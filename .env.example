# ===== 入出力（スプレッドシート / CSV） =====
# 'sheet' = Google Sheets API（サービスアカウント）/ 'gas' = GASウェブアプリ橋渡し / 'csv' = ローカルCSV
SOURCE=csv

# --- 方式①: Google Sheets API（サービスアカウント）を使う場合 ---
# スプレッドシートのID（URLの /d/ と /edit の間の文字列）
SHEET_ID=your-spreadsheet-id-here
# 対象シート（タブ）名
SHEET_TAB=シート1
# サービスアカウントJSONキーのパス（対象シートをこのSAのメールに「編集者」で共有しておくこと）
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# --- 方式②: GASウェブアプリ橋渡しを使う場合（GCP不要） ---
# gas-bridge/Code.gs をデプロイして得た /exec のURL
GAS_URL=https://script.google.com/macros/s/XXXXXXXXXXXXXXXXXXXXXXXX/exec
# status が空欄の行だけ処理（再開・差分更新）。true/false
ONLY_PENDING=false

# ===== URL発見（企業名 → 公式HP） — APIキー不要 =====
# 'bing' = Bing検索結果HTML（キー不要・無料・既定）/ 'duckduckgo' = DuckDuckGo HTML / 'none' = URL未入力行はNO_URL扱い
SEARCH_ENGINE=bing
# 検索エンジンへ連続クエリを投げる間隔（ミリ秒・礼儀）
SEARCH_DELAY_MS=1200

# ※ 外部AI API（Anthropic等）は使用しません。AI APIキーの設定は不要です。

# ===== クロール挙動（任意・上書き用）=====
# 連絡先を含む丁寧なUser-Agentにしてください
USER_AGENT=YourResearchBot/0.1 (+mailto:your-email@example.com)
CONCURRENCY=3
# 1サイト内で巡回する最大ページ数（トップ＋会社概要/お問い合わせ/採用 等の候補）
MAX_PAGES_PER_SITE=8
PER_PAGE_TIMEOUT_MS=15000
POLITE_DELAY_MS=1500
MAX_TEXT_CHARS=8000
CONFIDENCE_THRESHOLD=0.6

# =====================================================================
# ===== 統合パイプライン「究極の営業リスト」用（src/app.js）=====
# 下記は すべて任意。未設定なら自動でローカル・API不要の経路で動く。
# キーを入れた項目だけ高精度経路（gBizINFO/国税庁/Gemini/Hunter）に点火する。
# =====================================================================

# --- ICP（理想顧客像）。手動設定（Geminiキーが無くてもこれで発掘できる）---
# 商材説明（GEMINI_KEY があれば、これからICPを自動生成して下の手動設定を上書き）
PRODUCT_DESC=
# 既存受注（任意・改行/カンマ区切りの会社名など。ICP生成のヒント）
PRODUCT_EXISTING=
# 発掘対象の業種（カンマ区切り。gBiz検索語/Bing検索語に使用）
ICP_INDUSTRIES=
# 発掘対象の都道府県（カンマ区切り。空なら全国）
ICP_PREFECTURES=
# 従業員数レンジ（ICPの主軸フィルタ）
ICP_EMP_MIN=50
ICP_EMP_MAX=300
# 架電呼称の既定部署
ICP_DEPARTMENT=人事部
# 1回の発掘で集める目標社数
DISCOVER_TARGET=100

# --- 公的API（申請に数週間かかる。届いたら設定すれば自動で構造化発掘に切替）---
# gBizINFO REST API トークン（業種×地域の構造化発掘・代表者名/HP取得）
GBIZ_TOKEN=
# gBiz発掘の追加フィルタ（GBIZ_TOKEN がある時のみ効く）。
#  業種KWで事業概要・営業品目を部分一致フィルタ（カンマ区切り・OR）。空ならAPIの business_item のみ。
GBIZ_INDUSTRY_KEYWORDS=
#  事業概要が空の企業を残すか（true=取りこぼし防止 / false=精度優先）
GBIZ_KEEP_WHEN_NO_INDUSTRY_DATA=false
#  設立からの最低経過年数（新卒採用の継続性シグナル）。0で無効。
GBIZ_MIN_YEARS=0
#  補助金採択フラグを付与（source=4で突合・スコア加点）。trueでgBiz呼び出し約2倍。
GBIZ_ENRICH_SUBSIDY=false
# 国税庁 法人番号 Web-API アプリケーションID（商号→法人番号の名寄せ）
NTA_APP_ID=

# --- LLM（Google AI Studio の Gemini 無料枠）。あればICP生成と担当者抽出をAI化 ---
GEMINI_KEY=
# LLM_MODEL=gemini-flash-latest

# --- メール実在検証（任意・Hunter.io）。無ければMX篩い＋パターン推測のみ ---
HUNTER_KEY=
DO_EMAIL_VERIFY=false

# --- 出力（担当者マスタ）---
# 出力先タブ名（SHEET_ID＋サービスアカウントがあればこのタブへ upsert）
MASTER_TAB=担当者マスタ

# ===================================================================================
# ===== 多系統ソース統合・スコアリング・KPI（src/build-list.js / merge.js / source-kpi.js）=====
# すべて既定値あり。未設定でも sources/manifest.json から動く。
# ===================================================================================
# 採用インテントを上書きするトリガー列（系統C・truthyで各1★加点）
INTENT_TRIGGER_COLS=プレスリリース,出稿増,採用ページ更新,インテント,辞退シグナル
# 新卒採用フラグを示す列（いずれかtruthyで「新卒フラグ確定」=採用インテントの背骨）
SHINSOTSU_FLAG_COLS=新卒フラグ,新卒出稿,現在求人掲載中
# 属性ランク（A/B/C）の ICP適合スコア閾値
GRADE_A_MIN=75
GRADE_B_MIN=50
# 系統Cトリガーで優先度を1段引き上げる最低★（"今動いている"の割り込み）
INTENT_OVERRIDE_STARS=3
# --- ソース別KPI（設計#9「必ず回す」）---
# 「ICP適合」とみなす品質スコア下限（適合率の分子）
KPI_FIT_SCORE_MIN=60
# 評価サイクル（設計: 2週間）
KPI_CYCLE_DAYS=14
