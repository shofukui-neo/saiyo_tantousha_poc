{"url":"http://www.miyazaki-group.com/recruiting/staff/01.html","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n<head>\n<!-- Google tag (gtag.js) -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-G41M5YF4VE\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'G-G41M5YF4VE');\n</script>\n  <meta charset=\"UTF-8\">\n  <title>STAFF01 | 株式会社宮崎商店</title>\n  <meta name=\"description\" content=\"岩手の地元に密着70年。宮崎商店のホームページようこそ。\">\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1.0,minimum-scale=1.0,user-scalable=no\">\n  <meta name=\"format-detection\" content=\"telephone=no\">\n  <link rel=\"stylesheet\" href=\"/assets/css/style.min.css\">\n  <link href=\"https://fonts.googleapis.com/css?family=Poppins:400,600,700\" rel=\"stylesheet\">\n</head>\n<body class=\"\">\n  <div class=\"l-wrapper l-header__overlay\">\n\n    <header class=\"l-header\">\n      <div class=\"l-header__inner\">\n        <div class=\"l-header__head\">\n          <p class=\"l-header__logo\">\n            <a href=\"/\">\n              <img src=\"/assets/images/common/logo_corp_header.png\" alt=\"宮崎商店\">\n            </a>\n          </p>\n          <div class=\"l-header__nav-icon js-gnav-toggle\">\n            <span></span>\n          </div>\n        </div>\n\n        <nav class=\"l-header__body js-gnav-list\">\n          <ul class=\"l-header__list\">\n            <li class=\"l-header__item\">\n              <a class=\"l-header__link l-header__link--01\" href=\"/recruiting/\">リクルーティング</a>\n            </li>\n            <li class=\"l-header__item\">\n              <a class=\"l-header__link l-header__link--02\" href=\"/business/\">事業案内</a>\n            </li>\n            <li class=\"l-header__item\">\n              <a class=\"l-header__link l-header__link--03\" href=\"/company/\">会社案内</a>\n            </li>\n            <li class=\"l-header__item\">\n              <a class=\"l-header__link l-header__link--04\" href=\"https://www.talent-clip.jp/miyazaki-group/\" target=\"_blank\">採用情報</a>\n            </li>\n            <li class=\"l-header__item\">\n              <a class=\"l-header__link l-header__link--05\" href=\"/contact/\">お問い合わせ</a>\n            </li>\n            <li class=\"l-header__item l-header-sub\">\n              <span class=\"l-header__link l-header__link--fb js-fb-toggle\">Facebook</span>\n              <ul class=\"l-header-sub__list\">\n                <li class=\"l-header-sub__item\">\n                  <a class=\"l-header-sub__link\" href=\"https://www.facebook.com/%E5%AE%AE%E5%B4%8E%E5%95%86%E5%BA%97-2062845797276368/\" target=\"_blank\">Facebook 宮崎商店</a>\n                </li>\n                <li class=\"l-header-sub__item\">\n                  <a class=\"l-header-sub__link\" href=\"https://www.facebook.com/spasentoyukkomorioka/\" target=\"_blank\">Facebook ゆっこ盛岡</a>\n                </li>\n                <li class=\"l-header-sub__item is-no-link\">\n                  <a class=\"l-header-sub__link\">COMING SOON !</a>\n                </li>\n              </ul>\n            </li>\n          </ul>\n        </nav>\n      </div>\n    </header>\n\n\n    <section class=\"l-main\">\n\n      <div class=\"c-breadcrumb\">\n        <div class=\"c-inner\">\n          <ul class=\"c-breadcrumb__list\">\n            <li class=\"c-breadcrumb__item\"><a href=\"/\">HOME</a></li>\n            <li class=\"c-breadcrumb__item\"><a href=\"/recruiting/\">リクルーティング</a></li>\n            <li class=\"c-breadcrumb__item\">STAFF01</li>\n          </ul>\n        </div>\n      </div>\n\n      <div class=\"l-contents u-pt-0\">\n        <div class=\"p-staff p-staff--01\">\n          <div class=\"p-staff__inner\">\n\n            <section class=\"p-staff__box\">\n\n              <p class=\"p-staff__department p-staff__department--other\">\n                <span class=\"p-staff__department__en\">ACCOUNTING</span>\n                <br class=\"pc-hidden\"><span class=\"p-staff__department__jp\">経理部</span>\n              </p>\n\n              <div class=\"c-hdg-lv1 p-staff__ttl\">\n                <h1 class=\"c-hdg-lv1__txt\">緊張感にもやりがいを感じます。</h1>\n              </div>\n\n\n              <section class=\"p-staff__paragraph\">\n                <div class=\"c-hdg-lv2 c-hdg-lv2--simple\">\n                  <h2 class=\"c-hdg-lv2__txt\">未経験の自分に、チャンスを与えてくれた</h2>\n                </div>\n\n                <p>以前は販売や人事の仕事をしていましたが、大学の経済学部で学んだ知識をいかし、経理の仕事に就きたいと考えていました。そんな時、宮崎商店が経理担当者を募集していることを知り応募、採用が決まりました。未経験者である私にチャンスを与えてくれたこと、ありがたいと思っています。</p>\n              </section>\n\n\n              <section class=\"p-staff__paragraph\">\n                <div class=\"c-hdg-lv2 c-hdg-lv2--simple\">\n                  <h2 class=\"c-hdg-lv2__txt\">業務内容が幅広く、学ぶことがたくさん</h2>\n                </div>\n\n                <p>経理担当としてお金の流れを把握し、経営の近くでさまざまな知識を吸収できるのはとても面白いです。経理は正確性を求められる仕事ですが、その緊張感にもやりがいを感じます。一方で、経理の知識、社内の業務体制の知識、そして業界に対する知識がまだまだ足りないことも実感。上司や先輩にフォローしていただきながら経理のスペシャリストを目指しブラッシュアップしていきます。</p>\n              </section>\n\n\n              <p class=\"p-staff__paragraph\">\n                <img src=\"/assets/images/recruiting/staff/01/img_01.jpg\" alt=\"\">\n              </p>\n\n              <div class=\"p-staff__data\">\n                <div class=\"p-staff-data\">\n                  <h2 class=\"p-staff-data__ttl\">DATA</h2>\n                  <div class=\"p-staff-data__right\">\n                    <p class=\"p-staff-data__name\">本社 経理部<br>磯島 実  福島大学 卒</p>\n                    <p class=\"p-staff-data__career\">青森県出身。大学卒業後、他社で販売業務や人事担当業務に従事していたが、もともと希望していた経理の仕事に就くため2016年7月に入社。</p>\n                  </div>\n                </div>\n              </div>\n            </section>\n          </div><!-- /.p-staff__inner -->\n\n\n          <div class=\"p-staff-nav\">\n            <nav class=\"p-staff-nav__inner\">\n              <ul class=\"p-staff-nav__list\">\n                <li class=\"p-staff-nav__item\">\n                  <a class=\"p-staff-nav__link is-staff-current\">\n                    <div class=\"p-staff-nav__icon\">\n                      <img src=\"/assets/images/recruiting/staff/common/icon_nav_01.png\" alt=\"\">\n                    </div>\n                    <div class=\"p-staff-nav__txt\">\n                      <p class=\"p-staff-nav__stars\">MIYAZAKI RISING STARS!</p>\n                      <p class=\"p-staff-nav__num\">#001</p>\n                    </div>\n                  </a>\n                </li>\n                <li class=\"p-staff-nav__item\">\n                  <a class=\"p-staff-nav__link\" href=\"/recruiting/staff/02.html\">\n                    <div class=\"p-staff-nav__icon\">\n                      <img src=\"/assets/images/recruiting/staff/common/icon_nav_02.png\" alt=\"\">\n                    </div>\n                    <div class=\"p-staff-nav__txt\">\n                      <p class=\"p-staff-nav__stars\">MIYAZAKI RISING STARS!</p>\n                      <p class=\"p-staff-nav__num\">#002</p>\n                    </div>\n                  </a>\n                </li>\n                <li class=\"p-staff-nav__item\">\n                  <a class=\"p-staff-nav__link\" href=\"/recruiting/staff/03.html\">\n                    <div class=\"p-staff-nav__icon\">\n                      <img src=\"/assets/images/recruiting/staff/common/icon_nav_03.png\" alt=\"\">\n                    </div>\n                    <div class=\"p-staff-nav__txt\">\n                      <p class=\"p-staff-nav__stars\">MIYAZAKI RISING STARS!</p>\n                      <p class=\"p-staff-nav__num\">#003</p>\n                    </div>\n                  </a>\n                </li>\n                <li class=\"p-staff-nav__item\">\n                  <a class=\"p-staff-nav__link\" href=\"/recruiting/staff/04.html\">\n                    <div class=\"p-staff-nav__icon\">\n                      <img src=\"/assets/images/recruiting/staff/common/icon_nav_04.png\" alt=\"\">\n                    </div>\n                    <div class=\"p-staff-nav__txt\">\n                      <p class=\"p-staff-nav__stars\">MIYAZAKI RISING STARS!</p>\n                      <p class=\"p-staff-nav__num\">#004</p>\n                    </div>\n                  </a>\n                </li>\n                <li class=\"p-staff-nav__item\">\n                  <a class=\"p-staff-nav__link\" href=\"/recruiting/staff/05.html\">\n                    <div class=\"p-staff-nav__icon\">\n                      <img src=\"/assets/images/recruiting/staff/common/icon_nav_05.png\" alt=\"\">\n                    </div>\n                    <div class=\"p-staff-nav__txt\">\n                      <p class=\"p-staff-nav__stars\">MIYAZAKI RISING STARS!</p>\n                      <p class=\"p-staff-nav__num\">#005</p>\n                    </div>\n                  </a>\n                </li>\n                <!--li class=\"p-staff-nav__item\">\n                  <a class=\"p-staff-nav__link\" href=\"/recruiting/staff/06.html\">\n                    <div class=\"p-staff-nav__icon\">\n                      <img src=\"/assets/images/recruiting/staff/common/icon_nav_06.png\" alt=\"\">\n                    </div>\n                    <div class=\"p-staff-nav__txt\">\n                      <p class=\"p-staff-nav__stars\">MIYAZAKI RISING STARS!</p>\n                      <p class=\"p-staff-nav__num\">#006</p>\n                    </div>\n                  </a>\n                </li-->\n              </ul>\n            </nav>\n          </div>\n\n\n        </div><!-- /.p-staff -->\n      </div>\n\n    </section><!-- /.l-main -->\n    <style>\n      @media screen and (min-width: 769px) {\n        .p-staff-nav__list {\n          justify-content: flex-start;\n        }\n        .p-staff-nav__item {\n          margin-right: 12px;\n        }\n        .p-staff-nav__item:nth-child(3n) {\n          margin-right: 0;\n        }\n      }\n    </style>\n\n    <footer class=\"l-footer\">\n      <div class=\"l-footer__links\">\n        <p class=\"l-footer-links__corporate-logo\">\n          <a href=\"/\">\n            <img src=\"/assets/images/common/logo_corp_footer.png\" alt=\"宮崎商店 Miyazaki Syoten Ltd.\">\n          </a>\n        </p>\n        <nav class=\"l-footer-links__nav\">\n          <ul class=\"l-footer-links__list\">\n            <li class=\"l-footer-links__item\">\n              <a href=\"/privacy/\">個人情報保護方針</a>\n            </li>\n            <li class=\"l-footer-links__item\">\n              <a href=\"/sitemap.html\">サイトマップ</a>\n            </li>\n          </ul>\n        </nav>\n      </div>\n\n      <div class=\"l-footer__copyright\">\n        <p>\n          Copyright 2017(c) Miyazaki Syoten Co.,Ltd. All Rights Reserved.\n        </p>\n      </div>\n    </footer>\n\n\n  </div><!-- /.l-wrapper -->\n\n  <script src=\"/assets/js/jquery-3.1.1.min.js\"></script>\n  <script src=\"/assets/js/jquery.easing.1.3.js\"></script>\n  <script src=\"/assets/js/slick.min.js\"></script>\n  <script src=\"/assets/js/jquery.fadethis.min.js\"></script>\n  <script src=\"/assets/js/common.js\"></script>\n\n</body>\n</html>","finalUrl":"http://www.miyazaki-group.com/recruiting/staff/01.html","rendered":false,"_cachedAt":"2026-06-17T23:28:50.701Z"}