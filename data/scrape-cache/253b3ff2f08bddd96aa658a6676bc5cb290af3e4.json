g/top_allow.png\" alt=\"トップに戻る\"></a>\r\n  </div>\r\n  </header>\r\n\r\n\r\n    <main>\r\n\r\n\r\n\r\n      <section id=\"recruit-info_main\">\r\n        <div class=\"inner\">\r\n          <figure class=\"title-line-small\">\r\n            <img src=\"../assets/img/title-line-small.png\" alt=\"ライン\">\r\n          </figure>\r\n          <h2><span>A</span>PPLICATION <span>G</span>UIDELINES</h2>\r\n          <p>採用情報</p>\r\n          <div class=\"recruit-info_table\">\r\n            <dl>\r\n              <dt>募集職種</dt>\r\n              <dd>総合職</dd>\r\n            </dl>\r\n            <dl>\r\n              <dt>募集対象</dt>\r\n              <dd>4年制大学または、大学院を卒業(修了)見込みの方</dd>\r\n            </dl>\r\n            <dl>\r\n              <dt>募集学科</dt>\r\n              <dd>全学部、全学科</dd>\r\n            </dl>\r\n            <dl>\r\n              <dt>雇用形態</dt>\r\n              <dd>正社員</dd>\r\n            </dl>\r\n            <dl>\r\n              <dt>給与</dt>\r\n              <dd>学部：月給220,000円(基本給)<br>\r\n                修士：月給233,000円(基本給)<br>\r\n                ※2025年4月実績：220,000円(学部)、233,000(修士)</dd>\r\n            </dl>\r\n            <dl>\r\n              <dt>諸手当</dt>\r\n              <dd>通勤手当、時間外手当、扶養手当、単身赴任手当、ペット手当、営業手当</dd>\r\n            </dl>\r\n            <dl>\r\n              <dt>昇給</dt>\r\n              <dd>年1回</dd>\r\n            </dl>\r\n            <dl>\r\n              <dt>賞与</dt>\r\n              <dd>年2回(7月・12月)</dd>\r\n            </dl>\r\n            <dl>\r\n              <dt>休日休暇</dt>\r\n              <dd>週休2日制(土曜日・日曜日)、年間休日117日<br>\r\n                ※会社指定の土曜出勤日有り<br>\r\n                祝日、夏季休暇、年末年始休暇、慶弔休暇、年次有給休暇など</dd>\r\n            </dl>\r\n            <dl>\r\n              <dt>勤務地</dt>\r\n              <dd>本社(大阪)<br>\r\n                各営業所(札幌、仙台、東京、名古屋、広島、福岡)<br>\r\n                関西ロジスティクスセンター(大阪)</dd>\r\n            </dl>\r\n            <dl>\r\n              <dt>勤務時間</dt>\r\n              <dd>9時00分~17時30分　(休憩60分含む/実働7時間30分)</dd>\r\n            </dl>\r\n       