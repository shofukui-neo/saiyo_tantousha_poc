{"url":"https://asahi-ad.co.jp/recruiting/environment/","html":"<!DOCTYPE html>\r\n<html lang=\"ja\">\r\n\r\n<head>\r\n<!-- Google Tag Manager -->\r\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\r\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\r\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\r\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\r\n})(window,document,'script','dataLayer','GTM-53RNMQF');</script>\r\n<!-- End Google Tag Manager -->\r\n    \r\n    <meta charset=\"UTF-8\">\r\n    <title>職場環境 | 株式会社旭広告社 採用情報</title>\r\n    <meta name=\"description\" content=\"株式会社旭広告社の採用情報サイト、職場環境ページです。働き方改革に積極的に取り組み、やりがいをもって自分らしく働けるよう労働環境の整備に取り組んでいます。\" />\r\n    <meta name=\"keywords\" content=\"2026,採用,新卒,中途,エントリー,広告,代理店,横浜,地域貢献\" />\r\n    <meta property=\"og:title\" content=\"株式会社旭広告社 採用情報\" />\r\n    <meta property=\"og:type\" content=\"website\" />\r\n    <meta property=\"og:url\" content=\"https://www.asahi-ad.co.jp/recruiting/\" />\r\n    <meta property=\"og:image\" content=\"https://www.asahi-ad.co.jp/recruiting/images/asahi_og.png\" />\r\n    <meta property=\"og:site_name\" content=\"株式会社旭広告社 採用情報\" />\r\n    <meta property=\"og:description\" content=\"横浜の総合広告代理店、株式会社旭広告社の採用情報サイトです。仕事内容・社員インタビュー・福利厚生など、採用に関する情報をご紹介します。\" />\r\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\">\r\n    <link href=\"https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500&family=Roboto&display=swap\" rel=\"stylesheet\">\r\n    <link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/yakuhanjp@3.4.1/dist/css/yakuhanjp-noto.min.css\">\r\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"../js/drawer/drawer.css\">\r\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"../css/base.css\">\r\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"../css/environment.css?02050204v4\">\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no\" />\r\n\t\r\n<link rel=\"shortcut icon\" href=\"../favicon.ico\">\r\n<link rel=\"apple-touch-icon\" href=\"../apple-touch-icon.png\">\r\n<link rel=\"icon\" type=\"image/png\" href=\"../android-chrome-192x192.png\">\r\n</head>\r\n\r\n<body class=\"drawer drawer--right\">\r\n<!-- Google Tag Manager (noscript) -->\r\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-53RNMQF\"\r\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\r\n<!-- End Google Tag Manager (noscript) -->    \r\n    <div class=\"drawer_container\">\r\n        <button type=\"button\" class=\"drawer-toggle drawer-hamburger\">\r\n            <span class=\"sr-only\">toggle navigation</span>\r\n            <span class=\"drawer-hamburger-icon\"></span>\r\n        </button>\r\n        <nav class=\"drawer-nav\" role=\"navigation\">\r\n            <ul class=\"drawer-menu\">\r\n                <li class=\"drawer_logo\"><a href=\"../\"><img src=\"../images/footer_logo.png\" alt=\"株式会社旭広告社\"></a></li>\r\n                <li><a href=\"../\" class=\"drawer-menu-item\">HOME</a></li>\r\n                <li><a href=\"../message/\" class=\"drawer-menu-item\">社長メッセージ</a></li>\r\n                <li><a href=\"../interview/\" class=\"drawer-menu-item\">社員インタビュー</a></li>\r\n                <li><a href=\"../job/\" class=\"drawer-menu-item\">旭広告社の仕事を知る</a></li>\r\n                <li><a href=\"../data/\" class=\"drawer-menu-item\">DATAで見る旭広告社</a></li>\r\n                <li><a href=\"../welfare/\" class=\"drawer-menu-item\">福利厚生</a></li>\r\n                <li><a href=\"../environment/\" class=\"drawer-menu-item\">職場環境</a></li>\r\n                <li><a href=\"../recruit/\" class=\"drawer-menu-item\">採用情報</a></li>\r\n                <li class=\"st\">エントリー</li>\r\n                <li><a href=\"https://job.rikunabi.com/n/selection/job_descriptions/0fd0d43359bd8a60/?from=job_search\" class=\"drawer-menu-item\" target=\"new\" rel=\"nofollow\">新卒採用</a></li>\r\n                <li><a href=\"../recruit/#tab2\" class=\"drawer-menu-item\">中途採用</a></li>\r\n                <li class=\"st\">企業情報</li>\r\n                <li><a href=\"https://asahi-ad.co.jp/\" class=\"drawer-menu-item drawer-menu-item2\" target=\"_blank\">コーポレートサイト</a></li>\r\n                <li><a href=\"https://asahi-ad.co.jp/about/privacy-policy/\" class=\"drawer-menu-item drawer-menu-item2\" target=\"_blank\">プライバシーポリシー</a></li>\r\n            </ul>\r\n        </nav>\r\n    </div>\r\n\r\n    <header id=\"header\" class=\"cf\">\r\n        <p class=\"header_logo\"><a href=\"../\"><img src=\"../images/logo.png\" alt=\"株式会社旭広告社\"></a><span>RECRUIT</span></p>\r\n        <nav id=\"gnavi\">\r\n            <ul class=\"menu cf\">\r\n                <li><a href=\"../message/\">社長メッセージ</a></li>\r\n                <li><a href=\"../interview/\">社員インタビュー</a></li>\r\n                <li><a href=\"../job/\">旭広告社の仕事を知る</a></li>\r\n                <li><a href=\"../data/\">DATAで見る旭広告社</a></li>\r\n                <li><a href=\"../welfare/\">福利厚生</a></li>\r\n                <li><a href=\"../environment/\" class=\"on\">職場環境</a></li>\r\n                <li><a href=\"../recruit/\">採用情報</a></li>\r\n            </ul>\r\n            <ul class=\"entry\">\r\n                <li class=\"item\"><span>&gt; ENTRY</span>\r\n                    <ul class=\"child\">\r\n                        <!--<li><a href=\"../news/\">&gt; 新卒採用</a></li>-->\r\n                        <li><a href=\"https://job.rikunabi.com/n/selection/job_descriptions/0fd0d43359bd8a60/?from=job_search\" target=\"new\" rel=\"nofollow\">&gt; 新卒採用</a></li>\r\n                        <li><a href=\"../recruit/#tab2\">&gt; 中途採用</a></li>\r\n                    </ul>\r\n                </li>\r\n            </ul>\r\n        </nav>\r\n    </header>\r\n\r\n    <div id=\"page_title\">\r\n        <div class=\"inner1\">\r\n            <p>Environment</p>\r\n            <h1>職場環境</h1>\r\n        </div>\r\n    </div>\r\n\r\n    <div id=\"breadcrumb\">\r\n        <div class=\"inner1\">\r\n            <ul class=\"cf\">\r\n                <li><a href=\"../\">ホーム</a></li>\r\n                <li>職場環境</li>\r\n            </ul>\r\n        </div>\r\n    </div>\r\n\r\n    <section id=\"environment1\">\r\n        <div class=\"inner1\">\r\n            <div class=\"env_intro\">\r\n                <h2>旭広告社の職場環境</h2>\r\n                <p>働き方改革に積極的に取り組み、やりがいをもって自分らしく働けるよう<br class=\"br_768_none\">労働環境の整備に取り組んでいます。</p>\r\n            </div>\r\n        </div>\r\n    </section>\r\n\r\n\r\n    <section id=\"environment2\">\r\n        <div class=\"inner1\">\r\n            <h2>キャリアステップイメージ</h2>\r\n            <div class=\"env_box\">\r\n                <figure><a href=\"images/env_1.png\" target=\"_blank\"><img src=\"images/env_1.png\" alt=\"\"></a></figure>\r\n                <p><span class=\"bold\">まずは、社会人としての基礎づくりからスタート！</span><br>\r\n                    幅広い経験を積みながら、個人の適正・能力に合わせて成長をサポートしていきます。</p>\r\n                <dl class=\"cf\">\r\n                    <dt class=\"dt1\">一般社員</dt>\r\n                    <dd>\r\n                        <p><span class=\"bold\">計画と実行</span><br>\r\n                            目標管理の流れと意味を知り、新人育成計画に沿った活動とともに、基本的な知識やビジネスの基礎を学び仕事の質を高める。</p>\r\n                        <p>・マナーを身につけルールを守る<br>\r\n                            ・理解力を高める<br>\r\n                            ・PDCAサイクルの実行<br>\r\n                            ・報連相の実行<br>\r\n                            ・優先順位を判断し指示の励行</p>\r\n                    </dd>\r\n                </dl>\r\n                <dl class=\"cf\">\r\n                    <dt class=\"dt2\">主任</dt>\r\n                    <dd>\r\n                        <p><span class=\"bold\">チャレンジと成果</span><br>\r\n                            設定された方針に基づいた目標の立案と達成に向かい、売上・利益計画数値の設定と必達ポイントとなる期日管理の徹底を行う。</p>\r\n                        <p>・計画・計画能力を養う<br>\r\n                            ・工夫改善力・折衝力を養う<br>\r\n                            ・利益感覚を持つ<br>\r\n                            ・目標に向けチャレンジ意欲を持つ</p>\r\n                    </dd>\r\n                </dl>\r\n                <dl class=\"cf\">\r\n                    <dt class=\"dt3\">係長／課長代理</dt>\r\n                    <dd>\r\n                        <p><span class=\"bold\">チームリーダー</span><br>\r\n                            方針を設定し目標の立案と達成に向け、的確なマーケティング能力による他力活用や一人2役3役の推進を行う。</p>\r\n                        <p>・リーダー的能力を高める<br>\r\n                            ・マネジメント能力を高める<br>\r\n                            ・渉外能力を養う<br>\r\n                            ・開発能力を養う<br>\r\n                            ・他人の利益も図る姿勢を持つ</p>\r\n                    </dd>\r\n                </dl>\r\n                <dl class=\"cf\">\r\n                    <dt class=\"dt4\">課長／副部長</dt>\r\n                    <dd>\r\n                        <p><span class=\"bold\">マネジメント</span><br>\r\n                            組織の活性化策を打ち出し、的確な情報収集・市場調査により、部・課の統率と運営を行う。</p>\r\n                        <p>・目標・方針の実現化<br>\r\n                            ・セルフマネジメントの実行・完遂<br>\r\n                            ・会社全体のマンパワー効率を考える<br>\r\n                            ・部内外との協力体制の確立<br>\r\n                            ・指導統率力の向上</p>\r\n                    </dd>\r\n                </dl>\r\n                <dl class=\"cf\">\r\n                    <dt class=\"dt5\">部長</dt>\r\n                    <dd class=\"dd2\">\r\n                        <p><span class=\"bold\">経営者マインド</span><br>\r\n                            部の戦術立案と達成に向け、先行数字管理をしながら、部下の目標サポートを行う。また、動向の情報収集をし分析する。</p>\r\n                        <p>・目標・方針の実現化<br>\r\n                            ・セルフマネジメントの実行・完遂<br>\r\n                            ・会社全体のマンパワー効率を考える<br>\r\n                            ・部内外との協力体制の確立<br>\r\n                            ・指導統率力の向上</p>\r\n                    </dd>\r\n                </dl>\r\n            </div>\r\n        </div>\r\n    </section>\r\n\r\n\r\n    <section id=\"environment3\">\r\n        <div class=\"inner1\">\r\n            <h2>社員が働きやすい環境の整備</h2>\r\n\r\n            <div class=\"env_box2 cf\">\r\n                <figure><img src=\"images/env_2_01.png\" alt=\"\"></figure>\r\n                <div class=\"txt\">\r\n                    <h3>よこはまグッドバランス賞 認定</h3>\r\n                    <p>社員の声を聴き課題を解決する姿勢が評価され認定されました。</p>\r\n                    <div class=\"txt_box\">\r\n                        <p>横浜市では、女性の活躍やワーク・ライフ・バランスを推進するため、男女がともに働きやすい職場環境づくりを積極的に進める市内中小企業等を「よこはまグッドバランス賞」として認定しています。</p>\r\n                        <p>よこはまグッドバランス賞について：<br>\r\n                            <a href=\"https://www.city.yokohama.lg.jp/city-info/seisaku/torikumi/danjo/balance/hyoshou.html\" target=\"_blank\">https://www.city.yokohama.lg.jp/city-info/seisaku/torikumi/danjo/balance/hyoshou.html</a>\r\n                        </p>\r\n                    </div>\r\n                    <div class=\"txt_box2\">\r\n                        <p>当社ではワークライフバランス推進に取り組んでおります。</p>\r\n                        <a href=\"https://positive-ryouritsu.mhlw.go.jp/positivedb/\" target=\"_blank\" rel=\"nofollow\" class=\"first-link\"><img src=\"images/db_banner.jpg\" alt=\"女性の活躍推進企業\"></a>\r\n                        <a href=\"https://ryouritsu.mhlw.go.jp/\" target=\"_blank\" rel=\"nofollow\"><img src=\"images/ryoritsu.jpg\" alt=\"両立支援のひろば\"></a>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n\r\n            <div class=\"env_box2 cf\">\r\n                <figure><img src=\"images/env_2_02.png\" alt=\"\"></figure>\r\n                <div class=\"txt\">\r\n                    <h3>横浜健康経営 認定</h3>\r\n                    <p>健康課題に即した取り組みが評価され認定されました。</p>\r\n                    <div class=\"txt_box\">\r\n                        <p>横浜市では、従業員等の健康保持・増進の取組が、将来的に企業の収益性等を高める投資であると捉え、従業員等の健康づくりを経営的な視点から考え、戦略的に実践する「健康経営」の概念を幅広く普及させるため、健康経営に取り組む事業所を、横浜健康経営認証事業所として認証します。</p>\r\n                        <p>横浜健康経営認証について：<br>\r\n                            <a href=\"https://www.city.yokohama.lg.jp/kurashi/kenko-iryo/kenkozukuri/kakushu/life_style/ninsho/page01.html\" target=\"_blank\">https://www.city.yokohama.lg.jp/kurashi/kenko-iryo/kenkozukuri/kakushu/life_style/ninsho/page01.html</a>\r\n                        </p>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n        </div>\r\n    </section>\r\n\r\n\r\n    <section id=\"environment4\">\r\n        <div class=\"inner1\">\r\n            <h2>制度・待遇</h2>\r\n            <ul class=\"cf\">\r\n                <li class=\"env_item\">\r\n                    <figure><img src=\"images/env_3_01.png\" alt=\"資格取得制度\"></figure>\r\n                    <dl>\r\n                        <dt>技能資格手当</dt>\r\n                        <dd>会社指定技能資格を取得した人には手当として支給されます。</dd>\r\n                    </dl>\r\n                </li>\r\n                <li class=\"env_item\">\r\n                    <figure><img src=\"images/env_3_03.png\" alt=\"シフト通勤制度\"></figure>\r\n                    <dl>\r\n                        <dt>シフト通勤制度</dt>\r\n                        <dd>働き方改革の一環として、社員の生活スタイルに合った勤務時間を設定できるよう、シフト勤務を申請することができます。</dd>\r\n                    </dl>\r\n                </li>\r\n                <li class=\"env_item\">\r\n                    <figure><img src=\"images/env_3_04.png\" alt=\"携帯電話・タブレット貸与\"></figure>\r\n                    <dl>\r\n                        <dt>携帯電話・タブレット貸与</dt>\r\n                        <dd>携帯電話は、迅速な対応に便利で、iPadは、出先からでも会社のパソコンが共有できるため、メールの確認や日報入力、資料提示や実際の写真を見せるときなどに使用します。</dd>\r\n                    </dl>\r\n                </li>\r\n                <li class=\"env_item\">\r\n                    <figure><img src=\"images/env_3_05.png\" alt=\"研修制度\"></figure>\r\n                    <dl>\r\n                        <dt>研修制度</dt>\r\n                        <dd>\r\n                            <ul>\r\n                                <li>・新入社員研修</li>\r\n                                <li>・OJT研修</li>\r\n                                <li>・マーケティング研修</li>\r\n                                <li>・リーダー研修</li>\r\n                                <li>・自分に合った研修が受講できる、<br>外部人材育成研修</li>\r\n                            </ul>\r\n                        </dd>\r\n                    </dl>\r\n                </li>\r\n                <li class=\"env_item\">\r\n                    <figure><img src=\"images/env_3_06.png\" alt=\"異動希望届制度\"></figure>\r\n                    <dl>\r\n                        <dt>異動希望届制度</dt>\r\n                        <dd>自分が、将来どのような人材に成長したいのか、どのような部署に異動して何をしたいのか、希望を明記して提出します。</dd>\r\n                    </dl>\r\n                </li>\r\n                <li class=\"env_item\">\r\n                    <figure><img src=\"images/env_3_07.png\" alt=\"10％ルール\"></figure>\r\n                    <dl>\r\n                        <dt>10％ルール</dt>\r\n                        <dd>目的として、メイン業務から離れて、広い視点で自由な発想を生み出すために、10％の時間を費やし、普段は一緒に仕事をしない同僚と協力して新たな試みに挑戦し知識やスキルを得ます。</dd>\r\n                    </dl>\r\n                </li>\r\n                <li class=\"env_item\">\r\n                    <figure><img src=\"images/env_3_08.png\" alt=\"社内表彰制度\"></figure>\r\n                    <dl>\r\n                        <dt>社内表彰制度</dt>\r\n                        <dd>全社員を対象とした表彰制度があります。半期に1回賞賛され、キックオフミーティングで発表・表彰します。社員のモチベーション向上にもつながっています。</dd>\r\n                    </dl>\r\n                </li>\r\n                <li class=\"env_item\">\r\n                    <figure><img src=\"images/env_3_09.png\" alt=\"展示会補助金制度\"></figure>\r\n                    <dl>\r\n                        <dt>展示会補助金制度</dt>\r\n                        <dd>一流を知ることで感性を養う機会を広げていただきたいという趣旨をもとに、1回1,000円を上限として、年間12回まで使用できます。</dd>\r\n                    </dl>\r\n                </li>\r\n                <li class=\"env_item\">\r\n                    <figure><img src=\"images/env_3_10.png\" alt=\"17時間プロジェクト\"></figure>\r\n                    <dl>\r\n                        <dt>17時間プロジェクト</dt>\r\n                        <dd>希望するプロジェクトに月17時間まで参加することを認められ、実践で仕事を学べるほか、他業種の方や協力会社との交流により、自部署での業務幅の広がりやノウハウに生かすことができます。</dd>\r\n                    </dl>\r\n                </li>\r\n            </ul>\r\n        </div>\r\n    </section>\r\n\r\n   <div id=\"01\" class=\"alink\"></div>  \r\n    <section id=\"environment5\">\r\n        <div class=\"inner1\">\r\n            <h2>研修・教育</h2>\r\n            <div class=\"training_box\">\r\n                <!--<div class=\"training_w\">\r\n                    <div class=\"txt_training\">研修は社員の成長やスキル向上を促し、それにより高いモチベーションと自信を持って業務に取り組むことができるようになります。スキルアップ研修では、業務遂行能力が向上し、自己肯定感や自己信頼を高めることにつながります。研修で得た学びは現場で活かすことで、企業のミッション達成や業務改善にもつながっていきます。</div>\r\n                    <div class=\"img_training_w\">\r\n                        <div class=\"img_training\"><img src=\"images/training1.jpg\"></div>\r\n                        <div class=\"img_training\"><img src=\"images/training2.webp\"></div>\r\n                        <div class=\"img_training\"><img src=\"images/training3.webp\"></div>\r\n                        <div class=\"img_training\"><img src=\"images/training2.jpg\"></div>\r\n                    </div>\r\n                </div>-->\r\n             <!--   <div class=\"training_w\">\r\n\r\n  <div class=\"training_left\">\r\n\r\n    <div class=\"txt_training\">\r\n      研修は社員の成長やスキル向上を促し、それにより高いモチベーションと自信を持って業務に取り組むことができるようになります。スキルアップ研修では、業務遂行能力が向上し、自己肯定感や自己信頼を高めることにつながります。研修で得た学びは現場で活かすことで、企業のミッション達成や業務改善にもつながっていきます。\r\n    </div>\r\n\r\n    <div class=\"training_certificate\">\r\n\r\n      <div class=\"img_training\">\r\n        <img src=\"images/training2.webp\" alt=\"\">\r\n      </div>\r\n\r\n      <div class=\"img_training\">\r\n        <img src=\"images/training3.webp\" alt=\"\">\r\n      </div>\r\n\r\n    </div>\r\n\r\n  </div>\r\n\r\n  <div class=\"training_photo_column\">\r\n\r\n    <div class=\"img_training\">\r\n      <img src=\"images/training1.jpg\" alt=\"\">\r\n    </div>\r\n\r\n    <div class=\"img_training\">\r\n      <img src=\"images/training2.jpg\" alt=\"\">\r\n    </div>\r\n\r\n  </div>\r\n\r\n</div>-->\r\n\t\t\t\t\r\n\t\t\t\t\r\n\t\t\t\t<div class=\"training_w\">\r\n\r\n    <div class=\"training_left\">