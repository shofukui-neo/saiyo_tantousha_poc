{"url":"https://www.taiseikiko.com/recruit/","html":"\n<!DOCTYPE html>\n<html lang=\"ja\">\n\n<head>\n  <script src=\"shared/js/ga.js\"></script>\n  <meta charset=\"UTF-8\">\n  <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n  \r\n<title>リクルート｜不断水工法の大成機工</title>\r\n<meta name=\"description\" content=\"リクルート | 不断水工法の大成機工、上下水道・ガス管用特殊継手並びに機械器具を製造販売\">\r\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n<meta name=\"format-detection\" content=\"telephone=no\">\r\n\r\n<link rel=\"icon\" href=\"shared/images/common/favicon_32x32.png\" sizes=\"32x32\" />\r\n<link rel=\"icon\" href=\"shared/images/common/favicon_192x192.png\" sizes=\"192x192\" />\r\n<link rel=\"apple-touch-icon-precomposed\" href=\"shared/images/common/favicon_180x180.png\" />\r\n        <!--▲▲トップページ▲▲-->\r\n<!-- 「top」限定 -->\r\n   <!--▲▲トップページ▲▲-->\r\n   <link rel=\"stylesheet\" href=\"https://use.fontawesome.com/releases/v5.7.0/css/all.css\" integrity=\"sha384-lZN37f5QGtY3VHgisS14W3ExzMWZxybE1SJSEsQp9S+oqd12jhcu+A56Ebc1zFSJ\" crossorigin=\"anonymous\">\r\n<link rel=\"stylesheet\" href=\"shared/js/slick/slick.css\">\r\n<link rel=\"stylesheet\" href=\"shared/js/slick/slick-theme.css\">\r\n<link rel=\"stylesheet\" href=\"shared/css/style.css\">\r\n  </head>\n\n\n<body>\n    <div class=\"p-wrapper\">\n    <div id=\"bodyOverlay\"></div>\n<header class=\"l-header\">\n   <div class=\"header__inner\">\n     <div class=\"c-container-maxWidth\">\n       <div class=\"container\">\n\n         <!-- spヘッダー　ハンバーガートリガーここから -->\n         <div class=\"c-hamburgerBox\">\n           <button type=\"button\" class=\"c-hamburger\" id=\"js-navToggler\"> <span class=\"c-hamburger__bar\"></span></button>\n         </div>\n         <!-- spヘッダー　ハンバーガートリガーここまで -->\n\n         <!-- spヘッダー　ドロップメニュー内ここから -->\n         <div class=\"sp-header\" id=\"js-navToggle\">\n           <div class=\"sp-header__inner\">\n             <div class=\"c-container-maxWidth\">\n               <div class=\"container\">\n                 <div class=\"sp-header__link\">\n                   <p class=\"sp-header__link__item toOfficial\"><a href=\"../\">大成機工ホームページへ戻る</a></p>\n                   <p class=\"sp-header__link__item\"><a href=\"\">リクルートトップ</a></p>\n                   <p class=\"sp-header__link__item\"><a href=\"interview/01.html\">社員インタビュー（1）</a></p>\n                   <p class=\"sp-header__link__item\"><a href=\"interview/02.html\">社員インタビュー（2）</a></p>\n                   <p class=\"sp-header__link__item\"><a href=\"fukuri/\">福利厚生</a></p>\n                 </div>\n                 <div class=\"sp-header__link\">\n                   <p class=\"sp-header__link__title\">新卒採用情報</p>\n                   <p class=\"sp-header__link__item\"><a href=\"fresh/\">新卒採用情報（募集要項）</a></p>\n                   <p class=\"sp-header__link__item\"><a href=\"https://job.mynavi.jp/27/pc/search/corp80609/outline.html\" target=\"_blank\" rel=\"noopener\">エントリー</a></p>\n                 </div>\n                 <div class=\"sp-header__link\">\n                   <p class=\"sp-header__link__title\">キャリア採用情報</p>\n                   <p class=\"sp-header__link__item\"><a href=\"carrier/\">キャリア採用情報（募集要項）</a></p>\n                 </div>\n               </div>\n             </div>\n           </div>\n         </div>\n         <!-- spヘッダー　ドロップメニュー内ここまで -->\n\n         <!-- pcヘッダー　ここから -->\n         <div class=\"header__contents\">\n           <div class=\"header__item\">\n             <p class=\"header__item__logo mb-0\"><a href=\"../\"><img src=\"shared/images/header_logo.png\" alt=\"大成機工株式会社\"></a></p>\n             <p class=\"header__item__siteName mb-0\"><a href=\"\"><img src=\"shared/images/header_recruit.png\" alt=\"Recruit Special Site\"></a></p>\n           </div>\n           <div class=\"header__globalNavi\">\n             <div class=\"header__globalNavi__item\">\n               <a href=\"fresh/\" class=\"text-center\">\n                 <div class=\"\">\n                   <p class=\"mb-0\">新卒採用情報</p>\n                   <p class=\"mb-0\"><img src=\"shared/images/header_img01.png\" alt=\"New Graduate\"></p>\n                 </div>\n               </a>\n             </div>\n             <div class=\"header__globalNavi__item\">\n               <a href=\"carrier/\" class=\"text-center\">\n                 <div class=\"\">\n                   <p class=\"mb-0\">キャリア採用情報</p>\n                   <p class=\"mb-0\"><img src=\"shared/images/header_img02.png\" alt=\"New Graduate\"></p>\n                 </div>\n               </a>\n             </div>\n             <div class=\"header__globalNavi__item\">\n               <a href=\"fukuri/\" class=\"text-center\">\n                 <div class=\"\">\n                   <p class=\"mb-0\">福利厚生</p>\n                   <p class=\"mb-0\"><img src=\"shared/images/header_img03.png\" alt=\"New Graduate\"></p>\n                 </div>\n               </a>\n             </div>\n           </div>\n         </div>\n         <!-- pcヘッダー　ここまで -->\n\n       </div>\n       <!-- container -->\n     </div>\n     <!-- c-container-maxWidth -->\n   </div>\n   <!-- header__inner -->\n</header>\n    <div class=\"l-main\">\n      <div class=\"p-TopMainText\">\n        <div class=\"p-TopMainText__inner\">\n          <p class=\"p-TopMainText__text mb-0\">社会に必要な水道<br class=\"d-block d-md-none\"><span class=\"p-TopMainText__text--letterL\">インフラを支える<br class=\"d-block d-lg-none\"></span><span class=\"p-TopMainText__text--color\">カタイ</span>仕事ですが、やわらかな<span class=\"p-TopMainText__text--color\">アタマ</span>の人材を求めています。</p>\n        </div>\n      </div>\n      <div class=\"c-container-maxWidth\">\n        <div class=\"container\">\n          <div class=\"c-section\">\n            <div class=\"p-topCopy\">\n              <p class=\"p-topCopy__text\">業界トップシェア！<br>大成機工は「水」を活かす製品・技術のパイオニアです！</p>\n            </div>\n            <div class=\"row flex-column-reverse flex-md-row p-TopIntroduction\">\n              <div class=\"col-12 col-md-7\">\n                <p class=\"p-section__text p-TopIntroduction__text\">「大成機工」って何の会社？ 学生の皆さんにはあまり聞きなれない社名かもしれません。当社をビジネスモデルにあてはめるとBtoB（Business to Business） 、つまり企業が企業に対してモノやサービスを提供する会社です。でも、私たちの技術や製品が皆さんの暮らしの一部を支えているのは確かです。実は私たちは「不断水工法のパイオニア」として長年水道業界に携わっています。<br>人にとって欠かすことのできない大切な「水」を安全かつ確実に供給する事業をサポートし、ライフラインを守ることが私たちの仕事。<br>具体的には、水道管路・ガス管路の維持管理に必要な製品の製造・販売および関連工法の施工を行っている会社です。<br>業界トップシェアとして、全国の各自治体やガス供給会社などに製品・工法のサービスを提供する、水を活かす製品・技術のパイオニアでもあります。<br>人の命を守る「水」に関する仕事に私たちは誇りを持ち、仕事を通じて豊かな環境や社会に貢献している実感を持ち続けています。 やりがいのある当社の仕事に少しでも興味を抱かれた方のエントリーを心よりお待ちしております！</p>\n              </div>\n              <div class=\"col-12 col-md-5\">\n                <p class=\"p-section__image p-TopIntroduction__image\"><img src=\"shared/images/index_img01.jpg\" alt=\"\"></p>\n              </div>\n            </div>\n          </div>\n          <!-- /section -->\n          <div class=\"c-section\">\n            <p class=\"p-section__title p-section__title--center sp-left mb-0\">Interview</p>\n            <div class=\"row\">\n              <div class=\"col-12 col-md-6 p-TopInterviewBox\">\n                <a href=\"interview/01.html\">\n                  <div class=\"p-TopInterviewBox__item\">\n                    <p class=\"p-TopInterviewBox__item__image\">\n                    <picture>\n                      <source media=\"(min-width:768px)\" srcset=\"shared/images/index_img02.jpg\">\n                      <source media=\"(max-width:767px)\" srcset=\"shared/images/index_img02_sp.jpg\">\n                      <img src=\"shared/images/index_img02.jpg\" alt=\"\">\n                    </picture>\n                    </p>\n                    <p class=\"p-TopInterviewBox__item__name\"><span class=\"small\">技術部</span><br>\n                    藤村 政也 </p>\n</div>\n                </a>\n              </div>\n              <div class=\"col-12 col-md-6 p-TopInterviewBox\">\n                <a href=\"interview/02.html\">\n                  <div class=\"p-TopInterviewBox__item\">\n                    <p class=\"p-TopInterviewBox__item__image\">\n                    <picture>\n                      <source media=\"(min-width:768px)\" srcset=\"shared/images/index_img03.jpg\">\n                      <source media=\"(max-width:767px)\" srcset=\"shared/images/index_img03_sp.jpg\">\n                      <img src=\"shared/images/index_img03.jpg\" alt=\"\">\n                    </picture>\n                    </p>\n                    <p class=\"p-TopInterviewBox__item__name\"><span class=\"small\">工事部</span><br>百野 和樹</p>\n                  </div>\n                </a>\n              </div>\n            </div>\n          </div>\n          <!-- /section -->\n\n        </div>\n        <!-- /container -->\n      </div>\n      <!-- /c-container-maxWidth -->\n    </div>\n    <!--/l-main-->\n    <footer class=\"l-footer\">\r\n  <div class=\"footer__inner\">\r\n    <div class=\"c-container-maxWidth\">\r\n      <div class=\"container\">\r\n        <div class=\"footer__item\">\r\n          <p class=\"footer__item__logo mb-0\"><a href=\"../\"><img src=\"shared/images/footer_logo.png\" alt=\"大成機工株式会社\"></a></p>\r\n          <p class=\"footer__item__siteName mb-0\"><a href=\"\"><img src=\"shared/images/footer_recruit.png\" alt=\"Recruit Special Site\"></a></p>\r\n        </div>\r\n        <p class=\"footer__copyright\">Copyright © <span id=\"js-year\"></span> TAISEI KIKO Co., ltd. All Rights Reserved.</p>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</footer>\r\n\r\n<!-- ページトップここから -->\r\n<div id=\"page-top\"><a href=\"#\"><img src=\"shared/images/img_pageTop.png\" alt=\"\" class=\"\"></a></div>\r\n<!-- ページトップここまで -->\r\n  </div>\n  <!--/p-wrapper-->\n  <!--▼▼共通JS（フッター）▼▼-->\r\n<script src=\"//ajax.googleapis.com/ajax/libs/jquery/3.3.1/jquery.min.js\"></script> \r\n<script src=\"shared/js/include.js\"></script>\r\n<!--▲▲共通JS（フッター）▲▲-->\r\n</body>\n\n</html>\n","finalUrl":"https://www.taiseikiko.com/recruit/","rendered":false,"_cachedAt":"2026-06-22T15:09:36.014Z"}