ss/common.css\" rel=\"stylesheet\">\r\n<link href=\"/css/style.css\" rel=\"stylesheet\">\r\n<!--local_CSS-->\r\n<link href=\"https://fonts.googleapis.com/css2?family=Roboto+Condensed&display=swap\" rel=\"stylesheet\">\r\n<link href=\"/css/slick.css\" rel=\"stylesheet\">\r\n<link href=\"/css/index.css\" rel=\"stylesheet\">\r\n</head>\r\n\r\n<body>\r\n\r\n<!-- Google Tag Manager (noscript) -->\r\n<noscript>\r\n<iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-NTKXXD3\"\r\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe>\r\n</noscript>\r\n<!-- End Google Tag Manager (noscript) -->\r\n\r\n<div id=\"wrapper\"> \r\n  <!-- header -->\r\n  <header data-include=\"header\"></header>\r\n  <!-- /header -->\r\n  <div class=\"container\"> \r\n    <!-- infomation-area --> \r\n    <!--<div class=\"infomation-area\">\r\n                <div class=\"contents-inner\">\r\n\t\t\t\t\t<p class=\"heading\">【ゴールデンウィーク休業のお知らせ】<br>\r\n                        誠に勝手ながら、2026年5月2日（土）～6日（水）は一部を除きゴールデンウィーク休業とさせていただきます。期間中のお問合せについては7日（木）以降順次対応させていただきます。何卒、ご了承ください。</p> \r\n                     <p class=\"heading\">【社名変更のお知らせ】</p>\r\n                    <a href=\"https://www.persol-group.co.jp/news/20250414_01/\" target=\"_blank\">\r\n                        <p class=\"text\">パーソルを騙る不審な求人メールやWebサイト、SNSアカウントに関するご注意ください<span class=\"text-underline\">詳細はこちら</span></p>\r\n                    </a>\r\n                </div>\r\n            </div>-->\r\n             <!-- /infomation-area -->\r\n\t<div class=\"main-visual\">\r\n      <ul class=\"main-visual-slide\">\r\n\t\t  \r\n        <li class=\"slide slide4\">\r\n          <p class=\"pc-only\"><img src=\"/img/index/kv_index_01.jpg\" alt=\"\"></p>\r\n          <p class=\"sp-only\"><img src=\"/img/index/kv_index_01_sp.jpg\" alt=\"\"></p>\r\n          <p class=\"link-btn orange\"><a class=\"link\" href=\"https://client.persol-hrpartners.co.jp/contact\">まずは相談</a></p>\r\n          <p class=\"link-btn orange\"><a class=\"link\" href=\"https://client.persol-hrpartners.co.jp/downloads\">資料ダウンロード</a></p>\r\n        </li>\r\n        <li class=\"slide slide2\">\r\n          <p class=\"pc-only\"><img src=\"/img/index/kv_index_02.jpg\" alt=\"\"></p>\r\n          <p class=\"sp-only\"><img src=\"/img/index/kv_index_02_sp.jpg\" alt=\"\"></p>\r\n          <p class=\"link-btn orange\"><a class=\"link\" href=\"/worker/\">はたらき方のご紹介</a></p>\r\n        </li>\r\n      </ul>\r\n    </div>\r\n\r\n    <div class=\"contents\"> \r\n      <!-- main-content -->\r\n      <div class=\"main-content\"> \r\n        <!-- for-manager-cont -->\r\n        <div class=\"for-manager-cont\">\r\n          <div class=\"contents-inner\">\r\n            <div class=\"for-manager-inner\">\r\n              <h2 class=\"top-h2-ttl\"><span class=\"sub\">for THE PERSON in CHARGE</span>企業ご担当の方</h2>\r\n              <p class=\"for-manager-catch\">選ばれる理由</p>\r\n            </div>\r\n            <!-- chosen-area -->\r\n            <div class=\"chosen-area\">\r\n              <div class=\"chosen-block\">\r\n                <p class=\"img\"><img src=\"/img/index/pht_index_chosen_01.jpg\" alt=\"パナソニックのグループ会社として設立\"></p>\r\n                <p class=\"text\">パナソニックのグループ会社として設立<br>\r\n                  <span>パナソニック株式会社の人材系子会社として1989年に設立した当社には約30年以上に渡りパナソニックをはじめ、大手・中小メーカー様の“人”と“モノづくり”にまつわるご支援実績があり、組織の構造や業務の特性に対するナレッジがあります。</span></p>\r\n              </div>\r\n              <div class=\"chosen-block\">\r\n                <p class=\"img\"><img src=\"/img/index/pht_index_chosen_02.jpg\" alt=\"パーソルグループが持つ多様なリソースを活用\"></p>\r\n                <p class=\"text\">パーソルグループが持つ多様なリソースを活用<br>\r\n                  <span>パーソルグループには人材派遣、人材紹介、人材開発、採用支援、業務委託、受託開発など多様なサービスがあり、国内外企業のあらゆる人や雇用・労働課題への取組みに対するご支援実績があります。これらのリソースを最大限に活用したご提案を行い、長期視点で伴走します。</span></p>\r\n              </div>\r\n              <div class=\"chosen-block\">\r\n                <p class=\"img\"><img src=\"/img/index/pht_index_chosen_03.jpg\" alt=\"丁寧な対応と確かな品質をお約束\"></p>\r\n                <p class=\"text\">丁寧な対応と確かな品質をお約束<br>\r\n                  <span>当社グループは、高い倫理観のもと、相手を正しく理解し、誠実・着実に対応する姿勢を大切にしています。また開発受託の技術力、受託生産の製造力においては、パナソニックの要求ラインに準拠してきた実績で確かな品質を保証いたします。</span></p>\r\n              </div>\r\n            </div>\r\n            <!-- /chosen-area -->\r\n            <div class=\"link-btn black\"><a class=\"link\" href=\"https://client.persol-hrpartners.co.jp/advantage\">当社の強み</a></div>\r\n          </div>\r\n        </div>\r\n        <!-- /for-manager-cont --> \r\n        <!-- service-cont -->\r\n        <div class=\"service-cont\">\r\n          <div class=\"service-inner\">\r\n            <h2 class=\"top-h2-ttl\"><span class=\"sub\">SERVICE</span>サービス一覧</h2>\r\n            <div class=\"service-link-area\">\r\n              <p class=\"service-link-title\">派遣サービス</p>\r\n              <div class=\"service-link-list\">\r\n                <div class=\"service-link-block\"> <a class=\"link\" href=\"https://client.persol-hrpartners.co.jp/service/temp\">\r\n                  <div class=\"service-info\">\r\n                    <p class=\"img\"><img src=\"/img/index/pht_index_service_01.jpg\" alt=\"事務派遣\"></p>\r\n                    <p class=\"text\">事務派遣</p>\r\n                  </div>\r\n                  </a> </div>\r\n                <div class=\"service-link-block\"> <a class=\"link\" href=\"https://client.persol-hrpartners.co.jp/service/engineer\">\r\n                  <div class=\"service-info\">\r\n                    <p class=\"img\"><img src=\"/img/index/pht_index_service_02.jpg\" alt=\"エンジニア派遣\"></p>\r\n                    <p class=\"text\">エンジニア派遣</p>\r\n                  </div>\r\n                  </a> </div>\r\n                <div class=\"service-link-block\"> <a class=\"link\" href=\"https://client.persol-hrpartners.co.jp/service/vietnam\">\r\n                  <div class=\"service-info\">\r\n                    <p class=\"img\"><img src=\"/img/index/pht_index_service_03.jpg\" alt=\"外国人エンジニア派遣 OVERS\"></p>\r\n                    <p class=\"te