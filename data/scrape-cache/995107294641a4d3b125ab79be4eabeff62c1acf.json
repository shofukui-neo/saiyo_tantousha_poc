i>\n                                        <li class=\"p-drawer__nav-item\">\n                                            <a href=\"https://www.hojoen.com/question/\" class=\"p-drawer__nav-link\">よくあるご質問</a>\n                                        </li>\n                                    </ul>\n                                </nav>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</header>\n\n<!-- チャットボット -->\n<!--\n<script>\n(function(){\nvar w=window,d=document;\nvar s=\"https://app.chatplus.jp/cp.js\";\nd[\"__cp_d\"]=\"https://app.chatplus.jp\";\nd[\"__cp_c\"]=\"0138619e_1\";\nvar a=d.createElement(\"script\"), m=d.getElementsByTagName(\"script\")[0];\na.async=true,a.src=s,m.parentNode.insertBefore(a,m);})();\n</script>\n-->\n\n<a href=\"https://app.chatplus.jp/chat/visitor/0138619e_1?t=btn\" target=\"_blank\" class=\"c-chat-bot js-chatbot\">\n    <p class=\"c-chat-bot__text\">\n        ご質問に<span class=\"u-desktop--inline\">チャットで</span><br class=\"u-desktop\">\n        回答<br class=\"u-mobile\">いたします。\n    </p>\n    <div class=\"c-chat-bot__icon\">\n        <img src=\"https://www.hojoen.com/images/icon_chat.svg\" alt=\"チャットボット\">\n    </div>\n</a>\n\n<main class=\"l-main\">\n    <!-- 下層メインビジュアル -->\n    <div class=\"p-mv\">\n        <div class=\"p-mv__image p-mv__image--normal\">\n            <img src=\"../images/contact/mv.webp\" alt=\"MV\">\n        </div>\n    </div>\n\n    <!-- ぱんくず -->\n    <div class=\"p-breadcrumb\">\n        <div class=\"l-inner\">\n            <ul itemscope itemtype=\"https://schema.org/BreadcrumbList\">\n                <li itemprop=\"itemListElement\" itemscope itemtype=\"https://schema.org/Listitem\">\n                    <a itemprop=\"item\" href=\"/\"><span itemprop=\"name\">TOP</span></a>\n                    <meta itemprop=\"position\" content=\"1\" />\n                </li>\n                <li itemprop=\"itemListElement\" itemscope itemtype=\"https://schema.org/Listitem\">\n                    <span itemprop=\"name\">\n                        お問合せ\n                    </span>\n                    <meta itemprop=\"position\" content=\"2\" />\n                </li>\n            </ul>\n        </div>\n    </div>\n\n    <!-- 下層ページタイトル -->\n    <h1 class=\"c-lower-title fwSB\">\n        お問合せ\n    </h1>\n    <div class=\"contact_header pt110\">\n        <div class=\"tk_inner\">\n            <h2 class=\"contact_h2 font-shippori fwSB taC\">ご利用後のお問合せ</h2>\n            <div class=\"contact_header_text font-shippori taC mt40\">\n                <p>必要箇所にご入力の上、「入力内容確認画面へ」<br class=\"pc-none__inline\">ボタンを押してください。\n                <br>ご入力いただいた個人情報は<a href=\"../privacy/\">賢島宝生苑のプライ<br class=\"pc-none__inline\">バシーポリシー</a>に従って厳重に管理されます。\n                <br>このフォームから頂戴したご質問は通常、<br class=\"pc-none__inline\">1〜2営業日以内にご回答いたしますが、\n                <br>ご質問の内容によってはお時間を頂戴する場合が<br class=\"pc-none__inline\">ございます。あらかじめご了承ください。\n                <br>お急ぎの場合はお電話でのご質問も承って<br class=\"pc-none__inline\">おりますのでご利用ください。</p>\n            </div>\n        </div>\n    </div>\n    \n    <div class=\"pt85\" id=\"entry_form\">\n        <div class=\"tk_inner\">\n            <form action=\"after_confirm.php\" method=\"post\" enctype=\"multipart/form-data\" name=\"form1\" id=\"form1\" class=\"h-adr\">\n                <dl class=\"contact_form font-shippori\">\n                    <div class=\"contact_form__column\">\n                        <dt class=\"contact_form_title pt\">\n                            <p>お問合せ<br>ご要望の内容</p>\n                            <span class=\"contact_form_required\">必須項目</span>\n                        </dt>\n                        <dd class=\"contact_form_detail\">\n                            <textarea name=\"det\" id=\"det\" required class=\"autsize\"></textarea>\n                            <p id=\"error_01\" class=\"error false fwB\">※お問合せ、ご要望の内容を入力してください。</p>\n                            <p class=\"contact_form_caution\">※お忘れ物の場合は、色や大きさなどの詳細もご記入ください。</p>\n                        </dd>\n                    </div>\n                    <div class=\"contact_form__column\">\n                        <dt class=\"contact_form_title\">\n                            <p>お名前</p>\n                            <span class=\"contact_form_required\">必須項目</span>\n                        </dt>\n                        <dd class=\"contact_form_detail\">\n                            <input type=\"text\" name=\"user_name\" id=\"user_name\" autocomplete=\"name\" value=\"\" placeholder=\"\" required>\n                            <p id=\"error_03\" class=\"error false fwB\" >※お名前を入力してください。</p>\n                        </dd>\n                    </div>\n                    <div class=\"contact_form__column\">\n                        <dt class=\"contact_form_title\">\n                            <p>フリガナ</p>\n                            <span class=\"contact_form_required\">必須項目</span>\n                        </dt>\n                        <dd class=\"contact_form_detail\">\n                            <input type=\"text\" name=\"user_kana\" id=\"user_kana\" value=\"\" placeholder=\"\" required>\n                            <p id=\"error_04_01\" class=\"error false fwB\" >※フリガナを入力してください。</p>\n                            <p id=\"error_04_02\" class=\"error false fwB\" >※フリガナは全角カタカナで入力してください。</p>\n                        </dd>\n                    </div>\n                    <div class=\"contact_form__column\">\n                        <dt class=\"contact_form_title\">\n                            <p>ご利用団体名<br>(ツアー名)</p>\n                        </dt>\n                        <dd class=\"contact_form_detail\">\n                            <input type=\"text\" name=\"group_name\" id=\"group_name\" value=\"\" placeholder=\"\">\n                        </dd>\n                    </div>\n                    <div class=\"contact_form__column\">\n                        <dt class=\"contact_form_title\">\n                            <p>利用日・部屋番号</p>\n                            <span class=\"contact_form_required\">必須項目</span>\n                        </dt>\n                        <dd class=\"contact_form_detail\">\n                            <textarea name=\"reserve_date\" id=\"reserve_date\" class=\"autsize\" required></textarea>\n                            <p id=\"error_02\" class=\"error false fwB\" >※利用日・希望日を入力してください。</p>\n                            <p class=\"contact_form_caution\">※不明の場合は｢不明｣とご記入ください。</p>\n                        </dd>\n                    </div>\n                    <div class=\"contact_form__column\">\n                        <dt class=\"contact_form_title\">\n                            <p>郵便番号</p>\n                            <span class=\"contact_form_required\">必須項目</span>\n                        </dt>\n                        <dd class=\"contact_form_detail\">\n                            <input type=\"text\" name=\"postal_code\" id=\"postal_code\" class=\"p-postal-code\" autocomplete=\"postal-code\" value=\"\" placeholder=\"住所自動入力(ハイフンなしで入力)\" required>\n                            <p id=\"error_05_01\" class=\"error false fwB\" >※郵便番号を入力してください。</p>\n                            <p id=\"error_05_02\" class=\"error false fwB\" >※郵便番号はハイフンなしの半角数字で入力してください。</p>\n                        </dd>\n                    </div>\n                    <div class=\"contact_form__column\">\n                        <dt class=\"contact_form_title\">\n                            <p>ご住所</p>\n                            <span class=\"contact_form_required\">必須項目</span>\n                        </dt>\n                        <dd class=\"contact_form_detail\">\n                            <input type=\"text\" name=\"user_address\" id=\"user_address\" class=\"p-region p-locality p-street-address p-extended-address\" autocomplete=\"address\" value=\"\" placeholder=\"\" required>\n                            <p id=\"error_06\" class=\"error false fwB\" >※ご住所を入力してください。</p>\n                        </dd>\n                    </div>\n                    <div class=\"contact_form__column\">\n                        <dt class=\"contact_form_title\">\n                            <p>電話番号</p>\n                            <span class=\"contact_form_required\">必須項目</span>\n                        </dt>\n                        <dd class=\"contact_form_detail\">\n                            <input type=\"tel\" name=\"user_tel\" id=\"user_tel\" autocomplete=\"tel\" value=\"\" placeholder=\"\" required>\n                            <p id=\"error_07_01\" class=\"error false fwB\" >※電話番号を入力してください。</p>\n                            <p id=\"error_07_02\" class=\"error false fwB\" >※電話番号は半角数字で正しく入力してください。</p>\n                        </dd>\n                    </div>\n                    <div class=\"contact_form__column\">\n                        <dt class=\"contact_form_title\">\n                            <p>メールアドレス</p>\n                            <span class=\"contact_form_required\">必須項目</span>\n                        </dt>\n                        <dd class=\"contact_form_detail\">\n                            <input type=\"email\" name=\"user_email\" id=\"user_email\" autocomplete=\"email\" value=\"\" placeholder=\"\" required>\n                            <p id=\"error_08_01\" class=\"error false fwB\" >※メールアドレスを入力してください。</p>\n                            <p id=\"error_08_02\" class=\"error false fwB\" >※メールアドレスは半角英数字で入力してください。</p>\n                        </dd>\n                    </div>\n                    <div class=\"contact_form__column\">\n                        <dt class=\"contact_form_title\">\n                            <p>ご希望の連絡方法</p>\n                            <span class=\"contact_form_required\">必須項目</span>\n                        </dt>\n                        <dd class=\"contact_form_detail\">\n                            <div class=\"radio_box\" id=\"radio_box_contact_tool\">