ript src=\"/contact/js/contact.js\"></script>\n</head>\n<body>\n  <div class=\"l-wrap\">\n    <header class=\"l-header\"><div class=\"l-header__inr\">\r\n  <h1 class=\"l-header__logo\"><a href=\"/\"><img src=\"/common/images/logo.svg\" alt=\"四国パック株式会社\"></a></h1>\r\n  <nav class=\"l-header__nav\" data-hd-cts>\r\n    <ul class=\"l-header__navList\">\r\n      <li class=\"l-header__navItem\"><a href=\"/about/\">私たちの強み</a></li>\r\n      <li class=\"l-header__navItem\"><a href=\"/product/\">製品情報</a></li>\r\n      <li class=\"l-header__navItem\"><a href=\"/company/\">企業情報</a></li>\r\n      <li class=\"l-header__navItem\"><a href=\"/recruit/\">採用情報</a></li>\r\n    </ul>\r\n    <div class=\"l-header__contact\"><a href=\"/contact/\">お問い合わせ</a></div>\r\n  </nav>\r\n  <div class=\"l-header__btn sp\" data-hd-btn>\r\n    <div class=\"l-header__btnBar\"></div>\r\n    <p class=\"l-header__btnTxt\">MENU</p>\r\n  </div>\r\n  <div class=\"l-header__ol sp\"></div>\r\n</div></header>\r\n\n\n    <main class=\"l-main\">\n\n      <div class=\"c-idxTtl l-idt\"><div class=\"l-wid\">\n        <div class=\"c-idxTtl__txt js-fadeIn\">\n          <h1 class=\"jp\">お問い合わせ</h1>\n          <p class=\"en\">Contact Us</p>\n        </div>\n      </div></div>\n\n      <div class=\"u-contact l-idt\"><div class=\"l-wid\">\n        <ul class=\"u-contact__list\">\n          <li>半角カタカナは使用せず、全角カタカナでご記入ください</li>\n          <li>お問い合わせいただく際は、下記の項目を正確にご記入ください。</li>\n          <li>お問い合わせ内容によりましては、ご回答にお時間をいただく場合やお答えいたしかねる場合がございます。<br>また、状況により電話・封書等にて対応させていただく場合がございます。</li>\n          <li>当窓口からの回答内容の一部または全体を無断転載・引用することを固くお断りいたします。</li>\n          <li>情報をご入力する際は、個人情報の取り扱いについてご同意の上、ご入力ください。</li>\n          <li>お問い合わせフォームからの、アンケート調査および商品・サービスの売り込みなどはご遠慮ください。</li>\n        </ul>\n        <div class=\"u-contact__caution\">\n          <p>下記メールフォームより必要事項をご記入の上、入力を確認するボタンからお問い合わせください。</p>\n        </div>\n        <div class=\"u-contact__form\">\n          <div class=\"u-form\">\n            <p class=\"u-form__caution\"><spa