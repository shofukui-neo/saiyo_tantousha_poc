tion value=\"新潟県\">新潟県</option>\n                          <option value=\"富山県\">富山県</option>\n                          <option value=\"石川県\">石川県</option>\n                          <option value=\"福井県\">福井県</option>\n                          <option value=\"山梨県\">山梨県</option>\n                          <option value=\"長野県\">長野県</option>\n                          <option value=\"岐阜県\">岐阜県</option>\n                          <option value=\"静岡県\">静岡県</option>\n                          <option value=\"愛知県\">愛知県</option>\n                          <option value=\"三重県\">三重県</option>\n                          <option value=\"滋賀県\">滋賀県</option>\n                          <option value=\"京都府\">京都府</option>\n                          <option value=\"大阪府\">大阪府</option>\n                          <option value=\"兵庫県\">兵庫県</option>\n                          <option value=\"奈良県\">奈良県</option>\n                          <option value=\"和歌山県\">和歌山県</option>\n                          <option value=\"鳥取県\">鳥取県</option>\n                          <option value=\"島根県\">島根県</option>\n                          <option value=\"岡山県\">岡山県</option>\n                          <option value=\"広島県\">広島県</option>\n                          <option value=\"山口県\">山口県</option>\n                          <option value=\"徳島県\">徳島県</option>\n                          <option value=\"香川県\">香川県</option>\n                          <option value=\"愛媛県\">愛媛県</option>\n                          <option value=\"高知県\">高知県</option>\n                          <option value=\"福岡県\">福岡県</option>\n                          <option value=\"佐賀県\">佐賀県</option>\n                          <option value=\"長崎県\">長崎県</option>\n                          <option value=\"熊本県\">熊本県</option>\n                          <option value=\"大分県\">大分県</option>\n                          <option value=\"宮崎県\">宮崎県</option>\n                          <option value=\"鹿児島県\">鹿児島県</option>\n                          <option value=\"沖縄県\">沖縄県</option>\n                        </select>\n                      </label>\n                      <div class=\"js-errorPlace\"></div>\n                    </div>\n                  </div>\n                </div>\n                <div class=\"u-form__item js-validateLine\">\n                  <div class=\"u-form__labelWrap\">\n                    <div class=\"u-form__term\"><p class=\"u-form__ttl --required\">住所</p></div>\n                    <div class=\"u-form__dsc\">\n                      <input id=\"address\" type=\"text\" name=\"住所\" class=\"input js-rule-required\" placeholder=\"例）静岡県富士市大渕4226-2\">\n                      <div class=\"js-errorPlace\"></div>\n                    </div>\n                  </div>\n                </div>\n                <div class=\"u-form__item js-validateLine\">\n                  <div class=\"u-form__labelWrap\">\n                    <div class=\"u-form__term\"><p class=\"u-form__ttl --required\">お電話番号</p></div>\n                    <div class=\"u-form__dsc\">\n                      <input type=\"text\" name=\"お電話番号\" class=\"input js-rule-required-num\" placeholder=\"例）00-0000-0000 , 00000000000\">\n                      <div class=\"js-errorPlace\"></div>\n                    </div>\n                  </div>\n                </div>\n                <div class=\"u-form__item js-validateLine\">\n                  <div class=\"u-form__labelWrap\">\n                    <div class=\"u-form__term\"><p class=\"u-form__ttl --optional\">FAX番号</p></div>\n                    <div class=\"u-form__dsc\">\n                      <input type=\"text\" name=\"FAX番号\" class=\"input js-rule-num\">\n                      <div class=\"js-errorPlace\"></div>\n                    </div>\n                  </div>\n                </div>\n                <div class=\"u-form__item js-validateLine\">\n                  <div class=\"u-form__labelWrap\">\n                    <div class=\"u-form__term\"><p class=\"u-form__ttl --required\">メールアドレス</p></div>\n                    <div class=\"u-form__dsc\">\n                      <input type=\"text\" name=\"メールアドレス\" class=\"input js-rule-email\" placeholder=\"例）info@shikoku-pak.com\">\n                      <div class=\"js-errorPlace\"></div>\n                    </div>\n                  </div>\n                </div>\n                <div class=\"u-form__item js-validateLine\">\n                  <div class=\"u-form__labelWrap\">\n                    <div class=\"u-form__term\"><p class=\"u-form__ttl --required\">メールアドレス（確認用）</p></div>\n                    <div class=\"u-form__dsc\">\n                      <input type=\"text\" name=\"メールアドレス（確認用）\" class=\"input js-rule-email-same\">\n                      <div class=\"js-errorPlace\"></div>\n                    </div>\n                  </div>\n                </div>\n                <div class=\"u-form__agree js-validateLine\">\n                  <p class=\"u-form__ttl --required\">個人情報の確認</p>\n                  <div class=\"u-form__box\">\n                    <p class=\"u-form__boxTxt\">当社は、個人情報を取扱う組織ごとに個人情報保護の責任者を置き、 適切な管理に取り組みます。お客様が当ウェブサイトをご利用される際に、お客様の個人情報を入力していただく場合がございます。 ご提供いただく個人情報は、お客様のお名前、住所、電話番号、メールアドレス等ですが、原則としてお客様のご承諾なしにこれらの 情報を第三者に公開することはありません。ただし、犯罪捜査のため法令に基づく手続きを経て、裁判所並びに検察、警察及びその他 の行政機関からお客様の個人情報についての開示要請があった場合は、これを開示する事があります。あらかじめご了承ください。</p>\n                    <div class=\"u-check\">\n                      <label for=\"consent\">\n                        <input type=\"checkbox\" name=\"個人情報の確認\" value=\"同意しました\" id=\"consent\" class=\"js-rule-required\">\n                        <span>個人情報の確認に同意しました</span>\n                      </label>\n                    </div>\n                    <input type=\"checkbox\" name=\"確認用\" value=\"確認用\" id=\"notCheck\">\n                  </div>\n                </div>\n\n                <!-- ハニーポット（スパム対策）\n                <input type=\"text\" name=\"website\" style=\"display:none;\" tabindex=\"-1\" autocomplete=\"off\">\n                -->\n\n   