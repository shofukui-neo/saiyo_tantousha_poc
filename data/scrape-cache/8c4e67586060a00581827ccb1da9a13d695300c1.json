c\"><input type=\"text\" name=\"会社名\" class=\"input\" placeholder=\"例）四国パック株式会社\"></div>\n                  </div>\n                </div>\n                <div class=\"u-form__item js-validateLine\">\n                  <div class=\"u-form__labelWrap\">\n                    <div class=\"u-form__term\"><p class=\"u-form__ttl --optional\">フリガナ（会社名）</p></div>\n                    <div class=\"u-form__dsc\"><input type=\"text\" name=\"フリガナ（会社名）\" class=\"input\" placeholder=\"例）シコクパックカブシキカイシャ\"></div>\n                  </div>\n                </div>\n                <div class=\"u-form__item js-validateLine\">\n                  <div class=\"u-form__labelWrap\">\n                    <div class=\"u-form__term\"><p class=\"u-form__ttl --required\">お名前</p></div>\n                    <div class=\"u-form__dsc\">\n                      <input type=\"text\" name=\"お名前（姓）\" class=\"input js-rule-required\" placeholder=\"姓\">\n                      <input type=\"text\" name=\"お名前（名）\" class=\"input js-rule-required\" placeholder=\"名\">\n                      <div class=\"js-errorPlace\"></div>\n                    </div>\n                  </div>\n                </div>\n                <div class=\"u-form__item js-validateLine\">\n                  <div class=\"u-form__labelWrap\">\n                    <div class=\"u-form__term\"><p class=\"u-form__ttl --optional\">フリガナ</p></div>\n                    <div class=\"u-form__dsc\">\n                      <input type=\"text\" name=\"フリガナ（セイ）\" class=\"input\" placeholder=\"セイ\">\n                      <input type=\"text\" name=\"フリガナ（メイ）\" class=\"input\" placeholder=\"メイ\">\n                      <div class=\"js-errorPlace\"></div>\n                    </div>\n                  </div>\n                </div>\n                <div class=\"u-form__item js-validateLine\">\n                  <div class=\"u-form__labelWrap check\">\n                    <div class=\"u-form__term\"><p class=\"u-form__ttl --required\">郵便番号</p></div>\n    