{"url":"https://www.yamako.co.jp/recruit/","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n\n  <head>\n    <meta charset=\"utf-8\">\n    <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n    <meta name=\"robots\" content=\"index,follow\" />\n    <meta name=\"Keywords\" content=\"山形,ヤマコー\" />\n    <meta name=\"Description\" content=\"株式会社ヤマコーの採用ページです。不動産事業を始め、スポーツレジャー施設の運営、グループ企業のバス事業や旅行業、策動事業などでの営業・企画・総務・経理業務等、様々な場で活躍していただきます。\" />\n\n    <title>ヤマコー | 採用サイト</title>\n\n    <!-- Bootstrap Core CSS -->\n    <link href=\"https://www.yamako.co.jp/recruit/common/css/bootstrap.css\" rel=\"stylesheet\">\n    <link href=\"https://use.fontawesome.com/releases/v5.6.1/css/all.css\" rel=\"stylesheet\">\n    <!-- slider-pro -->\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"https://www.yamako.co.jp/recruit/common/css/slider-pro.css\"/>\n    <!-- Slickslider -->\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"https://www.yamako.co.jp/recruit/common/css/slick.css\" />\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"https://www.yamako.co.jp/recruit/common/css/slick-theme.css\" />\n    <!-- magnific-popup -->\n    <link rel=\"stylesheet\" href=\"https://www.yamako.co.jp/recruit/common/css/magnific-popup.css\" />\n    <!-- Custom CSS -->\n    <link href=\"https://www.yamako.co.jp/recruit/common/css/style.css\" rel=\"stylesheet\">\n    <link href=\"https://fonts.googleapis.com/css?family=Noto+Sans+JP:400,700&display=swap\" rel=\"stylesheet\">\n    <link href=\"https://fonts.googleapis.com/css?family=Gothic+A1:900&display=swap\" rel=\"stylesheet\">\n    <!-- recruit CSS -->\n    <link href=\"https://www.yamako.co.jp/recruit.css\" rel=\"stylesheet\">\n  \n    <!-- HTML5 Shim and Respond.js IE8 support of HTML5 elements and media queries -->\n    <!-- WARNING: Respond.js doesn't work if you view the page via file:// -->\n    <!--[if lt IE 9]>\n        <script src=\"https://oss.maxcdn.com/libs/html5shiv/3.7.0/html5shiv.js\"></script>\n        <script src=\"https://oss.maxcdn.com/libs/respond.js/1.4.2/respond.min.js\"></script>\n    <![endif]-->\n  \n  <!-- Global site tag (gtag.js) - Google Analytics -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=UA-76049367-55\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'UA-76049367-55');\n</script>\n\n<!-- Global site tag (gtag.js) - Google Analytics -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-HJ53MRM2HL\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'G-HJ53MRM2HL');\n</script>\n  \n  <!-- Google tag (gtag.js) -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=AW-16564281712\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'AW-16564281712');\n</script>\n  \n  　<!-- OGPの設定 -->\n<meta property=\"og:url\" content=\"http://www.yamako.co.jp/recruit/\" />\n<meta property=\"og:title\" content=\"株式会社ヤマコーの採用ページです。不動産事業を始め、スポーツレジャー施設の運営、グループ企業のバス事業や旅行業、策動事業などでの営業・企画・総務・経理業務等、様々な場で活躍していただきます。\" />\n<meta property=\"og:site_name\" content=\"株式会社ヤマコーの採用ページ\" />\n<meta property=\"og:image\" content=\"http://www.yamako.co.jp/recruit/common/img/main-img02.jpg\" />\n<!-- Twitterカードの設定 -->\n<meta name=\"twitter:site\" content=\"@yamakoutoria\" />\n<meta name=\"twitter:card\" content=\"summary\" />\n<meta name=\"twitter:title\" content=\"株式会社ヤマコーの採用ページ\" />\n<meta name=\"twitter:description\" content=\"不動産事業を始め、スポーツレジャー施設の運営、グループ企業のバス事業や旅行業、策動事業などでの営業・企画・総務・経理業務等、様々な場で活躍していただきます。\" />\n<meta name=\"twitter:image\" content=\"https://www.yamako.co.jp/recruit/common/img/main-img02.jpg\" />\n  </head>\n\n<body class=\"top-page\">\n\n\t<nav id=\"menu\">\n\t\t<div class=\"container-fluid container01\">\n\t\t\t<div class=\"navbar-header\">\n\t\t\t\t<h1><a href=\"https://www.yamako.co.jp/\"><img src=\"https://www.yamako.co.jp/recruit/common/img/logo01.png\" alt=\"\"></a><span>採用サイト</span></h1>\n\t\t\t\t<button type=\"button\" class=\"navbar-toggle\" data-toggle=\"collapse\" data-target=\"#menu-list\">\n\t\t          <span class=\"sr-only\">Toggle navigation</span>\n\t\t          <span class=\"icon-bar\"></span>\n\t\t          <span class=\"icon-bar\"></span>\n\t\t          <span class=\"icon-bar\"></span>\n\t\t        </button>\n\t\t\t</div><!-- navbar-header -->\n\t\t</div><!-- container -->\n\n\t\t<div class=\"container-fluid container02\">\n\t\t\t<div class=\"collapse navbar-collapse\" id=\"menu-list\">\n\t\t\t\t<ul class=\"nav navbar-nav\" id=\"menu-ul\">\n\t\t\t\t\t<li><a href=\"#sec01\">メッセージ</a></li>\n\t\t\t\t\t<li><a href=\"#sec02\">ヤマコーについて</a></li>\n\t\t\t\t\t<li><a href=\"#sec03\">社員インタビュー</a></li>\n\t\t\t\t\t<li><a href=\"#sec06\">募集要項</a></li>\n\t\t\t\t\t<li><a href=\"#sec07\">採用スケジュール</a></li>\n                    <li class=\"visible-xs\"><a href=\"#entry01\"><img src=\"https://www.yamako.co.jp/recruit/common/img/entry-img02.png\" class=\"center-block\" alt=\"ENTRY\"></a></li>\n\t\t\t\t\t<li class=\"visible-xs\"><a href=\"https://www.yamako.co.jp/contact/recruit.html\"><img src=\"https://www.yamako.co.jp/recruit/common/img/content-img02.png\" class=\"center-block\" alt=\"お問い合わせ\"></a></li>\n\t\t\t\t\t<li class=\"visible-xs\"><a href=\"https://www.yamako.co.jp/\"><img src=\"https://www.yamako.co.jp/recruit/common/img/home-img02.png\" class=\"center-block\" alt=\"ホームへ戻る\"></a></li>\n\t\t\t\t</ul>\n\t\t\t</div><!-- collapse navbar-collapse -->\n\t\t</div><!-- container -->\n\t</nav>\n\n\n  <!-------------- Header -------------->\n  <header id=\"myCarousel\" class=\"carousel slide\">\n    <div class=\"slider-pro\" id=\"slider1\">\n      <div class=\"sp-slides\">\n        <div class=\"sp-slide\">\n          <img src=\"https://www.yamako.co.jp/recruit-img/main01.jpg\" class=\"center-block hidden-sp\" alt=\"\">\n          <img src=\"https://www.yamako.co.jp/recruit-img/main01-sp.jpg\" class=\"center-block visible-sp\" alt=\"\">\n        </div>\n      </div>\n    </div>\n    <div class=\"hd-content01\"></div>\n  </header>\n\n    <!-------------- Page Content -------------->\n    <div id=\"contents\">\n\n      <!-------------- sidebtn -------------->\n    <ul id=\"side-btn\" class=\"sidebar hidden-xs\">\n        <li class=\"entry-btn01\"><a href=\"#entry01\"><img src=\"https://www.yamako.co.jp/recruit/common/img/entry-img01.png\" alt=\"ENTRY\"></a></li>\n        <li class=\"content-btn01\"><a href=\"https://www.yamako.co.jp/contact/recruit.html\"><img src=\"https://www.yamako.co.jp/recruit/common/img/content-img01.png\" alt=\"お問い合わせ\"></a></li>\n        <li class=\"content-btn01\"><a href=\"https://www.yamako.co.jp/\"><img src=\"https://www.yamako.co.jp/recruit/common/img/home-img01.png\" alt=\"ホームへ戻る\"></a></li>\n    </ul><!-- side-btn -->\n\n    <section id=\"sec02\">\n        <h2>M<span class=\"titcolor\">o</span>tt<span class=\"titcolor\">o</span><span class=\"sub\">地域になくてはならない企業グループへ</span></h2>\n        <p>ユトリアグループは、お客様の視点に立った「くらし・たび・あそび」の領域で事業を展開しています。いつでもどこでもお客様にゆとりと安心をお届けする、<br class=\"hidden-xs\">それがユトリアの「こころ」です。</p>\n        <div class=\"row\">\n            <div class=\"col-sm-4 col-xs-6\">\n              <a href=\"https://www.yamako.co.jp/group/#01\" class=\"btn01 col-sm-12\">\n                <img src=\"https://www.yamako.co.jp/recruit/common/img/serv01-icon.png\" class=\"img-responsive center-block col-xs-4 sp-block\" alt=\"ユトリアグループ-くらし\">\n                <h5>くらし<span>live</span></h5>\n                <!--<img src=\"https://www.yamako.co.jp/recruit/common/img/serv01-icon.png\" class=\"img-responsive center-block hidden-xs\" alt=\"ユトリアグループ-くらし\">-->\n                <img src=\"https://www.yamako.co.jp/recruit/common/img/serv01-icon.png\" class=\"img-responsive center-block sm-block\" alt=\"ユトリアグループ-くらし\">\n                <p>快適と安心をつくる</p>\n              </a>\n            </div><!-- /.col-sm-3 -->\n\n            <div class=\"col-sm-4 col-xs-6\">\n              <a href=\"https://www.yamako.co.jp/group/#02\" class=\"btn02\">\n                <img src=\"https://www.yamako.co.jp/recruit/common/img/serv02-icon.png\" class=\"img-responsive center-block col-xs-4 sp-block\" alt=\"ユトリアグループ-たび\">\n                <h5>たび<span>travel</span></h5>\n                <!--<img src=\"https://www.yamako.co.jp/recruit/common/img/serv02-icon.png\" class=\"img-responsive center-block hidden-xs\" alt=\"ユトリアグループ-たび\">-->\n                <img src=\"https://www.yamako.co.jp/recruit/common/img/serv02-icon.png\" class=\"img-responsive center-block sm-block\" alt=\"ユトリアグループ-たび\">\n                <p>思い出とやすらぎ<br class=\"sm-block\">をつくる</p>\n              </a>\n            </div><!-- /.col-sm-3 -->\n\n            <div class=\"col-sm-4 col-xs-6\">\n              <a href=\"https://www.yamako.co.jp/group/#03\" class=\"btn03\">\n                <img src=\"https://www.yamako.co.jp/recruit/common/img/serv03-icon.png\" class=\"img-responsive center-block col-xs-4 sp-block\" alt=\"ユトリアグループ-あそび\">\n                <h5>あそび<span>play</span></h5>\n                <!--<img src=\"https://www.yamako.co.jp/recruit/common/img/serv03-icon.png\" class=\"img-responsive center-block hidden-xs\" alt=\"ユトリアグループ-あそび\">-->\n                <img src=\"https://www.yamako.co.jp/recruit/common/img/serv03-icon.png\" class=\"img-responsive center-block sm-block\" alt=\"ユトリアグループ-あそび\">\n                <p>人の集まる地域<br class=\"sm-block\">をつくる</p>\n              </a>\n            </div><!-- /.col-sm-3 -->\n        </div><!-- /.row -->\n    </section>\n\n    <section id=\"sec04\">\n    <div class=\"sec04-wrap\">\n      <div class=\"container\">\n        <h2>Q<span class=\"titcolor\">＆</span>A<span class=\"sub\">学生のみなさんによく聞かれる質問にお答えします！</span></h2>\n\n<div class=\"cp_qa03\">\n  <div class=\"cp_actab\">\n    <input id=\"cp_tabfour031\" type=\"checkbox\" name=\"tabs\">\n    <label for=\"cp_tabfour031\">「総合職」って何ですか？</label>\n    <div class=\"cp_actab-content\">\n    <p>ユトリアグループ各社で、営業・企画・総務・経理など様々な知識を身に付け、グループの幹部社員として活躍してもらう職種です。</p>\n    </div>\n  </div>\n  <div class=\"cp_actab\">\n    <input id=\"cp_tabfour032\" type=\"checkbox\" name=\"tabs\">\n    <label for=\"cp_tabfour032\">新入社員はどこに配属されますか？</label>\n    <div class=\"cp_actab-content\">\n    <p>ユトリアグループ各社・各部門への配属となります。ちなみに、新入社員の直近5年の配属先は、㈱ヤマコーコミュニティ事業部・リナワールド事業部、山形交通㈱、山交観光㈱で、異動希望を出すことも可能です。</p>\n    </div>\n  </div>\n  <div class=\"cp_actab\">\n    <input id=\"cp_tabfour033\" type=\"checkbox\" name=\"tabs\">\n    <label for=\"cp_tabfour033\">総合職の人事異動は何年くらいで行われますか？また、異動希望や相談などはできますか？</label>\n    <div class=\"cp_actab-content\">\n    <p>人事異動に特に決まった年数はありませんが、３年～5年くらいで行われます。また定期的に行われる人事担当者との面談で相談に応じています。</p>\n    </div>\n  </div>\n  <div class=\"cp_actab\">\n    <input id=\"cp_tabfour034\" type=\"checkbox\" name=\"tabs\">\n    <label for=\"cp_tabfour034\">転勤の範囲は？</label>\n    <div class=\"cp_actab-content\">\n    <p>庄内地域を除く山形県内と宮城県仙台市です。山形市内を基準とすれば、いずれも公共交通機関や車で通うことができる範囲です。</p>\n    </div>\n  </div>\n  <div class=\"cp_actab\">\n    <input id=\"cp_tabfour035\" type=\"checkbox\" name=\"tabs\">\n    <label for=\"cp_tabfour035\">自分に合う仕事か不安です・・・</label>\n    <div class=\"cp_actab-content\">\n    <p>ユトリアグループでは様々な事業を展開しているため、皆さんに合った仕事があると思います。入社後も相談窓口や人事担当者との定期的な面談がありますのでご安心ください。</p>\n    </div>\n  </div>\n  <div class=\"cp_actab\">\n    <input id=\"cp_tabfour036\" type=\"checkbox\" name=\"tabs\">\n    <label for=\"cp_tabfour036\">自分が成長できる会社でしょうか？</label>\n    <div class=\"cp_actab-content\">\n    <p>様々な事業を展開しているため、幅の広い、かつ専門的な知識を学ぶことができます。また、グループ各社合同の「新入社員研修」「フォローアップ研修」「世代別研修」「階層別研修」など、研修には特に力を入れております。</p>\n    </div>\n  </div>\n  <div class=\"cp_actab\">\n    <input id=\"cp_tabfour037\" type=\"checkbox\" name=\"tabs\">\n    <label for=\"cp_tabfour037\">福利厚生はどのようなものがありますか？</label>\n    <div class=\"cp_actab-content\">\n    <p>ユトリアグループならではの福利厚生として、路線バス（山交バス）の利用やリナワールド、蔵王ライザスキー場などグループ施設での従業員限定割引が利用できます。</p>\n    </div>\n  </div>\n  <div class=\"cp_actab\">\n    <input id=\"cp_tabfour039\" type=\"checkbox\" name=\"tabs\">\n    <label for=\"cp_tabfour039\">まだどんな仕事をしたいかわかりません</label>\n    <div class=\"cp_actab-content\">\n    <p>ユトリアグループは「やりたいことが見つかる会社」です。様々な事業を展開しているので、様々な仕事にチャレンジする中で、きっと自分のやりたい仕事が見つかると思います。</p>\n    </div>\n  </div>\n  <div class=\"cp_actab\">\n    <input id=\"cp_tabfour040\" type=\"checkbox\" name=\"tabs\">\n    <label for=\"cp_tabfour040\">離職率はどうなっていますか？</label>\n    <div class=\"cp_actab-content\">\n    <p>離職率は低いです。例えば、入社3年以内の総合職社員の離職率は0％です。（2024.4.1時点）</p>\n    </div>\n  </div>\n  <div class=\"cp_actab\">\n    <input id=\"cp_tabfour041\" type=\"checkbox\" name=\"tabs\">\n    <label for=\"cp_tabfour041\">財務状況を教えてください</label>\n    <div class=\"cp_actab-content\">\n    <p><span class=\"fw01\">売上高</span><br />ヤマコー単体：25億6411万8000円<br />ユトリアグループ連結: 115億3759万円</p>\n    <p><span class=\"fw01\">経常利益</span><br />ヤマコー単体: 1億6002万7000円<br />ユトリアグループ連結: 10億3552万7000円</p>\n    <p><span class=\"fw01\">純利益</span><br />ヤマコー単体: ▲1695万7000円<br />ユトリアグループ連結: 8億0188万9000円<br />（2025年3月期）</p>\n    <p><span class=\"fw01\">総資産</span><br />ヤマコー単体: 114億8329万9000円<br />ユトリアグループ連結: 217億9583万3000円<br />（2025年3月31日現在）</p>\n    </div>\n  </div>\n  <div class=\"cp_actab\">\n    <input id=\"cp_tabfour042\" type=\"checkbox\" name=\"tabs\">\n    <label for=\"cp_tabfour042\">女性が活躍できる会社ですか？また、女性管理職比率はどのくらいですか？</label>\n    <div class=\"cp_actab-content\">\n    <p>女性取締役をはじめ、現在4名が女性管理職として活躍しています。女性管理職比率は16.6％（2025年1月現在）で、決して高い比率ではありませんが、性別を問わない公平な人事評価と昇格・昇給を行っていますので、今後もさらに女性管理職は増える見込みです。</p>\n    <p>さらに女性の活躍を推進するため、女性取締役を中心とした定期的な「女性社員懇談会」や労働組合の「女性セミナー」などを実施し、女性が働く環境の改善に取り組んでいます。</p>\n    <p class=\"qa-images\"><img src=\"https://www.yamako.co.jp/recruit-img/qa-image01.jpg\" alt=\"女性社員懇談会の様子\" class=\"img-responsive\"></p>\n    <p class=\"qa-images\"><img src=\"https://www.yamako.co.jp/recruit-img/qa-image02.jpg\" alt=\"女性社員懇談会の様子\" class=\"img-responsive\"></p>\n  </div>\n  </div>\n  </div>\n      </div><!-- /.container -->\n    </div><!-- /.sec04-wrap-->\n  </section><!-- /.sec04 -->\n\n  <section id=\"sec03\">\n    <div class=\"sec03-wrap\">\n      <div class=\"container \">\n        <h2>Staff int<span class=\"titcolor\">e</span>rvi<span class=\"titcolor\">e</span>w<span class=\"sub\">先輩社員に聞いてみよう！</span></h2>\n\n          <div class=\"row\">\n            <div class=\"col-xs-12\">\n             <ul class=\"slider staff-wrap\">\n\n                <li class=\"style-box\">\n                  <a class=\"popup-modal\" href=\"#inline-wrap06\">\n                    <img src=\"https://www.yamako.co.jp/recruit-img/sec03-img01.png\" alt=\"ヤマコー先輩社員1\" class=\"img-responsive\">\n                  </a>\n                  <div id=\"inline-wrap06\" class=\"mfp-hide\">\n                    <div class=\"row\">\n                      <div class=\"col-sm-12\"><h5>色々な職務を経験して成長</h5></div>\n                      <div class=\"col-sm-6\"><img src=\"https://www.yamako.co.jp/recruit-img/sec03-img01-1.png\" class=\"img-responsive center-block hidden-xs\"><img src=\"https://www.yamako.co.jp/recruit-img/sec03-simg01-1.png\" class=\"img-responsive center-block visible-xs\"></div>\n                      <div class=\"col-sm-6\">\n                        <p>大学時代、特にやりたいこともなく悩んでいたところ、ヤマコーの採用情報をみて「いろいろやってる会社なんだなぁ」と働いてからやりたいことを探すのもいいかなと思い応募しました。</p>\n                        <p>今は総務課で採用や広報の業務をしています。バスを利用する方や求職者の方に自社を知ってもらうために様々な企画を行っています。たくさんのアイデアを出すのは大変ですが、それが実現した時は達成感を感じられると思います。</p>\n                        <p>総務課の前は仙台観光センターで貸切バスの営業をしていました。色々なお客様と出会い、出張や添乗業務等いろいろな場所にも行きました。その時培った経験が、畑の違う総務という仕事でも生かされていると思います。色々な職務を経験して成長できるのがヤマコーの魅力だと思います。</p>\n                        </div>\n                      <p class=\"popup-modal-dismiss hidden-xs\"><a href=\"close\"><img src=\"https://www.yamako.co.jp/recruit/common/img/icon-close.png\" class=\"img-responsive center-block\"></a></p>\n                      <p class=\"popup-modal-dismiss visible-xs\"><a href=\"close\">閉じる</a></p>\n                    </div><!-- /.row -->\n                  </div><!-- /#inline-wrap02 -->\n                </li><!-- /.style-box-->\n\n                <li class=\"style-box\">\n                  <a class=\"popup-modal\" href=\"#inline-wrap02\">\n                    <img src=\"https://www.yamako.co.jp/recruit-img/sec03-img02.png\" alt=\"ヤマコー先輩社員2\" class=\"img-responsive\">\n                  </a>\n                  <div id=\"inline-wrap02\" class=\"mfp-hide\">\n                    <div class=\"row\">\n                      <div class=\"col-sm-12\"><h5>お客様の声を形に</h5></div>\n                      <div class=\"col-sm-6\"><img src=\"https://www.yamako.co.jp/recruit-img/sec03-img02-1.png\" class=\"img-responsive center-block hidden-xs\"><img src=\"https://www.yamako.co.jp/recruit-img/sec03-simg02-1.png\" class=\"img-responsive center-block visible-xs\"></div>\n                      <div class=\"col-sm-6\">\n                        <p>「山形県を盛り上げられる」可能性のある企業であり、添乗員の経験を活かせる「観光業界」につながっていること。そして当時の採用担当の方々のお人柄から会社の雰囲気がとても良いと感じ、入社を決意しました。</p>\n                        <p>山交観光㈱に出向し、現在は“募集型企画旅行”のツアー企画造成を行う部署に所属しています。出発決定ツアーの手続き・準備をメインで行い、企画も提案します。顧客獲得・満足度向上のための提案をブラッシュアップし、形にしたときにとてもやりがいを感じます。</p>\n                        <p>育休取得後、復帰した際には時短勤務や子供の病気など急な休みにも柔軟に対応して頂いており、会社規定の改善もあってとても働きやすいと感じています。一緒に働けることを楽しみにしています！</p>\n                        </div>\n                      <p class=\"popup-modal-dismiss hidden-xs\"><a href=\"close\"><img src=\"https://www.yamako.co.jp/recruit/common/img/icon-close.png\" class=\"img-responsive center-block\"></a></p>\n                      <p class=\"popup-modal-dismiss visible-xs\"><a href=\"close\">閉じる</a></p>\n                    </div><!-- /.row -->\n                  </div><!-- /#inline-wrap02 -->\n                </li><!-- /.style-box-->\n\n                <li class=\"style-box\">\n                  <a class=\"popup-modal\" href=\"#inline-wrap03\">\n                    <img src=\"https://www.yamako.co.jp/recruit-img/sec03-img03.png\" alt=\"ヤマコー先輩社員3\" class=\"img-responsive\">\n                  </a>\n                  <div id=\"inline-wrap03\" class=\"mfp-hide\">\n                    <div class=\"row\">\n                      <div class=\"col-sm-12\"><h5>お客様の笑顔が活力に</h5></div>\n                      <div class=\"col-sm-6\"><img src=\"https://www.yamako.co.jp/recruit-img/sec03-img03-1.png\" class=\"img-responsive center-block hidden-xs\"><img src=\"https://www.yamako.co.jp/recruit-img/sec03-simg03-1.png\" class=\"img-responsive center-block visible-xs\"></div>\n                      <div class=\"col-sm-6\">\n                        <p>大学生の頃、ヤマコーが運営するするスポーツクラブでアルバイトをしていました。ヤマコーの人と接する仕事に魅力を感じ、入社しました。</p>\n                        <p>現在はヤマコーリナワールド事業部で旅行代理店様への営業やイベントの企画を担当しています。遊園地という他にはない環境を活かしつつ、自分が【やりたい】【見たい】を形にし、「楽しかった」の声をいただいたり企画を目当てに多くのお客様にご来園いただいいた時は達成感があります。</p>\n                        <p>私は山交観光にもいましたので、お客様を【送客する側】と【受ける側】の両方を経験しています。これは幅広い分野を展開しているユトリアグループでしかできないことだと思います。この経験を活かし、遊園地を通して山形の観光業を盛り上げていきたいです。</p>\n                        </div>\n                      <p class=\"popup-modal-dismiss hidden-xs\"><a href=\"close\"><img src=\"https://www.yamako.co.jp/recruit/common/img/icon-close.png\" class=\"img-responsive center-block\"></a></p>\n                      <p class=\"popup-modal-dismiss visible-xs\"><a href=\"close\">閉じる</a></p>\n                    </div><!-- /.row -->\n                  </div><!-- /#inline-wrap03 -->\n                </li><!-- /.style-box-->\n\n                <li class=\"style-box\">\n                  <a class=\"popup-modal\" href=\"#inline-wrap05\">\n                    <img src=\"https://www.yamako.co.jp/recruit-img/sec03-img04.png\" alt=\"ヤマコー先輩社員4\" class=\"img-responsive\">\n                  </a>\n                  <div id=\"inline-wrap05\" class=\"mfp-hide\">\n                    <div class=\"row\">\n                      <div class=\"col-sm-12\"><h5>デザインでユトリアを盛り上げる</h5></div>\n                      <div class=\"col-sm-6\"><img src=\"https://www.yamako.co.jp/recruit-img/sec03-img04-1.png\" class=\"img-responsive center-block hidden-xs\"><img src=\"https://www.yamako.co.jp/recruit-img/sec03-simg04-1.png\" class=\"img-responsive center-block visible-xs\"></div>\n                      <div class=\"col-sm-6\">\n                        <p>ヤマコーのオープンカンパニーに参加したことが入社のきっかけです。参加前まではバス会社という印象でしたが、それ以外にも商業施設の運営や遊園地、スキー場など多岐にわたる事業を展開していることを知り興味が湧きました。大学で山形の様々な方との交流を通して、山形の魅力を多くの人に伝えたいという気持ちがあったので、山形の観光を支えるユトリアグループで働いてみたいという想いが強くなり入社を決意しました。</p>\n                        <p>現在は大学で学んだ知識を活かし、チラシ・看板・ラッピングなどのデザイン、SNSでの情報発信によるユトリアグループの魅力を発信などを行っております。困っていることをデザインを通してサポートできるところや手掛けたデザインが形になるところにやりがいを感じております。</p>\n                        <p>困っていると助けてくれる先輩方がたくさんいるので安心して働けます。一緒に働けるのを楽しみにしております。</p>\n                        </div>\n                      <p class=\"popup-modal-dismiss hidden-xs\"><a href=\"close\"><img src=\"https://www.yamako.co.jp/recruit/common/img/icon-close.png\" class=\"img-responsive center-block\"></a></p>\n                      <p class=\"popup-modal-dismiss visible-xs\"><a href=\"close\">閉じる</a></p>\n                    </div><!-- /.row -->\n                    </div><!-- /#inline-wrap05 -->\n                </li><!-- /.style-box-->\n             \n          </ul><!-- slider -->\n        </div><!-- col-xs-12 -->\n      </div><!-- /.row -->\n        <div class=\"move\">\n         <ul>\n          <li>\n           <iframe width=\"100%\" height=\"100%\" src=\"https://www.youtube.com/embed/ct3qXNRwVZU?si=Ov0M9ivVIE4kEKfP\" title=\"ヤマコー採用動画「社員インタビュー」篇\" frameborder=\"0\" allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share\" referrerpolicy=\"strict-origin-when-cross-origin\" allowfullscreen></iframe>\n          </li><li>\n           <iframe width=\"100%\" height=\"100%\" src=\"https://www.youtube.com/embed/VXOBR0dtxCc?si=ySUFJg80zGPyRDy9W\" title=\"社員インタビュー「育休制度について」篇　#育休制度について\" frameborder=\"0\" allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share\" referrerpolicy=\"strict-origin-when-cross-origin\" allowfullscreen></iframe>\n          </li><li>\n           <iframe width=\"100%\" height=\"100%\" src=\"https://www.youtube.com/embed/KmbMPyL2-gk\" title=\"採用動画「社員の一日～仙台観光センター～」篇　#shorts #社員の一日\" frameborder=\"0\" allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share\" referrerpolicy=\"strict-origin-when-cross-origin\" allowfullscreen></iframe>\n          </li><li>\n           <iframe width=\"100%\" height=\"100%\" src=\"https://www.youtube.com/embed/8tomwCeFNCU?si=boXQHaU1Sq3Tb1ne\" title=\"採用動画「社員の一日～リナワールド～」篇　#shorts #社員の一日\" frameborder=\"0\" allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share\" referrerpolicy=\"strict-origin-when-cross-origin\" allowfullscreen></iframe>\n          </li>\n         </ul>\n       </div><!-- /.move-->\n    </div><!-- /.container -->\n    </div><!-- /.sec03-wrap-->\n  </section><!-- /.sec03 -->\n\n    <section id=\"sec01\">\n      <div class=\"container\">\n        <h2>M<span class=\"titcolor\">e</span>ssag<span class=\"titcolor\">e</span><span class=\"sub\">メッセージ</span></h2>\n        <div class=\"row\">\n          <div class=\"sec01-simg visible-xs\"><img src=\"https://www.yamako.co.jp/recruit/common/img/sec01-simg01.png\" class=\"center-block\" alt=\"\"></div>\n          <div class=\"sec01-txt\">\n            <p>株式会社ヤマコーは、三山電鉄、高畠鉄道、尾花沢鉄道、山形交通自動車商会、今村自動車の5社が集まった「山形交通株式会社」から始まりました。創業から80余年、楽しんでいただける場所を提供し、山形県民のみなさんの足として地域とともに歩んで参りました。山形の交通を支えるという創業時の思いは、記章にも込められています。</p>\n            <p>我々はこれまで、交通のみならず様々な事業を展開してきました。そしてこれからも、時代の変化に対応し、これまでのやり方にとらわれずチャレンジし続けます。</p>\n            <p>我々が求める人材は、そうしたなんでもチャレンジできる姿勢をもった人です。具体的には、やってみたい、知りたいという好奇心を持つ人です。</p>\n            <p>「チャレンジを通して山形を盛り上げたい」そんな想いをもった人たちと一緒に仕事がしたいです。</p>\n            <p>代表取締役会長<span>平井康博</span></p>\n          </div><!-- /.col-sm-3 -->\n        </div><!-- /.row -->\n       <div class=\"diamond\">\n        <img class=size src=\"https://www.yamako.co.jp/recruit-img/yamagata-smile-company.jpg\" alt=\"やまがたスマイル企業DIAMOND 株式会社ヤマコー\" >\n       </div>\n      </div><!-- /.post-wrap -->\n    </section><!-- /#entry -->\n\n\n  <section id=\"sec05\">\n    <div class=\"sec05-wrap\" style=\"padding-bottom: 0;\">\n      <h3>応募職種</h3>\n        <div class=\"row\">\n            <div class=\"sec05-icon01\">総合職</div>\n            <div class=\"col-sm-5\">\n              <img src=\"https://www.yamako.co.jp//sec05-1-2024.jpg\" alt=\"2024年採用ヤマコー社員\" class=\"img-responsive\">\n            </div>\n            <div class=\"col-sm-7\">\n              <p>(株)ヤマコーの事業である不動産、スポーツレジャー施設やグループ企業のバス事業、旅行業、索道事業などでの営業・企画・総務・経理業務等、幅広く活躍いただきます。</p>\n            </div>\n        </div><!-- /.row -->\n      </div><!-- /.sec05-wrap -->\n  </section><!-- /.sec05 -->\n    \n    \n    <!------------ communication Section ------------>\n  <section id=\"sec06\" style=\"padding-top:80px;\">\n    <div class=\"sec06-wrap\">\n        <h4 class=\"wow fadeInDown\" data-wow-delay=\"300ms\">RECRUIT GUIDELINES<span>募集概要</span></h4>\n      <div class=\"box\">\n          <table class=\"guidelines\">\n            <tbody>\n                <tr>\n                  <th>募集人員</th>\n                  <td colspan=\"2\" class=\"sub-tit01\">若干名</td>\n                </tr>\n                <tr>\n                  <th>募集学部・学科</th>\n                  <td colspan=\"2\" class=\"sub-tit01\">4年制大学または大学院の全学部・全学科</td>\n                </tr>\n                <tr>\n                    <th rowspan=\"9\">採用後の待遇</th>\n                    <td class=\"sub-tit01\">基本給</td>\n                    <td>【各社共通】　四大卒・大学院了・既卒220,000円（諸手当除く）</td>\n                </tr>\n                <tr>\n                    <td class=\"sub-tit01\">諸手当</td>\n                    <td>【各社共通】　時間外手当、家族手当、通勤手当、営業手当、資格手当、その他</td>\n                </tr>\n                <tr>\n                    <td class=\"sub-tit01\">昇給</td>\n                    <td>【各社共通】　年1回（4月）</td>\n                </tr>\n                <tr>\n                    <td class=\"sub-tit01\">賞与</td>\n                    <td>【各社共通】年2回（7月・12月）</td>\n                </tr>\n                <tr>\n                    <td class=\"sub-tit01\">休日・休暇</td>\n                    <td>【各社共通】<br>年間120日（祝日・年末年始休暇など）<br>年次有給休暇、特別休暇（慶弔など）、リフレッシュ休暇<br>事業所によってはシフト制になります</td>\n                </tr>\n                <tr>\n                    <td class=\"sub-tit01\">待遇・福利厚生・<br class=\"hidden-xs\">社内制度</td>\n                    <td>【各社共通】<br>従業員証により山交バス乗車可能（一部路線制限あり）<br>健康保険、厚生年金、雇用保険、労災保険、育児休業制度、<br>介護休暇制度などまた、 ソフトボール・野球・ボウリング・ゴルフ等の社内スポーツ大会、保養施設・社員旅行の費用補助、総合スポーツクラブ「トップロード」の会費補助、「リナワールド」での家族レクリェーション補助など</td>\n                </tr>\n                <tr>\n                    <td class=\"sub-tit01\">勤務地</td>\n                    <td>【ユトリアグループ各社】<br>山形県（庄内地区を除く全域）、宮城県仙台市（山形交通のみ）</td>\n                </tr>\n\n                <tr>\n                    <td class=\"sub-tit01\">勤務時間</td>\n                    <td>※ 事業所により勤務時間は異なります。</td>\n                </tr>\n                <tr>\n                    <td class=\"sub-tit01\">研修制度</td>\n                    <td>【グループ共通】<br>新入社員研修<br>新社員（主に入社3年以内）研修<br>階層別研修<br>世代別研修<br>社外研修への派遣</td>\n                </tr>\n            </tbody>\n          </table>\n        \n      </div><!-- /.box-->\n  </div>\n  </section>\n\n  <section id=\"sec07\">\n    <div class=\"sec07-wrap\">\n            <h4>RECRUIT SCHEDULE<span>採用スケジュール</span></h4>\n            <table>\n                <tbody>\n                    <tr>\n                        <td class=\"sec07-point\"><img src=\"https://www.yamako.co.jp/recruit/common/img/sec07-img01.png\" alt=\"\" class=\"img-responsive\"></td>\n                        <th>エントリーフォームよりエントリー、及びエントリーシートの提出</th>\n                    </tr>\n                    <tr>\n                        <td class=\"sec07-point\"><img src=\"https://www.yamako.co.jp/recruit/common/img/sec07-img02.png\" alt=\"\" class=\"img-responsive\"></td>\n                        <th>当社会社説明会への参加</th>\n                    </tr>\n                    <tr>\n                        <td class=\"sec07-point\"><img src=\"https://www.yamako.co.jp/recruit/common/img/sec07-img03.png\" alt=\"\" class=\"img-responsive\"></td>\n                        <th>適性検査：当社会社説明会時に併せて実施します</th>\n                    </tr>\n                    <tr>\n                        <td class=\"sec07-point\"><img src=\"https://www.yamako.co.jp/recruit/common/img/sec07-img04.png\" alt=\"\" class=\"img-responsive\"></td>\n                        <th>面接（個人）：採用担当者面接</th>\n\n                    </tr>\n                    <tr>\n                        <td class=\"sec07-point\"><img src=\"https://www.yamako.co.jp/recruit/common/img/sec07-img05.png\" alt=\"\" class=\"img-responsive\"></td>\n                        <th>面接（個人）：役員面接</th>\n                    </tr>\n                    <tr>\n                        <td class=\"sec07-point\"><img src=\"https://www.yamako.co.jp/recruit/common/img/sec07-img06.png\" alt=\"\" class=\"img-responsive\"></td>\n                        <th>内々定</th>\n                    </tr>\n                </tbody>\n            </table>\n            <p class=\"sec07-txt\">※総合職はグループ採用となります。(株)ヤマコーに入社の後、本人の希望・適性等を考慮し(株)ヤマコーの各事業部またはグループ各社へ配属（在籍出向）となります。また、幅広く業務に携わっていただくため、グループ会社間で異動（在籍出向）することもあります。</p>\n    </div><!-- /.sec07-wrap -->\n    <div id=\"entry01\" class=\"sec07-wrap entry-wrap\">\n            <h4>ENTRY<span>エントリー</span></h4>\n    <div align=\"center\" id=\"size-bnr\" style=\"margin-top:3%;\">\n\n     <a href=\"https://job.mynavi.jp/27/pc/search/corp222025/outline.html\" target=\"_blank\">\n \n       <img src=\"https://www.yamako.co.jp/recruit/img/banner_entry_160_45.gif\" alt=\"マイナビ2027\" border=\"0\">\n\n     </a>\n    </div>  \n    <div align=\"center\" style=\"margin-top:3%;\">\n\n     <a href=\"https://job.rikunabi.com/n/company_jobs/?key=AAAAAQCnkp6xpmjtdmBEL7gZ7kurRLBCiVcVe8RteEPolG24daGLbw%3D%3D\" target=\"\">\n \n       <img style=\"width:238px;\" src=\"https://www.yamako.co.jp/logo_rikunavi.png\" width=\"238\" height=\"60\" border=\"0\">\n\n     </a>\n    </div>           \n<!--\n            <p>2022年度の募集は終了しました。</p>\n<!--\n    <p style=\"display:none;\">必須事項は必ずご入力ください。</p>\n            <div class=\"entry-box\" style=\"display:none!important;\">\n    mt:setvar name=\"my_form\" value=\"[[aform007]]\">\n    mt:var name=\"my_form\" aform=\"1\">\n            </div>\n-->\n    </div><!-- /.sec07-wrap -->\n  </section><!-- /.sec07 -->\n\n    </div><!-- /#contents -->\n\n\n  <!------------ FOOTER ------------>\n<footer id=\"ft01\">\n  <div class=\"container-fluid\">\n    <div class=\"row clearfix\">\n    <div class=\"totop\"><a href=\"#\"><img src=\"https://www.yamako.co.jp/recruit/common/img/pgtop.png\" alt=\"PAGE TOP\"></a></div>\n    <div class=\"col-sm-12\">\n        <p>株式会社ヤマコー　　採用担当チーム<br>〒990-2492山形県山形市鉄砲町2-13-18　TEL 023-622-5181（代表）　FAX 023-622-8215</p>\n    </div>\n  </div>\n  </div>\n  <div class=\"cp\">\n    <p>Copyright&copy; 2021 YAMAKO All rights Reserved.</p>\n  </div>\n</footer>\n  \n    <!-- jQuery -->\n    <!--<script src=\"https://ajax.googleapis.com/ajax/libs/jquery/1.11.0/jquery.min.js\"></script>-->\n    <script src=\"https://www.yamako.co.jp/recruit/common/js/jquery.js\"></script>\n    <script src=\"https://www.yamako.co.jp/recruit/common/js/bootstrap.min.js\"></script>\n    \n<script type=\"text/javascript\">\n    $(function() {\n        var topBtn = $('.totop');    \n        //スクロールしてトップ\n        topBtn.click(function () {\n            $('body,html').animate({\n                scrollTop: 0\n            }, 500);\n            return false;\n        });\n      });\n\n/*-- 携帯menuをクリックしたらmenu閉じる --*/\n$(document).ready(function () {\n    $(\".navbar-nav li a\").click(function(event) {\n        $(\".navbar-collapse\").collapse('hide');\n    });\n});\n</script>\n\n    <!-- Slid