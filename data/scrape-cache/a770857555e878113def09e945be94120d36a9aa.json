{"url":"https://www.hitachi-hpm.co.jp/recruit/newgraduate/interview/02.html","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n<head>\n<!-- Google Tag Manager -->\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n})(window,document,'script','dataLayer','GTM-M9FCJQP');</script>\n<!-- End Google Tag Manager -->\n<meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0, user-scalable=no, minimum-scale=1.0, maximum-scale=1.0\">\n<meta name=\"format-detection\" content=\"telephone=no\">\n<meta name=\"author\" content=\"Hitachi Plant Mechanics Co., Ltd.\">\n<meta name=\"robots\" content=\"index, follow\">\n<meta name=\"keywords\" content=\"日立プラントメカニクス,日立グループ,採用,採用情報,クレーン,産業用クレーン,新卒\">\n<meta name=\"description\" content=\"クレーンの製作から保守・メンテナンスまで一貫したビジネスを展開する株式会社 日立プラントメカニクスの先輩社員のインタビューです。\">\n<title>Yudai.A：株式会社 日立プラントメカニクス</title>\n<link rel=\"index\" href=\"http://www.hitachi-hpm.co.jp/\" title=\"ホーム\">\n<link rel=\"stylesheet\" type=\"text/css\" media=\"screen,print\" href=\"/css/jp/r1/common.css\">\n<link rel=\"stylesheet\" type=\"text/css\" media=\"screen,print\" href=\"/css/jp/r1/responsive.css\">\n<link rel=\"stylesheet\" type=\"text/css\" media=\"screen,print\" href=\"/css/jp/r1/wide.css\">\n<link rel=\"stylesheet\" type=\"text/css\" media=\"screen,print\" href=\"/css/jp/r1/common2.css\">\n<link rel=\"stylesheet\" type=\"text/css\" media=\"print\" href=\"/css/jp/r1/print.css\">\n<link rel=\"stylesheet\" type=\"text/css\" media=\"screen,print\" href=\"/recruit/css/recruit.css\">\n<link rel=\"stylesheet\" type=\"text/css\" media=\"print\" href=\"/recruit/css/recruit_print.css\">\n<script type=\"text/javascript\" src=\"/js/lib/jquery.js\"></script>\n<script type=\"text/javascript\" charset=\"Shift_JIS\" src=\"/js/jp/r1/common.js\"></script>\n<script type=\"text/javascript\" charset=\"Shift_JIS\" src=\"/js/jp/r1/responsive.js\"></script>\n<script type=\"text/javascript\" charset=\"Shift_JIS\" src=\"/js/jp/r1/wide.js\"></script>\n<script type=\"text/javascript\" charset=\"Shift_JIS\" src=\"/js/jp/r1/common2.js\"></script>\n<script type=\"text/javascript\" src=\"https://module.hitachi.com/search/js/sug.js#sv=//mf2aps06.marsflag.com/hitachi__RGN_JAPAN__result_00\"></script>\n<script type=\"text/javascript\" src=\"/recruit/js/newgraduate.js\"></script>\n<script type=\"text/javascript\" src=\"/recruit/js/recruit.js\"></script>\n</head>\n<body>\n<!-- Google Tag Manager (noscript) -->\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-M9FCJQP\"\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n<!-- End Google Tag Manager (noscript) -->\n\n<p id=\"top\"><a href=\"#body\">ページの本文へ</a></p>\n\n<div id=\"HeaderArea1\">\n\t<div class=\"Container Wide\">\n\n\t\t<div id=\"Statement\"><a href=\"https://www.hitachi.co.jp/\"><img src=\"/image/jp/r1/common2/corp_id.png\" alt=\"Hitachi\"></a></div>\n\n\t\t<div id=\"SupportNavi\" class=\"SupportNaviIconText\">\n\n\t\t\t<a href=\"https://www8.hitachi.co.jp/inquiry/hitachi-hpm/general/form.jsp\" target=\"_blank\"><img src=\"/image/jp/r1/common2/icon_mail.png\" alt=\"お問い合わせ\"><span>お問い合わせ</span></a>\n\n\t\t\t<button type=\"button\" id=\"SupportNaviSearch\" aria-expanded=\"false\" aria-controls=\"SearchFormArea\"><span><img src=\"/image/jp/r1/common2/icon_search.png\" alt=\"検索\"><span>検索</span></span></button>\n\t\t\t<div id=\"SearchFormArea\">\n\t\t\t\t<div>\n\t\t\t\t\t<button class=\"BtnClose\" aria-label=\"閉じる\"></button>\n\t\t\t\t\t<form action=\"https://module.hitachi.com/search/RGN_JAPAN.html\" method=\"get\" accept-charset=\"UTF-8\">\n\t\t\t\t\t\t<input type=\"hidden\" name=\"imgsize\" value=\"3\">\n\t\t\t\t\t\t<input type=\"hidden\" name=\"pagemax\" value=\"10\">\n\t\t\t\t\t\t<div class=\"SearchGroup\">\n\t\t\t\t\t\t\t<input type=\"text\" name=\"q\" size=\"20\" maxlength=\"40\" accesskey=\"s\" title=\"検索キーワード\" placeholder=\"日立グループ全体から検索\" autocomplete=\"off\" class=\"SearchPhrease\" id=\"MF_form_phrase\">\n\t\t\t\t\t\t\t<button class=\"SearchBtn\" type=\"submit\">検索</button>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</form>\n\t\t\t\t</div>\n\t\t\t</div><!--/#SearchFormArea-->\n\t\t</div><!--/#SupportNavi-->\n\n\t\t<button id=\"SpMenuBtn\" aria-label=\"メニュー\">\n\t\t\t<span></span>\n\t\t\t<span></span>\n\t\t\t<span></span>\n\t\t</button>\n\n\t</div><!--/.Container-->\n</div><!--/#HeaderArea1-->\n\n<div id=\"HeaderArea2\">\n\t<div class=\"Container Wide\">\n\t\t<div id=\"SiteID\">\n\t\t\t<a href=\"/index.html\"><span>株式会社 日立プラントメカニクス</span></a>\n\t\t\t<a href=\"/recruit/index.html\"><span>採用情報</span></a>\n\t\t</div>\n\t\t<ul id=\"GlobalNaviMenu\">\n\t\t\t<li><a href=\"/recruit/newgraduate/about.html\">会社概要</a></li>\n\t\t\t<li><a href=\"/recruit/newgraduate/info.html\">福利厚生</a></li>\n\t\t\t<li><a href=\"/recruit/office.html\">事業所紹介</a></li>\n\t\t\t<li><a href=\"/recruit/newgraduate/job/index.html\">仕事風景</a></li>\n\t\t\t<li class=\"Current\"><a href=\"/recruit/newgraduate/index.html\"><em>新卒採用</em></a></li>\n\t\t\t<li><a href=\"https://en-gage.net/hpm_careersaiyo/\" target=\"_blank\">経験者採用</a></li>\n\t\t\t<li><a href=\"/recruit/disability/index.html\">障がい者採用</a></li>\n\t\t</ul>\n\t</div><!--/.Container-->\n</div><!--/#HeaderArea2-->\n\n<div id=\"Contents\" class=\"interview-page01\">\n\n\t<div class=\"breadcrumb-list\">\n\t\t<div class=\"GridSet\">\n\t\t\t<div class=\"Grid4\">\n\t\t\t\t<ul>\n\t\t\t\t\t<li><a href=\"/recruit/index.html\">採用情報トップページ</a></li>\n\t\t\t\t\t<li><a href=\"/recruit/newgraduate/index.html\">新卒採用</a></li>\n\t\t\t\t\t<li><a href=\"/recruit/newgraduate/interview/index.html\">先輩社員の声</a></li>\n\t\t\t\t\t<li>Yudai.A</li>\n\t\t\t\t</ul>\n\t\t\t</div>\n\t\t</div>\n\t</div><!-- /.breadcrumb-list -->\n\n\n\n\t<div class=\"GridSet\">\n\t\t<div class=\"Grid4\">\n\n\t\t\t<div class=\"section-recruit\" id=\"section-interview-top\">\n\n\t\t\t\t<div class=\"recruit-title-en is-vertical\">INTERVIEW</div>\n\n\t\t\t\t<div class=\"interview-top-wrap\">\n\t\t\t\t\t<div class=\"interview-top-bg-bottom\"></div>\n\t\t\t\t\t<div class=\"interview-top-bg-photo\" style=\"background-image: url(/recruit/newgraduate/interview/image-02/img_interview_02_top.jpg);\"></div>\n\n\t\t\t\t\t<div class=\"interview-copy-wrap\">\n\t\t\t\t\t\t<!--<p class=\"interview-copy-num\">02</p>-->\n\t\t\t\t\t\t<span class=\"interview-copy\">\n\t\t\t\t\t\t\t<span class=\"blank\"></span>お客様の現場で迷惑をかけることのないように、<br class=\"only-pc\"><span class=\"blank\"></span>まずは工場内の検査業務をしっかり実行しています。\n\t\t\t\t\t\t</span>\n\t\t\t\t\t</div>\n\t\t\t\t\t<div class=\"interview-profile\">\n\t\t\t\t\t\t<span class=\"interview-profile-homed\">\n\t\t\t\t\t\t\t品質保証\n\t\t\t\t\t\t</span>\n\t\t\t\t\t\t<span class=\"interview-profile-name\">\n\t\t\t\t\t\t\tYudai.A\n\t\t\t\t\t\t</span>\n\t\t\t\t\t\t<span class=\"interview-profile-joined\">\n\t\t\t\t\t\t\t2025年入社\n\t\t\t\t\t\t</span>\n\t\t\t\t\t\t<a href=\"/recruit/newgraduate/job/index.html#anc-job07\" class=\"interview-profile-link\"><div class=\"more-general\">品質保証の仕事とは<span></span></div></a>\n\t\t\t\t\t</div>\n\t\t\t\t</div><!-- /.interview-top-wrap -->\n\n\t\t\t</div><!-- /#section-interview-top -->\n\n\n\n\t\t\t<div class=\"section-recruit\" id=\"section-interview-patt01\">\n\n\t\t\t\t<div class=\"interview-patt01-bg\">\n\t\t\t\t\t<div class=\"back-text\">INTERVIEW</div>\n\n\t\t\t\t\t<div class=\"interview-patt-main\">\n\t\t\t\t\t\t<div class=\"interview-patt-main-text\">\n\t\t\t\t\t\t\t<div class=\"recruit-title-en is-red\">TOPIC 01</div>\n\t\t\t\t\t\t\t<div class=\"recruit-subtitle\">\n\t\t\t\t\t\t\t\t曖昧な判断で出荷しないよう<br>実物と図面をしっかり見比べて、<br>問題がないかを確認しています。\n\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t<div class=\"description\">\n\t\t\t\t\t\t\t\t<p>出荷したクレーンに問題があると、納入後にクレーンが停止してしまい、お客様の生産そのものに大きな影響を与えてしまいます。そのようなことがないように工場内、外注先、納入先での検査により製品の品質を担保し、事故や不良の発生を未然に防ぐことがとても大事です。もし不良が発生してしまっても、その影響が最小限となるように努めることが品質保証部の役割です。私はその中で、工場内での検査業務に携わっています。<br>\n少しでもわからないこと、自分で判断がつかないことはすぐ上司に相談するようにしています。品質保証にとってグレーは黒であり、あいまいな判断で製品を出荷するわけにはいきません。実物と図面をしっかり見比べて、問題がないかを確認しています。</p>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t\t<div class=\"interview-patt-main-photo\">\n\t\t\t\t\t\t\t<img src=\"/recruit/newgraduate/interview/image-02/img_interview_02_topic_01.jpg\" alt=\"\" width=\"492\">\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div><!-- /.interview-top-main -->\n\t\t\t\t</div><!-- /.interview-patt01-bg -->\n\n\t\t\t</div><!-- /#section-interview-patt01 -->\n\n\n\n\t\t\t<div class=\"section-recruit\" id=\"section-interview-patt02\">\n\n\t\t\t\t<div class=\"interview-patt02-bg\">\n\t\t\t\t\t<div class=\"interview-patt-bg-photo\">\n\t\t\t\t\t\t<img src=\"/recruit/newgraduate/interview/image-02/img_interview_02_topic_02_01.jpg\" alt=\"\" width=\"1368\">\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\n\t\t\t\t<div class=\"interview-patt-main\">\n\t\t\t\t\t<div class=\"interview-patt-main-text\">\n\t\t\t\t\t\t<div class=\"recruit-title-en is-red\">TOPIC 02</div>\n\t\t\t\t\t\t<div class=\"recruit-subtitle\">\n\t\t\t\t\t\t\t検査を進めてきた製品が完成品として動き出す時、<br class=\"only-pc\">とても大きなやりがいを感じます。\n\t\t\t\t\t</div>\n\t\t\t\t\t\t<div class=\"description\">\n\t\t\t\t\t\t\t<p>完成品の試運転を工場内で行う際、実際に動いているさまを自分の目で見ることができます。動き出すまでは本当にきちんと動いてくれるのかプレッシャーとなることもありますが、正常に動作する瞬間は、品質保証の一員としてとてもやりがいを感じます。まだ納入先での動作確認に立ち会った経験はありませんが、今後現地での試運転対応に従事できる日をとても楽しみにしています。<br>\n作業環境については制服や空調服、PC用液晶モニターや必要な工具類などが支給されますので、仕事を進める上での効率性や快適性は高いと感じています。</p>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t\t<div class=\"interview-patt-main-photo\">\n\t\t\t\t\t\t<img src=\"/recruit/newgraduate/interview/image-02/img_interview_02_topic_02_02.jpg\" alt=\"\" width=\"577\">\n\t\t\t\t\t</div>\n\t\t\t\t</div><!-- /.interview-top-main -->\n\n\t\t\t</div><!-- /#section-interview-patt02 -->\n\n\n\n\t\t\t<div class=\"section-recruit\" id=\"section-interview-patt03\">\n\n\t\t\t\t<div class=\"interview-patt03-bg\">\n\t\t\t\t\t<div class=\"back-text\">INTERVIEW<br>ABOUT US</div>\n\n\t\t\t\t\t<div class=\"interview-patt-main\">\n\t\t\t\t\t\t<div class=\"interview-patt-main-text\">\n\t\t\t\t\t\t\t<div class=\"recruit-title-en is-red\">TOPIC 03</div>\n\t\t\t\t\t\t\t<div class=\"recruit-subtitle\">\n\t\t\t\t\t\t\t周囲から頼られる、<br class=\"only-pc\">そんな先輩社員になれるように頑張っていきます。\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t<div class=\"description\">\n\t\t\t\t\t\t\t\t<p class=\"mb-80\">\n\t\t\t\t\t\t\t\tこの会社に入って一番嬉しく感じたことは、周囲の先輩がとても親切であり、相談すると理解するまで丁寧に教えてくれるところです。入社してから何かと気にかけてもらい、親身になって指導してもらえることには本当に感謝しています。学生時代は化学系の学科を専攻していましたが、機械や電気の知識習得についてもさらに貪欲にチャレンジしていこうと思っています。失敗にめげることなく努力を重ね、先輩たちのように周りから頼られ、後輩にきかれてもパッと応えることができるような人になれるように成長していきたいと考えています。\n\t\t\t\t\t\t\t</p>\n\t\t\t\t\t\t\t\t<p>\n\t\t\t\t\t\t\t\t\t<img src=\"/recruit/newgraduate/interview/image-02/img_interview_02_topic_03.jpg\" alt=\"\" width=\"755\">\n\t\t\t\t\t\t\t\t</p>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div><!-- /.interview-top-main -->\n\t\t\t\t</div><!-- /.interview-patt01-bg -->\n\n\t\t\t</div><!-- /#section-interview-patt03 -->\n\n\n\n\t\t\t<div class=\"section-recruit\" id=\"section-interview-patt04\">\n\n\t\t\t\t<div class=\"interview-patt04-bg\">\n\t\t\t\t\t<div class=\"interview-patt-wrap\">\n\t\t\t\t\t\t<div class=\"recruit-title recruit-title-left\">\n\t\t\t\t\t\t\t<h2>CURRENT<br>SITUATION</h2>\n\t\t\t\t\t\t\t<div class=\"recruit-subtitle\">最近ハマっていることは？</div>\n\t\t\t\t\t\t\t<div class=\"recruit-title-en\">INTERVIEW</div>\n\t\t\t\t\t\t</div>\n\n\t\t\t\t\t\t<div class=\"interview-patt-main\">\n\t\t\t\t\t\t\t<div class=\"interview-patt-main-text mt-adjust01\">\n\t\t\t\t\t\t\t\t<div class=\"recruit-subtitle\">\n\t\t\t\t\t\t\t\t\tお菓子作りに取り組んでいます\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t<div class=\"description\">\n\t\t\t\t\t\t\t\t\t<p>\n\t\t\t\t\t\t\t\t\t大学時代にとある洋菓子店のショートケーキに感動したことがきっかけで、ケーキやティラミスなどを作っています。年末年始の連休にはタルト作りに挑戦し、家族にイチゴタルトを振る舞いました。美味しいのはもちろんですが、人に喜んでもらえることがとても楽しいです。\n\t\t\t\t\t\t\t\t</p>\n\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t<div class=\"interview-patt-main-text mt-adjust01\">\n\t\t\t\t\t\t\t\t<div class=\"recruit-subtitle\">\n\t\t\t\t\t\t\t\t\t温浴施設巡りでリフレッシュ！\n\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t<div class=\"description\">\n\t\t\t\t\t\t\t\t\t<p>\n\t\t\t\t\t\t\t\t\t\t最近よく友人と一緒に自然豊かな公園を巡り歩き、そのあとに温浴施設で汗を流して会話を楽しんでいます。行った後はとてもリフレッシュできます。\n\t\t\t\t\t\t\t\t\t</p>\n\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</div><!-- /.interview-top-main -->\n\t\t\t\t\t</div><!-- /.interview-patt-wrap -->\n\t\t\t\t</div><!-- /.interview-patt04-bg -->\n\n\t\t\t</div><!-- /#section-interview-patt04 -->\n\n\n\n\t\t\t<div class=\"section-recruit printBreak\" id=\"section-interview-other\">\n\n\t\t\t\t<div class=\"recruit-title\">\n\t\t\t\t\t<div class=\"recruit-title-en\">INTERVIEW</div>\n\t\t\t\t\t<h2>OTHER INTERVIEW</h2>\n\t\t\t\t\t<div class=\"recruit-subtitle\">他のインタビューを見る</div>\n\t\t\t\t</div>\n\n\t\t\t\t<ul class=\"interview-other-list\">\n\t\t\t\t\t<li>\n\t\t\t\t\t\t<a href=\"/recruit/newgraduate/interview/01.html\">\n\t\t\t\t\t\t\t<img class=\"interview-other-list-photo\" src=\"/recruit/newgraduate/image/img_interview_other_01.jpg\" alt=\"\" width=\"312\">\n\t\t\t\t\t\t\t<div class=\"interview-other-list-text\">\n\t\t\t\t\t\t\t\t<p>クレーン設計</p><br>\n\t\t\t\t\t\t\t\t<span>Noritaka.S</span><br>\n\t\t\t\t\t\t\t\t<span>2019年入社</span>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</a>\n\t\t\t\t\t</li>\n\t\t\t\t\t<li>\n\t\t\t\t\t\t<a href=\"/recruit/newgraduate/interview/02.html\" class=\"is-current\">\n\t\t\t\t\t\t\t<img class=\"interview-other-list-photo\" src=\"/recruit/newgraduate/image/img_interview_other_02.jpg\" alt=\"\" width=\"312\">\n\t\t\t\t\t\t\t<div class=\"interview-other-list-text\">\n\t\t\t\t\t\t\t\t<p>品質保証</p><br>\n\t\t\t\t\t\t\t\t<span>Yudai.A</span><br>\n\t\t\t\t\t\t\t\t<span>2025年入社</span>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</a>\n\t\t\t\t\t</li>\n\t\t\t\t\t<li>\n\t\t\t\t\t\t<a href=\"/recruit/newgraduate/interview/03.html\">\n\t\t\t\t\t\t\t<img class=\"interview-other-list-photo\" src=\"/recruit/newgraduate/image/img_interview_other_03.jpg\" alt=\"\" width=\"312\">\n\t\t\t\t\t\t\t<div class=\"interview-other-list-text\">\n\t\t\t\t\t\t\t\t<p>サービス設計</p><br>\n\t\t\t\t\t\t\t\t<span>Shunya.T</span><br>\n\t\t\t\t\t\t\t\t<span>2018年入社</span>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</a>\n\t\t\t\t\t</li>\n\t\t\t\t\t<li>\n\t\t\t\t\t\t<a href=\"/recruit/newgraduate/interview/04.html\">\n\t\t\t\t\t\t\t<img class=\"interview-other-list-photo\" src=\"/recruit/newgraduate/image/img_interview_other_04.jpg\" alt=\"\" width=\"312\">\n\t\t\t\t\t\t\t<div class=\"interview-other-list-text\">\n\t\t\t\t\t\t\t\t<p>生産技術</p><br>\n\t\t\t\t\t\t\t\t<span>Ren.U</span><br>\n\t\t\t\t\t\t\t\t<span>2025年入社</span>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</a>\n\t\t\t\t\t</li>\n\t\t\t\t\t<li>\n\t\t\t\t\t\t<a href=\"/recruit/newgraduate/interview/05.html\">\n\t\t\t\t\t\t\t<img class=\"interview-other-list-photo\" src=\"/recruit/newgraduate/image/img_interview_other_05.jpg\" alt=\"\" width=\"312\">\n\t\t\t\t\t\t\t<div class=\"interview-other-list-text\">\n\t\t\t\t\t\t\t\t<p>営業</p><br>\n\t\t\t\t\t\t\t\t<span>Miho.Y</span><br>\n\t\t\t\t\t\t\t\t<span>2024年入社</span>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</a>\n\t\t\t\t\t</li>\n\t\t\t\t\t<li>\n\t\t\t\t\t\t<a href=\"/recruit/newgraduate/interview/06.html\">\n\t\t\t\t\t\t\t<img class=\"interview-other-list-photo\" src=\"/recruit/newgraduate/image/img_interview_other_06.jpg\" alt=\"\" width=\"312\">\n\t\t\t\t\t\t\t<div class=\"interview-other-list-text\">\n\t\t\t\t\t\t\t\t<p>アフターサービス</p><br>\n\t\t\t\t\t\t\t\t<span>Haruki.M</span><br>\n\t\t\t\t\t\t\t\t<span>2022年入社</span>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</a>\n\t\t\t\t\t</li>\n\t\t\t\t</ul><!-- /.interview-other-list -->\n\n\t\t\t</div><!-- /#section-interview-other -->\n\n\n\n<div class=\"section-recruit multiple\" id=\"section-entry\">\n<img src=\"/recruit/newgraduate/