 rel=\"stylesheet\" type=\"text/css\">\r\n  <link rel=\"stylesheet\" href=\"/assets/css/common.css\" rel=\"stylesheet\" type=\"text/css\">\r\n  <link rel=\"stylesheet\" href=\"/jobs/graduate/css/style.css\" rel=\"stylesheet\" type=\"text/css\">\r\n  <script src=\"/assets/js/jquery-3.6.0.js\"></script>\r\n  <script src=\"/assets/slick/slick.min.js\"></script>\r\n  <script src=\"/assets/js/script.js\"></script>\r\n\r\n<script type=\"application/ld+json\">\r\n[\r\n  {\r\n    \"@context\": \"https://schema.org/\",\r\n    \"@type\": \"JobPosting\",\r\n    \"title\": \"新卒採用（総合職・専任職・専門職・ツアースタッフ職）\",\r\n    \"description\": \"近江鉄道グループの新卒採用情報。鉄道・バス・タクシー・船舶・ロープウェー・サービスエリアなど多角的な事業を展開し、地域で暮らす人や滋賀に訪れる人の生活を支えています。\",\r\n    \"identifier\": {\r\n      \"@type\": \"PropertyValue\",\r\n      \"name\": \"近江鉄道株式会社\",\r\n      \"value\": \"GRAD\"\r\n    },\r\n    \"datePosted\": \"2026-02-01\",\r\n    \"validThrough\": \"2027-03-31T23:59:59Z\",\r\n    \"employmentType\": \"FULL_TIME\",\r\n    \"image\": \"https://www.ohmitetudo.co.jp/jobs/images/graduate/main_visual.jpg\",\r\n    \"hiringOrganization\": {\r\n      \"@type\": \"Corporation\",\r\n      \"@id\": \"https://www.ohmitetudo.co.jp/#organization\",\r\n      \"name\": \"近江鉄道株式会社\",\r\n      \"logo\": \"https://www.ohmitetudo.co.jp/common/images/logo.png\"\r\n    },\r\n    \"jobLocation\": {\r\n      \"@type\": \"Place\",\r\n      \"address\": {\r\n        \"@type\": \"PostalAddress\",\r\n        \"addressRegion\": \"滋賀県\",\r\n        \"addressCountry\": \"JP\"\r\n      }\r\n    },\r\n    \"occupationalCategory\": \"事務系総合職, 鉄道技術系総合職, 鉄道運転士養成職, 鉄道技術職, バス運転手養成職, バス整備職, 総合ガイド職, 接客販売職, 事務職, ツアースタッフ職\",\r\n    \"experienceRequirements\": {\r\n      \"@type\": \"OccupationalExperienceRequirements\",\r\n      \"monthsOfExperience\": 0\r\n    },\r\n    \"applicantLocationRequirements\": {\r\n      \"@type\": \"Country\",\r\n      \"name\": \"Japan\"\r\n    }\r\n  },\r\n  {\r\n    \"@context\": \"https://schema.org\",\r\n    \"@type\": \"FAQPage\",\r\n    \"mainEntity\": [\r\n      {\r\n        \"@type\": \"Question\",\r\n        \"name\": \"どこからエントリーできますか。\",\r\n        \"acceptedAnswer\": {\r\n          \"@type\": \"Answer\",\r\n          \"text\": \"マイナビ2027で情報を公開しています。随時そちらからご確認ください。\"\r\n        }\r\n      },\r\n      {\r\n        \"@type\": \"Question\",\r\n        \"name\": \"どのような試験を実施しますか。\",\r\n        \"acceptedAnswer\": {\r\n          \"@type\": \"Answer\",\r\n          \"text\": \"筆記試験・適正検査・面接試験・グループディスカッション等の実施実績があります。※毎年内容を変更しております。\"\r\n        }\r\n      },\r\n      {\r\n        \"@type\": \"Question\",\r\n        \"name\": \"Iターン採用はありますか。\",\r\n        \"acceptedAnswer\": {\r\n          \"@type\": \"Answer\",\r\n          \"text\": \"出身地は問うことはありません。当社への強い志望があればどなたでもご応募可能です。\"\r\n        }\r\n      },\r\n      {\r\n        \"@type\": \"Question\",\r\n        \"name\": \"入社までに何か資格等を取得する必要がありますか。\",\r\n        \"acceptedAnswer\": {\r\n          \"@type\": \"Answer\",\r\n          \"text\": \"普通自動車免許 ※自動車整備職、バス運転手養成職はAT限定不可となります。\"\r\n        }\r\n      },\r\n      {\r\n        \"@type\": \"Question\",\r\n        \"name\": \"近江鉄道グループ内の会社への出向はありますか。\",\r\n        \"acceptedAnswer\": {\r\n          \"@type\": \"Answer\",\r\n          \"text\": \"近江鉄道グループの各子会社へ出向の可能性があります。\"\r\n        }\r\n      },\r\n      {\r\n        \"@type\": \"Question\",\r\n        \"name\": \"勤務先はどこになりますか。\",\r\n        \"acceptedAnswer\": {\r\n          \"@type\": \"Answer\",\r\n          \"text\": \"各職種によって異なりますが、事業すべてが県内にあるため転勤が発生したとしても、滋賀県内での勤務となります。※総合職では、入社後6ヶ月西武鉄道へ出向いたします。\"\r\n        }\r\n      },\r\n      {\r\n        \"@type\": \"Question\",\r\n        \"name\": \"社内はどのような雰囲気ですか。\",\r\n        \"acceptedAnswer\": {\r\n          \"@type\": \"Answer\",\r\n          \"text\": \"Aさん：あたたかく、すぐに相談できる先輩社員がいます。 Bさん：オンとオフの切り替えあり、業務を終えればスムーズに退社できます。\"\r\n        }\r\n      },\r\n      {\r\n        \"@type\": \"Question\",\r\n        \"name\": \"どのような福利厚生がありますか。\",\r\n        \"acceptedAnswer\": {\r\n          \"@type\": \"Answer\",\r\n          \"text\": \"■各種手当支給（時間外勤務手当、休日勤務手当、深夜勤務手当、通勤手当 他） ■各種社会保険、制服貸与、西武グループ施設割引、財形年金、財形貯蓄、互助会 他 ■昇給年1回、賞与年2回支給（7月・12月） ※業績による ■退職金制度 ■住宅手当支給 ※入社時に滋賀県外のお住まいの方が対象\"\r\n        }\r\n      },\r\n      {\r\n        \"@type\": \"Question\",\r\n        \"name\": \"育児に関する制度はありますか。\",\r\n        \"acceptedAnswer\": {\r\n          \"@type\": \"Answer\",\r\n          \"text\": \"産前産後休暇、育児休暇、短時間勤務制度があります。\"\r\n        }\r\n      }\r\n    ]\r\n  }\r\n]\r\n</script>\r\n\r\n</head>\r\n<body id=\"pageTop\">\r\n\r\n\r\n\r\n\r\n<!-- Google Tag Manager (noscript) -->\r\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-T6TPNV5\" height=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe>\r\n</noscript>\r\n<!-- End Google Tag Manager (noscript) -->\r\n\r\n <header class=\"header\">\r\n    <div class=\"header__main js-syncpscroll-x\">\r\n  <div class=\"header__main__inner\">\r\n    <div class=\"header__main__header\">\r\n      <p class=\"header__logo\"><a href=\"/\"><img src=\"/assets/images/header/logo_ohmigroup.png\" alt=\"近江鉄道グループ\"></a></p>\r\n\r\n      <p class=\"header__menu\"><a href=\"#menu\" class=\"js-menu\"><span>メニュー</span></a></p>\r\n    </div>\r\n\r\n    <div class=\"header__main__body js-menu_menu\" id=\"menu\">\r\n      <div class=\"header__main__body__col-wrap\">\r\n        <div class=\"header__main__body__col\">\r\n          <nav class=\"header__nav-wrap\">\r\n            <div class=\"header__nav-wrap__main\">\r\n              <div class=\"header__nav\">\r\n                <ul>\r\n                  <li>\r\n                    <p class=\"header__nav__link\"><a href=\"#lower01\" class=\"js-lower\">鉄道</a></p>\r\n\r\n                    <div class=\"header__nav__lower\" id=\"lower01\">\r\n                      <div class=\"header__nav__lower__inner\">\r\n                        <p class=\"header__nav__lower__main\"><a href=\"/railway/\">鉄道トップ</a></p>\r\n\r\n                        <div class=\"header__nav__lo