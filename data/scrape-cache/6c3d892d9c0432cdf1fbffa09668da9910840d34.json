ttr('src', $this.attr('src').replace(pc, sp));\r\n\t\t\t\t\t\t}\r\n\t\t\t\t\t});\r\n\t\t\t\t}\r\n\t\t\t\timageSwitch();\r\n\t\t\t\tvar resizeTimer;\r\n\t\t\t\t$(window).on('resize', function () {\r\n\t\t\t\t\tclearTimeout(resizeTimer);\r\n\t\t\t\t\tresizeTimer = setTimeout(function () {\r\n\t\t\t\t\t\timageSwitch();\r\n\t\t\t\t\t}, 200);\r\n\t\t\t\t});\r\n\t\t\t});\r\n\t\t});\r\n\t</script>\r\n\r\n\r\n\t<!--[if lt IE 9]>\r\n<script src=\"js/html5shiv.js\"></script>\r\n<script src=\"script/respond.min.js\"></script>\r\n<![endif]-->\r\n\t<!--[if lte IE 7]><script src=\"js/lte-ie7.js\"></script><![endif]-->\r\n  <!-- Google Tag Manager -->\r\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\r\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\r\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\r\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\r\n})(window,document,'script','dataLayer','GTM-MKR3PZ');</script>\r\n<!-- End Google Tag Manager -->\r\n\r\n<!-- Google Tag Manager (noscript) -->\r\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-MKR3PZ\"\r\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\r\n<!-- End Google Tag Manager (noscript) -->\r\n\r\n</head>\r\n\r\n<body>\r\n\r\n\r\n\t<header id=\"header\">\r\n\t\t<div class=\"container\">\r\n\t\t\t<div class=\"flexbox flex-end\">\r\n\t\t\t\t<div class=\"h_logo\"><a href=\"https://www.itec.co.jp\"><img src=\"img/logo.webp\" alt=\"iTEC採用情報サイト\"></a>\r\n\t\t\t\t</div>\r\n\t\t\t\t<div class=\"h_nav\">\r\n\t\t\t\t\t<nav id=\"gNav\">\r\n\t\t\t\t\t\t<ul class=\"flexbox\">\r\n\t\t\t\t\t\t\t<li><a href=\"./new_graduates/index.html\" class=\"yellow_btn\">新卒採用</a></li>\r\n\t\t\t\t\t\t\t<li><a href=\"./mid_career/index.html\" class=\"green_btn\">キャリア採用</a></li>\r\n\t\t\t\t\t\t</ul>\r\n\t\t\t\t\t</nav>\r\n\t\t\t\t</div>\r\n\t\t\t</div>\r\n\t\t</div>\r\n\t</header>\r\n\r\n\t<main id=\"main\" role=\"main\">\r\n\r\n\t\t<div id=\"mainImage\">\r\n\t\t\t<div class=\"inviewfadeInUp animated ttl\">\r\n\t\t\t\t<h1><img src=\"img/maincopy_pc.webp\" alt=\"『IT人財の育成を通じて社会の発展に貢献する』\" class=\"responsive_img\"></h1>\r\n\t\t\t</div>\r\n\t\t\t<div class=\"mask\"></div>\r\n\t\t\t<ul class=\"slider\">\r\n\t\t\t\t<li class=\"slide01 slide\"></li>\r\n\t\t\t\t<li class=\"slide02 slide\"></li>\r\n\t\t\t\t<li class=\"slide03 slide\"></li>\r\n\t\t\t\t<li class=\"slide04 slide\"></li>\r\n\t\t\t</ul>\r\n\t\t</div>\r\n\t\t<div class=\"breadArea inner\">\r\n\t\t\t<ul>\r\n\t\t\t\t<li><a href=\"/\">アイテックTOP</a></li>\r\n\t\t\t\t<li>採用情報サイト</li>\r\n\t\t\t</ul>\r\n\t\t</div>\r\n\t\t<section id=\"sectCompany\">\r\n\t\t\t<main id=\"gMain\">\r\n\t\t\t\t<p style=\"text-align:center;\">アイテック 教育事業本部</p>\r\n\t\t\t</main>\r\n\t\t</section>\r\n\r\n\r\n\t\t<section id=\"about\" class=\"section\">\r\n\t\t\t<div class=\"container inviewfadeInUp animated\">\r\n\t\t\t\t<h2><span>ABOUT US</span></h2>\r\n\t\t\t\t<p>\r\n\t\t\t\t\t今日、社会のデジタル化が急速に進み、金融・教育・医療・環境・交通・公共サービスなど<br>様々な分野で社会的課題解決と革新をもたらす可能性を秘めています。<br>\r\n\t\t\t\t\tそうした中、日本におけるIT人材の需要は増すばかりで2030年までには約80万人が足りなくなる見通しです。<br>\r\n\t\t\t\t\t『IT人材の育成』という社会価値の高いミッションを40年にわたり掲げ続けている当社。<br>\r\n\t\t\t\t\tデジタルトランスフォーメーションが進む社会に人材教育によって貢献するために、<br>\r\n\t\t\t\t\t教育サービスを通じてデジタル・IT人材の育成を担っていきます。<br>\r\n\t\t\t\t</p>\r\n\t\t\t</div>\r\n\t\t</section>\r\n\r\n\t\t<section id=\"message\" class=\"section\">\r\n\t\t\t<div class=\"container\">\r\n\t\t\t\t<h2 class=\"inviewfadeInUp animated\"><span>MESSAGE</span></h2>\r\n\t\t\t\t<div class=\"message_inner flexbox_pc space-between flex_direction_pc no-wrap align-center\">\r\n\t\t\t\t\t<div class=\"img shadow inviewfadeInUp animated\"><img src=\"img/kt_message.webp\" alt=\"土元 克則 写真\"></div>\r\n\t\t\t\t\t<div class=\"txt shadow inviewfadeInUp animated\">\r\n\t\t\t\t\t\t<p class=\"position\"><span>代表取締役社長 教育事業本部長</span></p>\r\n\t\t\t\t\t\t<p class=\"name\">土元 克則<span class=\"en\">katsunori tsuchimoto</span></p>\r\n\t\t\t\t\t\t<p>\r\n\t\t\t\t\t\t\t1990年にイタリア外資系パソコンメーカーに入社。営業職として日本の大手企業との取引を拡大する。<br><br>\r\n\t\t\t\t\t\t\t同社退職後、インターネットプロバイダー企業などで幅広い経験を積んだ後、ECサイト・メールサーバー運用サービス業にてCOO(最高執行責任者)に就任。IT業界を幅広く経験した後、当社の取締役副社長に就任する。\r\n\t\t\t\t\t\t</p>\r\n\t\t\t\t\t</div>\r\n\t\t\t\t</div>\r\n\t\t\t</div>\r\n\t\t</section>\r\n\r\n\t\t<div class=\"contents\">\r\n\t\t\t<div class=\"sections sections01\">\r\n\t\t\t\t<section id=\"point\" class=\"section\">\r\n\t\t\t\t\t<div class=\"container\">\r\n\t\t\t\t\t\t<div class=\"point_inner shadow\">\r\n\t\t\t\t\t\t\t<article class=\"box\">\r\n\t\t\t\t\t\t\t\t<h3 class=\"inviewfadeInUp animated\"><span>教育事業本部のビジネスモデル</span></h3>\r\n\t\t\t\t\t\t\t\t<p class=\"inviewfadeInUp animated\">\r\n\t\t\t\t\t\t\t\t\tアイテックは教育事業の開始から40年、IT人材の育成に特化してきました。「新人が最初に触れる教材」と言われるほど、業界に携わる方々には馴染み深いものを扱っています。<br><br>\r\n\t\t\t\t\t\t\t\t\t当社が蓄積してきた長年のノウハウを活かして、デジタル人材不足に悩む企業の助け舟となりたい。<br>\r\n\t\t\t\t\t\t\t\t\tまた、技術だけでなくヒューマンスキルの向上にも寄与したいと考えています。<br>\r\n\t\t\t\t\t\t\t\t\tIT技術の専門知識を学んでIT業界で活躍する方はもちろん、非IT業界でITを学んだことがない方がデジタル化を推進するために、業界で成功していただける〝道筋″をつくるのが私たちのビジネスの価値。誰もが活躍できる世界を創るというゴールを目指しています。\r\n\t\t\t\t\t\t\t\t</p>\r\n\t\t\t\t\t\t\t</article>\r\n\t\t\t\t\t\t\t\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t</div>\r\n\t\t\t\t</section>\r\n\t\t\t</div>\r\n\t\t</div>\r\n\r\n\t\t<section id=\"service\" class=\"section ttl box\">\r\n\t\t\t<h2 class=\"inviewfadeInUp animated\"><span>SERVICE</span></h2>\r\n\t\t</section>\r\n\r\n\r\n\t\t<div class=\"contents\">\r\n\t\t\t<div class=\"sections sections02\">\r\n\t\t\t\t<section id=\"products\">\r\n\t\t\t\t\t<div class=\"products_inner shadow\">\r\n\t\t\t\t\t\t<div class=\"container\">\r\n\t\t\t\t\t\t\t<h3 class=\"inviewfadeInUp animated\">商品・サービス</h3>\r\n\t\t\t\t\t\t\t<div class=\"service_inner flexbox_pc\">\r\n\t\t\t\t\t\t\t\t<article class=\"flexbox_pc flex-column box inviewfadeInUp animated\">\r\n\t\t\t\t\t\t\t\t\t<div class=\"txt sbox\">\r\n\t\t\t\t\t\t\t\t\t\t<h4 class=\"green_ttl\">通信教育</h4>\r\n\t\t\t\t\t\t\t\t\t\t<p>学習場所や時間に制約のないテキスト教材と、Webでの問題講習をブレンドした学習システム。通信教育に質問・採点をプラスすることで受講者は効率的に自分のレベルを把握しセルフペースで学習を進められます。\r\n\t\t\t\t\t\t\t\t\t\t</p>\r\n\t\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t\t<div class=\"img taC\"><img src=\"img/top-icon_01.webp\" alt=\"\"></div>\r\n\t\t\t\t\t\t\t\t</article>\r\n\t\t\t\t\t\t\t\t<article\r\n\t\t\t\t\t\t\t\t\tclass=\"flexbox_pc flex_direction_column_pc flex-column box inviewfadeInUp animated\">\r\n\t\t\t\t\t\t\t\t\t<div class=\"txt sbox\">\r\n\t\t\t\t\t\t\t\t\t\t<h4 class=\"yellow_ttl\">セミナー</h4>\r\n\t\t\t\t\t\t\t\t\t\t<p>情報処理技術者試験の試験対策をはじめ、ビジネスの価値を生み出す人財(高付加価値人財)の育成をテーマに要件定義力やマネジメントスキル等、ITエンジニアのビジネススキルアップのために、知識とヒューマンの両面からアプローチしたセミナーを多数取り揃えております。\r\n\t\t\t\t\t\t\t\t\t\t</p>\r\n\t\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t\t<div class=\"img taC\"><img src=\"img/top-icon_02.webp\" alt=\"\"></div>\r\n\t\t\t\t\t\t\t\t</article>\r\n\t\t\t\t\t\t\t\t<article class=\"flexbox_pc flex-column box inviewfadeInUp animated\">\r\n\t\t\t\t\t\t\t\t\t<div class=\"txt sbox\">\r\n\t\t\t\t\t\t\t\t\t\t<h4 class=\"green_ttl\">書籍</h4>\r\n\t\t\t\t\t\t\t\t\t\t<p>国家試験の情報処理技術者試験全13種別に対応したテキストやITエンジニアを目指す方々が学習するための基礎教材を取り揃えています</p>\r\n\t\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t\t<div class=\"img taC\"><img src=\"img/top-icon_03.webp\" alt=\"\"></div>\r\n\t\t\t\t\t\t\t\t</article>\r\n\t\t\t\t\t\t\t\t<article\r\n\t\t\t\t\t\t\t\t\tclass=\"flexbox_pc flex-column flex_direction_column_pc box inviewfadeInUp animated\">\r\n\t\t\t\t\t\t\t\t\t<div class=\"txt sbox\">\r\n\t\t\t\t\t\t\t\t\t\t<h4 class=\"yellow_ttl\">模擬試験</h4>\r\n\t\t\t\t\t\t\t\t\t\t<p>35年間国家試験の分析をしてきたアイテックだからできるオリジナル予想問題を掲載した模擬試験サービス、本試験の合格を目指す受験者の実力を診断するために、毎年１万人近い方々に利用されています。\r\n\t\t\t\t\t\t\t\t\t\t</p>\r\n\t\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t\t<div class=\"img taC\"><img src=\"img/top-icon_04.webp\" alt=\"\"></div>\r\n\t\t\t\t\t\t\t\t</article>\r\n\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t</div>\r\n\t\t\t\t</section>\r\n\t\t\t</div>\r\n\t\t</div>\r\n\r\n\t\t<section id=\"company\" class=\"flexbox_pc\">\r\n\t\t\t<div class=\"span_6_full txt\">\r\n\t\t\t\t<h3 class=\"inviewfadeInUp animated\">会社概要</h3>\r\n\t\t\t\t<dl class=\"clr inviewfadeInUp animated\">\r\n\t\t\t\t\t<dt>商号</dt>\r\n\t\t\t\t\t<dd>株式会社アイテック</dd>\r\n\t\t\t\t\t<dt>事業開始</dt>\r\n\t\t\t\t\t<dd>昭和58年5月</dd>\r\n\t\t\t\t\t<dt>会社設立</dt>\r\n\t\t\t\t\t<dd>平成17年6月</dd>\r\n\t\t\t\t\t<dt>資本金</dt>\r\n\t\t\t\t\t<dd>80,000,000円</dd>\r\n\t\t\t\t\t<dt>代表者</dt>\r\n\t\t\t\t\t<dd>代表取締役社長 土元 克則</dd>\r\n\t\t\t\t\t<dt>事業概要</dt>\r\n\t\t\t\t\t<dd>\r\n\t\t\t\t\t\t通信教育事業<br>\r\n\t\t\t\t\t\t書籍の出版・販売事業<br>\r\n\t\t\t\t\t\t企業向け社員研修事業<br>\r\n\t\t\t\t\t\tITエンジニアの派遣事業<br>\r\n\t\t\t\t\t</dd>\r\n\t\t\t\t\t<dt>教育事業本部</dt>\r\n\t\t\t\t\t<dd>\r\n\t\t\t\t\t\t〒143-0006<br>\r\n\t\t\t\t\t\t東京都大田区平和島6-1-1　センタービル8階<br>\r\n\t\t\t\t\t\tTEL：03-6877-6312（代）<br>\r\n\t\t\t\t\t\tFAX：03-5753-6120\r\n\t\t\t\t\t</dd>\r\n\t\t\t\t</dl>\r\n\t\t\t</div>\r\n\t\t\t<div class=\"span_6_full img\">\r\n\t\t\t\t<img src=\"img/top-company_sp.webp\" alt=\"株式会社アイテック 会社写真\" class=\"sp\">\r\n\t\t\t</div>\r\n\t\t</section>\r\n\r\n\t\t<section id=\"talent\" class=\"section\">\r\n\t\t\t<div class=\"container\">\r\n\t\t\t\t<h2 class=\"inviewfadeInUp animated\">当社が求める人材</h2>\r\n\t\t\t\t<p class=\"inviewfadeInUp animated\">『IT人材の育成を通じて社会の発展に貢献する』というミッションに共感し、<br>\r\n\t\t\t\t\t社会的価値創出の一翼を担いたいという想いがある方は、やりがいを感じながら働くことができると思います。<br>\r\n\t\t\t\t\t多くの人に携わるため「人が好き」であることが、仕事の原動力となるはず。<br>\r\n\t\t\t\t\t人の成長に一喜一憂できる方を求めています。<br>\r\n\t\t\t\t</p>\r\n\t\t\t</div>\r\n\t\t</section>\r\n\r\n\t\t<section id=\"btn\" class=\"section\">\r\n\t\t\t<div class=\"small_container\">\r\n\t\t\t\t<ul class=\"flexbox_pc space-between align-end inviewfadeInUp animated\">\r\n\t\t\t\t\t<li class=\"span_6 sp_box\"><a href=\"./new_graduates/index.html\" class=\"yellow_btn btn\">新卒採用</a></li>\r\n\t\t\t\t\t<li class=\"span_6 taC\"><img src=\"img/to_int.webp\" alt=\"キャリア採用者インタビューページへ\" class=\"to_int\"><a\r\n\t\t\t\t\t\t\thref=\"./mid_career/index.html\" class=\"green_btn btn\">キャリア採用</a></li>\r\n\t\t\t\t</ul>\r\n\t\t\t<