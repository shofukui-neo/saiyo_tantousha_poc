type-post_type menu-item-object-page menu-item-422\"><a href=\"https://koei-e.jp/recruit/\">リクルート情報</a></li>\n<li id=\"menu-item-425\" class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-425\"><a href=\"https://koei-e.jp/company/\">会社概要</a></li>\n</ul>   </div>\n\n   <!-- submenu -->\n   <ul class=\"header__sub\">\n     <li><a href=\"https://koei-e.jp/privacy/\">個人情報保護方針</a></li>\n     <li><a href=\"https://koei-e.jp/contact/\">お問い合わせ</a></li>\n   </ul>\n\n  </div><!-- END #header -->\n </div><!-- END #header_wrap -->\n\n \n<!-- header image -->\n<section class=\"headerimg\">\n    <div class=\"fig-headerimg\"><img src=\"https://koei-e.jp/wp/wp-content/uploads/2020/04/title_contact03.png\" alt=\"お問い合わせ\" /></div>\n  <div class=\"tx-headerimg\">\n    <h2 class=\"ttl-headerimg\">お問い合わせ</h2>\n    <p class=\"catch-headerimg\">CONTACT</p>\n  </div>\n</section>\n<!-- /header image -->\n\n\n <div id=\"main_contents_wrap\">\n  <div id=\"main_contents\" class=\"clearfix\">\n    \n        \n<ul id=\"bread_crumb\" class=\"clearfix\">\n <li itemscope=\"itemscope\" itemtype=\"http://data-vocabulary.org/Breadcrumb\" class=\"home\"><a itemprop=\"url\" href=\"https://koei-e.jp/\"><span itemprop=\"title\">Home</span></a></li>\n\n\n <li class=\"last\">お問い合わせ</li>\n\n </ul>\n    \n\n<div id=\"main_col\" class=\"contact\">\n\n \n\n\n <h1 class=\"headline1\"><span>お問い合わせ</span></h1>\n\n <div class=\"post clearfix\">\n     </div><!-- END .post -->\n\n \n \n<section class=\"blc-cnts\">\n\t<h2><span></span></h2>\n\t<p>ご質問やご要望等何でもお気軽にお問い合わせ下さい。<br />\r\nご返信までにお時間がかかる場合もございますので、お急ぎの方はお電話にて直接お問い合わせ下さいませ。</p>\n\t\t<!--<p class=\"al-cnt\"><strong>お電話でのお問い合わせ</strong></p>\n\t<div class=\"box-prof\">\n\t\t\t\t<p class=\"tel-con\"><strong>TEL　<a href=\"tel:0294351163\">0294-35-1163</a></strong></p>\n\t\t<p class=\"al-cnt\">※受付時間 9：00～17：00</p>\n\t</div>-->\n</section>\n\n<section class=\"blc-cnts\">\n\t<h2><span>お問い合わせフォーム</span></h2>\n\t<p class=\"attr\">当社の個人情報保護方針に同意の上、下記フォームに必要事項をご入力いただき、確認画面へ進んで下さい。<br />\r\n（<span>＊</span>は必須項目です。）</p>\n\t<div class=\"box-form\">\n\t\t<div id=\"mw_wp_form_mw-wp-form-184\" class=\"mw_wp_form mw_wp_form_input  \">\n\t\t\t\t\t<form method=\"post\" action=\"\" enctype=\"multipart/form-data\"><dl>\n<dt>貴社名＊</dt>\n<dd>\n<input type=\"text\" name=\"貴社名\" size=\"60\" value=\"\" placeholder=\"貴社名をご入力ください。\" />\n</dd>\n<dt>お名前＊</dt>\n<dd>\n<input type=\"text\" name=\"お名前\" class=\"required\" size=\"60\" value=\"\" placeholder=\"お名前をご入力ください。\" />\n</dd>\n<dt>お名前フリガナ＊</dt>\n<dd>\n<input type=\"text\" name=\"お名前フリガナ\" class=\"required\" size=\"60\" value=\"\" placeholder=\"お名前のフリガナをご入力ください。\" />\n</dd>\n<dt>お電話番号＊</dt>\n<dd>\n<input type=\"text\" name=\"お電話番号\" class=\"email required\" size=\"60\" value=\"\" placeholder=\"お電話番号をご入力ください。\" />\n</dd>\n<dt>メールアドレス＊</dt>\n<dd>\n<input type=\"text\" name=\"メールアドレス\" class=\"email required\" size=\"60\" value=\"\" placeholder=\"メールアドレスをご入力ください。\" />\n</dd>\n<dt>件名＊</dt>\n<dd>\n<input type=\"text\" name=\"件名\" size=\"60\" value=\"\" placeholder=\"件名をご入力ください。\" />\n</dd>\n<dt>お問い合わせ内容＊</dt>\n<dd>\n<textarea name=\"お問い合わせ内容\" cols=\"50\" rows=\"5\" ></textarea>\n</dd>\n</dl>\n<p class=\"tx-pri\"><a href=\"/privacy/\" target=\"_blank\" rel=\"noopener noreferrer\">プライバシーポリシー</a>をお読みいただき同意をいただいた場合は「個人情報の取り扱いについて、同意する」にチェックの上、<br />\n下記【確認する】ボタンを押してください。</p>\n<p class=\"tx-pri\">\t<span class=\"mwform-radio-field horizontal-item\">\n\t\t<label >\n\t\t\t<input type=\"radio\" name=\"個人情報の取り扱いについて、同意する\" value=\"個人情報の取り扱いについて、同意する\" />\n\t\t\t<span class=\"mwform-radio-field-text\">個人情報の取り扱いについて、同意する</span>\n\t\t</label>\n\t</span>\n\n<input type=\"hidden\" name=\"__children[個人情報の取り扱いについて、同意する][]\" value=\"{&quot;\\u500b\\u4eba\\u60c5\\u5831\\u306e\\u53d6\\u308a\\u6271\\u3044\\u306b\\u3064\\u3044\\u3066\\u3001\\u540c\\u610f\\u3059\\u308b&quot;:&quot;\\u500b\\u4eba\\u60c5\\u5831\\u306e\\u53d6\\u308a\\u6271\\u3044\\u306b\\u3064\\u3044\\u3066\\u3001\\u540c\\u610f\\u3059\\u308b&quot;}\" />\n</p>\n<div class=\"submit\">\n<input type=\"submit\" name=\"submitConfirm\" value=\"確認する\" />\n</div>\n<input type=\"hidden\" name=\"mw-wp-form-form-id\" value=\"184\" /><input type=\"hidden\" name=\"mw_wp_form_token\" value=\"53aa55727c3dd7c778112ecb23d5c3ff0208dd15762aa72c6d9354013ac6edc0\" /></form>\n\t\t\t\t<!-- end .mw_wp_form --></div>\n\t</div>\n</section>\n\n\n\n\n\n\n\n\n\n\n</div><!-- END #main_col -->\n\n\n  </div><!-- END #main_contents -->\n </div><!-- END #main_contents_wrap -->\n\n <a id=\"return_top\" href=\"#header\">ページ上部へ戻る</a>\n\n   <div id=\"footer\">\n  <div id=\"footer_inner\" class=\"clearfix\">\n   <div id=\"footer_widget\">\n    <div class=\"footer_widget clearfix widget_text\" id=\"text-10\">\n\t\t\t<div class=\"textwidget\"><p><a href=\"http://koei-e.jp/ss/\">〔サービスステーション事業〕</a></p>\n</div>\n\t\t</div>\n<div class=\"footer_widget clearfix widget_text\" id=\"text-9\">\n\t\t\t<div class=\"textwidget\"><p><a href=\"http://koei-e.jp/carlife/\">〔カーライフ事業〕</a><br />\n千葉市車検専門店<br />\n佐倉八千代車検専門店<br />\n鈑金塗装<br />\n車買取・販売<br />\nカーコーティング<br />\nレンタカー</p>\n</div>\n\t\t</div>\n<div class=\"footer_widget clearfix widget_text\" id=\"text-4\">\n\t\t\t<div class=\"textwidget\"><p><a href=\"http://koei-e.jp/homelife/\">〔ホームライフ事業〕</a><br />\nLPガス<br />\n住宅設備機器<br />\n太陽光発電<br />\nエネファーム</p>\n</div>\n\t\t</div>\n<div class=\"footer_widget clearfix widget_text\" id=\"text-8\">\n\t\t\t<div class=\"textwidget\"><p><a href=\"http://koei-e.jp/oil/\">〔産業エネルギー事業〕</a><br />\n産業用燃料<br />\n潤滑油</p>\n</div>\n\t\t</div>\n<div class=\"footer_widget clearfix widget_text\" id=\"text-6\">\n\t\t\t<div class=\"textwidget\"><p>〔その他〕<br />\n<a href=\"http://koei-e.jp/company/\">会社概要</a><br />\n<a href=\"http://koei-e.jp/recruit/\">採用情報</a><br />\n<a href=\"http://koei-e.jp/privacy/\">個人情報保護方針</a></p>\n</div>\n\t\t</div>\n   </div>\n  </div><!-- END #footer_inner -->\n </div><!-- END #footer -->\n  \n\n <div id=\"copyright\">\n  <div id=\"copyright_inner\" class=\"cle