<li class=\"p-footer__nav__item\">\n                        <a href=\"/visit/\" class=\"list-item\">見学・入居相談</a></li>\n                </ul>\n                <ul>\n                    <li class=\"p-footer__nav__btn\">\n                        <a href=\"/recruit/\" class=\"list-item\" target=\"_blank\">採用サイト</a></li>\n                </ul>\n            </div>\n        </div>\n    </div>\n</footer>\n<ul class=\"c-float\">\n    <li class=\"c-float__nav\"><a href=\"/contact/\" class=\"ico-contact\">資料請求・お問い合わせ</a></li>\n    <li class=\"c-float__nav\"><a href=\"/visit/\" class=\"ico-visit\">見学・入居相談</a></li>\n    <li class=\"c-float__nav\"><a href=\"#site-wrapper\" class=\"c-flo_top\">ページトップ</a></li>\n</ul>\n      <!--/site-wrap-->\n    </div>\n    <!-- scripts -->\n    <script src=\"//ajax.googleapis.com/ajax/libs/jquery/1.11.2/jquery.min.js\"></script>\n    <script>\n      window.jQuery || document.write('<script src=\"../../js/jquery-1.11.2.min.js\"><\\/script>')\n\n    </script>\n    <script src=\"../../js/common.js\"></script>\n    </body>\n\n</html>\n","finalUrl":"https://www.maihamaclub.co.jp/fujimi/staff/","rendered":false,"_cachedAt":"2026-06-22T20:29:11.088Z"}