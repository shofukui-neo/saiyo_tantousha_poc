{"url":"https://www.tipton.co.jp/recruit/form/entry/","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n<head>\n    <title>新卒・中途エントリー・お問い合わせフォーム｜株式会社チップトン</title>\n    <meta charset=\"UTF-8\">\n    <meta name=\"keywords\" content=\"採用,チップトン,新卒,中途,キャリア,求人,就職,転職,開発,設計,機械,メーカー,バレル研磨,海外,愛知\"/>\n    <meta name=\"description\"\n          content=\"常に“明日”に挑戦する開発型企業「株式会社チップトン」の採用情報サイトです。チップトンはバレル業界唯一の総合メーカーです。このサイトでは新卒・中途採用情報をはじめ、社員の声や社内の雰囲気、仕事内容をお届けしています。\"/>\n    <meta name=\"viewport\"\n          content=\"width=device-width,initial-scale=1.0,minimum-scale=1.0,maximum-scale=5.0,user-scalable=yes\">\n    <!--[アイコンここから]-->\n    <meta property=\"og:image\" content=\"https://www.tipton.co.jp/recruit/form/entry/../common/image/sns-icon.jpg\"/>\n    <link rel=\"shortcut icon\" href=\"https://www.tipton.co.jp/recruit/form/entry/../common/image/favicon.ico\" type=\"image/vnd.microsoft.icon\"/>\n    <link rel=\"icon\" href=\"https://www.tipton.co.jp/recruit/form/entry/../common/image/favicon.ico\" type=\"image/vnd.microsoft.icon\"/>\n    <link rel=\"apple-touch-icon\" href=\"https://www.tipton.co.jp/recruit/form/entry/../common/image/app-icon.png\"/>\n    <!--[アイコンここまで]-->\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"https://www.tipton.co.jp/recruit/form/entry/../common/css/master.css?var=201806\" media=\"screen,all\"\n          id=\"master\"/>\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"https://www.tipton.co.jp/recruit/form/entry/../common/css/base/print.css?var=201806\"\n          media=\"print\" id=\"printcss\"/>\n    <script src=\"https://www.tipton.co.jp/recruit/form/entry/../common/js/jquery.js?var=201806\"></script>\n    <script src=\"https://www.tipton.co.jp/recruit/form/entry/../common/js/contents.js?var=201806\"></script>\n    <script src=\"https://www.tipton.co.jp/recruit/form/entry/../common/js/pluto.js?var=201806\"></script>\n    <script src=\"https://www.tipton.co.jp/recruit/form/entry/../common/js/pluto-config.js?var=201806\"></script>\n</head>\n\n<body>\n<div id=\"body-in\" class=\"form\">\n\n    <p class=\"hide\"><a href=\"#main\">本文へ</a></p>\n    <p class=\"hide\"><a href=\"#footer\">フッターへ</a></p>\n    <hr>\n\n\n    <!--**[Container Header Start]**********************************************************-->\n    <header>\n        <div class=\"container header-area clearfix\">\n            <!--==Header Start=============================-->\n            <div id=\"header\" class=\"clearfix\">\n\n                <div class=\"header-area-cover\">\n                    <div class=\"header-area-in clearfix\">\n                        <!--==Header Main Start=============================-->\n                        <div class=\"header-main\">\n                            <h1 class=\"logo\"><a href=\"https://www.tipton.co.jp/recruit/form/entry/../..\"><img\n                                            src=\"https://www.tipton.co.jp/recruit/form/entry/../common/image/t18-header-logo001.gif\"\n                                            alt=\"株式会社チップトン RECRUITING SITE\"/></a></h1>\n                        </div>\n                        <hr>\n                        <!--==//Header Main End=============================-->\n                    </div>\n                </div><!--//header-area-in-->\n                <hr>\n\n            </div><!--//header-->\n            <!--==//Header End=============================-->\n        </div><!--//header-area-->\n        <hr>\n    </header>\n    <!--**[//Container Header End]**********************************************************-->\n\n\n    <!--==Container Contents Start=====================================================================-->\n    <div class=\"container underbg clearfix\">\n        <!--==Wrapper Start=====================================================================-->\n        <div id=\"wrapper-under\" class=\"clearfix\">\n            <!--==Main Area Start=====================================================================-->\n            <div id=\"main\" class=\"clearfix\">\n\n\n                <!--==h1 Start=============================================-->\n                <div class=\"h1-area\">\n                    <div class=\"h1-area-in\">\n                        <h1>新卒・中途採用、アルムナイ採用エントリー<br>\n                            採用に関するお問い合わせフォーム\n                        </h1>\n                    </div>\n                </div>\n                <!--h1-area-->\n                <!--==//h1 End===========================================-->\n\n                <!--==Contents Contents Start=====================================================================-->\n\n                <div id=\"main-contents\">\n                    <!--=================== Error-message Start ===================-->\n                                        <!--=================== // Error-message End ===================-->\n\n                    <!--=================== Step Start ===================-->\n                    <ul class=\"step-area clearfix\">\n                        <li class=\"active\">STEP<span>1</span> 情報入力</li>\n                        <li>STEP<span>2</span> 入力内容の確認</li>\n                        <li>STEP<span>3</span> ご応募・お問い合わせ完了</li>\n                    </ul>\n                    <!--=================== // Step End ===================-->\n\n                    <!--==Outline Start================-->\n                    <div class=\"outline clearfix\">\n                        <p class=\"outline-tx\"> ホームページをご覧いただきましてありがとうございます。<br>\n                            新卒・中途採用、アルムナイ採用へのエントリー・採用に関するお問い合わせは下記のフォームよりお願いいたします。<br>\n                            また、お電話でのご応募・お問い合わせも受け付けておりますので、お気軽にご連絡ください。 </p>\n                        <hr>\n                        <div class=\"outline-tel-area\">\n                            <p class=\"title\">お電話でのご応募・お問い合わせ </p>\n                            <p class=\"tel\"><a href=\"tel:052-691-5177\"><span>052-691-5177</span></a></p>\n                        </div>\n                    </div>\n                    <!--==//Outline End================-->\n\n                    <!--=================== Form Start ===================-->\n                    <form name=\"mainform\" method=\"post\" action=\"https://www.tipton.co.jp/recruit/form/entry/index.php/form/confirm\">\n\n\n                        <!--==Group Area Start================-->\n                        <div class=\"group-area clearfix\">\n                            <div class=\"group clearfix\">\n                                <div class=\"group-box clearfix\">\n                                    <div class=\"group-box-in\">\n                                        <div class=\"sub-area required\">\n                                            <p>お問い合わせ内容</p>\n                                        </div>\n                                        <div class=\"input-area\">\n                                                                                        <ul class=\"list-type clearfix\">\n                                                <li class=\"type03\"><label><input type=\"radio\" name=\"inquiry\"\n                                                                                 value=\"新卒採用エントリー\" id=\"inquiry01\"\n                                                        >新卒採用エントリー</label>\n                                                </li>\n                                                <li class=\"type03\"><label><input type=\"radio\" name=\"inquiry\"\n                                                                                 value=\"中途採用エントリー\" id=\"inquiry02\"\n                                                        >中途採用エントリー</label>\n                                                </li>\n                                                <li class=\"type03\"><label><input type=\"radio\" name=\"inquiry\"\n                                                                                 value=\"アルムナイ採用エントリー\" id=\"inquiry04\"\n                                                        >アルムナイ採用エントリー</label>\n                                                </li>\n                                                <li class=\"type03\"><label><input type=\"radio\" name=\"inquiry\"\n                                                                                 value=\"採用に関するご質問・ご相談\" id=\"inquiry03\"\n                                                        >採用に関するご質問・ご相談</label>\n                                                </li>\n                                            </ul>\n                                        </div>\n                                    </div><!--//group-box-in-->\n                                </div><!--//group-box-->\n                                <div class=\"group-box clearfix\">\n                                    <div class=\"group-box-in\">\n                                        <div class=\"sub-area required\">\n                                            <p>お名前</p>\n                                        </div>\n                                        <div class=\"input-area\">\n                                                                                        <input name=\"name\" type=\"text\" class=\"w40\" id=\"name\" value=\"\">\n                                            <span class=\"ex001\">（例：鈴木 太郎）</span>\n                                        </div>\n                                    </div><!--//group-box-in-->\n                                </div><!--//group-box-->\n                                <div class=\"group-box clearfix\">\n                                    <div class=\"group-box-in\">\n                                        <div class=\"sub-area required\">\n                                            <p>ふりがな</p>\n                                        </div>\n                                        <div class=\"input-area\">\n                                                                                        <input name=\"kana\" type=\"text\" class=\"w40\" id=\"kana\" value=\"\">\n                                            <span class=\"ex001\">（例：すずき たろう）</span>\n                                        </div>\n                                    </div><!--//group-box-in-->\n                                </div><!--//group-box-->\n\n                                <div class=\"group-box clearfix\">\n                                    <div class=\"group-box-in\">\n                                        <div class=\"sub-area required\">\n                                            <p>性別</p>\n                                        </div>\n                                        <div class=\"input-area\">\n                                                                                        <ul class=\"list-type clearfix\">\n                                                <li class=\"type05\"><label><input type=\"radio\" name=\"gender\" value=\"男性\" id=\"gender01\"\n                                                        >男性</label></li>\n                                                <li class=\"type05\"><label><input type=\"radio\" name=\"gender\" value=\"女性\" id=\"gender02\"\n                                                        >女性</label></li>\n                                            </ul>\n                                        </div>\n                                    </div><!--//group-box-in-->\n                                </div><!--//group-box-->\n\n                                <div class=\"group-box clearfix\">\n                                    <div class=\"group-box-in\">\n                                        <div class=\"sub-area required\">\n                                            <p>年齢</p>\n                                        </div>\n                                        <div class=\"input-area\">\n                                                                                        <input name=\"age\" type=\"text\" class=\"w20-add\" id=\"age\" value=\"\">&nbsp;&nbsp;才\n                                            <span class=\"ex001\">（例：30）</span>\n                                        </div>\n                                    </div><!--//group-box-in-->\n                                </div><!--//group-box-->\n\n                                <div class=\"group-box clearfix\">\n                                    <div class=\"group-box-in\">\n                                        <div class=\"sub-area required\">\n                                            <p>ご住所</p>\n                                        </div>\n                                        <div class=\"input-area\">\n                                                                                        <ul class=\"list-type clearfix\">\n                                                <li class=\"type01\">〒<input name=\"zipcode\" type=\"text\" class=\"w20-add\"\n                                                                           id=\"zipcode\" value=\"\">\n                                                    <a href=\"javascript:void(0);\"\n                                                            class=\"search-btn ajaxzip-trigger\">住所検索</a>\n                                                    <span class=\"alphanumeric\">半角</span><span\n                                                            class=\"ex002\">（例：4578566）</span></li>\n                                                <li class=\"type01 pad-left\">\n                                                    <select name=\"address01\" id=\"address01\" class=\"select-input\">\n                                                        <option value=\"\">都道府県を選択してください</option>\n                                                        <optgroup label=\"北海道・東北\">\n                                                            <option value=\"北海道\" >北海道</option>\n                                                            <option value=\"青森県\" >青森県</option>\n                                                            <option value=\"岩手県\" >岩手県</option>\n                                                            <option value=\"宮城県\" >宮城県</option>\n                                                            <option value=\"秋田県\" >秋田県</option>\n                                                            <option value=\"山形県\" >山形県</option>\n                                                            <option value=\"福島県\" >福島県</option>\n                                                        </optgroup>\n                                                        <optgroup label=\"関東\">\n                                                            <option value=\"茨城県\" >茨城県</option>\n                                                            <option value=\"栃木県\" >栃木県</option>\n                                                            <option value=\"群馬県\" >群馬県</option>\n                                                            <option value=\"埼玉県\" >埼玉県</option>\n                                                            <option value=\"千葉県\" >千葉県</option>\n                                                            <option value=\"東京都\" >東京都</option>\n                                                            <option value=\"神奈川県\" >神奈川県</option>\n                                                        </optgroup>\n                                                        <optgroup label=\"甲信越・北陸\">\n                                                            <option value=\"新潟県\" >新潟県</option>\n                                                            <option value=\"富山県\" >富山県</option>\n                                                            <option value=\"石川県\" >石川県</option>\n                                                            <option value=\"福井県\" >福井県</option>\n                                                            <option value=\"山梨県\" >山梨県</option>\n                                                            <option value=\"長野県\" >長野県</option>\n                                                        </optgroup>\n                                                        <optgroup label=\"東海\">\n                                                            <option value=\"岐阜県\" >岐阜県</option>\n                                                            <option value=\"静岡県\" >静岡県</option>\n                                                            <option value=\"愛知県\" >愛知県</option>\n                                                            <option value=\"三重県\" >三重県</option>\n                                                        </optgroup>\n                                                        <optgroup label=\"関西\">\n                                                            <option value=\"滋賀県\" >滋賀県</option>\n                                                            <option value=\"京都府\" >京都府</option>\n                                                            <option value=\"大阪府\" >大阪府</option>\n                                                            <option value=\"兵庫県\" >兵庫県</option>\n                                                            <option value=\"奈良県\" >奈良県</option>\n                                                            <option value=\"和歌山県\" >和歌山県</option>\n                                                        </optgroup>\n                                                        <optgroup label=\"中国\">\n                                                            <option value=\"鳥取県\" >鳥取県</option>\n                                                            <option value=\"島根県\" >島根県</option>\n                                                            <option value=\"岡山県\" >岡山県</option>\n                                                            <option value=\"広島県\" >広島県</option>\n                                                            <option value=\"山口県\" >山口県</option>\n                                                        </optgroup>\n                                                        <optgroup label=\"四国\">\n                                                            <option value=\"徳島県\" >徳島県</option>\n                                                            <option value=\"香川県\" >香川県</option>\n                                                            <option value=\"愛媛県\" >愛媛県</option>\n                                                            <option value=\"高知県\" >高知県</option>\n                                                        </optgroup>\n                                                        <optgroup label=\"九州・沖縄\">\n                                                            <option value=\"福岡県\" >福岡県</option>\n                                                            <option value=\"佐賀県\" >佐賀県</option>\n                                                            <option value=\"長崎県\" >長崎県</option>\n                                                            <option value=\"熊本県\" >熊本県</option>\n                                                            <option value=\"大分県\" >大分県</option>\n                                                            <option value=\"宮崎県\" >宮崎県</option>\n                                                            <option value=\"鹿児島県\" >鹿児島県</option>\n                                                            <option value=\"沖縄県\" >沖縄県</option>\n                                                        </optgroup>\n                                                    </select>\n                                                </li>\n                                                <li class=\"type01 pad-left\"><input name=\"address02\" type=\"text\"\n                                                                                   class=\"w80\" id=\"address02\" value=\"\">\n                                                </li>\n                                            </ul>\n                                            <span class=\"ex001\">（例：愛知県名古屋市南区豊田3-19-21）</span>\n                                        </div>\n                                    </div><!--//group-box-in-->\n                                </div><!--//group-box-->\n\n                                <div class=\"group-box clearfix\">\n                                    <div class=\"group-box-in\">\n                                        <div class=\"sub-area required\">\n                                            <p>電話番号</p>\n                                        </div>\n                                        <div class=\"input-area\">\n                                                                                        <input name=\"tel\" type=\"text\" class=\"w40\" id=\"tel\" value=\"\">\n                                            <span class=\"ex001\" x-ms-format-detection=\"none\">（例：090-1234-5678）</span>\n                                        </div>\n                                    </div><!--//group-box-in-->\n                                </div><!--//group-box-->\n\n                                <div class=\"group-box clearfix\">\n                                    <div class=\"group-box-in\">\n                                        <div class=\"sub-area required\">\n                                            <p>メールアドレス</p>\n                                        </div>\n                                        <div class=\"input-area\">\n                                                                                        <input name=\"mail\" type=\"text\" class=\"w60\" id=\"mail\" value=\"\">\n                                            <span class=\"half-width\">半角英数</span><span\n                                                    class=\"ex002\">（例：***＠tipton.co.jp）</span>\n                                            <span class=\"com001\">※返信を受け取りたいメールアドレスを正確にご記入ください。</span>\n                                        </div>\n                                    </div><!--//group-box-in-->\n                                </div><!--//group-box-->\n\n                                <div class=\"group-box clearfix\">\n                                    <div class=\"group-box-in\">\n                                        <div class=\"sub-area any\">\n                                            <p>その他</p>\n                                        </div>\n                                        <div class=\"input-area\">\n                                            <textarea name=\"other\" id=\"other\" cols=\"80\" rows=\"8\"\n                                                      placeholder=\"ご質問などございましたら、こちらにご記入ください。\"></textarea>\n                                        </div>\n                                    </div><!--//group-box-in-->\n                                </div><!--//group-box-->\n\n                            </div><!--//group-->\n                        </div>\n                        <hr>\n                        <!--==//Group Area End================-->\n\n                        <!--==Outline Start================-->\n                        <div class=\"outline-st clearfix\">\n                            <p> 新卒・中途採用、アルムナイ採用へのエントリーを希望される方は、こちらもご記入ください。\n                            </p>\n                            <hr>\n                        </div>\n                        <!--==//Outline End================-->\n\n                        <!--==Group Area Start================-->\n                        <div class=\"group-area clearfix\">\n                            <div class=\"group clearfix\">\n\n                                <div class=\"group-box clearfix\">\n                                    <div class=\"group-box-in\">\n                                        <div class=\"sub-area any\">\n                                            <p>希望職種</p>\n                                        </div>\n                                        <div class=\"input-area\">\n                                            <input name=\"job\" type=\"text\" class=\"w40\" id=\"job\" value=\"\">\n                                        </div>\n                                    </div><!--//group-box-in-->\n                                </div><!--//group-box-->\n                                <div class=\"group-box clearfix\">\n                                    <div class=\"group-box-in\">\n                                        <div class=\"sub-area any\">\n                                            <p>最終学歴 (卒業見込)</p>\n                                        </div>\n                                        <div class=\"input-area\">\n                                            <input name=\"education\" type=\"text\" class=\"w40\" id=\"education\" value=\"\">\n                                            <span class=\"ex001\">（例：○×大学 ○×学部　△□学科）</span>\n                                        </div>\n                                    </div><!--//group-box-in-->\n                                </div><!--//group-box-->\n                                <div class=\"group-box clearfix\">\n                                    <div class=\"group-box-in\">\n                                        <div class=\"sub-area any\">\n                                            <p>応募の動機<br>\n                                                最近の職務内容など</p>\n                                        </div>\n                                        <div class=\"input-area\">\n                                            <textarea name=\"content\" id=\"content\" cols=\"80\" rows=\"8\"\n                                                      placeholder=\"ご質問などございましたら、こちらにご記入ください。\"></textarea>\n                                        </div>\n                                    </div><!--//group-box-in-->\n                                </div><!--//group-box-->\n\n                            </div><!--//group-->\n                        </div>\n                        <hr>\n                        <!--==//Group Area End================-->\n\n                        <!--=================== Button Start ===================-->\n                        <div class=\"button-area clear\">\n                            <p> ご記入、誠にありがとうございました。 </p>\n                            <button type=\"submit\">確認画面へ進む</button>\n                        </div>\n                        <!--=================== // Button End ===================-->\n                        \n<input type=\"hidden\" name=\"error_name\" value=\"\" />\n                        \n<input type=\"hidden\" name=\"ticket\" value=\"0c5aa0913a7d22bb4da369dc4bbda689\" />\n                    </form>\n                    <!--=================== // Form End ===================-->\n                    <!--=================== Privacy Area Start ===================-->\n                    <div class=\"privacy-area clear\">\n                        <form action=\"https://www.login.secomtrust.net/customer/customer/pfw/CertificationPage.do\"\n                              name=\"CertificationPageForm\" method=\"post\" target=\"_blank\" style=\"margin:0;\">\n                            <input type=\"image\" src=\"https://www.tipton.co.jp/recruit/form/entry/../common/image/sticker_m.gif\" name=\"Sticker\"\n                                   alt=\"クリックして証明書の内容をご確認ください\" oncontextmenu=\"return false;\"/>\n                            <input type=\"hidden\" name=\"Req_ID\" value=\"2228497809\"/>\n                        </form>\n                        <div class=\"privacy-area-in\">\n                            <p class=\"privacy-title\">個人情報の取り扱いについてご確認ください。</p>\n                            <p class=\"privacy-txt\"> チップトンでは、お客様情報の適正な収集・利用、およびその保護に努めています。<br>\n                                お客様がご記入いただきました情報の取り扱いにつきましては「個人情報保護方針」をご参照ください。\n                            </p>\n                        </div>\n                    </div>\n                    <!--=================== // Privacy Area End ===================-->\n                </div>\n                <!--//maincontents-->\n                <!--==//Main Contents End=====================================================================-->\n\n            </div><!--//main-->\n            <!--**[//Main Area End]**********************************************************-->\n        </div><!--//wrapper-->\n        <!--==//Wrapper End=====================================================================-->\n    </div>\n    <!--==//Container Contents End=====================================================================-->\n\n    <!--**[Container Footer Start]**********************************************************-->\n    <footer>\n        <div class=\"container footer-area clear clearfix\">\n            <div id=\"footer\">\n                <div class=\"sig-area clearfix\">\n                    <div class=\"sig-area-in clearfix\">\n                        <p>株式会社チップトン</p>\n                        <address>〒457-8566 名古屋市南区豊田三丁目19番21号<br>電話：052-691-5177（本社 総務・人事課 ）<br>メール：&#115;&#111;&#117;&#109;&#117;&#64;&#116;&#105;&#112;&#116;&#111;&#110;&#46;&#99;&#111;&#46;&#106;&#112;\n                        </address>\n                    </div>\n                </div><!--//sig-area-->\n                <p class=\"copy\">Copyright © Tipton Corp. All rights reserved.</p>\n            </div><!--//footer-->\n        </div>\n    </footer>\n    <!--**[//Container Footer End]**********************************************************-->\n\n\n    <script src=\"https://www.tipton.co.jp/recruit/form/entry/../common/js/jquery-ajaxzip3-loader.js\"></script>\n    <script>\n        $(function () {\n            $('input[name=\"postal-code\"]').ajaxzipLoader({\n                zip1: 'zipcode',\n                zip2: '',\n                pref: 'address01',\n                address: 'address02'\n            });\n        });\n    </script>\n</div><!--//body-in-->\n\n<script type=\"text/javascript\">\n    var gaJsHost = ((\"https:\" == document.location.protocol) ? \"https://ssl.\" : \"http://www.\");\n    document.write(unescape(\"%3Cscript src='\" + gaJsHost + \"google-analytics.com/ga.js' type='text/javascript'%3E%3C/script%3E\"));\n</script>\n<script type=\"text/javascript\">\n    try {\n        var pageTracker = _gat._getTracker(\"UA-3069441-1\");\n        pageTracker._trackPageview();\n    } catch (err) {\n    }</script>\n\n</body>\n</html>\n","finalUrl":"https://www.tipton.co.jp/recruit/form/entry/","rendered":false,"_cachedAt":"2026-06-22T15:49:44.312Z"}