class=\"Grid4\">\n\n            <div class=\"contents-width\">\n\n                <div class=\"section-recruit sub-page-layout\" id=\"section-interview-top\">\n\n                    <div class=\"recruit-title-en is-vertical disability-vertical\">OFFICE</div>\n\n                    <div class=\"message-title\">\n                        <h1>OFFICE<br>INTRODUCTION<span>事業所紹介</span></h1>\n                    </div><!-- /title-message -->\n\n                </div><!-- /#section-interview-top -->\n\n\t\t\t</div><!-- /.contents-width -->\n\n\n<div class=\"contents-width\">\n<div class=\"message-section\">\n<h2 id=\"anc01\" class=\"title-second\">本社　Head Office</h2>\n<div class=\"ThumbW180SetStyle ClearFix\">\n<p class=\"Img CenterAdjust\"><img src=\"/recruit/image/office_01.jpg\" alt=\"\"></p>\n<div class=\"ImgSet\">\n<h3 class=\"title-second03\">主な部門</h3>\n<p class=\"TextStyle1\">営業統括本部、経営統括本部</p>\n<h3 class=\"title-second03\">事業内容</h3>\n<p class=\"TextStyle1\">全国営業部門の統括と、コーポレート部門による経営に必要な業務を行っています。</p>\n</div>\n</div>\n</div><!-- /.message-section -->\n\n<div class=\"message-section\">\n<h2 id=\"anc02\" class=\"title-second\">佐野工場　Sano Works</h2>\n<div class=\"ThumbW180SetStyle ClearFix\">\n<p class=\"Img CenterAdjust\"><img src=\"/recruit/image/office_02.gif\" alt=\"\"></p>\n<div class=\"ImgSet\">\n<h3 class=\"title-second03\">主な部門</h3>\n<p class=\"TextStyle1\">品質保証部、eCrane本部、クレーンシステム本部</p>\n<h3 class=\"title-second03\">事業内容</h3>\n<p class=\"TextStyle1\">産業用クレーンの開発、設計、製造、据付及び品質保証を行っています。</p>\n</div>\n</div>\n</div><!-- /.message-section -->\n\n<div class=\"message-section\">\n<h2 id=\"anc03\" class=\"title-second\">松戸事業所　Matsudo Works</h2>\n<div class=\"ThumbW180SetStyle ClearFix\">\n<p class=\"Img CenterAdjust\"><img src=\"/recruit/image/office_03.gif\" alt=\"\"></p>\n<div class=\"ImgSet\">\n<h3 class=\"title-second03\">主な部門</h3>\n<p class=\"TextStyle1\">クレーンサービス本部（東日本地区）</p>\n<h3 class=\"title-second03\">事業内容</h3>\n<p class=\"TextStyle1\">東日本エリアの産業用クレーンや全国に納入した輸送装置のサービス設計（機械、電気）及びアフターサービスを行っています。</p>\n</div>\n</div>\n</div><!-- /.message-section -->\n\n<div class=\"message-section\">\n<h2 id=\"anc04\" class=\"title-second\">尼崎事業所　Amagasaki Works</h2>\n<div class=\"ThumbW180SetStyle ClearFix\">\n<p class=\"Img CenterAdjust\"><img src=\"/recruit/image/office_04.jpg\" alt=\"\"></p>\n<div class=\"ImgSet\">\n<h3 class=\"title-second03\">主な部門</h3>\n<p class=\"TextStyle1\">クレーンサービス本部（西日本地区）、技術管理センタ</p>\n<h3 class=\"title-second03\">事業内容</h3>\n<p class=\"TextStyle1\">西日本エリアの産業用クレーンのサービス設計（機械、電気）及びアフターサービスと、製品及びサービスの知財管理を行っています。</p>\n</div>\n</div>\n</div><!-- /.message-section -->\n\n<div class=\"message-section\">\n<h2 id=\"anc05\" class=\"title-second\">徳山事務所　Tokuyama Office</h2>\n<div class=\"ThumbW180SetStyle ClearFix\">\n<p class=\"Img CenterAdjust\"><img src=\"/recruit/image/office_05.jpg\" alt=\"\"></p>\n<div class=\"ImgSet\">\n<h3 class=\"title-second03\">主な部門</h3>\n<p class=\"TextStyle1\">eCrane本部（ロジスティクス関連）、クレーンサービス本部（大型クレーン）</p>\n<h3 class=\"title-second03\">事業内容</h3>\n<p class=\"TextStyle1\">ロジスティクス分野のシステム設計と、全国に納入した大型クレーンのサービス設計（機械、電気）及びアフターサービスを行っています。</p>\n</div>\n</div>\n</div><!-- /.message-section -->\n</div><!-- /.contents-width -->\n\n\n\t\t</div><!--/Grid4-->\n\t</div><!--/GridSet-->\n</div><!--/Contents-->\n\n\n<div class=\"FatMenuWide\"></div><!-- /_include/fat_menu_wide.html -->\n\n\n<div id=\"FooterArea\">\n    <div class=\"Container Wide\">\n\n        <a href=\"#top\" id=\"FooterPageTop\" aria-label=\"ページの先頭へ\"></a>\n\n        <div id=\"Footer2\">\n\n            <div id=\"Footer2Menu\">\n                <a href=\"/sitemap.html\">サイトマップ</a>\n                <a href=\"https://www8.hitachi.co.jp/inquiry/hitachi-hpm/general/form.jsp\" target=\"_blank\">お問い合わせ</a>\n            </div>\n\n        </div><!--/#Footer2-->\n\n        <div id=\"Footer1\">\n\n            <div id=\"HitachiTop\">\n                <a href=\"https://www.hitachi.co.jp/\">日立グループTOP</a>\n            </div>\n\n            <div id=\"Footer1Menu\">\n                <a href=\"/utility/termofuse/index.html\">サイトの利用条件</a>\n                <a href=\"/utility/privacy/index.html\">個人情報保護に関して</a>\n                <a href=\"/history.html\">更新情報</a>\n            </div>\n\n            <div id=\"Copyright\">&copy; Hitachi Plant Mechanics Co., Ltd. <span>2007</span>. All rights reserved.</div>\n\n        </div><!--/#Footer1-->\n\n    </div><!--/.Container-->\n</div><!--/#FooterArea-->\n\n<script>\n(function (i, s, o, g, r, a, m) {(i[r] = i[r] || function () { (i[r].q = i[r].q || []).push(arguments) }),(a = s.createElement(o)), (m = s.getElementsByTagName(o)[0]);a.async = 1;a.src = g;m.parentNode.insertBefore(a, m);})(window, document, \"script\", \"//ar.mrc-s.com/web/ar.js\", \"mrc\");\nmrc(\"id\", \"mgr8af\");\nmrc(\"autolink\", [\"*.hitachi-hpm.co.jp\", \"hitachi-hpm.mrc-lp.com\"]);\nmrc(\"send\");\n</script>\n\n</body>\n</html>","finalUrl":"https://www.hitachi-hpm.co.jp/recruit/office.html","rendered":false,"_cachedAt":"2026-06-23T20:40:13.895Z"}