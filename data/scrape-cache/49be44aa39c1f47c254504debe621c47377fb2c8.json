on('inview', function(event, isInView, visiblePartX, visiblePartY) {\n            if(isInView){\n                $(this).stop().addClass('fade_set');\n            } else {\n                $(this).stop().removeClass('fade_set');\n            }\n        });\n    };\n});\n    \n$(function(){\n\n\tvar mw = '(min-width:500px)';\n\n\tfunction viewSwitch() {\n\t\t// 非対応ブラウザの場合は何もしない\n\t\tif( !window.matchMedia ){\n\t\t\treturn;\n\t\t}\n\t\tif(window.matchMedia(mw).matches ){\n\t\t\t// PCの場合\n\t\t\t$('.inline01').on('click', function(){\n                $(\".inline01\").colorbox({\n                    maxWidth:\"60%\",\n                    maxHeight:\"100%\",\n                    inline: true,\n                    rel:'group',\n                    closeButton:'true',\n                    onComplete: function(){\n                        var video = $(\"#video01\").get(0).play();\n                    },\n                    onClosed: function(){\n                        $(\"#video01\").get(0).pause();\n                    }\n                }); \n            });\n\t\t} else {\n\t\t\t// スマートフォンの場合\n\t\t\t$('.inline01').on('click', function(){\n                $(\".inline01\").colorbox({\n                    maxWidth:\"90%\",\n                    maxHeight:\"100%\",\n                    inline: true,\n                    rel:'group',\n                    closeButton:'true',\n                    onComplete: function(){\n                        var video = $(\"#video01\").get(0).play();\n                    },\n                    onClosed: function(){\n                        $(\"#video01\").get(0).pause();\n                    }\n                }); \n            });\n\t\t}\n\t}\n\n\tviewSwitch();\n\n\tvar resizeTimer;\n\t$(window).on('resize', function() {\n\t\tclearTimeout(resizeTimer);\n\t\tresizeTimer = setTimeout(function() {\n\t\t\tviewSwitch();\n\t\t}, 200);\n\t});\n\n});\n\t\n$(function() {\n\t$('.js_modal_btn').colorbox({\n\t\tinline: true,\n\t\tmaxWidth: '90%',\n\t\tmaxheight: '90%',\n\t});\t\n});\n\t\n$(function() {\n\tvar $gnavs = $('#gnav li a');\n\t$gnavs.each(function() {\n\t\t$(this).attr('href', '#' + $(this).attr('href').split('#')[1]);\n\t});\n});\n\n$(function() {\n\tvar\n\t\t$movie = $('#movie'),\n\t\twinwWidth = window.innerWidth;\n\t\n\tif($movie.width() / winwWidth >= 3.5) {\n\t\t$movie.height('80%');\n\t}\n});\n\t\n$(function() {\n\tvar v = document.getElementById('movie');\n\t\n\t//再生位置の取得\n\tv.addEventListener('timeupdate', function() {\t\t\n\t\tif (v.currentTime > 3.2){\n\t\t\t$('.bnr_sdgs').addClass('show');\n\t\t\t$('.bnr_news').addClass('show');\n\t\t}\n\t})\n});\n</script>\n</html>\n","finalUrl":"https://www.fsp.co.jp/","rendered":false,"_cachedAt":"2026-06-14T16:11:25.548Z"}