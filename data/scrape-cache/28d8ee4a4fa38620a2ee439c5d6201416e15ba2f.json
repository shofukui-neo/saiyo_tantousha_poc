{"url":"https://www.nippon-soda.co.jp/recruitment/saiyo/familiar/","html":"\n<!DOCTYPE html>\n<html xml:lang=\"ja\" lang=\"ja\">\n    <head>\n        <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n        <meta charset=\"utf-8\">\n        <meta name=\"description\" content=\"日本曹達株式会社　新卒採用情報\">\n        <meta name=\"keywords\" content=\"日本曹達,NISSO,新卒\">\n        <meta name='viewport' content='width=device-width,user-scalable=no'>\n        <meta name=\"format-detection\" content=\"telephone=no\">\n\n        <title>身近なNISSO｜日本曹達　新卒採用情報</title>\n\n        <!--<link rel=\"stylesheet\" href=\"../assets/css/vendor/remodal-default-theme.css\" media=\"all\">-->\n        <!--<link rel=\"stylesheet\" href=\"../assets/css/vendor/remodal.css\" media=\"all\">-->\n        <link rel=\"stylesheet\" href=\"../assets/font/font.css\" media=\"all\">\n        <link rel=\"stylesheet\" href=\"../assets/css/style.css\" media=\"all\">\n        \n        <link rel=\"stylesheet\" href=\"\" media=\"all\">\n\n        <script src=\"../assets/js/vendor/jquery.js\"></script>\n        <script src=\"../assets/js/vendor/jquery-css-transform.js\"></script>\n        <script src=\"../assets/js/vendor/jquery-animate-css-rotate-scale.js\"></script>\n        <script src=\"../assets/js/vendor/flexibility.js\"></script>\n        <script src=\"../assets/js/plugins.js\"></script>\n        <!--<script src=\"../assets/js/vendor/remodal.min.js\"></script>-->\n        <script src=\"../assets/js/script.js\"></script>\n        \n\n        <!--[if lt IE 9]><script src=\"../assets/js/vendor/html5shiv3_7_3.js\"></script><![endif]-->\n    </head>\n    <body>\n        <div id=\"wrapper\" class=\"child familiar category-top\">\n            <header class=\"sidepadding\">\n                <div class=\"insidebox\">\n                    <div class=\"float\">\n                        <div id=\"logo\" class=\"left\">\n                            <a href=\"../index.html\"><img src=\"../assets/img/common/header_logo_pc.png\" alt=\"\"></a>\n                        </div>\n                        <div id=\"pcmenu\" class=\"right pcshow\">\n                            <ul class=\"flexbox between\">\n                                <li><a id=\"pcmenu01\" class=\"\" href=\"../sixmerit/\" data-nav=\"00\">NISSOの特長6選</a></li>\n                                <li><a id=\"pcmenu01\" class=\"\" href=\"../business/\" data-nav=\"01\">事業紹介</a></li>\n                                <li><a id=\"pcmenu02\" class=\"\" href=\"../familiar/\" data-nav=\"02\">身近なNISSO</a></li>\n                                <li><a id=\"pcmenu03\" class=\"pcmenu\" href=\"javascript:void(0);\" data-nav=\"03\">仕事と社員</a></li>\n                                <li><a id=\"pcmenu04\" class=\"pcmenu\" href=\"javascript:void(0);\" data-nav=\"04\">キャリアサポート</a></li>\n                                <li><a id=\"pcmenu05\" class=\"pcmenu\" href=\"javascript:void(0);\" data-nav=\"05\">採用情報</a></li>\n                                <li><a id=\"pcmenu06\" class=\"\" href=\"https://nippon-soda.snar.jp/jobboard/detail.aspx?id=O1aKrvYGg_A\" target=\"_blank\">エントリー<span>ENTRY</span></a></li>\n                            </ul>\n                        </div>\n                        <div class=\"right spshow\">\n                            <div id=\"spmenu-btn\">\n                                <a href=\"javascript:void(0);\"><img src=\"../assets/img/common/spmenu_open.png\" alt=\"MENU\"></a>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </header>\n\n\n\n            <nav id=\"submenu\" class=\"pcshow\">\n                <div id=\"submenu03\" class=\"sidepadding submenu col3\" data-nav=\"03\">\n                    <div class=\"insidebox\">\n                        <div class=\"area\">\n                            <ul class=\"flexbox\">\n                                <li><a href=\"../works/jobcategory.html\">専攻と職種</a></li>\n                                <li><a href=\"../works/workflow.html\">仕事の流れ</a></li>\n                                <li><a href=\"../works/person.html\">社員紹介</a></li>\n                            </ul>\n                        </div>\n                    </div>\n                </div>\n                <div id=\"submenu04\" class=\"sidepadding submenu col2\" data-nav=\"04\">\n                    <div class=\"insidebox\">\n                        <div class=\"area\">\n                            <ul class=\"flexbox\">\n                                <li><a href=\"../career/career.html\">キャリアとNISSO</a></li>\n                                <li><a href=\"../career/talk.html\">ライフイベントとキャリア</a></li>\n                            </ul>\n                        </div>\n                    </div>\n                </div>\n                <div id=\"submenu05\" class=\"sidepadding submenu col2\" data-nav=\"05\">\n                    <div class=\"insidebox\">\n                        <div class=\"area\">\n                            <ul class=\"flexbox\">\n                                <li><a href=\"../recruit/bosyu.html\">募集要項</a></li>\n                                <li><a href=\"../recruit/qa.html\">採用Q&A</a></li>\n                            </ul>\n                        </div>\n                    </div>\n                </div>\n            </nav>\n\n\n\n            <nav id=\"spnav\" class=\"spshow\">\n                <div class=\"in\">\n                    <ul class=\"flexbox col1\">\n                        <li><a href=\"../sixmerit/\">NISSOの特長6選</a></li>\n                        <li><a href=\"../business/\">事業紹介</a></li>\n                        <li><a href=\"../familiar/\">身近なNISSO</a></li>\n                    </ul>\n\n                    <p class=\"ttl\">仕事と社員</p>\n                    <ul class=\"flexbox col3\">\n                        <li><a href=\"../works/jobcategory.html\">専攻と職種</a></li>\n                        <li><a href=\"../works/workflow.html\">仕事の流れ</a></li>\n                        <li><a href=\"../works/person.html\">社員紹介</a></li>\n                    </ul>\n\n                    <p class=\"ttl\">キャリアサポート</p>\n                    <ul class=\"flexbox col2\">\n                        <li><a href=\"../career/career.html\">キャリアとNISSO</a></li>\n                        <li><a class=\"multi-line\" href=\"../career/talk.html\">ライフイベントと<br class=\"spshow\">キャリア</a></li>\n                    </ul>\n\n                    <p class=\"ttl\">採用情報</p>\n                    <ul class=\"flexbox col2\">\n                        <li><a href=\"../recruit/bosyu.html\">募集要項</a></li>\n                        <li><a href=\"../recruit/qa.html\">採用Q&A</a></li>\n                    </ul>\n\n                    <ul class=\"flexbox col1\">\n                        <li><a href=\"https://nippon-soda.snar.jp/jobboard/detail.aspx?id=O1aKrvYGg_A\" target=\"_blank\">エントリー<span>ENTRY</span></a></li>\n                    </ul>\n                </div>\n            </nav>\n\n            <div id=\"mainbody\" class=\"sidepadding\">\n                <div class=\"insidebox\">\n                    <div id=\"h1\">\n                        <h1><img class=\"js-switchimg sp100\" src=\"../assets/img/familiar/top_h1_pc.png\" alt=\"身近なNISSO 日本曹達\"></h1>\n                    </div>\n\n\n                    <div id=\"sections\">\n                        <div class=\"inner1040\">\n                            <div id=\"section01\">\n                                <div class=\"accordionbtns\">\n                                    <a href=\"javascript:void(0);\" data-accordion-btn=\"abody0101\"><img class=\"js-switchimg\" src=\"../assets/img/familiar/top_btn01_pc.png\" alt=\"01 店舗\"></a>\n                                    <a href=\"javascript:void(0);\" data-accordion-btn=\"abody0102\"><img class=\"js-switchimg\" src=\"../assets/img/familiar/top_btn02_pc.png\" alt=\"02 病院\"></a>\n                                </div>\n                                <div class=\"accordionbody\">\n                                    <div id=\"abody0101\" class=\"abody\">\n                                        <div class=\"ttl\"><img class=\"js-switchimg\" src=\"../assets/img/familiar//accordion_ttl01_pc.png\" alt=\"01 店舗\"></div>\n\n\n                                        <div class=\"abody010101\">\n                                            <p class=\"ttl\">独自の技術で、商品梱包用段ボールにくっきり印刷</p>\n                                            <div class=\"box\">\n                                                <p>\n                                                    素材が柔らかく、印刷が難しい段ボール箱表面の文字がくっきり読めるのは、フレキソ印刷という技術のおかげ。ここで使われる印刷版の原料はゴム・樹脂が主ですが、印刷をシャープにするために版の固さを調節する「NISSO-PB」が使われています。なお同製品は、その優れた物質特性から他の様々な工業分野でも使われています。\n                                                </p>\n                                                <a href=\"http://www.nippon-soda.co.jp/fields_and_products/sp_chem.html\" target=\"_blank\">機能性化学品事業</a>\n                                            </div>\n                                        </div>\n\n\n                                        <div class=\"abody010102\">\n                                            <p class=\"ttl2\">レシートの印字にも日本曹達の化学品</p>\n                                            <div class=\"box\">\n                                                <p>\n                                                    買い物をすると渡されるレシート。どうして白紙に字が出るのだろうと不思議に思ったことはありませんか？それはレシートの表面に無色の染料と顕色剤が塗られているからです。熱が加わるとこの2つが反応して、無色だった染料が発色します。日本曹達の顕色剤「NKK-1304」は環境にやさしい材料として、レシートやチケット、ラベルなどに使用されています。\n                                                </p>\n                                                <a href=\"http://www.nippon-soda.co.jp/fields_and_products/sp_chem.html\" target=\"_blank\">機能性化学品事業</a>\n                                            </div>\n                                        </div>\n\n\n                                        <div class=\"abody010103\">\n                                            <p class=\"ttl3\">農作物を守る“農作物の薬”</p>\n                                            <div class=\"box\">\n                                                <p>\n                                                    店頭に並んだ野菜や果物。立派に育った旬のものは、見ていてうれしくなってきます。その喜びに大きく貢献しているのが、日本曹達の農薬群。とりわけ殺菌剤「トップジンM」と殺虫剤「モスピラン」は多くの病害虫に効果があるため、発売以来、“農作物の薬”として国内にとどまらず国外でも一般的に使用されています。\n                                                </p>\n                                                <a href=\"http://www.nippon-soda.co.jp/fields_and_products/agri.html\" target=\"_blank\">アグリビジネス</a>\n                                            </div>\n                                        </div>\n\n\n                                        <a class=\"close-btn\" href=\"javascript:void(0);\"><img class=\"js-switchimg\" src=\"../assets/img/common/icon_close_pc.png\" alt=\"CLOSE\"></a>\n                                    </div>\n\n\n\n                                    <div id=\"abody0102\" class=\"abody\">\n                                        <div class=\"ttl\"><img class=\"js-switchimg\" src=\"../assets/img/familiar//accordion_ttl02_pc.png\" alt=\"02 病院\"></div>\n\n\n                                        <div class=\"abody010201\">\n                                            <p class=\"ttl\">医薬錠剤の原料を結合・コーティング</p>\n                                            <div class=\"box\">\n                                                <p>\n                                                    飲みにくい粉末の薬を錠剤・顆粒剤に成形する際に使用されているのがHPCという添加物です。医薬品と同じ品質、安全性を担保して製造している企業は世界に2社しかなく、その1社が当社。国内シェアはNo.1。また、世界50か国に「NISSO HPC」を提供しています。\n                                                </p>\n                                                <a href=\"http://www.nippon-soda.co.jp/fields_and_products/pharm.html\" target=\"_blank\">医薬品事業</a>\n                                            </div>\n                                        </div>\n\n\n                                        <a class=\"close-btn\" href=\"javascript:void(0);\"><img class=\"js-switchimg\" src=\"../assets/img/common/icon_close_pc.png\" alt=\"CLOSE\"></a>\n                                    </div>\n                                </div>\n                            </div>\n\n\n\n\n\n                            <div id=\"section02\">\n                                <div class=\"accordionbtns\">\n                                    <a class=\"group02\" href=\"javascript:void(0);\" data-accordion-btn=\"abody0201\"><img class=\"js-switchimg\" src=\"../assets/img/familiar/top_btn03_pc.png\" alt=\"03 学校\"></a>\n                                    <a class=\"group02\" href=\"javascript:void(0);\" data-accordion-btn=\"abody0202\"><img class=\"js-switchimg\" src=\"../assets/img/familiar/top_btn04_pc.png\" alt=\"04 オフィス・ご家庭\"></a>\n                                </div>\n                                <div class=\"accordionbody\">\n                                    <div id=\"abody0201\" class=\"abody\">\n                                        <div class=\"ttl\"><img class=\"js-switchimg\" src=\"../assets/img/familiar//accordion_ttl03_pc.png\" alt=\"03 学校\"></div>\n\n\n                                        <div class=\"abody020101\">\n                                            <p class=\"ttl\">プール殺菌消毒剤の定番</p>\n                                            <div class=\"box\">\n                                                <p>\n                                                    小学校のプールの授業で、プールの底に沈んでいる丸くて白い塊をみたことはありませんか？これはプールの水を殺菌・消毒するための固形塩素剤で、皆さんが安心してプールを利用するために必要な薬剤なのです。「日曹ハイクロン」は固形塩素剤の中でも国内で高いシェアを誇り、多くの学校やスポーツクラブで水質維持に一役買っています。\n                                                </p>\n                                                <a href=\"http://www.nippon-soda.co.jp/fields_and_products/en_chem.html\" target=\"_blank\">環境化学品事業</a>\n                                            </div>\n                                        </div>\n\n\n                                        <div class=\"abody020102\">\n                                            <p class=\"ttl\">建物の微生物汚染を防ぐ</p>\n                                            <div class=\"box\">\n                                                <p>\n                                                    築年数が経過した学校の外壁や塀、屋根に、黒いシミが広がっていることがあります。この原因にあげられるのが、カビや藻。「バイオサイド」は、建築物を微生物汚染から守る薬剤で、塗布することで建物の外観をキレイに保つことができます。コンクリート用や木材用など様々なバリエーションが揃っています。\n                                                </p>\n                                                <a href=\"http://www.nippon-soda.co.jp/fields_and_products/sp_chem.html\" target=\"_blank\">機能性化学品事業</a>\n                                            </div>\n                                        </div>\n\n\n                                        <a class=\"close-btn\" href=\"javascript:void(0);\"><img class=\"js-switchimg\" src=\"../assets/img/common/icon_close_pc.png\" alt=\"CLOSE\"></a>\n                                    </div>\n\n\n\n                                    <div id=\"abody0202\" class=\"abody\">\n                                        <div class=\"ttl\"><img class=\"js-switchimg\" src=\"../assets/img/familiar//accordion_ttl04_pc.png\" alt=\"04 病院\"></div>\n\n\n                                        <div class=\"abody020201\">\n                                            <p class=\"ttl\">半導体製造の必需品</p>\n                                            <div class=\"box\">\n                                                <p>\n                                                    PCや炊飯器など、現代ではあらゆる家電に半導体が使われています。半導体の基板上には電子回路図が描かれていますが、その図を描く際にフォトレジストと呼ばれる薬剤が使用されます。「VPポリマー」はそのフォトレジストで使用される材料であり、高度の微細加工が必要な半導体製造に大きく役立っています。\n                                                </p>\n                                                <a href=\"http://www.nippon-soda.co.jp/fields_and_products/sp_chem.html\" target=\"_blank\">機能性化学品事業</a>\n                                            </div>\n                                        </div>\n\n\n                                        <div class=\"abody020202\">\n                                            <p class=\"ttl\">紫外線で汚れを酸化分解</p>\n                                            <div class=\"box\">\n                                                <p>\n                                                    住宅やテント地などの表面をきれいに保つために役立っているのが、酸化チタンコーティング剤「ビストレイター」です。酸化チタンは着色料や化粧品としても使われる無害な物質で、紫外線が当たると光触媒反応がおこり、汚れを酸化分解します。汚れを分解しても、酸化チタン自体が消耗することはありません。害がなくてずっと使える、人にも環境にも優しい製品です。\n                                                </p>\n                                                <a href=\"http://www.nippon-soda.co.jp/fields_and_products/sp_chem.html\" target=\"_blank\">機能性化学品事業</a>\n                                            </div>\n                                        </div>\n\n\n                                        <a class=\"close-btn\" href=\"javascript:void(0);\"><img class=\"js-switchimg\" src=\"../assets/img/common/icon_close_pc.png\" alt=\"CLOSE\"></a>\n                                    </div>\n                                </div>\n                            </div>\n\n\n\n\n\n                            <div id=\"section03\">\n                                <div class=\"accordionbtns\">\n                                    <a class=\"group03\" href=\"javascript:void(0);\" data-accordion-btn=\"abody0301\"><img class=\"js-switchimg\" src=\"../assets/img/familiar/top_btn05_pc.png\" alt=\"05 工場\"></a>\n                                    <a class=\"group03\" href=\"javascript:void(0);\" data-accordion-btn=\"abody0302\"><img class=\"js-switchimg\" src=\"../assets/img/familiar/top_btn06_pc.png\" alt=\"06 ゴミ焼却施設\"></a>\n                                </div>\n                                <div class=\"accordionbody\">\n                                    <div id=\"abody0301\" class=\"abody\">\n                                        <div class=\"ttl\"><img class=\"js-switchimg\" src=\"../assets/img/familiar//accordion_ttl05_pc.png\" alt=\"05 工場\"></div>\n\n\n                                        <div class=\"abody030101\">\n                                            <p class=\"ttl\">産業界に欠かせない基礎工業薬品</p>\n                                            <div class=\"box\">\n                                                <p>\n                                                    紙の原料が木であることはご存知だと思いますが、木からパルプを製造する際の、溶解や脱色といった工程で「カセイソーダ」が使われています。他にも、「カセイソーダ」は基礎工業薬品と言われ、上・下水道や工場排水の中和、アルミニウム原料であるアルミナ抽出、石鹸・洗剤の製造など、様々な用途があります。\n                                                </p>\n                                                <a href=\"http://www.nippon-soda.co.jp/fields_and_products/chlor.html\" target=\"_blank\">クロールアルカリ事業</a>\n                                            </div>\n                                        </div>\n\n\n                                        <a class=\"close-btn\" href=\"javascript:void(0);\"><img class=\"js-switchimg\" src=\"../assets/img/common/icon_close_pc.png\" alt=\"CLOSE\"></a>\n                                    </div>\n\n\n\n                                    <div id=\"abody0302\" class=\"abody\">\n                                        <div class=\"ttl\"><img class=\"js-switchimg\" src=\"../assets/img/familiar//accordion_ttl06_pc.png\" alt=\"06 ゴミ焼却施設\"></div>\n\n\n                                        <div class=\"abody030201\">\n                                            <p class=\"ttl\">クリーンな環境を守ります</p>\n                                            <div class=\"box\">\n                                                <p>\n                                                    ゴミ焼却施設で様々なゴミを焼却するときに発生する飛灰には、環境への悪影響が大きい鉛やカドミウムなどの重金属類が高濃度で含まれています。この飛灰を最終処分するときに活躍するのが「ハイジオン」です。回収した飛灰に「ハイジオン」を加え、重金属類を封じ込めることで、周辺土壌へ溶出することを防ぎます。\n                                                </p>\n                                                <a href=\"http://www.nippon-soda.co.jp/fields_and_products/en_chem.html\" target=\"_blank\">環境化学品事業</a>\n                                            </div>\n                                        </div>\n\n\n                                        <a class=\"close-btn\" href=\"javascript:void(0);\"><img class=\"js-switchimg\" src=\"../assets/img/common/icon_close_pc.png\" alt=\"CLOSE\"></a>\n                                    </div>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n\n\n            <footer class=\"sidepadding \">\n                <div class=\"insidebox\">\n                    <div id=\"pagetop\" class=\"pcshow\"><a href=\"#wrapper\"><img src=\"../assets/img/common/pagetop_pc.png\" alt=\"PAGE TOP\"></a></div>\n                    <div class=\"float\">\n                        <div class=\"left\">\n                            <ul class=\"flexbox\">\n                                <li><a href=\"http://www.nippon-soda.co.jp/privacy.html\" target=\"_blank\">プライバシーポリシー</a></li>\n                                <li><a href=\"http://www.nippon-soda.co.jp/contact/index.html\" target=\"_blank\">お問い合わせ</a></li>\n                            </ul>\n                        </div>\n                        <div class=\"right\">\n                            <div id=\"footer-logo\"><img class=\"js-switchimg\" src=\"../assets/img/common/footer_logo_pc.png\" alt=\"\"></div>\n                            <div id=\"copyright\">Copyright 2018 NIPPON SODA CO., LTD. All rights reserved</div>\n                        </div>\n                    </div>\n                </div>\n            </footer>\n\n\n\n        </div>\n    </body>\n</html>\n","finalUrl":"https://www.nippon-soda.co.jp/recruitment/saiyo/familiar/","rendered":false,"_cachedAt":"2026-06-22T21:32:51.822Z"}