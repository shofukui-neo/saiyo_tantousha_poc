{"url":"http://www.nichicon.co.jp/recruit_graduates/internship/","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n  <head>\n    <meta charset=\"UTF-8\">\n    <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1, shrink-to-fit=no\">\n    <title>インターンシップ | 新卒採用情報 | 採用情報 | 企業情報 | ニチコン株式会社 </title>\n    <meta name=\"description\" content=\"ニチコンのインターンシップをご紹介しています。\">\n    <link rel=\"canonical\" href=\"https://www.nichicon.co.jp/recruit_graduates/internship/\">\n    <meta property=\"og:type\" content=\"website\">\n    <meta property=\"og:title\" content=\"インターンシップ | 新卒採用情報 | 採用情報 | 企業情報 | ニチコン株式会社 \">\n    <meta property=\"og:description\" content=\"ニチコンのインターンシップをご紹介しています。\">\n    <meta property=\"og:url\" content=\"https://www.nichicon.co.jp/recruit_graduates/internship/\">\n    <meta property=\"og:image\" content=\"https://www.nichicon.co.jp/recruit_graduates/assets/images/meta-img/ogp.jpg\">\n    <link rel=\"icon\" href=\"/recruit_graduates/assets/images/meta-img/favicon.ico\">\n    <link rel=\"apple-touch-icon\" href=\"/recruit_graduates/assets/images/meta-img/touch-icon.png\">\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n    <link href=\"https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500;600;700&amp;family=Noto+Sans+JP:wght@100..900&amp;family=Work+Sans:ital,wght@0,100..900;1,100..900&amp;family=Zen+Kaku+Gothic+Antique&amp;display=swap\" rel=\"stylesheet\">\n    <link rel=\"stylesheet\" href=\"/recruit_graduates/assets/css/app.css\"><!-- Google Tag Manager -->\n      <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\n      new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\n      j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n      'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n      })(window,document,'script','dataLayer','GTM-TSTMN78');</script>\n    <!-- End Google Tag Manager -->\n  </head>\n  <body id=\"js-body\" data-page=\"internship\">\n    <!-- Google Tag Manager (noscript) -->\n      <noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-TSTMN78\"\n      height=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n    <!-- End Google Tag Manager (noscript) -->\n    <header class=\"l-header\">\n      <div class=\"header__link--top\"><a href=\"#top\">\n          <div class=\"flex-box\">\n            <div class=\"border\"></div>\n            <p class=\"header__link--txt\">Page top</p>\n          </div></a></div>\n      <div class=\"header__container--sp\">\n        <div class=\"header__inner\">\n          <h1 class=\"ttl__logo\"><a href=\"/recruit_graduates/\"><img src=\"/recruit_graduates/assets/images/nav-logo.svg\" alt=\"nichicon 新卒採用サイト\"></a></h1>\n        </div>\n      </div>\n      <div class=\"header__container\">\n        <div class=\"header__inner\">\n          <h1 class=\"ttl__logo\"><a href=\"/recruit_graduates/\"><img src=\"/recruit_graduates/assets/images/nav-logo.svg\" alt=\"nichicon 新卒採用サイト\"></a></h1>\n          <div class=\"navi\" id=\"navi\">\n            <ul class=\"navi__list\">\n              <li class=\"navi__list--item has-child\" data-page=\"about\">\n                <div class=\"list-wrap js-has-child\" data-label=\"about\">\n                  <p>ニチコンを知る</p><span class=\"arrow-ico\" data-label=\"about\"></span>\n                </div>\n                <div class=\"child-list__wrap\" data-label=\"about\">\n                  <ul class=\"child-list\">\n                    <li class=\"child-list__item\"><a class=\"flex-box\" href=\"/recruit_graduates/about/\">\n                        <p>ニチコンを知るTOP</p>\n                        <div class=\"c-arrow-only-ico\"></div></a></li>\n                    <li class=\"child-list__item\"><a class=\"flex-box\" href=\"/recruit_graduates/about/#anc-01\">\n                        <p>経営理念</p>\n                        <div class=\"c-arrow-only-ico\"></div></a></li>\n                    <li class=\"child-list__item\"><a class=\"flex-box\" href=\"/recruit_graduates/about/#anc-02\">\n                        <p>キーワードで見るニチコン</p>\n                        <div class=\"c-arrow-only-ico\"></div></a></li>\n                    <li class=\"child-list__item\"><a class=\"flex-box\" href=\"/recruit_graduates/about/#anc-03\">\n                        <p>創造業としての社会貢献</p>\n                        <div class=\"c-arrow-only-ico\"></div></a></li>\n                    <li class=\"child-list__item\"><a class=\"flex-box\" href=\"/recruit_graduates/about/#anc-04\">\n                        <p>積極的な研究開発</p>\n                        <div class=\"c-arrow-only-ico\"></div></a></li>\n                    <li class=\"child-list__item\"><a class=\"flex-box\" href=\"/recruit_graduates/about/#anc-05\">\n                        <p>ダイバーシティ</p>\n                        <div class=\"c-arrow-only-ico\"></div></a></li>\n                    <li class=\"child-list__item\"><a class=\"flex-box\" href=\"/recruit_graduates/about/#anc-06\">\n                        <p>グローバルな事業展開</p>\n                        <div class=\"c-arrow-only-ico\"></div></a></li>\n                    <li class=\"child-list__item\"><a class=\"flex-box\" href=\"/recruit_graduates/about/#anc-07\">\n                        <p>会社情報</p>\n                        <div class=\"c-arrow-only-ico\"></div></a></li>\n                    <li class=\"child-list__bnr\"><a class=\"c-bnr\" href=\"/brand/\"><span>ブランドサイト</span>\n                        <picture>\n                          <source srcset=\"/recruit_graduates/assets/images/nichicon_saiyobanner_pc.jpg\" media=\"(min-width: 769px)\"><img src=\"/recruit_graduates/assets/images/nichicon_saiyobanner_sp.jpg\" alt=\"\">\n                        </picture></a></li>\n                  </ul>\n                </div>\n              </li>\n              <li class=\"navi__list--item has-child\" data-page=\"jobs\">\n                <div class=\"list-wrap js-has-child\" data-label=\"jobs\">\n                  <p>ニチコンの仕事</p><span class=\"arrow-ico\" data-label=\"jobs\"></span>\n                </div>\n                <div class=\"child-list__wrap\" data-label=\"jobs\">\n                  <ul class=\"child-list\">\n                    <li class=\"child-list__item\"><a class=\"flex-box\" href=\"/recruit_graduates/jobs/\">\n                        <p>ニチコンの仕事TOP</p>\n                        <div class=\"c-arrow-only-ico\"></div></a></li>\n                    <li class=\"child-list__item\"><a class=\"flex-box\" href=\"/recruit_graduates/jobs/interview1.html\">\n                        <p>フィルムコンデンサ設計</p>\n                        <div class=\"c-arrow-only-ico\"></div></a></li>\n                    <li class=\"child-list__item\"><a class=\"flex-box\" href=\"/recruit_graduates/jobs/interview2.html\">\n                        <p>生産技術</p>\n                        <div class=\"c-arrow-only-ico\"></div></a></li>\n                    <li class=\"child-list__item\"><a class=\"flex-box\" href=\"/recruit_graduates/jobs/interview3.html\">\n                        <p>材料開発</p>\n                        <div class=\"c-arrow-only-ico\"></div></a></li>\n                    <li class=\"child-list__item\"><a class=\"flex-box\" href=\"/recruit_graduates/jobs/interview4.html\">\n                        <p>品質管理</p>\n                        <div class=\"c-arrow-only-ico\"></div></a></li>\n                    <li class=\"child-list__item\"><a class=\"flex-box\" href=\"/recruit_graduates/jobs/interview5.html\">\n                        <p>社内SE</p>\n                        <div class=\"c-arrow-only-ico\"></div></a></li>\n                    <li class=\"child-list__item\"><a class=\"flex-box\" href=\"/recruit_graduates/jobs/interview6.html\">\n                        <p>コンデンサ設計開発</p>\n                        <div class=\"c-arrow-only-ico\"></div></a></li>\n                    <li class=\"child-list__item\"><a class=\"flex-box\" href=\"/recruit_graduates/jobs/interview7.html\">\n                        <p>蓄電ソフト開発</p>\n                        <div class=\"c-arrow-only-ico\"></div></a></li>\n                    <li class=\"child-list__item\"><a class=\"flex-box\" href=\"/recruit_graduates/jobs/interview8.html\">\n                        <p>応用機器設計</p>\n                        <div class=\"c-arrow-only-ico\"></div></a></li>\n                    <li class=\"child-list__item\"><a class=\"flex-box\" href=\"/recruit_graduates/jobs/interview10.html\">\n                        <p>営業</p>\n                        <div class=\"c-arrow-only-ico\"></div></a></li>\n                  </ul>\n                </div>\n              </li>\n              <li class=\"navi__list--item\" data-page=\"technology\"><a href=\"/recruit_graduates/technology/\">\n                  <div class=\"list-wrap\">\n                    <p>未来をひらく技術力</p><span class=\"c-arrow-only-ico is-tab\"></span>\n                  </div></a></li>\n              <li class=\"navi__list--item\" data-page=\"internship\"><a href=\"/recruit_graduates/internship/\">\n                  <div class=\"list-wrap\">\n                    <p>インターンシップ</p><span class=\"c-arrow-only-ico is-tab\"></span>\n                  </div></a></li>\n              <li class=\"navi__list--item last-item has-child\" data-page=\"requirement\">\n                <div class=\"list-wrap js-has-child\" data-label=\"requirement\">\n                  <p>募集要項</p><span class=\"arrow-ico\" data-label=\"requirement\"></span>\n                </div>\n                <div class=\"child-list__wrap is-open\" data-label=\"requirement\">\n                  <ul class=\"child-list\">\n                    <li class=\"child-list__item\"><a class=\"flex-box\" href=\"/recruit_graduates/requirement/\">\n                        <p>募集要項TOP</p>\n                        <div class=\"c-arrow-only-ico\"></div></a></li>\n                    <li class=\"child-list__item\"><a class=\"flex-box\" href=\"/recruit_graduates/requirement/process.html\">\n                        <p>採用プロセス</p>\n                        <div class=\"c-arrow-only-ico\"></div></a></li>\n                  </ul>\n                </div>\n              </li>\n            </ul>\n          </div>\n          <div class=\"header__entry--wrap\"><a class=\"header__entry--btn -white\" href=\"https://job.axol.jp/bx/s/nichicon_27/mypage/login\" target=\"_blank\">\n              <p>My Page</p></a><a class=\"header__entry--btn\" href=\"https://job.axol.jp/bx/s/nichicon_27/entry/\" target=\"_blank\">\n              <p>Entry</p></a></div>\n          <div class=\"sp-menu__btn\" id=\"js-menu-btn\">\n            <p>Menu</p><span class=\"border-ico\"></span>\n          </div>\n        </div>\n      </div>\n    </header>\n    <div class=\"internship\">\n      <section class=\"internship-mv\">\n        <div class=\"internship-mv__container\">\n          <div class=\"internship-mv__img\">\n            <div class=\"c-container\">\n              <div class=\"c-ttl__contents\">\n                <div class=\"c-ttl__contents--item\">\n                  <h2 class=\"c-ttl white-txt u-textOverlay\"><span class=\"u-textOverlay__inner\">Internship</span></h2>\n                  <div class=\"c-ttl-label white-txt u-textOverlay is-pc\"><span class=\"u-textOverlay__inner\">理工系対象</span></div>\n                </div>\n                <div class=\"c-ttl__contents--item\">\n                  <div class=\"c-ttl-label white-txt u-textOverlay is-sp\"><span class=\"u-textOverlay__inner\">理工系対象</span></div>\n                  <p class=\"c-sub-ttl white-txt u-textOverlay\"><span class=\"u-textOverlay__inner\">インターンシップ</span></p>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </section>\n      <div class=\"internship-anchor__container\">\n        <div class=\"c-anchor-links\">\n          <div class=\"c-anchor-link\"><a class=\"c-btn\" href=\"#details\">\n              <div class=\"c-btn__txt\">実施内容</div></a></div>\n          <div class=\"c-anchor-link\"><a class=\"c-btn\" href=\"#past\">\n              <div class=\"c-btn__txt\">過去開催<br class=\"is-sp\">された内容</div></a></div>\n          <div class=\"c-anchor-link\"><a class=\"c-btn\" href=\"#requirement\">\n              <div class=\"c-btn__txt\">募集要項</div></a></div>\n        </div>\n      </div>\n      <section class=\"internship-details\" id=\"details\">\n        <div class=\"internship-contents__container\">\n          <h2 class=\"c-lower-ttl\">実施内容</h2>\n          <div class=\"internship-contents__wrap\">\n            <div class=\"internship-contents__lead\">\n              <p>当社は、創立以来培った、電気を効率よくマネジメントする技術を活かし、<br class=\"is-only-tab\">明るい未来社会づくりに貢献するさまざまな製品を開発しています。<br>本年度のインターンシップは対面またはオンラインにて実施します。</p>\n            </div>\n            <div class=\"internship-details__entry\">\n              <div class=\"entry__inner\">\n                <div class=\"entry__ttl\">インターンシップ エントリー</div>\n                <div class=\"entry__txt\">インターンシップへの参加は、下記QRコードからご応募ください。</div>\n                <div class=\"entry__qr\"><img src=\"/recruit_graduates/assets/images/internship_qr.png\" alt=\"\"></div>\n              </div>\n            </div>\n            <div class=\"internship-details__list js-fadeup-trigger\">\n              <dl class=\"details__list is-top is-pc\">\n                <dt class=\"details__list--ttl\">実施事業所</dt>\n                <dd class=\"details__list--txt\">実施内容</dd>\n              </dl>\n              <dl class=\"details__list\">\n                <dt class=\"details__list--ttl is-first-child\">\n                  <p>東京開発センター</p>\n                </dt>\n                <dd class=\"details__list--txt\">\n                  <ul class=\"txt-list\">\n                    <li class=\"txt-list__item\">・スイッチング電源ならびに家庭用蓄電システム等について</li>\n                    <li class=\"txt-list__item\">・事業所紹介</li>\n                    <li class=\"txt-list__item\">・技術系先輩社員とのグループディスカッションや座談会</li>\n                  </ul>\n                </dd>\n              </dl>\n              <dl class=\"details__list\">\n                <dt class=\"details__list--ttl\">\n                  <p>ニチコン亀岡</p>\n                </dt>\n                <dd class=\"details__list--txt\">\n                  <ul class=\"txt-list\">\n                    <li class=\"txt-list__item\">・V2L(Vehicle to Load)システムなどの自動車関連製品について</li>\n                    <li class=\"txt-list__item\">・事業所紹介</li>\n                    <li class=\"txt-list__item\">・技術系先輩社員とのグループディスカッションや座談会</li>\n                  </ul>\n                </dd>\n              </dl>\n              <dl class=\"details__list\">\n                <dt class=\"details__list--ttl\">\n                  <p>ニチコン草津</p>\n                </dt>\n                <dd class=\"details__list--txt\">\n                  <ul class=\"txt-list\">\n                    <li class=\"txt-list__item\">・フィルムコンデンサまたは高精度直流安定化電源について</li>\n                    <li class=\"txt-list__item\">・事業所紹介</li>\n                    <li class=\"txt-list__item\">・技術系先輩社員とのグループディスカッションや座談会</li>\n                  </ul>\n                </dd>\n              </dl>\n              <dl class=\"details__list\">\n                <dt class=\"details__list--ttl\">\n                  <p>ニチコン大野 <br class=\"is-only-tab\">福井工場</p>\n                </dt>\n                <dd class=\"details__list--txt\">\n                  <ul class=\"txt-list\">\n                    <li class=\"txt-list__item\">・アルミ電解コンデンサならびに小形リチウムイオン二次電池について</li>\n                    <li class=\"txt-list__item\">・事業所紹介</li>\n                    <li class=\"txt-list__item\">・技術系先輩社員とのグループディスカッションや座談会</li>\n                  </ul>\n                </dd>\n              </dl>\n              <dl class=\"details__list\">\n                <dt class=\"details__list--ttl\">\n                  <p>ニチコン製箔 <br class=\"is-only-tab\">大町工場</p>\n                </dt>\n                <dd class=\"details__list--txt\">\n                  <ul class=\"txt-list\">\n                    <li class=\"txt-list__item\">・アルミ電解コンデンサに使用される電極箔について</li>\n                    <li class=\"txt-list__item\">・事業所紹介</li>\n                    <li class=\"txt-list__item\">・技術系先輩社員とのグループディスカッションや座談会</li>\n                  </ul>\n                </dd>\n              </dl>\n              <dl class=\"details__list\">\n                <dt class=\"details__list--ttl\">\n                  <ul class=\"ttl--items\">\n                    <li>ニチコン大野<br class=\"is-only-tab\"> 本工場</li>\n                    <li>ニチコン大野 <br class=\"is-only-tab\">長野工場</li>\n                    <li>ニチコン岩手</li>\n                  </ul>\n                </dt>\n                <dd class=\"details__list--txt\">\n                  <ul class=\"txt-list\">\n                    <li class=\"txt-list__item\">・アルミ電解コンデンサについて</li>\n                    <li class=\"txt-list__item\">・事業所紹介</li>\n                    <li class=\"txt-list__item\">・技術系先輩社員とのグループディスカッションや座談会</li>\n                  </ul>\n                </dd>\n              </dl>\n            </div>\n          </div>\n        </div>\n      </section>\n      <section class=\"internship-past\" id=\"past\">\n        <div class=\"internship-contents__container\">\n          <h2 class=\"c-lower-ttl\">過去開催された内容</h2>\n          <div class=\"internship-contents__wrap\">\n            <div class=\"internship-contents__lead\">\n              <p>全国にある事業所での対面または、<br class=\"is-sp\">オンラインにて開催しています。</p>\n            </div>\n            <div class=\"internship-past__list\">\n              <div class=\"internship-past__list--item\">\n                <div class=\"ttl\">1Day 仕事研究<br class=\"is-sp\">（東京開発センター）</div>\n                <dl class=\"list\">\n                  <dt class=\"list-ttl\">実施内容</dt>\n                  <dd class=\"list-box\">\n                    <ul class=\"list-txt\">\n                      <li class=\"list-txt-item\">・蓄電システムの放充電試験とその評価体験</li>\n                      <li class=\"list-txt-item\">・技術系先輩社員とのグループディスカッションや座談会</li>\n                      <li class=\"list-txt-item\">・事業所内・施設見学、製品紹介</li>\n                    </ul>\n                  </dd>\n                </dl>\n                <dl class=\"list\">\n                  <dt class=\"list-ttl\">対象</dt>\n                  <dd class=\"list-box\">\n                    <div class=\"list-box__item\">電気電子、機械、情報、化学系をはじめとした理系専攻</div>\n                  </dd>\n                </dl>\n                <dl class=\"list\">\n                  <dt class=\"list-ttl\">開催形式</dt>\n                  <dd class=\"list-box\">\n                    <div class=\"list-box__item\">対面：東京開発センター（東京都中央区）</div>\n                  </dd>\n                </dl>\n                <dl class=\"list\">\n                  <dt class=\"list-ttl\">参加者の声</dt>\n                  <dd class=\"list-box\">\n                    <div class=\"list-box__item\">\n                      <p>東京開発センターの業務内容や蓄電の今後の需要の把握に加え、蓄電の設計等の仕事の進め方が把握でき、想定以上に業務内容を実感できた。 又、入社5年目の社員の方との質疑応答では、実際の勤務スケジュールや当社を選択した事由等の会社説明では把握できない内容をヒアリングすることができ、非常に有意義でした。</p>\n                    </div>\n                  </dd>\n                </dl>\n              </div>\n              <div class=\"internship-past__list--item\">\n                <div class=\"ttl\">1Day 仕事研究<br class=\"is-tab\">（ニチコン大野　福井工場）</div>\n                <dl class=\"list\">\n                  <dt class=\"list-ttl\">実施内容</dt>\n                  <dd class=\"list-box\">\n                    <ul class=\"list-txt\">\n                      <li class=\"list-txt-item\">・小形リチウムイオン二次電池に使用される技術紹介</li>\n                      <li class=\"list-txt-item\">・10年後の小形リチウムイオン二次電池新用途を考える</li>\n                      <li class=\"list-txt-item\">・技術系先輩社員とのグループディスカッションや座談会</li>\n                      <li class=\"list-txt-item\">・工場内・設備見学、開発・製造製品の紹介</li>\n                    </ul>\n                  </dd>\n                </dl>\n                <dl class=\"list\">\n                  <dt class=\"list-ttl\">対象</dt>\n                  <dd class=\"list-box\">\n                    <div class=\"list-box__item\">電気電子、機械、情報、化学系をはじめとした理系専攻</div>\n                  </dd>\n                </dl>\n                <dl class=\"list\">\n                  <dt class=\"list-ttl\">開催形式</dt>\n                  <dd class=\"list-box\">\n                    <div class=\"list-box__item\">オンライン</div>\n                  </dd>\n                </dl>\n                <dl class=\"list\">\n                  <dt class=\"list-ttl\">参加者の声</dt>\n                  <dd class=\"list-box\">\n                    <div class=\"list-box__item\">\n                      <p>オンラインでの参加であったものの、事業内容、製品開発プロセスが把握でき、満足できる内容でした。</p>\n                    </div>\n                  </dd>\n                </dl>\n              </div>\n            </div>\n          </div>\n        </div>\n      </section>\n      <section class=\"internship-requirement\" id=\"requirement\">\n        <div class=\"internship-contents__container\">\n          <h2 class=\"c-lower-ttl\">募集要項</h2>\n          <div class=\"internship-contents__wrap\">\n            <div class=\"internship-contents__lead\">\n              <p>参加をご希望の方は、<br class=\"is-sp\">以下をご確認ください。</p>\n            </div>\n            <div class=\"internship-past__list--item\">\n              <dl class=\"list\">\n                <dt class=\"list-ttl\">実施日</dt>\n                <dd class=\"list-box\">\n                  <ul class=\"list-txt no-indent\">\n                    <li class=\"list-txt-item\">8月中旬～9月中旬、12月の2タームにて実施予定。<br>詳細は6月以降に順次案内しますので、ナビサイトを確認ください。</li>\n                  </ul>\n                </dd>\n              </dl>\n              <dl class=\"list\">\n                <dt class=\"list-ttl\">開催方法</dt>\n                <dd class=\"list-box\">\n                  <div class=\"list-box__item\">対面またはオンライン（Cisco Webex）</div>\n                </dd>\n              </dl>\n              <dl class=\"list\">\n                <dt class=\"list-ttl\">応募方法</dt>\n                <dd class=\"list-box\">\n                  <div class=\"list-box__item\">リクナビあるいはマイナビにてエントリーいただいた後、エントリーシートをメールにて送信ください。</div>\n                </dd>\n              </dl>\n              <dl class=\"list\">\n                <dt class=\"list-ttl\">合否結果連絡</dt>\n                <dd class=\"list-box\">\n                  <div class=\"list-box__item\">\n                    <p>選考後、メールあるいは電話にて連絡します。</p>\n                  </div>\n                </dd>\n              </dl>\n              <dl class=\"list\">\n                <dt class=\"list-ttl\">報酬</dt>\n                <dd class=\"list-box\">\n                  <div class=\"list-box__item\">\n                    <p>支給なし</p>\n                  </div>\n                </dd>\n              </dl>\n              <dl class=\"list\">\n                <dt class=\"list-ttl\">交通費・宿泊費</dt>\n                <dd class=\"list-box\">\n                  <div class=\"list-box__item\">\n                    <p>対面開催時は支給あり（当社規程に基づく）</p>\n                  </div>\n                </dd>\n              </dl>\n            </div>\n            <div class=\"internship-details__entry\">\n              <div class=\"entry__inner\">\n                <div class=\"entry__ttl\">インターンシップ エントリー</div>\n                <div class=\"entry__txt\">インターンシップへの参加は、リクナビまたはマイナビからご応募ください。</div>\n                <div class=\"entry__qr\"><img src=\"/recruit_graduates/assets/images/internship_qr.png\" alt=\"\"></div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </section>\n    </div>\n    <footer class=\"l-footer\">\n      <div class=\"footer__container\">\n        <div class=\"footer__inner\">\n          <div class=\"footer__link\">\n            <div class=\"footer__link--item\"><a href=\"https://www.nichicon.co.jp/\" target=\"_blank\" rel=\"noopener noreferrer\">\n                <p>コーポレートサイト</p></a></div>\n            <div class=\"footer__link--item\"><a href=\"https://www.nichicon.co.jp/policy/\" target=\"_blank\" rel=\"noopener noreferrer\">\n                <p>個人情報保護方針</p></a></div>\n          </div><small class=\"footer__copy\">© 2024  NICHICON CORPORATION.</small>\n        </div>\n      </div>\n    </footer>\n    <script src=\"/recruit_graduates/assets/js/app.js\"></script>\n  </body>\n</html>","finalUrl":"http://www.nichicon.co.jp/recruit_graduates/internship/","rendered":false,"_cachedAt":"2026-06-22T17:32:07.519Z"}