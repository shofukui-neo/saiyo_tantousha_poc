{"url":"https://www.ttk-g.co.jp/group/toubu/recruit/","html":"\n<!DOCTYPE html>\n<html lang=\"ja\">\n\n<head>\n  <meta charset=\"UTF-8\">\n  <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\" />\n  <meta name=\"description\" content=\"地域とともに、地域の未来へ。株式会社ＴＴＫエンジ宮城はＴＴＫグループの一員として、東北地域の情報通信ネットワーク、モバイル通信ネットワークの設計・施工・保守をしております。\" />\n  <meta name=\"keywords\" content=\"東部電話工事株式会社,東北,宮城,仙台,ＴＴＫエンジ,電気通信工事,情報通信,電気設備,伝送設備,基地局,建設,保守,修理,きずな光,きずな光,ミライト\" />\n  <meta name=\"format-detection\" content=\"telephone=no\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1, minimum-scale=1, maximum-scale=1\">\n  <link rel=\"canonical\" href=\"https://www.ttk-g.co.jp/group/toubu/recruit/\" />\n  <link rel=\"shortcut icon\" href=\"/group/web_parts/favicon.ico\">\n  <title>採用情報｜株式会社TTKエンジ宮城</title>\n  <link rel=\"stylesheet\" href=\"/group/web_parts/css/style_toubu.css\" media=\"screen, all\" />\n  <link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/yakuhanjp@3.3.1/dist/css/yakuhanjp.min.css\">\n<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\">\n<link href=\"https://fonts.googleapis.com/css2?family=Open+Sans:wght@600;700&display=swap\" rel=\"stylesheet\">\n<link rel=\"stylesheet\" href=\"/group/web_parts/font-Awesome-4.7.0/css/font-awesome.min.css\" media=\"screen, all\" />\n\n  <script src=\"/group/web_parts/base.min.js\"></script>\n</head>\n\n<body class=\"toubu recruit\">\n<div id=\"header-container-toubu\"></div>\n\n<div class=\"breadcrumbBox\">\n  <ol id=\"breadcrumb\" class=\"breadcrumb\" itemscope itemtype=\"https://schema.org/BreadcrumbList\">\n    <li itemprop=\"itemListElement\" itemscope itemtype=\"https://schema.org/ListItem\">\n      <a itemprop=\"item\" href=\"/group/toubu/\"><span itemprop=\"name\">ホーム</span></a>\n      <meta itemprop=\"position\" content=\"1\" />\n    </li>\n    <!--li-->\n    <li itemprop=\"itemListElement\" itemscope itemtype=\"https://schema.org/ListItem\">\n      <a itemprop=\"item\" href=\"/group/toubu/recruit\"><span itemprop=\"name\">採用情報</span></a>\n      <meta itemprop=\"position\" content=\"2\" />\n    </li>\n    <!--li-->\n  </ol>\n</div>\n<!--breadcrumbBox-->\n\n<!--header-->\n<i id=\"x_1\" class=\"x_item\"></i><i id=\"x_2\" class=\"x_item\"></i>\n\n<div id=\"mvPage\" class=\"mv\">\n</div>\n<!--mv-->\n\n<div id=\"contents\">\n  <main id=\"main\">\n    <section>\n      <article>\n\n        <div class=\"titleBox_whiteBox titleBox_whiteBox_center markParent\">\n          <i class=\"mark\"><img src=\"/group/web_parts/img/toubu/cmn/mark_1.png\"></i>\n          <div class=\"titleBox center\">\n            <h2 class=\"jp\"><strong>採用情報</strong></h2><br>\n            <p class=\"en keyColor\"><span>RECRUIT</span></p>\n          </div>\n        </div>\n\n        <p class=\"max1200 w90 centerBox btm100px\"><a href=\"https://www.ttk-g.co.jp/recruit/group/\" target=\"_blank\"><img src=\"/group/web_parts/img/toubu/cmn/recBNR.png\" width=\"100%\" alt=\"TTK採用サイト\"></a></p>\n\n\n        <div class=\"recWrap markParent\">\n          <i class=\"mark\"><img src=\"/group/web_parts/img/toubu/cmn/mark_1.png\"></i>\n          <div class=\"titleBox center\">\n            <h2 class=\"jp\"><strong>採用情報</strong></h2><br>\n            <p class=\"en keyColor\"><span>RECRUIT</span></p>\n          </div>\n\n\n\n          <div class=\"ancBox ancBox_3\">\n            <ul>\n              <li><a href=\"#newGraduate\"><span>新卒採用情報</span></a></li>\n              <li><a href=\"#mid_career\"><span>中途採用情報</span></a></li>\n              <li><a href=\"#career\"><span>キャリア採用情報</span></a></li>\n            </ul>\n          </div>\n\n\n          <div class=\"ancParent\">\n            <i class=\"ancPoint\" id=\"newGraduate\"></i>\n            <div class=\"recBox w90 max1000 centerBox ckBox\">\n              <div class=\"simpleTBL baseTBL\">\n                                  <table>\n<thead>\n<tr>\n<th colspan=\"2\">新卒採用情報</th>\n</tr>\n</thead>\n<tbody>\n<tr>\n<th>募集職種</th>\n<td>電気通信工事技術者及び電気技術者</td>\n</tr>\n<tr>\n<th>業務内容</th>\n<td>&nbsp;主に電気通信設備にかかわる仕事で、光・メタルケーブル配線、装置試験や<br />\n&nbsp;屋内外における光・メタルケーブル伝送路の建設・接続試験、通信設備の点検、故障修理、<br />\n&nbsp;保全業務等<br />\n&nbsp;※エリア　宮城県内全域が中心</td>\n</tr>\n<tr>\n<th>勤務地</th>\n<td>宮城県　仙台市、石巻市、大崎市、気仙沼市</td>\n</tr>\n<tr>\n<th>勤務時間</th>\n<td>8:30～17:00</td>\n</tr>\n<tr>\n<th>休日・休暇</th>\n<td>原則　土・日・祝祭日　(月2・3回土日出勤有(代休付与又は手当支給))<br />\n夏季休暇(7/1～9/30のうち連続4日間)、&nbsp;年末年始休暇(12/29～1/3)、年次有給休暇、特別有給休暇</td>\n</tr>\n<tr>\n<th>給与支給額</th>\n<td>\n<p>月給　大学卒　　　　　　&nbsp;&nbsp;&nbsp;&nbsp;　&nbsp;　&nbsp; &nbsp; 209,875円<br />\n　　　短大・高専・専門校卒(2年)　　 206,542円<br />\n　　　高校卒　　　　&nbsp; &nbsp; &nbsp; &nbsp;　　&nbsp; &nbsp; &nbsp;　203,209円<br />\n　　※若年層自己啓発支援手当・暫定手当・特別手当含<br />\n　　　その他各種手当支給(会社規程による)、賞与年２回</p>\n</td>\n</tr>\n<tr>\n<th>通勤手当</th>\n<td>公共交通機関の場合は全額、車・バイク・自転車の場合は2km以上から支給、上限月額38,700円</td>\n</tr>\n<tr>\n<th>福利厚生</th>\n<td>社会保険完備、退職金制度有、福利厚生代行サービス導入</td>\n</tr>\n<tr>\n<th>募集対象</th>\n<td>令和9年3月　各学校卒業見込み者</td>\n</tr>\n<tr>\n<th>応募に必要な免許・資格</th>\n<td>普通自動車免許<br />\nWord、Excel操作</td>\n</tr>\n<tr>\n<th>受付期間</th>\n<td>\n<p>〇大学等（短大、専門学校、専門校）卒　　　　令和8年3月1日以降随時</p>\n\n<p>〇高等学校卒　　　　　　　　　　　　　　&nbsp;令和8年9月5日～9月15日</p>\n</td>\n</tr>\n<tr>\n<th>選考日</th>\n<td>\n<p>〇大学等（短大、専門学校、専門校）卒　　　　令和8年3月1日以降随時</p>\n\n<p>〇高等学校卒　　　　　　　　　　&nbsp; &nbsp; 　　　令和8年9月16日</p>\n</td>\n</tr>\n<tr>\n<th>選考方法</th>\n<td>面接<br />\n適性検査[SCOA総合検査]<br />\n学科試験[一般常識]</td>\n</tr>\n</tbody>\n</table>\n                              </div>\n            </div>\n            <!--recBox-->\n\n            <div class=\"recBTN_box w90 max1000 centerBox\">\n              <p class=\"contactBTN\"><a href=\"/contact/\"><span class=\"inr\">お問い合わせはこちらから</span></a></p>\n              <p class=\"telBTN\"><a href=\"tel:0227947112\"><span class=\"inr\"><span class=\"fa-stack fa-lg\"><i class=\"fa fa-circle fa-stack-2x\"></i><i class=\"fa fa-phone fa-stack-1x fa-inverse\"></i> </span> 022-794-7112</span></a></p>\n            </div>\n            <!--recBTN_box-->\n\n          </div>\n\n\n          <div class=\"ancParent\">\n            <i class=\"ancPoint\" id=\"mid_career\"></i>\n            <div class=\"recBox w90 max1000 centerBox ckBox\">\n              <div class=\"simpleTBL baseTBL\">\n                                  <table>\n<thead>\n<tr>\n<th colspan=\"2\">中途採用情報</th>\n</tr>\n</thead>\n<tbody>\n<tr>\n<th>募集職種</th>\n<td>電気通信工事技術者及び電気技術者</td>\n</tr>\n<tr>\n<th>業務内容</th>\n<td>石巻エリア・大崎エリア・気仙沼エリアを中心とした電気通信設備を維持するための定期点検及び電話故障時の対応、加害に対する緊急対応業務<br />\n※エリア　宮城県内全域が中心</td>\n</tr>\n<tr>\n<th>勤務地</th>\n<td>宮城県石巻市、大崎市、気仙沼市</td>\n</tr>\n<tr>\n<th>勤務時間</th>\n<td>8:30～17:00</td>\n</tr>\n<tr>\n<th>休日・休暇</th>\n<td>原則　土・日・祝　(月2・3回土日出勤有(代休付与又は手当支給))<br />\n夏季休暇(7/1～9/30のうち連続4日間)、&nbsp;年末年始休暇(12/29～1/3)</td>\n</tr>\n<tr>\n<th>給与支給額</th>\n<td>月給160,000円～235,520円</td>\n</tr>\n<tr>\n<th>通勤手当</th>\n<td>公共交通機関の場合は全額、車・バイク・自転車の場合は2ｋｍ以上から支給、上限月額38,700円</td>\n</tr>\n<tr>\n<th>福利厚生</th>\n<td>社会保険完備、退職金制度有、</td>\n</tr>\n<tr>\n<th>募集対象</th>\n<td>18歳～55歳</td>\n</tr>\n<tr>\n<th>応募に必要な免許・資格</th>\n<td>普通自動車免許<br />\nWord、Excel操作</td>\n</tr>\n<tr>\n<th>受付期間</th>\n<td>随時</td>\n</tr>\n<tr>\n<th>選考日</th>\n<td>随時</td>\n</tr>\n<tr>\n<th>選考方法</th>\n<td>\n<p>面接</p>\n\n<p>適正検査［SCOA総合検査］</p>\n\n<p>学科試験［一般常識］</p>\n</td>\n</tr>\n<tr>\n<th>エントリー方法</th>\n<td>ハローワークを通じてお申込み下さい</td>\n</tr>\n<tr>\n<th>備考</th>\n<td>経験者、有資格者を優遇します ※資格：工事担任者、電気工事士、陸上特殊無線技士等</td>\n</tr>\n</tbody>\n</table>\n                              </div>\n            </div>\n            <!--recBox-->\n\n            <div class=\"recBTN_box w90 max1000 centerBox\">\n              <p class=\"contactBTN\"><a href=\"/contact/\"><span class=\"inr\">お問い合わせはこちらから</span></a></p>\n              <p class=\"telBTN\"><a href=\"tel:0227947112\"><span class=\"inr\"><span class=\"fa-stack fa-lg\"><i class=\"fa fa-circle fa-stack-2x\"></i><i class=\"fa fa-phone fa-stack-1x fa-inverse\"></i> </span> 022-794-7112</span></a></p>\n            </div>\n            <!--recBTN_box-->\n\n          </div>\n\n\n          <div class=\"ancParent\">\n            <i class=\"ancPoint\" id=\"career\"></i>\n            <div class=\"recBox w90 max1000 centerBox ckBox\">\n              <div class=\"simpleTBL baseTBL\">\n                                  <table>\n                    <thead>\n                    <tr>\n                      <th colspan=\"2\">キャリア採用情報</th>\n                    </tr>\n                    </thead>\n                    <tbody>\n                    <tr>\n                      <th>募集状況</th>\n                      <td>現在募集していません。</td>\n                    </tr>\n                    </tbody>\n                  </table>\n                              </div>\n            </div>\n            <!--recBox-->\n\n            <div class=\"recBTN_box w90 max1000 centerBox\">\n              <p class=\"contactBTN\"><a href=\"/contact/\"><span class=\"inr\">お問い合わせはこちらから</span></a></p>\n              <p class=\"telBTN\"><a href=\"tel:0227947112\"><span class=\"inr\"><span class=\"fa-stack fa-lg\"><i class=\"fa fa-circle fa-stack-2x\"></i><i class=\"fa fa-phone fa-stack-1x fa-inverse\"></i> </span> 022-794-7112</span></a></p>\n            </div>\n            <!--recBTN_box-->\n\n          </div>\n\n\n        </div>\n        <!--recWrap-->\n\n\n      </article>\n      <!--article-->\n\n    </section>\n    <!--section-->\n  </main>\n</div>\n<!--contents-->\n\n\n<div id=\"footer-container-toubu\"></div>\n\n<div id=\"scrollTopBtn\"></div>\n<!-- ▲▲ footer ▲▲ -->\n\n<script type=\"module\" src=\"/statichtml/asset/js/group-toubu.js\"></script>\n</body>\n\n</html>\n","finalUrl":"https://www.ttk-g.co.jp/group/toubu/recruit/","rendered":false,"_cachedAt":"2026-06-23T23:32:27.694Z"}