{"url":"https://www.kinon.co.jp/recruit/interview-02.shtml","html":"<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\">\n<meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width\" />\n<meta name=\"format-detection\" content=\"telephone=no\">\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/common.css\" />\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/zone.css\" />\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/bpts.css\" />\n<!-- Basic parts -->\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/unit.css\" />\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/col.css\" />\n<!-- 本文領域レイアウタ -->\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/other.css\" />\n<!-- インタビュー用CSS -->\n<link rel=\"stylesheet\" type=\"text/css\" href=\"css/interview.css\" />\n<title>保守・サポート│社員の声│Recruit│キノンビクス株式会社</title>\n<style>\n.interview_fv {\n\tbackground-image: url(\"image/interview-02-00.jpg\");\n\tcolor: #fff;\n}\n#zone_substage h1 {\n\tfont-size: clamp(2.563rem, 0.767rem + 8.98vw, 7.5rem);\n\theight: auto;\n\tdisplay: block;\n\tpadding: 0;\n\tline-height: 1.5;\n\tfont-weight: normal;\n\tmargin: 1em 0 0 .5em;\n}\n@media screen and (max-width : 768px) {\n.interview_fv {\n\tbackground-position: center right;\n}\n</style>\n<!-- スクリプトのインクルード（事前呼び出し） --> \n<meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\" />\n<link rel=\"icon\" href=\"../favicon.ico\">\n\n<!-- fontawesome -->\n<link href=\"https://use.fontawesome.com/releases/v5.6.1/css/all.css\" rel=\"stylesheet\">\n\n\n</head>\n<body>\n<div id=\"zone_sheet\"> \n  <!-- ヘッダーのインクルード --> \n  <meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\" />\n<!--\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/css/other.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/css/bpts.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/css/common.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/css/zone.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/css/unit.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/css/col.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/css/other.css\"/>\n -->\n<div class=\"header_bg\">\n<div class=\"header_logo\"><a href=\"../../\"><img src=\"../image/common/logo.svg\"></a></div>\n<nav class=\"pc_menu\">\n  <div class=\"o_mainmenu\">\n    <ul>\n      <li><a href=\"../about/\">About us</a>\n        <ul>\n          <li><a href=\"/about/index.shtml\">代表挨拶</a></li>\n          <li><a href=\"/about/overview.shtml\">会社概要</a></li>\n          <li><a href=\"/about/philosophy.shtml\">経営理念</a></li>\n          <li><a href=\"/about/promises.shtml\">7つのお約束</a></li>\n          <li><a href=\"/about/history.shtml\">沿革</a></li>\n          <li><a href=\"/about/employee.shtml\">社員保有資格一覧</a></li>\n          <li><a href=\"/about/certifications.shtml\">各種認定と宣言</a></li>\n        </ul>\n      </li>\n      <li><a href=\"../culture/\">Culture</a></li>\n      <li><a href=\"../solution/\">Solution</a>\n        <ul>\n          <li><a href=\"../solution/index.shtml#jump_01\">システムソリューション</a></li>\n          <li><a href=\"../solution/index.shtml#s_index_section02\">場所から探す</a></a></li>\n          <li><a href=\"../solution/index.shtml#s_index_section03\">納入事例</a></a></li>\n        </ul>\n      </li>\n      <li><a href=\"../recruit/\">Recruit</a>\n        <ul>\n          <li><a href=\"/recruit/\">採用情報</a></li>\n          <li><a href=\"/recruit/job.shtml\">職種紹介</a></li>\n          <li><a href=\"/recruit/interview.shtml\">社員インタビュー</a></li>\n          <li><a href=\"/recruit/requirements.shtml\">募集要項</a></li>\n        </ul>\n      </li>\n      <li><a href=\"../misc/contact.shtml\">Contact</a></li>\n    </ul>\n  </div>\n</nav>\n</div>\n<!-- レスポンシブメニュー　 -->\n<header>\n<div class=\"header-logo-menu\">\n<div id=\"nav-drawer\">\n<input id=\"nav-input\" type=\"checkbox\" class=\"nav-unshown\">\n<label id=\"nav-open\" for=\"nav-input\">\n<span></span>\n<p class=\"label_txt_menu\">MENU</p>\n</label>\n<label class=\"nav-unshown\" id=\"nav-close\" for=\"nav-input\"></label>\n<div id=\"nav-content\">\n<!--  ----------------- -->\n<div class=\"accordion\"> \n  <!-- menu1 -->\n  <div class=\"option\">\n    <input type=\"checkbox\" id=\"toggle1\" class=\"toggle\">\n    <label class=\"title item10\" for=\"toggle1\">About us</label>\n    <div class=\"content\">\n      <ul>\n        <li class=\"f_m10_10\"><a href=\"/about/index.shtml\">代表挨拶</a></li>\n        <li class=\"f_m10_20\"><a href=\"/about/overview.shtml\">会社概要</a></li>\n        <li class=\"f_m10_30\"><a href=\"/about/philosophy.shtml\">経営理念</a></li>\n        <li class=\"f_m10_40\"><a href=\"/about/promises.shtml\">7つのお約束</a></li>\n        <li class=\"f_m10_50\"><a href=\"/about/history.shtml\">沿革</a></li>\n        <li class=\"f_m10_60\"><a href=\"/about/employee.shtml\">社員保有資格一覧</a></li>\n        <li class=\"f_m10_70\"><a href=\"/about/certifications.shtml\">各種認定と宣言</a></li>\n      </ul>\n    </div>\n  </div>\n  <!-- menu2 -->\n  <div class=\"option\">\n    <div class=\"one_link\"><a href=\"../culture/\">Culture</a></div>\n  </div>\n  <!-- menu3 -->\n  <div class=\"option\">\n    <input type=\"checkbox\" id=\"toggle3\" class=\"toggle\">\n    <label class=\"title item50\" for=\"toggle3\">Solution</label>\n    <div class=\"content\">\n      <ul>\n        <li class=\"f_m30_10\"><a href=\"../solution/index.shtml#sp_jump_01\">システムソリューション</a></li>\n        <li class=\"f_m30_20\"><a href=\"../solution/index.shtml#jump_15\">場所から探す</a></a></li>\n        <li class=\"f_m30_30\"><a href=\"../solution/index.shtml#jump_02\">納入事例</a></a></li>\n      </ul>\n    </div>\n  </div>\n  <!-- menu4 -->\n  <div class=\"option\">\n    <input type=\"checkbox\" id=\"toggle4\" class=\"toggle\">\n    <label class=\"title item60\" for=\"toggle4\">Recruit</label>\n    <div class=\"content\">\n      <ul>\n        <li class=\"f_m40_10\"><a href=\"/recruit/\">採用情報</a></li>\n        <li class=\"f_m40_20\"><a href=\"/recruit/job.shtml\">職種紹介</a></li>\n        <li class=\"f_m40_30\"><a href=\"/recruit/interview.shtml\">社員インタビュー</a></li>\n        <li class=\"f_m40_40\"><a href=\"/recruit/requirements.shtml\">募集要項</a></li>\n      </ul>\n    </div>\n  </div>\n  <!-- menu5 -->\n  <div class=\"option\">\n    <div class=\"one_link\"><a href=\"../misc/contact.shtml\">Contact</a></div>\n  </div>\n<!-- menu6 -->\n  <div class=\"option\">\n    <div class=\"one_link\"><a href=\"../\">Home</a></div>\n  </div>\n</div alt=\"eod:accordion\">\n</header>\n<!-- --------------------------------------------------- --> \n\n \n  <!-- ヘッダーのインクルード 終わり　--> \n  \n  <!-- ステージ-->\n  <div id=\"zone_substage\">\n    <div>\n      <h1>Interview</h1>\n    </div>\n    <!--- パンくず -->\n    <ol class=\"zone_pankuzu\">\n      <li><a href=\"../\">HOME</a></li>\n      <li><a href=\"/recruit/\">Recruit</a></li>\n      <li><a href=\"/recruit/interview.shtml\">社員の声</a></li>\n      <li>保守・サポート</li>\n    </ol>\n    <!-- パンくず --> \n  </div alt=\"eod:zone_substage\">\n  <!-- ステージ　終わり --> \n  <!-- 第2層 -->\n  <div id=\"zone_middle_floor\"> \n    <!--　ボディ領域　-->\n    <div id=\"zone_body\"> \n      <!--　メインエリア　-->\n      <div id=\"zone_mainarea_1col\">\n        <div class=\"sp_padding\"> \n          \n          <!--　▼▼▼　本文領域　▼▼▼　-->\n          <div class=\"col_textarea_full\">\n            <div class=\"interview_fv\">\n              <div class=\"interview_fv-box\">\n                <h2>「“この先もずっと続けられる仕事を。”<br>\n                  夢を追いかけた先に見つけた、\n                  新しい働き方のかたち。」</h2>\n                <p>京都支店　保守・サポート<span class=\"bpts_br\"></span>（京都サービスチーム）<br>\n                  20代　在職歴：半年</p>\n              </div>\n            </div>\n            <section id=\"interview_section01\">\n              <div class=\"l_overview_box\">\n                <p>もともと音楽業界で働くのが小学生時代からの夢で、音楽関係の専門学校を卒業後、音楽業界でイベントに携わる仕事をしていました。当時は月の半分以上を1人で日本各地を飛び回っていたのですが、チームプレイが出来る仕事ではなかったので、次第に「誰を目標にして、誰みたいになって仕事をしたらいいのだろう」とか、どういう働き方が正しいのかを自分で探して働くのが難しいと感じていました。今後のライフステージを考えると、このままの働き方をいつまで続けられるのか、という不安や孤独感もあって…誰かと一緒に腰を据えて仕事をしたいと思うようになりました。</p>\n                <p>そんな時にキノンビクス株式会社を知り、福利厚生が充実していることや、チーム全体で協力しあって仕事が出来るところに惹かれて入社しました。今は音楽にも関わる音響設備をはじめ、幅広い電子機器に触れる業務に携わりつつ、落ち着いた環境が得られています。前職で生かせなかった、専門学校時代に学んだことが現職で役立ったときには、過去の自分の学びも無駄ではなかったと実感しています。 </p>\n              </div>\n              \n              <!-- 大見出し -->\n              <h2 class=\"col_midashi_pagetop\" data-en=\"About the Job\"> <span>業務について</span> </h2 alt=\"eod:col_midashi_pagetop\">\n              <ul>\n                <li>\n                  <h3><span><img src=\"image/no-01.svg\"></span>どのような業務を担当していますか？</h3>\n                  <p class=\"pad-left\">私が所属する京都サービスチームは、主に大学、中学・高校のAV機器、その他自治体の議場システム等の保守点検・障害対応や入学式、卒業式などのイベント補佐を行っています。私はまだ入社して1年未満なので、基本的には各プロジェクトチームの上司と一緒に業務にあたっています。毎日新しいことを学び、知識を吸収している日々です。これから徐々に独り立ちしていく事になりますが、正直なところ心配なことはたくさんあります（笑）。前職は異なる業種でしたし、入社した時は本当に知識も何もない状態でした。機械などは直接見て、触ってみないとわからないことが多いので、そういう場面に直面した時にどう対応していくかが最近の課題ですね。</p>\n                </li>\n                <li>\n                  <h3><span><img src=\"image/no-02.svg\"></span>未経験での入社にあたって、不安に感じていたことや実際の印象を教えてください</h3>\n                  <div class=\"bpts_flexbox_onoff justify flexbox\">\n                    <div>\n                      <p>入社前は「自分に何ができるのか分からない」と心配していました。でも、チームの直属の上司はもちろん、他チームの上司も含めて皆さん本当に人柄が良く、知識量や経験の差を前提に1から指導してくださり、優しく接してくださいます。何かあったら助けてくれる上司がいてくださるので、今は安心感が大きいです。</p>\n                      <p>同世代が少ないという事も入社時に聞いていて、実際に私が所属する京都支店には20代が5人程いますが、全体的に見ると少ないので馴染めるか心配でした。でも、年齢問わずすごく雰囲気が良いので、最初に持っていた不安はすぐになくなりました。幅広い世代の方々がいらっしゃる分、様々な考え方や価値観を持っている方がいることを念頭におき、コミュニケーションを取るときには相手の意見を尊重しつつ自分の意見も伝えるように心がけています。 </p>\n                    </div>\n                    <img src=\"image/interview-02-04.jpg\" alt=\"\"> </div>\n                </li>\n                <li>\n                  <div class=\"bpts_flexbox_onoff justify flexbox rev\">\n                    <div class=\"wrap\">\n                      <h3><span><img src=\"image/no-03.svg\"></span>やりがいを感じる瞬間や、嬉しかったことはありますか？</h3>\n                      <p>京都支店は大学のお客様が多く、AV機器も多数取り扱われています。「調子がおかしくなったが何が原因かわからない」と連絡をいただく事が多いのですが、その機器の障害対応をして無事に直したあと、喜んでいただけて安心したお顔を見ると私も嬉しくなります。サービスチームとして、自分ができることやこのチームでしか学べないことをもっと知りたい、基礎から深く学びたい、という活力に繋がっています。 </p>\n                    </div>\n                    <img src=\"image/interview-02-01.jpg\" alt=\"\" style=\"margin-top: 5%;\"> </div>\n                </li>\n              </ul>\n              \n              <!-- 大見出し -->\n              <h2 class=\"col_midashi_pagetop\" data-en=\"About KINONVICS\"> <span>キノンビクスについて</span> </h2 alt=\"eod:col_midashi_pagetop\">\n              <ul>\n                <li>\n                  <h3><span><img src=\"image/no-01.svg\"></span>福利厚生・社内制度について教えてください</h3>\n                  <p class=\"pad-left\">同時期に入社した方が多く、私を含めて未経験者や20代の方も何人かいらっしゃいました。知識が充実していない私たちのために、社歴の長い上司が未経験者向け基礎知識のセミナーも行ってくださっています。繁忙期を除いて1カ月に1回ほど開催されていて、このようなサポートもとてもありがたく感じています。</p>\n                  <p class=\"pad-left\">毎年、社員旅行が実施されていますが、私はまだ開催時期がかぶっていないので参加したことはありません。社内イベントの際には基本的に滋賀本社・京都支店の社員が集まるのですが、忘年会や慰労会に参加したときには、社員同士の交流を深める良い機会となりました。</p>\n                  <p class=\"pad-left\">福利厚生の一環としては、各種保険制度や様々な休暇制度も充実していますし、ライフステージに合わせた働き方ができる環境が整っています。社員のことを大切に考えてくださっているな、と実感することがとても多いです。 </p>\n                </li>\n                <li>\n                  <h3><span><img src=\"image/no-02.svg\"></span>働く中で、会社の制度や雰囲気に安心感を持てた場面はありますか？</h3>\n                  <div class=\"bpts_flexbox_onoff justify flexbox\" style=\"align-items: flex-start;\">\n                    <div>\n                      <p>社員数が多いと、一人一人適切に評価されないのではないかと思っていました。でも意外とそうではなくて、上司の方々も社員が各々取り組んでいる業務や個人の様子もしっかり見てくださっていると感じます。フォロー体制もしっかりしていて、面談の機会もありますし、会社全体でも月に1度定例ミーティングや会議があります。業務の相談も日常的にできますし、入社年数に関わらずどんどん提案もできる環境です。</p>\n                      <div class=\"right\"><img src=\"image/interview-02-05.jpg\" alt=\"\" class=\"in02_mini_img\"> </div>\n                    </div>\n                    <img src=\"image/interview-02-02.jpg\" alt=\"\" style=\"margin-top: 0;\"> </div>\n                </li>\n              </ul>\n              \n              <!-- 大見出し -->\n              <h2 class=\"col_midashi_pagetop\" data-en=\"Message\"> <span>入社・応募を考えている方へのメッセージ</span> </h2 alt=\"eod:col_midashi_pagetop\">\n              <ul>\n                <li>\n                  <div class=\"bpts_flexbox_onoff justify flexbox rev\">\n                    <div class=\"wrap\">\n                      <p>当社を検索した際に、男性社員が多く働いている印象を持たれてエントリーを悩む女性の方もいらっしゃるかもしれません。実は私もそう思っていましたが、実際には女性社員もおられるし、同世代の方も徐々に増えています。また、事業や業務が難しそうに見えるかもしれませんが、なんでも聞いて相談できる環境が整っているので未経験の方も安心してほしいです。私もまったくの未経験からスタートしましたが、上司に支えられながら毎日働くことができています。 </p>\n                      <p>それに、同期のように何でも相談し合える仲間が増えてくれたらもっと働きやすくなるかな、と思っています。もし悩んでいるなら、ぜひ一緒に飛び込んでみましょう！ </p>\n                    </div>\n                    <img src=\"image/interview-02-03.jpg\" alt=\"\" style=\"margin-top: 0;\"> </div>\n                </li>\n              </ul>\n            </section>\n            <section id=\"interview_section02\">\n              <h2>1日のスケジュール</h2>\n              <ul>\n                <li>\n                  <h3>8：30</h3>\n                  <div class=\"txt\">\n                    <p>出社　業務開始<br>\n                      メールチェックや、その日の障害対応訪問先についてチーム内で情報共有</p>\n                  </div>\n                </li>\n                <li>\n                  <h3>9:00</h3>\n                  <div class=\"txt\">\n                    <p>外出<br>\n                      外出予定がない日や時間帯は社内で業務を行っています<br>\n                      繁忙期は基本的に一日中社外で点検</p>\n                  </div>\n                </li>\n                <li>\n                  <h3>12:00</h3>\n                  <div class=\"txt\">\n                    <p>昼食</p>\n                  </div>\n                </li>\n                <li>\n                  <h3>16:00</h3>\n                  <div class=\"txt\">\n                    <p>帰社<br>\n                      事務処理、明日以降の訪問準備など</p>\n                  </div>\n                </li>\n                <li>\n                  <h3>17:30</h3>\n                  <div class=\"txt\">\n                    <p>退勤</p>\n                  </div>\n                </li>\n              </ul>\n            </section>\n            <section id=\"interview_section03\">\n              <h2>その他INTERVIEW</h2>\n              <ul class=\"l_grid_interview_list\">\n                <!--  -->\n                <li class=\"eigyo\"> <a href=\"interview-01.shtml\">\n                  <div>\n                    <p>京都支店　営業<span class=\"pre\">（教育ソリューションチーム）</span></p>\n                    <h5>本当に納得できる選択をしていただくために、伝えるべきことを、誠実に伝える。</h5>\n                    <span>30代 在職歴：8年</span> </div>\n                  </a> </li>\n                <!--  -->\n                <li class=\"se\"> <a href=\"interview-03.shtml\">\n                  <div>\n                    <p>本社　システムエンジニア<span class=\"pre\">（システムデザインチーム）</span></p>\n                    <h5>向いている、向いていないよりも、まずはやってみる。<em class=\"bpts_br_pc\"></em>迷いながらの一歩が自分を変えました。</h5>\n                    <span>40代　在職歴：2年半</span> </div>\n                  </a> </li>\n                <!--  -->\n                <li class=\"engineer\"> <a href=\"interview-04.shtml\">\n                  <div>\n                    <p>本社　施工管理<span class=\"pre\">（滋賀システム技術チーム）</span></p>\n                    <h5>現場ごとに違う景色が、今の自分にちょうどいい。</h5>\n                    <span>30代　在職歴：1年</span> </div>\n                  </a> </li>\n              </ul>\n            </section>\n          </div alt=\"col_textarea_full\">\n          <!--　▲▲▲　本文領域　終わり　▲▲▲　--> \n        </div>\n        <!-- eod:sp_padding --> \n      </div alt=\"eod:zone_mainarea\">\n      <!--　メインエリア　終わり　--> \n    </div alt=\"eod:zone_body\">\n    <!--　ボディ領域　終わり　--> \n  </div alt=\"eod:zone_middle\">\n  <!--　第2層　終わり　--> \n  <!-- リクルート用　お問い合わせフッターのインクルード --> \n  <meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\" />\n<meta name=\"format-detection\" content=\"telephone=no\">\n<!-- \n<link rel=\"stylesheet\" type=\"text/css