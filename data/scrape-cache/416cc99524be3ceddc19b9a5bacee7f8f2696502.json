tn\"></div> \n          </nav> \n         </div> \n        </div> \n        <div id=\"bk2984\" class=\"b-both_diff -right_large -sp-single_column c-space_narrow c-sp-space_normal c-sp-padding_normal is-sp-hide bd-webp -dress_b14006Navi cssskin-_block_header init-block_animation init-sp-block_animation\" data-bk-id=\"bk2984\" data-shared=\"true\" data-sharedname=\"_グローバルナビ2\" data-animated=\"fadeIn\" data-sp-animated=\"fadeIn\"> \n         <div class=\" g-column\"> \n          <div class=\" column -col4 -col_sub\"> \n           <h1 class=\" c-page_title\"> \n            <div class=\"c-img   \"> \n             <picture> \n              <source type=\"image/webp\" srcset=\"_src/2239/img20150831145800040553.webp?v=1769645477911\"> \n              <img src=\"_src/2239/img20150831145800040553.png?v=1769645477911\" width=\"380\" height=\"100\" alt=\"株式会社マルイ_2025年新卒採用情報\" id=\"imgsrc2239_1\" class=\" c-no_adjust\" loading=\"lazy\"> \n             </picture> \n            </div></h1> \n          </div> \n          <div class=\" column -col8 -col_main\"> \n           <nav> \n            <div class=\" js-motion\"> \n             <ul class=\"m-motion menu-parts -f\"> \n              <li><a href=\"./\" data-pid=\"175\">ホーム</a></li> \n              <li><a href=\"message.html\" data-pid=\"176\">メッセージ</a></li> \n              <li><span class=\" c-unlink\">チームで取り組む</span> \n               <ul> \n                <li><a href=\"fisheries/session1.html\" data-pid=\"180\">マルイが挑むプロジェクト</a></li> \n                <li><a href=\"deli/session2.html\" data-pid=\"183\">新人社員の教育現場</a></li> \n                <li><a href=\"colleague/session3.html\" data-pid=\"189\">新人社員の研修</a></li> \n               </ul></li> \n              <li><a href=\"characteristic.html\" data-pid=\"177\">スーパーマルイの特徴</a></li> \n              <li class=\" c-current\"><a href=\"career_plan.html\" data-mypid=\"178\">キャリアプラン</a></li> \n              <li><a href=\"entry.html\" data-pid=\"179\" class=\"entry\">エントリー</a></li> \n             </ul> \n            </div> \n           </nav> \n          </div> \n         </div> \n        </div> \n       </section> \n      </div> \n     </header> \n    </div> \n    <div id=\"a-billboard\" class=\"a-billboard    cssskin-_area_billboard\"> \n     <div class=\"site_frame\"> \n      <section> \n      </section> \n     </div> \n    </div> \n    <main> \n     <div id=\"a-site_contents\" class=\"a-site_contents  noskin\"> \n      <article> \n       <div class=\"site_frame\"> \n        <div class=\"g-column\"> \n         <div id=\"a-main\" class=\"a-main column -col12 \"> \n          <section> \n           <div id=\"bk2986\" class=\"b-plain c-space_normal c-sp-space_normal c-padding_wide bd-webp -dress_b14006Main1 cssskin-_block_main init-block_animation init-sp-block_animation\" data-bk-id=\"bk2986\" data-animated=\"fadeIn\" data-sp-animated=\"fadeIn\"> \n            <div class=\" column -column1\"> \n             <p class=\"c-lead\">キャリアプラン</p> \n             <h2 class=\"none c-title c-center\">社会人一年目に挑む</h2> \n             <h4 class=\"none c-small_headline c-center\">新人社員の教育・研修・キャリアプラン</h4> \n            </div> \n           </div> \n           <div id=\"bk2999\" class=\"b-plain c-space_normal c-sp-space_wide bd-webp -dress_00bca8d34607437494a664ba54041520 cssskin-_block_main init-block_animation init-sp-block_animation\" data-bk-id=\"bk2999\" data-animated=\"fadeInUp\" data-sp-animated=\"fadeInUp\"> \n            <div class=\" g-column -col3 -sp-col1\"> \n             <div class=\" column -column1\"> \n              <div class=\"c-lead c-left\"> \n               <span style=\"color:#f07217;\"></span>4月 \n              </div> \n              <h2 class=\"lead c-title c-center\">本部研修</h2> \n              <div class=\"c-none c-center\">\n                &nbsp; \n              </div> \n              <div class=\"c-none c-center\"> \n               <div class=\"c-img   \"> \n                <picture> \n                 <source type=\"image/webp\" srcset=\"_src/2454/img20220119154624477373.webp?v=1769645477911\"> \n                 <img src=\"_src/2454/img20220119154624477373.jpg?v=1769645477911\" width=\"3557\" height=\"3557\" alt=\"本部研修\" id=\"imgsrc2454_1\" class=\" c-no_adjust\" loading=\"lazy\"> \n                </picture> \n               </div> \n              </div> \n              <h4 class=\"lead c-small_headline\">入社式を経ていよいよ社会人デビュー！！</h4> \n              <p class=\" c-body\">約１ヵ月間の<span class=\" d-bold\">本部研修</span>では、スーパーマーケットで働く基礎知識の習得はもちろん、社会人としての「働く」心構えやコンプライアンスなどもしっかり学びます。<br>また、お客様に快適にお買い物を楽しんでいただくため、接客訓練や品出し実習、コトＰＯＰやサンプルを作成する研修などもあります。<br>新入社員同士、お互いに意見を出し合いながら「販売」職の一歩目を力強く踏み出してください。</p> \n              <div class=\"c-none\"> \n               <span></span> \n              </div> \n             </div> \n             <div class=\" column -column2\"> \n              <div class=\"c-lead c-left\"> \n               <span class=\" d-bold\">５月～７月頃</span> \n              </div> \n              <h2 class=\"lead c-title c-center\"><span class=\" c-left\">部門実習</span></h2> \n              <div class=\"c-none c-center\">\n                &nbsp; \n              </div> \n              <div class=\"c-none c-center\"> \n               <div class=\"c-img   \"> \n                <picture> \n                 <source type=\"image/webp\" srcset=\"_src/2268/img20220119154250829797.webp?v=1769645477911\"> \n                 <img src=\"_src/2268/img20220119154250829797.jpg?v=1769645477911\" width=\"1944\" height=\"1944\" alt=\"部門研修\" id=\"imgsrc2268_1\" class=\" c-no_adjust\" loading=\"lazy\"> \n                </picture> \n               </div> \n              </div> \n              <h4 class=\" c-small_headline\">本格的な店舗デビューがスタート！！</h4> \n              <p class=\" c-body\">スーパーマーケットの基礎知識を本部研修で習得した後、本格的な店舗デビューとなる<span class=\" d-bold\">部門実習</span>が始まります。<br>例年４月末～５月初めにスタートする部門実習は、希望する部門＋もう１部門にチャレンジし、部門の基礎的な作業にチャレンジしてもらいます。<br>その実習の中で、部門の求めるものと皆さんの性格や能力がマッチングするか検討し、最終的には会社側が部門を決定します。<br>ただし、皆さんと相談なしに決めるわけではありませんので、ご安心ください。<br>やってみると意外な楽しさ、面白さも発見できますよ！！</p> \n             </div> \n             <div class=\" column -column3 -column-lasts\"> \n              <div class=\"c-lead c-left\"> \n               <span class=\" d-bold\">7月頃</span> \n              </div> \n              <h2 class=\"lead c-title c-center\"><span class=\" c-left\">正式配属</span></h2> \n              <div class=\"c-none c-center\">\n                &nbsp; \n              </div> \n              <div class=\"c-none c-center\"> \n               <div class=\"c-img   \"> \n                <picture> \n                 <source type=\"image/webp\" srcset=\"_src/2266/b14_006_1_07.webp?v=1769645477911\"> \n                 <img src=\"_src/2266/b14_006_1_07.jpg?v=1769645477911\" width=\"1000\" height=\"1000\" alt=\"正式配属\" id=\"imgsrc2266_1\" class=\" c-no_adjust\" loading=\"lazy\"> \n                </picture> \n               </div> \n              </div> \n              <h4 class=\"lead c-small_headline\">ついに正式配属！！</h4> \n              <p class=\" c-body\">約３か月の部門実習を経て、<span class=\" d-bold\">正式配属</span>になります。以降は、当社ではよほどのことがない限り、部門の変更をしません。<br>なぜなら、皆さんに部門の１年の流れ、商品の移り変わり、売れ行きの変化を学んでいただきたいからです。<br>部門の専門的な知識、技術を習得し、ぜひ入社３～５年目には部門リーダーである「<span class=\" d-bold\">チーフ職</span>」を目指してください。</p> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk3000\" class=\"b-plain c-space_normal c-sp-space_wide is-pc-hide bd-webp -dress_00bca8d34607437494a664ba54041520 cssskin-_block_main init-block_animation init-sp-block_animation\" data-bk-id=\"bk3000\" data-animated=\"fadeInUp\" data-sp-animated=\"fadeInUp\"> \n            <div class=\" column -column1\"> \n             <div class=\"c-lead c-left\">\n               毎月一回 \n             </div> \n             <h2 class=\"lead c-title\">フォローアップ研修</h2> \n             <h4 class=\" c-small_headline c-left\">１人１人のキャリアアップを常に支えます！！</h4> \n             <p class=\" c-body\">部門実習から、新入社員はそれぞれ違う店舗へ勤務することになるわけですが、お互いどこまで進んだか気になったり、心細くなったり・・・。<br>当社では、８月・１２月の繁忙期を除く毎月１回、本部に新人が集まって受ける「フォローアップ研修」があります。<br>ここでは、データ分析や利益、ロスの管理と言った計算の勉強をしたり、また先輩社員から仕事の進め方や技術的なアドバイスをもらったりします。</p> \n            </div> \n           </div> \n           <div id=\"bk3008\" class=\"b-plain c-space_normal c-sp-space_wide is-sp-hide bd-webp -dress_00bca8d34607437494a664ba54041520 cssskin-_block_main init-block_animation init-sp-block_animation\" data-bk-id=\"bk3008\" data-animated=\"fadeInUp\" data-sp-animated=\"fadeInUp\"> \n            <div class=\" column -column1\"> \n             <p class=\"c-lead\">毎月一回</p> \n             <h2 class=\"lead c-title\">フォローアップ研修</h2> \n             <h4 class=\" c-small_headline c-left\">１人１人のキャリアアップを常に支えます！！</h4> \n             <p class=\" c-body\">部門実習から、新入社員はそれぞれ違う店舗へ勤務することになるわけですが、お互いどこまで進んだか気になったり、心細くなったり・・・。<br>当社では、８月・１２月の繁忙期を除く毎月１回、本部に新人が集まって受ける「<span class=\" d-bold\">フォローアップ研修</span>」があります。<br>ここでは、データ分析や利益、ロスの管理と言った計算の勉強をしたり、また先輩社員から仕事の進め方や技術的なアドバイスをもらったりします。</p> \n            </div> \n           </div> \n           <div id=\"bk3001\" class=\"b-plain c-space_normal c-sp-space_normal bd-webp -dress_b14006Main1 cssskin-_block_main init-block_animation init-sp-block_animation\" data-bk-id=\"bk3001\" data-animated=\"fadeInUp\" data-sp-animated=\"fadeInUp\"> \n            <div class=\" column -column1\"> \n             <div class=\"c-lead c-left\">\n               能力育成・強化研修 \n             </div> \n             <h2 class=\"none c-title\"><span>次のステップアップも継続</span><span>支援</span></h2> \n            </div> \n           </div> \n           <div id=\"bk3002\" class=\"b-both_diff -left_large -sp-single_column c-space_narrow c-sp-space_normal c-sp-padding_normal is-pc-hide bd-webp -dress_b14006Main1 cssskin-_block_main init-block_animation init-sp-block_animation\" data-bk-id=\"bk3002\" data-animated=\"fadeInUp\" data-sp-animated=\"fadeInUp\"> \n            <div class=\" g-column\"> \n             <div class=\" column -col8 -col_main\"> \n              <div class=\" c-body c-center\"> \n               <div> \n                <div class=\"c-img   \"> \n                 <picture> \n                  <source type=\"image/webp\" srcset=\"_src/2284/b14_006_1_04.webp?v=1769645477911\"> \n                  <img src=\"_src/2284/b14_006_1_04.jpg?v=1769645477911\" width=\"1000\" height=\"1000\" alt=\"キャリアアップ\" id=\"imgsrc2284_1\" class=\" c-no_adjust\" loading=\"lazy\"> \n                 </picture> \n                </div> \n               </div> \n              </div> \n             </div> \n             <div class=\" column -col4 -col_sub\"> \n              <p class=\" c-body\"><span>階層別</span><span>に様々な研修を設けることで、次のステップアップも継続して支援を致します。</span><br><span>役職ごとに求められる責任やその重さに違いはあるかもしれませんが、大切なのは全員が同じ方向を見て、一つの目標に向かっていること。</span><span>&nbsp;</span><span>そのためにも協調性を持ち、<span class=\" d-bold\">意見を集約しながら最後に決断できるリーダーシップを発揮できる人材の育成</span>を常に目指しています。</span><br><span>また、社外より講師を招待して行う社内講演会では、仕事に挑む上での姿勢や夢へのチャレンジを学んでいます。</span><span>&nbsp;</span><br><span>区分に関係なく多くの従業員が参加し、日々の仕事のモチベーションを向上させる貴重な機会になっています。</span>&nbsp;</p> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk3009\" class=\"b-both_diff -left_large -sp-single_column c-space_narrow c-sp-space_normal c-sp-padding_normal is-sp-hide bd-webp -dress_b14006Main1 cssskin-_block_main init-block_animation init-sp-block_animation\" data-bk-id=\"bk3009\" data-animated=\"fadeInUp\" data-sp-animated=\"fadeInUp\"> \n            <div class=\" g-column\"> \n             <div class=\" column -col8 -col_main\"> \n              <p class=\" c-body\"><span>階層別</span><span>に様々な研修を設けることで、次のステップアップも継続して支援を致します。</span><br><span>役職ごとに求められる責任やその重さに違いはあるかもしれませんが、大切なのは全員が同じ方向を見て、一つの目標に向かっていること。</span><span>&nbsp;</span><span>そのためにも協調性を持ち、<span class=\" d-bold\">意見を集約しながら最後に決断できるリーダーシップを発揮できる人材の育成</span>を常に目指しています。</span><br><span>また、社外より講師を招待して行う社内講演会では、仕事に挑む上での姿勢や夢へのチャレンジを学んでいます。</span><span>&nbsp;</span><br><span>区分に関係なく多くの従業員が参加し、日々の仕事のモチベーションを向上させる貴重な機会になっています。</span></p> \n             </div> \n             <div class=\" column -col4 -col_sub\"> \n              <div class=\"c-none c-center\"> \n               <div class=\"c-img   \"> \n                <picture> \n                 <source type=\"image/webp\" srcset=\"_src/2282/b14_006_1_04.webp?v=1769645477911\"> \n                 <img src=\"_src/2282/b14_006_1_04.jpg?v=1769645477911\" width=\"1000\" height=\"1000\" alt=\"キャリアアップ\" id=\"imgsrc2282_1\" class=\" c-no_adjust\" loading=\"lazy\"> \n                </picture> \n               </div> \n              </div> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk3006\" class=\"b-plain c-space_narrow c-sp-space_normal cssskin-_block_main init-block_animation init-sp-block_animation\" data-bk-id=\"bk3006\" data-animated=\"fadeInUp\" data-sp-animated=\"fadeInUp\"> \n            <div class=\" column -column1\"> \n             <div class=\" c-body c-center\"> \n              <div class=\"c-img   \"> \n               <picture> \n                <source type=\"image/webp\" srcset=\"_src/2270/img20211004121540093925.webp?v=1769645477911\"> \n                <img src=\"_src/2270/img20211004121540093925.jpg?v=1769645477911\" width=\"2072\" height=\"1032\" alt=\"教育・研修制度\" id=\"imgsrc2270_1\" loading=\"lazy\"> \n               </picture> \n              </div> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk3005\" class=\"b-plain c-space_normal c-sp-space_normal c-sp-padding_normal is-pc-hide bd-webp -dress_00bca8d34607437494a664ba54041520 cssskin-_block_main init-block_animation init-sp-block_animation\" data-bk-id=\"bk3005\" data-animated=\"fadeInUp\" data-sp-animated=\"fadeInUp\"> \n            <div class=\" column -column1\"> \n             <div class=\"c-lead c-left\">\n               頑張った人に報いるが信条。 \n              <br>一人一人の成長を全力バックアップ。 \n             </div> \n             <h2 class=\"none c-title c-left\">&nbsp;人事考課制度</h2> \n             <p class=\" c-body\"><span style=\"color:#f0eee7;\" data-sitecolor-text=\"\">当社の経営方針である<span class=\" d-bold\">「人で勝てる」企業</span>を目指して、人事制度も「<span class=\" d-bold\">やった人に報いる</span>」ものとなっています。業績だけでなく、課題に取り組む姿勢や身だしなみ、エチケットなど多面的に評価する『人事考課』を用い、自信が設定した課題など目標を明確に取り組みます。</span><br><span style=\"color:#f0eee7;\">また年に１回上司と、今後のキャリアアップの目標について、コミュニケーションを取る機会もあります。</span><br><span style=\"color:#f0eee7;\">自分の”理想”の実現に向け、積極的に取り組む人を応援します！！</span></p> \n            </div> \n           </div> \n           <div id=\"bk3011\" class=\"b-plain c-space_normal c-sp-space_normal c-sp-padding_normal is-sp-hide bd-webp -dress_00bca8d34607437494a664ba54041520 cssskin-_block_main init-block_animation init-sp-block_animation\" data-bk-id=\"bk3011\" data-animated=\"fadeInUp\" data-sp-animated=\"fadeInUp\"> \n            <div class=\" column -column1\"> \n             <div class=\"c-lead c-left\">\n               頑張った人に報いる人事は信条。 \n              <br>一人一人の成長を全力バックアップ。 \n             </div> \n             <h2 class=\"none c-title c-left\">&nbsp;人事考課制度</h2> \n             <p class=\" c-body\"><span style=\"color:#f0eee7;\" data-sitecolor-text=\"\">当社の経営方針である<span class=\" d-bold\">「人で勝てる」企業</span>を目指して、人事制度も「<span class=\" d-bold\">やった人に報いる</span>」ものとなっています。業績だけでなく、課題に取り組む姿勢や身だしなみ、エチケットなど多面的に評価する『人事考課』を用い、自信が設定した課題など目標を明確に取り組みます。</span><br><span style=\"color:#f0eee7;\">また年に１回上司と、今後のキャリアアップの目標について、コミュニケーションを取る機会もあります。</span><br><span style=\"color:#f0eee7;\">自分の”理想”の実現に向け、積極的に取り組む人を応援します！！</span></p> \n            </div> \n           </div> \n           <div id=\"bk3007\" class=\"b-plain c-space_normal c-sp-space_normal c-sp-padding_normal is-pc-hide bd-webp -dress_437d92af42264fd29ab2644238d99c53 cssskin-_block_main init-block_animation init-sp-block_animation\" data-bk-id=\"bk3007\" data-animated=\"fadeInUp\" data-sp-animated=\"fadeInUp\"> \n            <div class=\" column -column1\"> \n             <h3 class=\"lead c-large_headline c-left\">職掌等級制度</h3> \n             <h4 class=\"quote c-small_headline c-center\"> \n              <div class=\"c-img   \"> \n               <picture> \n                <source type=\"image/webp\" srcset=\"_src/2278/img20211004121542179010.webp?v=1769645477911\"> \n                <img src=\"_src/2278/img20211004121542179010.jpg?v=1769645477911\" width=\"2000\" height=\"1036\" alt=\"人事考課制度\" id=\"imgsrc2278_1\" class=\" c-no_adjust\" loading=\"lazy\"> \n               </picture> \n              </div></h4> \n             <div class=\"c-none\">\n               &nbsp; \n             </div> \n             <div class=\"c-none\">\n               &nbsp; \n             </div> \n             <h3 class=\" c-large_headline\">店舗構成</h3> \n             <h4 class=\" c-small_headline c-center\"> \n              <div class=\"c-img   \"> \n               <picture> \n                <source type=\"image/webp\" srcset=\"_src/2280/bumon_20211221115218842.webp?v=1769645477911\"> \n                <img src=\"_src/2280/bumon_20211221115218842.png?v=1769645477911\" width=\"1920\" height=\"1080\" alt=\"部門構成\" id=\"imgsrc2280_1\" loading=\"lazy\"> \n               </picture> \n              </div></h4> \n            </div> \n           </div> \n           <div id=\"bk3010\" class=\"b-plain c-space_normal c-sp-space_normal c-sp-padding_normal is-sp-hide bd-webp -dress_437d92af42264fd29ab2644238d99c53 cssskin-_block_main init-block_animation init-sp-block_animation\" data-bk-id=\"bk3010\" data-animated=\"fadeInUp\" data-sp-animated=\"fadeInUp\"> \n            <div class=\" g-column -col2 -sp-col1\"> \n             <div class=\" column -column1\"> \n              <h3 class=\"lead c-large_headline c-left\">職掌等級制度</h3> \n              <h4 class=\"quote c-small_headline c-center\"> \n               <div class=\"c-img   \"> \n                <picture> \n                 <source type=\"image/webp\" srcset=\"_src/2286/img20211004121542179010.webp?v=1769645477911\"> \n                 <img src=\"_src/2286/img20211004121542179010.jpg?v=1769645477911\" width=\"2000\" height=\"1036\" alt=\"人事考課制度\" id=\"imgsrc2286_1\" class=\" c-no_adjust\" loading=\"lazy\"> \n                </picture> \n               </div></h4> \n             </div> \n             <div class=\" column -column2 -column-lasts\"> \n              <h3 class=\" c-large_headline\">店舗構成</h3> \n              <h4 class=\" c-small_headline c-center\"> \n               <div class=\"c-img   \"> \n                <picture> \n                 <source type=\"image/webp\" srcset=\"_src/2288/bumon_20211221115218842.webp?v=1769645477911\"> \n                 <img src=\"_src/2288/bumon_20211221115218842.png?v=1769645477911\" width=\"1920\" height=\"1080\" alt=\"部門構成\" id=\"imgsrc2288_1\" loading=\"lazy\"> \n                </picture> \n               </div></h4> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk3004\" class=\"b-plain c-space_normal c-sp-space_normal bd-webp -dress_b14006Main1 cssskin-_block_main init-block_animation init-sp-block_animation\" data-bk-id=\"bk3004\" data-animated=\"fadeInUp\" data-sp-animated=\"fadeInUp\"> \n            <div class=\" column -column1\"> \n             <div class=\"c-lead c-left\">\n               福利厚生 \n             </div> \n            </div> \n           </div> \n           <div id=\"bk3003\" class=\"b-plain c-space_normal c-sp-space_normal bd-webp -dress_b14006Main1 cssskin-_block_main init-block_animation init-sp-block_animation\" data-bk-id=\"bk3003\" data-animated=\"fadeInUp\" data-sp-animated=\"fadeInUp\"> \n            <div class=\" g-column -col3 -sp-col1\"> \n             <div class=\" column -column1\"> \n              <h3 class=\" c-large_headline c-center\">産休・育休制度</h3> \n              <h4 class=\" c-small_headline c-center\"> \n               <div class=\"c-img   \"> \n                <picture> \n                 <source type=\"image/webp\" srcset=\"_src/2272/pxt00006098269202.webp?v=1769645477911\"> \n                 <img src=\"_src/2272/pxt00006098269202.jpg?v=1769645477911\" width=\"1333\" height=\"1333\" alt=\"産休・育休制度\" id=\"imgsrc2272_1\" class=\" c-no_adjust\" loading=\"lazy\"> \n                </picture> \n               </div></h4> \n              <p class=\"c-lead\">産休・育休制度にも力を入れています。</p> \n              <p class=\" c-body\">スーパーなどの業界では産休や育休を取りにくい、復帰しにくいなどの話をよく聞くことがありますが、スーパーマルイでは社員のほか、パートさんも<span class=\" d-bold\">産休・育休１００％取得</span>されており、産休後に職場復帰し皆さん活躍しています。<br>男性の育休の取得ももちろん可能です。</p> \n              <div class=\"c-none\">\n                &nbsp; \n              </div> \n             </div> \n             <div class=\" column -column2\"> \n              <h3 class=\" c-large_headline c-center\">まかない食</h3> \n              <h4 class=\" c-small_headline c-center\"> \n               <div class=\"c-img   \"> \n                <picture> \n                 <source type=\"image/webp\" srcset=\"_src/2274/pxt00002589730803.webp?v=1769645477911\"> \n                 <img src=\"_src/2274/pxt00002589730803.jpg?v=1769645477911\" width=\"3000\" height=\"3000\" alt=\"まかない食\" id=\"imgsrc2274_1\" class=\" c-no_adjust\" loading=\"lazy\"> \n                </picture> \n               </div></h4> \n              <p class=\"c-lead\">スーパーで「<span class=\" d-bold\">まかない</span>」は、珍しいと良く言われます。</p> \n              <p class=\" c-body\">各店でまかない担当の方を採用し、お昼を用意してもらう<span>「<span class=\" d-bold\">まかない制度</span>」</span>があります。社員だけでなく、お昼を挟んで働くパートさんも、休憩室で用意してもらった食事をとることができます。<br>温かい食卓を囲んで、リラックスタイム！そして、仕事の大事な活力です！！</p> \n              <div class=\"c-none\">\n                &nbsp; \n              </div> \n             </div> \n             <div class=\" column -column3 -column-lasts\"> \n              <h3 class=\" c-large_headline c-center\"><span>企業内保育園</span></h3> \n              <h4 class=\" c-small_headline c-center\"> \n               <div class=\"c-img   \"> \n                <picture> \n                 <source type=\"image/webp\" srcset=\"_src/2276/smile.webp?v=1769645477911\"> \n                 <img src=\"_src/2276/smile.jpg?v=1769645477911\" width=\"900\" height=\"900\" alt=\"すまいる保育園\" id=\"imgsrc2276_1\" class=\" c-no_adjust\" loading=\"lazy\"> \n                </picture> \n               </div></h4> \n              <p class=\"c-lead\">0.5歳児～の未満児対応の企業主導型保育事業</p> \n              <p class=\" c-body\">当社には、従業員のお子さん（０.5～２歳児）を預けて働ける企業内保育園：&nbsp;<a href=\"http://smile-mitsuke.com/\">すまいるほいくえん</a>&nbsp;が見附市にあります。女性の活躍のステージの向上や、長く働ける環境づくりの一環として、企業として積極的な施策を講じています。<br>女性のキャリアアップと育児の両立を、企業としても応援していきます。</p> \n              <div class=\"c-none c-center\">\n                &nbsp; \n              </div> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk3278\" class=\"b-plain c-space_normal c-sp-space_normal is-pc-hide bd-webp -dress_b14006Main1 cssskin-_block_main init-block_animation init-sp-block_animation\" data-bk-id=\"bk3278\" data-animated=\"fadeInUp\" data-sp-animated=\"fadeInUp\"> \n            <div class=\" column -column1\"> \n             <p class=\"c-lead\"><span style=\"color:#383838;\">その他福利厚生</span></p> \n             <div class=\" c-body c-left\"> \n              <span class=\" d-bold\"><span style=\"color:#383838;\">・各種社会保険　・定期健康診断</span></span> \n             </div> \n             <div class=\" c-body c-left\"> \n              <span class=\" d-bold\"><span style=\"color:#383838;\">・成人病検診　・人間ドック</span></span> \n             </div> \n             <div class=\" c-body c-left\"> \n              <span class=\" d-bold\"><span style=\"color:#383838;\">・財形預金制度　・退職金共済</span></span> \n             </div> \n             <div class=\" c-body c-left\"> \n              <span class=\" d-bold\"><span style=\"color:#383838;\">・独身寮</span></span> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk3279\" class=\"b-plain c-space_normal c-sp-space_normal c-sp-padding_normal is-sp-hide bd-webp -dress_b14006Main1 cssskin-_block_main init-block_animation init-sp-block_animation\" data-bk-id=\"bk3279\" data-animated=\"fadeInUp\" data-sp-animated=\"fadeInUp\"> \n            <div class=\" column -column1\"> \n             <p class=\"c-lead\"><span style=\"color:#383838;\">その他福利厚生</span>