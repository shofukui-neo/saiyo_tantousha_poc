cript>\n<script src=\"https://www.yamako.co.jp/common/js/bootstrap.min.js\"></script>\n    \n    <script type=\"text/javascript\">\n\t$(function () {\n\t  $(window).on('scroll', function () {\n\t    if ($(this).scrollTop() > 150) {\n\t      $('#menu').addClass('scrolled');\n\t    } else {\n\t      $('#menu').removeClass('scrolled');\n\t    }\n\t  });\n    \n      //ハンバーガーメニューのアニメーション\n      $('.navbar-toggle').on('click',function(){\n        $('.icon-bar').toggleClass('active');\n        \n        //ロゴ非表示用 & 配置換え\n        if($('.active').length) {\n            $('.container01').addClass('open01');\n            $('.navbar-toggle').css('background-color', 'rgba(255,255,255,0)');\n            \n            $('#menu-sub').insertAfter('#menu-ul');\n        } else {\n            $('.container01').removeClass('open01');\n            $('.navbar-toggle').css('background-color', '#993847');\n            \n            $('#menu-sub').insertAfter('#menu-list');\n        }\n      });\n\t});\n\n/*-- スムーズスクロール ユトリアグループ --*/\n$(function(){\n  $('#btn01 a[href^=#]').click(function(){\n      var adjust = 50;// 移動先を50px上にずらす\n      var speed = 400;// スクロールの速度\n      var href= $(this).attr(\"href\");// アンカーの値取得\n      var target = $(href == \"#\" || href == \"\" ? 'html' : href);// 移動先を取得\n      var position = target.offset().top - adjust;// 移動先を調整\n      $('body,html').animate({scrollTop:position}, speed, 'swing');// スムーススクロール\n      return false;\n  });\n});\n    </script>\n    \n    <!-- Slider-pro -->\n<script src=\"https://www.yamako.co.jp/common/js/jquery.sliderPro.min.js\"></script>\n    <script>\n    jQuery(document).ready(function($){\n      $( '#slider1' ).sliderPro({\n        width: \"100%\",\n        aspectRatio: 2.5,\n        loop: false,\n        autoplay: true,\n        updateHash: false,\n        touchSwipe: false,\n        slideDistance: 0,\n        playVideoAction: 'stopAutoplay',\n        endVideoAction: 'replayVideo',\n        leaveVideoAction: 'removeVideo',\n        reachVideoAction: 'playVideo',\n      });\n    });\n    </script>\n\n    <script>\n    $(function() {\n        var topBtn = $('.pagetop');    \n        //スクロールしてトップ\n        topBtn.click(function () {\n            $('body,html').animate({\n                scrollTop: 0\n            }, 500);\n            return false;\n        });\n      });\n    </script>\n\n<!-- slickslider -->\n<script src=\"http://www.yamako.co.jp/common/js/slick.js\"></script>\n<script>\n/*--- 土地スライダー ---*/\n$(function() {\n  $('.slider01').slick({\n    infinite: true, //スライドのループ有効化\n    arrows: false, //矢印非表示\n    fade: true, //フェードの有効化\n    draggable: false, //ドラッグ操作の無効化\n  });\n  $('.slider01-thumb').slick({\n    arrows: true, //矢印表示\n    infinite: true, //スライドのループ有効化\n    slidesToShow: 3, //表示するスライドの数\n    slidesToScroll:3, //一度にスクロールするスライド数\n    focusOnSelect: true, //フォーカスの有効化\n    asNavFor: '.slider01', //slider01クラスのナビゲーション\n  });\n});\n</script>\n<script src=\"https://www.yamako.co.jp/mt8/mt-static/plugins/AForm/js/jquery.validate.js?t=20260423130903\" type=\"text/javascript\"></script>\n<script src=\"https://www.yamako.co.jp/mt8/mt-static/plugins/AForm/js/js.cookie.min.js?t=20260423130903\" type=\"text/javascript\"></script>\n<script type=\"text/javascript\">jQuery.query = { numbers: false };</script>\n<script src=\"https://www.yamako.co.jp/mt8/mt-static/plugins/AForm/js/jquery.query-object.js?t=20260423130903\" type=\"text/javascript\"></script>\n<script src=\"https://www.yamako.co.jp/mt8/mt-static/plugins/AForm/js/jquery-ui.min.js?t=20260423130903\" type=\"text/javascript\"></script>\n\n<script src=\"https://www.yamako.co.jp/mt8/mt-static/plugins/AForm/js/aform.js?t=20260423130903\" type=\"text/javascript\"></script>\n</body>\n</html>\n","finalUrl":"https://www.yamako.co.jp/contact/recruit.html","rendered":false,"_cachedAt":"2026-06-23T21:11:22.922Z"}