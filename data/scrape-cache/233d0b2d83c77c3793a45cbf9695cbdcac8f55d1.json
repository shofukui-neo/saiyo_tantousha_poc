js/setting.js\"></script>\r\n\r\n\r\n</head>\r\n<body class=\"format_free no_javascript\">\r\n<script src=\"/shared/site_jinji2026/js/init.js\"></script>\r\n<div id=\"tmp_wrapper\">\r\n<noscript>\r\n<p>このサイトではJavaScriptを使用したコンテンツ・機能を提供しています。JavaScriptを有効にするとご利用いただけます。</p>\r\n</noscript>\r\n<p><a href=\"#tmp_honbun\" class=\"skip\">本文へスキップします。</a></p>\r\n<div id=\"tmp_wrap_header\">\r\n<div class=\"container\">\r\n<header id=\"tmp_header\">\r\n<div id=\"tmp_hlogo\">\r\n<p><a href=\"/f1903/saiyou/index.html\"><span>埼玉県職員採用情報</span></a></p>\r\n</div>\r\n<ul id=\"tmp_hnavi_s\">\r\n<li id=\"tmp_hnavi_lmenu\"><a href=\"javascript:void(0);\"><span>メニュー</span></a></li>\r\n</ul>\r\n</header>\r\n<div id=\"tmp_wrap_gnavi\">\r\n<div id=\"tmp_gnavi\">\r\n<ul class=\"gnavi\">\r\n<li class=\"glist0\"><a href=\"/f1903/saiyou/index.html\">TOP</a></li>\r\n<li class=\"glist1\"><a href=\"/f1903/saiyou/shigoto/index.html\">埼玉県について</a></li>\r\n<li class=\"glist2\"><a href=\"/f1903/saiyou/shoukai/index.html\">仕事／職員紹介</a></li>\r\n<li class=\"glist3\"><a href=\"/f1903/saiyou/fukuri/index.html\">環境／制度</a></li>\r\n<li class=\"glist4\"><a href=\"/f1903/saiyou/qa/index.html\">Q&amp;A／アンケート</a></li>\r\n<li class=\"glist5\"><a href=\"/f1903/saiyou/seminar/index.html\">イベント情報</a></li>\r\n<li class=\"glist6\"><a href=\"/f1903/saiyou/pamph/index.html\">パンフレット／動画</a></li>\r\n</ul>\r\n</div>\r\n<p id=\"tmp_hnavi_exam\"><a href=\"/f1903/saiyou/shiken/index.html\"><span>試験・選考情報</span></a></p>\r\n</div>\r\n</div>\r\n</div>\r\n<div id=\"tmp_sma_menu\">\r\n<div id=\"tmp_sma_lmenu\" class=\"wrap_sma_sch\">\r\n<div class=\"sma_sch\">\r\n<p id=\"tmp_sma_hnavi_exam\"><a href=\"/f1903/saiyou/shiken/index.html\"><span>試験・選考情報</span></a></p>\r\n<p class=\"close_btn\"><a href=\"javascript:void(0);\"><span>閉じる</span></a></p>\r\n</div>\r\n</div>\r\n</div>\r\n<main id=\"tmp_wrap_main\" class=\"column_cnt\">\r\n<div class=\"container\">\r\n<div id=\"tmp_main\">\r\n<p id=\"tmp_honbun\" class=\"skip\">ここから本文です。</p>\r\n<div id=\"tmp_contents\">\r\n<h1>埼玉県について</h1>\r\n<p>知事メッセージや基本データを通して、県の姿をお伝えします。</p>\r\n<p>&nbsp;</p>\r\n<h2><a id=\"chiji_message\" name=\"chiji_message\">知事メッセージ</a></h2>\r\n<p><img align=\"right\" alt=\"大野知事写真\" height=\"471\" src=\"/images/197288/chijishashinshikaku.png\" width=\"350\" />埼玉県職員採用ホームページをご覧いただき、ありがとうございます。<br />\r\n皆さんは、埼玉県職員として働くことについて、どのような印象をお持ちでしょうか。<br />\r\n県庁は、前例踏襲のお役所仕事だけというイメージを持つ方もおられるかもしれません。</p>\r\n<p>しかし、埼玉県庁は今、大きな変革の真っただ中にあります。</p>\r\n<p>全国でもトップクラスのデジタル化を進め、生産性の向上と県民サービスの質の向上を両立させることに取り組んでいます。<br />\r\nDX（デジタルトランスフォーメーション）を推進することで、業務効率化から生まれた時間を、職員が創造的な仕事に充てられるようにし、職員のアイデアや能力が存分に発揮できる環境を整えると共に、デジタルを活用した50年後を見据えたオフィスの実現を目指し、具体的に動き始めています。</p>\r\n<p>また、未来を見据え、大型プロジェクトの実現に取り組んでいます。<br />\r\n例えば、国内外に誇るオンリーワンの施設で、『試合がある日もない日も楽しめる公園』を目指す「大宮スーパー・ボールパーク構想」や、「地域の活力向上機能」と「未来の県庁の先行モデル機能」を担い、県北部の更なる発展を目指す、「北部地域振興交流拠点」の整備を進めています。<br />\r\nこうしたスケールの大きなプロジェクトに携わることができるのも、埼玉県職員の大きな魅力です。</p>\r\n<p>私は、県庁を誰もが活躍できる「日本一働きやすい職場」にしたいと考えています。</p>\r\n<p>埼玉県庁で、皆さんの個性や能力を最大限に生かし、新たな埼玉県を皆さんの手で作っていってください。</p>\r\n<p>自分の可能性と時代が要請する変化に挑戦し、県民と地域のために共に歩んでいきましょう。<br />\r\n皆さんの新しい一歩を心からお待ちしています。</p>\r\n<p>&nbsp;&nbsp;&nbsp;<img align=\"right\" alt=\"知事署名\" height=\"38\" src=\"/images/197288/shomei.jpg\" width=\"300\" /></p>\r\n<p>&nbsp;</p>\r\n<h2><a id=\"motomerujinbutsu\" name=\"motomerujinbutsu\">求める人物像</a></h2>\r\n<p><img alt=\"求める人物像1\" height=\"270\" src=\"/images/197288/motomeru1.jpg\" width=\"270\" />&nbsp; &nbsp;<img alt=\"求める人物像2\" height=\"270\" src=\"/images/197288/motomeru2.jpg\" width=\"270\" />&nbsp; &nbsp;<img alt=\"求める人物像3\" height=\"270\" src=\"/images/197288/motomeru3.jpg\" width=\"270\" /></p>\r\n<p>埼玉県職員のミッションは、埼玉県民の幸せをつくることです。</p>\r\n<p>私たちは、埼玉県の未来を考え、柔軟な発想とチャレンジ精神で行動する人材を広く募集します。</p>\r\n<p>&nbsp;</p>\r\n<h2><a id=\"saitamakendeta\" name=\"saitamakendeta\">埼玉県基本データ</a></h2>\r\n<p><img alt=\"面積\" height=\"270\" src=\"/images/197288/saitama_cms_sozai_1.jpg\" width=\"270\" />&nbsp;&nbsp;<img alt=\"市町村数\" height=\"270\" src=\"/images/197288/date2.jpg\" width=\"270\" />&nbsp;&nbsp;<img alt=\"人口\" height=\"270\" src=\"/images/197288/date3.jpg\" width=\"270\" /></p>\r\n<p><img alt=\"交通\" height=\"270\" src=\"/images/197288/date4.jpg\" width=\"270\" />&nbsp;&nbsp;<img alt=\"経済\" height=\"270\" src=\"/images/197288/date5.jpg\" width=\"270\" />&nbsp;&nbsp;<img alt=\"企業立地\" height=\"270\" src=\"/images/197288/date6.jpg\" width=\"270\" /></p>\r\n<p><img alt=\"農業\" height=\"270\" src=\"/images/197288/date7.jpg\" width=\"270\" />&nbsp;&nbsp;<img alt=\"ブランド食材\" height=\"270\" src=\"/images/197288/date8.jpg\" width=\"270\" />&nbsp;&nbsp;<img alt=\"川の国\" height=\"270\" src=\"/images/197288/sashikae1.png\" width=\"270\" /></p>\r\n<div class=\"section\">\r\n<div class=\"section\">\r\n<p>&nbsp;</p>\r\n</div>\r\n</div>\r\n<p>&nbsp;</p>\r\n</div>\r\n\r\n\r\n</div>\r\n</div>\r\n</main>\r\n<div id=\"tmp_pankuzu\">\r\n<div class=\"container\">\r\n<p><a href=\"/index.html\">トップページ</a> &gt; <a href=\"/kense/index.html\">県政情報・統計</a> &gt; <a href=\"/kense/jinji/index.html\">人事・職員</a> &gt; <a href=\"/kense/jinji/saiyo/index.html\">採用情報</a> &gt; <a href=\"/f1903/saiyou/index.html\">埼玉県職員採用情報</a> &gt; 埼玉県について</p>\r\n</div>\r\n</div>\r\n\r\n<footer id=\"tmp_footer\">\r\n<div class=\"wrap_foot_add\">\r\n<div class=\"container\">\r\n<div class=\"pnavi\">\r\n<p class=\"ptop\"><a href=\"#tmp_header\"><span>TOP</span></a></p>\r\n</div>\r\n<div class=\"foot_add\">\r\n<div class=\"fcnt\">\r\n<p class=\"flogo\"><span>埼玉県職員採用情報</span></p>\r\n</div>\r\n<div class=\"fcnt\">\r\n<p>埼玉県人事委員会事務局<br>\r\n任用審査課 採用試験担当</p>\r\n</div>\r\n<div class=\"fcnt\">\r\n<address>\r\n<p>〒330-9301<br>\r\n埼玉県さいたま市浦和区高砂3-15-1県庁第二庁舎3階<br>\r\n電話番号：048-822-8181<br>\r\nファックス番号：048-830-4930<br>\r\nMail：a6402-10&#64;pref.saitama.lg.jp</p>\r\n</address>\r\n</div>\r\n</div>\r\n</div>\r\n</div>\r\n<div class=\"wrap_fnavi\">\r\n<div class=\"container\">\r\n<ul class=\"fnavi\">\r\n<li class=\"link_site_map\"><a href=\"/f1903/saiyou/sitemap.html\">サイトマップ</a></li>\r\n<li><a href=\"/a0301/