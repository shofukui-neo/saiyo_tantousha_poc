{"url":"https://www.cnw.co.jp/recruit/president.html","html":"<!DOCTYPE html>\r\n<html lang=\"ja\">\r\n<head>\r\n  <meta charset=\"UTF-8\">\r\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n  <title>代表挨拶 | キャリアネットワーク採用サイト</title>\r\n  <link href=\"https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@300;400;500;600;700&family=Noto+Sans+JP:wght@300;400;500;700&family=Inter:wght@300;400;500;600;700&display=swap\" rel=\"stylesheet\">\r\n  <link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@fortawesome/fontawesome-free@6.4.0/css/all.min.css\">\r\n  <link rel=\"stylesheet\" href=\"css/sub.css\">\r\n  <link rel=\"stylesheet\" href=\"css/president.css\">\r\n</head>\r\n<body>\r\n\r\n<!-- ========================================\r\n     HEADER\r\n======================================== -->\r\n<header class=\"site-header\">\r\n  <div class=\"site-header__inner\">\r\n    <a href=\"index.html\" class=\"site-header__logo\">\r\n      <img src=\"images/logo.webp\" width=\"200\">\r\n      <span class=\"site-header__logo-text\">採用サイト<span>RECRUIT</span></span>\r\n    </a>\r\n    <nav class=\"site-header__nav\" id=\"headerNav\">\r\n      <ul>\r\n        <li><a href=\"company.html\" class=\"active\">会社を知る</a></li>\r\n        <li><a href=\"work.html\">仕事を知る</a></li>\r\n        <li><a href=\"people.html\">人を知る</a></li>\r\n        <li><a href=\"jobs.html\">採用情報</a></li>\r\n      </ul>\r\n    </nav>\r\n    <a href=\"jobs.html#apply\" class=\"site-header__cta\">応募する</a>\r\n    <button class=\"site-header__hamburger\" id=\"hamburger\" aria-label=\"メニュー\">\r\n      <span></span><span></span><span></span>\r\n    </button>\r\n  </div>\r\n</header>\r\n\r\n<div class=\"sp-menu\" id=\"spMenu\">\r\n  <ul>\r\n    <li><a href=\"company.html\" class=\"sp-menu__link active\">会社を知る</a></li>\r\n    <li><a href=\"work.html\" class=\"sp-menu__link\">仕事を知る</a></li>\r\n    <li><a href=\"people.html\" class=\"sp-menu__link\">人を知る</a></li>\r\n    <li><a href=\"jobs.html\" class=\"sp-menu__link\">採用情報</a></li>\r\n  </ul>\r\n  <a href=\"jobs.html#apply\" class=\"sp-menu__cta\">まず話を聞いてみる（無料）</a>\r\n  <a href=\"jobs.html#apply\" class=\"sp-menu__cta sp-menu__cta--sub\">30秒で応募する →</a>\r\n</div>\r\n\r\n<!-- ========================================\r\n     PAGE HERO\r\n======================================== -->\r\n<section class=\"page-hero\">\r\n  <div class=\"container page-hero__inner\">\r\n    <nav class=\"breadcrumb\" aria-label=\"パンくずリスト\">\r\n      <a href=\"mockup.html\">HOME</a>\r\n      <i class=\"fa-solid fa-chevron-right\"></i>\r\n      <a href=\"company.html\">会社を知る</a>\r\n      <i class=\"fa-solid fa-chevron-right\"></i>\r\n      <span>代表挨拶</span>\r\n    </nav>\r\n    <span class=\"page-hero__en\">MESSAGE</span>\r\n    <h1 class=\"page-hero__title\">代表挨拶</h1>\r\n    <p class=\"page-hero__desc\">\r\n      「人の可能性を信じる」という原点は、<br class=\"pc-only\">\r\n      創業から一度も変わっていません。\r\n    </p>\r\n  </div>\r\n</section>\r\n\r\n<!-- ========================================\r\n     SEC 01: 代表写真 × 挨拶本文\r\n======================================== -->\r\n<section class=\"pres-intro\">\r\n  <div class=\"container pres-intro__inner\">\r\n\r\n    <!-- 写真カラム -->\r\n    <div class=\"pres-intro__photo-col\" data-fade>\r\n      <div class=\"pres-intro__img-wrap\">\r\n        <!-- 動画モーダルトリガー -->\r\n        <button\r\n          class=\"pres-video-trigger\"\r\n          id=\"presVideoTrigger\"\r\n          aria-label=\"社長インタビュー動画を再生する\"\r\n          aria-haspopup=\"dialog\"\r\n        >\r\n          <img\r\n            src=\"images/president.jpg\"\r\n            alt=\"代表取締役社長 中山 喜雄\"\r\n            class=\"pres-intro__photo\"\r\n            loading=\"eager\"\r\n            onerror=\"this.style.background='linear-gradient(135deg,#1B3A6B,#3B7DD8)';this.style.minHeight='480px';this.removeAttribute('src');\"\r\n          >\r\n          <!-- ホバー時の再生アイコン -->\r\n          <span class=\"pres-play-overlay\" aria-hidden=\"true\">\r\n            <span class=\"pres-play-circle\">\r\n              <i class=\"fa-solid fa-play\"></i>\r\n            </span>\r\n            <span class=\"pres-play-label\">動画を再生する</span>\r\n          </span>\r\n          <!-- 常時バッジ -->\r\n          <span class=\"pres-video-badge\" aria-hidden=\"true\">\r\n            <i class=\"fa-solid fa-circle-play\"></i> インタビュー動画あり\r\n          </span>\r\n        </button>\r\n      </div>\r\n    \r\n    \r\n    \r\n\r\n      \r\n\r\n      <div class=\"pres-intro__profile\">\r\n        <p class=\"pres-intro__title\">Representative Director</p>\r\n        <p class=\"pres-intro__name-ja\">中山 喜雄</p>\r\n        <p class=\"pres-intro__name-en\">Yoshio Nakayama</p>\r\n\r\n        <div class=\"pres-intro__career\">\r\n          <div class=\"pres-intro__career-item\">\r\n            <span class=\"pres-intro__career-year\">1998</span>\r\n            <span class=\"pres-intro__career-text\">大手人材派遣会社 入社</span>\r\n          </div>\r\n          <div class=\"pres-intro__career-item\">\r\n            <span class=\"pres-intro__career-year\">2001</span>\r\n            <span class=\"pres-intro__career-text\">同社 福井支店 支店長就任</span>\r\n          </div>\r\n          <div class=\"pres-intro__career-item\">\r\n            <span class=\"pres-intro__career-year\">2003</span>\r\n            <span class=\"pres-intro__career-text\">株式会社キャリアネットワーク 設立・代表取締役就任</span>\r\n          </div>\r\n          <div class=\"pres-intro__career-item\">\r\n            <span class=\"pres-intro__career-year\">現在</span>\r\n            <span class=\"pres-intro__career-text\">代表取締役社長（創業より）</span>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- 本文カラム -->\r\n    <div class=\"pres-intro__body-col\">\r\n\r\n      <!-- キャッチコピー -->\r\n      <div class=\"pres-catch\" data-fade>\r\n        <span class=\"pres-catch__label\">President's Message</span>\r\n        <h2 class=\"pres-catch__heading\">\r\n          人の可能性を信じることが、<br>\r\n          私たちの仕事の<em>すべての出発点</em>です。\r\n        </h2>\r\n      </div>\r\n\r\n      <!-- 本文 -->\r\n      <div class=\"pres-body\">\r\n        \r\n        \r\n        \r\n        \r\n        <h3 data-fade>福井県の人手不足という課題を、出会いの力で解決したい</h3>\r\n        <p data-fade>\r\n          私たちは、福井県が抱える人手不足の課題を解決したいという想いから事業を始めました。実際に周囲からは、「福井にはいい仕事がない」「仕事の選択肢が少ない」といった声や、企業経営者の方々から「良い人材がなかなか集まらない」という悩みを数多く聞いてきました。</p>\r\n\r\n<p data-fade>しかし私は、福井には魅力的な仕事も、意欲ある人材もたくさんいると感じています。\r\nそれにもかかわらず、互いに出会うきっかけがうまくつくられていない。その課題に対して、企業と求職者をつなぐ“より良い出会い”を生み出したいと考えたことが、この事業の原点です。\r\n        </p>\r\n\r\n        \r\n        \r\n        <h3 data-fade>当社が何より大切にしているのは、「スピード」と「現場主義」</h3>\r\n        <p data-fade>\r\n          私たちが大切にしている価値観は、大きく2つあります。\r\nひとつはスピード感、もうひとつは徹底した現場主義です。<br /><br />\r\n\r\n求人情報はまさに“生もの”です。\r\n昨日までなかった求人が今日突然出てくることもあれば、状況が短期間で大きく変わることもあります。だからこそ、どれだけ早く動けるかがとても重要です。<br /><br />\r\n\r\nまた、私たちは小さな組織だからこそ、意思決定の速さにも強みがあります。\r\n全員で決めたことをすぐに実行に移せる。思い立ったらすぐ行動し、現場に即対応できる。この機動力こそが、私たちの大きな強みだと考えています。\r\n        </p>\r\n\r\n        <blockquote class=\"pres-quote\" data-fade>\r\n          向いているのは、「素直さ」と「積極性」を持った方\r\n        </blockquote>\r\n\r\n        <p data-fade>\r\n          この仕事に向いている方として、特に大切だと感じているのは素直さと積極性です。\r\n\r\n私たちの仕事では、特別な資格や高度な専門スキルが最初から必要なわけではありません。\r\nそれ以上に大切なのは、企業の担当者の方や求職者の方の話を丁寧に聞き、その想いや背景をしっかり理解しようとする姿勢です。\r\n\r\nそしてもうひとつが積極性です。\r\nまずはやってみる、挑戦してみる。その気持ちが成長につながります。完璧であることよりも、一歩踏み出せることを大切にしています。\r\n        </p>\r\n\r\n        \r\n        \r\n        <h3 data-fade>未経験でも、少しずつ成功体験を積み重ねて成長できる</h3>\r\n        <p data-fade>\r\n         未経験で入社される方も、もちろん歓迎しています。\r\n最初から大きな仕事を任せるのではなく、まずは小さなことから挑戦してもらう機会をたくさん用意しています。\r\n\r\n小さな成功体験を一つひとつ積み重ねることで、自信がつき、次のステップに進めるようになる。\r\nその積み重ねによって、少しずつより大きな仕事にも挑戦できるようになります。\r\n\r\nいきなり大きな責任を背負わせるのではなく、安心して成長していける環境を整えているので、未経験の方でも不安なくスタートしていただけると思います。\r\n        </p>\r\n\r\n        \r\n        <h3 data-fade>人の人生の転機に関われることが、この仕事の大きなやりがい</h3>\r\n        <p data-fade>\r\n         この仕事のやりがいは、何よりも人の人生の転機に関われることです。\r\n\r\n私たちが提案した仕事をきっかけに、その方が前向きに働けるようになったり、人生が大きく変わったりする場面をこれまで何度も見てきました。\r\nそうした瞬間に立ち会えることは、この仕事ならではの大きな喜びです。\r\n\r\nまた、企業にとっては人材不足の解決につながり、求職者にとっては新しい人生のスタートにつながる。\r\nその両方から感謝の言葉をいただけることも、この仕事の大きな魅力だと感じています。\r\n        </p>\r\n        \r\n        \r\n        \r\n        <h3 data-fade>身につくのは、「企業を見る力」「人を見る力」「提案力」</h3>\r\n        <p data-fade>\r\n        この仕事を通じて身につく力は、大きく3つあります。\r\n\r\n1つ目は、企業を客観的に見る力。\r\n2つ目は、人を見る力。\r\n3つ目は、提案力です。\r\n\r\n企業の担当者から仕事内容や課題をヒアリングし、求職者の経歴や希望を丁寧に伺いながら、「この方はこの企業で活躍できるだろうか」と考え、最適な提案をしていく。\r\nその過程の中で、自然とこれらの力が磨かれていきます。\r\n        </p>\r\n        \r\n        \r\n        \r\n        <h3 data-fade>風通しがよく、頑張りが正しく評価される職場を目指して</h3>\r\n        <p data-fade>\r\n        社員が安心して長く働けるよう、私たちが意識しているのは風通しの良い組織づくりと、頑張りが正しく評価される仕組みです。\r\n\r\n小さな組織だからこそ、現場の声やアイデアをすぐに形にしやすい環境があります。\r\n「こんなことをやってみたい」という提案があれば、スピーディーに実行へ移していけるのも当社ならではです。\r\n\r\nまた、成果や日々の努力についても、公平にしっかり評価したいと考えています。\r\n頑張った分がきちんと認められることで、安心して前向きに働き続けられる職場をつくっていきたいと思っています。\r\n        </p>\r\n        \r\n        \r\n        <h3 data-fade>まずは気軽に話してみませんか</h3>\r\n        <p data-fade>\r\n       人の役に立ちたい。\r\n福井県の人手不足という課題の解決に貢献したい。\r\nそんな気持ちがあれば、特別なスキルがなくても大丈夫です。\r\n\r\nまずは一度、気軽にお話ししてみませんか。\r\n皆さまとお会いできることを、心より楽しみにしています。\r\n        </p>\r\n\r\n      </div><!-- /.pres-body -->\r\n\r\n      <!-- 署名 -->\r\n      <div class=\"pres-sign\" data-fade>\r\n        <span class=\"pres-sign__company\">株式会社キャリアネットワーク</span>\r\n        <span class=\"pres-sign__title\">代表取締役社長</span>\r\n        <span class=\"pres-sign__name\">中山 喜雄</span>\r\n        <span class=\"pres-sign__name-en\">Yoshio Nakayama</span>\r\n      </div>\r\n\r\n    </div><!-- /.pres-intro__body-col -->\r\n  </div>\r\n</section>\r\n\r\n<!-- ========================================\r\n     SEC 02: 経営理念（MISSION / VISION / VALUE）\r\n======================================== -->\r\n<section class=\"pres-mvv\">\r\n  <div class=\"container\">\r\n\r\n    <div class=\"pres-mvv__header\" data-fade>\r\n      <span class=\"pres-mvv__en\">Our Philosophy</span>\r\n      <h2 class=\"pres-mvv__title\">\r\n        私たちが大切にしている、<br>3つの価値観\r\n      </h2>\r\n    </div>\r\n\r\n    <div class=\"pres-mvv__grid\">\r\n\r\n      <div class=\"pres-mvv__card\" data-fade>\r\n        <div class=\"pres-mvv__card-icon\">\r\n          <i class=\"fa-solid fa-bullseye\"></i>\r\n        </div>\r\n        <p class=\"pres-mvv__card-label\">Mission</p>\r\n        <h3 class=\"pres-mvv__card-title\">地域の雇用と<br>人の可能性をつなぐ</h3>\r\n        <p class=\"pres-mvv__card-body\">\r\n          地元・福井で、働きたい人と採用したい企業をつなぎ、地域全体の活力を高めることが私たちの使命です。一組一組の出会いを、丁寧に積み重ねていきます。\r\n        </p>\r\n      </div>\r\n\r\n      <div class=\"pres-mvv__card\" data-fade>\r\n        <div class=\"pres-mvv__card-icon\">\r\n          <i class=\"fa-solid fa-eye\"></i>\r\n        </div>\r\n        <p class=\"pres-mvv__card-label\">Vision</p>\r\n        <h3 class=\"pres-mvv__card-title\">誰もが自分らしく<br>働ける地域社会</h3>\r\n        <p class=\"pres-mvv__card-body\">\r\n          学歴・経験・年齢に関わらず、誰もが力を発揮できる環境を福井から実現します。「ここで働いてよかった」と思える職場を、一つでも多く生み出したい。\r\n        </p>\r\n      </div>\r\n\r\n      <div class=\"pres-mvv__card\" data-fade>\r\n        <div class=\"pres-mvv__card-icon\">\r\n          <i class=\"fa-solid fa-handshake\"></i>\r\n        </div>\r\n        <p class=\"pres-mvv__card-label\">Value</p>\r\n        <h3 class=\"pres-mvv__card-title\">誠実・熱意・伴走</h3>\r\n        <p class=\"pres-mvv__card-body\">\r\n          求職者にも企業にも誠実に向き合い、熱意をもって伴走する。入社して終わりではなく、その後もずっと気にかけ続けることが、キャリアネットワークの約束です。\r\n        </p>\r\n      </div>\r\n\r\n    </div>\r\n  </div>\r\n</section>\r\n\r\n<!-- ========================================\r\n     SEC 03: 会社のこれから\r\n======================================== -->\r\n<section class=\"pres-vision\">\r\n  <div class=\"container pres-vision__inner\">\r\n\r\n    <!-- 画像 -->\r\n    <div class=\"pres-vision__visual\" data-fade>\r\n      <img\r\n        src=\"images/bg-office.jpg\"\r\n        alt=\"オフィスの様子\"\r\n        class=\"pres-vision__img\"\r\n        loading=\"lazy\"\r\n        onerror=\"this.style.background='linear-gradient(135deg,#E8F0FC,#D0E0F8)';this.style.minHeight='300px';this.removeAttribute('src');\"\r\n      >\r\n    </div>\r\n\r\n    <!-- テキスト -->\r\n    <div data-fade>\r\n      <span class=\"pres-vision__label\">Looking Ahead</span>\r\n      <h2 class=\"pres-vision__heading\">\r\n        20年の歩みを糧に、<br>\r\n        次の20年へ。\r\n      </h2>\r\n      <div class=\"pres-vision__body\">\r\n        <p>\r\n          キャリアネットワークは2003年の創業以来、福井の地で人と企業をつなぎ続けてきました。その間に支援してきた求職者は1,200名を超え、地域の企業との信頼関係も着実に積み上げてきました。\r\n        </p>\r\n        <p>\r\n          しかし、私たちはまだ成長の途中です。少子高齢化が進む中、地方の雇用課題はますます複雑になっています。だからこそ、一人ひとりに寄り添うこの仕事の価値は、これからさらに高まると確信しています。\r\n        </p>\r\n        <p>\r\n          次の10年、20年を共に歩む仲間を、今まさに探しています。人と関わることが好きで、誰かの人生の転機に貢献したいと思っているあなたに、ぜひ仲間になってほしいと思っています。\r\n        </p>\r\n      </div>\r\n    </div>\r\n\r\n  </div>\r\n</section>\r\n\r\n<!-- ========================================\r\n     BOTTOM CTA\r\n======================================== -->\r\n<section class=\"pres-cta\">\r\n  <div class=\"container\">\r\n    <span class=\"pres-cta__en\" data-fade>Join Us</span>\r\n    <h2 class=\"pres-cta__heading\" data-fade>\r\n      私たちと一緒に、<br>福井の未来をつくりませんか。\r\n    </h2>\r\n    <p class=\"pres-cta__sub\" data-fade>\r\n      まずはカジュアル面談で、チームの雰囲気を直接感じてみてください。<br>\r\n      選考なし・無料です。\r\n    </p>\r\n    <div class=\"pres-cta__btns\" data-fade>\r\n      <a href=\"jobs.html#apply\" class=\"pres-cta__btn pres-cta__btn--accent\">\r\n        <i class=\"fa-solid fa-calendar-check\"></i> カジュアル面談を予約する\r\n      </a>\r\n      <a href=\"jobs.html\" class=\"pres-cta__btn pres-cta__btn--outline\">\r\n        <i class=\"fa-solid fa-briefcase\"></i> 募集要項を見る\r\n      </a>\r\n    </div>\r\n  </div>\r\n</section>\r\n\r\n<!-- ========================================\r\n     FOOTER\r\n======================================== -->\r\n<footer class=\"site-footer\">\r\n  <div class=\"container\">\r\n    <div class=\"site-footer__top\">\r\n      <div class=\"site-footer__brand\">\r\n        <div class=\"site-footer__logo\">\r\n          <img src=\"images/logo.webp\" width=\"200\">\r\n          <span class=\"site-footer__logo-text\">キャリアネットワーク<span>RECRUIT</span></span>\r\n        </div>\r\n        <p class=\"site-footer__catchcopy\">学歴より、熱意。<br>未経験から、人材のプロへ。</p>\r\n        <div class=\"site-footer__sns\">\r\n          <a href=\"https://www.instagram.com/fukui_tenshoku/\" aria-label=\"Instagram\"><i class=\"fa-brands fa-instagram\"></i></a>\r\n          <a href=\"https://x.com/fukui_tenshoku\" aria-label=\"Twitter/X\"><i class=\"fa-brands fa-x\"></i></a>\r\n          <a href=\"https://page.line.me/824ylbtv?openQrModal=true\" aria-label=\"LINE\"><i class=\"fa-brands fa-line\"></i></a>\r\n        </div>\r\n      </div>\r\n      <div class=\"site-footer__nav\">\r\n        <div class=\"site-footer__nav-group\">\r\n          <div class=\"site-footer__nav-title\">会社を知る</div>\r\n          <ul>\r\n            <li><a href=\"company.html\">会社概要</a></li>\r\n            <li><a href=\"president.html\">代表挨拶</a></li>\r\n          </ul>\r\n        </div>\r\n        <div class=\"site-footer__nav-group\">\r\n          <div class=\"site-footer__nav-title\">仕事を知る</div>\r\n          <ul>\r\n            <li><a href=\"work.html#coordinator\">派遣コーディネーター</a></li>\r\n            <li><a href=\"work.html#advisor\">キャリアアドバイザー</a></li>\r\n          </ul>\r\n        </div>\r\n        <div class=\"site-footer__nav-group\">\r\n          <div class=\"site-footer__nav-title\">人を知る</div>\r\n          <ul>\r\n            <li><a href=\"people.html\">スタッフ一覧</a></li>            <li><a href=\"people/a.html\">N.Yさんのインタビュー</a></li>\r\n            <li><a href=\"people/b.html\">K.Aさんのインタビュー</a></li>\r\n            <li><a href=\"people/c.html\">N.Aさんのインタビュー</a></li>\r\n            <li><a href=\"people/d.html\">K.Aさんのインタビュー</a></li>\r\n            <li><a href=\"people/e.html\">K.Kさんのインタビュー</a></li>\r\n          </ul>\r\n        </div>\r\n        <div class=\"site-footer__nav-group\">\r\n          <div class=\"site-footer__nav-title\">採用情報</div>\r\n          <ul>\r\n            <li><a href=\"jobs.html\">募集職種一覧</a></li>\r\n            <li><a href=\"jobs.html#flow\">選考フロー</a></li>\r\n            <li><a href=\"jobs.html#apply\">応募する</a></li>\r\n          </ul>\r\n        </div>\r\n      </div>\r\n    </div>\r\n    <div class=\"site-footer__bottom\">\r\n      <div class=\"site-footer__legal\">\r\n        \r\n        <a href=\"https://www.cnw.co.jp/privacy\" target=\"_blank\">個人情報の取り扱い</a>\r\n        <a href=\"https://www.cnw.co.jp/form/contact#no-back\" target=\"_blank\">お問い合わせ</a>\r\n      </div>\r\n      <p class=\"site-footer__copy\">© 2026 株式会社キャリアネットワーク All Rights Reserved.</p>\r\n    </div>\r\n  </div>\r\n</footer>\r\n\r\n<div class=\"sticky-cta-bar\" id=\"stickyCta\">\r\n  <div class=\"sticky-cta-bar__inner\">\r\n    <p class=\"sticky-cta-bar__text\">あなたの一歩を待っています</p>\r\n    <div class=\"sticky-cta-bar__btns\">\r\n      <a href=\"jobs.html#apply\" class=\"sticky-btn sticky-btn--apply\"><i class=\"fa-solid fa-bolt\"></i> <span>30秒応募</span></a>\r\n      <a href=\"https://page.line.me/824ylbtv?openQrModal=true\" class=\"sticky-btn sticky-btn--line\"><i class=\"fa-brands fa-line\"></i> <span>LINE</span></a>\r\n      <a href=\"jobs.html#apply\" class=\"sticky-btn sticky-btn--casual\"><i class=\"fa-solid fa-calendar-check\"></i> <span>面談予約</span></a>\r\n    </div>\r\n    <button class=\"sticky-cta-bar__close\" id=\"stickyClose\" aria-label=\"閉じる\"><i class=\"fa-solid fa-xmark\"></i></button>\r\n  </div>\r\n</div>\r\n\r\n<!-- ========================================\r\n     動画モーダル\r\n======================================== -->\r\n<div\r\n  class=\"video-modal\"\r\n  id=\"videoModal\"\r\n  role=\"dialog\"\r\n  aria-modal=\"true\"\r\n  aria-labelledby=\"videoModalTitle\"\r\n  aria-hidden=\"true\"\r\n>\r\n  <!-- 背景（クリックで閉じる） -->\r\n  <div class=\"video-modal__backdrop\" id=\"videoModalBackdrop\"></div>\r\n\r\n  <!-- コンテンツ -->\r\n  <div class=\"video-modal__content\">\r\n    <div class=\"video-modal__header\">\r\n      <p class=\"video-modal__title\" id=\"videoModalTitle\">\r\n        <i class=\"fa-solid fa-circle-play\"></i>\r\n        社長インタビュー ｜ 中山 喜雄\r\n      </p>\r\n      <button class=\"video-modal__close\" id=\"videoModalClose\" aria-label=\"閉じる\">\r\n        <i class=\"fa-solid fa-xmark\"></i>\r\n      </button>\r\n    </div>\r\n\r\n    <div class=\"video-modal__video-wrap\">\r\n      <!-- ローディングスピナー -->\r\n      <div class=\"video-modal__spinner\" id=\"videoSpinner\">\r\n        <div class=\"spinner-ring\"></div>\r\n      </div>\r\n      <!-- 動画本体（src は JS で注入 → 開いたときだけロード） -->\r\n      <video\r\n        class=\"video-modal__video\"\r\n        id=\"presVideo\"\r\n        controls\r\n        playsinline\r\n        webkit-playsinline\r\n        preload=\"none\"\r\n      >\r\n        <!-- ソースはJSで動的に設定 -->\r\n      </video>\r\n    </div>\r\n\r\n    <p class=\"video-modal__footer\">\r\n      <i class=\"fa-solid fa-keyboard\"></i>&nbsp; Esc キーで閉じます\r\n    </p>\r\n  </div>\r\n</div>\r\n\r\n<script src=\"js/sub.js\"></script>\r\n<script>\r\n(function () {\r\n  'use strict';\r\n\r\n  // 動画ファイルURL（直接URLまたはローカル相対パス）\r\n  const VIDEO_SRC = 'ceo.mp4';\r\n\r\n  const trigger  = document.getElementById('presVideoTrigger');\r\n  const modal    = document.getElementById('videoModal');\r\n  const backdrop = document.getElementById('videoModalBackdrop');\r\n  const closeBtn = document.getElementById('videoModalClose');\r\n  const video    = document.getElementById('presVideo');\r\n  const spinner  = document.getElementById('videoSpinner');\r\n\r\n  // ---- モーダルを開く ----\r\n  function openModal() {\r\n    // 動画ソースをまだセットしていなければ注入（遅延ロード）\r\n    if (!video.src || video.src === window.location.href) {\r\n      video.src = VIDEO_SRC;\r\n    }\r\n    modal.classList.add('is-open');\r\n    modal.setAttribute('aria-hidden', 'false');\r\n    document.body.style.overflow = 'hidden';\r\n    // フォーカスを閉じるボタンへ\r\n    setTimeout(() => closeBtn.focus(), 50);\r\n    video.play().catch(() => {/* autoplay ブロック時は無視 */});\r\n  }\r\n\r\n  // ---- モーダルを閉じる ----\r\n  function closeModal() {\r\n    modal.classList.remove('is-open');\r\n    modal.setAttribute('aria-hidden', 'true');\r\n    document.body.style.overflow = '';\r\n    video.pause();\r\n    // フォーカスをトリガーへ戻す\r\n    trigger.focus();\r\n  }\r\n\r\n  // ---- スピナー制御 ----\r\n  video.addEventListener('waiting', () => spinner.classList.remove('is-hidden'));\r\n  video.addEventListener('playing', () => spinner.classList.add('is-hidden'));\r\n  video.addEventListener('canplay', () => spinner.classList.add('is-hidden'));\r\n  video.addEventListener('loadeddata', () => spinner.classList.add('is-hidden'));\r\n\r\n  // ---- イベント登録 ----\r\n  trigger.addEventListener('click', openModal);\r\n  closeBtn.addEventListener('click', closeModal);\r\n  backdrop.addEventListener('click', closeModal);\r\n\r\n  // Esc キーで閉じる\r\n  document.addEventListener('keydown', function (e) {\r\n    if (e.key === 'Escape' && modal.classList.contains('is-open')) {\r\n      closeModal();\r\n    }\r\n  });\r\n\r\n  // フォーカストラップ（モーダル内で Tab を循環）\r\n  modal.addEventListener('keydown', function (e) {\r\n    if (e.key !== 'Tab') return;\r\n    const focusable = modal.querySelectorAll(\r\n      'button, [href], input, select, textarea, [tabindex]:not([tabindex=\"-1\"])'\r\n    );\r\n    const first = focusable[0];\r\n    const last  = focusable[focusable.length - 1];\r\n    if (e.shiftKey) {\r\n      if (document.activeElement === first) { e.preventDefault(); last.focus(); }\r\n    } else {\r\n      if (document.activeElement === last)  { e.preventDefault(); first.focus(); }\r\n    }\r\n  });\r\n\r\n})();\r\n</script>\r\n</body>\r\n</html>\r\n","finalUrl":"https://www.cnw.co.jp/recruit/president.html","rendered":false,"_cachedAt":"2026-06-23T21:23:18.556Z"}