          <p>採用情報</p>\n                  <ul class=\"l-f__links-sub\">\n                    <li class=\"l-f__linksItem-sub\"><a href=\"/recruit/info/guideline/\">募集要項・選考の流れ</a></li>\n                    <li class=\"l-f__linksItem-sub u-pb10\"><a href=\"/recruit/info/faq/\">よくあるご質問</a></li>\n                  </ul>\n                </li>\n                <li class=\"l-f__linksItem\">\n                  <p>エントリー</p>\n                  <ul class=\"l-f__links-sub\">\n                    <li class=\"l-f__linksItem-sub\"><a href=\"/recruit/new-graduate-entry/\">新卒採用エントリー</a></li>\n                    <li class=\"l-f__linksItem-sub u-pb10\"><a href=\"/recruit/entry/\">経験者採用エントリー</a></li>\n                  </ul>\n                </li>\n              </ul>\n            </nav>\n          </div>\n        </div>\n        <div class=\"l-f__corporateLink\">\n          <a href=\"/\" target=\"_blank\" rel=\"noopener\">コーポレートサイト</a>\n        </div>\n      </div>\n      <div class=\"l-f__bottom\">\n        <a href=\"/recruit/privacy/\" class=\"l-f__privacy\">個人情報保護方針</a>\n        <small class=\"l-f__copyright\">&copy; YAMASAN Co.,LTD.</small>\n      </div>\n    </footer>\n    <!-- /footer -->\n  </div>\n  <!-- end of #container -->\n  <script src=\"/recruit/inc/js/page/picturefill.min.js\"></script>\n  <script src=\"/recruit/inc/js/page/ofi.min.js\"></script>\n  <script src=\"/recruit/inc/js/common.min.js\"></script>\n  <script src=\"/recruit/inc/js/page/jquery.matchHeight.min.js\"></script>\n  <!--[if lt IE 9]><script src=\"/recruit/inc/js/old-ie.min.js\"></script><![endif]-->\n  <script src=\"/recruit/inc/js/page/headerChange.min.js\"></script>\n</body>\n\n</html>","finalUrl":"https://www.k-yamasan.co.jp/recruit/privacy/","rendered":false,"_cachedAt":"2026-06-23T21:52:31.244Z"}