Ңе…үеёӮпјҡзҙ„64еҲҶ</td>\r\n\t\t\t\t\t\t\t\t<td>жүҖжІўпјҡзҙ„75еҲҶ</td>\r\n\t\t\t\t\t\t\t</tr>\r\n\t\t\t\t\t\t\t<tr>\r\n\t\t\t\t\t\t\t\t<td>жёӢи°·пјҡзҙ„35еҲҶ</td>\r\n\t\t\t\t\t\t\t\t<td>е·қи¶ҠеёӮпјҡзҙ„86еҲҶ</td>\r\n\t\t\t\t\t\t\t\t<td>йЈҜиғҪпјҡзҙ„95еҲҶ</td>\r\n\t\t\t\t\t\t\t</tr>\r\n\t\t\t\t\t\t\t<tr>\r\n\t\t\t\t\t\t\t\t<td>ж–°е®ҝдёүдёҒзӣ®пјҡзҙ„43еҲҶ</td>\r\n\t\t\t\t\t\t\t\t<td>жЈ®жһ—е…¬ең’пјҡзҙ„109еҲҶ</td>\r\n\t\t\t\t\t\t\t\t<td></td>\r\n\t\t\t\t\t\t\t</tr>\r\n\t\t\t\t\t\t\t<tr>\r\n\t\t\t\t\t\t\t\t<td>жұ иўӢпјҡзҙ„49еҲҶ</td>\r\n\t\t\t\t\t\t\t\t<td></td>\r\n\t\t\t\t\t\t\t\t<td></td>\r\n\t\t\t\t\t\t\t</tr>\r\n\t\t\t\t\t\t</tbody>\r\n\t\t\t\t\t<!-- /.basic --></table>\r\n\r\n\t\t\t\t\t<p class=\"fz12 mt15\">вҖ»жҷӮй–“еёҜгҒ«гӮҲгҒЈгҒҰгҖҒзӣ®зҡ„ең°гҒҫгҒ§гҒ®зӣҙйҖҡеҲ—и»ҠгҒҢгҒӘгҒ„е ҙеҗҲгҒҢгҒ”гҒ–гҒ„гҒҫгҒҷгҒ®гҒ§гҒ”жіЁж„ҸгҒҸгҒ гҒ•гҒ„гҖӮгҒҫгҒҹгҖҒйҒӢиЎҢзЁ®еҲҘгҒ«гӮҲгӮҠжүҖиҰҒжҷӮй–“гҒҢз•°гҒӘгӮӢгҒ“гҒЁгҒҢгҒӮгӮҠгҒҫгҒҷгҖӮ</p>\r\n\t\t\t\t</div>\r\n\t\t\t</section>\r\n\r\n\r\n\r\n\r\n\t\t\t<section class=\"section s hasBorderT dot\">\r\n\t\t\t\t<a class=\"target\" id=\"route_map\"></a>\r\n\t\t\t\t<h3 class=\"comTit2\"><img src=\"img/route_map/sec_route_map_tit.png\" alt=\"зӣёдә’зӣҙйҖҡи·Ҝз·ҡеӣі\" width=\"170\" height=\"25\"></h3>\r\n\r\n\t\t\t\t<div class=\"baseTextArea\">\r\n\t\t\t\t\t<p><img src=\"img/route_map/sec_route_map_img.png?202403\" alt=\"зӣёдә’зӣҙйҖҡи·Ҝз·ҡеӣі\" width=\"1200\" height=\"1200\"></p>\r\n\t\t\t\t\t<p><a href=\"pdf/sougorosen.pdf?202403\" class=\"boxLink\" target=\"_blank\">и·Ҝз·ҡеӣігӮ’гғҖгӮҰгғігғӯгғјгғүгҒҷгӮӢпјҲPDFпјү</a></p>\r\n\t\t\t\t<!-- /.baseTextArea --></div>\r\n\t\t\t</section>\r\n\r\n\r\n\t\t\t<section class=\"section s hasBorderT dot\">\r\n\t\t\t\t<a class=\"target\" id=\"transfer\"></a>\r\n\t\t\t\t<h3 class=\"comTit2\"><img src=\"img/route_map/sec_transfer_tit.png\" alt=\"д№—гӮҠжҸӣгҒҲжЎҲеҶ…\" width=\"140\" height=\"25\"></h3>\r\n\r\n\t\t\t\t<div class=\"baseTextArea transfer\">\r\n\t\t\t\t\t<p><img src=\"img/route_map/sec_transfer_img.png\" alt=\"д№—гӮҠжҸӣгҒҲ