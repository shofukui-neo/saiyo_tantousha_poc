{"url":"https://asahi-ad.co.jp/recruiting/job/","html":"<!DOCTYPE html>\r\n<html lang=\"ja\">\r\n\r\n<head>\r\n<!-- Google Tag Manager -->\r\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\r\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\r\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\r\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\r\n})(window,document,'script','dataLayer','GTM-53RNMQF');</script>\r\n<!-- End Google Tag Manager -->\r\n    \r\n    <meta charset=\"UTF-8\">\r\n    <title>旭広告社の仕事を知る | 株式会社旭広告社 採用情報</title>\r\n    <meta name=\"description\" content=\"株式会社旭広告社の採用情報サイト、旭広告社の仕事を知るページです。各部門・各業種が、会社の中でどんな役割を持ち仕事をしているのか。実際の業務内容をご紹介いたします。\" />\r\n    <meta name=\"keywords\" content=\"2026,採用,新卒,中途,エントリー,広告,代理店,横浜,地域貢献\" />\r\n    <meta property=\"og:title\" content=\"株式会社旭広告社 採用情報\" />\r\n    <meta property=\"og:type\" content=\"website\" />\r\n    <meta property=\"og:url\" content=\"https://www.asahi-ad.co.jp/recruiting/\" />\r\n    <meta property=\"og:image\" content=\"https://www.asahi-ad.co.jp/recruiting/images/asahi_og.png\" />\r\n    <meta property=\"og:site_name\" content=\"株式会社旭広告社 採用情報\" />\r\n    <meta property=\"og:description\" content=\"横浜の総合広告代理店、株式会社旭広告社の採用情報サイトです。仕事内容・社員インタビュー・福利厚生など、採用に関する情報をご紹介します。\" />\r\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\">\r\n    <link href=\"https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500&family=Roboto&display=swap\" rel=\"stylesheet\">\r\n    <link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/yakuhanjp@3.4.1/dist/css/yakuhanjp-noto.min.css\">\r\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"../js/drawer/drawer.css\">\r\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"../css/base.css\">\r\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"../css/job.css\">\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no\" />\r\n\t\r\n<link rel=\"shortcut icon\" href=\"../favicon.ico\">\r\n<link rel=\"apple-touch-icon\" href=\"../apple-touch-icon.png\">\r\n<link rel=\"icon\" type=\"image/png\" href=\"../android-chrome-192x192.png\">\r\n</head>\r\n\r\n<body class=\"drawer drawer--right\">\r\n<!-- Google Tag Manager (noscript) -->\r\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-53RNMQF\"\r\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\r\n<!-- End Google Tag Manager (noscript) -->    \r\n    <div class=\"drawer_container\">\r\n        <button type=\"button\" class=\"drawer-toggle drawer-hamburger\">\r\n            <span class=\"sr-only\">toggle navigation</span>\r\n            <span class=\"drawer-hamburger-icon\"></span>\r\n        </button>\r\n        <nav class=\"drawer-nav\" role=\"navigation\">\r\n            <ul class=\"drawer-menu\">\r\n                <li class=\"drawer_logo\"><a href=\"../\"><img src=\"../images/footer_logo.png\" alt=\"株式会社旭広告社\"></a></li>\r\n                <li><a href=\"../\" class=\"drawer-menu-item\">HOME</a></li>\r\n                <li><a href=\"../message/\" class=\"drawer-menu-item\">社長メッセージ</a></li>\r\n                <li><a href=\"../interview/\" class=\"drawer-menu-item\">社員インタビュー</a></li>\r\n                <li><a href=\"../job/\" class=\"drawer-menu-item\">旭広告社の仕事を知る</a></li>\r\n                <li><a href=\"../data/\" class=\"drawer-menu-item\">DATAで見る旭広告社</a></li>\r\n                <li><a href=\"../welfare/\" class=\"drawer-menu-item\">福利厚生</a></li>\r\n                <li><a href=\"../environment/\" class=\"drawer-menu-item\">職場環境</a></li>\r\n                <li><a href=\"../recruit/\" class=\"drawer-menu-item\">採用情報</a></li>\r\n                <li class=\"st\">エントリー</li>\r\n                <li><a href=\"https://job.rikunabi.com/n/selection/job_descriptions/0fd0d43359bd8a60/?from=job_search\" class=\"drawer-menu-item\" target=\"new\" rel=\"nofollow\">新卒採用</a></li>\r\n                <li><a href=\"../recruit/#tab2\" class=\"drawer-menu-item\">中途採用</a></li>\r\n                <li class=\"st\">企業情報</li>\r\n                <li><a href=\"https://asahi-ad.co.jp/\" class=\"drawer-menu-item drawer-menu-item2\" target=\"_blank\">コーポレートサイト</a></li>\r\n                <li><a href=\"https://asahi-ad.co.jp/about/privacy-policy/\" class=\"drawer-menu-item drawer-menu-item2\" target=\"_blank\">プライバシーポリシー</a></li>\r\n            </ul>\r\n        </nav>\r\n    </div>\r\n\r\n    <header id=\"header\" class=\"cf\">\r\n        <p class=\"header_logo\"><a href=\"../\"><img src=\"../images/logo.png\" alt=\"株式会社旭広告社\"></a><span>RECRUIT</span></p>\r\n        <nav id=\"gnavi\">\r\n            <ul class=\"menu cf\">\r\n                <li><a href=\"../message/\">社長メッセージ</a></li>\r\n                <li><a href=\"../interview/\">社員インタビュー</a></li>\r\n                <li><a href=\"../job/\" class=\"on\">旭広告社の仕事を知る</a></li>\r\n                <li><a href=\"../data/\">DATAで見る旭広告社</a></li>\r\n                <li><a href=\"../welfare/\">福利厚生</a></li>\r\n                <li><a href=\"../environment/\">職場環境</a></li>\r\n                <li><a href=\"../recruit/\">採用情報</a></li>\r\n            </ul>\r\n            <ul class=\"entry\">\r\n                <li class=\"item\"><span>&gt; ENTRY</span>\r\n                    <ul class=\"child\">\r\n                        <!--<li><a href=\"../news/\">&gt; 新卒採用</a></li>-->\r\n                        <li><a href=\"https://job.rikunabi.com/n/selection/job_descriptions/0fd0d43359bd8a60/?from=job_search\" target=\"new\" rel=\"nofollow\">&gt; 新卒採用</a></li>\r\n                        <li><a href=\"../recruit/#tab2\">&gt; 中途採用</a></li>\r\n                    </ul>\r\n                </li>\r\n            </ul>\r\n        </nav>\r\n    </header>\r\n\r\n    <div id=\"page_title\">\r\n        <div class=\"inner1\">\r\n            <p>Job</p>\r\n            <h1>旭広告社の仕事を知る</h1>\r\n        </div>\r\n    </div>\r\n\r\n    <div id=\"breadcrumb\">\r\n        <div class=\"inner1\">\r\n            <ul class=\"cf\">\r\n                <li><a href=\"../\">ホーム</a></li>\r\n                <li>旭広告社の仕事を知る</li>\r\n            </ul>\r\n        </div>\r\n    </div>\r\n\r\n    <section id=\"job1\">\r\n        <div class=\"inner1\">\r\n            <h2>私たちの使命は、<br>お客様の商品が<br class=\"pc_br_none\">売れるようにすること。</h2>\r\n            <p>電柱広告から交通広告、インターネットサイトの構築、ポスター、パンフレットの制作、イベント運営まで、<br class=\"br_768_none\">\r\n                様々な業務を行っている当社では、総合広告代理店として多くの領域を手掛けられる「機能」をもっているため、<br class=\"br_768_none\">\r\n                お客様のニーズに応えるべき、提案をさせていただいております。</p>\r\n            <figure><img src=\"images/job01.png\" alt=\"\"></figure>\r\n        </div>\r\n    </section>\r\n\r\n    <section id=\"job2\" class=\"job_container\">\r\n        <h2>営業部門</h2>\r\n        <div class=\"inner1\">\r\n            <ul class=\"job_office\">\r\n                <li>営業１部</li>\r\n                <li>東京営業所</li>\r\n                <!--<li>県央営業所</li>-->\r\n                <li>沼津営業所</li>\r\n                <li class=\"pc_none\">クロスメディア部</li>\r\n                <li class=\"pc_none\">営業２部</li>\r\n                <li class=\"pc_none\">媒体部</li>\r\n\t\t\t\t<li class=\"pc_none\">デジタルマーケティング室</li>\r\n            </ul>\r\n            <ul class=\"job_office sp_none\">\r\n                <li>クロスメディア部</li>\r\n                <li>営業２部</li>\r\n                <li>媒体部</li>\r\n\t\t\t\t<li>デジタルマーケティング室</li>\r\n            </ul>\r\n            <div class=\"job_box\">\r\n                <div class=\"job_box_txt cf\">\r\n                    <figure><img src=\"images/job_a.jpg\" alt=\"営業\"></figure>\r\n                    <h3>営業</h3>\r\n                    <p>クライアントの課題解決に向けた広告提案を行う仕事です。マーケティングリサーチ、企画提案、予算やスケジュール管理といった幅広い業務を行います。あらゆるメディアを利用して、クライアント（広告主）と消費者（ターゲットユーザー）を結びつけるお手伝いをする業務です。</p>\r\n                    <p>個人で担当エリアの新規開拓や既存顧客への追加営業、またチームでの企画営業など営業スタイルは様々です。クライアントの要望をデザイナー、媒体社、印刷会社、施行会社、など社内外の関係各所と協力して提案し、カタチにしていきます。</p>\r\n                    <p>お客様は、民間企業のみならず、行政との取引も多く、たくさんのお客様、関係者と関わりを持てるお仕事です。</p>\r\n                </div>\r\n                <h4>【 お仕事の例 】</h4>\r\n                <ul class=\"job_example cf\">\r\n                    <li>担当エリアを持ち、電柱広告販売を中心にセールスを行います。<br>\r\n                        空き電柱の調査、掲出場所やデザインのご提案、ご契約後は電柱の取り付け位置など細かな調整も行います。<br>\r\n                        お客様のニーズに合った多媒体の広告提案も行います。</li>\r\n                    <li>医業関連のお客さまには、医療法広告規制に基づいて開院前～開院後に至るまでをトータルにサポートします。<br>\r\n                        ロゴマーク、名刺、診察券、チラシ、屋内・屋外サイン、Webサイト等、集患・増患に適した広告展開を立案・実施します。</li>\r\n                    <li>電車の中吊り広告、駅構内のデジタルサイネージ、バスの案内放送等、様々な交通広告をエリアマーケティングのノウハウを活用してご提案します。<br>\r\n                        空き状況調査、お見積りの提出、媒体社との調整も行います。</li>\r\n                    <li>各種式典、講演会、イベント等の企画や運営を行います。<br>\r\n                        イベントの告知、ゲスト・MC等のキャスティング、装飾施行、キャンペーンや、ノベルティの制作、会場の設営、事務局の運営、当日の進行～撤去に至るまで、運営業務全般に携わります。</li>\r\n                </ul>\r\n                <div class=\"job_aptitude\">\r\n                    <figure><img src=\"images/job_icon1.png\" alt=\"\"></figure>\r\n                    <h4>\\ こんな方に向いています！ /</h4>\r\n                    <ul class=\"cf\">\r\n                        <li>好奇心旺盛の方</li>\r\n                        <li>人と話すのが好きな方</li>\r\n                        <li>発想力が豊かな方</li>\r\n                        <li>お客様の懐に入れる方</li>\r\n                    </ul>\r\n                </div>\r\n            </div>\r\n\r\n            <div class=\"job_box\">\r\n                <div class=\"job_box_txt cf\">\r\n                    <figure><img src=\"images/job_b.jpg\" alt=\"営業サポート\"></figure>\r\n                    <h3>営業サポート</h3>\r\n                    <p>営業担当者がスムーズに業務を行えるよう、あらゆる面でサポートすることが主な業務です。<br>電話・来客応対をはじめ、クライアント対応、管理業務や資料作成などを行います。営業担当からの依頼に迅速に対応することにより、効率良く営業が出来るようにサポートします。</p>\r\n                </div>\r\n                <div class=\"job_aptitude\">\r\n                    <figure><img src=\"images/job_icon2.png\" alt=\"\"></figure>\r\n                    <h4>\\ こんな方に向いています！ /</h4>\r\n                    <ul class=\"cf\">\r\n                        <li>臨機応変に対応できる方</li>\r\n                        <li>人が喜ぶことに生きがいを感じる方</li>\r\n                        <li>機転を利かせられる方</li>\r\n                        <li>柔軟な対応のできる方</li>\r\n                    </ul>\r\n                </div>\r\n            </div>\r\n        </div>\r\n    </section>\r\n\r\n    <section id=\"job3\" class=\"job_container\">\r\n        <h2>制作部門</h2>\r\n        <div class=\"inner1\">\r\n            <ul class=\"job_office\">\r\n                <li>企画制作部</li>\r\n            </ul>\r\n\r\n            <div class=\"job_box\">\r\n                <div class=\"job_box_txt cf\">\r\n                    <figure><img src=\"images/job_c.jpg\" alt=\"制作部門\"></figure>\r\n                    <p>営業やプランナーと共に、クライアントのSPツール及びプロモーション全般の企画・提案、制作進行管理を行う仕事です。<br>紙媒体の制作から、WEB広告やHPの制作など幅広いツールのクリエイティブ業務に携わり、クライアントの意向に沿って、効果的なデザインをご提案します。</p>\r\n                </div>\r\n                <div class=\"job_aptitude\">\r\n                    <figure><img src=\"images/job_icon1.png\" alt=\"\"></figure>\r\n                    <h4>\\ こんな方に向いています！ /</h4>\r\n                    <ul class=\"cf\">\r\n                        <li>クオリティーを追及できる方</li>\r\n                        <li>アイデアが豊富な方</li>\r\n                        <li>仕事に集中できる方</li>\r\n                        <li>お客様の要望を的確に理解できる方</li>\r\n                    </ul>\r\n                </div>\r\n            </div>\r\n        </div>\r\n    </section>\r\n\r\n    <section id=\"job4\" class=\"job_container\">\r\n        <h2>管理部門</h2>\r\n        <div class=\"inner1\">\r\n            <ul class=\"job_office\">\r\n                <li>総務部</li>\r\n                <li>経理部</li>\r\n                <li>システム部</li>\r\n            </ul>\r\n\r\n            <div class=\"job_box\">\r\n                <div class=\"job_box_txt cf\">\r\n                    <figure><img src=\"images/job_d.jpg\" alt=\"管理部門\"></figure>\r\n                    <p>主に全従業員の業務サポートを行う部門です。<br>総務部では人事、法務、労務、広報から社員教育、採用業務さらに庶務までを行い、経理部では資産を管理し会計や財務業務、日々の出納業務などを行っています。システム部は会社全体のあらゆるシステム管理を担っています。会社を円滑に運営していくためにはなくてはならないセクションです。</p>\r\n                </div>\r\n                <div class=\"job_aptitude\">\r\n                    <figure><img src=\"images/job_icon2.png\" alt=\"\"></figure>\r\n                    <h4>\\ こんな方に向いています！ /</h4>\r\n                    <ul class=\"cf\">\r\n                        <li>責任感の強い方</li>\r\n                        <li>仕事の優先順位を見極められる方</li>\r\n                        <li>仕事が早い方</li>\r\n                        <li>数字に強い方</li>\r\n                    </ul>\r\n                </div>\r\n            </div>\r\n        </div>\r\n    </section>\r\n\r\n    <section id=\"foot_recruit\">\r\n        <div class=\"inner1 cf\">\r\n            <h2>採用情報</h2>\r\n            <ul class=\"cf\">\r\n                <li><a href=\"../recruit/#tab1\">\r\n                        <figure><img src=\"../images/foot_recruit2.png\" alt=\"新卒採用情報\"></figure>\r\n                        <p>新卒採用情報</p>\r\n                    </a></li>\r\n                <li><a href=\"../recruit/#tab2\">\r\n                        <figure><img src=\"../images/foot_recruit3.png\" alt=\"中途採用情報\"></figure>\r\n                        <p>中途採用情報</p>\r\n                    </a></li>\r\n            </ul>\r\n        </div>\r\n    </section>\r\n\r\n    <footer id=\"footer\">\r\n        <div class=\"inner1 cf\">\r\n            <div class=\"footer_txt\">\r\n                <p><a href=\"../\"><img src=\"../images/footer_logo.png\" alt=\"株式会社旭広告社\"></a></p>\r\n                <p class=\"p1\">〒231-0014　神奈川県横浜市中区常盤町2-19<br>TEL: 045-681-2831</p>\r\n            </div>\r\n            <ul class=\"ul1\">\r\n                <li><a href=\"../message/\">社長メッセージ</a></li>\r\n                <li><a href=\"../interview/\">社員インタビュー</a></li>\r\n                <li><a href=\"../job/\">旭広告社の仕事を知る</a></li>\r\n                <li><a href=\"../data/\">DATAで見る</a></li>\r\n            </ul>\r\n\r\n            <ul class=\"ul1\">\r\n                <li><a href=\"../welfare/\">福利厚生</a></li>\r\n                <li><a href=\"../environment/\">職場環境</a></li>\r\n                <li><a href=\"../recruit/#tab1\">新卒採用情報</a></li>\r\n                <li><a href=\"../recruit/#tab1\">中途採用情報</a></li>\r\n            </ul>\r\n\r\n            <ul class=\"ul2\">\r\n                <li><a href=\"https://asahi-ad.co.jp/\" target=\"_blank\"><img src=\"../images/icon1.png\" alt=\"\">コーポレートサイト</a></li>\r\n                <li><a href=\"https://asahi-ad.co.jp/about/privacy-policy/\" target=\"_blank\"><img src=\"../images/icon1.png\" alt=\"\">プライバシーポリシー</a></li>\r\n            </ul>\r\n        </div>\r\n        <div id=\"copyright\">\r\n            <div class=\"inner1\">\r\n                <p>&copy; ASAHI ADVERTISING, INC.</p>\r\n            </div>\r\n        </div>\r\n    </footer>\r\n    <div id=\"pagetop\"><a href=\"#\"><img src=\"../images/pagetop.png\" alt=\"Pagetop\"></a></div>\r\n\r\n<script type=\"text/javascript\" src=\"https://cdnjs.cloudflare.com/ajax/libs/jquery/1.11.1/jquery.min.js\"></script>\r\n\r\n    <script src=\"../js/script1.js\" type=\"text/javascript\"></script>\r\n    <script src=\"../js/drawer/drawer.js\" type=\"text/javascript\"></script>\r\n    <script src=\"../js/drawer/iscroll.js\" type=\"text/javascript\"></script>\r\n    <script src=\"../js/drawer/drawer2.js\" type=\"text/javascript\"></script>\r\n</body></html>\r\n","finalUrl":"https://asahi-ad.co.jp/recruiting/job/","rendered":false,"_cachedAt":"2026-06-22T21:48:05.470Z"}