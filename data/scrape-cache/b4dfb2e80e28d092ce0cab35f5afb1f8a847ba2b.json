{"url":"https://www.query.jp/company/","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n<head>\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n<meta charset=\"UTF-8\">\n<title>会社情報｜株式会社クエリー</title>\n<meta name=\"description\" content=\"会社情報を紹介するページです。株式会社クエリーはソフトウェア開発・通信機器の導入・販売などを行う会社です。東京都千代田区と神奈川県厚木市にオフィスがあります。\" />\n<meta name=\"keywords\" content=\"会社情報\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1,user-scalable=no\">\n<meta name=\"format-detection\" content=\"telephone=no\">\n    <link rel=\"icon\" sizes=\"192x192\" href=\"/assets/img/android-icon.png\">\n    <link rel=\"apple-touch-icon\" href=\"/assets/img/apple-touch-icon.png\" />\n    <meta name=\"apple-mobile-web-app-title\" content=\"クエリー\">\n    <meta name=\"application-name\" content=\"クエリー\">\n<link rel=\"stylesheet\" href=\"/assets/css/pc.css\" type=\"text/css\" media=\"all\">\n<link rel=\"stylesheet\" href=\"/assets/css/sp.css\" type=\"text/css\" media=\"screen and (max-width:640px)\">\n<link rel=\"stylesheet\" href=\"/assets/css/parts.css\" type=\"text/css\" media=\"all\">\n  <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\">\n    <link href=\"https://fonts.googleapis.com/css2?family=Bodoni+Moda:wght@400;500;600;700;800;900&display=swap\" rel=\"stylesheet\">\n    <script src=\"/assets/js/jquery-1.11.3.min.js\"></script>\n  <script src=\"/assets/js/loading.js\"></script>\n  <script src=\"/assets/js/common.js\"></script>\n<script src=\"/assets/js/parts.js\"></script>\n<!-- This Page only -->\n<script src=\"/assets/js/jquery.tile.js\"></script>\n<script type=\"text/javascript\">\n$(document).ready(function(){\nif ($(window).width() > 640) {\n\t$(window).on(\"load resize\", function(){\n\t\t\t$('.flexBox').each(function(i){\n\t\t\t\t\t$(this).find('div').tile(3);\n\t\t\t});\n\t});\n}\n});\n</script>\n<!-- This Page only -->\n<!--[if !IE]><!-->\n\n<!--<![endif]-->\n<!--[if lt IE 9]>\n<script src=\"js/html5shiv.min.js\"></script>\n<script src=\"js/respond.mi