ref');\n          const target = $(href == '#' || href == '' ? 'html' : href);\n          const position = target.offset().top;\n\n          $('html, body').animate({\n            scrollTop: position\n          }, speed, 'swing');\n          return false;\n        });\n      });\n    </script>\n  </body>\n</html>","finalUrl":"https://www.kokudoec.co.jp/recruit/company/","rendered":false,"_cachedAt":"2026-06-23T22:38:21.318Z"}