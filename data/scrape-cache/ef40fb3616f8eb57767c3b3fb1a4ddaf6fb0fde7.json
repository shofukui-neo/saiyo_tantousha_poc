",\"08f5eda1dfd9f09363e672141a608ef61aa9d0d1f2228499d5e20d280f5d039c\",\"87da6248640d2d94a5cdadbc80c1f2ce3ec3811d374cfd18f75e179250d4432d\",\"f55864ff2b57975c28d0de7839515f5562e0a36f48eb9dc09e2595fb6cc59168\",\"63292acc59fc668e1e7749ad750095773d77b443a35eb43687dfd0832e8d577c\"]);</script>\n<!-- Google Tag Manager -->\n<script>\n    var now = new Date();\n    var afiID = ('0'+(now.getMonth()+1)).slice(-2)+('0'+now.getDate()).slice(-2)+('0'+now.getSeconds()).slice(-2);\n        dataLayer.push({'afiID': afiID});\n                        dataLayer.push({'segments': []});\n        \n    (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\n        new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\n        j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n        'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n    })(window,document,'script','dataLayer', 'GTM-W7FT57K');\n        </script>\n<!-- End Google Tag Manager -->\n        <meta charset=\"UTF-8\">\n        <link rel=\"icon\" type=\"image/x-icon\" href=\"/favicon_agent.ico\">\n\n                        \n        <meta property=\"og:title\" content=\"運営会社｜キャリアチケット\" />\n<meta property=\"og:type\" content=\"website\" />\n<meta property=\"og:url\" content=\"https://careerticket.jp/info/company/\" />\n<meta property=\"og:image\" content=\"https://careerticket.jp/img/ogp/careerticket.webp\" />\n<meta property=\"og:site_name\" content=\"キャリアチケット就職\" />\n<meta property=\"og:description\" content=\"『キャリアチケット』はレバレジーズ株式会社が運営しています。運営会社ページです。新卒就活で、エントリーシートや面接がうまくいかない、業界研究や企業探しに苦労している、という方はぜひご相談ください。\" />\n<meta property=\"og:locale\" content=\"ja_JP\" />\n<meta property=\"fb:app_id\" content=\"1024867871027267\">\n<!--twitterの設定-->\n<meta name=\"twitter:card\" content=\"summary_large_image\">\n<meta name=\"twitter:site\" content=\"@careerticket\">\n<!-- InstanceBeginEditable name=\"doctitle\" -->\n<title>運営会社｜キャリアチケット</title>\n<meta name=\"Description\" content=\"『キャリアチケット』はレバレジーズ株式会社が運営しています。運営会社ページです。新卒就活で、エントリーシートや面接がうまくいかない、業界研究や企業探しに苦労している、という方はぜひご相談ください。\">\n<meta name=\"Keywords\" content=\"運営会社,キャリアチケット,新卒,就活,内定,エントリーシート,面接対策,業界研究\">\n<link rel=\"canonical\" href=\"https://careerticket.jp/info/company/\"><meta name=\"robots\" content=\"index,follow\">\n<!--パンくず-->\n    <script type=\"application/ld+json\">\n        {\"@context\":\"http:\\/\\/schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[[{\"@type\":\"ListItem\",\"position\":1,\"item\":{\"name\":\"\\u30ad\\u30e3\\u30ea\\u30a2\\u30c1\\u30b1\\u30c3\\u30c8\\u5c31\\u8077TOP\",\"@id\":\"https:\\/\\/careerticket.jp\"}},{\"@type\":\"ListItem\",\"position\":2,\"item\":{\"name\":\"\\u904b\\u55b6\\u4f1a\\u793e\"}}]]}\n   </script>\n<meta name=\"facebook-domain-verification\" content=\"gtpk0872k9k02hbn1qw4w27qprd3se\" />\n                <link rel=\"stylesheet\" href=\"https://careerticket.jp/build/assets/defaultNew-D_Jxa8cn.css?1781763702\">\n        \n<link rel=\"stylesheet\" href=\"https://careerticket.jp/build/assets/info_company-DFhSx_kI.css?1781763702\">\n        <!-- optimizely -->\n        <script src=\"https://cdn.optimizely.com/js/25654440446.js\"></script>\n            </head>\n\n    <body class=\"page\" id=\"top\">\n        <!-- Google Tag Manager (noscript) -->\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-W7FT57K\"\n                  height=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n<!-- End Google Tag Manager (noscript) -->\n        <div class=\"l-wrapper\">\n            <div class=\"l-header\">\n    <div class=\"p-headerNew js-fixedHeader js-header \">\n    <div class=\"p-headerNew__inner\">\n        <p class=\"p-headerNew__logo\"><a href=\"https://careerticket.jp\" data-click-label=\"data-click-ヘッダー_ロゴ\"><img src=\"/img/pc/commonNew/logo_career-ticket_row_pb.svg\" width=\"200\" height=\"48\" alt=\"キャリアチケット就職\" data-view-label=\"data-view-ヘッダー_ロゴ\"></a></p>\n        <nav class=\"p-headerNew__glonavi\">\n            <ul class=\"p-headerNew__glonaviList\">\n                <li class=\"p-headerNew__glonaviItem\">\n                    <p class=\"p-headerNew__glonaviItemNestLabel\" data-click-label=\"data-click-ヘッダー_就職エージェント\">就職エージェント</p>\n                    <ul class=\"p-headerNew__glonaviNest\">\n    <li class=\"p-headerNew__glonaviNestItem\"><a href=\"https://careerticket.jp/2027/\" data-click-label=\"data-click-ヘッダー_就職エージェント_n+1卒\">2027年卒業予定の方はこちら<i class=\"c-icn--arrowRight\"></i></a></li>\n    <li class=\"p-headerNew__glonaviNestItem\"><a href=\"https://careerticket.jp/2028/\" data-click-label=\"data-click-ヘッダー_就職エージェント_n+2卒\">2028年卒業予定の方はこちら<i class=\"c-icn--arrowRight\"></i></a></li>\n    <li class=\"p-headerNew__glonaviNestItem\"><a href=\"https://careerticket.jp/2029/\" data-click-label=\"data-click-ヘッダー_就職エージェント_n+3卒\">2029年卒業予定の方はこちら<i class=\"c-icn--arrowRight\"></i></a></li>\n    <li class=\"p-headerNew__glonaviNestItem\"><a href=\"https://careerticket.jp/adviser/\" data-click-label=\"data-click-ヘッダー_就職エージェント_アドバイザー紹介\">アドバイザー紹介<i class=\"c-icn--arrowRight\"></i></a></li>\n    <li class=\"p-headerNew__glonaviNestItem\"><a href=\"https://careerticket.jp/faq/\" data-click-label=\"data-click-ヘッダー_就職エージェント_よくある質問\">よくある質問<i class=\"c-icn--arrowRight\"></i></a></li>\n</ul>                </li>\n                <li class=\"p-headerNew__glonaviItem\"><a href=\"https://media.careerticket.jp/?page=top&mark=gn\" target=\"_blank\" rel=\"noopener\" data-click-label=\"data-click-ヘッダー_就職スカウト\">就職スカウト</a></li>\n                <li class=\"p-headerNew__glonaviItem\"><a href=\"https://careerticket.jp/event/\" data-click-label=\"data-click-ヘッダー_セミナー・イベント\">セミナー・イベント</a></li>\n                <li class=\"p-headerNew__glonaviItem\"><a href=\"https://careerticket.jp/media/\" data-click-label=\"data-click-ヘッダー_記事メディア\">記事メディア</a></li>\n\n                                    <li class=\"p-headerNew__glonaviItem\"><a href=\"https://careerticket.jp/partner/concept/\" data-click-label=\"data-click-ヘッダー_企業の方へ\">企業の方へ</a></li>\n                            </ul>\n        </nav>\n\n                    <div class=\"p-headerNew__btnArea\">\n                            <p class=\"p-headerNew__btn c-btnNew--cta\"><a href=\"https://careerticket.jp/entry/input/\" rel=\"nofollow\" data-click-label=\"data-click-ヘッダー_無料で登録\">無料で登録<i class=\"c-icn--arrowRight\"></i></a></p>\n                        </div>\n            </div>\n</div>\n</div>            <div class=\"l-containerNew\">\n                                    <div class=\"p-breadcrumbNew\">\n        <ul class=\"p-breadcrumbNew__inner\">\n                                                <li class=\"p-breadcrumbNew__list\" itemscope itemtype=\"http://schema.org/Breadcrumb\"><a href=\"https://careerticket.jp\" itemprop=\"url\"><span itemprop=\"title\">キャリアチケット就職TOP</span></a></li>\n                                                                <li class=\"p-breadcrumbNew__list\">運営会社</li>\n                                    </ul>\n    </div>\n                                <div class=\"l-contentNew--tertiary\">\n  <div class=\"p-pageLayout__headCont\">\n    <h1 class=\"p-pageLayout__headContTtl--breadcrumbs l-contentNew__inner\">\n      運営会社\n    </h1>\n  </div>\n  <div class=\"p-pageLayout__mainCont l-contentNew__inner\">\n    <div class=\"c-cardNew\">\n      <ul class=\"p-document\">\n        <li class=\"p-document__item\">\n          <ul class=\"p-document__paragraph\">\n            <li class=\"p-document__paragraph\">\n              キャリアチケット就職を運営するレバレジーズ株式会社は、エンジニア・医療領域を軸に様々な業界のキャリアサポートを行っている会社です。多様な業界/職種の方々のキャリアをサポートしてきたノウハウを活かし、あなたの就活活動を応援します。\n            </li>\n            <li class=\"p-document__paragraph\">\n              「最高のキャリアスタートを支援する」 <br />\n              これが、キャリアチケット就職の思いです。\n            </li>\n            <li class=\"p-document__paragraph\">\n              就活生には後悔しない就職先を、企業には求める層の採用機会を提供できるよう、常にサービス内容を改善しています。\n            </li>\n            <li class=\"p-document__paragraph\">\n              より多くの若者に安心できる将来を。\n            </li>\n          </ul>\n        </li>\n\n        <li class=\"p-document__item\">\n          <section class=\"p-infoCompany p-box\">\n            <div class=\"p-infoCompany__inner\">\n              <h2 class=\"p-box__label\">レバレジーズ株式会社　概要</h2>\n              <div class=\"p-box__content\">\n                <ul class=\"p-infoCompany__attention\">\n                  <li class=\"p-infoCompany__attention__element\">\n                    <div class=\"p-infoCompany__attention__label\">\n                      <p>設立</p>\n                    </div>\n                    <p>2005年4月6日</p>\n                  </li>\n                  <li class=\"p-infoCompany__attention__element\">\n                    <div class=\"p-infoCompany__attention__label\">\n                      <p>資本金</p>\n                    </div>\n                    <p>5000万円</p>\n                  </li>\n                  <li class=\"p-infoCompany__attention__element\">\n                    <div class=\"p-infoCompany__attention__label\">\n                      <p>代表取締役</p>\n                    </div>\n                    <p>岩槻 知秀</p>\n                  </li>\n                  <li class=\"p-infoCompany__attention__element\">\n                    <div class=\"p-infoCompany__attention__label\">\n                      <p>認定</p>\n                    </div>\n                    <p>\n                      有料職業紹介事業許可番号　13-ユ-302698<br />\n                      労働者派遣事業許可番号　派13-302333\n                    </p>\n                  </li>\n                  <li class=\"p-infoCompany__attention__element\">\n                    <div class=\"p-infoCompany__attention__label\">\n                      <p>事業内容</p>\n                    </div>\n                    <p>\n                      自社メディア事業／人材関連事業／システムエンジニアリング事業\n                    </p>\n                  </li>\n                </ul>\n              </div>\n            </div>\n          </section>\n        </li>\n\n        <li class=\"p-document__item\">\n          <section class=\"p-infoCompany p-box\">\n            <div class=\"p-infoCompany__inner\">\n              <h2 class=\"p-box__label\">所在地</h2>\n              <div class=\"p-box__content\">\n                <ul class=\"p-infoCompany__attention\">\n                  <li class=\"p-infoCompany__attention__element\">\n                    <div class=\"p-infoCompany__attention__label\">\n                      <p>本社</p>\n                    </div>\n                    <p>\n                      〒150-6190　東京都渋谷区渋谷2-24-12\n                      渋谷スクランブルスクエア 24F・25F\n                    </p>\n                  </li>\n                  <li class=\"p-infoCompany__attention__element\">\n                    <div class=\"p-infoCompany__attention__label\">\n                      <p>道玄坂支店</p>\n                    </div>\n                    <p>\n                      〒150-0043　東京都渋谷区道玄坂2-11-1 JMFビル渋谷03 7F・8F・9F\n                    </p>\n                  </li>\n                  <li class=\"p-infoCompany__attention__element\">\n                    <div class=\"p-infoCompany__attention__label\">\n                      <p>半蔵門支店</p>\n                    </div>\n                    <p>\n                      〒102-0083　東京都千代田区麹町2-3-2 半蔵門PREX North 4F\n                    </p>\n                  </li>\n                  <li class=\"p-infoCompany__attention__element\">\n                    <div class=\"p-infoCompany__attention__label\">\n                      <p>渋谷支店</p>\n                    </div>\n                    <p>\n                      〒150-0002　東京都渋谷区渋谷3-6-3 渋谷363清水ビル3F\n                    </p>\n                  </li>\n                  <li class=\"p-infoCompany__attention__element\">\n                    <div class=\"p-infoCompany__attention__label\">\n                      <p>池袋支店</p>\n                    </div>\n                    <p>\n                      〒171-0022　東京都豊島区南池袋1-16-15\n                      ダイヤゲート池袋5F\n                    </p>\n                  </li>\n                  <li class=\"p-infoCompany__attention__element\">\n                    <div class=\"p-infoCompany__attention__label\">\n                      <p>大阪支店</p>\n                    </div>\n                    <p>\n                      〒530-0014　大阪府大阪市北区鶴野町1-9\n                      梅田ゲートタワー10F\n                    </p>\n                  </li>\n                </ul>\n              </div>\n            </div>\n          </section>\n        </li>\n\n        <li class=\"p-document__item\">\n          <section class=\"p-infoCompany p-box\">\n            <div class=\"p-infoCompany__inner\">\n              <h2 class=\"p-box__label\">沿革</h2>\n              <div class=\"p-box__content\">\n                <ul class=\"p-infoCompany__attention\">\n                  <li class=\"p-infoCompany__attention__element\">\n                    <div class=\"p-infoCompany__attention__label\">\n                      <p>2005.04</p>\n                    </div>\n                    <p>レバレジーズ株式会社を設立・SES事業を開始</p>\n                  </li>\n                  <li class=\"p-infoCompany__attention__element\">\n                    <div class=\"p-infoCompany__attention__label\">\n                      <p>2005.06</p>\n                    </div>\n                    <p>業務拡張により西早稲田（ヨートー早稲田ビル）に移転</p>\n                  </li>\n                  <li class=\"p-infoCompany__attention__element\">\n                    <div class=\"p-infoCompany__attention__label\">\n                      <p>2006.09</p>\n                    </div>\n                    <p>業務拡張により早稲田（キリン1stビル）に移転</p>\n                  </li>\n                  <li class=\"p-infoCompany__attention__element\">\n                    <div class=\"p-infoCompany__attention__label\">\n                      <p>2007.09</p>\n                    </div>\n                    <p>大阪支店設立</p>\n                  </li>\n                  <li class=\"p-infoCompany__attention__element\">\n                    <div class=\"p-infoCompany__attention__label\">\n                      <p>2007.10</p>\n                    </div>\n                    <p>人材紹介事業を開始</p>\n                  </li>\n                  <li class=\"p-infoCompany__attention__element\">\n                    <div class=\"p-infoCompany__attention__label\">\n                      <p>2008.05</p>\n                    </div>\n                    <p>業務拡張により渋谷（新大宗円山ビル）に移転</p>\n                  </li>\n                  <li class=\"p-infoCompany__attention__element\">\n                    <div class=\"p-infoCompany__attention__label\">\n                      <p>2009.10</p>\n                    </div>\n                    <p>看護師紹介事業を開始</p>\n                  </li>\n                  <li class=\"p-infoCompany__attention__element\">\n                    <div class=\"p-infoCompany__attention__label\">\n                      <p>2010.09</p>\n                    </div>\n                    <p>業務拡張により渋谷（渋谷プライムプラザ）に移転</p>\n                  </li>\n                  <li class=\"p-infoCompany__attention__element\">\n                    <div class=\"p-infoCompany__attention__label\">\n                      <p>2011.04</p>\n                    </div>\n                    <p>資本金を5000万円に増資</p>\n                  </li>\n                  <li class=\"p-infoCompany__attention__element\">\n                    <div class=\"p-infoCompany__attention__label\">\n                      <p>2011.08</p>\n                    </div>\n                    <p>業務拡張により大阪支店移転</p>\n                  </li>\n                  <li class=\"p-infoCompany__attention__element\">\n                    <div class=\"p-infoCompany__attention__label\">\n                      <p>2012.05</p>\n                    </div>\n                    <p>福岡支店設立</p>\n                  </li>\n                  <li class=\"p-infoCompany__attention__element\">\n                    <div class=\"p-infoCompany__attention__label\">\n                      <p>2012.08</p>\n                    </div>\n                    <p>\n                      業務拡張により渋谷（渋谷ヒカリエ）に移転・名古屋支店設立\n                    </p>\n                  </li>\n                  <li class=\"p-infoCompany__attention__element\">\n                    <div class=\"p-infoCompany__attention__label\">\n                      <p>2012.11</p>\n                    </div>\n                    <p>佐賀支店設立</p>\n                  </li>\n                  <li class=\"p-infoCompany__attention__element\">\n                    <div class=\"p-infoCompany__attention__label\">\n                      <p>2013.03</p>\n                    </div>\n                    <p>京都営業所設立・札幌営業所設立</p>\n                  </li>\n                  <li class=\"p-infoCompany__attention__element\">\n                    <div class=\"p-infoCompany__attention__label\">\n                      <p>2013.09</p>\n                    </div>\n                    <p>さいたま支店設立</p>\n                  </li>\n                  <li class=\"p-infoCompany__attention__element\">\n                    <div class=\"p-infoCompany__attention__label\">\n                      <p>2013.12</p>\n                    </div>\n                    <p>広島支店設立</p>\n                  </li>\n                  <li class=\"p-infoCompany__attention__element\">\n                    <div class=\"p-infoCompany__attention__label\">\n                      <p>2014.04</p>\n                    </div>\n                    <p>渋谷支店設立</p>\n                  </li>\n                  <li class=\"p-infoCompany__attention__element\">\n                    <div class=\"p-infoCompany__attention__label\">\n                      <p>2014.09</p>\n                    </div>\n                    <p>立川支店設立</p>\n                  </li>\n                  <li class=\"p-infoCompany__attention__element\">\n                    <div class=\"p-infoCompany__attention__label\">\n                      <p>2015.03</p>\n                    </div>\n                    <p>\n                      厚生労働省認可「職業紹介優良事業者」に認定<br />\n                      レバレジーズ・ベンチャーズ有限責任事業組合（LLP）を設立\n                    </p>\n                  </li>\n                  <li class=\"p-infoCompany__attention__element\">\n                    <div class=\"p-infoCompany__attention__label\">\n                      <p>2015.04</p>\n                    </div>\n                    <p>\n                      厚生労働省より「若者キャリア応援制度」の実施事業者に認定<br />\n                      東京都渋谷区に100%出資関連会社「レバレジーズキャリア」を設立<br />\n                      船橋支店設立\n                    </p>\n                  </li>\n                  <li class=\"p-infoCompany__attention__element\">\n                    <div class=\"p-infoCompany__attention__label\">\n                      <p>2017.05</p>\n                    </div>\n                    <p>キャリアチケット渋谷支店設立</p>\n                  </li>\n                  <li class=\"p-infoCompany__attention__element\">\n                    <div class=\"p-infoCompany__attention__label\">\n                      <p>2017.10</p>\n                    </div>\n                    <p>池袋支店設立</p>\n                  </li>\n                  <li class=\"p-infoCompany__attention__element\">\n                    <div class=\"p-infoCompany__attention__label\">\n                      <p>2018.01</p>\n                    </div>\n                    <p>秋葉原支店設立</p>\n                  </li>\n                  <li class=\"p-infoCompany__attention__element\">\n                    <div class=\"p-infoCompany__attention__label\">\n                      <p>2018.08</p>\n                    </div>\n                    <p>船橋支店設立・キャリアチケット秋葉原支店設立</p>\n                  </li>\n                  <li class=\"p-infoCompany__attention__element\">\n                    <div class=\"p-infoCompany__attention__label\">\n                      <p>2018.11</p>\n                    </div>\n                    <p>キャリアチケット大阪支店設立</p>\n                  </li>\n                  <li class=\"p-infoCompany__attention__element\">\n                    <div c