{"url":"https://www.okb-kcs.co.jp/journal/2024/10_recruit_contents.html","html":"<!doctype html>\n<html lang=\"ja\"><!-- InstanceBegin template=\"/Templates/default02.dwt\" codeOutsideHTMLIsLocked=\"false\" --><head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<link rel=\"icon\" sizes=\"16x16 32x32 48x48\" href=\"/favicon.ico\">\n<link rel=\"apple-touch-icon\" href=\"/apple-touch-icon.png\">\n<!-- InstanceBeginEditable name=\"doctitle\" -->\n<title>まさかの、エンジニアやお！～新入社員による学生向けコンテンツ制作～ - 共立コンピューターサービス株式会社（KCS）</title>\n<meta name=\"keywords\" content=\"新人,研修,企画\">\n<meta name=\"description\" content=\"2024年度ITソリューション本部に配属された新入社員9名が、自身の経験を活かして、就職活動に役立つコンテンツを企画しました。\">\n<meta property=\"og:url\" content=\"https://www.okb-kcs.co.jp/journal/2024/10_recruit_contents.html\">\n<meta property=\"og:type\" content=\"article\">\n<meta property=\"og:title\" content=\"まさかの、エンジニアやお！～新入社員による学生向けコンテンツ制作～ - 共立コンピューターサービス株式会社（KCS）\">\n<meta property=\"og:description\" content=\"2024年度ITソリューション本部に配属された新入社員9名が、自身の経験を活かして、就職活動に役立つコンテンツを企画しました。\">\n<meta property=\"og:site_name\" content=\"共立コンピューターサービス株式会社（KCS）\">\n<meta property=\"og:image\" content=\"https://www.okb-kcs.co.jp/journal/2024/images/10_recruit_contents_p01.webp\">\n<!-- InstanceEndEditable -->\n<link href=\"https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css\" rel=\"stylesheet\" integrity=\"sha384-9ndCyUaIbzAi2FUVXJi0CjmCapSmO7SnpJef0486qhLnuZ2cdeRhO02iuK6FUUVM\" crossorigin=\"anonymous\">\n<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n<link href=\"https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;700&family=Quicksand:wght@500;700&display=swap\" rel=\"stylesheet\">\n<link href=\"../../css/default02.css\" rel=\"stylesheet\">\n\n<!-- Google Tag Manager -->\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n})(window,document,'script','dataLayer','GTM-5MB5TN');</script>\n<!-- End Google Tag Manager -->\n\n<!-- InstanceBeginEditable name=\"head\" -->\n<style type=\"text/css\">\nheader{\n    background: linear-gradient(to right, rgba(255,255,255,1) 0%,rgba(255,255,255,0) 90%),url('images/10_recruit_contents_p01.webp') center;\n    background-size: cover;\n}\n\n.balloon-start .faceicon {\n    float: left;\n    margin-right: -90px;\n    width: 80px;\n}\n.balloon-start .faceicon img{\n    border: solid 3px #d7ebfe;\n    border-radius: 50%;\n}\n.balloon-start .says {\n    display: inline-block;\n    position: relative; \n    margin: 5px 0 0 105px;\n    padding: 17px 13px;\n    border-radius: 12px;\n    background: #d7ebfe;\n}\n.balloon-start .says:after {\n    content: \"\";\n    display: inline-block;\n    position: absolute;\n    top: 18px; \n    left: -24px;\n    border: 12px solid transparent;\n    border-right: 12px solid #d7ebfe;\n}\n\n.balloon-end .faceicon {\n    float: right;\n    margin-left: -90px;\n    width: 80px;\n}\n.balloon-end .faceicon img{\n    border: solid 3px #f2f2f2;\n    border-radius: 50%;\n}\n.balloon-end .says {\n    display: inline-block;\n    position: relative; \n    margin: 5px 105px 0 0;\n    padding: 17px 13px;\n    border-radius: 12px;\n    background: #f2f2f2;\n    text-align:left;\n}\n.balloon-end .says:after {\n    content: \"\";\n    display: inline-block;\n    position: absolute;\n    top: 18px; \n    right: -24px;\n    border: 12px solid transparent;\n    border-left: 12px solid #f2f2f2;\n}\n</style>\n<!-- InstanceEndEditable -->\n</head>\n\n<body>\n<!-- Google Tag Manager (noscript) -->\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-5MB5TN\"\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n<!-- End Google Tag Manager (noscript) -->\n\n<!-- InstanceBeginEditable name=\"header\" -->\n<header>\n<div id=\"header\"></div>\n<div class=\"py-5 px-sm-5 lh-lg\" id=\"jumbotron\">\n<div class=\"container-fluid\">\n<h1 class=\"display-5 fw-bold bg-white d-inline\">まさかの、エンジニアやお！～新入社員による学生向けコンテンツ制作～</h1>\n<div class=\"col-md-8 bg-white pb-1\" id=\"description\">\n<div class=\"text-secondary small\">掲載日：2024年11月6日</div>\n<p class=\"fs-5 p-4\">2024年度ITソリューション本部に配属された新入社員9名が、自身の経験を活かして、就職活動に役立つコンテンツを企画しました。</p>\n<nav class=\"bg-white px-4\">\n<ul class=\"list-inline\">\n<li class=\"list-inline-item mt-2\"><a class=\"btn btn-success\" href=\"#content_1\" role=\"button\">行動分析</a></li>\n<li class=\"list-inline-item mt-2\"><a class=\"btn btn-success\" href=\"#content_2\" role=\"button\">不安解消</a></li>\n<li class=\"list-inline-item mt-2\"><a class=\"btn btn-success\" href=\"#content_3\" role=\"button\">キャッチコピー</a></li>\n<li class=\"list-inline-item mt-2\"><a class=\"btn btn-success\" href=\"#content_4\" role=\"button\">繋がり</a></li>\n</ul>\n</nav>\n</div>\n</div><!-- /.container-fluid -->\n</div>\n</header>\n<!-- InstanceEndEditable -->\n\n<!-- InstanceBeginEditable name=\"main\" -->\n<main class=\"lh-lg\">\n<div class=\"container-fluid\">\n<div aria-label=\"breadcrumb\">\n<ol class=\"breadcrumb\">\n<li class=\"breadcrumb-item small\"><a href=\"../../index.html\">Home</a></li>\n<li class=\"breadcrumb-item small\"><a href=\"../index.html\">Webジャーナル</a></li>\n<li class=\"breadcrumb-item small active\" aria-current=\"page\">まさかの、エンジニアやお！～新入社員による学生向けコンテンツ制作～</li>\n</ol>\n</div>\n</div><!-- /.container-fluid -->\n\n<div class=\"container text-center py-5\">\n<div class=\"balloon-start text-start mb-3\">\n<div class=\"faceicon\"><img src=\"images/10_recruit_contents_p03.png\" alt=\"やっさん\" class=\"img-fluid rounded-circle\"></div>\n<div class=\"says\">\n<p class=\"m-0\">どんなコンテンツにする？みんな、就活してる時ってどんな感じだった？</p>\n</div>\n</div><!-- /.balloon-start -->\n<div class=\"balloon-end text-end mb-3\">\n<div class=\"faceicon\"><img src=\"images/10_recruit_contents_p11.png\" alt=\"すう\" class=\"img-fluid rounded-circle\"></div>\n<div class=\"says\">\n<p class=\"m-0\">採用サイトって、ザっとしか見なかったな～時間無いし、長い文章は…</p>\n</div>\n</div><!-- /.balloon-end -->\n<div class=\"balloon-end text-end mb-3\">\n<div class=\"faceicon\"><img src=\"images/10_recruit_contents_p08.png\" alt=\"まつ\" class=\"img-fluid rounded-circle\"></div>\n<div class=\"says\">\n<p class=\"m-0\">メールのやりとりが慣れてなくて、大変だった思い出</p>\n</div>\n</div><!-- /.balloon-end -->\n<div class=\"balloon-end text-end mb-3\">\n<div class=\"faceicon\"><img src=\"images/10_recruit_contents_p10.png\" alt=\"むらぴ\" class=\"img-fluid rounded-circle\"></div>\n<div class=\"says\">\n<p class=\"m-0\">就活マナーとか、面接で何聞かれるかな？とか、不安だった～</p>\n</div>\n</div><!-- /.balloon-end -->\n<div class=\"balloon-start text-start mb-5\">\n<div class=\"faceicon\"><img src=\"images/10_recruit_contents_p09.png\" alt=\"かと\" class=\"img-fluid rounded-circle\"></div>\n<div class=\"says\">\n<p class=\"m-0\">当時の状況を書き出してみようか！そこにヒントがあるかも</p>\n</div>\n</div><!-- /.balloon-start -->\n<div class=\"row py-5 g-4\">\n<div class=\"col-md-6\"><p><img src=\"images/10_recruit_contents_p14.webp\" alt=\"企画の様子\" class=\"img-fluid rounded\"></p></div>\n<div class=\"col-md-6\"><p><img src=\"images/10_recruit_contents_p15.webp\" alt=\"企画の様子\" class=\"img-fluid rounded\"></p></div>\n</div><!-- /.row -->\n</div><!-- /.container -->\n\n<div class=\"bg-light\">\n<div class=\"container-fluid text-center py-5\" id=\"content_1\">\n<h2 class=\"my-5\">就活時の行動と気持ち</h2>\n<div class=\"row py-5 g-4\">\n<div class=\"col-md-6\"><p><img src=\"images/10_recruit_contents_p12.webp\" alt=\"カスタマージャーニーマップ\" class=\"img-fluid\"></p></div>\n<div class=\"col-md-6\"><p><img src=\"images/10_recruit_contents_p13.webp\" alt=\"カスタマージャーニーマップ\" class=\"img-fluid\"></p></div>\n</div><!-- /.row -->\n</div><!-- /.container-fluid -->\n<div class=\"container text-center pb-5\">\n<div class=\"balloon-start text-start mb-3\">\n<div class=\"faceicon\"><img src=\"images/10_recruit_contents_p04.png\" alt=\"さと\" class=\"img-fluid rounded-circle\"></div>\n<div class=\"says\">\n<p class=\"m-0\">行動と気持ちって関係があるんだね。不安…会社の雰囲気…あと、メールについて何か企画できないかな？</p>\n</div>\n</div><!-- /.balloon-start -->\n<div class=\"balloon-end text-end mb-3\">\n<div class=\"faceicon\"><img src=\"images/10_recruit_contents_p07.png\" alt=\"たき\" class=\"img-fluid rounded-circle\"></div>\n<div class=\"says\">\n<p class=\"m-0\">学生の不安を解消できるコンテンツ。題して、「<a href=\"#content_2\">心配性でも不安ゼロ！</a>」</p>\n</div>\n</div><!-- /.balloon-end -->\n<div class=\"balloon-end text-end mb-3\">\n<div class=\"faceicon\"><img src=\"images/10_recruit_contents_p05.png\" alt=\"いお\" class=\"img-fluid rounded-circle\"></div>\n<div class=\"says\">\n<p class=\"m-0\">見せ方も工夫しよう！<a href=\"#content_3\">キャッチコピーとかキーワードとか</a>、直感的に分かるもの</p>\n</div>\n</div><!-- /.balloon-end -->\n<div class=\"balloon-end text-end mb-3\">\n<div class=\"faceicon\"><img src=\"images/10_recruit_contents_p06.png\" alt=\"かん\" class=\"img-fluid rounded-circle\"></div>\n<div class=\"says\">\n<p class=\"m-0\"><a href=\"#content_4\">企業とのやりとりの方法</a>も考えてみようよ！</p>\n</div>\n</div><!-- /.balloon-end -->\n<div class=\"balloon-start text-start mb-5\">\n<div class=\"faceicon\"><img src=\"images/10_recruit_contents_p03.png\" alt=\"やっさん\" class=\"img-fluid rounded-circle\"></div>\n<div class=\"says\">\n<p class=\"m-0\">良いね！3つのチームに分かれて進めよう！</p>\n</div>\n</div><!-- /.balloon-start -->\n</div><!-- /.container -->\n</div>\n\n<div class=\"container text-center py-5\" id=\"content_2\">\n<span class=\"text-success small\">＼　<strong>踏み出せ一歩！</strong>　／</span><br>\n<h2 class=\"mb-5\">心配性でも不安ゼロ！</h2>\n<div class=\"balloon-start text-start mb-3\">\n<div class=\"faceicon\"><img src=\"images/10_recruit_contents_p10.png\" alt=\"むらぴ\" class=\"img-fluid rounded-circle\"></div>\n<div class=\"says\">\n<p class=\"m-0\">コンテンツを見てくれる学生さんって、こんな感じかな？</p>\n</div>\n</div><!-- /.balloon-start -->\n<div class=\"my-5 p-4 rounded shadow\">\n<p class=\"mb-0\"><img src=\"images/10_recruit_contents_p02.webp\" alt=\"ペルソナ\" class=\"img-fluid\"></p>\n</div>\n<div class=\"balloon-end text-end mb-3\">\n<div class=\"faceicon\"><img src=\"images/10_recruit_contents_p04.png\" alt=\"さと\" class=\"img-fluid rounded-circle\"></div>\n<div class=\"says\">\n<p class=\"m-0\">エントリーどうするの？とか、仕事内容や職場の雰囲気…不安だったなぁ</p>\n</div>\n</div><!-- /.balloon-end -->\n<div class=\"balloon-end text-end mb-3\">\n<div class=\"faceicon\"><img src=\"images/10_recruit_contents_p07.png\" alt=\"たき\" class=\"img-fluid rounded-circle\"></div>\n<div class=\"says\">\n<p class=\"m-0\">エントリーについては、「<a href=\"../../recruit/entry/index.html#flow\">採用までの流れ</a>」を補足しようよ！</p>\n</div>\n</div><!-- /.balloon-end -->\n<div class=\"balloon-start text-start mb-3\">\n<div class=\"faceicon\"><img src=\"images/10_recruit_contents_p10.png\" alt=\"むらぴ\" class=\"img-fluid rounded-circle\"></div>\n<div class=\"says\">\n<p class=\"m-0\">具体的な仕事について、どうすると分かりやすいだろう</p>\n</div>\n</div><!-- /.balloon-start -->\n<div class=\"balloon-end text-end mb-3\">\n<div class=\"faceicon\"><img src=\"images/10_recruit_contents_p09.png\" alt=\"かと\" class=\"img-fluid rounded-circle\"></div>\n<div class=\"says\">\n<p class=\"m-0\">入社後のイメージに繋がるよう、先輩に「1日の流れ」を聞いてきたよ！</p>\n</div>\n</div><!-- /.balloon-end -->\n</div><!-- /.container -->\n<div class=\"container-fluid text-center\">\n<div class=\"mb-5 p-4 rounded shadow\">\n<div class=\"row py-2 g-4\">\n<div class=\"col-md-6\"><p class=\"mb-0\"><img src=\"images/10_recruit_contents_p16.webp\" alt=\"1日の流れ\" class=\"img-fluid\"></p></div>\n<div class=\"col-md-6\"><p class=\"mb-0\"><img src=\"images/10_recruit_contents_p17.webp\" alt=\"1日の流れ\" class=\"img-fluid\"></p></div>\n</div><!-- /.row -->\n</div>\n</div><!-- /.container-fluid -->\n<div class=\"container text-center pb-5\">\n<div class=\"balloon-end text-end mb-3\">\n<div class=\"faceicon\"><img src=\"images/10_recruit_contents_p04.png\" alt=\"さと\" class=\"img-fluid rounded-circle\"></div>\n<div class=\"says\">\n<p class=\"m-0\"><a href=\"../../prism/office/index.html\">Office-PRISM</a>と<a href=\"../../prism/web/index.html\">販売-PRISM</a>、製品によってやることも変わるね</p>\n</div>\n</div><!-- /.balloon-end -->\n<div class=\"balloon-end text-end mb-3\">\n<div class=\"faceicon\"><img src=\"images/10_recruit_contents_p10.png\" alt=\"むらぴ\" class=\"img-fluid rounded-circle\"></div>\n<div class=\"says\">\n<p class=\"m-0\">社内での作業だけじゃなく、お客様のところでの作業もあるんだね</p>\n</div>\n</div><!-- /.balloon-end -->\n<div class=\"balloon-start text-start mb-3\">\n<div class=\"faceicon\"><img src=\"images/10_recruit_contents_p09.png\" alt=\"かと\" class=\"img-fluid rounded-circle\"></div>\n<div class=\"says\">\n<p class=\"m-0\">様々な“人”がいることや、雰囲気も伝えようよ</p>\n</div>\n</div><!-- /.balloon-start -->\n<div class=\"balloon-end text-end mb-3\">\n<div class=\"faceicon\"><img src=\"images/10_recruit_contents_p04.png\" alt=\"さと\" class=\"img-fluid rounded-circle\"></div>\n<div class=\"says\">\n<p class=\"m-0\">「風通しが良い」「アットホーム」ってよく見るけど、本当に？って思っちゃうからね</p>\n</div>\n</div><!-- /.balloon-end -->\n<div class=\"balloon-end text-end mb-5\">\n<div class=\"faceicon\"><img src=\"images/10_recruit_contents_p07.png\" alt=\"たき\" class=\"img-fluid rounded-circle\"></div>\n<div class=\"says\">\n<p class=\"m-0\">ということで、最後に<a href=\"#content_5\">メンバーのMBTI診断結果</a>を公開！</p>\n</div>\n</div><!-- /.balloon-end -->\n</div><!-- /.container -->\n\n<div class=\"bg-light\">\n<div class=\"container text-center py-5\" id=\"content_3\">\n<span class=\"text-success small\">＼　<strong>せっかちさん止まって～！第一印象大事 </strong>　／</span><br>\n<h2 class=\"mb-5\">キャッチコピー＆キーワード</h2>\n<div class=\"row py-5 g-4\">\n<div class=\"col-md-6\"><p><img src=\"images/10_recruit_contents_p18.png\" alt=\"ペルソナ\" class=\"img-fluid rounded\"></p></div>\n<div class=\"col-md-6\"><p><img src=\"images/10_recruit_contents_p19.png\" alt=\"就活生の企業選定の決め手となるコンテンツ\" class=\"img-fluid rounded\"></p></div>\n</div><!-- /.row -->\n<div class=\"balloon-start text-start mb-3\">\n<div class=\"faceicon\"><img src=\"images/10_recruit_contents_p05.png\" alt=\"いお\" class=\"img-fluid rounded-circle\"></div>\n<div class=\"says\">\n<p class=\"m-0\">新卒採用サイトって、大体トップページに印象的なキャッチコピーがあるよね</p>\n</div>\n</div><!-- /.balloon-start -->\n<div class=\"balloon-end text-end mb-3\">\n<div class=\"faceicon\"><img src=\"images/10_recruit_contents_p11.png\" alt=\"すう\" class=\"img-fluid rounded-circle\"></div>\n<div class=\"says\">\n<p class=\"m-0\">キャッチコピーは「はじめの掴み」の効果があるね</p>\n</div>\n</div><!-- /.balloon-end -->\n<div class=\"balloon-end text-end mb-3\">\n<div class=\"faceicon\"><img src=\"images/10_recruit_contents_p05.png\" alt=\"いお\" class=\"img-fluid rounded-circle\"></div>\n<div class=\"says\">\n<p class=\"m-0\">KCSもオリジナルのキャッチコピーを作ろう！</p>\n</div>\n</div><!-- /.balloon-end -->\n<div class=\"row py-5 g-4\">\n<div class=\"col-md-6\"><p><img src=\"images/10_recruit_contents_p20.webp\" alt=\"キャッチコピー\" class=\"img-fluid rounded\"></p></div>\n<div class=\"col-md-6\"><p><img src=\"images/10_recruit_contents_p25.webp\" alt=\"まさかの、エンジニアやお！\" class=\"img-fluid rounded\"></p></div>\n</div><!-- /.row -->\n<div class=\"balloon-start text-start mb-3\">\n<div class=\"faceicon\"><img src=\"images/10_recruit_contents_p11.png\" alt=\"すう\" class=\"img-fluid rounded-circle\"></div>\n<div class=\"says\">\n<p class=\"m-0\">私たち目線のキーワードは、「<a href=\"../../recruit/entry/index.html#vision\">キーワードで見るKCS</a>」に掲載したよ</p>\n</div>\n</div><!-- /.balloon-start -->\n<div class=\"balloon-start text-start mb-5\">\n<div class=\"faceicon\"><img src=\"images/10_recruit_contents_p05.png\" alt=\"いお\" class=\"img-fluid rounded-circle\"></div>\n<div class=\"says\">\n<p class=\"m-0\">このページに載っているみんなの似顔絵も作ったよ</p>\n</div>\n</div><!-- /.balloon-start -->\n<p>\\ 似てる～～～～～〜！ /</p>\n<div class=\"row pb-5 g-4 justify-content-center\">\n<div class=\"col-4 col-md-3 col-lg-1\"><p><img src=\"images/10_recruit_contents_p03.png\" alt=\"やっさん\" class=\"img-fluid rounded-circle\"></p></div>\n<div class=\"col-4 col-md-3 col-lg-1\"><p><img src=\"images/10_recruit_contents_p04.png\" alt=\"さと\" class=\"img-fluid rounded-circle\"></p></div>\n<div class=\"col-4 col-md-3 col-lg-1\"><p><img src=\"images/10_recruit_contents_p06.png\" alt=\"かん\" class=\"img-fluid rounded-circle\"></p></div>\n<div class=\"col-4 col-md-3 col-lg-1\"><p><img src=\"images/10_recruit_contents_p07.png\" alt=\"たき\" class=\"img-fluid rounded-circle\"></p></div>\n<div class=\"col-4 col-md-3 col-lg-1\"><p><img src=\"images/10_recruit_contents_p08.png\" alt=\"まつ\" class=\"img-fluid rounded-circle\"></p></div>\n<div class=\"col-4 col-md-3 col-lg-1\"><p><img src=\"images/10_recruit_contents_p09.png\" alt=\"かと\" class=\"img-fluid rounded-circle\"></p></div>\n<div class=\"col-4 col-md-3 col-lg-1\"><p><img src=\"images/10_recruit_contents_p10.png\" alt=\"むらぴ\" class=\"img-fluid rounded-circle\"></p></div>\n<div class=\"col-4 col-md-3 col-lg-1\"><p><img src=\"images/10_recruit_contents_p11.png\" alt=\"すう\" class=\"img-fluid rounded-circle\"></p></div>\n</div><!-- /.row -->\n</div><!-- /.container -->\n</div>\n\n<div class=\"container text-center py-5\" id=\"content_4\">\n<span class=\"text-success small\">＼　<strong>繋がりやすい環境とは</strong>　／</span><br>\n<h2 class=\"mb-5\">使い慣れたツールでのコミュニケーション提案</h2>\n<div class=\"balloon-start text-start mb-3\">\n<div class=\"faceicon\"><img src=\"images/10_recruit_contents_p06.png\" alt=\"かん\" class=\"img-fluid rounded-circle\"></div>\n<div class=\"says\">\n<p class=\"m-0\">私たちのグループは、学生と繋がる新しい方法について人事担当に提案したよ</p>\n</div>\n</div><!-- /.balloon-start -->\n<div class=\"balloon-end text-end mb-3\">\n<div class=\"faceicon\"><img src=\"images/10_recruit_contents_p08.png\" alt=\"まつ\" class=\"img-fluid rounded-circle\"></div>\n<div class=\"says\">\n<p class=\"m-0\">発表の様子を紹介するね</p>\n</div>\n</div><!-- /.balloon-end -->\n<div class=\"balloon-end text-end mb-3\">\n<div class=\"faceicon\"><img src=\"images/10_recruit_contents_p07.png\" alt=\"たき\" class=\"img-fluid rounded-circle\"></div>\n<div class=\"says\">\n<p class=\"m-0\">MBTI診断結果も！</p>\n</div>\n</div><!-- /.balloon-end -->\n<div class=\"balloon-end text-end mb-3\">\n<div class=\"faceicon\"><img src=\"images/10_recruit_contents_p03.png\" alt=\"やっさん\" class=\"img-fluid rounded-circle\"></div>\n<div class=\"says\">\n<p class=\"m-0\">臨場感が出るよう、言葉や発表の仕方も工夫したよ</p>\n</div>\n</div><!-- /.balloon-end -->\n</div><!-- /.container -->\n<div class=\"container-fluid text-center pb-5\">\n<div class=\"row pb-5 g-4\">\n<div class=\"col-md-4\"><p><img src=\"images/10_recruit_contents_p26.webp\" alt=\"発表\" class=\"img-fluid rounded\"></p></div>\n<div class=\"col-md-4\"><p><img src=\"images/10_recruit_contents_p27.webp\" alt=\"発表\" class=\"img-fluid rounded\"></p></div>\n<div class=\"col-md-4\"><p><img src=\"images/10_recruit_contents_p28.webp\" alt=\"人事担当\" class=\"img-fluid rounded border\"></p></div>\n</div><!-- /.row -->\n</div><!-- /.container-fluid -->\n\n<div class=\"bg-light\">\n<div class=\"container-fluid text-center py-5\">\n<h2 class=\"my-5\">私たちのコンテンツはいかがでしたか？</h2>\n<p>分からないこと、もっと知りたいことがありましたら、インターンシップや会社説明会に是非ご参加ください。<br>\n直接お会いできる日を楽しみにしています！</p>\n<div class=\"row pt-5 g-4\">\n<div class=\"col-md-3 col-6\"><p><img src=\"images/10_recruit_contents_p21.webp\" alt=\"企画の様子\" class=\"img-fluid rounded\"></p></div>\n<div class=\"col-md-3 col-6\"><p><img src=\"images/10_recruit_contents_p22.webp\" alt=\"企画の様子\" class=\"img-fluid rounded\"></p></div>\n<div class=\"col-md-3 col-6\"><p><img src=\"images/10_recruit_contents_p23.webp\" alt=\"企画の様子\" class=\"img-fluid rounded\"></p></div>\n<div class=\"col-md-3 col-6\"><p><img src=\"images/10_recruit_contents_p24.webp\" alt=\"企画の様子\" class=\"img-fluid rounded\"></p></div>\n</div><!-- /.row -->\n</div><!-- /.container-fluid -->\n<div class=\"container text-center py-5\">\n<div class=\"row row-cols-3 row-cols-sm-5 justify-content-center g-4\" id=\"content_5\">\n<div class=\"col\"><p>\\ やお /<br><img src=\"images/10_recruit_contents_p03.png\" alt=\"やっさん\" class=\"img-fluid rounded-circle\"><br>やっさん<span class=\"badge rounded-pill text-bg-warning ms-1\">文系</span><br><small>ISFJ（擁護者）</small></p></div>\n<div class=\"col\"><p>\\ やお /<br><img src=\"images/10_recruit_contents_p04.png\" alt=\"さと\" class=\"img-fluid rounded-circle\"><br>さと<span class=\"badge rounded-pill text-bg-warning ms-1\">文系</span><br><small>INFJ（提唱者）</small></p></div>\n<div class=\"col\"><p>\\ でしょ /<br><img src=\"images/10_recruit_contents_p05.png\" alt=\"いお\" class=\"img-fluid rounded-circle\"><br>いお<span class=\"badge rounded-pill text-bg-success ms-1\">理系</span><br><small>ISTJ（管理者）</small></p></div>\n<div class=\"col\"><p>\\ だら〜 /<br><img src=\"images/10_recruit_contents_p06.png\" alt=\"かん\" class=\"img-fluid rounded-circle\"><br>かん<span class=\"badge rounded-pill text-bg-success ms-1\">理系</span><br><small>ISTP（巨匠）</small></p></div>\n<div class=\"col\"><p>\\ でしょ /<br><img src=\"images/10_recruit_contents_p07.png\" alt=\"たき\" class=\"img-fluid rounded-circle\"><br>たき<span class=\"badge rounded-pill text-bg-success ms-1\">理系</span><br><small>ENFJ（主人公）</small></p></div>\n<div class=\"col\"><p>\\ やが /<br><img src=\"images/10_recruit_contents_p08.png\" alt=\"まつ\" class=\"img-fluid rounded-circle\"><br>まつ<span class=\"badge rounded-pill text-bg-success ms-1\">理系</span><br><small>INFJ（提唱者）</small></p></div>\n<div class=\"col\"><p>\\ だら〜 /<br><img src=\"images/10_recruit_contents_p09.png\" alt=\"かと\" class=\"img-fluid rounded-circle\"><br>かと<span class=\"badge rounded-pill text-bg-success ms-1\">理系</span><br><small>ESFJ（領事）</small></p></div>\n<div class=\"col\"><p>\\ やお /<br><img src=\"images/10_recruit_contents_p10.png\" alt=\"むらぴ\" class=\"img-fluid rounded-circle\"><br>むらぴ<span class=\"badge rounded-pill text-bg-success ms-1\">理系</span><br><small>INFJ（提唱者）</small></p></div>\n<div class=\"col\"><p>\\ やお /<br><img src=\"images/10_recruit_contents_p11.png\" alt=\"すう\" class=\"img-fluid rounded-circle\"><br>すう<span class=\"badge rounded-pill text-bg-warning ms-1\">文系</span><br><small>INFJ（提唱者）</small></p></div>\n</div><!-- /.row -->\n<p class=\"text-end pt-5\">記事担当：2024年度 ITソリューション本部 新入社員</p>\n</div><!-- /.container -->\n</div>\n\n<div class=\"text-center py-5\" id=\"contact\">\n<div class=\"container bg-white rounded\">\n<h2 class=\"my-5\">インターンシップのお申し込み</h2>\n<p>インターンシップの申し込みは、マイナビからできます。<br>\n詳細は、マイナビをご覧ください。</p>\n<p class=\"pb-5\"><a href=\"../../recruit/entry/internship.html\" class=\"btn btn-success btn-lg\" target=\"_blank\">マイナビへのリンクはこちら<i class=\"bi bi-chevron-double-right ms-2\" aria-hidden=\"true\"></i></a></p>\n</div><!-- /.container -->\n</div><!-- /#contact -->\n\n<div class=\"container-fluid text-center py-5\">\n<h2 class=\"my-5\">関連ページ</h2>\n\n<div class=\"row row-cols-1 row-cols-sm-3 text-start kcs_topics photos py-5 g-4\">\n\n<div class=\"col\">\n<a href=\"../2024/09_internship_2days.html\">\n<div class=\"card h-100 shadow\">\n<img src=\"../2024/images/09_internship_2days_p05.webp\" class=\"card-img-top\" alt=\"2024年夏、2daysインターンシップ開催\n（対面・オンライン・プラスワン）\">\n<div class=\"card-body\">\n<h3 class=\"card-title h5\">2024年夏、2daysインターンシップ開催<small>（対面・オンライン・プラスワン）</small></h3>\n<p class=\"card-text link-primary\">仕事体験も、職場の見学も、アレもコレも体験できる人気のコースです。</p>\n<small class=\"text-secondary\">2024年8月～9月</small>\n</div>\n</div>\n</a>\n</div>\n\n<div class=\"col\">\n<a href=\"09_internship_1day.html\">\n<div class=\"card h-100 shadow\">\n<img src=\"images/09_internship_1day_p01.jpg\" class=\"card-img-top\" alt=\"2024年夏、1day仕事体験（IT業界の仕事を知ろう）開催（オンライン・対面）\">\n<div class=\"card-body\">\n<h3 class=\"card-title h5\">2024年夏、1day仕事体験（IT業界の仕事を知ろう）開催<small>（オンライン・対面）</small></h3>\n<p class=\"card-text link-primary\">4年生大学・大学院・短期大学・専門学校に在籍中の方向けに、仕事体験イベントを開催しています。</p>\n<small class=\"text-secondary\">2024年8月～9月</small>\n</div>\n</div>\n</a>\n</div>\n\n<div class=\"col\">\n<a href=\"../../recruit/index.html\">\n<div class=\"card h-100 shadow\">\n<img src=\"../../company/images/index_p03.jpg\" class=\"card-img-top\" alt=\"採用情報\">\n<div class=\"card-body\">\n<h3 class=\"card-title h5\">採用情報</h3>\n<p class=\"card-text link-primary\">求める人材像や実際にKCSで働く先輩の生の声など、就活に役立つ情報が満載。</p>\n</div>\n</div>\n</a>\n</div>\n\n</div><!-- /.row -->\n</div><!-- /.container-fluid -->\n\n</main>\n<!-- InstanceEndEditable -->\n\n<p id=\"pagetop\"><a href=\"#header\"><i class=\"bi bi-arrow-bar-up fs-4\"></i></a></p>\n<div id=\"footer\"></div>\n<script src=\"https://code.jquery.com/jquery-3.7.1.min.js\" integrity=\"sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo=\" crossorigin=\"anonymous\"></script>\n<script src=\"../../js/default02.js\"></script> \n<script src=\"https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js\" integrity=\"sha384-geWF76RCwLtnZ8qwWowPQNguL3RmwHVBC9FhGdlKrxdiJJigb/j/68SIy3Te4Bkz\" crossorigin=\"anonymous\"></script>\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css\">\n<script src=\"https://cdnjs.cloudflare.com/ajax/libs/protonet-jquery.inview/1.1.2/jquery.inview.min.js\" integrity=\"sha512-D68mBFX2aQwVh2wV6uCDLmabIveaSQL3uVUo2Ze7VwxIeOcAd4C1/JagkVoObb/NLkYDrdvY3JHK1KOfenHVcA==\" crossorigin=\"anonymous\" referrerpolicy=\"no-referrer\"></script>\n<!-- InstanceBeginEditable name=\"added_js\" -->\n\n<!-- InstanceEndEditable -->\n</body>\n<!-- InstanceEnd --></html>","finalUrl":"https://www.okb-kcs.co.jp/journal/2024/10_recruit_contents.html","rendered":false,"_cachedAt":"2026-06-23T23:11:17.688Z"}