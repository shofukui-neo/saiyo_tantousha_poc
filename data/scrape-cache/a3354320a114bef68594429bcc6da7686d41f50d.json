-li\" itemprop=\"itemListElement\" itemscope itemtype=\"http://schema.org/ListItem\">\r\n\t\t\t\t\t<a class=\"mod-topicPath-a\" itemprop=\"item\" href=\"/company/\">\r\n\t\t\t\t\t\t<span class=\"mod-topicPath-span\" itemprop=\"name\">企業情報</span>\r\n\t\t\t\t\t</a>\r\n\t\t\t\t\t<meta itemprop=\"position\" content=\"2\">\r\n\t\t\t\t</li>\r\n\t\t\t<li class=\"mod-topicPath-li\" itemprop=\"itemListElement\" itemscope itemtype=\"http://schema.org/ListItem\">\r\n\t\t\t\t\t<a class=\"mod-topicPath-a\" itemprop=\"item\" href=\"/company/career/\">\r\n\t\t\t\t\t\t<span class=\"mod-topicPath-span\" itemprop=\"name\">教育制度</span>\r\n\t\t\t\t\t</a>\r\n\t\t\t\t\t<meta itemprop=\"position\" content=\"3\">\r\n\t\t\t\t</li>\r\n\t\t\t</ul>\r\n\t\t\t</nav>\r\n\t\t\t<h1 class=\"mod-head01-normal\">教育制度</h1>\r\n\t\t</section>\r\n\r\n\t\t<section class=\"company-career mod-auto_pc pt30 pb50 clearfix\">\r\n\t\t\t<div class=\"mod-sideLeftNav inc_company_sideNav\">\r\n\t<h3 class=\"ff_mincho fs_middle mb20\"><a href=\"/company/\" class=\"mod-link01\">企業情報トップ</a></h3>\r\n\t<div class=\"mb20\">\r\n\t\t<ul class=\"ul-line\">\r\n\t\t\t<li><a class=\"mod-sideNav-a mod-link01\" href=\"/company/message/\">代表挨拶</a></li>\r\n\t\t\t<li><a class=\"mod-sideNav-a mod-link01\" href=\"/company/profile/\">企業概要</a></li>\r\n\t\t\t<li><a class=\"mod-sideNav-a mod-link01\" href=\"/company/philosophy/\">企業理念</a></li>\r\n\t\t\t<li><a class=\"mod-sideNav-a mod-link01\" href=\"/company/factory/\">全国事業所一覧</a></li>\r\n\t\t\t<li><a class=\"mod-sideNav-a mod-link01\" href=\"/company/history/\">nishikawaの歴史</a></li>\r\n\t\t\t<li><a class=\"mod-sideNav-a mod-link01\" href=\"/company/career/\">教育制度</a></li>\r\n\t\t\t<li><a class=\"mod-sideNav-a mod-link01\" href=\"/company/certify/\">西川寝具社内検定</a></li>\r\n\t\t\t<li><a class=\"mod-sideNav-a mod-link01\" href=\"/company/laboratory/\">日本睡眠科学研究所</a></li>\r\n\t\t\t<li><a class=\"mod-sideNav-a mod-link01\" href=\"/company/renishikawa/\">サステナビリティ</a></li>\r\n\t\t\t<li><a class=\"mod-sideNav-a mod-link01\" href=\"/company/cm/\">CM情報</a></li>\r\n\t\t\t<li><a class=\"mod-sideNav-a mod-link01\" href=\"/company/recruit/\">採用情報</a></li>\r\n\t\t\t<li><a class=\"mod-sideNav-a mod-link01\" href=\"/company/security_action/\">SECURITY ACTION</a></li>\r\n\t\t</ul>\r\n\t</div>\r\n</div>\r\n\t\t\t<div class=\"mod-sideLeftContent pb50\">\r\n\t\t\t\t<div class=\"mod-sideLeftContent-inner mod-auto_sp\">\r\n\t\t\t\t\t<h3 class=\"mod-head03 color_text2 ff_mincho\">資格取得養成講座の<span class=\"di_iblock\">ご案内</span></h3>\r\n\t\t\t\t\t<div class=\"pure-g space-u-40 mb40\">\r\n\t\t\t\t\t\t<div class=\"pure-u-2-3 pure-u-md-1 space-u-40-child\">\r\n\t\t\t\t\t\t\t<p>nishikawaでは、お客様お一人おひとりに合った眠りと寝具をコンサルティングセールスできる人材の育成を目指し、様々なレベルの資格取得講座を開催しています。<br>各資格を取得した販売スタッフはお客様の眠りのお悩みに対し、豊富な知識で毎日の快適な眠りをサポートいたします。</p>\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t<div class=\"pure-u-1-3 pure-u-md-1 space-u-40-child\">\r\n\t\t\t\t\t\t\t<figure class=\"ta_center\">\r\n\t\t\t\t\t\t\t\t<img src=\"/images/company/career/img_01.jpg\">\r\n\t\t\t\t\t\t\t</figure>\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t</div>\r\n\t\t\t\t\t<figure class=\"width-u-60 width-lg-100 mod-auto-center mod-border01 p20\">\r\n\t\t\t\t\t\t<img src=\"/images/company/career/instruction.png\" class=\"width-u-100\">\r\n\t\t\t\t\t</figure>\r\n\t\t\t\t\t<div class=\"pure-g space-u-20 mt20\">\r\n\t\t\t\t\t\t<div class=\"pure-u-1-2 pure-u-lg-1 space-u-20-child\">\r\n\t\t\t\t\t\t\t<div class=\"company-borderBox\">\r\n\t\t\t\t\t\t\t\t<h4 class=\"fs_large_s ff_mincho fw_bold ta_center mb20\" data-mh=\"title-text\">スリープマスター<span class=\"di_iblock\">養成講座</span></h4>\r\n\t\t\t\t\t\t\t\t<p class=\"mb10\" data-mh=\"career\">寝具だけでなく睡眠についても幅広い知識を持ち、お客様のお悩みに応じたご提案ができる人材を育成する講座です。資格取得後は、お客様に安心してご相談いただけるような、眠りのプロフェッショナルとして活躍して頂きます。</p>\r\n\t\t\t\t\t\t\t\t<figure class=\"ta_center\"><img src=\"/images/company/career/img_02.jpg\" alt=\"\"></figure>\r\n\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t<div class=\"pure-u-1-2 pure-u-lg-1 space-u-20-child\">\r\n\t\t\t\t\t\t\t<div class=\"company-borderBox\">\r\n\t\t\t\t\t\t\t\t<h4 class=\"fs_large_s ff_mincho fw_bold ta_center mb20\" data-mh=\"title-text\">スリープマスター<span class=\"di_iblock\">エキスパート講座</span></h4>\r\n\t\t\t\t\t\t\t\t<p class=\"mb10\" data-mh=\"career\">「スリープマスター」を習得した上で、取得が可能な講座です。<br>講演時での話し方やコンプライアンス・法令遵守について学ぶ実践的なスペシャル資格です。<br>地元の企業様や自治体・学校などへ、快眠セミナーや睡眠計測のご提案を行い、社会貢献に繋げていただけます。</p>\r\n\t\t\t\t\t\t\t\t<figure class=\"ta_center\"><img src=\"/images/company/career/img_08.jpg\" alt=\"\"></figure>\r\n\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t<div class=\"pure-u-1-2 pure-u-lg-1 space-u-20-child\">\r\n\t\t\t\t\t\t\t<div class=\"company-borderBox\">\r\n\t\t\t\t\t\t\t\t<h4 class=\"fs_large_s ff_mincho fw_bold ta_center mb20\" data-mh=\"title-text\">スリープアドバイザー<span class=\"di_iblock\">養成講座</span></h4>\r\n\t\t\t\t\t\t\t\t<p class=\"mb10\" data-mh=\"career\">豊富な商品知識を身につけ、寝具全般をトータル提案できる人材を育成する講座です。<br>講座の中で様々な寝具の掛け比べ・寝比べを体感していただくことで、お客様へより説得力のあるご案内ができる技術を身につけます。</p>\r\n\t\t\t\t\t\t\t\t<figure class=\"ta_center\"><img src=\"/images/company/career/img_03.jpg\" alt=\"\"></figure>\r\n\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t<div class=\"pure-u-1-2 pure-u-lg-1 space-u-20-child\">\r\n\t\t\t\t\t\t\t<div class=\"company-borderBox\">\r\n\t\t\t\t\t\t\t\t<h4 class=\"fs_large_s ff_mincho fw_bold ta_center mb20\" data-mh=\"title-text\">ピローアドバイザー<span class=\"di_iblock\">養成講座</span></h4>\r\n\t\t\t\t\t\t\t\t<p class=\"mb10\" data-mh=\"career\">まくらのコンサルティングができる、“エキスパート”を育成する講座です。<br>店頭にお越し頂いたお客様がまくらをお試しになる際に、適切な高さや素材選びのお手伝いをさせていただくための資格です。</p>\r\n\t\t\t\t\t\t\t\t<figure class=\"ta_center\" data-mh=\"career-img\"><img src=\"/images/company/career/img_04.jpg\" alt=\"\"></figure>\r\n\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t<div class=\"pure-u-1-2 pure-u-lg-1 space-u-20-child\">\r\n\t\t\t\t\t\t\t<div class=\"company-borderBox\" data-mh=\"suteki\">\r\n\t\t\t\t\t\t\t\t<h4 class=\"fs_large_s ff_mincho fw_bold ta_center mb20\" data-mh=\"title-text\">羽毛ふとん診断士<span class=\"di_iblock\">養成講座</span></h4>\r\n\t\t\t\t\t\t\t\t<p class=\"mb10\" data-mh=\"career\">お客様がお持ちの羽毛ふとんを診断し、リフレッシュ・リフォーム・リサイクルなどの診断ができる人材の育成を目指します。</p>\r\n\t\t\t\t\t\t\t\t<figure class=\"ta_center\" data-mh=\"career-img\"><img src=\"/images/company/career/img_05.jpg\" alt=\"\"></figure>\r\n\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t<div class=\"pure-u-1-2 pure-u-lg-1 space-u-20-child\">\r\n\t\t\t\t\t\t\t<div class=\"company-borderBox\" data-mh=\"suteki\">\r\n\t\t\t\t\t\t\t\t<h4 class=\"fs_large_s ff_mincho fw_bold ta_center mb20\" data-mh=\"title-text\">寝具リフォーム<span class=\"di_iblock\">コンサルタント養成講座</span></h4>\r\n\t\t\t\t\t\t\t\t<p class=\"mb10\" data-mh=\"career\">羽毛ふとん・シープトン・まくらを中心とした寝具のメンテナンスに関する知識を備え、お客様に適切なアドバイスができる人材の育成を目指します。</p>\r\n\t\t\t\t\t\t\t\t<figure class=\"ta_center\"><img src=\"/images/company/career/img_06.jpg\" alt=\"\"></figure>\r\n\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t<div class=\"pure-u-1-2 pure-u-lg-1 space-u-20-child\">\r\n\t\t\t\t\t\t\t<div class=\"company-borderBox\" data-mh=\"suteki\">\r\n\t\t\t\t\t\t\t\t<h4 class=\"fs_large_s ff_mincho fw_bold ta_center mb20\" data-mh=\"title-text\">タオルアドバイザー<span class=\"di_iblock\">養成講座</span></h4>\r\n\t\t\t\t\t\t\t\t<p class=\"mb10\" data-mh=\"career\">今治タオルをはじめとするタオルの商品知識やタオルアート、シーンに応じた販売方法を学び、お客様に適切なアドバイスができる人材の育成を目指します。</p>\r\n\t\t\t\t\t\t\t\t<figure class=\"ta_center\"><img src=\"/images/company/career/img_07.jpg\" alt=\"\"></figure>\r\n\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t</div>\r\n\t\t\t\t\t<div class=\"mod-borderTop mt30 pt30\">\r\n\t\t\t\t\t\t<div class=\"company-borderBox\">\r\n\t\t\t\t\t\t\t<p>【西川株式会社　販売職限定】</p>\r\n\t\t\t\t\t\t\t<ul class=\"pure-g space-u-20 company-career-certify pt20\">\r\n\t\t\t\t\t\t\t\t<li class=\"pure-u-1-5 pure-u-lg-1-1 space-u-20-child ta_center\">\r\n\t\t\t\t\t\t\t\t\t<figure><img src=\"/images/company/img_certify_mark.png\" alt=\"西川寝具社内検定 バッチ\"></figure>\r\n\t\t\t\t\t\t\t\t</li>\r\n\t\t\t\t\t\t\t\t<li class=\"pure-u-4-5 pure-u-lg-1-1 space-u-20-child\">\r\n\t\t\t\t\t\t\t\t\t<h4 class=\"fs_large_s ff_mincho ta_lg_center\">厚生労働省認定<span class=\"company-career-certify-span\">西川寝具社内検定</span></h4>\r\n\t\t\t\t\t\t\t\t\t<p class=\"mt20\">寝具業界初の厚生労働省認定の社内検定制度を導入。<br>販売員の対外的な信頼を高め、お客様の満足度を向上させる取り組みを行っています。</p>\r\n\t\t\t\t\t\t\t\t\t<div class=\"mod-button mod-button_300 mt20 opacity\">\r\n\t\t\t\t\t\t\t\t\t\t<a href=\"/company/certify/\" class=\"mod-button-a mod-button-a_red\">社内検定についてはこちら<i class=\"icon icon-arrow_right mod-iconArrowRight\"></i></a>\r\n\t\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t</li>\r\n\t\t\t\t\t\t\t</ul>\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t</div>\r\n\t\t\t\t</div>\r\n\t\t\t</div>\r\n\t\t</section>\r\n\r\n\t</main>\r\n\r\n\t<footer class=\"footer inc_common_footer\">\r\n\t<a href=\"#pagetop\" rel=\"scroll\" class=\"footer-pagetop\">\r\n\t\t<div class=\"footer-pagetop-inner\">\r\n\t\t\t<i class=\"icon icon-arrow_top\"></i>\r\n\t\t\t<span>PAGE TOP</span>\r\n\t\t</div>\r\n\t</a>\r\n\t<ul class=\"footer-wrap\">\r\n\t\t<li class=\"footer-category\">\r\n\t\t\t<p class=\"footer-category-head\"><a href=\"/categories/\" class=\"footer-a footer-category-spHead\">商品情報</a></p>\r\n\t\t\t<div class=\"footer-category-inner clearfix\">\r\n\t\t\t\t<ul class=\"footer-category-catList\" data-view=\"sp\"><li><a href=\"/categories/\" class=\"footer-a\">商品情報TOP</a></li></ul>\r\n\t\t\t\t<ul class=\"footer-category-catList\">\r\n\t\t\t\t\t<li><a href=\"/categories/comforters.html\" class=\"footer-a\">掛け布団</a>\r\n\t\t\t\t\t\t<ul class=\"pl10\">\r\n\t\t\t\t\t\t\t<li><a href=\"/categories/down/\" class=\"\">├ 羽毛布団</a></li>\r\n\t\t\t\t\t\t\t<li><a href=\"/categories/synthetic/\" class=\"\">├ 合繊布団</a></li>\r\n\t\t\t\t\t\t\t<li><a href=\"/categories/silk/\" class=\"\">├ 真綿布団</a></li>\r\n\t\t\t\t\t\t\t<li><a href=\"/categories/ramie/\" class=\"\">├ 麻布団</a></li>\r\n\t\t\t\t\t\t\t<li><a href=\"/categories/wool/\" class=\"\">└ ウール布団</a></li>\r\n\t\t\t\t\t\t</ul>\r\n\t\