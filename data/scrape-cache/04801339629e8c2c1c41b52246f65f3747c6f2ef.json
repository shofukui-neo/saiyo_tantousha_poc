er_list_wrapper\" data-v-3f1e9455><h4 class=\"footer_list_title\" data-v-3f1e9455>Environment</h4> <ul class=\"footer_list\" data-v-3f1e9455><li class=\"footer_list_text\" data-v-3f1e9455><a href=\"/recruit/global_career/environment/welfare\" data-v-3f1e9455>\n              福利厚生\n            </a></li><li class=\"footer_list_text\" data-v-3f1e9455><a href=\"/recruit/global_career/environment/diversity\" data-v-3f1e9455>\n              ダイバーシティ\n            </a></li></ul></div> <div class=\"footer_list_wrapper\" data-v-3f1e9455><h4 class=\"footer_list_title\" data-v-3f1e9455>Recruit</h4> <ul class=\"footer_list\" data-v-3f1e9455><li class=\"footer_list_text\" data-v-3f1e9455><a href=\"/recruit/global_career/recruitment/list\" data-v-3f1e9455>\n              募集一覧\n            </a></li><li class=\"footer_list_text\" data-v-3f1e9455><a href=\"/recruit/global_career/recruitment/registration\" data-v-3f1e9455>\n              エントリー\n            </a></li></ul></div></div></div> <div class=\"wrapper-footer_rules\" data-v-3f1e9455><div class=\"footer_rules\" data-v-3f1e9455><ul class=\"footer_rules_list\" data-v-3f1e9455><li data-v-3f1e9455><a href=\"https://www.nipponsteel.com/terms/\" target=\"_blank\" data-v-3f1e9455>サイト利用について</a></li><li data-v-3f1e9455><a href=\"https://www.nipponsteel.com/terms/social_media.html\" target=\"_blank\" data-v-3f1e9455>ソーシャルメディアポリシー</a></li><li data-v-3f1e9455><a href=\"https://www.nipponsteel.com/privacy/\" target=\"_blank\" data-v-3f1e9455>個人情報保護方針</a></li><li data-v-3f1e9455><a href=\"https://www.nipponsteel.com/privacy/cookie.html\" target=\"_blank\" data-v-3f1e9455>クッキー使用について</a></li><li data-v-3f1e9455><a href=\"https://www.nipponsteel.com/contact/\" target=\"_blank\" data-v-3f1e9455>お問い合わせ</a></li></ul> <div class=\"copyright\" data-v-3f1e9455><p data-v-3f1e9455>Copyright NIPPON STEEL CORPORATION. All rights reserved.</p></div></div></div></footer></div></div></div><script>window.__NUXT__={staticAssetsBase:\"/_nuxt/static/1780559484\",layout:\"default\",error:null,serverRendered:!0,routePath:\"/company/about\",config:{}}</script><script src=\"/recruit/global_career/_nuxt/7d96ad5.js\" defer></script><script src=\"/recruit/global_career/_nuxt/97bb7bd.js\" defer></script><script src=\"/recruit/global_career/_nuxt/1ba6e89.js\" defer></script><script src=\"/recruit/global_career/_nuxt/86a2779.js\" defer></script><script src=\"/recruit/global_career/_nuxt/d4a45cf.js\" defer></script>\r\n  </body>\r\n</html>\r\n","finalUrl":"https://www.nipponsteel.com/recruit/global_career/company/about/","rendered":false,"_cachedAt":"2026-06-23T18:59:11.970Z"}