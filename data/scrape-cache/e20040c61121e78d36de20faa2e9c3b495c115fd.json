{"url":"https://www.kakihara.co.jp/recruit/worklife/worklife.html","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n<head>\n<!-- Google Tag Manager -->\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n})(window,document,'script','dataLayer','GTM-TJ6RC8D');</script>\n<!-- End Google Tag Manager -->\n\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1, minimum-scale=1, maximum-scale=1, user-scalable=no\">\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge,chrome=1\">\n<title>ワークライフ｜採用情報</title>\n<meta name=\"description\" content=\"柿原工業株式会社は、「あらゆる素材を独自のメタライジング技術によって高付加価値化する」を事業テーマに、その最先端を切り開きます。樹脂製品の一貫生産体制（金型、射出成形、表面処理-めっき-、塗装、組立、リサイクル）で高品質、短納期の製品をお届けします。\">\n<meta name=\"keywords\" content=\"メッキ,めっき,樹脂メッキ,樹脂めっき,マグネシウム合金代替,Mg合金代替,衝撃吸収PP樹脂メッキ,モノリスプロセス,金型,射出成形,表面処理,塗装,ISO14001,ISO9001,組立,環境対策,印刷,メインドア,スロットマシン,アルミ調,サテンめっき,サテンメッキ,3価クロムめっき,3価クロムメッキ,高品質,短納期,コストダウン,金メッキ,大型製品,樹脂メッキのリサイクル,樹脂めっきのリサイクル\">\n<meta name=\"copyright\" content=\"柿原工業株式会社\" />\n<meta name=\"robots\" content=\"noarchive\">\n<link href=\"../common/css/font-awesome.min.css\" rel=\"stylesheet\" media=\"screen,print\">\n<link href=\"../common/css/noto-sans-cjkjp.css\" rel=\"stylesheet\" media=\"screen,print\">\n<link href=\"../common/css/reset.css\" rel=\"stylesheet\" media=\"screen,print\">\n<link href=\"../common/css/common.css\" rel=\"stylesheet\" media=\"screen\">\n<link href=\"../common/css/layout.css\" rel=\"stylesheet\" media=\"screen\">\n<link href=\"../common/css/navi_l.css\" rel=\"stylesheet\" media=\"screen and (min-width:1280px)\">\n<link href=\"../common/css/navi_s.css\" rel=\"stylesheet\" media=\"screen and (max-width:1279px)\">\n<link href=\"../common/css/list_l.css\" rel=\"stylesheet\" media=\"screen and (min-width:700px)\">\n<link href=\"../common/css/list_s.css\" rel=\"stylesheet\" media=\"screen and (max-width:699px)\">\n<link href=\"../common/css/foot_l.css\" rel=\"stylesheet\" media=\"screen and (min-width:700px)\">\n<link href=\"../common/css/foot_s.css\" rel=\"stylesheet\" media=\"screen and (max-width:699px)\">\n<link href=\"../common/css/magnific-popup.css\" rel=\"stylesheet\" media=\"screen,print\">\n<link href=\"css/print.css\" rel=\"stylesheet\" media=\"print\">\n<link href=\"css/style.css\" rel=\"stylesheet\" media=\"screen\">\n<script src=\"../js/jquery-1.8.1.js\" type=\"text/javascript\"></script>\n<script src=\"../js/common.js\" type=\"text/javascript\"></script>\n<script src=\"../js/jquery.matchHeight.js\" type=\"text/javascript\"></script>\n<script type=\"text/javascript\">\n    // ナビゲーションのオープン・クローズの画面拡張処理\n\t$(function() {\n\t\t$(\"#panel-btn\").click(function() {\t\n\t\t$(\"#gNavi\").slideToggle(200);\n\t\t$(\"#panel-btn-icon\").toggleClass(\"close\");\n\t\t\treturn false;\n\t\t});\n\t\t$(window).resize(function(){\n\t\t\tvar win = $(window).width();\n\t\t\tvar p = 1279;\n\t\t\tif(win > p){\n\t\t\t\t$(\"#gNavi\").show();\n    \t\t} else {\n\t    \t\t//メニューが開いているかどうか判定、開いていないときはナビを閉じる\n\t    \t\tif($(\"#panel-btn-icon\").hasClass(\"close\")){\n\t\t    \t} else {\n\t\t\t\t\t$(\"#gNavi\").hide();\n\t\t\t\t}\n    \t\t}\n\t\t});\n\t});\n\t//フッタのロゴをマウスオーバーした際にCorporate Websaiteをアクティブにする\n\t$(function() {\n\t\t$(\"#corpBox img\").hover(\n\t\tfunction () {\n\t\t\t$(\"#corpBox p\").addClass('hover');\n\t\t},\n\t\tfunction () {\n\t\t\t$(\"#corpBox p\").removeClass('hover');\t\n\t\t}\n\t\t);\n\t});\n\t//フッタのリストを揃える\n\t$(function() {\n    \t$('#footerNavi li').matchHeight();\n\t});\n</script>\n<script type=\"text/javascript\">\n\t$(function() {\n    \t$('.mBox li').matchHeight();\n\t});\n</script>\n</head>\n<body>\n<!-- Google Tag Manager (noscript) -->\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-TJ6RC8D\"\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n<!-- End Google Tag Manager (noscript) -->\n<div id=\"loader-bg\">\n    <div id=\"loading\">\n        <div class=\"spinner\">\n            <div class=\"circle\"></div>\n        </div>\n    </div>\n</div>\n<header id=\"header\">\n    <div id=\"headArea\">\n        <div id=\"sMenu\">\n            <div id=\"panel-btn-menu\">MENU</div>\n            <a href=\"javascript:void(0)\" id=\"panel-btn\"><span id=\"panel-btn-icon\"></span></a> </div>\n        <div id=\"logo\"><a href=\"../index.html\"><img src=\"../common/image/rogo.png\" alt=\"柿原工業株式会社\" width=\"169\" height=\"32\"></a></div>\n        <div id=\"corpo\"><a href=\"http://www.kakihara.co.jp/\" target=\"_blank\">コーポレートサイト</a></div>\n    </div>\n</header>\n<div id=\"gNavi\">\n    <div id=\"naviArea\">\n        <ul class=\"naviBox\">\n            <li class=\"naviList\"> <span class=\"pcNone\"><a href=\"index.html\">ホーム</a></span> </li>\n            <li class=\"naviList\"> <a href=\"../about/about.html\">About Kakihara</a> </li>\n            <li class=\"naviList\"> <a href=\"../interview/interview.html\">トップインタビュー</a> </li>\n            <li class=\"naviList\"> <a href=\"../episode/episode.html\">開発エピソード</a> </li>\n            <li class=\"naviList\"> <a href=\"../cross01/closs01.html\">クロストーク</a> </li>\n            <li class=\"naviList\"> <a href=\"../worklife/worklife.html\">ワークライフ</a> </li>\n            <li class=\"naviList\"> <a href=\"../staff/staff.html\">カキハラ4＋</a> </li>\n            <li class=\"naviList\"> <a href=\"../works/works.html\">全仕事解説</a> </li>\n            <li class=\"naviList\"> <a href=\"../recruit.html\">採用情報</a> </li>\n            <li> <a href=\"../entry/page.html\" class=\"mov-popup\">エントリー</a> </li>\n            <li class=\"naviList\"> <span class=\"pcNone\"><a href=\"http://www.kakihara.co.jp/\"  target=\"_blank\">コーポレートサイト</a></span> </li>\n        </ul>\n    </div>\n</div>\n<article id=\"imageContainer\">\n    <div class=\"imageBox\">\n        <h1>ワークライフ</h1>\n        <img src=\"../common/image/image.png\" alt=\"image\" width=\"1400\" height=\"642\" class=\"image\">\n        <div class=\"titleBox\"><img src=\"../common/image/title.png\" alt=\"title\" width=\"1400\" height=\"127\" class=\"title\"></div>\n    </div>\n    <div class=\"readBox clearFix\">\n        <div class=\"tleftBox\">\n            \n                <h2>プライベートを大切にする<br>\n働き方の達人たち。\n</h2>\n                <p>休日は趣味に没頭したり、家族とのんびり食事をしたり。さらに、年3回ある長期休暇を有意義に使って気分をリフレッシュすれば、新たな気持ちで仕事にも取り組めます。メリハリのある生活こそ、人生を楽しく過ごすコツ。そんなONとOFFの切り替え上手な達人たちを紹介します。</p>\n            \n        </div>\n    </div>\n</article>\n<div id=\"bodyContainer\">\n    <article class=\"bodyinlineBox clearFix\">\n        <div class=\"inview\"><aside class=\"midashi_left\">Life Style</aside></div>\n        <div class=\"mBox\">\n            <ul>\n\t            <li class=\"inview\"><img src=\"image/pict01.jpg\" alt=\"pict01\">\n                    <p data-mh=\"data\">家族と友人と一緒に沖縄県の渡嘉敷島（とかしきじま）へ。沖縄独特の空気感は、心をリフレッシュするのにはもってこい。子どもたちにとっても新しい体験は記憶に残る大切なものです。</p>\n                    <p data-mh=\"name\" class=\"name\">荒木 貴文<br>\n                        営業技術部　営業技術課</p>\n                </li>\n                <li class=\"inview\"><img src=\"image/pict02.jpg\" alt=\"pict02\">\n                    <p data-mh=\"data\">入社してから始めたゴルフ。100を切るべく練習中です。社内には同好会があり、社内コンペもあります。ここで優勝するという目標も良いモチベーションになっています。</p>\n                    <p data-mh=\"name\" class=\"name\">牧　賢志<br>\n                        営業技術部　営業技術課</p>\n                </li>\n                <li class=\"inview\"><img src=\"image/pict03.jpg\" alt=\"pict03\">\n                    <p data-mh=\"data\">会社の先輩や同期と週末に釣りに行っては海に癒されています。ルアーフィッシングの他に、船釣りや投げ釣りにも手を出してしまって、一年中が釣り三昧となっています（笑）。</p>\n                    <p data-mh=\"name\" class=\"name\">藤井 航平<br>\n                        金属製造部　金属表面処理課</p>\n                </li>\n                <li class=\"inview\"><img src=\"image/pict04.jpg\" alt=\"pict04\">\n                    <p data-mh=\"data\">初めての海外旅行でフランスへ。世界遺産のモン・サン=ミシェルは圧巻の迫力でした。近くにオムレツのおいしい店があります。機会があれば行ってみてください。</p>\n                    <p data-mh=\"name\" class=\"name\">大橋 真介<br>\n                        樹脂製造部　業務課</p>\n                </li>\n                <li class=\"inview\"><img src=\"image/pict05.jpg\" alt=\"pict05\">\n                    <p data-mh=\"data\">ついに25年ぶりにカープがリーグ優勝した日の写真です。他部署の人たちとも熱い応援で一丸に！　これをきっかけに仕事上のコミュニケーションの幅も広がりました。</p>\n                    <p data-mh=\"name\" class=\"name\">梅本 恵子<br>\n                        管理部総務課</p>\n                </li>\n                <li class=\"inview\"><img src=\"image/pict06.jpg\" alt=\"pict06\">\n                    <p data-mh=\"data\">私の休日はアウトドアで過ごしています。会社の仲間や友人と毎週のように山登りをして楽しんでいます。結婚記念日には妻と、神の島「宮島」の弥山（みせん）頂上に登りました。</p>\n                    <p data-mh=\"name\" class=\"name\">梶原　博<br>\n                        樹脂製造部　業務課</p>\n                </li>\n                <li class=\"inview\"><img src=\"image/pict07.jpg\" alt=\"pict07\">\n                    <p data-mh=\"data\">フットサルの大会で、見事優勝した時の記念の一枚です。フットサルの練習は、誰でも気軽に参加できます。好プレーや珍プレーが続出し、いつも笑いが絶えません。</p>\n                    <p data-mh=\"name\" class=\"name\">塚脇 正浩<br>\n                        樹脂製造部　樹脂表面処理課</p>\n                </li>\n                <li class=\"inview\"><img src=\"image/pict08.jpg\" alt=\"pict08\">\n                    <p data-mh=\"data\">毎年夏になると四国の吉野川でラフティング。絶景を眺めながら激流を仲間と下る爽快感・迫力・楽しさは、何度やっても飽きません。数日後には全身筋肉痛ですが…。</p>\n                    <p data-mh=\"name\" class=\"name\">東山 匡史<br>\n                        樹脂製造部　初期育成グループ</p>\n                </li>\n                <li class=\"inview\"><img src=\"image/pict09.jpg\" alt=\"pict09\">\n                    <p data-mh=\"data\">お正月に、大学時代に語学留学したシドニーへ。8年ぶりに会ったホストファミリーは、変わらず元気（犬も元気！）で安心しました。常夏の正月は貴重な体験となりました。</p>\n                    <p data-mh=\"name\" class=\"name\">荒谷 知夏<br>\n                        海外業務室</p>\n                </li>\n\t\t\t</ul>\n\t\t</div>\n    </article>\n</div>\n<div id=\"panBox\">\n    <div id=\"panList\"><img src=\"../common/image/pan_rogo.png\" alt=\"kakihara Recruiting Website\" width=\"178\" height=\"15\"> |　<a href=\"../index.html\">Home</a>　|　ワークライフ</div>\n</div>\n<footer id=\"footer\">\n    <div id=\"footerArea\">\n        <div id=\"footerNavi\" class=\"clearFix\">\n            <ul>\n                <li class=\"link\"> <a href=\"../index.html\"> ホーム</a> </li>\n                <li class=\"link\"> <a href=\"../about/about.html\">About Kakihara</a> </li>\n                <li class=\"link\"> <a href=\"../interview/interview.html\">トップインタビュー</a> </li>\n                <li class=\"link\"> <a href=\"../episode/episode.html\">開発エピソード</a> </li>\n                <li class=\"link\"> <a href=\"../cross01/closs01.html\">クロストーク</a> </li>\n                <li class=\"link\"> <a href=\"../worklife/worklife.html\">ワークライフ</a> </li>\n                <li class=\"link\"> <a href=\"../staff/staff.html\">カキハラ4＋</a> </li>\n                <li class=\"link\"> <a href=\"../works/works.html\">全仕事解説</a> </li>\n                <li class=\"link\"> <a href=\"../recruit.html\">採用情報</a> </li>\n                <li class=\"link\"> <a href=\"../entry/page.html\" class=\"mov-popup\">エントリー</a> </li>\n            </ul>\n        </div>\n        <div id=\"copyBox\" class=\"clearFix\">\n            <p>Copyright c 2017 Kakihara Industries Co., Ltd. All Rights Reserved.</p>\n            <div id=\"corpBox\">\n                <p><a href=\"http://www.kakihara.co.jp/\" target=\"_blank\">Corporate Website　<i class=\"fa fa-angle-right\" aria-hidden=\"true\"></i></a></p>\n                <a href=\"http://www.kakihara.co.jp/\" target=\"_blank\"><img src=\"../common/image/foot_rogo.png\" alt=\"foot_rogo\" width=\"169\" height=\"32\"></a> </div>\n        </div>\n        <div id=\"topBox\"> <a href=\"#Top\">Back to top</a></div>\n    </div>\n</footer>\n<script src=\"../js/jquery.magnific-popup.min.js\"></script> \n<script>\n\t//Ajax\n\t$(window).on('load', function() {\n\t\t$('.mov-popup').magnificPopup({\n\t\t\ttClose: '閉じる', \n\t\t\ttype: 'ajax'\n\t\t});\n\t});\n</script>\n</body>\n\n</html>","finalUrl":"https://www.kakihara.co.jp/recruit/worklife/worklife.html","rendered":false,"_cachedAt":"2026-06-22T21:00:30.504Z"}