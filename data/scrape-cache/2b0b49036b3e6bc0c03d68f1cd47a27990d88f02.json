{"url":"https://www.kankyou-seibi.co.jp/recruit/flow/","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n<head>\n<meta charset=\"UTF-8\">\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<meta name=\"format-detection\" content=\"email=no,telephone=no,address=no\">\n<title>仕事内容とキャリアイメージ｜博多湾環境整備株式会社 採用サイト｜港湾工事・浚渫工事・河川維持・海上清掃</title>\n\n<meta name=\"keywords\" content=\"\">\n<meta name=\"description\" content=\"博多湾環境整備では博多港長期構想の実現へ向け、港湾工事、浚渫工事、河川維持工事や海上清掃などインフラを整備する事業のほか、インバウンドやMICEに関わる事業として福岡市海浜公園の指定管理者や福岡国際センターの維持管理を行っています。また、アオサの回収や水質改善など、環境を守り育てる事業にも力を入れています。\">\n\n<link rel=\"icon\" href=\"../assets/img/common/favicon.png\">\n<link rel=\"stylesheet\" href=\"../assets/css/base.css\" rel=\"preload\" as=\"style\">\n<link rel=\"stylesheet\" href=\"../assets/css/style.css?20240531\" rel=\"preload\" as=\"style\">\n\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick.css\" rel=\"preload\" as=\"style\">\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick-theme.css\" rel=\"preload\" as=\"style\">\n<link rel=\"stylesheet\" href=\"https://use.fontawesome.com/releases/v5.6.1/css/all.css\" rel=\"preload\" as=\"style\">\n\n<!-- Global site tag (gtag.js) - Google Analytics -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=UA-171510190-1\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'UA-171510190-1');\n</script>\n</head>\n<body id=\"flow\" class=\"lower\">\n\n<header id=\"header\">\n\t<div class=\"inner\">\n\t\t<h1 class=\"logo\">\n\t\t\t<a href=\"../\">\n\t\t\t\t<img src=\"..//assets/img/common/logo.svg\" width=\"320\" height=\"38\" alt=\"博多湾環境整備株式会社\">\n\t\t\t\t<span>採用サイト</span>\n\t\t\t</a>\n\t\t</h1>\n\t\t<div class=\"burger-menu\">\n\t\t\t<nav class=\"gnav\">\n\t\t\t\t<ul>\n\t\t\t\t\t<li><a href=\"../data/\"><span class=\"en\">VARIOUS OUR DATA</span><span class=\"jp\">データで見る博多湾環境整備</span></a></li>\n                    <li><a href=\"../flow/\"><span class=\"en\">DESCRIPTION & CARRIER</span><span class=\"jp\">仕事内容とキャリアイメージ</span></a></li>\n                    <li><a href=\"../intern/\"><span class=\"en\">INTERNSHIP</span><span class=\"jp\">インターンシップ</span></a></li>\n\t\t\t\t\t<li><a href=\"../application/\"><span class=\"en\">APPLICATION GUIDELINES</span><span class=\"jp\">募集要項</span></a></li>\n\t\t\t\t\t<li><a href=\"../entry/\"><span class=\"en\">ENTRY</span><span class=\"jp\">エントリー</span></a></li>\n\t\t\t\t</ul>\n\t\t\t</nav>\n\t\t</div>\n\t\t<div class=\"burger\"><span></span><span></span><span></span></div>\n\t</div>\n</header>\n\n<div id=\"pagetop\"></div>\n\n<div id=\"pagehead\">\n    <div class=\"inner\">\n    \t<h2><span class=\"en\">DESCRIPTION & CARRIER</span><span class=\"jp\">仕事内容とキャリアイメージ</span></h2>\n        <nav class=\"breadcrumb\">\n        \t<ul itemscope=\"\" itemtype=\"http://schema.org/BreadcrumbList\">\n        \t\t<li itemprop=\"itemListElement\" itemscope=\"\" itemtype=\"http://schema.org/ListItem\">\n        \t\t\t<a itemprop=\"item\" href=\"../\"><span itemprop=\"name\">トップ</span></a>\n        \t\t\t<meta itemprop=\"position\" content=\"1\">\n        \t\t</li>\n        \t\t<li itemprop=\"itemListElement\" itemscope=\"\" itemtype=\"http://schema.org/ListItem\">\n        \t\t\t<span itemprop=\"name\">仕事内容とキャリアイメージ</span>\n        \t\t\t<meta itemprop=\"position\" content=\"2\">\n        \t\t</li>\n        \t</ul>\n        </nav>\n    </div>\n</div>\n\n<main id=\"main\">\n\t<article>\n\n\t\t<section class=\"sec01\">\n\t\t\t<div class=\"inner\">\n                <h3 class=\"title01\">\n                    <span class=\"jp\">仕事内容</span>\n                    <span class=\"en\">DESCRIPTION</span>\n                </h3>\n                <ul>\n                    <li>\n                        <div>\n                            <i><img src=\"../assets/img/flow/icon01.svg\" width=\"33\" height=\"42\" alt=\"\"></i>\n                            <h4>工程管理</h4>\n                            <p>\n\t                            ・工程表の作成<br>\n\t                            ・人員や資材等の手配<br>\n\t                            ・工程促進の工夫\n                            </p>\n                        </div>\n                    </li>\n                    <li>\n                        <div>\n                            <i><img src=\"../assets/img/flow/icon02.svg\" width=\"45\" height=\"35\" alt=\"\"></i>\n                            <h4>原価管理</h4>\n                            <p>\n\t                            ・工事原価の積算<br>\n\t                            ・人件費や材料費の数量集計<br>\n\t                            ・外注費等の交渉\n                            </p>\n                        </div>\n                    </li>\n                    <li>\n                        <div>\n                            <i><img src=\"../assets/img/flow/icon03.svg\" width=\"34\" height=\"40\" alt=\"\"></i>\n                            <h4>品質管理</h4>\n                            <p>\n\t                            ・工事写真の撮影<br>\n\t                            ・材料の寸法や品質の確認\n                            </p>\n                        </div>\n                    </li>\n                    <li>\n                        <div>\n                            <i><img src=\"../assets/img/flow/icon04.svg\" width=\"52\" height=\"31\" alt=\"\"></i>\n                            <h4>安全管理</h4>\n                            <p>\n\t                            ・危険予知活動（KY活動）<br>\n\t                            ・安全設備の設置<br>\n\t                            ・安全パトロール\n                            </p>\n                        </div>\n                    </li>\n                </ul>\n\t\t\t</div>\n\t\t</section>\n\n\t\t<section class=\"sec02\">\n\t\t\t<div class=\"inner\">\n                <h3 class=\"title01\">\n                    <span class=\"jp\">1日の流れ</span>\n                    <span class=\"en\">DAILY WORKFLOW</span>\n                </h3>\n                <div class=\"box\">\n                    <dl>\n                        <dt><span>7: 30</span></dt>\n                        <dd>\n                            <h4>出社</h4>\n                            <p>現場事務所に出社・作業の準備・エ程確認</p>\n                        </dd>\n                        <dt><span>7: 45</span></dt>\n                        <dd>\n                            <h4>朝礼</h4>\n                            <p>ラジオ体操・朝礼・危険予知活動(KY活動）</p>\n                        </dd>\n                        <dt><span>8: 00</span></dt>\n                        <dd>\n                            <h4>作業開始</h4>\n                            <p>現場の安全巡回・測量や工事写真撮影・発注者との打合せ・作業従事者とのコミュニケーション</p>\n                        </dd>\n                        <dt><span>10:00</span></dt>\n                        <dd>\n                            <h4>休憩</h4>\n                            <p>作業の一時中断・水分補給等</p>\n                        </dd>\n                        <dt><span>12:00</span></dt>\n                        <dd>\n                            <h4>昼休憩</h4>\n                            <p>現場事務所にて昼食・休憩</p>\n                        </dd>\n                        <dt><span>13:00</span></dt>\n                        <dd>\n                            <h4>作業開始</h4>\n                            <p>現場の安全巡回・測量や工事写真撮影・発注者や協力業者との打合せ・作業従事者とのコミュニケーション</p>\n                        </dd>\n                        <dt><span>15:00</span></dt>\n                        <dd>\n                            <h4>休憩</h4>\n                            <p>作業の一時中断・水分補給等</p>\n                        </dd>\n                        <dt><span>16:45</span></dt>\n                        <dd>\n                            <h4>後片付け</h4>\n                            <p>重機や資材の整理整頓・翌日の作業準備・飛散養生等</p>\n                        </dd>\n                        <dt><span>17:00</span></dt>\n                        <dd>\n                            <h4>作業終了</h4>\n                            <p>工事進捗の確認・工事日報の記載・帰宅</p>\n                        </dd>\n                    </dl>\n                </div>\n\t\t\t</div>\n\t\t</section>\n\n\t\t<section class=\"sec03\">\n\t\t\t<div class=\"inner\">\n                <h3 class=\"title02\">\n                    <span class=\"en\">CARRIER</span>\n                    <span class=\"jp\">キャリアイメージ</span>\n                </h3>\n                <ul>\n                    <li>\n                        <figure><img src=\"../assets/img/flow/career01.jpg\" width=\"400\" height=\"220\" alt=\"\"></figure>\n                        <div class=\"text\">\n                            <dl>\n                                <dt><span>1</span>年目</dt>\n                                <dd>\n                                    <h4>新人</h4>\n                                    <p>先輩について現場で施工管理について学ぶ。</p>\n                                </dd>\n                            </dl>\n                        </div>\n                    </li>\n                    <li>\n                        <figure><img src=\"../assets/img/flow/career02.jpg\" width=\"400\" height=\"220\" alt=\"\"></figure>\n                        <div class=\"text\">\n                            <dl>\n                                <dt><span>2</span>年目</dt>\n                                <dd>\n                                    <h4>工事担当者</h4>\n                                    <p>指示を受けながらも、自分で考え行動する。<br>資格取得必須。</p>\n                                </dd>\n                            </dl>\n                        </div>\n                    </li>\n                    <li>\n                        <figure><img src=\"../assets/img/flow/career03.jpg\" width=\"400\" height=\"220\" alt=\"\"></figure>\n                        <div class=\"text\">\n                            <dl>\n                                <dt><span>5</span>年目</dt>\n                                <dd>\n                                    <h4>現場代理人</h4>\n                                    <p>現場監督として、工事現場全般を管理する。</p>\n                                </dd>\n                            </dl>\n                        </div>\n                    </li>\n                </ul>\n\t\t\t</div>\n\t\t</section>\n\n\t</article>\n</main>\n\n\n<footer id=\"footer\">\n\t<div class=\"inner\">\n        <nav class=\"gnav\">\n    \t\t<ul>\n    \t\t\t<li><a href=\"../\">トップ</a></li>\n    \t\t\t<li><a href=\"../data/\">データで見る博多湾環境整備</a></li>\n                <li><a href=\"../flow/\">仕事内容とキャリアイメージ</a></li>\n                <li><a href=\"../intern/\">インターンシップ</a></li>\n    \t\t\t<li><a href=\"../application/\">募集要項</a></li>\n    \t\t\t<li><a href=\"../entry/\">エントリー</a></li>\n    \t\t</ul>\n        </nav>\n\t\t<h1 class=\"logo\">\n\t\t\t<a href=\"../\">\n\t\t\t\t<img src=\"..//assets/img/common/logo_w.svg\" width=\"185\" height=\"22\" alt=\"博多湾環境整備株式会社\">\n\t\t\t\t<span>採用サイト</span>\n\t\t\t</a>\n\t\t</h1>\n\t\t<ul class=\"link\">\n\t\t\t<li><a href=\"https://www.kankyou-seibi.co.jp/company/privacy.html\" target=\"_blank\">プライバシーポリシー</a></li>\n\t\t\t<li><a href=\"https://www.kankyou-seibi.co.jp/\" target=\"_blank\">コーポレートサイト</a></li>\n\t\t</ul>\n\t\t<div class=\"copyright\"><p>&copy;2024 博多湾環境整備株式会社</p></div>\n\t</div>\n</footer>\n\n<script src=\"https://ajax.googleapis.com/ajax/libs/jquery/3.6.0/jquery.min.js\" rel=\"preconnect\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick.min.js\" rel=\"preconnect\"></script>\n<script src=\"../assets/js/script.js\" rel=\"preconnect\"></script>\n\n</body>\n</html>","finalUrl":"https://www.kankyou-seibi.co.jp/recruit/flow/","rendered":false,"_cachedAt":"2026-06-22T21:51:08.866Z"}