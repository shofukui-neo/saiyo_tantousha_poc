   <h1 class=\"logo01\"><img src=\"images/common/logo01.svg?rev=2\" alt=\"株式会社 GSタカハシ\"></h1>\r\n          <p class=\"cne\"><span>GS</span> TAKAHASHI</p>\r\n        </a>\r\n        \r\n        <div id=\"menubox\">\r\n          <ul id=\"menucont\">\r\n            <li><a href=\"outline.html\"><p class=\"mtj\">会社概要</p><p class=\"mte\"><span>O</span>UTLINE</p></a></li>\r\n            <li><a href=\"airwash.html\"><p class=\"mtj\"><span class=\"cd01\">エアウォッシュとは</span></p><p class=\"mte\"><span>A</span>IR WASH</p></a></li>\r\n            <li><a href=\"original.html\"><p class=\"mtj\">オリジナル商品</p><p class=\"mte\"><span>O</span>RIGINAL <span>P</span>RODUCTS</p></a></li>\r\n            <li><a href=\"handled.html\"><p class=\"mtj\">取扱メーカー</p><p class=\"mte\"><span>P</span>RODUCTS <span>H</span>ANDLED</p></a></li>\r\n            <li><a href=\"sdgs.html\"><p class=\"mtj\">SDGs</p><p class=\"mte\"><span>SDGs</span></p></a></li>\r\n            <li><a href=\"recruit.html\"><p class=\"mtj\">採用情報</p><p class=\"mte\"><span>R</span>ECRUIT</p></a></li>\r\n          </ul> <!-- /#menucont -->\r\n        </div> <!-- /#menubox -->\r\n        \r\n        <div id=\"headtoibox\">\r\n          <a href=\"contact.html\">\r\n            <img class=\"icon\" src=\"images/common/icon_mail01.svg\" alt=\"\">\r\n            <p class=\"mtj\">お問合せ</p><p class=\"mte\"><span>C</span>ONTACT</p>\r\n          </a>\r\n        </div> <!-- /#headtoibox -->\r\n        \r\n      </div> <!-- /#obione -->\r\n      \r\n      <div id=\"thibox01\">\r\n        <div class=\"thitem\"><img src=\"images/recruit/thiph01.jpg\" alt=\"\"></div>\r\n        <div class=\"thitem\"><img src=\"images/recruit/thiph02.jpg?rev=2\" alt=\"\"></div>\r\n        <div class=\"thitem\"><img src=\"images/recruit/thiph03_2.jpg\" alt=\"\"></div>\r\n        <div class=\"thitem\"><img src=\"images/recruit/thiph04.jpg\" alt=\"\"></div>\r\n        <div class=\"thitem\"><img src=\"images/recruit/thiph05.jpg\" alt=\"\"></div>\r\n      </div> <!-- /#thibox01 -->\r\n      \r\n    </header>\r\n  </div> <!-- /#headerbase -->\r\n  <div id=\"midbase01\" class=\"midbase\">\r\n    <div id=\"midbox01\" class=\"midbox\">\r\n      \r\n      \r\n      <div class=\"calbar\">\r\n        <div class=\"calcore\">\r\n          <ul class=\"calcont\">\r\n            <li><a href=\"recruit.html#message\"><p>メッセージ</p></a></li>\r\n            <li><a href=\"recruit.html#newgraduate\"><p>新卒募集</p></a></li>\r\n            <li><a href=\"recruit.html#career\"><p>中途募集</p></a></li>\r\n            <li><a href=\"recruit.html#entryform\"><p>エントリーフォーム</p></a></li>\r\n            <li><a href=\"recruit.html#movie\"><p>ムービー</p></a></li>\r\n            <li><a href=\"https://www.gakujo.ne.jp/2024/company/baseinfo/25736/\" target=\"_blank\"><p>採用サイト</p></a></li>\r\n          </ul> <!-- /.calcont -->\r\n        </div> <!-- /.calcore -->\r\n      </div> <!-- /.calbar -->\r\n      \r\n      \r\n      <a id=\"message\" class=\"anc01\"></a>\r\n      \r\n      \r\n      <div id=\"stcb01_01\" class=\"stcont\">\r\n        <div id=\"stb01_01\" class=\"stbox01\">\r\n          <p class=\"ste\"><span>R</span>ECRUIT</p>\r\n          <h3 class=\"stj\">採用情報</h3>\r\n        </div>\r\n        \r\n        \r\n        <div id=\"ccatchbox01\">\r\n          <h4 id=\"ccatch01\">メッセージ <br class=\"mbbr\">〜GSタカハシを知る〜</h4>\r\n          <p id=\"cccom01\">\r\n            インテリア商材を扱う福岡の商社で創業81年目を迎えました。<br>\r\n            福岡天神地区の再開発や高齢化に伴い<br class=\"mbbr\">住環境に対する変化を読み取り、<br>\r\n            お客様の期待にしっかり応えていきたいと思ってます。<br>\r\n            そのためフレッシュな力が必要です。<br class=\"mbbr\">あなたらしく仕事を楽しんで力を存分に発揮してください。\r\n          </p>\r\n        </div> <!-- /#ccatchbox01 -->\r\n        \r\n        \r\n        <div id=\"rdbox01\">\r\n          \r\n          <div id=\"psn01\" class=\"rdbitem\">\r\n            <div class=\"ib\"><img src=\"images/recdetail/rdph01.jpg\" alt=\"\"></div>\r\n            <div class=\"info\">\r\n              <div class=\"ihb rt\">\r\n                <p class=\"it\">＃01 ｜ 谷村 彰彦</p>\r\n                <p class=\"ii\">福岡本社　営業部長 / 1984年入社</p>\r\n              </div>\r\n              <div class=\"icb\">\r\n                <p class=\"hl\">若い社員の成長を感じられるところが、やりがいです。</p>\r\n                <div class=\"qab\">\r\n                  <dl class=\"qa\">\r\n                    <dt>Q:担当業務・仕事内容を教えてください</dt>\r\n                    <dd>\r\n                      本社にいますので、本社と営業所間の取りまとめ役が基本業務です。\r\n                    </dd>\r\n                  </dl>\r\n                  <dl class=\"qa\">\r\n                    <dt>Q:仕事のやりがいを教えてください</dt>\r\n                    <dd>\r\n                      社員がそれぞれ色々な考え方や捉え方をしますので、その事について話をするのが大変楽しく感じます。それに加えて、若い社員の成長を感じられるところがやりがいです。\r\n\r\n                    </dd>\r\n                  </dl>\r\n                  <dl class=\"qa\">\r\n                    <dt>Q:会社に入って成長したところを<br>教えてください</dt>\r\n                    <dd>\r\n                      対面する方々との、聞き方、話し方が少しは成長したかな？<br>\r\n                      と思っています。\r\n                    </dd>\r\n                  </dl>\r\n                  <dl class=\"qa\">\r\n                    <dt>Q:就活の方に<br>会社のアピールをしてください</dt>\r\n                    <dd>\r\n                      我社、㈱ＧＳタカハシは、人間関係が他社と比較にならないくらい良好だと思っています。<br>\r\n                      外部の方からもそのような話を聞きますので、間違いありません。こういう基本的なところが一番の会社です。\r\n                    </dd>\r\n                  </dl>\r\n                </div> <!-- /.qab -->\r\n              </div> <!-- /.icb -->\r\n              <div class=\"lb\">\r\n                <a class=\"rlbtn\" href=\"recruit.html#psn01\">一覧に戻る</a>\r\n              </div>\r\n            </div> <!-- /.info -->\r\n          </div> <!-- /.rdbitem -->\r\n          \r\n          <div id=\"psn02\" class=\"rdbitem\">\r\n            <div class=\"ib\"><img src=\"images/recdetail/rdph02.jpg\" alt=\"\"></div>\r\n            <div class=\"info\">\r\n              <div class=\"ihb\">\r\n                <p class=\"it\">＃02 ｜ 古賀 優希</p>\r\n                <p class=\"ii\">福岡南営業所　営業主任 / 2007年入社</p>\r\n              </div>\r\n              <div class=\"icb\">\r\n                <p class=\"hl\">お客様から頼りになるという言葉をもらった時がやりがいを感じます。</p>\r\n                <div class=\"qab\">\r\n                  <dl class=\"qa\">\r\n                    <dt>Q:担当業務・仕事内容を教えてください</dt>\r\n                    <dd>\r\n                      取引があるお客様へのルート営業です。<br>\r\n                      新商品のご案内や問い合わせへの対応、現場での打ち合わせ、現場への商品の配達など。<br>\r\n                      お客様からのご紹介などで新規店の開拓もやっています。\r\n                    </dd>\r\n                  </dl>\r\n                  <dl class=\"qa\">\r\n                    <dt>Q:仕事のやりがいを教えてください</dt>\r\n                    <dd>\r\n                      日々仕事をして得た知識や職人さんとの構築した関係を発揮して、現場がスムーズに流れていくように、臨機応変な対応が出来てお客様から頼りになるという言葉をもらった時がやりがいを感じます。\r\n                    </dd>\r\n                  </dl>\r\n                  <dl class=\"qa\">\r\n                    <dt>Q:会社に入って成長したところを<br>教えてください</dt>\r\n                    <dd>\r\n                      高卒で入社し、社会の事が全く分からない状態でしたが、始めの頃は上司、先輩社員の方に社会人としての基本を教わりました。<br>\r\n                      営業に出てからは情報収集の大切さを学び、色んな方と会話する仕事ですので仕事の事のみならず色んな媒体に目を向けられるようになりました。\r\n                    </dd>\r\n                  </dl>\r\n                  <dl class=\"qa\">\r\n                    <dt>Q:就活の方に<br>会社のアピールをしてください</dt>\r\n                    <dd>\r\n                      ゼロからのスタートは誰でもどこでも同じです。<br>\r\n                      私自身も常に後輩社員と共に成長しようと思っています。<br>\r\n                      そういう思いの社員が多い会社だと思いますので、やりがいもあり、働きやすいです。\r\n                    </dd>\r\n                  </dl>\r\n                </div> <!-- /.qab -->\r\n              </div> <!-- /.icb -->\r\n              <div class=\"lb\">\r\n                <a class=\"rlbtn\" href=\"recruit.html#psn02\">一覧に戻る</a>\r\n              </div>\r\n            </div> <!-- /.info -->\r\n          </div> <!-- /.rdbitem -->\r\n          \r\n          <div id=\"psn03\" class=\"rdbitem\">\r\n            <div class=\"ib\"><img src=\"images/recdetail/rdph03.jpg?rev=2\" alt=\"\"></div>\r\n            <div class=\"info\">\r\n              <div class=\"ihb\">\r\n                <p class=\"it\">＃03 ｜ 宮原 杏花</p>\r\n                <p class=\"ii\">本社　営業部 / 2021年入社</p>\r\n              </div>\r\n              <div class=\"icb\">\r\n                <p class=\"hl\">挨拶をしたお客様に顔を覚えて頂けると身が引き締まる思いになります。</p>\r\n                <div class=\"qab\">\r\n                  <dl class=\"qa\">\r\n                    <dt>Q:担当業務・仕事内容を教えてください</dt>\r\n                    <dd>\r\n                      営業に所属しています。まだ入社して３カ月なので、先輩に同行しカタログの配布をしたり、打合せや集金をしにお客様訪問をしています。また、今は商品を覚えたり、お客様への対応の仕方を学んだりするために事務所で電話応対や受発注などをすることもあります。\r\n                    </dd>\r\n                  </dl>\r\n                  <dl class=\"qa\">\r\n                    <dt>Q:仕事のやりがいを教えてください</dt>\r\n                    <dd>\r\n                      今はまだお客様と接することは少ないのですが、挨拶をしたお客様に顔を覚えて頂いていた時や“頑張ってね”や“期待してるよ”と言われると身が引き締まる思いになります。また、研修中に倉庫で入出荷の手伝いをして商品の名前や用途を覚え、スムーズに商品のピッキングや受発注ができたときやりがいを感じます。\r\n                    </dd>\r\n                  </dl>\r\n                  <dl class=\"qa\">\r\n                    <dt>Q:会社に入って成長したところを<br>教えてください</dt>\r\n                    <dd>\r\n                      まず、基本的なことですが、敬語をきちんと使えたり、電話応対で焦らずにスムーズに対応できたときは成長したと感じます。また、営業の先輩に同行してお客様から商品の発注や相談を受けたときに、ぱっと商品が頭に浮かんできたときは、少しずつでも知識が身についてきたなと感じます。\r\n                    </dd>\r\n                  </dl>\r\n                  <dl class=\"qa\">\r\n                    <dt>Q:就活の方に<br>会社のアピールをしてください</dt>\r\n                    <dd>\r\n                      まず、ここで働いている事務の方も営業の方も皆さん本当に人が良いなと思います。疑問に思うことや分からないこと、改善してほしいことなどを言いやすく、みなさん優しく答えてくださります。また、扱っている商品が、襖や取手、壁紙、カーテン、水回りなど幅広く、初めて知るものだらけで面白いです。インテリアや住居に興味がある方、人と接することが好きな方はぜひ来てみてください！\r\n                    </dd>\r\n                  </dl>\r\n                </div> <!-- /.qab -->\r\n              </div> <!-- /.icb -->\r\n              <div class=\"lb\">\r\n                <a class=\"rlbtn\" href=\"recruit.html#psn03\">一覧に戻る</a>\r\n              </div>\r\n            </div> <!-- /.info -->\r\n          </div> <!-- /.rdbitem -->\r\n          \r\n          <div id=\"psn04\" class=\"rdbitem\">\r\n            <div class=\"ib\"><img src=\"images/recdetail/rdph04_2.jpg\" alt=\"\"></div>\r\n            <div class=\"info\">\r\n              <div class=\"ihb\">\r\n                <p class=\"it\">＃04 ｜ 黒岩 宏士朗</p>\r\n                <p class=\"ii\">福岡西営業所 / 2018年入社</p>\r\n              </div>\r\n              <div class=\"icb\">\r\n                <p class=\"hl\">価格ではなく自分という個人をお客様から評価していただき<br>発注を頂けた時が嬉しく思います。</p>\r\n                <div class=\"qab\">\r\n                  <dl class=\"qa\">\r\n                    <dt>Q:担当業務・仕事内容を教えてください</dt>\r\n                    <dd>\r\n                      弊社と取引していただいているお客様へのルート営業になります。<br>\r\n                      主に、商材の受発注、納品、現場の打ち合わせ、商材のPR、集金など 大変多くの事をやります。\r\n                    </dd>\r\n                  </dl>\r\n                  <dl class=\"qa\">\r\n                    <dt>Q:仕事のやりがいを教えてください</dt>\r\n                    <dd>\r\n                      一番はお客様に「黒岩君に発注して良かった。ありがとう」と言われる事が、この仕事をしてよかったと感じます。<br>\r\n                      その他には、ライバル企業がたくさんある中で、価格ではなく自分という個人をお客様から評価していただき発注を頂けた時が嬉しく思います。\r\n                    </dd>\r\n                  </dl>\r\n                  <dl class=\"qa\">\r\n                    <dt>Q:会社に入って成長したところを<br>教えてください</dt>\r\n                    <dd>\r\n                      元々は受け身気質だったのですが、営業職になったことで自ら考えて行動して主体性を発揮できるようになったところが一番成長できました。<br>\r\n                      また、その他にも「計画力」「対応力」「コミュニケーション能力」など様々な点でも成長できたと思います。\r\n                    </dd>\r\n                  </dl>\r\n                  <dl class=\"qa\">\r\n                    <dt>Q:就活の方に<br>会社のアピールをしてください</dt>\r\n                    <dd>\r\n                      大変多くの商材を取り扱い、その商材を現場に納品するので「知識」と「体力」が求められる仕事になりますが、社員がお互いに助け合う雰囲気の良い働きやすい職場です。<br>\r\n                      営業やインテリアに興味がある方はぜひ会社説明会に来てみてください!\r\n                    </dd>\r\n                  </dl>\r\n                </div> <!-- /.qab -->\r\n              </div> <!-- /.icb -->\r\n              <div class=\"lb\">\r\n                <a class=\"rlbtn\" href=\"recruit.html#psn04\">一覧に戻る</a>\r\n              </div>\r\n            </div> <!-- /.info -->\r\n          </div> <!-- /.rdbitem -->\r\n          \r\n          <div id=\"psn05\" class=\"rdbitem\">\r\n            <div class=\"ib\"><img src=\"images/recdetail/rdph05.jpg?rev=5\" alt=\"\"></div>\r\n            <div class=\"info\">\r\n              <div class=\"ihb rt\">\r\n                <p class=\"it\">＃05 ｜ 古賀 宏章</p>\r\n                <p class=\"ii\">大分営業所　所長 / 1995年入社</p>\r\n              </div>\r\n              <div class=\"icb\">\r\n                <p class=\"hl\">様々な困難に直面しますが、所員全員で立ち向かい、助け合い、<br>ワンチームとして業務を遂行しています。</p>\r\n                <div class=\"qab\">\r\n                  <dl class=\"qa\">\r\n                    <dt>Q:担当業務・仕事内容を教えてください</dt>\r\n                    <dd>\r\n                      大分営業所の責任者です。仕事内容は多岐にわたっています。<br>\r\n                      私の重要な役割は所員全員が円滑に仕事ができる雰囲気作りとやる気を出させるモチベーション作りです。そして営業所目標を達成するために業務の進捗状況を確認しながら指導・育成していくことが私の仕事であります。\r\n                    </dd>\r\n                  </dl>\r\n                  <dl class=\"qa\">\r\n                    <dt>Q:仕事のやりがいを教えてください</dt>\r\n                    <dd>\r\n                      様々な困難に直面しますが、所員全員で立ち向かい、助け合い、ワンチームとして業務を遂行しています。部下が成果を上げたとき、成長したとき、そんな姿をみて大変嬉しく思います。<br>\r\n                      またお客様が当社の対応に満足され会社・所員へ感謝の言葉を頂いたときは苦労した甲斐があったと心から思えます。\r\n                    </dd>\r\n                  </dl>\r\n                  <dl class=\"qa\">\r\n                    <dt>Q:会社に入って成長したところを<br>教えてください</dt>\r\n                    <dd>\r\n                      社会人としての基本的なマナーや知識はもちろんのこと、精神面での向上ができたと思われます。仕事は嫌な相手でも無視はできません、相手を選ぶこともできません。人間関係の構築は非常に重要であり、幅広い関係を築くことにより視野も広がります。何よりも自分自身の限界が深くなりました。\r\n                    </dd>\r\n                  </dl>\r\n                  <dl class=\"qa\">\r\n                    <dt>Q:就活の方に<br>会社のアピールをしてください</dt>\r\n                    <dd>\r\n                      どんな仕事も決して楽ではありません。<br>\r\n                      ＧＳタカハシももちろん楽ではありません、が当社には大企業にないアットホーム的な雰囲気がたくさんあります。ぜひ入社して家族になってみませんか。\r\n                    </dd>\r\n                  </dl>\r\n                </div> <!-- /.qab -->\r\n              </div> <!-- /.icb -->\r\n              <div class=\"lb\">\r\n                <a class=\"rlbtn\" href=\"recruit.html#psn05\">一覧に戻る</a>\r\n              </div>\r\n            </div> <!-- /.info -->\r\n          </div> <!-- /.rdbitem -->\r\n          \r\n          <div id=\"psn06\" class=\"rdbitem\">\r\n            <div class=\"ib\"><img src=\"images/recdetail/rdph06.jpg\" alt=\"\"></div>\r\n            <div class=\"info\">\r\n              <div class=\"ihb\">\r\n                <p class=\"it\">＃06 ｜ 山口 滉樹</p>\r\n                <p class=\"ii\">福岡南営業所　営業主任 / 2016年入社</p>\r\n              </div>\r\n              <div class=\"icb\">\r\n                <p class=\"hl\">自分が提案した商品が採用。その現場で暮らす人の笑顔がやりがいです。</p>\r\n                <div class=\"qab\">\r\n                  <dl class=\"qa\">\r\n                    <dt>Q:担当業務・仕事内容を教えてください</dt>\r\n                    <dd>\r\n                      営業職です。基本的には既存お客様へのルートセールスになります。<br>\r\n                      セールスといっても、お客様と一緒にひとつの現場を作り上げる、言わば協力業者です。材料運搬や打ち合わせ等、お客様のお仕事をサポートするのが、メインの仕事になります。\r\n                    </dd>\r\n                  </dl>\r\n                  <dl class=\"qa\">\r\n                    <dt>Q:仕事のやりがいを教えてください</dt>\r\n                    <dd>\r\n                      自分の提案した商品が採用されたとき。<br>\r\n                      また、携わった現場の工事が終わり、そこで人々が笑顔で生活していたり、働いていたりするのを見たときに嬉しい気持ちになり、やりがいを感じます。\r\n                    </dd>\r\n                  </dl>\r\n                  <dl class=\"qa\">\r\n                    <dt>Q:会社に入って成長したところを<br>教えてください</dt>\r\n                    <dd>\r\n                      5年前、新卒で入社したのですが、その前と比べ、スケジュールの組み方、上手な時間の使い方が仕事をするうえで、自然と身に付いたと感じます。<br>\r\n                      また、毎日多くのお客様とお話する機会があるので、目上の方との話し方や接し方等、まだまだ未熟ですが、日々成長中です。\r\n                    </dd>\r\n                  </dl>\r\n                  <dl class=\"qa\">\r\n                    <dt>Q:就活の方に<br>会社のアピールをしてください</dt>\r\n                    <dd>\r\n                      弊社の魅力としましては、九州の建築業界ではトップクラスの高いシェアを誇っている点です。<br>\r\n                      また、年に一度、全社員が､一同に集まる新年会であったり、社内ソフトボール大会や、社員旅行など社員間の親睦を深めるイベントもあり、非常に働きやすい会社です。\r\n                    </dd>\r\n                  </dl>\r\n                </div> <!-- /.qab -->\r\n              </div> <!-- /.icb -->\r\n              <div class=\"lb\">\r\n                <a class=\"rlbtn\" href=\"recruit.html#psn06\">一覧に戻る</a>\r\n              </div>\r\n            </div> <!-- /.info -->\r\n          </div> <!-- /.rdbitem -->\r\n          \r\n        </div> <!-- /#rdbox01 -->\r\n        \r\n        \r\n      </div> <!-- /#stcb01_01 -->\r\n      \r\n      \r\n      \r\n    </div> <!-- /#midbox01 -->\r\n  </div> <!-- /#midbase01 -->\r\n  <div id=\"mfclbase\" class=\"midbase\">\r\n    <div id=\"mfclbox\" class=\"midbox\">\r\n      \r\n      \r\n      <div id=\"mfclstcb01\" class=\"stcont\">\r\n        \r\n        <div id=\"clb01_01\" class=\"clinkbox\">\r\n          <div id=\"clc01_01\" class=\"clinkcont\">\r\n            \r\n            <a id=\"cl01_01_01\" class=\"clink\" href=\"original.html\">\r\n              <div class=\"ib\">\r\n                <img src=\"images/common/clph01.jpg\" alt=\"\">\r\n                <p class=\"itj cd01\">オリジナル商品</p>\r\n              </div>\r\n              <p class=\"ite\"><span>O</span>RIGINAL <span>P</span>RODUCTS</p>\r\n            </a>\r\n            \r\n            <a id=\"cl01_01_02\" class=\"clink\" href=\"recruit.html\">\r\n              <div class=\"ib\">\r\n                <img src=\"images/common/clph02.jpg\" alt=\"\">\r\n                <p class=\"itj\">採用情報</p>\r\n              </div>\r\n              <p class=\"ite\"><span>R</span>ECRUIT</p>\r\n            </a>\r\n            \r\n            <a id=\"cl01_01_03\" class=\"clink\" href=\"outline.html\">\r\n              <div class=\"ib\">\r\n                <img src=\"images/common/clph03.jpg?rev=3\" alt=\"\">\r\n                <p class=\"itj\">会社概要</p>\r\n              </div>\r\n              <p class=\"ite\"><span>O</span>UTLINE</p>\r\n            </a>\r\n            \r\n          </div> <!-- /.clinkcont -->\r\n        </div> <!-- /.clinkbox -->\r\n        \r\n      </div> <!-- /#mfclstcb01 -->\r\n      \r\n      \r\n    </div> <!-- /#mfclbox -->\r\n  </div> <!-- /#mfclbase -->\r\n  <div id=\"midfootbase\" class=\"midbase\">\r\n    <div id=\"midfootbox\" class=\"midbox\">\r\n      \r\n      <div id=\"mfbannerbox\">\r\n        <a class=\"mfbanner\" href=\"outline.html#paperroad\"><img src=\"images/common/mfbanner_paperroad01.jpg\" alt=\"GSタカハシの原点 和紙の専門店 PAPER ROAD FUKUOKA\"></a>\r\n      </div> <!-- /#mfbannerbox -->\r\n      \r\n      <a class=\"rtt01\"><p>PAGE TOP</p></a>\r\n      \r\n    </div> <!-- /#midfootbox -->\r\n  </div> <!-- /#midfootbase -->\r\n  <div id=\"footerbase\">\r\n    <footer>\r\n      \r\n      <div id=\"fmenubox\">\r\n        <ul id=\"fmenucont\">\r\n          <li><a href=\"outline.html\"><p class=\"mtj\">会社概要</p></a></li>\r\n          <li><a href=\"airwash.html\"><p class=\"mtj\">エアウォッシュとは</p></a></li>\r\n          <li><a href=\"original.html\"><p class=\"mtj\">オリジナル商品</p></a></li>\r\n          <li><a href=\"handled.html\"><p class=\"mtj\">取扱メーカー</p></a></li>\r\n          <li><a href=\"sdgs.html\"><p class=\"mtj\">SDGs</p></a></li>\r\n          <li><a href=\"recruit.html\"><p class=\"mtj\">採用情報</p></a></li>\r\n          <li><a href=\"contact.html\"><p class=\"mtj\">お問合せ</p></a></li>\r\n        </ul> <!-- /#fmenucont -->\r\n      </div> <!-- /#fmenubox -->\r\n      \r\n      <div id=\"footinfobox01\">\r\n        <a id=\"footlogo01\" href=\"./\">\r\n          <p class=\"logo02\"><img src=\"images/common/logo02.svg\" alt=\"株式会社 GSタカハシ\"></p>\r\n        </a>\r\n        <div id=\"finfo01\">\r\n          <p class=\"info\">\r\n            商　号　株式会社GSタカハシ<br>\r\n            所在地　〒810-0001 福岡市中央区天神3-10-10<br>\r\n            　　　　TEL 092-741-3231<br>\r\n            　　　　FAX 092-712-8496\r\n          </p>\r\n        </div> <!-- /#finfo01 -->\r\n      </div> <!-- /#footinfobox01 -->\r\n      \r\n      <p id=\"footcopy\">&copy; 2021 GS TAKAHASHI co.,ltd.</p>\r\n      \r\n    </footer>\r\n  </div> <!-- /#footerbase -->\r\n</div> <!-- /#bodybox -->\r\n\r\n\r\n\r\n\r\n\r\n\r\n</body>\r\n</html>","finalUrl":"https://www.gs-takahashi.co.jp/recdetail.html","rendered":false,"_cachedAt":"2026-06-22T19:44:44.357Z"}