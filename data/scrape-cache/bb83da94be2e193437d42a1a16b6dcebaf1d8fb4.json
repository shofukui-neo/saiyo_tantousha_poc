login-logout-pict').removeClass(\"login\");\n\t\t\t\t\t\t$('#login-logout-pict').html('<a class=\"hide-for-large hide-for-xlarge key-login-small has-bg-img\" href=\"/OCLSTF0000.do\">ログイン</a>');\n\t\t\t\t\t//$('#smartNaviButton').append('<li class=\"hide-for-large hide-for-xlarge quick-login-small\"><a class=\"hide-for-large hide-for-xlarge key-login-small has-bg-img\" href=\"/OCLSTF0000.do\">ログイン</a></li>');\n\t\t\t\t\t\t$('#smartNaviButton').append('<li class=\"hide-for-large hide-for-xlarge key-registration\"><a href=\"/office/registration/\">登録</a></li>');\n\t\t\t\t\t//$('#smartNaviButton').append('<li class=\"has-sep hide-for-small hide-for-medium\"><a href=\"/about/\">ランスタッドについて</a></li>');\n\t\t\t\t\t//$('#smartNaviButton').append('<li class=\"has-sep hide-for-small hide-for-medium\"><a href=\"/contact/\">お問い合わせ</a></li>');\n\t\t\t\t\t\t$('#smartNaviButton').append('<li class=\"hide-for-small hide-for-medium my-randstad-login has-bg-img-before\"><a href=\"/OCLSTF0000.do\">ログイン</a></li>');\n\t\t\t\t\t$('#loginSideMenu').hide();\n\t\t\t\t\t$('#loginPanelOuter').remove();\n\t\t\t\t}\n\t\t\t\tnaviRebind();\n\t\t\t\trenderQuickLogin();\n\t\t\t});\n\t\t}\n\t\tfunction setGnaviRegistLink() {\n\t\t\tvar gnaviRegistUrl;\n\t\t\tif(document.URL.match(\"/office/\")) {\n\t\t\t\tgnaviRegistUrl = \"/registration/OSTSTF0010.do?brand=office\";\n\t\t\t} else if(document.URL.match(\"/factory/\")) {\n\t\t\t\tgnaviRegistUrl = \"/registration/OSTSTF0010.do?brand=factory\";\n\t\t\t} else if(document.URL.match(\"/spot/\")) {\n\t\t\t\tgnaviRegistUrl = \"/registration/OSTSTF0010.do?brand=spot\";\n\t\t\t} else if(document.URL.match(\"/tenshoku/\")) {\n\t\t\t\tgnaviRegistUrl = \"/mypage/OWMSTF0100.do?brand=tenshoku\";\n\t\t\t} else if(document.URL.match(\"/professionals/\")) {\n\t\t\t\tgnaviRegistUrl = \"/mypage/OWMSTF0100.do?brand=professionals\";\n\t\t\t} else {\n\t\t\t\tgnaviRegistUrl = \"/find-jobs/registration/\";\n\t\t\t}\n\t\t\t$(\"#gnaviRegistLink a\").attr(\"href\", gnaviRegistUrl);\n\t\t}\n\t\tfunction naviRebind() {\n\t\t\t$(document).on('click','#header.login .topNavi .login_link',function(){\n\t\t\t\t$(\"#header.login #headerPanel\").toggle();\n\t\t\t});\n\t\t}\n\t\t// ログイン判定\n\t\t$(function(){\n\t\t\tgetLoginStatus();\n\t\t\tsetGnaviRegistLink();\n\t\t});\n\t</script>\n</header>\n<div id=\"loginPanelOuter\" class=\"my-randstad-login-panel\">\n\t<div class=\"my-randstad-login-panel-active\">\n\t\t<div class=\"my-randstad-login-panel--inner\"><span class=\"my-randstad-login-name\"></span>\n\t\t\t<ul id=\"loginPanel\" class=\"list-clean\">\n\t\t\t</ul>\n\t\t\t<a class=\"btn btn-prim\" href=\"/OCLSTF0050.do\">ログアウト</a></div>\n\t</div>\n\t<!-- / .my-randstad-login-panel --></div>\n      <nav class=\"rs-breadcrumb__nav\" aria-label=\"現在位置\">\n        <ol class=\"rs-breadcrumb rs-none rs-md:flex\">\n          <li class=\"rs-breadcrumb__item\"><a class=\"rs-breadcrumb__link\" href=\"/\"><span class=\"rs-breadcrumb__text\">ランスタッドの求人・転職・派遣TOP</span></a></li>\n          <li class=\"rs-breadcrumb__item\"><a class=\"rs-breadcrumb__link\" href=\"/recruit/\"><span class=\"rs-breadcrumb__text\">採用情報</span></a></li>\n          <li class=\"rs-breadcrumb__item\"><a class=\"rs-breadcrumb__link\" href=\"/recruit/evp/\"><span class=\"rs-breadcrumb__text\">EVP（従業員価値提案）と私たちの想い</span></a></li>\n        </ol>\n      </nav>\n    </div>\n    <div id=\"sb-site\">\n      <div class=\"main\" id=\"ContentWrapper\">\n        <div class=\"box-content cf\" id=\"OneColumnDiv\"><a id=\"skipnav\"></a>\n          <div id=\"OneColumnInnerDiv\">\n<main>\n              <div class=\"rs-main-title-layout\">\n                <div class=\"rs-base-layout\">\n                  <h1 class=\"rs-heading rs-heading--level-1\"><span>EVP（従業員価値提案）と私たちの想い</span></h1>\n                </div>\n              </div>\n              <section class=\"rs-section-layout rs-strip rs-strip--beige\">\n                <div class=\"rs-base-layout\">\n                  <div class=\"rs-top-contents rs-top-contents--evp\">\n                    <div class=\"rs-top-contents__image rs-text-center\"><img src=\"/recruit/img_f/icon-benefit-lead.svg\" width=\"254\" height=\"254\" alt=\"\"></div>\n                    <div class=\"rs-top-contents__lead\">\n                      <p>EVPとは、英語の「Employee Value Proposition」の頭文字を取った略語で、直訳である「従業員価値提案」と呼ばれることもあります。<br>ランスタッドで働くということは、人々が意義のある仕事を見つけ、関連スキルを習得し、目的意識と帰属意識を持つことを支援する情熱的なグローバルコミュニティの一員となるということです。才能、目標、強みに関しては、2人として同じ人はいないということを私たちは理解しています。<br>だからこそ、私たちは、皆さん一人ひとりが成長するために必要な専門スキルを習得し、貢献が認められ、人々の生活に変化をもたらすキャリアを歩めるよう導くことに全力を尽くしています。<br>ランスタッドでは、誰もが歓迎され、祝福される包括的な環境の一員となることができます。そして、ランスタッドとして重要なのは、皆さんの幸福を優先し、ご自身が仕事でもプライベートでも成長できるよう努めていることです。<br>私たちは、個々の力を合わせた以上の力を発揮し、仕事を通じて社会にポジティブな影響を与えています。これがランスタッドの存在意義です。</p>\n                    </div>\n                  </div>\n                </div>\n              </section>\n              <div class=\"rs-base-layout rs-mt-50-80\">\n                <section class=\"rs-section-layout\">\n                  <h2 class=\"rs-heading rs-heading--level-2\">私たちは共に成長します　\" together we grow \"</h2>\n                  <p>ランスタッドは世界で最も公平で専門性を備えた人材サービス企業になるというミッションのもと、「人」こそがビジネスの中核であると捉え、従業員エンゲージメントの向上と選ばれる雇用主となることを目指し新EVPを以下の５つの柱に基づいて新たに提案しています。</p>\n                </section>\n                <section class=\"rs-section-layout\">\n                  <h3 class=\"rs-heading rs-heading--level-3\">5 pillars together we grow.（5つの柱）</h3>\n                  <div class=\"rs-mt-30-50 rs-pillar-grid\">\n                    <div class=\"rs-pillar-layout\">\n                      <figure class=\"rs-pillar-layout__img\"><img src=\"/recruit/img_f/evp_01.svg\" alt=\"パーパス（目的)\" width=\"120\" height=\"120\" loading=\"lazy\"></figure>\n                      <h4 class=\"rs-pillar-layout__title\">パーパス（目的)</h4>\n                      <p class=\"rs-pillar-layout__text\">私たちは、世界で最も公平で専門性を備えた人材サービス会社になるというミッションを掲げています。人々が有意義な仕事につき、それぞれが適切なスキルを身につけ、職場に目的と居場所を見出す手助けをします。</p>\n                    </div>\n                    <div class=\"rs-pillar-layout\">\n                      <figure class=\"rs-pillar-layout__img\"><img src=\"/recruit/img_f/evp_02.svg\" alt=\"企業文化\" width=\"120\" height=\"120\" loading=\"lazy\"></figure>\n                      <h4 class=\"rs-pillar-layout__title\">企業文化</h4>\n                      <p class=\"rs-pillar-layout__text\">私たちのコア・バリュー「to know, to serve, to trust（よく知ることを通して、献身的な姿勢で、信頼関係を築く。）」、「striving for perfection（最高のサービスを弛むことなく追求する。）」,「simultaneous promotion of all interests（すべてのビジネスパートナーの満足を追求する。）」は、人を重視する強い企業文化の基盤となっています。公平性は私たちのビジネスの中核であり、誰もが活躍できるインクルーシブ（包括的）な職場構築に専心します。</p>\n                    </div>\n                    <div class=\"rs-pillar-layout\">\n                      <figure class=\"rs-pillar-layout__img\"><img src=\"/recruit/img_f/evp_03.svg\" alt=\"成長とキャリア\" width=\"120\" height=\"120\" loading=\"lazy\"></figure>\n                      <h4 class=\"rs-pillar-layout__title\">成長とキャリア</h4>\n                      <p class=\"rs-pillar-layout__text\">個人の成長に対する私たちのアプローチは、あなたが持っているユニークな才能やスキルを認めることから始まります。スキルアップやキャリア開発、メンターシップ・プログラムを通じて成長するためのサポートを提供し、将来の目標や希望に到達するためのキャリアパスの実現に導きます。</p>\n                    </div>\n                    <div class=\"rs-pillar-layout\">\n                      <figure class=\"rs-pillar-layout__img\"><img src=\"/recruit/img_f/evp_04.svg\" alt=\"ウェルビーイング\" width=\"120\" height=\"120\" loading=\"lazy\"></figure>\n                      <h4 class=\"rs-pillar-layout__title\">ウェルビーイング</h4>\n                      <p class=\"rs-pillar-layout__text\">あなたがベストな状態でいてこそ、私たちはタレント（人材）とクライアント企業に最高のサービスを提供できるのです。ランスタッドは、あなたが公私共に活躍できるよう、あなたのウェルビーイングを優先します。これには、メンタルヘルスサポートや、チームのニーズを考慮した柔軟な勤務形態も含まれます。</p>\n                    </div>\n                    <div class=\"rs-pillar-layout\">\n                      <figure class=\"rs-pillar-layout__img\"><img src=\"/recruit/img_f/evp_05.svg\" alt=\"報酬\" width=\"120\" height=\"120\" loading=\"lazy\"></figure>\n                      <h4 class=\"rs-pillar-layout__title\">報酬</h4>\n                      <p class=\"rs-pillar-layout__text\">ランスタッドでは、あなたの努力と業績に対して、相応で競争力のある、公平な報酬が与えられます。ランスタッドでは、従業員からのフィードバック、外部市場のインサイト、社内カリブレーションに基づいて、報奨方針と慣行を定期的に見直しています。また、株式所有の促進を通じて、私たちの成功を分かち合うことを奨励しています。</p>\n                    </div>\n                  </div>\n                </section>\n                <section class=\"rs-section-layout\">\n                  <h3 class=\"rs-heading rs-heading--level-3\">ランスタッド・ジャパンEVPブックレット</h3>\n                  <p>詳しくは以下ブックレットをご覧ください。</p>\n                  <div class=\"rs-mt-30-50\">\n                    <script class=\"docswell-embed\" async src=\"https://www.docswell.com/assets/libs/docswell-embed/docswell-embed.min.js\" data-src=\"https://www.docswell.com/slide/ZMX2DE/embed?key=2025-03-25-174430\" data-aspect=\"0.5625\"></script>\n                  </div>\n                </section>\n                <section class=\"rs-section-layout rs-img-grid-layout\">\n                  <h3 class=\"rs-heading rs-heading--level-3 rs-img-grid-layout__title\">ランスタッドEVP自転車ギフトの想い</h3>\n                  <figure class=\"rs-img-grid-layout__img\"><img src=\"\t/recruit/img_f/evp_bicycle.png\" alt=\"\" width=\"800\" height=\"450\" loading=\"lazy\"></figure>\n                  <p class=\"rs-img-grid-layout__text\">EVPのローンチを記念して、ランスタッドから全世界の社員へ、ランスタッド創業のシンボルである特別な自転車が届けられました。<br>この自転車は、私たちがEVP（従業員価値提案）を通じて、社員一人ひとりの成長と活躍を支援していくというコミットメントを象徴するものです。</p>\n                </section>\n                <section class=\"rs-section-layout rs-img-grid-layout rs-img-grid-layout--reverse\">\n                  <h3 class=\"rs-heading rs-heading--level-3 rs-img-grid-layout__title\">ランスタッドEVPカードゲーム</h3>\n                  <figure class=\"rs-img-grid-layout__img\"><img src=\"\t/recruit/img_f/evp_card-game.png\" alt=\"\" width=\"800\" height=\"450\" loading=\"lazy\"></figure>\n                  <p class=\"rs-img-grid-layout__text\">ランスタッド・ジャパンでは、社員エンゲージメントを高める新しい取り組みとして、独自のEVPカードゲームを開発しました。<br>このゲームを通じて、私たちのEVP（従業員価値提案）について楽しく学ぶことができます。日・英二ヶ国表記で、在宅勤務の社員もオンラインで参加することができるインクルーシブなカードゲームです。</p>\n                </section>\n              </div>\n            </main>\n          </div>\n        </div>\n        <div>\n<div class=\"rs-section-layout rs-strip rs-strip--beige rs-position-relative\">\n  <div class=\"rs-base-layout\">\n    <div class=\"rs-information-menu\">\n      <div class=\"rs-information-menu__sns\">\n        <p class=\"rs-text-bold\">SNS公式アカウント</p>\n        <ul class=\"rs-information-menu-sns-list\">\n          <li><a class=\"rs-information-menu-sns-link\" href=\"https://www.facebook.com/RandstadJapan\" target=\"_blank\"><span class=\"rs-information-menu-sns-link__icon\">\n                <svg class=\"rs-filter\">\n                  <use xlink:href=\"/dist/assets/image/icons.svg#facebook-filled-30\"></use>\n                </svg></span></a></li>\n          <li><a class=\"rs-information-menu-sns-link\" href=\"https://twitter.com/randstadjapan\" target=\"_blank\"><span class=\"rs-information-menu-sns-link__icon\">\n                <svg class=\"rs-filter\">\n                  <use xlink:href=\"/dist/assets/image/icons.svg#twitter-filled-30\"></use>\n                </svg></span></a></li>\n          <li><a class=\"rs-information-menu-sns-link\" href=\"http://www.linkedin.com/company/randstad-japan\" target=\"_blank\"><span class=\"rs-information-menu-sns-link__icon\">\n                <svg class=\"rs-filter\">\n                  <use xlink:href=\"/dist/assets/image/icons.svg#linkedin-filled-30\"></use>\n                </svg></span></a></li>\n          <li><a class=\"rs-information-menu-sns-link\" href=\"https://www.youtube.com/user/RandstadJapan\" target=\"_blank\"><span class=\"rs-information-menu-sns-link__icon\">\n                <svg class=\"rs-filter\">\n                  <use xlink:href=\"/dist/assets/image/icons.svg#youtube-filled-30\"></use>\n                </svg></span></a></li>\n          <li><a class=\"rs-information-menu-sns-link\" href=\"https://www.instagram.com/randstad_japan/\" target=\"_blank\"><span class=\"rs-informa