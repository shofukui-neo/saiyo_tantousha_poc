>\n          <div class=\"rs-recruit-information-category\"><a class=\"rs-recruit-information-link rs-recruit-information-link--main\" href=\"/recruit/challenged/\">障がい者採用</a>\n          </div>\n          <div class=\"rs-recruit-information-category\"><a class=\"rs-recruit-information-link rs-recruit-information-link--main\" href=\"/recruit/alumni/\">アルムナイ採用・登録</a>\n          </div>\n          <div class=\"rs-recruit-information-category\"><a class=\"rs-recruit-information-link rs-recruit-information-link--main\" href=\"/recruit/faq/\">よくあるご質問・お問い合わせ</a>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div><a class=\"rs-page-top-button\" href=\"#top\"><i class=\"rs-icon rs-icon--caret-up rs-page-top-button__icon\"></i></a>\n</div>\n<footer class=\"cf footer-main\">\n          <div class=\"box-inner\">\n            <div id=\"FooterDiv\" class=\"grid-wrap\">\n              <div class=\"footer-main-col\">\n                <div class=\"footer-main-col-inner\">\n                  <dl class=\"footer-link-list\">\n                    <dt class=\"footer-list-header footer-list-header-toggle has-bg-img-after footer-list-header-large\"><a href=\"/\">お仕事をお探しの方</a></dt>\n                    <dd class=\"footer-link-list-sub\">\n                      <ul class=\"list-clean\">\n                        <li><a href=\"/find-jobs/registration/\">ランスタッドに登録</a></li>\n                      </ul>\n                    </dd>\n                  </dl>\n                  <dl class=\"footer-link-list\">\n                    <dt class=\"footer-list-header footer-list-header-toggle has-bg-img-after\">派遣・紹介予定派遣</dt>\n                    <dd class=\"footer-link-list-sub\">\n                      <ul class=\"list-clean\">\n                        <li><a href=\"/office/\" class=\"sEGG_recCB\" data-cat-id=\"office\">事務派遣・正社員</a></li>\n                        <li><a href=\"/factory/\" class=\"sEGG_recCB\" data-cat-id=\"factory\">製造・軽作業・ドライバー</a></li>\n                        <li><a href