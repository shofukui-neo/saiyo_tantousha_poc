3A%2F%2Fwww.leadkonan.co.jp%2F\" />\n<link rel=\"alternate\" title=\"oEmbed (XML)\" type=\"text/xml+oembed\" href=\"https://www.leadkonan.co.jp/wp-json/oembed/1.0/embed?url=https%3A%2F%2Fwww.leadkonan.co.jp%2F&#038;format=xml\" />\n<style>.removed_link, a.removed_link {\r\n\ttext-decoration: line-through;\r\n}</style>\r\n</head>\r\n<body>\r\n<div class=\"all\">\r\n<header>\r\n\t<div class=\"headerinner\">\r\n\t\t\t<h1 class=\"header-logo\"><img src=\"https://www.leadkonan.co.jp/manage/wp-content/themes/leadkonan/img/titlelogo.png\" alt=\"株式会社リードコナン\"></h1>\r\n\t\t\t<div class=\"right\">\r\n\t\t\t<script async src=\"https://cse.google.com/cse.js?cx=956ae349a51cb452c\"></script>\r\n\t\t\t<div class=\"gcse-searchbox-only\"></div>\r\n\t\t\t<div class=\"fontsize\">\r\n\t\t\t\t<p>文字の大きさ</p>\r\n\t\t\t\t<ul>\r\n\t\t\t\t\t<li class=\"middle\">標準</li>\r\n\t\t\t\t\t<li class=\"large\">大</li>\r\n\t\t\t\t</ul>\r\n\t\t\t</div>\r\n\t\t</div>\r\n\t</div>\r\n\t<a href=\"#\" class=\"panelbtn\"><span class=\"panelbtn_icon\"></span></a>\r\n\t<nav class=\"glnaviwrap\">\r\n\t\t<ul class=\"glnavi\">\r\n\t\t\t<li class=\"menu_firstlevel\"><a href=\"https://www.leadkonan.co.jp\">HOME</a>\r\n\t\t\t<li class=\"menu_firstlevel\"><a class=\"menu_firstlevel_btn\">サービス&nbsp;▼</a>\r\n\t\t\t<ul class=\"menu_secondlevel\">\r\n\t\t\t\t<li class=\"nav_s1\"><a href=\"https://www.leadkonan.co.jp/service/software/\">ソフトウェア・開発</a></li>\r\n\t\t\t\t<li class=\"nav_s2\"><a href=\"https://www.leadkonan.co.jp/service/office/\">オフィスITソリューション</a></li>\r\n\t\t\t\t<li class=\"nav_s3\"><a href=\"https://www.leadkonan.co.jp/service/creation/\">Webサイト･コンテンツ作成</a></li>\r\n\t\t\t\t<li class=\"nav_s4\"><a href=\"https://www.leadkonan.co.jp/service/support/\">パソコン修理、廃棄、データ復旧</a></li>\r\n\t\t\t</ul>\r\n\t\t\t</li>\r\n\t\t\t<li class=\"menu_firstlevel\"><a class=\"menu_firstlevel_btn\">会社案内&nbsp;▼</a>\r\n\t\t\t<ul class=\"menu_secondlevel\">\r\n\t\t\t\t<li class=\"nav_b1\"><a href=\"https://www.leadkonan.co.jp/company/gree