od=\"get\">\r\n                <input type=\"text\" name=\"q\" size=\"10\" id=\"searchfield\" title=\"searchfield\" onfocus=\"clearText(this)\" onblur=\"clearText(this)\" />\r\n                <input type=\"submit\" name=\"Search\" value=\"\" alt=\"Search\" id=\"searchbutton\" title=\"Search\" />\r\n                <INPUT type=hidden name=\"as_sitesearch\" value=\"kasutani.com\"> \r\n            </form>\r\n       </div>\r\n       \r\n\t</div> <!-- end of templatemo_site_title_bar -->        \r\n       \r\n</div> <!-- end of templatemo_site_title_bar_wrapper -->\r\n<!-- end of templatemo_banner_wrapper -->\r\n\r\n<div id=\"templatemo_menu_wrapper\">\r\n\r\n    <div id=\"templatemo_menu\">\r\n    \r\n\t    <ul>\r\n            <li><a href=\"../index.html\">HOME</a></li>\r\n          <li><a href=\"../information/information.html\">ごあいさつ</a></li>\r\n            <li><a href=\"../company_guidance/company_guidance.html\">企業案内</a></li>\r\n            <li><a href=\"../fishery_relation/fishery_relations.html\">製品のご案内</a></li>\r\n\t    <li><a href=\"../quality_control/quality_control.html\">品質管理</a></li>\r\n\t    <li><a href=\"recruit_guidelines.html\">求人情報</a></li>            \r\n            <li><a href=\"../form/form.html\">お問い合わせ</a></li>\r\n        </ul>\r\n    \r\n    </div> \r\n    <!-- end of templatemo_menu --></div> <!-- end of templatemo_menu_wrapper -->\r\n<!-- InstanceBeginEditable name=\"main\" -->\r\n<div id=\"templatemo_content_wrapper\">\r\n  <div id=\"templatemo_content\">\r\n    <div class=\"cleaner_h30\">\r\n      <div align=\"center\"><img src=\"../total_image/kikko.jpg\" alt=\"Creating the Future\" width=\"939\" height=\"50\" /></div>\r\n    </div>\r\n    <div align=\"center\">\r\n      <p><img src=\"../images/bar_recruit.jpg\" alt=\"会社概要\" width=\"938\" height=\"50\" /></p>\r\n    </div>\r\n    <div class=\"section_w960_p30\">\r\n      <h2 style=\"margin-bottom:1em;display: inline-block;margin-right: 20px;\">募集要項</h2>\r\n      <table width=\"80%\">\r\n        <tr>\r\n          <td width=\"120\" class=\"em_text light_bg\">応募資格</td>\r\n          <td class=\"em_text\">令和7年3月末に大学を卒業（修了）見込みの方</td>\r\n        </tr>\r\n        <tr>\r\n          <td class=\"em_text light_bg\">募集職種</td>\r\n          <td class=\"em_text\">技術系 ： 海上施設設計および海洋調査技術など</td>\r\n        </tr>\r\n        <tr>\r\n          <td class=\"em_text light_bg\">採用予定数</td>\r\n          <td class=\"em_text\">若干名</td>\r\n        </tr>\r\n        <tr>\r\n          <td class=\"em_text light_bg\">初任給</td>\r\n          <td class=\"em_text\">令和7年4月入社：220,000円(予定)</td>\r\n        </tr>\r\n        <tr>\r\n          <td class=\"em_text light_bg\">昇給</td>\r\n          <td class=\"em_text\">年1回</td>\r\n        </tr>\r\n        <tr>\r\n          <td class=\"em_text light_bg\">賞与</td>\r\n          <td class=\"em_text\">年2回（8月、12月）</td>\r\n        </tr>\r\n        <tr>\r\n          <td class=\"em_text light_bg\">諸手当</td>\r\n          <td class=\"em_text\">決算手当、通勤手当、家族手当など</td>\r\n        </tr>\r\n        <tr>\r\n          <td class=\"em_text light_bg\">勤務地</td>\r\n          <td class=\"em_text\">本社、各営業所</td>\r\n        </tr>\r\n        <tr>\r\n          <td class=\"em_text light_bg\">勤務時間</td>\r\n          <td class=\"em_text\">8：15　～　17：15</td>\r\n        </tr>\r\n        <tr>\r\n          <td class=\"em_text light_bg\">休日・休暇</td>\r\n          <td class=\"em_text\">土曜、日曜、祝日、夏季、年末年始</td>\r\n        </tr>\r\n        <tr>\r\n          <td class=\"em_text light_bg\">社会保険</td>\r\n          <td class=\"em_text\">雇用保険、労災保険、健康保険、厚生年金保険</td>\r\n        </tr>\r\n        <tr>\r\n          <td class=\"em_text light_bg\">福利厚生</td>\r\n          <td class=\"em_text\">退職金制度（勤続3年以上）、育児介護休業制度、資格取得報奨金制度</td>\r\n        </tr>\r\n      </table>\r\n      <p>　</p>\r\n      <table width=\"80%\">\r\n        <tr>\r\n          <td class=\"em_text light_bg\" width=\"120\">応募資格</td>\r\n          <td class=\"em_text\">令和7年3月末に高等学校を卒業（修了）見込みの方</td>\r\n        </tr>\r\n        <tr>\r\n          <td class=\"em_text light_bg\">募集職種</td>\r\n          <td class=\"em_text\">製造職　：　漁網・漁具製造、現場設置作業、土木資材製造　</td>\r\n        </tr>\r\n        <tr>\r\n          <td class=\"em_text light_bg\">採用予定数</td>\r\n          <td class=\"em_text\">若干名</td>\r\n        </tr>\r\n        <tr>\r\n          <td class=\"em_text light_bg\">初任給</td>\r\n          <td class=\"em_text\">令和7年4月入社：180,000円(予定)</td>\r\n        </tr>\r\n        <tr>\r\n          <td class=\"em_text light_bg\">昇給</td>\r\n          <td class=\"em_text\">年1回</td>\r\n        </tr>\r\n        <tr>\r\n          <td class=\"em_text light_bg\">賞与</td>\r\n          <td class=\"em_text\">年2回（8月、12月）</td>\r\n        </tr>\r\n        <tr>\r\n          <td class=\"em_text light_bg\">諸手当</td>\r\n          <td class=\"em_text\">決算手当、通勤手当、家族手当など</td>\r\n        </tr>\r\n        <tr>\r\n          <td class=\"em_text light_bg\">勤務地</td>\r\n          <td class=\"em_text\">本社</td>\r\n        </tr>\r\n        <tr>\r\n          <td class=\"em_text light_bg\">勤務時間</td>\r\n          <td class=\"em_text\">8：15　～　17：15</td>\r\n        </tr>\r\n        <tr>\r\n          <td class=\"em_text light_bg\">休日・休暇</td>\r\n          <td class=\"em_text\">土曜、日曜、祝日、夏季、年末年始</td>\r\n        </tr>\r\n        <tr>\r\n          <td class=\"em_text light_bg\">社会保険</td>\r\n          <td class=\"em_text\">雇用保険、労災保険、健康保険、厚生年金保険</td>\r\n        </tr>\r\n        <tr>\r\n          <td class=\"em_text light_bg\">福利厚生</td>\r\n          <td class=\"em_text\">退職金制度（勤続3年以上）、育児介護休業制度、資格取得報奨金制度</td>\r\n        </tr>\r\n      </table>\r\n      \r\n      <p class=\"em_text\" style=\"margin-top:2em;\"><a href=\"EntrySheet.pdf\">■ エントリーシート</a></p>\r\n      <p class=\"em_text\" style=\"margin-top:2em;\">■ 採用に関するお問い合わせ<br />\r\n      </p>\r\n      <p class=\"em_text\">〒854-0037<br />\r\n        長崎県諫早市川内町485番地<br>\r\n        粕谷製網株式会社　総務部<br />\r\n        TEL：0957-22-0373</p>\r\n    <div class=\"cleaner_h20\"></div>\r\n    <div class=\"cleaner\"></div>\r\n  </div>\r\n  <div class=\"cleaner