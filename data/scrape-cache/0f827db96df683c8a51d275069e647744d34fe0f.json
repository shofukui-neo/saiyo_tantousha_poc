{"url":"https://www.tis-web.co.jp/recruit/bs_fa.html","html":"<!DOCTYPE html>\n<html lang=\"ja\" prefix=\"og: http://ogp.me/ns#\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta content=\"IE=edge\" http-equiv=\"X-UA-Compatible\">\n    <meta content=\"initial-scale=1,width=device-width\" name=\"viewport\">\n    <title>株式会社ティ・アイ・エス新卒採用</title>\n    <link href=\"#\" rel=\"canonical\">\n    <meta content=\"株式会社ティ・アイ・エスの採用特設サイトです。福岡・佐賀を拠点に産業機械製作のFA事業、太陽光発電システム販売・メンテナンスの太陽光事業、機器の導入支援・メンテナンスのサービス事業を行っている企業です。\" name=\"description\">\n    <meta content=\"ja_JP\" property=\"og:locale\">\n    <meta content=\"株式会社ティ・アイ・エス新卒採用\" property=\"og:site_name\">\n    <meta content=\"株式会社ティ・アイ・エス新卒採用\" property=\"og:title\">\n    <meta content=\"website\" property=\"og:type\">\n    <meta content=\"#\" property=\"og:url\">\n    <meta content=\"assets/images/ogimage.jpg\" property=\"og:image\">\n    <meta content=\"株式会社ティ・アイ・エスの採用特設サイトです。福岡・佐賀を拠点に産業機械製作のFA事業、太陽光発電システム販売・メンテナンスの太陽光事業、機器の導入支援・メンテナンスのサービス事業を行っている企業です。\" property=\"og:description\">\n    <meta content=\"summary_large_image\" name=\"twitter:card\">\n    <meta content=\"株式会社ティ・アイ・エス新卒採用\" name=\"twitter:title\">\n    <meta content=\"株式会社ティ・アイ・エスの採用特設サイトです。福岡・佐賀を拠点に産業機械製作のFA事業、太陽光発電システム販売・メンテナンスの太陽光事業、機器の導入支援・メンテナンスのサービス事業を行っている企業です。\" name=\"twitter:description\">\n    <meta content=\"assets/images/ogimage.jpg\" name=\"twitter:image\">\n    <link href=\"assets/css/style.css\" rel=\"stylesheet\">\n    <script src=\"https://ajax.googleapis.com/ajax/libs/jquery/2.2.4/jquery.min.js\"></script>\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n    <link href=\"https://fonts.googleapis.com/css2?family=Azeret+Mono:wght@700&family=Rubik+Mono+One&display=swap\" rel=\"stylesheet\">\n    <link rel=\"apple-touch-icon\" sizes=\"180x180\" href=\"assets/images/icon/apple-touch-icon.png\">\n    <link rel=\"icon\" type=\"image/png\" sizes=\"32x32\" href=\"assets/images/icon/favicon-32x32.png\">\n    <link rel=\"icon\" type=\"image/png\" sizes=\"16x16\" href=\"assets/images/icon/favicon-16x16.png\">\n    <link rel=\"manifest\" href=\"assets/images/icon/site.webmanifest.txt\">\n    <link rel=\"mask-icon\" href=\"assets/images/icon/safari-pinned-tab.svg\" color=\"#615ea8\">\n    <meta name=\"msapplication-TileColor\" content=\"#615ea8\">\n    <meta name=\"theme-color\" content=\"#ffffff\">\n</head>\n<body id=\"top\">\n\n<div class=\"bs_fa page-bs\">\n\n  <header class=\"header add-scrolled add-reverse\" id=\"header\">\n    <div class=\"header-inner\">\n\n        <div class=\"header-ttl\">\n            <a class=\"header-ttlLink\" href=\"index.html\"><img src=\"assets/images/tis_logo.png\"><span>Recruit Site</span></a>\n        </div>\n\n        <nav class=\"header-nav\">\n            <button class=\"header-closeButton\" id=\"js-header_closeBtn\" type=\"button\">\n                <span></span>\n                <span></span>\n            </button>\n            <ul class=\"header-list\">\n                <li class=\"header-item\">\n                    <div class=\"header-item_ttl\"><a class=\"header-itemLink-top js-unlink\" href=\"index.html#mission\">ビジョン</a></div>\n                </li>\n                <li class=\"header-item\">\n                    <div class=\"header-item_ttl\"><a class=\"header-itemLink-top js-unlink\" href=\"index.html#message\">メッセージ</a></div>\n                </li>\n                <li class=\"header-item\">\n                    <div class=\"header-item_ttl\"><a class=\"header-itemLink-top js-unlink\" href=\"index.html#business\">事業内容</a></div>\n                </li>\n                <li class=\"header-item\">\n                    <div class=\"header-item_ttl\"><a class=\"header-itemLink-top js-unlink\" href=\"index.html#interview\">社員インタビュー</a></div>\n                </li>\n                <li class=\"header-item\">\n                    <div class=\"header-item_ttl\"><a class=\"header-itemLink-top js-unlink\" href=\"index.html#culture\">TISの文化</a></div>\n                </li>\n                <li class=\"header-item\">\n                    <div class=\"header-item_ttl\"><a class=\"header-itemLink-top js-unlink\" href=\"index.html#company\">会社概要</a></div>\n                </li>\n                <li class=\"header-item\">\n                    <div class=\"header-item_ttl\"><a class=\"header-itemLink-top js-unlink\" href=\"recruit.html\">採用情報</a></div>\n                </li>\n                <li class=\"header-btnarea\">\n                    <a class=\"header-entry\" href=\"entry.html\" ><img src=\"assets/images/entry.svg\" alt=\"\"><tspan>エントリー</tspan>\n                    </a>\n                </li>\n            </ul>\n        </nav>\n    </div>\n    <button class=\"header-navButton\" id=\"js-header_toggleBtn\" type=\"button\">\n        <span class=\"header-toggleBtn\">\n            <span></span>\n            <span></span>\n            <span></span>\n        </span>\n        <span class=\"header-toggleBtn-txt\">メニュー</span>\n    </button>\n    <a class=\"header-entryButton\" href=\"entry.html\" >\n        <img src=\"assets/images/entry.svg\"><tspan>エントリー</tspan></a>\n    <div class=\"header-bg js-headerBg\" id=\"js-headerBg\"></div>\n  </header>\t\n  <main class=\"project-container mod-crosstalk\">\n        <div class=\"project-boxKv js-kvImage\">\n          <div class=\"project-boxKvInner\">\n            <h1 class=\"project-boxKvTtl js-inView rise add-inView\">\n              <span class=\"project-boxKvTtl-tag\">Factory Automation</span>\n              <span class=\"project-boxKvTtl-ttl\">FA事業部</span>\n            </h1>\n          </div>\n        </div>\n        <section class=\"project\">\n          <div class=\"project-index-wrap js-inView rise add-inView\">\n            <div class=\"project-index-wrap__inner\">\n              <p class=\"project-flow-case\">仕事の内容 </p>\n              <p class=\"team-feature__desc\">FA事業部では取引先からの依頼を受け、自動化装置の設計・製造を行っています。</p>\n              <p class=\"team-feature__desc\">依頼内容は商品の搬送や箱詰め、外観検査など様々あり、<br class=\"sp-hidden\">多種多様な業界から依頼が寄せられています。</p>\n              <p class=\"team-feature__desc\">数多くの依頼を受け培った技術力で自信をもって装置の提案・設計を行っており、<br class=\"sp-hidden\">提案～設計～製造～納品～アフターフォローまで一貫して行っているため<br class=\"sp-hidden\">取引先の要望に迅速に対応しています。</p>\n              <p class=\"team-feature__desc\">また、FA事業部では取引先の依頼による装置だけでなく「煎自動マイスター」という<br class=\"sp-hidden\">漢方薬の自動生薬煎じ包装機を開発しており、メーカーとしての役割も担っています。</p>\n              <p class=\"team-feature__desc mb60\">数多くの薬局で利用をしていただいており、<br class=\"sp-hidden\">患者様にとって有益となる煎じパックの普及に貢献しています。</p>\n              <p class=\"project-flow-case\">仕事の流れ </p>\n              <ul class=\"project-flow-wrapper clearfix\">\n                <li class=\"project-flow-wrapper__item\">\n                  <span class=\"project-flow-wrapper__item__time project-flow-wrapper__item__time--blue\">受注活動</span>\n                  <h3 class=\"project-flow-wrapper__item__title\"> 営業 </h3>\n                  <p class=\"project-flow-wrapper__item__text\"> 展示会への出展・企業からの紹介・新規取引先開拓・既存取引先企業の継続引合い等から新たな案件を受注するための活動を行います。積極的に多くの企業との関係性を築きながら進めていきます。 </p>\n                </li>\n                <li class=\"project-flow-wrapper__item project-flow-wrapper__item--mt01\"> <span class=\"project-flow-wrapper__item__time\">訪問</span>\n                  <h3 class=\"project-flow-wrapper__item__title\"> 営業 </h3>\n                  <p class=\"project-flow-wrapper__item__text\"> お客様のお困りごとをヒアリング。しっかりと耳を傾けて、お客様が本当に求めているものは何か、お客様が抱えている課題や問題は何か、を考えていきます。</p>\n                </li>\n                <li class=\"project-flow-wrapper__item\"> <span class=\"project-flow-wrapper__item__time\">情報共有</span>\n                  <h3 class=\"project-flow-wrapper__item__title\"> 社内ミーティング </h3>\n                  <p class=\"project-flow-wrapper__item__text\"> 社内で設計担当と情報共有（打ち合わせ）を行い、課題等を解決するための意見を出し合います。ミーティングのたびに新たな気付きがあり、知識の幅が広がる場にもなっています。</p>\n                </li>\n                <li class=\"project-flow-wrapper__item project-flow-wrapper__item--mt02\"> <span class=\"project-flow-wrapper__item__time\">構想設計</span>\n                  <h3 class=\"project-flow-wrapper__item__title\"> 設計 </h3>\n                  <p class=\"project-flow-wrapper__item__text\"> システムの全体像を考えながら、必要な機能・性能をイメージし、お客様に提案する資料を作り上げていきます。</p>\n                </li>\n                <li class=\"project-flow-wrapper__item\"> <span class=\"project-flow-wrapper__item__time\">お客様へ提案</span>\n                  <h3 class=\"project-flow-wrapper__item__title\"> 営業 </h3>\n                  <p class=\"project-flow-wrapper__item__text\"> 私たちの提案が、お客様が抱えている課題や問題をどう解決するのか、予算なども見極めながら、両者の考えをすり合わせていきます。 </p>\n                </li>\n                <li class=\"project-flow-wrapper__item project-flow-wrapper__item--mt02\"> <span class=\"project-flow-wrapper__item__time\">受注</span>\n                  <h3 class=\"project-flow-wrapper__item__title\"> 営業 </h3>\n                  <p class=\"project-flow-wrapper__item__text\"> お客様とのすり合わせが滞りなく完了すると受注となり、開発段階へ移ります。導入前も、導入後もお客様へのサポートやコミュニケーションは必須です。</p>\n                </li>\n                <li class=\"project-flow-wrapper__item\"> <span class=\"project-flow-wrapper__item__time project-flow-wrapper__item__time\">詳細設計</span>\n                  <h3 class=\"project-flow-wrapper__item__title\"> 詳細設計 </h3>\n                  <p class=\"project-flow-wrapper__item__text\"> 打ち合わせに基づいて、詳細設計、部品図・部品リストの作成を行います。</p>\n                </li>\n                <li class=\"project-flow-wrapper__item\"> <span class=\"project-flow-wrapper__item__time project-flow-wrapper__item__time\">部品調達</span>\n                  <h3 class=\"project-flow-wrapper__item__title\"> 部品調達 </h3>\n                  <p class=\"project-flow-wrapper__item__text\"> 詳細設計に基づいて、部品の手配および製造担当へ受け渡しを行います。</p>\n                </li>\n                <li class=\"project-flow-wrapper__item\"> <span class=\"project-flow-wrapper__item__time project-flow-wrapper__item__time\">組み立て</span>\n                  <h3 class=\"project-flow-wrapper__item__title\"> 製造 </h3>\n                  <p class=\"project-flow-wrapper__item__text\"> 組立図に基づいて、装置を1から組み立てていきます。図面通りに形ができてくる、緊張と興奮の日々です。</p>\n                </li>\n                <li class=\"project-flow-wrapper__item\"> <span class=\"project-flow-wrapper__item__time project-flow-wrapper__item__time\">動作確認</span>\n                  <h3 class=\"project-flow-wrapper__item__title\"> 確認と調整 </h3>\n                  <p class=\"project-flow-wrapper__item__text\"> 実際に機械を動かしながら出来上がり動作の確認。またお客様の検査実施も行います。調整が必要な場合は、調整も行います。</p>\n                </li>\n                <li class=\"project-flow-wrapper__item\"> <span class=\"project-flow-wrapper__item__time project-flow-wrapper__item__time\">納品・据付</span>\n                  <h3 class=\"project-flow-wrapper__item__title\"> 立ち会い </h3>\n                  <p class=\"project-flow-wrapper__item__text\"> お客様の工場で、再度組み立てます。営業、設計、製造のみんなで力を合わせて仕上げます。そして再度製品を動かし、お客様の確認を得ます。</p>\n                </li>\n                <li class=\"project-flow-wrapper__item\"> <span class=\"project-flow-wrapper__item__time project-flow-wrapper__item__time--blue\">納品後</span>\n                  <h3 class=\"project-flow-wrapper__item__title\"> アフターフォロー </h3>\n                  <p class=\"project-flow-wrapper__item__text\"> 製品やサービスを提供したあとも、不具合やトラブルがあれば迅速に対応していきます。アフターフォローをいかに迅速に丁寧にできるかで、お客様との今後の信頼関係も変化していきます。</p>\n                </li>\n              </ul>\n            </div>\n          </div>\n        </section>\n      \n    <section class=\"entryBtn\">\n      <div class=\"personal-carousel-boxBtn\">\n      <a class=\"common-btn\" href=\"recruit.html\"><span>採用情報を見る</span></a>\n      </div>    \n    </section>\n  </main>\n</div>\n<footer class=\"footer\" id=\"js-footer\">\n  <div class=\"pagetop\">\n      <a href=\"#top\"><span><small>PAGE TOP</small></span></a>\n  </div>\n<div class=\"footer-inner\">\n  <ul class=\"footer-list\">\n    <li class=\"footer-item\">\n      <dl class=\"footer-boxList\">\n        <dt class=\"footer-boxItem_ttl\"><a class=\"footer-itemLink\" href=\"index.html#mission\">ビジョン</a></dt>\n      </dl>\n    </li>\n    <li class=\"footer-item\">\n      <dl class=\"footer-boxList\">\n        <dt class=\"footer-boxItem_ttl\"><a class=\"footer-itemLink\" href=\"index.html#message\">メッセージ</a></dt>\n      </dl>\n    </li>\n    <li class=\"footer-item\">\n      <dl class=\"footer-boxList\">\n        <dt class=\"footer-boxItem_ttl\"><a class=\"footer-itemLink\" href=\"index.html#business\">事業内容</a>\n        </dt>\n        <dd class=\"footer-boxItem\">\n          <a class=\"footer-boxItemLink\" href=\"bs_fa.html\">FA事業の仕事</a>\n        </dd>\n        <dd class=\"footer-boxItem\">\n          <a class=\"footer-boxItemLink\" href=\"bs_ser.html\">サービス事業の仕事</a>\n        </dd>\n        <dd class=\"footer-boxItem\">\n          <a class=\"footer-boxItemLink\" href=\"bs_eco.html\">エコシステム事業の仕事</a>\n        </dd>\n      </dl>\n    </li>\n    <li class=\"footer-item\">\n      <dl class=\"footer-boxList\">\n        <dt class=\"footer-boxItem_ttl\"><a class=\"footer-itemLink\" href=\"index.html#interview\">社員インタビュー</a></dt>\n        <dd class=\"footer-boxItem\">\n          <a class=\"footer-boxItemLink\" href=\"crosstalk.html\">若手クロストーク</a>\n        </dd>\n      </dl>\n    </li>\n    <li class=\"footer-item\">\n      <dl class=\"footer-boxList\">\n        <dt class=\"footer-boxItem_ttl\"><a class=\"footer-itemLink\" href=\"index.html#culture\">TISの文化</a></dt>\n      </dl>\n    </li>\n    <li class=\"footer-item\">\n      <dl class=\"footer-boxList\">\n        <dt class=\"footer-boxItem_ttl\"><a class=\"footer-itemLink\" href=\"index.html#company\">会社概要</a></dt>\n      </dl>\n    </li>\n          <li class=\"footer-item\">\n      <div class=\"footer-boxList\">\n        <div class=\"footer-boxItem_ttl\"><a class=\"footer-itemLink\" href=\"recruit.html\">採用情報</a></div>\n      </div>\n      <div class=\"footer-boxList\">\n        <div class=\"footer-boxItem_ttl\"><a class=\"footer-itemLink\" href=\"https://www.tis-web.co.jp/\" target=\"_blank\">コーポレートサイト</a></div>\n      </div>\n    </li>\n  </ul>\n  <div class=\"footer_logo\">\n    <a class=\"footer_logoLink\" href=\"https://www.tis-web.co.jp/\" target=\"_blank\">\n      <img alt=\"株式会社ティ・アイ・エス\" src=\"assets/images/tis_logo.png\" class=\"footer_logoImg\">\n    </a>\n  </div>\n  <p class=\"footer_copyright\">Copyright © Technical Information Service Co.,LTD</p>\n</div>\n</footer>\n<script src=\"assets/js/common.js\"></script>\n</body>\n</html>","finalUrl":"https://www.tis-web.co.jp/recruit/bs_fa.html","rendered":false,"_cachedAt":"2026-06-22T18:55:59.649Z"}