ss/style.css?24\" media=\"print\">\n<link rel=\"stylesheet\" href=\"/asset/css/style_add.css\" media=\"print\">\n<link rel=\"stylesheet\" type=\"text/css\" media=\"print\" href=\"/asset/css/print2.css\">\n<link rel=\"canonical\" href=\"https://www.eneos-globe.co.jp/news/2026/05/post-307.html\"> \n<script src=\"/asset/js/jquery.min.js\"></script>\n  <script src=\"/asset/js/main.js?24\" defer></script>\n  <script src=\"/asset/js/main_add.js?24\" defer></script>\n  <script>\n  \n  \n  \n  </script>\n<style>\n.youtube iframe + p, .youtube iframe + p + button{display: none;}</style>\n</head>\n \n<body>\n<!-- Google Tag Manager (noscript) -->\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-PDBJ968\"\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n<!-- End Google Tag Manager (noscript) -->\n  <header id=\"header\" class=\"header\"></header>\n  <main>\n    <div class=\"bread\">\n      <div class=\"bread_wrap\">\n        <ul class=\"bread_list\" itemscope itemtype=\"https://schema.org/BreadcrumbList\">\n          <li class=\"bread_list_item\" itemprop=\"itemListElement\" itemscope itemtype=\"https://schema.org/ListItem\">\n            <a href=\"/\" itemprop=\"item\">\n              <span itemprop=\"name\">\n\t            <span class=\"bread_home\">home</span>\n                <svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 18 16.5\">\n                  <path id=\"icon_home\" d=\"M15.75,10v7.5h-4.5V13H6.75v4.5H2.25V10H0L9,1l9,9ZM15,5.57V1.75H12.75V3.32Z\" transform=\"translate(0 -1)\"/>\n                </svg>                \n              </span>\n            </a>\n            <meta itemprop=\"position\" content=\"1\" />\n          </li>\n          <li class=\"bread_list_item\" itemprop=\"itemListElement\" itemscope itemtype=\"https://schema.org/ListItem\">\n            <a href=\"/news\" itemprop=\"item\">\n              <span itemprop=\"name\">\n                プレスリリース\n              </span>\n            </a>\n            <meta itemprop=\"position\" content=\"2\" />\n          </li>\n          <li class=\"bread_list_item is-current\" itemprop=\"itemListElement\" itemscope itemtype=\"https://schema.org/ListItem\">\n            <a href=\"\" itemprop=\"item\">\n              <span itemprop=\"name\">\n                採用ホームページリニューアルについて\n              </span>\n            </a>\n            <meta itemprop=\"position\" content=\"3\" />\n          </li>\n        </ul>\n      </div>\n    </div>\n    <div class=\"news_pageData\">\n      <div class=\"news_pageData_wrap\">\n        <div class=\"date\"><time datetime=\"2026-05-12T15:00:00+09:00\" itemprop=\"datePublished\">2026.5.12</time></div>\n        <div class=\"tag\">プレスリリース</div>\n      </div>\n    </div>\n    <div class=\"title\">\n      <div class=\"title_wrap\">\n        <div class=\"title_element\">\n          <h1>採用ホームページリニューアルについて</h1>\n        </div>\n      </div>\n    </div>\n    <section class=\"section\">\n      <div class=\"section_wrap\">\n        <div class='section_contents numHeading_list'><p class=\"animate fadein-up\">ＥＮＥＯＳグローブ株式会社（本社：東京都千代田区、社長：小西 徹、以下「当社」）は、このたび採用ホームページをリニューアルし、２０２６年４月２０日（月）に公開いたしましたので、お知らせいたします。</p><p class=\"animate fadein-up\"><span style=\"text-decoration: underline;\">■ 採用サイト</span><span><span style=\"text-decoration: underline;\">URL</span><br /><a href=\"https://recruit.eneos-globe.co.jp/\">https://recruit.eneos-globe.co.jp/</a><br /></span></p><p class=\"animate fadein-up\">本リニューアルは、当社へのご入社を検討されている皆さまに、当社の事業内容や当社で働く魅力がより分かりやすく伝わる採用サイトを目指して実施したものです。<br />ホームページの構成およびコンテンツ全般を見直し、当社が大切にしている価値観や働く社員の雰囲気によりスポットを当てた内容へと刷新いたしました。</p><div class='section_contents'><p class=\"image_one is-center animate fadein-up\"><img src=\"https://www.eneos-globe.co.jp/news/3ad9ad4ec0733168ec136fafc503ebc0579a3fa2.png\" alt=\"\" width=\"800\" height=\"374\" class=\"asset asset-image mt-image-center\" style=\"max-width:100%;height:auto;display:block;margin-left:auto;margin-right:auto\"/></p></div><div class='section_box_heading animate fadein-up'><h4 class=\"underLineHeading\">リニューアルの主なポイント</h4></div><p class=\"animate fadein-up\">1）応募者目線で情報を整理し、分かりやすさを向上<br />知りたい情報に迷わずたどり着けるよう、コンテンツの配置や導線を最適化し、企業理解を深めやすいサイト構成へと再構築しました。</p><p class=\"animate fadein-up\">2）若手社員の「座談会」コンテンツを新設<br />入社のきっかけ、若手の裁量、当社で働く魅力、今後の目標など、応募者が知りたい若手社員のリアルな本音を対話形式で届けるコンテンツを追加しました。入社後に当社で働く姿をより具体的にイメージできる内容となっています。</p><p class=\"animate fadein-up\">3）「転勤<span>×</span>各勤務地の魅力」をテーマにしたコンテンツを新設<br />各支店の営業担当が、転勤をきっかけとした「その土地ならではの経験」やそこで知った「その土地のおすすめポイント」を紹介し、その地方で働く面白さや地方での生活のイメージが湧くコンテンツを追加しました。</p><p class=\"animate fadein-up\">4）中途採用の応募者に分かりやすい内容へ<br />中途入社をご検討されている方々への情報を追加し、内容の充実化を図りました。</p><p style=\"text-align: right;\" class=\"animate fadein-up\">以上</p><p style=\"text-align: right;\" class=\"animate fadein-up\">■本件に関するお問い合わせ<br />総務人事部　総務法務グループ<br />TEL 03-5253-9170</p></div>\n        \n        \n        <div class=\"section_return\">\n          <a href=\"/news\">\n            <div class=\"iconLink\">\n              <div class=\"icon return\">\n                <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"15\" height=\"15\" viewBox=\"0 0 15 15\">\n                  <path id=\"icon_return\" d=\"M8.392,1.888H3.75V0L0,3.369,3.75,6.875V5H8.392a3.405,3.405,0,0,1,3.476,3.392,3.482,3.482,0,0,1-3.476,3.483H3.75V15H8.392A6.608,6.608,0,0,0,15,8.392,6.52,6.52,0,0,0,8.392,1.888Z\" fill=\"#fff\"/>\n                </svg>                                     \n              </div>\n              <div class=\"text\">\n                <span class=\"roll_alt\" alt=\"一覧へ戻る\">\n                  <span class=\"roll_text\">一覧へ戻る</span>\n                </span>\n              </div>\n            </div>\n          </a>\n        </div>\n      </div>\n    </section>\n  </main>\n  <footer id=\"footer\" class=\"footer\"></footer>\n  <div id=\"returnTop\" class=\"returnTop\"></div>\n <!-- <div id=\"cookie\" class=\"cookie\"></div>-->\n</body>\n</html>","finalUrl":"https://www.eneos-globe.co.jp/news/2026/05/post-307.html","rendered":false,"_cachedAt":"2026-06-14T19:40:37.297Z"}