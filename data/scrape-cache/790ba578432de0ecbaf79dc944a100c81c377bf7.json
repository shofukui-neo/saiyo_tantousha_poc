t\t\t});\r\n\t\t});\r\n\t</script>\r\n\r\n\r\n\t<!--[if lt IE 9]>\r\n<script src=\"js/html5shiv.js\"></script>\r\n<script src=\"script/respond.min.js\"></script>\r\n<![endif]-->\r\n\t<!--[if lte IE 7]><script src=\"js/lte-ie7.js\"></script><![endif]-->\r\n  <!-- Google Tag Manager -->\r\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\r\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\r\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\r\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\r\n})(window,document,'script','dataLayer','GTM-MKR3PZ');</script>\r\n<!-- End Google Tag Manager -->\r\n\r\n<!-- Google Tag Manager (noscript) -->\r\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-MKR3PZ\"\r\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\r\n<!-- End Google Tag Manager (noscript) -->\r\n\r\n</head>\r\n\r\n<body>\r\n\r\n\r\n\t<header id=\"header\">\r\n\t\t<div class=\"container\">\r\n\t\t\t<div class=\"flexbox flex-end\">\r\n\t\t\t\t<div class=\"h_logo\"><a href=\"https://www.itec.co.jp\"><img src=\"../img/logo.webp\" alt=\"iTEC採用情報サイト\"></a>\r\n\t\t\t\t</div>\r\n\t\t\t\t<div class=\"h_nav\">\r\n\t\t\t\t\t<nav id=\"gNav\">\r\n\t\t\t\t\t\t<ul class=\"flexbox\">\r\n\t\t\t\t\t\t\t<li><a href=\"../new_graduates/index.html\" class=\"yellow_btn\">新卒採用</a></li>\r\n\t\t\t\t\t\t\t<li><a href=\"../mid_career/index.html\" class=\"green_btn\">キャリア採用</a></li>\r\n\t\t\t\t\t\t</ul>\r\n\t\t\t\t\t</nav>\r\n\t\t\t\t</div>\r\n\t\t\t</div>\r\n\t\t</div>\r\n\t</header>\r\n\r\n\t<main id=\"main\" role=\"main\" class=\"new-graduates\">\r\n\t\t<div id=\"ttl\">\r\n\t\t\t<div class=\"inviewfadeInUp animated ttl\">\r\n\t\t\t\t<h1>新卒採用</h1>\r\n\t\t\t</div>\r\n\t\t\t<div class=\"mask\"></div>\r\n\t\t</div>\r\n\r\n\t\t<div class=\"breadArea inner\">\r\n\t\t\t<ul>\r\n\t\t\t\t<li><a href=\"/\">アイテックTOP</a></li>\r\n\t\t\t\t<li><a href=\"/company/recruit/\">採用情報サイト</a></li>\r\n\t\t\t\t<li>新卒採用</li>\r\n\t\t\t</ul>\r\n\t\t</div>\r\n\r\n\t\t<section id=\"int\" class=\"section section-recruit\">\r\n\t\t\t<h2 class=\"inviewfadeInUp animated\">INTERVIEW</h2>\r\n\t\t\t<article id=\"story01\" class=\"box\">\r\n\t\t\t\t<div class=\"person flexbox_pc box inviewfadeInUp animated\">\r\n\t\t\t\t\t<div class=\"span_6_full img\">\r\n\t\t\t\t\t\t<img src=\"../img/sinsotsu-story02_main.webp\" alt=\"社員紹介2 法人営業部 営業職／既存法人担当\" class=\"sp\">\r\n\t\t\t\t\t</div>\r\n\t\t\t\t\t<div class=\"span_6_full txt flexbox align-center\">\r\n\t\t\t\t\t\t<div class=\"txt_inner\">\r\n\t\t\t\t\t\t\t<h5 class=\"story_num\">STORY01</h5>\r\n\t\t\t\t\t\t\t<p class=\"position sbox\">\r\n\t\t\t\t\t\t\t\t法人営業部<br>\r\n\t\t\t\t\t\t\t\t営業職／既存法人担当\r\n\t\t\t\t\t\t\t</p>\r\n\t\t\t\t\t\t\t<p class=\"name sbox\">T.Y</p>\r\n\t\t\t\t\t\t\t<p>2009年入社</p>\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t</div>\r\n\t\t\t\t</div>\r\n\t\t\t\t<div class=\"container int_content\">\r\n\t\t\t\t\t<div class=\"profile flexbox_pc space-between flex_direction_pc no-wrap align-center box\">\r\n\t\t\t\t\t\t<div class=\"img shadow inviewfadeInUp animated\"><img src=\"../img/sinsotsu-ty_pro_01.webp\"\r\n\t\t\t\t\t\t\t\talt=\"社員紹介2 プロフィール写真1\"></div>\r\n\t\t\t\t\t\t<div class=\"txt shadow inviewfadeInUp animated\">\r\n\t\t\t\t\t\t\t<h3>PROFILE</h3>\r\n\t\t\t\t\t\t\t<p>\r\n\t\t\t\t\t\t\t\tアイテックのグループ会社にSEとして新卒入社したが、アイテックに出向転籍、営業支援部に配属となり営業のサポートを担当。その後、法人営業部門に移り、自ら既存顧客を中心とした企画・提案を行っている。現在、子どもを保育園に預けて働いているママさんでもある。\r\n\t\t\t\t\t\t\t</p>\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t</div>\r\n\r\n\t\t\t\t\t<div class=\"int_box flexbox_pc space-between no-wrap align-start box\">\r\n\t\t\t\t\t\t<div class=\"img shadow inviewfadeInUp animated\"><img src=\"../img/sinsotsu-ty_pro_02.webp\"\r\n\t\t\t\t\t\t\t\talt=\"社員紹介2 プロフィール写真2\"></div>\r\n\t\t\t\t\t\t<div class=\"txt shadow inviewfadeInUp animated\">\r\n\t\t\t\t\t\t\t<p>\r\n\t\t\t\t\t\t\t\t私は主に既存取引のある顧客や大手SIerを担当しています。既存顧客の場合は一度行った研修結果を踏まえて、より細かい研修を提案することが可能です。例えば、2年前に行った新人研修の対象者に向けて、今度は階層別研修を開催するなど。そんな中で、クライアントの新人の方が研修を通じて成長していく姿を間近で見ることができるのは、とてもやりがいを感じますね。新人研修で右も左もわからずあたふたしていた方から、「後輩を指導しています」という話を聞いたりした時には、本当にこの仕事をしていて良かったなと思います。\r\n\t\t\t\t\t\t\t</p>\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t</div>\r\n\r\n\t\t\t\t\t<div class=\"int_box flexbox_pc space-between no-wrap align-start flex_direction_pc box\">\r\n\t\t\t\t\t\t<div class=\"img shadow inviewfadeInUp animated\"><img src=\"../img/sinsotsu-ty_pro_03.webp\"\r\n\t\t\t\t\t\t\t\talt=\"社員紹介2 プロフィール写真3\"></div>\r\n\t\t\t\t\t\t<div class=\"txt shadow inviewfadeInUp animated\">\r\n\t\t\t\t\t\t\t<h4>ライフイベントに柔軟に対応してくれる</h4>\r\n\t\t\t\t\t\t\t<p>\r\n\t\t\t\t\t\t\t\t女性である以上、出産・育児というライフイベントを迎えることがあると思いますが、アイテックは働くことと両立できるように最大限考慮してくれます。産休・育休の取得はもちろん、10時から15時がコアタイム（※インタビュー当時は10－15時がコアタイムでした）のフレックスタイム制にプラスして時短勤務が可能。さらに、自宅勤務することもできます。また、上司や先輩たちも積極的に産休・育休を取得しているので、取りにくいということもありません。自分の環境に合わせた働き方ができるのも、この会社の特徴ですね。\r\n\t\t\t\t\t\t\t</p>\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t</div>\r\n\t\t\t\t</div>\r\n\t\t\t</article>\r\n\r\n\r\n\t\t\t<article id=\"story02\">\r\n\t\t\t\t<div class=\"person flexbox_pc box inviewfadeInUp animated\">\r\n\t\t\t\t\t<div class=\"span_6_full img\">\r\n\t\t\t\t\t\t<img src=\"../img/sinsotsu-story03_main.webp\" alt=\"社員紹介3 管理部 総務人事担当\" class=\"sp\">\r\n\t\t\t\t\t</div>\r\n\t\t\t\t\t<div class=\"span_6_full txt flexbox align-center\">\r\n\t\t\t\t\t\t<div class=\"txt_inner\">\r\n\t\t\t\t\t\t\t<h5 class=\"story_num\">STORY02</h5>\r\n\t\t\t\t\t\t\t<p class=\"position sbox\">\r\n\t\t\t\t\t\t\t\t管理部<br>\r\n\t\t\t\t\t\t\t\t総務人事担当\r\n\t\t\t\t\t\t\t</p>\r\n\t\t\t\t\t\t\t<p class=\"name sbox\">N.K</p>\r\n\t\t\t\t\t\t\t<p>2014年入社</p>\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t</div>\r\n\t\t\t\t</div>\r\n\t\t\t\t<div class=\"container int_content\">\r\n\t\t\t\t\t<div class=\"profile flexbox_pc space-between flex_direction_pc no-wrap align-center box\">\r\n\t\t\t\t\t\t<div class=\"img shadow inviewfadeInUp animated\"><img src=\"../img/sinsotsu-nk_pro_01.webp\"\r\n\t\t\t\t\t\t\t\talt=\"社員紹介3 プロフィール写真1\"></div>\r\n\t\t\t\t\t\t<div class=\"txt shadow inviewfadeInUp animated\">\r\n\t\t\t\t\t\t\t<h3>PROFILE</h3>\r\n\t\t\t\t\t\t\t<p>\r\n\t\t\t\t\t\t\t\t前職はコンビニエンスストアの店員としてアルバイト勤務をしていたが、どうしても事務職をやってみたいという思いから転職を決意。右も左もわからないまま入社したが、地道に事務経験を積み上げている。\r\n\t\t\t\t\t\t\t</p>\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t</div>\r\n\r\n\t\t\t\t\t<div class=\"int_box flexbox_pc space-between no-wrap align-start box\">\r\n\t\t\t\t\t\t<div class=\"img shadow inviewfadeInUp animated\"><img src=\"../img/sinsotsu-nk_pro_02.webp\"\r\n\t\t\t\t\t\t\t\talt=\"社員紹介3 プロフィール写真2\"></div>\r\n\t\t\t\t\t\t<div class=\"txt shadow inviewfadeInUp animated\">\r\n\t\t\t\t\t\t\t<p>\r\n\t\t\t\t\t\t\t\tアイテックのバックヤード業務全般に携わっています。請求書・領収書の発行、事務用品の発注から管理、社員の給与計算など労務に関わるものまで、幅広く対応しています。社員が働きやすくなるように、就業環境を整えるのも私の仕事。ルーティン業務以外にも、社員が喜ぶことを企画して実行しています。例えば、福利厚生サービスを増やしたり、残業時間管理のためのツールを作ったり、社内に健康食品が食べられるコーナーを設置したり。新しいことを考えて実行することがとても楽しい仕事です。\r\n\t\t\t\t\t\t\t</p>\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t</div>\r\n\r\n\t\t\t\t\t<div class=\"int_box flexbox_pc space-between no-wrap align-start flex_direction_pc box\">\r\n\t\t\t\t\t\t<div class=\"img shadow inviewfadeInUp animated\"><img src=\"../img/sinsotsu-nk_pro_03.webp\"\r\n\t\t\t\t\t\t\t\talt=\"社員紹介3 プロフィール写真3\"></div>\r\n\t\t\t\t\t\t<div class=\"txt shadow inviewfadeInUp animated\">\r\n\t\t\t\t\t\t\t<h4>「社員は家族」という社風</h4>\r\n\t\t\t\t\t\t\t<p>\r\n\t\t\t\t\t\t\t\t私がアイテックに入社を決めたのは、「社員は家族」という考え方に共感したからです。これは当社の代表がモットーとしているのですが、仕事をしやすい環境をつくることは家族のことを考えて優しく接することと同じだと考えています。『フレックスタイム制度』『時短勤務制度』『時間単位有給』『サテライト（自宅）勤務制度』『リフレッシュ休暇』など、社員のための手厚い制度が当社の特徴です。でも、もっともっと良い会社にしていきたいですね。\r\n\t\t\t\t\t\t\t</p>\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t</div>\r\n\t\t\t\t</div>\r\n\t\t\t</article>\r\n\t\t</section>\r\n\r\n\t\t<section id=\"recruit\">\r\n\t\t\t<div class=\"container\">\r\n\t\t\t\t<h2>RECRUIT<!--<br />\r\n2020年3月卒業見込みの方--></h2>\r\n\t\t\t\t<!-- エントリー受付外の記述　ここから　-->\r\n\t\t\t\t<section id=\"entry\">\r\n\t\t\t\t\t<div class=\"container\">\r\n\t\t\t\t\t\t<table border=\"1\" cellspacing=\"0\" bordercolor=\"#eeeeee\">\r\n\r\n\t\t\t\t\t\t\t<tr>\r\n\t\t\t\t\t\t\t\t<th style=\"text-align:center;\"><span\r\n\t\t\t\t\t\t\t\t\t\tstyle=\"font-weight:bold;font-size:18px;\">今年度の新卒採用は終了しました。次年度の新卒採用については、募集開始次第、本サイト上にてご案内いたします。</span>\r\n\t\t\t\t\t\t\t\t</th>\r\n\t\t\t\t\t\t\t</tr>\r\n\t\t\t\t\t\t</table>\r\n\t\t\t\t\t</div>\r\n\t\t\t\t</section>\r\n\t\t\t\t<!--  エントリー受付外の記述　ここまで　-->\r\n\r\n\t\t\t\t<table>\r\n\t\t\t\t\t<tr>\r\n\t\t\t\t\t\t<th>募集職種</th>\r\n\t\t\t\t\t\t<td>\r\n\t\t\t\t\t\t\t<p class=\"sbox\">営業職・事務職(試用期間：3ヶ月)</p>\r\n\t\t\t\t\t\t\t<ul>\r\n\t\t\t\t\t\t\t\t<li class=\"flexbox space-between\">\r\n\t\t\t\t\t\t\t\t\t<span class=\"job_type_ttl flexbox align-center flex-center\"><span>営業職</span></span>\r\n\t\t\t\t\t\t\t\t\t<span class=\"job_type_txt flexbox align-center\">\r\n\t\t\t\t\t\t\t\t\t\t<span>営業部門（法人・書店・代理店）</span>\r\n\t\t\t\t\t\t\t\t\t</span>\r\n\t\t\t\t\t\t\t\t</li>\r\n\t\t\t\t\t\t\t\t<li class=\"flexbox space-between\">\r\n\t\t\t\t\t\t\t\t\t<span class=\"job_type_ttl flexbox align-center flex-center\">\r\n\t\t\t\t\t\t\t\t\t\t<span>事務職</span>\r\n\t\t\t\t\t\t\t\t\t</span>\r\n\t\t\t\t\t\t\t\t\t<span class=\"job_type_txt flexbox align-center\">\r\n\t\t\t\t\t\t\t\t\t\t<span>※入社後、適正により下記の配属予定部門から決定いたします。<br>\r\n\t\t\t\t\t\t\t\t\t\t\t・セミナー部門（セミナーの企画・提案・運営）<br>\r\n\t\t\t\t\t\t\t\t\t\t\t・コンテンツ制作部門（編集・校正）<br>\r\n\t\t\t\t\t\t\t\t\t\t\t・バックオフィス部門（データ入力・公開模試運営）<br>\r\n\t\t\t\t\t\t\t\t\t\t\t・管理部門（総務・人事・経理）<br>\r\n\t\t\t\t\t\t\t\t\t\t\t・マーケティング部門（商品企画・プロモーション）</span>\r\n\t\t\t\t\t\t\t\t\t</span>\r\n\t\t\t\t\t\t\t\t</li>\r\n\r\n\t\t\t\t\t\t\t</ul>\r\n\t\t\t\t\t\t</td>\r\n\t\t\t\t\t</tr>\r\n\t\t\t\t\t<tr>\r\n\t\t\t\t\t\t<th>勤務地</th>\r\n\t\t\t\t\t\t<td>\r\n\t\t\t\t\t\t\t教育事業本部<br>\r\n\t\t\t\t\t\t\t住所：東京都大田区平和島6-1-1　センタービル8階<br>\r\n\t\t\t\t\t\t\t※転勤は予定しておりません<br><br>\r\n\r\n\t\t\t\t\t\t\tアクセス<br>\r\n\t\t\t\t\t\t\t東京モノレール 「流通センター」駅\r\n\t\t\t\t\t\t</td>\r\n\t\t\t\t\t</tr>\r\n\t\t\t\t\t<tr>\r\n\t\t\t\t\t\t<th>勤務時間</th>\r\n\t\t\t\t\t\t<td>9時00分～17時30分　実働：7時間30分（昼休憩：1時間を含む）<br>※フレックスタイム制　コアタイム11時00分～14時00分</td>\r\n\t\t\t\t\t</tr>\r\n\t\t\t\t\t<tr>\r\n\t\t\t\t\t\t<th>初任給</th>\r\n\t\t\t\t\t\t<td>\r\n\t\t\t\t\t\t\t大学卒・修士了／21万6千円<br><br>\r\n\r\n\t\t\t\t\t\t\t※月30時間分のみなし残業代含む<br>\r\n\t\t\t\t\t\t\t※試用期間中も給与額は同じです\r\n\t\t\t\t\t\t</td>\r\n\t\t\t\t\t</tr>\r\n\t\t\t\t\t<tr>\r\n\t\t\t\t\t\t<th>諸手当</th>\r\n\t\t\t\t\t\t<td>\r\n\t\t\t\t\t\t\t時間外・深夜・休日勤務手当<br>\r\n\t\t\t\t\t\t\t営業手当（営業部門のみ）<br>\r\n\t\t\t\t\t\t\t職務手当<br>\r\n\t\t\t\t\t\t\t管理職手当<br>\r\n\t\t\t\t\t\t\tインセンティブ手当（四半期毎、年4回）\r\n\t\t\t\t\t\t</td>\r\n\t\t\t\t\t</tr>\r\n\t\t\t\t\t<tr>\r\n\t\t\t\t\t\t<th>昇給</th>\r\n\t\t\t\t\t\t<td>年1回</td>\r\n\t\t\t\t\t</tr>\r\n\t\t\t\t\t<tr>\r\n\t\t\t\t\t\t<th>賞与</th>\r\n\t\t\t\t\t\t<td>決算賞与（年1回）</td>\r\n\t\t\t\t\t</tr>\r\n\t\t\t\t\t<tr>\r\n\t\t\t\t\t\t<th>休日・休暇</th>\r\n\t\t\t\t\t\t<td>\r\n\t\t\t\t\t\t\t※年間休日122日（2018年実績）<br>\r\n\t\t\t\t\t\t\t週休2日制（土,日,祝・祭日）<br>\r\n\t\t\t\t\t\t\t※毎年3・9月の第2日曜日は公開模擬試験開催のため出社日（振替休日あり）<br>\r\n\t\t\t\t\t\t\t年末年始休暇（12月29日～1月4日）<br>\r\n\t\t\t\t\t\t\t年次有給休暇<br>\r\n\t\t\t\t\t\t\t※初年度10日、勤続年数1年：14日、2年：16日、<br>\r\n\t\t\t\t\t\t\t3年：17日、4年：19日、5年以上：20日<br>\r\n\t\t\t\t\t\t\t時間単位有給休暇（年40時間まで）<br>\r\n\t\t\t\t\t\t\t慶弔休暇<br>\r\n\t\t\t\t\t\t\t結婚休暇（5日間）<br>\r\n\t\t\t\t\t\t\t妻の出産（2日間）<br>\r\n\t\t\t\t\t\t\t誕生日休暇（誕生日の前後一週間内で１日取得）<br>\r\n\t\t\t\t\t\t\tリフレッシュ休暇<br>\r\n\t\t\t\t\t\t\t※5年ごとに5日間、年次有給休暇と併せて最大2週間取得可能<br>\r\n\t\t\t\t\t\t\t※補助金5万～10万支給あり\r\n\t\t\t\t\t\t</td>\r\n\t\t\t\t\t</tr>\r\n\t\t\t\t\t<tr>\r\n\t\t\t\t\t\t<th>社会保険</th>\r\n\t\t\t\t\t\t<td>\r\n\t\t\t\t\t\t\t健康保険<br>\r\n\t\t\t\t\t\t\t厚生年金<br>\r\n\t\t\t\t\t\t\t雇用保険<br>\r\n\t\t\t\t\t\t\t労災保険\r\n\t\t\t\t\t\t</td>\r\n\t\t\t\t\t</tr>\r\n\t\t\t\t\t<tr>\r\n\t\t\t\t\t\t<th>福利厚生</th>\r\n\t\t\t\t\t\t<td>\r\n\t\t\t\t\t\t\t通勤・営業交通費全額支給<br>\r\n\t\t\t\t\t\t\t退職金制度（企業年金基金を利用）<br>\r\n\t\t\t\t\t\t\t契約施設（スポーツ施設,保養施設,遊園施設）優待<br>\r\n\t\t\t\t\t\t\t専門のカウンセラーによるメンタルヘルスケア制度<br>\r\n\t\t\t\t\t\t\t育児・介護短時間勤務制度、各種慶弔見舞制度<br>\r\n\t\t\t\t\t\t\t在宅勤務制度<br>\r\n\t\t\t\t\t\t\t社員紹介制度<br>\r\n\t\t\t\t\t\t\t再雇用制度（結婚、育児、介護等による事情で退職した社員が再雇用を希望した場合に優先的に募集する制度）<br>\r\n\t\t\t\t\t\t\t資格奨励金制度（1万～5万円を支給）<br>\r\n\t\t\t\t\t\t\tスキルアップサポート制度<br>\r\n\t\t\t\t\t\t\t※自身のスキルアップの為の教材購入・セミナー受講・受験費用等を会社が負担します\r\n\t\t\t\t\t\t</td>\r\n\t\t\t\t\t</tr>\r\n\t\t\t\t\t<tr>\r\n\t\t\t\t\t\t<th>募集人数</th>\r\n\t\t\t\t\t\t<td>若干名</td>\r\n\t\t\t\t\t</tr>\r\n\t\t\t\t\t<tr>\r\n\t\t\t\t\t\t<th>採用学部学科</th>\r\n\t\t\t\t\t\t<td>全学部全学科（理系・文系　問いません）</td>\r\n\t\t\t\t\t</tr>\r\n\t\t\t\t\t<tr>\r\n\t\t\t\t\t\t<th>提出書類</th>\r\n\t\t\t\t\t\t<td>履歴書（できるだけ学校指定のもの・写真貼付）、成績証明書</td>\r\n\t\t\t\t\t</tr>\r\n\t\t\t\t\t<tr>\r\n\t\t\t\t\t\t<th>選考方法</th>\r\n\t\t\t\t\t\t<td>適性検査、面接複数回</td>\r\n\t\t\t\t\t</tr>\r\n\t\t\t\t</table>\r\n\t\t\t</div>\r\n\t\t</section>\r\n\r\n\t\t<!-- エントリー受付中の記述　ここから　\r\n\r\n\t<section id=\"entry\" class=\"section bg\">\r\n\t\t<div class=\"container\">\r\n\t\t\t<h2>ENTRY</h2>\r\n\t\t\t <form action=\"new_mail.php\" method=\"post\" id=\"messageform\">\r\n\t\t\t<table class=\"sbox\">\r\n\t\t\t\t\r\n\t\t\t\t<tr>\r\n\t\t\t\t\t<th>氏名</th>\r\n\t\t\t\t\t<td>\r\n\t\t\t\t\t\t<input type=\"text\" name=\"氏名\" class=\"itxt validate[required]\" id=\"name\" placeholder=\"例）山田 太郎\">\r\n\t\t\t\t\t</td>\r\n\t\t\t\t</tr>\r\n\t\t\t\t<tr>\r\n\t\t\t\t\t<th>メールアドレス</th>\r\n\t\t\t\t\t<td>\r\n\t\t\t\t\t\t<input type=\"email\" name=\"メールアドレス\" class=\"itxt validate[required]\" id=\"email\" placeholder=\"例）abc.jp@example.com\">\r\n\t\t\t\t\t</td>\r\n\t\t\t\t</tr>\r\n\t\t\t\t<tr>\r\n\t\t\t\t\t<th>学校名</th>\r\n\t\t\t\t\t<td>\r\n\t\t\t\t\t\t<input type=\"text\" name=\"学校名\" class=\"itxt validate[required]\" id=\"school\" placeholder=\"例）○○大学\">\r\n\t\t\t\t\t</td>\r\n\t\t\t\t</tr>\r\n\t\t\t\t<tr>\r\n\t\t\t\t\t<th>応募職種</th>\r\n\t\t\t\t\t<td>\r\n\t\t\t\t\t\t<select name=\"応募職種\" id=\"job\" class=\"itxt validate[required] boxcolor\">\r\n\t\t\t\t\t\t\t\t<div class=\"select-wrap\">\r\n\t\t\t\t\t\t\t\t<option value=\"\">選択してください</option>\r\n\t\t\t\t\t\t\t\t<option value=\"営業職\">営業職</option>\r\n\t\t\t\t\t\t\t\t<option value=\"事務職\">事務職</option>\r\n</