{"url":"http://www.nichicon.co.jp/recruit_graduates/requirement/","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n  <head>\n    <meta charset=\"UTF-8\">\n    <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1, shrink-to-fit=no\">\n    <title>募集要項 | 新卒採用情報 | 採用情報 | 企業情報 | ニチコン株式会社 </title>\n    <meta name=\"description\" content=\"ニチコンの採用情報 - 募集要項をご紹介しています。\">\n    <link rel=\"canonical\" href=\"https://www.nichicon.co.jp/recruit_graduates/requirement/\">\n    <meta property=\"og:type\" content=\"website\">\n    <meta property=\"og:title\" content=\"募集要項 | 新卒採用情報 | 採用情報 | 企業情報 | ニチコン株式会社 \">\n    <meta property=\"og:description\" content=\"ニチコンの採用情報 - 募集要項をご紹介しています。\">\n    <meta property=\"og:url\" content=\"https://www.nichicon.co.jp/recruit_graduates/requirement/\">\n    <meta property=\"og:image\" content=\"https://www.nichicon.co.jp/recruit_graduates/assets/images/meta-img/ogp.jpg\">\n    <link rel=\"icon\" href=\"/recruit_graduates/assets/images/meta-img/favicon.ico\">\n    <link rel=\"apple-touch-icon\" href=\"/recruit_graduates/assets/images/meta-img/touch-icon.png\">\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n    <link href=\"https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500;600;700&amp;family=Noto+Sans+JP:wght@100..900&amp;family=Work+Sans:ital,wght@0,100..900;1,100..900&amp;family=Zen+Kaku+Gothic+Antique&amp;display=swap\" rel=\"stylesheet\">\n    <link rel=\"stylesheet\" href=\"/recruit_graduates/assets/css/app.css\"><!-- Google Tag Manager -->\n      <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\n      new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\n      j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n      'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n      })(window,document,'script','dataLayer','GTM-TSTMN78');</script>\n    <!-- End Google Tag Manager -->\n  </head>\n  <body id=\"js-body\" data-page=\"requirement\">\n    <!-- Google Tag Manager (noscript) -->\n      <noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-TSTMN78\"\n      height=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n    <!-- End Google Tag Manager (noscript) -->\n    <header class=\"l-header\">\n      <div class=\"header__link--top\"><a href=\"#top\">\n          <div class=\"flex-box\">\n            <div class=\"border\"></div>\n            <p class=\"header__link--txt\">Page top</p>\n          </div></a></div>\n      <div class=\"header__container--sp\">\n        <div class=\"header__inner\">\n          <h1 class=\"ttl__logo\"><a href=\"/recruit_graduates/\"><img src=\"/recruit_graduates/assets/images/nav-logo.svg\" alt=\"nichicon 新卒採用サイト\"></a></h1>\n        </div>\n      </div>\n      <div class=\"header__container\">\n        <div class=\"header__inner\">\n          <h1 class=\"ttl__logo\"><a href=\"/recruit_graduates/\"><img src=\"/recruit_graduates/assets/images/nav-logo.svg\" alt=\"nichicon 新卒採用サイト\"></a></h1>\n          <div class=\"navi\" id=\"navi\">\n            <ul class=\"navi__list\">\n              <li class=\"navi__list--item has-child\" data-page=\"about\">\n                <div class=\"list-wrap js-has-child\" data-label=\"about\">\n                  <p>ニチコンを知る</p><span class=\"arrow-ico\" data-label=\"about\"></span>\n                </div>\n                <div class=\"child-list__wrap\" data-label=\"about\">\n                  <ul class=\"child-list\">\n                    <li class=\"child-list__item\"><a class=\"flex-box\" href=\"/recruit_graduates/about/\">\n                        <p>ニチコンを知るTOP</p>\n                        <div class=\"c-arrow-only-ico\"></div></a></li>\n                    <li class=\"child-list__item\"><a class=\"flex-box\" href=\"/recruit_graduates/about/#anc-01\">\n                        <p>経営理念</p>\n                        <div class=\"c-arrow-only-ico\"></div></a></li>\n                    <li class=\"child-list__item\"><a class=\"flex-box\" href=\"/recruit_graduates/about/#anc-02\">\n                        <p>キーワードで見るニチコン</p>\n                        <div class=\"c-arrow-only-ico\"></div></a></li>\n                    <li class=\"child-list__item\"><a class=\"flex-box\" href=\"/recruit_graduates/about/#anc-03\">\n                        <p>創造業としての社会貢献</p>\n                        <div class=\"c-arrow-only-ico\"></div></a></li>\n                    <li class=\"child-list__item\"><a class=\"flex-box\" href=\"/recruit_graduates/about/#anc-04\">\n                        <p>積極的な研究開発</p>\n                        <div class=\"c-arrow-only-ico\"></div></a></li>\n                    <li class=\"child-list__item\"><a class=\"flex-box\" href=\"/recruit_graduates/about/#anc-05\">\n                        <p>ダイバーシティ</p>\n                        <div class=\"c-arrow-only-ico\"></div></a></li>\n                    <li class=\"child-list__item\"><a class=\"flex-box\" href=\"/recruit_graduates/about/#anc-06\">\n                        <p>グローバルな事業展開</p>\n                        <div class=\"c-arrow-only-ico\"></div></a></li>\n                    <li class=\"child-list__item\"><a class=\"flex-box\" href=\"/recruit_graduates/about/#anc-07\">\n                        <p>会社情報</p>\n                        <div class=\"c-arrow-only-ico\"></div></a></li>\n                    <li class=\"child-list__bnr\"><a class=\"c-bnr\" href=\"/brand/\"><span>ブランドサイト</span>\n                        <picture>\n                          <source srcset=\"/recruit_graduates/assets/images/nichicon_saiyobanner_pc.jpg\" media=\"(min-width: 769px)\"><img src=\"/recruit_graduates/assets/images/nichicon_saiyobanner_sp.jpg\" alt=\"\">\n                        </picture></a></li>\n                  </ul>\n                </div>\n              </li>\n              <li class=\"navi__list--item has-child\" data-page=\"jobs\">\n                <div class=\"list-wrap js-has-child\" data-label=\"jobs\">\n                  <p>ニチコンの仕事</p><span class=\"arrow-ico\" data-label=\"jobs\"></span>\n                </div>\n                <div class=\"child-list__wrap\" data-label=\"jobs\">\n                  <ul class=\"child-list\">\n                    <li class=\"child-list__item\"><a class=\"flex-box\" href=\"/recruit_graduates/jobs/\">\n                        <p>ニチコンの仕事TOP</p>\n                        <div class=\"c-arrow-only-ico\"></div></a></li>\n                    <li class=\"child-list__item\"><a class=\"flex-box\" href=\"/recruit_graduates/jobs/interview1.html\">\n                        <p>フィルムコンデンサ設計</p>\n                        <div class=\"c-arrow-only-ico\"></div></a></li>\n                    <li class=\"child-list__item\"><a class=\"flex-box\" href=\"/recruit_graduates/jobs/interview2.html\">\n                        <p>生産技術</p>\n                        <div class=\"c-arrow-only-ico\"></div></a></li>\n                    <li class=\"child-list__item\"><a class=\"flex-box\" href=\"/recruit_graduates/jobs/interview3.html\">\n                        <p>材料開発</p>\n                        <div class=\"c-arrow-only-ico\"></div></a></li>\n                    <li class=\"child-list__item\"><a class=\"flex-box\" href=\"/recruit_graduates/jobs/interview4.html\">\n                        <p>品質管理</p>\n                        <div class=\"c-arrow-only-ico\"></div></a></li>\n                    <li class=\"child-list__item\"><a class=\"flex-box\" href=\"/recruit_graduates/jobs/interview5.html\">\n                        <p>社内SE</p>\n                        <div class=\"c-arrow-only-ico\"></div></a></li>\n                    <li class=\"child-list__item\"><a class=\"flex-box\" href=\"/recruit_graduates/jobs/interview6.html\">\n                        <p>コンデンサ設計開発</p>\n                        <div class=\"c-arrow-only-ico\"></div></a></li>\n                    <li class=\"child-list__item\"><a class=\"flex-box\" href=\"/recruit_graduates/jobs/interview7.html\">\n                        <p>蓄電ソフト開発</p>\n                        <div class=\"c-arrow-only-ico\"></div></a></li>\n                    <li class=\"child-list__item\"><a class=\"flex-box\" href=\"/recruit_graduates/jobs/interview8.html\">\n                        <p>応用機器設計</p>\n                        <div class=\"c-arrow-only-ico\"></div></a></li>\n                    <li class=\"child-list__item\"><a class=\"flex-box\" href=\"/recruit_graduates/jobs/interview10.html\">\n                        <p>営業</p>\n                        <div class=\"c-arrow-only-ico\"></div></a></li>\n                  </ul>\n                </div>\n              </li>\n              <li class=\"navi__list--item\" data-page=\"technology\"><a href=\"/recruit_graduates/technology/\">\n                  <div class=\"list-wrap\">\n                    <p>未来をひらく技術力</p><span class=\"c-arrow-only-ico is-tab\"></span>\n                  </div></a></li>\n              <li class=\"navi__list--item\" data-page=\"internship\"><a href=\"/recruit_graduates/internship/\">\n                  <div class=\"list-wrap\">\n                    <p>インターンシップ</p><span class=\"c-arrow-only-ico is-tab\"></span>\n                  </div></a></li>\n              <li class=\"navi__list--item last-item has-child\" data-page=\"requirement\">\n                <div class=\"list-wrap js-has-child\" data-label=\"requirement\">\n                  <p>募集要項</p><span class=\"arrow-ico\" data-label=\"requirement\"></span>\n                </div>\n                <div class=\"child-list__wrap is-open\" data-label=\"requirement\">\n                  <ul class=\"child-list\">\n                    <li class=\"child-list__item\"><a class=\"flex-box\" href=\"/recruit_graduates/requirement/\">\n                        <p>募集要項TOP</p>\n                        <div class=\"c-arrow-only-ico\"></div></a></li>\n                    <li class=\"child-list__item\"><a class=\"flex-box\" href=\"/recruit_graduates/requirement/process.html\">\n                        <p>採用プロセス</p>\n                        <div class=\"c-arrow-only-ico\"></div></a></li>\n                  </ul>\n                </div>\n              </li>\n            </ul>\n          </div>\n          <div class=\"header__entry--wrap\"><a class=\"header__entry--btn -white\" href=\"https://job.axol.jp/bx/s/nichicon_27/mypage/login\" target=\"_blank\">\n              <p>My Page</p></a><a class=\"header__entry--btn\" href=\"https://job.axol.jp/bx/s/nichicon_27/entry/\" target=\"_blank\">\n              <p>Entry</p></a></div>\n          <div class=\"sp-menu__btn\" id=\"js-menu-btn\">\n            <p>Menu</p><span class=\"border-ico\"></span>\n          </div>\n        </div>\n      </div>\n    </header>\n    <div class=\"requirement\">\n      <section class=\"requirement-mv\">\n        <div class=\"requirement-mv__container\">\n          <div class=\"requirement-mv__img\">\n            <div class=\"c-container\">\n              <div class=\"c-ttl__contents\">\n                <h2 class=\"c-ttl white-txt u-textOverlay\"><span class=\"u-textOverlay__inner\">Requirements</span></h2>\n                <p class=\"c-sub-ttl white-txt u-textOverlay\"><span class=\"u-textOverlay__inner\">募集要項</span></p>\n              </div>\n            </div>\n          </div>\n        </div>\n      </section>\n      <div class=\"requirement-anchor__container\">\n        <div class=\"c-anchor-links\">\n          <div class=\"c-anchor-link\"><a class=\"c-btn\" href=\"#lead\">\n              <div class=\"c-btn__txt\">採用方針</div></a></div>\n          <div class=\"c-anchor-link\"><a class=\"c-btn\" href=\"#persona\">\n              <div class=\"c-btn__txt\">求める人材</div></a></div>\n          <div class=\"c-anchor-link\"><a class=\"c-btn\" href=\"#details\">\n              <div class=\"c-btn__txt\">募集要項</div></a></div>\n          <div class=\"c-anchor-link\"><a class=\"c-btn\" href=\"#question\">\n              <div class=\"c-btn__txt\">よくある<br class=\"is-sp\">ご質問</div></a></div>\n        </div>\n      </div>\n      <section class=\"requirement-lead\" id=\"lead\">\n        <div class=\"requirement-lead__container\">\n          <div class=\"requirement-lead__inner\">\n            <div class=\"requirement-lead__wrap\">\n              <h2 class=\"requirement-lead__ttl\"><span class=\"mini-ttl\">採用方針</span>情熱こそが会社の未来を創る<br class=\"is-sp\">源泉</h2>\n              <div class=\"requirement-lead__txt\">\n                <p class=\"txt-item\">ニチコンは、情熱こそが会社の未来を創る源泉だと考えています。それは当社が、世界的な大競争を通じて、お客さまとの信頼関係を築くためには、ひたむきに情熱を注ぐことがいかに大切であるかを知っているからです。</p>\n                <p class=\"txt-item\">チャレンジ精神旺盛で、現状に満足することなく、いつも「なぜ？」という<br class=\"is-pc\">気持ちを持ち続ける。そして、困難に直面しても決して諦めることなく、目的達成のために全力を尽くす人。当社が求めているのは、そんな情熱を持った人です。当社は、それに応えて年功序列を廃し、若い人達の活躍の場が多くあります。</p>\n                <p class=\"txt-item\">また、グローバル化が進展している今日では、それに対応できるだけの幅広い視野で物事を捉えることが不可欠です。そのため、世界的な視点から変化を<br class=\"is-pc\">いち早く捉え、的確に対応できる可能性を持った人材を必要としています。</p>\n                <p class=\"txt-item\">採用選考において当社は、面接を重視します。多様な個性を持った情熱との<br class=\"is-pc\">出会いを大切にしたいからです。どうか、思い切ってあなた自身の可能性を<br class=\"is-pc\">アピールしてください。その日の来ることを楽しみにしています。</p>\n              </div>\n              <div class=\"gradient-wrap\">\n                <div class=\"requirement-lead__txt--btn is-sp\">続きを読む</div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </section>\n      <section class=\"requirement-persona js-fadeup-trigger\" id=\"persona\">\n        <div class=\"requirement-contents__container\">\n          <div class=\"c-container\">\n            <h2 class=\"c-lower-ttl\">求める人材</h2>\n            <div class=\"requirement-contents__wrap\">\n              <div class=\"requirement-contents__inner\">\n                <div class=\"requirement-persona__column\">\n                  <div class=\"requirement-persona__column--item\">\n                    <div class=\"ttl\">挑戦</div>\n                    <div class=\"txt\">社会の変化を察知し、<br>変化に対応できる人材</div>\n                  </div>\n                  <div class=\"requirement-persona__column--item\">\n                    <div class=\"ttl\">ファンづくり</div>\n                    <div class=\"txt\">顧客に期待以上の価値を<br>提供できる人材</div>\n                  </div>\n                  <div class=\"requirement-persona__column--item\">\n                    <div class=\"ttl\">あきらめない</div>\n                    <div class=\"txt\">できるまでやり抜く力を<br>持った人材</div>\n                  </div>\n                  <div class=\"requirement-persona__column--item\">\n                    <div class=\"ttl\">チームワーク</div>\n                    <div class=\"txt\">チームとして成果を<br>出せる人材</div>\n                  </div>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </section>\n      <section class=\"requirement-details\" id=\"details\">\n        <div class=\"requirement-contents__container\">\n          <div class=\"c-container\">\n            <h2 class=\"c-lower-ttl\">募集要項</h2>\n            <div class=\"requirement-contents__wrap\">\n              <div class=\"requirement-contents__inner\">\n                <div class=\"requirement-details__accordion\">\n                  <h3 class=\"requirement-contents__ttl\">採用職種・配属予定事業所</h3>\n                  <div class=\"requirement-details__accordion--item\">\n                    <div class=\"accordion__btn\" data-class=\"science\">\n                      <p>理系（電気、電子、機械、情報、化学、<br class=\"is-sp\">材料、物理、<br class=\"is-only-tab\">経営工学、デザイン、 他）</p>\n                      <div class=\"arrow-ico\"></div>\n                    </div>\n                    <div class=\"accordion__content\" data-content=\"science\">\n                      <div class=\"accordion__content--inner\">\n                        <div class=\"accordion__content--wrap\">\n                          <div class=\"accordion__content--item\">\n                            <div class=\"ttl\">採用職種</div>\n                            <div class=\"txt\">\n                              <ul class=\"counter-num\">\n                                <li>「回路製品」および「コンデンサ応用機器」の回路設計・機構設計・制御ソフト開発・生産技術・設備開発・デザイン企画（家庭用蓄電システム、Ｖ２Ｈ（Vehicle to Home）システム、EV・PHEV用急速充電器、公共・産業用蓄電システム、スイッチング電源、機能モジュール、超高精度加速器用電源（医療用・研究用）、停電補償装置、瞬時電圧低下補償装置 他）</li>\n                                <li>「各種コンデンサ等」の材料開発・製品開発・生産技術・設備開発・品質管理（アルミ電解コンデンサ、フィルムコンデンサ、導電性高分子アルミ固体電解コンデンサ、小形リチウムイオン二次電池 他）</li>\n                                <li>システム開発</li>\n                                <li>営業（国内・海外）</li>\n                                <li>管理部門 等（生産管理、購買、経理、総務、人事、法務、システム開発）</li>\n                              </ul>\n                            </div>\n                          </div>\n                          <div class=\"accordion__content--item\">\n                            <div class=\"ttl\">配属予定事業所</div>\n                            <div class=\"sub-ttl\">理工系 (技術職)</div>\n                            <div class=\"txt\">\n                              <ul class=\"counter-dot\">\n                                <li><span class=\"list-ttl\">【東京開発センター（東京都中央区）】</span><br>スイッチング電源・蓄電システムの回路設計、開発試作、制御ソフト開発他</li>\n                                <li><span class=\"list-ttl\">【ニチコン製箔（長野県大町市・<br class=\"is-sp\">福井県大野市）】</span><br>アルミ電解コンデンサの箔開発、設備機械の設計・改良、生産技術、品質管理他</li>\n                                <li><span class=\"list-ttl\">【ニチコン草津（滋賀県草津市）】</span><br>フィルムコンデンサ・コンデンサ応用機器（「超高精度加速器用電源（医療用・研究用）」「停電補償装置」「瞬時電圧低下補償装置」）の製品開発、設備機械の設計・改良、生産技術、品質管理他</li>\n                                <li><span class=\"list-ttl\"> 【ニチコン亀岡（京都府亀岡市）】</span><br>回路製品（「車載用充電器」「V2H(Vehicle to Home)システム」「EV用急速充電器」他）・正特性サーミスタの製品開発、制御ソフト開発、設備機械の設計・改良、生産技術、品質管理他</li>\n                                <li><span class=\"list-ttl\">【ニチコン大野（福井県大野市・<br class=\"is-sp\">長野県安曇野市）】</span><br>アルミ電解コンデンサ・導電性高分子アルミ固体電解コンデンサ・電気二重層コンデンサ、小形リチウムイオン二次電池の小形・長寿命化を含めた新製品開発（ペースト開発を含む）、設備機械の設計・改良、生産技術、品質管理他</li>\n                                <li><span class=\"list-ttl\">【ニチコン岩手（岩手県岩手郡岩手町・<br class=\"is-sp\">岩手県紫波郡紫波町）】</span><br>アルミ電解コンデンサ・導電性高分子ハイブリッドアルミ電解コンデンサの小形・長寿命化を含めた新製品開発、設備機械の設計・改良、生産技術、品質管理他</li>\n                                <li><span class=\"list-ttl\"> 【ニチコンワカサ（福井県小浜市）】</span><br>スイッチング電源・蓄電システムに関する設備機械の設計・改良、生産技術、品質管理他</li>\n                                <li><span class=\"list-ttl\">【酉島電機製作所（滋賀県草津市）】</span><br>変圧器・リアクトルの製品開発、設備機械の設計・改良、生産技術、品質管理他</li>\n                                <li><span class=\"list-ttl\">【日本リニアックス（大阪府高槻市）】</span><br>圧力伝送器・傾斜計・ストローク計の製品開発、設備機械の設計・改良、生産技術、品質管理他</li>\n                                <li><span class=\"list-ttl\">【本社（京都府京都市）】</span><br>ニチコングループ全般にわたるシステム開発・製品のデザイン企画他</li>\n                              </ul>\n                            </div>\n                            <div class=\"sub-ttl\">理工系 (営業職)</div>\n                            <div class=\"txt is-indent\">全国の事業所<br class=\"is-sp\">（東京・愛知・京都 他）</div>\n                          </div>\n                        </div>\n                      </div>\n                    </div>\n                  </div>\n                  <div class=\"requirement-details__accordion--item\">\n                    <div class=\"accordion__btn\" data-class=\"humanities\">\n                      <p>文系（全学部全学科）</p>\n                      <div class=\"arrow-ico\"></div>\n                    </div>\n                    <div class=\"accordion__content\" data-content=\"humanities\">\n                      <div class=\"accordion__content--inner\">\n                        <div class=\"accordion__content--wrap\">\n                          <div class=\"accordion__content--item\">\n                            <div class=\"ttl\">採用職種</div>\n                            <div class=\"txt\">\n                              <ul class=\"counter-num\">\n                                <li>営業（国内・海外）</li>\n                                <li>管理部門 等（生産管理、購買、経理、総務、人事、法務、システム開発）</li>\n                              </ul>\n                            </div>\n                          </div>\n                        </div>\n                      </div>\n                    </div>\n                  </div>\n                </div>\n                <div class=\"requirement-details__item\">\n                  <h3 class=\"requirement-contents__ttl\">募集対象</h3>\n                  <div class=\"requirement-contents__txt\">\n                    <p>\n                      2027年3月大学院修了・大学卒業見込の方<br>\n                      （2026年9月大学院修了・大学卒業見込の方の応募も可）<br>\n                      （日本の大学で勉強されている外国人留学生の方および海外の大学で勉強されている日本人の方も積極的に採用します。）\n                    </p>\n                  </div>\n                </div>\n                <div class=\"requirement-details__item\">\n                  <h3 class=\"requirement-contents__ttl\">給与</h3>\n                  <div class=\"requirement-contents__txt\">\n                    <p>\n                      2026年4月入社初任給<br>\n                      大学院(博士)了331,000円、<br class=\"is-sp\">大学院(修士)了317,000円、<br class=\"is-sp\">大学卒288,000円\n                    </p>\n                  </div>\n                </div>\n                <div class=\"requirement-details__item\">\n                  <h3 class=\"requirement-contents__ttl\">昇給・賞与</h3>\n                  <div class=\"requirement-contents__txt\">\n                    <p>昇給／年１回　賞与／年２回</p>\n                  </div>\n                </div>\n                <div class=\"requirement-details__item\">\n                  <h3 class=\"requirement-contents__ttl\">休日休暇</h3>\n                  <div class=\"requirement-contents__txt\">\n                    <p>\n                      年間休日122日<br>\n                      上記と別で、年休一斉取得または<br class=\"is-sp\">計画取得あり<br>\n                      週休２日制（土・日）、祝日、GW・夏季休暇・年末年始休暇、年次有給休暇、失効年休積立制度、慶弔休暇、育児休業、介護休業 他\n                    </p><small class=\"comment\">※会社カレンダーによる</small>\n                  </div>\n                </div>\n                <div class=\"requirement-details__item\">\n                  <h3 class=\"requirement-contents__ttl\">保険・福利厚生</h3>\n                  <div class=\"requirement-contents__txt\">\n                    <p>\n                      健康保険・介護保険・厚生年金保険・雇用保険・<br class=\"is-sp\">労災保険<br>\n                      育児休業・介護休業制度、従業員持株会（20%補助あり）、財形貯蓄制度、慶弔見舞金、貸付金制度、団体長期障害所得補償保険制度、(選択制)確定拠出年金制度、個室独身寮制度<span class=\"small-top\">※</span>　他\n                    </p><small class=\"comment\">※本制度の対象となる方が、借り上げ社宅を利用できます。地域により異なりますが、自己負担額は7,500～9,000円／月です。</small>\n                  </div>\n                </div>\n                <div class=\"requirement-details__item\">\n                  <h3 class=\"requirement-contents__ttl\">勤務時間</h3>\n                  <div class=\"requirement-contents__txt\">\n                    <p>8:45～17:15（本社・営業）、<br class=\"is-sp\">8:30～17:10 （工場） 他</p>\n                  </div>\n                </div>\n                <div class=\"requirement-details__item\">\n                  <h3 class=\"requirement-contents__ttl\">教育制度</h3>\n                  <div class=\"requirement-contents__txt\">\n                    <p>「人こそニチコンのエネルギー」をモットーに一人ひとりの個性・能力を伸ばします。</p>\n                    <ul class=\"counter-dot\">\n                      <li>・新入社員研修<br>入社後、主要事業所等で集合研修を実施し、「会社概要・諸制度・技術開発・製品知識など」について、社員として必要とする基本を教育します。</li>\n                      <li>・その他<br>新入社員フォロー研修、階層別研修、設計品質教育、技術者教育（MOT教育）、営業職研修、品質保証教育、自己啓発研修（エチケット・マナー研修、通信教育・英会話支援(修了者には全額補助あり)　他）</li>\n                    </ul>\n                  </div>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </section>\n      <section class=\"requirement-question\" id=\"question\">\n        <div class=\"requirement-contents__container\">\n          <div class=\"c-container\">\n            <h2 class=\"c-lower-ttl\">よくあるご質問</h2>\n            <div class=\"requirement-contents__wrap\">\n              <div class=\"requirement-contents__inner\">\n                <h3 class=\"requirement-details__ttl\">選考について</h3>\n                <div class=\"requirement-details__accordion--item\">\n                  <div class=\"accordion__btn\" data-class=\"question1\">\n                    <p>選考のステップについて<br class=\"is-sp\">教えてください。</p>\n                    <div class=\"arrow-ico\"></div>\n                  </div>\n                  <div class=\"accordion__content\" data-content=\"question1\">\n                    <div class=\"accordion__content--inner\">\n                      <div class=\"accordion__content--wrap\">\n                        <div class=\"accordion__content--item\">\n                          <div class=\"answer\">まずは採用ナビサイトよりエントリーしてください。その後のプロセスは以下のとおりです。\n                            <div class=\"step-list__inner\">\n                              <div class=\"step-list\">\n                                <div class=\"ttl\">STEP1：エントリー</div>\n                                <div class=\"txt\">会社説明会の日程をご案内いたしますので、<br class=\"is-sp\">ナビサイトより予約のうえご参加ください。</div>\n                              </div>\n                              <div class=\"step-list\">\n                                <div class=\"ttl\">STEP2：書類選考</div>\n                                <div class=\"txt\">書類選考の結果、面接日程をご連絡いたします。</div>\n                              </div>\n                              <div class=\"step-list\">\n                                <div class=\"ttl\">STEP3：選考（面接(2~3回）、作文）</div>\n                              </div>\n                              <div class=\"step-list\">\n                                <div class=\"ttl\">STEP4：内定</div>\n                              </div>\n                            </div>\n                            <p class=\"link-txt\">詳細は<a class=\"link\" href=\"/recruit_graduates/requirement/process.html\">こちら</a></p>\n                          </div>\n                        </div>\n                      </div>\n                    </div>\n                  </div>\n                </div>\n                <div class=\"requirement-details__accordion--item\">\n                  <div class=\"accordion__btn\" data-class=\"question2\">\n                    <p>語学力はどのぐらい必要ですか。</p>\n                    <div class=\"arrow-ico\"></div>\n                  </div>\n                  <div class=\"accordion__content\" data-content=\"question2\">\n                    <div class=\"accordion__content--inner\">\n                      <div class=\"accordion__content--wrap\">\n                        <div class=\"accordion__content--item\">\n                          <p class=\"answer\">語学力を備えていらっしゃることはプラス評価させていただきます。<br class=\"is-sp\">しかしながら、選考の際に語学力のみを重視することはありません。語学力が求められる職種についても、配属の際の判断材料とすることはありますが、入社時点で必ず必要になることはありません。<br>また、入社後には自己啓発のための通信教育講座を受講することができますので、制度を活用して語学力を伸ばしていくことができます。</p>\n                        </div>\n                      </div>\n                    </div>\n                  </div>\n                </div>\n                <div class=\"requirement-details__accordion--item\">\n                  <div class=\"accordion__btn\" data-class=\"question3\">\n                    <p>選考に有利な資格はありますか。</p>\n                    <div class=\"arrow-ico\"></div>\n                  </div>\n                  <div class=\"accordion__content\" data-content=\"question3\">\n                    <div class=\"accordion__content--inner\">\n                      <div class=\"accordion__content--wrap\">\n                        <div class=\"accordion__content--item\">\n                          <p class=\"answer\">資格そのもので有利・不利ということはありません。<br class=\"is-sp\">その資格が職務の遂行に役立つものであれば、考慮されることはあります。</p>\n                        </div>\n                      </div>\n                    </div>\n                  </div>\n                </div>\n                <div class=\"requirement-details__accordion--item\">\n                  <div class=\"accordion__btn\" data-class=\"question4\">\n                    <p>OB·OGの紹介は<br class=\"is-sp\">行っていただけますか。</p>\n                    <div class=\"arrow-ico\"></div>\n                  </div>\n                  <div class=\"accordion__content\" data-content=\"question4\">\n                    <div class=\"accordion__content--inner\">\n                      <div class=\"accordion__content--wrap\">\n                        <div class=\"accordion__content--item\">\n                          <p class=\"answer\">申し訳ございませんが、OB・OGの紹介は行っておりません。</p>\n                        </div>\n                      </div>\n                    </div>\n                  </div>\n                </div>\n                <div class=\"requirement-details__accordion--item\">\n                  <div class=\"accordion__btn\" data-class=\"question5\">\n                    <p>海外の大学に留学している学生の<br class=\"is-sp\">採用について教えてください。</p>\n                    <div class=\"arrow-ico\"></div>\n                  </div>\n                  <div class=\"accordion__content\" data-content=\"question5\">\n                    <div class=\"accordion__content--inner\">\n                      <div class=\"accordion__content--wrap\">\n                        <div class=\"accordion__content--item\">\n                          <p class=\"answer\">海外大学在籍者の採用も積極的に行っています。 選考プロセス・募集要領は日本国内の学生と同じです。</p>\n                        </div>\n                      </div>\n                    </div>\n                  </div>\n                </div>\n                <div class=\"requirement-details__accordion--item\">\n                  <div class=\"accordion__btn\" data-class=\"question6\">\n                    <p>浪人・留年は<br class=\"is-sp\">不利になるのでしょうか。</p>\n                    <div class=\"arrow-ico\"></div>\n                  </div>\n                  <div class=\"accordion__content\" data-content=\"question6\">\n                    <div class=\"accordion__content--inner\">\n                      <div class=\"accordion__content--wrap\">\n                        <div class=\"accordion__content--item\">\n                          <p class=\"answer\">あくまでも人物本位で選考します。</p>\n                        </div>\n                      </div>\n                    </div>\n                  </div>\n                </div>\n                <div class=\"requirement-details__accordion--item\">\n                  <div class=\"accordion__btn\" data-class=\"question7\">\n                    <p>入社前の研修はありますか。</p>\n                    <div class=\"arrow-ico\"></div>\n                  </div>\n                  <div class=\"accordion__content\" data-content=\"question7\">\n                    <div class=\"accordion__content--inner\">\n                      <div class=\"accordion__content--wrap\">\n                        <div class=\"accordion__content--item\">\n                          <p class=\"answer\">入社前の研修はしていません。学業をはじめ、残る学生生活を悔いのないよう充実したものにしていただきたいと考えています。<br>ただし、入社式までの間、近況報告と近況報告に記入いただいた質問事項に対する回答を送付するかたちでコミュニケーションを図るとともに、入社前の不安を取り除くための課題図書を案内しています。<br class=\"is-sp\">また、社内報（トップメッセージをはじめ当社情報および当社動向等が書かれています）や、当仕が新聞記事に紹介された際はニュースリリースを送付しています。</p>\n                        </div>\n                      </div>\n                    </div>\n                  </div>\n                </div>\n                <div class=\"requirement-details__accordion--item\">\n                  <div class=\"accordion__btn\" data-class=\"question8\">\n                    <p>理系ですが、自由応募と推薦応募のどちらでも応募可能ですか。<br>また、推薦応募はどのように応募すればいいですか。</p>\n                    <div class=\"arrow-ico\"></div>\n                  </div>\n                  <div class=\"accordion__content\" data-content=\"question8\">\n                    <div class=\"accordion__content--inner\">\n                      <div class=\"accordion__content--wrap\">\n                        <div class=\"accordion__content--item\">\n                          <p class=\"answer\">自由応募と推薦応募、どちらでも応募可能です。<br>ただし、推薦応募の場合、一次面接が免除されます。所属している研究室または就職担当教授などからの推薦状が必要となりますので、<br class=\"is-pc\">確認をお願いします。</p>\n                        </div>\n                      </div>\n                    </div>\n                  </div>\n                </div>\n                <div class=\"requirement-details__accordion--item\">\n                  <div class=\"accordion__btn\" data-class=\"question9\">\n                    <p>採用人数・文理の割合を<br class=\"is-sp\">教えてください。</p>\n                    <div class=\"arrow-ico\"></div>\n                  </div>\n                  <div class=\"accordion__content\" data-content=\"question9\">\n                    <div class=\"accordion__content--inner\">\n                      <div class=\"accordion__content--wrap\">\n                        <div class=\"accordion__content--item\">\n                          <p class=\"answer\">例年80名程度採用しており、文理の割合はおよそ1対3です。</p>\n                        </div>\n                      </div>\n                    </div>\n                  </div>\n                </div>\n                <div class=\"requirement-details__accordion--item\">\n                  <div class=\"accordion__btn\" data-class=\"question10\">\n                    <p>博士後期課程（ドクター）でも<br class=\"is-sp\">応募できますか。</p>\n                    <div class=\"arrow-ico\"></div>\n                  </div>\n                  <div class=\"accordion__content\" data-content=\"question10\">\n                    <div class=\"accordion__content--inner\">\n                      <div class=\"accordion__content--wrap\">\n                        <div class=\"accordion__content--item\">\n                          <p class=\"answer\">ご応募いただけます。<br class=\"is-sp\">まずは採用ナビサイトよりエントリ ーのうえ、 会社説明会に参加ください。</p>\n                        </div>\n                      </div>\n                    </div>\n                  </div>\n                </div>\n              </div>\n              <div class=\"requirement-contents__inner\">\n                <h3 class=\"requirement-details__ttl\">入社後について</h3>\n                <div class=\"requirement-details__accordion--item\">\n                  <div class=\"accordion__btn\" data-class=\"question11\">\n                    <p>配属はどのように決まりますか。</p>\n                    <div class=\"arrow-ico\"></div>\n                  </div>\n                  <div class=\"accordion__content\" data-content=\"question11\">\n                    <div class=\"accordion__content--inner\">\n                      <div class=\"accordion__content--wrap\">\n                        <div class=\"accordion__content--item\">\n                          <p class=\"answer\">まずは、エントリーフォームに希望職種を記入してください。本人の希望と適性、部門のニーズを照らし合わせて総合的に判断し、<br class=\"is-pc\">入社後に実施する新入社員研修終了後、配属が決定します。</p>\n                        </div>\n                      </div>\n                    </div>\n                  </div>\n                </div>\n                <div class=\"requirement-details__accordion--item\">\n                  <div class=\"accordion__btn\" data-class=\"question12\">\n                    <p>転勤・異動はありますか。</p>\n                    <div class=\"arrow-ico\"></div>\n                  </div>\n                  <div class=\"accordion__content\" data-content=\"question12\">\n                    <div class=\"accordion__content--inner\">\n                      <div class=\"accordion__content--wrap\">\n                        <div class=\"accordion__content--item\">\n                          <p class=\"answer\">今後の事業展開や人員計画、人材育成計画等に基づき、社員の適性ならびに本人の希望を考慮しつつ、必要に応じて適宜実施しています。<br class=\"is-sp\">また、当社では自己申告制度や公募制度があり、転勤や異動の希望を伝える機会があります。</p>\n                        </div>\n                      </div>\n                    </div>\n                  </div>\n                </div>\n                <div class=\"requirement-details__accordion--item\">\n                  <div class=\"accordion__btn\" data-class=\"question13\">\n                    <p>入社後の研修について<br class=\"is-sp\">教えてください。</p>\n                    <div class=\"arrow-ico\"></div>\n                  </div>\n                  <div class=\"accordion__content\" data-content=\"question13\">\n                    <div class=\"accordion__content--inner\">\n                      <div class=\"accordion__content--wrap\">\n                        <div class=\"accordion__content--item\">\n                          <p class=\"answer\">\n                            【入社後～配属まで】<br>\n                            入社以降の新入社員研修では、経営方針や各事業所の事業内容をはじめ、社会人としてのマナーや仕事の取り組み方などについて<br class=\"is-pc\">学んでいただきます。<br class=\"is-sp\">また、いくつかの事業所を訪問し、工場の工程見学や技術者から講義を受けることで製品知識や市場動向等についても学びます。<br>\n                            【事業所配属後】<br>\n                            配属先において、必要となる知識、技術、スキルを習得するための研修、実習などが行われます。<br class=\"is-sp\">また、OJT(On the Job Training)により<br class=\"is-pc\">先輩社員から実際の業務を学んでいきます。\n                          </p>\n                        </div>\n                      </div>\n                    </div>\n                  </div>\n                </div>\n                <div class=\"requirement-details__accordion--item\">\n                  <div class=\"accordion__btn\" data-class=\"question14\">\n                    <p>海外で働くチャンスはありますか。</p>\n                    <div class=\"arrow-ico\"></div>\n                  </div>\n                  <div class=\"accordion__content\" data-content=\"question14\">\n                    <div class=\"accordion__content--inner\">\n                      <div class=\"accordion__content--wrap\">\n                        <div class=\"accordion__content--item\">\n                          <p class=\"answer\">もちろんあります。<br class=\"is-sp\">当社は海外20拠点に事業展開しており、常時60名ほどの社員が海外駐在しています。<br>希望される方はぜひ申し出てください。</p>\n                        </div>\n                      </div>\n                    </div>\n                  </div>\n                </div>\n              </div>\n              <div class=\"requirement-contents__inner\">\n                <h3 class=\"requirement-details__ttl\">福利厚生について</h3>\n                <div class=\"requirement-details__accordion--item\">\n                  <div class=\"accordion__btn\" data-class=\"question15\">\n                    <p>年間の休日はどのぐらいありますか。</p>\n                    <div class=\"arrow-ico\"></div>\n                  </div>\n                  <div class=\"accordion__content\" data-content=\"question15\">\n                    <div class=\"accordion__content--inner\">\n                      <div class=\"accordion__content--wrap\">\n                        <div class=\"accordion__content--item\">\n                          <p class=\"answer\">\n                            122日です。<br class=\"is-sp\">GW・年末年始・夏季休暇等があります。<br>\n                            また、これとは別に年休一斉取得または計画取得を年5日実施しています。\n                          </p>\n                        </div>\n                      </div>\n                    </div>\n                  </div>\n                </div>\n                <div class=\"requirement-details__accordion--item\">\n                  <div class=\"accordion__btn\" data-class=\"question16\">\n                    <p>寮について教えてください。</p>\n                    <div class=\"arrow-ico\"></div>\n                  </div>\n                  <div class=\"accordion__content\" data-content=\"question16\">\n                    <div class=\"accordion__content--inner\">\n                      <div class=\"accordion__content--wrap\">\n                        <div class=\"accordion__content--item\">\n                          <p class=\"answer\">独身で、配属された事業所に自宅通勤できないと会社が判断した場合に入寮対象となります。<br>住居は会社が準備しますので、ご自身で部屋を探していただく必要はありません。<br class=\"is-sp\">なお、入寮条件に該当する方が会社の用意した寮以外の物件に居住する場合は、会社援助対象外となります。</p>\n                        </div>\n                      </div>\n                    </div>\n                  </div>\n                </div>\n                <div class=\"requirement-details__accordion--item\">\n                  <div class=\"accordion__btn\" data-class=\"question17\">\n                    <p>産休や育休制度はありますか。</p>\n                    <div class=\"arrow-ico\"></div>\n                  </div>\n                  <div class=\"accordion__content\" data-content=\"question17\">\n                    <div class=\"accordion__content--inner\">\n                      <div class=\"accordion__content--wrap\">\n                        <div class=\"accordion__content--item\">\n                          <p class=\"answer\">出産については産前・産後休暇、育児については最長2年の育児休業、お子さんが小学校1年生の年度末までの短時間勤務制度、子の看護休暇、時間外勤務、深夜勤務の免除等もあり、子どもをもつ社員が仕事と育児を両立できるように制度が整っています。<br class=\"is-sp\">また、男性社員の育児休業についても取得を促進しています。</p>\n                        </div>\n                      </div>\n                    </div>\n                  </div>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </section>\n    </div>\n    <div class=\"c-container\"></div>\n    <footer class=\"l-footer\">\n      <div class=\"footer__container\">\n        <div class=\"footer__inner\">\n          <div class=\"footer__link\">\n            <div class=\"footer__link--item\"><a href=\"https://www.nichicon.co.jp/\" target=\"_blank\" rel=\"noopener noreferrer\">\n                <p>コーポレートサイト</p></a></div>\n            <div class=\"footer__link--item\"><a href=\"https://www.nichicon.co.jp/policy/\" target=\"_blank\" rel=\"noopener noreferrer\">\n                <p>個人情報保護方針</p></a></div>\n          </div><small class=\"footer__copy\">© 2024  NICHICON CORPORATION.</small>\n        </div>\n      </div>\n    </footer>\n    <script src=\"/recruit_graduates/assets/js/app.js\"></script>\n  </body>\n</html>","finalUrl":"http://www.nichicon.co.jp/recruit_graduates/requirement/","rendered":false,"_cachedAt":"2026-06-22T17:32:08.608Z"}