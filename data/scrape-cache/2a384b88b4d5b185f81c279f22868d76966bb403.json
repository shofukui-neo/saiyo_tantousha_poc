ef^=\"#\"]').on('click', function (e) {\n      const $target = $($(this).attr('href'));\n      if ($target.length) {\n        e.preventDefault();\n        $header.removeClass('is-active');\n        $('html, body').animate({ scrollTop: $target.offset().top }, 500);\n      }\n    });\n  });\n</script> -->\n\n<script>\n  $(function () {\n    const $header = $('.header');\n\n    // ハンバーガーメニューの開閉\n    $('.btn-border').on('click', () => $header.toggleClass('is-active'));\n\n    // メニュー内の「#」が含まれるリンクすべてに対応\n    $('.menu-wrapper a[href*=\"#\"]').on('click', function (e) {\n      const href = $(this).attr('href');\n      const hashIndex = href.indexOf('#');\n      const hasHash = hashIndex !== -1;\n\n      if (hasHash) {\n        const path = href.substring(0, hashIndex);\n        const hash = href.substring(hashIndex);\n        const currentPath = location.pathname.replace(/\\/$/, '');\n\n        // 同じページ内へのアンカーか確認\n        if (location.pathname.endsWith(path.replace(/\\/$/, ''))) {\n          const $target = $(hash);\n          if ($target.length) {\n            e.preventDefault();\n            $('html, body').animate({ scrollTop: $target.offset().top }, 500);\n          }\n        }\n      }\n\n      // いずれにしてもメニューは閉じる\n      $header.removeClass('is-active');\n    });\n  });\n</script>\n\n\n<!-- 同ページ内でアンカーリンククリック時に、ハンバーガーメニュー閉じないのに対応 -->\n<!-- <script>\n\t$(function(){\n\t\tvar state = false;\n\t\t$('.menu-wrapper a').click(function(e){\n\t\t\t$header.removeClass('is-active');\n\t\t});\n\t});\n</script> -->\n\n<!-- ギミックの兼ね合いで、/about/index.htmlでは読み込まない。 -->\n\n\n\n<script>\n\t$(window).on('load scroll resize', function(){\n\t\tvar scroll = $(window).scrollTop();\n\t\tvar windowHeight = $(window).height();\n\t\t$('.trigger').each(function(){\n\t\t\tvar imgPos = $(this).offset().top;\n\t\t\tif (scroll > imgPos - windowHeight + windowHeight / 3){\n\t\t\t\t$(this).addClass('is-show');\n\t\t\t// } else {\n\t\t\t// \t$(this).removeClass('is-show');\n\t\t\t}\n\t\t});\n\t});\n</script>\n\n<script>\n  document.addEventListener('DOMContentLoaded', () => {\n    const items = document.querySelectorAll('.link-list li');\n\n    document.addEventListener('click', () => {\n      items.forEach(i => i.classList.remove('is-active'));\n    });\n\n    items.forEach(item => {\n      item.addEventListener('click', e => {\n        e.stopPropagation();\n        if (item.classList.contains('is-active')) {\n          item.classList.remove('is-active');\n        } else {\n          items.forEach(i => i.classList.remove('is-active'));\n          item.classList.add('is-active');\n        }\n      });\n    });\n  });\n</script>\n\n\n\n\n\t<script>\n\t\t$(function() {\n\t\t$('.index-acc-list').each(function() {\n\t\t\tconst $dl = $(this);\n\t\t\tconst $dd = $dl.find('dd').hide();\n\n\t\t\tconst toggleDD = () => {\n\t\t\t$dl.hasClass('is-show') ? $dd.stop(true, true).slideDown(400) : $dd.stop(true, true).slideUp(400);\n\t\t\t};\n\n\t\t\ttoggleDD(); // 初期状態で.is-showがついていたら対応\n\n\t\t\tnew MutationObserver(m => {\n\t\t\tif (m[0].attributeName === 'class') toggleDD();\n\t\t\t}).observe($dl[0], { attributes: true });\n\t\t});\n\t\t});\n\t</script>\n\n\n\t<script>\n\t\tconst cards = document.querySelectorAll(\".index-number-list li\");\n\t\tcards.forEach((card) => {\n\t\tcard.addEventListener(\"click\", () => {\n\t\t\tcard.classList.toggle(\"is-flipped\");\n\t\t});\n\t\t});\n\n\t\tdocument.querySelectorAll('.philosophy-panel-list > li').forEach((panel) => {\n\t\tpanel.addEventListener('click', () => {\n\t\t\tpanel.classList.toggle('flipped');\n\t\t});\n\t\t});\n\t</script>\n\t\n\n\n</body>\n</html>","finalUrl":"https://www.itx-corp.co.jp/recruit/about/","rendered":false,"_cachedAt":"2026-06-22T22:24:48.139Z"}