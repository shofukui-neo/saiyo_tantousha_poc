{"url":"https://www.fsi.co.jp/5g-info/index.html","html":"<!DOCTYPE html>\r\n<html>\r\n<head>\r\n<meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\">\r\n<meta name=\"viewport\" content=\"width=device-width\">\r\n<meta name=\"format-detection\" content=\"telephone=no\">\r\n<meta name=\"twitter:card\" content=\"summary_large_image\">\r\n<meta name=\"author\" content=\"\">\r\n<meta name=\"description\" content=\"富士ソフトのローカル5Gソリューションは、導入・構築から運用までワンストップで支援。お客様のユースケースに合わせた柔軟なご提案や製造、物流、医療などあらゆる現場のDXを高速・低遅延な通信基盤で実現します。\">\r\n<meta name=\"keywords\" content=\"富士ソフト,5G,ローカル5G,戦略\">\r\n<title>ローカル5G導入・構築ソリューション ｜富士ソフト株式会社</title>\r\n\r\n\r\n\r\n\r\n<!-- Google Tag Manager -->\r\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\r\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\r\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\r\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\r\n})(window,document,'script','dataLayer','GTM-MD5J4F');</script>\r\n<!-- End Google Tag Manager -->\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\t<meta property=\"og:type\" content=\"website\">\r\n\t<meta property=\"og:url\" content=\"https://www.fsi.co.jp/5g-info/\">\r\n\t<meta property=\"og:image\" content=\"https://www.fsi.co.jp/5g-info/assets/images/ogp.png\">\r\n\t<meta property=\"og:title\" content=\"ローカル5G導入・構築ソリューション｜富士ソフト株式会社\">\r\n\t<meta property=\"og:description\" content=\"富士ソフトのローカル5Gソリューションは、導入・構築から運用までワンストップで支援。お客様のユースケースに合わせた柔軟なご提案や製造、物流、医療などあらゆる現場のDXを高速・低遅延な通信基盤で実現します。\">\r\n\r\n\r\n\t<link rel=\"icon\" type=\"image/x-icon\" href=\"assets/images/favicon.ico\">\r\n\t<link rel=\"canonical\" href=\"index.html\">\r\n\t<link rel=\"stylesheet\" href=\"assets/styles/destyle.css\">\r\n\t<link rel=\"stylesheet\" type=\"text/css\" href=\"assets/styles/reset.css\" media=\"all\">\r\n\t<link rel=\"stylesheet\" type=\"text/css\" href=\"assets/styles/index.css\" media=\"all\">\r\n\t<link rel=\"stylesheet\" type=\"text/css\" href=\"assets/styles/style_new.css\" media=\"all\">\r\n\t<link rel=\"stylesheet\" type=\"text/css\" href=\"assets/styles/251224_style.css\" media=\"all\">\r\n\r\n\t<script src=\"assets/scripts/jquery-3.6.1.min.js\"></script>\r\n\r\n</head>\r\n<body id=\"top\">\r\n\r\n\r\n\r\n<!-- Google Tag Manager (noscript) -->\r\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-MD5J4F\" height=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\r\n<!-- End Google Tag Manager (noscript) -->\r\n\r\n<div class=\"page\">\r\n\t<header>\r\n\t\t<div class=\"header-inner\">\r\n\t\t\t<div class=\"logo\"><a href=\"/5g-info/\">\r\n\t\t\t\t<picture>\r\n\t\t\t\t\t<source srcset=\"assets/images/logo_sp.png\" media=\"(max-width: 767px)\">\r\n\t\t\t\t\t<img src=\"assets/images/logo.png\" alt=\"FUJISOFT\">\r\n\t\t\t\t</picture>\r\n\t\t\t</a></div>\r\n\t\t<a href=\"javascript:void(0);\" class=\"sp_show nav_tgl_btn\">\r\n\t\t\t<span class=\"nav_tgl_icn nav_tgl_icn--01\"></span>\r\n\t\t\t<span class=\"nav_tgl_icn nav_tgl_icn--02\"></span>\r\n\t\t</a>\r\n\t\t<nav class=\"header-nav\">\r\n\t\t\t<ul>\r\n\t\t\t\t\t<li class=\"sp_show\"><a href=\"/5g-info/\" class=\"nav_link\">TOP</a></li>\r\n\t\t\t\t\t<li><a href=\"/5g-info/incorporate/\" class=\"nav_link\">導入検討中の企業様</a></li>\r\n\t\t\t\t\t<li><a href=\"/5g-info/partnership/\" class=\"nav_link\">協業検討中の企業様</a></li>\r\n\t\t\t\t\t<li><a href=\"/5g-info/products/\" class=\"nav_link\">製品・ソリューション</a></li>\r\n\t\t\t\t\t<li><a href=\"https://sem-inq.fsi.co.jp/public/application/add/6744\" class=\"contact-btn contact-btn--01\" target=\"_blank\">無料でお問い合わせ</a></li>\r\n\t\t\t\t\t<li class=\"sp_show\"><a href=\"https://sem-inq.fsi.co.jp/public/application/add/6745\" class=\"contact-btn contact-btn--02\" target=\"_blank\">資料請求</a></li>\r\n\t\t\t</ul>\r\n\t\t</nav>\r\n\t\t</div>\r\n\t</header>\r\n\t<main>\r\n\t\t<div id=\"main_visual\">\r\n\t\t\t<div class=\"ly-container\">\r\n\t\t\t\t<h1 class=\"main-ttl\">次世代通信の<span class=\"sp-br\"></span>未来を創造する</h1>\r\n\t\t\t\t<p class=\"main-txt\">富士ソフトのローカル5Gソリューションが、<span class=\"sp-br\"></span>企業のDXと新たなビジネス機会を実現します。</p>\r\n\t\t\t</div>\r\n\t\t</div>\r\n\r\n\t\t<section class=\"contact contact_01\">\r\n\t\t\t<div class=\"ly-container\">\r\n\t\t\t\t<div class=\"contact-box\">\r\n\t\t\t\t\t<p class=\"contact-txt\">\r\n\t\t\t\t\t\tローカル5Gに関するお悩みやご質問、<br>お気軽にご相談ください。\r\n\t\t\t\t\t</p>\r\n\r\n\t\t\t\t\t<div class=\"btn_area\">\r\n\t\t\t\t\t\t<p class=\"btn_txt\">\r\n\t\t\t\t\t\t\t＼個別相談・ラボ見学・実証実験の実施まで／\r\n\t\t\t\t\t\t</p>\r\n\r\n\t\t\t\t\t\t<div class=\"contact-btn_wrap\">\r\n\t\t\t\t\t\t\t<a href=\"https://sem-inq.fsi.co.jp/public/application/add/6744\" class=\"contact-btn contact-btn--01\" target=\"_blank\">無料でお問い合わせ</a>\r\n\t\t\t\t\t\t\t<a href=\"https://sem-inq.fsi.co.jp/public/application/add/6745\" class=\"contact-btn contact-btn--02\" target=\"_blank\">資料請求</a>\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t</div>\r\n\t\t\t\t</div>\r\n\t\t\t</div>\r\n\t\t</section>\r\n\r\n  <section class=\"type_bg_bk\" id=\"news\">\r\n    <div class=\"ly-container txt_wh\">\r\n      <h2 class=\"heading_wh\">新着情報</h2>\r\n      <div class=\"news-list-wrap\">\r\n        <a href=\"https://www.fsi.co.jp/company/news/20260324.html\" target=\"_blank\" rel=\"noopener\">\r\n          <dl class=\"news-list\">\r\n            <dt class=\"news-list-row\">\r\n              2026.3.24\r\n              <b class=\"news-list-label\">ニュース</b>\r\n            </dt>\r\n            <dd class=\"news-list-content\">\r\n              富士ソフト、PEGATRON製“すぐつながる”屋外5Gミリ波対応CPE「M2U300」を販売開始 -災害・イベント・観光地での通信混雑に、即応性の高い新たなインフラ選択肢\r\n            </dd>\r\n          </dl>\r\n        </a>\r\n      </div>\r\n      \r\n      <div class=\"news-list-wrap\">\r\n        <a href=\"https://www.fsi.co.jp/company/news/20251104.html\" target=\"_blank\" rel=\"noopener\">\r\n          <dl class=\"news-list\">\r\n            <dt class=\"news-list-row\">\r\n              2025.11.04\r\n              <b class=\"news-list-label\">ニュース</b>\r\n            </dt>\r\n            <dd class=\"news-list-content\">\r\n              PEGATRON Corporationと販売代理店契約を締結　5Gソリューション体制を強化\r\n            </dd>\r\n          </dl>\r\n        </a>\r\n      </div>\r\n    </div>\r\n  </section>\r\n\r\n  <section class=\"type_bg_bl\" id=\"incorporate_wrap\">\r\n    <div class=\"ly-container\">\r\n      <div class=\"incorporate_anchor\">\r\n        <a href=\"#incorporate\">導入検討中の企業様</a>\r\n        <a href=\"#partnership\">協業検討中の企業様</a>\r\n      </div>\r\n\r\n      <div class=\"box_half\" id=\"incorporate\">\r\n        <h2 class=\"heading_lb\">導入検討中の企業様</h2>\r\n        <p class=\"subheading_wh\">DX推進をお考えの企業様へ</p>\r\n        <p class=\"txt_wh\">ローカル5Gが解決する具体的な課題、業種別のソリューション、導入効果を詳しくご紹介します。</p>\r\n        <div><a href=\"/5g-info/incorporate/\" class=\"button_gr\">詳しく知る</a></div>\r\n      </div>\r\n        <div class=\"incorporate_img\">\r\n          <img src=\"assets/images/incorporate_img.png\" alt=\"\">\r\n        </div>\r\n    </div>\r\n  </section>\r\n\r\n  <section class=\"type_bg_bk\" id=\"partnership_wrap\">\r\n    <div class=\"spD incorporate_btn\"><a href=\"/5g-info/incorporate/\" class=\"button_gr\">詳しく知る</a></div>\r\n    <div class=\"bg_bot\">\r\n      <img src=\"assets/images/bg_bot.png\" alt=\"\" class=\"pcD\">\r\n      <img src=\"assets/images/bg_bot_sp.png\" alt=\"\" class=\"spD\">\r\n    </div>\r\n\r\n    <div class=\"ly-container\" id=\"partnership\">\r\n      <div class=\"box_half_r\">\r\n        <h2 class=\"heading_wh\">\r\n          協業検討中の企業様\r\n        </h2>\r\n        <p class=\"subheading_wh\">新たなビジネス機会を<br class=\"spD\">お探しの企業様へ</p>\r\n        <p class=\"txt_wh\">ローカル5G市場の成長機会、パートナーメリット、富士ソフトのサポート体制をご紹介します。</p>\r\n        <div><a href=\"/5g-info/partnership/\" class=\"button_gr\">詳しく知る</a></div>\r\n      </div>\r\n      <div class=\"partnership_img\">\r\n        <img src=\"assets/images/partnership_img.png\" alt=\"\">\r\n      </div>\r\n    </div>\r\n\r\n    <div class=\"bg_top\">\r\n      <img src=\"assets/images/bg_top.png\" alt=\"\" class=\"pcD\">\r\n      <img src=\"assets/images/bg_top_sp.png\" alt=\"\" class=\"spD\">\r\n    </div>\r\n  </section>\r\n\r\n  <section class=\"type_bg_bl\" id=\"product\">\r\n    <div class=\"ly-container\">\r\n      <div class=\"box_half\">\r\n        <h2 class=\"heading_lb\">製品・<br class=\"spD\">ソリューション</h2>\r\n        <p class=\"subheading_wh\">最先端の技術を持った製品を<br>取り揃えております。</p>\r\n        <p class=\"txt_wh\">富士ソフトが取り扱っている製品とネットワーク構築のサービスについてご紹介します。<br>\r\n          お客様のユースケースに合わせてソリューションをご提供することができます。</p>\r\n        <div><a href=\"/5g-info/products/\" class=\"button_gr\">詳しく知る</a></div>\r\n      </div>\r\n      <div class=\"product_img\">\r\n        <img src=\"assets/images/product_img.png\" alt=\"\">\r\n      </div>\r\n    </div>\r\n  </section>\r\n\r\n\t\t<section class=\"dx_bg\" id=\"dx\">\r\n\t\t\t<div class=\"ly-container\">\r\n\t\t\t\t<h2 class=\"heading_line_bl\">ネットワークの<br class=\"spD\">民主化で、<br>\r\n\t\t\t\t\tすべての企業に<br class=\"spD\">DXの機会を</h2>\r\n\t\t\t\t<p>ローカル5Gは、<br class=\"spD\">これまで大企業や通信キャリアに<br class=\"spD\">独占されていた<br class=\"pcD\">\r\n\t\t\t\t\t超高速・低遅延・高信頼性の通信インフラを、<br class=\"pcD\">\r\n\t\t\t\t\tあらゆる企業にて構築できる時代をもたらします。</p>\r\n\t\t\t\t<p>富士ソフトは、<br class=\"spD\">ローカル5Gの導入を民主化し、<br>\r\n\t\t\t\t\tすべての企業がDXの恩恵を受けられる社会を実現します。</p>\r\n\t\t\t</div>\r\n\t\t</section>\r\n\r\n\r\n    <section id=\"manufacturer\" class=\"type_bg_bk\">\r\n      <div class=\"ly-container\">\r\n        <h2 class=\"heading_wh\">取扱いメーカー</h2>\r\n        <div class=\"manufacturer-container\">\r\n          <div class=\"manufacturer-overview\">\r\n            <h3><a href=\"https://5g.pegatroncorp.com/\" target=\"_blank\">PEGATRON Corporation</a></h3>\r\n            <div class=\"manufacturer-overview-inner\">\r\n              <div class=\"manufacturer-overview-left\">\r\n                <img src=\"assets/images/pegatron__img.png\" alt=\"\">\r\n              </div>\r\n              <div class=\"manufacturer-overview-right\">\r\n                <div class=\"txt_top\">\r\n                  <div class=\"establish\">\r\n                    <p class=\"cap_ttl\">設立</p>\r\n                    <p>2007年6月27日</p>\r\n                  </div>\r\n                  <div class=\"locate\">\r\n                    <p class=\"cap_ttl\">本社所在地</p>\r\n                    <p>台湾・台北市北投区力行街96号</p>\r\n                  </div>\r\n                </div>\r\n                <button class=\"js-accordion js-accordion--bk spD\">\r\n                  続きを読む\r\n                </button>\r\n                <div class=\"txt_bot accordion-box\">\r\n                  <p class=\"cap_ttl\">事業内容</p>\r\n                  <ul>\r\n                    <li>・EMS（Electronics Manufacturing Services）事業を中心に、PC、スマートフォン、ゲーム機、家電、通信機器などの設計・製造・保守を展開​</li>\r\n                    <li>・5G製品（基地局、ホームルーター、USBドングル、監視カメラなど）にも注力しています</li>\r\n                  </ul>\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n\r\n        <div class=\"manufacturer-container lb\">\r\n          <div class=\"manufacturer-overview\">\r\n            <h3><a href=\"https://www.ataya.io/\" target=\"_blank\">Atayalan, Inc</a></h3>\r\n            <div class=\"manufacturer-overview-inner\">\r\n              <div class=\"manufacturer-overview-left\">\r\n                <img src=\"assets/images/atayalan__img.png\" alt=\"\">\r\n              </div>\r\n              <div class=\"manufacturer-overview-right\">\r\n                <div class=\"txt_top\">\r\n                  <div class=\"establish\">\r\n                    <p class=\"cap_ttl lb\">設立</p>\r\n                    <p>2021年7月8日</p>\r\n                  </div>\r\n                  <div class=\"locate\">\r\n                    <p class=\"cap_ttl lb\">本社所在地</p>\r\n                    <p>アメリカ合衆国・3945 Freedom Circle,<br class=\"spD\"> Suite 760,\r\n                      Santa Clara, CA 95054</p>\r\n                  </div>\r\n                </div>\r\n                <button class=\"js-accordion js-accordion--bk spD\">\r\n                  続きを読む\r\n                </button>\r\n                <div class=\"txt_bot accordion-box\">\r\n                  <p class=\"cap_ttl lb\">事業内容</p>\r\n                  <p>\r\n                    Atayaは、エンタープライズ向けネットワーク接続を「統合」「セキュア化」「簡素化」するソリューションを提供する企業です。世界各地での本番導入実績を持ち、既存のWi-Fi、Ethernet環境に加え、プライベート5G、ZTNA（Zero\r\n                    Trust Network Access）を組み合わせることで、Industry\r\n                    4.0およびエンタープライズ領域におけるユニバーサルな接続環境を実現します。また、OT（制御系）とIT（情報系）を統合する、シンプルかつ高い操作性を備えたユーザーエクスペリエンスを提供し、企業ネットワークの運用効率と安全性の向上を支援します。\r\n                  </p>\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n\r\n        <div class=\"manufacturer-container lg\">\r\n          <div class=\"manufacturer-overview\">\r\n            <h3 class=\"manufacturer-overview-colum\"><a\r\n                href=\"https://www.liteon.com/en/product/networking-and-surveillance/networking-solutions/5g-total-solution\"\r\n                target=\"_blank\">LITE-ON <br class=\"spD\">Technology Corporation</a></h3>\r\n            <div class=\"manufacturer-overview-inner\">\r\n              <div class=\"manufacturer-overview-left\">\r\n                <img src=\"assets/images/liteon__img.png\" alt=\"\">\r\n              </div>\r\n              <div class=\"manufacturer-overview-right\">\r\n                <div class=\"txt_top\">\r\n                  <div class=\"establish\">\r\n                    <p class=\"cap_ttl lg\">設立</p>\r\n                    <p>1975年6月2日</p>\r\n                  </div>\r\n                  <div class=\"locate\">\r\n                    <p class=\"cap_ttl lg\">本社所在地</p>\r\n                    <p>台湾・台北市內湖區瑞光路392號</p>\r\n                  </div>\r\n                </div>\r\n                <button class=\"js-accordion js-accordion--bk spD\">\r\n                  続きを読む\r\n                </button>\r\n                <div class=\"txt_bot accordion-box\">\r\n                  <p class=\"cap_ttl lg\">事業内容</p>\r\n                  <p>\r\n                    LITEON Technology\r\n                    Corporation（2301.TW）は1975年に設立されました。台湾におけるLED分野のパイオニアとして、TAIEX（台湾証券取引所）に上場した初の電子機器メーカーです。<br>\r\n                    過去50年にわたり、LITEONは光電子および電源管理技術におけるリーディングポジションを確立し、世界市場で強固な地位を築いてきました。LITEONはAIコンピューティング、電動化、インテリジェントエネルギーインフラを支え、近年ではデータセンター向け電源、オプトエレクトロニクス、AIoT、車載電子分野で大きな成長を遂げています。<br>\r\n                    世界的な環境問題や気候変動を踏まえ、LITEONは20年前から関連する国際的な取り組みに参加し、サプライヤーと協力してサステナビリティ要件を満たす次世代製品の開発を進めており、具体的な行動を通じて社会的責任を果たしています。<br>\r\n                    LITEONは先進的なインテリジェントIoT製品および5Gネットワークインフラの提供に注力し、包括的なサービスと優れたユーザーエクスペリエンスを提供しています。提供分野は、5Gネットワークソリューション、監視システム、AIoTアプリケーション、サーバー関連技術まで多岐にわたります。\r\n                  </p>\r\n                  <ul>\r\n                    <li>・5G製品：FR1 & FR2 5G オールインワン・スモールセル、FR1 & FR2 O-RU、FWA</li>\r\n                    <li>・ソフトウェア管理システム：EMS & RIC</li>\r\n                  </ul>\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </section>\r\n\r\n\r\n\r\n\t\t<section id=\"local_5g\" class=\"type_bg_bl\">\r\n\t\t\t<div class=\"ly-container\">\r\n\t\t\t\t<h2 class=\"heading_lb\">ローカル5Gラボ</h2>\r\n        <div class=\"pcD\">\r\n          <div class=\"local_box\">\r\n            <div class=\"box_half\">\r\n              <p class=\"subheading_wh\">日本初の評価環境で<br>\r\n                見学や実証実験ができます</p>\r\n              <p class=\"txt_wh\">\r\n                富士ソフトは、日本で初めて「Microsoft Azure Private 5G Core」を採用したローカル5G評価環境を秋葉原オフィスに開設しています。<br>\r\n                検証にかかるコストやビジネス課題などお客様のご要望に合わせて事前検証ができます。\r\n              </p>\r\n              <div><a href=\"https://sem-inq.fsi.co.jp/public/application/add/6744 \" class=\"contact-btn contact-btn--01\" target=\"_blank\">無料でお問い合わせ</a></div>\r\n            </div>\r\n            <div class=\"local_img\">\r\n              <img src=\"assets/images/local_img_pc.png\" alt=\"\" class=\"img_box\">\r\n            </div>\r\n          </div>\r\n        </div>\r\n\r\n        <div class=\"spD\">\r\n          <div class=\"local_box\">\r\n            <p class=\"subheading_wh\">日本初の評価環境で<br>\r\n              見学や実証実験ができます</p>\r\n            <div class=\"local_img\">\r\n              <img src=\"assets/images/local_img_pc.png\" alt=\"\" class=\"img_box\">\r\n            </div>\r\n            <div>\r\n              <p class=\"txt_wh\">富士ソフトは、日本で初めて「Microsoft Azure Private 5G\r\n                Core」を採用したローカル5G評価環境を秋葉原オフィスに開設しています。<br>検証にかかるコストやビジネス課題などお客様のご要望に合わせて事前検証ができます。</p>\r\n            </div>\r\n            <div><a href=\"https://sem-inq.fsi.co.jp/public/application/add/6744\" class=\"contact-btn contact-btn--01\"\r\n                target=\"_blank\">無料でお問い合わせ</a></div>\r\n          </div>\r\n        </div>\r\n\t\t\t</div>\r\n\t\t</section>\r\n\r\n\t<section class=\"contact contact_02\">\r\n\t\t<div class=\"ly-container\">\r\n\t\t\t<div class=\"contact-box\">\r\n\t\t\t\t<p class=\"contact-txt\">\r\n\t\t\t\t\t<span>＼個別相談・ラボ見学・実証実験の実施まで／</span>\r\n\t\t\t\t\tローカル5Gに関するお悩みやご質問、<br>お気軽にご相談ください。\r\n\t\t\t\t</p>\r\n\r\n\t\t\t\t<div class=\"contact-btn_wrap\">\r\n\t\t\t\t\t<a href=\"https://sem-inq.fsi.co.jp/public/application/add/6744\" class=\"contact-btn contact-btn--01\" target=\"_blank\">無料でお問い合わせ</a>\r\n\t\t\t\t\t<a href=\"https://sem-inq.fsi.co.jp/public/application/add/6745\" class=\"contact-btn contact-btn--02\" target=\"_blank\">資料請求</a>\r\n\t\t\t\t</div>\r\n\t\t\t</div>\r\n\t\t</div>\r\n\t</section>\r\n\t</main>\r\n\t<div class=\"page_top_wrap\">\r\n\t\t<a href=\"index.html#top\" class=\"page_top\">ページトップへ戻る</a>\r\n\t</div>\r\n\t<footer>\r\n\t\t<div class=\"footer_inr\">\r\n\t\t\t<div class=\"ly-container\">\r\n\t\t\t\t<div class=\"logo\">\r\n\t\t\t\t\t<picture>\r\n\t\t\t\t\t\t<source srcset=\"assets/images/footer_logo_sp.png\" media=\"(max-width: 767px)\">\r\n\t\t\t\t\t\t<img src=\"assets/images/footer_logo.png\" alt=\"FUJISOFT\