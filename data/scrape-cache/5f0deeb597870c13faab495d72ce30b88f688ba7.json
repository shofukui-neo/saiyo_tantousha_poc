{"url":"https://www.koaglobal.com/recruit/company_01.html","html":"<!DOCTYPE html>\r\n<html lang=\"ja\">\r\n<head>\r\n<script id=\"Cookiebot\" src=\"https://consent.cookiebot.com/uc.js\" data-cbid=\"9b6fb1f6-52f8-4ad1-af6e-c4b14938b209\" data-blockingmode=\"auto\" type=\"text/javascript\"></script>\r\n<meta charset=\"utf-8\">\r\n<meta name=\"format-detection\" content=\"telephone=no\">\r\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\r\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1, maximum-scale=1, user-scalable=0\">\r\n<title>数字で見るKOA | COMPANY |新卒採用情報 | KOA株式会社</title>\r\n<meta name=\"keywords\" content=\"新卒採用情報,新卒,インターンシップ,会社説明会,伊那谷,抵抗器,電子部品,KOA,コーア\">\r\n<meta name=\"description\" content=\"ワクワクしようよ！このコンセプトには、私たちの様々な思いが込められています。何事も楽しまないとオモシロくない！仕事も、普段の生活も、真剣に楽しく。時には悩んで凹んで、乗り越えた時に楽しさが込み上げてくる。私たちは皆さんと共にワクワクする未来を創っていきたい。そう思っています。\">\r\n\r\n<!--============ IMPORT =============-->\r\n<link href=\"share/css/import.css?260409\" rel=\"stylesheet\" type=\"text/css\" media=\"all\" />\r\n<link href=\"share/css/aos.css?260409\" rel=\"stylesheet\" type=\"text/css\" media=\"screen\" />\r\n<link href=\"share/css/print.css?260409\" rel=\"stylesheet\" type=\"text/css\" media=\"print\" />\r\n\r\n<script type=\"text/javascript\" src=\"share/js/jquery.min.js\"></script>\r\n<script type=\"text/javascript\" src=\"share/js/common.js\"></script>\r\n<script type=\"text/javascript\" src=\"share/js/aos.js\"></script>\r\n<script type=\"text/javascript\" src=\"share/js/jquery-numerator.js\"></script>\r\n<!--=========== /IMPORT =============-->\r\n\r\n<!-- Favicons -->\r\n<link rel=\"icon\" href=\"images/favicon.ico\" type=\"image/vnd.microsoft.icon\">\r\n\r\n<!-- Google Analytics -->\r\n<script>\r\n    (function (i, s, o, g, r, a, m) {\r\n        i['GoogleAnalyticsObject'] = r; i[r] = i[r] || function () {\r\n            (i[r].q = i[r].q || []).push(arguments)\r\n        }, i[r].l = 1 * new Date(); a = s.createElement(o),\r\n        m = s.getElementsByT