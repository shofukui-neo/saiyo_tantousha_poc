{"url":"https://www.tenryu-magna.com/recruit.html","html":"<!doctype html>\n<html>\n<head>\n<meta charset=\"utf-8\">\n<meta http-equiv='content-language' content=\"ja\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<meta http-equiv=\"X-UA-Compatible\" content=\"ie=edge\">\n<title>株式会社 天龍　採用情報-採用条件/概要</title>\n<meta name=\"description\" content=\"株式会社天龍は、長年培った技術とチャレンジ精神で高品質な釣竿を生み出すロッドメーカーです。素材開発から設計・製造まで一貫体制でものづくりを追求。世界に誇る一本を共に創る仲間を募集しています。採用条件/概要\">\n<link href=\"https://use.fontawesome.com/releases/v6.5.1/css/all.css\" rel=\"stylesheet\" type=\"text/css\" crossorigin=\"anonymous\">\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/common/css/style.css?20241204\">\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/common/css/aboutus.css\">\n<!--<script type=\"text/javascript\" src=\"/common/js/adobefont.js\"></script>--> \n<script type=\"text/javascript\" src=\"/common/js/jquery-3.6.0.min.js\"></script>\n<!-- Google tag (gtag.js) -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-8D3DWBY15Z\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'G-8D3DWBY15Z');\n</script>\n<script type=\"application/ld+json\">\n{\n \"@context\" : \"https://schema.org/\",\n \"@type\" : \"JobPosting\",\n \"datePosted\" : \"2023-02-17\",\n \"validThrough\" : \"2024-02-17\",\n \"title\" : \"製造職、営業職、製造管理職など\",\n \"employmentType\" : \"FULL_TIME\",\n \"description\" : \"<p>釣竿、汎用長尺パイプの成形および、研磨、塗装、加工（組立）<br>SMC成型（強化プラスチック製品など）および、表面処理などの二次加工<br>各エリアでのルート営業</p>\",\n \"jobLocation\" : {\n  \"@type\" : \"Place\",\n  \"address\" : {\n   \"@type\" : \"PostalAddress\",\n   \"addressCountry\" : \"JP\",\n   \"postalCode\" : \"399-2562\",\n   \"addressRegion\" : \"長野県\",\n   \"addressLocality\" : \"飯田市\",\n   \"streetAddress\" : \"長野原700-42\"\n  }\n },\n \"baseSalary\" : {\n  \"@type\" : \"MonetaryAmount\",\n  \"currency\" : \"JPY\",\n  \"value\" : {\n   \"@type\" : \"QuantitativeValue\",\n   \"unitText\" : \"MONTH\"\n  }\n },\n \"hiringOrganization\" : {\n  \"@type\" : \"Organization\",\n  \"name\" : \"株式会社 天龍\",\n  \"sameAs\" : \"https://tenryu-magna.com/\",\n  \"logo\" : \"https://tenryu-magna.com/common/images/logo.png\"\n },\n \"identifier\" : {\n  \"@type\" : \"PropertyValue\",\n  \"name\" : \"株式会社 天龍\",\n  \"value\" : \"0001\"\n }\n}\n</script>\n</head>\n\n<body>\n<main>\n  <div class=\"contents\">\n    <h2>採用情報</h2>\n    <div class=\"block\">\n      <div class=\"container aboutus\">\n        <div class=\"article\">\n          <h3>採用概要</h3>\n          <ul class=\"tab\">\n            <li><a href=\"javascrpt:;\" data-id=\"shinsotsu\">新卒採用</a></li>\n            <li><a href=\"javascrpt:;\" data-id=\"chuto\">中途採用</a></li>\n          </ul>\n          <dl class=\"line-grid tab-toggle\" id=\"shinsotsu\">\n            <dt class=\"divider\">募集職種・分野</dt>\n            <dd>製造職、営業職、製造管理職など</dd>\n            <dt>製造職</dt>\n            <dd>\n              <ul>\n                <li>釣竿、ゴルフシャフト、汎用長尺パイプの成形および、研磨、塗装、加工（組立） </li>\n\n              </ul>\n            </dd>\n            <dt>営業職</dt>\n            <dd>海外～日本全国の各エリアでのルート営業<br>\n                  <ul class=\"rice\"><li>営業職は釣具店様との商談等があるため、釣りの知識・経験があると良い</li>\n                    <li>在宅での勤務可能。詳細についてはお問合せ下さい。 </li>\n                  </ul>     \n\n            </dd>\n            <dt>募集資格</dt>\n            <dd>\n              <ul>\n                <li>経験不問（経験者は優遇あり）</li>\n                <li>普通自動車運転免許</li>\n              </ul>\n            </dd>\n            <dt>募集対象</dt>\n            <dd>全学部・全学科　高卒～大卒（院卒）\n             \n            </dd>\n            <dt>募集人数</dt>\n            <dd>\n             5名\n              \n            </dd>\n            <dt>勤務地</dt>\n            <dd>\n              <ul>\n                <li>本社工場 <br>\n                  〒399-2562　長野県飯田市長野原700-42 </li>\n                <li>営業職は研修後、担当エリア決定</li>\n              </ul>\n            </dd>\n            <dt>勤務時間</dt>\n            <dd>8:20～17:20 </dd>\n            <dt>給与</dt>\n            <dd>当社規定による </dd>\n            <dt>諸手当</dt>\n            <dd>皆勤・通勤・役付・家族・住宅・時間外など </dd>\n            <dt>昇給</dt>\n            <dd>年1回(4月) </dd>\n            <dt>賞与</dt>\n            <dd>年2回</dd>\n            <dt>休日休暇</dt>\n            <dd>年間休日：105日（当社カレンダーによる）<br>\n              <ul>\n                <li>土曜出勤日は年間5日程度</li>\n                <li>有給休暇の計画的付与制度あり(5日間)</li>\n              </ul>\n            </dd>\n            <dt>待遇・福利厚生</dt>\n            <dd>\n              <ul>\n                <li>従業員親睦会（昇龍会）　忘年会または新年会 </li>\n                <li>慶弔休暇・退職金制度あり</li>\n                <li>年末年始・GW・夏季休暇あり</li>\n              </ul>\n            </dd>\n            <dt>研修制度</dt>\n            <dd>新入社員研修・社内研修・若手社員研修など\n\n            </dd>\n            <dt>休日休暇</dt>\n            <dd>\n              <ul>\n                <li>当社カレンダーによる（年間105日）</li>\n                <li>年次有給休暇 <br>\n                  入社後、6ケ月より10日間、以降社内規定による</li>\n              </ul>\n            </dd>\n            <dt>応募方法 </dt>\n            <dd>下記を、弊社本社まで郵送ください。\n              <ul>\n                <li>履歴書 </li>\n                <li>職務経歴書</li>\n              </ul>\n            </dd>\n          </dl>\n          <dl class=\"line-grid tab-toggle\" id=\"chuto\">\n            <dt class=\"divider\">募集職種・分野</dt>\n            <dd>製造職、営業職、製造管理職など</dd>\n            <dt>製造職</dt>\n            <dd>\n              <ul>\n                <li>釣竿、ゴルフシャフト、汎用長尺パイプの成形および、研磨、塗装、加工（組立）</li>\n                <!--<li>SMC成型（強化プラスチック製品など）および、表面処理などの二次加工</li>-->\n              </ul>\n            </dd>\n            <dt>営業職</dt>\n            <dd>\n海外～日本全国の各エリアでのルート営業<br>\n                  <ul class=\"rice\"><li>営業職は釣具店様との商談等があるため、釣りの知識・経験があると良い</li>\n                    <li>在宅での勤務可能。詳細についてはお問合せ下さい。 </li>\n                  </ul>              \n\n            </dd>\n            <dt>製造管理職</dt>\n            <dd>\n生産管理、工程管理、品質管理など\n            </dd>\n            <dt>募集資格</dt>\n            <dd>\n              <ul>\n                <li>経験不問（経験者は優遇あり）</li>\n                <li>普通自動車運転免許</li>\n              </ul>\n            </dd>\n            <dt>募集対象</dt>\n            <dd>学歴は問いません\n\n            </dd>\n            <dt>募集人数</dt>\n            <dd>若干名（お問い合わせください）\n            </dd>\n            <dt>勤務地</dt>\n            <dd>\n              <ul>\n                <li>本社工場 <br>\n                  〒399-2562　長野県飯田市長野原700-42 </li>\n                <!--<li> 毛賀工場<br>\n                  〒395-0813　長野県飯田市毛賀207 </li>-->\n                <li>営業職は研修後、担当エリア決定</li>\n              </ul>\n            </dd>\n            <dt>勤務時間</dt>\n            <dd>8:20～17:20 </dd>\n            <dt>給与</dt>\n            <dd>当社規定による </dd>\n            <dt>諸手当</dt>\n            <dd>皆勤・通勤・役付・家族・住宅・時間外など </dd>\n            <dt>昇給</dt>\n            <dd>年1回(4月) </dd>\n            <dt>賞与</dt>\n            <dd>年2回</dd>\n            <dt>休日休暇</dt>\n            <dd>年間休日：105日（当社カレンダーによる）<br>\n              <ul>\n                <li>土曜出勤日は年間5日程度</li>\n                <li>有給休暇の計画的付与制度あり(5日間)</li>\n              </ul>\n            </dd>\n            <dt>待遇・福利厚生</dt>\n            <dd>\n              <ul>\n                <li>従業員親睦会（昇龍会）　忘年会または新年会 </li>\n                <li>慶弔休暇・退職金制度あり</li>\n                <li>年末年始・GW・夏季休暇あり</li>\n              </ul>\n            </dd>\n            <dt>研修制度</dt>\n            <dd>\n              <ul>\n                <li>新入社員研修・社内研修・若手社員研修など</li>\n              </ul>\n            </dd>\n            <dt>休日休暇</dt>\n            <dd>\n              <ul>\n                <li>当社カレンダーによる（年間105日）</li>\n                <li>年次有給休暇 <br>\n                  入社後、6ケ月より10日間、以降社内規定による</li>\n              </ul>\n            </dd>\n            <dt>応募方法 </dt>\n            <dd>下記を、弊社本社まで郵送ください。\n              <ul>\n                <li>履歴書 </li>\n                <li>職務経歴書</li>\n              </ul>\n            </dd>\n          </dl>\n          <dl class=\"line-grid\">\n            <dt>お問い合わせ先</dt>\n            <dd>\n              <ul>\n                <li>TEL：0265-26-7550 <br>\n                  電話受付時間：9:00～17:00（土、日、祝日を除く）</li>\n                <li> E-mail：<script type=\"text/javascript\">\n<!--\nfunction converter(M){\nvar str=\"\", str_as=\"\";\nfor(var i=0;i<M.length;i++){\nstr_as = M.charCodeAt(i);\nstr += String.fromCharCode(str_as + 1);\n}\nreturn str;\n}\nvar ad = converter(String.fromCharCode(104,109,101,110,63,115,100,109,113,120)+String.fromCharCode(116,44,108,96,102,109,96,45,98,110,108));\ndocument.write(ad);\n//-->\n</script> \n                  <br>\n                  ※件名に採用募集に関する事を明記願います </li>\n              </ul>\n              担当：石井/塩澤　迄 </dd>\n          </dl>\n        </div>\n        <div class=\"aside-memu aboutus-menu\">\n          <ul>\n            <li><a title=\"採用情報\" href=\"/cominfo.html\" target=\"_top\">採用情報</a></li>\n            <li><a title=\"採用概要\" href=\"/recruit.html\" target=\"_top\">採用概要</a></li>\n          </ul>\n        </div>\n      </div>\n    </div>\n  </div>\n</main>\n<footer>\n  <div>\n    <div class=\"bottom-bar\">\n      <nav>\n        <ul>\n          <li><a href=\"/privacy.html\">個人情報の取扱について</a></li>\n        </ul>\n      </nav>\n      <div class=\"copyright\"><span><span class=\"isFull\">Copyright </span> &copy; <script type=\"text/javascript\">document.write( new Date().getFullYear());</script>TENRYU CO.,LTD. <span class=\"isFull\">All rights reserved.</span></span></div>\n    </div>\n  </div>\n</footer>\n<script src=\"/common/js/common.js?20230227\"></script> \n<script type=\"text/javascript\">\nPageInit(function(){\n    $(\"body\").addClass(\"loaded\");　\n});\n$('[href^=\"'+window.location.pathname+'\"]').addClass(\"current\");\nRandom_h2_img();\n\nvar id = window.location.search=='?chuto'?\"chuto\":\"shinsotsu\";\n\n$('[data-id=\"'+id+'\"]',\".tab\").addClass(\"current\");\nTabToggle(id);\n    \nfunction TabToggle(id){\n  $('a',\".tab\").removeClass(\"current\");\n  $(\".tab-toggle\").hide();\n  $('[data-id=\"'+id+'\"]',\".tab\").addClass(\"current\");\n  $(\"#\"+id).show();    \n}    \n$('a',\".tab\").click(function(){\n  var id = $(this).attr(\"data-id\");\n  TabToggle(id)\n})\n</script>\n</body>\n</html>\n","finalUrl":"https://www.tenryu-magna.com/recruit.html","rendered":false,"_cachedAt":"2026-06-22T20:02:52.671Z"}