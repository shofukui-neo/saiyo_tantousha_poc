{"url":"https://www.eidaikako.co.jp/recruit/","html":"<!DOCTYPE html>\n<html lang=\"ja\" prefix=\"og: http://ogp.me/ns# website: http://ogp.me/ns/website#\">\n<head>\n<meta charset=\"utf-8\">\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n<meta name=\"viewport\" content=\"width=device-width,user-scalable=no,initial-scale=1.0,maximum-scale=1.0\">\n\n<meta name='robots' content='index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1' />\n\n\t<!-- This site is optimized with the Yoast SEO plugin v24.3 - https://yoast.com/wordpress/plugins/seo/ -->\n\t<title>永大化工の採用サイト</title>\n\t<meta name=\"description\" content=\"永大化工では、それぞれの職種が、培った技術や経験を活かして「モノづくり」の可能性を広げ、豊かな社会づくりに貢献しています。あなたも、自分らしく働ける環境で新しい挑戦を始めてみませんか？\" />\n\t<link rel=\"canonical\" href=\"https://recruit.eidaikako.co.jp/\" />\n\t<meta property=\"og:locale\" content=\"ja_JP\" />\n\t<meta property=\"og:type\" content=\"website\" />\n\t<meta property=\"og:title\" content=\"永大化工の採用サイト\" />\n\t<meta property=\"og:description\" content=\"永大化工では、それぞれの職種が、培った技術や経験を活かして「モノづくり」の可能性を広げ、豊かな社会づくりに貢献しています。あなたも、自分らしく働ける環境で新しい挑戦を始めてみませんか？\" />\n\t<meta property=\"og:url\" content=\"https://recruit.eidaikako.co.jp/\" />\n\t<meta property=\"og:site_name\" content=\"永大化工の採用サイト\" />\n\t<meta property=\"og:image\" content=\"https://recruit.eidaikako.co.jp/wp/wp-content/uploads/2025/01/ogp.png\" />\n\t<meta property=\"og:image:width\" content=\"1200\" />\n\t<meta property=\"og:image:height\" content=\"630\" />\n\t<meta property=\"og:image:type\" content=\"image/png\" />\n\t<meta name=\"twitter:card\" content=\"summary_large_image\" />\n\t<script type=\"application/ld+json\" class=\"yoast-schema-graph\">{\"@context\":\"https://schema.org\",\"@graph\":[{\"@type\":\"CollectionPage\",\"@id\":\"https://recruit.eidaikako.co.jp/\",\"url\":\"https://recruit.eidaikako.co.jp/\",\"name\":\"永大化工の採用サイト\",\"isPartOf\":{\"@id\":\"https://recruit.eidaikako.co.jp/#website\"},\"about\":{\"@id\":\"https://recruit.eidai