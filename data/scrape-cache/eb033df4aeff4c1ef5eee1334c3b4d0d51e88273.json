v id=\"all-wrapper\"  >\n\t<div class=\"modal-slide\"></div>\n\t\t<header id = \"header\" >\n\t\t\t<div class=\"container\">\n\t\t\t\t<div class=\"flex flex-box\">\n\t\t\t\t\t<div class=\"left\">\n            <h1 id = \"logo\"><a href=\"https://recruit.eidaikako.co.jp/\"><img src=\"https://recruit.eidaikako.co.jp/wp/wp-content/themes/template/assets/images/common/header-logo.svg\" alt=\"コーポレートサイトロゴ\"></a></h1>\n          </div>\n          <div class=\"right\">\n            <div id=\"modalbtn\" class=\"modalbtn\"></div>\n              <nav class=\"modal\" id = \"modal\" >\n              \t\n            <ul class=\"flex\" >\n              <li class=\"nav-list\"><a href=\"https://recruit.eidaikako.co.jp/about/\">会社を知る</a></li>\n              <li class=\"nav-list\"><a href=\"https://recruit.eidaikako.co.jp/service/\">仕事を知る</a></li>\n              <li class=\"nav-list hover-nav\">\n                <a href=\"https://recruit.eidaikako.co.jp/balance/\" class=\"click\">働き方を知る</a>\n                <ul class=\"in-nav\">\n                  <li class=\"nav-list sp\"><a href=\"https://recruit.eidaikako.co.jp/balance/\">働き方を知る</a></li>\n                  <li class=\"nav-list\"><a href=\"https://recruit.eidaikako.co.jp/interview/\">インタビュー</a></li>\n                  <li class=\"nav-list\"><a href=\"https://recruit.eidaikako.co.jp/recruitment/\">募集要項</a></li>\n                </ul>\n              </li>\n              <li class=\"nav-list\"><a href=\"https://recruit.eidaikako.co.jp/news/\">お知らせ</a></li>\n              <li class=\"nav-list\"><a href=\"https://recruit.eidaikako.co.jp/entry/\">エントリー</a></li>\n              <li class=\"nav-list\"><a href=\"https://www.eidaikako.co.jp/\" target=\"_blank\">コーポレートサイト</a></li>\n            </ul>\n                        </nav>\n          </div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</header>\n\t\t<div class=\"page-wrapper\">\n\t\t\t<main>\n\n\n\n<div class=\"modal-inner-slide\"></div>\n<div class=\"fv-wrap\">\n    <div class=\"fv-area\">\n        <iframe src=\"https://player.vimeo.com/video/1045189245?h=e34b16685c&amp;badge=0&amp;autopause=0&amp;quality_selector=1&amp;player_id=0&amp;background=1&amp;app_id=58479\" frameborder=\"0\" allow=\"autoplay; fullscreen; picture-in-picture\" style=\"position:absolute;top:0;left:0;width:100%;height:100%;\" title=\"top-pc\"></iframe>\n    </div><script src=\"https://player.vimeo.com/api/player.js\"></script>\n</div>\n<!-- <section class=\"fv\">\n        <div class=\"swiper fv-swiper\">\n          <div class=\"swiper-wrapper fv-swiper-wrapper\">\n            <div class=\"swiper-slide fv-swiper-slide\"><div class=\"swiper-img\"><img src=\"https://recruit.eidaikako.co.jp/wp/wp-content/themes/template/assets/images/top/fv01.webp\" alt=\"\"></div></div>\n            <div class=\"swiper-slide fv-swiper-slide\"><div class=\"swiper-img\"><img src=\"https://recruit.eidaikako.co.jp/wp/wp-content/themes/template/assets/images/top/fv02.webp\" alt=\"\"></div></div>\n            <div class=\"swiper-slide fv-swiper-slide\"><div class=\"swiper-img\"><img src=\"https://recruit.eidaikako.co.jp/wp/wp-content/themes/template/assets/images/top/fv03.webp\" alt=\"\"></div></div>\n          </div>\n          <div class=\"swiper-pagination\"></div>\n        </div>\n      </section> -->\n\n\n<section id=\"sec01\" class=\"about-area\">\n    <div class=\"container banner-size\">\n    <h2 class=\"align-c ttl\"><div class=\"en-ttl light-co\">About</div><span class=\"white-tx\">会社を知る</span></h2>\n        <div class=\"flex box f_row-reverse\">\n            <div class=\"left\">\n            <img src=\"https://recruit.eidaikako.co.jp/wp/wp-content/themes/template/assets/images/top/top-about-us.webp\" alt=\"\">\n            </div>\n            <div class=\"right\">\n                <h3 class=\"white-tx sub-ttl\">未来を支えるモノづくり</h3>\n                <p class=\"white-tx\">永大化工は、合成樹脂成形品の製造と販売を通じて、日常生活や産業を支える製品を提供している会社です。<br>自動車用品分野では高品質な純正フロアマットを手がけ、産業資材分野では半導体関連部材や建築部材など、さまざまなニーズに応えています。\n</p>\n                <div class=\"btn-box\">\n                    <a href=\"https://recruit.eidaikako.co.jp/about/\" rel=\"noopener noreferrer\" class=\"btn arrow en main\"><span class=\"white-tx\">もっと見る</span></a>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>\n\n<section id=\"sec02\" class=\"business culture bg-bg fadeUpTrigger fadeUp\">\n\t<div class=\"container\">\n\t\t<h2 class=\"align-c ttl\"><div class=\"en-ttl light-co\">Business</div><span class=\"text-co\">事業を知る</span></h2>\n\t\t<div class=\"culture-list flex f_wrap two-column\">\n\t\t\t<dl>\n\t\t\t\t<dt class=\"sub-tx\">自動車用品事業</dt>\n\t\t\t\t<dd class=\"noto\">永大化工は、自動車メーカー純正フロアマットのリーディングカンパニーとして、国内外の大手メーカーにOEM商品を提供しています。さらに、オリジナルブランド『ENAS』を展開し、国内トップシェアを誇ります。<br>\n主力商品は、カーペットマットと耐水・防汚に優れたオールウェザーマットの2種類。長年の技術と品質で信頼を築き、近年はサステナブルなフロアマットの開発や製造過程でのCO2削減にも取り組んでいます。<br>\nこれからも革新的な製品で、モビリティ社会の発展に貢献してまいります。</dd>\n\t\t\t</dl>\n\t\t\t<dl>\n\t\t\t\t<dt class=\"sub-tx\">産業資材事業</dt>\n\t\t\t\t<dd class=\"noto\">永大化工の産業資材事業は、「下水道管路補修部材」や「半導体関連部材」、「住宅関連部材」、「鋼製家具部材」、「家電製品部材」、「工業用部材」の6分野を中心に展開しています。これらの製品は、国内の大手企業に広く採用され、社会のあらゆる場面で利用されています。<br>\n設立以来培った合成樹脂の「押出成形」技術を基盤に、高品質な部材を市場のニーズに応じて提供。ご家庭やオフィス、社会インフラまで、多様な用途で豊かな暮らしを支えています。これからも高度な技術力を活かし、暮らしと産業に貢献してまいります。</dd>\n\t\t\t</dl>\n\t\t</div>\n        <div class=\"btn-box\">\n                    <a href=\"https://recruit.eidaikako.co.jp/service#sec01\" class=\"btn arrow main en\"><span class=\"white-tx\">もっと見る</span></a>\n        </div>\n\t</div>\n</section>\n\n\n<section id=\"sec03\" class=\"about-area\">\n    <div class=\"container fadeUpTrigger fadeUp\">\n    <h2 class=\"align-c ttl\"><div class=\"en-ttl light-co\">Job</div><span class=\"\">仕事を知る</span></h2>\n        <div class=\"flex box\">\n            <div class=\"left\">\n            <img src=\"https://recruit.eidaikako.co.jp/wp/wp-content/themes/template/assets/images/top/top-service.webp\" alt=\"\">\n            </div>\n            <div class=\"right\">\n            <h3 class=\"sub-ttl\">モノづくりで社会を支える<br class=\"pc\">多様な仕事</h3>\n            <p>永大化工では、それぞれの職種が、培った技術や経験を活かして「モノづくり」の可能性を広げ、豊かな社会づくりに貢献しています。あなたも、自分らしく働ける環境で新しい挑戦を始めてみませんか？</p>\n                <div class=\"btn-box\">\n                    <a href=\"https://recruit.eidaikako.co.jp/service#sec02\" rel=\"noopener noreferrer\" class=\"btn arrow main en\"><span class=\"white-tx\">もっと見る</span></a>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>\n\n<section id=\"sec04\" class=\"cv-area1 cv-img p-top-wave\">\n    <div class=\"container\">\n    <h2 class=\"align-c ttl\"><div class=\"en-ttl light-co\">Balance</div><span class=\"white-tx\">働き方を知る</span></h2>\n        <p class=\"white\">永大化工では、社員一人ひとりが自分らしく働ける環境づくりを大切にしています。キャリア開発を支援する1on1ミーティングや充実した研修制度、心身の健康をサポートする取り組み、多彩な福利厚生制度、そして多様性を尊重する職場環境。これらを通じて、社員が安心して成長し続けられる職場を目指しています。</p>\n        <div class=\"btn-box\">\n            <a href=\"https://recruit.eidaikako.co.jp/balance/\" class=\"recruit-btn\">\n            <div class=\"recruit-btn-container\">\n                <span>もっと見る</span>\n                <div class=\"icon\">\n                <img src=\"https://recruit.eidaikako.co.jp/wp/wp-content/themes/template/assets/images/common/recruit-btn-icon.svg\" alt=\"Button icon.\">\n                 \n                </div>\n             \n                </div>\n            </a>\n        </div>\n    </div>\n</section>\n\n<section id=\"sec05\" class=\"swiper-area p-top-wave\">\n                    <div class=\"container p-btm0\">\n                      <div class=\"sectitle-box fadeInTrigger fadeIn\">\n                      <h2 class=\"align-c ttl\"><div class=\"en-ttl light-co\">Interview</div><span class=\"\">社員インタビュー</span></h2>\n                      </div>\n                    </div>\n                     <div class=\"swiper-container\" id = \"swiper-blog\">\n                        <div class=\"swiper-mask\" id = \"swiper-mask\"></div>\n                      <ul class=\"swiper-wrapper blog-list\">\n                                                                            <li class=\" swiper-slide fadeUpTrigger\">\n                                            <a href=\"https://recruit.eidaikako.co.jp/interview/interview04/\">\n                                                  <div class=\"img-box\">\n                                                                    <img width=\"2400\" height=\"1644\" src=\"https://recruit.eidaikako.co.jp/wp/wp-content/uploads/2023/11/01.webp\" class=\"attachment-post-thumbnail size-post-thumbnail wp-post-image\" alt=\"\" decoding=\"async\" fetchpriority=\"high\" srcset=\"https://recruit.eidaikako.co.jp/wp/wp-content/uploads/2023/11/01.webp 2400w, https://recruit.eidaikako.co.jp/wp/wp-content/uploads/2023/11/01-300x206.webp 300w, https://recruit.eidaikako.co.jp/wp/wp-content/uploads/2023/11/01-1024x701.webp 1024w, https://recruit.eidaikako.co.jp/wp/wp-content/uploads/2023/11/01-768x526.webp 768w, https://recruit.eidaikako.co.jp/wp/wp-content/uploads/2023/11/01-1536x1052.webp 1536w, https://recruit.eidaikako.co.jp/wp/wp-content/uploads/2023/11/01-2048x1403.webp 2048w\" sizes=\"(max-width: 2400px) 100vw, 2400px\" />                                                            </div>\n                            <div class=\"text-box\">\n                                <div class=\"meta flex f_wrap\">\n                                    <span class=\"date blue\">Interview 04</span>\n                                    <span class=\"cat blue\">自動車用品本部・生産準備担当</span>\n                                </div>\n                                <p>やりがいある“生産レシピ”作り。子育ても仕事も、楽しんでいます。</p>\n                            </div>\n                        </a>\n                    </li>\n                                                            <li class=\" swiper-slide fadeUpTrigger\">\n                                            <a href=\"https://recruit.eidaikako.co.jp/interview/interview03/\">\n                                                  <div class=\"img-box\">\n                                                                    <img width=\"2400\" height=\"1644\" src=\"https://recruit.eidaikako.co.jp/wp/wp-content/uploads/2024/09/01.jpg\" class=\"attachment-post-thumbnail size-post-thumbnail wp-post-image\" alt=\"\" decoding=\"async\" srcset=\"https://recruit.eidaikako.co.jp/wp/wp-content/uploads/2024/09/01.jpg 2400w, https://recruit.eidaikako.co.jp/wp/wp-content/uploads/2024/09/01-300x206.jpg 300w, https://recruit.eidaikako.co.jp/wp/wp-content/uploads/2024/09/01-1024x701.jpg 1024w, https://recruit.eidaikako.co.jp/wp/wp-content/uploads/2024/09/01-768x526.jpg 768w, https://recruit.eidaikako.co.jp/wp/wp-content/uploads/2024/09/01-1536x1052.jpg 1536w, https://recruit.eidaikako.co.jp/wp/wp-content/uploads/2024/09/01-2048x1403.jpg 2048w\" sizes=\"(max-width: 2400px) 100vw, 2400px\" />                                                            </div>\n                            <div class=\"text-box\">\n                                <div class=\"meta flex f_wrap\">\n                                    <span class=\"date blue\">Interview 03</span>\n                                    <span class=\"cat blue\">自動車用品本部・製品開発担当</span>\n                                </div>\n                                <p>“自由な社風”と自由な発想力で、自分が開発に関われる幸せがあります。</p>\n                            </div>\n                        </a>\n                    </li>\n                                                            <li class=\" swiper-slide fadeUpTrigger\">\n                                            <a href=\"https://recruit.eidaikako.co.jp/interview/interview02/\">\n                                                  <div class=\"img-box\">\n                                                                    <img width=\"2400\" height=\"1644\" src=\"https://recruit.eidaikako.co.jp/wp/wp-content/uploads/2024/10/01.jpg\" class=\"attachment-post-thumbnail size-post-thumbnail wp-post-image\" alt=\"\" decoding=\"async\" srcset=\"https://recruit.ei