{"url":"https://www.nttdata-ncb.co.jp/recruit/essentials/mid_career.php","html":"<!doctype html>\n<html lang=\"ja\">\n\n<head>\n\n    <!-- Google tag (gtag.js) -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-8WF1PH0GBZ\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'G-8WF1PH0GBZ');\n</script>\n\n<meta charset=\"utf-8\">\n<meta name=\"description\" content=\"NTTデータNCBは、NTTデータと西日本シティ銀行の持ちうるノウハウやIT技術力などを最大限に活かし、「お客様にとって、なくてはならないNTTデータNCB」をめざします。地域企業の発展拡大、ひいては地域の発展に大きく貢献いたします。\">\n<meta name=\"viewport\" content=\"width=device-width,user-scalable=no,maximum-scale=1\">\n<meta name=\"format-detection\" content=\"telephone=no\">\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=Edge,chrome=1\">\n\n<meta property=\"og:title\" content=\"株式会社NTTデータNCB\">\n<meta property=\"og:description\" content=\"NTTデータNCBは、NTTデータと西日本シティ銀行の持ちうるノウハウやIT技術力などを最大限に活かし、「お客様にとって、なくてはならないNTTデータNCB」をめざします。地域企業の発展拡大、ひいては地域の発展に大きく貢献いたします。\">\n<meta property=\"og:type\" content=\"website\">\n<meta property=\"og:url\" content=\"https://www.nttdata-ncb.co.jp/\">\n<meta property=\"og:site_name\" content=\"株式会社NTTデータNCB\">\n<meta property=\"og:image\" content=\"/assets/img/base/ogp.png\">\n\n<meta name=\"twitter:card\" content=\"summary_large_image\">\n<meta name=\"twitter:title\" content=\"株式会社NTTデータNCB\">\n<meta name=\"twitter:description\" content=\"NTTデータNCBは、NTTデータと西日本シティ銀行の持ちうるノウハウやIT技術力などを最大限に活かし、「お客様にとって、なくてはならないNTTデータNCB」をめざします。地域企業の発展拡大、ひいては地域の発展に大きく貢献いたします。\">\n<meta name=\"twitter:url\" content=\"https://www.nttdata-ncb.co.jp/\">\n<meta name=\"twitter:image\" content=\"/assets/img/base/ogp.png\">\n\n<link rel=\"shortcut icon\" href=\"/assets/img/base/favicon.ico\">\n<link rel=\"apple-touch-icon\" href=\"/assets/img/base/apple-touch-icon.png\">\n\n    <title>経験者募集要項 | 採用情報 | 株式会社NTTデータNCB</title>\n\n    <!-- <link href=\"https://fonts.googleapis.com/css?family=Lato:300,400,400i,700,700i,900\" rel=\"stylesheet\">\n<link href=\"https://fonts.googleapis.com/earlyaccess/notosansjapanese.css\" rel=\"stylesheet\"> -->\n\n<link href=\"/assets/css/style.css?20250212\" rel=\"stylesheet\">\n    \n\n</head>\n\n<body class=\"page-recruit\">\n\n\n    <header class=\"l-recruit-header\">\n  <div class=\"l-recruit-header-logo\">\n    <a href=\"/recruit/\" class=\"l-recruit-header-logo__link\">\n      <div class=\"l-recruit-header-logo__main\">\n        <img src=\"/assets/img/recruit/ntt-data-logo-white.png?20250616\" alt=\"NTT DATA\">\n      </div>\n      <div class=\"l-recruit-header-logo__sub\">\n        <img src=\"/assets/img/recruit/corplate-logo.png\" alt=\"株式会社NTTデータNCB\">\n      </div>\n    </a>\n  </div>\n\n\n  <!-- スマホメニューを開くボタン -->\n  <button class=\"fullScreenMenu-button\" type=\"button\" data-fullScreenMenu-trigger=\"js-fullScreenMenu-content\"\n    aria-label=\"メニューを開く\">\n    <span class=\"fullScreenMenu-button__line\"></span>\n    <span class=\"fullScreenMenu-button__line\"></span>\n    <span class=\"fullScreenMenu-button__line\"></span>\n  </button>\n</header><!-- /#globalHeader -->\n\n\n\n<!-- スマホメニュー本体 -->\n<div id=\"js-fullScreenMenu-content\" class=\"fullScreenMenu-content\">\n  <div class=\"fullScreenMenu-content__inner\">\n    <div class=\"l-header-fullScreenMenu\">\n      <ul class=\"l-header-fullScreenMenu__function\">\n        <li class=\"l-header-fullScreenMenu__function-item\">\n          <a href=\"/\" class=\"l-header-fullScreenMenu__function-item-link\">\n            <span>企業TOP</span>\n          </a>\n        </li>\n        <li class=\"l-header-fullScreenMenu__function-item\">\n          <a href=\"/recruit/\" class=\"l-header-fullScreenMenu__function-item-link\">\n            <span>採用TOP</span>\n          </a>\n        </li>\n        <li class=\"l-header-fullScreenMenu__function-item\">\n          <a href=\"/recruit/interview/\" class=\"l-header-fullScreenMenu__function-item-link\">\n            <span>仕事を知る</span>\n          </a>\n        </li>\n        <li class=\"l-header-fullScreenMenu__function-item\">\n          <a href=\"/recruit/system/\" class=\"l-header-fullScreenMenu__function-item-link\">\n            <span>福利厚生／教育</span>\n          </a>\n        </li>\n        <li class=\"l-header-fullScreenMenu__function-item\">\n          <a href=\"/recruit/system/education.php\" class=\"l-header-fullScreenMenu__function-item-link\">\n            <span>教育制度／文系出身者の声</span>\n          </a>\n        </li>\n        <li class=\"l-header-fullScreenMenu__function-item\">\n          <a href=\"/recruit/system/welfare.php\" class=\"l-header-fullScreenMenu__function-item-link\">\n            <span>福利厚生</span>\n          </a>\n        </li>\n        <li class=\"l-header-fullScreenMenu__function-item\">\n          <a href=\"/recruit/system/enviroment.php\" class=\"l-header-fullScreenMenu__function-item-link\">\n            <span>制度・環境</span>\n          </a>\n        </li>\n        <li class=\"l-header-fullScreenMenu__function-item\">\n          <a href=\"/recruit/keyword/\" class=\"l-header-fullScreenMenu__function-item-link\">\n            <span>キーワードで知る</span>\n          </a>\n        </li>\n        <li class=\"l-header-fullScreenMenu__function-item\">\n          <a href=\"/recruit/essentials/\" class=\"l-header-fullScreenMenu__function-item-link\">\n            <span>新卒募集要項</span>\n          </a>\n        </li>\n        <li class=\"l-header-fullScreenMenu__function-item\">\n          <a href=\"/recruit/essentials/mid_career.php\" class=\"l-header-fullScreenMenu__function-item-link\">\n            <span>経験者募集要項</span>\n          </a>\n        </li>\n      </ul>\n    </div>\n  </div>\n</div>\n    <div class=\"l-contents -col--1\">\n\n        <div class=\"l-contents-detail\">\n\n            <main class=\"l-main\">\n                <section class=\"p-recruit-hero-common\">\n                    <div class=\"p-recruit-hero-common__inner\">\n                        <div class=\"p-recruit-hero-common__left\">\n                            <h1 class=\"p-recruit-hero-common__title\">\n                                <span class=\"p-recruit-hero-common__title-main\">経験者募集要項</span>\n                            </h1>\n                        </div>\n                        <div class=\"p-recruit-hero-common__right\">\n                            <div class=\"p-recruit-hero-common__image\"><img src=\"/assets/img/recruit/essentials/hero.png\" alt=\"\"></div>\n                        </div>\n                    </div>\n                </section>\n\n\n                <div class=\"c-breadcrumb\">\n                    <div class=\"c-breadcrumb__inner\">\n                        <ul class=\"c-breadcrumb-list\">\n                            <li class=\"c-breadcrumb-list__item\"><a href=\"/recruit/\" class=\"\">ホーム</a></li>\n                            <li class=\"c-breadcrumb-list__item\">経験者募集要項</li>\n                        </ul>\n                    </div>\n                </div>\n\n\n                <section class=\"recruit-essentials-list\">\n                    <div class=\"l-contentsInner\">\n                        <ul class=\"recruit-essentials-list__ul\">\n                            <li class=\"recruit-essentials-list__li\">\n                                <p class=\"recruit-essentials-list-head\">\n                                    募集職種\n                                </p>\n                                <p class=\"recruit-essentials-list-body\">\n                                    システムエンジニア\n                                </p>\n                            </li>\n                            <li class=\"recruit-essentials-list__li\">\n                                <p class=\"recruit-essentials-list-head\">\n                                    職務内容\n                                </p>\n                                <p class=\"recruit-essentials-list-body\">\n                                    金融分野における新規サービス、または既存更改のシステム開発、維持運用業務\n                                </p>\n                            </li>\n                            <li class=\"recruit-essentials-list__li\">\n                                <p class=\"recruit-essentials-list-head\">\n                                    条件\n                                </p>\n                                <p class=\"recruit-essentials-list-body\">\n                                    システム開発に関わる経験\n                                </p>\n                            </li>\n                            <li class=\"recruit-essentials-list__li\">\n                                <p class=\"recruit-essentials-list-head\">\n                                    給与\n                                </p>\n                                <p class=\"recruit-essentials-list-body\">\n                                    当社規定による（経験・能力等を考慮の上、決定）\n                                </p>\n                            </li>\n                            <li class=\"recruit-essentials-list__li\">\n                                <p class=\"recruit-essentials-list-head\">\n                                    諸手当\n                                </p>\n                                <p class=\"recruit-essentials-list-body\">\n                                    通勤手当（原則全額支給）、時間外手当、扶養手当、住宅手当、リモートワーク手当<br>\n                                    緊急対応手当、慶弔見舞金、単身赴任手当、地域加算手当（首都圏勤務）<br>\n                                    <small>※各種手当については、支給条件等があります。</small>\n                                </p>\n                            </li>\n                            <li class=\"recruit-essentials-list__li\">\n                                <p class=\"recruit-essentials-list-head\">\n                                    昇給\n                                </p>\n                                <p class=\"recruit-essentials-list-body\">\n                                    年1回\n                                </p>\n                            </li>\n                            <li class=\"recruit-essentials-list__li\">\n                                <p class=\"recruit-essentials-list-head\">\n                                    賞与\n                                </p>\n                                <p class=\"recruit-essentials-list-body\">\n                                    年2回（6月、12月）\n                                </p>\n                            </li>\n                            <li class=\"recruit-essentials-list__li\">\n                                <p class=\"recruit-essentials-list-head\">\n                                    休日・休暇\n                                </p>\n                                <p class=\"recruit-essentials-list-body\">\n                                    完全週休2日制、祝日、年末年始<br>\n                                    年次有給休暇、特別連続休暇、特別有給休暇、産前産後休暇、育児休業、生理休暇、看護休暇、介護休暇、長期療養休暇\n                                </p>\n                            </li>\n                            <li class=\"recruit-essentials-list__li\">\n                                <p class=\"recruit-essentials-list-head\">\n                                    各種社会保険\n                                </p>\n                                <p class=\"recruit-essentials-list-body\">\n                                    健康保険、厚生年金、雇用保険、労災保険\n                                </p>\n                            </li>\n                            <li class=\"recruit-essentials-list__li\">\n                                <p class=\"recruit-essentials-list-head\">\n                                    勤務地\n                                </p>\n                                <p class=\"recruit-essentials-list-body\">\n                                    福岡市中心（プロジェクトにより他県での勤務あり）\n                                </p>\n                            </li>\n                            <li class=\"recruit-essentials-list__li\">\n                                <p class=\"recruit-essentials-list-head\">\n                                    勤務時間\n                                </p>\n                                <p class=\"recruit-essentials-list-body\">\n                                    8：30～17：30（時差出勤あり）\n                                </p>\n                            </li>\n                            <li class=\"recruit-essentials-list__li\">\n                                <p class=\"recruit-essentials-list-head\">\n                                    提出書類\n                                </p>\n                                <p class=\"recruit-essentials-list-body\">\n                                    履歴書、職務経歴書\n                                </p>\n                            </li>\n                        </ul>\n                        <!-- <h3 class=\"c-commonHero__h3\">\n              <span>採用に関するお問い合わせ（採用担当）</span>\n            </h3> -->\n                        <!-- <div class=\"recruit-essentials-list__contact is-no-border\">\n                            <a href=\"mailto:&#115;&#97;&#105;&#121;&#111;u@&#110;&#116;&#116;da&#116;a&#45;&#110;cb&#46;co.&#106;p\" class=\"recruit-essentials-list__contactInner\">\n                                <span class=\"-wrapper\">\n                                    <span class=\"-sub\">Mail</span>\n                                    <span class=\"-main\">saiyou@nttdata-ncb.co.jp</span>\n                                </span>\n                            </a>\n                        </div> -->\n                    </div>\n                </section>\n\n\n                <section class=\"recruit-essentials-flow\">\n                    <div class=\"l-contentsInner\">\n                        <h2 class=\"p-recruit-about__h2\">選考の流れ</h2>\n                        <div class=\"recruit-essentials-flow-process\">\n                            <div class=\"recruit-essentials-flow-process-item\">\n                                <p class=\"-head\">応募</p>\n                                <p class=\"-body\">以下「応募について」の流れに沿って応募してください。</p>\n                            </div>\n                            <div class=\"recruit-essentials-flow-process-item\">\n                                <p class=\"-head\">書類選考</p>\n                                <p class=\"-body\">履歴書、職務経歴書での書類選考を行います。</p>\n                            </div>\n                            <div class=\"recruit-essentials-flow-process-item\">\n                                <p class=\"-head\">面接および適性試験</p>\n                                <p class=\"-body\">面接は1～2回実施します。適性試験はweb受験です。</p>\n                            </div>\n                            <!-- <div class=\"recruit-essentials-flow-process-item\">\n                                <p class=\"-head\">一次面接</p>\n                            </div> -->\n                            <div class=\"recruit-essentials-flow-process-item\">\n                                <p class=\"-head\">内々定</p>\n                            </div>\n                        </div>\n                    </div>\n                </section>\n\n\n                <!-- <section class=\"recruit-essentials-faq\">\n                    <div class=\"l-contentsInner\">\n                        <h2 class=\"p-recruit-about__h2\">Q&A</h2>\n                        <div class=\"recruit-essentials-faq__wrapper\">\n                            <div class=\"recruit-essentials-faq__category\">\n                                <div class=\"recruit-essentials-faq__unit\">\n                                    <div class=\"recruit-essentials-faq__unit-item\">\n                                        <div class=\"recruit-essentials-faq__unit-item-question\">\n                                            <p class=\"-head\">Q</p>\n                                            <p class=\"-body\">会社説明会への参加が受験条件になりますか？</p>\n                                        </div>\n                                        <div class=\"recruit-essentials-faq__unit-item-answer\">\n                                            <p class=\"-head\">A</p>\n                                            <p class=\"-body\">参加は必須ではございません。ただ、当社の雰囲気なども感じていただけますし、実際に働く若手社員とコミュニケーションを取れる機会となりますので、是非、会社説明会へご参加ください。</p>\n                                        </div>\n                                    </div>\n                                    <div class=\"recruit-essentials-faq__unit-item\">\n                                        <div class=\"recruit-essentials-faq__unit-item-question\">\n                                            <p class=\"-head\">Q</p>\n                                            <p class=\"-body\">応募の際や入社までに取得すべき資格はありますか？</p>\n                                        </div>\n                                        <div class=\"recruit-essentials-faq__unit-item-answer\">\n                                            <p class=\"-head\">A</p>\n                                            <p class=\"-body\">基本的には、入社後、会社の研修制度を利用して取得頂ければ良いですが、内定後から通信教育などで会社のフォロー体制があり、入社前に基本情報技術者試験に挑戦することも可能です。</p>\n                                        </div>\n                                    </div>\n                                    <div class=\"recruit-essentials-faq__unit-item\">\n                                        <div class=\"recruit-essentials-faq__unit-item-question\">\n                                            <p class=\"-head\">Q</p>\n                                            <p class=\"-body\">配属先や業務の希望を伝えることはできますか？</p>\n                                        </div>\n                                        <div class=\"recruit-essentials-faq__unit-item-answer\">\n                                            <p class=\"-head\">A</p>\n                                            <p class=\"-body\">配属先や業務の希望がある方は人事担当へぜひ伝えてください。そのうえで、皆さんに活躍していただく配属先を検討し、最終的に会社が決定いたします。</p>\n                                        </div>\n                                    </div>\n                                    <div class=\"recruit-essentials-faq__unit-item\">\n                                        <div class=\"recruit-essentials-faq__unit-item-question\">\n                                            <p class=\"-head\">Q</p>\n                                            <p class=\"-body\">転勤はありますか。</p>\n                                        </div>\n                                        <div class=\"recruit-essentials-faq__unit-item-answer\">\n                                            <p class=\"-head\">A</p>\n                                            <p class=\"-body\">主な勤務先は福岡市となります。配属によっては、グループ会社の大きな案件に挑戦できる機会があり、数年間の首都圏勤務の可能性もあります。</p>\n                                        </div>\n                                    </div>\n                                    <div class=\"recruit-essentials-faq__unit-item\">\n                                        <div class=\"recruit-essentials-faq__unit-item-question\">\n                                            <p class=\"-head\">Q</p>\n                                            <p class=\"-body\">休日・休暇や福利厚生について教えてください。</p>\n                                        </div>\n                                        <div class=\"recruit-essentials-faq__unit-item-answer\">\n                                            <p class=\"-head\">A</p>\n                                            <p class=\"-body\">土日祝日が休日の、完全週休二日制に加え、年末年始休暇があり、福利厚生として財形貯蓄・退職金・企業年金・慶弔見舞金などもあります。その他、国内宿泊施設利用や映画鑑賞など様々な場面で、お得に利用できるサービスに加入しており、こちらは、内定者の皆さんも利用できる制度となっています。</p>\n                                        </div>\n                                    </div>\n                                    <div class=\"recruit-essentials-faq__unit-item\">\n                                        <div class=\"recruit-essentials-faq__unit-item-question\">\n                                            <p class=\"-head\">Q</p>\n                                            <p class=\"-body\">研修制度について教えてください。</p>\n                                        </div>\n                                        <div class=\"recruit-essentials-faq__unit-item-answer\">\n                                            <p class=\"-head\">A</p>\n                                            <p class=\"-body\">資格取得のための通信教育をはじめ、役職等に応じたスキルアップ、技術力を高めるテクニカル分野の研修について、実績のあるＮＴＴデータグループの制度を利用できます。これから必須の知識となるDX関連の研修も現在推進中です。新入社員研修では、ＮＴＴデータグループ各社の新入社員が参加するため、横のつながりができるなど良い経験ができます。</p>\n                                        </div>\n                                    </div>\n                                    <div class=\"recruit-essentials-faq__unit-item\">\n                                        <div class=\"recruit-essentials-faq__unit-item-question\">\n                                            <p class=\"-head\">Q</p>\n                                            <p class=\"-body\">文系なので、入社後ついていけるか不安です。</p>\n                                        </div>\n                                        <div class=\"recruit-essentials-faq__unit-item-answer\">\n                                            <p class=\"-head\">A</p>\n                                            <p class=\"-body\">文系出身は、割合からすると少ないですが、活躍している先輩社員がたくさんいます。テクニカルな知識が必要な場面もありますが、先輩社員がフォローしてくれたり、研修受講で、必要な知識を習得していけば問題ありません。仕事の中では、人とのコミュニケーションも重要ですが、むしろ得意な方が多いかもしれません。会社の教育制度や先輩社員が、皆さんをフォローしていきますので、安心してください。</p>\n                                        </div>\n                                    </div>\n                                </div>\n                            </div>\n                            <div class=\"recruit-essentials-faq__category\">\n                                <h3 class=\"c-commonHero__h3\">\n                                    <span>〇〇について</span>\n                                </h3>\n                                <div class=\"recruit-essentials-faq__unit\">\n                                    <div class=\"recruit-essentials-faq__unit-item\">\n                                        <div class=\"recruit-essentials-faq__unit-item-question\">\n                                            <p class=\"-head\">Q</p>\n                                            <p class=\"-body\">タイトルが入ります。</p>\n                                        </div>\n                                        <div class=\"recruit-essentials-faq__unit-item-answer\">\n                                            <p class=\"-head\">A</p>\n                                            <p class=\"-body\">回答が入ります。回答が入ります。回答が入ります。回答が入ります。回答が入ります。回答が入ります。回答が入ります。</p>\n                                        </div>\n                                    </div>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                </section> -->\n\n                <section class=\"recruit-essentials-application-method\">\n                    <div class=\"c-linkBox -gray l-contentsInner\">\n                        <h4 class=\"c-linkBox-title\"><span>応募について</span></h4>\n                        <p class=\"c-catchText\">詳しい応募方法については、個別にご案内しますので、<br class=\"sp-break\">以下の通りメールでお問い合わせください。</p>\n                        <ul class=\"recruit-essentials-list__ul\">\n                            <li class=\"recruit-essentials-list__li\">\n                                <p class=\"recruit-essentials-list-head\">\n                                    宛先\n                                </p>\n                                <p class=\"recruit-essentials-list-body\"><a href=\"mailto:saiyou@nttdata-ncb.co.jp\" target=\"_blank\">saiyou@nttdata-ncb.co.jp</a>\n                                </p>\n                            </li>\n                            <li class=\"recruit-essentials-list__li\">\n                                <p class=\"recruit-essentials-list-head\">\n                                    件名\n                                </p>\n                                <p class=\"recruit-essentials-list-body\">\n                                    【経験者採用応募】yyyy/mm/dd（メール送信日）　 〇〇　〇〇（氏名）\n                                </p>\n                            </li>\n                            <li class=\"recruit-essentials-list__li\">\n                                <p class=\"recruit-essentials-list-head\">\n                                    本文に記載いただく内容\n                                </p>\n                                <p class=\"recruit-essentials-list-body\">\n                                    ご連絡先（氏名、電話番号、メールアドレス）\n                                </p>\n                            </li>\n                        </ul>\n                    </div>\n                </section>\n\n\n            </main><!-- l-main -->\n\n        </div><!-- /l-contents-detail -->\n\n    </div><!-- /l-contents -->\n\n\n    <footer class=\"l-recruit-footer\">\n        <div class=\"l-recruit-footer-jump\">\n            <div class=\"l-recruit-footer-jump__inner --single\">\n                <div class=\"l-recruit-footer-jump-item -document -recruit\">\n                    <a href=\"/recruit/essentials/\" class=\"l-recruit-footer-jump-item__link\">\n                        <span class=\"-text\">新卒募集要項は<br>こちら</span>\n                        <span class=\"-icon\"></span>\n                    </a>\n                </div>\n            </div>\n        </div>\n        <p class=\"l-recruit-footer-copyright\">Copyright &copy; NTT DATA NCB Corporation</p>\n    </footer>\n    <div class=\"c-scrollPageTop\">\n        <a href=\"#\" data-scroll=\"\"></a>\n    </div>\n\n    <script src=\"/assets/js/vendor.js?20241213\"></script>\n<script src=\"/assets/js/main.js?20241213\"></script>\n\n</body>\n\n</html>","finalUrl":"https://www.nttdata-ncb.co.jp/recruit/essentials/mid_career.php","rendered":false,"_cachedAt":"2026-06-22T20:33:15.474Z"}