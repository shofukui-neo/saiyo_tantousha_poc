{"url":"https://map.jp/support/contactform/order/index.php","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>オーダーマップ お問い合わせフォーム</title>\n<link rel=\"icon\" type=\"image/x-icon\" href=\"../favicon.ico\">\n<link rel=\"stylesheet\" href=\"../css/style.css\">\n<style>\n:root {\n    --theme-color: #254999;\n    --base-color:  #DCE4F5;\n}\n</style>\n</head>\n<body>\n\n<div class=\"page-wrapper\">\n    <div class=\"form-header\">\n        <div class=\"product-title\">オーダーマップ</div>\n    </div>\n\n    <div class=\"form-container\">\n        <p class=\"form-intro\">\n            必要事項をご入力の上、送信してください。担当者よりご連絡いたします。\n        </p>\n\n        \n        <form method=\"post\" action=\"index.php\" novalidate>\n            <input type=\"hidden\" name=\"csrf_token\" value=\"7673eb19d217a66f74fe4e187c0d3b34\">\n\n            <!-- お名前 -->\n            <div class=\"form-group\">\n                <label class=\"field-label\" for=\"name\">お名前 <span class=\"required-mark\">必須</span></label>\n                <input type=\"text\" id=\"name\" name=\"name\"\n                       value=\"\"\n                       maxlength=\"100\" autocomplete=\"name\"\n                       class=\"\">\n                \n                <label class=\"field-label\" for=\"furigana\" style=\"margin-top:10px;\">ふりがな <span class=\"required-mark\">必須</span></label>\n                <input type=\"text\" id=\"furigana\" name=\"furigana\"\n                       value=\"\"\n                       maxlength=\"100\" placeholder=\"やまだ たろう\"\n                       class=\"\">\n                            </div>\n\n            <!-- 電話番号 -->\n            <div class=\"form-group\">\n                <label class=\"field-label\" for=\"phone\">電話番号 <span class=\"required-mark\">必須</span></label>\n                <input type=\"tel\" id=\"phone\" name=\"phone\"\n                       value=\"\"\n                       placeholder=\"000-000-0000\" maxlength=\"15\" autocomplete=\"tel\"\n                       class=\"\">\n                            </div>\n\n            <!-- 返信先メール -->\n            <div class=\"form-group\">\n                <label class=\"field-label\" for=\"email\">返信先メールアドレス <span class=\"required-mark\">必須</span></label>\n                <p class=\"field-note\">半角でご入力ください</p>\n                <input type=\"email\" id=\"email\" name=\"email\"\n                       value=\"\"\n                       maxlength=\"200\" autocomplete=\"email\"\n                       class=\"\">\n                \n                <label class=\"field-label\" for=\"email_confirm\" style=\"margin-top:10px;\">返信先メールアドレス（確認） <span class=\"required-mark\">必須</span></label>\n                <input type=\"email\" id=\"email_confirm\" name=\"email_confirm\"\n                       value=\"\"\n                       maxlength=\"200\" autocomplete=\"email\" placeholder=\"もう一度入力してください\"\n                       class=\"\">\n                            </div>\n\n            <!-- 法人名 -->\n            <div class=\"form-group\">\n                <label class=\"field-label\" for=\"company_name\">法人名（個人利用の場合は入力不要）</label>\n                <input type=\"text\" id=\"company_name\" name=\"company_name\"\n                       value=\"\"\n                       maxlength=\"100\" autocomplete=\"organization\">\n            </div>\n\n            <!-- 住所 -->\n            <div class=\"form-group\">\n                <label class=\"field-label\">住所（任意）</label>\n                <div class=\"address-row\" style=\"margin-bottom:6px;\">\n                    <span class=\"postal-mark\">〒</span>\n                    <input type=\"text\" id=\"postal_code\" name=\"postal_code\"\n                           value=\"\"\n                           placeholder=\"000-0000\" maxlength=\"8\" style=\"width:120px;\">\n                    <span style=\"font-size:12px;color:#888;margin-left:6px;\">入力すると住所が自動入力されます</span>\n                </div>\n                <input type=\"text\" id=\"address\" name=\"address\"\n                       value=\"\"\n                       placeholder=\"例）都道府県・市区町村・丁目番地・建物名等\" maxlength=\"300\"\n                       style=\"margin-top:0;\">\n            </div>\n\n            <!-- FAX番号 -->\n            <div class=\"form-group\">\n                <label class=\"field-label\" for=\"fax\">FAX番号（任意）</label>\n                <input type=\"text\" id=\"fax\" name=\"fax\"\n                       value=\"\"\n                       placeholder=\"000-000-0000\" maxlength=\"15\">\n            </div>\n\n            <!-- 作成したい地図 -->\n            <div class=\"form-group\">\n                <label class=\"field-label\" for=\"map_type\">作成したい地図 <span class=\"required-mark\">必須</span></label>\n                <select id=\"map_type\" name=\"map_type\"\n                        class=\"\">\n                    <option value=\"\">-- 選択してください --</option>\n                                        <option value=\"小学校安全マップ\" >小学校安全マップ</option>\n                                        <option value=\"小学校通学路図\" >小学校通学路図</option>\n                                        <option value=\"校区防災マップ\" >校区防災マップ</option>\n                                        <option value=\"町会地図\" >町会地図</option>\n                                        <option value=\"その他地図\" >その他地図</option>\n                                    </select>\n                            </div>\n\n            <!-- 作成したい地域 -->\n            <div class=\"form-group\">\n                <label class=\"field-label\" for=\"region\">作成したい地域（任意）</label>\n                <input type=\"text\" id=\"region\" name=\"region\"\n                       value=\"\"\n                       placeholder=\"例）石川県金沢市\" maxlength=\"200\">\n            </div>\n\n            <!-- 連絡手段 -->\n            <div class=\"form-group\">\n                <label class=\"field-label\">ご希望の連絡手段 <span class=\"required-mark\">必須</span></label>\n                <p class=\"field-note\">弊社営業時間内の対応となります</p>\n                <div class=\"radio-group\">\n                    <label class=\"radio-label\">\n                        <input type=\"radio\" name=\"contact_method\" value=\"電話\"\n                               >\n                        電話\n                    </label>\n                    <label class=\"radio-label\">\n                        <input type=\"radio\" name=\"contact_method\" value=\"メール\"\n                               >\n                        メール\n                    </label>\n                </div>\n                            </div>\n\n            <!-- その他 -->\n            <div class=\"form-group\">\n                <label class=\"field-label\" for=\"other_notes\">その他（任意）</label>\n                <textarea id=\"other_notes\" name=\"other_notes\"\n                          placeholder=\"ご要望・ご質問等があればご記入ください\"></textarea>\n            </div>\n\n            <hr class=\"section-divider\">\n\n            <div class=\"privacy-box\">\n                <h3>お問い合わせに関する個人情報の取り扱い</h3>\n                <p>ご登録いただいた情報は、当社の<a href=\"https://map.jp/index/privacypolicy.html\" target=\"_blank\">プライバシーポリシー</a>に従い適正に管理しています。</p>\n                <p>ご登録いただいた情報は、お客様からのお問い合わせやご依頼内容に的確に対応することを目的に限定して利用します。</p>\n                <p>これ以外の目的で利用したり、第三者に提供もしくは預託することはありません。</p>\n                <label class=\"privacy-agree-label\">\n                    <input type=\"checkbox\" name=\"privacy_agree\" value=\"1\"\n                           >\n                    個人情報の取り扱いに同意する\n                    <span class=\"required-mark\">必須</span>\n                </label>\n                            </div>\n\n            <div class=\"red-notes\">\n                <p>※お問い合わせいただいたメールの返信は当社営業時間内となります。ご了承ください。</p>\n                <p>※返信メールアドレスに送信できない場合や、問い合わせの内容によってお電話させていただく場合がございます。</p>\n            </div>\n\n            <!-- ハニーポット：ボット対策（人間には見えません） -->\n            <div style=\"display:none !important; position:absolute; left:-9999px;\" aria-hidden=\"true\">\n                <input type=\"text\" name=\"website\" tabindex=\"-1\" autocomplete=\"off\">\n            </div>\n            <button type=\"submit\" class=\"btn-submit\">確認画面へ</button>\n        </form>\n    </div>\n</div>\n\n<script>\n\nvar PREFS = ['','北海道','青森県','岩手県','宮城県','秋田県','山形県','福島県','茨城県','栃木県','群馬県','埼玉県','千葉県','東京都','神奈川県','新潟県','富山県','石川県','福井県','山梨県','長野県','岐阜県','静岡県','愛知県','三重県','滋賀県','京都府','大阪府','兵庫県','奈良県','和歌山県','鳥取県','島根県','岡山県','広島県','山口県','徳島県','香川県','愛媛県','高知県','福岡県','佐賀県','長崎県','熊本県','大分県','宮崎県','鹿児島県','沖縄県'];\nfunction autoFillFromZip(code, addressField) {\n    var s = document.getElementById('_zs');\n    if (s) s.parentNode.removeChild(s);\n    window.$yubin = function(d) {\n        var v = d[code];\n        if (v) {\n            var pref = (typeof v[0] === 'number') ? (PREFS[v[0]] || '') : (v[0] || '');\n            addressField.value = pref + (v[1]||'') + (v[2]||'');\n        }\n    };\n    s = document.createElement('script');\n    s.id = '_zs';\n    s.src = 'https://yubinbango.github.io/yubinbango-data/data/' + code.substring(0,3) + '.js';\n    document.head.appendChild(s);\n}\nvar postalInput = document.getElementById('postal_code');\nvar addressInput = document.getElementById('address');\nif (postalInput && addressInput) {\n    postalInput.onblur = function() {\n        var raw = this.value.replace(/[^0-9]/g, '');\n        if (raw.length > 3) this.value = raw.substring(0,3) + '-' + raw.substring(3,7);\n        else this.value = raw;\n        if (raw.length === 7) autoFillFromZip(raw, addressInput);\n    };\n    postalInput.onkeyup = function() {\n        var raw = this.value.replace(/[^0-9]/g, '');\n        if (raw.length === 7) autoFillFromZip(raw, addressInput);\n    };\n}\n</script>\n\n<p class=\"site-copyright\">&copy; 2026 KANKOSHA Co., Ltd.</p>\n</body>\n</html>\n","finalUrl":"https://map.jp/support/contactform/order/index.php","rendered":false,"_cachedAt":"2026-06-23T20:42:49.722Z"}