tro_title_icon\" loading=\"lazy\" src=\"../../assets/img/recruit/part-time-staff/icon_smile.svg\" alt=\"\" width=\"58\" height=\"58\">\n\t\t\t\t\t<span class=\"pg_intro_title_text\">\n\t\t\t\t\t\t店舗PRスタッフ<br>\n\t\t\t\t\t\t<span class=\"size_s\">（パート）</span>\n\t\t\t\t\t</span>\n\t\t\t\t</h2>\n\t\t\t\t<p class=\"pg_intro_text\">\n\t\t\t\t\tスーパーマーケットでのヤクルト商品のご紹介、試飲販売が主なお仕事です。ご来店されたお客様にヤクルトの商品価値をお伝えし、健康情報をお届けします。\n\t\t\t\t</p>\n\t\t\t</div>\n\t\t\t<figure class=\"pg_intro_img\">\n\t\t\t\t<img src=\"../../assets/img/recruit/part-time-staff/pr_img.jpg\" alt=\"\" width=\"600\" height=\"400\">\n\t\t\t</figure>\n\t\t<!-- //pg_intro --></div>\n\n\t\t<section id=\"charm\" class=\"pg_charm\">\n\t\t\t<div class=\"pg_header\">\n\t\t\t\t<h3 class=\"pg_header_title\">お仕事の魅力</h3>\n\t\t\t</div>\n\t\t\t<ul class=\"pg_charm_lists md_view\">\n\t\t\t\t<li>\n\t\t\t\t\t<span class=\"pg_charm_img\">\n\t\t\t\t\t\t<picture>\n\t\t\t\t\t\t\t<source media=\"(min-width:769px)\" srcset=\"../../assets/img/recruit/part-time-staff/charm_img_01_pc.png\" width=\"196\" height=\"89\">\n\t\t\t\t\t\t\t<img loading=\"lazy\" src=\"../../assets/img/recruit/part-time-staff/charm_img_01_sp.png\" alt=\"家事両立\" width=\"102\" height=\"46\">\n\t\t\t\t\t\t</picture>\n\t\t\t\t\t</span>\n\t\t\t\t\t<span class=\"pg_charm_detail\">\n\t\t\t\t\t\t10〜17時の間に勤<br class=\"sp_br\">務<br class=\"pc_br\">（短時間・週1〜<br class=\"sp_br\">OK！）\n\t\t\t\t\t</span>\n\t\t\t\t</li>\n\t\t\t\t<li>\n\t\t\t\t\t<span class=\"pg_charm_img\">\n\t\t\t\t\t\t<picture>\n\t\t\t\t\t\t\t<source media=\"(min-width:769px)\" srcset=\"../../assets/img/recruit/part-time-staff/charm_img_02_pc.png\" width=\"196\" height=\"89\">\n\t\t\t\t\t\t\t<img loading=\"lazy\" src=\"../../assets/img/recruit/part-time-staff/charm_img_02_sp.png\" alt=\"NO!ノルマ\" width=\"102\" height=\"46\">\n\t\t\t\t\t\t</picture>\n\t\t\t\t\t</span>\n\t\t\t\t\t<span class=\"pg_charm_detail\">\n\t\t\t\t\t\t販売ノルマ・買い<br class=\"sp_br\">取り<br class=\"pc_br\">一切なし！\n\t\t\t\t\t</span>\n\t\t\t\t</li>\n\t\t\t\t<li>\n\t\t\t\t\t<span class=\"pg_charm_img\">\n\t\t\t\t\t\t<picture>\n\t\t\t\t\t\t\t<source media=\"(min-width:769px)\" srcset=\"../../assets/img/recruit/part-time-staff/charm_img_03_pc.png\" width=\"196\" height=\"89\">\n\t\t\t\t\t\t\t<img loading=\"lazy\" src=\"../../assets/img/recruit/part-time-staff/charm_img_03_sp.png\" alt=\"自宅近く\" width=\"102\" height=\"46\">\n\t\t\t\t\t\t</picture>\n\t\t\t\t\t</span>\n\t\t\t\t\t<span class=\"pg_charm_detail\">\n\t\t\t\t\t\t勤務地は<br class=\"pc_br\">ご自宅近<br class=\"sp_br\">くのスーパー！\n\t\t\t\t\t</span>\n\t\t\t\t</li>\n\t\t\t\t<li>\n\t\t\t\t\t<span class=\"pg_charm_img\">\n\t\t\t\t\t\t<picture>\n\t\t\t\t\t\t\t<source media=\"(min-width:769px)\" srcset=\"../../assets/img/recruit/part-time-staff/charm_img_04_pc.png\" width=\"196\" height=\"89\">\n\t\t\t\t\t\t\t<img loading=\"lazy\" src=\"../../assets/img/recruit/part-time-staff/charm_img_04_sp.png\" alt=\"WワークOK!\" width=\"102\" height=\"46\">\n\t\t\t\t\t\t</picture>\n\t\t\t\t\t</span>\n\t\t\t\t\t<span class=\"pg_charm_detail\">\n\t\t\t\t\t\t仕事の掛け持ちも<br>問題なし！\n\t\t\t\t\t</span>\n\t\t\t\t</li>\n\t\t\t</ul>\n\t\t<!-- //pg_charm --></section>\n\n\t\t<div class=\"pg_movie\">\n\t\t\t<div class=\"pg_movie_youtube\">\n\t\t\t\t<iframe width=\"888\" height=\"500\" src=\"https://www.youtube.com/embed/dZUpHSWAlaU?si=p2MBgAUJYphYelMX\" title=\"YouTube video player\" frameborder=\"0\" allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share\" referrerpolicy=\"strict-origin-when-cross-origin\" allowfullscreen></iframe>\n\t\t\t</div>\n\t\t</div>\n\n\t\t<section id=\"staff\" class=\"pg_staff\">\n\t\t\t<div class=\"pg_header\">\n\t\t\t\t<h3 class=\"pg_header_title\">先輩スタッフの声</h3>\n\t\t\t</div>\n\t\t\t<div class=\"pg_staff_column md_view\">\n\t\t\t\t<section class=\"pg_staff_item\">\n\t\t\t\t\t<h4 class=\"pg_staff_item_title\">\n\t\t\t\t\t\t<img loading=\"lazy\" src=\"../../assets/img/recruit/part-time-staff/staff_icon_01.png\" alt=\"\" width=\"92\" height=\"90\">\n\t\t\t\t\t\t<span>30代<br>スタッフ歴1年</span>\n\t\t\t\t\t</h4>\n\t\t\t\t\t<p class=\"pg_staff_item_text\">\n\t\t\t\t\t\t研修でヤクルト商品や健康知識について勉強していくことで、家族がより健康になれたと感じています。10時からのお仕事なので、子供の登校後に家事ができるのも嬉しいポイント♪\n\t\t\t\t\t</p>\n\t\t\t\t</section>\n\t\t\t\t<section class=\"pg_staff_item\">\n\t\t\t\t\t<h4 class=\"pg_staff_item_title\">\n\t\t\t\t\t\t<img loading=\"lazy\" src=\"../../assets/img/recruit/part-time-staff/staff_icon_02.png\" alt=\"\" width=\"92\" height=\"90\">\n\t\t\t\t\t\t<span>40代<br>スタッフ歴3年</span>\n\t\t\t\t\t</h4>\n\t\t\t\t\t<p class=\"pg_staff_item_text\">\n\t\t\t\t\t\t平日メインや短時間勤務もOKなので、子育て中のママにピッタリだと思います。帰りに買い物ができるので、時間を有効に使えます！\n\t\t\t\t\t</p>\n\t\t\t\t</section>\n\t\t\t\t<section class=\"pg_staff_item\">\n\t\t\t\t\t<h4 class=\"pg_staff_item_title\">\n\t\t\t\t\t\t<img loading=\"lazy\" src=\"../../assets/img/recruit/part-time-staff/staff_icon_03.png\" alt=\"\" width=\"92\" height=\"90\">\n\t\t\t\t\t\t<span>50代<br>スタッフ歴8年</span>\n\t\t\t\t\t</h4>\n\t\t\t\t\t<p class=\"pg_staff_item_text\">\n\t\t\t\t\t\t年齢関係なくいろんな方と出会え、お話を聞いたり教えていただいたり勇気をもらったり、元気が出ます。お客様との会話は自分にとってもプラスになっています。\n\t\t\t\t\t</p>\n\t\t\t\t</section>\n\t\t\t<!-- //pg_staff_column --></div>\n\t\t<!-- //pg_staff --></section>\n\t\t\n\t\t<section class=\"pg_recruitment\">\n\t\t\t<div class=\"pg_header\">\n\t\t\t\t<h3 class=\"pg_header_title\">募集要項</h3>\n\t\t\t</div>\n\t\t\t<div class=\"pg_recruitment_item\">\n\t\t\t\t<dl class=\"pg_recruitment_dl\">\n\t\t\t\t\t<div class=\"pg_recruitment_dl_shelf\">\n\t\t\t\t\t\t<dt class=\"pg_recruitment_dt\">\n\t\t\t\t\t\t\t職種\n\t\t\t\t\t\t</dt>\n\t\t\t\t\t\t<dd class=\"pg_recruitment_dd\">\n\t\t\t\t\t\t\t店舗PRスタッフ（パート）\n\t\t\t\t\t\t</dd>\n\t\t\t\t\t</div>\n\t\t\t\t\t<div class=\"pg_recruitment_dl_shelf\">\n\t\t\t\t\t\t<dt class=\"pg_recruitment_dt\">\n\t\t\t\t\t\t\t収入\n\t\t\t\t\t\t</dt>\n\t\t\t\t\t\t<dd class=\"pg_recruitment_dd\">\n\t\t\t\t\t\t\t平日：時給1,200円<br>\n\t\t\t\t\t\t\t土日：時給1,400円（1日6時間以上できる場合）\n\t\t\t\t\t\t</dd>\n\t\t\t\t\t</div>\n\t\t\t\t\t