   <div class=\"search__close\"><span></span></div>\n          </div>\n          <a href=\"/form/\" class=\"link__contact\"></a>\n          <a class=\"link__recruit\" href=\"/entry/company/\">RECRUIT</a>\n          <!--<div class=\"link__language\">\n            <a href=\"\">JP</a><span>｜</span><a href=\"\">EN</a>\n          </div>-->\n          <p class=\"companyname\">高橋カーテンウォール工業株式会社</p>\n        </div>\n        <div class=\"search-sp-button\"><button type=\"submit\"></button></div>\n        <div class=\"search-sp-close\"><span></span></div>\n        <div id=\"search-button\"><span></span></div>\n        <a href=\"/form/\" class=\"contact-sp\"></a>\n        <div id=\"nav-button\">\n          <span></span>\n        </div>\n        <div class=\"search-sp\">\n          <form method=\"get\" action=\"/\">\n            <!--<p id=\"placeholder\">キーワード検索</p>-->\n            <input type=\"text\" name=\"s\" id=\"s\" placeholder=\"キーワード検索\">\n            <hr>\n          </form>\n        </div>\n      </div>\n    </div>\n    <div class=\"navi-sp\">\n      <nav role=\"navigation\">\n        <ul>\n          <li class=\"nav-pccw\"><a href=\"/feature/pc%E3%82%AB%E3%83%BC%E3%83%86%E3%83%B3%E3%82%A6%E3%82%A9%E3%83%BC%E3%83%AB%E3%81%AB%E3%81%A4%E3%81%84%E3%81%A6\">PCカーテンウォール</a></li>\n          <li class=\"nav-texture\"><a href=\"/texture/\">TEXTURE</a></li>\n          <li><a href=\"/texture/simulator/\" target=\"_blank\">- SIMULATOR</a></li>\n          <li class=\"nav-project\"><a href=\"/project/\">PROJECT</a></li>\n          <li class=\"nav-about _parent\"><p>ABOUT US<span></span><span></span></p>\n            <div class=\"_sub _sub-about\">\n              <a href=\"/about/\" class=\"nav-about-about\">社長挨拶</a>\n              <a href=\"/about/outline/\" class=\"nav-about-outline\">会社概要</a>\n              <a href=\"/about/access/\" class=\"nav-about-access\">アクセス</a>\n              <a href=\"/about/history/\" class=\"nav-about-history\">沿革</a>\n              <a href=\"/feature/pcsa/\" class=\"nav-about-pcsa\">PCSA</a>\n              <a href=\"/about/group/\" class=\"nav-about-group\">関連会社・関連事業</a>\n              <a href=\"/about/aqua/\" class=\"nav-about-aqua\">AQUA by TCW</a>\n              <a href=\"/about/update/\" class=\"nav-about-update\">更新履歴</a>\n            </div>\n          </li>\n          <li class=\"nav-ir _parent\"><p>IR INFO<span></span><span></span></p>\n            <div class=\"_sub _sub-ir\">\n              <a href=\"/ir/\" class=\"nav-ir-ir\">IR NEWS</a>\n              <a href=\"/ir/presentation/\" class=\"nav-ir-presentation\">決算説明会</a>\n              <a href=\"/ir/earning/\" class=\"nav-ir-earning\">決算短信</a>\n              <a href=\"/ir/meeting/\" class=\"nav-ir-meeting\">株主総会</a>\n              <a href=\"/ir/publicnotice/\" class=\"nav-ir-publicnotice\">電子公告</a>\n              <a href=\"/ir/securitie/\" class=\"nav-ir-securitie\">有価証券報告書等</a>\n              <a href=\"/ir/other/\" class=\"nav-ir-other\">その他開示事項</a>\n            </div>\n          </li>\n          <li><a href=\"/form/\">CONTACT</a></li>\n          <li><a class=\"recruit\" href=\"/entry/company/\">RECRUIT</a></li>\n          <li class=\"nav-about _parent\"><p>SEARCH</p></li>\n        </ul>\n      </nav>\n      <div class=\"search\">\n        <form method=\"get\" action=\"/\">\n          <input type=\"text\" name=\"s\" id=\"s\" placeholder=\"キーワード検索\">\n          <hr>\n          <div class=\"search__button\"><button type=\"submit\"></button></div>\n        </form>\n      </div>\n      <div class=\"etc\">\n        <a href=\"https://stocks.finance.yahoo.co.jp/stocks/detail/?code=1994.T\" target=\"_blank\" class=\"nav-stockprice\">最新株価情報</a>\n        <!--<a href=\"/\">高橋カーテンウォール工業株式会社</a>-->\n        <a href=\"/privacypolicy/\">PRIVACY POLICY</a>\n      </div>\n    </div>\n  </header>\n  <main class=\"main\" role=\"main\">\n        <section class=\"title\">\n      <div class=\"_container\">\n        <h1><img src=\"/assets/img/main/entry/title.png\" alt=\"TAKAHASHI CURTAIN WALL RECRUIT\"></h1>\n      </div>\n    </section>\n    <section class=\"entry-nav\">\n      <div class=\"_container\">\n        <ul>\n          <li><a href=\"/entry/company/\" class=\"entry-nav--company _on\">会社情報</a></li>\n          <li><a href=\"/entry/newgrads/\" class=\"entry-nav--newgrads\">新卒採用<span class=\"entry-nav__status\">（第二新卒もこちら）</span></a></li>\n          <li><a href=\"/entry/career/\" class=\"entry-nav--career\">中途採用</a></li>\n        </ul>\n      </div>\n    </section>\n    <section class=\"contents\">\n      <div class=\"page-link\"><div class=\"_container\"><ul>\n<li><a href=\"#phase1\"><strong>会社紹介</strong></a></li>\n<li><a href=\"#phase2\"><strong>会社データ</strong></a></li>\n<li><a href=\"#phase3\"><strong>働き方データ</strong></a></li>\n<li><a href=\"#phase4\"><strong>会社概要</strong></a></li>\n<li><a href=\"#phase5\"><strong>所在地</strong></a></li>\n</ul>\n</div></div>\n      <div class=\"_container\">\n        <div class=\"contents__main\">\n          <div class=\"content\">\n          <div class=\"page-head\"><p><strong id=\"phase1\">★広報（メディア・SNS)</strong></p>\n</div>\n<div class=\"page-head\"><p>&nbsp;</p>\n<p><a href=\"https://job.mynavi.jp/27/pc/search/corp104174/outline.html\"><img decoding=\"async\" src=\"https://t-cw.co.jp/wp/wp-content/uploads/2022/01/9e77e678b19ce1fee9ed1f1e6b43263c.png\" alt=\"\" width=\"204\" height=\"44\" class=\"alignnone wp-image-11824\" /></a><span style=\"font-size: 10pt;\"><strong><span style=\"color: #000000;\">　<a href=\"https://job.mynavi.jp/28/pc/search/corp104174/is.html\"><img decoding=\"async\" src=\"https://t-cw.co.jp/wp/wp-content/uploads/2022/01/066c231df10919ed80c6a04df28eafe4.png\" alt=\"\" width=\"196\" height=\"41\" class=\"alignnone wp-image-12291\" /></a></span></strong></span></p>\n<p><span style=\"font-size: 10pt;\"><strong><span style=\"color: #000000;\">【27卒】説明会・選考実施中！　　　　【28卒】インターンシップ募集中！</span></strong></span></p>\n<p>&nbsp;</p>\n<p>&nbsp;</p>\n</div>\n<div class=\"page-head\"><p><a href=\"https://shachomeikan.jp/presidents/detail/10063548\"><img decoding=\"async\" src=\"https://t-cw.co.jp/wp/wp-content/uploads/2022/01/212095de7089eda1e2a572fd91ff0d38.png\" alt=\"\" width=\"157\" height=\"157\" class=\"alignnone wp-image-11192\" />　　</a><a href=\"https://japanpride.jp/person/takahashi_takeharu/\"><img decoding=\"async\" src=\"https://t-cw.co.jp/wp/wp-content/uploads/2022/01/JQ_banner02-1.jpg\" alt=\"\" width=\"161\" height=\"161\" class=\"alignnone wp-image-11580\" />　　</a></p>\n<p><span style=\"font-size: 10pt;\"><strong><span style=\"color: #000000;\">　社長インタビュー動画★　　社長の取材内容が掲載されました★</span></strong></span></p>\n</div>\n<div class=\"page-head\"><p><strong><span style=\"color: #333333; font-size: 12pt;\">【Instagram（採用アカウント）】</span></strong></p>\n<p><span style=\"font-size: 10pt;\">新入社員の声、研修の様子、会社の雰囲気、平日ランチなどを投稿中！</span></p>\n<p><a href=\"https://www.instagram.com/tcw_saiyo/\"><img fetchpriority=\"high\" decoding=\"async\" src=\"https://t-cw.co.jp/wp/wp-content/uploads/2022/01/29d3bc99193cb0b837fb8cc53f050ae5.png\" alt=\"\" width=\"567\" height=\"750\" class=\"alignnone size-full wp-image-11987\" /></a></p>\n<p>&nbsp;</p>\n</div>\n<div class=\"image img_1\">\n</div>\n<div class=\"page-head\"><p><strong id=\"phase1\">会社紹介</strong></p>\n</div>\n<h1 class=\"contents-title\">【奨学金返済補助制度・住宅補助制度あり！】<br />\n創業から70年以上続く、高層ビルの外壁メーカーです。<br />\n街の景観を彩る仕事を一緒にしませんか？</h1>\n<div class=\"movie\">\n<iframe width=\"560\" height=\"315\" src=\"https://www.youtube.com/embed/rC5YQNjPdiM?loop=1&rel=0&playlist=rC5YQNjPdiM\" frameborder=\"0\" allow=\"autoplay; encrypted-media\" allowfullscreen></iframe>\n</div>\n<h2>当社の仕事（設計部若手社員に話を聞きました）</h2>\n<div class=\"text\"><p><span style=\"color: #ff6600;\">Q.どんな仕事をしていますか？</span><br />\nA.「私は、設計部でPCカーテンウォールの設計を行っています。<br />\n具体的には建築設計事務所のまとめた設計図書（意匠・構造図）を基に短い物件で3カ月、長い物件で半年ぐらいゼネコン（建設会社）とその関連協力業者と打ち合わせを行います。」</p>\n<p><span style=\"color: #ff6600;\">Q.やりがいはどのような時感じますか？</span><br />\nA.「苦労してまとめた図面を元に工場で製品を製作して、その製品を工事部の手により取り付けられ建物が竣工して、多くの人の生活を守り社会の役にたっているなと感じる時です。またPCカーテンウォールは、建物の表面に付いているのでビジュアル的にも非常に目立つため友達にも自慢できます。」</p>\n<p><span style=\"color: #ff6600;\">Q.仕事をする上で大切にしていることはなんですか？</span><br />\nA.「『粘り強さ』と『根気』です。実設計をしていくと意匠的な問題、機能的な問題と様々な問題が浮き彫りになってきます。その問題の一つひとつを打合せをして解決していかなければなりませんが、これはとても労力のいる作業となります。<br />\nしかし、問題から逃げずに粘り強く打合せをして、根気よく一つずつ問題を解決して最後に無事にPCカーテンウォールの取り付けが完了した時はとても達成感がありました。この達成感が次の仕事の励みになります。」</p>\n</div>\n<h2>当社の仕事（設計部上司に話を聞きました）</h2>\n<div class=\"text\"><p>「T君の仕事ぶりは、何事にも一生懸命です。この仕事は、たくさんの人と関わりながら、ひとつひとつ積み上げて行く仕事なのでやはり『粘り強さ』と『根気』は必要です。特に若いうちは、会う人会う人がみんな年上で悔しい思いをする事も有るでしょう。そのような人達を味方に付けるのは、本人の熱意だと思います。<br />\nPCカーテンウォールの設計は何でも自由にできるわけではありません。むしろ不自由さの中で活路を見出し価値ある設計を求められます。<br />\n建物を1つ造るには、多くのプロたちの労苦が必要です。このハードルを越えた時、初めて「同じ釜の飯」を食った仲間になれるのです。<br />\nT君もこれからいろんな人や物件に巡り合うと思いますが、今の気持ちを大切にして取組んでいけば、いずれこの仕事をやってきて本当に良かったと思う日がくるでしょう。私もまだ旅の途中ですが、そのような生き方をして来た尊敬する先輩を私はたくさん見て来ました。 頑張ってください期待しています。」</p>\n</div>\n          </div>\n        </div>\n      </div>\n    </section>\n    <section class=\"contents _companydata _post\">\n      <div class=\"_container\">\n        <div class=\"contents__main\">\n          <div class=\"content\">\n          <div class=\"page-head\"><p><strong id=\"phase2\">会社データ</strong></p>\n</div>\n<h2>プロフィール</h2>\n<div class=\"text\"><p><span style=\"color: #ff6600;\">業界シェアNo.1！</span>（2023年度PCSAマーケティング部会調査による）<br />\n当社の手掛けた作品は日本全国に多数あり、『日本のビルベスト100』（(株)エクスナレッジ　出版、＠関西人　著）や『世界に誇れる東京のビル100』（同）に選ばれた作品もたくさんあります。</p>\n</div>\n<aside class=\"add\"><p>◆施工実績<br />\n1.サンシャイン60（東京都豊島区）2.東京都庁（東京都新宿区）3.コレド日本橋（東京都中央区）4.東京スカイツリーイーストタワー（東京都墨田区）5.新宿東宝ビル（東京都新宿区）6.横浜ランドマークタワー（神奈川県横浜市）7.明治大学リバティタワー（東京都千代田区）8.梅田阪急ビル（大阪府大阪市）9.グランフロント大阪（大阪府大阪市）10.JRセントラルタワーズ（愛知県名古屋市）11.ワールドビジネスガーデン（千葉県千葉市）12.新宿パークタワー（東京都新宿区）13.仙台トラストタワー（宮城県仙台市）14.群馬県庁舎（群馬県前橋市）15.NHK広島放送センタービル（広島県広島市）16.浜松アクトタワー（静岡県浜松市）17.クイーンズスクエア横浜（神奈川県横浜市）18.NTTドコモ川崎ビル（神奈川県川崎市）19.メディアシップ（新潟県新潟市）20.丸の内パークビルディング（東京都千代田区）21.鉄鋼ビルディング（東京都千代田区）22.JPタワー（東京都千代田区）23.GINZA KABUKIZA（東京都中央区）24.日本橋三井タワー（東京都中央区）25.愛宕グリーンヒルズMORIタワー（東京都港区）26.明治安田生命ビル（東京都千代田区）27.山王パークタワー（東京都千代田区）28.アーク森ビル（東京都港区）29.大手町タワー（東京都千代田区）30.ミッドタウンタワー（東京都港区）　　ほか</p>\n</aside>\n<div class=\"image img_2\">\n<div class=\"img1\">\n<img src=\"https://t-cw.co.jp/wp/wp-content/uploads/2022/01/dd0d526e6d748a62c6f3df6ff07168fc-314x204-1.png\" alt=\"\">\n<p>ピアノの鍵盤をイメージした建物の依頼があり、白い鍵盤の部分を当社が担当しました。素敵なデザインですね。&nbsp;</p>\n</div>\n<div class=\"img1\">\n<img src=\"https://t-cw.co.jp/wp/wp-content/uploads/2022/01/5c4752589b9c960901c86e850af0db2e-314x204-1.png\" alt=\"\">\n<p>東京駅付近での当社が手掛けた建物（黄色部分）です。&nbsp;</p>\n</div>\n</div>\n<h2>事業内容</h2>\n<div class=\"text\"><p>TCWはとっても地味な仕事をしています。</p>\n<p>消費者向けの仕事ではないので、CM無し、一般人の知名度はゼロ。<br />\n社名から、だいたいカーテン屋さんと勘違いされます。</p>\n<p>でも、出来あがった製品は、とても有名な建物に使われます。</p>\n<p>東京であれば、東京都庁、東大や早稲田、明治などの大学、名古屋であれば、駅前のJRセントラルタワー、京都であれば、京都駅ビル、大阪であれば、グランフロント大阪。超一等地で当社の造ったコンクリート製のオーダーメイド外壁が使われます。</p>\n<p>パーティーの帰り、社員みんなで乗った山手線から、<br />\n「あれは、○葉さんが設計した建物だ。」<br />\n「あれは、島○さんが担当した建物だ。」<br />\nワイワイ手掛けた作品を指さします。</p>\n<p>あなたもこんな仕事をしてみませんか？</p>\n<p>ちなみに、東京本社は一級建築士事務所として登録されております。<br />\n仕事をしながら資格取得を目指していただけます。</p>\n</div>\n<div class=\"movie\">\n<iframe width=\"560\" height=\"315\" src=\"https://www.youtube.com/embed/MrN2AbhRIOY?loop=1&rel=0&playlist=MrN2AbhRIOY\" frameborder=\"0\" allow=\"autoplay; encrypted-media\" allowfullscreen></iframe>\n</div>\n<div class=\"movie\">\n<iframe width=\"560\" height=\"315\" src=\"https://www.youtube.com/embed/1LAX0cDBMgk?loop=1&rel=0&playlist=1LAX0cDBMgk\" frameborder=\"0\" allow=\"autoplay; encrypted-media\" allowfullscreen></iframe>\n</div>\n          </div>\n        </div>\n      </div>\n    </section>\n    <section class=\"contents _workdata _post\">\n      <div class=\"_container\">\n        <div class=\"contents__main\">\n        <div class=\"content\">\n          <div class=\"page-head\"><p><strong id=\"phase3\">働き方データ</strong></p>\n</div>\n<div class=\"image img_1\">\n<div>\n<img src=\"https://t-cw.co.jp/wp/wp-content/uploads/2022/01/9b70644ab9304f9337aab9314e86f8e7.png\" alt=\"\">\n</div>\n</div>\n<div class=\"image img_1\">\n<div>\n<img src=\"https://t-cw.co.jp/wp/wp-content/uploads/2022/01/caa7569eab024fa9cdbf2852f7639a5c.png\" alt=\"\">\n</div>\n</div>\n          </div>\n        </div>\n      </div>\n    </section>\n    <section class=\"contents _outline _post\">\n      <div class=\"_container\">\n        <div class=\"contents__main\">\n        <div class=\"content\">\n          <div class=\"page-head\"><p><strong id=\"phase4\">会社概要</strong></p>\n</div>\n<div class=\"outline\">\n<dl>\n<dt>会社名</dt>\n<dd>高橋カーテンウォール工業株式会社</dd>\n</dl>\n<dl>\n<dt>本社所在地</dt>\n<dd>〒103-0023 <br class=\"_sp\" />東京都中央区日本橋本町1-5-4</dd>\n</dl>\n<dl>\n<dt>本社電話番号</dt>\n<dd>03-3271-1711（代表）</dd>\n</dl>\n<dl>\n<dt>創業</dt>\n<dd>1951年（昭和26年）5月1日</dd>\n</dl>\n<dl>\n<dt>設立</dt>\n<dd>1965年（昭和40年）1月8日</dd>\n</dl>\n<dl>\n<dt>資本金</dt>\n<dd>1億円</dd>\n</dl>\n<dl>\n<dt>社員数</dt>\n<dd>189名（男性144名・女性45名）、協力会社約600名、合計700～800名（2023年度実績）</dd>\n</dl>\n<dl>\n<dt>売上高</dt>\n<dd>72億6,900万円（2023年12月期）</dd>\n</dl>\n<dl class=\"outline__office\">\n<dt>事業所</dt>\n<dd>大阪支店／大阪府大阪市北区中之島3-2-18 住友中之島ビル11Ｆ<br />\n結城工場／茨城県結城市北南茂呂1961<br />\nつくば工場／茨城県結城郡八千代町栗山711<br />\n下館工場／茨城県筑西市西山田223-1<br />\n滋賀工場／滋賀県甲賀市信楽町西349-1</dd>\n</dl>\n<dl>\n<dt>平均年収</dt>\n<dd>632万円</dd>\n</dl>\n</div>\n\n          </div>\n        </div>\n      </div>\n    </section>\n    <section class=\"contents _access _post\">\n      <div class=\"_container\">\n        <div class=\"contents__main\">\n        <div class=\"content\">\n          <div class=\"page-head\"><p><strong id=\"phase5\">所在地</strong></p>\n</div>\n<div class=\"access tokyo\">\n<h2>東京本社</h2>\n<p><iframe width=\"600\" height=\"450\" style=\"border: 0;\" src=\"https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d6481.217606232555!2d139.77138863081433!3d35.686633300009014!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x6018895449609673%3A0x6256c4a23a54039c!2z6auY5qmL44Kr44O844OG44Oz44Km44Kp44O844Or5bel5qWtKOagqik!5e0!3m2!1sja!2sjp!4v1573816539879!5m2!1sja!2sjp\" frameborder=\"0\" allowfullscreen=\"allowfullscreen\"></iframe></p>\n<dl>\n<dt>住所</dt>\n<dd>〒103-0023<br />\n東京都中央区日本橋本町1-5-4 <br class=\"_sp\" />住友不動産日本橋ビル 5F</dd>\n</dl>\n<dl>\n<dt>TEL</dt>\n<dd>03-3271-1711（代表）</dd>\n</dl>\n<dl>\n<dt>FAX</dt>\n<dd>03-3271-1754</dd>\n</dl>\n<dl>\n<dt>地下鉄</dt>\n<dd>地下鉄銀座線「三越前」駅A5出口　徒歩3分<br />\n地下鉄半蔵門線「三越前」駅A5出口　徒歩3分</dd>\n</dl>\n<dl>\n<dt>JR</dt>\n<dd>JR総武快速線「新日本橋」駅6番出口　徒歩5分<br />\nJR中央線・山手線・京浜東北線「神田」駅南口　徒歩13分</dd>\n</dl>\n</div>\n\n          </div>\n        </div>\n      </div>\n    </section>\n    <section class=\"entry-nav _footer\">\n      <div class=\"_container\">\n      <ul>\n          <li><a href=\"/entry/company/\" class=\"entry-nav--company _on\">会社情報</a></li>\n          <li><a href=\"/entry/newgrads/\" class=\"entry-nav--newgrads\">新卒採用<span class=\"entry-nav__status\">（第二新卒もこちら）</span></a></li>\n          <li><a href=\"/entry/career/\" class=\"entry-nav--career\">中途採用</a></li>\n        </ul>\n      </div>\n    </section>\n    <section class=\"contents _footer\">\n      <div class=\"page-link\"><div class=\"_container\"><ul>\n<li><a href=\"#phase1\"><strong>会社紹介</strong></a></li>\n<li><a href=\"#phase2\"><strong>会社データ</strong></a></li>\n<li><a href=\"#phase3\"><strong>働き方データ</strong></a></li>\n<li><a href=\"#phase4\"><strong>会社概要</strong></a></li>\n<li><a href=\"#phase5\"><strong>所在地</strong></a></li>\n</ul>\n</div></div>\n    </section>\n  </main>\n  </main>\n  <footer class=\"footer\" role=\"contentinfo\">\n    <div class=\"_container\">\n      <h1>高橋カーテンウォール工業株式会社</h1>\n      <nav>\n        <ul>\n          <li><a href=\"/form/\">CONTACT US</a></li>\n          <li><a href=\"/privacypolicy/\">PRIVACY POLICY</a></li>\n        </ul>\n      </nav>\n      <p class=\"copyright\">&copy; TAKAHASHI CURTAIN WALL CORPORATION</p>\n    </div>\n  </footer></div>\n<script src=\"//ajax.googleapis.com/ajax/libs/jquery/2.2.4/jquery.min.js\"></script>\n<script src=\"/assets/js/core.js\"></script>\n<script type=\"speculationrules\">\n{\"prefetch\":[{\"source\":\"documen