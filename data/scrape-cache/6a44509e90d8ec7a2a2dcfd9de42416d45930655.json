\n            });\n            $('a[href^=\"#\"]').click(function() {\n                var time = 500;\n                var href = $(this).attr(\"href\");\n                var target = $(href == \"#\" ? 'html' : href);\n                var distance = target.offset().top;\n                $(\"html, body\").animate({\n                    scrollTop: distance\n                }, time, \"swing\");\n                return false;\n            });\n        });\n    </script>\n    <script>\n        function mailcheck() {\n            var mail = email.value;\n            var mail2 = email2.value;\n            if (mail != mail2) {\n                email2.setCustomValidity('メールアドレスが一致しません');\n            } else {\n                email2.setCustomValidity('');\n            }\n        }\n        var sn = document.getElementById('email2');\n        sn.addEventListener('input', mailcheck, false);\n    </script>\n\n</body>\n\n</html>","finalUrl":"http://www.patroad.co.jp/contact.html","rendered":false,"_cachedAt":"2026-06-23T21:19:08.200Z"}