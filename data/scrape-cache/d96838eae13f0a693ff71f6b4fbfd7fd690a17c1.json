"text/css\" media=\"screen and (max-width: 1023px) and (min-width: 0px)\"\r\n    href=\"../../assets/css/mobile.css\">\r\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"../../assets/css/career/common.css\" media=\"screen\" />\r\n  <link rel=\"stylesheet\" type=\"text/css\" href=\"../../assets/css/career/area.css\" media=\"screen\" />\r\n  <script type=\"text/javascript\" src=\"https://code.jquery.com/jquery-3.4.1.min.js\"></script>\r\n  <script type=\"text/javascript\" src=\"../../assets/js/function.js\"></script>\r\n  <!-- Global site tag (gtag.js) - Google Analytics -->\r\n  <script async src=\"https://www.googletagmanager.com/gtag/js?id=UA-476156-1\"></script>\r\n  <script>\r\n    window.dataLayer = window.dataLayer || [];\r\n    function gtag() { dataLayer.push(arguments); }\r\n    gtag('js', new Date());\r\n\r\n    gtag('config', 'UA-476156-1');\r\n  </script>\r\n</head>\r\n\r\n<body class=\"basic career area\">\r\n<!-- Google Tag Manager (noscript) -->\r\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-PC6HWS\"\r\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\r\n<!-- End Google Tag Manager (noscript) -->\r\n  <header>\r\n    <div class=\"logo\"><a href=\"../\"><img src=\"../../assets/img/common_img/logo.svg\" alt=\"フクダ電子株式会社\" /></a></div>\r\n    <script type=\"text/javascript\">\r\n      writeGmenuCareer(\"../../\");\r\n    </script>\r\n  </header>\r\n\r\n\r\n  <div id=\"container\">\r\n\r\n    <div class=\"h1-box fin\">\r\n      <h1><span>RECRUIT</span>キャリア採用</h1>\r\n      <p class=\"txt-header\">キャリア採用<br class=\"brsp\">エントリー</p>\r\n    </div>\r\n\r\n\r\n    <main>\r\n\r\n      <section class=\"section01 fin\">\r\n\r\n       <div class=\"content-box\">\r\n\r\n          <div class=\"area-block\">\r\n            <h3 class=\"h3-style01\">フクダ電子本社</h3>\r\n            <div class=\"area-item\">\r\n              <dl class=\"head\">\r\n                <dt>\r\n                  <h4>開発職【正社員】</h4>\r\n                </dt>\r\n                <dd>\r\n                \r\n                </dd>\r\n              </dl>\r\n              <dl>\r\n\r\n                <dt>\r\n                  <p>雇用形態</p>\r\n                </dt>\r\n                <dd>正社員</dd>\r\n\r\n                <dt>\r\n                  <p>職種&#10112;<br>業務内容<br>募集必須要件<br>募集勤務地</p>\r\n                </dt>\r\n                <dd>開発／プリント基板アートワーク設計<br>プリント基板のアートワーク設計・レビュー・その他開発付帯業務<br>電子基板設計の開発経験 ５年以上<br>東京都文京区本郷</dd>\r\n\t\t\t\t  <dt>\r\n                  <p>職種&#10113;<br>業務内容<br>募集必須要件<br>募集勤務地</p>\r\n                </dt>\r\n                <dd>開発／ハードウェア回路設計<br>ハードウェア回路設計・レビュー・その他開発付帯業務<br>デジタル回路又はアナログ回路設計の開発経験 ５年以上<br>東京都文京区本郷</dd>\r\n\t\t\t\t  <dt>\r\n                  <p>職種&#10114;<br>業務内容<br>募集必須要件<br><br><br>募集勤務地</p>\r\n                </dt>\r\n                <dd>開発／組込みソフトウェア設計<br>組込みソフトウエア設計・レビュー・その他開発付帯業務<br>以下、いずれか必須 ５年以上<br>※１組込みLinux上でのソフト開発経験 ※言語：C、C++\r\n<br>※２組込みソフト、ドライバソフト開発経験　※組込みリアルタイムOS、iTron<br>東京都文京区本郷、京都市伏見区竹田中島町</dd>\t\t\t\t  \r\n\t\t\t\t  \r\n\t\t\t\t  <dt>\r\n                  <p>学歴</p>\r\n                </dt>\r\n                <dd>大卒以上</dd>\r\n\t\t\t\t   <dt>\r\n                  <p>基本給月給</p>\r\n                </dt>\r\n                <dd>月給2５万円～　（昇給年1回、賞与年2回）　※スキル経験によって決定します</dd> \r\n\t\t\t\t  <dt>\r\n                  <p>その他手当</p>\r\n                </dt>\r\n                <dd>通勤手当、住宅手当、地域手当、扶養家族手当、残業手当、資格手当等　※規定に則り支給します</dd>\r\n\t\t\t\t  <dt>\r\n                  <p>就業時間</p>\r\n                </dt>\r\n                <dd>9：00~17：30（休憩11：50~12：50）</dd>\r\n\t\t\t\t   <dt>\r\n                  <p>休日</p>\r\n                </dt>\r\n                <dd>土曜、日曜、祝日、年末年始、夏季休暇、GWその他規程による</dd>              \r\n\t\t\t\t  <dt>\r\n                  <p>試用期間</p>\r\n                </dt>\r\n                <dd>6か月</dd>\r\n\t\t\t\t\r\n\t\t\t\t</dl>\r\n            </div>\r\n           \r\n\r\n            <!-- div class=\"area-item\">\r\n              <dl class=\"head\">\r\n                <dt>\r\n                  <h4>求人3</h4>\r\n                </dt>\r\n                <dd>\r\n                \r\n                </dd>\r\n              </dl>\r\n              <dl>\r\n\r\n                <dt>\r\n                  <p>雇用形態</p>\r\n                </dt>\r\n                <dd>契約社員</dd>\r\n\r\n                <dt>\r\n                  <p>職種</p>\r\n                </dt>\r\n                <dd>医療機器製造</dd>\r\n\t\t\t\t  <dt>\r\n                  <p>業務内容</p>\r\n                </dt>\r\n                <dd>プリント基板実装ラインの段取り替え・品質管理業務等の補佐</dd>\r\n\t\t\t\t   <dt>\r\n                  <p>募集必須要件</p>\r\n                </dt>\r\n                <dd>製造業務経験</dd>\r\n\t\t\t\t   <dt>\r\n                  <p>学歴</p>\r\n                </dt>\r\n                <dd>高卒以上</dd>\r\n\t\t\t\t   <dt>\r\n                  <p>勤務地</p>\r\n                </dt>\r\n                <dd>千葉県白井市中305-1　白井事業所</dd>\r\n\t\t\t\t   <dt>\r\n                  <p>就業時間</p>\r\n                </dt>\r\n                <dd>9：00~17：30（休憩12：00~12：50、15：00~15：10）</dd>\r\n\t\t\t\t   <dt>\r\n                  <p>休日</p>\r\n                </dt>\r\n                <dd>土曜、日曜、祝日、年末年始、夏季休暇、GWその他規程による</dd>\r\n\t\t\t\t  <dt>\r\n                  <p>基本給</p>\r\n                </dt>\r\n                <dd>175,000円~　（昇給年1回、賞与年2回）<br>※別途、規定に則り支給します（通勤手当、扶養家族手当、残業手当、資格手当等）<br>※ご経験を優遇の上、決定します\r\n</dd>\t\t\r\n\t\t\t\t</dl>\r\n            </div>\r\n\t\t\t  \r\n            <div class=\"area-item\">\r\n              <dl class=\"head\">\r\n                <dt>\r\n                  <h4>求人4</h4>\r\n                </dt>\r\n                <dd>\r\n                \r\n                </dd>\r\n              </dl>\r\n              <dl>\r\n\r\n                <dt>\r\n                  <p>雇用形態</p>\r\n                </dt>\r\n                <dd>契約社員</dd>\r\n\r\n                <dt>\r\n                  <p>職種</p>\r\n                </dt>\r\n                <dd>医療機器営業</dd>\r\n\t\t\t\t  <dt>\r\n                  <p>業務内容</p>\r\n                </dt>\r\n                <dd>ME機器講習会 講師補助/受付業務</dd>\r\n\t\t\t\t   <dt>\r\n                  <p>募集必須要件</p>\r\n                </dt>\r\n                <dd>臨床検査技師または心電図検定2級以上</dd>\r\n\t\t\t\t   <dt>\r\n                  <p>学歴</p>\r\n                </dt>\r\n                <dd>大卒以上</dd>\r\n\t\t\t\t   <dt>\r\n                  <p>勤務地</p>\r\n                </dt>\r\n                <dd>東京都文京区湯島</dd>\r\n\t\t\t\t   <dt>\r\n                  <p>就業時間</p>\r\n                </dt>\r\n                <dd>9：00~17：30（休憩11：50~12：50）</dd>\r\n\t\t\t\t   <dt>\r\n                  <p>休日</p>\r\n                </dt>\r\n                <dd>土曜、日曜、祝日、年末年始、夏季休暇、GWその他規程による</dd>\r\n\t\t\t\t  <dt>\r\n                  <p>基本給</p>\r\n                </dt>\r\n                <dd>200,000円~　（昇給年1回、賞与年2回）<br>※別途、規定に則り支給します（通勤手当、扶養家族手当、残業手当、資格手当等）</dd>\r\n                </dl>\r\n            </div -->          \r\n          </div>           \r\n        </div>\r\n\r\n\r\n      </section>\r\n\r\n      <section class=\"section02 job-entry-block fin\">\r\n        <div class=\"content-box\">\r\n        <div class=\"line-title\">勤務地からエントリー</div>\r\n        <ul class=\"job-entry\">\r\n          \r\n          <li>\r\n            <a href=\"/recruit/career/area/area01.html\" class=\"abox\"></a>\r\n            <p>北海道・東北地区</p>\r\n         </li>\r\n         <li>\r\n            <a href=\"/recruit/career/area/area02.html\" class=\"abox\"></a>\r\n            <p>関東地区</p>\r\n         </li>\r\n         <li>\r\n            <a href=\"/recruit/career/area/area03.html\" class=\"abox\"></a>\r\n            <p>北陸・中部・東海地区</p>\r\n         </li>\r\n         <li>\r\n            <a href=\"/recruit/career/area/area04.html\" class=\"abox\"></a>\r\n            <p>近畿地区</p>\r\n         </li>\r\n         <li>\r\n            <a href=\"/recruit/career/area/area05.html\" class=\"abox\"></a>\r\n            <p>中国・四国地区</p>\r\n         </li>\r\n         <li>\r\n            <a href=\"/recruit/career/area/area06.html\" class=\"abox\"></a>