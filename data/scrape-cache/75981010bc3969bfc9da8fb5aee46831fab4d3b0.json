</div>\n<!-- /.ly_bgWhite -->\n\n<div class=\"ly_bgBlue bl_M01 bl_M01__col1\">\n  <div class=\"ly_body\">\n    <div class=\"bl_M01_txt\"><h1 class=\"el_pageTtl\">採用トピックス</h1></div>\n  </div>\n  <!-- /.bl_M01 -->\n</div>\n\n<!--#include virtual=\"/dealer/dairi/_inc/_localNav_recruit.html\" -->\n<div class=\"bl_N01 recruit-menu\">\n  <div class=\"ly_body\">\n    <ul class=\"bl_N01_list js_matchHeightChildren\">\n      <li class=\"bl_N01_list_child\"><div class=\"bl_N01_list_child_inner\"><span><a href=\"/dealer/sj-saitama/recruit/\">採用情報</a></span></div></li>\n      <li class=\"bl_N01_list_child graduate-guideline\"><div class=\"bl_N01_list_child_inner\"><span><a href=\"/dealer/sj-saitama/recruit/graduate-guideline/\">【新卒採用】<br>募集要項</a></span></div></li>\n      <li class=\"bl_N01_list_child career-guideline\"><div class=\"bl_N01_list_child_inner\"><span><a href=\"/dealer/sj-saitama/recruit/career-guideline/\">【中途採用】<br>募集要項</a></span></div></li>\n      <li class=\"bl_N01_list_child workplace_information\"><div class=\"bl_N01_list_child_inner\"><span><a href=\"/dealer/sj-saitama/recruit/workplace_information/\">職場情報</a></span></div></li>\n      <li class=\"bl_N01_list_child briefing\"><div class=\"bl_N01_list_child_inner\"><span><a href=\"/dealer/sj-saitama/recruit/briefing/\">説明会情報</a></span></div></li>\n      <li class=\"bl_N01_list_child message\"><div class=\"bl_N01_list_child_inner\"><span><a href=\"/dealer/sj-saitama/recruit/message/\">みなさんへの<br />メッセージ</a></span></div></li>\n      <li class=\"bl_N01_list_child workplace\"><div class=\"bl_N01_list_child_inner\"><span><a href=\"/dealer/sj-saitama/recruit/workplace/\">職場紹介</a></span></div></li>\n      <li class=\"bl_N01_list_child shop\"><div class=\"bl_N01_list_child_inner\"><span><a href=\"/dealer/sj-saitama/recruit/shop/\">拠点紹介</a></span></div></li>\n      <li class=\"bl_N01_list_child topic\"><div class=\"bl_N01_list_child_inner\"><span><a href=\"/dealer/sj-saitama/recruit/topic/\">採用トピックス</a></span></div></li>\n    </ul>\n  </div>\n</div>\n<!-- /.bl_N01 -->\n\n\n<div class=\"ly_bgGray ly_padding ly_padding__bottom\" id=\"topic\">\n  <section>\n    <div class=\"ly_body ly_bgWhite cf hp_mb30 ly_body__mainContents topic_detail jsContent\" style=\"display:none\">\n                        <p class=\"data\"><span class=\"cat\" style=background-color:#0099CA;>採用教育活動</span><span class=\"day\">2026.06.12</span></p>\n        <p class=\"detail_ttl\">サービス新入社員入門研修</p>\n                <p style=\"text-align: center;\">みなさんこんにちわ！<img src=\"/dealer/sj-admin/asset/js/tinymce/plugins/emoticons/img/128.png\" alt=\"128\" width=\"32\" height=\"32\" name=\"emoticons\" /></p>\r\n<p style=\"text-align: center;\">スズキ自販埼玉　採用担当です。</p>\r\n<p style=\"text-align: center;\">&nbsp;</p>\r\n<p style=\"text-align: center;\">先日、サービス職　<span style=\"color: #ff0000;\"><strong>新入社員入門研修</strong></span>を行いました！</p>\r\n<p style=\"text-align: center;\"><img src=\"/dealer/sj-admin/sharefiles/image4_4bd937ce-661c-11f1-b316-fa163e38a592.jpeg\" alt=\"\" width=\"400\" height=\"300\" /></p>\r\n<p style=\"text-align: center;\">整備業務の基礎の知識や安全作業の重要性について学びました。</p>\r\n<p style=\"text-align: center;\">講師は各拠点の工場長が担当し、それぞれの経験を交えながら</p>\r\n<p style=\"text-align: center;\">わかりやすく、説明してくださいました<img src=\"/dealer/sj-admin/asset/js/tinymce/plugins/emoticons/img/03.png\" alt=\"03\" width=\"32\" height=\"32\" name=\"emoticons\" /><img src=\"/dealer/sj-admin/asset/js/tinymce/plugins/emoticons/img/178.png\" alt=\"178\" width=\"32\" height=\"32\" name=\"emoticons\" /></p>\r\n<p style=\"text-align: center;\">&nbsp;</p>\r\n<p style=\"text-align: center;\"><img src=\"/dealer/sj-admin/sharefiles/image3_08864782-661c-11f1-bde7-fa163e38a592.jpeg\" alt=\"\" width=\"350\" height=\"467\" /><img src=\"/dealer/sj-admin/sharefiles/image1 (1)_e3bf7aa2-66bd-11f1-a0b7-fa163e38a592.jpeg\" alt=\"\" width=\"350\" height=\"467\" /></p>\r\n<p style=\"text-align: center;\">さまざまな拠点の工場長との交流を通じて</p>\r\n<p style=\"text-align: center;\">幅広い知識や考え方に触れる貴重な</p>\r\n<p style=\"text-align: center;\">機会になりました！！！<img src=\"/dealer/sj-admin/asset/js/tinymce/plugins/emoticons/img/29.png\" alt=\"29\" width=\"32\" height=\"32\" name=\"emoticons\" /></p>\r\n<p style=\"text-align: center;\">&nbsp;</p>\r\n<p style=\"text-align: center;\">スズキ自販埼玉では、入社後もしっかり研修を行いサポート</p>\r\n<p style=\"text-align: center;\">していきますのでご安心ください<img src=\"/dealer/sj-admin/asset/js/tinymce/plugins/emoticons/img/07.png\" alt=\"07\" width=\"32\" height=\"32\" name=\"emoticons\" /><img src=\"/dealer/sj-admin/asset/js/tinymce/plugins/emoticons/img/07.png\" alt=\"07\" width=\"32\" height=\"32\" name=\"emoticons\" /><img src=\"/dealer/sj-admin/asset/js/tinymce/plugins/emoticons/img/198.png\" alt=\"198\" width=\"32\" height=\"32\" name=\"emoticons\" /></p>\r\n<p style=\"text-align: center;\">&nbsp;</p>\r\n<p style=\"text-align: center;\">最後に、新入社員・工場長</p>\r\n<p style=\"text-align: center;\">１日お疲れ様でした！！</p>\r\n<p style=\"text-align: center;\">ありがとうございました<img src=\"/dealer/sj-admin/asset/js/tinymce/plugins/emoticons/img/96.png\" alt=\"96\" width=\"32\" height=\"32\" name=\"emoticons\" /></p>\r\n<p style=\"text-align: center;\"><img src=\"/dealer/sj-admin/sharefiles/IMG_0553_724ef9ea-661f-11f1-a89b-fa163e38a592.jpg\" alt=\"\" width=\"600\" height=\"450\" /></p>\r\n<p style=\"text-align: center;\">&nbsp;</p>\r\n<p style=\"text-align: center;\">&nbsp;</p>\r\n<p style=\"text-align: center;\">&nbsp;</p>\n              \n    </div>\n  </section>\n\n  <section>\n    <div class=\"ly_body ly_bgWhite cf ly_body__mainContents\">\n      <div class=\"topic_detail\">\n        <p class=\"detail_ttl\">最新記事</p>\n      </div>\n      <div class=\"bl_B10 cf\">\n              <div class=\"topic_detail_list bl_B10_block\">\n          <a href=\"/dealer/sj-saitama/recruit/topic/?id=46862\">\n            <div class=\"bl_B10_block_inner js_matchHeight cf\">\n                            <div class=\"img bl_centerThumb\">\n                                <img src=\"/dealer/sj-admin/sharefiles/image4_4bd937c