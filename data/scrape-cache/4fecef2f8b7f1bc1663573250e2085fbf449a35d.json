p--preset--gradient--luminous-dusk) !important;}.has-pale-ocean-gradient-background{background: var(--wp--preset--gradient--pale-ocean) !important;}.has-electric-grass-gradient-background{background: var(--wp--preset--gradient--electric-grass) !important;}.has-midnight-gradient-background{background: var(--wp--preset--gradient--midnight) !important;}.has-small-font-size{font-size: var(--wp--preset--font-size--small) !important;}.has-medium-font-size{font-size: var(--wp--preset--font-size--medium) !important;}.has-large-font-size{font-size: var(--wp--preset--font-size--large) !important;}.has-x-large-font-size{font-size: var(--wp--preset--font-size--x-large) !important;}\n/*# sourceURL=global-styles-inline-css */\n</style>\n\n<link rel='stylesheet' id='contact-form-7-css' href='https://shikokuiryoki.com/recruit/wp-content/plugins/contact-form-7/includes/css/styles.css' media='all' />\n<link rel=\"canonical\" href=\"https://shikokuiryoki.com/recruit/about/\" />\n<link rel=\"stylesheet\" href=\"https://shikokuiryoki.com/recruit/wp-content/themes/shikokuiryoki_recruit/assets/css/reset.css\">\n<link rel=\"stylesheet\" href=\"https://shikokuiryoki.com/recruit/wp-content/themes/shikokuiryoki_recruit/style.css\">\n<link rel=\"shortcut icon\" href=\"https://shikokuiryoki.com/recruit/wp-content/themes/shikokuiryoki_recruit/images/favicon.ico\">\n\n    <link rel=\"stylesheet\" href=\"https://shikokuiryoki.com/recruit/wp-content/themes/shikokuiryoki_recruit/assets/css/pages.css\">\n\n<!-- Global site tag (gtag.js) - Google Analytics -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-ZC06HNPL99\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'G-ZC06HNPL99');\n</script>\n</head>\n\n<header class=\"header_logo\">\n\t<h1 class=\"header_logo_\">\n\t\t<a href=\"https://shikokuiryoki.com/recruit/\">\n\t\t\t<div class=\"jr\">JR四国グループ</div>\n\t\t\t<div class=\"header_logo_content\">\n\t\t\t\t<img src=\"https://shikokuiryoki.com/recruit/wp-content/themes/shikokuiryoki_recruit/images/logo.svg\" alt=\"四国医療器 オフィシャルサイト\">\n\t\t\t\t<span class=\"recruit\">Recruit</span>\n\t\t\t</div>\n\t\t</a>\n\t</h1>\n\n\t<h2 class=\"recruit_types\">\n\t\t<span>新卒</span>\n\t\t<span>キャリア</span>\n\t\t<span>カムバック採用</span>\n\t</h2>\n</header>\n\n<header class=\"header\">\t\n\t<div id=\"header_nav_area\"><!--  #header_nav_area -->\n\t\t<nav>\n\t\t<div class=\"header_nav_area_inner\">\n\t\t\t<ul class=\"nav_list\">\n            <li><a href=\"https://shikokuiryoki.com/recruit/about/\">ABOUT US</a></li>\n\t\t\t<li><a href=\"https://shikokuiryoki.com/recruit/message/\">MESSAGE</a></li>\n\t\t\t<li><a href=\"https://shikokuiryoki.com/recruit/interview/person1/\">INTERVIEW</a></li>\n\t\t\t<li><a href=\"https://shikokuiryoki.com/recruit/requirements/\">募集要項</a></li>\n\t\t\t<li><a href=\"https://shikokuiryoki.com/recruit/qa/\">Q&A</a></li>\n\t\t\t<li><a href=\"https://shikokuiryoki.com/\" target=\"_blank\">コーポレートサイト</a></li>\n\t\t\t<li><a href=\"https://shikokuiryoki.com/recruit/contact/\">お問い合わせ</a></li>\n\t\t\t</ul>\n\t\t</div>\n\n\t\t<div class=\"btn_close\">\n\t\t\t<span></span>\n\t\t\t<span></span>\n\t\t</div>\n\t\t</nav>\n\n\t\t<div class=\"btn_open\">\n\t\t\t<span></span>\n\t\t\t<span></span>\n\t\t\t<span></span>\t\t\t\n\t\t</div>\n\t\t\n\t\t<div class=\"toggle_btn_bg\"></div>\n\n\t  <div id=\"mask\"></div>\n\n\t</div><!--  END #header_nav_area -->\t\n</header><body class=\"wp-singular page-template page-template-page-about page-template-page-about-php page page-id-10 wp-theme-shikokuiryoki_recruit pages about\">\n<main>\n    <div class=\"page-ttl\">\n        <div>\n            <h1 class=\"ttl\">ABOUT US</h1>\n            <h2 class=\"hl\">四国医療器とは ｜ わたしたちのことを知ってください。</h2>\n        </div>\n    </div>\n\n    <section class=\"sec sec_1\">\n        <div class=\"img\">\n\n        </div>\n        \n        <div class=\"txt_container\">\n            <div>\n                <h3 class=\"sec_ttl\">私たちの仕事</h3>\n                <h4 class=\"hl\">顧客のニーズにいち早く適切に応えることで<br>築かれていく信頼関係。</h4>\n                <p>私たちの仕事は、ドクターや看護師という<br>医療現場で働く人たちと深く関わります。<br>一刻を争う医療現場からの医療機器・理化学機器の要求に<br>的確にスピーディーに応えることが大切です。<br>また、迅速にそして臨機応変に対応することで、<br>相手に喜んでもらえるのもこの仕事の醍醐味。<br>仕事を通じて人間関係を構築し、<br>タフで頼られる存在になってもらえればと思います。</p>\n            </div>\n        </div>\n\n        <div class=\"links_container\">\n            <div>\n                <ul class=\"links_lists\">\n                    <li><a href=\"https://shikokuiryoki.com/products/#products_me\" target=\"_blank\">医療機器とは</a></li>\n                    <li><a href=\"https://shikokuiryoki.com/products/#products_pce\" target=\"_blank\">理化学機器とは</a></li>\n                </ul>\n            </div>                \n        </div>\n\n    </section>\n\n    <section class=\"sec sec_2\" id=\"sec_topmessage\">\n        <div class=\"img\"></div>\n        <div class=\"inner\">\n            <div class=\"txt\">\n                <h3 class=\"sec_ttl\">トップメッセージ</h3>\n                <h4 class=\"hl\">医療・理化学分野において、<br>常に顧客から必要とされる企業であり続けるために。</h4>\n                <p>医療・理化学の現場において必要とされる技術・情報の進化はめざましく、その現場に携わる方々が医療機器、検査機器、理化学研究機器を使用する際に要求される知識･技能は、ますます専門化・高度化しています。<br><br>このような現場が必要としているモノや情報を提供することをとおして、医療・理化学の現場を支えていくことが私たちの使命です。<br>私たちは社是「誠実」のもと、社会・地域から信頼され、社員とともに成長していく企業を目指します。\n                </p>\n\n                <div class=\"top_name\">\n                    <p>四国医療器株式会社<br>代表取締役</p>\n                    <p class=\"name\">尾形 龍紀</p>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <sectoion class=\"sec sec_3\" id=\"sec_company\">\n        <div class=\"inner\">\n            <div class=\"imgs\">\n                <ul class=\"lists\">\n                    <li><img src=\"https://shikokuiryoki.com/recruit/wp-content/themes/shikokuiryoki_recruit/images/about/item2.png\" alt=\"会社概要 イメージ\"></li>\n                    <li><img src=\"https://shikokuiryoki.com/recruit/wp-content/themes/shikokuiryoki_recruit/images/about/item3.png\" alt=\"会社概要 イメージ\"></li>\n                    <li><img src=\"https://shikokuiryoki.com/recruit/wp-content/themes/shikokuiryoki_recruit/images/about/item4.png\" alt=\"会社概要 イメージ\"></li>\n                </ul>\n            </div>\n            <div class=\"txt\">\n                <h3 class=\"sec_ttl\">会社概要</h3>\n                \n                <table class=\"table_style1\">\n                    <tbody>\n                        <tr>\n                            <th>商号</th>\n                            <td>四国医療器株式会社</td>\n                        </tr>\n                        <tr>\n                            <th>創業</th>\n                            <td>1935年6月1日</td>\n                        </tr>\n                        <tr>\n                            <th>代表者</th>\n                            <td>代表取締役社長　尾形 龍紀</td>\n                        </tr>\n                        <tr>\n                            <th>資本金</th>\n                            <td>2千800万円</td>\n                        </tr>\n                        <tr>\n                            <th>決算期</th>\n                            <td>年１回（３月）</td>\n                        </tr>\n                        <tr>\n                            <th>売上高</th>\n                            <td>\n                                <!--155億円（2021年度）-->\n                                <!--160億円（2022年度）-->\n                                175.4億円（2024年度）\n                            </td>\n                        </tr>\n                        <tr>\n                            <th>従業員数</th>\n                            <td>221名（2025年4月現在）</td>\n                        </tr>\n                        <tr>\n                            <th>役員</th>\n                            <td>\n                            代表取締役社長　尾形 龍紀<br>\n                            取締役　藤本 広一<br>\n                            取締役　北村 一樹<br>\n                            取締役　高橋 稔幸<br>\n                            取締役　尾形 昌徳<br>\n                            取締役（非常勤）　髙畠 雅彦<br>\n                            取締役（非常勤）　戸川 健司<br>\n                            監査役（非常勤）　岡田 幸士<br>\n                            </td>\n                        </tr>\n                        <tr>\n                            <th>取引銀行</th>\n                            <td>本社　中国銀行 高松支店・百十四銀行 高松支店・三菱UFJ銀行 高松支店<br>支店　四国銀行 下知支店</td>\n                        </tr>\n                        <tr>\n                            <th>事業内容</th>\n                            <td>医療機器及び理化学機器の総合商社</td>\n                        </tr>\n                        <tr>\n                            <th>取扱商品</th>\n                            <td>診断用機器、手術用機器、治療用機器、病院設備機器、在宅療養支援、\nディスポーザブル用品、検査用試薬、衛生材料、医療情報システム、理化学分析機器、\n研究室用機器、医療用ガス　等</td>\n                        </tr>                 \n                    </tbody>\n                </table>\n            </div>\n        </div>\n\n    </sectoion>\n   \n</main>\n<footer>\n    <div class=\"inner\">\n        <nav class=\"nav_pickup lists\">\n            <div>\n                <a href=\"https://job.mynavi.jp/28/pc/search/corp100267/outline.html\" target=\"_blank\">\n                    <div class=\"bg_w\">仕事体験情報掲載中</div>\n                    <div class=\"ttl\"><img src=\"https://shikokuiryoki.com/recruit/wp-content/themes/shikokuiryoki_recruit/images/footer-nav_1.svg\" alt=\"仕事体験情報\"></div>\n                </a>\n            </div>\n            <div>\n                <a href=\"https://job.mynavi.jp/27/pc/search/corp100267/outline.html\" target=\"_blank\">\n                    <div class=\"bg_w\">就職情報掲載中</div>\n                    <div class=\"ttl\"><img src=\"https://shikokuiryoki.com/recruit/wp-content/themes/shikokuiryoki_recruit/images/footer-nav_2.svg\" alt=\"就活情報\"></div>\n                </a>\n            </div>\n            <div>\n                <a href=\"https://shikokuiryoki.com/recruit/qa/\">\n                    <div class=\"bg_w\">よくある質問はこちら</div>\n                    <div class