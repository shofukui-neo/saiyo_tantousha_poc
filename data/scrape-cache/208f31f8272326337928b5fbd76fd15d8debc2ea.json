images/icons/arw_circle.svg\" alt=\"\" height=\"19\" width=\"18\" decoding=\"async\" loading=\"lazy\"></a></li>\n                    <li><a href=\"/recruit/requirement/#faq\" class=\"u-hover-arw\">よくある質問<img class=\"arw\" src=\"/recruit/assets/images/icons/arw_circle.svg\" alt=\"\" height=\"19\" width=\"18\" decoding=\"async\" loading=\"lazy\"></a></li>\n                    <li><a href=\"/recruit/meeting/\" class=\"u-hover-arw\">会社説明会のご案内<img class=\"arw\" src=\"/recruit/assets/images/icons/arw_circle.svg\" alt=\"\" height=\"19\" width=\"18\" decoding=\"async\" loading=\"lazy\"></a></li>\n                  </ul>\n                </div>\n              </div>\n            </div>\n          </li>\n        </ul>\n        <div class=\"l-gnav__cv\"><a class=\"c-btn-cv\" href=\"/recruit/entry/\"><span class=\"txt u-uppercase\">Entry</span></a></div>\n      </nav>\n    </div>\n  </div>\n</header>\n<div class=\"l-mega l-sm\">\n  <div class=\"l-inner\">\n    <div class=\"l-mega-nav\">\n      <ul class=\"l-mega-nav__menus\">\n        <li>\n          <div class=\"l-mega-nav__accord js-accordion-trigger\">\n            <div class=\"c-ttl-primary\"><span class=\"ttl-en\">Imagine Your Job</span> <span class=\"ttl-jp\">働くことをイメージしよう</span></div><button class=\"trigger\" aria-label=\"メニューを開く\"></button>\n          </div>\n          <div class=\"l-mega-nav__panel js-accordion-panel\">\n            <div>\n              <ul class=\"l-mega-nav__children\">\n                <li><a href=\"/recruit/work/\">若手社員インタビュー</a></li>\n                <li><a href=\"/recruit/work/#person\">こんな人と働きたい</a></li>\n                <li><a href=\"/recruit/work/#message\">人事部長メッセージ</a></li>\n              </ul>\n            </div>\n          </div>\n        </li>\n        <li>\n          <div class=\"l-mega-nav__accord js-accordion-trigger\">\n            <div class=\"c-ttl-primary\"><span class=\"ttl-en\">Career Design</span> <span class=\"ttl-jp\">キャリアデザイン</span></div><button class=\"trigger\" aria-label=\"メニューを開く\"></button>\n          </div>\n          <div class=\"l-mega-nav__panel js-accordion-panel\">\n            <div>\n              <ul class=\"l-mega-nav__children\">\n                <li><a href=\"/recruit/education/\">研修・育成</a></li>\n                <li><a href=\"/recruit/internship/\">インターンシップ</a></li>\n                <li><a href=\"/recruit/welfare/\">福利厚生</a></li>\n              </ul>\n            </div>\n          </div>\n        </li>\n        <li>\n          <div class=\"l-mega-nav__accord js-accordion-trigger\">\n            <div class=\"c-ttl-primary\"><span class=\"ttl-en\">Recruit</span> <span class=\"ttl-jp\">リクルート</span></div><button class=\"trigger\" aria-label=\"メニューを開く\"></button>\n          </div>\n          <div class=\"l-mega-nav__panel js-accordion-panel\">\n            <div>\n              <ul class=\"l-mega-nav__children\">\n                <li><a href=\"/recruit/requirement/\">募集要項</a></li>\n                <li><a href=\"/recruit/requirement/#faq\">よくある質問</a></li>\n                <li><a href=\"/recruit/meeting/\">会社説明会のご案内</a></li>\n              </ul>\n            </div>\n          </div>\n        </li>\n      </ul>\n    </div>\n    <div class=\"l-mega__btn\"><a href=\"/recruit/entry/\" class=\"c-btn-circle\"><span class=\"txt u-uppercase\">Entry</span> <img class=\"arw\" src=\"/recruit/assets/images/icons/arw_circle.svg\" alt=\"\" height=\"19\" width=\"18\" decoding=\"async\" loading=\"lazy\"></a></div>\n  </div>\n</div>\n    <div class=\"l-wrapper\">\n      <div class=\"l-content\"><!-- main -->\n        <main class=\"l-main\">\n          <div class=\"top-hero\">\n            <div class=\"top-hero__bg\">\n              <picture>\n                <source srcset=\"/recruit/assets/images//top/hero_visual_sp.webp\" media=\"(max-width: 767px)\" type=\"image/webp\">\n                <source srcset=\"/recruit/assets/images//top/hero_visual_sp.jpg\" media=\"(max-width: 767px)\">\n                <source srcset=\"/recruit/assets/images//top/hero_visual.webp\" type=\"image/webp\"><img src=\"/recruit/assets/images//top/hero_visual.jpg\" alt=\"\" class=\"lazy-none\" height=\"860\" width=\"2800\">\n              </picture>\n            </div>\n            <div class=\"top-hero__inner\">\n              <div class=\"top-hero__copy\">\n                <h2 class=\"copy-main\"><span class=\"ttl\">未来の働き方を<br class=\"l-sm\">デザインしよう</span></h2>\n                <div class=\"copy-sub u-uppercase\">\n                  <p>Design your Future of Work</p>\n                </div>\n              </div>\n            </div>\n            <div class=\"top-placeBnr l-lg\"><a href=\"/column/?tags%5B%5D=workplace\" target=\"_blank\" class=\"u-hover-scale\" rel=\"noopener noreferrer\" title=\"リンクを新規タブで開きます\">\n                <div class=\"top-placeBnr__bg frame\">\n                  <picture>\n                    <source srcset=\"/recruit/assets/images//top/bln_place.webp\" type=\"image/webp\"><img src=\"/recruit/assets/images//top/bln_place.jpg\" alt=\"\" height=\"232\" width=\"732\" decoding=\"async\" loading=\"lazy\">\n                  </picture>\n                </div>\n                <div class=\"top-placeBnr__txt\">\n                  <p class=\"txt\">みんなのワークプレイス</p>\n                  <div class=\"more\"><span>Show more<img class=\"arw\" src=\"/recruit/assets/images/icons/arw_wht.svg\" alt=\"\" height=\"16\" width=\"18\" decoding=\"async\" loading=\"lazy\"></span></div>\n                </div>\n              </a></div>\n          </div>\n          <section class=\"top-intro\">\n            <div class=\"l-inner\">\n              <div class=\"top-intro__content\">\n                <div class=\"top-intro__head\">\n                  <h2 class=\"ttl\">仕事を通じて<br class=\"l-lg\">成長しよう</h2>\n                </div>\n                <div class=\"top-intro__txt u-ta-justify\">\n                  <p class=\"u-mb-letter\">「オフィス」は今、課題であふれています。少子化による人材不足や、コロナ禍をきっかけとしたオフィス離れ・コミュニケーション低下など…、世の中の様々な変化により「オフィス」に求められる役割は変化し続けています。</p>\n                  <p>オフィス関連総合商社である私たちは、「シゴトバコンシェルジュ」としてお客様のお悩みに丁寧に寄り添うFace to Faceスタイルで快適なオフィスをご提案しています。仕事を通じて成長を実感しましょう。</p>\n                </div>\n              </div>\n              <div class=\"top-intro__bln -top\"></div>\n              <div class=\"top-intro__bln -bottom\"></div>\n            </div>\n          </section>\n          <div class=\"top-links\">\n            <div class=\"l-inner\">\n              <section class=\"l-sec js-scroll fadein\">\n                <h2 class=\"c-ttl-primary\"><span class=\"ttl-en\">Imagine Your Job</span> <span class=\"ttl-jp\">働くことをイメージしよう</span></h2>\n                <ul class=\"top-links__cards\">\n                  <li class=\"top-links__card\"><a href=\"/recruit/work/\" class=\"u-hover-scale\">\n                      <figure class=\"bg frame\">\n                        <picture>\n                          <source srcset=\"/recruit/assets/images//top/link_interview.webp\" type=\"image/webp\"><img src=\"/recruit/assets/images//top/link_interview.jpg\" alt=\"\" height=\"453\" width=\"828\" decoding=\"async\" loading=\"lazy\">\n                        </picture>\n                      </figure>\n                      <div class=\"card-inner\">\n                        <h3 class=\"ttl\">若手社員インタビュー</h3>\n                        <p class=\"lead\">さまざまな職場で<br>活躍する社員を通じて仕事を知ろう</p>\n                        <div class=\"more\"><span>Show more<img class=\"arw\" src=\"/recruit/assets/images/icons/arw_wht.svg\" alt=\"\" height=\"16\" width=\"18\" decoding=\"async\" loading=\"lazy\"></span></div>\n                      </div>\n                    </a></li>\n                  <li class=\"top-links__card\"><a href=\"/recruit/work/#person\" class=\"u-hover-scale\">\n                      <figure class=\"bg frame\">\n                        <picture>\n                          <source srcset=\"/recruit/assets/images//top/link_person.webp\" type=\"image/webp\"><img src=\"/recruit/assets/images//top/link_person.jpg\" alt=\"\" height=\"453\" width=\"828\" decoding=\"async\" loading=\"lazy\">\n                        </picture>\n                      </figure>\n                      <div class=\"card-inner\">\n                        <h3 class=\"ttl\">こんな人と働きたい</h3>\n                        <p class=\"lead\">ありがとうを追求し<br>行動できる人</p>\n                        <div class=\"more\"><span>Show more<img class=\"arw\" src=\"/recruit/assets/images/icons/arw_wht.svg\" alt=\"\" height=\"16\" width=\"18\" decoding=\"async\" loading=\"lazy\"></span></div>\n                      </div>\n                    </a></li>\n                  <li class=\"top-links__card\"><a href=\"/recruit/work/#message\" class=\"u-hover-scale\">\n                      <figure class=\"bg frame\">\n                        <picture>\n                          <source srcset=\"/recruit/assets/images//top/link_message.webp\" type=\"image/webp\"><img src=\"/recruit/assets/images//top/link_message.jpg\" alt=\"\" height=\"453\" width=\"828\" decoding=\"async\" loading=\"lazy\">\n                        </picture>\n                      </figure>\n                      <div class=\"card-inner\">\n                        <h3 class=\"ttl\">人事部長メッセージ</h3>\n                        <p class=\"lead\">学生の皆さん<br>一緒に働きましょう</p>\n                        <div class=\"more\"><span>Show more<img class=\"arw\" src=\"/recruit/assets/images/icons/arw_wht.svg\" alt=\"\" height=\"16\" width=\"18\" decoding=\"async\" loading=\"lazy\"></span></div>\n                      </div>\n                    </a></li>\n                </ul>\n              </section>\n              <section class=\"l-sec js-scroll fadein\">\n                <h2 class=\"c-ttl-primary\"><span class=\"ttl-en\">Career Design</span> <span class=\"ttl-jp\">キャリアデザイン</span></h2>\n                <ul class=\"top-links__cards\">\n                  <li class=\"top-links__card\"><a href=\"/recruit/education/\" class=\"u-hover-scale\">\n                      <figure class=\"bg frame\">\n                        <pi