tItem\">\n                <div class=\"siteHeader__listItemPlusBox js-puls\"><a class=\"siteHeader__listItemLink\" href=\"../../business/\">事業紹介<span class=\"siteHeader__listItemLinkSubText\">BUSINESS</span></a></div>\n              </div>\n              <div class=\"siteHeader__listItem\"> \n                <div class=\"siteHeader__listItemPlusBox js-puls\"><a class=\"siteHeader__listItemLink\" href=\"../../company/\">会社情報<span class=\"siteHeader__listItemLinkSubText\">CORPORATE</span></a><span class=\"siteHeader__pulsBtn\"></span></div>\n                <ul class=\"siteHeader__listContentMenu js-content\">\n                  <li class=\"siteHeader__listContentMenuItem\"> <a class=\"siteHeader__listContentMenuLink\" href=\"../../company/profile/\">会社概要</a></li>\n                  <li class=\"siteHeader__listContentMenuItem\"> <a class=\"siteHeader__listContentMenuLink\" href=\"../../company/greeting/\">社長挨拶</a></li>\n                  <li class=\"siteHeader__listContentMenuItem\"> <a class=\"siteHeader__listContentMenuLink\" href=\"../../company/history/\">沿革</a></li>\n                  <li class=\"siteHeader__listContentMenuItem\"> <a class=\"siteHeader__listContentMenuLink\" href=\"../../company/philosophy/\">企業理念</a></li>\n                <li class=\"siteHeader__listContentMenuItem\"> <a class=\"siteHeader__listContentMenuLink\" href=\"../../company/purpose/\">パーパス</a></li>\n                  <li class=\"siteHeader__listContentMenuItem\"> <a class=\"siteHeader__listContentMenuLink\" href=\"../../company/quality/\">品質 ・ 環境方針</a></li>\n                  <li class=\"siteHeader__listContentMenuItem\"> <a class=\"siteHeader__listContentMenuLink\" href=\"../../company/health/\">健康経営</a></li>\n                  <li class=\"siteHeader__listContentMenuItem\"> <a class=\"siteHeader__listContentMenuLink\" href=\"../../company/organization/\">組織図</a></li>\n                  <li class=\"siteHeader__listContentMenuItem\"> <a class=\"siteHeader__listContentMenuLink\" href=\"../../company/office/\">拠点一覧</a></li>\n                </ul>\n              </div>\n              <div class=\"siteHeader__listItem\"> \n                <div class=\"siteHeader__listItemPlusBox js-puls\"><a class=\"siteHeader__listItemLink\" href=\"../../recruit/\">採用情報<span class=\"siteHeader__listItemLinkSubText\">RECRUIT</span></a><span class=\"siteHeader__pulsBtn\"></span></div>\n                <ul class=\"siteHeader__listContentMenu js-content\">\n                  <li class=\"siteHeader__listContentMenuItem\"> <a class=\"siteHeader__listContentMenuLink\" href=\"../../recruit/facilities/\">JETがつくるもの・仕事の流れ</a></li>\n                  <li class=\"siteHeader__listContentMenuItem\"> <a class=\"siteHeader__listContentMenuLink\" href=\"../../recruit/workstyle/\">JETの働き方</a></li>\n                  <li class=\"siteHeader__listContentMenuItem\">\n                    <p class=\"siteHeader__listContentMenuLink-nolink\">PROJECT & PERSON</p>\n                  </li>\n                  <li class=\"siteHeader__listContentMenuItem\"><a class=\"siteHeader__listContentMenuLink-small\" href=\"../../recruit/interview_project1/\">PROJECT</a></li>\n                  <li class=\"siteHeader__listContentMenuItem\"><a class=\"siteHeader__listContentMenuLink-small\" href=\"../../recruit/interview_person1/\">PERSON 1</a></li>\n                  <li class=\"siteHeader__listContentMenuItem\"><a class=\"siteHeader__listContentMenuLink-small\" href=\"../../recruit/interview_person2/\">PERSON 2</a></li>\n                  <li class=\"siteHeader__listContentMenuItem\"><a class=\"siteHeader__listContentMenuLink-small\" href=\"../../recruit/interview_person3/\">PERSON 3</a></li>\n                  <li class=\"siteHeader__listContentMenuItem\"> <a class=\"siteHeader__listContentMenuLink\" href=\"../../recruit/graduate/\">募集要項</a></li>\n                  <li class=\"siteHeader__listContentMenuItem\"> <a class=\"siteHeader__listContentMenuLink\" href=\"../../recruit/faq/\">よくある質問</a></li>\n                </ul>\n              </div>\n              <div class=\"siteHeader__listItem\"> <a class=\"siteHeader__listItemLink-sp\" href=\"../../topics/\"><span class=\"siteHeader__listItemLinkTitle\">トピックス</span><span class=\"siteHeader__listItemLinkSubText\">TOPICS</span></a></div>\n              <div class=\"siteHeader__listItem\"> <a class=\"siteHeader__listItemLink-sp\" href=\"../../information_disclosure/\"><span class=\"siteHeader__listItemLinkTitle\">情報公開</span><span class=\"siteHeader__listItemLinkSubText\">INFORMATION DISCLOSURE</span></a></div>\n              <div class=\"siteHeader__listItem siteHeader__listItem-contact\"> <a class=\"siteHeader__listItemLink-sp\" href=\"../../inquiry/\"><span class=\"siteHeader__listItemLinkTitle\">お問い合わせ</span><span class=\"siteHeader__listItemLinkSubText\">CONTACT</span></a></div>\n            </div>\n          </div>\n        </nav>\n        <div class=\"siteHeader__humMenu js-humOpenBtn\"><span class=\"siteHeader__humMenuLine siteHeader__humMenuLine-first\"> </span><span class=\"siteHeader__humMenuLine siteHeader__humMenuLine-second\">  </span><span class=\"siteHeader__humMenuLine siteHeader__humMenuLine-third\">  </span></div>\n      </div>\n    </header>\n    <main class=\"main\" role=\"main\">\n      <div class=\"workstyle\">\n        <div class=\"workstyle__wrap\">\n          <div class=\"workstyle__inner\">\n            <div class=\"c-breadcrumb\">\n              <ul class=\"c-breadcrumb__list\"> \n                <li class=\"c-breadcrumb__listItem\"> <a class=\"c-breadcrumb__listItemLink\" href=\"../../\"><img class=\"c-breadcrumb__listItemHome\" src=\"../../_assets/images/common/icon_home.png\" alt=\"ホーム\"></a></li>\n                <li class=\"c-breadcrumb__listItem\"> <a class=\"c-breadcrumb__listItemLink\" href=\"../../recruit/\">採用情報（トップ）</a></li>\n                <li class=\"c-breadcrumb__listItem\"> <span class=\"c-breadcrumb__listItemText\">JETの働き方 </span></li>\n              </ul>\n              <div class=\"c-pageTitle workstyle__title\" data-aos=\"fade-up\">\n                <h1 class=\"c-decorativeSmallTitle-blue c-pageTitle__heading\">WORKSTYLE</h1>\n                <h2 class=\"c-heading-blue c-pageTitle__text workstyle__heading\">JETの働き方</h2>\n              </div>\n            </div>\n            <div class=\"workstyle__content\"> \n              <section class=\"workstyle__contentSec\" data-aos=\"fade-up\">\n                <div class=\"workstyle__contentitleBox\"> \n                  <h3 class=\"workstyle__contentSecTitle\">柔軟で働きやすい<br class=\"u-spDb\">職場環境づくりに注力</h3>\n                </div>\n                <div class=\"workstyle__contentSecFlex\"> \n                  <div class=\"workstyle__contentSecTextArea\">\n                    <p class=\"workstyle__contentSecText\">当社では、多様な価値観や個別のライフスタイルを尊重し、従業員一人ひとりが柔軟かつ安心して働ける環境づくりに力を入れて取り組んでいます。　特に、時間や場所に捉われない柔軟な働き方ついては、ワークライフバランスの観点だけではなく、生産性の向上や組織の活性化につながる手段としてトップダウンで推進しています。</p>\n                  </div>\n                  <div class=\"workstyle__contentSecImgArea\">\n                    <figure class=\"workstyle__contentSecImgBox\"> <img class=\"workstyle__contentSecImg\" src=\"../../_assets/images/lower/recruit/workstyle/workstyle_img01.jpg\" alt=\"サテライトオフィス\">\n                      <figcaption class=\"workstyle__contentSecImgText\">サテライトオフィス（東急株式会社・NewWork）</figcaption>\n                    </figure>\n                  </div>\n                </div>\n                <ul class=\"workstyle__contentSystemList\">\n                  <li class=\"workstyle__contentSystemListItem\">\n                    <p class=\"workstyle__contentSystemListTitle\">リモートワーク制度</p>\n                    <p class=\"workstyle__contentSystemListText\">従業員一人ひとりにモバイルPCとスマートフォンを支給し、<br class=\"u-pcDb\">在宅勤務やサテライトオフィスで働くことができる環境が整っています。</p>\n                  </li>\n                  <li class=\"workstyle__contentSystemListItem\">\n                    <p class=\"workstyle__contentSystemListTitle\">フレックスタイム制度</p>\n                    <p class=\"workstyle__contentSystemListText\">コアタイムのないフレックスタイム制度を運用しています。</p>\n                    <p class=\"workstyle__contentSystemListText\">始業と終業の時間を柔軟に選択することができ、効率的な働き方が可能です。</p>\n                  </li>\n                  <li class=\"workstyle__contentSystemListItem\">\n                    <p class=\"workstyle__contentSystemListTitle\">年次有給休暇取得促進</p>\n                    <p class=\"workstyle__contentSystemListText\">法律の基準を上回る22日を毎年付与しています。また、計画的に取得できる制度や、<br class=\"u-pcDb\">半日単位での取得の推進など、年次有給休暇の取得率の向上に力を入れています。</p>\n                    <p class=\"workstyle__contentSystemListText-big\">平均取得日数：17.7日（2024年度実績）</p>\n                  </li>\n                </ul>\n              </section>\n              <section class=\"workstyle__contentSec\" data-aos=\"fade-up\"> \n                <div class=\"workstyle__contentSecTitleBox\"> \n                  <h3 class=\"workstyle__contentSecTitle\">ライフステージに応じた<br class=\"u-spDb\">働き方を支援</h3>\n                  <p class=\"workstyle__contentSecTitle-sub\">子育てや介護と、仕事を両立しながら能力を最大限発揮して<br class=\"u-pcDb\">効率的に働けるような勤務制度を整備しています。</p>\n                </div>\n                <ul class=\"workstyle__contentSystemList\">\n                  <li class=\"workstyle__contentSystemListItem\">\n                    <p class=\"workstyle__contentSystemListTitle\">育児休業制度</p>\n                    <p class=\"workstyle__contentSystemListText\">法律の基準を上回る育児休業制度を整備しており、最大で子が３歳に達するまで取得することが可能です。</p>\n                  </li>\n                  <li class=\"workstyle__contentSystemListItem\">\n                    <p class=\"workstyle__contentSystemListTitle\">育児のための柔軟な勤務制度</p>\n                    <p class=\"workstyle__contentSystemListText\">所定就業時間を短縮する短時間勤務や時間外労働を制限する勤務など、<br class=\"u-pcDb\">柔軟な働き方を用意しており、子育てとの両立を支援しています。</p>\n                  </li>\n                  <li class=\"workstyle__contentSystemListItem\">\n                    <p class=\"workstyle__contentSystemListTitle\">介護休業制度</p>\n                    <p class=\"workstyle__contentSystemListText\">法律の基準を上回る介護休業制度を整備しており、最大で１年間取得することが可能です。</p>\n                  </li>\n                  <li class=\"workstyle__contentSystemListItem\">\n                    <p class=\"workstyle__contentSystemListTitle\">介護のための柔軟な勤務制度</p>\n                    <p class=\"workstyle__contentSystemListText\">育児のための柔軟な勤務制度と同様に、短時間勤務や時間外制限勤務が可能な体制を整備しています。</p>\n                  </li>\n                </ul>\n                <figure class=\"workstyle__contentSecImgBox-full\"> <img class=\"workstyle__contentSecImg\" src=\"../../_assets/images/lower/recruit/workstyle/workstyle_img02.jpg\" alt=\"柔軟で働きやすい職場環境づくりに注力\"></figure>\n              </section>\n              <section class=\"workstyle__contentSec\" data-aos=\"fade-up\"> \n                <div class=\"workstyle__contentSecTitleBox\"> \n                  <h3 class=\"workstyle__contentSecTitle\">福利厚生</h3>\n                </div>\n                <ul class=\"workstyle__contentSystemList-second\"> \n                  <li class=\"workstyle__contentSystemListItem\">\n                    <p class=\"workstyle__contentSystemListTitle\">昼食費補助制度</p>\n                    <p class=\"workstyle__contentSystemListText\">毎月の給与で昼食費の一部を補助する手当を支給しています。</p>\n                  </li>\n                  <li class=\"workstyle__contentSystemListItem\">\n                    <p class=\"workstyle__contentSystemListTitle\">資格取得支援制度</p>\n                    <p class=\"workstyle__contentSystemListText\">業務上必要な資格の取得を奨励しており、受験費用の補助や報奨一時金を支給する制度が整っています。</p>\n                  </li>\n                </ul>\n                <figure class=\"workstyle__contentSecImgBox-full\"> <img class=\"workstyle__contentSecImg\" src=\"../../_assets/images/lower/recruit/workstyle/workstyle_img03.jpg\" alt=\"福利厚生\"></figure>\n              </section>\n            </div>\n            <div class=\"workstyle__content-second\" data-aos=\"fade-up\"> \n              <div class=\"workstyle__contentSecTitleBox-none\"> \n                <h3 class=\"workstyle__contentSecTitle\">JETの教育・研修</h3>\n                <p class=\"workstyle__contentSecTitle-sub\">当社では従業員一人ひとりのキャリア開発の支援に力を入れており、教育・研修メニューの拡充を図っています。職位に応じたスキルの習得を目的とした階層別研修から、職域に関連した能力を深めることができる専門・技術研修、英語教育に至るまで幅広いプログラムをご用意。<br class=\"u-pcDb\">自己啓発支援も充実しており、学習意欲のある従業員を手厚くサポートしています。</p>\n              </div>\n              <figure class=\"workstyle__contentSecImgBox-educate\"><img class=\"workstyle__contentSecImg-educate\" src=\"../../_assets/images/lower/recruit/workstyle/workstyle_img04-pc.png\" alt=\"JETの教育・研修\"></figure>\n              <figure class=\"workstyle__contentSecImgBox-educate-sp\"><img class=\"workstyle__contentSecImg-educate\" src=\"../../_assets/images/lower/recruit/workstyle/workstyle_img04.png\" alt=\"JETの教育・研修\"></figure>\n              <div class=\"workstyle__recruitBtn\"><a class=\"c-recruit__btn\" href=\"../../recruit/\">採用トップへ戻る </a></div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </main>\n    <footer class=\"siteFooter\">\n      <div class=\"siteFooter__outer js-changeWidth\">\n        <div class=\"siteFooter__wrap\">\n          <div class=\"siteFooter__inner\">\n            <div class=\"siteFooter__logoBox\"><a class=\"siteFooter__logoLink\" href=\"../../\"><img class=\"siteFooter__logo\" src=\"../../_assets/images/common/footer_logo-pc.png\" alt=\"JFE環境テクノロジー株式会社\"></a></div>\n            <nav class=\"siteFooter__nav\" role=\"navigation\">\n              <ul class=\"siteFooter__list\"> \n                <li class=\"siteFooter__listItem\"><a class=\"siteFooter__listItemLink\" href=\"../../\">ホーム</a></li>\n                <li class=\"siteFooter__listItem\"> <a class=\"siteFooter__listItemLink\" href=\"../../business/\">事業紹介</a></li>\n                <li class=\"siteFooter__listItem\"> <a class=\"siteFooter__listItemLink\" href=\"../../company/\">会社情報</a></li>\n                <li class=\"siteFooter__listItem\"> <a class=\"siteFooter__listItemLink\" href=\"../../recruit/\">採用情報</a></li>\n                <li class=\"siteFooter__listItem\"> <a class=\"sit