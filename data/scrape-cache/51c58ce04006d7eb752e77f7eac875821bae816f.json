{"url":"https://www.aeondelight.co.jp/jobs/highschool/","html":" <!doctype html>\r\n<html lang=\"ja\">\r\n<head>\r\n<meta charset=\"utf-8\" />\r\n<meta http-equiv=\"Content-Style-Type\" content=\"text/css\" />\r\n<meta http-equiv=\"Content-script-type\" content=\"text/javascript\" />\r\n<meta name=\"format-detection\" content=\"telephone=no\">\r\n<meta name=\"viewport\" content=\"width=device-width\">\r\n<meta name=\"description\" content=\"イオングループのサービス事業を担うイオンディライト株式会社の高校生採用サイトです。\">\r\n<title>高校生採用サイト｜イオンディライト株式会社</title>\r\n<meta property=\"og:title\" content=\"高校生採用サイト｜イオンディライト株式会社\">\r\n<meta property=\"og:site_name\" content=\"高校生採用サイト｜イオンディライト株式会社\">\r\n<meta property=\"og:description\" content=\"イオングループのサービス事業を担うイオンディライト株式会社の高校生採用サイトです。\">\r\n<meta property=\"og:type\" content=\"website\">\r\n<meta property=\"og:image\" content=\"/highschool/img/ogp.jpg\">\r\n<meta property=\"og:url\" content=\"https://www.aeondelight.co.jp/highschool/\">\r\n<meta property=\"og:locale\" content=\"ja_JP\">\r\n<meta name=\"format-detection\" content=\"telephone=no\">\r\n\t\r\n<!-- このページで使用するcssを読み込む -->\r\n<link rel=\"icon\" type=\"image/x-icon\" href=\"/jobs/common/img/favicon.ico\">\r\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/yakuhanjp@4.1.1/dist/css/yakuhanjp.css\">\r\n<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\r\n<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\r\n<link href=\"https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@100..900&family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap\" rel=\"stylesheet\">\r\n\t\r\n<link href=\"https://unpkg.com/aos@2.3.1/dist/aos.css\" rel=\"stylesheet\">\r\n<link rel=\"stylesheet\" type=\"text/css\" href=\"css/style.css\" media=\"all, projection, print\" />\r\n<link rel=\"stylesheet\" type=\"text/css\" href=\"https://cdnjs.cloudflare.com/ajax/libs/Modaal/0.4.4/css/modaal.