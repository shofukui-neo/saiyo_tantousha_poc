deUp(300);\r\n\t\t\t// $(\".accordion-btn\").not(this).find(\".accordion-more-btn\").removeClass(\"active\");\r\n\t\t});\r\n\t});\r\n</script>\r\n\r\n<script>\r\n\twindow.addEventListener('popstate', function(event) {\r\n\t\tlocation.reload();\r\n\t});\r\n</script>\r\n\r\n<script>\r\n\tdocument.addEventListener('DOMContentLoaded', function() {\r\n\t\tconst btnBorder = document.querySelector('.btn-border');\r\n\t\tconst header = document.querySelector('.header');\r\n\t\tconst innerContent = document.querySelector('.hamburger-inner-content');\r\n\t\tconst Body = document.querySelector('body');\r\n\r\n\t\t// .btn-border をクリックしたときに is-active をトグル\r\n\t\tbtnBorder.addEventListener('click', function() {\r\n\t\t\theader.classList.toggle('is-active');\r\n\t\t\tinnerContent.classList.toggle('is-active');\r\n\t\t\tBody.classList.toggle('is-active');\r\n\t\t});\r\n\t});\r\n\r\n</script>\r\n\r\n\r\n<script>\r\n\t// スマホ表示時のサブメニューの開閉\r\n\t$(document).ready(function() {\r\n\t\t// スマホ表示かどうかを判定する関数\r\n\t\tfunction isMobile() {\r\n\t\t\treturn $(window).width() <= 1024;\r\n\t\t}\r\n\t\t// 最初のチェック\r\n\t\tif (isMobile()) {\r\n\t\t\t$('.category-title-res').on('click', function() {\r\n\t\t\t\t$(this).toggleClass('open');\r\n\t\t\t\t$(this).next('.page-navi-list').slideToggle();\r\n\t\t\t});\r\n\t\t}\r\n\t\t// ウィンドウリサイズ時の処理\r\n\t\t$(window).resize(function() {\r\n\t\t\tif (isMobile()) {\r\n\t\t\t\t$('.category-title-res').off('click').on('click', function() {\r\n\t\t\t\t\t$(this).toggleClass('open');\r\n\t\t\t\t\t$(this).next('.page-navi-list').slideToggle();\r\n\t\t\t\t});\r\n\t\t\t} else {\r\n\t\t\t\t$('.category-title-res').off('click').removeClass('open');\r\n\t\t\t\t$('.page-navi-list').show();\r\n\t\t\t}\r\n\t\t});\r\n\t});\r\n</script>\r\n\r\n<script>\r\n\tjQuery(function(){\r\n\t\t$('.modal').modaal();\r\n\t});\r\n</script>\r\n\r\n<!-- ページ内リンクスクロール設定 -->\r\n<script>\r\n\t$('a[href^=\"#\"]').click(function () {\r\n\t\t  const speed = 500;\r\n\t\t  let href = $(this).attr(\"href\");\r\n\t\t  let target = $(href == \"#\" || href == \"\" ? \"html\" : href);\r\n\t\t  let position = target.offset().top;\r\n\t\t  $(\"body,html\").animate({ scrollTop: position }, speed, \"swing\");\r\n\t\t  return false;\r\n\t\t});\r\n\t\r\n</script>\r\n\r\n\r\n\r\n\t<script>\r\n\t\t$(document).ready(function(){\r\n\t\t\t$(\".menu-box\").each(function(index) {\r\n\t\t\t\t$(this).hover(\r\n\t\t\t\t\tfunction() {\r\n\t\t\t\t\t\t$(\".menu-container\").addClass(\"bg-\" + index);\r\n\t\t\t\t\t},\r\n\t\t\t\t\tfunction() {\r\n\t\t\t\t\t\t$(\".menu-container\").removeClass(\"bg-\" + index);\r\n\t\t\t\t\t}\r\n\t\t\t\t);\r\n\t\t\t});\r\n\t\t});\r\n\t</script>\r\n\r\n</body>\r\n</html>","finalUrl":"https://www.iwatani.co.jp/jpn/recruit/career/","rendered":false,"_cachedAt":"2026-06-23T18:01:15.027Z"}