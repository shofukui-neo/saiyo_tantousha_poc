8\";\n  fjs.parentNode.insertBefore(js, fjs);\n}(document, 'script', 'facebook-jssdk'));</script>\n\n    <div class=\"site fb fb-like\">\n      <div class=\"fb-like\" data-href=\"https://www.city.shimada.shizuoka.jp/gyosei-docs/2024syokuininterviewtop.html\" data-layout=\"button_count\" data-action=\"like\"></div>\n    </div>\n\n    <div class=\"site fb fb-share\">\n      <div class=\"fb-share-button\" data-href=\"https://www.city.shimada.shizuoka.jp/gyosei-docs/2024syokuininterviewtop.html\" data-layout=\"button_count\"></div>\n    </div>\n\n    <div class=\"site twitter\">\n      <a href=\"https://twitter.com/share\" class=\"twitter-share-button\" data-url=\"https://www.city.shimada.shizuoka.jp/gyosei-docs/2024syokuininterviewtop.html\">ツイート</a>\n      <script>!function(d,s,id){var js,fjs=d.getElementsByTagName(s)[0],p=/^http:/.test(d.location)?'http':'https';\n      if(!d.getElementById(id)){js=d.createElement(s);js.id=id;js.src=p+'://platform.twitter.com/widgets.js';\n      fjs.parentNode.insertBefore(js,fjs);}}(document, 'script', 'twitter-wjs');</script>\n    </div>\n\n</div>\n\r\n              </div>\r\n              \r\n              <header class=\"released\">更新日：<time datetime=\"2024-06-12\">2024年6月12日</time></header>\r\n              \r\n              <div class=\"article_tit01\">令和5-6年度職員インタビュー（記事＆動画）</div>\r\n              \r\n              <div class=\"article_txt01\">\r\n                <!-- layout_yield -->    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n      \n    <article class=\"body\">\n      <h2>令和5-6年度職員インタビュー（令和6年6月12日更新）</h2>\r\n\r\n<p>島田市役所で働く若手職員へのインタビューや土木技術のお仕事紹介動画を公開しました！<br />\r\n受験したきっかけや業務内容、プライベートの過ごし方などを記事＆動画形式でそれぞれご紹介します。<br />\r\n島田市役所の受験を考えている方、公務員に興味のある方はぜひご覧ください！</p>\r\n\r\n<p><a href=\"https://www.youtube.com/@shimadacityjinji/videos\">「YouTube人事課公式チャンネル」はこちら</a></p>\r\n\r\n<h2>島田市の概要動画</h2>\r\n\r\n<p>YouTube島田市役所人事課公式チャンネルに島田市の概要説明の動画を公開</p>\r\n\r\n<p>ぜひご覧ください</p>\r\n\r\n<p><a href=\"https://www.youtube.com/watch?v=WKSQ7os1K9Q\"><img alt=\"R6.5.21setumeisiryou.jpg\" src=\"/fs/8/9/7/3/7/6/_/R6.5.21setumeisiryou.jpg\" style=\"width: 500px; height: 375px;\" /></a></p>\r\n\r\n<h2>島田市の職員談話</h2>\r\n\r\n<p><a href=\"https://www.youtube.com/watch?v=BexF9M_rECw\">職員採用説明会WEBの職員談話の動画</a></p>\r\n\r\n<p><a href=\"https://www.youtube.com/watch?v=BexF9M_rECw\"><img alt=\"1000003598.jpg\" src=\"/fs/8/9/8/0/5/4/_/1000003598.jpg\" style=\"width: 500px; height: 334px;\" /></a></p>\r\n\r\n<p>&nbsp;</p>\r\n\r\n<h2>職員インタビュー（記事）</h2>\r\n\r\n<p>&nbsp;</p>\r\n\r\n<p><a href=\"https://www.city.shimada.shizuoka.jp/gyosei-docs/2024syokuininterview01.html\"><img alt=\"komatsuA.JPG\" src=\"/fs/8/9/8/0/4/7/_/komatsuA.JPG\" /></a></p>\r\n\r\n<p>&nbsp;</p>\r\n\r\n<p><a href=\"https://www.city.shimada.shizuoka.jp/gyosei-docs/2024syokuininterview02.html\"><img alt=\"sibataA.JPG\" src=\"/fs/8/9/8/0/4/8/_/sibataA.JPG\" /></a></p>\r\n\r\n<p>&nbsp;</p>\r\n\r\n<p><a href=\"https://www.city.shimada.shizuoka.jp/gyosei-docs/2024syokuininterview03.html\"><img alt=\"watanabeA.JPG\" src=\"/fs/8/9/8/0/4/9/_/watanabeA.JPG\" /></a></p>\r\n\r\n<p>&nbsp;</p>\r\n\r\n<p>※バナーをクリックするとインタビュー記事（サイト内）に遷移します。</p>\r\n\r\n<p>&nbsp;</p>\r\n\r\n<p><a href=\"https://www.city.shimada.shizuoka.jp/fs/8/8/8/4/0/2/_/oishibutyo.pdf\">令和5年度大石行政経営部長インタビュー</a></p>\r\n\r\n<p><a href=\"https://www.city.shimada.shizuoka.jp/fs/8/8/8/4/0/2/_/oishibutyo.pdf\"><img alt=\"ooishigyouseikeieibutyo.JPG\" src=\"/fs/8/9/5/2/9/2/_/ooishigyouseikeieibutyo.JPG\" style=\"width: 500px; height: 334px;\" /></a></p>\r\n\r\n<h2>職員インタビュー（動画）</h2>\r\n\r\n<p><a href=\"https://www.youtube.com/watch?v=qRjLtWO9Xa8\"><img alt=\"20240301_152129_0000.png\" src=\"/fs/8/9/5/2/9/3/_/20240301_152129_0000.png\" style=\"width: 500px; height: 281px;\" /></a></p>\r\n\r\n<p>&nbsp;</p>\r\n\r\n<p><a href=\"https://www.youtube.com/watch?v=Pau0tRFkCJo\"><img alt=\"20240301_152129_0001.png\" src=\"/fs/8/9/5/2/9/4/_/20240301_152129_0001.png\" style=\"width: 500px; height: 281px;\" /></a></p>\r\n\r\n<p>&nbsp;</p>\r\n\r\n<p><a href=\"https://www.youtube.com/watch?v=MqmvQ2tvm8M\"><img alt=\"20240301_152129_0002.png\" src=\"/fs/8/9/5/2/9/6/_/20240301_152129_0002.png\" style=\"width: 500px; height: 281px;\" /></a></p>\r\n\r\n<p>※バナーをクリックするとインタビュー動画（YouTube）に遷移します。</p>\r\n\r\n<h2>その他</h2>\r\n\r\n<p><a href=\"https://www.youtube.com/@shimadacityjinji/videos\">土木技術職員の仕事紹介動画も掲載「YouTube人事課公式チャンネル」はこちら</a></p>\r\n\r\n<p><a href=\"https://www.city.shimada.shizuoka.jp/gyosei-docs/dobokugijutsu.html\"><img alt=\"kensetsu.jpg\" src=\"/fs/8/9/5/2/9/7/_/kensetsu.jpg\" style=\"width: 500px; height: 283px;\" /></a></p>\r\n\r\n<p>&nbsp;</p>\r\n\r\n<p>各種SNSでも職員採用試験の情報や市役所の様子をお届けしています。ぜひフォローしてみてください！<br />\r\n（外部サイト・別ウィンドウで開きます。）</p>\r\n\r\n<ul>\r\n\t<li><a href=\"https://twitter.com/shimada_jinji\" target=\"_blank\">島田市役所人事課公式X（旧Twitter）</a></li>\r\n\t<li><a href=\"https://www.instagram.com/shimadajinji/\" target=\"_blank\">島田市役所人事課公式Instagram</a></li>\r\n</ul>\n    </article>\n\n    \n    \n    \n    <section class=\"categories\">\n  <header><h2>カテゴリー</h2></header>\n  <div class=\"nodes\">\n    <ul>\n      <li><a href=\"/gyosei/shisei/jinji/saiyo/\">採用情報</a></li>\n      <li><a href=\"/gyosei/shisei/jinji/saiyo/r6shiken/\">令和6年度実施「島田市職員採用試験」</a></li>\n      <li><a href=\"/gyosei/shisei/jinji/saiyo/interview/\">職員インタビュー</a></li>\n    </ul>\n  </div>\n</section>\n\n    \n    \n    \n    \n    \n\n\n\n\n\n\n\n  <footer class=\"contact\">\n    <h2>お問い合わせ</h2>\n      <p class=\"group\">行政経営部人事課任用・給与担当</p>\n      <dl class=\"tel\"><dt>電話:</dt><dd><a href=\"tel:0547367135\">0547-36-7135</a></dd></dl>\n      <dl class=\"fax\"><dt>Fax:</dt><dd>0547-37-7770</dd></dl>\n      <dl class=\"email\"><dt>E-Mail:</dt><dd><a href=\"mailto:jinji&#64;city&#46;shimada&#46;lg&#46;jp\">jinji&#64;city&#46;shimada&#46;lg&#46;jp</a></dd></dl>\n  </footer>\n\n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n\n<!-- /layout_yield -->\r\n              </div>\r\n              \r\n 