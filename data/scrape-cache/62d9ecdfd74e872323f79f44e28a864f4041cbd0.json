;&nbsp;<br class=\"br-sp\">TEL：0547-37-5111（代表）<br class=\"br-sp2\">FAX：0547-37-8200&nbsp;&nbsp;&nbsp;&nbsp;<br class=\"br-sp\">法人番号：6000020222097</p>\r\n  </div>\r\n  \r\n  <div class=\"footer_c\">\r\n    <p>Copyright©City of Shimada All rights Reserved.</p>\r\n  </div>\r\n  \r\n</div>\r\n<!-- end-skip-voice -->\r\n    \r\n    <script>\r\n      $(function() {\r\n        var pagetop = $('#page_top');\r\n        pagetop.hide();\r\n        $(window).scroll(function () {\r\n          if ($(this).scrollTop() > 500) {  //100pxスクロールしたら表示\r\n            pagetop.fadeIn();\r\n          } else {\r\n            pagetop.fadeOut();\r\n          }\r\n        });\r\n        pagetop.click(function () {\r\n          $('body,html').animate({\r\n            scrollTop: 0\r\n          }, 500); //0.5秒かけてトップへ移動\r\n          return false;\r\n        });\r\n      });\r\n    </script>\r\n    \r\n  \r\n  <script type=\"text/javascript\" src=\"/_Incapsula_Resource?SWJIYLWA=719d34d31c8e3a6e6fffd425f7e032f3&ns=15&cb=1111389186\" async></script></body>\n\n</html>\n","finalUrl":"https://www.city.shimada.shizuoka.jp/gyosei-docs/2024syokuininterviewtop.html","rendered":false,"_cachedAt":"2026-06-23T20:06:22.246Z"}