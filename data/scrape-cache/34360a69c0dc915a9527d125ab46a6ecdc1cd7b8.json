{"url":"https://www.suwa.sansha.co.jp/","html":"\r\n<!DOCTYPE html>\r\n<html lang=\"ja\">\r\n  <head prefix=\"og: http://ogp.me/ns# fb: http://ogp.me/ns/fb# website: http://ogp.me/ns/website#\">\r\n    <meta charset=\"UTF-8\">\r\n    <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\r\n    <meta name=\"viewport\" content=\"target-densitydpi=device-dpi, width=device-width, maximum-scale=1.0, user-scalable=yes\">\r\n    <title>株式会社諏訪三社電機｜ホーム</title>\r\n    <meta name=\"description\" content=\"株式会社諏訪三社電機はお客様のニーズにお応えし、高効率で信頼性の高い電源機器をご提案します。\">\r\n    <meta name=\"keywords\" content=\"カスタム電源,産業用電源,コンピュータ用電源,UPS,電子回路,諏訪三社電機\">\r\n    <meta name=\"author\" content=\"Suwa Sansha Electric\">\r\n\r\n    <link rel=\"stylesheet\" href=\"css/style.css\">\r\n    <link rel=\"stylesheet\" href=\"css/index.css\">\r\n    <link rel=\"stylesheet\" href=\"//maxcdn.bootstrapcdn.com/font-awesome/4.7.0/css/font-awesome.min.css\">\r\n    <link rel=\"stylesheet\" href=\"js/swiper/css/swiper.css\">\r\n    <link rel=\"stylesheet\" href=\"css/update.css\">\r\n    \r\n\r\n    <meta name=\"format-detection\" content=\"telephone=no\">\r\n\r\n    <!-- OGP -->\r\n    <meta property=\"og:site_name\" content=\"株式会社諏訪三社電機\">\r\n    <meta property=\"og:description\" content=\"株式会社諏訪三社電機オフィシャルサイト。電源装置等の電子機器の製造・販売について、小型化・コストダウン・フレキシブルなご対応などご要望にあわせてご提案いたします。\">\r\n    <meta property=\"og:type\" content=\"website\">\r\n    <meta property=\"og:url\" content=\"https://www.suwa.sansha.co.jp/\">\r\n    <meta property=\"og:image\" content=\"https://www.suwa.sansha.co.jp/images/opengraph.png\">\r\n    <meta property=\"og:locale\" content=\"ja\">\r\n    <!-- / OGP -->\r\n\r\n  <link rel=\"shortcut icon\" href=\"images/favicon.ico\">\r\n  <link rel=\"icon\" type=\"image/vnd.microsoft.icon\" href=\"images/favicon.ico\">\r\n\r\n  <!-- Global site tag (gtag.js) - Google Analytics -->\r\n  <script async src=\"https://www.googletagmanager.com/gtag/js?id=UA-86128310-2\"></script>\r\n  <script>\r\n    window.data