member_stories/kaneda/\">金田 汐美</a></li>\n              </ul>\n            </li>\n          </ul>\n          <ul class=\"nav-item\">\n            <li>\n              <span><a href=\"/recruit_info/work_style/\">WORK STYLE</a></span>\n              <ul class=\"lower\">\n                <li><a href=\"/recruit_info/work_style/suzaki/\">須﨑 久美子</a></li>\n                <li><a href=\"/recruit_info/work_style/taguchi/\">田口 晴基</a></li>\n                <li><a href=\"/recruit_info/work_style/nakashima/\">中島 知子</a></li>\n              </ul>\n            </li>\n          </ul>\n        </div>\n        <div class=\"footer-nav-wrap\">\n          <!--<ul class=\"nav-item\">\n            <li>\n              <span><a href=\"/recruit_info/work_style/\">WORK STYLE</a></span>\n              <ul class=\"lower\">\n                <li><a href=\"/recruit_info/work_style/suzaki/\">須﨑 久美子</a></li>\n                <li><a href=\"/recruit_info/work_style/taguchi/\">田口 晴基</a></li>\n                <li><a href=\"/recruit_info/work_style/nakashima/\">中島 知子</a></li>\n              </ul>\n            </li>\n          </ul> -->\n          <ul class=\"nav-item\">\n            <li>\n              <span><a href=\"/recruit_info/events/\">EVENT</a></span>\n              <ul class=\"lower\">\n                <li><a href=\"/recruit_info/events/\">イベント情報</a></li>\n                <li><a href=\"/recruit_info/events/\">イベントレポート</a></li>\n              </ul>\n            </li>\n          </ul>\n          <ul class=\"nav-item\">\n            <li><span><a href=\"/recruit_info/recruit/\">RECRUIT</a></span></li>\n          </ul>\n        </div>\n        <div class=\"footer-proof\">\n          <div class=\"proof-item\">\n            <div><img src=\"/mt-static/support/theme_static/recruit/images/common/jpx_prime.png\" alt=\"東京証券取引所 プライム市場、証券コード4763\"></div>\n            <span>当サイトは株式会社クリーク･アンド･リバー社（東京証券取引所 プライム市場、証券コード4763）が運営しています。</span>\n          </div>\n          <div class=\"proof-item\">\n            <div><a 