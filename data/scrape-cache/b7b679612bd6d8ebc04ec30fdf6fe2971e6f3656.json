{"url":"https://www.avantistaff.com/recruit/","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n<head prefix=\"og: http://ogp.me/ns# fb: http://ogp.me/ns/fb# article: http://ogp.me/ns/article#\">\n  <meta charset=\"UTF-8\">\n  <meta http-equiv=\"x-ua-compatible\" content=\"ie=edge\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n  <meta name=\"format-detection\" content=\"telephone=no\">\n  <meta name=\"description\" content=\"アヴァンティスタッフの自社採用ページです。人材派遣会社アヴァンティスタッフは、みずほ銀行・丸紅と30年以上の強いつながりを持つパーソルグループの総合人材サービス企業です。\">\n  <title>採用情報 | 派遣・人材派遣はアヴァンティスタッフ</title>\n  <link rel=\"icon\" type=\"image/vnd.microsoft.icon\" href=\"https://www.avantistaff.com/flont_screen/images/common/favicon.ico\">\n  <link rel=\"stylesheet\" href=\"https://www.avantistaff.com/flont_screen/css/style.css?20241016\">\n  <link rel=\"stylesheet\" href=\"https://www.avantistaff.com/flont_screen/css/page/recruit.css?20260326\">\n  <script src=\"https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js\"></script>\n\n  <!-- Webフォント -->\n  <script>\n    (function(d) {\n      var config = {\n        kitId: 'vza5aht',\n        scriptTimeout: 3000,\n        async: true\n      },\n      h=d.documentElement,t=setTimeout(function(){h.className=h.className.replace(/\\bwf-loading\\b/g,\"\")+\" wf-inactive\";},config.scriptTimeout),tk=d.createElement(\"script\"),f=false,s=d.getElementsByTagName(\"script\")[0],a;h.className+=\" wf-loading\";tk.src='https://use.typekit.net/'+config.kitId+'.js';tk.async=true;tk.onload=tk.onreadystatechange=function(){a=this.readyState;if(f||a&&a!=\"complete\"&&a!=\"loaded\")return;f=true;clearTimeout(t);try{Typekit.load(config)}catch(e){}};s.parentNode.insertBefore(tk,s)\n    })(document);\n  </script>\n<script>\n  (function(d) {\n    var config = {\n      kitId: 'pur8gpk',\n      scriptTimeout: 3000,\n      async: true\n    },\n    h=d.documentElement,t=setTimeout(function(){h.className=h.className.replace(/\\bwf-loading\\b/g,\"\")+\" wf-inactive\";},config.scriptTimeout),tk=d.createElement(\"script\"),f=false,s=d.getElementsByTagName(\"script\")[0],a;h.className+=\" wf-loading\";tk.src='https://use.typekit.net/'+config.kitId+'.js';tk.async=true;tk.onload=tk.onreadystatechange=function(){a=this.readyState;if(f||a&&a!=\"complete\"&&a!=\"loaded\")return;f=true;clearTimeout(t);try{Typekit.load(config)}catch(e){}};s.parentNode.insertBefore(tk,s)\n  })(document);\n</script>\n<!-- Google Tag Manager -->\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n})(window,document,'script','dataLayer','GTM-KGM9NH8');</script>\n<!-- End Google Tag Manager --></head>\n<body class=\"recruit\">\n<!-- Google Tag Manager (noscript) -->\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-KGM9NH8\"\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n<!-- End Google Tag Manager (noscript) -->\n<header>\n  <div class=\"header-recruit\">\n  <div class=\"header-recruit__inner\">\n    <div class=\"header-recruit__logo\">\n      <a href=\"https://www.avantistaff.com\"><img src=\"https://www.avantistaff.com/flont_screen/images/recruit/logo.svg\" alt=\"アヴァンティスタッフ\"></a>\n    </div><!-- /.header-recruit__logo -->\n    <div class=\"header-recruit__links\">\n      <ul class=\"header-recruit__list\">\n        <li><a href=\"#aboutus\">About</a></li>\n        <li><a href=\"#interview\">Interview</a></li>\n        <li><a href=\"#faq\">FAQ</a></li>\n      </ul>\n      \n      <div class=\"header-recruit__entry end\">\n        <a tabindex=\"-1\">新卒採用<br>現在募集<br class=\"sp\">していません</a>\n      </div>\n      <div class=\"header-recruit__entry\">\n        <a href=\"https://www.avantistaff.com/recruit/midcareerguide\">キャリア採用<br>エントリー</a>\n      </div>\n    </div><!-- /.header-recruit__links -->\n  </div><!-- /.header-recruit__inner -->\n</div><!-- /.header-recruit -->\n  <section class=\"recruit-mv\">\n    <div class=\"recruit-mv__catch\">\n      <h1 class=\"recruit-mv__ja\">あなたに合った価値を、ともに。</h1>\n    </div><!-- /.recruit-mv__catch -->\n  </section><!-- /.recruit-mv -->\n</header>\n\n<!-- お知らせ -->\n<section class=\"recruittop-news\">\n  <div class=\"recruittop-news__cont\">\n    <div class=\"recruittop-news__ttl\">\n      <div class=\"recruittop-news__ttlinner\">\n        <h2 class=\"recruittop-news__ttl--ja\">お知らせ</h2>\n        <p class=\"recruittop-news__ttl--en\">News</p>\n      </div><!-- /.recruittop-news__ttlinner -->\n    </div><!-- /.recruittop-news__ttl -->\n    <div class=\"recruittop-news__item\">\n      <ul class=\"recruittop-news__list\">\n        <li>\n          <span>\n            <!--<div class=\"recruittop-news__list--date\"></div>-->\n            <h3 class=\"recruittop-news__list--ttl\">【2027年度新卒採用】募集を終了いたしました。</h3>\n          </span>\n        </li>\n      </ul>\n    </div><!-- /.recruittop-news__item -->\n  </div><!-- /.recruittop-news__cont -->\n</section><!-- /.recruittop-news -->\n\n<main class=\"main\">\n  <!-- アヴァンティスタッフについて -->\n  <section class=\"recruittop-aboutus\" id=\"aboutus\">\n    <div class=\"recruit-ttl\">\n      <h2 class=\"recruit-ttl--ja\">アヴァンティスタッフについて</h2>\n      <p class=\"recruit-ttl--en\">About Us</p>\n    </div><!-- /.recruit-ttl -->\n    <!--<h3 class=\"recruittop-aboutus__subttl\">人材派遣、人材紹介、アウトソーシング、教育研修。</h3>-->\n    <p class=\"recruittop-aboutus__detail u-mt-3\">\n      アヴァンティスタッフは<br class=\"sp\">みずほ銀行・丸紅と30年以上の強いつながりを持つ<br class=\"sp\">パーソルグループの総合人材サービス企業です。<br>人材派遣、人材紹介、アウトソーシング、教育研修など<br class=\"sp\">幅広い事業により<br>企業の様々な課題解決をサポートしております。<br>「まずアヴァンティに聞いてみよう」と<br class=\"sp\">皆様に頼られる企業であり続けるべく、<br>日々“アヴァンティ（前進）“を続けてまいります。<br>「企業」と「求職者」の頼れるパートナーとして、<br class=\"sp\">私たちと一緒に「はたらく」を楽しみませんか？\n    </p>\n    <div class=\"recruittop-aboutus__entry\">\n      <div class=\"recruittop-aboutus__entrybtn\">\n        <h3>新卒採用</h3>\n        \n        <!-- /.recruittop-aboutus__entrybtn--halfway -->\n        <div class=\"recruittop-aboutus__entrybtn--double\">\n          <a href=\"\" class=\"btn btn-recruit end btn-recruit-entry normalbtn-arrow-turn--recruit\">\n            <div class=\"btn-recruit-item\">\n              <span>現在は募集していません</span>\n            </div>\n          </a>\n        </div>\n      </div><!-- /.recruittop-aboutus__entrybtn -->\n      <div class=\"recruittop-aboutus__entrybtn recruittop-aboutus__entrybtn--halfway\">\n        <h3>キャリア採用</h3>\n        <div class=\"recruittop-aboutus__entrybtn--double\">\n          <a href=\"https://www.avantistaff.com/recruit/midcareerguide\" class=\"btn btn-recruit btn-recruit-entry normalbtn-arrow-turn--recruit new\">\n            <div class=\"btn-recruit-item\">\n              <!--総合職（正社員）-->\n              <span>エントリー</span>\n            </div>\n          </a>\n        </div><!-- /.recruittop-aboutus__entrybtn--halfway -->\n      </div><!-- /.recruittop-aboutus__entrybtn -->\n    </div>\n  </section><!-- /.recruittop-aboutus -->\n\n  <!-- 社員インタビュー -->\n  <section class=\"recruittop-interview\" id=\"interview\">\n    <div class=\"recruit-ttl\">\n      <h2 class=\"recruit-ttl--ja\">社員インタビュー</h2>\n      <p class=\"recruit-ttl--en\">Interview</p>\n    </div><!-- /.recruit-ttl -->\n    <section class=\"recruittop-interview__cont\">\n      <div class=\"recruittop-interview__item recruittop-interview__item--first\">\n        <div class=\"recruittop-interview__meta recruittop-interview__meta--first\">\n          <h3 class=\"recruittop-interview__item--name\">営業<span>2017年 新卒入社</span></h3>\n        </div><!-- /.recruittop-interview__meta -->\n        <dl class=\"recruittop-interview__item--faq\">\n          <dt><span>Q.</span>入社の決め手は何ですか？</dt>\n          <dd>\n            就職活動の際は、「人」との関わりが多く、社会貢献度の高い業界を軸に動きました。営業職を志望したのは、自分自身の「人間力」を鍛えたかったから。みずほ銀行と丸紅と強いつながりを持つ当社であれば、大手企業の人事施策の一端にも携わることができ、「雇用創造」という面で、より社会貢献ができると考え、当社に入社しました。\n          </dd>\n        </dl>\n      </div><!-- /.recruittop-interview__item -->\n      <div class=\"recruittop-interview__img recruittop-interview__img--first\">\n        <img class=\"recruit-person__img\" src=\"https://www.avantistaff.com/flont_screen/images/recruit/interview0_a.png?20250623\" alt=\"人物のアイコン\">\n      </div><!-- /.recruittop-interview__img -->\n    </section><!-- /.recruittop-interview__cont -->\n    <section class=\"recruittop-interview__cont\">\n      <div class=\"recruittop-interview__item recruittop-interview__item--second\">\n        <div class=\"recruittop-interview__meta recruittop-interview__meta--second\">\n          <h3 class=\"recruittop-interview__item--name\">コーディ<br class=\"sp\">ネーター<span>2016年 入社</span></h3>\n        </div><!-- /.recruittop-interview__meta -->\n        <dl class=\"recruittop-interview__item--faq\">\n          <dt><span>Q.</span>仕事のやりがいは何ですか？</dt>\n          <dd>\n            私の業務は、求人と求職者をマッチングさせ、求職者の方にお仕事を紹介する仕事です。「働く」という、生活をするうえでとても重要なことの選択に関わらせていただくことが、大きなやりがいだと感じていますが、同時に責任も大きいと思っています。また、様々な職場環境や多様な価値観に触れることができるのは、人材業界ならではの面白みですね！\n          </dd>\n        </dl>\n      </div><!-- /.recruittop-interview__item -->\n      <div class=\"recruittop-interview__img recruittop-interview__img--second\">\n        <img class=\"recruit-person__img\" src=\"https://www.avantistaff.com/flont_screen/images/recruit/interview0_b.png?20250623\" alt=\"女性のシルエットアイコン\">\n      </div><!-- /.recruittop-interview__img -->\n    </section><!-- /.recruittop-interview__cont -->\n  </section><!-- /.recruittop-interview -->\n\n  <!-- よくあるご質問 -->\n  <section class=\"recruittop-faq\" id=\"faq\">\n    <div class=\"recruit-ttl\">\n      <h2 class=\"recruit-ttl--ja\">よくあるご質問</h2>\n      <p class=\"recruit-ttl--en\">FAQ</p>\n    </div><!-- /.recruit-ttl -->\n    <div class=\"recruittop-faq__inner recruittop-faq__tabarea\">\n      <ul class=\"recruittop-faq__tab\">\n        <li class=\"is-active\"><span>選考について</span></li>\n        <li>入社後について</li>\n      </ul>\n      <div class=\"recruittop-faq__selection recruittop-faq__panel is-show\" id=\"panel1\">\n        <dl class=\"recruittop-faq__cont\">\n          <dt class=\"toggle\">\n            <span class=\"recruittop-faq__q\">Q</span>\n            <span>選考はどのような流れで行われますか？</span>\n          </dt>\n          <dd class=\"toggle-cont\">\n            <div class=\"recruittop-faq__item\">\n              <span class=\"recruittop-faq__a\">A</span>\n              <span>\n                原則、書類選考→一次選考→二次選考＋Webテスト→最終選考となります。<br>\n                期間は1ヵ月前後を目安としています。\n              </span>\n            </div><!-- /.recruittop-faq__item -->\n          </dd>\n          <dt class=\"toggle\">\n            <span class=\"recruittop-faq__q\">Q</span>\n            <span>どのような服装で面接に伺えば良いですか。</span>\n          </dt>\n          <dd class=\"toggle-cont\">\n            <div class=\"recruittop-faq__item\">\n              <span class=\"recruittop-faq__a\">A</span>\n              <span>\n                当社はドレスコードを原則自由化しておりますので、ジャケットの着用等は不要です。\n              </span>\n            </div><!-- /.recruittop-faq__item -->\n          </dd>\n          <dt class=\"toggle\">\n            <span class=\"recruittop-faq__q\">Q</span>\n            <span>近年の採用状況を教えてください。</span>\n          </dt>\n          <dd class=\"toggle-cont\">\n            <div class=\"recruittop-faq__item\">\n              <span class=\"recruittop-faq__a\">A</span>\n              <span>\n                2024年度は、新卒採用4名、キャリア採用23名でした。\n              </span>\n            </div><!-- /.recruittop-faq__item -->\n          </dd>\n          <dt class=\"toggle\">\n            <span class=\"recruittop-faq__q\">Q</span>\n            <span>面接可能な時間帯について教えてください。</span>\n          </dt>\n          <dd class=\"toggle-cont\">\n            <div class=\"recruittop-faq__item\">\n              <span class=\"recruittop-faq__a\">A</span>\n              <span>\n                基本的には、平日の就業時間内で行っておりますが、難しい場合にはお気軽にご相談ください。\n              </span>\n            </div><!-- /.recruittop-faq__item -->\n          </dd>\n          <dt class=\"toggle\">\n            <span class=\"recruittop-faq__q\">Q</span>\n            <span>選考結果は必ず連絡いただけますか。</span>\n          </dt>\n          <dd class=\"toggle-cont\">\n            <div class=\"recruittop-faq__item\">\n              <span class=\"recruittop-faq__a\">A</span>\n              <span>\n                新卒採用・キャリア採用に関わらず、選考結果は必ずご連絡しております。<br>\n                選考状況によりますが、1週間以内を目途に合否連絡をさせていただいております。\n              </span>\n            </div><!-- /.recruittop-faq__item -->\n          </dd>\n        </dl><!-- /.recruittop-faq__cont -->\n      </div><!-- /.recruittop-faq__selection -->\n      <div class=\"recruittop-faq__join recruittop-faq__panel\" id=\"panel2\">\n        <dl class=\"recruittop-faq__cont\">\n          <dt class=\"toggle\">\n            <span class=\"recruittop-faq__q\">Q</span>\n            <span>入社後の研修はありますか？</span>\n          </dt>\n          <dd class=\"toggle-cont\">\n            <div class=\"recruittop-faq__item\">\n              <span class=\"recruittop-faq__a\">A</span>\n              <span>\n                新卒入社とキャリア採用で研修内容は異なりますが、業務知識の習得を目的とした研修は、入社時に必ず行います。\n              </span>\n            </div><!-- /.recruittop-faq__item -->\n          </dd>\n          <dt class=\"toggle\">\n            <span class=\"recruittop-faq__q\">Q</span>\n            <span>事前に必要な資格はありますか？</span>\n          </dt>\n          <dd class=\"toggle-cont\">\n            <div class=\"recruittop-faq__item\">\n              <span class=\"recruittop-faq__a\">A</span>\n              <span>\n                特にございません。\n              </span>\n            </div><!-- /.recruittop-faq__item -->\n          </dd>\n          <dt class=\"toggle\">\n            <span class=\"recruittop-faq__q\">Q</span>\n            <span>異動・転勤はありますか？</span>\n          </dt>\n          <dd class=\"toggle-cont\">\n            <div class=\"recruittop-faq__item\">\n              <span class=\"recruittop-faq__a\">A</span>\n              <span>\n                総合職は、会社の必要性に応じて異動や転勤の可能性はございます。<br>\n                但し、本社勤務者が社員の8割なので、転勤は頻繁ではございません。\n              </span>\n            </div><!-- /.recruittop-faq__item -->\n          </dd>\n          <dt class=\"toggle\">\n            <span class=\"recruittop-faq__q\">Q</span>\n            <span>仕事とプライベートを両立させることはできますか？</span>\n          </dt>\n          <dd class=\"toggle-cont\">\n            <div class=\"recruittop-faq__item\">\n              <span class=\"recruittop-faq__a\">A</span>\n              <span>\n                完全フレックスタイム制、ノー残業デー、時短制度等があり、従業員それぞれの生活スタイルに合ったかたちで仕事ができるような環境があります。\n              </span>\n            </div><!-- /.recruittop-faq__item -->\n          </dd>\n          <dt class=\"toggle\">\n            <span class=\"recruittop-faq__q\">Q</span>\n            <span>クラブ活動はありますか？</span>\n          </dt>\n          <dd class=\"toggle-cont\">\n            <div class=\"recruittop-faq__item\">\n              <span class=\"recruittop-faq__a\">A</span>\n              <span>\n                野球部とゴルフ部があります。クラブ活動を通じて業務で関わる人以外とも交流することができます。\n              </span>\n            </div><!-- /.recruittop-faq__item -->\n          </dd>\n        </dl><!-- /.recruittop-faq__cont -->\n      </div><!-- /.recruittop-faq__join -->\n    </div><!-- /.recruittop-faq__inner -->\n  </section><!-- /.recruittop-faq -->\n\n  <!-- 募集要項 -->\n  <section class=\"recruittop-requirement\">\n    <div class=\"recruit-ttl\">\n      <h2 class=\"recruit-ttl--ja\">募集要項</h2>\n      <p class=\"recruit-ttl--en\">Requirement</p>\n    </div><!-- /.recruit-ttl -->\n    <div class=\"recruittop-requirement__inner\">\n      <div class=\"recruittop-requirement__cont\">\n        <div class=\"recruittop-requirement__item recruittop-requirement__item--new\">\n          <div class=\"recruittop-requirement__individual\">\n            <h3 class=\"recruittop-requirement__ttl\">新卒採用</h3>\n            <div class=\"recruittop-requirement__btn\">\n\t\t\t\t      \n              <a href=\"\" class=\"btn btn-recruit end normalbtn-arrow-turn--recruit\">現在は募集していません</a>\n            </div>\n          </div><!-- /.recruittop-requirement__individual -->\n        </div><!-- /.recruittop-requirement__item -->\n        <div class=\"recruittop-requirement__item recruittop-requirement__item--halfway\">\n          <div class=\"recruittop-requirement__individual\">\n            <h3 class=\"recruittop-requirement__ttl\">キャリア採用</h3>\n            <div class=\"recruittop-requirement__btn\">\n              <a href=\"https://www.avantistaff.com/recruit/midcareerguide\" class=\"btn btn-recruit normalbtn-arrow-turn--recruit\">エントリー</a>\n            </div><!-- /.recruittop-requirement__btn -->\n          </div><!-- /.recruittop-requirement__individual -->\n        </div><!-- /.recruittop-requirement__item -->\n      </div><!-- /.recruittop-requirement__cont -->\n    </div><!-- /.recruittop-requirement__inner -->\n  </section><!-- /.recruittop-requirement -->\n</main>\n\n<footer>\n  <!-- recruitフッター -->\n<section class=\"footer-recruit\">\n  <div class=\"footer-recruit__cont\">\n    <figure class=\"footer-recruit__logo\">\n      <a href=\"https://www.avantistaff.com\"><img src=\"https://www.avantistaff.com/flont_screen/images/recruit/ft-logo.svg\" alt=\"アヴァンティスタッフ\"></a>\n    </figure>\n    <ul class=\"footer-recruit__links\">\n      <li><a href=\"https://www.avantistaff.com/corporate/privacypolicy\">個人情報保護方針</a></li>\n      <li><a href=\"https://www.avantistaff.com/corporate/outline\">会社概要</a></li>\n    </ul>\n  </div><!-- /.footer-recruit__cont -->\n\n  <!-- コピーライト -->\n  <div class=\"copyright copyright--recruit\">\n    <p class=\"copyright__txt copyright__txt--corporate\">&copy;2026 <a href=\"https://www.avantistaff.com\">株式会社アヴァンティスタッフ</a> All rights reserved.</p>\n  </div>\n</section><!-- /.footer-recruit -->\n\n<!-- ページトップ -->\n<div class=\"pagetop\">\n  <button class=\"pagetop-btn\">\n    <img src=\"https://www.avantistaff.com/flont_screen/images/recruit/pagetop.svg\" alt=\"ページトップ\">\n  </button>\n</div><!-- /.pagetop -->\n</footer>\n\n<script src=\"https://www.avantistaff.com/flont_screen/js/pagetop.js\"></script>\n<script src=\"https://www.avantistaff.com/flont_screen/js/internal.js\"></script>\n<script src=\"https://www.avantistaff.com/flont_screen/js/tab.js\"></script>\n<script src=\"https://www.avantistaff.com/flont_screen/js/toggle.js\"></script>\n\n<script src=\"/flont_screen/js/common.js?20220801\"></script>\n</body>\n</html>\n","finalUrl":"https://www.avantistaff.com/recruit/","rendered":false,"_cachedAt":"2026-06-14T19:23:36.252Z"}