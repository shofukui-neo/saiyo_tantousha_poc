{"url":"https://www.iyobank.co.jp/career/comeback.html","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n\n<head prefix=\"og: http://ogp.me/ns# fb: http://ogp.me/ns/fb# article: http://ogp.me/ns/article#\">\n<meta charset=\"utf-8\">\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n<!-- InstanceBeginEditable name=\"doctitle\" -->\n<title>行員再雇用（カムバック）制度｜採用情報｜伊予銀行</title>\n<meta name=\"description\" content=\"伊予銀行の行員再雇用（カムバック）制度のページです。新卒採用や中途採用、いよぎんスタッフ（パートタイマー）など、共に働く方を募集しています。\">\n<meta name=\"keywords\" content=\"\">\n<!-- InstanceEndEditable -->\n<meta name=\"viewport\" content=\"width=device-width\">\n<meta name=\"format-detection\" content=\"telephone=no\">\n<!-- InstanceBeginEditable name=\"addMETA\" -->\n<meta property=\"og:type\" content=\"article\">\n<meta property=\"og:title\" content=\"行員再雇用（カムバック）制度｜採用情報｜伊予銀行\">\n<meta property=\"og:description\" content=\"伊予銀行の行員再雇用（カムバック）制度のページです。新卒採用や中途採用、いよぎんスタッフ（パートタイマー）など、共に働く方を募集しています。\">\n<meta property=\"og:url\" content=\"https://www.iyobank.co.jp/career/comeback.html\">\n<meta property=\"og:image\" content=\"https://www.iyobank.co.jp/common/images/og_image.png\">\n<meta property=\"og:site_name\" content=\"伊予銀行\">\n<meta property=\"og:locale\" content=\"ja_JP\">\n<!-- InstanceEndEditable -->\n<link rel=\"shortcut icon\" href=\"/common/img/symbol/favicon.ico\">\n<link rel=\"apple-touch-icon-precomposed\" href=\"/common/img/symbol/apple-touch-icon.png\">\n<!-- InstanceBeginEditable name=\"addLINK\" -->\n<link rel=\"canonical\" href=\"https://www.iyobank.co.jp/career/comeback.html\">\n<!-- InstanceEndEditable -->\n<link rel=\"stylesheet\" href=\"/common/css/base.css\">\n<!-- InstanceBeginEditable name=\"addCSS_LIB\" --><!-- InstanceEndEditable -->\n<link rel=\"stylesheet\" href=\"/common/plugin/slick/slick.css\">\n<link rel=\"stylesheet\" href=\"/common/plugin/colorbox/colorbox.css\">\n<!-- InstanceBeginEditable name=\"addCSS_PLUGIN\" --><!-- InstanceEndEditable -->\n<link rel=\"stylesheet\" href=\"/common/css/layout_pc.css\">\n<link rel=\"stylesheet\" href=\"/common/css/layout_sp.css\">\n<link rel=\"stylesheet\" href=\"/common/css/parts_pc.css\">\n<link rel=\"stylesheet\" href=\"/common/css/parts_sp.css\">\n<!-- InstanceBeginEditable name=\"addCSS\" -->\n<link rel=\"stylesheet\" href=\"/common/css/jin.css\">\n<!-- InstanceEndEditable -->\n<script src=\"/common/lib/jquery.js\"></script>\n<!-- InstanceBeginEditable name=\"addJS_LIB\" --><!-- InstanceEndEditable -->\n<script src=\"/common/plugin/slick/slick.js\"></script>\n<script src=\"/common/plugin/colorbox/jquery.colorbox.js\"></script>\n<script src=\"/common/plugin/cookie/js.cookie.min.js\"></script>\n<!-- InstanceBeginEditable name=\"addJS_PLUGIN\" --><!-- InstanceEndEditable -->\n<script src=\"/common/js/common.js\"></script>\n<script src=\"/common/js/listhing-entry.js\"></script>\n<script src=\"/common/js/analytics.js\"></script>\n<!-- InstanceBeginEditable name=\"addJS\" -->\n<script src=\"/common/js/jin.js\"></script>\n<!-- InstanceEndEditable -->\n<!-- InstanceParam name=\"isPageGuide\" type=\"boolean\" value=\"true\" -->\n<!-- InstanceParam name=\"isContainerSidebar\" type=\"boolean\" value=\"true\" -->\n<!-- InstanceParam name=\"varCategory\" type=\"text\" value=\"kojin\" -->\n<!-- InstanceParam name=\"varClass\" type=\"text\" value=\"\" -->\n<!-- InstanceParam name=\"isSystemContainer\" type=\"boolean\" value=\"true\" -->\n<!-- InstanceBeginEditable name=\"addHEAD_END\" --><!-- InstanceEndEditable -->\n<script src=\"/common/js/recommend.js\"></script>\n<!-- Fair-Navi アクセシビリティツール -->\n<script src=\"/fairnavi/loader.js\" data-fairnavi=\"ovuqymoy\" defer></script>\n</head>\n<body>\n<!-- Google Tag Manager (noscript) -->\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-MR6M7ZZ\"\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n<!-- End Google Tag Manager (noscript) -->\n<!-- InstanceBeginEditable name=\"addBODY_START\" --><!-- InstanceEndEditable -->\n<header id=\"header\" class=\"Header\">\n  <div class=\"header-identity\">\n    <h1 class=\"identity_logo\"><a href=\"/\"><img src=\"/common/img/com_logo01.png\" alt=\"伊予銀行\"></a></h1>\n    <p class=\"identity_code\">金融機関コード:0174</p>\n  </div>\n  <div class=\"header-nav-body\">\n    <div class=\"header-nav_home\"><a href=\"/\">トップへ戻る</a></div>\n    <div class=\"header-nav_inner\">\n      <div class=\"header-button-close\">閉じる</div>\n      <div class=\"header-utility\">\n        <ul class=\"header-utility_link\" data-row-sp=\"2\">\n          <li><a href=\"/otoiawase/\">お問い合わせ・ご相談</a></li>\n          <li><a href=\"https://help.iyobank.co.jp/\">よくあるご質問</a></li>\n          <li><a href=\"/glossary/\">用語集</a></li>\n          <li><a href=\"/site-map.html\">サイトマップ</a></li>\n          <li><a href=\"/english/\">English</a></li>\n        </ul>\n      </div>\n      <nav id=\"gnav01\" class=\"gnav-primary\">\n        <ul class=\"gnavList\" data-row-sp=\"auto\">\n          <li class=\"gnav_kojin\"><a href=\"/\"><span>個人のお客さま</span></a></li>\n          <li class=\"gnav_hojin\"><a href=\"/business/\"><span>法人・個人事業主のお客さま</span></a></li>\n          <li><a href=\"/about/\"><span>企業・IR・サステナビリティ</span></a></li>\n          <li class=\"is-current\"><a href=\"/career/\"><span>採用情報</span></a></li>\n        </ul>\n      <!--/Gnav--></nav>\n      <nav id=\"gnav02\" class=\"gnav-secondary\">\n        <div class=\"gnav-heading\">\n          <h2 class=\"gnav-heading_title\">採用情報</h2>\n          <p class=\"gnav-heading_link\"><a href=\"/career/\">一覧</a></p>\n        </div>\n        <ul class=\"gnavList\" data-row-pc=\"4\" data-row-sp=\"1\">\n          <li><a href=\"/career/shinsotsu/\"><span>新卒採用</span></a></li>\n          <li><a href=\"/career/employment.html\"><span>キャリア採用</span></a></li>\n          <li class=\"is-current\"><a href=\"/career/comeback.html\"><span>行員再雇用（カムバック）制度</span></a></li>\n          <li><a href=\"/career/staff.html\"><span>パートタイマー採用</span></a></li>\n        </ul>\n      <!--/Gnav--></nav>\n      <nav id=\"gnav03\" class=\"gnav-other\">\n        <ul class=\"gnavList\">\n          <li class=\"ic_0305\"><a href=\"/kinri-gaikokukawasesoba-market/\"><span>金利・外国為替相場</span></a></li>\n          <li class=\"ic_0301\"><a href=\"/simulation.html\"><span>お申し込み・<br>シミュレーション</span></a></li>\n          <li class=\"ic_0302\"><a href=\"/otoiawase/\"><span>お問い合わせ・<br>ご相談</span></a></li>\n          <li class=\"ic_0304\"><a href=\"/tesuryo/\"><span>手数料一覧</span></a></li>\n          <li class=\"ic_0303\"><a href=\"https://help.iyobank.co.jp/\" target=\"_blank\"><span>よくあるご質問</span></a></li>\n          <li class=\"ic_0306\"><a href=\"/form/voice/agree\"><span class=\"link_label\">ご意見・ご要望</span></a></li>\n        </ul>\n      </nav>\n    </div>\n  <!-- /.header-nav-body --></div>\n  <ul class=\"header-ui-list\">\n    <li class=\"header-ui_search\">\n      <a href=\"javascript:void(0);\" class=\"js-header-serchTrigger\" data-targetHref=\"#headerSearch\"><span class=\"list_label\">検索</span></a>\n    </li>\n    <li class=\"header-ui_atm\"><a href=\"https://map.iyobank.co.jp/\" target=\"_blank\"><span class=\"list_label\">店舗ATM</span></a></li>\n    <li class=\"header-ui_menu\"><a href=\"javascript:void(0);\"><span></span><span></span><span></span><span class=\"list_label\">メニュー</span></a></li>\n  </ul>\n  <div id=\"headerSearch\" class=\"headerSearch js-header-serchPanel\">\n    <div class=\"headerSearch_body\">\n      <form name=\"search_form\" action=\"https://sitesearch.iyobank.co.jp/\" method=\"GET\" onsubmit=\"return mysearch(this);\">\n        <div class=\"headerSearch_wrap\">\n          <input type=\"text\" name=\"kw\" value=\"\" class=\"headerSearch_textcnt iSearchAssist\" placeholder=\"検索キーワードを入力してください\">\n          <button class=\"headerSearch_submit\" type=\"submit\"></button>\n        </div>\n        <input type=\"hidden\" name=\"ie\" value=\"u\">\n      </form>\n    </div>\n  </div>\n<!--/Header--></header>\n<div class=\"header-menu-overlay\"></div>\n<main id=\"main\" class=\"Main\">\n  <div id=\"mainBody\" class=\"MainBody\">\n    <div class=\"pageGuide\">\n      <ol class=\"breadcrumbs\" itemscope itemtype=\"http://schema.org/BreadcrumbList\">\n        <li itemprop=\"itemListElement\" itemscope itemtype=\"http://schema.org/ListItem\">\n          <a itemprop=\"item\" href=\"/\"><span itemprop=\"name\">ホーム</span></a>\n          <meta itemprop=\"position\" content=\"1\" />\n        </li><!-- InstanceBeginEditable name=\"editBreadcrumbs\" -->\n\t\t\t\t\t\t\t\t\t<li itemprop=\"itemListElement\" itemscope itemtype=\"http://schema.org/ListItem\">\n\t\t\t\t\t\t\t\t\t\t<a itemprop=\"item\" href=\"/career/index.html\"><span itemprop=\"name\">採用情報</span></a>\n\t\t\t\t\t\t\t\t\t\t<meta itemprop=\"position\" content=\"2\" />\n\t\t\t\t\t\t\t\t\t</li>\n\t\t\t\t\t\t\t\t<li>行員再雇用（カムバック）制度</li><!-- InstanceEndEditable -->\n      </ol>\n    <!--/pageGuide--></div>\n    <div class=\"container\" data-sidebar=\"true\" data-system=\"true\">\n      <div class=\"contents\">\n      <!-- InstanceBeginEditable name=\"editContainer\" -->\n      <div class=\"jinContentsWrap\">\n<!--\n\t\tmodules\n\t--><div class=\"heading-lv1-v2\">\n          <div class=\"heading_wrap\">\n            <div class=\"heading_subtitle\">採用情報</div>\n            <h1 class=\"heading_title\">行員再雇用（カムバック）制度</h1>\n          </div>\n        <!--/heading-lv1--></div>\n        <section>\n<!--\n          <div class=\"heading-lv2\">\n            <div class=\"block\">\n              <h2 class=\"heading_title\">〇〇について</h2>\n            </div>\n          <!--/heading-lv2</div>\n-->\n          <div class=\"table-layout\" data-layout-sp=\"scroll\">\n            <table class=\"table_inner\">\n              <colgroup>\n              <col span=\"1\" class=\"gp-w-020per\">\n              <col span=\"1\" class=\"gp-w-020per\">\n              <col span=\"1\" class=\"gp-w-060per\">\n              </colgroup>\n              <thead>\n                <tr>\n                  <th colspan=\"3\" class=\"cell-style1 f-normal-weight\" style=\"text-align: center;\">募集内容</th>\n                </tr>\n              </thead>\n              <tbody>\n                <tr>\n                  <th colspan=\"2\" class=\"cell-style1 f-normal-weight\">対象者</th>\n                  <td>当行行員の退職者のうち、下記の要件を満たす方\n                    <ul class=\"list-note\">\n                      <li><span class=\"list_mark\">※</span>勤続年数の定めはありません。</li>\n                    </ul></td>\n                  </td>\n                </tr>\n                <tr>\n                  <th colspan=\"2\" class=\"cell-style1 f-normal-weight\">退職時資格</th>\n                  <td>リーダー層およびアソシエイト層</td>\n                </tr>\n                <tr>\n                  <th colspan=\"2\" class=\"cell-style1 f-normal-weight\">退職時取得資格</th>\n                  <td>「証券外務員(会員一種)」資格(注1)<br>「損害保険募集人」資格<br>「生命保険募集人」資格(一般・専門・変額・外貨)の4種(注2)</td>\n                </tr>\n                <tr>\n                  <th colspan=\"2\" class=\"cell-style1 f-normal-weight\">離職期間</th>\n                  <td>期間の定めはありません。</td>\n                </tr>\n                <tr>\n                  <th rowspan=\"2\" class=\"cell-style1 f-normal-weight\">勤務地</th>\n                  <th class=\"cell-style2 f-normal-weight\">勤務地</th>\n                  <td>当行本支店</td>\n                </tr>\n                <tr>\n                  <th class=\"cell-style2 f-normal-weight\">転勤有無</th>\n                  <td>有</td>\n                </tr>\n                <tr>\n                  <th colspan=\"2\" class=\"cell-style1 f-normal-weight\">勤務時間</th>\n                  <td>8：30～17：30(所定労働時間8時間)<br>休憩時間：60分<br>時間外労働有無：有<br>フレックスタイム制導入</td>\n                </tr>\n                <tr>\n                  <th colspan=\"2\" class=\"cell-style1 f-normal-weight\">コース区分</th>\n                  <td>\n                    <ol class=\"list-order\">\n                      <li><span class=\"list_mark\">①</span>総合職（エリアＦ）退職者（特定総合職Ａコース・Ｂコースの退職者を除く）…総合職（エリアＦ・Ｗ・Ｌ）またはオフィスコース</li>\n                      <li><span class=\"list_mark\">②</span>総合職（エリアＷ・Ｌ）退職者（エリア職または特定総合職Ａコース・Ｂコースの退職者を含む）…総合職（エリアＷ・Ｌ）またはオフィスコース</li>\n                      <li><span class=\"list_mark\">③</span>専門職退職者…専門職（職種は退職時と同一）</li>\n                      <li><span class=\"list_mark\">④</span>オフィスコース退職者…オフィスコース</li>\n                    </ol>\n                    <ul class=\"list-note\">\n                      <li><span class=\"list_mark\">※</span>2022年10月以前の総合職退職者は①になります。</li>\n                      <li><span class=\"list_mark\">※</span>ただし、退職後のキャリア等により上記と異なるコースで採用する場合があります。</li>\n                    </ul>\n                  </td>\n                </tr>\n                <tr>\n                  <th rowspan=\"14\" class=\"cell-style1 f-normal-weight\">待遇・福利厚生</th>\n                  <th class=\"cell-style2 f-normal-weight\">待遇</th>\n                  <td>原則として退職時の資格に準じます。\n                    <ul class=\"list-note\">\n                      <li><span class=\"list_mark\">※</span>詳細は面接時に説明いたします。</li>\n                    </ul>\n                  </td>\n                </tr>\n                <tr>\n                  <th class=\"cell-style2 f-normal-weight\">賃金形態</th>\n                  <td>月給制</td>\n                </tr>\n                <tr>\n                  <th class=\"cell-style2 f-normal-weight\">昇給</th>\n                  <td>有</td>\n                </tr>\n                <tr>\n                  <th class=\"cell-style2 f-normal-weight\">残業手当</th>\n                  <td>有</td>\n                </tr>\n                <tr>\n                  <th class=\"cell-style2 f-normal-weight\">通勤手当</th>\n                  <td>有</td>\n                </tr>\n                <tr>\n                  <th class=\"cell-style2 f-normal-weight\">家族手当</th>\n                  <td>有</td>\n                </tr>\n                <tr>\n                  <th class=\"cell-style2 f-normal-weight\">単身赴任手当</th>\n                  <td>有（対象者制限あり）</td>\n                </tr>\n                <tr>\n                  <th class=\"cell-style2 f-normal-weight\">寮社宅</th>\n                  <td>独身寮、社宅\n                    <ul class=\"list-note\">\n                      <li><span class=\"list_mark\">※</span>総合職（エリアＬ）、オフィスコース除く</li>\n                    </ul>\n                  </td>\n                </tr>\n                <tr>\n                  <th class=\"cell-style2 f-normal-weight\">社会保険</th>\n                  <td>健康保険、厚生年金保険、雇用保険、労災保険</td>\n                </tr>\n                <tr>\n                  <th class=\"cell-style2 f-normal-weight\">退職金制度</th>\n                  <td>有（定年：60歳）</td>\n                </tr>\n                <tr>\n                  <th class=\"cell-style2 f-normal-weight\">企業年金制度</th>\n                  <td>有（確定給付企業年金、確定拠出年金）</td>\n                </tr>\n                <tr>\n                  <th class=\"cell-style2 f-normal-weight\">教育制度</th>\n                  <td>OJT、各種資格取得奨励制度、チャレンジポスト（行内公募）制度など</td>\n                </tr>\n                <tr>\n                  <th class=\"cell-style2 f-normal-weight\">その他制度</th>\n                  <td>住宅融資制度、持株会制度、祝金制度、見舞金制度、弔慰金制度ほか</td>\n                </tr>\n                <tr>\n                  <th class=\"cell-style2 f-normal-weight\">福利厚生補足</th>\n                  <td>研修所、保養所、グラウンド、契約スポーツ施設、契約リゾートホテル</td>\n                </tr>\n                <tr>\n                  <th rowspan=\"2\" class=\"cell-style1 f-normal-weight\">休日・休暇</th>\n                  <th class=\"cell-style2 f-normal-weight\">休日</th>\n                  <td>完全週休二日制（土・日）、祝日、12月31日、1月2日・3日\n                  <ul class=\"list-note\">\n                    <li><span class=\"list_mark\">※</span>年間休日約120日</li>\n                  </ul></td>\n                </tr>\n                <tr>\n                  <th class=\"cell-style2 f-normal-weight\">休暇</th>\n                  <td>年次有給休暇（雇用開始日に4～15日、雇用後最初の1月1日より以後毎年20日、連続休暇・リフレッシュ休暇など年間合計11日の計画取得制度のほか参観日休暇・人間ドック休暇制度あり）<br>積立有給休暇（勤続10年より、最大60日）<br>看護休暇・介護休暇（5～10日、給与支給）<br>結婚休暇（3日）・10年勤続休暇（2日）・永年勤続休暇（5日）・退職者旅行休暇（5日）・ボランティア休暇（月2日）・ドナー休暇・忌引ほか（全て給与支給）</td>\n                </tr>\n                <tr>\n                  <th rowspan=\"4\" class=\"cell-style1 f-normal-weight\">災害・傷病保障</th>\n                  <th class=\"cell-style2 f-normal-weight\">業務上災害補償</th>\n                  <td>労災保険による補償額が給与額に不足する場合、差額を補償など</td>\n                </tr>\n                <tr>\n                  <th class=\"cell-style2 f-normal-weight\">通勤災害補償</th>\n                  <td>労災保険による補償額が給与額に不足する場合、差額を補償など</td>\n                </tr>\n                <tr>\n                  <th class=\"cell-style2 f-normal-weight\">長期傷病欠勤補償</th>\n                  <td>傷病による欠勤が1週間以上続いた場合、給与額を補償</td>\n                </tr>\n                <tr>\n                  <th class=\"cell-style2 f-normal-weight\">休職手当</th>\n                  <td>傷病による休職の場合、給与の一定額を補償</td>\n                </tr>\n              </tbody>\n            </table>\n          <!--/table-layout--></div>\n          <ol class=\"list-order\">\n            <li><span class=\"list_mark\">(注1)</span>　証券外務員資格は、2014年10月1日以前の退職者の方に限り、「特別会員二種」を認めます。この場合、採用後速やかに「証券外務員（会員一種）」資格を取得していただきます。</li>\n            <li><span class=\"list_mark\">(注2)</span>　2022年9月30日以前退職者の方は、外貨を除きます。</li>\n          </ol>\n        </section>\n        <div class=\"box-layout-v2 color-v5\">\n          <div class=\"box_detail\">\n            <p class=\"heading-attention f-bold f-color\"><span>採用選考において取得した個人情報について</span></p>\n            <p class=\"text-paragraph\">WEBからのエントリー情報を含め、採用のために取得した個人情報（履歴書・応接メモ・成績・卒業・健康診断証明書等）は、当行の採用活動、および採用後の適切な雇用管理のためにのみ利用します。これらの目的以外に、取得した個人情報を利用することは致しません。また、不採用となった場合返却は致しませんが、取得した個人情報は当行で責任を持って機密廃棄致します。</p>\n          </div>\n        <!--/box-layout--></div>\n        <div class=\"table-layout\" data-layout-sp=\"vertical\">\n          <table class=\"table_inner\">\n            <colgroup>\n              <col span=\"1\" >\n              <col span=\"1\" >\n            </colgroup>\n            <tbody>\n              <tr>\n                <th class=\"cell-style1 f-normal-weight\">労働施策総合推進法に基づく中途採用比率</th>\n                <td style=\"vertical-align: middle;\">2023年度：9%　2024年度：10%　2025年度：13%　（公表日：2026年4月1日）</td>\n              </tr>\n            </tbody>\n          </table>\n        <!--/table-layout--></div>\n        <section class=\"box-layout color-v3\">\n          <h2 class=\"box_title\">お問い合わせ・ご応募はこちらから</h2>\n          <div class=\"box_detail\">\n            <div class=\"contact-box-layout\">\n              <div class=\"contact-box_inner\">\n                <div class=\"contact-box_detail-v2\">\n                  <p class=\"f-bold f-color-v3 f-sizeLL gp-al-center\">松山</p>\n                  <p class=\"f-bold gp-al-center gp-mt-SS\">伊予銀行 人事部採用担当者</p>\n                  <p class=\"contact-tel\"><a href=\"tel:0120411142\">0120-41-1142</a></p>\n                  <p class=\"f-sizeS\">受付時間／9:00～17:00（銀行休業日は除く）</p>\n                </div>\n                <div class=\"contact-box_detail-v2\">\n                  <p class=\"f-bold f-color-v3 f-sizeLL gp-al-center\">東京</p>\n                  <p class=\"f-bold gp-al-center gp-mt-SS\">伊予銀行 東京事務所採用担当者</p>\n                  <p class=\"contact-tel-v2\"><a href=\"tel:0332421401\">03-3242-1401</a></p>\n                  <p class=\"f-sizeS\">受付時間／9:00～17:00（銀行休業日は除く）</p>\n                </div>\n              </div>\n            <!-- /.contact-box-layout --></div>\n          </div>\n        <!--/box-layout--></section>\n        <div class=\"box-layout-v2\">\n          <h6 class=\"box_title\">元行員の皆さまへ</h6>\n          <div class=\"box_detail\">\n            <p>行員再雇用（カムバック）制度を希望される方は上記電話番号よりお申込みください。<br>また、以下のURLから「アルムナイ専用サイト」へご登録いただくことも可能です。</p>\n            <table style=\"margin-top: 0.5em;\">\n              <tr>\n                <td style=\"white-space: nowrap; border: none;\">URL：</td>\n                <td style=\"border: none;\"><a href=\"https://retiree.alumy.jp/enterprises/b2f1e4bcdee0436aa015c6acdd0eea37/retirees/invite?utm_source=hr_stock&utm_medium=press&utm_campaign=\" target=\"_blank\" class=\"js-externalLink a-blank\">https://retiree.alumy.jp/enterprises/b2f1e4bcdee0436aa015c6acdd0eea37/retirees/invite?utm_source=hr_stock&utm_medium=press&utm_campaign=</a></td>\n              </tr>\n            </table>\n          </div>\n        <!--/box-layout--></div><!--\n\t\t\t/modules\n\t\t--><!--/jinContentsWrap--></div>\n        <!-- InstanceEndEditable -->\n      <!--/contents--></div>\n              <div class=\"sidebar\">\n          <ul class=\"link-button career-side-button\">\n            <li><a href=\"/about/\"><span class=\"link_label\">伊予銀行について</span></a></li>\n          </ul>\n          <nav class=\"sidebar-nav\">\n          <h2 class=\"nav_head\"><a href=\"/career/\">採用情報</a></h2>\n          <ul class=\"nav_category stage1\">\n            <li><a href=\"/sp/shinsotsu/\" target=\"_blank\" class=\"a-blank\"><span class=\"link_label\">新卒採用</span></a></li>\n            <li><a href=\"/career/employment.html\">キャリア採用</a></li>\n            <li><a href=\"/career/comeback.html\">行員再雇用（カムバック）制度</a></li>\n            <li><a href=\"/career/staff.html\">パートタイマー採用</a></li>\n          </ul>\n        <!--/sidebar-nav--></nav>\n<!-- InstanceBeginEditable name=\"otherSide\" --><!-- InstanceEndEditable -->\n        <!--/sidebar--></div>\n    <!--/container--></div>\n<aside class=\"footer-sns-layout\">\n      <dl class=\"footer-sns_list\">\n        <dt>いよぎんの公式SNS</dt>\n        <dd>\n          <ul class=\"footer-sns_icon\">\n            <li class=\"footer-sns_fb\"><a href=\"https://www.facebook.com/iyobank.official\" target=\"_blank\" class=\"js-externalLink\">Facebook</a></li>\n            <li class=\"footer-sns_youtube\"><a href=\"https://www.youtube.com/user/iyobankchannel\" target=\"_blank\" class=\"js-externalLink\">YouTube</a></li>\n            <li class=\"footer-sns_twitter\"><a href=\"https://twitter.com/IYOBANKofficial\" target=\"_blank\" class=\"js-externalLink\">Twitter</a></li>\n          </ul>\n        </dd>\n      </dl>\n    <!--/.footer-sns