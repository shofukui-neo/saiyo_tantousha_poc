--preset--font-size--large) !important;}.has-x-large-font-size{font-size: var(--wp--preset--font-size--x-large) !important;}\n/*# sourceURL=global-styles-inline-css */\n</style>\n\n<link rel='stylesheet' id='contact-form-7-css' href='https://www.hondacars-saitamanishi.co.jp/recruit/wp-content/plugins/contact-form-7/includes/css/styles.css?ver=6.1.6' media='all' />\n<link rel='stylesheet' id='jquery-ui-dialog-min-css-css' href='https://www.hondacars-saitamanishi.co.jp/recruit/wp-includes/css/jquery-ui-dialog.min.css?ver=6f5b5aa788e8dc229410b49c8395742b' media='all' />\n<link rel='stylesheet' id='contact-form-7-confirm-plus-css' href='https://www.hondacars-saitamanishi.co.jp/recruit/wp-content/plugins/confirm-plus-contact-form-7/assets/css/styles.css?ver=20260121_061253' media='all' />\n<link rel='stylesheet' id='uaplus-css' href='https://www.hondacars-saitamanishi.co.jp/recruit/wp-content/themes/recruit/css/uaplus.css' media='all' />\n<link rel='stylesheet' id='swiper-css' href='https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css?ver=11' media='all' />\n<link rel='stylesheet' id='theme-style-css' href='https://www.hondacars-saitamanishi.co.jp/recruit/wp-content/themes/recruit/css/style.css?202603031' media='all' />\n<script id=\"jquery-core-js\" src=\"https://www.hondacars-saitamanishi.co.jp/recruit/wp-includes/js/jquery/jquery.min.js?ver=3.7.1\"></script>\n<script id=\"jquery-migrate-js\" src=\"https://www.hondacars-saitamanishi.co.jp/recruit/wp-includes/js/jquery/jquery-migrate.min.js?ver=3.4.1\"></script>\n<link rel=\"icon\" href=\"https://www.hondacars-saitamanishi.co.jp/recruit/wp-content/uploads/2026/02/site-icon-150x150.png\" sizes=\"32x32\" />\n<link rel=\"icon\" href=\"https://www.hondacars-saitamanishi.co.jp/recruit/wp-content/uploads/2026/02/site-icon-300x300.png\" sizes=\"192x192\" />\n<link rel=\"apple-touch-icon\" href=\"https://www.hondacars-saitamanishi.co.jp/recruit/wp-content/uploads/2026/02/site-icon-300x300.png\" />\n<meta name=\"msapplication-TileImage\" content=\"https://www.hondacars-saitamanishi.co.jp/recruit/wp-content/uploads/2026/02/site-icon-300x300.png\" />\n</head>\n\n<body>\n  <header class=\"header\">\n    <div>\n      <!-- ナビゲーションバー -->\n      <nav class=\"nav-bar\">\n        <div class=\"nav-container\">\n          <div class=\"nav-container-inner\">\n            <a href=\"https://www.hondacars-saitamanishi.co.jp/recruit/\" class=\"logo-wrapper\">\n              <div class=\"logo-honda\"><img src=\"https://www.hondacars-saitamanishi.co.jp/recruit/wp-content/themes/recruit/img/logo.png\" alt=\"ホンダカーズ埼玉西\"></div>\n              <div class=\"nav-label\">RECRUITMENT</div>\n            </a>\n            <!-- ナビゲーション募集要項ボタン PC用 -->\n            <nav class=\"nav-requirements nav-requirements-pc\">\n              <a href=\"https://www.hondacars-saitamanishi.co.jp/recruit/graduate/\" class=\"nav-requirement-btn new-graduate\">\n                <div class=\"nav-requirement-title\">新卒採用</div>\n              </a>\n              <a href=\"https://www.hondacars-saitamanishi.co.jp/recruit/career/\" class=\"nav-requirement-btn mid-career\">\n                <div class=\"nav-requirement-title\">中途採用</div>\n              </a>\n              <a href=\"/home/company\" class=\"nav-requirement-btn company-info\"\n                target=\"_blank\">\n                <div class=\"nav-requirement-title\">会社概要</div>\n              </a>\n            </nav>\n          </div>\n          <button class=\"hamburger-menu\" id=\"hamburgerBtn\" aria-label=\"メニュー\">\n            <span></span>\n            <span></span>\n            <span></span>\n          </button>\n        </div>\n      </nav>\n      <!-- ドロワーメニュー -->\n      <div class=\"drawer-menu\" id=\"drawerMenu\">\n        <div class=\"drawer-content\">\n          <div class=\"drawer-accordion-item\">\n            <button class=\"drawer-accordion-btn\">\n              <span>募集要項</span>\n              <span class=\"drawer-accordion-toggle\">+</span>\n            </button>\n            <div class=\"drawer-accordion-content\">\n              <a href=\"https://www.hondacars-saitamanishi.co.jp/recruit/graduate/\" class=\"drawer-item-subtitle\">− 新卒採用</a>\n              <a href=\"https://www.hondacars-saitamanishi.co.jp/recruit/career/\" class=\"drawer-item-subtitle\">− 中途採用</a>\n            </div>\n          </div>\n          <a href=\"/home/company\" class=\"drawer-item drawer-link external-link\"\n            target=\"_blank\">\n            <span>会社概要</span>\n          </a>\n          <a href=\"https://www.hondacars-saitamanishi.co.jp/recruit/topics/\" class=\"drawer-item drawer-link\">新着情報</a>\n          <div class=\"drawer-accordion-item\">\n            <button class=\"drawer-accordion-btn\">\n              <span>職種紹介</span>\n              <span class=\"drawer-accordion-toggle\">+</span>\n            </button>\n            <div class=\"drawer-accordion-content\">\n              <a href=\"https://www.hondacars-saitamanishi.co.jp/recruit/jobs/sales/\" class=\"drawer-item-subtitle\">− 営業職</a>\n              <a href=\"https://www.hondacars-saitamanishi.co.jp/recruit/jobs/engineer/\" class=\"drawer-item-subtitle\">− サービスエンジニア</a>\n              <a href=\"https://www.hondacars-saitamanishi.co.jp/recruit/jobs/showroom/\" class=\"drawer-item-subtitle\">− ショールームスタッフ</a>\n              <a href=\"https://www.hondacars-saitamanishi.co.jp/recruit/jobs/mainoffice/\" class=\"drawer-item-subtitle\">− 本社事務職</a>\n            </div>\n          </div>\n          <div class=\"drawer-accordion-item\">\n            <button class=\"drawer-accordion-btn\">\n              <span>福利厚生</span>\n              <span class=\"drawer-accordion-toggle\">+</span>\n            </button>\n            <div class=\"drawer-accordion-content\">\n              <a href=\"https://www.hondacars-saitamanishi.co.jp/recruit/#benefits-section\" class=\"drawer-item-subtitle\">− 福利厚生</a>\n              <a href=\"https://www.hondacars-saitamanishi.co.jp/recruit/support/\" class=\"drawer-item-subtitle\">− 充実した支援制度</a>\n            </div>\n          </div>\n          <a href=\"https://www.hondacars-saitamanishi.co.jp/recruit/message/\" class=\"drawer-item drawer-link\">社長メッセージ</a>\n          <a href=\"https://www.hondacars-saitamanishi.co.jp/recruit/faq/\" class=\"drawer-item drawer-link\">よくある質問（FAQ）</a>\n          <a href=\"https://www.hondacars-saitamanishi.co.jp/recruit/inquiry/\" class=\"drawer-item drawer-link\">お問い合わせ</a>\n          <a href=\"https://www.hondacars-saitamanishi.co.jp/recruit/social/\" class=\"drawer-item drawer-link\">社会貢献活動</a>\n          <a href=\"https://www.hondacars-saitamanishi.co.jp/recruit/sdgs/\" class=\"drawer-item drawer-link\">SDGs</a>\n          <a href=\"/\" class=\"drawer-item drawer-link external-link\"\n            target=\"_blank\">\n            <span>コーポレートサイト</span>\n          </a>\n          <a href=\"/home/privacy\" class=\"drawer-item drawer-link external-link\"\n            target=\"_blank\">\n            <span>プライバシーポリシー</span>\n          </a>\n          <a href=\"/home/terms\" class=\"drawer-item drawer-link external-link\"\n            target=\"_blank\">\n            <span>ご利用にあたって</span>\n          </a>\n          <div class=\"drawer-footer\">\n            <div class=\"drawer-footer-sns\">\n              <a href=\"https://www.instagram.com/hondacars3124/\" class=\"drawer-footer-sns-icon\" aria-label=\"Instagram\"\n                target=\"_blank\"><img src=\"https://www.hondacars-saitamanishi.co.jp/recruit/wp-content/themes/recruit/img/sns/Instagram_Glyph_Gradient.png\" alt=\"\"></a>\n              <a href=\"https://www.facebook.com/profile.php?id=100076060586114&locale=ja_JP\" class=\"drawer-footer-sns-icon\"\n                aria-label=\"Facebook\" target=\"_blank\"><img src=\"https://www.hondacars-saitamanishi.co.jp/recruit/wp-content/themes/recruit/img/sns/Facebook_Logo_Primary.png\" alt=\"\"></a>\n              <a href=\"https://www.youtube.com/@%E6%A0%AA%E5%BC%8F%E4%BC%9A%E7%A4%BE%E3%83%9B%E3%83%B3%E3%83%80%E3%82%AB%E3%83%BC%E3%82%BA%E5%9F%BC%E7%8E%89%E8%A5%BF\"\n                class=\"drawer-footer-sns-icon\" aria-label=\"YouTube\" target=\"_blank\"><img src=\"https://www.hondacars-saitamanishi.co.jp/recruit/wp-content/themes/recruit/img/sns/youtube_social_icon_white.png\"\n                  alt=\"\"></a>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n    <!-- ナビゲーション募集要項ボタン モバイル用 -->\n    <nav class=\"nav-requirements nav-requirements-sp\">\n      <a href=\"https://www.hondacars-saitamanishi.co.jp/recruit/graduate/\" class=\"nav-requirement-btn new-graduate\">\n        <div class=\"nav-requirement-title\">新卒採用</div>\n      </a>\n      <a href=\"https://www.hondacars-saitamanishi.co.jp/recruit/career/\" class=\"nav-requirement-btn mid-career\">\n        <div class=\"nav-requirement-title\">中途採用</div>\n      </a>\n      <a href=\"/home/company\" class=\"nav-requirement-btn company-info\"\n        target=\"_blank\">\n        <div class=\"nav-requirement-title\">会社概要</div>\n      </a>\n    </nav>\n  </header>\n\n<main>\n  <!-- ページヘッダー -->\n  <div class=\"social-header\">\n    <div class=\"social-header-image\">\n      <img src=\"https://www.hondacars-saitamanishi.co.jp/recruit/wp-content/themes/recruit/img/social_header.jpg?20260210\" alt=\"\">\n    </div>\n    <div class=\"social-page-title\">\n      <p class=\"social-page-title-ja\">社会貢献活動</p>\n      <p class=\"social-page-title-en\">Social contribution activities</p>\n    </div>\n  </div>\n\n  <!-- ページコンテンツ -->\n  <div class=\"page-content-wrapper\">\n    <!-- リード文セクション -->\n    <section class=\"social-lead\">\n      <div class=\"social-lead-text\">\n        <p>\n          私たちは、社会貢献活動を経営の重要課題の一つとして位置づけています。地域の環境保全や福祉支援に加え、交通安全の普及啓発や事故被害者への支援、さらには災害時の機動力提供など、私たちの資源を活かした活動を推進しています。地域社会に寄り添い、共に持続可能な未来を築くため、これからも真摯に取り組んでまいります。\n        </p>\n      </div>\n    </section>\n\n    <!-- プロジェクトアイテム -->\n    <section class=\"social-items-wrapper\">\n      <div class=\"social-items\">\n        <div class=\"social-item\">\n          <div class=\"social-item-badge\">Project 01</div>\n          <div class=\"social-team\">\n            <span class=\"social-team-name\">NPOさやま環境市民ネットワーク</span>\n          </div>\n          <div class=\"social-project-name\">環境保全活動のサポート</div>\n          <div class=\"social-project-detail\">\n            <p>2003年の「狭山市環境基本計画」策定を機に発足した任意団体であり、これまで4つの分科会（緑・川・ごみ・温暖化）を中心に、会員200名を超える規模で環境保全活動を支援しています。</p>\n          </div>\n          <div class=\"social-project-image tate\">\n            <img src=\"https://www.hondacars-saitamanishi.co.jp/recruit/wp-content/themes/recruit/img/social-item01.jpg\" alt=\"\">\n          </div>\n        </div>\n        <div class=\"social-item\">\n          <div class=\"social-item-badge\">Project 02</div>\n          <div class=\"social-team\">\n            <span class=\"social-team-name\">狭山市福祉協議会</span>\n          </div>\n          <div class=\"social-project-name\">福祉支援・食材寄付</div>\n          <div class=\"social-project-detail\">\n            <p>狭山市社会福祉協議会を通じて福祉支援活動（フードドライブなど）を行い、物価高騰で生活に困窮する方々への食料支援や、子どもの貧困対策としての子ども食堂への食品提供活動を支援しています。</p>\n          </div>\n        </div>\n        <div class=\"social-item\">\n          <div class=\"social-item-badge\">Project 03</div>\n          <div class=\"social-team\">\n            <span class=\"social-team-name\">彩の国ロードサポート制度</span>\n          </div>\n          <div class=\"social-project-name\">店舗周辺道路の清掃活動</div>\n          <div class=\"social-project-detail\">\n            <p>ボランティアで店舗周辺の県道などで、定期的にゴミ拾いや除草などの清掃活動を行い、快適で美しい道路環境作りに取り組んでおります。</p>\n            <a href=\"https://www.pref.saitama.lg.jp/a1006/kenminsanka/index.html\"\n              target=\"_blank\">https://www.pref.saitama.lg.jp/a1006/kenminsanka/index.html</a>\n          </div>\n          <div class=\"social-project-image tate\">\n            <img src=\"https://www.hondacars-saitamanishi.co.jp/recruit/wp-content/themes/recruit/img/social-item03.jpg\" alt=\"\">\n          </div>\n        </div>\n        <div class=\"social-item\">\n          <div class=\"social-item-badge\">Project 04</div>\n          <div class=\"social-team\">\n            <span class=\"social-team-name\">埼玉県Keep38プロジェクト</span>\n          </div>\n          <div class=\"social-project-name\">交通安全啓蒙活動 ステッカー配布</div>\n          <div class=\"social-project-detail\">\n            <p>「KEEP38プロジェクト」とは、県内における横断歩行者が被害に遭う交通事故の撲滅を目指し、横断歩道における歩行者優先義務が規定された「道路交通法第38条」の交通ルールを正しく理解し、その遵守を表明して模範運転をすることにより、歩行者優先の機運を高め、安全運転の促進を図る取り組みです。</p>\n            <p>道路交通法第38条を守る＝KEEP38<br>当社は、オリジナルステッカーを作成し、配布することで活動に参加しております</p>\n          </div>\n          <div class=\"social-project-image tate\">\n            <img src=\"https://www.hondacars-saitamanishi.co.jp/recruit/wp-content/themes/recruit/img/social-item04.jpg\" alt=\"\">\n          </div>\n        </div>\n        <div class=\"social-item\">\n          <div class=\"social-item-badge\">Project 05</div>\n          <div class=\"social-team\">\n            <span class=\"social-team-name\">NPOフードバンクネット西埼玉</span>\n          </div>\n          <div class=\"social-project-name\">食材提供 フードドライブ</div>\n          <div class=\"social-project-detail\">\n            <p>埼玉県西部（所沢市中心）で活動する全国フードバンク推進協議会加盟団体で、生活困窮世帯やパントリー団体への食品無償提供、企業からの寄贈受付、地域住民からのフードドライブなど、食品ロス削減と福祉支援両立の活動を支援しています。</p>\n          </div>\n          <div class=\"social-project-image tate\">\n            <img src=\"https://www.hondacars-saitamanishi.co.jp/recruit/wp-content/themes/recruit/img/social-item05.jpg\" alt=\"\">\n          </div>\n        </div>\n        <div class=\"social-item\">\n          <div class=\"social-item-badge\">Project 06</div>\n          <div class=\"social-team\">\n            <span class=\"social-team-name\">フードバンクいるま</span>\n          </div>\n          <div class=\"social-project-name\">食材提供</div>\n          <div class=\"social-project-detail\">\n            <p>埼玉県入間市を中心に、企業や家庭から寄付された未利用食品を、支援が必要な世帯や団体へ無償で届ける活動を支援しています。</p>\n          </div>\n        </div>\n        <div class=\"social-item\">\n          <div class=\"social-item-badge\">Project 07</div>\n          <div class=\"social-team\">\n            <span class=\"social-team-name\">公益社団法人 埼玉犯罪被害者援助センター</span>\n          </div>\n          <div class=\"social-project-name\">犯罪被害者支援活動支援自販機<br>2店舗に支援型自販機設置</div>\n          <div class=\"social-project-detail\">\n            <p>犯罪や交通事故の被害に遭われた方とその家族を支援する民間団体です。 埼玉県公安委員会から「犯罪被害者等早期援助団体」の指定を受けており、警察などの公的機関とも連携して、被害直後から弁護士による法律相談や、カウンセラーによるカウンセリングを受けられるほか、経済的なサポート提供活動を支援しています。</p>\n            <a href=\"https://svsc8080.jp/vendingmachine/\"\n              target=\"_blank\">https://svsc8080.jp/vendingmachine/</a>\n          </div>\n        </div>\n        <div class=\"social-item\">\n          <div class=\"social-item-badge\">Project 08</div>\n          <div class=\"social-team\">\n            <span class=\"social-team-name\">ECO　Tama　Project</span>\n          </div>\n          <div class=\"social-project-name\">卵殻再生用紙Camishell名刺</div>\n          <div class=\"social-project-detail\">\n            <p>「エコ玉プロジェクト（ECO Tama Project）」は、産業廃棄物として処理される「卵の殻」を資源として有効活用した紙を名刺の紙に使用しております。</p>\n          </div>\n          <div class=\"social-project-image tate\">\n            <img src=\"https://www.hondacars-saitamanishi.co.jp/recruit/wp-content/themes/recruit/img/social-item08.jpg\" alt=\"\">\n          </div>\n        </div>\n        <div class=\"social-item\">\n          <div class=\"social-item-badge\">Project 09</div>\n          <div class=\"social-team\">\n            <span class=\"social-team-name\">埼玉育児院後援</span>\n          </div>\n          <div class=\"social-project-name\">お楽しみ会　イベント参加など</div>\n          <div class=\"social-project-detail\">\n            <p>家庭での養育が困難な2歳〜18歳までの子どもたちを受け入れ、家庭に代わって生活の場を提供し、自立を支援する施設のイベントを支援しています。</p>\n          </div>\n        </div>\n        <div class=\"social-item\">\n          <div class=\"social-item-badge\">Project 10</div>\n          <div class=\"social-team\">\n            <span class=\"social-team-name\">災害時における車両供与等の協定（狭山市）</span>\n          </div>\n          <div class=\"social-project-name\">2025年2月締結<br>災害時の車両提供、店舗敷地開放</div>\n          <div class=\"social-project-detail\">\n            <p>狭山市内に地震や風水害等の大規模災害が発生し、又は発生するおそれがある場合に、当社の所有する電気自動車や乗用自動車、発電機等の無償貸与する協定を締結しました。</p>\n            <a href=\"https://www.city.sayama.saitama.jp/kurashi/anshin/bosai/bousaitaisei/ouen/hondacars.html\"\n              target=\"_blank\">https://www.city.sayama.saitama.jp/kurashi/anshin/bosai/bousaitaisei/ouen/hondacars.html</a>\n          </div>\n          <div class=\"social-project-image\">\n            <img src=\"https://www.hondacars-saitamanishi.co.jp/recruit/wp-content/themes/recruit/img/social-item10.jpg\" alt=\"\">\n          </div>\n        </div>\n        <div class=\"social-item\">\n          <div class=\"social-item-badge\">Project 11</div>\n          <div class=\"social-team\">\n            <span class=\"social-team-name\">災害時における車両供与等の協定（所沢市）</span>\n          </div>\n          <div class=\"social-project-name\">2025年6月締結<br>災害時の車両提供、店舗敷地開放</div>\n          <div class=\"social-project-detail\">\n            <p>所沢市内に大規模な災害が発生した場合には、市からの要請に基づいて、車両・発電機等の貸与や店舗・モータープールの一時利用できるよう協定を締結しました。</p>\n            <a href=\"https://www.city.tokorozawa.saitama.jp/tokoronews/press/r7/8gatu/taiyokyotei.html\"\n              target=\"_blank\">https://www.city.tokorozawa.saitama.jp/tokoronews/press/r7/8gatu/taiyokyotei.html</a>\n          </div>\n          <div class=\"social-project-image\">\n            <img src=\"https://www.hondacars-saitamanishi.co.jp/recruit/wp-content/themes/recruit/img/social-item11.jpg\" alt=\"\">\n          </div>\n        </div>\n        <div class=\"social-item\">\n          <div class=\"social-item-badge\">Project 12</div>\n          <div class=\"social-team\">\n            <span class=\"social-team-name\">交通安全教室あやとりい教室</span>\n          </div>\n          <div class=\"social-project-name\">幼稚園での子供安全教室の開催<br>(狭山市入間市で10カ所)</div>\n          <div class=\"social-project-detail\">\n            <p>主に4～5歳児（年中・年長）を対象とし、子どもたちが交通ルールを楽しく学べるよう設計されているHondaが提供するオリジナルの交通安全教育プログラムです。当社を含むHonda Cars（ホンダ車の販売会社）が幼稚園や保育園などで実施しております。</p>\n          </div>\n        </div>\n        <div class=\"social-item\">\n          <div class=\"social-item-badge\">Project 13</div>\n          <div class=\"social-team\">\n            <span class=\"social-team-name\">所沢市へHondaｰe公用車寄贈</span>\n          </div>\n          <div class=\"social-project-name\">環境対応電気自動車の寄贈</div>\n          <div class=\"social-project-detail\">\n            <p>2025年5月、企業版ふるさと納税の仕組みを活用し、所沢市へ電気自動車「Honda e」1台を寄贈しました。脱炭素社会の実現（ゼロカーボンシティ）への貢献と、未来を担う子どもたちの教育環境向上を目的としています。</p>\n            <a href=\"https://www.city.tokorozawa.saitama.jp/shiseijoho/keikaku/kanminrenkei/seisak20230523152618980.html\"\n              target=\"_blank\">https://www.city.tokorozawa.saitama.jp/shiseijoho/keikaku/kanminrenkei/seisak20230523152618980.html</a>\n          </div>\n          <div class=\"social-project-image\">\n            <img src=\"https://www.hondacars-saitamanishi.co.jp/recruit/wp-content/themes/recruit/img/social-item13.jpg\" alt=\"\">\n          </div>\n        </div>\n\n      </div>\n    </section>\n  </div>\n</main>\n\n\n<!-- フッター -->\n<footer class=\"footer\">\n  <!-- SNS エリア -->\n  <div class=\"footer-sns-area\">\n    <h2 class=\"footer-sns-title\">Official SNS</h2>\n    <div class=\"footer-sns-icons\">\n      <a href=\"https://www.instagram.com/hondacars3124/\" class=\"footer-icon\" aria-label=\"Instagram\" target=\"_blank\">\n        <img src=\"https://www.hondacars-saitamanishi.co.jp/recruit/wp-content/themes/recruit/img/sns/Instagram_Glyph_Gradient.png\" alt=\"Instagram\">\n      </a>\n      <a href=\"https://www.facebook.com/profile.php?id=100076060586114&locale=ja_JP\" class=\"footer-icon\" aria-label=\"Facebook\" target=\"_blank\">\n        <img src=\"https://www.hondacars-saitamanishi.co.jp/recruit/wp-content/themes/recruit/img/sns/Facebook_Logo_Primary.png\" alt=\"Facebook\">\n      <