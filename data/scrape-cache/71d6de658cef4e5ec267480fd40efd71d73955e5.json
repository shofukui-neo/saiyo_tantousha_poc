ool-recruit/assets/image/top/character03_pc.svg\" alt=\"\" class=\"fluidimage switch desvg\">\n\n\n\n            </a>\n            <a href=\"#modal-04\" id=\"open-04\" class=\"character character04\"> <span class=\"character_fukidashi\">\n                <img src=\"/high_school-recruit/assets/image/top/character_fukidashi04.svg\" alt=\"休みは休みでも…\" class=\"fluidimage\">\n              </span><img src=\"/high_school-recruit/assets/image/top/character04.svg\" alt=\"\" class=\"fluidimage desvg\">\n            </a>\n          </div>\n          <div class=\"column column03\">\n            <a href=\"/high_school-recruit/hataraku/\" class=\"gameBox box03 imgalpha\">\n              <div class=\"gameBox_inner\">\n                <p class=\"gameBox_num\">03</p>\n                <p class=\"gameBox_img\"> <img src=\"/high_school-recruit/assets/image/top/gameBox_img03.webp\" alt=\"\" class=\"fluidimage\"></p>\n                <h2 class=\"gameBox_ttl\">\n                  <span class=\"gameBox_ttlBig\">はたらくひと</span>\n                  を<br>\n                  ササエルって？</h2>\n                <h2 class=\"gameBox_catch\"><span>福利厚生</span></h2>\n                <p class=\"gameBox_txt\">休暇や独自の支援など・・・<br>\n                  さまざまな福利厚生をチェック。</p>\n                <p class=\"gameBox_link\">もっと詳しく</p>\n              </div>\n              <p class=\"gameBox_imgBg\"></p>\n            </a>\n            <a href=\"#modal-05\" id=\"open-05\" class=\"character character05\">\n              <span class=\"character_fukidashi\">\n                <img src=\"/high_school-recruit/assets/image/top/character_fukidashi05.svg\" alt=\"休憩中も安心…！\" class=\"fluidimage\">\n              </span>\n              <img src=\"/high_school-recruit/assets/image/top/character05_pc.svg\" alt=\"\" class=\"fluidimage switch desvg\">\n            </a>\n          </div>\n          <div class=\"column column04\">\n            <a href=\"/high_school-recruit/mirai/\" class=\"gameBox box04 imgalpha\">\n              <div class=\"gameBox_inner\">\n                <p class=\"gameBox_num\">04</p>\n                <p class=\"gameBox_img\"> <img src=\"/high_school-recruit/assets/image/top/gameBox_img04.webp\" alt=\"\" class=\"fluidimage\"></p>\n                <h2 class=\"gameBox_ttl\">\n                  <span class=\"gameBox_ttlBig\">みらい</span>\n                  を<br>\n                  ササエルって？</h2>\n                <h2 class=\"gameBox_catch\"><span>キャリア育成</span></h2>\n                <p class=\"gameBox_txt\">得られるスキルや資格、未来のキャリア<br class=\"sp\">ステップを<br class=\"pc\">\n                  のぞいてみましょう。</p>\n                <p class=\"gameBox_link\">もっと詳しく</p>\n              </div>\n              <p class=\"gameBox_imgBg\"></p>\n            </a>\n            <a href=\"#modal-06\" id=\"open-06\" class=\"character character06\">\n              <span class=\"character_fukidashi\">\n                <img src=\"/high_school-recruit/assets/image/top/character_fukidashi06.svg\" alt=\"テンションが上がるのは…\" class=\"fluidimage\">\n              </span>\n              <img src=\"/high_school-recruit/assets/image/top/character06_pc.svg\" alt=\"\" class=\"fluidimage switch desvg\">\n            </a>\n          </div>\n        </div>\n      </div>\n      <div class=\"goal\">\n        <h2 class=\"goal_ttl\">\n          <picture>\n            <source media=\"(max-width: 768px)\" srcset=\"/high_school-recruit/assets/image/top/game_goalImg01_sp.svg\">\n            <img src=\"/high_school-recruit/assets/image/top/game_goalImg01_pc.svg\" alt=\"\">\n          </picture>\n        </h2>\n        <p class=\"goal_img\">\n          <picture>\n            <source media=\"(max-width: 768px)\" srcset=\"/high_school-recruit/assets/image/top/game_goalImg02_sp.webp\">\n            <img src=\"/high_school-recruit/assets/image/top/game_goalImg02_pc.webp\" alt=\"\" class=\"fluidimage\">\n          </picture>\n        </p>\n        <p class=\"goal_txt\">\n          <picture>\n            <source media=\"(max-width: 768px)\" srcset=\"/high_school-recruit/assets/image/top/game_goalTxt03_sp.svg\">\n            <img src=\"/high_school-recruit/assets/image/top/game_goalImg03_pc.svg\" alt=\"\" class=\"fluidimage\">\n          </picture>\n        </p>\n      </div>\n    </section>\n    <!-- /.game -->\n    <div class=\"pre-footer\">\n      <div class=\"inner\">\n        <a href=\"/high_school-recruit/interview/\" class=\"p-footer_block imgalpha\">\n          <h2 class=\"p-footer_ttl\">先輩インタビュー</h2>\n          <p class=\"p-footer_txt\">リブドゥコーポレーションをささえ活躍する<br>\n            先輩たちのインタビューを紹介。</p>\n          <span class=\"p-footer_link\">もっと詳しく</spana>\n        </a><!-- p-footer_block -->\n\n        <a href=\"/high_school-recruit/for-guardian/\" class=\"p-footer_block imgalpha\">\n          <h2 class=\"p-footer_ttl\">保護者ならびに先生方へ</h2>\n          <p class=\"p-footer_txt\">採用に関する情報や、<br>\n            お問い合わせ先を紹介。</p>\n          <span class=\"p-footer_link\">もっと詳しく</span>\n        </a>\n      </div>\n    </div>\n    <footer>\n      <div class=\"inner\">\n        <a href=\"#pageTop\" class=\"footer_goTop\">TOPへ</a>\n        <h2 class=\"footer_ttl\">採用情報</h2>\n        <p class=\"footer_txt\">進路ご担当の先生を通じて<br class=\"sp\">お問い合わせください</p>\n        <a href=\"/high_school-recruit/infomation/\" class=\"footer_link\">採用情報はこちら</a>\n        <p class=\"footer_copy\">© 2025 Livedo Corporation</p>\n      </div>\n    </footer>\n    <!-- /footer -->\n  </article>\n  <!-- /article -->\n\n  <div id=\"modal-01\" class=\"modal_wrap\">\n    <div class=\"modal_box\">\n      <div class=\"modal_boxTxtBox\">\n        <h2 class=\"modal_boxTtl\">Point 01</h2>\n        <h3 class=\"modal_boxSubTtl\">BBQパーティー！</h3>\n        <p class=\"modal_boxTxt\">会社主催のBBQパーティーがあります！これをきっかけに仲良くなった人もたくさんいますよ！（徳島貞光・徳島三野・徳島市場工場/栃木芳賀工場/愛媛新居浜工場）</p>\n      </div>\n      <div class=\"modal_boxImgBox\">\n        <img src=\"/high_school-recruit/assets/image/top/modal_boxImg01.webp\" alt=\"\" class=\"fluidimage\">\n      </div>\n      <span class=\"close-modal close-modal-01\"><img src=\"/high_school-recruit/assets/image/common/ico_modalClose01_pc.svg\" alt=\"\"></span>\n    </div>\n  </div>\n\n  <div id=\"modal-02\" class=\"modal_wrap\">\n    <div class=\"modal_box\">\n      <div class=\"modal_boxTxtBox\">\n        <h2 class=\"modal_boxTtl\">Point 02</h2>\n        <h3 class=\"modal_boxSubTtl\">食堂のおすすめ！</h3>\n        <p class=\"modal_boxTxt\">冷凍の社食がとにかく充実してる！麺類やライスバーガーにピラフ、厚切りフレンチトーストやドーナツが全部100～200円で食べられます！（栃木芳賀工場）</p>\n      </div>\n      <div class=\"modal_boxImgBox\">\n        <img src=\"/high_school-recruit/assets/image/top/modal_boxImg02.webp\" alt=\"\" class=\"fluidimage\">\n      </div>\n      <span class=\"close-modal close-modal-02\"><img src=\"/high_school-recruit/assets/image/common/ico_modalClose01_pc.svg\" alt=\"\"></span>\n    </div>\n  </div>\n\n  <div id=\"modal-03\" class=\"modal_wrap\">\n    <div class=\"modal_box\">\n      <div class=\"modal_boxTxtBox\">\n        <h2 class=\"modal_boxTtl\">Point 03</h2>\n        <h3 class=\"modal_boxSubTtl\">くつろぎスペース！</h3>\n        <p class=\"modal_boxTxt\">エントランスにあるくつろぎスペースがお気に入り！無料のお茶やコーヒーを飲みながら、同期や先輩とおしゃべりするのが日課です。（愛媛新居浜工場）</p>\n      </div>\n      <div class=\"modal_boxImgBox\">\n        <img src=\"/high_school-recruit/assets/image/top/modal_boxImg03.webp\" alt=\"\" class=\"fluidimage\">\n      </div>\n      <span class=\"close-modal close-modal-03\"><img src=\"/high_school-recruit/assets/image/common/ico_modalClose01_pc.svg\" alt=\"\"></span>\n    </div>\n  </div>\n\n  <div id=\"modal-04\" class=\"modal_wrap\">\n    <div class=\"modal_box\">\n      <div class=\"modal_boxTxtBox\">\n        <h2 class=\"modal_boxTtl\">Point 04</h2>\n        <h3 class=\"modal_boxSubTtl\">特別な休暇！</h3>\n        <p class=\"modal_boxTxt\">誕生日月とその前後1カ月のうち、好きな1日を休みにできるバースデー休暇制度があります！特別な休暇は、仕事のモチベーションUPにつながります！</p>\n      </div>\n      <div class=\"modal_boxImgBox\">\n        <img src=\"/high_school-recruit/assets/image/top/modal_boxImg04.webp\" alt=\"\" class=\"fluidimage\">\n      </div>\n      <span class=\"close-modal close-modal-04\"><img src=\"/high_school-recruit/assets/image/common/ico_modalClose01_pc.svg\" alt=\"\"></span>\n    </div>\n  </div>\n\n  <div id=\"modal-05\" class=\"modal_wrap\">\n    <div class=\"modal_box\">\n      <div class=\"modal_boxTxtBox\">\n        <h2 class=\"modal_boxTtl\">Point 05</h2>\n        <h3 class=\"modal_boxSubTtl\">社内Wi-Fi完備！</h3>\n        <p class=\"modal_boxTxt\">工場内は社内Wi-Fiが完備されているので、休憩時間中はネットサーフィンを楽しんでいます！</p>\n      </div>\n      <div class=\"modal_boxImgBox\">\n        <img src=\"/high_school-recruit/assets/image/top/modal_boxImg05.webp\" alt=\"\" class=\"fluidimage\">\n      </div>\n      <span class=\"close-modal close-modal-05\"><img src=\"/high_school-recruit/assets/image/common/ico_modalClose01_pc.svg\" alt=\"\"></span>\n    </div>\n  </div>\n\n  <div id=\"modal-06\" class=\"modal_wrap\">\n    <div class=\"modal_box\">\n      <div class=\"modal_boxTxtBox\">\n        <h2 class=\"modal_boxTtl\">Point 06</h2>\n        <h3 class=\"modal_boxSubTtl\">トイレがきれい！</h3>\n        <p class=\"modal_boxTxt\">工場のトイレがすごく広くてきれい！<br>\n          女性更衣室には、パウダールームを完備！<br>\n          帰る前に身支度をするときも、地味にテンションが上がります！（愛媛新居浜工場）</p>\n      </div>\n      <div class=\"modal_boxImgBox\">\n        <img src=\"/high_school-recruit/assets/image/top/modal_boxImg06.webp\" alt=\"\" class=\"fluidimage\">\n      </div>\n      <span class=\"close-modal close-modal-06\"><img src=\"/high_school-recruit/assets/image/common/ico_modalClose01_pc.svg\" alt=\"\"></span>\n    </div>\n  </div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n  <a href=\"#pageTop\" class=\"go_top\"><img src=\"/high_school-recruit/assets/image/common/ico_goTop01_pc.svg\" alt=\"\"></a>\n\n\n\n  <!-- js -->\n  <script src=\"https://code.jquery.com/jquery-3.3.1.js\"></script>\n  <script src=\"https://cdnjs.cloudflare.com/ajax/libs/body-scroll-lock/3.1.5/bodyScrollLock.min.js\"></script>\n  <script src=\"https://unpkg.co/gsap@3/dist/gsap.min.js\"></script>\n  <script src=\"https://unpkg.com/gsap@3/dist/ScrollTrigger.mi