1\">\r\n                <div class=\"content-wrap\">\r\n                    <div class=\"content\">\r\n                        <div class=\"inner-wrap\">\r\n                            <div class=\"inner\">\r\n                                <h3 class=\"font-ls\">Suwa Sansha<br>Recruit</h3>\r\n                            </div>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n            <div class=\"main-wrap main-wrap2\">\r\n                <div class=\"content-wrap\">\r\n                    <div class=\"content\">\r\n                        <div class=\"inner-wrap\">\r\n                            <div class=\"inner\">\r\n                                <ul>\r\n                                    <li>\r\n\t\t\t\t\t <span>\r\n\t\t\t\t\t    <span class=\"left\">2026.05.27<span>新着</span></span>\r\n                                        　 <span class=\"right\">6月合同説明会参加情報　ぜひ当社ブースへお越しください。<br />\r\n\t\t\t\t\t\t6月 4日(木) 13:30～15:00<br />　茅野高等学校　企業説明会・研究会　学内イベント<br />\r\n\t\t\t\t\t\t6月 5日(金) 時間未定         <a href=\"https://mono-web.jp/seminar/list\">理系就活のひろば</a><br />\r\n\t\t\t\t\t\t6月 6日(土) 10:00～12:40<br />　諏訪東京理科大学　合同企業研究セミナー　学内イベント<br />\r\n\t\t\t\t\t\t6月11日(木) 13:30～17:30<br />　高校生のじもと研究会　上諏訪温泉浜の湯<br />\r\n\t\t\t\t\t\t6月13日(土) 14:00～17:00<br />　<a href=\"https://work-suwa.jp/17429/\">諏訪地域合同就職説明会＆インターンシップフェア</a>　茅野市民館<br />\r\n\t\t\t\t\t\t6月20日(土) 13:00～17:00<br />　<a href=\"https://job.mynavi.jp/conts/event/2028/10625/index.html\">マイナビインターンシップ＆キャリア発見フェア</a><br />　松本ホテルブエナビスタ</span>\r\n                                        </span>\r\n                                    </li>\r\n                                    <li>\r\n                                        <span>\r\n\r\n\t\t\t\t\t    <span class=\"left\">2026.05.20<span>新着</span></span>\r\n                                        　 <span class=\"right\">新卒採用に新たに営業職の募集を開始しました。<br />\r\n\t\t\t\t\t\t\t\t\tキャリア採用に新たに購買の募集を開始しました。</span>\r\n                                        </span>\r\n                                    </li>\r\n                                    <li>\r\n                                        <span>\r\n\t\t\t\t\t    <span class=\"left\">2026.05.18</span>\r\n                                        　 <span class=\"right\">5月合同説明会参加情報　ぜひ当社ブースへお越しください。<br />\r\n                                                5月20日(水) 13:00～14:20<br />　長野高専インターンシップ交流会　学内イベント<br />\r\n                                                5月22日(金) 13:00～15:00<br />　岡谷工業高等学校　合同企業研究会　学内イベント<br />\r\n\t\t\t\t\t\t5月25日(月) 8:55～12:00<br />　岡谷東高等学校　合同企業研究会　学内イベント<br />\r\n\t\t\t\t\t\t5月25日(月) 14:00～15:15<br />　諏訪二葉高等学校　地元企業お悩み解決隊・説明会　学内イベント</span>\r\n                                        </span>\r\n                                    </li>\r\n                                </ul>\r\n                            </div>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n            <div class=\"main-wrap main-wrap3\">\r\n                <div class=\"content-wrap\">\r\n                    <div class=\"content\">\r\n                        <div class=\"inner-wrap mv\">\r\n                            <div class=\"inner\">\r\n                                <div class=\"inner-left\">\r\n                                    &nbsp;\r\n                                </div>\r\n                                <div class=\"inner-right\">\r\n                                    <h3 class=\"font-ls\">Movie<span>動画</span></h3>\r\n                                    <p>\r\n                                        新卒採用 WEB会社説明会動画配信中！<br>\r\n                                        グループで働くスタッフの姿や想いを映像で<br class=\"only-pc\">お届けいたします。\r\n                                    </p>\r\n                                </div>\r\n                                <img class=\"only-sp\" src=\"images/movie_01_sp.jpg\" alt=\"Movie 動画\">\r\n                            </div>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n            <div class=\"main-wrap main-wrap4\">\r\n                <div class=\"content-wrap\">\r\n                    <div class=\"content\">\r\n                        <div class=\"inner-wrap\">\r\n                            <div class=\"inner\">\r\n                                <h3 class=\"font-ls\">Purpose<span>パーパス</span></h3>\r\n\t\t\t\t\t\t\t\t<h4>パワーエレクトロニクスと<br class=\"only-sp\">創造⼒で、<br class=\"only-sp\">社会を前進させる。</h4>\r\n                                <ul>\r\n                                    <li>\r\n                                        <span class=\"detail\">\r\n                                            <h5>パワーエレクトロニクス</h5>\r\n                                            <p>\r\n\t\t\t\t\t\t\t\t\t\t\t\t私たちの変わることがない社会の役割、事業領域。<br>\r\n\t\t\t\t\t\t\t\t\t\t\t\t私たちは常にパワーエレクトロニクスと向き合っていきます。\r\n\t\t\t\t\t\t\t\t\t\t\t</p>\r\n                                        </span>\r\n                                    </li>\r\n                                    <li>\r\n                                        <span class=\"detail\">\r\n                                            <h5>創造力</h5>\r\n                                            <p>\r\n\t\t\t\t\t\t\t\t\t\t\t\t私たちは技術の会社ですが、技術者だけでなく、全ての社員がパーパスを基に活動していきます。<br>\r\n\t\t\t\t\t\t\t\t\t\t\t\t全ての社員が創造性を意識して、オンリーワンにこだわって活動していきます。\r\n\t\t\t\t\t\t\t\t\t\t\t</p>\r\n                                        </span>\r\n                                    </li>\r\n                                    <li>\r\n                                        <span class=\"detail\">\r\n                                            <h5>社会を前進させる</h5>\r\n                                            <p>\r\n\t\t\t\t\t\t\t\t\t\t\t\t電源機器とパワー半導体のメーカーとして、社会がより良い方向に進んでいく源であり、力になっていくこと。<br>\r\n\t\t\t\t\t\t\t\t\t\t\t\t私たちが存在している意義であり、志です。\r\n\t\t\t\t\t\t\t\t\t\t\t</p>\r\n                                        </span>\r\n                                