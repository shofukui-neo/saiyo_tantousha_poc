', new Date());\n  gtag('config', 'UA-2097811-1');\n  gtag('config', 'G-0BNP76Q4Q7');\n</script>\n</head>\n\n<body>\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=AW-734422123\"></script> \n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n  gtag('config', 'AW-734422123');\n</script>\n<div class=\"openbtn\"><span></span><span></span><span></span></div>\n<nav id=\"g-nav\">\n        <div id=\"g-nav-list\">\n                <ul>\n                        <li><a href=\"../index.html#01_business\" title=\"事業を知る\">事業を知る</a></li>\n                        <li><a href=\"../index.html#02_member\" title=\"職種と人を知る\">職種と人を知る</a></li>\n                        <li><a href=\"../index.html#03_workspace\" title=\"環境・待遇を知る\">環境・待遇を知る</a></li>\n                        <li><a href=\"../index.html#04_information\" title=\"新卒採用\">新卒採用</a></li>\n                        <li><a href=\"../index.html#04_information\" title=\"キャリア採用\">キャリア採用</a></li>\n                </ul>\n        </div>\n</nav>\n<nav class=\"pc\">\n        <div class=\"inner\">\n                <div class=\"logo\"><a href=\"../index.html\"><img src=\"../images/index/logo.svg\" alt=\"ソリマチ株式会社採用情報\"></a></div>\n                <div class=\"area\">\n                        <ul>\n                                <li><a href=\"../business/service.html\" title=\"事業を知る\">事業を知る</a></li>\n                                <li><a href=\"movie.html\" title=\"職種と人を知る\" class=\"select\">職種と人を知る</a></li>\n                                <li><a href=\"../workspace/office.html\" title=\"環境・待遇を知る\">環境・待遇を知る</a></li>\n                                <li><a href=\"../recruit/newgraduate.html\" title=\"新卒採用\">新卒採用</a></li>\n                                <li><a href=\"../recruit/career.html\" title=\"キャリア採用\">キャリア採用</a></li>\n                        </ul>\n                </div>\n        </div>\n</nav>\n<div id=\"contents\">\n        <div class=\"inner\">\n                <div class=\"side side--sticky\">\n                        <h1>職種と人を知る</h1>\n                        <ul>\n                                <li><a href=\"movie.html\" title=\"06 新卒採用コンセプト動画\">06 新卒採用コンセプト動画</a></li>\n                                <li><a href=\"engineer.html\" title=\"07 技術を研ぐ職業\" class=\"select\">07 技術を研ぐ職業</a></li>\n                                <li><a href=\"business.html\" title=\"08 人と人を繋ぐ職業\">08 人と人を繋ぐ職業</a></li>\n                                <li><a href=\"recruit.html\" title=\"09 採用担当の紹介\">09 採用担当の紹介</a></li>\n                        </ul>\n                </div>\n                <div class=\"area\">\n                        <h1>Engineer</h1>\n                        <h2><span>07</span>技術を研ぐ仕事<span class=\"sm\">（エンジニア）</span></h2>\n                        <p>ソリマチで活躍するエンジニア社員を紹介します。若手からベテランまで色々な社員のインタビューを公開しています。</p>\n                        <img src=\"../images/member/img_22.jpg\" width=\"700\" class=\"img_kadoR marB30\"/>\n                        <div class=\"point_wrap marB30\">\n                                <div class=\"point\">\n                                        <h4><span class=\"point_tle\">STEP.01</span><img src=\"../images/member/img_27.jpg\" width=\"110\" alt=\"\"/></h4>\n                                        <img src=\"../images/member/img_03.png\" alt=\"\" width=\"100%\" class=\"marB10\"/> </div>\n                                <div class=\"point\">\n                                        <h4><span class=\"point_tle\">STEP.02</span><img src=\"../images/member/img_16.png\" width=\"80\" alt=\"\"/></h4>\n                                        <img src=\"../images/member/img_05.png\" alt=\"\" width=\"100%\" class=\"marB10\"/>\n                                        <div class=\"balloon\">ITエンジニア</div>\n                                </div>\n                                <div class=\"point\">\n                                        <h4><span class=\"point_tle\">STEP.03</span><img src=\"../images/member/img_17.png\" width=\"80\" alt=\"\"/></h4>\n                                        <img src=\"../images/member/img_06.png\" alt=\"\" width=\"100%\" class=\"marB10\"/>\n                                        <div class=\"balloon\">QMエンジニア</div>\n                                </div>\n                        </div>\n                        <h3>仕事紹介</h3>\n                        <h5>ITエンジニア(システムエンジニア・プログラマー)</h5>\n                        <p><img src=\"../images/member/img_25.jpg\" width=\"250\" alt=\"ITエンジニア(システムエンジニア　プログラマー)\" class=\"img_rwd_r img_kadoR\"/>ソフトウェア製品、クラウドシステムの企画・設計から開発、テストまで(上流～下流工程)担当します。プロジェクトごとにチームで開発作業に取り組みます。自社開発のメーカーのため、企画段階から携わり、お客様に満足いただける製品開発を行います。</p>\n                        <div class=\"clear\"></div>\n                        <h5>QMエンジニア(品質管理)</h5>\n                        <p><img src=\"../images/member/img_26.jpg\" width=\"250\" alt=\"QMエンジニア(品質管理)\" class=\"img_rwd_r img_kadoR\"/>設計や仕様からITエンジニアとともに製品に関わります。自社で開発した製品のテスト項目設計、テストを行い、お客様が安心して使えるよう品質を高めます。製品の知識やユーザー視点が必要となるお仕事です。</p>\n                        <div class=\"clear\"></div>\n                        <h3 class=\"heading04\">YouTubeで公開中</h3>\n                        <div class=\"interview_wrap marB30\">\n                                <div class=\"interview\">\n                                        <div class=\"balloon-interview\">人が温かく、質問しやすい環境</div>\n                                        <div class=\"youtube\">\n                                                <iframe width=\"560\" height=\"315\" src=\"https://www.youtube.com/embed/J55ctQ_gG6k?si=M1fuTazBH253kOQC\" title=\"YouTube video player\" frameborder=\"0\" allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share\" allowfullscreen></iframe>\n                                        </div>\n                                </div>\n                                <div class=\"interview\">\n                                        <div class=\"balloon-interview\">1年目から\"戦力\"</div>\n                                        <div class=\"youtube\">\n                                                <iframe width=\"560\" height=\"315\" src=\"https://www.youtube.com/embed/7erj-XxLsLA?si=FTJTmyNhXh19KpFM\" title=\"YouTube video player\" frameborder=\"0\" allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share\" allowfullscreen></iframe>\n                                        </div>\n                                </div>\n                                <div class=\"interview\">\n                                        <div class=\"balloon-interview\">若いうちからマネジメントに挑戦</div>\n                                        <div class=\"youtube\">\n                                                <iframe width=\"560\" height=\"315\" src=\"https://www.youtube.com/embed/jNhMBuEaF04?si=12PJAaf6Z0h22W7w\" title=\"YouTube video player\" frameborder=\"0\" allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share\" allowfullscreen></iframe>\n                                        </div>\n                                </div>\n                                <div class=\"interview\">\n                                        <div class=\"balloon-interview\">安心できる製品を届けたい</div>\n                                        <div class=\"youtube\">\n                                                <iframe width=\"560\" height=\"315\" src=\"https://www.youtube.com/embed/szaaWkkMFE4?si=Vv4Pv44Pfv5RMrgB\" title=\"YouTube video player\" frameborder=\"0\" allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share\" allowfullscreen></iframe>\n                                        </div>\n                                </div>\n                        </div>\n                        \n                        <!--\n                        <div class=\"interview_wrap marB30\">\n                                <div class=\"interview\">\n                                        <div class=\"balloon-interview\">進化に追従・開拓し続けています</div>\n                                        <div class=\"youtube\">\n                                                <iframe width=\"560\" height=\"315\" src=\"https://www.youtube.com/embed/J55ctQ_gG6k?si=M1fuTazBH253kOQC\" title=\"YouTube video player\" frameborder=\"0\" allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share\" allowfullscreen></iframe>\n                                        </div>\n                                </div>\n                                <div class=\"interview\">\n                                        <div class=\"balloon-interview\">成長を「後押し」する会社です</div>\n                                        <div class=\"youtube\">\n                                                <iframe width=\"560\" height=\"315\" src=\"https://www.youtube.com/embed/7erj-XxLsLA?si=FTJTmyNhXh19KpFM\" title=\"YouTube video player\" frameborder=\"0\" allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share\" allowfullscreen></iframe>\n                                        </div>\n                                </div>\n                                <div class=\"interview\">\n                                        <div class=\"balloon-interview\">新潟で働く喜びを後輩へ繋ぐ</div>\n                                        <div class=\"youtube\">\n                                                <iframe width=\"560\" height=\"315\" src=\"https://www.youtube.com/embed/jNhMBuEaF04?si=12PJAaf6Z0h22W7w\" title=\"YouTube video player\" frameborder=\"0\" allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share\" allowfullscreen></iframe>\n                                        </div>\n                                </div>\n                                <div class=\"interview\">\n                                        <div class=\"balloon-interview\">男性でも安心して育休</div>\n                                        <div class=\"youtube\">\n                                                <iframe width=\"560\" height=\"315\" src=\"https://www.youtube.com/embed/szaaWkkMFE4?si=Vv4Pv44Pfv5RMrgB\" title=\"YouTube video player\" frameborder=\"0\" allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share\" allowfullscreen></iframe>\n                                        </div>\n                                </div>\n                                <div class=\"interview\">\n                                        <div class=\"balloon-interview\">変化が激しいなかでもスキルアップ</div>\n                                        <div class=\"youtube\">\n                                                <iframe width=\"560\" height=\"315\" src=\"https://www.youtube.com/embed/szaaWkkMFE4?si=Vv4Pv44Pfv5RMrgB\" title=\"YouTube video player\" frameborder=\"0\" allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share\" allowfullscreen></iframe>\n                                        </div>\n                                </div>\n                        </div>-->\n                        <h3 class=\"heading04\">インタビュー記事</h3>\n                        <p class=\"txt_cent\">ソリマチリクルートブックで記事を読むことができます。</p>\n                        <a href=\"../pdf/guide_book.pdf\" target=\"_blank\"><img src=\"../images/member/img_13.jpg\" alt=\"進化に追従・開拓し続けています\" style=\"width: 50%; border:1px solid #ccc;\" class=\"img_cent\"/></a>\n                        <ol class=\"pagination\">\n                                <li class=\"prev\"><a href=\"../business/family.html\"><</a></li>\n                                <li><a href=\"movie.html\">6</a></li>\n                                <li class=\"current\"><a href=\"engineer.html\">7</a></li>\n                                <li><a href=\"business.html\">8</a></li>\n                                <li><a href=\"recruit.html\">9</a></li>\n                                <li class=\"next\"><a href=\"../workspace/office.html\">></a></li>\n                        </ol>\n                </div>\n        </div>\n</div>\n<footer>\n        <div class=\"inner\"> &copy; Copyright Sorimachi Co.,Ltd. All rights reserved. </div>\n</footer>\n<div class=\"pagetop\"><a href=\"#\">▲</a></div>\n</body>\n</html>","finalUrl":"https://sorimachi.co.jp/about/recruit/member/engineer.html","rendered":false,"_cachedAt":"2026-06-23T23:07:09.819Z"}