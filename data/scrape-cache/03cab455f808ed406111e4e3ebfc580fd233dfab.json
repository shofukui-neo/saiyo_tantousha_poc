{"url":"https://www.cmp.co.jp/recruit_fresh/career/","html":"<!doctype html>\n<html lang=\"ja\">\n<head>\n<meta charset=\"utf-8\" />\n<meta http-equiv=\"Content-Style-Type\" content=\"text/css\" />\n<meta http-equiv=\"Content-script-type\" content=\"text/javascript\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<meta name=\"format-detection\" content=\"telephone=no\">\n<meta name=\"robots\" content=\"noindex\">\n<title>キャリアステップ | 新卒採用情報 | 中国塗料株式会社</title>\n<meta name=\"description\" content=\"中国塗料株式会社の採用情報サイトです。採用に関する情報をお知らせしています。「キャリアステップ」をご紹介します。\">\n<meta property=\"og:title\" content=\"キャリアステップ | 新卒採用情報 | 中国塗料株式会社\">\n<meta property=\"og:site_name\" content=\"新卒採用情報 | 中国塗料株式会社\">\n<meta property=\"og:description\" content=\"中国塗料株式会社の採用情報サイトです。採用に関する情報をお知らせしています。「キャリアステップ」をご紹介します。\">\n<meta property=\"og:type\" content=\"article\">\n<meta property=\"og:image\" content=\"/recruit_fresh/common/img/ogp.jpg\">\n<meta property=\"og:url\" content=\"https://www.cmp.co.jp/recruit_fresh/career/\">\n<meta property=\"og:locale\" content=\"ja_JP\">\n\n<!-- このページで使用するcssを読み込む -->\n<link rel=\"icon\" href=\"https://www.cmp.co.jp/library/cmp_jpn/img/favicon.ico\">\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/yakuhanjp@4.1.1/dist/css/yakuhanjp.css\">\n<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n<link href=\"https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@100..900&family=Raleway:ital,wght@0,100..900;1,100..900&display=swap\" rel=\"stylesheet\">\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../common/css/common.css\" media=\"all, projection, print\" />\n<link href=\"https://unpkg.com/aos@2.3.1/dist/aos.css\" rel=\"stylesheet\">\n\t\n<link rel=\"stylesheet\" href=\"../common/css/scroll-hint.css\" media=\"all, projection, print\">\t\n<link rel=\"stylesheet\" type=\"text/css\" href=\"css/style.css\" media=\"all, projection,