                 </div>\n                  <ul class=\"link-list-wrap js-accordion-wrap\">\n                    <li class=\"item\">\n                      <a href=\"/recruit/data/\">\n                        <span class=\"txt\">データで見る</span>\n                        <svg class=\"arrow\">\n                          <use xlink:href=\"/recruit/img/svg/sprite-symbol.svg#icon-arrow\"></use>\n                        </svg>\n                      </a>\n                    </li>\n                    <li class=\"item\">\n                      <a href=\"/recruit/product/\">\n                        <span class=\"txt\">暮らしの中の大鐵</span>\n                        <svg class=\"arrow\">\n                          <use xlink:href=\"/recruit/img/svg/sprite-symbol.svg#icon-arrow\"></use>\n                        </svg>\n                      </a>\n                    </li>\n                    <li class=\"item\">\n                      <a href=\"/recruit/movie/\">\n                        <span class=\"txt\">スペシャルムービー</span>\n                        <svg class=\"arrow\">\n                          <use xlink:href=\"/recruit/img/svg/sprite-symbol.svg#icon-arrow\"></use>\n                        </svg>\n                      </a>\n                    </li>\n                  </ul>\n                </div>\n                <!-- Top, Faq, Corporate -->\n                <div class=\"wrap no-flex min-1340\">\n                  <a href=\"/recruit/\" class=\"c-title01 c-title01__left\">\n                    <span class=\"en\">Top</span>\n                    <span class=\"ja\">採用トップ</span>\n                  </a>\n                  <a href=\"/recruit/faq/\" class=\"c-title01 c-title01__left\">\n                    <span class=\"en\">Faq</span>\n                    <span class=\"ja\">よくあるご質問</span>\n                  </a>\n                  <a href=\"/\" class=\"link link__blank\">-コーポレートサイトトップへ</a>\n                </div>\n              </div>\n              <div class=\"bottom-wrap\">\n        