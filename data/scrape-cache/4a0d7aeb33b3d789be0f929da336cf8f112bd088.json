{"url":"https://www.osaka-seitetu.co.jp/recruit/career/","html":"\n\n<!DOCTYPE html>\n<html lang=\"ja\">\n\n<head>\n  <!-- Google Tag Manager -->\n  <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\n  new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\n  j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n  'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n  })(window,document,'script','dataLayer','GTM-PPQTCSGM');</script>\n  <!-- End Google Tag Manager -->\n\t\t\t\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width\">\n  <meta name=\"format-detection\" content=\"telephone=no\">\n  \n  <!-- title,description -->\n  <title>職種紹介/キャリア事例 | 大阪製鐵株式会社リクルートサイト</title>\n  <meta name=\"description\" content=\"職種をキャリア事例を交えてご紹介しております。大阪を本拠とする鉄鋼メーカー大阪製鐵株式会社(おおさかせいてつ)のリクルートサイトです。職種の紹介、先輩社員の紹介、福利厚生、研修制度などさまざまな角度から見たコンテンツで当社を知っていただけます。\">\n  <link rel=\"canonical\" href=\"https://www.osaka-seitetu.co.jp/recruit/career/\">\n\n  <!-- ogp -->\n  <meta property=\"og:locale\" content=\"ja_JP\">\n  <meta property=\"og:url\" content=\"https://www.osaka-seitetu.co.jp/recruit/career/\">\n      <meta property=\"og:type\" content=\"article\">\n    <meta property=\"og:title\" content=\"職種紹介/キャリア事例 | 大阪製鐵株式会社リクルートサイト\">\n  <meta property=\"og:description\" content=\"職種をキャリア事例を交えてご紹介しております。大阪を本拠とする鉄鋼メーカー大阪製鐵株式会社(おおさかせいてつ)のリクルートサイトです。職種の紹介、先輩社員の紹介、福利厚生、研修制度などさまざまな角度から見たコンテンツで当社を知っていただけます。\">\n  <meta property=\"og:site_name\" content=\"大阪製鐵株式会社リクルートサイト\">\n  <meta property=\"og:image\" content=\"https://www.osaka-seitetu.co.jp/recruit/img/common/ogp-img.png\">\n\n  <!-- favicon/webclipicon -->\n  <link rel=\"apple-touch-icon\" href=\"https://www.osaka-seitetu.co.jp/recruit/img/common/apple-touch-icon.png\" type=\"image/png\" sizes=\"180x180\">\n  <link rel=\"shortcut icon\" href=\"/favicon.ico\" type=\"image/vnd.microsoft.icon\">\n  <link rel=\"icon\" href=\"/favicon.ico\"