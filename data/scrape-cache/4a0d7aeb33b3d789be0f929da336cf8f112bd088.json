ist-wrap\">\n                        <li class=\"item\">\n                          <a href=\"/recruit/welfare#room\">\n                            <span class=\"txt\">独身寮・社宅</span>\n                            <svg class=\"arrow\">\n                              <use xlink:href=\"/recruit/img/svg/sprite-symbol.svg#icon-arrow\"></use>\n                            </svg>\n                          </a>\n                        </li>\n                        <li class=\"item\">\n                          <a href=\"/recruit/welfare#pension\">\n                            <span class=\"txt\">確定拠出年金</span>\n                            <svg class=\"arrow\">\n                              <use xlink:href=\"/recruit/img/svg/sprite-symbol.svg#icon-arrow\"></use>\n                            </svg>\n                          </a>\n                        </li>\n                        <li class=\"item\">\n                          <a href=\"/recruit/welfare#club\">\n                            <span class=\"txt\">部活動</span>\n                            <svg class=\"arrow\">\n                              <use xlink:href=\"/recruit/img/svg/sprite-symbol.svg#icon-arrow\"></use>\n                            </svg>\n                          </a>\n                        </li>\n                        <li class=\"item\">\n                          <a href=\"/recruit/welfare#rest\">\n                            <span class=\"txt\">保養所</span>\n                            <svg class=\"arrow\">\n                              <use xlink:href=\"/recruit/img/svg/sprite-symbol.svg#icon-arrow\"></use>\n                            </svg>\n                          </a>\n                        </li>\n                      </ul>\n                      <ul class=\"link-list-wrap\">\n                        <li class=\"item\">\n                          <a href=\"/recruit/welfare#stock\">\n                            <span class=\"txt\">持ち株会</span>\n                            <svg class=\"arrow\">\n                              <use xlink:href=\"/recruit/img/svg/sprite-symbol.svg#icon-arrow\"></use>\n                            </svg>\n                          </a>\n                        </li>\n                        <li class=\"item\">\n                          <a href=\"/recruit/welfare#care\">\n                            <span class=\"txt\">育児・介護に関わる<span class=\"ib\">制度</span></span>\n                            <svg class=\"arrow\">\n                              <use xlink:href=\"/recruit/img/svg/sprite-symbol.svg#icon-arrow\"></use>\n                            </svg>\n                          </a>\n                        </li>\n                        <li class=\"item\">\n                          <a href=\"/recruit/welfare#relo\">\n                            <span class=\"txt\">リロクラブ</span>\n                            <svg class=\"arrow\">\n                              <use xlink:href=\"/recruit/img/svg/sprite-symbol.svg#icon-arrow\"></use>\n                            </svg>\n                          </a>\n                        </li>\n                      </ul>\n                    </div>\n                  </div>\n                </div>\n              </div>\n              <!-- Top, Faq, Corporate -->\n              <div class=\"wrap no-flex max-1399\">\n                <a href=\"/recruit/\" class=\"c-title01 c-title01__left pc\">\n                  <span class=\"en\">Top</span>\n                  <span class=\"ja\">採用トップ</span>\n                  <svg class=\"arrow sp\">\n                    <use xlink:href=\"/recruit/img/svg/sprite-symbol.svg#icon-arrow\"></use>\n                  </svg>\n                </a>\n                <a href=\"/recruit/faq/\" class=\"c-title01 c-title01__left\">\n                  <span class=\"en\">Faq</span>\n                  <span class=\"ja\">よくあるご質問</span>\n                  <svg class=\"arrow sp\">\n                    <use xlink:href=\"/recruit/img/svg/sprite-symbol.svg#icon-arrow\"></use>\n                  </svg>\n                </a>\n                <a href=\"/\" class=\"link link__blank\">-コーポレートサイトトップへ</a>\n              </div>\n            </nav>\n          </div>\n\n          <div class=\"pick-wrap\">\n            <a href=\"/recruit/application/\" class=\"btn btn__type01\">\n              <div class=\"c-title01 c-title01__left c-title01__revers\">\n                <span class=\"en\">Application</span>\n                <span class=\"ja\">募集要項</span>\n              </div>\n              <div class=\"c-btn_arrow02\">\n                <svg class=\"arrow\">\n                  <use xlink:href=\"/recruit/img/svg/sprite-symbol.svg#icon-arrow\"></use>\n                </svg>\n              </div>\n            </a>\n            <a href=\"/recruit/entry/\" class=\"btn btn__type01\">\n              <div class=\"c-title01 c-title01__left c-title01__revers\">\n                <span class=\"en\">Entry</span>\n                <span class=\"ja\">エントリー</span>\n              </div>\n              <div class=\"c-btn_arrow02\">\n                <svg class=\"arrow\">\n                  <use xlink:href=\"/recruit/img/svg/sprite-symbol.svg#icon-arrow\"></use>\n                </svg>\n              </div>\n            </a>\n            <a href=\"/recruit/movie/\" class=\"btn btn__type02 movie\">\n              <div class=\"c-title01 c-title01__revers\">\n                <span class=\"en\">Special Movie</span>\n                <span class=\"ja\">スペシャルムービー</span>\n              </div>\n            </a>\n            <a href=\"/recruit/product/\" class=\"btn btn__type02 scene\">\n              <div class=\"c-title01 c-title01__revers\">\n                <span class=\"en\">Scene of Use</span>\n                <span class=\"ja\">暮らしの中の大鐵</span>\n              </div>\n            </a>\n          </div>\n        </div>\n      </header>\n<main class=\"page_career\">\n  <section class=\"c-underMv\">\n    <div class=\"inner\">\n      <div class=\"txt-wrap\">\n        <ul class=\"c-breadcrumbs\">\n          <li class=\"breadcrumbs-item\"><a href=\"/\">TOP</a></li>\n          <li class=\"breadcrumbs-item\"><a href=\"/recruit/\">採用トップ</a></li>\n          <li class=\"breadcrumbs-item\">職種紹介/キャリア事例</li>\n        </ul>\n        <h1 class=\"c-title01 c-title01__left\">\n          <span class=\"en\">Job & Career</span>\n          <span class=\"ja\">職種紹介/キャリア事例</span>\n        </h1>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"job\">\n    <div class=\"inner_under\">\n      <h2 class=\"c-title02 c-title02__small\">\n        <span class=\"en\">About Job</span>\n        <span class=\"ja\">職種紹介</span>\n      </h2>\n      <ul class=\"job__wrapper\">\n        <!-- 製鋼課 -->\n        <li class=\"job__item js-modal-open\" data-target=\"job01\">\n          <div class=\"thumb\"><img src=\"/recruit/img/career/img-job01.jpg\" alt=\"\"></div>\n          <div class=\"job__txt\">\n            <h3 class=\"title\">製鋼課</h3>\n            <p class=\"txt\">原材料となる鉄スクラップを電気炉で溶解し、素材となる鋼片を製造します。</p>\n          </div>\n        </li>\n        <!-- 圧延課 -->\n        <li class=\"job__item js-modal-open\" data-target=\"job02\">\n          <div class=\"thumb\"><img src=\"/recruit/img/career/img-job02.jpg\" alt=\"\"></div>\n          <div class=\"job__txt\">\n            <h3 class=\"title\">圧延課</h3>\n            <p class=\"txt\">鋼片を回転するロールで引き延ばし、さまざまな形の最終製品を製造します。</p>\n          </div>\n        </li>\n        <!-- 整備課 -->\n        <li class=\"job__item js-modal-open\" data-target=\"job03\">\n          <div class=\"thumb\"><img src=\"/recruit/img/career/img-job03.jpg\" alt=\"\"></div>\n          <div class=\"job__txt\">\n            <h3 class=\"title\">整備課</h3>\n            <p class=\"txt\">工場内の電気設備の保守・管理、設備の更新、設計・施工管理等を行っています。</p>\n          </div>\n        </li>\n        <!-- 商品企画グループ -->\n        <li class=\"job__item js-modal-open\" data-target=\"job04\">\n          <div class=\"thumb\"><img src=\"/recruit/img/career/img-job04.jpg\" alt=\"\"></div>\n          <div class=\"job__txt\">\n            <h3 class=\"title\">商品企画グループ</h3>\n            <p class=\"txt\">工程管理や品質改善を通じた製品品質の維持・向上を行っています。</p>\n          </div>\n        </li>\n        <!-- 生産管理グループ -->\n        <li class=\"job__item js-modal-open\" data-target=\"job05\">\n          <div class=\"thumb\"><img src=\"/recruit/img/career/img-job05.jpg\" alt=\"\"></div>\n          <div class=\"job__txt\">\n            <h3 class=\"title\">生産管理グループ</h3>\n            <p class=\"txt\">生産計画を立てたり工程管理をして営業部門や生産部門と調整を行います。</p>\n          </div>\n        </li>\n        <!-- 情報システムグループ -->\n        <li class=\"job__item js-modal-open\" data-target=\"job06\">\n          <div class=\"thumb\"><img src=\"/recruit/img/career/img-job06.jpg\" alt=\"\"></div>\n          <div class=\"job__txt\">\n            <h3 class=\"title\">情報システムグループ</h3>\n            <p class=\"txt\">工場や事務所で運用するサーバーやシステムの保守・管理等を行っています。</p>\n          </div>\n        </li>\n        <!-- 営業グループ -->\n        <li class=\"job__item js-modal-open\" data-target=\"job07\">\n          <div class=\"thumb\"><img src=\"/recruit/img/career/img-job07.jpg\" alt=\"\"></div>\n          <div class=\"job__txt\">\n            <h3 class=\"title\">営業グループ</h3>\n            <p class=\"txt\">製品の受注から納品まで、常にお客様に寄り添いながら営業活動を行います。</p>\n          </div>\n        </li>\n        <!-- 海外営業グループ -->\n        <li class=\"job__item js-modal-open\" data-target=\"job08\">\n          <div class=\"thumb\"><img src=\"/recruit/img/career/img-job08.jpg\" alt=\"\"></div>\n          <div class=\"job__txt\">\n            <h3 class=\"title\">海外営業グループ</h3>\n            <p class=\"txt\">製品の輸出からグループ会社含めた大阪製鐵グループの海外戦略を担っています。</p>\n          </div>\n        </li>\n        <!-- 財務グループ -->\n        <li class=\"job__item js-modal-open\" data-target=\"job09\">\n          <div class=\"thumb\"><img src=\"/recruit/img/career/img-job09.jpg\" alt=\"\"></div>\n          <div class=\"job__txt\">\n            <h3 class=\"title\">財務グループ</h3>\n            <p class=\"txt\">工場含む会社全体の予算編成や損益管理、決算対応、資金計画等を担っています。</p>\n          </div>\n        </li>\n        <!-- 人事労働グループ -->\n        <li class=\"job__item js-modal-open\" data-target=\"job10\">\n          <div class=\"thumb\"><img src=\"/recruit/img/career/img-job10.jpg\" alt=\"\"></div>\n          <div class=\"job__txt\">\n            <h3 class=\"title\">人事労働グループ</h3>\n            <p class=\"txt\">労務管理から採用・研修まで、当社で働くヒトに関わる仕事に携わっています。</p>\n          </div>\n        </li>\n        <!-- 秘書・総務グループ -->\n        <li class=\"job__item js-modal-open\" data-target=\"job11\">\n          <div class=\"thumb\"><img src=\"/recruit/img/career/img-job11.jpg\" alt=\"\"></div>\n          <div class=\"job__txt\">\n            <h3 class=\"title\">秘書・総務グループ</h3>\n            <p class=\"txt\">会社運営のサポートから、社外に向けた広報活動まで社内外の顔として活動しています。</p>\n          </div>\n        </li>\n      </ul>\n    </div>\n  </section>\n\n  <!-- 製鋼課 -->\n<div class=\"modal\" id=\"job01\">\n  <div class=\"modal__overlay\"></div>\n  <div class=\"modal__contents\">\n    <h3 class=\"title\">製鋼課</h3>\n    <h4 class=\"sub-title\">常に向上心を持ち、循環型社会へ貢献する！</h4>\n    <p class=\"txt\">ビルの解体物や廃棄された自動車等の鉄スクラップを電気炉と呼ばれる巨大な鍋で溶解し、成分調整を経た溶鋼を鋳型に連続して流し込むことで素材となる鋼片を製造しています。我々スタッフは、製造工程における安全管理、品質改善、コスト削減などに取り組んでいます。製造ラインの上工程として、圧延と呼ばれる下工程に鋼片を安定供給できるよう、現場作業者と一丸となって日々精進しています！</p>\n    <div class=\"wrapper\">\n      <div class=\"wrap contents\">\n        <h5 class=\"wrap__title\">\n          <span class=\"icon\"><img src=\"/recruit/img/career/icon-content.svg\" alt=\"\"></span>\n          主な業務内容\n        </h5>\n        <ul>\n          <li>安全、環境、防災活動</li>\n          <li>品質管理、改善</li>\n          <li>操業(コスト)管理、改善</li>\n        </ul>\n      </div>\n      <div class=\"wrap interview\">\n        <h5 class=\"wrap__title\">\n          <span class=\"icon\"><img src=\"/recruit/img/career/icon-interview.svg\" alt=\"\"></span>\n          先輩インタビュー\n        </h5>\n        <div class=\"wrap__interview\">\n          <a href=\"/recruit/interview/detail06.php\">\n            <img src=\"/recruit/img/