->\r\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-MDCL22\"\r\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\r\n<!-- End Google Tag Manager (noscript) -->  \n  <header id=\"header\" class=\"header\">\n    <div id=\"gnav_btn\" class=\"flex flex-a-ctr\">\n      <div class=\"gnav_btn--lines\">\n        <span></span><span></span><span></span>\n      </div>\n      <span>\n        <img src=\"/recruitment/wp/wp-content/themes/original_theme/images/common/gnav_btn.png\" height=\"8\" width=\"32\" alt=\"MENU\" class=\"black\">\n        <img src=\"/recruitment/wp/wp-content/themes/original_theme/images/common/gnav_btn_wh.png\" height=\"8\" width=\"32\" alt=\"MENU\" class=\"white\">\n      </span>\n    </div>\n    <nav class=\"gnav\">\n      <ul class=\"gnav--list flex flex-col2 flex-sp-block\">\n        <li class=\"gnav--parent home sp-none\">\n          <a href=\"/recruitment/\" class=\"font-jp-min\">トップページ</a>\n        </li>\n        <li class=\"gnav--parent\">\n          <strong class=\"font-jp-min parent\">市川工務店を知る</strong>\n          <ul class=\"gnav--child\">\n            <li><a href=\"/recruitment/company/\">会社案内</a></li>\n            <li><a href=\"/recruitment/welfare/\">働き方</a></li>\n            <li><a href=\"/recruitment/welfare/#welfare_training\">研修制度</a></li>\n          </ul>\n        </li>\n        <li class=\"gnav--parent\">\n          <strong class=\"font-jp-min parent\">市川工務店の仕事</strong>\n          <ul class=\"gnav--child\">\n            <li><a href=\"/recruitment/business/#public_section\">土木事業</a></li>\n            <li><a href=\"/recruitment/business/#architecture_section\">建築事業</a></li>\n          </ul>\n        </li>\n        <li class=\"gnav--parent\">\n          <strong class=\"font-jp-min parent\">市川工務店の社員</strong>\n          <ul class=\"gnav--child\">\n            <li><a href=\"/recruitment/interview/\">先輩社員インタビュー</a></li>\n            <li><a href=\"/recruitment/crosstalk/\">クロストーク</a></li>\n          </ul>\n        </li>\n        <li class=\"gnav--parent\">\n          <strong class=\"font-jp-min parent\">採用情報について</strong>\n          <ul class=\"gnav--child\">\n            <li><a href=\"/recruitment/requirements/graduate/\">募集要項</a></li>\n            <li><a href=\"/recruitment/faq/\">よくある質問</a></li>\n          </ul>\n        </li>\n        <li class=\"pc-none gnav--corp\"><a href=\"https://www.ic-group.co.jp/\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"new_tab\">株式会社市川工務店</a></li>\n      </ul>\n      <ul class=\"gnav--list gnav--list-wide entry--link flex flex-sp-block\">\n        <li class=\"gnav--parent\">\n          <a href=\"https://job.mynavi.jp/27/pc/search/corp73236/outline.html\" target=\"_blank\" rel=\"noopener noreferrer\">\n            <h3 class=\"ttl\">\n              <strong class=\"font-jp-min color-wh\">新卒採用<span>（27年度卒業）</span></strong>\n              <small class=\"font-en color-gre\">Entry For Graduate Recruitment</small>\n            </h3>\n            <i><img src=\"/recruitment/wp/wp-content/themes/original_theme/images/common/mynav.png\" height=\"59\" width=\"71\" alt=\"新卒応募 マイナビ\"></i>\n          </a>\n        </li>\n        <li class=\"gnav--parent\">\n          <a href=\"https://job.mynavi.jp/28/pc/search/corp73236/outline.html\" target=\"_blank\" rel=\"noopener noreferrer\">\n            <h3 class=\"ttl\">\n              <strong class=\"font-jp-min color-wh\">新卒採用<span>（28年度卒業）</span></strong>\n              <small class=\"font-en color-gre\">Entry For Graduate Recruitment</small>\n            </h3>\n            <i><img src=\"/recruitment/wp/wp-content/themes/original_theme/images/common/mynav.png\" height=\"59\" width=\"71\" alt=\"新卒応募 マイナビ\"></i>\n          </a>\n        </li>\n        <li class=\"gnav--parent\">\n          <a href=\"/recruitment/requirements/mincareer/\">\n            <h3 class=\"ttl\">\n              <strong class=\"font-jp-min color-wh\">中途採用</strong>\n              <small class=\"font-en color-gre\">Entry For Career Recruitment</small>\n            </h3>\n            <i><img src=\"/recruitment/wp/wp-content/themes/original_theme/images/common/mail.png\" height=\"48\" width=\"64\" alt=\"中途応募\"></i>\n          </a>\n        </li>\n      </ul>\n    </nav>\n    <hr>\n    <h1 class=\"header--logo\">\n      <a href=\"/recruitment/\">\n        <small>株式会社市川工務店 リクルートサイト</small>\n        <img src=\"/recruitment/wp/wp-content/themes/original_theme/images/common/head_logo.png\" alt=\"福利厚生｜岐阜県で女性技術者として活躍するなら㈱市川工務店\" width=\"140\" height=\"44\">\n      </a>\n    </h1>\n    <hr>\n    <div class=\"entry_btn sp-none\">\n      <a href=\"#entry\" class=\"font-jp-min smooth\"><span class=\"font-en\">Entry</span>応募する</a>\n    </div>\n  </header>\n\n  \n    <!-- start page_ttl -->\n    <div class=\"page_ttl\"  id=\"page_ttl\">\n      <h2 class=\"inner\">\n                <span class=\"page_ttl-jp\">働き方</span>\n                <span class=\"page_ttl-en\">Work Style</span>\n      </h2>\n    </div>\n    <!-- end page_ttl -->\n\n  \r\n<main class=\"welfare\" id=\"welfare\">\n\n\n  <section class=\"section_pdg page_intro bg-pt1 welfare_point\" id=\"welfare_point\">\n    <div class=\"inner inner-lg\" id=\"page_top\">\n      <p class=\"txt-ctr mgn-btm80\">市川工務店ではそれぞれの社員にあった働き方を提供するために、多彩な制度を用意しています。<br>働く社員のことを一番に考えて整備した、社員ファーストな取り組みや制度を紹介します。</p>\n      <div class=\"flex flex-col2 flex-sp-block flex-reverse mgn-btm56\">\n        <div class=\"txt\">\n          <h2 class=\"heading-2 mgn-btm24\">仕事の時間と同じくらい、<br class=\"sp-none\">休みも大事</h2>\n          <p class=\"mgn-btm24\">市川工務店は、完全週休2日制です。その他、有給休暇とは別に配偶者出産休暇やバースデー休暇など、プライベートを充実させる休暇制度があります。子育てを応援する手当のほか、家族で余暇を楽しむための福利厚生も充実しています。<br>また、資格取得を目指す方なら、無理することなく勉強時間を確保することができます。</p>\n          <ul class=\"list\">\n            <li>完全週休2日制（土・日・祝休み）</li>\n            <li>配偶者出産休暇</li>\n            <li>バースデー休暇</li>\n            <li>毎月の子ども手当＋生計手当（一時金）出産時、幼稚園・保育園入園時、小中学校入学時に50,000円、高校入学100,000円を支給</li>\n            <li>福利厚生サービス（レジャー施設・飲食店などで割引）加入</li>\n          </ul>\n        </div>\n        <div class=\"img\">\n          <img src=\"/recruitment/wp/wp-content/themes/original_theme/images/welfare/welfare_img2.jpg\" alt=\"仕事の時間と同じくらい、休みも大事\" width=\"620\" height=\"460\">\n        </div>\n      </div>\n\n      <div class=\"flex flex-col2 flex-sp-block mgn-btm56\">\n        <div class=\"txt\">\n          <h2 class=\"heading-2 mgn-btm24\">女性が働きやすい環境を<br class=\"sp-none\">会社全体で応援</h2>\n          <p class=\"mgn-btm24\">男性従業員が約300人であるのに対して、女性従業員は40名程度。<br>\n            少数派だから我慢しなければならない、という風潮は市川工務店にはありません。<br>\n            現場での女性用更衣室の確保や専用トイレの設置、女性用サイズの作業服の導入など、女性技術者の会「けんけんぱ」の声は、会社を動かすほどの影響力があります。</p>\n          <ul class=\"list\">\n            <li>女性目線の改善提案を目指す、女性技術者の会「けんけんぱ」</li>\n            <li>10年間、出産・育児理由の退職者ゼロ</li>\n            <li>短時間勤務（子の小学校4年生終了まで6時間までの短時間勤務が可能）</li>\n          </ul>\n        </div>\n        <div class=\"img\">\n          <img src=\"/recruitment/wp/wp-content/themes/original_theme/images/welfare/welfare_img1.jpg\" alt=\"女性が働きやすい環境を会社全体で応援\" width=\"620\" height=\"460\">\n        </div>\n      </div>\n\n      <div class=\"flex flex-col2 flex-sp-block flex-reverse mgn-btm56\">\n        <div class=\"txt\">\n          <h2 class=\"heading-2 mgn-btm24\">資格取得のノウハウと<br class=\"sp-none\">取得後の手当が充実</h2>\n          <p class=\"mgn-btm24\">社員数360名に対し、1級土木施工管理技士は124名、さらに1級建築施工管理技士は77名在籍。2人に1人は何らかの資格を取得している計算です。<br>「資格取得は当たり前」という社内の雰囲気もあって、自然と勉強に取り組める環境が息づいています。合格によって毎月支給される資格手当で、さらにやる気を後押しします。</p>\n          <ul class=\"list\">\n            <li>主要資格取得で、毎月資格手当を支給（27資格が対象）</li>\n            <li>資格取得のための勉強会の開催</li>\n            <li>土木や建築学科卒以外の社員による、資格取得実績あり</li>\n            <li>難関資格取得者には一時金として、30万円を支給</li>\n          </ul>\n        </div>\n        <div class=\"img\">\n          <img src=\"/recruitment/wp/wp-content/themes/original_theme/images/welfare/welfare_img3.jpg\" alt=\"資格取得のノウハウと取得後の手当が充実\" width=\"620\" height=\"460\">\n        </div>\n      </div>\n\n      <div class=\"flex flex-col2 flex-sp-block mgn-btm64\">\n        <div class=\"txt\">\n          <h2 class=\"heading-2 mgn-btm24\">キャリア形成をサポートする、<br class=\"sp-none\">多彩な教育研修</h2>\n          <p class=\"mgn-btm24\">社員一人ひとりが仕事を通じて成長し長期的に活躍していけるように、新入社員研修だけでなく年代・専門性・職種ごとに細分化し数多くの研修を行っています。また資格取得を支援する研修も実施し、キャリア形成までしっかりとサポートします。</p>\n          <ul class=\"list\">\n            <li>新入社員研修から管理職研修まで、ベストなタイミングで必要な研修を開催</li>\n            <li>約1ヶ月に渡り、ビジネスの基礎から学べる新入社員研修を開催</li>\n            <li>資格取得に向けた公的資格受験準備講習で合格のノウハウを共有</li>\n          </ul>\n        </div>\n        <div class=\"img\">\n          <img src=\"/recruitment/wp/wp-content/themes/original_theme/images/welfare/welfare_img4.jpg\" alt=\"キャリア形成をサポートする、多彩な教育研修\" width=\"620\" height=\"460\">\n        </div>\n      </div>\n\n      <h3 class=\"heading-2 txt-ctr mgn-btm32\">その他の制度</h3>\n      <table class=\"welfare_point--other table_line\">\n        <tr>\n          <th>休日・休暇制度</th>\n          <td>\n            <ul class=\"list\">\n              <li>完全週休2日制（土曜日・日曜日・祝祭日）</li>\n              <li>GW</li>\n              <li>夏季休暇</li>\n              <li>年末年始</li>\n              <li>有給休暇（入社時10日付与）</li>\n              <li>バースデー休暇</li>\n              <li>配偶者出産休暇</li>\n              <li>特別休暇</li>\n              <li>介護休暇（対象家族1人につき通算93日）</li>\n            </ul>\n          </td>\n        </tr>\n        <tr>\n          <th>育児支援制度</th>\n          <td>\n            <ul class=\"list\">\n              <li>育児休暇（子が2歳になるまで取得可能）</li>\n              <li>短時間勤務（子の小学校4年生終了まで6時間までの短時間勤務が可能）</li>\n              <li>子ども手当（子1人につき8,000円）</li>\n              <li>生計手当（一時金）出⽣時、幼稚園・保育園入園時、小中学校入学時に50,000円、高校入学100,000円を支給</li>\n            </ul>\n          </td>\n        </tr>\n        <tr>\n          <th>資格手当</th>\n          <td>\n            <ul class=\"list\">\n              <li>資格手当公的資格保有者に支給（一級⼟⽊施工管理技⼠・一級建築施工管理技士。その他、支給対象資格は、27資格）</li>\n              <li>資格取得奨励⾦難関資格取得者に一時金として30万円支給</li>\n            </ul>\n          </td>\n        </tr>\n        <tr>\n          <th>その他</th>\n          <td>\n            <ul class=\"list\">\n              <li>制度<br>福利厚生倶楽部・慶弔見舞金・社員親睦会・表彰（業績貢献、永年勤続）・定期健康診断・人間ドック（40、50、60歳時）・配偶者健康診断費用助成・インフルエンザ予防接種費用全額補助・健康相談・特定保健指導・健康保険・厚生年金・雇用保険・労災保険・退職金・確定拠出年金・財形貯蓄　など</li>\n              <li>施設<br>独身寮、保有メンバーズホテル（ホテルレシーア南知多、ホテルアソシア高山リゾート）など</li>\n            </ul>\n          </td>\n        </tr>\n      </table>\n\n    </div>\n  </section>\n\n  <section class=\"section_pdg welfare_training\" id=\"welfare_training\">\n    <div class=\"inner\">\n      <h2 class=\"section_ttl mgn-btm40\">\n        <strong>研修制度</strong>\n        <small class=\"color-gre\">Training System</small>\n      </h2>\n      <h3 class=\"heading-2 mgn-btm72\">階層別研修</h3>\n      <div class=\"welfare_training--step mgn-btm80\">\n        <table class=\"welfare_training--graf\">\n          <tr>\n            <td class=\"step1\">\n              <div class=\"step_ojt\">\n                <div class=\"step_content flex flex-c-wrap\">\n                  <h4>新入社員研修<br><small>期間：約1ヶ月（前半：全職種合同、後半：職種ごと）</small></h4>\n                  <div class=\"txt\">\n                    <h5>目的</h5>\n                    <ul class=\"list\">\n                      <li>学生から企業人への意識の切り替え</li>\n                      <li>新入社員としての基礎知識の習得</li>\n                      <li>安全に対する基礎知識の習得</li>\n                      <li>市川工務店およびグループ会社の理解</li>\n                    </ul>\n                  </div>\n                  <div class=\"txt\">\n                    <h5>内容</h5>\n                    <ul class=\"list\">\n                      <li>規則・業務などの説明</li>\n                      <li>ビジネスマナー講習</li>\n                      <li>交通安全講習</li>\n                      <li>コンプライアンス講習</li>\n                      <li>安全衛生講習（座学・現場実地）</li>\n                      <li>工場見学</li>\n                      <li>パソコン講習</li>\n                      <li>ビジネス基礎研修など</li>\n                    </ul>\n                  </div>\n                </div>\n              </div>\n            </td>\n            <td class=\"step2\">\n              <div class=\"step_ojt\">\n                <div class=\"step_content\">\n                  <h4>新入社員フォローアップ研修</h4>\n                  <div class=\"txt\">\n                    <h5>目的</h5>\n                    <p>新入社員が抱える悩みに対して、講義やグループワークを通して解決方法を考える。入社半年を振り返ることにより、自身の現状を把握して、今後の行動目標を設定。以降の成長へとつなげる。</p>\n                  </div>\n                </div>\n              </div>\n            </td>\n            <td class=\"step3\">\n              <div class=\"step_ojt\">\n                <div class=\"step_content\">\n                  <h4>若手社員研修</h4>\n                  <div class=\"txt\">\n                    <h5>目的</h5>\n                    <p>求められる役割の変化と環境の変化を受け入れ、自分自身の考え方や仕事の進め方を見つめ直す。社内外におけるコミュニケーションと調整・折衝スキルのレベルアップが目的。</p>\n                  </div>\n                </div>\n              </div>\n            </td>\n            <td class=\"step4\">\n              <div class=\"step_ojt\">\n                <div class=\"step_content\">\n                  <h4>中堅社員研修<br><small>※職種別に実施、下記は施工管理</small></h4>\n                  <div class=\"txt\">\n                    <h5>目的</h5>\n                    <p>現場代理人に必要な工事成績向上力と現場コミュニケーション能力を身につけることで、工事をスムーズに運営する能力を高める。</p>\n                  </div>\n                </div>\n              </div>\n            </td>\n            <td class=\"step5\">\n              <div class=\"step_ojt\">\n                <div class=\"step_content\">\n                  <h4>管理職研修</h4>\n                  <div class=\"txt\">\n                    <h5>目的</h5>\n                    <p>管理職として求められる能力の向上。</p>\n                  </div>\n                </div>\n              </div>\n            </td>\n          </tr>\n          <tr>\n            <th>新入社員<br>研修</th>\n            <th>新入社員<br>フォローアップ研修</th>\n            <th>若手社員<br>研修</th>\n            <th>中堅社員<br>研修</th>\n            <th>管理職<br>研修</th>\n          </tr>\n        </table>\n      </div>\n      <div class=\"welfare_training--other flex flex-col2 flex-sp-block\">\n        <div>\n          <h3 class=\"heading-3 mgn-btm24\">資格取得研修</h3>\n          <ul class=\"list mgn-btm56\">\n            <li>土木施工管理技士</li>\n            <li>建築施工管理技士</li>\n            <li>建設業経理士</li>\n          </ul>\n        </div>\n        <div>\n          <h3 class=\"heading-3 mgn-btm24\">その他</h3>\n          <ul class=\"list\">\n            <li>職種別教育・研修</li>\n            <li>安全研修</li>\n            <li>ISO研修</li>\n            <li>OJT</li>\n          </ul>\n        </div>\n      </div>\n    </div>\n  </section>\n\n</main>\r\n<!-- start entry -->\n<aside id=\"entry\" class=\"section_pdg bg-pt1\">\n  <div class=\"inner inner-lg waypoint fade\">\n          <h2 class=\"heading-1 txt-ctr mgn-btm64\">私たちと、<br class=\"pc-none\">ともに働こう。</h2>\n      <ul class=\"entry--link flex flex-sp-block mgn-btm64\">\n        <li>\n          <a href=\"https://job.mynavi.jp/27/pc/search/corp73236/outline.html\" target=\"_blank\" rel=\"noopener noreferrer\">\n            <h3 class=\"ttl\">\n              <strong class=\"font-jp-min color-wh\">新卒採用<span>（27年度卒業）</span></strong>\n              <small class=\"font-en color-gre\">Entry For Graduate Recruitment</small>\n            </h3>\n            <i><img src=\"/recruitment/wp/wp-content/themes/original_theme/images/common/mynav.png\" height=\"59\" width=\"71\" alt=\"新卒応募 マイナビ\"></i>\n          </a>\n        </li>\n        <li>\n          <a href=\"https://job.mynavi.jp/28/pc/search/corp73236/outline.html\" target=\"_blank\" rel=\"noopener noreferrer\">\n            <h3 class=\"ttl\">\n              <strong class=\"font-jp-min color-wh\">新卒採用<span>（28年度卒業）</span></strong>\n              <small class=\"font-en color-gre\">Entry For Graduate Recruitment</small>\n            </h3>\n            <i><img src=\"/recruitment/wp/wp-content/themes/original_theme/images/common/mynav.png\" height=\"59\" width=\"71\" alt=\"新卒応募 マイナビ\"></i>\n          </a>\n        </li>\n        <li>\n          <a href=\"/recruitment/requirements/mincareer/\">\n            <h3 class=\"ttl\">\n              <strong class=\"font-jp-min color-wh\">中途採用</strong>\n              <small class=\"font-en color-gre\">Entry For Career Recruitment</small>\n            </h3>\n            <i><img src=\"/recruitment/wp/wp-content/themes/original_theme/images/common/mail.png\" height=\"48\" width=\"64\" alt=\"中途応募\"></i>\n          </a>\n        </li>\n      </ul>\n      <h4 class=\"heading-1 txt-ctr sp-none\">みなさんがもたらす、新しい風を<br>市川工務店は、待っています。</h4>\n    \n    \n  </div>\n</aside>\n<!-- end entry -->\n\n<div id=\"pagetop\">\n  <a href=\"#top\" class=\"smooth font-en\">Page Top</a>\n</div>\n\n<footer class=\"footer\">\n  <ul class=\"footer--gallery flex flex-j-between\">\n    <li class=\"gallery1\"></li>\n    <li class=\"gallery2\"></li>\n    <li class=\"gallery3\"></li>\n  </ul>\n  <hr class=\"section_hr\">\n  <hr class=\"section_hr\">\n  <hr class=\"section_hr\">\n  <nav class=\"footer--content inner inner-sm\">\n    <h2 class=\"logo txt-ctr mgn-btm40\">\n      <a href=\"/recruitment/\">\n        <img src=\"/recruitment/wp/wp-content/themes/original_theme/images/common/footer_logo.png\" height=\"49\" width=\"166\" alt=\"株式会社市川工務店\">\n      </a>\n    </h2>\n    <div class=\"nav\">\n      <ul class=\"sp-none-flex flex-j-ctr\">\n        <li class=\"nav--parent\">\n          <strong class=\"font-jp-min parent\">市川工務店を知る</strong>\n          <ul class=\"nav--child\">\n            <li><a href=\"/recruitment/company/\">会社案内</a></li>\n            <li><a href=\"/recruitment/welfare/\">働き方</a></li>\n            <li><a href=\"/recruitment/welfare/#welfare_training\">研修制度</a></li>\n          </ul>\n        </li>\n        <li class=\"nav--parent\">\n          <strong class=\"font-jp-min parent\">市川工務店の仕事</strong>\n          <ul class=\"nav--child\">\n            <li><a href=\"/recruitment/business/#public_section\">土木事業</a></li>\n            <li><a href=\"/recruitment/business/#architecture_section\">建築事業</a></li>\n          </ul>\n        </li>\n        <li class=\"nav--parent\">\n          <strong class=\"font-jp-min parent\">市川工務店の社員</strong>\n          <ul class=\"nav--child\">\n            <li><a href=\"/recruitment/interview/\">先輩社員インタビュー</a></li>\n            <li><a href=\"/recruitment/crosstalk/\">クロストーク</a></li>\n          </ul>\n        </li>\n        <li class=\"nav--parent\">\n          <strong class=\"font-jp-min parent\">採用情報について</strong>\n          <ul class=\"nav--child\">\n            <li><a href=\"/recruitment/requirements/graduate/\">募集要項</a></li>\n            <li><a href=\"/recruitment/faq/\">よくある質問</a></li>\n            <li class=\"corplink\"><a href=\"https://www.ic-group.co.jp/\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"new_tab\">株式会社市川工務店</a></li>\n          </ul>\n        </li>\n      </ul>\n    </div>\n    <p class=\"footer--copyright txt-ctr\"><small>&copy;2019 ICHIKAWA　KOUMUTEN CO.LTD</small></p>\n  </nav>\n</footer>\n\n\r\n<script src=\"//ajax.googleapis.com/ajax/libs/jquery/3.3.1/jquery.min.js\"></script>\r\n<script src=\"/recruitment/wp/wp-content/themes/original_theme/js/jquery.waypoints.min.js\"></script>\r\n\r\n\r\n\r\n<script>\r\n    $(function(){\r\n\r\n        const ua = navigator.userAgent;\r\n    const if_pc = ua.indexOf('iPhone') < 0 && ua.indexOf('Android') < 0;\r\n    const if_sp = ua.indexOf('iPhone') > 0 || ua.indexOf('Android') > 0;\r\n\r\n    /* telタグ例外処理\r\n    ********************************************** */\r\n      if(if_pc){\r\n        $('a[href ^= \"tel:\"]').each(function(){\r\n           $(this).css({'pointerEvents':'none','display':'inline-block'}).removeAttr('onclick');\r\n        });\r\n      }\r\n\r\n    /* スムーススクロール\r\n    ********************************************** */\r\n      if(!window.matchMedia(\"(max-width:768px)\").matches){\r\n        var margin = 20;\r\n      } else {\r\n        var margin = 80;\r\n      }\r\n      $('a.smooth[href^=\"#\"]').on('click',function(){\r\n        var speed = 400;\r\n        var href= $(this).attr('href');\r\n        var target = $(href == '#' || href == '' ? 'html' : href);\r\n        var position = target.offset().top - margin;\r\n        $('body,html').animate({scrollTop:position}, speed, 'swing');\r\n        return false;\r\n      });\r\n\r\n    /* gnav_btnクリックでheaderにactive付与\r\n    ********************************************** */\r\n      $('#gnav_btn').on('click',function(){\r\n        $(this).closest('header').toggleClass('active');\r\n      });\r\n      $('.gnav a').on('click',function(){\r\n        $('.header').removeClass('active');\r\n      });\r\n\r\n    /* スクロールでヘッダーにfixed付与\r\n    ********************************************** */\r\n      var head = $('#header');\r\n      $(window).on('scroll', function(){\r\n        if ($(this).scrollTop() > 80) {\r\n          head.addClass('fixed');\r\n        } else {\r\n          head.removeClass('fixed');\r\n        }\r\n      });\r\n\r\n    /* ナビゲーションにcurrentつける\r\n    ********************************************** */\r\n      var activeurl = location.pathname.split('/')[2];\r\n      var nav = $('.gnav').find('a');\r\n      nav.each(function(){\r\n        if( $(this).attr('href').split('/')[2] == activeurl ) {\r\n          $(this).addClass('current');\r\n        };\r\n      });\r\n\r\n    /* waypoint\r\n    ********************************************** */\r\n      var position = '80%';\r\n      $('.waypoint').waypoint(function(direction){\r\n        var activePoint = $(this.element);\r\n        if (direction === 'down') { //scroll down\r\n          activePoint.addClass('active');\r\n        }\r\n      },{offset : position});\r\n\r\n\r\n    \r\n    \r\n      if(!window.matchMedia(\"(max-width:768px)\").matches){\r\n        /* ナビゲーション色\r\n        ********************************************** */\r\n        function changeColor() {\r\n          var timing = 40; //　変化するタイミングを微調整する\r\n\r\n          var scrollY = window.pageYOffset;\r\n          var body = document.body;\r\n\r\n          var trigger1 = document.getElementById('page_ttl');// 白\r\n          var trigger2 = document.getElementById('page_top');// 黒\r\n\r\n          var trigger1Y = trigger1.getBoundingClientRect().top;\r\n          var trigger2Y = trigger2.getBoundingClientRect().top;\r\n\r\n          if(trigger2Y - timing > 0 && 0 >= trigger1Y - timing) {\r\n            body.classList.add('change_white');\r\n          } else {\r\n            body.classList.remove('change_white');\r\n          }\r\n        }\r\n        window.addEventListener('scroll', changeColor);\r\n      }\r\n\r\n    \r\n\r\n    \r\n    \r\n\r\n    \r\n\r\n    \r\n    \r\n  });\r\n\r\n  \r\n    \r\n</script>\r\n\r\n\r\n\n\n<!-- facebook -->\n<div id=\"fb-root\"></div>\n<script>\n  (function(d, s, id) {\n    var js, fjs = d.getElementsByTagName(s)[0];\n    if (d.getElementById(id)) return;\n    js = d.createElement(s);\n    js.id = id;\n    js.src = \"//connect.facebook.net/ja_JP/sdk.js#xfbml=1&appId=739888202714641&version=v2.0\";\n    fjs.parentNode.insertBefore(js, fjs);\n  }(document, 'script', 'facebook-jssdk'));\n</script>\n\n<!-- twitter -->\n<script>\n  ! function(d, s, id) {\n    var js, fjs = d.getElementsByTagName(s)[0],\n      p = /^http:/.test(d.location) ? 'http' : 'https';\n    if (!d.getElementById(id)) {\n      js = d.createElement(s);\n      js.id = id;\n      js.src = p + '://platform.twitter.com/widgets.js';\n      fjs.parentNode.insertBefore(js, fjs);\n    }\n  }(document, 'script', 'twitter-wjs');\n</script>\n\n    </body>\n\n</html>","finalUrl":"https://www.ic-group.co.jp/recruitment/welfare/","rendered":false,"_cachedAt":"2026-06-22T15:58:20.001Z"}