t\t<a href=\"/corporateSustainability.php\">環境・CSR</a>\n\t\t\t<ul class=\"sub_menu\">\n\t\t\t\t<li><a href=\"/newsrelease.php#news\">お知らせ</a></li>\n\t\t\t\t<li><a href=\"/newsrelease.php#press\">プレスリリース</a></li>\n\t\t\t</ul>\n\t\t</div>\n\t\t<div>\n\t\t\t<a href=\"/movie.php\">動画で観る製鉄</a>\n\t\t\t<ul class=\"sub_menu\">\n\t\t\t\t<li><a href=\"/newsrelease.php#news\">お知らせ</a></li>\n\t\t\t\t<li><a href=\"/newsrelease.php#press\">プレスリリース</a></li>\n\t\t\t</ul>\n\t\t</div>\n\t\t<div>\n\t\t\t<a href=\"/recruit.php\">採用情報</a>\n\t\t\t<ul class=\"sub_menu\">\n\t\t\t\t<li><a href=\"/newsrelease.php#news\">お知らせ</a></li>\n\t\t\t\t<li><a href=\"/newsrelease.php#press\">プレスリリース</a></li>\n\t\t\t</ul>\n\t\t</div>\n\t</div>\n\t<div id=\"nav_SP\" style=\"display:none;\">\n\t\t<div id=\"menu_wrapper\">\n\t\t\t<p class=\"humberger\">\n\t\t\t\t<span></span>\n\t\t\t\t<span></span>\n\t\t\t\t<span></span>\n\t\t\t</p>\n\t\t\t<nav id=\"sp_menu\" style=\"display:none;\">\n\t\t\t\t<ul class=\"menu\">     \n\t\t\t\t\t<li><a href=\"/\">ホーム</a></li>\n\t\t\t\t\t<li><a href=\"/newsrelease.php\">ニュースリリース</a></li>\n\t\t\t\t\t<li><a href=\"/companyProfile.php\">会社概要</a></li>\n\t\t\t\t\t<li><a href=\"/businessSummary.php\">事業概要</a></li>\n\t\t\t\t\t<li><a href=\"/corporateSustainability.php\">環境・CSR</a></li>\n\t\t\t\t\t<li><a href=\"/movie.php\">動画で観る製鉄</a></li>\n\t\t\t\t\t<li><a href=\"/recruit.php\">採用情報</a></li>\n\t\t\t\t\t<li><a href=\"/companyProfile.php#map\">所在地マップ</a></li>\n\t\t\t\t\t<li><a href=\"/privacypolicy.php\">個人情報保護方針</a></li>\n\t\t\t\t\t<li><a href=\"/contact.php?token=5c409e615f17d15724546c93f3c29b87be544654fb2197d860949f114ad8a31f\">採用情報へのお問合せ</a></li>\n\t\t\t\t</ul>\n\t\t\t</nav>\n\t\t</div>\n\t</div>\n\t<script>\n\t$(function(){\n\t\t$(\".humberger\").on(\"click\", function(){\n\t\t\tvar rightVal = 0;\n\t\t\tif($(this).hasClass(\"open\")) {\n\t\t\t\trightVal = '-100vw';\n\t\t\t\t$(this).removeClass(\"open\");\n\t\t\t} else {\n\t\t\t\t$(this).addClass(\"open\");\n\t\t\t\t$(\"#sp_menu\").css(\"display\",\"block\");\n\t\t\t}\n\t \n\t\t\t$(\"#sp_menu\").stop().animate({\n\t\t\t\t'right': rightVal\n\t\t\t}, 200);\n\t\t\tif(!$(this).hasClass(\"open\")) {\n\t\t\t\tsetTimeout(function() {\n\t\t\t\t\t$(\"#sp_menu\").css(\"display\",\"none\");\n\t\t\t\t}, 200)\n\t\t\t}\n\t\t});\n\t});\n\t</script>  </header>\n\n  <section id=\"page_head\">\n    <div class=\"bg_image bg_zoomin\" style=\"background-image:url(/images/job/college/mv.jpg)\"></div>\n    <div class=\"headtext \"></div>\n    <div class=\"scroll\"><span></span><span></span><span></span>Scroll</div>\n  </section>\n\n  <main class=\"wrapper p-0\">\n    <section id=\"message\">\n      <div class=\"container\">\n        <h1 style=\"color:#0135d9\" class=\"text-center my-5\">Declaration</h1>\n        <div class=\"row\">\n          <div class=\"col-12 col-md\">\n            <h3 class=\"fade slideUp\">業を磨き、仕事の情熱から、生きる喜びを。</h3>\n          </div>\n          <div class=\"col-12 col-md\">\n            <p class=\"fade\">\n              私たちは1987年新発足以来、お客さま、そして地域の皆様に支えられながら、着実に成長を続けてきました。<br>\n              これからの変化の激しい事業環境へ対応するためには、より広い視野と柔軟な発想を持った人財「ひと」が必要だと考えています。<br>\n              一丸となって改善・改革を進める事ができる「ひと」変化に対応できる新しい発想をもった「ひと」そういう「ひと」との出会いを強く求めています。<br>\n              そして、共に、お客さま、そして地域にとって必要とされる企業を目指してまいります。\n            </p>\n          </div>\n        </div>\n      </div>\n    </section>\n    <section id=\"about\" style=\"background-image:url(/images/job/about_back.jpg); background-size: contain;\">\n      <div class=\"container py-5\">\n        <div style=\"background-color:rgba(255, 255, 255, 0.8);padding:1rem\">\n          <h1 class=\"text-center\" style=\"color:#0135d9\">About Us</h1>\n          <h2 class=\"border-bottom border-black d-inline-block mb-3 p-0\">九州製鋼とは</h2>\n          <div class=\"fade\">\n            私たちは、鉄スクラップから主に鉄筋コンクリート用棒鋼を製造し、建築現場などに提供している会社です。<br>\n            鉄筋コンクリート用棒鋼は、コンクリート構造物の強度を保つためには欠かせない建設資材。確かな品質の鉄筋を製造し、地域のインフラ整備や都市開発に貢献しています。\n          </div>\n          <div class=\"row flex-wrap g-1\">\n            <div class=\"col-12 col-md fade\" style=\"transition-delay: 0s;\">\n              <img class=\"img-fluid\" src=\"/images/job/about01.jpg\" alt=\"工事向け機材\">\n            </div>\n            <div class=\"col-12 col-md fade\" style=\"transition-delay: .25s;\">\n              <img class=\"img-fluid\" src=\"/images/job/about02.jpg\" alt=\"産業・医療・家庭用ガス\">\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n    <section id=\"point\" style=\"background-image:url(/images/job/point_back.jpg);background-size: contain\">\n      <div style=\"background-color:rgba(255,255,255,.5)\">\n        <div class=\"container py-5\">\n          <div class=\"\">\n            <h1 style=\"color:#0135d9\">Strong Point</h1>\n            <h2 class=\"border-bottom border-black d-inline-block mb-3 p-0\">九州製鋼で働く魅力</h2>\n          </div>\n          <div class=\"row flex-wrap g-3\">\n            <div class=\"col-12 col-lg-10 fade slideUp\">\n              <div class=\"box\">\n                <div class=\"box-img\">\n                  <img class=\"w-100 img-fluid\" src=\"/images/job/point01.jpg\" alt=\"dummy\">\n                </div>\n                <div class=\"box-text\">\n                  <div class=\"d-flex p-1 pb-2 g-1\">\n                    <img src=\"/images/job/point_num01.png\" class=\"align-self-center me-2\">\n                    <div class=\"title d-flex align-items-center\">\n                      <h5 class=\"text-white m-0\">持続可能な環境への取り組み</h5>\n                    </div>\n                  </div>\n                  <div>\n                    コンクリート構造物の建築に使用される鉄筋コンクリート用棒鋼や鋳鋼用溶鋼を製造している当社の特徴は、その原材料にあります。<br>\n                    使用している原料は、橋やビル、船舶、自動車が解体されたときや自動車や船舶を製造するときに発生する鉄スクラップ。<br>\n                    それを電気炉で溶かして鉄筋コンクリート用棒鋼に再生します。<br>\n                    しかも、鉄スクラップから鋼を製造するときに出る鉄鋼スラグについても道路用路盤材やその他の土木資材として提供するなど、資源のリサイクルを徹底。<br>\n                    モノづくりを行う企業として責任を果たすべく、持続可能な環境への取り組みを行い、資源循環型社会の一端を担っています。\n                  </div>\n                </div>\n              </div>\n            </div>\n            <div class=\"col-12 col-lg-10 offset-lg-2 fade slideUp\" style=\"transition-delay: .2s\">\n              <div class=\"box\">\n                <div class=\"box-img\">\n                  <img class=\"w-100 img-fluid\" src=\"/images/job/point02.jpg\" alt=\"dummy\">\n                </div>\n                <div class=\"box-text\">\n                  <div class=\"d-flex p-1\">\n                    <img src=\"/images/job/point_num02.png\" class=\"align-self-center me-2\">\n                    <div class=\"title d-flex align-items-center\">\n                      <h5 class=\"text-white m-0\">ワークバランスを重視</h5>\n                    </div>\n                  </div>\n                  <div>\n                    当社では、社員やその家族を守るため、安心して働ける環境を整備しています。<br>\n                    通勤手当や時間外手当はもちろんのこと、職種によっては技能手当や交代勤務手当、サンデープレミアム手当（日曜や祝祭日に出勤した場合の手当）など、各種手当が充実。<br>\n                    働きに適した手当を支給するほか、休みもたっぷり。<br>\n                    年間休日は125日以上で、基本的には土曜、日曜が休みです。<br>\n                    会社についてのことや仕事に関する基本的な知識は、研修で学んだあと、配属先で先輩社員が丁寧にレクチャーします。<br>\n                    気さくで話しやすい先輩が多く、面倒見もよいので何でも聞いてください。<br>\n                    資格取得については会社がサポートする制度もあるので、スキルアップにもチャレンジできますよ。\n                  </div>\n                </div>\n              </div>\n            </div>\n            <div class=\"col-12 col-md-10 fade slideUp\" style=\"transition-delay: .3s\">\n              <div class=\"box\">\n                <div class=\"box-img\">\n                  <img class=\"w-100 img-fluid\" src=\"/images/job/point03.jpg\" alt=\"dummy\">\n                </div>\n                <div class=\"box-text\">\n                  <div class=\"d-flex p-1\">\n                    <img src=\"/images/job/point_num03.png\" class=\"align-self-center me-2\">\n                    <div class=\"title d-flex align-items-center\">\n                      <h5 class=\"text-white m-0\">地域密着</h5>\n                    </div>\n                  </div>\n                  <div>\n                    地域社会に貢献できる会社<br />\n                    <br />\n                    私たちの会社は、佐賀県武雄市と福岡県糟屋郡久山町に拠点をおいています。<br>\n                    大都市に企業が集中する中、地方で事業を行うことは、新たな雇用を創出し、関連サービスが生まれるなど、地域活性化に繋がります。<br>\n                    また、自然環境豊かな場所で働けるため、ストレスも軽減でき、仕事に集中できることも大きなメリットです。\n                  </div>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n    <section id=\"advice\" style=\"background-color:#e0e8ff\">\n      <div class=\"container py-5\">\n        <h1 style=\"color:#0135d9\" class=\"text-center col-12 col-md\">Message</h1>\n        <div class=\"d-flex flex-md-row-reverse flex-wrap\">\n          <div class=\"col-12 col-md align-self-center \">\n            <h2 class=\"d-inline-block mb-3 p-0\">先輩からメッセージ</h2>\n          </div>\n        </div>\n        <div class=\"row flex-wrap g-3\">\n          <div class=\"col-12 col-md-6 fade d-flex flex-column justify-content-between\" style=\"transition-delay: 0s;\">\n            <div>\n              <div style=\"background-color:#0135d9\" class=\"text-white py-2 px-3 mb-3\">製鋼部 製鋼課　K.Nさん（26歳）</div>\n              <img src=\"/images/job/college/advice01_1.jpg\" alt=\"圧延課スタッフ　Y.Sさん\" class=\"w-100 img-fluid\">\n              <p>\n                私の仕事は、操業データの集計を主な業務とし、製鋼に関する事務作業全般に携わっています。<br />\n                業務の中で失敗をしてしまった場合でも、次にどう改善すればよいかという具体的なアドバイスをいただけるため、前向きに学びながら成長できる環境です。<br />\n                職場はオンとオフのメリハリがあり、休憩時間には会話も多く、リフレッシュできる和やかな雰囲気があります。<br />\n                また、有給休暇も取得しやすく、仕事とプライベートの両立がしやすい点も、大きな魅力の一つです。<br />\n                現場作業と事務作業の両方を経験する中で、少しずつ自分のできることが増えていくのを実感しています。<br />\n                上司や先輩方は常に頼りになる存在であり、どんなときも丁寧な指導と温かいサポートをしてくださるため、日々やりがいを持って働くことができています。\n              </p>\n            </div>\n            <div class=\"bg-white p-3\">\n              <div class=\"fs-5 fw-bold d-flex justify-content-center gap-4 mb-2\">\n                <img src=\"/images/job/clock.png\" class=\"img-fluid\" style=\"height:2.5rem\">\n                <span>スケジュール紹介</span>\n              </div>\n              <div class=\"schedule py-4 px-3 mx-0 row\">\n                <div class=\"schedule-list\">\n                  <div class=\"schedule-item\">\n                    <div class=\"schedule-time\">8:00</div>\n                    <div class=\"schedule-text\">ラジオ体操、KY(危険予知)活動、申し送り確認</div>\n                  </div>\n                  <div class=\"schedule-item\">\n                    <div class=\"schedule-time\">9:00</div>\n                    <div class=\"schedule-text\">メール確認・返信</div>\n                  </div>\n                  <div class=\"schedule-item\">\n                    <div class=\"schedule-time\">10:00</div>\n                    <div class=\"schedule-text\">前月操業データ集計まとめ</div>\n                  </div>\n                  <div class=\"schedule-item\">\n                    <div class=\"schedule-time\">11:00</div>\n                    <div class=\"schedule-text\">↓</div>\n                  </div>\n                  <div class=\"schedule-item\">\n                    <div class=\"schedule-time\">12:00</div>\n                    <div class=\"schedule-text\">昼食</div>\n                  </div>\n                  <div class=\"schedule-item\">\n                    <div class=\"schedule-time\">13:00</div>\n                    <div class=\"schedule-text\">メール確認・返信</div>\n                  </div>\n                  <div class=\"schedule-item\">\n                    <div class=\"schedule-time\">14:00</div>\n                    <div class=\"schedule-text\">操業データの集計</div>\n                  </div>\n                  <div class=\"schedule-item\">\n                    <div class=\"schedule-time\">15:00</div>\n                    <div class=\"schedule-text\">現場確認</div>\n                  </div>\n                  <div class=\"schedule-item\">\n                    <div class=\"schedule-time\">16:00</div>\n                    <div class=\"schedule-text\">購入品依頼の申請</div>\n                  </div>\n                  <div class=\"schedule-item\">\n                    <div class=\"schedule-time\">17:00</div>\n                    <div class=\"schedule-text\">退社</div>\n                  </div>\n                </div>\n                <div style=\"height: 3.5rem;\" class=\"d-lg-none\"></div>\n              </div>\n            </div>\n\n          </div>\n          <div class=\"col-12 col-md-6 fade d-flex flex-column justify-content-between\" style=\"transition-delay: 0.25s;\">\n            <div>\n              <div style=\"background-color:#0135d9\" class=\"text-white py-2 px-3 mb-3\">業務部 購買課　A.Kさん（24歳）</div>\n              <img class=\"w-100 img-fluid\" src=\"/images/job/college/advice02_1.jpg\" alt=\"購買課　A.Kさん\">\n              <p>\n                私がいる購買課は、製品作りに必要な資材（スクラップ・スケール）や作業に必要な部品や道具を購入し現場へ届ける部署です。<br>\n                発注から、納期管理、納品・出荷管理、請求管理、在庫管理までを一貫して担っています。また依頼があれば補修工事を手配したりもします。特に購入に際しては、価格や買うタイミングを管理し、適切な時期に予算内で高品質なものを揃えるという重要な役割を担っています。<br>\n                仕事で何か分からない時は、他部署の人にも気軽に質問ができる職場なので、暖かく見守ってくれていると感じています。<br>\n                ある時は現場へ行ったり、またある時は現場や事務所で必要なものをそろえたり不要な物を処分したりと、毎日やりがいを持って仕事しています。<br>\n                担当業務に優先順位をつけ今日はここまで終わらせようと自分で決めたところまでやり切った時なんかは、とても気持ちがいいです。<br>\n                自分のペースでコツコツと仕事できるので、個人一人一人が尊重されている良い会社だと感じています。<br>\n                働いている方々も優しくて、よく助けになってくれます。この会社に入れて良かったなぁとつくづく思っています。\n              </p>\n            </div>\n\n            <div class=\"bg-white p-3\">\n              <div class=\"fs-5 fw-bold d-flex justify-content-center gap-4 mb-2\">\n                <img src=\"/images/job/clock.png\" class=\"img-fluid\" style=\"height:2.5rem\">\n                <span>スケジュール紹介</span>\n              </div>\n              <div class=\"schedule py-4 px-3 mx-0 row\">\n                <div class=\"schedule-list\">\n                  <div class=\"schedule-item\">\n                    <div class=\"schedule-time\">7:45</div>\n                    <div class=\"schedule-text\">朝礼(ラジオ体操と今日行う業務の連絡をします。)</div>\n                  </div>\n                  <div class=\"schedule-item\">\n                    <div class=\"schedule-time\">8:00</div>\n                    <div class=\"schedule-text\">スクラップ在庫確認(月初めは棚卸)</div>\n                  </div>\n                  <div class=\"schedule-item\">\n                    <div class=\"schedule-time\">8:40</div>\n                    <div class=\"schedule-text\">\n                      スクラップのトラック積込指示<br>\n                      購入依頼申請処理<br>\n                      月末締め作業の準備(月初めは締め資料作成)<br>\n                      電話の対応や取り次ぎ\n                    </div>\n                  </div>\n                  <div class=\"schedule-item\">\n                    <div class=\"schedule-time\">12:00</div>\n                    <div class=\"schedule-text\">昼休憩(食堂でお弁当を食べます)</div>\n                  </div>\n                  <div class=\"schedule-item\">\n                    <div class=\"schedule-time\">13:00</div>\n                    <div class=\"schedule-text\">\n                      発注書作成<br>\n                      電話の対応や取り次ぎ<br>\n                      納入物の受け取り\n                    </div>\n                  </div>\n                  <div class=\"schedule-item\">\n                    <div class=\"schedule-time\">16:45</div>\n                    <div class=\"schedule-text\">退社</div>\n                  </div>\n                </div>\n                <div style=\"height: 2.5rem;\" class=\"d-lg-block d-none\"></div>\n              </div>\n            </div>\n          </div>\n        </div>\n    </section>\n\n    <section id=\"flow\" style=\"background-image:url(/images/job/flow_back.jpg);background-size: contain\">\n      <div style=\"background-color:#0135d980\">\n        <div class=\"container py-5\">\n          <div class=\"d-flex flex-md-row-reverse flex-wrap\">\n            <h1 class=\"text-center col-12 col-md text-white\">Flow</h1>\n            <div class=\"col-12 col-md align-self-center \">\n              <h2 class=\"border-bottom border-white d-inline-block mb-3 text-white p-0\">入社までの流れ</h2>\n            </div>\n          </div>\n          <div>\n            <img alt=\"demo\" class=\"img-fluid w-100 fade slideUp\" src=\"/images/job/flowchart.png\">\n            <div class=\"text-white fade slideUp\">面接は計２回ですが、一次面接はWEB（Zoom等）で行うことも可能です。<br>最終選考のみ本社にお越しいただきます。<br>最終選考でかかった交通費は全額当社が負担いたします。<br><br>その他、面接に関しまして柔軟に対応致しますので、不安な点やご不明点がありましたらお気軽にご相談ください。</div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <section id=\"recruit\">\n      <div class=\"container py-5\">\n        <h1 style=\"color:#0135d9\" class=\"text-center col-12 col-md\">Recruit</h1>\n        <div class=\"d-flex flex-md-row-reverse flex-wrap\">\n          <div class=\"col-12 col-md align-self-center \">\n            <h2 class=\"border-bottom border-black d-inline-block mb-3 p-0\">求人情報</h2>\n          </div>\n        </div>\n        <table class=\"table table-bordered recruit-table my-3\">\n          <tbody>\n            <tr>\n              <th>【仕事の内容】 </th>\n              <td>\n                <div class=\"d-flex\">\n                  <div class=\"text-nowrap\">福岡：</div>\n                  <div>\n                    鉄筋コンクリート用異形棒鋼（製品）の生産プロセスにおける圧延工程<br>\n                    （鋼片を鉄筋の形状に熱間加工する工程）の全般業務\n                  </div>\n                </div>\n                <div class=\"d-flex\">\n                  <div class=\"text-nowrap\">佐賀：</div>\n                  <div>\n                    鉄筋コンクリート用棒鋼用の原料である鋼塊及び鋳鋼用溶鋼の製造及びメンテナンス<br>\n                    鉄屑から鋼片を製造する業務\n                  </div>\n                </div>\n                ※職種は勤務地によって異なります\n              </td>\n            </tr>\n            <tr>\n              <th>【労働条件等】 </th>\n              <td>\n                <table class=\"job\">\n                  <tbody>\n                    <tr>\n                      <th>基本給</th>\n                      <td>月額232,000円</td>\n                    </tr>\n                    <tr>\n                      <th>就業時間</th>\n                      <td>\n                        変形労働時間制（1ヶ月単位）<br>\n                        本社　　　08:30～17:30<br>\n                        福岡工場　07:45～16:45　13:15～22:15　22:00～08:00<br>\n                        佐賀工場　08:00～17:00　14:30～00:00　22:00～08:45<br>\n                        ※勤務地または所属先によって就業時間が異なる\n                      </td>\n                    </tr>\n                    <tr>\n                      <th>休日等</th>\n                      <td>\n                        年間127日～156日<br>\n                        ※勤務地または所属先によって休日が異なる\n                      </td>\n                    </tr>\n                    <tr>\n                      <th>手当等</th>\n                      <td>通勤手当、日祝手当、資格手当、その他各種手当あり </td>\n                    </tr>\n                    <tr>\n                      <th>賞与</th>\n                      <td>年2回（7月、12月）</td>\n                    </tr>\n                    <tr>\n                      <th>加入保険等&nbsp;&nbsp;</th>\n                      <td>雇用、労災、健康、厚生等あり</td>\n                    </tr>\n                  </tbody>\n                </table>\n              </td>\n            </tr>\n          </tbody>\n        </table>\n      </div>\n    </section>\n\n  </main>\n\n  <footer>\n    \t<div id=\"page_top\"><a href=\"#\"></a></div>\r\n\t<div class=\"f_logo\"><a href=\"/\"><img src=\"/images/header/logo.png\"></a></div>\r\n\t<div class=\"f_menu\">\r\n\t\t<div><a href=\"/companyProfile.php#map\">所在地マップ</a></div>\r\n\t\t<div><a href=\"/privacypolicy.php\">個人情報保護方針</a></div>\r\n\t\t<div><a href=\"/contact.php?token=5c409e615f17d15724546c93f3c29b87be544654fb2197d860949f114ad8a31f\">採用情報へのお問合せ</a></div>\r\n\t</div>\r\n\t<div class=\"f_inner_menu\">\r\n\t\t<div><p class=\"head\"><a href=\"/newsrelease.php\">ニュースリリース</a></p>\r\n\t\t\t<ul>\r\n\t\t\t\t<li><a href=\"/newsrelease.php#news\">お知らせ</a></li>\r\n\t\t\t\t<li><a href=\"/newsrelease.php#press\">プレスリリース</a></li>\r\n\t\t\t</ul>\r\n\t\t</div>\r\n\t\t<div><p class=\"head\"><a href=\"/companyProfile.php\">会社概要<