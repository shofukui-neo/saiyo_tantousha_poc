ass=\"head\"><a href=\"/movie.php\">動画で観る製鉄</a></p>\r\n\t\t\t<ul>\r\n\t\t\t\t<li><a href=\"/movie.php#all_movie\">製造工程Ｍovie</a></li>\r\n\t\t\t\t<li><a href=\"/movie.php#saga_movie\">製鋼部門Ｍovie</a></li>\r\n\t\t\t\t<li><a href=\"/movie.php#fukuoka_movie\">圧延部門Ｍovie</a></li>\r\n\t\t\t</ul>\r\n\t\t</div>\r\n\t</div>\r\n\t<div class=\"copyright\">© 2007 Kyushu Steel Corporation.</div>  </footer>\n</body>\n\n</html>\n","finalUrl":"https://www.kyushu-steel.com/recruit/cl.php","rendered":false,"_cachedAt":"2026-06-22T20:32:06.509Z"}