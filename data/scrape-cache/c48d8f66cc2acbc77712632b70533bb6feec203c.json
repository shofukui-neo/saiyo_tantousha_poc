-- nav_right -->\n    </div><!-- nav_inner -->\n  </header>\n\n\n<main>\n  <!-- subVisual\n================================================== -->\n  <div id=\"subVisual\">\n    <h2>求人情報<span>RECRUITMENT INFORMATION</span></h2>\n  </div><!-- subVisual -->\n\n\n  <div class=\"hidden relative\">\n\n    <span class=\"bg_en recruitdetail\">RECRUITMENT INFORMATION</span>\n    <!-- recruitdetail\n ================================================== -->\n    <section id=\"recruitdetail\" class=\"section\">\n      <div class=\"wrap\">\n        <div class=\"recruit_top\">\n          <img width=\"1000\" height=\"666\" src=\"https://sanwanet.co.jp/wp/wp-content/uploads/2025/11/求人情報②_P6A9944.jpg\" class=\"attachment-post-thumbnail size-post-thumbnail wp-post-image\" alt=\"\" decoding=\"async\" fetchpriority=\"high\" srcset=\"https://sanwanet.co.jp/wp/wp-content/uploads/2025/11/求人情報②_P6A9944.jpg 1000w, https://sanwanet.co.jp/wp/wp-content/uploads/2025/11/求人情報②_P6A9944-300x200.jpg 300w, https://sanwanet.co.jp/wp/wp-content/uploads/2025/11/求人情報②_P6A9944-768x511.jpg 768w\" sizes=\"(max-width: 1000px) 100vw, 1000px\" />          <dl>\n            <dt>職種</dt>\n            <dd>技術職(施工管理/現場代理人)<br>中途(未経験者向け)</dd>\n            <dt>雇用形態</dt>\n            <dd>正社員</dd>\n            <dt>給与</dt>\n            <dd>月給270,000円～298,000円（初年度の年収イメージ：380万円～450万円）<br />\r\n※年齢、経験、能力を考慮の上、優遇いたします。<br />\r\n※上記月給には固定残業代（48,000円～53,000円／月30時間分）を含みます。超過分は別途支給。</dd>\n            <dt>勤務地</dt>\n            <dd>香川・徳島・大阪・東京・福岡・福島</dd>\n            <dt>勤務時間</dt>\n            <dd>8：30～17：30（休憩60分）</dd>\n          </dl>\n        </div>\n        <div class=\"btnArea ac\">\n          <a href=\"#entry\">エントリーする</a>\n        </div>\n\n        <div class=\"recruit_under\">\n          <ul id=\"accordion\">\n            <li>\n              <div class=\"label\">仕事内容</div>\n              <div class=\"detail\">三和電業グループは、オフィスビル・商業施設・公共施設・工場などの電気設備工事を通じて、人々の生活を支えています。<br />\r\n未経験の方には、まずは現場での補助業務を中心に、電気設備の基礎・安全管理・工具の使い方などを一から学んでいただきます。<br />\r\nその後、先輩社員のサポートを受けながら、「4大管理（安全・工程・品質・原価管理）」など専門的な業務にもステップアップしていきます。<br />\r\n当社は「技術力」と同じように「人間力」を重視しており、経営理念・フィロソフィに基づいた教育に力を入れています。<br />\r\n技術だけでなく、礼儀・責任感・チームワークといった人としての成長を大切にし、誠実に努力する姿勢をしっかり評価します。</div>\n            </li>\n            <li>\n              <div class=\"label\">職場について</div>\n              <div class=\"detail\">社員同士の距離が近く、わからないことはすぐに相談できる家族的で温かい雰囲気の職場です。<br />\r\nパートナー社員が丁寧に指導し、安心して成長できるサポート体制を整えています。<br />\r\n部門内での技術勉強会や経営理念共有の機会を通じて、技術と人間力の両方を磨ける環境です。</div>\n            </li>\n            <li>\n              <div class=\"label\">当社で働く魅力</div>\n              <div class=\"detail\">・未経験からでも安心して技術を身につけられる教育体制<br />\r\n・経営理念に基づき「人間力」を育てる研修・勉強会<br />\r\n・国家資格取得支援制度、各種手当、リゾート施設利用など福利厚生が充実<br />\r\n・地域に根ざし、社会に貢献できる誇りある仕事</div>\n            </li>\n            <li>\n              <div class=\"label\">求める人物像</div>\n              <div class=\"detail\">・未経験から手に職をつけたい方<br />\r\n・誠実に学び、コツコツ努力できる方<br />\r\n・仲間を大切にし、協力して仕事に取り組める方<br />\r\n・技術と人間力の両方を磨いていきたい方</div>\n            </li>\n          </ul>\n        </div>\n      </div>\n    </section><!-- detail -->\n\n\n\n    <!-- guidelines\n ================================================== -->\n    <section id=\"guidelines\" class=\"section bg_section\">\n\n      <div class=\"wrap\">\n        <h2 class=\"hd in_ani fadeleft\">募集要項<span>GUIDELINES</span></h2>\n        <div class=\"inner\">\n          <dl class=\"guidelines_list\">\n            <dt>雇用形態</dt>\n            <dd>正社員</dd>\n            <dt>業務内容</dt>\n            <dd>技術者（施工管理/現場代理人）</dd>\n            <dt>勤務地</dt>\n            <dd>香川・徳島・大阪・東京・福岡・福島</dd>\n            <dt>勤務時間</dt>\n            <dd>8：30～17：30（休憩60分）</dd>\n            <dt>給与</dt>\n            <dd>月給270,000円～298,000円（初年度の年収イメージ：380万円～450万円）<br />\r\n※年齢、経験、能力を考慮の上、優遇いたします。<br />\r\n※上記月給には固定残業代（48,000円～53,000円／月30時間分）を含みます。超過分は別途支給。</dd>\n            <dt>諸手当</dt>\n            <dd>通勤手当：実費支給（上限あり）<br />\r\n家族手当：配偶者5,000円、子供5,000円<br />\r\n住宅手当：上限15,000円<br />\r\n残業手当：固定残業手当を超過した分は別途支給<br />\r\n資格手当<br />\r\n地域手当<br />\r\n役職手当<br />\r\n営業手当<br />\r\n健康増進手当：禁煙宣言者5,000円</dd>\n            <dt>昇給</dt>\n            <dd>年1回（6月）</dd>\n            <dt>賞与</dt>\n            <dd>年2回（7月、12月）</dd>\n            <dt>応募条件</dt>\n            <dd>高校/短大/専門/高専/大学/大学院 卒業の方</dd>\n            <dt>備考</dt>\n            <dd>試用期間3ヶ月あり（待遇変動はありません）</dd>\n            <dt>募集人数</dt>\n            <dd>3名</dd>\n            <dt>休日休暇</dt>\n            <dd>◆休日<br />\r\n週休2日制（会社カレンダーによる※土日休み推奨）<br />\r\n年間休日休暇127日<br />\r\n◆休暇<br />\r\n夏期休暇、年末年始休暇、創立記念日、特別休暇（結婚・忌服休暇）、リフレッシュ休暇、有給休暇<br />\r\n産前産後休暇、育児休暇（パパ育休制度含む）</dd>\n            <dt>福利厚生</dt>\n            <dd>社会保険完備（健康保険、厚生年金、雇用保険、労働災害補償保険（労災））<br />\r\n退職金制度、再雇用制度、確定拠出年金、財形貯蓄、共済会、社員持株会、資格取得補助金制度、社員表彰制度（永年勤続等）、<br />\r\n奨学金返済支援制度、海外研修旅行、レクリエーション、クラブ活動（野球、釣り、ゴルフなど）、教育研修制度、<br />\r\n寮社宅、施設の利用（リゾート施設等）、受動喫煙対策：屋内全面禁煙</dd>\n            <dt>応募方法</dt>\n            <dd>エントリーフォームに必要事項を記入し応募してください。</dd>\n            <dt>提出書類</dt>\n            <dd>履歴書（写真貼付）・職務経歴書</dd>\n            <dt>選考方法</dt>\n            <dd>書類選考→SPI 試験→面接</dd>\n\n          </dl>\n\n        </div>\n        <div class=\"btnArea ac\">\n          <a href=\"#entry\">エントリーする</a>\n        </div>\n      </div>\n    </section>\n    <!-- guidelines -->\n\n\n    <!-- company\n    ================================================== -->\n    <section id=\"company\" class=\"section bg_section\">\n\n      <div class=\"wrap\">\n        <h2 class=\"hd in_ani fadeleft\">企業情報<span>COMPANY INFORMATION</span></h2>\n\n        <div class=\"inner\">\n          <h3>三和電業グループ</h3>\n          <dl>\n            <dt>事業内容</dt>\n            <dd>【三和電業株式会社】<br>\n              一般施設（オフィスビル・商業施設・医療施設）／電気・計装・給排水衛生・空調換気設備<br>\n              産業施設（医薬品工場・半導体工場）／電気・計装・給排水衛生・空調換気設備<br>\n              特殊設備（医薬品工場・半導体工場）／特別高圧受変電設備・UTLY設備<br>\n              【三和プラントエンジニアリング株式会社】<br>\n              計装制御設備／各種制御盤、監視盤の設計・製造／ネットワーク設備／FAシステム開発／<br>\n              FAパッケージソフト開発・販売<br>\n              【三和空調株式会社】<br>\n              特殊空気調和設備/クリーンルーム関連設備・バイオハザード関連設備・直膨式低湿空気調和<br>\n              設備・恒温恒湿空気調和設備<br>\n              その他設備/ＨＡＣＣＰ関連設備・冷凍冷蔵設備・給排水衛生設備・電気計装設備<br>\n              【三和エコ&エナジー株式会社】<br>\n              太陽光発電設備工事／環境設備工事／省エネルギー設備工事及びエンジニアリング／電気設備<br>\n              工事／計装設備工事／防災設備工事／監視制御設備工事</dd>\n            <dt>創業</dt>\n            <dd>1948年4月</dd>\n            <dt>資本金</dt>\n            <dd>1億8,000万円（グループ全体）</dd>\n            <dt>社員数</dt>\n            <dd>286名（グループ全体）</dd>\n            <dt>売上高</dt>\n            <dd>74億6,600万円（グループ全体・2024年実績）</dd>\n          </dl>\n        </div>\n\n\n      </div>\n    </section>\n    <!-- company -->\n\n\n\n    <!-- entry\n    ================================================== -->\n    <section id=\"entry\" class=\"section\">\n      <div class=\"wrap\">\n        <h2>エントリー</h2>\n\n\n\n        \n<div class=\"wpcf7 no-js\" id=\"wpcf7-f4388-o1\" lang=\"ja\" dir=\"ltr\" data-wpcf7-id=\"4388\">\n<div class=\"screen-reader-response\"><p role=\"status\" aria-live=\"polite\" aria-atomic=\"true\"></p> <ul></ul></div>\n<form action=\"/recruit/recruit-4416#wpcf7-f4388-o1\" method=\"post\" class=\"wpcf7-form init\" aria-label=\"コンタクトフォーム\" novalidate=\"novalidate\" data-status=\"init\">\n<fieldset class=\"hidden-fields-container\"><input type=\"hidden\" name=\"_wpcf7\" value=\"4388\" /><input type=\"hidden\" name=\"_wpcf7_version\" value=\"6.1.1\" /><input type=\"hidden\" name=\"_wpcf7_locale\" value=\"ja\" /><input type=\"hidden\" name=\"_wpcf7_unit_tag\" value=\"wpcf7-f4388-o1\" /><input type=\"hidden\" name=\"_wpcf7_container_post\" value=\"0\" /><input type=\"hidden\" name=\"_wpcf7_posted_data_hash\" value=\"\" />\n</fieldset>\n<dl class=\"form_list\">\n\t<dt>\n\t\t<p>名前<span>必須</span>\n\t\t</p>\n\t</dt>\n\t<dd>\n\t\t<p><span class=\"wpcf7-form-control-wrap\" data-name=\"text-111\"><input size=\"40\" maxlength=\"400\" class=\"wpcf7-form-control wpcf7-text wpcf7-validates-as-required\" autocomplete=\"name\" aria-required=\"true\" aria-invalid=\"false\" value=\"\" type=\"text\" name=\"text-111\" /></span>\n\t\t</p>\n\t</dd>\n\t<dt>\n\t\t<p>フリガナ<span>必須</span>\n\t\t</p>\n\t</dt>\n\t<dd>\n\t\t<p><span class=\"wpcf7-form-control-wrap\" data-name=\"text-222\"><input size=\"40\" maxlength=\"400\" class=\"wpcf7-form-control wpcf7-text wpcf7-validates-as-required\" aria-required=\"true\" aria-invalid=\"false\" value=\"\" type=\"text\" name=\"text-222\" /></span>\n\t\t</p>\n\t</dd>\n\t<dt>\n\t\t<p>生年月日\n\t\t</p>\n\t</dt>\n\t<dd class=\"birth\">\n\t\t<p><span class=\"wpcf7-form-control-wrap\" data-name=\"text-333\"><input size=\"40\" maxlength=\"400\" class=\"wpcf7-form-control wpcf7-text year\" aria-invalid=\"false\" value=\"\" type=\"text\" name=\"text-333\" /></span>年<span class=\"wpcf7-form-control-wrap\" data-name=\"text-444\"><input size=\"40\" maxlength=\"400\" class=\"wpcf7-form-control wpcf7-text month\" aria-invalid=\"false\" value=\"\" type=\"text\" name=\"text-444\" /></span>月<span class=\"wpcf7-form-control-wrap\" data-name=\"text-555\"><input size=\"40\" maxlength=\"400\" class=\"wpcf7-form-control wpcf7-text day\" aria-invalid=\"false\" value=\"\" type=\"text\" name=\"text-555\" /></span>日\n\t\t</p>\n\t</dd>\n\t<dt>\n\t\t<p>電話番号<span>必須</span>\n\t\t</p>\n\t</dt>\n\t<dd>\n\t\t<p><span class=\"wpcf7-form-control-wrap\" data-name=\"text-666\"><input size=\"40\" maxlength=\"400\" class=\"wpcf7-form-control wpcf7-text wpcf7-validates-as-required\" aria-required=\"true\" aria-invalid=\"false\" value=\"\" type=\"text\" name=\"text-666\" /></span>\n\t\t</p>\n\t</dd>\n\t<dt>\n\t\t<p>メールアドレス<span>必須</span>\n\t\t</p>\n\t</dt>\n\t<dd>\n\t\t<p><span class=\"wpcf7-form-control-wrap\" data-name=\"text-777\"><input size=\"40\" maxlength=\"400\" class=\"wpcf7-form-control wpcf7-text wpcf7-validates-as-required\" aria-required=\"true\" aria-invalid=\"false\" value=\"\" type=\"text\" name=\"text-777\" /></span>\n\t\t</p>\n\t</dd>\n\t<dt class=\"txt\">\n\t\t<p>備考\n\t\t</p>\n\t</dt>\n\t<dd class=\"txt\">\n\t\t<p><span class=\"wpcf7-form-control-wrap\" data-name=\"textarea-888\"><textarea cols=\"40\" rows=\"10\" maxlength=\"2000\" class=\"wpcf7-form-control wpcf7-textarea\" aria-invalid=\"false\" name=\"textarea-888\"></textarea></span>\n\t\t</p>\n\t</dd>\n</dl>\n<div class=\"policyArea\">\n\t<h3>個人情報保護方針\n\t</h3>\n\t<div class=\"inner\">\n\t\t<p><br />\n三和電業株式会社（以下当社）では、個人情報に関する法令およびその他の規範を遵守し、お客様の大切な個人情報の保護に万全を尽くします。\n\t\t</p>\n\t\t<p>個人情報の収集について\n\t\t</p>\n\t\t<p><br />\n当社では、次のような場合に必要な範囲で個人情報を収集することがあります。\n\t\t</p>\n\t\t<p><br />\n・当社へのお問い合わせ時\n\t\t</p>\n\t\t<p>・当社へのサービスお申し込み時\n\t\t</p>\n\t\t<p>個人情報の利用目的について\n\t\t</p>\n\t\t<p><br />\n当社は、お客様から収集した個人情報を次の目的で利用いたします。\n\t\t</p>\n\t\t<p><br />\n・お客様への連絡のため\n\t\t</p>\n\t\t<p>・お客様からのお問い合せに対する回答のため\n\t\t</p>\n\t\t<p>・お客様へのサービス提供のため\n\t\t</p>\n\t\t<p>個人情報の第三者への提供について\n\t\t</p>\n\t\t<p><br />\n当社では、お客様より取得した個人情報を第三者に開示または提供することはありません。\n\t\t</p>\n\t\t<p>ただし、次の場合は除きます。\n\t\t</p>\n\t\t<p><br />\n・警察からの要請など、官公署からの要請の場合\n\t\t</p>\n\t\t<p>・法律の適用を受ける場合\n\t\t</p>\n\t\t<p>個人情報の開示、訂正等について\n\t\t</p>\n\t\t<p><br />\n当社は、お客様ご本人からの自己情報の開示、訂正、削除等のお求めがあった場合は、確実に応じます。\n\t\t</p>\n\t\t<p>個人情報保護に関するお問い合わせ先\n\t\t</p>\n\t\t<p><br />\n住所：〒761-8073　香川県高松市太田下町2580番地3\n\t\t</p>\n\t\t<p>電話番号：087-865-8585\n\t\t</p>\n\t\t<p>三和電業株式会社\n\t\t</p>\n\t</div>\n</div>\n<div class=\"policyCheck\">\n\t<p>送信するには個人情報の取扱いについてへの同意が必要です。\n\t</p>\n\t<div>\n\t\t<p><sup>必須</sup><span class=\"wpcf7-form-control-wrap\" data-name=\"radio-222\"><span class=\"wpcf7-form-control wpcf7-radio agreeChk\"><span class=\"wpcf7-list-item first last\"><label><input type=\"radio\" name=\"radio-222\" value=\"同意する\" /><span class=\"wpcf7-list-item-label\">同意する</span></label></span></span></span>\n\t\t</p>\n\t</div>\n</div>\n<p><input class=\"wpcf7-form-control wpcf7-submit has-spinner submit\" type=\"submit\" value=\"送信\" />\n</p>\n<input class=\"wpcf7-form-control wpcf7-hidden\" id=\"recruit-title\" value=\"\" type=\"hidden\" name=\"recruit_title\" /><div class=\"wpcf7-response-output\" aria-hidden=\"true\"></div>\n</form>\n</div>\n        <script>\n          document.addEventListener('wpcf7mailsent', function(event) {\n            if (event.detail.contactFormId == '4388') {\n              window.location.href = '/sanwa/wp/contact/contact/r-thanks/';\n            }\n          }, false);\n        </script>\n      </div>\n    </section>\n\n\n\n  </div>\n</main>\n\n\n<!-- footer\n================================================== -->\n<!-- footer\n================================================== -->\n<footer>\n  <div class=\"inner\">\n    <div class=\"footer_logo\">\n      <a href=\"https://sanwanet.co.jp\"><img src=\"https://sanwanet.co.jp/wp/wp-content/themes/sanwa_2025/assets/images/logo.png\" alt=\"三和電業グループ\"></a>\n    </div>\n\n    <div class=\"footer_menu\">\n      <ul>\n        <li><a href=\"https://sanwanet.co.jp\">TOP</a></li>\n        <li><a href=\"https://sanwanet.co.jp/news/\">新着情報</a></li>\n        <li><a href=\"https://sanwanet.co.jp/about/\">三和電業グループについて</a></li>\n        <li><a href=\"https://sanwanet.co.jp/company/\">各社概要</a></li>\n        <li><a href=\"https://sanwanet.co.jp/technology/\">技術紹介</a></li>\n        <li><a href=\"https://sanwanet.co.jp/works/\">施工事例</a></li>\n        <li><a href=\"https://sanwanet.co.jp/recruit/\">採用情報</a></li>\n      </ul>\n      <ul>\n        <li><a href=\"https://sanwanet.co.jp/sanwakai/\">三和会</a></li>\n        <li><a href=\"https://sanwanet.co.jp/information/\">情報誌</a></li>\n        <li><a href=\"https://sanwanet.co.jp/policy/\">個人情報保護について</a></li>\n        <li><a href=\"https://sanwanet.co.jp/partner/\">協力会社様専用サイト</a></li>\n        <li><a href=\"https://sanwanet.co.jp/kyouryokukai/\">三和電業グループ<br class=\"sp\">安全衛生協力会専用サイト</a></li>\n        <li><a href=\"https://sanwanet.co.jp/contact/\">お問い合わせ</a></li>\n      </ul>\n    </div>\n    <!-- footer_right -->\n\n    <p class=\"ft_copy\">Copyright(c) 2025 Sanwa Dengyo Group All Rights Reserved.</p>\n  </div>\n\n  <script type=\"speculationrules\">\n{\"prefetch\":[{\"source\":\"document\",\"where\":{\"and\":[{\"href_matches\":\"\\/*\"},{\"not\":{\"href_matches\":[\"\\/wp\\/wp-*.php\",\"\\/wp\\/wp-admin\\/*\",\"\\/wp\\/wp-content\\/uploads\\/*\",\"\\/wp\\/wp-content\\/*\",\"\\/wp\\/wp-content\\/plugins\\/*\",\"\\/wp\\/wp-content\\/themes\\/sanwa_2025\\/*\",\"\\/*\\\\?(.+)\"]}},{\"not\":{\"selector_matches\":\"a[rel~=\\\"nofollow\\\"]\"}},{\"not\":{\"selector_matches\":\".no-prefetch, .no-prefetch a\"}}]},\"eagerness\":\"conservative\"}]}\n</script>\n\n<!-- Template file: single-recruit.php -->\n<script type=\"text/javascript\" src=\"https://sanwanet.co.jp/wp/wp-includes/js/dist/hooks.min.js?ver=4d63a3d491d11ffd8ac6\" id=\"wp-hooks-js\"></script>\n<script type=\"text/javascript\" src=\"https://sanwanet.co.jp/wp/wp-includes/js/dist/i18n.min.js?ver=5e580eb46a90c2b997e6\" id=\"wp-i18n-js\"></script>\n<script type=\"text/javascript\" id=\"wp-i18n-js-after\">\n/* <![CDATA[ */\nwp.i18n.setLocaleData( { 'text direction\\u0004ltr': [ 'ltr' ] } );\n/* ]]> */\n</script>\n<script type=\"text/javascript\" src=\"https://sanwanet.co.jp/wp/wp-content/plugins/contact-form-7/includes/swv/js/index.js?ver=6.1.1\" id=\"swv-js\"></script>\n<script type=\"text/javascript\" id=\"contact-form-7-js-translations\">\n/* <![CDATA[ */\n( function( domain, translations ) {\n\tvar localeData = translations.locale_data[ domain ] || translations.locale_data.messages;\n\tlocaleData[\"\"].domain = domain;\n\twp.i18n.setLocaleData( localeData, domain );\n} )( \"contact-form-7\", {\"translation-revision-date\":\"2025-08-05 08:50:03+0000\",\"generator\":\"GlotPress\\/4.0.1\",\"domain\":\"messages\",\"locale_data\":{\"messages\":{\"\":{\"domain\":\"messages\",\"plural-forms\":\"nplurals=1; plural=0;\",\"lang\":\"ja_JP\"},\"This contact form is placed in the wrong place.\":[\"\\u3053\\u306e\\u30b3\\u30f3\\u30bf\\u30af\\u30c8\\u30d5\\u30a9\\u30fc\\u30e0\\u306f\\u9593\\u9055\\u3063\\u305f\\u4f4d\\u7f6e\\u306b\\u7f6e\\u304b\\u308c\\u3066\\u3044\\u307e\\u3059\\u3002\"],\"Error:\":[\"\\u30a8\\u30e9\\u30fc:\"]}},\"comment\":{\"reference\":\"includes\\/js\\/index.js\"}} );\n/* ]]> */\n</script>\n<script type=\"text/javascript\" id=\"contact-form-7-js-before\">\n/* <![CDATA[ */\nvar wpcf7 = {\n    \"api\": {\n        \"root\": \"https:\\/\\/sanwanet.co.jp\\/wp-json\\/\",\n        \"namespace\": \"contact-form-7\\/v1\"\n    }\n};\n/* ]]> */\n</script>\n<script type=\"text/javascript\" src=\"https://sanwanet.co.jp/wp/wp-content/plugins/contact-form-7/includes/js/index.js?ver=6.1.1\" id=\"contact-form-7-js\"></script>\n</footer>\n\n\n\n\n<script>\n  (function() {\n    // 「投稿タイトル」を拾う関数\n    function getRecruitTitle() {\n      var title = '';\n\n      // 1) h1 から優先的に拾う（必要に応じてセレクタ追加OK）\n      var el = document.querySelector(\n        'article h1, h1.entry-title, h1.post-title, .single-title'\n      );\n      if (el && el.textContent.trim()) {\n        title = el.textContent.trim();\n      } else {\n        // 2) og:title\n        var og = document.querySelector('meta[property=\"og:title\"]');\n        if (og && og.getAttribute('content')) {\n          title = og.getAttribute('content').trim();\n        } else if (document.title) {\n          // 3) 最後の保険（document.title）\n          title = document.title.trim();\n        }\n      }\n\n      if (!title) return '';\n\n      // ★ここから「いらない部分カット」処理★\n      // 全角の「｜」で区切って、最初のブロックだけ残す\n      if (title.indexOf('｜') !== -1) {\n        title = title.split('｜')[0];\n      }\n      // 念のため半角の \"|\" にも対応\n      if (title.indexOf('|') !== -1) {\n        title = title.split('|')[0];\n      }\n\n      // 不要な前後スペースを削る\n      title = title.trim();\n\n      return title;\n    }\n\n    function ensureHidden(form, name, id) {\n      var input = form.querySelector('[name=\"' + name + '\"]');\n      if (!input) {\n        input = document.createElement('input');\n        input.type = 'hidden';\n        input.name = name; // ← [recruit_title] 等のタグ名になる\n        if (id) input.id = id;\n        form.appendChild(input);\n      }\n      return input;\n    }\n\n    function fillRecruitMeta(wrapper) {\n      if (!wrapper) return;\n      var form = wrapper.querySelector('form');\n      if (!form) return;\n\n      var title = getRecruitTitle();\n      var url = window.location.href;\n\n      var titleField = ensureHidden(form, 'recruit_title', 'recruit-title');\n      var urlField = ensureHidden(form, 'recruit_url', 'recruit-url');\n\n      titleField.value = title || '';\n      urlField.value = url || '';\n    }\n\n    // CF7 がフォームを初期化したタイミング\n    document.addEventListener('wpcf7init', function(e) {\n      var wrap = document.getElementById(e.detail.unitTag);\n      fillRecruitMeta(wrap);\n    });\n\n    // 念のため、フォームが動的に差し替わった場合も追従\n    var mo = new MutationObserver(function() {\n      document.querySelectorAll('.wpcf7').forEach(fillRecruitMeta);\n    });\n    mo.observe(document.documentElement, {\n      childList: true,\n      subtree: true,\n    });\n  })();\n</script>\n\n\n\n\n</body>\n\n</html>","finalUrl":"https://sanwanet.co.jp/recruit/recruit-4416","rendered":false,"_cachedAt":"2026-06-23T22:04:04.743Z"}