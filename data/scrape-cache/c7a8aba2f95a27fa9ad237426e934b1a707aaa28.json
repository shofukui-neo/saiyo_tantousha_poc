{"url":"https://zynas.co.jp/recruit/message/","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n<head prefix=\"og: http://ogp.me/ns# fb: http://ogp.me/ns/fb# website: http://ogp.me/ns/website#\">\n<head>\n    <!-- Google tag (gtag.js) -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-G55V1BGKK4\"></script>\n<script>\n    window.dataLayer = window.dataLayer || [];\n    function gtag(){dataLayer.push(arguments);}\n    gtag('js', new Date());\n\n    gtag('config', 'G-G55V1BGKK4');\n</script>    <!-- Google Tag Manager -->\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n})(window,document,'script','dataLayer','GTM-TLL4QPTD');</script>\n<!-- End Google Tag Manager -->\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n        <title>採用情報｜株式会社ザイナス</title>\n    <meta name=\"description\" content=\"株式会社ザイナスの採用情報サイト。新卒採用、中途採用へ向けた情報を随時掲載しています。ザイナスの文化、福利厚生や社員インタビューなどさまざまな角度からザイナスをご紹介します。\">\n    <link rel=\"canonical\" href=\"https://recruit.zynas.co.jp\">\n    <meta property=\"og:locale\" content=\"ja_JP\">\n    <meta property=\"og:type\" content=\"website\">\n    <meta property=\"og:image\" content=\"https://recruit.zynas.co.jp/ogp/ogp.png\">\n    <meta property=\"og:title\" content=\"採用情報｜株式会社ザイナス\">\n    <meta property=\"og:description\" content=\"株式会社ザイナスの採用情報サイト。新卒採用、中途採用へ向けた情報を随時掲載しています。ザイナスの文化、福利厚生や社員インタビューなどさまざまな角度からザイナスをご紹介します。\">\n    <meta property=\"og:url\" content=\"https://recruit.zynas.co.jp\">\n    <meta property=\"og:site_name\" content=\"採用情報｜株式会社ザイナス\">\n    <meta property=\"fb:app_id\" content=\"1445068859685997\">\n    <meta property=\"fb:admins\" content=\"100081903395611\">\n    <meta name=\"twitter:card\" content=\"summary_large_image\">\n    <meta name=\"twitter:site\" content=\"zynasCorp\">\n\n    <!-- 電話番号自動リンク化解除 -->\n    <meta name=\"format-detection\" content=\"telephone=no\">\n\n    <!-- Favicon -->\n    <link rel=\"icon\" type=\"image/x-icon\" href=\"https://recruit.zynas.co.jp/favicon/favicon.ico\">\n    <link rel=\"apple-touch-icon\" href=\"https://recruit.zynas.co.jp/favicon/apple-touch-icon.png\">\n\n    <!-- Font -->\n    <script>\n        (function(d) {\n            var config = {\n                kitId: 'mqa6mvk',\n                scriptTimeout: 3000,\n                async: true\n            },\n            h=d.documentElement,t=setTimeout(function(){h.className=h.className.replace(/\\bwf-loading\\b/g,\"\")+\" wf-inactive\";},config.scriptTimeout),tk=d.createElement(\"script\"),f=false,s=d.getElementsByTagName(\"script\")[0],a;h.className+=\" wf-loading\";tk.src='https://use.typekit.net/'+config.kitId+'.js';tk.async=true;tk.onload=tk.onreadystatechange=function(){a=this.readyState;if(f||a&&a!=\"complete\"&&a!=\"loaded\")return;f=true;clearTimeout(t);try{Typekit.load(config)}catch(e){}};s.parentNode.insertBefore(tk,s)\n        })(document);\n    </script>\n\n    <!-- CSS -->\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"./css/reset.css\">\n            <link rel=\"stylesheet\" type=\"text/css\" href=\"https://cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick-theme.min.css\">\n        <link rel=\"stylesheet\" type=\"text/css\" href=\"https://cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick.min.css\">\n        <link rel=\"stylesheet\" type=\"text/css\" href=\"./css/common.css\">\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"./css/global-joinUs.css\">\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"./css/global-header.css\">\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"./css/global-footer.css\">\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"./css/index.css\">\n</head>\n<body>\n    <!-- Google Tag Manager -->\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n})(window,document,'script','dataLayer','GTM-TLL4QPTD');</script>\n<!-- End Google Tag Manager -->    <header id=\"header\">\n    \n    <h1 id=\"headerLogo\"><a href=\"./\"><img src=\"./img/logo/logo-zynas.svg\" alt=\"Zynas Recruit Site\"></a></h1>\n\n    <div id=\"headerNavMenu\">\n        <nav id=\"headerNavMenu--global\">\n            <h1>採用サイトコンテンツ</h1>\n            <ul>\n                <li><a href=\"./\">ホーム<span aria-hidden=\"true\">HOME</span></a></li>\n                <li><a href=\"./culture\">カルチャー<span aria-hidden=\"true\">CULTURE</span></a></li>\n                <li><a href=\"./workers\">働く人<span aria-hidden=\"true\">PERSON</span></a></li>\n                <li><a href=\"./environment\">働く環境<span aria-hidden=\"true\">WORK STYLE</span></a></li>\n                <li><a href=\"./data\">数字で見るザイナス<span aria-hidden=\"true\">DATA</span></a></li>\n                <li><a href=\"./faq\">よくある質問<span aria-hidden=\"true\">Q&A</span></a></li>\n            </ul>\n        </nav>\n\n        <nav id=\"headerNavMenu--banner\">\n            <h1>関連バナー</h1>\n            <ul>\n                <li><a href=\"https://note.com/zynas/m/m729c646de512\" target=\"_blank\" rel=\"noopener noreferrer\"><img src=\"./img/common/header/header-banner--01.jpg\" alt=\"note インタビュー記事一覧\"></a></li>\n                <li><a href=\"https://note.com/zynas/m/m13b3151ba6fb\" target=\"_blank\" rel=\"noopener noreferrer\"><img src=\"./img/common/header/header-banner--02.jpg\" alt=\"note 25卒・26卒 採用向けマガジン\"></a></li>\n            </ul>\n        </nav>\n\n        <nav id=\"headerNavMenu--sns\">\n            <h1>FOLLOW US!</h1>\n            <ul>\n                <li><a class=\"note\" href=\"https://note.com/zynas/\" target=\"_blank\" rel=\"noopener noreferrer\" aria-label=\"noteのリンク\"></a></li>\n                <li><a class=\"x\" href=\"https://twitter.com/zynasCorp\" target=\"_blank\" rel=\"noopener noreferrer\" aria-label=\"Xのリンク\"></a></li>\n                <li><a class=\"instagram\" href=\"https://www.instagram.com/zynas_corp\" target=\"_blank\" rel=\"noopener noreferrer\" aria-label=\"Instagramのリンク\"></a></li>\n                <li><a class=\"facebook\" href=\"https://www.facebook.com/zynas.inc\" target=\"_blank\" rel=\"noopener noreferrer\" aria-label=\"Facebookのリンク\"></a></li>\n            </ul>\n        </nav>\n    </div>\n\n    <div id=\"headerEntry\">\n        <button id=\"headerEntryBtn\" aria-label=\"募集要項・エントリーメニューボタン\">募集要項・エントリー</button>\n        <nav id=\"headerEntryMenu\">\n            <h1>募集要項・エントリー</h1>\n            <ul>\n                <li><a href=\"https://open.talentio.com/r/1/c/zynas/homes/3087\" target=\"_blank\" rel=\"noopener noreferrer\">中途採用</a></li>\n                <!-- <li><a href=\"https://job.rikunabi.com/2025/company/r450110032/\" target=\"_blank\" rel=\"noopener noreferrer\">新卒採用（25卒）</a></li> -->\n                <!-- <li><a href=\"https://job.mynavi.jp/26/pc/search/corp244872/outline.html\" target=\"_blank\" rel=\"noopener noreferrer\">新卒採用（26卒）</a></li> -->\n                 <li><a href=\"https://job.mynavi.jp/27/pc/search/corp244872/outline.html\" target=\"_blank\" rel=\"noopener noreferrer\">新卒採用（27卒）</a></li>\n                <li><a href=\"https://zynas.co.jp/recruit-contact\" target=\"_blank\" rel=\"noopener noreferrer\">カジュアル面談・<br>採用お問い合わせ</a></li>\n            </ul>\n        </nav>\n    </div>\n\n    <button id=\"headerNavBtn\" aria-label=\"メニューボタン\"></button>\n\n</header>\n\n    <main id=\"main\">\n\n\n        <section id=\"firstview\">\n            <hgroup class=\"fv-header js-fadeIn\">\n                <h1>\n                    <picture>\n                        <source srcset=\"./img/page-top/firstview/top-firstview-heading--sp.svg\" media=\"(max-width: 767px)\">\n                        <source srcset=\"./img/page-top/firstview/top-firstview-heading--tab.svg\" media=\"(max-width: 1079px)\">\n                        <img src=\"./img/page-top/firstview/top-firstview-heading--pc.svg\" alt=\"「明日」の話をしよう\">\n                    </picture>\n                </h1>\n                <div><span>TOMORROW&nbsp;</span><span>will be&nbsp;</span><br>\n                    <span>A&nbsp;</span><span>BETTER&nbsp;</span><span>DAY</span>\n                </div>\n            </hgroup>\n            <div class=\"fv-slider js-fadeIn\">\n                <div class=\"fv-slide\"><img src=\"./img/page-top/firstview/top-firstview-slide--01.png\" alt=\"\"></div>\n                <div class=\"fv-slide\"><img src=\"./img/page-top/firstview/top-firstview-slide--02.png\" alt=\"\"></div>\n                <div class=\"fv-slide\"><img src=\"./img/page-top/firstview/top-firstview-slide--03.png\" alt=\"\"></div>\n                <div class=\"fv-slide\"><img src=\"./img/page-top/firstview/top-firstview-slide--04.png\" alt=\"\"></div>\n                <div class=\"fv-slide\"><img src=\"./img/page-top/firstview/top-firstview-slide--05.png\" alt=\"\"></div>\n                <div class=\"fv-slide\"><img src=\"./img/page-top/firstview/top-firstview-slide--01.png\" alt=\"\"></div>\n                <div class=\"fv-slide\"><img src=\"./img/page-top/firstview/top-firstview-slide--02.png\" alt=\"\"></div>\n                <div class=\"fv-slide\"><img src=\"./img/page-top/firstview/top-firstview-slide--03.png\" alt=\"\"></div>\n                <div class=\"fv-slide\"><img src=\"./img/page-top/firstview/top-firstview-slide--04.png\" alt=\"\"></div>\n                <div class=\"fv-slide\"><img src=\"./img/page-top/firstview/top-firstview-slide--05.png\" alt=\"\"></div>\n            </div>\n        </section>\n        <!-- / #firstview -->\n\n\n        <section id=\"introduction\">\n            <div class=\"wrapper js-fadeUp\">\n                <h2 class=\"heading\">INTRODUCTION</h2>\n                <div class=\"content\">\n                    <p class=\"lead\">\n                        はじめまして。ザイナスです。<br>\n                        数ある企業の中から、私たちを見つけてくださりありがとうございます。<br>\n                        唐突ですが、皆さんの描く「明日」はどんな未来ですか？仕事は生活の中にあり、<br>\n                        「明日」をつくる大きな材料です。<br>\n                        <br>\n                        「お客様と話しながら素敵な企画をたてたい」<br>\n                        「コードの腕を磨いておもしろいシステムを作りたい」<br>\n                        「全力で働きながら家庭も大事にしたい」<br>\n                        <br>\n                        一人ひとり形は違っても、それぞれが描く「明日」をしっかり持っていて欲しい。<br>\n                        そして私たちは、皆さんのその想いを一緒に実現していきたいと思っています。<br>\n                        ザイナスには社員の数だけ道があります。<br>\n                        <br>\n                        あなたの描く「明日」を教えてください。\n                    </p>\n                    <a class=\"permalink\" href=\"./culture\">ザイナスのカルチャーを見る</a>\n                </div>\n            </div>\n        </section>\n        <!-- / #introduction -->\n\n\n        <section id=\"person\">\n            <div class=\"wrapper\">\n\n                <div id=\"personContainer-01\">\n                    <div class=\"section-content js-fadeUp\">\n                        <hgroup class=\"heading\">\n                            <h2 class=\"heading__ja\">働く人</h2>\n                            <p class=\"heading__en\">PERSON</p>\n                        </hgroup>\n                        <p class=\"lead\">ザイナスには様々な想いを持った社員が働いています。<br>なぜザイナスを選んだのか、どんなことをしているのか、<br>社員が描く様々な「明日」を紹介します。</p>\n                        <a class=\"permalink\" href=\"./workers\">ザイナスの働く人一覧を見る</a>\n                    </div>\n                    <a class=\"person js-fadeUp\" href=\"https://note.com/zynas/n/n09c8343d5854\" target=\"_blank\" rel=\"noopener noreferrer\">\n                        <div class=\"thumbnail\"><img src=\"./img/page-top/person/person-thumbnail--01.png\" alt=\"I・Mさんの写真\"></div>\n                        <div class=\"content\">\n                            <p class=\"lead\"><span>教わる「後輩」から伝える「先輩」へ。</span><span>技術を磨いて、はたらく</span></p>\n                            <p class=\"career\">熊本学園大学卒 2023年入社</p>\n                            <p class=\"tag\">#受託開発 #Smart Dorm #早期選考 #文系</p>\n                        </div>\n                    </a>\n                </div>\n\n                <div id=\"personContainer-02\">\n                    <a class=\"person js-fadeUp\" href=\"https://note.com/zynas/n/n26a5ccba3e15\" target=\"_blank\" rel=\"noopener noreferrer\">\n                        <div class=\"thumbnail\"><img src=\"./img/page-top/person/person-thumbnail--02.png\" alt=\"I・Fさんの写真\"></div>\n                        <div class=\"content\">\n                            <p class=\"lead\"><span>システムを学ぶ、つくる。</span><span>変わらない思いとともに、はたらく</span></p>\n                            <p class=\"career\">I・F 大分工業高等専門学校卒 2024年入社</p>\n                            <p class=\"tag\">#保守 #受託開発 #システム #習慣化</p>\n                        </div>\n                    </a>\n                    <a class=\"person js-fadeUp\" href=\"https://note.com/zynas/n/nd2baf6d70119\" target=\"_blank\" rel=\"noopener noreferrer\">\n                        <div class=\"thumbnail\"><img src=\"./img/page-top/person/person-thumbnail--03.png\" alt=\"K・Rさんの写真\"></div>\n                        <div class=\"content\">\n                            <p class=\"lead\"><span>社会貢献×地元×IT</span><span>社会や人への思いを胸に、はたらく</span></p>\n                            <p class=\"career\">K・R 九州大学 2023年入社</p>\n                            <p class=\"tag\">#プログラマ #研究 #インフラ #EDiSON</p>\n                        </div>\n                    </a>\n                    <a class=\"person js-fadeUp\" href=\"https://note.com/zynas/n/nb0fec9bbf613\" target=\"_blank\" rel=\"noopener noreferrer\">\n                        <div class=\"thumbnail\"><img src=\"./img/page-top/person/person-thumbnail--04.png\" alt=\"K・Sさんの写真\"></div>\n                        <div class=\"content\">\n                            <p class=\"lead\"><span>「やりたいと思える仕事」を</span><span>ひたむきに追求して、はたらく</span></p>\n                            <p class=\"career\">K・S 兵庫県立大学卒 2023年入社</p>\n                            <p class=\"tag\">#AWS #資格取得 #東京 #第二新卒</p>\n                        </div>\n                    </a>\n                    <a class=\"person js-fadeUp\" href=\"https://note.com/zynas/n/n38b6cd33a678\" target=\"_blank\" rel=\"noopener noreferrer\">\n                        <div class=\"thumbnail\"><img src=\"./img/page-top/person/person-thumbnail--05.png\" alt=\"A・Kさんの写真\"></div>\n                        <div class=\"content\">\n                            <p class=\"lead\"><span>能動的に動く、磨く、描く。</span><span>この先も大分で挑戦しながら、はたらく</span></p>\n                            <p class=\"career\">A・K 九州大学卒 2022年入社</p>\n                            <p class=\"tag\">#エンジニア #SAP #Zynas AppHaus Oita #Uターン</p>\n                        </div>\n                    </a>\n                    <a class=\"person js-fadeUp\" href=\"https://note.com/zynas/n/n938afb15be6e\" target=\"_blank\" rel=\"noopener noreferrer\">\n                        <div class=\"thumbnail\"><img src=\"./img/page-top/person/person-thumbnail--06.png\" alt=\"M・Kさんの写真\"></div>\n                        <div class=\"content\">\n                            <p class=\"lead\"><span>ITの世界で日々研鑽。</span><span>可能性を超えるために、はたらく</span></p>\n                            <p class=\"career\">M・K 大分県立大分商業高等学校 2023年入社</p>\n                            <p class=\"tag\">#セキュリティ #SES #ワークライフバランス #転職</p>\n                        </div>\n                    </a>\n                </div>\n\n            </div>\n        </section>\n        <!-- / #person -->\n\n\n        <section id=\"workstyle\">\n            <div class=\"wrapper\">\n                <div id=\"workstyleContainer-01\" class=\"js-fadeUp\">\n                    <div class=\"section-content\">\n                        <hgroup class=\"heading\">\n                            <h2 class=\"heading__ja\">働く環境</h2>\n                            <p class=\"heading__en\">WORK STYLE</p>\n                        </hgroup>\n                        <p class=\"lead\">ザイナスでは、社員全員が安心して働くことができるように、様々な環境づくりに取り組んでいます。誰もが自分らしく、能力を発揮できる職場を目指し、日々アップデートしています。</p>\n                    </div>\n                    <a class=\"viewmore\" href=\"./environment#benefits\">\n                        <img class=\"symbol\" src=\"./img/page-top/workstyle/top-workstyle-symbol--benefits.svg\" alt=\"\">\n                        <p class=\"title\">福利厚生</p>\n                        <p class=\"label\">VIEW MORE</p>\n                    </a>\n                    <a class=\"viewmore\" href=\"./environment#training\">\n                        <img class=\"symbol\" src=\"./img/page-top/workstyle/top-workstyle-symbol--training.svg\" alt=\"\">\n                        <p class=\"title\">研修制度</p>\n                        <p class=\"label\">VIEW MORE</p>\n                    </a>\n                    <a class=\"viewmore\" href=\"./environment#event\">\n                        <img class=\"symbol\" src=\"./img/page-top/workstyle/top-workstyle-symbol--event.svg\" alt=\"\">\n                        <p class=\"title\">社内行事</p>\n                        <p class=\"label\">VIEW MORE</p>\n                    </a>\n                </div>\n                <div id=\"workstyleContainer-02\" class=\"js-fadeUp\">\n                    <picture>\n                        <source srcset=\"./img/page-top/workstyle/workstyle-thumbnail--sp.png\" media=\"(max-width: 767px)\">\n                        <img src=\"./img/page-top/workstyle/workstyle-thumbnail--pc.png\" alt=\"\">\n                    </picture>\n                </div>\n            </div>\n        </section>\n        <!-- #workstyle -->\n\n\n        <section id=\"data\">\n            <div class=\"wrapper\">\n                <div class=\"thumbnail js-fadeUp\"><img src=\"./img/page-top/data/data-thumbnail.png\" alt=\"\"></div>\n                <div class=\"section-content js-fadeUp\">\n                    <hgroup class=\"heading\">\n                        <h2 class=\"heading__ja\">数字で見るザイナス</h2>\n                        <p class=\"heading__en\">DATA</p>\n                    </hgroup>\n                    <p class=\"lead\">「雰囲気はなんとなくわかったけど、実際は…!?」そんな方のために、ありのままのザイナスをデータで表しお伝えします。</p>\n                    <a class=\"permalink\" href=\"./data\">ザイナスを数字で見る</a>\n                </div>\n            </div>\n        </section>\n        <!-- / #data -->\n\n\n        <section id=\"faq\">\n            <div class=\"wrapper js-fadeUp\">\n                <hgroup class=\"heading\">\n                    <h2 class=\"heading__ja\">よくある質問</h2>\n                    <p class=\"heading__en\">Q&A</p>\n                </hgroup>\n                <p class=\"lead\">皆さんからよくいただく質問を集めました。人事担当者がお答えしています。<br>今ある不安を、少しでもとり除いていただけたら嬉しいです。</p>\n                <a class=\"permalink\" href=\"./faq\">VIEW MORE</a>\n            </div>\n        </section>\n        <!-- / #faq -->\n\n\n        <section id=\"magazine\">\n            <div class=\"wrapper\">\n                <div class=\"section-content js-fadeUp\">\n                    <hgroup class=\"heading\">\n                        <h2 class=\"heading__ja\">もっと知りたい、ザイナスのこと</h2>\n                        <p class=\"heading__en\">MAGAZINE</p>\n                    </hgroup>\n                    <p class=\"lead\">ザイナス公式noteでは、よりリアルな業務内容や雰囲気を知っていただける記事を更新しています。</p>\n                </div>\n                <div class=\"magazine-content js-fadeUp\">\n                    <a class=\"item\" href=\"https://note.com/zynas/m/m729c646de512\" target=\"_blank\" rel=\"noopener noreferrer\">\n                        <div class=\"item__thumbnail\"><img src=\"./img/page-top/magazine/magazine-thumbnail--interview.png\" alt=\"\"></div>\n                        <h3 class=\"item__heading\">社員インタビュー記事</h3>\n                        <p class=\"item__lead\">社員の仕事や会社に対する想いを綴っています。</p>\n                    </a>\n                    <a class=\"item\" href=\"https://note.com/zynas/m/m13b3151ba6fb\" target=\"_blank\" rel=\"noopener noreferrer\">\n                        <div class=\"item__thumbnail\"><img src=\"./img/page-top/magazine/magazine-thumbnail--magazine.png\" alt=\"\"></div>\n                        <h3 class=\"item__heading\">採用向けマガジン</h3>\n                        <p class=\"item__lead\">「これを読めばザイナスの基本がわかる！」という記事を集めました。</p>\n                    </a>\n                </div>\n            </div>\n        </section>\n        <!-- / #magazine -->\n\n\n        <section id=\"joinUs\">\n    <img class=\"thumbnail\" src=\"./img/common/img-common-join-us-thumbnail.png\" alt=\"\">\n    <div class=\"content\">\n        <h1>JOIN US</h1>\n        <p>きかせて、「明日」のこと</p>\n        <a href=\"https://zynas.co.jp/recruit-contact\" target=\"_blank\" rel=\"noopener noreferrer\">カジュアル面談に応募する</a>\n    </div>\n</section>\n\n    </main>\n\n\n    <!-- global-footer -->\n    <footer id=\"footer\">\n    <div id=\"footerInner\">\n\n        <h1 id=\"footerTop\">\n            <a class=\"home-link\" href=\"./\"><img class=\"logo\" src=\"./img/logo/logo-zynas.svg\" alt=\"Zynas Recruit Site\"></a>\n        </h1>\n\n        <div id=\"footerMiddle\">\n\n            <div id=\"footerMiddle-left\">\n                <ul id=\"footerList-office\">\n                    <li>\n                        <p class=\"office--name\">大分本社</p>\n                        <address class=\"office--content\">\n                            <p class=\"address\">\n                                〒870-0839<br>\n                                大分市金池南1丁目5番1号 コレジオ大分 5階\n                            </p>\n                            <a class=\"googlemaps\" href=\"https://maps.app.goo.gl/J9sYdSpQtp72BwLg7\" target=\"_blank\" rel=\"noopener noreferrer\">Google maps</a>\n                            <p class=\"tel\">TEL&nbsp;：&nbsp;097-547-8639</p>\n                            <p class=\"fax\">FAX&nbsp;：&nbsp;097-547-8619</p>\n                        </address>\n                    </li>\n             