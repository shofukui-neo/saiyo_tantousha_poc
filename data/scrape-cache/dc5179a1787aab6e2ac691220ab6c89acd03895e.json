.12.2/ScrollTrigger.min.js?ver=3.12.2\" id=\"scroll-trigger-js\"></script> </head><body class=\"wp-singular page-template-default page page-id-9 wp-theme-yamauchi-doboku company\" ontouchstart=\"\"><div class=\"side_cta\"> <a class=\"side_cta_btn side_cta_youtube\" href=\"https://www.youtube.com/@yamauchidoboku\" target=\"_blank\" rel=\"noopener noreferrer\"> 公式YouTube </a> <a class=\"side_cta_btn side_cta_contact\" href=\"https://yamauchi-doboku.jp/contact/\"> お問い合わせ </a></div><div id=\"page\" class=\"site\"><header id=\"masthead\" class=\"site-header\" role=\"banner\"><div class=\"site-header-main\"><div class=\"site-branding\"><p class=\"site-title link\"> <a class=\"site-branding_logo\" href=\"https://yamauchi-doboku.jp/\" rel=\"home\"> <picture> <source srcset=\"https://yamauchi-doboku.jp/wp-content/themes/yamauchi-doboku/assets/images/header_logo.svg\" media=\"(max-width:768px)\"> <img src=\"https://yamauchi-doboku.jp/wp-content/themes/yamauchi-doboku/assets/images/header_logo.svg\" alt=\"ヘッダーロゴ\"> </picture> </a></p></div><nav id=\"nav\" class=\"navigation\"><ul class=\"navigation_link\"><li class=\"navigation_link_item\"><a href=\"https://yamauchi-doboku.jp/company/\"><span>企業情報</span></a></li><li class=\"navigation_link_item\"><a href=\"https://yamauchi-doboku.jp/business/\"><span>事業内容</span></a></li><li class=\"navigation_link_item\"><a href=\"https://yamauchi-doboku.jp/works/\"><span>実績</span></a></li><li class=\"navigation_link_item\"><a href=\"https://yamauchi-doboku.jp/recruit/\"><span>採用情報</span></a></li><li class=\"navigation_link_item\"><a href=\"https://yamauchi-doboku.jp/anniv100th/\"><span>100年をつなぐ</span></a></li></ul></nav><div id=\"drawer_toggle\" class=\"smt_menu\"> <span></span> <span></span> <span></span></div><div class=\"smt_menu_box\"><ul class=\"smt_menu_link\"><li class=\"site-map_item\"><a href=\"https://yamauchi-doboku.jp/company/\">企業情報</a></li><li class=\"site-map_item\"><a href=\"https://yamauchi-doboku.jp/business/\">事業内容</a></li><li class=\"site-map_item\"><a href=\"https://yamauchi-doboku.jp/works/\">実績</a></li><li class=\"site-map_item\"><a href=\"https://yamauchi-doboku.jp/recruit/\">採用情報</a></li><li class=\"site-map_item\"><a href=\"https://yamauchi-doboku.jp/anniv100th/\">100年をつなぐ</a></li></ul><div class=\"smt_box_footer\"> <img src=\"https://yamauchi-doboku.jp/wp-content/themes/yamauchi-doboku/assets/images/100thanniv_logo.png\" alt=\"100周年ロゴ\"></div></div></div></header><div class=\"site-inner\"><div id=\"content\" class=\"site-content\"><div id=\"primary\" class=\"content-area\"><main id=\"main\" class=\"site-main\" role=\"main\"><div class=\"page_content company_content\"><div class=\"page_kv\"><h1 class=\"page_headline eng fadeIn\"> COMPANY<div class=\"line-canvas-container\" aria-hidden=\"true\"></div></h1><div class=\"breadcrumb\"><a href=\"https://yamauchi-doboku.jp/\">TOP</a> ／ 企業情報</div></div><section><div class=\"section section01\"><div class=\"section_wrapper\"><div class=\"greetings\"><h1> <span>代表メッセージ</span> <span class=\"eng\">Greetings</span></h1><div class=\"box\"><div class=\"box_item\"> <picture class=\"fadeIn\"> <source srcset=\"https://yamauchi-doboku.jp/wp-content/themes/yamauchi-doboku/assets/images/company_president.jpg\" media=\"(max-width:768px)\" /> <img src=\"https://yamauchi-doboku.jp/wp-content/themes/yamauchi-doboku/assets/images/company_president.jpg\" alt=\"代表取締役社長の写真\" /> </picture></div><div class=\"box_item\"><h2> 地域に根ざし、次の世代へ</h2><p class=\"greetings_text\"> 弊社は本州最北端に位置する下北半島で大正14年に創業以来、「いいものを、人に、地域に」をスローガンにこの地域社会の発展及び地域皆さまの安全と快適な生活を支えて参りました。<br /> 近年頻発する自然災害は脅威でありますが、下北半島の緑豊かな山々と四方を海で囲まれた自然環境の中で、自然（環境）と人との調和を図ることと、次の世代の人たちが成長するための機会を提供することは、これからの豊かな社会環境を創造するために重要な役割の一つであると考えています。<br /> 今後もこの地域に根ざした100年の実績と技術の研鑽に励み、地域の皆さまに信頼され、期待に応えられる会社を目指し、一つひとつの仕事に全力で取り組んでまいりますので、これからも変わらぬご愛顧を賜りますようよろしくお願い申し上げます。</p><p class=\"signature\"> <span>代表取締役社長</span> <img src=\"https://yamauchi-doboku.jp/wp-content/themes/yamauchi-doboku/assets/images/y_sign.png\" alt=\"山内 将邦\" /></p></div></div></div><div class=\"managerial\"><h1> <span>経営方針</span> <span class=\"eng\">Managerial Policy</span></h1><div class=\"box\"><div class=\"box_item pc_only\"> <picture class=\"fadeIn\"> <source srcset=\"https://yamauchi-doboku.jp/wp-content/themes/yamauchi-doboku/assets/images/rinen_title.png\" media=\"(max-width:768px)\" /> <img src=\"https://yamauchi-doboku.jp/wp-content/themes/yamauchi-doboku/assets/images/rinen_title.png\" alt=\"企業理念タイトルとロゴ\" /> </picture></div><div class=\"box_item pc_only\"> <picture class=\"fadeIn\"> <source srcset=\"https://yamauchi-doboku.jp/wp-content/themes/yamauchi-doboku/assets/images/rinen_text.png\" media=\"(max-width:768px)\" /> <img src=\"https://yamauchi-doboku.jp/wp-content/themes/yamauchi-doboku/assets/images/rinen_text.png\" alt=\"企業理念テキスト\" /> </picture></div><div class=\"box_item pc_only\"> <picture class=\"fadeIn\"> <source srcset=\"https://yamauchi-doboku.jp/wp-content/themes/yamauchi-doboku/assets/images/rinen_layout.png\" media=\"(max-width:768px)\" /> <img src=\"https://yamauchi-doboku.jp/wp-content/themes/yamauchi-doboku/assets/images/rinen_layout.png\" alt=\"「いいものを、人に、地域に」\" /> </picture></div><div class=\"box_item md_only\"> <picture class=\"fadeIn\"> <source srcset=\"https://yamauchi-doboku.jp/wp-content/themes/yamauchi-doboku/assets/images/sp_renen_layout1.jpg\" media=\"(max-width:768px)\" /> <img src=\"https://yamauchi-doboku.jp/wp-content/themes/yamauchi-doboku/assets/images/sp_renen_layout1.jpg\" alt=\"企業理念タイトルとロゴとテキスト\" /> </picture></div><div class=\"box_item md_only\"> <picture class=\"fadeIn\"> <source srcset=\"https://yamauchi-doboku.jp/wp-content/themes/yamauchi-doboku/assets/images/sp_renen_layout2.jpg?20260213_02\" media=\"(max-width:768px)\" /> <img src=\"https://yamauchi-doboku.jp/wp-content/themes/yamauchi-doboku/assets/images/sp_renen_layout2.jpg\" alt=\"使命\" /> </picture></div><div class=\"box_item md_only\"> <picture class=\"fadeIn\"> <source srcset=\"https://yamauchi-doboku