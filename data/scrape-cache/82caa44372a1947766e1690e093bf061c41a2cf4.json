', new Date());\n  gtag('config', 'UA-2097811-1');\n  gtag('config', 'G-0BNP76Q4Q7');\n</script>\n</head>\n\n<body>\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=AW-734422123\"></script> \n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n  gtag('config', 'AW-734422123');\n</script>\n<div class=\"openbtn\"><span></span><span></span><span></span></div>\n<nav id=\"g-nav\">\n        <div id=\"g-nav-list\">\n                <ul>\n                        <li><a href=\"../index.html#01_business\" title=\"事業を知る\">事業を知る</a></li>\n                        <li><a href=\"../index.html#02_member\" title=\"職種と人を知る\">職種と人を知る</a></li>\n                        <li><a href=\"../index.html#03_workspace\" title=\"環境・待遇を知る\">環境・待遇を知る</a></li>\n                        <li><a href=\"../index.html#04_information\" title=\"新卒採用\">新卒採用</a></li>\n                        <li><a href=\"../index.html#04_information\" title=\"キャリア採用\">キャリア採用</a></li>\n                </ul>\n        </div>\n</nav>\n<nav class=\"pc\">\n        <div class=\"inner\">\n                <div class=\"logo\"><a href=\"../index.html\"><img src=\"../images/index/logo.svg\" alt=\"ソリマチ株式会社採用情報\"></a></div>\n                <div class=\"area\">\n                        <ul>\n                                <li><a href=\"service.html\" title=\"事業を知る\" class=\"select\">事業を知る</a></li>\n                                <li><a href=\"../member/movie.html\" title=\"職種と人を知る\">職種と人を知る</a></li>\n                                <li><a href=\"../workspace/office.html\" title=\"環境・待遇を知る\">環境・待遇を知る</a></li>\n                                <li><a href=\"../recruit/newgraduate.html\" title=\"新卒採用\">新卒採用</a></li>\n                                <li><a href=\"../recruit/career.html\" title=\"キャリア採用\">キャリア採用</a></li>\n                        </ul>\n                </div>\n        </div>\n</nav>\n<div id=\"contents\">\n        <div class=\"inner\">\n                <div class=\"side side--sticky\">\n                        <h1>事業を知る</h1>\n                        <ul>\n                                <li><a href=\"service.html\" title=\"01 ソリマチ製品の紹介\">01 ソリマチ製品の紹介</a></li>\n                                <li><a href=\"industry.html\" title=\"02 会計ソフト業界を知る\">02 会計ソフト業界を知る</a></li>\n                                <li><a href=\"message.html\" title=\"03 社長からメッセージ\">03 社長からメッセージ</a></li>\n                                <li><a href=\"sorimachi_group.html\" title=\"04 ソリマチテックグループの紹介\">04 ソリマチテックグループの紹介</a></li>\n                                <li><a href=\"family.html\" title=\"05 ご家族の皆様へ\" class=\"select\">05 ご家族の皆様へ</a></li>\n                        </ul>\n                </div>\n                <div class=\"area\">\n                        <h1>for Family</h1>\n                        <h2><span>05</span>ご家族の皆様へ</h2>\n                        <p>ソリマチ株式会社に興味を持ってくださったご家族の皆様へ。毎日を快く安心して見守っていただくために、ご家族様に向けたメッセージページをご用意しました。</p>\n                        <h3>ワークライフバランス</h3>\n                        <p>社員が気持ちよく働けるように、ワークライフバランスを大事にしています。</p>\n                        <div class=\"point_wrap marB30\">\n                                <div class=\"point\">\n                                        <h4><span class=\"point_tle\">POINT.01</span>平均残業時間</h4>\n                                        <img src=\"../images/business/img_13.png\" alt=\"\" width=\"120\" class=\"img_cent marB20\"/>\n                                        <p>生産性向上を行い徹底的に残業時間を削減。ONとOFFをきちんと切り替えることで、業務に集中して取り組むことができます。</p>\n                                </div>\n                                <div class=\"point\">\n                                        <h4><span class=\"point_tle\">POINT.02</span>年間休日日数</h4>\n                                        <img src=\"../images/business/img_14.png\" alt=\"\" width=\"120\" class=\"img_cent marB20\"/>\n                                        <p>完全週休二日制を採用しています。土日と祝日はご自身の時間をゆっくり過ごせます。</p>\n                                </div>\n                                <div class=\"point\">\n                                        <h4><span class=\"point_tle\">POINT.03</span>有給消化率</h4>\n                                        <img src=\"../images/business/img_18.png\" alt=\"\" width=\"120\" class=\"img_cent marB20\"/>\n                                        <p>通常の有給休暇に加えて特別休暇を支給しています。どの部署も休みの取りやすい雰囲気です。</p>\n                                </div>\n                        </div>\n                        <h3 class=\"heading04\">ご家族の皆様の疑問にお答えします！</h3>\n                        <img src=\"../images/business/img_12.png\" alt=\"\" class=\"img_kadoR marB30\" width=\"700px\">\n                        <dl class=\"qa\">\n                                <dt>入社後の研修制度は？</dt>\n                                <dd>製品・サービスの使い方から資料作り、社内システム、電話対応まで先輩社員が丁寧にレクチャーします。</dd>\n                                <dt>職場の雰囲気は？</dt>\n                                <dd>ワンフロアなので職種や役職に関係なく日頃から話しやすい雰囲気です。テレワークと出社を混ぜたハイブリッド勤務とフリーアドレスにより、自分に合った働き方を実現しています。</dd>\n                                <dt>会社の安定性は？</dt>\n                                <dd>ソリマチテックグループの自己資本は174億円、自己資本比率は91%と大手に負けない経営を続けています。</dd>\n                                <dt>転勤はありますか？</dt>\n                                <dd>基本的にはありません。長く働いてもらいたいからこそ、入社前に勤務地の希望をヒアリングして配属を決定し、入社後の転勤も発生しないように努めています。</dd>\n                                <dt>プライベートの時間は取れますか？</dt>\n                                <dd>土日祝日がお休みで、夜間・早朝作業はありません。年末年始や長期休暇も取得しやすい環境のため、自身の時間は十分に確保できます。 </dd>\n                        </dl>\n                        <ol class=\"pagination\">\n                                <li><a href=\"service.html\">1</a></li>\n                                <li><a href=\"industry.html\">2</a></li>\n                                <li><a href=\"message.html\">3</a></li>\n                                <li><a href=\"sorimachi_group.html\">4</a></li>\n                                <li class=\"current\"><a href=\"family.html\">5</a></li>\n                                <li class=\"next\"><a href=\"../member/movie.html\">></a></li>\n                        </ol>\n                </div>\n        </div>\n</div>\n<footer>\n        <div class=\"inner\"> &copy; Copyright Sorimachi Co.,Ltd. All rights reserved. </div>\n</footer>\n<div class=\"pagetop\"><a href=\"#\">▲</a></div>\n</body>\n</html>","finalUrl":"https://sorimachi.co.jp/about/recruit/business/family.html","rendered":false,"_cachedAt":"2026-06-23T23:07:08.766Z"}