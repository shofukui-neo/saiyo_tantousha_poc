ofollow\">ENTRY</a></li>\r\n              <li><a class=\"mypage\" href=\"https://axol.jp/zw/s/token_28/mypage/\" target=\"_blank\" rel=\"nofollow\">MY PAGE</a></li>\r\n              <li><a href=\"https://job.mynavi.jp/28/pc/search/corp54375/outline.html\" target=\"_blank\" rel=\"nofollow\"><img src=\"/recruit/image_cmn/btn-mynavi2028.jpg\" alt=\"マイナビ2028\"></a></li>\r\n              <li><a href=\"https://job.rikunabi.com/job_search/?kw=%E6%9D%B1%E5%BB%BA%E3%82%B3%E3%83%BC%E3%83%9D%E3%83%AC%E3%83%BC%E3%82%B7%E3%83%A7%E3%83%B3\" target=\"_blank\" rel=\"nofollow\"><img src=\"/recruit/image_cmn/btn-recnavi2028.jpg\" alt=\"リクナビ2028\"></a></li>\r\n            </ul>\r\n          </section>\r\n          <section class=\"career\">\r\n            <h4>中途採用</h4>\r\n            <ul class=\"button_list\">\r\n              <li><a class=\"entry\" href=\"/recruit/entry/?id=01\">ENTRY</a></li>\r\n            </ul>\r\n          </section>\r\n        </section>\r\n        <ul class=\"sp_sns\">\r\n          <li><a href=\"https://www.facebook.com/token.corp\" target=\"_blank\"><img src=\"/recruit/image_cmn/icon-facebook-n.svg\" alt=\"facebook\"></a></li>\r\n          <li><a href=\"https://twitter.com/tokencorp\" target=\"_blank\"><img src=\"/recruit/image_cmn/icon-x-n.svg\" alt=\"x\"></a></li>\r\n          <li><a href=\"https://www.youtube.com/user/tokentelevision\" target=\"_blank\"><img src=\"/recruit/image_cmn/icon-youtube-n.svg\" alt=\"youtube\"></a></li>\r\n          <li><a href=\"https://www.instagram.com/token.corp_official/\" target=\"_blank\"><img src=\"/recruit/image_cmn/icon-instagram-n.svg\" alt=\"Instagram\"></a></li>\r\n          <!--<li><a href=\"\"><img src=\"/recruit/image_cmn/icon-tiktok-n.png\" alt=\"Tiktok\"></a></li>-->\r\n        </ul>\r\n      </section>\r\n    </div>\r\n  </header>\r\n</div>\r\n<main id=\"main\">\r\n  <div class=\"kv_sub_wrap\">\r\n    <div class=\"inner\">\r\n      <p class=\"kv_sub_cat_en\">About Token</p>\r\n      <p class=\"kv_sub_cat\">会社を知る</p>\r\n      <h1 class=\"kv_sub_tit\">制度<br class=\"sp\"><span class=\"sm\">（キャリアパス・福利厚生・働き方）</span></h1>\r\n    </div>\r\n  </div>\r\n  <div id=\"wrap\">\r\n    <nav id=\"breadcrumbs\">\r\n      <ul>\r\n        <li><a href=\"/\">Top</a></li>\r\n        <li><a href=\"/recruit/\">求人・採用情報</a></li>\r\n        <li>制度（キャリアパス・福利厚生・働き方）</li>\r\n      </ul>\r\n    </nav>\r\n    <div class=\"system_anchorbox\">\r\n      <div class=\"inner\">\r\n        <ul class=\"system_anchor\">\r\n          <li><a href=\"#system_section1\"><span class=\"en\">career path</span><span class=\"ja\">キャリアパス</span></a></li>\r\n          <li><a href=\"#system_section2\"><span class=\"en\">employee benefits</span><span class=\"ja\">福利厚生</span></a></li>\r\n          <li><a href=\"#system_section3\"><span class=\"en\">work style</span><span class=\"ja\">働き方</span></a></li>\r\n        </ul>\r\n      </div>\r\n    </div>\r\n    <section class=\"system_section1\" id=\"system_section1\">\r\n      <div class=\"inner\">\r\n        <div class=\"system_section_h2_wrap\">\r\n          <p class=\"system_section_h2_eng\">career path</p>\r\n          <h2 class=\"system_section_h2\">キャリアパス</h2>\r\n        </div>\r\n        <div class=\"system_section_h3_wrap\">\r\n          <p class=\"system_section_h3_eng\">career step</p>\r\n          <h3 class=\"system_section_h3\">キャリアステップ</h3>\r\n        </div>\r\n        <div class=\"system_section1_list_wrap\">\r\n          <div class=\"system_section1_list_pc\">\r\n            <div><img src=\"/recruit/system/image/img-section1-slide1-pc.jpg\" alt=\"営業\"></div>\r\n            <!-- <div><img src=\"/recruit/system/image/img-section1-slide2-pc.jpg\" alt=\"営業\"></div>\r\n            <div><img src=\"/recruit/system/image/img-section1-slide3-pc.jpg\" alt=\"営業\"></div>\r\n            <div><img src=\"/recruit/system/image/img-section1-slide4-pc.jpg\" alt=\"営業\"></div> -->\r\n          </div>\r\n          <div class=\"system_section1_list_sp\">\r\n            <div><img src=\"/recruit/system/image/img-section1-slide1-sp.jpg\" alt=\"営業\"></div>\r\n            <!-- <div><img src=\"/recruit/system/image/img-section1-slide2-sp.jpg\" alt=\"営業\"></div>\r\n            <div><img src=\"/recruit/system/image/img-section1-slide3-sp.jpg\" alt=\"営業\"></div>\r\n            <div><img src=\"/recruit/system/image/img-section1-slide4-sp.jpg\" alt=\"営業\"></div> -->\r\n          </div>\r\n        </div>\r\n        <div class=\"system_section_h3_wrap\">\r\n          <p class=\"system_section_h3_eng\">personnel training</p>\r\n          <h3 class=\"system_section_h3\">人材育成</h3>\r\n        </div>\r\n        <div class=\"system_section1_layout1\">\r\n          <div>\r\n            <div class=\"thumb\"><img  src=\"/recruit/system/image/img-section1-pic1.png\" alt=\"新入社員研修\"></div>\r\n            <div class=\"cont\">\r\n              <h4 class=\"tit matcheight\">新入社員研修</h4>\r\n              <p class=\"desc\">ビジネスマナーをはじめ、税務、不動産や資産運用の専門知識などを学ぶため、新入社員を対象として入社後約2週間の研修を実施します。</p>\r\n            </div>\r\n          </div>\r\n          <div>\r\n            <div class=\"thumb\"><img  src=\"/recruit/system/image/img-section1-pic2.png\" alt=\"新任事業所長研修\"></div>\r\n            <div class=\"cont\">\r\n              <h4 class=\"tit matcheight\">新任事業所長への教育</h4>\r\n              <p class=\"desc\">新任として任命された事業所長を対象に、事業所マネジメントの基礎知識を習得することを目的としたテキスト学習を行います。</p>\r\n            </div>\r\n          </div>\r\n          <div>\r\n            <div class=\"thumb\"><img  src=\"/recruit/system/image/img-section1-pic3.png\" alt=\"キャリアコンサルティング制度\"></div>\r\n            <div class=\"cont\">\r\n              <h4 class=\"tit matcheight\">キャリアコンサルティング<br class=\"pc\">制度</h4>\r\n              <p class=\"desc\">年1回、所属長と「業務自己申告書」に沿った面談を行い、将来のキャリアについて目標や計画を設定します。</p>\r\n            </div>\r\n          </div>\r\n          <div>\r\n            <div class=\"thumb\"><img  src=\"/recruit/system/image/img-section1-pic4.png\" alt=\"自己啓発支援制度\"></div>\r\n            <div class=\"cont\">\r\n              <h4 class=\"tit matcheight\">自己啓発支援制度</h4>\r\n              <p class=\"desc\">会社が定める資格に合格した際には、資格に応じて「合格時の受験料の補助」、「資格手当」が支給されます。</p>\r\n            </div>\r\n          </div>\r\n          <div>\r\n            <div class=\"thumb\"><img src=\"/recruit/system/image/img-section1-pic5.png\" alt=\"社内検定などの制度\"></div>\r\n            <div class=\"cont\">\r\n              <h4 class=\"tit matcheight\">社内検定などの制度</h4>\r\n              <p class=\"desc\">「パソコン技能資格制度」、「業務支援システム活用検定」など、様々な社内検定があり、スキルアップを図ることができます。</p>\r\n            </div>\r\n          </div>\r\n          <div>\r\n            <div class=\"thumb\"><img  src=\"/recruit/system/image/img-section1-pic6.png\" alt=\"表彰制度\"></div>\r\n            <div class=\"cont\">\r\n              <h4 class=\"tit matcheight\">表彰制度</h4>\r\n              <p class=\"desc\">「優秀社員表彰」、「永年勤続表彰」、「優良運転者表彰」など、社員が成し得た功績功労を称える様々な表彰制度を設けています。</p>\r\n            </div>\r\n          </div>\r\n        </div>\r\n        <div class=\"system_section1_btn1\">\r\n          <span class=\"overlay\"></span>\r\n          <span class=\"tit\">研修センター</span>\r\n          <span class=\"desc\">愛知県刈谷市にある「研修センター」は、ホールを含めた4つの研修室をはじめ宿泊施設も隣接しており、<br class=\"pc\">泊りがけや大人数の研修・会議にも最適です。</span>\r\n          <a class=\"system_section1_btn1_btn\" href=\"/recruit/education_center/\">\r\n            <span class=\"eng\">View More</span>\r\n          </a>\r\n        </div>\r\n      </div>\r\n    </section>\r\n    <section class=\"system_section2\" id=\"system_section2\">\r\n      <div class=\"inner\">\r\n        <div class=\"system_section_h2_wrap\">\r\n          <p class=\"system_section_h2_eng\">employee benefits</p>\r\n          <h2 class=\"system_section_h2\">福利厚生</h2>\r\n        </div>\r\n        <div class=\"system_section_h3_wrap blue\">\r\n          <p class=\"system_section_h3_eng\">work life balance</p>\r\n          <h3 class=\"system_section_h3\">ワークライフバランス制度</h3>\r\n        </div>\r\n        <div class=\"system_section2_layout1 blue\">\r\n          <div>\r\n            <div class=\"circle\">01</div>\r\n            <div class=\"thumb\"><img  src=\"/recruit/system/image/img-section2-pic1.png\" alt=\"年次有給休暇\"></div>\r\n            <h4 class=\"tit\">年次有給休暇</h4>\r\n          </div>\r\n          <div>\r\n            <div class=\"circle\">02</div>\r\n            <div class=\"thumb\"><img  src=\"/recruit/system/image/img-section2-pic2.png\" alt=\"夏季・年末年始休暇\"></div>\r\n            <h4 class=\"tit\">夏季・年末年始休暇</h4>\r\n          </div>\r\n          <div>\r\n            <div class=\"circle\">03</div>\r\n            <div class=\"thumb\"><img  src=\"/recruit/system/image/img-section2-pic3.png\" alt=\"慶弔休暇\"></div>\r\n            <h4 class=\"tit\">慶弔休暇</h4>\r\n          </div>\r\n          <div>\r\n            <div class=\"circle\">04</div>\r\n            <div class=\"thumb\"><img  src=\"/recruit/system/image/img-section2-pic4.png\" alt=\"永年勤続休暇\"></div>\r\n            <h4 class=\"tit\">永年勤続休暇</h4>\r\n          </div>\r\n          <div>\r\n            <div class=\"circle\">05</div>\r\n            <div class=\"thumb\"><img  src=\"/recruit/system/image/img-section2-pic5.png\" alt=\"療養休暇\"></div>\r\n            <h4 class=\"tit\">療養休暇</h4>\r\n          </div>\r\n          <div class=\"sp_hide\">\r\n            <div class=\"circle\">06</div>\r\n            <div class=\"thumb\"><img  src=\"/recruit/system/image/img-section2-pic6.png\" alt=\"女性の健康保護休暇\"></div>\r\n            <h4 class=\"tit\">女性の健康保護休暇</h4>\r\n          </div>\r\n          <div class=\"sp_hide\">\r\n            <div class=\"circle\">07</div>\r\n            <div class=\"thumb\"><img  src=\"/recruit/system/image/img-section2-pic7.png\" alt=\"産前・産後休暇\"></div>\r\n            <h4 class=\"tit\">産前・産後休暇</h4>\r\n          </div>\r\n          <div class=\"sp_hide\">\r\n            <div class=\"circle\">08</div>\r\n            <div class=\"thumb\"><img  src=\"/recruit/system/image/img-section2-pic8.png\" alt=\"半日有給休暇制度\"></div>\r\n            <h4 class=\"tit\">半日有給休暇制度</h4>\r\n          </div>\r\n          <div class=\"sp_hide\">\r\n            <div class=\"circle\">09</div>\r\n            <div class=\"thumb\"><img  src=\"/recruit/system/image/img-section2-pic9.png\" alt=\"災害休暇\"></div>\r\n            <h4 class=\"tit\">災害休暇</h4>\r\n          </div>\r\n          <div class=\"sp_hide\">\r\n            <div class=\"circle\">10</div>\r\n            <div class=\"thumb\"><img  src=\"/recruit/system/image/img-section2-pic10.png\" alt=\"受注休暇（営業職のみ）\"></div>\r\n            <h4 class=\"tit\">受注休暇（営業職のみ）</h4>\r\n          </div>\r\n        </div>\r\n        <a class=\"system_section2_layout1_more\" href=\"\">\r\n          <span class=\"label\">\r\n            <span class=\"off\">View More</span>\r\n            <span class=\"on\">Close</span>\r\n          </span>\r\n          <span class=\"ic\"><span class=\"off\">+</span><span class=\"on\">-</span></span>\r\n        </a>\r\n        <div class=\"system_section_h3_wrap pink\">\r\n          <p class=\"system_section_h3_eng\">Childcare <br class=\"sp\">support system</p>\r\n          <h3 class=\"system_section_h3\">子育て支援制度</h3>\r\n        </div>\r\n        <div class=\"system_section2_layout1 pink\">\r\n          <div>\r\n            <div class=\"circle\">01</div>\r\n            <div class=\"thumb\"><img  src=\"/recruit/system/image/img-section2-pic11.png\" alt=\"育児休暇\"></div>\r\n            <h4 class=\"tit\">育児休業</h4>\r\n            <p class=\"desc\">原則として子どもが1歳の誕生日を迎えるまで（やむを得ない事情がある場合は最長満2歳まで）、育児休業を取得することができます。</p>\r\n          </div>\r\n          <div>\r\n            <div class=\"circle\">02</div>\r\n            <div class=\"thumb\"><img  src=\"/recruit/system/image/img-section2-pic12.png\" alt=\"育児時短勤務\"></div>\r\n            <h4 class=\"tit\">時短勤務</h4>\r\n            <p class=\"desc\">子どもが小学校を卒業するまで、時短勤務を選択することが認められています。時短勤務を選択すると、1日6時間まで就業時間を短縮することが可能です。</p>\r\n          </div>\r\n          <div>\r\n            <div class=\"circle\">03</div>\r\n            <div class=\"thumb\"><img  src=\"/recruit/system/image/img-section2-pic13.png\" alt=\"子の看病休暇\"></div>\r\n            <h4 class=\"tit\">子の看護等休暇</h4>\r\n            <p class=\"desc\">子どもが病気やケガをしたとき、または予防接種・定期通院など、健康管理のために世話を行う必要がある場合に、終日または半日の休暇を取得することができます。</p>\r\n          </div>\r\n          <div>\r\n            <div class=\"circle\">04</div>\r\n            <div class=\"thumb\"><img  src=\"/recruit/system/image/img-section2-pic14.png\" alt=\"子の育児支援休暇\"></div>\r\n            <h4 class=\"tit\">子の育児支援休暇</h4>\r\n            <p class=\"desc\">満3歳未満の子どもを育てる社員（男女問わず）に対し、年次有給休暇とは別に連続3日間の有給休暇を付与する東建コーポレーション独自の制度です。</p>\r\n          </div>\r\n        </div>\r\n        <div class=\"system_section_h3_wrap gold\">\r\n          <p class=\"system_section_h3_eng\">Elder care <br class=\"sp\">support system</p>\r\n          <h3 class=\"system_section_h3\">介護支援制度</h3>\r\n        </div>\r\n        <div class=\"system_section2_layout1 gold\">\r\n          <div>\r\n            <div class=\"circle\">01</div>\r\n            <div class=\"thumb\"><img  src=\"/recruit/system/image/img-section2-pic15.png\" alt=\"介護休業\"></div>\r\n            <h4 class=\"tit\">介護休業</h4>\r\n            <p class=\"desc\">要介護状態にある家族の介護をするため、長期的な就労が不可となる場合、通算365日の範囲内で「介護休業」を取得することが可能です。</p>\r\n          </div>\r\n          <div>\r\n            <div class=\"circle\">02</div>\r\n            <div class=\"thumb\"><img  src=\"/recruit/system/image/img-section2-pic16.png\" alt=\"介護休暇\"></div>\r\n            <h4 class=\"tit\">介護休暇</h4>\r\n            <p class=\"desc\">家族や親族に介護が必要になった場合、1年につき5日（要介護者が2人以上の場合は最大10日／年）終日または半日の休暇を有給として取得することができます。</p>\r\n          </div>\r\n        </div>\r\n        <div class=\"system_section2_box1\">\r\n          <h3><span>福利厚生施設</span></h3>\r\n          <div class=\"system_section2_box1_inner\">\r\n            <h4 class=\"blue\">海外リゾート宿泊施設</h4>\r\n            <div class=\"system_section2_box1_layout1\">\r\n              <div>\r\n                <div class=\"thumb\"><img  src=\"/recruit/system/image/img-section2-pic17.jpg\" alt=\"グアム コンドミニアム「ビラ カントン タシ」\"></div>\r\n                <div class=\"tit\">\r\n                  <p>グアム<br><span class=\"sm\">コンドミニアム<br>「ビラ カントン タシ」</span></p>\r\n                </div>\r\n              </div>\r\n              <div>\r\n                <div class=\"thumb\"><img  src=\"/recruit/system/image/img-section2-pic18.jpg\" alt=\"ハワイ コンドミニアム 「ヨットハーバータワーズ」\"></div>\r\n                <div class=\"tit\">\r\n                  <p>ハワイ<br><span class=\"sm\">コンドミニアム<br>「ヨットハーバータワーズ」</span></p>\r\n                </div>\r\n              </div>\r\n            </div>\r\n            <h4 class=\"blue2\">国内リゾート宿泊施設</h4>\r\n            <div class=\"system_section2_box1_layout1\">\r\n              <div>\r\n                <div class=\"thumb\"><img  src=\"/recruit/system/image/img-section2-pic19.jpg\" alt=\"神奈川県 ファミール・ヴィラ強羅（4番館）\"></div>\r\n                <div class=\"tit\">\r\n                  <p>神奈川県<br><span class=\"sm\">ファミール・ヴィラ強羅<br>（4番館）</span></p>\r\n                </div>\r\n              </div>\r\n              <div>\r\n                <div class=\"thumb\"><img  src=\"/recruit/system/image/img-section2-pic20.jpg\" alt=\"静岡県 プリオール浜名湖\"></div>\r\n                <div class=\"tit\">\r\n                  <p>静岡県<br><span class=\"sm\">プリオール浜名湖</span></p>\r\n                </div>\r\n              </div>\r\n              <div>\r\n                <div class=\"thumb\"><img  src=\"/recruit/system/image/img-section2-pic21.jpg\" alt=\"兵庫県 マリンプラザ淡路\"></div>\r\n                <div class=\"tit\">\r\n                  <p>兵庫県<br><span class=\"sm\">マリンプラザ淡路</span></p>\r\n                </div>\r\n              </div>\r\n              <div>\r\n                <div class=\"thumb\"><img  src=\"/recruit/system/image/img-section2-pic22.jpg\" alt=\"三重県 ホテル多度温泉\"></div>\r\n                <div class=\"tit\">\r\n                  <p>三重県<br><span class=\"sm\"><a href=\"https://www.token-tado.co.jp/tado_onsen/\" target=\"_blank\">ホテル多度温泉</a></span></p>\r\n                </div>\r\n              </div>\r\n            </div>\r\n            <h4 class=\"green\">ゴルフ場</h4>\r\n            <div class=\"system_section2_box1_layout1\">\r\n              <div>\r\n                <div class=\"thumb\"><img  src=\"/recruit/system/image/img-section2-pic23.jpg\" alt=\"東建多度カントリークラブ・名古屋\"></div>\r\n                <div class=\"tit\">\r\n                  <p>三重県<br><span class=\"sm\"><a href=\"https://www.token-tado.co.jp/golf/\" target=\"_blank\">東建多度カントリークラブ・名古屋</a></span></p>\r\n                </div>\r\n              </div>\r\n              <div>\r\n                <div class=\"thumb\"><img  src=\"/recruit/system/image/img-section2-pic24.jpg\" alt=\"東建塩河カントリー倶楽部\"></div>\r\n                <div class=\"tit\">\r\n                  <p>岐阜県<br><span class=\"sm\"><a href=\"https://www.token-shuga.com/\" target=\"_blank\">東建塩河カントリー倶楽部</a></span></p>\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </section>\r\n    <section class=\"system_section3\" id=\"system_section3\">\r\n      <div class=\"inner\">\r\n        <div class=\"system_section_h2_wrap\">\r\n          <p class=\"system_section_h2_eng\">work style</p>\r\n          <h2 class=\"system_section_h2\">働き方</h2>\r\n        </div>\r\n        <div class=\"system_section3_layout1\">\r\n          <div>\r\n            <div class=\"thumb\"><img src=\"/recruit/system/image/img-section3-pic1.jpg\" alt=\"テレワーク制度\"></div>\r\n            <h3 class=\"tit\">テレワーク制度</h3>\r\n            <p class=\"desc\">業務の効率化を図り、生活と仕事を両立することを目的とし、自宅で出社を伴わないフルテレワーク勤務（在宅勤務）が可能です。<br>※フルテレワーク勤務には条件があり、業務の性質上、対象となる職種が限られています。</p>\r\n          </div>\r\n          <div>\r\n            <div class=\"thumb\"><img src=\"/recruit/system/image/img-section3-pic2.jpg\" alt=\"フレックスタイム制度\"></div>\r\n            <h3 class=\"tit\">フレックスタイム制度</h3>\r\n            <p class=\"desc\">会社が定めたフレキシブルタイム内であれば、始業時刻・終業時刻・労働時間、及びその配分を個人の裁量で決めることが可能です。<br>※業務の性質上、対象となる職種が限られています。</p>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </section>\r\n  </div>\r\n</main>\r\n<!-- requirements -->\r\n<div class=\"requirement_bg\">\r\n  <section id=\"requirement\">\r\n    <h2>募集要項</h2>\r\n    <p class=\"cap_eng\">Requirements</p>\r\n    <div class=\"requirement_h2_label\">新卒・中途</div>\r\n    <div class=\"requirement_box newgraduate\">\r\n      <h3>新卒採用</h3>\r\n      <div class=\"requirement_layout1\">\r\n        <div>\r\n          <h4 class=\"requirement_job\">営業職</h4>\r\n          <p class=\"requirement_desc\">土地所有者様に収益や節税対策を目的とした、賃貸マンション・アパート経営による土地の有効活用をご提案する「コンサルティング営業」です。<br>税務・不動産・金融など幅広い知識を身に付けながら、お客様の人生設計に寄り添った提案を行います。</p>\r\n          <div class=\"requirement_links\">\r\n            <a href=\"/recruit/newgraduate/sales/\">詳細を見る</a>\r\n            <a href=\"https://job.axol.jp/bx/s/token_27/entry/\" target=\"_blank\" rel=\"nofollow\">応募する</a>\r\n          </div>\r\n        </div>\r\n        <div>\r\n          <h4 class=\"requirement_job\">建築職</h4>\r\n          <p class=\"requirement_desc\">賃貸アパート・マンションを建築するために、現場での施工管理を担当します。業務内容は、工程計画の立案、測量や配置図の作成、施工品質の確認、予算管理、資材や職人の手配、現場の安全管理、各種検査の立会いなど多岐にわたります。</p>\r\n          <div class=\"requirement_links\">\r\n            <a href=\"/recruit/newgraduate/architect/\">詳細を見る</a>\r\n            <a href=\"https://job.axol.jp/bx/s/token_27/entry/\" target=\"_blank\" rel=\"nofollow\">応募する</a>\r\n          </div>\r\n        </div>\r\n        <div>\r\n          <h4 class=\"requirement_job\">設計職・商品開発職</h4>\r\n          <p class=\"requirement_desc\">設計・積算業務を行いながら、着工までの諸申請業務、完工までの工事監理を行います。<br>本社設計職では、新商品の開発や新技術の研究開発、より高効率な設計・業務改善なども行います。</p>\r\n          <div class=\"requirement_links\">\r\n            <a href=\"/recruit/newgraduate/designer/\">詳細を見る</a>\r\n            <a href=\"https://job.axol.jp/bx/s/token_27/entry/\" target=\"_blank\" rel=\"nofollow\">応募する</a>\r\n          </div>\r\n        </div>\r\n        <div>\r\n          <h4 class=\"requirement_job\">仲介職</h4>\r\n          <p class=\"requirement_desc\">オーナー様の賃貸マンション・賃貸アパート経営の安定や、より良い住まいを求めるお客様に満足していただける賃貸物件をお世話するために「入居仲介」、「賃貸管理」の業務を行います。</p>\r\n          <div class=\"requirement_links\">\r\n            <a href=\"/recruit/newgraduate/estate-agency/\">詳細を見る</a>\r\n            <a href=\"https://job.axol.jp/bx/s/token_27/entry/\" target=\"_blank\" rel=\"nofollow\">応募する</a>\r\n          </div>\r\n        </div>\r\n      </div>\r\n      <p class=\"requirement_text1\">ご応募は、マイナビ・リクナビより受け付けております。<br class=\"none_sp\">各ナビサイトの「エントリー」ボタンからお手続きください。</p>\r\n      <h3 class=\"requirement_h3_year\">2027</h3>\r\n      <div class=\"requirement_layout2\">\r\n        <div class=\"entry\"><a href=\"https://job.axol.jp/bx/s/token_27/entry/\" target=\"_blank\">ENTRY</a></div>\r\n        <div class=\"mypage\"><a href=\"https://job.axol.jp/bx/s/token_27/mypage/login\" target=\"_blank\">MY PAGE</a></div>\r\n        <div class=\"rikunavi\"><a href=\"https://job.rikunabi.com/n/job_search/?kw=%E6%9D%B1%E5%BB%BA%E3%82%B3%E3%83%BC%E3%83%9D%E3%83%AC%E3%83%BC%E3%82%B7%E3%83%A7%E3%83%B3\" target=\"_blank\"><img src=\"/recruit/image_cmn/btn-recnavi2027_2.jpg\" alt=\"リクナビ2027\"></a></div>\r\n        <div class=\"mynavi\"><a href=\"https://job.mynavi.jp/27/pc/search/corp54375/outline.html\" target=\"_blank\"><img src=\"/recruit/image_cmn/btn-mynavi2027_2.jpg\" alt=\"マイナビ2027\"></a></div>\r\n      </div>\r\n      <h3 class=\"requirement_h3_year\">2028</h3>\r\n      <!--<p class=\"requirement_comingsoon\">coming soon</p>-->\r\n      <div class=\"requirement_layout2\">\r\n        <div class=\"entry\"><a href=\"https://axol.jp/zw/s/token_28/entry/\" target=\"_blank\">ENTRY</a></div>\r\n        <div class=\"mypage\"><a href=\"https://axol.jp/zw/s/token_28/mypage/\" target=\"_blank\">MY PAGE</a></div>\r\n        <div class=\"rikunavi\"><a href=\"https://job.rikunabi.com/job_search/?kw=%E6%9D%B1%E5%BB%BA%E3%82%B3%E3%83%BC%E3%83%9D%E3%83%AC%E3%83%BC%E3%82%B7%E3%83%A7%E3%83%B3\" target=\"_blank\"><img src=\"/recruit/image_cmn/btn-recnavi2028.jpg\" alt=\"リクナビ2028\"></a></div>\r\n        <div class=\"mynavi\"><a href=\"https://job.mynavi.jp/28/pc/search/corp54375/outline.html\" target=\"_blank\"><img src=\"/recruit/image_cmn/btn-mynavi2028.jpg\" alt=\"マイナビ2028\"></a></div>\r\n      </div>\r\n    </div>\r\n    <div class=\"requirement_box career\">\r\n      <h3>中途採用</h3>\r\n      <div id=\"requirement_accordion_1\" class=\"requirement_layout1\">\r\n        <div>\r\n          <h4 class=\"requirement_job\">営業職</h4>\r\n          <p class=\"requirement_desc\">弊社の主力商品である賃貸物件（賃貸マンション・アパート）等の営業受注活動を行います。主として都市近郊農家等の土地所有者の方に、賃貸マンション・アパート・貸店舗等のリース建築経営をご提案する土地活用コンサルティング営業です。</p>\r\n          <div class=\"requirement_links\">\r\n            <a href=\"/recruit/career/sales/\">詳細を見る</a>\r\n            <a href=\"/recruit/entry/?id=01\">応募する</a>\r\n          </div>\r\n        </div>\r\n        <!--\r\n        <div>\r\n          <h4 class=\"requirement_job\">法人営業職</h4>\r\n          <p class=\"requirement_desc\">不動産仲介店や管理会社を訪問し、不動産仲介店「ホームメイト」のフランチャイズ店や「ホームメイト」サイトの物件情報掲載店の募集活動を行っていただきます。また、契約後のアフターフォロー活動も行っていただきます。</p>\r\n          <div class=\"requirement_links\">\r\n            <a href=\"/recruit/career/business/\">詳細を見る</a>\r\n            <a href=\"/recruit/entry/?id=01\">応募する</a>\r\n          </div>\r\n        </div>\r\n        -->\r\n        <div>\r\n          <h4 class=\"requirement_job\">仲介職</h4>\r\n          <p class=\"requirement_desc\">「ホームメイト」の店舗スタッフとして、オーナー様の賃貸経営を支援する賃貸管理業務と、入居者様への物件提案・契約手続きなどの、入居仲介業務を行います。<br>オーナー様と入居者様双方にとって最適な提案を行うポジションです。</p>\r\n          <div class=\"requirement_links\">\r\n            <a href=\"/recruit/career/estate-agency/\">詳細を見る</a>\r\n            <a href=\"/recruit/entry/?id=05\">応募する</a>\r\n          </div>\r\n        </div>\r\n        <div>\r\n          <h4 class=\"requirement_job\">建築職</h4>\r\n          <p class=\"requirement_desc\">リース住宅の建築工事において、安全・品質・工程・原価管理などの施工管理業務を担当します。<br>また、積算業務や見積り作成などの営業受注支援業務にも携わり、工事の円滑な進行と品質確保を支えるポジションです。</p>\r\n          <div class=\"requirement_links\">\r\n            <a href=\"/recruit/career/architect/\">詳細を見る</a>\r\n            <a href=\"/recruit/entry/?id=03\">応募する</a>\r\n          </div>\r\n        </div>\r\n        <div>\r\n          <h4 class=\"requirement_job\">設計職</h4>\r\n          <p class=\"requirement_desc\">設計・積算支援業務を効率的に行い、お客様にご納得いただける提案を実現するため、「提案図面」及び「契約図面」の作成を担当します。<br>営業と連携しながら、受注活動を技術面から支える設計支援業務を行うポジションです。</p>\r\n          <div class=\"requirement_links\">\r\n            <a href=\"/recruit/career/designer/\">詳細を見る</a>\r\n            <a href=\"/recruit/entry/?id=04\">応募する</a>\r\n          </div>\r\n        </div>\r\n      </div>\r\n      <!-- <a id=\"js_requirement_accordion_btn\" href=\"\" class=\"requirement_accordion_btn\">View More<i></i></a> -->\r\n    </div>\r\n  </section>\r\n</div>\r\n<ul class=\"foot_sns\">\r\n  <li><a href=\"https://www.facebook.com/token.corp\" target=\"_blank\"><img src=\"/recruit/image_cmn/icon-facebook.svg\" alt=\"facebook\"></a></li>\r\n  <li><a href=\"https://twitter.com/tokencorp\" target=\"_blank\"><img src=\"/recruit/image_cmn/icon-x.svg\" alt=\"x\"></a></li>\r\n  <li><a href=\"https://www.youtube.com/user/tokentelevision\" target=\"_blank\"><img src=\"/recruit/image_cmn/icon-youtube.svg\" alt=\"youtube\"></a></li>\r\n  <li><a href=\"https://www.instagram.com/token.corp_official/\" target=\"_blank\"><img src=\"/recruit/image_cmn/icon-instagram.svg\" alt=\"Instagram\"></a></li>\r\n  <!--<li><a href=\"\"><img src=\"/recruit/image_cmn/icon-tiktok-b.png\" alt=\"Tiktok\"></a></li> -->\r\n</ul>\r\n<div class=\"foot_txt\">\r\n  <ul>\r\n    <li><a href=\"/privacy/\">個人情報保護に関する基本方針</a></li>\r\n    <li><a href=\"/personal_info/\">特定個人情報の適切な取り扱いに関する基本方針</a></li>\r\n    <li><a href=\"/social/\">SNS（ソーシャルメディア）ポリシー</a></li>\r\n  </ul>\r\n</div>\r\n<footer>\r\n  <p>Copyright © 土地活用の東建コーポレーション All RIGHTS RESERVED.</p>\r\n</footer>\r\n<div class=\"pagetop_wrap\"><a href=\"\" class=\"pagetop\"><span>PAGE<br>TOP</span></a></div>\r\n<script src=\"/responsive/js-cmn/jquery.matchHeight-min.js\"></script>\r\n<script src=\"/responsive/js-cmn/slick/slick.min.js\"></script> \r\n<script src=\"/recruit/js/recruit.js?20260330113301\"></script> \r\n<script src=\"/recruit/system/js/system.js?20260608112852\"></script> \r\n<!-- ▲ Local scriptここまで ▲ --> \r\n<script type=\"application/ld+json\">\r\n  {\r\n    \"@context\": \"https://schema.org/\",\r\n    \"@type\": \"BreadcrumbList\",\r\n    \"itemListElement\": [{\r\n      \"@type\": \"ListItem\",\r\n      \"position\": 1,\r\n      \"name\": \"東建コーポレーション\",\r\n      \"item\": \"https://www.token.co.jp/\"\r\n    },{\r\n      \"@type\": \"ListItem\", \r\n      \"position\": 2, \r\n      \"name\": \"求人・採用情報\",\r\n      \"item\": \"https://www.token.co.jp/recruit/\"  \r\n    },{\r\n      \"@type\": \"ListItem\", \r\n      \"position\": 3, \r\n      \"name\": \"制度\",\r\n      \"item\": \"https://www.token.co.jp/recruit/system/\"  \r\n    }]\r\n  }\r\n</script>\r\n</body>\r\n</html>","finalUrl":"https://www.token.co.jp/recruit/system/","rendered":false,"_cachedAt":"2026-06-22T22:22:30.718Z"}