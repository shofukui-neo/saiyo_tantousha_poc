bsp;\n            <span itemprop=\"name\">採用Q&A</span>\n            <meta itemprop=\"position\" content=\"3\">\n    </li>\n    \t\t  </ul>\n</div><!--/TopicPath-->\n\n    <div class=\"recruit_nav_widget widget_place_01\">\n\t\t\t\n  <div class=\"inner_02\">\n    <nav>\n      <ul class=\"recruit_nav_list\">\n        <li class=\"recruit_nav_item\"><a href=\"/recruit/\" class=\"recruit_nav_link\">採用情報TOP</a></li>\n        <li class=\"recruit_nav_item\"><a href=\"/recruit/interview/\" class=\"recruit_nav_link\">仕事・人を知る</a></li>\n        <li class=\"recruit_nav_item\"><a href=\"/recruit/environment/\" class=\"recruit_nav_link\">働く環境を知る</a></li>\n        <li class=\"recruit_nav_item\"><a href=\"/recruit/application/\" class=\"recruit_nav_link\">募集要項</a></li>\n        <li class=\"recruit_nav_item\"><a href=\"/recruit/faq/\" class=\"recruit_nav_link\">採用Q&A</a></li>\n        <li class=\"recruit_nav_item\"><a href=\"/userfiles/files/recruit/panf_2026s.pdf\" class=\"recruit_nav_link\"target=\"_blank\">パンフレット</a></li>\n      </ul>\n    </nav>\n  </div>\n</div>\n\n    <div class=\"pagebody_inner\">\n      <div class=\"list_faq\">\n                <div class=\"item\" id=\"faq_00073\">\n          <h3 class=\"btn_q\"><span data-href=\"/faq/1704796676/\">文系学部なのですが応募は可能ですか？</span></h3>\n          <div class=\"box_a\">\n              可能です。<br />\r\n文系学生の皆さんでも、ITに何かしら興味がある方であれば歓迎です。<br />\r\n興味だけでなく、「興味があってこんなことを勉強してます」等の明確な過程のある方は大歓迎！\n          </div>\n        </div>\n                <div class=\"item\" id=\"faq_00074\">\n          <h3 class=\"btn_q\"><span data-href=\"/faq/1704796711/\">資格は取っておいた方が有利ですか？</span></h3>\n          <div class=\"box_a\">\n              有利です。<br />\r\n就職活動において、どの業界、職種においても有利な資格はあると思います。<br />\r\n当社の場合、技術系で入社する皆さんには、国家資格の「基本情報技術者」を推奨しております。\n          </div>\n        </div>\n                <div class=\"item\" id=\"faq_00075\">\n          <h3 class=\"btn_q\"><span data-href=\"/faq/1704796738/\">育児休暇制度について教えてください。</span></h3>\n          <div class=\"box_a\">\n              育児だけでなく介護も制度があります。<br />\r\n制度の利用実績もあり、育児については、男性の利用実績もあります。<br />\r\n皆さん復帰もしておりますので、育児や介護しながら勤務する環境は整っている企業であると自負しております。\n          </div>\n        </div>\n                <div class=\"item\" id=\"faq_00076\">\n          <h3 class=\"btn_q\"><span data-href=\"/faq/1704796756/\">将来のビジョンについて教えてください。</span></h3>\n          <div class=\"box_a\">\n              &nbsp;当社は、設立以来、ソフトウェアの開発を中心とし拡大してきましたが、最近ではサポート系の事業も成長しており、 製品を「製造からサポート、保守まで」一貫して対応するノウハウが蓄積してきたと感じております。<br />\r\n今以上に技術力の幅を広げて、沖縄のIT産業にさらなる貢献を！　と思ってます。\n          </div>\n        </div>\n              </div>\n    </div>\n\n      </main>\n  <!-- //pagebody --> \n\n  <!-- site_footer --> \n  <div id=\"FooterArea\">\n  <!-- コンテナ（幅1275px、レスポンシブ対応の場合）※「5. コンテナについて」を参照 -->\n  <div class=\"Container Wide\">\n    <a href=\"#top\" id=\"FooterPageTop\" aria-label=\"ページの先頭へ\"></a>\n    <!-- オプショナルフッタ 「7.3. オプショナルフッタ」を参照-->\n    <div id=\"Footer2\">\n            <!-- オプショナルフッタ項目「7.5. オプショナルフッタ項目」を参照 -->\n      <div id=\"Footer2Menu\">\n        <a href=\"/sitemap/\">サイトマップ</a>\n        <a href=\"/topics/\">新着情報</a>\n        <a href=\"/contact/\">お問い合わせ</a>\n      </div>\n    </div>\n    <!-- フッタ -->\n    <div id=\"Footer1\">\n      <!-- 日立グループTOP「7.6. 日立グループTOP」 -->\n      <div id=\"HitachiTop\">\n        <a href=\"https://www.hitachi.co.jp/\">日立グループTOP</a>\n      </div>\n      <!-- フッタ項目「7.7. フッタ項目」を参照 -->\n      <div id=\"Footer1Menu\">\n        <a href=\"https://www.hitachi.co.jp/utility/termofuse/index.html\">サイトの利用条件</a>\n        <a href=\"/privacy/\">個人情報保護に関して</a>\n      </div>\n      <!-- コピーライト「7.8. コピーライト」を参照 -->\n      <div id=\"Copyright\">&copy;Okinawa Hitachi Network Systems, Ltd. 2026. All rights reserved.</div>\n    </div>\n  </div>\n</div>\n\n \n  <!-- //site_footer --> \n</div>\n\n\n<script type=\"text/javascript\" src=\"/js/lib/jquery.js\"></script>\n<script type=\"text/javascript\" src=\"/js/jp/r1/common.js\"></script>\n<script type=\"text/javascript\" src=\"/js/jp/r1/responsive.js\"></s