uerySelectorAll('.swiper-slide').length;\n\n                    // Swiperの設定\n                    const swiperConfig = {\n                    loop: slideCount > 4, // スライドが4枚以上の場合のみループを有効化\n                    autoplay: slideCount > 4 ? { delay: 7000 } : false, // スライドが4枚以上の場合のみ自動再生を有効化\n                    //autoplay: false, // スライドが4枚以上の場合のみ自動再生を有効化\n                    slidesPerView: 1.5, // 表示するスライド数（必要に応じて変更）\n                    spaceBetween: 10,\n                    centeredSlides: true,\n                    loopFillGroupWithBlank: true, // 不足分を空白で埋める\n                    speed: 800,\n                    navigation: {\n                        nextEl: '.swiper-button-next',\n                        prevEl: '.swiper-button-prev',\n                    },\n                    pagination: {\n                        el: '.swiper-pagination',\n                        clickable: true,\n                    },\n                    breakpoints: {\n                        700: {\n                            slidesPerView: 3.5,\n                            spaceBetween: 20,\n                        },\n                        1000: {\n                        slidesPerView: 4,\n                        spaceBetween: 20,\n                        centeredSlides: false,\n                        }\n                    }\n                    };\n\n                    // Swiperインスタンスを初期化\n                    const swiper = new Swiper('.swiper', swiperConfig);\n            </script>\n        </div>\n    </body>\n</html>","finalUrl":"https://www.dai-ichi.com/","rendered":false,"_cachedAt":"2026-06-17T23:28:19.122Z"}