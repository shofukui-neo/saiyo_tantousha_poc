{"url":"https://www.fuji-label.co.jp/recruit/entry/","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge,chrome=1\">\n<meta name=\"copyright\" content=\"&copy; 2020 FUJI LABEL Inc. All Rights Reserved.\">\n<title>エントリーページ｜株式会社不二レーベル</title>\n\n\t<!-- This site is optimized with the Yoast SEO plugin v14.2 - https://yoast.com/wordpress/plugins/seo/ -->\n\t<meta name=\"description\" content=\"不二レーベルのエントリーページ ページです。不二レーベルは昭和40年に誕生したラベラーおよびラベルのメーカーです。誕生以来、商品の顔であるラベル印刷からオートラベラーの企画、開発、設計、製造、販売まで一貫して行っております。どんなラベルでも、どんなラベラーでも、お悩みを解決します！\" />\n\t<meta name=\"robots\" content=\"index, follow\" />\n\t<meta name=\"googlebot\" content=\"index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1\" />\n\t<meta name=\"bingbot\" content=\"index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1\" />\n\t<link rel=\"canonical\" href=\"https://www.fuji-label.co.jp/recruit/entry/\" />\n\t<script type=\"application/ld+json\" class=\"yoast-schema-graph\">{\"@context\":\"https://schema.org\",\"@graph\":[{\"@type\":\"Organization\",\"@id\":\"https://www.fuji-label.co.jp/#organization\",\"name\":\"\\u682a\\u5f0f\\u4f1a\\u793e\\u4e0d\\u4e8c\\u30ec\\u30fc\\u30d9\\u30eb\",\"url\":\"https://www.fuji-label.co.jp/\",\"sameAs\":[],\"logo\":{\"@type\":\"ImageObject\",\"@id\":\"https://www.fuji-label.co.jp/#logo\",\"inLanguage\":\"ja\",\"url\":\"\",\"caption\":\"\\u682a\\u5f0f\\u4f1a\\u793e\\u4e0d\\u4e8c\\u30ec\\u30fc\\u30d9\\u30eb\"},\"image\":{\"@id\":\"https://www.fuji-label.co.jp/#logo\"}},{\"@type\":\"WebSite\",\"@id\":\"https://www.fuji-label.co.jp/#website\",\"url\":\"https://www.fuji-label.co.jp/\",\"name\":\"\\u682a\\u5f0f\\u4f1a\\u793e\\u4e0d\\u4e8c\\u30ec\\u30fc\\u30d9\\u30eb\",\"description\":\"\\u4e0d\\u4e8c\\u30ec\\u30fc\\u30d9\\u30eb\\u306f\\u662d\\u548c40\\u5e74\\u306b\\u8a95\\u751f\\u3057\\u30