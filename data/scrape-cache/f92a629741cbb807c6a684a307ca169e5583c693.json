{"url":"https://jp.sharp/support/announce/ay_info_220920.html","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n<head prefix=\"og: http://ogp.me/ns#\">\n  <meta charset=\"utf-8\">\n  <meta http-equiv=\"X-UA-Compatible\" content=\"IE=Edge\">\n  <meta name=\"format-detection\" content=\"telephone=no,email=no,address=no\">\n  <meta name=\"copyright\" content=\"&copy; SHARP CORPORATION\">\n  <meta content=\"シャープ製エアコンAirest(AY-L40P-W 等4機種)をご使用いただいているお客様に室内機の制御基板不具合にともなう無料点検・修理のおしらせ\" name=\"description\">\n  <meta content=\"シャープ,SHARP,エアコン,Airest,AY-L22P-W,AY-L25P-W,AY-L28P-W,AY-L40P-W,点検,修理\" name=\"keywords\">\n  <script src=\"/support/products/common/plugin/products-viewport.js\"></script>\n  <meta content=\"シャープ製エアコンAirestの無料点検・修理のおしらせ\" property=\"og:title\">\n  <meta content=\"シャープ製エアコンAirest(AY-L40P-W 等4機種)をご使用いただいているお客様に室内機の制御基板不具合にともなう無料点検・修理のおしらせ\"\n        property=\"og:description\">\n  <meta property=\"og:image\" content=\"/index_common/images/ogp.png\">\n  <meta property=\"og:type\" content=\"product\">\n  <meta property=\"og:site_name\" content=\"シャープ株式会社\">\n  <link href=\"https://jp.sharp/support/announce/ay_info_220920.html\" rel=\"canonical\">\n  <title>シャープ製エアコンAirestの無料点検・修理のおしらせ│製品に関する大切なお知らせ│サポート・お問い合わせ：シャープ</title>\n  <link rel=\"icon\" href=\"/products/common/images/favicon.ico\" type=\"image/x-icon\">\n  <link rel=\"apple-touch-icon\" href=\"/products/common/images/apple-touch-icon.png\" sizes=\"180x180\">\n  <link rel=\"stylesheet\" href=\"/support/products/common/css/bootstrap-reboot.min.css\">\n  <link rel=\"stylesheet\" href=\"/support/products/common/css/global.css\">\n  <link rel=\"stylesheet\" href=\"https://use.fontawesome.com/releases/v5.7.2/css/all.css\"\n        integrity=\"sha384-fnmOCqbTlWIlj8LyTjo7mOUStjsKC4pOpQbqyi7RrhN7udi9RwhKkMHpvLbHG9Sr\" crossorigin=\"anonymous\">\n  <script src=\"https://ajax.googleapis.com/ajax/libs/jquery/3.3.1/jquery.min.js\"></script>\n  <script type=\"text/javascript\" src=\"https://cs.sharp.co.jp/trouble_check/div/js/gaua01.js\"></script>\n  <!-- LOCAL CSS -->\n  <link rel=\"stylesheet\" type=\"text/css\" href=\"/support/css/information.css\">\n  <link rel=\"stylesheet\" type=\"text/css\" href=\"/support/css/information_fix.css\">\n  <link rel=\"stylesheet\" type=\"text/css\" href=\"/support/css/share.css\">\n  <!-- /LOCAL CSS -->\n\n  <style>\n    #informationWrap h1 {\n      padding: 0 15px 10px 15px;\n      font-weight: bold;\n      font-size: 1.8rem;\n      border-bottom: 4px solid #ccc;\n    }\n\n    #informationWrap h2 {\n      font-size: 1.8rem;\n      font-weight: 500;\n      padding: 5px 15px;\n      background: #ccc;\n    }\n\n    #informationWrap h3 {\n      font-size: 1.6rem;\n      margin-bottom: 5px;\n      padding-bottom: 5px;\n      padding-left: 0;\n      border-bottom: 3px solid #ccc;\n    }\n\n    #informationWrap h4 {\n      background: transparent;\n      font-size: 1.6rem;\n      margin-bottom: 5px;\n      padding-bottom: 5px;\n      padding-left: 0;\n      border-bottom: none;\n    }\n\n    #informationWrap h4:before {\n      content: \"■\";\n    }\n\n    .informationWrap ul > li {\n      list-style: disc inside;\n    }\n\n    .informationWrap .tableWrapper {\n      display: flex;\n      text-align: center;\n      overflow-x: auto;\n    }\n\n    .informationWrap .tableWrapper table {\n      margin: 0 auto;\n      white-space: nowrap;\n    }\n\n    .informationWrap table {\n      border: 1px solid #ccc;\n    }\n\n    .informationWrap th {\n      border: 1px solid #ccc;\n      padding: 4px;\n    }\n\n    .informationWrap td {\n      border: 1px solid #ccc;\n      padding: 4px;\n    }\n\n    .informationWrap section {\n      margin-top: 15px;\n    }\n\n    .informationWrap .serial-image {\n      max-width: 760px;\n      height: auto;\n      margin: 0 auto;\n      display: block;\n    }\n\n    .webEntrySection label {\n      font-weight: 500;\n      font-size: 1.6rem;\n      display: block;\n    }\n\n    .webEntrySection input[type=\"text\"], .webEntrySection select {\n      font-weight: 400;\n      font-size: 1.6rem;\n      outline: none;\n      border: 1px solid rgb(224, 224, 224);\n      border-radius: 4px;\n      text-indent: 4px;\n      background-color: transparent;\n      width: 32rem;\n      max-width: 90%;\n    }\n\n    .webEntrySection input[type=\"text\"]:hover:enabled, .webEntrySection select:hover:enabled {\n      border-color: rgb(64, 64, 64);\n      transition: border-color 0.25s;\n    }\n\n    .webEntrySection input[type=\"text\"]:focus:enabled, .webEntrySection select:focus:enabled {\n      border-color: #bc007f;\n      outline: 1px solid #bc007f;\n    }\n\n    .webEntrySection input[type=\"text\"]:invalid, .webEntrySection select:invalid {\n      border: 1px solid rgb(230, 161, 164);\n    }\n\n    .webEntrySection input[type=\"text\"]:invalid:hover:enabled, .webEntrySection select:invalid:hover:enabled {\n      border: 1px solid rgb(230, 0, 13);\n    }\n\n    .webEntrySection input[type=\"text\"]:invalid:focus:enabled, .webEntrySection select:invalid:focus:enabled {\n      border-color: rgb(230, 0, 13);\n      outline: 1px solid rgb(230, 0, 13);\n    }\n\n    .webEntrySection .hint {\n      color: rgb(32, 32, 32);\n      font-size: 1.6rem;\n      text-align: left;\n      font-weight: 300;\n      margin: 0.2rem 0 0 0.2rem;\n    }\n\n    .webEntrySection button.entryButton {\n      color: #ffffff;\n      border: none;\n      background-color: #bc007f;\n      font-size: 1.6rem;\n      font-weight: 500;\n      padding: 8px 12px;\n      border-radius: 8px;\n      transition: background-color 0.25s;\n    }\n\n    .webEntrySection button:focus:enabled, .webEntrySection button:hover:enabled {\n      outline: none;\n      opacity: 0.55;\n      transition: opacity 0.25s;\n    }\n\n    .webEntrySection .errorText {\n      color: rgb(230, 0, 13);\n    }\n\n    .Fsize01 {\n      font-size: 120%;\n    }\n\n    @media only screen and (max-width: 767px) {\n      .Fsize01 {\n        font-size: 105%;\n      }\n    }\n  </style>\n</head>\n\n<body>\n<header id=\"globalHeader\"></header>\n<div id=\"breadcrumb\"></div>\n<main id=\"main\">\n  <article>\n    <section class=\"sub-section outer-base-width\">\n      <div class=\"base-width\">\n        <div class=\"informationWrap\" id=\"informationWrap\">\n          <div class=\"date mb20\">2022年09月20日</div>\n          <h1 class=\"txtCen mb15\">シャープ製エアコン\n            <ruby>Airest\n              <rp>(</rp>\n              <rt>エアレスト</rt>\n              <rp>)</rp>\n            </ruby>\n            (AY-L40P-W 等4機種)をご使用いただいているお客様に<br>\n            室内機の制御基板不具合にともなう 無料点検・修理のおしらせ\n          </h1>\n          <div class=\"mainContentWrap\">\n            <div class=\"note\">\n              <p> 弊社が2019年11月～2020年7月までに製造いたしました、ルームエアコン\n                <ruby>Airest\n                  <rp>(</rp>\n                  <rt>エアレスト</rt>\n                  <rp>)</rp>\n                </ruby>\n                (AY-L40P-W 等4機種)におきまして、\n                室内機の制御基板の不具合により、ごく稀に同基板が発煙・発火する恐れがあることが判明いたしました。<br>\n                ご愛用のお客様には、多大なご迷惑をおかけしますことを深くお詫び申し上げます。<br>\n                つきましては、無料で対象機種の点検・修理を実施させていただきますので、下記方法により対象機種をご確認の上、下記の窓口へご連絡いただき、点検・修理までの間は、ご使用をお控えいただきます様、謹んでお願い申し上げます。\n              </p>\n            </div>\n            <section>\n              <h2>対象機種および確認方法</h2>\n              <section>\n                <h3>【対象機種】</h3>\n                <p class=\"note\">2019年11月～2020年7月生産の以下4機種　※2019年製、2020年製が対象です。</p>\n                <div class=\"tableWrapper pcOnly\">\n                  <table>\n                    <thead>\n                    <tr>\n                      <th>機種名(形名)</th>\n                      <th colspan=\"2\">製造番号</th>\n                    </tr>\n                    </thead>\n                    <tbody>\n                    <tr>\n                      <th>AY-L22P-W</th>\n                      <td>91000001 ～ 91000020</td>\n                      <td>01000021 ～ 01003300</td>\n                    </tr>\n                    <tr>\n                      <th>AY-L25P-W</th>\n                      <td>91000001 ～ 91000020</td>\n                      <td>01000021 ～ 01001820</td>\n                    </tr>\n                    <tr>\n                      <th>AY-L28P-W</th>\n                      <td>91000001 ～ 91000020</td>\n                      <td>01000021 ～ 01003520</td>\n                    </tr>\n                    <tr>\n                      <th>AY-L40P-W</th>\n                      <td>91000001 ～ 91000030</td>\n                      <td>01000031 ～ 01004480</td>\n                    </tr>\n                    </tbody>\n                  </table>\n                </div>\n                <div class=\"tableWrapper spOnly\">\n                  <table>\n                    <thead>\n                    <tr>\n                      <th>機種名(形名)</th>\n                      <th>製造番号</th>\n                    </tr>\n                    </thead>\n                    <tbody>\n                    <tr>\n                      <th rowspan=\"2\">AY-L22P-W</th>\n                      <td>91000001 ～ 91000020</td>\n                    </tr>\n                    <tr>\n                      <td>01000021 ～ 01003300</td>\n                    </tr>\n                    <tr>\n                      <th rowspan=\"2\">AY-L25P-W</th>\n                      <td>91000001 ～ 91000020</td>\n                    </tr>\n                    <tr>\n                      <td>01000021 ～ 01001820</td>\n                    </tr>\n                    <tr>\n                      <th rowspan=\"2\">AY-L28P-W</th>\n                      <td>91000001 ～ 91000020</td>\n                    </tr>\n                    <tr>\n                      <td>01000021 ～ 01003520</td>\n                    </tr>\n                    <tr>\n                      <th rowspan=\"2\">AY-L40P-W</th>\n                      <td>91000001 ～ 91000030</td>\n                    </tr>\n                    <tr>\n                      <td>01000031 ～ 01004480</td>\n                    </tr>\n                    </tbody>\n                  </table>\n                </div>\n              </section>\n              <section>\n                <h3>【対象機種の確認方法】</h3>\n                <section>\n                  <h4>エアコン本体下面に貼り付けられている銘板による確認方法</h4>\n                  <div class=\"note\">\n                    <p>機種名(形名)及び製造番号、製造年はエアコン本体下面に貼り付けられている銘板に表示しております。</p>\n                    <picture>\n                      <source class=\"serial-image\" media=\"(max-width: 767px)\"\n                              srcset=\"image/ay_info_220920/serial-plate-sp.png\">\n                      <source class=\"serial-image\" media=\"(min-width: 768px)\"\n                              srcset=\"image/ay_info_220920/serial-plate-pc.png\">\n                      <img alt=\"銘板の左上側に形名を記載しております。中上側に製造番号を記載しております。※2019年製、2020年製が対象です。右上側に製造番号を記載しております。\"\n                           class=\"serial-image\"\n                           height=\"360\"\n                           src=\"image/ay_info_220920/serial-plate-pc.png\"\n                           width=\"760\"></picture>\n                  </div>\n                </section>\n                <section>\n                  <h4>保証書による確認方法</h4>\n                  <div class=\"note\">\n                    <p>機種名(形名)及び製造番号は保証書にも記載しております。</p>\n                    <picture>\n                      <source class=\"serial-image\" media=\"(max-width: 767px)\"\n                              srcset=\"image/ay_info_220920/serial-warranty-sp.png\">\n                      <source class=\"serial-image\" media=\"(min-width: 768px)\"\n                              srcset=\"image/ay_info_220920/serial-warranty.png\">\n                      <img alt=\"保証書の左上側に形名を記載しております。中上側に製造番号を記載しております。\"\n                           class=\"serial-image\"\n                           height=\"360\"\n                           src=\"image/ay_info_220920/serial-warranty.png\"\n                           width=\"760\"></picture>\n                  </div>\n                </section>\n              </section>\n            </section>\n            <section>\n              <h2>お申込み窓口</h2>\n              <section class=\"webEntrySection\">\n                <h3>インターネットによるお申し込み</h3>\n                <form id=\"applicationForm\"\n                      action=\"https://cs.sharp.co.jp/trouble_check/rule/wrp_agreement.html\"\n                      class=\"boxDot ml20 mr20 p15\"\n                >\n                  <p>エアコンの機種名(形名)と製造番号をご入力いただき、『点検の申込フォームへ進む』ボタンを押してください </p>\n                  <input name=\"id\" type=\"hidden\" value=\"ay_tenken03\">\n                  <div class=\"mt10\">\n                    <label class=\"required\" for=\"modelField\">機種名(形名)</label>\n                    <select id=\"modelField\" name=\"kcd\" required class=\"\">\n                      <option value=\"\" hidden selected>選択してください</option>\n                      <option value=\"AY-L22P-W\">AY-L22P-W</option>\n                      <option value=\"AY-L25P-W\">AY-L25P-W</option>\n                      <option value=\"AY-L28P-W\">AY-L28P-W</option>\n                      <option value=\"AY-L40P-W\">AY-L40P-W</option>\n                    </select>\n                  </div>\n                  <div class=\"mt10\">\n                    <label for=\"serialField\" class=\"required\">製造番号</label>\n                    <input id=\"serialField\" inputmode=\"numeric\" maxlength=\"8\" minlength=\"8\"\n                           placeholder=\"例)01234567\"\n                           name=\"sno\" pattern=\"^[0-9]{8}$\" required type=\"text\">\n                    <p class=\"hint\">8桁の数字で入力してください<span class=\"fntRed\">※</span></p>\n                  </div>\n                  <button class=\"mt10 entryButton\" type=\"submit\">&#9654; 点検の申込フォームへ進む</button>\n                  <p class=\"fntNormal fntRed mt05 txtIndent\">※&nbsp;製造番号がご不明な場合は、≪お申し出窓口≫フリーダイヤルにお電話ください</p>\n                  <p class=\"note errorText\" id=\"isTargetMessage\" role=\"alert\"></p>\n                </form>\n              </section>\n              <section>\n                <h3>お電話によるお申し込み</h3>\n                <div class=\"boxDot p15 mb20 ml20 mr20 mt20 txtCen\">\n                  <p class=\"fntBold Fsize01\">《 シャープ エアコン点検受付センター 》</p>\n                  <p class=\"fntBold\">フリーダイヤル（無料）</p>\n                  <p class=\"fntBold fnt150\">0120-251-340</p>\n                  <p class=\"fntBold mt15\">受付時間</p>\n                  <p>月曜～土曜　午前9時～午後6時<br>\n                    日曜・祝日　午前9時～午後5時 </p>\n                </div>\n                <div class=\"fntBold\">《個人情報の取扱いについて》</div>\n                <p>お客様からご提供いただく 氏名、住所、電話番号などの情報は、本件の対応に係わる業務のみに利用させていただきます。<br>\n                  お客様からご提供いただいた個人情報は、弊社が定める個人情報保護方針に従い、厳重に管理いたします。</p>\n              </section>\n            </section>\n          </div>\n        </div>\n      </div>\n    </section>\n  </article>\n</main>\n<div id=\"pageTop\" class=\"default\">\n  <div class=\"page-top-container outer-base-width\">\n    <div class=\"base-width\"><a href=\"#\"><i class=\"fas fa-chevron-up\"></i></a></div>\n  </div>\n  <!-- /outer-base-width -->\n</div>\n<footer id=\"globalFooter\"></footer>\n\n<!-- SCRIPT -->\n<script src=\"/support/products/common/plugin/jquery.allBasics3.js\"></script>\n<script src=\"/support/js/sc-common-parts.js\"></script>\n<script>\n  ScCommonParts.breadcrumbs([\n    {name: '製品に関する大切なお知らせ', url: '/support/announce/'},\n    {name: 'シャープ製エアコンAirestの無料点検・修理のおしらせ', url: ''}\n  ])\n</script>\n<!-- /SCRIPT -->\n\n<!-- support -->\n<script src=\"/support/top/js/global.js\"></script>\n<script>\n  (function () {\n    /** 形名ごとの対象の製造番号範囲(境界値含) */\n    const TARGET_SERIAL_RANGES = {\n      'AY-L22P-W': [\n        {min: 91000001, max: 91000020},\n        {min: 1000021, max: 1003300},\n      ],\n      'AY-L25P-W': [\n        {min: 91000001, max: 91000020},\n        {min: 1000021, max: 1001820},\n      ],\n      'AY-L28P-W': [\n        {min: 91000001, max: 91000020},\n        {min: 1000021, max: 1003520},\n      ],\n      'AY-L40P-W': [\n        {min: 91000001, max: 91000030},\n        {min: 1000031, max: 1004480},\n      ],\n    }\n\n\n    function trimSpace(str) {\n      return str.replace(/[\\t\\s　]/g, '');\n    }\n\n    function zen2han(str) {\n      return str.replace(/[Ａ-Ｚａ-ｚ０-９]/g, function (s) { //全角から半角英数字に統一\n        return String.fromCharCode(s.charCodeAt(0) - 65248);\n            });\n        }\n\n        /**\n         * 製造番号フィールドのonChangeでのフォーマット\n         */\n        function onChangeSerialField(e) {\n            e.target.value = zen2han(trimSpace(e.target.value));\n        }\n\n        /**\n         * @param {string} model - 形名\n         * @param {string} serialNumber - 製造番号\n         * @return {boolean} - 対象機種の対象製造番号ならばtrue, 対象でないならfalseを返す\n         */\n        function isTargetProduct(model, serialNumber) {\n            if (!(model in TARGET_SERIAL_RANGES)) {\n                return false;\n            }\n\n            const ranges = TARGET_SERIAL_RANGES[model];\n            const serialInt = parseInt(serialNumber, 10);\n\n            return ranges.some(function (range) { //いずれかの範囲に含まれるならば対象(境界値含)\n                return range.min <= serialInt && serialInt <= range.max;\n            });\n        }\n\n        /**\n         * 対象機種の判定結果メッセージの差し替え\n         * @param {string} message\n         */\n        function applyIsTargetMessage(message) {\n            document.getElementById('isTargetMessage').innerText = message;\n        }\n\n        /**\n         * @param {Event} e\n         */\n        function onSubmit(e) {\n            const model = document.getElementById('modelField').value;\n            const serialNumber = document.getElementById('serialField').value;\n            const isTarget = isTargetProduct(model, serialNumber);\n            //console.debug(model, serialNumber, isTarget);\n            if (isTarget) {\n                applyIsTargetMessage('');\n            } else {\n                applyIsTargetMessage('ご入力いただいた機種名(形名)・製造番号の製品は点検対象ではございせんでした。\\n製造番号に誤りがないか再度ご確認をお願いいたします。');\n                e.preventDefault();\n            }\n        }\n\n        //初期設定\n        function onLoad() {\n            document.getElementById('serialField').addEventListener('change', onChangeSerialField);\n            document.getElementById('applicationForm').addEventListener('submit', onSubmit);\n        }\n\n        window.document.addEventListener('DOMContentLoaded', onLoad);\n    })();\n</script>\n</body>\n</html>","finalUrl":"https://jp.sharp/support/announce/ay_info_220920.html","rendered":false,"_cachedAt":"2026-06-23T17:56:14.639Z"}