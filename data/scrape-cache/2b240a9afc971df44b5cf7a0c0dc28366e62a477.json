-child__item-->\r\n                  <ul class=\"lib-child__list\">\r\n                    <!-- [START .lib-child__item]-->\r\n                    <li class=\"lib-child__item\"><a href=\"/facilities/\" target=\"\"><span class=\"txt\">医療・福祉の衛生管理</span></a></li>\r\n                    <!-- [START .lib-child__item]-->\r\n                    <li class=\"lib-child__item\"><a href=\"/food-sanitation/\" target=\"\"><span class=\"txt\">食品の衛生管理</span></a></li>\r\n                    <!-- [START .lib-child__item]-->\r\n                    <li class=\"lib-child__item\"><a href=\"/water-sanitation/\" target=\"\"><span class=\"txt\">水の衛生管理</span></a></li>\r\n                    <!-- [START .lib-child__item]-->\r\n                    <li class=\"lib-child__item\"><a href=\"/sanitation-for-life/\" target=\"\"><span class=\"txt\">暮らしの衛生管理</span></a></li>\r\n                  </ul>\r\n                </div>\r\n                <!-- [END .lib-child__outer]-->\r\n              </div>\r\n            </li>\r\n            <li class=\"lib-nav__item\"><a class=\"lib-nav__btn\" href=\"/products/\" target=\"\"><span class=\"txt\">製品案内</span></a></li>\r\n            <li class=\"lib-nav__item\"><a class=\"lib-nav__btn\" href=\"/purelox/\" target=\"\"><span class=\"txt\">ピューラックスについて</span></a></li>\r\n            <li class=\"lib-nav__item\"><a class=\"lib-nav__btn\" href=\"/company/\" target=\"\"><span class=\"txt\">会社情報</span></a></li>\r\n            <li class=\"lib-nav__item\"><a class=\"lib-nav__btn\" href=\"/media/news\" target=\"\"><span class=\"txt\">お知らせ</span></a></li>\r\n          </ul>\r\n          <ul class=\"lib-induce__outer justify-content-center align-items-lg-end\">\r\n            <!-- <li><a class=\"lib-induce__btn --download\" href=\"/estimate/\"><span class=\"txt\">資料請求</span></a></li> -->\r\n            <li class=\"w-auto h-auto\"><a class=\"lib-induce__btn --contact bg-other2 rounded-2 px-3 py-2\" href=\"/contact/\"><span class=\"txt flex-row gap-2\">お問い合わせ/SDS・資料請求</span></a></li>\r\n          </ul>\r\n          <!-- [END .lib-induce__outer]-->\r\n        </div>\r\n        <!-- [END .lib-nav__outer]-->\r\n      </div>\r\n      <!-- [END .lib-nav__cover]-->\r\n    </nav>\r\n    <!-- [END .lib-nav__panel]-->\r\n  </div>\r\n</div>\r\n<!-- [END .lib-header__outer]-->\n\n    <nav class=\"lib-breadcrumb__outer\" aria-label=\"Breadcrumbs\">\n      <div class=\"lib-breadcrumb__inside\">\n        <ol class=\"lib-breadcrumb__list\" itemscope itemtype=\"http://schema.org/BreadcrumbList\">\n          <li itemprop=\"itemListElement\" itemscope itemtype=\"http://schema.org/ListItem\"><a href=\"https://www.oyalox.co.jp/index.html\" itemprop=\"item\"><span itemprop=\"name\">HOME</span></a><meta itemprop=\"position\" content=\"1\" /></li><li itemprop=\"itemListElement\" itemscope itemtype=\"http://schema.org/ListItem\"><a href=\"https://www.oyalox.co.jp/contact.html\" itemprop=\"item\" aria-current=\"location\"><span itemprop=\"name\">お問い合わせ/SDS・資料請求</span></a><meta itemprop=\"position\" content=\"2\" /></li>\n        </ol>\n      </div>\n    </nav>\n    \n    <main id=\"contents\">\n      <!-- ブロック貼り付けエリア -->\n      <div id=\"dcms_layoutPageBlockPasteArea\">\n        <!-- ブロック -->\n        <div id=\"dcms_layoutPageBlock\">\n          <div class=\"lib-hero__outer js-page-main\">\n<div class=\"lib-hero__txtarea wrap\">\n<div class=\"lib-hero__inner\">\n<div class=\"c-under-mv-text-en\">contact</div>\n<h1 class=\"lib-hero__title title\">お問い合わせ/SDS・資料請求</h1>\n</div>\n</div>\n</div>\n<div class=\"container\">\n<div class=\"lib-horizon__row row gy-4 gx-5 flex-md-row border-set\">\n<div class=\"lib-horizon__col col-12 _col-md-8 d-flex align-items-center\">\n<div class=\"lib-card__item\">\n<div class=\"lib-card__txtarea\">\n<div class=\"lib-card__inside\">\n<div class=\"lib-title__outer\">\n<h1 class=\"headline__note\">お問い合わせ注意事項</h1>\n<h2 class=\"lib-card__title fs-h5\"><br /> <span>お問い合わせフォームについて</span></h2>\n</div>\n<ul class=\"before-accent\">\n<li>お問い合わせのフォームからのご回答につきましてはお時間をいただくことがございます。</li>\n<li>お急ぎの場合はお電話でお問合せください。 <a class=\"text-main c-hover --underline\" href=\"/company/office.html\">オーヤラックス営業窓口</a> <br />【受付時間：9：00 ～ 17：00　（土 ・ 日 ・ 祝祭日、 夏期休暇、 年末年始を除く）】</li>\n<li>当社製品以外の内容に関するお問い合わせにつきましては対応しておりません。</li>\n<li>ピューラックスに関するよくある質問は、 <a href=\"/qa.html\">こちらからご覧ください。</a></li>\n<li>セールス・勧誘等はご遠慮ください。</li>\n</ul>\n</div>\n<!-- // lib-card__inside--></div>\n<!-- // lib-card__txtarea--></div>\n<!-- // lib-card__item--></div>\n<div class=\"lib-horizon__col col-12 _col-md-8 d-flex align-items-center\">\n<div class=\"lib-card__item\">\n<div class=\"lib-card__txtarea\">\n<div class=\"lib-card__inside\">\n<div class=\"lib-title__outer\">\n<h2 class=\"lib-card__title fs-h5\">資料(カタログ・取扱説明書・リーフレット)・SDSについて</h2>\n</div>\n<ul class=\"before-accent\">\n<li><span>カタログ・取扱説明書・リーフレット・SDSのダウンロードには会員登録が必要です。 <a href=\"/contact/registration.html\">会員登録はこちら</a> </span></li>\n<li><span>カタログ本体が必要な方は別途お問い合わせよりご連絡ください。発送先につきましては、国内に限らせていただきます。</span></li>\n</ul>\n</div>\n<!-- // lib-card__inside--></div>\n<!-- // lib-card__txtarea--></div>\n<!-- // lib-card__item--></div>\n<!-- . col--></div>\n<!-- .row--></div>\n<div class=\"container --mdl\">\n<div>\n<ul class=\"row row-cols-1 row-cols-md-2 row-cols-lg-3 gy-3 gx-3 justify-content-center\">\n<li class=\"col text-center\">\n<p class=\"pb-2 fs-16 fw-bold\">製品に関するご質問・<br />各種お問い合わせはこちら</p>\n<a class=\"lib-link__btn ico-after-arr justify-content-between\" href=\"/contact/inquiry\"> <span class=\"txt\">お問い合わせ</span> </a></li>\n<li class=\"col text-center\">\n<p class=\"pb-2 fs-16 fw-bold\">カタログ・取扱説明書・リーフレットの<br />ダウンロードはこちら</p>\n<a class=\"lib-link__btn ico-after-arr justify-content-between\" href=\"/catalogue\"> <span class=\"txt\">資料ダウンロード</span> </a></li>\n<li class=\"col text-center\">\n<p class=\"pb-2 fs-16 fw-bold\">SDS（安全データシート）の<br />ダウンロードはこちら</p>\n<a class=\"lib-link__btn ico-after-arr justify-content-between\" href=\"/sds.html\"> <span class=\"txt\">SDSダウンロード</span> </a></li>\n</ul>\n</div>\n</div>\n\n        </div><!-- // ブロック -->\n      </div><!-- // ブロック貼り付けエリア -->\n      \n    </main>\n    <div class=\"lib-column__side\">\n      \n\n    </div>\n    <div class=\"container _mt-0\">\r\n  <div class=\"l-cta d-grid\">\r\n    <div class=\"l-text --fill-box pb-9\">\r\n      <p class=\"lib-card__caption fs-h5 fw-bold text-main tcenter\">Contact</p>\r\n      <div class=\"lib-title__outer tcenter\">\r\n        <h2 class=\"lib-card__title fs-h1\">お問い合わせ</h2>\r\n      </div>\r\n      <div class=\"lib-txt__outer tcenter mt-4 mt-lg-5\">\r\n        <p>衛生や製品に関するご質問、ご相談、<span class=\"d-inline-block\">資料請求などございましたら</span>\r\n<span class=\"d-block\">お気軽にお問い合わせください。</span></p>\r\n      </div>\r\n    </div>\r\n    <div class=\"l-link mw-md bg-wht --fill-box rounded-4 shadow-sm wow fadeInUpSmall\" data-wow-delay=\"0.5s\">\r\n      <ul class=\"row row-cols-1 row-cols-md-2 gy-4 lib-btn__outer --grid\">\r\n        <li class=\"col\">\r\n          <div class=\"c-icon-text column-gap-3 fs-h1 fw-bold text-main\"><img src=\"/dcms_media/image/icon-phone.png\" alt=\"受話器のアイコン\" width=\"23\" height=\"30\">\r\n            <a href=\"tel:03-3263-6201\" class=\"tel\">03-3263-6201</a>\r\n          </div>\r\n          <p class=\"tcenter fs-14 mt-2\">受付時間　9 : 00 ～ 17 : 00(土日祝日除く)</p>\r\n        </li>\r\n        <li class=\"col\"><a class=\"lib-link__btn sizeL bg-other2 ico-before-mail fs-18\" href=\"/contact/\"><span class=\"txt\">資料請求・お問い合わせ</span></a></li>\r\n      </ul>\r\n    </div>\r\n    <div class=\"l-img mw-md vstack justify-content-end align-items-end\">\r\n      <div class=\"wow swing\" data-wow-delay=\"0.5s\" style=\"width: clamp(4.5rem, calc(3.3636363636363633rem + 4.848484848484849vw), 7rem);\"><img src=\"/dcms_media/image/pu-chan.png\" alt=\"ぴゅーちゃん\" width=\"116\" height=\"161\"></div>\r\n    </div>\r\n    <div class=\"l-bg-color bg-lmain rounded-5\">\r\n    </div>\r\n  </div>\r\n</div>\r\n<!-- // lib-cta-BS01--> <footer class=\"js-footer lib-footer__outer lib-foote