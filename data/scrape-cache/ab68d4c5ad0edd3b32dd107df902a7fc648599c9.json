/mv_sakura.svg\" alt=\"\" width=\"320\" height=\"306\">\n\t\t<!-- //pg_mv_header --></div>\n\t\t<p class=\"pg_mv_text_01\">怖がらずに本音で話そう。<br class=\"spbr\">そのドキドキを受け止めるから。</p>\n\t\t<p class=\"pg_mv_text_02\">おいでよ、君の好奇心。</p>\n\t\t<div class=\"pg_mv_img\">\n\t\t\t<picture>\n\t\t\t\t<source media=\"(min-width:769px)\" srcset=\"assets/images/mv_img_pc.jpg\" width=\"1336\" height=\"728\">\n\t\t\t\t<img src=\"assets/images/mv_img_sp.jpg\" alt=\"\" width=\"732\" height=\"600\">\n\t\t\t</picture>\n\t\t</div>\n\t\t<p class=\"pg_mv_text_en\">\n\t\t\t<span class=\"pg_mv_en_01\">\n\t\t\t\t<img src=\"assets/images/mv_en_01.svg\" alt=\"Mito Yakult\" width=\"267\" height=\"142\">\n\t\t\t</span>\n\t\t\t<span class=\"pg_mv_en_02\">\n\t\t\t\t<img src=\"assets/images/mv_en_02.svg\" alt=\"RECRUIT 2027\" width=\"616\" height=\"78\">\n\t\t\t</span>\n\t\t</p>\n\t<!-- //pg_mv --></section>\n\n\t<div class=\"pg_introduction\">\n\t\t<p class=\"pg_introduction_text_01\">\n\t\t\t良心的で価値ある商品を、<br class=\"sp_only\">愛する地域の人々へ。<br>\n\t\t\t水戸の現状や課題を知り、<br class=\"sp_only\">社会に貢献することの意義を<br>\n\t\t\t私たちと一緒に探求してほしい。\n\t\t</p>\n\t\t<p class=\"pg_introduction_text_02\">\n\t\t\t<span>フレッシュな君たちを<br class=\"sp_only\">待っています!</span>\n\t\t</p>\n\t\t<figure class=\"pg_introduction_img\">\n\t\t\t<img src=\"assets/images/home_message_illust.png\" alt=\"\" width=\"1400\" height=\"700\">\n\t\t</figure>\n\t<!-- //pg_introduction --></div>\n\n\t<div class=\"pg_tab_wrap\" data-tab-wrap>\n\t\t<div class=\"pg_tablist\" role=\"tablist\">\n\t\t\t<button type=\"button\" id=\"tab_welfare\" class=\"pg_tablist_button __welfare\" role=\"tab\" aria-controls=\"panel_welfare\" aria-selected=\"true\" tabindex=\"0\" data-tab>\n\t\t\t\t福利厚生\n\t\t\t</button>\n\t\t\t<button type=\"button\" id=\"tab_org\" class=\"pg_tablist_button __org\" role=\"tab\" aria-controls=\"panel_org\" aria-selected=\"false\" tabindex=\"-1\" data-tab>\n\t\t\t\t組織図\n\t\t\t</button>\n\t\t\t<button type=\"button\" id=\"tab_question\" class=\"pg_tablist_button __question\" role=\"tab\" aria-controls=\"panel_question\" aria-selected=\"false\" tabindex=\"-1\" data-tab>\n\t\t\t\tよくある質問\n\t\t\t</button>\n\t\t<!-- //pg_tablist --></div>\n\t\n\t\t<div class=\"pg_tab_body\" data-tabpanel-wrap>\n\t\t\t<section id=\"panel_welfare\" class=\"pg_tabpanel __welfare\" role=\"tabpanel\" aria-labelledby=\"tab_welfare\" tabindex=\"0\" data-tabpanel>\n\t\t\t\t<div class=\"pg_tabpanel_inner\">\n\t\t\t\t\t<div class=\"pg_tabpanel_header\">\n\t\t\t\t\t\t<h2 class=\"pg_tabpanel_title\">\n\t\t\t\t\t\t\t<span class=\"en\" lang=\"en\">WELFARE BENEFITS</span>\n\t\t\t\t\t\t\t<span class=\"ja\">福利厚生</span>\n\t\t\t\t\t\t</h2>\n\t\t\t\t\t\t<p class=\"pg_tabpanel_discription\">\n\t\t\t\t\t\t\t弊社では、従業員の安心・安全と豊かな暮らしをサポートできるよう福利厚生に力をいれています。\n\t\t\t\t\t\t</p>\n\t\t\t\t\t\t<div class=\"pg_tabpanel_icon __welfare\">\n\t\t\t\t\t\t\t<img loading=\"lazy\" src=\"assets/images/home_welfare/tabpanel_icon.svg\" alt=\"\" width=\"181\" height=\"138\">\n\t\t\t\t\t\t</div>\n\t\t\t\t\t<!-- //pg_tabpanel_header --></div>\n\t\t\t\t\t<div class=\"pg_tabpanel_body\">\n\t\t\t\t\t\t<ul class=\"pg_welfare_lists\">\n\t\t\t\t\t\t\t<li>\n\t\t\t\t\t\t\t\t<figure class=\"pg_welfare_figure\">\n\t\t\t\t\t\t\t\t\t<img loading=\"lazy\" src=\"assets/images/home_welfare/icon_01.png\" alt=\"\" width=\"176\" height=\"176\">\n\t\t\t\t\t\t\t\t\t<figcaption>社会保険各種完備</figcaption>\n\t\t\t\t\t\t\t\t</figure>\n\t\t\t\t\t\t\t</li>\n\t\t\t\t\t\t\t<li>\n\t\t\t\t\t\t\t\t<figure class=\"pg_welfare_figure\">\n\t\t\t\t\t\t\t\t\t<img loading=\"lazy\" src=\"assets/images/home_welfare/icon_02.png\" alt=\"\" width=\"176\" height=\"176\">\n\t\t\t\t\t\t\t\t\t<figcaption>定期健康診断</figcaption>\n\t\t\t\t\t\t\t\t</figure>\n\t\t\t\t\t\t\t</li>\n\t\t\t\t\t\t\t<li>\n\t\t\t\t\t\t\t\t<figure class=\"pg_welfare_figure\">\n\t\t\t\t\t\t\t\t\t<img loading=\"lazy\" src=\"assets/images/home_welfare/icon_03.png\" alt=\"\" width=\"176\" height=\"176\">\n\t\t\t\t\t\t\t\t\t<figcaption>出産育児休業<br class=\"spbr\"><span class=\"sp_none\"