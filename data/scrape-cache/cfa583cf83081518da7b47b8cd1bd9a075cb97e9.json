</div>-->\r\n      <div class=\"header-r\">\r\n        <div class=\"navi-bt1\"><a href=\"#qa\">よくある質問</a></div>\r\n        <div class=\"navi-bt1\"><a href=\"#hbt\">販売店一覧</a></div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</div>\r\n<!-- / ヘッダー -->\r\n\r\n<div id=\"wrapper\"> \r\n  \r\n  <!-- メイン -->\r\n  <div id=\"mainBanner\">\r\n    <div class=\"titlebase\">\r\n      <div class=\"topcom\">\r\n        <div class=\"titlepc\"> <img src=\"images/title.png\" width=\"940\" height=\"408\" alt=\"新聞配達スタッフ募集中！\"> </div>\r\n        <div class=\"topcom-m-txt1\">\r\n          <p>朝の短時間で高収入。<br class=\"sp\">\r\n            女性も多数活躍中！</p>\r\n        </div>\r\n        <div class=\"topcom1\">\r\n          <div class=\"topcom1-txt1\">朝の短時間で昼間の<br>\r\n            パート並みの収入が魅力</div>\r\n        </div>\r\n        <div class=\"topcom2\">\r\n          <div class=\"topcom2-txt1\">副業や定年後の<br>アルバイトに最適<br>体への負担も少ないです</div>\r\n        </div>\r\n        <div class=\"topcom3\">\r\n          <div class=\"topcom3-txt1\">運動不足を解消しながら<br>\r\n            お小遣いも稼ぎたい</div>\r\n        </div>\r\n        <div class=\"topcom-m-txt2\">\r\n          <p>配達順路を覚えれば<br class=\"sp\">\r\n            誰にでもできるお仕事です。<br class=\"sp\">\r\n            ゆっくり丁寧に教えます。</p>\r\n        </div>\r\n      </div>\r\n    </div>\r\n    <div class=\"maintxt\">\r\n      <div class=\"maintxt1\">朝の始まりは新聞から。</div>\r\n      <div class=\"maintxt2\">私たちと一緒に<br class=\"sp\">\r\n        働いてみませんか？</div>\r\n      <div class=\"maintxt3\"> 新聞配達は、毎回同じ個所に新聞を届ける仕事です。<br>\r\n        早朝１時間～勤務可能。ダブルワークの方も多数。<br>\r\n        午前３時～６時の間で、自分のペースで働けます。<br>\r\n        短時間で効率よく稼ぎたい方にオススメです。<br>\r\n        興味のある方は、お近くの山形新聞販売店にお問い合わせください。 </div>\r\n    </div>\r\n    <div class=\"com\">\r\n      <div class=\"com1\">\r\n        <div class=\"com1-txt1\">★月収</div>\r\n        <div class=\"com1-txt2\">４万円～８万円</div>\r\n        <div class=\"com1-txt3\">（１日１～２時間勤務）</div>\r\n        <div class=\"com1-txt4\">※市街地で100～200部を<br>\r\n          &emsp;配達した場合のモデル</div>\r\n      </div>\r\n      <div class=\"com2\">\r\n        <div class=\"com2-txt1\">未経験OK！</div>\r\n        <div class=\"com2-txt2\">短時間OK！</div>\r\n        <div class=\"com2-txt3\">ダブルワーク<br>\r\n          の方活躍中！</div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n  <!-- / メイン --> \r\n  \r\n  <!-- Q&A -->\r\n  \r\n  <div class=\"shikirisen-qa\">\r\n    <div id=\"qa\" class=\"yokuarushitsumon-title-base\">\r\n      <div class=\"yokuarushitsumon-title-txt\"> <span>未経験でも安心！<br>\r\n        </span>よくある質問 </div>\r\n    </div>\r\n  </div>\r\n  \r\n  <!-- QAここから -->\r\n  <div class=\"qa\">\r\n    <div class=\"qa-l\">\r\n      <div class=\"qa-l-set\">\r\n        <div class=\"q-all\">\r\n          <div class=\"q-l\"><img src=\"images/qmoji.png\"  height=\"50\" alt=\"Q\"></div>\r\n          <div class=\"q-r\">\r\n            <p>配達場所を覚えら<br>\r\n              れるか心配です…</p>\r\n          </div>\r\n          <div class=\"q-c\"><img src=\"images/c1.png\" alt=\"\" height=\"80\"></div>\r\n        </div>\r\n        <div class=\"a-all\">\r\n          <div class=\"a-l\"><img src=\"images/amoji.png\"  height=\"50\" alt=\"A\"></div>\r\n          <div class=\"a-r\">\r\n            <p>ご安心ください。<br>\r\n              販売店スタッフが、地図に<br>\r\n              基づいて丁寧にお教えします。</p>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n    <div class=\"qa-r\">\r\n      <div class=\"qa-r-set\">\r\n        <div class=\"q-all\">\r\n          <div class=\"q-l\"><img src=\"images/qmoji.png\"  height=\"50\" alt=\"Q\"></div>\r\n          <div class=\"q-r\">\r\n            <p>休みはとれますか？</p>\r\n          </div>\r\n          <div class=\"q-c\"><img src=\"images/c2.png\" alt=\"\" height=\"80\"></div>\r\n        </div>\r\n        <div class=\"a-all\">\r\n          <div class=\"a-l\"><img src=\"images/amoji.png\"  height=\"50\" alt=\"A\"></div>\r\n          <div class=\"a-r\">\r\n            <p>月１回の休刊日のほか、<br>\r\n              事前に相談いただければ販売店<br>\r\n              スタッフが代理で配達しますので<br>\r\n              心配無用です。週３日程度の勤務<br>\r\n              の方もいます。</p>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n  <!-- QAここまで --> \r\n  \r\n  <!-- QAここから -->\r\n  <div class=\"qa\">\r\n    <div class=\"qa-l\">\r\n      <div class=\"qa-l-set\">\r\n        <div class=\"q-all\">\r\n          <div class=\"q-l\"><img src=\"images/qmoji.png\"  height=\"50\" alt=\"Q\"></div>\r\n          <div class=\"q-r\">\r\n            <p>配達は原付バイクに<br>\r\n              乗らないとダメ？</p>\r\n          </div>\r\n          <div class=\"q-c\"><img src=\"images/c3.png\" alt=\"\" height=\"80\"></div>\r\n        </div>\r\n        <div class=\"a-all\">\r\n          <div class=\"a-l\"><img src=\"images/amoji.png\"  height=\"50\" alt=\"A\"></div>\r\n          <div class=\"a-r\">\r\n            <p>自家用車や自転車での配達も<br>\r\n              可能です。また、ほとんどの方が<br>\r\n              初めは原付バイク未経験です。<br>\r\n              乗り方も含めてスタッフが丁寧に<br>\r\n              教えます。</p>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n    <div class=\"qa-r\">\r\n      <div class=\"qa-r-set\">\r\n        <div class=\"q-all\">\r\n          <div class=\"q-l\"><img src=\"images/qmoji.png\"  height=\"50\" alt=\"Q\"></div>\r\n          <div class=\"q-r\">\r\n            <p>配達中のケガや<br>\r\n              事故が発生した場合<br>\r\n              はどうなるの？</p>\r\n          </div>\r\n          <div class=\"q-c\"><img src=\"images/c4.png\" alt=\"\" height=\"80\"></div>\r\n        </div>\r\n        <div class=\"a-all\">\r\n          <div class=\"a-l\"><img src=\"images/amoji.png\"  height=\"50\" alt=\"A\"></div>\r\n          <div class=\"a-r\">\r\n            <p>団体傷害保険や労災で対応<br>\r\n              いたします。皆さんが安全に安心<br>\r\n              して仕事ができるようにしていま<br class=\"sp\">す。</p>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n  <!-- QAここまで --> \r\n  \r\n  <!-- QAここから -->\r\n  <div class=\"qa\">\r\n    <div class=\"qa-l\">\r\n      <div class=\"qa-l-set\">\r\n        <div class=\"q-all\">\r\n          <div class=\"q-l\"><img src=\"images/qmoji.png\"  height=\"50\" alt=\"Q\"></div>\r\n          <div class=\"q-r\">\r\n            <p>配達部数は少なくても<br>\r\n              大丈夫？</p>\r\n          </div>\r\n          <div class=\"q-c\"><img src=\"images/c5.png\" alt=\"\" height=\"80\"></div>\r\n        </div>\r\n        <div class=\"a-all\">\r\n          <div class=\"a-l\"><img src=\"images/amoji.png\"  height=\"50\" alt=\"A\"></div>\r\n          <div class=\"a-r\">\r\n            <p>少ない部数で、という方も<br>\r\n              ご安心ください。<br>\r\n              近所を徒歩で配達される方も<br>\r\n              いらっしゃいます。</p>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n    <div class=\"qa-r\">\r\n      <div class=\"qa-r-set\">\r\n        <div class=\"q-all\">\r\n          <div class=\"q-l\"><img src=\"images/qmoji.png\"  height=\"50\" alt=\"Q\"></div>\r\n          <div class=\"q-r\">\r\n            <p>配達時間は何時から<br>\r\n              何時まで？</p>\r\n          </div>\r\n          <div class=\"q-c\"><img src=\"images/c6.png\" alt=\"\" height=\"80\"></div>\r\n        </div>\r\n        <div class=\"a-all\">\r\n          <div class=\"a-l\"><img src=\"images/amoji.png\"  height=\"50\" alt=\"A\"></div>\r\n          <div class=\"a-r\">\r\n            <p>地域によって差はありますが、<br>\r\n              午前３時から午前６時までの間で<br>\r\n              配達をお願いしています。<br>\r\n              詳しい配達開始時間は販売店に<br>\r\n              お問い合わせをお願いします。 </p>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n  <!-- QAここまで --> \r\n  \r\n  <!-- / Q&A -->\r\n  \r\n  <div class=\"shikirisen\" id=\"hbt\"></div>\r\n  \r\n  <!-- 販売店一覧 -->\r\n  \r\n  <div class=\"hanbaitenichiran-title-waku\">\r\n    <div class=\"hanbaitenichiran-title-base\">\r\n      <div class=\"hanbaitenichiran-title-txt\">山形新聞販売店一覧</div>\r\n    </div>\r\n  </div>\r\n  <div class=\"ken-area\"> <img src=\"images/okitama-area.png\" width=\"257\" height=\"200\" alt=\"置賜エリア\"> </div>\r\n  <div class=\"gridWrapper\">\r\n    <div class=\"grid colDark\">\r\n      <div clas