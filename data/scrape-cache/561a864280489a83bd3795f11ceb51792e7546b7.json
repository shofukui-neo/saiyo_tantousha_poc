=\"https://ryu-tsu.jp/\"><img src=\"https://ryu-tsu.jp/wp-content/themes/ryu-tsu/img/common/logo.png\" alt=\"鳥取県倉吉市 運送・観光・イベント 流通株式会社\">\r\n\t\t\t</a>\r\n\t\t\t\t<nav id=\"gnav\" class=\"gnav\" role=\"navigation\">\r\n\t\t\t<ul id=\"menu-%e3%82%b0%e3%83%ad%e3%83%bc%e3%83%90%e3%83%ab%e3%83%a1%e3%83%8b%e3%83%a5%e3%83%bc\" class=\"gnav__list\"><li id=\"menu-item-30\" class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-home menu-item-30\"><a href=\"https://ryu-tsu.jp/\">TOP</a></li>\n<li id=\"menu-item-31\" class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-31\"><a href=\"https://ryu-tsu.jp/about/\">流通について</a></li>\n<li id=\"menu-item-32\" class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-32\"><a href=\"https://ryu-tsu.jp/service/\">サービス</a></li>\n<li id=\"menu-item-41\" class=\"menu-item menu-item-type-custom menu-item-object-custom menu-item-41\"><a href=\"http://ryu-tsu.jp/news\">NEWS</a></li>\n<li id=\"menu-item-131\" class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-131\"><a href=\"https://ryu-tsu.jp/voices/\">お客様の声</a></li>\n<li id=\"menu-item-43\" class=\"menu-item menu-item-type-custom menu-item-object-custom menu-item-43\"><a href=\"http://ryu-tsu.jp/blog\">ブログ</a></li>\n<li id=\"menu-item-40\" class=\"menu-item menu-item-type-post_type menu-item-object-page current-menu-item page_item page-item-28 current_page_item menu-item-40\"><a href=\"https://ryu-tsu.jp/recruit/\" aria-current=\"page\">リクルート</a></li>\n</ul>\t\t\t<div class=\"gnav__search\">\r\n\t\t\t\t<form class=\"searchform\" method=\"GET\" action=\"/\"  role=\"search\">\r\n  <input type=\"text\" name=\"s\" value=\"\" id=\"search_text\" placeholder=\"\">\r\n  <button type=\"submit\">検索</button>\r\n</form>\r\n\t\t\t</div>\r\n\t\t\t<a class=\"gnav__tel\" href=\"tel:0120221211\">0120-22-1211</a>\r\n\t\t\t<a class=\"gnav__contact\" href=\"https://ryu-tsu.jp/contact/\"><span>お問い合わせ</span></a>\r\n\t\t</nav>\r\n\t\t<div class=\"gnav__search d--sp d--tab\">\r\n\t\t\t\t<form class=\"searchform\" method=\"GET\" action=\"/\"  role=\"search\">\r\n  <input type=\"text\" name=\"s\" value=\"\" id=\"search_text\" placeholder=\"\">\r\n  <button type=\"submit\">検索</button>\r\n</form>\r\n\t\t\t</div>\r\n\t\t<button id=\"header__hm\" class=\"header__hm\"><span></span><span></span><span></span></button>\r\n\t</div>\r\n</header>\r\n\r\n\r\n\t<div class=\"page-title\">\r\n\t\t<h1>リクルート</h1>\t</div>\r\n\r\n<div class=\"contents clearfix\">\r\n\t<main class=\"main\" role=\"main\">\r\n\n<article class=\"recruit post-28 page type-page status-publish hentry\">\n\t<div class=\"recruit-lead\">\r\n\t<div class=\"container\">\r\n\t\t<p class=\"mb-1\">流通株式会社は、鳥取県倉吉市を本社とし、<br class=\"d--pc d--tab\">鳥取市・倉吉市・米子市・松江市の合計4拠点で<br class=\"d--pc d--tab\">地域密着サービス業を行っています。</p>\r\n\t\t<p class=\"mb-1\">運送事業・バス事業・イベント事業・人材サービス事業をメインの事業とし、<br class=\"d--pc d--tab\">地域に欠かせない会社をめざし、<br class=\"d--pc d--tab\">お客様のお困りごとに耳を傾けています♪</p>\r\n\t\t<p class=\"mb-3\">私たちは「地域密着サービス業」の<br class=\"d--pc d--tab\">リーディングカンパニーを目指しています。</p>\r\n\t</div>\r\n</div>\r\n\r\n<div class=\"recruit-link\">\r\n\t<div class=\"container\">\r\n\t\t<h2 class=\"heading3 heading3--has-border\"><span>詳しいリクルートページへ</span></h2>\r\n\t\t<ul>\r\n\t\t\t<li>\r\n\t\t\t\t<a href=\"https://furusato.tori-info.co.jp/kigyo_guide/search/349//\" target=\"_blank\" rel=\"noopener noreferrer\">\r\n\t\t\t\t\t<figure><img decoding=\"async\" src=\"https://ryu-tsu.jp/wp-content/themes/ryu-tsu/img/recruit/link_img01.jpg\" alt=\"学生さんはこちら\"></figure>\r\n\t\t\t\t\t<p>新卒採用</p>\r\n\t\t\t\t</a>\r\n\t\t\t</li>\r\n\t\t\t<li>\r\n\t\t\t\t<a href=\"https://ryu-tsu.jp/blog/5618/\" target=\"_blank\" rel=\"noopener noreferrer\">\r\n\t\t\t\t\t<figure><img decoding=\"async\" src=\"https://ryu-tsu.jp/wp-content/themes/ryu-tsu/img/recruit/link_img02.jpg\" alt=\"現在募集中の職種はこちら\"></figure>\r\n\t\t\t\t\t<p>中途採用</p>\r\n\t\t\t\t</a>\r\n\t\t\t</li>\r\n\t\t\t\r\n\t\t</ul>\r\n\t</div>\r\n</div>\r\n\r\n<div class=\"recruit-talent\">\r\n\t<div class=\"container\">\r\n\t\t<h2 class=\"heading3 heading3--has-border\"><span>求める人材</span></h2>\r\n\t\t<p class=\"mb-1\">当社は、「地域の皆様のお役に立つ仕事！」を目指し、日々進化し続けています。<br>\r\n\t\tそんな変化に富んだ当社が求めるのは、<br class=\"d--pc d--tab\"><span class=\"fc-theme\">「地元山陰が好きな方」</span></p>\r\n\t\t<p>そして、変化に対応するべく、<br class=\"d--pc d--tab\"><span class=\"fc-theme\">「受け身ではなく、自分で考え行動できる方」</span>を求めています！</p>\r\n\t\t<p class=\"mb-2\">私たちは<span class=\"fc-theme\">「3年前と同じことをしていない」</span>ことを大切にし<br class=\"d--pc d--tab\">進化し続けるチームです。</p>\r\n\t\t<div class=\"recruit-talent__media\">\r\n\t\t\t<iframe src=\"https://www.youtube.com/embed/mNAcAaa_siE\" frameborder=\"0\" allow=\"accelerometer; autoplay; encrypted-media; gyroscope; picture-in-picture\" allowfullscreen></iframe>\r\n\t\t</div>\r\n\t</div>\r\n</div>\r\n\r\n<div class=\"recruit-challenging\">\r\n\t<div class=\"container\">\r\n\t\t<h2 class=\"heading3 heading3--has-border\"><span>仕事のやりがい</span></h2>\r\n\t\t<p class=\"mb-1\">当社はお客さまから直接「<span class=\"fc-theme\">ありがとう</span>」と言って頂ける仕事。</p>\r\n\t\t<p class=\"mb-1\">お客さまの目の前でサービス行うことが多いため、<br class=\"d--pc d--tab\">喜んでいただけるかどうかの反応がすぐにわかります。</p>\r\n\t\t<p class=\"mb-1\">また、変化に挑戦する社風のため未経験なことに挑戦する機会が多く、<br class=\"d--pc d--tab\">成⻑を実感できます！</p>\r\n\t\t<p>新卒入社が社員の半分を占め、<br class=\"d--pc d--tab\"><p>教え合う文化が出来ているので安心してスタートできます♪</p>\r\n\t</div>\r\n</div>\r\n\r\n<div class=\"recruit-gallery\">\r\n\t<img decoding=\"async\" src=\"https://ryu-tsu.jp/wp-content/themes/ryu-tsu/img/recruit/challenging_img01.jpg\" alt=\"仕事のやりがい\">\r\n\t<img decoding=\"async\" src=\"https://ryu-tsu.jp/wp-content/themes/ryu-tsu/img/recruit/challenging_img02.jpg\" alt=\"仕事のやりがい\">\r\n\t<img decoding=\"async\" src=\"https://ryu-tsu.jp/wp-content/themes/ryu-tsu/img/recruit/challenging_img03.jpg\" alt=\"仕事のやりがい\">\r\n</div>\r\n\r\n<div class=\"recruit-appeal\">\r\n\t<div class=\"container\">\r\n\t\t<h2 class=\"heading3 heading3--has-border\"><span>流通の魅力！</span></h2>\r\n\t\t<ol class=\"mt-4\">\r\n\t\t\t<li>\r\n\t\t\t\t<figure><img decoding=\"async\" src=\"https://ryu-tsu.jp/wp-content/themes/ryu-tsu/img/recruit/appeal_img01.jpg\" alt=\"資格取得費用は会社が負担！\"></figure>\r\n\t\t\t\t<div class=\"recruit-appeal__inner\">\r\n\t\t\t\t\t<h3>資格取得費用は会社が負担！</h3>\r\n\t\t\t\t\t<p>準中型〜大型バスの免許など、様々な資格を取得可能！<br>\r\n\t\t\t\t\tスキルや経験に合わせて取得できるので、<br class=\"d--pc d--tab\">個人のペースで確実にスキルアップができます。</p>\r\n\t\t\t\t</div>\r\n\t\t\t</li>\r\n\t\t\t<li>\r\n\t\t\t\t<figure><img decoding=\"async\" src=\"https://ryu-tsu.jp/wp-content/themes/ryu-tsu/img/recruit/appeal_img02.jpg\" alt=\"毎年14日間の連続休暇が取得できる！\"></figure>\r\n\t\t\t\t<div class=\"recruit-appeal__inner\">\r\n\t\t\t\t\t<h3>毎年14日間の連続休暇が取得できる！</h3>\r\n\t\t\t\t\t<p>年に1回、好きな時に連続休暇の取れる、<br class=\"d--pc d--tab\">「わくわくホリデー」制度を実施しています！<br>\r\n\t\t\t\t\tひとり旅や家族サービスなど使い方は人それぞれ。<br>\r\n\t\t\t\t\t休暇中の仕事は他のスタッフが 代わりに行うルールのため、<br class=\"d--pc d--tab\">完全プライベートなお休みを取る事ができます！</p>\r\n\t\t\t\t</div>\r\n\t\t\t</li>\r\n\t\t\t<li>\r\n\t\t\t\t<figure><img decoding=\"async\" src=\"https://ryu-tsu.jp/wp-content/themes/ryu-tsu/img/recruit/appeal_img03.jpg\" alt=\"会社行事で親密度アップ！\"></figure>\r\n\t\t\t\t<div class=\"recruit-appeal__inner\">\r\n\t\t\t\t\t<h3>会社行事で親密度アップ！</h3>\r\n\t\t\t\t\t<p>アットホームな雰囲気が流通の特徴。<br>\r\n\t\t\t\t\tサービス業なのでチームワークがとっても大切！<br>\r\n\t\t\t\t\tなので、旅行や飲み会など、<br class=\"d--pc d--tab\">スタッフ同士がコミュニケーションを取れる場を<br class=\"d--pc d--tab\">積極的に設けています！</p>\r\n\t\t\t\t</div>\r\n\t\t\t</li>\r\n\t\t</ol>\r\n\t</div>\r\n</div>\r\n\r\n<div class=\"recruit-link main__bottomcontents\">\r\n\t<div class=\"container\">\r\n\t\t<h2 class=\"heading3 heading3--has-border\"><span>詳しいリクルートページへ</span></h2>\r\n\t\t<ul>\r\n\t\t\t<li>\r\n\t\t\t\t<a href=\"https://recruit.ryu-tsu.jp/\" target=\"_blank\" rel=\"noopener noreferrer\">\r\n\t\t\t\t\t<figure><img decoding=\"async\" src=\"https://ryu-tsu.jp/wp-content/themes/ryu-tsu/img/recruit/link_img01.jpg\" alt=\"学生さんはこちら\"></figure>\r\n\t\t\t\t\t<p>新卒採用</p>\r\n\t\t\t\t</a>\r\n\t\t\t</li>\r\n\t\t\t<li>\r\n\t\t\t\t<a href=\"https://ryu-tsu.jp/blog/5618/\" target=\"_blank\" rel=\"noopener noreferrer\">\r\n\t\t\t\t\t<figure><img decoding=\"async\" src=\"https://ryu-tsu.jp/wp-content/themes/ryu-tsu/img/recruit/link_img02.jpg\" alt=\"現在募集中の職種はこちら\"></figure>\r\n\t\t\t\t\t<p>中途採用</p>\r\n\t\t\t\t</a>\r\n\t\t\t</li>\r\n\t\t\t\r\n\t\t</ul>\r\n\t</div>\r\n</div></article>\n\n\r\n\t\t\t</main>\r\n\r\n\t</div>\r\n\r\n<footer class=\"footer\">\r\n\t<div class=\"container\">\r\n\t\t<div class=\"clearfix\">\r\n\t\t\t<a class=\"footer__logo\" href=\"https://ryu-tsu.jp/\"><img src=\"https://ryu-tsu.jp/wp-content/themes/ryu-tsu/img/common/logo.png\" alt=\"鳥取県倉吉市 運送・観光・イベント 流通株式会社\"></a>\r\n\t\t\t<ul class=\"footer__store\">\r\n\t\t\t\t<li><a href=\"tel:0857311211\"><span>鳥取店</span><span>0857-31-1211</span></a></li>\r\n\t\t\t\t<li><a href=\"tel:0858221211\"><span>倉吉店</span><span>0858-22-1211</span></a></li>\r\n\t\t\t\t<li><a href=\"tel:0859371211\"><span>米子店</span><span>0859-37-1211</span></a></li>\r\n\t\t\t\t<li><a href=\"tel:0852321211\"><span>松江店</span><span>0852-32-1211</span></a></li>\r\n\t\t\t</ul>\r\n\t\t</div>\r\n\t\t<nav class=\"footer__nav\">\r\n\t\t\t<ul id=\"menu-%e3%82%b0%e3%83%ad%e3%83%bc%e3%83%90%e3%83%ab%e3%83%a1%e3%83%8b%e3%83%a5%e3%83%bc-1\" class=\"footer__nav-list\"><li class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-home menu-item-30\"><a href=\"https://ryu-tsu.jp/\">TOP</a></li>\n<li class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-31\"><a href=\"https://ryu-tsu.jp/about/\">流通について</a></li>\n<li class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-32\"><a href=\"https://ryu-tsu.jp/service/\">サービス</a></li>\n<li class=\"menu-item menu-item-type-custom menu-item-object-custom menu-item-41\"><a href=\"http://ryu-tsu.jp/news\">NEWS</a></li>\n<li class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-131\"><a href=\"https://ryu-tsu.jp/voices/\">お客様の声</a></li>\n<li class=\"menu-item menu-item-type-cu