es/ktd_wp/img/ig.svg\" alt=\"\">\n</a>\n</div>\n</div>\n</div>\n</div>\n</div>\n</header>\n<main class=\"main main-page\">\n<!-- eyecatch -->\n<div class=\"eyecatch eyecatch-entry\">\n<div class=\"eyecatch-inner\">\n<h1 class=\"page-title\">\n<span class=\"jp murecho\">\n採用エントリー\n</span>\n<span class=\"en\">\nENTRY\n</span>\n</h1>\n</div>\n</div>\n<!-- entry -->\n<section class=\"entry fadeUpTrigger\">\n<div class=\"inner\">\n<div class=\"entry-form\">\n<div class=\"wpcf7 no-js\" id=\"wpcf7-f31-o1\" lang=\"ja\" dir=\"ltr\" data-wpcf7-id=\"31\">\n<div class=\"screen-reader-response\"><p role=\"status\" aria-live=\"polite\" aria-atomic=\"true\"></p> <ul></ul></div>\n<form action=\"/entry/#wpcf7-f31-o1\" method=\"post\" class=\"wpcf7-form init\" aria-label=\"コンタクトフォーム\" enctype=\"multipart/form-data\" novalidate=\"novalidate\" data-status=\"init\">\n<fieldset class=\"hidden-fields-container\"><input type=\"hidden\" name=\"_wpcf7\" value=\"31\"/><input type=\"hidden\" name=\"_wpcf7_version\" value=\"6.1.6\"/><input type=\"hidden\" name=\"_wpcf7_locale\" value=\"ja\"/><input type=\"hidden\" name=\"_wpcf7_unit_tag\" value=\"wpcf7-f31-o1\"/><input type=\"hidden\" name=\"_wpcf7_container_post\" value=\"0\"/><input type=\"hidden\" name=\"_wpcf7_posted_data_hash\" value=\"\"/>\n</fieldset>\n<div class=\"Form\">\n<ul class=\"entry-list\">\n<li>\n<p>【必須】項目は必ずご入力ください。\n</p>\n</li>\n<li>\n<p>迷惑メール対策でドメイン指定受信の設定をされている場合、メールが受信出来ない場合がございます。\n</p>\n</li>\n<li>\n<p>携帯電話のメールアドレスでご応募をする場合は、「受信拒否設定」を解除してください。受信拒否設定をした状態でご応募をする場合は、ドメイン@kanto-d.co.jpを「受信許可」に設定してください。\n</p>\n</li>\n<li>\n<p>自動返信メールが迷惑メールに振り分けられる場合があります。届かない場合はご確認ください。\n</p>\n</li>\n<li>\n<p>数日経っても返信がない場合は、お手数ですがお電話にてご連絡ください。\n</p>\n</li>\n</ul>\n<div class=\"contact-table\">\n<table>\n<tr>\n<td>\n<p><label for=\"name01\" class=\"label\">お名前<span class=\"required\">必須</span></label>\n</p>\n</td>\n<td>\n<p><span class=\"wpcf7-form-control-wrap\" data-name=\"name01\"><input size=\"40\" maxlength=\"400\" class=\"wpcf7-form-control wpcf7-text wpcf7-validates-as-required\" id=\"name01\" aria-required=\"true\" aria-invalid=\"false\" placeholder=\"例）山田花子\" value=\"\" type=\"text\" name=\"name01\"/></span>\n</p>\n</td>\n</tr>\n<tr>\n<td>\n<p><label for=\"name02\" class=\"label\">フリガナ<span class=\"required\">必須</span></label>\n</p>\n</td>\n<td>\n<p><span class=\"wpcf7-form-control-wrap\" data-name=\"name02\"><input size=\"40\" maxlength=\"400\" class=\"wpcf7-form-control wpcf7-text wpcf7-validates-as-required\" id=\"name02\" aria-required=\"true\" aria-invalid=\"false\" placeholder=\"例）ヤマダハナコ\" value=\"\" type=\"text\" name=\"name02\"/></span>\n</p>\n</td>\n</tr>\n<tr>\n<td>\n<p><label for=\"birth\" class=\"label\">生年月日<span class=\"required\">必須</span></label>\n</p>\n</td>\n<td>\n<p><span class=\"wpcf7-form-control-wrap\" data-name=\"birth\"><input size=\"40\" maxlength=\"400\" class=\"wpcf7-form-control wpcf7-text wpcf7-validates-as-required\" id=\"birth\" aria-required=\"true\" aria-invalid=\"false\" placeholder=\"例）2001年1月1日の場合：20010101\" value=\"\" type=\"text\" name=\"birth\"/></span>\n</p>\n</td>\n</tr>\n<tr>\n<td>\n<p><label for=\"postcode\" class=\"label\">郵便番号<span class=\"required\">必須</span></label>\n</p>\n</td>\n<td>\n<p><span class=\"wpcf7-form-control-wrap\" data-name=\"postcode\"><input size=\"40\" maxlength=\"400\" class=\"wpcf7-form-control wpcf7-text wpcf7-validates-as-required\" id=\"postcode\" aria-required=\"true\" aria-invalid=\"false\" placeholder=\"例）0001234（ハイフンなし）\" value=\"\" type=\"text\" name=\"postcode\"/></span>\n</p>\n</td>\n</tr>\n<tr>\n<td>\n<p><label for=\"prefectures\" class=\"label\">住所<span class=\"required\">必須</span></label>\n</p>\n</td>\n<td>\n<p><span class=\"wpcf7-form-control-wrap\" data-name=\"prefectures\"><input size=\"40\" maxlength=\"400\" class=\"wpcf7-form-control wpcf7-text wpcf7-validates-as-required\" id=\"prefectures\" aria-required=\"true\" aria-invalid=\"false\" placeholder=\"例）埼玉県川越市天沼新田319-6\" value=\"\" type=\"text\" name=\"prefectures\"/></span>\n</p>\n</td>\n</tr>\n<tr>\n<td>\n<p><label for=\"tel\" class=\"label\">電話番号<span class=\"required\">必須</span></label>\n</p>\n</td>\n<td>\n<p><span class=\"wpcf7-form-control-wrap\" data-name=\"tel\"><input size=\"40\" maxlength=\"400\" class=\"wpcf7-form-control wpcf7-tel wpcf7-validates-as-required wpcf7-text wpcf7-validates-as-tel\" id=\"tel\" aria-required=\"true\" aria-invalid=\"false\" placeholder=\"例）電話番号を入力してください\" value=\"\" type=\"tel\" name=\"tel\"/></span>\n</p>\n</td>\n</tr>\n<tr>\n<td>\n<p><label for=\"your-email\" class=\"label\">メール<span class=\"required\">必須</span></label>\n</p>\n</td>\n<td>\n<p><span class=\"wpcf7-form-control-wrap\" data-name=\"your-email\"><input size=\"40\" maxlength=\"400\" class=\"wpcf7-form-control wpcf7-email wpcf7-validates-as-required wpcf7-text wpcf7-validates-as-email\" id=\"your-email\" autocomplete=\"email\" aria-required=\"true\" aria-invalid=\"false\" placeholder=\"例）メールアドレスを入力してください\" value=\"\" type=\"email\" name=\"your-email\"/></span>\n</p>\n</td>\n</tr>\n<tr>\n<td>\n<p><label for=\"your-email-confirm\" class=\"label\">メール（確認）<span class=\"required\">必須</span></label>\n</p>\n</td>\n<td>\n<p><span class=\"wpcf7-form-control-wrap\" data-name=\"your-email-confirm\"><input size=\"40\" maxlength=\"400\" class=\"wpcf7-form-control wpcf7-email wpcf7-validates-as-required wpcf7-text wpcf7-validates-as-email\" id=\"your-email-confirm\" aria-required=\"true\" aria-invalid=\"false\" placeholder=\"例）メールアドレスを入力してください\" value=\"\" type=\"email\" name=\"your-email-confirm\"/></span>\n</p>\n</td>\n</tr>\n<tr class=\"contact-file\">\n<td>\n<p><label for=\"file01\" class=\"label\">履歴書</label>\n</p>\n</td>\n<td>\n<p><span class=\"wpcf7-form-control-wrap\" data-name=\"file01\"><input size=\"40\" class=\"wpcf7-form-control wpcf7-file\" accept=\".jpg,.jpeg,.png,.gif,.pdf\" aria-invalid=\"false\" type=\"file\" name=\"file01\"/></span>\n</p>\n</td>\n</tr>\n<tr class=\"contact-file\">\n<td>\n<p><label for=\"file02\" class=\"label\">職務経歴書</label>\n</p>\n</td>\n<td>\n<p><span class=\"wpcf7-form-control-wrap\" data-name=\"file02\"><input size=\"40\" class=\"wpcf7-form-control wpcf7-file\" accept=\".jpg,.jpeg,.png,.gif,.pdf\" aria-invalid=\"false\" type=\"file\" name=\"file02\"/></span>\n</p>\n</td>\n</tr>\n<tr>\n<td>\n<p><label for=\"textarea\" class=\"label\">自己PR<span class=\"required\">必須</span></label>\n</p>\n</td>\n<td>\n<p><span class=\"wpcf7-form-control-wrap\" data-name=\"textarea\"><textarea cols=\"40\" rows=\"10\" maxlength=\"2000\" class=\"wpcf7-form-control wpcf7-textarea wpcf7-validates-as-required\" id=\"textarea\" aria-required=\"true\" aria-invalid=\"false\" placeholder=\"メッセージ内容をご記入ください\" name=\"textarea\"></textarea></span>\n</p>\n</td>\n</tr>\n<tr class=\"contact-check\">\n<td>\n<p><label for=\"check\" class=\"label\">求人募集を知った媒体<span class=\"required\">必須</span></label>\n</p>\n</td>\n<td>\n<div class=\"check\">\n<p><span class=\"wpcf7-form-control-wrap\" data-name=\"check\"><span class=\"wpcf7-form-control wpcf7-checkbox wpcf7-validates-as-required\" id=\"check\"><span class=\"wpcf7-list-item first\"><label><input type=\"checkbox\" name=\"check[]\" value=\"Instagram\"/><span class=\"wpcf7-list-item-label\">Instagram</span></label></span><span class=\"wpcf7-list-item\"><label><input type=\"checkbox\" name=\"check[]\" value=\"ホームページ\"/><span class=\"wpcf7-list-item-label\">ホームページ</span></label></span><span class=\"wpcf7-list-item\"><label><input type=\"checkbox\" name=\"check[]\" value=\"学校からの紹介\"/><span class=\"wpcf7-list-item-label\">学校からの紹介</span></label></span><span class=\"wpcf7-list-item\"><label><input type=\"checkbox\" name=\"check[]\" value=\"知人からの情報\"/><span class=\"wpcf7-list-item-label\">知人からの情報</span></label></span><span class=\"wpcf7-list-item last\"><label><input type=\"checkbox\" name=\"check[]\" value=\"その他\"/><span class=\"wpcf7-list-item-label\">その他</span></label></span></span></span>\n</p>\n</div>\n</td>\n</tr>\n<tr class=\"form-privacy\">\n<td>\n<p><label for=\"privacy\" class=\"label\">個人情報の取り扱い<span class=\"required\">必須</span></label>\n</p>\n</td>\n<td>\n<p><span class=\"wpcf7-form-control-wrap\" data-name=\"form-check\"><span class=\"wpcf7-form-control wpcf7-checkbox wpcf7-validates-as-required form-check\"><span class=\"wpcf7-list-item first last\"><label><input type=\"checkbox\" name=\"form-check[]\" value=\"個人情報保護方針に同意します\"/><span class=\"wpcf7-list-item-label\">個人情報保護方針に同意します</span></label></span></span></span>\n</p>\n</td>\n</tr>\n</table>\n</div>\n<div class=\"form-btn\">\n<p><input type=\"button\" class=\"confirm_button\" value=\"入力内容を確認する\" disabled />\n</p>\n</div>\n</div><!-- 確認画面 -->\n<div class=\"confirm_area\">\n<h2 class=\"confirm-title murecho\"> 入力内容の確認\n</h2>\n<div class=\"contact-table\">\n<table>\n<tr>\n<td>\n<p><label for=\"name01\" class=\"label\">お名前<span class=\"required\">必須</span></label>\n</p>\n</td>\n<td>\n<p><span class=\"confirm_name01\"></span>\n</p>\n</td>\n</tr>\n<tr>\n<td>\n<p><label for=\"name02\" class=\"label\">フリガナ<span class=\"required\">必須</span></label>\n</p>\n</td>\n<td>\n<p><span class=\"confirm_name02\"></span>\n</p>\n</td>\n</tr>\n<tr>\n<td>\n<p><label for=\"birth\" class=\"label\">生年月日<span class=\"required\">必須</span></label>\n</p>\n</td>\n<td>\n<p><span class=\"confirm_birth\"></span>\n</p>\n</td>\n</tr>\n<tr>\n<td>\n<p><label for=\"postcode\" class=\"label\">郵便番号<span class=\"required\">必須</span></label>\n</p>\n</td>\n<td>\n<p><span class=\"confirm_postcode\"></span>\n</p>\n</td>\n</tr>\n<tr>\n<td>\n<p><label for=\"prefectures\" class=\"label\">住所<span class=\"required\">必須</span></label>\n</p>\n</td>\n<td>\n<p><span class=\"confirm_prefectures\"></span>\n</p>\n</td>\n</tr>\n<tr>\n<td>\n<p><label for=\"tel\" class=\"label\">電話番号<span class=\"required\">必須</span></label>\n</p>\n</td>\n<td>\n<p><span class=\"confirm_tel\"></span>\n</p>\n</td>\n</tr>\n<tr>\n<td>\n<p><label for=\"email\" class=\"label\">メール<span class=\"required\">必須</span></label>\n</p>\n</td>\n<td>\n<p><span class=\"confirm_your-email\"></span>\n</p>\n</td>\n</tr>\n<tr class=\"contact-file\">\n<td>\n<p><label for=\"file01\" class=\"label\">履歴書</label>\n</p>\n</td>\n<td>\n<p><span class=\"confirm_file01\"></span>\n</p>\n</td>\n</tr>\n<tr class=\"contact-file\">\n<td>\n<p><label for=\"file02\" class=\"label\">職務経歴書</label>\n</p>\n</td>\n<td>\n<p><span class=\"confirm_file02\"></span>\n</p>\n</td>\n</tr>\n<tr>\n<td>\n<p><label for=\"textarea\" class=\"label\">自己PR<span class=\"required\">必須</span></label>\n</p>\n</td>\n<td>\n<p><span class=\"confirm_textarea\"></span>\n</p>\n</td>\n</tr>\n<tr class=\"contact-check\">\n<td>\n<p><label for=\"check\" class=\"label\">求人募集を知った媒体<span class=\"required\">必須</span></label>\n</p>\n</td>\n<td>\n<p><span class=\"confirm_check\"></span>\n</p>\n</td>\n</tr>\n</table>\n</div>\n<div class=\"form-btn\">\n<p><input type=\"button\" class=\"back_button\" value=\"戻る\"/><br/>\n<input class=\"wpcf7-form-control wpcf7-submit has-spinner submit_button\" type=\"submit\" value=\"送信する\"/>\n</p>\n</div>\n</div>\n<p><script>\n document.addEventListener('DOMContentLoaded', () => {\n const form = document.querySelector('.wpcf7-form');\n if (!form) return;\n\n const pokeCF7Validation = () => {\n const evts = ['change', 'input', 'blur'];\n form.querySelectorAll('input, select, textarea').forEach(el => {\n evts.forEach(t => el.dispatchEvent(new Event(t, { bubbles: true })));\n });\n };\n\n const confirmButton = form.querySelector('.confirm_button');\n if (confirmButton) {\n confirmButton.disabled = false;\n\n confirmButton.addEventListener('click', () => {\n form.classList.add('is-confirm-attempted');\n pokeCF7Validation();\n\n setTimeout(() => {\n const ok = checkConfirmButton();\n const emailOk = checkEmailMatch();\n if (!ok || !emailOk) {\n scrollToFirstError();\n return;\n }\n\n document.querySelector('.Form').style.display = 'none';\n document.querySelector('.confirm_area').style.display = 'block';\n\n const header = document.querySelector('.header');\n const headerH = header ? header.offsetHeight : 0;\n const confirmArea = document.querySelector('.confirm_area');\n if (confirmArea) {\n const y = window.pageYOffset + confirmArea.getBoundingClientRect().top - headerH - 12;\n window.scrollTo({ top: Math.max(0, y), behavior: 'smooth' });\n }\n }, 30);\n });\n }\n\n const checkConfirmButton = () => {\n let flag = true;\n\n const requiredInputs = form.querySelectorAll('[aria-required=\"true\"]');\n requiredInputs.forEach(input => {\n if (input.value.trim() === '') {\n flag = false;\n }\n });\n\n const radioContainers = form.querySelectorAll('.wpcf7-radio');\n radioContainers.forEach(container => {\n const checked = container.querySelector('input:checked');\n if (!checked) flag = false;\n });\n\n const checkboxContainers = form.querySelectorAll('.wpcf7-checkbox');\n checkboxContainers.forEach(container => {\n if (!container.classList.contains('wpcf7-validates-as-required')) return;\n const checked = container.querySelector('input:checked');\n if (!checked) flag = false;\n });\n\n const acceptanceContainers = form.querySelectorAll('.wpcf7-acceptance');\n acceptanceContainers.forEach(container => {\n if (container.classList.contains('optional')) return;\n const checked = container.querySelector('input:checked');\n if (!checked) flag = false;\n });\n\n return flag;\n };\n\n const checkEmailMatch = () => {\n const emailInput = form.querySelector('input[name=\"your-email\"]');\n const emailConfirmInput = form.querySelector('input[name=\"your-email-confirm\"]');\n if (!emailInput || !emailConfirmInput) return true;\n\n const email = emailInput.value.trim();\n const emailConfirm = emailConfirmInput.value.trim();\n\n const tipSelector = '.wpcf7-not-valid-tip';\n const existingTip = emailConfirmInput.parentNode.querySelector(tipSelector);\n\n if (email !== emailConfirm) {\n emailConfirmInput.setAttribute('aria-invalid', 'true');\n if (!existingTip) {\n const tip = document.createElement('span');\n tip.className = 'wpcf7-not-valid-tip';\n tip.textContent = 'メールアドレスが一致しません';\n emailConfirmInput.parentNode.appendChild(tip);\n }\n return false;\n } else {\n emailConfirmInput.removeAttribute('aria-invalid');\n if (existingTip) existingTip.remove();\n return true;\n }\n };\n\n const scrollToFirstError = () => {\n const firstError =\n form.querySelector('.wpcf7-not-valid') ||\n form.querySelector('[aria-invalid=\"true\"]') ||\n form.querySelector('.wpcf7-not-valid-tip');\n\n const target = firstError || form.querySelector('.contact-table');\n if (target) {\n const y = window.pageYOffset + target.getBoundingClientRect().top;\n window.scrollTo({ top: y, behavior: 'smooth' });\n }\n };\n\n const formInputs = form.querySelectorAll('input, select, textarea');\n formInputs.forEach(input => {\n input.addEventListener('change', function () {\n setTimeout(() => {}, 100);\n\n const type = this.getAttribute('type');\n if (type === 'radio') {\n const value = this.value;\n const id = this.closest('[id]').id;\n document.querySelector(`.confirm_${id}`).textContent = value;\n } else if (type === 'checkbox') {\n if (this.closest('.wpcf7-acceptance')) return;\n const name = this.name;\n const checkedItems = form.querySelectorAll(`input[name=\"${name}\"]:checked`);\n const values = Array.from(checkedItems).map(item => item.value);\n const id = this.closest('[id]').id;\n document.querySelector(`.confirm_${id}`).textContent = values.join(', ');\n } else {\n const value = this.value;\n const id = this.id;\n document.querySelector(`.confirm_${id}`).textContent = value;\n }\n }, true);\n });\n\n const backEvent = () => {\n document.querySelector('.Form').style.display = 'block';\n document.querySelector('.confirm_area').style.display = 'none';\n };\n\n const backButtonEvent = () => {\n backEvent();\n const header = document.querySelector('.header');\n const y = header ? window.pageYOffset + header.getBoundingClientRect().top : 0;\n window.scrollTo(0, y);\n };\n\n const backButton = document.querySelector