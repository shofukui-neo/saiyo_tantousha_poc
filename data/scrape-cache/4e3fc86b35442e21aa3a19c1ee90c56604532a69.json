{"url":"https://www.kawakita.co.jp/recruit/interview/ishiguro/","html":"<!doctype html>\n<html lang=\"ja\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<meta http-equiv=\"X-UA-Compatible\" content=\"ie=edge\">\n  \n<!-- Google Tag Manager -->\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n})(window,document,'script','dataLayer','GTM-KCHSLKW');</script>\n<!-- End Google Tag Manager -->\n  \n<title>電設工事 石黒浩剛｜採用情報｜川北電気工業株式会社</title>\n<meta name=\"description\" content=\"川北電気工業の電設工事部門の石黒浩剛を紹介しています。\">\n<meta name=\"keywords\" content=\"川北電気工業,電気,電力,電設,工事,kawakita,光通信,ネットワーク,送電\">\n\n<meta property=\"og:locale\" content=\"ja_JP\">\n<meta property=\"og:type\" content=\"website\">\n<meta property=\"og:title\" content=\"電設工事 石黒浩剛｜採用情報｜川北電気工業株式会社\">\n<meta property=\"og:description\" content=\"川北電気工業の電設工事部門の石黒浩剛を紹介しています。\">\n<meta property=\"og:url\" content=\"https://www.kawakita.co.jp/recruit/interview/ishiguro/\">\n<meta property=\"og:site_name\" content=\"川北電気工業株式会社\">\n<meta property=\"og:image\" content=\"https://www.kawakita.co.jp/images/og_recruit.png\">\n<link rel=\"canonical\" href=\"https://www.kawakita.co.jp/recruit/interview/ishiguro/\">\n<link rel=\"icon\" href=\"https://www.kawakita.co.jp/favicon.ico\" type=\"image/vnd.microsoft.icon\">\n<link rel=\"shortcut icon\" href=\"https://www.kawakita.co.jp/favicon.ico\" type=\"image/vnd.microsoft.icon\">\n<link rel=\"apple-touch-icon\" sizes=\"57x57\" href=\"https://www.kawakita.co.jp/apple-touch-icon.png\">\n<link rel=\"stylesheet\" type=\"text/css\" href=\"https://www.kawakita.co.jp/css/base.css\">\n<link rel=\"stylesheet\" type=\"text/css\" href=\"https://www.kawakita.co.jp/css/common.css\">\n<link rel=\"stylesheet\" type=\"text/css\" href=\"https://www.kawakita.co.jp/css/animate.min.css\">\n<link rel=\"stylesheet\" type=\"text/css\" href=\"https://www.kawakita.co.jp/css/hover.css\">\n<link rel=\"stylesheet\" href=\"https://use.fontawesome.com/releases/v5.5.0/css/all.css\" integrity=\"sha384-B4dIYHKNBt8Bc12p+WXckhzcICo0wtJAoU8YZTY5qE0Id1GSseTk6S+L3BlXeVIU\" crossorigin=\"anonymous\">\n</head>\n<body id=\"interview01\"  class=\"recruit interview\">\n<!-- Google Tag Manager (noscript) -->\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-KCHSLKW\"\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n<!-- End Google Tag Manager (noscript) -->\n  <!-- ヘッダ -->\n  <header id=\"header\" class=\"header-recruit inblock-wrap\">\n    <div class=\"logo pic\"><a href=\"https://www.kawakita.co.jp/\"><img src=\"https://www.kawakita.co.jp/images/header/logo.png\" alt=\"川北電気工業株式会社\"></a></div>\n    <div class=\"sep\"></div>\n    <div class=\"title\"><a href=\"https://www.kawakita.co.jp/recruit/\">RECRUITMENT</a></div>\n    <div class=\"float-right menubtn pic\"><a href=\"#\"><img src=\"https://www.kawakita.co.jp/images/header/menubtn-off.png\" alt=\"MENU\"></a></div>\n    <div class=\"float-right btn btn-red\"><a href=\"https://www.kawakita.co.jp/recruit/contact/\" class=\"bl\">エントリー</a></div>\n  </header>\n  <div id=\"grand-menu\">\n    <nav id=\"pc-menu-wrap\">\n      <div class=\"inner content1350\">\n        <div id=\"pc-menu-table\" class=\"inblock-wrap content1124\">\n          <div class=\"row row-1\">\n            <ul class=\"footer-menu-list\">\n              <li><a href=\"https://www.kawakita.co.jp/recruit/message/\" class=\"textlink\">企業メッセージ</a></li>\n              <li>会社情報\n                <ul class=\"footer-menu-list-inner\">\n                  <li><a href=\"https://www.kawakita.co.jp/company/president/\" class=\"textlink\" target=\"_blank\">社長挨拶<img src=\"https://www.kawakita.co.jp/images/icon-link.png\" alt=