{"url":"https://www.aeonretail.jp/saiyo/newgraduate/about/","html":"<!DOCTYPE html\n  PUBLIC \"-//W3C//DTD XHTML 1.0 Transitional//EN\" \"https://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd\">\n<html lang=\"ja\" dir=\"ltr\" xmlns:og=\"http://ogp.me/ns#\" xmlns:fb=\"https://www.facebook.com/2008/fbml\">\n\n<head>\n  <meta http-equiv=\"Content-Type\" content=\"text/html; charset=utf-8\" />\n  <title>ABOUT｜採用サイト｜イオンリテール株式会社｜イオン</title>\n  <meta http-equiv=\"Content-Style-Type\" content=\"text/css\" />\n  <meta http-equiv=\"Content-Script-Type\" content=\"text/javascript\" />\n  <meta name=\"viewport\" content=\"width=device-width\">\n  <meta name=\"format-detection\" content=\"telephone=no\">\n  <meta name=\"description\" content=\"イオンリテール 株式会社の採用サイトです。お客さまを第一に考えた地域密着型の総合小売業であるイオンリテールの、企業紹介と理念紹介ページです。\">\n  <meta property=\"og:title\" content=\"ABOUT｜採用サイト｜イオンリテール株式会社｜イオン\">\n  <meta property=\"og:type\" content=\"article\">\n  <meta property=\"og:url\" content=\"https://www.aeonretail.jp/saiyo/newgraduate/about/\">\n  <meta property=\"og:image\" content=\"https://www.aeonretail.jp/saiyo/newgraduate/OGP.png\">\n  <meta property=\"og:site_name\" content=\"採用サイト｜イオンリテール株式会社\">\n  <meta property=\"og:description\" content=\"イオンリテール 株式会社の採用サイトです。お客さまを第一に考えた地域密着型の総合小売業であるイオンリテールの、企業紹介と理念紹介ページです。\">\n  <meta property=\"fb:app_id\" content=\"387286195088495\">\n  <meta name=\"twitter:card\" content=\"summary\">\n  <meta name=\"twitter:site\" content=\"@AEON_JAPAN\">\n  <link rel=\"apple-touch-icon-precomposed\" href=\"/favicon_256.png\" />\n  <link rel=\"shortcut icon\" type=\"image/x-icon\" href=\"/favicon_16.ico\" />\n  <link rel=\"shortcut icon\" type=\"image/x-icon\" href=\"/favicon_32.ico\" />\n  <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n\t<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n\t<link href=\"https://fonts.googleapis.com/css2?family=Zen+Maru+Gothic:wght@300;400;500;700;900&display=swap\" rel=\"stylesheet\">\n  <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/normalize/8.0.1/normalize.min.css\">\n  <link rel=\"stylesheet\" href=\"/saiyo/newgraduate/css/slick-theme.css\">\n  <link rel=\"stylesheet\" href=\"/saiyo/newgraduate/css/slick.css\">\n  <link rel=\"stylesheet\" href=\"/saiyo/newgraduate/css/common.css\">\n  <link rel=\"stylesheet\" href=\"/saiyo/newgraduate/css/about.css?\">\n\n  <!-- Google Tag Manager -->\n  <script>(function (w, d, s, l, i) {\n      w[l] = w[l] || []; w[l].push({\n        'gtm.start':\n          new Date().getTime(), event: 'gtm.js'\n      }); var f = d.getElementsByTagName(s)[0],\n        j = d.createElement(s), dl = l != 'dataLayer' ? '&l=' + l : ''; j.async = true; j.src =\n          'https://www.googletagmanager.com/gtm.js?id=' + i + dl; f.parentNode.insertBefore(j, f);\n    })(window, document, 'script', 'dataLayer', 'GTM-M38PPC');</script>\n  <!-- End Google Tag Manager -->\n\n</head>\n\n<body class=\"about\" id=\"top\">\n  <!-- Google Tag Manager (noscript) -->\n  <noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-M38PPC\" height=\"0\" width=\"0\"\n      style=\"display:none;visibility:hidden\"></iframe></noscript>\n  <!-- End Google Tag Manager (noscript) -->\n\n  <div class=\"contents\">\n    <header class=\"header\" id=\"header\">\n      <section class=\"header_inner\">\n        <div class=\"headernav leftnav\">\n          <p class=\"headerlogo\">\n            <a href=\"/saiyo/newgraduate/\"><img src=\"/saiyo/newgraduate/img/top/logo.png\" alt=\"AEON RETAIL\" width=\"560\" height=\"280\" /></a>\n          </p>\n          <h2 class=\"headertit\">イオンリテール新卒採用サイト</h2>\n        </div>\n        <div class=\"headernav rightnav\">\n          <ul class=\"sns-link\">\n            <li class=\"sns\">\n              <a href=\"https://www.instagram.com/aeonretail_recruit/\" target=\"_blank\">\n              <div class=\"instagram_wrap top\">\n                <img src=\"/saiyo/newgraduate/img/common/Instagram_color.svg\" alt=\"Instagram\" width=\"44\" height=\"44\" />\n              <p class=\"instagram_title_top\">新卒採用<br>アカウント</p>\n              </div></a>\n            </li>\n          </ul>\n          <div class=\"recruit_menu\">\n            <span>RECRUIT</span>\n              <ul class=\"recruit_links\">\n                <li><a href=\"https://job.mynavi.jp/27/pc/search/corp69194/outline.html\" target=\"_blank\">マイナビ2027</a></li>\n                <li><a href=\"https://job.mynavi.jp/28/pc/search/corp69194/outline.html\" target=\"_blank\">マイナビ2028</a></li>\n                <li><a href=\"https://www.onecareer.jp/companies/4098\" target=\"_blank\">ONE CAREER</a></li>\n              </ul>\n          </div>\n          <div class=\"fullnavi_btn\" id=\"menu_btn\"><span></span><span></span><span></span></div>\n        </div>\n\n        <div class=\"fullnavi headernav\">\n          <div class=\"fullnavi_scroll\">\n            <ul class=\"fullnavi_inner\">\n              <li><a href=\"/saiyo/newgraduate/\">トップページ</a></li>\n              <li><a href=\"/saiyo/newgraduate/message/\">あなたへのメッセージ</a></li>\n              <li><a href=\"/saiyo/newgraduate/about/\">イオンリテールとは</a></li>\n              <li><a href=\"/saiyo/newgraduate/dna/\">イオンリテールのDNA</a></li>\n              <li><a href=\"/saiyo/newgraduate/challenge/\">イオンリテールの挑戦</a></li>\n              <li><a href=\"/saiyo/newgraduate/people/\">社員紹介</a></li>\n              <li><a href=\"/saiyo/newgraduate/job/\">職種紹介</a></li>\n              <li><a href=\"/saiyo/newgraduate/specialmovie/\">スペシャルムービー</a></li>\n              <li><a href=\"/saiyo/newgraduate/recruit/\">採用情報</a></li>\n            </ul>\n            <div class=\"sp_d recruit_section\">\n              <!-- <div class=\"recruit_block lastyear\">\n                <div>\n                  <a href=\"https://aeonretail.snar.jp/login.aspx\" target=\"_blank\"><img src=\"/saiyo/newgraduate/img/common/2025mypage.png\" alt=\"MY PAGE 2025\" width=\"636\" height=\"126\" /></a>\n                </div>\n              </div> -->\n              <div class=\"recruit_block\">\n                <div>\n                  <a href=\"https://job.axol.jp/bx/s/aeonretail_27/mypage/login\" target=\"_blank\"><img src=\"/saiyo/newgraduate/img/common/2027mypage.png\" alt=\"MY PAGE 2027\" width=\"636\" height=\"126\" /></a>\n                </div>\n                <div>\n                  <a href=\"https://job.axol.jp/bx/s/aeonretail_27/entry/\" target=\"_blank\"><img src=\"/saiyo/newgraduate/img/common/2027entry.png\" alt=\"2027 ENTRY\" width=\"636\" height=\"126\"/></a>\n                </div>\n                <div>\n                  <a href=\"https://axol.jp/zw/s/aeonretail_28/mypage/login\" target=\"_blank\"><img src=\"/saiyo/newgraduate/img/common/2028mypage.png\" alt=\"MY PAGE 2028\" width=\"636\" height=\"126\" /></a>\n                </div>\n                <div>\n                  <a href=\"https://axol.jp/zw/s/aeonretail_28/entry/\" target=\"_blank\"><img src=\"/saiyo/newgraduate/img/common/2028entry.png\" alt=\"2028 ENTRY\" width=\"636\" height=\"126\"/></a>\n                </div>\n              </div>\n              <div class=\"recruit2025\">\n                <div>\n                  <span>RECRUIT</span>\n                    <p>\n                      <a href=\"https://job.mynavi.jp/27/pc/search/corp69194/outline.html\" target=\"_blank\">マイナビ2027<i></i></a>\n                    </p>\n                    <p>\n                      <a href=\"https://www.onecareer.jp/companies/4098\" target=\"_blank\">ONE CAREER<i></i></a>\n                    </p>\n                    <p>\n                      <a href=\"https://job.mynavi.jp/28/pc/search/corp69194/outline.html\" target=\"_blank\">マイナビ2028<i></i></a>\n                    </p>\n                </div>\n              </div>\n              <div class=\"recruit_sns\">\n                <a href=\"https://www.instagram.com/aeonretail_recruit/\" target=\"_blank\">\n                <div class=\"instagram_wrap bottom\">\n                  <img src=\"/saiyo/newgraduate/img/common/Instagram_color.svg\" alt=\"Instagram\" width=\"44\" height=\"44\" />\n                  <p class=\"instagram_title\">新卒採用アカウント</p>\n                </div></a>\n              </div>\n            </div>\n          </div>\n        </div>\n      </section>\n    </header>\n    <div class=\"main_contents\">\n      <div class=\"page_mv\">\n        <div class=\"mv_inner\">\n          <div class=\"mv_img\"></div>\n          <div class=\"mv_ttl\">\n            <h1><img src=\"/saiyo/newgraduate/img/about/title-about.svg\" alt=\"イオンリテールとは\"></h1>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"main_contents_inner\" id=\"about-cont\">\n        <div class=\"page_contents sec-1\">\n          <div class=\"contents_section point01 show\">\n            <div class=\"section_inner\">\n              <h2>すべてのサプライチェーンを<br>設計する「総合小売業」です。</h2>\n              <p>私たちは小売だけではなく、サプライチェーン全体をデザインしています。<br>\n                新店舗の用地取得から商品開発や商品仕入れ、デジタルを駆使した販売促進など、店舗でお客さまをお迎えするまでのすべてのプロセスに携わります。<br>\n                一人ひとりの「想い」を繋ぐことで、はじめて「イオン」が誕生するのです。</p>\n            </div>\n          </div>\n        </div>\n        <div class=\"page_contents sec-2\">\n          <div class=\"contents_section point02 show\">\n            <div class=\"section_inner\">\n              <h2>私たちの一番大切な場所、<br class=\"smt\">それは「店舗」です。</h2>\n              <p>\n                イオンリテールの原点は「店舗」です。なぜなら、お客さまと会える唯一の場所だから。私たちの仕事は、地域社会やお客さまの声に耳を傾け、「今何が必要とされているのか」を追究することから始まります。そして、その声を拾い上げ、お客さまにワクワクしていただける店舗運営・商品提案を実現していくことが最大のミッションです。\n              </p>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"page_contents sec-3\">\n          <div class=\"contents_section point03 show\">\n            <div class=\"section_inner\">\n              <h2>目指すのはイオンらしい<br class=\"smt\">「新しい総合」</h2>\n              <p>ニューノーマルと呼ばれる時代を迎え、「総合小売業」の在り方も大きく変化しています。<br>\n                衣食住といった生活必需品を安定供給することはもちろん、常に時代の一歩先を行く新たなお買物スタイルを提案し続けることが、イオンだからできる「新しい総合の価値」であると考えます。</p>\n              <div class=\"about_slide show\">\n                <div class=\"about_slid_list\">\n                  <img src=\"/saiyo/newgraduate/img/about/about_3-slider1.jpg\" alt=\"新しい総合イメージ\">\n                </div>\n                <div class=\"about_slid_list\">\n                  <img src=\"/saiyo/newgraduate/img/about/about_3-slider2.jpg\" alt=\"新しい総合イメージ\">\n                </div>\n                <div class=\"about_slid_list\">\n                  <img src=\"/saiyo/newgraduate/img/about/about_3-slider3.jpg\" alt=\"新しい総合イメージ\">\n                </div>\n                <div class=\"about_slid_list\">\n                  <img src=\"/saiyo/newgraduate/img/about/about_3-slider4.jpg\" alt=\"新しい総合イメージ\">\n                </div>\n                <div class=\"about_slid_list\">\n                  <img src=\"/saiyo/newgraduate/img/about/about_3-slider5.jpg\" alt=\"新しい総合イメージ\">\n                </div>\n                <div class=\"about_slid_list\">\n                  <img src=\"/saiyo/newgraduate/img/about/about_3-slider6.jpg\" alt=\"新しい総合イメージ\">\n                </div>\n                <div class=\"about_slid_list\">\n                  <img src=\"/saiyo/newgraduate/img/about/about_3-slider7.jpg\" alt=\"新しい総合イメージ\">\n                </div>\n                <div class=\"about_slid_list\">\n                  <img src=\"/saiyo/newgraduate/img/about/about_3-slider8.jpg\" alt=\"新しい総合イメージ\">\n                </div>\n                <div class=\"about_slid_list\">\n                  <img src=\"/saiyo/newgraduate/img/about/about_3-slider9.jpg\" alt=\"新しい総合イメージ\">\n                </div>\n                <div class=\"about_slid_list\">\n                  <img src=\"/saiyo/newgraduate/img/about/about_3-slider10.jpg\" alt=\"新しい総合イメージ\">\n                </div>\n                <div class=\"about_slid_list\">\n                  <img src=\"/saiyo/newgraduate/img/about/about_3-slider11.jpg\" alt=\"新しい総合イメージ\">\n                </div>\n                <div class=\"about_slid_list\">\n                  <img src=\"/saiyo/newgraduate/img/about/about_3-slider12.jpg\" alt=\"新しい総合イメージ\">\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"page_contents sec-4\">\n          <div class=\"contents_section movie show\">\n            <div class=\"section_inner\">\n              <h2>イオン店舗見学ツアームービー</h2>\n              <p>イオンリテールの原点である「店舗」を<br class=\"smt\">見学できるツアームービーです。<br>\n                イオンリテールならではの<br class=\"smt\">「新しい総合小売業」を感じてみてください。</p>\n              <div class=\"movie-wrap\">\n                  <iframe width=\"872\" height=\"492\" src=\"https://aeonretail.mil.movie/WVz8F5/\" title=\"video player\" allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture\" allowfullscreen></iframe>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"page_contents sec-5 thought show\">\n          <h2 class=\"slide_ttl\">イオンの基本理念</h2>\n          <div class=\"contents_section idea\">\n            <div class=\"basic-principles-txt\">\n              <p>お客さまを原点に平和を追求し、<br>人間を尊重し、地域社会に貢献する。</p>\n              <p>イオンは、小売業が平和産業であり、人間産業であり、<br>地域産業であると信じ、<br>\n                その使命を果たす企業集団として永続するために、<br>\n                お客さまを原点に絶えず革新し続けてゆきます。</p>\n            </div>\n\n            <div class=\"section_inner movie-box\">\n              <h3>イオングループ未来ビジョン</h3>\n              <div class=\"movie-wrap\">\n                  <iframe width=\"560\" height=\"315\" src=\"https://www.youtube.com/embed/IWqSyWsLtAQ?si=x_36a594qf34At4S\" title=\"YouTube video player\" allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share\" allowfullscreen></iframe>\n              </div>\n            </div>\n          </div>\n\n          <div class=\"contents_section slide_ttl show\">\n            <div class=\"section_inner\">\n              <h3 class=\"slide_ttl\">イオンリテールでは、<br>\n                イオンの基本理念に基づき、<br class=\"smt\">さまざまな取り組みを行っています。</h3>\n            </div>\n            <div class=\"round-box_wrap\">\n              <dl class=\"subco_1\">\n                <dt>お客さま</dt>\n                <dd class=\"catch\">お客さまの声がブランドの原点</dd>\n                <dd class=\"subco-img\">\n                  <figure>\n                    <img src=\"/saiyo/newgraduate/img/about/topvalu_brand-logo.png\" alt=\"トップバリュブランド\">\n                  </figure>\n                </dd>\n                <dd class=\"notes\">トップバリュはお客さまの生活をより良くしたいという想いから生まれました。<br>\n                  時代と共に変わり続けるお客さまのニーズにお応えするため、これからもお客さまに寄り添った商品を提供していきます。</dd>\n                <dd><a class=\"btn message\" href=\"https://www.topvalu.net/\" target=\"_blank\">READ&nbsp;MORE</a></dd>\n              </dl>\n\n              <dl class=\"subco_2\">\n                <dt>平和</dt>\n                <dd class=\"catch\">イオンの植樹活動</dd>\n                <dd class=\"subco-img\">\n                  <figure>\n                    <img src=\"/saiyo/newgraduate/img/about/subco-img2.jpg\" alt=\"イオンの植樹活動\">\n                  </figure>\n                </dd>\n                <dd class=\"notes\">「お客さまを原点に平和を追求し、人間を尊重し、地域社会に貢献する」という基本理念を具現化し、平和の礎を築くために、植樹活動を行っています。<br>\n                  イオンの植樹活動は、日本だけでなく、中国、マレーシア、タイなどアジア各国でも展開しており、世界各地のお客さまとの植樹活動の輪が広がっています。</dd>\n                <dd><a class=\"btn message\" href=\"https://www.aeon.info/sustainability/environment/shokuju/\"\n                    target=\"_blank\">READ&nbsp;MORE</a></dd>\n              </dl>\n              <dl class=\"subco_3\">\n                <dt>人間</dt>\n                <dd class=\"catch\">イオンの“ダイ満足”</dd>\n                <dd class=\"subco-img\">\n                  <figure>\n                    <img alt=\"ダイ満足\" src=\"/saiyo/newgraduate/img/about/subco3-logo.png\">\n                  </figure>\n                </dd>\n                <dd class=\"notes\">イオンでは、ダイバーシティを推進することで生み出される、従業員とその家族、お客さま、会社の満足を“ダイ満足”と名付けています。</dd>\n                <dd>\n                  <a class=\"btn message\" href=\"https://www.aeon.info/diversity/satisfaction/\" target=\"_blank\">READ&nbsp;MORE</a>\n                </dd>\n              </dl>\n\n              <dl class=\"subco_4\">\n                <dt>地域</dt>\n                <dd class=\"catch\">幸せの黄色いレシート</dd>\n                <dd class=\"subco-img\">\n                  <figure>\n                    <img src=\"/saiyo/newgraduate/img/about/subco-img4.jpg\" alt=\"幸せの黄色いレシート\">\n                  </figure>\n                </dd>\n                <dd class=\"notes\">\n                  お客さまがレジ精算時に受け取った黄色いレシートを、地域のボランティア団体名が書かれた店内備え付けのBOXに投函していただくことで、レシート金額合計の1％分の品物をイオンが各団体に寄贈する取り組みです。\n                </dd>\n                <dd>\n                  <a class=\"btn message\" href=\"https://www.aeon.info/sustainability/social/yellow/\" target=\"_blank\">READ&nbsp;MORE</a>\n                </dd>\n              </dl>\n            </div>\n          </div>\n        </div>\n\n      </div>\n\n      <!-- .next_page -->\n      <div class=\"next_page\">\n        <div class=\"next_page_inner\">\n          <a href=\"/saiyo/newgraduate/dna/\" class=\"next_page_img\">\n            <span>イオンリテールのDNA</span>\n          </a>\n          <p>イオンリテールで創業当時から<br class=\"smt\">受け継がれてきた考え方やDNAを紹介します。</p>\n        </div>\n      </div>\n      <!-- /.next_page -->\n\n    </div>\n    <ul class=\"fix_menu fix_mypage\">\n      <li class=\"mypage_under\">\n        <p>\n          <a href=\"https://job.axol.jp/bx/s/aeonretail_27/mypage/login\" target=\"_blank\"><span>27年卒</span></a>\n        </p>\n        <p>\n          <a href=\"https://axol.jp/zw/s/aeonretail_28/mypage/login\" target=\"_blank\"><span>28年卒</span></a>\n        </p>\n      </li>\n      <li class=\"mypage\"><span>MY<br />PAGE</span></li>\n    </ul>\n\t\t<ul class=\"fix_menu fix_entry\">\n      <li class=\"entry_under\">\n        <p>\n          <a href=\"https://job.axol.jp/bx/s/aeonretail_27/entry/\" target=\"_blank\"><span>27年卒</span></