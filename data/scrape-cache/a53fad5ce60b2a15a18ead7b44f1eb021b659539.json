\t</div>\n\t\t</div>\n\t\n\t<div class=\"row justify-content-center mt-5 animation-fade\">\n<div class=\"col-12 col-lg-11 col-xl-9\">\n\t<div id=\"mailform\">\n\n <form method=\"post\" action=\"mail2.php\">\n     \n       <div class=\"mailcont\">\n         \n         \n           \n           <dl>\n           <dt>\n             <label>お名前<span  class=\"text-danger\">※</span ></label>\n             </dt>\n           <dd>\n             <input type=\"text\" name=\"お名前\" id=\"name\" class=\"size-m\" value=\"\" />\n             </dd>\n           </dl>\n           \n           <dl>\n           <dt>\n             <label>フリガナ<span  class=\"text-danger\">※</span >（全角カナ）</label>\n             </dt>\n           <dd>\n             <input type=\"text\" name=\"フリガナ\" id=\"kana\" class=\"size-m\" value=\"\" />\n             </dd>\n           </dl>\n           \n           <dl>\n           <dt>\n             <label>メールアドレス<span  class=\"text-danger\">※</span ></label>\n             </dt>\n           <dd>\n             <input type=\"text\" name=\"メールアドレス\" id=\"e-mail\" class=\"size-m\"  value=\"\" />\n             </dd>\n           </dl>\n           \n           <dl>\n           <dt>\n               <label>連絡先電話番号（携帯電話可）</label>\n             </dt>\n           <dd>\n             <input type=\"text\" name=\"電話番号\" id=\"phone\" class=\"size-m\" size=\"13\" value=\"\" />\n             </dd>\n           </dl>\n           \n           \n           <dl>\n           <dt>\n             <label>ご住所</label>\n             </dt>\n           <dd>\n             〒 <input type=\"text\" name=\"郵便番号\" id=\"zip\" class=\"size-s\" value=\"\" /><br>\n             <input type=\"text\" name=\"ご住所\" id=\"address\" class=\"size-l\" value=\"\" />\n             </dd>\n           </dl>\n         \n         \n           \n         \n         <dl>\n           <dt>\n             <label>お問い合わせ内容<span  class=\"text-danger\">※</span ></label>\n             </dt>\n           \n           <dd>\n             <textarea wrap=\"hard\" rows=\"10\" cols=\"55\" name=\"お問い合わせ内容\" class=\"size-l\" id=\"message\"></textarea>\n             </dd>\n           </dl>\n\n         \n         \n         \n         <div id=\"formbutton\" class=\"mb-5\">\n           \n           <!--<div class=\"back-button\"><input type=\"submit\" value=\"前に戻る\" /></div>-->\n           <button type=\"submit\" class=\"btn btn-info btn-lg btn-fome1\">確認する</button>\n           <!--<div class=\"submit-button\"><input type=\"submit\" value=\"送信する\" /></div>-->\n           </div>\n           \n            <div class=\"pl-3 pr-3 mb-3\">\n         <p><span class=\"text-danger\">※</span>このウェブサイトは、お客様の個人情報を保護しています。\n           　<br>\n           　\n           すべての情報がSSLで暗号化されてから安全に送受信されます。 </p>\n         <p>個人情報のお取り扱いについて<br>\n           弊社は皆さまよりいただいた個人情報を厳重に管理し、お客さまの承諾を得た場合をのぞき、<br>\n           第三者へ提供・提示等は一切致しません。<br>\n           詳しくは<a href=\"https://www.matsue-doken.co.jp/policy.html\" target=\"_blank\">個人情報保護方針</a>をご覧ください。</p>\n       </div>\n       \n       \n       </div>\n       \n\n\n   </form>\n\n</div>\n</div>\n</div>\n</div>\n</section>\n\n</article>\n  <!--<section id=\"section-footer\">\n  <div class=\"entry-bnt animation-fade\">  \n\n\t\t  <a href=\"/recruit/information/recruit-info.html\" class=\"entry-bnt-a\"><span class=\"bt-ic\"><img src=\"../images/bnt_ic01.png\" width=\"87\" height=\"61\" alt=\">>>\"/></span>ENTRY<span class=\"bt-ic\"><img src=\"../images/bnt_ic02.png\" width=\"87\" height=\"61\" alt=\"<<<\"/></span></a>\n\n</div>\n</section>-->\n\n<!-- InstanceEndEditable --> </main>\n  <!-- /.container -->\n  \n  <footer>\n    <div class=\"container\">\n      <!--<nav>\n        <div class=\"row justify-content-center\">\n          <div>\n            <ul class=\"top\">\n              <li><a href=\"../index.html\">ホーム</a></li>\n              <li><a href=\"../news/index.html\">ニュース</a></li>\n              <li><a href=\"index.html\">お問い合わせ</a></li>\n            </ul>\n          </div>\n          <div>\n    