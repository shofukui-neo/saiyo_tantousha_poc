     <!-- /logo -->\n      <!-- global navi -->\n      <nav role=\"navigation\" class=\"gNav gNav-accordion drawer-nav\">\n        <ol class=\"clearfix drawer-menu\">\n          <li class=\"gNav__item gNav__item--normal gNav__item--message\">\n            <a href=\"message_index.html\" class=\"hoverNot\">\n              <span class=\"en\">MESSAGE</span>先輩メッセージ\n            </a>\n          </li>\n          <li class=\"gNav__item gNav__item--normal gNav__item--crosstalk\">\n            <a href=\"crosstalk.html\" class=\"hoverNot\">\n              <span class=\"en\">CROSSTALK</span>新人座談会\n            </a>\n          </li>\n          <li class=\"gNav__item gNav__item--normal gNav__item--work\">\n            <a href=\"work.html\" class=\"hoverNot\">\n              <span class=\"en\">WORK</span>今岡工業の仕事\n            </a>\n          </li>\n          <li class=\"gNav__item gNav__item--guide accordion close\">\n            <a href=\"guide_new_grad.html\" class=\"trigger hoverNot\">\n              <span class=\"en\">GUIDE</span>募集要項\n            </a>\n            <ul class=\"accordionMenu--mobile accordionMenu--pc\">\n              <li><a href=\"guide_new_grad.html\"><span>新卒の方</span></a></li>\n              <li><a href=\"guide_kisotsu_kentiku.html\"><span>既卒 建築技術</span></a></li>\n              <li><a href=\"guide_kisotsu_doboku.html\"><span>既卒 土木技術</span></a></li>\n              <li><a href=\"guide_kisotsu_eigyou.html\"><span>既卒 営業職</span></a></li>\n            </ul>\n          </li>\n          <li class=\"gNav__item gNav__item--normal gNav__item--faq\">\n            <a href=\"faq.html\" class=\"hoverNot\">\n              <span class=\"en\">FAQ</span>よくある質問\n            </a>\n          </li>\n          <li class=\"gNav__item gNav__item--normal gNav__item--entry\">\n            <a href=\"/recruite_form/index\" class=\"hoverNot\">\n              <span class=\"en\">ENTRY</span>エントリー\n            </a>\n          </li>\n          <li class=\"gNav__item gNav__item--close dn-pc\">\n            <a class=\"drawer-toggle\">\n              閉じる\n            </a>\n          </li>\n        </ol>\n      </nav>\n      <!-- /global navi -->\n      <!-- mobile menu -->\n      <div id=\"close\" class=\"headerArea__menuBtn dn-pc drawer-toggle\">\n        <span class=\"dn\">MENU</span>\n      </div>\n      <!-- /mobile menu -->\n    </div>\n  </header>\n  <!-- /header -->\n\n  <!-- main container -->\n  <main>\n    <div role=\"main\">\n      <!-- h1 -->\n      <h1 class=\"sub-category sub-category--massage\">\n        <span class=\"sub-category__inner\">\n          <span class=\"catNameEn\">MESSAGE</span>\n          <span class=\"catName\">先輩メッセージ</span>\n        </span>\n      </h1>\n      <!-- /h1 -->\n\n      <!-- breadcrumbs -->\n      <div class=\"sub-breadcrumbs dn-mobile\">\n        <ol class=\"l-container-sub clearfix\">\n          <li><a href=\"index.html\">トップページ</a></li>\n          <li><a href=\"message_index.html\">先輩メッセージ</a></li>\n          <li>守本 芳雄</li>\n        </ol>\n      </div>\n      <!-- /breadcrumbs -->\n\n      <!-- l-container-sub -->\n      <div class=\"l-container-sub sub-container\">\n        <section>\n          <!-- h2 -->\n          <h2 class=\"mod-hl-01 mod-hl-01--catTag\">\n            <span class=\"icon-message icon\">&thinsp;</span>\n            守本 芳雄\n            <span class=\"en\">Morimoto Yoshio</span>\n            <span class=\"small\">2013年に入社</span>\n            <span class=\"catTag\">土木施工管理</span>\n          </h2>\n          <!-- /h2 -->\n          <!-- articleBox-01 -->\n          <div class=\"column-articleBox-subLeft--w300 l-innerBox clearfix\">\n            <div class=\"mod-column-sub\">\n              <img src=\"img/massage/bnr_01.jpg\" alt=\"スタッフ写真\" class=\"imgFit\">\n            </div>\n            <div class=\"mod-column-main\">\n              <div class=\"mod-column-main__inner\">\n                <section>\n                  <h3 class=\"mod-hl-02\">\n                    <span class=\"icon\">Q</span>この仕事を選んだきっかけは何ですか？\n                  </h3>\n                  <p>\n                    昔から“ものづくり”が好きで、子供の頃は自分で秘密基地を作ったりしていました。 それが講じて、中学の時に「家を建ててみたい」という想いが芽生え、高校は工業高校の建築科へ進学しました。\n                  </p>\n                  <p class=\"marginTop10\">\n                    その後、京都の大学で建築について学びましたが、卒業後は地元に戻りたい気持ちが強く、島根県で就職活動を行い、最終的に今岡工業に入社しました。\n                  </p>\n                </section>\n                <section class=\"marginTop30\">\n                  <h3 class=\"mod-hl-02\">\n                    <span class=\"icon\">Q</span>実際に入社していかがでしょうか？\n                  </h3>\n                  <p>\n                    今現在は土木の仕事を行っています。土木も建築も、基礎となる知識は共通する部分があるのですが、 実務レベルの知識となると勉強しなければならない事が沢山あります。\n                  </p>\n                  <p class=\"marginTop10\">\n                    特に１年目の時は、専門用語なども分からないことだらけでした。 そうした時は現場で先輩に聞いたり、 聞けるタイミングにないときは、取り敢えずメモをして帰社してから急いで調べるなどしました。\n                    勉強することが多く大変でしたが、そうした経験を通じて「すぐに聞き、すぐに調べる。」 というクセがついたことで、分からない事を自分のものにしていくコツを掴むことが出来たように思います。\n                  </p>\n                </section>\n              </div>\n            </div>\n          </div>\n          <!-- /articleBox-01 -->\n          <!-- articleBox-02 -->\n          <div class=\"column-articleBox-subRight--w300 l-innerBox marginTop60 clearfix\">\n            <div class=\"mod-column-sub\">\n              <img src=\"img/massage/pic_face01.jpg\" alt=\"スタッフ写真\" class=\"imgFit\">\n            </div>\n            <div class=\"mod-column-main\">\n              <div class=\"mod-column-main__inner\">\n                <section>\n                  <h3 class=\"mod-hl-02\">\n                    <span class=\"icon\">Q</span>現在の目標があればお聞かせください。\n                  </h3>\n                  <p>\n                    一級土木施工管理技士の資格を取得して、はやく自分がリーダーとして仕事ができる「自分の現場」を持ちたいと思っています。そのような仕事では、責任者として大変なことは沢山あるのだと思いますが、それらの苦労が達成感としてプラスに返ってくると考えています。\n                  </p>\n                  <p class=\"marginTop10\">\n                    まずは資格を取得することが前提ではありますが、「自分の現場」を持てるよう日々経験を積み上げていきたいと思います。\n                  </p>\n                </section>\n                <section class=\"marginTop30\">\n                  <h3 class=\"mod-hl-02\">\n                    <span class=\"icon\">Q</span>今岡工業の魅力はなんでしょうか？\n                  </h3>\n                  <p>\n                    サポート体制がしっかりしている部分だと思います。分からないことも聞きやすく、勉強しやすいのではないでしょうか。ものづくりへの興味がある人にとっては、自分を成長させやすい、とても良い環境だと思います。\n                  </p>\n                </section>\n              </div>\n            </div>\n          </div>\n          <!-- /articleBox-02 -->\n          <!-- articleBox-03 -->\n          <!-- <div class=\"column-articleBox-subLeft--w300 l-innerBox marginTop60 clearfix\">\n            <div class=\"mod-column-sub\">\n              <img src=\"img/massage/pic_sample.jpg\" alt=\"スタッフ写真\" class=\"imgFit\">\n            </div>\n            <div class=\"mod-column-main\">\n              <div class=\"mod-column-main__inner\">\n                <section>\n                  <h3 class=\"mod-hl-02\">\n                    <span class=\"icon\">Q</span>プライベートは何をしていますか？\n                  </h3>\n                  <p>\n                    この文章はダミーです。文字の大きさ、量、字間、行間等を確認するために入れています。この文章はダミーです。文字の大きさ、量、字間、行間等を確認するために入れています。この文章はダミーです。文字の大きさ、量、字間、行間等を確認するために入れています。\n                    この文章はダミーです。文字の大きさ、量、字間、行間等を確認するために入れています。この文章はダミーです。文字の大きさ、量、字間、行間等を確認するために入れています。この文章はダミーです。文字の大きさ、量、字間、行間等を確認するために入れています。\n                  </p>\n                </section>\n              </div>\n            </div>\n          </div> -->\n          <!-- /articleBox-03 -->\n          <!-- btn -->\n          <div class=\"marginTop60 textCenter\">\n            <a href=\"message_index.html\" class=\"mod-btn-02 mod-btn-w300\">\n              <span class=\"icon-menu\">&thinsp;</span> 一覧に戻る\n            </a>\n          </div>\n          <!-- /btn -->\n        </section>\n      </div>\n      <!-- /l-container-sub -->\n    </div>\n  </main>\n  <!-- /main container -->\n\n  <!-- footer -->\n  <footer role=\"contentinfo\" class=\"mod-bg-cSub\">\n    <!-- footer -->\n    <div class=\"footer clearfix\">\n      <!-- main -->\n      <div class=\"footer__main\">\n        <a href=\"index.html\">\n          <img src=\"img/common/logo_footer_02.png\" alt=\"今岡工業株式会社\" class=\"imgFit footer__main__logo\">\n        </a>\n        <p class=\"footer__main__address\">\n          〒693-0024 島根県出雲市塩冶神前 2-8-16<br>\n          TEL <a href=\"tel:0853237778\">0853-23-7778</a> / FAX 0853-22-5959\n        </p>\n        <div class=\"footer__main__siteBtn\">\n          <a href=\"#\" class=\"hoverNot\"><span class=\"icon icon-arrow_right_02\">&thinsp;</span> 企業サイトへ</a>\n        </div>\n      </div>\n      <!-- /main -->\n      <!-- sub -->\n      <div class=\"footer__sub dn-mobile\">\n        <h6 class=\"footer__sub__hed\">MENU</h6>\n        <div class=\"clearfix footer__sub__menu\">\n          <ul>\n            <li><a href=\"index.html\" class=\"hoverNot\">トップページ</a></li>\n            <li><a href=\"message_index.html\" class=\"hoverNot\">先輩メッセージ</a></li>\n            <li><a href=\"crosstalk.html\" class=\"hoverNot\">新人座談会</a></li>\n          </ul>\n          <ul>\n            <li><a href=\"work.html\" class=\"hoverNot\">今岡工業の仕事</a></li>\n            <li><a href=\"guide_new_grad.html\" class=\"hoverNot\">募集要項</a></li>\n            <li><a href=\"faq.html\" class=\"hoverNot\">よくある質問</a></li>\n          </ul>\n          <ul>\n            <li><a href=\"/recruite_form/index\" class=\"hoverNot\">エントリーフォーム</a></li>\n          </ul>\n        </div>\n      </div>\n      <!-- /sub -->\n    </div>\n    <!-- /footer -->\n    <!-- copyright -->\n    <div class=\"mod-bg-cMain copyright\">\n      (C)Copyright 2019 imaokakogyo Corporation. All rights reserved.\n    </div>\n    <!-- /copyright -->\n  </footer>\n  <!-- /footer -->\n\n  <!-- pageTop -->\n  <div class=\"pageTop-box\">\n    <div id=\"pageTop\" class=\"pageTop\">\n      <img src=\"img/common/btn_pg_top.png\" alt=\"トップに戻る\" class=\"imgFit\">\n    </div>\n  </div>\n  <!-- /pageTop -->\n\