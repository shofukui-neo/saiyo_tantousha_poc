{"url":"https://www.suzuki-recruit.jp/people/interview/","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n<head>\n  <title>飾らない自分で、お客様の人生を飾る｜スズキ販売会社グループ｜新卒採用</title>\n  <meta charset=\"UTF-8\">\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n\n<meta name=\"description\" content=\"\">\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1,shrink-to-fit=no\">\n<meta name=\"format-detection\" content=\"telephone=no\">\n\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/assets/css/vendor/slick.css\">\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/assets/css/vendor/slick-theme.css\">\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/assets/css/vendor/colorbox.css\">\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/assets/css/style.css\">\n\n<meta name=\"description\" content=\"スズキ販売会社グループの新卒採用サイトでは、スズキの歴史や製品、販売会社の仕事や職種を紹介だけでなく、充実した研修制度や、仕事のやりがいを知ることができる社員インタビューも掲載しています。\">\n<meta property=\"og:title\" content=\"スズキ販売会社グループ｜新卒採用\">\n<meta property=\"og:description\" content=\"スズキ販売会社グループの新卒採用サイトでは、スズキの歴史や製品、販売会社の仕事や職種を紹介だけでなく、充実した研修制度や、仕事のやりがいを知ることができる社員インタビューも掲載しています。\">\n\n<!-- Google tag (gtag.js) -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-VFMXFW4VG5\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'G-VFMXFW4VG5');\n</script></head>\n<body>\n<div class=\"l-wrapper\">\n\n  <header class=\"l-header\">\n  <div class=\"l-header_in\">\n    <div class=\"_logo\">\n      <a href=\"/\">\n        <picture>\n          <source srcset=\"/assets/img/common/logo_sp.svg\" media=\"(max-width: 768px)\">\n          <img src=\"/assets/img/common/logo.svg\" alt=\"\">\n        </picture>\n      </a>\n    </div>\n    <nav class=\"l-header_gnav\">\n      <div class=\"_link\">\n        <a href=\"/sales/#arealist\">販売会社一覧</a>\n      </div>\n      <div>\n        <div class=\"c-menuBtn2\">\n          <span></span>\n          <span></span>\n          <span></span>\n        </div>\n      </div>\n    </nav>\n  </div>\n\n  <div class=\"c-menuContainer2\">\n    <div class=\"c-menuContainer2_in\">\n      <div class=\"p-menuLink\">\n  <dl>\n    <dt>COMPANY</dt>\n    <dd>\n      <ul> \n        <li><a href=\"/company/\">飾らないルーツを知る（スズキの歴史とスタンス）</a></li>\n        <li><a href=\"/sales/\">全国のお客様を飾る販売会社（スズキ販売会社の紹介）</a></li>\n      </ul>\n    </dd>\n  </dl>\n  <dl>\n    <dt>WORK</dt>\n    <dd>\n      <ul>\n        <li><a href=\"/work/\">お客様の人生を飾る3つの仕事（職種紹介・キャリアステップ）</a></li>\n      </ul>\n    </dd>\n  </dl>\n  <dl>\n    <dt>PEOPLE</dt>\n    <dd>\n      <ul>\n        <li><a href=\"/people/interview/\">飾らない自分で、お客様の人生を飾る（社員インタビュー）</a></li>\n        <li><a href=\"/people/crosstalk/\">飾らずに、語り合う（対談）</a></li>\n      </ul>\n    </dd>\n  </dl>\n  <dl>\n    <dt>TRAINING</dt>\n    <dd>\n      <ul>\n        <li><a href=\"/training/\">人生を飾るための手厚いフォロー（教育研修制度の紹介）</a></li>\n      </ul>\n    </dd>\n  </dl>\n</div>    </div>\n  </div>\n</header>  \n  <main class=\"l-content\">\n    <div class=\"l-content_in\">\n\n      <section class=\"p-secOtherMv\">\n        <div class=\"p-mapMv\">\n          <div class=\"p-mapMv_bg_img\">\n            <picture>\n              <source srcset=\"/assets/img/common/bg_star_sp.svg\" media=\"(max-width: 768px)\">\n              <img src=\"/assets/img/common/bg_star.svg\" alt=\"\">\n            </picture>\n          </div>\n\n          <div class=\"p-mapMv_img\">\n            <img src=\"/assets/img/common/map.svg\" alt=\"\">\n          </div>\n        </div>\n\n        <div class=\"p-secOtherMv_wrap\">\n          <div class=\"_category\"><span>PEOPLE</span></div>\n\n          <h1>飾らない自分で、お客様の人生を飾る</h1>\n          <h2>社員インタビュー</h2>\n  \n          <p>スズキのクルマを通じて、全国各地のお客様の人生を<br class=\"u-middleblock\">豊かに飾っている社員たちのインタビュー記事です。<br>どんな仕事をしているのか。何をやりがいに感じているのか。<br>中々聞けないエピソード満載でお届けします。</p>\n        </div>\n      </section>\n\n      <section class=\"l-sec p-secPeopleStaff\">\n        <div class=\"l-sec_in\">\n          <h2 class=\"p-secPeopleStaff_txt1 c-subTitle\">\n            <span><span class=\"_small\">STAFF</span><span>INTERVIEW</span></span>\n          </h2>\n          <ul class=\"p-secPeopleStaff_list\">\n            <li id=\"oc1\">\n              <div class=\"_title\"><span>直販営業</span></div>\n              <p>お客様に直接クルマを販売して<br class=\"u-middleblock\">豊かなカーライフをつくる</p>\n              <ul class=\"p-interviewList\">\n                <li>\n                  <a href=\"/people/interview/01/\">\n                    <div class=\"_num\">01</div>\n                    <div class=\"_img\">\n                      <img src=\"/assets/img/common/people_staff_1.webp\" alt=\"\">\n                    </div>\n                    <h3>\n                      <span>積極性と誠実さを武器に、</span>\n                      <span>全国トップの営業スタッフを</span>\n                      <span>目指す。</span>\n                    </h3>\n                    <div class=\"_name\">\n                      <div>直販営業</div>\n                      <div>K.T さん<span>（2022年入社）</span></div>\n                    </div>\n                  </a>\n                </li>\n                <li>\n                  <a href=\"/people/interview/02/\">\n                    <div class=\"_num\">02</div>\n                    <div class=\"_img\">\n                      <img src=\"/assets/img/common/people_staff_2.webp\" alt=\"\">\n                    </div>\n                    <h3>\n                      <span>丁寧に信頼関係を築き、</span>\n                      <span>ライフスタイルに合わせた一台を提案する。</span>\n                    </h3>\n                    <div class=\"_name\">\n                      <div>直販営業</div>\n                      <div>Y.M さん<span>（2023年入社）</span></div>\n                    </div>\n                  </a>\n                </li>\n                <li>\n                  <a href=\"/people/interview/03/\">\n                    <div class=\"_num\">03</div>\n                    <div class=\"_img\">\n                      <img src=\"/assets/img/common/people_staff_3.webp\" alt=\"\">\n                    </div>\n                    <h3>\n                      <span>店長というステージでも</span>\n                      <span>お客様の人生を飾りたい。</span>\n                    </h3>\n                    <div class=\"_name\">\n                      <div>直販営業・店長</div>\n                      <div>T.N さん<span>（2011年入社）</span></div>\n                    </div>\n                  </a>\n                </li>\n              </ul>\n            </li>\n            <li id=\"oc2\">\n              <div class=\"_title\"><span>業販営業</span></div>\n              <p>地域の販売店様とタッグを組み<br class=\"u-middleblock\">スズキ車のネットワークを広げていく</p>\n              <ul class=\"p-interviewList\">\n                <li>\n                  <a href=\"/people/interview/04/\">\n                    <div class=\"_num\">04</div>\n                    <div class=\"_img\">\n                      <img src=\"/assets/img/common/people_staff_4.webp\" alt=\"\">\n                    </div>\n                    <h3>\n                      <span>飾らない姿勢と地道な努力が、</span>\n                      <span>業販営業としての成長を</span>\n                      <span>加速させる。</span>\n                    </h3>\n                    <div class=\"_name\">\n                      <div>業販営業</div>\n                      <div>T.K さん<span>（2022年入社）</span></div>\n                    </div>\n                  </a>\n                </li>\n                <li>\n                  <a href=\"/people/interview/05/\">\n                    <div class=\"_num\">05</div>\n                    <div class=\"_img\">\n                      <img src=\"/assets/img/common/people_staff_5.webp\" alt=\"\">\n                    </div>\n                    <h3>\n                      <span>三者の成功を導く、</span>\n                      <span>キーパーソンとして働く。</span>\n                    </h3>\n                    <div class=\"_name\">\n                      <div>業販営業</div>\n                      <div>J.S さん<span>（2013年入社）</span></div>\n                    </div>\n                  </a>\n                </li>\n              </ul>\n            </li>\n            <li id=\"oc3\">\n              <div class=\"_title\"><span>サービス</span></div>\n              <p>スズキ車の点検や整備を通して<br class=\"u-middleblock\">お客様の安心安全なカーライフを実現する</p>\n              <ul class=\"p-interviewList\">\n                <li>\n                  <a href=\"/people/interview/06/\">\n                    <div class=\"_num\">06</div>\n                    <div class=\"_img\">\n                      <img src=\"/assets/img/common/people_staff_6.webp\" alt=\"\">\n                    </div>\n                    <h3>\n                      <span>一つひとつの作業に</span>\n                      <span>誠実に向き合い、</span>\n                      <span>お客様の安心と安全を守る。</span>\n                    </h3>\n                    <div class=\"_name\">\n                      <div>サービス</div>\n                      <div>R.M さん<span>（2021年入社）</span></div>\n                    </div>\n                  </a>\n                </li>\n                <li>\n                  <a href=\"/people/interview/07/\">\n                    <div class=\"_num\">07</div>\n                    <div class=\"_img\">\n                      <img src=\"/assets/img/common/people_staff_7.webp\" alt=\"\">\n                    </div>\n                    <h3>\n                      <span>磨き続けてきた技術や知識で</span>\n                      <span>地域のカーライフを守っていく。</span>\n                    </h3>\n                    <div class=\"_name\">\n                      <div>サービス</div>\n                      <div>Y.T さん<span>（2014年入社）</span></div>\n                    </div>\n                  </a>\n                </li>\n                <li>\n                  <a href=\"/people/interview/08/\">\n                    <div class=\"_num\">08</div>\n                    <div class=\"_img\">\n                      <img src=\"/assets/img/common/people_staff_8.webp\" alt=\"\">\n                    </div>\n                    <h3>\n                      <span>工場長として</span>\n                      <span>スタッフの個性を活かし、</span>\n                      <span>チームの力を引き出す。</span>\n                    </h3>\n                    <div class=\"_name\">\n                      <div>サービス・工場長</div>\n                      <div>J.O さん<span>（2009年入社）</span></div>\n                    </div>\n                  </a>\n                </li>\n              </ul>\n            </li>\n          </ul>\n        </div>\n      </section>\n\n      <section class=\"l-sec p-secTopOverview\">\n  <div class=\"l-sec_in\">\n    <div class=\"p-secTopOverview_cnt\">\n      <div class=\"_img\">\n        <div>\n          <a href=\"/\">\n            <img src=\"/assets/img/common/logo2.svg\" alt=\"\">\n          </a>\n        </div>\n      </div>\n      <div class=\"_txt\">\n        <div class=\"p-menuLink\">\n  <dl>\n    <dt>COMPANY</dt>\n    <dd>\n      <ul> \n        <li><a href=\"/company/\">飾らないルーツを知る（スズキの歴史とスタンス）</a></li>\n        <li><a href=\"/sales/\">全国のお客様を飾る販売会社（スズキ販売会社の紹介）</a></li>\n      </ul>\n    </dd>\n  </dl>\n  <dl>\n    <dt>WORK</dt>\n    <dd>\n      <ul>\n        <li><a href=\"/work/\">お客様の人生を飾る3つの仕事（職種紹介・キャリアステップ）</a></li>\n      </ul>\n    </dd>\n  </dl>\n  <dl>\n    <dt>PEOPLE</dt>\n    <dd>\n      <ul>\n        <li><a href=\"/people/interview/\">飾らない自分で、お客様の人生を飾る（社員インタビュー）</a></li>\n        <li><a href=\"/people/crosstalk/\">飾らずに、語り合う（対談）</a></li>\n      </ul>\n    </dd>\n  </dl>\n  <dl>\n    <dt>TRAINING</dt>\n    <dd>\n      <ul>\n        <li><a href=\"/training/\">人生を飾るための手厚いフォロー（教育研修制度の紹介）</a></li>\n      </ul>\n    </dd>\n  </dl>\n</div>      </div>\n    </div>\n    <div class=\"p-secTopOverview_copy\">COPYRIGHT © 2024 SUZUKI MOTOR CORPORATION, LTD. ALL RIGHTS RESERVED.</div>\n  </div>\n</section>      <section class=\"p-secTopFooter\">\n  <div class=\"p-secTopFooter_in\">\n    <div class=\"p-secTopFooter_sticky\">\n      <div class=\"_concept\">\n        <h1><span>飾らない自分で、</span><span>お客様の人生を飾ろう</span></h1>\n        <div class=\"_btn\">\n      