{"url":"http://www.greenmessage.co.jp/recruit/partner.html","html":"<!doctype html>\n<html lang=\"ja\">\n<head>\n\t<meta charset=\"UTF-8\">\n\t<meta name=\"description\" content=\"生産者、ユーザー、消費者の想いをつないでまいります。グリーンメッセージは生産技術や商品開発に注力したサラダメーカーです。\">\n\t<meta name=\"Keywords\" content=\"グリーンメッセージ, サラダ, 野菜工場, 食生活, キユーピー\" />\n\t<meta name=\"viewport\" content=\"width=device-width\">\n\t<title>パートナー採用 ｜ グリーンメッセージ</title>\n\t<link rel=\"stylesheet\" media=\"all\" href=\"../css/common/common.css\">\n\t<link rel=\"stylesheet\" media=\"all\" href=\"../css/recruit/style.css\">\n\t<script src=\"https://ajax.googleapis.com/ajax/libs/jquery/1.8.0/jquery.min.js\"></script>\n\t<script src=\"../js/script.js\"></script>\n\t<script src=\"../js/fitie.js\"></script>\n</head>\n\n<body>\n\t<div id=\"wrapper\">\n\t\t<div id=\"sidebar\">\n\t\t\t<div id=\"sidebarWrap\">\n\t\t\t\t<nav id=\"mainnav\">\n\t\t\t\t\t<div class=\"header_gm\"><a href=\"../index.html\"><img src=\"../images/common/btn_header_greenmessage.png\"></a></div>\n\t\t\t\t\t<p id=\"menuWrap\"><a id=\"menu\"><span id=\"menuBtn\"></span></a></p>\n\t\t\t\t\t<div class=\"panel\">\n\t\t\t\t\t\t<ul>\n\t\t\t\t\t\t\t<li><a href=\"../company/about_greenmessage.html\"><b>会社案内</b></a></li>\n\t\t\t\t\t\t\t<li><a href=\"../effort/resource.html\"><b>とりくみ</b></a></li>\n\t\t\t\t\t\t\t<li><a href=\"../commit/delicious.html\"><b>こだわり</b></a></li>\n\t\t\t\t\t\t\t<li><a href=\"../department/production.html\"><b>部署紹介</b></a></li>\n\t\t\t\t\t\t\t<li>\n\t\t\t\t\t\t\t\t<a href=\"../recruit/new_graduate.html\">\n\t\t\t\t\t\t\t\t\t<span class=\"recruit\">\n\t\t\t\t\t\t\t\t\t\t<b>採用情報</b>\n\t\t\t\t\t\t\t\t\t</span>\n\t\t\t\t\t\t\t\t</a>\n\t\t\t\t\t\t\t</li>\n\t\t\t\t\t\t</ul>\n\t\t\t\t\t</div>\n\t\t\t\t</nav>\n\t\t\t</div>\n\t\t</div>\n\n\t\t<header id=\"header\">\n\t\t\t<img src=\"../images/recruit/img_career_main_image.png\">\n\t\t\t<div id=\"slogan_4words\">\n\t\t\t\t<img src=\"../images/recruit/img_career_logo_main.png\">\n\t\t\t</div>\n\t\t</header>\n\n\t\t<!-- サブメニュー -->\n\t\t<span id=\"submenu\" class=\"link-t-a\"></span>\n\t\t<div class=\"submenu\">\n\t\t\t<ul>\n\t\t\t\t<li class=\"select\"><a href=\"new_graduate.html#submenu\" class=\"anchor\">新卒採用</a></li>\n\t\t\t\t<li><a href=\"partner.html#submenu\"><b>パートナー採用</b></a></li>\n\t\t\t</ul>\n\t\t</div>\n\t\t<!-- //サブメニュー -->\n\n\t\t<!-- サブメニュー以下メインコンテンツ -->\n\t\t<section id=\"main\">\n\t\t\t<div class=\"subtitle_text\">\n\t\t\t\t募集要項\n\t\t\t</div>\n\t\t\t<!--div class=\"wave\">\n\t\t\t\t<img src=\"../images/common/img_line_wave.png\">\n\t\t\t</div-->\n\t\t\t<div class=\"relation_company\">\n\t\t\t\t<br />\n\t\t\t\t<b>仕事内容</b><br />\n\t\t\t\t品質管理にこだわってサラダを作っている工場です。<br />野菜をカットしたり、サラダの盛り付けをする仕事です。<br />\n\t\t\t\t<hr/>\n\t\t\t\t<b>時給</b><br />\n\t\t\t\t神奈川県最低賃金＋10円～<br class=\"br-sp\" />&nbsp;※夜勤手当、交通費あり（規定内）<br />\n\t\t\t\t<hr/>\n\t\t\t\t<b>福利厚生</b><br />\n\t\t\t\tマニュアルによる業務説明、勉強会、社員登用制度あり<br />ユニフォーム貸与、社会保険完備<br />\n\t\t\t\t<hr/>\n\t\t\t\t<b>臨時雇用期間</b><br />\n\t\t\t\t入社後2ヶ月<br />\n\t\t\t\t<hr/>\n\t\t\t\t<b>勤務地</b><br />\n\t\t\t\t本社、本社工場<br />\n\t\t\t\t<hr/>\n\t\t\t\t<b>勤務時間</b><br />\n\t\t\t\t採用担当までご確認ください。<br class=\"br-sp\" />長期で働ける方を歓迎いたします。<br />\n\t\t\t\t<hr/>\n\t\t\t\t<b>休日</b><br />\n\t\t\t\tシフトによります<br class=\"br-sp\" />（月に8～9日を基本としますがご相談ください）<br />\n\t\t\t\t<hr/>\n\t\t\t\t<b>応募方法</b><br />\n\t\t\t\t採用担当係までメールまたは電話でお問い合わせください。<br class=\"br-pc\" />\n\t\t\t  （受付時間 平日9:00～17:00）<br>\n\t\t\t  <br />〒242-0001 神奈川県大和市下鶴間2415<br />TEL&nbsp;&nbsp;<a href=\"tel:07042513591\">070-4251-3591</a>（採用直通）<br />\n\t\t\t\tメール&nbsp;&nbsp;ml_greenmessagereception@kewpie.co.jp\n\t\t\t\t<hr/>\n\t\t\t</div>\n\t\t</section>\n\t\t<!-- //サブメニュー以下メインコンテンツ -->\n\n\t\t<!-- float解除 -->\n\t\t<div class=\"clearfix\"></div>\n\n\t\t<!-- フッター -->\n\t\t<footer id=\"mainnav_footer\">\n\t\t\t<ul>\n\t\t\t<li><a href=\"../site_policy.html\"><b>＞サイトポリシー</b></a></li>\n\t\t\t<li><a href=\"../privacy_policy.html\"><b>＞プライバシーポリシー</b></a></li>\n\t\t\t<li><a href=\"../contact.html\"><b>＞お問い合わせ</b>