{"url":"https://www.pro-win.co.jp/recruit/employmentseminar2027.html","html":"<!doctype html>\r\n<html>\r\n<head>\r\n<meta charset=\"utf-8\">\r\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1, user-scalable=no\">\r\n<meta name=\"format-detection\" content=\"telephone=no\">\r\n<title>新卒採用 募集要項（2027年度卒） ｜株式会社ウイン 採用情報</title>\r\n<meta name=\"keywords\" content=\"\">\r\n<meta name=\"description\" content=\"\">\r\n<!-- common -->\r\n<link href=\"common/css/base.css\" rel=\"stylesheet\" type=\"text/css\">\r\n<link href=\"common/css/common.css\" rel=\"stylesheet\" type=\"text/css\">\r\n<link href=\"common/css/contents.css\" rel=\"stylesheet\" type=\"text/css\">\r\n<link href=\"common/css/seminar2027.css\" rel=\"stylesheet\" type=\"text/css\">\r\n<link rel=\"icon\" href=\"/common/images/favicon.svg\" type=\"image/svg\">\r\n<!--[if lt IE 9]>\r\n<script src=\"http://html5shim.googlecode.com/svn/trunk/html5.js\"></script>\r\n<![endif]-->\r\n<script src=\"http://ajax.googleapis.com/ajax/libs/jquery/1.8.2/jquery.min.js\"></script>\r\n<script src=\"common/js/jquery.cookie.js\" type=\"text/javascript\"></script>\r\n<script type=\"text/javascript\" src=\"common/js/jquery.set.js\"></script>\r\n<script type=\"text/javascript\" src=\"common/js/heightLine.js\"></script>\r\n<script type=\"text/javascript\" src=\"common/js/scrollsmoothly.js\"></script>\r\n<script>\r\n$(function() {\r\n\tvar array = [\r\n\t\"images/bg01.png\",\r\n\t\"images/bg02.png\",\r\n\t];\r\n \r\n\tvar l = array.length;\r\n\tvar r = Math.floor(Math.random()*l);\r\n\tvar bgimgurl = array[r];\r\n\t$(\"h1#img\").css('background-image',('url(\"'+bgimgurl+'\")'));\r\n});\r\n</script>\r\n<script src=\"//kitchen.juicer.cc/?color=Hvo/yBbwnSM=\" async></script>\n<!-- Google tag (gtag.js) -->\n\t<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-3MKRWRKFDZ\"></script>\n\t<script>\n\t\twindow.dataLayer = window.dataLayer || [];\n\n\t\tfunction gtag() {\n\t\t\tdataLayer.push(arguments);\n\t\t}\n\t\tgtag('js', new Date());\n\n\t\tgtag('config', 'G-3MKRWRKFDZ');\n\n\t</script>\n<!-- Begin Mieruca Embed Code -->\n<script type=\"text/javascript\" id=\"mierucajs\">\nwindow.__fid = window.__fid || [];__fid.push([806551535]);\n(function() {\nfunction mieruca(){if(typeof window.__fjsld != \"undefined\") return; window.__fjsld = 1; var fjs = document.createElement('script'); fjs.type = 'text/javascript'; fjs.async = true; fjs.id = \"fjssync\"; var timestamp = new Date;fjs.src = ('https:' == document.location.protocol ? 'https' : 'http') + '://hm.mieru-ca.com/service/js/mieruca-hm.js?v='+ timestamp.getTime(); var x = document.getElementsByTagName('script')[0]; x.parentNode.insertBefore(fjs, x); };\nsetTimeout(mieruca, 500); document.readyState != \"complete\" ? (window.attachEvent ? window.attachEvent(\"onload\", mieruca) : window.addEventListener(\"load\", mieruca, false)) : mieruca();\n})();\n</script>\n<!-- End Mieruca Embed Code -->\n</head>\r\n\r\n<body>\r\n<!-- skip_nav -->\r\n<div id=\"page_top\">\r\n  <p class=\"skip\">ページの先頭です。</p>\r\n  <p class=\"skip\"><a href=\"#skip_menu\">メインメニューへ移動します。</a></p>\r\n  <p class=\"skip\"><a href=\"#skip_honbun\">本文へ移動します。</a></p>\r\n  <p class=\"skip\"><a href=\"#skip_footer\">フッターへ移動します。</a></p>\r\n</div>\r\n<!-- /skip_nav --> \r\n\r\n<!-- // Header START // -->\r\n<header>\r\n<div id=\"HeadSubMenu\">\r\n<ul class=\"clearfix\">\r\n  <li><a href=\"/inquiry/\">お問い合わせ</a></li>\r\n  <li><a href=\"/profile/office.html\">アクセス</a></li>\r\n  <li><a href=\"/\">ウインコーポレートサイト</a></li>\r\n</ul>\r\n</div><!-- /#HeadSubMenu -->\r\n\r\n<p id=\"skip_menu\" class=\"skip\">メインメニューです。</p>\r\n<div id=\"HeadEntryMenu\" class=\"clearfix\">\r\n  <div class=\"innerBlock\">\r\n    <p><a href=\"/recruit/\"><img src=\"/recruit/common/images/logo.png\" width=\"388\" height=\"34\" alt=\"株式会社ウイン 採用情報\"/></a></p>\r\n    <ul class=\"clearfix button\">\r\n      <li><a href=\"/recruit/entry/#section01\">新卒採用</a></li>\r\n      <li><a href=\"/recruit/entry/#section02\">キャリア採用</a></li>\r\n    </ul>\r\n  </div>\r\n</div><!-- /#HeadEntryMenu --><div id=\"HeadGlobalMenu\">\r\n  <ul class=\"clearfix button\">\r\n    <li><a href=\"/recruit/vision/\">ビジョン</a></li>\r\n    <li><a href=\"/recruit/seek/\">求める人材</a></li>\r\n    <li><a href=\"/profile/approach.html\">ウインの取組み</a></li>\r\n    <li><a href=\"/recruit/department/\">部署紹介</a></li>\r\n    <li><a href=\"/recruit/jobcategory/\">募集職種</a></li>\r\n    <li><a href=\"/recruit/flow/\">採用の流れ</a></li>\r\n  </ul>\r\n</div><!-- /#HeadGlobalMenu --><div class=\"main-seminar2027\">\r\n<h1>\r\n  <img class=\"main-pc-seminar2027\" src=\"./common/images/seminar2027/main-pc.jpg\" alt=\"松山から、次のスタンダードを創る。\">\r\n  <img class=\"main-sp-seminar2027\" src=\"./common/images/seminar2027/main-sp.jpg\" alt=\"松山から、次のスタンダードを創る。\">\r\n</h1>\r\n</div>\r\n\r\n</header>\r\n<!-- // Header END // -->\r\n\r\n\r\n\r\n<!-- // Contents START // -->\r\n\r\n\r\n<p id=\"skip_honbun\" class=\"skip\">本文です。</p>\r\n\r\n<section class=\"section-seminar2027\">\r\n  <div>\r\n    <p class=\"fs-1up-seminar2027\">私たちは、愛媛・松山を拠点にITシステム開発、Web制作、BPO事業、さらには地域の文化施設マネジメントまで幅広い事業を展開しています。<br>「地元に貢献したい」「松山にいながら最先端のスキルを身につけたい」という想いを持つ愛媛大学の皆さんのエントリーをお待ちしています。 </p>\r\n  </div>\r\n</section>\r\n\r\n<section class=\"section-seminar2027 section-seminar2027-bg-blue\">\r\n  <div>\r\n    <h2>募集職種および仕事内容</h2>\r\n    <p class=\"mb-m-seminar2027\">文系・理系を問わず、あなたの適性や興味に合わせて以下の5つのコースからキャリアを選択できます。入社後の研修体制が整っているため、どの職種も未経験からプロフェッショナルを目指せます。 </p>\r\n    <div class=\"about-box-seminar2027\">\r\n      <h3>システム営業コース（DXソリューション）</h3>\r\n      <ul class=\"about-list-seminar2027\">\r\n        <li>\r\n          <h4>主な仕事内容</h4>\r\n          <p>地元企業や自治体の課題をヒアリングし、ITシステムやAIツール、Web制作などを組み合わせた解決策（DX化）を提案・コンサルティングします。「売る」のではなく「一緒に課題を解決する」お医者さんのようなポジションです。</p>\r\n        </li>\r\n        <li>\r\n          <h4>求めるスキル・素養</h4>\r\n          <p>コミュニケーション能力、課題解決への熱意、相手に寄り添う力</p>\r\n        </li>\r\n      </ul>\r\n    </div>\r\n    <div class=\"about-box-seminar2027\">\r\n      <h3>ITエンジニアコース</h3>\r\n      <ul class=\"about-list-seminar2027\">\r\n        <li>\r\n          <h4>主な仕事内容</h4>\r\n          <p>システム開発、アプリ開発、AIを活用した業務効率化ツールの構築などを行います。社会インフラから身近なアプリまで、自分の組んだプログラムが動くやりがいを味わえます。</p>\r\n        </li>\r\n        <li>\r\n          <h4>求めるスキル・素養</h4>\r\n          <p>プログラミングやモノづくりへの興味、論理的思考力</p>\r\n        </li>\r\n      </ul>\r\n    </div>\r\n    <div class=\"about-box-seminar2027\">\r\n      <h3>Webクリエイターコース </h3>\r\n      <ul class=\"about-list-seminar2027\">\r\n        <li>\r\n          <h4>主な仕事内容</h4>\r\n          <p>Webサイトの企画・デザイン、コーディングなどを担当します。お客様の魅力を引き出し、ターゲットに届くクリエイティブを形にする仕事です。</p>\r\n        </li>\r\n        <li>\r\n          <h4>求めるスキル・素養</h4>\r\n          <p>デザインや情報発信への興味、トレンドへの敏感さ</p>\r\n        </li>\r\n      </ul>\r\n    </div>\r\n    <div class=\"about-box-seminar2027\">\r\n      <h3>BPO総合職コース</h3>\r\n      <ul class=\"about-list-seminar2027\">\r\n        <li>\r\n          <h4>主な仕事内容</h4>\r\n          <p>企業のバックオフィス業務（データ入力、コールセンター運営など）の設計・マネジメントを行います。業務フローの改善やスタッフの育成など、組織を動かすマネジメント力が身につきます。</p>\r\n        </li>\r\n        <li>\r\n          <h4>求めるスキル・素養</h4>\r\n          <p>業務プロセスの構築力、チームマネジメント力、サポート力</p>\r\n        </li>\r\n      </ul>\r\n    </div>\r\n    <div class=\"about-box-seminar2027\">\r\n      <h3>企画・施設マネジメントコース</h3>\r\n      <ul class=\"about-list-seminar2027\">\r\n        <li>\r\n          <h4>主な仕事内容</h4>\r\n          <p>地域の歴史的建造物や文化施設の運営管理、各種イベントの企画・プロデュースを行います。愛媛の魅力を県内外へ発信し、地域の活性化に直接関わることができる仕事です。</p>\r\n        </li>\r\n        <li>\r\n          <h4>求めるスキル・素養</h4>\r\n          <p>企画力、地域文化・歴史への関心、ホスピタリティ </p>\r\n        </li>\r\n      </ul>\r\n    </div>\r\n  </div>\r\n</section>\r\n\r\n<section class=\"section-seminar2027\">\r\n  <div>\r\n    <h2>募集対象・求める人物像</h2>\r\n    <p class=\"mb-m-seminar2027\"><strong>対象：</strong>2027年3月に大学・大学院を卒業・修了見込みの方（文理不問・全学部全学科対象） </p>\r\n    <h3>歓迎する人物像</h3>\r\n    <ul class=\"list-mark-seminar2027\">\r\n      <li>松山の街や地域社会に貢献したいという強い想いがある方</li>\r\n      <li>AIなどの新しい技術やトレンドに興味があり、積極的に吸収したい方</li>\r\n      <li>チームワークを大切にし、自ら主体的に考え、行動できる方</li>\r\n    </ul>\r\n  </div>\r\n</section>\r\n\r\n<section class=\"section-seminar2027\">\r\n  <div>\r\n    <h2>勤務条件</h2>\r\n    <table>\r\n      <tbody>\r\n        <tr>\r\n          <th>初任給（大卒・大学院卒）</th>\r\n          <td>月給 220,000円</td>\r\n        </tr>\r\n        <tr>\r\n          <th>諸手当</th>\r\n          <td>・通勤手当（月額上限15,000円まで支給）<br>\r\n・時間外勤務手当（実績に応じて全額支給）<br>\r\n・役職手当<br>\r\n・資格手当（IT関連、AI関連資格など対象資格）</td>\r\n        </tr>\r\n        <tr>\r\n          <th>昇給・賞与</th>\r\n          <td><strong>昇給：</strong>年1回（定期評価に基づく）<br>\r\n<strong>賞与：</strong>年2回（8月・12月） ※会社の業績および個人の評価に基づき支給 </td>\r\n        </tr>\r\n        <tr>\r\n          <th>勤務地</th>\r\n          <td>愛媛県松山市（本社およびITソリューション事業本部）<br>\r\n※原則として転勤はありません。大好きな松山の街で腰を据えて中長期的なキャリアを築くことができます。</td>\r\n        </tr>\r\n        <tr>\r\n          <th>勤務時間</th>\r\n          <td>勤務時間：9:00 ～ 18:00（実働8時間 ／ 休憩60分）</td>\r\n        </tr>\r\n        <tr>\r\n          <th>休日休暇</th>\r\n          <td>・完全週休2日制（土日祝） ※施設運営部門はシフト制による週休2日<br>\r\n・年間休日 120日以上<br>\r\n・年末年始休暇、夏季休暇<br>\r\n・有給休暇（入社半年後に10日付与）<br>\r\n・慶弔休暇、産前産後休暇、育児休暇（取得・復帰実績あり）</td>\r\n        </tr>\r\n        <tr>\r\n          <th>福利厚生・社内制度</th>\r\n          <td><strong>各種保険：</strong>社会保険完備（雇用、労災、健康、厚生年金）<br>\r\n<strong>AI・ITスキルアップ支援：</strong>業務でのAI活用研修や、資格取得のための受験費用補助・報奨金制度<br>\r\n<strong>地域貢献アクティビティ：</strong>* 社員参加型の地域コミュニティ活動やボランティア活動への参加<br>\r\n<strong>その他：</strong>定期健康診断、マイカー通勤可（駐車場あり ※規定による）、社内クラブ補助 </td>\r\n        </tr>\r\n      </tbody>\r\n    </table>\r\n  </div>\r\n</section>\r\n\r\n<section class=\"section-seminar2027 section-seminar2027-flow\">\r\n  <div>\r\n    <h2>選考フロー（予定）</h2>\r\n    <p class=\"mb-m-seminar2027\">選考は人物重視で行います。皆さんの「愛媛で実現したいこと」「学生時代に熱中したこと」をぜひご自身の言葉で聞かせてください。</p>\r\n    <ul class=\"list-flow-seminar2027\">\r\n      <li>\r\n        <div>\r\n          <span class=\"this_num\">01</span>\r\n          <span class=\"this_ttl\">エントリー</span>\r\n          <span class=\"this_txt\">弊社採用ページよりエントリーください。</span>\r\n        </div>\r\n      </li>\r\n      <li>\r\n        <div>\r\n          <span class=\"this_num\">02</span>\r\n          <span class=\"this_ttl\">会社説明会</span>\r\n          <span class=\"this_txt\">対面・オンライン両方で開催。先輩社員との座談会もあります。</span>\r\n        </div>\r\n      </li>\r\n      <li>\r\n        <div>\r\n          <span class=\"this_num\">03</span>\r\n          <span class=\"this_ttl\">書類選考</span>\r\n          <span class=\"this_txt\">履歴書またはエントリーシートでの選考を行います。</span>\r\n        </div>\r\n      </li>\r\n      <li>\r\n        <div>\r\n          <span class=\"this_num\">04</span>\r\n          <span class=\"this_ttl\">一次面接</span>\r\n          <span class=\"this_txt\">人事担当者・現場責任者との面接と、適性検査を行います。</span>\r\n        </div>\r\n      </li>\r\n      <li>\r\n        <div>\r\n          <span class=\"this_num\">05</span>\r\n          <span class=\"this_ttl\">最終面接</span>\r\n          <span class=\"this_txt\">役員との最終面接を行います。</span>\r\n        </div>\r\n      </li>\r\n      <li>\r\n        <div>\r\n          <span class=\"this_num\">06</span>\r\n          <span class=\"this_ttl\">内定</span>\r\n        </div>\r\n      </li>\r\n    </ul>\r\n    <h3>お問い合わせ先</h3>\r\n    <p><a href=\"&#109;&#97;&#105;&#108;&#116;&#111;&#58;&#119;&#105;&#110;&#46;&#104;&#111;&#110;&#115;&#121;&#97;&#46;&#115;&#97;&#105;&#121;&#111;&#117;&#64;&#112;&#114;&#111;&#45;&#119;&#105;&#110;&#46;&#99;&#111;&#46;&#106;&#112;\"><img src=\"/recruit/common/images/recruit-mail.png\" alt=\"採用に関するメール\"></a></p>\r\n    \r\n\r\n  </div>\r\n</section>\r\n\r\n<!-- // Contents END // -->\r\n\r\n\r\n<!-- // Footer START // -->\r\n<footer>\r\n\r\n<div id=\"gotop\"><a href=\"#page_top\"><img class=\"imgover\" src=\"common/images/btn_pagetop.png\" width=\"70\" height=\"70\" alt=\"このページの一番上へ\" /></a></div> \r\n\r\n<p id=\"skip_footer\" class=\"skip\">フッターです。</p>\r\n</footer>\r\n<!-- // Footer END // -->\r\n\r\n</body>\r\n</html>\r\n","finalUrl":"https://www.pro-win.co.jp/recruit/employmentseminar2027.html","rendered":false,"_cachedAt":"2026-06-22T16:48:12.685Z"}