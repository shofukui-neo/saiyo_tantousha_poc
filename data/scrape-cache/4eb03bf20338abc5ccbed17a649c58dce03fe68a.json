ataLayer', 'GTM-P8XXC67');</script>\r\n  <!-- End Google Tag Manager -->\r\n</head>\r\n\r\n<body>\r\n  <!-- Google Tag Manager (noscript) -->\r\n  <noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-P8XXC67\" height=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\r\n  <!-- End Google Tag Manager (noscript) -->\r\n\r\n  <div id=\"header\"></div>\r\n  <script>\r\n    $(function () {\r\n      $('#header').load('https://www.tepco-sa.co.jp/ssl/src/inc/header.html');\r\n    });\r\n  </script>\r\n\r\n  <div class=\"page-wrapper career-job-listings-contract-page\">\r\n    <div class=\"main-container bg-transparent p-0 mb-5\">\r\n      <nav aria-label=\"breadcrumb\" class=\"page-breadcrumb\">\r\n        <ol class=\"breadcrumb mb-0\">\r\n          <li class=\"breadcrumb-item\"><a href=\"https://www.tepco-sa.co.jp/ssl/\">ホーム</a></li>\r\n          <li class=\"breadcrumb-item\"><a href=\"https://www.tepco-sa.co.jp/ssl/recruit/\">採用情報</a></li>\r\n          <li class=\"breadcrumb-item\"><a href=\"https://www.tepco-sa.co.jp/ssl/recruit/work_contents/\">おしごと紹介</a></li>\r\n          <li class=\"breadcrumb-item active\" aria-current=\"page\">障がいのある方</li>\r\n        </ol>\r\n      </nav>\r\n    </div>\r\n    <div class=\"main-container\">\r\n      <div class=\"heading-wrapper\">\r\n        <div class=\"heading\">\r\n          <div class=\"sc-title text-center\">障がいのある方</div>\r\n          <div class=\"sub-title text-center text-uppercase fw-bold\">Handicap</div>\r\n        </div>\r\n      </div>\r\n\r\n      <div class=\"work-detail\">\r\n        <div class=\"work-detail-intro\">\r\n          <div class=\"work-detail-intro-img\"><img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/work_contents/handicap/img01.png\" alt=\"\"></div>\r\n          <div>\r\n            <div class=\"work-detail-intro-ttl\">仕事内容</div>\r\n            <p class=\"para-text\">・庶務<br>\r\n              ・コピー・スキャナー作業やFAX送信<br>\r\n              ・データ入力</p>\r\n            <p class=\"para-text\">お持ちの障がいの内容とご本人の希望や適性を考慮し勤務地と業務をご紹介します。ご興味がある方は、「応募する」ボタンからお気軽にご応募ください。\r\n              （障がいの内容に合ったお仕事をご紹介させていただくために、障がい者手帳名や等級など差支えない範囲でご入力ください）</p>\r\n          </div>\r\n        </div>\r\n        <div class=\"work-detail-heading mt-5\">\r\n          <span>Detail 1</span>\r\n          <div>庶務</div>\r\n        </div>\r\n        <p class=\"para-text\">文房具などの備品の受発注や書類の仕分け、ファイリングするなどの整理業務やお客さまにハガキなどを郵送します。</p>\r\n        <div class=\"work-detail-heading mt-5\">\r\n          <span>Detail 2</span>\r\n          <div>コピー・スキャナー処理やFAX送信</div>\r\n        </div>\r\n        <p class=\"para-text\">書類のコピーやスキャナー作業、受付処理が完了した申込用紙などを取引先へFAX送信します。</p>\r\n        <div class=\"work-detail-heading mt-5\">\r\n          <span>Detail 3</span>\r\n          <div>データ入力</div>\r\n        </div>\r\n        <p class=\"para-text\">東京電力のお客さま情報や処理実績を決められたフォーマットに入力します。</p>\r\n\r\n        <p class=\"text-end mt-5\"><a href=\"https://www.tepco-sa.co.jp/ssl/recruit/part_time/voice_04/\" class=\"c-link\">VOICE はたらく人の声～障がいのある方～</a></p>\r\n      </div>\r\n\r\n    </div>\r\n  </div>\r\n  <!-- main content -->\r\n\r\n  <div id=\"footer\"></div>\r\n  <script defer>\r\n    $(function () {\r\n      $('#footer').load('https://www.tepco-sa.co.jp/ssl/src/inc/footer.html');\r\n    });\r\n  </script>\r\n  <script src=\"https://www.tepco-sa.co.jp/ssl/src/js/popper.min.js\"></script>\r\n  <script src=\"https://www.tepco-sa.co.jp/ssl/src/js/bootstrap.min.js\"></script>\r\n  <script src=\"https://www.tepco-sa.co.jp/ssl/src/js/slick.js\"></script>\r\n  <script src=\"https://www.tepco-sa.co.jp/ssl/src/js/jquery.matchHeight-min.js\"></script>\r\n  <script src=\"https://www.tepco-sa.co.jp/ssl/src/js/custom.js\"></script>\r\n</body>\r\n\r\n</html>","finalUrl":"https://www.tepco-sa.co.jp/ssl/recruit/work_contents/handicap/","rendered":false,"_cachedAt":"2026-06-22T21:08:16.226Z"}