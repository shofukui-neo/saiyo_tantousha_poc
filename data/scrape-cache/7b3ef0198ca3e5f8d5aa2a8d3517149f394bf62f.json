{"url":"https://www.data-p.co.jp/contact/","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n\n  <head>\n    <!-- Google Tag Manager -->\n    <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\n    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\n    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n    })(window,document,'script','dataLayer','GTM-KG4D784');</script>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width\">\n    <title>お問い合わせフォーム | DATAPLUS [株式会社データプラス]</title>\n    <meta name=\"description\" content=\"信頼のNTTグループ企業 DATAPLUS [株式会社データプラス]へのお問い合わせについて。\">\n    <meta name=\"keywords\" content=\"データプラス,DATAPLUS,NTT\">\n\n    <meta property=\"og:type\" content=\"article\">\n    <meta property=\"og:title\" content=\"お問い合わせフォーム | DATAPLUS [株式会社データプラス]\">\n    <meta property=\"og:description\" content=\"信頼のNTTグループ企業 DATAPLUS [株式会社データプラス]へのお問い合わせについて。\">\n    <meta property=\"og:site_name\" content=\"DATAPLUS [株式会社データプラス] ウェブサイト\">\n    <meta property=\"og:url\" content=\"https://www.data-p.co.jp/contact/\">\n    <meta property=\"og:image\" content=\"https://www.data-p.co.jp/common/img/common/og_image.png\">\n\n    <meta http-equiv=\"Pragma\" content=\"no-cache\">\n    <meta http-equiv=\"Cache-Control\" content=\"no-store,no-cache\">\n    <meta http-equiv=\"Expires\" content=\"0\">\n\n      <link href=\"/common/img/common/favicon.ico\" rel=\"icon\">\n  <link href=\"/common/img/common/touch-icon.png\" sizes=\"180x180\" rel=\"apple-touch-icon\">\n  <link href=\"https://fonts.googleapis.com/css?family=Noto+Sans+JP:400,700&display=swap\" rel=\"stylesheet\">\n  <link href=\"https://fonts.googleapis.com/css?family=Roboto:700,900i&display=swap\" rel=\"stylesheet\">\n  <link href=\"/common/css/common.css\" rel=\"stylesheet\">\n<!-- Global site tag (gtag.js) - Google Analytics -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=UA-152929986-1\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'UA-152929986-1');\n  gtag('config', 'AW-693389117');\n</script>\n<script async src=\"https://s.yimg.jp/images/listing/tool/cv/ytag.js\"></script>\n<script>\nwindow.yjDataLayer = window.yjDataLayer || [];\nfunction ytag() { yjDataLayer.push(arguments); }\nytag({\"type\":\"ycl_cookie\", \"config\":{\"ycl_use_non_cookie_storage\":true}});\n</script>\n<script async src=\"https://s.yimg.jp/images/listing/tool/cv/ytag.js\"></script>\n<script>\nwindow.yjDataLayer = window.yjDataLayer || [];\nfunction ytag() { yjDataLayer.push(arguments); }\nytag({\n  \"type\":\"yjad_retargeting\",\n  \"config\":{\n    \"yahoo_retargeting_id\": \"3VY030UDKM\",\n    \"yahoo_retargeting_label\": \"\"\n    /*,\n    \"yahoo_retargeting_page_type\": \"\",\n    \"yahoo_retargeting_items\":[\n      {item_id: '', category_id: '', price: '', quantity: ''}\n    ]*/\n  }\n});\n</script>\n  </head>\n\n  <body>\n    <!-- Google Tag Manager (noscript) -->\n    <noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-KG4D784\"\n    height=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n    <!-- End Google Tag Manager (noscript) -->\n    <div class=\"l-container\">\n\n      <noscript>\n  <div class=\"c-box -danger u-ta-c\">\n    <p class=\"u-font-red\">当サイトはJavaScriptを使用しています。<br>JavaScriptが無効になっている場合は、有効にしてください。</p>\n  </div>\n</noscript>\n<header class=\"l-header\">\n  <div class=\"l-header__inner\">\n    <div class=\"l-header__logo\">\n      <a href=\"/\">\n        <img src=\"/common/img/common/logo_main.svg\" alt=\"株式会社データプラス\">\n      </a>\n    </div>\n    <a class=\"l-header-menu-btn\">\n      <span></span>\n      <span></span>\n      <span></span>\n    </a>\n    <div class=\"l-header__nav\">\n      <nav class=\"l-gnav\">\n        <ul class=\"l-gnav__list\">\n          <li class=\"l-gnav__item\">\n            <a href=\"/\" class=\"l-gnav__link\" data-text=\"HOME\">ホーム</a>\n          </li>\n          <li class=\"l-gnav__item\">\n            <a href=\"/works/\" class=\"l-gnav__link\" data-text=\"WORKS\">事業案内</a>\n          </li>\n          <li class=\"l-gnav__item\">\n            <a href=\"/company/\" class=\"l-gnav__link\" data-text=\"COMPANY\">会社案内</a>\n          </li>\n          <li class=\"l-gnav__item\">\n            <a href=\"/news/\" class=\"l-gnav__link\" data-text=\"NEWS\">お知らせ</a>\n          </li>\n        </ul>\n      </nav>\n      <div class=\"l-header-text-size\">\n        <span class=\"l-header-text-size__title\">文字サイズ</span>\n        <button class=\"l-header-text-size__small\">小</button>\n        <button class=\"l-header-text-size__medium -current\">中</button>\n        <button class=\"l-header-text-size__large\">大</button>\n      </div>\n      <div class=\"l-header__contact\">\n        <a href=\"/contact/\" class=\"l-header__contact-btn\">お問い合わせ</a>\n      </div>\n    </div>\n  </div>\n</header>\n\n      <main class=\"l-main\">\n        \n        <div class=\"l-title -contact\">\n          <div class=\"l-title__text\">\n            <h1 class=\"l-title__main\">お問い合わせフォーム</h1>\n            <span class=\"l-title__sub\">CONTACT FORM</span>\n          </div>\n        </div>\n        \n        <div class=\"c-content-block\">\n          <div class=\"c-content-block__inner\">\n            \n            <div class=\"c-form-block\">\n\n\n\n              <form action=\"./\" method=\"post\" class=\"h-adr\">\n\n                <span class=\"p-country-name\" style=\"display:none;\">Japan</span>\n\n                <dl class=\"c-form\">\n                  <dt class=\"c-form__title\">お問い合わせ項目（複数選択可）<span class=\"c-form__label\">必須</span></dt>\n                  <dd class=\"c-form__body \">\n\n<ul class=\"c-form__btn-list\">\n    <li><label for=\"type_1\"  class=\"c-checkbox\"><input name=\"type[1]\" id=\"type_1\" type=\"checkbox\" value=\"1\"  class=\"c-checkbox__input\"><span class=\"c-checkbox__text\">指示らくネットforトラックについて</span></label></li>\n    <li><label for=\"type_2\"  class=\"c-checkbox\"><input name=\"type[2]\" id=\"type_2\" type=\"checkbox\" value=\"2\"  class=\"c-checkbox__input\"><span class=\"c-checkbox__text\">ロジスティクスについて</span></label></li>\n    <li><label for=\"type_3\"  class=\"c-checkbox\"><input name=\"type[3]\" id=\"type_3\" type=\"checkbox\" value=\"3\"  class=\"c-checkbox__input\"><span class=\"c-checkbox__text\">指示らくネットforバスについて</span></label></li>\n    <li><label for=\"type_4\"  class=\"c-checkbox\"><input name=\"type[4]\" id=\"type_4\" type=\"checkbox\" value=\"4\"  class=\"c-checkbox__input\"><span class=\"c-checkbox__text\">プリンティングについて</span></label></li>\n    <li><label for=\"type_5\"  class=\"c-checkbox\"><input name=\"type[5]\" id=\"type_5\" type=\"checkbox\" value=\"5\"  class=\"c-checkbox__input\"><span class=\"c-checkbox__text\">メーリングについて</span></label></li>\n    <li><label for=\"type_6\"  class=\"c-checkbox\"><input name=\"type[6]\" id=\"type_6\" type=\"checkbox\" value=\"6\"  class=\"c-checkbox__input\"><span class=\"c-checkbox__text\">システム開発について</span></label></li>\n    <li><label for=\"type_7\"  class=\"c-checkbox\"><input name=\"type[7]\" id=\"type_7\" type=\"checkbox\" value=\"7\"  class=\"c-checkbox__input\"><span class=\"c-checkbox__text\">データエントリーについて</span></label></li>\n</ul>\n\n                  </dd>\n                </dl>\n                <dl class=\"c-form\">\n                  <dt class=\"c-form__title\">会社名<span class=\"c-form__label\">必須</span></dt>\n                  <dd class=\"c-form__body \">\n\n                    <input type=\"text\" name=\"company\" class=\"c-input-text\" placeholder=\"例）株式会社データプラス\" value=\"\">\n\n                  </dd>\n                </dl>\n                <dl class=\"c-form\">\n                  <dt class=\"c-form__title\">お名前<span class=\"c-form__label\">必須</span></dt>\n                  <dd class=\"c-form__body \">\n\n                    <input type=\"text\" name=\"name\" class=\"c-input-text\" placeholder=\"例）山田　太郎\" value=\"\">\n\n                  </dd>\n                </dl>\n                <dl class=\"c-form\">\n                  <dt class=\"c-form__title\">電話番号<span class=\"c-form__label\">必須</span></dt>\n                  <dd class=\"c-form__body \">\n\n                    <input type=\"tel\" name=\"tel\" class=\"c-input-text -small\" placeholder=\"例）0312345678\" value=\"\" style=\"ime-mode: disabled;\">\n\n                  </dd>\n                </dl>\n                <dl class=\"c-form\">\n                  <dt class=\"c-form__title\">メールアドレス</dt>\n                  <dd class=\"c-form__body \">\n\n                    <input type=\"email\" name=\"email\" class=\"c-input-text\" placeholder=\"例）sample@data-p.co.jp\" value=\"\" style=\"ime-mode: disabled;\">\n\n                  </dd>\n                </dl>\n                <dl class=\"c-form\">\n                  <dt class=\"c-form__title\">郵便番号<span class=\"c-form__label\">必須</span></dt>\n                  <dd class=\"c-form__body \">\n\n                    <p>入力後に住所が自動入力されます。</p>\n                    <input type=\"tel\" name=\"zip\" class=\"c-input-text -small p-postal-code\" placeholder=\"例）8410048\" value=\"\" style=\"ime-mode: disabled;\" maxlength=\"7\">\n\n                  </dd>\n                </dl>\n                <dl class=\"c-form\">\n                  <dt class=\"c-form__title\">住所<span class=\"c-form__label\">必須</span></dt>\n                  <dd class=\"c-form__body \">\n\n                    <input type=\"text\" name=\"address\" class=\"c-input-text p-region p-locality p-street-address p-extended-address\" placeholder=\"例）佐賀県鳥栖市藤木町1-48\" value=\"\">\n\n                  </dd>\n                </dl>\n                <dl class=\"c-form\">\n                  <dt class=\"c-form__title\">お問い合わせ内容</dt>\n                  <dd class=\"c-form__body\">\n\n                    <textarea name=\"comment\" cols=\"30\" rows=\"10\" class=\"c-input-textarea\" placeholder=\"内容をご記入ください。\"></textarea>\n\n                  </dd>\n                </dl>\n\n                <div class=\"c-form-block__privacy\">\n                  <h2 class=\"c-heading -medium -sideline\">個人情報の取り扱いについて</h2>\n                  <p>株式会社データプラス（以下当社という）はご登録いただいた個人情報を適切に取り扱うために、以下の取り組みを実施いたします。</p>\n                  \n                  <ul class=\"c-ordered-list\">\n                    <li>\n                      <h3>個人情報の取扱い責任者</h3>\n                      <p>個人情報保護管理者 営業部長 臼井 学</p>\n                    </li>\n                    <li>\n                      <h3 class=\"\">個人情報の利用目的</h3>\n                      <p>当社は、下記の目的によりご登録いただいた個人情報を利用いたします。</p>\n                      <ul class=\"c-list\">\n                        <li>お客様との契約の履行、契約管理。</li>\n                        <li>当該サービスを提供に伴う連絡。</li>\n                        <li>お客様に有益と思われる当社のサービス、または提携先のサービス等の連絡。</li>\n                      </ul>\n                    </li>\n                    <li>\n                      <h3 class=\"\">個人情報の取扱いについて</h3>\n                      <p>取得した個人情報は、下記に該当する場合を除き、第三者への提供は行いません。</p>\n                      <ul class=\"c-list\">\n                        <li>お客様の同意がある場合</li>\n                        <li>利用目的を達成するために、事前に秘密保持契約を締結した当社の関連会社や業務委託先等に必要な範囲で開示する場合</li>\n                        <li>法令等により開示を求められた場合。</li>\n                      </ul>\n                    </li>\n                    <li>\n                      <h3>個人情報の開示</h3>\n                      <p>当社が所有する貴方の個人情報について貴方が開示を求められる場合は当社のホームページ「個人情報保護」7項に基づき行います。</p>\n                    </li>\n                    <li>\n                      <h3>個人情報保護に関するお問い合わせ先</h3>\n                      <p>個人情報相談窓口 <span class=\"js-tel-link\">0942-87-3111</span></p>\n                    </li>\n                  </ul>\n                </div>\n                \n                <p class=\"u-ta-c\">上記の内容をご確認のうえ、<br class=\"sp:view\">確認画面へお進みください。</p>\n\n                <div class=\"c-form-block__btns\">\n                  <button type=\"submit\" class=\"c-btn -blue\" name=\"check\">確認する</button>\n                </div>\n              </form>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"l-contact\">\n          <div class=\"l-contact__inner\">\n            <h2 class=\"l-contact__title\">お電話でのお問い合わせはこちら</h2>\n            <div class=\"l-contact__tel-wrap\">\n              <p class=\"l-contact__tel\"><span class=\"l-contact__tel-title\">クラウドシステムに関するご相談</span><br><span class=\"l-contact__tel-number js-tel-link\">0942-87-3114</span></p>\n              <p class=\"l-contact__tel\"><span class=\"l-contact__tel-title\">アウトソーシングに関するご相談</span><br><span class=\"l-contact__tel-number js-tel-link\">092-588-9380</span></p>\n            </div>\n          </div>\n        </div>\n\n      </main>\n\n      <footer class=\"l-footer\">\n  <a href=\"#\" class=\"l-footer__pagetop\"><span>ページ上部へ戻る</span></a>\n\n  <div class=\"l-footer__info\">\n    <div class=\"l-footer-info\">\n      <div class=\"l-footer-info__profile\">\n        <a href=\"/\" class=\"l-footer-info__logo\">\n          <img src=\"/common/img/common/logo_white.svg\" alt=\"株式会社データプラス\">\n        </a>\n        <p><span class=\"u-font-bold\">代表電話：</span><span class=\"js-tel-link\">0942-87-3111</span><br>\n          <span class=\"u-font-bold\">受付時間：</span>9:00 ～ 17:30<br>\n          （土日祝・年末年始を除く）</p>\n      </div>\n      <div class=\"l-footer-info__nav\">\n        <div class=\"l-footer-info__nav-list\">\n          <a href=\"/company/\" class=\"l-footer-info__nav-link -lv1\">会社案内</a>\n          <a href=\"/company/profile/\" class=\"l-footer-info__nav-link\">会社概要</a>\n          <a href=\"/company/privacy/\" class=\"l-footer-info__nav-link\">個人情報保護方針</a>\n          <a href=\"/company/policy/\" class=\"l-footer-info__nav-link\">情報セキュリティ・環境</a>\n          <a href=\"/company/compliance/\" class=\"l-footer-info__nav-link\">NTTグループ企業倫理憲章</a>\n        </div>\n        <div class=\"l-footer-info__nav-list\">\n          <span class=\"l-footer-info__nav-link -lv1 -disabled\">その他</span>\n          <a href=\"/news/\" class=\"l-footer-info__nav-link\">お知らせ</a>\n          <a href=\"/qa/\" class=\"l-footer-info__nav-link\">よくあるご質問</a>\n          <a href=\"/contact/\" class=\"l-footer-info__nav-link\">お問い合わせ</a>\n          <a href=\"/sitemap.html\" class=\"l-footer-info__nav-link\">サイトマップ</a>\n        </div>\n      </div>\n      <div class=\"l-footer-info__nav -col-2\">\n        <div class=\"l-footer-info__nav-list\">\n          <a href=\"/works/\" class=\"l-footer-info__nav-link -lv1\">事業案内</a>\n          <span class=\"l-footer-info__nav-link -lv2 -disabled\">クラウドシステム開発</span>\n          <a href=\"/works/truck/\" class=\"l-footer-info__nav-link\">指示らくネット for トラック</a>\n          <a href=\"/works/bus/\" class=\"l-footer-info__nav-link\">指示らくネット for バス</a>\n          <a href=\"/works/other/\" class=\"l-footer-info__nav-link\">その他システム開発</a>\n        </div>\n        <div class=\"l-footer-info__nav-list\">\n          <span class=\"l-footer-info__nav-link -lv2 -disabled\">アウトソーシング事業</span>\n          <a href=\"/works/logistics/\" class=\"l-footer-info__nav-link\">ロジスティクス</a>\n          <a href=\"/works/printing/\" class=\"l-footer-info__nav-link\">プリンティング</a>\n          <a href=\"/works/mailing/\" class=\"l-footer-info__nav-link\">メーリング</a>\n          <a href=\"/works/data_entry/\" class=\"l-footer-info__nav-link\">データエントリー</a>\n        </div>\n      </div>\n    </div>\n  </div>\n\n  <ul class=\"l-footer-certified\">\n    <li class=\"l-footer-certified__item\">\n      <a href=\"https://privacymark.jp/\" class=\"l-footer-certified__link\" target=\"_blank\" rel=\"noopener\">\n        <div class=\"l-footer-certified__image\"><img src=\"/common/img/common/img_certified_privacy.png\" alt=\"たいせつにします プライバシー\"></div>\n        <p class=\"l-footer-certified__text\">プライバシーマーク<br>\n          18820062(13)</p>\n      </a>\n    </li>\n    <li class=\"l-footer-certified__item\">\n      <div class=\"l-footer-certified__image\"><img src=\"/common/img/common/img_certified_management_isms.png\" alt=\"ISMS認証マーク\">\n      </div>\n      <p class=\"l-footer-certified__text\">情報セキュリティ マネジメント<br>\n        システム (ISMS) JQA-IM0599<br>\n        本社 鳥栖物流センタ<br>\n        諸岡物流センタ</p>\n    </li>\n  </ul>\n  <div class=\"l-footer-bottom-info\">\n    <p class=\"l-footer-bottom-info__copyright\">Copyright 2012-2026 DATAPLUS Corp. All Rights Reserved.</p>\n    <span class=\"l-footer-bottom-info__examination\">[審2019-6]</span>\n  </div>\n</footer>\n\n    </div>\n\n    <script src=\"https://ajax.googleapis.com/ajax/libs/jquery/3.3.1/jquery.min.js\"></script>\n<script src=\"/common/js/common.js\"></script>\n    <script src=\"https://yubinbango.github.io/yubinbango/yubinbango.js\"></script>\n  </body>\n\n</html>\n","finalUrl":"https://www.data-p.co.jp/contact/","rendered":false,"_cachedAt":"2026-06-23T22:15:31.786Z"}