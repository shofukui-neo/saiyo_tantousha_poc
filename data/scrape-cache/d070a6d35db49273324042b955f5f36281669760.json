rce srcset=\"/takaki/images/logo-blue.svg\" media=\"(max-width: 736px)\" />\r\n            <img src=\"../images/logo.svg\" alt=\"たかきデザインオフィス\" />\r\n          </picture>\r\n        </a>\r\n      </div>\r\n      <input type=\"checkbox\" id=\"menu-btn-check\" />\r\n      <label for=\"menu-btn-check\" class=\"menu-btn\"><span></span></label>\r\n      <div class=\"gnav\">\r\n        <ul>\r\n          <li><a href=\"../service/index.html\">サービス</a></li>\r\n          <li><a href=\"../case/index.html\">事例紹介</a></li>\r\n          <li><a href=\"../aboutUs/index.html\">たかきについて</a></li>\r\n          <li><a href=\"../column/index.html\">コラム</a></li>\r\n          <li>\r\n            <a href=\"../estimates/index.html\" target=\"_blank\" rel=\"noopener noreferrer\">見積りシミュレーション</a>\r\n          </li>\r\n          <li><a href=\"../download/index.html\">資料ダウンロード</a></li>\r\n        </ul>\r\n        <!--gnav -->\r\n      </div>\r\n      <!--global-heaer -->\r\n    </div>\r\n    <div class=\"stage\">\r\n      <div class=\"h1-area contact-top\">\r\n        <h1>お問い合わせ</h1>\r\n        <!--h1-area -->\r\n      </div>\r\n      <div class=\"breadcrumbs\">\r\n        <div class=\"global-inner\">\r\n          <ul>\r\n            <li><a href=\"../index.html\">ホーム</a></li>\r\n            <li>お問い合わせ</li>\r\n          </ul>\r\n          <!--global-inner -->\r\n        </div>\r\n        <!--breadcrumbs -->\r\n      </div>\r\n      <div class=\"contact\">\r\n        <section>\r\n          <div class=\"global-inner border-2tone\">\r\n            <h2>メールフォームでのお問い合わせ</h2>\r\n            <p class=\"mb-30 mb-30-sp\">\r\n              些細なご相談から、お見積り依頼や具体的な発注依頼まで、お気軽にお問い合わせください。\r\n            </p>\r\n            <div class=\"flex-box flex-between block-sp\">\r\n              <div class=\"col-2 mb-30-sp\">\r\n                <div class=\"button\">\r\n                  <a href=\"https://sem-inq.fsi.co.jp/public/application/add/508\" target=\"_blank\" class=\"red\"><span>お問い合わせ</span>\r\n                    <div class=\"mail\"></div>\r\n                  </a>\r\n                </div>\r\n              </div>\r\n              <div class=\"col-2\">\r\n                <ul class=\"notice\">\r\n                  <li class=\"gray\">\r\n                    富士ソフトのお問い合わせフォームが開きますので、フォームに必要事項を入力し、送信をお願いたします。\r\n                  </li>\r\n                  <li class=\"gray\">\r\n                    ※2営業日以内に担当者よりご連絡いたします<br />\r\n                    （年末年始やお盆期間等はお時間をいただく場合がございます）。\r\n                  </li>\r\n                </ul>\r\n              </div>\r\n              <!--flex-box  -->\r\n            </div>\r\n            <!--global-inner -->\r\n          </div>\r\n        </section>\r\n        <section>\r\n          <div class=\"global-inner border-2tone\">\r\n            <h2>お電話でのお問い合わせ</h2>\r\n            <div class=\"flex-box flex-between block-sp\">\r\n              <div class=\"col-2 tel-box\">\r\n                <div class=\"tel-number\">\r\n                  <a href=\"tel:050-3000-2775\"><img src=\"../images/txt-TEL.svg\" class=\"t-tel\" /></a>\r\n                </div>\r\n                <div class=\"business-hour\">9：00〜17：30（土日祝日を除く）</div>\r\n              </div>\r\n              <div class=\"col-2\">\r\n                <ul class=\"notice\">\r\n                  <li class=\"gray\">\r\n                    電話番号をお確かめのうえ、お間違えのないようお願いいたします。\r\n                  </li>\r\n                  <li class=\"gray\">\r\n                    時間帯によって、回線が込み合い、お電話がつながらない場合がございます。<br />\r\n                    つながらない場合は、しばらくお待ちいただいた後におかけ直しいただきますようお願いいたします。\r\n                  </li>\r\n                </ul>\r\n                <!--col-2  -->\r\n              </div>\r\n              <!--flex-box  -->\r\n            </div>\r\n            <!--global-inner -->\r\n          </div>\r\n        </section>\r\n        <section>\r\n          <div class=\"global-inner border-2tone\">\r\n            <h2>よくあるご質問</h2>\r\n            <p class=\"mb-60\">\r\n              お問い合わせいただく前に、よくあるご質問をご確認いただければ、お客様のお問い合わせ内容に対する解決策が見つかるかもしれません。ぜひご活用ください。\r\n            </p>\r\n            <div id=\"accordion\" class=\"accordion-container\">\r\n              <h3 class=\"accordion-title js-accordion-title\">\r\n                システム開発、UIデザインまで一貫して依頼できますか？\r\n              </h3>\r\n              <div class=\"accordion-content\">\r\n                <p>はい、対応可能です。</p>\r\n                <p>\r\n                  富士ソフトの技術部門と連携してトータルでご提案させていただきます。<br />\r\n                  もちろんそれぞれ単体でのご相談も承っております。\r\n                </p>\r\n                <!--accordion-content -->\r\n              </div>\r\n              <h3 class=\"accordion-title js-accordion-title\">\r\n                HCD(人間中心設計)とは何ですか？\r\n              </h3>\r\n              <div class=\"accordion-content\">\r\n                <p>\r\n                  利用者目線の「使いやすく満足度の高い」設計を考える仕組みです。\r\n                </p>\r\n                <p>\r\n                  たかきデザインオフィスではHCDの考え方をベースにサービスをご提供しています。<br />\r\n                  <a href=\"../aboutUs/index.html\">詳しくはこちら</a>をご覧ください。\r\n                </p>\r\n                <!--accordion-content -->\r\n              </div>\r\n              <h3 class=\"accordion-title js-accordion-title\">\r\n                費用はどのくらいですか？\r\n              </h3>\r\n              <div class=\"accordion-content\">\r\n                <p>\r\n                  概算のシミュレーションを<a href=\"../estimates/index.html\" target=\"_blank\">こちら</a>から試算いただけます。\r\n                </p>\r\n                <p>\r\n                  より詳細なお見積は<a href=\"https://sem-inq.fsi.co.jp/public/application/add/78\" target=\"_blank\">こちら</a>よりお問合せください。\r\n                </p>\r\n                <!--accordion-content -->\r\n              </div>\r\n              <h3 class=\"accordion-title js-accordion-title\">\r\n                どんな業界の実績が多いですか？\r\n              </h3>\r\n              <div class=\"accordion-content\">\r\n                <p>\r\n                  メーカー、情報サービス、金融、医療、官公庁など幅広く実績がございます。\r\n                </p>\r\n                <p>\r\n                  <a href=\"../case/index.html\">こちら</a>で実績の一部をご紹介しております。\r\n                </p>\r\n                <!--accordion-content -->\r\n              </div>\r\n              <h3 class=\"accordion-title js-accordion-title\">\r\n                まだ案件内容が具体的に固まっていない段階でも相談できますか？\r\n              </h3>\r\n              <div class=\"accordion-content\">\r\n                <p>はい、まだ構想段階でもぜひお気軽にご相談ください。</p>\r\n                <p>\r\n                  状況をお伺いして、弊社でどのようなご支援ができるのかご提案させていただきます。\r\n                </p>\r\n                <!--accordion-content -->\r\n              </div>\r\n              <h3 class=\"accordion-title js-accordion-title\">\r\n                開発部門のためデザインの知識がなく、依頼したい内容をどう伝えていいかわかりません。\r\n              </h3>\r\n              <div class=\"accordion-content\">\r\n                <p>問題ございません。</p>\r\n                <p>\r\n                  まずお気軽にご相談いただければ、弊社で情報を整理からご一緒に考えさせていただきます。\r\n                </p>\r\n                <!--accordion-content -->\r\n              </div>\r\n              <!--\r\n<h3 class=\"accordion-title js-accordion-title\">ドキュメント制作ツール(WikiWorks)を試してみることはできますか？</h3>\r\n<div class=\"accordion-content\">\r\n<p>はい、無料でお試しいただけます。</p>\r\n<p><a href=\"https://sem-inq.fsi.co.jp/public/application/add/508\" target=\"_blank\">こちら</a>までお問合せください。</p>\r\n-->\r\n              <!--accordion-content</div>\r\n -->\r\n              <h3 class=\"accordion-title js-accordion-title\">\r\n                成果物の著作権はどうなりますか？\r\n              </h3>\r\n              <div class=\"accordion-content\">\r\n                <p>基本的に著作権の所有はお客様側となります。</p>\r\n                <!--accordion-content -->\r\n              </div>\r\n              <!--/#accordion-->\r\n            </div>\r\n            <!--global-inner -->\r\n          </div>\r\n        </section>\r\n        <!--contact -->\r\n      </div>\r\n      <div class=\"banner-contact\">\r\n        <div class=\"global-inner\">\r\n          <div class=\"box\">\r\n            <p class=\"lead-wikiworks\">\r\n              WikiWorksを無料でも<br class=\"sp\" />\r\n              お試しいただけます。<br />\r\n              ぜひお気軽にお問い合わせください。\r\n            </p>\r\n            <p class=\"lead\">\r\n              UI／UXデザインの<br class=\"sp\" />\r\n              ご相談・ご質問・お見積依頼などは<br class=\"sp\" />\r\n              お気軽にお問い合わせください。\r\n            </p>\r\n            <div class=\"flex-box flex-between-center block-sp\">\r\n              <div class=\"col-2\">\r\n                <div class=\"tel-number\">\r\n                  <a href=\"tel:050-3000-2775\"><img src=\"../images/txt-TEL.svg\" class=\"t-tel\" /></a>\r\n                </div>\r\n                <div class=\"business-hour\">9：00～17：30（土日祝日を除く）</div>\r\n              </div>\r\n              <div class=\"col-2\">\r\n                <div class=\"button\">\r\n                  <a href=\"index.html\" class=\"red\"><span>お問い合わせ</span>\r\n                    <div class=\"mail\"></div>\r\n                  </a>\r\n                </div>\r\n              </div>\r\n              <!--flex-box -->\r\n            </div>\r\n            <!--box -->\r\n          </div>\r\n          <!--global-inner-->\r\n        </div>\r\n        <!--banner-contact -->\r\n      </div>\r\n      <div class=\"footer-banner-wrapper\">\r\n        <div class=\"global-inner\">\r\n          <div class=\"footer-banner\">\r\n            <div class=\"item\">\r\n              <p>\r\n                提供サービスのご紹介、導入事例など詳細情報を<br class=\"pc\" />\r\n                掲載した資料をご用意しています。\r\n              </p>\r\n              <div class=\"button\">\r\n                <a href=\"../download/index.html\" class=\"blue\"><span>資料のダウンロード</span>\r\n                  <div class=\"toright\"></div>\r\n                </a>\r\n              </div>\r\n              <!--item -->\r\n            </div>\r\n            <div class=\"item\">\r\n              <p>\r\n                その場で簡単にお見積りをシミュレーションできます。<br class=\"pc\" />\r\n                ぜひご参考価格としてご検討ください。\r\n              </p>\r\n              <div class=\"button\">\r\n                <a href=\"../estimates/index.html\" target=\"_blank\" class=\"blue\"><span>見積りシミュレーション</span>\r\n                  <div class=\"toright\"></div>\r\n                </a>\r\n              </div>\r\n              <!--item -->\r\n            </div>\r\n            <!--footer-banner -->\r\n          </div>\r\n          <!--global-inner -->\r\n        </div>\r\n        <!--footer-banner-wrapper -->\r\n      </div>\r\n      <!--stage -->\r\n    </div>\r\n    <div class=\"footer\">\r\n      <div class=\"inner\">\r\n        <div class=\"flex-box block-sp\">\r\n          <div class=\"footer-logo\">\r\n            <a href=\"../index.html\"><img src=\"../images/logo.svg\" alt=\"\" /></a>\r\n          </div>\r\n          <div class=\"navi\">\r\n            <ul>\r\n              <li><a href=\"../service/index.html\">サービス</a></li>\r\n              <li><a href=\"../aboutUs/index.html\">たかきについて</a></li>\r\n              <li><a href=\"../download/index.html\">資料ダウンロード</a></li>\r\n              <li><a href=\"../case/index.html\">事例紹介</a></li>\r\n              <li><a href=\"../column/index.html\">コラム</a></li>\r\n              <li>\r\n                <a href=\"../estimates/index.html\" target=\"_blank\" rel=\"noopener noreferrer\">見積りシミュレーション</a>\r\n              </li>\r\n              <li><a href=\"index.html\">お問い合わせ</a></li>\r\n            </ul>\r\n          </div>\r\n          <!--flex-box -->\r\n        </div>\r\n        <div class=\"flex-box block-sp\">\r\n          <div class=\"footer-logo\">\r\n            <a href=\"/\" target=\"_blank\"><img src=\"../images/logo_fujisoft-white.png\" alt=\"\" /></a>\r\n          </div>\r\n          <div class=\"navi2\">\r\n            <ul>\r\n              <li>\r\n                <a href=\"/csr/security/\" target=\"_blank\" rel=\"noopener noreferrer\">情報セキュリティ基本方針</a>\r\n              </li>\r\n              <li>\r\n                <a href=\"/csr/privacy/\" target=\"_blank\" rel=\"noopener noreferrer\">個人情報保護方針</a>\r\n              </li>\r\n              <li>\r\n                <a href=\"/csr/privacy/my_number.html\" target=\"_blank\" rel=\"noopener noreferrer\">特定個人情報等取り扱い基本方針</a>\r\n              </li>\r\n              <li>\r\n                <a href=\"/company/guide/\" target=\"_blank\" rel=\"noopener noreferrer\">サイトのご利用について　</a>\r\n              </li>\r\n              <li>\r\n                <a href=\"/company/guide/index_sm.html\" target=\"_blank\" rel=\"noopener noreferrer\">ソーシャルメディアガイドライン</a>\r\n              </li>\r\n            </ul>\r\n          </div>\r\n          <!--flex-box -->\r\n        </div>\r\n        <!--inner -->\r\n      </div>\r\n      <!--footer -->\r\n    </div>\r\n    <div class=\"copyright\">\r\n      <div class=\"global-inner\">\r\n        <p>&copy; FUJISOFT INCORPORATED and TAKAKI Design Office</p>\r\n        <!--global-inner -->\r\n      </div>\r\n      <!--copyright -->\r\n    </div>\r\n    <div id=\"page_top\"><a href=\"index.html#\">TO TOP</a></div>\r\n    <script src=\"https://ajax.googleapis.com/ajax/libs/jquery/3.2.1/jquery.min.js\"></script>\r\n    <script>\r\n      $(function () {\r\n        // 画像を含む外部リンクのアイコンを削除\r\n        $(\"a:has(img)\").addClass(\"remove-icon\");\r\n      });\r\n    </script>\r\n    <script>\r\n      $(function () {\r\n        var pagetop = $(\"#page_top\");\r\n        // ボタン非表示\r\n        pagetop.hide();\r\n\r\n        // 100px スクロールしたらボタン表示\r\n        $(window).scroll(function () {\r\n          if ($(this).scrollTop() > 100) {\r\n            pagetop.fadeIn();\r\n          } else {\r\n            pagetop.fadeOut();\r\n          }\r\n        });\r\n        pagetop.click(function () {\r\n          $(\"body, html\").animate({ scrollTop: 0 }, 200);\r\n          return false;\r\n        });\r\n      });\r\n    </script>\r\n    <!--アコーディオン -->\r\n    <script>\r\n      jQuery(function ($) {\r\n        $(\".js-accordion-title\").on(\"click\", function () {\r\n          /*クリックでコンテンツを開閉*/\r\n          $(this).next().slideToggle(100);\r\n          /*矢印の向きを変更*/\r\n          $(this).toggleClass(\"open\", 100);\r\n        });\r\n      });\r\n    </script>\r\n    <!--IEでの　object-fit -->\r\n    <script src=\"https://cdnjs.cloudflare.com/ajax/libs/object-fit-images/3.2.4/ofi.min.js\"></script>\r\n    <script>\r\n      objectFitImages();\r\n      // jQuery\r\n      $(function () {\r\n        objectFitImages();\r\n      });\r\n    </script>\r\n    <!--IEでのpicure　タグ -->\r\n    <script src=\"https://cdnjs.cloudflare.com/ajax/libs/picturefill/3.0.2/picturefill.js\"></script>\r\n    <!--タブレット、PCでviewport無効 -->\r\n    <script>\r\n      if (\r\n        navigator.userAgent.indexOf(\"iPhone\") > 0 ||\r\n        navigator.userAgent.indexOf(\"iPod\") > 0 ||\r\n        navigator.userAgent.indexOf(\"Android\") > 0\r\n      ) {\r\n        //iPhone、iPod、Androidの設定\r\n        document.write(\r\n          '<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">',\r\n        );\r\n      } else {\r\n        //それ以外（PC、iPadなど）の設定\r\n        document.write(\"\");\r\n      }\r\n    </script>\r\n    <!--グローバルメニュー　ヘッダー固定（スマホ） -->\r\n    <script>\r\n      if (window.matchMedia(\"(max-width: 736px)\").matches) {\r\n        jQuery(window).on(\"scroll\", function () {\r\n          if (60 < jQuery(this).scrollTop()) {\r\n            // 1000px以上スクロールしたら\r\n            jQuery(\".global-header\").addClass(\"fixed\");\r\n          } else {\r\n            jQuery(\".global-header\").removeClass(\"fixed\");\r\n          }\r\n        });\r\n      }\r\n    </script>\r\n    <!--キービジュアル途中消す -->\r\n    <script>\r\n      $(window).scroll(function () {\r\n        if ($(window).scrollTop() > 2000) {\r\n          $(\".kv\").addClass(\"display-none\");\r\n        } else {\r\n          $(\".kv\").removeClass(\"display-none\");\r\n        }\r\n      });\r\n    </script>\r\n    <!--header fixed アンカー処理 -->\r\n    <script>\r\n      $(function () {\r\n        var headerHeight = $(\".global-header\").outerHeight();\r\n        var urlHash = location.hash;\r\n        if (urlHash) {\r\n          $(\"body,html\").stop().scrollTop(0);\r\n          setTimeout(function () {\r\n            var target = $(urlHash);\r\n            var position = target.offset().top - headerHeight;\r\n            $(\"body,html\").stop().animate({ scrollTop: position }, 500);\r\n          }, 100);\r\n        }\r\n        $('a[href^=\"#\"]').click(function () {\r\n          var href = $(this).attr(\"href\");\r\n          var target = $(href);\r\n          var position = target.offset().top - headerHeight;\r\n          $(\"body,html\").stop().animate({ scrollTop: position }, 500);\r\n          return false;\r\n        });\r\n      });\r\n    </script>\r\n    <!-- TOPのみ KV -->\r\n    <script>\r\n      $(function () {\r\n        var $mainTop = $(\".main-top\");\r\n\r\n        if (!$mainTop.length) return;\r\n\r\n        // 中面の先頭のセクションに青矢印を挿入する\r\n        $mainTop\r\n          .children()\r\n          .eq(0)\r\n          .prepend(\r\n            '<div class=\"kv-scroll-area-next\"><div class=\"kv-scroll-area-inner\"><img src=\"/takaki/images/arrow_in_kvnext.svg\" alt=\"\" class=\"kv-scroll-next\"></div></div>',\r\n          );\r\n\r\n        $(\".kv-scroll-area-next\").ready(function () {\r\n          // KVと中面とで、positionの指定によって幅100%の解釈が異なる（スクロールバーの幅の有無）ため、揃える\r\n          $(window)\r\n            .on(\"resize\", function () {\r\n              var windowWidth = window.innerWidth;\r\n              $(\".kv-scroll-area, .kv-scroll-area-next\").width(windowWidth);\r\n            })\r\n            .trigger(\"resize\");\r\n\r\n          // スクロールに追従する要素は、コンテンツ幅以下になったときに見切れてしまうので、画面の横スクロールに合わせて移動させる\r\n          $(window).on(\"scroll\", function () {\r\n            var posTop = $(window).scrollTop();\r\n            var posLeft = $(window).scrollLeft();\r\n\r\n            $(\".kv-inner\").css(\"transform\", \"translateX(-\" + posLeft + \"px)\");\r\n\r\n            if (posTop > 20) {\r\n              $(\".kv-scroll-area\").addClass(\"is-scroll\");\r\n            } else {\r\n              $(\".kv-scroll-area\").removeClass(\"is-scroll\");\r\n            }\r\n          });\r\n        });\r\n      });\r\n    </script>\r\n    <!-- 追従ヘッダー 横スクロール -->\r\n    <script>\r\n      // スクロールに追従する要素は、コンテンツ幅以下になったときに見切れてしまうので、画面の横スクロールに合わせて移動させる\r\n      $(function () {\r\n        $(window).on(\"scroll\", function () {\r\n          var posLeft = $(window).scrollLeft();\r\n          $(\".header, .global-header\").css(\r\n            \"transform\",\r\n            \"translateX(-\" + posLeft + \"px)\",\r\n          );\r\n        });\r\n      });\r\n    </script>\r\n  \r\n</body>\r\n</html>\r\n\r\n\r\n","finalUrl":"https://www.fsi.co.jp/takaki/contact/index.html","rendered":false,"_cachedAt":"2026-06-22T22:52:31.974Z"}