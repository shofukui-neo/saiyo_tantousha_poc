\"wp-block-paragraph\"></p>\n    </div>\n\n    <div class=\"post__pager\">\n                <a href=\"https://zynas.co.jp/post/1074\" rel=\"prev\"><span class=\"pager--prev\" aria-label=\"前の記事へ\"></span></a>        \n        <a class=\"post__link--archive\" href=\"https://zynas.co.jp/news\">記事一覧に戻る</a>\n\n                <a href=\"https://zynas.co.jp/post/1086\" rel=\"next\"><span class=\"pager--next\" aria-label=\"次の記事へ\"></span></a>            </div>\n\n    </section>\n\n\n<!--------------- Template Recruit --------------->\n<section id=\"templateRecruit\" class=\"cm-inner\">\n    <div class=\"recruit__container\">\n        <img class=\"recruit__img lazyload\" src=\"data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAfEAAAFYAQAAAABrWvj2AAAAAnRSTlMAAHaTzTgAAAAsSURBVHja7cExAQAAAMKg9U9tCj+gAAAAAAAAAAAAAAAAAAAAAAAAAAAAeBhWAAABDPbmAgAAAABJRU5ErkJggg==\" alt=\"\" loading=\"lazy\" data-src=\"https://zynas.co.jp/wp-content/themes/zynas/img/cm/img-cm-recruit-block.png\" decoding=\"async\" data-eio-rwidth=\"497\" data-eio-rheight=\"344\"><noscript><img class=\"recruit__img\" src=\"https://zynas.co.jp/wp-content/themes/zynas/img/cm/img-cm-recruit-block.png\" alt=\"\" loading=\"lazy\" data-eio=\"l\"></noscript>\n        <div class=\"recruit__content\">\n            <h2 class=\"recruit__head\">採用情報</h2>\n            <p class=\"recruit__text\">より良い明日へ、ともにシステム作りをするメンバーを募集しています。</p>\n            <a class=\"recruit__permalink\" href=\"https://recruit.zynas.co.jp\" target=\"_blank\" rel=\"noopener noreferrer\">詳しく見る</a>\n        </div>\n    </div>\n</section><!--------------- / Template Recruit --------------->\n\n\n<!--------------- Template Breadcrumbs --------------->\n<div id=\"templateBreadcrumbs\" class=\"cm-inner\">\n    <div class=\"breadcrumbs__container\">\n        <ol class=\"breadcrumbs__list\">\n            <li class=\"breadcrumbs__item\"><a class=\"breadcrumbs__permalink\" href=\"https://zynas.co.jp\">ホーム</a></li>\n            <li class=\"breadcrumbs__item\">\n            