{"url":"https://www.neco-net.co.jp/recruit/index.html","html":"<!doctype html>\n<html lang=\"ja\">\n<head>\n<title>採用情報｜原子力エンジニアリング株式会社</title>\n<meta name=\"description\" content=\"原子力関連施設において、試験研究炉、核燃料取扱施設、核融合装置など、施設の運転保守管理業務、それら施設に設置される、さまざまな実験・試験装置を使用した研究開発の支援業務や廃棄物管理業務などを通じて、原子力の研究開発の土台を支える業務を行っています。\">\n<meta name=\"keywords\" content=\"原子力,エネルギー,環境,研究,開発,原子力発電所,エネルギー環境,実験,試験,放射性,廃棄物,点検,検査,原子力エンジニアリング\">\n\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<meta name=\"format-detection\" content=\"telephone=no\">\n\n<meta property=\"og:type\" content=\"article\">\n<meta property=\"og:title\" content=\"採用情報｜原子力エンジニアリング株式会社\">\n<meta property=\"og:description\" content=\"原子力関連施設において、試験研究炉、核燃料取扱施設、核融合装置など、施設の運転保守管理業務、それら施設に設置される、さまざまな実験・試験装置を使用した研究開発の支援業務や廃棄物管理業務などを通じて、原子力の研究開発の土台を支える業務を行っています。\">\n<meta property=\"og:site_name\" content=\"原子力エンジニアリング株式会社\">\n<meta property=\"og:url\" content=\"https://www.neco-net.co.jp/recruit/\">\n<meta property=\"og:image\" content=\"https://www.neco-net.co.jp/ogp.jpg\">\n<link rel=\"stylesheet\" href=\"../css/import.css\">\n<link rel=\"icon\" type=\"image/svg+xml\" href=\"../favicon.svg\" />\n<link rel=\"icon\" type=\"image/vnd.microsoft.icon\" href=\"../favicon.png\" />\n<link rel=\"apple-touch-icon\" href=\"../apple-touch-icon.png\">\n\n<script src=\"../js/jquery-1.7.2.min.js\" type=\"text/javascript\"></script>\n<script src=\"../js/viewport.js\" type=\"text/javascript\"></script>\n<script src=\"../js/hover.js\" type=\"text/javascript\"></script>\n<script src=\"../js/menu.js\" type=\"text/javascript\"></script>\n<script src=\"../js/inview.js\" type=\"text/javascript\"></script>\n<script src=\"../js/inview_op.js\" type=\"text/javascript\"></script>\n<script src=\"../js/smaller.js\" type=\"text/javascript\"></script>\n<script src=\"../js/scroll.js\" type=\"text/javascript\"></script>\n<script src=\"../js/ScrollTrigger.min.js\" type=\"text/javascript\"></script>\n<script src=\"../js/jquery.easing.1.3.js\" type=\"text/javascript\"></script>\n\n<!-- Googleアナリティクス開始【原子力エンジニアリング株式会社】 -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-CW27MV4TRW\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'G-CW27MV4TRW');\n</script>\n<!-- Googleアナリティクス終了【原子力エンジニアリング株式会社】 -->\n</head>\n\n<body id=\"recruit\">\n<header>\n<div id=\"menu\">\n<div class=\"header_nav\">\n    <div class=\"flex\">\n        <a href=\"../index.html\" class=\"logo\"><img src=\"../images/logo.svg\" alt=\"原子力エンジニアリング株式会社\" width=\"379\" height=\"48\"></a>\n        <a href=\"../index.html\" class=\"logo_short\"><img src=\"../images/logo_short.svg\" alt=\"原子力エンジニアリング株式会社\" width=\"266\" height=\"48\"></a>\n        <a href=\"../index.html\" class=\"logo_icon\"><img src=\"../images/logo_icon.svg\" alt=\"原子力エンジニアリング株式会社\" width=\"60\" height=\"48\"></a>\n        <div>\n            <nav class=\"global_nav\">\n                <ul>\n                    <li><a href=\"../about/index.html\">NECOについて</a></li>\n                    <li><a href=\"../works/index.html\">私たちの仕事</a></li>\n                    <li><a href=\"../people/index.html\">NECOの仲間</a></li>\n                    <li><a href=\"../career_formation/index.html\">キャリア形成</a></li>\n                    <li><a href=\"../benefit/index.html\">環境と制度</a></li>\n                    <li class=\"act\"><a href=\"index.html\">採用情報</a></li>\n                    <li class=\"contact\"><a href=\"../contact/index.html\"><span>お問い合わせ</span></a></li>\n                </ul>\n            </nav>\n            <!-- /global_nav -->\n        </div>\n    </div>\n    <!-- /flex -->\n</div>\n<!-- /header_nav -->\n</div>\n<!-- /menu -->\n\t\n<nav class=\"floating_contact\">\n<ul class=\"flex\">\n<li><a href=\"../recruit/index.html#entry\">採用エントリー</a></li>\n<li><a href=\"../recruit/index.html#requirements\">募集要項</a></li>\n</ul>\n</nav>\n<!-- /floating_contact -->\n\n<div class=\"global_nav_sp\">\n<div class=\"menu\">\n    <a href=\"../index.html\" class=\"logo_sp\"><img src=\"../images/logo.svg\" alt=\"原子力エンジニアリング株式会社\"></a>\n    <div class=\"toggle\">\n        <div class=\"bar top\"></div>\n        <div class=\"bar middle\"></div>\n        <div class=\"bar bottom\"></div>\n    </div>\n    <!-- /toggle -->\n    <nav class=\"menu_sp\">\n        <ul>\n            <li><a href=\"../about/index.html\">NECOについて</a></li>\n            <li><a href=\"../works/index.html\">私たちの仕事</a></li>\n            <li><a href=\"../people/index.html\">NECOの仲間</a></li>\n            <li><a href=\"../career_formation/index.html\">キャリア形成</a></li>\n            <li><a href=\"../benefit/index.html\">環境と制度</a></li>\n            <li><a href=\"index.html\">採用情報</a></li>\n            <li class=\"contact\"><a href=\"../contact/index.html\">お問い合わせ</a></li>\n        </ul>\n    </nav>\n</div>\n<!-- /menu -->\n</div>\n<!-- /global_nav_sp -->\n</header>\n\n\n<div class=\"mainvisual\">\n<div class=\"inner\">\n<ul>\n    <li>\n        <picture>\n        <img src=\"../images/entry_title/bg_title_recruit.jpg\" alt=\"\" width=\"1680\" height=\"750\">\n        </picture>\n    </li>\n</ul>\n</div>\n<!-- /inner -->\n<div class=\"wrap\">\n    <h1><a href=\"index.html\"><span>採用情報</span>RECRUIT</a></h1>\n    <img src=\"../images/entry_title/deco/recruit.png\" alt=\"\" width=\"260\" height=\"186\">\n</div>\n<nav class=\"bread clearfix\">\n<ol>\n    <li><a href=\"../index.html\">HOME</a></li>\n\t<li>採用情報</li>\n</ol>\n</nav>\n<!-- /bread -->\n</div>\n<!-- /mainvisual -->\n\n\n<main>\n<h1><span>原子力研究の最先端を支援し、<br class=\"sp\">一緒に夢を持って働こう！</span></h1>\n\n<section class=\"intro_box\">\n<div class=\"inner\">\n<a id=\"entry\" class=\"anchor\"></a>\n<h2>採用エントリー</h2>\n<div class=\"area01\">\n<div class=\"inner\">\n<h4>メールでの採用エントリー</h4>\n<p>新卒採用、キャリア採用どちらも受け付けております。下記のエントリーフォームよりご応募ください。</p>\n<div class=\"btn02\"><a href=\"https://forms.gle/7sPWYET6j62tBbH57\" target=\"_blank\">エントリーフォームから応募する</a></div>\n</div>\n</div>\n\n<a id=\"mynavi\" class=\"anchor\"></a>\n<div class=\"area01\">\n<div class=\"inner\">\n<h4>新卒の方へ</h4>\n<p>マイナビからもエントリーを受け付けております。</p>\n<div class=\"mynavi_area\">\n<ul class=\"row2\">\n\n\n<li><a href=\"https://job.mynavi.jp/26/pc/search/corp205752/outline.html\" target=\"_blank\"><img src=\"https://job.mynavi.jp/conts/kigyo/2026/logo/banner_entry_160_45.gif\" alt=\"\"></a></li>\n<!-- Begin mynavi Navi Link -->\n\n<a href=\"https://job.mynavi.jp/27/pc/search/corp205752/outline.html\" target=\"_blank\">\n<img src=\"https://job.mynavi.jp/conts/kigyo/2027/logo/banner_entry_160_45.gif\" alt=\"マイナビ2027\" border=\"0\">\n</a>\n\n<!-- End mynavi Navi Link -->\n</ul>\n</div>\n</div>\n</div>\n\t\n<a id=\"requirements\" class=\"anchor\"></a>\n<h2>募集要項</h2>\n<div class=\"index_menu mb_high\">\n<div class=\"full_wrap\">\n<a href=\"graduate/index.html\">\n<div class=\"wrap clearfix\">\n<img src=\"images/image01.jpg\" alt=\"\" width=\"500\" height=\"320\">\n<div class=\"text_wrap\">\n<h3>新卒採用</h3>\n<p>職務に対する高い意識を持った人材を求めています。</p>\n<div class=\"btn\">\n<p>くわしく見る</p>\n</div>\n</div>\n</div>\n<!-- /wrap -->\n</a>\n</div>\n<!-- /full_wrap -->\n\t\n<div class=\"full_wrap\">\n<a href=\"career/index.html\">\n<div class=\"wrap clearfix\">\n<img src=\"images/image02.jpg\" alt=\"\" width=\"450\" height=\"300\">\n<div class=\"text_wrap\">\n<h3>キャリア採用</h3>\n<p>積み上げてきた経験、知識、技術を弊社で活かしてみませんか。</p>\n<div class=\"btn\">\n<p>くわしく見る</p>\n</div>\n</div>\n</div>\n<!-- /wrap -->\n</a>\n</div>\n<!-- /full_wrap -->\n</div>\n<!-- /index_menu -->\n\t\n<a id=\"message\" class=\"anchor\"></a>\n<h2>採用メッセージ</h2>\n<h3>同じチームの一員として、原子力と共に未来の夢をかなえよう</h3>\n<div class=\"wrap flex mb_normal\">\n    <div class=\"image_wrap\">\n        <img src=\"images/message01_hagiya.jpg\" alt=\"\" width=\"600\" height=\"450\">\n        <p class=\"ab_name\">代表取締役社長　萩谷 弘通</p>\n    </div>\n    <div class=\"text_wrap\">\n\t\t<p class=\"catch\">ほしい人材は、仕事に対して前向きに取り組んでくれる方</p>\n        <p>「原子力エンジニアリング」という社名のせいか、「理系でないと就職できない」と思われれる方が多いのですが、実はそんなことはありません。実際、弊社にはたくさんの文系出身の技術者がいます。商業や経済といった学科・学部を卒業した社員が、現場で活躍して、技術系国家資格にも合格しているのです。</p>\n\t\t<p>業務に必要な知識・技能は入社してから学ぶことができます。必要なのは、仕事に対して、技術の継承に対しての前向きさだけです。</p>\n    </div>\n</div>\n\t\n<div class=\"wrap flex_reverse mb_normal\">\n    <div class=\"image_wrap\">\n        <img src=\"images/message02.jpg\" alt=\"\" width=\"600\" height=\"450\">\n    </div>\n    <div class=\"text_wrap\">\n\t\t<p class=\"catch\">会社全体でキャリアアップをサポート</p>\n        <p>もちろん、私たちの業務は非常に専門性が高いものです。顧客である原子力研究開発機構、量子科学研究機構から求められる技術力・力量も年々高度化しています。学ぶことはたくさんあるのですが、心配しないでください。私たちは充実した研修制度や現場OJTで人材育成に取り組んでいます。</p>\n\t\t<p>必要な資格についても受験料・交通費を全額支給。すでに資格を取得した先輩が講師を務める勉強会・講座もあり、会社全体であなたのキャリアアップをサポートします。</p>\n    </div>\n</div>\n\t\n<div class=\"wrap flex mb_normal\">\n    <div class=\"image_wrap\">\n        <img src=\"images/message03.jpg\" alt=\"\" width=\"600\" height=\"450\">\n    </div>\n    <div class=\"text_wrap\">\n\t\t<p class=\"catch\">技術だけでなく「安全文化」の継承も</p>\n\t\t<p>原子力施設の運転・管理については、たくさんの決められたルールがあります。決められたルールをしっかり遵守することが安全な維持・管理を可能とし、品質向上・顧客満足のみならず地域・社会への貢献にもつながっていきます。技術だけでなく、創業以来、先輩たちが培ってきた「安全文化」も継承していってほしいと願っています。</p>\n\t\t<p>また、私たちの業務はとても独りでできることではありません。グループでの業務ですからチームワークとコミュニケーションが重要。チームの一員として仕事に対して前向きに取り組んでくれる方、ぜひご応募ください。</p>\n    </div>\n</div>\n</div>\n<!-- /inner -->\n</section>\n<!-- /adjust_group -->\n\n<section class=\"policy_area adjust_s\">\n<div class=\"inner\">\n<div class=\"mission_box\">\n<h3>ミッション/ビジョン<span class=\"en\">Mission / Vision</span></h3>\n<p class=\"txtC yu_min mb_row\"><span class=\"bld_L\">原子力と共に未来の夢をかなえよう</span>Make your dreams come true</p>\n<ol>\n\t<li>\n        <img src=\"images/mission_num01.svg\" alt=\"\" width=\"53\" height=\"53\" class=\"num\">\n        <div class=\"image_wrap\">\n            <img src=\"images/mission01.png\" alt=\"\" width=\"144\" height=\"160\">\n        </div>\n        <div class=\"text_wrap\">\n            <h4>会社の“夢”</h4>\n            <p>社員数1000人を目指し、成長し続ける100年企業へ</p>\n        </div>\n    </li>\n\t<li>\n        <img src=\"images/mission_num02.svg\" alt=\"\" width=\"53\" height=\"53\" class=\"num\">\n        <div class=\"image_wrap\">\n            <img src=\"images/mission02.png\" alt=\"\" width=\"133\" height=\"154\">\n        </div>\n        <div class=\"text_wrap\">\n            <h4>仕事の“夢”</h4>\n            <p>原子力研究の最先端を支援し、誇りとやりがいを持ち、プロジェクト達成を目指す</p>\n        </div>\n    </li>\n\t<li>\n        <img src=\"images/mission_num03.svg\" alt=\"\" width=\"53\" height=\"53\" class=\"num\">\n        <div class=\"image_wrap\">\n            <img src=\"images/mission03.png\" alt=\"\" width=\"154\" height=\"137\">\n        </div>\n        <div class=\"text_wrap\">\n            <h4>働く社員の“夢”</h4>\n            <p>安定企業で働き、自身の描いたライフプランや将来の夢を実現する</p>\n        </div>\n    </li>\n\t<li>\n        <img src=\"images/mission_num04.svg\" alt=\"\" width=\"53\" height=\"53\" class=\"num\">\n        <div class=\"image_wrap\">\n            <img src=\"images/mission04.png\" alt=\"\" width=\"135\" height=\"149\">\n        </div>\n        <div class=\"text_wrap\">\n            <h4>社会の“夢”</h4>\n            <p>未来のエネルギー社会、実証事業や廃止措置、環境への貢献をする</p>\n        </div>\n    </li>\n</ol>\n\n<!-- /inner -->\n</div>\n<!-- /area02 -->\n</div>\n</section>\n\n<div id=\"contents\">\n<section class=\"adjust_group\">\n<div class=\"inner\">\n<h2>NECOの仕事風景</h2>\n<p>様々な業務から成り立つ原子力の現場で、NECOの仲間たちは今日も明るく働いています。とある日の仕事風景を動画でお届けします！</p>\n<div class=\"iframe_wrap asp16_9 mb_high\">\n<iframe width=\"560\" height=\"315\" src=\"https://www.youtube.com/embed/c2Lumwot1bY?si=Gn86pSneL3xkjxJR\" title=\"YouTube video player\" frameborder=\"0\" allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share\" referrerpolicy=\"strict-origin-when-cross-origin\" allowfullscreen></iframe>\n</div>\n<style>\n/*\n<div class=\"imgC mb_high\">\n<div class=\"movie_frame\">\n<img src=\"images/move_thumb.jpg\" width=\"600\" height=\"387\" alt=\"\" class=\"move_main\" />\n<div class=\"move_mark\">\n\t<img src=\"../images/move.png\" alt=\"\" width=\"600\" height=\"387\">\n</div>\n<!--/move_mark-->\n<a href=\"https://www.youtube.com/embed/c2Lumwot1bY\" class=\"fb_youtube\"></a>\n</div>\n<!--/movie_frame_new-->\n</div>\n<!--/imgC-->\n*/\n</style>\n\n<h3>求人に関するお問い合わせ</h3>\n\n<div class=\"area01\">\n<div class=\"inner\">\n<h4>原子力エンジニアリング株式会社</h4>\n<p>〒319-1112　茨城県那珂郡東海村村松字平原3129-29<br>\n<span class=\"bld\">TEL：029-287-2828（代）<br>\nFAX：029-287-3399</span></p>\n<div class=\"btn02\">\n    <a href=\"https://forms.gle/zbkWBxVViE6ps3tR8\" target=\"_blank\">メールでのお問い合わせ</a>\n</div>\n</div>\n<!-- /inner -->\n</div>\n<!-- /area01 -->\n\n</div>\n<!-- /inner -->\n</section>\n<!-- /adjust_group -->\n\n</div>\n<!-- contents -->\n</main>\n\n\n<footer>\n<div class=\"inner\">\n<nav class=\"footer_area_nav sp\">\n    <ul>\n        <li><a href=\"../about/index.html\">NECOについて</a></li>\n        <li><a href=\"../works/index.html\">私たちの仕事</a></li>\n        <li><a href=\"../people/index.html\">NECOの仲間</a></li>\n        <li><a href=\"../career_formation/index.html\">キャリア形成</a></li>\n        <li><a href=\"../benefit/index.html\">環境と制度</a></li>\n        <li><a href=\"index.html\">採用情報</a></li>\n        <li><a href=\"../privacy/index.html\">プライバシーポリシー</a></li>\n        <!--<li><a href=\"../faq/index.html\">よくある質問</a></li>-->\n        <li><a href=\"../contact/index.html\">お問い合わせ</a></li>\n        <li><a href=\"../sitemap/index.html\">サイトマップ</a></li>\n    </ul>\n</nav>\n<!-- /footer_area_nav -->\n<div class=\"vcard_area\">\n    <div class=\"fn org\"><a href=\"../index.html\"><img src=\"../images/logo.svg\" alt=\"原子力エンジニアリング株式会社\" class=\"footer_logo\"></a></div>\n    <dl class=\"flex\">\n        <dt>本社</dt>\n        <dd class=\"adr\">\n            <span class=\"postal-code\">〒319-1112</span><span class=\"region\">茨城県</span><span class=\"locality\">那珂郡東海村</span><span class=\"street-address\">村松字平原3129-29</span>\n            <br>\n            <span class=\"tel\"><span class=\"type\">TEL：</span><span class=\"value\">029-287-2828</span></span>/\n            <span class=\"fax\">\n                <span class=\"type\">FAX：</span><span class=\"value\">029-287-3399</span>\n            </span>\n        </dd>\n    </dl>\n</div>\n<!-- /vcard_area -->\n</div>\n<!-- /inner -->\n\n<div class=\"footer_area_nav pc\">\n<div class=\"inner\">\n<ul class=\"flex\">\n<li><a href=\"../privacy/index.html\">プライバシーポリシー</a></li>\n<li><a href=\"../contact/index.html\">お問い合わせ</a></li>\n<li><a href=\"../sitemap/index.html\">サイトマップ</a></li>\n</ul>\n<div class=\"copyright\">\n<small >Copyright Nuclear Engineering Co.,Ltd. All Rights Reserved.</small>\n</div>\n</div>\n<!-- /inner -->\n</div>\n<!-- /footer_area_nav -->\n\n<div class=\"copyright sp\">\n    <small >Copyright Nuclear Engineering Co.,Ltd. All Rights Reserved.</small>\n</div>\n</footer>\n\n\n<nav class=\"floating_menu sp\">\n<ul>\n<!--<li class=\"contact full\"><a href=\"../contact/index.html\">お問い合わせ</a></li>-->\n<li class=\"entry\"><a href=\"../recruit/index.html#entry\">採用エントリー</a></li>\n<li class=\"requirements\"><a href=\"../recruit/index.html#requirements\">募集要項</a></li>\n</ul>\n</nav>\n\n\n</body>\n</html>\n","finalUrl":"https://www.neco-net.co.jp/recruit/","rendered":false,"_cachedAt":"2026-06-22T16:02:11.585Z"}