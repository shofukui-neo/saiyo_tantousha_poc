{"url":"https://www.jfe-et.co.jp/recruit/interview_person1/","html":"<!DOCTYPE html>\r\n<html lang=\"ja\">\r\n  <head>\r\n    <title>PERSON1 | JFE環境テクノロジー株式会社</title>\r\n    <meta charset=\"utf-8\">\r\n    <meta http-equiv=\"X-UA-Compatible\" content=\"IE=Edge\">\r\n    <meta name=\"format-detection\" content=\"telephone=no\">\r\n    <meta name=\"viewport\" content=\"width=device-width, user-scalable=1, initial-scale=1, viewport-fit=cover\">\r\n    <meta name=\"keywords\" content=\"this is meta keywords\">\r\n    <meta name=\"description\" content=\"先輩社員に、日々取り組む業務や今後の展望についてお話を伺いました。\">\r\n    <meta property=\"og:title\" content=\"PERSON1│JFE環境テクノロジー株式会社\">\r\n    <meta property=\"og:type\" content=\"website\">\r\n    <meta property=\"og:description\" content=\"先輩社員に、日々取り組む業務や今後の展望についてお話を伺いました。\">\r\n    <meta property=\"og:url\" content=\"\">\r\n    <meta property=\"og:image\" content=\"https://jfe-et.co.jp/_assets/images/_etc/ogp.png\">\r\n    <meta property=\"fb:app_id\" content=\"XXXXXXXXXXXXXXXX\">\r\n    <meta name=\"twitter:card\" content=\"summary\">\r\n    <meta name=\"twitter:site\" content=\"@XXXXX\">\r\n    <meta name=\"twitter:creator\" content=\"@XXXXX\">\r\n    <meta name=\"twitter:image:src\" content=\"https://jfe-et.co.jp/_assets/images/_etc/ogp.png\">\r\n    <link rel=\"icon\" type=\"image/x-icon\" href=\"../../_assets/images/_etc/favicon.ico\">\r\n    <link rel=\"icon\" type=\"image/png\" href=\"../../_assets/images/_etc/favicon.png\">\r\n    <link rel=\"apple-touch-icon\" type=\"image/png\" href=\"../../_assets/images/_etc/custom-icon.png\">\r\n    <!-- Google Tag Manager -->\r\n    <script>\r\n      (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\r\n      new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\r\n      j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\r\n      'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\r\n      })(window,document,'script','dataLayer','GTM-WR73CMD');\r\n    </script>\r\n    <!-- End Google Tag Manager -->\r\n    \r\n    <!-- Styles-->\r\n    <link rel=\"stylesheet\" media=\"print,screen\" href=\"https://cdnjs.cloudflare.com/ajax/libs/jqueryui/1.12.1/themes/base/jquery-ui.min.css\">\r\n    <link rel=\"stylesheet\" media=\"print,screen\" href=\"https://cdnjs.cloudflare.com/ajax/libs/Swiper/5.4.3/css/swiper.min.css\">\r\n    <link href=\"https://unpkg.com/aos@2.3.1/dist/aos.css\" rel=\"stylesheet\">\r\n    <link rel=\"stylesheet\" media=\"print,screen\" href=\"../../_assets/css/style.css\">\r\n  </head>\r\n  <body class=\"projectPage\" id=\"project\">\r\n     \r\n    <!-- Google Tag Manager (noscript) -->\r\n    <noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-WR73CMD\" height=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\r\n    <!-- End Google Tag Manager (noscript) -->\r\n    <header class=\"siteHeader\">\r\n      <div class=\"siteHeader__inner\">\r\n        <div class=\"siteHeader__logoBox\"><a class=\"siteHeader__logoLink\" href=\"../../\"> <img class=\"siteHeader__logo u-pcDb\" src=\"../../_assets/images/common/header_logo-pc.png\" alt=\"JFE環境テクノロジー株式会社\"><img class=\"siteHeader__logo u-spDb\" src=\"../../_assets/images/common/header_logo-sp.png\" alt=\"JFE環境テクノロジー株式会社\"></a></div>\r\n        <nav class=\"siteHeader__nav\" role=\"navigation\">\r\n          <ul class=\"siteHeader__list\"> \r\n            <li class=\"siteHeader__listItem\"> <a class=\"siteHeader__listItemLink\" href=\"../../\">ホーム</a></li>\r\n            <li class=\"siteHeader__listItem\"><a class=\"siteHeader__listItemLink\" href=\"../../business/\">事業紹介</a></li>\r\n            <li class=\"siteHeader__listItem\"> <a class=\"siteHeader__listItemLink\" href=\"../../company/\">会社情報</a>\r\n              <ul class=\"siteHeader__listContentMenu js-content\">\r\n                <li class=\"siteHeader__listContentMenuItem\"><a class=\"siteHeader__listContentMenuLink\" href=\"../../company/profile/\">会社概要</a></li>\r\n                <li class=\"siteHeader__listContentMenuItem\"> <a class=\"siteHeader__listContentMenuLink\" href=\"../../company/greeting/\">社長挨拶</a></li>\r\n                <li class=\"siteHeader__listContentMenuItem\"> <a class=\"siteHeader__listContentMenuLink\" href=\"../../company/history/\">沿革</a></li>\r\n                <li class=\"siteHeader__listContentMenuItem\"> <a class=\"siteHeader__listContentMenuLink\" href=\"../../company/philosophy/\">企業理念</a></li>\r\n                <li class=\"siteHeader__listContentMenuItem\"> <a class=\"siteHeader__listContentMenuLink\" href=\"../../company/purpose/\">パーパス</a></li>\r\n                <li class=\"siteHeader__listContentMenuItem\"> <a class=\"siteHeader__listContentMenuLink\" href=\"../../company/quality/\">品質 ・ 環境方針</a></li>\r\n                <li class=\"siteHeader__listContentMenuItem\"> <a class=\"siteHeader__listContentMenuLink\" href=\"../../company/health/\">健康経営</a></li>\r\n                <li class=\"siteHeader__listContentMenuItem\"> <a class=\"siteHeader__listContentMenuLink\" href=\"../../company/organization/\">組織図</a></li>\r\n                <li class=\"siteHeader__listContentMenuItem\"> <a class=\"siteHeader__listContentMenuLink\" href=\"../../company/office/\">拠点一覧</a></li>\r\n              </ul>\r\n            </li>\r\n            <li class=\"siteHeader__listItem\"> <a class=\"siteHeader__listItemLink\" href=\"../../recruit/\">採用情報</a>\r\n              <ul class=\"siteHeader__listContentMenu\">\r\n                <li class=\"siteHeader__listContentMenuItem\"> <a class=\"siteHeader__listContentMenuLink\" href=\"../../recruit/facilities/\">JETがつくるもの・仕事の流れ</a></li>\r\n                <li class=\"siteHeader__listContentMenuItem\"> <a class=\"siteHeader__listContentMenuLink\" href=\"../../recruit/workstyle/\">JETの働き方</a></li>\r\n                <li class=\"siteHeader__listContentMenuItem\">\r\n                  <p class=\"siteHeader__listContentMenuLink-nolink\">PROJECT & PERSON</p>\r\n                </li>\r\n                <li class=\"siteHeader__listContentMenuItem\"><a class=\"siteHeader__listContentMenuLink-small\" href=\"../../recruit/interview_project1/\">PROJECT</a></li>\r\n                <li class=\"siteHeader__listContentMenuItem\"><a class=\"siteHeader__listContentMenuLink-small\" href=\"../../recruit/interview_person1/\">PERSON 1</a></li>\r\n                <li class=\"siteHeader__listContentMenuItem\"><a class=\"siteHeader__listContentMenuLink-small\" href=\"../../recruit/interview_person2/\">PERSON 2</a></li>\r\n                <li class=\"siteHeader__listContentMenuItem\"><a class=\"siteHeader__listContentMenuLink-small\" href=\"../../recruit/interview_person3/\">PERSON 3</a></li>\r\n                <li class=\"siteHeader__listContentMenuItem\"> <a class=\"siteHeader__listContentMenuLink\" href=\"../../recruit/graduate/\">募集要項</a></li>\r\n                <li class=\"siteHeader__listContentMenuItem\"> <a class=\"siteHeader__listContentMenuLink\" href=\"../../recruit/faq/\">よくある質問</a></li>\r\n              </ul>\r\n            </li>\r\n            <li class=\"siteHeader__listItem\"> <a class=\"siteHeader__listItemLink\" href=\"../../topics/\">トピックス</a></li>\r\n            <li class=\"siteHeader__listItem\"> <a class=\"siteHeader__listItemLink\" href=\"../../information_disclosure/\">情報公開</a></li>\r\n          </ul>\r\n          <div class=\"siteHeader__contactBox\"> <a class=\"siteHeader__contactLink\" href=\"../../inquiry/\">お問い合わせ</a></div>\r\n        </nav>\r\n        <nav class=\"siteHeader__nav-sp\" role=\"navigation\">\r\n          <div class=\"siteHeader__navInner-sp js-humContent\">\r\n            <div class=\"siteHeader__closeBtnBox js-humCloseBtn\"><span class=\"siteHeader__closeBtn\"></span></div>\r\n            <div class=\"siteHeader__list\"> \r\n              <div class=\"siteHeader__listItem\"> <a class=\"siteHeader__listItemLink-sp\" href=\"../../\"><span class=\"siteHeader__listItemLink