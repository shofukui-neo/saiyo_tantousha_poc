\"></script>\n<script type=\"text/javascript\" src=\"https://www.nj-aac.com/wordpress/wp-includes/js/jquery/jquery-migrate.min.js?ver=3.4.1\" id=\"jquery-migrate-js\"></script>\n<link rel=\"https://api.w.org/\" href=\"https://www.nj-aac.com/wp-json/\" /><link rel=\"alternate\" title=\"JSON\" type=\"application/json\" href=\"https://www.nj-aac.com/wp-json/wp/v2/pages/63\" /><link rel=\"EditURI\" type=\"application/rsd+xml\" title=\"RSD\" href=\"https://www.nj-aac.com/wordpress/xmlrpc.php?rsd\" />\n\n<link rel=\"canonical\" href=\"https://www.nj-aac.com/company/presidentsmessage\" />\n<link rel='shortlink' href='https://www.nj-aac.com/?p=63' />\n<link rel=\"alternate\" title=\"oEmbed (JSON)\" type=\"application/json+oembed\" href=\"https://www.nj-aac.com/wp-json/oembed/1.0/embed?url=https%3A%2F%2Fwww.nj-aac.com%2Fcompany%2Fpresidentsmessage\" />\n<link rel=\"alternate\" title=\"oEmbed (XML)\" type=\"text/xml+oembed\" href=\"https://www.nj-aac.com/wp-json/oembed/1.0/embed?url=https%3A%2F%2Fwww.nj-aac.com%2Fcompany%2Fpresidentsmessage&#038;format=xml\" />\n</head>\r\n\r\n<body class=\"wp-singular page-template-default page page-id-63 page-child parent-pageid-44 wp-theme-nj-aac presidentsmessage\">\r\n\t<div class=\"site-wrap\">\r\n\t\t<div class=\"site-header site-header--default\" id=\"ancher-top\">\r\n\t\t\t<header class=\"site-header--fixed\">\r\n\t\t\t\t<a class=\"header-logo\" href=\"https://www.nj-aac.com/\"><img src=\"https://www.nj-aac.com/wordpress/wp-content/themes/nj-aac/img/logo.png\" alt=\"株式会社 北日本朝日航洋\"></a>\r\n\t\t\t\t<div class=\"header-nav-wrap\">\r\n\t\t\t\t\t<a href=\"#\" class=\"nav-toggle menu\" id=\"nav-toggle\"><span class=\"icon\"></span></a>\r\n\t\t\t\t\t<nav class=\"header-nav\" id=\"header-nav\">\r\n\t\t\t\t\t\t<ul class=\"menu\"><li class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-538\"><a href=\"https://www.nj-aac.com/business\"><span class=\"ja\">事業紹介</span><span class=\"en\">Business</span></a></li>\n<li class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-1430\"><a href=\"https://www.nj-aac.com/find\"><span class=\"ja\">目的から事業を探す</span><span class=\"en\">Find business</span></a></li>\n<li class=\"menu-item menu-item-type-post_type menu-item-object-page current-page-ancestor menu-item-82\"><a href=\"https://www.nj-aac.com/company\"><span class=\"ja\">企業情報</span><span class=\"en\">Information</span></a></li>\n<li class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-964\"><a target=\"_blank\" href=\"https://www.nj-aac.com/recruit\"><span class=\"ja\">採用情報</span><span class=\"en\">Recruit</span></a></li>\n<li class=\"menu-item-contact menu-item menu-item-type-post_type menu-item-object-page menu-item-84\"><a href=\"https://www.nj-aac.com/contact\"><span class=\"ja\">お問い合わせ</span><span class=\"en\">Contact</span></a></li>\n</ul>\t\t\t\t\t</nav>\r\n\t\t\t\t\t<div id=\"nav-bg\" class=\"nav-bg\"></div>\r\n\t\t\t\t</div>\r\n\t\t\t\t\r\n\t\t\t</header>\r\n\t\t</div>\r\n\r\n\t\t<div class=\"site-content\">\r\n\r\n\r\n\t<div class=\"site-content\">\r\n\r\n\t\t<div class=\"page-title\">\r\n\t\t\t<div class=\"inner\">\r\n\t\t\t\t<h1 class=\"title\">社長挨拶</h1>\r\n\t\t\t</div>\r\n\t\t</div>\r\n\r\n\t\t        <div class=\"breadcrumb inner\">\r\n            <ol>\r\n            <li><a href=\"https://www.nj-aac.com\">ホーム</a></li><li><a href=\"https://www.nj-aac.com/company\">企業情報</a></li><li>社長挨拶</li>            </ol>\r\n        </div>\r\n\r\n\t\t<div class=\"inner\">\r\n\t\t\t<main class=\"main\">\r\n\r\n\t\t\t\t\n<h2 class=\"wp-block-heading is-style-title2\">社長挨拶</h2>\n\n\n\n<div class=\"wp-block-media-text alignwide has-media-on-the-right is-stacked-on-mobile is-vertically-aligned-top mb-5\" style=\"grid-template-columns:auto 30%\"><div class=\"wp-block-media-text__content\">\n<p>平素は格別のお引き立てを賜り、誠にありがとうございます。</p>\n\n\n\n<p>わたしたち北日本朝日航洋は1972年の創業以来、測量、地籍調査など国土を測る仕事から、地理空間情報技術を活かした自治体サービス支援や建設コンサルタント・補償コンサルタント事業など空間情報コンサルタントの技術集団として活動を行って参りました。</p>\n\n\n\n<p>近年では、長年培った空間情報技術を用いて、i-Construction、インフラ分野のＤＸをさらに推進するとともに、脱炭素社会の実現に向けたＧＸの取組みなど、地域社会と共生し、地域の特徴に応じた社会的課題や環境問題、防災・減災に対する活動に取り組んでおります。</p>\n</div><figure class=\"wp-block-media-text__media\"><img decoding=\"async\" src=\"https://www.nj-aac.com/wordpress/wp-content/uploads/2024/06/80d8fc5e4d2327a61f59c76a6a7e7a96-1200x812.jpg\" alt=\"\" class=\"wp-image-2002 size-medium\"/></figure></div>\n\n\n\n<p>これからも、価値観の多様化や技術革新など、急速に変化する社会状況において、お客様から選ばれつづけ、さらには事業を拡大して発展を遂げるためには、変化のスピードに対応し、チャレンジブルな取り組み姿勢が重要です。地域社会の声に耳を傾け、探究心を持ち行動することを最優先に、お客さまをはじめ関係者の皆様から信頼されつづける企業として、従業員一同研鑽して参ります。</p>\n\n\n\n<p>今後も、皆さま方の変わらぬご支援、ご鞭撻を賜りますようよろしくお願い申し上げます。</p>\n\n\n<div class=\"wp-block-image\">\n<figure class=\"alignright size-full is-resized\"><img fetchpriority=\"high\" decoding=\"async\" width=\"579\" height=\"817\" src=\"https://www.nj-aac.com/wordpress/wp-content/uploads/2024/11/3c56c7c4082c269d0a37248d7287f1a8-1.jpg\" alt=\"\" class=\"wp-image-2088\" style=\"width:338px;height:auto\" srcset=\"https://www.nj-aac.com/wordpress/wp-content/uploads/2024/11/3c56c7c4082c269d0a37248d7287f1a8-1.jpg 579w, https://www.nj-aac.com/wordpress/wp-content/uploads/2024/11/3c56c7c4082c269d0a37248d7287f1a8-1-276x390.jpg 276w\" sizes=\"(max-width: 579px) 100vw, 579px\" /></figure></div>\t\t\t\t\r\n\t\t\t</main>\r\n\t\t</div>\r\n\r\n\t</div>\r\n\r\n<div class=\"page-top\"><a href=\"#\"><img src=\"https://www.nj-aac.com/wordpress/wp-content/themes/nj-aac/img/page-top.png\" alt=\"TOP\"></a></div>\r\n\r\n\t\t\t<footer class=\"site-footer\">\r\n\t\t\t\t<div class=\"footer-inner\">\r\n\r\n\t\t\t\t\t<div class=\"footer-nav\">\r\n\t\t\t\t\t\t<ul class=\"menu\"><li class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-home menu-item-132\"><a href=\"https://www.nj-aac.com/\">HOME</a></li>\n<li class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-has-children menu-item-133\"><a href=\"https://www.nj-aac.com/business\">事業紹介</a>\n<ul class=\"sub-menu\">\n\t<li class=\"menu-i