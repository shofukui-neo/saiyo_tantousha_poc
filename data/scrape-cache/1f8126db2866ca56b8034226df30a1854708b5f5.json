aac/img/logo-health-and-productivity-2024.jpg\" alt=\"健康経営優良法人2024\"></a>\r\n\t\t\t\t\t\t\t<a><img src=\"https://www.nj-aac.com/wordpress/wp-content/themes/nj-aac/img/logo-ikusei-r6.jpg\" alt=\"いわて産業人材奨学金返還支援制度\"></a>\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t<p>北日本朝日航洋は、プライバシーマーク、くるみんマーク、健康経営優良法人、いわて産業人材奨学金返還支援制度の認定を取得しています。</p>\r\n\t\t\t\t\t\t<small class=\"copyright\">&copy;2010-2021 North Japan Aero Asahi Corporation</small>\r\n\t\t\t\t\t</div>\r\n\r\n\t\t\t\t</div>\r\n\t\t\t\t\r\n\t\t\t</footer>\r\n\t\t</div>\t</div><script type=\"speculationrules\">\n{\"prefetch\":[{\"source\":\"document\",\"where\":{\"and\":[{\"href_matches\":\"\\/*\"},{\"not\":{\"href_matches\":[\"\\/wordpress\\/wp-*.php\",\"\\/wordpress\\/wp-admin\\/*\",\"\\/wordpress\\/wp-content\\/uploads\\/*\",\"\\/wordpress\\/wp-content\\/*\",\"\\/wordpress\\/wp-content\\/plugins\\/*\",\"\\/wordpress\\/wp-content\\/themes\\/nj-aac\\/*\",\"\\/*\\\\?(.+)\"]}},{\"not\":{\"selector_matches\":\"a[rel~=\\\"nofollow\\\"]\"}},{\"not\":{\"selector_matches\":\".no-prefetch, .no-prefetch a\"}}]},\"eagerness\":\"conservative\"}]}\n</script>\n\t\t<style>\n\t\t\t:root {\n\t\t\t\t-webkit-user-select: none;\n\t\t\t\t-webkit-touch-callout: none;\n\t\t\t\t-ms-user-select: none;\n\t\t\t\t-moz-user-select: none;\n\t\t\t\tuser-select: none;\n\t\t\t}\n\t\t</style>\n\t\t<script type=\"text/javascript\">\n\t\t\t/*<![CDATA[*/\n\t\t\tdocument.oncontextmenu = function(event) {\n\t\t\t\tif (event.target.tagName != 'INPUT' && event.target.tagName != 'TEXTAREA') {\n\t\t\t\t\tevent.preventDefault();\n\t\t\t\t}\n\t\t\t};\n\t\t\tdocument.ondragstart = function() {\n\t\t\t\tif (event.target.tagName != 'INPUT' && event.target.tagName != 'TEXTAREA') {\n\t\t\t\t\tevent.preventDefault();\n\t\t\t\t}\n\t\t\t};\n\t\t\t/*]]>*/\n\t\t</script>\n\t\t<script type=\"text/javascript\" id=\"vk-ltc-js-js-extra\">\n/* <![CDATA[ */\nvar vkLtc = {\"ajaxurl\":\"https:\\/\\/www.nj-aac.com\\/wordpress\\/wp-admin\\/admin-ajax.php\",\"editLabel\":\"\\u7de8\\u96c6\"};\n/* ]]> */\n</script>\n<script type=\"text/javascript\" src=\"https://www.nj-aac.com/wordpress/wp-content/plugins/vk-link-target-controller/js/script.min.js?ver=1.10.0\" id=\"vk-ltc-js-js\"></script>\n<script type=\"text/javascript\" src=\"https://www.nj-aac.com/wordpress/wp-content/themes/nj-aac/js/script.js?ver=1.0\" id=\"script-js\"></script>\n</body>\r\n</html>","finalUrl":"https://www.nj-aac.com/company/presidentsmessage","rendered":false,"_cachedAt":"2026-06-23T21:00:22.723Z"}