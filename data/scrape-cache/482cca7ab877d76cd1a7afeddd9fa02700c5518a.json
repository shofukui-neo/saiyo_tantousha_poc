span>\n                            </h3>\n                            <div class=\"date-icon\"><img src=\"./assets/img/date-pic-03.svg\" class=\"data-icon\"></div>\n                            <p class=\"data-row\">\n                                <span class=\"data-value\">\n                                    <span class=\"data-number\">100</span>\n                                    <span class=\"data-unit\">%</span>\n                                </span>\n                            </p>\n                        </li>\n                        <li class=\"date-card\">\n                            <h3>\n                                <span class=\"data-label\">有休取得率</span>\n                            </h3>\n                            <div class=\"date-icon\"><img src=\"./assets/img/date-pic-04.svg\" class=\"data-icon\"></div>\n                            <p class=\"data-row\">\n                                <span class=\"data-value\">\n                                    <span class=\"data-number\">63.1</span>\n                                    <span class=\"data-unit\">%</span>\n                                </span>\n                            </p>\n                            <p class=\"data-meta\">2025年度実績</p>\n                        </li>\n                        <li class=\"date-card\">\n                            <h3>\n                                <span class=\"data-label\">男女比</span>\n                            </h3>\n                            <div class=\"date-icon\"><img src=\"./assets/img/date-pic-05.svg\" class=\"data-icon\"></div>\n                            <div class=\"data-group\">\n                                <p class=\"data-row\">\n                                    <span class=\"data-item-label\">男性</span>\n                                    <span class=\"data-value\">\n                                        <span class=\"data-number\">66</span>\n                                        <span class=\"data-unit\">%</span>\n                                    </span>\n                                </p>\n                                <p class=\"data-row\">\n                                    <span class=\"data-item-label\">女性</span>\n                                    <span class=\"data-value\">\n                                        <span class=\"data-number\">34</span>\n                                        <span class=\"data-unit\">%</span>\n                                    </span>\n                                </p>\n                            </div>\n                            <p class=\"data-meta\">2026.5.1現在</p>\n                        </li>\n                        <li class=\"date-card\">\n                            <h3>\n                                <span class=\"data-label\">年齢分布</span>\n                                <span class=\"data-description\">（役員除く）</span>\n                            </h3>\n                            <div class=\"date-icon\"><img src=\"./assets/img/date-pic-06.svg\" class=\"data-icon\"></div>\n                            <div class=\"data-group\">\n                                <p class=\"data-row\">\n                                    <span class=\"data-item-label\">20代</span>\n                                    <span class=\"data-value\">\n                                        <span class=\"data-number\">9</span>\n                                        <span class=\"data-unit\">人</span>\n                                    </span>\n                                </p>\n                                <p class=\"data-row\">\n                                    <span class=\"data-item-label\">30代</span>\n                                    <span class=\"data-value\">\n                                        <span class=\"data-number\">33</span>\n                                        <span class=\"data-unit\">人</span>\n                                    </span>\n                                </p>\n                                <p class=\"data-row\">\n                                    <span class=\"data-item-label\">40代</span>\n                                    <span class=\"data-value\">\n                                        <span class=\"data-number\">22</span>\n                                        <span class=\"data-unit\">人</span>\n                                    </span>\n                                </p>\n                                <p class=\"data-row\">\n                                    <span class=\"data-item-label\">50代</span>\n                                    <span class=\"data-value\">\n                                        <span class=\"data-number\">18</span>\n                                        <span class=\"data-unit\">人</span>\n                                    </span>\n                                </p>\n                                <p class=\"data-row\">\n                                    <span class=\"data-item-label\">60代</span>\n                                    <span class=\"data-value\">\n                                        <span class=\"data-number\">5</span>\n                                        <span class=\"data-unit\">人</span>\n                                    </span>\n                                </p>\n                            </div>\n                            <p class=\"data-meta\">2026年3月末現在</p>\n                        </li>\n                    </ul>\n                </div>\n            </div>\n        </section>\n        <section class=\"jobtype\" id=\"jobtype\">\n            <div class=\"inner\">\n                <div class=\"jobtype-area\">\n                    <div class=\"text-area\">\n                        <h2 class=\"section-heading\">\n                            <span class=\"en\">JOB TYPE</span>\n                            <span class=\"jp\">職種を知る</span>\n                        </h2>\n                        <p>野球がもつ笑顔と感動を、ビジネスの力でもっと大きく。私たちと一緒に一歩を踏み出しましょう。</p>\n   