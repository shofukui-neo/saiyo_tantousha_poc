 Tag Manager (noscript) -->\r\n<!-- header start -->\r\n<header id=\"header\"></header>\r\n<!-- header end -->\r\n<main>\r\n<section class=\"mv02 l-section\">\r\n\t<div class=\"swiper\">\r\n    <div class=\"swiper-wrapper\" data-num=\"4\">\r\n\t  <!-- top slider 13 -->\r\n      <div class=\"swiper-slide slide-fix\">\r\n        <div class=\"slide\">\r\n          <div class=\"slide-media img-cover\"><img src=\"cmn/img/home/home-hero-13.jpg\" alt=\"5500emⅢ誕生！\"></div>\r\n\t\t\t<div class=\"slide-cbox\">\r\n          \t\t<h2 class=\"slide-title\">世界最大の電動射出成形機<br>5500emⅢ誕生！</h2>\r\n\t\t\t\t<p class=\"slide-text\">自動車のxEV化に伴う外板ボディパネルや車体下部の空力部品等の大型樹脂部品の需要に応える、<br>世界最大の電動射出成形機5500emⅢを上市。<br>～詳細は2025年10月16日のニュースリリースをご確認ください～</p>\r\n\t\t\t</div>\r\n        </div>\r\n      </div>\r\n\t  <!-- /top slider 13 -->\r\n\t  <!-- top slider 11 -->\r\n      <div class=\"swiper-slide\">\r\n        <div class=\"slide\">\r\n          <div class=\"slide-media img-cover\"><img src=\"cmn/img/home/home-hero-12.jpg\" alt=\"世界への挑戦 UH9000誕生！\"></div>\r\n\t\t\t<div class=\"slide-cbox\">\r\n          \t\t<h2 class=\"slide-title\">世界への挑戦<br>UH9000誕生！</h2>\r\n\t\t\t\t<p class=\"slide-text\">「ギガキャスト技術」を実現する国内最大のダイカストマシンUH9000を上市。<br>革新のテクノロジーでモノづくりの未来をサポートします。</p>\r\n\t\t\t</div>\r\n        </div>\r\n      </div>\r\n\t  <!-- /top slider 11 -->\r\n\t  <!-- top slider 01 -->\r\n      <div class=\"swiper-slide\">\r\n        <div class=\"slide\">\r\n          <div class=\"slide-media img-cover\"><img src=\"./cmn/img/home/home-hero-01.jpg\" alt=\"\"></div>\r\n\t\t\t<div class=\"slide-cbox\">\r\n          \t\t<h2 class=\"slide-title\">地域との「共存同栄」</h2>\r\n\t\t\t\t<p class=\"slide-text\">セメント産業の生命線「宇部伊佐専用道路」。<br>この道を支えるのは当社が架設した全長1020mの興産大橋です。<br>交通渋滞の解消に繋がり、産業都市・宇部の発展に大きく寄与しています。</p>\r\n\t\t\t</div>\r\n        </div>\r\n      </div>\r\n\t  <!-- /top slider 01 -->\r\n\t  <!-- top slider 02 -->\r\n      <div class=\"swiper-slide\">\r\n        <div class=\"slide\">\r\n          <div class=\"slide-media img-cove