{"url":"https://www.marutafoods.co.jp/gaiyou/","html":"\r\n<!DOCTYPE html>\r\n<html lang=\"ja\" class=\"no-js no-svg\">\r\n<head>\r\n<meta charset=\"utf-8\">\r\n<meta name=\"viewport\" content=\"width=device-width\">\r\n<meta name=\"description\" content=\"マルタスギヨのホームページへようこそ。数の子わさび、みそ漬、酢漬、醤油などの製品情報をはじめ、簡単お料理レシピ、プレゼントなどをご紹介。\">\r\n<meta name=\"keywords\" content=\"マルタスギヨ, 新潟,タレかつ, たれカツ 数の子, 酢漬け, 珍味, 佃煮, 漬物, わかめ, 米糀, 梅干, 醤油, 調味料, 食品, おかず, おつまみ\">\r\n\r\n<script>(function(html){html.className = html.className.replace(/\\bno-js\\b/,'js')})(document.documentElement);</script>\n<title>会社概要 &#8211; マルタスギヨ株式会社</title>\n<meta name='robots' content='max-image-preview:large' />\n<!--[if lt IE 9]>\n<script type='text/javascript' src='https://www.marutafoods.co.jp/wp/wp-content/themes/marutafoods/assets/js/html5.js?ver=3.7.3' id='html5-js'></script>\n<![endif]-->\n<script type='text/javascript' src='https://www.marutafoods.co.jp/wp/wp-includes/js/jquery/jquery.min.js?ver=3.6.1' id='jquery-core-js'></script>\n<script type='text/javascript' src='https://www.marutafoods.co.jp/wp/wp-includes/js/jquery/jquery-migrate.min.js?ver=3.3.2' id='jquery-migrate-js'></script>\n<script type=\"text/javascript\">\n\twindow._se_plugin_version = '8.1.9';\n</script>\n\r\n<meta property=\"og:title\" content=\"マルタスギヨ株式会社\">\n<meta property=\"og:url\" content=\"https://www.marutafoods.co.jp\">\n<meta property=\"og:image\" content=\"https://www.marutafoods.co.jp/common/img/og/logo.jpg\" />\r\n<meta property=\"og:type\" content=\"company\"/>\r\n<meta property=\"og:site_name\" content=\"マルタスギヨ株式会社\"/>\r\n\r\n<link rel=\"shortcut icon\" href=\"/favicon.ico\">\r\n\r\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/common/css/ress.css\">\r\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/common/css/animate.css\">\r\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/common/css/layout.css\">\r\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/common/css/print.css\" media=\"print\">\r\n\r\n<!--jQuery-->\r\n<script src=\"//ajax.googleapis.com/ajax/libs/jquery/1.11.1/jquery.min.js\"></script>\r\n<script src=\"/common/js/jquery-extension.js\"></script>\r\n\r\n\r\n<!--レスポンシブcss-->\r\n<link rel=\"stylesheet\" href=\"/common/css/style-sm.css\" media=\"print, screen and (max-width:1059px)\">\r\n<link rel=\"stylesheet\" href=\"/common/css/style-s.css\" media=\"screen and (max-width:767px)\">\r\n<link rel=\"stylesheet\" href=\"/common/css/style-ml.css\" media=\"print,  screen and (min-width:768px)\">\r\n<link rel=\"stylesheet\" href=\"/common/css/style-m.css\" media=\"print, screen and (min-width:768px) and (max-width:1059px)\">\r\n<link rel=\"stylesheet\" href=\"/common/css/style-l.css\" media=\"only screen and (min-width:1060px)\">\r\n\r\n<!--ノトフォント-->\r\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/common/font/notosansjapanese.css\">\r\n\r\n<!--fontawesome-->\r\n<link href=\"https://maxcdn.bootstrapcdn.com/font-awesome/4.7.0/css/font-awesome.min.css\" rel=\"stylesheet\" integrity=\"sha384-wvfXpqpZZVQGK6TAh5PVlGOfQNHSoD2xbE+QkPxCAFlNEevoEH3Sl0sibVcOQVnN\" crossorigin=\"anonymous\">\r\n\r\n<!--アナリティクス-->\r\n<!-- Global site tag (gtag.js) - Google Analytics -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=UA-24575863-1\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'UA-24575863-1');\n</script>\n<!--/アナリティクス-->\r\n</head>\r\n\r\n<body class=\"page-template page-template-page-company page-template-page-company-php page page-id-87 has-header-image page-two-column colors-light\" id=\"page\">\r\n<!--ヘッダー-->\r\n<header class=\"header\" id=\"top-head\">\n  <div class=\"head_white_bg\">\n    <div class=\"head_wrap1\">\n      <h1 class=\"head_logo\"><a href=\"/\"><img src=\"/common/img/header/logo.png\" alt=\"マルタスギヨ株式会社\"/></a></h1>\n      <p class=\"head_contact_link sp_none\"><a href=\"/contact/\">お問い合わせ</a></p>\n      <p class=\"head_policy_link sp_none mr30\"><a href=\"/policy/\">個人情報について</a></p>\n      <p class=\"head_policy_link sp_none\"><a href=\"/en/\">ENGLISH</a></p>\n        \n        <div class=\"sp_only\">\n            <a href=\"/en/\" class=\"sp_header_en_link\">ENGLISH</a>\n        </div>\n        \n        \n    <a class=\"menu-trigger sp_only\">\n      <span></span>\n      <span></span>\n      <span></span>\n      <div class=\"sp_head_menu\">メニュー</div>\n      </a>\n    </div>\n  </div>\n  <div class=\"head_red_bg\">\n    <ul class=\"head_wrap2 gnav head_gnav fadeOutUp\">\n      <li class=\"gnav_kodawari\"><a href=\"/kodawari/\">マルタスギヨの<br class=\"sp_none\">こだわり</a></li>\n      <li class=\"head_key gnav_products\"><a href=\"/products/\" class=\"sp_none\">商品紹介</a><a class=\"sp_only\">商品紹介</a>\n      <ul class=\"head_open\">\n      <li><a href=\"/products/\">商品紹介トップ</a></li>\n      \t<li class=\"cat-item cat-item-2 cat-item-items_1\"><a href=\"https://www.marutafoods.co.jp/products_cat/items_1/\">山海漬・松前漬・数の子シリーズ</a>\n</li>\n\t<li class=\"cat-item cat-item-13 cat-item-items_2\"><a href=\"https://www.marutafoods.co.jp/products_cat/items_2/\">酢漬シリーズ</a>\n</li>\n\t<li class=\"cat-item cat-item-35 cat-item-items_3\"><a href=\"https://www.marutafoods.co.jp/products_cat/items_3/\">珍味シリーズ</a>\n</li>\n\t<li class=\"cat-item cat-item-40 cat-item-items_4\"><a href=\"https://www.marutafoods.co.jp/products_cat/items_4/\">佃煮シリーズ</a>\n</li>\n\t<li class=\"cat-item cat-item-43 cat-item-items_5\"><a href=\"https://www.marutafoods.co.jp/products_cat/items_5/\">漬物シリーズ</a>\n</li>\n\t<li class=\"cat-item cat-item-46 cat-item-items_6\"><a href=\"https://www.marutafoods.co.jp/products_cat/items_6/\">わかめシリーズ</a>\n</li>\n\t<li class=\"cat-item cat-item-56 cat-item-items_9\"><a href=\"https://www.marutafoods.co.jp/products_cat/items_9/\">業務用シリーズ</a>\n</li>\n\t<li class=\"cat-item cat-item-58 cat-item-items_10\"><a href=\"https://www.marutafoods.co.jp/products_cat/items_10/\">醤油シリーズ</a>\n</li>\n\t<li class=\"cat-item cat-item-60 cat-item-items_11\"><a href=\"https://www.marutafoods.co.jp/products_cat/items_11/\">醤油ギフトシリーズ</a>\n</li>\n\t<li class=\"cat-item cat-item-62 cat-item-items_12\"><a href=\"https://www.marutafoods.co.jp/products_cat/items_12/\">調味料シリーズ</a>\n</li>\n\t<li class=\"cat-item cat-item-49 cat-item-items_7\"><a href=\"https://www.marutafoods.co.jp/products_cat/items_7/\">サラダシリーズ</a>\n</li>\n\t<li class=\"cat-item cat-item-102 cat-item-items_13\"><a href=\"https://www.marutafoods.co.jp/products_cat/items_13/\">その他シリーズ</a>\n</li>\n \n      </ul>\n      </li>\n      <li class=\"gnav_recipe\"><a href=\"/recipe/\">レシピ</a></li>\n      <li class=\"gnav_shop\"><a href=\"/shop/\">オンラインショップ</a></li>\n      <li class=\"gnav_company\"><a href=\"/company/\" >会社案内</a></li>\n      <li class=\"gnav_recruit\"><a href=\"/recruit/\" >採用情報</a></li>\n    </ul>\n  </div>\n</header>\n\n\n\n\n<!--/ヘッダー-->\r\n<!--パン屑-->\r\n<nav class=\"pankuzu\">\r\n<ul class=\"w1060\">\r\n  <li><a href=\"/\">HOME</a></li>\r\n  <li><a href=\"/company/\">会社案内</a></li>\r\n    <li>会社概要</li>\r\n</ul>\r\n</nav>\r\n<!--/パン屑-->\r\n\r\n<section class=\"w1060 subpage_cantent_body\">\r\n<div align=\"center\" class=\"under_red_line\">\r\n  <h2 class=\"common_title\">会社概要</h2>\r\n    </div>\r\n    \r\n    <div class=\"products_wrap \">\r\n      <div class=\"products_wrap_right \">\r\n<!-- コンテンツ ==================================== -->\r\n       <div class=\"gaiyou_pic_wrap\">\r\n      \r\n      <p><img src=\"https://www.marutafoods.co.jp/wp/wp-content/uploads/2017/11/4c1d9008130402c08e9f27e254911a5f.png\" alt=\"\"  class=\"\"  /></p>\r\n      \r\n            \r\n      <p><img src=\"https://www.marutafoods.co.jp/wp/wp-content/uploads/2017/11/bcb6d63213e7e748b0a95b857e1fe711.png\" alt=\"\"  class=\"\"  /></p>\r\n      \r\n            </div>\r\n\r\n\r\n       <div class=\"rec1_2\">\r\n      <table class=\"\">\r\n      \r\n      <tr>\r\n      <th>社名</th>\r\n      <td><p>マルタスギヨ株式会社</p>\n</td>\r\n      </tr>\r\n      \r\n            \r\n      <tr>\r\n      <th>本社所在地</th>\r\n      <td><p>〒950-3365<br />\n新潟県新潟市北区太子堂134番地4</p>\n</td>\r\n      </tr>\r\n      \r\n            \r\n      <tr>\r\n      <th>代表者</th>\r\n      <td><p>代表取締役社長　　臼池 忠幸</p>\n</td>\r\n      </tr>\r\n      \r\n            \r\n      <tr>\r\n      <th>創業年月</th>\r\n      <td><p>昭和46年10月</p>\n</td>\r\n      </tr>\r\n      \r\n            \r\n      <tr>\r\n      <th>資本金</th>\r\n      <td><p>27,500千円</p>\n</td>\r\n      </tr>\r\n      \r\n            \r\n      <tr>\r\n      <th>決算</th>\r\n      <td><p>6月</p>\n</td>\r\n      </tr>\r\n      \r\n            \r\n      <tr>\r\n      <th>販売地域</th>\r\n      <td><p>新潟・東京を縦軸として、北海道から九州までの全国網<br />\n新潟を起点とする全国チルド輸送網を持つ</p>\n</td>\r\n      </tr>\r\n      \r\n            \r\n      <tr>\r\n      <th>生産品目</th>\r\n      <td><p>数の子わさび等の粕漬加工品類</p>\n<p>数の子、ししゃも等魚卵醤油漬加工品類</p>\n<p>魚介類の酢漬加工品類</p>\n<p>昆布巻き等の佃煮加工品類</p>\n<p>農産物、水産物の醤油による加工品類</p>\n<p>醤油、調味料、たれ類</p>\n</td>\r\n      </tr>\r\n      \r\n            \r\n      <tr>\r\n      <th>営業所</th>\r\n      <td><p>東京・仙台・名古屋・大阪・札幌・金沢</p>\n</td>\r\n      </tr>\r\n      \r\n            \r\n      <tr>\r\n      <th>駐在所</th>\r\n      <td><p>秋田・岡山・福岡</p>\n</td>\r\n      </tr>\r\n      \r\n            \r\n      <tr>\r\n      <th>関連企業</th>\r\n      <td><p>株式会社スギヨ<br />\n石川県七尾市西三階町10号4-1<br />\nTEL：0767-53-0180<br />\nURL：<span style=\"color: #3366ff;\"><a style=\"color: #3366ff;\" href=\"http://www.sugiyo.co.jp/\" target=\"_blank\" rel=\"noopener\">http://www.sugiyo.co.jp/</a></span></p>\n</td>\r\n      </tr>\r\n      \r\n            \r\n      <tr>\r\n      <th>ISO22000認証取得</th>\r\n      <td><p><img class=\"alignnone size-full wp-image-3261\" src=\"https://www.marutafoods.co.jp/wp/wp-content/uploads/2023/09/marutaISOnew-1.png\" alt=\"\" width=\"213\" height=\"155\" /></p>\n<p>2018年1月29日、マルタスギヨ株式会社 本社工場におきまして、食品安全マネジメントシステムの国際規格である「ISO 22000」の認証を取得いたしました。</p>\n<p>今後も、企業ビジョン「食べる喜び・笑顔を創造するフードカンパニー」のもと、食の「安心・安全」を第一に、皆様にお喜びいただける商品を製造してまいります。</p>\n<p style=\"text-align: center;\"><span style=\"font-size: 14pt;\">マルタスギヨ株式会社　ISO22000　食品安全方針</span></p>\n<p style=\"text-align: center;\"><span style=\"font-size: 14pt;\"><br />\n【企業理念】</span></p>\n<p style=\"text-align: center;\"><span style=\"font-size: 10pt;\">より良いものをより易く提供することで、</span><br />\n<span style=\"font-size: 13.3333px;\">当社の商品を召し上がって頂く国内外のお客様へ</span><br />\n<span style=\"font-size: 13.3333px;\">地元の食文化を通じて、食べる喜び・おいしさをお届けします。</span></p>\n<p style=\"text-align: center;\"><span style=\"font-size: 14pt;\">【ビジョン】</span></p>\n<p style=\"text-align: center;\"><span style=\"font-size: 10pt;\">「食べる喜び・笑顔を創造するフードカンパニー」</span><br />\n<span style=\"font-size: 10pt;\">私たちは企業理念及びビジョンを追求するとともに、</span><br />\n<span style=\"font-size: 10pt;\">食品安全マネジメントシステムの有効性を継続的に改善して参ります。</span><br />\n<span style=\"font-size: 10pt;\">当社は安心・安全はもとより、おいしさと健康を追求した食品を</span><br />\n<span style=\"font-size: 10pt;\">提供するために、今後とも努力してまいります。</span></p>\n<p style=\"text-align: center;\"><span style=\"font-size: 14pt;\">【基本方針】</span></p>\n<p style=\"text-align: left;\"><span style=\"font-size: 10pt;\">１、事業活動に関連する国内外の関係法規法令・条例等を遵守し、食品の安全を確保します。</span></p>\n<p><span style=\"font-size: 10pt;\">２、フードチェーンの一員として常に食品安全を優先し、お客様やお取引先との食品安全に関するコミュニケーションを大切にしてまいります。</span></p>\n<p><span style=\"font-size: 10pt;\">３、食品安全に対する意識・知識に基づいた行動を習慣化して行えるよう、食品製造に従事する従業員に食品安全教育を実施します。</span></p>\n<p><span style=\"font-size: 10pt;\">４、お客様からのご意見・ご指摘を真摯に受け止め、よりよい製品づくりに活かします。</span></p>\n<p><span style=\"font-size: 10pt;\">５、定期的なマネジメントレビューを実施し、食品安全方針および目標の継続的改善を図ります。</span></p>\n</td>\r\n      </tr>\r\n      \r\n            \r\n      <tr>\r\n      <th>MSC CoC 認証取得</th>\r\n      <td><p><img class=\"alignleft wp-image-2330\" src=\"https://www.marutafoods.co.jp/wp/wp-content/uploads/2020/04/Japanese-Landscape-Blue-CMYK-300x115.jpg\" alt=\"\" width=\"100\" height=\"38\" /><span style=\"color: #0000ff;\">MSC-C-57567<br />\n漁業が、MSC漁業認証規格に則りMSC漁業認証を取得し、その漁業で獲られた水産物を、流通から製造、加工、販売に至る全ての過程において「CoC認証」を取得した企業が適切に管理することで、初めて「海のエコラベル」のついた製品が消費者の食卓に並べられるようになります。</span></p>\n<p>令和元年７月本社工場・小須戸工場・阿賀野センターが<br />\nMSC CoC 認証を取得しました。</p>\n</td>\r\n      </tr>\r\n      \r\n            \r\n      <tr>\r\n      <th>新潟市障がい者雇用企業認定</th>\r\n      <td><p>新潟市障がい者雇用企業認定事業で、本社工場・事務所、小須戸工場が、積極的に障がい者雇用に取り組む企業として「みつばち企業認定」を受けています。</p>\n<p><img class=\"size-full wp-image-1901 aligncenter\" src=\"http://www.marutafoods.co.jp/wp/wp-content/uploads/2019/04/83a49f33cfd4afd339530cacec962fd7.jpg\" alt=\"\" width=\"99\" height=\"160\" /></p>\n</td>\r\n      </tr>\r\n      \r\n            \r\n      <tr>\r\n      <th>新潟県ハッピーパートナー企業認定</th>\r\n      <td><p>新潟県が推進する『ハッピー・パートナー企業(新潟県男女共同参画推進企業）』の認定を受けています。</p>\n<p><img class=\"alignnone wp-image-2039 size-thumbnail\" src=\"http://www.marutafoods.co.jp/wp/wp-content/uploads/2019/09/e46371544903b2b53483abb647231428-150x150.jpg\" alt=\"\" width=\"150\" height=\"150\" /></p>\n</td>\r\n      </tr>\r\n      \r\n            \r\n      <tr>\r\n      <th>一般事業主行動計画</th>\r\n      <td><p><a href=\"https://www.marutafoods.co.jp/wp/wp-content/uploads/2023/03/0dfb1c434bdf9686dda015ebaeaf6687.pdf\" target=\"_blank\" rel=\"noopener\">ワークライフバランス実現行動計画</a></p>\n</td>\r\n      </tr>\r\n      \r\n            \r\n      <tr>\r\n      <th>女性活躍に関する情報公開</th>\r\n      <td><p><a href=\"https://www.marutafoods.co.jp/wp/wp-content/uploads/2022/03/f3aeb802abb335865c366a04e1584c14.pdf\">女性活躍に関する情報公開</a></p>\n</td>\r\n      </tr>\r\n      \r\n            \r\n      <tr>\r\n      <th>スギヨグループ人権方針</th>\r\n      <td><p><span style=\"font-size: 14pt;\"><strong>スギヨグループ人権方針<br />\n</strong></span>スギヨグループは、「日本の伝統的食文化と先進技術を融合して豊かな食を創造し、世界の人々の安全な生活の実現と健康の増進に貢献する」ことを企業理念に掲げ、持続的な成長と中長期的な企業価値向上のために自律的な対応を図ってきました。</p>\n<p>その企業活動の基本姿勢として「すべての人間の尊厳と権利を尊重すること」は重要な社会的責任と認識し、ここに「スギヨグループ人権方針」を定めました。</p>\n<p><strong>＜「スギヨグループ人権方針」について詳しくはこちら＞<br />\n</strong><span style=\"color: #0000ff;\"><a style=\"color: #0000ff;\" href=\"https://www.marutafoods.co.jp/wp/wp-content/uploads/2019/12/2905c647c9b06ec0dffb67d5d0ef8c6b.pdf\">スギヨグループ人権方針</a></span><strong><br />\n</strong></p>\n</td>\r\n      </tr>\r\n      \r\n            \r\n      <tr>\r\n      <th>マルタスギヨ　　　環境方針</th>\r\n      <td><p><a href=\"https://www.marutafoods.co.jp/wp/wp-content/uploads/2022/09/a8c504994ffe1083e56c59dbb2a0818b-1.pdf\">マルタスギヨ株式会社環境方針</a></p>\n</td>\r\n      </tr>\r\n      \r\n      </table>\r\n      </div>\r\n\r\n<!-- /コンテンツ ==================================== -->\r\n      </div>\r\n      \r\n        <style>\r\n  .products_wrap_left. .products_left_cat_link .cat-item- a{background: #f5dfe1;}\r\n  </style>\r\n      \r\n      <div class=\"products_wrap_left \">\r\n<ul id=\"links01\" class=\"products_left_cat_link\"> \r\n<li class=\"page_item page-item-106\"><a href=\"https://www.marutafoods.co.jp/company/\">ごあいさつ</a></li>\n<li class=\"page_item page-item-87 current_page_item\"><a href=\"https://www.marutafoods.co.jp/gaiyou/\" aria-current=\"page\">会社概要</a></li>\n<li class=\"page_item page-item-100\"><a href=\"https://www.marutafoods.co.jp/location/\">所在地</a></li>\n</ul>\r\n      </div>\r\n    </div>\r\n</section>\r\n\r\n<!--フッター-->\r\n<footer>\n  <div class=\"footer_black_section\">\n    <div class=\"w1060 footer_black_wrap\">\n      <div>\n        <p><a href=\"/\">HOME</a></p>\n        <p><a href=\"/kodawari/\">マルタスギヨのこだわり</a></p>\n      </div>\n      \n      <div>\n        <p class=\"foot_open_key\"><a href=\"/products/\" class=\"pc_only\">商品紹介</a><a class=\"pc_none\">商品紹介</a></p>\n        <ul class=\"foot_open_list\">\n          \t<li class=\"cat-item cat-item-2 cat-item-items_1\"><a href=\"https://www.marutafoods.co.jp/products_cat/items_1/\">山海漬・松前漬・数の子シリーズ</a>\n</li>\n\t<li class=\"cat-item cat-item-13 cat-item-items_2\"><a href=\"https://www.marutafoods.co.jp/products_cat/items_2/\">酢漬シリーズ</a>\n</li>\n\t<li class=\"cat-item cat-item-35 cat-item-items_3\"><a href=\"https://www.marutafoods.co.jp/products_cat/items_3/\">珍味シリーズ</a>\n</li>\n\t<li class=\"cat-item cat-item-40 cat-item-items_4\"><a href=\"https://www.marutafoods.co.jp/produ