- End Google Tag Manager (noscript) -->\r\n<!-- ヘッダー -->\n<header class=\"clearfix pos-rel\">\n<div class=\"header row\">\n<div class=\"pos-rel clearfix\">\n<!-- ロゴ -->\n<div class=\"logo\">\n<h1><a href=\"/\"><img src=\"/img/logo.png\" alt=\"株式会社 MCエバテック\"></a></h1>\n</div>\n\n<div class=\"btnMenu none sm-show\">\n<a href=\"#\"><img src=\"/img/btnMenu.png\" alt=\"メニュー\"></a>\n</div>\n\n<!-- ヘッダコンテンツ -->\n<div class=\"headerContents clearfix\">\n<!-- サブメニュー -->\n<div class=\"navSub clearfix\">\n<div class=\"searchFormInput pos-rel clearfix mt0\">\n<script>\n(function() {\nvar cx = '009216501880610831661:hccxu59mxxm';\nvar gcse = document.createElement('script');\ngcse.type = 'text/javascript';\ngcse.async = true;\ngcse.src = (document.location.protocol == 'https:' ? 'https:' : 'http:') +\n'//www.google.com/cse/cse.js?cx=' + cx;\nvar s = document.getElementsByTagName('script')[0];\ns.parentNode.insertBefore(gcse, s);\n})();\n</script>\n<gcse:search></gcse:search>\n</div>\n<nav class=\" clearfix mt5\">\n<ul class=\"horizon\">\n\t<li><a href=\"/sitemap/\">＞ サイトマップ</a></li>\n\t<li class=\"other\"><a href=\"/english/\">＞ English</a></li>\n</ul>\n</nav>\n</div>\n\n<!-- そのたコンテンツ -->\n<div class=\"searchForm clearfix\">\n\n<div class=\"searchFormBanner clearfix\">\n<ul class=\"horizon\">\n\t<!--<li><a href=\"https://www.mitsubishichem-hd.co.jp/\" target=\"_blank\"><img src=\"/img/banner/header/mitsubishichem.png\" alt=\"三菱ケミカルホールディングス\"></a></li>-->\n\t<li><a href=\"https://www.tkcc.co.jp/\" target=\"_blank\"><img src=\"/img/banner/header/kansainestukagaku.png\" alt=\"関西熱化学グループ\"></a></li>\n\t<li><a href=\"https://www.kobelco.co.jp/\" target=\"_blank\"><img src=\"/img/banner/header/kobelco.png\" alt=\"KOBELCO\"></a></li>\n\t<!--<li><a href=\"http://www.mitsubishi.com/j\" target=\"_blank\"><img src=\"/img/banner/header/mitsubishi.com.png\" alt=\"三菱グループ\"></a></li>-->\n</ul>\n</div>\n</div>\n</div>\n</div>\n</div>\r\n<!-- グローバルメニュー -->\r\n<div class=\"navGlobal sm-none clearfix\">\r\n<div class=\"row\">\r\n<nav>\r\n<ul class=\"horizon\">\r\n<li><a href=\"/service/\">製品・サービス</a></li>\r\n<li><a href=\"/company/profile.html\">企業情報</a></li>\r\n<li><a href=\"/csr/\">CSR活動</a></li>\r\n<li><a href=\"/recruit/\">採用情報</a></li>\r\n<li><a href=\"/contact/\"  class=\"inquiry\"><span>お問い合わせ</span></a></li>\r\n</ul>\r\n</nav>\r\n</div>\r\n</div>\r\n</header><!-- コンテンツ -->\r\n        <main class=\"clearfix\">\r\n            <!-- コンテンツヘッダー -->\r\n            <div class=\"contentsHeader\">\r\n                <div class=\"row\">\r\n                    <div class=\"mainVisual hiddenImage\">\r\n                    </div>\r\n                    <div class=\"breadcrumb sm-none\">\r\n                        <ul class=\"horizon\">\r\n                            <li><a href=\"/index.html\">HOME</a></li>\r\n                            <li>＞</li>\r\n                            <li><a href=\"#\">ごあいさつ</a></li>\r\n                        </ul>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n                \r\n            <!-- コンテンツ内容 -->\r\n            <div class=\"row clearfix\">\r\n                <div class=\"contentsHeader2 mb40 clearfix\">\r\n                    <h2 class=\"h-level2\">ごあいさつ</h2>\r\n                </div>\r\n                <div class=\"rightContents mb100\">\r\n                    <!-- ▼▼▼▼ コンテンツ ▼▼▼▼ -->\r\n                    <h3 class=\"h-level3-1 c0\">ごあいさつ</h3>\r\n                    <div class=\"mb30 clearfix pos-rel\">\r\n                        <div class=\"col-6 pr20 col-sm-12 sm-pr0 sm-tc sm-mb20\">\r\n                      </div>\r\n                        <div class=\"col-6 col-margin-6 pl20 pos-abs col-sm-12 sm-pl0 col-sm-margin-0 sm-pos-rel sm-tc\" style=\"bottom:0px;\">\r\n                            <!--<img src=\"/company/img/message_image_02.jpg\" alt=\"株式会社MCエバテック 取締役社長 水野 隆\">-->\r\n                        </div>\r\n                    </div>\r\n                        \r\n                    <div class=\"content_text mb40 clearfix text_end\">　株式会社MCエバテックのホームページにお立ち寄りいただき、誠にありがとうございます。<br>\r\n<br>\r\n　当社は、2011年10月1日に関西熱化学（株）100％出資会社であった、ケイエヌエンタープライズ（株）、（株）ケイエヌラボアナリシス、カーボンテック（株）の3社合併により、（株）MCエバテックとして発足いたしました。その後、2013年10月に（株）三菱化学アナリテックの分析部門を譲受け、2020年10月に（株）大阪環境技術センターを吸収合併、ニチゴー九州（株）の分析事業を<strong id=\"docs-internal-guid-c126fe9f-7fff-b4d4-c467-b51adb75c186\">吸収分割</strong><strong id=\"docs-internal-guid-ae4a66d9-7fff-3e6e-8051-83b8b57c6c8f\">により承継する等し</strong>、分析事業の強化を行いました。<br>\r\n<br>\r\n　炭素材（活性炭）、分析、精密洗浄および住生活に関わるサービスといった幅広い事業分野で、市場動向、産業構造や生活環境の変化に敏感に反応し、ニーズを見極め、柔軟で迅速な対応を心掛け、お客様に対し新たな価値の提供に努めて参ります。<br>\r\n<br>\r\n　また、企業活動の基盤となる安全とコンプライアンスを徹底し、信頼される製品・サービスを提供することで、より魅力のある企業となることを目指して日々活動しています。<br>\r\n<br>\r\n　私どもの製品・サービスがお客様に満足いただけるよう、社員一同全力を尽くして参りますので、引き続き皆様のご指導とご支援をお願い申し上げます。<br>\r\n<br>\r\n<p class=\"bordered p20\">\t\t\t\t\t\t\t\r\n　“「ＭＣエバテック（ＭＣ　Evolve Technologies Corporation）」に込めた想い”<br>\r\n関西熱化学グループ共通のシンボルマークに込められているキャッチフレーズ「Heart to Evolve（進化する心）」から「Evolve」、更なる技術の進化を目指して「Technologies」を社名に入れることで、お客様により満足いただける製品・サービスを提供するため、常に進化し、新たなフィールドへ挑戦し続けるという決意を表現しています。<br>\r\n</p>\r\n<p><br>\r\n</p>\r\n<p>&nbsp;</p>\r\n<p>&nbsp;</p>\r\n<p>&nbsp;</p>\r\n<br>\r\n<p class=\"tr mb20\">2026年6月19日</p>\r\n<p class=\"tr\"><img style=\"margin-bottom: 20px;\" src=\"img/message_image_08.jpg\" alt=\"株式会社ＭＣエバテック\" width=\"190\" height=\"43\"></p>\r\n<p class=\"tr mb20\">代表取締役社長　辻川　昌徳</p>\r\n </div>\r\n                        \r\n                    <!-- ▲▲▲▲ コンテンツ ▲▲▲▲ -->\r\n                </div>\r\n                <div class=\"leftContents\">\r\n\t\t\t\t    <h3 class=\"h-level3 mb10\">企業情報</h3>\r\n<div class=\"sideMenu clearfix\">\r\n<nav>\r\n<ul>\r\n<li class=\"sideMenuItem c0\">\r\n<a href=\"/company/message.html\">ごあいさつ</a>\r\n</li>\r\n<li class=\"sideMenuItem c0\">\r\n<a href=\"/company/profile.html\">企業情報</a>\r\n</li>\r\n<li class=\"sideMenuItem c0\">\r\n<a href=\"/company/iso.html\">ISO・品質管理</a>\r\n</li>\r\n<li class=\"sideMenuItem c0\">\r\n<a href=\"/company/access.html\">アクセスマップ</a>\r\n</li>\r\n</ul>\r\n</nav>\r\n</div>\t\t\t\t\t<div class=\"sideMenu2 clearfix\">\r\n<nav>\r\n<ul>\r\n<li class=\"sideMenuItem2 service\">\r\n<a href=\"/service/index.html\">製品サービス</a>\r\n</li>\r\n<li class=\"sideMenuItem2 company\">\r\n<a href=\"/company/index.html\">企業情報</a>\r\n</li>\r\n<li class=\"sideMenuItem2 csr\">\r\n<a href=\"/csr/index.html\">CSR活動</a>\r\n</li>\r\n<li class=\"sideMenuItem2 recruit\">\r\n<a href=\"/recruit/index.html\">採用情報</a>\r\n</li>\r\n</ul>\r\n</nav>\r\n</div><div>\r\n<!--<div class=\"col-12 col-sm-6 sm-pr20 banner left\">\r\n<a href=\"https://www.mitsubishichem-hd.co.jp/\" target=\"_blank\"><img src=\"/img/banner/side/banner_05.png\" alt=\"三菱ケミカルホールディングス\"></a>\r\n</div>-->\r\n<div class=\"col-12 col-sm-6 sm-pl20 banner right mb40 sm-mb0\">\r\n<a href=\"https://www.tkcc.co.jp/\" target=\"_blank\"><img src=\"/img/banner/side/banner_04.png\" alt=\"関西熱化学株式会社\"></a>\r\n</div>\r\n<div class=\"col-12 col-sm-6 sm-pr20 banner left\">\r\n<a href=\"/english/\"><img src=\"/img/banner/side/banner_02.png\" alt=\"English版\"></a>\r\n</div>\r\n<div class=\"col-12 col-sm-6 sm-pl20 banner right\">\r\n<a href=\"/service/amenity/koubusou.html\"><img src=\"/img/banner/side/banner_01.png\" alt=\"割烹 甲武荘\"></a>\r\n</div>\r\n</div>\r\n\t\t\t\t</div>\r\n            </div>\r\n        </main>\r\n    <!-- フッター -->\r\n<footer class=\"clearfix\">\r\n                <div class=\"sitemap_new clearfix\">\r\n                    <div class=\"row pos-rel\">\r\n                        <ul class=\"clearfix\">\r\n                        <li><a href=\"/\">HOME</a></li>\r\n\t\t\t\t\t\t<li><a href=\"/company/profile.html\">企業情報</a>\r\n\t\t\t\t\t\t\t<ul>\r\n\t\t\t\t\t\t\t<li><a href=\"/company/message.html\">ごあいさつ</a></li>\r\n\t\t\t\t\t\t\t<li><a href=\"/company/profile.html\">企業情報</a></li>\r\n\t\t\t\t\t\t\t<li><a href=\"/company/iso.html\">ISO・品質管理への取り組み</a></li>\r\n\t\t\t\t\t\t\t<li><a href=\"/company/access.html\">アクセスマップ</a></li>\r\n\t\t\t\t\t\t\t</ul