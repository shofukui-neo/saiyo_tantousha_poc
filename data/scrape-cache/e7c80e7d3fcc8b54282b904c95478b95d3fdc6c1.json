{"url":"https://job.hari-match.com/member/register/","html":"<!DOCTYPE html>\r\n<html lang=\"ja\">\r\n<head>\r\n<meta charset=\"utf-8\">\r\n<title>兵庫県の新卒学生向け就職サイト｜はりまっち｜利用規約</title>\r\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1.0,maximum-scale=1.0,user-scalable=no\">\r\n<!-- favicon -->\r\n<link rel=\"icon\" href=\"/icon/favicon.ico\" />\r\n\r\n<meta name=\"description\" content=\"\" />\r\n<meta name=\"keywords\" content=\"\" />\r\n<link rel=\"canonical\" href=\"https://job.hari-match.com/member/register/\" />\r\n<!-- ogp -->\r\n<meta property=\"og:type\" content=\"website\">\r\n<meta property=\"og:title\" content=\"利用規約\">\r\n<meta property=\"og:description\" content=\"\">\r\n<meta property=\"og:image\" content=\"https://job.hari-match.com/assets/img/common/img_logo_line.png\">\r\n<meta property=\"og:url\" content=\"https://job.hari-match.com/member/register/agree.php\">\r\n<meta property=\"og:site_name\" content=\"はりまっち\">\r\n\r\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/assets/css/top.css?ver=260605\">\r\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/assets/css/form.css?ver=260605\">\r\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/assets/css/mypage.css?ver=260605\">\r\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/assets/css/modaal.css?ver=260605\">\r\n\r\n<link href=\"/vendors/bootstrap/dist/css/bootstrap.min.css\" rel=\"stylesheet\" />\r\n<script src=\"/vendors/jquery/3.6.0/jquery.min.js\"></script>\r\n<script src=\"/vendors/jquery/dist/jquery.validate.min.js\" defer></script>\r\n<script src=\"/vendors/bootstrap/dist/js/bootstrap.bundle.min.js\" defer></script>\r\n\r\n<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\r\n<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\r\n<link href=\"https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;700&display=swap\" rel=\"stylesheet\">\r\n<script src=\"/assets/js/jquery.min.js\"></script>\r\n<script src=\"/assets/js/modaal.mi