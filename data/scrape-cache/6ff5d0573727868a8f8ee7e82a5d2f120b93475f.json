-webkit-box-align: start;\r\n\t-ms-flex-align: start;\r\n\talign-items: flex-start;\r\n\t-ms-flex-line-pack: start;\r\n\talign-content: flex-start;\r\n\tposition: relative;\r\n\tmargin: 0px;\r\n\tpadding: 0px;\r\n}\r\n\r\n\r\n.formgroupcell\r\n{\r\n\tdisplay: block;\r\n\tposition: relative;\r\n\tmargin: 0px;\r\n\tpadding: 0px;\r\n}\r\n\r\n\r\n#fgc01_01_01\r\n{\r\n\tdisplay: block;\r\n\twidth: 494px;\r\n}\r\n\r\n\r\n#fgc01_01_02\r\n{\r\n\twidth: 340px;\r\n\tmargin-left: 33px;\r\n}\r\n\r\n\r\n#fgc01_02_01\r\n{\r\n\twidth: 100%;\r\n}\r\n\r\n\r\n.fttr\r\n{\r\n\tdisplay: -webkit-box;\r\n\tdisplay: -ms-flexbox;\r\n\tdisplay: flex;\r\n\t-ms-flex-wrap: wrap;\r\n\tflex-wrap: wrap;\r\n\t-webkit-box-pack: start;\r\n\t-ms-flex-pack: start;\r\n\tjustify-content: flex-start;\r\n\t-webkit-box-align: start;\r\n\t-ms-flex-align: start;\r\n\talign-items: flex-start;\r\n\t-ms-flex-line-pack: start;\r\n\talign-content: flex-start;\r\n\tposition: relative;\r\n\twidth: 100%;\r\n\tmargin: 14px 0px 0px 0px;\r\n\tpadding: 0px;\r\n}\r\n\r\n\r\n.cellname, .cellvalue\r\n{\r\n\tdisplay: block;\r\n\tposition: relative;\r\n\tmargin: 0px;\r\n\tpadding: 0px;\r\n\tfont-size: 16px;\r\n\tfont-weight: 500;\r\n\tline-height: 24px;\r\n\ttext-align: left;\r\n\tvertical-align: top;\r\n}\r\n\r\n\r\n.cellname\r\n{\r\n\twidth: 134px;\r\n\tmargin: 0px;\r\n\tpadding: 8px 0px 0px 0px;\r\n}\r\n\r\n\r\n.cellvalue\r\n{\r\n\twidth: calc( 100% - 134px );\r\n\tmargin: 0px;\r\n\tpadding: 0px;\r\n}\r\n\r\n\r\n.fttr.pcfttr .cellname { width: 92px; }\r\n.fttr.pcfttr .cellvalue { width: calc( 100% - 92px ); }\r\n\r\n\r\n.fttr.kmfttr .cellname { width: 124px; }\r\n.fttr.kmfttr .cellvalue { width: calc( 100% - 124px ); }\r\n\r\n\r\n.kmfttr .cellvalue label\r\n{\r\n\tdisplay: block;\r\n\tposition: relative;\r\n\tmargin: 8px 0px 8px 0px;\r\n\tcursor: pointer;\r\n}\r\n\r\n\r\n.attent\r\n{\r\n\tdisplay: block;\r\n\tposition: relative;\r\n\tmargin: 24px 0px 0px 0px;\r\n\tpadding-left: 1em;\r\n\tfont-size: 14px;\r\n\tfont-weight: 500;\r\n\tline-height: 20px;\r\n\ttext-indent: -1em;\r\n\ttext-align: left;\r\n\tvertical-align: top;\r\n}\r\n\r\n\r\n.midvalue\r\n{\r\n\twidth: calc( 100% - 14px - 14px );\r\n}\r\n\r\n\r\n.longvalue\r\n{\r\n\twidth: calc( 100% - 14px - 14px );\r\n}\r\n\r\n\r\n.formbtnbox\r\n{\r\n\tdisplay: block;\r\n\tposition: relative;\r\n\tmargin: 62px auto 0px auto;\r\n\ttext-align: center;\r\n}\r\n\r\n\r\n#sendbtn\r\n{\r\n\tdisplay: block;\r\n\tposition: relative;\r\n\tmargin: 0px auto 0px auto;\r\n\twidth: 294px;\r\n\theight: 73px;\r\n\tfont-size: 22px;\r\n\tfont-weight: 500;\r\n\tline-height: 73px;\r\n\ttext-decoration: none;\r\n\ttext-align: center;\r\n\tvertical-align: top;\r\n\tcolor: #FFFFFF;\r\n\tbackground-color: #5D8DC9;\r\n\tborder-radius: 10px;\r\n\tcursor: pointer;\r\n\ttransition-duration: 150ms;\r\n}\r\n\r\n\r\n#sendbtn:hover\r\n{\r\n\tbackground-color: #1E5AA0;\r\n}\r\n\r\n\r\n.formcom02\r\n{\r\n\tdisplay: block;\r\n\tposition: relative;\r\n\twidth: 380px;\r\n\tmargin: 0px auto 0px auto;\r\n\tfont-size: 15px;\r\n\tfont-weight: 500;\r\n\tline-height: 1.6em;\r\n\ttext-align: left;\r\n\tvertical-align: top;\r\n}\r\n\r\n\r\n</style>\r\n<link rel=\"stylesheet\" type=\"text/css\" href=\"css/common_mb.css\">\r\n<link rel=\"stylesheet\" type=\"text/css\" href=\"css/subcommon_mb.css\">\r\n<style type=\"text/css\">\r\n\r\n\r\n\r\n@media ( max-width: 1280px )\r\n{\r\n\t#formbase\r\n\t{\r\n\t\twidth: 1124px;\r\n\t}\r\n}\r\n\r\n\r\n\r\n@media ( max-width: 640px )\r\n{\r\n\t#formbase\r\n\t{\r\n\t\twidth: 100%;\r\n\t}\r\n\t\r\n\t\r\n\t.formbox\r\n\t{\r\n\t\twidth: 420px;\r\n\t}\r\n\t\r\n\t\r\n\t.formgroup\r\n\t{\r\n\t\tdisplay: block;\r\n\t}\r\n\t\r\n\t\r\n\t#fgc01_01_01\r\n\t{\r\n\t\twidth: 100%;\r\n\t}\r\n\t\r\n\t\r\n\t#fgc01_01_02\r\n\t{\r\n\t\twidth: 100%;\r\n\t\tmargin-left: 0px;\r\n\t}\r\n\t\r\n\t\r\n\t.fttr.pcfttr .cellname, .fttr.kmfttr .cellname { width: 134px; }\r\n\t.fttr.pcfttr .cellvalue, .fttr.kmfttr .cellvalue { width: calc( 100% - 134px ); }\r\n\t\r\n\t\r\n\t.attent\r\n\t{\r\n\t\tmargin: 0px 0px 8px 134px;\r\n\t}\r\n}\r\n\r\n\r\n\r\n\r\n</style>\r\n<script type=\"text/javascript\" charset=\"utf-8\">\r\n\r\n\r\nvar\tgCGIURL = './inquiry/contactmail.php';\r\n\r\n\r\nfunction SendContact()\r\n{\r\n\tvar\ttheParams = new FormData( $( '#form01' )[ 0 ] );\r\n\t\r\n\t$.ajax(\r\n\t\t{\r\n\t\t\ttype: 'POST',\r\n\t\t\turl: gCGIURL,\r\n\t\t\tcontentType: false,\r\n\t\t\tprocessData: false,\r\n\t\t\tdata: theParams,\r\n\t\t\tdataType: 'json',\r\n\t\t\tsuccess: GetSendContactResult\r\n\t\t} );\r\n}\r\n\r\n\r\nfunction GetSendContactResult( pReturnValue )\r\n{\r\n\tif ( pReturnValue.status == 'error' )\r\n\t{\r\n\t\tShowErrorMessage( pReturnValue.errormessage );\r\n\t\treturn;\r\n\t}\r\n\t\r\n\tShowThanks();\r\n}\r\n\r\n\r\nfunction FormTop()\r\n{\r\n\tvar\tthePos = $( '#formtop' ).offset().top;\r\n\t\r\n\t$( 'html,body' ).scrollTop( thePos );\r\n}\r\n\r\n\r\nfunction ShowForm()\r\n{\r\n\t$( '#formbox03' ).css( 'display', 'none' );\r\n\t$( '#formbox01' ).css( 'display', 'block' );\r\n\t\r\n\tFormTop();\r\n}\r\n\r\n\r\nfunction ShowThanks()\r\n{\r\n\t$( '#formbox01' ).css( 'display', 'none' );\r\n\t$( '#formbox03' ).css( 'display', 'block' );\r\n\t\r\n\tFormTop();\r\n}\r\n\r\n\r\nfunction ShowErrorMessage( pMessage )\r\n{\r\n\tvar\ttheMessage = '<span style=\"color: #FF0000; font-weight: bold;\">' + pMessage.replace( /\\n/g, '<br>' );\r\n\t\r\n\tShowDialog( 'エラー', theMessage, kButtonOK, function(){} );\r\n}\r\n\r\n\r\nfunction CheckForm01()\r\n{\r\n\tvar\ttheFInfoList = [\r\n\t\t\t{ 'fname': 'companyname', 'jname': '会社名' },\r\n\t\t\t{ 'fname': 'chargename', 'jname': 'ご担当者名' },\r\n\t\t\t{ 'fname': 'email1', 'jname': 'メールアドレス' },\r\n\t\t\t{ 'fname': 'postalcode', 'jname': '郵便番号' },\r\n\t\t\t{ 'fname': 'koumoku[]', 'jname': 'お問合せ項目' },\r\n\t\t\t{ 'fname': 'inqcont', 'jname': '内容' }\r\n\t\t];\r\n\t\r\n\tvar\ttheErrorText = '';\r\n\tvar\tx;\r\n\tvar\ttheMax = theFInfoList.length;\r\n\t\r\n\tvar\ttheRegAS = /\\[\\]$/;\r\n\t\r\n\tfor ( x = 0; x < theMax; x++ )\r\n\t{\r\n\t\tvar\ttheItem = theFInfoList[ x ];\r\n\t\t\r\n\t\tif ( theItem.fname.match( theRegAS ) )\r\n\t\t{\r\n\t\t\tvar\ttheValues = [];\r\n\t\t\t\r\n\t\t\t$( 'input[name=\\'' + theItem.fname + '\\']:checked' ).each( function( pIndex ){\r\n\t\t\t\t\ttheValues.push( $( this ).val() );\r\n\t\t\t\t} );\r\n\t\t\t\r\n\t\t\tif ( theValues.length < 1 )\r\n\t\t\t{\r\n\t\t\t\ttheErrorText += theItem.jname + 'が選択されていません。' + \"\\n\";\r\n\t\t\t}\r\n\t\t}\r\n\t\telse\r\n\t\t{\r\n\t\t\tvar\ttheID = theItem.fname + 'f';\r\n\t\t\tvar\ttheValue = $( '#' + theID ).val();\r\n\t\t\tif ( theValue == '' )\r\n\t\t\t{\r\n\t\t\t\ttheErrorText += theItem.jname + 'が入力されていません。' + \"\\n\";\r\n\t\t\t}\r\n\t\t\telse if ( theItem.fname == 'email1' )\r\n\t\t\t{\r\n\t\t\t\tif ( MailAddrCheck( theValue ) != true )\r\n\t\t\t\t{\r\n\t\t\t\t\ttheErrorText += theItem.jname + 'が正しく入力されていません。' + \"\\n\";\r\n\t\t\t\t}\r\n\t\t\t}\r\n\t\t}\r\n\t}\r\n\t\r\n\tif ( theErrorText != '' )\r\n\t{\r\n\t\talert( theErrorText );\r\n\t\t\r\n\t\treturn false;\r\n\t}\r\n\t\r\n\treturn true;\r\n}\r\n\r\n\r\nfunction MailAddrCheck( pValue )\r\n{\r\n    var theMailRegex1 = new RegExp( '(?:[-!#-\\'*+/-9=?A-Z^-~]+\\.?(?:\\.[-!#-\\'*+/-9=?A-Z^-~]+)*|\"(?:[!#-\\[\\]-~]|\\\\\\\\[\\x09 -~])*\")@[-!#-\\'*+/-9=?A-Z^-~]+(?:\\.[-!#-\\'*+/-9=?A-Z^-~]+)*' );\r\n    var theMailRegex2 = new RegExp( '^[^\\@]+\\@[^\\@]+$' );\r\n    \r\n    if ( pValue.match( theMailRegex1 ) && pValue.match( theMailRegex2 ) )\r\n    {\r\n        if( pValue.match( /[^a-zA-Z0-9\\!\\\"\\#\\$\\%\\&\\'\\(\\)\\=\\~\\|\\-\\^\\\\\\@\\[\\;\\:\\]\\,\\.\\/\\\\\\<\\>\\?\\_\\`\\{\\+\\*\\} ]/ ) )\r\n        {\r\n        \treturn false;\r\n        }\r\n        \r\n        if( !pValue.match( /\\.[a-z]+$/ ) )\r\n        {\r\n        \treturn false;\r\n        }\r\n        \r\n        return true;\r\n    }\r\n    \r\n    return false;\r\n}\r\n\r\n\r\n\r\n\r\n$(function() {\r\n\t$( '#sendbtn' ).click( function(){\r\n\t\t\t$( '#form01' ).submit();\r\n\t\t} );\r\n\t\r\n\t$( '#form01' ).submit( function(){\r\n\t\t\tif ( CheckForm01() != true )\r\n\t\t\t{\r\n\t\t\t\treturn false;\r\n\t\t\t}\r\n\t\t\t\r\n\t\t\t//ConfirmContact();\r\n\t\t\tSendContact();\r\n\t\t\treturn false;\r\n\t\t} );\r\n});\r\n\r\n\r\n</script>\r\n<script type=\"text/javascript\" charset=\"utf-8\" src=\"js/postcommon.js\"></script>\r\n<script type=\"text/javascript\" charset=\"utf-8\" src=\"js/postsubcommon.js\"></script>\r\n<!-- WebAnalysis --><script src=\"/mode2_piwik/wa.js\"></script><noscript><img src=\"/mode2_piwik/piwik.php?idsite=1\" style=\"border:0;\"></noscript><!-- End WebAnalysis --></head>\r\n<body>\r\n\r\n\r\n\r\n\r\n\r\n\r\n<div id=\"bodybox\">\r\n  <div id=\"headerbase\">\r\n    <header>\r\n      <div id=\"obione\">\r\n        \r\n        <a id=\"headlogo01\" href=\"./\">\r\n          <h1 class=\"logo01\"><img src=\"images/common/logo01.svg?rev=2\" alt=\"株式会社 GSタカハシ\"></h1>\r\n          <p class=\"cne\"><span>GS</span> TAKAHASHI</p>\r\n        </a>\r\n        \r\n        <div id=\"menubox\">\r\n          <ul id=\"menucont\">\r\n            <li><a href=\"outline.html\"><p class=\"mtj\">会社概要</p><p class=\"mte\"><span>O</span>UTLINE</p></a></li>\r\n            <li><a href=\"airwash.html\"><p class=\"mtj\"><span class=\"cd01\">エアウォッシュとは</span></p><p class=\"mte\"><span>A</span>IR WASH</p></a></li>\r\n            <li><a href=\"original.html\"><p class=\"mtj\">オリジナル商品</p><p class=\"mte\"><span>O</span>RIGINAL <span>P</span>RODUCTS</p></a></li>\r\n            <li><a href=\"handled.html\"><p class=\"mtj\">取扱メーカー</p><p class=\"mte\"><span>P</span>RODUCTS <span>H</span>ANDLED</p></a></li>\r\n            <li><a href=\"sdgs.html\"><p class=\"mtj\">SDGs</p><p class=\"mte\"><span>SDGs</span></p></a></li>\r\n            <li><a href=\"recruit.html\"><p class=\"mtj\">採用情報</p><p class=\"mte\"><span>R</span>ECRUIT</p></a></li>\r\n          </ul> <!-- /#menucont -->\r\n        </div> <!-- /#menubox -->\r\n        \r\n        <div id=\"headtoibox\">\r\n 