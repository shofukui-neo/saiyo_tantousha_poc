late(-25.427 -1.414)\" fill=\"none\" stroke=\"#415567\" stroke-miterlimit=\"10\" stroke-width=\"3\"/> </g> </g> </svg> </a> <a href=\"https://yamauchi-doboku.jp/wp-content/themes/yamauchi-doboku/assets/images/pdf/中途採用-求人-技術者.pdf\" class=\"card_link-btn fadeIn\" target=\"_blank\" rel=\"noopener noreferrer\"> <span>技術者</span> <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"76\" height=\"33\" viewBox=\"0 0 76 33\"> <g id=\"グループ_229\" data-name=\"グループ 229\" transform=\"translate(-1464 -14118)\"> <path id=\"パス_960\" data-name=\"パス 960\" d=\"M-25.593-20.3c-.493,0-.7.2-.7.7V-.7c0,.493.2.7.7.7h2.639c.493,0,.725-.2.725-.7V-5.655c0-.261.116-.377.377-.377h2.291c5.771,0,8.845-2.523,8.845-7.25,0-4.669-2.871-7.018-8.613-7.018Zm10.672,7.076c0,2.32-1.624,3.422-4.611,3.422h-2.32c-.261,0-.377-.116-.377-.377v-5.974c0-.261.116-.377.377-.377h2.32C-16.486-16.53-14.921-15.544-14.921-13.224ZM-6.684-20.3c-.493,0-.7.2-.7.7V-.7c0,.493.2.7.7.7H-.507C6.684,0,10.976-4.06,10.976-10.382c0-6-4.118-9.918-11.02-9.918ZM6.771-10.237c0,4-2.61,6.467-7.279,6.467H-2.944c-.261,0-.377-.116-.377-.377V-16.153c0-.261.116-.377.377-.377H-.391C4.161-16.53,6.771-14.094,6.771-10.237ZM15.211-20.3c-.493,0-.7.2-.7.7V-.7c0,.493.2.7.7.7H17.85c.493,0,.725-.2.725-.7v-6.67c0-.261.116-.377.377-.377H25.97c.493,0,.725-.2.725-.7v-2.349c0-.551-.174-.725-.725-.725H18.951c-.261,0-.377-.116-.377-.377v-4.263c0-.261.116-.377.377-.377h8c.551,0,.725-.2.725-.7V-19.6c0-.493-.232-.7-.725-.7Z\" transform=\"translate(1501.304 14144.65)\" fill=\"#415567\"/> <g id=\"長方形_337\" data-name=\"長方形 337\" transform=\"translate(1464 14118)\" fill=\"none\" stroke=\"#415567\" stroke-width=\"3\"> <rect width=\"76\" height=\"33\" stroke=\"none\"/> <rect x=\"1.5\" y=\"1.5\" width=\"73\" height=\"30\" fill=\"none\"/> </g> </g> </svg> <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"41.453\" height=\"29.934\" viewBox=\"0 0 41.453 29.934\"> <g id=\"グループ_246\" data-name=\"グループ 246\" transform=\"translate(0 1.061)\"> <g id=\"グループ_64\" data-name=\"グループ 64\"> 