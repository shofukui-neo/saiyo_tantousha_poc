m/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js?ver=3.12.2\" id=\"scroll-trigger-js\"></script> </head><body class=\"wp-singular page-template-default page page-id-210 page-parent wp-theme-yamauchi-doboku recruit\" ontouchstart=\"\"><div class=\"side_cta\"> <a class=\"side_cta_btn side_cta_youtube\" href=\"https://www.youtube.com/@yamauchidoboku\" target=\"_blank\" rel=\"noopener noreferrer\"> 公式YouTube </a> <a class=\"side_cta_btn side_cta_contact\" href=\"https://yamauchi-doboku.jp/contact/\"> お問い合わせ </a></div><div id=\"page\" class=\"site\"><header id=\"masthead\" class=\"site-header\" role=\"banner\"><div class=\"site-header-main\"><div class=\"site-branding\"><p class=\"site-title link\"> <a class=\"site-branding_logo\" href=\"https://yamauchi-doboku.jp/\" rel=\"home\"> <picture> <source srcset=\"https://yamauchi-doboku.jp/wp-content/themes/yamauchi-doboku/assets/images/header_logo.svg\" media=\"(max-width:768px)\"> <img src=\"https://yamauchi-doboku.jp/wp-content/themes/yamauchi-doboku/assets/images/header_logo.svg\" alt=\"ヘッダーロゴ\"> </picture> </a></p></div><nav id=\"nav\" class=\"navigation\"><ul class=\"navigation_link\"><li class=\"navigation_link_item\"><a href=\"https://yamauchi-doboku.jp/company/\"><span>企業情報</span></a></li><li class=\"navigation_link_item\"><a href=\"https://yamauchi-doboku.jp/business/\"><span>事業内容</span></a></li><li class=\"navigation_link_item\"><a href=\"https://yamauchi-doboku.jp/works/\"><span>実績</span></a></li><li class=\"navigation_link_item\"><a href=\"https://yamauchi-doboku.jp/recruit/\"><span>採用情報</span></a></li><li class=\"navigation_link_item\"><a href=\"https://yamauchi-doboku.jp/anniv100th/\"><span>100年をつなぐ</span></a></li></ul></nav><div id=\"drawer_toggle\" class=\"smt_menu\"> <span></span> <span></span> <span></span></div><div class=\"smt_menu_box\"><ul class=\"smt_menu_link\"><li class=\"site-map_item\"><a href=\"https://yamauchi-doboku.jp/company/\">企業情報</a></li><li class=\"site-map_item\"><a href=\"https://yamauchi-doboku.jp/business/\">事業内容</a></li><li class=\"site-map_item\"><a href=\"https://yamauchi-doboku.jp/works/\">実績</a></li><li class=\"site-map_item\"><a href=\"https://yamauchi-doboku.jp/recruit/\">採用情報</a></li><li class=\"site-map_item\"><a href=\"https://yamauchi-doboku.jp/anniv100th/\">100年をつなぐ</a></li></ul><div class=\"smt_box_footer\"> <img src=\"https://yamauchi-doboku.jp/wp-content/themes/yamauchi-doboku/assets/images/100thanniv_logo.png\" alt=\"100周年ロゴ\"></div></div></div></header><div class=\"site-inner\"><div id=\"content\" class=\"site-content\"><div id=\"primary\" class=\"content-area\"><main id=\"main\" class=\"site-main\" role=\"main\"><div class=\"page_content recruit_content\"><div class=\"page_kv\"><h1 class=\"page_headline eng fadeIn\"> RECRUIT<div class=\"line-canvas-container\" aria-hidden=\"true\"></div></h1><div class=\"breadcrumb\"><a href=\"https://yamauchi-doboku.jp/\">TOP</a> ／ 採用情報</div></div><section><div class=\"section section01\"><div class=\"section_wrapper\"><div class=\"intro\"><h1 class=\"fadeIn\"> <span>採用メッセージ</span> <span class=\"eng\">Message</span></h1><div class=\"headline_img fadeIn\"> <picture class=\"fadeIn\"> <source srcset=\"https://yamauchi-doboku.jp/wp-content/themes/yamauchi-doboku/assets/images/recruit_img1.png\" media=\"(max-width:768px)\" /> <img src=\"https://yamauchi-doboku.jp/wp-content/themes/yamauchi-doboku/assets/images/recruit_img1.png\" alt=\"ひと創り　ものがたり。\" /> </picture></div><h2 class=\"fadeIn zen_old\">境界線を越えてゆく</h2><p class=\"fadeIn zen_old\"> “いいものを、人に、地域に”<br class=\"sm_only\" />というミッションを目指すうえで<br class=\"sm_only\" />欠かせないこと。<br /> それは「ひと創り」です。<br /> 様々な多様性を受け入れる時代<br class=\"sm_only\" />だからこそ、一人ひとりの個性を<br class=\"sm_only\" />より尊重する採用活動が<br class=\"sm_only\" />必要だと考えております。<br /><br /> 例えば、「できない」が<br class=\"sm_only\" />「できるようになる」、<br class=\"sm_only\" />「教えられる」から<br class=\"sm_only\" />「教える」という立場になる。<br /> どんなに小さな成長でも、<br class=\"sm_only\" />それが一人ひとりの<br class=\"sm_only\" />「ものがたり」になります。<br /><br /> 山内土木では、「ひと創り」という<br class=\"sm_only\" />ものがたりの中で<br class=\"sm_only\" />自分の可能性を拡げながら<br /> あらゆる境界線を越えて行く、<br class=\"sm_only\" />そんなあなたの挑戦を応援します。</p></div><div class=\"looking_for\"><div class=\"looking_for_bg\"><h1 class=\"fadeIn\">求める人物像</h1><p class=\"fadeIn\"> 山内土木では、拠点であるむつ市に対して情熱を持ち、変化に対して柔軟に対応できる方を歓迎します。<br /> また、チームで成し遂げる仕事であるため、その人らしさや“個性”を大切にしています。</p> <span class=\"bg_text eng\">IDEAL CANDIDATE PROFILE</span></div><div class=\"swiper looking_for_swiper\"><div class=\"swiper-wrapper cardlist\"><div class=\"card fadeIn swiper-slide\"><h2>情熱・前進<br /><span>タイプ</span></h2> <picture class=\"fadeIn\"> <source srcset=\"https://yamauchi-doboku.jp/wp-content/themes/yamauchi-doboku/assets/images/type1.png\" media=\"(max-width:768px)\" /> <img src=\"https://yamauchi-doboku.jp/wp-content/themes/yamauchi-doboku/assets/images/type1.png\" alt=\"指さし呼称をする現場作業員\" /> </picture><h3>こんな個性大歓迎</h3><p> ・とにかく返事が良いと褒められる<br /> ・身体を動かして成し遂げることが好き<br /> ・声をかけあって鼓舞し合う文化が好き</p></div><div class=\"card fadeIn swiper-slide\"><h2>寡黙・冷静沈着<br /><span>タイプ</span></h2> <picture class=\"fadeIn\"> <source srcset=\"https://yamauchi-doboku.jp/wp-content/themes/yamauchi-doboku/assets/images/type2.png\" media=\"(max-width:768px)\" /> <img src=\"https://yamauchi-doboku.jp/wp-content/themes/yamauchi-doboku/assets/images/type2.png\" alt=\"重機を操縦する現場作業員\" /> </picture><h3>こんな個性大歓迎</h3><p> ・口数は多くないが自分の意見がある<br /> ・コツコツと積み重ねていくことが得意<br /> ・専門性が高い分野に興味がある</p></div><div class=\"card fadeIn swiper-slide\"><h2>ユニーク・盛り上げ<br /><span>タイプ</span></h2> <picture class=\"fadeIn\"> <source srcset=\"https://yamauchi-doboku.jp/wp-content/themes/yamauchi-doboku/assets/images/type3.png\" media=\"(max-width:768px)\" /> <img src=\"https://yamauchi-doboku.jp/wp-content/themes/yamauchi-doboku/assets/images/type3.png\" alt=\"笑顔で手を挙げる現場作業員\" /> </picture><h3>こんな個性大歓迎</h3><p> ・ムードメーカーと呼ばれることが多い<br /> ・学生時代, 班長をたくさん経験してきた<br /> ・初対面の人ともすぐ仲良くなれる</p></div></div></div></div><div class=\"career\"><h1> <span>仕事内容と<br class=\"sm_only\" />キャリアステップ</span> <span class=\"eng\">Job Description<br class=\"sm_only\" /> & Career Plan</span></h1><p>入社後にお任せする業務について、<br class=\"sm_only\" />キャリアごとに大きく2つの<br class=\"sm_only\" />職種がございます。</p><div class=\"box\"><div class=\"box_item\"><h2> <span class=\"eng\">STEP1</span> <span>技能者</span></h2><p> 監督の指示のもと、工事に関わる作業を行います。<br /> 取得している資格によって、重機を動かす仕事など任される範囲が広がります。</p> <picture> <source srcset=\"https://yamauchi-doboku.jp/wp-content/themes/yamauchi-doboku/assets/images/career_step1.jpg\" media=\"(max-width:768px)\" /> <img src=\"https://yamauchi-doboku.jp/wp-content/themes/yamauchi-doboku/assets/images/career_step1.jpg\" alt=\"重機を操縦する現場作業員\" /> </picture></div><div class=\"box_item\"><h2> <span class=\"eng\">STEP2</span> <span>技術者</span></h2><p> 建設現場全体の指揮・管理を行います。工事の進行管理のほか、安全管理や品質管理、資材や人の手配など、業務内容は広範囲に及びます。</p> <picture> <source srcset=\"https://yamauchi-doboku.jp/wp-content/themes/yamauchi-doboku/assets/images/career_step2.jpg\" media=\"(max-width:768px)\" /> <img src=\"https://yamauchi-doboku.jp/wp-content/themes/yamauchi-doboku/assets/images/career_step2.jpg\" alt=\"路肩で作業をする現場作業員\" /> </picture></div><div class=\"box_item box_card\"><div class=\"box_card_header\"> <span class=\"somosomo\"> <span>そもそもの</span> <span class=\"eng\">Question</span> </span> <svg class=\"question-svg\" xmlns=\"http://www.w3.org/2000/svg\" width=\"270\" height=\"270\" viewBox=\"0 0 270 270\" fill=\"none\"> <g clip-path=\"url(#clip0_14_2)\"> <path class=\"mask-path\" opacity=\"0.401\" d=\"M52.1247 159.342C51.5247 198.864 81.6157 229.76 120.336 231.566L135.784 256.042C138.793 260.656 140.599 261.659 145.614 261.659H164.073C167.283 261.659 168.888 260.859 168.888 259.051C168.819 257.885 168.401 256.767 167.688 255.841L149.026 227.554C179.119 219.529 199.984 192.646 199.984 159.343C200.584 118.015 167.684 85.9161 125.754 86.5171C84.2247 85.9151 51.3227 118.014 52.1247 159.342ZM170.893 159.342C170.893 186.426 151.031 205.686 125.753 205.686C100.475 205.686 81.2147 186.426 81.2147 159.342C81.2147 131.857 100.475 112.597 125.753 112.597C151.232 112.598 170.893 131.857 170.893 159.342Z\" fill=\"#415567\"/> <path class=\"mask-path\" opacity=\"0.404\" d=\"M135.636 17.6719H115.636V67.7729H135.636V17.6719Z\" fill=\"#415567\"/> <path class=\"mask-path\" opacity=\"0.404\" d=\"M162.431 72.5245L179.924 82.2207L204.214 38.4005L186.721 28.7043L162.431 72.5245Z\" fill=\"#415567\"/> <path class=\"mask-path\" opacity=\"0.404\" d=\"M64.5586 28.7004L47.0586 38.4004L71.3576 82.2388L88.8576 72.5388L64.5586 28.7004Z\" fill=\"#415567\"/> <path id=\"trace-path-1\" class=\"trace-path\" d=\"M86 84L51 27\" stroke=\"#2795D9\" stroke-width=\"30\"/> <path id=\"trace-path-2\" class=\"trace-path\" d=\"M126 74.5V8\" stroke=\"#2795D9\" stroke-width=\"30\"/> <path id=\"trace-path-3\" class=\"trace-path\" d=\"M167 83.5L200.5 25\" stroke=\"#2795D9\" stroke-width=\"30\"/> </g> <defs> <clipPath id=\"clip0_14_2\"> <rect width=\"270\" height=\"270\" fill=\"white\"/> </clipPath> </defs> </svg></div><div class=\"box_card_body\"><h3>現場作業員から、どうすれば現場監督になれる？</h3><div class=\"box_card_question_bg\"><div class=\"box_card_question\"><p> <span>回答1</span> <span>多様な現場の実務経験</span></p><p> <span>解説</span> <span>現場監督という国家資格はありませんが、現場を統括するリーダーのため実務経験は必須です。</span></p></div></div><div class=\"box_card_question_bg\"><div class=\"box_card_question\"><p> <span>回答2</span> <span>施工管理技士2級以上の取得が望ましい</span></p><p> <span>解説</span> <span>工程管理や品質管理のにおいて専門知識が必要になります。特に1級施工管理技士は、法律上「監理技術者」として認められる資格のため、大規模な工事を任されるためには必須となります。</span></p></div></div></div></div></div></div><div class=\"interview\"><h1> <span>インタビュー</span> <span class=\"eng\">Interview</span></h1><p>山内土木で活躍している3名の社員にインタビューを実施しました。</p><div class=\"cardlist\"><div class=\"card\"> <span class=\"eng\">Riku Sakamoto</span><div class=\"card_header flip-card\"><div class=\"card_header_inner\"> <picture> <source srcset=\"https://yamauchi-doboku.jp/wp-content/themes/yamauchi-doboku/assets/images/interview01_1.png\" media=\"(max-width:768px)\" /> <img src=\"https://yamauchi-doboku.jp/wp-content/themes/yamauchi-doboku/assets/images/interview01_1.png\" alt=\"インタビュワー01\" /> </picture> <picture> <source srcset=\"https://yamauchi-doboku.jp/wp-content/themes/yamauchi-doboku/assets/images/interview01_2.png\" media=\"(max-width:768px)\" /> <img src=\"https://yamauchi-doboku.jp/wp-content/themes/yamauchi-doboku/assets/images/interview01_2.png\" alt=\"インタビュワー01のホバー画像\" /> </picture></div></div><div class=\"card_body\"><h2>むつ市に戻り、<br />自分らしく</h2><p class=\"name\"> <span>土木部</span> <span>坂本 陸</span></p> <a href=\"https://yamauchi-doboku.jp/recruit/interview01/\" class=\"page_link-btn fadeIn\"> <span>インタビューを見る</span> <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"41.453\" height=\"29.934\" viewBox=\"0 0 41.453 29.934\"> <g id=\"グループ_246\" data-name=\"グループ 246\" transform=\"translate(0 1.061)\"> <g id=\"グループ_64\" data-name=\"グループ 64\"> <line id=\"線_79\" data-name=\"線 79\" x2=\"39.333\" transform=\"translate(0 13.906)\" fill=\"none\" stroke=\"#415567\" stroke-miterlimit=\"10\" stroke-width=\"3\"/> <path id=\"パス_863\" data-name=\"パス 863\" d=\"M50.854,1.414,64.76,15.32,50.854,29.227\" transform=\"translate(-25.427 -1.414)\" fill=\"none\" stroke=\"#415567\" stroke-miterlimit=\"10\" stroke-width=\"3\"/> </g> </g> </svg> </a></div></div><div class=\"card\"> <span class=\"eng\">Tsubasa Ishitoya</span><div class=\"card_header flip-card\"><div class=\"card_header_inner\"> <picture> <source srcset=\"https://yamauchi-doboku.jp/wp-content/themes/yamauchi-doboku/assets/images/interview02_1.png\" media=\"(max-width:768px)\" /> <img src=\"https://yamauchi-doboku.jp/wp-content/themes/yamauchi-doboku/assets/images/interview02_1.png\" alt=\"インタビュワー02\" /> </picture> <picture> <source srcset=\"https://yamauchi-doboku.jp/wp-content/themes/yamauchi-doboku/assets/images/interview02_2.png\" media=\"(max-width:768px)\" /> <img src=\"https://yamauchi-doboku.jp/wp-content/themes/yamauchi-doboku/assets/images/interview02_2.png\" alt=\"インタビュワー02のホバー画像\" /> </picture></div></div><div class=\"card_body\"><h2>若手をつなぐ<br />存在でありたい</h2><p class=\"name\"> <span>土木部</span> <span>石戸谷 翼</span></p> <a href=\"https://yamauchi-doboku.jp/recruit/interview02/\" class=\"page_link-btn fadeIn\"> <span>インタビューを見る</span> <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"41.453\" height=\"29.934\" viewBox=\"0 0 41.453 29.934\"> <g id=\"グループ_246\" data-name=\"グループ 246\" transform=\"translate(0 1.061)\"> <g id=\"グループ_64\" data-name=\"グループ 64\"> <line id=\"線_79\" data-name=\"線 79\" x2=\"39.333\" transform=\"translate(0 13.906)\" fill=\"none\" stroke=\"#415567\" stroke-miterlimit=\"10\" stroke-width=\"3\"/> <path id=\"パス_863\" data-name=\"パス 863\" d=\"M50.854,1.414,64.76,15.32,50.854,29.227\" transform=\"translate(-25.427 -1.414)\" fill=\"none\" stroke=\"#415567\" stroke-miterlimit=\"10\" stroke-width=\"3\"/> </g> </g> </svg> </a></div></div><div class=\"card\"> <span class=\"eng\">Kouji Murata</span><div class=\"card_header flip-card\"><div class=\"card_header_inner\"> <picture> <source srcset=\"https://yamauchi-doboku.jp/wp-content/themes/yamauchi-doboku/assets/images/interview03_1.png\" media=\"(max-width:768px)\" /> <img src=\"https://yamauchi-doboku.jp/wp-content/themes/yamauchi-doboku/assets/images/interview03_1.png\" alt=\"インタビュワー03\" /> </picture> <picture> <source srcset=\"https://yamauchi-doboku.jp/wp-content/themes/yamauchi-doboku/assets/images/interview03_2.png\" media=\"(max-width:768px)\" /> <img src=\"https://yamauchi-doboku.jp/wp-content/themes/yamauchi-doboku/assets/images/interview03_2.png\" alt=\"インタビュワー03のホバー画像\" /> </picture></div></div><div class=\"card_body\"><h2>建築で故郷の<br />未来を描く</h2><p class=\"name\"> <span>建築部</span> <span>村田 浩爾</span></p> <a href=\"https://yamauchi-doboku.jp/recruit/interview03/\" class=\"page_link-btn fadeIn\"> <span>インタビューを見る</span> <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"41.453\" height=\"29.934\" viewBox=\"0 0 41.453 29.934\"> <g id=\"グループ_246\" data-name=\"グループ 246\" transform=\"translate(0 1.061)\"> <g id=\"グループ_64\" data-name=\"グループ 64\"> <line id=\"線_79\" data-name=\"線 79\" x2=\"39.333\" transform=\"translate(0 13.906)\" fill=\"none\" stroke=\"#415567\" stroke-miterlimit=\"10\" stroke-width=\"3\"/> <path id=\"パス_863\" data-name=\"パス 863\" d=\"M50.854,1.414,64.76,15.32,50.854,29.227\" transform=\"translate(-25.427 -1.414)\" fill=\"none\" stroke=\"#415567\" stroke-miterlimit=\"10\" stroke-width=\"3\"/> </g> </g> </svg> </a></div></div></div></div><div class=\"benefits\"><h1> <span>福利厚生・制度</span> <span class=\"eng\">Employee benefits</span></h1><p> 社員一人ひとりの<br class=\"sm_only\" />個性を尊重しながら、キャリアや成長、<br /> 働きやすい環境を維持することを目的に様々な福利厚生や制度を設けております。</p><div class=\"panellist\"><div class=\"panel panel01\"><div class=\"panel_header\"><h2>企業委託生<br />制度</h2><p> 企業委託生制度とは、入社後、札幌工科専門学校（1年生）に委託生として入学し、土木に関する基礎知識から2級土木施工管理技士1次試験の合格を目指すための技術者教育を行う制度です。若年層のスキル教育の一環として、資格取得を目指したチャレンジの機会を準備しています。未経験入社で不安な中「いきなり現場へ」ということはございません。ご本人と相談のうえ、知識習得を優先する場合はこのような制度をお勧めしています。</p></div><div class=\"panel_body\"><div class=\"panel_img\"> <picture> <source srcset=\"https://yamauchi-doboku.jp/wp-content/themes/yamauchi-doboku/assets/images/benefit1_sapporo.jpg\" media=\"(max-width:768px)\" /> <img src=\"https://yamauchi-doboku.jp/wp-content/themes/yamauchi-doboku/assets/images/benefit1_sapporo.jpg\" alt=\"札幌工科専門学校の図\" /> </picture></div><div class=\"panel_text\"><div class=\"panel_text_item\"><h3>制度を活用した社員の声</h3><p>入社後、専門知識は現場の中で学ぶ機会が沢山あるのですが、私は普通高校出身ということもあり、会社と相談したうえでこの制度を活用してみることに決めました。また、将来的には現場監督を見据えているので、知識習得だけでなく土木の基礎知識や測量などの実務経験もしっかり重ねながら、資格取得への挑戦も考えています。暮らしの面では、下宿生活のため不自由はなく、とても充実した毎日を送っています。</p></div><div class=\"panel_text_img\"> <picture> <source srcset=\"https://yamauchi-doboku.jp/wp-content/themes/yamauchi-doboku/assets/images/benefit1_staff.jpg\" media=\"(max-width:768px)\" /> <img src=\"https://yamauchi-doboku.jp/wp-content/themes/yamauchi-doboku/assets/images/benefit1_staff.jpg\" alt=\"土木部社員の画像\" /> </picture><div class=\"panel_text_img_name\"> <span>土木部</span> <span>長島 優星</span></div></div></div></div></div><div class=\"panel panel02\"><div class=\"panel_header\"><h2>資格取得<br />支援制度</h2><p> 資格取得に関する申請時の費用や講習受講費、交通費など、取得に必要とされる費用は会社が負担いたします。また、一部の資格については、資格取得後に資格手当が支給されます。</p></div><div class=\"panel_body\"><div class=\"panel_text\"><h3>入社してから取得できる主な資格</h3><p> <span>・施工管理技士（土木/建築・1級および2級）</span> <span>・作業主任者（足場/土止め/型枠など）</span> <span>・車両系建設機械</span> <span>・移動式クレーン</span> <span>・玉掛け</span> <span>・各種技能講習、各種特別教育</span> <span>など</span></p></div><div class=\"panel_img\"> <picture> <source srcset=\"https://yamauchi-doboku.jp/wp-content/themes/yamauchi-doboku/assets/images/benefit2_img.jpg\" media=\"(max-width:768px)\" /> <img src=\"https://yamauchi-doboku.jp/wp-content/themes/yamauchi-doboku/assets/images/benefit2_img.jpg\" alt=\"タイヤローラーの画像\" /> </picture></div></div></div><div class=\"panel panel03\"><div class=\"panel_header\"><h2>健康増進<br />制度</h2><p> 健康増進と体力維持が社員の活力向上やパフォーマンスの向上をもたらし、組織全体の活性化につながると考えております。社員は当社が施設運営管理している「むつ市ウェルネスパーク」を福利厚生制度として無料で利用することができます。勤務後や休日など、ご自身のライフスタイルに合わせて活用いただいています。</p></div><div class=\"panel_body\"><div class=\"panel_img\"> <picture> <source srcset=\"https://yamauchi-doboku.jp/wp-content/themes/yamauchi-doboku/assets/images/benefit3_img1.jpg\" media=\"(max-width:768px)\" /> <img src=\"https://yamauchi-doboku.jp/wp-content/themes/yamauchi-doboku/assets/images/benefit3_img1.jpg\" alt=\"ウェルネスパークの屋内ジム\" /> </picture> <picture> <source srcset=\"https://yamauchi-doboku.jp/wp-content/themes/yamauchi-doboku/assets/images/benefit3_img2.jpg\" media=\"(max-width:768px)\" /> <img src=\"https://yamauchi-doboku.jp/wp-content/themes/yamauchi-doboku/assets/images/benefit3_img2.jpg\" alt=\"ウェルネスパークの屋内プール\" /> </picture></div></div></div></div></div><div class=\"infomation\"><h1> <span>募集要項</span> <span class=\"eng\">Recruit Information</span></h1><p> 現在当社では以下の職種において<br class=\"sm_only\" />求人募集を行っております。<br /> ご興味のある方は、<br class=\"sm_only\" />まずは会社見学のお申込みを<br class=\"sm_only\" />お待ちしております。<br /> ※高等学校卒業予定の方の<br class=\"sm_only\" />応募につきましては、<br class=\"sm_only\" />各学校を通じてご応募ください。</p><div class=\"cardlist\"><div class=\"card\"><div class=\"card_header\"><h2> <span>新卒採用</span> <span class=\"eng\">New graduate recruitment</span></h2></div><div class=\"card_body\"> <a href=\"https://yamauchi-doboku.jp/recruit/requirement01/\" class=\"card_link-btn fadeIn\"> <span>技能者</span> <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"41.453\" height=\"29.934\" viewBox=\"0 0 41.453 29.934\"> <g id=\"グループ_246\" data-name=\"グループ 246\" transform=\"translate(0 1.061)\"> <g id=\"グループ_64\" data-name=\"グループ 64\"> <line id=\"線_79\" data-name=\"線 79\" x2=\"39.333\" transform=\"translate(0 13.906)\" fill=\"none\" stroke=\"#415567\" stroke-miterlimit=\"10\" stroke-width=\"3\"/> <path id=\"パス_863\" data-name=\"パス 863\" d=\"M50.854,1.414,64.76,15.32,50.854,29.227\" transform=\"translate(-25.427 -1.414)\" fill=\"none\" stroke=\"#415567\" stroke-miterlimit=\"10\" stroke-width=\"3\"/> </g> </g> </svg> </a> <a href=\"https://yamauchi-doboku.jp/recruit/requirement02/\" class=\"card_link-btn fadeIn\"> <span>技術者</span> <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"41.453\" height=\"29.934\" viewBox=\"0 0 41.453 29.934\"> <g id=\"グループ_246\" data-name=\"グループ 246\" transform=\"translate(0 1.061)\"> <g id=\"グループ_64\" data-name=\"グループ 64\"> <line id=\"線_79\" data-name=\"線 79\" x2=\"39.333\" transform=\"translate(0 13.906)\" fill=\"none\" stroke=\"#415567\" stroke-miterlimit=\"10\" stroke-width=\"3\"/> <path id=\"パス_863\" data-name=\"パス 863\" d=\"M50.854,1.414,64.76,15.32,50.854,29.227\" transform=\"translate(-25.427 -1.414)\" fill=\"none\" stroke=\"#415567\" stroke-miterlimit=\"10\" stroke-width=\"3\"/> </g> </g> </svg> </a></div></div><div class=\"card\"><div class=\"card_header\"><h2> <span>中途採用</span> <span class=\"eng\">Mid-career recruitment</span></h2></div><div class=\"card_body\"> <a href=\"https://yamauchi-doboku.jp/wp-content/themes/yamauchi-doboku/assets/images/pdf/中途採用-求人-技能者.pdf\" class=\"card_link-btn fadeIn\" target