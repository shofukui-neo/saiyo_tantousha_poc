/recruit/wp-content/themes/pasco/assets/js/jquery.min.js?ver=3.7.1\" id=\"jquery-js\"></script>\n<link rel=\"icon\" href=\"https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/01/cropped-favicon-32x32.png\" sizes=\"32x32\" />\n<link rel=\"icon\" href=\"https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/01/cropped-favicon-192x192.png\" sizes=\"192x192\" />\n<link rel=\"apple-touch-icon\" href=\"https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/01/cropped-favicon-180x180.png\" />\n<meta name=\"msapplication-TileImage\" content=\"https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/01/cropped-favicon-270x270.png\" />\n</script>\r\n</head>\r\n<body>\r\n\t<header id=\"header\" class=\"p-header\">\r\n    <div class=\"p-header__wrap\">\r\n        <a href=\"https://www.pasconet.co.jp/recruit/\" class=\"p-header__logo hover\">\r\n            <span class=\"p-header__logo-img\">\r\n                <img src=\"https://www.pasconet.co.jp/recruit/wp-content/themes/pasco/assets/images/common/pasco_logo.svg\" alt=\"Pasco\">\r\n            </span>\r\n            <span class=\"p-header__logo-txt\">新卒<br class=\"sp\">採用サイト</span>\r\n        </a>\r\n        <div class=\"p-header__right\">\r\n            <h1 class=\"p-header__ttl\">敷島製パン株式会社 Pascoの大学生向けの新卒採用サイト「「現状維持は衰退」、常に改善点を探して上を目指す。」ページ</h1>\r\n            <div class=\"p-header__main\">\r\n                <nav class=\"p-header__nav\">\r\n                    <a href=\"https://www.pasconet.co.jp/recruit/details/\" class=\"p-header__btn btn-hover\">募集要項<span class=\"icon icon-info\"></span></a>\r\n                    <a href=\"https://job.axol.jp/bx/s/pasco_27/entry\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"p-header__btn p-header__btn--info btn-hover\">27年卒 ENTRY<span class=\"icon icon-entry\"></span></a>\r\n                    <a href=\"https://axol.jp/zw/s/pasco_28/entry/agreement\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"p-header__btn p-header__btn--info btn-hover\">28年卒 ENTRY<span class=\"icon icon-entry\"></span></a>\r\n                </nav>\r\n                <a href=\"https://www.instagram.com/pasco_saiyo/\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"p-header__ins\"><img src=\"https://www.pasconet.co.jp/recruit/wp-content/themes/pasco/assets/images/common/icn_ins.svg\" alt=\"instagram\"></a>\r\n                <div class=\"hamburger-box js-show-menu\" role=\"button\" aria-label=\"Menu\" aria-expanded=\"false\"><span class=\"hamburger-inner\"></span></div>\r\n            </div>\r\n        </div>\r\n    </div>\r\n\r\n    <div class=\"p-header__wrap p-header__wrap--fixed\">\r\n        <a href=\"https://www.pasconet.co.jp/recruit/\" class=\"p-header__logo hover\">\r\n            <span class=\"p-header__logo-img\">\r\n                <img src=\"https://www.pasconet.co.jp/recruit/wp-content/themes/pasco/assets/images/common/pasco_logo.svg\" alt=\"Pasco\">\r\n            </span>\r\n            <span class=\"p-header__logo-txt\">新卒<br>採用サイト</span>\r\n        </a>\r\n        <div class=\"p-header__right\">\r\n            <div class=\"p-header__main\">\r\n                <nav class=\"p-header__nav\">\r\n                    <a href=\"https://www.pasconet.co.jp/recruit/details/\" class=\"p-header__btn btn-hover\">募集要項<span class=\"icon icon-info\"></span></a>\r\n                    <a href=\"https://job.axol.jp/bx/s/pasco_27/entry\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"p-header__btn p-header__btn--info btn-hover\">27年卒 ENTRY<span class=\"icon icon-entry\"></span></a>\r\n                    <a href=\"https://axol.jp/zw/s/pasco_28/entry/agreement\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"p-header__btn p-header__btn--info btn-hover\">28年卒 ENTRY<span class=\"icon icon-entry\"></span></a>\r\n                </nav>\r\n                <a href=\"https://www.instagram.com/pasco_saiyo/\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"p-header__ins\"><img src=\"https://www.pasconet.co.jp/recruit/wp-content/themes/pasco/assets/images/common/icn_ins.svg\" alt=\"instagram\"></a>\r\n            </div>\r\n        </div>\r\n    </div>\r\n    <div class=\"hamburger-box hamburger-box--single js-show-menu\" role=\"button\" aria-label=\"Menu\" aria-expanded=\"false\"><span class=\"hamburger-inner\"></span></div>\r\n\r\n    <div class=\"global-nav\">\r\n    <div class=\"global-nav__wrap\">\r\n        <nav class=\"global-nav__group\">\r\n            <ul class=\"nav-list\">\r\n                <li class=\"nav-item\">\r\n                    <a href=\"https://www.pasconet.co.jp/recruit/\" class=\"nav-link\">\r\n                        <span class=\"nav-link__ttl\">Top</span>\r\n                        <span class=\"nav-link__sub\">採用ページトップ</span>\r\n                    </a>\r\n                </li>\r\n                <li class=\"nav-item\">\r\n                    <a href=\"https://www.pasconet.co.jp/recruit/news/\" class=\"nav-link\">\r\n                        <span class=\"nav-link__ttl\">News</span>\r\n                        <span class=\"nav-link__sub\">お知らせ</span>\r\n                    </a>\r\n                </li>\r\n                <li class=\"nav-item\">\r\n                    <a href=\"https://www.pasconet.co.jp/recruit/company/\" class=\"nav-link\">\r\n                        <span class=\"nav-link__ttl\">Company</span>\r\n                        <span class=\"nav-link__sub\">会社概要&<br class=\"sp\">社長メッセージ</span>\r\n                    </a>\r\n                </li>\r\n                <li class=\"nav-item\">\r\n                    <a href=\"https://www.pasconet.co.jp/recruit/data/\" class=\"nav-link\">\r\n                        <span class=\"nav-link__ttl\">Data</span>\r\n                        <span class=\"nav-link__sub\">数字で見るPasco</span>\r\n                    </a>\r\n                </li>\r\n                <li class=\"nav-item\">\r\n                    <a href=\"https://www.pasconet.co.jp/recruit/interview/\" class=\"nav-link\">\r\n                        <span class=\"nav-link__ttl\">Interview</span>\r\n                        <span class=\"nav-link__sub\">社員インタビュー</span>\r\n                    </a>\r\n                </li>\r\n            </ul>\r\n            <ul class=\"nav-list\">\r\n                <li class=\"nav-item\">\r\n                    <a href=\"https://www.pasconet.co.jp/recruit/discussion/\" class=\"nav-link\">\r\n                        <span class=\"nav-link__ttl\">Discussion</span>\r\n                        <span class=\"nav-link__sub\">社員対談</span>\r\n                    </a>\r\n                </li>\r\n                <li class=\"nav-item\">\r\n                    <a href=\"https://www.pasconet.co.jp/recruit/culture/\" class=\"nav-link\">\r\n                        <span class=\"nav-link__ttl\">Culture</span>\r\n                        <span class=\"nav-link__sub\">企業文化＆働く環境</span>\r\n                    </a>\r\n                </li>\r\n                <li class=\"nav-item\">\r\n                    <a href=\"https://www.pasconet.co.jp/recruit/career/\" class=\"nav-link\">\r\n                        <span class=\"nav-link__ttl\">Career</span>\r\n                        <span class=\"nav-link__sub\">教育・研修制度＆<br class=\"sp\">キャリアパス</span>\r\n                    </a>\r\n                </li>\r\n                <li class=\"nav-item\">\r\n                    <a href=\"https://www.pasconet.co.jp/recruit/business/\" class=\"nav-link\">\r\n                        <span class=\"nav-link__ttl\">Business</span>\r\n                        <span class=\"nav-link__sub\">事業内容</span>\r\n                    </a>\r\n                </li>\r\n                <li class=\"nav-item\">\r\n                    <a href=\"https://www.pasconet.co.jp/recruit/qa/\" class=\"nav-link\">\r\n                        <span class=\"nav-link__ttl\">Q&A</span>\r\n                        <span class=\"nav-link__sub\">よくある質問</span>\r\n                    </a>\r\n                </li>\r\n            </ul>\r\n        </nav>\r\n        <nav class=\"global-nav__other\">\r\n            <a href=\"https://www.pasconet.co.jp/recruit/details/\" class=\"btn btn-sub btn-hover\">募集要項・<br class=\"pc\">採用スケジュール<span class=\"icon icon-info\"></span></a>\r\n            <a href=\"https://job.axol.jp/bx/s/pasco_27/entry/\" class=\"btn btn-primary-reverse btn-hover\" target=\"_blank\">27年卒 ENTRY<span class=\"icon icon-entry\"></span></a>\r\n            <a href=\"https://axol.jp/zw/s/pasco_28/entry/agreement\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"btn btn-primary-reverse btn-hover\">28年卒 ENTRY<span class=\"icon icon-entry\"></span></a>\r\n        </nav>\r\n    </div>\r\n</div></header>\r\n\r\n<ul class=\"nav-fixed sp\">\r\n    <li><a href=\"https://www.pasconet.co.jp/recruit/details/\" class=\"btn btn-sub btn-hover\">募集要項<span class=\"icon icon-info\"></span></a></li>\r\n    <li><a href=\"https://job.axol.jp/bx/s/pasco_27/entry\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"btn btn-primary btn-hover\">27年卒 ENTRY<span class=\"icon icon-entry\"></span></a></li>\r\n    <li><a href=\"https://axol.jp/zw/s/pasco_28/entry/agreement\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"btn btn-primary btn-hover\">28年卒 ENTRY<span class=\"icon icon-entry\"></span></a></li>\r\n</ul><div class=\"c-mv\">\r\n    <div class=\"c-mv__wrap\">\r\n        <div class=\"c-mv__content\">\r\n            <h2 class=\"c-mv__page\">Interview</h2>\r\n            <p class=\"c-mv__sub\">社員インタビュー</p>\r\n        </div>\r\n        <div class=\"c-breadcrumb\">\r\n            <ul class=\"c-breadcrumb__list\">\r\n                <li class=\"c-breadcrumb__item hover\"><a href=\"https://www.pasconet.co.jp/recruit/\">ホーム</a></li>\r\n                <li class=\"c-breadcrumb__item hover\"><a href=\"https://www.pasconet.co.jp/recruit/interview/\">社員インタビュー</a></li>\r\n                <li class=\"c-breadcrumb__item\">「現状維持は衰退」、常に改善点を探して上を目指す。</li>\r\n            </ul>\r\n        </div>\r\n    </div>\r\n</div>\r\n<div class=\"inner\">\r\n    <div class=\"c-single\">\r\n        <div class=\"c-single__media\">\r\n                        <div class=\"c-single__media-img\">\r\n                                    <p class=\"c-single__media-cate\">生産</p>\r\n                                \r\n                <img width=\"1024\" height=\"950\" src=\"https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A9827-scaled-e1772094269506-1024x950.jpg\" class=\"attachment-large size-large wp-post-image\" alt=\"\" decoding=\"async\" fetchpriority=\"high\" srcset=\"https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A9827-scaled-e1772094269506-1024x950.jpg 1024w, https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A9827-scaled-e1772094269506-300x278.jpg 300w, https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A9827-scaled-e1772094269506-768x713.jpg 768w, https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A9827-scaled-e1772094269506-1536x1425.jpg 1536w, https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A9827-scaled-e1772094269506.jpg 1703w\" sizes=\"(max-width: 1024px) 100vw, 1024px\" />            </div>\r\n                        \r\n            <div class=\"c-single__media-body\">\r\n                                <p class=\"btn-basic\">2019年入社 / 製造（菓子パン）　係長職</p>\r\n                \r\n                <p class=\"c-single__media-ttl\">「現状維持は衰退」、常に改善点を探して上を目指す。</p>\r\n                <p class=\"c-single__media-name\">髙島</p>\r\n            </div>\r\n        </div>\r\n\r\n        \r\n                \r\n        <div class=\"detail-body c-txt\"><div class=\"box\">\n<p>【略歴】</p>\n<p>2019年4月：生産職入社</p>\n<p>2022年9月：班長職に昇進</p>\n<p>2025年9月：係長職に昇進</p>\n<p>&nbsp;</p>\n<p>【好きな商品】</p>\n<p>1位：国産小麦 クラウンメロンパン</p>\n<p>2位：とろけるクリームシフォン</p>\n<p>3位：スナックパン チョコ</p>\n</div>\n<h3>Q：入社の理由は？<br />\nA：自分を必要としてくれていると感じ、入社を決意。</h3>\n<p>大学時代は、細菌や微生物など、バイオ環境化学について学んでおり、台所などにある滑りの原因となる「黄色ブドウ球菌のバイオフィルム形成」について研究していました。就職活動では、もともとおいしいものを食べることが好きだったため、食品・飲料メーカーに絞ってさまざまな企業の説明を受けていた中で、Pascoのブースをフラッと訪れたのがきっかけです。</p>\n<p>また、私は愛知県出身で、本社を愛知県に構えるPascoに親近感があったことも受けようと思った理由の一つですね。採用活動を通して、20社以上受けましたが「会社が自分を必要としてくれる」と強く感じられたのがPascoでした。</p>\n<h3>Q：仕事の内容は？<br />\nA：生産ライン全体の管理や調整が主な仕事。</h3>\n<div>\n<div class=\"img-with-txt\">\n<div class=\"img-with-txt__content\">\n<div><img decoding=\"async\" class=\"alignnone size-full wp-image-269\" src=\"https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A9944.jpg\" alt=\"\" width=\"2521\" height=\"1656\" srcset=\"https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A9944.jpg 2521w, https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A9944-300x197.jpg 300w, https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A9944-1024x673.jpg 1024w, https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A9944-768x504.jpg 768w, https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A9944-1536x1009.jpg 1536w, https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A9944-2048x1345.jpg 2048w\" sizes=\"(max-width: 2521px) 100vw, 2521px\" /></div>\n<div>　</div>\n<p>現在は係長職として働いており、生産ラインの管理や運営を主に行っています。「生産ラインが問題なく動いているか」「不具合がないか」「改善できることはないか」など、全体を見て回る役割です。実際に手を動かす生産も業務のうちですが、7:3の割合でマネジメントを行っていることが多いですね。係長になる前から、隣で係長の業務を見て学んでいたので、仕事は増えましたが新たに覚えることは少なく、特に支障なくマネジメント業務も行えています。もちろん、トラブルが重なったときは大変です。</p>\n<p>&nbsp;</p>\n<p>また、ライン設備の故障や入れ替えなどで工事を実施する場合、自分の工場では生産がストップするため、他工場に生産応援してもらう必要があります。私の役割は、他工場に対してどれだけ生産応援を依頼するか考え、関係各所に連絡してやり取りすることです。こちら側が要請することもあれば、他工場の依頼を受けることもあり、工場同士は持ちつ持たれつの関係です。</p>\n<p>&nbsp;</p>\n<p>その他にも、新商品やリニューアルがあった際には、実際に工場で生産するためのラインテストを実施します。商品開発部門での試作段階では、パンをごく少量しかつくらないため、実際に大量生産する際の問題点や改善点を確認し、調整する必要があります。</p>\n<h3>Q：生産職で大切なことは？<br />\nA：「現状維持は衰退」、常に改善点を探して上を目指すこと。</h3>\n<div>\n<div class=\"img-with-txt\">\n<div class=\"img-with-txt__content\">\n<div><img decoding=\"async\" class=\"alignnone size-full wp-image-270\" src=\"https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A9996-scaled.jpg\" alt=\"\" width=\"2560\" height=\"1707\" srcset=\"https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A9996-scaled.jpg 2560w, https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A9996-300x200.jpg 300w, https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A9996-1024x683.jpg 1024w, https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A9996-768x512.jpg 768w, https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A9996-1536x1024.jpg 1536w, https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A9996-2048x1365.jpg 2048w\" sizes=\"(max-width: 2560px) 100vw, 2560px\" /></div>\n<div>　</div>\n<p>「現状維持は衰退」が自分の座右の銘なのですが、良い状態を維持しようとするだけでは、どこかが悪くなってしまいます。常に良い状態をキープして満足するのではなく、「まだ何か改善点があるんじゃないか」「他に活かせないか」と、常に考えて上を目指すようにしています。改善点は、1人で歩いていてフッと降りてくることもありますし、いろんな人に話を聞く中で見えてくることもあります。そのため、他のラインや他部署の人とも積極的に会話するようにしています。</p>\n<p>&nbsp;</p>\n<p>また、生産部門はラインが複数あり、そのラインの中で何人もの人が関わるため、協調性は欠かせません。パンづくりは団体競技に近いと思います。</p>\n<h3>Q：どんな会社？<br />\nA：育休・産休制度や時短勤務の活用を推奨している会社。</h3>\n<p>育休・産休制度が整っており、女性にも男性にも優しい会社だと思います。特に男性の育休の取得については、実際に取得している男性の同僚が多く、非常にハードルが低くなっています。</p>\n<p>また、時短勤務が可能なことも魅力の一つです。育児をしている社員は、子どもが体調不良になったときは業務を調整し帰宅することも可能で、働きやすい環境だと思います。</p>\n<p>その他には、シンプルにつくるパンがおいしいことも魅力の一つですね。生産職として、パンのおいしさには自信を持っています。</p>\n<h3>Q：今後の目標は？<br />\nA：生産部門とは全く異なるポジションで、中長期的な目線での仕事に携わりたい。</h3>\n<p>今まで、生産部門の中でも同一ラインでしか働いたことがないため、生産部門での経験を活かして全く別の業務にも挑戦してみたいですね。また、これまでは短期的な目標を追い求めてきましたが、今後は年単位の中長期的な視点を持って業務に取り組んでいきたいと考えています。</p>\n</div>\n</div>\n</div>\n</div>\n</div>\n</div>\n</div>\r\n    </div>\r\n</div>\r\n<div class=\"container\">\r\n        <nav class=\"c-back-nav\">\r\n                    <a href=\"https://www.pasconet.co.jp/recruit/production/p202/\" class=\"c-back-nav__arrow c-back-nav__arrow--prev\"></a>\r\n        \r\n        <a href=\"https://www.pasconet.co.jp/recruit/interview/\" class=\"btn btn-sub c-back-nav__button\">一覧へ戻る</a>\r\n\r\n                    <a href=\"https://www.pasconet.co.jp/recruit/production/p188/\" class=\"c-back-nav__arrow c-back-nav__arrow--next\"></a>\r\n            </nav>\r\n\r\n        <nav class=\"c-category-filter\">\r\n        <ul class=\"c-category-filter__list\">\r\n            <li><a href=\"https://www.pasconet.co.jp/recruit/interview/\" class=\"btn-basic\">すべて</a></li>\r\n                        <li><a href=\"https://www.pasconet.co.jp/recruit/interview/engineer/\" class=\"btn-basic\">エンジニア</a></li>\r\n                        <li><a href=\"https://www.pasconet.co.jp/recruit/interview/sales/\" class=\"btn-basic\">営業</a></li>\r\n                        <li><a href=\"https://www.pasconet.co.jp/recruit/interview/production/\" class=\"btn-basic\">生産</a></li>\r\n                    </ul>\r\n    </nav>\r\n    </div>\r\n\r\n<footer class=\"p-footer\">\r\n    <div class=\"inner\">\r\n        <div class=\"footer-entry\">\r\n            <h3 class=\"footer-entry__ttl font-en\">Entry!</h3>\r\n            <p class=\"footer-entry__txt\">Pascoでは、<br class=\"sp\">一緒に働く社員を募集しています。<br>\r\n            まだ夢がはっきりしていなくても<br class=\"sp\">大丈夫。挑戦する気持ちを持つ<br class=\"sp\">皆さまからのエントリーを<br class=\"sp\">お待ちしています。</p>\r\n            <div class=\"footer-entry__nav\">\r\n                <a href=\"https://www.pasconet.co.jp/recruit/details/\" class=\"btn btn-sub btn-hover\">募集要項・<br class=\"pc\">採用スケジュール<span class=\"icon icon-info\"></span></a>\r\n                <a href=\"https://job.axol.jp/bx/s/pasco_27/entry\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"btn btn-primary btn-hover\">27年卒 ENTRY<span class=\"icon icon-entry\"></span></a>\r\n                <a href=\"https://axol.jp/zw/s/pasco_28/entry/agreement\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"btn btn-primary btn-hover\">28年卒 ENTRY<span class=\"icon icon-entry\"></span></a>\r\n            </div>\r\n            <div class=\"footer-entry__img --left\">\r\n                <picture>\r\n                    <source media=\"(min-width: 768px)\" srcset=\"https://www.pasconet.co.jp/recruit/wp-content/themes/pasco/assets/images/common/footer_entry_img01.svg\">\r\n             