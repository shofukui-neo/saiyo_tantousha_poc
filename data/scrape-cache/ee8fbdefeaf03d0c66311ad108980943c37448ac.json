ry/request/\">\r\n        <i class=\"fa-solid fa-angle-right fontColorGreen\"></i>\r\n        <p>運送相談</p>\r\n      </a>\r\n      <a href=\"https://www.daiichi-kamotsu.co.jp/inquiry/contact/\">\r\n        <i class=\"fa-solid fa-angle-right fontColorGreen\"></i>\r\n        <p>その他お問合せ</p>\r\n      </a>\r\n    </div>\r\n  </div>\r\n  <div class=\"headerAreaSP\">\r\n    <a href=\"https://www.daiichi-kamotsu.co.jp/\" class=\"logoLink\"><img src=\"https://www.daiichi-kamotsu.co.jp/images/logo.png\"></a>\r\n    <input type=\"checkbox\" id=\"checkSP\">\r\n    <label for=\"checkSP\" class=\"btnSP\"><span></span></label>\r\n    <div class=\"menuSP\">\r\n      <div class=\"option\">\r\n        <input type=\"checkbox\" id=\"chaseMenu\" class=\"checkAccordion\">\r\n        <label class=\"spMenuTitle\" for=\"chaseMenu\">貨物追跡照会</label>\r\n        <ul class=\"spMenuList\">\r\n          <li><a href=\"https://www.daiichi-kamotsu.co.jp/chase/contact_num/\">貨物追跡照会</a></li>\r\n          <li><a href=\"https://www.daiichi-kamotsu.co.jp/chase/private_num/\">お客様専用伝票番号から照会</a></li>\r\n          <li><a href=\"https://boxtoi.jitbox.co.jp/boxtoi/inquiry\">JITBOXチャーター便照会</a></li>\r\n          <li><a href=\"https://www.daiichi-kamotsu.co.jp/company/pressroom/pdf/surcharge.pdf\">燃料サーチャージ料金算出燃料価格のご案内</a></li>\r\n        </ul>\r\n      </div>\r\n      <div class=\"option\">\r\n        <a href=\"https://www.daiichi-kamotsu.co.jp/service/\">サービス</a>\r\n      </div>\r\n      <div class=\"option\">\r\n        <a href=\"https://www.daiichi-kamotsu.co.jp/quality/\">輸送品質</a>\r\n      </div>\r\n      <div class=\"option\">\r\n        <a href=\"https://www.daiichi-kamotsu.co.jp/company/\">企業情報</a>\r\n      </div>\r\n      <div class=\"option\">\r\n        <a href=\"https://www.daiichi-kamotsu.co.jp/sustainability/\">サステナビリティ</a>\r\n      </div>\r\n      <div class=\"option\">\r\n        <input type=\"checkbox\" id=\"careerMenu\" class=\"checkAccordion\">\r\n        <label class=\"spMenuTitle\" for=\"careerMenu\">採用情報</label>\r\n        <ul class=\"spMenuList\">\r\n          <li><a href=\"https://www.daiichi-kamotsu.co.jp/recruit/\">採用情報トップ</a></li>\r\n          <li><a href=\"https://www.daiichi-kamotsu.co.jp/recruit/infomation/newgraduates/\">新卒採用情報</a></li>\r\n          <li><a href=\"https://www.daiichi-kamotsu.co.jp/recruit/infomation/midcareer/\">経験者採用情報</a></li>\r\n          <li><a href=\"https://www.daiichi-kamotsu.co.jp/recruit/infomation/disability/\">障がい者採用情報</a></li>\r\n        </ul>\r\n      </div>\r\n      <div class=\"option\">\r\n        <a href=\"https://www.daiichi-kamotsu.co.jp/inquiry/consultation/\">輸送協力会社様相談窓口</a>\r\n      </div>\r\n      <div class=\"option\">\r\n        <a href=\"https://www.daiichi-kamotsu.co.jp/inquiry/\">各種照会・お問合せ</a>\r\n      </div>\r\n      <div class=\"option\">\r\n        <a href=\"https://www.daiichi-kamotsu.co.jp/member/\">マイページログイン</a>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</header>  <main>\r\n    <!-- <section class=\"guidanceTopImage\"> -->\r\n    <section>\r\n      <div class=\"topImageArea\">\r\n        <p style=\"margin:2em auto 0;\"><span class=\"fontColorGreen\">第一貨物マイページ</span>のご案内</p>\r\n        <!-- <img src=\"img/mypageGuidance.jpg\"> -->\r\n      </div>\r\n    </section>\r\n    <div class=\"inner\">\r\n      <section>\r\n        <p class=\"marginTop40\">第一貨物マイページでは、弊社独自の情報サービス DST（Delivery ServiceTime）を含む、各種Webサービスを提供しています。<br>\r\n          本サービスは事前申込制・無料でご利用頂けます。</p>\r\n        <div class=\"marginTop40 fontSize14 footnote\">\r\n          <p class=\"footnoteTitle\">DST （Delivery Service Time）</p>\r\n          <p class=\"footnoteReader\">&hellip;</p>\r\n          <p class=\"footnoteText\">配達予定日や配達予定時間、悪天候の影響による配達遅延などの輸送情報をWebまたはメールでご提供するサービスです。</p>\r\n        </div>\r\n      </section>\r\n\r\n      <section>\r\n        <p class=\"borderTitle\">第一貨物マイページでできること</p>\r\n      </section>\r\n\r\n      <section>\r\n        <p class=\"chdTitle title_1\">１．出荷済荷物の配達時間照会</p>\r\n        <p class=\"margin20 textLeft\">\r\n          お問い合わせ番号を入力することなく、荷物の配達状況を一覧で確認することができます。<br>\r\n          第一貨物マイページでの照会の他、CSVデータとしてメール配信も可能です。<br>\r\n          このサービスは当社お取引先様はもちろん、定期的に当社から配達があるお客様もご利用いただけます。\r\n        </p>\r\n\r\n        <div class=\"flexContent textLeft\">\r\n          <div class=\"flexContents_1\">\r\n            <p class=\"flexTitle_1 web_inq\">Web照会</p>\r\n            <p class=\"flexText_1\">\r\n              弊社ホームページTOPの「マイページログイン」から照会できます。<a href=\"img/DST_webSample.png\" target=\"_blank\">※Web照会イメージ</a><br>\r\n              IDとパスワードを発行しますので、セキュリティは万全です。ご出荷されたお客様は「県別」「輸送状況別」に検索が可能です。都度更新される最新情報をご確認頂けます。\r\n            </p>\r\n          </div>\r\n          <div class=\"flexContents_1\">\r\n            <p class=\"flexTitle_1 mail_inq\">メールサービス<span>（日・祝日は除く）</span></p>\r\n            <p class=\"flexText_1\">\r\n              お客様がご指定するメールアドレスへCSVデータとしてご提供します。<a href=\"img/DST_mailSample.png\" target=\"_blank\">※メール配信イメージ</a>\r\n            </p>\r\n            <div class=\"flexText_1\">\r\n              <p><span class=\"mailServiceText_1\">配信回数</span><span class=\"mailServiceText_2\">1日3回</span></p> \r\n              <p><span class=\"mailServiceText_1\">配信時間</span><span class=\"mailServiceText_2\">午前7時・午前9時・午後2時 での最新情報を各30分後に配信します。</span></p>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </section>\r\n\r\n      <section>\r\n        <p class=\"chdTitle title_2\">２．配達日数照会（リードタイム照会）</p>\r\n        <p class=\"margin20 textLeft\">\r\n          お届け先の都道府県を選択して頂くことで、市区町村毎の配達予定日が表示されます。\r\n        </p>\r\n      </section>\r\n\r\n      <section>\r\n        <p class=\"chdTitle title_3\">３．運賃のお見積り</p>\r\n        <p class=\"margin20 textLeft\">\r\n          お預かり日・お届け先・出荷個数・総重量・商品サイズを選択・入力して頂くことで、発送契約に基づいたお見積り運賃が表示されます。<br>\r\n          発送契約が複数ある場合は該当の契約コードを選択して頂くことで、お見積りが可能です。\r\n        </p>\r\n      </section>\r\n\r\n      <section>\r\n        <p class=\"chdTitle title_4\">４．出荷済荷物の運賃照会</p>\r\n        <p class=\"margin20 textLeft\">\r\n          出荷済みの荷物のお問合せ番号を入力して頂くことで、 1度に最大5件まで一括で照会が可能です。<br>\r\n          照会件数に上限はありません。\r\n        </p>\r\n      </section>\r\n\r\n      <section>\r\n        <p class=\"squareTitle\">お申込み方法</p>\r\n        <p class=\"margin20\">\r\n          本サービスをご利用されるお客様は、弊社営業担当までお申し付けください。<br>\r\n          ご利用の際は、「第一貨物マイページID・パスワード」が必要です。弊社営業担当が申込書をお持ち致しますので、利用規約を確認の上、お申し込み下さい。<br>\r\n          申し込みから数日で「第一貨物マイページID・パスワード」の案内書をお持ち致しますので、その時点から利用可能となります。\r\n        </p>\r\n      </section>\r\n\r\n      <section>\r\n        <ul class=\"warning margin20\">\r\n          <p>注意事項</p>\r\n          <li>本サービスのご利用は法人様に限らせて頂きます。</li>\r\n          <li>本サービスをご利用いただくお客様には、ご担当者様宛てに事前確認をさせて頂きます。</li>\r\n          <li>交通事情により、配達予定時間が前後する場合があります。</li>\r\n        </ul>\r\n      </section>\r\n\r\n      <section>\r\n        <p class=\"squareTitle\">よくある質問</p>\r\n        <div class=\"QandA margin20\">\r\n          <p>Ｑ．IDとパスワードを忘れてしまった。</p>\r\n          <p>Ａ． 弊社営業担当が対応しますので、担当事業所までご連絡ください。</p>\r\n        </div>\r\n        <div class=\"QandA\">\r\n          <p>Ｑ． メールサービスの宛先を複数登録できるのか。</p>\r\n          <p>Ａ． 5件まで登録可能です。</p>\r\n        </div>\r\n        <div class=\"QandA\">\r\n          <p>Ｑ． メールサービスで悪天候による配達遅延情報だけを送信して欲しい。\r\n          </p>\r\n          <p>Ａ． ご対応可能です。</p>\r\n        </div>\r\n      </section>\r\n\r\n      <div class=\"contactInformationArea\">\r\n        <div class=\"contactInformation\">\r\n          <ul class=\"infoAddress\">\r\n            <li class=\"title\">輸送事業本部　営業部</li>\r\n            <li>〒135-0043　東京都江東区塩浜1-2-2</li>\r\n            <li>営業　9:00～18:00<span class=\"fontSize14\">（日・祝除く）</span></li>\r\n          </ul>\r\n          <ul class=\"infoContact\">\r\n            <li>\r\n              <p class=\"infoTitle\">TEL：</p>\r\n              <p>03-3649-8182<span class=\"fontSize14\">（直通）</span></p>\r\n            </li>\r\n            <li>\r\n              <p class=\"infoTitle\">FAX：</p>\r\n              <p>03-3649-8189</p>\r\n            </li>\r\n            <li>\r\n              <p class=\"infoTitle\">E-MAIL：</