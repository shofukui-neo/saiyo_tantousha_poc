{"url":"https://www.kissei.co.jp/recruit/fresh/","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n<head>\n  <meta name=\"charset\" content=\"UTF-8\">\n<meta name=\"format-detection\" content=\"telephone=no,address=no,email=no\">\n<meta name=\"viewport\" content=\"viewport-fit=cover,width=device-width,initial-scale=1.0,minimum-scale=1.0\">\n<meta name=\"theme-color\" content=\"#FFFFFF\">\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\" />\n<meta http-equiv=\"Content-Type\" content=\"text/html; charset=utf-8\" />\n<meta http-equiv=\"content-language\" content=\"ja\" />\n<meta http-equiv=\"content-style-type\" content=\"text/css\" />\n<meta http-equiv=\"content-script-type\" content=\"text/javascript\" />\n<link rel=\"icon\" type=\"image/svg+xml\" href=\"/build/images/common/favicon.svg\">\n\n<title>新卒採用 | 採用サイト | キッセイ薬品工業株式会社</title>\n<meta name=\"description\" content=\"キッセイ薬品の新卒採用・募集要項についてご紹介します。\">\n<link rel=\"canonical\" href=\"https://recruit.kissei.co.jp/graduate/\">\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/build/css/style.css?v=c81bf28605e3d931df95a27a8b337d901b35f8f6\"><meta property=\"og:type\" content=\"website\">\n<meta property=\"og:title\" content=\"新卒採用 | 採用サイト | キッセイ薬品工業株式会社\">\n<meta property=\"og:description\" content=\"キッセイ薬品の新卒採用・募集要項についてご紹介します。\">\n<meta property=\"og:url\" content=\"https://recruit.kissei.co.jp/graduate/\">\n<meta property=\"og:image\" content=\"https://recruit.kissei.co.jp/build/images/common/ogimage.png\">\n<meta property=\"og:locale\" content=\"ja_JP\">\n<meta property=\"og:site_name\" content=\"\">\n<meta name=\"twitter:title\" content=\"新卒採用 | 採用サイト | キッセイ薬品工業株式会社\">\n<meta name=\"twitter:description\" content=\"キッセイ薬品の新卒採用・募集要項についてご紹介します。\">\n<meta name=\"twitter:card\" content=\"summary_large_image\">\n<meta name=\"twitter:image\" content=\"https://recruit.kissei.co.jp/build/images/common/ogimage.png\">\n<!-- Google tag (gtag.js) -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-L0F77M9