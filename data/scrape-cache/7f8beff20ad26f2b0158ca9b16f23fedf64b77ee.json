;</script>\r\n  <!-- End Google Tag Manager -->\r\n</head>\r\n\r\n<body>\r\n  <!-- Google Tag Manager (noscript) -->\r\n  <noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-P8XXC67\" height=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\r\n  <!-- End Google Tag Manager (noscript) -->\r\n\r\n  <div id=\"header\"></div>\r\n  <script>\r\n    $(function () {\r\n      $('#header').load('https://www.tepco-sa.co.jp/ssl/src/inc/header.html');\r\n    });\r\n  </script>\r\n\r\n  <div class=\"page-wrapper career-graduate-page career-mid-career-page\">\r\n    <div class=\"main-container bg-transparent p-0 mb-5\">\r\n      <nav aria-label=\"breadcrumb\" class=\"page-breadcrumb\">\r\n        <ol class=\"breadcrumb mb-0\">\r\n          <li class=\"breadcrumb-item\"><a href=\"https://www.tepco-sa.co.jp/ssl/\">ホーム</a></li>\r\n          <li class=\"breadcrumb-item\"><a href=\"https://www.tepco-sa.co.jp/ssl/recruit/\">採用情報</a></li>\r\n          <li class=\"breadcrumb-item active\" aria-current=\"page\">キャリア採用</li>\r\n        </ol>\r\n      </nav>\r\n    </div>\r\n    <div class=\"main-container\">\r\n      <div class=\"heading-wrapper\">\r\n        <div class=\"heading\">\r\n          <div class=\"sc-title text-center\">キャリア採用</div>\r\n          <div class=\"sub-title text-center text-uppercase\">Career recruitment</div>\r\n        </div>\r\n      </div>\r\n      <div class=\"link-wrapper mb-5\">\r\n        <div class=\"row justify-content-center\">\r\n          <div class=\"col-12 col-sm-6 col-xl-4\">\r\n            <a href=\"#link1\" class=\"d-flex justify-content-center align-items-center\">\r\n              募集中のおしごと\r\n              <svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"currentColor\">\r\n                <path d=\"M13.0001 16.1716L18.3641 10.8076L19.7783 12.2218L12.0001 20L4.22192 12.2218L5.63614 10.8076L11.0001 16.1716V4H13.0001V16.1716Z\">\r\n                </path>\r\n              </svg>\r\n            </a>\r\n          </div>\r\n          <div class=\"col-12 col-sm-6 col-xl-4\">\r\n            <a href=\"#link2\" class=\"d-flex justify-content-center align-items-center\">\r\n              採用までの流れ\r\n              <svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"currentColor\">\r\n                <path d=\"M13.0001 16.1716L18.3641 10.8076L19.7783 12.2218L12.0001 20L4.22192 12.2218L5.63614 10.8076L11.0001 16.1716V4H13.0001V16.1716Z\">\r\n                </path>\r\n              </svg>\r\n            </a>\r\n          </div>\r\n        </div>\r\n      </div>\r\n      <div class=\"intro-wrapper\">\r\n        <div class=\"side-label fw-bold\" id=\"link1\">募集中のおしごと</div>\r\n        <div class=\"row row-gap-3\">\r\n          <div class=\"col-12 col-lg-auto\">\r\n            <div class=\"left-image img-wrapper\">\r\n              <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/career/career-contract-bg2.jpg\" alt=\"career-contract-bg\" style=\"border-radius: 12px;\">\r\n            </div>\r\n          </div>\r\n          <div class=\"col\">\r\n            <div class=\"info-right\">\r\n              <div class=\"para-text\">\r\n                求人を行っている仕事のご紹介となります。<br>\r\n                ご希望の業務がありましたら、お気軽にご応募ください。\r\n              </div>\r\n              <a href=\"https://www.tepco-sa.co.jp/ssl/recruit/career/job_offer/\" class=\"intro-btn btn-detail-orange me-auto me-md-0 ms-auto btnn btnn-orange arrow-fill\">\r\n                くわしくはこちら\r\n              </a>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n      <div class=\"recruitment-wrapper fw-normal para-text\">\r\n        <div class=\"side-label fw-bold\" id=\"link2\">採用までの流れ</div>\r\n\r\n        <div class=\"row row-gap-3 align-items-center\">\r\n          <div class=\"col-12 col-sm-auto\">\r\n            <div class=\"img-wrapper left-image\">\r\n              <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/career/step-recruitment-1.png\" alt=\"recruitment-img\">\r\n            </div>\r\n          </div>\r\n          <div class=\"col\">\r\n            <div>\r\n              ご希望の募集情報がござましたら当ホームページ「応募する」ボタンから必要事項をご記入のうえご応募ください。\r\n            </div>\r\n          </div>\r\n        </div>\r\n        <div class=\"row row-gap-3 align-items-center\">\r\n          <div class=\"col-12 col-sm-auto\">\r\n            <div class=\"img-wrapper left-image\">\r\n              <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/career/step-recruitment-2.png\" alt=\"recruitment-img\">\r\n            </div>\r\n          </div>\r\n          <div class=\"col\">\r\n            <div>\r\n              履歴書・職務経歴書を送付いただき、面接にお越しいただく方を選考いたします。<br>\r\n              選考を通過された方には面接日時などの詳細をご連絡いたします。<br>\r\n              ※書類選考に1週間程度お時間をいただいております。\r\n            </div>\r\n          </div>\r\n        </div>\r\n        <div class=\"row row-gap-3 align-items-center\">\r\n          <div class=\"col-12 col-sm-auto\">\r\n            <div class=\"img-wrapper left-image\">\r\n              <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/career/step-recruitment-career-mid-career-3.png\" alt=\"recruitment-img\">\r\n            </div>\r\n          </div>\r\n          <div class=\"col\">\r\n            <div>\r\n              業務内容のご説明と面接を実施いたします。<br>\r\n              業務内容に関することなど確認したいことがございましたら面接の際にお聞きください。\r\n            </div>\r\n          </div>\r\n        </div>\r\n        <div class=\"row row-gap-3 align-items-center\">\r\n          <div class=\"col-12 col-sm-auto\">\r\n            <div class=\"img-wrapper left-image\">\r\n              <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/career/step-recruitment-4.png\" alt=\"recruitment-img\">\r\n            </div>\r\n          </div>\r\n          <div class=\"col\">\r\n            <div>\r\n              1次面接の選考を通過された方は２次面接の詳細をご連絡いたします。\r\n            </div>\r\n          </div>\r\n        </div>\r\n        <div class=\"row row-gap-3 align-items-center\">\r\n          <div class=\"col-12 col-sm-auto\">\r\n            <div class=\"img-wrapper left-image\">\r\n              <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/career/step-recruitment-career-mid-career-5.png\" alt=\"recruitment-img\">\r\n            </div>\r\n          </div>\r\n          <div class=\"col\">\r\n            <div>\r\n              2次面接の選考結果メールを送らせていただきます。<br>\r\n              採用の場合は、入社手続き等についても併せてご案内いたします。\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n      <div class=\"cta\">\r\n        <div class=\"title text-center text-orange fw-bold\">ご応募(面接予約)・ご登録</div>\r\n        <div class=\"text-center fw-bold\">現在募集をかけている求人に<br class=\"d-md-none\">応募したい方はこちら</div>\r\n        <a href=\"https://www.tepco-sa.co.jp/ssl/recruit/privacypolicy_03/\" class=\"cta-btn mx-auto btnn btnn-green arrow-fill d-flex align-items-center justify-content-center\">\r\n          <div class=\"icon-contract img-wrapper\">\r\n            <img class=\"contain\" src=\"https://www.tepco-sa.co.jp/ssl/images/icons/icon-contract.png\" alt=\"icon-contract\">\r\n          </div>\r\n          <div>応募する</div>\r\n        </a>\r\n      </div>\r\n    </div>\r\n  </div>\r\n  <!-- main-content -->\r\n\r\n  <div id=\"footer\"></div>\r\n  <script defer>\r\n    $(function () {\r\n      $('#footer').load('https://www.tepco-sa.co.jp/ssl/src/inc/footer.html');\r\n    });\r\n  </script>\r\n  <script src=\"https://www.tepco-sa.co.jp/ssl/src/js/popper.min.js\"></script>\r\n  <script src=\"https://www.tepco-sa.co.jp/ssl/src/js/bootstrap.min.js\"></script>\r\n  <script src=\"https://www.tepco-sa.co.jp/ssl/src/js/slick.js\"></script>\r\n  <script src=\"https://www.tepco-sa.co.jp/ssl/src/js/jquery.matchHeight-min.js\"></script>\r\n  <script src=\"https://www.tepco-sa.co.jp/ssl/src/js/custom.js\"></script>\r\n</body>\r\n\r\n</html>","finalUrl":"https://www.tepco-sa.co.jp/ssl/recruit/career/","rendered":false,"_cachedAt":"2026-06-22T21:08:11.051Z"}