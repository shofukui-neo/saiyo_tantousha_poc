title\" content=\"マンアップ\">\n<link rel=\"icon\" href=\"https://man-up.co.jp/wp-content/themes/manup/img/common/favicon-192x192.png\" sizes=\"192x192\" type=\"image/png\">\n<!-- /icon -->\n\n<!-- vendor -->\n<script src=\"https://man-up.co.jp/wp-content/themes/manup/js/jquery.min.js\"></script>\n<script src=\"https://man-up.co.jp/wp-content/themes/manup/js/underscore-min.js\"></script>\n<link rel=\"stylesheet\" href=\"https://man-up.co.jp/wp-content/themes/manup/css/uikit.min.css\">\n<script src=\"https://man-up.co.jp/wp-content/themes/manup/js/uikit.min.js\"></script>\n<!-- /vendor -->\n\n<!-- css -->\n<link rel=\"stylesheet\" href=\"https://man-up.co.jp/wp-content/themes/manup/css/manup.css?ver=20251204\">\n<!-- /css -->\n\n</head>\n<body class=\"home page-template-default page page-id-139 page-home page-%e3%83%88%e3%83%83%e3%83%97%e3%83%9a%e3%83%bc%e3%82%b8\">\n<!-- Google Tag Manager -->\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n})(window,document,'script','dataLayer','GTM-P8R6G6L');</script>\n<!-- End Google Tag Manager -->\n\n<div id=\"wrapper\">\n\n<header id=\"header\" class=\"header uk-container uk-flex uk-flex-middle\">\n  <div class=\"header-logo\"><a href=\"https://man-up.co.jp\"><img src=\"https://man-up.co.jp/wp-content/themes/manup/img/common/logo_01.png\" srcset=\"https://man-up.co.jp/wp-content/themes/manup/img/common/logo_01.svg\" alt=\"株式会社マンアップ\"></a></div>\n  <a href=\"#offcanvas\" class=\"header-menu-btn uk-hidden-larges\" data-uk-offcanvas>\n    <img src=\"https://man-up.co.jp/wp-content/themes/manup/img/common/btn_menu.svg\" alt=\"メニュー\">\n  </a>\n</header><!-- /#header -->\n\n\n<main id=\"main\">\n\n<div id=\"keyvisual\" class=\"keyvisual home uk-cover uk-position-relative\">\n  <div class=\"keyvisual-inner uk-container\">\n    <div class=\"home-tit-01\">\n      <h2 class=\"tit\">私たちは、<br class=\"display-sp\">未来の人と社会の<br class=\"display-sp\">架け橋として<br>貢献する<br class=\"display-sp\">リソースカンパニーです。</h2>\n      <p class=\"text\">\n        <span class=\"text-cover\">人を想い、未来を創る。人材の力で、企業の挑戦を支える。</span><br>\n        <span class=\"text-cover\">販促ビジネスを加速させる。人材×販促＋物流で現場力を最大化。</span><br>\n        <span class=\"text-cover\">軽作業から検査業務まで。「任せてよかった」をすべての現場に。</span>\n      </p>\n    </div><!-- /.home-tit-01 -->\n\n    <a href=\"#home-01\" class=\"keyvisual-scrollicon\" data-uk-smooth-scroll><i></i></a><!-- /.keyvisual-scrollicon -->\n\n    <ul class=\"keyvisual-anchor uk-flex uk-flex-centetr uk-flex-wrap\">\n      <li><a class=\"com-link-02\" href=\"#home-01\" data-uk-smooth-scroll>SERVICE</a></li>\n      <li><a class=\"com-link-02\" href=\"#home-02\" data-uk-smooth-scroll>COMPANY</a></li>\n      <li><a class=\"com-link-02\" href=\"#home-03\" data-uk-smooth-scroll>INFORMATION</a></li>\n    </ul>\n    <!-- /.keyvisual-anchor -->\n  </div><!-- /.keyvisual-inner -->\n\n  <img class=\"uk-invisible\" src=\"https://man-up.co.jp/wp-content/themes/manup/img/home/poster_01.jpg\" width=\"1600\" height=\"800\" alt=\"\">\n  <video class=\"keyvisual-cover uk-cover-object uk-position-absolute\" poster=\"https://man-up.co.jp/wp-content/themes/manup/img/home/poster_01.jpg\" muted autoplay loop playsinline>\n    <source src=\"https://man-up.co.jp/wp-content/themes/manup/img/home/movie_01.mp4\" type=\"video/mp4\">\n    <source src=\"https://man-up.co.jp/wp-content/themes/manup/img/home/movie_01.mov\" type=\"video/mov\">\n  </video><!-- /.keyvisual-cover -->\n</div><!-- /#keyvisual -->\n\n\n<section id=\"home-01\" class=\"com-section\">\n  <h2 class=\"com-tit-01\" data-uk-scrollspy=\"{cls:'uk-animation-fade'}\">SERVICE<em class=\"sub\">事業案内</em></h2>\n\n  <div class=\"home-layout-01\">\n    <div class=\"home-panel-01 blue\" data-uk-scrollspy=\"{cls:'uk-animation-fade'}\">\n      <div class=\"uk-flex\">\n        <div class=\"img img-cover\"><img src=\"https://man-up.co.jp/wp-content/themes/manup/img/home/01_01.jpg\" alt=\"\"></div>\n        <div class=\"img img-cover\"><img src=\"https://man-up.co.jp/wp-content/themes/manup/img/home/01_02.jpg\" alt=\"\"></div>\n      </div>\n      <div class=\"detail\">\n        <h3 class=\"com-tit-01 medium home-tit-02\"><a href=\"https://man-up.co.jp/sales/\">\n          Sales <b>PROMOTION</b>\n          <em class=\"sub\"><span class=\"com-link-01\">販促支援事業</span></em>\n        </a></h3>\n        <p class=\"text bold\">デモ販売などの販促業務を支援。人材派遣事業、ロジスティクス事業を活用したワンストップサービスにより、他社の追従を許さないサービスを提供いたします。</p>\n      </div>\n    </div><!-- /.home-panel-01 -->\n    <div class=\"uk-text-center uk-margin-top\">\n      <a href=\"https://man-up.co.jp/sales-promotion\" class=\"com-link-01\">販売促進特設ページはこちら</a>\n    </div>\n  </div><!-- /.home-layout-01 -->\n\n  <div class=\"home-layout-02 uk-flex\" data-uk-grid-match=\"{target:'.js-height'}\">\n    <div class=\"home-panel-02\" data-uk-scrollspy=\"{cls:'uk-animation-fade'}\">\n      <div class=\"img img-cover\"><img src=\"https://man-up.co.jp/wp-content/themes/manup/img/home/02_01.jpg\" alt=\"\"></div>\n      <div class=\"detail-wrap\">\n        <div class=\"detail js-height\">\n          <h3 class=\"com-tit-01 medium home-tit-02\"><a href=\"https://man-up.co.jp/dispatch/\">\n            <b>TEMPORARY</b> Staffing\n            <em class=\"sub\"><span class=\"com-link-01\">人材派遣事業</span></em>\n          </a></h3>\n          <p class=\"text\">40年の実績。お客様のニーズを的確に判断し、新しい人材活用を提案し、常にお客様のベストパートナーである事を目指します。</p>\n        </div>\n      </div>\n    </div><!-- /.home-panel-02 -->\n\n    <div class=\"home-panel-02\" data-uk-scrollspy=\"{cls:'uk-animation-fade'}\">\n      <div class=\"img img-cover\"><img src=\"https://man-up.co.jp/wp-content/themes/manup/img/home/02_02.jpg\" alt=\"\"></div>\n      <div class=\"detail-wrap\">\n        <div class=\"detail js-height\">\n          <h3 class=\"com-tit-01 medium home-tit-02\"><a href=\"https://man-up.co.jp/logistics/\">\n            <b>LOGISTICS</b> Service\n            <em class=\"sub\"><span class=\"com-link-01\">ロジスティクス事業</span></em>\n          </a></h3>\n          <p class=\"text\">入庫から梱包、配送、人材手配までの全てを一元管理。煩雑で手間のかかる作業を、一貫してお任せいただけます。</p>\n        </div>\n      </div>\n    </div><!-- /.home-panel-02 -->\n  </div><!-- /.home-layout-02 -->\n\n\n  <div class=\"home-layout-03\">\n    <div class=\"home-panel-02 blue\">\n      <div class=\"img img-cover medium\" data-uk-scrollspy=\"{cls:'uk-animation-fade'}\"><img\n          src=\"./wp-content/themes/manup/img/home/03_01.jpg\" alt=\"業務請負/業務委託\"></div>\n      <div class=\"detail\">\n        <h3 class=\"com-tit-01 medium home-tit-02\"><a href=\"https://man-up.co.jp/businesscontract/\">\n            <b>BUISINESS</b> Contract\n            <em class=\"sub\"><span class=\"com-link-01\">業務請負/業務委託</span></em>\n          </a></h3>\n        <p class=\"text\">自社倉庫内、企業様倉庫内での軽作業業務を請負いたします。</p>\n      </div>\n    </div><!-- /.home-panel-02 -->\n  </div><!-- /.home-layout-03 -->\n\n  <div class=\"home-layout-04\">\n    <div class=\"home-panel-02\" data-uk-scrollspy=\"{cls:'uk-animation-fade'}\">\n      <div class=\"img img-cover medium\"><img src=\"https://man-up.co.jp/wp-content/themes/manup/img/home/04_01.jpg\" alt=\"\"></div>\n      <div class=\"detail\">\n        <h3 class=\"com-tit-01 medium home-tit-02\"><a href=\"https://man-up.co.jp/nursery/\">\n          <b>CHILDCARE</b> Services\n          <em class=\"sub\"><span class=\"com-link-01\">知育・保育業務</span></em>\n        </a></h3>\n        <p class=\"text\">思考力と人間力を育む知能教育と受験対策の幼児教室の運営、質の高い知育・保育体制で病院内保育の運営支援を行っています。</p>\n      </div>\n    </div><!-- /.home-panel-02 -->\n  </div><!-- /.home-layout-04 -->\n</section><!-- /#home-01 -->\n\n\n<section id=\"home-02\" class=\"com-section\">\n  <h2 class=\"com-tit-01\" data-uk-scrollspy=\"{cls:'uk-animation-fade'}\">COMPANY<em class=\"sub\">企業情報</em></h2>\n\n  <div class=\"uk-container\">\n    <ul 