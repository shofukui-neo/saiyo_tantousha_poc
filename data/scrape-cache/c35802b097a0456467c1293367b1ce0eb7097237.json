orm\"><div class=\"inquiry_item\"><h2 class=\"req\"><span>гҒ”еҚ”еҠӣгҒ„гҒҹгҒ гҒ‘гӮӢгғ“гӮёгғҚгӮ№еҲҶйҮҺ</span></h2><p><label class=\"checkbox\"><input type=\"checkbox\" name=\"inquiry_businessfields\" value=\"гӮ·гӮ№гғҶгғ й–Ӣзҷә\">гӮ·гӮ№гғҶгғ й–Ӣзҷә</label></p><p><label class=\"checkbox\"><input type=\"checkbox\" name=\"inquiry_businessfields\" value=\"гӮӨгғігғ•гғ©е°Һе…Ҙгғ»ж§ӢзҜү\">гӮӨгғігғ•гғ©е°Һе…Ҙгғ»ж§ӢзҜү</label></p><p><label class=\"checkbox\"><input type=\"checkbox\" name=\"inquiry_businessfields\" value=\"жӨңиЁјгғ»иҮӘеӢ•еҢ–\">жӨңиЁјгғ»иҮӘеӢ•еҢ–</label></p><p><label class=\"checkbox\"><input type=\"checkbox\" name=\"inquiry_businessfields\" value=\"гҒқгҒ®д»–\">гҒқгҒ®д»–</label></p></div><div class=\"inquiry_item\"><h2 class=\"req\"><span>дёҠиЁҳгӮ’йҒёжҠһгҒ—гҒҹзҗҶз”ұпјҸиІҙзӨҫPR</span></h2><textarea name=\"inquiry_businessfields-reason\" placeholder=\"дёҠиЁҳгӮ’йҒёжҠһгҒ—гҒҹзҗҶз”ұгӮ„иІҙзӨҫгҒ«гҒӨгҒ„гҒҰгҒ®PRгӮ’е…ҘеҠӣгҒ—гҒҰгҒҸгҒ гҒ•гҒ„пјҲ500ж–Үеӯ—д»ҘеҶ…пјү\" rows=\"6\"></textarea></div><div class=\"inquiry_item\"><h2 class=\"req\"><span>иІҙзӨҫжӢ зӮ№пјҸгҒ”еҜҫеҝңеҸҜиғҪгҒӘгӮЁгғӘгӮў</span></h2><p><label class=\"checkbox\"><input type=\"checkbox\" name=\"inquiry_office\" value=\"й–ўжқұ\">й–ўжқұ</label></p><p><label class=\"checkbox\"><input type=\"checkbox\" name=\"inquiry_office\" value=\"еҗҚеҸӨеұӢ\">еҗҚеҸӨеұӢ</label></p><p><label class=\"checkbox\"><input type=\"checkbox\" name=\"inquiry_office\" value=\"еӨ§йҳӘ\">еӨ§йҳӘ</label></p><p><label class=\"checkbox\"><input type=\"checkbox\" name=\"inquiry_office\" value=\"еҜҢеұұ\">еҜҢеұұ</label></p><p><label class=\"checkbox\"><input type=\"checkbox\" name=\"inquiry_office\" value=\"зҰҸеІЎ\">зҰҸеІЎ</label></p></div><div class=\"inquiry_item\"><h2 class=\"req\"><span>иІҙзӨҫжҠҖиЎ“иҖ…ж•°</span></h2><input type=\"text\" name=\"inquiry_employees\" placeholder=\"дҫӢпјү150\" value=\"\"></div><div class=\"inquiry_item\"><h2 class=\"req\"><span>иІҙзӨҫгӮөгӮӨгғҲURL</span></h2><input type=\"text\" name=\"inquiry_url\" placeholder=\"дҫӢпјүhttps://www.cec-ltd.co.jp/\" value=\"\"></div><div class=\"inquiry_item\"><h2 class=\"req\"><span>дјҡзӨҫеҗҚ</span></h2><input type=\"text\" name=\"inquiry_company_name_required\" placeholder=\"дјҡзӨҫеҗҚгӮ’е…ҘеҠӣгҒ—гҒҰгҒҸгҒ гҒ•гҒ„\" value=\"\"></div><div class=\"inquiry_item\"><h2 class=\"req\"><span>йғЁзҪІеҗҚ</span></h2><input type=\"text\" name=\"inquiry_department_name_required\" placeholder=\"йғЁзҪІеҗҚгӮ’е…ҘеҠӣгҒ—гҒҰгҒҸгҒ гҒ•гҒ„\" value=\"\"></div><div class=\"inquiry_item\"><h2 class=\"req\"><span>гҒҠеҗҚеүҚ</span></h2><input type=\"text\" name=\"inquiry_name_required\" placeholder=\"гҒҠеҗҚеүҚгӮ’е…ҘеҠӣгҒ—гҒҰгҒҸгҒ гҒ•гҒ„\" value=\"\"></div><div class=\"inquiry_item\"><h2 class=\"req\"><span>гғЎгғјгғ«гӮўгғүгғ¬гӮ№</span></h2><input type=\"text\" name=\"inquiry_email_required\" placeholder=\"дҫӢпјүinfo@example.com\" value=\"\"></div><div class=\"inquiry_item\"><h2 class=\"req req--not\"><span>йӣ»и©ұз•ӘеҸ·</span></h2><input type=\"tel\" name=\"inquiry_tel\" placeholder=\"дҫӢпјү0357892441\" value=\"\"></div><div class=\"inquiry_item\">\r<h2 class=\"req req--not\"><span>гҒ”дҪҸжүҖ</span></h2>\r</div>\r<div class=\"inquiry_item\"><h3><span>йғөдҫҝз•ӘеҸ·</span></h3><input type=\"tel\" name=\"inquiry_postcode\" placeholder=\"дҫӢпјү1500022\" value=\"\"></div><div class=\"inquiry_item\"><h3><span>йғҪйҒ“еәңзңҢ</span></h3><div class=\"select--select\"><select name=\"inquiry_prefecture\"><option value=\"\" selected=\"selected\">йҒёжҠһгҒ—гҒҰгҒҸгҒ гҒ•гҒ„</option><option value=\"еҢ—жө·йҒ“\">еҢ—жө·йҒ“</option><option value=\"йқ’жЈ®зңҢ\">йқ’жЈ®зңҢ</option><option value=\"еІ©жүӢзңҢ\">еІ©жүӢзңҢ</option><option value=\"е®®еҹҺзңҢ\">е®®еҹҺзңҢ</option><option value=\"з§Ӣз”°зңҢ\">з§Ӣз”°зңҢ</option><option value=\"еұұеҪўзңҢ\">еұұеҪўзңҢ</option><option value=\"зҰҸеі¶зңҢ\">зҰҸеі¶зңҢ</option><option value=\"иҢЁеҹҺзңҢ\">иҢЁеҹҺзңҢ</option><option value=\"ж ғжңЁзңҢ\">ж ғжңЁзңҢ</option><option value=\"зҫӨйҰ¬зңҢ\">зҫӨйҰ¬зңҢ</option><option value=\"еҹјзҺүзңҢ\">еҹјзҺүзңҢ</option><option value=\"еҚғи‘үзңҢ\">