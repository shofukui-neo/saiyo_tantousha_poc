{"url":"http://www.greenmessage.co.jp/","html":"<!doctype html>\n<html lang=\"ja\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"description\" content=\"生産者、ユーザー、消費者の想いをつないでまいります。グリーンメッセージは生産技術や商品開発に注力したサラダメーカーです。\">\n<meta name=\"Keywords\" content=\"グリーンメッセージ, サラダ, 野菜工場, 食生活, キユーピー\" />\n<meta name=\"viewport\" content=\"width=device-width\">\n<title>グリーンメッセージ ホームページ ｜ グリーンメッセージ</title>\n<link rel=\"stylesheet\" media=\"all\" href=\"./css/common/common.css\">\n<link rel=\"stylesheet\" media=\"all\" href=\"./css/top/style.css\">\n<script src=\"https://ajax.googleapis.com/ajax/libs/jquery/1.8.0/jquery.min.js\"></script>\n<!--link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/bxslider/4.2.12/jquery.bxslider.css\">\n<script src=\"https://cdn.jsdelivr.net/bxslider/4.2.12/jquery.bxslider.min.js\"></script> -->\n<script src=\"./js/script.js\"></script>\n<script src=\"./js/fitie.js\"></script>\n    <style>\n        .topic_text dl {\n            line-height: 1.4;\n            overflow: hidden;\n            font-size: 90%;\n        }\n        .topic_text dl dt {\n            float:left;\n            width:25%;\n        }   \n            \n        .topic_text dl dd {\n            margin-bottom: 20px;\n            width:75%;\n            float:left;\n            }   \n\n  @media only screen and (min-width : 599px ) {    \n         .topic_text dl {\n             overflow: hidden;  \n             font-size: 85%;\n        }\n        .topic_text dl dt {\n            width:23%;\n            font-size: 100%;\n        }\n        \n        .topic_text dl dd {\n            width:77%;\n        }\n  }\n</style>\n</head>\n\n<body>\n<div id=\"wrapper\">\n<div id=\"sidebar\">\n<div id=\"sidebarWrap\">\n<nav id=\"mainnav\">\n<p id=\"menuWrap\"><a id=\"menu\"><span id=\"menuBtn\"></span></a></p>\n<div class=\"panel\">\n<ul>\n<li><a href=\"./company/about_greenmessage.html\"><b>会社案内</b></a></li>\n<li><a href=\"./effort/resource.html\"><b>とりくみ</b></a></li>\n<li><a href=\"./commit/delicious.html\"><b>こだわり</b></a></li>\n<li><a href=\"./department/production.html\"><b>部署紹介</b></a></li>\n<li>\n<a href=\"./recruit/new_graduate.html\">\n<span class=\"recruit\">\n<b>採用情報</b>\n</span>\n</a>\n</li>\n</ul>\n</div>\n</nav>\n</div>\n</div>\n\n<header id=\"header\">\n\n<!--div class=\"slider\"-->\n<div class=\"header-img\">\n<img src=\"images/top/img_main_slide_01.png\">   <!--トップページのキービジュアル部分の画像-->\n</div>\n<!--/div-->\n\n<div id=\"slogan\">\n<img src=\"images/top/img_top_logo_greenmessage.png\">\n</div>\n</header>\n\n\n<!-- グリーンメッセージとは -->\n<section id=\"sec01\">\n<!--div class=\"about_gm\">\n<img src=\"images/top/img_top_logo_aboutus.png\" class=\"img_top_about_gm\">\n<br />\n<img src=\"images/common/img_line_wave.png\" class=\"Img_wave\">\n</div-->\n\n<div class=\"vision\">\n<p><img src=\"images/top/img_top_companylogopc.png\" class=\"img_top_companylogo\" /></p>\n<div>まごころを込めて安全で<br>\n    おいしい国産野菜をお届けします</div>\n<a href=\"./company/about_greenmessage.html\"><img src=\"images/top/btn_top_more.png\" class=\"more_b\"></a>\n</div>\n</section>\n<!-- // グリーンメッセージとは -->\n\n<!-- 下層４ブロック -->\n<section id=\"sec02\">\n<!-- 画像1 -->\n<div class=\"block\" id=\"left\">\n<img src=\"images/top/img_top_picture_left.png\">\n</div>\n<div class=\"block\" id=\"left\">\n<div class=\"txt\">\n<div class=\"under_title\">\n<img src=\"images/top/img_top_logo_topics.png\" class=\"img_top_contact\"><br />\n    <!--img src=\"images/common/img_line_wave.png\" class=\"Img_wave\"-->\n</div>\n<div class=\"topic_text\">\n<dl>\n<dt>2022年3月17日</dt>\n<dd><a href=\"pdf/actionplan2.pdf\" target=\"_blank\">女性活躍推進法の一般事業主行動計画</a>を策定しました。</dd>\n<dt>2022年3月1日</dt>\n<dd>2023年度入社の新卒採用につきましては<br />\n               実施を見送らせていただきます。</dd>\n\n<dt>2021年8月1日</dt>\n<dd><a href=\"pdf/actionplan1.pdf\" target=\"_blank\">次世代育成支援対策推進法の一般事業主行動計画</a>を策定しました。\n</dd>\n\n<dt>2021年7月10日</dt>\n<dd><a href=\"https://www.pref.kanagawa.jp/docs/z4r/heartkigyo_r1.html#seizou\" target=\"_blank\">かながわ障害者雇用ハート企業</a>として掲載されました。</dd>\n<dt>2021年5月20日</dt>\n<dd>メンタルヘルス・マネジメント検定Ⅱ種に<br />\n社員7名が合格しました。</dd>\n<dt>2021年4月1日</dt>\n<dd><a href=\"https://www.tanzawasaisei.jp/\" target=\"_blank\">丹沢大山自然再生委員会</a>へ入会しました。</dd>\n\n<dt>2020年7月16日</dt>\n<dd>メンタルヘルス・マネジメント検定Ⅱ種に<br />社員4名が合格しました。</dd>\n\n\n<dt>2020年3月19日</dt>\n<dd>弊社では保健所のご指導を頂きながら新型<br />コロナウイルス感染予防対策を取っております。</dd>\n\n<!--dt>2020年3月19日</dt>\n<dd>2021年度キユーピーグループ新卒採用サイトが<br />オープンしています。<br />ご登録・エントリーは <a href=\"https://mypage.1050.i-web.jpn.com/kewpiegroup2021/\" target=\"_blank\">こちら</a> まで。</dd-->\n\n</dl>\n<!--合同説明会バナー  <a href=\"https://i-note.co/kewpiegroup/2020/seminar-event.html\" target=\"_blank\"><img src=\"images/top/group-intern2020.PNG\" alt=\"キユーピーグループ合同説明会\"></a>-->\n</div>\n<!-- <div class=\"more\">\n<img src=\"images/top/more_w.png\">\n</div>\n --></div>\n</div>\n<div class=\"clearfix\"></div>\n<!-- 画像2 -->\n<div class=\"block\" id=\"right\">\n<img src=\"images/top/img_top_picture_right.png\">\n</div>\n<!-- トピックス -->\n<div class=\"block\" id=\"right\">\n<div class=\"txt\">\n<div class=\"under_title\">\n<img src=\"images/top/img_top_logo_contact.png\" class=\"img_top_contact\"><br />\n<!--img src=\"images/common/img_line_wave.png\" class=\"Img_wave\"-->\n</div>\n<div class=\"contact_text\">\nグリーンメッセージへのお問い合わせはこちらから\n</div>\n<div class=\"contact\">\n                    株式会社グリーンメッセージ<br>\n                    <dl>\n                        <dt>本社</dt><dd>〒242-0001<br>\n                        神奈川県大和市下鶴間2415</dd>\n                    \n                        <dt>メール</dt>　<dd>ml_greenmessagereception@kewpie.co.jp</dd>\n                        </dl>\n</div>\n<a href=\"https://goo.gl/maps/NjT4B4b8KN4E1qvU6\" target=\"_blank\"><img src=\"images/top/btn_top_map.png\" class=\"more_b\"></a>\n</div>\n</div>\n<div class=\"clearfix\"></div>\n</section>\n<!-- // 下層４ブロック -->\n\n<!-- float解除 -->\n<div class=\"clearfix\"></div>\n\n<!-- フッター -->\n<footer id=\"mainnav_footer\">\n<ul>\n<li><a href=\"site_policy.html\"><b>＞サイトポリシー</b></a></li>\n<li>