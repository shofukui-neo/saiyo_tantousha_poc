{"url":"http://www.princeton.co.jp/recruit","html":"<!DOCTYPE html>\n<html lang=\"ja\" dir=\"ltr\" prefix=\"og: https://ogp.me/ns#\">\n  <head>\n    <meta charset=\"utf-8\" />\n<meta name=\"description\" content=\"プリンストンの現在の採用情報を掲載しています。\" />\n<link rel=\"canonical\" href=\"http://www.princeton.co.jp/recruit\" />\n<meta property=\"og:site_name\" content=\"株式会社プリンストン\" />\n<meta property=\"og:url\" content=\"http://www.princeton.co.jp/recruit\" />\n<meta property=\"og:title\" content=\"採用情報トップ\" />\n<meta property=\"og:description\" content=\"HOME 採用情報 RECRUIT 採用情報 プリンストンでは以下の職種を募集しております。ご検討いただく際は職種欄をクリック(タップ)してご覧ください。\" />\n<!-- Google Tag Manager -->\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n})(window,document,'script','dataLayer','GTM-NSPM7P');</script>\n<!-- End Google Tag Manager --><meta name=\"Generator\" content=\"Drupal 10 (https://www.drupal.org)\" />\n<meta name=\"MobileOptimized\" content=\"width\" />\n<meta name=\"HandheldFriendly\" content=\"true\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n<link rel=\"icon\" href=\"/favicon.ico\" type=\"image/vnd.microsoft.icon\" />\n\n    <title>採用情報 | 株式会社プリンストン</title>\n    <link rel=\"stylesheet\" media=\"all\" href=\"/sites/default/files/css/css_A3pk3Fkm8AgX0knm0O1SJm1_Sd6akCemPmdhE5EYE-k.css?delta=0&amp;language=ja&amp;theme=princeton&amp;include=eJxNjlEKwzAMQy8UyJGK63olzLFK5A2y0690DPql95A-pC7krKvQiv64Gym78e-B7eww7KTRxdvHisvEK5etUfG2MSvCFF6O0UItEfWBSN58d6xyGywJOKs-ryycTOvXjy-sUjn9\" />\n<link rel=\"stylesheet\" media=\"all\" href=\"/sites/default/files/css/css_mhL336R-1x8CypTI9jDPOf_fsG-bOjoBVC7kYo4Ziag.css?delta=1&amp;language=ja&amp;theme=princeton&amp;include=eJxNjlEKwzAMQy8UyJGK63olzLFK5A2y0690DPql95A-pC7krKvQiv64Gym78e-B7eww7KTRxdvHisvEK5etUfG2MSvCFF6O0UItEfWBSN58d6xyGywJOKs-ryycTOvXjy-sUjn9\" />\n<link rel=\"stylesheet\" media=\"all\" href=\"https://fonts.googleapis.com/css2?family=Kanit:wght@300;400;500;600;700&amp;family=Noto+Sans+JP:wght@300;400;500;700&amp;family=Roboto+Condensed:wght@300&amp;display=swap\" />\n<link rel=\"stylesheet\" media=\"all\" href=\"/static/css/custom.css\" />\n\n    \n  </head>\n  <body class=\"path-node page-node-type-page\">\n        <a href=\"#main-content\" class=\"visually-hidden focusable skip-link\">\n      メインコンテンツに移動\n    </a>\n    <!-- Google Tag Manager (noscript) -->\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-NSPM7P\"\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n<!-- End Google Tag Manager (noscript) -->\n      <div class=\"dialog-off-canvas-main-canvas\" data-off-canvas-main-canvas>\n    <div class=\"l-wrapper\">\n  <header class=\"l-header\">\n    <div class=\"header\">\n      <div class=\"header_inner\">\n  <p class=\"header_logo\">\n  <a href=\"/\" rel=\"home\"><img src=\"/themes/princeton/images/common/logo.svg\" alt=\"Princeton\" width=\"184\" height=\"30\"></a>\n</p>\n<nav class=\"header_navigation\">\n  \n              <ul class=\"gnavigation-primary\">\n            <li>\n              <button>\n          <span>\n            <span class=\"back\" area-hidden=\"true\">ソリューション</span>\n            <span class=\"front\">ソリューション</span>\n            <span class=\"transparent\" area-hidden=\"true\">ソリューション</span>\n          </span<\n        </button>\n                    </li>\n        <li>\n              <button>\n          <span>\n            <span class=\"back\" area-hidden=\"true\">デジタル製品</span>\n            <span class=\"front\">デジタル製品</span>\n            <span class=\"transparent\" area-hidden=\"true\">デジタル製品</span>\n          </span<\n        </button>\n                    </li>\n        <li>\n              <button>\n          <span>\n            <span class=\"back\" area-hidden=\"true\">法人のお客様</span>\n            <span class=\"front\">法人のお客様</span>\n            <span class=\"transparent\" area-hidden=\"true\">法人のお客様</span>\n          </span<\n        </button>\n                    </li>\n        <li>\n              <button>\n          <span>\n            <span class=\"back\" area-hidden=\"true\">サポート</span>\n            <span class=\"front\">サポート</span>\n            <span class=\"transparent\" area-hidden=\"true\">サポート</span>\n          </span<\n        </button>\n                    </li>\n        <li>\n              <button>\n          <span>\n            <span class=\"back\" area-hidden=\"true\">ストア</span>\n            <span class=\"front\">ストア</span>\n            <span class=\"transparent\" area-hidden=\"true\">ストア</span>\n          </span<\n        </button>\n                    </li>\n        <li>\n              <button><span><svg viewBox=\"0 0 64 64\" width=\"64\" height=\"64\" class=\"icon-small\"><use xlink:href=\"#icon-search\"></use></svg></button>\n            </li>\n        </ul>\n  \n\n\n</nav>\n<nav>\n  \n              <ul class=\"gnavigation-secondary\">\n              <li>\n                  <a href=\"/support/contacts\" data-drupal-link-system-path=\"node/477\">CONTACT</a>\n        \n              </li>\n          <li>\n                  <a href=\"/news\" data-drupal-link-system-path=\"news\">NEWS</a>\n        \n              </li>\n          <li>\n                  <a href=\"/information\" data-drupal-link-system-path=\"information\">NEW PRODUCTS</a>\n        \n              </li>\n          <li>\n                  <a href=\"/company\" data-drupal-link-system-path=\"node/206\">COMPANY</a>\n        \n              </li>\n          <li>\n                  <a href=\"/recruit\" data-drupal-link-system-path=\"node/1921\" class=\"is-active\" aria-current=\"page\">RECRUIT</a>\n        \n              </li>\n          <li>\n                \n                                <ul class=\"gnavigation-secondary_language js-naviLanguage\">\n              <li>\n                  <a href=\"/\">JP</a>\n        \n              </li>\n          <li>\n                  <a href=\"/en/company\" data-drupal-link-system-path=\"node/555\">EN</a>\n        \n              </li>\n        </ul>\n  \n              </li>\n        </ul>\n  \n\n\n</nav>\n\n</div>\n\n    </div>\n  </header>\n  <div class=\"l-megamenu\" style=\"display: none;\">\n    <div class=\"megamenu\">\n          </div>\n  </div>\n\n  <main role=\"main\" class=\"l-mainContents\">\n    <div data-drupal-messages-fallback class=\"hidden\"></div>\n\n    \n          <div class=\"region region-content\">\n    <div id=\"block-princeton-content\" class=\"block block-system block-system-main-block\">\n  \n    \n      \n<article class=\"node node--type-page node--view-mode-full\">\n\n  <div class=\"l-container\">\n    \n        \n  </div>\n\n  \n  <div class=\"node__content\">\n      <div class=\"layout layout--onecol\">\n    <div  class=\"layout__region layout__region--content\">\n      <div class=\"block block-layout-builder block-field-blocknodepagebody\">\n  \n    \n      \n            <div class=\"clearfix text-formatted field field--name-body field--type-text-with-summary field--label-hidden field__item\"><div class=\"page-contacts\">\n  <div class=\"l-breadcrumbs is-first\">\n    <ol>\n      <li> <a href=\"/\">HOME</a> </li>\n      <li> <span>採用情報</span> </li>\n    </ol>\n  </div>\n  <header class=\"l-pageTitle-text\">\n    <div class=\"l-container\">\n      <div class=\"heading-en\">\n        <div class=\"l-container\">\n          <h1 class=\"heading\">RECRUIT</h1>\n          <p>採用情報</p>\n        </div>\n      </div>\n      <p class=\"fz-copy2 text-center\">プリンストンでは以下の職種を募集しております。ご検討いただく際は職種欄をクリック(タップ)してご覧ください。</p>\n      <!--<section class=\"closed_attention\">\n        <h3></h3>\n        <p></p>\n        <ul class=\"txt_cre\">\n          <li>2023年12月29日(金)～2024年1月3日(水)</li>\n        </ul>\n        <p> </p>\n      </section>--> \n    </div>\n  </header>\n  <section class=\"first_contents_mtshort content_wrapper1300\">\n    <h2 class=\"usual_bothsides_line\"><span>中途採用</span></h2>\n    <div class=\"accordion mt30_15\">\n\t<!-- *****************法人営業始まり***************** -->\n      <div class=\"accordion_option\">\n        <input type=\"checkbox\" id=\"toggle1\" class=\"accordion_toggle\">\n        <label class=\"accordion_title\" for=\"toggle1\">法人営業 (代理店向け/OA機器~最先端会議システムなど幅広い商材)<span class=\"recruit_tokyo\">東京・新橋</span></label>\n        <div class=\"accordion_content\">\n          <dl class=\"rule_table wt95 m_beside_a mb30_15\">\n            <div>\n              <dt>仕事の内容</dt>\n              <dd>\n                <ul class=\"permanentdisc_list\">\n                  <li>既に取引のある代理店に向けた、液晶ディスプレイやUSBメモリ、ICT機器や最先端のビデオ会議システム等の提案営業をお任せします。海外大手メーカーの商材も取り扱いしており、幅広いIT知識が身に付きます。</li>\n                  <li>代理店と信頼関係の構築、デモやプレゼンによる製品・ソリューションの提案、見積もり対応や納期調整、製品勉強会実施や展示会参加・製品導入・設置立ち合い等。社内のテクニカルスタッフやプロモーションスタッフ、営業アシスタント等と連携を取り合いながら仕事を進めていただきます。</li>\n                  <li>商材は一般企業の他、官公庁、医療機関、学校法人等様々な組織で利用され、利便性や生産性向上により働き方改革等に貢献します。</li>\n                  <li>ビデオ会議システムをどのように提案・導入しているのか、働くイメージをつかみたい方は、ぜひご覧ください。<div><dl class=\"shikaku mt10\"><dt>デジタル化の窓口</dt><dd><a href=\"https://digi-mado.jp/article/97950/\" target=\"_blank\">https://digi-mado.jp/article/97950/</a></dd></dl></div></li>\n                </ul>\n              </dd>\n            </div>\n            <div>\n              <dt>必要な能力・経験</dt>\n              <dd>\n                <dl class=\"hishi\">\n                  <dt class=\"txt_pri\">必須</dt>\n                  <dd>\n                    <ul class=\"permanentdisc_list\">\n                      <li>法人営業経験3年以上</li>\n                      <li>PCスキル(Word・Excel・PowerPoint)</li>\n                      <li>普通自動車運転免許(AT限定可)</li>\n                    </ul>\n                  </dd>\n                  <dt class=\"txt_pri\">歓迎</dt>\n                  <dd>\n                    <ul class=\"permanentdisc_list\">\n                      <li>IT商社での営業経験</li>\n                      <li>英語(日常会話レベル)</li>\n                    </ul>\n                  </dd>\n                  <dd> 競合他社も多い中、エンドユーザーのニーズを素早く察知して、自社製品とどまらず、当社代理店と協力して最適な環境をエンドユーザーへ届けることがミッションです。</dd>\n                </dl>\n              </dd>\n            </div>\n            <div>\n              <dt>学歴</dt>\n              <dd><ul class=\"permanentdisc_list\"><li>高校</li><li>専修</li><li>短大</li><li>高専</li><li>大学</li><li>大学院</li></ul></dd>\n            </div>\n            <div>\n              <dt>雇用形態</dt>\n              <dd>正社員(期限の定めはありません)<ul class=\"kome mt0 mb0\"><li class=\"mt0 mb0\">3ヶ月の試用期間あり (試用期間中の条件変更はありません)</li></ul></dd>\n            </div>\n            <div>\n              <dt>勤務地・交通</dt>\n              <dd> 東京都港区新橋4-21-3 新橋東急ビル5F<ul class=\"kome mt0 mb0\"><li class=\"mt0 mb0\">JR・都営浅草線 新橋駅から徒歩2分／東京メトロ銀座線 新橋駅から徒歩3分</li></ul></dd>\n            </div>\n            <div>\n              <dt>勤務時間</dt>\n              <dd>9：00〜17：30（実働7.5時間）</dd>\n            </div>\n            <div>\n              <dt>残業</dt>\n              <dd>有<br>平均残業時間：15時間</dd>\n            </div>\n            <div>\n              <dt>残業手当</dt>\n              <dd>有<br>固定残業代制度あり (※超過分別途支給)<br>固定残業代の相当時間：20.0時間/月</dd>\n            </div>\n            <div>\n              <dt>通勤手当</dt>\n              <dd>会社規程に基づき支給<br>上限：10万円/月</dd>\n            </div>\n            <div>\n              <dt>休日・休暇</dt>\n              <dd>完全週休2日制（土日）、祝日\n                <dl class=\"hishi mt10\">\n                  <dt class=\"txt_pri\">年間休日</dt>\n                  <dd>124日</dd>\n                  <dt class=\"txt_pri\">有給休暇</dt>\n                  <dd>11日(最高付与日数20日)\n                    <ul class=\"kome mt0\">\n                      <li class=\"mt0\">入社後6か月以内の基準日に達したら上記を付与</li>\n                    </ul>\n                  </dd>\n                  <dt class=\"txt_pri\">休暇制度</dt>\n                  <dd>\n                    <ul class=\"permanentdisc_list\">\n                      <li>夏季休暇</li>\n                      <li>年末年始休暇</li>\n                      <li>慶弔休暇</li>\n                      <li>産前・産後休暇</li>\n                      <li>育児休暇</li>\n                    </ul>\n                    <ul class=\"kome\">\n                      <li>上記の年末年始休暇は、12/29～1/3の6日間です。</li>\n                      <li>年間休日以外に別途、夏季休暇として、6月～9月の間で5日間、1日単位で自由に取得できます。</li>\n                    </ul>\n                  </dd>\n                </dl>\n              </dd>\n            </div>\n            <div>\n              <dt>待遇・福利厚生</dt>\n              <dd>\n                <dl class=\"hishi\">\n                  <dt class=\"txt_pri\">保険制度</dt>\n                  <dd>\n                    <ul class=\"permanentdisc_list\">\n                      <li>健康保険</li>\n                      <li>厚生年金</li>\n                      <li>雇用保険</li>\n                      <li>労災保険</li>\n                    </ul>\n                    <ul class=\"permanent_list\">\n                      <li>昇給年1回</li>\n                      <li>賞与年2回</li>\n                      <li>交通費支給(月10万円迄)</li>\n                      <li>iDeco手当：在籍3年以上で月額5000円</li>\n                    </ul>\n                  </dd>\n                </dl>\n                <dl class=\"shikaku mt10\">\n                  <dt class=\"\">その他</dt>\n                  <dd>\n                    <ul class=\"permanentdisc_list\">\n                      <li>社内サークル活動<sup>※</sup>(ゴルフ、ウォーキング、ビール愛好会他)</li>\n                    </ul>\n                    <ul class=\"kome mt0 mb0\">\n                      <li class=\"mb0\">会社補助あり</li>\n                    </ul>\n                  </dd>\n                </dl>\n              </dd>\n            </div>\n          </dl>\n          <div class=\"brock_ac mb50_25 wt80 usual_gray_bg_wrap pt15 pb15 m_beside_a\">\n            <p>ご応募いただく場合は以下のメールアドレス宛に、件名へ「採用の問い合わせ」とご入力のうえ、メールをお送りください。</p>\n            <p class=\"mt10\"><strong>rec-info<span class=\"atplus\">princeton.co.jp</span></strong> (アットマークのみ手入力でお願いします。)</p>\n          </div>\n        </div>\n      </div>\n\t<!-- *****************法人営業終わり***************** -->\n\t\t\n\t<!-- *****************商品企画始まり***************** -->\n      <div class=\"accordion_option\">\n        <input type=\"checkbox\" id=\"toggle2\" class=\"accordion_toggle\">\n        <label class=\"accordion_title\" for=\"toggle2\">商品企画 (経験者歓迎！PC・スマホ周辺機器の商品企画・開発)<span class=\"recruit_tokyo\">東京・新橋</span></label>\n        <div class=\"accordion_content\">\n          <dl class=\"rule_table wt95 m_beside_a mb30_15\">\n            <div>\n              <dt>仕事の内容</dt>\n              <dd>当社の中心事業であるIT機器の商品企画・開発業務をお任せします。市場トレンドを読み解き、顧客の潜在ニーズに応える新たな製品の企画立案から、海外製造元の選定、開発、品質管理、そして市場投入まで、一貫してプロジェクトを推進する重要なポジションです。あなたの企画が、多種多様な企業・官公庁・教育機関の「働き方改革」を加速させます。</dd>\n            </div>\n            <div>\n              <dt>具体的な業務内容</dt>\n              <dd>\n                <dl class=\"hishi\">\n                  <dt class=\"txt_pri\">新商品の企画・立案・開発プロセス全般</dt>\n                  <dd>\n                    <ul class=\"permanentdisc_list\">\n                      <li>市場調査、競合分析、顧客ニーズの深掘りを通じた新製品コンセプトの企画立案。</li>\n                      <li>製品仕様の策定、機能要件定義。</li>\n                      <li>最適な海外製造元（ベンダー）の選定・開拓、交渉・折衝。</li>\n                      <li>開発スケジュール、品質、コストの全体管理。</li>\n                      <li>発注業務、生産管理、納期調整、品質チェック。</li>\n                      <li>国際運送業者との連携、物流管理。</li>\n                    </ul>\n                  </dd>\n                </dl>\n              </dd>\n            </div>\n            <div>\n              <dt>必要な能力・経験</dt>\n              <dd>\n                <dl class=\"hishi\">\n                  <dt class=\"txt_pri\">必須</dt>\n                  <dd>\n                    <ul class=\"permanentdisc_list\">\n                      <li>IT製品（PC、スマートフォン、周辺機器）に関する知識をお持ちの方</li>\n                      <li>Word、Excelの基本操作ができる方</li>\n                    </ul>\n                  </dd>\n                  <dt class=\"txt_pri\">歓迎</dt>\n                  <dd>\n                    <ul class=\"permanentdisc_list\">\n                      <li>IT機器の商品企画や開発に携わった経験がある方</li>\n                      <li>海外とのコミュニケーションに抵抗がない方</li>\n                      <li>英語もしくは中国語日常会話レベル以上</li>\n                      <li>自ら考え、実行していく力をお持ちの方</li>\n                    </ul>\n                  </dd>\n                </dl>\n              </dd>\n            </div>\n            <div>\n              <dt>学歴</dt>\n              <dd><ul class=\"permanentdisc_list\"><li>高校</li><li>専修</li><li>短大</li><li>高専</li><li>大学</li><li>大学院</li></ul></dd>\n            </div>\n            <div>\n              <dt>雇用形態</dt>\n              <dd>正社員(期限の定めはありません)<ul class=\"kome mt0 mb0\"><li class=\"mt0 mb0\">3ヶ月の試用期間あり (試用期間中の条件変更はありません)</li></ul></dd>\n            </div>\n            <div>\n              <dt>勤務地・交通</dt>\n              <dd> 東京都港区新橋4-21-3 新橋東急ビル5F<ul class=\"kome mt0 mb0\"><li class=\"mt0 mb0\">JR・都営浅草線 新橋駅から徒歩2分／東京メトロ銀座線 新橋駅から徒歩3分</li></ul></dd>\n            </div>\n            <div>\n              <dt>勤務時間</dt>\n              <dd>9：00〜17：30（実働7.5時間）</dd>\n            </div>\n            <div>\n              <dt>残業</dt>\n              <dd>有<br>平均残業時間：15時間</dd>\n            </div>\n            <div>\n              <dt>残業手当</dt>\n              <dd>有<br>固定残業代制度あり (※超過分別途支給)<br>固定残業代の相当時間：20.0時間/月</dd>\n            </div>\n            <div>\n              <dt>通勤手当</dt>\n              <dd>会社規程に基づき支給<br>上限：10万円/月</dd>\n            </div>\n            <div>\n              <dt>休日・休暇</dt>\n              <dd>完全週休2日制（土日）、祝日\n                <dl class=\"hishi mt10\">\n                  <dt class=\"txt_pri\">年間休日</dt>\n                  <dd>124日</dd>\n                  <dt class=\"txt_pri\">有給休暇</dt>\n                  <dd>11日(最高付与日数20日)\n                    <ul class=\"kome mt0\">\n                      <li class=\"mt0\">入社後6か月以内の基準日に達したら上記を付与</li>\n                    </ul>\n                  </dd>\n                  <dt class=\"txt_pri\">休暇制度</dt>\n                  <dd>\n       