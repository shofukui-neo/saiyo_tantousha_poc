{"url":"https://www.fuji-kougyou.jp/contact.html","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n\n<head>\n    <meta charset=\"utf-8\">\n    <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n    <title>お問い合わせ</title>\n    <meta name=\"description\" content=\"藤工業株式会社は“創意工夫”“信頼”“スピード”三つのＳを胸に「鉄筋の総合デパート」を目指して参りました。これからも「鉄筋の総合デパート」として多くの商品だけでなく、技術までをもご提供出来るように取り組んでまいります。\">\n    <meta name=\"keywords\" content=\"\">\n    <link href=\"css/reset.min.css\" rel=\"stylesheet\" media=\"all\">\n    <link href=\"css/original.css\" rel=\"stylesheet\" media=\"all\">\n    <link href=\"css/skitter.styles.min.css\" rel=\"stylesheet\" media=\"all\">\n    <!--[if lt IE 9]>\n        <script src=\"js/html5shiv-printshiv.js\" media=\"all\"></script>\n    <![endif]-->\n</head>\n\n<body>\n    <header>\n        <div class=\"wrapper\">\n            <div class=\"header-left btn\">\n                <h1><a href=\"index.html\"><img src=\"images/img_header_logo.png\" alt=\"埼玉県さいたま市に本社工場を構える藤工業株式会社です。\"></a></h1>\n            </div>\n            <div class=\"header-right\">\n                <div class=\"font-change\">\n                    <ul>\n                        <li><img class=\"changeBtn\" src=\"images/btn_font_med.png\" alt=\"中\"></li>\n                        <li><img class=\"changeBtn\" src=\"images/btn_font_large.png\" alt=\"大\"></li>\n                    </ul>\n                </div>\n                <img src=\"images/img_header_tel.png\" alt=\"048-795-0075 埼玉県さいたま市岩槻区古々場2-7-1\">\n            </div>        \n        </div>\n    </header><!--  end of header  -->\n    <nav>\n            <ul>\n                <li class=\"nav1\"><a href=\"index.html\"><img src=\"images/btn_nav01_off.gif\" alt=\"ホーム\"></a></li>\n                <li class=\"nav2\"><a href=\"greeting.html\"><img src=\"images/btn_nav02_off.gif\" alt=\"製品紹介\"></a></li>\n                <li class=\"nav3\"><a href=\"fkhoop.html\"><img src=\"images/btn_nav03_off.gif\" alt=\"FKフープ\"></a></li>\n                <li class=\"nav4\"><a href=\"fkbase.html\"><img src=\"images/btn_nav04_off.gif\" alt=\"FKベース\"></a></li>\n                <li class=\"nav5\"><a href=\"mkhoop.html\"><img src=\"images/btn_nav05_off.gif\" alt=\"エムケーフープ\"></a></li>\n                <li class=\"nav10\"><a href=\"headbar.html\"><img src=\"images/btn_nav10_off.gif\" alt=\"ヘッドバー\"></a></li>\n                <li class=\"nav6\"><a href=\"iwatsuki.html\"><img src=\"images/btn_nav06_off.gif\" alt=\"工場紹介\"></a></li>\n                <li class=\"nav7\"><a href=\"company.html\"><img src=\"images/btn_nav07_off.gif\" alt=\"会社概要\"></a></li>\n                <li class=\"nav8\"><a href=\"contact.html\"><img src=\"images/btn_nav08_off.gif\" alt=\"お問い合わせ\"></a></li>\n            </ul>\n    </nav><!--  end of navigation  -->\n    <div id=\"main-contents\" class=\"wrapper\">\n        <h2><img src=\"images/h2_contact.png\" alt=\"お問い合わせ\"></h2>\n        <div class=\"inner-w\">\n            <div class=\"contents-inner\">\n                <h3 class=\"title-text\">お電話でのお問い合わせ</h3>\n                <img class=\"f-left mr20\" src=\"images/img_header_logo.png\" alt=\"藤工業株式会社\">\n                <p class=\"contact-tel\">TEL：048-795-0075<br>\n                FAX：048-795-0177<br>\n                〒339-0072 埼玉県さいたま市岩槻区古ヶ場2-7-1</p>\n            </div>\n            <div class=\"contents-inner\">\n                <h3 class=\"title-text\">メールでのお問い合わせ</h3>\n                <p>お問い合わせいただきました内容を確認次第、ご連絡・ご返答させていただきます。<br>\n                尚、お客さまからいただいたEメールアドレスが違っていたり、システム障害などによりお返事できない場合がございますので、返答の無い場合は、お電話でその旨お問い合わせください。</p>\n                <p><span class=\"must\">※</span>印は入力必須となっております。</p>\n<form method=\"post\" action=\"contact/postmail\">\n    <table class=\"contact-table\">\n                    <tbody>\n                        <tr>\n                            <th rowspan=\"5\">お問い合わせ項目</th>\n                            <td colspan=\"2\">必要な項目のみご選択お願いします。</td>\n                        </tr>\n                        <tr>\n                            <td>1.製品について</td>\n                            <td><select name=\"word1[]\">\n                                <option value=\"\" selected=\"selected\">選択してください</option>\n                                <option value=\"FKフープ\">FKフープ</option>\n                                <option value=\"FKベース\">FKベース</option>\n                                </select></td>\n                        </tr>\n                        <tr>\n                            <td>2.求人について</td>\n                            <td><select name=\"word1[]\">\n                                <option value=\"\" selected=\"selected\">選択してください</option>\n                                <option value=\"鉄筋組立（下請け）\">鉄筋組立（下請け）</option>\n                                <option value=\"鉄筋組立（直傭）\">鉄筋組立（直傭）</option>\n                                <option value=\"鉄筋加工（工場）\">鉄筋加工（工場）</option>\n                                <option value=\"営業\">営業</option>\n                                <option value=\"一般事務\">一般事務</option>\n                                <option value=\"積算（ビル・マンション）\">積算（ビル・マンション）</option>\n                                <option value=\"積算（住宅）\">積算（住宅）</option>\n                                </select></td>\n                        </tr>\n                        <tr>\n                            <td>3.資料請求の方</td>\n                            <td><select name=\"word1[]\">\n                                <option value=\"\" selected=\"selected\">選択してください</option>\n                                <option value=\"会社概要パンフレット\">会社概要パンフレット</option>\n                                <option value=\"FKベースパンフレット\">FKベースパンフレット</option>\n                                <option value=\"FKフープパンフレット\">FKフープパンフレット</option>\n                                </select></td>\n                        </tr>\n                        <tr>\n                            <td>4.その他</td>\n                            <td>※下記のお問い合わせ内容にご記入お願いします。</td>\n                        </tr>\n                        <tr>\n                            <th>御社名<span class=\"must\">※</span></th>\n                            <td colspan=\"2\"><input name=\"word4\" type=\"text\" size=\"40\"><br>（全角入力　例：山田　太郎）</td>\n                        </tr>\n                        <tr>\n                            <th>ご担当者（お名前）<span class=\"must\">※</span></th>\n                            <td colspan=\"2\"><input name=\"word5\" type=\"text\" size=\"40\"></td>\n                        </tr>\n                        <tr>\n                            <th>フリガナ</th>\n                            <td colspan=\"2\"><input name=\"word6\" type=\"text\" size=\"40\"><br>（全角入力　例：ヤマダ　タロウ）</td>\n                        </tr>\n                        <tr>\n                            <th>郵便番号</th>\n                            <td colspan=\"2\"><input name=\"word7\" type=\"text\" size=\"10\"><br>（半角入力　例：338-0013</td>\n                        </tr>\n                        <tr>\n                            <th>ご住所</th>\n                            <td colspan=\"2\"><input name=\"word8\" type=\"text\" size=\"40\"><br>（例：埼玉県さいたま市岩槻区古ヶ場2-7-1</td>\n                        </tr>\n                        <tr>\n                            <th>電話番号<span class=\"must\">※</span></th>\n                            <td colspan=\"2\"><input name=\"word9\" type=\"text\" size=\"40\"><br>（半角入力　例：048-795-0075 携帯可）</td>\n                        </tr>\n                        <tr>\n                            <th>FAX番号</th>\n                            <td colspan=\"2\"><input name=\"word10\" type=\"text\" size=\"40\"><br>（半角入力　例：048-799-0177）</td>\n                        </tr>\n                        <tr>\n                            <th>E-mail<span class=\"must\">※</span></th>\n                            <td colspan=\"2\"><input name=\"word11\" type=\"text\" size=\"40\"><br>（半角入力　例：sssss@example.com）</td>\n                        </tr>\n                        <tr>\n                            <th class=\"vlt\">お問い合わせ内容<span class=\"must\">※</span></th>\n                            <td colspan=\"2\"><textarea name=\"word12\" cols=\"40\" rows=\"10\"></textarea></td>\n                        </tr>\n                    </tbody>\n                </table>\n                <h4 class=\"tac\">個人情報の取り扱いについて</h4>\n                <p>当事業所は、社会的責任及び個人情報の重要性を尊重して個人情報の取り扱いに関する基本的な指針により、ご利用者様の個人情報を取り扱います。</p>\n    <p class=\"tac\"><input type=\"submit\" value=\"上記、個人情報の取扱に同意して内容を確認する\" /></p>\n                </form>\n            </div>\n        </div>\n    </div><!--  end of contents  -->\n    <footer>\n        <div class=\"footer-inner\">\n            <div class=\"pagetop btn\">\n                <a href=\"#top\"><img src=\"images/img_pagetop.png\" alt=\"ページの先頭へ戻る\"></a>\n            </div>\n            <div class=\"footer-left btn\">\n                <a href=\"index.html\"><img src=\"images/img_footer_logo.png\" alt=\"藤工業株式会社\"></a>\n                <p>Copyrightc 2015 FUJINDUSTRY All Rights Reserved.</p>\n            </div>\n            <div class=\"footer-right\">\n                <ul>\n                    <li><a href=\"index.html\">ホーム</a></li>\n                    <li><a href=\"greeting.html\">製品紹介</a></li>\n                    <li><a href=\"fkhoop.html\">FKフープ</a></li>\n                    <li><a href=\"fkbase.html\">FKベース</a></li>\n                    <li><a href=\"mkhoop.html\">エムケーフープ</a></li>\n                    <li><a href=\"headbar.html\">ヘッドバー</a></li>\n                    <li><a href=\"iwatsuki.html\">工場紹介</a></li>\n                    <li><a href=\"company.html\">会社概要</a></li>\n                    <li><a href=\"contact.html\">お問い合わせ</a></li>\n                </ul>\n            </div>\n        </div>\n    </footer>\n    \n    \n    <script src=\"js/jquery-1.11.3.min.js\"></script>\n    <script src=\"js/jquery.cookie.js\"></script>\n    <script src=\"js/jquery.fontsizechange.js\"></script>\n    <script src=\"js/fade.js\"></script>\n</body>\n\n</html>","finalUrl":"https://www.fuji-kougyou.jp/contact.html","rende