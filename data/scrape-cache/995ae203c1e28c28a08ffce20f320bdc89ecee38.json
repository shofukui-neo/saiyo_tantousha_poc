/inc/inc_header --></header>\r\n<!-- ===== /header ====== -->\r\n\r\n<!-- ===== globalNav ====== -->\r\n<nav id=\"globalNav\" class=\"ly_globalNav inc_globalnav\"><!-- /shared/inc/inc_globalnav --></nav>\r\n<!-- ===== /globalNav ====== -->\r\n\r\n<!-- ===== contents ====== -->\r\n<main class=\"ly_mainContents\" id=\"contents\">\r\n\r\n  <div class=\"ly_container\">\r\n    <div class=\"ly_inner _pb0\">\r\n      <!-- breadCrumb -->\r\n      <div class=\"bl_breadCrumb\">\r\n        <ul>\r\n          <li><a href=\"/\">HOME</a></li>\r\n          <li><a href=\"./\">お問い合せ</a></li>\r\n          <li>東レの製品情報全般に関するお問い合わせ</li>\r\n        </ul>\r\n      </div>\r\n      <!-- /breadCrumb -->\r\n  \r\n      <h1 class=\"bl_headingLv1\">東レの製品情報全般に関するお問い合わせ</h1>\r\n\t\t\r\n\t\t<div class=\"_mb50 bPattern02 -gray\">\r\n\t\t\t<p>＜日傘製品についての問い合わせ＞<br>\r\n\t\t\t\t弊社サマーシールド生地を使用した日傘製品については、主に以下の三社で取り扱っていますので、直接お問い合わせいただければ幸いです。<br>\r\n\t\t\t\t・オーロラ株式会社　お客様相談室　℡：03-5771-2062<br>\r\n\t\t\t\t・株式会社　シューズセレクション　℡：03-6459-3282　<br>\r\n\t\t\t\t・株式会社　ハンズ（旧東急ハンズ）<a href=\"https://info.hands.net/list/\" target=\"_blank\" class=\"_iconWindow\">https://info.hands.net/list/</a>　お近くの店舗へ</p>\r\n\t\t\t<p class=\"_mt30\">＜サマーシールド生地性能などについての問い合わせ＞<br>\r\n\t\t\t\t東レ株式会社　スポーツ・衣料資材事業部　<a href=\"https://www.contact.toray/input/206\" target=\"_blank\">お問合せフォーム</a></p>\r\n\t\t</div>\r\n\t\t<p class=\"_mb30\">※Internet Explorerではフォームが表示されない場合がございますので、ChromeやEdge等のブラウザでの閲覧を推奨いたします。</p>\r\n      <div class=\"bl_grid -col2 uq_contactLinks\">\r\n        <div class=\"grid -blue\">\r\n          <a href=\"\" target=\"_blank\" onclick=\"MainComponent.contactLink('216'); return false;\" class=\"\">\r\n            樹脂に関する<br>お問い合わせフォーム\r\n          </a>\r\n        </div>\r\n        <div class=\"grid -blue\">\r\n          <a href=\"\" target=\"_blank\" onclick=\"MainComponent.contactLink('223'); return false;\" class=\"\">\r\n            フィルムに関する<br>お問い合わせフォーム\r\n          </a>\r\n        </div>\r\n        <div class=\"grid -blue\">\r\n          <a href=\"\" target=\"_blank\" onclick=\"MainComponent.contactLink('179'); return false;\" class=\"setPalam\">\r\n            水処理膜に関する<br>お問い合わせフォーム\r\n          </a>\r\n        </div>\r\n        <div class=\"grid -blue\">\r\n          <a href=\"https://www.toray-watertreat.com/contact/?s=https://www.toray.co.jp/contact/products.html\" target=\"_blank\" class=\"setPalam\">\r\n            水処理膜装置に関する<br>お問い合わせフォーム\r\n          </a>\r\n        </div>\r\n        <div class=\"grid -blue\">\r\n          <a href=\"https://www.toray.jp/contact2/con_042.html?s=https://www.toray.co.jp/contact/products.html\" target=\"_blank\" class=\"setPalam\" style=\"display: block;\">\r\n            ウルトラスエード<sup>&reg;</sup>に関する<br>お問い合わせフォーム\r\n          </a>\r\n        </div>\r\n        <div class=\"grid -blue\">\r\n          <a href=\"\" target=\"_blank\" onclick=\"MainComponent.contactLink('186'); return false;\" class=\"setPalam\">\r\n            炭素繊維複合材料に関する<br>お問い合わせフォーム\r\n          </a>\r\n        </div>\r\n        <div class=\"grid -blue\">\r\n          <a href=\"https://www.torayvino.com/contact/?s=https://www.toray.co.jp/contact/products.html\" target=\"_blank\" class=\"setPalam\" style=\"display: block;\">\r\n            トレビーノ<sup>&reg;</sup>、ウォーターボール<sup>&reg;</sup>に関する<br>お問い合わせフォーム\r\n          </a>\r\n        </div>\r\n        <div class=\"grid -blue\">\r\n          <a href=\"\" target=\"_blank\" onclick=\"MainComponent.contactLink('139'); return false;\" class=\"setPalam\">\r\n            その他製品に関する<br>お問い合わせフォーム\r\n          </a>\r\n        </div>\r\n      </div>\r\n      <p class=\"_fzS _mt30\">※東レでは、皆様からのアイデア等のご提案についてはお受けすることを遠慮させていただいております。</p>\r\n\r\n\r\n</div>\r\n</div><!-- /ly_container-->\r\n\r\n\r\n</main>\r\n<!-- ===== /contents ====== -->\r\n\r\n<!-- ===== footer ====== -->\r\n<footer class=\"ly_footer inc_footer\"><!-- /shared/inc/inc_footer --></footer>\r\n<!-- ===== /footer ====== -->\r\n<p id=\"pagetop\" class=\"pagetop\" role=\"presentatio