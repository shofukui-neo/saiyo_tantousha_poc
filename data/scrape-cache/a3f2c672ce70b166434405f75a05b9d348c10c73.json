ec.co.jp/wp-content/uploads/2025/07/cropped-favicon-32x32.png\" sizes=\"32x32\" />\n<link rel=\"icon\" href=\"https://www.kokudoec.co.jp/wp-content/uploads/2025/07/cropped-favicon-192x192.png\" sizes=\"192x192\" />\n<link rel=\"apple-touch-icon\" href=\"https://www.kokudoec.co.jp/wp-content/uploads/2025/07/cropped-favicon-180x180.png\" />\n<meta name=\"msapplication-TileImage\" content=\"https://www.kokudoec.co.jp/wp-content/uploads/2025/07/cropped-favicon-270x270.png\" />\n  </head>\n\n  <body class=\"wp-singular page-template page-template-page-recruit page-template-page-recruit-php page page-id-157 page-parent wp-theme-kokudo post-name-recruit post-type-page\">\n    <header class=\"l-header\">\n      <div class=\"l-header__logo\">\n        <a href=\"/recruit\">\n          <img src=\"/wp-content/themes/kokudo/recruit/assets/img/common/h-logo.webp\">\n          <p>\n            <span>国土技術コンサルタンツ</span>\n            <u></u>\n            <span>RECRUIT</span>\n          </p>\n        </a>\n      </div>\n      <div class=\"c-hamburger\">\n        <input type=\"checkbox\" id=\"menu-btn-check\">\n        <label for=\"menu-btn-check\" class=\"c-hamburger__btn\"><span></span></label>\n        <!--ここからメニュー-->\n        <div class=\"c-hamburger__menu\">\n          <ul class=\"l-header__nav\">\n            <li>\n              <a href=\"/recruit\">TOP</a>\n            </li>\n            <li>\n              <a href=\"/recruit/message\">メッセージ</a>\n            </li>\n            <li>\n              <a href=\"/recruit/company\">会社を知る</a>\n            </li>\n            <li>\n              <a href=\"/recruit/member\">働く人を知る</a>\n            </li>\n            <li>\n              <a href=\"/recruit/business\">仕事を知る</a>\n            </li>\n            <li>\n              <a href=\"/recruit/#ENVIRONMENT\">働く環境を知る</a>\n              <ul class=\"is-sp\">\n                <li>\n                  <a href=\"/recruit/data\">⚫︎数字で見る</a>\n                </li>\n                <li><a href=\"/recruit/service\">⚫︎福利厚生 / キャリア形成</a></li>\n                <li>\n                  <a href=\"/recruit/special\">⚫︎鹿児島スペシャルページ</a>\n                </li>\n              </ul>\n            </li>\n            <li>\n              <a href=\"/recruit/information\">採用情報</a>\n            </li>\n            <li>\n              <a href=\"/contact\">お問い合わせ</a>\n            </li><li class=\"is-sp\"><a href=\"/\">コーポレートサイトへ</a></li>\n          </ul>\n          <!--ここまでメニュー-->\n        </div>\n      </div>\n\n    </header>\n\n<main>\n    <section class=\"p-top-keyvisual\">\n      <video autoplay=\"\" loop=\"\" muted=\"\" playsinline=\"\" class=\"is-sp\">\n        <source src=\"/wp-content/themes/kokudo/recruit/assets/video/kv_sp.mp4\"\n          type=\"video/mp4\">\n      </video>\n      <video autoplay=\"\" loop=\"\" muted=\"\" playsinline=\"\" class=\"is-pc\">\n        <source src=\"/wp-content/themes/kokudo/recruit/assets/video/kv_pc.mp4\"\n          type=\"video/mp4\">\n      </video>\n      <h1 class=\"p-top-keyvisual__title\"><span>RECRUIT</span>\n        自分らしさを武器に、<br>\n        可能性を広げよう！\n      </h1>\n    </section>\n\n    <section class=\"p-top-vision p-top-index\">\n      <h2>あなた<span>の</span>ビジョン<span>が</span>街<span>を</span>つなぐ</h2>\n      <sub>Your vision connects the city</sub>\n      <ul class=\"p-top-vision__image\">\n        <li><img decoding=\"async\" src=\"/wp-content/themes/kokudo/recruit/assets/img/top/vision01.webp\"></li>\n        <li><img decoding=\"async\" src=\"/wp-content/themes/kokudo/recruit/assets/img/top/vision02.webp\"></li>\n      </ul>\n    </section>\n\n    <section class=\"p-top-message p-top-index\">\n      <h2>Message</h2>\n      <sub>「あなたらしさを大切にし、一緒に成長しよう！」</sub>\n      <p>１つの事にこだわってしまうとそのことだけにしか<br>\n        目が向かず他の可能性を見逃してしまうため<br>\n        様々な視点をもち、常に新たな可能性へと挑戦する事。</p>\n      <div class=\"c-button is-message\">\n        <a href=\"/recruit/message\">メッセージ<i class=\"fa-solid fa-square-caret-right\" aria-hidden=\"true\"></i></a>\n      </div>\