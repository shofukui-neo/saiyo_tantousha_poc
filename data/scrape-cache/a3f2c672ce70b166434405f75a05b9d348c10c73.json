p/slide21.webp\" alt=\"\"></span>\n                  <span><img decoding=\"async\" src=\"/wp-content/themes/kokudo/recruit/assets/img/top/slide22.webp\" alt=\"\"></span>\n                  <span><img decoding=\"async\" src=\"/wp-content/themes/kokudo/recruit/assets/img/top/slide23.webp\" alt=\"\"></span>\n                  <span><img decoding=\"async\" src=\"/wp-content/themes/kokudo/recruit/assets/img/top/slide24.webp\" alt=\"\"></span>\n                  <span><img decoding=\"async\" src=\"/wp-content/themes/kokudo/recruit/assets/img/top/slide25.webp\" alt=\"\"></span>\n                </figure>\n              </li>\n            </ul>\n          </li>\n\n        </ul>\n        <div class=\"p-top-our-vision-contents\">\n          <sup>OUR VISION</sup>\n          <h2>『選ばれる』を軸に<br>\n            『つながる』企業へ。</h2>\n          <p>国土の技術者として、“選ばれる”を軸に会社と共に成長していける人。<br>\n            1人の人間として短所にばかり目を向けず<br>\n            自分や周囲の人の長所にも目を向けて<br>\n            知識や技術を基に、図面を描いたり測量をしたりと<br>\n            選ばれる技術者を目指しています。</p>\n          <div class=\"c-button\">\n            <a href=\"/recruit/company\">会社を知る<i class=\"fa-solid fa-square-caret-right\" aria-hidden=\"true\"></i></a>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"p-top-people p-top-index\">\n      <sup>People</sup>\n      <h2>働く人を知る</h2>\n      <ul class=\"p-top-people-list\">\n        <li>\n          <a href=\"/recruit/member/01-2\">\n            <div class=\"p-top-people-list__image\">\n              <img decoding=\"async\" src=\"/wp-content/themes/kokudo/recruit/assets/img/top/people01.webp\" alt=\"\">\n            </div>\n            <div class=\"p-top-people-list__text\">\n              <p>\n                <strong>技術部 技術2課長 1993年入社</strong>\n                <span>次代を担う若手技術者の成長と</span>\n                <span>地域からの信頼を目指して</span>\n              </p>\n              <i class=\"fa-solid fa-square-caret-right\" aria-hidden=\"true\"></i>\n            </div>\n          </a>\n        </li>\n\n        <li>\n          <a href=\"/recruit/member/02-2\">\n            <div class=\"p-top-people-list__image\">\n              <img decoding=\"async\" src=\"/wp-content/themes/kokudo/recruit/assets/img/top/people02.webp\" alt=\"\">\n            </div>\n            <div class=\"p-top-people-list__text\">\n              <p>\n                <strong>技術部 技術2課主任 2008年入社</strong>\n                <span>頼られる技術者として</span>\n                <span>雰囲気づくりと技術力向上に励む</span>\n              </p>\n              <i class=\"fa-solid fa-square-caret-right\" aria-hidden=\"true\"></i>\n            </div>\n          </a>\n        </li>\n\n        <li>\n          <a href=\"/recruit/member/03-2\">\n            <div class=\"p-top-people-list__image\">\n              <img decoding=\"async\" src=\"/wp-content/themes/kokudo/recruit/assets/img/top/people03.webp\" alt=\"\">\n            </div>\n            <div class=\"p-top-people-list__text\">\n              <p>\n                <strong>技術部 技術1課係長 2014年入社</strong>\n                <span>資格を重ね、専門性を磨く</span>\n                <span>皆が働きやすい職場へ貢献したい</span>\n              </p>\n              <i class=\"fa-solid fa-square-caret-right\" aria-hidden=\"true\"></i>\n            </div>\n          </a>\n        </li>\n      </ul>\n\n      <div class=\"p-top-people__more\">\n        <a href=\"/recruit/member\">動画インタビューなど 詳しく見る→</a>\n      </div>\n    </section>\n\n    <section class=\"p-top-works p-top-index\">\n      <div class=\"p-top-works__flex\">\n        <div class=\"p-top-works__contents\">\n          <sup>仕事を知る</sup>\n          <h2>WORKS</h2>\n          <div class=\"is-sp\">\n            <ul class=\"p-top-works__images\">\n              <li>\n                <img decoding=\"async\" src=\"/wp-content/themes/kokudo/recruit/assets/img/top/works01.webp\" alt=\"\">\n              </li>\n              <li>\n                <img decoding=\"async\" src=\"/wp-content/themes/kokudo/recruit/assets/img/top/works02.webp\" alt=\"\">\n              </li>\n              <li>\n                <img decoding=\"async\" src=\"/wp-content/themes/kokudo/recruit/assets/img/top/works03.webp\" alt=\"\">\n              </li>\n              <li>\n                <img decoding=\"async\" src=\"/wp-content/themes/kokudo/recruit/assets/img/top/works04.webp\" alt=\"\">\n              </li>\n              <li>\n                <img decoding=\"async\" src=\"/wp-content/themes/kokudo/recruit/assets/img/top/works05.webp\" alt=\"\">\n              </li>\n            </ul>\n          </div>\n\n          <p>成長の喜びを<br>\n            仲間と分かち合う。\n          </p>\n          <sub>建設コンサルタントとして、未来を創ろう</sub>\n          <div class=\"c-button\">\n            <a href=\"/recruit/business\">View More<i class=\"fa-solid fa-square-caret-right\" aria-hidden=\"true\"></i></a>\n          </div>\n        </div>\n        <div class=\"p-top-works__images-wrap is-pc\">\n          <ul class=\"p-top-works__images\">\n            <li>\n              <img decoding=\"async\" src=\"/wp-content/themes/kokudo/recruit/assets/img/top/works01.webp\" alt=\"\">\n            </li>\n            <li>\n              <img decoding=\"async\" src=\"/wp-content/themes/kokudo/recruit/assets/img/top/works02.webp\" alt=\"\">\n            </li>\n            <li>\n              <img decoding=\"async\" src=\"/wp-content/themes/kokudo/recruit/assets/img/top/works03.webp\" alt=\"\">\n            </li>\n            <li>\n              <img decoding=\"async\" src=\"/wp-content/themes/kokudo/recruit/assets/img/top/works04.webp\" alt=\"\">\n            </li>\n            <li>\n              <img decoding=\"async\" src=\"/wp-content/themes/kokudo/recruit/assets/img/top/works05.webp\" alt=\"\">\n            </li>\n          </ul>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"p-top-environment p-top-index\" id=\"ENVIRONMENT\">\n      <sup>ENVIRONMENT</sup>\n      <h2>働く環境を知る</h2>\n      <ul class=\"p-top-environment__lists\">\n        <li>\n          <a href=\"/recruit/service\">\n            <div class=\"p-top-environment__image\">\n              <img decoding=\"async\" src=\"/wp-content/themes/kokudo/recruit/assets/img/top/environment-bg1.webp\" alt=\"\">\n            </div>\n            <div class=\"p-top-environment__contents\">\n              <h3>\n                <img decoding=\"async\" src=\"/wp-content/themes/kokudo/recruit/assets/img/top/environment-icon01.webp\" alt=\"\">\n                BENEFITS\n              </h3>\n              <div class=\"p-top-environment__text\">\n                <strong>福利厚生/<br>キャリア形成</strong>\n                <p>社員一人ひとりが安心して働き、成長できる環境づくりに力を入れています。充実した福利厚生やサポート制度を通じて、仕事もプライベートも充実させられる職場を目指しています。私たちの取り組みを、ご覧ください。</p>\n              </div>\n            </div>\n          </a>\n        </li>\n        <li>\n          <a href=\"/recruit/data\">\n            <div class=\"p-top-environment__image\">\n              <img decoding=\"async\" src=\"/wp-content/themes/kokudo/recruit/assets/img/top/environment-bg2.webp\" alt=\"\">\n            </div>\n            <div class=\"p-top-environment__contents\">\n              <h3>\n                <img decoding=\"async\" src=\"/wp-content/themes/kokudo/recruit/assets/img/top/environment-icon02.webp\" alt=\"\">\n                DATA\n              </h3>\n              <div class=\"p-top-environment__text\">\n                <strong>数字で見る</strong>\n                <p>私たちのことをもっと身近に感じていただくために、特徴や魅力を「数字」でご紹介します。社員数や平均年齢、男女比など、データを通して、働く環境や社風をイメージしていただける内容となっています。</p>\n              </div>\n            </div>\n          </a>\n        </li>\n        <li>\n          <a href=\"/recruit/special\">\n            <div class=\"p-top-environment__image\">\n              <img decoding=\"async\" src=\"/wp-content/themes/kokudo/recruit/assets/img/top/environment-bg3.webp\" alt=\"\">\n            </div>\n            <div class=\"p-top-environment__contents\">\n              <h3>\n                <img decoding=\"async\" src=\"/wp-content/themes/kokudo/recruit/assets/img/top/environment-icon03.webp\" alt=\"\">\n                SPECIAL\n              </h3>\n              <div class=\"p-top-environment__text\">\n                <strong>ようこそ鹿児島！</strong>\n                <p>私たちは鹿児島という豊かな地域に支えられながら成長してきました。この土地で働く魅力、自然や文化、人の温かさなど、鹿児島ならではの魅力をたっぷりご紹介します。私たちの原点を、ぜひ知ってください。</p>\n              </div>\n            </div>\n          </a>\n        </li>\n      </ul>\n    </section>\n\n    <section class=\"p-top-join-us  p-top-index\">\n      <div class=\"p-top-join-us__wrap\">\n        <div class=\"p-top-environment__image\">\n          <img decoding=\"async\" src=\"/wp-content/themes/kokudo/recruit/assets/img/top/joinus.webp\" alt=\"\">\n        </div>\n        <div class=\"p-top-join-us-contents\">\n          <h2>JOIN US</h2>\n          <p>あなたの情熱で<br>\n            未来を設計する</p>\n          <sub>進化し続けるコンサルタントの舞台に、今、飛び込もう</sub>\n          <div class=\"c-button\">\n            <a href=\"/recruit/information\">採用情報<i class=\"fa-solid fa-square-caret-right\" aria-hidden=\"true\"></i></a>\n          </div>\n        </div>\n      </div>\n    </section>\n\n  </main>\n\n  <script>\n    $(window).scroll(function (){\n      var kvHeight = $('.p-top-keyvisual').height();\n      var scrollTop = $(this).scrollTop();\n      var windowHeight = $(window).height();\n      var target = $('.p-top-works').offset().top;\n      var opacityVal = (scrollTop + windowHeight - target - 300) / 500; \n      var gapVal = (scrollTop + windowHeight - target) / 20; \n\n      if (scrollTop + windowHeight - target > 0) {\n        if (opacityVal < 3) {\n          $('.p-top-works__images').css('opacity', opacityVal);\n          $('.p-top-works__images').css('gap', gapVal);\n        }\n      }\n\n      if (scrollTop - 200 > kvHeight) {\n        $('.p-top-keyvisual').css('opacity', '0');\n      } else {\n        $('.p-top-keyvisual').css('opacity', '1');\n      }\n    });\n  </script>\n\n\n\n<p class=\"wp-block-paragraph\"></p>\n\n<section class=\"l-entry\">\n      <!-- 画像エリア -->\n      <div class=\"l-entry-bg\">\n        <strong>あなたの夢を、街に刻もう！</strong>\n        <p>わたしたちと一緒に未来を作っていきませんか？</p>\n\n        <div class=\"l-entry__btn\">\n          <a href=\"https://rqt2iij1f.jbplt.jp/\" target=\"_blank\">キャリア採用<i class=\"fa-solid fa-square-caret-right\"></i></a>\n          <a href=\"/recruit/information/\">新卒採用<i class=\"fa-solid fa-square-caret-right\"></i></a>\n        </div>\n      </div>\n\n      <!-- 追従ボタン -->\n      <a class=\"l-entry__fixed-btn is-new\" href=\"/recruit/information/\">\n        <div>\n          <img src=\"/wp-content/themes/kokudo/recruit/assets/img/common/entry-icon2.webp\" alt=\"\">\n        </div>\n        <span>新卒採用</span>\n        ENTRY\n      </a>\n\n      <a class=\"l-entry__fixed-btn is-mid\" href=\"https://rqt2iij1f.jbplt.jp/\" target=\"_blank\">\n        <div>\n          <img src=\"/wp-content/themes/kokudo/recruit/assets/img/common/entry-icon1.webp\" alt=\"\">\n        </div>\n        <span>キャリア採用</span>\n        ENTRY\n      </a>\n\n      <div class=\"l-entry__spbtn is-sp\" style=\"bottom: 0px;\">\n        <div class=\"l-entry__spbtn-flex\">\n          <a class=\"l-entry__spbtn-recruit\" href=\"/recruit/information/\">新卒採用</a>\n          <a class=\"l-entry__spbtn-graduate\" href=\"https://rqt2iij1f.jbplt.jp/\" target=\"_blank\">キャリア採用</a>\n        </div>\n      </div>\n\n    </section>\n\n    <footer class=\"l-footer\">\n      <!-- 画像下リンク集 -->\n      <div class=\"l-footer__links-list\">\n        <div class=\"l-footer__textlink\">\n          <a href=\"https://rqt2iij1f.jbplt.jp/\" target=\"_blank\">キャリア<br class=\"is-sp\">採用\n            <span><i class=\"icon fa-solid fa-arrow-right-long\"></i></span>\n            <u></u>\n          </a>\n          <a href=\"/recruit/information\">新卒<br class=\"is-sp\">採用情報\n            <span><i class=\"icon fa-solid fa-arrow-right-long\"></i></span>\n            <u></u>\n          </a>\n        </div>\n  \n        <div class=\"l-footer__btnlink\">\n          <span></span>\n          <a href=\"https://job.myna