{"url":"https://www.web-nkc.com/caution/invoice.html","html":"<!DOCTYPE html PUBLIC \"-//W3C//DTD XHTML 1.0 Transitional//EN\" \"http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd\">\r\n<html xmlns=\"http://www.w3.org/1999/xhtml\"><!-- InstanceBegin template=\"/Templates/temp_topicsnews.dwt\" codeOutsideHTMLIsLocked=\"false\" -->\r\n<head>\r\n  <meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\" />\r\n  <link rel=\"stylesheet\" href=\"../css/index.css\" type=\"text/css\" media=\"all\" />\r\n  <script type=\"text/javascript\" src=\"../js/jquery.nkc.js\"></script>\r\n  <script type=\"text/javascript\" src=\"../js/jquery.droppy.js\"></script>\r\n  <script type=\"text/javascript\" src=\"../js/smartRollover.js\"></script>\r\n  <!-- InstanceBeginEditable name=\"doctitle\" -->\r\n  <title>株式会社エヌケーシー</title>\r\n  <!-- InstanceEndEditable -->\r\n  <script type=\"text/javascript\">  \r\n    $(function() {  \r\n      $(\"#nav\").droppy();  \r\n    });  \r\n</script>\r\n  <!-- InstanceBeginEditable name=\"head\" -->\r\n  <!-- InstanceEndEditable -->\r\n<script type=\"text/javascript\">\r\n\r\n  var _gaq = _gaq || [];\r\n  _gaq.push(['_setAccount', 'UA-21709387-1']);\r\n  _gaq.push(['_trackPageview']);\r\n\r\n  (function() {\r\n    var ga = document.createElement('script'); ga.type = 'text/javascript'; ga.async = true;\r\n    ga.src = ('https:' == document.location.protocol ? 'https://ssl' : 'http://www') + '.google-analytics.com/ga.js';\r\n    var s = document.getElementsByTagName('script')[0]; s.parentNode.insertBefore(ga, s);\r\n  })();\r\n\r\n</script>\r\n</head>\r\n<body>\r\n<div id=\"parent-wrapper\">\r\n<table width=\"100%\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" class=\"wrapper\">\r\n  <tr>\r\n    <td width=\"900\"><table width=\"900\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\">\r\n      <tr>\r\n        <td><table width=\"100%\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\">\r\n          <tr>\r\n            <td width=\"2%\"><img src=\"../img/top_h_o_r1_c1.gif\" alt=\"株式会社エヌケーシー\" width=\"20\" height=\"56\" /></td>\r\n            <td width=\"28%\"><a href=\"http://www.web-nkc.com/\" onmouseout=\"MM_swapImgRestore()\" onmouseover=\"MM_swapImage('home','','../img/top_h_o_r1_c2.gif',1)\"><img src=\"../img/top_h_o_r1_c2.gif\" alt=\"株式会社エヌケーシー\" name=\"home\" width=\"245\" height=\"56\" border=\"0\" id=\"home\" /></a><br /></td>\r\n            <td width=\"70%\">\r\n              <div class=\"header-option\">\r\n                </div>\r\n            </td>\r\n          </tr>\r\n        </table></td>\r\n      </tr>\r\n    </table></td>\r\n  </tr>\r\n</table>\r\n<div id=\"container\" class=\"wrapper\">\r\n  <!-- ここからが中身 -->\r\n\r\n  <div><!-- InstanceBeginEditable name=\"MainEdit\" -->\r\n    <table width=\"800\" border=\"0\" align=\"center\" cellpadding=\"0\" cellspacing=\"30\">\r\n      <tr>\r\n        <td align=\"center\" class=\"t16b\"><div align=\"left\"><font color=\"red\"><font size=\"2\"> 　　</font></font></div></td>\r\n      </tr>\r\n      <tr>\r\n        <td align=\"center\" class=\"\"><div align=\"right\">\r\n          \r\n        </div></td>\r\n      </tr>\r\n      <tr>\r\n        <td height=\"16\" align=\"center\" class=\"t16b\"><p>インボイス制度（適格請求書等保存方式）対応に関するご案内</p></td>\r\n      </tr>\r\n      <tr>\r\n        <td height=\"250\"><table width=\"100%\" border=\"0\" cellspacing=\"0\" cellpadding=\"0\">\r\n          <tr>\r\n            <td><table width=\"98%\" border=\"0\" cellspacing=\"10\" cellpadding=\"0\">\r\n              <tr>\r\n                <td height=\"198\" colspan=\"3\"><table width=\"650\" border=\"0\" align=\"center\" cellpadding=\"0\" cellspacing=\"0\">\r\n                  <tr>\r\n                    <td width=\"26\" height=\"16\" rowspan=\"6\" valign=\"top\"><p>&nbsp;</p></td>\r\n                  \r\n                  </tr>\r\n                  <tr>\r\n                    <td width=\"624\" valign=\"top\"><p align=\"center\">2023年10月1日（日）より、インボイス制度が開始されました。<br>\r\n            弊社は適格請求書発行事業者として、インボイス（適格請求書）を発行いたします。</p>\r\n    <br />                  \r\n<div style=\"background: #fff; border: 1px #ccc solid; box-shadow: 0 2px 3px 0 #ddd; font-size: 120%; padding: 5px; width: 98%;\"> ● インボイス対応日 </div>\r\n<br />2023年10月1日ご利用分から開始<br />\r\n<br />\r\n<div style=\"background: #fff; border: 1px #ccc solid; box-shadow: 0 2px 3px 0 #ddd; font-size: 120%; padding: 5px; width: 98%;\"> ● 弊社適格請求書発行事業者登録番号のご案内 </div>\r\n<br />株式会社エヌケーシーの登録番号をご案内します。<br />\r\n<br />\r\n\r\n<div style=\"background: #4169e1; border: 1px solid #4169e1; padding-left: 20px; text-align: center; width: 95%;\"> <span style=\"color: white;\">適格請求書発行事業者登録番号</span></div> <div style=\"border: 1px solid #4169e1; font-size: 120%; padding: 10px; text-align: center; width: 95%;\"> Ｔ4270001000563 </div>\r\n<br />\r\n<br />\r\n<div style=\"background: #fff; border: 1px #ccc solid; box-shadow: 0 2px 3px 0 #ddd; font-size: 120%; padding: 5px; width: 98%;\"> ● カード会員様（法人、個人事業主様） </div>\r\n<br />毎月のカードご利用明細のうちインボイス制度の対象となるご利用について、ご要望いただいた会員様へ<br>カードご利用明細書とは別にインボイスを発行いたします。<br>\r\n発行をご希望の方は、エヌケーシーカスタマーセンターへご連絡ください。<br />\r\n<br />\r\n<br />\r\n<u>弊社がインボイスを発行する取引例</u><br />\r\n会員様と弊社との取引がある場合のみ、弊社はインボイスを発行できます。<br>\r\n•カード年会費（家族カードを含む）<br>\r\n•カードご利用明細書発行手数料<br>\r\n•ETC発行手数料<br>\r\n•ATM手数料<br>　　　　　　\r\n<br>\r\n<br />  \r\n<div style=\"border: #000000 solid 1px; font-size: 100%; padding: 10px; width: 70%; text-align: center; margin: auto;\"> 【お問い合わせ先】<br> \r\n　エヌケーシー　カスタマーセンター <br>\r\n　ＴＥＬ：０８５７－３２－８３１１<br>\r\n　オペレーター受付時間：平日１０：００～１６：００<br>\r\n </div><br />\r\n <br />\r\n <p align=\"center\">インボイス制度について　国税庁のサイトをご参照ください。（外部サイトに遷移します）<br>\r\n<a href=\"https://www.nta.go.jp/taxes/shiraberu/zeimokubetsu/shohi/keigenzeiritsu/invoice.htm\"><div style=\"border-radius: 20px; border: 4px double #000000; font-size: 100%; padding: 10px; width: 40%; text-align: center; margin: auto;\"> 国税庁 – インボイス制度 　＞</div></a></p>\r\n                      \r\n                      </p><p align=\"justify\">&nbsp;</p></td>\r\n                 </tr>\r\n                  <tr>\r\n                    <td valign=\"top\">&nbsp;</td>\r\n                  </tr>\r\n                  <tr>\r\n                    <td valign=\"top\"><p>&nbsp;</p>\r\n                      <p>&nbsp;</p></td>\r\n                  </tr>\r\n                  <tr>\r\n                    <td valign=\"top\">&nbsp;</td>\r\n                    </tr>\r\n                </table></td>\r\n                </tr>\r\n              </table></td>\r\n            </tr>\r\n          <tr>\r\n            <td align=\"center\"><table width=\"650\" border=\"0\" align=\"center\" cellpadding=\"0\" cellspacing=\"0\">\r\n              <tr>\r\n                <td align=\"right\">&nbsp;</td>\r\n                </tr>\r\n              <tr>\r\n                <td align=\"right\">　以上<br /></td>\r\n                </tr>\r\n              </table></td>\r\n            </tr>\r\n          </table></td>\r\n      </tr>\r\n      </table>\r\n  <!-- InstanceEndEditable --></div>\r\n\r\n  <!-- ここまでが中身 -->\r\n    <div id=\"footer\">\r\n      <ul class=\"foot-menu\">\r\n        <li></li>\r\n      </ul>\r\n      <div class=\"copyright\">\r\n        <img src=\"../img/top_cop.jpg\" alt=\"\" width=\"366\" height=\"14\" />\r\n      </div>\r\n      <div class=\"footer-sub\"></div>\r\n    </div>\r\n  </div>\r\n</div>\r\n</div>\r\n</body>\r\n<!-- InstanceEnd --></html>\r\n","finalUrl":"https://www.web-nkc.com/caution/invoice.html","rendered":false,"_cachedAt":"2026-06-23T21:39:21.326Z"}