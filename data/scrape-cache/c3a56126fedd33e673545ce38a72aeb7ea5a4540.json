に関する問い合わせ（メーカーさま）\">商品に関する問い合わせ（メーカーさま）</option>\r\n\t          <option value=\"開業に関するご相談\">開業に関するご相談</option>\r\n\t          <option value=\"弊社へのご意見・ご質問\">弊社へのご意見・ご質問</option>\r\n                </select>             \r\n              </div>\r\n              <textarea name=\"comment\"></textarea>\r\n            </dd>\r\n          </dl>\r\n        </div><!-- / .form-area -->\r\n        \r\n        <div class=\"contact-send-btn form-send\"><input type=\"submit\" name=\"submit\" value=\"内容確認\" class=\"contact-send-btn\"></div>\r\n      </form>\r\n    </article><!-- / .contact-container -->\r\n<script>\r\n  $(function(){\r\n    /* ページ読み込み時のボタン制御処理 */\r\n    if ($('.policy-check .checkbox-input:checked').val()) {\r\n         $('.contact-send-btn').prop(\"disabled\", false);\r\n    } else {\r\n        $('.contact-send-btn').prop(\"disabled\", true);\r\n    }\r\n    $('.policy-check').click(function(){\r\n        if($('.policy-check .checkbox-input').prop('checked')){\r\n            $('.contact-send-btn').prop(\"disabled\", false);\r\n        }else{\r\n            $('.contact-send-btn').prop(\"disabled\", true);\r\n        }\r\n    });\r\n  });\r\n</script>\r\n  </main><!-- / #contents-wrapper -->\r\n  \r\n  <div id=\"footer-wrapper\" class=\"effect\">\r\n    <div class=\"f-contact\">\r\n      <h2 class=\"sec-ttl effect\"><span class=\"en\">CONTACT</span>お問い合わせ</h2>\r\n      <p class=\"f-contact-txt effect\">ミツイではサロンの発展を総合的にサポートするために、<br>\r\n経営を支えるあらゆる事業をカタチにし、<br>\r\nひとつひとつのサービスクオリティを追求し続けています。</p>\r\n      <div class=\"f-contact-btn btn-form effect\"><a href=\"contact/\">専用フォームからお問い合わせ</a></div>\r\n      \r\n    </div><!-- / .f-contact -->\r\n    <footer class=\"site-footer\">\r\n      <div class=\"site-footer-wrap\">\r\n        <div class=\"site-footer__logo effect\"><img src=\"img/common/logo_blue.svg\" alt=\"ミツイコーポレーション株式会社\"></div>\r\n        <h2 class=\"site-footer-name effect\">総合美容商社<br>ミツイコーポレーション株式会社</h2>\r\n        <p class=\"site-footer-tel effect\">TEL:054-2