('Android') > 0){\r\n        $('.tel-link').each(function(){\r\n            var str = $(this).text();\r\n            $(this).html($('<a>').attr('href', 'tel:' + str.replace(/-/g, '')).append(str + '</a>'));\r\n        });\r\n    }\r\n});\r\n</script>\r\n\r\n<!-- Global site tag (gtag.js) - Google Analytics -->\r\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=UA-106470999-1\"></script>\r\n<script>\r\n  window.dataLayer = window.dataLayer || [];\r\n  function gtag(){dataLayer.push(arguments);}\r\n  gtag('js', new Date());\r\n\r\n  gtag('config', 'UA-106470999-1');\r\n</script>\r\n<!-- GoogleAnalytics -->\r\n\r\n</head>\r\n\r\n<body>\r\n\r\n<div id=\"wrapper\" class=\"information\">\r\n\r\n<header>\r\n  <div class=\"pc h_inner_top\">\r\n    <h1>カガク興商株式会社の個人情報の取扱について</h1>\r\n  </div>\r\n  <div id=\"fixedBox\" class=\"pc h_inner\">\r\n    <ul class=\"menu clearfix\">\r\n      <li>\r\n        <a href=\"./\">\r\n          <img src=\"img/common/h_logo.png\" width=\"287px\" height=\"33px\" alt=\"\" >\r\n        </a>\r\n      </li>\r\n      <li>\r\n        <img src=\"img/common/nav01.png\" alt=\"\" >\r\n        <ul class=\"clearfix\">\r\n          <li>\r\n            <a href=\"material.html\">\r\n              溶材部\r\n            </a>\r\n          </li>\r\n          <li>\r\n            <a href=\"oil.html\">\r\n              石油販売部\r\n            </a>\r\n          </li>\r\n          <li>\r\n            <a href=\"gas.html\">\r\n              石油ガス部\r\n            </a>\r\n          </li>            \r\n        </ul>\r\n      </li>\r\n      <li>\r\n        <a href=\"company.html\">\r\n          <img src=\"img/common/nav02.png\" alt=\"\" >\r\n        </a>\r\n      </li>      \r\n      <li>\r\n        <a href=\"recruit.html\">\r\n          <img src=\"img/common/nav03.png\" alt=\"\" >\r\n        </a>\r\n      </li>\r\n      <li>\r\n        <a href=\"sdgs.html\">\r\n          <img src=\"img/common/nav05.png\" alt=\"\" >\r\n        </a>\r\n      </li>\t\t\t\r\n      <li>\r\n        <a href=\"contact.html\">\r\n          <img src=\"img/common/nav04.png\" alt=\"\" >\r\n        </a>\r\n      </li>\r\n    </ul>\r\n  </div>\r\n  <div class=\"pc main01\">\r\n    <a href=\"./\">ホーム</a>　＞　個人情報の取扱について\r\n  </div>\r\n  \r\n  <div id=\"fixedBox\" class=\"sp h_inner\">\r\n    <div class=\"nav-wrap\">\r\n      <div class=\"menu\">\r\n        <a href=\"./\">\r\n        </a>\r\n        <div class=\"gnav-btn\">\r\n          <div class=\"icon-animation\">\r\n            <span class=\"top\"></span>\r\n            <span class=\"middle\"></span>\r\n            <span class=\"bottom\"></span>\r\n          </div>\r\n        </div>\r\n      </div>\r\n      <nav>\r\n        <ul class=\"gnav\">\r\n          <li><a href=\"./\">ホーム</a></li>\r\n          <li>\r\n            <p><span>業務内容　&#9661;</span></p>\r\n            <ul>\r\n              <li><a href=\"material.html\">　溶材部</a></li>\r\n              <li><a href=\"oil.html\">　石油販売部</a></li>\r\n              <li><a href=\"gas.html\">　石油ガス部</a></li>\r\n            </ul>\r\n          </li>\r\n          <li><a href=\"company.html\">会社案内</a></li>\r\n         <li><p><span>求人情報　&#9661;</span></p>\r\n            <ul>\r\n              <li><a href=\"recruit.html\">　求人情報</a></li>\r\n              <li><a href=\"voice.html\">　先輩社員の声</a></li>\r\n            </ul>\r\n          </li>\r\n          <li><a href=\"sdgs.html\">SDGsへの取り組み</a></li>\t\t\t\r\n          <li><a href=\"contact.html\">お問い合わせ</a></li>\r\n          <li><a href=\"information.html\">個人情報の取扱について</a></li>\r\n          <li><a href=\"about.html\">当サイトご利用について</a></li>\r\n        </ul>\r\n      </nav>\r\n    </div>\r\n  </div><!-- / sp -->  \r\n\r\n  <div class=\"sp h_img\">\r\n    <img src=\"img/information/sp_information_main.jpg\" width=\"1050px\" height=\"577px\" alt=\"\" >\r\n  </div>  \r\n\r\n</header>\r\n\r\n<div id=\"main\">\r\n  <article class=\"main02\">\r\n    <section>\r\n      <div class=\"information_txt01\">\r\n        カガク興商株式会社ホームページ（以下、「当サイト」といいます）は、カガク興商株式会社（以下、「弊社」といいます）が運営しております。弊社は個人情報の保護に関する法律その他の関係法令を遵守し、お客さまの個人情報を適切に取り扱います。\r\n      </div> \r\n    </section>\r\n  </article>\r\n  <article class=\"main_b01\">\r\n    <section>    \r\n      <div class=\"ttl03\">当サイトにおける個人情報とは</div>\r\n      <div class=\"information_txt02\">\r\n        ・当サイトにおける個人情報とは、当サイトを通じてお客様から意図的にご提供いただいた『お名前（会社名）・ご住所・電話番号・メールアドレス』など、特定の個人を識別することができる情報のことをいいます。\r\n      </div>\r\n\r\n      <div class=\"ttl04\">個人情報の取得及び利用目的</div>\r\n      <div class=\"information_txt02\">\r\n        ・当サイトではアクセスされたお客様の個人情報の取得にあたっては、適法かつ公正な手段により行います。お客様のご承諾なく個人情報を取得することはありません。<br>\r\n        ・当サイトにおいてご提供いただいたお客様の個人情報は、お客様の目的達成に必要な範囲内においてのみ利用いたします。\r\n      </div>    \r\n\r\n      <div class=\"ttl05\">個人情報の第三者への提供</div>\r\n      <div class=\"information_txt02\">\r\n        ・ご提供いただきました個人情報は、次の場合を除き第三者に開示することはありません。<br>\r\n        　1.ご本人様の同意がある場合。<br>\r\n        　2.弊社と個人情報に関する契約を締結している協力会社、提携会社及び業務委託先会社に対して、お客様に明示した利用目的の達成に必要な範囲内で委託する場合。<br>\r\n        　3.法令等に基づき個人情報の提供を要請された場合。\r\n      </div>  \r\n      \r\n      \r\n      <div class=\"ttl03\">リンク先サイトにおける個人情報の取り扱いについて</div>\r\n      <div class=\"information_txt02\">\r\n        ・当サイトでは外部のサイトへのリンクを含んでいますが、第三者のサイトにおいて、利用者の方が提供する個人情報の取り扱いに関しては、弊社は一切責任を負いません。<br>\r\n        ・各リンク先における個人情報の提供などは、各リンク先にある個人情報の取り扱いに関するポリシー等をご確認ください。\r\n      </div>\r\n\r\n      <div class=\"ttl04\">アクセスログの取得及び利用目的</div>\r\n      <div class=\"information_txt02\">\r\n        ・当サイトではアクセスされた方の情報をアクセスログという形で記録しています。<br>\r\n        ・アクセスログは、アクセスされた方のドメイン名やIPアドレス、使用しているブラウザの種類、アクセス日時等が含まれますが、個人を特定できる情報を含むものではありません。<br>\r\n        ・取得したアクセスログは、よりお客様のニーズにあったサイト作成を推進するためなどの目的に利用させていただきます。\r\n      </div>    \r\n\r\n\r\n    </section>\r\n  </article>\r\n</div><!--  /main -->\r\n\r\n<footer>\r\n  <div id=\"pagetop\">\r\n    <a href=\"#wrapper\">\r\n      <img src=\"img/common/sp_pagetop.png\" width=\"80px\" height=\"69px\" alt=\"pagetop\" />\r\n    </a>\r\n  </div>\r\n  <div class=\"f_inner01\">\r\n    <ul class=\"b_nav clearfix\">\r\n      <li><a href=\"./\">ホーム</a>&nbsp;&nbsp;｜&nbsp;&nbsp;</li>\r\n      <li><a href=\"material.html\">溶材部</a>&nbsp;&nbsp;｜&nbsp;&nbsp;</li>\r\n      <li><a href=\"oil.html\">石油販売部</a>&nbsp;&nbsp;｜&nbsp;&nbsp;</li>\r\n      <li><a href=\"gas.html\">石油ガス部</a>&nbsp;&nbsp;｜&nbsp;&nbsp;</li>\r\n      <li><a href=\"company.html\">会社案内</a>&nbsp;&nbsp;｜&nbsp;&nbsp;</li>\r\n      <li><a href=\"recruit.html\">求人案内</a>&nbsp;&nbsp;｜&nbsp;&nbsp;</li>\r\n      <li><a href=\"sdgs.html\">SDGsへの取り組み</a>&nbsp;&nbsp;｜&nbsp;&nbsp;</li>\t\t\r\n      <li><a href=\"contact.html\">お問い合わせ</a></li>\r\n    </ul>\r\n    <div class=\"f_inner02 clearfix\">\r\n      <div class=\"copyright\">Copyright (C) 2018 カガク興商株式会社. All Rights Reserved.</div>\r\n      <div class=\"link\">\r\n        <img src=\"img/common/f_sign.png\" width=\"17px\" height=\"15px\" alt=\"\" >\r\n        <a href=\"information.html\">個人情報の取扱について</a>　\r\n        <img src=\"img/common/f_sign.png\" width=\"17px\" height=\"15px\" alt=\"\" >\r\n        <a href=\"about.html\">当サイトご利用について</a>\r\n      </div>\r\n    </div>\r\n  </div>\r\n  <div class=\"f_inner03\">\r\n    <div class=\"f_inner04 clearfix\">\r\n      <div class=\"logo\">\r\n        <a href=\"./\">\r\n          <img src=\"img/common/f_logo.png\" width=\"368px\" height=\"42px\" alt=\"\" >\r\n        </a>\r\n      </div>\r\n      <div class=\"name\">\r\n        <img src=\"img/common/f_name.png\" width=\"198px\" height=\"20px\" alt=\"\" >\r\n        <p>\r\n          　〒986-0858　<br class=\"sp\">宮城県石巻市三ツ股一丁目2番77号<br>\r\n          　TEL : <span class=\"tel-link\">0225-95-3381</span>　<br class=\"sp\">FAX : 0225-94-2996\r\n        </p>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</footer>\r\n\r\n</div><!--  /wrapper -->\r\n\r\n</body>\r\n\r\n</html>","finalUrl":"http://www.kagaku-k.co.jp/information.html","rendered":false,"_cachedAt":"2026-06-22T16:07:08.313Z"}