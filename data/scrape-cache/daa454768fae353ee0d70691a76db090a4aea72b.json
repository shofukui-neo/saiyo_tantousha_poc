{"url":"https://www.kinon.co.jp/recruit/job-02.shtml","html":"<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\">\n<meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width\" />\n<meta name=\"format-detection\" content=\"telephone=no\">\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/common.css\" />\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/zone.css\" />\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/bpts.css\" />\n<!-- Basic parts -->\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/unit.css\" />\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/col.css\" />\n<!-- 本文領域レイアウタ -->\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/other.css\" />\n<!-- 職種紹介用CSS -->\n<link rel=\"stylesheet\" type=\"text/css\" href=\"css/job.css\" />\n<title>施工管理│職種紹介│Recruit│キノンビクス株式会社</title>\n<style>\n/* サブページのステージ */\n#zone_substage {\n\tbackground-image: url(\"image/job-02-01.jpg\");\n\tcolor: #fff;\n\tmax-width: 100%;\n}\n#job_section04 .box::after {\n\tbackground-image: url(\"image/icon-job-02.jpg\");\n}\n#zone_substage div {\n\tbackground: url(\"image/bg-triangle-02.png\")no-repeat;\n\tbackground-position: 7% 92%;\n}\n\n@media screen and (max-width : 960px) {\n#zone_substage div {\n\tbackground-position: 4% 71%!important;\n}\n}\n\n@media screen and (max-width : 768px) {\n#zone_substage div {\n\tbackground-size: 100px!important;\n}\n#zone_substage {\n\tbackground-position: right center;\n}\n}\n\n@media screen and (max-width : 500px) {\n#zone_substage div {\n\tbackground: none;\n}\n}\n</style>\n<!-- スクリプトのインクルード（事前呼び出し） --> \n<meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\" />\n<link rel=\"icon\" href=\"../favicon.ico\">\n\n<!-- fontawesome -->\n<link href=\"https://use.fontawesome.com/releases/v5.6.1/css/all.css\" rel=\"stylesheet\">\n\n\n</head>\n<body>\n<div id=\"zone_sheet\"> \n  <!-- ヘッダーのインクルード --> \n  <meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\" />\n<!--\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/css/other.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/css/bpts.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/css/common.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/css/zone.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/css/unit.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/css/col.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/css/other.css\"/>\n -->\n<div class=\"header_bg\">\n<div class=\"header_logo\"><a href=\"../../\"><img src=\"../image/common/logo.svg\"></a></div>\n<nav class=\"pc_menu\">\n  <div class=\"o_mainmenu\">\n    <ul>\n      <li><a href=\"../about/\">About us</a>\n        <ul>\n          <li><a href=\"/about/index.shtml\">代表挨拶</a></li>\n          <li><a href=\"/about/overview.shtml\">会社概要</a></li>\n          <li><a href=\"/about/philosophy.shtml\">経営理念</a></li>\n          <li><a href=\"/about/promises.shtml\">7つのお約束</a></li>\n          <li><a href=\"/about/history.shtml\">沿革</a></li>\n          <li><a href=\"/about/employee.shtml\">社員保有資格一覧</a></li>\n          <li><a href=\"/about/certifications.shtml\">各種認定と宣言</a></li>\n        </ul>\n      </li>\n      <li><a href=\"../culture/\">Culture</a></li>\n      <li><a href=\"../solution/\">Solution</a>\n        <ul>\n          <li><a href=\"../solution/index.shtml#jump_01\">システムソリューション</a></li>\n          <li><a href=\"../solution/index.shtml#s_index_section02\">場所から探す</a></a></li>\n          <li><a href=\"../solution/index.shtml#s_index_section03\">納入事例</a></a></li>\n        </ul>\n      </li>\n      <li><a href=\"../recruit/\">Recruit</a>\n        <ul>\n          <li><a href=\"/recruit/\">採用情報</a></li>\n          <li><a href=\"/recruit/job.shtml\">職種紹介</a></li>\n          <li><a href=\"/recruit/interview.shtml\">社員インタビュー</a></li>\n          <li><a href=\"/recruit/requirements.shtml\">募集要項</a></li>\n        </ul>\n      </li>\n      <li><a href=\"../misc/contact.shtml\">Contact</a></li>\n    </ul>\n  </div>\n</nav>\n</div>\n<!-- レスポンシブメニュー　 -->\n<header>\n<div class=\"header-logo-menu\">\n<div id=\"nav-drawer\">\n<input id=\"nav-input\" type=\"checkbox\" class=\"nav-unshown\">\n<label id=\"nav-open\" for=\"nav-input\">\n<span></span>\n<p class=\"label_txt_menu\">MENU</p>\n</label>\n<label class=\"nav-unshown\" id=\"nav-close\" for=\"nav-input\"></label>\n<div id=\"nav-content\">\n<!--  ----------------- -->\n<div class=\"accordion\"> \n  <!-- menu1 -->\n  <div class=\"option\">\n    <input type=\"checkbox\" id=\"toggle1\" class=\"toggle\">\n    <label class=\"title item10\" for=\"toggle1\">About us</label>\n    <div class=\"content\">\n      <ul>\n        <li class=\"f_m10_10\"><a href=\"/about/index.shtml\">代表挨拶</a></li>\n        <li class=\"f_m10_20\"><a href=\"/about/overview.shtml\">会社概要</a></li>\n        <li class=\"f_m10_30\"><a href=\"/about/philosophy.shtml\">経営理念</a></li>\n        <li class=\"f_m10_40\"><a href=\"/about/promises.shtml\">7つのお約束</a></li>\n        <li class=\"f_m10_50\"><a href=\"/about/history.shtml\">沿革</a></li>\n        <li class=\"f_m10_60\"><a href=\"/about/employee.shtml\">社員保有資格一覧</a></li>\n        <li class=\"f_m10_70\"><a href=\"/about/certifications.shtml\">各種認定と宣言</a></li>\n      </ul>\n    </div>\n  </div>\n  <!-- menu2 -->\n  <div class=\"option\">\n    <div class=\"one_link\"><a href=\"../culture/\">Culture</a></div>\n  </div>\n  <!-- menu3 -->\n  <div class=\"option\">\n    <input type=\"checkbox\" id=\"toggle3\" class=\"toggle\">\n    <label class=\"title item50\" for=\"toggle3\">Solution</label>\n    <div class=\"content\">\n      <ul>\n        <li class=\"f_m30_10\"><a href=\"../solution/index.shtml#sp_jump_01\">システムソリューション</a></li>\n        <li class=\"f_m30_20\"><a href=\"../solution/index.shtml#jump_15\">場所から探す</a></a></li>\n        <li class=\"f_m30_30\"><a href=\"../solution/index.shtml#jump_02\">納入事例</a></a></li>\n      </ul>\n    </div>\n  </div>\n  <!-- menu4 -->\n  <div class=\"option\">\n    <input type=\"checkbox\" id=\"toggle4\" class=\"toggle\">\n    <label class=\"title item60\" for=\"toggle4\">Recruit</label>\n    <div class=\"content\">\n      <ul>\n        <li class=\"f_m40_10\"><a href=\"/recruit/\">採用情報</a></li>\n        <li class=\"f_m40_20\"><a href=\"/recruit/job.shtml\">職種紹介</a></li>\n        <li class=\"f_m40_30\"><a href=\"/recruit/interview.shtml\">社員インタビュー</a></li>\n        <li class=\"f_m40_40\"><a href=\"/recruit/requirements.shtml\">募集要項</a></li>\n      </ul>\n    </div>\n  </div>\n  <!-- menu5 -->\n  <div class=\"option\">\n    <div class=\"one_link\"><a href=\"../misc/contact.shtml\">Contact</a></div>\n  </div>\n<!-- menu6 -->\n  <div class=\"option\">\n    <div class=\"one_link\"><a href=\"../\">Home</a></div>\n  </div>\n</div alt=\"eod:accordion\">\n</header>\n<!-- --------------------------------------------------- --> \n\n \n  <!-- ヘッダーのインクルード 終わり　--> \n  \n  <!-- ステージ-->\n  <div id=\"zone_substage\">\n    <div>\n      <h1>施工管理</h1>\n      <p>大画面のスクリーンに映し出される鮮明な映像」<br>\n        「心を震わせる迫力の音響」<br>\n        「教育現場からビジネスの最前線まで、ICTで広がる新たな世界」<br>\n        こうしたワクワクする未来を現実にするのが、私たちの仕事。<br>\n        設計図だけでは、まだアイデアの世界。あなたの手によって命を吹き込まれた空間が、人を感動させる。<br>\n        あなたの技術が、お客様の夢見る世界をカタチにする！ </p>\n    </div>\n  </div alt=\"eod:zone_substage\">\n  <!-- ステージ　終わり --> \n  <!--- パンくず -->\n  <ol class=\"zone_pankuzu\">\n    <li><a href=\"../\">HOME</a></li>\n    <li><a href=\"/recruit/\">Recruit</a></li>\n    <li><a href=\"/recruit/job.shtml\">職種紹介</a></li>\n    <li>施工管理</li>\n  </ol>\n  <!-- パンくず --> \n  <!-- 第2層 -->\n  <div id=\"zone_middle_floor\"> \n    <!--　ボディ領域　-->\n    <div id=\"zone_body\"> \n      <!--　メインエリア　-->\n      <div id=\"zone_mainarea_1col\">\n        <div class=\"sp_padding\"> \n          \n          <!--　▼▼▼　本文領域　▼▼▼　-->\n          <div class=\"col_textarea_full\">\n          <ul class=\"page-nav bpts_flexbox_noblock justify wrap\">\n            <li><a href=\"#job_section02\">仕事内容</a></li>\n            <li><a href=\"#job_section03\">キャリアステップ</a></li>\n            <li><a href=\"#interview_id\">INTERVIEW</a></li>\n          </ul>\n          <section id=\"job_section01\">\n            <h2>技術職の魅力</h2>\n            <ul class=\"check-list\">\n              <li>自分の手で、理想の空間をつくる<br>\n                機器を設置し、配線を整え、システムを動かす…目の前で形になっていく瞬間は、めちゃくちゃワクワクする！ </li>\n              <li>多彩なフィールドで活躍できる<br>\n                あなたの技術が、さまざまな業界の最前線を支え、「自分が手がけたシステムが、今まさに動いている」と実感できる！ </li>\n              <li>チームでつくりあげる達成感<br>\n                「ここを調整すると、もっと良くなる！」みんなで知恵を出し合い、試行錯誤しながら完成させたときの達成感は格別！ </li>\n            </ul>\n            <h3><span>＼</span>　　こんな人にピッタリ　　<span>／</span></h3>\n            <ul class=\"circle-list\">\n              <li>\n                <p><span class=\"color\">モノづくりやDIY </span>が好き！</p>\n              </li>\n              <li>\n                <p> <span class=\"color\">最新の映像・音響機器</span>をいじってみたい！</p>\n              </li>\n              <li>\n                <p>「自分がつくったもの」が<span class=\"color\">形に残る仕事</span>がしたい！</p>\n              </li>\n            </ul>\n          </section>\n          <section id=\"job_section02\">\n            <div class=\"bpts_flexbox_onoff justify flexbox\">\n              <div class=\"left\">\n                <h2>仕事内容</h2>\n                <div> <img src=\"image/job-02-parts-01.jpg\" alt=\"\" class=\"img01\"> <img src=\"image/job-02-parts-02.jpg\" alt=\"\" class=\"img02\"> <img src=\"image/job-02-parts-03.jpg\" alt=\"\" class=\"img03\"> </div>\n              </div>\n              <div class=\"right\">\n                <ul class=\"circle-list\">\n                  <li>\n                    <h3>施工管理 </h3>\n                    <p>現場を下見し、施工計画を考え、部材の手配や協力会社への工事依頼を行います。</p>\n                  </li>\n                  <li>\n                    <h3>弱電設備工事・配線工事</h3>\n                    <p>機器の設置や必要な電気配線工事を行います。 </p>\n                  </li>\n                  <li>\n                    <h3>AV機器の設置</h3>\n                    <p>プロジェクターやスピーカーなどの機器を、最適な位置や角度になるよう設置します。 </p>\n                  </li>\n                  <li>\n                    <h3>動作チェック</h3>\n                    <p>機器を設定・調整し、動作に問題がないか確認します。 </p>\n                  </li>\n                </ul>\n                <h4 class=\"color\">こんな資格が取得可能！ </h4>\n                <ul class=\"sub-list\">\n                  <li>\n                    <h5>電気工事士</h5>\n                    <p>電気設備の施工技術が身につく！ </p>\n                  </li>\n                  <li>\n                    <h5>電気工事施工管理技士</h5>\n                    <p>安全で高品質な施工を実現するリーダーになれる！ </p>\n                  </li>\n                  <li>\n                    <h5>消防設備士</h5>\n                    <p>非常警報設備など、対応できる幅が広がる！</p>\n                  </li>\n                </ul>\n              </div>\n            </div>\n          </section>\n          <section id=\"job_section03\">\n            <h2>キャリアステップ</h2>\n            <img src=\"image/job-02-05.svg\" alt=\"\">\n            <div class=\"bpts_flexbox_onoff justify flexbox\">\n              <h3><span class=\"big color\">1</span>年目</h3>\n              <div class=\"wrap\">\n                <div class=\"l_step_title\">基礎を学び、施工の楽しさを実感！ </div>\n                <ul class=\"circle-list\">\n                  <li>\n                    <h4>先輩について学び、現場に慣れる！ </h4>\n                    <p>基本的な作業からスタートし、配線の取り付けや機器の配置を実践しながら、施工の流れを覚えます。<br>\n                      作業を安全に進めるための知識や、設備の知識を習得し、少しずつ「自分でできること」を増やしていきます。 </p>\n                  </li>\n                </ul>\n                <div class=\"txt-box\">\n                  <h5>おすすめ資格</h5>\n                  <p>第二種電気工事士 - 電気工事の基本を学び、小規模な工事に挑戦しよう！ </p>\n                </div>\n              </div>\n            </div>\n            <div class=\"bpts_flexbox_onoff justify flexbox\">\n              <h3><span class=\"big color\">2</span>年目</h3>\n              <div class=\"wrap\">\n                <div class=\"l_step_title\">経験を積み、工事を効率的に進める！</div>\n                <ul class=\"circle-list\">\n                  <li>\n                    <h4>実践経験を増やし、施工スキルを磨く</h4>\n                    <p>先輩のフォローを受けながら、より難易度の高い現場にもチャレンジします。<br>\n                      「どうすればもっと効率よく作業できるか？」を考えながら、施工のスピードと精度を上げていきます。<br>\n                      少しずつ任される仕事も増え、先輩の期待を超える動きができるように成長します！ </p>\n                  </li>\n                </ul>\n                <div class=\"txt-box\">\n                  <h5>おすすめ資格</h5>\n                  <p>消防設備士 – 非常警報設備などの施工技術を学び、対応できる現場の幅を広げよう！ </p>\n                </div>\n              </div>\n            </div>\n            <div class=\"bpts_flexbox_onoff justify flexbox\">\n              <h3><span class=\"big color\">3</span>年目</h3>\n              <div class=\"wrap\">\n                <div class=\"l_step_title\">自分で考え、現場を支える存在に！ </div>\n                <ul class=\"circle-list\">\n                  <li>\n                    <h4>施工の全体像を把握し、主体的に動く！ </h4>\n                    <p>作業の進捗を管理しながら、機器の設置・配線・テストまで一連の流れを把握。<br>\n                      現場で発生する課題に対して「どう解決するか？」を考え、自分なりの判断で対応できる力を身につけます。<br>\n                      また、先輩や他の技術者と連携しながら、少しずつリーダーシップを発揮し、「任せても大丈夫」と思われる存在を目指します！ </p>\n                  </li>\n                </ul>\n                <div class=\"txt-box\">\n                  <h5>おすすめ資格</h5>\n                  <p>•第一種電気工事士 - より高度な電気工事技術を学び、大規模な施設の施工も担当できるように！ </p>\n                </div>\n              </div>\n            </div>\n          </section>\n          <div id=\"interview_id\" class=\"bpts_spacer_h80\"></div>\n          <section id=\"job_section04\">\n            <h2>社員INTERVIEW</h2>\n            <img src=\"image/bg-job.gif\" alt=\"\"> <a href=\"interview-04.shtml\">\n            <div class=\"box\">\n              <div>\n                <h3>施工管理<br>\n                  滋賀システム技術チーム<br>\n                  30代　在職歴：1年</h3>\n                <span>Read more　　→</span></div>\n              <div class=\"ciecle_icon\"><img src=\"image/icon-job-02.jpg\"></div>\n            </div>\n            </a>\n            </div>\n          </section>\n          <section id=\"job_section05\">\n            <h2>その他職種</h2>\n            <ul class=\"bpts_flexbox_onoff justify flexbox\">\n              <li><a href=\"job-01.shtml\">\n                <h3><img src=\"image/job-01-01.jpg\" alt=\"\"><span>あなたの提案で未来が変わる！<br>\n                  映像・音響・ICTシステムの<br>\n                  営業職とは？</span></h3>\n                営業　　→</a> </li>\n              <li><a href=\"job-03.shtml\">\n                <h3><img src=\"image/job-03-01.jpg\" alt=\"\"><span>アイデアで未来を創造する！<br>\n                  映像・音響・ICTシステムの<br>\n                  エンジニア職とは？</span></h3>\n                システムエンジニア　　→</a> </li>\n              <li> <a href=\"job-04.shtml\">\n                <h3><img src=\"image/job-04-01.jpg\" alt=\"\"><span>知識で未来を輝かせる！<br>\n                  映像・音響・ICTシステムの<br>\n                  サポート職！</span></h3>\n                保守・サポート　　→</a> </li>\n            </ul>\n          </section>\n        </div alt=\"col_textarea_full\">\n        <!--　▲▲▲　本文領域　終わり　▲▲▲　--> \n      </div>\n      <!-- eod:sp_padding --> \n    </div alt=\"eod:zone_mainarea\">\n    <!--　メインエリア　終わり　--> \n  </div alt=\"eod:zone_body\">\n  <!--　ボディ領域　終わり　--> \n</div alt=\"eod:zone_middle\">\n<!--　第2層　終わり　--> \n<!-- リクルート用　お問い合わせフッターのインクルード --> \n<meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\" />\n<meta name=\"format-detection\" content=\"telephone=no\">\n<!-- \n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/common.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/zone.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/bpts.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/unit.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/col.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/other.css\"/>\n-->\n<!-- リクルートフッターここから -->\n<div class=\"bpts_footer_recruit\"> \n  <!-- ▼ 左ボックス -->\n  <div>\n    <h4>採用に関するお問い合わせ</h4>\n    <table>\n      <tr>\n        <th>担当</th>\n        <td><span>管理グループ</span><br>\n          西村 伸宏</td>\n      </tr>\n      <tr>\n        <th>TEL</th>\n        <td>077-552-1144</td>\n      </tr>\n<!--      <tr>\n        <th>Mail　</th>\n        <td><a href=\"mailto:\"></a></td>\n      </tr>-->\n    </table>\n  </div>\n  <!-- ▲ 左ボックス --> \n  <!-- ▼ 右ボックス -->\n  <div> <a href=\"requirements.shtml\">\n    <h6>募集要項</h6></a> </div>\n  <!-- ▲ 右ボックス --> \n</div>\n<!-- ▲リクルートフッターここまで --> \n\n<!-- お問い合わせfooterここから -->\n<div class=\"bpts_footer_contact_area recruit_wrap\">\n  <h6 class=\"recruit_fotter\">ご相談等ありましたら<span>お気軽にお問い合わせください</span></h6>\n  <div class=\"center\"> <a href=\"/recruit/saiyou-contact.shtml\" class=\"bpts_btn_squarered\"><span>お問い合わせフォームを開く</span></a> </div>\n</div>\n<!-- お問い合わせfooterここまで --> \n \n<!--　第3層　-->\n<div id=\"zone_bottom_floor\"> \n  <!--　フッター　-->\n  <div id=\"zone_footer\"> \n    <!-- フッターのインクルード --> \n    <meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\" />\n<meta name=\"format-detection\" content=\"telephone=no\">\n<!-- \n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/common.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/zone.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/bpts.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/unit.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/col.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/other.css\"/>\n -->\n<div id=\"pagetop\"><a href=\"#top\">Page Top</a></div>\n<!--　フッター　-->\n<footer id=\"footer\">\n<div class=\"bpts_footer_wrapper\"> \n  \n  <!-- -------------------- ▼　画像とロゴ -------------------- -->\n  <div class=\"footer_image_logo\"><!-- <img src=\"../image/common/footer-img.jpg\" style=\"max-width: 1211px;width: 100%;\">-->\n    <h2><img src=\"../image/sitetop/logo-title-w.svg\"></h2>\n  </div>\n  <!-- -------------------- ▲　画像とロゴ -------------------- --> \n  \n  <!-- -------------------- ▼ 地図のエリア -------------------- -->\n  <div class=\"footer