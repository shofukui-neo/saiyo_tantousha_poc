nter_sp.png\" alt=\"社内専用ダウンロードセンター\" class=\"footer_banner dl_center mt30 sp_box\">\r\n        </a>\r\n        <a href=\"../supplier/supplier.pdf\" target=\"_blank\">\r\n            <img src=\"../common/banner_supplier_sp.png\" alt=\"供給者の皆様へ\" class=\"footer_banner sp_box\">\r\n        </a>\r\n    </div>\r\n\r\n    <div class=\"space07\"></div>\r\n\r\n    <div class=\"copyright txt14 mt40 txt12_sp\"><p class=\"px50\">COPYRIGHT(C) SANEI-KIKAI Co., Ltd. ALL RIGHTS RESERVED.</p></div>\r\n\r\n </footer>\r\n\r\n\r\n<a href=\"#top\" class=\"pagetop\">\r\n    <img src=\"../common/pagetop.png\">\r\n</a>\r\n\r\n<script src=\"../js/swiper-bundle.min.js\"></script>\r\n<script>\r\ndocument.addEventListener('click', e => {\r\n\r\n\r\n  const match = e.target.className.match(/q_([1-5])/);\r\n  const num = match[1];\r\n  document.querySelectorAll(`.q_${num}`).forEach(el => el.classList.toggle('active'));\r\n});\r\n</script>\r\n</body>\r\n</html>\r\n","finalUrl":"http://sanei-kikai.co.jp/recruit/index.php","rendered":false,"_cachedAt":"2026-06-17T23:29:30.199Z"}