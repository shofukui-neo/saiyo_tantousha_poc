3A%2F%2Fdevelopers.facebook.com%2Fdocs%2Fplugins%2F&amp;src=sdkpreparse\" class=\"fb-xfbml-parse-ignore\">シェア</a></div>\n</div><div class=\"social_media_btn twitter_btn\">\n<a href=\"https://twitter.com/share?ref_src=twsrc%5Etfw\" data-show-count=\"false\" data-url=\"https://www.pref.miyagi.jp/site/kyouiku/saiyousenkou.html\" data-text=\"令和８年度宮城県職員採用選考考査の実施概要\" data-lang=\"ja\" class=\"twitter-share-button\">ツイート</a><script async src=\"https://platform.twitter.com/widgets.js\" charset=\"utf-8\"></script>\n</div></div>\n<p id=\"tmp_print\"></p>\n<p id=\"tmp_update\">掲載日：2026年4月20日</p>\n\n</div>\n</div>\n</div>\n<div id=\"tmp_wrap_main\" class=\"column_rnavi\">\n<div id=\"tmp_main\">\n<div class=\"wrap_col_main\">\n<div class=\"col_main\">\n<p id=\"tmp_honbun\" class=\"skip rs_skip\">ここから本文です。</p>\n<div id=\"tmp_readspeaker\" class=\"rs_preserve rs_skip rs_splitbutton rs_addtools rs_exp\"></div>\n<div id=\"tmp_contents\">\n\n<h1>令和８年度宮城県職員採用選考考査の実施概要</h1>\n<h2>選考考査のお知らせ</h2>\n<table border=\"1\" cellpadding=\"5\" cellspacing=\"0\" summary=\"\" class=\"datatable\">\n\t<caption>\n\t<p><a id=\"content_topgakugei\" name=\"content_topgakugei\"><strong>募集職種一覧</strong></a></p>\n\t</caption>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"col\">募集職種</th>\n\t\t\t<th scope=\"col\">採用予定人員</th>\n\t\t\t<th colspan=\"1\" scope=\"col\">実施スケジュール</th>\n\t\t\t<th scope=\"col\">備考</th>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<td colspan=\"1\" rowspan=\"2\">\n\t\t\t<p>学芸員（美術）</p>\n\t\t\t</td>\n\t\t\t<td colspan=\"1\" rowspan=\"2\">\n\t\t\t<p>1人</p>\n\t\t\t<p>程度</p>\n\t\t\t</td>\n\t\t\t<td colspan=\"1\" rowspan=\"2\">\n\t\t\t<p>申込受付期間</p>\n\t\t\t<p>令和8年4月24日（金曜日）～5月19日（火曜日）</p>\n\t\t\t<p>第1次考査</p>\n\t\t\t<p>令和8年6月21日（日曜日）</p>\n\t\t\t<p>第2次考査</p>\n\t\t\t<p>令和8年7月14日（火曜日）～7月17日（金曜日）のうち指定する日</p>\n\t\t\t</td>\n\t\t\t<td colspan=\"1\" rowspan=\"2\">\n\t\t\t<p>詳細はこちらになります。</p>\n\t\t\t<p><a href=\"/documents/3757/boshuuyoukou.pdf\" class=\"icon_pdf\">R8宮城県職員（学芸員（美術））募集要項（PDF：1,055KB）</a></p>\n\t\t\t<p><a href=\"/documents/3757/shutsudairei.pdf\" class=\"icon_pdf\">専門考査の問題例（PDF：87KB）</a></p>\n\t\t\t</td>\n\t\t</tr>\n\t\t<tr>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<td colspan=\"1\" rowspan=\"2\">\n\t\t\t<p>学芸員（美術史・経験者）</p>\n\t\t\t</td>\n\t\t\t<td colspan=\"1\" rowspan=\"2\">\n\t\t\t<p>1人</p>\n\t\t\t<p>程度</p>\n\t\t\t</td>\n\t\t\t<td colspan=\"1\" rowspan=\"2\">\n\t\t\t<p>申込受付期間</p>\n\t\t\t<p>令和8年4月24日（金曜日）～5月19日（火曜日）</p>\n\t\t\t<p>第1次考査</p>\n\t\t\t<p>令和8年6月21日（日曜日）</p>\n\t\t\t<p>第2次考査</p>\n\t\t\t<p>令和8年7月14日（火曜日）～7月17日（金曜日）のうち指定する日</p>\n\t\t\t</td>\n\t\t\t<td colspan=\"1\" rowspan=\"2\">\n\t\t\t<p>詳細はこちらになります。</p>\n\t\t\t<p><a href=\"/documents/3757/boshuuyoukoukeikensha.pdf\" class=\"icon_pdf\">R8宮城県職員（学芸員（美術史・経験者））募集要項（PDF：428KB）</a></p>\n\t\t\t<p><a href=\"/documents/3757/shokumukeirekisho.xls\" class=\"icon_excel\">職務経歴書（エクセル：112KB）</a></p>\n\t\t\t</td>\n\t\t</tr>\n\t</tbody>\n</table>\n<h3>考査会場</h3>\n<h4>第1次考査</h4>\n<p>　東北福祉大学仙台駅東口キャンパス（仙台市宮城野区榴岡２－５－26）</p>\n<h4>第2次考査</h4>\n<p>　仙台市内</p>\n<h3>受考手続き等</h3>\n<p>以下のリンクからみやぎ電子申請サービス（LoGoフォーム）へアクセスし、申し込んでください。</p>\n<p>《学芸員（美術）》</p>\n<p><a href=\"https://logoform.jp/form/GQGB/1538607\">【宮城県】令和８年度宮城県職員採用選考考査受考申込フォーム【学芸員（美術）】_教育庁総務課（外部サイトへリンク）</a></p>\n<p>《学芸員（美術史・経験者）》</p>\n<p><a href=\"https://logoform.jp/form/GQGB/1538363\">【宮城県】令和８年度宮城県職員採用選考考査受考申込フォーム【学芸員（美術史・経験者）】_教育庁総務課（外部サイトへリンク）</a></p>\n<p>&nbsp;</p>\n<p>※電子申請を行う際に顔写真等のデータ（画像(jpg,jpeg,gif,png),PDF(pdf)）をアップロードする必要があります。</p>\n<p>※申込完了後、「受考票」を電子メールで送付しますので、第1次考査当日に持参してください。</p>\n<p>&nbsp;</p>\n\n\n\n\n\n</div>\n<div id=\"tmp_inquiry\">\n<div id=\"tmp_inquiry_ttl\">\n<p>お問い合わせ先</p>\n</div>\n<div id=\"tmp_inquiry_cnt\">\n<form method=\"post\" action=\"https://www.pref.miyagi.jp/cgi-bin/simple_faq/form.cgi\">\n<div class=\"inquiry_parts\">\n<p>\n<a href=\"/soshiki/kyou-soumu/index.html\">総務課職員人事班</a></p>\n<p>宮城県仙台市青葉区本町三丁目8-1宮城県庁　16階</p>\n<p>電話番号：022-211-3638</p>\n<p>ファックス番号：022-211-3699</p>\n<p class=\"inquiry_btn\"><input value=\"お問い合わせフォーム\" type=\"submit\"></p>\n</div>\n<p>\n<input typ