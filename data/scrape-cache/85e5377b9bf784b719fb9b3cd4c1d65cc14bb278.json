es/css/reset.min.css\">\n\t<script type=\"module\" src=\"/saiyo/files/js/head.astro_astro_type_script_index_0_lang.js\"></script>\n\n<link rel=\"stylesheet\" href=\"/saiyo/files/css/global.css\">\n<link rel=\"stylesheet\" href=\"/saiyo/files/css/career.css\">\n<link rel=\"stylesheet\" href=\"/saiyo/files/css/newgraduate2-about_strength.css\"><script type=\"module\" src=\"/saiyo/files/js/page.js\"></script></head>\n\n  <body id=\"pagetop\">\n    <div id=\"bgvideo\">\n      <video class=\"-pc\" src=\"/saiyo/files/img/common/bg.mp4\" muted loop autoplay playsinline poster=\"/saiyo/files/img/common/video-poster.png\"></video>\n      <video class=\"-sp\" src=\"/saiyo/files/img/common/bg_sp.mp4\" muted loop autoplay playsinline poster=\"/saiyo/files/img/common/video-poster.png\"></video>\n    </div>\n\n    <header id=\"newgrad_header\">\n  <div class=\"container menu_overlay\">\n    <div class=\"inner\">\n      <div>\n        <div class=\"logo_group\">\n          <a href=\"/saiyo/newgraduate/\">\n            <img class=\"logo\" src=\"/saiyo/files/img/common/logo.svg\" width=\"129\" height=\"30\" alt=\"Nito 日東工業\">\n            新卒採用サイト\n          </a>\n        </div>\n      </div>\n\n      <nav class=\"nav_group\">\n         <ul class=\"list\">\n           <li class=\"item\">\n             <a class=\"link\" href=\"/saiyo/newgraduate/industry/\">電気の流れを知る</a>\n              <div class=\"nav_child\">\n              <div class=\"nav_child_inner\">\n                <a href=\"/saiyo/newgraduate/industry/\" class=\"nav_child_index\">\n                  <span class=\"nav_child_num\"><small>#</small>01</span>\n                  <span class=\"nav_child_jp\">業界を知る</span>\n                  <span class=\"nav_child_en\">Our Industry</span>\n                </a>\n              </div>\n            </div>\n           </li>\n           <li class=\"item\">\n            <div class=\"link nav_trigger\">会社・事業を知る</div>\n            <div class=\"nav_child\">\n              <div class=\"nav_child