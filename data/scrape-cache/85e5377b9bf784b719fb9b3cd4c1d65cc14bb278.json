       <div class=\"nav_child_index accordion_trigger\">\n                    <span class=\"nav_child_num\"><small>#</small>05</span>\n                    <span class=\"nav_child_jp\">採用情報</span>\n                    <span class=\"nav_child_en\">Recruit</span>\n                  </div>\n                <div class=\"nav_child_detail\">\n                  <div class=\"nav_child_img -pc -active\">\n                    <img class=\"site_type\" src=\"/saiyo/files/img/newgraduate/common/nav_recruit.jpg\" width=\"190\" height=\"171\" alt=\"Recruit 新卒採用情報\">\n                  </div>\n                  <div class=\"nav_child_img -pc\">\n                    <img class=\"site_type\" src=\"/saiyo/files/img/newgraduate/common/nav_recruit_qa.jpg\" width=\"190\" height=\"171\" alt=\"Recruit FAQ\">\n                  </div>\n                  <div class=\"nav_child_wrap\">\n                    <a class=\"nav_child_link\" data-img=\"0\" href=\"/saiyo/newgraduate/recruit/\">\n                      <div class=\"nav_child_img -sp -active\">\n                        <img class=\"site_type\" src=\"/saiyo/files/img/newgraduate/common/nav_recruit.jpg\" width=\"190\" height=\"171\" alt=\"Recruit 新卒採用情報\">\n                      </div>\n                      新卒採用情報\n                      <svg class=\"circle\" viewBox=\"0 0 24 24\">\n                        <g id=\"oval_675\" data-name=\"oval 675\" fill=\"none\" stroke=\"#e50012\" stroke-width=\"1\">\n                          <circle cx=\"12\" cy=\"12\" r=\"12\" stroke=\"none\"></circle>\n                          <circle cx=\"12\" cy=\"12\" r=\"11.5\" fill=\"none\"></circle>\n                        </g>\n                      </svg>\n                    </a>\n                    <a class=\"nav_child_link\" data-img=\"1\" href=\"/saiyo/newgraduate/recruit_qa/\">\n                      <div class=\"nav_child_img -sp\">\n                        <img class=\"site_type\" src=\"/saiyo/files/img/newgraduate/common/nav_recruit_qa.jpg\" width=\"190\" height=\"171\" alt=\"Recruit FAQ\">\n                      </div>\n                      FAQ\n                      <svg class=\"circle\" viewBox=\"0 0 24 24\">\n                        <g id=\"oval_675\" data-name=\"oval 675\" fill=\"none\" stroke=\"#e50012\" stroke-width=\"1\">\n                          <circle cx=\"12\" cy=\"12\" r=\"12\" stroke=\"none\"></circle>\n                          <circle cx=\"12\" cy=\"12\" r=\"11.5\" fill=\"none\"></circle>\n                        </g>\n                      </svg>\n                    </a>\n                  </div>\n                </div>\n              </div>\n            </div>\n           </li>\n         </ul>\n          <a class=\"entrylink\" href=\"mailto:saiyo@nito.co.jp\">\n            <span class=\"txt\">お問い合わせ</span>\n          </a>\n      </nav>\n\n      <div class=\"menu-btn -sp\" id=\"menu-btn\">\n        <span class=\"bar\"></span>\n        <span class=\"bar\"></span>\n      </div>\n    </div>\n  </div>\n\n</header>\n\n<div class=\"page_overlay\"></div>\n    <main>\n      <div class=\"wave wave01\">\n        <img src=\"/saiyo/files/img/newgraduate/common/fv_wave01.svg\" alt=\"\">\n      </div>\n      <div class=\"wave wave02\">\n        <img src=\"/saiyo/files/img/newgraduate/common/fv_wave02.svg\" alt=\"\">\n      </div>\n      <div class=\"wave wave03\">\n        <img src=\"/saiyo/files/img/newgraduate/common/fv_wave03.svg\" alt=\"\">\n      </div>\n\n      <section class=\"fv\">\n        <div class=\"inner\">\n          <div class=\"ttl_group\">\n            <p class=\"category\">業界を知る</p>\n            <h1 class=\"page_ttl\">日東工業の強み</h1>\n            <p class=\"en\">Nitto Kogyo’s Strengths</p>\n          </div>\n          <div class=\"image\">\n            <picture>\n              <source media=\"(max-width: 768px)\" srcset=\"/saiyo/files/img/newgraduate/about_strength/fv_image_sp.jpg\">\n              <img src=\"/saiyo/files/img/newgraduate/about_strength/fv_image.jpg\" alt=\"\">\n            </picture>\n          </div>\n        </div>\n\n        <div class=\"slider_area\">\n          <div id=\"fv_slider\" class=\"splide\">\n            <div class=\"splide__track\">\n              <ul class=\"splide__list\">\n                <li class=\"splide__slide\">Strengths</li>\n                <li class=\"splide__slide\">Strengths</li>\n                <li class=\"splide__slide\">Strengths</li>\n                <li class=\"splide__slide\">Strengths</li>\n                <li class=\"splide__slide\">Strengths</li>\n                <li class=\"splide__slide\">Strengths</li>\n              </ul>\n            </div>\n          </div>\n        </div>\n      </section>\n\n      <div class=\"main_container\">\n        <section class=\"if -fadeUp\" id=\"if\">\n          <div class=\"inner\">\n            <div class=\"conts_ttl\">\n              <h2 class=\"ttl\">\n                もしも日東工業が<br class=\"-sp\">なかったら？\n              </h2>\n            </div>\n\n            <p class=\"intro_cap\">\n              日東工業の製品は、電気を安全に使える生活を守るため、街中のあらゆるところにあふれています。そんな、人々のあたりまえの日常を守る私たちの製品、もしなかったらどうなるの？「あたりまえ」が失われてしまう5つのケースをご紹介します。\n            </p>\n\n            <div class=\"slider_area\">\n              <div id=\"if_slide\" class=\"splide\" aria-label=\"\">\n                <div class=\"splide__track\">\n                  <ul class=\"splide__list\">\n                    <li class=\"splide__slide\">\n                      <div class=\"slide_head\">\n                        <p class=\"head_text\">\n                          電気を建物や施設へ<br class=\"-sp\">引き込む\n                        </p>\n                        <p class=\"head_num\">CASE<span class=\"num\">01</span></p>\n                      </div>\n                      <div class=\"content\">\n                        <div class=\"text_group\">\n                          <p class=\"lead\">\n                            <span class=\"line\">高圧受電設備</span>\n                          </p>\n                          <p class=\"text\">\n                            電力会社から供給される高圧電力を建物や施設へ引き込むために適切な電圧に変換するのが「高圧受電設備」です。\n                          </p>\n                        </div>\n                        <div class=\"wrap\">\n                          <div class=\"image\">\n                            <img src=\"/saiyo/files/img/newgraduate/about_strength/case_image01.jpg\" width=\"451\" height=\"451\" loading=\"lazy\" alt=\"高圧受電設備\">\n                          </div>\n                          <div class=\"balloon\">\n                            <p class=\"balloon_copy\">\n                              もしも日東工業がなかったら…？\n                            </p>\n                            <div class=\"balloon_image\">\n                              <img src=\"/saiyo/files/img/newgraduate/about_strength/if_case01.jpg\" width=\"307\" height=\"204\" loading=\"lazy\" alt=\"もしも\">\n                            </div>\n                            <p class=\"text\">\n                              工場やビル、商業施設、病院、学校などに電力が供給されず、照明もパソコンも空調も、電気を必要とするものがまったく使えなくなってしまいます。\n                            </p>\n                          </div>\n                        </div>\n                      </div>\n                    </li>\n                    <li class=\"splide__slide\">\n                      <div class=\"slide_head\">\n                        <p class=\"head_text\">\n                          家庭に電気を分配し、<br class=\"-sp\">安全を守る\n                        </p>\n                        <p class=\"head_num\">CASE<span class=\"num\">02</span></p>\n                      </div>\n                      <div class=\"content\">\n                        <div class=\"text_group\">\n                          <p class=\"lead\">\n                            <span class=\"line\">分電盤・ブレーカー</span>\n                          </p>\n                          <p class=\"text\">\n                            各家庭や家の中の各部屋に電気を分配し、安全に使えるようにしているのが「分電盤」や「ブレーカー」です。\n                          </p>\n                        </div>\n                        <div class=\"wrap\">\n                          <div class=\"image\">\n                            <img src=\"/saiyo/files/img/newgraduate/about_strength/case_image02.jpg\" width=\"451\" height=\"451\" loading=\"lazy\" alt=\"分電盤・ブレーカー\">\n                          </div>\n                          <div class=\"balloon\">\n                            <p class=\"balloon_copy\">\n                              もしも日東工業がなかったら…？\n                            </p>\n                            <div class=\"balloon_image\">\n                              <img src=\"/saiyo/files/img/newgraduate/about_strength/if_case02.jpg\" width=\"307\" height=\"204\" loading=\"lazy\" alt=\"もしも\">\n                            </div>\n                            <p class=\"text\">\n                              電気の使いすぎによる火災・停電、漏電による火災・感電のリスクが高まり、あなたの家が常に危険と隣り合わせに…。\n                            </p>\n                          </div>\n                        </div>\n                      </div>\n                    </li>\n                    <li class=\"splide__slide\">\n                      <div class=\"slide_head\">\n                        <p class=\"head_text\">\n                          通信接続機器を<br class=\"-sp\">守る\n                        </p>\n                        <p class=\"head_num\">CASE<span class=\"num\">03</span></p>\n                      </div>\n                      <div class=\"content\">\n                        <div class=\"text_group\">\n                          <p class=\"lead\">\n                            <span class=\"line\">光接続箱・システムラック</span>\n                          </p>\n                          <p class=\"text\">\n                            光ファイバーケーブルを守る「光接続箱」とサーバーを守る「システムラック」。安定的な通信接続を可能にします。\n                          </p>\n                        </div>\n                        <div class=\"wrap\">\n                          <div class=\"image\">\n                            <img src=\"/saiyo/files/img/newgraduate/about_strength/case_image03.jpg\" width=\"451\" height=\"451\" loading=\"lazy\" alt=\"光接続箱・システムラック\">\n                          </div>\n                          <div class=\"balloon\">\n                            <p class=\"balloon_copy\">\n                              もしも日東工業がなかったら…？\n                            </p>\n                            <div class=\"balloon_image\">\n                              <img src=\"/saiyo/files/img/newgraduate/about_strength/if_case03.jpg\" width=\"307\" height=\"204\" loading=\"lazy\" alt=\"もしも\">\n                            </div>\n                            <p class=\"text\">\n                              通信の安定性が損なわれ、「ネットが繋がらなくて、推しの配信が見られない！」などのトラブルが起こる可能性も。\n                            </p>\n                          </div>\n                        </div>\n                      </div>\n                    </li>\n                    <li class=\"splide__slide\">\n                      <div class=\"slide_head\">\n                        <p class=\"head_text\">\n                          再生可能エネルギーを<br class=\"-sp\">使えるようにする\n                        </p>\n                        <p class=\"head_num\">CASE<span class=\"num\">04</span></p>\n                      </div>\n                      <div class=\"content\">\n                        <div class=\"text_group\">\n                          <p class=\"lead\">\n                            <span class=\"line\">太陽光発電設備</span>\n                          </p>\n                          <p class=\"text\">\n                            地球環境にやさしい再生可能エネルギーを、電力系統に接続するための機器が太陽光発電設備などの接続機器です。\n                          </p>\n                        </div>\n                        <div class=\"wrap\">\n                          <div class=\"image\">\n                            <img src=\"/saiyo/files/img/newgraduate/about_strength/case_image04.jpg\" width=\"451\" height=\"451\" loading=\"lazy\" alt=\"太陽光発電設備\">\n                          </div>\n                          <div class=\"balloon\">\n                            <p class=\"balloon_copy\">\n                              もしも日東工業がなかったら…？\n                            </p>\n                            <div class=\"balloon_image\">\n                              <img src=\"/saiyo/files/img/newgraduate/about_strength/if_case04.jpg\" width=\"307\" height=\"204\" loading=\"lazy\" alt=\"もしも\">\n                            </div>\n                            <p class=\"text\">\n                              せっかくつくった再生可能エネルギーが使えない無駄なものに…。脱炭素社会の実現も夢のまた夢となるでしょう。\n                            </p>\n                          </div>\n                        </div>\n                      </div>\n                    </li>\n                    <li class=\"splide__slide\">\n                      <div class=\"slide_head\">\n                        <p class=\"head_text\">\n                          電気自動車の<br class=\"-sp\">充電をする\n                        </p>\n                        <p class=\"head_num\">CASE<span class=\"num\">05</span></p>\n                      </div>\n                      <div class=\"content\">\n                        <div class=\"text_group\">\n                          <p class=\"lead\">\n                            <span class=\"line\">EV充電設備</span>\n                          </p>\n                          <p class=\"text\">\n                            外出先で電気自動車の充電をするために必要なのがEV充電設備。電気に関わるこういった製品も日東工業でつくっています。\n                          </p>\n                        </div>\n                        <div class=\"wrap\">\n                          <div class=\"image\">\n                            <img src=\"/saiyo/files/img/newgraduate/about_strength/case_image05.jpg\" width=\"451\" height=\"451\" loading=\"lazy\" alt=\"EV充電設備\">\n                          </div>\n                          <div class=\"balloon\">\n                            <p class=\"balloon_copy\">\n                              もしも日東工業がなかったら…？\n                            </p>\n                            <div class=\"balloon_image\">\n                              <img src=\"/saiyo/files/img/newgraduate/about_strength/if_case05.jpg\" width=\"307\" height=\"204\" loading=\"lazy\" alt=\"もしも\">\n                            </div>\n                            <p class=\"text\">\n                              ガソリンスタンドがないようなもので、電気自動車の充電場所がなくなり、充電が切れたら自宅へ帰れなくなってしまいます。\n                            </p>\n                          </div>\n                        </div>\n                      </div>\n                    </li>\n                  </ul>\n                </div>\n              </div>\n\n              <div class=\"block\">\n                <div class=\"arrow\">\n                  <picture>\n                    <source media=\"(max-width: 768px)\" srcset=\"/saiyo/files/img/newgraduate/about_strength/if_arrow_sp.png\" width=\"267\" height=\"70\">\n                    <img class=\"-fadeUp\" src=\"/saiyo/files/img/newgraduate/about_strength/if_arrow.png\" width=\"267\" height=\"110\" loading=\"lazy\" alt=\"\">\n                  </picture>\n                </div>\n                <h3 class=\"copy -fadeUp\">\n                  <span class=\"line\">日東工業の製品は<br class=\"-sp\">「あらゆるところ」にあり！<br>電気を受電し調整する、身近な存在</span>\n                </h3>\n                <p class=\"text -fadeUp\">\n                  電力会社から電力の供給を受ける地点に設置される「高圧受電設備」や「配・分電盤」の製造から、ICTの発展した現代社会に欠かせない「情報通信関連製品」、脱炭素社会の実現に貢献する「再生可能エネルギー製品」、今後ますます普及が見込まれる「電気自動車の充電設備」まで。培ってきた技術と時代を見つめる感性で、社会に貢献する製品を作り続けています。\n                </p>\n              </div>\n            </div>\n          </div>\n        </section>\n\n        <section class=\"strength\" id=\"strength\">\n          <div class=\"inner\">\n            <div class=\"conts_ttl -fadeUp\">\n              <h2 class=\"ttl\">\n                <span class=\"en\">Strength</span>日東工業の強み\n              </h2>\n            </div>\n\n            <div class=\"pin_area\">\n              <div class=\"block pin_block\" id=\"strength01\">\n                <div class=\"content\">\n                  <div class=\"wrap\">\n                    <div class=\"text_group\">\n                      <div class=\"group_head\">\n                        <p class=\"num\"><span>#</span>01</p>\n                        <p class=\"ttl\"><strong>技術力</strong>の日東工業</p>\n                      </div>\n                      <p class=\"text\">\n                        日東工業の確かな技術を支えているのは、「グループの総合力」と「充実した試験・研究設備」。受配電設備メーカーや制御盤専業メーカーなど各分野のリーディングカンパニーと連携してその英知を結集しているほか、社内にある試験設備で何千回、何万回という製品評価試験を行い、そこから得られたデータを元に確かな技術を開発しています。\n                      </p>\n                    </div>\n                    <div class=\"image_group\">\n                      <p class=\"num\">01</p>\n                      <div class=\"image\">\n                        <img src=\"/saiyo/files/img/newgraduate/about_strength/strength_image01.jpg\" width=\"454\" height=\"302\" loading=\"lazy\" alt=\"\">\n                      </div>\n                    </div>\n                  </div>\n                </div>\n              </div>\n              <div class=\"block pin_block\" id=\"strength02\">\n                <div class=\"content\">\n                  <div class=\"wrap\">\n                    <div class=\"text_group\">\n                      <div class=\"group_head\">\n                        <p class=\"num\"><span>#</span>02</p>\n                        <p class=\"ttl\"><strong>開発力</strong>の日東工業</p>\n                      </div>\n                      <p class=\"text\">\n                        日東工業の製品開発は、顕在化されているニーズだけではなく、「お客様が真に求めていることは何か？」という潜在的なニーズを発掘するところから始まります。機能、性能、デザイン性などの先進性を追求するとともに、安全性の向上、地球環境への配慮、省スペース化、省施工性の研究を進め、製品へと反映しています。\n                      </p>\n                    </div>\n                    <div class=\"image_group\">\n                      <p class=\"num\">02</p>\n                      <div class=\"image\">\n                        <img src=\"/saiyo/files/img/newgraduate/about_strength/strength_image02.jpg\" width=\"454\" height=\"302\" loading=\"lazy\" alt=\"\">\n                      </div>\n                    </div>\n                  </div>\n                </div>\n              </div>\n              <div class=\"block pin_block\" id=\"strength03\">\n                <div class=\"content\">\n                  <div class=\"wrap\">\n                    <div class=\"text_group\">\n                      <div class=\"group_head\">\n                        <p class=\"num\"><span>#</span>03</p>\n                        <p class=\"ttl\"><strong>業界</strong>のリーディングカンパニーの日東工業　</p>\n                      </div>\n                      <p class=\"text\">\n                        分電盤・キャビネット業界では、お客様の要望に応じて1品ずつ製造する「オーダーメイド」が一般的でした。そんな中、日東工業はいち早く製品の標準化を実現。「安く、早く、安定した品質」の標準品という強固なビジネスモデルを確立しました。現在では3万点以上の製品を揃え、200を超える販売代理店とのネットワークを活かし、注文の翌日に届ける「ワンデイデリバリー」が可能な体制を構築しています。\n                      </p>\n                    </div>\n                    <div class=\"image_group\">\n                      <p class=\"num\">03</p>\n                      <div class=\"image\">\n                        <img src=\"/saiyo/files/img/newgraduate/about_strength/strength_image03.jpg\" width=\"454\" height=\"302\" loading=\"lazy\" alt=\"\">\n                      </div>\n                    </div>\n                  </div>\n                </div>\n              </div>\n              <div class=\"block pin_block\" id=\"strength04\">\n                <div class=\"content\">\n                  <div class=\"wrap\">\n                    <div class=\"text_group\">\n                      <div class=\"group_head\">\n                        <p class=\"num\"><span>#</span>04</p>\n                        <p class=\"ttl\"><strong>防災・減災</strong>の日東工業</p>\n                      </div>\n                      <p class=\"text\">\n                        『地震から学ぶ』をテーマに開発された製品が地震IoTセンサー。地震発生時はブレーカーを遮断し、電気火災から建物や身を守り、地震発生後は建物が倒壊しているかどうかなど現地の建物状態を遠隔で確認することにより早期復旧や支援をすることができます。このような地域の防災力を高める製品づくりにも、日東工業は注力しています。\n                      </p>\n                    </div>\n                    <div class=\"image_group\">\n                      <p class=\"num\">04</p>\n                      <div class=\"image\">\n                        <img src=\"/saiyo/files/img/newgraduate/about_strength/strength_image04.jpg\" width=\"454\" height=\"302\" loading=\"lazy\" alt=\"\">\n                      </div>\n                    </div>\n                  </div>\n                </div>\n              </div>\n              <div class=\"block pin_block\" id=\"strength05\">\n                <div class=\"content\">\n                  <div class=\"wrap\">\n                    <div class=\"text_group\">\n                      <div class=\"group_head\">\n                        <p class=\"num\"><span>#</span>05</p>\n                        <p class=\"ttl\">\n                          <strong>グローバル</strong>の日東工業\n                        </p>\n                      </div>\n                      <p class=\"text\">\n                        日東工業のビジネスフィールドは世界へと開かれています。シンガポール・タイ・中国などのアジア各国に現地法人を設置し、約700人のスタッフが現地の事業に携わっています。現地のインフラ整備等、進出した地域の社会課題解決に貢献し、地域の発展に寄与することを使命に、これからも変わらぬ姿勢で役割を果たしていきます。\n                      </p>\n                    </div>\n                    <div class=\"image_group\">\n                      <p class=\"num\">05</p>\n                      <div class=\"image\">\n                        <img src=\"/saiyo/files/img/newgraduate/about_strength/strength_image05.jpg\" width=\"454\" height=\"302\" loading=\"lazy\" alt=\"\">\n                      </div>\n                    </div>\n                  </div>\n                </div>\n              </div>\n            </div>\n          </div>\n        </section>\n\n        <section class=\"related\">\n          <div class=\"inner\">\n            <h3 class=\"lead\">( Related Contents )</h3>\n            <div class=\"block -fadeUp\">\n              <a class=\"related_link\" href=\"/saiyo/newgraduate/about_strength/\">\n                <div class=\"image\">\n                  <img src=\"/saiyo/files/img/newgraduate/common/related_about_strength.jpg\" alt=\"日東工業の強み\">\n                </div>\n                <span class=\"txt\">日東工業の強み<span class=\"en\">Nitto Kogyo’s Strengths</span></span>\n                <svg class=\"circle\" viewBox=\"0 0 24 24\">\n                  <g id=\"oval_675\" data-name=\"oval 675\" fill=\"none\" stroke=\"#e50012\" stroke-width=\"1\">\n                    <circle cx=\"12\" cy=\"12\" r=\"12\" stroke=\"none\"></circle>\n                    <circle cx=\"12\" cy=\"12\" r=\"11.5\" fill=\"none\"></circle>\n                  </g>\n                </svg>\n              </a>\n              <a class=\"related_link\" href=\"/saiyo/newgraduate/about_data/\">\n                <div class=\"image\">\n                  <img src=\"/saiyo/files/img/newgraduate/common/related_about_data.jpg\" alt=\"数字で見る日東工業\">\n                </div>\n                <span class=\"txt\">数字で見る日東工業<span class=\"en\">Our Data</span></span>\n                <svg class=\"circle\" viewBox=\"0 0 24 24\">\n                  <g id=\"oval_675\" data-name=\"oval 675\" fill=\"none\" stroke=\"#e50012\" stroke-width=\"1\">\n                    <circle cx=\"12\" cy=\"12\" r=\"12\" stroke=\"none\"></circle>\n                    <circle cx=\"12\" cy=\"12\" r=\"11.5\" fill=\"none\"></circle>\n                  </g>\n                </svg>\n              </a>\n            </div>\n          </div>\n        </section>\n      </div>\n\n      <footer id=\"newgrad_footer\">\n  <div class=\"container\">\n    <div class=\"inner\">\n      <div class=\"site_block\">\n        <div class=\"logo_group\">\n          <a href=\"/saiyo/newgraduate/\">\n            <img class=\"logo\" src=\"/saiyo/files/img/common/logo.svg\" width=\"129\" height=\"30\" alt=\"Nito 日東工業\">\n            <img class=\"site_type -default\" src=\"/saiyo/files/img/common/sitetype01.svg\" width=\"63\" height=\"10\" alt=\"Recruit Site\">\n          </a>\n        </div>\n        <div class=\"outlink_group\">\n          <a class=\"outlink\" href=\"https://www.nito.co.jp/\" target=\"_blank\" rel=\"noopener