{"url":"https://www.chudenfudosan.co.jp/recruit/interview-tech/01.html","html":"<!DOCTYPE html>\n<html lang=\"ja\" dir=\"ltr\" prefix=\"content: http://purl.org/rss/1.0/modules/content/  dc: http://purl.org/dc/terms/  foaf: http://xmlns.com/foaf/0.1/  og: http://ogp.me/ns#  rdfs: http://www.w3.org/2000/01/rdf-schema#  schema: http://schema.org/  sioc: http://rdfs.org/sioc/ns#  sioct: http://rdfs.org/sioc/types#  skos: http://www.w3.org/2004/02/skos/core#  xsd: http://www.w3.org/2001/XMLSchema# \">\n  <head>\n\n    <!-- Google Tag Manager-->\n    <script>\n      (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\n      new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\n      j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n      'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n      })(window,document,'script','dataLayer','GTM-T4PD7BD');\n    </script>\n    <!-- End Google Tag Manager-->\n    <meta charset=\"utf-8\">\n    <meta http-equiv=\"x-dns-prefetch-control\" content=\"on\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n    <meta name=\"format-detection\" content=\"email=no,telephone=no,address=no\">\n    <link rel=\"apple-touch-icon-precomposed\" href=\"/appconfig/icon-192x192.png\">\n    <link href=\"https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;700&amp;display=swap\" rel=\"stylesheet\">\n\n    <link rel=\"canonical\" href=\"https://www.chudenfudosan.co.jp/recruit/interview-tech/01.html\" />\n<meta name=\"description\" content=\"中電不動産に新卒で入社した先輩のインタビュー内容を紹介します。就職活動でやって良かったことや会社の雰囲気、入社後の仕事など、役に立つ情報が満載です。\" />\n<meta property=\"og:description\" content=\"中電不動産に新卒で入社した先輩のインタビュー内容を紹介します。就職活動でやって良かったことや会社の雰囲気、入社後の仕事など、役に立つ情報が満載です。\" />\n<link rel=\"shortcut icon\" href=\"/themes/chudenfudosan/favicon.ico\" type=\"image/vnd.microsoft.icon\" />\n<link rel=\"revision\" href=\"https://www.chudenfudosan.co.jp/recruit/interview-tech/01.html\" />\n\n    <title>技術職 建設・緑化部｜採用情報｜中電不動産株式会社</title>\n    <link rel=\"preload\" href=\"/common/assets/fonts/fa-solid-900.woff2\" as=\"font\" crossorigin>\n    <link rel=\"preload\" href=\"/common/assets/fonts/fa-regular-400.woff2\" as=\"font\" crossorigin>\n    <link rel=\"preload\" href=\"/common/assets/fonts/fa-light-300.woff2\" as=\"font\" crossorigin>\n    <link rel=\"stylesheet\" media=\"all\" href=\"/sites/default/files/css/css_v52pnKvzGMwJsCsbQob1gLXKl-3n3S7iFQHISwvruAA.css\" />\n<link rel=\"stylesheet\" media=\"all\" href=\"/sites/default/files/css/css_XmWb_eVtIK_TNP0eorBPXNYSsdD_eTqRnukgW7lyvJA.css\" />\n\n    \n<!--[if lte IE 8]>\n<script src=\"/sites/default/files/js/js_VtafjXmRvoUgAzqzYTA3Wrjkx9wcWhjP0G4ZnnqRamA.js\"></script>\n<![endif]-->\n\n    <meta property=\"og:title\" content=\"技術職 建設・緑化部｜採用情報｜中電不動産株式会社\">\n    <meta property=\"og:url\" content=\"https://www.chudenfudosan.co.jp/recruit/interview-tech/01.html\">\n    <meta property=\"og:image\" content=\"https://www.chudenfudosan.co.jp/common/assets/images/ogp.png\">\n  </head>\n  <body class=\"path-node page-node-type-interview\">\n    <!-- Google Tag Manager (noscript)-->\n    <noscript>\n      <iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-T4PD7BD\" height=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe>\n    </noscript>\n    <!-- End Google Tag Manager (noscript)-->\n\n    \n      <div class=\"dialog-off-canvas-main-canvas\" data-off-canvas-main-canvas>\n    <div id=\"document\">\n\n        <div id=\"block-zhongdianbudongchangongtonghetsutaxiaceng\" class=\"block block-block-content block-block-content68937ee6-cf8f-417c-a2f9-32969418a9a6\">\n  \n    \n      \n            <div class=\"clearfix text-formatted field field--name-body field--type-text-with-summary field--label-hidden field__item\">      <header class=\"header is-fixed-sp\" id=\"header\">\n        <nav class=\"header__nav\">\n          <p class=\"site-logo\"><a class=\"site-logo__link\" href=