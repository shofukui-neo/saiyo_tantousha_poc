?file=language&amp;v=1\" type=\"text/javascript\"></script>\n\t\t<script src=\"https://ajax.googleapis.com/ajax/libs/jquery/1.7.1/jquery.min.js\" type=\"text/javascript\"></script>\n\t\t<script src=\"https://ajax.googleapis.com/ajax/libs/jqueryui/1.8.17/jquery-ui.min.js\" type=\"text/javascript\"></script>\n\n\t\t<link type=\"text/css\" rel=\"stylesheet\" href=\"https://ajax.googleapis.com/ajax/libs/jqueryui/1.7.0/themes/smoothness/jquery-ui.css\">\n\t\t<link rel=\"stylesheet\" type=\"text/css\" media=\"all\" href=\"https://www.umc.co.jp/modules/contents/index.php?page=main_css\">\n\t\t<script type=\"text/javascript\" src=\"https://www.umc.co.jp/themes/umc/js/global.min.js\"></script>\n\t\t<script type=\"text/javascript\" src=\"https://www.umc.co.jp/include/xoops.js\"></script>\n\n\t\t<script type=\"text/javascript\">\n\t\t\t$(function() {\n\t\t\t\t// scrolltop\n\t\t\t\tif ($('#fixedBox') != null) {\n\t\t\t\t\tvar nav = $('#fixedBox'),\n\t\t\t\t\t    offset = nav.offset();\n\t\t\t\t\tnav.removeClass('fixed');\n\t\t\t\t\t$(window).scroll(function() {\n\t\t\t\t\t\tif (nav.length) {\n\t\t\t\t\t\t\tif ($(window).scrollTop() > offset.top - 116) {\n\t\t\t\t\t\t\t\tnav.addClass('fixed');\n\t\t\t\t\t\t\t} else {\n\t\t\t\t\t\t\t\tnav.removeClass('fixed');\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t\t// nav.addClass('fixed');\n\t\t\t\t\t\t} else {\n\t\t\t\t\t\t\tnav.removeClass('fixed');\n\t\t\t\t\t\t}\n\t\t\t\t\t});\n\t\t\t\t}\n\t\t\t\t// pagetop //////////////////////////\n\t\t\t\tvar topBtn = $('#page-top');\n\t\t\t\ttopBtn.hide();\n\t\t\t\t//スクロールが100に達したらボタン表示\n\t\t\t\t$(window).scroll(function() {\n\t\t\t\t\tif ($(this).scrollTop() > 100) {\n\t\t\t\t\t\ttopBtn.fadeIn();\n\t\t\t\t\t} else {\n\t\t\t\t\t\ttopBtn.fadeOut();\n\t\t\t\t\t}\n\t\t\t\t});\n\t\t\t\t//スクロールしてトップ\n\t\t\t\ttopBtn.click(function() {\n\t\t\t\t\t$('body,html').animate({\n\t\t\t\t\t\tscrollTop : 0\n\t\t\t\t\t}, 500);\n\t\t\t\t\treturn false;\n\t\t\t\t});\n\n\t\t\t});\n\t\t</script>\n\n\t\t<script>\n\t\t\t$(function() {\n\t\t\t\tvar com = computer();\n\t\t\t\t// entry banner ////////////////////\n\t\t\t\tvar entBnr = $('#entry_banner');\n\t\t\t\tentBnr.hide();\n\n\t\t\t\tif (com == 'pc' || com == 'ipad') {\n\t\t\t\t\t//スクロールが100に達したらボタン表示\n\t\t\t\t\t$(window).scroll(function() {\n\t\t\t\t\t\tif ($(this).scrollTop() > 100) {\n\t\t\t\t\t\t\tentBnr.fadeIn();\n\t\t\t\t\t\t} else {\n\t\t\t\t\t\t\tentBnr.fadeOut();\n\t\t\t\t\t\t}\n\t\t\t\t\t});\n\t\t\t\t}\n\n\t\t\t\tvar mainBnn = $('div.main_banner');\n\t\t\t\tvar topMsgBox = $('div#top_msg_box');\n\t\t\t\tif (com == 'iphone' || com == 'android') {\n\t\t\t\t\tmainBnn.hide();\n\t\t\t\t\ttopMsgBox.hide();\n\t\t\t\t}\n\t\t\t\t// console.log(com);\n\t\t\t});\n\t\t</script>\n\n\t\t<script type=\"text/javascript\">\n\t\t\t// useragent ////\n\t\t\tif ((navigator.userAgent.indexOf('iPhone') > 0 && navigator.userAgent.indexOf('iPad') == -1) || navigator.userAgent.indexOf('Android') > 0) {\n\t\t\t\tdocument.getElementById('header_banner').style.display = \"none\";\n\t\t\t\t// alert('sp');\n\t\t\t}\n\t\t</script>\n\t\t<script src=\"https://www.umc.co.jp/idwork/js/jquery.1.11.1.min.js\"></script>\n\t\t<script src=\"https://www.umc.co.jp/idwork/js/modernizr-2.6.2-respond-1.1.0.min.min.js\"></script>\n\t\t<script src=\"https://www.umc.co.jp/idwork/js/jquery.easing.1.3.min.js\"></script>\n\t\t<script src=\"https://www.umc.co.jp/idwork/js/bootstrap.min.js\"></script>\n\t\t<script src=\"https://www.umc.co.jp/idwork/js/jquery.appear.min.js\"></script>\n\t\t<script src=\"https://www.umc.co.jp/idwork/js/main2.js\"></script>\n\t\t<script src=\"https://www.umc.co.jp/idwork/js/heightLine.min.js\"></script>\n\t\t<!-- <script src=\"https://www.umc.co.jp/idwork/js/smoothscroll.min.js\"></script> -->\n\t\t<!-- userAgent -->\n\t\t<script src=\"https://www.umc.co.jp/themes/umc/js/userAgent.js\"></script>\n\t\t<!-- ipAddress -->\n\t\t<script src=\"https://www.umc.co.jp/idwork/js/getIp.js\"></script>\n\n\t\t<script src=\"js/function.js\" charset=\"UTF-8\"></script>