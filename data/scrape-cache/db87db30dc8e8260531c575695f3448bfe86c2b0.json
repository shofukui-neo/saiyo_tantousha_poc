\t});\r\n\t\t\t} else {\r\n\t\t\t\t$('.category-title-res').off('click').removeClass('open');\r\n\t\t\t\t$('.page-navi-list').show();\r\n\t\t\t}\r\n\t\t});\r\n\t});\r\n</script>\r\n\r\n<script>\r\n\tjQuery(function(){\r\n\t\t$('.modal').modaal();\r\n\t});\r\n</script>\r\n\r\n<!-- ページ内リンクスクロール設定 -->\r\n<script>\r\n\t$('a[href^=\"#\"]').click(function () {\r\n\t\t  const speed = 500;\r\n\t\t  let href = $(this).attr(\"href\");\r\n\t\t  let target = $(href == \"#\" || href == \"\" ? \"html\" : href);\r\n\t\t  let position = target.offset().top;\r\n\t\t  $(\"body,html\").animate({ scrollTop: position }, speed, \"swing\");\r\n\t\t  return false;\r\n\t\t});\r\n\t\r\n</script>\r\n\r\n\t<script>\r\n\t\t$(document).ready(function(){\r\n\t\t\t$(\".menu-box\").each(function(index) {\r\n\t\t\t\t$(this).hover(\r\n\t\t\t\t\tfunction() {\r\n\t\t\t\t\t\t$(\".menu-container\").addClass(\"bg-\" + index);\r\n\t\t\t\t\t},\r\n\t\t\t\t\tfunction() {\r\n\t\t\t\t\t\t$(\".menu-container\").removeClass(\"bg-\" + index);\r\n\t\t\t\t\t}\r\n\t\t\t\t);\r\n\t\t\t});\r\n\t\t});\r\n\t</script>\r\n\r\n</body>\r\n</html>","finalUrl":"https://www.iwatani.co.jp/jpn/recruit/diversity/","rendered":false,"_cachedAt":"2026-06-23T18:01:16.055Z"}