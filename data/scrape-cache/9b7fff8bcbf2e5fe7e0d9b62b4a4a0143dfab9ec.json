{"url":"http://www.k-kaneko.com","html":"<!doctype html>\n<html lang=\"ja\">\n\n<head>\n  <meta charset=\"utf-8\">\n  <!-- Google tag (gtag.js) -->\n  <script async src=\"https://www.googletagmanager.com/gtag/js?id=G-YQW1MG8B7L\"></script>\n  <script>\n    window.dataLayer = window.dataLayer || [];\n    function gtag(){dataLayer.push(arguments);}\n    gtag('js', new Date());\n\n    gtag('config', 'G-YQW1MG8B7L');\n  </script>\n  <meta name=\"viewport\" content=\"width=device-width\">\n  <title>株式会社兼子</title>\n  <link href=\"assets/js/slick/slick.css\" rel=\"stylesheet\">\n  <link href=\"assets/js/slick/slick-theme.css\" rel=\"stylesheet\">\n  <link href=\"assets/css/style.css\" rel=\"stylesheet\">\n  <link href=\"assets/img/favicon.png\" rel=\"icon\">\n  <script>console.log('load');</script><!-- transition fix -->\n</head>\n\n<body class=\"home\">\n  <div class=\"wrapper\">\n\n    <div class=\"header\">\n      <div class=\"title fade\">\n        <a href=\"\">\n          <img src=\"assets/img/logo_kaneko.png\" alt=\"株式会社兼子\">\n        </a>\n      </div>\n\n      <div class=\"gnavi\">\n        <ul>\n          <li><a href=\"#services\">事業案内</a></li>\n          <li><a href=\"company/strength/\">強み</a></li>\n          <li><a href=\"cases/\">事例紹介</a></li>\n          <li><a href=\"company/profile/\">会社案内</a></li>\n          <li><a href=\"sustainability/\">サステナビリティ</a></li>\n          <li><a href=\"https://recruit.kaneko-hd.co.jp/\" target=\"_blank\">採用情報</a></li>\n          <li><a href=\"contact/\" class=\"button\"><span class=\"contact\">お問い合わせ</span></a></li>\n        </ul>\n      </div>\n    </div>\n\n    <div class=\"gnavi-button\">\n      <span></span>\n    </div>\n\n    <div class=\"main\">\n      <section class=\"kv fade\">\n        <p class=\"copy type\">私たちは商いを通じて社会に貢献します。</p>\n        <div class=\"slider\">\n          <img src=\"assets/img/kv_3.jpg\" alt=\"\">\n          <img src=\"assets/img/kv_1.jpg\" alt=\"\">\n          <img src=\"assets/img/kv_2.jpg\" alt=\"\">\n          <img src=\"assets/img/kv_4.jpg\" alt=\"\">\n          <img src=\"assets/img/kv_5.jpg\" alt=\"\">\n          <img src=\"assets/img/kv_6.jpg\" alt=\"\">\n        </div>\n      </section>\n\n      <section class=\"services fade\" id=\"services\">\n        <h1 class=\"heading-1\">\n          <span class=\"en type\">SERVICES</span>\n          <span class=\"jp type\">事業案内</span>\n        </h1>\n\n        <div class=\"services-list w80 fade\">\n          <div class=\"services-item\">\n            <a href=\"services/recycle/\">\n              <div class=\"photo\">\n                <figure class=\"w2-h1\">\n                  <img src=\"assets/img/services_recycle.jpg\" alt=\"\">\n                </figure>\n              </div>\n              <div class=\"text\">\n                <p class=\"title\">資源リサイクル</p>\n                <p class=\"lead\">企業や家庭から排出される様々な古紙・プラスチック・金属などを資源として再生します。</p>\n                <span class=\"more mt15\">READ MORE</span>\n              </div>\n            </a>\n          </div>\n          <div class=\"services-item\">\n            <a href=\"services/disposal/\">\n              <div class=\"photo\">\n                <figure class=\"w2-h1\">\n                  <img src=\"assets/img/services_disposal.jpg\" alt=\"\">\n                </figure>\n              </div>\n              <div class=\"text\">\n                <p class=\"title\">廃棄物再資源化・処理</p>\n                <p class=\"lead\">企業から排出される産業廃棄物をワンストップで収集運搬・再資源化・処理を行い、リサイクル率の向上を目指します。</p>\n                <span class=\"more mt15\">READ MORE</span>\n              </div>\n            </a>\n          </div>\n          <div class=\"services-item\">\n            <a href=\"services/consulting/\">\n              <div class=\"photo\">\n                <figure class=\"w2-h1\">\n                  <img src=\"assets/img/services_consulting.jpg\" alt=\"\">\n                </figure>\n              </div>\n              <div class=\"text\">\n                <p class=\"title\">リサイクルコンサルティング</p>\n                <p class=\"lead\">古紙だけでなく、プラスチックも含めた資源をお客様に最適なソリューションでリサイクルします。</p>\n                <span class=\"more mt15\">READ MORE</span>\n              </div>\n            </a>\n          </div>\n          <div class=\"services-item\">\n            <a href=\"services/equipment/\">\n              <div class=\"photo\">\n                <figure class=\"w2-h1\">\n                  <img src=\"assets/img/services_equipment.jpg\" alt=\"\">\n                </figure>\n              </div>\n              <div class=\"text\">\n                <p class=\"title\">設備導入コンサルティング</p>\n                <p class=\"lead\">設備導入コンサルティングによる廃棄物の再資源化、お客様のビジネスの省人化・省力化、機密情報処理の安全性向上を実現しています。</p>\n                <span class=\"more mt15\">READ MORE</span>\n              </div>\n            </a>\n          </div>\n        </div>\n      </section>\n\n      <section class=\"cases fade\">\n        <div class=\"buttons\">\n          <a href=\"cases/\" class=\"button\">\n            <span class=\"en\">CASE STUDY</span>\n            <span class=\"jp\">これまでの事例紹介</span>\n          </a>\n        </div>\n      </section>\n\n      <section class=\"about fade\">\n        <h1 class=\"heading-1\">\n          <span class=\"en type\">ABOUT US</span>\n          <span class=\"jp type\">株式会社兼子について</span>\n        </h1>\n\n        <div class=\"flex w80 fade\">\n          <a href=\"company/strength/\" class=\"w47\">\n            <figure class=\"w3-h2\">\n              <img src=\"assets/img/strength/1.jpg\" alt=\"\">\n            </figure>\n            <span class=\"arrow heading-7 mt30\">株式会社兼子の強み</span>\n          </a>\n          <a href=\"company/profile/\" class=\"w47\">\n            <figure class=\"w3-h2\">\n              <img src=\"assets/img/company.jpg\" alt=\"\">\n            </figure>\n            <span class=\"arrow heading-7 mt30\">会社案内</span>\n          </a>\n        </div>\n      </section>\n    </div>\n\n    <div class=\"footer fade\">\n\n      <div class=\"banners\">\n        <a href=\"https://ww