ia; gyroscope; picture-in-picture; web-share\" allowfullscreen=\"allowfullscreen\"></iframe>\r\n    </div>\r\n  </div>\r\n</div>\r\n<div class=\"workstyle-box bg-gray\">\r\n  <div class=\"flex center\">\r\n    <h2 class=\"bg-ttl\">WORK<span class=\"jp-ttl\">働く環境</span></h2>\r\n  </div>\r\n  <div class=\"workstyle-bg\">\r\n    <div class=\"bnr-box inner\">\r\n      <div class=\"flex center\"><a href=\"/recruit/feature\" class=\"txt-4box\">\r\n          <div class=\"image\">\r\n            <p class=\"txt-center\"><img decoding=\"async\" src=\"/wp-content/themes/child/image/contents/recruit/recruit_img_workstyle_1.jpg\" alt=\"働く魅力\" /></p>\r\n          </div>\r\n          <div class=\"text\">\r\n            <p class=\"txt-center no-mb\">働く魅力</p>\r\n          </div>\r\n        </a> <a href=\"/recruit/job\" class=\"txt-4box\">\r\n          <div class=\"image\">\r\n            <p class=\"txt-center\"><img decoding=\"async\" src=\"/wp-content/themes/child/image/contents/recruit/recruit_img_job_1.jpg\" alt=\"職種紹介\" /></p>\r\n          </div>\r\n          <div class=\"text\">\r\n            <p class=\"txt-center no-mb\">職種紹介</p>\r\n          </div>\r\n        </a> <a href=\"/recruit/training\" class=\"txt-4box\">\r\n          <div class=\"image\">\r\n            <p class=\"txt-center\"><img decoding=\"async\" src=\"/wp-content/themes/child/image/contents/recruit/recruit_img_training_1.jpg\" alt=\"教育体制\" /></p>\r\n          </div>\r\n          <div class=\"text\">\r\n            <p class=\"txt-center no-mb\">教育体制</p>\r\n          </div>\r\n        </a> <a href=\"/recruit/welfare\" class=\"txt-4box end\">\r\n          <div class=\"image\">\r\n            <p class=\"txt-center\"><img decoding=\"async\" src=\"/wp-content/themes/child/image/contents/recruit/recruit_img_welfare.jpg\" alt=\"福利厚生\" /></p>\r\n          </div>\r\n          <div class=\"text\">\r\n            <p class=\"txt-center no-mb\">福利厚生</p>\r\n          </div>\r\n        </a></div>\r\n    </div>\r\n  </div>\r\n<