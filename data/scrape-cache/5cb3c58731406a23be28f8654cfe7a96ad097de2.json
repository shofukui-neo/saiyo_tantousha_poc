=\"service\"><a href=\"/service/\">製品・サービス</a></li>\r\n                  <li class=\"company menu-icon\">\r\n                  <div class=\"bg-menu\">\r\n                  <a href=\"/company\">会社案内</a>\r\n                  <div class=\"nav-menu-link\"></div>\r\n                    <div class=\"child-menu\">\r\n                      <ul class=\"flex start submenu\">\r\n                        <li><a href=\"/company/message\">ごあいさつ</a></li>\r\n                        <li><a href=\"/company/data\">会社概要</a></li>\r\n                        <li><a href=\"/company/base\">事業拠点</a></li>\r\n                      </ul>\r\n                    </div>\r\n                  </div>\r\n                  </li>\r\n                  <li class=\"facility\"><a href=\"/facility/\">設備紹介</a></li>\r\n                  <li class=\"sdgs\"><a href=\"/sdgs/\">SDGs</a></li>\r\n                  <li class=\"dx-attempt\"><a href=\"/dx-attempt/\">DX推進に<br class=\"br-1500 dx-header\">向けた取組</a></li>\r\n                  <li class=\"company menu-icon\">\r\n                  <div class=\"bg-menu\">\r\n                  <a href=\"/recruit/\">採用情報</a>\r\n                  <div class=\"nav-menu-link\"></div>\r\n                    <div class=\"child-menu\">\r\n                      <ul class=\"flex start submenu\">\r\n                        <li><a href=\"/recruit/feature\">働く魅力</a></li>\r\n                        <li><a href=\"/recruit/job\">職種紹介</a></li>\r\n                        <li><a href=\"/recruit/training\">教育体制</a></li>\r\n                        <li><a href=\"/recruit/welfare\">福利厚生</a></li>\r\n                        <!--<li><a href=\"/recruit/voice\">先輩の声</a></li>-->\r\n                        <li><a href=\"/recruit/concept\">採用コンセプト</a></li>\r\n                        <li><a href=\"/recruit/flow\">選考の流れ</a></li>\r\n                        <li><a href=\"/recruit/requirements\">募集要項</a></li>\r\n                      </ul>\r\n                    </div>\r\n                  </div>\r\n                  </li>\r\n                  <li class=\"entry\"><a href=\"/recruit/entry/\" class=\"nav-entry\"><span class=\"nav-en\">ENTRY</span>採用エントリー</a></li>\r\n                  <li class=\"contact\"><a href=\"/contact/\" class=\"nav-contact\"><span class=\"nav-en\">CONTACT</span>お問い合わせ</a></li>\r\n                </ul>\r\n              </div>\r\n              <!-- #Navi end -->\r\n            </nav>\r\n          </div>\r\n        </div>\r\n        <!--PC/タブレット表示-->\r\n        <!-- #Header end -->\r\n      </header>\t<div id=\"page-ttl\">\r\n\t\t<div class=\"inner\">\r\n\t\t\t<h1>福利厚生</h1>\r\n\t\t</div>\r\n\t</div>\r\n  <div id=\"contents\">\r\n  <div id=\"breadcrumb\"><ul><li><a class=\"breadcrumb-home\" href=\"https://www.chusei-oil.com\"><span>ホーム</span></a></li><li><a href=\"https://www.chusei-oil.com/recruit/\"><span>採用情報</span></a></li><li><span>福利厚生</span></li></ul></div><main>\r\n      \n\n\t\t\t<div class=\"inner\">\r\n  <p class=\"main-ttl\">“<span class=\"bold\">企業は人</span>” 人材は会社を大きくするための<br class=\"br-414\">\r\n    財産です。</p>\r\n  <p class=\"main-sub-ttl\"> 中国精油では｢人材｣を｢人財｣と考え、｢この会社に<br class=\"br-414\">入社して本当に良かった｣と、<br class=\"sp-none\">社員一人ひとりが<br class=\"br-414\">実感できる会社を目指し、仕事も家庭生活も充実させる<br class=\"br-414\"><br class=\"sp-none\"><span class=\"bold\">ワーク・ライフ・バランスを大切にした環境づくり</span>に<br class=\"br-414\">力を入れています </p>\r\n  <div class=\"flex gallery box-mb\">\r\n    <div class=\"txt-4box\"><img decoding=\"async\" src=\"/wp-content/themes/child/image/contents/recruit/welfare/recruit-welfare-01_1.jpg\" alt=\"\"></div>\r\n    <div class=\"txt-4box\"><img decoding=\"async\" src=\"/wp-content/themes/child/image/contents/recruit/welfare/recruit-welfare-02_1.jpg\" alt=\"\"></div>\r\n    <div class=\"txt-4box\"><img decoding=\"async\" src=\"/wp-content/themes/child/image/contents/recruit/welfare/recruit-welfare-03_1.jpg\" alt=\"\"></div>\r\n    <div class=\"txt-4box end\"><img decoding=\"async\" src=\"/wp-content/themes/child/image/contents/recruit/welfare/recruit-welfare-04_1.jpg\" alt=\"\"></div>\r\n  </div>\r\n</div>\r\n<div class=\"bg-gray box-mb\">\r\n  <div class=\"inner welfare\">\r\n    <h2>充実の福利厚生</h2>\r\n    <div class=\"flex\">\r\n      <div class=\"txt-2box\">\r\n        <div class=\"welfare-content\">\r\n          <h3>各種手当</h3>\r\n          <div class=\"flex\">\r\n            <div class=\"txt-2box\">\r\n              <ul class=\"no-mt\">\r\n                <li>物価手当</li>\r\n                <li>営業手当</li>\r\n                <li>精勤手当</li>\r\n                <li>通勤手当</li>\r\n                <li>役職手当</li>\r\n              </ul>\r\n            </div>\r\n            <div class=\"txt-2box end\">\r\n              <ul class=\"no-mt\">\r\n                <li>家族手当</li>\r\n                <li>地域手当</li>\r\n                <li>賞与(年2回/6月,12月)</li>\r\n                <li>昇格・昇給(年1回/4月)</li>\r\n              </ul>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n      <div class=\"txt-2box end\">\r\n        <div class=\"welfare-content\">\r\n          <h3>各種制度</h3>\r\n          <div class=\"flex\">\r\n            <div class=\"txt-3box\">\r\n              <ul class=\"no-mt\">\r\n                <li>健康保険</li>\r\n                <li>厚生年金</li>\r\n                <li>雇用保険</li>\r\n                <li>資格取得補助</li>\r\n                <li>健康診断費用補助</li>\r\n              </ul>\r\n            </div>\r\n            <div class=\"txt-3box\">\r\n              <ul class=\"no-mt\">\r\n                <li>出産休暇制度</li>\r\n                <li>育児休暇制度</li>\r\n                <li>介護休暇制度</li>\r\n                <li>家賃補助制度</li>\r\n                <li>再雇用制度</li>\r\n              </ul>\r\n            </div>\r\n            <div class=\"txt-3box end\">\r\n              <ul class=\"no-mt\">\r\n                <li>退職金制度</li>\r\n                <li>社員表彰制度</li>\r\n                <li>慶弔見舞金制度</li>\r\n                <li>永年勤続報酬制度</li>\r\n                <li>正社員登用制度</li>\r\n                <li>団体生命保険加入</li>\r\n              </ul>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</div>\r\n<div class=\"inner box-mb\">\r\n  <div class=\"bg-blue\">\r\n    <h3>各種手当・制度</h3>\r\n    <div class=\"welfare-various\">\r\n      <div class=\"flex\">\r\n        <div class=\"txt-3box\">\r\n          <div class=\"welfare-content\">\r\n            <h4>資格取得支援制度</h4>\r\n            <p class=\"txt-center welfare-ico\"><img decoding=\"async\" src=\"/wp-content/themes/child/image/contents/recruit/welfare/support-ico.svg\" alt=\"アイコン:資格取得支援制度\"></p>\r\n            <p class=\"no-mb\">業務に必要な資格取得の費用を会社が負担し、全面的にスキルアップをサポートします。社員の成長を後押しする一環として、資格取得を奨励しています。</p>\r\n          </div>\r\n        </div>\r\n        <div class=\"txt-3box\">\r\n          <div class=\"welfare-content\">\r\n            <h4>家賃補助制度</h4>\r\n            <p class=\"txt-center welfare-ico\"><img decoding=\"async\" src=\"/wp-content/themes/child/image/contents/recruit/welfare/rent-ico.svg\" alt=\"アイコン:家賃補助制度\"></p>\r\n            <p class=\"no-mb\">自宅から配属先への通勤が困難と判断した場合は、社規定に準じて借上家賃の75%を支給致します。</p>\r\n          </div>\r\n        </div>\r\n        <div class=\"txt-3box end\">\r\n          <div class=\"welfare-content\">\r\n            <h4>育児支援制度<br class=\"sp-none\">\r\n              <span class=\"sub-ttl\"> (出産休暇・育児休暇)</span></h4>\r\n            <p class=\"txt-center welfare-ico\"><img decoding=\"async\" src=\"/wp-content/themes/child/image/contents/recruit/welfare/childcare-ico.svg\" alt=\"アイコン:育児支援制度\"></p>\r\n            <p class=\"no-mb\">出産休暇はもちろん育児休暇も取得可能です。仕事だけでなくご家族との時間も大切にできる環境づくりに力を入れています。</p>\r\n          </div>\r\n        </div>\r\n        <div class=\"txt-3box\">\r\n          <div class=\"welfare-content\">\r\n            <h4>健康診断制度</h4>\r\n            <p class=\"txt-center welfare-ico\"><img decoding=\"async\" src=\"/wp-content/themes/child/image/contents/recruit/welfare/health-ico.svg\" alt=\"アイコン:健康診断制度\"></p>\r\n            <p class=\"no-mb\">毎年9月に全拠点の社員、パート社員、契約社員の方を対象に健康診断を実施しております。</p>\r\n          </div>\r\n        </div>\r\n        <div class=\"txt-3box\">\r\n          <div class=\"welfare-content\">\r\n            <h4>変形労働制の導入</h4>\r\n            <p class=\"txt-center welfare-ico\"><img decoding=\"async\" src=\"/wp-content/themes/child/image/contents/recruit/welfare/balance-ico.svg\" alt=\"アイコン:変形労働制の導入\"></p>\r\n            <p class=\"no-mb\">総労働時間が増えすぎないように、個人で年間の勤務時間の調整が可能です。<br>\r\n              <span class=\"look-red\">ワークライフバランス</span>の推進も大切に進めながら働きやすい環境づくりに取り組んでいます。 </p>\r\n          </div>\r\n        </div>\r\n        <div class=\"txt-3box end\">\r\n          <div class=\"welfare-content\">\r\n            <h4>通勤手当</h4>\r\n            <p class=\"txt-center welfare-ico\"><img decoding=\"async\" src=\"/wp-content/themes/child/image/contents/recruit/welfare/car-ico.svg\" alt=\"アイコン:通勤手当\"></p>\r\n            <p class=\"no-mb\">社規定に準じて、通勤にかかる交通費を毎月支給致します。最高50,000円まで支給致します。</p>\r\n          </div>\r\n        </div>\r\n        <div class=\"txt-3box\">\r\n          <div class=\"welfare-content\">\r\n            <h4>役職手当</h4>\r\n            <p class=\"txt-center welfare-ico\"><img decoding=\"async\" src=\"/wp-content/themes/child/image/contents/recruit/welfare/director-ico.svg\" alt=\"アイコン:役職手当\"></p>\r\n            <p class=\"no-mb\">一般の人にはない特別な責任と役割を与えられた社員に対して毎月支給致します。</p>\r\n          </div>\r\n        </div>\r\n        <div class=\"txt-3box\">\r\n          <div class=\"welfare-content\">\r\n            <h4>精勤手当</h4>\r\n            <p class=\"txt-center welfare-ico\"><img decoding=\"async\" src=\"/wp-content/themes/child/image/contents/recruit/welfare/diligence-ico.svg\" alt=\"アイコン:精勤手当\"></p>\r\n            <p class=\"no-mb\">無遅刻・無早退・無欠勤の社員に対して毎月14,000円支給致します。</p>\r\n          </div>\r\n        </div>\r\n        <div class=\"txt-3box end\">\r\n          <div class=\"welfare-content\">\r\n            <h4>営業手当</h4>\r\n            <p class=\"txt-center welfare-ico\"><img decoding=\"async\" src=\"/wp-content/themes/child/image/contents/recruit/welfare/sales-ico.svg\" alt=\"アイコン:営業手当\"></p>\r\n            <p class=\"no-mb\">各拠点の営業担当者に対して、毎月一律20,000円を支給致します。</p>\r\n          </div>\r\n        </div>\r\n        <div class=\"txt-3box\">\r\n          <div class=\"welfare-content\">\r\n            <h4>地域手当</h4>\r\n            <p class=\"txt-center\"><img decoding=\"async\" src=\"/wp-content/themes/child/image/contents/recruit/welfare/region-ico.svg\" alt=\"地域手当\"></p>\r\n            <p class=\"no-mb\">社規定に準じて、東京支店・大阪販売支店・九州支店・新門司工場の勤務の方に対して最高30,000円まで地域手当を支給致します。</p>\r\n          </div>\r\n        </div>\r\n        <div class=\"txt-3box\">\r\n          <div class=\"welfare-content\">\r\n            <h4>家族手当</h4>\r\n            <p class=\"txt-center welfare-ico\"><img decoding=\"async\" src=\"/wp-content/themes/child/image/contents/recruit/welfare/family-ico.svg\" alt=\"家族手当\"></p>\r\n            <p class=\"no-mb\">扶養家族の人数に応じて家族手当を支給致します。扶養家族1人目は10,000円、2人目以降は1,000円ずつ支給致します。</p>\r\n          </div>\r\n        </div>\r\n        <div class=\"txt-3box end\">\r\n          <div class=\"welfare-content\">\r\n            <h4>物価手当</h4>\r\n            <p class=\"txt-center welfare-ico\"><img decoding=\"async\" src=\"/wp-content/themes/child/image/contents/recruit/welfare/cost-living-ico.svg\" alt=\"物価手当\"></p>\r\n            <p class=\"no-mb\">社規定に準じて、毎月45,000円支給致します。</p>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</div>\r\n\t\t\t<!-- #post -->\n          <div class=\"footer-entry\">\r\n    <div class=\"inner\">\r\n      <div class=\"bg-white\">\r\n        <h2 class=\"bg-ttl mb-30\">ENTRY<span class=\"jp-ttl\">ご応募・エントリー</span></h2>\r\n        <div class=\"flex mb-10 inner btn-box\">\r\n          <div class=\"txt-2box\">\r\n            <h3 class=\"txt-blue bold\">新卒採用</h3>\r\n            <div class=\"flex center\">\r\n              <div class=\"txt-2box\">\r\n                <p class=\"txt-center no-mb\">\r\n                  <a href=\"https://job.mynavi.jp/27/pc/search/corp92339/outline.html\" target=\"_blank\" rel=\"nofollow noreferrer noopener\">\r\n                    <picture>\r\n                      <source media=\"(max-width: 559px)\" srcset=\"/wp-content/themes/child/image/contents/recruit/bnr_mynavi2027_sp.jpg\">\r\n                      <source media=\"(max-width: 1140px)\" srcset=\"/wp-content/themes/child/image/contents/recruit/bnr_mynavi2027_sf.jpg\">\r\n                      <img src=\"/wp-content/themes/child/image/contents/recruit/bnr_mynavi2027.jpg\" alt=\"バナー:マイナビ2027\">\r\n                    </picture>\r\n                  </a>\r\n                </p>\r\n              </div>\r\n              <div class=\"txt-2box\">\r\n                <p class=\"txt-center no-mb\">\r\n                  <a href=\"https://job.mynavi.jp/28/pc/search/corp92339/outline.html\" target=\"_blank\" rel=\"nofollow noreferrer noopener\">\r\n                    <picture>\r\n                      <source media=\"(max-width: 559px)\" srcset=\"/wp-content/themes/child/image/contents/recruit/bnr_mynavi2028_sp.jpg\">\r\n                      <source media=\"(max-width: 1140px)\" srcset=\"/wp-content/themes/child/image/contents/recruit/bnr_mynavi2028_sf.jpg\">\r\n                      <img src=\"/wp-content/themes/child/image/contents/recruit/bnr_mynavi2028.jpg\" alt=\"バナー:マイナビ2028\">\r\n                    </picture>\r\n                  </a>\r\n                </p>\r\n              </div>\r\n            </div>\r\n          </div>\r\n          <div class=\"txt-2box end\">\r\n            <h3 class=\"look-red bold\">中途採用</h3>\r\n            <div class=\"flex center entry-image\">\r\n              <a href=\"/recruit/entry\" class=\"link-btn entry-link-btn w-100\">エントリーフォーム</a>\r\n            </div>\r\n          </div>\r\n        </div>\r\n        <div class=\"flex center\">\r\n          <a href=\"/contact/\" class=\"link-btn w-100 black\">その他のお問い合わせ</a>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</main>\r\n</div>\r\n\r\n<!-- #Footer start -->\r\n