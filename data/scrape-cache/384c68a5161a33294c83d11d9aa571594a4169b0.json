{"url":"https://www.toyo.ac.jp/recruit/staff/","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n<head prefix=\"og: http://ogp.me/ns# fb: http://ogp.me/ns/fb# article: http://ogp.me/ns/article#\">\n  <meta charset=\"UTF-8\">\n  <title>新卒職員採用サイト｜東洋大学公式サイト</title>\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" id=\"viewport\">\n<meta name=\"description\" content=\"新卒職員採用サイト\">\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n<meta name=\"format-detection\" content=\"telephone=no\">\n<meta name=\"google\" content=\"nositelinkssearchbox\">\n<meta property=\"og:image\" content=\"https://www.toyo.ac.jp/ogp.jpg\">\n<meta property=\"og:title\" content=\"新卒職員採用サイト\">\n<meta property=\"og:description\" content=\"新卒職員採用サイト\">\n<meta name=\"twitter:card\" content=\"summary_large_image\">\n<link rel=\"stylesheet\" href=\"/js/lib.min.css\">\n<link rel=\"stylesheet\" href=\"/css/style.min.css\">\n<link rel=\"stylesheet\" href=\"/css/style_variables.css\">\n<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n<link href=\"https://fonts.googleapis.com/css2?family=Afacad+Flux:wght@400;700&family=Zen+Kaku+Gothic+New:wght@500;700&family=Zen+Old+Mincho:wght@400;700&display=swap\" rel=\"stylesheet\">\n<link rel=\"icon\" href=\"/img/common/favicon.ico\">\n<script src=\"//msta.j-server.com/MSTA/LUC2TOYOUN/js/msta.js\"></script>\n  <!-- [ga_head] -->\n  <!-- Google Tag Manager -->\n  <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\n  new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\n  j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n  'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n  })(window,document,'script','dataLayer','GTM-5FN4LJN');</script>\n  <!-- End Google Tag Manager -->\n  <!-- [1:大学][4:ToyoTime] -->\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n})(window,document,'script','dataLayer','GTM-WQWGDDL');</script>\n  <!-- Google tag (gtag.js) -->\n  <script async src=\"https://www.googletagmanager.com/gtag/js?id=G-5Z0SL6M46Z\"></script>\n  <script>\n    window.dataLayer = window.dataLayer || [];\n    function gtag(){dataLayer.push(arguments);}\n    gtag('js', new Date());\n    gtag('config', 'G-5Z0SL6M46Z');\n  </script>\n</head>\n<body class=\"\" data-siteurl=\"/\" data-config-wid=\"1\" data-ogp-domain=\"www.toyo.ac.jp\" data-archive-type=\"page06\" data-object-id=\"812\">\n  <!-- [ga_body] -->\n  <!-- Google Tag Manager (noscript) -->\n  <noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-5FN4LJN\"\n  height=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n  <!-- End Google Tag Manager (noscript) -->\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-WQWGDDL\"\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n  <div class=\"wrapper\">\n    <div data-include-path=\"_include/important.html\" data-include-option=\"system\"></div>\n    <div data-include-path=\"_include/header.html\" data-include-option=\"system\"></div>\n<!-- page-detail -->\n  <main class=\"contents contents_side\">\n  <div class=\"editor-mv\">\n<div class=\"home__mv mv-area\">\n<div class=\"mv-left\">\n<div data-include-path=\"_include/weather.html\" data-include-option=\"system\"></div>\n</div>\n<div class=\"cat-home__mv\">\n<div class=\"mv-img mv-video\"><img class=\"mv-img__inner ofi_cover\" style=\"max-width: none; width: 100%; height: 100%;\" src=\"/recruit/img/mv.jpg\" alt=\"\" width=\"2600\" height=\"1200\"></div>\n<div class=\"cat-home__mv-head\">\n<h1 class=\"cat-home__ttl\"><span class=\"cat-home__ttl-en\">Recruiting<br class=\"d-md-none\">information</span> <span class=\"cat-home__ttl-ja\">新卒職員採用</span></h1>\n</div>\n</div>\n<div class=\"mv-right\"><a class=\"mfp-ajax\" href=\"/_include/search.html\"> <img src=\"/img/common/ico_mv-search.svg\" alt=\"検索\" width=\"28\" height=\"29\"> </a></div>\n</div>\n</div>\n<div class=\"pblock-kuzu mt-md-30\">\n<ol class=\"breadcrumb\">\n<li class=\"breadcrumb-item\"><a href=\"/\">home</a></li>\n<li class=\"breadcrumb-item\"><a href=\"/recruit/\">採用情報</a></li>\n<li class=\"breadcrumb-item active\">新卒職員採用</li>\n</ol>\n</div>\n<div class=\"editor\">\n<div class=\"pblock\">\n<div class=\"pnav pnav_sp-drop\"><a class=\"dropdown-toggle d-md-none\" href=\"#\" role=\"button\" data-toggle=\"dropdown\" aria-haspopup=\"true\" aria-expanded=\"false\">選択してください</a>\n<div class=\"nav\">\n<div class=\"nav-row\"><a class=\"nav-link scroll\" href=\"#anc01\">ビジョン</a> <a class=\"nav-link scroll\" href=\"#anc02\">職員紹介</a> <a class=\"nav-link scroll\" href=\"#anc03\">採用情報</a> <a class=\"nav-link scroll\" href=\"#anc04\">仕事内容／キャリア／研修制度</a> <a class=\"nav-link scroll\" href=\"#anc05\">エントリー／説明会</a></div>\n</div>\n</div>\n</div>\n<div class=\"pb-50 pb-md-80 pt-100 pt-md-130 px-30 px-md-60\" data-bg-img-pc=\"/recruit/img/bg_vision.jpg\" data-bg-img-sp=\"/recruit/img/bg_vision.jpg\">\n<div class=\"pblock\">\n<div class=\"row row-cols-1 row-cols-md-2 gutters-x60 gutters-y50\">\n<div class=\"col\">\n<p class=\"ptitle_t19 ff__en\"><a id=\"anc01\"></a>VISION</p>\n<p class=\"lead_style01 color__pc-white\">ビジョン</p>\n<p class=\"cat-home__txt color__pc-white\">東洋大学のビジョンと学校法人東洋大学職員人材育成ビジョンをご紹介します。</p>\n<a class=\"plink_type_box_border mt-50 color__white\" href=\"/recruit/staff/vision/\"><span class=\"color__white ff__en ff__en-uppercase fz__normal\">東洋大学のビジョン</span></a>\n<a class=\"plink_type_box_border mt-50 color__white\" href=\"/recruit/staff/development_vision/\"><span class=\"color__white ff__en ff__en-uppercase fz__normal\">学校法人東洋大学　職員人材育成ビジョン</span></a></div>\n<div class=\"col\"><img src=\"/recruit/img/img_vision.jpg\" width=\"510\" alt=\"VISION\"></div>\n</div>\n</div>\n</div>\n<div class=\"pt-md-120 pt-90\">\n<div class=\"pblock mb-md-60 mb-40\">\n<h2 class=\"ptitle_t1\"><a id=\"anc02\"></a>people</h2>\n<p class=\"lead_style01\">職員紹介</p>\n<p>インタビューを通して、実際に東洋大学で働く職員とその仕事内容をご紹介します。</p>\n</div>\n<div class=\"recruit-people\">\n<div class=\"swiper recruit-people__slider\">\n<div class=\"swiper-wrapper\">\n<div class=\"swiper-slide\"><a href=\"/interview/00546.html\" class=\"recruit-peopleSlide\">\n<figure class=\"recruit-peopleSlide__image\"><img src=\"/recruit/img/img_people00.jpg\" alt=\"井古田 真李奈\"></figure>\n<div class=\"recruit-peopleSlide__content\">\n<p class=\"recruit-peopleSlide__title\">深く広く学習ができる<br class=\"d-sp-none\">「大学」が好き</p>\n<p class=\"recruit-peopleSlide__dept\">赤羽台事務部赤羽台事務課</p>\n<p class=\"recruit-peopleSlide__name\"><span class=\"recruit-peopleSlide__ja\">井古田 真李奈</span> <span class=\"recruit-peopleSlide__en\">Ikota Marina</span></p>\n</div>\n</a></div>\n<div class=\"swiper-slide\"><a href=\"/interview/00544.html\" class=\"recruit-peopleSlide\">\n<figure class=\"recruit-peopleSlide__image\"><img src=\"/recruit/img/img_people01.jpg\" alt=\"伊藤 藍\"></figure>\n<div class=\"recruit-peopleSlide__content\">\n<p class=\"recruit-peopleSlide__title\">研究者の好奇心が、<br class=\"d-sp-none\">あらゆる研究の出発点</p>\n<p class=\"recruit-peopleSlide__dept\">研究推進部研究推進課</p>\n<p class=\"recruit-peopleSlide__name\"><span class=\"recruit-peopleSlide__ja\">伊藤 藍</span> <span class=\"recruit-peopleSlide__en\">Ito Ai </span></p>\n</div>\n</a></div>\n<div class=\"swiper-slide\"><a href=\"/interview/00541.html\" class=\"recruit-peopleSlide\">\n<figure class=\"recruit-peopleSlide__image\"><img src=\"/recruit/img/img_people02.jpg\" alt=\"加藤 玲史\"></figure>\n<div class=\"recruit-peopleSlide__content\">\n<p class=\"recruit-peopleSlide__title\">学生第一の予算業務を</p>\n<p class=\"recruit-peopleSlide__dept\">経理部経理課</p>\n<p class=\"recruit-peopleSlide__name\"><span class=\"recruit-peopleSlide__ja\">加藤 玲史</span> <span class=\"recruit-peopleSlide__en\">Kato Reiji</span></p>\n</div>\n</a></div>\n<!--\n              <div class=\"swiper-slide\">\n                <a href=\"/interview/00539.html\" class=\"recruit-peopleSlide\">\n                  <figure class=\"recruit-peopleSlide__image\"><img src=\"/recruit/img/img_people03.png\" alt=\"實川 由梨菜\"></figure>\n                  <div class=\"recruit-peopleSlide__content\">\n                    <p class=\"recruit-peopleSlide__title\">学生一人一人に<br class=\"d-sp-none\">適切なアドバイスを</p>\n                    <p class=\"recruit-peopleSlide__dept\">教務部国際学部教務課</p>\n                    <p class=\"recruit-peopleSlide__name\">\n                      <span class=\"recruit-peopleSlide__ja\">實川 由梨菜</span>\n                      <span class=\"recruit-peopleSlide__en\">Jitsukawa Yurina</span>\n                    </p>\n                  </div>\n                </a>\n              </div>\n-->\n<div class=\"swiper-slide\"><a href=\"/interview/00531.html\" class=\"recruit-peopleSlide\">\n<figure class=\"recruit-peopleSlide__image\"><img src=\"/recruit/img/img_people04.jpg\" alt=\"松尾 くみ\"></figure>\n<div class=\"recruit-peopleSlide__content\">\n<p class=\"recruit-peopleSlide__title\">教職員向けの制度が、学生へ還元されていくことを意識しています</p>\n<p class=\"recruit-peopleSlide__dept\">人事部人事課</p>\n<p class=\"recruit-peopleSlide__name\"><span class=\"recruit-peopleSlide__ja\">松尾 くみ</span> <span class=\"recruit-peopleSlide__en\">Matsuo Kumi</span></p>\n</div>\n</a></div>\n<div class=\"swiper-slide\"><a href=\"/interview/00523.html\" class=\"recruit-peopleSlide\">\n<figure class=\"recruit-peopleSlide__image\"><img src=\"/recruit/img/img_people05.jpg\" alt=\"木全 貴大\"></figure>\n<div class=\"recruit-peopleSlide__content\">\n<p class=\"recruit-peopleSlide__title\">グローバル化に力を入れている東洋大学の教育理念に共感しました</p>\n<p class=\"recruit-peopleSlide__dept\">総務部広報課</p>\n<p class=\"recruit-peopleSlide__name\"><span class=\"recruit-peopleSlide__ja\">木全 貴大</span> <span class=\"recruit-peopleSlide__en\">Kimata Takahiro</span></p>\n</div>\n</a></div>\n<!--\n              <div class=\"swiper-slide\">\n                <a href=\"/interview/00021.html\" class=\"recruit-peopleSlide\">\n                  <figure class=\"recruit-peopleSlide__image\"><img src=\"/recruit/img/img_people06.jpg\" alt=\"葛谷 佳樹\"></figure>\n                  <div class=\"recruit-peopleSlide__content\">\n                    <p class=\"recruit-peopleSlide__title\">ミスマッチのない<br class=\"d-sp-none\">大学選びを高校生に</p>\n                    <p class=\"recruit-peopleSlide__dept\">入試部入試課</p>\n                    <p class=\"recruit-peopleSlide__name\">\n                      <span class=\"recruit-peopleSlide__ja\">葛谷 佳樹</span>\n                      <span class=\"recruit-peopleSlide__en\"> Kuzutani Yoshiki</span>\n                    </p>\n                  </div>\n                </a>\n              </div>\n              <div class=\"swiper-slide\">\n                <a href=\"/interview/00562.html\" class=\"recruit-peopleSlide\">\n                  <figure class=\"recruit-peopleSlide__image\"><img src=\"/recruit/img/img_people07.jpg\" alt=\"宮本 靖子\"></figure>\n                  <div class=\"recruit-peopleSlide__content\">\n                    <p class=\"recruit-peopleSlide__title\">自分自身の成長が<br class=\"d-sp-none\">学生に還元される</p>\n                    <p class=\"recruit-peopleSlide__dept\">朝霞事務部朝霞事務課</p>\n                    <p class=\"recruit-peopleSlide__name\">\n                      <span class=\"recruit-peopleSlide__ja\">宮本 靖子</span>\n                      <span class=\"recruit-peopleSlide__en\">Miyamoto Yasuko</span>\n                    </p>\n                  </div>\n                </a>\n              </div>\n-->\n<div class=\"swiper-slide\"><a href=\"/interview/00560.html\" class=\"recruit-peopleSlide\">\n<figure class=\"recruit-peopleSlide__image\"><img src=\"/recruit/img/img_people08.jpg\" alt=\"清水 和樹\"></figure>\n<div class=\"recruit-peopleSlide__content\">\n<p class=\"recruit-peopleSlide__title\">留学生にも選ばれる大学に</p>\n<p class=\"recruit-peopleSlide__dept\">国際部国際課</p>\n<p class=\"recruit-peopleSlide__name\"><span class=\"recruit-peopleSlide__ja\">清水 和樹</span> <span class=\"recruit-peopleSlide__en\">Shimizu Kazuki</span></p>\n</div>\n</a></div>\n<div class=\"swiper-slide\"><a href=\"/interview/00558.html\" class=\"recruit-peopleSlide\">\n<figure class=\"recruit-peopleSlide__image\"><img src=\"/recruit/img/img_people09.jpg\" alt=\"水島 緑\"></figure>\n<div class=\"recruit-peopleSlide__content\">\n<p class=\"recruit-peopleSlide__title\">多くの学生に<br class=\"d-sp-none\">海外留学を経験してほしい</p>\n<p class=\"recruit-peopleSlide__dept\">教務部法学部教務課</p>\n<p class=\"recruit-peopleSlide__name\"><span class=\"recruit-peopleSlide__ja\">水島 緑</span> <span class=\"recruit-peopleSlide__en\">Mizushima Midori</span></p>\n</div>\n</a></div>\n<div class=\"swiper-slide\"><a href=\"/interview/00556.html\" class=\"recruit-peopleSlide\">\n<figure class=\"recruit-peopleSlide__image\"><img src=\"/recruit/img/img_people10.jpg\" alt=\"石井 秀樹\"></figure>\n<div class=\"recruit-peopleSlide__content\">\n<p class=\"recruit-peopleSlide__title\">学修者本位の<br class=\"d-sp-none\">教育の実現を目指して</p>\n<p class=\"recruit-peopleSlide__dept\">教務部全学学務推進課</p>\n<p class=\"recruit-peopleSlide__name\"><span class=\"recruit-peopleSlide__ja\">石井 秀樹</span> <span class=\"recruit-peopleSlide__en\">Ishii Hideki</span></p>\n</div>\n</a></div>\n<div class=\"swiper-slide\"><a href=\"/interview/00554.html\" class=\"recruit-peopleSlide\">\n<figure class=\"recruit-peopleSlide__image\"><img src=\"/recruit/img/img_people11.jpg\" alt=\"馬橋 由佳\"></figure>\n<div class=\"recruit-peopleSlide__content\">\n<p class=\"recruit-peopleSlide__title\">仕事も育児もバランスよく効率的に</p>\n<p class=\"recruit-peopleSlide__dept\">教務部法学部教務課</p>\n<p class=\"recruit-peopleSlide__name\"><span class=\"recruit-peopleSlide__ja\">馬橋 由佳</span> <span class=\"recruit-peopleSlide__en\">Mabashi Yuka</span></p>\n</div>\n</a></div>\n<div class=\"swiper-slide\"><a href=\"/interview/00552.html\" class=\"recruit-peopleSlide\">\n<figure class=\"recruit-peopleSlide__image\"><img src=\"/recruit/img/img_people12.jpg\" alt=\"宮下 昌之\"></figure>\n<div class=\"recruit-peopleSlide__content\">\n<p class=\"recruit-peopleSlide__title\">中長期的な学校法人の事業を構想</p>\n<p class=\"recruit-peopleSlide__dept\">経営企画本部事務室経営企画本部事務課 主任</p>\n<p class=\"recruit-peopleSlide__name\"><span class=\"recruit-peopleSlide__ja\">宮下 昌之</span> <span class=\"recruit-peopleSlide__en\">Miyashita Masayuki</span></p>\n</div>\n</a></div>\n<div class=\"swiper-slide\"><a href=\"/interview/00550.html\" class=\"recruit-peopleSlide\">\n<figure class=\"recruit-peopleSlide__image\"><img src=\"/recruit/img/img_people13.jpg\" alt=\"田中 章\"></figure>\n<div class=\"recruit-peopleSlide__content\">\n<p class=\"recruit-peopleSlide__title\">大学の発展に寄与できる<br class=\"d-sp-none\">人材を採用・育成</p>\n<p class=\"recruit-peopleSlide__dept\">人事部人事課 課長補佐</p>\n<p class=\"recruit-peopleSlide__name\"><span class=\"recruit-peopleSlide__ja\">田中 章</span> <span class=\"recruit-peopleSlide__en\">Tanaka Akira</span></p>\n</div>\n</a></div>\n<div class=\"swiper-slide\"><a href=\"/interview/00548.html\" class=\"recruit-peopleSlide\">\n<figure class=\"recruit-peopleSlide__image\"><img src=\"/recruit/img/img_people14.jpg\" alt=\"古丸 努\"></figure>\n<div class=\"recruit-peopleSlide__content\">\n<p class=\"recruit-peopleSlide__title\">教員人事と予算の観点から<br class=\"d-sp-none\">大学改革</p>\n<p class=\"recruit-peopleSlide__dept\">学長室学長事務課 課長補佐</p>\n<p class=\"recruit-peopleSlide__name\"><span class=\"recruit-peopleSlide__ja\">古丸 努</span> <span class=\"recruit-peopleSlide__en\">Komaru Tsutomu</span></p>\n</div>\n</a></div>\n</div>\n<div class=\"recruit-people__controller\">\n<div class=\"recruit-people__scrollbar\"></div>\n<div class=\"recruit-people__prev\"></div>\n<div class=\"recruit-people__next\"></div>\n</div>\n</div>\n</div>\n</div>\n<div class=\"pblock\">\n<div class=\"row row-cols-1 row-cols-md-2 gutters-x60 mt-30\">\n<div class=\"col\"><a class=\"plink_type_box_border\" href=\"/interview/?target=staff\">職員紹介一覧</a></div>\n<div class=\"col\"><a class=\"plink_type_box_border\" href=\"/recruit/staff/interview/\">内定者インタビュー</a></div>\n</div>\n</div>\n<div class=\"pblock\">\n<h2 class=\"ptitle_t1 mt-120 mt-md-150\"><a id=\"anc03\"></a>Recruit</h2>\n<p class=\"lead_style01\">採用情報</p>\n<div class=\"row row-cols-1 row-cols-md-2 flex-row-reverse gutters-x60 gutters-y20 mb-40\">\n<div class=\"col\">\n<p class=\"cat-home__txt mb-md-60 mb-40\">募集要項や採用実績、福利厚生、よくある質問（Q＆A）などをご紹介します。</p>\n<a class=\"plink_type_box_border\" href=\"/recruit/staff/recruit/\"><span class=\"ff__en ff__en-uppercase fz__normal\">read more</span></a>\n<figure class=\"mt-md-100 mt-50\"><!--img src=\"/recruit/img/img_recruit02.jpg\" alt=\"採用情報\"--><img src=\"/assets/recruit/img/komaki.jpg\" alt=\"採用情報\" style=\"width: 250px;\"><img src=\"/assets/recruit/img/shimizu.jpg\" alt=\"採用情報\" style=\"width: 250px;\"></figure>\n</div>\n<div class=\"col\">\n<div class=\"pblock-full-left\"><img src=\"/recruit/img/img_recruit01.jpg\" alt=\"採用情報\" width=\"1440\" height=\"1280\"></div>\n</div>\n</div>\n</div>\n<div class=\"pblock\">\n<h2 class=\"ptitle_t1 mt-120 mt-md-150\"><a id=\"anc04\"></a>work &amp; career</h2>\n<p class=\"lead_style01\">仕事内容／キャリア／研修制度</p>\n<div class=\"row row-cols-1 row-cols-md-2 flex-row-reverse gutters-x60 gutters-y20 mb-40\">\n<div class=\"col\">\n<div class=\"pblock-full-right\"><img src=\"/recruit/img/img_career.jpg\" alt=\"仕事内容／キャリア／研修制度\" width=\"1440\" height=\"1280\"></div>\n</div>\n<div class=\"col\">\n<p class=\"cat-home__txt mb-md-60 mb-40\">職員の役割は大きく2つ、『教育研究をサポート』そして『大学を経営管理』することです。さらに部署ごとで職員の仕事は多岐に渡るため、幅広いことにチャレンジできる環境です。こちらのページでは、職員の仕事内容と職員の能力開発をサポートする研修制度をご紹介します。</p>\n<a class=\"plink_type_box_border bt\" href=\"/recruit/staff/work_career/\"><span class=\"ff__en ff__en-uppercase fz__normal\">read more</span></a></div>\n</div>\n</div>\n<div class=\"recruit-entry\" data-bg-img-pc=\"/recruit/img/bg_entry.jpg\" data-bg-img-sp=\"/recruit/img/bg_entry.jpg\">\n<div class=\"pblock\">\n<div class=\"recruit-entry__container\">\n<div class=\"recruit-entry__inner\">\n<p class=\"text-center\"><span class=\"ptitle_t20\"><a id=\"anc05\"></a>ENTRY</span></p>\n<p class=\"lead_style06 text-center mb-md-40 mb-20\">エントリー</p>\n<p class=\"recruit-entry__text\">学校法人東洋大学の職員採用試験に応募するためには、<br class=\"d-sp-none\">「マイナビ」よりエントリーしていただく必要がございます。<br class=\"d-sp-none\">また、説明会やインターンシップの参加にもエントリーが必要です。</p>\n<div class=\"row row-cols-1 mt-md-60 mt-40\">\n<div class=\"col\"><a class=\"plink_type_box_border\" href=\"/recruit/staff/entry/\">エントリー</a></div>\n<div class=\"col\"><a class=\"plink_type_box_border\" href=\"/recruit/staff/event/\">説明会／インターンシップ情報</a></div>\n</div>\n</div>\n</div>\n</div>\n</div>\n</div>\n</main>\n<div data-include-path=\"_include/aside.html\" data-include-option=\"system\"></div>\n<!-- /page-detail -->\n    <footer class=\"ft\">\n\t<p class=\"ft_pagetop pagetop\"><a class=\"ft_pagetop-link scroll\" href=\"#\"><img src=\"/img/common/ico_pagetop.svg\" alt=\"Scroll Up\" width=\"60\" height=\"60\"></a></p>\n\t<div class=\"ft__main\">\n\t\t<div class=\"ft__logo\">\n\t\t\t<a class=\"ft__logo-link\" href=\"/\">\n\t\t\t\t<img class=\"ft__logo-img\" src=\"/img/common/img_logo-ft.svg\" alt=\"東洋大学\" width=\"179\" height=\"48\">\n\t\t\t</a>\n\t\t</div>\n\t\t<div class=\"pblock\">\n\t\t\t<div class=\"ft-menu\">\n\t\t\t\t<div class=\"row row-cols-1 row-cols-md-4 justify-content-center gutters-y10\">\n\t\t\t\t\t<div class=\"col\">\n\t\t\t\t\t\t<ul class=\"ft-menu__list ft-menu__list_sp-col2\">\n\t\t\t\t\t\t\t<li class=\"ft-menu__item\"><a class=\"ft-menu__link\" href=\"/about/\">東洋大学について</a></li>\n\t\t\t\t\t\t\t<li class=\"ft-menu__item\"><a class=\"ft-menu__link\" href=\"/academics/\">教育・国際</a></li>\n\t\t\t\t\t\t\t<li class=\"ft-menu__item\"><a class=\"ft-menu__link\" href=\"/campuslife/\">学生生活・キャリア</a></li>\n\t\t\t\t\t\t\t<li class=\"ft-menu__item\"><a class=\"ft-menu__link\" h