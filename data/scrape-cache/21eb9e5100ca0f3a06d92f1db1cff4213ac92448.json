{"url":"https://www.yokohama-ri.co.jp/recruit/new_graduate/index.html","html":"<!doctype html>\r\n<html lang=\"ja\">\r\n<head>\r\n<meta charset=\"utf-8\">\r\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\r\n<title>新卒採用情報｜浜銀総合研究所</title>\r\n<meta name=\"keywords\" content=\"新卒採用情報,コンサルティング,調査,エリアマーケティング,シンクタンク,HRI,浜銀総合研究所,浜銀総研,横浜銀行\" />\r\n<meta name=\"description\" content=\"新卒採用情報に関するページです。HRI浜銀総合研究所の採用ページ。浜銀総研は先見性、創造性を発揮した専門的調査・コンサルティングを提供する地域のベストパートナー。\" />\r\n<meta property=\"og:title\" content=\"\" />\r\n<meta property=\"og:description\" content=\"\" />\r\n<meta property=\"og:type\" content=\"website\" />\r\n<meta property=\"og:url\" content=\"\" />\r\n<meta property=\"og:image\" content=\"\" />\r\n<meta property=\"og:site_name\" content=\"\" />\r\n<link href=\"https://fonts.googleapis.com/css?family=Lato\" rel=\"stylesheet\">\r\n<link rel=\"stylesheet\" href=\"../../css/reset.css\" >\r\n<link rel=\"stylesheet\" href=\"../../css/parts.css\" >\r\n<link rel=\"stylesheet\" href=\"../common/css/recruit-common.css\" >\r\n<link rel=\"stylesheet\" href=\"../common/css/newgraduate.css\">\r\n<!-- Google Tag Manager -->\r\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\r\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\r\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\r\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\r\n})(window,document,'script','dataLayer','GTM-5SW5XMB');</script>\r\n<script src=\"../common/js/jquery.min.js\"></script>\r\n<script src=\"../common/js/recruit-common.js\"></script><script src=\"\"></script><!--[if IE]>\r\n\t\t<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge,chrome=1\" />\r\n\t\t<meta http-equiv=\"cleartype\" content=\"on\" />\r\n\t<![endif]-->\r\n<!--[if lt IE 9]>\r\n\t\t<script src=\"js/html5shiv.min.js\"></script>\r\n\t\t<script src=\"js/IE9.js\"></script>\r\n\t\t<script src=\"js/respond.min.js\"></script>\r\n\t<![endif]-->\r\n</head>\r\n<body id=\"page-top\">\r\n\r\n<!-- Google Tag Manager (noscript) -->\r\n<noscript>\r\n<iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-5SW5XMB\"\r\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe>\r\n</noscript>\r\n<!-- End Google Tag Manager (noscript) -->\r\n<header class=\"pc-header\">\r\n  <div class=\"header__top-area\">\r\n    <div class=\"header__logo\"> <a href=\"../../index.html\"><img src=\"../common/img/ricruit_header_logo.png\" alt=\"株式会社浜銀総合研究所\"></a>\r\n      <p class=\"sp-header_logo_txt\">採用情報サイト</p>\r\n    </div>\r\n    <nav class=\"header__navi\">\r\n      <ul class=\"header_navi-parent\">\r\n        <li class=\"\"> <a href=\"../index.html\">TOP</a> </li>\r\n        <li class=\"\"><a href=\"../message/index.html\">MESSAGE</a> </li>\r\n        <li class=\"\"><a href=\"../brain/index.html\">INTERVIEW</a> </li>\r\n        <li class=\"\"><a href=\"../project/index.html\">PROJECT</a> </li>\r\n      </ul>\r\n      <div class=\"pc-header_btn_wrap\">\r\n        <p class=\"btn shinjin-adopt\"><a href=\"index.html\">新卒採用</a></p>\r\n<!--\r\n        <p class=\"btn career-adopt\"><a class=\"disabled\">キャリア採用</a></p>\r\n-->\r\n        <p class=\"btn career-adopt><span class=\"font-color01\"><a href=\"https://hrmos.co./pages/yokohama-ri/ \">キャリア採用<br><span style=\"font-size:0.875em; line-height:2;\">（HRMOS採用ページ）</span></a></span></p>\r\n      </div>\r\n    </nav>\r\n  </div>\r\n</header>\r\n<header class=\"sp-header\">\r\n  <div class=\"sp-header__hamagin\">\r\n    <div class=\"sp-header_logo_icn\"><img src=\"../common/img/ricruit_header_logo.png\" alt=\"株式会社浜銀総合研究所\"></div>\r\n    <p class=\"sp-header_logo_txt\">採用情報サイト</p>\r\n  </div>\r\n  <div class=\"sp-header_btn_wrap\">\r\n    <p class=\"btn shinjin-adopt\"><a href=\"index.html\">新卒採用</a></p>\r\n<!--\r\n    <p class=\"btn career-adopt\"><a class=\"disabled\">キャリア採用</a></p>\r\n-->\r\n    <p class=\"btn career-adopt\"><span class=\"font-color05\"><a href=\"https://hrmos.co./pages/yokohama-ri/ \">キャリア採用<br><span style=\"font-size:0.875em; line-height:2;\">（HRMOS採用ページ）</span></a></span></p>\r\n  </div>\r\n</header>\r\n<div class=\"neader__nav-bg\">\r\n  <div id=\"header__nav-btn\">\r\n    <div id=\"header__nav-btn-inner\"> <span></span> <span></span> <span></span> </div>\r\n  </div>\r\n  <nav class=\"sp_header__nav-list\">\r\n    <ul>\r\n      <li></li>\r\n      <li class=\"btn-arrow01\"><a href=\"../index.html\">TOP</a> </li>\r\n      <li class=\"btn-arrow01\"><a href=\"../message/index.html\">MESSAGE</a> </li>\r\n      <li class=\"btn-arrow01\"> <a href=\"../brain/index.html\">INTERVIEW</a> </li>\r\n      <li class=\"btn-arrow01\"><a href=\"../project/index.html\">PROJECT</a></li>\r\n    </ul>\r\n    <div class=\"sp-header_btn_wrap\">\r\n      <p class=\"btn shinjin-adopt\"><a href=\"index.html\">新卒採用</a></p>\r\n<!--\r\n      <p class=\"btn career-adopt\"><a class=\"disabled\">キャリア採用<span class=\"disabled-txt\">※現在、募集しておりません。</span></a></p>\r\n-->\r\n      <p class=\"btn career-adopt\"><span class=\"font-color05\"><a href=\"https://hrmos.co./pages/yokohama-ri/ \">キャリア採用<br><span style=\"font-size:0.875em; line-height:2;\">（HRMOS採用ページ）</span></a></span></p>\r\n    </div>\r\n  </nav>\r\n</div>\r\n<!--/header-->\r\n<section class=\"mv\"> \r\n  <!--パンくずリスト-->\r\n  <div class=\"breadcrumb\">\r\n    <ul>\r\n      <li><a href=\"../index.html\">浜銀総合研究所 採用情報サイト トップ</a></li>\r\n      <li>NEW GRADUATE</li>\r\n    </ul>\r\n  </div>\r\n  <div class=\"mv_ttl-wrap\">\r\n    <h1 class=\"mv__h1\">NEW GRADUATE</h1>\r\n    <p class=\"mv_sub-ttl\">新卒採用情報</p>\r\n  </div>\r\n</section>\r\n<section class=\"recruit_mainarea\">\r\n  <div class=\"newgraduate__content-area area01\" id=\"01\">\r\n    <div class=\"newgraduate__content-area-wrap\">\r\n      <div class=\"newgraduate__content-ttl-wrap\">\r\n        <p class=\"newgraduate__content-ttl ttl-line02\">募集業種</p>\r\n        <span class=\"ttl-line-after01\"></span> </div>\r\n      <div class=\"newgraduate__content-txt\">コンサルタント・研究員</div>\r\n    </div>\r\n  </div>\r\n  <div class=\"newgraduate__content-area area02\" id=\"02\">\r\n    <div class=\"newgraduate__content-area-wrap\">\r\n      <div class=\"newgraduate__content-ttl-wrap\">\r\n        <p class=\"newgraduate__content-ttl ttl-line02\">募集概要</p>\r\n        <span class=\"ttl-line-after01\"></span> </div>\r\n      <div class=\"newgraduate__content-txt overview\">\r\n        <dl class=\"newgraduate__content-list\">\r\n          <dt class=\"newgraduate__content-list-ttl\">募集学部学科</dt>\r\n          <dd class=\"newgraduate__content-list-txt\">全学部・全学科（4年制大学もしくは大学院）</dd>\r\n        </dl>\r\n        <dl class=\"newgraduate__content-list\">\r\n          <dt class=\"newgraduate__content-list-ttl\">募集人数</dt>\r\n          <dd class=\"newgraduate__content-list-txt\">若干名</dd>\r\n        </dl>\r\n        <dl class=\"newgraduate__content-list\">\r\n          <dt class=\"newgraduate__content-list-ttl\">選考方法</dt>\r\n          <dd class=\"newgraduate__content-list-txt\">書類選考、面接</dd>\r\n        </dl>\r\n        <dl class=\"newgraduate__content-list\">\r\n          <dt class=\"newgraduate__content-list-ttl\">応募方法</dt>\r\n          <dd class=\"newgraduate__content-list-txt\">2026年度新卒採用の受付終了<br>\r\n          2027年3月卒業見込みの大学生・大学院生（修士課程）対象<br>\r\n          オープンカンパニー・インターンシップ受付中<br>\r\n         （マイナビ・ワンキャリアよりエントリーしてください）</dd>\r\n        </dl>\r\n        <dl class=\"newgraduate__content-list\">\r\n          <dt class=\"newgraduate__content-list-ttl\">応募資格</dt>\r\n          <dd class=\"newgraduate__content-list-txt\">2027年3月に大学卒業見込みまたは大学院修了見込みの方</dd>\r\n        </dl>\r\n        <dl class=\"newgraduate__content-list\">\r\n          <dt class=\"newgraduate__content-list-ttl\">連絡先</dt>\r\n          <dd class=\"newgraduate__content-list-txt\">〒220-8616　神奈川県横浜市西区みなとみらい3-1-1<br>\r\n            株式会社浜銀総合研究所　企画総務部　採用担当<br>\r\n            <span class=\"tel-link\" data-action=\"call\" data-tel=\"tel:0452252374\">TEL 045-225-2371</span></dd>\r\n        </dl>\r\n      </div>\r\n    </div>\r\n  </div>\r\n  <div class=\"newgraduate__content-area area03\" id=\"03\">\r\n    <div class=\"newgraduate__content-area-wrap\">\r\n      <div class=\"newgraduate__content-ttl-wrap\">\r\n        <p class=\"newgraduate__content-ttl ttl-line02\">採用実績</p>\r\n        <span class=\"ttl-line-after01\"></span> </div>\r\n      <div class=\"newgraduate__content-txt-wrap\">\r\n        <div class=\"newgraduate__content-txt result\">\r\n<!--      <dl class=\"newgraduate__content-list\">\r\n            <dt class=\"newgraduate__content-list-ttl\">2020年</dt>\r\n            <dd class=\"newgraduate__content-list-txt\">3名（文3：理0）（院2：学1）</dd>\r\n          </dl> -->\r\n          <dl class=\"newgraduate__content-list\">\r\n            <dt class=\"newgraduate__content-list-ttl\">2021年</dt>\r\n            <dd class=\"newgraduate__content-list-txt\">3名（文2：理1）（院2：学1）</dd>\r\n          </dl>\r\n          <dl class=\"newgraduate__content-list\">\r\n            <dt class=\"newgraduate__content-list-ttl\">2022年</dt>\r\n            <dd class=\"newgraduate__content-list-txt\">2名（文2：理0）（院1：学1）</dd>\r\n          </dl>\r\n          <dl class=\"newgraduate__content-list\">\r\n            <dt class=\"newgraduate__content-list-ttl\">2023年</dt>\r\n            <dd class=\"newgraduate__content-list-txt\">3名（文3：理0）（院0：学3）</dd>\r\n          </dl>\r\n          <dl class=\"newgraduate__content-list\">\r\n            <dt class=\"newgraduate__content-list-ttl\">2024年</dt>\r\n            <dd class=\"newgraduate__content-list-txt\">5名（文5：理0）（院1：学4）</dd>\r\n          </dl>\r\n          <dl class=\"newgraduate__content-list\">\r\n            <dt class=\"newgraduate__content-list-ttl\">2025年</dt>\r\n            <dd class=\"newgraduate__content-list-txt\">9名（文7：理2）（院2：学7）</dd>\r\n          </dl>\r\n          <dl class=\"newgraduate__content-list\">\r\n            <dt class=\"newgraduate__content-list-ttl\">2026年<br>(見込み)</dt>\r\n            <dd class=\"newgraduate__content-list-txt\">9名（文6：理3）（院4：学5）</dd>\r\n          </dl>\r\n        </div>\r\n        <div class=\"newgraduate__content-txt detail\">\r\n          <dl class=\"newgraduate__content-list\">\r\n            <dt class=\"newgraduate__content-list-ttl\">給与</dt>\r\n            <dd class=\"newgraduate__content-list-txt\">大学卒　260,000円(2025年4月実績)<br>\r\n              修士了　275,000円(2025年4月実績)</dd>\r\n          </dl>\r\n          <dl class=\"newgraduate__content-list\">\r\n            <dt class=\"newgraduate__content-list-ttl\">諸手当</dt>\r\n            <dd class=\"newgraduate__content-list-txt\">通勤手当、時間外手当、住居補給金　等</dd>\r\n          </dl>\r\n          <dl class=\"newgraduate__content-list\">\r\n            <dt class=\"newgraduate__content-list-ttl\">改定</dt>\r\n            <dd class=\"newgraduate__content-list-txt\">年一回（7月）</dd>\r\n          </dl>\r\n          <dl class=\"newgraduate__content-list\">\r\n            <dt class=\"newgraduate__content-list-ttl\">賞与</dt>\r\n            <dd class=\"newgraduate__content-list-txt\">年二回（6月、12月）</dd>\r\n          </dl>\r\n          <dl class=\"newgraduate__content-list\">\r\n            <dt class=\"newgraduate__content-list-ttl\">福利厚生</dt>\r\n            <dd class=\"newgraduate__content-list-txt\">独身寮、財形貯蓄制度、厚生施設　等</dd>\r\n          </dl>\r\n          <dl class=\"newgraduate__content-list\">\r\n            <dt class=\"newgraduate__content-list-ttl\">保険</dt>\r\n            <dd class=\"newgraduate__content-list-txt\">各種社会保険完備、育児休業制度、介護休業制度　等</dd>\r\n          </dl>\r\n          <dl class=\"newgraduate__content-list\">\r\n            <dt class=\"newgraduate__content-list-ttl\">勤務地</dt>\r\n            <dd class=\"newgraduate__content-list-txt\">神奈川県横浜市</dd>\r\n          </dl>\r\n          <dl class=\"newgraduate__content-list\">\r\n            <dt class=\"newgraduate__content-list-ttl\">勤務時間</dt>\r\n            <dd class=\"newgraduate__content-list-txt\">標準就労時間　8：45～17：15（昼休み60分）フレックスタイム制（コアタイム無）</dd>\r\n          </dl>\r\n          <dl class=\"newgraduate__content-list\">\r\n            <dt class=\"newgraduate__content-list-ttl expect\">休日・休暇</dt>\r\n            <dd class=\"newgraduate__content-list-txt\">完全週休二日制（土、日）、祝日、年次休暇（初年度15日、最大20日）、年末年始、特別傷病休暇、慶弔・出産・育児・看護・介護・リフレッシュ休暇、ワークライフバランス支援休暇、チャイルドプラン休暇、連続休暇制度、時間単位年休</dd>\r\n          </dl>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n  <div class=\"newgraduate__content-area area04\" id=\"04\">\r\n    <div class=\"newgraduate__content-area-wrap\">\r\n      <div class=\"newgraduate__content-ttl-wrap\">\r\n        <p class=\"newgraduate__content-ttl ttl-line02\">採用までの流れ</p>\r\n        <span class=\"ttl-line-after01\"></span> </div>\r\n      <div class=\"newgraduate__content-txt entry\">\r\n        <ul class=\"newgraduate__content-entry-list\">\r\n          <li class=\"newgraduate__content-entry-item entry-arrow\">サイトからエントリー　　　　 \r\n                \t<a href=\"https://job.mynavi.jp/27/pc/search/corp239677/outline.html\" target=\"_blank\"><span class=\"font-color01\" style=\"font-size:1.25em;\"><u>マイナビ</u></a>\r\n                        <span>　　　</span>\r\n\t\t\t<a href=\"https://www.onecareer.jp/companies/51317\" target=\"_blank\"><span class=\"font-color01\" style=\"font-size:1.25em;\"><u>ワンキャリア</u></a>\r\n\t\t\t\t\t                                        </li>\r\n          <li class=\"newgraduate__content-entry-item entry-arrow\">会社説明会開催</li>\r\n          <li class=\"newgraduate__content-entry-item entry-arrow\">履歴書提出</li>\r\n          <li class=\"newgraduate__content-entry-item entry-arrow\">人事面接</li>\r\n          <li class=\"newgraduate__content-entry-item entry-arrow\">面接（複数回）</li>\r\n          <li class=\"newgraduate__content-entry-item now-posi\">内々定のご連絡</li>\r\n        </ul>\r\n      </div>\r\n    </div>\r\n  </div>\r\n  <div class=\"newgraduate__content-area area05\" id=\"05\">\r\n    <div class=\"newgraduate__content-area-wrap\">\r\n      <div class=\"newgraduate__content-ttl-wrap\">\r\n        <p class=\"newgraduate__content-ttl ttl-line02\">業務内容</p>\r\n        <span class=\"ttl-line-after01\"></span> </div>\r\n      <div class=\"newgraduate__content-txt business\">\r\n        <dl class=\"newgraduate__content-business-list\">\r\n          <dt class=\"newgraduate__content-business-ttl  ttl-line03\">地域政策分野</dt>\r\n          <dd class=\"newgraduate__content-business-txt\">主に都市・地域計画、経済・産業政策関連コンサルティング、医療・福祉政策コンサルティング等、神奈川県下の地方自治体を中心に、自治体や地域の経営に関する支援を行います。</dd>\r\n        </dl>\r\n        <dl class=\"newgraduate__content-business-list\">\r\n          <dt class=\"newgraduate__content-business-ttl ttl-line03\">自治体経営コンサルティング分野</dt>\r\n          <dd class=\"newgraduate__content-business-txt\">全国の地方自治体および地方公営企業の経営等に関する支援を行います。</dd>\r\n        </dl>\r\n        <dl class=\"newgraduate__content-business-list\">\r\n          <dt class=\"newgraduate__content-business-ttl ttl-line03\">戦略系・マネジメントコンサルティング分野／人事系コンサルティング分野／ISO、プライバシーマーク等認証取得支援コンサルティング分野</dt>\r\n          <dd class=\"newgraduate__content-business-txt\">中堅・中小企業の経営革新、人事制度構築等に関わる経営コンサルティング<br>\r\n            主に経営戦略、企業再生、新事業開発、営業力強化、組織・人事、情報システム戦略、経営管理システム等に関する支援コンサルティングを行います。</dd>\r\n        </dl>\r\n        <dl class=\"newgraduate__content-business-list\">\r\n          <dt class=\"newgraduate__content-business-ttl ttl-line03\">ビッグデータと機械学習を駆使したデータサイエンス・コンサルティング</dt>\r\n          <dd class=\"newgraduate__content-business-txt\">私たちは金融機関を主な顧客として、ビッグデータの解析と機械学習の技術を活用してビジネス課題の解決を目指します。<br>\r\n            膨大なデータから有用な情報を見つけ出し、それをもとに具体的な解決策を提案する業務を行います。<br>\r\n            データの力を最大限に引き出し、クライアントのビジネス成長を支える役割を担うことを目指して活動を行います。</dd>\r\n        </dl>\r\n        <dl class=\"newgraduate__content-business-list\">\r\n          <dt class=\"newgraduate__content-business-ttl ttl-line03\">地域経済調査分野／マクロ経済調査分野／産業調査分野</dt>\r\n          <dd class=\"newgraduate__content-business-txt\">国内外の経済・産業・金融動向の分析、及び神奈川を中心とする地域経済動向や産業構造の分析を行います。</dd>\r\n        </dl>\r\n        <dl class=\"newgraduate__content-business-list\">\r\n          <dt class=\"newgraduate__content-business-ttl ttl-line03\">海外進出支援コンサルティング分野</dt>\r\n          <dd class=\"newgraduate__content-business-txt\">企業の海外進出支援・コンサルティング、海外ビジネスに関する情報や各種サービスを行います。</dd>\r\n        </dl>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</section>\r\n<footer>\r\n  <div class=\"footer_contents\">\r\n    <div class=\"footer_contents-inner\">\r\n      <div class=\"footer_contents_ttl\">\r\n        <p class=\"footer_contents_main-ttl\">新卒採用情報</p>\r\n        <p class=\"footer_contents_sub-ttl ttl-line01\">NEW GRADUATE</p>\r\n        <span class=\"ttl-line-after01\"></span> </div>\r\n      <div class=\"footer_contents_btn-wrap\">\r\n        <div class=\"footer_contents-btn shinjin-adopt\">\r\n          <p class=\"btn btn-arrow04\"><a href=\"index.html\">新卒採用情報はこちら</a></p>\r\n        </div>\r\n        <div class=\"footer_contents-btn career-adopt\">\r\n          <p>\r\n\r\n</p>\r\n        </div>\r\n      </div>\r\n      <div class=\"footer_contents_ttl career-adopt\">\r\n        <p class=\"footer_contents_main-ttl\">キャリア採用情報</p>\r\n        <p class=\"footer_contents_sub-ttl ttl-line01\">CAREER</p>\r\n        <span class=\"ttl-line-after01\"></span> </div>\r\n<!--\r\n      <p class=\"footer_contents_txt\">下記までお問合せください。</p>\r\n-->\r\n       <div class=\"footer_contents_btn-wrap\">\r\n       <div class=\"footer_contents-btn shinjin-adopt\">\r\n         <p class=\"btn btn-arrow04\"><a href=\"https://hrmos.co./pages/yokohama-ri/\">キャリア採用情報はこちら<br><span style=\"font-size:0.875em; line-height:2;\">（HRMOS採用ページへ移動します）</span></a></p>\r\n                                </div>\r\n                        </div>\r\n      <div class=\"footer_contents_apoint-wrap\">\r\n        <div class=\"footer_contents_apoint_txt\">\r\n          <p class=\"footer_contents_apoint_txt-xsize\">お問合せ・ご相談は<span class=\"sp-in\">...</span></p>\r\n          お電話にてお伺いいたします。<br>\r\n          お気軽にご連絡ください。</div>\r\n        <span class=\"footer_contents_apoint_tel tel-link\" data-action=\"call\" data-tel=\"tel:0452252371\">\r\n        <div class=\"footer_contents_apoint_tel-wrap\">\r\n          <div class=\"footer_contents_tel-icn\"><img src=\"../common/img/tel_btn_icn.png\" alt=\"045-225-2371\"></div>\r\n          <div class=\"footer_contents_tel-info-wrap\">\r\n            <p class=\"footer_contents_tel-number\">045-225-2371</p>\r\n            <p class=\"footer_contents_tel-personnel\">株式会社浜銀総合研究所　企画総務部</p>\r\n          </div>\r\n        </div>\r\n        </span> </div>\r\n    </div>\r\n  </div>\r\n  <div class=\"footer-navi-wrap\">\r\n    <nav class=\"top__footer-navi\">\r\n      <ul>\r\n        <li class=\"footer_btn-arrow01\"><a href=\"../../html/site_map\">サイトマップ</a></li>\r\n        <li class=\"footer_btn-arrow01\"><a href=\"../../html/regulation/index.html\">免責・利用規定</a></li>\r\n        <li class=\"footer_btn-arrow01\"><a href=\"../../html/security_policy/index.html\">情報セキュリティ基本方針</a></li>\r\n        <li class=\"footer_btn-arrow01\"><a href=\"../../html/regulation/person.html\">個人情報保護について</a></li>\r\n      </ul>\r\n    </nav>\r\n    <p class=\"footer__txt\"> 【浜銀総合研究所は、横浜銀行グループのシンクタンク・コンサルティング会社。地元神奈川、横浜、川崎、東京に密着した調査から全国規模および海外にいたるまでの専門的研究を手がけています。】<br>\r\n      このホームページに関するご意見、お問合せは、<a href=\"../../html/inquiry/inquiry.html\">こちら</a>までお願いします。このホームページの内容を、許可無く転載・複製することを禁止します。 </p>\r\n    <small>Copyright 2019 (C) Hamagin Research Institute,Ltd.All rights reserved.</small></div>\r\n</footer>\r\n<div class=\"page-top_btn\"> <a href=\"#page-top\">&nbsp;</a> </div>\r\n</body>\r\n</html>","finalUrl":"https://www.yokohama-ri.co.jp/recruit/new_graduate/index.html","rendered":false,"_cachedAt":"2026-06-14T19:11:34.383Z"}