iv class=\"f2m_err f2m_err_first_kana\"></div>\n\t\t\t\t\t<div class=\"f2m_err f2m_err_last_kana\"></div>\n\t\t\t\t</td>\n\t\t\t</tr>\n\t\t\t<tr>\n\t\t\t\t<th>学校名<span>必須</span></th>\n\t\t\t\t<td>\n\t\t\t\t\t<input type=\"text\" name=\"school_name\">\n\t\t\t\t\t<div class=\"f2m_err f2m_err_school_name\"></div>\n\t\t\t\t</td>\n\t\t\t</tr>\n\t\t\t<tr>\n\t\t\t\t<th>学部名</th>\n\t\t\t\t<td>\n\t\t\t\t\t<input type=\"text\" name=\"faculty\">\n\t\t\t\t</td>\n\t\t\t</tr>\n\t\t\t<tr>\n\t\t\t\t<th>学科名</th>\n\t\t\t\t<td>\n\t\t\t\t\t<input type=\"text\" name=\"department\">\n\t\t\t\t</td>\n\t\t\t</tr>\n\t\t\t<tr>\n\t\t\t\t<th>卒業年（西暦）<span>必須</span></th>\n\t\t\t\t<td>\n\t\t\t\t\t<input type=\"text\" name=\"graduate\">\n\t\t\t\t\t<div class=\"f2m_err f2m_err_graduate\"></div>\n\t\t\t\t</td>\n\t\t\t</tr>\n\t\t\t<tr>\n\t\t\t\t<th>電話番号<span>必須</span></th>\n\t\t\t\t<td>\n\t\t\t\t\t<input type=\"tel\" name=\"phone\" class=\"p-entry_input_tel\" placeholder=\"例）0612345678\">\n\t\t\t\t\t<div class=\"f2m_err f2m_err_phone\"></div>\n\t\t\t\t</td>\n\t\t\t</tr>\n\t\t\t<tr>\n\t\t\t\t<th>メールアドレス<span>必須</span></th>\n\t\t\t\t<td>\n\t\t\t\t\t<input type=\"text\" name=\"email\" placeholder=\"例）info@xxx.co.jp\">\n\t\t\t\t\t<div class=\"f2m_err f2m_err_email\"></div>\n\t\t\t\t</td>\n\t\t\t</tr>\n\t\t\t<tr>\n\t\t\t\t<th>メールアドレス（再入力）<span>必須</span></th>\n\t\t\t\t<td>\n\t\t\t\t\t<input type=\"text\" name=\"email2\" placeholder=\"例）info@xxx.co.jp\">\n\t\t\t\t\t<div class=\"f2m_err f2m_err_email2\"></div>\n\t\t\t\t</td>\n\t\t\t</tr>\n\t\t\t<tr>\n\t\t\t\t<th>応募区分</th>\n\t\t\t\t<td>\n\t\t\t\t\t<input type=\"radio\" id=\"entry01\" class=\"visually-hidden\" name=\"entry_type\" value=\"新卒採用\"><label for=\"entry01\">新卒採用</label>\n\t\t\t\t\t<input type=\"radio\" id=\"entry02\" class=\"visually-hidden\" name=\"entry_type\" value=\"キャリア採用\"><label for=\"entry02\">キャリア採用</label>\n\t\t\t\t</td>\n\t\t\t</tr>\n\t\t\t<tr>\n\t\t\t\t<th>希望職種</th>\n\t\t\t\t<td>\n\t\t\t\t\t<div class=\"p-entry_select\">\n\t\t\t\t\t\t<selec