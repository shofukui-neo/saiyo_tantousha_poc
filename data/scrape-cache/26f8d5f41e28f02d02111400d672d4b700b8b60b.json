{"url":"https://site.awi.co.jp/recruit/recruit/recruiting.html","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n<head>\n<!-- Google Tag Manager -->\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\n\tnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\n\tj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n\t'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n\t})(window,document,'script','dataLayer','GTM-N4DKX2CP');</script>\n<!-- End Google Tag Manager -->\n<meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\" />\n<meta name=\"keywords\" content=\"エア・ウォーター,airwater,新卒採用\" />\n<meta name=\"description\" content=\"エア・ウォーターの新卒（大学卒・大学院修了）採用情報です。\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1.0,minimum-scale=1.0\">\n<title>募集要項 | 採用サイト | エア・ウォーター株式会社</title>\n<!-- Google Tag Manager -->\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n})(window,document,'script','dataLayer','GTM-5WJXMST');</script>\n<!-- End Google Tag Manager -->\n<link rel=\"shortcut icon\" href=\"https://www.awi.co.jp/common/images/favicon.ico\" type=\"image/vnd.microsoft.icon\">\n<link rel=\"apple-touch-icon\" sizes=\"152x152\" href=\"https://www.awi.co.jp/common/images/apple-touch-icon.png\">\n\t\n<!-- 共通で使用するcssを読み込む -->\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../common/css/base.css\" media=\"all\" />\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../common/css/hacks.css\" media=\"all\" />\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../common/css/reset.css\" media=\"all\" />\n<link rel=\"stylesheet\" type=\"text/css\" href=\"css/recruiting.css\" media=\"all\" />\n\n<!-- 共通で使用するjsを読み込む -->\n<script src=\"https://code.jquery.com/jquery-1.10.1.min.js\"></script>\n<script src=\"../common/js/library.js\"></script>\n\n<!-- このページで使用するcss、プラグインのオプション設定を記述したjsなどを読み込む -->\n<script src=\"../common/js/jquery.matchHeight.js\"></script>\n<script>\n$(function(){\n　　$('.matchHeight').matchHeight();\n　　$('#menu_block ul li').matchHeight();\n　　$('#ideal dl').matchHeight();\n});\n</script>\n<script>\n\t$(function(){\n\t\t$('.accordion-menu > dt').on('click',function(){\n\t\t\t$(this).next('dd').slideToggle();\n\t\t});\n\t});\n</script>\n<!-- Global site tag (gtag.js) - Google Analytics -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=UA-190657780-1\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'UA-190657780-1');\n  gtag('config', 'G-3Y0BEEZQ9C');\n</script>\n\n</head>\n\n\n<body class=\"close\">\n<!-- Google Tag Manager (noscript) -->\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-N4DKX2CP\"\n\theight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n<!-- End Google Tag Manager (noscript) -->\n\n\n<!--========== #header ==========-->\n<header id=\"header\" class=\"cbox\">\n\t<h1 class=\"logo\"><a href=\"https://www.awi.co.jp/\" target=\"_blank\"><img src=\"../common/img/logo.png\" alt=\"エア・ウォーター\"></a><a href=\"../\"><span>採用サイト</span></a></h1>\n\t<div class=\"head_list cbox\">\n\t\t<span class=\"menu_btn\"><span class=\"line\"></span></span>\n\t\t<div class=\"entry_list\">\n\t\t\t<div class=\"nav-item open-item line\">\n\t\t\t\t<div class=\"cntnr\">\n\t\t\t\t\t<span class=\"u_line\">キャリア採用</span>\n\t\t\t\t</div>\n\t\t\t\t<div class=\"open_cntnts\">\n\n\t\t\t\t\t<a href=\"../recruit/career.html\">\n\t\t\t\t\t\t<span class=\"u_line02 txt-14\">キャリア採用情報</span>\n\t\t\t\t\t</a>\n\t\t\t\t\t<a href=\"../recruit/alumni.html\">\n\t\t\t\t\t\t<span class=\"u_line02 txt-14\">アルムナイ採用</span>\n\t\t\t\t\t