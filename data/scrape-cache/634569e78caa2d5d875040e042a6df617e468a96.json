t/data/js/common/jquery.min.js?v=0.0.1\"></script>\n        <script type=\"text/javascript\" src=\"/recruit/data/js/common/jquery.lh.js?v=0.0.1\"></script>\n        <script src=\"https://unpkg.com/aos@2.3.1/dist/aos.js\"></script>\n        <script src=\"//cdn.jsdelivr.net/npm/vivus@latest/dist/vivus.min.js\"></script>\n        <script type=\"text/javascript\" src=\"/recruit/data/js/common/base.js?v=0.0.1\"></script>\n\n         \n    </body>\n</html>","finalUrl":"https://www.asahi-metal.com/recruit/philosophy/","rendered":false,"_cachedAt":"2026-06-22T18:25:21.273Z"}