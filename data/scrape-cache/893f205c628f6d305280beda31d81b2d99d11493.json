class=\"kana\" id=\"kana\" type=\"text\" name=\"kana\" placeholder=\"フリガナを入力してください\" value=\"\">\n                    </div>\n                  </dd>\n                </dl>\n              </div>\n              <div class=\"row\">\n                <dl>\n                  <dt>\n                    <label for=\"corporate\">会社名</label>\n                  </dt>\n                  <dd> \n                    <div class=\"field\">\n                      <input class=\"corporate\" id=\"corporate\" type=\"text\" name=\"corporate\" placeholder=\"会社名を入力してください\" value=\"\">\n                    </div>\n                  </dd>\n                </dl>\n              </div>\n              <div class=\"row\">\n                <dl>\n                  <dt>\n                    <label for=\"tel\">電話番号</label>\n                  </dt>\n                  <dd> \n                    <div class=\"field\">\n                      <input class=\"tel\" id=\"tel\" type=\"text\" name=\"tel\" placeholder=\"電話番号を入力してください\" value=\"\">\n                    </div>\n                  </dd>\n                </dl>\n              </div>\n              <div class=\"row\">\n                <dl>\n                  <dt>\n                    <label for=\"mail\">メールアドレス</label>\n                  </dt>\n                  <dd>\n                    <div class=\"field\">\n                      <input class=\"mail\" id=\"mail\" type=\"text\" name=\"mail\" placeholder=\"例）xxxxxxx@ooo.com\" value=\"\">\n                    </div>\n                  </dd>\n                </dl>\n              </div>\n              <div class=\"row\">\n                <dl>\n                  <dt>\n                    <label for=\"remail\">メールアドレス（確認）</label>\n                  </dt>\n                  <dd>\n                    <div class=\"field\">\n                      <input class=\"remail\" id=\"remail\" type=\"text\" name=\"remail\" placeholder=\"例）xxxxxxx@ooo.com\" value=\"\">\n                    </div>\n                    <p class=\"notice\">半角英数でご入力ください。<br>メールの受信を拒否設定されている場合は、設定を解除してご利用ください。</p>\n                  </dd>\n                </dl>\n              </div>\n              <div class=\"row last\">\n                <dl>\n                  <dt>\n                    <label for=\"textarea\">ご相談内容</label>\n                  </dt>\n                  <dd>\n                    <div class=\"field\">\n                      <textArea class=\"textarea\" id=\"textarea\" type=\"text\" name=\"textarea\"></textArea>\n                    </div>\n                  </dd>\n                </dl>\n              </div>\n              <div class=\"btnArea\">\n                <input type=\"hidden\" name=\"token\" value=\"ff6aedea81c64131ced8d7f64a939101699779f5\">\n                <button class=\"btn btnConfirm\" type=\"button\">入力内容を確認する</button>\n                <button class=\"btn btnReturn\" type=\"button\">入力画面にもどる</button>\n                <button class=\"btn btnSubmit\" type=\"submit\" name=\"submitConfirm\" value=\"\">送信</button>\n              </div>\n            </form>\n          </div>\n        </section>\n        <aside id=\"secRecruits\">\n          <div class=\"inner\">\n            <div class=\"ttlbox\">\n              <h2 class=\"titleStyleA\">採用情報</h2>\n              <p class=\"en _cormorant\">RECRUIT</p>\n            </div>\n            <div class=\"obj\"><img src=\"../assets/img//common/rec_zokuzoku04.png\" srcset=\"../assets/img//common/rec_zokuzoku04.png 1x, ../assets/img//common/rec_zokuzoku04@2x.png 2x\" alt=\"属属\">\n              <p class=\"label en _cormorant\">ZOKUZOKU</p>\n            </div>\n            <h3 class=\"lead\">手は口ほどにモノを言う</h3>\n            <p>Def tribeの採用特設ページはこちら。<br>「属して属さない働き方」で、会社も社会も変えてみませんか？</p>\n            <div class=\"btnArea\"><a class=\"btnStyle02\" href=\"..//recruit/\">採用情報へ</a></div>\n          </div>\n        </aside>\n      </main>\n      <footer id=\"footer\">\n        <div class=\"inner\">\n          <div class=\"cta\">\n            <p class=\"tt