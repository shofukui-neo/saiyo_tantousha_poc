1-1\"></script>\n\t<script>\n\t\twindow.dataLayer = window.dataLayer || [];\n\t\tfunction gtag() { dataLayer.push(arguments); }\n\t\tgtag('js', new Date());\n\t\tgtag('config', 'UA-2097811-1');\n\t\tgtag('config', 'G-0BNP76Q4Q7');\n\t</script>\n</head>\n\n<body>\n\t<script async src=\"https://www.googletagmanager.com/gtag/js?id=AW-734422123\"></script>\n\t<script>\n\t\twindow.dataLayer = window.dataLayer || [];\n\t\tfunction gtag() { dataLayer.push(arguments); }\n\t\tgtag('js', new Date());\n\t\tgtag('config', 'AW-734422123');\n\t</script>\n\t<div class=\"openbtn\"><span></span><span></span><span></span></div>\n\t<nav id=\"g-nav\">\n\t\t<div id=\"g-nav-list\">\n\t\t\t<ul>\n\t\t\t\t<li><a href=\"../index.html#01_business\" title=\"事業を知る\">事業を知る</a></li>\n\t\t\t\t<li><a href=\"../index.html#02_member\" title=\"職種と人を知る\">職種と人を知る</a></li>\n\t\t\t\t<li><a href=\"../index.html#03_workspace\" title=\"環境・待遇を知る\">環境・待遇を知る</a></li>\n\t\t\t\t<li><a href=\"../index.html#04_information\" title=\"新卒採用\">新卒採用</a></li>\n\t\t\t\t<li><a href=\"../index.html#04_information\" title=\"キャリア採用\">キャリア採用</a></li>\n\t\t\t</ul>\n\t\t</div>\n\t</nav>\n\t<nav class=\"pc\">\n\t\t<div class=\"inner\">\n\t\t\t<div class=\"logo\"><a href=\"../index.html\"><img src=\"../images/index/logo.svg\" alt=\"ソリマチ株式会社採用情報\"></a></div>\n\t\t\t<div class=\"area\">\n\t\t\t\t<ul>\n\t\t\t\t\t<li><a href=\"../business/service.html\" title=\"事業を知る\">事業を知る</a></li>\n\t\t\t\t\t<li><a href=\"../member/movie.html\" title=\"職種と人を知る\">職種と人を知る</a></li>\n\t\t\t\t\t<li><a href=\"../workspace/office.html\" title=\"環境・待遇を知る\">環境・待遇を知る</a></li>\n\t\t\t\t\t<li><a href=\"newgraduate.html\" title=\"新卒採用\" class=\"select\">新卒採用</a></li>\n\t\t\t\t\t<li><a href=\"career.html\" title=\"キャリア採用\">キャリア採用</a></li>\n\t\t\t\t</ul>\n\t\t\t</div>\n\t\t</div>\n\t</nav>\n\t<div id=\"contents\">\n\t\t<div class=\"inner\">\n\t\t\t<div class=\"side side--sticky\">\n\t\t\t\t<h1>新卒採用</h1>\n\t\t\t\t<ul>\n\t\t\t\t\t<li><a href=\"newgraduate.html#01\" title=\"2025新卒採用情報\">募集職種</a></li>\n\t\t\t\t\t<li><a href=\"newgraduate.html#02\" title=\"2025新卒採用情報\">給与</a></li>\n\t\t\t\t\t<li><a href=\"newgraduate.html#03\" title=\"2025新卒採用情報\">職種と勤務地</a></li>\n\t\t\t\t</ul>\n\t\t\t</div>\n\t\t\t<div class=\"area\">\n\t\t\t\t<h1>Recruit</h1>\n\t\t\t\t<h2><span>2027</span>新卒向け先輩社員座談会のご案内</h2>\n\t\t\t\t<p id=\"internship\">\n\t\t\t\t\t本選考につながる先輩社員座談会を開催しております！<br>\n\t\t\t\t\t詳しい内容と日程は下記よりご覧ください。<br>\n\t\t\t\t\t皆さんのご参加をお待ちしております！！\n\t\t\t\t</p>\n\t\t\t\t<div class=\"docswell\">\n\t\t\t\t\t<iframe src=\"https://www.docswell.com/slide/5MXD7E/embed?mode=extend&key=2025-06-06-160253\" scrolling=\"no\" allowfullscreen=\"true\"></iframe>\n\t\t\t\t</div>\n\t\t\t\t<br>\n\t\t\t\t<h2><span>2027</span>新卒採用情報</h2>\n\t\t\t\t<img src=\"../images/recruit/recruit2027.jpg\" width=\"700\" alt=\"わがまま採用\" class=\"img_kadoR\" />\n\t\t\t\t<h3 id=\"01\" class=\"heading04\">募集要項</h3>\n\t\t\t\t<table class=\"newgraduate\">\n\t\t\t\t\t<tbody>\n\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t<th>応募資格</th>\n\t\t\t\t\t\t\t<td>2027年3月に専門学校または大学を卒業見込みの学生、大学院を修了見込みの学生</td>\n\t\t\t\t\t\t</tr>\n\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t<th>採用予定人数</th>\n\t\t\t\t\t\t\t<td>10名程度</td>\n\t\t\t\t\t\t</tr>\n\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t<th>職種と仕事内容</th>\n\t\t\t\t\t\t\t<td>\n\t\t\t\t\t\t\t\t<h1>ITエンジニア職</h1>\n\t\t\t\t\t\t\t\t<p>自社ソフトウェア、クラウドシステムの設計から開発、テストまでを行う</p>\n\t\t\t\t\t\t\t\t<h1>QMエンジニア職</h1>\n\t\t\t\t\t\t\t\t<p>自社製品全般の設計・品質管理・テスト工程を専門に行う</p>\n\t\t\t\t\t\t\t\t<h1>セールス・マーケティング職</h1>\n\t\t\t\t\t\t\t\t<p>～コンサルティング営業～<br>セミナーや展示会、研修会の企画・運営を行ったり、<br>会計事務所や商工会を訪問し、販売促進の企画立案や提案を行う<br><br>～企画営業～<br>プロモーション企画の立案、販促物の企画や作成、売上実績の集計などを行う</p>\n\t\t\t\t\t\t\t</td>\n\t\t\t\t\t\t</tr>\n\t\t\t\t\t</tbody>\n\t\t\t\t</table>\n\t\t\t\t<h3 id=\"02\" class=\"heading04\">給与</h3>\n\t\t\t\t<table class=\"newgraduate\">\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<th colspan=\"2\">東京＜セールス・マーケティング職 -コンサルティング営業／企画営業＞</th>\n\t\t\t\t\t</tr>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<th>院卒</th>\n\t\t\t\t\t\t<td>362,600円（基本給268,000円＋ビジネス手当66,100円＋地域手当28,500円）</td>\n\t\t\t\t\t</tr>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<th>学部卒</th>\n\t\t\t\t\t\t<td>343,100円（基本給252,000円＋ビジネス手当62,600円＋地域手当28,500円）</td>\n\t\t\t\t\t</tr>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<th>専門卒（2年）・短卒</th>\n\t\t\t\t\t\t<td>330,800円（基本給242,000円＋ビジネス手当60,300円＋地域手当28,500円）</td>\n\t\t\t\t\t</tr>\n\t\t\t\t</table>\n\n\t\t\t\t<table class=\"newgraduate mb0\">\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<th colspan=\"2\">各営業所〈セールス・マーケティング職ーコンサルティング営業〉</th>\n\t\t\t\t\t</tr>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<th>院卒</th>\n\t\t\t\t\t\t<td>362,600円（基本給268,000円＋ビジネス手当66,100円＋※地域手当）</td>\n\t\t\t\t\t</tr>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<th>学部卒</th>\n\t\t\t\t\t\t<td>343,100円（基本給252,000円＋ビジネス手当62,600円＋※地域手当）</td>\n\t\t\t\t\t</tr>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<th>専門卒（2年）・短卒</th>\n\t\t\t\t\t\t<td>330,800円（基本給242,000円＋ビジネス手当60,300円＋※地域手当）</td>\n\t\t\t\t\t</tr>\n\t\t\t\t</table>\n\t\t\t\t<p>\n\t\t\t\t\t※地域手当は営業所ごとに異なります<br>\n\t\t\t\t\tさいたま営業所→28,500円、大阪営業所→22,000円、名古屋営業所→10,000円\n\t\t\t\t</p>\n\n\t\t\t\t<table class=\"newgraduate\">\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<th colspan=\"2\">東京＜ITエンジニア＞</th>\n\t\t\t\t\t</tr>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<th>院卒</th>\n\t\t\t\t\t\t<td>357,700円（基本給264,000円＋定額残業手当65,200円＋地域手当28,500円）</td>\n\t\t\t\t\t</tr>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<th>学部卒</th>\n\t\t\t\t\t\t<td>338,200円（基本給248,000円＋定額残業手当61,700円＋地域手当28,500円）</td>\n\t\t\t\t\t</tr>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<th>専門卒（2年）・短卒</th>\n\t\t\t\t\t\t<td>323,500円（基本給236,000円＋定額残業手当59,000円＋地域手当28,500円）</td>\n\t\t\t\t\t</tr>\n\t\t\t\t</table>\n\t\t\t\t<table class=\"newgraduate\">\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<th colspan=\"2\">長岡・新潟＜ITエンジニア・QMエンジニア＞</th>\n\t\t\t\t\t</tr>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<th>院卒</th>\n\t\t\t\t\t\t<td>322,900円（基本給264,000円＋定額残業手当58,900円）</td>\n\t\t\t\t\t</tr>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<th>学部卒</th>\n\t\t\t\t\t\t<td>303,300円（基本給248,000円＋定額残業手当55,300円）</td>\n\t\t\t\t\t</tr>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<th>専門卒（2年）・短卒</th>\n\t\t\t\t\t\t<td>288,600円（基本給236,000円＋定額残業手当52,600円）</td>\n\t\t\t\t\t</tr>\n\t\t\t\t</table>\n\t\t\t\t<p class=\"fw1\">福利厚生・待遇</p>\n\t\t\t\t<ul class=\"training\">\n\t\t\t\t\t<ul>\n\t\t\t\t\t\t<li>昇給年2回（8月・2月）</li>\n\t\t\t\t\t\t<li>賞与年2回（8月・1月）</li>\n\t\t\t\t\t\t<li>各種社会保険完備（雇用、労災、健康、厚生年金）</li>\n\t\t\t\t\t\t<li>通勤手当</li>\n\t\t\t\t\t\t<li>出張手当</li>\n\t\t\t\t\t\t<li>役職手当</li>\n\t\t\t\t\t\t<li>資格手当</li>\n\t\t\t\t\t\t<li>営業手当</li>\n\t\t\t\t\t\t<li>住宅手当（月2万5000円）</li>\n\t\t\t\t\t\t<li>報奨金制度</li>\n\t\t\t\t\t\t<li>社員持株会</li>\n\t\t\t\t\t\t<li>退職金制度</li>\n\t\t\t\t\t\t<li>出産・育児支援制度</li>\n\t\t\t\t\t\t<li>オフィス内禁煙</li>\n\t\t\t\t\t\t<li>会員制総合福利厚生サービス</li>\n\t\t\t\t\t</ul>\n\t\t\t\t</ul>\n\t\t\t\t<p class=\"fw1 marT30\">休日休暇</p>\n\t\t\t\t<ul class=\"training\">\n\t\t\t\t\t<li>完全週休2日制（土・日）</li>\n\t\t\t\t\t<li>祝日</li>\n\t\t\t\t\t<li>年末年始休暇</li>\n\t\t\t\t\t<li>特別休暇</li>\n\t\t\t\t\t<li>慶弔休暇</li>\n\t\t\t\t\t<li>産前・産後休暇</li>\n\t\t\t\t\t<li>育児休暇</li>\n\t\t\t\t\t<li>介護休暇</li>\n\t\t\t\t</ul>\n\t\t\t\t<h3 id=\"03\" class=\"heading04\">職種と勤務地</h3>\n\t\t\t\t<div class=\"scroll-table\">\n\t\t\t\t\t<table class=\"newgraduate mb0\">\n\t\t\t\t\t\t<tbody>\n\t\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t\t<th nowrap>職種</th>\n\t\t\t\t\t\t\t\t<th nowrap>東京本社</th>\n\t\t\t\t\t\t\t\t<th nowrap>新潟開発<br>センター</th>\n\t\t\t\t\t\t\t\t<th nowrap>長岡開発<br>センター</th>\n\t\t\t\t\t\t\t\t<th nowrap>各営業所</th>\n\t\t\t\t\t\t\t</tr>\n\t\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t\t<td>ITエンジニア職</td>\n\t\t\t\t\t\t\t\t<td class=\"txt_cent\">〇</td>\n\t\t\t\t\t\t\t\t<td class=\"txt_cent\">〇</td>\n\t\t\t\t\t\t\t\t<td class=\"txt_cent\">〇</td>\n\t\t\t\t\t\t\t\t<td>&nbsp;</td>\n\t\t\t\t\t\t\t</tr>\n\t\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t\t<td>QMエンジニア職</td>\n\t\t\t\t\t\t\t\t<td>&nbsp;</td>\n\t\t\t\t\t\t\t\t<td>&nbsp;</td>\n\t\t\t\t\t\t\t\t<td class=\"txt_cent\">〇</td>\n\t\t\t\t\t\t\t\t<td>&nbsp;</td>\n\t\t\t\t\t\t\t</tr>\n\t\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t\t<td>\n\t\t\t\t\t\t\t\t\tセールス・マーケティング職<br>\n\t\t\t\t\t\t\t\t\t（コンサルティング営業）\n\t\t\t\t\t\t\t\t</td>\n\t\t\t\t\t\t\t\t<td class=\"txt_cent\">〇</td>\n\t\t\t\t\t\t\t\t<td>&nbsp;</td>\n\t\t\t\t\t\t\t\t<td>&nbsp;</td>\n\t\t\t\t\t\t\t\t<td class=\"txt_cent\">〇</td>\n\t\t\t\t\t\t\t</tr>\n\t\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t\t<td>\n\t\t\t\t\t\t\t\t\tセールス・マーケティング職<br>\n\t\t\t\t\t\t\t\t\t（企画営業）\n\t\t\t\t\t\t\t\t</td>\n\t\t\t\t\t\t\t\t<td class=\"txt_cent\">〇</td>\n\t\t\t\t\t\t\t\t<td>&nbsp;</td>\n\t\t\t\t\t\t\t\t<td>&nbsp;</td>\n\t\t\t\t\t\t\t\t<td>&nbsp;</td>\n\t\t\t\t\t\t\t</tr>\n\t\t\t\t\t\t</tbody>\n\t\t\t\t\t</table>\n\t\t\t\t\t<p>\n\t\t\t\t\t\t※営業所（札幌、盛岡、さいたま、名古屋、大阪、広島、福岡、熊本）は募集を行わない<br>\n\t\t\t\t\t\t期間や募集が終了している場合があります。最新の状況はエントリー時に確認ください\n\t\t\t\t\t</p>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\t\t<div class=\"sns\">\n\t\t\t<a href=\"https://www.youtube.com/@sorimachi_recruit/videos\" target=\"_blank\" title=\"リクルートYoutube\"><img src=\"../images/recruit/recruit_sns_02.png\" alt=\"リクルートYoutube\"></a>\n\t\t\t<a href=\"https://www.instagram.com/sorimachi_recruit/\" target=\"_blank\" title=\"リクルートInstagram\"><img src=\"../images/recruit/recruit_sns_01.png\" alt=\"リクルートInstagram\"></a>\n\t\t</div>\n\t</div>\n\t<div class=\"entry-fixed\">\n\t\t<a href=\"https://forms.gle/RrrQZ4pNF1SSkVDp6\" target=\"_blank\" title=\"エントリーはこちら\">エントリーはこちら</a>\n\t\t<!-- <a href=\"https://ws.formzu.net/fgen/S17317580/\" target=\"_blank\" title=\"新卒採用申込み\">新卒採用申込み</a> -->\n\t</div>\n\t<div id=\"common_contact\">\n\t\t<footer>\n\t\t\t<div class=\"inner\"> &copy; Copyright Sorimachi Co.,Ltd. All rights reserved. </div>\n\t\t</footer>\n\t\t<div class=\"pagetop\"><a href=\"#\">▲</a></div>\n</body>\n\n</html>","finalUrl":"https://sorimachi.co.jp/about/recruit/recruit/newgraduate.html","rendered":false,"_cachedAt":"2026-06-23T23:07:02.585Z"}