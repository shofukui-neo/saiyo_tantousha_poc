{"url":"https://recruit.jops.co.jp/interview/staff-07/","html":"<!DOCTYPE html>\n<html lang=\"ja\" id=\"ja\">\n<head>\n<meta charset=\"utf-8\">\n\n<!-- meta -->\n<!-- 20251008-3 -->\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1, shrink-to-fit=no\">\n<meta name=\"author\" content=\"（株）日本オープンシステムズ\">\n<meta name=\"format-detection\" content=\"telephone=no\">\n\n<!-- CSS -->\n<link rel=\"stylesheet\" href=\"/common/css/style.css?20260619-1\">\n<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n<link href=\"https://fonts.googleapis.com/css2?\n\tfamily=Noto+Sans+JP:wght@100..900&\n\tfamily=Noto+Serif+JP:wght@200..900&\n\tfamily=M+PLUS+Rounded+1c&\n\tfamily=Lato:wght@100;300;400;700;900&\ndisplay=swap\" rel=\"stylesheet\">\n<script src=\"/common/js/bootstrap.bundle5.3.js\"></script>\n<script src=\"/common/js/common.js\"></script>\n<script src=\"/common/js/css_browser_selector.js\"></script>\n<script src=\"/common/js/anime.min.js\"></script>\n<script src=\"/common/js/animate/wow.js\"></script>\n<script src=\"https://cdnjs.cloudflare.com/ajax/libs/lottie-web/5.7.4/lottie.min.js\"></script>\n<script src=\"/common/js/scroll-hint.js\"></script>\n\n<link rel=\"stylesheet\" href=\"/common/js/splide/splide-core.min.css\">\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/glightbox/dist/css/glightbox.min.css\" />\n<link href=\"https://unpkg.com/aos@2.3.1/dist/aos.css\" rel=\"stylesheet\">\n<link rel=\"apple-touch-icon\" href=\"/common/images/parts/favicon.png\">\n<link rel=\"shortcut icon\" href=\"/common/images/parts/favicon.png\">\n<meta property=\"og:image\" content=\"/common/images/parts/favicon.png\">\n\n<!-- Google tag (gtag.js) -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-J2W1236FVP\"></script>\n<script>\n window.dataLayer = window.dataLayer || [];\n function gtag(){dataLayer.push(arguments);}\n gtag('js', new Date());\n\n gt