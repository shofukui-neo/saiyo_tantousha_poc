__item]-->\r\n                                    </ul>\r\n                                </div>\r\n                            </div>\r\n                        </li>\r\n\t\t\t\t\t\t<!-- [END li.lib-nav__item]-->\r\n\t\t\t\t\t\t<!-- [START li.lib-nav__item]-->\r\n\t\t\t\t\t\t<li class=\"lib-nav__item\"><a class=\"lib-nav__btn js-child__focus\" href=\"/recruit/\"><span\r\n\t\t\t\t\t\t\t\t\tclass=\"txt\">採用情報</span></a></li>\r\n\t\t\t\t\t\t<!-- [END li.lib-nav__item]-->\r\n\t\t\t\t\t</ul>\r\n\t\t\t\t\t<ul class=\"lib-induce__outer\">\r\n\t\t\t\t\t\t<li><a class=\"lib-induce__btn ico-before-mail bg-fill bg-main\" href=\"/contact/\"><span class=\"txt\">お問い合わせ</span></a></li>\r\n\t\t\t\t\t\t<li><a class=\"lib-induce__btn ico-before-dl bg-fill bg-accent\" href=\"/download/\"><span\r\n\t\t\t\t\t\t\t\t\tclass=\"txt\">資料ダウンロード</span></a></li>\r\n\t\t\t\t\t</ul>\r\n\t\t\t\t\t<!-- [END lib-induce__outer]-->\r\n\t\t\t\t</div>\r\n\t\t\t\t<!-- [END lib-nav__outer]-->\r\n\t\t\t</div>\r\n\t\t\t<!-- [END lib-nav__cover]-->\r\n\t\t</nav>\r\n\t\t<!-- [END lib-nav__panel]-->\r\n\t</div>\r\n\t<!-- [END lib-header__inner]-->\r\n</div>\r\n<!-- [END lib-header__outer]--></div></span>\n\r\n  <nav class=\"lib-breadcrumb__outer\" aria-label=\"Breadcrumbs\">\r\n    <div class=\"lib-breadcrumb__inside\">\r\n      <ol class=\"lib-breadcrumb__list\" itemscope itemtype=\"http://schema.org/BreadcrumbList\">\r\n      <li itemprop=\"itemListElement\" itemscope itemtype=\"http://schema.org/ListItem\"><a href=\"https://www.takayasu-rf.co.jp/\" itemprop=\"item\"><span itemprop=\"name\">HOME</span></a><meta itemprop=\"position\" content=\"1\" /></li><li itemprop=\"itemListElement\" itemscope itemtype=\"http://schema.org/ListItem\"><a href=\"https://www.takayasu-rf.co.jp/recruit/\" itemprop=\"item\" aria-current=\"location\"><span itemprop=\"name\">採用情報</span></a><meta itemprop=\"position\" content=\"2\" /></li>\r\n      </ol>\r\n    </div>\r\n  </nav>\r\n  \r\n  <main id=\"contents\">\r\n    <!-- ブロック貼り付けエリア -->\r\n    <div id=\"dcms_layoutPageBlockPasteArea\">\r\n    <!-- ブロック -->\r\n    <div id=\"dcms_layoutPageBlock\">\r\n    <div class=\"lib-hero__outer js-page-main\">\n<div class=\"lib-hero__txtarea wrap\">\n<div class=\"lib-hero__inner\">\n<h1 class=\"lib-hero__title title\">採用情報</h1>\n</div>\n</div>\n</div>\n<div class=\"container lib-wide__outer\" style=\"padding-right: unset;\">\n<div class=\"lib-cnt-028 lib-cnt-ride__outer --bottom\">\n<div class=\"lib-cnt-028__row row flex-column flex-lg-row gx-lg-5 d-flex\">\n<div class=\"lib-cnt-028__txtarea col-12 col-lg-9 col-xxl-8 d-flex\">\n<div class=\"lib-card__item bg-white\">\n<div class=\"lib-card__txtarea\">\n<div class=\"lib-card__inside\">\n<div class=\"lib-title__outer\">\n<h2 class=\"lib-card__title fs-h1\">「あえて中小企業に<br />就職するという選択」</h2>\n</div>\n<div class=\"lib-card__txt\">―それは意外と“通”な選択かもしれません。<br />大企業のネームバリューや安定感に惹かれがちですが、中小企業にはそれとは違う魅力がたっぷりあります。</div>\n<div class=\"lib-card__txt\">たとえば…</div>\n</div>\n</div>\n<!-- // lib-card__txtarea--></div>\n<!-- // lib-card__item--></div>\n<!-- // lib-cnt-028__txtarea-->\n<div class=\"lib-cnt-028__thumb col-12 col-lg-8 col-xxl-9\"><span class=\"thumb\"><img src=\"/dcms_media/image/recruit-img01.webp\" alt=\"「あえて中小企業に就職するという選択」\" width=\"500\" height=\"250\" loading=\"lazy\" /></span></div>\n<!-- // lib-cnt-028__thumb--></div>\n<!-- // lib-cnt-028__row--></div>\n<!-- // lib-cnt-028--></div>\n<div class=\"container\">\n<div class=\"row row-cols-1 row-cols-md-2 gy-4 gx-4\">\n<div class=\"col d-flex\">\n<div class=\"lib-card__item border-set\">\n<div class=\"lib-card__txtarea\">\n<div class=\"lib-card__inside\">\n<div class=\"lib-title__outer\">\n<h3 class=\"title tcenter fs-h4\">幅広い業務に携われる</h3>\n</div>\n<div class=\"lib-txt__outer\">\n<div class=\"lib-card__txt t-md-center\" style=\"text-align: left;\">大企業では業務が分業化されていることが多いですが、中小企業では一人が担う範囲が広いため、様々なスキルが身につきやすく、成長スピードも加速しやすいです。</div>\n</div>\n<!-- // lib-txt__outer--></div>\n<!-- // lib-card__inside--></div>\n<!-- // lib-card__txtarea--></div>\n<!-- // lib-card__item--></div>\n<!-- // col-->\n<div class=\"col d-flex\">\n<div class=\"lib-card__item border-set\">\n<div class=\"lib-card__txtarea\">\n<div class=\"lib-card__inside\">\n<div class=\"lib-title__outer\">\n<h3 class=\"title tcenter fs-h4\">経営層との距離が近い</h3>\n</div>\n<div class=\"lib-txt__outer\">\n<div class=\"lib-card__txt t-md-center\" style=\"text-align: left;\">トップの意思決定やビジョンを間近で感じられるのは貴重な体験です。自分の意見が経営に反映されるチャンスもあります。。</div>\n</div>\n<!-- // lib-txt__outer--></div>\n<!-- // lib-card__inside--></div>\n<!-- // lib-card__txtarea--></div>\n<!-- // lib-card__item--></div>\n<!-- // col--></div>\n</div>\n<div class=\"container --mdl\">\n<div class=\"row row-cols-1 row-cols-md-2 gy-4 gx-4\">\n<div class=\"col d-flex\">\n<div class=\"lib-card__item border-set\">\n<div class=\"lib-card__txtarea\">\n<div class=\"lib-card__inside\">\n<div class=\"lib-title__outer\">\n<h3 class=\"title tcenter fs-h4\">企業と一緒に成長できる</h3>\n</div>\n<div class=\"lib-txt__outer\">\n<div class=\"lib-card__txt t-md-center\" style=\"text-align: left;\">発展途上の企業なら、自分の活躍がそのまま会社の成長に直結する達成感があります。まさに「主役」として仕事ができる感覚。</div>\n</div>\n<!-- // lib-txt__outer--></div>\n<!-- // lib-card__inside--></div>\n<!-- // lib-card__txtarea--></div>\n<!-- // lib-card__item--></div>\n<!-- // col-->\n<div class=\"col d-flex\">\n<div class=\"lib-card__item border-set\">\n<div class=\"lib-card__txtarea\">\n<div class=\"lib-card__inside\">\n<div class=\"lib-title__outer\">\n<h3 class=\"title tcenter fs-h4\">風通しの良い職場環境</h3>\n</div>\n<div class=\"lib-txt__outer\">\n<div class=\"lib-card__txt t-md-center\" style=\"text-align: left;\">少人数ゆえのフラットな人間関係や、柔軟な働き方ができる風土も魅力です。</div>\n</div>\n<!-- // lib-txt__outer--></div>\n<!-- // lib-card__inside--></div>\n<!-- // lib-card__txtarea--></div>\n<!-- // lib-card__item--></div>\n<!-- // col--></div>\n</div>\n<div class=\"container --mdl\">\n<div class=\"row row-cols-1 row-cols-md-2 gy-4 gx-4\">\n<div class=\"col d-flex\">\n<div class=\"lib-card__item border-set\">\n<div class=\"lib-card__txtarea\">\n<div class=\"lib-card__inside\">\n<div class=\"lib-title__outer\">\n<h3 class=\"title tcenter fs-h4\">自分の「色」を出しやすい</h3>\n</div>\n<div class=\"lib-txt__outer\">\n<div class=\"lib-card__txt t-md-center\" style=\"text-align: left;\">制度や文化が固定化されていないぶん、イチ個人の工夫や提案が受け入れられやすく、やりがいを感じやすいです。「大きな船に乗る」か「小さな船を一緒につくる」か。どちらにも良さがありますが、中小企業を選ぶというのは、自分の影響力を強く実感したい人にとって、とても魅力的な選択肢です。</div>\n</div>\n<!-- // lib-txt__outer--></div>\n<!-- // lib-card__inside--></div>\n<!-- // lib-card__txtarea--></div>\n<!-- // lib-card__item--></div>\n<!-- // col--></div>\n</div>\n<div class=\"container\">\n<div class=\"lib-horizon__row row gy-4 gx-5 flex-column-reverse flex-md-row\">\n<div class=\"lib-horizon__col col-12 col-md-7 d-flex align-items-center\">\n<div class=\"lib-card__item\">\n<div class=\"lib-card__txtarea\">\n<div class=\"lib-card__inside\">\n<div class=\"lib-title__outer\">\n<h3 class=\"lib-card__title\">持続可能な未来を共に築きましょう</h3>\n</div>\n<div class=\"lib-card__txt\">私たちは、環境に配慮したリサイクル製品の製造を通じて、持続可能な未来を目指しています。<br />あなたの情熱とスキルを活かし、共に地球を守るための一歩を踏み出しませんか？</div>\n</div>\n<!-- // lib-card__inside--></div>\n<!-- // lib-card__txtarea--></div>\n<!-- // lib-card__item--></div>\n<!-- . col-->\n<div class=\"lib-horizon__col col-12 col-md-5 d-flex\"><span class=\"lib-card__thumb\"><img class=\"object-fit-cover\" src=\"/dcms_media/image/3R.webp\" alt=\"3R.webp\" width=\"700\" height=\"500\" loading=\"lazy\" /></span></div>\n<!-- . col--></div>\n<!-- .row--></div>\n<div class=\"container\">\n<div class=\"lib-card__item border-set bg-lgry\">\n<div class=\"lib-card__txtarea\">\n<div class=\"lib-card__inside\">\n<div class=\"lib-title__outer\">\n<h2 class=\"title tcenter\">求める人材像</h2>\n</div>\n<div class=\"lib-txt__outer\">\n<div class=\"lib-card__txt t-md-center\">経営理念は、「正直、親切、努力」です。<br /> モットーは、「事業を通じて社会に貢献すること」、<br /> そして「関わるすべての人々の幸福の増進に役立つこと」です。</div>\n</div>\n<!-- // lib-txt__outer--></div>\n<!-- // lib-card__inside--></div>\n<!-- // lib-card__txtarea--></div>\n<!-- // lib-card__item--></div>\n<div class=\"container --mdl lib-txt__outer  t-md-center\">\n<p>髙安の求める人物像に少しでも当てはまる方、共感できる方、ぜひ髙安と共に成長し、<br />より良い人物・より良い企業・より良い社会を目指していきましょう。</p>\n</div>\n<hr class=\"lib-separator --mdl\" />\n<div class=\"row row-cols-1 row-cols-lg-2 gy-5 gx-5 lib-cnt-002\">\n<div class=\"col d-flex\">\n<div class=\"lib-cnt-002__row row flex-column-reverse flex-md-row-reverse gy-3 flex-grow-1\">\n<div class=\"lib-cnt-002__col col-12 col-md-8 col-lg-8 d-flex\">\n<div class=\"lib-card__item\">\n<div class=\"lib-card__txtarea\">\n<div class=\"lib-card__inside\">\n<h3 class=\"lib-card__title\">正直、素直、誠実なひと</h3>\n<div class=\"lib-card__txt\">仕事の成果の追求は必要になりますが、自分の成果だけを追い求めず、周りの人をサポートしたり連携協力してより良い結果を出さなければなりません。</div>\n</div>\n<!-- // lib-card__inside--></div>\n<!-- // lib-card__txtarea--></div>\n<!-- // lib-card__item--></div>\n<div class=\"lib-cnt-001__col col-12 col-md-4 col-lg-4 tcenter lh-unset\"><span class=\"thumb\"><img class=\"max-100 max-md-unset\" src=\"/dcms_media/image/recruit-img02.webp\" alt=\"正直、素直、誠実なひと\" width=\"100\" height=\"100\" loading=\"lazy\" /></span></div>\n<!-- // .col--></div>\n<!-- // .row--></div>\n<!-- // .col-->\n<div class=\"col d-flex\">\n<div class=\"lib-cnt-002__row row flex-column-reverse flex-md-row-reverse gy-3 flex-grow-1\">\n<div class=\"lib-cnt-002__col col-12 col-md-8 col-lg-8 d-flex\">\n<div class=\"lib-card__item\">\n<div class=\"lib-card__txtarea\">\n<div class=\"lib-card__inside\">\n<h3 class=\"lib-card__title\">親切なひと</h3>\n<div class=\"lib-card__txt\">相手の立場になって物事を考えることができ、自分が同じ立場ならどう思うのか？を考えられる人です。思いやりがある人は、相手の気持ちを読み取るからこそベストな対応ができ、相手にとって迷惑とならない、心地よい対応が出来ます。</div>\n</div>\n<!-- // lib-card__inside--></div>\n<!-- // lib-card__txtarea--></div>\n<!-- // lib-card__item--></div>\n<div class=\"lib-cnt-001__col col-12 col-md-4 col-lg-4 tcenter lh-unset\"><span class=\"thumb\"><img class=\"max-100 max-md-unset\" src=\"/dcms_media/image/recruit-img03.webp\" alt=\"親切なひと\" width=\"100\" height=\"100\" loading=\"lazy\" /></span></div>\n<!-- // .col--></div>\n<!-- // .row--></div>\n<!-- // .col--></div>\n<hr class=\"lib-separator --min\" />\n<div class=\"row row-cols-1 row-cols-lg-2 gy-5 gx-5 lib-cnt-002\">\n<div class=\"col d-flex\">\n<div class=\"lib-cnt-002__row row flex-column-reverse flex-md-row-reverse gy-3 flex-grow-1\">\n<div class=\"lib-cnt-002__col col-12 col-md-8 col-lg-8 d-flex\">\n<div class=\"lib-card__item\">\n<div class=\"lib-card__txtarea\">\n<div class=\"lib-card__inside\">\n<h3 class=\"lib-card__title\">人を大切にできるひと</h3>\n<div class=\"lib-card__txt\">髙安は人を大事にします。「人に教えられ・人と協力し・人を育てていく」その中で、各部ともに繋がりを持ち、助け合い、多くの仕事を進めていかなければなりません。</div>\n</div>\n<!-- // lib-card__inside--></div>\n<!-- // lib-card__txtarea--></div>\n<!-- // lib-card__item--></div>\n<div class=\"lib-cnt-001__col col-12 col-md-4 col-lg-4 tcenter lh-unset\"><span class=\"thumb\"><img class=\"max-100 max-md-unset\" src=\"/dcms_media/image/recruit-img04.webp\" alt=\"努力を惜しまないひと（成長し続ける）\" width=\"100\" height=\"100\" loading=\"lazy\" /></span></div>\n<!-- // .col--></div>\n<!-- // .row--></div>\n<!-- // .col-->\n<div class=\"col d-flex\">\n<div class=\"lib-cnt-002__row row flex-column-reverse flex-md-row-reverse gy-3 flex-grow-1\">\n<div class=\"lib-cnt-002__col col-12 col-md-8 col-lg-8 d-flex\">\n<div class=\"lib-card__item\">\n<div class=\"lib-card__txtarea\">\n<div class=\"lib-card__inside\">\n<h3 class=\"lib-card__title\">社会に貢献する意欲があるひと</h3>\n<div class=\"lib-card__txt\">髙安はリサイクルの会社です。「新しい製品を開発すること」「売上げを伸ばすこと」「人員の確保」「働きやすい職場作り」など企業活動自体が社会貢献に繋がります。</div>\n</div>\n<!-- // lib-card__inside--></div>\n<!-- // lib-card__txtarea--></div>\n<!-- // lib-card__item--></div>\n<div class=\"lib-cnt-001__col col-12 col-md-4 col-lg-4 tcenter lh-unset\"><span class=\"thumb\"><img class=\"max-100 max-md-unset\" src=\"/dcms_media/image/recruit-img05.webp\" alt=\"社会に貢献する意欲があるひと\" width=\"100\" height=\"100\" loading=\"lazy\" /></span></div>\n<!-- // .col--></div>\n<!-- // .row--></div>\n<!-- // .col--></div>\n<hr class=\"lib-separator --min\" />\n<div class=\"row row-cols-1 row-cols-lg-2 gy-5 gx-5 lib-cnt-002\">\n<div class=\"col d-flex\">\n<div class=\"lib-cnt-002__row row flex-column-reverse flex-md-row-reverse gy-3 flex-grow-1\">\n<div class=\"lib-cnt-002__col col-12 col-md-8 col-lg-8 d-flex\">\n<div class=\"lib-card__item\">\n<div class=\"lib-card__txtarea\">\n<div class=\"lib-card__inside\">\n<h3 class=\"lib-card__title\">努力を惜しまないひと<br />（成長し続ける）</h3>\n<div class=\"lib-card__txt\">熱意・やる気をもって仕事に取り組める。そして「なにか1つでも負けないもの」「高い専門性」「独自のもの」などの個性を育てていけることを目指します。</div>\n</div>\n<!-- // lib-card__inside--></div>\n<!-- // lib-card__txtarea--></div>\n<!-- // lib-card__item--></div>\n<div class=\"lib-cnt-001__col col-12 col-md-4 col-lg-4 tcenter lh-unset\"><span class=\"thumb\"><img class=\"max-100 max-md-unset\" src=\"/dcms_media/image/recruit-img06.webp\" alt=\"人を大切にできるひと\" width=\"100\" height=\"100\" loading=\"lazy\" /></span></div>\n<!-- // .col--></div>\n<!-- // .row--></div>\n<!-- // .col--></div>\n<div class=\"container lib-wide__outer bg-lmain --fill pb-0\">\n<div class=\"lib-title__outer container --typeD\">\n<h2 class=\"title\">社員インタビュー</h2>\n</div>\n</div>\n<div style=\"text-align:center\"><iframe width=\"560\" height=\"315\" src=\"https://www.youtube.com/embed/2Zkr39bg0zo?si=N0S7M4SE5LAI-LI7&amp;wmode=opaque\" title=\"YouTube video player\" frameborder=\"0\" allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share\" referrerpolicy=\"strict-origin-when-cross-origin\" allowfullscreen=\"\"></iframe></div>\n<div class=\"container lib-wide__outer bg-lmain --fill pt-5 pb-5\">\n<div class=\"container lib-txt__outer\">\n<p>先輩社員から仕事の内容・やりがい・選んだ理由等をお伝えします。</p>\n</div>\n</div>\n<div class=\"container lib-wide__outer bg-lmain --fill pt-5\">\n<div class=\"container --mdl\">\n<div class=\"lib-grid__outer row row-cols-1 row-cols-md-2 row-cols-lg-4 gy-5 gx-md-3\">\n<div class=\"lib-grid__col col d-flex\">\n<div class=\"lib-card__item\">\n<div class=\"lib-card__txtarea\">\n<div class=\"lib-card__inside\">\n<h3 class=\"lib-card__title tcenter\">Shizuka</h3>\n<ul class=\"before-accent\">\n<li>所属部門：長繊維製造部</li>\n<li>名前：Shizuka</li>\n<li>職種：研究開発職</li>\n<li>入社：2019年</li>\n</ul>\n</div>\n<!-- // lib-card__inside-->\n<div class=\"lib-card__btn\"><a class=\"lib-link__btn\" href=\"/recruit/staff/staff28/\"><span class=\"txt\">詳細はこちら</span></a></div>\n<!-- // lib-card__btn--></div>\n<!-- // lib-card__txtarea--> <span class=\"lib-card__thumb\"><img src=\"/dcms_media/image/recruit-img-07.webp\" alt=\"Aさん\" width=\"350\" height=\"150\" loading=\"lazy\" /></span> <!-- // lib-card__thumb--></div>\n<!-- // lib-card__item--></div>\n<!-- . col-->\n<div class=\"lib-grid__col col d-flex\">\n<div class=\"lib-card__item\">\n<div class=\"lib-card__txtarea\">\n<div class=\"lib-card__inside\">\n<h3 class=\"lib-card__title tcenter\">Tatsuya</h3>\n<ul class=\"before-accent\">\n<li>所属部門：長繊維製造部</li>\n<li>名前：Tatsuya</li>\n<li>職種：工場保全職</li>\n<li>入社：2016年</li>\n</ul>\n</div>\n<!-- // lib-card__inside-->\n<div class=\"lib-card__btn\"><a class=\"lib-link__btn\" href=\"/recruit/staff/staff30/\"><span class=\"txt\">詳細はこちら</span></a></div>\n<!-- // lib-card__btn--></div>\n<!-- // lib-card__txtarea--> <span class=\"lib-card__thumb\"><img src=\"/dcms_media/image/recruit-img-08.webp\" alt=\"Bさん\" width=\"350\" height=\"150\" loading=\"lazy\" /></span> <!-- // lib-card__thumb--></div>\n<!-- // lib-card__item--></div>\n<!-- . col-->\n<div class=\"lib-grid__col col d-flex\">\n<div class=\"lib-card__item\">\n<div class=\"lib-card__txtarea\">\n<div class=\"lib-card__inside\">\n<h3 class=\"lib-card__title tcenter\">Keita</h3>\n<ul class=\"before-accent\">\n<li>所属部門：総務部</li>\n<li>名前：Keita</li>\n<li>職種：事務職（労務）</li>\n<li>入社：2023年</li>\n</ul>\n</div>\n<!-- // lib-card__inside-->\n<div class=\"lib-card__btn\"><a class=\"lib-link__btn\" href=\"/recruit/staff/staff32/\"><span class=\"txt\">詳細はこちら</span></a></div>\n<!-- // lib-card__btn--></div>\n<!-- // lib-card__txtarea--> <span class=\"lib-card__thumb\"><img src=\"/dcms_media/image/recruit-img-09.webp\" alt=\"Cさん\" width=\"350\" height=\"150\" loading=\"lazy\" /></span> <!-- // lib-card__thumb--></div>\n<!-- // lib-card__item--></div>\n<!-- . col-->\n<div class=\"lib-grid__col col d-flex\">\n<div class=\"lib-card__item\">\n<div class=\"lib-card__txtarea\">\n<div class=\"lib-card__inside\">\n<h3 class=\"lib-card__title tcenter\">Ayano</h3>\n<ul class=\"before-accent\">\n<li>所属部門：総務部</li>\n<li>名前：Ayano</li>\n<li>職種：事務職（経理）</li>\n<li>入社：2016年</li>\n</ul>\n</div>\n<!-- // lib-card__inside-->\n<div class=\"lib-card__btn\"><a class=\"lib-link__btn\" href=\"/recruit/staff/2019staff01/\"><span class=\"txt\">詳細はこちら</span></a></div>\n<!-- // lib-card__btn--></div>\n<!-- // lib-card__txtarea--> <span class=\"lib-card__thumb\"><img src=\"/dcms_media/image/recruit-img-10.webp\" alt=\"Dさん\" width=\"350\" height=\"150\" loading=\"lazy\" /></span> <!-- // lib-card__thumb--></div>\n<!-- // lib-card__item--></div>\n<!-- . col--></div>\n</div>\n</div>\n<div class=\"lib-title__outer container --typeD\">\n<h2 class=\"title\">福利厚生</h2>\n</div>\n<div class=\"container\">\n<div class=\"row row-cols-1 row-cols-md-2 gy-4 gx-4\">\n<div class=\"col d-flex\">\n<div class=\"lib-card__item border-set\">\n<div class=\"lib-card__txtarea\">\n<div class=\"lib-card__inside\">\n<div class=\"lib-title__outer\">\n<h3 class=\"title tcenter fs-h4\">時間単位有給制度あり</h3>\n</div>\n<div class=\"lib-txt__outer\">\n<div class=\"lib-card__txt t-md-center\" style=\"text-align: left;\">通常の有給休暇はもちろん、半日や時間単位で取得できるので柔軟な働き方が可能です。</div>\n</div>\n<!-- // lib-txt__outer--></div>\n<!-- // lib-card__inside--></div>\n<!-- // lib-card__txtarea--></div>\n<!-- // lib-card__item--></div>\n<!-- // col-->\n<div class=\"col d-flex\">\n<div class=\"lib-card__item border-set\">\n<div class=\"lib-card__txtarea\">\n<div class=\"lib-card__inside\">\n<div class=\"lib-title__outer\">\n<h3 class=\"title tcenter fs-h4\">各種社会保険</h3>\n</div>\n<div class=\"lib-txt__outer\">\n<div class=\"lib-card__txt t-md-center\" style=\"text-align: left;\">（健康保険、厚生年金保険、雇用保険、労災保険）、財形貯蓄、慰安旅行、退職金制度あり。</div>\n</div>\n<!-- // lib-txt__outer--></div>\n<!-- // lib-card__inside--></div>\n<!-- // lib-card__txtarea--></div>\n<!-- // lib-card__item--></div>\n<!-- // col--></div>\n</div>\n<div class=\"container --mdl\">\n<div class=\"row row-cols-1 row-cols-md-2 gy-4 gx-4\">\n<div class=\"col d-flex\">\n<div class=\"lib-card__item border-set\">\n<div class=\"lib-card__txtarea\">\n<div class=\"lib-card__inside\">\n<div class=\"lib-title__outer\">\n<h3 class=\"title tcenter fs-h4\">研修制度</h3>\n</div>\n<div class=\"lib-txt__outer\">\n<div class=\"lib-card__txt t-md-center\" style=\"text-align: left;\">新人研修では、ビジネスマナーとして名刺交換・電話来客対応等を習得、会社の規則の説明や伝票の書き方、各部の仕事内容や役割を学びます。</div>\n</div>\n<!-- // lib-txt__outer--></div>\n<!-- // lib-card__inside--></div>\n<!-- // lib-card__txtarea--></div>\n<!-- // lib-card__item--></div>\n<!-- // col-->\n<div class=\"col d-flex\">\n<div class=\"lib-card__item border-set\">\n<div class=\"lib-card__txtarea\">\n<div class=\"lib-card__inside\">\n<div class=\"lib-title__outer\">\n<h3 class=\"title tcenter fs-h4\">自己啓発支援制度</h3>\n</div>\n<div class=\"lib-txt__outer\">\n<div class=\"lib-card__txt t-md-center\" style=\"text-align: left;\">業務に資すると会社が認めた資格を取得し、それに関連する業務に従事する社員に取得費用補助と資格手当を支給します。</div>\n</div>\n<!-- // lib-txt__outer--></div>\n<!-- // lib-card__inside--></div>\n<!-- // lib-card__txtarea--></div>\n<!-- // lib-card__item--></div>\n<!-- // col--></div>\n</div>\n<div class=\"container --mdl\">\n<div class=\"row row-cols-1 row-cols-md-2 gy-4 gx-4\">\n<div class=\"col d-flex\">\n<div class=\"lib-card__item border-set\">\n<div class=\"lib-card__txtarea\">\n<div class=\"lib-card__inside\">\n<div class=\"lib-title__outer\">\n<h3 class=\"title tcenter fs-h4\">改善提案制度</h3>\n</div>\n<div class=\"lib-txt__outer\">\n<div class=\"lib-card__txt t-md-center\" style=\"text-align: left;\">提案をすれば金一封。さらに採用されれば内容により賞金額が大きく。</div>\n</div>\n<!-- // lib-txt__outer--></div>\n<!-- // lib-card__inside--></div>\n<!-- // lib-card__txtarea--></div>\n<!-- // lib-card__item--></div>\n<!-- // col--></div>\n</div>\n<div class=\"container\">\n<div class=\"lib-card__item border-set bg-lmain\">\n<div class=\"lib-card__txtarea\">\n<div class=\"lib-card__inside\">\n<div class=\"lib-title__outer\">\n<h2 class=\"title tcenter\">募集要項</h2>\n</div>\n<div class=\"lib-txt__outer\">\n<div class=\"lib-card__txt t-md-center\" style=\"text-align: left;\">募集職種・仕事内容・勤務地・勤務時間・応募資格・給料など掲載しています。 また、エントリーから内定までの流れについても こちらに 掲載しています。</div>\n</div>\n<!-- // lib-txt__outer--></div>\n<!-- // lib-card__inside-->\n<div class=\"lib-card__btn tcenter\"><a class=\"lib-link__btn\" href=\"/recruit/new-graduate-requirements/\"><span class=\"txt\">詳しく見る（新卒採用）</span></a></div>\n<div class=\"lib-card__btn tcenter\"><a class=\"lib-link__btn\" href=\"/recruit/mid-career-requirements/\"><span class=\"txt\">詳しく見る（中途採用）</span></a></div>\n<!-- // lib-card__btn--></div>\n<!-- // lib-card__txtarea--></div>\n<!-- // lib-card__item--></div>\n<div class=\"container lib-wide__outer bg-lgry --fill pb-0\">\n<div class=\"lib-title__outer container --typeD\">\n<h2 class=\"title\">エントリー</h2>\n</div>\n</div>\n<div class=\"container lib-wide__outer bg-lgry --fill pt-5\">\n<div class=\"container --mdl\">\n<div class=\"lib-grid__outer row row-cols-1 row-cols-md-2 gy-5 gx-lg-5\">\n<div class=\"lib-grid__col col d-flex\">\n<div class=\"lib-card__item bg-shadow\">\n<div class=\"lib-card__txtarea\">\n<div class=\"lib-card__inside\">\n<h3 class=\"lib-card__title tcenter\">採用エントリー</h3>\n<div class=\"lib-card__txt\">高安株式会社では、新たに共に働く社員を募集しています。ご希望の方はこちらのエントリーフォームより申し込みをお願いします。<br /><br /></div>\n</div>\n<!-- // lib-card__inside-->\n<div class=\"lib-card__btn\"><a class=\"lib-link__btn\" href=\"/recruit/entry/\"><span class=\"txt\">エントリーはこちら</span></a></div>\n<!-- // lib-card__btn--></div>\n<!-- // lib-card__txtarea--> <span class=\"lib-card__thumb\"><img src=\"/d