"/\" property=\"item\" typeof=\"WebPage\"><span property=\"name\">гғӣгғјгғ </span></a>\r\n\t\t\t\t\t</li>\r\n\t\t\t\t\t<li class=\"c-breadcrumb__item\" property=\"itemListElement\" typeof=\"ListItem\">\r\n\t\t\t\t\t\t<meta property=\"position\" content=\"2\"><a class=\"c-breadcrumb__item-link\" href=\"/recruit/\" property=\"item\" typeof=\"WebPage\"><span property=\"name\">жҺЎз”Ёжғ…е ұ</span></a>\r\n\t\t\t\t\t</li>\r\n\t\t\t\t\t<li class=\"c-breadcrumb__item\" property=\"itemListElement\" typeof=\"ListItem\">\r\n\t\t\t\t\t\t<meta property=\"position\" content=\"3\"><span property=\"name\">зӨҫе“ЎгӮӨгғігӮҝгғ“гғҘгғјпјҲжҠҖиЎ“пјү</span>\r\n\t\t\t\t\t</li>\r\n\t\t\t\t</ol>\r\n\t\t\t</div>\r\n\t\t\t<div class=\"l-content\">\r\n\t\t\t\t<div class=\"c-wrapper\">\r\n\t\t\t\t\t<h1 class=\"c-headline-lv2\">зӨҫе“ЎгӮӨгғігӮҝгғ“гғҘгғј</h1>\r\n\t\t\t\t</div>\r\n\t\t\t\t<div class=\"c-spacers\">\r\n\t\t\t\t\t<section class=\"c-spacer-xl\">\r\n\t\t\t\t\t\t<div class=\"kv\">\r\n\t\t\t\t\t\t\t<div class=\"c-wrapper\">\r\n\t\t\t\t\t\t\t\t<div class=\"kv__inner\">\r\n\t\t\t\t\t\t\t\t\t<div class=\"kv__img\">\r\n\t\t\t\t\t\t\t\t\t\t<img class=\"lazyload\" src=\"data:image/gif;base64,R0lGODlhAQABAGAAACH5BAEKAP8ALAAAAAABAAEAAAgEAP8FBAA7\" data-width=\"1000\" data-height=\"500\" data-src=\"/assets/img/recruit/voice_03/kv_img.jpg\" alt=\"\" />\r\n\t\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t\t<div class=\"kv__body\">\r\n\t\t\t\t\t\t\t\t\t\t<div class=\"kv__body-inner\">\r\n\t\t\t\t\t\t\t\t\t\t\t<p class=\"kv__copy\">гғҷгӮ№гғҲгӮ’е°ҪгҒҸгҒ—гҒҰгҒҠе®ўж§ҳгӮ’з¬‘йЎ”гҒ«</p>\r\n\t\t\t\t\t\t\t\t\t\t\t<p><span class=\"kv__sub-title\">зҶҠжң¬ж”ҜзӨҫдҫӣзөҰжҠҖиЎ“иӘІ</span><span class=\"kv__title\">е№із”° ејҳд№ҹ<span class=\"kv__title-sub\">пјҲ2014е№ҙе…ҘзӨҫпјү</span></span></p>\r\n\t\t\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t</section>\r\n\t\t\t\t\t<section class=\"c-spacer-xl\">\r\n\t\t\t\t\t\t<div class=\"c-wrapper\">\r\n\t\t\t\t\t\t\t<div class=\"c-spacers\">\r\n\t\t\t\t\t\t\t\t<div class=\"c-spacer-lg--fat\">\r\n\t\t\t\t\t\t\t\t\t<div class=\"c-col-2\">\r\n\t\t\t\t\t\t\t\t\t\t<div class=\"c-grid-row\">\r\n\t\t\t\t\t\t\t\t\t\t\t<div class=\"c-grid-col-6 c-grid-col-sp-12\">\r\n\t\t\t\t\t\t\t\t\t\t\t\t<h3 class=\"c-headline-lv3\">д»•дәӢгҒ®еҶ…е®№гҒЁгӮ„гӮҠгҒҢгҒ„гҒ«гҒӨгҒ„гҒҰ<br>ж•ҷгҒҲгҒҰгҒҸгҒ гҒ•гҒ„</h3>\r\n\t\t\t\t\t\t\t\t\t\t\t\t<p>гҒҠе®ўж§ҳгҒ«гҖҒе®үеҝғгҒ—гҒҰе®үе®ҡзҡ„гҒ«гӮ¬гӮ№гӮ’дҪҝз”ЁгҒ—гҒҰгҒ„гҒҹгҒ гҒ‘гӮӢгӮҲгҒҶгҖҒдҫӣзөҰиЁӯеӮҷгҒ®гғЎгғігғҶгғҠгғігӮ№гӮ„иЈңдҝ®гғ»ж”№е–„гҒҜгӮӮгҒЎгӮҚгӮ“гҒ®гҒ“гҒЁгҖҒж–°гҒ—гҒ„иЁӯеӮҷиЁӯзҪ®гҒ®гҒҹгӮҒжҸҗжЎҲгғ»з©Қз®—гғ»иЁӯиЁҲгғ»ж–Ҫе·Ҙз®ЎзҗҶгҒӘгҒ©гҒ®жҘӯеӢҷгӮ’иЎҢгҒЈгҒҰгҒ„гҒҫгҒҷгҖӮ<br>\r\n\t\t\t\t\t\t\t\t\t\t\t\tиҮӘеҲҶиҮӘиә«гҒ®иЁӯиЁҲгҒ—гҒҹиЁӯеӮҷгҒҢеҪўгҒ«гҒӘгҒЈгҒҰгҖҒгҒ•гӮүгҒ«гҖҒгҒқгҒ®иЁӯеӮҷгҒҢгҒҠе®ўж§ҳгҒ«жәҖи¶ігҒ„гҒҹгҒ гҒ‘гҒҹгҒЁгҒҚгҖҒеӨ§гҒҚгҒӘгҖҢгӮ„гӮҠгҒҢгҒ„гҖҚгӮ’ж„ҹгҒҳгҒҫгҒҷгҖӮгҒқгҒ®гҒҹгӮҒгҒ«гҒҜгҖҒгӮ¬гӮ№гӮ„дҫӣзөҰиЁӯеӮҷгҒ«й–ўгҒҷгӮӢзҹҘиӯҳгҒ гҒ‘гҒ§гҒӘгҒҸгҖҒгҒҠе®ўж§ҳгҒ®ж¶ҲиІ»ж©ҹеҷЁгғ»гҒқгҒ®дҪҝз”Ёж–№жі•гҒӘгҒ©гӮӮи©ізҙ°гҒ«зҹҘгӮӢеҝ…иҰҒгҒҢгҒӮгӮҠгҒҫгҒҷгҖӮгҒқгӮҢгӮүгӮ’иӘҝжҹ»гғ»жӨңиЁҺгҒ—гҒҰгҒ„гҒҸгҒ“гҒЁгҒҜйқһеёёгҒ«еӨ§еӨүгҒӘгҒ“гҒЁгҒ§гҒҷгҒҢгҖҒгғҷгӮ№гғҲгӮ’е°ҪгҒҸгҒ—гҒҰеҜҫеҝңгҒ—гҒҰгҒ„гҒҸгҒ“гҒЁгҒ“гҒқгҒҠе®ўж§ҳгҒ®з¬‘йЎ”гҒ«з№ӢгҒҢгӮӢгҒЁдҝЎгҒҳгҒҰгҒ„гҒҫгҒҷгҖӮ</p>\r\n\t\t\t\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t\t\t\t<div class=\"c-grid-col-6 c-grid-col-sp-12\">\r\n\t\t\t\t\t\t\t\t\t\t\t<img class=\"lazyload\" src=\"data:image/gif;base64,R0lGODlhAQABAGAAACH5BAEKAP8ALAAAAAABAAEAAAgEAP8FBAA7\" data-width=\"480\" data-height=\"288\" data-src=\"/assets/img/recruit/voice_03/flow_img01.jpg\" alt=\"гӮӨгғЎгғјгӮёеҶҷзңҹпјҡзӨҫе“ЎгҒӢгӮүиҰӢгҒҹзҰҸеІЎй…ёзҙ гҒҜпјҹ\" />\r\n\t\t\t\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t<div class=\"c-spacer-lg--fat\">\r\n\t\t\t\t\t\t\t\t\t<div class=\"c-col-2\">\r\n\t\t\t\t\t\t\t\t\t\t<div class=\"c-grid-row -row-reverse-pc\">\r\n\t\t\t\t\t\t\t\t\t\t\t<div class=\"c-grid-col-6 c-grid-col-sp-12\">\r\n\t\t\t\t\t\t\t\t\t\t\t\t<h3 class=\"c-headline-lv3\">е…ҘзӨҫгҒ®гҒҚгҒЈгҒӢгҒ‘гҒҜпјҹ</h3>\r\n\t\t\t\t\t\t\t\t\t\t\t\t<p>ең°еҹҹгҒ«ж №д»ҳгҒ„гҒҹдјҒжҘӯгҒ§еғҚгҒҚгҒҹгҒ„гҖҒгҒқгӮ“гҒӘжғігҒ„гҒ§е°ұжҙ»гӮ’иЎҢгҒЈгҒҰгҒ„гҒҫгҒ—гҒҹгҖӮ<br>\r\n\t\t\t\t\t\t\t\t\t\t\t\tгҖҢзҰҸеІЎй…ёзҙ ж ӘејҸдјҡзӨҫгҖҚгҒЁгҒ„гҒҶдјҒжҘӯгҒҜгҖҒй•·гҒ„е№ҙжңҲгҒ«гҒҠгҒ„гҒҰгҖҒд№қе·һе…ЁеҹҹгҒ§еҗ„еҲҶйҮҺгҒ®дјҒжҘӯгҒ®ж”ҜгҒҲгҒЁгҒӘгӮҠгҖҒең°еҹҹзӨҫдјҡгҒ®зҷәеұ•гҒ«иІўзҢ®гҒ—гҒҰгҒҚгҒҫгҒ—гҒҹгҖӮгҒқгӮ“гҒӘдјҡзӨҫгҒ®еңЁгӮҠж–№гҒ«ж„ҹйҠҳгӮ’еҸ—гҒ‘гҖҒе…ҘзӨҫгӮ’жұәеҝғгҒ—гҒҫгҒ—гҒҹгҖӮ</p>\r\n\t\t\t\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t\t\t\t<div class=\"c-grid-col-6 c-grid-col-sp-12\">\r\n\t\t\t\t\t\t\t\t\t\t\t\t<img class=\"lazyload\" src=\"data:image/gif;base64,R0lGODlhAQABAGAAACH5BAEKAP8ALAAAAAABAAEAAAgEAP8FBAA7\" data-width=\"480\" data-height=\"288\" data-src=\"/assets/img/recruit/voice_03/flow_img02.jpg\" alt=\"гӮӨгғЎгғјгӮёеҶҷзңҹпјҡеҝ—жңӣеӢ•ж©ҹгҒҜпјҹ\" />\r\n\t\t\t\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t</section>\r\n\t\t\t\t\t<div class=\"c-spacer-xl\">\r\n\t\t\t\t\t\t<div class=\"c-wrapper\">\r\n\t\t\t\t\t\t\t<div class=\"message\">\r\n\t\t\t\t\t\t\t\t<div class=\"message__head\">\r\n\t\t\t\t\t\t\t\t\t<div class=\"message__copy\">\r\n\t\t\t\t\t\t\t\t\t\t<p>е°ұжҙ»дёӯгҒ®еӯҰз”ҹгҒ•гӮ“гҒёгғЎгғғгӮ»гғјгӮё</p>\r\n\t\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t\t<div class=\"message__img\">\r\n\t\t\t\t\t\t\t\t\t\t<img class=\"lazyload\" src=\"data:image/gif;base64,R0lGODlhAQABAGAAACH5BAEKAP8ALAAAAAABAAEAAAgEAP8FBAA7\" data-width=\"300\" data-height=\"180\" data-src=\"/assets/img/recruit/voice_03/message_img.jpg\" alt=\"гӮӨгғЎгғјгӮёеҶҷзңҹпјҡе…ҘзӨҫеёҢжңӣгҒ®ж–№гҒёгҒ®гғЎгғғгӮ»гғјгӮё\" />\r\n\t\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t<div class=\"message__body\">\r\n\t\t\t\t\t\t\t\t\t<div class=\"message__text\">\r\n\t\t\t\t\t\t\t\t\t\t<p>дјҒжҘӯгҒЁгҒҜгҖҒеҗҢгҒҳзӣ®жЁҷгҒ«еҗ‘гҒӢгҒЈгҒҰеҠӣгӮ’е°ҪгҒҸгҒ—гҖҒеҲҮзЈӢзҗўзЈЁгҒ—гҖҒгӮҜгғ©гӮӨгӮўгғігғҲгҒ«жәҖи¶ігҒ„гҒҹгҒ гҒҸгҒ“гҒЁгҒ§еҲ©зӣҠгӮ’з”ҹгҒҝз¶ҡгҒ‘гӮӢгғ—гғӯйӣҶеӣЈгҒ§гҒҷгҖӮгӮӮгҒ—гӮӮгҖҒзӣ®жҢҮгҒҷзӣ®жЁҷгӮ’е…ұжңүгҒ§гҒҚгӮӢгҒ®гҒ§гҒӮгӮҢгҒ°гҖҒжҳҜйқһгҒЁгӮӮеҪ“зӨҫгҒ§е…ұгҒ«жҲҗй•·гҒ—гҒҰгҒ„гҒ‘гӮҢгҒ°е№ёгҒ„гҒ§гҒҷгҖӮгҒҫгҒҹгҖҒзҡҶгҒ•гӮ“гҒҢгҖҒеҝғгҒӢгӮүдёҖз·’гҒ«жӯ©гҒҝгҒҹгҒ„гҒЁжҖқгҒҲгӮӢдјҒжҘӯгҒЁеҮәдјҡгҒҲгӮӢгҒ“гҒЁгӮ’йЎҳгҒЈгҒҰгҒ„гҒҫгҒҷгҖӮ</p>\r\n\t\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t</div>\r\n\t\t\t\t\t<div class=\"c-spacer-xl\">\r\n\t\t\t\t\t\t<div class=\"c-block-xl c-bg-bluetone03\">\r\n\t\t\t\t\t\t\t<div class=\"c-wrapper\">\r\n\t\t\t\t\t\t\t\t<div class=\"schedule\">\r\n\t\t\t\t\t\t\t\t\t<h3 class=\"schedule__headline\"><span class=\"schedule__headline-inner\">1ж—ҘгҒ®гӮ№гӮұгӮёгғҘгғјгғ«</span></h3>\r\n\t\t\t\t\t\t\t\t\t<div class=\"schedule__content\">\r\n\t\t\t\t\t\t\t\t\t\t<div class=\"schedule__timeline\">\r\n\t\t\t\t\t\t\t\t\t\t\t<ul class=\"schedule__timeline-items\">\r\n\t\t\t\t\t\t\t\t\t\t\t\t<li class=\"schedule__timeline-item\">\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t<div class=\"schedule__timeline-item-head\">\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t<p class=\"schedule__timeline-item-time\">8:00</p>\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t<div class=\"schedule__timeline-item-body\">\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t<h4 class=\"schedule__timeline-item-title\">еҮәзӨҫ</h4>\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t<div class=\"schedule__timeline-item-text\">\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<p>гӮігғјгғ’гғјгӮ’ж·№гӮҢгҒҰгҖҒPCгҒЁдёҖз·’гҒ«иҮӘеҲҶиҮӘиә«гӮ’иө·еӢ•гҖӮ<br>жң¬ж—ҘгҒ®гӮ№гӮұгӮёгғҘгғјгғ«гӮ’еҶҚзўәиӘҚгҖӮ</p>\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t\t\t\t\t</li>\r\n\t\t\t\t\t\t\t\t\t\t\t\t<li class=\"schedule__timeline-item\">\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t<div class=\"schedule__timeline-item-head\">\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t<p class=\"schedule__timeline-item-time\">8:30</p>\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t<div class=\"schedule__timeline-item-body\">\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t<h4 class=\"schedule__timeline-item-title\">гғҹгғјгғҶгӮЈгғігӮ°</h4>\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t<div class=\"schedule__timeline-item-text\">\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<p>жң¬ж—ҘгҒ®дәҲе®ҡгӮ’дёҠеҸёгҒёе ұе‘ҠгҖӮ<br>е…ЁдҪ“гҒ®еӢ•гҒҚгҒ«еҗҲгӮҸгҒӣгҒҰгӮ№гӮұгӮёгғҘгғјгғ«гӮ’жңҖзөӮиӘҝж•ҙгҖӮ</p>\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t\t\t\t\t</li>\r\n\t\t\t\t\t\t\t\t\t\t\t\t<li class=\"schedule__timeline-item\">\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t<div class=\"schedule__timeline-item-head\">\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t<p class=\"schedule__timeline-item-time\">10:00</p>\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t<div class=\"schedule__timeline-item-body\">\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t<h4 class=\"schedule__timeline-item-title\">е®ўе…ҲиЁӘе•Ҹ</h4>\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t<div class=\"schedule__timeline-item-text\">\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<p>гҒҠе®ўж§ҳгҒ®е·Ҙе ҙгӮ’иЁӘе•ҸгҖӮе®ҹж–ҪдәҲе®ҡгҒ®е·ҘдәӢеҶ…е®№гӮ’еҶҚзўәиӘҚгғ»и©ізҙ°гӮ’зҸҫе ҙгҒ§жү“гҒЎеҗҲгӮҸгҒӣгҖӮ</p>\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t\t\t\t\t</li>\r\n\t\t\t\t\t\t\t\t\t\t\t\t<li class=\"schedule__timeline-item\">\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t<div class=\"schedule__timeline-item-head\">\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t<p class=\"schedule__timeline-item-time\">12:00</p>\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t<div class=\"schedule__timeline-item-body\">\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t<h4 class=\"schedule__timeline-item-title\">гғ©гғігғҒ</h4>\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t<div class=\"schedule__timeline-item-text\">\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<p>гҒ„гҒӨгӮӮгҒ®е®ҡйЈҹеұӢгҒ§е”җжҸҡгҒ’е®ҡйЈҹпјҲгҒ”йЈҜеӨ§зӣӣгӮҠпјүгӮ’е®ҢйЈҹеҫҢгҖҒе°‘гҒ—дј‘жҶ©гҒ—гҒҫгҒҷгҖӮ</p>\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t\t\t\t\t</li>\r\n\t\t\t\t\t\t\t\t\t\t\t\t<li class=\"schedule__timeline-item\">\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t<div class=\"schedule__timeline-item-head\">\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t<p class=\"schedule__timeline-item-time\">13:00</p>\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t<div class=\"schedule__timeline-item-body\">\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t<h4 class=\"schedule__timeline-item-title\">иЁӯиЁҲ</h4>\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t<div class=\"schedule__timeline-item-text\">\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<p>гҒҠе®ўж§ҳгҒ®иҰҒжңӣгҒ«еҝңгҒҲгӮӢгӮҲгҒҶгҒӘиЁӯеӮҷгӮ’иЁӯиЁҲгҖӮ<br>CADгӮ’дҪҝгҒЈгҒҰгҖҒеӣійқўгӮ’дҪңжҲҗгҒ—гҒҰгҒ„гҒҚгҒҫгҒҷгҖӮ</p>\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t\t\t\t\t</li>\r\n\t\t\t\t\t\t\t\t\t\t\t\t<li class=\"schedule__timeline-item\">\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t<div class=\"schedule__timeline-item-head\">\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t<p class=\"schedule__timeline-item-time\">15:00</p>\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t<div class=\"schedule__timeline-item-body\">\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t<h4 class=\"schedule__timeline-item-title\">гҒҠе•ҸгҒ„еҗҲгӮҸгҒӣеҜҫеҝң</h4>\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t<div class=\"schedule__timeline-item-text\">\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<p>йӣ»и©ұгҒ«гҒҰгҖҒгҒҠе®ўж§ҳгҒӢгӮүгҒ®гҒҠе•ҸгҒ„еҗҲгӮҸгҒӣгҒ«еҜҫеҝңгҒ—гҒҫгҒҷгҖӮ<br>\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\tиЁӯеӮҷгҒ«гҒӨгҒ„гҒҰгҒ®дёҚе®үгғ»з–‘е•ҸзӯүгҒ«еҜҫгҒ—гҒҰгҖҒйҒ©еҲҮгҒӘиӘ¬жҳҺгӮ„гӮўгғүгғҗгӮӨгӮ№гӮ’иЎҢгҒ„е®үеҝғгӮ’жҸҗдҫӣгҒ—гҒҫгҒҷгҖӮ</p>\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t\t\t\t\t</li>\r\n\t\t\t\t\t\t\t\t\t\t\t\t<li class=\"schedule__timeline-item\">\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t<div class=\"schedule__timeline-item-head\">\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t<p class=\"schedule__timeline-item-time\">16:00</p>\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t<div class=\"schedule__timeline-item-body\">\r\n\t\t\t