ider__body\">\n        <p class=\"p-slider__job\">海外営業総括部</p>\n        <p class=\"p-slider__name\">S . M</p>\n      </div>\n      <buttom class=\"c-button p-slider__button\">View more</buttom>\n    </a>\n  </div>\n  <div class=\"p-slider__item swiper-slide\">\n    <a class=\"p-slider__link\" href=\"/newgraduates/interview06/\">\n      <figure class=\"p-slider__img-wrapper\">\n        <div class=\"p-slider__img-mask\">\n          <img class=\"p-slider__img\" src=\"/assets/images/interview/newgraduates06_slider.jpg\" alt=\"\">\n        </div>\n        <div class=\"p-slider__number-wrapper\">\n          <span class=\"p-slider__category\">新卒採用</span>\n          <span class=\"p-slider__number\">06</span>\n        </div>\n      </figure>\n      <div class=\"p-slider__body\">\n        <p class=\"p-slider__job\">北米駐在員事務所</p>\n        <p class=\"p-slider__name\">R . K</p>\n      </div>\n      <buttom class=\"c-button p-slider__button\">View more</buttom>\n    </a>\n  </div>\n  <div class=\"p-slider__item swiper-slide\">\n    <a class=\"p-slider__link\" href=\"/newgraduates/interview07/\">\n      <figure class=\"p-slider__img-wrapper\">\n        <div class=\"p-slider__img-mask\">\n          <img class=\"p-slider__img\" src=\"/assets/images/interview/newgraduates07_slider.jpg\" alt=\"\">\n        </div>\n        <div class=\"p-slider__number-wrapper\">\n          <span class=\"p-slider__category\">新卒採用</span>\n          <span class=\"p-slider__number\">07</span>\n        </div>\n      </figure>\n      <div class=\"p-slider__body\">\n        <p class=\"p-slider__job\">コンプライアンス・法務部</p>\n        <p class=\"p-slider__name\">R . S</p>\n      </div>\n      <buttom class=\"c-button p-slider__button\">View more</buttom>\n    </a>\n  </div>\n</div>\n<div class=\"swiper-pagination\"></div>\n<div class=\"swiper-button-prev\"></div>\n<div class=\"swiper-button-next\"></div>    </div><!-- /.p-slider -->\n  </section><!-- /.p-other-interview -->\n\n</div><!-- /.p-interview -->\n\n    </main><!-- /.l-main -->\n\n    <footer class=\"l-footer\">\n      <div class=\"p-footer\">\n  <div class=\"p-footer__inner\">\n    <ul class=\"p-footer__nav\">\n  <li class=\"p-footer__nav-item\">\n    <a class=\"c-link-blank p-footer__nav-link\" href=\"https://www.iseki.co.jp/\" target=\"_blank\">井関農機株式会社 企業サイト</a>\n  </li>\n  <li class=\"p-footer__nav-item\">\n    <a class=\"c-link-blank p-footer__nav-link\" href=\"https://www.iseki.co.jp/pp/\" target=\"_blank\">個人情報保護方針</a>\n  </li>\n  <li class=\"p-footer__nav-item\">\n    <a class=\"c-link-blank p-footer__nav-link\" href=\"https://www.iseki.co.jp/aboutsite/\" target=\"_blank\">サイトについて</a>\n  </li>\n  <li class=\"p-footer__nav-item\">\n    <a class=\"c-link-blank p-footer__nav-link\" href=\"https://www.iseki.co.jp/socialmedia-gl/\" target=\"_blank\">ソーシャルメディアガイドライン</a>\n  </li>\n</ul>    <p class=\"p-footer__copyright\">&copy;2024 ISEKI &amp; CO.,LTD.</p>\n  </div>\n</div><!-- /.p-footer -->    </footer><!-- /.l-footer -->\n\n  </div><!-- /.l-container -->\n</body>\n\n</html>","finalUrl":"https://recruit.iseki.co.jp/newgraduates/interview03/","rendered":false,"_cachedAt":"2026-06-23T16:29:35.123Z"}