{"url":"https://www.suwa.sansha.co.jp/contact_sora/","html":"<!DOCTYPE html>\r\n<html lang=\"ja\">\r\n  <head prefix=\"og: http://ogp.me/ns# fb: http://ogp.me/ns/fb# website: http://ogp.me/ns/website#\">\r\n    <meta charset=\"UTF-8\">\r\n    <META HTTP-EQUIV=\"Content-type\" CONTENT=\"text/html; charset=UTF-8\">\r\n    <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\r\n    <meta name=\"viewport\" content=\"target-densitydpi=device-dpi, width=960, maximum-scale=1.0, user-scalable=yes\">\r\n    <title>株式会社諏訪三社電機｜ソラパワーボックス - お問い合わせ</title>\r\n    <meta name=\"description\" content=\"株式会社諏訪三社電機はお客様のニーズにお応えし、高効率で信頼性の高い電源機器をご提案します。\">\r\n    <meta name=\"keywords\" content=\"カスタム電源,産業用電源,コンピュータ用電源,UPS,電子回路,諏訪三社電機\">\r\n    <meta name=\"author\" content=\"Suwa Sansha Electric\">\r\n\r\n    <link rel=\"stylesheet\" href=\"../css/style.css\">\r\n    <link rel=\"stylesheet\" href=\"css/contact.css\">\r\n    <link rel=\"stylesheet\" href=\"//maxcdn.bootstrapcdn.com/font-awesome/4.7.0/css/font-awesome.min.css\">\r\n\r\n    <meta name=\"format-detection\" content=\"telephone=no\">\r\n\r\n    <!-- OGP -->\r\n    <meta property=\"og:site_name\" content=\"株式会社諏訪三社電機\">\r\n    <meta property=\"og:description\" content=\"株式会社諏訪三社電機オフィシャルサイト。電源装置等の電子機器の製造・販売について、小型化・コストダウン・フレキシブルなご対応などご要望にあわせてご提案いたします。\">\r\n    <meta property=\"og:type\" content=\"website\">\r\n    <meta property=\"og:url\" content=\"https://www.suwa.sansha.co.jp/\">\r\n    <meta property=\"og:image\" content=\"https://www.suwa.sansha.co.jp/images/opengraph.png\">\r\n    <meta property=\"og:locale\" content=\"ja\">\r\n    <!-- / OGP -->\r\n\r\n  <link rel=\"shortcut icon\" href=\"../images/favicon.ico\">\r\n  <link rel=\"icon\" type=\"image/vnd.microsoft.icon\" href=\"../images/favicon.ico\">\r\n\r\n  <!-- Global site tag (gtag.js) - Google Analytics -->\r\n  <script async src=\"https://www.googletagmanager.com/gtag/js?id=UA-86128310-2\"></script>\r\n  <script>\r\n      {literal}\r\n      window.dataLayer = window.dataLayer || [];\r\n      function gtag(){dataLayer.push(arguments);}\r\n      gtag('js', new Date());\r\n\r\n      gtag('config', 'UA-86128310-2');\r\n      {/literal}\r\n  </script>\r\n  <script>\r\n    document.addEventListener('DOMContentLoaded', function(){\r\n        const today = new Date();\r\n        const yyyy = today.getFullYear();\r\n        const mm = today.getMonth() + 1;       // 1〜12 の数値をそのまま使う\r\n        const dd = today.getDate();            // 1〜31 の数値をそのまま使う\r\n        const dateStr = `${yyyy}/${mm}/${dd}`;\r\n        document.getElementById('00NJ20000039sm5').value = dateStr;\r\n    });\r\n  </script>\r\n  </head>\r\n  <body id=\"wrap\">\r\n\r\n    <header class=\"l-header\">\r\n        <div class=\"l-header__inner\">\r\n            <div class=\"header_logo\">\r\n              <h1>\r\n              <a href=\"/\">\r\n                <img src=\"../images/header_logo.png\" width=\"380\" height=\"28\" alt=\"株式会社諏訪三社電機\">\r\n              </a>\r\n            </h1>\r\n          </div>\r\n          <nav class=\"header_link\">\r\n            <ul>\r\n                 <li><a href=\"/index.html#development\">製品開発</a></li>\r\n                 <li><a href=\"/index.html#products\">製品情報</a></li>\r\n\t           <li><a href=\"/sorapowerbox/\">標準製品</a></li>\r\n                 <li><a href=\"/index.html#system\">開発体制</a></li>\r\n                 <li><a href=\"/overview.html\">会社概要</a></li>\r\n                 <li><a href=\"/index.html#faq\">FAQ</a></li>\r\n                 <li><a href=\"/recruit/index.html\">採用</a></li>\r\n                 <li class=\"contact\"><a href=\"../index.html#contactus\">お問い合わせ</a></li>\r\n            </ul>\r\n          </nav>\r\n        </div><!-- /.l-header__inner -->\r\n      </header>\r\n\r\n    <div id=\"contact\">\r\n        <div class=\"l-heading\">\r\n            <div class=\"l-heading__inner\">\r\n                <h3>ソラパワーボックスに関するお問い合わせ</h3>\r\n            </div>\r\n        </div>\r\n          \r\n        <div class=\"l-wrapper\">\r\n            <div class=\"l-wrapper__inner\">\r\n        \r\n                <p>お問い合わせについては以下のフォームよりお願い致します。</p>\r\n        \r\n                <form action=\"https://webto.salesforce.com/servlet/servlet.WebToLead?encoding=UTF-8&orgId=00D5h0000017O6g\" method=\"POST\">\r\n                    <input type=hidden name=\"oid\" value=\"00D5h0000017O6g\">\r\n                    <input type=hidden name=\"retURL\" value=\"https://www.suwa.sansha.co.jp/sorapowerbox/thanks_for_your_inquiry/\">\r\n\r\n                    <input type=\"hidden\" id=\"00NJ20000039sm5\" name=\"00NJ20000039sm5\" value=\"\">\r\n                    <input type=\"hidden\" name=\"lead_source\" value=\"ホームページ\">\r\n                    <ul class=\"table_contact\">\r\n                        <li>\r\n                            <ul>\r\n                                <li class=\"required\">必須</li>\r\n                                <li class=\"label\"><label for=\"contact-name\">お名前</label></li>\r\n                                <li class=\"form\">\r\n                                    <input  id=\"last_name\" maxlength=\"80\" name=\"last_name\" size=\"20\" type=\"text\" required />\r\n                                </li>\r\n                            </ul>\r\n                        </li>\r\n                        <li>\r\n                            <ul>\r\n                                <li class=\"required\">必須</li>\r\n                                <li class=\"label\"><label for=\"contact-email\">E-mail</label></li>\r\n                                <li class=\"form\">\r\n                                    <input  id=\"email\" maxlength=\"80\" name=\"email\" type=\"text\" required />\r\n                                </li>\r\n                            </ul>\r\n                        </li>\r\n                        <li>\r\n                            <ul>\r\n                                <li class=\"required\">必須</li>\r\n                                <li class=\"label\"><label for=\"contact-tel\">TEL</label></li>\r\n                                <li class=\"form\">\r\n                                    <input  id=\"phone\" maxlength=\"40\" name=\"phone\" type=\"text\" required />\r\n                                </li>\r\n                            </ul>\r\n                        </li>\r\n                        <li>\r\n                            <ul>\r\n                                <li class=\"required\">必須</li>\r\n                                <li class=\"label\"><label for=\"contact-company\">会社名</label></li>\r\n                                <li class=\"form\">\r\n                                    <input  id=\"company\" maxlength=\"40\" name=\"company\" type=\"text\" required />\r\n                                </li>\r\n                            </ul>\r\n                        </li>\r\n                        <li class=\"contact-contact\">\r\n                            <ul>\r\n                                <li class=\"label\"><label for=\"contact-contact\">ソラパワーボックスに関するお問い合わせ</label></li>\r\n                                <li class=\"note\">お問い合わせ事項がありましたらご記入をお願いいたします。（※必須ではありません）\r\n                                </li>\r\n                                <li class=\"form-lg\">\r\n                                    <textarea rows=\"15\" id=\"00NJ20000039vWZ\" name=\"00NJ20000039vWZ\"></textarea>\r\n                                </li>\r\n                            </ul>\r\n                        </li>\r\n                        <li class=\"personal-information\">\r\n                            <ul>\r\n                                <li class=\"required\">必須</li>\r\n                                <li class=\"label\"><label for=\"contact-contact\">お問い合わせに関する個人情報の取り扱い</label></li>\r\n                                <li><div class=\"personal-information-note\">\r\n                                    <p>■事業者の氏名または名称<br>\r\n                                        株式会社諏訪三社電機</p>\r\n                    \r\n                                    <p>■個人情報の利用目的について<br>\r\n                                        お問い合わせの方から当社にご提供いただいた個人情報は、次の目的で使用し、当該目的以外では使用しません。<br>\r\n                                        （１）当社の開発・技術に関する情報提供<br>\r\n                                        （２）当社の顧客管理<br>\r\n                                        （３）当社の営業活動における統計作成</p>\r\n                    \r\n                                    <p>■個人情報の第三者提供について<br>\r\n                                        当社は個人情報を次のいずれかに該当する場合を除き、第三者へ提供いたしません。<br>\r\n                                        ・ 登録者が事前に承諾された場合<br>\r\n                                        ・ 国の機関または地方公共団体が法令の定める業務を遂行することに対して協力する必要がある場合<br>\r\n                                        ・ 登録者および人の生命、身体または財産の保護のために必要がある場合</p>\r\n                    \r\n                                    <p>■対象となる個人情報の開示等およびお問い合わせ窓口について<br>\r\n                                        登録者ご本人またはその代理人が、個人情報に関して、利用目的の通知、開示、内容の訂正・追加または削除、利用の停止、消去および第三者への提供の停止を要求される場合の連絡先は、以下になります。</p>\r\n                    \r\n                                    <p>株式会社諏訪三社電機　総務部<br>\r\n                                    電話番号：０２６６－８２－６６００</p>\r\n                    \r\n                                    <p>■個人情報のご記入について<br>\r\n                                    全ての項目は任意記入とさせていただきますが、空欄のままの項目によっては適切な手続きや迅速な対応ができない場合があります。</p>\r\n\r\n                                    </div>\r\n                                </li>\r\n                            </ul>\r\n                            <div class=\"subscribe\">\r\n                                <input type=\"checkbox\" name=\"request\" value=\"request\" id=\"contact-request\" required><label for=\"contact-request\"> 上記利用目的及び個人情報保護方針を確認し、同意します</label>\r\n                            </div>\r\n                        </li>\r\n                    </ul>\r\n        \r\n                    <div class=\"contact_btn\">\r\n                        <div class=\"button\"><input type=\"submit\" name=\"submit\"></div>\r\n                    </div> \r\n                </form>  \r\n            </div>    \r\n        </div>\r\n    </div><!-- /#contact -->\r\n    \r\n    <div id=\"pagetop\"><a href=\"#\"><img src=\"../images/pagetop.png\" alt=\"pagetop\"></a></div>\r\n\r\n    <footer class=\"l-footer\">\r\n       <div class=\"l-footer__inner\">\r\n         <p>株式会社諏訪三社電機は、<a href=\"https://www.sansha.co.jp/\" target=\"_blank\">株式会社三社電機製作所</a>の100%子会社です。</p>\r\n \r\n         <div class=\"banner\"><a href=\"https://www.sansha.co.jp/\" target=\"_blank\"><img src=\"../images/footer_banner.png\" width=\"734\" height=\"187\" alt=\"大容量の電源機器やパワー半導体をお探しなら「株式会社三社電機製作所」\"></a></div>\r\n \r\n         <div class=\"l-footer__logo\"><a href=\"/index.html\"><img src=\"../images/footer_logo.png\" width=\"532\" height=\"45\" alt=\"株式会社諏訪三社電機\"></a></div>\r\n \r\n             <small class=\"l-footer__copyright\">Copyright (C) Suwa Sansha Electric Co., Ltd.All Rights Reserved.</small>\r\n       </div><!-- /l-footer__inner -->\r\n     </footer>\r\n \r\n \r\n     <!-- JavaScript -->\r\n     <script src=\"https://ajax.googleapis.com/ajax/libs/jquery/2.1.1/jquery.min.js\"></script>\r\n     <script src=\"../js/pagetop.js\"></script>\r\n     <!-- / JavaScript -->\r\n   </body>\r\n </html>","finalUrl":"https://www.suwa.sansha.co.jp/contact_sora/","rendered":false,"_cachedAt":"2026-06-22T20:02:54.848Z"}