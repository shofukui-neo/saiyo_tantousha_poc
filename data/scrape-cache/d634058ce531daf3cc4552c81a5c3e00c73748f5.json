{"url":"https://www.yutaka-unyu.co.jp/policy/greeting.html","html":"<!DOCTYPE html>\r\n<html lang=\"ja\">\r\n\r\n<head prefix=\"og: http://ogp.me/ns# fb: http://ogp.me/ns/fb# article: http://ogp.me/ns/article#\">\r\n<meta charset=\"utf-8\">\r\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\r\n<title>代表挨拶 | 会社案内 | 重量物輸送で九州No.1シェアの豊運輸株式会社</title>\r\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1.0\">\r\n<meta name=\"keywords\" content=\"福岡,九州,重量物輸送,特殊製品輸送,住宅部材輸送,運送会社,クレーン\">\r\n<meta name=\"description\" content=\"重量物輸送は福岡の豊運輸へ。50年以上の実績をもち、トラック、トレーラなど370台以上の多彩な車輌で、日本全国へ安全にお運びいたします。重たいもの、大きなもの、長いもの、精密なもの、重量物や特殊製品、住宅部材輸送のエキスパートです。\">\r\n<link rel=\"stylesheet\" href=\"../css/style.css\" media=\"all\">\r\n<link rel=\"shortcut icon\" href=\"../favicon.ico\" />\r\n\r\n<!--[if lt IE 9]>\r\n\t<script src=\"js/html5shiv.js\"></script>\r\n\t<script src=\"js/rem.js\"></script>\r\n<![endif]-->\r\n\r\n<!--[if (gte IE 6)&(lte IE 8)]>\r\n\t<script src=\"js/selectivizr-min.js\"></script>\r\n<![endif]-->\r\n\r\n<!-- Google Tag Manager -->\r\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\r\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\r\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\r\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\r\n})(window,document,'script','dataLayer','GTM-WQDGNHP');</script>\r\n<!-- End Google Tag Manager -->\r\n</head>\r\n\r\n<body id=\"greeting\">\r\n    <!-- Google Tag Manager (noscript) -->\r\n    <noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-WQDGNHP\"\r\n    height=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\r\n    <!-- End Google Tag Manager (noscript) -->\r\n\r\n    <header class=\"header\">\r\n        <header_common></header_common>\r\n    </header>\r\n\r\n    <div class=\"main-title main-title--policy\">\r\n        <div class=\"curtain\"></div>\r\n    </div>\r\n\t<p class=\"topic-path\">\r\n\t\t<a href=\"../\" class=\"topic-path__link\">HOME</a> - <a href=\"index.html\" class=\"topic-path__link\">会社案内TOP</a> - 代表挨拶\r\n\t</p>\r\n\r\n    <h2 class=\"main-title-text\">\r\n        <span class=\"main-title-text__en\">YUTAKA <span class=\"main-title-text__en--minus\">P</span>OLICY</span>\r\n        <span class=\"main-title-text__ja\">会社案内</span>\r\n    </h2>\r\n\r\n    <div class=\"contents\">\r\n        <div class=\"page-link\">\r\n            <h3 class=\"page-link__title\">代表挨拶</h3>\r\n            <ul class=\"page-link__items\">\r\n                <li class=\"page-link__item\">\r\n                    <a href=\"index.html\" class=\"page-link__link\">会社案内TOP</a>\r\n                </li>\r\n                <li class=\"page-link__item\">\r\n                    <a href=\"greeting.html\" class=\"page-link__link active\">代表挨拶</a>\r\n                </li>\r\n                <li class=\"page-link__item\">\r\n                    <a href=\"overview.html\" class=\"page-link__link\">会社概要・沿革</a>\r\n                </li>\r\n                <li class=\"page-link__item\">\r\n                    <a href=\"guide.html\" class=\"page-link__link\">営業所案内</a>\r\n                </li>\r\n                <li class=\"page-link__item\">\r\n                    <a href=\"effort.html\" class=\"page-link__link\">品質と環境への取り組み</a>\r\n                </li>\r\n            </ul>\r\n        </div>\r\n        <div class=\"greeting-wrapper\">\r\n            <div class=\"greeting-daihyou\">\r\n                <div class=\"greeting-daihyou__main\">\r\n                    <div class=\"greeting-daihyou__photo\">\r\n                        <img src=\"img/greeting/photo_daihyou.jpg\" alt=\"\">\r\n                    </div>\r\n                    <div class=\"greeting-daihyou__block\">\r\n                        <p class=\"greeting-daihyou__copy\">\r\n                            お客様、社員、支えてくださる皆様に感謝し、<br class=\"pc_s\">\r\n                            恩に報い続けた50年。<br>\r\n                            さらに50年先も、世の中に、お客様に、<br class=\"pc_s\">\r\n                            必要とされる会社であるために、報い続ける。\r\n                        </p>\r\n                        <p class=\"greeting-daihyou__name\">\r\n                            <span class=\"greeting-daihyou__name-company\">豊運輸株式会社 <br class=\"pc_s\">代表取締役社長</span>\r\n                            <span class=\"greeting-daihyou__name-full\">福田 篤</span>\r\n                            <span class=\"greeting-daihyou__name-en\">FUKUDA ATSUSHI</span>\r\n                        </p>\r\n                    </div>\r\n                </div>\r\n                <p class=\"greeting-daihyou__text\">\r\n                    私たちを取り巻く社会環境は、常にめまぐるしく変化しています。この千変万化の社会においても、変わってはならないもの、守り続けなければならないものがあります。私共、豊運輸は創業以来「感謝・安全・輸送」を企業理念とし、社会貢献の一端を担って参りました。\r\n                </p>\r\n                <p class=\"greeting-daihyou__text\">\r\n                    <span class=\"greeting-daihyou__text--strong\">感謝報恩の心</span>をもつということ、それは私にとって、また豊運輸にとって極めて大切なことであると考えます。人は天地自然の全ての恵みにより生かされており、また、企業は縁ある多くの人々の労により存在しています。感謝の心を持ち、お客様には安全・確実に荷物を運ばせていただくことで、また社員には、安全に働くことができる環境を作ることで、それぞれの恩に報いることが、私にとっての無限の活力となっているのです。\r\n                </p>\r\n                <p class=\"greeting-daihyou__text greeting-daihyou__text--mgnone\">\r\n                    健全な会社を作るのは、健全な社員であり、また逆もしかりです。感謝報恩の心は、全ての喜びとし、社会との調和・共存共栄の姿を作り、常に正直に健全であることです。それが、つまりは豊運輸の次世代に繋ぐ道であると確信し、これからも前進し続けて参ります。\r\n                </p>\r\n            </div>\r\n            <!--//greeting-daihyou-->\r\n\r\n            <div class=\"greeting-philosophy\">\r\n                <h4 class=\"base-title base-title--spacing-middle base-title--mb-middle\">企業理念</h4>\r\n                <div class=\"greeting-philosophy__photo\">\r\n                    <img src=\"img/greeting/illust_rinen.png\" alt=\"感謝・安全輸送\">\r\n                </div>\r\n            </div>\r\n            <!--//greeting-philosophy-->\r\n\r\n            <div class=\"greeting-motto\">\r\n                <h4 class=\"greeting-motto__title\">社訓</h4>\r\n                <ul class=\"greeting-motto__items\">\r\n                    <li class=\"greeting-motto__item\">\r\n                        <span class=\"greeting-motto__number\">一、</span>\r\n                        <span class=\"greeting-motto__text\">顧客に感謝しよう</span>\r\n                    </li>\r\n                    <li class=\"greeting-motto__item\">\r\n                        <span class=\"greeting-motto__number\">一、</span>\r\n                        <span class=\"greeting-motto__text\">事故災害を無くし<br class=\"pc\">\r\n                        社会に奉仕しよう</span>\r\n                    </li>\r\n                    <li class=\"greeting-motto__item\">\r\n                        <span class=\"greeting-motto__number\">一、</span>\r\n                        <span class=\"greeting-motto__text\">社員は一致協力して<br>\r\n                        企業の繁栄と共に<br class=\"pc\">\r\n                        社員（家族）の幸福を<br class=\"pc\">創りましょう</span>\r\n                    </li>\r\n                </ul>\r\n            </div>\r\n            <!--//greeting-motto--->\r\n\r\n            <div class=\"greeting-policy\">\r\n                <h4 class=\"greeting-policy__title\">経営方針・社是</h4>\r\n                <ul class=\"greeting-policy__items\">\r\n                    <li class=\"greeting-policy__item\">\r\n                        一、私は豊運輸の代表です<br>\r\n                        誠実と信用を得ることに徹し感謝します\r\n                    </li>\r\n                    <li class=\"greeting-policy__item\">\r\n                        一、今日も真面目で真心に反することのないように徹します\r\n                    </li>\r\n                    <li class=\"greeting-policy__item\">\r\n                        一、今日も言うこと行うことに恥じることのないように徹します\r\n                    </li>\r\n                    <li class=\"greeting-policy__item\">\r\n                        一、今日もやる気を起こし気力に欠けることのないように徹します\r\n                    </li>\r\n                    <li class=\"greeting-policy__item\">\r\n                        一、私は豊運輸の代表です<br>\r\n                        安全輸送（無事故・無災害）と皆様に喜ばれる輸送に徹し感謝します\r\n                    </li>\r\n                </ul>\r\n            </div>\r\n            <!--//greeting-policy--->\r\n\r\n        </div>\r\n        <!--//contact-wrapper-->\r\n    </div>\r\n    <!--contents-->\r\n\r\n\t<div id=\"page_top\"><a href=\"#\"><img src=\"../img/pagetop.png\" alt=\"pagetop\"></a></div>\r\n\t<footer class=\"footer\">\r\n        <footer_common></footer_common>\r\n\t</footer>\r\n<!--JS-->\r\n<script type=\"text/javascript\" src=\"../js/jquery-1.11.2.min.js\"></script>\r\n<script type=\"text/javascript\" src=\"../js/animation.js\"></script>\r\n<script type=\"text/javascript\" src=\"../js/pagetop.js\"></script>\r\n<script type=\"text/javascript\" src=\"../js/ofi.min.js\"></script>\r\n<script>\r\n\tobjectFitImages();\r\n</script>\r\n\r\n<script type=\"text/javascript\" src=\"../js/import.js\"></script>\r\n<script type=\"text/javascript\" src=\"../js/scrollsmoothly.js\"></script>\r\n<script type=\"text/javascript\" src=\"../js/jquery.matchHeight.js\"></script>\r\n<script type=\"text/javascript\">\r\n\t$(function() {\r\n        $('.greeting-motto__item').matchHeight();\r\n\t});\r\n</script>\r\n\r\n<script>\r\n$(window).on('load', function(){\r\n      $('.main-title').addClass('active');\r\n  });\r\n</script>\r\n\r\n<!--/JS-->\r\n<script src=\"https://cdnjs.cloudflare.com/ajax/libs/riot/2.6.7/riot+compiler.min.js\"></script>\r\n<script type=\"riot/tag\" src=\"../tags/header_common.tag\"></script>\r\n<script type=\"riot/tag\" src=\"../tags/footer_common.tag\"></script>\r\n<script src=\"../tags/base.js\"></script>\r\n\r\n</body>\r\n</html>\r\n","finalUrl":"https://www.yutaka-unyu.co.jp/policy/greeting.html","rendered":false,"_cachedAt":"2026-06-22T20:32:20.565Z"}