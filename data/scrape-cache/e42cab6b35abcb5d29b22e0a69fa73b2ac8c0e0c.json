/recruit/interview/\"><b>Our People</b><br>人を知る／社員インタビュー</a></li>\r\n          <!--<li><a href=\"/recruit/interview/\"><b>Interview</b><br>人を知る</a></li>-->\r\n          <li><button id=\"companySpBtn\"><b>About Token</b><br>会社を知る<i></i></button></li>\r\n        </ul>\r\n        <ul class=\"sub_list\">\r\n          <li><a href=\"/recruit/system/\">制度（キャリアパス・福利厚生・働き方）</a></li>\r\n          <li><a href=\"/recruit/number\">数字で知る東建コーポレーション</a></li>\r\n          <li><a href=\"/recruit/woman/\">女性活躍推進</a></li>\r\n          <li><a class=\"link\" href=\"/corporate/\" target=\"_blank\" rel=\"nofollow\">会社情報</a></li>\r\n        </ul>\r\n        <section class=\"blue_bg\">\r\n          <div class=\"recruit_ttl\">\r\n            <b>Requirements</b>\r\n            <h3>募集要項</h3>\r\n          </div>\r\n          <section class=\"newgraduate\">\r\n            <h4>新卒採用</h4>\r\n          </section>\r\n          <section>\r\n            <h4>新卒採用 2027</h4>\r\n            <ul>\r\n              <li><a class=\"entry\" href=\"https://job.axol.jp/bx/s/token_27/entry/\" target=\"_blank\" rel=\"nofollow\">ENTRY</a></li>\r\n              <li><a class=\"mypage\" href=\"https://job.axol.jp/bx/s/token_27/mypage/login\" target=\"_blank\" rel=\"nofollow\">MY PAGE</a></li>\r\n              <li><a href=\"https://job.mynavi.jp/27/pc/search/corp54375/outline.html\" target=\"_blank\" rel=\"nofollow\"><img src=\"/recruit/image_cmn/btn-mynavi2027.jpg\" alt=\"マイナビ2027\"></a></li>\r\n              <li><a href=\"https://job.rikunabi.com/n/job_search/?kw=%E6%9D%B1%E5%BB%BA%E3%82%B3%E3%83%BC%E3%83%9D%E3%83%AC%E3%83%BC%E3%82%B7%E3%83%A7%E3%83%B3\" target=\"_blank\" rel=\"nofollow\"><img src=\"/recruit/image_cmn/btn-recnavi2027.jpg\" alt=\"リクナビ2027\"></a></li>\r\n            </ul>\r\n          </section>\r\n          <section>\r\n            <h4>新卒採用 2028</h4>\r\n            <ul>\r\n              <!--<li class=\"comingsoon\">Coming Soon</li>-->\r\n              <li><a class=\"entry\" href=\"https://axol.jp/zw/s/token_28/entry/\" target=\"_blank\" rel=\"nofollow\">ENTRY</a></li>\r\n              <li><a class=\"mypage\" href=\"https://axol.jp/zw/s/token_28/mypage/\" target=\"_blank\" rel=\"nofollow\">MY PAGE</a></li>\r\n              <li><a href=\"https://job.mynavi.jp/28/pc/search/corp54375/outline.html\" target=\"_blank\" rel=\"nofollow\"><img src=\"/recruit/image_cmn/btn-mynavi2028.jpg\" alt=\"マイナビ2028\"></a></li>\r\n              <li><a href=\"https://job.rikunabi.com/job_search/?kw=%E6%9D%B1%E5%BB%BA%E3%82%B3%E3%83%BC%E3%83%9D%E3%83%AC%E3%83%BC%E3%82%B7%E3%83%A7%E3%83%B3\" target=\"_blank\" rel=\"nofollow\"><img src=\"/recruit/image_cmn/btn-recnavi2028.jpg\" alt=\"リクナビ2028\"></a></li>\r\n            </ul>\r\n          </section>\r\n          <section class=\"career\">\r\n            <h4>中途採用</h4>\r\n            <ul class=\"button_list\">\r\n              <li><a class=\"entry\" href=\"/recruit/entry/?id=01\">ENTRY</a></li>\r\n            </ul>\r\n          </section>\r\n        </section>\r\n        <ul class=\"sp_sns\">\r\n          <li><a href=\"https://www.facebook.com/token.corp\" target=\"_blank\"><img src=\"/recruit/image_cmn/icon-facebook-n.svg\" alt=\"facebook\"></a></li>\r\n          <li><a href=\"https://twitter.com/tokencorp\" target=\"_blank\"><img src=\"/recruit/image_cmn/icon-x-n.svg\" alt=\"x\"></a></li>\r\n          <li><a href=\"https://www.youtube.com/user/tokentelevision\" target=\"_blank\"><img src=\"/recruit/image_cmn/icon-youtube-n.svg\" alt=\"youtube\"></a></li>\r\n          <li><a href=\"https://www.instagram.com/token.corp_official/\" target=\"_blank\"><img src=\"/recruit/image_cmn/icon-instagram-n.svg\" alt=\"Instagram\"></a></li>\r\n          <!--<li><a href=\"\"><img src=\"/recruit/image_cmn/icon-tiktok-n.png\" alt=\"Tiktok\"></a></li>-->\r\n        </ul>\r\n      </section>\r\n    </div>\r\n  </header>\r\n</div>\r\n<main id=\"main\">\r\n  <div class=\"kv_sub_wrap\">\r\n    <div class=\"inner\">\r\n      <p class=\"kv_sub_cat_en\">About Token</p>\r\n      <p class=\"kv_sub_cat\">会社を知る</p>\r\n      <h1 class=\"kv_sub_tit\">数字で知る<br class=\"sp\">東建コーポレーション</h1>\r\n    </div>\r\n  </div>\r\n  <div id=\"wrap\">\r\n    <nav id=\"breadcrumbs\">\r\n      <ul>\r\n        <li><a href=\"/\">Top</a></li>\r\n        <li><a href=\"../\">求人・採用情報</a></li>\r\n        <li>数字で知る東建コーポレーション</li>\r\n      </ul>\r\n    </nav>\r\n    <div class=\"number_anchorbox\">\r\n      <div class=\"inner\">\r\n        <p>INFOGRAPHICS</p>\r\n        <ul>\r\n          <li><a href=\"#number_section1\">会社<br class=\"br_number\"><span>の数字</span></a></li>\r\n          <li><a href=\"#number_section2\">働き方<br class=\"br_number\"><span>の数字</span></a></li>\r\n          <li><a href=\"#number_section3\">これまでと、<br>今<br class=\"br_number\"><span>の数字</span></a></li>\r\n          <li><a href=\"#number_section4\">社員の<br>リアルと<br>\"らしさ\"<br class=\"br_number\"><span>の数字</span></a></li>\r\n        </ul>\r\n      </div>\r\n    </div>\r\n  </div>\r\n  <section id=\"number_section1\" class=\"number_section1 n_section\">\r\n    <h2 class=\"ffM\">会社<br><span>の数字</span></h2>\r\n    <ul class=\"mini_section_box\">\r\n      <li class=\"mini_section topic01\">\r\n        <h3>創業</h3>\r\n        <strong class=\"ffM\">1974<span>年</span>9<span>月</span></strong>\r\n        <p>半世紀の実績はダテじゃない！？<br>安定感も、未来へのワクワクも両方あります。</p>\r\n      </li>\r\n      <li class=\"mini_section topic02\">\r\n        <h3>事業所数</h3>\r\n        <strong class=\"ffM\">216</strong>\r\n        <p>北は北海道から、南は沖縄まで。<br>あなたの街にもきっとあります。<br>全国216の拠点が、活躍の舞台です。</p>\r\n        <p class=\"ffM data202506\">〈2025年6月〉</p>\r\n      </li>\r\n      <li class=\"mini_section topic03\">\r\n        <h3>社員数</h3>\r\n        <strong class=\"ffM\">5,394<span>名</span></strong>\r\n        <p>新しい仲間が続々と増えています。<br>会社の成長と一緒にあなたの\"やりたい！\"が<br>見つかるチャンスもきっと広がっていく。</p>\r\n        <p class=\"ffM data202506\">〈2025年6月〉</p>\r\n      </li>\r\n      <li class=\"mini_section topic04\">\r\n        <h3>売上高</h3>\r\n        <div class=\"co_img01\">\r\n          <img src=\"../number/image/co-graph01.png\" alt=\"売上高 比較図\">\r\n        </div>\r\n        <p>会社の成長、\"たいりょく\"が違います。<br>毎年、過去最高を更新する安定感が、<br>未来を明るく照らしています。</p>\r\n      </li>\r\n      <li class=\"mini_section topic05\">\r\n        <h3>年齢別構成比</h3>\r\n        <div class=\"co_img02\">\r\n          <img src=\"../number/image/co-graph02.png\" alt=\"年齢別構 比較図\">\r\n        </div>\r\n        <p>20代のフレッシュな感性と、60代の豊かな経験。<br>様々な世代の個性が混ざり合うから、<br>面白いアイデアが生まれます。</p>\r\n        <p class=\"ffM data202506\">〈2025年6月〉</p>\r\n      </li>\r\n    </ul>\r\n  </section>\r\n  <section id=\"number_section2\" class=\"number_section2 n_section matcheight\">\r\n    <h2 class=\"ffM\">働き方<br><span>の数字</span></h2>\r\n      <ul class=\"mini_section_box\">\r\n        <li class=\"mini_section topic01\">\r\n          <h3>平均残業時間</h3>\r\n          <strong class=\"ffM\">14<span>時間／月</span></strong>\r\n          <p>仕事もプライベートも、全力で楽しむ。<br>限られた時間でスマートに成果を出すのが、<br>私たちの働き方です。</p>\r\n        </li>\r\n        <li class=\"mini_section topic02\">\r\n          <h3>有休の取りやすさ</h3>\r\n          <strong>★ ★ ★ ★ <em>★</em></strong>\r\n          <p>休むときは、しっかり休む。<br class=\"sp\">星4つの取りやすさが、<br>そのカルチャーを証明しています。</p>        </li>\r\n        <li class=\"mini_section topic03\">\r\n          <h3>職場での服装</h3>\r\n          <ul class=\"percentage_txt\">\r\n            <li><p>ビジネスカジュアル</p><strong class=\"ffM\">53.3<span class=\"percent\">%</span></strong></li>\r\n            <li><p>スーツ</p><strong class=\"ffM\">29.5<span class=\"percent\">%</span></strong></li>\r\n            <li><p>制服</p><strong class=\"ffM\">17.2<span class=\"percent\">%</span></strong></li>\r\n          </ul>\r\n          <p>\"働く服\"を、もっと自由に、もっと楽しく。<br>今日のコーデを考えるのが、ちょっと楽しい！？<br>東建ではビジネスカジュアルが定着しています！</p>\r\n        </li>\r\n        <li class=\"mini_section topic04\">\r\n        <h3>職場で履いている靴</h3>\r\n        <ul class=\"percentage_txt\">\r\n          <li><p>革靴</p><strong class=\"ffM\">38.7<span class=\"percent\">%</span></strong></li>\r\n          <li><p>スニーカー</p><strong class=\"ffM\">37.2<span class=\"percent\">%</span></strong></li>\r\n          <li><p>ヒール</p><strong class=\"ffM\">9.9<span class=\"percent\">%</span></strong></li>\r\n          <li><p>その他</p><strong class=\"ffM\">14.2<span class=\"percent\">%</span></strong></li>\r\n        </ul>\r\n        <p>今日の服装に合わせて、足元もお洒落に。<br>革靴派もスニーカー派も。<br>社員の自由な個性を、尊重する会社です。</p>\r\n        </li>\r\n        <li class=\"mini_section topic05\">\r\n        <h3>一番良いと感じている福利厚生</h3>\r\n        <ul class=\"percentage_txt\">\r\n          <li><p>各種保険の加入</p><strong class=\"ffM\">61.7<span class=\"percent\">%</span></strong></li>\r\n          <li><p>海外コンドミニアム／国内リゾートマンションの施設利用</p><strong class=\"ffM\">13.4<span class=\"percent\">%</span></strong></li>\r\n          <li><p>慶弔見舞金制度</p><strong class=\"ffM\">10.1<span class=\"percent\">%</span></strong></li>\r\n        </ul>\r\n        <p>「この制度があって、本当に良かった！」<br>社員のリアルな声を集計した福利厚生ランキング、<br>第1位は「各種保険の加入」でした。<br>安心して業務に取り組むことができますね。</p>\r\n        </li>\r\n      </ul>\r\n  </section>\r\n  <section id=\"number_section3\" class=\"number_section3 n_section\">\r\n    <h2 class=\"ffM\">これまでと、今<br><span>の数字</span></h2>\r\n    <ul class=\"mini_section_box\">\r\n      <li class=\"mini_section topic01\">\r\n        <h3>入社の決め手</h3>\r\n        <ul class=\"percentage_txt\">\r\n          <li><p>給料に魅力を感じた</p><strong class=\"ffM\">21.7<span class=\"percent\">%</span></strong></li>\r\n          <li><p>面接の対応をしてくれた方や社員の雰囲気が良かった</p><strong class=\"ffM\">15.8<span class=\"percent\">%</span></strong></li>\r\n          <li><p>事業内容に興味が<br class=\"pc\">あった</p><strong class=\"ffM\">15.1<span class=\"percent\">%</span></strong></li>\r\n        </ul>\r\n        <p>先輩たちが、最後に「ここだ！」と思った<br>決め手はお給料。<br>他にも、会社説明会では聞けないリアルな本音を<br>こっそり紹介します。</p>\r\n      </li>\r\n      <li class=\"mini_section topic02\">\r\n        <h3>入社前に経験した業界</h3>\r\n        <ul class=\"percentage_txt\">\r\n          <li><p>建築</p><strong class=\"ffM\">26.8<span class=\"percent\">%</span></strong></li>\r\n          <li><p>サービス・インフラ</p><strong class=\"ffM\">20.5<span class=\"percent\">%</span></strong></li>\r\n          <li><p>小売</p><strong class=\"ffM\">15.5<span class=\"percent\">%</span></strong></li>\r\n        </ul>\r\n        <p>「サービス関係」「小売業」など、<br>様々な経歴の仲間が集まっています。<br>あなたの経験が、<br>会社の新しい刺激になるかもしれません。</p>\r\n      </li>\r\n      <li class=\"mini_section topic03\">\r\n        <h3>入社後に感じたギャップは<br class=\"sp\">あった？</h3>\r\n        <div class=\"gap_graph\">\r\n          <p class=\"lead_txt\">「いい意味で、想像と違った！」<br>そんな入社後のポジティブなギャップ、<br class=\"sp\">聞いてみました。<br>さて、一番多かった答えとは？</p>\r\n          <ul>\r\n            <li>\r\n              <p class=\"graph_txt\">あった</p>\r\n              <div class=\"co_img03\">\r\n                <img src=\"../number/image/until-graph.png\" alt=\"56.7%\">\r\n              </div>\r\n            </li>\r\n          </ul>\r\n        </div>\r\n        <h4>みんなが感じた<br class=\"sp\">ギャップ</h4>\r\n        <ul class=\"gap_comment\">\r\n          <li>\r\n            <h5>1位</h5>\r\n            <p>働き方の柔軟さ（残業、有休休暇、リモートワークなど）</p>\r\n          </li>\r\n          <li>\r\n            <h5>2位</h5>\r\n            <p>社内の雰囲気（人間関係、コミュニケーションの活発さなど）</p>\r\n          </li>\r\n          <li>\r\n            <h5>3位</h5>\r\n            <p>仕事のやりがい（事業の社会貢献性、裁量権の大きさなど）</p>\r\n          </li>\r\n        </ul>\r\n      </li>\r\n      <li class=\"mini_section topic04\">\r\n        <h3>「東建って思ってたより○○<br class=\"pc\">だった」と感じた<br class=\"sp\">瞬間がある？</h3>\r\n        <ul class=\"percentage_txt\">\r\n          <li><p>みんな未経験で大丈夫だった</p><strong class=\"ffM\">27.4<span class=\"percent\">%</span></strong></li>\r\n          <li><p>働き方がいい意味で自由だった</p><strong class=\"ffM\">25.2<span class=\"percent\">%</span></strong></li>\r\n          <li><p>有休が取りやすい環境だった</p><strong class=\"ffM\">20.9<span class=\"percent\">%</span></strong></li>\r\n        </ul>\r\n        <p>活躍している先輩も、みんな最初は未経験でした。<br>それでも大丈夫！未経験者、歓迎です。<br>他にも、社員が感じた「思ったより○○！」に<br>入る意外な言葉を大公開！</p>\r\n      </li>\r\n      <li class=\"mini_section topic05\">\r\n        <h3>仕事のやりがいを感じる<br class=\"sp\">のは<br class=\"pc\">どんなとき？</h3>\r\n        <ul class=\"percentage_txt\">\r\n          <li><p>自分の仕事が社会や誰かの役に立っていると実感できたとき</p><strong class=\"ffM\">23.4<span class=\"percent\">%</span></strong></li>\r\n          <li><p>お客様の笑顔が見れたとき</p><strong class=\"ffM\">18.3<span class=\"percent\">%</span></strong></li>\r\n          <li><p>契約に<br class=\"sp\">つながったとき</p><strong class=\"ffM\">15.9<span class=\"percent\">%</span></strong></li>\r\n        </ul>\r\n        <p>思わずガッツポーズが出ちゃう、<br>仕事で一番\"アガる\"瞬間は？<br>みんなの仕事への「情熱」が、ここにあります。</p>\r\n      </li>\r\n      <li class=\"mini_section topic06\">\r\n        <h3>東建コーポレーションを<br class=\"sp\">ひと言で表すと？</h3>\r\n        <div class=\"co_img04\">\r\n          <img class=\"pc\" src=\"../number/image/until-typo-pc.png\" alt=\"東建コーポレーションをひと言で\">\r\n          <img class=\"sp\" src=\"../number/image/until-typo-sp.png\" alt=\"東建コーポレーションをひと言で\">\r\n        </div>\r\n      </li>\r\n    </ul>\r\n  </section>\r\n  <section id=\"number_section4\" class=\"number_section4 n_section\">\r\n    <h2 class=\"ffM\">社員のリアルと<br class=\"sp\">\"らしさ\"<br><span>の数字</span></h2>\r\n    <ul class=\"mini_section_box\">\r\n      <li class=\"mini_section topic01\">\r\n        <h3>休日の過ごし方は？</h3>\r\n        <ul class=\"percentage_txt\">\r\n          <li><p>家族で同じ時間を<br class=\"pc\">過ごす</p><strong class=\"ffM\">29.1<span class=\"percent\">%</span></strong></li>\r\n          <li><p>散歩やスポーツなど、体を動かす</p><strong class=\"ffM\">11.8<span class=\"percent\">%</span></strong></li>\r\n          <li><p>おいしい物を食べに<br class=\"pc\">行く</p><strong class=\"ffM\">11.3<span class=\"percent\">%</span></strong></li>\r\n        </ul>\r\n        <p>休日の過ごし方には、<br class=\"sp\">その人の個性が出ますよね。<br>気になる社員たちのプライベートを、<br>ちょっとだけ、覗いてみました。</p>\r\n      </li>\r\n      <li class=\"mini_section topic02\">\r\n        <h3>アウトドア派？インドア派？</h3>\r\n        <div class=\"co_img05 percentage_txt\">\r\n          <img src=\"../number/image/real-graph.png\" alt=\"アウトドア派は51.4% インドア派は48.6%\">\r\n        </div>\r\n        <p>休日は外でアクティブ？<br>それともお家でまったり？<br>社内では大体半々という結果に！</p>\r\n      </li>\r\n      <li class=\"mini_section topic03\">\r\n        <h3>おわりに</h3>\r\n        <p>会社の売上高から社員の率直な意見まで、東建コーポレーションにまつわる色々な数字をご紹介しました。<br>数字やデータから、「もし自分がここで働いたら...」なんて、未来を想像するきっかけになれば幸いです。</p>\r\n      </li>\r\n    </ul>\r\n  </section>\r\n</main>\r\n\r\n  <!-- requirements -->\r\n  <div class=\"requirement_bg\">\r\n  <section id=\"requirement\">\r\n    <h2>募集要項</h2>\r\n    <p class=\"cap_eng\">Requirements</p>\r\n    <div class=\"requirement_h2_label\">新卒・中途</div>\r\n    <div class=\"requirement_box newgraduate\">\r\n      <h3>新卒採用</h3>\r\n      <div class=\"requirement_layout1\">\r\n        <div>\r\n          <h4 class=\"requirement_job\">営業職</h4>\r\n          <p class=\"requirement_desc\">土地所有者様に収益や節税対策を目的とした、賃貸マンション・アパート経営による土地の有効活用をご提案する「コンサルティング営業」です。<br>税務・不動産・金融など幅広い知識を身に付けながら、お客様の人生設計に寄り添った提案を行います。</p>\r\n          <div class=\"requirement_links\">\r\n            <a href=\"/recruit/newgraduate/sales/\">詳細を見る</a>\r\n            <a href=\"https://job.axol.jp/bx/s/token_27/entry/\" target=\"_blank\" rel=\"nofollow\">応募する</a>\r\n          </div>\r\n        </div>\r\n        <div>\r\n          <h4 class=\"requirement_job\">建築職</h4>\r\n          <p class=\"requirement_desc\">賃貸アパート・マンションを建築するために、現場での施工管理を担当します。業務内容は、工程計画の立案、測量や配置図の作成、施工品質の確認、予算管理、資材や職人の手配、現場の安全管理、各種検査の立会いなど多岐にわたります。</p>\r\n          <div class=\"requirement_links\">\r\n            <a href=\"/recruit/newgraduate/architect/\">詳細を見る</a>\r\n            <a href=\"https://job.axol.jp/bx/s/token_27/entry/\" target=\"_blank\" rel=\"nofollow\">応募する</a>\r\n          </div>\r\n        </div>\r\n        <div>\r\n          <h4 class=\"requirement_job\">設計職・商品開発職</h4>\r\n          <p class=\"requirement_desc\">設計・積算業務を行いながら、着工までの諸申請業務、完工までの工事監理を行います。<br>本社設計職では、新商品の開発や新技術の研究開発、より高効率な設計・業務改善なども行います。</p>\r\n          <div class=\"requirement_links\">\r\n            <a href=\"/recruit/newgraduate/designer/\">詳細を見る</a>\r\n            <a href=\"https://job.axol.jp/bx/s/token_27/entry/\" target=\"_blank\" rel=\"nofollow\">応募する</a>\r\n          </div>\r\n        </div>\r\n        <div>\r\n          <h4 class=\"requirement_job\">仲介職</h4>\r\n          <p class=\"requirement_desc\">オーナー様の賃貸マンション・賃貸アパート経営の安定や、より良い住まいを求めるお客様に満足していただける賃貸物件をお世話するために「入居仲介」、「賃貸管理」の業務を行います。</p>\r\n          <div class=\"requirement_links\">\r\n            <a href=\"/recruit/newgraduate/estate-agency/\">詳細を見る</a>\r\n            <a href=\"https://job.axol.jp/bx/s/token_27/entry/\" target=\"_blank\" rel=\"nofollow\">応募する</a>\r\n          </div>\r\n        </div>\r\n      </div>\r\n      <p class=\"requirement_text1\">ご応募は、マイナビ・リクナビより受け付けております。<br class=\"none_sp\">各ナビサイトの「エントリー」ボタンからお手続きください。</p>\r\n      <h3 class=\"requirement_h3_year\">2027</h3>\r\n      <div class=\"requirement_layout2\">\r\n        <div class=\"entry\"><a href=\"https://job.axol.jp/bx/s/token_27/entry/\" target=\"_blank\">ENTRY</a></div>\r\n        <div class=\"mypage\"><a href=\"https://job.axol.jp/bx/s/token_27/mypage/login\" target=\"_blank\">MY PAGE</a></div>\r\n        <div class=\"rikunavi\"><a href=\"https://job.rikunabi.com/n/job_search/?kw=%E6%9D%B1%E5%BB%BA%E3%82%B3%E3%83%BC%E3%83%9D%E3%83%AC%E3%83%BC%E3%82%B7%E3%83%A7%E3%83%B3\" target=\"_blank\"><img src=\"/recruit/image_cmn/btn-recnavi2027_2.jpg\" alt=\"リクナビ2027\"></a></div>\r\n        <div class=\"mynavi\"><a href=\"https://job.mynavi.jp/27/pc/search/corp54375/outline.html\" target=\"_blank\"><img src=\"/recruit/image_cmn/btn-mynavi2027_2.jpg\" alt=\"マイナビ2027\"></a></div>\r\n      </div>\r\n      <h3 class=\"requirement_h3_year\">2028</h3>\r\n      <!--<p class=\"requirement_comingsoon\">coming soon</p>-->\r\n      <div class=\"requirement_layout2\">\r\n        <div class=\"entry\"><a href=\"https://axol.jp/zw/s/token_28/entry/\" target=\"_blank\">ENTRY</a></div>\r\n        <div class=\"mypage\"><a href=\"https://axol.jp/zw/s/token_28/mypage/\" target=\"_blank\">MY PAGE</a></div>\r\n        <div class=\"rikunavi\"><a href=\"https://job.rikunabi.com/job_search/?kw=%E6%9D%B1%E5%BB%BA%E3%82%B3%E3%83%BC%E3%83%9D%E3%83%AC%E3%83%BC%E3%82%B7%E3%83%A7%E3%83%B3\" target=\"_blank\"><img src=\"/recruit/image_cmn/btn-recnavi2028.jpg\" alt=\"リクナビ2028\"></a></div>\r\n        <div class=\"mynavi\"><a href=\"https://job.mynavi.jp/28/pc/search/corp54375/outline.html\" target=\"_blank\"><img src=\"/recruit/image_cmn/btn-mynavi2028.jpg\" alt=\"マイナビ2028\"></a></div>\r\n      </div>\r\n    </div>\r\n    <div class=\"requirement_box career\">\r\n      <h3>中途採用</h3>\r\n      <div id=\"requirement_accordion_1\" class=\"requirement_layout1\">\r\n        <div>\r\n          <h4 class=\"requirement_job\">営業職</h4>\r\n          <p class=\"requirement_desc\">弊社の主力商品である賃貸物件（賃貸マンション・アパート）等の営業受注活動を行います。主として都市近郊農家等の土地所有者の方に、賃貸マンション・アパート・貸店舗等のリース建築経営をご提案する土地活用コンサルティング営業です。</p>\r\n          <div class=\"requirement_links\">\r\n            <a href=\"/recruit/career/sales/\">詳細を見る</a>\r\n            <a href=\"/recruit/entry/?id=01\">応募する</a>\r\n          </div>\r\n        </div>\r\n        <!--\r\n        <div>\r\n          <h4 class=\"requirement_job\">法人営業職</h4>\r\n          <p class=\"requirement_desc\">不動産仲介店や管理会社を訪問し、不動産仲介店「ホームメイト」のフランチャイズ店や「ホームメイト」サイトの物件情報掲載店の募集活動を行っていただきます。また、契約後のアフターフォロー活動も行っていただきます。</p>\r\n          <div class=\"requirement_links\">\r\n            <a href=\"/recruit/career/business/\">詳細を見る</a>\r\n            <a href=\"/recruit/entry/?id=01\">応募する</a>\r\n          </div>\r\n        </div>\r\n        -->\r\n        <div>\r\n          <h4 class=\"requirement_job\">仲介職</h4>\r\n          <p class=\"requirement_desc\">「ホームメイト」の店舗スタッフとして、オーナー様の賃貸経営を支援する賃貸管理業務と、入居者様への物件提案・契約手続きなどの、入居仲介業務を行います。<br>オーナー様と入居者様双方にとって最適な提案を行うポジションです。</p>\r\n          <div class=\"requirement_links\">\r\n            <a href=\"/recruit/career/estate-agency/\">詳細を見る</a>\r\n            <a href=\"/recruit/entry/?id=05\">応募する</a>\r\n          </div>\r\n        </div>\r\n        <div>\r\n          <h4 class=\"requirement_job\">建築職</h4>\r\n          <p class=\"requirement_desc\">リース住宅の建築工事において、安全・品質・工程・原価管理などの施工管理業務を担当します。<br>また、積算業務や見積り作成などの営業受注支援業務にも携わり、工事の円滑な進行と品質確保を支えるポジションです。</p>\r\n          <div class=\"requirement_links\">\r\n            <a href=\"/recruit/career/architect/\">詳細を見る</a>\r\n            <a href=\"/recruit/entry/?id=03\">応募する</a>\r\n          </div>\r\n        </div>\r\n        <div>\r\n          <h4 class=\"requirement_job\">設計職</h4>\r\n          <p class=\"requirement_desc\">設計・積算支援業務を効率的に行い、お客様にご納得いただける提案を実現するため、「提案図面」及び「契約図面」の作成を担当します。<br>営業と連携しながら、受注活動を技術面から支える設計支援業務を行うポジションです。</p>\r\n          <div class=\"requirement_links\">\r\n            <a href=\"/recruit/career/designer/\">詳細を見る</a>\r\n            <a href=\"/recruit/entry/?id=04\">応募する</a>\r\n          </div>\r\n        </div>\r\n      </div>\r\n      <!-- <a id=\"js_requirement_accordion_btn\" href=\"\" class=\"requirement_accordion_btn\">View More<i></i></a> -->\r\n    </div>\r\n  </section>\r\n</div>\r\n<ul class=\"foot_sns\">\r\n  <li><a href=\"https://www.facebook.com/token.corp\" target=\"_blank\"><img src=\"/recruit/image_cmn/icon-facebook.svg\" alt=\"facebook\"></a></li>\r\n  <li><a href=\"https://twitter.com/tokencorp\" target=\"_blank\"><img src=\"/recruit/image_cmn/icon-x.svg\" alt=\"x\"></a></li>\r\n  <li><a href=\"https://www.youtube.com/user/tokentelevision\" target=\"_blank\"><img src=\"/recruit/image_cmn/icon-youtube.svg\" alt=\"youtube\"></a></li>\r\n  <li><a href=\"https://www.instagram.com/token.corp_official/\" target=\"_blank\"><img src=\"/recruit/image_cmn/icon-instagram.svg\" alt=\"Instagram\"></a></li>\r\n  <!--<li><a href=\"\"><img src=\"/recruit/image_cmn/icon-tiktok-b.png\" alt=\"Tiktok\"></a></li> -->\r\n</ul>\r\n<div class=\"foot_txt\">\r\n  <ul>\r\n    <li><a href=\"/privacy/\">個人情報保護に関する基本方針</a></li>\r\n    <li><a href=\"/personal_info/\">特定個人情報の適切な取り扱いに関する基本方針</a></li>\r\n    <li><a href=\"/social/\">SNS（ソーシャルメディア）ポリシー</