//////////ヘッダー終わり/////////////////////////////////////////////////////-->\n\n<!--/////////////////////////////////////////////////////メインナビ/////////////////////////////////////////////////////-->\n<div id=\"mainnavi\">\n\n<ul>\n<li class=\"out\"><a href=\"../outline/outline.html\">会社概要</a></li>\n<li class=\"bra\"><a href=\"../business/business.html\">事業内容</a></li>\n<li class=\"cas\"><a href=\"../case/case.html\">施工事例</a></li>\n<li class=\"ser\"><a href=\"../service/service.html\">サービス体制</a></li>\n<li class=\"faq\"><a href=\"../faq/faq.html\">よくある質問</a></li>\n<li class=\"gro\"><a href=\"../group/group.html\">グループ紹介</a></li>\n<li class=\"con\"><a href=\"../contact/contact.html\">お問い合わせ</a></li>\n</ul>\n\n</div><!--mainnavi-->\n<!--/////////////////////////////////////////////////////メインナビ終わり/////////////////////////////////////////////////////-->\n\n<!--/////////////////////////////////////////////////////パンくずリスト/////////////////////////////////////////////////////-->\n<div id=\"bread\">\n<a href=\"../index.html\">トップページ</a>&nbsp;&gt;&nbsp;<a href=\"ordert.html\">季節の商品ピックアップ</a>\n</div><!--bread-->\n<!--/////////////////////////////////////////////////////パンくずリスト終わり/////////////////////////////////////////////////////-->\n\n\n<!--/////////////////////////////////////////////////////商品説明/////////////////////////////////////////////////////-->\n<div id=\"product\">\n\n\t<table>\n\t\t<tr>\n\t\t\t<td colspan=\"3\" class=\"product01\">温水洗浄便座</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<td rowspan=\"9\" class=\"product02\"><img src=/upload/furusato/20260501154513059335800.jpg width=300 height=300 ></td>\n\t\t\t<td class=\"product03\">型名</td>\n\t\t\t<td class=\"product04\">温水洗浄便座『シャワンザ』　EW9014</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<td class=\"product03\">販売価格</td>\n\t\t\t<td class=\"product04\">50,000円</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<td colspan=\"2\" class=\"product05\">メーカー希望価格　84,700円（税込）のところ<br />\r\n新菖工業価格　50,000円（標準取付工事費込・税込）<br />\r\n他社製の洋風便器にも取付可能</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<td colspan=\"2\" class=\"product06\">製品仕様</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<td colspan=\"2\" class=\"product07\">\n\t\t\t\t●抗菌便座●脱臭機能なし●ノズルクリーニング●本体、便フタ着脱機能●おまかせ節電●8時間切タイマー●色：パステルアイボリー　W：ホワイト\t\t\t</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<td colspan=\"2\" class=\"product06\">ご注意</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<td colspan=\"2\" class=\"product07\">※販売は当社営業エリア内に限らせて頂きます<br />\r\n※販売価格に標準取付工事費が含まれております<br />\r\n※既存の洋風便器の形状によっては取付が出来ない場合がございます</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<td colspan=\"2\" class=\"product06\">メーカーURL</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<td colspan=\"2\" class=\"product07\"><a href=\"https://www.sanei.ltd/products/ew9014/\" target=\"_blank\">https://www.sanei.ltd/products/ew9014/</a></td>\n\t\t</tr>\n\t</table>\n\n\n</div><!--product-->\n<!--/////////////////////////////////////////////////////商品説明終わり/////////////////////////////////////////////////////-->\n\n\n<!--/////////////////////////////////////////////////////フォーム/////////////////////////////////////////////////////-->\n<div id=\"contact\">\n\n<form name=\"fm\" method=\"post\">\n<input type=\"hidden\" name=\"idx\"\tvalue=\"7\">\n\n\n\n</div><!--contact-->\n\n<div id=\"form\">\n\n\t<img src=\"../images/order_title.gif\" alt=\"オンラインでのお申込み\" class=\"contact_title\" width=\"800\" height=\"32\" />\n\n\t<div class=\"contact01\">\n\t\t<div class=\"contact02\">下記フォームにて必要事項入力の後、[送信] ボタンを押して下さい。<span class=\"contact_aka\">※必須項目</span></div>\n\t\t<table class=\"contact03\"><tbody>\n\t\t\t<tr>\n\t\t\t\t<td class=\"contact05\">申込台数<span class=\"contact_aka\">※</span></td>\n\t\t\t\t<td class=\"contact06\"><input type=\"text\" name=\"value\" class=\"contact09\" />&nbsp;&nbsp;台</td>\n\t\t\t</tr>\n\t\t\t<tr>\n\t\t\t\t<td class=\"contact05\">氏名<span class=\"contact_aka\">※</span></td>\n\t\t\t\t<td class=\"contact06\">姓&nbsp;&nbsp;<input type=\"text\" name=\"name_f1\"  class=\"contact08\" />&nbsp;&nbsp;\n\t\t\t\t\t\t\t\t   名&nbsp;&nbsp;<input type=\"text\" name=\"name_f2\"  class=\"contact08\" />&nbsp;&nbsp;例）新発田 太郎</td>\n\t\t\t</tr>\n\t\t\t<tr>\n\t\t\t\t<td class=\"contact05\">フリガナ<span class=\"contact_aka\">※</span></td>\n\t\t\t\t<td class=\"contact06\">セイ<input type=\"text\" name=\"name_k1\"  class=\"contact08\" />&nbsp;&nbsp;\n\t\t\t\t\t\t\t\t   メイ<input type=\"text\" name=\"name_k2\"  class=\"contact08\" />&nbsp;&nbsp;例）シバタ タロウ</td>\n\t\t\t</tr>\n\t\t\t<tr>\n\t\t\t\t<td class=\"contact05\">郵便番号<span class=\"contact_aka\">※</span></td>\n\t\t\t\t<td class=\"contact06\">〒<input type=\"text\" name=\"zip_code1\" class=\"contact09\" />&nbsp;‐&nbsp;\n\t\t\t\t\t\t\t\t\t<input type=\"text\" name=\"zip_code2\" class=\"contact09\" /></td>\n\t\t\t</tr>\n\t\t\t<tr>\n\t\t\t\t<td class=\"contact05\">住所<span class=\"contact_aka\">※</span></td>\n\t\t\t\t<td class=\"contact06\"><input type=\"text\" name=\"address1\" class=\"contact10\" /></td>\n\t\t\t</tr>\n\t\t\t<tr>\n\t\t\t\t<td class=\"contact05\">ビル・マンション名</td>\n\t\t\t\t<td class=\"contact06\"><input type=\"text\" name=\"address2\" class=\"contact10\" /></td>\n\t\t\t</tr>\n\t\t\t<tr>\n\t\t\t\t<td class=\"contact05\">電話番号<span class=\"contact_aka\">※</span><br /></td>\n\t\t\t\t<td class=\"contact06\"><input type=\"text\" name=\"tel1\" class=\"contact11\" />&nbsp;‐&nbsp;\n\t\t\t\t\t\t\t\t     <input type=\"text\" name=\"tel2\"  class=\"contact11\" />&nbsp;‐&nbsp;\n\t\t\t\t\t\t\t\t     <input type=\"text\" name=\"tel3\"  class=\"contact11\" /></td>\n\t\t\t</tr>\n\t\t\t<tr>\n\t\t\t\t<td class=\"contact05\">FAX番号<br /></td>\n\t\t\t\t<td class=\"contact06\"><input type=\"text\" name=\"fax1\" class=\"contact11\" />&nbsp;‐&nbsp;\n\t\t\t\t\t\t\t\t     <input type=\"text\" name=\"fax2\" class=\"contact11\" />&nbsp;‐&nbsp;\n\t\t\t\t\t\t\t\t     <input type=\"text\" name=\"fax3\" class=\"contact11\" /></td>\n\t\t\t</tr>\n\t\t\t<tr>\n\t\t\t\t<td class=\"contact05\">メールアドレス<span class=\"contact_aka\">※</span><br /></td>\n\t\t\t\t<td class=\"contact06\"><input type=\"text\" name=\"email\" class=\"contact10\" /></td>\n\t\t\t</tr>\n\t\t\t<tr>\n\t\t\t\t<td