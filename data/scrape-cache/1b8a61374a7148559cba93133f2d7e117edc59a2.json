main class=\"page recruit\">\n    <div class=\"recruit-main\">\n      <div class=\"recruit-main-title\">\n        <h1>Recruitment</h1>\n        <h2>\n          INNOVATING<br>VALUES<br>FOR THE FUTURE\n          <span>新たな挑戦が未来を創造する</span>\n        </h2>\n      </div>\n      <ul class=\"recruit-main-slick\">\n        <li class=\"recruit-main-item recruit-main-item-01\"></li>\n        <li class=\"recruit-main-item recruit-main-item-02\"></li>\n        <li class=\"recruit-main-item recruit-main-item-03\"></li>\n      </ul>\n      <div class=\"recruit-main-contact\">\n        <a href=\"https://ohji-rubber.co.jp/contact/recruit/\">ENTRY</a>\n      </div>\n    </div>\n    <div class=\"breadcrumb\"><div class=\"breadcrumb-wrap page-content-width\"><ul><li><a href=\"https://ohji-rubber.co.jp\" class=\"com-btn-hover--text\">TOP</a></li><li><span>求人情報</span></li></ul></div></div>    <section class=\"sec-00\">\n      <div class=\"content-width\">\n        <div class=\"page-title\">\n          <h2 class=\"page-title-h2\">\n            皆さんの「挑戦したい」を<br>王子ゴム化成で叶えませんか？\n          </h2>\n        </div>\n\n        <p class=\"page-desc\">\n          「挑戦と創造」の社訓のもと、<br>新技術の開発・蓄積をしながら<br class=\"md-br\">日本国内だけでなく、<br>\n          海外生産拠点を整備しアジアを中心に<br class=\"md-br\">世界のOHJIへと飛躍し続けています\n        </p>\n        \n      </div>\n    </section>\n    <section class=\"page-sec\">\n      <div class=\"page-sec-img\">\n        <img src=\"https://ohji-rubber.co.jp/wp-content/themes/ohji/img/recruit/top_ver3.jpg\" alt=\"王子ゴム化成株式会社　求人情報\">\n      </div>\n      <div class=\"recruit-content\">\n        \n        \n\n        <div class=\"page-titl\">\n          <h2 class=\"page-title-h2\">\n            学生の皆さんへ\n          </h2>\n        </div>\n        <p class=\"page-desc\">\n          王子ゴム化成では、2027年度の新卒者採用の募集をいたします。<br class=\"pc-br\">学生の皆さんのご応募を、心よりお待ちしております。\n        </p>\n        <div class=\"page-btn-blue mb15\">\n          <a href=\"https://ohji-rubber.co.jp/recruit/info/\">新卒募集要項</a>\n        </div>\n        <div class=\"page-btn-blue mb15\">\n          <a href=\"https://ohji-rubber.co.jp/contact/recruit/\">ENTRY</a>\n        </div>\n\t\t         <div class=\"recruit-bnr center mb50\" style=\"border:2px solid #0dafeb;\">\n\t\t\t\t\t\t<a href=\"https://job.mynavi.jp/27/pc/search/corp56937/outline.html\" target=\"_blank\" style=\"border:none; padding:3px 10px; display:block;\">\n\t\t\t\t\t\t\t\t<img src=\"https://ohji-rubber.co.jp/wp-content/uploads/2026/02/27logo_l.gif\" alt=\"マイナビ2027\" border=\"0\" width=\"100%\" style=\"display:block;\">\n\t\t\t</a>\n\t\t\t        </div>\n\t\t  \n        <div class=\"page-titl\">\n          <h2 class=\"page-title-h2\">\n            キャリア採用について\n          </h2>\n        </div>\n        <p class=\"page-desc mb30\">\n          王子ゴム化成では、<br class=\"pc-br\">2026年度のキャリア採用の募集をいたしております。<br>\n          募集の際にはキャリア採用の募集要項をご確認ください。\n        </p>\n        <div class=\"page-btn-blue mb15\">\n          <a href=\"https://ohji-rubber.co.jp/recruit/career/\">キャリア採用募集要項</a>\n        </div>\n        <div class=\"page-btn-blue mb15\">\n          <a href=\"https://ohji-rubber.co.jp/contact/recruit/\">ENTRY</a>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"page-sec\">\n      <div class=\"recruit-width\">\n        <div class=\"recruit-col\">\n          <div class=\"recruit-col-4-3 pr-5\">\n            <img src=\"https://ohji-rubber.co.jp/wp-content/themes/ohji/img/recruit/overflow_ver2.jpg\" alt=\"\">\n          </div>\n          <div class=\"recruit-col-4-1\">\n            <div class=\"page-title\">\n              <h2 class=\"page-title-h2\">\n                業務内容\n              </h2>\n            </div>\n            <p class=\"page-desc\">\n              職種・分野別に各々の業務内容をご紹介\n            </p>\n            <ul class=\"recruit-list\">\n              <li><a href=\"https://ohji-rubber.co.jp/recruit/business/#sec01\">営業</a></li>\n              <li><a href=\"https://ohji-rubber.co.jp/recruit/business/#sec02\">技術開発</a></li>\n              <li><a href=\"https://ohji-rubber.co.jp/recruit/business/#sec03\">製造技術</a></li>\n              <li><a href=\"https://ohji-rubber.co.jp/recruit/business/#sec04\">製造管理</a></li>\n            </ul>\n          </div>\n        </div>\n      </div>\n\n\n    </section>\n    <section class=\"page-sec\">\n      <div class=\"recruit-width\">\n        <div class=\"recruit-col\">\n          <div class=\"recruit-col-2-1\">\n            <div class=\"page-title\">\n              <h3 class=\"page-title-h3\">お知らせ</h3>\n            </div>\n\n \n          <div class =\"rec_chart\">\n            <p class=\"page-desc\">\n              下記要領にて2026年新卒者採用試験を随時行います。\n            </p>\n            \n            <div class=\"page-chart mb0\">\n                <dl class=\"page-chart-dl\">\n                  <dt>場所</dt>\n                  <dd>\n                    王子ゴム化成株式会社　防府工場　（防府市勝間2丁目１-6）\n                  </dd>\n                </dl>\n                <!--\n                <dl class=\"page-chart-dl\">\n                  <dt>提出書類</dt>\n                  <dd>履歴書、成績証明書</dd>\n                </dl>\n                \n                <dl class=\"page-chart-dl\">\n                  <dt>選考方法</dt>\n                  <dd>筆記試験、一次面接及び社長面接の計2回</dd>\n                </dl>\n                \n                <dl class=\"page-chart-dl\">\n                  <dt>採用人数</dt>\n                  <dd>製造技術職、営業職の3名以上採用予定</dd>\n                </dl>\n                \n                <dl class=\"page-chart-dl\">\n                  <dt>初任給</dt>\n                  <dd>\n                    院　卒：215,000円<br>\n                    四大卒：201,000円<br>\n                    高専卒：175,000円\n                  </dd>\n                </dl>\n                -->\n                <dl class=\"page-chart-dl\">\n                  <dt>応募方法</dt>\n                  <dd>\n                    お問い合わせフォームからご連絡ください。<br>\n\t\t\t\t\t  <a href=\"https://ohji-rubber.co.jp/contact/recruit/\">採用専用お問い合わせフォームはこちら</a>\n                  </dd>\n                </dl>\n                \n              </div> \n              \n            </div>\n\n\t\t\t </div>\n\n          <div class=\"recruit-col-2-1 mb0\">\n            <div class=\"page-title\">\n              <h2 class=\"page-title-h3\">企業動画公開中</h2>\n            </div>\n            <p class=\"page-desc\">\n              営業職の方の仕事内容の紹介動画です。ぜひご覧ください。\n            </p>\n            <div class=\"page-youtube\">\n              <div class=\"page-youtube-wrap\">\n\t\t\t\t  \t\t\t\t                  <iframe width=\"100%\" height=\"100%\" src=\"https://www.youtube.com/embed/8L1zb3WUXMo\" title=\"YouTube video player\" frameborder=\"0\" allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture\" allowfullscreen></iframe>\n              </div>\n            </div>\n          </div>\n        </div>\n\n      </div>\n    </section>\n\n\n    <section class=\"page-sec\">\n      <div class=\"recruit-width\">\n        <div class=\"page-title\">\n          <h2 class=\"page-title-h2\">\n            王子ゴム化成を知る\n          </h2>\n        </div>\n        <p class=\"page-desc\">\n          山口県防府市を拠点に、国内・海外市場にも自社ゴム・樹脂製品を展開する当社では、<br class=\"pc-br\">\n          とりわけゴムライニング製品は、そのクオリティの高さから圧倒的なシェアを誇っています。\n        </p>\n\n        <ul class=\"recruit-list-col\">\n          <li><a href=\"https://ohji-rubber.co.jp/recruit/message/\">先輩たちのメッセージ</a></li>\n          <li><a href=\"https://ohji-rubber.co.jp/recruit/person/\">求める人物像</a></li>\n          <li><a href=\"https://ohji-rubber.co.jp/recruit/faq/\">採用FAQ</a></li>\n          <li><a href=\"https://ohji-rubber.co.jp/recruit/vr/\">バーチャル工場見学</a></li>\n          <li><a href=\"https://ohji-rubber.co.jp/company/\">会社情報</a></li>\n        </ul>\n      </div>\n    </section>\n    <section class=\"page-sec\">\n      <div class=\"recruit-width\">\n        <div class=\"page-title\">\n          <h2 class=\"page-title-h2 center\">ENTRY</h2>\n        </div>\n        <p class=\"page-desc center\">\n          この度は、弊社にご関心をお寄せいた