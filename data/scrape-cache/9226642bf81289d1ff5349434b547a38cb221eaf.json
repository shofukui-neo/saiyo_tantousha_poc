{"url":"http://www.shinsyo-kogyo.co.jp/contact/contact.html","html":"<!DOCTYPE html PUBLIC \"-//W3C//DTD XHTML 1.0 Transitional//EN\" \"http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd\">\n<html xmlns=\"http://www.w3.org/1999/xhtml\" xml:lang=\"ja\" lang=\"ja\">\n<head>\n<meta http-equiv=\"Content-Type\" content=\"text/html; charset=utf-8\" />\n<title>新菖工業株式会社-お問い合わせ</title>\n<meta http-equiv=\"Content-Style-Type\" content=\"text/css\" />\n<meta http-equiv=\"Content-Script-Type\" content=\"text/javascript\" />\n<meta name=\"author\" content=\"新菖工業株式会社\" />\n<meta name=\"description\" content=\"新菖工業株式会社は新潟県新発田市で設備工事の設計施工・設備関連機器の販売を営んでいます。\" />\n<meta name=\"keywords\" content=\"新菖工業,新潟,新発田,水道,ガス,空調,冷暖房,換気,冷凍,冷蔵,衛生,給排水,衛生,浄化槽,厨房,内管,ヒートポンプ,ボイラー\" />\n<link href=\"../css/reset.css\" rel=\"stylesheet\" type=\"text/css\" />\n<link href=\"../css/common.css\" rel=\"stylesheet\" type=\"text/css\" />\n<link href=\"../css/contact.css\" rel=\"stylesheet\" type=\"text/css\" />\n<link rel=\"shortcut icon\" href=\"../favicon.ico\" />\n<link rel=\"icon\" href=\"../favicon.ico\" />\n</head>\n\n\n\n\n<body>\n<a name=\"top\"></a>\n<div id=\"wrapper\">\n\n<!--/////////////////////////////////////////////////////ヘッダー/////////////////////////////////////////////////////-->\n<div id=\"header\">\n\n\t<div class=\"logo\">\n\n\t\t<a href=\"../index.html\"><img src=\"../images/logo.gif\" alt=\"新菖工業株式会社\" width=\"220\" height=\"55\" /></a>\n\n\t</div><!--logo-->\n\n\n\t<div id=\"h_right\">\n\n\t\t<table class=\"header_nav\"><tbody>\n\t\t\t<tr>\n\t\t\t\t<td class=\"home\"><a href=\"../index.html\">HOME</a></td>\n\t\t\t\t<td class=\"mail\"><a href=\"../contact/contact.html\">お問い合わせ</a></td>\n\t\t\t</tr>\n\t\t\t<tr>\n\t\t\t\t<td class=\"tel_area\" colspan=\"2\"><img src=\"../images/top_tel.gif\" alt=\"新菖工業株式会社電話番号\" width=\"172\" height=\"38\" /></td>\n\t\t\t</tr>\n\t\t</tbody></table>\n\n\t</div><!--h_right-->\n\n\n</div><!--header-->\n<!--/////////////////////////////////////////////////////ヘッダー終わり/////////////////////////////////////////////////////-->\n\n<!--/////////////////////////////////////////////////////メインナビ/////////////////////////////////////////////////////-->\n<div id=\"mainnavi\">\n\n<ul>\n<li class=\"out\"><a href=\"../outline/outline.html\">会社概要</a></li>\n<li class=\"bra\"><a href=\"../business/business.html\">事業内容</a></li>\n<li class=\"cas\"><a href=\"../case/case.html\">施工事例</a></li>\n<li class=\"ser\"><a href=\"../service/service.html\">サービス体制</a></li>\n<li class=\"faq\"><a href=\"../faq/faq.html\">よくある質問</a></li>\n<li class=\"gro\"><a href=\"../group/group.html\">グループ紹介</a></li>\n<li class=\"con\"><a href=\"../contact/contact.html\">お問い合わせ</a></li>\n</ul>\n\n</div><!--mainnavi-->\n<!--/////////////////////////////////////////////////////メインナビ終わり/////////////////////////////////////////////////////-->\n\n<!--/////////////////////////////////////////////////////パンくずリスト/////////////////////////////////////////////////////-->\n<div id=\"bread\">\n<a href=\"../index.html\">トップページ</a>&nbsp;&gt;&nbsp;<a href=\"contact.html\">お問い合わせ</a>\n</div><!--bread-->\n<!--/////////////////////////////////////////////////////パンくずリスト終わり/////////////////////////////////////////////////////-->\n\n\n<!--/////////////////////////////////////////////////////本文/////////////////////////////////////////////////////-->\n<div id=\"contact\">\n\n<form name=\"fm\" method=\"post\">\n\n\t<p class=\"contact001\">お問い合わせを受付けております。<br />\n\tサービスにつきまして、ご不明な点やご質問がある場合には、お気軽にお問い合わせください。<br>\n\t※お急ぎの修理のご依頼はお電話でお問い合わせください。</p>\n\n\t<img src=\"../images/ser_title_telcontact.gif\" alt=\"お電話でのお問い合わせ\" class=\"contact_title\" width=\"800\" height=\"32\" />\n\n\t<table class=\"contact002\"><tbody>\n\t\t<tr>\n\t\t\t<td class=\"contact003\">お電話でのお問い合わせは･･･</td>\n\t\t\t<td class=\"contact004\"><img src=\"../images/contact_tel.gif\" alt=\"0254-22-5523\" width=\"172\" height=\"28\" /></td>\n\t\t</tr>\n\t</tbody></table>\n\n</div><!--contact-->\n\n<div id=\"form\">\n\n\t<img src=\"../images/ser_title_onlinecontact.gif\" alt=\"オンラインでのお問い合わせ\" class=\"contact_title\" width=\"800\" height=\"32\" />\n\n\t<div class=\"contact01\">\n\t\t<div class=\"contact02\">下記フォームにて必要事項入力の後、[確認] ボタンを押して下さい。<span class=\"contact_aka\">※必須項目</span></div>\n\t\t<table class=\"contact03\"><tbody>\n\t\t\t<tr>\n\t\t\t\t<td class=\"contact04\" colspan=\"2\">お問合せの内容</td>\n\t\t\t</tr>\n\t\t\t<tr>\n\t\t\t\t<td class=\"contact05\">内容<span class=\"contact_aka\">※</span></td>\n\t\t\t\t<td class=\"contact06\">ご不明な点やご質問等ご自由にご記入下さい。<br /><textarea  name=\"content\"  class=\"contact07\"></textarea></td>\n\t\t\t</tr>\n\t\t\t<tr>\n\t\t\t\t<td class=\"contact04\" colspan=\"2\">お客様情報</td>\n\t\t\t</tr>\n\t\t\t<tr>\n\t\t\t\t<td class=\"contact05\">氏名<span class=\"contact_aka\">※</span></td>\n\t\t\t\t<td class=\"contact06\">姓&nbsp;&nbsp;<input type=\"text\" name=\"name_f1\"  class=\"contact08\" />&nbsp;&nbsp;\n\t\t\t\t\t\t\t\t   名&nbsp;&nbsp;<input type=\"text\" name=\"name_f2\"  class=\"contact08\" />&nbsp;&nbsp;例）新発田 太郎</td>\n\t\t\t</tr>\n\t\t\t<tr>\n\t\t\t\t<td class=\"contact05\">フリガナ<span class=\"contact_aka\">※</span></td>\n\t\t\t\t<td class=\"contact06\">セイ<input type=\"text\" name=\"name_k1\"  class=\"contact08\" />&nbsp;&nbsp;\n\t\t\t\t\t\t\t\t   メイ<input type=\"text\" name=\"name_k2\"  class=\"contact08\" />&nbsp;&nbsp;例）シバタ タロウ</td>\n\t\t\t</tr>\n\t\t\t<tr>\n\t\t\t\t<td class=\"contact05\">郵便番号<span class=\"contact_aka\">※</span></td>\n\t\t\t\t<td class=\"contact06\">〒<input type=\"text\" name=\"zip_code1\" class=\"contact09\" />&nbsp;‐&nbsp;\n\t\t\t\t\t\t\t\t\t<input type=\"text\" name=\"zip_code2\" class=\"contact09\" /></td>\n\t\t\t</tr>\n\t\t\t<tr>\n\t\t\t\t<td class=\"contact05\">住所<span class=\"contact_aka\">※</span></td>\n\t\t\t\t<td class=\"contact06\"><input type=\"text\" name=\"address1\" class=\"contact10\" /></td>\n\t\t\t</tr>\n\t\t\t<tr>\n\t\t\t\t<td class=\"contact05\">ビル・マンション名</td>\n\t\t\t\t<td class=\"contact06\"><input type=\"text\" name=\"address2\" class=\"contact10\" /></td>\n\t\t\t</tr>\n\t\t\t<tr>\n\t\t\t\t<td class=\"contact05\">電話番号<span class=\"contact_aka\">※</span><br /></td>\n\t\t\t\t<td class=\"contact06\"><input type=\"text\" name=\"tel1\" class=\"contact11\" />&nbsp;‐&nbsp;\n\t\t\t\t\t\t\t\t     <input type=\"text\" name=\"tel2\"  class=\"contact11\" />&nbsp;‐&nbsp;\n\t\t\t\t\t\t\t\t     <input type=\"text\" name=\"tel3\"  class=\"contact11\" /></td>\n\t\t\t</tr>\n\t\t\t<tr>\n\t\t\t\t<td class=\"contact05\">FAX番号<br /></td>\n\t\t\t\t<td class=\"contact06\"><input type=\"text\" name=\"fax1\" class=\"contact11\" />&nbsp;‐&nbsp;\n\t\t\t\t\t\t\t\t     <input type=\"text\" name=\"fax2\" class=\"contact11\" />&nbsp;‐&nbsp;\n\t\t\t\t\t\t\t\t     <input type=\"text\" name=\"fax3\" class=\"contact11\" /></td>\n\t\t\t</tr>\n\t\t\t<tr>\n\t\t\t\t<td class=\"contact05\">メールアドレス<span class=\"contact_aka\">※</span><br /></td>\n\t\t\t\t<td class=\"contact06\"><input type=\"text\" name=\"email\" class=\"contact10\" /></td>\n\t\t\t</tr>\n\t\t\t<tr>\n\t\t\t\t<td class=\"contact12\" colspan=\"2\">\n\t\t\t\t\t<a href=\"policy.html\">「個人情報の取り扱いについて」</a>&nbsp;の内容を必ずご確認のうえ、<br />\n\t\t\t\t\t「同意する」ボタンをチェックして下さい。<br />\n\t\t\t\t\t<input type=\"radio\" name=\"doui\" value=\"Y\" checked />同意する&nbsp;\n\t\t\t\t\t<input type=\"radio\" name=\"doui\" value=\"N\"  />同意しない</td>\n\t\t\t</tr>\n\t\t</tbody></table>\n\n\t\t<table class=\"contact13\"><tbody>\n\t\t\t<tr>\n\t\t\t\t<td class=\"contact14\" colspan=\"2\">上記のご記入内容でよろしければ [送信] ボタンを押して下さい。</td>\n\t\t\t</tr>\n\t\t\t<tr>\n\t\t\t\t<td class=\"contact15\">\n\t\t\t\t\t<div id=\"contact017\">\n\t\t\t\t\t<a href=\"javascript:void(0);\" onclick=\"bt_reg()\" class=\"contact17\"><span>送信</span></a>\n\t\t\t\t\t</div>\n\t\t\t\t</td>\n\t\t\t</tr>\n\t\t</tbody></table>\n\t\t</form>\n\t</div>\n\n</div><!--form-->\n<!--/////////////////////////////////////////////////////本文終わり/////////////////////////////////////////////////////-->\n\n\n<!--/////////ページトップへ戻る/////////-->\n<div class=\"gototop\">\n<p><a href=\"#top\"><span>PAGETOP</span></a></p>\n</div><!--gototop-->\n<!--/////////ページトップへ戻る/////////-->\n\n\n<!--/////////////////////////////////////////////////////フッターナビ/////////////////////////////////////////////////////-->\n<div id=\"footernavi\">\n\n<ul>\n<li><a href=\"../hometown/hometown.html\">ふるさと紹介</a></li>\n<li><a href=\"../link/link.html\">関連リンク</a></li>\n<li><a href=\"../corporation/corporation.html\">協力業者の方へ</a></li>\n<li><a href=\"../contact/policy.html\">個人情報の取扱い</a></li>\n<li><a href=\"../sitemap/sitemap.html\">サイトマップ</a></li>\n</ul>\n\n</div><!--footernavi-->\n<!--/////////////////////////////////////////////////////フッターナビ終わり/////////////////////////////////////////////////////-->\n\n\n\n</div><!--wrapper-->\n\n<!--/////////////////////////////////////////////////////フッター/////////////////////////////////////////////////////-->\n<div id=\"footer_wrapper\">\n\n<div id=\"footer\">\n<p class=\"address\">\n<span>新菖工業株式会社</span>&nbsp;<a href=\"../outline/outline.html#map\" target=\"_blank\"><img src=\"../images/map_icon.gif\" alt=\"\" width=\"28\" height=\"14\" /></a><br />\n新潟県新発田市富塚町1丁目1番33号<br />\nTel&nbsp;0254-22-5523<br />\nFax&nbsp;0254-22-5168<br />\n\n</p>\n\n\n<p class=\"copy\">Copyright&nbsp;&copy;&nbsp;shinsyo&nbsp;kogyo&nbsp;Co.Ltd.&nbsp;All Rights Reserved.</p>\n\n</div><!--footer-->\n</div><!--footer_wrapper-->\n<!--/////////////////////////////////////////////////////フッター/////////////////////////////////////////////////////-->\n\n</body>\n</html>\n\n\n\n<script language=javascript>\nfunction bt_reg(){\n\n\tvar fm = eval(\"document.fm\");\n\n\t\n\n\tif ( fm.doui[0].checked != true  ) {\n\t\talert(\"個人情報の取り扱いの内容を必ずご確認のうえ、「同意」するボタンをチェックしてください。\");\n\t\treturn;\n\t} \t\n\n\n\tif (fm.name_f1.value == \"\" || fm.name_f2.value == \"\" ) {\n\t\talert(\"氏名を入力して下さい。\");\n\t\tfm.name_f1.focus();\n\t\treturn;\n\t}\n\t\n\tif (fm.name_k1.value == \"\" || fm.name_k2.value == \"\" ) {\n\t\talert(\"フリガナを入力して下さい。\");\n\t\tfm.name_k1.focus();\n\t\treturn;\n\t}\t\n\n\tif (fm.zip_code1.value == \"\" || fm.zip_code2.value == \"\" ) {\n\t\talert(\"郵便番号を入力して下さい。\");\n\t\tfm.zip_code1.focus();\n\t\treturn;\n\t}\n\n\tif (fm.address1.value == \"\" ) {\n\t\talert(\"住所を入力して下さい。\");\n\t\tfm.address1.focus();\n\t\treturn;\n\t}\n\n\tif (fm.tel1.value == \"\" || fm.tel2.value == \"\" || fm.tel3.value ==\"\" ) {\n\t\talert(\"電話番号を入力して下さい。\");\n\t\tfm.tel1.focus();\n\t\treturn;\n\t}\n\n\tif ( fm.email.value == \"\" ){\n\t\talert(\"メールアドレスを入力して下さい。\");\n\t\tfm.email.focus();\n\t\treturn;\n\t}\n\t\n\tif ( fm.content.value == \"\"){\n\t\talert(\"内容を入力してください。\");\n\t\tfm.content.focus();\n\t\treturn;\n\t}\n\n\tfm.action = \"contact_proc.php?sp=new\";\n\tfm.submit();\n\n}\n</script>\n","finalUrl":"http://www.shinsyo-kogyo.co.jp/contact/contact.html","rendered":false,"_cachedAt":"2026-06-23T23:01:31.601Z"}