{"url":"https://www.tepco-sa.co.jp/ssl/","html":"<!DOCTYPE html>\r\n<html lang=\"ja\">\r\n\r\n<head>\r\n  <meta charset=\"UTF-8\">\r\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n  <meta name=\"description\" content=\"テプコ・ソリューション・アドバンス株式会社の公式サイトです。法人・個人向けの電力サービス、BPO事業、エネルギーソリューションなど、幅広い事業内容をご紹介しています。\">\r\n  <meta name=\"author\" content=\"テプコ・ソリューション・アドバンス株式会社\">\r\n  <title>テプコ・ソリューション・アドバンス株式会社 | 電力サービスとエネルギーソリューション</title>\r\n  <!--260310追記ここから-->\r\n  <link rel=\"canonical\" href=\"https://www.tepco-sa.co.jp/ssl/\">\r\n  <!--260310追記ここまで-->\r\n\r\n  <!--favicon https://www.favicon-generator.org/-->\r\n  <link rel=\"apple-touch-icon\" sizes=\"57x57\" href=\"https://www.tepco-sa.co.jp/ssl/images/site-icon/apple-icon-57x57.png\">\r\n  <link rel=\"apple-touch-icon\" sizes=\"60x60\" href=\"https://www.tepco-sa.co.jp/ssl/images/site-icon/apple-icon-60x60.png\">\r\n  <link rel=\"apple-touch-icon\" sizes=\"72x72\" href=\"https://www.tepco-sa.co.jp/ssl/images/site-icon/apple-icon-72x72.png\">\r\n  <link rel=\"apple-touch-icon\" sizes=\"76x76\" href=\"https://www.tepco-sa.co.jp/ssl/images/site-icon/apple-icon-76x76.png\">\r\n  <link rel=\"apple-touch-icon\" sizes=\"114x114\" href=\"https://www.tepco-sa.co.jp/ssl/images/site-icon/apple-icon-114x114.png\">\r\n  <link rel=\"apple-touch-icon\" sizes=\"120x120\" href=\"https://www.tepco-sa.co.jp/ssl/images/site-icon/apple-icon-120x120.png\">\r\n  <link rel=\"apple-touch-icon\" sizes=\"144x144\" href=\"https://www.tepco-sa.co.jp/ssl/images/site-icon/apple-icon-144x144.png\">\r\n  <link rel=\"apple-touch-icon\" sizes=\"152x152\" href=\"https://www.tepco-sa.co.jp/ssl/images/site-icon/apple-icon-152x152.png\">\r\n  <link rel=\"apple-touch-icon\" sizes=\"180x180\" href=\"https://www.tepco-sa.co.jp/ssl/images/site-icon/apple-icon-180x180.png\">\r\n  <link rel=\"icon\" type=\"image/png\" sizes=\"192x192\" href=\"https://www.tepco-sa.co.jp/ssl/images/site-icon/android-icon-192x192.png\">\r\n  <link rel=\"icon\" type=\"image/png\" sizes=\"32x32\" href=\"https://www.tepco-sa.co.jp/ssl/images/site-icon/favicon-32x32.png\">\r\n  <link rel=\"icon\" type=\"image/png\" sizes=\"96x96\" href=\"https://www.tepco-sa.co.jp/ssl/images/site-icon/favicon-96x96.png\">\r\n  <link rel=\"icon\" type=\"image/png\" sizes=\"16x16\" href=\"https://www.tepco-sa.co.jp/ssl/images/site-icon/favicon-16x16.png\">\r\n  <link rel=\"manifest\" href=\"https://www.tepco-sa.co.jp/ssl/images/site-icon/manifest.json\">\r\n  <meta name=\"msapplication-TileColor\" content=\"#ffffff\">\r\n  <meta name=\"msapplication-TileImage\" content=\"https://www.tepco-sa.co.jp/ssl/images/site-icon/ms-icon-144x144.png\">\r\n  <meta name=\"theme-color\" content=\"#ffffff\">\r\n\r\n  <!--google fonts-->\r\n  <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\r\n  <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\r\n  <link href=\"https://fonts.googleapis.com/css2?family=Hina+Mincho&family=Zen+Maru+Gothic:wght@400;500;700;900&display=swap\" rel=\"stylesheet\">\r\n\r\n  <!--css-->\r\n  <link href=\"https://www.tepco-sa.co.jp/ssl/src/css/vendor.css\" rel=\"stylesheet\">\r\n  <link href=\"https://www.tepco-sa.co.jp/ssl/src/css/theme.css\" rel=\"stylesheet\">\r\n  <link href=\"https://www.tepco-sa.co.jp/ssl/src/css/themes/top.css\" rel=\"stylesheet\">\r\n  <script src=\"https://www.tepco-sa.co.jp/ssl/src/js/jquery.min.js\"></script>\r\n\r\n  <!-- Google Tag Manager -->\r\n  <script>(function (w, d, s, l, i) {\r\n      w[l] = w[l] || []; w[l].push({\r\n        'gtm.start':\r\n          new Date().getTime(), event: 'gtm.js'\r\n      }); var f = d.getElementsByTagName(s)[0],\r\n        j = d.createElement(s), dl = l != 'dataLayer' ? '&l=' + l : ''; j.async = true; j.src =\r\n          'https://www.googletagmanager.com/gtm.js?id=' + i + dl; f.parentNode.insertBefore(j, f);\r\n    })(window, document, 'script', 'dataLayer', 'GTM-P8XXC67');</script>\r\n  <!-- End Google Tag Manager -->\r\n</head>\r\n\r\n<body>\r\n  <!-- Google Tag Manager (noscript) -->\r\n  <noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-P8XXC67\" height=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\r\n  <!-- End Google Tag Manager (noscript) -->\r\n\r\n  <div id=\"header\"></div>\r\n  <script>\r\n    $(function () {\r\n      $('#header').load('/ssl/src/inc/header.html');\r\n    });\r\n  </script>\r\n\r\n  <div class=\"page-wrapper top-page\">\r\n    <div class=\"sc-hero-slider\">\r\n      <div class=\"slider-box position-relative\">\r\n        <div class=\"img-wrapper\">\r\n          <img class=\"slider-pc\" src=\"https://www.tepco-sa.co.jp/ssl/images/top-page/hero-img-1.png\" alt=\"hero-img\">\r\n          <img class=\"slider-sp\" src=\"https://www.tepco-sa.co.jp/ssl/images/top-page/hero-img-1-sp.png\" alt=\"hero-img\">\r\n        </div>\r\n      </div>\r\n      <div class=\"slider-box position-relative\">\r\n        <div class=\"img-wrapper\">\r\n          <img class=\"slider-pc\" src=\"https://www.tepco-sa.co.jp/ssl/images/top-page/hero-img-2.png\" alt=\"hero-img\">\r\n          <img class=\"slider-sp\" src=\"https://www.tepco-sa.co.jp/ssl/images/top-page/hero-img-2-sp.png\" alt=\"hero-img\">\r\n        </div>\r\n      </div>\r\n      <div class=\"slider-box position-relative\">\r\n        <div class=\"img-wrapper\">\r\n          <img class=\"slider-pc\" src=\"https://www.tepco-sa.co.jp/ssl/images/top-page/hero-img-3.png\" alt=\"hero-img\">\r\n          <img class=\"slider-sp\" src=\"https://www.tepco-sa.co.jp/ssl/images/top-page/hero-img-3-sp.png\" alt=\"hero-img\">\r\n        </div>\r\n      </div>\r\n      <div class=\"slider-box position-relative\">\r\n        <div class=\"img-wrapper\">\r\n          <img class=\"slider-pc\" src=\"https://www.tepco-sa.co.jp/ssl/images/top-page/hero-img-4.png\" alt=\"hero-img\">\r\n          <img class=\"slider-sp\" src=\"https://www.tepco-sa.co.jp/ssl/images/top-page/hero-img-4-sp.png\" alt=\"hero-img\">\r\n        </div>\r\n      </div>\r\n    </div>\r\n    <div class=\"main-container sc-notice-recipient\">\r\n      <div class=\"title-wrapper fw-bold no-border-title alert\">重要なお知らせ</div>\r\n      <div class=\"fn-gen-maru-gothic title-wrapper fw-bold no-border-title text-center\">テプコ・ソリューション・アドバンスからのお知らせを受け取られた方</div>\r\n      <div class=\"notice-wrapper mb-4\">\r\n        <div class=\"left-top\">\r\n          <div class=\"notice-wrapper__ttl fn-gen-maru-gothic\">電気設備の安全点検でご訪問します</div>\r\n          <div class=\"notice-wrapper__img\">\r\n            <img src=\"https://www.tepco-sa.co.jp/ssl/images/top-page/notice-left.png\" alt=\"notice-img\">\r\n          </div>\r\n          <div class=\"notice-wrapper__txt\">\r\n            <p class=\"para-text\">\r\n              訪問時には作業員は写真入りの従事者証をつけてお伺いします。電気製品などの販売や金銭を請求することは一切ありません。\r\n            </p>\r\n            <p class=\"para-text\">\r\n              当社は登録調査機関として東京電力パワーグリッド株式会社より委託を受け、4年に1度の法定調査を行っております。\r\n            </p>\r\n          </div>\r\n          <a href=\"https://www.tepco-sa.co.jp/ssl/business/homes/safety-inspection/\" class=\"sc-btn btn-detail-orange d-flex align-items-center justify-content-between ms-auto\">くわしくはこちら\r\n            <svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"currentColor\">\r\n              <path d=\"M19.376 12.4161L8.77735 19.4818C8.54759 19.635 8.23715 19.5729 8.08397 19.3432C8.02922 19.261 8 19.1645 8 19.0658V4.93433C8 4.65818 8.22386 4.43433 8.5 4.43433C8.59871 4.43433 8.69522 4.46355 8.77735 4.5183L19.376 11.584C19.6057 11.7372 19.6678 12.0477 19.5146 12.2774C19.478 12.3323 19.4309 12.3795 19.376 12.4161Z\">\r\n              </path>\r\n            </svg>\r\n          </a>\r\n        </div>\r\n        <div class=\"right-top\">\r\n          <div class=\"notice-wrapper__ttl fn-gen-maru-gothic\">配電設備などの電気工事にともなう停電のお知らせをします</div>\r\n          <div class=\"notice-wrapper__img\">\r\n            <img src=\"https://www.tepco-sa.co.jp/ssl/images/top-page/notice-right.png\" alt=\"notice-img\">\r\n          </div>\r\n          <div class=\"notice-wrapper__txt\">\r\n            <p class=\"para-text\">停電がともなう東京電力パワーグリッド株式会社の電気設備の工事にともない、お客さまへ停電のお知らせをする業務を東京電力パワーグリッド株式会社より委託を受け、対象のお客さまへお知らせを配付、郵送しております。</p>\r\n          </div>\r\n          <a href=\"https://www.tepco-sa.co.jp/ssl/business/homes/safety-inspection/#a1\" class=\"sc-btn btn-detail-orange d-flex align-items-center justify-content-between ms-auto\">くわしくはこちら\r\n            <svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"currentColor\">\r\n              <path d=\"M19.376 12.4161L8.77735 19.4818C8.54759 19.635 8.23715 19.5729 8.08397 19.3432C8.02922 19.261 8 19.1645 8 19.0658V4.93433C8 4.65818 8.22386 4.43433 8.5 4.43433C8.59871 4.43433 8.69522 4.46355 8.77735 4.5183L19.376 11.584C19.6057 11.7372 19.6678 12.0477 19.5146 12.2774C19.478 12.3323 19.4309 12.3795 19.376 12.4161Z\">\r\n              </path>\r\n            </svg>\r\n          </a>\r\n        </div>\r\n        <div class=\"left-bottom\">\r\n          <div class=\"notice-wrapper__img\"><img src=\"https://www.tepco-sa.co.jp/ssl/images/top-page/permit-1.png\" alt=\"\" width=\"320\"></div>\r\n          <div class=\"d-md-none mt-4\">\r\n            <div class=\"fn-gen-maru-gothic title-wrapper fw-bold no-border-title text-center\">\r\n              作業員は従事者証を携帯しています\r\n            </div>\r\n          </div>\r\n        </div>\r\n        <div class=\"right-bottom\">\r\n          <div class=\"notice-wrapper__img\"><img src=\"https://www.tepco-sa.co.jp/ssl/images/top-page/permit-2.png\" alt=\"\" width=\"320\"></div>\r\n        </div>\r\n      </div>\r\n      <div class=\"bottom\">\r\n        <div class=\"fn-gen-maru-gothic title-wrapper fw-bold no-border-title text-center\">\r\n          作業員は従事者証を携帯しています\r\n        </div>\r\n        <p class=\"para-text text-center\">社員や提携工事会社を装った詐欺・窃盗・悪質な勧誘には十分にご注意ください</p>\r\n      </div>\r\n    </div>\r\n    <div class=\"main-container sc-group-container sc-gap\">\r\n      <div class=\"sc-about d-flex flex-column flex-lg-row\">\r\n        <div class=\"about-text\">\r\n          <div class=\"fn-gen-maru-gothic title-wrapper fw-bold\">\r\n            TSAについて\r\n          </div>\r\n          <div class=\"descp-wrapper d-flex flex-column\">\r\n            <p class=\"para-text mb-0\">\r\n              テプコ・ソリューション・アドバンス株式会社（TSA）は東京電力パワーグリッド株式会社の100%子会社として、電気・ガスにかかわる業務を受託しています。\r\n            </p>\r\n            <p class=\"para-text\">\r\n              受託業務で培った知見を活かし、バックオフィス業務から現場作業まで一貫して対応し、お客さまの快適なくらしや企業の業務効率化まで幅広くサポートしています。\r\n            </p>\r\n          </div>\r\n        </div>\r\n        <div class=\"img-wrapper\">\r\n          <img src=\"https://www.tepco-sa.co.jp/ssl/images/top-page/about-logo.png\" alt=\"logo-img\">\r\n        </div>\r\n      </div>\r\n      <div class=\"sc-strength\">\r\n        <div class=\"fn-gen-maru-gothic title-wrapper fw-bold\">TSAの強み</div>\r\n        <div class=\"strength-list d-flex flex-column\">\r\n          <div class=\"strength-card sc-box\">\r\n            <div class=\"count-title d-flex align-items-center flex-column flex-md-row\">\r\n              <div class=\"count-circle d-flex flex-column align-items-center justify-content-center\">\r\n                <div class=\"point fw-normal\">Strength</div>\r\n                <div class=\"count-num\">1</div>\r\n              </div>\r\n              <div class=\"menu-title fw-bold\">25年の実績とノウハウの蓄積</div>\r\n            </div>\r\n            <p class=\"menu-descp para-text\">\r\n              電気の契約管理や料金計算、現場作業といった業務を通じて、制度や業界の変化に適応しながら蓄積してきた知見とノウハウがあります。これらを活かし、高度な業務処理はもちろん、業務フローの改善や最適化にも貢献します。\r\n            </p>\r\n            <button data-target=\"strength01\" type=\"button\" class=\"js-modal-open sc-btn btn-detail-orange d-flex align-items-center justify-content-between ms-auto\">くわしくはこちら\r\n              <svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"currentColor\">\r\n                <path d=\"M19.376 12.4161L8.77735 19.4818C8.54759 19.635 8.23715 19.5729 8.08397 19.3432C8.02922 19.261 8 19.1645 8 19.0658V4.93433C8 4.65818 8.22386 4.43433 8.5 4.43433C8.59871 4.43433 8.69522 4.46355 8.77735 4.5183L19.376 11.584C19.6057 11.7372 19.6678 12.0477 19.5146 12.2774C19.478 12.3323 19.4309 12.3795 19.376 12.4161Z\">\r\n                </path>\r\n              </svg>\r\n            </button>\r\n            <div id=\"strength01\" class=\"c-modal js-modal\">\r\n              <div class=\"c-modal__bg js-modal-close\"></div>\r\n              <div class=\"c-modal__content\">\r\n                <button class=\"c-modal__close js-modal-close\"><img src=\"https://www.tepco-sa.co.jp/ssl/images/icons/close.svg\" alt=\"close\"></button>\r\n                <div class=\"c-modal__inner\">\r\n                  <div class=\"strength01\">\r\n                    <div><img src=\"https://www.tepco-sa.co.jp/ssl/images/top-page/strength1-1.png\" alt=\"\"></div>\r\n                    <div><img src=\"https://www.tepco-sa.co.jp/ssl/images/top-page/strength1-2.png\" alt=\"\"></div>\r\n                  </div>\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n          <div class=\"strength-card sc-box\">\r\n            <div class=\"count-title d-flex align-items-center flex-column flex-md-row\">\r\n              <div class=\"count-circle d-flex flex-column align-items-center justify-content-center\">\r\n                <div class=\"point fw-normal\">Strength</div>\r\n                <div class=\"count-num\">2</div>\r\n              </div>\r\n              <div class=\"menu-title fw-bold\">電気事業に関する幅広い業務領域</div>\r\n            </div>\r\n            <p class=\"menu-descp para-text\">\r\n              電気事業に関わるバックオフィス業務から現場作業まで、多岐にわたる業務を担い、幅広いニーズにお応えします。業務の特性に応じて最適なサービスを提供し、電気事業に関わるあらゆる業務を支援します。\r\n            </p>\r\n            <button data-target=\"strength02\" type=\"button\" class=\"js-modal-open sc-btn btn-detail-orange d-flex align-items-center justify-content-between ms-auto\">くわしくはこちら\r\n              <svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"currentColor\">\r\n                <path d=\"M19.376 12.4161L8.77735 19.4818C8.54759 19.635 8.23715 19.5729 8.08397 19.3432C8.02922 19.261 8 19.1645 8 19.0658V4.93433C8 4.65818 8.22386 4.43433 8.5 4.43433C8.59871 4.43433 8.69522 4.46355 8.77735 4.5183L19.376 11.584C19.6057 11.7372 19.6678 12.0477 19.5146 12.2774C19.478 12.3323 19.4309 12.3795 19.376 12.4161Z\">\r\n                </path>\r\n              </svg>\r\n            </button>\r\n            <div id=\"strength02\" class=\"c-modal js-modal\">\r\n              <div class=\"c-modal__bg js-modal-close\"></div>\r\n              <div class=\"c-modal__content\">\r\n                <button class=\"c-modal__close js-modal-close\"><img src=\"https://www.tepco-sa.co.jp/ssl/images/icons/close.svg\" alt=\"close\"></button>\r\n                <div class=\"c-modal__inner\">\r\n                  <div class=\"text-center\">\r\n                    <img src=\"https://www.tepco-sa.co.jp/ssl/images/top-page/strength2.png\" alt=\"\">\r\n                  </div>\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n          <div class=\"strength-card sc-box\">\r\n            <div class=\"count-title d-flex align-items-center flex-column flex-md-row\">\r\n              <div class=\"count-circle d-flex flex-column align-items-center justify-content-center\">\r\n                <div class=\"point fw-normal\">Strength</div>\r\n                <div class=\"count-num\">3</div>\r\n              </div>\r\n              <div class=\"menu-title fw-bold\">関東エリアをカバーする拠点網</div>\r\n            </div>\r\n            <p class=\"menu-descp para-text\">\r\n              関東一円に拠点を構えることで、お客さまのニーズに応じた業務を、最適なタイミングで提供できる体制を整えています。電気事業の専門性とエリアを網羅する拠点ネットワークを掛け合わせ、貴社の確かなパートナーとして事業を支援します。\r\n            </p>\r\n            <button data-target=\"strength03\" type=\"button\" class=\"js-modal-open sc-btn btn-detail-orange d-flex align-items-center justify-content-between ms-auto\">くわしくはこちら\r\n              <svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"currentColor\">\r\n                <path d=\"M19.376 12.4161L8.77735 19.4818C8.54759 19.635 8.23715 19.5729 8.08397 19.3432C8.02922 19.261 8 19.1645 8 19.0658V4.93433C8 4.65818 8.22386 4.43433 8.5 4.43433C8.59871 4.43433 8.69522 4.46355 8.77735 4.5183L19.376 11.584C19.6057 11.7372 19.6678 12.0477 19.5146 12.2774C19.478 12.3323 19.4309 12.3795 19.376 12.4161Z\">\r\n                </path>\r\n              </svg>\r\n            </button>\r\n            <div id=\"strength03\" class=\"c-modal js-modal\">\r\n              <div class=\"c-modal__bg js-modal-close\"></div>\r\n              <div class=\"c-modal__content\">\r\n                <button class=\"c-modal__close js-modal-close\"><img src=\"https://www.tepco-sa.co.jp/ssl/images/icons/close.svg\" alt=\"close\"></button>\r\n                <div class=\"c-modal__inner\">\r\n                  <div class=\"text-center\">\r\n                    <img src=\"https://www.tepco-sa.co.jp/ssl/images/top-page/strength3.png\" alt=\"\">\r\n                  </div>\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n      <div class=\"sc-business-contents\">\r\n        <div class=\"fn-gen-maru-gothic title-wrapper fw-bold\">幅広い事業内容</div>\r\n        <div class=\"row content-list\">\r\n          <div class=\"col-12 col-md-6 col-lg-4\">\r\n            <a href=\"https://www.tepco-sa.co.jp/ssl/business/homes/community-support/\" class=\"card orange position-relative\">\r\n              <div class=\"fn-gen-maru-gothic fw-semibold business-title\">TEPCO<br>\r\n                コミュニティサポート</div>\r\n              <div class=\"description\">みなさまの電気にまつわる日々のくらしや非常時の安心のためにお手伝いします</div>\r\n              <div class=\"img-wrapper\">\r\n                <img src=\"https://www.tepco-sa.co.jp/ssl/image