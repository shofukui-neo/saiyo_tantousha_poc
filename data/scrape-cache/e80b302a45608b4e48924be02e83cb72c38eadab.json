>\n      </a>\n    </li>\n    <li class=\"gNav__item gNav__item--normal dn-pc\">\n      <a href=\"/information\">\n        <span class=\"gNav__item__inner\">\n          情報公開\n        </span>\n      </a>\n    </li>\n    <li class=\"gNav__item gNav__item--normal gNav__item--fb\">\n      <a href=\"https://www.facebook.com/profile.php?id=61553735414491\" target=\"_blank\">\n        <span class=\"dn-pc\">Facebook</span>\n      </a>\n    </li>\n    <li class=\"gNav__item gNav__item--normal gNav__item--contact\">\n            <a href=\"/contact/\">\n              <span class=\"gNav__item__inner\">\n                お問い合わせ\n              </span>\n            </a>\n          </li>\n    <li class=\"gNav__item gNav__item--close dn-pc\">\n      <a class=\"drawer-toggle\">\n        閉じる\n      </a>\n    </li>\n  </ol>\n</nav>    <!-- /global navi -->\n  </div>\n</header>    <!-- /header -->\n\n    <!-- main container -->\n    <main>\n      <div role=\"main\">\n                <!-- 01 top-slider -->\n        <div class=\"top-slider\">\n          <div class=\"top-slider__item\">\n            <img src=\"/theme/furukawa_consultant/img/top/kv_item_01.png\" alt=\"自然を生かして、人を生かす\" class=\"imgFit itemImg-catch\">\n            <!-- SCROLL DOWN -->\n            <a href=\"#top-contents\" class=\"top-slider__crdown\">\n              <div class=\"arrowWrap\">\n                <div class=\"arrowInner\">\n                  <p>SCROLL DOWN</p>\n                  <div class=\"arrow\"><span>thinsp;</span>&</div>\n                </div>\n              </div>\n            </a>\n            <!-- /SCROLL DOWN -->\n          </div>\n          <div class=\"top-kvMypattern\">\n            <!-- 1-1 -->\n            <div class=\"top-kvMypattern__item top-kvMypattern__item--01\">\n              <div class=\"top-kvMypattern__item__inner\">\n                <img src=\"/theme/furukawa_consultant/img/top/kv_slide_item_01.png\" alt=\"Research design｜設計部\" class=\"imgFit itemImg-title\">\n              </div>\n            </div>\n            <!-- /1-1 -->\n            <!-- 1-2 -->\n            <div class=\"top-kvMypattern__item top-kvMypattern__item--02\">\n              <div class=\"top-kvMypattern__item__inner\">\n                <img src=\"/theme/furukawa_consultant/img/top/kv_slide_item_02.png\" alt=\"Survrying research｜測量部\" class=\"imgFit itemImg-title\">\n              </div>\n            </div>\n            <!-- /1-2 -->\n            <!-- 1-3 -->\n            <div class=\"top-kvMypattern__item top-kvMypattern__item--03\">\n              <div class=\"top-kvMypattern__item__inner\">\n                <img src=\"/theme/furukawa_consultant/img/top/kv_slide_item_03.png\" alt=\"Geological research｜地質部\" class=\"imgFit itemImg-title\">\n              </div>\n            </div>\n            <!-- /1-3 -->\n            <!-- 1-4 -->\n            <div class=\"top-kvMypattern__item top-kvMypattern__item--04\">\n              <div class=\"top-kvMypattern__item__inner\">\n                <img src=\"/theme/furukawa_consultant/img/top/kv_slide_item_04.png\" alt=\"Architecture compensation｜建築補償部\" class=\"imgFit itemImg-title\">\n              </div>\n            </div>\n            <!-- /1-4 -->\n            <!-- 1-5 -->\n            <div class=\"top-kvMypattern__item top-kvMypattern__item--05\"></div>\n            <!-- /1-5 -->\n          </div>\n        </div>\n        <!-- /01 top-slider -->\n        <!-- recruit-bnr -->\n        <div class=\"top-recruitBnr\">\n          <a href=\"/recruit/guideline/\">\n            <img src=\"/theme/furukawa_consultant/img/top/job_banner.jpg\" alt=\"正社員募集中　技術職事務職　詳しくはこちら\" class=\"imgFit\">\n          </a>\n        </div>\n        <!-- /recruit-bnr -->\n        <!-- 02 about -->\n        <section class=\"top-about\" id=\"top-contents\">\n          <div class=\"top-about__h2\">\n            <img src=\"/theme/furukawa_consultant/img/top/about_item_01.png\" alt=\"株式会社古川コンサルタント｜ロゴマーク\" class=\"imgFit\">\n            <h2>\n            〜自然を生かし人を生かす〜<br>\n            島根県出雲市の総合建設<span class=\"d-inlineBlock\">コンサルタント</span>\n          </h2>\n        </div>\n        <p class=\"top-about__text\">\n          私たち「株式会社古川コンサルタント」は島根県出雲市の総合建設コンサルタントとして「自然を生かして人を生かす」をテーマに、自然環境、お客様、地域住民の皆様のことをトータル的に考えながら今まで培ってきた経験と総合的な技術力で事業を展開しています。私たちだからこそできる「地域社会との共存」を目指し、農村・都市基盤整備の企画・調査から施工管理まで幅広いニーズに即応しています。\n        </p>\n          <div class=\"top-about__img\">\n            <img src=\"/theme/furukawa_consultant/img/top/about_item_02.png\" alt=\"地域で暮らす人々のイラスト\" class=\"imgFit\">\n          </div>\n          <div class=\"top-about__btn\">\n            <a href=\"/about\" class=\"mod-btn-01 mod-btn-w500 hoverNot\">\n              <span class=\"mod-btn-01__inner\">\n                私たちの事業について\n              </span>\n            </a>\n          </div>\n        </section>\n        <!-- /02 about -->\n        <!-- 03 guide-bnr -->\n        <div class=\"top-guideBnrBox mod-bg-cLB\">\n          <div class=\"l-container clearfix\">\n            <!-- 3-1 -->\n            <a href=\"/casebook/casebooks/\" class=\"top-guideBnr matchHeight hoverNot\">\n              <span class=\"top-guideBnr__img\">\n                <img src=\"/theme/furukawa_consultant/img/top/bnr_works_01.jpg\" alt=\"事業実績の写真\" class=\"imgObjectFitCover\">\n              </span>\n              <span class=\"top-guideBnr__main\">\n                <span class=\"top-guideBnr__main__title\">\n                  事 業 実 績\n                </span>\n                <span class=\"top-guideBnr__main__text\">\n                今まで関わらせていただいた業務を紹介いたします。随時更新していきます。\n                </span>\n              </span>\n            </a>\n            <!-- /3-1 -->\n            <!-- 3-2 -->\n            <a href=\"/company\" class=\"top-guideBnr matchHeight hoverNot\">\n              <span class=\"top-guideBnr__img\">\n                <img src=\"/theme/furukawa_consultant/img/top/bnr_company_01.jpg\" alt=\"株式会社古川コンサルタントの外観写真\" class=\"imgObjectFitCover\">\n              </span>\n              <span class=\"top-guideBnr__main\">\n                <span class=\"top-guideBnr__main__title\">\n                  会 社 案 内\n                </span>\n                <span class=\"top-guideBnr__main__text\">\n                株式会社古川コンサルタントの会社概要・支店・営業所等のご紹介をいたします。\n                </span>\n              </span>\n            </a>\n            <!-- /3-2 -->\n            <!-- 3-3 -->\n            <a href=\"/recruit/index\" class=\"top-guideBnr matchHeight hoverNot\">\n              <span class=\"top-guideBnr__img\">\n                <img src=\"/theme/furukawa_consultant/img/top/bnr_recruit_01.jpg\" alt=\"社員の写真\" class=\"imgObjectFitCover\">\n              </span>\n              <span class=\"top-guideBnr__main\">\n                <span class=\"top-guideBnr__main__title\">\n                  採 用 情 報\n                </span>\n                <span class=\"top-guideBnr__main__text\">\n                私たちと一緒に街・人・地域の未来づくりに貢献しませんか。随時募集しております。\n                </span>\n              </span>\n            </a>\n            <!-- /3-3 -->\n          </div>\n        </div>\n        <!-- /03 guide-bnr -->\n        <!-- 04 news -->\n        <section class=\"top-news\">\n          <div class=\"top-news__h2\">\n            <img src=\"/theme/furukawa_consultant/img/top/news_hl_01.png\" alt=\"新着情報 NEWS & TOPICS\" class=\"imgFit\">\n            <h2 class=\"dn\">新着情報 NEWS & TOPICS</h2>\n          </div>\n          <div class=\"top-newsArticleContainer\">\n            \n\n        <article class=\"top-newsArticle\">\n          <a href=\"/news/archives/213\" class=\"top-newsArticle__inner\">\n            <time class=\"top-newsArticle__date\" datetime=\"2026-04-01\">2026.04.01</time>\n                        <span class=\"top-newsArticle__catTag\">社内情報</span>\n            <h2 class=\"top-newsArticle__title\">令和8年度　年度始式</h2>\n          </a>\n        </article>\n        <article class=\"top-newsArticle\">\n          <a href=\"/news/archives/214\" class=\"top-newsArticle__inner\">\n            <time class=\"top-news