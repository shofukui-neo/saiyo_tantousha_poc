ackground: var(--wp--preset--gradient--midnight) !important;}.has-small-font-size{font-size: var(--wp--preset--font-size--small) !important;}.has-medium-font-size{font-size: var(--wp--preset--font-size--medium) !important;}.has-large-font-size{font-size: var(--wp--preset--font-size--large) !important;}.has-x-large-font-size{font-size: var(--wp--preset--font-size--x-large) !important;}\n/*# sourceURL=global-styles-inline-css */\n</style>\n\n<link rel=\"https://api.w.org/\" href=\"https://www.ttk-g.co.jp/recruit/wp-json/\" /><link rel=\"alternate\" title=\"JSON\" type=\"application/json\" href=\"https://www.ttk-g.co.jp/recruit/wp-json/wp/v2/posts/82\" /><link rel=\"EditURI\" type=\"application/rsd+xml\" title=\"RSD\" href=\"https://www.ttk-g.co.jp/recruit/cmssys/xmlrpc.php?rsd\" />\n<meta name=\"generator\" content=\"WordPress 7.0\" />\n<link rel=\"canonical\" href=\"https://www.ttk-g.co.jp/recruit/post-82/\" />\n<link rel='shortlink' href='https://www.ttk-g.co.jp/recruit/?p=82' />\n\n</head>\n\n<body class=\"recruit recruit_pages\">\n  <div id=\"header-container\"></div>\n\n    <div class=\"mv\">\n    <h2 class=\"mv_tit\">\n      <span class=\"en\">NEWS</span><br>\n      <span class=\"jp\">新着情報</span>\n    </h2>\n\n    <ol class=\"breadcrumb\" itemscope itemtype=\"http://schema.org/BreadcrumbList\">\n      <li itemprop=\"itemListElement\" itemscope itemtype=\"http://schema.org/ListItem\">\n        <a itemprop=\"item\" href=\"../\"><span itemprop=\"name\">TOP</span></a>\n        <meta itemprop=\"position\" content=\"1\" />\n      </li>\n      <li itemprop=\"itemListElement\" itemscope itemtype=\"http://schema.org/ListItem\">\n        <span itemprop=\"name\">News</span>\n        <meta itemprop=\"position\" content=\"2\" />\n      </li>\n    </ol>\n  </div><!-- mv -->\n  \n  <main class=\"news co-detail\">\n\n    \n<section class=\"area01 inner02\">\n\n        <div class=\"tit_wrap\">\n        <div class=\"date\">2026/03/01</div>\n        <div class=\"category cate02\">説明会情報</div>\n        <p class=\"title\">令和９年度　新卒採用活動をスタートいたしました</p>\n    </div>\n    <div class=\"article\">\n        \n<p class=\"wp-block-paragraph\">令和９年度新卒採用のご応募受付を開始しました。<br>下記により、会社説明会を開催いたします。</p>\n\n\n\n<p class=\"wp-block-paragraph\">マイナビ2027よりご予約の上、ぜひご参加下さい。<br>たくさんのご応募をお待ちしております。</p>\n\n\n\n<p class=\"wp-block-paragraph\">◆◇◆ ＴＴＫ 会社説明会のご案内 ◆◇◆</p>\n\n\n\n<p class=\"wp-block-paragraph\">【日時】</p>\n\n\n\n<p class=\"wp-block-paragraph\">・3月16日（月）10：00～11：30、14：00～15：30</p>\n\n\n\n<p class=\"wp-block-paragraph\">・3月17日（火）10：00～11：30、14：00～15：30</p>\n\n\n\n<p class=\"wp-block-paragraph\">・3月25日（水）10：00～11：30、14：00～15：30</p>\n\n\n\n<p class=\"wp-block-paragraph\">【内容】</p>\n\n\n\n<p class=\"wp-block-paragraph\">・会社概要、採用条件・募集要項の説明<br>・社員との対話会</p>\n\n\n\n<p class=\"wp-block-paragraph\">【場所】</p>\n\n\n\n<p class=\"wp-block-paragraph\">株式会社ＴＴＫ本社7階会議室<br>〒984－8558 仙台市若林区新寺1丁目2－23<br>JR各線仙台駅東口から徒歩5分<br>※駐車場はございませんので公共機関を利用してお越し下さい。</p>\n\n\n\n<p class=\"wp-block-paragraph\">★当日の受付は、開始15分前からとなります。</p>\n\n\n\n<p class=\"wp-block-paragraph\">★定員数に限りがあります。お早めにご予約ください。</p>\n\n\n\n<p class=\"wp-block-paragraph\">★当日は社員より、実際の仕事内容をご紹介させていただいたり、<br>皆さんから質問を受け付ける時間を設ける予定です。</p>\n\n\n\n<p class=\"wp-block-paragraph\">マイナビ2027よりご予約の上、ぜひご参加下さい！</p>\n    </div>\n    \n    <div class=\"button\"><a href=\"https://www.ttk-g.co.jp/recruit/news/\">一覧へ戻る</a></div>\n</section>\n\n\n</main>\n\n<div class=\"page-top\"><a href=\"#\"><img src=\"../lib/cmn-img/pagetop.png\" alt=\"\"></a></div>\n\n<div id=\"footer-container\"></div>\n\n<script src=\"/lib/cmn-js/all.js\"></script>\n<script type=\"module\" src=\"/statichtml/asset/js/recruit.js\"></script>\n<script type=\"text/javascript\">\n  $(function() {\n      $('.height').matchHeight();\n  });\n</script>\n\n<script type=\"speculationrules\">\n{\"prefetch\":[{\"source\":\"document\",\"where\":{\"and\":[{\"href_matches\":\"/recruit/*\"},{\"not\":{\"href_matches\":[\"/recruit/cmssys/wp-*.php\",\"/recruit/cmssys/wp-admin/*\",\"/recruit/cmssys/wp-c