('checked', false);\n            }\n          });\n        });\n      </script>\n\n    <script>\n    jQuery(document).ready(function($) {\n        // 1. サイドバーのアコーディオン\n        $('#newsSidebar li:has(.children) > a').after('<span class=\"cat-toggle\">＋</span>');\n        $('.cat-toggle').on('click', function() {\n            $(this).next('.children').slideToggle();\n            $(this).toggleClass('open');\n            $(this).text($(this).hasClass('open') ? '－' : '＋');\n        });\n\n        // 2. お問い合わせフォーム用\n        var otherArea = $('#mw_other_area');\n        var radioName = 'mw_overview';\n        if ($('input[name=\"' + radioName + '\"]:checked').val() === 'その他') {\n            otherArea.show();\n        } else {\n            otherArea.hide();\n        }\n        $('input[name=\"' + radioName + '\"]').on('change', function() {\n            if ($(this).val() === 'その他') {\n                otherArea.slideDown();\n            } else {\n                otherArea.slideUp();\n            }\n        });\n    }); // ここでしっかり閉じる\n    </script>\n\n    <!-- Instagram Feed JS -->\r\n<script type=\"text/javascript\">\r\nvar sbiajaxurl = \"https://www.takehanagumi.co.jp/wp-admin/admin-ajax.php\";\r\n</script>\r\n<script type='text/javascript' src='https://www.takehanagumi.co.jp/wp-content/plugins/mw-wp-form/js/form.js?ver=4.9.29'></script>\n<script type='text/javascript' src='https://www.google.com/recaptcha/api.js?render=6LdMNikrAAAAAAvTZfVkIDLUsXUc8nU17HgBZYqG&#038;ver=4.9.29'></script>\n<script type='text/javascript'>\ngrecaptcha.ready(function() {\n    grecaptcha.execute('6LdMNikrAAAAAAvTZfVkIDLUsXUc8nU17HgBZYqG', {\n            action: 'homepage'\n        }).then(function(token) {\n            var recaptchaResponse = jQuery('input[name=\"recaptcha-v3\"]');\n            recaptchaResponse.val(token);\n        });\n    });\n</script>\n<script type='text/javascript' src='https://www.takehanagumi.co.jp/wp-includes/js/wp-embed.min.js?ver=4.9.29'></script>\n<style>\n@media scr