class=\"mwform-radio-field horizontal-item\">\n\t\t<label for=\"mw_type-2\">\n\t\t\t<input type=\"radio\" name=\"mw_type\" value=\"新卒\" id=\"mw_type-2\" />\n\t\t\t<span class=\"mwform-radio-field-text\">新卒</span>\n\t\t</label>\n\t</span>\n\t<span class=\"mwform-radio-field horizontal-item\">\n\t\t<label for=\"mw_type-3\">\n\t\t\t<input type=\"radio\" name=\"mw_type\" value=\"インターンシップ\" id=\"mw_type-3\" />\n\t\t\t<span class=\"mwform-radio-field-text\">インターンシップ</span>\n\t\t</label>\n\t</span>\n\t<span class=\"mwform-radio-field horizontal-item\">\n\t\t<label for=\"mw_type-4\">\n\t\t\t<input type=\"radio\" name=\"mw_type\" value=\"会社説明会の申込み\" id=\"mw_type-4\" />\n\t\t\t<span class=\"mwform-radio-field-text\">会社説明会の申込み</span>\n\t\t</label>\n\t</span>\n\t<span class=\"mwform-radio-field horizontal-item\">\n\t\t<label for=\"mw_type-5\">\n\t\t\t<input type=\"radio\" name=\"mw_type\" value=\"お問い合わせ\" id=\"mw_type-5\" />\n\t\t\t<span class=\"mwform-radio-field-text\">お問い合わせ</span>\n\t\t</label>\n\t</span>\n\n<input type=\"hidden\" name=\"__children[mw_type][]\" value=\"{&quot;\\u4e2d\\u9014&quot;:&quot;\\u4e2d\\u9014&quot;,&quot;\\u65b0\\u5352&quot;:&quot;\\u65b0\\u5352&quot;,&quot;\\u30a4\\u30f3\\u30bf\\u30fc\\u30f3\\u30b7\\u30c3\\u30d7&quot;:&quot;\\u30a4\\u30f3\\u30bf\\u30fc\\u30f3\\u30b7\\u30c3\\u30d7&quot;,&quot;\\u4f1a\\u793e\\u8aac\\u660e\\u4f1a\\u306e\\u7533\\u8fbc\\u307f&quot;:&quot;\\u4f1a\\u793e\\u8aac\\u660e\\u4f1a\\u306e\\u7533\\u8fbc\\u307f&quot;,&quot;\\u304a\\u554f\\u3044\\u5408\\u308f\\u305b&quot;:&quot;\\u304a\\u554f\\u3044\\u5408\\u308f\\u305b&quot;}\" />\n</dd>\r\n</dl>\r\n\r\n<!--\r\n<dl class=\"table flex\">\r\n<dt>応募職種<span class=\"small\">中途</span></dt>\r\n<dd>&#091;mwform_radio name=\"mw_career\" children=\"土木現場施工管理職,建築現場施工管理職,現場施工管理職見習い（土木・建築）\" vertically=\"true\"&#093;</dd>\r\n</dl>\r\n\r\n<dl class=\"table flex\">\r\n<dt>応募職種<span class=\"small\">新卒</span></dt>\r\n<dd>&#091;mwform_radio name=\"mw_new\" children=\"土木現場施工管理職,建築現場施工管理職・設計職,総合職（営業・総