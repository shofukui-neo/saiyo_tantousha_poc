g (gtag.js) - Google Analytics -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-W07RKCEYM7\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n  gtag('config', 'G-W07RKCEYM7');\n</script>\n</head>\n\n<body class=\"wp-singular post-template-default single single-post postid-6729 single-format-standard wp-theme-template-original sec post post-6729 information detail\">\n\n\n<header id=\"HEADER_AREA\"><!-- Global header --></header>\n\n<div id=\"CONTENTS_AREA\">\n  <div id=\"PATH_BLOCK\"><div class=\"inner\">\n    <ol id=\"TOPICPATH_BLOCK\">\n      <li><a href=\"/\">ホーム</a></li>\n      <li><a href=\"/information/\">インフォメーション</a></li>\n      <li>年末年始期間の休業日と消耗品発送業務日程のご案内</li>\n    </ol>\n  </div></div>\n  \n  <main id=\"CONTENTS_BLOCK\">\n    \n    <!-- CONTENTS BLOCK-->\n    <article class=\"section_block article_block\"><div class=\"inner short\">\n      <div class=\"link_box top\"><a href=\"/information/\">< 一覧に戻る</a></div>\n      \n          <div class=\"header\">\n        <time class=\"time\" datetime=\"2025-12-05T17:30:44+09:00\">2025年12月5日</time>\n      \n          <span class=\"c_icon gray\">お知らせ</span>        <h1 class=\"title\">年末年始期間の休業日と消耗品発送業務日程のご案内</h1>\n      </div>\n      \n            \n      <div class=\"contents\"><div>いつもご利用ありがとうございます。<br />年末年始休暇期間および消耗品各種の発送についてご案内いたします。</div>\r\n<p><span id=\"more-6729\"></span><strong><span style=\"font-size: 14pt;\">◆年末年始休暇期間</span><br />２０２５年１２月２７日（土）～２０２６年１月４日（日）<br /></strong>※１２月２７日（土）９：００~１７：３０は電話サポートのみ対応<strong><br /></strong></p>\r\n<div>\r\n<div><strong><span style=\"font-size: 14pt;\">◆消耗品受付と出荷について</span><br /></strong><span style=\"color: #000000;\">年末年始は物流増加により着日のご希望に添えない場合がございます。余裕をもった早目のご依頼をお願いいたします。</span><strong><br /><br />【１】<span style=\"color: #000000;\">消耗品各種<span style=\"font-size: 8pt;\">（【２】【３】</span></span></strong><span style=\"font-size: 8pt; color: #000000;\"><strong>以外）</strong></span><br />\r\n<div>\r\n<div>最終受付日：１２月２５日（木）１２時まで</div>\r\n<div>\r\n<div>最終発送日：１２月２６日（金）</div>\r\n<div>\r\n<div>\r\n<div>受付開始日：　１月　５日（月）<br />発送開始日：　１月　５日（月）</div>\r\n</div>\r\n</div>\r\n</div>\r\n</div>\r\n</div>\r\n<div>\r\n<div>\r\n<div>\r\n<div> </div>\r\n</div>\r\n</div>\r\n<strong>【２】<span style=\"color: #000000;\">自動錠剤分包機ATCシリーズ用 分包紙・インクリボン（バイオメディカ社製）</span></strong></div>\r\n<div>\r\n<div>\r\n<div>最終受付日：１２月１８日（木）</div>\r\n<div>\r\n<div>最終発送日：１２月２６日（金）</div>\r\n<div>\r\n<div>受付開始日：　１月　５日（月）</div>\r\n<div>\r\n<div>発送開始日：　１月　６日（火）</div>\r\n</div>\r\n</div>\r\n</div>\r\n</div>\r\n<div><br />\r\n<div><strong>【３】<span style=\"color: #000000;\">代理店様向け 薬袋</span></strong><br />\r\n<div>最終受付日：１２月１７日（水）１５時まで</div>\r\n<div>\r\n<div>最終発送日：１２月１８日（木）</div>\r\n<div>\r\n<div>受付開始日：　１月　５日（月）</div>\r\n<div>\r\n<div>発送開始日：　１月　６日（火）</div>\r\n</div>\r\n</div>\r\n</div>\r\n</div>\r\n</div>\r\n</div>\r\n</div></div>\n        \n    <div class=\"link_box\"><a href=\"/information/\">< 一覧に戻る</a></div>\n    </div></article>\n  </main>\n\n</div>\n\n<footer id=\"FOOTER_AREA\"><!-- Global Footer --></footer>\n<script type=\"speculationrules\">\n{\"prefetch\":[{\"source\":\"document\",\"where\":{\"and\":[{\"href_matches\":\"/*\"},{\"not\":{\"href_matches\":[\"/wp-*.php\",\"/wp-admin/*\",\"/wp-content/uploads/*\",\"/wp-content/*\",\"/wp-content/plugins/*\",\"/wp-content/themes/template-original/*\",\"/*\\\\?(.+)\"]}},{\"not\":{\"selector_matches\":\"a[rel~=\\\"nofollow\\\"]\"}},{\"not\":{\"selector_matches\":\".no-prefetch, .no-prefetch a\"}}]},\"eagerness\":\"conservative\"}]}\n</script>\n<script id=\"contact-form-7-js-extra\">\nvar wpcf7 = {\"apiSettings\":{\"root\":\"https://www.e-medicom.co.jp/wp-json/contact-form-7/v1\",\"namespace\":\"contact-form-7/v1\"}};\n//# sourceURL=contact-form-7-js-extra\n</script>\n<script id=\"contact-form-7-js\" src=\"https://www.e-medicom.co.jp/wp-content/plugins/contact-form-7/includes/js/scripts.js?ver=5.3.2\"></script>\n<script id=\"cf7msm-js-extra