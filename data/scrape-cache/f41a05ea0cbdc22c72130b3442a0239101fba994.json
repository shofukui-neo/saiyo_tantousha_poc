-footer__ul__li__link2\">\n                                    インタビュー02 営業職\n                                </a>\n                                <a href=\"/recruit/interview/03/\" class=\"c-footer__ul__li__link2\">\n                                    インタビュー03 事務職\n                                </a>\n                                <a href=\"/recruit/cross-talk/\" class=\"c-footer__ul__li__link\">\n                                    営業 × 技能対談\n                                </a>\n                            </li>\n                            <li class=\"c-footer__ul__li\">\n                                <a href=\"javascript:void(0);\" class=\"c-footer__ul__li__main\">\n                                    採用を知る\n                                </a>\n                                <a href=\"/recruit/concept/\" class=\"c-footer__ul__li__link\">\n                                    採用コンセプト\n                                </a>\n                                <a href=\"/recruit/newgraduate/\" class=\"c-footer__ul__li__link\">\n                                    新卒採用情報\n                                </a>\n                                <a href=\"/recruit/career/\" class=\"c-footer__ul__li__link\">\n                                    中途採用情報\n                                </a>\n                            </li>\n                        </ul>\n                    </div>\n                </div>\n                <p class=\"c-footer__copyright\">\n                    © 2003 asahi-metal.com\n                </p>\n            </div>\n        </footer>\n\n        <script type=\"text/javascript\" src=\"/recruit/data/js/common/jquery.min.js?v=0.0.1\"></script>\n        <script type=\"text/javascript\" src=\"/recruit/data/js/common/jquery.lh.js?v=0.0.1\"></script>\n        <script src=\"https://unpkg.com/aos@2.3.1/dist/aos.js\"></script>\n        <script src=\"//cdn.jsdelivr.net/npm/vivus@latest/dist/vivus.min.js\"></script>\n        <script type=\"text/javascript\" 