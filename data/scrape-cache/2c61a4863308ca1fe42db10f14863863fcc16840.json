{"url":"https://www.hirojob.com/","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n\n<head>\n    <!-- Google Tag Manager -->\n    <script>(function (w, d, s, l, i) {\n            w[l] = w[l] || []; w[l].push({\n                'gtm.start':\n                    new Date().getTime(), event: 'gtm.js'\n            }); var f = d.getElementsByTagName(s)[0],\n                j = d.createElement(s), dl = l != 'dataLayer' ? '&l=' + l : ''; j.async = true; j.src =\n                    'https://www.googletagmanager.com/gtm.js?id=' + i + dl; f.parentNode.insertBefore(j, f);\n        })(window, document, 'script', 'dataLayer', 'GTM-WTQR8TQ');</script>\n    <!-- End Google Tag Manager -->\n    <meta charset=\"UTF-8\" />\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n    <title>【ヒロジョブ】｜広島の就職活動（就活）情報サイト</title>\n    <meta name=\"keywords\" content=\"広島,就職活動,就活,新卒採用,ヒロジョブ\" />\n    <meta name=\"description\" content=\"広島県の就活（就職活動）・新卒採用情報なら「ヒロジョブ」。人気の地元企業へのエントリーや説明会予約が可能。さらにヒロジョブだけの就活イベント・合同企業説明会も開催しています。\" />\n    <link rel=\"stylesheet\" href=\"css/reset.css\">\n    <link rel=\"stylesheet\" href=\"css/style.css?20200427\">\n    <link rel=\"stylesheet\" href=\"css/wideslider.css\">\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/animate.css/3.5.2/animate.css\">\n    <link rel=\"shortcut icon\" href=\"img/favicon.ico\" />\n    <script src=\"https://code.jquery.com/jquery-3.2.1.min.js\"></script>\n    <script src=\"js/pagetop.js\"></script>\n    <script src=\"js/wideslider.js\"></script>\n    <script src=\"js/footerFixed.js\"></script>\n    <script src=\"js/jquery.matchHeight.js\"></script>\n\n    <!--[if lt IE 9]>\n<script src=\"/gosetsu/js/html5shiv.js\"></script>\n<![endif]-->\n\n    <!--[if lt IE 9]>\n<script src=\"/gosetsu/js/selectivizr.js\"></script>\n<![endif]-->\n\n</head>\n\n<body>\n    <!-- Google Tag Manager (noscript) -->\n    <noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-WTQR8TQ\" height=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n    <!-- End Google Tag Manager (noscript) -->\n    <div id=\"wrapper\">\n      <header id=\"mainHeader\">\n          <div id=\"headerInner\">\n              <div class=\"headerInnerL\">\n                  <div class=\"headerWrap\">\n                      <div class=\"visitorNav\">\n                          <ul class=\"ull\">\n                              <li class=\"navlogo\">\n                              <p><img alt=\"広島の就活・就職活動情報サイトヒロジョブ\" src=\"img/logo_hirojob.png\"></p>\n                              </li>\n                          </ul>\n                      </div>\n                  </div>\n              </div>\n              <div class=\"headerInnerR\">\n                  <div class=\"HeaderInquiryBox02\">\n                      <a class=\"HeaderInquiryButton\" href=\"#forCompany\">採用企業様へ</a>\n                  </div>\n              </div>\n          </div>\n      </header>\n      <section>\n        <div class=\"mainImg\">\n          <div class=\"siteLogo mainImgText\">\n            <h1>広島で就職活動するなら<br>\n            <img alt=\"ヒロジョブ\" src=\"img/logo_hirojob.png\"></h1>\n          </div>\n        </div>\n        <div class=\"contents\">\n          <div class=\"contentsInner\">\n            <div class=\"contentsInnerFrame\">\n              <section>\n                <h2 class=\"content__title--1st\">ヒロジョブの就活生向けサービス</h2>\n                  <div class=\"contentsInnerBox\">\n                    <section>\n                    <h3 class=\"content__title--2nd\">広島地域密着！就活準備・新卒採用情報サイト</h3>\n                      <h4 class=\"content__title--3rd\">広島県での就職活動に役立つ情報や機能が満載</h4>\n                        <ul class=\"content__list\">\n                          <li>地元優良企業の新卒採用情報</li>\n                          <li>広島企業のインターンシップ&amp;キャリア・企業説明会情報</li>\n                          <li>気になる企業にはエントリー、説明会予約が可能</li>\n                          <li>その他就活ノウハウコンテンツなど…</li>\n                        </ul>\n                        <div class=\"contentsLinkArea clearfix\">\n                          <div class=\"siteBoxLeft\">\n                            <div class=\"siteBoxInner\">\n                              <a href=\"https://hirojob.com/2027/\" target=\"_blank\" class=\"link\"></a>\n                              <div class=\"siteTitle\">\n                                <h5 class=\"siteBoxTitle\">2027年3月に卒業予定の方はこちら</h5>\n                              </div>\n                              <div class=\"siteLogo\">\n                              <img alt=\"27卒向け。広島県の就活情報サイト ヒロジョブ2027\" src=\"img/logo_hirojob_2027.png\">\n                              </div>\n                            </div>\n                          </div>\n                          <div class=\"siteBoxRight\">\n                            <div class=\"siteBoxInner\" style=\"height: 120.781px;\">\n                              <a href=\"https://hirojob.com/2028/\" target=\"_blank\" class=\"link\"></a>\n                              <div class=\"siteTitle\">\n                                <h5 class=\"siteBoxTitle\">2028年3月に卒業予定の方はこちら</h5>\n                              </div>\n                              <div class=\"siteLogo\">\n                                <img alt=\"28卒向け。広島県の就活情報サイト ヒロジョブ2028\" src=\"img/logo_hirojob_2028.png\">\n                              </div>\n                            </div>\n                          </div>\n                        </div>\n                      <h4 class=\"content__title--3rd\">広島以外の就活情報サイトはこちら</h4>\n                      <ul>\n                        <li class=\"content__link-list\"><a href=\"http://www.okajob.com/\" target=\"_blank\">&gt; 岡山県の就活ならオカジョブ</a></li>\n                      </ul>\n\n\t\t\t\t\t  <h3 class=\"content__title--2nd\">就活にもっとワクワクを！</h3>\n                      <h4 class=\"content__title--3rd\">シーズ就活サロンで成功の”種”を蒔こう</h4>\n                      <div class=\"contentsInnerBox2 clearfix\">\n                        <div class=\"contentsInnerBox2Right\">\n                          <a href=\"https://syukatsu-salon.seedsjp.com/\" target=\"_blank\"><img alt=\"就活にもっとワクワクを！シーズ就活サロン\" src=\"img/syukatsu-salon_img.png\"></a>\n                        </div>\n                        <div class=\"contentsInnerBox2Left\">\n                          <p>\n\t\t\t\t\t\t\tシーズ就活サロンは、広島・岡山で就職したい学生を対象に、就活対策・準備を応援する無料の就活サロン。就活イベントを開催する他、ブログでは就活イベントの様子やリアルな就活生の声をお届け。<br>\n\t\t\t\t\t\t\t一緒に「楽しく」就活準備を進めよう！\n\t\t\t\t\t\t</p>\n                          <p>LINE公式アカウントでは広島・岡山開催の就活イベントの案内やお役立ち情報など、最新の就活対策情報をお知らせします。ぜひご登録ください。</p>\n                          <h4 class=\"content__title--3rd\">最新の就活対策情報配信中！</h4>\n                          <ul>\n                            <li class=\"content__link-list\"><a href=\"https://syukatsu-salon.seedsjp.com/\" target=\"_blank\">&gt; シーズ就活サロン公式サイト</a></li>\n                            <li class=\"content__link-list\"><a href=\"https://www.youtube.com/channel/UCdqJxK_H9FFQ75Ne-V09d1w\" target=\"_blank\">&gt; シーズ就活サロン公式Youtubeチャンネル</a></li>\n                          </ul>\n                        </div>\n                      </div>\n                    </section>\n                  </div>\n                  <div class=\"contentsInnerBox\">\n                    <section>\n                    <h3 class=\"content__title--2nd\">ヒロジョブだけの就活イベント・合同企業説明会</h3>\n                      <h4 class=\"content__title--3rd\">就活解禁前 — 自己分析〜選考対策が学べるイベント・セミナーを中心に開催</h4>\n                      <p>10月からは、自己分析や選考対策をテーマにした就活イベントを開催！早めのうちに就活対策ができるほか、就活仲間も作れると好評です。<br>\n                      その他にも、インターンシップ&amp;キャリア先を見つける「インターンシップフェア」も夏と冬に開催。</p>\n                      <h4 class=\"content__title--3rd\">3月の就活解禁後 — 合同説明会「ヒロジョブ合説」</h4>\n                      <p>合同企業説明会イベント「ヒロジョブ合説」は多数の広島企業が出展！<br>\n                      毎年たくさんの就活生の皆さんにご参加いただいています。</p>\n                      <p>合同説明会は企業の担当者に直接社内の雰囲気や制度についても質問できるチャンス。<br>\n                      様々な地元企業があなたにお会いできるのを待っています。ぜひ奮ってご参加ください。</p>\n                      <p><img alt=\"広島県の合説イベント「ヒロジョブ合説」の様子\" src=\"img/hiro_gosetsu_img.jpg\"></p>\n                      <h4 class=\"content__title--3rd\">最新の就活イベント情報はヒロジョブでチェック</h4>\n                      <ul>\n                        <li class=\"content__link-list\"><a href=\"https://hirojob.com/2027/event/\" target=\"_blank\">&gt; 広島の27卒学生向け就活イベント情報ページはこちら</a></li>\n                        <li class=\"content__link-list\"><a href=\"https://hirojob.com/2028/event/\" target=\"_blank\">&gt; 広島の28卒学生向け就活イベント情報ページはこちら</a></li>\n                      </ul>\n                    </section>\n                  </div>\n              </section>\n            </div>\n          </div>\n        </div>\n        <div class=\"contents mt50\">\n          <div class=\"contentsInner\">\n            <div class=\"contentsInnerFrame\">\n              <section>\n                <h2 class=\"content__title--1st\">ヒロジョブの転職関連サービス</h2>\n                  <div class=\"contentsInnerBox\">\n                    <section>\n                    <h3 class=\"content__title--3rd\">企業とのやり取りを代行。転職活動を円滑に進めるなら転職エージェント</h3>\n                    <div class=\"contentsLinkArea clearfix\">\n                      <div class=\"siteBoxLeft\">\n                        <div class=\"siteBoxInner\">\n                          <a href=\"http://tenshoku.hirojob.com/\" target=\"_blank\" class=\"link\"></a>\n                          <div class=\"siteTitle\">\n                            <h3 class=\"siteBoxTitle\">広島密着の転職エージェント</h3>\n                          </div>\n                          <div class=\"siteLogo\">\n                            <img alt=\"ヒロジョブキャリア\" src=\"img/logo_hirojob_career.png\">\n                          </div>\n                        </div>\n                      </div>\n                    </div>\n                    </section>\n                  </div>\n                  <div class=\"contentsInnerBox\">\n                    <section>\n                    <h3 class=\"content__title--3rd\">採用お祝い金が貰える自己応募型採用情報サイト</h3>\n                    <div class=\"contentsLinkArea clearfix\">\n                      <div class=\"siteBoxLeft\">\n                        <div class=\"siteBoxInner\">\n                          <a href=\"https://hiroten.hirojob.com/\" target=\"_blank\" class=\"link\"></a>\n                          <div class=\"siteTitle\">\n                            <h5 class=\"siteBoxTitle\">広島の中途採用情報サイト</h5>\n                          </div>\n                          <div class=\"siteLogo\">\n                            <img alt=\"ヒロジョブ転職\" src=\"img/logo_hirojob_tenshoku.png\">\n                          </div>\n                        </div>\n                      </div>\n                      <div class=\"siteBoxRight\">\n                        <div class=\"siteBoxInner\">\n                          <a href=\"https://ar-baito.com/tyugoku/hiroshima\" target=\"_blank\" class=\"link\"></a>\n                          <div class=\"siteTitle\">\n                            <h5 class=\"siteBoxTitle\">アルバイト・パートの求人なら</h5>\n                          </div>\n                          <div class=\"siteLogo\">\n                            <img alt=\"アルバイトドットコム\" src=\"img/logo_arubaito.png\">\n                          </div>\n                        </div>\n                      </div>\n                    </div>\n                    </section>\n                  </div>\n              </section>\n            </div>\n          </div>\n        </div>\n        <div class=\"contents mt50\">\n          <div class=\"contentsInner\">\n            <div class=\"contentsInnerFrame\">\n              <section id=\"forCompany\">\n                <h2 class=\"content__title--1st\">サービスをご検討中の採用企業様</h2>\n                  <div class=\"contentsInnerBox\">\n                    <section>\n                    <h3 class=\"content__title--2nd\">広島の新卒採用なら「ヒロジョブ」にお任せください</h3>\n                      <h4 class=\"content__title--3rd\">地元広島の学生・就活生にアプローチするならヒロジョブ</h4>\n                      <div class=\"contentsInnerBox2 clearfix\">\n                        <div class=\"contentsInnerBox2Right\">\n                          <img alt=\"地元広島の学生・就活生にアプローチするならヒロジョブ\" src=\"img/hiroshima_shinsotsu_img.jpg\">\n                        </div>\n                        <div class=\"contentsInnerBox2Left\">\n                          <p>地域密着型の就活情報サイトや各種イベントを通して、広島の企業と広島で働きたい学生とを結びつけることが私たちの使命です。<br>\n                          ウェブ上での接触はもちろんのこと、合説や中小規模の就活イベントを通じて直接の交流機会も多数ご用意しております。</p>\n                          <p>また新規に新卒採用を始める企業様や、独力での新卒採用に不安を感じていらっしゃる企業様向けに、新卒採用業務の一部代行や採用コンサルティングも承っております。<br>\n                          地元ならではの手厚いサポート体制で採用を成功に導きます。</p>\n                          <ul>\n                            <li class=\"content__link-list\"><a href=\"https://www.seedsjp.com/business/sinsotsu/\" target=\"_blank\">&gt; 新卒採用サービスについて詳しくはこちら</a></li>\n                          </ul>\n                        </div>\n                      </div>\n                      <h4 class=\"content__title--3rd\">企業パンフレットなどによる適切な情報発信も大切です</h4>\n                        <div class=\"contentsInnerBox2\">\n                          <p>新卒採用を行う上で欠かせないのが情報発信ツール。特に、会社の思いを伝える会社案内・採用案内パンフレットは重要です。<br>\n                          また、合同企業説明会もたくさんの参加企業の中から貴社を見つけてもらえるようなブース演出も不可欠。<br>\n                          貴社のメッセージがしっかり届いているか、受け取った側の印象に残り、共感を得られたかどうかが結果を大きく左右します。</p>\n                          <p>弊社は就活サイトや就活イベント以外にも、新卒採用支援の一環としてこれらデザイン制作も承っておりますので、お気軽にお問い合わせください。</p>\n                          <ul>\n                            <li class=\"content__link-list\"><a href=\"https://www.seedsjp.com/business/design/\" target=\"_blank\">&gt; デザイン制作について詳しくはこちら</a></li>\n                            <li class=\"content__link-list\"><a href=\"https://www.seedsjp.com/design-works/\" target=\"_blank\">&gt; 制作実績はこちら</a></li>\n                          </ul>\n                        </div>\n                      <h4 class=\"content__title--3rd\">採用から育成、適性検査までワンストップでご提供</h4>\n                        <div class=\"contentsInnerBox2 clearfix\">\n                        <p>新卒採用だけでなく、内定者・新入社員向けのフォローアップ研修や適性検査サービス、中途採用サービスなど人財採用・育成に関するサービスを幅広く提供しております。<br>\n                          また、業務効率化、営業活動の効率化のためのITソリューションの導入支援も行なっております。</p>\n                        <ul>\n                          <li class=\"content__link-list\"><a href=\"https://www.seedsjp.com/business/\" target=\"_blank\">&gt; 株式会社シーズの法人向けサービスはこちら</a></li>\n                        </ul>\n                      </div>\n                    </section>\n                  </div>\n              </section>\n            </div>\n          </div>\n        </div>\n      </section>\n      <footer id=\"footer\">\n        <a href=\"#wrapper\" id=\"pageTop\" style=\"display: block;\"><img width=\"60\" height=\"60\" src=\"img/btn_pagetop.png\" alt=\"ページトップへ\"></a>\n        <div class=\"footerTop\">\n          <div class=\"footerInner01\">\n          <ul class=\"footerItemCenter\">\n          <li><a href=\"https://www.seedsjp.com/\" target=\"_blank\">会社案内</a></li>\n          <li><a href=\"https://www.seedsjp.com/company/maps/\" target=\"_blank\">拠点案内</a></li>\n          <li><a href=\"https://www.seedsjp.com/news/\" target=\"_blank\">ニュースリリース</a></li>\n          <li><a href=\"https://www.seedsjp.com/personal/\" target=\"_blank\">個人のお客様</a></li>\n          <li><a href=\"https://www.seedsjp.com/business/\" target=\"_blank\">法人のお客様</a></li>\n          <li><a href=\"https://www.seedsjp.com/inquiry/contact/\" target=\"_blank\">お問い合わせ</a></li>\n          </ul>\n          </div>\n        </div>\n        <div class=\"footerBottom\">\n          <div class=\"footerInner02\">\n            <div class=\"footerInnerList\">\n              <ul>\n                <li><a href=\"https://www.seedsjp.com/policy/\" target=\"_blank\">プライバシーポリシー</a></li>\n                <li class=\"footerInnerListLiEnd\"><a href=\"https://www.seedsjp.com/privacy/\"  target=\"_blank\">個人情報の取扱について</a></li>\n                </ul>\n            </div>\n          <address>Copyright ©\n          <script type=\"text/javascript\">myDate = new Date(); myYear = myDate.getFullYear(); document.write(myYear);</script>\n          Seeds\n          Co.,Ltd. All Right Reserved</address>\n          </div>\n        </div>\n      </footer>\n    </div>\n    <script src=\"https://cdnjs.cloudflare.com/ajax/libs/wow/1.1.2/wow.min.js\"></script>\n    <script>\n        new WOW().init();\n    </script>\n</body>\n\n</html>\n","finalUrl":"https://www.hirojob.com/","rendered":false,"_cachedAt":"2026-06-22T14:39:42.774Z"}