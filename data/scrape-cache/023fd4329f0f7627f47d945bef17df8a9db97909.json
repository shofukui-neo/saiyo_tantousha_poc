noscript> \n  <!-- End Google Tag Manager (noscript) --> \n  <!-- Google Tag Manager (noscript) --> \n  <noscript>\n   <iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-PQGQDWS\" height=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe>\n  </noscript> \n  <!-- End Google Tag Manager (noscript) --> \n  <div id=\"page\" class=\"bg-window \"> \n   <div class=\"bg-document\"> \n    <noscript> \n     <div id=\"js-off\"> \n      <img src=\"_module/images/noscript.gif\" alt=\"Enable JavaScript in your browser. このウェブサイトはJavaScriptをオンにしてご覧下さい。\"> \n     </div> \n    </noscript> \n    <div id=\"a-header\" data-float=\"false\" class=\"a-header   cssskin-_area_header\"> \n     <header> \n      <div class=\"site_frame\"> \n       <section> \n        <div id=\"bk63015865\" class=\"b-both_diff -right_large -sp-single_column c-space_normal c-sp-space_normal c-sp-padding_normal bd-webp -dress_b13001GhostHeader cssskin-_block_header\" data-bk-id=\"bk63015865\" data-shared=\"true\" data-sharedname=\"_グローバルナビ\"> \n         <div class=\" g-column\" id=\"menu\"> \n          <div class=\" column -col5 -col_sub\"> \n           <div class=\"c-lead\"> \n            <div class=\"c-img   \"> \n             <a href=\"./\" data-pid=\"4241026\"> \n              <picture> \n               <source type=\"image/webp\" srcset=\"_src/67668431/headerlogo_ver1.webp?v=1779690992076\"> \n               <img src=\"_src/67668431/headerlogo_ver1.png?v=1779690992076\" width=\"400\" height=\"65\" alt=\"TOKOヘッダーロゴ\" id=\"imgsrc67668431_1\" class=\" c-no_adjust\" loading=\"lazy\"> \n              </picture></a> \n            </div> \n           </div> \n          </div> \n          <div class=\" column -col7 -col_main\"> \n           <nav> \n            <div id=\"js-globalNavigation\" data-slide-type=\"rightSlide\" data-btn-position=\"rightTop_fixed\"> \n             <div class=\" -menu_right\"> \n              <ul class=\"c-menu -menu_a menu-parts\"> \n               <li><a href=\"company.html\" data-pid=\"4241027\">会社概要</a></li> \n               <li><a href=\"service.html\" data-pid=\"4242619\">営業品目</a></li> \n               <li><a href=\"works.html\" data-pid=\"6144807\">制作実績</a></li> \n               <li><a href=\"product.html\" data-pid=\"4242621\">開発商品</a></li> \n               <li><a href=\"workflow.html\" data-pid=\"4241028\">部門紹介</a></li> \n               <li><a href=\"recruit.html\" data-mypid=\"4241034\" class=\" c-current\">採用情報</a></li> \n               <li><a href=\"./#contact\" data-pid=\"4241026\">お問合せ</a></li> \n              </ul> \n             </div> \n            </div> \n            <div id=\"spNavigationTrigger\" class=\" c-sp_navigation_btn\"></div> \n           </nav> \n          </div> \n         </div> \n        </div> \n       </section> \n      </div> \n     </header> \n    </div> \n    <div id=\"a-ghost_header\" data-effect=\"fade\" data-float=\"true\" class=\"a-ghost_header js-ghost_mode  cssskin-_block_ghost_header\"> \n     <header> \n      <div class=\"site_frame\"> \n       <section> \n        <div id=\"bk68614180\" class=\"b-plain cssskin-_block_ghost_header\" data-bk-id=\"bk68614180\"> \n         <div class=\" column -column1\"> \n         </div> \n        </div> \n        <div id=\"bk68615819\" class=\"b-plain c-space_narrow c-sp-space_normal c-sp-padding_normal cssskin-_block_ghost_header\" data-bk-id=\"bk68615819\" data-shared=\"true\" data-sharedname=\"ゴーストHD\"> \n         <div class=\" column -column1\"> \n          <h4 class=\" c-small_headline c-center\"><a href=\"#contact\" class=\"blackline js-link_scroller\"><span class=\"bindicon-circle-down\"></span>広告・販促に関するあらゆるオーダーにお応えします。まずはお電話ください。</a></h4> \n         </div> \n        </div> \n       </section> \n      </div> \n     </header> \n    </div> \n    <div id=\"a-billboard\" class=\"a-billboard    cssskin-_area_billboard\"> \n     <div class=\"site_frame\"> \n      <section> \n       <div id=\"bk63015740\" class=\"b-plain -bg-stretch c-space_normal c-sp-space_normal cssskin-_block_billboard\" data-bk-id=\"bk63015740\" data-shared=\"true\" data-sharedname=\"_ビルボード\"> \n        <div class=\" column -column1\"> \n         <h1 class=\" c-page_title\"><span class=\"smode c-center\">RECRUIT</span></h1> \n         <div class=\"c-lead c-center\"> \n          <div class=\"c-breadcrumb\"> \n           <a href=\"./\" data-pid=\"4241026\">HOME</a> | \n           <em>RECRUIT</em> \n          </div> \n         </div> \n        </div> \n       </div> \n       <div id=\"bk63254119\" class=\"b-plain c-sp-space_init c-sp-padding_init cssskin-redline\" data-bk-id=\"bk63254119\" data-shared=\"true\" data-sharedname=\"redline\"> \n        <div class=\" column -column1\"> \n         <p class=\"c-credit\"> </p> \n         <table style=\"border-collapse: collapse; width: 100%; height: 2px;\"> \n          <tbody> \n           <tr> \n            <td style=\"width: 70%;line-height: 1.5;vertical-align:middle;\">&nbsp;</td> \n            <td style=\"background-color: #ff0000; width: 15%;line-height: 1.5;vertical-align:middle;\">&nbsp;</td> \n            <td style=\"width: 15%;line-height: 1.5;vertical-align:middle;\">&nbsp;</td> \n           </tr> \n          </tbody> \n         </table> \n         <p></p> \n        </div> \n       </div> \n      </section> \n     </div> \n    </div> \n    <main> \n     <div id=\"a-site_contents\" class=\"a-site_contents  noskin\"> \n      <article> \n       <div class=\"site_frame\"> \n        <div class=\"g-column\"> \n         <div id=\"a-main\" class=\"a-main column -col12 \"> \n          <section> \n           <div id=\"bk70494459\" class=\"b-accordion b-accordion_contents c-space_normal c-sp-space_normal c-padding_wide c-sp-padding_normal cssskin-_block_main\" data-bk-id=\"bk70494459\" data-open-columns=\"all\"> \n            <div class=\" g-column\"> \n             <div class=\" b-accordion_navigation\"> \n              <a href=\"#\" class=\" js-link_scroller\"><span class=\"bindicon-user-plus\"></span> 中途採用募集（業務別）</a> \n             </div> \n             <div class=\" accordion-content\"> \n              <div class=\" column\"> \n               <h3 class=\" c-large_headline\"><span class=\"bindicon-user-plus\"></span>営業事務（パート）　<span style=\"background-color:#ffff00; color:#ff0000;\">　NEW　</span><span style=\"background-color:#ffff00; color:#ff0000;\"></span></h3> \n               <table class=\"c-list_table\"> \n                <tbody> \n                 <tr> \n                  <th>職種</th> \n                  <td> <p>営業事務（パート）</p></td> \n                 </tr> \n                 <tr> \n                  <th>仕事内容</th> \n                  <td> <p>営業事務職では、営業スタッフがお客様との折衝に専念できるよう、サポートを行っていただきます。具体的には見積書・作業伝票・発注書・資料・スケジュールの作成、電話やメール対応、顧客のデータ管理などが主な業務となります。実際の仕事を通じて知識や技術を身に付けられるよう指導いたしますので未経験でも安心して働いていただけます。</p></td> \n                 </tr> \n                 <tr> \n                  <th>応募資格</th> \n                  <td> <p>高卒以上</p></td> \n                 </tr> \n                 <tr> \n                  <th>応募方法</th> \n                  <td> <p>下記電話番号まで随時ご連絡ください。　</p><p>折り返し、詳細を説明させていただきます。　</p><p>東光印刷 IPC制作１部</p><p><span class=\" d-bold\">TEL.<a href=\"tel:0825010780\">082-501-0780</a></span>　担当者/吉岡</p></td> \n                 </tr> \n                 <tr> \n                  <th>採用人数</th> \n                  <td> <p>1名</p></td> \n                 </tr> \n                 <tr> \n                  <th>提出書類</th> \n                  <td> <p>履歴書（要写真）</p></td> \n                 </tr> \n                 <tr> \n                  <th>選考方法</th> \n                  <td> <p>書類選考、面接</p></td> \n                 </tr> \n                 <tr> \n                  <th>時給</th> \n                  <td> <p>1,300円</p></td> \n                 </tr> \n                 <tr> \n                  <th>諸手当</th> \n                  <td> <p>通勤手当（20,000円まで）</p></td> \n                 </tr> \n                 <tr> \n                  <th>勤務地</th> \n                  <td> <p>本社（広島市西区商工センター）　　　　</p></td> \n                 </tr> \n                 <tr> \n                  <th>勤務時間</th> \n                  <td> <p>9：00～17：00の間で6～7時間　又は 8：30～17：30（8時間）</p></td> \n                 </tr> \n                 <tr> \n                  <th>休日休暇</th> \n                  <td> <p>■土曜・日曜・祝日、夏季・年末年始</p><p>その他年次有給休暇</p></td> \n                 </tr> \n                 <tr> \n                  <th>福利厚生</th> \n                  <td> <p>各種保険（健康・厚生年金・雇用・労災）　</p></td> \n                 </tr> \n                </tbody> \n               </table> \n               <p class=\" c-body\">&nbsp;</p> \n               <h3 class=\" c-large_headline\"><span class=\"bindicon-user-plus\"></span>フォトグラファー（写真/動画）<span style=\"background-color:#ffff00; color:#ff0000;\"></span></h3> \n               <table class=\"c-list_table\"> \n                <tbody> \n                 <tr> \n                  <th>職種</th> \n                  <td> <p>フォトグラファー（写真/動画）</p></td> \n                 </tr> \n                 <tr> \n                  <th>仕事内容</th> \n                  <td> <p>ひとの生活にかかわる「衣・食・住」を自社スタジオで写真や動画を撮影し活躍していただける広告フォトグラファーを募集しています！社内にはファッション・フードスタイリストも在籍しており、チームでのクリエイティブワークを実現できます。あなたの視点で広告の新しい表現を一緒に作りませんか。</p></td> \n                 </tr> \n                 <tr> \n                  <th>応募資格</th> \n                  <td> <p>商業写真撮影の経験がある方　年齢制限あり（５９歳以下）</p><p>＊試用期間３ヶ月程度（同条件）</p></td> \n                 </tr> \n                 <tr> \n                  <th>応募方法</th> \n                  <td> <p>下記電話番号まで随時ご連絡ください。　</p><p>折り返し、詳細を説明させていただきます。　</p><p>東光印刷 IPC制作１部</p><p><span class=\" d-bold\">TEL.<a href=\"tel:0825687282\">082-568-7282</a></span>　担当者/中山（ナカヤマ）</p></td> \n                 </tr> \n                 <tr> \n                  <th>採用人数</th> \n                  <td> <p>1名</p></td> \n                 </tr> \n                 <tr> \n                  <th>提出書類</th> \n                  <td> <p>履歴書（要写真）・自主制作された作品など</p></td> \n                 </tr> \n                 <tr> \n                  <th>選考方法</th> \n                  <td> <p>書類選考、面接（2回予定）</p></td> \n                 </tr> \n                 <tr> \n                  <th>給与</th> \n                  <td> <p>当社規定による</p></td> \n                 </tr> \n                 <tr> \n                  <th>諸手当</th> \n                  <td> <p>住宅手当、特務手当、通勤手当（20,000円まで）</p></td> \n                 </tr> \n                 <tr> \n                  <th>昇給</th> \n                  <td> <p>年1回</p></td> \n                 </tr> \n                 <tr> \n                  <th>賞与</th> \n                  <td> <p>年2回（7月・12月）</p></td> \n                 </tr> \n                 <tr> \n                  <th>勤務地</th> \n                  <td> <p>広島市東区二葉の里（東光印刷㈱IPC）　　　</p></td> \n                 </tr> \n                 <tr> \n                  <th>勤務時間</th> \n                  <td> <p>９：００～１８：００</p></td> \n                 </tr> \n                 <tr> \n                  <th>休日休暇</th> \n                  <td> <p>年間休日118日(2026年　120日予定）</p><p>■日曜・祝日、夏季・冬季休暇</p><p>■土曜（月3回程度、当社カレンダーに準じます）</p><p>その他年次有給休暇・慶弔特別休暇</p></td> \n                 </tr> \n                 <tr> \n                  <th>福利厚生</th> \n                  <td> <p>各種保険（健康・厚生年金・雇用・労災）　</p></td> \n                 </tr> \n                </tbody> \n               </table> \n               <p class=\" c-body\">&nbsp;</p> \n               <h3 class=\" c-large_headline\"><span class=\"bindicon-user-plus\"></span>開発エンジニア<span style=\"background-color:#ffff00; color:#ff0000;\"></span></h3> \n               <table class=\"c-list_table\"> \n                <tbody> \n                 <tr> \n                  <th>職種</th> \n                  <td> <p>開発エンジニア</p></td> \n                 </tr> \n                 <tr> \n                  <th>仕事内容</th> \n                  <td> <p>社内のデジタル発展チームと連携し印刷会社のリソースを活かした新しい顧客接点の仕組みづくりに挑戦します!</p><p>《こんな方大歓迎》◎印刷×デジタル、◎体験×計測、◎社内DX×外部価値創出</p><p>上記にピンときた方、ぜひお力添えください！デジタル媒体の高度化する顧客ニーズに応えるため、外部パートナー(協業会社)との連携強化や新規事業拡大の体制構築を進めてます。</p></td> \n                 </tr> \n                 <tr> \n                  <th>応募資格</th> \n                  <td> <p>WEB開発経験者　年齢　不問</p><p>＊試用期間３ヶ月程度（同条件）</p></td> \n                 </tr> \n                 <tr> \n                  <th>応募方法</th> \n                  <td> <p>下記電話番号まで随時ご連絡ください。　</p><p>折り返し、詳細を説明させていただきます。　</p><p>東光印刷IPC&nbsp;</p><p><span class=\" d-bold\">TEL.<a href=\"tel:0825687282\">082-568-7282</a></span>　担当者/平田（ヒラタ）</p></td> \n                 </tr> \n                 <tr> \n                  <th>採用人数</th> \n                  <td> <p>1名</p></td> \n                 </tr> \n                 <tr> \n                  <th>提出書類</th> \n                  <td> <p>履歴書（要写真）</p></td> \n                 </tr> \n                 <tr> \n                  <th>選考方法</th> \n                  <td> <p>書類選考、面接（2回予定）</p></td> \n                 </tr> \n                 <tr> \n                  <th>給与</th> \n                  <td> <p>当社規定による</p></td> \n                 </tr> \n                 <tr> \n                  <th>諸手当</th> \n                  <td> <p>住宅手当、特務手当、通勤手当（20,000円まで）</p></td> \n                 </tr> \n                 <tr> \n                  <th>昇給</th> \n                  <td> <p>年1回</p></td> \n                 </tr> \n                 <tr> \n                  <th>賞与</th> \n                  <td> <p>年2回（7月・12月）</p></td> \n                 </tr> \n                 <tr> \n                  <th>勤務地</th> \n                  <td> <p>広島市東区二葉の里（東光印刷㈱IPC）　　　</p></td> \n                 </tr> \n                 <tr> \n                  <th>勤務時間</th> \n                  <td> <p>９：００～１８：００</p></td> \n                 </tr> \n                 <tr> \n                  <th>休日休暇</th> \n                  <td> <p>年間休日118日(2026年　120日予定）</p><p>■日曜・祝日、GW・夏季・冬季休暇</p><p>■土曜（月3回程度、当社カレンダーに準じます）</p><p>その他年次有給休暇・慶弔特別休暇</p></td> \n                 </tr> \n                 <tr> \n                  <th>福利厚生</th> \n                  <td> <p>各種保険（健康・厚生年金・雇用・労災）　</p></td> \n                