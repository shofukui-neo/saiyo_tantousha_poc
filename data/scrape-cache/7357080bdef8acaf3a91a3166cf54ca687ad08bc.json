newsList\">\r\n          <div id=\"js-news-top\">\r\n            <!-- news.json から動的に読み込み -->\r\n          </div>\r\n          <a href=\"/news\" class=\"p-top__newsBtn m-btn__arrow\">\r\n            一覧を見る\r\n          </a>\r\n        </div><!-- p-top__newsList -->\r\n      </div><!-- p-top__newsInner -->\r\n      <div class=\"m-box\">\r\n        <div class=\"m-box__inner\">\r\n          <a href=\"https://www.mitsuuroko.com/news/covid19.html\" rel=\"noreferrer\" target=\"_blank\" class=\"m-box__link\">\r\n            <span class=\"m-box__icon\">\r\n              当社グループ拠点における<br class=\"m-box__spBreak\">新型コロナウイルス感染について\r\n            </span>\r\n          </a>\r\n        </div>\r\n      </div>\r\n        <div class=\"m-box m-box--l\">\r\n          <div class=\"m-box__inner\">\r\n            <div class=\"m-factoryContent\">\r\n                <div class=\"m-factoryContent__left\">\r\n                    <p class=\"m-factoryContent__ttl\">検査結果のお知らせ</p>\r\n                </div>\r\n                <div class=\"m-factoryContent__right\">\r\n                    <p class=\"m-factoryContent__txt\">当社工場で製造する飲料水の水質検査をお知らせいたします。</p>\r\n                    <div class=\"m-factoryContent__pdf\">\r\n                        <a href=\"/assets/pdf/pfas/report1_2605.pdf\" target=\"_blank\">2026年5月　PFAS検査結果（庵原工場1）</a>\r\n                    </div>\r\n                    <div class=\"m-factoryContent__pdf\">\r\n                        <a href=\"/assets/pdf/pfas/report2_2605.pdf\" target=\"_blank\">2026年5月　PFAS検査結果（庵原工場2）</a>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n    </div><!-- p-top__news -->\r\n\r\n    <div class=\"p-top__contents\" id=\"parallax-01\">\r\n      <div class=\"p-top__contBlock p-top__contBlock--01\">\r\n        <div class=\"img\">\r\n          <picture>\r\n            <source srcset=\"/assets/img/top/sp/cont_img01_sp.png\" media=\"(max-width: 750px)\">\r\n            <img src=\"/assets/img/top/cont_img01.png\" alt=\"事業内容\">\r\n          </picture>\r\n        </div>\r\n        <div class=\"txt_block\">\r\n          <div class=\"inner\">\r\n            <span class=\"ttl\">事業内容</span>\r\n            <span class=\"sub_ttl sub_ttl--01\">BUSINESS DETAILS</span>\r\n            <p class=\"txt\">飲料のOEM製造を中心に県内地場産品である茶系飲料や果汁飲料といった自社商品も製造しています。お客様のご要望に沿ったオリジナル商品のご提案から製品化までをトータルでサポートします。農協の加工事業の時代から起算し60余年の伝統と実績と、充実の設備で多様なニーズにお応えします。</p>\r\n            <a href=\"/development/\" class=\"btn m-btn__arrowWt\">詳しく見る</a>\r\n          </div>\r\n        </div><!-- txt_block -->\r\n      </div><!-- p-top__contBlock--01 -->\r\n      <div class=\"p-top__contBlock p-top__contBlock--02\">\r\n        <div class=\"img\">\r\n          <picture>\r\n            <source srcset=\"/assets/img/top/sp/cont_img02_sp.png\" media=\"(max-width: 750px)\">\r\n            <img src=\"/assets/img/top/cont_img02.png\" alt=\"工場について\">\r\n          </picture>\r\n        </div>\r\n        <div class=\"txt_block\">\r\n          <div class=\"inner\">\r\n            <span class=\"ttl\">工場について</span>\r\n            <span class=\"sub_ttl sub_ttl--02\">ABOUT THE FACTORY</span>\r\n            <p class=\"txt\">工場は興津工場（おきつ）と庵原工場（いはら）の２拠点で、<br class=\"u-pc\">合計で４ラインを保有しています。<br class=\"u-pc\">稼働している設備の一部をご紹介します。</p>\r\n            <a href=\"/factory/\" class=\"btn m-btn__arrowWt\">詳しく見る</a>\r\n          </div>\r\n        </div><!-- txt_block -->\r\n      </div><!-- p-top__contBlock--01 -->\r\n      <div class=\"p-top__contMaskTop\">\r\n        <picture>\r\n          <picture>\r\n            <source srcset=\"/assets/img/top/cont_mask_top.png\" media=\"(max-width: 750px)\">\r\n            <img src=\"/assets/img/top/cont_mask_top.png\" alt=\"\">\r\n          </picture>\r\n        </picture>\r\n      </div><!-- p-top__contMask -->\r\n      <div class=\"p-top__contMask\">\r\n        <picture>\r\n          <picture>\r\n            <source srcset=\"/assets/img/top/sp/cont_mask_sp.png\" media=\"(max-width: 750px)\">\r\