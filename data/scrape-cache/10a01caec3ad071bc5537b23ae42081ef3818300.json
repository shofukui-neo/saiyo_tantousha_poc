{"url":"https://www.token.co.jp/inquiry/estate_request/","html":"<!DOCTYPE html>\r\n<html lang=\"ja\">\r\n<head>\r\n<!-- common -->\r\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\r\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\r\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\r\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\r\n})(window,document,'script','dataLayer','GTM-M4FXRTR');</script>\r\n<meta charset=\"utf-8\">\r\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0, user-scalable=no\">\r\n<meta http-equiv=\"x-ua-compatible\" content=\"ie=edge\">\r\n<meta name=\"format-detection\" content=\"telephone=no\">\r\n<link rel=\"icon\" href=\"/favicon.ico\">\r\n<link rel=\"apple-touch-icon\" href=\"/homeicon.png\">\r\n<!-- common End --><link rel=\"canonical\" href=\"https://www.token.co.jp/inquiry/estate_request/\" />\r\n<title>資料請求｜東建コーポレーション</title>\r\n<meta name=\"robots\" content=\"ALL\" />\r\n<meta name=\"apple-mobile-web-app-title\" content=\"東建ｺｰﾎﾟﾚｰｼｮﾝ\" />\r\n<meta name=\"description\" content=\"土地活用やアパート経営をご検討中の方へ。成功事例やノウハウが満載のパンフレットを無料でお届けします\" />\r\n<meta property=\"og:title\" content=\"資料請求｜東建コーポレーション\" />\r\n<meta property=\"og:type\" content=\"website\" />\r\n<meta property=\"og:url\" content=\"https://www.token.co.jp/inquiry/estate_request/\" />\r\n<!--<meta property=\"og:image\" content=\"https://www.token.co.jp/estate/image/img_main.jpg\" />-->\r\n<meta property=\"og:site_name\" content=\"資料請求｜東建コーポレーション\" />\r\n<meta property=\"og:description\" content=\"土地活用やアパート経営をご検討中の方へ。成功事例やノウハウが満載のパンフレットを無料でお届けします\" />\r\n<meta name=\"twitter:card\" content=\"summary_large_image\" />\r\n<meta name=\"twitter:site\" content=\"@tokencorp\" />\r\n<link rel=\"SHORTCUT ICON\" href=\"/favicon.ico\" />\r\n<link rel=\"apple-touch-icon-precomposed\" href=\"/homeicon_estate.png\" />\r\n<!--#config timefmt=\"%Y%m%d%H%I%S\" --> \r\n<!-- common css-->\r\n<link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/normalize/4.2.0/normalize.min.css\">\r\n<link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css\">\r\n<link rel=\"stylesheet\" href=\"https://fonts.googleapis.com/icon?family=Material+Icons+Round\">\r\n<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\r\n<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\r\n<link href=\"https://fonts.googleapis.com/css2?family=Barlow:ital,wght@0,500;0,700;1,500;1,700&family=Jost:ital,wght@0,500;1,500&family=Noto+Sans+JP:wght@100..900&family=Zen+Old+Mincho&display=swap\" rel=\"stylesheet\">\r\n<link rel=\"stylesheet\" href=\"/responsive/token_estate/css/common-760.css\">\r\n<link rel=\"stylesheet\" href=\"/responsive/css-cmn/bass-sp-760.css\">\r\n<link rel=\"stylesheet\" href=\"/responsive/css-cmn/content-sp-760.css\">\r\n<link rel=\"stylesheet\" href=\"/responsive/js-cmn/slick/slick.css\">\r\n<link rel=\"stylesheet\" href=\"/responsive/css-cmn/estate/common.css?20250604\">\r\n<!-- リニューアル後削除 -->\r\n<link rel=\"stylesheet\" href=\"/responsive/css-cmn/estate/former.css\">\r\n<!-- common css End --><!-- Local css -->\r\n<link rel=\"stylesheet\" href=\"/responsive/js-cmn/slick/slick.css\" />\r\n<link rel=\"stylesheet\" href=\"css/estate_request.css?20260616142535\" />\r\n<!-- Local css end --> \r\n<!-- common js-->\r\n  <script src=\"https://ajax.googleapis.com/ajax/libs/jquery/3.1.1/jquery.min.js\"></script>\r\n<!-- common js End --><link rel=\"stylesheet\" href=\"/responsive/js-cmn/fancybox/jquery.fancybox.css\" />\r\n<script src=\"/responsive/js-cmn/slick/slick.min.js\"></script> \r\n<!--<script src=\"js/simulation.js\"></script>-->\r\n\r\n</head>\r\n\r\n<body>\r\n<div id=\"wrap\"> \r\n  <!-- header --> \r\n  <div class=\"header_wrap\">\r\n  <div class=\"gnav-bg\">\r\n    <header id=\"globalNav\">\r\n      <div class=\"header-logo\"><a href=\"/\"><img src=\"/responsive/image_cmn/estate/logo-token.png\" alt=\"Token\" width=\"156\" height=\"48\"></a></div>\r\n      <span class=\"keyword\">土地活用<br><span class=\"dot\">・</span>賃貸経営</span>\r\n      <dl class=\"freedial\">\r\n        <dt>土地活用、アパート経営・賃貸経営に関するご相談</dt>\r\n        <dd><img src=\"/responsive/image_cmn/estate/ico-tel.png\" alt=\"Freedial\" width=\"32\" height=\"32\">0120-51-8200</dd>\r\n      </dl>\r\n      <ul class=\"gnav-link\">\r\n        <li><a class=\"contact\" href=\"/estate/online-consultation/\"><img src=\"/responsive/image_cmn/estate/ico-header-contact.png\" alt=\"お問い合わせ\">土地活用の<br>お問い合わせ</a></li>\r\n        <li><a class=\"request\" href=\"/inquiry/estate_request/\"><img src=\"/responsive/image_cmn/estate/ico-header-shiryou.png\" alt=\"資料請求\">資料請求</a></li>\r\n        <li><span class=\"contact_sp\"><img src=\"/responsive/image_cmn/estate/ico-header-contact.png\" alt=\"お問い合わせ\">&emsp;資料請求<br>お問い合わせ</span></li>\r\n      </ul>\r\n    </header>\r\n  </div>\r\n  <div class=\"estate_menu_bg\">\r\n    <div class=\"sp_contact none_pc\">\r\n      <p>まずは、お気軽に<br>ご相談ください。</p>\r\n      <dl class=\"tel_contact\">\r\n        <dt>お電話でのお問い合わせ</dt>\r\n        <dd class=\"tel\"><img class=\"ico\" src=\"/responsive/image_cmn/estate/ico-footer-tel.png\" alt=\"Freedial\">0120-51-8200</dd>\r\n        <dd class=\"time\">平日：9〜12時、13〜17時<br class=\"none_pc\">（土・日・祝日、夏季・年末年始休暇は休業）</dd>\r\n      </dl>\r\n      <ul class=\"content_btns\">\r\n        <li><a href=\"/corporate/branch/\"><img class=\"ico\" src=\"/responsive/image_cmn/estate/ico-shiten.png\" alt=\"お近くの東建コーポレーション\">お近くの東建コーポレーション<i class=\"arrow\"></i></a></li>\r\n        <li><a href=\"/estate/online-consultation/\"><img class=\"ico\" src=\"/responsive/image_cmn/estate/ico-contact.png\" alt=\"お問い合わせ\">土地活用の<br class=\"none_sp\">お問い合わせ<i class=\"arrow\"></i></a></li>\r\n        <li><a href=\"/inquiry/estate_request/\"><img class=\"ico\" src=\"/responsive/image_cmn/estate/ico-shiryou.png\" alt=\"資料請求\">資料請求<i class=\"arrow\"></i></a></li>\r\n      </ul>\r\n    </div>\r\n  </div>\r\n</div>  <!-- /header -->\r\n  <div id=\"wrap_inner\"> \r\n    <!-- contentsここから -->\r\n    <div id=\"contents\">\r\n      <h1>資料請求</h1>\r\n      <ul class=\"flow\">\r\n        <li class=\"current\">&#9312;カタログ選択</li>\r\n        <li>&#9313;お届け先入力</li>\r\n        <li>&#9314;入力確認</li>\r\n        <li>&#9315;送信完了</li>\r\n      </ul>\r\n      <form id=\"form\" class=\"h-adr\" method=\"post\" action=\"./\">\r\n        <span class=\"p-country-name\" style=\"display:none;\">Japan</span>\r\n        <section id=\"select\">\r\n          <h2>ご希望の資料を<b>２冊</b>までお選びください</h2>\r\n          <div class=\"bg_gray\">\r\n            <section class=\"set\">\r\n              <h3>おすすめの資料セット</h3>\r\n              <ul>\n  <li>\n    <label>\n      <input type=\"checkbox\" name=\"catalog_set\" value=\"1\" data-items=\"3,7\">\n      <dl>\n        <dt><i></i>アパート経営基本セット</dt>\n        <dd>\n          <div class=\"thumb\">\n            <img src=\"image/lease.png\" alt=\"リース建築経営のながれ\">\n            <img src=\"image/keieijutsu.png\" alt=\"知って得する！“満室”経営術\">\n          </div>\n          <ul class=\"items\">\n            <li>・リース建築経営のながれ</li>\n            <li>・知って得する！“満室”経営術</li>\n          </ul>\n          <p>弊社サービスを利用した賃貸アパート経営に関する基本のセットです。賃貸アパートの長期安定経営を実現するための情報をまとめました。</p>\n        </dd>\n      </dl>\n    </label>\n  </li>\n  <li>\n    <label>\n      <input type=\"checkbox\" name=\"catalog_set\" value=\"2\" data-items=\"3,2\">\n      <dl>\n        <dt><i></i>相続対策セット</dt>\n        <dd>\n          <div class=\"thumb\">\n            <img src=\"image/lease.png\" alt=\"リース建築経営のながれ\">\n            <img src=\"image/souzokuzei.png\" alt=\"相続税対策 入門ガイド\">\n          </div>\n          <ul class=\"items\">\n            <li>・リース建築経営のながれ</li>\n            <li>・相続税対策 入門ガイド</li>\n          </ul>\n          <p>資産の相続や、承継に伴う、相続税対策についてまとめたセットです。リース建築経営の基本情報と入門ガイドブックでわかりやすく紹介します。</p>\n        </dd>\n      </dl>\n    </label>\n  </li>\n</ul>\n            </section>\r\n            <section class=\"single\">\r\n              <h3>パンフレットを個別に選ぶ</h3>\r\n              <ul>\n  <li>\n    <label>\n      <input type=\"checkbox\" name=\"catalog[]\" value=\"1\" id=\"catalog-apart\" data-src=\"image/apart.png\">\n      <dl>\n        <dt><i></i>アパート経営のすすめ</dt>\n        <dd>\n          <div class=\"thumb\"><img src=\"image/apart.png\" alt=\"アパート経営のすすめ\"></div>\n          <p>土地を持たない方でも始められる資産形成術を紹介。初心者の方でも、収益を生む仕組みがひと目でわかる入門書です。</p>\n        </dd>\n      </dl>\n    </label>\n  </li>\n  <li>\n    <label>\n      <input type=\"checkbox\" name=\"catalog[]\" value=\"2\" id=\"catalog-souzoku\" data-src=\"image/souzokuzei.png\">\n      <dl>\n        <dt><i></i>相続税対策 入門ガイド</dt>\n        <dd>\n          <div class=\"thumb\"><img src=\"image/souzokuzei.png\" alt=\"相続税対策 入門ガイド\"></div>\n          <p>アパート・マンション建築による相続税対策をわかりやすく紹介。資産を守って、攻めの対策術を！</p>\n        </dd>\n      </dl>\n    </label>\n  </li>\n  <li>\n    <label>\n      <input type=\"checkbox\" name=\"catalog[]\" value=\"3\" id=\"catalog-lease\" data-src=\"image/lease.png\">\n      <dl>\n        <dt><i></i>リース建築経営のながれ</dt>\n        <dd>\n          <div class=\"thumb\"><img src=\"image/lease.png\" alt=\"リース建築経営のながれ\"></div>\n          <p>農地や遊休地の活用、相続税対策など土地に関する悩みを、アパート・賃貸住宅経営で解決。安定収入と節税を東建がサポートします。</p>\n        </dd>\n      </dl>\n    </label>\n  </li>\n  <li>\n    <label>\n      <input type=\"checkbox\" name=\"catalog[]\" value=\"7\" id=\"catalog-keieijustu\" data-src=\"image/keieijutsu.png\">\n      <dl>\n        <dt><i></i>知って得する！<br>“満室”経営術</dt>\n        <dd>\n          <div class=\"thumb\"><img src=\"image/keieijutsu.png\" alt=\"知って得する！“満室”経営術\"></div>\n          <p>少子高齢化時代の土地活用は、市場調査とエリア選定が鍵。長期安定経営が見込めるエリアをご提案します。</p>\n        </dd>\n      </dl>\n    </label>\n  </li>\n</ul>\n            </section>\r\n          </div>\r\n        </section>\r\n        <section id=\"delivery_address\">\r\n          <ul class=\"flow\">\r\n            <li class=\"before\">&#9312;カタログ選択</li>\r\n            <li class=\"current\">&#9313;お届け先入力</li>\r\n            <li>&#9314;入力確認</li>\r\n            <li>&#9315;送信完了</li>\r\n          </ul>\r\n          <h2>お届け先を入力してください</h2>\r\n          <section>\r\n            <h3>お客様情報</h3>\r\n            <table>\r\n              <tbody>\r\n                <tr>\r\n                  <th class=\"required\">お名前<br>\r\n                    <span class=\"f_small\">（フルネーム）</span>\r\n                  </th>\r\n                  <td>\r\n                    <div class=\"input_wrap\">\r\n                      <input id=\"name_kanji\" type=\"text\" name=\"name\" maxlength=\"20\" value=\"\" placeholder=\"例：東建太郎\" required>\r\n                      <i class=\"fa-solid fa-circle-check\"></i>\r\n                      <p class=\"caution_msg check_name_kanji\" style=\"display: none;\">お名前（フルネーム）を入力してください。</p>\r\n                      <p class=\"small_caution_msg\">※氏名共にご入力ください</p>\r\n                                          </div>\r\n                  </td>\r\n                </tr>\r\n                <tr>\r\n                  <th class=\"required\">ふりがな</th>\r\n                  <td>\r\n                    <div class=\"input_wrap\">\r\n                      <input id=\"name_kana\" type=\"text\" name=\"kana\" maxlength=\"20\" value=\"\" placeholder=\"例：とうけんたろう\" required>\r\n                      <i class=\"fa-solid fa-circle-check\"></i>\r\n                      <p class=\"caution_msg check_name_kana\" style=\"display: none;\">お名前（ひらがな）を入力してください。</p>\r\n                                          </div>\r\n                  </td>\r\n                </tr>\r\n                <tr>\r\n                  <th class=\"required\">電話番号<br>\r\n                    <span class=\"f_small\">（ハイフン不要）</span></th>\r\n                  <td>\r\n                    <ul>\r\n                      <li>\r\n                        <div class=\"input_wrap\">\r\n                          <input id=\"tel\" type=\"tel\" name=\"tel\" maxlength=\"11\" value=\"\" placeholder=\"例：0522328000\" required>\r\n                          <i class=\"fa-solid fa-circle-check\"></i>\r\n                          <p class=\"caution_msg check_tel\" style=\"display: none;\">⁩⁩電話番号（半角数字・ハイフンなし）を入力してください。</p>\r\n                                                  </div>\r\n                      </li>\r\n                    </ul>\r\n                  </td>\r\n                </tr>\r\n                <tr>\r\n                  <th class=\"required\">メール<br class=\"none_pc\">アドレス</th>\r\n                  <td>\r\n                    <ul>\r\n                      <li>\r\n                        <div class=\"input_wrap\">\r\n                          <input id=\"email\" type=\"email\" name=\"email\" maxlength=\"50\" value=\"\" placeholder=\"info@token.co.jp\" required>\r\n                          <i class=\"fa-solid fa-circle-check\"></i>\r\n                          <p class=\"caution_msg check_email\" style=\"display: none;\">⁩メールアドレスを入力してください。</p>\r\n                                                  </div>\r\n                      </li>\r\n                    </ul>\r\n                  </td>\r\n                </tr>\r\n              </tbody>\r\n            </table>\r\n          </section>\r\n          <section>\r\n            <h3>資料送付先</h3>\r\n            <table>\r\n              <tbody>\r\n                <tr class=\"post\">\r\n                  <th class=\"required\">郵便番号</th>\r\n                  <td>\r\n                    <div class=\"input_wrap\">\r\n                      <input id=\"post_code\" class=\"p-postal-code\" type=\"text\" name=\"zip\" maxlength=\"7\" value=\"\" placeholder=\"4600008\">\r\n                      <i class=\"fa-solid fa-circle-check\"></i>\r\n                                          </div><!--<button type=\"button\" class=\"postal-search\">郵便番号を調べる</button>-->\r\n                  </td>\r\n                </tr>\r\n                <tr class=\"address\">\r\n                  <th class=\"v-top required\">ご住所</th>\r\n                  <td>\r\n                    <div class=\"input_flex\">\r\n                      <div class=\"select_wrap\">\r\n                        <select id=\"prefecture\" class=\"p-region-id\" name=\"prf\" required>\r\n                          <option value=\"\" disabled selected>都道府県</option>\r\n                          <option value=\"1\">北海道</option>\n<option value=\"2\">青森県</option>\n<option value=\"3\">岩手県</option>\n<option value=\"4\">宮城県</option>\n<option value=\"5\">秋田県</option>\n<option value=\"6\">山形県</option>\n<option value=\"7\">福島県</option>\n<option value=\"8\">茨城県</option>\n<option value=\"9\">栃木県</option>\n<option value=\"10\">群馬県</option>\n<option value=\"11\">埼玉県</option>\n<option value=\"12\">千葉県</option>\n<option value=\"13\">東京都</option>\n<option value=\"14\">神奈川県</option>\n<option value=\"15\">新潟県</option>\n<option value=\"16\">富山県</option>\n<option value=\"17\">石川県</option>\n<option value=\"18\">福井県</option>\n<option value=\"19\">山梨県</option>\n<option value=\"20\">長野県</option>\n<option value=\"21\">岐阜県</option>\n<option value=\"22\">静岡県</option>\n<option value=\"23\">愛知県</option>\n<option value=\"24\">三重県</option>\n<option value=\"25\">滋賀県</option>\n<option value=\"26\">京都府</option>\n<option value=\"27\">大阪府</option>\n<option value=\"28\">兵庫県</option>\n<option value=\"29\">奈良県</option>\n<option value=\"30\">和歌山県</option>\n<option value=\"31\">鳥取県</option>\n<option value=\"32\">島根県</option>\n<option value=\"33\">岡山県</option>\n<option value=\"34\">広島県</option>\n<option value=\"35\">山口県</option>\n<option value=\"36\">徳島県</option>\n<option value=\"37\">香川県</option>\n<option value=\"38\">愛媛県</option>\n<option value=\"39\">高知県</option>\n<option value=\"40\">福岡県</option>\n<option value=\"41\">佐賀県</option>\n<option value=\"42\">長崎県</option>\n<option value=\"43\">熊本県</option>\n<option value=\"44\">大分県</option>\n<option value=\"45\">宮崎県</option>\n<option value=\"46\">鹿児島県</option>\n<option value=\"47\">沖縄県</option>\n                        </select>\r\n                        <!--<i class=\"fa-solid fa-circle-check\"></i>--></div>\r\n                      <div class=\"input_wrap municipalities\">\r\n                        <input id=\"municipalities\" class=\"p-locality p-street-address\" type=\"text\" name=\"adr\" maxlength=\"50\" value=\"\" placeholder=\"市区郡\" required>\r\n                        <i class=\"fa-solid fa-circle-check\"></i>\r\n                        <p class=\"caution_msg check_municipalities\" style=\"display: none;\">市区郡を入力してください。</p>\r\n                                              </div>\r\n                    </div>\r\n                    <div class=\"input_wrap\">\r\n                      <input id=\"house_number\" type=\"text\" name=\"adr2\" maxlength=\"50\" value=\"\" placeholder=\"丸の内ニ丁目1番33号\" required>\r\n                      <i class=\"fa-solid fa-circle-check\"></i>\r\n                      <p class=\"caution_msg check_house_number\" style=\"display: none;\">⁩番地まで入力してください</p>\r\n                                          </div>\r\n                    <p class=\"kome\">※丁目・番地・号までご入力ください</p>\r\n                    <div class=\"input_wrap\">\r\n                      <input id=\"building_name\" type=\"text\" name=\"adr3\" maxlength=\"50\" value=\"\" placeholder=\"東建本社丸の内ビル101\">\r\n                      <i class=\"fa-solid fa-circle-check\"></i>\r\n                                          </div>\r\n                    <!--<p class=\"caution_msg check_building_name\" style=\"display: none;\">⁩番地・建物・部屋番号などを入力してください。</p>-->\r\n                    <p class=\"kome\">※建物名＋部屋番号までご入力ください</p>\r\n                  </td>\r\n                </tr>\r\n              </tbody>\r\n            </table>\r\n          </section>\r\n          <section>\r\n            <h3>土地に関するご質問</h3>\r\n            <table>\r\n              <tbody>\r\n                <tr>\r\n                  <th class=\"th_land required\">ご所有地の有無</th>\r\n                  <td>\r\n                    <ul>\r\n                      <li><label class=\"radio_wrap\"><input type