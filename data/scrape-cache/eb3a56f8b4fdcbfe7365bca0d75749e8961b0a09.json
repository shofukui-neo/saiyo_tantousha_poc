er_navi-list\">\n            <ul class=\"header_navi-list-child\">\n              <li class=\"header_navi__sub-list\">\n                <p class=\"header_navi-list_txt btn btn-color06\"><a href=\"/recruit/message/index.html\"  target=\"_blank\">メッセージ</a></p>\n              </li>\n            </ul>\n          </li>\n          <li class=\"header_navi-list\">\n            <ul class=\"header_navi-list-child\">\n              <li class=\"header_navi__sub-list\">\n                <p class=\"header_navi-list_txt btn btn-color06\"><a href=\"/recruit/new_graduate/index.html\"  target=\"_blank\">新卒採用</a></p>\n              </li>\n            </ul>\n          </li>\n          <li class=\"header_navi-list\">\n            <ul class=\"header_navi-list-child\">\n              <li class=\"header_navi__sub-list\">\n                <p class=\"header_navi-list_txt btn btn-color06\"><a href=\"/recruit/project/index.html\"  target=\"_blank\">プロジェクト</a></p>\n              </li>\n            </ul>\n          </li>\n        </ul>\n      </li>\n      <li><a href=\"/html/company/index.html\">企業情報</a>\n        <ul class=\"header_navi-child\">\n          <li class=\"header_navi-child-ttl_wrap\">\n            <div class=\"header_navi-child-ttl_inner\">\n              <p class=\"header_navi-child-ttl_txt\">ENTERPRISE<br>INFORMATION</p>\n              <p class=\"header_navi-list_txt btn btn-color06\"><a href=\"/html/company/index.html\">企業情報</a></p>\n            </div>\n          </li>\n          <li class=\"header_navi-list\">\n            <ul class=\"header_navi-list-child\">\n              <li class=\"header_navi__sub-list\">\n                <p class=\"header_navi-list_txt btn btn-color06\"><a href=\"/html/company/system.html\">組織図</a></p>\n              </li>\n            </ul>\n          </li>\n          <li class=\"header_navi-list\">\n            <ul class=\"header_navi-list-child\">\n              <li class=\"header_navi__sub-list\">\n                <p class=\"header_navi-list_txt btn btn-color06\"><a href=\"/html/company/message.html\">社長メッセージ</a></p>\n              </li>\n            </ul>\n          </li>\n          <li class=\"header_navi-list\">\n            <ul class=\"header_navi-list-child\">\n              <li class=\"header_navi__sub-list\">\n                <p class=\"header_navi-list_txt btn btn-color06\"><a href=\"/html/company/enkaku.html\">沿革</a></p>\n              </li>\n            </ul>\n          </li>\n          <li class=\"header_navi-list\">\n            <ul class=\"header_navi-list-child\">\n              <li class=\"header_navi__sub-list\">\n                <p class=\"header_navi-list_txt btn btn-color06\"><a href=\"/html/report/prerelease.html\">プレスリリース</a></p>\n              </li>\n            </ul>\n          </li>\n        </ul>\n      </li>\n    </ul>\n  </nav></header><section class=\"mv mv_company\"> \r\n  <!--パンくずリスト-->\r\n  <div class=\"breadcrumb\">\r\n    <ul>\r\n      <li><a href=\"../../\">トップページ</a></li>\r\n      <li><a href=\"index.html\">企業情報</a></li>\r\n      <li>社長メッセージ</li>\r\n    </ul>\r\n  </div>\r\n  <h1 class=\"mv__h1\">社長メッセージ</h1>\r\n</section>\r\n<section id=\"mainarea\" class=\"clearfix\">\r\n  <h2 class=\"sub-ttl\"><a name=\"top\" id=\"top\"></a>社長メッセージ</h2>\r\n  <div id=\"topmes\">\r\n    <div id=\"messbox\" class=\"clearfix mes\">\r\n      <div id=\"messpic\" class=\"mes\"><br> <img src=\"img/suzuki.jpg\" alt=\"代表取締役社長　鈴木　圭一\"><br>\r\n        代表取締役社長<br>\r\n        鈴木　圭一 </div>\r\n      <div id=\"message\" class=\"mes\"> 　株式会社浜銀総合研究所は、「先見性と創造性と専門性を発揮し、地域の将来の発展に貢献する」ことを経営理念として、1988年に設立されました。創業の地、横浜は、1859年（安政6年）の開港以来、産業振興や技術開発の草分け的役割を果たし、つねにわが国の経済社会をリードしてきました。私たちも、横浜に根付いた先駆者精神を基本スタンスとして、創業以来、調査、研究に際しては、既存の統計データを超えて、自らの足で地道に積み上げたものを検証し、また、コンサルティングにあたっては、徹底して現場を重視し、お客さまとともに問題解決に取り組み、成果を追求する姿勢を貫いてまいりました。このような現場主義のもと、生み出された多くの実績に対するお客さまからの高い評価は、私どもの誇りであり、また大きな喜びであります。<br>\r\n　今、わが国の社会は、少子高齢化・人口減少、デジタル化、グローバル化、エネルギー・環境問題などさまざまな課題に直面し、構造的な変革を求められています。そしてこれらの課題解決に向けて、当社独自の調査・研究成果や経営情報を発信するとともに、専門的な知見と情報を統合・融合し、お客さまに応じた最適なソリューションを提供することが、私たちシンクタンクの使命であると考えます。<br>\r\n　私たちは、今後も社員ひとりひとりが、プロフェッショナルとして専門能力の向上に努め、「行動する問題解決型頭脳集団」として、知的ノウハウのさらなる蓄積に努めてまいります。そして地域社会の潮流の変化を的確にとらえ、先進的なサービスの提供を通じて価値創造の実現を支援していくことにより、地域のみなさまの期待に応え、社会の持続的発展に貢献してまいります。<br>\r\n      </div>\r\n    </div>\r\n  </div>\r\n  <!-- topmes --> \r\n</section>\r\n<section class=\"bottom_link_list\">\r\n  <ul class=\"article__3col01-list\">\r\n              <li class=\"article__3col01-article\"> <a href=\"index.html\">\r\n      <div class=\"article__3col01-ttl_wrap\">\r\n        <h3 class=\"article__3col01-ttl\">会社概要</h3>\r\n      </div>\r\n      </a> </li>\r\n    <li class=\"article__3col01-article\"> <a href=\"system.html\">\r\n      <div class=\"article__3col01-ttl_wrap\">\r\n        <h3 class=\"article__3col01-ttl\">組織図</h3>\r\n      </div>\r\n      </a> </li>\r\n<!--    <li class=\"article__3col01-article\"> <a href=\"message.html\">\r\n      <div class=\"article__3col01-ttl_wrap\">\r\n        <h3 class=\"article__3col01-ttl\">社長メッセージ</h3>\r\n      </div>\r\n      </a> </li>-->\r\n    <li class=\"article__3col01-article\"> <a href=\"enkaku.html\">\r\n      <div class=\"article__3col01-ttl_wrap\">\r\n        <h3 class=\"article__3col01-ttl\">沿革</h3>\r\n      </div>\r\n      </a> </li>\r\n  </ul>\r\n  <ul class=\"article__3col01-list\">\r\n    <!--\t\t      <li class=\"article__3col01-article\"> <a href=\"enkaku.html\">\r\n        <div class=\"article__3col01-ttl_wrap\">\r\n          <h3 class=\"article__3col01-ttl\">沿革</h3>\r\n        </div>\r\n        </a> </li>-->\r\n    <li class=\"article__3col01-article\"> <a href=\"../report/prerelease.html\">\r\n      <div class=\"article__3col01-ttl_wrap\">\r\n        <h3 class=\"article__3col01-ttl\">プレスリリース</h3>\r\n      </div>\r\n      </a> </li>\r\n  </ul>\r\n</section>\r\n<div class=\"page-top_btn\"> <a href=\"#page-top\">&nbsp;</a> </div>\r\n<footer>\r\n  <nav class=\"top__footer-navi\">\r\n    <ul>\r\n      <li><a href=\"/html/site_map/\">サイトマップ</a></li>\r\n      <li><a href=\"/html/regulation/index.html\">免責・利用規定</a></li>\r\n      <li><a href=\"/html/security_policy/index.html\">情報セキュリティ基本方針</a></li>\r\n      <li><a href=\"/html/regulation/person.html\">個人情報保護について</a></li>\r\n      <li><a href=\"/html/regulation/shareduse.html\">法人等のお客さまの情報の共同利用について</a></li>\r\n    </ul>\r\n  </nav>\r\n  <p class=\"footer__txt\"> 【浜銀総合研究所は、横浜銀行グループのシンクタンク・コンサルティング会社。地元神奈川、横浜、川崎、東京に密着した調査から全国規模および海外にいたるまでの専門的研究を手がけています。】<br>\r\n    このホームページに関するご意見、お問合せは、<a href=\"/html/inquiry/inquiry.html\">こちら</a>までお願いします。このホームページの内容を、許可無く転載・複製することを禁止します。 </p>\r\n  <small>Copyright 2019 (C) Hamagin Research Institute,Ltd.All rights reserved.</small> </footer>\r\n<script>\r\n\t// Fix link value (as dev)\r\n\tlet $prd_domain = 'www.yokohama-ri.co.jp';\r\n\tlet $this_domain = window.location.hostname;\r\n\tlet $env = ($this_domain === $prd_domain) ? 1 : 0;\r\n\t$(function(){\r\n\t\tif ($env === 0)\r\n\t\t{\r\n\t\t\t$('a').each(function(){\r\n\t\t\t\tlet $href = $(this).attr('href');\r\n\t\t\t\tlet $is_target = ($(this).hasClass('noRewrite')) ? 0 : 1;\r\n\t\t\t\tlet $href_fix = $href.replace($prd_domain, $this_domain);\r\n\t\t\t\tif ($is_target) $(this).attr('href', $href_fix);\r\n\t\t\t})\r\n\t\t}\r\n\t})\r\n</script><div class=\"site_login_wrap\">\r\n  <div id=\"site__close-btn\">\r\n    <div id=\"site__close-btn-inner\"> <span></span> <span></span> </div>\r\n  </div>\r\n  <div class=\"site_login_inner\">\r\n    <form autocomplete=\"off\">\r\n      <p class=\"site_login_ttl\">会員ログイン</p>\r\n        <div id=\"account_lock_message\" style=\"color:#ff0000;font-size: 14px;margin-bottom: 20px;display:none;\">10回連続ログイン失敗により、アカウントがロックされました。<br/>1時間後に解除されますが、お急ぎの場合は管理者へお問い合わせください。</div>\r\n        <div id=\"login_error_message\" style=\"color:#ff0000;font-size: 14px;margin-bottom: 20px;display:none;\">会員IDかパスワードが間違っています</div>\r\n      <p class=\"site_login_id\">\r\n        <input type=\"text\" name=\"memberid\" placeholder=\"会員ID\" >\r\n      </p>\r\n      <p class=\"site_login_id\">\r\n        <input type=\"password\"  name=\"passwd\" placeholder=\"パスワード\">\r\n      </p>\r\n      <p class=\"site_login_txt\">＊会員IDまたはパスワードをお忘れの方は<a href=\"/html/inquiry/inquiry.html?nno=3\">こちら</a></p>\r\n      <p class=\"site_loginsubmit\">\r\n        <input type=\"button\" value=\"ログイン\" id=\"site_login_button\" />\r\n      </p>\r\n      <ul class=\"site_login_list\">\r\n        <li>・新規入会の会員さまには、入会受付から2週間程度で会員ＩＤ、パスワードをご案内します。</li>\r\n        <li>・「会員ログイン」して「有料サービス」をお申込みいただいた場合、「お申込み」だけで「課金」が発生することはありませんのでご安心ください。</li>\r\n      </ul>\r\n    </form>\r\n  </div>\r\n\r\n<script>\r\n\r\n/* ログイン */\r\n$(function() {\r\n    $(\"#site_login_button\").on(\"click\", function() {\r\n        $.ajax({\r\n            url: \"/php/loginform.php?dt=1614868130\",\r\n            type:'POST',\r\n            data:{\r\n                'memberid': $('input[name=\"memberid\"]').val(),\r\n                'passwd': $('input[name=\"passwd\"]').val(),\r\n                'logintokens': \"6104ca638fa34a9b17b047d9ae3fe5ba\"\r\n            }/*,\r\n            dataType:'json'*/\r\n        }).done(function(data, textStatus, jqXHR) {\r\n            if (data != null && data != \"\") {\r\n                $(\"#account_lock_message\").hide();\r\n                $(\"#login_error_message\").hide();\r\n                // 認証失敗\r\n                if (data == \"failed\") {\r\n                    //alert(\"failed\");\r\n                    $(\"#login_error_message\").show();\r\n                } else if (data == \"locked\") {\r\n                    //alert(\"locked\");\r\n                    $(\"#account_lock_message\").show();\r\n                } else {\r\n                    location.href = data;\r\n                    setTimeout(function(){\r\n                         $('.site_login_wrap').css({display: 'none'});\r\n                    },2000);\r\n                }\r\n            }\r\n        }).fail(function(jqXHR, textStatus, errorThrown) {\r\n            //alert(\"fail\");\r\