rumbs__list\">\r\n              <li class=\"breadcrumbs__item\">\r\n                <a href=\"/index.html\">\r\n                  <span class=\"multiline-none-light\">ホーム</span>\r\n                </a>\r\n              </li>\r\n              <li class=\"breadcrumbs__item\">採用情報</li>\r\n            </ul>\r\n          </nav>\r\n          <div class=\"articleBody fade\">\r\n            <section class=\"articleContents\">\r\n              <div id=\"HeadingPrimary\" class=\"HeadingLevel1\">\r\n                <h1 class=\"HeadingLevel1__body\">\r\n                  <span class=\"HeadingLevel1__main\">採用情報</span>\r\n                </h1>\r\n              </div>\r\n              <br>\r\n              <br>\r\n              <div class=\"office\">\r\n                <div class=\"switch__content\">\r\n\r\n                  <div class=\"office__body\" id=\"philosophy\">\r\n                    <!--h2 class=\"heading-2\">採用条件</h2-->\r\n                    <div style=\"padding-top: 0em; border-top: 0px solid #e6edf1;\">\r\n                      <table class=\"table_Basic\">\r\n                        <colgroup>\r\n                          <col width=\"30%\">\r\n                          <col width=\"70%\">\r\n                        </colgroup>\r\n                        <tbody>\r\n                          <tr>\r\n                            <th>募集職種</th>\r\n                            <td>営業・サービス・事務</td>\r\n                          </tr>\r\n                          <tr>\r\n                            <th>選考方法</th>\r\n                            <td>書類選考、面接</td>\r\n                          </tr>\r\n                          <tr>\r\n                            <th>給与</th>\r\n                            <td>当社規定により支給</td>\r\n                          </tr>\r\n                          <tr>\r\n                            <th>諸手当</th>\r\n                            <td>役職手当、家族手当、通勤手当、業務手当、赴任手当、資格手当、内勤手当\r\n                            </td>\r\n                          </tr>\r\n                          <tr>\r\n                            <th>賞与</th>\r\n                            <td>年２回（7月、12月）</td>\r\n                          </tr>\r\n                          <tr>\r\n                            <th>昇給</th>\r\n                            <td>年１回（4月）</td>\r\n                          </tr>\r\n                          <tr>\r\n                            <th>勤務地</th>\r\n                            <td>各営業拠点内</td>\r\n                          </tr>\r\n                          <tr>\r\n                            <th>勤務時間</th>\r\n                            <td>①7：00〜16：15（休憩　1時間30分）　- 営業・サービス<br>\r\n②7：30〜16：45（休憩　1時間30分）　- 営業・サービス<br>\r\n③8：00〜17：15（休憩　1時間30分）　- 営業・サービス<br>\r\n④8：30〜18：45（休憩　1時間30分）　- 営業・サービス<br>\r\n⑤8：30〜17：15（休憩　1時間00分）　- 事務員</td>\r\n                          </tr>\r\n                          <tr>\r\n                            <th>休日</th>\r\n                            <td>年間107日（日曜・祝日、隔週第2.第4土曜、年末年始、お盆、誕生日、その他）</td>\r\n                          </tr>\r\n                          <tr>\r\n                            <th>休暇</th>\r\n                            <td>有給休暇<br>\r\n特別休暇（慶弔休暇、育児休暇、介護休暇等）</td>\r\n                          </tr>\r\n                          <tr>\r\n                            <th>試用期間</th>\r\n                            <td>３カ月、試用期間中は日給</td>\r\n                          </tr>\r\n                          <tr>\r\n                            <th>福利厚生</th>\r\n                            <td>社会保険（健康保険、厚生年金保険、雇用保険、労災保険）、<br>\r\n慶弔見舞制度、退職金制度、社員研修旅行、<br>\r\nクボタグループ保険（生命保険、損害保険）制度、<br>\r\n確定拠出年金制度（DC）等</td>\r\n                          </tr>\r\n                          <tr>\r\n                            <th>教育制度</th>\r\n                            <td>各種資格取得制度</td>\r\n                          </tr>\r\n                        </tbody>\r\n                      </table>\r\n                      <br>\r\n                      <br>\r\n                      \r\n                      <div class=\"Box\">\r\n    