{"url":"http://www.tokutu.co.jp/","html":"\r\n<!DOCTYPE html>\r\n<html lang=\"ja\">\r\n<head>\r\n<!-- Google Tag Manager -->\r\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\r\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\r\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\r\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\r\n})(window,document,'script','dataLayer','GTM-KR2LV5H');</script>\r\n<!-- End Google Tag Manager -->\r\n<meta charset=\"UTF-8\">\r\n<title>NX徳通株式会社</title>\r\n<meta name=\"description\" content=\"NX徳通は、トラック輸送、鉄道輸送、倉庫による保管など、総合物流企業としての実績とノウハウを活かし、お客様のあらゆる物流ニーズにお応えして、最適なロジスティクスを実現します。\">\r\n<meta name=\"keywords\" content=\"NX徳通,徳通,引越,荷物,トラック貸切輸送,積合せ輸送（企業間輸送）,鉄道輸送,保管サービス（倉庫）,重量品輸送,産業廃棄物収集運搬,3PL,日本通運\">\r\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1.0\">\r\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\r\n\r\n<link rel=\"shortcut icon\" href=\"img/cmn/favicon.ico\" type=\"/image/vnd.microsoft.icon\" />\r\n<link rel=\"icon\" href=\"img/cmn/favicon.ico\" type=\"image/vnd.microsoft.icon\" />\r\n<link href=\"//fonts.googleapis.com/css?family=Prata\" rel=\"stylesheet\">\r\n<link href=\"css/setting.css\" rel=\"stylesheet\">\r\n<link href=\"css/animate.css\" rel=\"stylesheet\">\r\n<link href=\"css/drawer.css\" rel=\"stylesheet\">\r\n<link href=\"css/parts.css\" rel=\"stylesheet\">\r\n<link href=\"css/layout.css\" rel=\"stylesheet\">\r\n<link href=\"css/top.css\" rel=\"stylesheet\">\r\n<style>\r\n.fontNormal {\r\n\tfont-weight: normal;\r\n}\r\n.pb_32 {\r\n\tpadding-bottom: 32px\r\n}\r\n\r\n@media screen and (min-width: 899px) {\r\na[href^=\"tel:\"] {\r\n\tpointer-events: none;\r\n}\r\n.fontsize_22rem {\r\n\tfont-size: 22rem;\r\n}\r\n}\r\ntr a {\r\n\tfont-weight: normal;\r\n}\r\n.rikunabi {\r\n\tposition: absolute;\r\n\tbottom: 100px;\r\n\tright: 48px;\r\n\tz-index: 77;\r\n}\r\n.rikunabi_sp {\r\n\tdisplay: none;\r\n}\r\n\r\n@media screen and (max-width: 899px) {\r\n.rikunabi {\r\n\tdisplay: none;\r\n}\r\n.rikunabi_sp {\r\n\tdisplay: block;\r\n\tpadding: 30px 9px;\r\n}\r\n\t.rikunabi_sp img {\r\n\t\twidth: 110px;\r\n\t}\r\n}\r\n\r\n\r\nsection.secDesignG {\r\n\tmargin: 210px 0 480px 0px;\r\n}\r\n@media screen and (max-width: 599px) {\r\n\tsection.secDesignG {\r\n\t\tmargin-bottom: 160px;\r\n\t}\r\n}\r\n@media screen and (min-width: 899px) and (max-height: 799px) {\r\n\tsection.secDesignG {\r\n\t\tmargin-bottom: 300px;\r\n\t}\r\n}\r\nsection.secDesignG::before, section.secDesignG::after {\r\n    border-style: none;\r\n  }\r\n.newsList {\r\n    display: flex;\r\n    flex-wrap: wrap;\r\n    width: 100%;\r\n}\r\n@media screen and (max-width: 599px) {\r\n.newsList {\r\n\tdisplay: block;\r\n}\r\n}\r\n.newsList dt,.newsList dd{\r\n\tmargin-bottom: 20px;\r\n}\r\n.newsList dt,.newsList dd a,.newsList dd p,.newsList dd > div{\r\n\tpadding: 10px 0;\r\n}\r\n.newsList dt{\r\n\twidth: 170px;\r\n}\r\n.newsList dd{\r\n\twidth: calc(100% - 170px);\r\n\tposition: relative;\r\n}\r\n.newsList dd::before{\r\n\tcontent: \"\";\r\n\tdisplay: inline-block;\r\n\tposition: absolute;\r\n\twidth: calc(100% + 170px);\r\n  height: 20%;\r\n  bottom: 0;\r\n  right: 0;\r\n  border-bottom: 1px solid #ddd;\r\n  pointer-events: none;\r\n}\r\n@media screen and (max-width: 599px) {\r\n.newsList dt{\r\n\tmargin-bottom: 0px;\r\n}\r\n.newsList dt,.newsList dd{\r\n\twidth: 100%;\r\n}\r\n.newsList dd::before{\r\n\twidth: 95%;\r\n}\r\n}\r\n.newsList dd a{\r\n\tdisplay: inline-block;\r\n\twidth: 100%;\r\n}\r\n.newsList .pht,.listDesignN .pht{\r\n\tdisplay: none;\r\n}\r\n\r\n.listDesignN {\r\n  width: 100%;\r\n  cursor:pointer;\r\n}\r\n@media screen and (max-width: 599px) {\r\n  .listDesignN {\r\n    width: 100%;\r\n  }\r\n}\r\n.newsList .listDesignN h3 {\r\n  font-size: 16px;\r\n}\r\n.newsList .listDesignN h3:hover {\r\n  text-decoration: none;\r\n  color: #5BC2E7;\r\n}\r\n.listDesignN h3 span.hoverInline{\r\n  display: none;\r\n}\r\n.details h3 span.hoverInline{\r\n  display: inline !important;\r\n}\r\n.listDesignN p {\r\n  font-weight: normal;\r\n  display: none;\r\n}\r\n.listDesignN a {\r\n  transition: .3s;\r\n}\r\n.listDesignN a:hover,\r\n.listDesignN a:hover h3 {\r\n  color: #FFF;\r\n}\r\n.line{\r\n\tdisplay:inline-block;\r\n\twidth: 100%;\r\n\tborder-bottom: 1px solid #ddd;\r\n}\r\nbold{\r\n\tfont-weight: bold;\r\n}\r\n</style>\r\n\r\n<script src=\"//ajax.googleapis.com/ajax/libs/jquery/3.6.4/jquery.min.js\"></script>\r\n<script src=\"js/jquery.inview.min.js\"></script>\r\n<script src=\"js/iscroll.js\"></script>\r\n<script src=\"js/dropdown.js\"></script>\r\n<script src=\"js/drawer.js\"></script>\r\n<script>\r\n$(document).ready(function() {\r\n  $(\".drawer\").drawer();\r\n});\r\n</script>\r\n\r\n<script src=\"js/video-resize.min.js\"></script>\r\n<script>\r\n$(function(){\r\nvar video = vr.video({\r\n\telement: '#video',\r\n\talign: {x: 0.5, y: 0.5}, //コンテナ内のビデオの位置を定義。align: {x: 0.5, y: 0.5}中央に表示されるビデオになります。\r\n\tsources: 'movie/movie.mp4',\r\n\tposter: 'img/mainimg_pc.jpg', //ビデオが読み込まれている間に表示される画像のパス\r\n\tmobilePoster: 'img/mainimg_sp.jpg', //画面幅がmobileBreak値のものよりも小さいデバイスに表示される画像。\r\n\tautoplay: true,\r\n\tloop: true,\r\n\tmute: true,\r\n\tmobileBreak: 850, //モバイルレイアウトの最大画面幅を決定します。画面の幅がmobileBreak値以下の場合、ビデオは代わり<img>にposter/ mobilePostersourceを使用して静的にレンダリングされます。\r\n});\r\nvideo.init();\r\n});\r\n</script>\r\n\r\n<script src=\"js/cmn.js\"></script>\r\n<script async defer src=\"//maps.googleapis.com/maps/api/js?key=AIzaSyAIakVqzLIcdy7vvrAb6koZH99H3KU336g\"></script>\r\n\r\n</head>\r\n\r\n<body class=\"drawer drawer--left drawer--sidebar\">\r\n<!-- Google Tag Manager (noscript) -->\r\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-KR2LV5H\"\r\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\" sandbox></iframe></noscript>\r\n<!-- End Google Tag Manager (noscript) -->\r\n<!--\r\n/////////////////////////////////////////////////////////\r\n/////////////////////////////////////////////////////////\r\n-->\r\n<header id=\"wrap\" class=\"panoramaArea\">\r\n<div class=\"videoWrap\">\r\n<video id=\"video\" class=\"pc\"></video>\r\n</div>\r\n\r\n<h1><a href=\"\"><img src=\"img/cmn/logo.svg\"></a></h1>\r\n<p class=\"message animated fadeIn\">\r\n<span class=\"title\"><i><span class=\"title_a\">NXグループ</span><br><span class=\"title_c\">NX徳通株式会社</span></i></span>\r\n<span class=\"title title_d\"><i><span>物流を通じて<br class=\"sp\">地域に貢献し、<br>豊かな未来を創る<br class=\"sp\">総合物流企業です。</span></i></span><br>\r\n<a class=\"rikunabi_sp\" href=\"https://job.mynavi.jp/27/pc/search/corp293459/outline.html\" target=\"_blank\"><img src=\"img/cmn/bnr_rikunabi.gif\"></a>\r\n</p>\r\n<div class=\"rikunabi\"><a href=\"https://job.mynavi.jp/27/pc/search/corp293459/outline.html\" target=\"_blank\"><img src=\"img/cmn/bnr_rikunabi.gif\"></a></div>\r\n<a href=\"#anc0\" class=\"scroll\">scroll</a>\r\n</header>\r\n<!--\r\n/////////////////////////////////////////////////////////\r\n/////////////////////////////////////////////////////////\r\n-->\r\n<button type=\"button\" class=\"drawer-toggle drawer-hamburger\">\r\n<span class=\"sr-only\">toggle navigation</span>\r\n<span class=\"drawer-hamburger-icon\"></span>\r\n</button>\r\n\r\n<nav class=\"drawer-nav\" role=\"navigation\">\r\n<ul class=\"globalNav drawer-menu\">\r\n<li>\r\n\t<a href=\"#anc0\">News<span>お知らせ</span></a>\r\n</li>\r\n<li>\r\n\t<a href=\"#anc1\">Service<span>サービス一覧</span></a>\r\n</li>\r\n<li>\r\n<a href=\"#anc2\" data-toggle=\"dropdown\">Moving<span>NX徳通の引越サービス</span></a>\r\n</li>\r\n<li>\r\n<a href=\"#anc3\" data-toggle=\"dropdown\">Case Studies<span>事例集</span></a>\r\n</li>\r\n<li class=\"drawer-dropdown\">\r\n<a href=\"#anc4\" data-toggle=\"dropdown\">Company<span>会社情報</span></a>\r\n\t<ul class=\"localNav drawer-dropdown-menu\">\r\n\t<li><a href=\"#ancCompany1\">企業理念</a></li>\r\n\t<li><a href=\"#ancCompany2\">代表メッセージ</a></li>\r\n\t<li><a href=\"#ancCompany3\">会社概要</a></li>\r\n\t<li><a href=\"#ancCompany4\">会社沿革</a></li>\r\n\t<li><a href=\"#ancCompany5\">所在地</a></li>\r\n\t</ul>\r\n</li>\r\n<li>\r\n<a href=\"#anc5\">Recruit<span>採用情報</span></a>\r\n</li>\r\n<li>\r\n<a href=\"#anc6\">Contact<span>各種お問い合わせ</span></a>\r\n</li>\r\n<li>\r\n\t<a href=\"#anc7\" data-toggle=\"dropdown\">Search<span>輸送状況検索</span></a>\r\n\t<ul class=\"localNav drawer-dropdown-menu\">\r\n\t\t<li><a href=\"https://www45.nittsu.co.jp/webapp/rcsanvaj701.srv\" target=\"_blank\">鉄道コンテナ</a></li>\r\n\t</ul>\r\n</li>\r\n</ul>\r\n</nav>\r\n<!--\r\n/////////////////////////////////////////////////////////\r\n/////////////////////////////////////////////////////////\r\n-->\r\n<main>\r\n<!-- <div style=\"width: 90%;max-width: 720px;margin: auto;background:#8ec400;padding: 24px;margin: 48px auto 0;text-align: center;\">\r\n<a class=\"headerCampaign_text\" href=\"https://www.nittsu.co.jp/info/20211129.html\" target=\"_blank\" style=\"color:#fff;\">グループブランド導入に伴う日本通運グループ各社の社名変更に関するお知らせ</a>\r\n</div> -->\r\n\r\n<section id=\"anc0\" class=\"secDesignG\">\r\n<div class=\"wrap\">\r\n<div class=\"secTtl\">\r\n<h2>News<span>お知らせ</span></h2>\r\n</div>\r\n<dl class=\"newsList\">\r\n<dt>2026年4月1日</dt><dd><a href=\"doc/news20260401.pdf\" target=\"_blank\">東京支店移転・統合のお知らせ</a></dd>\r\n<dt>2025年12月15日</dt><dd><a href=\"doc/news20251215.pdf\" target=\"_blank\">本社移転のお知らせ</a></dd>\r\n<dt>2025年11月25日</dt><dd><a href=\"doc/news20251125.pdf\" target=\"_blank\">大阪支店移転のお知らせ</a></dd>\r\n<dt>2025年10月28日</dt><dd><div class=\"listDesignN\" id=\"newsList1\">\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t<div class=\"pht\"><img class=\"pc\" src=\"img/news_img01.jpg\"><img class=\"sp\" src=\"img/news_img01sp.jpg\"></div>\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t<div class=\"ttlArea flexCenterLeft\">\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t<h3><span class=\"hoverInline\">「会社創立84年、安全と技術の頂点へ」<br></span>当社ドライバーが全国トラックドライバー・コンテストで優勝！</h3>\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t<p class=\"txt\">当社鳴門支店所属ドライバー 田中宏樹さん が、第57回全国トラックドライバー・コンテスト（トレーラー部門）で優勝し、警察庁長官賞および全日本トラック協会長賞を受賞しました。<br>\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<span class=\"line\"></span>\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t地区大会を勝ち抜いてきた全国の精鋭ドライバー146名（うちトレーラー部門34名）が集い、運転技術・安全確認・法令遵守などを競いました。<br>\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t高度な技術が求められる難関であり、今回の優勝は業界でも非常に名誉ある成果です。<br><br>\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t本人からのコメント<br>\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t「<bold>強化訓練中に失敗ばかりで自信を失っていると、仲間や家族が励ましてくれ、心機一転してコンテストに臨むことができました。また、苦手な学科は過去問を何度も解いたり、空き時間に復習を重ねたことで、良い結果につながりました。今後は、この経験を活かし、他のドライバーの模範になるよう精進いたします。</bold>」<br><br>\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t当社は、社員一人ひとりの安全意識と技術向上を支援し、「安全はすべてに優先する」を安全理念に掲げ、地域や業界の模範となる企業を目指してまいります。\r\n\t\t\t\t\t\t\t\t\t\t\t\t</p>\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t</div></div></dd>\r\n<dt>2021年11月26日</dt><dd><a href=\"https://www.nittsu.co.jp/info/20211129.html\" target=\"_blank\">グループブランド導入に伴う日本通運グループ各社の社名変更に関するお知らせ</a></dd>\r\n</dl>\r\n</div>\r\n</section>\r\n\r\n<section id=\"anc1\" class=\"secDesignA\">\r\n<div class=\"wrap\">\r\n<img src=\"img/service_mainimg.jpg\" class=\"secPht\">\r\n\r\n\r\n<div class=\"secTtl\">\r\n<h2>Service<span>サービス一覧</span></h2>\r\n<p>\r\nNX徳通は、トラック輸送、鉄道輸送、倉庫による保管など、\r\n総合物流企業としての実績とノウハウを活かし、お客様のあらゆる物流ニーズにお応えして、\r\n最適なロジスティクスを実現します。\r\n</p>\r\n</div>\r\n\r\n<ul class=\"clm2 listDesignA\">\r\n<li class=\"clm2\">\r\n<div class=\"pht\"><img src=\"img/service_img01.jpg\"></div>\r\n<div class=\"ttlArea flexCenterLeft\">\r\n<h3>トラック貸切輸送</h3>\r\n<span class=\"tel\">[ TEL ] 088-664-5012</span>\r\n<span class=\"hour\">[ 受付時間 ] 8:30 ～ 17:30 月～金(祝祭日を除く)</span>\r\n<p class=\"txt\">\r\n小型車から大型車など各種取り揃え、徳島県内はもとより、全国各地へ向けての車両、貨物等に対し、\r\n様々なご要望に対応しています。輸送途中での積み替えがなく、簡易な梱包で配送が可能です。<br>\r\nまた、県外の当社拠点にて四国及び徳島県までの車両情報、貨物情報等についてのネットワークも構築しています。\r\n</p>\r\n</div>\r\n</li>\r\n<li class=\"clm2\">\r\n<div class=\"pht\"><img src=\"img/service_img02.jpg\"></div>\r\n<div class=\"ttlArea flexCenterLeft\">\r\n<h3>積合せ輸送（企業間輸送）</h3>\r\n<span class=\"tel\">[ TEL ] 088-664-1441</span>\r\n<span class=\"hour\">[ 受付時間 ] 8:30 ～ 17:30 月～金(祝祭日を除く)</span>\r\n<p class=\"txt\">\r\n当社が窓口となり、当社物流センター（倉庫）拠点等から、名鉄ＮＸ運輸㈱および、そのグループ会社の特別積合せ貨物輸送を利用し、「こぐまアロー便」でお届けいたします。<br>\r\n<span class=\"caution\">法人のお客様が対象となります。個人様あての配送はおこなっておりません<br>\r\n集貨場所の状況やお荷物の性質・梱包状態によりお取扱いできない場合もございます。事前に営業所へお問合せ願います。</span>\r\n</p>\r\n<p class=\"txt\">\r\n<a href=\"https://ap.meitetsuunyu.co.jp/webtrace/webtsuiseki/webtsuiseki.aspx\" target=\"_blank\" class=\"btnLink\">名鉄ＮＸ運輸（株）配送状況問合せ（外部サイト）</a>\r\n</p>\r\n</div>\r\n</li>\r\n<li class=\"clm2\">\r\n<div class=\"pht\"><img src=\"img/service_img03.jpg\"></div>\r\n<div class=\"ttlArea flexCenterLeft\">\r\n<h3>鉄道輸送</h3>\r\n<span class=\"tel\">[ TEL ] 088-686-2162</span>\r\n<span class=\"hour\">[ 受付時間 ] 8:30 ～ 17:30 月～金(祝祭日を除く)</span>\r\n<p class=\"txt\">\r\n鉄道コンテナ輸送は、鉄道による幹線部分と、トラックによる集荷・配達との連携によりお届けする複合一貫輸送サービスです。\r\n発のお客様から着のお客様まで一貫してコーディネートいたします。北海道から九州まで全国に張り巡らされたネットワークを活用し、\r\nお預かりした荷物をドア・ツー・ドアで安全・確実・スムーズに、しかも低コストで輸送しております。\r\n<a href=\"https://www45.nittsu.co.jp/webapp/rcsanvaj701.srv\" target=\"_blank\" class=\"btnLink\">鉄道コンテナ 輸送状況 （日本通運）</a>\r\n</p>\r\n</div>\r\n</li>\r\n<li class=\"clm2\">\r\n<div class=\"pht\"><img src=\"img/service_img05.jpg\"></div>\r\n<div class=\"ttlArea flexCenterLeft\">\r\n<h3>保管サービス（倉庫）</h3>\r\n<span class=\"tel\">[ TEL ] 088-664-5012</span>\r\n<span class=\"hour\">[ 受付時間 ] 8:30 ～ 17:30 月～金(祝祭日を除く)</span>\r\n<p class=\"txt\">\r\n倉庫は、原材料や製品の在庫拠点、供給拠点としての利用や、国際輸送をサポートする拠点など、\r\n物流センターとして、さまざまなお客様のニーズにお応えしております。\r\n更に近年は、必要な量だけジャストインタイムにユーザーへお届けするなど物流の高品質が求められております。\r\n営業倉庫を核とした総合的な物流サービスを提案し、リアルタイムな物流情報提供を行うなど、\r\n県内最大規模の倉庫面積とネットワークを活かし、お客様へ最適な物流サービスをコーディネートいたします。\r\n<img src=\"img/service_img05-1.jpg\">\r\n</p>\r\n</div>\r\n</li>\r\n<li class=\"clm2\">\r\n<div class=\"pht\"><img src=\"img/service_img06.jpg\"></div>\r\n<div class=\"ttlArea flexCenterLeft\">\r\n<h3>重量品輸送</h3>\r\n<span class=\"tel\">[ TEL ] 088-664-3722</span>\r\n<span class=\"hour\">[ 受付時間 ] 8:30 ～ 17:30 月～金(祝祭日を除く)</span>\r\n<p class=\"txt\">\r\nあらゆる重量物の輸送や据付けに関して、優れたノウ・ハウと豊富な実績を持つエキスパート集団にお任せ下さい。\r\n特殊機材の機動力で、重くて特殊な形状のものを動かし、据え付けます。\r\n<img src=\"img/service_img06-1.jpg\">\r\n</p>\r\n</div>\r\n</li>\r\n<li class=\"clm2\">\r\n<div class=\"pht\"><img src=\"img/service_img07.jpg\"></div>\r\n<div class=\"ttlArea flexCenterLeft\">\r\n<h3>産業廃棄物収集運搬</h3>\r\n<span class=\"tel\">[ TEL ] 088-664-3722</span>\r\n<span class=\"hour\">[ 受付時間 ] 8:30 ～ 17:30 月～金(祝祭日を除く)</span>\r\n<p class=\"txt\">\r\n廃棄物の処理については、排出事業者の適正処理に関する管理責任が、より厳格に求められるようになってきております。\r\n廃棄物は、法律上「一般廃棄物」と「産業廃棄物」に区分されており、それぞれに適正に処理するための方法などが定められております。\r\n企業など事業活動を行っている事業者から排出されるもののうち、法令で産業廃棄物と規定されているものは産業廃棄物、\r\nそうでないものは一般廃棄物となります。<br>\r\n当社では事業所から排出される産業廃棄物を処理・処分業者まで収集運搬する業務を行っています。\r\n</p>\r\n</div>\r\n</li>\r\n<li class=\"clm2\">\r\n<div class=\"pht\"><img src=\"img/service_img08.jpg\"></div>\r\n<div class=\"ttlArea flexCenterLeft\">\r\n<h3>3PL</h3>\r\n<span class=\"tel\">[ TEL ] 088-664-5012</span>\r\n<span class=\"hour\">[ 受付時間 ] 8:30 ～ 17:30 月～金(祝祭日を除く)</span>\r\n<p class=\"txt\">\r\nお客様の全ての部門における包括的な物流の改革、あるいは必要とされる部門（例えば販売物流）のみ輸送の効率化を図るなど、ご要望に応じた提案をいたします。<br>\r\n豊富なノウハウを有する総合物流企業として、徳島県のみならず全国規模でお客様のビジネスをサポートいたします。\r\n</p>\r\n</div>\r\n</li>\r\n\r\n</ul>\r\n</div><!-- wrap -->\r\n</section>\r\n<!--\r\n////////////////////////////////////////////////////////\r\n-->\r\n<section id=\"anc2\" class=\"secDesignB\">\r\n<div class=\"wrap\">\r\n<img src=\"img/hikkoshi_mainimg.jpg\" class=\"secPht\">\r\n\r\n<div class=\"secTtl\">\r\n<h2>Moving<span>NX徳通の引越サービス</span></h2>\r\n<p>\r\n徳島からのご家族や単身のお引越し、事務所の移転・レイアウト変更は、NX徳通にお任せください。確かな技術と豊富な経験で、お客様の大切な家財や什器類を親切・丁寧・確実にお運びいたします。\r\n</p>\r\n</div>\r\n\r\n<ul class=\"clm3 listDesignB\">\r\n<li id=\"ancHikkoshi1\">\r\n<div class=\"pht\"><img src=\"img/hikkoshi_img01.jpg\"></div>\r\n<div class=\"ttlArea flexCenterLeft\">\r\n<h3>ご家族のお引越</h3>\r\n<p class=\"txt\">\r\n「引越をするなら少しでも安くしたい。でも安心して任せられる業者に・・・・・でもどうすれば？」<br><br>\r\nNX徳通では、お客さまそれぞれのご要望に合わせて、ご家族・単身プランやオプションサービスなどを組み合せ、\r\nお客さまにぴったりのお引越をプロデュース！<br>\r\nお客様にご納得いただける引越し内容でご満足をいただいています。<br>\r\n今後もお客様の大切なお荷物を、より一層安全にお取扱いいたします。<br>\r\n\r\n<span class=\"caution\">※</span>NX徳通は引越優良事業者に認定されています。<br>\r\n全日本トラック協会にて平成２６年度より「引越事業者優良認定制度」が創設されました。<br>\r\nこの制度は、全日本トラック協会が安全・安心な引越サービスを提供すると認めた引越事業者を、\r\n引越優良事業者として認定するものであり、当該事業者には優良事業者の証として「引越安心マーク」が交付されます。\r\n<img src=\"img/hikkoshi_img01-1.jpg\">\r\n<img src=\"img/hikkoshi_img01-2.jpg\">\r\n</p>\r\n</div>\r\n</li>\r\n<li id=\"ancHikkoshi2\">\r\n<div class=\"pht\"><img src=\"img/hikkoshi_img02.jpg\"></div>\r\n<div class=\"ttlArea flexCenterLeft\">\r\n<h3>単身のお引越（単身パック）</h3>\r\n<p class=\"txt\">\r\nお客様ごとに専用ボックスに入れて運ぶので、お荷物を安心、安全に運べます。進学、就職（新入社員）、法人では単身赴任者にピッタリのお引越しです。<br>\r\n人事担当者様の手間を軽減するために、転勤者様へのご連絡や手配などは全て当社がお引き受けし、事務の省力化・コスト削減をサポート致します。<br>\r\n</p>\r\n</div>\r\n</li>\r\n<li id=\"ancHikkoshi3\">\r\n<div class=\"pht\"><img src=\"img/hikkoshi_img03.jpg\"></div>\r\n<div class=\"ttlArea flexCenterLeft\">\r\n<h3>会社のお引越（事務所移転）</h3>\r\n<p class=\"txt\">\r\nコンパクトな移転から大規模移転まで、さまざまな業種の移転業務について最適なサービスをご提供いたします。<br>\r\n</p>\r\n</div>\r\n</li>\r\n\r\n</ul>\r\n\r\n<div class=\"contactAreaA\">\r\n<h4>引越・移転に関するお問合せ</h4>\r\n\r\n<div class=\"clm2\">\r\n<div>\r\n\t<a href=\"https://www.nittsu.co.jp/hikkoshi/\" target=\"_blank\" class=\"btnLink\"><span class=\"fontsize_22rem\">NXの国内引越サービス</span><br><span class=\"fontNormal\">※日本通運のサイトを表示します。</span></a>\r\n</div>\r\n<div class=\"pb_32\">\r\n\t<a href=\"tel:0120-13-1092\" target=\"_blank\" class=\"btnLink\"><span class=\"fontsize_22rem\">NX徳通の移転サービス</span><br><span class=\"fontNormal\">フリーダイヤル</span>　0120-13-1092</a>\r\n</div>\r\n\r\n</div>\r\n\t<p>※ご依頼の集中時や休日等の関係により、回答に1～2日程度お時間を頂く場合がございますので、ご了承ください</p>\r\n</div><!-- contactAreaA -->\r\n\r\n</div><!-- wrap -->\r\n</section>\r\n<!--\r\n////////////////////////////////////////////////////////\r\n-->\r\n<section id=\"anc3\" class=\"secDesignC\">\r\n<div class=\"wrap\">\r\n\r\n<div class=\"secTtl\">\r\n<h2>Case Studies<span>事例集</span></h2>\r\n</div>\r\n<ul class=\"clm2 listDesignA\">\r\n<li id=\"ancJirei1\" class=\"clm2\">\r\n<div class=\"pht\"><img src=\"img/jirei_img01.jpg\"></div>\r\n<div class=\"ttlArea flexCenterLeft\">\r\n<h3>鉄道コンテナ</h3>\r\n<p class=\"txt\">\r\n工場から近距離と長距離の双方の輸送を伴うお客様に対して、長距離の納品先については鉄道コンテナ輸送を提案しました。\r\n従来、トラック輸送で対応してきたものの、昨今、ドライバー不足からトラック輸送の手配が困難で大変困っていたとのことでした。\r\n鉄道は、1本の高速コンテナ列車で大型トラック55台分を輸送することが可能なので、トラックに代わる輸送手段として有効であり、\r\nトラックに比べてリーズナブルな運賃が提供できるメリットもあります。また、輸送単位当たりのCO2排出量がトラックの約10分の1と、様々な輸送機関の中で環境負荷が最も少ない輸送手段です。<br><br>\r\nお客様からは、物流費用が削減できること、そして環境にも貢献できることが一石二鳥になると大変喜んでいただいております。<br><br>\r\nお客様のニーズに応じて最適な輸送モードが提案できるのも総合物流企業であるNX徳通ならではと評価いただいております。\r\n<img src=\"img/jirei_img01-1.jpg\">\r\n</p>\r\n</div>\r\n</li>\r\n<li id=\"ancJirei2\" class=\"clm2\">\r\n<div class=\"pht\"><img src=\"img/jirei_img02.jpg\"></div>\r\n<div class=\"ttlArea flexCenterLeft\">\r\n<h3>事務所移転</h3>\r\n<p class=\"txt\">\r\nはじめてオフィスの移転を迎えるお客様に対してあらゆる面でサポートさせていただきました。\r\nはじめてのお客様にとっては全体像がなかなか掴みづらいものです。\r\nそこで、作業完了までのプランを綿密に計画するにあたり、まず移動物品の物量を下見、屋内・屋外の移動経路も安全で最適なルートを確認しました。\r\nまた、転居先も事前に現地に赴いて、状況を把握しました。<br><br>\r\nまた、お客様の部門が多岐にわたることから各部門の責任者の方々に対し、事前説明会を実施、窓口担当者の方の負担を軽減し、\r\n移動作業がよりスムーズに行えるよう万全の体制で臨みました。当日は最後までスムーズに移転作業をさせていただくことができ、\r\nお客様からは長年の経験とノウハウが蓄積されているNX徳通ならではと評価いただきました。\r\n</p>\r\n</div>\r\n</li>\r\n\r\n</ul>\r\n</div><!-- wrap -->\r\n</section>\r\n<!--\r\n////////////////////////////////////////////////////////\r\n-->\r\n<section id=\"anc4\" class=\"secDesignD company\">\r\n<div class=\"wrap\">\r\n<img src=\"img/company_mainimg.jpg\" class=\"secPht\">\r\n\r\n<div class=\"secTtl\">\r\n<h2>Company<span>会社情報</span></h2>\r\n</div>\r\n\r\n<ul class=\"listDesignC\">\r\n\r\n<li id=\"ancCompany1\">\r\n<h3>企業理念</h3>\r\n<div class=\"inner\">\r\n<p>\r\n私たちの使命、それは社会発展の原動力であること。<br>\r\n私たちの挑戦、それは物流から新たな価値を創ること。<br>\r\n私たちの誇り、それは信頼される存在であること。\r\n</p>\r\n</div>\r\n</li>\r\n<li id=\"ancCompany2\" class=\"clm2\">\r\n<div class=\"pht\"><img src=\"img/company_img01.jpg\"></div>\r\n<div class=\"ttlArea flexCenterLeft\">\r\n<h3>代表メッセージ</h3>\r\n<p class=\"name\"><span>代表取締役社長</span>大西　恭司</p>\r\n<p class=\"txt\">\r\n　1942年創業以来、徳島通運株式会社として多くの皆さまにご愛顧を賜り、厚く御礼申し上げます。<br>　当社は、2022年1月、「日本通運グループ」から「ＮＸグループ」への経営体制移行に合わせ、「ＮＸ徳通株式会社」に社名変更いたしました。徳島県を拠点とした企業ではありますが、東京・大阪等にも支店を構え、総合物流企業としてさらなる発展を目指しております。また、国際関連業務につきましてもグループの力を結集し、グローバル化に取り組んでおります。</p>\r\n<p class=\"txt\">\r\n　私たちNXグループは、常に変化し続ける社会において、安全かつ効率的なサプライチェーンの構築をサポートする使命を胸に掲げています。今日の環境では、脱炭素社会、持続可能性、DX化の推進が鍵となっています。これらの要因を重視し、各事業の専門性と競争力を高め、企業価値の最大化を図ってまいります。</p>\r\n<p class=\"txt\">\r\n　これからも、「お客様第一主義」をモットーに、地域に密着した企業として、徳島県の発展のために鋭意努力してまいりますので、引き続き、変わらぬご支援を、よろしくお願い申し上げます。\r\n</p>\r\n</div>\r\n</li>\r\n<li id=\"ancCompany3\" class=\"clm2 flexReverse\">\r\n<div class=\"pht\"><img src=\"img/company_img02.jpg\"></div>\r\n<div class=\"ttlArea flexCenterLeft\">\r\n<h3>会社概要</h3>\r\n\r\n<table>\r\n<tbody>\r\n\r\n<tr>\r\n<th>社名</th>\r\n<td>NX徳通株式会社\t</td>\r\n</tr>\r\n<tr>\r\n<th>設立</th>\r\n<td>昭和17年11月1日</td>\r\n</tr>\r\n<tr>\r\n<th>所在地</th>\r\n<td>〒770-0873<br>徳島市東沖洲一丁目20番2号</td>\r\n</tr>\r\n<tr>\r\n<th>TEL</th>\r\n<td>088-664-5151</td>\r\n</tr>\r\n<tr>\r\n<th>FAX</th>\r\n<td>088-664-5122</td>\r\n</tr>\r\n<tr>\r\n<th>資本金</th>\r\n<td>5,000万円</td>\r\n</tr>\r\n<tr>\r\n<th>従業員数</th>\r\n<td>約270名</td>\r\n</tr>\r\n<tr>\r\n<th>車両台数</th>\r\n<td>約170台</td>\r\n</tr>\r\n<tr>\r\n<th>事業所数</th>\r\n<td>8事業所</td>\r\n</tr>\r\n<tr>\r\n<th>約款</th>\r\n<td>\r\n<a href=\"/doc/yakkan01.pdf\" target=\"_blank\">標準貨物自動車運送約款［PDF 168KB］</a><br>\r\n<a href=\"/doc/yakkan02.pdf\" target=\"_blank\">標準貨物軽自動車運送約款［PDF 168KB］</a><br>\r\n<a href=\"/doc/yakkan03.pdf\" target=\"_blank\">標準貨物自動車利用運送約款［PDF 376KB］</a><br>\r\n<a href=\"/doc/yakkan04.pdf\" target=\"_blank\">標準鉄道利用運送約款［PDF 285KB］</a><br>\r\n<a href=\"/doc/yakkan05.pdf\" target=\"_blank\">標準内航利用運送約款［PDF 300KB］</a><br>\r\n<a href=\"/doc/yakkan06.pdf\" target=\"_blank\">標準引越運送約款［PDF 129KB］</a><br>\r\n<a href=\"/doc/yakkan07.pdf\" target=\"_blank\">標準貨物利用運送（引越）約款［PDF 275KB］</a><br>\r\n<a href=\"/doc/yakkan08.pdf?20260408\" target=\"_blank\">標準倉庫寄託約款（乙）［PDF 138KB］</a>\r\n</td>\r\n</tr>\r\n<tr>\r\n<th>運賃表</th>\r\n<td>\r\n<a href=\"/doc/fare01.pdf\" target=\"_blank\">一般貨物自動車運送事業の貸切運賃料金［PDF 1,164KB］</a><br>\r\n<a href=\"/doc/fare02.pdf\" target=\"_blank\">一般貨物自動車運送事業の積合せ運賃・料金表［PDF 448KB］</a><br>\r\n<a href=\"/doc/fare03.pdf\" target=\"_blank\">一般貨物自動車運送事業の引越運賃料金［PDF 473KB］</a><br>\r\n<a href=\"/doc/fare04.pdf\" target=\"_blank\">鉄道利用運送事業運賃料金［PDF 543KB］</a>\r\n</td>\r\n</tr>\r\n\t<tr>\r\n<th>個人情報保護</th>\r\n<td>\r\n<a href=\"/doc/privacy01.pdf\" target=\"_blank\">個人情報保護方針 [PDF 150KB]</a>\r\n</td>\r\n</tr>\r\n\r\n</tbody>\r\n</table>\r\n\r\n</div>\r\n</li>\r\n<li id=\"ancCompany4\">\r\n<h3>会社沿革</h3>\r\n\r\n<table>\r\n<tbody>\r\n<tr>\r\n<th>昭和17年11月</th>\r\n<td>徳島合同運送株式会社が中心となり、県下主要駅の通運業者が合同、徳島通運株式会社として発足。資本金500千円。</td>\r\n</tr>\r\n<tr>\r\n<th>昭和25年10月</th>\r\n<td>路線貨物自動車運送業を開始。</td>\r\n</tr>\r\n<tr>\r\n<th>昭和27年1月</th>\r\n<td>一般区域貨物自動車運送業を開始。</td>\r\n</tr>\r\n<tr>\r\n<th>昭和37年2月</th>\r\n<td>倉庫業を開始。</td>\r\n</tr>\r\n<tr>\r\n<th>昭和37年11月</th>\r\n<td>日本通運株式会社の経営参加により日通系列会社として再発足。</td>\r\n</tr>\r\n<tr>\r\n<th>昭和44年11月</th>\r\n<td>資本金16,000千円に増資。</td>\r\n</tr>\r\n<tr>\r\n<th>昭和45年5月</th>\r\n<td>資本金24,000千円に増資。</td>\r\n</tr>\r\n<tr>\r\n<th>昭和48年11月</th>\r\n<td>資本金32,000千円に増資。</td>\r\n</tr>\r\n<tr>\r\n<th>昭和57年7月</th>\r\n<td>軽車両等運送事業開始。</td>\r\n</tr>\r\n<tr>\r\n<th>昭和60年12月</th>\r\n<td>東京支店新設</td>\r\n</tr>\r\n<tr>\r\n<th>昭和61年7月</th>\r\n<td>大阪支店新設</td>\r\n</tr>\r\n<tr>\r\n<th>平成6年6月</th>\r\n<td>資本金50,000千円に増資。</td>\r\n</tr>\r\n<tr>\r\n<th>平成6年11月</th>\r\n<td>建設業を開始。</td>\r\n</tr>\r\n<tr>\r\n<th>平成10年3月</th>\r\n<td>産業廃棄物収集運搬業を開始。</td>\r\n</tr>\r\n<tr>\r\n<th>平成22年6月</th>\r\n<td>北関東事業所新設</td>\r\n</tr>\r\n<tr>\r\n<th>平成27年3月</th>\r\n<td>九州支店新設</td>\r\n</tr>\r\n<tr>\r\n<th>令和4年1月</th>\r\n<td>NX徳通株式会社に社名変更</td>\r\n</tr>\r\n<tr>\r\n<th>令和5年4月</th>\r\n<td>九州支店を九州事業所に変更</td>\r\n</tr>\r\n<tr>\r\n<th>令和6年1月</th>\r\n<td>NX阿波合同株式会社をNX徳通に統合</td>\r\n</tr>\r\n<tr>\r\n<th>令和8年4月</th>\r\n<td>東京支店を移転、北関東事業所と統合して北関東支店に変更</td>\r\n</tr>\r\n\r\n</tbody>\r\n</table>\r\n</li>\r\n<li id=\"ancCompany5\">\r\n<h3>所在地</h3>\r\n<ul class=\"clm3 listDesignB\">\r\n<li>\r\n<a href=\"javascript:void(0);\">\r\n<div class=\"pht\"><img src=\"img/access_img01.jpg\"></div>\r\n<div class=\"ttlArea flexCenterLeft\">\r\n<h3>本社</h3>\r\n<div class=\"txt\">\r\n<p>〒770-0873 徳島市東沖洲一丁目20番2号</p>\r\n<p><b>[ 代表 ]</b> 088-664-5151</p>\r\n<p><b>[ コーポレート部 ]</b> 088-664-5151</p>\r\n<p><b>[ コンプライアンス・リスクマネジメント部 ]</b> 088-664-5050</p>\r\n<iframe src=\"https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d255.3128881334466!2d134.6000069551886!3d34.06172985240175!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x35536cf124d3904f%3A0xfb295d0a350406!2z77yu77y45ZWG5LqL44ixIOW-s-WztuWWtualreOCu-ODs-OCv-ODvA!5e0!3m2!1sja!2sjp!4v1767763121496!5m2!1sja!2sjp\" frameborder=\"0\" allowfullscreen sandbox=\"allow-scripts allow-popups allow-popups-to-escape-sandbox allow-same-origin\"></iframe>\r\n</div>\r\n</div>\r\n</a>\r\n</li>\r\n<li>\r\n<a href=\"javascript:void(0);\">\r\n<div class=\"pht\"><img src=\"img/access_img04.jpg\"></div>\r\n<div class=\"ttlArea flexCenterLeft\">\r\n<h3>徳島支店 / 営業本部</h3>\r\n<div class=\"txt\">\r\n<p>〒770-0873 徳島市東沖洲2丁目60</p>\r\n<p><b>[ 代表 ]</b> 088-664-1441</p>\r\n<p><b>[ 営業 ]</b> 088-664-1441</p>\r\n<p><b>[ オペレーション ]</b> 088-664-1441</p>\r\n<p><b>[ 花・野菜センター ]</b> 088-664-3484</p>\r\n</div>\r\n\r\n<div class=\"txt\">\r\n<h3>営業本部</h3>\r\n<p>\r\n<b>[ TEL ]</b> 088-664-5012\r\n</p>\r\n\r\n<iframe src=\"https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d1575.0138841747996!2d134.59931710015817!3d34.06019686575101!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x35536cf1040e60fb%3A0x575abe2beee2a4bd!2z44CSNzcwLTA4NzMg5b6z5bO255yM5b6z5bO25biC5p2x5rKW5rSy77yS5LiB55uu77yW77yQ!5e0!3m2!1sja!2sjp!4v1513242151978\" frameborder=\"0\" allowfullscreen sandbox=\"allow-scripts allow-popups allow-popups-to-escape-sandbox allow-same-origin\"></iframe>\r\n</div>\r\n</div>\r\n</a>\r\n</li>\r\n<li>\r\n<a href=\"javascript:void(0);\">\r\n<div class=\"pht\"><img src=\"img/access_img02.jpg\"></div>\r\n<div class=\"ttlArea flexCenterLeft\">\r\n<h3>鳴門支店</h3>\r\n<d