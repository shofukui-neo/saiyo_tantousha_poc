\n                (i[r].q = i[r].q || []).push(arguments)\n            }, i[r].l = 1 * new Date();\n            a = s.createElement(o),\n                m = s.getElementsByTagName(o)[0];\n            a.async = 1;\n            a.src = g;\n            m.parentNode.insertBefore(a, m)\n        })(window, document, 'script', '//www.google-analytics.com/analytics.js', 'ga');\n\n        ga('create', 'UA-48586834-1', 'daimo.jp');\n        ga('send', 'pageview');\n    </script>\n    <!-- Google Analytics END -->\n\n\n</head>\n\n\n\n<body class=\"home blog\" id=\"top\">\n    <!-- Google Tag Manager (noscript) -->\n    <noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-M5FQZSS\"\n            height=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n    <!-- End Google Tag Manager (noscript) -->\n\n    <header>\n        <a href=\"https://daimo.jp/\"><img src=\"https://daimo.jp/cont/wp-content/themes/daimo_theme/inc/images/logo.png\" class=\"logo\" alt=\"大之木ダイモ\"></a>\n\n        <nav class=\"global\">\n            <a href=\"#\" class=\"btn menu\"><img src=\"https://daimo.jp/cont/wp-content/themes/daimo_theme/inc/images/ico/ico_close.svg\" alt=\"\"></a>\n            <ul>\n                <li class=\"home\"><a href=\"https://daimo.jp/\"><img src=\"https://daimo.jp/cont/wp-content/themes/daimo_theme/inc/images/ico/ico_home.svg\">ホーム</a></li>\n\n                                    <li class=\"\">\n                                        <a href=\"https://daimo.jp/company/\">会社案内</a>\n                    <ul>\n                        <li><a href=\"https://daimo.jp/company/\">大之木ダイモについて</a></li>\n                        <li><a href=\"https://daimo.jp/company/history/\">沿革</a></li>\n                        <li><a href=\"https://daimo.jp/company/initiative/\">取り組み</a></li>\n                    </ul>\n                    </li>\n\n                                            <li class=\"\">\n                                                <a href=\"https://daimo.jp/business/\">事業内容</a>\n                        <ul>\n                            <li><a href=\"https://daimo.jp/business/\">事業内容</a></li>\n                            <li><a href=\"https://daimo.jp/business/ship-interior/\">船舶内装事業部</a></li>\n                        </ul>\n                        </li>\n\n                                                    <li class=\"\">\n                                                        <a href=\"https://daimo.jp/recruit/\">採用情報</a>\n                            <ul>\n                                <li><a href=\"https://daimo.jp/recruit/\">採用情報</a></li>\n                                <li><a href=\"https://daimo.jp/recruit/interview/\">社員インタビュー</a></li>\n                                <li><a href=\"https://daimo.jp/recruit/offer-details/\">募集要項</a></li>\n                            </ul>\n                            </li>\n                            <li class=\"contact for-sp\">\n                                <a href=\"https://daimo.jp/contact/\">お問い合わせ</a>\n                            </li>\n                            <li class=\"relation\">\n                                <ul>\n                                    <li class=\"\"><a href=\"/kinoie/\" target=\"_blank\">注文住宅</a></li>\n                                    <li class=\"\"><a href=\"/reform/renovation/\" target=\"_blank\">リノベーション</a></li>\n                                    <li class=\"\"><a href=\"/reform/\" target=\"_blank\">リフォーム</a></li>\n                                    <li class=\"\"><a href=\"https://www.daimo-fudousan.com/\" target=\"_blank\">不動産</a></li>\n                                </ul>\n                            </li>\n                            <li class=\"sns\">\n                                <a href=\"https://ja-jp.facebook.com/onoki.daimo/\" class=\"facebook\" target=\"_blank\"><img src=\"https://daimo.jp/cont/wp-content/themes/daimo_theme/inc/images/ico/ico_facebook.svg\" alt=\"\"></a>\n                            </li>\n            </ul>\n        </nav>\n        <a href=\"#\" class=\"btn menu for-sp\"><img src=\"https://daimo.jp/cont/wp-content/themes/daimo_theme/inc/images/ico/ico_humberger.svg\"></a>\n    </header>\n\n    <div id=\"container\">\n        <div id=\"main\"><style>\n    @media (max-width: 767px) {\n        .housinglist {\n            width: 100% !important;\n        }\n    }\n\n    @media (min-width: 768px) {\n        .housinglist {\n            width: 22% !important;\n        }\n    }\n</style>\n\n<section id=\"mv\">\n    <h1>空間に<br>アイデアを。</h1>\n    <div class=\"slide\">\n        <div class=\"swiper-container simple\">\n            <ul class=\"swiper-wrapper\">\n                <li class=\"swiper-slide\">\n                    <img src=\"https://daimo.jp/cont/wp-content/themes/daimo_theme/inc/images/top/slide01a.jpg\" alt=\"\" class=\"\">\n                </li>\n                <li class=\"swiper-slide\">\n                    <img src=\"https://daimo.jp/cont/wp-content/themes/daimo_theme/inc/images/top/slide01b.jpg\" alt=\"\" class=\"\">\n                </li>\n                <li class=\"swiper-slide\">\n                    <img src=\"https://daimo.jp/cont/wp-content/themes/daimo_theme/inc/images/top/slide02.jpg\" alt=\"\" class=\"\">\n                </li>\n                <li class=\"swiper-slide\">\n                    <img src=\"https://daimo.jp/cont/wp-content/themes/daimo_theme/inc/images/top/slide03.jpg\" alt=\"\" class=\"\">\n                </li>\n                <li class=\"swiper-slide\">\n                    <img src=\"https://daimo.jp/cont/wp-content/themes/daimo_theme/inc/images/top/slide04.jpg\" alt=\"\" class=\"\">\n                </li>\n                <li class=\"swiper-slide\">\n                    <img src=\"https://daimo.jp/cont/wp-content/themes/daimo_theme/inc/images/top/slide05.jpg\" alt=\"\" class=\"\">\n                </li>\n            </ul>\n        </div>\n        <ul class=\"ticker\">\n                                                            <li>\n                        <a href=\"https://daimo.jp/850/\"><span class=\"date\">2026.06.01</span>広島県知事より表彰を受賞しました（木材産業分野）</a>\n                    </li>\n                \n        </ul>\n    </div>\n</section>\n\n<section id=\"about\">\n    <div>\n        <img src=\"https://daimo.jp/cont/wp-content/themes/daimo_theme/inc/images/top/pic_nobori.jpg\" alt=\"\">\n        <div>\n            <h2>大正9年創立から<br>広島と共に<br class=\"for-sp\">歩み続けて100余年。</h2>\n            <p>そして、これからもずっと。</p>\n        </div>\n    </div>\n    <div>\n        <div></div>\n        <div>\n            <p>大之木ダイモは大正9年に創立し、広島市、呉市を中心に、<br>\n                新築注文住宅・リフォーム・土地探しまで住まいにまつわる事業をはじめ暮らしをサポートする事業を展開してまいりました。<br>\n                地域の気候風土に応じながら、そこに暮らすみなさまの、快適で心地よい暮らしに寄り添うものづくりをこれからもつづけていきます。\n            </p>\n            <a href=\"https://daimo.jp//company/\" class=\"btn\">私たちのこと</a>\n        </div>\n    </div>\n</section>\n\n<section id=\"housing\" class=\"title-bg\">\n    <div class=\"contents\" data-text=\"Housing\">\n        <h2>大之木ダイモの家</h2>\n        <div class=\"item-list\">\n            <div class=\"housinglist\">\n                <figure>\n                    <a href=\" https://daimo.jp//kinoie/\" class=\"housing\"><img src=\"https://daimo.jp/cont/wp-content/themes/daimo_theme/inc/images/top/pic_housing01.jpg\" alt=\"注文住宅\"></a>\n                    <figcaption>\n                        <h3>注文住宅<span>Custom Home</span></h3>\n                    </figcaption>\n                </figure>\n                <p style=\"margin: 0 0 0 0.5em;\">健康で快適な暮らしをサポートするため、お客様それぞれの暮らしに合った最善の設計をご提案するのはもちろん、目に見えないところまできめ細やかにこだわり身体への優しさを考えた家づくりを行っています。</p>\n                <!--<a href=\"https://daimo.jp//kinoie/\" class=\"btn invert\" target=\"_blank\">注文住宅</a>-->\n            </div>\n            <div class=\"housinglist\">\n                <figure>\n                    <a href=\"https://daimo.jp//reform/renovation/\" class=\"housing\"><img src=\"https://daimo.jp/cont/wp-content/themes/daimo_theme/inc/images/top/pic_housing02.jpg\" alt=\"リノベーション\"></a>\n                    <figcaption>\n                        <h3>リノベーション<span>Renovation</span></h3>\n                    </figcaption>\n                </figure>\n                <p style=\"margin: 0 0 0 0.5em;\">「リノベーション」は、更に良いものに作り変える、マイナスをプラスに変える工事です。あなたの「これからの暮らし」に合わせたマンションや戸建て住宅のリノベーションを行っております。</p>\n                <!--<a href=\"https://daimo.jp//kinoie/rinovation/\" class=\"btn invert\" target=\"_blank\">リノベーション</a>-->\n            </div>\n            <div class=\"housinglist\">\n                <figure>\n                    <a href=\"https://daimo.jp//reform/\" class=\"housing\"><img src=\"https://daimo.jp/cont/wp-content/themes/daimo_theme/inc/images/top/pic_housing03.jpg\" alt=\"リフォーム\"></a>\n                    <figcaption>\n                        <h3>リフォーム<span>Reform</span></h3>\n                    </figcaption>\n                </figure>\n                <p style=\"margin: 0 0 0 0.5em;\">木材事業、住宅事業に取り組んできた長い歴史と経験から生まれた総合力を活かし、安心いただける施工・サービスが行えます。ライフスタイルの変化とともに暮らしやすい幸せのリフォームをご提供いたします。</p>\n                <!--<a href=\"https://daimo.jp//reform/\" class=\"btn invert\" target=\"_blank\">リフォーム</a>-->\n            </div>\n            <div class=\"housinglist\">\n                <figure>\n                    <a href=\"https://www.daimo-fudousan.com/\" class=\"housing\"><img src=\"https://daimo.jp/cont/wp-content/themes/daimo_theme/inc/images/top/pic_housing04.jpg\" alt=\"不動産\"></a>\n                    <figcaption>\n                        <h3>不動産<span>Estate</span></h3>\n                    </figcaption>\n                </figure>\n                <p style=\"margin: 0 0 0 0.5em;\">お客様のニーズに添った物件探し・資金計画から購入後の新築・リフォーム工事のサポートまでワンストップで新生活をご提案いたします。売却のご相談も承っておりますのでお気軽にお問い合わせください。</p>\n                <!--<a href=\"https://www.daimo-fudousan.com/\" class=\"btn invert\" target=\"_blank\">不動産</a>-->\n            </div>\n\n\n        </div>\n\n    </div>\n</section>\n\n<section id=\"service\" class=\"title-bg h-80p\">\n    <div class=\"contents\" data-text=\"Service\">\n        <div>\n            <h2>暮らしにまつわるサービス</h2>\n            <p>長い歴史の中で培った経験や知識を活かした多岐にわたる事業についてご紹介いたします</p>\n            <a href=\"https://daimo.jp//business/#other-divisions\" class=\"btn\">詳しく</a>\n        </div>\n        <div>\n            <ul class=\"business-panel\">\n                <li class=\"ship\">\n                    <a href=\"https://daimo.jp//business/#ship\">\n                        <figure>\n                            <img src=\"https://daimo.jp/cont/wp-content/themes/daimo_theme/inc/images/ico/ico_ship.svg\" alt=\"\">\n                            <figcaption>船舶内装事業部</figcaption>\n                        </figure>\n                    </a>\n                </li>\n                <li class=\"tree\">\n                    <a href=\"https://daimo.jp//business/#tree\">\n                        <figure>\n                            <img src=\"https://daimo.jp/cont/wp-content/themes/daimo_theme/inc/images/ico/ico_tree.svg\" alt=\"\">\n                            <figcaption>木材事業部</figcaption>\n                        </figure>\n                    </a>\n                </li>\n                <li class=\"homecenter\">\n                    <a href=\"https://daimo.jp//business/#homecenter\">\n                        <figure>\n                            <img src=\"https://daimo.jp/cont/wp-content/themes/daimo_theme/inc/images/ico/ico_tak.svg\" alt=\"\">\n                            <figcaption>マチナカ<br>ホームコンビニ<br>TAK</figcaption>\n                        </figure>\n                    </a>\n                </li>\n                <li class=\"building\">\n                    <a href=\"https://daimo.jp//business/#building\">\n                        <figure>\n                            <img src=\"https://daimo.jp/cont/wp-content/themes/daimo_theme/inc/images/ico/ico_house.svg\" alt=\"\">\n                            <figcaption>澎湃館事業部<br>&nbsp;</figcaption>\n                        </figu