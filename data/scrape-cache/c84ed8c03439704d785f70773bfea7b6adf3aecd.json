css?1669639510\"/>    <link rel=\"stylesheet\" href=\"/members/css/top.css?1669639510\"/>\n    <!-- fonts -->\n    <link href=\"https://maxcdn.bootstrapcdn.com/font-awesome/4.7.0/css/font-awesome.min.css\" rel=\"stylesheet\">\n    <link href=\"https://fonts.googleapis.com/css?family=Montserrat:500|Noto+Sans+JP:400,700&amp;subset=japanese\" rel=\"stylesheet\">\n</head>\n\n<body>\n<!-- Google Tag Manager (noscript) -->\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-KX9RXK6\"\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n<!-- End Google Tag Manager (noscript) --><script>\n    function changePreviewSize(obj){\n\n        var idx = obj.selectedIndex;\n        var val = obj.options[idx].value;\n        var head = document.getElementsByTagName('head')[0];\n        var previewLink = document.getElementById(\"changePreviewSize\");\n\n        if(!val && previewLink){\n            head.removeChild(previewLink);\n            return;\n        }\n        var loading = document.getElementById('loadingArea');\n        loading.style.display = '';\n\n        if(previewLink) var oldChangePreviewSize = previewLink;\n\n        var previewLink = document.createElement('link');\n        previewLink.rel = 'stylesheet';\n        previewLink.type = 'text/css';\n        previewLink.id = 'changePreviewSize';\n        previewLink.href = '/wombat/css/preview_' + val + '.css';\n        previewLink.addEventListener(\"load\", function(event) {\n            loading.style.display = 'none';\n            if(oldChangePreviewSize){\n                head.removeChild(oldChangePreviewSize);\n            }\n        });\n        head.appendChild(previewLink);\n\n\n\n    }\n\n</script>\n\n<!-- header -->\n<header id=\"header\">\n    <h1>熊本県観光連盟会員専用サイト</h1>\n\n    </header>\n<!-- header -->\n\n<!-- contents -->\n<div id=\"contents\">\n\n\n\n            <div class=\"wrapper\">\n    <h3 class=\"menber-ttl\"><span>会員番号・パスワードをお忘れの方</span></h3>\n    <div class=\"complete-msg\">\n        <p>パスワードを再設定しますので、会員番号と登録済の代表者メールアドレスを入力してください。<br>\n            代表者メールアドレスを入力して送信すると再登録のURLがメールで送られます。</p>\n\n        <form method=\"post\" accept-charset=\"utf-8\" class=\"\" action=\"/members/users/reset\"><div style=\"display:none;\"><input type=\"hidden\" name=\"_method\" value=\"POST\"/><input type=\"hidden\" name=\"_csrfToken\" autocomplete=\"off\" value=\"8ed99f5a9ee652afe30e91e8c6cf30e213d14154ed3cc4b2bc31d37d9366e8fc1837168cd7cb3a4e5cdb4288123e46fb88e197b3d23be7c0843c5153350a394f\"/></div>\n        <dl>\n            <dt>会員番号</dt>\n            <dd>\n                <label for=\"username\">会員番号</label>                <input type=\"text\" name=\"username\" class=\"text-l\" id=\"username\"/>            </dd>\n        </dl>\n        <dl>\n            <dt>代表者メールアドレス</dt>\n            <dd>\n                <label for=\"email\">代表者メールアドレス</label>                <input type=\"email\" name=\"email\" class=\"text-l\" id=\"email\"/>\n            </dd>\n        </dl>\n        \n        <p class=\"attention\">会員番号、登録した代表者メールアドレスが不明な場合は、以下までご連絡ください。<br>\n            (公社)熊本県観光連盟<br>\n            TEL：096‐382‐2660 （受付時間8:30～17:15）</p>\n        <div style=\"display: none;\">\n            <div class=\"submit\"><input type=\"submit\" id=\"submit-button\" value=\"Submit\"/></div>        </div>\n        <div class=\"btn-area\">\n            <p class=\"btn-enter\"><a href=\"javascript:document.getElementById('submit-button').click();\">再設定メールを送信する</a></p>\n            <p class=\"btn-back\"><a href=\"/members\">トップへ戻る</a></p>\n        </div>\n\n        </form>\n    </div>\n\n</div>\n    \n</div>\n<!-- contents -->\n\n\n<!-- footer -->\n<footer id=\"footer\">\n    <p>(公社)熊本県観光連盟<br>\n        〒862-0950　熊本市中央区水前寺6丁目5-19 熊本県庁会議棟1号館3階<br>\n        TEL：096-382-2660（受付時間 平日8:30~17:15） FAX：096-382-2663</p>\n    <div class=\"f-bnr\">\n        <a href=\"https://kumamoto.guide/\" target=\"_blank\"><img src=\"/members/img/bnr_kumamoto.png?1669639512\" alt=\"もっと、もーっと！くまもっと。\"/></a>\n    </div>\n    <p class=\"copy\">©2018 Kumamoto Prefecture・Kumamoto Prefectural Tourism Federation</p></footer>\n<!-- footer -->\n\n<!-- js-->\n<script src=\"/members/js/jquery-3.4.1.min.js?1669639510\"></script><script src=\"/members/js/common.js?1669639510\"></script></body>\n</html>\n","finalUrl":"https://kumamoto.guide/members/users/reset","rendered":false,"_cachedAt":"2026-06-22T19:17:26.265Z"}