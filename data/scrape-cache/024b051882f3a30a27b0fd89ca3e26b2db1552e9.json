'https://www.kokudoec.co.jp/wp-content/plugins/vk-all-in-one-expansion-unit/inc/call-to-action/package/assets/css/style.css?ver=9.109.0.1' media='all' />\n<link rel=\"https://api.w.org/\" href=\"https://www.kokudoec.co.jp/wp-json/\" /><link rel=\"alternate\" title=\"JSON\" type=\"application/json\" href=\"https://www.kokudoec.co.jp/wp-json/wp/v2/pages/42\" /><link rel=\"EditURI\" type=\"application/rsd+xml\" title=\"RSD\" href=\"https://www.kokudoec.co.jp/xmlrpc.php?rsd\" />\n<meta name=\"generator\" content=\"WordPress 7.0\" />\n<link rel=\"canonical\" href=\"https://www.kokudoec.co.jp/company/\" />\n<link rel='shortlink' href='https://www.kokudoec.co.jp/?p=42' />\n<!-- [ VK All in One Expansion Unit OGP ] -->\n<meta property=\"og:site_name\" content=\"株式会社国土技術コンサルタンツ\" />\n<meta property=\"og:url\" content=\"https://www.kokudoec.co.jp/company/\" />\n<meta property=\"og:title\" content=\"企業情報 | 株式会社国土技術コンサルタンツ\" />\n<meta property=\"og:description\" content=\"                  COMPANY 企業情報                            VISION 経営理念        技 術 の 研 鑚 に 励 み『 顧 客 が 信 頼 す る 品 質 』を常 に 大 切 に し        社 会 資 本 形 成 へ の 参 画 を 通 じ“ 豊 か な 地 域 社 会 の 創 造 ” に 貢献 し ま す。        株式会社国土技術コンサルタンツは        社\" />\n<meta property=\"og:type\" content=\"article\" />\n<!-- [ / VK All in One Expansion Unit OGP ] -->\n<!-- [ VK All in One Expansion Unit twitter card ] -->\n<meta name=\"twitter:card\" content=\"summary_large_image\">\n<meta name=\"twitter:description\" content=\"                  COMPANY 企業情報                            VISION 経営理念        技 術 の 研 鑚 に 励 み『 顧 客 が 信 頼 す る 品 質 』を常 に 大 切 に し        社 会 資 本 形 成 へ の 参 画 を 通 じ“ 豊 か な 地 域 社 会 の 創 造 ” に 貢献 し ま す。        株式会社国土技術コンサルタンツは        社\">\n<meta name=\"twitter:title\" content=\"企業情報 | 株式会社国土技術コンサルタンツ\">\n<meta name=\"twitter:url\" content=\"https://www.kokudoec.co.jp/company/\">\n\t<meta name=\"twitter:domain\" content=\"www.kokudoec.co.jp\">\n\t<!-- [ / VK All in One Expansion Unit twitter card ] -->\n\t<link rel=\"icon\" href=\"https://www.kokudoec.co.jp/wp-content/uploads/2025/07/cropped-favicon-32x32.png\" sizes=\"32x32\" />\n<link rel=\"icon\" href=\"https://www.kokudoec.co.jp/wp-content/uploads/2025/07/cropped-favicon-192x192.png\" sizes=\"192x192\" />\n<link rel=\"apple-touch-icon\" href=\"https://www.kokudoec.co.jp/wp-content/uploads/2025/07/cropped-favicon-180x180.png\" />\n<meta name=\"msapplication-TileImage\" content=\"https://www.kokudoec.co.jp/wp-content/uploads/2025/07/cropped-favicon-270x270.png\" />\n  </head>\n\n  <body class=\"wp-singular page-template page-template-page-home page-template-page-home-php page page-id-42 wp-theme-kokudo post-name-company post-type-page\">\n    <header class=\"l-header\">\n<div class=\"l-header__logo\">\n  <a href=\"/\">\n    <img src=\"https://www.kokudoec.co.jp/wp-content/themes/kokudo/assets/img/common/h-logo.webp\">\n    <p>\n      <span>国土技術コンサルタンツ</span>\n      <u></u>\n      <span>Corporate</span>\n    </p>\n  </a>\n</div>\n      <div class=\"c-hamburger\">\n        <input type=\"checkbox\" id=\"menu-btn-check\">\n        <label for=\"menu-btn-check\" class=\"c-hamburger__btn\"><span></span></label>\n        <div class=\"c-hamburger__menu\">\n          <ul class=\"l-header__nav\">\n            <li>\n              <a href=\"/\">TOP</a>\n            </li>\n            <li>\n              <a href=\"/#introduction\">事業紹介</a>\n              <ul class=\"is-sp\">\n                <li><a href=\"/introduction/01\">建設コンサルタント</a></li>\n                <li><a href=\"/introduction/02\">測量</a></li>\n                <li><a href=\"/introduction/03\">補償コンサルタント</a></li>\n              </ul>\n            </li>\n            <li>\n              <a href=\"/company\">企業情報</a>\n            </li>\n            <li>\n              <a href=\"/history\">会社の歴史</a>\n            </li>\n            <li>\n              <a href=\"/achivements\">実績紹介</a>\n            </li>\n            <li>\n              <a href=\"/press\">最新情報</a>\n            </li>\n            <li>\n              <a href=\"/recruit\">採用サイト</a>\n            </li>\n            <li>\n              <a href=\"/contact\">お問い合わせ</a>\n            </li>\n          </ul>\n        </div>\n      </div>\n\n    </header>\n\n<main class=\"p-company\">\n    <section class=\"p-company__fv\">\n      <h1>\n        COMPANY <span>企業情報</span>\n      </h1>\n    </section>\n\n    <section class=\"p-company-message\">\n      <div class=\"p-company-message__vision\">\n        <h2>VISION <span>経営理念</span></h2>\n        <strong>技 術 の 研 鑚 に 励 み『 顧 客 が 信 頼 す る 品 質 』を常 に 大 切 に し<br>\n        社 会 資 本 形 成 へ の 参 画 を 通 じ“ 豊 か な 地 域 社 会 の 創 造 ” に 貢献 し ま す。</strong>\n        <p>株式会社国土技術コンサルタンツは<br>\n        社会基盤の基礎となる道路や橋梁などの<br>\n        設計や公共工事に係る補償を行う総合建設コンサルタントです。<br><br>\n        \n        事業を通し本来の「あるべき姿」を大切にしています。</p>\n      </div>\n\n      <div class=\"p-company-message-rep\">\n        <div class=\"p-company-message-rep__textarea\">\n          <strong>『 選ばれ続ける企業 』であるために。</strong>\n          <p>私共 株式会社国土技術コンサルタンツは1970年に創業し、以来一貫して公共事業における委託業務を社業としてまいりました。<br>\n          この間、測量業・建設コンサルタント業・補償コンサルタント業などの登録を行い「総合建設コンサルタント」として社業の充実に努めてまいりました。<br><br>\n          \n          我が国に於いては、度重なる大規模災害に対し「安全・安心な国土づくり」が議論されています。　加えて、社会資本の老朽化も深刻な問題として現存し、早急かつ確実な対応も求められています。しかし、対応の遅れは現実であり、今後ともより効率的で効果的な公共事業の必要性は高く、より一層の品質確保とトータルコストの縮減が課題であると認識します。　さらに　公共事業の実施にあたっては業者選定における公平性および透明性の確保が重要な事項となっています。<br>\n          　我が社ではこのような社会情勢に対応すべく　更なる自己改革を行い　より質の高い技術の確保・保持に努めることで「選ばれる企業」として認知されるように努力を続ける所存でございます。<br>\n          　業務の成果でも皆様方からのご満足をいただける様に努め「持続可能で活力ある地域づくり」に貢献したいと考えております。</p>\n          <p class=\"p-company-message-name\">\n            代表取締役\n            <span>安 永 信 一 郎　</span>\n          </p>\n        </div>\n        <div class=\"p-company-message-rep__image\">\n          <img decoding=\"async\" src=\"/wp-content/themes/kokudo/assets/img/company/image01.webp\" alt=\"\">\n        </div>\n      </div>\n    </section>\n\n    <section class=\"p-company-about\">\n      <h2 class=\"p-company-section__title\">会社概要</h2>\n      <div class=\"p-company-about__flex\">\n        <ul class=\"p-company-about__text\">\n          <li>\n            <span>企業名</span>\n            <span>株式会社国土技術コンサルタンツ</span>\n          </li>\n          <li>\n            <span>所在地</span>\n            <span>〒890-0008　鹿児島市伊敷二丁目１４番１０号</span>\n          </li>\n          <li>\n            <span>電話番号</span>\n            <span>099-229-0030</span>\n          </li>\n          <li>\n            <span>FAX番号</span>\n            <span>099-229-0474</span>\n          </li>\n          <li>\n            <span>設立</span>\n            <span>1970年11月16日</span>\n          </li>\n          <li>\n            <span>資本金</span>\n            <span>1,000万円</span>\n          </li>\n          <li>\n            <span>役員</span>\n            <span>\n              代表取締役　　　安永　信一郎<br>\n              代表取締役会長　安永　幸信\n            </span>\n          </li>\n          <li>\n            <span>従業員数</span>\n            <span>51名（男性36名 女性15名）※R7年7月1日現在</span>\n          </li>\n          <li>\n            <span>国土交通大臣<br class=\"is-pc\">許可番号</span>\n            <span>測量業<br>\n              第(13)-3624号　当初登録 S45.11.16<br><br>\n              建設コンサルタント業<br>\n              建04第2342号　当初登録 S51.10.25<br>\n              河川、砂防及び海岸・海洋部門、道路部門、農業土木部門<br>\n              土質及び基礎部門、鋼構造及びコンクリート部門<br><br>\n              補償コンサルタント業<br>\n              補06第778号　当初登録 S60.2.25<br>\n              土地調査部門、物件部門、営業補償、特殊補償部門、事業損失部門<br>\n              <a href=\"/qualified\">各部門の有資格者数はこちら</a>\n          </span>\n          </li>\n          <li>\n            <span>支店情報</span>\n            <span>\n              <b>宮崎支店</b>\n              <sub>\n                〒880-0211<br>\n                宮崎県宮崎市佐土原町下田島12219-132<br>\n                TEL 050-3441-1931　FAX 050-3441-1931\n              </sub>\n              <b>霧島支店</b>\n              <sub>\n                〒899-5117<br>\n                鹿児島県霧島市隼人町見次1660-4<br>\n                TEL 0995-44-7202　FAX 0995-44-7205\n              </sub>\n              <b>姶良支店</b>\n              \n              <sub>\n                〒899-5652<br>\n                鹿児島県姶良市平松6237-2<br>\n                TEL 0995-67-6108　FAX 0995-67-6113\n              </sub>\n              \n              <b>奄美支店</b>\n              <sub>\n                〒894-0033<br>\n                鹿児島県奄美市名瀬矢之脇町12番19号<br>\n                TEL 0997-53-4476　FAX 0997-53-4476\n              </sub>\n              \n              <b>熊毛支店</b>\n              \n              <sub>\n                〒891-3101<br>\n                鹿児島県西之表市西之表15121番地<br>\n                TEL 0997-23-3946　FAX 0997-23-3946\n              </sub>\n            </span>\n          </li>\n        </ul>\n        <div class=\"p-company-about__map\"><iframe src=\"https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d849.39816263459!2d130.52783010199946!3d31.617619888907164!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x353e5d942c2e6d6d%3A0x6bd03593fe95e2d1!2z77yI5qCq77yJ5Zu95Zyf5oqA6KGT44Kz44Oz44K144Or44K_44Oz44OE!5e0!3m2!1sja!2sjp!4v1753800497430!5m2!1sja!2sjp\" width=\"600\" height=\"450\" style=\"border:0;\" allowfullscreen=\"\" loading=\"lazy\" referrerpolicy=\"no-referrer-when-downgrade\"></iframe>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"p-company-history\">\n      <h2 class=\"p-company-section__title\">沿革</h2>\n      <ul class=\"p-company-history__flex\">\n        <li>\n          <span>1970.11</span>\n          <span>安永克己が共同で福島測量　株式会社を鹿児島市易居町に設立<br>\n          建設省登録を受ける（現：国土交通省）</span>\n        </li>\n        <li>\n          <span>1976.10</span>\n          <span>\n            建設コンサルタント業の道路部門を営業登録する\n          </span>\n        </li>\n        <li>\n          <span>1977.1</span>\n          <span>\n            株式会社 国土技術コンサルタンツに社名を変更する\n          </span>\n        </li>\n        <li>\n          <span>1981.4</span>\n          <span>\n            鹿児島市泉町に移転を行う\n          </span>\n        </li>\n        <li>\n          <span>1981.9</span>\n          <span>\n            安永克己が代表取締役社長に就任する\n          </span>\n        </li>\n        <li>\n          <span>1985.1</span>\n          <span>\n            鹿児島市西伊敷に設立、移転を行う\n          </span>\n        </li>\n        <li>\n          <span>1985.2</span>\n          <span>\n            補償コンサルタント業の土地調査部門を営業登録する\n          </span>\n        </li>\n        <li>\n          <span>1994.12</span>\n          <span>鹿児島市伊敷（現住所）に本社設立、移転を行う</span>\n        </li>\n        <li>\n          <span>1998.11</span>\n          <span>安永克己が代表取締役会長に就任、安永幸信が代表取締役社長に就任</span>\n        </li>\n        <li>\n          <span>2001.7</span>\n          <span>国際標準化機構による品質マネジメントシステム”ISO9001”の認証を受ける</span>\n        </li>\n        <li>\n          <span>2007.2</span>\n          <span>鹿児島市より”環境管理自事業所認定”(現グリーンオフィスかごしま)を受ける</span>\n        </li>\n        <li>\n          <span>2007.6</span>\n          <span>宮崎支店が開設される</span>\n        </li>\n        <li>\n          <span>2009.11</span>\n          <span>環境省策定の環境マネジメントシステム”エコアクション21”の認証を受ける</span>\n        </li>\n        <li>\n          <span>2011.9</span>\n          <span>霧島支店、姶良支店が開設される</span>\n        </li>\n        <li>\n          <span>2014.3</span>\n          <span>奄美営業所が開設される</span>\n        </li>\n        <li>\n          <span>2016.7</span>\n          <span>安永幸信が”平成28年建設事業関係功労者国土交通大臣表彰”を授与される</span>\n        </li>\n        <li>\n          <span>2018.4</span>\n          <span>安永幸信が”黄綬褒章”を授与される</span>\n        </li>\n        <li>\n          <span>2018.9</span>\n          <span>鹿児島県より”かごしま子育て応援企業”に認定される</span>\n        </li>\n        <li>\n          <span>2019.4</span>\n          <span>奄美営業所の移転に伴い奄美支店に名称を変更する</span>\n        </li>\n        <li>\n          <span>2019.7</span>\n          <span>鹿児島県より”かごしま結婚・子育てサポート宣言企業”に認定される</span>\n        </li>\n        <li>\n          <span>2021.4</span>\n          <span>安永幸信が代表取締役会長に就任、安永信一郎が代表取締役社長に就任</span>\n        </li>\n        <li>\n          <span>2021.12</span>\n          <span>鹿児島市より”かごしまSDGs推進パートナー登録”を受ける</span>\n        </li>\n        <li>\n          <span>2022.6</span>\n          <span>鹿児島市より”鹿児島市イクボス推進同盟の加盟”を承認される</span>\n        </li>\n        <li>\n          <span>2023.4</span>\n          <span>安永幸信が”旭日双光章”を授与される</span>\n        </li>\n        <li>\n          <span>2025.1</span>\n          <span>鹿児島県より”鹿児島県SDGs登録事業者”の登録を受ける</span>\n        </li>\n        <li>\n          <span>1995.1</span>\n          <span>補償コンサルタント業追加部門登録　物件部門</span>\n        </li>\n        <li>\n          <span>1995.12</span>\n          <span>補償コンサルタント業追加部門登録　営業補償・特殊補償部門</span>\n        </li>\n        <li>\n          <span>1996.9</span>\n          <span>建設コンサルタント業追加部門登録　農業土木部門</span>\n        </li>\n        <li>\n          <span>1999.11</span>\n          <span>建設コンサルタント業追加部門登録　　鋼構造及びコンクリート部門</span>\n        </li>\n        <li>\n          <span>2001.10</span>\n          <span>建設コンサルタント業追加部門登録　　河川、砂防及び海岸部門<br>\n          　　　　　　　　　　　　　　　　　　土 質 及 び 基 礎 部 門</span>\n        </li>\n        <li>\n          <span>2008.10</span>\n          <span>補償コンサルタント業追加部門登録　　事 業 損 失 部 門</span>\n        </li>\n      </ul>\n    </section>\n\n  </main>\n\n<section class=\"p-form\">\n      <div class=\"p-form__inner\">\n        <div class=\"p-form__text-content\">\n          <p class=\"p-form__main-title\">CONTACT</p>\n          <p class=\"p-form__sub-title\">お問い合わせ</p>\n          <p class=\"p-form__description\">ご質問やご依頼など<br>フォームよりお気軽にご相談ください</p>\n        </div>\n        <div class=\"p-form__link-wrapper\">\n          <a href=\"/contact\" class=\"p-form__link\">\n            <span class=\"p-form__link-text-upper\">GET IN</span>\n            <span class=\"p-form__link-text-lower\">\n              <i class=\"icon fa-solid fa-arrow-right\"></i>\n              TOUCH.\n            </span>\n          </a>\n        </div>\n      </div>\n    </section>\n\n    <footer class=\"l-footer\">\n      <div class=\"l-footer__inner\">\n        <ul class=\"l-footer_links\">\n          <li><a href=\"/\">TOP</a></li>\n          <li>\n            <a href=\"/#introduction\">事