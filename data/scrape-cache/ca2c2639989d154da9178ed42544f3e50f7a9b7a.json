{"url":"https://www.yutaka-unyu.co.jp/","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n\n<head prefix=\"og: http://ogp.me/ns# fb: http://ogp.me/ns/fb# article: http://ogp.me/ns/article#\">\n    <meta charset=\"utf-8\">\n    <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n    <title>重量物輸送で九州No.1シェアの豊運輸株式会社</title>\n    <meta name=\"viewport\" content=\"width=device-width,initial-scale=1.0\">\n    <meta name=\"keywords\" content=\"福岡,九州,重量物輸送,特殊製品輸送,住宅部材輸送,運送会社,クレーン\">\n    <meta name=\"description\" content=\"重量物輸送は福岡の豊運輸へ。50年以上の実績をもち、トラック、トレーラなど370台以上の多彩な車輌で、日本全国へ安全にお運びいたします。重たいもの、大きなもの、長いもの、精密なもの、重量物や特殊製品、住宅部材輸送のエキスパートです。\">\n    <meta name=\"format-detection\" content=\"telephone=no\">\n    <link rel=\"stylesheet\" href=\"/css/style.css\" media=\"all\">\n    <link rel=\"shortcut icon\" href=\"favicon.ico\" />\n\n    <!--[if lt IE 9]>\n    <script src=\"/js/html5shiv.js\"></script>\n    <script src=\"/js/rem.js\"></script>\n    <![endif]-->\n\n    <!--[if (gte IE 6)&(lte IE 8)]>\n    <script src=\"/js/selectivizr-min.js\"></script>\n    <![endif]-->\n\n    <!-- Google Tag Manager -->\n    <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\n        new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\n                j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n                'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n                })(window,document,'script','dataLayer','GTM-WQDGNHP');</script>\n    <!-- End Google Tag Manager -->\n</head>\n\n<body id=\"top\">\n<!-- Google Tag Manager (noscript) -->\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-WQDGNHP\"\n                  height=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n<!-- End Google Tag Manager (noscript) -->\n\n<header class=\"header\">\n    <header_common></header_common>\n</header>\n\n\n<div class=\"top-slider\">\n    <div class=\"loader\"><img src=\"/common/loading.gif\" alt=\"\"></div>\n    <div class=\"flexslider RightToLeft d1_3 target\">\n        <ul class=\"slides\">\n            <li>\n                <img src=\"/img/main_01.png\" alt=\"豊運輸なら、運べる。こんなに大きなものも。\" class=\"pc_s\">\n                <img src=\"/img/sp_main_01.png\" alt=\"豊運輸なら、運べる。こんなに大きなものも。\" class=\"sp_s\">\n            </li>\n            <li>\n                <img src=\"/img/main_02.png\" alt=\"豊運輸なら、運べる。こんなに重たいものも。\" class=\"pc_s\">\n                <img src=\"/img/sp_main_02.png\" alt=\"豊運輸なら、運べる。こんなに重たいものも。\" class=\"sp_s\">\n            </li>\n            <li>\n                <img src=\"/img/main_03.png\" alt=\"豊運輸なら、運べる。こんなに長いものも。\" class=\"pc_s\">\n                <img src=\"/img/sp_main_03.png\" alt=\"豊運輸なら、運べる。こんなに長いものも。\" class=\"sp_s\">\n            </li>\n        </ul>\n    </div>\n</div>\n\n\n<div class=\"top-quality\">\n    <div class=\"top-quality__head\">\n        <div class=\"sec-inner\">\n            <h2 class=\"top-quality__title\">\n                <span class=\"top-quality__title-en\">YUTAKA <br class=\"sp_s\"><span>Q</span>UALITY</span>\n                <span class=\"top-quality__title-ja\">サービス案内</span>\n            </h2>\n            <p class=\"top-quality__copy\">\n                重量物輸送におけるシェアは九州No.1。<br>\n                大きなもの、重たいもの、長いもの、精密なもの、豊運輸に運べないものは、ほぼありません。\n            </p>\n        </div>\n    </div>\n    <ul class=\"top-quality__items\">\n        <li class=\"top-quality__item\">\n            <a href=\"/quality/heavy.html\">\n                <div class=\"top-quality__item-img animation-appear d0_2\">\n                    <img src=\"/img/quality_photo01.png\" alt=\"\">\n                </div>\n                <dl class=\"top-quality__item-text animation-appear d0_2\">\n                    <dt>重量物輸送</dt>\n                    <dd>主に鋼材・鉄骨・コンクリート二次製品・リース部材などの重量物を輸送します。</dd>\n                </dl>\n            </a>\n        </li>\n        <li class=\"top-quality__item\">\n            <a href=\"/quality/specialty.html\">\n                <div class=\"top-quality__item-img animation-appear d0_4 sp_d0_3\">\n                    <img src=\"/img/quality_photo02.png\" alt=\"\">\n                </div>\n                <dl class=\"top-quality__item-text animation-appear d0_4 sp_d0_3\">\n                    <dt>特殊製品輸送</dt>\n                    <dd>クレーンガータ・大型タンク・大型機械など長大品を輸送します。</dd>\n                </dl>\n            </a>\n        </li>\n        <li class=\"top-quality__item\">\n            <a href=\"/quality/building.html\">\n                <div class=\"top-quality__item-img animation-appear d0_6\">\n                    <img src=\"/img/quality_photo03.png\" alt=\"\">\n                </div>\n                <dl class=\"top-quality__item-text animation-appear d0_6\">\n                    <dt>住宅部材輸送</dt>\n                    <dd>有名ハウスメーカーの住宅用パネルやユニットハウスなどを輸送しています。</dd>\n                </dl>\n            </a>\n        </li>\n        <li class=\"top-quality__item\">\n            <a href=\"/quality/other.html\">\n                <div class=\"top-quality__item-img animation-appear d0_8 sp_d0_3\">\n                    <img src=\"/img/quality_photo04.png\" alt=\"\">\n                </div>\n                <dl class=\"top-quality__item-text other animation-appear d0_8 sp_d0_3\">\n                    <dt>その他の輸送</dt>\n                    <dd>雑貨、食肉、燃料、自動車部品、コンテナ、スクラップ、船輸送など、さまざまな輸送を行っています。</dd>\n                </dl>\n            </a>\n        </li>\n        <li class=\"top-quality__item\">\n            <a href=\"/quality/crane.html\">\n                <div class=\"top-quality__item-img animation-appear d1_0\">\n                    <img src=\"/img/quality_photo05.png\" alt=\"\">\n                </div>\n                <dl class=\"top-quality__item-text crane animation-appear d1_0\">\n                    <dt>クレーン事業・倉庫事業</dt>\n                    <dd>輸送業務に付帯する、クレーン事業・倉庫業事業も行っております。</dd>\n                </dl>\n            </a>\n        </li>\n    </ul>\n</div>\n<!--//top-quality-->\n\n<div class=\"top-policy\">\n    <h2 class=\"top-policy__title animation-SlideUp\">\n        <span class=\"top-policy__title-en\">YUTAKA <span>P</span>OLICY</span>\n        <span class=\"top-policy__title-ja\">会社案内</span>\n    </h2>\n    <p class=\"top-policy__copy animation-SlideUp\">\n        九州を拠点に、日本全国へどんな物でもお運びします。<br class=\"pc_s\">\n        エキスパートとして<span>「感謝・安全・輸送」</span>を追及し、100年企業を目指してまいります。\n    </p>\n    <ul class=\"top-policy__items\">\n        <li class=\"top-policy__item top-policy__item--greeting animation-LeftToRight\">\n            <a href=\"/policy/greeting.html\" class=\"top-policy__link\">\n                <span class=\"top-policy__link-ja\">代表挨拶</span><span class=\"top-policy__link-en\">GREETING</span>\n            </a>\n        </li>\n        <li class=\"top-policy__item top-policy__item--overview animation-SlideUp d0_6\">\n            <a href=\"/policy/overview.html\" class=\"top-policy__link\">\n                <span class=\"top-policy__link-ja\">会社概要・沿革</span><span class=\"top-policy__link-en\">OVERVIEW</span>\n            </a>\n        </li>\n        <li class=\"top-policy__item top-policy__item--guide animation-RightToLeft d0_3\">\n            <a href=\"/policy/guide.html\" class=\"top-policy__link\">\n                <span class=\"top-policy__link-ja\">営業所案内</span><span class=\"top-policy__link-en\">GUIDE</span>\n            </a>\n        </li>\n    </ul>\n</div>\n<!--//top-policy-->\n\n<div class=\"top-movie\">\n    <div class=\"top-movie__title\">\n        <div class=\"top-movie__title-inner\">\n            <h2 class=\"animation-SlideUp\">\n                <span class=\"top-movie__title-en\">YUTAKA <span>M</span>OVIE</span>\n                <span class=\"top-movie__title-ja\">動画紹介</span>\n            </h2>\n            <p class=\"top-movie__copy animation-SlideUp\">\n                豊運輸は平成29年に50周年を迎え、記念動画を制作いたしました。<br>\n                50年間支えてくださった皆様へ感謝し、ご恩に報いて、社会に貢献してまいります。\n            </p>\n        </div>\n    </div>\n    <div class=\"top-movie__contents\">\n        <ul class=\"top-movie__items\">\n            <li class=\"top-movie__item\">\n                <iframe width=\"100%\" src=\"https://www.youtube.com/embed/KGBUq8bIx2I?rel=0\" frameborder=\"0\" allow=\"accelerometer; autoplay; encrypted-media; gyroscope; picture-in-picture\" allowfullscreen></iframe>\n            </li>\n            <li class=\"top-movie__item\">\n                <iframe width=\"100%\" src=\"https://www.youtube.com/embed/uTXylkRMR0U?rel=0\" frameborder=\"0\" allow=\"accelerometer; autoplay; encrypted-media; gyroscope; picture-in-picture\" allowfullscreen></iframe>\n            </li>\n            <li class=\"top-movie__item\">\n                <iframe width=\"100%\" src=\"https://www.youtube.com/embed/8jzf5Zq5NsI\" title=\"YouTube video player\" frameborder=\"0\" allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share\" allowfullscreen></iframe>\n            </li>\n        </ul>\n    </div>\n</div>\n<!--top-movie-->\n\n<div class=\"top-news\">\n    <div class=\"top-news__inner\">\n        <h2 class=\"top-news__title animation-LeftToRight\">\n            <span class=\"top-news__title-en\"><span>N</span>EWS &amp;<br class=\"pc\"> TOPICS</span>\n            <span class=\"top-news__title-ja\">新着情報</span>\n        </h2>\n        <div class=\"top-news__contents animation-RightToLeft d0_3\">\n            <ul class=\"top-news__items\">\n                                <li class=\"top-news__item\">\n                    <p>\n                        <span class=\"top-news__day\">2021.10.19</span>\n                                                <a href=\"/news/detail/id/27\" class=\"top-news__link\">ゴールドホッファー社のトレーラを導入いたしました。\n                                                                            </a>\n                    </p>\n                </li>\n                                <li class=\"top-news__item\">\n                    <p>\n                        <span class=\"top-news__day\">2019.02.19</span>\n                                                <a href=\"/news/detail/id/22\" class=\"top-news__link\">ホームページをリニューアルしました。\n                                                                            </a>\n                    </p>\n                </li>\n                            </ul>\n            <a href=\"/news/\" class=\"top-news__more-btn\"><span>一覧を見る</span></a>\n        </div>\n    </div>\n    <!--//top-news__inner-->\n</div>\n<!--//top-news-->\n\n<div id=\"page_top\"><a href=\"#\"><img src=\"/img/pagetop.png\" alt=\"pagetop\"></a></div>\n<footer class=\"footer\">\n    <footer_common></footer_common>\n</footer>\n<!--JS-->\n<script type=\"text/javascript\" src=\"/js/jquery-1.11.2.min.js\"></script>\n<script type=\"text/javascript\" src=\"/js/animation.js\"></script>\n<script type=\"text/javascript\" src=\"/js/pagetop.js\"></script>\n\n<script src=\"/js/jquery.flexslider-min.js\"></script>\n<script>\n    $(window).load(function(){\n        $('.flexslider').flexslider({\n            animation: \"slide\",\n            slideshowSpeed: 5000,\n            animationSpeed: 500,\n            directionNav: false,\n        });\n    });\n</script>\n\n<script type=\"text/javascript\" src=\"/js/ofi.min.js\"></script>\n<script>\n    objectFitImages();\n</script>\n\n<script type=\"text/javascript\" src=\"/js/import.js\"></script>\n<script type=\"text/javascript\" src=\"/js/scrollsmoothly.js\"></script>\n<script type=\"text/javascript\" src=\"/js/jquery.matchHeight.js\"></script>\n<script type=\"text/javascript\">\n    $(function() {\n        $('.top-quality__item').matchHeight();\n        $('.top-quality__item-text').matchHeight();\n        $('.footer-bottom__link').matchHeight();\n    });\n</script>\n\n<!--loading-->\n<script>\n    $(function(){\n        $('.loader').css('display','block');\n        $(window).load(function(){\n            var delaySpeed = 200;\n            var fadeSpeed = 1000;\n            $('.loader').each(function(i){\n                $(this).delay(i*(delaySpeed)).fadeOut(200);\n            });\n            $('.target').each(function(i){\n                $(this).delay(i*(delaySpeed)).css({display:'block',opacity:'0'}).animate({opacity:'1',marginTop:'0px'},fadeSpeed);\n            });\n        });\n    });\n</script>\n<!--//loading-->\n\n\n<!--/JS-->\n<script src=\"https://cdnjs.cloudflare.com/ajax/libs/riot/2.6.7/riot+compiler.min.js\"></script>\n<script type=\"riot/tag\" src=\"/tags/header_common.tag\"></script>\n<script type=\"riot/tag\" src=\"/tags/footer_common.tag\"></script>\n<script src=\"/tags/base.js\"></script>\n\n\n</body>\n</html>\n\n","finalUrl":"https://www.yutaka-unyu.co.jp/","rendered":false,"_cachedAt":"2026-06-22T20:32:19.529Z"}