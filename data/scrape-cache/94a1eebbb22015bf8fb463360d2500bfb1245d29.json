op relative\">\n\t\t\t\t<a href=\"https://recruit.hamada-hi.com\">\n\t\t\t\t\t<div class=\"logo absolute\">\n\t\t\t\t\t\t<img src=\"https://recruit.hamada-hi.com/wp-content/themes/hamada_recruit/images/h-logo.png\" alt=\"濵田重工株式会社\">\n\t\t\t\t\t</div>\n\t\t\t\t</a>\n\t\t\t</div>\n\t\t\t<div class=\"list w900\">\n\t\t\t\t<ul class=\"flex relative\">\n\t\t\t\t\t<li>\n\t\t\t\t\t\t<a href=\"https://recruit.hamada-hi.com\">トップページ</a>\n\t\t\t\t\t</li>\n\t\t\t\t\t<li>\n\t\t\t\t\t\t<a href=\"https://recruit.hamada-hi.com/rec_news/\">お知らせ</a>\n\t\t\t\t\t</li>\n\t\t\t\t\t<li>\n\t\t\t\t\t\t<a href=\"https://recruit.hamada-hi.com/voice/\">先輩社員の声</a>\n\t\t\t\t\t</li>\n\t\t\t\t\t<li>\n\t\t\t\t\t\t<a href=\"https://recruit.hamada-hi.com/culture/\">文化を知る</a>\n\t\t\t\t\t</li>\n\t\t\t\t\t<li>\n\t\t\t\t\t\t<a href=\"https://recruit.hamada-hi.com/welfare/\">福利厚生</a>\n\t\t\t\t\t</li>\n\t\t\t\t\t<li>\n\t\t\t\t\t\t<a href=\"https://recruit.hamada-hi.com/education/\">教育制度</a>\n\t\t\t\t\t</li>\n\t\t\t\t\t<li>\n\t\t\t\t\t\t<a href=\"https://recruit.hamada-hi.com/abouthamada/\">数字でわかる濱田重工</a>\n\t\t\t\t\t</li>\n\t\t\t\t\t<li>\n\t\t\t\t\t\t<a href=\"https://recruit.hamada-hi.com/iron_making_process/\">鉄づくりのプロセス</a>\n\t\t\t\t\t</li>\n\t\t\t\t\t<li>\n\t\t\t\t\t\t<a href=\"//hamada-hi.com/company/sponsor/\">スポンサー活動</a>\n\t\t\t\t\t</li>\n\t\t\t\t\t<li>\n\t\t\t\t\t\t<a href=\"//hamada-hi.com\">コーポレートサイト</a>\n\t\t\t\t\t</li>\n\t\t\t\t\t<li>\n\t\t\t\t\t\t<a href=\"https://recruit.hamada-hi.com/university/\">総合職（事務・技術）新卒採用</a>\n\t\t\t\t\t</li>\n\t\t\t\t\t<li>\n\t\t\t\t\t\t<a href=\"https://recruit.hamada-hi.com/highschool/\">技術職新卒採用（高校生向け）</a>\n\t\t\t\t\t</li>\n\t\t\t\t\t<li>\n\t\t\t\t\t\t<a href=\"https://recruit.hamada-hi.com/career/\">募集要項(中途採用者向け)</a>\n\t\t\t\t\t</li>\n\t\t\t\t\t<li>\n\t\t\t\t\t\t<a href=\"https://recruit.hamada-hi.com/contact/\">お問い合わせ</a>\n\t\t\t\t\t</li>\n\t\t\t\t</ul>\n\t\t\t\t<div class=\"menu-logo\"><img src=\"https://recruit.hamada-hi.com/wp-content/themes/hamada_recruit/images/h-menu_logo.png\" alt=\"濵田重工株式会社\"></div>\n\t\t\t</div>\n\t\t\t<div class=\"asirai absolute\"><img src=\"https://recruit.hamada-hi.com/wp-content/themes/hamada_recruit/images/f-logo_asirai.png\" alt=\"濵田重工株式会社\"></div>\n\t\t</div>\n\n\t\t<!-- ハンバーガー btn-->\n\t\t<div class=\"open_btn\">\n\t\t\t<div class=\"circle relative\">\n\t\t\t\t<span class=\"absolute\"></span>\n\t\t\t\t<span class=\"absolute\"></span>\n\t\t\t\t<span class=\"absolute\"></span>\n\t\t\t</div>\n\t\t</div>\n\t</header>\n\n<main class=\"l-page\">\n\n      <article class=\"relative pd-bottom Fade-area i_blue\" id=\"interview-detail\">\n  \n    <section class=\"l-head-area relative\">\n      <div class=\"l-logo\">\n        <a href=\"https://recruit.hamada-hi.com\"><img src=\"https://recruit.hamada-hi.com/wp-content/themes/hamada_recruit/images/h-logo.png\" alt=\"濵田重工株式会社\"></a>\n      </div>\n      <div class=\"img\"><img src=\"https://recruit.hamada-hi.com/wp-content/themes/hamada_recruit/images/lower/l-interview_top.jpg\" alt=\"先輩社員の声\"></div>\n      <div class=\"l-top-ttl-area absolute\">\n        <div class=\"relative l-top-ttl\">\n           <h1 class=\"en\">Interview</h1>\n           <span>先輩社員の声</span>\n        </div>\n      </div>\n    </section>\n\n        <section id=\"voice\" class=\"pd-top relative pd-bottom\">\n      <div class=\"relative\">\n        <h2 class=\"en\"><span class=\"initial orange\">V</span>oice<small>社員の声</small></h2>\n        <p class=\"ttl-txt w1000 anm\">18歳からコツコツ頑張り後輩のロールモデルへ</p>\n        <div class=\"container\">\n          <div class=\"w1000\">\n            <div class=\"Clip-area\">\n              <div class=\"index flex anm\">\n                <h3>K.H</h3>\n                <span>大分支店 製銑環境課 ／ 2016年入社</span>\n              </div>\n            </div>\n\n            <div class=\"flex item\">\n              <div class=\"img anm\"><img src=\"https://recruit.hamada-hi.com/wp-content/uploads/2024/08/はまゆう9月号_裏表紙-メイン写真-scaled-e1724895487730.jpg\" width=\"600\" alt=\"K.H\"></div>\n              <div class=\"txt anm\">\n                <h4><span class=\"en\">Q1.</span> 入社のきっかけは何ですか？</h4>\n                <p>商業高校に通っていましたが、昔から機械の運転に興味がありました。また、小学校からの知人が、当社に入社していたこともきっかけの1つです。</p>\n              </div>\n            </div>\n            <div class=\"flex item\">\n              <div class=\"txt anm\">\n                <h4><span class=\"en\">Q2.</span> 仕事内容とやりがいを教えてください</h4>\n                <p>自社鉱石処理設備の保守点検およびオペレーター業務、原料払出移動期の沿革オペレーター業務を行っています。「スムーズにできるようになったな」と上司や先輩から褒めていただいたときは、とてもうれしかったです。</p>\n              </div>\n              <div class=\"img anm\"><img src=\"https://recruit.hamada-hi.com/wp-content/uploads/2023/09/大分支店-1-scaled.jpg\" width=\"600\" alt=\"K.H\"></div>\n            </div>\n          </div>\n\n          <div class=\"w1200\">\n            <div class=\"bg relative\">\n              <div class=\"img relative anm\"><img src=\"https://recruit.hamada-hi.com/wp-content/uploads/2024/08/はまゆう9月号_裏表紙-2-scaled-e1724895791582.jpg\" alt=\"K.H\"></div>\n              <div class=\"absolute item\">\n                <div class=\"anm\">\n                  <h4><span class=\"en\">Q3.</span> 職場の雰囲気を教えてください</h4>\n                  <p>仕事のことだけでなく、休日やプライベートの話もできる関係性を築くことができています。私の職場の主任は、現在30代。他職場と比べると、比較的年齢の近い方が多いです。</p>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n          <section id=\"schedule\" class=\"pd-top Fade-area relative pd-bottom l-interview life\">\n    \n      <div class=\"relative w900\">\n        <h2 class=\"en\">\n                      <span>Life</span>\n                    <small>\n                          私の社会人生活                      </small>\n        </h2>\n        <div class=\"white relative anm\">\n          <div class=\"flex box relative\">\n            <span class=\"time num-bold\"></span>\n            <div class=\"txt\">\n              <div class=\"flex s-item\">\n                  <span class=\"num-bold\">01</span>\n                  <h3>知識がなくても問題なし</h3>\n              </div>\n              <p>商業高校出身なので、機械に関する知識はゼロで入社しましたが、入社後の知識と技能の習得において、あまり苦労することはなかったです。また、3交代職場なので、睡眠やプライベート時間の確保に対して不安もありましたが、特に問題なく充実した日々を送れています。</p>\n            </div>\n          </div>\n          <div class=\"flex box relative\">\n            <span class=\"time num-bold\"></span>\n            <div class=\"txt\">\n              <div class=\"flex s-item\">\n                <span class=\"num-bold\">02</span>\n                <h3>人見知りからの脱却</h3>\n              </div>\n              <p>配属当初は、疑問点があっても遠慮して質問できずにいました。ですが、私の好きな野球など共通の話題がある方々に話しかけるようにしたことで、今では年齢関係なく皆さんと話すことができています。</p>\n            </div>\n          </div>\n          <div class=\"flex box relative\">\n            <span class=\"time num-bold\"></span>\n            <div class=\"txt\">\n              <div class=\"flex s-item\">\n                <span class=\"num-bold\">03</span>\n                <h3>中堅社員としての苦悩</h3>\n              </div>\n              <p>入社8年目を迎え、教える立場になることも増えました。入社当初の私のように、何も知らない後輩に教えるので、うまく伝わっているかな？と不安に思うことも。心配なときは、上司や先輩に「こうやって教えたんですけど、合っていますか？」と確認するようにしています。</p>\n            </div>\n          </div>\n          <div class=\"flex box relative\">\n            <span class=\"time num-bold\"></span>\n            <div class=\"txt\">\n              <div class=\"flex s-item\">\n                <span class=\"num-bold\">04</span>\n                <h3>手順書を再確認</h3>\n              </div>\n              <p>後輩に教えるときは、手順書を読み直して、作業の正しい手順や潜んでいるリスクなどを再確認するようにしています。私自身の理解を深めることで、よりわかりやすく後輩に伝えていきたいです。</p>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <section id=\"private\" class=\"pd-top Fade-area relative pd-bottom l-interview\">\n      <div class=\"relative w900\">\n        <h2 class=\"en\"><span class=\"initial orange\">P</span>rivate<small>休日の過ごし方</small></h2>\n\n        <div class=\"relative\">\n         <div class=\"flex_h anm\">\n            <div class=\"img\"><img src=\"https://recruit.hamada-hi.com/wp-content/uploads/2024/08/はまゆう9月号_裏表紙-3-e1724896988132.jpg\" width=\"600\" alt=\"K.H\"></div>\n            <p class=\"txt\">小学2年生のときに野球を始めてもうすぐ20年。現在も、プロ野球観戦や職場の同僚も所属している草野球チームの試合に出場したりと、野球を楽しんでいます。最近、好きな選手が球団を離れましたが、西武ライオンズを応援していきます。</p>\n         </div>\n        </div>\n      </div>\n    </section>\n\n      \n    <div class=\"btn relative\">\n      <a href=\"https://recruit.hamada-hi.com/voice/\">一覧に戻る</a>\n    </div>\n  </article>\n</main>\n\n<footer>\n\t<div class=\"box relative\">\n\t\t<div class=\"f-logo\"><a href=\"https://recruit.hamada-hi.com\"><img src=\"https://recruit.hamada-hi.com/wp-content/themes/hamada_recruit/images/f-menu_logo.png\" alt=\"濵田重工株式会社 Recruit\"></a></div>\n\t\t<div class=\"nav w1000\">\n\t\t\t<ul class=\"flex\">\n\t\t\t\t<li><a href=\"https://recruit.hamada-hi.com/rec_news/\">最新情報</a></li>\n\t\t\t\t<li><a href=\"https://recruit.hamada-hi.com/voice/\">先輩の声</a></li>\n\t\t\t\t<li><a href=\"https://recruit.hamada-hi.com/education/\">教育制度</a></li>\n\t\t\t\t<li><a href=\"https://recruit.hamada-hi.com/welfare/\">福利厚生</a></li>\n\t\t\t\t<li><a href=\"https://recruit.hamada-hi.com/abouthamada/\">数字でわかる濱田重工</a></li>\n\t\t\t\t<li><a href=\"//hamada-hi.com/company/sponsor/\">スポンサー活動</a></li>\n\t\t\t\t<li><a href=\"//hamada-hi.com\">コーポレートサイト</a></li>\n\t\t\t</ul>\n\t\t</div>\n\t\t<div class=\"absolute logo-asirai\"><img src=\"https://recruit.hamada-hi.com/wp-content/themes/hamada_recruit/images/f-logo_asirai.png\" alt=\"濵田重工株式会社\"></div>\n\t</div>\n\t<div class=\"copylight\">Copyright(c) HAMADA HEAVY INDUSTRIES LTD. All rights reserved.</div>\n</footer>\n<script>\n\t/*クリックしたらナビが右から左に出現*/\n\t$(\".open_btn\").click(function () {//ボタンがクリックされたら\n\t\t$(this).toggleClass('active');//ボタン自身に activeクラスを付与し\n\t\t$(\"#g-nav-list\").toggleClass('panelactive');//ナビゲーションにpanelactiveクラスを付与\n\t\t$(\"body\").toggleClass('hidden');//ナビゲーションにpanelactiveクラスを付与\n\t});\n\n\t$(\"#g-nav-list a\").click(function () {//ナビゲーションのリンクがクリックされたら\n\t\t$(\".open_btn\").removeClass('active');//ボタンの a