{"url":"https://www.tepco-sa.co.jp/ssl/recruit/environment_and_system/","html":"<!DOCTYPE html>\r\n<html lang=\"ja\">\r\n\r\n<head>\r\n  <meta charset=\"UTF-8\">\r\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n  <meta name=\"description\" content=\"テプコ・ソリューション・アドバンスの職場環境や制度をご紹介します。多様な働き方を支える制度や職場の雰囲気をお伝えします。\">\r\n  <meta name=\"keywords\" content=\"職場環境, 就業制度, ワークライフバランス, テプコ・ソリューション・アドバンス, 職場環境\">\r\n  <meta name=\"author\" content=\"テプコ・ソリューション・アドバンス株式会社\">\r\n  <title>テプコ・ソリューション・アドバンスの特徴｜採用情報｜テプコ・ソリューション・アドバンス株式会社</title>\r\n\r\n  <!--favicon https://www.favicon-generator.org/-->\r\n  <link rel=\"apple-touch-icon\" sizes=\"57x57\" href=\"https://www.tepco-sa.co.jp/ssl/images/site-icon/apple-icon-57x57.png\">\r\n  <link rel=\"apple-touch-icon\" sizes=\"60x60\" href=\"https://www.tepco-sa.co.jp/ssl/images/site-icon/apple-icon-60x60.png\">\r\n  <link rel=\"apple-touch-icon\" sizes=\"72x72\" href=\"https://www.tepco-sa.co.jp/ssl/images/site-icon/apple-icon-72x72.png\">\r\n  <link rel=\"apple-touch-icon\" sizes=\"76x76\" href=\"https://www.tepco-sa.co.jp/ssl/images/site-icon/apple-icon-76x76.png\">\r\n  <link rel=\"apple-touch-icon\" sizes=\"114x114\" href=\"https://www.tepco-sa.co.jp/ssl/images/site-icon/apple-icon-114x114.png\">\r\n  <link rel=\"apple-touch-icon\" sizes=\"120x120\" href=\"https://www.tepco-sa.co.jp/ssl/images/site-icon/apple-icon-120x120.png\">\r\n  <link rel=\"apple-touch-icon\" sizes=\"144x144\" href=\"https://www.tepco-sa.co.jp/ssl/images/site-icon/apple-icon-144x144.png\">\r\n  <link rel=\"apple-touch-icon\" sizes=\"152x152\" href=\"https://www.tepco-sa.co.jp/ssl/images/site-icon/apple-icon-152x152.png\">\r\n  <link rel=\"apple-touch-icon\" sizes=\"180x180\" href=\"https://www.tepco-sa.co.jp/ssl/images/site-icon/apple-icon-180x180.png\">\r\n  <link rel=\"icon\" type=\"image/png\" sizes=\"192x192\" href=\"https://www.tepco-sa.co.jp/ssl/images/site-icon/android-icon-192x192.png\">\r\n  <link rel=\"icon\" type=\"image/png\" sizes=\"32x32\" href=\"https://www.tepco-sa.co.jp/ssl/images/site-icon/favicon-32x32.png\">\r\n  <link rel=\"icon\" type=\"image/png\" sizes=\"96x96\" href=\"https://www.tepco-sa.co.jp/ssl/images/site-icon/favicon-96x96.png\">\r\n  <link rel=\"icon\" type=\"image/png\" sizes=\"16x16\" href=\"https://www.tepco-sa.co.jp/ssl/images/site-icon/favicon-16x16.png\">\r\n  <link rel=\"manifest\" href=\"https://www.tepco-sa.co.jp/ssl/images/site-icon/manifest.json\">\r\n  <meta name=\"msapplication-TileColor\" content=\"#ffffff\">\r\n  <meta name=\"msapplication-TileImage\" content=\"https://www.tepco-sa.co.jp/ssl/images/site-icon/ms-icon-144x144.png\">\r\n  <meta name=\"theme-color\" content=\"#ffffff\">\r\n  <link rel=\"canonical\" href=\"https://www.tepco-sa.co.jp/ssl/recruit/environment_and_system/\">\r\n\r\n  <!--google fonts-->\r\n  <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\r\n  <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\r\n  <link href=\"https://fonts.googleapis.com/css2?family=Hina+Mincho&family=Zen+Maru+Gothic:wght@400;500;700;900&display=swap\" rel=\"stylesheet\">\r\n\r\n  <!--css-->\r\n  <link href=\"https://www.tepco-sa.co.jp/ssl/src/css/vendor.css\" rel=\"stylesheet\">\r\n  <link href=\"https://www.tepco-sa.co.jp/ssl/src/css/theme.css\" rel=\"stylesheet\">\r\n  <link href=\"https://www.tepco-sa.co.jp/ssl/src/css/themes/career-detail.css\" rel=\"stylesheet\">\r\n  <script src=\"https://www.tepco-sa.co.jp/ssl/src/js/jquery.min.js\"></script>\r\n\r\n  <!-- Google Tag Manager -->\r\n  <script>(function (w, d, s, l, i) {\r\n      w[l] = w[l] || []; w[l].push({\r\n        'gtm.start':\r\n          new Date().getTime(), event: 'gtm.js'\r\n      }); var f = d.getElementsByTagName(s)[0],\r\n        j = d.createElement(s), dl = l != 'dataLayer' ? '&l=' + l : ''; j.async = true; j.src =\r\n          'https://www.googletagmanager.com/gtm.js?id=' + i + dl; f.parentNode.insertBefore(j, f);\r\n    })(window, document, 'script', 'dataLayer', 'GTM-P8XXC67');</script>\r\n  <!-- End Google Tag Manager -->\r\n</head>\r\n\r\n<body>\r\n  <!-- Google Tag Manager (noscript) -->\r\n  <noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-P8XXC67\" height=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\r\n  <!-- End Google Tag Manager (noscript) -->\r\n\r\n  <div id=\"header\"></div>\r\n  <script>\r\n    $(function () {\r\n      $('#header').load('https://www.tepco-sa.co.jp/ssl/src/inc/header.html');\r\n    });\r\n  </script>\r\n\r\n  <div class=\"page-wrapper benefits-page Workenvironment-page\">\r\n    <div class=\"main-container bg-transparent p-0 mb-5\">\r\n      <nav aria-label=\"breadcrumb\" class=\"page-breadcrumb\">\r\n        <ol class=\"breadcrumb mb-0\">\r\n          <li class=\"breadcrumb-item\"><a href=\"https://www.tepco-sa.co.jp/ssl/\">ホーム</a></li>\r\n          <li class=\"breadcrumb-item\"><a href=\"https://www.tepco-sa.co.jp/ssl/recruit/\">採用情報</a></li>\r\n          <li class=\"breadcrumb-item active\" aria-current=\"page\">テプコ・ソリューション・アドバンスの特徴</li>\r\n        </ol>\r\n      </nav>\r\n    </div>\r\n    <div class=\"main-container\">\r\n      <div class=\"heading-wrapper\">\r\n        <div class=\"heading\">\r\n          <div class=\"sc-title text-center\">テプコ・ソリューション・アドバンスの特徴</div>\r\n          <div class=\"sub-title text-center text-uppercase text-orange\">Environment and System</div>\r\n        </div>\r\n      </div>\r\n\r\n      <div class=\"title-wrapper fs-26\" id=\"link1\">働く環境</div>\r\n      <div class=\"environment_and_system-title\">男女比</div>\r\n      <figure class=\"mb-5 text-center\">\r\n        <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/environment_and_system/benefits-1.png\" alt=\"男女比：男性32.2% 女性67.8%\">\r\n      </figure>\r\n      <div class=\"environment_and_system-img\">\r\n        <div>\r\n          <div>\r\n            <div class=\"environment_and_system-title\">全従業員の割合</div>\r\n          </div>\r\n          <figure>\r\n            <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/environment_and_system/benefits-2.png\" alt=\"正社員50.1% 契約・パート社員49.9%\">\r\n          </figure>\r\n        </div>\r\n        <div>\r\n          <div>\r\n            <div class=\"environment_and_system-title mb-1\">在籍3年以上の割合</div>\r\n            <div class=\"environment_and_system-title-sub\">（全従業員）</div>\r\n          </div>\r\n          <figure>\r\n            <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/environment_and_system/benefits-3.png\" alt=\"68.0%\">\r\n          </figure>\r\n        </div>\r\n        <div>\r\n          <div>\r\n            <div class=\"environment_and_system-title\">育児休業取得率</div>\r\n          </div>\r\n          <figure>\r\n            <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/environment_and_system/benefits-4.png\" alt=\"100%\">\r\n          </figure>\r\n        </div>\r\n      </div>\r\n\r\n      <div class=\"benefits-bg-wrapper\">\r\n        <div class=\"fs-26 title text-center fw-bold\">特別休暇一例</div>\r\n        <div class=\"b-list\">\r\n          <span>・フォーシーズンズ休暇</span>\r\n          <span>・リフレッシュ休暇</span>\r\n          <span>・子の看護休暇</span>\r\n          <span>・介護休暇</span>\r\n          <span>・結婚休暇</span>\r\n          <span>・出産休暇（配偶者）</span>\r\n          <span>・忌服休暇</span>\r\n          <span>・裁判員休暇</span>\r\n          <span>等</span>\r\n        </div>\r\n        <div class=\"b-note\">※各休暇については当社規定による</div>\r\n      </div>\r\n\r\n      <div class=\"benefits-bg-wrapper\">\r\n        <div class=\"fs-26 title text-center fw-bold\">無期転換について</div>\r\n        <div class=\"para-text\">当社は、有期労働契約が５年を超えて繰り返し更新された場合、有期契約者本人の申し込みにより期間の定めのない労働契約（無期労働契約）に転換する制度を導入し、有期契約者とより適切な雇用関係にしていくために努めています。\r\n        </div>\r\n      </div>\r\n\r\n      <div class=\"benefits-bg-wrapper\">\r\n        <div class=\"fs-26 title text-center fw-bold\">労働施策総合推進法に基づく中途採用比率</div>\r\n        <div class=\"d-none d-lg-block\">\r\n          <table class=\"table\">\r\n            <tr>\r\n              <td>&nbsp;</td>\r\n              <td>2020年度</td>\r\n              <td>2021年度</td>\r\n              <td>2022年度</td>\r\n              <td>2023年度</td>\r\n              <td>2024年度</td>\r\n            </tr>\r\n            <tr>\r\n              <td>正規雇用労働者の中途採用比率</td>\r\n              <td>100% ※新卒採用なし</td>\r\n              <td>73.9%</td>\r\n              <td>71.9%</td>\r\n              <td>66.7%</td>\r\n              <td>65.4%</td>\r\n            </tr>\r\n          </table>\r\n        </div>\r\n        <div class=\"d-lg-none\">\r\n          <table class=\"table\">\r\n            <tr>\r\n              <td>&nbsp;</td>\r\n              <td>正規雇用労働者の中途採用比率</td>\r\n            </tr>\r\n            <tr>\r\n              <td>2020年度</td>\r\n              <td>100% ※新卒採用なし</td>\r\n            </tr>\r\n            <tr>\r\n              <td>2021年度</td>\r\n              <td>73.9%</td>\r\n            </tr>\r\n            <tr>\r\n              <td>2022年度</td>\r\n              <td>71.9%</td>\r\n            </tr>\r\n            <tr>\r\n              <td>2023年度</td>\r\n              <td>66.7%</td>\r\n            </tr>\r\n            <tr>\r\n              <td>2024年度</td>\r\n              <td>65.4%</td>\r\n            </tr>\r\n          </table>\r\n        </div>\r\n        <p class=\"d-flex justify-content-end mb-0\">公表日：2025年4月1日</p>\r\n      </div>\r\n\r\n      <div class=\"work-padding\">\r\n        <div class=\"title-wrapper fs-26\">ライフステージにあわせた制度紹介</div>\r\n        <p class=\"para-text\">妊娠中や子育て、介護などそれぞれのライフステージに合わせた制度でワークライフをサポートしています。</p>\r\n\r\n        <figure class=\"text-center d-none d-lg-block\">\r\n          <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/environment_and_system/img_lifestage_pc.png\" alt=\"\">\r\n        </figure>\r\n        <div class=\"lifestage-image d-lg-none\">\r\n          <p>横スクロールできます。</p>\r\n          <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/environment_and_system/img_lifestage_sp.png\" alt=\"\">\r\n        </div>\r\n      </div>\r\n\r\n      <div class=\"work-padding\">\r\n        <div class=\"title-wrapper fs-26\">サポート体制</div>\r\n        <p class=\"para-text\">テプコ・ソリューション・アドバンスでは、安心して働いていただくために法令違反行為やハラスメントに関する相談窓口を設けております。</p>\r\n\r\n        <div class=\"d-flex flex-wrap align-items-center justify-content-center hotline-btns\">\r\n          <div>企業倫理窓口</div>\r\n          <div>人権相談窓口</div>\r\n        </div>\r\n      </div>\r\n\r\n      <div class=\"work-padding\">\r\n        <div class=\"title-wrapper fs-26\">勤務時の服装について</div>\r\n        <p class=\"para-text mb-0\">\r\n          リラックスして仕事ができるカジュアルな服装で勤務しています。 <br>\r\n          ビジネスシーンに合わせてふさわしい服装を自分で決めています。\r\n        </p>\r\n      </div>\r\n\r\n      <div class=\"work-padding\">\r\n        <div class=\"title-wrapper fs-26\" id=\"link2\">生産性向上に向けたカイゼン活動の取組</div>\r\n        <p class=\"para-text\">\r\n          東京電力グループ全体で取り組んでいるカイゼン活動。<br>\r\n          当社は、人材育成とコスト削減・生産性向上を目的に、本社にカイゼン推進グループを設置。「カイゼンを基軸とした生産性向上」の活動を継続的に推進しています。\r\n        </p>\r\n        <p class=\"para-text\">\r\n          取組の一例としては、各職場でカイゼン活動を中心的に推進するリーダーを集めた研修や全社員・契約社員を対象としたカイゼン基礎研修を開催。<br>\r\n          そのような取り組みによって、カイゼンに対する意識が全社に浸透し始め、大きな成果が実感できる事例の報告が続々と挙がってきています！\r\n        </p>\r\n        <p class=\"para-text mb-0\">\r\n          カイゼンに終わりはありません。<br>\r\n          TSAは、更なる生産性の向上を目指し、今後もカイゼン活動の推進に取り組んでいきます。\r\n        </p>\r\n      </div>\r\n\r\n      <div class=\"work-padding\">\r\n        <div class=\"title-wrapper fs-26\" id=\"link3\">女性活躍推進</div>\r\n        <p class=\"para-text\">\r\n          働く意思のある女性が、その個性と能力を十分に発揮できる社会を実現するため、「女性の職業生活における活躍の推進に関する法律」（女性活躍推進法）が、2016年4月から施行されました。<br>\r\n          当社では、事業主としてのその責務を果たせるよう、積極的に女性活躍推進の取組を行っています。</p>\r\n        <figure class=\"text-center mt-5\">\r\n          <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/environment_and_system/workenvironment-1.png\" alt=\"一般事業主行動計画の定量的目標:\r\n          管理職に占める女性の割合を15％以上とする。係長級に占める女性の割合を50％以上とする。\">\r\n        </figure>\r\n      </div>\r\n\r\n      <div class=\"work-padding\">\r\n        <div class=\"initiative-block\">\r\n          <div class=\"row row-cols-1 row-cols-md-2\">\r\n            <div>\r\n              <div class=\"ini-bg\">\r\n                <div class=\"ini-title fs-20 fw-bold text-center\">取組み1</div>\r\n                <div class=\"ini-sub-title fs-20 fw-bold text-center\">社員の育成と活躍の場拡大</div>\r\n                <p class=\"para-text\">\r\n                  ジョブローテーションによる育成とキャリア形成の検討。\r\n                  能力発揮を重視した役割の付与と適任者の昇格の実施\r\n                </p>\r\n              </div>\r\n            </div>\r\n            <div>\r\n              <div class=\"ini-bg\">\r\n                <div class=\"ini-title fs-20 fw-bold text-center\">取組み2</div>\r\n                <div class=\"ini-sub-title fs-20 fw-bold text-center\">ワークライフバランスの実現に向けた勤務制度の活用の推奨</div>\r\n                <p class=\"para-text\">\r\n                  フレックスタイム制度や在宅勤務制度、育児・介護に関する時間休制度などの活用の推奨\r\n                </p>\r\n              </div>\r\n            </div>\r\n          </div>\r\n\r\n          <div class=\"ini-bg mt-4\">\r\n            <div class=\"ini-title fs-20 fw-bold no-border\">「えるぼし認定」</div>\r\n            <div class=\"d-flex flex-column flex-sm-row gap-5\">\r\n              <p class=\"para-text mb-0\">\r\n                当社は、女性の活躍推進に関する取り組みの実績が優良である企業として、厚生労働省が認定する「えるぼし認定」３つ星を取得しました。<br>\r\n                （2025年1月21日認定取得）\r\n              </p>\r\n              <div class=\"career-logo\">\r\n                <a href=\"https://positive-ryouritsu.mhlw.go.jp/positivedb/detail?id=4373\" target=\"_blank\"><img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/career/career-logo.png\" alt=\"career-logo\"></a>\r\n              </div>\r\n            </div>\r\n          </div>\r\n\r\n          <div class=\"career-btn-link\">\r\n            <a href=\"https://positive-ryouritsu.mhlw.go.jp/positivedb/detail?id=4373\" target=\"_blank\">厚生労働省「女性の活躍推進企業データベース\r\n              <div class=\"right-icon\"><svg width=\"32px\" xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"#ffffff\" color=\"#ffffff\">\r\n                  <path d=\"M13.1717 12.0007L8.22192 7.05093L9.63614 5.63672L16.0001 12.0007L9.63614 18.3646L8.22192 16.9504L13.1717 12.0007Z\">\r\n                  </path>\r\n                </svg>\r\n              </div>\r\n            </a>\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n    </div>\r\n  </div>\r\n  <!-- main content -->\r\n\r\n  <div id=\"footer\"></div>\r\n  <script defer>\r\n    $(function () {\r\n      $('#footer').load('https://www.tepco-sa.co.jp/ssl/src/inc/footer.html');\r\n    });\r\n  </script>\r\n  <script src=\"https://www.tepco-sa.co.jp/ssl/src/js/popper.min.js\"></script>\r\n  <script src=\"https://www.tepco-sa.co.jp/ssl/src/js/bootstrap.min.js\"></script>\r\n  <script src=\"https://www.tepco-sa.co.jp/ssl/src/js/slick.js\"></script>\r\n  <script src=\"https://www.tepco-sa.co.jp/ssl/src/js/jquery.matchHeight-min.js\"></script>\r\n  <script src=\"https://www.tepco-sa.co.jp/ssl/src/js/custom.js\"></script>\r\n</body>\r\n\r\n</html>","finalUrl":"https://www.tepco-sa.co.jp/ssl/recruit/environment_and_system/","rendered":false,"_cachedAt":"2026-06-22T21:08:13.131Z"}