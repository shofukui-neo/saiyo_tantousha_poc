on-kv-main-img\" style=\"background-image: url(/assets/img/common/default-kv.png);\"></div> -->\n            <div class=\"com-section-kv-main-img\" style=\"background-image: url(/assets/img/recruit/img-recruit-kv.jpg);\"></div>\n          </div>\n          <!-- End .com-section-kv-main-img-block -->\n          <div class=\"lay-breadcrumbs-list\">\n            <ol class=\"mod-panel-layout\">\n              <li>\n                <a href=\"/\">トップ</a>\n              </li>\n              <li>\n                <a href=\"/recruit/\">採用情報</a>\n              </li>\n            </ol>\n          </div>\n          <!-- End .lay-breadcrumbs-list -->\n        </section>\n\n        <section class=\"recruit__types\">\n          <div class=\"com-section-inner\">\n            <h2 class=\"recruit__type__ttl recruit__ttl\">募集職種</h2>\n\n            <section class=\"recruit__sales recruit__details\">\n              <h3 class=\"recruit__sales__ttl recruit__details__ttl\">営業</h3>\n              <table class=\"recruit__table\">\n                <tbody>\n                  <tr class=\"recruit__table__row\">\n                    <th class=\"recruit__table__head\">募集職種</th>\n                    <td class=\"recruit__table__detail\">営業（大阪営業所）</td>\n                  </tr>\n                  <tr class=\"recruit__table__row\">\n                    <th class=\"recruit__table__head\">職務内容</th>\n                    <td class=\"recruit__table__detail\">測量機器・システム販売、ルート営業、レンタル新規提案営業</td>\n                  </tr>\n                  <tr class=\"recruit__table__row\">\n                    <th class=\"recruit__table__head\">応募資格</th>\n                    <td class=\"recruit__table__detail\">\n                      <ul class=\"recruit__table__list\">\n                        <li class=\"recruit__table__item\"><span class=\"recruit__table__item_bold\">学歴：</span>高卒以上</li>\n                        <li class=\"recruit__table__item\"><span class=\"recruit__table__item_bold\">資格：</span>普通自動車運転免許（AT限定可）</li>\n                        <li class=\"recruit__table__item\"><span class=\"recruit__table__item_bold\">経験・能力：</span>パソコン基本操作<span class=\"sp-break\">（ワード・エクセル）</span></li>\n                      </ul>\n                    </td>\n                  </tr>\n                </tbody>\n              </table>\n            </section>\n            <!-- End .recruit__sales -->\n\n            <section class=\"recruit__ga recruit__details\">\n              <h3 class=\"recruit__details__ttl\">総務</h3>\n              <table class=\"recruit__table\">\n                <tbody>\n                  <tr class=\"recruit__table__row\">\n                    <th class=\"recruit__table__head\">募集職種</th>\n                    <td class=\"recruit__table__detail\">総務（本社）</td>\n                  </tr>\n                  <tr class=\"recruit__table__row\">\n                    <th class=\"recruit__table__head\">職務内容</th>\n                    <td class=\"recruit__table__detail\">一般事務、経理、営業補助など</td>\n                  </tr>\n                  <tr class=\"recruit__table__row\">\n                    <th class=\"recruit__table__head\">応募資格</th>\n                    <td class=\"recruit__table__detail\">\n                      <ul class=\"recruit__table__list\">\n                        <li class=\"recruit__table__item\"><span class=\"recruit__table__item_bold\">学歴：</span>高卒以上</li>\n                        <li class=\"recruit__table__item\"><span class=\"recruit__table__item_bold\">経験・能力：</span>パソコン基本操作<span class=\"sp-break\">（ワード・エクセル）</span><span class=\"recruit__table__item_note\">※実務経験のある方は優遇</span></li>\n                      </ul>\n                    </td>\n                  </tr>\n                </tbody>\n              </table>\n            </section>\n            <!-- End .recruit__ga -->\n\n\n            <section class=\"recruit__tech recruit__details\">\n              <h3 class=\"recruit__details__ttl\">技術</h3>\n              <table class=\"recruit__table\">\n                <tbody>\n                  <tr class=\"recruit__table__row\">\n                    <th class=\"recruit__table__head\">募集職種</th>\n                    <td class=\"recruit__table__detail\">技術　<span style=\"color:red\">※現在は募集しておりません</span></td>\n                  </tr>\n                  <tr class=\"recruit__table__row\">\n                    <th class=\"recruit__table__head\">職務内容</th>\n                    <td class=\"recruit__table__detail\">測量機器のメンテナンス</td>\n                  </tr>\n                  <tr class=\"recruit__table__row\">\n                    <th class=\"recruit__table__head\">応募資格</th>\n                    <td class=\"recruit__table__detail\">\n                      <ul class=\"recruit__table__list\">\n                        <li class=\"recruit__table__item\"><span class=\"recruit__table__item_bold\">学歴：</span>高卒以上</li>\n                        <li class=\"recruit__table__item\"><span class=\"recruit__table__item_bold\">経験・能力：</span>パソコン基本操作<span class=\"sp-break\">（ワード・エクセル）</span><span class=\"recruit__table__item_note\">※実務経験のある方は優遇</span></li>\n                      </ul>\n                    </td>\n                  </tr>\n                </tbody>\n              </table>\n            </section>\n            <!-- End .recruit__tech -->\n          </div>\n        </section>\n        <!-- End .recruit__types -->\n\n        <section class=\"recruit__info\">\n          <div class=\"com-section-inner\">\n            <h2 class=\"recruit__info__ttl recruit__ttl\">募集要項</h2>\n            <table class=\"recruit__table\">\n              <tbody>\n                <tr class=\"recruit__table__row\">\n                  <th class=\"recruit__table__head\">応募期間</th>\n                  <td class=\"recruit__table__detail\">随時</td>\n                </tr>\n                <tr class=\"recruit__table__row\">\n                  <th class=\"recruit__table__head\">選考方法</th>\n                  <td class=\"recruit__table__detail\">書類選考、面接</td>\n                </tr>\n                <tr class=\"recruit__table__row\">\n                  <th class=\"recruit__table__head\">就業時間</th>\n                  <td class=\"recruit__table__detail\">8：30～17：30</td>\n                </tr>\n                <tr class=\"recruit__table__row\">\n                  <th class=\"recruit__table__head\">時間外労働</th>\n                  <td class=\"recruit__table__detail\">あり（月20～30時間程度）</td>\n                </tr>\n                <tr class=\"recruit__table__row\">\n                  <th class=\"recruit__table__head\">賃金</th>\n                  <td class=\"recruit__table__detail\">経験・能力を考慮し当社規程に準じて個別に設定します。</td>\n                </tr>\n                <tr class=\"recruit__table__row\">\n                  <th class=\"recruit__table__head\">諸手当</th>\n                  <td class=\"recruit__table__detail\">家族手当、時間外勤務手当、通勤手当など</td>\n                </tr>\n                <tr class=\"recruit__table__row\">\n                  <th class=\"recruit__table__head\">昇給</th>\n                  <td class=\"recruit__table__detail\">年1回（7月）</td>\n                </tr>\n                <tr class=\"recruit__table__row\">\n                  <th class=\"recruit__table__head\">賞与</th>\n                  <td class=\"recruit__table__detail\">年2回（7月、12月）　<span class=\"sp-break\">※業績により期末賞与あり（3月）</span></td>\n                </tr>\n                  <tr class=\"recruit__table__row\">\n                  <th class=\"recruit__table__head\">休日</th>\n                  <td class=\"recruit__table__detail\">\n                    <ul class=\"recruit__table__list\">\n                      <li class=\"recruit__table__item\">週休2日制（土曜、日曜、祝日）　<span class=\"sp-break\">※当社カレンダーによる</span></li>\n                      <li class=\"recruit__table__item\">年次有給休暇（半日休暇制度あり）</li>\n                      <li class=\"recruit__table__item\">産前産後、育児、介護休業　※過去3年取得率100％（6名）</li>\n                    </ul>\n                  </td>\n                </tr>\n\n                <tr class=\"recruit__table__row\">\n                  <th class=\"recruit__table__head\">その他</th>\n                  <td class=\"recruit__table__detail\">\n                    <ul class=\"recruit__table__list\">\n                      <li class=\"recruit__table__item\">平均年収　約700万円（2025年度実績）</li>\n                      <li class=\"recruit__table__item\">社員平均年齢　40.7歳（2026年5月現在）</li>\n                    </ul>\n                  </td>\n                </tr>\n                <tr class=\"recruit__table__row\">\n                  <th class=\"recruit__table__head\">加入保険</th>\n                  <td class=\"recruit__table__detail\">雇用保険、労災保険、厚生年金、健康保険</td>\n                </tr>\n                <tr class=\"recruit__table__row\">\n                  <th class=\"recruit__table__head\">福利厚生</th>\n                   <td class=\"recruit__table__detail\">\n                    <ul class=\"recruit__table__list\">\n                     <li class=\"recruit__table__item\">保養施設利用補助、健康診断・インフルエンザ予防接種費用補助</li>      \n                     <li class=\"recruit__table__item\">グループ保険（医療保障・死亡保障）</li>\n                     <li class=\"recruit__table__item\">資格取得支援、永年勤続表彰</li> \n                     <li class=\"recruit__table__item\">退職金制度、その他</li>    \n                   </ul>\n                 </td>\n               </tr>               \n              </tbody>\n            </table>\n          </div>\n        </section>\n        <!-- End .recruit__info -->\n\n<br>\n<br>\n<div style=\"text-align:center\">\n<a href=\"https://en-gage.net/sanyou-sokki/?banner=1\" target=\"_blank\"><img src=\"https://en-gage.net/imageFile_new/company/widget_banner_A_pc_728×90.png\" alt=\"engage\" border=\"0\"></a> \n</div>\n      </article>\n      <!-- End #lay-article -->\n    </main>\n    <!-- End #lay-main -->\n\n    <!-- Start footer -->\n    <div class=\"lay-page-top-wrap\">\n  <a href=\"#\" class=\"lay-page-top\">\n      PAGE<br>TOP\n    <!-- <img src=\"/assets/img/common/page-top.png\" alt=\"PAGE TOP\" class=\"over\"> -->\n  </a>\n</div>\n<!-- End .lay-page-top-wrap -->\n\n<section class=\"f