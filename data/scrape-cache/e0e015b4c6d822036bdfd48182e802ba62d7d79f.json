{"url":"https://www.okinawa.ccbc.co.jp/recruite/interview/marketing.html","html":"<!doctype html>\n<html lang=\"ja\">\n<head>\n<!-- Google Tag Manager --> \n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n})(window,document,'script','dataLayer','GTM-K49Q3QS');</script> \n<!-- End Google Tag Manager -->\n<meta charset=\"UTF-8\">\n<title>社員インタビュー｜沖縄コカ･コーラボトリング採用情報</title>\n<meta name=\"description\" content=\"沖縄地域のコカ･コーラ採用情報サイト　リクルート情報　新規学卒　募集要項\">\n<meta name=\"keywords\" content=\"沖縄,コカ･コーラ,リクルート,大学卒,募集要項,募集要項\">\n<meta property=\"og:title\" content=\">社員インタビュー｜沖縄コカ･コーラボトリング 採用情報　新卒採用\">\n<meta property=\"og:type\" content=\"website\" />\n<meta property=\"og:url\" content=\"http://www.okinawa.ccbc.co.jp/recruite/interview/akamine.html\">\n<meta property=\"og:image\" content=\"http://www.okinawa.ccbc.co.jp/cmn/img/logo.gif\">\n<meta property=\"og:description\" content=\"未来へ受け継いでいこうワシタチムグクルに\">\n<meta property=\"og:site_name\" content=\"沖縄コカ･コーラボトリング採用情報\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1, maximum-scale=1\">\n<meta name=\"format-detection\" content=\"telephone=no\">\n<link rel=\"shortcut icon\" href=\"/favicon.ico\"/>\n<meta name=\"apple-mobile-web-app-title\" content=\"沖縄コカコーラ\">\n<link rel=\"apple-touch-icon\" sizes=\"192x192\" href=\"/cmn/touch-icon.png\">\n<link href=\"/recruite/css/style.css\" rel=\"stylesheet\" type=\"text/css\">\n<link href=\"style.css\" rel=\"stylesheet\" type=\"text/css\">\n<link href=\"img/marketing/style.css\" rel=\"stylesheet\" type=\"text/css\">\n<script\nsrc=\"https://code.jquery.com/jquery-2.2.4.min.js\"\nintegrity=\"sha256-BbhdlvQf/xTY9gja0Dq3HiwQF8LaCRTXxZKRutelT44=\"\ncrossorigin=\"anonymous\"></script> \n<script type=\"text/javascript\" src=\"/recruite/js/script.js\"></script>\n</head>\n<body>\n<!-- Google Tag Manager (noscript) -->\n<noscript>\n<iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-K49Q3QS\"\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe>\n</noscript>\n<!-- End Google Tag Manager (noscript) --> \n<!--loding-->\n<div id=\"loader\">\n  <div class=\"spinner\">\n    <div class=\"rect1\"></div>\n    <div class=\"rect2\"></div>\n    <div class=\"rect3\"></div>\n    <div class=\"rect4\"></div>\n    <div class=\"rect5\"></div>\n  </div>\n</div>\n<!--/loding-->\n<div id=\"wrapper\"> \n  <!--header--> \n  <header>\n<div id=\"header\">\n<div class=\"sitename\">\n<h1><a href=\"/recruite/\"><img src=\"/recruite/img/logo.svg\" alt=\"沖縄コカ･コーラボトリング採用情報\" class=\"logo\"/><span class=\"siteH1\"><span class=\"corp\">沖縄コカ･コーラボトリング</span>RECRUIT SITE</span></a></h1>\n</div>\n<div class=\"contactmenu\"><a href=\"/recruite/form/\" target=\"_blank\" class=\"en\">CONTACT<span class=\"icon-forward\"></span></a></div>\n<nav>\n<ul id=\"jetmenu\" class=\"jetmenu\">\n<li><a href=\"/recruite/message/\">\n<p>社長メッセージ</p>\n</a></li>\n<li><a href=\"/recruite/vision/\">\n<p>企業ビジョン</p>\n</a></li>\n<li><a href=\"/recruite/culture/\">\n<p>企業文化</p>\n</a></li>\n<li><a href=\"/recruite/carrier_plan/\">\n<p>教育・キャリアプラン</p>\n</a></li>\n<li><a href=\"javascript:void();\">\n<p>社員インタビュー<span class=\"icon-arrow-down\"></span></p>\n</a><!--row-->\n<div class=\"megamenu full-width\">\n<div class=\"row\">\n<div class=\"memint\">\n<div class=\"title mh\">\n<h5><span class=\"en\">Interview</span>社員インタビュー</h5>\n</div>\n<ul>\n<li><a href=\"/recruite/interview/marketing.html\">\n<p><img src=\"/recruite/img/cmn/men06.jpg\" alt=\"\"/></p>\n<p class=\"text1\">トレードマーケティング部</p>\n<p class=\"text2\">新垣 凜／與久田 藍香</p>\n</a></li>\n<li><a href=\"/recruite/interview/akamine.html\">\n<p><img src=\"/recruite/img/cmn/men07.jpg\" alt=\"\"/></p>\n<p class=\"text1\">浦添工場 製造二課</p>\n<p class=\"text2\">赤嶺 孝太</p>\n</li>\n<li></li>\n</ul>\n</div>\n<a></a></div>\n</div>\n<!--/row--></li>\n<li><a href=\"/recruite/guideline/\">\n<p>募集要項</p>\n</a></li>\n</ul>\n</nav>\n</div>\n</header>\n \n  <!--/header-->\n  <main> \n    <!--　メイン画像　-->\n    <div class=\"secondtitle marketing\">\n      <div class=\"fade-layer\"></div>\n      <h2><span class=\"en\">Interview</span>社員インタビュー</h2>\n    </div>\n    <!--　/ メイン画像　--> \n    <!--　社員情報　-->\n    <div style=\"position: relative;\">\n      <div class=\"trg\"></div>\n      <!--名刺-->\n      <div class=\"card_layout\">\n        <ul>\n          <li>\n            <div class=\"meminfo\">\n              <div>\n                <p class=\"post\">営業本部トレードマーケティング部チャネル企画課 </p>\n                <p class=\"name\">新垣　凜<span>Rin Arakaki</span></p>\n                <p class=\"year\">2020年入社／国際教養学部出身</p>\n              </div>\n            </div>\n          </li>\n          <li>\n            <div class=\"meminfo \">\n              <div>\n                <p class=\"post\">営業本部トレードマーケティング部\n                  戦略企画課 </p>\n                <p class=\"name\">與久田　藍香<span>Aika Yokuda</span></p>\n                <p class=\"year\">2019年入社／生物工学科出身 </p>\n              </div>\n            </div>\n          </li>\n        </ul>\n      </div>\n      <!--/名刺--> \n      \n      <!--　/ 社員情報　--> \n      <!--　社員インタビュー　-->\n      <section class=\"section1\">\n        <div class=\"sec1width\">\n          <div class=\"textbox\">\n            <dl class=\"qa\">\n              <dt><span>私たちの仕事</span></dt>\n              <dd>\n                <p class=\"name\">新垣</p>\n                <p>スーパーマーケット、コンビニエンスストアや飲食店での売り上げ拡大に向けて、データ分析などで営業スタッフをサポートする仕事をしています。米軍ルートをメインで担当しているので、学生時代に習得した英語を使って米軍パスの申請や基地内のショップや軍艦からの受注、本部へ新商品登録のオファーなども行っています。</p>\n                <p class=\"name\">與久田</p>\n                <p>商品プロモーション関係を担当しており、企画の情報発信やポップ・機材の手配、SNS配信などを担当しています。その他にも自動販売機の設置展開状況等の情報管理もしており、新型機材の情報や全国のコカ･コーラの状況など日本コカ･コーラとやり取りしています。</p>\n              </dd>\n            </dl>\n            <dl class=\"qa\">\n              <dt><span>仕事の面白さ</span></dt>\n              <dd>\n                <p class=\"name\">新垣</p>\n                <p>私の業務は日々のセールス情報をチェックするので、商品の動向が見えるところです。この新商品が売れている！とか、一日でこんなに売り上げが伸びたんだ！とか、データをみながら楽しんでいます。<br>\n                  また、私の業務ではAccessからデータを抽出し、ExcelやPowerPointに情報をまとめていくのですが情報を渡す相手が見やすいようにデータの見せ方を工夫することが難しいところでもあり、面白いところだと思います。最初はわからないことも多かったのですが、周りに教えていただいたり、先輩方の資料を参考に関数を読み解いて真似したりしながら学んでいます！！</p>\n                <p class=\"name\">與久田</p>\n                <p>私は全国のプロモーションや沖縄限定のプロモーションに企画・立案から立ち会えることです。自分が発注した資材が実際の店舗に飾られている時や、新商品が並んでいる時は、成果が目に見えるのでやっぱり嬉しいです。沖縄限定のプロモーション企画の提案が社内で通った時はとても嬉しかったです。また、プロモーション期間のセールスが上がっていると次も頑張ろうという気持ちになります。</p>\n              </dd>\n            </dl>\n          </div>\n          <div class=\"imgbox fadein\"></div>\n        </div>\n      </section>\n    </div>\n    <section class=\"section2\">\n      <div class=\"sec2width\">\n        <div class=\"imgbox fadein\"></div>\n        <div class=\"textbox\">\n          <dl class=\"qa fadein\">\n            <dt><span>沖縄コカ･コーラボトリングを選んだ理由</span></dt>\n            <dd>\n              <p class=\"name\">與久田</p>\n              <p>コカ･コーラのインパクトは大きかった。ネームバリューに惹かれて説明会に参加しました。</p>\n              <p class=\"name\">新垣</p>\n              <p>私もそうです。あとは参加した説明会で、営業で活躍している女性先輩社員とお話しする機会があり、自分もこうなりたいと思い入社を決めちゃいました！</p>\n              <p class=\"name\">與久田</p>\n              <p>私は専門学校出身なので工場の品質管理業務ができる企業を探していたことと、ジンジャエールが大好きだったからです！当初の予定とは違いますが・・・オフィス業務もとても楽しいです！</p>\n            </dd>\n          </dl>\n          <dl class=\"qa fadein\">\n            <dt><span>なりたい自分</span></dt>\n            <dd>\n              <p class=\"name\">與久田</p>\n              <p>産休・育休に入っている方や、子育てしながら働いている先輩社員を見て、私も仕事をしながら育児や家事をこなせるキャリアウーマンになりたいと思っています。プライベートでの目標は10年後も今の体形を維持することと、ロサンゼルスに大谷翔平選手の試合を見に行く事です！</p>\n              <p class=\"name\">新垣</p>\n              <p>入社4年目ですが、まだまだ勉強中の毎日です。私たちの部署には、スキルのある、頼りになる先輩方がたくさんいます。私も早くそんな先輩方に追いつき、後輩が入ってきたときには同じ様に引っ張っていける人材になりたいです。</p>\n            </dd>\n          </dl>\n        </div>\n      </div>\n    </section>\n    <section class=\"section5\">\n      <div class=\"sec5width\">\n        <div class=\"textbox\">\n          <dl class=\"qa fadein\">\n            <dt><span>休日の過ごし方</span></dt>\n            <dd>\n              <p class=\"name\">新垣</p>\n              <p>最近は海に泳ぎに行ったり、海やベランダでBBQをしたりと夏を満喫しています！ぷかぷかと海に浮かぶだけでカラダが浄化されて最高のリフレッシュになるのでオススメです。日光浴で、幸せホルモン「セロトニン」を生成できますよ～♪バーベキューはもちろん食べる担当です（笑）何も予定がない日はお昼前までぐっすり寝たりもします（笑）</p>\n              <p class=\"name\">與久田</p>\n              <p>朝活してます！朝ジョギングに行ったりジムに行ったりして、朝から動いてはやめにご飯を食べるようにしています。友達と遊びに行く日も、朝に何かをしてから出かけるようにして、自分を整える時間をつくっています。</p>\n            </dd>\n          </dl>\n          <dl class=\"qa fadein\">\n            <dt><span>学生の皆さんへ</span></dt>\n            <dd>\n              <p class=\"name\">新垣</p>\n              <p>やりたいことを見つけるのは難しいと思いますが、これだけは譲れないという軸を持っていたらいい会社に巡り合えると思います。学生の時にしかできないことはたくさんあるので、卒業までの時間を有効につかって楽しんでください。</p>\n              <p class=\"name\">與久田</p>\n              <p>焦りや不安が尽きず、やりたいことがわからない人も多いと思うので、やりたくないことを見つけるのも一つのポイントだと思います。仕事は楽しいことだけではないが、仕事を楽しくすることも自分次第だと思うから是非頑張って欲しいです。大事なことは、時には遊んでリフレッシュすることです！</p>\n            </dd>\n          </dl>\n        </div>\n        <div class=\"imgbox fadein\"></div>\n      </div>\n    <div class=\"intimg\"><picture>\n  <source type=\"image/webp\" media=\"(max-width: 767px)\" srcset=\"/recruite/interview/img/marketing/img3.webp\" />\n\t\t<source type=\"image/webp\" media=\"(max-width: 1159px)\" srcset=\"/recruite/interview/img/marketing/img3_l.webp\" />\n  <source type=\"image/webp\" media=\"(min-width: 1160px)\" srcset=\"/recruite/interview/img/marketing/img3_l2.webp 2x\" />\n\t<source media=\"(max-width: 767px)\" srcset=\"/recruite/interview/img/marketing/img3.jpg\">\n\t\t<source media=\"(max-width: 1159px)\" srcset=\"/recruite/interview/img/marketing/img3_l.jpg\">\n  <img src=\"/recruite/interview/img/marketing/img3_l2.jpg\" alt=\"\" />\n</picture></div>\n\t  </section>\n    \n    <!--　/ 社員インタビュー　--> \n  </main>\n  <!--　お問い合わせ　-->\n<aside class=\"infoLink\">\n<article class=\"contact\">\n<div class=\"basewidth\"><div class=\"all_contact\"><a href=\"tel:0988775257\" target=\"_blank\" class=\"inqtel\">\n      <p><span class=\"icon-phone\"></span><span class=\"phone\"><strong>098-877-5257</strong><i>平日9:00～17:00</i></span><span class=\"icospc\"></span></p>\n      </a><a href=\"/recruite/guideline/\"  class=\"guideline\"><p><span class=\"icon-file\"></span><span>募集要項</span><span class=\"icospc\"></span></p></a><a href=\"/recruite/form/\" target=\"_blank\"  class=\"inqmail\">\n      <p><span class=\"icon-envelope\"></span><span>採用に関するお問い合わせ</span></p>\n      </a></div>\n</div>\n</article>\n</aside>\n<!--　/ お問い合わせ　--> \n<!--footer-->\n<footer>\n<div id=\"footer\">\n<div class=\"logo\"><a href=\"/recruite/\"><img src=\"/recruite/img/logo.svg\" alt=\"沖縄コカ･コーラボトリング リクルート\"/><span class=\"siteH1\"><span class=\"corp\">沖縄コカ･コーラボトリング</span>RECRUIT SITE</span></a></div>\n<div class=\"footernav\">\n<nav>\n<dl class=\"line\">\n<dt>Contents</dt>\n<dd>\n<ul>\n<li><a href=\"/recruite/message/\">社長メッセージ</a></li>\n<li><a href=\"/recruite/vision/\">企業ビジョン</a></li>\n<li><a href=\"/recruite/culture/\">企業文化</a></li>\n<li><a href=\"/recruite/carrier_plan/\">教育・キャリアプラン</a> </li>\n<li><a href=\"/recruite/guideline/\">募集要項</a> </li>\n<li><a href=\"/recruite/form/\" target=\"_blank\">お問い合わせ</a> </li>\n</ul>\n</dd>\n</dl>\n<dl>\n<dt>Interview </dt>\n<dd>\n<ul>\n<li><a href=\"/recruite/interview/marketing.html\">新垣 凜／與久田 藍香</a></li>\n<li><a href=\"/recruite/interview/akamine.html\">赤嶺 孝太</a></li>\n</ul>\n</dd>\n</dl>\n</nav>\n</div>\n</div>\n<p class=\"copyright\">&copy; Okinawa Coca-Cola Bottling. All rigts reserved.</p>\n</footer>\n<!--/footer-->\n<p class=\"pagetop\"><a href=\"#wrapper\"><img src=\"/recruite/img/pagetop.png\" alt=\"このページのトップへ\"/></a></p>\n<!--SNSボタン-->\n<div id=\"sns\"><a href=\"https://youtube.com/channel/UChsB29BLuWGsuVKFCWQSERA?si=pPadrNdcxwR5iD5V\" target=\"_blank\"><span class=\"icon-youtube\"></span>Youtube</a><a href=\"https://www.instagram.com/okinawa_cocacola_recruit/\" target=\"_blank\"><span class=\"icon-instagram\"></span>Instagram</a></div> \n</div>\n<!--スクリプト--> \n<script>\n$('.fade-layer').animate({\n  'opacity' : '1'\n}, 5000);\n\t</script> \n<script type=\"text/javascript\" src=\"/recruite/js/jetmenu.js\"></script> \n<script type=\"text/javascript\" src=\"/recruite/js/common.js\"></script>\n</body>\n</html>\n","finalUrl":"https://www.okinawa.ccbc.co.jp/recruite/interview/marketing.html","rendered":false,"_cachedAt":"2026-06-23T22:41:25.494Z"}