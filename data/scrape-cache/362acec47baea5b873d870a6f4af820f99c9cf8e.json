css/interview.css?ver=1772161332' type='text/css' media='all' />\n<script type=\"text/javascript\" src=\"https://www.pasconet.co.jp/recruit/wp-content/themes/pasco/assets/js/jquery.min.js?ver=3.7.1\" id=\"jquery-js\"></script>\n<link rel=\"icon\" href=\"https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/01/cropped-favicon-32x32.png\" sizes=\"32x32\" />\n<link rel=\"icon\" href=\"https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/01/cropped-favicon-192x192.png\" sizes=\"192x192\" />\n<link rel=\"apple-touch-icon\" href=\"https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/01/cropped-favicon-180x180.png\" />\n<meta name=\"msapplication-TileImage\" content=\"https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/01/cropped-favicon-270x270.png\" />\n</script>\r\n</head>\r\n<body>\r\n\t<header id=\"header\" class=\"p-header\">\r\n    <div class=\"p-header__wrap\">\r\n        <a href=\"https://www.pasconet.co.jp/recruit/\" class=\"p-header__logo hover\">\r\n            <span class=\"p-header__logo-img\">\r\n                <img src=\"https://www.pasconet.co.jp/recruit/wp-content/themes/pasco/assets/images/common/pasco_logo.svg\" alt=\"Pasco\">\r\n            </span>\r\n            <span class=\"p-header__logo-txt\">新卒<br class=\"sp\">採用サイト</span>\r\n        </a>\r\n        <div class=\"p-header__right\">\r\n            <h1 class=\"p-header__ttl\">敷島製パン株式会社 Pascoの大学生向けの新卒採用サイト「穏やかな人が多く、チャレンジしたい人にもってこいの環境。」ページ</h1>\r\n            <div class=\"p-header__main\">\r\n                <nav class=\"p-header__nav\">\r\n                    <a href=\"https://www.pasconet.co.jp/recruit/details/\" class=\"p-header__btn btn-hover\">募集要項<span class=\"icon icon-info\"></span></a>\r\n                    <a href=\"https://job.axol.jp/bx/s/pasco_27/entry\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"p-header__btn p-header__btn--info btn-hover\">27年卒 ENTRY<span class=\"icon icon-entry\"></span></a>\r\n                    <a href=\"https://axol.jp/zw/s/pasco_28/entry/agreement\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"p-header__btn p-header__btn--info btn-hover\">28年卒 ENTRY<span class=\"icon icon-entry\"></span></a>\r\n                </nav>\r\n                <a href=\"https://www.instagram.com/pasco_saiyo/\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"p-header__ins\"><img src=\"https://www.pasconet.co.jp/recruit/wp-content/themes/pasco/assets/images/common/icn_ins.svg\" alt=\"instagram\"></a>\r\n                <div class=\"hamburger-box js-show-menu\" role=\"button\" aria-label=\"Menu\" aria-expanded=\"false\"><span class=\"hamburger-inner\"></span></div>\r\n            </div>\r\n        </div>\r\n    </div>\r\n\r\n    <div class=\"p-header__wrap p-header__wrap--fixed\">\r\n        <a href=\"https://www.pasconet.co.jp/recruit/\" class=\"p-header__logo hover\">\r\n            <span class=\"p-header__logo-img\">\r\n                <img src=\"https://www.pasconet.co.jp/recruit/wp-content/themes/pasco/assets/images/common/pasco_logo.svg\" alt=\"Pasco\">\r\n            </span>\r\n            <span class=\"p-header__logo-txt\">新卒<br>採用サイト</span>\r\n        </a>\r\n        <div class=\"p-header__right\">\r\n            <div class=\"p-header__main\">\r\n                <nav class=\"p-header__nav\">\r\n                    <a href=\"https://www.pasconet.co.jp/recruit/details/\" class=\"p-header__btn btn-hover\">募集要項<span class=\"icon icon-info\"></span></a>\r\n                    <a href=\"https://job.axol.jp/bx/s/pasco_27/entry\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"p-header__btn p-header__btn--info btn-hover\">27年卒 ENTRY<span class=\"icon icon-entry\"></span></a>\r\n                    <a href=\"https://axol.jp/zw/s/pasco_28/entry/agreement\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"p-header__btn p-header__btn--info btn-hover\">28年卒 ENTRY<span class=\"icon icon-entry\"></span></a>\r\n                </nav>\r\n                <a href=\"https://www.instagram.com/pasco_saiyo/\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"p-header__ins\"><img src=\"https://www.pasconet.co.jp/recruit/wp-content/themes/pasco/assets/images/common/icn_ins.svg\" alt=\"instagram\"></a>\r\n            </div>\r\n        </div>\r\n    </div>\r\n    <div class=\"hamburger-box hamburger-box--single js-show-menu\" role=\"button\" aria-label=\"Menu\" aria-expanded=\"false\"><span class=\"hamburger-inner\"></span></div>\r\n\r\n    <div class=\"global-nav\">\r\n    <div class=\"global-nav__wrap\">\r\n        <nav class=\"global-nav__group\">\r\n            <ul class=\"nav-list\">\r\n                <li class=\"nav-item\">\r\n                    <a href=\"https://www.pasconet.co.jp/recruit/\" class=\"nav-link\">\r\n                        <span class=\"nav-link__ttl\">Top</span>\r\n                        <span class=\"nav-link__sub\">採用ページトップ</span>\r\n                    </a>\r\n                </li>\r\n                <li class=\"nav-item\">\r\n                    <a href=\"https://www.pasconet.co.jp/recruit/news/\" class=\"nav-link\">\r\n                        <span class=\"nav-link__ttl\">News</span>\r\n                        <span class=\"nav-link__sub\">お知らせ</span>\r\n                    </a>\r\n                </li>\r\n                <li class=\"nav-item\">\r\n                    <a href=\"https://www.pasconet.co.jp/recruit/company/\" class=\"nav-link\">\r\n                        <span class=\"nav-link__ttl\">Company</span>\r\n                        <span class=\"nav-link__sub\">会社概要&<br class=\"sp\">社長メッセージ</span>\r\n                    </a>\r\n                </li>\r\n                <li class=\"nav-item\">\r\n                    <a href=\"https://www.pasconet.co.jp/recruit/data/\" class=\"nav-link\">\r\n                        <span class=\"nav-link__ttl\">Data</span>\r\n                        <span class=\"nav-link__sub\">数字で見るPasco</span>\r\n                    </a>\r\n                </li>\r\n                <li class=\"nav-item\">\r\n                    <a href=\"https://www.pasconet.co.jp/recruit/interview/\" class=\"nav-link\">\r\n                        <span class=\"nav-link__ttl\">Interview</span>\r\n                        <span class=\"nav-link__sub\">社員インタビュー</span>\r\n                    </a>\r\n                </li>\r\n            </ul>\r\n            <ul class=\"nav-list\">\r\n                <li class=\"nav-item\">\r\n                    <a href=\"https://www.pasconet.co.jp/recruit/discussion/\" class=\"nav-link\">\r\n                        <span class=\"nav-link__ttl\">Discussion</span>\r\n                        <span class=\"nav-link__sub\">社員対談</span>\r\n                    </a>\r\n                </li>\r\n                <li class=\"nav-item\">\r\n                    <a href=\"https://www.pasconet.co.jp/recruit/culture/\" class=\"nav-link\">\r\n                        <span class=\"nav-link__ttl\">Culture</span>\r\n                        <span class=\"nav-link__sub\">企業文化＆働く環境</span>\r\n                    </a>\r\n                </li>\r\n                <li class=\"nav-item\">\r\n                    <a href=\"https://www.pasconet.co.jp/recruit/career/\" class=\"nav-link\">\r\n                        <span class=\"nav-link__ttl\">Career</span>\r\n                        <span class=\"nav-link__sub\">教育・研修制度＆<br class=\"sp\">キャリアパス</span>\r\n                    </a>\r\n                </li>\r\n                <li class=\"nav-item\">\r\n                    <a href=\"https://www.pasconet.co.jp/recruit/business/\" class=\"nav-link\">\r\n                        <span class=\"nav-link__ttl\">Business</span>\r\n                        <span class=\"nav-link__sub\">事業内容</span>\r\n                    </a>\r\n                </li>\r\n                <li class=\"nav-item\">\r\n                    <a href=\"https://www.pasconet.co.jp/recruit/qa/\" class=\"nav-link\">\r\n                        <span class=\"nav-link__ttl\">Q&A</span>\r\n                        <span class=\"nav-link__sub\">よくある質問</span>\r\n                    </a>\r\n                </li>\r\n            </ul>\r\n        </nav>\r\n        <nav class=\"global-nav__other\">\r\n            <a href=\"https://www.pasconet.co.jp/recruit/details/\" class=\"btn btn-sub btn-hover\">募集要項・<br class=\"pc\">採用スケジュール<span class=\"icon icon-info\"></span></a>\r\n            <a href=\"https://job.axol.jp/bx/s/pasco_27/entry/\" class=\"btn btn-primary-reverse btn-hover\" target=\"_blank\">27年卒 ENTRY<span class=\"icon icon-entry\"></span></a>\r\n            <a href=\"https://axol.jp/zw/s/pasco_28/entry/agreement\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"btn btn-primary-reverse btn-hover\">28年卒 ENTRY<span class=\"icon icon-entry\"></span></a>\r\n        </nav>\r\n    </div>\r\n</div></header>\r\n\r\n<ul class=\"nav-fixed sp\">\r\n    <li><a href=\"https://www.pasconet.co.jp/recruit/details/\" class=\"btn btn-sub btn-hover\">募集要項<span class=\"icon icon-info\"></span></a></li>\r\n    <li><a href=\"https://job.axol.jp/bx/s/pasco_27/entry\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"btn btn-primary btn-hover\">27年卒 ENTRY<span class=\"icon icon-entry\"></span></a></li>\r\n    <li><a href=\"https://axol.jp/zw/s/pasco_28/entry/agreement\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"btn btn-primary btn-hover\">28年卒 ENTRY<span class=\"icon icon-entry\"></span></a></li>\r\n</ul><div class=\"c-mv\">\r\n    <div class=\"c-mv__wrap\">\r\n        <div class=\"c-mv__content\">\r\n            <h2 class=\"c-mv__page\">Interview</h2>\r\n            <p class=\"c-mv__sub\">社員インタビュー</p>\r\n        </div>\r\n        <div class=\"c-breadcrumb\">\r\n            <ul class=\"c-breadcrumb__list\">\r\n                <li class=\"c-breadcrumb__item hover\"><a href=\"https://www.pasconet.co.jp/recruit/\">ホーム</a></li>\r\n                <li class=\"c-breadcrumb__item hover\"><a href=\"https://www.pasconet.co.jp/recruit/interview/\">社員インタビュー</a></li>\r\n                <li class=\"c-breadcrumb__item\">穏やかな人が多く、チャレンジしたい人にもってこいの環境。</li>\r\n            </ul>\r\n        </div>\r\n    </div>\r\n</div>\r\n<div class=\"inner\">\r\n    <div class=\"c-single\">\r\n        <div class=\"c-single__media\">\r\n                        <div class=\"c-single__media-img\">\r\n                                    <p class=\"c-single__media-cate\">エンジニア</p>\r\n                                \r\n                <img width=\"999\" height=\"1024\" src=\"https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A9210-scaled-e1772073161109-999x1024.jpg\" class=\"attachment-large size-large wp-post-image\" alt=\"\" decoding=\"async\" fetchpriority=\"high\" srcset=\"https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A9210-scaled-e1772073161109-999x1024.jpg 999w, https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A9210-scaled-e1772073161109-293x300.jpg 293w, https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A9210-scaled-e1772073161109-768x787.jpg 768w, https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A9210-scaled-e1772073161109-1498x1536.jpg 1498w, https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A9210-scaled-e1772073161109.jpg 1707w\" sizes=\"(max-width: 999px) 100vw, 999px\" />            </div>\r\n                        \r\n            <div class=\"c-single__media-body\">\r\n                                <p class=\"btn-basic\">2015年入社 / AI・ロボット開発　係長職</p>\r\n                \r\n                <p class=\"c-single__media-ttl\">穏やかな人が多く、チャレンジしたい人にもってこいの環境。</p>\r\n                <p class=\"c-single__media-name\">村井</p>\r\n            </div>\r\n        </div>\r\n\r\n        \r\n                \r\n        <div class=\"detail-body c-txt\"><div class=\"box\">\n<p>【略歴】<br />\n2015年4月：エンジニア職入社<br />\n2018年9月：TPM推進部に配属<br />\n2020年12月：AI・ロボット開発に配属<br />\n2024年9月：係長職に昇進</p>\n<p>&nbsp;</p>\n<p>【好きな商品】<br />\n1位：国産小麦 バゲット<br />\n2位：麦のめぐみ 全粒粉入り食パン<br />\n3位：国産小麦と米粉のロール</p>\n</div>\n<h3>Q：入社の理由は？<br />\nA：柔らかいものを機械で扱う面白さに惹かれて入社。</h3>\n<p>私は工学部出身で、機械の故障のメカニズムについて研究していました。金属など硬いものに触れる機会が多かったからこそ、逆に、食品など柔らかいものを扱うことに興味を持つようになりました。人の手で行う料理という工程を機械でどう実現するのか、その技術について興味深く感じていました。また、設備保全を学んでいたため、工場運営を支える仕事にも魅力を感じていました。</p>\n<p>そのような背景があり、就職活動では食品メーカーを中心に考えたのですが、他の食品系企業は、生産職や総合職に限った募集ばかりで、私が希望していたエンジニアや工場運営の仕事に携われる職種の募集があったのがPascoでした。<br />\n地元の企業で昔から馴染みがあったことも、入社の決め手になりました。</p>\n<h3>Q：仕事の内容は？<br />\nA：人とAI・ロボットが共に働く未来を創る仕事。</h3>\n<div>\n<div class=\"img-with-txt\">\n<div class=\"img-with-txt__content\">\n<div><img decoding=\"async\" class=\"alignnone wp-image-282 \" src=\"https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A9252-scaled-e1772012134250.png\" alt=\"\" width=\"929\" height=\"712\" srcset=\"https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A9252-scaled-e1772012134250.png 2227w, https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A9252-scaled-e1772012134250-300x230.png 300w, https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A9252-scaled-e1772012134250-1024x785.png 1024w, https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A9252-scaled-e1772012134250-768x589.png 768w, https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A9252-scaled-e1772012134250-1536x1177.png 1536w, https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A9252-scaled-e1772012134250-2048x1570.png 2048w\" sizes=\"(max-width: 929px) 100vw, 929px\" /></div>\n<div>　</div>\n<p>近年は、労働人口の減少による人手不足が深刻化しており、現在所属している部署では、その解決策としてAI・ロボット・IoTを活用した生産工程の自動化に取り組んでいます。例えば、AIの画像認識技術によるパン・菓子の品質検査、単純苦渋作業のロボットへの置き換え、生産設備のIoT化による無人監視など、さまざまなロボットを研究・開発しています。</p>\n<p>&nbsp;</p>\n<p>仕事の流れとしては、トップダウンで「こういうことがしたい」という要望に対応することもあれば、私たち側から現場の声を吸い上げて「技術的にこうすれば困りごとを解決できそう」と提案することも。いずれの場合でも、まず生産現場を調査し、実際の生産工程を理解する必要があります。特に新たな設備を導入するとなると、生産職やエンジニア職に「どう使うのか」「どうすれば使いやすいか」などいろいろな話をヒアリングし、実際の導入についてシミュレーションを重ねながら検討し、最終導入まで取り組みます。</p>\n<p>案件によっては、やりたいことに合致する技術があるかどうかを調査することにも時間がかかったりして、種をまいてから芽が出るまで数年かかることもあります。一方で、すぐに導入できるものもあります。他業界では普及している技術でも、食品業界では使われていないことがほとんどのため、他業界の技術を参考にすることが多いですね。</p>\n<p>&nbsp;</p>\n<p>技術の進化に追いつくのは大変ですが、新しい技術を学んで現場で応用できると達成感があります。新しいことにチャレンジできる機会の多さが、私の原動力です。</p>\n<h3>Q：AI・ロボット開発で大切なことは？<br />\nA：ベストな選択を追求すること。</h3>\n<p>大切なのは、その場しのぎで対応するのではなく、本当に最適な手段を選ぶことだと考えています。例えば、生産現場に新たな設備を導入する際、「このままでも問題はないが、もう少しこうすれば使いやすいのに」といった声が出ないよう、一度立ち止まって「最終的にベストな結果につながるか」を必ず考えるようにしています。技術は日々進歩していくため、現在のベストもいずれはベストではなくなりますが、それでも「あのタイミングでは最善の選択だった」と言い切れるくらい、後悔のない対応をしています。</p>\n<p>&nbsp;</p>\n<p>ベストを目指すからこそ、頭を悩まされる場面は多くあります。特に衛生面は、他の業界より厳しく考えることが多いです。また、例えば自動車部品なら製造工程で1個目と2個目で形が変わることは絶対にありませんが、パンは形や重量が一個一個異なりますし、生地が柔らかすぎてロボットが掴めないといった課題があり、全く同じ方法では解決できない場合もあります。ベストを実現することはなかなか難しいですね。</p>\n<h3>Q：どんな会社？<br />\nA：穏やかな人が多く、チャレンジしたい人にもってこいの環境。</h3>\n<div>\n<div class=\"img-with-txt\">\n<div class=\"img-with-txt__content\">\n<div><img decoding=\"async\" class=\"alignnone size-full wp-image-255\" src=\"https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A9295-scaled.jpg\" alt=\"\" width=\"2560\" height=\"1707\" srcset=\"https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A9295-scaled.jpg 2560w, https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A9295-300x200.jpg 300w, https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A9295-1024x683.jpg 1024w, https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A9295-768x512.jpg 768w, https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A9295-1536x1024.jpg 1536w, https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A9295-2048x1365.jpg 2048w\" sizes=\"(max-width: 2560px) 100vw, 2560px\" /></div>\n<div>　</div>\n<p>これまで一緒に働いてきた方は穏やかな方が多く、安心して働きやすいです。仕事上、さまざまな部署と関わることが多いのですが、質問に対して親身になって答えてくれますし、協力してくれる人も多いため、温かい人が多いなと感じています。</p>\n<p>また、自分のペースで成長できる企業だと思います。自分のアイデアや提案が受け入れられ、挑戦するチャンスも数多くあります。そのため、「難しいからこそやってみたい」と困難な状況であるほど燃える方は、とても合っている会社だと思います。新しいことにもチャレンジしたいという方と一緒に成長していきたいです。</p>\n<h3>Q：今後の目標は？<br />\nA：誰もが働きやすい環境をつくること。</h3>\n<p>自動化技術を活用することで労働人口減少に対応し、どんな人でも働ける、そんな生産現場がつくれたら良いなと思っています。例えば「体力的に辛い」とか、「この仕事は男性にしかできない」とか、限定的な人しか対応できない仕事をなくすべきだと思っていて、人的な作業がある部分に踏み込んでいきたいです。</p>\n<p>&nbsp;</p>\n<p>また、パンの生産現場では、長時間の作業によって暑さが負担となることもあります。AIやIoT技術を活用した無人監視システムを導入すれば、人が常時作業に張り付く必要がなくなり、作業環境が大幅に改善されると思います。無人監視はそう遠い未来ではなく、もう実現できる目星がついています。</p>\n<p>&nbsp;</p>\n<p>そのほかにも、AIの開発に取り組みたいなと考えています。現在所属している部署では、AIとロボットの2つの分野があり、私はロボットの分野を専門としており、仕組みが分からないままAIを使っている場面も多いため、自分でプログラムを書けたらもっと理解できるんじゃないかなと思います。</p>\n<p>将来的には、パンの品質の良し悪しをAIに判断させたりと、人が判断する場面を減らせたら良いですよね。そういうものを自社内でつくれるかどうかはさておき、自分でAIがどう動いているのか勉強して、最終的にはどんな人でも働きやすい生産現場をつくりたいです。</p>\n</div>\n</div>\n</div>\n</div>\n</div>\n</div>\n</div>\r\n    </div>\r\n</div>\r\n<div class=\"container\">\r\n        <nav class=\"c-back-nav\">\r\n                    <a href=\"https://www.pasconet.co.jp/recruit/sales/p184/\" class=\"c-back-nav__arrow c-back-nav__arrow--prev\"></a>\r\n        \r\n        <a href=\"https://www.pasconet.co.jp/recruit/interview/\" class=\"btn btn-sub c-back-nav__button\">一覧へ戻る</a>\r\n\r\n                    <span class=\"c-back-nav__arrow c-back-nav__arrow--next disabled\"></span>\r\n            </nav>\r\n\r\n        <nav class=\"c-category-filter\">\r\n        <ul class=\"c-category-filter__list\">\r\n            <li><a href=\"https://www.pasconet.co.jp/recruit/interview/\" class=\"btn-basic\">すべて</a></li>\r\n                        <li><a href=\"https://www.pasconet.co.jp/recruit/interview/engineer/\" class=\"btn-basic\">エンジニア</a></li>\r\n                        <li><a href=\"https://www.pasconet.co.jp/recruit/interview/sales/\" class=\"btn-basic\">営業</a></li>\r\n                        <li><a href=\"https://www.pasconet.co.jp/recruit/interview/production/\" class=\"btn-basic\">生産</a></li>\r\n                    </ul>\r\n    </nav>\r\n    </div>\r\n\r\n<footer class=\"p-footer\">\r\n    <div class=\"inner\">\r\n        <div class=\"footer-entry\">\r\n            <h3 class=\"footer-entry__ttl font-en\">Entry!</h3>\r\n            <p class=\"footer-entry__txt\">Pascoでは、<br class=\"sp\">一緒に働く社員を募集しています。<br>\r\n            まだ夢がはっきりしていなくても<br class=\"sp\">大丈夫。挑戦する気持ちを持つ<br class=\"sp\">皆さまからのエントリーを<br class=\"sp\">お待ちしています。</p>\r\n            <div class=\"footer-entry__nav\">\r\n                <a href=\"https://www.pasconet.co.jp/recruit/details/\" class=\"btn btn-sub btn-hover\">募集要項・<br class=\"pc\">採用スケジュール<span class=\"icon icon-info\"></span></a>\r\n                <a href=\"https://job.axol.jp/bx/s/pasco_27/entry\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"btn btn-primary btn-hover\">27年卒 ENTRY<span class=\"icon icon-entry\"></span></a>\r\n                <a href=\"https://axol.jp/zw/s/pasco_28/entry/agreement\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"btn btn-primary btn-hover\">28年卒 ENTRY<span class=\"icon icon-entry\"></span></a>\r\n            </div>\r\n            <div class=\"footer-entry__img --left\">\r\n                <picture>\r\n                    <source media=\"(min-width: 768px)\" srcset=\"https://www.pasconet.co.jp/recruit/wp-content/themes/pasco/assets/images/common/footer_entry_img01.svg\">\r\n                    <img src=\"https://www.pasconet.co.jp/recruit/wp-content/themes/pasco/assets/images/common/footer_entry_img01_sp.svg\">\r\n                </picture>\r\n            </div>\r\n            <div class=\"footer-entry__img --right\">\r\n                <picture>\r\n                    <source media=\"(min-width: 768px)\" srcset=\"https://www.pasconet.co.jp/recruit/wp-content/themes/pasco/assets/images/common/footer_entry_img02.svg\">\r\n                    <img src=\"https://www.pasconet.co.jp/recruit/wp-content/themes/pasco/assets/images/common/footer_entry_img02_sp.svg\">\r\n                </picture>\r\n            </div>\r\n        </div>\r\n    </div>\r\n\r\n    <div class=\"container\">\r\n        <div class=\"p-footer__wrap\">\r\n            <div class=\"p-footer__logo\">\r\n                <span class=\"p-footer__logo-img\"><img src=\"https://www.pasconet.co.jp/recruit/wp-content/themes/pasco/assets/images/common/pasco_logo.svg\" alt=\"Pasco\"></span>\r\n                <span class=\"p-footer__logo-txt\">新卒採用サイト</span>\r\n            </div>\r\n            <nav class=\"p-footer__nav\">\r\n                <ul>\r\n                    <li><a href=\"https://www.pasconet.co.jp/recruit/\">採用サイトトップ</a></li>\r\n                    <li><a href=\"https://www.pasconet.co.jp/recruit/news/\">お知らせ</a></li>\r\n                    <li><a href=\"https://www.pasconet.co.jp/recruit/company/\">会社概要&<br class=\"sp\">社長メッセージ</a></li>\r\n                    <li><a href=\"https://www.pasconet.co.jp/recruit/data/\">数字で見るPasco</a></li>\r\n                    <li><a href=\"https://www.pasconet.co.jp/recruit/interview/\">社員インタビュー</a></li>\r\n                    <li><a href=\"https://www.pasconet.co.jp/recruit/discussion/\">社員対談</a></li>\r\n                </ul>\r\n                <ul>\r\n                    <li><a href=\"https://www.pasconet.co.jp/recruit/culture/\">企業文化&働く環境</a></li>\r\n                    <li><a href=\"https://www.pasconet.co.jp/recruit/career/\">教育・研修制度＆<br class=\"sp\">キャリアパス</a></li>\r\n                    <li><a href=\"https://www.pasconet.co.jp/recruit/business/\">事業内容</a></li>\r\n                    <li><a href=\"https://www.pasconet.co.jp/recruit/qa/\">よくある質問</a></li>\r\n                    <li><a href=\"https://www.pasconet.co.jp/recruit/details/\">募集要項・<br>採用スケジュール</a></li>\r\n                </ul>\r\n            </nav>\r\n        </div>\r\n        <div class=\"p-footer__other\">\r\n            <nav class=\"footer-nav\">\r\n                <a href=\"https://www.pasconet.co.jp/\" target=\"_blank\" rel=\"noopener noreferrer\">コーポレートサイト</a>\r\n                <a href=\"https://www.pasconet.co.jp/privacypolicy/\" target=\"_blank\" rel=\"noopener noreferrer\">プライバシーポリシー</a>\r\n            </nav>\r\n            <p class=\"copyright font-en\">© All Rights Reserved.<br class=\"sp\">Pasco Shikishima Corporation</p>\r\n        </div>\r\n    </div>\r\n</footer><script type=\"speculationrules\">\n{\"prefetch\":[{\"source\":\"document\",\"where\":{\"and\":[{\"href_matches\":\"/recruit/*\"},{\"not\":{\"href_matches\":[\"/recruit/wp-*.php\",\"/recruit/wp-admin/*\",\"/recruit/wp-content/uploads/*\",\"/recruit/wp-content/*\",\"/recruit/wp-content/plugins/*\",\"/recruit/wp-content/themes/pasco/*\",\"/recruit/*\\\\?(.+)\"]}},{\"not\":{\"selector_matches\":\"a[rel~=\\\"nofollow\\\"]\"}},{\"not\":{\"selector_matches\":\".no-prefetch, .no-prefetch a\"}}]},\"eagerness\":\"conservative\"}]}\n</script>\n<script type=\"text/javascript\" src=\"https://www.pasconet.co.jp/recruit/wp-content/themes/pasco/assets/js/fixHeight.js?ver=1.0\" id=\"fixHeight-js\"></script>\n<script type=\"text/javascript\" src=\"https://www.pasconet.co.jp/recruit/wp-content/themes/pasco/assets/js/rellax.min.js?ver=1.0\" id=\"rellax-js\"></script>\n<script type=\"text/javascript\" src=\"https://www.pasconet.co.jp/recruit/wp-content/themes/pasco/assets/js/wow.min.js?ver=1.0\" id=\"wow-js\"></script>\n<script type=\"text/javascript\" src=\"https://www.pasconet.co.jp/recruit/wp-content/themes/pasco/assets/js/slick.min.js?ver=1.8.1\" id=\"slick-js\"></script>\n<script type=\"text/javascript\" src=\"https://www.pasconet.co.jp/recruit/wp-content/themes/pasco/assets/js/jquery.sticky-kit.min.js?ver=1.0\" id=\"sticky-js\"></script>\n<script type=\"text/javascript\" src=\"https://www.pasconet.co.jp/recruit/wp-content/themes/pasco/assets/js/script.js?ver=1773111457\" id=\"main-js\"></script>\n\r\n</body>\r\n</html>","finalUrl":"https://www.pasconet.co.jp/recruit/engineer/p182/","rendered":false,"_cachedAt":"2026-06-22T21:04:28.467Z"}