class=\"company\">会社概要</a></li>\n\t\t\t\t\t\t<li><a href=\"https://www.fuji-label.co.jp/recruit/\" class=\"recruit\">採用情報</a></li>\n\t\t\t\t\t\t<li><a href=\"https://www.fuji-label.co.jp/contact/\" class=\"contact\">お問い合わせ</a></li>\n\t\t\t\t\t</ul>\n\t\t\t\t</div>\n\t\t\t</nav>\n\t\t</div>\n\t</div>\n</header>\n\n<main class=\"l-main\">\n\t\n\t\t<!-- ページタイトル -->\n\t\t<section class=\"l-section bg-dot\">\n\t\t\t<div class=\"l-container\">\n\t\t\t\t<div class=\"l-page-title\">\n\t\t\t\t\t<h1 class=\"page-title\">Contact<span>お問い合わせ</span></h1>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</section>\n\n\t\t<!-- パンくず -->\n\t\t<section class=\"l-section\">\n\t\t\t<div class=\"l-container\">\n\t\t\t\t<ul class=\"list-breadcrumb\">\n\t\t\t\t\t<li><a href=\"https://www.fuji-label.co.jp\">TOP</a></li>\n\t\t\t\t\t<li>お問い合わせ</li>\n\t\t\t\t</ul>\n\t\t\t</div>\n\t\t</section>\n\n\t\t<!-- 本文エリア -->\n\t\t\n<section class=\"l-section\">\n<div class=\"l-container\">\n<div class=\"contact-area\" data-aos=\"fade-in\">\n<p>お問い合わせは、下記項目にご入力の上、「確認」ボタンをクリックしてください。<br>なお<span class=\"required\">*</span>印の項目は必須事項となっておりますので必ずご入力ください。</p>\n<p>お問い合わせ内容によりまして、ご返答までにお時間をいただく場合がございます。<br>緊急のお問い合わせは電話（04-2938-7670）をご利用ください。</p>\n<form action=\"\" method=\"post\"><div id=\"mw_wp_form_mw-wp-form-32\" class=\"mw_wp_form mw_wp_form_input  \">\n\t\t\t\t\t<form method=\"post\" action=\"\" enctype=\"multipart/form-data\"><div class=\"uk-margin\">\r\n\r\n<label class=\"uk-form-label\">お名前<span class=\"required\">*</span></label>\r\n<div><input type=\"text\" name=\"your-name\" id=\"your-name\" class=\"uk-input\" size=\"60\" maxlength=\"50\" value=\"\" placeholder=\"お名前を入力してください\" />\n</div>\r\n</div>\r\n<div class=\"uk-margin\">\r\n\r\n<label class=\"uk-form-label\">会社名<span class=\"required\">*</span></label>\r\n<div><input type=\"text\" name=\"your-company\" id=\"your-company\" class=\"uk-input\" size=\"60\" maxlength=\"100\" value=\"\" placeholder=\"会社名を入力してください\" />\n</div>\r\n</div>\r\n<div class=\"uk-margin\">\r\n\r\n<label class=\"uk-form-label\">部署名</label>\r\n<div><input type=\"text\" name=\"your-department\" id=\"your-department\" class=\"uk-input\" size=\"60\" maxlength=\"100\" value=\"\" placeholder=\"部署名を入力してください\" />\n</div>\r\n</div>\r\n<div class=\"uk-margin\">\r\n\r\n<label class=\"uk-form-label\">郵便番号<span class=\"required\">*</span></label>\r\n<div><input type=\"text\" name=\"your-postal-code\" id=\"your-postal-code\" class=\"uk-input\" size=\"60\" maxlength=\"8\" value=\"\" placeholder=\"郵便番号を入力してください\" data-conv-half-alphanumeric=\"true\"/>\n</div>\r\n</div>\r\n<div class=\"uk-margin\">\r\n\r\n<label class=\"uk-form-label\">ご住所<span class=\"required\">*</span></label>\r\n<div><input type=\"text\" name=\"your-address\" id=\"your-address\" class=\"uk-input\" size=\"60\" maxlength=\"100\" value=\"\" placeholder=\"ご住所を入力してください\" />\n</div>\r\n</div>\r\n<div class=\"uk-margin\">\r\n\r\n<label class=\"uk-form-label\">電話番号<span class=\"required\">*</span></label>\r\n<div><input type=\"text\" name=\"your-tel\" id=\"your-tel\" class=\"uk-input\" size=\"60\" maxlength=\"100\" value=\"\" placeholder=\"電話番号を入力してください\" data-conv-half-alphanumeric=\"true\"/>\n</div>\r\n</div>\r\n<div class=\"uk-margin\">\r\n\r\n<label class=\"uk-form-label\">メールアドレス<span class=\"required\">*</span></label>\r\n<div><input type=\"text\" name=\"your-email\" id=\"your-email\" class=\"uk-input\" size=\"60\" maxlength=\"100\" value=\"\" placeholder=\"メールアドレスを入力してください\" data-conv-half-alphanumeric=\"true\"/>\n</div>\r\n</div>\r\n<div class=\"uk-margin\">\r\n<div class=\"uk-form-label\">お問い合わせの種類<span class=\"required\">*</span></div>\r\n<div class=\"uk-form-controls\">\t<span class=\"mwform-radio-field vertical-item\">\n\t\t<label for=\"your-message-type-1\">\n\t\t\t<input type=\"radio\" name=\"your-message-type\" value=\"ラベラー／プリンターについてのご質問、ご要望\" id=\"your-message-type-1\" class=\"uk-radio\" />\n\t\t\t<span class=\"mwform-radio-field-text\">ラベラー／プリンターについてのご質問、ご要望</span>\n\t\t</label>\n\t</span>\n\t<span class=\"mwform-radio-field vertical-item\">\n\t\t<label for=\"your-message-type-2\">\n\t\t\t<input type=\"radio\" name=\"your-message-type\" value=\"ラベルについてのご質問、ご要望\" id=\"your-message-type-2\" class=\"uk-radio\" />\n\t\t\t<span class=\"mwform-radio-field-text\">ラベルについてのご質問、ご要望</span>\n\t\t</label>\n\t</span>\n\t<span class=\"mwform-radio-field vertical-item\">\n\t\t<label for=\"your-message-type-3\">\n\t\t\t<input type=\"radio\" name=\"your-message-type\" value=\"ラベル、ラベラー両方についてのご質問、ご要望\" id=\"your-message-type-3\" class=\"uk-radio\" />\n\t\t\t<span class=\"mwform-radio-field-text\">ラベル、ラベラー両方についてのご質問、ご要望</span>\n\t\t</label>\n\t</span>\n\t<span class=\"mwform-radio-field vertical-item\">\n\t\t<label for=\"your-message-type-4\">\n\t\t\t<input type=\"radio\" name=\"your-message-type\" value=\"その他一般的なご質問、ご要望\" id=\"your-message-type-4\" class=\"uk-radio\" />\n\t\t\t<span class=\"mwform-radio-field-text\">その他一般的なご質問、ご要望</span>\n\t\t</label>\n\t</span>\n<input type=\"hidden\" name=\"__children[your-message-type][]\" value=\"{&quot;\\u30e9\\u30d9\\u30e9\\u30fc\\uff0f\\u30d7\\u30ea\\u30f3\\u30bf\\u30fc\\u306b\\u3064\\u3044\\u3066\\u306e\\u3054\\u8cea\\u554f\\u3001\\u3054\\u8981\\u671b&quot;:&quot;\\u30e9\\u30d9\\u30e9\\u30fc\\uff0f\\u30d7\\u30ea\\u30f3\\u30bf\\u30fc\\u306b\\u3064\\u3044\\u3066\\u306e\\u3054\\u8cea\\u554f\\u3001\\u3054\\u8981\\u671b&quot;,&quot;\\u30e9\\u30d9\\u30eb\\u306b\\u3064\\u3044\\u3066\\u306e\\u3054\\u8cea\\u554f\\u3001\\u3054\\u8981\\u671b&quot;:&quot;\\u30e9\\u30d9\\u30eb\\u306b\\u3064\\u3044\\u3066\\u306e\\u3054\\u8cea\\u554f\\u3001\\u3054\\u8981\\u671b&quot;,&quot;\\u30e9\\u30d9\\u30eb\\u3001\\u30e9\\u30d9\\u30e9\\u30fc\\u4e21\\u65b9\\u306b\\u3064\\u3044\\u3066\\u306e\\u3054\\u8cea\\u554f\\u3001\\u3054\\u8981\\u671b&quot;:&quot;\\u30e9\\u30d9\\u30eb\\u3001\\u30e9\\u30d9\\u30e9\\u30fc\\u4e21\\u65b9\\u306b\\u3064\\u3044\\u3066\\u306e\\u3054\\u8cea\\u554f\\u3001\\u3054\\u8981\\u671b&quot;,&quot;\\u305d\\u306e\\u4ed6\\u4e00\\u822c\\u7684