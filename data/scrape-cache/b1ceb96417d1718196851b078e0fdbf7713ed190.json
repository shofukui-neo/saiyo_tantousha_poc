oscript>\n<!-- End Google Tag Manager (noscript) -->\n<div id=\"page\" class=\"page\">\n<header class=\"header\" id=\"header\">\n<a class=\"header__logo\" href=\"../\"><img src=\"../common/img/logo.svg\" alt=\"総合厨房機器メーカー 株式会社中西製作所\"></a>\n<nav class=\"gnav\" id=\"gnav\">\n<button class=\"gnav-btn\" id=\"gnav-btn\" aria-controls=\"gnav-panel\" aria-expanded=\"false\" aria-label=\"メインメニュー\"><span class=\"gnav-btn__icon\"></span><span class=\"gnav-btn__label\">MENU</span></button>\n<div class=\"gnav-panel\" id=\"gnav-panel\"></div>\n</nav>\n</header>\n\n<div id=\"content\">\n<main>\n<div class=\"page-header\">\n<div class=\"page-mv prlx\" data-rellax-speed=\"-7\"></div>\n<div class=\"page-title\">\n<div class=\"page-title__main\">お知らせ</div>\n<div class=\"page-title__sub\">Information</div>\n</div>\n<div class=\"breadcrumbs\">\n<ul>\n<li><a href=\"../\">HOME</a></li>\n<li><a href=\"./\">お知らせ</a></li>\n<li>タイ「ProPak Asia 2026」出展のお知らせ</li>\n</ul>\n</div>\n<!-- /.page-header --></div>\n\n<div class=\"page-container article\">\n<div class=\"container container--narrow\">\n<h1 class=\"article__title\">タイ「ProPak Asia 2026」出展のお知らせ</h1>\n<div class=\"article__tags\">\n<a href=\"tag.html?tag=展示会出展\" class=\"tag\">展示会出展</a>\n<a href=\"tag.html?tag=海外展開\" class=\"tag\">海外展開</a>\n</div>\n<p class=\"article__date\">2026年05月11日</p>\n\n<div class=\"article__body\">\n<!-- ===========本文エリアここから=========== -->\n\r\n\r\n<div class=\"unit-text\">\r\n<span style=\"font-size:14px;\">この度、中西製作所は6月10日(水)～13日(土)まで、タ<span style=\"line-height:115%\"><span style=\"line-height:115%\"><span biz=\"\" udp=\"\">イ・バンコクで開催される、製造加工・包装関係のアジア最大級の国際トレードショー「ProPak Asia 2026」に出展します。</span></span></span></span><br />\r\n<br />\r\n<span style=\"font-size:10.5pt\"><span style=\"line-height:115%\"><span style=\"line-height:115%\"><span biz=\"\" udp=\"\">深刻な人手不足が続く世界の飲食現場に対し、日本の「おにぎり」を通じた体験型展示で、独自の過熱水蒸気調理機「SVロースター」を提案。また、麺類の計量、盛付け作業を自動化し、生産効率を大幅に向上させる、「茹麺計量盛付ロボット(計麺)」の実演稼働も行います。</span></span></span></span>\r\n</div>\r\n<div class=\"unit-heading\">\r\n<h2>ProPAK Asiaとは</h2>\r\n</div>\r\n<div class=\"unit-text\">\r\nタイのバンコクで毎年6月に開催される、<b data-index-in-node=\"19\" data-path-to-node=\"3\">アジア最大級の製造加工・包装技術に関する国際展示会</b>です。食品、飲料、医薬品、化粧品など幅広い分野の製造ラインにおける最新テクノロジーが一堂に会します。\r\n</div>\r\n<div class=\"unit-heading\">\r\n<h2>開催概要</h2>\r\n</div>\r\n<div class=\"unit-text\">\r\n<p><span style=\"font-size:16px;\"><strong>■ 開催日時</strong><br />\r\n2026年6月10日(水)～13日(土)</span><br />\r\n<br />\r\n<span style=\"font-size:16px;\"><strong>■ 会　場 / ブース番号</strong><br />\r\nIMPACT CHALLENGER HALL<br />\r\n<br />\r\n<strong>■公式サイトは<a href=\"https://www.propakasia.com/ppka/2026/en/index.asp\">こちら</a></strong></span></p>\r\n\r\n</div>\r\n\n\n<!-- ===========本文エリアここまで=========== -->\n<!-- /.article__body --></div>\n\n<aside class=\"article__related\">\n\n</aside>\n<!-- /.container --></div>\n<!-- /.page-container --></div>\n</main>\n<!-- /#content --></div>\n\n<footer class=\"footer\" id=\"footer\">\n<div id=\"pagetop\"><a href=\"#top\">ページトップ</a></div>\n<div id=\"fnav\"></div>\n<div class=\"footer__lower\">\n<div class=\"footer-logo\"><img src=\"../common/img/logo2.svg\" alt=\"株式会社中西製作所\"></div>\n<div class=\"footer-copyright\">&copy; NAKANISHI MFG. CO., LTD. ALL RIGHTS RESERVED.</div>\n</div>\n</footer>\n<!-- /#page --></div>\n\n<script src=\"https://code.jquery.com/jquery-3.3.1.min.js\" integrity=\"sha256-FgpCb/KJQlLNfOu91ta32o/NMZxltwRo8QtmkMRdAu8=\" crossorigin=\"anonymous\"></script>\n<script>window.jQuery || document.write('<script src=\"../common/js/vendor/jquery-3.3.1.min.js\"><\\/script>')</script>\n<script src=\"../common/js/vendor/rellax/rellax.min.js\"></script>\n<script src=\"../common/js/init.js\"></script>\n<!-- ページ先読みscript -->\n<script src=\"//instant.page/1.1.0\" type=\"module\" integrity=\"sha384-EwBObn5QAxP8f09iemwAJljc+sU+eUXeL9vSBw1eNmVarwhKk2F9vBEpaN9rsrtp\"></script>\n</body>\n</html>\n","finalUrl":"https://www.nakanishi.co.jp/information/20260415093321.html","rendered":false,"_cachedAt":"2026-06-23T17:36:34.940Z"}