{"url":"https://www.honyakuctr.com/inquiry/translator/","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>サービス以外に関するお問い合わせ | 株式会社翻訳センター</title>\n<meta name=\"description\" content=\"医薬、特許、工業、金融・法務分野に特化した翻訳を提供している国内最大規模の産業翻訳サービス企業、翻訳センターのその他全般のお問い合わせページです。\" />\n<meta name=\"keywords\" content=\"\" />\n<!-- iPhoneファビコン設定用 -->\n<link rel=\"apple-touch-icon\" href=\"/favicon/favicon_logo_180.png\" sizes=\"180x180\">\n<!-- iPhoneファビコン設定用ここまで -->\n<!-- Androidファビコン設定用 -->\n<link rel=\"icon\" type=\"image/png\" href=\"/favicon/favicon_logo_192.png\" sizes=\"192x192\">\n<link rel=\"icon\" type=\"image/png\" href=\"/favicon/favicon_logo_512.png\" sizes=\"512x512\">\n<!-- Androidファビコン設定用ここまで -->\n<!-- SVGファビコン設定用 -->\n<link rel=\"icon\" type=\"image/svg+xml\" href=\"/favicon/favicon_logo.svg\">\n<!-- SVGファビコン設定用ここまで -->\n<link rel=\"shortcut icon\" type=\"image/ico\" href=\"/favicon.ico\">\n<!--[if lt IE 9]>\n<script type=\"text/javascript\" src=\"/js/IE9.js\"></script>\n<script type=\"text/javascript\" src=\"/js/css3-mediaqueries.js\"></script>\n<![endif]-->\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/_mtadmin/mt-static/plugins/AForm/style.css\" />\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/_mtadmin/mt-static/plugins/AForm/jquery-ui.min.css\" />\n<link rel=\"stylesheet\" href=\"/_mtadmin/mt-static/plugins/AForm/theme/theme01.css\" type=\"text/css\" />\n<link rel=\"canonical\" href='https://www.honyakuctr.com/inquiry/general/'>\n\n\n\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/css/form_default.css\" />\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/css/form_common.css\" />\n<!-- <script type=\"text/javascript\" src=\"https://ajax.googleapis.com/ajax/libs/jquery/1.12.4/jquery.min.js\"></script> -->\n<script type=\"text/javascript\" src=\"https://ajax.googleapis.com/ajax/libs/jquery/1.12.4/jquery.min.js\"></script>\n<script type=\"text/javascript\" src=\"/js/jquery.easing.1.3.js\"></script>\n<style>\n/* JSオフ表示 */\n.js_off{\n\twidth: 95%;\n\ttext-align: center;\n\tcolor: #333;\n\tmargin-top: 30px;\n\tpadding: 20px;\n\tbackground: #fbfce5;\n    border: solid 2px #ff3333;\n    border-radius: 2px;\n}\n\n@media screen and (max-width:768px) {\n.js_off{\n\twidth: 90%;\n\ttext-align: center;\n\tcolor: #333;\n\tmargin-top: 30px;\n\tpadding: 20px;\n\tbackground: #fbfce5;\n    border: solid 2px #ff3333;\n    border-radius: 2px;\n\t}\n}\n</style>\n<script>\n$(function () {\n      // URLを取得\n      const currentUrl = window.location.href;\n      console.log(currentUrl);\n      if (currentUrl) {\n          const url = new URL(currentUrl);\n          const placeParam = url.searchParams.get(\"place\");\n          // パラメータが存在すれば input に値をセット\n          if (placeParam) {\n              if (placeParam === \"freelance\"){\n\t\t\t\tconst select = document.getElementById(\"INQUIRY_GEN_TYPE\");\n\t\t\t\tif (select) select.value = \"4\";\n              }\n          }\n      }\n});\n</script>\n<!-- Google Tag Manager -->\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n})(window,document,'script','dataLayer','GTM-M4N5D4J');</script>\n<!-- End Google Tag Manager -->\n</head>\n<body>\n<!-- Google Tag Manager (noscript) -->\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-M4N5D4J\"\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n<!-- End Google Tag Manager (noscript) -->\n<div id=\"wrapper\">\n\t<div id=\"header_wrap\">\n\t\t<div id=\"header\">\n\t\t\t<div class=\"logo\"><a href=\"/\" target=\"_blank\" rel=\"noopener\"><img src=\"/images/form/logo.jpg\" width=\"182\" height=\"64\" alt=\"翻訳センター\" /></a></div>\n\t\t</div>\n\t\t<!-- #header -->\n\t</div>\n\t<!-- #header -->\n\t<div id=\"article\">\n\n\t\t<noscript>\n\t\t<div class=\"js_off\">\n\t\t\t<p>JavaScriptが無効となっています。ご利用のブラウザでJavaScriptをオンにしてからご利用ください。</p>\n\t\t</div>\n\t\t</noscript>\n\n\t\t<div class=\"title_wrap\">\n\t\t\t<h1 class=\"title\">サービス以外に関するお問い合わせ</h1>\n\t\t</div>\n\n\t<div class=\"description\">\n\t\t<p>本フォームでは、当社サービス以外（企業情報・IR、登録関連など）のお問い合わせを受け付けております。<br>お送りいただいたお問い合わせには順次対応いたしますが、お問い合わせが混み合っている場合は2～3営業日お時間をいただく場合もございます。あらかじめご了承ください。</p>\n    \t<p>※サービスに関するお問い合わせは <a href=\"/inquiry/service/\">こちら</a> から受け付けております。</p>\n\t</div>\n\n\t\t\n\t\t<script type=\"text/javascript\">\n<!--\naform = new Object;\naform.id = '4';\naform.logger_url = 'https://www.honyakuctr.com/confirm/aform_logger.cgi';\naform.checker_url = 'https://www.honyakuctr.com/confirm/aform_checker.cgi';\naform.phrases = {\"Input error:\": \"入力エラー:\"};\naform.static_uri = '/_mtadmin/mt-static/';\naform.require_ajax_check = '';\naform.is_active = 'published';\naform.check_immediate = '1';\naform.parameters = new Object;\naform.datepickers = new Object;\naform.relations = new Object;\naform.relations = {}\naform.payment = { parts_id: '', field_id: '', methods: {} };\naform.recaptcha = new Object;\naform.pages = [{\"next\":null,\"parts_id\":[\"INQUIRY_GEN_TYPE\",\"INQUIRY_GEN_TEXT\",\"INQUIRY_GEN_NAME\",\"INQUIRY_GEN_KANA\",\"INQUIRY_GEN_COMPANY\",\"INQUIRY_GEN_EMAIL\",\"INQUIRY_GEN_TEL\",\"INQUIRY_GEN_POLICY\",\"INQUIRY_GEN_SALES\"],\"prev\":null}];\naform.auto_status = '1';\naform.enabled_report = parseInt('0');\n//-->\n</script>\n\n\n  <script src=\"/_mtadmin/mt-static/plugins/AForm/js/zenhanconv.js\" type=\"text/javascript\"></script>\n\n\n\n\n\n\n<div id=\"aform-4\" class=\"aform ja\">\n<div class=\"aform-header\">サービス以外に関するお問い合わせ</div>\n<div class=\"aform-checking\" style=\"display:none;\">フォームの状態を確認しています...</div>\n<div class=\"aform-content\">\n\n<form enctype=\"multipart/form-data\" name=\"aform-form-4\" id=\"aform-form-4\" method=\"post\" action=\"https://www.honyakuctr.com/confirm/aform_engine.cgi?form_id=4\"  novalidate=\"novalidate\" >\n    <input type=\"hidden\" name=\"blog_id\" value=\"1\" />\n    <input type=\"hidden\" name=\"id\" value=\"4\" />\n    <input type=\"hidden\" name=\"run_mode\" value=\"confirm\" />\n    <input type=\"hidden\" name=\"aform_url\" value=\"\" />\n    <input type=\"hidden\" name=\"aform_path\" value=\"\" />\n    <input type=\"hidden\" name=\"entry_id\" value=\"\" />\n    \n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n  \n  <div\n        class=\"aform-input aform-hdln INQUIRY_GEN_HEADING01\">お問い合わせ内容のご入力</div>\n\n\n\n\n\n<dl class=\"dl_INQUIRY_GEN_TYPE\">\n  <dt><label for=\"INQUIRY_GEN_TYPE\" class=\"aform-label INQUIRY_GEN_TYPE\">お問い合わせ項目<span class=\"aform-required\">必須</span></label>\n  </dt>\n  <dd>\n      <select \n        id=\"INQUIRY_GEN_TYPE\"\n        class=\"aform-input aform-select INQUIRY_GEN_TYPE aform-validate validate-selection\" \n        name=\"aform-field-79\"\n        required\n        title=\"選択してください\"><option value=\"\">選択してください</option><option value=\"1\">会社概要</option><option value=\"2\">業務内容</option><option value=\"3\">当社IR情報</option><option value=\"4\">フリーランス登録</option><option value=\"5\">その他</option></select>\n      <div class=\"aform-error INQUIRY_GEN_TYPE\" id=\"INQUIRY_GEN_TYPE-error\"></div></dd>\n</dl>\n\n\n\n\n\n<dl class=\"dl_INQUIRY_GEN_TEXT\">\n  <dt><label for=\"INQUIRY_GEN_TEXT\" class=\"aform-label INQUIRY_GEN_TEXT\">お問い合わせ内容<span class=\"aform-required\">必須</span></label>\n  </dt>\n  <dd>\n      <textarea \n        id=\"INQUIRY_GEN_TEXT\"\n        class=\"aform-input aform-textarea INQUIRY_GEN_TEXT aform-validate required\" \n        name=\"aform-field-80\" \n        cols=\"40\" \n        rows=\"6\" \n        placeholder=\"\"\n        \n        required\n        ></textarea>\n      <div class=\"aform-error INQUIRY_GEN_TEXT\" id=\"INQUIRY_GEN_TEXT-error\"></div></dd>\n</dl>\n\n\n\n\n\n  \n  <div\n        class=\"aform-input aform-hdln INQUIRY_GEN_HEADING02\">お客様情報のご入力</div>\n\n\n\n\n\n<dl class=\"dl_INQUIRY_GEN_NAME\">\n  <dt><label for=\"INQUIRY_GEN_NAME\" class=\"aform-label INQUIRY_GEN_NAME\">お名前<span class=\"aform-required\">必須</span></label>\n  </dt>\n  <dd><div class=\"aform-input-example INQUIRY_GEN_NAME\">例）翻訳　太郎</div>\n      <ul class=\"aform-name-ul\"><li><label for=\"INQUIRY_GEN_NAME-lastname\">姓</label>\n      <input \n        id=\"INQUIRY_GEN_NAME-lastname\"\n        class=\"aform-input aform-name INQUIRY_GEN_NAME validate-name aform-validate required\" \n        name=\"aform-field-82-lastname\" \n        type=\"text\" \n        \n        size=\"20\" \n        placeholder=\"\"\n        title=\"お名前(姓)を入力してください\"\n        \n        required\n         /></li><li><label for=\"INQUIRY_GEN_NAME-firstname\">名</label>\n      <input \n        id=\"INQUIRY_GEN_NAME-firstname\"\n        class=\"aform-input aform-name INQUIRY_GEN_NAME validate-name aform-validate required\" \n        name=\"aform-field-82-firstname\" \n        type=\"text\" \n        \n        size=\"20\" \n        placeholder=\"\"\n        title=\"お名前(名)を入力してください\"\n        \n        required\n         /></li></ul>\n      <div class=\"aform-error INQUIRY_GEN_NAME\" id=\"INQUIRY_GEN_NAME-lastname-error\"></div><div class=\"aform-error INQUIRY_GEN_NAME\" id=\"INQUIRY_GEN_NAME-firstname-error\"></div></dd>\n</dl>\n\n\n\n\n\n<dl class=\"dl_INQUIRY_GEN_KANA\">\n  <dt><label for=\"INQUIRY_GEN_KANA\" class=\"aform-label INQUIRY_GEN_KANA\">お名前（フリガナ）</label>\n  </dt>\n  <dd><div class=\"aform-input-example INQUIRY_GEN_KANA\">例）ホンヤク　タロウ</div>\n      <ul class=\"aform-kana-ul\"><li><label for=\"INQUIRY_GEN_KANA-lastname-kana\">セイ(カタカナ)</label>\n      <input \n        id=\"INQUIRY_GEN_KANA-lastname-kana\"\n        class=\"aform-input aform-kana INQUIRY_GEN_KANA aform-validate validate-name-kana\" \n        name=\"aform-field-83-lastname-kana\" \n        type=\"text\" \n         \n        size=\"20\" \n        placeholder=\"\"\n        title=\"お名前（フリガナ）(セイ)をカタカナで入力してください\"\n        \n        \n         /></li><li><label for=\"INQUIRY_GEN_KANA-firstname-kana\">メイ(カタカナ)</label>\n      <input \n        id=\"INQUIRY_GEN_KANA-firstname-kana\"\n        class=\"aform-input aform-kana INQUIRY_GEN_KANA aform-validate validate-name-kana\" \n        name=\"aform-field-83-firstname-kana\" \n        type=\"text\" \n         \n        size=\"20\" \n        placeholder=\"\"\n        title=\"お名前（フリガナ）(メイ)をカタカナで入力してください\"\n        \n        \n         /></li></ul>\n      <div class=\"aform-error INQUIRY_GEN_KANA\" id=\"INQUIRY_GEN_KANA-lastname-kana-error\"></div><div class=\"aform-error INQUIRY_GEN_KANA\" id=\"INQUIRY_GEN_KANA-firstname-kana-error\"></div></dd>\n</dl>\n\n\n\n\n\n<dl class=\"dl_INQUIRY_GEN_COMPANY\">\n  <dt><label for=\"INQUIRY_GEN_COMPANY\" class=\"aform-label INQUIRY_GEN_COMPANY\">法人名（団体名、事務所名）</label>\n  </dt>\n  <dd><div class=\"aform-input-example INQUIRY_GEN_COMPANY\">例）株式会社翻訳センター</div>\n      <input \n        id=\"INQUIRY_GEN_COMPANY\"\n        class=\"aform-input aform-text INQUIRY_GEN_COMPANY aform-validate\" \n        name=\"aform-field-84\" \n        type=\"text\" \n         \n        size=\"40\" \n        placeholder=\"\"\n        title=\"法人名（団体名、事務所名）を入力してください\"\n        \n        \n         />\n      <div class=\"aform-error INQUIRY_GEN_COMPANY\" id=\"INQUIRY_GEN_COMPANY-error\"></div></dd>\n</dl>\n\n\n\n\n\n<dl class=\"dl_INQUIRY_GEN_EMAIL\">\n  <dt><label for=\"INQUIRY_GEN_EMAIL\" class=\"aform-label INQUIRY_GEN_EMAIL\">メールアドレス<span class=\"aform-required\">必須</span></label>\n  </dt>\n  <dd><div class=\"aform-input-example INQUIRY_GEN_EMAIL\">例）honyaku.taro@honyakuctr.co.jp<br><em>※入力間違いがないか、必ずご確認ください。</em></div>\n      <input \n        id=\"INQUIRY_GEN_EMAIL\"\n        class=\"aform-input aform-email INQUIRY_GEN_EMAIL aform-validate hankaku validate-email required\" \n        name=\"aform-field-85\" \n        type=\"email\" \n         \n        size=\"40\" \n        placeholder=\"\"\n        title=\"メールアドレス(英数記号のみ)を入力してください 例）foo@example.com\"\n        required\n        \n         />\n      <div class=\"aform-error INQUIRY_GEN_EMAIL\" id=\"INQUIRY_GEN_EMAIL-error\"></div></dd>\n</dl>\n\n\n\n\n\n<dl class=\"dl_INQUIRY_GEN_TEL\">\n  <dt><label for=\"INQUIRY_GEN_TEL\" class=\"aform-label INQUIRY_GEN_TEL\">電話番号<span class=\"aform-required\">必須</span></label>\n  </dt>\n  <dd><div class=\"aform-input-example INQUIRY_GEN_TEL\">例）06-1234-5678</div>\n      <input \n        id=\"INQUIRY_GEN_TEL\"\n        class=\"aform-input aform-tel INQUIRY_GEN_TEL aform-validate hankaku validate-tel required\" \n        name=\"aform-field-86\" \n        type=\"tel\" \n         \n        size=\"40\" \n        placeholder=\"\"\n        title=\"電話番号(数字とハイフンのみ)を入力してください 例）03-1234-5678\"\n        required\n        \n         />\n      <div class=\"aform-error INQUIRY_GEN_TEL\" id=\"INQUIRY_GEN_TEL-error\"></div></dd>\n</dl>\n\n\n\n\n\n  \n  <div\n        class=\"aform-input aform-hdln INQUIRY_GEN_HEADING03\">同意事項</div>\n\n\n\n\n\n<dl class=\"dl_INQUIRY_GEN_POLICY\">\n  <dt><span class=\"aform-label INQUIRY_GEN_POLICY\">個人情報保護方針<span class=\"aform-required\">必須</span></span>\n  </dt>\n  <dd><div class=\"aform-input-example INQUIRY_GEN_POLICY\"><a href=\"/privacypolicy.html\" target=\"_blank\">個人情報保護方針</a></div>\n      <ul class=\"aform-checkbox-ul aform-field-88 INQUIRY_GEN_POLICY aform-vertical-ul\"><li><input\n            class=\"aform-input aform-checkbox INQUIRY_GEN_POLICY aform-validate validate-privacy\" \n            id=\"INQUIRY_GEN_POLICY-1\" \n            name=\"aform-field-88-1\"\n            type=\"checkbox\" \n            value=\"1\" \n            required\n            title=\"個人情報保護方針に同意してください。規約にご同意いただける場合チェックを入れてください（ご同意いただけない場合は送信できません）\" /><label for=\"INQUIRY_GEN_POLICY-1\">「個人情報保護方針」を確認し、記載されている内容について同意しました。</label></li></ul>\n      <div class=\"aform-error INQUIRY_GEN_POLICY\" id=\"INQUIRY_GEN_POLICY-error\"></div></dd>\n</dl>\n\n\n\n\n\n<dl class=\"dl_INQUIRY_GEN_SALES\">\n  <dt><span class=\"aform-label INQUIRY_GEN_SALES\">その他同意事項<span class=\"aform-required\">必須</span></span>\n  </dt>\n  <dd>\n      <ul class=\"aform-checkbox-ul aform-field-89 INQUIRY_GEN_SALES aform-vertical-ul\"><li><input\n            class=\"aform-input aform-checkbox INQUIRY_GEN_SALES aform-validate validate-privacy\" \n            id=\"INQUIRY_GEN_SALES-1\" \n            name=\"aform-field-89-1\"\n            type=\"checkbox\" \n            value=\"1\" \n            required\n            title=\"その他同意事項に同意してください。規約にご同意いただける場合チェックを入れてください（ご同意いただけない場合は送信できません）\" /><label for=\"INQUIRY_GEN_SALES-1\">セールスではありません。</label></li></ul>\n      <div class=\"aform-error INQUIRY_GEN_SALES\" id=\"INQUIRY_GEN_SALES-error\"></div></dd>\n</dl>\n\n\n\n\n\n\n\n\t<div class=\"aform-button-area\"><input id=\"aform_btn_confirm_4\" type=\"submit\" name=\"Submit\" value=\"確認\" /></div>\n\n\n</form>\n\n\n\n\n</div>\n</div>\n  \n\n</div>\n\t<div id=\"footer_wrap\">\n\t\t<div id=\"footer\">\n\t\t\t<p class=\"copyright\"><img src=\"/images/form/text_copyright.jpg\" width=\"121\" height=\"15\" alt=\"©Honyaku Center Inc.\" /></p>\n\t\t</div>\n\t\t<!-- #footer -->\n\t</div>\n\t<!-- #footer_wrap -->\n\n</div>\n<!-- #wrapper -->\n\n<script type=\"text/javascript\" language=\"javascript\">\n/* <![CDATA[ */\nvar yahoo_retargeting_id = 'JS8GYMN4UK';\nvar yahoo_retargeting_label = '';\n/* ]]> */\n</script>\n<script type=\"text/javascript\" language=\"javascript\" src=\"//b92.yahoo.co.jp/js/s_retargeting.js\"></script>\n<script src=\"https://www.honyakuctr.com/_mtadmin/mt-static/plugins/AForm/js/jquery.validate.js?t=20260408091527\" type=\"text/javascript\"></script>\n<script src=\"https://www.honyakuctr.com/_mtadmin/mt-static/plugins/AForm/js/js.cookie.min.js?t=20260408091527\" type=\"text/javascript\"></script>\n<script type=\"text/javascript\">jQuery.query = { numbers: false };</script>\n<script src=\"https://www.honyakuctr.com/_mtadmin/mt-static/plugins/AForm/js/jquery.query-object.js?t=20260408091527\" type=\"text/javascript\"></script>\n<script src=\"https://www.honyakuctr.com/_mtadmin/mt-static/plugins/AForm/js/jquery-ui.min.js?t=20260408091527\" type=\"text/javascript\"></script>\n\n<script src=\"https://www.honyakuctr.com/_mtadmin/mt-static/plugins/AForm/js/aform.js?t=20260408091527\" type=\"text/javascript\"></script>\n\n</body>\n</html>\n","finalUrl":"https://www.honyakuctr.com/inquiry/general/?place=freelance","rendered":false,"_cachedAt":"2026-06-22T17:30:32.864Z"}