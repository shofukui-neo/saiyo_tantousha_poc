" method=\"post\" class=\"h-adr\">\n        <div class=\"form-content\" id=\"entry-form\">\n          <ol class=\"form-step\">\n            <li class=\"-current\">\n              <!-- <span class=\"en\">Input</span> -->\n              <span class=\"ja\">ご入力</span>\n            </li>\n            <li>\n              <!-- <span class=\"en\">Confirm</span> -->\n              <span class=\"ja\">入力内容のご確認</span>\n            </li>\n            <li>\n              <!-- <span class=\"en\">Submit</span> -->\n              <span class=\"ja\">送信完了</span>\n            </li>\n          </ol>\n          \n<div class=\"form-row\">\n\t<label class=\"form-col\" for=\"category\">エントリー種別 <span class=\"required\">必須</span></label>\n\t<div class=\"form-col radio-button-wrap\">\n\t\t<input id=\"category-radio1\" type=\"radio\" name=\"category[]\" value=\"新卒採用\">\n\t\t<label class=\"radio-button\" for=\"category-radio1\">新卒採用</label>\n\t\t<input type=\"hidden\" name=\"field[]\" value=\"category\">\n\t\t<input type=\"hidden\" name=\"category:v#required\">\n\t\t\n\t</div>\n</div>\n\n<div class=\"form-row\">\n\t<label class=\"form-col\" for=\"name\">お名前 <span class=\"required\">必須</span></label>\n\t<div class=\"form-col\">\n\t\t<input id=\"name\" type=\"text\" name=\"name\" value=\"\" placeholder=\"例）建設 太郎\" class=\"text-field \" />\n\t\t<input type=\"hidden\" name=\"field[]\" value=\"name\" />\n\t\t<input type=\"hidden\" name=\"name:v#required\" />\n\t\t<input type=\"hidden\" name=\"name:c\" value=\"KV\" />\n\t\t\n\t</div>\n</div>\n\n<div class=\"form-row\">\n\t<label class=\"form-col\" for=\"furigana\">フリガナ <span class=\"required\">必須</span></label>\n\t<div class=\"form-col\">\n\t\t<input id=\"furigana\" type=\"text\" name=\"furigana\" value=\"\" placeholder=\"例）ケンセツ タロウ\" class=\"text-field \" />\n\t\t<input type=\"hidden\" name=\"field[]\" value=\"furigana\" />\n\t\t<input type=\"hidden\" name=\"furigana:v#required\" />\n\t\t<input type=\"hidden\" name=\"furigana:c\" value=\"KV\" />\n\t\