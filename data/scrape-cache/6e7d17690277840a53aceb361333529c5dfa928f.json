>\n            <input type=\"hidden\" name=\"ie\" value=\"UTF-8\">\n            <input type=\"hidden\" name=\"oe\" value=\"UTF-8\">\n            <input type=\"hidden\" value=\"alp-grp.jp\" name=\"as_sitesearch\" />\n</form>\n</nav>\n</header>\n<style type=\"text/css\">\n</style>\n\n\t<script>\n\t(function($) {\n\t    $(function() {\n\t        var $header = $('#top-head');\n\t        // Nav Fixed\n\t        $(window).scroll(function() {\n\t            if ($(window).scrollTop() > 250) {\n\t                $header.addClass('fixed');\n\t            } else {\n\t                $header.removeClass('fixed');\n\t                \n\t                \t            }\n\t        });\n\t    });\n\t})(jQuery);\n\t</script>\n<div id=\"top-head\" class=\"head2\">\n\n\t<nav class=\"nav-horizontal blue\" role=\"navigation\">\n\t<div class=\"mask\">\n\t<ul class=\"list blue\">\n\t<li><a href=\"./recruit.html\" class=\"long15\">採用情報に戻る</a></li>\n\t<li><a href=\"#sc01\">募集要項</a></li>\n\t<li><a href=\"#sc02\">薬剤師</a></li>\n\t<!--<li><a href=\"#sc03\" class=\"long1\">臨床検査技師</a></li>-->\n\t<li><a href=\"#sc05\">営業</a></li>\n\t<li><a href=\"#sc06\">パート</a></li>\n\t</ul>\n\t</div>\n\t</nav>\n</div>\n\n<div id=\"content\" class=\"page\"> \n<div class=\"page-01 saiyou\">\n\n<div class=\"recruit-bt\"><br /><br />\n<img src=\"./img/01-recruit/recruit-017.jpg\" width=\"250\" alt=\"中途採用\" /><span class=\"recruit-bt3\"><a href=\"./contact-recruit2.html\">エントリー</a></span>\n</div>\n\n\n<div id=\"sc01\">\n<h3><span style=\"color: #7ecef4\">●</span> 募集要項【正社員】</h3>\n\n\n\n</div>\n\n<div id=\"sc02\">\n<h4><span style=\"color: #e60012\">●</span> 薬剤師</h4>\n<table>\n<tbody>\n<tr><th width=\"25%\">主な仕事内容</th><td>調剤薬局での服薬指導・調剤・監査・薬歴管理等、店舗運営の全般</td></tr>\n<tr><th>応募資格</th><td>薬剤師国家資格保有者</td></tr>\n<tr><th>給与</th><td>委細面談</td></tr>\n<tr><th>勤務地</th><td>石川県、富山県、福井県</td></tr>\n</tbody>\n</table>\n</div>\n\n<!--\n\n\n<div id=\"sc03\">\n<h4><span style=\"color: #e60012\">●</span> 臨床検査技師</h4>\n<table>\n<tbody>\n<tr><th width=\"25%\">主な仕事内容</th><td>臨床検査業務全般</td></tr>\n<tr><th>応募資格</th><td>臨床検査技師国家資格保有者</td></tr>\n<tr><th>給与</th><td>委細面談</td></tr>\n<tr><th>勤務地</th><td>石川県</td></tr>\n</tbody>\n</table>\n</div>\n\n<!--\n\n\n<div id=\"sc05\">\n<h4><span style=\"color: #e60012\">●</span> ルート営業（検査物の集配）</h4>\n<table>\n<tbody>\n<tr><th width=\"25%\">主な仕事内容</th><td>医療機関を訪問し、検査物の集配業務</td></tr>\n<tr><th>応募資格</th><td>普通自動車免許</td></tr>\n<tr><th>給与</th><td>委細面談</td></tr>\n<tr><th>勤務地</th><td>富山市</td></tr>\n</tbody>\n</table> \n\n\n\n<h4><span style=\"color: #e60012\">●</span> ルート営業（検査物の集配）食品環境検査部門</h4>\n<table>\n<tbody>\n<tr><th width=\"25%\">主な仕事内容</th><td>食品製造業、外食産業、小売業等の食品検査物の集配業務</td></tr>\n<tr><th>応募資格</th><td>普通自動車免許</td></tr>\n<tr><th>給与</th><td>委細面談</td></tr>\n<tr><th>勤務地</th><td>本社</td></tr>\n</tbody>\n</table> -->\n <!--\n\n<h4><span style=\"color: #e60012\">●</span> 受付事務（調剤薬局）</h4>\n<table>\n<tbody>\n<tr><th width=\"25%\">主な仕事内容</th><td>調剤薬局での受付、接客、医療事務、薬剤師のサポート等</td></tr>\n<tr><th>応募資格</th><td>普通自動車免許</td></tr>\n<tr><th>給与</th><td>委細面談</td></tr>\n<tr><th>勤務地</th><td>福井県（西谷店、丸岡店、かすみ店）</td></tr>\n</tbody>\n</table> -->\n\n<h4><span style=\"color: #e60012\">●</span> その他待遇（共通）</h4>\n<table>\n<tbody>\n<tr><th width=\"25%\">諸手当</th><td>時間外、通勤、役職手当、その他</td></tr>\n<tr><th>昇給</th><td>年1回</td></tr>\n<tr><th>賞与</th><td>年2回 5.0ヶ月</td></tr>\n<tr><th>勤務時間</th><td>変形労働時間制(週40時間労働)<br />9:00～18:00を基本に、早番遅番交代制の8時間勤務</td></tr>\n<tr><th>休日休暇</th><td>週休2日制(日・月～土の1日/当社カレンダーによる交替制)※祝日のある週は日・祝日が休み<br />夏季、年末年始、年次有給、慶弔、特別、年間休日112日</td></tr>\n<tr><th>保険</th><td>各種社会保険完備</td></tr>\n<tr><th>福利厚生</th><td>ベネフィットステーション、積立NISA、会員制リゾートホテル等の各種制度</td></tr>\n<tr><th>教育制度</th><td>新入社員研修、その他階層別に研修を実施</td></tr>\n<tr><th>提出書類</th><td>履歴書</td></tr>\n</tbody>\n</table>\n\n<div id=\"sc06\">\n\n<h3><span style=\"color: #7ecef4\">●</span> 募集要項【パート】</h3>\n\n<!-- <p>※現在、パートの募集は行っておりません。</p> -->\n\n<h4><span style=\"color: #e60012\">●</span> 薬剤師</h4>\n<table>\n<tbody>\n<tr><th width=\"25%\">主な仕事内容</th><td>調剤薬局での服薬指導・調剤・監査・薬歴管理等、店舗運営の全般</td></tr>\n<tr><th>応募資格</th><td>薬剤師国家資格保有者</td></tr>\n<tr><th>給与</th><td>時給：1,900円〜2,300円</td></tr>\n<tr><th>勤務地</th><td>石川県、富山県、福井県</td></tr>\n</tbody>\n</table>\n\n<!--\n<h4><span style=\"color: #e60012\">●</span> 臨床検査技師</h4>\n<table>\n<tbody>\n<tr><th width=\"25%\">主な仕事内容</th><td>臨床検査業務全般</td></tr>\n<tr><th>応募資格</th><td>臨床検査技師国家資格保有者</td></tr>\n<tr><th>給与</th><td>時給：1,200円〜</td></tr>\n<tr><th>勤務地</th><td>石川県</td></tr>\n</tbody>\n</table>-->\n\n<!--\n\n<h4><span style=\"color: #e60012\">●</span> ルート営業（検査物の集配）</h4>\n<table>\n<tbody>\n<tr><th width=\"25%\">主な仕事内容</th><td>医療機関を訪問し、検査物の集配業務</td></tr>\n<tr><th>応募資格</th><td>普通自動車免許</td></tr>\n<tr><th>給与</th><td>時給930円</td></tr>\n<tr><th>勤務地</th><td>月～土　9：15～14：15（休憩なし）</td></tr>\n<tr><th>勤務地</th><td>石川県（小松営業所）</td></tr>\n</tbody>\n</table> \n\n\n\n<h4><span style=\"color: #e60012\">●</span> 検査補助（臨床検査部門）</h4>\n<table>\n<tbody>\n<tr><th width=\"25%\">主な仕事内容</th><td>培地作成、試験管洗浄などの医学的臨床検査の補助業務</td></tr>\n<tr><th>応募資格</th><td>普通自動車免許</td></tr>\n<tr><th>給与</th><td>時給880円</td></tr>\n<tr><th>勤務地</th><td>月～金　9：00～13：00</td></tr>\n<tr><th>勤務地</th><td>本社</td></tr>\n</tbody>\n</table>\n\n\n-->\n<style>\nh3 {margin-bottom: -20px !important;}\n</style>\n\n<h3><span style=\"color: #7ecef4\">●</span><span style=\"color: #e60012\">連絡先・書類提出先</span></h3>\n<p>〒920-8217　石川県金沢市近岡町309番地<br />\nTEL.076-237-3104<br />\n管理部人事課　長浜 潤</p>\n\n</div>\n</div>\n<div class=\"clear\"></div>\n\n\n<script>\n$(function(){\n   // #で始まるアンカーをクリックした場合に処理\n   $('a[href^=#]').click(function() {\n      // スクロールの速度\n      var speed = 400; // ミリ秒\n      // アンカーの値取得\n      var href= $(this).attr(\"href\");\n      // 移動先を取得\n      var target = $(href == \"#\" || href == \"\" ? 'html' : href);\n      // 移動先を数値で取得\n      var position = target.offset().top;\n      // スムーススクロール\n      $('body,html').animate({scrollTop:position}, speed, 'swing');\n      return false;\n   });\n});\n</script>\n \t\n\n  \n      \n</div>\n\n<div class=\"side-sns\">\n<!--<p class=\"sid