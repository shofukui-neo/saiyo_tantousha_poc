y WP Statistics - https://wp-statistics.com -->\n\n<link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/Swiper/7.3.3/swiper-bundle.min.css\" />\n\t\n</head>\n<body class=\"wp-singular page-template-default page page-id-336 page-child parent-pageid-25 wp-theme-whitestudio requirments-career\">\n    <!-- ヘッダー -->\n\t<header class=\"top-head-ex\">\n\t\t<!-- ヘッダー中身 -->\n\t\t<div class=\"top-head-ex-gird\">\n\t\t\t<a href=\"https://hoshizaki-keihan.co.jp/\">\n\t\t\t\t<img src=\"https://hoshizaki-keihan.co.jp/wp/wp-content/themes/whitestudio/images/common/img-logo.png\" alt=\"京阪ロゴ\">\n\t\t\t</a>\n\t\t\t<div class=\"header-menu-pc-grid-2\">\n\t\t\t\t<a href=\"#footer\" class=\"map\">サイトマップ</a>\n\t\t\t\t<a href=\"https://hoshizaki-keihan.co.jp/company\">企業情報</a>\n\t\t\t\t<a href=\"https://hoshizaki-keihan.co.jp/location\">営業所一覧</a>\n\t\t\t\t<a href=\"https://hoshizaki-keihan.co.jp/toiawase\">お問い合わせ</a>\n\t\t\t\t<a href=\"https://hoshizaki-keihan.co.jp/recruite\" class=\"saiyo\">採用情報</a>\n\t\t\t\t\t\t\t\t\t\t\t<a href=\"https://job.mynavi.jp/27/pc/search/corp40189/outline.html\" target=\"_blank\" class=\"saiyo\">マイナビ2027</a>\n\t\t\t\t\t\t\t\t\t\t</div>\n\t\t\t<a href=\"#footer\" class=\"nav-bottom-link\">\n\t\t\t\t<div class=\"nav-bottom\"></div>\n\t\t\t\t<div class=\"nav-bottom\"></div>\n\t\t\t\t<div class=\"nav-bottom\"></div>\n\t\t\t\t<p>Menu</p>\n\t\t\t</a>\n\t\t</div>\n\t\t<!-- / ヘッダー中身 -->\n\t</header>\n\t<!-- / ヘッダー -->\n    <div id=\"p_top\"></div>\n\t<main>\n<div class=\"sub-page-line\"></div>\n<div class=\"inner2\">\n\t<div class=\"sub-title-grid\">\n\t\t<div class=\"sub-title-grid-left\">\n\t\t\t<h1 class=\"sub-title\">募集要項 - キャリア<span>\n\t\t\t\tRequirments</span>\n\t\t\t</h1>\n\t\t</div>\n\t</div>\n</div>\n<?/*営業*/?>\n<div class=\"inner3 contena-tbl\">\n\t<section class=\"mb30 rec-car\">\n\t\t<h3 class=\"midashi-6 midashi-6-red\" id=\"eigy\">[ 募集要項・キャリア採用 ]</h3>\n\t\t<ul class=\"common-table-plink\">\n\t\t\t<li><a href=\"#eigy\">営業職 ></a></li>\n\t\t\t<li><a href=\"#service\">技術サービス職 ></a></li>\n\t\t\t<li><a href=\"#part\">パートタイマー　障がい者採用 ></a></li>\n\t\t</ul>\n\t\t<dl class=\"flextable-2\">\n\t\t\t<dt>募集職種</dt>\n\t\t\t<dd>営業職</dd>\n\t\t</dl>\n\t\t<section>\n\t\t\t<h4>[ 勤務 ]</h4>\n\t\t\t<dl class=\"flextable-2\">\n\t\t\t\t<dt>勤務地</dt><dd>大阪・京都・滋賀・奈良・和歌山のいずれかでの配属を予定しております</dd>\n\t\t\t\t<dt>勤務時間</dt><dd>9：00～17：50</dd>\n\t\t\t\t<dt>休日休暇</dt><dd>年間122日（2026年実績）<br>\n\t\t\t\t完全週休二日制（土日）・夏季休暇・年末年始休暇<br>\n\t\t\t\t有給休暇制度（半日・時間単位取得可）・産前産後休暇・介護休暇・特別有給<br>\n\t\t\t\t※年5日程度祝日出勤が発生します\n\t\t\t\t</dd>\n\t\t\t</dl>\n\t\t</section>\n\t\t<section>\n\t\t\t<h4>[ 待遇 ]</h4>\n\t\t\t<dl class=\"flextable-2\">\n\t\t\t\t<dt>給与</dt>\n\t\t\t\t<dd>\n\t\t\t\t\t◆月給267,590円～355,117円＋諸手当<br>\n\t\t\t\t\t月給には以下が含まれます。<br>\n\t\t\t\t\t・本給、職能給、地域手当、その他特別手当<br>\n\t\t\t\t\t・営業、技術手当※　53,890円～71,517円<br>\n\t\t\t\t\t※時間外労働の有無に関わらず、32時間分の時間外手当として支給いたします<br>\n\t\t\t\t\t32時間を超える時間外労働分についての割増賃金は別途支給いたします<br>\n\t\t\t\t\t※3ヶ月間の試用期間は営業サービス手当の支給はございません<br>\n\t\t\t\t\t残業代は別途支給となります<br>\n\t\t\t\t\t<br>\n\t\t\t\t\t<span class=\"bold\">【モデル年収】</span>\n\t\t\t\t\t年収490万円（入社4年目/32歳）<br>\n\t\t\t\t\t年収460万円（入社3年目/30歳　※配偶者有）\n\t\t\t\t</dd>\n\t\t\t\t<dt>諸手当</dt><dd>通勤手当（上限なし）、役付手当、家族手当、住宅手当、時間外手当</dd>\n\t\t\t\t<dt>賃金改定</dt><dd>年1回（4月）　5.0％（2026年実績）</dd>\n\t\t\t\t<dt>賞与</dt><dd>年2回（7月、12月）　7.1ヶ月（2025年実績）</dd>\n\t\t\t</dl>\n\t\t</section>\n\t\t<section>\n\t\t\t<h4>[ 応募資格 ]</h4>\n\t\t\t<dl class=\"flextable-2\">\n\t\t\t\t<dt>応募資格</dt><dd>35歳以下の男女（長期キャリア形成のため）</dd>\n\t\t\t\t<dt>募集職種</dt><dd>営業職</dd>\n\t\t\t\t<dt>学歴</dt><dd>不問</dd>\n\t\t\t\t<dt>応募方法</dt>\n\t\t\t\t<dd><a href=\"https://hoshizaki-keihan.co.jp/entryf\" target=\"_blank\">エントリーフォーム</a>よりご応募願います<br>\n\t\t\t\t\tご応募後、5営業日以内にご連絡させていただきます</dd>\n\t\t\t\t<dt>提出書類</dt><dd>履歴書・職務経歴書</dd>\n\t\t\t\t<dt>選考方法</dt><dd>(1次)　Web適性テスト　＋　事業部責任者　→　(2次)　Web適正テスト　＋　役員面接</dd>\n\t\t\t</dl>\n\t\t</section>\n\t\t<section>\n\t\t\t<h4>[ 採用受付 ]</h4>\n\t\t\t<dl class=\"flextable-2\">\n\t\t\t\t<dt>お問い合わせ先</dt>\n\t\t\t\t<dd>管理部　総務課　採用担当<br>\n