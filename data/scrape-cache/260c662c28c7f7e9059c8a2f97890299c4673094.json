     function gtag() { dataLayer.push(arguments); }\n      gtag('js', new Date());\n\n      gtag('config', 'G-M2C3PBSPC7');\n    </script>\n    <script type=\"application/ld+json\">\n  {\n\t\t\"@context\": \"http://schema.org\",\n\t\t\"@type\" : \"BreadcrumbList\",\n\t\t\"itemListElement\":[\n    \t\t                    {\n            \"@type\"   : \"ListItem\",\n            \"position\": \"1\",\n            \"item\"    : {\n                \"@id\" : \"https://www.dmre.daikin.co.jp/recruit/\",\n                \"name\": \"ダイキンMRエンジニアリング株式会社 採用サイト\"\n            }\n          },\n                    {\n            \"@type\"   : \"ListItem\",\n            \"position\": \"2\",\n          \"item\"    : {\n              \"@id\" : \"https://www.dmre.daikin.co.jp/recruit/career/\",\n              \"name\": \"キャリア採用\"\n          }\n        }\n\t\t]\n\t}\n\n</script>\n</head>\n<body>\n<div class=\"wrap\"><header class=\"header\">\n    <div class=\"header__main\">\n                    <a href=\"/recruit/\">\n                <p class=\"header__logo\"><picture class=\"\">\n    <source srcset=\"/recruit/common/img/logo.avif\" type=\"image/avif\">\n    <a href=\"https://www.dmre.daikin.co.jp/\"><img src=\"/recruit/common/img/logo.png\" alt=\"ダイキンMRエンジニアリング株式会社\" width=\"270\" height=\"77\" ></a>\n  </picture></p>\n                <p class=\"header__lead\">新卒採用サイト</p>\n            </a>\n            </div>\n    <div class=\"header__menu\"><button class=\"header__menu-btn js-menu\"><span class=\"header__menu-bar\"></span><span class=\"header__menu-txt\">MENU</span></button></div>\n    <nav class=\"header__nav\">\n        <ul class=\"header__nav-list\">\n            <li><a href=\"/recruit/\">採用トップ</a></li>\n            <li><a href=\"/recruit/business/\">事業概要</a></li>\n            <li><a href=\"/recruit/interview/people01/\">先輩社員インタビュー</a></li>\n            <li><a href=\"/recruit/message/\">社長メッセージ</a></li>\n            <li><a href=\"/recruit/training-welfare/\">研修制度・福利厚生</a></li>\n            <li><a href=\"https://www.dmre.daikin.co.jp/results/#sect1\" target=\"_blank\">プロジェクト事例</a></li>\n            <li><a href=\"/recruit/manager/people01/\">採用担当者から</a></li>\n        </ul>\n    </nav>\n    <div class=\"header-recruit\">\n        <button class=\"header-recruit__entry js-entry-btn\">\n            <span class=\"header-recruit__entry-txt\">新卒採用<br>エントリー</span>\n        </button>\n        <a href=\"/recruit/career/\" class=\"header-recruit__entry career\">\n            <p class=\"header-recruit__entry-txt\">キャリア採用は<br>こちら</p>\n        </a>\n        <a href=\"https://www.dmre.daikin.co.jp/contact/index.html\" target=\"_blank\" class=\"header-recruit__inquiry\">\n            <p class=\"header-recruit__inquiry-ja\">お問い合わせ</p>\n        </a>\n    </div>\n</header>\n\n\n<main class=\"main\">\n    <div class=\"main-wrap\">\n        <div class=\"career_content\">\n            <section class=\"career__wrap\">\n                <h1 class=\"career__title\"><span>キャリア採用</span></h1>\n                <figure class=\"career__img\">\n                    <picture class=\"\">\n    <source srcset=\"img/main_img.avif\" type=\"image/avif\">\n    <img src=\"img/main_img.jpg\" alt=\"\" width=\"678\" height=\"479\"  loading=\"lazy\">\n  </picture>\n                </figure>\n                <div class=\"career__table\">\n                    <div class=\"career__table_ttl_wrap\">\n                        <p class=\"career__table_tag\"><span class=\"table_tag\">募集職種</span></p>\n                        <h2 class=\"career__table_ttl\">フィールドエンジニア</h2>\n                    </div>\n                    <!--------職務内容-------->\n                    <section class=\"career__contents\">\n                        <div class=\"career__table_info_wrap\">\n                            <h3 class=\"career__table_sub_ttl\"><span class=\"underline blue\">職務内容</span></h3>\n                            <p class=\"career__table_info_lead\">業務内容は、船舶用の空調設備や冷凍装置の施工、メンテナンスです。<br>\n                                具体的には、冷凍・空調機器据え付け後、調整運転、性能試験を実施、顧客へ取扱説明を行っていただきます。<br>\n                                勤務地の東京支店には、４名（課長１名：40代、リーダー１名：30代、メンバー１名：20代、事務１名）が在籍しています。\n                            </p>\n                        </div>\n                        <div class=\"career__main\">\n                            <h4 class=\"career__table-head\">応募について</h4>\n                            <dl class=\"career__table_overview_wrap\">\n                                <div class=\"career__table_overview\">\n                                    <dt class=\"overview_ttl\">応募資格</dt>\n                                    <dd class=\"overview_detail\">①・②の、いずれかに該当される方<br>\n                                        ①工場での製造関連のご経験がある方<br>\n                                        ②設備施工のご経験がある方<br>\n                                        ※その他、何かしら造船関係の業務経験がある方を歓迎\n                                    </dd>\n                                </div>\n                                <div class=\"career__table_overview\">\n                                    <dt class=\"overview_ttl\">最終学歴</dt>\n                                    <dd class=\"overview_detail\">大学院、大学、短期大学、専修・各種学校、高等専門学校</dd>\n                                </div>\n                                <div class=\"career__table_overview\">\n                                    <dt class=\"overview_ttl\">選考方法</dt>\n                                    <dd class=\"overview_detail\">書類選考後、適性検査及び面接を行います。<br>1次面接はオンライン、2次面接は対面で実施します。</dd>\n                                </div>\n                                <div class=\"career__table_overview\">\n                                    <dt class=\"overview_ttl\">応募方法</dt>\n                                    <dd class=\"overview_detail\">件名「キャリア求人応募」と記載の上、履歴書を添付してメールしてください。<br>\n                                        【送付先】saiyo.dmre☆daikin.co.jp<br>\n                                        <span class=\"overview_notice\">※ご連絡の際は、☆を＠に変えてください</span></dd>\n                                </div>\n                            </dl>\n                        </div>\n                        <div class=\"career__main\">\n                            <h4 class=\"career__table-head\">勤務条件</h4>\n                            <dl class=\"career__table_overview_wrap\">\n                                <div class=\"career__table_overview\">\n                                    <dt class=\"overview_ttl\">勤務地</dt>\n                                    <dd class=\"overview_detail\">大阪本社<br>\n〒532-0011 大阪府大阪市淀川区西中島五丁目5番15号 新大阪セントラルタワー11階<br>\n東京オフィス<br>\n〒210-0005　神奈川県川崎市川崎区東田町11番地27メットライフ川崎ビル8階<br>\n中四国オフィス<br>\n〒729-0104　広島県福山市松永町4丁目3番5号\n\n                                        <br>\n\n                                    </dd>\n                                </div>\n                                <div class=\"career__table_overview\">\n                                    <dt class=\"overview_ttl\">受動喫煙対策</dt>\n                                    <dd class=\"overview_detail\">敷地内喫煙可能場所あり</dd>\n                                </div>\n                                <div class=\"career__table_overview\">\n                                    <dt class=\"overview_ttl\">転勤</dt>\n                                    <dd class=\"overview_detail\">有（当面は転勤を想定しておりませんが、組織変更による他地区への転勤の可能性があります。）<br>\n                                        今治、大阪、九州地方への転勤の可能性がございます。</dd>\n                                </div>\n\n                                <div class=\"career__table_overview\">\n                                    <dt class=\"overview_ttl\">昇給の有無</dt>\n                                    <dd class=\"overview_detail\">有</dd>\n                                </div>\n                                <div class=\"career__table_overview\">\n                                    <dt class=\"overview_ttl\">就業時間</dt>\n                                    <dd class=\"overview_detail\">8:00～17:00（所定労働時間：8時間、休憩：60分）</dd>\n                                </div>\n                                <div class=\"career__table_overview\">\n                                    <dt class=\"overview_ttl\">休日休暇</dt>\n                                    <dd class=\"overview_detail\">年間休日数：124日<br>\n                                        休日休暇形態：完全週休2日制(土日祝)<br>\n                                        年間有給休暇：10～21日（下限日数は、入社半年経過後の付与日数）<br>\n                                        夏季休暇、年末年始休暇（それぞれ平均8連休）</dd>\n                                </div>\n                                <div class=\"career__table_overview\">\n                                    <dt class=\"overview_ttl\">試用期間</dt>\n                                    <dd class=\"overview_detail\">有 （期間：6カ月）</dd>\n                                </div>\n                                <div class=\"career__table_overview\">\n                                    <dt class=\"overview_ttl\">雇用形態</dt>\n                                    <dd class=\"overview_detail\">正社員</dd>\n                                </div>\n                            </dl>\n                        </div>\n                        <div class=\"career__main\">\n                            <h4 class=\"career__table-head\">福利厚生</h4>\n                            <dl class=\"career__table_overview_wrap\">\n                                <div class=\"career__table_overview\">\n                                    <dt class=\"overview_ttl\">教育制度/資格補助</dt>\n                                    <dd class=\"overview_detail\">新入社員研修、リーダー研修、基幹職研修、資格取得支援</dd>\n                                </div>\n                                <div class=\"career__table_overview\">\n                                    <dt class=\"overview_ttl\">通勤手当</dt>\n                                    <dd class=\"overview_detail\">有　当社規定による</dd>\n                                </div>\n                                <div class=\"career__table_overview\">\n                                    <dt class=\"overview_ttl\">住宅手当</dt>\n                                    <dd class=\"overview_detail\">有　当社規定による</dd>\n                                </div>\n\n                                <div class=\"career__table_overview\">\n                                    <dt class=\"overview_ttl\">社会保険</dt>\n                                    <dd class=\"overview_detail\">健康保険、厚生年金、雇用保険、労災保険</dd>\n                                </div>\n                                <div class=\"career__table_overview\">\n                                    <dt class=\"overview_ttl\">その他</dt>\n                                    <dd class=\"overview_detail\">\n                                        <ul class=\"info_checklist\">\n                                            <li>産休/育児休業（取得実績あり）</li>\n                                            <li>保養所(ダイキングループ共通)</li>\n                                            <li>ダイキン工業と同一の退職年金制度</li>\n                                            <li>資格取得支援あり</li>\n                                            <li>有給休暇取得推進</li>\n                                        </ul>\n                                    </dd>\n                                </div>\n                                <div class=\"career__table_overview\">\n                                    <dt class=\"overview_ttl\">寮社宅</dt>\n                                    <dd class=\"overview_detail\">有　当社規定による</dd>\n                                </div>\n                                <div class=\"career__table_overview\">\n                                    <dt class=\"overview_ttl\">退職金制度</dt>\n                                    <dd class=\"overview_detail\">有　当社規定による</dd>\n                                </div>\n                            </dl>\n                        </div>\n                    </section>\n\n\n                </div>\n            </section>\n        </div>\n    </div>\n</main>\n<footer class=\"footer\">\n    <div class=\"footer__wrap\">\n        <div class=\"footer__info\">\n            <p class=\"footer__info_ttl\">ダイキンMRエンジニアリング株式会社</p>\n            <address class=\"footer__info_address\">大阪市淀川区西中島五丁目5番15号 新大阪セントラルタワー11階</address>\n            <dl class=\"footer__info_tel\">\n                <dt>tel</dt>\n                <dd>06-4805-7291</dd>\n                <dt>fax</dt>\n                <dd>06-4805-7321</dd>\n            </dl>\n            <p class=\"footer__info_mail\">e-mail:saiyo.dmre☆daikin.co.jp<br>\n                <span class=\"footer__info_notice\">※ご連絡の際は、☆を＠に変えてください</span></p>\n            <p class=\"footer__info_inquiry\"><a href=\"https://www.dmre.daikin.co.jp/contact/index.html\" target=\"_blank\">お問い合わせ</a></p>\n            <p class=\"footer__info_copyright\">Copyright (C) 2024 DAIKIN MR ENGINEERING,LTD. All Rights Reserved.</p>\n            <ul class=\"footer__info-link-list\">\n                <li><a href=\"https://www.dmre.daikin.co.jp/terms/index.html\" target=\"_blank\">ウェブサイトご利用条件</a></li>\n                <li><a href=\"https://www.dmre.daikin.co.jp/privacy/index.html\" target=\"_blank\">個人情報保護方針</a></li>\n            </ul>\n            <a href=\"https://www.dmre.daikin.co.jp\" target=\"_blank\" class=\"footer__info-corporate\">ダイキンMRエンジニアリングのコーポレートサイトへ</a>\n        </div>\n        <div class=\"footer__btn_wrap\">\n            <button class=\"footer__btn entry js-entry-btn\">\n                <span class=\"footer__btn_ttl\">新卒採用<br class=\"pc-only\">エントリー</span>\n            </button>\n            <a href=\"/recruit/career/\" class=\"footer__btn career\">\n                <p class=\"footer__btn_ttl\">キャリア採用は<br class=\"pc-only\">こちら</p>\n            </a>\n        </div>\n    </div>\n</footer>\n\n<div id=\"recruit-popup\" class=\"mfp-hide recruit-popup\">\n    <div class=\"recruit-popup__wrap\">\n        <div class=\"recruit-popup__close\"><button class=\"js-popup-close\"><img src=\"/recruit/common/img/popup_close.svg\" alt=\"\" width=\"32\" height=\"32\"></button></div>\n        <div class=\"recruit-popup__main\">\n            <a href=\"https://job.rikunabi.com/2026/company/r839362059/\" target=\"_blank\" class=\"recruit-popup__btn y25\">新卒採用 26卒<br>\n                エントリーはこちら</a>\n            <a href=\"https://www.onecareer.jp/companies/5985\" target=\"_blank\" class=\"recruit-popup__btn y26\">新卒採用 27卒<br>エントリーはこちら</a>\n\n        </div>\n        <center>\n                <table>\n                <tr>\n                <td align=\"center\">\n                <font size=\"+2\">－ 説明会に参加済みの方へ － </font><br><br></td></tr>\n                <tr>\n                <td>\n応募の際は、件名 「新卒採用応募」 と記載の上、履歴書またはエントリーシートを添付してメールしてください。<br>\n学校指定のフォームで問題ありません。\n<br><br>\n【送付先】 saiyo.dmre☆daikin.co.jp<br>\n&nbsp;&nbsp;※ご連絡の際は、☆を@に変えてください\n      <br><br> \n                </td>\n                </tr>\n                </table>\n      </center>\n        \n    </div>\n</div>\n\n</div>\n\n</body>\n</html>\n\n","finalUrl":"https://www.dmre.daikin.co.jp/recruit/career/","rendered":false,"_cachedAt":"2026-06-22T15:36:54.463Z"}