{"url":"https://www.nttdata-ncb.co.jp/recruit/system/welfare.php","html":"<!doctype html>\n<html lang=\"ja\">\n\n<head>\n\n  <!-- Google tag (gtag.js) -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-8WF1PH0GBZ\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'G-8WF1PH0GBZ');\n</script>\n\n<meta charset=\"utf-8\">\n<meta name=\"description\" content=\"NTTデータNCBは、NTTデータと西日本シティ銀行の持ちうるノウハウやIT技術力などを最大限に活かし、「お客様にとって、なくてはならないNTTデータNCB」をめざします。地域企業の発展拡大、ひいては地域の発展に大きく貢献いたします。\">\n<meta name=\"viewport\" content=\"width=device-width,user-scalable=no,maximum-scale=1\">\n<meta name=\"format-detection\" content=\"telephone=no\">\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=Edge,chrome=1\">\n\n<meta property=\"og:title\" content=\"株式会社NTTデータNCB\">\n<meta property=\"og:description\" content=\"NTTデータNCBは、NTTデータと西日本シティ銀行の持ちうるノウハウやIT技術力などを最大限に活かし、「お客様にとって、なくてはならないNTTデータNCB」をめざします。地域企業の発展拡大、ひいては地域の発展に大きく貢献いたします。\">\n<meta property=\"og:type\" content=\"website\">\n<meta property=\"og:url\" content=\"https://www.nttdata-ncb.co.jp/\">\n<meta property=\"og:site_name\" content=\"株式会社NTTデータNCB\">\n<meta property=\"og:image\" content=\"/assets/img/base/ogp.png\">\n\n<meta name=\"twitter:card\" content=\"summary_large_image\">\n<meta name=\"twitter:title\" content=\"株式会社NTTデータNCB\">\n<meta name=\"twitter:description\" content=\"NTTデータNCBは、NTTデータと西日本シティ銀行の持ちうるノウハウやIT技術力などを最大限に活かし、「お客様にとって、なくてはならないNTTデータNCB」をめざします。地域企業の発展拡大、ひいては地域の発展に大きく貢献いたします。\">\n<meta name=\"twitter:url\" content=\"https://www.nttdata-ncb.co.jp/\">\n<meta name=\"twitter:image\" content=\"/assets/img/base/ogp.png\">\n\n<link rel=\"shortcut icon\" href=\"/assets/img/base/favicon.ico\">\n<link rel=\"apple-touch-icon\" href=\"/assets/img/base/apple-touch-icon.png\">\n\n  <title>福利厚生 | 株式会社NTTデータNCB</title>\n\n  <!-- <link href=\"https://fonts.googleapis.com/css?family=Lato:300,400,400i,700,700i,900\" rel=\"stylesheet\">\n<link href=\"https://fonts.googleapis.com/earlyaccess/notosansjapanese.css\" rel=\"stylesheet\"> -->\n\n<link href=\"/assets/css/style.css?20250212\" rel=\"stylesheet\">\n  \n\n</head>\n\n<body class=\"page-recruit page-welfare\">\n\n\n  <header class=\"l-recruit-header\">\n  <div class=\"l-recruit-header-logo\">\n    <a href=\"/recruit/\" class=\"l-recruit-header-logo__link\">\n      <div class=\"l-recruit-header-logo__main\">\n        <img src=\"/assets/img/recruit/ntt-data-logo-white.png?20250616\" alt=\"NTT DATA\">\n      </div>\n      <div class=\"l-recruit-header-logo__sub\">\n        <img src=\"/assets/img/recruit/corplate-logo.png\" alt=\"株式会社NTTデータNCB\">\n      </div>\n    </a>\n  </div>\n\n\n  <!-- スマホメニューを開くボタン -->\n  <button class=\"fullScreenMenu-button\" type=\"button\" data-fullScreenMenu-trigger=\"js-fullScreenMenu-content\"\n    aria-label=\"メニューを開く\">\n    <span class=\"fullScreenMenu-button__line\"></span>\n    <span class=\"fullScreenMenu-button__line\"></span>\n    <span class=\"fullScreenMenu-button__line\"></span>\n  </button>\n</header><!-- /#globalHeader -->\n\n\n\n<!-- スマホメニュー本体 -->\n<div id=\"js-fullScreenMenu-content\" class=\"fullScreenMenu-content\">\n  <div class=\"fullScreenMenu-content__inner\">\n    <div class=\"l-header-fullScreenMenu\">\n      <ul class=\"l-header-fullScreenMenu__function\">\n        <li class=\"l-header-fullScreenMenu__function-item\">\n          <a href=\"/\" class=\"l-header-fullScreenMenu__function-item-link\">\n            <span>企業TOP</span>\n          </a>\n        </li>\n        <li class=\"l-header-fullScreenMenu__function-item\">\n          <a href=\"/recruit/\" class=\"l-header-fullScreenMenu__function-item-link\">\n            <span>採用TOP</span>\n          </a>\n        </li>\n        <li class=\"l-header-fullScreenMenu__function-item\">\n          <a href=\"/recruit/interview/\" class=\"l-header-fullScreenMenu__function-item-link\">\n            <span>仕事を知る</span>\n          </a>\n        </li>\n        <li class=\"l-header-fullScreenMenu__function-item\">\n          <a href=\"/recruit/system/\" class=\"l-header-fullScreenMenu__function-item-link\">\n            <span>福利厚生／教育</span>\n          </a>\n        </li>\n        <li class=\"l-header-fullScreenMenu__function-item\">\n          <a href=\"/recruit/system/education.php\" class=\"l-header-fullScreenMenu__function-item-link\">\n            <span>教育制度／文系出身者の声</span>\n          </a>\n        </li>\n        <li class=\"l-header-fullScreenMenu__function-item\">\n          <a href=\"/recruit/system/welfare.php\" class=\"l-header-fullScreenMenu__function-item-link\">\n            <span>福利厚生</span>\n          </a>\n        </li>\n        <li class=\"l-header-fullScreenMenu__function-item\">\n          <a href=\"/recruit/system/enviroment.php\" class=\"l-header-fullScreenMenu__function-item-link\">\n            <span>制度・環境</span>\n          </a>\n        </li>\n        <li class=\"l-header-fullScreenMenu__function-item\">\n          <a href=\"/recruit/keyword/\" class=\"l-header-fullScreenMenu__function-item-link\">\n            <span>キーワードで知る</span>\n          </a>\n        </li>\n        <li class=\"l-header-fullScreenMenu__function-item\">\n          <a href=\"/recruit/essentials/\" class=\"l-header-fullScreenMenu__function-item-link\">\n            <span>新卒募集要項</span>\n          </a>\n        </li>\n        <li class=\"l-header-fullScreenMenu__function-item\">\n          <a href=\"/recruit/essentials/mid_career.php\" class=\"l-header-fullScreenMenu__function-item-link\">\n            <span>経験者募集要項</span>\n          </a>\n        </li>\n      </ul>\n    </div>\n  </div>\n</div>\n  <div class=\"l-contents -col--1\">\n\n    <div class=\"l-contents-detail\">\n\n      <main class=\"l-main\">\n        <section class=\"p-recruit-hero-common\">\n          <div class=\"p-recruit-hero-common__inner\">\n            <div class=\"p-recruit-hero-common__left\">\n              <h1 class=\"p-recruit-hero-common__title\">\n                <span class=\"p-recruit-hero-common__title-main\">EMPLOYEE BENEFITS</span>\n                <span class=\"p-recruit-hero-common__title-sub\">福利厚生</span>\n              </h1>\n            </div>\n            <div class=\"p-recruit-hero-common__right\">\n              <div class=\"p-recruit-hero-common__image\"><img src=\"/assets/img/recruit/system/welfare/welfare-main-image.png\" alt=\"\"></div>\n            </div>\n          </div>\n        </section>\n\n\n        <div class=\"c-breadcrumb\">\n          <div class=\"c-breadcrumb__inner\">\n            <ul class=\"c-breadcrumb-list\">\n              <li class=\"c-breadcrumb-list__item\"><a href=\"/recruit/\" class=\"\">ホーム</a></li>\n              <li class=\"c-breadcrumb-list__item\"><a href=\"/recruit/system/\" class=\"\">福利厚生 / 教育</a></li>\n              <li class=\"c-breadcrumb-list__item\">福利厚生</li>\n            </ul>\n          </div>\n        </div>\n\n\n        <section class=\"p-recruit-about\">\n          <div class=\"p-recruit-about__inner\">\n            <h2 class=\"p-recruit-about__h2 recruit-welfare__h2\">働きやすい環境づくり</h2>\n            <p class=\"p-recruit-about__text recruit-welfare__h2-text\">社員のみなさんが、働きやすい職場環境となるよう、さまざまな制度を設けています。<br>※2025年6月現在</p>\n          </div>\n        </section>\n\n\n        <section class=\"recruit-welfare mt48\">\n          <div class=\"recruit-welfare__inner\">\n            <h3 class=\"recruit-education-flow-training__list-item-h3\">\n              <span class=\"recruit-education-flow-training__list-item-h3-inner\">休日・休暇</span>\n            </h3>\n\n            <h4 class=\"recruit-education-title__h4\">\n              <span>休日</span>\n            </h4>\n            <p class=\"recruit-interview-single-message__box-text\">完全週休2日制（土日）、祝日、年末年始（12/30～1/3）</p>\n\n            <h4 class=\"recruit-education-title__h4\">\n              <span>休暇</span>\n            </h4>\n            <p class=\"recruit-interview-single-message__box-text\">\n              年次有給休暇（初年度13日、最大年間20日）、特別連続休暇（年間5日）、産前産後休業、特別有給休暇（慶弔他）、<br>\n              育児休業（こどもが満1歳になる前日まで）、介護休業、子の看護等休暇、介護休暇、生理休暇\n            </p>\n\n\n            <div class=\"recruit-welfare__wrap\">\n              <ul class=\"recruit-welfare-list\">\n                <li class=\"recruit-welfare-list__item\">\n                  <div class=\"recruit-welfare-list__item-left\">\n                    <div class=\"recruit-welfare-list__item-icon\">\n                      <img src=\"/assets/img/recruit/system/welfare/logo-06.png\" alt=\"\" class=\"icon06\">\n                    </div>\n                  </div>\n                  <div class=\"recruit-welfare-list__item-right\">\n                    <h4 class=\"recruit-welfare-list__item-h4\">育児のための短時間勤務</h4>\n                    <p class=\"recruit-welfare-list__item-text\">\n                      子どもが小学3年生まで取得可能です。<br>\n                      1日の勤務時間を最大2時間短くして勤務することができます。\n                    </p>\n                  </div>\n                </li>\n\n                <li class=\"recruit-welfare-list__item\">\n                  <div class=\"recruit-welfare-list__item-left\">\n                    <div class=\"recruit-welfare-list__item-icon\">\n                      <img src=\"/assets/img/recruit/system/welfare/logo-11.png\" alt=\"\" class=\"icon11\">\n                    </div>\n                  </div>\n                  <div class=\"recruit-welfare-list__item-right\">\n                    <h4 class=\"recruit-welfare-list__item-h4\">年次有給休暇</h4>\n                    <p class=\"recruit-welfare-list__item-text\">入社1年目は13日、2年目は16日、3年目には20日が年間で付与されます。<br>また、半日での取得、年間5日間までは1時間単位での取得も可能です。</p>\n                  </div>\n                </li>\n\n                 <li class=\"recruit-welfare-list__item\">\n                  <div class=\"recruit-welfare-list__item-left\">\n                    <div class=\"recruit-welfare-list__item-icon\">\n                      <img src=\"/assets/img/recruit/system/welfare/logo-18.png\" alt=\"\" class=\"icon11\">\n                    </div>\n                  </div>\n                  <div class=\"recruit-welfare-list__item-right\">\n                    <h4 class=\"recruit-welfare-list__item-h4\">特別連続休暇</h4>\n                    <p class=\"recruit-welfare-list__item-text\">年次有給休暇とは別に年間で5日取得できる有給休暇で、日単位で原則2日以上の連続で取得していただきます。</p>\n                  </div>\n                </li>\n              </ul>\n            </div>\n          </div>\n        </section>\n\n        <section class=\"recruit-welfare mt80\">\n          <div class=\"recruit-welfare__inner\">\n            <h3 class=\"recruit-education-flow-training__list-item-h3\">\n              <span class=\"recruit-education-flow-training__list-item-h3-inner\">手当</span>\n            </h3>\n            <p class=\"recruit-interview-single-message__box-text\">\n              通勤手当（原則全額支給）、時間外手当、扶養手当、住宅手当、リモートワーク手当、緊急対応手当、慶弔見舞金、単身赴任手当、地域加算手当（首都圏勤務）<br>\n              ※各種手当については、支給条件等があります。\n            </p>\n          </div>\n        </section>\n\n        <section class=\"recruit-welfare mt80\">\n          <div class=\"recruit-welfare__inner\">\n            <h3 class=\"recruit-education-flow-training__list-item-h3\">\n              <span class=\"recruit-education-flow-training__list-item-h3-inner\">多様な働き方を支える制度</span>\n            </h3>\n            <div class=\"recruit-welfare__wrap\">\n              <ul class=\"recruit-welfare-list\">\n                <li class=\"recruit-welfare-list__item\">\n                  <div class=\"recruit-welfare-list__item-left\">\n                    <div class=\"recruit-welfare-list__item-icon\">\n                      <img src=\"/assets/img/recruit/system/welfare/logo-16.png\" alt=\"\" class=\"icon16\">\n                    </div>\n                  </div>\n                  <div class=\"recruit-welfare-list__item-right\">\n                    <h4 class=\"recruit-welfare-list__item-h4\">テレワーク制度の導入</h4>\n                    <p class=\"recruit-welfare-list__item-text\">\n                      少子高齢化対策の推進、ワーク・ライフ・バランスの実現等を目的に、業務に応じて、テレワーク制度を活用しています。<br>\n                      様々な事情により通勤が困難になった場合でも、自宅を勤務場所として仕事をするケース（フルリモート）もあります。\n                    </p>\n                  </div>\n                </li>\n\n                <li class=\"recruit-welfare-list__item\">\n                  <div class=\"recruit-welfare-list__item-left\">\n                    <div class=\"recruit-welfare-list__item-icon\">\n                      <img src=\"/assets/img/recruit/system/welfare/logo-08.png\" alt=\"\" class=\"icon08\">\n                    </div>\n                  </div>\n                  <div class=\"recruit-welfare-list__item-right\">\n                    <h4 class=\"recruit-welfare-list__item-h4\">定時前退社制度</h4>\n                    <p class=\"recruit-welfare-list__item-text\">\n                    毎週水曜日は定時退社時間よりも30分早く帰ることができます。\n                    </p>\n                  </div>\n                </li>\n\n                <li class=\"recruit-welfare-list__item\">\n                  <div class=\"recruit-welfare-list__item-left\">\n                    <div class=\"recruit-welfare-list__item-icon\">\n                      <img src=\"/assets/img/recruit/system/welfare/logo-17.png\" alt=\"\" class=\"icon08\">\n                    </div>\n                  </div>\n                  <div class=\"recruit-welfare-list__item-right\">\n                    <h4 class=\"recruit-welfare-list__item-h4\">ビジネス・カジュアルの導入</h4>\n                    <p class=\"recruit-welfare-list__item-text\">\n                      TPOを常に意識し、清潔感のある身だしなみを原則として、<br>\n                      ＮＴＴデータグループの「ビジネス・カジュアル・ガイドライン」に沿って実施しています。\n                    </p>\n                  </div>\n                </li>\n              </ul>\n            </div>\n          </div>\n        </section>\n\n\n        <section class=\"recruit-welfare mt80\">\n          <div class=\"recruit-welfare__inner\">\n            <h3 class=\"recruit-education-flow-training__list-item-h3\">\n              <span class=\"recruit-education-flow-training__list-item-h3-inner\">その他 福利厚生</span>\n            </h3>\n\n            <div class=\"recruit-welfare__wrap\">\n              <ul class=\"recruit-welfare-list\">\n                <li class=\"recruit-welfare-list__item\">\n                  <div class=\"recruit-welfare-list__item-left\">\n                    <div class=\"recruit-welfare-list__item-icon\">\n                      <img src=\"/assets/img/recruit/system/welfare/logo-03.png\" alt=\"\" class=\"icon03\">\n                    </div>\n                  </div>\n                  <div class=\"recruit-welfare-list__item-right\">\n                    <h4 class=\"recruit-welfare-list__item-h4\">定期健康診断もしくは人間ドック受診（年齢に応じて最大５万円）</h4>\n                    <p class=\"recruit-welfare-list__item-text\">毎年、社員の希望により定期健康診断を受診するか、人間ドックを受診するか自分で選ぶことができます。</p>\n                    <div class=\"recruit-welfare-list__item-text-small\">\n                      ※人間ドックに関しては、会社負担の金額を超えた分が個人負担となっています。<br>\n                      また、年に1回、インフルエンザ予防接種の補助も行っています。\n                    </div>\n                  </div>\n                </li>\n                <li class=\"recruit-welfare-list__item\">\n                  <div class=\"recruit-welfare-list__item-left\">\n                    <div class=\"recruit-welfare-list__item-icon\">\n                      <img src=\"/assets/img/recruit/system/welfare/logo-04.png\" alt=\"\" class=\"icon04\">\n                    </div>\n                  </div>\n                  <div class=\"recruit-welfare-list__item-right\">\n                    <h4 class=\"recruit-welfare-list__item-h4\">財形貯蓄制度</h4>\n                    <p class=\"recruit-welfare-list__item-text\">一般財形貯蓄、財形住宅貯蓄、財形年金貯蓄の3種類があります。</p>\n                  </div>\n                </li>\n                <li class=\"recruit-welfare-list__item\">\n                  <div class=\"recruit-welfare-list__item-left\">\n                    <div class=\"recruit-welfare-list__item-icon\">\n                      <img src=\"/assets/img/recruit/system/welfare/logo-02.png\" alt=\"\" class=\"icon02\">\n                    </div>\n                  </div>\n                  <div class=\"recruit-welfare-list__item-right\">\n                    <h4 class=\"recruit-welfare-list__item-h4\">保険制度</h4>\n                    <p class=\"recruit-welfare-list__item-text\">健康保険、厚生年金、雇用保険、労災保険を完備しています。</p>\n                  </div>\n                </li>\n                <li class=\"recruit-welfare-list__item\">\n                  <div class=\"recruit-welfare-list__item-left\">\n                    <div class=\"recruit-welfare-list__item-icon\">\n                      <img src=\"/assets/img/recruit/system/welfare/logo-13.png\" alt=\"\" class=\"icon13\">\n                    </div>\n                  </div>\n                  <div class=\"recruit-welfare-list__item-right\">\n                    <h4 class=\"recruit-welfare-list__item-h4\">退職金制度</h4>\n                    <p class=\"recruit-welfare-list__item-text\">確定給付企業年金制度を取り入れています。</p>\n                  </div>\n                </li>\n                <li class=\"recruit-welfare-list__item\">\n                  <div class=\"recruit-welfare-list__item-left\">\n                    <div class=\"recruit-welfare-list__item-icon\">\n                      <img src=\"/assets/img/recruit/system/welfare/logo-12.png\" alt=\"\" class=\"icon12\">\n                    </div>\n                  </div>\n                  <div class=\"recruit-welfare-list__item-right\">\n                    <h4 class=\"recruit-welfare-list__item-h4\">定年退職者再雇用制度</h4>\n                    <p class=\"recruit-welfare-list__item-text\">満65歳までの再雇用が可能です。</p>\n                  </div>\n                </li>\n                <li class=\"recruit-welfare-list__item\">\n                  <div class=\"recruit-welfare-list__item-left\">\n                    <div class=\"recruit-welfare-list__item-icon\">\n                      <img src=\"/assets/img/recruit/system/welfare/logo-07.png\" alt=\"\" class=\"icon07\">\n                    </div>\n                  </div>\n                  <div class=\"recruit-welfare-list__item-right\">\n                    <h4 class=\"recruit-welfare-list__item-h4\">従業員協議会</h4>\n                    <p class=\"recruit-welfare-list__item-text\">当社には労働組合はありませんが、その代わりとなるものです。ここでは、経営者・従業員相互の信頼関係を基に、働きやすい職場環境づくりと労働条件の改善・向上などについて、意見交換・話し合いを行っています。</p>\n                  </div>\n                </li>\n                <li class=\"recruit-welfare-list__item\">\n                  <div class=\"recruit-welfare-list__item-left\">\n                    <div class=\"recruit-welfare-list__item-icon\">\n                      <img src=\"/assets/img/recruit/system/welfare/logo-14.png\" alt=\"\" class=\"icon14\">\n                    </div>\n                  </div>\n                  <div class=\"recruit-welfare-list__item-right\" id=\"support\">\n                    <h4 class=\"recruit-welfare-list__item-h4\">資格取得支援</h4>\n                    <p class=\"recruit-welfare-list__item-text\">社が指定した資格について、資格試験受験料の負担や合格時のお祝い金制度があります。<br>上記に加えて、更新が必要で費用が発生する場合、更新にかかる費用も支援しています。</p>\n                  </div>\n                </li>\n                <li class=\"recruit-welfare-list__item\">\n                  <div class=\"recruit-welfare-list__item-left\">\n                    <div class=\"recruit-welfare-list__item-icon\">\n                      <img src=\"/assets/img/recruit/system/welfare/logo-15.png\" alt=\"\" class=\"icon15\">\n                    </div>\n                  </div>\n                  <div class=\"recruit-welfare-list__item-right\" id=\"self-education\">\n                    <h4 class=\"recruit-welfare-list__item-h4\">セルフエデュケーション支援</h4>\n                    <p class=\"recruit-welfare-list__item-text\">業務に関するもので、自ら任意に参加する研修やセミナー、学習及び書籍の購入に各年度１人１万円を限度に社が負担します。</p>\n                  </div>\n                </li>\n                <li class=\"recruit-welfare-list__item\">\n                  <div class=\"recruit-welfare-list__item-left\">\n                    <div class=\"recruit-welfare-list__item-icon\">\n                      <img src=\"/assets/img/recruit/system/welfare/logo-19.png\" alt=\"\" class=\"icon19\">\n                    </div>\n                  </div>\n                  <div class=\"recruit-welfare-list__item-right\">\n                    <h4 class=\"recruit-welfare-list__item-h4\">福利厚生倶楽部</h4>\n                    <p class=\"recruit-welfare-list__item-text\">国内宿泊、海外宿泊、レジャー、スポーツクラブ等のメニューを会員価格で利用ができ、また、育児サービス・介護サービスにおいては補助制度が使えます。詳しくは<a href=\"https://www.fukuri.jp/contents/files/fukuri/img/eigyo/c1/index.html?compname=%E6%A0%AA%E5%BC%8F%E4%BC%9A%E7%A4%BENTT%E3%83%87%E3%83%BC%E3%82%BFNCB\" class=\"recruit-welfare-list__item-text-link\" target=\"_blank\">こちら</a>。</p>\n                  </div>\n                </li>\n                <li class=\"recruit-welfare-list__item\">\n                  <div class=\"recruit-welfare-list__item-left\">\n                    <div class=\"recruit-welfare-list__item-icon\">\n                      <img src=\"/assets/img/recruit/system/welfare/logo-09.png\" alt=\"\" class=\"icon09\">\n                    </div>\n                  </div>\n                  <div class=\"recruit-welfare-list__item-right\">\n                    <h4 class=\"recruit-welfare-list__item-h4\">レクリエーション</h4>\n                    <p class=\"recruit-welfare-list__item-text\">社員交流、リフレッシュを目的に年2～3回おこなっています。詳しくは、<a href=\"/recruit/system/enviroment.php\" class=\"recruit-welfare-list__item-text-link\">社内イベントページ</a>に掲載しています。</p>\n                  </div>\n                </li>\n\n\n              </ul>\n              <!-- <div class=\"recruit-welfare-button\">\n                                    <a href=\"https://www.fukuri.jp/contents/files/fukuri/img/eigyo/c1/index.html?compname=%E6%A0%AA%E5%BC%8F%E4%BC%9A%E7%A4%BENTT%E3%83%87%E3%83%BC%E3%82%BFNCB\" target=\"_blank\" class=\"recruit-welfare-button__inner\">\n                                        <span>福利厚生倶楽部のご案内</span>\n                    </a>\n              </div> -->\n            </div>\n          </div>\n        </section>\n\n      </main><!-- l-main -->\n\n    </div><!-- /l-contents-detail -->\n\n  </div><!-- /l-contents -->\n\n\n  <footer class=\"l-recruit-footer\">\n  <div class=\"l-recruit-footer-jump\">\n    <div class=\"l-recruit-footer-jump__inner\">\n      <div class=\"l-recruit-footer-jump-item -entry\">\n        <a href=\"https://job.mynavi.jp/27/pc/search/corp80005/outline.html\" target=\"_blank\" class=\"l-recruit-footer-jump-item__link\">\n          <span class=\"-text\">ENTRY</span>\n          <span class=\"-icon\"></span>\n        </a>\n      </div>\n      <div class=\"l-recruit-footer-jump-item -document\">\n        <a href=\"/recruit/essentials/\" class=\"l-recruit-footer-jump-item__link\">\n          <span class=\"-text\">募集要項</span>\n          <span class=\"-icon\"></span>\n        </a>\n      </div>\n    </div>\n  </div>\n  <p class=\"l-recruit-footer-copyright\">Copyright &copy; NTT DATA NCB Corporation</p>\n</footer>\n\n<div class=\"c-scrollPageTop\">\n  <a href=\"#\" data-scroll></a>\n</div><!-- /scrollToPageTop -->  <script src=\"/assets/js/vendor.js?20241213\"></script>\n<script src=\"/assets/js/main.js?20241213\"></script>\n\n\n</body>\n\n</html>","finalUrl":"https://www.nttdata-ncb.co.jp/recruit/system/welfare.php","rendered":false,"_cachedAt":"2026-06-22T20:33:17.667Z"}