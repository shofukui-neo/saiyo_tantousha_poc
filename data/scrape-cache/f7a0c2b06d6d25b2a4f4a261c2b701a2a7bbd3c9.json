{"url":"https://www.super-marui.com/recruit/deli/session2.html","html":"<!DOCTYPE html>\n<html lang=\"ja-JP\">\n <head> \n  <meta charset=\"UTF-8\"> \n  <meta http-equiv=\"content-type\" content=\"text/html; charset=UTF-8\"> \n  <meta name=\"robots\" content=\"index\"> \n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"> \n  <meta name=\"description\" content=\"2021年4月に入社した惣菜部所属の新人社員と、教育担当のチーフ、トレーナーそれぞれの立場から、マルイ・新人教育の“ホンネ”に迫った。\"> \n  <meta property=\"og:title\" content=\"新人社員の教育現場|新人社員の“ホンネ”\"> \n  <meta property=\"og:type\" content=\"website\"> \n  <meta property=\"og:image\" content=\"https://www.super-marui.com/recruit/bdflashinfo/thumbnail-large.png\"> \n  <meta property=\"og:url\" content=\"https://www.super-marui.com/recruit/deli/session2.html\"> \n  <meta property=\"og:site_name\" content=\"リクルート採用情報サイト | 株式会社マルイ\"> \n  <meta property=\"og:description\" content=\"2021年4月に入社した惣菜部所属の新人社員と、教育担当のチーフ、トレーナーそれぞれの立場から、マルイ・新人教育の“ホンネ”に迫った。\"> \n  <meta name=\"twitter:card\" content=\"summary_large_image\"> \n  <meta name=\"twitter:image\" content=\"https://www.super-marui.com/recruit/bdflashinfo/thumbnail-large.png\"> \n  <meta name=\"note:card\" content=\"summary_large_image\"> \n  <link rel=\"canonical\" href=\"https://www.super-marui.com/recruit/deli/session2.html\"> \n  <title>新人社員の教育現場|新人社員の“ホンネ”</title> \n  <link rel=\"stylesheet\" type=\"text/css\" href=\"../_module/styles/bind.css?v=17.0.6\" id=\"bind-css\"> \n  <link rel=\"stylesheet\" type=\"text/css\" href=\"../_dress/b014006/base.css?1777131014518\"> \n  <link rel=\"stylesheet\" type=\"text/css\" href=\"../_dress/b14006Navi/base.css?1777131014518\"> \n  <link rel=\"stylesheet\" type=\"text/css\" href=\"../_dress/b14006Main1/base.css?1777131014518\"> \n  <link rel=\"stylesheet\" type=\"text/css\" href=\"../_dress/93f5ddf232da4e5eabf8affc97d8ac99/base.css?1777131014518\"> \n  <link rel=\"stylesheet\" type=\"text/css\" href=\"../_dress/00bca8d34607437494a664ba54041520/base.css?17771310