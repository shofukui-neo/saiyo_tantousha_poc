p-single_column c-space_narrow c-sp-space_normal c-sp-padding_normal is-sp-hide bd-webp -dress_b14006Navi cssskin-_block_header init-block_animation init-sp-block_animation\" data-bk-id=\"bk3252\" data-shared=\"true\" data-sharedname=\"_グローバルナビ2\" data-animated=\"fadeIn\" data-sp-animated=\"fadeIn\"> \n         <div class=\" g-column\"> \n          <div class=\" column -col4 -col_sub\"> \n           <h1 class=\" c-page_title\"> \n            <div class=\"c-img   \"> \n             <picture> \n              <source type=\"image/webp\" srcset=\"../_src/2239/img20150831145800040553.webp?v=1769645477911\"> \n              <img src=\"../_src/2239/img20150831145800040553.png?v=1769645477911\" width=\"380\" height=\"100\" alt=\"株式会社マルイ_2025年新卒採用情報\" id=\"imgsrc2239_1\" class=\" c-no_adjust\" loading=\"lazy\"> \n             </picture> \n            </div></h1> \n          </div> \n          <div class=\" column -col8 -col_main\"> \n           <nav> \n            <div class=\" js-motion\"> \n             <ul class=\"m-motion menu-parts -f\"> \n              <li><a href=\"../\" data-pid=\"175\">ホーム</a></li> \n              <li><a href=\"../message.html\" data-pid=\"176\">メッセージ</a></li> \n              <li><span class=\" c-unlink\">チームで取り組む</span> \n               <ul> \n                <li><a href=\"../fisheries/session1.html\" data-pid=\"180\">マルイが挑むプロジェクト</a></li> \n                <li><a href=\"../deli/session2.html\" data-pid=\"183\">新人社員の教育現場</a></li> \n                <li><a href=\"../colleague/session3.html\" data-pid=\"189\">新人社員の研修</a></li> \n               </ul></li> \n              <li><a href=\"../characteristic.html\" data-pid=\"177\">スーパーマルイの特徴</a></li> \n              <li><a href=\"../career_plan.html\" data-pid=\"178\">キャリアプラン</a></li> \n              <li><a href=\"../entry.html\" data-pid=\"179\" class=\"entry\">エントリー</a></li> \n             </ul> \n            </div> \n           </nav> \n          </div> \n         </div> \n        </div> \n       </section> \n      </div> \n     </header> \n    </div> \n    <div id=\"a-billboard\" class=\"a-billboard    cssskin-_area_billboard\"> \n     <div class=\"site_frame\"> \n      <section> \n       <div id=\"bk3253\" class=\"b-plain cssskin-_block_billboard\" data-bk-id=\"bk3253\"> \n        <div class=\" column -column1\"> \n        </div> \n       </div> \n      </section> \n     </div> \n    </div> \n    <main> \n     <div id=\"a-site_contents\" class=\"a-site_contents  noskin\"> \n      <article> \n       <div class=\"site_frame\"> \n        <div class=\"g-column\"> \n         <div id=\"a-main\" class=\"a-main column -col12 \"> \n          <section> \n           <div id=\"bk3254\" class=\"b-plain c-sp-space_normal bd-webp -dress_b14006Main1 cssskin-_block_main init-block_animation init-sp-block_animation\" data-bk-id=\"bk3254\" data-animated=\"fadeIn\" data-sp-animated=\"fadeIn\"> \n            <div class=\" g-column -col2 -sp-col1\"> \n             <div class=\" column -column1\"> \n              <div class=\"c-lead c-left\">\n                チェッカー部門｜野崎さん \n              </div> \n              <h2 class=\" c-title c-left\">新人社員に聞いてみた</h2> \n              <p class=\" c-body\">&nbsp;</p> \n              <div class=\"c-breadcrumb\"> \n               <a href=\"../\" data-pid=\"175\">HOME</a> | \n               <a href=\"session3.html\" data-pid=\"189\">同期チーム｜トークセッション</a> | \n               <em>新人同期インタビュー</em> \n              </div> \n              <br>店舗のチェッカー部門所属の野崎さんにインタビュー。 \n              <p></p> \n             </div> \n             <div class=\" column -column2 -column-lasts\"> \n              <div class=\"c-none c-center\"> \n               <div class=\"c-img   \"> \n                <picture> \n                 <source type=\"image/webp\" srcset=\"../_src/2400/img20220119143719780529.webp?v=1769645477911\"> \n                 <img src=\"../_src/2400/img20220119143719780529.jpg?v=1769645477911\" width=\"1440\" height=\"1440\" alt=\"新人社員インタビュー\" id=\"imgsrc2400_1\" class=\" c-no_adjust\" loading=\"lazy\"> \n                </picture> \n               </div> \n              </div> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk3255\" class=\"b-plain c-space_normal c-sp-space_normal c-sp-padding_normal is-pc-hide bd-webp -dress_4a7c05ad488a4c3fba8d9501d5dc26b3 cssskin-_block_main init-block_animation init-sp-block_animation\" data-bk-id=\"bk3255\" data-animated=\"fadeIn\" data-sp-animated=\"fadeIn\"> \n            <div class=\" g-column -col2 -sp-col1\"> \n             <div class=\" column -column1\"> \n              <div class=\"c-enclosure\"> \n               <div class=\"c-img c-fleft  \"> \n                <picture> \n                 <source type=\"image/webp\" srcset=\"../_src/2402/sign.webp?v=1769645477911\"> \n                 <img src=\"../_src/2402/sign.png?v=1769645477911\" width=\"100\" height=\"100\" alt=\"\" id=\"imgsrc2402_1\" class=\" c-no_adjust\" loading=\"lazy\"> \n                </picture> \n               </div>働く前と後で、イメージと違っていたことはありますか？ \n              </div> \n              <div class=\"c-none\">\n                &nbsp; \n              </div> \n              <p class=\" c-body\"><span style=\"color:#383838;\">レジ操作以外でも、思っていた以上に覚えることが多く、大変な仕事だと</span><span style=\"color:#383838;\">思いました。特にサービスカウンターの仕事は多いですね。</span></p> \n              <div class=\"c-none\">\n                &nbsp; \n              </div> \n              <div class=\"c-enclosure\"> \n               <div class=\"c-img c-fleft  \"> \n                <picture> \n                 <source type=\"image/webp\" srcset=\"../_src/2404/sign.webp?v=1769645477911\"> \n                 <img src=\"../_src/2404/sign.png?v=1769645477911\" width=\"100\" height=\"100\" alt=\"\" id=\"imgsrc2404_1\" class=\" c-no_adjust\" loading=\"lazy\"> \n                </picture> \n               </div>レジ部門のやりがい、楽しさ、大変さは？ \n              </div> \n              <div class=\"c-none\">\n                &nbsp; \n              </div> \n              <p class=\" c-body\"><span style=\"color:#383838;\">朝の早い時間帯以外は基本忙しいので、じっとしているより動くほうが</span><span style=\"color:#383838;\">好きな人は向いていると思います。お客様の質問の対応は経験が必要</span><span style=\"color:#383838;\">ですが、先輩を良い意味で頼って様々な場面を覚えておくことが大切だと</span><span style=\"color:#383838;\">思います。</span></p> \n             </div> \n             <div class=\" column -column2 -column-lasts\"> \n              <div class=\"c-enclosure\"> \n               <div class=\"c-img c-fleft  \"> \n                <picture> \n                 <source type=\"image/webp\" srcset=\"../_src/2403/sign.webp?v=1769645477911\"> \n                 <img src=\"../_src/2403/sign.png?v=1769645477911\" width=\"100\" height=\"100\" alt=\"\" id=\"imgsrc2403_1\" class=\" c-no_adjust\" loading=\"lazy\"> \n                </picture> \n               </div>最近、自分を自分で褒めてあげたいことは？ \n              </div> \n              <div class=\"c-none\">\n                &nbsp; \n              </div> \n              <p class=\" c-body\"><span style=\"color:#383838;\">ちょっと変ですが、チェッカーらしいちょっと高めの声を出せるようになって</span><span style=\"color:#383838;\">きました。吉田さんと、「声のコンディションが決まってきた」なんて言ってますが・・・。</span><br><span style=\"color:#383838;\">接客なので、あんまり低いと特に子供さんから怖がられマス。</span></p> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk3256\" class=\"b-plain c-space_normal c-sp-space_normal c-sp-padding_normal is-sp-hide bd-webp -dress_4a7c05ad488a4c3fba8d9501d5dc26b3 cssskin-_block_main init-block_animation init-sp-block_animation\" data-bk-id=\"bk3256\" data-animated=\"fadeIn\" data-sp-animated=\"fadeIn\"> \n            <div class=\" g-column -col2 -sp-col1\"> \n             <div class=\" column -column1\"> \n              <div class=\"c-enclosure\"> \n               <div class=\"c-img   \"> \n                <picture> \n                 <source type=\"image/webp\" srcset=\"../_src/2405/sign.webp?v=1769645477911\"> \n                 <img src=\"../_src/2405/sign.png?v=1769645477911\" width=\"100\" height=\"100\" alt=\"\" id=\"imgsrc2405_1\" class=\" c-no_adjust\" loading=\"lazy\"> \n                </picture> \n               </div>働く前と後で、イメージと違っていたことはありますか？ \n              </div> \n              <p class=\" c-body\">&nbsp;<br><span style=\"color:#383838;\">レジ操作以外でも、思っていた以上に覚えることが多く、大変な仕事だと</span><span style=\"color:#383838;\">思いました。特にサービスカウンターの仕事は多いですね。</span><br>&nbsp;</p> \n              <div class=\"c-enclosure\"> \n               <div class=\"c-img   \"> \n                <picture> \n                 <source type=\"image/webp\" srcset=\"../_src/2406/sign.webp?v=1769645477911\"> \n                 <img src=\"../_src/2406/sign.png?v=1769645477911\" width=\"100\" height=\"100\" alt=\"\" id=\"imgsrc2406_1\" class=\" c-no_adjust\" loading=\"lazy\"> \n                </picture> \n               </div>レジ部門のやりがい、楽しさ、大変さは？ \n              </div> \n              <p class=\" c-body\">&nbsp;<br><span style=\"color:#383838;\">朝の早い時間帯以外は基本忙しいので、じっとしているより動くほうが</span><span style=\"color:#383838;\">好きな人は向いていると思います。お客様の質問の対応は経験が必要</span><span style=\"color:#383838;\">ですが、先輩を良い意味で頼って様々な場面を覚えておくことが大切だと</span><span style=\"color:#383838;\">思います。</span></p> \n             </div> \n             <div class=\" column -column2 -column-lasts\"> \n              <div class=\"c-enclosure\"> \n               <div class=\"c-img   \"> \n                <picture> \n                 <source type=\"image/webp\" srcset=\"../_src/2407/sign.webp?v=1769645477911\"> \n                 <img src=\"../_src/2407/sign.png?v=1769645477911\" width=\"100\" height=\"100\" alt=\"\" id=\"imgsrc2407_1\" class=\" c-no_adjust\" loading=\"lazy\"> \n                </picture> \n               </div>最近、自分を自分で褒めてあげたいことは？ \n              </div> \n              <p class=\" c-body\">&nbsp;<br><span style=\"color:#383838;\">ちょっと変ですが、チェッカーらしいちょっと高めの声を出せるようになって</span><span style=\"color:#383838;\">きました。吉田さんと、「声のコンディションが決まってきた」なんて言ってますが・・・。</span><br><span style=\"color:#383838;\">接客なので、あんまり低いと特に子供さんから怖がられマス。</span></p> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk3269\" class=\"b-plain c-sp-space_normal bd-webp -dress_b14006Main1 cssskin-_block_main init-block_animation init-sp-block_animation\" data-bk-id=\"bk3269\" data-animated=\"fadeIn\" data-sp-animated=\"fadeIn\"> \n            <div class=\" g-column -col2 -sp-col1\"> \n             <div class=\" column -column1\"> \n              <div class=\"c-lead c-left\">\n                青果部門｜吉田さん \n              </div> \n              <h2 class=\" c-title c-left\">新人社員に聞いてみた</h2> \n              <p class=\" c-body\">&nbsp;</p> \n              <div class=\"c-breadcrumb\"> \n               <a href=\"../\" data-pid=\"175\">HOME</a> | \n               <a href=\"session3.html\" data-pid=\"189\">同期チーム｜トークセッション</a> | \n               <em>新人同期インタビュー</em> \n              </div> \n              <br>店舗の青果部門所属の吉田さんにインタビュー。 \n              <p></p> \n             </div> \n             <div class=\" column -column2 -column-lasts\"> \n              <div class=\"c-none c-center\"> \n               <div class=\"c-img   \"> \n                <picture> \n                 <source type=\"image/webp\" srcset=\"../_src/2408/img20220119142628834680.webp?v=1769645477911\"> \n                 <img src=\"../_src/2408/img20220119142628834680.jpg?v=1769645477911\" width=\"1440\" height=\"1440\" alt=\"新人社員インタビュー\" id=\"imgsrc2408_1\" class=\" c-no_adjust\" loading=\"lazy\"> \n                </picture> \n               </div> \n              </div> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk3270\" class=\"b-plain c-space_normal c-sp-space_normal c-sp-padding_normal is-pc-hide bd-webp -dress_4a7c05ad488a4c3fba8d9501d5dc26b3 cssskin-_block_main init-block_animation init-sp-block_animation\" data-bk-id=\"bk3270\" data-animated=\"fadeIn\" data-sp-animated=\"fadeIn\"> \n            <div class=\" g-column -col2 -sp-col1\"> \n             <div class=\" column -column1\"> \n              <div class=\"c-enclosure\"> \n               <div class=\"c-img c-fleft  \"> \n                <picture> \n                 <source type=\"image/webp\" srcset=\"../_src/2410/sign.webp?v=1769645477911\"> \n                 <img src=\"../_src/2410/sign.png?v=1769645477911\" width=\"100\" height=\"100\" alt=\"\" id=\"imgsrc2410_1\" class=\" c-no_adjust\" loading=\"lazy\"> \n                </picture> \n               </div>マルイを選んだ理由を聞かせてください。 \n              </div> \n              <div class=\"c-none\">\n                &nbsp; \n              </div> \n              <p class=\" c-body\"><span style=\"color:#383838;\">自分が書いたコトＰＯＰが、売上に直接関係するかもしれないと思ったら、</span><span style=\"color:#383838;\">とても楽しそうだし、書きがいがありそうだと思ったからです。</span></p> \n              <div class=\"c-none\">\n                &nbsp; \n              </div> \n              <div class=\"c-enclosure\"> \n               <div class=\"c-img c-fleft  \"> \n                <picture> \n                 <source type=\"image/webp\" srcset=\"../_src/2412/sign.webp?v=1769645477911\"> \n                 <img src=\"../_src/2412/sign.png?v=1769645477911\" width=\"100\" height=\"100\" alt=\"\" id=\"imgsrc2412_1\" class=\" c-no_adjust\" loading=\"lazy\"> \n                </picture> \n               </div>青果部門のやりがい、楽しさ、大変さとは？ \n              </div> \n              <div class=\"c-none\">\n                &nbsp; \n              </div> \n              <p class=\" c-body\"><span style=\"color:#383838;\">野菜や果物の旬の時期や、その移り変わりがピースのようにつながって</span><span style=\"color:#383838;\">行く感じが、とても楽しいです。</span><br><span style=\"color:#383838;\">一方で、朝から重いものを上げ下げする作業もあり、体力は使いますよ。</span></p> \n             </div> \n             <div class=\" column -column2 -column-lasts\"> \n              <div class=\"c-enclosure\"> \n               <div class=\"c-img c-fleft  \"> \n                <picture> \n                 <source type=\"image/webp\" srcset=\"../_src/2411/sign.webp?v=1769645477911\"> \n                 <img src=\"../_src/2411/sign.png?v=1769645477911\" width=\"100\" height=\"100\" alt=\"\" id=\"imgsrc2411_1\" class=\" c-no_adjust\" loading=\"lazy\"> \n                </picture> \n               </div>最近、自分を自分で褒めてあげたいことは？ \n              </div> \n              <div class=\"c-none\">\n                &nbsp; \n              </div> \n              <p class=\" c-body\"><span style=\"color:#383838;\">ＰＯＰは、自分ではなかなか上手に書けるようになってきたのではないか・・・と思い込んでます。何点かは、店長から掲示板にＵＰしてもらったこともあり、自信になりますね。</span></p> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk3271\" class=\"b-plain c-space_normal c-sp-space_normal c-sp-padding_normal is-sp-hide bd-webp -dress_4a7c05ad488a4c3fba8d9501d5dc26b3 cssskin-_block_main init-block_animation init-sp-block_animation\" data-bk-id=\"bk3271\" data-animated=\"fadeIn\" data-sp-animated=\"fadeIn\"> \n            <div class=\" g-column -col2 -sp-col1\"> \n             <div class=\" column -column1\"> \n              <div class=\"c-enclosure\"> \n               <div class=\"c-img   \"> \n                <picture> \n                 <source type=\"image/webp\" srcset=\"../_src/2413/sign.webp?v=1769645477911\"> \n                 <img src=\"../_src/2413/sign.png?v=1769645477911\" width=\"100\" height=\"100\" alt=\"\" id=\"imgsrc2413_1\" class=\" c-no_adjust\" loading=\"lazy\"> \n                </picture> \n               </div>マルイを選んだ理由を聞かせてください。 \n              </div> \n              <p class=\" c-body\">&nbsp;<br><span style=\"color:#383838;\">自分が書いたコトＰＯＰが、売上に直接関係するかもしれないと思ったら、</span><span style=\"color:#383838;\">とても楽しそうだし、書きがいがありそうだと思ったからです。</span><br>&nbsp;</p> \n              <div class=\"c-enclosure\"> \n               <div class=\"c-img   \"> \n                <picture> \n                 <source type=\"image/webp\" srcset=\"../_src/2414/sign.webp?v=1769645477911\"> \n                 <img src=\"../_src/2414/sign.png?v=1769645477911\" width=\"100\" height=\"100\" alt=\"\" id=\"imgsrc2414_1\" class=\" c-no_adjust\" loading=\"lazy\"> \n                </picture> \n               </div>青果部門のやりがい、楽しさ、大変さとは？ \n              </div> \n              <p class=\" c-body\">&nbsp;<br><span style=\"color:#383838;\">野菜や果物の旬の時期や、その移り変わりがピースのようにつながって</span><br><span style=\"color:#383838;\">行く感じが、とても楽しいです。</span><br><span style=\"color:#383838;\">一方で、朝から重いものを上げ下げする作業もあり、体力は使いますよ。</span></p> \n             </div> \n             <div class=\" column -column2 -column-lasts\"> \n              <div class=\"c-enclosure\"> \n               <div class=\"c-img   \"> \n                <picture> \n                 <source type=\"image/webp\" srcset=\"../_src/2415/sign.webp?v=1769645477911\"> \n                 <img src=\"../_src/2415/sign.png?v=1769645477911\" width=\"100\" height=\"100\" alt=\"\" id=\"imgsrc2415_1\" class=\" c-no_adjust\" loading=\"lazy\"> \n                </picture> \n               </div>最近、自分を自分で褒めてあげたいことは？ \n              </div> \n              <p class=\" c-body\">&nbsp;<br><span style=\"color:#383838;\">ＰＯＰは、自分ではなかなか上手に書けるようになってきたのではないか・・・と思い込んでます。何点かは、店長から掲示板にＵＰしてもらったこともあり、自信になりますね。</span></p> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk3257\" class=\"b-plain c-space_normal c-sp-space_normal c-sp-padding_normal cssskin-_block_main\" data-bk-id=\"bk3257\"> \n            <div class=\" column -column1\"> \n             <div class=\" c-body c-right\"> \n              <a href=\"../colleague/session3.html\" data-pid=\"189\" class=\"back\">&lt;&lt; 前のページに戻る</a> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk3258\" class=\"b-plain c-space_normal c-sp-space_normal c-sp-padding_init is-sp-hide cssskin-_block_main\" data-bk-id=\"bk3258\" data-shared=\"true\" data-sharedname=\"fwave1\"> \n            <div class=\" column -column1\"> \n             <div class=\" c-body c-center\"> \n              <div class=\"c-img   \"> \n               <picture> \n                <source type=\"image/webp\" srcset=\"../_src/2228/wave_20220112143151277.webp?v=1769645477911\"> \n                <img src=\"../_src/2228/wave_20220112143151277.png?v=1769645477911\" width=\"1920\" height=\"76\" alt=\"マルイ_リクルート求人\" id=\"imgsrc2228_1\" class=\" c-no_adjust\" loading=\"lazy\"> \n               </picture> \n              </div> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk3259\" class=\"b-plain c-space_normal c-sp-space_normal c-sp-padding_init is-pc-hide cssskin-_block_main\" data-bk-id=\"bk3259\" data-shared=\"true\" data-sharedname=\"fwave2\"> \n            <div class=\" column -column1\"> \n             <div class=\" c-body c-center\"> \n              <div class=\"c-img   \"> \n               <picture> \n                <source type=\"image/webp\" srcset=\"../_src/2235/wave800.webp?v=1769645477911\"> \n                <img src=\"../_src/2235/wave800.png?v=1769645477911\" width=\"800\" height=\"102\" alt=\"マルイ_リクルート求人\" id=\"imgsrc2235_1\" class=\" c-no_adjust\" loading=\"lazy\"> \n               </picture> \n              </div> \n             </div> \n            </div> \n           </div> \n          </section> \n         </div> \n        </div> \n       </div> \n      </article> \n     </div> \n    </main> \n    <div id=\"a-footer\" data-float=\"false\" class=\"a-footer   cssskin-_area_footer\"> \n     <footer> \n      <div class=\"site_frame\"> \n       <div id=\"bk3262\" class=\"b-both_diff -left_large -sp-single_column c-space_normal c-sp-space_normal cssskin-_block_footer\" data-bk-id=\"bk3262\" data-shared=\"true\" data-sharedname=\"_フッタメニュー\"> \n        <div class=\" g-column\"> \n         <div class=\" column -col8 -col_main\"> \n          <nav> \n           <div class=\" -menu_left\"> \n            <ul class=\"c-menu -menu_b menu-parts\"> \n             <li><a href=\"https://www.super-marui.com/company/%e4%bc%9a%e7%a4%be%e6%a6%82%e8%a6%81/\">会社概要</a></li> \n             <li><a href=\"https://www.super-marui.com/company/%e4%bc%9a%e7%a4%be%e7%90%86%e5%bf%b5/\">会社理念</a></li> \n             <li><a href=\"http