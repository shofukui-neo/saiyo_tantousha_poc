{"url":"https://www.super-marui.com/recruit/colleague/new_employees.html","html":"<!DOCTYPE html>\n<html lang=\"ja-JP\">\n <head> \n  <meta charset=\"UTF-8\"> \n  <meta http-equiv=\"content-type\" content=\"text/html; charset=UTF-8\"> \n  <meta name=\"robots\" content=\"index\"> \n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"> \n  <meta name=\"description\" content=\"社会人の同期はライバルでもあり、良き相談相手でもあり、学生時代の友達以上の“チーム”になる。 昨年入社の女性新人2名から、同期の連携を取材した。新人社員研修の率直な感想も紹介！\"> \n  <meta property=\"og:title\" content=\"新人同期インタビュー|リクルート採用情報サイト\"> \n  <meta property=\"og:type\" content=\"website\"> \n  <meta property=\"og:image\" content=\"https://www.super-marui.com/recruit/bdflashinfo/thumbnail-large.png\"> \n  <meta property=\"og:url\" content=\"https://www.super-marui.com/recruit/colleague/new_employees.html\"> \n  <meta property=\"og:site_name\" content=\"リクルート採用情報サイト | 株式会社マルイ\"> \n  <meta property=\"og:description\" content=\"社会人の同期はライバルでもあり、良き相談相手でもあり、学生時代の友達以上の“チーム”になる。 昨年入社の女性新人2名から、同期の連携を取材した。新人社員研修の率直な感想も紹介！\"> \n  <meta name=\"twitter:card\" content=\"summary_large_image\"> \n  <meta name=\"twitter:image\" content=\"https://www.super-marui.com/recruit/bdflashinfo/thumbnail-large.png\"> \n  <meta name=\"note:card\" content=\"summary_large_image\"> \n  <link rel=\"canonical\" href=\"https://www.super-marui.com/recruit/colleague/new_employees.html\"> \n  <title>新人同期インタビュー|リクルート採用情報サイト</title> \n  <link rel=\"stylesheet\" type=\"text/css\" href=\"../_module/styles/bind.css?v=17.0.6\" id=\"bind-css\"> \n  <link rel=\"stylesheet\" type=\"text/css\" href=\"../_dress/b014006/base.css?1777131029915\"> \n  <link rel=\"stylesheet\" type=\"text/css\" href=\"../_dress/b14006Navi/base.css?1777131029915\"> \n  <link rel=\"stylesheet\" type=\"text/css\" href=\"../_dress/b14006Main1/base.css?1777131029915\"> \n  <link rel=\"stylesheet\" type=\"text/css\" href=\"../_dress/4a7c05ad488a4c3fba8d9501d5dc26b3/base.css?1777131029915\"> \n  <link rel=\"stylesheet\" type=\"