id=\"application\" value=\"新卒採用\" >\n                        <label class=\"contact__agreementCheckLabel\" for=\"application_new\">新卒採用</label>\n                        <input class=\"contact__agreementCheck checker\" type=\"checkbox\" name=\"application[]\" id=\"application\" value=\"キャリア採用\" >\n                        <label class=\"contact__agreementCheckLabel\" for=\"application_career\">キャリア採用</label>\n                      </div>\n                    </div>\n                  </div>\n                  <div class=\"contact__errorBox\">\n                                      </div>\n                </div>\n                <div class=\"contact__formItemBox\">\n                  <div class=\"contact__formItem\">\n                    <div class=\"contact__formItem-left contact__formItem-leftFlex\"><span class=\"contact__formItemName\">氏名</span><span class=\"contact__formItemRequired\">必須</span></div>\n                    <div class=\"contact__formItem-right\">\n                      <input class=\"contact__input\" type=\"text\" name=\"name\" value=\"\">\n                    </div>\n                  </div>\n                  <div class=\"contact__errorBox\">\n                                      </div>\n                </div>\n                <div class=\"contact__formItemBox\">\n                  <div class=\"contact__formItem\">\n                    <div class=\"contact__formItem-left contact__formItem-leftFlex\"><span class=\"contact__formItemName\">フリガナ</span><span class=\"contact__formItemRequired\">必須</span></div>\n                    <div class=\"contact__formItem-right\">\n                      <input class=\"contact__input\" type=\"text\" name=\"kana\" value=\"\">\n                    </div>\n                  </div>\n                  <div class=\"contact__errorBox\">\n                                    </div>\n                </div>\n                <div class=\"contact__formItemBox\">\n                  <div class=\"contact__formItem\">\n                    <div class=\"contact__formItem-left contact__formItem-leftFlex\"><span class=\"contact__formItemName\">生年月日</span><span class=\"contact__formItemRequired\">必須</span></div>\n                    <div class=\"contact__formItem-right\">\n                      <input class=\"contact__input\" type=\"date\" name=\"birthdate\" value=\"\">\n                    </div>\n                  </div>\n                  <div class=\"contact__errorBox\">\n                                      </div>\n                </div>\n                <div class=\"contact__formItemBox\">\n                  <div class=\"contact__formItem\">\n                    <div class=\"contact__formItem-left contact__formItem-leftFlex\"><span class=\"contact__formItemName\">学校名・学部／学科</span><span class=\"contact__formItemRequired\">必須</span></div>\n                    <div class=\"contact__formItem-right\">\n                      <input class=\"contact__input\" type=\"text\" name=\"school_facility_department_name\" value=\"\">\n                    </div>\n                  </div>\n                  <div class=\"contact__errorBox\">\n                                      </div>\n                </div>\n                <!-- 非対応ブラウザ向け警告メッセージ -->\n                <div id=\"month-input-warning\" class=\"contact__browserWarning\" style=\"display: none;\">\n                <p>※ お使いのブラウザでは年月選択カレンダーに対応していません。<br>\n                「YYYY-MM」形式（例: 2025-03）で直接入力してください。</p>\n                </div>\n                <div class=\"contact__formItemBox\">\n                  <div class=\"contact__formItem\">\n                    <div class=\"contact__formItem-left contact__formItem-leftFlex\"><span class=\"contact__formItemName\">卒業年月（見込, 既卒）</span><span class=\"contact__formItemRequired\">必須</span></div>\n                    <div class=\"contact__formItem-right\">\n                      <input class=\"contact__input\" type=\"month\" name=\"expected_grad_date\" id=\"expected_grad_date\" value=\"\">\n                    </div>\n                  </div>\n                  <div class=\"contact__errorBox\">\n                                      </div>\n                </div>\n                <div class=\"contact__formItemBox\">\n                  <div class=\"contact__formItem\">\n                    <div class=\"contact__formItem-left\"><span class=\"contact__formItemName\">郵便番号</span></div>\n                    <div class=\"contact__formItem-right contact__formItem-rightFlex\">\n                      <input class=\"contact__input contact__input-wd01\" type=\"text\"\n                        name=\"postcode1\" value=\"\"><span class=\"contact__line\"> </span>\n                      <input class=\"contact__input contact__input contact__input-wd02\" type=\"text\"\n                        name=\"postcode2\" value=\"\">\n                    </div>\n                  </div>\n                  <div class=\"contact__errorBox\">\n                                      </div>\n                </div>\n                <div class=\"contact__formItemBox\">\n                  <div class=\"contact__formItem contact__formItem-flexTop\">\n                    <div class=\"contact__formItem-left contact__formItem-left-mt\"><span class=\"contact__formItemName\">住所</span></div>\n                    <div class=\"contact__formItem-right\">\n                      <textarea class=\"contact__textarea\" name=\"address\" cols=\"30\" rows=\"10\"></textarea>\n                    </div>\n                  </div>\n                    <div class=\"contact__errorBox-textarea\">\n                                        </div>\n                </div>\n                <div class=\"contact__formItemBox\">\n                  <div class=\"contact__formItem\">\n                    <div class=\"contact__formItem-left\"><span class=\"contact__formItemName\">電話番号</span></div>\n                    <div class=\"contact__formItem-right contact__formItem-rightFlex\">\n                      <input class=\"contact__input contact__input-wd04\" type=\"text\" name=\"tel1\" value=\"\"><span class=\"contact__line\"> </span>\n                      <input class=\"contact__input contact__input-wd04\" type=\"text\" name=\"tel2\" value=\"\"><span class=\"contact__line\"> </span>\n                      <input class=\"contact__input contact__input-wd03\" type=\"text\" name=\"tel3\" value=\"\">\n                    </div>\n                  </div>\n                  <div class=\"contact__errorBox\">\n                                      </div>\n                </div>\n                <div class=\"contact__formItemBox\">\n                  <div class=\"contact__formItem\">\n                    <div class=\"contact__formItem-left contact__formItem-leftFlex\"><span class=\"contact__formItemName\">メールアドレス</span><span class=\"contact__formItemRequired\">必須</span></div>\n                    <div class=\"contact__formItem-right\">\n                      <input class=\"contact__input\" type=\"text\" name=\"mail\" value=\"\">\n                    </div>\n                  </div>\n                  <div class=\"contact__errorBox\">\n                                    </div>\n                </div>\n                <div class=\"contact__formItemBox\">\n                  <div class=\"contact__formItem contact__formItem-flexTop\">\n                    <div class=\"contact__formItem-left contact__formItem-leftFlex contact__formItem-left-mt\"><span class=\"contact__formItemName\">自由記入欄</span></div>\n                    <div class=\"contact__formItem-right\">\n                      <textarea class=\"contact__textarea\" name=\"content\" cols=\"30\" rows=\"10\"></textarea>\n                    </div>\n                  </div>\n                  <div class=\"contact__errorBox-textarea\">\n                                      </div>\n                </div>\n                <div class=\"contact__agreementBox\">\n                  <p class=\"contact__agreementTitle\">個人情報の取扱いなどの<br class=\"u-spDb\">同意項目について</p>\n                  <div class=\"contact__agreementContent\">\n                    <ul class=\"contact__agreementContentList\">\n                      <li class=\"contact__agreementContentItem\">1.お問い合わせ入力フォームに入力いただいた情報は、お問い合わせへの対応以外の目的では使用いたしません。</li>\n                      <li class=\"contact__agreementContentItem\">2.お客様から提供いただいた情報は、お問い合わせに対し適切なご回答をするために、当社の関係会社へ開示することがありますので、あらかじめご了承ください。</li>\n                      <li class=\"contact__agreementContentItem\">3.お問い合わせへのご回答には、お時間がかかる場合がございます（土曜、日曜・祝日は翌営業日以降のご対応とさせていただきます）。</li>\n                      <li class=\"contact__agreementContentItem\">4.お名前、ご連絡先などお問い合わせの際の必須の記載項目に不備がある場合、ご回答できない場合がございます。</li>\n                      <li class=\"contact__agreementContentItem\">5.当社グループ事業と直接関係のない内容に関するお問い合わせなど、内容によってはご回答できない場合もございますのであらかじめご了承ください。</li>\n                      <li class=\"contact__agreementContentItem\">6.当社からのご回答内容について、当社の許可なくお問い合わせの目的以外で使用されることはご遠慮ください。</li>\n                      <li class=\"contact__agreementContentItem\">7.当社個人情報の取扱いをご確認頂き、ご同意頂ける方は「同意する」にチェックを入れて、確認画面へ進んでください。</li>\n                    </ul>\n                    <div class=\"contact__agreementCheckBox\">\n                      <input class=\"contact__agreementCheck\" type=\"checkbox\" name=\"agreementCheck\" id=\"agreementCheck\" >\n                      <label class=\"contact__agreementCheckLabel\" for=\"agreementCheck\">同意する</label><span class=\"contact__formItemRequired\">必須</span>\n                    </div>\n                  </div>\n                  <div class=\"contact__errorBox-agree\">\n                                      </div>\n                </div>\n                <input type=\"hidden\" name=\"recaptchaResponse\" id=\"recaptchaResponse\">\n                <div class=\"contact__formBtnBox\">\n                  <button id=\"riset_input\" class=\"c-btnGray__normal c-btnGray__normal-cross\">リセット</button>\n                  <button class=\"c-btnGray__bold c-btnGray__bold-arrow\" type=\"submit\">確認画面へ</button>\n                </div>\n              </form>\n            </p>\n          </div>\n        </div>\n      </div>\n    </main>\n    <footer class=\"siteFooter\">\n      <div class=\"siteFooter__outer js-changeWidth\">\n        <div class=\"siteFooter__wrap\">\n          <div class=\"siteFooter__inner\">\n            <div class=\"siteFooter__logoBox\"><a class=\"siteFooter__logoLink\" href=\"../\"><img class=\"siteFooter__logo\" src=\"../_assets/images/common/footer_logo-pc.png\" alt=\"JFE環境テクノロジー株式会社\"></a></div>\n            <nav class=\"siteFooter__nav\" role=\"navigation\">\n              <ul class=\"siteFooter__list\">\n                <li class=\"siteFooter__listItem\"><a class=\"siteFooter__listItemLink\" href=\"../\">ホーム</a></li>\n                <li class=\"siteFooter__listItem\"> <a class=\"siteFooter__listItemLink\" href=\"../business/\">事業紹介</a></li>\n                <li class=\"siteFooter__listItem\"> <a class=\"siteFooter__listItemLink\" href=\"../company/\">会社情報</a></li>\n                <li class=\"siteFooter__listItem\"> <a class=\"siteFooter__listItemLink\" href=\"../recruit/\">採用情報</a></li>\n                <li class=\"siteFooter__listItem\"> <a class=\"siteFooter__listItemLink\" href=\"../topics/\">トピックス</a></li>\n                <li class=\"siteFooter__listItem\"> <a class=\"siteFooter__listItemLink\" href=\"../information_disclosure/\">情報公開</a></li>\n                <li class=\"siteFooter__listItem siteFooter__listItem-contact\"> <a class=\"siteFooter__listItemLink\" href=\"../inquiry/\">お問い合わせ</a></li>\n              </ul>\n              <div class=\"siteFooter__contactBox\"> <a class=\"siteFooter__contactLink\" href=\"../inquiry/\">お問い合わせ</a></div>\n            </nav>\n          </div>\n        </div>\n      </div>\n      <div class=\"siteFooter__wrapGray js-changeWidth\">\n        <div class=\"siteFooter__innerGray\">\n          <div class=\"siteFooter__innerGray-left\">\n            <div class=\"siteFooter__innerGrayLinkBox\"> <a class=\"siteFooter__innerGrayLink\" href=\"../