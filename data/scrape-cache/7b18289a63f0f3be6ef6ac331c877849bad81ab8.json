 (warning) {\n        warning.style.display = 'block';\n      }\n      \n      // プレースホルダーを設定\n      var monthInput = document.getElementById('expected_grad_date');\n      if (monthInput) {\n        monthInput.setAttribute('placeholder', 'YYYY-MM（例: 2025-03）');\n        monthInput.setAttribute('pattern', '\\\\d{4}-\\\\d{2}');\n      }\n    }\n  })();\n</script>\n\n\n","finalUrl":"https://www.jfe-et.co.jp/recruit_form/","rendered":false,"_cachedAt":"2026-06-22T22:37:31.222Z"}