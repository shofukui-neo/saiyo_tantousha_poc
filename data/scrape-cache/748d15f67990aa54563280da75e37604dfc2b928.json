catch(n){try{n=n[t(483)]()}catch(t){}r(o(n),c)}})()})();})();</script>\n<link href=\"https://gifu-np.ismcdn.jp/resources/gifu/css/pc/denshi.css?rd=2026/06/23 09:04\" rel=\"stylesheet\">\n</head>\n<body>\n<!-- Google Tag Manager (noscript) -->\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-MDTTJRD\"\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n<!-- End Google Tag Manager (noscript) -->\n<div class=\"l-wrap\">\n<div class=\"m-header --webmember\">\n<div class=\"m-header__logo\"><a href=\"/\"><img src=\"https://gifu-np.ismcdn.jp/common/images/site/logo_site.svg?rd=2026/06/23 09:04\" alt=\"岐阜新聞デジタル\"></a></div>\n</div>\n<div class=\"m-nav\">\n<nav class=\"l-inner m-nav__list\">\n<a class=\"m-nav__link\" href=\"/list/webmember/kiyaku\">ご利用規約</a>\n<a class=\"m-nav__link\" href=\"/list/webmember/top\">岐阜新聞デジタル会員とは</a>\n<a class=\"m-nav__link\" href=\"/list/webmember/regist\">お申し込み手順</a>\n<a class=\"m-nav__link\" href=\"/list/webmember/faq\">よくあるご質問</a>\n<a class=\"m-nav__link\" href=\"/list/webmember/tokusho\">特定商取引法に基づく表示</a>\n<a class=\"m-nav__link\" href=\"/list/webmember/privacy\">プライバシーポリシー</a>\n</nav>\n</div>\n  <div class=\"l-content l-inner\">\n    <main class=\"l-main-wide\">\n\n<div class=\"article-header\">\n  <h1 class=\"article-header__heading\">よくあるご質問</h1>\n</div>\n\n<div class=\"article-body\">\n<div class=\"denshi\">\r\n<div class=\"m-faq\">\r\n<h3 class=\"m-faq__heading\">ご入会前のご質問</h3>\r\n\r\n<div class=\"m-faq__block\">\r\n<div class=\"m-faq__q\">岐阜新聞を購読していないのですが、「宅配＋デジタルプラン」に申し込むことはできますか？</div>\r\n\r\n<div class=\"m-faq__a\">できません。「宅配＋デジタルプラン」は、岐阜新聞の購読者を対象にしたサービスです。岐阜新聞のご購読が必須となります。ご了承ください。</div>\r\n</div>\r\n\r\n<div class=\"m-faq__block\">\r\n<div class=\"m-faq__q\">法人契約はできますか？</div>\r\n\r\n<div class=\"m-faq__a\">「宅配＋デジタルプラン」「デジタルプラン」のご利用は個人に限らせていただいております。</div>\r\n</div>\r\n\r\n<div class=\"m-faq__block\">\r\n<div class=\"m-faq__q\">何日分の記事が読めますか？</div>\r\n\r\n<div class=\"m-faq__a\">岐阜新聞デジタルにおいて非会員は7日、「無料会員」は365日、「デジタルプラン」「併読＋デジタルプラン」は無期限となります。</div>\r\n</div>\r\n\r\n<div class=\"m-faq__block\">\r\n<div class=\"m-faq__q\">記事検索はできますか？</div>\r\n\r\n<div class=\"m-faq__a\">テキスト表示できない記事（表やグラフなど）や、画像化されているもの（テストの問題など）は検索できないものもございます。<br />\r\nまた、都合により元となる記事を削除した場合も検索できません。</div>\r\n</div>\r\n</div>\r\n\r\n<div class=\"m-faq\">\r\n<h3 class=\"m-faq__heading\">ご利用料金について</h3>\r\n\r\n<div class=\"m-faq__block\">\r\n<div class=\"m-faq__q\">支払方法はどのようになりますか？</div>\r\n\r\n<div class=\"m-faq__a\">岐阜新聞の読者がご入会いただける「併読＋デジタルプラン」の追加料金はございません。<br />\r\n「デジタルプラン」は、クレジットカード、キャリア決済（d払い、auかんたん決済、ソフトバンクまとめて支払い）となります。</div>\r\n\r\n<div class=\"m-faq__q\">「デジタルプラン」の利用料金は日割りにできますか？</div>\r\n\r\n<div class=\"m-faq__a\">日割りの課金はありません。解約された場合も日割りの返金はできません。</div>\r\n</div>\r\n</div>\r\n\r\n<div class=\"m-faq\">\r\n<h3 class=\"m-faq__heading\">ご入会時のご質問</h3>\r\n\r\n<div class=\"m-faq__block\">\r\n<div class=\"m-faq__q\">携帯電話（フィーチャーフォン）は対応していますか？</div>\r\n\r\n<div class=\"m-faq__a\">対応していません。パソコン、タブレット端末、スマートフォン等でお申し込みください。</div>\r\n\r\n<div class=\"m-faq__block\">\r\n<div class=\"m-faq__q\">「新規登録」のメールアドレスを登録しましたが手続き用メールが届きません。</div>\r\n\r\n<div class=\"m-faq__a\">スマートフォン・タブレット端末をご使用の場合で「メールを送信できませんでした」と表示される場合は、迷惑メール防止機能が設定されている可能性があります。<br />\r\n［gifu-np.co.jp］を受信可能なドメインとして設定してください。<br />\r\n<br />\r\n※迷惑メール防止機能の受信拒否などを設定していない場合でも、携帯電話以外からのメールは受信しないように標準で設定されていることがあります。<br />\r\n<br />\r\n【ご参考URL】<br />\r\n◆<a href=\"https://www.nttdocomo.co.jp/info/spam_mail/domain/\" target=\"_blank\">docomo</a>（指定受信／拒否設定）<br />\r\n◆<a href=\"https://www.au.com/support/service/mobile/trouble/mail/email/filter/\" target=\"_blank\">au</a>（迷惑メールフィルター機能）<br />\r\n◆<a href=\"https://www.softbank.jp/mobile/support/mail/antispam/mms/whiteblack/\" target=\"_blank\">SoftBank</a>（迷惑メールの個別設定）<br />\r\n◆<a href=\"https://www.ymobile.jp/support/faq/view/21378\" target=\"_blank\">Y!mobile</a>（設定：指定ドメイン受信を設定する）<br />\r\n◆<a href=\"https://www.uqwimax.jp/mobile/support/guide/mail/\" target=\"_blank\">UQ mobile</a>（メールサービス　迷惑メールフィルター設定方法）</div>\r\n</div>\r\n\r\n<div class=\"m-faq__block\">\r\n<div class=\"m-faq__q\">電話やファクス、販売店での入会申し込みはできますか？</div>\r\n\r\n<div class=\"m-faq__a\">できません。ご入会は岐阜新聞デジタルトップ画面にある「お申し込み」より行ってください。</div>\r\n</div>\r\n\r\n<div class=\"m-faq__block\">\r\n<div class=\"m-faq__q\">新聞購読者名が分かりません。</div>\r\n\r\n<div class=\"m-faq__a\">販売店から発行される領収書をご覧ください。</div>\r\n</div>\r\n</div>\r\n</div>\r\n\r\n<div class=\"m-faq\">\r\n<h3 class=\"m-faq__heading\">ご入会中のご質問</h3>\r\n\r\n<div class=\"m-faq__block\">\r\n<div class=\"m-faq__q\">ログインできません、どうしたらよいですか？</div>\r\n\r\n<div class=\"m-faq__a\">ID・パスワードに誤りはありませんか。大文字、小文字、全角、半角などに注意してもう一度入力してください。</div>\r\n</div>\r\n\r\n<div class=\"m-faq__block\">\r\n<div class=\"m-faq__q\">パスワードを変更したい。</div>\r\n\r\n<div class=\"m-faq__a\">マイページの「登録情報変更」からパスワードの変更を行ってください。</div>\r\n</div>\r\n\r\n<div class=\"m-faq__block\">\r\n<div class=\"m-faq__q\">パスワードを忘れました。</div>\r\n\r\n<div class=\"m-faq__a\">マイページ内の「パスワードをお忘れの方」よりパスワードの再発行を行ってください。</div>\r\n</div>\r\n\r\n<div class=\"m-faq__block\">\r\n<div class=\"m-faq__q\">プランを変更することはできますか？</div>\r\n\r\n<div class=\"m-faq__a\">マイページより変更を行ってください。</div>\r\n</div>\r\n\r\n<div class=\"m-faq__block\">\r\n<div class=\"m-faq__q\">メールアドレスが変更になりました。手続きは必要ですか？</div>\r\n\r\n<div class=\"m-faq__a\">メールアドレス変更時は、必ず「マイページ」の「登録情報変更」から「ID変更」を行ってください。<br />\r\n変更後は、ログイン時のIDも変更となりますのでご注意ください。</div>\r\n</div>\r\n\r\n<div class=\"m-faq__block\">\r\n<div class=\"m-faq__q\">引っ越しをしたのですが、どのような手続きが必要ですか？</div>\r\n\r\n<div class=\"m-faq__a\">引っ越しをされた場合は、「マイページ」の「登録情報変更」から「個人情報変更」をクリックして、住所、電話番号などの変更を行ってください。<br />\r\n<br />\r\n<br />\r\n※「宅配＋デジタルプラン」の方は住所変更をされなかった場合、引っ越し前の販売店では「購読確認」が取れなくなるため、継続してご覧いただくことができなくなります。</div>\r\n</div>\r\n</div>\r\n</div>\r\n\r\n<div class=\"m-faq\">\r\n<h3 class=\"m-faq__heading\">紙面ビューアについて</h3>\r\n\r\n<div class=\"m-faq__block\">\r\n<div class=\"m-faq__q\">紙面ビューアの購読に必要なものは何ですか？</div>\r\n\r\n<div class=\"m-faq__a\">ご利用いただくにはインターネットに接続したパソコン、またはスマートフォン、タブレット端末をご用意していただく必要があります。 従来の携帯電話（フィーチャーフォン）ではご利用いただけません。<br />\r\n購読には会員登録が必要になります。<br />\r\nパソコンやスマートフォンなどで受信できるメールアドレスが必要です。<br />\r\nデジタルプランは決済にクレジットカード、キャリア決済をご利用いただけます。</div>\r\n</div>\r\n\r\n<div class=\"m-faq__block\">\r\n<div class=\"m-faq__q\">家族で利用することはできますか？</div>\r\n\r\n<div class=\"m-faq__a\">同一世帯のご家族に限り「宅配＋デジタルプラン」は5人（5端末）、デジタルプランは2人（2端末）までご利用いただけます。<br />\r\n１契約１IDですので、同一ID、パスワードを共有していただきます。</div>\r\n</div>\r\n\r\n<div class=\"m-faq__block\">\r\n<div class=\"m-faq__q\">インターネット接続ができない環境でも使用できますか？</div>\r\n\r\n<div class=\"m-faq__a\">使用することはできません。紙面情報を取得するため、常時接続されている必要があります。</div>\r\n</div>\r\n\r\n<div class=\"m-faq__block\">\r\n<div class=\"m-faq__q\">スマートフォンで「パソコン版」を見られますか？</div>\r\n\r\n<div class=\"m-faq__a\">スマートフォンでは「スマートフォン版」のみご覧いただけます。</div>\r\n</div>\r\n\r\n<div class=\"m-faq__block\">\r\n<div class=\"m-faq__q\">記事を印刷することはできますか？</div>\r\n\r\n<div class=\"m-faq__a\">クリップした記事、紙面全体が印刷できます。<br />\r\n※パソコン版のみの機能となります。</div>\r\n</div>\r\n\r\n<div class=\"m-faq__block\">\r\n<div class=\"m-faq__q\">紙面は毎日何時の更新ですか？</div>\r\n\r\n<div class=\"m-faq__a\">毎朝５時ごろ更新です。<br />\r\n※休刊日は除く</div>\r\n</div>\r\n\r\n<div class=\"m-faq__block\">\r\n<div class=\"m-faq__q\">何日分の紙面が読めますか？</div>\r\n\r\n<div class=\"m-faq__a\">紙面イメージは当日を含め30日分です。</div>\r\n</div>\r\n\r\n<div class=\"m-faq__block\">\r\n<div class=\"m-faq__q\">記事検索はできますか？</div>\r\n\r\n<div class=\"m-faq__a\">紙面ビューアでは過去９０日分の記事の中から検索ができます。<br />\r\nテキスト表示できない記事（表やグラフなど）や、画像化されているもの（テストの問題など）は検索できないものもございます。<br />\r\nまた、都合により元となる記事を削除した場合も検索できません。</div>\r\n</div>\r\n\r\n<div class=\"m-faq__block\">\r\n<div class=\"m-faq__q\">クリップできる記事本数に制限はありますか？</div>\r\n\r\n<div class=\"m-faq__a\">制限はあります。上限に達した場合は削除することで新しい記事をクリップすることができます。<br />\r\nまた都合により、元となる記事を削除した場合、閲覧できなくなる場合がございます。</div>\r\n</div>\r\n\r\n<div class=\"m-faq__block\">\r\n<div class=\"m-faq__q\">真っ白な画面が出て紙面が表示されません。</div>\r\n\r\n<div class=\"m-faq__a\">リロード（更新）ボタンを押した場合、ブラウザに搭載された「戻る」ボタンを押した場合に発生することがあります。その場合、「紙面ビューア」のトップからログインしなおしてください。<br />\r\n※前のページに戻る場合は、紙面ビューアの画面内にあります（戻る）ボタンを押してください。</div>\r\n</div>\r\n\r\n<div class=\"m-faq__block\">\r\n<div class=\"m-faq__q\">「タイムアウトになりました。ログイン画面に戻りますか？」と表示されます。</div>\r\n\r\n<div class=\"m-faq__a\">紙面ビューアをログアウト（終了）せずに一定時間が経過すると、自動的にログアウトする仕様となっております。紙面ビューアをご覧になるには、再度ログインしてください。</div>\r\n</div>\r\n</div>\r\n\r\n<div class=\"m-faq\">\r\n<h3 class=\"m-faq__heading\">退会について</h3>\r\n\r\n<div class=\"m-faq__block\">\r\n<div class=\"m-faq__q\">退会するにはどうしたらいいですか？</div>\r\n\r\n<div class=\"m-faq__a\">岐阜新聞デジタル会員の解約は「マイページ」の「岐阜新聞デジタル会員の退会予約」から行います。<br />\r\n月半ばでの解約申請は「予約」のかたちで行います。予約をいただくと当月末日に解約となります。</div>\r\n</div>\r\n</div>\r\n\n</div>    </main>\n  </div>\n<footer class=\"m-footer overlay-none\">\n  <div class=\"m-footer-bottom\">\n    <div class=\"l-inner m-footer-bottom__wrap\">\n      <div class=\"m-footer-bottom__logo\"><img src=\"https://gifu-np.ismcdn.jp/common/images/site/footer-logo_2022.png\" alt=\"岐阜新聞社\"></div>\n      <div class=\"m-footer-bottom__text\">\n        <div class=\"m-footer-address\">岐阜新聞社<br>〒500-8577　岐阜県岐阜市今小町10<br>058(264)1151（代表）</div>\n        <div class=\"m-footer-notes\">当サイトに掲載されている記事・写真の無断転載を禁じます。著作権は岐阜新聞社または配信元の通信社、情報提供者に帰属します。</div>\n        <div class=\"m-footer-copylight\">© 岐阜新聞社</div>\n      </div>\n    </div>\n  </div>\n</footer></div>\n<script type=\"text/javascript\">\n  window._taboola = window._taboola || [];\n  _taboola.push({flush: true});\n</script>\n<script\n  src=\"https://code.jquery.com/jquery-3.5.1.min.js\"\n  integrity=\"sha256-9/aliU8dGd2tb6OSsuzixeV4y/faTqgFtohetphbbj0=\"\n  crossorigin=\"anonymous\"></script>\n<script src=\"https://gifu-np.ismcdn.jp/common/js/lib/lozad.min.js\"></script>\n<script src=\"https://gifu-np.ismcdn.jp/common/js/lib/ofi.min.js\"></script>\n<div class=\"measurement\" style=\"display:none;\">\n<script src=\"/oo/np/lsync.js\" async></script>\n<script>\nvar MiU=MiU||{};MiU.queue=MiU.queue||[];\nvar mwdata = {\n  'media': 'www.gifu-np.co.jp',\n  'skin': 'cc/webmember/default',\n  'id': '',\n  'category': '',\n  'subcategory': '',\n  'model': '',\n  'modelid': ''\n}\nMiU.queue.push(function(){MiU.fire(mwdata);});\n</script>\n</div></body>\n</html>\n","finalUrl":"https://www.gifu-np.co.jp/list/webmember/faq","rendered":false,"_cachedAt":"2026-06-23T16:21:33.795Z"}