{"url":"https://www.jp.nikon.com/contacts/form/","html":"<!doctype html>\r\n<html lang=\"ja\" class=\"no-js\">\r\n<head>\r\n<meta charset=\"utf-8\">\r\n<title>投資家情報、サステナビリティ、その他企業活動、本ウェブサイトに関するお問い合わせ | お問い合わせ | Nikon</title>\r\n<meta name=\"description\" content=\"ニコンのお問い合わせフォーム（投資家情報、サステナビリティ、本ウェブサイトについて）です。\">\r\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\r\n<meta name=\"format-detection\" content=\"telephone=no\">\r\n<!--JSオン／オフ環境で表示を切り替えるための処理-->\n<script>document.documentElement.classList.replace(\"no-js\", \"js\");</script>\n\n<!-- www.jp.nikon.com に対する OneTrust Cookie 同意通知の始点 -->\n<script src=\"https://cdn.cookielaw.org/scripttemplates/otSDKStub.js\"  type=\"text/javascript\" charset=\"UTF-8\" data-domain-script=\"0ae0e496-916e-4717-8f0f-c6e9c72c4a4a\" ></script>\n<script type=\"text/javascript\">\nfunction OptanonWrapper() { }\n</script>\n<!-- www.jp.nikon.com に対する OneTrust Cookie 同意通知の終点 -->\n\n<script type=\"text/plain\" class=\"optanon-category-C0003\">(function(){var styleTag = document.createElement('style');styleTag.innerText = \".onetrust-movie-overlay-C0003{display:none;}\";document.getElementsByTagName('head')[0].insertAdjacentElement('beforeend', styleTag);})();</script>\n<script type=\"text/plain\" class=\"optanon-category-C0004\">(function(){var styleTag = document.createElement('style');styleTag.innerText = \".onetrust-movie-overlay-C0004{display:none;}\";document.getElementsByTagName('head')[0].insertAdjacentElement('beforeend', styleTag);})();</script>\n\r\n<link rel=\"stylesheet\" href=\"/assets/css/common.css\">\r\n<link rel=\"stylesheet\" href=\"/assets/css/form/form.css\">\r\n<link rel=\"stylesheet\" href=\"/assets/css/form/swip-form.css\">\r\n<link rel=\"stylesheet\" href=\"/assets/css/form/swip_mail_api.css\">\r\n<link rel=\"stylesheet\" href=\"/assets/css/form/fontawesome-all.css\">\r\n<script src=\"/assets/js/common.js\" defer></script>\r\n<script src=\"/contacts/form/js/swip_form_key.js\"></script>\r\n<script src=\"/assets/js/form/jquery-3.6.0.min.js\"></script>\r\n<script src=\"/assets/js/form/swip_site-2.0.js\"></script>\r\n<script src=\"/assets/js/form/swip_form_api-2.0.js\"></script>\r\n<script src=\"/assets/js/form/swip_form_function-2.0.js\"></script>\r\n<script src=\"/assets/js/form/swip_form_env.js\"></script>\r\n<script type=\"text/plain\" class=\"optanon-category-C0002\" src=\"//rt.nc0006rtbc.nikon.com/bcx/rt_tag.js\" onload=\"bcxBeacon.send()\"></script>\n<script type=\"text/javascript\">\nfunction click_send(s) {\nif(typeof(bcxBeacon) != \"undefined\"){\nbcxBeacon.setAltName(s);\nbcxBeacon.send();\n}}\n</script>\n\n<!-- User Insight PCDF Code Start -->\n<script type=\"text/plain\" class=\"optanon-category-C0002\">\nvar _uic = _uic ||{}; var _uih = _uih ||{};_uih['id'] = 56372;\n_uih['lg_id'] = '';\n_uih['fb_id'] = '';\n_uih['tw_id'] = '';\n_uih['uigr_1'] = ''; _uih['uigr_2'] = ''; _uih['uigr_3'] = ''; _uih['uigr_4'] = ''; _uih['uigr_5'] = '';\n_uih['uigr_6'] = ''; _uih['uigr_7'] = ''; _uih['uigr_8'] = ''; _uih['uigr_9'] = ''; _uih['uigr_10'] = '';\n_uic['uls'] = 1;\n_uic['security_type'] = -1;\n\n/* DO NOT ALTER BELOW THIS LINE */\n(function() {\nvar bi = document.createElement('script');bi.type = 'text/javascript'; bi.async = true;\nbi.src = '//cs.nakanohito.jp/b3/bi.js';\nvar s = document.getElementsByTagName('script')[0];s.parentNode.insertBefore(bi, s);\n})();\n</script>\n<!-- User Insight PCDF Code End -->\n\n<!--Tags Header Embed Code: REPLACE THE NEXT LINE WITH THE EMBED CODE FROM YOUR OWN DEVELOPMENT ENVIRONMENT-->\n<script src=\"https://assets.adobedtm.com/202e3357fcdd/f98042ff2ff9/launch-d9d1375f9608.min.js\" async></script>\n<!--/Tags Header Embed Code-->\r\n</head>\r\n<body class=\"Page\">\r\n<div class=\"wrapper\">\r\n<div class=\"head-navi\">\r\n<div class=\"head-navi-inner\">\r\n<header class=\"header\" id=\"header\">\n<div class=\"header-inner\">\n<div class=\"header__region\">株式会社ニコン｜Japan</div>\n<div class=\"header__logoSet\">\n<h1 class=\"header__logo\"><a href=\"/\"><img src=\"/assets/img/logo.svg\" width=\"68\" height=\"68\" alt=\"Nikon\"></a></h1>\n</div>\n<div class=\"header__utility\">\n<ul class=\"header__utility__links\">\n<li class=\"header__utility__link header__utility__sites\"><a href=\"/business/\">法人のお客様<span class=\"header__utility__overview\">ものづくり、先端医療、研究開発。幅広い現場をニコンの製品・ソリューションが支えます</span></a></li>\n<li class=\"header__utility__link header__utility__sites\"><a href=\"/consumer/\">個人のお客様<span class=\"header__utility__overview\">カメラ、レンズ、双眼鏡、補聴器。ニコンの商品・ソリューションが人々の日常を豊かに彩ります</span></a></li>\n<li class=\"header__utility__link header__utility__sites\"><a href=\"/company/\">企業情報<span class=\"header__utility__overview\">企業情報、サステナビリティ、投資家情報から、今を伝える最新情報までお伝えします</span></a></li>\n<li class=\"header__utility__search\"><a class=\"header__search-button\" href=\"/search/\"><span class=\"u-visually-hidden\">検索</span></a></li>\n<li class=\"header__utility__link header__utility__global\"><a href=\"https://www.nikon.com/\" target=\"_blank\" onclick=\"click_send('/External-link_www.nikon.com/'); return true;\">Global Site<span class=\"u-visually-hidden\"> 別窓で遷移します</span></a></li>\n</ul>\n</div>\n</div>\n<div class=\"header__search\">\n<div class=\"header__search-inner\">\n<div class=\"header__search__form\" role=\"search\">\n<form id=\"commonSearch\" name=\"commonSearch\" action=\"/search/\" method=\"get\">\n<input type=\"hidden\" value=\"1:b2b,1:b2c,1:corp\" name=\"r\">\n<input type=\"text\" name=\"q\" size=\"20\" placeholder=\"検索キーワードを入力してください\" aria-label=\"検索キーワード\"><button type=\"submit\"><span class=\"u-visually-hidden\">検索</span></button>\n</form>\n</div>\n</div>\n</div>\n\n</header><!-- /.header -->\n\r\n<nav class=\"global-navi\">\n<div class=\"global-navi-inner\">\n<h2 class=\"u-visually-hidden\" id=\"global-navi-label\">グローバルナビゲーション</h2>\n<div class=\"global-navi__button\">\n<button>\n<span class=\"u-visually-hidden global-navi__button__label\">メニュー</span>\n<span class=\"global-navi__hamburger\">\n<span class=\"global-navi__hamburger_bar1\"></span>\n<span class=\"global-navi__hamburger_bar2\"></span>\n<span class=\"global-navi__hamburger_bar3\"></span>\n</span>\n</button>\n</div>\n<div class=\"global-navi__wrap\">\n<div class=\"global-navi__utility\">\n<ul class=\"global-navi__utility__links\">\n</ul>\n</div>\n</div>\n</div>\n</nav><!-- /.global-navi -->\n\r\n</div><!-- /.head-navi-inner -->\r\n</div><!-- /.head-navi -->\r\n\r\n<nav class=\"c-breadcrumb\" aria-label=\"パンくずリスト\">\r\n<ol>\r\n<li><a href=\"/\">ホーム</a></li>\r\n<li><a href=\"/contacts/\">お問い合わせ</a></li>\r\n<li><a aria-current=\"page\">投資家情報、サステナビリティ、その他企業活動、本ウェブサイトに関するお問い合わせ</a></li>\r\n</ol>\r\n</nav><!-- /.c-breadcrumb -->\r\n\r\n<main class=\"main\">\r\n<div class=\"main-inner\" id=\"contentsAreaTitle\">\r\n<form id=\"inquiryForm\" onsubmit=\"return false;\" method=\"post\" novalidate=\"novalidate\" name=\"text\">\r\n<div class=\"main-narrow\" id=\"contentsArea\">\r\n<h1 class=\"c-heading-a\">投資家情報、サステナビリティ、その他企業活動、本ウェブサイトに関するお問い合わせ</h1>\r\n\r\n<!-- c-form-step -->\r\n<ol class=\"c-form-step\">\r\n<li class=\"c-form-step__caption c-form-step__caption--current\" aria-hidden=\"false\"><span>入力</span></li>\r\n<li class=\"c-form-step__caption\" aria-hidden=\"true\"><span>入力内容の確認</span></li>\r\n<li class=\"c-form-step__caption\" aria-hidden=\"true\"><span>送信完了</span></li>\r\n</ol>\r\n<!-- /.c-form-step -->\r\n\r\n<p class=\"c-text\">企業活動、ウェブサイトに関するお問い合わせ、ご意見・ご感想は下記フォームをご利用ください。</p>\r\n\r\n<div class=\"c-panel c-panel--grey u-mt-08\">\r\n<p class=\"panel-text\">その他のお問い合わせは、「お問い合わせ」ページよりお問い合わせください。</p>\r\n\r\n<ul class=\"c-link-list c-link-list--inline-block\">\r\n<li><a href=\"/contacts/\">お問い合わせ</a></li>\r\n</ul><!-- /.c-link-list -->\r\n</div>\r\n\r\n\r\n\r\n\r\n<div id=\"err_message_top\"></div>\r\n<div id=\"err_message_summary\"></div>\r\n\r\n<h2 class=\"c-heading-b\">お問い合わせ入力欄</h2>\r\n\r\n<div class=\"c-form\">\r\n<div class=\"c-form__group c-form__group--narrow\" id=\"err_attribute_1\">\r\n<fieldset>\r\n<legend>\r\n<span class=\"c-form__title\">\r\n<span class=\"c-form__label\">\r\n<span class=\"c-form__label__text\"><span class=\"c-form__icon is--required\">必須</span>お問い合わせ種別</span>\r\n</span>\r\n</span>\r\n</legend>\r\n<div class=\"c-form__content form__radioList formInputRadio\" id=\"request_type\" name=\"お問い合わせ種別\" require_check=\"required\" data-index-number=\"1\" data-error-type='{\"msg\":true,\"attr\":true}'>\r\n<div id=\"err_message_1\"  data-errclass=\"c-form__errorText\"></div>\r\n<div class=\"c-form__radio\">\r\n<label><input name=\"request_type\" type=\"radio\"  value=\"投資家情報\" required>投資家情報</label>\r\n<label><input name=\"request_type\" type=\"radio\"  value=\"サステナビリティ\">サステナビリティ</label>\r\n<label><input name=\"request_type\" type=\"radio\"  value=\"その他企業活動\">その他企業活動</label>\r\n<label><input name=\"request_type\" type=\"radio\"  value=\"本ウェブサイトについて\">本ウェブサイトについて</label>\r\n</div>\r\n</div>\r\n</fieldset>\r\n</div>\r\n\r\n<div class=\"c-form__group\" id=\"err_attribute_2\">\r\n<div class=\"c-form__title\">\r\n<label class=\"c-form__label\" for=\"request_content\">\r\n<span class=\"c-form__label__text\"><span class=\"c-form__icon is--required\">必須</span>お問い合わせ内容</span>\r\n</label>\r\n</div>\r\n<div class=\"c-form__content\">\r\n<div id=\"err_message_2\" data-errclass=\"c-form__errorText\"></div>\r\n<textarea name=\"お問い合わせ内容\" type=\"text\" value=\"\" class=\"c-form__control formInput\" id=\"request_content\" require_check=\"required\" maxlength=\"1000\" validation_type=\"string\" data-index-number=\"2\" data-error-type='{\"msg\":true,\"attr\":true}'></textarea>\r\n</div>\r\n</div>\r\n</div>\r\n\r\n<h2 class=\"c-heading-b\">お客様情報</h2>\r\n<div class=\"c-form\">\r\n<div class=\"c-form__group\" id=\"err_attribute_3\">\r\n<div class=\"c-form__title\">\r\n<label class=\"c-form__label\" for=\"mail_address\">\r\n<span class=\"c-form__label__text\"\r\n><span class=\"c-form__icon is--required\">必須</span>メールアドレス</span>\r\n</label>\r\n</div>\r\n<div class=\"c-form__content\">\r\n<div id=\"err_message_3\" data-errclass=\"c-form__errorText\"></div>\r\n<input type=\"email\" name=\"メールアドレス\" value=\"\" class=\"c-form__control formInput\" id=\"mail_address\" require_check=\"required\" autocomplete=\"email\" maxlength=\"100\" validation_type=\"mail\" data-index-number=\"3\" data-error-type='{\"msg\":true,\"attr\":true}'>\r\n</div>\r\n</div>\r\n\r\n<div class=\"c-form__group\" id=\"err_attribute_4\">\r\n<div class=\"c-form__title\">\r\n<label class=\"c-form__label\" for=\"validation_mail_address\">\r\n<span class=\"c-form__label__text\"><span class=\"c-form__icon is--required\">必須</span>メールアドレス（再入力）</span>\r\n<span class=\"c-form__description\">※確認のため、メールアドレスをもう一度ご入力ください。</span>\r\n</label>\r\n</div>\r\n<div class=\"c-form__content\">\r\n<div id=\"err_message_4\" data-errclass=\"c-form__errorText\"></div>\r\n<input type=\"email\" name=\"メールアドレス（再入力）\" value=\"\" class=\"c-form__control formInput\" id=\"validation_mail_address\" require_check=\"required\" autocomplete=\"email\" maxlength=\"100\" validation_type=\"mail\" data-index-number=\"4\" data-error-type='{\"msg\":true,\"attr\":true}'>\r\n</div>\r\n</div>\r\n</div><!-- /.c-form -->\r\n\r\n<div class=\"c-panel c-panel--grey u-mt-12\">\r\n<p class=\"panel-text\">お客様にご入力いただきました個人情報は、当該お問い合わせ、ご意見・ご感想への回答以外の目的で使用する事はございません。また、お客様の個人情報を適切に取扱うことが当社の重要な社会的責務と考え、個人情報の保護に努めております。詳細については「個人情報保護について」をご覧ください。ご入力いただいた情報は暗号化され送信されます。</p>\r\n<ul class=\"c-link-list\">\r\n<li><a href=\"/privacy/\">個人情報保護について</a></li>\r\n</ul><!-- /.c-link-list -->\r\n<dl class=\"c-definitionlist\">\r\n<dt class=\"u-fwn\">このフォームについてのお問い合わせ先：</dt>\r\n<dd>株式会社ニコン 経営戦略本部 広報部</dd>\r\n</dl><!-- /.c-definitionlist -->\r\n<ul class=\"c-link-list\">\r\n<li><a href=\"/privacy/form/\">個人情報の取扱いに関するお問い合わせ</a></li>\r\n</ul><!-- /.c-link-list -->\r\n</div><!-- /.c-panel -->\r\n\r\n<p class=\"c-text\">上記事項をご確認の上、ご同意いただける方は「同意して入力確認に進む」を押してください。</p>\r\n\r\n<div class=\"c-form-paging\">\r\n<button type=\"submit\" id=\"confirm\" class=\"c-button\"><span>同意して入力確認に進む</span></button>\r\n</div>\r\n\r\n<h2 class=\"c-heading-b\">免責事項</h2>\r\n\r\n<p class=\"c-text\">あなたがメールフォームまたは他の手段でこのウェブサイトに送付するいかなるアイデア、コンセプト、示唆またはコメント（以下 “アイデア等” と言います）について、株式会社ニコン（以下 “ニコン” と言います）は、監視する義務を負いません。また、ニコンは、あなたがアイデア等をニコンに送付した時点で、あなたが当該アイデア等に関する一切の権利を放棄したものとみなします。ニコンは当該アイデア等について守秘義務を負わず、当該アイデア等から生じるいかなる問題についても一切責任を負いません。<br>\r\n製品のお問い合わせについては、お受けしておりませんので、ご注意ください。</p>\r\n</div>\r\n</form>\r\n\r\n<!-- 確認画面 -->\r\n<div class=\"main-narrow\" id=\"contentsAreaConfirm\" style=\"display: none\">\r\n<h1 class=\"c-heading-a\">投資家情報、サステナビリティ、その他企業活動、本ウェブサイトに関するお問い合わせ</h1>\r\n\r\n<ol class=\"c-form-step\">\r\n<li class=\"c-form-step__caption\" aria-hidden=\"true\"><span>入力</span></li>\r\n<li class=\"c-form-step__caption c-form-step__caption--current\" aria-hidden=\"false\"><span>入力内容の確認</span></li>\r\n<li class=\"c-form-step__caption\" aria-hidden=\"true\"><span>送信完了</span></li>\r\n</ol>\r\n<!-- /.c-form-step -->\r\n\r\n<p class=\"c-text\">\r\n入力内容をご確認ください。<br>よろしければ「送信する」を押してください。修正する場合は「修正する」を押してください。\r\n</p>\r\n\r\n<h2 class=\"c-heading-b\">お問い合わせ入力欄</h2>\r\n<table class=\"c-table c-table--horizontal\">\r\n<colgroup>\r\n<col class=\"c-table__cell-40\">\r\n<col class=\"c-table__cell-60\">\r\n</colgroup>\r\n<tbody>\r\n<tr>\r\n<th>お問い合わせ種別</th>\r\n<td><span id=\"request_type_con\" class=\"formInputConfirm\" name=\"お問い合わせ種別\"></span></td>\r\n</tr>\r\n<tr>\r\n<th>お問い合わせ内容</th>\r\n<td><span id=\"request_content_con\" class=\"formInputConfirm\" name=\"お問い合わせ内容\"></span></td>\r\n</tr>\r\n</tbody>\r\n</table>\r\n<!-- /.c-table -->\r\n\r\n<h2 class=\"c-heading-b\">お客様情報</h2>\r\n<table class=\"c-table c-table--horizontal\">\r\n<colgroup>\r\n<col class=\"c-table__cell-40\">\r\n<col class=\"c-table__cell-60\">\r\n</colgroup>\r\n<tbody>\r\n<tr>\r\n<th>メールアドレス</th>\r\n<td><span id=\"mail_address_con\" class=\"formInputConfirm\" name=\"メールアドレス\"></span></td>\r\n</tr>\r\n</tbody>\r\n</table>\r\n<!-- /.c-table -->\r\n\r\n<div class=\"c-form_captcha\">\r\n<div class=\"c-form__paging_captcha\">\r\n<form method=\"POST\" style=\"display: inline\" onsubmit=\"return false;\">\r\n<p class=\"c-text_captcha\"><em id=\"captcha_message\" class=\"u-red\"></em></p>\r\n<p class=\"c-text_captcha\">画像に表示されている文字列を入力してください。</p>\r\n<div id=\"swip_indicator\" style=\"height: 80px; display: block; padding-bottom: 10px\">\r\n<div style=\"margin: 0 auto\">\r\n<img src=\"/assets/img/form/loading.gif\" border=\"0\">\r\n</div>\r\n</div>\r\n<div id=\"swip_captcha\" style=\"height: 80px; display: none; padding-bottom: 10px\">\r\n<img class=\"c_captcha_img\" src=\"/assets/img/form/loading.gif\" id=\"captcha\" style=\"border: 1px solid #e6e6e6; padding: 1px\">\r\n<div style=\"display: inline-flex;align-items: flex-end;color: green;\" id=\"get_captcha\">\r\n<i class=\"fas fa-sync-alt fa-lg\"></i>\r\n</div>\r\n</div>\r\n\r\n<div style=\"display: block; padding-bottom: 10px\">\r\n<input id=\"captcha_code_input\" type=\"text\" name=\"captcha_code_input\" style=\"min-width: 100px; max-width: 222px\" autocomplete=\"off\">\r\n</div>\r\n\r\n<div class=\"c-form-paging\">\r\n<button type=\"submit\" id=\"back_btn\" class=\"c-button c-button--cancel\"><span>修正する</span></button>\r\n<button type=\"submit\" id=\"exec_btn\" class=\"c-button\"><span>送信する</span></button>\r\n</div>\r\n</form>\r\n</div>\r\n</div>\r\n<!-- /.c-form -->\r\n</div>\r\n<!-- 送信完了画面 -->\r\n<div class=\"main-narrow\" id=\"contentsAreaResult\" style=\"display: none\">\r\n<h1 class=\"c-heading-a\">\r\n投資家情報、サステナビリティ、その他企業活動、本ウェブサイトに関するお問い合わせ\r\n</h1>\r\n\r\n<!-- c-form-step -->\r\n<ol class=\"c-form-step\">\r\n<li class=\"c-form-step__caption\" aria-hidden=\"true\"><span>入力</span></li>\r\n<li class=\"c-form-step__caption\" aria-hidden=\"true\"><span>入力内容の確認</span></li>\r\n<li class=\"c-form-step__caption c-form-step__caption--current\" aria-hidden=\"false\"><span>送信完了</span></li>\r\n</ol>\r\n<!-- /.c-form-step -->\r\n\r\n<p class=\"c-text\">送信が完了しました。</p>\r\n\r\n<p class=\"c-text\">\r\n確認のため、お客様が入力されたメールアドレス宛にメールを送信しました。<br>\r\nメールが届かない場合はメールアドレスの入力を誤った可能性がありますので、ご確認の上、再度お問い合わせください。\r\n</p>\r\n</div>\r\n<!-- エラー画面 -->\r\n<div class=\"main-narrow\" id=\"contentsAreaError\" style=\"display: none;\">\r\n\r\n<h1 class=\"c-heading-a\">投資家情報、サステナビリティ、その他企業活動、本ウェブサイトに関するお問い合わせ</h1>\r\n\r\n<!-- c-form-step -->\r\n<ol class=\"c-form-step\">\r\n<li class=\"c-form-step__caption\" aria-hidden=\"true\"><span>入力</span></li>\r\n<li class=\"c-form-step__caption\" aria-hidden=\"true\"><span>入力内容の確認</span></li>\r\n<li class=\"c-form-step__caption\" aria-hidden=\"true\"><span>送信完了</span></li>\r\n</ol>\r\n<!-- /.c-form-step -->\r\n\r\n<p class=\"c-text\">大変申し訳ございません。</p>\r\n<p class=\"c-text\">何らかの問題により、システムが正常動作しておりません。<br>\r\n大変お手数ですが、時間をおいて再度お試しください。</p>\r\n\r\n<div class=\"c-form-paging\">\r\n<button type=\"submit\" id=\"back_input_btn\" class=\"c-button c-button--cancel\">修正する</button>\r\n</div>\r\n</div><!-- /.main-narrow -->\r\n</div><!-- /.main-inner -->\r\n</main><!-- /.main -->\r\n\r\n<footer class=\"footer\">\r\n<div class=\"footer__row\">\r\n<div class=\"footer__row-inner\">\r\n<div class=\"footer__divider1\">\r\n<div class=\"footer__information\">\r\n<ul class=\"footer__information__links\">\r\n<li class=\"footer__information__link\"><a href=\"/company/news/\">ニュース</a></li>\r\n<li class=\"footer__information__link\"><a href=\"/company/updates/\">サイト更新情報</a></li>\r\n<li class=\"footer__information__link\"><a href=\"/company/rss/\">RSSについて</a></li>\r\n<li class=\"footer__information__link\"><a href=\"/socialmedia/\">ソーシャルメディアアカウント</a></li>\r\n</ul>\r\n</div>\r\n</div>\r\n</div>\r\n</div>\r\n<div class=\"footer__row footer__row--border\">\r\n<div class=\"footer__row-inner\">\r\n<div class=\"footer__divider2\">\r\n<div class=\"footer__utility\">\r\n<ul class=\"footer__utility__links\">\r\n<li class=\"footer__utility__link\"><a href=\"/contacts/\">お問い合わせ</a></li>\r\n<li class=\"footer__utility__link\"><a href=\"/privacy/\">個人情報保護について</a></li>\r\n<li class=\"footer__utility__link\"><a href=\"/usage/\">利用規程</a></li>\r\n<li class=\"footer__utility__link\"><a href=\"/cookie/\">クッキーノーティス</a></li>\r\n</ul>\r\n</div>\r\n<div class=\"footer__globalSite\">\r\n<a href=\"https://www.nikon.com/\" target=\"_blank\" onclick=\"click_send('/External-link_www.nikon.com/'); return true;\">Global Site<span class=\"u-visually-hidden\"> 別窓で遷移します</span></a>\r\n</div>\r\n<div class=\"footer__logo\">\r\n<div class=\"footer__brand\"><img src=\"/assets/img/logo_footer_jp.svg\" width=\"80\" height=\"12\" alt=\"株式会社ニコン\"></div>\r\n<p class=\"footer__copyright\">&copy; 2026 Nikon Corporation</p>\r\n</div>\r\n</div>\r\n</div>\r\n</div>\r\n<p class=\"c-link-pagetop\"><a href=\"#header\"><span class=\"u-visually-hidden\">ページの先頭へ戻る</span></a></p>\r\n</footer><!-- /.footer -->\r\n\r\n</div><!-- /.wrapper -->\r\n</body>\r\n</html>\r\n","finalUrl":"https://www.jp.nikon.com/contacts/form/","rendered":false,"_cachedAt":"2026-06-23T20:40:03.731Z"}