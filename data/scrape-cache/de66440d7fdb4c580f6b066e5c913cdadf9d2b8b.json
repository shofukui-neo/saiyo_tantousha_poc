{"url":"https://www.e-deftribe.com/recruit/jobs/","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n  <head>\n    <meta charset=\"utf-8\" />\n    <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\" />\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n    <meta name=\"format-detection\" content=\"telephone=no\" />\n    <title>Def tribeの魅力｜大阪でITの最先端を走る</title>\n    <link\n      rel=\"icon\"\n      type=\"image/png\"\n      href=\"../assets/images/common/favicons.png\"\n    />\n    <link\n      rel=\"apple-touch-icon\"\n      href=\"../assets/images/common/apple-touch-icon.png\"\n      sizes=\"180x180\"\n    />\n    <meta\n      content=\"「働く時間がもっと楽しくなる」Def tribeの魅力的な働くメリットと多彩なアクティビティをご紹介します。他社には負けない充実した福利厚生、実力で上がる給与、きちんと取れる休暇、楽しいアクティビティのある職場は、なにもかも「条件がいい」。\"\n      name=\"description\"\n    />\n    <meta\n      content=\"Def tribe, IT企業 転職 大阪,システム エンジニア 給料,SE 給料\"\n      name=\"keywords\"\n    />\n    <meta\n      property=\"og:url\"\n      content=\"https://www.e-deftribe.com/recruit/jobs/\"\n    />\n    <meta\n      property=\"og:site_name\"\n      content=\"大阪でITの最先端を走る Def tribeリクルート\"\n    />\n    <meta\n      property=\"og:title\"\n      content=\"Def tribeの魅力｜大阪でITの最先端を走る\"\n    />\n    <meta\n      property=\"og:description\"\n      content=\"「働く時間がもっと楽しくなる」Def tribeの魅力的な働くメリットと多彩なアクティビティをご紹介します。他社には負けない充実した福利厚生、実力で上がる給与、きちんと取れる休暇、楽しいアクティビティのある職場は、なにもかも「条件がいい」。\"\n    />\n    <meta\n      property=\"og:image\"\n      content=\"https://www.e-deftribe.com/recruit/assets/images/common/ogp.png\"\n    />\n    <meta property=\"og:type\" />\n    <meta property=\"og:locale\" content=\"ja_JP\" />\n    <meta name=\"twitter:card\" content=\"summary_large_image\" />\n    <meta\n      name=\"twitter:title\"\n      content=\"Def tribeの魅力｜大阪でITの最先端を走る\"\n    />\n    <meta\n      name=\"twitter:description\"\n      content=\"「働く時間がもっと楽しくなる」Def tribeの魅力的な働くメリットと多彩なアクティビティをご紹介します。他社には負けない充実した福利厚生、実力で上がる給与、きちんと取れる休暇、楽しいアクティビティのある職場は、なにもかも「条件がいい」。\"\n    />\n    <meta\n      name=\"twitter:image\"\n      content=\"https://www.e-deftribe.com/recruit/assets/images/common/ogp.png\"\n    />\n    <link rel=\"stylesheet\" href=\"../assets/css/style.css\" />\n    <!-- Global site tag (gtag.js) - Google Analytics-->\n    <script\n      async\n      src=\"https://www.googletagmanager.com/gtag/js?id=UA-66863947-1\"\n    ></script>\n    <script>\n      window.dataLayer = window.dataLayer || [];\n\n      function gtag() {\n        dataLayer.push(arguments);\n      }\n      gtag(\"js\", new Date());\n\n      gtag(\"config\", \"UA-66863947-1\");\n    </script>\n    <script>\n      window.dataLayer = window.dataLayer || [];\n\n      function gtag() {\n        dataLayer.push(arguments);\n      }\n      gtag(\"js\", new Date());\n      gtag(\"config\", \"G-4KWEZ8V0LM\");\n    </script>\n    <script src=\"https://kitchen.juicer.cc/?color=GF9shR22mrg=\" async></script>\n  </head>\n\n  <body class=\"jobs\">\n    <div id=\"wrap\">\n      <header id=\"header\">\n        <div class=\"inner\">\n          <h1 class=\"logo\">\n            <a href=\"../\"\n              ><img src=\"../assets/images/common/ht_logo.png\" alt=\"\"\n            /></a>\n          </h1>\n          <div id=\"pc_navigation\">\n            <ul>\n              <li><a href=\"../jobs/\">Def tribeの魅力</a></li>\n              <li><a href=\"../idealcandidate/\">求める人材・部署</a></li>\n              <li><a href=\"../welfare/\">福利厚生・研修制度</a></li>\n              <li><a href=\"../welfare/#techgym\">Def tribe×techgym</a></li>\n            </ul>\n          </div>\n          <div id=\"navigation\">\n            <div class=\"navBtn\"><span></span></div>\n            <div class=\"in\">\n              <div class=\"navlogo\">\n                <a href=\"../\"\n                  ><img src=\"../assets/images/common/nav_logo.png\" alt=\"\"\n                /></a>\n              </div>\n              <div class=\"link_area\">\n                <div class=\"flex\">\n                  <ul class=\"link01\">\n                    <li><a href=\"../\">TOP</a></li>\n                    <li><a href=\"../jobs/\">Def tribeの魅力</a></li>\n                    <li><a href=\"../idealcandidate/\">求める人材・部署</a></li>\n                    <li><a href=\"../welfare/\">福利厚生・研修制度</a></li>\n                  </ul>\n                  <ul class=\"link02\">\n                    <li><a href=\"../../\">コーポレートサイトトップ</a></li>\n                    <li><a href=\"../../company.html\">企業情報</a></li>\n                    <li><a href=\"../../contact/\">お問い合わせ</a></li>\n                    <li>\n                      <a href=\"../../privacy-policy.html\"\n                        >プライバシーポリシー</a\n                      >\n                    </li>\n                    <li>\n                      <a href=\"../../security.html\">情報セキュリティポリシー</a>\n                    </li>\n                  </ul>\n                </div>\n              </div>\n              <div class=\"collabo\">\n                <a href=\"../welfare/#techgym\"\n                  ><img src=\"../assets/images/common/nav_collabo.png\" alt=\"\"\n                /></a>\n              </div>\n              <!-- <ul class=\"icon\">\n                            <li>\n                                <a href=\"https://www.facebook.com/profile.php?id=100070377188634\" target=\"_blank\"><img class=\"svg\" src=\"./assets/img/common/icon_fb.svg\" alt=\"\"></a>\n                            </li>\n                            <li>\n                                <a href=\"https://twitter.com/deftribe0315\" target=\"_blank\"><img class=\"svg\" src=\"../assets/images/icon/icon_tw.svg\" alt=\"\"></a>\n                            </li>\n                            <li>\n                                <a href=\"https://www.instagram.com/deftribe0315/\" target=\"_blank\"><img class=\"svg\" src=\"../assets/images/icon/icon_inst.svg\" alt=\"\"></a>\n                            </li>\n                        </ul> -->\n            </div>\n          </div>\n          <div class=\"btnbox\">\n            <div class=\"navBtn\"><span></span></div>\n            <div class=\"entrybtn pc\">\n              <a\n                href=\"https://en-gage.net/e-deftribe_saiyopage/\"\n                target=\"_blank\"\n                ><span class=\"en\">ENTRY<small>&amp;</small></span\n                ><span class=\"txt\"\n                  >現在の募集情報\n                  <div class=\"icon\">\n                    <img\n                      class=\"svg\"\n                      src=\"../assets/images/icon/icon_blank.svg\"\n                      alt=\"\"\n                    /></div></span\n              ></a>\n            </div>\n          </div>\n        </div>\n      </header>\n      <main id=\"main\">\n        <div class=\"jobs\" id=\"contents\">\n          <div class=\"bodyline\"></div>\n          <div class=\"in\">\n            <section id=\"jobs_top\">\n              <div class=\"inner\">\n                <div class=\"title_style01\">\n                  <div class=\"box\">\n                    <div class=\"border01\"></div>\n                    <div class=\"border02\"></div>\n                    <h2 class=\"top\">Def tribeの魅力</h2>\n                    <p class=\"title\">\n                      新しいことに<br class=\"sp\" />挑む新しい企業\n                    </p>\n                  </div>\n                </div>\n                <div class=\"anker_box\">\n                  <div class=\"anker\">\n                    <a href=\"#jobs_outline\">Def tribeとは</a>\n                  </div>\n                  <div class=\"anker\">\n                    <a href=\"#jobs_activity\">アクティビティ</a>\n                  </div>\n                </div>\n              </div>\n            </section>\n            <section id=\"jobs_outline\">\n              <div class=\"inner\">\n                <div class=\"title_style02\">\n                  <p class=\"en\">ABOUT</p>\n                  <h2 class=\"sub\">Def tribeとは</h2>\n                </div>\n                <div class=\"outline_col\">\n                  <div class=\"img_area\">\n                    <div class=\"img\">\n                      <img\n                        src=\"../assets/images/jobs/outline_img01.jpg\"\n                        alt=\"\"\n                      />\n                    </div>\n                  </div>\n                  <div class=\"textbox\">\n                    <h2 class=\"midashi02\">\n                      “やりたいこと”が<br\n                        class=\"pc\"\n                      />言葉にできる<br />ノリがよくて<br\n                        class=\"pc\"\n                      />儲かる会社\n                    </h2>\n                    <div class=\"textarea\">\n                      <p>\n                        Def\n                        tribeは、<strong>「働く時間をもっと楽しくしたい」</strong>との思いで作った会社。だからこそ、スタッフが働きやすい環境作りを心掛けています。\n                      </p>\n                    </div>\n                  </div>\n                </div>\n                <div class=\"column_area\">\n                  <div class=\"column\">\n                    <div class=\"box\">\n                      <div class=\"in\">\n                        <p class=\"left\">CONDITIONS</p>\n                        <p class=\"right\">CONDITIONS</p>\n                        <div class=\"text\">\n                          <img\n                            src=\"../assets/images/jobs/outline_text01.png\"\n                            alt=\"\"\n                          />\n                        </div>\n                      </div>\n                    </div>\n                    <div class=\"textbox\">\n                      <h3 class=\"midashi03\">声を揃えて「条件がいい」</h3>\n                      <div class=\"textarea\">\n                        <p>\n                          「充実した福利厚生」「実力で上がる給与」「きちんと休める休暇」など、すべてにおいて好条件。他社には負けない大きな魅力がここにはあります。\n                        </p>\n                      </div>\n                    </div>\n                  </div>\n                  <div class=\"column\">\n                    <div class=\"box\">\n                      <div class=\"in\">\n                        <p class=\"left\">INCREASE</p>\n                        <p class=\"right\">INCREASE</p>\n                        <div class=\"text\">\n                          <img\n                            src=\"../assets/images/jobs/outline_text02.png\"\n                            alt=\"\"\n                          />\n                        </div>\n                      </div>\n                    </div>\n                    <div class=\"textbox\">\n                      <h3 class=\"midashi03\">\n                        前職より給与がUPする確率は「ほぼ100%」\n                      </h3>\n                      <div class=\"textarea\">\n                        <p>\n                          中途採用の方は、前職よりも給与が良くなる確率が「ほぼ100%」という実績。一人ひとりのスキルにあった額面支給になります。\n                        </p>\n                      </div>\n                    </div>\n                  </div>\n                  <div class=\"column\">\n                    <div class=\"box\">\n                      <div class=\"in\">\n                        <p class=\"left\">NO ZANGYO</p>\n                        <p class=\"right\">NO ZANGYO</p>\n                        <div class=\"text\">\n                          <img\n                            src=\"../assets/images/jobs/outline_text03.png\"\n                            alt=\"\"\n                          />\n                        </div>\n                      </div>\n                    </div>\n                    <div class=\"textbox\">\n                      <h3 class=\"midashi03\">全体の9割は定時退社</h3>\n                      <div class=\"textarea\">\n                        <p>\n                          残業が多いイメージをよく持たれる業種ですが、弊社は定時退社の割合が全体の9割。労働時間内に集中して仕事をするスタイルです。\n                        </p>\n                      </div>\n                    </div>\n                  </div>\n                  <div class=\"column\">\n                    <div class=\"box\">\n                      <div class=\"in\">\n                        <p class=\"left\">ANTI ZANGYO</p>\n                        <p class=\"right\">ANTI ZANGYO</p>\n                        <div class=\"text\">\n                          <img\n                            src=\"../assets/images/jobs/outline_text04.png\"\n                            alt=\"\"\n                          />\n                        </div>\n                      </div>\n                    </div>\n                    <div class=\"textbox\">\n                      <h3 class=\"midashi03\">残業は1日1時間以内</h3>\n                      <div class=\"textarea\">\n                        <p>\n                          社員の9割が18：00の定時退社。残りの1割は残業があったとしても1時間以内。遅い時間まで無理に働くことはないから、プライベートも充実します。\n                        </p>\n                      </div>\n                    </div>\n                  </div>\n<!--\n                  <div class=\"column\">\n                    <div class=\"box\">\n                      <div class=\"in\">\n                        <p class=\"left\">HANAKIN</p>\n                        <p class=\"right\">HANAKIN</p>\n                        <div class=\"text\">\n                          <img\n                            src=\"../assets/images/jobs/outline_text05.png\"\n                            alt=\"\"\n                          />\n                        </div>\n                      </div>\n                    </div>\n                    <div class=\"textbox\">\n                      <h3 class=\"midashi03\">嬉しいプレミアムフライデー</h3>\n                      <div class=\"textarea\">\n                        <p>\n                          毎月最終の金曜日はプレミアムフライデーで、15：00退社。スタッフも仲がいいのでそのまま飲みに行ったり、家でゆっくりしたりとそれぞれの時間を楽しんでいます。\n                        </p>\n                      </div>\n                    </div>\n                  </div>\n-->\n                  <div class=\"column\">\n                    <div class=\"box\">\n                      <div class=\"in\">\n                        <p class=\"left\">PAID HOLIDAYS</p>\n                        <p class=\"right\">PAID HOLIDAYS</p>\n                        <div class=\"text\">\n                          <img\n                            src=\"../assets/images/jobs/outline_text06.png\"\n                            alt=\"\"\n                          />\n                        </div>\n                      </div>\n                    </div>\n                    <div class=\"textbox\">\n                      <h3 class=\"midashi03\">有給の消化率は100%</h3>\n                      <div class=\"textarea\">\n                        <p>\n                          「有給を全力で楽しんでほしい」が、弊社代表の方針。スタッフ間の理解もあるため、気を使わずに自由なタイミングできっちり有給を取ることができます。\n                        </p>\n                      </div>\n                    </div>\n                  </div>\n                  <div class=\"column\">\n                    <div class=\"box\">\n                      <div class=\"in\">\n                        <p class=\"left\">JOY</p>\n                        <p class=\"right\">JOY</p>\n                        <div class=\"text\">\n                          <img\n                            src=\"../assets/images/jobs/outline_text07.png\"\n                            alt=\"\"\n                          />\n                        </div>\n                      </div>\n                    </div>\n                    <div class=\"textbox\">\n                      <h3 class=\"midashi03\">遊びも大切に</h3>\n                      <div class=\"textarea\">\n                        <p>\n                          中小企業としては珍しい充実したアクティビティ活動。楽しみの一環として、今後もさまざまな企画を行い、発信していきます。\n                        </p>\n                      </div>\n                    </div>\n                  </div>\n                  <div class=\"column\">\n                    <div class=\"box\">\n                      <div class=\"in\">\n                        <p class=\"left\">LET’S GIVE AN OPINION</p>\n                        <p class=\"right\">LET’S GIVE AN OPINION</p>\n                        <div class=\"text\">\n                          <img\n                            src=\"../assets/images/jobs/outline_text08.png\"\n                            alt=\"\"\n                          />\n                        </div>\n                      </div>\n                    </div>\n                    <div class=\"textbox\">\n                      <h3 class=\"midashi03\">ピラミッド型ではない会社</h3>\n                      <div class=\"textarea\">\n                        <p>\n                          ピラミッド型の会社ではなく、スタッフみんなで協力して作る会社。言いたいことが言える環境は、会社としての成長にも繋がります。\n                        </p>\n                      </div>\n                    </div>\n                  </div>\n                  <div class=\"column\">\n                    <div class=\"box\">\n                      <div class=\"in\">\n                        <p class=\"left\">UNITY</p>\n                        <p class=\"right\">UNITY</p>\n                        <div class=\"text\">\n                          <img\n                            src=\"../assets/images/jobs/outline_text09.png\"\n                            alt=\"\"\n                          />\n                        </div>\n                      </div>\n                    </div>\n                    <div class=\"textbox\">\n                      <h3 class=\"midashi03\">スタッフの団結力</h3>\n                      <div class=\"textarea\">\n                        <p>\n                          いろんなプロジェクトを管理する上で必要なモノが、スタッフの強い団結力。プライベートでも一緒に過ごすほどの仲の良さは、仕事のしやすさにも繋がります。\n                        </p>\n                      </div>\n                    </div>\n                  </div>\n                  <div class=\"column\">\n                    <div class=\"box\">\n                      <div class=\"in\">\n                        <p class=\"left\">TRY</p>\n                        <p class=\"right\">TRY</p>\n                        <div class=\"text\">\n                          <img\n                            src=\"../assets/images/jobs/outline_text10.png\"\n                            alt=\"\"\n                          />\n                        </div>\n                      </div>\n                    </div>\n                    <div class=\"textbox\">\n                      <h3 class=\"midashi03\">やりたいことが現実に</h3>\n                      <div class=\"textarea\">\n                        <p>\n                          「個人の成長＝会社の成長」と考える企業だから、アイデアがあれば何でもやってみる。挑戦したい人たちを全面的に歓迎・サポートします。\n                        </p>\n                      </div>\n                    </div>\n                  </div>\n                  <div class=\"column\">\n                    <div class=\"box\">\n                      <div class=\"in\">\n                        <p class=\"left\">SEE THE FUTURE</p>\n                        <p class=\"right\">SEE THE FUTURE</p>\n                        <div class=\"text\">\n                          <img\n                            src=\"../assets/images/jobs/outline_text11.png\"\n                            alt=\"\"\n                          />\n                        </div>\n                      </div>\n                    </div>\n                    <div class=\"textbox\">\n                      <h3 class=\"midashi03\">発展して進むスピード感</h3>\n                      <div class=\"textarea\">\n                        <p>\n                          IT業界は常に進化を続ける。すさまじいスピードで発展していく業界で、常に最先端を勉強・習得できる環境が整っています。\n                        </p>\n                      </div>\n                    </div>\n                  </div>\n                </div>\n              </div>\n            </section>\n            <section id=\"jobs_activity\">\n              <div class=\"inner\">\n                <div class=\"title_style02\">\n                  <p class=\"en\">ACTIVITY</p>\n                  <h2 class=\"sub\">アクティビティ</h2>\n                </div>\n                <div class=\"collayout\">\n                  <div class=\"textbox\">\n                    <h3 class=\"midashi02\">好奇心から<br />縮める距離感</h3>\n                    <div class=\"textarea\">\n                      <h3 class=\"midashi04\">遊び心あるアクティビティ</h3>\n                      <p>\n                        「遊びも楽しみたい」と始まったアクティビティ活動も今では9種類以上。スタッフだけでなく、取引先様やパートナー企業との交流のきっかけにもなります。\n                      </p>\n                    </div>\n                  </div>\n                  <div class=\"img_area\">\n                    <div class=\"box\">\n                      <div class=\"img\">\n                        <img\n                          src=\"../assets/images/jobs/activity_img01.jpg\"\n                          alt=\"\"\n                        />\n                      </div>\n                      <p class=\"text\">キャンプ</p>\n                    </div>\n                    <div class=\"box\">\n                      <div class=\"img\">\n                        <img\n                          src=\"../assets/images/jobs/activity_img02.jpg\"\n                          alt=\"\"\n                        />\n                      </div>\n                      <p class=\"text\">サバイバルゲーム</p>\n                    </div>\n                    <div class=\"box\">\n                      <div class=\"img\">\n                        <img\n                          src=\"../assets/images/jobs/activity_img03.jpg\"\n                          alt=\"\"\n                        />\n                      </div>\n                      <p class=\"text\">登山</p>\n                    </div>\n                    <div class=\"box\">\n                      <div class=\"img\">\n                        <img\n                          src=\"../assets/images/jobs/activity_img04.jpg\"\n                          alt=\"\"\n                        />\n                      </div>\n                      <p class=\"text\">釣り</p>\n                    </div>\n                    <div class=\"box\">\n                      <div class=\"img\">\n                        <img\n                          src=\"../assets/images/jobs/activity_img05.jpg\"\n                          alt=\"\