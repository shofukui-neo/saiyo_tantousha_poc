{"url":"https://www.ktec-akashi.co.jp/recruit/people/interview06.html","html":"<!DOCTYPE html>\r\n<html lang=\"ja\">\r\n\r\n<head prefix=\"og: https://ogp.me/ns#\">\r\n    <meta charset=\"UTF-8\">\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n    <meta name=\"description\" content=\"カワサキモータースの関連会社、ケイテックの公式サイトです。川崎重工グループを中心に事業展開するデジタル・ソリューション・カンパニーです。\">\r\n\r\n    <title>RECRUIT | K-TEC 株式会社ケイテック</title>\r\n\r\n    <!-- ファビコン -->\r\n    <link rel=\"icon\" type=\"image/x-icon\" href=\"/recruit/assets/img/index/favicon.png\">\r\n    <link rel=\"apple-touch-icon\" href=\"/recruit/assets/img/index/icon.png\">\r\n\r\n    <!-- ogp -->\r\n    <meta property=\"og:locale\" content=\"ja_JP\">\r\n    <meta property=\"og:site_name\" content=\"RECRUIT | K-TEC 株式会社ケイテック\">\r\n    <meta property=\"og:url\" content=\"https://www.ktec-akashi.co.jp/recruit/\">\r\n    <meta property=\"og:type\" content=\"website\">\r\n    <meta property=\"og:title\" content=\"RECRUIT | K-TEC 株式会社ケイテック\">\r\n    <meta property=\"og:description\" content=\"カワサキモータースの関連会社、ケイテックの採用サイトです。川崎重工グループを中心に事業展開するデジタル・ソリューション・カンパニーです。\">\r\n    <meta property=\"og:image\" content=\"https://www.ktec-akashi.co.jp/recruit/assets/img/ogp-100.jpg\">\r\n\r\n    <!-- font -->\r\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\r\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\r\n    <link\r\n        href=\"https://fonts.googleapis.com/css2?family=Josefin+Sans:ital,wght@0,100..700;1,100..700&family=Noto+Sans+JP:wght@100..900&family=Noto+Sans:ital,wght@0,100..900;1,100..900&family=Roboto:ital,wght@0,100..900;1,100..900&display=swap\"\r\n        rel=\"stylesheet\">\r\n\r\n    <!-- css -->\r\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"../../assets/css/reset.css\">\r\n\r\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"../assets/css/slick.css\">\r\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"../assets/css/slick-theme.css\">\r\n\r\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"../assets/css/recruit.css\">\r\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"../assets/css/interview.css\">\r\n\r\n    <!-- Google tag (gtag.js) -->\r\n    <script async src=\"https://www.googletagmanager.com/gtag/js?id=G-XHJS5KLZ2J\"></script>\r\n    <script>\r\n        window.dataLayer = window.dataLayer || [];\r\n        function gtag() { dataLayer.push(arguments); }\r\n        gtag('js', new Date());\r\n\r\n        gtag('config', 'G-XHJS5KLZ2J');\r\n    </script>\r\n\r\n</head>\r\n\r\n<body>\r\n\r\n    <!-- 共通のヘッダーを使用 -->\r\n    <div id=\"recruit_header\"></div>\r\n\r\n    <main>\r\n        <!-- section01 メインイメージ -->\r\n        <section class=\"interview_sec01\">\r\n            <div class=\"interview_sec01_inn interview06_sec01_inn\">\r\n                <article class=\"interview_top_ttl\">\r\n                    <p class=\"fs16 fc-dblue\">インタビュー</p>\r\n                    <img src=\"../assets/img/interview/interview_top_ttl.png\" alt=\"INTERVIEW\">\r\n                    <div class=\"interview_top_img pc-only\">\r\n                        <img src=\"../assets/img/interview/interview_main_img06.png\" alt=\"\">\r\n                    </div>\r\n                    <!-- パンくずリスト -->\r\n                    <nav aria-label=\"Breadcrumb\" class=\"recruit_breadcrumb\">\r\n                        <ul>\r\n                            <li><a href=\"/recruit/index.html\">TOP</a></li>\r\n                            <li><a href=\"index.html\">人を知る</a></li>\r\n                            <li><span aria-current=\"page\">デジタルソリューション部第一課</span></li>\r\n                        </ul>\r\n                    </nav>\r\n                </article>\r\n                <article class=\"interview_top_txt\">\r\n                    <div>\r\n                        <h1>バイクを“知る”ことが仕事になる。<br>\r\n                            マニュアルで支えるカワサキの品質。</h1>\r\n                    </div>\r\n                    <div class=\"interview_top_profile_box\">\r\n                        <ul class=\"interview_name\">\r\n                            <li class=\"fs26 fc-white\">デジタルソリューション部</li>\r\n                            <li class=\"fs26 fc-white\">第一課</li>\r\n                            <li class=\"fs58 fc-white\">T.O</li>\r\n                            <li class=\"fs20 fc-white\">2019年入社</li>\r\n                            <li class=\"fs20 fc-white\">大学卒（情報工学科）</li>\r\n                        </ul>\r\n                        <div class=\"pc-only\">\r\n                            <ul class=\"interview_hashtag\">\r\n                                <li class=\"fs15 fc-dblue\">#&emsp;新卒入社</li>\r\n                                <li class=\"fs15 fc-dblue\">#&emsp;バイク</li>\r\n                                <li class=\"fs15 fc-dblue\">#&emsp;英語</li>\r\n                                <li class=\"fs15 fc-dblue\">#&emsp;マニュアル制作</li>\r\n                            </ul>\r\n                        </div>\r\n                    </div>\r\n                </article>\r\n                <div class=\"interview_top_ink pc-only\">\r\n                    <img src=\"../assets/img/interview/interview_top_deco_grn.png\">\r\n                </div>\r\n            </div>\r\n            <div class=\"sp-only\">\r\n                <ul class=\"interview_hashtag sp-only\">\r\n                    <li class=\"fs15 fc-dblue\">#&emsp;新卒入社</li>\r\n                                <li class=\"fs15 fc-dblue\">#&emsp;新卒入社</li>\r\n                                <li class=\"fs15 fc-dblue\">#&emsp;バイク</li>\r\n                                <li class=\"fs15 fc-dblue\">#&emsp;英語</li>\r\n                                <li class=\"fs15 fc-dblue\">#&emsp;マニュアル制作</li>\r\n                </ul>\r\n            </div>\r\n        </section>\r\n\r\n        <!-- section02 入社前 -->\r\n        <section class=\"interview_sec02 fadeUpTrigger\">\r\n            <div class=\"interview_sec02_box\">\r\n                <h1 class=\"fc-dblue border-b_green mark-green\">学生時代に学んだこと</h1>\r\n                <p class=\"fc-dblue fs16_2\">\r\n                    情報工学科でしたので、主に数学とプログラミングについて学んでいました。1回生の4月、「日常生活から学ぶ内容まで、全てを自分で選んで自由に行動できる」という状況に感動したことが印象に残っています。また、バイクが好きだったこともあり、学生時代の平日は学校→バイト→ツーリング、休日は整備→バイト→ツーリングという、ある意味今より忙しい日々を過ごしていたかもしれません。\r\n                </p>\r\n            </div>\r\n            <div class=\"interview_sec02_box\">\r\n                <h1 class=\"fc-dblue border-b_green mark-green\">入社の決め手</h1>\r\n                <p class=\"fc-dblue fs16_2\">\r\n                    カワサキ製の最新機種に仕事で常に触れていられることが、「ここしかない！」と思える一番の決め手でした。実家が愛媛ですので、比較的帰省しやすい関西の勤務地というのは一つのポイントです。\r\n            </div>\r\n        </section>\r\n\r\n        <!-- section03 キャリアパス -->\r\n        <section class=\"interview_sec03 fadeUpTrigger\">\r\n            <h1 class=\"mark-green\">キャリアパス</h1>\r\n            <div class=\"interview_sec03_inn bgc-lgreen\">\r\n                <table class=\"table_green\">\r\n                    <tr>\r\n                        <th class=\"fc-green\">2019年</th>\r\n                        <td>ケイテック入社、現デジタルソリューション部第一課に配属</td>\r\n                    </tr>\r\n                    <tr>\r\n                        <th class=\"fc-green\">2020年</th>\r\n                        <td>「Z650RS」「KX250/KX250X」「RIDGE」等のマニュアル作成を担当</td>\r\n                    </tr>\r\n                    <tr>\r\n                        <th class=\"fc-green\">2024年</th>\r\n                        <td>各製品のモデルリーダーと並行して業務改善活動を行う</td>\r\n                    </tr>\r\n                </table>\r\n            </div>\r\n        </section>\r\n\r\n        <!-- section04 インタビュー -->\r\n        <section class=\"interview_sec04\">\r\n            <article class=\"interview_sec04_box interview_sec04_box01 fadeUpTrigger\">\r\n                <div class=\"interview_sec04_box_txt\">\r\n                    <h2 class=\"fs16 fc-dblue\">現在の仕事とやりがい</h2>\r\n                    <h3 class=\"fs33 fc-white bg-green\">誰もが理解できるマニュアルを、<br>\r\n                        試行錯誤し完成させる達成感</h3>\r\n                    <p class=\"fs16_2 fc-dblue\">\r\n                        エンドユーザー向けの「取扱説明書（オーナーズマニュアル）」や、ディーラー向けの「整備要領書（サービスマニュアル）」の作成を担当しています。バイクの基本構造の知識と分解整備能力に加えて、誰が見ても分かりやすい文章と画像を作成するスキルが求められます。<br>\r\n                        日本語だけでなく英語でのライティングもあり、幅広い知識と表現力が身につく点にやりがいを感じます。<br>\r\n                        マニュアルを手にしたお客様が満足できる形を目指し、日々試行錯誤しています。そうした積み重ねで一冊のマニュアルを完成させたときの達成感が、次の仕事も頑張ろうという原動力になります。\r\n                    </p>\r\n                </div>\r\n                <div class=\"interview_sec04_box_img\">\r\n                    <img src=\"../assets/img/interview/interview06_img01.png\" alt=\"\">\r\n                </div>\r\n            </article>\r\n            <article class=\"interview_sec04_box interview_sec04_box02 fadeUpTrigger\">\r\n                <div class=\"interview_sec04_box_txt\">\r\n                    <h2 class=\"fs16 fc-dblue\">印象に残っている仕事や成長を実感した点</h2>\r\n                    <h3 class=\"fs33 fc-white bg-green\">ひとつの仕事を完成させたことが<br>\r\n                        大きな自信につながった</h3>\r\n                    <p class=\"fs16_2 fc-dblue\">\r\n                        最も印象に残っている仕事は「Ninja ZX-25R」のマニュアル作成です。一年目の最後に担当した仕事で、エンジンに関わる章を担当させていただきました。作業検証・原稿作成で一年間の経験をフル活用し、失敗をしつつも先輩のサポートによってなんとか完成させられたことが、自分の中で大きな自信につながりました。\r\n                    </p>\r\n                </div>\r\n                <div class=\"interview_sec04_box_img\">\r\n                    <img src=\"../assets/img/interview/interview06_img02.png\" alt=\"\">\r\n                </div>\r\n            </article>\r\n            <article class=\"interview_sec04_box interview_sec04_box03 fadeUpTrigger\">\r\n                <div class=\"interview_sec04_box_txt\">\r\n                    <h2 class=\"fs16 fc-dblue\">職場環境</h2>\r\n                    <h3 class=\"fs33 fc-white bg-green\">充実した研修と、<br>\r\n                        柔軟で見通しの立つスケジュール</h3>\r\n                    <p class=\"fs16_2 fc-dblue\">\r\n                        バイク好きはもちろん、免許のない人でも新入社員教育がしっかりしているので安心してスタートできます。<br>\r\n                        実車検証で最新機種を１台まるごと分解して見られるのは、ケイテックの中でもこの部署ならではの魅力です。<br>\r\n                        忙しい時期でもスケジュールを柔軟に見直せるため、業務に支障がない範囲で休暇を取りやすい環境です。たとえば、バイクの車検や、土日だけでは足りないツーリングなども、計画的に休暇を組み込むことができます。また、チームではお互いの仕事をサポートし合い、納期に間に合わせるよう最善の行動を取る意識が根付いています。\r\n                    </p>\r\n                </div>\r\n                <div class=\"interview_sec04_box_img\">\r\n                    <img src=\"../assets/img/interview/interview06_img03.png\" alt=\"\">\r\n                </div>\r\n            </article>\r\n        </section>\r\n\r\n        <!-- section05 タイムスケジュール -->\r\n        <section class=\"interview_sec05 fc-white fadeUpTrigger\">\r\n            <div class=\"interview_sec05_inn\">\r\n                <h1 class=\"mark-green\">ある日のスケジュール</h1>\r\n                <ul class=\"interview_sec_box fs20 green_list_mark\">\r\n                    <li class=\"interview_sec_box01\">\r\n                        <ul>\r\n                            <li><span class=\"fc-green\">07:00</span>起床</li>\r\n                            <li><span class=\"fc-green\">08:00</span>メールチェック開始</li>\r\n                            <li><span class=\"fc-green\">09:00</span>原稿作成</li>\r\n                            <li><span class=\"fc-green\">12:00</span>昼食・軽いスポーツ</li>\r\n                            <li><span class=\"fc-green\">13:00</span>スタジオ検証作業</li>\r\n                        </ul>\r\n                    </li>\r\n                    <li class=\"interview_sec_box02\">\r\n                        <ul>\r\n                            <li><span class=\"fc-green\">16:00</span>撮影写真確認・原稿作成</li>\r\n                            <li><span class=\"fc-green\">19:00</span>退社</li>\r\n                            <li><span class=\"fc-green\">19:30</span>帰宅、夕食</li>\r\n                            <li><span class=\"fc-green\">23:00</span>就寝</li>\r\n                        </ul>\r\n                    </li>\r\n                </ul>\r\n            </div>\r\n        </section>\r\n\r\n        <!-- section06 仕事のやりがい -->\r\n        <section class=\"interview_sec06 fadeUpTrigger\">\r\n\r\n            <div class=\"interview_sec06_box\">\r\n                <div class=\"interview_sec06_box_img interview_sec06_box_img-green fukidashi06\">\r\n                    <h4 class=\"fs26 fc-green sp-only\">仕事のやりがいとは？</h4>\r\n                    <img src=\"../assets/img/interview/interview06_img04.png\" alt=\"\">\r\n                </div>\r\n                <div class=\"interview_sec06_box_txt\">\r\n                    <div class=\"interview_sec06_box_txt_inn interview_sec06_box_txt_inn01\">\r\n                        <h4 class=\"fs26 fc-green\">ケイテックの好きなところ</h4>\r\n                        <p class=\"fs16_2 fc-dblue\">\r\n                            部門間をまたいだ会社内の友人も多くいて、登山や、サッカー観戦、ジンギス会っていうのもあって交流やイベントが楽しいです。世代関係なく、なんでも言い合える仲間が社内にいるのは心強いです。<br>\r\n                            また、バイク好きにとってカワサキの純正部品が割引価格で購入できるところは嬉しいですね。\r\n                        </p>\r\n                    </div>\r\n                    <div class=\"interview_sec06_box_txt_inn interview_sec06_box_txt_inn02\">\r\n                        <h4 class=\"fs26 fc-green\">未来の自分へ</h4>\r\n                        <p class=\"fs16_2 fc-dblue\">\r\n                            今年で7年目になる自分ですが、いまだに経験できない分野のマニュアルが存在します。数年後、あの人に渡しておけばこの仕事は間違いない、と言われるような社員になれるよう努力しておきますので、マニュアル制作チームを引っ張っていけるぐらい、信頼を得られるように引き続き頑張ってください！\r\n                        </p>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n        </section>\r\n\r\n        <!-- section07 学生さんへメッセージ -->\r\n        <section class=\"interview_sec07 bgc-lgreen border-green fadeUpTrigger\">\r\n            <div class=\"interview_sec07_box_txt_ttl pc-only\">\r\n                <img src=\"../assets/img/interview/message_ttl_grn_pc.png\">\r\n            </div>\r\n            <div class=\"interview_sec07_box_txt_ttl sp-only \">\r\n                <img src=\"../assets/img/interview/message_ttl_grn_sp.png\">\r\n            </div>\r\n            <div class=\"interview_sec07_box\">\r\n                <div class=\"interview_sec07_box_img\">\r\n                    <img src=\"../assets/img/interview/interview06_img05.png\" alt=\"\">\r\n                </div>\r\n                <div class=\"interview_sec07_box_txt\">\r\n                    <p class=\"fs16_2 fc-dblue\">\r\n                        人生において自分が重視したいポイントをよく考えて、それが叶う場所を探してください。\r\n                    </p>\r\n                </div>\r\n            </div>\r\n        </section>\r\n\r\n        <!-- section08 リンク -->\r\n        <section class=\"interview_sec08\">\r\n            <!-- OTHER INTERVIEW -->\r\n             <article class=\"other_interview_link_article border-b_dblue\">\r\n                <div class=\"other_interview_links_ttl\">\r\n                    <h1>OTHER INTERVIEW</h1>\r\n                </div>\r\n                <ul class=\"other_interview_links\">\r\n                    <li>\r\n                        <a href=\"interview01.html\">\r\n                            <div class=\"interview_link_btn\">\r\n                                <div class=\"pc-only\">\r\n                                    <img src=\"../assets/img/interview/interview_link_btn_img01.png\" alt=\"\">\r\n                                </div>\r\n                                <div class=\"sp-only\">\r\n                                    <img src=\"../assets/img/interview/interview_link_btn_img01_sp.png\" alt=\"\">\r\n                                </div>\r\n                                <div class=\"interview_link_btn_txt\">\r\n                                    <p class=\"fc-white fs12\">2023年入社</p>\r\n                                    <p class=\"fc-white fs14\">航空ソリューション部<br>\r\n                                        民間エンジン技術課</p>\r\n                                </div>\r\n                            </div>\r\n                        </a>\r\n                    </li>\r\n                    <li>\r\n                        <a href=\"interview02.html\">\r\n                            <div class=\"interview_link_btn\">\r\n      