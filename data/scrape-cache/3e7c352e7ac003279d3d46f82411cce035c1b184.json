ck': callback\n  });\n  return false;\n}\n</script>\n</head>\n\n<body>\n<!-- スマホ用ナビ ---------------------------------------------------------------------------------------->\n<div class=\"fat-nav\">\n    <div class=\"fat-nav__wrapper\">\n        <div class=\"menu_top\">\n        <br><br><br><br>\n        </div>\n        <div class=\"ddnlink\">トップページ<a href=\"/\"></a></div>\n        <div class=\"ddnlink\">店舗・チラシ<a href=\"/shop/\"></a></div>\n        <div class=\"ddnlink\">ポイントカード案内<a href=\"/card/\"></a></div>\n        <div class=\"ddnlink\">ニュースリリース<a href=\"/news/\"></a></div>\n        <div class=\"ddnlink\">会社情報<a href=\"/company/outline.html\"></a></div>\n        <div class=\"ddnlink\">採用情報<a href=\"/recruit/\"></a></div>\n        <div class=\"ddnlink\">ご利用にあたって<a href=\"/use/\"></a></div>\n        <div class=\"ddnlink\">サステナビリティ基本方針<a href=\"/sustainability/\"></a></div>\n        <div class=\"ddnlink\">カスタマーハラスメントに対する基本方針<a href=\"/customer_harassment/\"></a></div>\n        <div class=\"ddnlink\">プライバシーポリシー<a href=\"/privacy/\"></a></div>\n        <div class=\"ddnlink\">サイトマップ<a href=\"/sitemap/\"></a></div>\n    </div>\n</div>  \n<!-- ヘッダー ---------------------------------------------------------------------------------------->\n<div id=\"header\">\n    <div class=\"header_inner\">\n        <ul>\n            <li class=\"hn1\"><a href=\"/\"><img src=\"/_common/imgs/logo.svg\" alt=\"アオキスーパー\" width=\"100%\" /></a></li>\n            <li class=\"hn2\"></li>\n            <li class=\"hn3\"><a href=\"/sitemap/\"><img src=\"/_common/imgs/h_arrow.svg\" class=\"arrow\">サイトマップ</a></li>\n            <li class=\"hn4\">品質と価格で暮らしのお手伝い</li>\n        </ul>\n    </div>\n\t<div id=\"gnav_box\">\n\t\t<ul id=\"gnav\">\n\t\t\t<!------------------------------------------------------------------------------------------>\n\t\t\t<li id=\"nn1\">\n\t\t\t\t<a href=\"/\"><img src=\"/_common/imgs/btn_top_off.svg\" alt=\"アオキスーパートップ\" width=\"100%\"/></a>\n\t\t\t</li>\n\t\t\t<!------------------------------------------------------------------------------------------>\n\t\t\t<li id=\"nn1\">\n\t\t\t\t<a href=\"/shop/\"><img src=\"/_common/imgs/btn_srore_off.svg\" alt=\"店舗・チラシ\" width=\"100%\"/></a>\n\t\t\t</li>\n\t\t\t<!------------------------------------------------------------------------------------------>\n\t\t\t<li id=\"nn1\">\n\t\t\t\t<a href=\"/card/\"><img src=\"/_common/imgs/btn_card_off.svg\" alt=\"ポイントカード案内\" width=\"100%\" /></a>\n\t\t\t</li>\n\t\t\t<!------------------------------------------------------------------------------------------>\n\t\t\t<li id=\"nn1\">\n\t\t\t\t<a href=\"/news/\"><img src=\"/_common/imgs/btn_news_off.svg\" alt=\"IR情報\" width=\"100%\" /></a>\n\t\t\t</li>\n\t\t\t<!------------------------------------------------------------------------------------------>\n\t\t\t<li id=\"nn1\">\n\t\t\t\t<a href=\"/company/outline.html\"><img src=\"/_common/imgs/btn_company_off.svg\" alt=\"会社情報\" width=\"100%\" /></a>\n\t\t\t</li>\n\t\t\t<!------------------------------------------------------------------------------------------>\n\t\t\t<li id=\"nn1\">\n\t\t\t\t<a href=\"/recruit/\"><img src=\"/_common/imgs/btn_recruite_off.svg\" alt=\"採用情報\" width=\"100%\" /></a>\n\t\t\t</li>\n\t\t\t<!------------------------------------------------------------------------------------------>\n\t\t</ul>\t\t\n\t</div>\n\n\t<ul class=\"menuicon\">\n\t\t<li><a href=\"/\"><img src=\"/_common/imgs/btn_sp_top_off.svg\"></a></li><li><a href=\"/shop/\"><img src=\"/_common/imgs/btn_sp_srore_off.svg\"></a></li><li><a href=\"/card/\"><img src=\"/_common/imgs/btn_sp_card_off.svg\"></a></li><li><a href=\"/news/\"><img src=\"/_common/imgs/btn_sp_news_off.svg\"></a></li><li><a href=\"/company/outline.html\"><img src=\"/_common/imgs/btn_sp_company_off.svg\"></a></li><li><a href=\"/recruit/\"><img src=\"/_common/imgs/btn_sp_recruite_off.svg\"></a></li>\n\t</ul>\n</div><div class=\"contents contents_header pages\">\n    <div class=\"contents_inner text-center\">\n        <span class=\"contents_title\">採用情報</span>\n    </div>\n</div>\n<div class=\"contents\">\n    <div class=\"contents_inner\">\n        <ul class=\"breadcrumb\">\n        \t<li><a href=\"/\">アオキスーパートップページ</a></li>\n            <li><a href=\"/recruit/\">採用情報</a></li>\n        \t<li><span>新卒・中途採用情報</span></li>\n        </ul>\n\n        <div class=\"recruit_area\">\n\t        <img src=\"../img/asr_pc.svg\" class=\"pcimg titleimg\">\n            <img src=\"../img/asr_sp.svg\" class=\"spimg titleimg\">\n        </div>\n    </div>\n\n    <div class=\"tayousei\">\n        <div class=\"tayousei_img\">\n            <img src=\"imgs/tayousei_pc.jpg\" width=\"1000px\" class=\"pc\">\n            <img src=\"imgs/tayousei_sp.jpg\" width=\"100%\" class=\"sp\">\n        </div>\n    </div>\n\n    <div class=\"shogakukin\">\n        <div class=\"shogakukin_img\">\n            <img src=\"../shogakukin/imgs/title.png\" width=\"100%\">\n        </div>\n        <div class=\"shogakukin_btn\">\n            <a href=\"../shogakukin/\"><img src=\"../shogakukin/imgs/btn1.png\" width=\"100%\" class=\"img_alpha\"></a>\n        </div>\n    </div>\n\n    <div class=\"link\" id=\"shinsotsu\"></div>\n    \n        <div class=\"jobtype nousan\"><img src=\"../img/icon_nousan.svg\" class=\"jobicon\"></div>\n\n        <div class=\"contents_inner notop\">\n            <h3 class=\"nousan\">農産部</h3>\n\n            <div class=\"job_box_l\">\n                <img src=\"../imgs/ph_nousan.jpg\">\n            </div>\n            <div class=\"job_box_r\">\n                <h4 class=\"nousan\">仕事内容</h4>\n                <p>農産部では果物や野菜、生花を担当しています。農産部のお仕事内容は、彩り鮮やかな果物やとれたて新鮮な野菜などの仕入れや加工、またお客様が次々と商品をかごの中に入れてしまうような、そんな魅力的な売場づくりを行っていただきます。生鮮食料品の中でも果物や野菜は季節や天候により相場が変動することや、食卓を彩る旬な食材を豊富に取り扱っていることから専門的な商品知識や販売技術を身につけることができます。売り頃、買い頃の良い品をお客様に提供し、お客様に満足していただけるよう農産部のスペシャリストを目指しましょう！</p>\n                <a href=\"https://job.mynavi.jp/27/pc/search/corp104837/outline.html\" target=\"_blank\" onclick=\"gtag_report_conversion();\">\n                    <div class=\"btn btn_nousan\">新卒採用はこちら</div>\n                </a>\n                <a href=\"https://aokisuper-recruit.net/jobfind-pc/area/All?jobtype=00105\" target=\"_blank\">\n                    <div class=\"btn btn_nousan\">中途採用はこちら</div>\n                </a>\n            </div>\n        </div>\n        <div class=\"clear\"></div>\n\n    \n        <div class=\"jobtype suisan\"><img src=\"../img/icon_suisan.svg\" class=\"jobicon\"></div>\n\n        <div class=\"contents_inner notop\">\n            <h3 class=\"suisan\">水産部</h3>\n\n            <div class=\"job_box_l\">\n                <img src=\"../imgs/ph_suisan.jpg\">\n            </div>\n            <div class=\"job_box_r\">\n                <h4 class=\"suisan\">仕事内容</h4>\n                <p>水産部では鮮魚や魚介練り製品、冷凍食品を担当しています。水産部のお仕事の醍醐味はなんといってもお魚をさばくところにあります。新鮮なお魚をお刺身や三枚おろしなどお客様が料理に使用する用途に合わせて調理加工します。お魚のさばき方や盛り付けの見栄え次第で、売れ行きが変わるため、自分の調理した商品が売れたときは、他では味わえないやりがいを感じることができます。<br>包丁の使い方やお魚の調理方法などは先輩社員の指導の下行いますので、初心者の方でもご安心ください。素早くお魚をさばく姿は憧れの的になること間違いなしです！</p>\n                <a href=\"https://job.mynavi.jp/27/pc/search/corp104837/outline.html\" target=\"_blank\" onclick=\"gtag_report_conversion();\">\n                    <div class=\"btn btn_suisan\">新卒採用はこちら</div>\n                </a>\n                <a href=\"https://aokisuper-recruit.net/jobfind-pc/area/All?jobtype=00110\" target=\"_blank\">\n                    <div class=\"btn btn_suisan\">中途採用はこちら</div>\n                </a>\n            </div>\n        </div>\n        <div class=\"clear\"></div>\n\n    \n        <div class=\"jobtype chikusan\"><img src=\"../img/icon_chikusan.svg\" class=\"jobicon\"></div>\n\n        <div class=\"contents_inner notop\">\n            <h3 class=\"chikusan\">畜産部</h3>\n\n            <div class=\"job_box_l\">\n                <img src=\"../imgs/chikusan2.JPG\">\n            </div>\n            <div class=\"job_box_r\">\n                <h4 class=\"chikusan\">仕事内容</h4>\n                <p>畜産部では牛肉、豚肉、鶏肉の精肉とハムなどの加工肉を担当しています。アオキスーパー自慢の国産の牛肉はバイヤーが厳選した上質の和牛のみを取り扱っています。畜産部のお仕事の面白さは、仕入れた精肉の原料をどのように加工するかにより、いろいろな用途の商品が作れるところにあります。牛肉の特徴を最大限に引き出すために手切りでの加工や、スライサーを使用してミリ単位にこだわった加工をするなど様々です。特別な日に高級なお肉ではなく、普段から高品質のお肉をお値打ち価格で提供することで食卓に笑顔を運びましょう！ </p>\n                <a href=\"https://job.mynavi.jp/27/pc/search/corp104837/outline.html\" target=\"_blank\" onclick=\"gtag_report_conversion();\">\n                    <div class=\"btn btn_chikusan\">新卒採用はこちら</div>\n                </a>\n                <a href=\"https://aokisuper-recruit.net/jobfind-pc/area/All?jobtype=00107\" target=\"_blank\">\n                    <div class=\"btn btn_chikusan\">中途採用はこちら</div>\n                </a>\n            </div>\n        </div>\n        <div class=\"clear\"></div>\n\n    \n        <div class=\"jobtype delica\"><img src=\"../img/icon_delica.svg\" class=\"jobicon\"></div>\n\n        <div class=\"contents_inner notop\">\n            <h3 class=\"delica\">デリカ部</h3>\n\n            <div class=\"job_box_l\">\n                <img src=\"../imgs/MD4_1152.jpg\">\n            </div>\n            <div class=\"job_box_r\">\n                <h4 class=\"delica\">仕事内容</h4>\n                <p>デリカ部はお寿司とデリカ（お弁当や揚げ物）の製造販売をします。デリカ部の1日は商品を調理して、売場に陳列することから始まります。同じ商品であっても、工夫次第で売れ行きが毎日変化します。季節のイベントや行事が1年を通じて訪れてきます。それに合わせて販売計画を練って、売場のレイアウトから商品陳列、加工の仕方などを考え、販売数量を考えていただきます。お客様との会話の中から新しい商品アイデアが生まれます。</p>\n                <a href=\"https://job.mynavi.jp/27/pc/search/corp104837/outline.html\" target=\"_blank\" onclick=\"gtag_report_conversion();\">\n                    <div class=\"btn btn_delica\">新卒採用はこちら</div>\n                </a>\n                <a href=\"https://aokisuper-recruit.net/jobfind-pc/area/All?jobtype=00112\" target=\"_blank\">\n                    <div class=\"btn btn_delica\">中途採用はこちら</div>\n                </a>\n            </div>\n        </div>\n        <div class=\"clear\"></div>\n\n    \n        <div class=\"jobtype ippan\"><img src=\"../img/icon_ippan.svg\" class=\"jobicon\"></div>\n\n        <div class=\"contents_inner notop\">\n            <h3 class=\"ippan\">一般部</h3>\n\n            <div class=\"job_box_l\">\n                <img src=\"../imgs/ph_ippan.jpg\">\n            </div>\n            <div class=\"job_box_r\">\n                <h4 class=\"ippan\">仕事内容</h4>\n                <p>一般部では一般食品・菓子・日配品・酒などの加工食品や雑貨を担当しています。取り扱い品目が多く、幅広い商品知識を身に付けることができる部署です。アオキスーパーの特長は、季節のイベントや地域行事に合わせ、販売したい商品、販売価格、販売数量、陳列場所を各売場担当者が決定できるところです。自分の思いのこもった商品が売れたときは喜びを感じ、更なるアイデアが生まれます。一般部は店舗運営も兼務していることから人材・設備・金銭の管理も行います。最初は部門担当者から始まり、副店長、店長へとステップアップをしていただきます。</p>\n                <a href=\"https://job.mynavi.jp/27/pc/search/corp104837/outline.html\" target=\"_blank\" onclick=\"gtag_report_conversion();\">\n                    <div class=\"btn btn_ippan\">新卒採用はこちら</div>\n                </a>\n                <a href=\"https://aokisuper-recruit.net/jobfind-pc/area/All?jobtype=00111\" target=\"_blank\">\n                    <div class=\"btn btn_ippan\">中途採用はこちら</div>\n                </a>\n            </div>\n        </div>\n        <div class=\"clear\"></div>\n\n    \n        <div class=\"jobtype honbu\"><img src=\"../img/icon_honbu.svg\" class=\"jobicon\"></div>\n\n        <div class=\"contents_inner notop\">\n            <h3 class=\"honbu\">本部</h3>\n\n            <div class=\"job_box_l\">\n                <img src=\"../imgs/ph_honbu.jpg\">\n            </div>\n            <div class=\"job_box_r\">\n                <h4 class=\"honbu\">仕事内容</h4>\n                <p>本社には店舗運営を円滑にするために、開発部、人事部、総務部、経理部、情報システム部、販売推進部、検査室と多様な部署があります。少子高齢・人口減少による経費の増加、原料価格上昇による販売価格の上昇など先行きが不透明な時代です。それぞれの課題を一つずつ解決改善していく縁の下の力持ち的な存在と言えるでしょう。新卒の方はもちろん中途採用の方も活躍をしています。</p>\n                <a href=\"https://job.mynavi.jp/27/pc/search/corp104837/outline.html\" target=\"_blank\" onclick=\"gtag_report_conversion();\">\n                    <div class=\"btn btn_honbu\">新卒採用はこちら</div>\n                </a>\n                <a href=\"https://aokisuper-recruit.net/jobfind-pc/area/All?jobtype=00114\" target=\"_blank\">\n                    <div class=\"btn btn_honbu\">中途採用はこちら</div>\n                </a>\n            </div>\n        </div>\n        <div class=\"clear\"></div>\n\n    \n\n</div>\n<!-- フッター ---------------------------------------------------------------------------------------->\n<div id=\"footer1\">\n    <div id=\"f_menu_area\">\n        <div class=\"f_menu\">\n            <ul>\n                <li class=\"hn3\"><a href=\"/\"><img src=\"/_common/imgs/f_arrow.svg\" class=\"arrow\">トップ</a></li>\n                <li class=\"hn3\"><a href=\"/shop/\"><img src=\"/_common/imgs/f_arrow.svg\" class=\"arrow\">店舗・チラシ</a></li>\n            </ul>\n        </div>\n        <div class=\"f_menu\">\n            <ul>\n                <li class=\"hn3\"><a href=\"/card/\"><img src=\"/_common/imgs/f_arrow.svg\" class=\"arrow\">ポイントカード</a></li>\n                <li class=\"hn3\"><a href=\"/smartreceipt/\"><img src=\"/_common/imgs/f_arrow.svg\" class=\"arrow\">スマートレシート</a></li>\n            </ul>\n        </div>\n        <div class=\"f_menu\">\n            <ul>\n                <li class=\"hn3\"><a href=\"/news\"><img src=\"/_common/imgs/f_arrow.svg\" class=\"arrow\">ニュースリリース</a></li>\n            </ul>\n        </div>\n        <div class=\"f_menu\">\n            <ul>\n                <li class=\"hn3\"><a href=\"/company/outline.html\"><img src=\"/_common/imgs/f_arrow.svg\" class=\"arrow\">会社情報</a></li>\n                <li class=\"hn3\"><a href=\"/company/koukoku.html\"><img src=\"/_common/imgs/f_arrow.svg\" class=\"arrow\">電子公告</a></li>\n            </ul>\n        </div>\n        <div class=\"f_menu\">\n            <ul>\n                <li class=\"hn3\"><a href=\"/recruit\"><img src=\"/_common/imgs/f_arrow.svg\" class=\"arrow\">採用情報</a></li>\n            </ul>\n        </div>\n    </div>\n</div>\n<div id=\"footer2\">\n    <div class=\"f_menu_sub\">\n        <a href=\"/use/\"><img src=\"/_common/imgs/f_arrow.svg\" class=\"arrow\">ご利用にあたって</a>　　<a href=\"/sustainability/\"><img src=\"/_common/imgs/f_arrow.svg\" class=\"arrow\">サステナビリティ基本方針</a>　　<a href=\"/customer_harassment/\"><img src=\"/_common/imgs/f_arrow.svg\" class=\"arrow\">カスタマーハラスメントに対する基本方針</a>　　<a href=\"/privacy/\"><img src=\"/_common/imgs/f_arrow.svg\" class=\"arrow\">プライバシーポリシー</a>　　<a href=\"/sitemap/\"><img src=\"/_common/imgs/f_arrow.svg\" class=\"arrow\">サイトマップ</a>\n    </div>\n</div>\n<div id=\"cc\">\n    Copyright © Aoki Super co.,ltd. All rights reserved.\n</div>\n<p id=\"page-top\"><a href=\"#wrap\"><img src=\"/_common/imgs/btn_pagetop.svg\" width=\"100%\" alt=\"PAGE TOP\"/></a></p>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"//maxcdn.bootstrapcdn.com/font-awesome/4.3.0/css/font-awesome.min.css\">\n\n\n<script>\n$(function() {\n    $(\".menuicon p\").click( function() {\n        $(\".sp_pulldown_menu\").css(\"display\",\"none\");\n        $(this).next(\".sp_pulldown_menu\").toggle();\n    })\n    $(\".fix .close\").click(function(){\n        $(\".fix\").not('#truefix').fadeOut();\n    });\n})\n</script>\n<!-- TOPICS --> \n<script src=\"../../home/js/vendor/jquery.touchSwipe.min.js\"></script>\n<script src=\"../../home/js/jquery.film_roll.min.js\"></script>\n<script src=\"../../home/js/index.js\"></script>\n<!-- スマホNAV --> \n<script type=\"text/javascript\" src=\"../../_common/js/jquery.fatNav.min.js\"></script>\n<script src=\"../../_common/js/menu.js\"></script>\n\n</body>\n</html>","finalUrl":"https://aokisuper.co.jp/recruit/job/","rendered":false,"_cachedAt":"2026-06-22T21:10:53.427Z"}