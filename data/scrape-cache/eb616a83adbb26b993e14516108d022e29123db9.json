dd-css' href='https://sanbe-denki.co.jp/wp-content/themes/sanbedenki/css/add.css?ver=1.0.0' media='all' />\n<link rel=\"https://api.w.org/\" href=\"https://sanbe-denki.co.jp/wp-json/\" /><link rel=\"alternate\" title=\"JSON\" type=\"application/json\" href=\"https://sanbe-denki.co.jp/wp-json/wp/v2/pages/17\" /><link rel=\"EditURI\" type=\"application/rsd+xml\" title=\"RSD\" href=\"https://sanbe-denki.co.jp/xmlrpc.php?rsd\" />\n<meta name=\"generator\" content=\"WordPress 7.0\" />\n<link rel=\"canonical\" href=\"https://sanbe-denki.co.jp/recruit\" />\n<link rel='shortlink' href='https://sanbe-denki.co.jp/?p=17' />\n\n<meta property=\"og:title\" content=\"採用情報\">\n<meta property=\"og:description\" content=\"\">\n<meta property=\"og:type\" content=\"article\">\n<meta property=\"og:url\" content=\"https://sanbe-denki.co.jp/recruit\">\n<meta property=\"og:image\" content=\"https://sanbe-denki.co.jp/wp-content/themes/sanbedenki/img/common/ogp.jpg\">\n<meta property=\"og:site_name\" content=\"サンベ電気株式会社\">\n<meta name=\"twitter:card\" content=\"summary_large_image\">\n<meta name=\"twitter:site\" content=\"\">\n<meta property=\"og:locale\" content=\"ja_JP\">\n<link rel=\"icon\" href=\"https://sanbe-denki.co.jp/wp-content/uploads/2025/07/cropped-favicon-32x32.png\" sizes=\"32x32\" />\n<link rel=\"icon\" href=\"https://sanbe-denki.co.jp/wp-content/uploads/2025/07/cropped-favicon-192x192.png\" sizes=\"192x192\" />\n<link rel=\"apple-touch-icon\" href=\"https://sanbe-denki.co.jp/wp-content/uploads/2025/07/cropped-favicon-180x180.png\" />\n<meta name=\"msapplication-TileImage\" content=\"https://sanbe-denki.co.jp/wp-content/uploads/2025/07/cropped-favicon-270x270.png\" />\n\n</head>\n<body>\n\n    <div class=\"container\">\n\n    <header class=\"header\">\n        <div class=\"h_logo_wrap\">\n            <h1 class=\"h_logo\"><a href=\"https://sanbe-denki.co.jp/\"><img src=\"https://sanbe-denki.co.jp/wp-content/themes/sanbedenki/img/common/logo.png\" alt=\"サンベ電気株式会社\"></a></h1>\n        </div>\n        <nav class=\"h_nav\">\n            <ul class=\"h_items\">\n                <li class=\"h_item\"><a href=\"https://sanbe-denki.co.jp/about-us\" class=\"h_item_link \"><span class=\"en\">ABOUT US</span>サンベ電気について</a></li>\n                <li class=\"h_item\"><a href=\"https://sanbe-denki.co.jp/#works\" class=\"h_item_link \"><span class=\"en\">WORKS</span>業務案内</a></li>\n                <li class=\"h_item\"><a href=\"https://sanbe-denki.co.jp/company\" class=\"h_item_link \"><span class=\"en\">COMPANY</span>会社案内</a></li>\n                <li class=\"h_item\"><a href=\"https://sanbe-denki.co.jp/recruit\" class=\"h_item_link active\"><span class=\"en\">RECRUIT</span>採用情報</a></li>\n                <li class=\"h_item\"><a href=\"https://sanbe-denki.co.jp/contact\" class=\"h_item_link \"><span class=\"en\">CONTACT</span>お問い合わせ</a></li>\n            </ul>\n        </nav>\n    </header>\n\n    <div class=\"d_icon\">\n        <div class=\"d_icon_bars\">\n            <span class=\"bar bar1\"></span>\n            <span class=\"bar bar2\"></span>\n            <span class=\"bar bar3\"></span>\n        </div>\n        <div class=\"d_icon_menu\">MENU</div>\n    </div>\n\n    <main class=\"main\">\n\n<div class=\"p-recruit_bg js-parallax\">\n    <div class=\"js-parallax_img\"><img src=\"https://sanbe-denki.co.jp/wp-content/themes/sanbedenki/img/page/recruit_bg.jpg\" alt=\"image\"></div>\n</div>\n\n<section class=\"p-recruit\">\n    <div class=\"p-recruit_head\">\n        <div class=\"inner\">\n            <hgroup class=\"p_title text_white\">\n                <p><img src=\"https://sanbe-denki.co.jp/wp-content/themes/sanbedenki/img/page/ttl_recruit.svg\" alt=\"Recruit\"></p>\n                <h1>採用情報</h1>\n            </hgroup>\n        </div>\n        <section class=\"p-recruit_head_wrapper\">\n            <div class=\"p-recruit_head_wrap\">\n                <div class=\"p-recruit_head_texts\">\n                    <hgroup class=\"p-recruit_head_title\">\n                        <p>MESSAGE</p>\n                        <h3>採用への思い</h3>\n                    </hgroup>\n                    <p class=\"p-recruit_head_text\">全ての社員が健康で安心でき、働き甲斐のある企業を目指しています。女性はもちろん、高齢者や障がい者、外国人などの採用も積極的に行っています。また無資格、未経験者も大歓迎です。</p>\n                    <p class=\"p-recruit_head_by\">採用担当<span class=\"name\">泉頭直貴</span></p>\n                    <div class=\"p-recruit_head_logo\"><img src=\"https://sanbe-denki.co.jp/wp-content/themes/sanbedenki/img/page/logo_illust_color.svg\" alt=\"image\"></div>\n                </div>\n                <div class=\"p-recruit_head_imgs\">\n                    <div class=\"p-recruit_head_img\"><img src=\"https://sanbe-denki.co.jp/wp-content/themes/sanbedenki/img/page/recruit_message.png\" alt=\"image\"></div>\n                    <div class=\"p-recruit_head_img_bg\"></div>\n                </div>\n            </div>\n        </section>\n        <section class=\"p-voice\">\n            <div class=\"inner\">\n                <hgroup class=\"p_title p-recruit_section_title\">\n                    <p><img src=\"https://sanbe-denki.co.jp/wp-content/themes/sanbedenki/img/page/ttl_voice.svg\" alt=\"Voice\"></p>\n                    <h2>先輩社員の声</h2>\n                </hgroup>\n                <ul class=\"p-voice_lists\">\n                    <li class=\"p-voice_list\">\n                        <div class=\"p-voice_list_img\"><img src=\"https://sanbe-denki.co.jp/wp-content/themes/sanbedenki/img/page/voice01_img.jpg\" alt=\"image\"></div>\n                        <div class=\"p-voice_list_body\">\n                            <div class=\"p-voice_list_num\"><img src=\"https://sanbe-denki.co.jp/wp-content/themes/sanbedenki/img/page/voice_01.svg\" alt=\"01\"></div>\n                            <p class=\"p-voice_list_lead\">仕事の楽しさや現場が<br class=\"is_sp\">完成した時の<br>達成感があります！</p>\n                            <div class=\"p-voice_list_texts\">\n                                <p class=\"p-voice_list_text show\">私がサンベ電気に入社して感じたことは、職場の雰囲気が明るく、仕事を丁寧に細かく教えて下さり、素人の私にも積極的に作業をさせてくれる頼もしい先輩社員が多く在籍されている会社だなということです。仕事では、日々同じ作業ばかりではなく、電気工事全般からちょっとした土木作業など、現場職として色々な役割をこなす為、多くの仕事が覚えられる楽しい仕事だと感じています。難しいことがたくさんありますが、その分仕事を覚え、自分でできる作業がひとつずつ増えると、先輩方から「これやっといてくれん?」と少しずつ頼まれるようになってきて、その言葉が増えてきた時はすごくやりがいを感じます。丁寧な仕事をすることで仕事を任せてもらえ、丁寧な仕事をする事で良い施工ができ、それが結局地域のお客様に喜んでいただけ、私達のやる気と活力にも繋がります。これからも、電気職人のプロを目指して頑張りたいと思います。 </p>\n                            </div>\n                            <div class=\"p-voice_list_bottom\">\n                                <p class=\"p-voice_list_name\">松江営業所 工務課<span class=\"name\">富永 広輝</span></p>\n                                <p class=\"p-voice_list_since\">2024年11月入社</p>\n                            </div>\n                            <button class=\"p-voice_list_button active\">全文を読む</button>\n                        </div>\n                    </li>\n                    <li class=\"p-voice_list\">\n                        <div class=\"p-voice_list_img\"><img src=\"https://sanbe-denki.co.jp/wp-content/themes/sanbedenki/img/page/voice02_img.jpg\" alt=\"image\"></div>\n                        <div class=\"p-voice_list_body\">\n                            <div class=\"p-voice_list_num\"><img src=\"https://sanbe-denki.co.jp/wp-content/themes/sanbedenki/img/page/voice_02.svg\" alt=\"02\"></div>\n                            <p class=\"p-voice_list_lead\">先輩方が丁寧に教えてくださり<br>仕事が楽しくなっていきました。</p>\n                            <div class=\"p-voice_list_texts\">\n                                <p class=\"p-voice_list_text show\">入社して5年目になりますが、働いてみて今感じることは、やりがいがあり、風の通しの良い職場だと思います。私が今担当している仕事は主に一般住宅の改修工事で、お客様のニーズに応えられるよう日々努力しています。また、基本的に後輩と一緒に現場を回っていますが、入社した時は自分が現場で役に立てるか心配でした。しかし、分からないことがあれば先輩方が丁寧に教えてくださり、できることが増えていき、仕事が楽しくなっていきました。今後はもっと職場にも地域にも貢献できるように、日々成長していきたいと思います。</p>\n                            </div>\n                            <div class=\"p-voice_list_bottom\">\n                                <p class=\"p-voice_list_name\">出雲営業所 工務課<span class=\"name\">松島 史瑛太</span></p>\n                                <p class=\"p-voice_list_since\">2021年年4月入社</p>\n                            </div>\n                            <button class=\"p-voice_list_button active\">全文を読む</button>\n                        </div>\n                    </li>\n                    <li class=\"p-voice_list\">\n                        <div class=\"p-voice_list_img\"><img src=\"https://sanbe-denki.co.jp/wp-content/themes/sanbedenki/img/page/voice03_img.jpg\" alt=\"image\"></div>\n                        <div class=\"p-voice_list_body\">\n                            <div class=\"p-voice_list_num\"><img src=\"https://sanbe-denki.co.jp/wp-content/themes/sanbedenki/img/page/voice_03.svg\" alt=\"03\"></div>\n                            <p class=\"p-voice_list_lead\">仕事の楽しさや現場が<br>完成した時の<br>達成感があります！</p>\n                            <div class=\"p-voice_list_texts\">\n                                <p class=\"p-voice_list_text\">入社して3年目になりますが、入社当初から職場の雰囲気がよく働きやすい会社だと、3年経った今でも感じています。 私は中途で入社したので、前職との環境の変化でわからないことばかりでしたが、先輩の方々に一つ一つ丁寧に教えていただき、できることが徐々に増え、できることが増えたことにより仕事の楽しさや現場が完成した時の達成感をより感じることができています。 失敗や成功を繰り返し、経験からくる知識や技術を大事にしながら、日々成長していきたいと思います。</p>\n                            </div>\n                            <div class=\"p-voice_list_bottom\">\n                                <p class=\"p-voice_list_name\">松江営業所 工務課<span class=\"name\">宮廻 和生</span></p>\n                                <p class=\"p-voice_list_since\">2022年8月入社</p>\n                            </div>\n                            <button class=\"p-voice_list_button\">全文を読む</button>\n                        </div>\n                    </li>\n                    <li class=\"p-voice_list\">\n                        <div class=\"p-voice_list_img\"><img src=\"https://sanbe-denki.co.jp/wp-content/themes/sanbedenki/img/page/voice04_img.jpg\" alt=\"image\"></div>\n                        <div class=\"p-voice_list_body\">\n                            <div class=\"p-voice_list_num\"><img src=\"https://sanbe-denki.co.jp/wp-content/themes/sanbedenki/img/page/voice_04.svg\" alt=\"04\"></div>\n                            <p class=\"p-voice_list_lead\">やりがいを感じる瞬間は<br>お客様に感謝の言葉を<br>言われた時です！</p>\n                            <div class=\"p-voice_list_texts\">\n                                <p class=\"p-voice_list_text\">自分が学生の頃は建設業にあまり良い印象がなく、働くことにとても不安を感じていました。しかし、いざサンベ電気に入社してみると先輩や上司の方々が優しく丁寧に指導してくださるので前向きに仕事に取り組めています。お客様に感謝の言葉を言われた時が一番やりがいを感じる瞬間です。これからも向上心を持ち続けて知識や技術を身に着けて地域や会社に貢献できる一人前の電気工事士になれるように頑張っていきたいと思います。</p>\n                            </div>\n                            <div class=\"p-voice_list_bottom\">\n                                <p class=\"p-voice_list_name\">松江営業所 工務課<span class=\"name\">菊島 天澄</span></p>\n                                <p class=\"p-voice_list_since\">2022年4月入社</p>\n                            </div>\n                            <button class=\"p-voice_list_button\">全文を読む</button>\n                        </div>\n                    </li>\n                    <li class=\"p-voice_list\">\n                        <div class=\"p-voice_list_img\"><img src=\"https://sanbe-denki.co.jp/wp-content/themes/sanbedenki/img/page/voice05_img.jpg\" alt=\"image\"></div>\n                        <div class=\"p-voice_list_body\">\n                            <div class=\"p-voice_list_num\"><img src=\"https://sanbe-denki.co.jp/wp-content/themes/sanbedenki/img/page/voice_05.svg\" alt=\"05\"></div>\n                            <p class=\"p-voice_list_lead\">朝礼では教養を学び<br>協調性につながっています。</p>\n                            <div class=\"p-voice_list_texts\">\n                                <p class=\"p-voice_list_text\">私は、中国の東北地方長春市出身です。日本人の妻と、埼玉から島根県雲南市に移住して来ました。入社初日から社内の雰囲気が良く、明るく健康的だと感じています。毎日の朝礼では、社会人としての教養を学んでいます。正しい行い、心がけが身につき、現場での協力や協調につながっていると思います。私は日本語があまり上手くありませんが、先輩が優しく丁寧に詳しく教えてくださいますので、自己の成長を感じることができ、楽しく仕事ができていることに感謝しています。これからも、しっかり技術と知識を身につけるよう努力し、地域社会に貢献できるよう頑張っていきたいと思っています。</p>\n                            </div>\n                            <div class=\"p-voice_list_bottom\">\n                                <p class=\"p-voice_list_name\">出雲営業所 工務課<span class=\"name\">張 其瑞</span></p>\n                                <p class=\"p-voice_list_since\">2025年2月入社</p>\n                            </div>\n                            <button class=\"p-voice_list_button\">全文を読む</button>\n                        </div>\n                    </li>\n                </ul>\n            </div>\n        </section>\n        <section class=\"p-requirements\">\n            <div class=\"inner\">\n                <hgroup class=\"p_title p-recruit_section_title text_white\">\n                    <p><img src=\"https://sanbe-denki.co.jp/wp-content/themes/sanbedenki/img/page/ttl_requirements.svg\" alt=\"Requirements\"></p>\n                    <h2 class=\"lg\">募集要項</h2>\n                </hgroup>\n                <p class=\"p-requirements_text text_white\">面接、または見学をご希望される方は<br class=\"is_sp\">下記のエントリーフォームにご記入いただき、<br class=\"is_sp\">ご送信をお願いします。 <br>ご応募を心よりお待ちしております。</p>\n\n                                <div class=\"p-requirements_details inner_s\">\n                    <table class=\"p-requirements_table\">\n                        <tbody>\n                                                        <tr>\n                                <th>募集職種</th>\n                                <td>電気工事、管工事、電気通信工事、空調工事、太陽光発電設備の設計・施工</td>\n                            </tr>\n                                                        <tr>\n                                <th>勤務地</th>\n                                <td>松江（本社）、安来、出雲、大田、川本、浜田</td>\n                            </tr>\n                                                        <tr>\n                                <th>勤務時間</th>\n                                <td>平日 8：00～17：00</td>\n                            </tr>\n                                                        <tr>\n                                <th>雇用形態</th>\n                                <td>正社員</td>\n                            </tr>\n                                                        <tr>\n                                <th>資格</th>\n                                <td>普通自動車運転免許証</td>\n                            </tr>\n                                                        <tr>\n                                <th>給与</th>\n                                <td>高校新卒（技術系）185,000円〜<br />\r\n※中途採用の場合は、年齢・経験・能力を考慮の上、優遇いたします。</td>\n                            </tr>\n                                                        <tr>\n                                <th>諸手当</th>\n                                <td>通勤手当、役職手当、残業手当、家族手当、住宅手当、資格取得報奨金、資格手当、現場代理人手当　※契約形態により異なります。</td>\n                            </tr>\n                                                        <tr>\n                                <th>昇給</th>\n                                <td>年１回　（7月）</td>\n                            </tr>\n                                                        <tr>\n                                <th>賞与</th>\n                                <td>年２回　（７月・12月）</td>\n                            </tr>\n                                                        <tr>\n                                <th>休暇</th>\n                                <td>休日（4週7休）（土（第1のみ勤務）、日、祝、他、会社年間カレンダーによる)、年末年始、有給休暇、慶弔休暇、産前産後休暇、育児休暇、介護休暇、健康休暇、地域休暇<br />\r\n年間休日実績：2021年度実績115日</td>\n                            </tr>\n                                                        <tr>\n                                <th>社会保険</th>\n                                <td>健康保険、介護保険、厚生年金保険、雇用保険、労災保険</td>\n                            </tr>\n                                                        <tr>\n                                <th>福利厚生</th>\n                                <td>退職金制度（定年70歳、70歳～75歳まで1年毎の更新、再雇用制度有）、健康診断、財形貯蓄、酷暑手当（7～9月）</td>\n                            </tr>\n                                                    </tbody>\n                    </table>\n                </div>\n                \n                <section class=\"p-requirements_benefits inner_s\">\n                    <hgroup class=\"p_title p-recruit_section_title text_white\">\n                        <h2 class=\"lg\">福利厚生</h2>\n                    </hgroup>\n                                        <table class=\"p-requirements_table\">\n                        <tbody>\n                            <tr>\n                                <th>項　目</th>\n                                <th>該当者</th>\n                                <th>支給要件及び内容等</th>\n                            </tr>\n                                                        <tr>\n                                <th class=\"level1\">家 族 手 当</th>\n                                <td class=\"text_center\">1名以上の子息</td>\n                                <td>1名増えるごとに増額</td>\n                            </tr>\n                                                        <tr>\n                                <th class=\"level1\">住 宅 手 当</th>\n                                <td class=\"text_center\">自己所有者</td>\n                                <td>住宅ローン返済者</td>\n                            </tr>\n                                                        <tr>\n                                <th class=\"level1\">住 宅 手 当</th>\n                                <td class=\"text_center\">借上げ住宅</td>\n                                <td>家賃3万円以上</td>\n                            </tr>\n                                                        <tr>\n                                <th class=\"level1\">長期貸付金</th>\n                                <td class=\"text_center\">住宅資金（購入.改築）・<br />\r\n車購入等</td>\n                                <td>低利融資（給料、賞与返済）<br />\r\n利率（年）=0.6%</td>\n                            </tr>\n                                                        <tr>\n                                <th class=\"level1\">貸与工具</th>\n                                <td class=\"text_center\">技術系職員</td>\n                                <td>会社よりの貸与品 ・・・・ 腰回り工具(安全帯、ランヤード等)、電動工具（インパクト・ドリルドライバー等)</td>\n                            </tr>\n                                                        <tr>\n                                <th class=\"level1\">作業服・<br />\r\n作業靴類</th>\n                                <td class=\"text_center\">〃</td>\n                                <td>会社よりの貸与品 ・・・・ 作業服（夏、冬）・雨衣 ・防寒着・作業靴・安全帽</td>\n                            </tr>\n                                                        <tr>\n                                <th class=\"level1\">通勤車両駐車料</th>\n                                <td class=\"text_center\">自己所有車両通勤者</td>\n                                <td>無料</td>\n                            </tr>\n                                                        <tr>\n                                <th class=\"level1\">情報交換会<br />\r\n助成費</th>\n                                <td class=\"text_center\">全　職　員</td>\n                                <td>年3回　会社補助、営業所単位で実施</td>\n                            </tr>\n                                                        <tr>\n                                <th class=\"level1\">ジョイメイト<br />\r\n会員</th>\n                                <td class=\"text_center\">全　職　員</td>\n                                <td>各種祝金（入学・勤続・誕生）・各種斡旋（薬品,イベント助成）・指定店割引制度・（月例会費会社負担）</td>\n                            </tr>\n                                                        <tr>\n                                <th class=\"level1\">積立金制度</th>\n                                <td class=\"text_center\">全職員</td>\n                                <td>積立NISA(特別奨励金有)</td>\n                            </tr>\n                                                        <tr>\n                                <th class=\"level1\">資格取得助成</th>\n                                <td class=\"text_center\">全職員</td>\n                                <td>準備講習費、教材費、交通費、宿泊費</td>\n                            </tr>\n                                                        <tr>\n                                <th class=\"level1\">退職金制度</th>\n                                <td class=\"text_center\">勤続 3年以上</td>\n                                <td>会社規定による</td>\n                            </tr>\n                                                        <tr>\n                                <th class=\"level2\">生命保険会社</th>\n                                <td class=\"text_center\">勤続 半年以上</td>\n                                <td>入院 ・手術に適用<br />\r\n団体3大疾病保障保険</td>\n                            </tr>\n                                                        <tr>\n                                <th class=\"level3\">技能資格合格祝金</th>\n                                <td class=\"text_center\">1～3回迄の合格者</td>\n                                <td>1級、2級(電気・管・通信)施工管理他</td>\n                            </tr>\n                                                        <tr>\n                                <th class=\"level3\">技能コンクール</th>\n                                <td class=\"text_center\">出場者 1名当たり</td>\n                                <td>特別手当（上位入賞者は別途 祝金あり）</td>\n                            </tr>\n                                                        <tr>\n                                <th class=\"level3\">優良工事受賞者</th>\n                                <td class=\"text_center\">被 表 彰 者</td>\n                                <td>報奨金</td>\n                            </tr>\n                                                    </tbody>\n                    </table>\n                    <ul class=\"p-requirements_benefits_levels\">\n                        <li class=\"p-requirements_benefits_level -level1\">雇用されていて一定の条件を満たした人に<br class=\"is_sp\">支給される項目</li>\n                        <li class=\"p-requirements_benefits_level -level2\">万一という時に支給される項目</li>\n                        <li class=\"p-requirements_benefits_level -level3\">頑張れば支給される項目</li>\n                    </ul>\n                                    </section>\n            </div>\n        </section>\n\n        <div class=\"p-recruit_contact\">\n            <div class=\"in