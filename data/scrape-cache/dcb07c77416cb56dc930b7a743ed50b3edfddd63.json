\"></div>\r\n\t<div id=\"dnn_ctr945_ContentPane\"><!-- Start_Module_945 --><div id=\"dnn_ctr945_ModuleContent\">\r\n\t\r\n<!-- End_Module_945 -->\r\n</div></div>\r\n</section>\r\n\r\n</div>\r\n                </div>\r\n            </div>\r\n        </div>\r\n        <div id=\"dnn_MegaMenuPane\" class=\"MegaMenuPane\">\r\n<div class=\"ic-moduleheader\"></div>\r\n<section class=\"moduleSkin moduleZero\">\r\n\t<div class=\"moduleButton\"></div>\r\n\t<div id=\"dnn_ctr980_ContentPane\"><!-- Start_Module_980 --><div id=\"dnn_ctr980_ModuleContent\">\r\n\t<div id=\"dnn_ctr980_ViewContent_lblContent\">\r\n\t\t\r\n\t</div>\r\n\r\n\r\n\r\n<!-- End_Module_980 -->\r\n</div></div>\r\n</section>\r\n\r\n</div>\r\n    </header>\r\n    <div id=\"main\">\r\n        <div class=\"breadcrumb\">\r\n            <header id=\"dnn_BreadcrumbPane\" class=\"BreadcrumbPane\">\r\n<div class=\"ic-moduleheader\"></div>\r\n<section class=\"moduleSkin moduleZero\">\r\n\t<div class=\"moduleButton\"></div>\r\n\t<div id=\"dnn_ctr979_ContentPane\"><!-- Start_Module_979 --><div class=\"breadcrumbList\"><div id=\"dnn_ctr979_ModuleContent\">\r\n\t\r\n<!-- End_Module_979 -->\r\n</div></div></div>\r\n</section>\r\n\r\n</header>\r\n        </div>\r\n        <div class=\"contentWrapper\">\r\n            <div class=\"pageTitle\">\r\n                <header id=\"dnn_PagetitlePane\" class=\"PagetitlePane\">\r\n<div class=\"ic-moduleheader\"></div>\r\n<section class=\"moduleSkin moduleZero\">\r\n\t<div class=\"moduleButton\"></div>\r\n\t<div id=\"dnn_ctr917_ContentPane\"><!-- Start_Module_917 --><div id=\"dnn_ctr917_ModuleContent\">\r\n\t<!-- End_Module_917 -->\r\n</div></div>\r\n</section>\r\n\r\n</header>\r\n            </div>\r\n            <div class=\"contentTop\">\r\n                <div id=\"dnn_ContentTopPane\" class=\"ContentTopPane DNNEmptyPane\"></div>\r\n            </div>\r\n            <div class=\"content00\">\r\n                <div class=\"inner matchHeightWrap\">\r\n                    <div id=\"dnn_ContentLPane\" class=\"ContentLPane DNNEmptyPane\"></div>\r\n                    <div id=\"dnn_ContentRPane\" class=\"ContentRPane DNNEmptyPane\"></div>\r\n                </div>\r\n            </div>\r\n            <div class=\"contentMiddle\">\r\n                <div class=\"inner\">\r\n                    <main class=\"mainArea\">\r\n                        <div id=\"dnn_ContentPane\" class=\"ContentPane\">\r\n<div class=\"ic-moduleheader\"></div>\r\n<section class=\"moduleSkin moduleZero\">\r\n\t<div class=\"moduleButton\"></div>\r\n\t<div id=\"dnn_ctr918_ContentPane\"><!-- Start_Module_918 --><div id=\"dnn_ctr918_ModuleContent\">\r\n\t\r\n<p class=\"alignCenter\"><img alt=\"\" src=\"/Portals/0/files/recruit/challenged/index/images/img_mainvisual.jpg\" /></p>\r\n<h2>採用担当者より</h2>\r\n\t\t\t\t\t\r\n<p>第一三共グループでは、インクルージョン＆ダイバーシティ（誰もが区別されることなく、最大限に実力を発揮すること）に基づき、障がいのある方の採用と継続的に活躍できる職場環境の整備を図っており、現在国内では約150人の障がいのある社員が全国で働いています。<br />\r\n<br />\r\n当社の社員それぞれの仕事は、人々の命・健康につながっており、文系・理系など出身学部に関わらず、やりがいを持って働くことができます。<br />\r\n<br />\r\n入社の際には、丁寧にお話を伺い、皆さんの能力が発揮できるような職場のマッチングと必要なサポートを図ってまいります。お互いを知るために、自分を飾らず、強み・弱み、必要な配慮や質問などを遠慮なく、具体的に自分の言葉で伝えてください。 当社としても皆さんの言葉を受け止めた上で、会社としてサポートできること、そしてできないことをお伝えし、お互いのマッチングが図れるよう情報を提供していきます。<br />\r\n<br />\r\nチャレンジ精神にあふれ、様々な個性、異なる文化や価値観の中で刺激し合いながら成長し、自身の仕事を通じて世界中の人々の健康で豊かな生活に貢献したいという情熱と思いやりに満ちた方々をお待ちしています。<br />\r\n<br />\r\n</p>\r\n<div>\r\n<p class=\"alignCenter\"><img alt=\"\" src=\"/Portals/0/files/recruit/challenged/index/images/img_challenged_01.jpg\" /></p>\r\n<h2 class=\"txtBold\">募集要項</h2>\r\n<p>募集職種や勤務地などの募集要項と、応募後の選考の流れについてご案内いたします。<br />\r\n<br />\r\n</p>\r\n<table style=\"border:1px solid #dbe5f1;\" class=\"tableBasic notBlock full\">\r\n    <colgroup> <col width=\"20%\" /> <col width=\"80%\" /></colgroup>\r\n    <tbody>\r\n        <tr>\r\n            <td style=\"background-color: #17365d; color: #ffffff; font-size: larger; text-align: left; vertical-align: middle;\" rowspan=\"2\">募集職種</td>\r\n            <td style=\"border:1px solid #dbe5f1;text-align: left; vertical-align: middle; background-color: #ffffff;   color: #000000; font-size: larger;\">【キャリア採用】　<a href=\"https://mypage.1050.i-web.jpn.com/daiichisankyo_career/applicant/recruitment/index\" target=\"_blank\">キャリア採用のホームページをご覧ください。</a></td>\r\n        </tr>\r\n        <tr>\r\n            <td style=\"border:1px solid #dbe5f1;text-align: left; vertical-align: middle; background-color: #ffffff;   color: #000000; font-size: larger;\">【新卒採用】　　　コーポレートスタッフ　※現在は受付を終了しております。</td>\r\n        </tr>\r\n        <tr>\r\n            <td style=\"background-color: #17365d; color: #ffffff; font-size: larger; text-align: left; vertical-align: middle;\">応募資格</td>\r\n            <td style=\"border:1px solid #dbe5f1;text-align: left; vertical-align: middle; background-color: #ffffff;   color: #000000; font-size: larger;\">大卒以上の方</td>\r\n        </tr>\r\n        <tr>\r\n            <td style=\"background-color: #17365d; color: #ffffff; font-size: larger; text-align: left; vertical-align: middle;\">雇用形態</td>\r\n            <td style=\"border:1px solid #dbe5f1;text-align: left; vertical-align: middle; background-color: #ffffff;   color: #000000; font-size: larger;\">正社員（試用期間3か月）</td>\r\n        </tr>\r\n        <tr>\r\n            <td style=\"background-color: #17365d; color: #ffffff; font-size: larger; text-align: left; vertical-align: middle;\" rowspan=\"2\">勤務地</td>\r\n            <td style=\"border:1px solid #dbe5f1;text-align: left; vertical-align: middle; background-color: #ffffff;   color: #000000; font-size: larger;\">【キャリア採用】　東京（本社、研究所）、神奈川（研究所）、群馬（研究所）※職種により異なります。<br />\r\n            </td>\r\n        </tr>\r\n        <tr>\r\n            <td style=\"border:1px solid #dbe5f1;text-align: left; vertical-align: middle; background-color: #ffffff;   color: #000000; font-size: larger;\">【新卒採用】　　　東京（本社)</td>\r\n        </tr>\r\n        <tr>\r\n            <td style=\"background-color: #17365d; color: #ffffff; font-size: larger; text-align: left; vertical-align: middle;\" rowspan=\"2\">応募方法</td>\r\n            <td style=\"border:1px solid #dbe5f1;text-align: left; vertical-align: middle; background-color: #ffffff;   color: #000000; font-size: larger;\">【キャリア採用】　<a href=\"https://job.axol.jp/vb/c/daiichisankyo/work/search\" target=\"_blank\">採用ページ</a>からご希望の職種にご応募ください。<br />\r\n            </td>\r\n        </tr>\r\n        <tr>\r\n            <td style=\"border:1px solid #dbe5f1;text-align: left; vertical-align: middle; background-color: #ffffff;   color: #000000; font-size: larger;\">【新卒採用】　　　現在は受付を終了しております。</td>\r\n        </tr>\r\n        <tr>\r\n            <td style=\"background-color: #17365d; color: #ffffff; font-size: larger; text-align: left; vertical-align: middle;\">連絡先</td>\r\n            <td style=\"border:1px solid #dbe5f1;text-align: left; vertical-align: middle; background-color: #ffffff;   color: #000000; font-size: larger;\">〒103-8426　東京都中央区日本橋本町3-5-1<br />\r\n            第一三共株式会社　人事部　採用担当<br />\r\n            <br />\r\n            <p class=\"linkBtn alignLeft\"><a href=\"mailto:saiyo@daiichisankyo.co.jp\">メールでのお問い合わせはこちら</a></p>\r\n            </td>\r\n        </tr>\r\n    </tbody>\r\n</table>\r\n</div>\r\n\r\n\r\n<!-- End_Module_918 -->\r\n</div></div>\r\n</section>\r\n\r\n</div>\r\n                    </main>\r\n                </div>\r\n            </div>\r\n            <div class=\"content01\">\r\n                <div class=\"inner\">\r\n                    <div id=\"dnn_Content01Pane\" class=\"Content01Pane DNNEmptyPane\"></div>\r\n                </div>\r\n            </div>\r\n            <div class=\"content02\">\r\n                <div class=\"inner\">\r\n                    <div id=\"dnn_Content02Pane\" class=\"Content02Pane DNNEmptyPane\"></div>\r\n                </div>\r\n            </div>\r\n            <div class=\"content03\">\r\n                <div class=\"inner\">\r\n                    <div id=\"dnn_Content03Pane\" class=\"Content03Pane DNNEmptyPane\"></div>\r\n            