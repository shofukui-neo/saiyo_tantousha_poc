lay=swap\" rel=\"stylesheet\">\r\n    <!-- Global site tag (gtag.js) - Google Analytics -->\r\n    <script async src=\"https://www.googletagmanager.com/gtag/js?id=UA-176591669-1\"></script>\r\n    <script>\r\n      window.dataLayer = window.dataLayer || [];\r\n      function gtag(){dataLayer.push(arguments);}\r\n      gtag('js', new Date());\r\n\r\n      gtag('config', 'UA-176591669-1');\r\n    </script>\r\n    <script>\r\n    if (navigator.userAgent.indexOf('iPhone') > 0) {\r\n        let body = document.getElementsByTagName('body')[0];\r\n        body.classList.add('iPhone');\r\n    }\r\n     \r\n    if (navigator.userAgent.indexOf('iPad') > 0) {\r\n        let body = document.getElementsByTagName('body')[0];\r\n        body.classList.add('iPad');\r\n    }\r\n     \r\n    if (navigator.userAgent.indexOf('Android') > 0) {\r\n        let body = document.getElementsByTagName('body')[0];\r\n        body.classList.add('Android');\r\n    }\r\n    </script>\r\n</head>\r\n\r\n<body class=\"body\">\r\n\r\n    <div class=\"header_area\">\r\n      <header class=\"header\">\r\n         <div class=\"header_container_contain top_header flexbox\">\r\n              <div class=\"logo_area flexbox\">\r\n                <h1><a href=\"../\"><img src=\"../img/common/tit_logo.png\" alt=\"西井製作所\"></h1>\r\n                <p class=\"lh_18 logo_txt\">ナンバープレート・精密部品・航空機部品<br class=\"h-sp\">多岐にわたる開発・製造</p>\r\n              </div>\r\n              <div id=\"gnav\" class=\"gnav new_nav\">\r\n                <ul class=\"flexbox flex-justify-between ham-nav\">\r\n                    <li class=\"dp-n fw-16 br-b\"><a href=\"../\">トップページ</a></li>\r\n                    <li class=\"fw-16 br-b\"><a href=\"../history/\">西井製作所の歴史</a></li>\r\n                    <li class=\"fw-16 br-b\"><a href=\"../technique/\">製品</a></li>\r\n                    <li class=\"fw-16 br-b\"><a href=\"../facility/\">設備</a></li>\r\n                    <li class=\"fw-16 br-b\"><a href=\"../company/\" class=\"selected\">会社情報</a></li>\r\n                    <li class=\"fw-16 br-b\"><a href=\"../recruit/\">採用情報</a></li>\r\n                     <li class=\"fw-16 br-b\"><a href=\"https://www.hiroshima-nishii.co.jp/ikuma-lp/\" target=\"_blank\" class=\"blank-gnav\">伊久馬</a></li>\r\n              <li class=\"fw-16 br-b item_bottom\"><a href=\"http://www.hiroshima-nishii.co.jp/zaidan/\" target=\"_blank\" class=\"blank-gnav\">広島伝承技術振興センター</a></li>\r\n              <!--<li class=\"fw-16 br-b\"><a href=\"https://www.amazon.co.jp/%E8%A5%BF%E4%BA%95%E8%A3%BD%E4%BD%9C%E6%89%80%E7%99%BE%E5%B9%B4%E7%89%A9%E8%AA%9E-%E6%AC%A1%E3%81%AE100%E5%B9%B4%E3%82%92%E3%81%A4%E3%81%8F%E3%82%8B%E5%90%9B%E3%81%9F%E3%81%A1%E3%81%B8/dp/486250681X\" target=\"_blank\" class=\"blank-gnav\">マンガ「西井製作所百年物語」</a></li>-->\r\n                    <li class=\"gnav_contact dp-n\">\r\n                      <h1>お問い合わせ</h1>\r\n                      <div class=\"tel\">\r\n                        <p>\r\n                          <i><img src=\"../img/common/phone_icon.png\" alt=\"電話\"></i> <a href=\"tel:0828210241\">082-821-0241\r\n                        </a></p>\r\n                        <p class=\"ft-18m\">受付時間 8:00-17:00(土日祝日除く)</p>\r\n                      </div>\r\n                      <div class=\"mail ft-18m\"><a href=\"mailto:nishii@hiroshima-nishii.co.jp\"><i><img src=\"../img/common/mail-icon.png\" alt=\"メール\"></i> メールでのお問い合わせはこちら</a></div>\r\n                    </li>\r\n                </ul>\r\n                <div class=\"toggle\">\r\n                  <span></span>\r\n                  <span></span>\r\n                  <span></span>\r\n                </div><!-- toggle -->\r\n              </div>\r\n          </div><!-- container_l -->\r\n          <div class=\"side_header\">\r\n\r\n            <div class=\"side-contact fw-16\">\r\n              <a href=\"mailto:nishii@hiroshima-nishii.co.jp\"> <img src=\"../img/common/mail-icon-side.png\" alt=\"お問合せ\">　お問い合わせ</a>\r\n            </div>\r\n            <!-- <div class=\"pagetop\">\r\n              <a href=\"#\"><img src=\"img/common/pagetop.png\" alt=\"PAGETOP\"></a>\r\n            </div> -->\r\n        </div>\r\n      </header>\r\n    </div><!-- header_area -->\r\n    <main class=\"main subpage\">\r\n        <section class=\"subpage-ttl is-company\">\r\n          <div class=\"container\">\r\n          \t<h2 class=\"subpage-ttl__hdg\">会社情報<span class=\"subpage-ttl__hdg__en\">COMPANY</span></h2>\r\n          </div><!-- container -->\r\n        </section>\r\n\r\n        <section class=\"company01\" id=\"anc01\">\r\n          <div class=\"container_s\">\r\n\r\n\r\n            <h3 class=\"hdg02 mb-30 txt_center mb-100\">メッセージ<span>MESSAGE</span></h3>\r\n\r\n            <div class=\"company01__message\">\r\n            \t<div class=\"company01__message__image\"><img src=\"../img/company/message_image01.jpg\" alt=\"西井製作所　代表取締役\"></div>\r\n\r\n              <h4 class=\"company01__message__hdg\">人を想い、未来を想う。<br>今こそ西井製作所だからできることを。</h4>\r\n              <p class=\"mb-30\">西井製作所の強み、それは「人」です。大正7年（1918年）4月15日、西井伊久馬により創業した西井製作所。これまで戦争やオイルショック、バブル崩壊、リーマンショックと幾度とない逆境の時代を乗り越えることができたのは、これまでの常識にとらわれることなく情報をキャッチし、行動し、常に新しい風を取り入れてきた「人」がいたからこそ。そのため弊社では、「自ら考え、自ら判断し、自らが行動する。そして、自らの行動に責任を持つ」という社員育成を行い、一人ひとりの社員が自己成長を図ることのできる、人生学校となる企業づくりを徹底しています。</p>\r\n\r\n              <p class=\"mb-30\">これから益々、先の読めない時代が訪れるでしょう。だからこそ試練に立ち向かい、西井製作所だからこそ何ができるかを考え、どういう未来を創造するかを考え続ける。「人」の絶え間ない努力と諦めない心が根づいているからこそ、混沌とした時代の中でも私たちには一筋の光が見えています。これまでナンバープレート、仏壇金具、防衛産業、航空機産業、半導体産業で培ってきた技術力と開発力に加えて設計力を強化し、「メーカー西井製作所」となれるよう新しい時代の柱となる新規事業参入に向けて邁進する所存でございます。</p>\r\n\r\n              <p class=\"mb-30\">夢を描くからには、必ず実現する。その強い意志を持ち、お客様の信頼に応え、人々の豊かな暮らしの手助けができるよう、西井製作所はこれからも歩み続けてまいります。</p>\r\n\r\n              <p class=\"company01__message__ceo t-right\"><span class=\"t-left\">代表取締役<br>西井 裕昭</span></p>\r\n\r\n            </div>\r\n\r\n          </div><!-- container -->\r\n      </section>\r\n\r\n      <div class=\"company__imageBox__wrap\">\r\n      <ul class=\"company__imageBox\">\r\n        <li class=\"company__imageBox__item\"><img src=\"../img/company/company_image01.jpg\" alt=\"\"></li>\r\n        <li class=\"company__imageBox__item\"><img src=\"../img/company/company_image02.jpg\" alt=\"\"></li>\r\n        <li class=\"company__imageBox__item\"><img src=\"../img/company/company_image03.jpg\" alt=\"\"></li>\r\n        <li class=\"company__imageBox__item\"><img src=\"../img/company/company_image01.jpg\" alt=\"\"></li>\r\n        <li class=\"company__imageBox__item\"><img src=\"../img/company/company_image02.jpg\" alt=\"\"></li>\r\n        <li class=\"company__imageBox__item\"><img src=\"../img/company/company_image03.jpg\" alt=\"\"></li>\r\n      </ul>\r\n      </div>\r\n\r\n\r\n      <section class=\"company02\" id=\"anc02\">\r\n          <div class=\"container_s\">\r\n          \t<h3 class=\"hdg02 mb-70 txt_center\">経営理念<span>PHILOSOPHY</span></h3>\r\n            <h4 class=\"company01__message__hdg\">自らの成長を通じ、人々のお役に立ち感謝される会社をつくります。<br>そして、全員で人生の勝利者になります。</h4>\r\n            <p class=\"mb-30\">人生の勝利者とは、誰かと比べて勝った負けたではありません。勝利者とは、自分自身が大切なものを最も大切にすること。自分自身で、豊かだったと思える豊かな心を持ち合わせていること。自らが主体的にありたい姿の実現に向けて行動し続けられている状態だと思っています。</p>\r\n\r\n            <p class=\"mb-30\">人生において、プライベートと仕事の両方が満たされないといけないと思います。<br>\r\nプライベートにおける勝利者とは、どんな状況を指すのでしょうか？<br>\r\nお金持ち、家が欲しい、旅行がしたい、高級な車に乗りたい、趣味を楽しみたい、家族と幸せになりたい。人それぞれの充実感がある\r\nと思います。プライベートで、勝利者になる為には、お金や物欲を含めて物と、家族の幸せ、友人といった心を満たす必要があるのだ\r\nと思います。<br>\r\nでは、プライベートが充実していれば、人生の勝利者になれるのか？というと、そんなことはないと思います。<br>\r\n仕事は、人生の中で半分以上の時間を占めています。そして、会社でのお客様との関わり、会社での仕事のやり方が自分の考え方、生き\r\n方に大きな影響を与えてしまうのも事実です。お客様から、社員から信頼を得ることは心を豊かにしてくれる。<br>\r\n会社での人の育て方、接し方は、家庭での夫婦の良き関係、あるいは、子育てに影響を与える。<br>\r\n仕事の進め方は、時間の作り方を豊かにし、プライベートの時間も有効に使えるようになる。<br>\r\n更には、お客様からの信頼の量がお金になります。<br>\r\n良き人が良き会社をつくり、良き会社が良き家族をつくり、良き会社・家族が良き地域をつくり、良き地域が良き暮らしをつくっています。<br>\r\n自分を取り巻く全ての環境が整っていくことによって人生は豊かになり、自分自身の生き方が世の中をつくっていくのです。当社は、良き人を育てる人生学校を目指します。</p>\r\n\r\n            <p class=\"mb-30\">当社が目指すお役立ちは、相手の期待通りの成果を出すのではなく、私が持っている能力・魅力を最大限に発揮することで、相手の期待以上の成果を上げるお役立ちです。<br>\r\n            そして、お役立ちは特定の人に対してではなく「お客様」「社員」「地域」「社会」「環境」、私たちを取り巻く全ての人々のお役に立つことによって、感謝が飛び交う社会を創造します。<br>\r\n            人生の勝利者とは、自分自身の人生を振り返って物心共に豊かな人生を送るだけでなく、周りの者から「あなたのお陰で…」と感謝の言葉をもらえる人生企業として、感謝される会社を永続させます。</p>\r\n\r\n             <p class=\"mb-30\">感謝される会社とは、<br>\r\n「不満」とは、相手が求める期待に応えられ ていない状況。相手の中に悪い記憶が残る状態。<br>\r\n「満足」とは、相手が求める期待に応えられている状況。ただし、可も無く不可もの無く。相手の記憶に残らない状態。<br>\r\n「感動」とは、相手が口にも出さず、自分でも気づいていない期待に応えられている状況。相手の中に良い記憶が起こる状態。<br>\r\n「感謝」とは、感動が継続する状態。</p>\r\n\r\n              <p class=\"mb-90\">当社が目指すお役立ちは、相手の期待通りの成果を出すのではなく、私が持っている能力・魅力を成?させ続けることによって、相手に感動を与え続けることです。そして、感動を与える相手は、「お客様」「社員」「家族」「地域」「社会」「環境」、私たちを取り巻く全ての環境に対して感動を提供していきます。そうすることで、世の中が豊かになることで、社員一人ひとりが人生の勝利者になれる会社を目指しています。</p>\r\n\r\n            \r\n          </div><!-- container -->\r\n      </section>\r\n\r\n      <div class=\"company__imageBox__wrap\">\r\n        <ul class=\"company__imageBox\">\r\n          <li class=\"company__imageBox__item\"><img src=\"../img/company/company_image04.jpg\" alt=\"\"></li>\r\n          <li class=\"company__imageBox__item\"><img src=\"../img/company/company_image05.jpg\" alt=\"\"></li>\r\n          <li class=\"company__imageBox__item\"><img src=\"../img/company/company_image06.jpg\" alt=\"\"></li>\r\n          <li class=\"company__imageBox__item\"><img src=\"../img/company/company_image04.jpg\" alt=\"\"></li>\r\n          <li class=\"company__imageBox__item\"><img src=\"../img/company/company_image05.jpg\" alt=\"\"></li>\r\n          <li class=\"company__imageBox__item\"><img src=\"../img/company/company_image06.jpg\" alt=\"\"></li>\r\n        </ul>\r\n      </div>\r\n\r\n      <section class=\"company04\" id=\"anc04\">\r\n          <div class=\"container_s\">\r\n          \t<h3 class=\"hdg02 mb-90 txt_center\">拠点・アクセス<span>ACCESS</span></h3>\r\n\r\n            <div class=\"company04__access flexbox flex-wrap flex-justify-between mb-70\">\r\n              <div class=\"company04__access__text\">\r\n                <h4 class=\"hdg01 mb-20\"><span>本社工場</s