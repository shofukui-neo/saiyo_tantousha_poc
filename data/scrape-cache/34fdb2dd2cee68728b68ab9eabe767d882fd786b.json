{"url":"https://www.shikoku-gasnen.co.jp/support/ryokin.html","html":"\n<!DOCTYPE html>\n<html lang=\"ja\"><!-- InstanceBegin template=\"/Templates/base.dwt\" codeOutsideHTMLIsLocked=\"false\" -->\n<head>\n<meta http-equiv=\"Content-Type\" content=\"text/html; charset=utf-8\" />\n<meta http-equiv=\"Content-Style-Type\" content=\"text/css\">\n<meta http-equiv=\"Content-Script-Type\" content=\"text/javascript\" />\n<!-- InstanceBeginEditable name=\"construct\" -->\n<!-- InstanceEndEditable -->\n<title>お手続き | 料金のお問い合わせ | 四国ガス燃料株式会社</title>\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\"/> \n<meta name=\"keywords\" xml:lang=\"ja\" lang=\"ja\" content=\"愛媛県,今治市,四国ガス燃料,LPガス,ガス機器,ガスコンロ,給湯器,ガスファンヒーター,乾燥機,ガス炊飯器,ミストサウナ,四国\" />\n<meta name=\"author\" content=\"四国ガス燃料は人へ、暮らしへ、環境へ、ガスエネルギーのネットワークを広げていきます。\" />\n<meta http-equiv=\"Content-Script-Type\" content=\"text/javascript\" />\n<meta http-equiv=\"Content-Style-Type\" content=\"text/css\" />\n<meta http-equiv=\"Content-Language\" content=\"ja\" />\n<meta http-equiv=\"imagetoolbar\" content=\"no\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1.0,minimum-scale=1.0,maximum-scale=1.5,user-scalable=yes\">\n<meta name=\"format-detection\" content=\"telephone=no\">\n<link href=\"/css/screen.css?2\" rel=\"stylesheet\" type=\"text/css\" /><link rel=\"stylesheet\" type=\"text/css\" href=\"../css/dw.css\" />\n<link rel=\"index\" href=\"https://www.shikoku-gasnen.co.jp/\" />\n<link rel=\"shortcut icon\" href=\"/favicon.ico\" />\n<link href=\"/css/print.css\" rel=\"stylesheet\" type=\"text/css\" media=\"print\" />\n<script type=\"text/javascript\">var jstemplate={http:\"https://www.shikoku-gasnen.co.jp/\",https:\"https://www.shikoku-gasnen.co.jp/\",src:\"/\"};</script>\n<script src=\"/js/jquery-1.10.2.min.js\" type=\"text/javascript\"></script>\n<script src=\"/js/jquery.easing.js\" type=\"text/javascript\"></script>\n<script src=\"/js/common.js\" type=\"text/javascript\"></script>\n\n<!-- Google tag (gt