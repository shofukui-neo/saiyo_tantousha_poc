t\t\t\t\t</ul>\n\t\t\t\t\t\t<p class=\"mt40\"><a href=\"/\"><img src=\"/img/logo_footer.png\" alt=\"株式会社ニチダイ\"></a></p>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t\t<div class=\"copyArea\">\n\t\t\t\t<div class=\"bc_inner\">\n\t\t\t\t\t<div class=\"ca_L\"><a href=\"/policy/privacy.html\">個人情報保護方針</a>　　<a href=\"/policy/site.html\">サイトポリシー</a>　　<a href=\"/policy/social.html\">ソーシャルメディアポリシー</a></div>\n\t\t\t\t\t<div class=\"ca_R\">Copyright(C) NICHIDAI CORPORATION All Rights Reserved.</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</footer>\n\t</div>\n</div>\n<script src=\"/js/lib.js\"></script> \n<script src=\"/js/main.js\"></script>\n</body>\n</html>\n","finalUrl":"https://www.nichidai.jp/recruit/career.html","rendered":false,"_cachedAt":"2026-06-22T17:26:37.016Z"}