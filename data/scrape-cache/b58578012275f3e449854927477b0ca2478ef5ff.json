ub-menu\">\n\t<li id=\"menu-item-3823\" class=\"menu-item menu-item-type-custom menu-item-object-custom menu-item-3823\"><a href=\"http://kawaguchi-denki.jp/wp/company/\">会社概要</a></li>\n\t<li id=\"menu-item-3825\" class=\"menu-item menu-item-type-custom menu-item-object-custom menu-item-3825\"><a href=\"http://kawaguchi-denki.jp/wp/company/#about2\">営業所・出張所</a></li>\n\t<li id=\"menu-item-3824\" class=\"menu-item menu-item-type-custom menu-item-object-custom menu-item-3824\"><a href=\"http://kawaguchi-denki.jp/wp/company/#about3\">沿革</a></li>\n</ul>\n</li>\n<li id=\"menu-item-3811\" class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-3811\"><a href=\"https://kawaguchi-denki.jp/recruit/\">採用情報</a></li>\n<li id=\"menu-item-3822\" class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-has-children menu-item-3822\"><a href=\"https://kawaguchi-denki.jp/contact/\">お問い合わせ</a>\n<ul class=\"sub-menu\">\n\t<li id=\"menu-item-3934\" class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-privacy-policy menu-item-3934\"><a rel=\"privacy-policy\" href=\"https://kawaguchi-denki.jp/privacy-policy/\">個人情報保護方針</a></li>\n</ul>\n</li>\n</ul>\t\t\t\t\t<div class=\"drawer-under\">\n\t\t\t\t\t<a class=\"sns youtube\" href=\"https://www.youtube.com/channel/UC6Bls7wrLyufV63PMwnHtWw\" target=\"_blank\">\n\t\t\t\t\t\t<img src=\"https://kawaguchi-denki.jp/wp/wp-content/themes/kawaden/assets/images/sns-youtube.png\" alt=\"Youtube\"></a>\n\t\t\t\t\t<a class=\"sns insta\" href=\"https://www.instagram.com/kawaden1970/\" target=\"_blank\">\n\t\t\t\t\t\t<img src=\"https://kawaguchi-denki.jp/wp/wp-content/themes/kawaden/assets/images/sns-insta.png\" alt=\"Instagram\"></a>\n\t\t\t\t\t</div>\n\t\t\t\t</nav>\n\t\t\t</div>\n\t\t</div>\n\t</header>\n\n<main class=\"l-front\">\n\n\t\n\t<section class=\"p-front-visual js-fadein\">\n\t\t\n\t\t<div class=\"p-front-visual__catch\">\n\t\t\t<p class=\"catch-line\">街のカタチをつくる</p>\n\t\t\t<p class=\"catch-line\">ひとの暮らしを照らす</p>\n\t\t</div>\n\t\t\n\t</section>\n\n\t<section class=\"p-front__content\">\n\t\t\n\t\t<div class=\"l-inner\">\n\t\t\t\n<div class=\"home-recruit-wrap\">\n<h2><p class=\"ja\"><span class=\"js-scroll-in1\">採用情報</span></p><p class=\"en js-scroll-in1\">Recruit</p></h2>\n<a href=\"https://kawaguchi-denki.jp/wp/recruit/\" class=\"front-recruit__bana\">\n<span>採用情報はこちら→</span>\n</a>\n</div>\n\n\n\n<section class=\"p-frontService\" id=\"business\">\n<h2><p class=\"ja\"><span class=\"js-scroll-in1\">事業内容</span></p><p class=\"en js-scroll-in1\">Service</p></h2>\n<div class=\"loop-gallery\">\n<ul>\n<li><img decoding=\"async\" src=\"https://kawaguchi-denki.jp/wp/wp-content/uploads/2026/01/service-slide5.jpg\"></li>\n<li><img decoding=\"async\" src=\"https://kawaguchi-denki.jp/wp/wp-content/uploads/2026/01/service-slide1.jpg\"></li>\n<li><img decoding=\"async\" src=\"https://kawaguchi-denki.jp/wp/wp-content/uploads/2026/01/service-slide4.jpg\"></li>\n<li><img decoding=\"async\" src=\"https://kawaguchi-denki.jp/wp/wp-content/uploads/2026/01/service-slide3.jpg\"></li>\n<li><img decoding=\"async\" src=\"https://kawaguchi-denki.jp/wp/wp-content/uploads/2026/01/service-slide2.jpg\"></li>\n<li><img decoding=\"async\" src=\"https://kawaguchi-denki.jp/wp/wp-content/uploads/2026/01/service-slide5.jpg\"></li>\n<li><img decoding=\"async\" src=\"https://kawaguchi-denki.jp/wp/wp-content/uploads/2026/01/service-slide1.jpg\"></li>\n<li><img decoding=\"async\" src=\"https://kawaguchi-denki.jp/wp/wp-content/uploads/2026/01/service-slide4.jpg\"></li>\n<li><img decoding=\"async\" src=\"https://kawaguchi-denki.jp/wp/wp-content/uploads/2026/01/service-slide3.jpg\"></li>\n<li><img decoding=\"async\" src=\"https://kawaguchi-denki.jp/wp/wp-content/uploads/2026/01/service-slide2.jpg\"></li>\n</ul>\n</div>\n<div class=\"top\">\n<p class=\"copy\">設計→施工→保守・管理まで弊社で対応しています</p>\n<p class=\"txt\">お客様のご要望、そして弊社からの省エネや照明デザインを設計に反映し、大型プラントから木造住宅まで\n様々な電気工事に対応しています。<br>\n電気工事のことなら、安心と安全をお届けする弊社にご相談ください。</p>\n</div>\n<div class=\"service\">\n\n\n\n<div class=\"dtl js-scroll-in1\">\n<a href=\"./business/service1\">\n<div class=\"dtl-inner\">\n<img decoding=\"async\" src=\"https://kawaguchi-denki.jp/wp/wp-content/uploads/2026/01/service1.webp\">\n<div class=\"right\">\n<h3 class=\"js-scroll-in\"><span class=\"num\">1.</span>電気設備工事</h3>\n<p>飲食や物販の商業施設、オフィスビルやプラント設備、高圧受変電設備の新設・改修まで承ります。</p>\n<span class=\"more-btn\">詳細</span>\n</div>\n</div>\n</a>\n</div>\n\n\n\n<div class=\"dtl js-scroll-in1\">\n<a href=\"./business/service2\">\n<div class=\"dtl-inner\">\n<img decoding=\"async\" src=\"https://kawaguchi-denki.jp/wp/wp-content/uploads/2026/01/service2.webp\">\n<div class=\"right\">\n<h3 class=\"js-scroll-in\"><span class=\"num\">2.</span>電気通信設備工事</h3>\n<p>施設内のネットワーク、防犯カメラ、音響・放送設備、電光掲示板やサイネージなどを承っております。</p>\n<span class=\"more-btn\">詳細</span>\n</div>\n</div>\n</a>\n</div>\n\n\n\n<div class=\"dtl js-scroll-in1\">\n<a href=\"./business/service3\">\n<div class=\"dtl-inner\">\n<img decoding=\"async\" src=\"https://kawaguchi-denki.jp/wp/wp-content/uploads/2026/01/service3.webp\">\n<div class=\"right\">\n<h3 class=\"js-scroll-in\"><span class=\"num\">3.</span>計装制御工事</h3>\n<p>プラントでの計装・制御、放射線遮蔽扉の制御盤作成など、設計から現地施工、保守点検まで承ります。</p>\n<span class=\"more-btn\">詳細</span>\n</div>\n</div>\n</a>\n</div>\n\n\n\n<div class=\"dtl js-scroll-in1\">\n<a href=\"./business/service4\">\n<div class=\"dtl-inner\">\n<img decoding=\"async\" src=\"https://kawaguchi-denki.jp/wp/wp-content/uploads/2026/01/service4.webp\">\n<div class=\"right\">\n<h3 class=\"js-scroll-in\"><span class=\"num\">4.</span>換気空調設備工事</h3>\n<p>家庭用・業務用の空調設備工事、冷媒ガスの回収・充填、建築設備点検（風量測定）などを承ります。</p>\n<span class=\"more-btn\">詳細</span>\n</div>\n</div>\n</a>\n</div>\n\n\n\n<div class=\"dtl js-scroll-in1\">\n<a href=\"./business/service5\">\n<div class=\"dtl-inner\">\n<img decoding=\"async\" src=\"https://kawaguchi-denki.jp/wp/wp-content/uploads/2026/01/service5.webp\">\n<div class=\"right\">\n<h3 class=\"js-scroll-in\"><span class=\"num\">5.</span>消防設備工事</h3>\n<p>自動火災報知設備の設計・施工・点検、消火器具販売、非常用照明の建築設備点検など幅広く対応します。</p>\n<span class=\"more-btn\">詳細</span>\n</div>\n</div>\n</a>\n</div>\n\n\n\n</div>\n</section>\n\n\n\n<section class=\"p-front-company\">\n<h2><p class=\"ja\"><span class=\"js-scroll-in1\">会社情報</span></p><p class=\"en js-scroll-in1\">Company</p></h2>\n<div class=\"p-front-company__inner\">\n<div class=\"p-front-company__thumb\"><img decoding=\"async\" src=\"https://kawaguchi-denki.jp/wp/wp-content/uploads/2026/01/gaikan.webp\"></div>\n<div class=\"p-front-company__detail\">\n<div class=\"p-front-company__detail-inner\">\n<table>\n  <tr>\n    <th>商号</th>\n    <td>川口電気株式会社</td>\n  </tr>\n  <tr>\n    <th>所在地</th>\n    <td>福井県敦賀市木崎51-35 <a class=\"btn\" href=\"https://www.google.com/maps?ll=35.645333,136.038702&#038;z=15&#038;t=m&#038;hl=ja&#038;gl=JP&#038;mapclient=embed&#038;cid=3890682335088805361\" target=\"_blank\">MAP</a></td>\n  </tr>\n  <tr>\n    <th>電話番号</th>\n    <td>0770-23-3000</td>\n  </tr>\n  <tr>\n    <th>営業時間</th>\n    <td>8：00～17：20（土日祝定休）</td>\n  </tr\n  <tr>\n    <th>事業内容</th>\n    <td>\n      各種設備の設計・施工・保守管理<br>\n      （電気設備、電気通信設備、計装制御、<br class=\"pc\">換気空調、消防設備）\n    </td>\n  </tr>\n</table>\n<a href=\"https://kawaguchi-denki.jp/wp/company/\" class=\"more-btn\">詳細</a></div>\n</div>\n</div>\n</section>\n\n\n\n<p></p>\n\t\t</div>\n\t\t\n\t</section>\n\n\t\n</main>\n\n<footer class=\"l-footer\">\n\t<div class=\"l-footer__main\">\n\t\t<div class=\"l-footer__left\">\n\t\t\t<div class=\"l-footer__info\">\n\t\t\t\t<a class=\"l-footer__logo\" href=\"https://kawaguchi-denki.jp\">\n\t\t\t\t\t<img src=\"https://kawaguchi-denki.jp/wp/wp-content/themes/kawaden/assets/images/logo-wh.svg\" alt=\"川口電気株式会社\">\n\t\t\t\t</a>\n\t\t\t\t<a class=\"l-footer__name\" href=\"https://kawaguchi-denki.jp\">川口電気株式会社</a>\n\t\t\t\t<p class=\"l-footer__addr\">\n\t\t\t\t\t〒914-0814　福井県敦賀市木崎 51-35<br>\n\t\t\t\t\t<a href=\"tel:0770233000\">0770-23-3000</a>\n\t\t\t\t</p>\n\t\t\t\t<ul class=\"l-foote