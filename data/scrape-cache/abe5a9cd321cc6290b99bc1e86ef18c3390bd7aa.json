t_wrap clearfix\" id=\"webconnect-gadget-1\">\r\n\t<span></span>\r\n\t<span></span>\r\n\t<span></span>\r\n</div>\r\n<!-- yado end -->\r\n\r\n<!-- jr start -->\r\n<div class=\"content_wrap disnon clearfix\" id=\"webconnect-tour-hotels-gadget\"></div>\r\n<!-- jr end -->\r\n\r\n<!-- kokunai start -->\r\n<div class=\"content_wrap disnon clearfix\">\r\n<div class=\"column2WrapA01 clearfix\">\r\n<div class=\"tourL\">\r\n<h2>交通+宿泊セットで自由な旅(フリープラン)</h2>\r\n<ul class=\"clearfix\">\r\n<li class=\"nav01\"><h3>航空+宿泊<br />\r\n<span>セットプラン</span></h3>\r\n<p class=\"ico\"><img src=\"//www.nta.co.jp/hokkaido/image/index/search_box/tab_li_01.gif\" width=\"83\" height=\"83\" alt=\"\" /></p>\r\n<p>航空と宿泊を<br />\r\n自由に組み合わせ</p>\r\n<a target=\"_blank\" href=\"//www.nta.co.jp/dpp/search?OutDepAptCD=CTS&InDepAptCD=HND\">検索する</a></li>\r\n<li class=\"nav02\"><h3>JR+宿泊<br />\r\n<span>セットプラン</span></h3>\r\n<p class=\"ico\"><img src=\"//www.nta.co.jp/hokkaido/image/index/search_box/tab_li_02.gif\" width=\"83\" height=\"83\" alt=\"\" /></p>\r\n<p>JRと宿泊を<br />\r\n自由に組み合わせ</p>\r\n<a target=\"_blank\" href=\"//www.nta.co.jp/nta_jr/?Departure=1\">検索する</a></li>\r\n</ul>\r\n</div>\r\n<div class=\"tourR\">\r\n<h2>コースから選べる旅</h2>\r\n<ul class=\"clearfix\">\r\n<li>\r\n<h3>パッケージツアー<br />\r\n<span>セットプラン</span></h3>\r\n<p class=\"ico\"><img src=\"//www.nta.co.jp/hokkaido/image/index/search_box/tab_li_03.gif\" width=\"83\" height=\"83\" alt=\"\" /></p>\r\n<p>コースから選べる！<br />\r\nバーゲンツアーから添乗員同行の旅までプラン満載！</p>\r\n<a target=\"_blank\" href=\"//www.nta.co.jp/nta_dom_tour/search.jsp\">検索する</a> </li>\r\n</ul>\r\n</div>\r\n<!-- / columnBlock02 --></div>\r\n<ul class=\"linkList pl10\">\r\n<li><a href=\"//www.nta.co.jp/help/\">検索・予約ヘルプ</a></li>\r\n</ul>\r\n<!-- / content_wrap --></div>\r\n<!-- kokunai end -->\r\n\r\n\r\n<!-- kaigai start -->\r\n<div class=\"content_wrap disnon clearfix\">\r\n<div class=\"column2WrapA01 clearfix\">\r\n<h2 class=\"mb10\">出発月日・出発地・目的地・条件をお選びください。</h2>\r\n<div class=\"kaigaiTourWrap clearfix