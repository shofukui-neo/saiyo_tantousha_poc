{"url":"https://www.hiropla.co.jp/recruit/","html":"<!DOCTYPE HTML>\n<html lang=\"ja\" data-file=\"parts\">\n<head prefix=\"og: http://ogp.me/ns# fb: http://ogp.me/ns/fb# article: http://ogp.me/ns/article#\">\n<!-- Google tag (gtag.js) -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-0K7TJ3WY7J\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'G-0K7TJ3WY7J');\n</script>\n<meta charset=\"utf-8\">\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n<title>採用情報｜広島プラスチック株式会社</title>\n<meta name=\"description\" content=\"広島プラスチック株式会社は、プラスチック製品製造及び金型企画・製作をおこなっております。帝人グループの射出成形＆加工メーカーとして自動車関連、住設・インフラ関連、医療関連等、さまざまな分野のプラスチック製品を供給しています。\">\n<meta name=\"keywords\" content=\"プラスチック製品,自動車関連,住設関連,医療関連,プラスチック,射出成形\">\n<meta name=\"viewport\" content=\"width=device-width\">\n<meta name=\"format-detection\" content=\"telephone=no\">\n<meta property=\"og:type\" content=\"article\">\n<meta property=\"og:title\" content=\"採用情報｜広島プラスチック株式会社\">\n<meta property=\"og:description\" content=\"広島プラスチック株式会社は、プラスチック製品製造及び金型企画・製作をおこなっております。帝人グループの射出成形＆加工メーカーとして自動車関連、住設・インフラ関連、医療関連等、さまざまな分野のプラスチック製品を供給しています。\">\n<meta property=\"og:url\" content=\"https://www.hiropla.co.jp/\">\n<meta property=\"og:image\" content=\"https://www.hiropla.co.jp/common-files/img/symbol/ogp.png\">\n<meta property=\"og:site_name\" content=\"広島プラスチック株式会社\">\n<link rel=\"shortcut icon\" href=\"/common-files/img/symbol/favicon.ico\">\n<link rel=\"apple-touch-icon-precomposed\" href=\"/common-files/img/symbol/apple-touch-icon.png\">\n<link rel=\"stylesheet\" href=\"/common-files/css/base.css\">\n<link rel=\"stylesheet\" href=\"/common-files/plugin/slick/slick.css\">\n<link rel=\"stylesheet\" href=\"/common-files/plugin/colorbox/colorbox.css\">\n<link rel=\"stylesheet\" href=\"/common-files/css/layout_pc.css\">\n<link rel=\"stylesheet\" href=\"/common-files/css/layout_sp.css\">\n<lin