 href=\"/item/\" class=\"gnav-megamenu_title_link\"><span class=\"gnav-megamenu_title_label\">製品・サービス トップ</span></a></div>\n            </div>\n            <div class=\"gnav-megamenu_body\">\n              <ul class=\"gnav-megamenu_link\" data-row-pc=\"3\" data-row-sp=\"2\">\n                <li><a href=\"/item/#lv02-01\"><span class=\"gnav-megamenu_link_label\">自動車関連部品</span></a></li>\n                <li><a href=\"/item/#lv02-02\"><span class=\"gnav-megamenu_link_label\">住宅関連部品</span></a></li>\n                <li><a href=\"/item/#lv02-03\"><span class=\"gnav-megamenu_link_label\">医療関連部品</span></a></li>\n                <li><a href=\"/item/#lv02-04\"><span class=\"gnav-megamenu_link_label\">その他</span></a></li>\n              </ul>\n            </div>\n            <div class=\"gnav-megamenu_foot\">\n              <div class=\"gnav-megamenu_close\"><a href=\"javascript:void(0)\" class=\"js-header-gnav_megamenu_close\"><span class=\"gnav-megamenu_close_label\">閉じる</span></a></div>\n            </div>\n          </div>\n        </div>\n      </li>\n      <li class=\"js-header-gnav_list\" data-gnav-current=\"facility\">\n        <a href=\"#megamenu-03\" class=\"type-toggle js-header-gnav_megamenu-trigger\"><span class=\"gnav_label\">設備紹介</span></a>\n        <div id=\"megamenu-03\" class=\"gnav-megamenu js-header-gnav_megamenu\">\n          <div class=\"gnav-megamenu_inner\">\n            <div class=\"gnav-megamenu_head\">\n              <div class=\"gnav-megamenu_title\"><a href=\"/facility/\" class=\"gnav-megamenu_title_link\"><span class=\"gnav-megamenu_title_label\">設備紹介 トップ</span></a></div>\n            </div>\n            <div class=\"gnav-megamenu_body\">\n              <ul class=\"gnav-megamenu_link\" data-row-pc=\"3\" data-row-sp=\"2\">\n                <li><a href=\"/facility/#lv02-01\"><span class=\"gnav-megamenu_link_label\">成形機</span></a></li>\n                <li><a href=\"/facility/#lv02-02\"><span class=\"gnav-megamenu_link_label\">金型工場</span></a></li>\n                <li><a href=\"/facility/#lv02-03\"><span class=\"gnav-megamenu_link_label\">クリーンルーム</span></a></li>\n\n              </ul>\n            </div>\n            <div class=\"gnav-megamenu_foot\">\n              <div class=\"gnav-megamenu_close\"><a href=\"javascript:void(0)\" class=\"js-header-gnav_megamenu_close\"><span class=\"gnav-megamenu_close_label\">閉じる</span></a></div>\n            </div>\n          </div>\n        </div>\n      </li>\n      <li class=\"js-header-gnav_list\" data-gnav-current=\"recruit\">\n        <a href=\"#megamenu-04\" class=\"type-toggle js-header-gnav_megamenu-trigger\"><span class=\"gnav_label\">採用情報</span></a>\n        <div id=\"megamenu-04\" class=\"gnav-megamenu js-header-gnav_megamenu\">\n          <div class=\"gnav-megamenu_inner\">\n            <div class=\"gnav-megamenu_head\">\n              <div class=\"gnav-megamenu_title\"><a href=\"/recruit/\" class=\"gnav-megamenu_title_link\"><span class=\"gnav-megamenu_title_label\">採用情報 トップ</span></a></div>\n            </div>\n            <div class=\"gnav-megamenu_body\">\n              <ul class=\"gnav-megamenu_link\" data-row-pc=\"3\" data-row-sp=\"2\">\n                <li><a href=\"/recruit/#lv02-01\"><span class=\"gnav-megamenu_link_label\">募集要項（新卒）</span></a></li>\n                <li><a href=\"/recruit/#lv02-02\"><span class=\"gnav-megamenu_link_label\">募集要項（キャリア）</span></a></li>\n                <li><a href=\"/recruit/#lv02-03\"><span class=\"gnav-megamenu_link_label\">よくあるお問い合わせ</span></a></li>\n                <li><a href=\"/recruit/#lv02-04\"><span class=\"gnav-megamenu_link_label\">先輩の声</span></a></li>\n              </ul>\n            </div>\n            <div class=\"gnav-megamenu_foot\">\n              <div class=\"gnav-megamenu_close\"><a href=\"javascript:void(0)\" class=\"js-header-gnav_megamenu_close\"><span class=\"gnav-megamenu_close_label\">閉じる</span></a></div>\n            </div>\n          </div>\n        </div>\n      </li>\n    </ul>\n    <div class=\"gnav-utility pc-hidden\">\n      <ul class=\"gnav-utility-list\">\n        <li><a href=\"/news/\">ニュース</a></li>\n      </ul>\n    </div>\n    <div class=\"gnav-utility-v2 js-utility pc-hidden\">\n      <ul class=\"gnav-utility-list-v2\">\n        <li class=\"type-sitemap\"><a href=\"/sitemap/\">サイトマップ</a></li>\n<!--        <li class=\"type-lang\"><a href=\"javascript:void(0)\" class=\"js-utility_trigger\">日本語</a></li>-->\n      </ul>\n    </div>\n  <!--/GnavBody--></div>\n<!--/Gnav--></nav>\n\n<main id=\"main\" class=\"Main\">\n  <div id=\"mainBody\" class=\"MainBody\">\n    <div class=\"pageGuide\">\n      <ol class=\"breadcrumbs\" itemscope itemtype=\"http://schema.org/BreadcrumbList\">\n        <li itemprop=\"itemListElement\" itemscope itemtype=\"http://schema.org/ListItem\">\n          <a itemprop=\"item\" href=\"/\"><span itemprop=\"name\">ホーム</span></a>\n          <meta itemprop=\"position\" content=\"1\" />\n        </li>\n        <li>採用情報</li>\n      </ol>\n      <!--/pageGuide--></div>\n    <div class=\"pageHead\">\n      <div class=\"heading-lv1-v2\">\n        <div class=\"block\">\n          <h1 class=\"heading_title\">採用情報</h1>\n        </div>\n      <!--/heading-lv1-v2--></div>\n    <!--/pageHead--></div>\n    <div class=\"container\" data-wide=\"false\" data-sidebar=\"false\">\n      <div class=\"contents\">\n        <div class=\"contents-wrap\">\n<div class=\"navi-anchor\">\n  <ul class=\"navi_inner\" data-row-pc=\"4\" data-row-sp=\"2\">\n    <li><a href=\"#lv02-01\"><span class=\"navi_label\">募集要項（新卒）</span></a></li>\n    <li><a href=\"#lv02-02\"><span class=\"navi_label\">募集要項（キャリア）</span></a></li>\n    <li><a href=\"#lv02-03\"><span class=\"navi_label\">よくあるお問い合わせ</span></a></li>\n    <li><a href=\"#lv02-04\"><span class=\"navi_label\">先輩の声</span></a></li>\n  </ul>\n<!--/navi-anchor--></div>\n\n\n\n\n\n\n\n<section id=\"lv02-01\">\n\t\t\t\t\t\t<div class=\"heading-lv2-v2\">\n\t\t\t\t\t\t\t<div class=\"block\">\n\t\t\t\t\t\t\t\t<h2 class=\"heading_title\">募集要項（新卒）</h2>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t<!--/heading-lv2-v2--></div>\n<p class=\"text-title\">来春（2027年春）入社の社員を下記の通り募集致します。</p>\n<div class=\"table-layout-v2\" data-layout-sp=\"vertical\">\n  <table class=\"table_inner\">\n    <colgroup>\n      <col span=\"1\" class=\"gp-w-025per\">\n      <col span=\"1\" class=\"gp-w-075per\">\n    </colgroup>\n    <tbody>\n      <tr>\n        <th class=\"cell-style2\">雇用形態</th>\n        <td>正社員</td>\n      </tr>\n      <tr>\n        <th class=\"cell-style2\">仕事の内容</th>\n        <td>自動車部品、住宅関連部品等のプラスチック製品の製造管理業務</td>\n      </tr>\n      <tr>\n        <th class=\"cell-style2\">対象</th>\n        <td>1. 大学卒：2027年3月卒業見込みの方<br>\n        2. 既卒：既卒者については大学卒業後3年以内の方</td>\n      </tr>\n      <tr>\n        <th class=\"cell-style2\">学歴、資格</th>\n        <td>不問</td>\n      </tr>\n      <tr>\n        <th class=\"cell-style2\">勤務地</th>\n        <td>事業所住所に同じ（東広島市八本松町）</td>\n      </tr>\n      <tr>\n        <th class=\"cell-style2\">勤務時間</th>\n        <td>8:20～17:00（休憩1.17h、実働7.5h）</td>\n      </tr>\n      <tr>\n        <th class=\"cell-style2\">時間外勤務</th>\n        <td>有り（月平均10h）</td>\n      </tr>\n      <tr>\n        <th class=\"cell-style2\">休日</th>\n        <td>会社カレンダーによる（年間休日数115日）<br>週休二日制、長期休暇（GW、夏季、年末年始）</td>\n      </tr>\n      <tr>\n        <th class=\"cell-style2\">有休等</th>\n        <td>年次有給休暇、慶弔休、育児・介護休暇制度有り</td>\n      </tr>\n      <tr>\n        <th class=\"cell-style2\">給与</th>\n        <td>大学卒：217,400円以上<br>※既卒者については弊社規程を基に決定いたします。</td>\n      </tr>\n      <tr>\n        <th class=\"cell-style2\">待遇</th>\n        <td>資格給、通勤手当、住宅手当、家族手当、特別作業手当等<br>昇給年1回、賞与年2回</td>\n      </tr>\n      <tr>\n        <th class=\"cell-style2\">福利厚生</th>\n        <td>各種社会保険（健康保険、厚生年金保険、雇用保険、労災保険）<br>\n退職金制度、財形貯蓄制度、従業員持ち株会制度、育児・介護休業制度<br>\n社内行事、永年勤続表彰等</td>\n      </tr>\n      <tr>\n        <th class=\"cell-style2\">選考方法</th>\n        <td>履歴書、作文、面接</td>\n      </tr>\n      <tr>\n        <th class=\"cell-style2\">お問い合わせ先</th>\n        <td>総務課<br>TEL：<a href=\"tel:0824280048\">082-428-0048</a>\n        <ul class=\"link-text\">\n        <li><a href=\"https://inquiry.teijin.co.jp/form/contact_hp_jp.html\" target=\"_blank\" class=\"a-blank\">お問い合わせフォームはこちら</a></li>\n        </ul></td>\n      </tr>\n    </tbody>\n  </table>\n<!--/table-layout-v2--></div>\n\n</section>\n\n\n\n<section id=\"lv02-02\">\n\t\t\t\t\t\t<div class=\"heading-lv2-v2\">\n\t\t\t\t\t\t\t<div class=\"block\">\n\t\t\t\t\t\t\t\t<h2 class=\"heading_title\">募集要項（キャリア）</h2>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t<!--/heading-lv2-v2--></div>\n<p class=\"text-title\">キャリア採用についてはお問い合わせください。</p>\n<div class=\"table-layout-v2\" data-layout-sp=\"vertical\">\n  <table class=\"table_inner\">\n    <colgroup>\n      <col span=\"1\" class=\"gp-w-025per\">\n      <col span=\"1\" class=\"gp-w-075per\">\n    </colgroup>\n    <tbody>\n      <tr>\n        <th class=\"cell-style2\">お問い合わせ先</th>\n        <td>総務課<br>TEL：<a href=\"tel:0824280048\">082-428-0048</a>\n        <ul class=\"link-text\">\n        <li><a href=\"https://inquiry.teijin.co.jp/form/contact_hp_jp.html\" target=\"_blank\" class=\"a-blank\">お問い合わせフォームはこちら</a></li>\n        </ul>\n        </td>\n      </tr>\n    </tbody>\n  </table>\n<!--/table-layout-v2--></div>\n\n</section>\n\n<section id=\"lv02-03\">\n<div class=\"heading-lv2-v2\">\n<div class=\"block\">\n<h2 class=\"heading_title\">よくあるお問い合わせ</h2>\n</div>\n<!--/heading-lv2-v2--></div>\n<div class=\"table-layout-v2\" data-layout-sp=\"vertical\">\n  <table class=\"table_inner\">\n    <colgroup>\n      <col span=\"1\" class=\"gp-w-025per\">\n      <col span=\"1\" class=\"gp-w-075per\">\n    </colgroup>\n    <tbody>\n      <tr>\n        <th class=\"cell-style2\">Q1: 転勤はありますか？</th>\n        <td>A1: 事業所は1カ所ですので転勤はありません。</td>\n      </tr>\n      <tr>\n        <th class=\"cell-style2\">Q2: 工場見学は可能ですか？</th>\n        <td>A2: 可能ですので総務課までお問い合わせください。</td>\n      </tr>\n    </tbody>\n  </table>\n<!--/table-layout-v2--></div>\n</section>\n\n\n<section id=\"lv02-04\">\n<div class=\"heading-lv2-v2\">\n<div class=\"block\">\n<h2 class=\"heading_title\">先輩の声</h2>\n</div>\n<!--/heading-lv2-v2--></div>\n\n\n\n\n<div class=\"heading-lv3\">\n    <div class=\"block\">\n      <div class=\"heading_subtitle\">製造部 成形一課（2016年度入社）</div>\n      <h3 class=\"heading_title\">植田 慎悟 <span class=\"is-smaller\">ウエダ シンゴ</span></h3>\n    </div>\n  <!--/heading-lv3--></div>\n  <div class=\"column-media\" data-layout-sp=\"col\" data-media-size=\"1/2\" data-media-side=\"left\">\n  <div class=\"column_image\" data-layout-sp=\"row\" data-row-pc=\"2\" data-row-sp=\"2\">\n    <div class=\"image-set\">\n      <figure class=\"image_inner js-fitWidth\">\n        <img src=\"/img/recruit_voice_02_01.png\" alt=\"\"/>\n      </figure>\n    <!--/image-set--></div>\n    <div class=\"image-set\">\n      <figure class=\"image_inner js-fitWidth\">\n        <img src=\"/img/recruit_voice_02_02.png\" alt=\"\"/>\n      </figure>\n    <!--/image-set--></div>\n  </div>\n  <div class=\"column_detail\" data-wraparound=\"false\">\n<dl class=\"list-description\">\n<dt>仕事内容を教えてください。</dt>\n<dd>プラスチック製品の成形作業に携わっています。成形品の品質確認又は金型交換や原料準備等の成形立上作業を行っています。</dd>\n<dt>職場の雰囲気はどうですか?</dt>\n<dd>親切で、明るい人の多い、良い職場です。時には厳しく指導もありましたが、楽しく仕事が出来る職場です。</dd>\n<dt>広島プラスチックの良いところ、ひとつ教えて！</dt>\n<dd>高校を卒業し、プラスチックの事を何も知らなかった私がこの2年間で色々学べ、楽しいコミュニケーションの中でスキルアップ出来ています。</dd>\n</dl>\n  </div>\n<!--/column-media--></div>\n\n\n\n</section>\n\n\n        <!--/contents-wrap--></div>\n      <!--/contents--></div>\n    <!--/container--></div>\n  <!--/MainBody--></div>\n<!--/Main--></main>\n<aside id=\"assist\" class=\"Assist\">\n\n  <div id=\"assistClone\" class=\"AssistClone js-footer\" data-button-count=\"2\">\n    <div class=\"assist-wrap\">\n      <div class=\"footer-assist js-utility\">\n        <ul class=\"assist_buttons js-footer_assist_button\">\n          <li class=\"type-pagetop\"><a href=\"#header\" class=\"js-footer_pagetop\"><span class=\"assist_label\">ページ上部へ</span></a></li>\n        </ul>\n      <!-