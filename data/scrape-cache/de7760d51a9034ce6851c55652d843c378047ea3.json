{"url":"https://www.hanshin-tollkobe.co.jp/corp_info/index02.html","html":"<!doctype html>\r\n<html lang=\"ja\"><!-- InstanceBegin template=\"/Templates/base.dwt\" codeOutsideHTMLIsLocked=\"false\" -->\r\n<head>\r\n<!-- Google tag (gtag.js) -->\r\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-D46ENBW51P\"></script>\r\n<script>\r\n  window.dataLayer = window.dataLayer || [];\r\n  function gtag(){dataLayer.push(arguments);}\r\n  gtag('js', new Date());\r\n\r\n  gtag('config', 'G-D46ENBW51P');\r\n  gtag('config', 'UA-87337378-1');\r\n</script>\r\n\r\n<meta charset=\"utf-8\">\r\n<!-- InstanceBeginEditable name=\"doctitle\" -->\r\n<title>社会貢献活動｜阪神高速トール神戸</title>\r\n<meta name=\"Description\" content=\"阪神高速トール神戸株式会社は社会貢献活動の一環として、お客さまや地域の皆さまに愛される企業を目指し、様々な取り組みを行っています。\" />\r\n<!-- InstanceEndEditable -->\r\n<meta http-equiv=\"Pragma\" content=\"no-cache\">\r\n<meta http-equiv=\"Cache-Control\" content=\"no-cache\">\r\n<meta name=\"author\" content=\"阪神高速トール神戸\" />\r\n<meta name=\"copyright\" content=\"阪神高速トール神戸\" />\r\n<meta name=\"robots\" content=\"all\" />\r\n<link href=\"../common/css/import.css?20260525121533\" rel=\"stylesheet\" type=\"text/css\" media=\"all\" />\r\n<!-- InstanceBeginEditable name=\"head\" -->\r\n<!-- InstanceEndEditable -->\r\n<!-- InstanceParam name=\"bodyID\" type=\"text\" value=\"\" -->\r\n<!-- InstanceParam name=\"g_menu\" type=\"text\" value=\"g_menu02\" -->\r\n<!-- InstanceParam name=\"contents\" type=\"text\" value=\"corp-info\" -->\r\n<!-- InstanceParam name=\"filename\" type=\"text\" value=\"index02\" -->\r\n</head>\r\n\r\n<body id=\"corp-info\" class=\"index02\">\r\n    <a name=\"top\" id=\"top\"></a>\r\n    <header id=\"header-frame\">\r\n\r\n      <div id=\"header\">\r\n        <h1>\r\n          <a href=\"/\">\r\n            <img src=\"/common/img/header01.png\" width=\"276\" height=\"38\" alt=\"阪神高速トール神戸株式会社\" />\r\n            <span>お客さまから愛される料金所を目指します</span>\r\n          </a>\r\n        </h1>\r\n        <div id=\"header_right\">\r\n          <p><a href=\"/sitemap/\">サイトマップ</a></p>\r\n          <div id=\"fontSize\">\r\n            <noscript><p>JavaScriptを使用しています。</p></noscript>\r\n            文字サイズ\r\n            <ul>\r\n              <li class=\"changeBtn\">小</li>\r\n              <li class=\"changeBtn\">中</li>\r\n              <li class=\"changeBtn\">大</li>\r\n            </ul>\r\n          </div>\r\n        </div>\r\n      </div><!-- //header -->\r\n\r\n      <nav id=\"nav\">\r\n        <ul>\r\n          <li class=\"nav01\"><a href=\"/\">トップページ<span>TOP PAGE</span></a></li>\r\n          <li class=\"nav02\"><a href=\"/corp_info/\">会社情報<span>CORPORATE INFORMATION</span></a></li>\r\n          <li class=\"nav03\"><a href=\"/corp_outline/\">会社概要<span>COMPANY PROFILE</span></a></li>\r\n          <li class=\"nav04\"><a href=\"/business/\">事業内容<span>BUSINESS CONTENTS</span></a></li>\r\n          <li class=\"nav05\">\r\n            <a href=\"javascript:void(0);\">採用情報<span>CAREER</span></a>\r\n            <ul class=\"nav--sub\">\r\n              <li><a href=\"/business_2/\">料金所スタッフ採用情報</a></li>\r\n              <li>\r\n                <a href=\"https://tenshoku.mynavi.jp/jobinfo-426307-3-6-1/?msockid=3d319ca12add6b111ec189be2b0f6a58\" target=\"_blank\" title=\"新しいウインドウが開きます。\" rel=\"noopener noreferrer\">\r\n                  本社採用情報\r\n                  <img src=\"/common/img/blank_icon--white.svg\" width=\"11\" height=\"10\" alt=\"\" class=\"blank\">\r\n                  <span class=\"note\">（マイナビ転職に移動します）</span>\r\n                </a>\r\n              </li>\r\n            </ul>\r\n          </li>\r\n        </ul>\r\n      </nav>\r\n\r\n    </header>\r\n\r\n\r\n\r\n\r\n<div id=\"changeArea\">\r\n<div id=\"main\">\r\n<!-- InstanceBeginEditable name=\"EditRegion3\" -->\r\n<h2><img src=\"img/corpinfo_h2.jpg\" width=\"950\" height=\"123\" alt=\"会社情報\" /></h2>\r\n<div class=\"clearfix mt25\">\r\n\t<div class=\"content\">\r\n  \r\n    <h3 class=\"h-type01 space20b\">社会貢献活動</h3>\r\n    <h4 class=\"h-type02 space25b\">当社は社会貢献活動の一環として、お客さまや地域の皆さまに愛される企業を目指し、様々な取り組みを行っています。</h4>\r\n  \r\n      <!-- こども110番青少年を守る店、守る家 -->\r\n      <div class=\"corp-info-index02-box\">\r\n        <h5 class=\"h-type03-brackets space10b\">こども110番青少年を守る店、守る家</h5>\r\n        <p class=\"l160\">子どもが被害者となる事件を未然に防止するため、神戸市の「こども110番青少年を守る店、守る家」に当社の若宮営業所を登録し、緊急避難や一時保護に協力しています。</p>\r\n\t\t\t\t<div class=\"clearfix mt20\">\r\n\t\t\t\t\t<img src=\"img/index02_img11.jpg\" width=\"210\" height=\"140\" alt=\"\" class=\"f_left\" loading=\"lazy\">\r\n\t\t\t\t\t<img src=\"img/index02_img12.jpg\" width=\"210\" height=\"140\" alt=\"\" class=\"f_left ml25\" loading=\"lazy\">\r\n\t\t\t\t</div>\r\n      </div>\r\n  \r\n      <!-- 地域清掃活動 -->\r\n      <div class=\"corp-info-index02-box\">\r\n        <h5 class=\"h-type03-brackets space10b\">地域清掃活動</h5>\r\n        <p class=\"l160\">トール神戸では休憩時間を利用し、従業員がボランティアとして事務所周辺の清掃活動を実施し地域美化にも取り組んでいます。</p>\r\n\t\t\t\t<div class=\"clearfix mt20\">\r\n\t\t\t\t<img src=\"img/index02_img06.jpg\" width=\"210\" height=\"140\" alt=\"\" class=\"f_left\" loading=\"lazy\">\r\n\t\t\t\t<img src=\"img/index02_img07.jpg\" width=\"210\" height=\"140\" alt=\"\" class=\"f_left ml25\" loading=\"lazy\">\r\n\t\t\t\t</div>\r\n      </div>\r\n  \r\n      <!-- コンプライアンス活動 -->\r\n      <div class=\"corp-info-index02-box\">\r\n        <h5 class=\"h-type03-brackets space10b\">コンプライアンス活動</h5>\r\n        <p class=\"l160\">コンプライアンス研修の実施や、コンプライアンス手引き・コンプライアンスハンドブック等を配布し、社員のコンプライアンス意識の向上を図っています。</p>\r\n      </div>\r\n\r\n      <!-- AEDの設置 -->\r\n      <div class=\"corp-info-index02-box\">\r\n        <h5 class=\"h-type03-brackets space10b\">AEDの設置</h5>\r\n        <div class=\"clearfix mt10\">\r\n          <img src=\"img/index02_img09.png\" width=\"210\" height=\"210\" alt=\"AED\" class=\"f_right\" loading=\"lazy\">\r\n          <div class=\"w440 f_left l160 mr30\">\r\n            <p class=\"l160 space30b\">どなたでもご利用いただけるよう各営業所に「AED」を設置しています。<br />\r\n            また、神戸市の「まちかど救急ステーション」に登録をしています。</p>\r\n            <p>まちかど救急ステーション </p>\r\n            <p><a href=\"https://www.city.kobe.lg.jp/a84309/bosai/shobo/ambulance/matiqp/\" target=\"_blank\" title=\"新しいウインドウが開きます。\" rel=\"noopener noreferrer\">https://www.city.kobe.lg.jp/a84309/bosai/shobo/ambulance/matiqp/\r\n            <img src=\"../common/img/blank_icon.png\" width=\"13\" height=\"12\" alt=\"\"/></a></p>\r\n          </div>\r\n        </div>\r\n      </div>\r\n\t\t\r\n      <!-- 提供表示式救急キットFAの車両設置 -->\r\n      <div class=\"corp-info-index02-box\">\r\n        <h5 class=\"h-type03-brackets space10b\">提供表示式救急キットFAの車両設置</h5>\r\n        <p class=\"l160\">本社及び各営業所車両に社会貢献製品「提供表示式救急キットFA」を設置し、有事の際、救急キットを必要とされる方へ提供します。</p>\r\n        <p>提供表示式救急キットFA</p>\r\n        <p class=\"space30b\"><a href=\"https://www.elpuenteintl.com/\" target=\"_blank\" title=\"新しいウインドウが開きます。\" rel=\"noopener noreferrer\">https://www.elpuenteintl.com/\r\n        <img src=\"../common/img/blank_icon.png\" width=\"13\" height=\"12\" alt=\"\"/></a></p>\r\n        <img src=\"img/index02_img13.png\" width=\"445\" height=\"233\" alt=\"提供表示式救急キットFA\" loading=\"lazy\">\r\n      </div>\r\n\r\n      <!-- 地球環境への配慮 -->\r\n      <div class=\"corp-info-index02-box\">\r\n        <h5 class=\"h-type03-brackets space10b\">地球環境への配慮</h5>\r\n        <div class=\"clearfix mt10\">\r\n          <img src=\"img/index02_img03.webp\" width=\"210\" height=\"140\" alt=\"\" class=\"f_left\" loading=\"lazy\">\r\n          <p class=\"w440 f_left l160 ml30\">グリーン購入法に沿った製品の購入を行っています。<br />\r\n          また、こまめな消灯や夏期期間のクールビズの実施、深江浜事務所等では憩いの花壇を設置し市民の方々へ癒しを提供しています。</p>\r\n        </div>\r\n      </div>\r\n\r\n      <!-- 災害用備蓄食糧の寄付 -->\r\n      <div class=\"corp-info-index02-box\">\r\n        <h5 class=\"h-type03-brackets space10b\">災害用備蓄食糧の寄付</h5>\r\n        <p class=\"l160\">入替時期を迎える災害用備蓄食糧品を認定NPO法人等のフードバンクに寄付しています。</p>\r\n      </div>\r\n\r\n      <!-- 阪神高速 未来(あす)へのチャレンジプロジェクト -->\r\n      <div class=\"corp-info-index02-box\">\r\n        <h5 class=\"h-type03-brackets space10b\">阪神高速 未来(あす)へのチャレンジプロジェクト</h5>\r\n        <div class=\"clearfix mt10\">\r\n          <img src=\"img/index02_img15.png\" width=\"219\" height=\"190\" alt=\"阪神高速 未来(あす)へのチャレンジプロジェクト\" class=\"f_right\" loading=\"lazy\">\r\n          <div class=\"w440 f_left l160 mr30\">\r\n          <p class=\"l160 space30b\">本プロジェクトは、市民団体が阪神高速道路沿線で行う公益的な活動に対し、公募により助成を実施するもので、持続可能な開発目標（SDGs）の目標の１つである「17.パートナーシップで目標を達成しよう」で示されているように、協働により社会課題の解決を図り、地域・社会の持続的発展及びSDGs達成へ貢献していくものです。<br>当社も阪神高速グループの一員として、本プロジェクトに参画しており、地域・社会に貢献できる活動を応援し、明るい未来の共創に努めてまいります。</p>\r\n            <p class=\"l160\">プロジェクトの詳細は、<br>下記URL（阪神高速道路株式会社ホームページ）をご覧ください。</p>\r\n            <p class=\"l160\"><a href=\"https://www.hanshin-exp.co.jp/company/sustainability/challenge_project/\" target=\"_blank\" title=\"新しいウインドウが開きます。\" rel=\"noopener noreferrer\">https://www.hanshin-exp.co.jp/company/sustainability/challenge_project/ \r\n            <img src=\"../common/img/blank_icon.png\" width=\"13\" height=\"12\" alt=\"\"/></a></p>\r\n        </div>\r\n      </div>\r\n      </div>\r\n\r\n\t</div><!-- //content -->\r\n\r\n\r\n\r\n  <div id=\"side\" class=\"menu1-2\">\r\n      <p class=\"side--title\">\r\n        会社情報\r\n        <span>CORPORATE INFORMATION</span>\r\n      </p>\r\n      <ul>\r\n        <li class=\"menu1-1\"><a href=\"/corp_info/\">会社情報</a></li>\r\n        <li class=\"menu1-2\"><a href=\"/corp_info/index02.html\">社会貢献活動</a></li>\r\n        <li class=\"menu1-3\"><a href=\"/corp_info/index03.html\">人材育成</a></li>\r\n        <li class=\"menu1-4\">\r\n          <a href=\"/corp_info/pdf/career.pdf?v=202507\" target=\"_blank\" title=\"PDFファイルが開きます。\" rel=\"noopener noreferrer\">\r\n          労働施策総合推進法に基づく<br />中途採用比率の公表\r\n          <img src=\"/common/img/icon_pdf.gif\" width=\"16\" height=\"16\" alt=\"\"/>\r\n          </a>\r\n        </li>\r\n      </ul>\r\n\r\n  </div><!-- //side -->\r\n\r\n</div>\r\n<!-- InstanceEndEditable -->\r\n</div><!-- //main -->\r\n</div><!-- //changeArea -->\r\n\r\n<div id=\"pagetop\"><p><a href=\"#top\"><img src=\"/common/img/pagetop.jpg\" width=\"170\" height=\"26\" alt=\"ページトップへ戻る\" class=\"rollover\" /></a></p></div>\r\n<div id=\"footer\">\r\n\t<p><a href=\"/\">トップページ</a>　｜　\r\n    <a href=\"/corp_info/\">会社情報</a>　｜　\r\n    <a href=\"/corp_outline/\">会社概要</a>　｜　\r\n    <a href=\"/business/\">事業内容</a>　｜　\r\n    <a href=\"/news\">お知らせ</a>　｜　\r\n    <a href=\"/link/\">お役立ちリンク集</a>　｜　\r\n    <a href=\"/sitemap/\">サイトマップ</a>　｜　\r\n    <a href=\"/security/\">セキュリティポリシー</a>　｜　\r\n    <a href=\"/privacy/\">個人情報保護方針</a></p>\r\n</div><!-- //footer -->\r\n<div id=\"copyright\"><p>Copyright(c) Hanshin Expressway Toll KOBE Co., Ltd. All rights reserved.</p></div>\r\n\r\n<script type=\"text/javascript\" src=\"../common/js/jquery/jquery.min.js\"></script>\r\n<script type=\"text/javascript\" src=\"../common/js/fontsizechange.js\"></script>\r\n<script type=\"text/javascript\" src=\"../common/js/jquery.cookie.js\"></script>\r\n<script type=\"text/javascript\" src=\"../common/js/jquery.rollover.js\"></script>\r\n<script type=\"text/javascript\" src=\"../common/js/common.js\"></script>\r\n<!-- InstanceBeginEditable name=\"js\" -->\r\n<!-- InstanceEndEditable -->\r\n<script type=\"text/javascript\" src=\"/_Incapsula_Resource?SWJIYLWA=719d34d31c8e3a6e6fffd425f7e032f3&ns=10&cb=284192301\" async></script></body>\r\n<!-- InstanceEnd --></html>\r\n","finalUrl":"https://www.hanshin-tollkobe.co.jp/corp_info/index02.html","rendered":false,"_cachedAt":"2026-06-22T17:43:20.698Z"}