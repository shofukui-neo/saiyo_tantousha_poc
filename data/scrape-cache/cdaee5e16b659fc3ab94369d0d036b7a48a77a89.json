"js-accordion_trigger\"><span>採用</span></a>\n\n  <div class=\"subMenu js-accordion_panel\">\n\t<div class=\"row\">\n\t\t\n\t  <div class=\"subMenuInfo\">\n\t\t<h2>採用</h2>\n\t\t<span class=\"rightBlock\">\n\t\t  <a href=\"javascript: void(0);\" class=\"btnClose js-accordion_close\">閉じる</a>\n\t\t</span>\n\t  <!-- / .subMenuInfo --></div>\n    <div class=\"column-layout\" data-row-pc=\"3\" data-row-sp=\"1\">\n      <div class=\"column_item\">\n        <div class=\"image-set\">\n          <figure class=\"image_inner\">\n            <a href=\"http://www.khi-saiyo.jp/\" target=\"_blank\" class=\"a-blank\">\n              <img src=\"/common_new/img/nav_im28.jpg\" alt=\"\"/>\n              <span class=\"image_title-v2\"><span>総合採用情報</span></span>\n            </a>\n          </figure>\n        </div>\n      </div>\n      <div class=\"column_item\">\n        <div class=\"image-set\">\n          <figure class=\"image_inner\">\n            <a href=\"https://www.khi-saiyo.jp/production/\" target=\"_blank\" class=\"a-blank\">\n              <img src=\"/common_new/img/nav_im37.jpg\" alt=\"\"/>\n              <span class=\"image_title-v2\"><span>生産採用情報</span></span>\n            </a>\n          </figure>\n        </div>\n      </div>\n      <div class=\"column_item\">\n        <div class=\"image-set\">\n          <figure class=\"image_inner\">\n            <a href=\"https://www.khi-gr.jp/\" target=\"_blank\" class=\"a-blank\">\n              <img src=\"/common_new/img/nav_im32.jpg\" alt=\"\"/>\n              <span class=\"image_title-v2\"><span>関係会社採用情報</span></span>\n            </a>\n          </figure>\n        </div>\n     <!--\n        <div class=\"column-layout\" data-row-pc=\"2\">\n          <div class=\"image-set\">\n            <figure class=\"image_inner\">\n              <a href=\"https://progres01.jposting.net/pgkhi/u/job.phtml?job_code=122\" target=\"_blank\" class=\"a-blank\">\n                <img src=\"/common_new/img/nav_im29.jpg\" alt=\"\"/>\n                <span class=\"image_title-v2\" style=\"padding: 3px 30px 3px 10px;\"><span>障がい者採用情報(新卒)</span></span>\n              </a>\n            </figure>\n          </div>    \n          <div class=\"image-set\">\n            <figure class=\"image_inner\">\n              <a href=\"https://progres01.jposting.net/pgkhi/u/job.phtml?search_contents_code[17]=1&submit[search_category]=1\" target=\"_blank\" class=\"a-blank\">\n                <img src=\"/common_new/img/nav_im30.jpg\" alt=\"\"/>\n              <span class=\"image_title-v2\" style=\"padding: 3px 30px 3px 10px;\"><span>障がい者採用情報(中途)</span></span>\n              </a>\n            </figure>\n          </div>\n        </div>\n-->\n\n\n\n      </div>\n    <!--/column-layout--></div>\n\t  \n\t<!-- / .row --></div>\n  <!-- / .subMenu --></div>\n</li>\n<li><a href=\"/news/\"><span>ニュース</span></a></li>\n</ul>\n<!-- / #globalNav --></nav>\n<!-- / #header --></div>\n<!-- / #headerArea --></div>\n</header>\n<div class=\"overlay\"></div>\n  <div id=\"breadCrumb\">\n  <ul>\n    <li><a href=\"/\">Home</a></li>\n  <!-- InstanceBeginEditable name=\"breadcrumb\" -->\n    <li>企業情報</li>\n  <!-- InstanceEndEditable -->\n  </ul>\n  <!-- / #breadCrumb -->\n</div>\n    <main role=\"main\">\n<article id=\"anchorContents\">\n<!-- InstanceBeginEditable name=\"keyvisual\" -->\n<div id=\"keyvisualArea\" class=\"content corporate\">\n<div class=\"textArea\">\n<div class=\"inner\">\n<div class=\"captionBox\">\n<h1 class=\"title\">企業情報</h1>\n<!-- / .captionBox --></div>\n<!-- / .inner --></div>\n<!-- / .textArea --></div>\n<!-- / #keyvisualArea --></div>\n<!-- InstanceEndEditable -->\n<div id=\"contentsArea\" data-sidebar=\"false\">\n  <!-- InstanceBeginEditable name=\"contents\" -->\n    <div class=\"contents\">\n      <p>川崎重工は、国内外の100に及ぶ関連企業とともに\"技術の企業集団\"川崎重工グループを形成しています。<br>技術の歴史は100年を越え、磨きあげてきた先端技術をもって新たな価値を創造し、社会の発展に貢献するという理念のもと、陸・海・空はもとより、遥かな宇宙から深海にまで、多彩な製品を送り出しています。</p>\n      <hr class=\"line-layout\">\n      <div class=\"column-layout\" data-row-pc=\"3\" data-row-sp=\"2\">\n        <div class=\"column_item\" data-row-sp=\"1\">\n          <div class=\"image-set image-link\">\n            <figure class=\"image_inner\">\n              <a href=\"/corporate/message.html\">\n                <img src=\"/corporate/img/index_im01.jpg\" alt=\"\"/>\n                <span class=\"image_link_title v-sizeS\"><span>社長メッセージ</span></span>\n              </a>\n            </figure>\n          </div>\n          <p class=\"text-paragraph\">社長の橋本 康彦からのご挨拶です。</p>\n        </div>\n        <div class=\"column_item\" data-row-sp=\"1\">\n          <div class=\"image-set image-link\">\n            <figure class=\"image_inner\">\n              <a href=\"/corporate/statement.html\">\n                <img src=\"/corporate/img/index_im02.png\" alt=\"\"/>\n                <span class=\"image_link_title v-sizeS\"><span class=\"f-sizeS\">カワサキグループ・ミッションステートメント</span></span>\n              </a>\n            </figure>\n          </div>\n          <p class=\"text-paragraph\">川崎重工グループの経営理念をご紹介します。</p>\n        </div>\n        <div class=\"column_item\" data-row-sp=\"1\">\n          <div class=\"image-set image-link\">\n            <figure class=\"image_inner\">\n              <a href=\"/groupvision2030/\">\n                <img src=\"/corporate/img/index_im14.jpg\" alt=\"\"/>\n                <span class=\"image_link_title v-sizeS\"><span>グループビジョン 2030</span></span>\n              </a>\n            </figure>\n          </div>\n          <p class=\"text-paragraph\">弊社の2030年に⽬指す将来像をご紹介します。</p>\n        </div>\n        <div class=\"column_item\" data-row-sp=\"1\">\n          <div class=\"image-set image-link\">\n            <figure class=\"image_inner\">\n              <a href=\"/corporate/tag.html\">\n                <img src=\"/corporate/img/index_im03.png\" alt=\"\"/>\n                <span class=\"image_link_title v-sizeS\"><span>川崎重工のタグライン</span></span>\n              </a>\n            </figure>\n          </div>\n          <p class=\"text-paragraph\">グループタグラインについてご紹介します。</p>\n        </div>\n        <div class=\"column_item\" data-row-sp=\"1\">\n          <div class=\"image-set image-link\">\n            <figure class=\"image_inner\">\n              <a href=\"/corporate/outline.html\">\n                <img src=\"/corporate/img/index_im04.jpg\" alt=\"\"/>\n                <span class=\"image_link_title v-sizeS\"><span>会社概要</span></span>\n              </a>\n            </figure>\n          </div>\n          <p class=\"text-paragraph\">資本金、売上、従業員数などを掲載しています。</p>\n        </div>\n        <div class=\"column_item\" data-row-sp=\"1\">\n          <div class=\"image-set image-link\">\n            <figure class=\"image_inner\">\n              <a href=\"/corporate/network/\">\n                <img src=\"/corporate/img/index_im05.png\" alt=\"\"/>\n                <span class=\"image_link_title v-sizeS\"><span>事業拠点・関係会社</span></span>\n              </a>\n            </figure>\n          </div>\n          <p class=\"text-paragraph\">国内外の事業所、関係会社のご紹介です。</p>\n        </div>\n        <div class=\"column_item\" data-row-sp=\"1\">\n          <div class=\"image-set image-link\">\n            <figure class=\"image_inner\">\n              <a href=\"/corporate/division/\">\n                <img src=\"/corporate/img/index_im06.jpg\" alt=\"\"/>\n                <span class=\"image_link_title v-sizeS\"><span>事業部門紹介</span></span>\n              </a>\n            </figure>\n          </div>\n          <p class=\"text-paragraph\">多彩な製品を生み出す6つのカンパニーをご紹介します。</p>\n        </div>\n        <div class=\"column_item\" data-row-sp=\"1\">\n          <div class=\"image-set image-link\">\n            <figure class=\"image_inner\">\n              <a href=\"/corporate/executives/\">\n                <img src=\"/corporate/img/index_im07.jpg\" alt=\"\"/>\n                <span class=\"image_link_title v-sizeS\"><span>役員</span></span>\n              </a>\n            </figure>\n          </div>\n          <p class=\"text-paragraph\">川崎重工の役員をご紹介します。</p>\n        </div>\n        <div class=\"column_item\" data-row-sp=\"1\">\n          <div class=\"image-set image-link\">\n            <figure class=\"image_inner\">\n              <a href=\"/corporate/organization_chart.html\">\n                <img src=\"/corporate/img/index_im08.jpg\" alt=\"\"/>\n                <span class=\"image_link_title v-sizeS\"><span>組織・事業体制図</span></span>\n              </a>\n            </figure>\n          </div>\n          <p class=\"text-paragraph\">川崎重工（単体）の組織・事業体制図を掲載しています。</p>\n        </div>\n        <div class=\"column_item\" data-row-sp=\"1\">\n          <div class=\"image-set image-link\">\n            <figure class=\"image_inner\">\n              <a href=\"/corporate/dx/\">\n                <img src=\"/corporate/img/index_im13.jpg\" alt=\"\"/>\n                <span class=\"image_link_title v-sizeS\"><span>DX戦略</span></span>\n              </a>\n            </figure>\n          </div>\n          <p class=\"text-paragraph\">当社のDX戦略についてご紹介します。</p>\n        </div>\n        <div class=\"column_item\" data-row-sp=\"1\">\n          <div class=\"image-set image-link\">\n            <figure class=\"image_inner\">\n              <a href=\"/history/\" target=\"_blank\" class=\"a-blank\">\n                <img src=\"/corporate/img/index_im17.jpg\" alt=\"\"/>\n                <span class=\"image_link_title v-sizeS\"><span>川崎重工の歴史</span></span>\n              </a>\n            </figure>\n          </div>\n          <p class=\"text-paragraph\">100年を越える川崎重工の歴史をご紹介します。</p>\n        </div>\n        <div class=\"column_item\" data-row-sp=\"1\">\n          <div class=\"image-set image-link\">\n            <figure class=\"image_inner\">\n              <a href=\"/corporate/library/\">\n                <img src=\"/corporate/img/index_im11.jpg\" alt=\"\"/>\n                <span class=\"image_link_title v-sizeS\"><span>Kawasakiライブラリ</span></span>\n              </a>\n            </figure>\n          </div>\n          <p class=\"text-paragraph\">当社が発行している資料や冊子をご紹介します。 </p>\n        </div>\n        <div class=\"column_item\" data-row-sp=\"1\">\n          <div class=\"image-set image-link\">\n            <figure class=\"image_inner\">\n              <a href=\"/corporate/kawasaki-nmwa.html\">\n                <img src=\"/corporate/img/index_im16.jpg\" alt=\"\"/>\n                <span class=\"image_link_title v-sizeS\"><span>パートナーシップについて</span></span>\n              </a>\n            </figure>\n          </div>\n          <p class=\"text-paragraph\">川崎重工と国立西洋美術館はオフィシャルパートナー契約を締結しました。</p>\n        </div>\n        <div class=\"column_item\" data-row-sp=\"1\">\n          <div class=\"image-set image-link\">\n            <figure class=\"image_inner\">\n              <a href=\"/expo2025/\" target=\"_blank\" class=\"a-blank\">\n                <img src=\"/corporate/img/index_im18.jpg\" alt=\"\"/>\n                <span class=\"image_link_title v-sizeS\"><span>大阪・関西万博</span></span>\n              </a>\n            </figure>\n          </div>\n          <p class=\"text-paragraph\">未来の都市パビリオンで、移動することで幸せを感じる仕組み「移動本能」をテーマに、未来のサステナブルモビリティを披露しました。</p>\n        </div>\n        <div class=\"column_item\" data-row-sp=\"1\">\n          <div class=\"image-set image-link\">\n            <figure class=\"image_inner\">\n              <a href=\"/corporate/contacts/\">\n                <img src=\"/corporate/img/index_im12.jpg\" alt=\"\"/>\n                <span class=\"image_link_title v-sizeS\"><span>お問い合わせ</span></span>\n              </a>\n            </figure>\n          </div>\n          <p class=\"text-paragraph\">当社へのお問い合わせはこちらをご覧ください。</p>\n        </div>\n      <!--/column-layout--></div>\n    </div>\n    <hr class=\"line-layout\">\n    <div class=\"contents\">\n      <ul class=\"link-text-v3\" data-row-pc=\"3\" data-row-sp=\"1\">\n        <li><a href=\"https://www.khi-kenpo.or.jp\" target=\"_blank\" class=\"a-blank\">健康保険組合</a></li>\n        <li><a href=\"http://kawasaki-hospital-kobe.or.jp/\" target=\"_blank\" class=\"a-blank\">川崎病院</a></li>\n        <li><a href=\"https://www.khi.co.jp/ethic/\" target=\"_blank\" class=\"a-blank\">医の倫理委員会</a></li>\n      </ul>\n    </div>\n  <!-- InstanceEndEditable -->\n<!-- / #contentsArea --></div>\n<!-- #anchorContents --></article>\n</main>\n\n<div id=\"footerLinkArea\">\n\n<div id=\"footerLink\">\n\n<section id=\"groupLink\">\n<h2><a href=\"/\"><img src=\"/common_new/img/com_logo01.png\" alt=\"Kawasaki 川崎重工業株式会社\" width=\"240\" height=\"68\"></a></h2>\n</section>\n\n<section id=\"productsLink\">\n<h2>製品</h2>\n<ul class=\"row\">\n<li class=\"col_1of4\"><a href=\"/mobility/\"><img src=\"/common_new/img/footer_ic01.png\" alt=\"\" height=\"56\" width=\"135\"><br><span>輸送用機器</span></a></li><!--\n--><li class=\"col_1of4\"><a href=\"/energy/\"><img src=\"/common_new/img/footer_ic02.png\" alt=\"\" height=\"56\" width=\"56\"><br><span>エネルギー・環境</span></a></li><!--\n--><li class=\"col_1of4\"><a href=\"/industrial_equipment/\"><img src=\"/common_new/img/footer_ic03.png\" alt=\"\" height=\"56\" width=\"56\"><br><span>産業用設備</span></a></li><!--\n--><li class=\"col_1of4\"><a href=\"/leisure/\"><img src=\"/common_new/img/footer_ic04.png\" alt=\"\" height=\"56\" width=\"56\"><br><span>レジャー</span></a></li>\n</ul>\n<p class=\"footerLinkTxt\">世界の人々の豊かな生活と地球環境の未来に貢献する&ldquo;Global Kawasaki&rdquo;<br>\n川崎重工グループは、広範な領域における高度な総合技術力によって、地球環境との調和を図りながら、豊かで美しい未来社会の形成に向けて、新たな価値を創造します。</p>\n</section>\n</div>\n</div>\n<footer>\n<div class=\"inner\">\n<ul>\n<li><a href=\"/sitemap/\">サイトマップ</a></li><!--\n--><li><a href=\"/privacy_policy/\">個人情報の取扱いに関する方針</a></li><!--\n--><li><a href=\"/site_policy/\">サイトポリシー</a></li><!--\n--><li><a href=\"/socialguidelines/\">SNSコミュニティガイドライン</a></li>\n<li><a href=\"/cookie_policy/\">クッキーポリシー</a></li>\n<li><a class=\"optanon-show-settings\" style=\"cursor: pointer;\">クッキー詳細設定</a></li>\n</ul>\n<p class=\"copyright\" style=\"margin-top:10px;\">Copyright &copy; Kawasaki Heavy Industries, Ltd. All rights reserved.</p>\n</div>\n  <div id=\"pagetop\" class=\"Pagetop js-pagetop\">\n    <a href=\"#header\">ページの先頭に戻ります</a>\n  <!--/Pagetop--></div>\n</footer>\n</div>\n\n\n\n</body>\n</html>","finalUrl":"https://www.khi.co.jp/corporate/","rendered":false,"_cachedAt":"2026-06-14T19:17:15.925Z"}