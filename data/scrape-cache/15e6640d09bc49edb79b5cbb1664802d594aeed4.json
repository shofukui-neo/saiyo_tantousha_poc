n            <input type=\"hidden\" name=\"ie\" value=\"UTF-8\">\n            <input type=\"hidden\" name=\"oe\" value=\"UTF-8\">\n            <input type=\"hidden\" value=\"alp-grp.jp\" name=\"as_sitesearch\" />\n</form>\n</nav>\n</header>\n<style type=\"text/css\">\n</style>\n\n\t<script>\n\t(function($) {\n\t    $(function() {\n\t        var $header = $('#top-head');\n\t        // Nav Fixed\n\t        $(window).scroll(function() {\n\t            if ($(window).scrollTop() > 250) {\n\t                $header.addClass('fixed');\n\t            } else {\n\t                $header.removeClass('fixed');\n\t                \n\t                \t            }\n\t        });\n\t    });\n\t})(jQuery);\n\t</script>\n<div id=\"top-head\" class=\"head2\">\n\n\t<nav class=\"nav-horizontal blue\" role=\"navigation\">\n\t<div class=\"mask\">\n\t<ul class=\"list blue\">\n\t<li><a href=\"./recruit.html\" class=\"long15\">採用情報に戻る</a></li>\n\t<li><a href=\"#sc01\">募集要項</a></li>\n\t<li><a href=\"#sc02\">総合職</a></li>\n\t<li><a href=\"#sc03\">薬剤師職</a></li>\n\t<li><a href=\"#sc04\">臨床検査技師職\t</a></li>\n\t</ul>\n\t</div>\n\t</nav>\n</div>\n\n<div id=\"content\" class=\"page\"> \n<div class=\"page-01 saiyou\">\n\n<div class=\"recruit-bt\"><br /><br />\n<img src=\"./img/01-recruit/recruit-016.jpg\" width=\"250\" alt=\"新卒採用\" /><span class=\"recruit-bt3\"><a href=\"./contact-recruit1.html\">エントリー</a></span>\n</div>\n\n\n<div id=\"sc01\">\n<h3><span style=\"color: #7ecef4\">●</span> 2027年度募集要項</h3>\n\n\n\n</div>\n\n<div id=\"sc02\">\n<h4><span style=\"color: #e60012\">●</span> 総合職</h4>\n<table>\n<tbody>\n<tr><th width=\"25%\">職種</th><td>総合職 （営業、情報システム、ルート業務、薬局事務、検査補助）</td></tr>\n<tr><th>勤務地</th><td>石川県、富山県、福井県、新潟県、群馬県、埼玉県</td></tr>\n<tr><th>勤務時間</th><td>午前9時～午後6時 （シフトによる交替勤務あり,週40時間変形労働時間制）</td></tr>\n<tr><th>休日休暇</th><td>年間休日111日(2025年実績)【日曜・祝日,平日（シフトによる）,夏季・年末年始】</td></tr>\n<tr><th>初任給</th><td>短大卒：214,400円 大卒:242,200円 院卒:244,200円 (2026年実績)<br>※営業職は5,000円付加</td></tr>\n<tr><th>昇給</th><td>年1回</td></tr>\n<tr><th>賞与</th><td>年2回　4.0か月（2025年度実績）</td></tr>\n<tr><th>福利厚生</th><td>ベネフィットステーション、積立NISA、会員制リゾートホテル等の各種制度</td></tr>\n</tbody>\n</table>\n</div>\n\n<div id=\"sc03\">\n<h4><span style=\"color: #e60012\">●</span> 薬剤師職</h4>\n<table>\n<tbody>\n<tr><th width=\"25%\">職種</th><td>薬剤師（薬剤師国家資格保有者、薬剤師国家資格受験資格者）</td></tr>\n<tr><th>勤務地</th><td>石川県、富山県、福井県</td></tr>\n<tr><th>勤務時間</th><td>午前9時～午後6時 （シフトによる交替勤務あり,週40時間変形労働時間制）</td></tr>\n<tr><th>休日休暇</th><td>年間休日111日(2025年実績)【日曜・祝日,平日（シフトによる）,夏季・年末年始】</td></tr>\n<tr><th>初任給</th><td>324,200円 (2026年実績)</td></tr>\n<tr><th>昇給</th><td>年1回　</td></tr>\n<tr><th>賞与</th><td>年2回　4.0か月（2025年度実績）</td></tr>\n<tr><th>福利厚生</th><td>ベネフィットステーション、積立NISA、会員制リゾートホテル等の各種制度</td></tr>\n</tbody>\n</table>\n</div>\n\n\n<div id=\"sc04\">\n<h4><span style=\"color: #e60012\">●</span> 臨床検査技師職</h4>\n<table>\n<tbody>\n<tr><th width=\"25%\">職種</th><td>臨床検査技師職（臨床検査技師国家資格保有者、臨床検査技師国家資格受験資格者）</td></tr>\n<tr><th>勤務地</th><td>石川県、新潟県、群馬県</td></tr>\n<tr><th>勤務時間</th><td>午前9時～午後6時 （シフトによる交替勤務あり,週40時間変形労働時間制）</td></tr>\n<tr><th>休日休暇</th><td>年間休日111日(2025年実績)【日曜・祝日,平日（シフトによる）,夏季・年末年始】</td></tr>\n<tr><th>初任給</th><td>大卒:257,200円 院卒:259,200円 (2026年実績)</td></tr>\n<tr><th>昇給</th><td>年1回</td></tr>\n<tr><th>賞与</th><td>年2回　4.0か月（2025年度実績）</td></tr>\n<tr><th>福利厚生</th><td>ベネフィットステーション、積立NISA、会員制リゾートホテル等の各種制度</td></tr>\n</tbody>\n</table>\n</div>\n\n\n<div id=\"sc05\">\n<h4><span style=\"color: #e60012\">●</span> 採用情報</h4>\n<table>\n<tbody>\n<tr><th width=\"25%\">　募集期間</th><td>2026年3月〜6月</td></tr>\n<tr><th>選考日時</th><td><s>3月選考予定日3/28（土）</s><br><s>4月選考予定日4/25（土）</s><br><s>5月選考予定日5/16（土）</s><br>6月選考予定日6/27（土）</td></tr>\n<tr><th>応募方法</th><td>まずは、エントリーフォームのご提出をお願いします。<br>順次、ご案内をさせて頂きます。又、マイナビからのエントリーも受け付けています。</td></tr>\n<tr><th>会社説明会</th><td>随時<br>\n別途エントリーをお願いします。又は、マイナビよりお申し込みください。</td></tr>\n\n<tr><th>選考方法</th><td>1次選考：書類選考　(履歴書又はエントリーシート、卒業見込書、成績証明書)<br>\n2次選考：筆記試験、面接(個人面接)</td></tr>\n<tr><th>選考場所</th><td>株式会社アルプ 本社 （石川県金沢市近岡町309番地）</td></tr>\n<tr><th>書類送付先</th><td>株式会社アルプ 管理部人事課 （〒920-8217 石川県金沢市近岡町309番地）</td></tr>\n<tr><th>担当者</th><td>人事課採用担当 長浜 潤　E-mail : <a href=\"mailto:j-nagahama@alp-grp.jp\">j-nagahama@alp-grp.jp</a></td></tr>\n<tr><th>申込方法</th><td>当サイトのエントリーページからエントリーできます。<br>→ <a href=\"https://www.alp-grp.jp/contact-recruit1.html\">ホームページからエントリー</a><br>→ <a href=\"https://job.mynavi.jp/27/pc/search/corp80470/outline.html\">マイナビからエントリー</a></td></tr>\n</tbody>\n</table>\n</div>\n\n\n\n<!--\n<div id=\"sc07\">\n<h3><span style=\"color: #7ecef4\">●</span> その他待遇（共通）</h3><br><br>\n<table>\n<tbody>\n<tr><th width=\"25%\">諸手当</th><td>時間外、通勤、役職手当、その他</td></tr>\n<tr><th>昇給</th><td>年1回</td></tr>\n<tr><th>賞与</th><td>年2回　5.0ヶ月</td></tr>\n<tr><th>勤務時間</th><td>変形労働時間制(週40時間労働)<br />9:00～18:00を基本に、早番遅番交代制の8時間勤務</td></tr>\n<tr><th>休日休暇</th><td>週休2日制(日・月～土の1日/当社カレンダーによる交替制)※祝日のある週は日・祝日が休み<br />夏季、年末年始、年次有給、慶弔、特別、年間休日112日（※2023年実績）</td></tr>\n<tr><th>勤務地</th><td>石川県、富山県、福井県、新潟県、群馬県、埼玉県の各事業所</td></tr>\n<tr><th>保険</th><td>各種社会保険完備</td></tr>\n<tr><th>福利厚生</th><td>社員預金、ベネフィットワン、積立NISA、会員制リゾートホテル等の各種制度</td></tr>\n<tr><th>教育制度</th><td>新入社員研修、その他階層別に研修を実施</td></tr>\n<tr><th>提出書類</th><td>履歴書、卒業見込証明書、成績証明書</td></tr>\n</tbody>\n</table>\n</div>-->\n\n<style>\nh3 {margin-bottom: -20px !important;}\n</style>\n\n<!--\n\n<h3><span style=\"color: #7ecef4\">●</span><span style=\"color: #e60012\">連絡先・書類提出先</span></h3>\n<p>〒920-8217　石川県金沢市近岡町309番地<br />\nTEL.076-237-3104<br />\n管理部人事課　髙間俊幸</p> -->\n\n\n\n</div>\n</div>\n<div class=\"clear\"></div>\n\n\n<script>\n$(function(){\n   // #で始まるアンカーをクリックした場合に処理\n   $('a[href^=#]').click(function() {\n      // スクロールの速度\n      var speed = 400; // ミリ秒\n      // アンカーの値取得\n      var href= $(this).attr(\"href\");\n      // 移動先を取得\n      var target = $(href == \"#\" || href == \"\" ? 'html' : href);\n      // 移動先を数値で取得\n      var position = target.offset().top;\n      // スムーススクロール\n      $('body,html').animate({scrollTop:position}, speed, 'swing');\n      return false;\n   });\n});\n</script>\n  \n      \n</div>\n\n<div clas