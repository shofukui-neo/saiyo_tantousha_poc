" itemscope itemtype=\"http://schema.org/BreadcrumbList\">\n          <li itemprop=\"itemListElement\" itemscope itemtype=\"http://schema.org/ListItem\">\n            <a itemprop=\"item\" href=\"/\"><span itemprop=\"name\">トップ</span></a>\n            <meta itemprop=\"position\" content=\"1\" />\n          </li>\n          <li itemprop=\"itemListElement\" itemscope itemtype=\"http://schema.org/ListItem\">\n            <a itemprop=\"item\" href=\"/about/\"><span itemprop=\"name\">企業情報</span></a>\n            <meta itemprop=\"position\" content=\"2\" />\n          </li>\n          <li>ごあいさつ</li>\n        </ol>\n        <!--/pageGuide-->\n      </div>\n\n      <div class=\"container\" data-wide=\"false\" data-sidebar=\"false\">\n        <div class=\"contents\">\n          <div class=\"contents-wrap\">\n            <div class=\"heading-lv1\">\n              <div class=\"heading_subtitle\">企業情報</div>\n              <h1 class=\"heading_title\">ごあいさつ</h1>\n            </div>\n            <!--/heading-lv1-->\n\n            <section>\n              <p class=\"text-paragraph\">\n                当社は、1975年の創業以来、エンジニアリングをベースとした生産設備建設、環境関連設備、環境分析を得意とする帝人グループのエンジニアリング会社です。\n              </p>\n              <p class=\"text-paragraph\">\n                お客様の立場に立って、最適なソリューションをご提案・ご提供することを、第一に、これまで取組んで参りました。\n              </p>\n              <p class=\"text-paragraph\">\n                これからもお客様の事業環境ニーズに対応した最適なソリューションをご提案し続けるために、技術力の向上、チャレンジ精神の発揮に努め、クオリティ・オブ・ライフの向上実現を目指して参ります。\n              </p>\n              <p class=\"text-paragraph\">\n                これまでの皆様からのご支援に感謝申し上げるとともに、今後ともより一層のご支援・ご鞭撻を賜りたく、よろしくお願い申し上げます。\n              </p>\n              <!--/column-media-->\n              <p class=\"text-paragraph gp-al-right\">代表取締役</p>\n              <div class=\"image-set gp-al-right\">\n                <figure class=\"image_inner\"><img src=\"img/about_message_im01.jpg\" alt=\"\"></figure>\n              </div>\n              <!--/image-set-->\n            </section>\n            <!--/contents-wrap-->\n          </div>\n          <!--/contents-->\n        </div>\n        <!--/container-->\n      </div>\n      <!--/MainBody-->\n    </div>\n    <!--/Main-->\n  </main>\n  <aside id=\"assist\" class=\"Assist\">\n    <div id=\"assistModal\" class=\"AssistModal\">\n  <div class=\"assist-utility js-utility_modal\" data-utility=\"lang\">\n    <div class=\"utility_heading\">\n      <div class=\"utility_title\">東邦化工建設株式会社 企業サイト</div>\n      <div class=\"utility_close\"><a href=\"javascript:void(0)\" class=\"js-utility_modal_close\">閉じる</a></div>\n    </div>\n    <div class=\"utility_content\">\n      <ul class=\"utility_links\" data-count-pc=\"3\" data-count-sp=\"1\">\n        <li><a href=\"/\"><span class=\"utility_links_label\">日本（日本語）</span></a></li>\n        <li><a href=\"/en/\" target=\"_blank\"><span class=\"utility_links_label\">Global（English）</span></a></li>\n        <li><a href=\"/ch/\" target=\"_blank\"><span class=\"utility_links_label\">中国（簡体中文）</span></a></li>\n      </ul>\n    </div>\n    <!--/assist-utility-->\n  </div>\n  <!--/AssistModal-->\n</div>\n    <div id=\"assistClone\" class=\"AssistClone js-footer\" data-button-count=\"2\">\n      <div class=\"assist-wrap\">\n        <div class=\"footer-assist js-utility\">\r\n        <ul class=\"assist_buttons js-footer_assist_button\">\r\n          <li class=\"type-pagetop\"><a href=\"#header\" class=\"js-footer_pagetop\"><span class=\"assist_label\">ページ上部へ</span></a></li>\r\n        </ul>\r\n      <!--/footer-assist--></div>\r\n\n        <!--/assist-wrap-->\n      </div>\n      <div class=\"footer-policy js-footer_policy\">\r\n        <div class=\"policy_box\">\r\n          <p class=\"policy_text\">当ウェブサイトでは、お客様により良いサービスを提供するため、クッキーを利用しています。クッキーの使用に同意いただける場合は「同意」ボタンをクリックし、クッキーに関する情報や設定については「詳細を見る」ボタンをクリックしてください。</p>\r\n          <div class=\"policy_action\">\r\n            <button type=\"button\" class=\"policy_agree js-footer_policy_agree\"><span class=\"policy_agree_label\">同意</span></b