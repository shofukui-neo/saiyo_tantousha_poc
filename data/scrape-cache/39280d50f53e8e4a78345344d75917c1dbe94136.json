.googleapis.com/css2?family=Montserrat:wght@600;700;800&family=Noto+Sans+JP:wght@400;500;700&family=EB+Garamond:wght@600&display=swap');\n  </style>\n\n  <!-- パンくずリスト_bgcolor有 -->\n  <nav class=\"nav_bg\">\n    <ol class=\"breadcrumb\">\n      <li><a href=\"/\">TOP</a></li>\n      <li>企業情報</li>\n    </ol>\n    <div class=\"top_title_txt_container\">\n      <p class=\"top_title_txt\">Corporate information</p>\n    </div>\n  </nav>\n  <style>\n    .nav_bg {\n      background-color: #f0f8ff;\n      padding: 1em 1em 4em 1em;\n    }\n\n    .top_title_txt_container {\n      max-width: 1110px;\n      margin: 0 auto;\n      padding: 0 1em;\n    }\n\n    .top_title_txt {\n      font-family: 'EB Garamond', serif;\n      font-size: 7rem;\n      letter-spacing: 3px;\n      color: #0069C7;\n      font-weight: 600;\n    }\n\n    .breadcrumb {\n      display: flex;\n      flex-wrap: wrap;\n      list-style: none;\n      max-width: 1110px;\n      margin: 30px auto 70px auto;\n      padding: 0 1em;\n    }\n\n    .breadcrumb li {\n      font-family: 'Noto Sans JP', sans-serif;\n      font-size: 1.2rem;\n      font-weight: 400;\n      color: #222;\n    }\n\n    .breadcrumb a {\n      text-decoration: underline;\n    }\n\n    .breadcrumb a:hover {\n      font-weight: 700;\n    }\n\n    .breadcrumb li:not(:last-of-type)::after {\n      content: \"＞\";\n      margin: 0 1.3em;\n      color: #222;\n    }\n\n    .breadcrumb li:last-child {\n      font-weight: 700;\n    }\n\n    @media print,\n    screen and (max-width: 750px) {\n      .breadcrumb {\n        margin-bottom: clamp(20px, 10vw, 70px);\n      }\n\n      .breadcrumb li:not(:last-of-type)::after {\n        margin: 0 0.5em;\n      }\n    }\n\n    @media print,\n    screen and (max-width: 470px) {\n      .top_title_txt {\n        font-size: clamp(4.7rem, 14.9vw, 7rem)\n      }\n    }\n  </style>\n\n  <!-- 会社概要 -->\n  <div class=\"message_container\">\n    <div class=\"box_title\" style=\"width: 100%;\">\n      会社概要\n    </div>\n  </div>\n  <style>\n    .message_container {\n      display: flex;\n      margin: 0 auto;\n      max-width: 1110px;\n      padding: 7em 1em 0 1em;\n    }\n\n    .box_title {\n      width: 30%;\n      font-family: 'Noto Sans JP', sans-serif;\n      font-size: 4rem;\n      font-weight: 700;\n      color: #222;\n      letter-spacing: 1.5px;\n      padding-left: 0.8em;\n      text-indent: -0.8em;\n    }\n\n    .box_title::before {\n      content: \"\";\n      height: 13px;\n      width: 13px;\n      background: #0069C7;\n      display: inline-block;\n      margin-right: 0.2em;\n      vertical-align: middle;\n    }\n\n    .box_title_txt {\n      width: 70%;\n    }\n\n    @media print,\n    screen and (max-width: 881px) {\n      .message_container {\n        display: block;\n      }\n\n      .box_title,\n      .box_title_txt {\n        width: 100%;\n      }\n\n    }\n\n    @media print,\n    screen and (max-width: 470px) {\n      .box_title {\n        font-size: clamp(3rem, 8.6vw, 4rem);\n      }\n    }\n  </style>\n\n  <!-- 会社概要_テーブル -->\n  <div class=\"gray_bg\" style=\"background-color: #FFF;\">\n    <div class=\"table_container\">\n      <table class=\"ub_table\">\n        <tr>\n          <th class=\"txt16\" style=\"font-weight: 700;\">商号</th>\n          <td class=\"txt14\">ヨシダ印刷 株式会社</td>\n        </tr>\n        <tr>\n          <th class=\"txt16\" style=\"font-weight: 700;\">所在地</th>\n          <td class=\"txt14\">\n            <span style=\"font-weight: 700;\">金沢本社</span>\n            <br>\n            〒921-8546\n            <br>\n            石川県金沢市御影町19ｰ1\n            <br>\n            TEL：076ｰ241-2141（代）／<br class=\"sp-br\">FAX：076ｰ243-4515\n            <br>\n            <br>\n            <span style=\"font-weight: 700;\">東京本社</span>\n            <br>\n            〒130ｰ0014\n            <br>\n            東京都墨田区亀沢3-20-14\n            <br>\n            TEL：03ｰ3626ｰ1301（代）／<br class=\"sp-br\">FAX：03ｰ3626ｰ1300\n          </td>\n        </tr>\n        <tr>\n          <th class=\"txt16\" style=\"font-weight: 700;\">創業</th>\n          <td class=\"txt14\">1906年（明治39年6月）</td>\n        </tr>\n        <tr>\n          <th class=\"txt16\" style=\"font-weight: 700;\">法人化</th>\n          <td class=\"txt14\">1950年（昭和25年9月）</td>\n        </tr>\n        <tr>\n          <th class=\"txt16\" style=\"font-weight: 700;\">資本金</th>\n          <td class=\"txt14\">9,800万円</td>\n        </tr>\n        <tr>\n          <th class=\"txt16\" style=\"font-weight: 700;\">役員</th>\n          <td class=\"txt14\">\n            <span style=\"font-weight: 700;\">代表取締役社長</span>　吉田　克也\n            <br>\n            <br>\n            <span style=\"font-weight: 700;\">常務取締役</span>　　　池田　徹\n            <br>\n            <br>\n            <span style=\"font-weight: 700;\">常務取締役</span>　　　堀　英也\n            <br>\n            <br>\n            <span style=\"font-weight: 700;\">取締役</span>　　　　　小原　恵\n            <br>\n            <br>\n            <span style=\"font-weight: 700;\">取締役</span>　　　　　三宅　康介\n            <br>\n            <br>\n            <span style=\"font-weight: 700;\">執行役員</span>　　　　松永　啓太郎\n            <br>\n            <br>\n            <span style=\"font-weight: 700;\">執行役員</span>　　　　滝口　祐司\n            <br>\n            <br>\n            <span style=\"font-weight: 700;\">執行役員</span>　　　　村田　栄路\n            <br>\n            <br>\n            <span style=\"font-weight: 700;\">執行役員</span>　　　　石田　俊典\n          </td>\n        </tr>\n        <tr>\n          <th class=\"txt16\" style=\"font-weight: 700;\">役員・従業員数</th>\n          <td class=\"txt14\">140名（グループ全体180名）</td>\n        </tr>\n        <tr>\n          <th class=\"txt16\" style=\"font-weight: 700;\">事業所</th>\n          <td class=\"txt14\">\n            関西支店\n            <br>\n            富山営業所\n            <br>\n            金沢本社工場\n            <br>\n            江東潮見工場\n          </td>\n        </tr>\n        <tr>\n          <th class=\"txt16\" style=\"font-weight: 700;\">主要営業品目</th>\n          <td class=\"txt14\">\n            各種印刷物の企画・制作、編集、印刷、加工\n            <br>\n            各種デジタルメディアの企画・制作\n          </td>\n        </tr>\n        <tr>\n          <th class=\"txt16\" style=\"font-weight: 700;\">グループ会社</th>\n          <td class=\"txt14\">\n            株式会社 ヨシダ洋紙\n            <br>\n            株式会社 ヨシダ七尾\n            <br>\n            ワイピービズインプルーブ 株式会社\n          </td>\n        </tr>\n        <tr>\n          <th class=\"txt16\" style=\"font-weight: 700;\">登録・認定</th>\n          <td class=\"txt14\">\n            届出電気通信事業者（D-15-00286）\n            <br>\n            ISO/IEC27001:2022\n          </td>\n        </tr>\n      </table>\n    </div>\n  </div>\n  <style>\n    .sp-br {\n      display: none;\n    }\n\n    .gray_bg {\n      background-color: #F2F2F2;\n      padding: 4em 8em 7em 8em;\n    }\n\n    .ub_title {\n      position: relative;\n      color: #222;\n      font-family: 'Noto Sans JP', sans-serif;\n      font-size: 3rem;\n      font-weight: 700;\n      text-align: center;\n      margin-bottom: 100px;\n      letter-spacing: 1px;\n    }\n\n    .ub_title:before {\n      content: '';\n      position: absolute;\n      left: 50%;\n      bottom: -30px;\n      width: 50px;\n      height: 5px;\n      -moz-transform: translateX(-50%);\n      -webkit-transform: translateX(-50%);\n      -ms-transform: translateX(-50%);\n      transform: translate(-50%);\n      background-color: #0069C7;\n    }\n\n    .table_container {\n      max-width: 920px;\n      margin: 0 auto;\n    }\n\n    .ub_table {\n      table-layout: fixed;\n      width: 100%;\n    }\n\n    .ub_table tr {\n      border-collapse: collapse;\n      border-top: 1px solid #DDDBDB;\n      border-bottom: 1px solid #DDDBDB;\n    }\n\n    .ub_table th {\n      text-align: left;\n    }\n\n    .ub_table th,\n    .ub_table td {\n      padding: 25px 30px;\n      color: #000;\n      font-family: 'Noto Sans JP', sans-serif;\n      font-weight: 400;\n      letter-spacing: 1px;\n    }\n\n    @media print,\n    screen and (min-width: 750px) {\n      .ub_table th {\n        width: 30%;\n      }\n\n      .ub_table td {\n        width: 70%;\n      }\n    }\n\n    @media print,\n    screen and (max-width: 750px) {\n      .gray_bg {\n        padding: 6em 1em;\n      }\n\n      .ub_table th,\n      .ub_table td {\n        display: block;\n        padding: 1em;\n      }\n\n      .ub_table td {\n        padding-left: 2em;\n      }\n    }\n\n    @media print,\n    screen and (max-width: 470px) {\n      .sp-br {\n        display: block;\n      }\n    }\n  </style>\n\n  <!-- 職場風土改善事業の取り組み -->\n  <div class=\"gray_bg bg_ctrl\">\n    <div class=\"message_container\" style=\"display: block; padding: 0;\">\n      <div style=\"max-width: 1110px; padding: 7em 1em;\">\n        <div class=\"box_title\" style=\"width: 100%;\">\n          職場風土改善事業の取り組み\n        </div>\n        <!-- テキストフォーマット_left -->\n        <div class=\"text_container text_container_mt\">\n          <p class=\"text_container_txt\">\n            ヨシダ印刷株式会社は、職場環境整備を促進する企業として「一般事業主行動計画」を策定し、「職場風土改革促進事業主」として、2009年（平成21年）6月に財団法人21世紀職業財団より指定を受け職場の風土改善に取り組んでいます。\n            <br>\n            この指定は、「仕事と生活とを両立しやすい職場づくりのための風土改善に積極的に取り組む姿勢を明らかにした企業」と認められたものです。\n            <br>\n            これからも社員ひとりひとりが、仕事と生活をより充実させ、いずれにも責任のある生き生きとした毎日が過ごせるような職場づくりに取り組んでまいります。\n          </p>\n        </div>\n        <div class=\"text_container\" style=\"text-align: right;\">\n          <p class=\"text_container_txt\" style=\"text-align: right;\">\n            代表取締役社長　吉田　克也\n          </p>\n        </div>\n        <div class=\"col1_box\">\n<!--旧記述\n          <a href=\"https://www.yoshida-p.co.jp/pdf/20201228doc.pdf\">一般事業主行動計画</a>\n-->\n          <a href=\"https://www.yoshida-p.co.jp/images/20250901doc.pdf\" target=\"_blank\">一般事業主行動計画</a>\n        </div>\n      </div>\n    </div>\n  </div>\n  <style>\n    .bg_ctrl {\n      padding: 0;\n    }\n\n    .text_container {\n      text-align: center;\n      margin: 0 auto;\n      display: block;\n      max-width: 968px;\n      paddin