ab_selecter li').removeClass('active');\n\t\t\t\t\t\t$(this).addClass('active');\n\t\t\t\t\t})\n\t\t\t\t\t$('#selecter2').click(function(){\n\t\t\t\t\t\t$('#tab01').fadeOut('fast');\n\t\t\t\t\t\t$('#tab02').fadeIn('fast');\n\t\t\t\t\t\t$('.tab_selecter li').removeClass('active');\n\t\t\t\t\t\t$(this).addClass('active');\n\t\t\t\t\t})\n\n\t\t\t\t});\n\t\t\t</script>\n<script>\n\t\t\t\t\twindow.onpageshow = function() {\n\t\t\t\t\t\tif ($(\"#doui\").is(':checked')) {\n\t\t\t\t\t\t\t$('#submit_btn input').prop('disabled', false);\n\t\t\t\t\t\t} else {\n\t\t\t\t\t\t\t$('#submit_btn input').prop('disabled', true);\n\t\t\t\t\t\t}\n\t\t\t\t\t};\n\n</script>\n\t\t</head>\n\t\t<body class=\"page-template page-template-page-main page-template-page-main-php page page-id-8 has-header-image page-two-column colors-light\">\n\n\t\t\t<h1 id=\"logo\">\n\t\t\t\t<a href=\"https://www.systembase.co.jp/\">株式会社システムベース　オフィシャルサイトに移動</a>\n\t\t\t\t<!--<div id=\"tour_bnr\"><a href=\"https://www.systembase.co.jp/recruit/tour.html\" target=\"_blank\"><img src=\"https://www.systembase.co.jp/recruit/wp-content/uploads/2022/02/banner_tour_s.svg\" width=\"180\" height=\"60\" alt=\"\"></a></div>-->\n\t\t\t</h1>\n\t\t\t<header>\n\t\t\t\t\t\t\t\t\t<h2>『企業を知る』</h2>\n\t\t\t\t\t\t\t</header>\n\n\t\t\t<nav id=\"gnav\">\n\t\t\t\t<div id=\"mynavi\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<!-- Begin mynavi Navi Link -->\r\n<a href=\"https://job.mynavi.jp/27/pc/search/corp55373/outline.html\" target=\"_blank\">\r\n<img src=\"https://www.systembase.co.jp/recruit/wp-content/uploads/2025/09/banner_entry2027.png\" alt=\"マイナビ2027\" border=\"0\">\r\n</a>\r\n<!-- End mynavi Navi Link -->\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t\t<ul>\n\t\t\t\t\t\t<li id=\"gnav01\"><a href=\"https://www.systembase.co.jp/recruit/recruit6/\" title=\"エントリーフォーム\">エントリーフォーム</a></li>\n\t\t\t\t\t\t<li id=\"gnav02\"><a href=\"https://www.systembase.co.jp/recruit/#section5f\" title=\"会社説明会・募集要項\">会社説明会・募集要項</a></li>\n\t\t\t\t\t\t<li id=\"gnav03\"><a href=\"https://www.systembase.co.jp/recruit/#section4f\" title=\"キャリアと制度\">キャリアと制度</a></li>\n\t\t\t\t\t\t<li id=\"gnav04\"><a href=\"https://www.systembase.co.jp/recruit/#section3f\" title=\"人を知る\">人を知る</a></li>\n\t\t\t\t\t\t<li id=\"gnav05\"><a href=\"https://www.systembase.co.jp/recruit/#section2f\" title=\"仕事を知る\">仕事を知る</a></li>\n\t\t\t\t\t\t<li id=\"gnav06\"><a href=\"https://www.systembase.co.jp/recruit/#section1f\" title=\"企業を知る\">企業を知る</a></li>\n\t\t\t\t\t</ul>\n\t\t\t\t\t\t\t</nav><main>\n\t\t\t\t\t\t\t\t\t\t\t\t\t<section id=\"section1\">\r\n<article id=\"section1-1\">\r\n<div class=\"fll\"><img decoding=\"async\" src=\"https://www.systembase.co.jp/recruit/wp-content/uploads/2021/12/recruit1_illust1.png\" alt=\"\"></div>\r\n<div class=\"flr\">\r\n<h3>システムベースについて</h3>\r\n<p>当社は、創業当時からデータセンターを持ち、300社以上にネットワークでのサービスを提供してきた強みを生かし、クラウドサービスの拡大に力を入れております。</p>\r\n<p>&nbsp;</p>\r\n<p>また、システムインテグレータとしてお客様のニーズにあった情報システムを企画から設計・開発、運用まで一貫して担っております。</p>\r\n<p>社内の円滑な人間関係が、お客様とのコミュニケーションにも繋がるとの考えから、｢明るく、楽しく｣｢全員主役、全員脇役｣をモットーに、日々の業務を進めております。</p>\r\n<p>常にお客様に最良の品質を提供していくために、全社一丸となって製品、技術、サービスの向上に努めており、お客様の「信頼と満足」をより向上させる活動を行なっております。</p>\r\n<p>&nbsp;</p>\r\n</div>\r\n</article>\r\n<article id=\"section1-2\">\r\n<ul>\r\n\t<li><a id=\"paly_vid\" href=\"#player\" target=\"_blank\" rel=\"noopener noreferrer\"><img decoding=\"async\" src=\"https://www.systembase.co.jp/wp-content/uploads/2023/11/banner_message2023.png\" alt=\"これからともに働く皆様へ 社長からのメッセージ\"></a></li>\r\n<!--\r\n\t\r\n\t\r\n\t\r\n\t<li><a href=\"https://www.systembase.co.jp/recruit/tour.html\" target=\"_blank\" rel=\"noopener noreferrer\"><img decoding=\"async\" src=\"https://www.systembase.co.jp/recruit/wp-content/uploads/2022/01/banner_tour.png\" alt=\"潜入システムベース社内ツアー\"></a></li>\r\n\r\n\r\n\r\n--></ul>\r\n<div id=\"video\"><video width=\"960\" height=\"540\" id=\"player\" controls=\"controls\"> <source src=\"https://www.systembase.co.jp/wp-content/uploads/2023/11/Top_comment_mini202310.mp4\"> </video></div>\r\n</article>\r\n</section>\r\n<section id=\"section2\">\r\n<article>\r\n<div class=\"fll\"><img decoding=\"async\" src=\"https://www.systembase.co.jp/recruit/wp-content/uploads/2021/12/recruit1_illust2.png\" alt=\"\"></div>\r\n<div class=\"flr\">\r\n<h3>経営理念</h3>\r\n<p>情報処理サービスで地域の皆様のお役に立ちたいと考えております。</p>\r\n<p>&nbsp;</p>\r\n<p>今後もパシフィックシステム・グループとして、豊かで高度な情報社会を実現するために、確かな情報通信技術に基づく最適なソリューションとサービスを提供すると共に、 環境への配慮、社会への貢献とも調和した事業活動を行ないます。</p>\r\n</div>\r\n</article>\r\n</section>\r\n<section id=\"section4\">\r\n<article>\r\n<div class=\"fll\"><img decoding=\"async\" src=\"https://www.systembase.co.jp/recruit/wp-content/uploads/2021/12/recruit1_illust4.png\" alt=\"\"></div>\r\n<div class=\"flr\">\r\n<h3>福利厚生他</h3>\r\n<dl>\r\n<dt>入社日に有給休暇付与</dt>\r\n<dd>\r\n<p>（労働基準法では、入社半年経過後に１０日付与）</p>\r\n<p>（半日有給休暇の取得も可能です。）</p>\r\n</dd>\r\n<dt>時間外勤務手当　全額支給</dt>\r\n</dl>\r\n<dl>\r\n<dt>完全週休二日制、年末年始（１２月３０日～翌年１月３日）</dt>\r\n<dt>中小企業退職金共済加入</dt>\r\n</dl>\r\n<p>（入社１年を経過すると、会社が毎月定額の掛金を掛け、その累積額+運用益が退職金として支給されます。勤務年数や役職によって掛金が増額します。）</p>\r\n<dl>\r\n<dt>確定拠出年金制度</dt>\r\n</dl>\r\n<dl>\r\n<dt>女性社員の育児休業 100%取得、100%復職を継続中</dt>\r\n<dt>資格取得合格一時金制度</dt>\r\n<dt><a href=\"https://bs.benefit-one.co.jp/bs-official/recruit/index.html\" target=\"_blank\" rel=\"noopener noreferrer\"></a></dt>\r\n</dl>\r\n</div>\r\n</article>\r\n</section>\r\n<section id=\"section5\">\r\n<article>\r\n<div class=\"fll\"><img decoding=\"async\" src=\"https://www.systembase.co.jp/recruit/wp-content/uploads/2021/12/recruit1_illust5.png\" alt=\"\"></div>\r\n<div class=\"flr\">\r\n<h3>システムベースの取組</h3>\r\n<p>快適な職場づくりのために、私たちは様々な取組を行っています。</p>\r\n<h4>健康</h4>\r\n<ul>\r\n\t<li><img decoding=\"async\" src=\"https://www.systembase.co.jp/recruit/wp-content/uploads/2025/04/2025kenkoukeiei.png\" alt=\"\"><br>\r\nいわて健康経営宣言企業</li>\r\n\t<li><img decoding=\"async\" src=\"https://www.systembase.co.jp/recruit/wp-content/uploads/2024/11/あっぴリレーマラソン.jpg\" alt=\"\"><br>\r\n各種クラブ活動の推奨<br>\r\n（マラソン、ゴルフ、サッカー、ボウリング）</li>\r\n</ul>\r\n<h4>働きやすさ</h4>\r\n<ul>\r\n\t<li><img decoding=\"async\" src=\"https://www.systembase.co.jp/recruit/wp-content/uploads/2022/02/iwate_hatarakikata_kaikaku.png\" alt=\"いわて働き方改革AWARDエントリー\"><br>\r\nいわて働き方改革AWARDエントリー</li>\r\n\t<li><a href=\"https://positive-ryouritsu.mhlw.go.jp/positivedb/detail?id=25163\" target=\"_blank\" rel=\"noopener\"><img decoding=\"async\" src=\"https://www.systembase.co.jp/recruit/wp-content/uploads/2022/02/elle_boshi.jpg\" alt=\"女性活躍推進　「えるぼし認定★★★」\"></a>女性活躍推進　「えるぼし認定★★★」</li>\r\n\t<li>\r\n<div style=\"display: flex;\">\r\n<p style=\"width: 20%; flex: none;\"><img decoding=\"async\" style=\"display: block; width: 100%; height: 100%; object-fit: cover; object-position: center top;\" src=\"https://www.systembase.co.jp/recruit/wp-content/uploads/2023/10/WAKAMONO-1.jpg\"></p>\r\n<p style=\"width: 20%; flex: none;\"><img decoding=\"async\" style=\"display: block; width: 100%; height: 100%; object-fit: cover; object-position: center top;\" src=\"https://www.systembase.co.jp/recruit/wp-content/uploads/2024/08/WAKAMONO2-2.jpg\"></p>\r\n<p style=\"width: 20%; flex: none;\"><img decoding=\"async\" style=\"display: block; width: 100%; height: 100%; object-fit: cover; object-position: center top;\" src=\"https://www.systembase.co.jp/recruit/wp-content/uploads/2024/08/WAKAMONO3-2.jpg\"></p>\r\n<p style=\"width: 20%; flex: none;\"><img decoding=\"async\" style=\"display: block; width: 100%; height: 100%; object-fit: cover; object-position: center top;\" src=\"https://www.systembase.co.jp/recruit/wp-content/uploads/2025/04/WAKAMONO-4-2.jpg\"></p>\r\n<p style=\"width: 20%; flex: none;\"><img decoding=\"async\" style=\"display: block; width: 100%; height: 100%; object-fit: cover; object-position: center top;\" src=\"https://www.systembase.co.jp/recruit/wp-content/uploads/2023/10/WAKAMONO-5.jpg\"></p>\r\n</div>\r\n\r\n\r\n若者応援企業宣言</li>\r\n</ul>\r\n<h4>社会貢献活動</h4>\r\n<ul>\r\n\t<li><img decoding=\"async\" src=\"https://www.systembase.co.jp/recruit/wp-content/uploads/2023/10/HOUSHIKATUDOU_2023.jpg\" alt=\"\"><br>\r\n本社周辺の清掃活動<br>\r\n毎年、本社周辺の清掃活動を実施</li>\r\n\t<li><img decoding=\"async\" src=\"https://www.systembase.co.jp/recruit/wp-content/uploads/2022/02/michinoku_geinomatsuri-1.jpg\" alt=\"みちのく芸能祭り参加\"><br>\r\nみちのく芸能祭り参加</li>\r\n</ul>\r\n<h4>環境取組</h4>\r\n<ul>\r\n\t<li class=\"width_double\">本社の照明はLED照明を使用<br>\r\n省電力化とLED化による照明の寿命が伸び産業廃棄物の削減に貢献</li>\r\n</ul>\r\n<h4>SDGｓの取組</h4>\r\n<p><img fetchpriority=\"high\" decoding=\"async\" src=\"https://www.systembase.co.jp/recruit/wp-content/uploads/2022/02/sdg_poster_ja_2021.png\" width=\"610\" height=\"362\" alt=\"\"></p>\r\n<p>私たちは、事業・企業活動を通じてSDGｓへの貢献に取り組んでおります。</p>\r\n<p>&nbsp;</p>\r\n<p>&nbsp;</p>\r\n<h5>【事業活動を通じたSDGｓへの取組】</h5>\r\n<p>&nbsp;</p>\r\n<h5><img decoding=\"async\" src=\"https://www.systembase.co.jp/recruit/wp-content/uploads/2022/02/sdgs_icon8.png\" width=\"160\" height=\"160\" alt=\"8　働きがいも経済成長も\"></h5>\r\n<p>生産効率を改善する環境設計のサポート</p>\r\n<p>・<a href=\"https://rapidreport.systembase.co.jp/\" title=\"開発者のための帳票ツール RapidReport | 株式会社システムベース\" target=\"_blank\" rel=\"noopener\">開発者のための帳票ツール　RapidReport</a><br>\r\n・<a href=\"https://www.systembase.co.jp/service26/\" title=\"Telegno-SYS|生産管理で差がつく！気づきを与えるシステムで効率UP！\" target=\"_blank\" rel=\"noopener\">生産管理システム「Telegno-SYS」</a></p>\r\n<p>&nbsp;</p>\r\n<h5 id=\"sdgs9\" class=\"sdgs\"><img decoding=\"async\" src=\"https://www.systembase.co.jp/recruit/wp-content/uploads/2022/02/sdgs_icon9.png\" width=\"160\" height=\"160\" alt=\"9　産業と技術革新基礎をつくろう\"></h5>\r\n<p>インフラ構築によるDXの促進（ネットワーク構築サービス）</p>\r\n<p>&nbsp;</p>\r\n<h5 id=\"sdgs3\" class=\"sdgs\"><img loading=\"lazy\" decoding=\"async\" src=\"https://www.systembase.co.jp/recruit/wp-content/uploads/2022/02/sdgs_icon3.png\" width=\"160\" height=\"160\" alt=\"3　すべての人に健康と福祉を\"></h5>\r\n<p>医療関連システムの販売・導入（電子カルテシステム・介護事業者支援システム）</p>\r\n<p>&nbsp;</p>\r\n<h5>【企業活動を通じたSDGｓへの取組】</h5>\r\n<p><strong>働きがいのある職場</strong></p>\r\n<p>&nbsp;</p>\r\n<h5 id=\"sdgs3\" class=\"sdgs\"><img loading=\"lazy\" decoding=\"async\" src=\"https://www.systembase.co.jp/recruit/wp-content/uploads/2022/02/sdgs_icon3.png\" width=\"160\" height=\"160\" alt=\"3　すべての人に健康と福祉を\"> <img decoding=\"async\" src=\"https://www.systembase.co.jp/recruit/wp-content/uploads/2022/02/sdgs_icon8.png\" width=\"160\" height=\"160\" alt=\"8　働きがいも経済成長も\"></h5>\r\n<p>いわて健康経営宣言企業<br>\r\n残業削減（目標ゼロ）活動の取組<br>\r\n女性の育児休暇取得率100％　復帰100％　継続中<br>\r\nいわて働き方改革AWARDエントリー<br>\r\n若者応援企業宣言</p>\r\n</div>\r\n</article>\r\n</section>\t\t\t\t\t\t\t</main>\n\n<p class=\"gotop\"><a href=\"#\">▲&nbsp;UP</a></p>\n<footer>\n\t<nav id=\"fnav\" class=\"clearfix\">\n\t\t<ul>\n\t\t\t<li><a href=\"https://www.systembase.co.jp/about/privacy/\" title=\"個人情報保護方針\">→個人情報保護方針</a></li>\n\t\t\t<li><a href=\"https://www.systembase.co.jp/about/security/\" title=\"情報セキュリティ基本方針\">→情報セキュリティ基本方針</a></li>\n\t\t</ul>\n\t</nav>\n\t<div id=\"copyright\">&copy; SystemBase all rights reserved.</div>\n</footer>\n</body>\n</html>","finalUrl":"https://www.systembase.co.jp/recruit/recruit1/","rendered":false,"_cachedAt":"2026-06-23T20:58:52.269Z"}