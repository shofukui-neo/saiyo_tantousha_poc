"stylesheet\"><!-- Google tag (gtag.js) -->\n    <script async src=\"https://www.googletagmanager.com/gtag/js?id=G-29SHHWMP7N\"></script>\n    <script>\n    \twindow.dataLayer = window.dataLayer || [];\n    \tfunction gtag(){dataLayer.push(arguments);}\n    \tgtag('js', new Date());\n    \n    \tgtag('config', 'G-29SHHWMP7N');\n    </script>\n  </head>\n  <body class=\"pg_career\" id=\"top\">\n    <div class=\"ly_wrapper\" id=\"ly_wrapper\">\n      <header class=\"ly_header\" id=\"ly_header\">\n        <div class=\"ly_header_inner\">\n          <div class=\"ly_header_head\">\n            <p class=\"logo\"><a href=\"../\"><img src=\"../assets/images/common/logo.svg\" alt=\"岩谷瓦斯株式会社\" width=\"200\" height=\"46\" loading=\"lazy\"></a></p>\n            <button class=\"hamBtn\"><span class=\"icon\"></span></button>\n          </div>\n          <div class=\"ly_header_body\">\n            <div class=\"inner\">\n              <nav class=\"mainNav\">\n                <ul>\n                  <li class=\"withChild is-open\">\n                    <button class=\"parent\"><span>事業紹介</span><span class=\"icon\"></span></button>\n                    <nav class=\"childNav business\">\n                      <div class=\"childNav_inner\">\n                        <div class=\"childNav_head\"><a href=\"../business/\">\n                            <article>\n                              <div class=\"thumb\"><img src=\"../images/index/business_gas_mv_01.jpg\" alt=\"事業紹介TOP\" width=\"792\" height=\"664\" loading=\"lazy\">\n                              </div>\n                              <h2 class=\"title\"><span class=\"main\" lang=\"en\">Business</span><span class=\"sub\">事業紹介</span></h2><span class=\"el_circle\"></span>\n                            </article></a></div>\n                        <nav class=\"childNav_body\">\n                          <ul>\n                            <li>\n                              <div class=\"childNav_hdg\"><a href=\"../business/gas/\">\n      