{"url":"https://www.neco-net.co.jp/people/interview02/index.html","html":"<!doctype html>\n<html lang=\"ja\">\n<head>\n<title>東海事業所 トリチウム研グループ所属｜NECOの仲間｜原子力エンジニアリング株式会社</title>\n<meta name=\"description\" content=\"原子力関連施設において、試験研究炉、核燃料取扱施設、核融合装置など、施設の運転保守管理業務、それら施設に設置される、さまざまな実験・試験装置を使用した研究開発の支援業務や廃棄物管理業務などを通じて、原子力の研究開発の土台を支える業務を行っています。\">\n<meta name=\"keywords\" content=\"原子力,エネルギー,環境,研究,開発,原子力発電所,エネルギー環境,実験,試験,放射性,廃棄物,点検,検査,原子力エンジニアリング\">\n\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<meta name=\"format-detection\" content=\"telephone=no\">\n\n<meta property=\"og:type\" content=\"article\">\n<meta property=\"og:title\" content=\"東海事業所 トリチウム研グループ所属｜NECOの仲間｜原子力エンジニアリング株式会社\">\n<meta property=\"og:description\" content=\"原子力関連施設において、試験研究炉、核燃料取扱施設、核融合装置など、施設の運転保守管理業務、それら施設に設置される、さまざまな実験・試験装置を使用した研究開発の支援業務や廃棄物管理業務などを通じて、原子力の研究開発の土台を支える業務を行っています。\">\n<meta property=\"og:site_name\" content=\"原子力エンジニアリング株式会社\">\n<meta property=\"og:url\" content=\"https://www.neco-net.co.jp/people/interview02/\">\n<meta property=\"og:image\" content=\"https://www.neco-net.co.jp/ogp.jpg\">\n<link rel=\"stylesheet\" href=\"../../css/import.css\">\n<link rel=\"icon\" type=\"image/svg+xml\" href=\"../../favicon.svg\" />\n<link rel=\"icon\" type=\"image/vnd.microsoft.icon\" href=\"../../favicon.png\" />\n<link rel=\"apple-touch-icon\" href=\"../../apple-touch-icon.png\">\n\n<script src=\"../../js/jquery-1.7.2.min.js\" type=\"text/javascript\"></script>\n<script src=\"../../js/viewport.js\" type=\"text/javascript\"></script>\n<script src=\"../../js/hover.js\" type=\"text/javascript\"></script>\n<script src=\"../../js/menu.js\" type=\"text/javascript\"></script>\n<script src=\"../../js/inview.js\" type=\"text/javascript\"></script>\n<script src=\"../../js/inview_op.js\" type=\"text/javascript\"></script>\n<script src=\"../../js/smaller.js\" type=\"text/javascript\"></script>\n<script src=\"../../js/scroll.js\" type=\"text/javascript\"></script>\n<script src=\"../../js/ScrollTrigger.min.js\" type=\"text/javascript\"></script>\n<script src=\"../../js/jquery.easing.1.3.js\" type=\"text/javascript\"></script>\n\t\n<!-- Googleアナリティクス開始【原子力エンジニアリング株式会社】 -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-CW27MV4TRW\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'G-CW27MV4TRW');\n</script>\n<!-- Googleアナリティクス終了【原子力エンジニアリング株式会社】 -->\n</head>\n\n<body id=\"people\" class=\"interview\">\n<header>\n<div id=\"menu\">\n<div class=\"header_nav\">\n<div class=\"flex\">\n<a href=\"../../index.html\" class=\"logo\"><img src=\"../../images/logo.svg\" alt=\"原子力エンジニアリング株式会社\" width=\"379\" height=\"48\"></a>\n<a href=\"../../index.html\" class=\"logo_short\"><img src=\"../../images/logo_short.svg\" alt=\"原子力エンジニアリング株式会社\" width=\"266\" height=\"48\"></a>\n<a href=\"../../index.html\" class=\"logo_icon\"><img src=\"../../images/logo_icon.svg\" alt=\"原子力エンジニアリング株式会社\" width=\"60\" height=\"48\"></a>\n<div>\n<nav class=\"global_nav\">\n<ul>\n<li><a href=\"../../about/index.html\">NECOについて</a></li>\n<li><a href=\"../../works/index.html\">私たちの仕事</a></li>\n<li><a href=\"../../people/index.html\">NECOの仲間</a></li>\n<li><a href=\"../../career_formation/index.html\">キャリア形成</a></li>\n<li><a href=\"../../benefit/index.html\">環境と制度</a></li>\n<li><a href=\"../../recruit/index.html\">採用情報</a></li>\n<li class=\"contact\"><a href=\"../../contact/index.html\"><span>お問い合わせ</span></a></li>\n</ul>\n</nav>\n<!-- /global_nav -->\n</div>\n</div>\n<!-- /flex -->\n</div>\n<!-- /header_nav -->\n</div>\n<!-- /menu -->\n\t\n<nav class=\"floating_contact\">\n<ul class=\"flex\">\n<li><a href=\"../../recruit/index.html#entry\">採用エントリー</a></li>\n<li><a href=\"../../recruit/index.html#requirements\">募集要項</a></li>\n</ul>\n</nav>\n<!-- /floating_contact -->\n\n<div class=\"global_nav_sp\">\n<div class=\"menu\">\n<a href=\"../../index.html\" class=\"logo_sp\"><img src=\"../../images/logo.svg\" alt=\"原子力エンジニアリング株式会社\"></a>\n<div class=\"toggle\">\n<div class=\"bar top\"></div>\n<div class=\"bar middle\"></div>\n<div class=\"bar bottom\"></div>\n</div>\n<!-- /toggle -->\n<nav class=\"menu_sp\">\n<ul>\n<li><a href=\"../../about/index.html\">NECOについて</a></li>\n<li><a href=\"../../works/index.html\">私たちの仕事</a></li>\n<li><a href=\"../../people/index.html\">NECOの仲間</a></li>\n<li><a href=\"../../career_formation/index.html\">キャリア形成</a></li>\n<li><a href=\"../../benefit/index.html\">環境と制度</a></li>\n<li><a href=\"../../recruit/index.html\">採用情報</a></li>\n<li class=\"contact\"><a href=\"../../contact/index.html\">お問い合わせ</a></li>\n</ul>\n</nav>\n</div>\n<!-- /menu -->\n</div>\n<!-- /global_nav_sp -->\n</header>\n\n\n<div class=\"mainvisual\">\n<div class=\"inner\">\n<ul>\n    <li>\n        <picture>\n        <img src=\"../../images/entry_title/bg_title_people.jpg\" alt=\"\" width=\"1680\" height=\"750\">\n        </picture>\n    </li>\n</ul>\n</div>\n<!-- /inner -->\n<div class=\"wrap\">\n    <h1><a href=\"../index.html\"><span>NECOの仲間</span>PEOPLE</a></h1>\n    <img src=\"../../images/entry_title/deco/people.png\" alt=\"\" width=\"361\" height=\"195\">\n</div>\n<nav class=\"bread clearfix\">\n<ol>\n    <li><a href=\"../../index.html\">HOME</a></li>\n    <li><a href=\"../index.html\">NECOの仲間</a></li>\n\t<li>東海事業所 トリチウム研グループ所属</li>\n</ol>\n</nav>\n<!-- /bread -->\n</div>\n<!-- /mainvisual -->\n\n\n<main>\n<section class=\"intro_box\">\n<div class=\"flex_box\">\n    <div class=\"column_set\">\n        <div class=\"column2 pic\">\n            <img src=\"images/main.jpg\" alt=\"\" width=\"600\" height=\"387\">\n        </div>\n    <div class=\"column2 text\">\n<p class=\"name animated\" data-scroll=\"once toggle(.fadeIn, .invisible) addHeight\"><span class=\"assignment\">東海事業所 トリチウム研グループ所属</span></p>\n<p class=\"txtC\">工業高等学校出身<br class=\"sp\"> 2017年入社</p>\n<p class=\"comment txtC\">新エネルギーの開発をサポートする仕事です。</p>\n</div>\n</div>\n<!-- /column_set -->\n</div>\n</section>\n<!-- /intro_box -->\n\n\n<div id=\"contents\">\n<section class=\"adjust_group\">\n<div class=\"inner\">\n<h3>入社を決めた理由を教えてください。</h3>\n<div class=\"wrap clearfix\">\n    <p><img src=\"images/image01.jpg\" alt=\"\" width=\"450\" height=\"300\" class=\"floatL\">特に原子力関係で働こうと思っていたわけではありません。どの会社に就職しようか悩んでいたときに、この会社で働く兄が勧めてくれたのが入社を決めた直接のきっかけです。だから、核に関する知識もまったく無く、どんな仕事をしているのか想像もつかない状態でした。</p>\n\t<p>そこで事前に行われていた会社見学会に参加。具体的な仕事内容までは把握できませんでしたが、働いている方々がとても優しそうで、この環境なら自分も続けられそうだと感じたことが最終的な決め手になりました。</p>\n</div>\n\n<h3>核を扱う不安はありませんでしたか？</h3>\n<div class=\"wrap clearfix\">\n    <p><img src=\"images/image02.jpg\" alt=\"\" width=\"450\" height=\"300\" class=\"floatR\">福島の第一原子力発電の事故などを見ると、危険な仕事なのではないかと思われる方も少なくないと思います。私も、まったく不安が無かったわけではありません。でも、会社見学のときに説明を受け、安全に配慮して作業を行えば決して危険ではないことを知りました。</p>\n    <p>実際に仕事に就いてからも、決められた手順に従い安全を確認しながら作業すれば、何も問題ないことを実感しています。ただ、これはどんな仕事も同じですが、適度な緊張感は必要ですね。</p>\n</div>\n\n<h3>実際に行っている仕事内容を教えてください。</h3>\n<div class=\"wrap clearfix\">\n    <p><img src=\"images/image03.jpg\" alt=\"\" width=\"450\" height=\"300\" class=\"floatL\">トリチウム研グループに所属し、内装設備の運転や保守管理などを行っています。私が担当する施設ではトリチウムを扱った実験などが行われているのですが、その実験が滞りなく安全に進められるようお手伝いをする仕事です。</p>\n\t<p>具体的には、建屋内にある管理区域内で発生する放射性廃棄物の保管・搬出作業、実験などで発生したトリチウム廃液の処理作業など。また、内装設備の日常点検やデータの整理、記録作業、図面の作成、設備の解体作業をお手伝いすることもあります。</p>\n</div>\n\t\n<h3>仕事のやりがいを教えてください。</h3>\n<div class=\"wrap clearfix\">\n    <p><img src=\"images/image04.jpg\" alt=\"\" width=\"450\" height=\"300\" class=\"floatR\">新しいエネルギーを作り出そうと頑張っている研究者の、お手伝いができることは大きなやりがいにつながっています。また、少しずつ仕事を覚え、自分の成長につながっていることを実感できるのも嬉しいですね。基本的にチームで仕事を行っているので、分からないことがあればすぐに教えていただけます。</p>\n\t<p>まだまだ勉強しなくちゃいけない事が沢山あるので、早く多くの仕事を完璧にこなせるようになりたいですね。</p>\n</div>\n\t\n<h3>就職を考えている方にアドバイスをお願いします。</h3>\n<div class=\"wrap clearfix\">\n    <p><img src=\"images/image05.jpg\" alt=\"\" width=\"450\" height=\"300\" class=\"floatL\">専門的な仕事なので、自分にできるかどうか不安な方もいると思います。必要となる資格も多く、私も危険物取扱主任者乙種・2類・4類をはじめ7種類の資格を取得しています。大変そうですが、会社が資格取得のバックアップ体制を整えてくれるので大丈夫。働きながら資格を取得することができます。</p>\n\t<p>また、新入社員のための独り立ちプログラムやNECOテクニカルスクールなどで分野別の基礎知識も習得できるので、やる気さえあれば、理系、文系を問わず活躍できます。ぜひ、私たちと一緒に頑張りましょう！</p>\n</div>\n\n\n<div class=\"contents_sub_navi\">\n<dl>\n<dt><a href=\"../../people/index.html\">NECOの仲間</a></dt>\n<dd>\n<ul class=\"row2\">\n<li><a href=\"../../people/interview01/index.html\">東海事業所　事業管理部　事業管理第3課所属<span class=\"pc\">／</span><br class=\"sp\"></a></li>\n<li class=\"act\"><a href=\"../../people/interview02/index.html\">東海事業所 トリチウム研グループ所属<span class=\"pc\">／</span><br class=\"sp\"></a></li>\n<li><a href=\"../../people/interview03/index.html\">東海事業所 焼却処理グループ所属<span class=\"pc\">／</span><br class=\"sp\"></a></li>\n<li><a href=\"../../people/interview04/index.html\">技術営業部 営業課所属<span class=\"pc\">／</span><br class=\"sp\"></a></li>\n</ul>\n</dd>\n</dl>\n</div>\n<!-- /contents_sub_navi -->\n</div>\n<!-- /inner -->\n</section>\n<!-- /adjust_group -->\n\n</div>\n<!-- contents -->\n</main>\n\n\n<footer>\n<div class=\"inner\">\n<nav class=\"footer_area_nav sp\">\n<ul>\n<li><a href=\"../../about/index.html\">NECOについて</a></li>\n<li><a href=\"../../works/index.html\">私たちの仕事</a></li>\n<li><a href=\"../../people/index.html\">NECOの仲間</a></li>\n<li><a href=\"../../career_formation/index.html\">キャリア形成</a></li>\n<li><a href=\"../../benefit/index.html\">環境と制度</a></li>\n<li><a href=\"../../recruit/index.html\">採用情報</a></li>\n<li><a href=\"../../privacy/index.html\">プライバシーポリシー</a></li>\n<li><a href=\"../../contact/index.html\">お問い合わせ</a></li>\n<li><a href=\"../../sitemap/index.html\">サイトマップ</a></li>\n</ul>\n</nav>\n<!-- /footer_area_nav -->\n<div class=\"vcard_area\">\n    <div class=\"fn org\"><a href=\"../../index.html\"><img src=\"../../images/logo.svg\" alt=\"原子力エンジニアリング株式会社\" class=\"footer_logo\"></a></div>\n    <dl class=\"flex\">\n        <dt>本社</dt>\n        <dd class=\"adr\">\n            <span class=\"postal-code\">〒319-1112</span><span class=\"region\">茨城県</span><span class=\"locality\">那珂郡東海村</span><span class=\"street-address\">村松字平原3129-29</span>\n            <br>\n            <span class=\"tel\"><span class=\"type\">TEL：</span><span class=\"value\">029-287-2828</span></span>/\n            <span class=\"fax\">\n                <span class=\"type\">FAX：</span><span class=\"value\">029-287-3399</span>\n            </span>\n        </dd>\n    </dl>\n</div>\n<!-- /vcard_area -->\n</div>\n<!-- /inner -->\n\n<div class=\"footer_area_nav pc\">\n<div class=\"inner\">\n<ul class=\"flex\">\n<li><a href=\"../../privacy/index.html\">プライバシーポリシー</a></li>\n<li><a href=\"../../contact/index.html\">お問い合わせ</a></li>\n<li><a href=\"../../sitemap/index.html\">サイトマップ</a></li>\n</ul>\n<div class=\"copyright\">\n<small >Copyright Nuclear Engineering Co.,Ltd. All Rights Reserved.</small>\n</div>\n</div>\n<!-- /inner -->\n</div>\n<!-- /footer_area_nav -->\n\n<div class=\"copyright sp\">\n    <small >Copyright Nuclear Engineering Co.,Ltd. All Rights Reserved.</small>\n</div>\n</footer>\n\n\n<nav class=\"floating_menu sp\">\n<ul>\n<!--<li class=\"contact full\"><a href=\"../../contact/index.html\">お問い合わせ</a></li>-->\n<li class=\"entry\"><a href=\"../../recruit/index.html#entry\">採用エントリー</a></li>\n<li class=\"requirements\"><a href=\"../../recruit/index.html#requirements\">募集要項</a></li>\n</ul>\n</nav>\n\n\n</body>\n</html>\n","finalUrl":"https://www.neco-net.co.jp/people/interview02/","rendered":false,"_cachedAt":"2026-06-22T16:48:23.857Z"}