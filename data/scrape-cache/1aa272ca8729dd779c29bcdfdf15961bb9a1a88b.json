{"url":"https://rococoweb.co.jp/recruit/","html":"<!DOCTYPE html>\r\n<html class=\"no-js\" lang=\"ja\">\r\n  <head>\r\n    <meta charset=\"UTF-8\" />\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\r\n    <link rel=\"profile\" href=\"https://gmpg.org/xfn/11\" />\r\n    <title>採用情報 | ロココ</title>\r\n    <link rel=\"canonical\" href=\"https://rococoweb.co.jp/recruit/\" />\r\n    <script type=\"text/javascript\">\r\n      window.ga =\r\n        window.ga ||\r\n        function () {\r\n          (ga.q = ga.q || []).push(arguments);\r\n        };\r\n      ga.l = +new Date();\r\n      ga(\"create\", \"UA-164909322-1\", \"auto\");\r\n      // Plugins\r\n      ga(\"require\", \"outboundLinkTracker\");\r\n      ga(\"send\", \"pageview\");\r\n    </script>\r\n    <script async src=\"https://www.google-analytics.com/analytics.js\"></script>\r\n    <link rel=\"stylesheet\" href=\"../css/contact.css\" media=\"all\" />\r\n    <link\r\n      rel=\"stylesheet\"\r\n      id=\"parent-style-css\"\r\n      href=\"../css/style.css\"\r\n      media=\"all\"\r\n    />\r\n    <link\r\n      rel=\"stylesheet\"\r\n      id=\"twentytwenty-style-css\"\r\n      href=\"../css/child-style.css\"\r\n      media=\"all\"\r\n    />\r\n    <style id=\"custom-background-css\">\r\n      body.custom-background {\r\n        background-color: #ffffff;\r\n      }\r\n    </style>\r\n    <script src=\"../js/jquery-3.7.0.min.js\"></script>\r\n    <script\r\n      src=\"https://www.googletagmanager.com/gtag/js?id=UA-164909322-1\"\r\n      async\r\n    ></script>\r\n    <script>\r\n      window.dataLayer = window.dataLayer || [];\r\n      function gtag() {\r\n        dataLayer.push(arguments);\r\n      }\r\n      gtag(\"js\", new Date());\r\n      gtag(\"config\", \"UA-164909322-1\", { anonymize_ip: true });\r\n    </script>\r\n    <link\r\n      rel=\"icon\"\r\n      href=\"../img/uploads/2020/04/cropped-icon-32x32.png\"\r\n      sizes=\"32x32\"\r\n    />\r\n    <link\r\n      r