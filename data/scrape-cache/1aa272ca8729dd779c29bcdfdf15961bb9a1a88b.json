"\r\n                    alt=\"株式会社ロココ\"\r\n                    srcset=\"\r\n                      ../img/uploads/2020/04/logo.png        426w,\r\n                      ../img/uploads/2020/04/logo-300x59.png 300w\r\n                    \"\r\n                    sizes=\"(max-width: 426px) 100vw, 426px\" /></a\r\n                ><span class=\"screen-reader-text\">ロココ</span>\r\n              </div>\r\n            </div>\r\n            <!-- .header-titles -->\r\n            <!--　モバイル用ハンバーガー　-->\r\n            <!--\r\n\t\t\t\t\t\t<button class=\"toggle nav-toggle mobile-nav-toggle\" data-toggle-target=\".menu-modal\"  data-toggle-body-class=\"showing-menu-modal\" aria-expanded=\"false\" data-set-focus=\".close-nav-toggle\">\r\n\t\t\t\t\t\t\t<span class=\"toggle-inner\">\r\n\t\t\t\t\t\t\t\t<span class=\"toggle-icon\">\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t</span>\r\n\t\t\t\t\t\t\t\t<span class=\"toggle-text\"></span>\r\n\t\t\t\t\t\t\t</span>\r\n\t\t\t\t\t\t</button>\r\n-->\r\n            <!-- .nav-toggle -->\r\n          </div>\r\n          <!-- .header-titles-wrapper -->\r\n\r\n          <div class=\"header_recruite_navi\">\r\n            <nav>\r\n              <ul>\r\n                <li\r\n                  id=\"menu-item-63\"\r\n                  class=\"menu-item menu-item-type-custom menu-item-object-custom current-menu-item menu-item-63\"\r\n                >\r\n                  <a href=\"../recruit/#contact\" aria-current=\"page\"\r\n                    ><i class=\"far fa-envelope\"></i\r\n                  ></a>\r\n                </li>\r\n                <li\r\n                  id=\"menu-item-62\"\r\n                  class=\"menu-item menu-item-type-custom menu-item-object-custom current-menu-item menu-item-62\"\r\n                >\r\n                  <a href=\"../recruit/\" aria-current=\"page\"\r\n                    ><p class=\"header_square_recruit\">採用情報</p></a\r\n                  >\r\n                </li>\r\n              </ul>\r\n            </nav>\r\n          </div>\r\n        </div>\r\n      </div>\r\n      <!-- .header-inner -->\r\n    </header>\r\n    <!-- #site-header -->\r\n\r\n    <div\r\n      class=\"menu-modal cover-modal header-footer-group\"\r\n      data-modal-target-string=\".menu-modal\"\r\n    >\r\n      <div class=\"menu-modal-inner modal-inner\">\r\n        <div class=\"menu-wrapper section-inner\">\r\n          <div class=\"menu-top\">\r\n            <button\r\n              class=\"toggle close-nav-toggle fill-children-current-color\"\r\n              data-toggle-target=\".menu-modal\"\r\n              data-toggle-body-class=\"showing-menu-modal\"\r\n              aria-expanded=\"false\"\r\n              data-set-focus=\".menu-modal\"\r\n            >\r\n              <span class=\"toggle-text\">メニューを閉じる</span>\r\n              <svg\r\n                class=\"svg-icon\"\r\n                aria-hidden=\"true\"\r\n                role=\"img\"\r\n                focusable=\"false\"\r\n                xmlns=\"http://www.w3.org/2000/svg\"\r\n                width=\"16\"\r\n                height=\"16\"\r\n                viewBox=\"0 0 16 16\"\r\n              >\r\n                <polygon\r\n                  fill=\"\"\r\n                  fill-rule=\"evenodd\"\r\n                  points=\"6.852 7.649 .399 1.195 1.445 .149 7.899 6.602 14.352 .149 15.399 1.195 8.945 7.649 15.399 14.102 14.352 15.149 7.899 8.695 1.445 15.149 .399 14.102\"\r\n                />\r\n              </svg></button\r\n            ><!-- .nav-toggle -->\r\n\r\n            <nav class=\"mobile-menu\" aria-label=\"モバイル\" role=\"navigation\">\r\n              <ul class=\"modal-menu reset-list-style\">\r\n                <li\r\n                  id=\"menu-item-73\"\r\n                  class=\"menu-item menu-item-type-custom menu-item-object-custom menu-item-73\"\r\n                >\r\n                  <div class=\"ancestor-wrapper\">\r\n                    <a href=\"../#about\">私たちについて</a>\r\n                  </div>\r\n                  <!-- .ancestor-wrapper -->\r\n                </li>\r\n                <li\r\n                  id=\"menu-item-74\"\r\n                  class=\"menu-item menu-item-type-custom menu-item-object-custom menu-item-74\"\r\n                >\r\n                  <div class=\"ancestor-wrapper\">\r\n                    <a href=\"../#message\">ヒストリー</a>\r\n                  </div>\r\n                  <!-- .ancestor-wrapper -->\r\n                </li>\r\n                <li\r\n                  id=\"menu-item-75\"\r\n                  class=\"menu-item menu-item-type-custom menu-item-object-custom menu-item-75\"\r\n                >\r\n                  <div class=\"ancestor-wrapper\">\r\n                    <a href=\"../#company_overview\">会社概要</a>\r\n                  </div>\r\n                  <!-- .ancestor-wrapper -->\r\n                </li>\r\n                <li\r\n                  id=\"menu-item-76\"\r\n                  class=\"menu-item menu-item-type-custom menu-item-object-custom menu-item-76\"\r\n                >\r\n                  <div class=\"ancestor-wrapper\">\r\n                    <a href=\"../#access\">アクセス</a>\r\n                  </div>\r\n                  <!-- .ancestor-wrapper -->\r\n                </li>\r\n              </ul>\r\n            </nav>\r\n          </div>\r\n          <!-- .menu-top -->\r\n\r\n          <div class=\"menu-bottom\"></div>\r\n          <!-- .menu-bottom -->\r\n        </div>\r\n        <!-- .menu-wrapper -->\r\n      </div>\r\n      <!-- .menu-modal-inner -->\r\n    </div>\r\n    <!-- .menu-modal -->\r\n\r\n    <main id=\"site-content\" role=\"main\">\r\n      <ul id=\"recruit_mv\">\r\n        <a href=\"../recruit/#recruit_message\">\r\n          <li>\r\n            <img src=\"../img/recruit/mv/1.jpg\" alt=\"\" />\r\n            <p>メッセージ</p>\r\n          </li>\r\n        </a>\r\n        <a href=\"#job\">\r\n          <li>\r\n            <img src=\"../img/recruit/mv/2.jpg\" alt=\"\" />\r\n            <p>職種</p>\r\n          </li>\r\n        </a>\r\n        <a href=\"#activity\">\r\n          <li>\r\n            <img src=\"../img/recruit/mv/3.jpg\" alt=\"\" />\r\n            <p>社内活動</p>\r\n          </li>\r\n        </a>\r\n      </ul>\r\n\r\n      <nav id=\"recruit_nav\">\r\n        <ul>\r\n          <li>\r\n            <a href=\"../recruit/#recruit_mv\"\r\n              ><span></span><span>採用TOP</span></a\r\n            >\r\n          </li>\r\n          <li>\r\n            <a href=\"../recruit/#job\"><span>1.</span><span>仕事内容</span></a>\r\n          </li>\r\n          <li>\r\n            <a href=\"../recruit/#plan\"><span>2.</span><span>成長計画</span></a>\r\n          </li>\r\n          <li>\r\n            <a href=\"../recruit/#activity\"\r\n              ><span>3.</span><span>社内活動</span></a\r\n            >\r\n          </li>\r\n        </ul>\r\n      </nav>\r\n\r\n      <p class=\"recruit_top_link\">\r\n        <a href=\"../entry/\" target=\"_blank\">\r\n          募集要項<i class=\"fas fa-chevron-circle-right\"></i>\r\n        </a>\r\n      </p>\r\n\r\n      <section id=\"recruit_message\">\r\n        <hr />\r\n        <p class=\"sub_title\">採用に向けたメッセージ</p>\r\n        <p id=\"recruit_message_sentence\">\r\n          私たちの企業理念は『人を魅力的にする』ことです。<br />\r\n          <br />\r\n          これは関わる全ての人々を指しており、お客様、お取引先、働く仲間そしてその家族をより魅力的にしていくという理念です。<br />\r\n          <br />\r\n          それを実現していくためには、関わる全ての人々と共に私たちが魅力的になることが求められます。<br />\r\n          全社員が成長していくことを最も大切にしたいと思っています。\r\n        </p>\r\n      </section>\r\n\r\n      <section id=\"recruit_vision\">\r\n        <hr />\r\n        <p class=\"sub_title\">企業理念</p>\r\n        <div class=\"slogan\"><span>人を魅力的にする</span></div>\r\n        <div class=\"recruit_vision_visual\">\r\n          <div>ビジョン</div>\r\n          <p class=\"italic\">\r\n            The world where self-actualization<br />is possible.\r\n          </p>\r\n          <p>自己実現できる世界</p>\r\n        </div>\r\n        <hr id=\"vision_line\" />\r\n        <p class=\"recruit_vision_txt\">\r\n          私たちは、関わる全ての人々がより魅力的になる世界を目指しています。<br /><br />\r\n          関わりのある全ての人々、お客様やお取引先、そしてその周囲の人々をより魅力的にします。<br /><br />\r\n          人々をより魅力的にできるように、我々がまず「自己実現できる世界」を目指しています。<br />「自分のしたいこと＝社会貢献」が実現可能な組織。<br /><br />\r\n          私たちは、常に魅力的であるために、楽しみ、学び、成長しながら進みます。\r\n        </p>\r\n        <div class=\"more_button\">\r\n          <a href=\"../philosophy/\"\r\n            >もっと詳しく見る<i class=\"fas fa-chevron-circle-right\"></i\r\n          ></a>\r\n        </div>\r\n      </section>\r\n\r\n      <section id=\"recruit_givetake\">\r\n        <hr />\r\n        <p class=\"sub_title\">私たちが求める人物像</p>\r\n        <ul>\r\n          <li>\r\n            <i class=\"fas fa-people-carry\"></i>\r\n            <p class=\"givetake_title\"><span>利他精神</span></p>\r\n            <p class=\"givetake_txt\">\r\n              お客様をはじめ、取引先様やロココの仲間にも喜んで頂けるように、自分本位ではなく他者の利益のための献身的な行動を重んじています。\r\n            </p>\r\n          </li>\r\n          <li>\r\n            <i class=\"fas fa-user\"></i>\r\n            <p class=\"givetake_title\"><span>主体性</span></p>\r\n            <p class=\"givetake_txt\">\r\n              全ての事を「自分事」として捉えて、行動できる方に活躍して頂きたいと考えています。<br />\r\n              目的達成のために自ら考えて行動することを期待しています。\r\n            </p>\r\n          </li>\r\n          <li>\r\n            <i class=\"fas fa-walking\"></i>\r\n            <p class=\"givetake_title\"><span>成長意欲</span></p>\r\n            <p class=\"givetake_txt\">\r\n              自身の掲げる目標や、会社の目指すゴールに向かって成長する意欲を大切にしています。<br />\r\n              あなたの人としての成長が、ビジネスの原動力になると考えて尊重しています。\r\n            </p>\r\n          </li>\r\n        </ul>\r\n        <hr id=\"givetake_line\" />\r\n        <hr />\r\n        <p class=\"sub_title\">私たちが与えられる価値</p>\r\n        <ul style=\"margin-bottom: 0\">\r\n          <li>\r\n            <i class=\"fas fa-star\"></i>\r\n            <p class=\"givetake_title\"><span>評価と昇給</span></p>\r\n            <p class=\"givetake_txt\">\r\n              貢献シートを半期ごと更新し、そのシートの貢献内容をもとに「自己申告」で給与決めていきます。\r\n            </p>\r\n          </li>\r\n          <li>\r\n            <i class=\"far fa-calendar-alt\"></i>\r\n            <p class=\"givetake_title\"><span>柔軟な働き方</span></p>\r\n            <p class=\"givetake_txt\">\r\n              一定の基準はありますが、各個人の状況や要望に応じて、様々な働き方を模索しています。<br />\r\n              それぞれが方向性をしっかり持てば、やり方はフレックスが身上です。\r\n            </p>\r\n          </li>\r\n          <li>\r\n            <i class=\"fas fa-pencil-ruler\"></i>\r\n            <p class=\"givetake_title\"><span>会社づくりへ参画</span></p>\r\n            <p class=\"givetake_txt\">\r\n              まだまだ発展途上の会社であるため、会社のルールや制度など多方面で会社づくりに参画できます。<br />\r\n              より充実した環境を共に目指しましょう。\r\n            </p>\r\n          </li>\r\n        </ul>\r\n        <ul style=\"margin-top: 0\">\r\n          <li>\r\n            <i class=\"fas fa-chart-line\"></i>\r\n            <p class=\"givetake_title\"><span>失敗できる環境</span></p>\r\n            <p class=\"givetake_txt\">\r\n              私たちは「やってみる」ことを大切にしています。失敗から学び、人は魅力的になっていきます。\r\n            </p>\r\n          </li>\r\n          <li>\r\n            <i class=\"fas fa-exchange-alt\"></i>\r\n            <p class=\"givetake_title\"><span>社内ジョブチェンジ</span></p>\r\n            <p class=\"givetake_txt\">\r\n              入社後にチームに信頼される、貢献できるようになれば、面談を通してジョブチェンジが可能です。\r\n            </p>\r\n          </li>\r\n          <li>\r\n            <i class=\"fas fa-user-friends\"></i>\r\n            <p class=\"givetake_title\"><span>充実したOJT</span></p>\r\n            <p class=\"givetake_txt\">\r\n              中途入社したメンバーはほぼ実務未経験から。未経験から大きな戦力となる過程を先輩が全力で伴走します。\r\n            </p>\r\n          </li>\r\n        </ul>\r\n        <hr id=\"givetake_line\" />\r\n      </section>\r\n\r\n      <section id=\"job\">\r\n        <div class=\"title\">\r\n          <div class=\"red_box\"><div class=\"white_box\"></div></div>\r\n          <p>About job</p>\r\n        </div>\r\n        <h2>職種ごとの要項 / 特色</h2>\r\n        <dl id=\"job_wrap\">\r\n          <dt id=\"jyutyuu\" class=\"job_name\">\r\n            <i class=\"fas fa-headset\"></i\r\n            ><span>カスタマーリレーション（CR）部</span\r\n            ><i class=\"fas fa-chevron-down down-arrow\"></i>\r\n          </dt>\r\n          <dd class=\"job_body\">\r\n            <div class=\"job_main_img\">\r\n              <img src=\"../img/recruit/job/jyutyuu.jpg\" />\r\n            </div>\r\n            <p class=\"job_copy\">\r\n              ネット<!--通販-->の不安を解消し、お客様に寄り添いたい\r\n            </p>\r\n            <div class=\"job_other_wrap\">\r\n              <ul class=\"job_other_img\">\r\n                <li>\r\n                  <img src=\"../img/recruit/job/j2.jpg\" />\r\n                </li>\r\n                <li>\r\n                  <img src=\"../img/recruit/job/j3.jpg\" />\r\n                </li>\r\n                <li>\r\n                  <img src=\"../img/recruit/job/j4.jpg\" />\r\n                </li>\r\n              </ul>\r\n            </div>\r\n            <p class=\"job_title\">\r\n              <i class=\"fas fa-edit\"></i\r\n              ><span>カスタマーリレーション（CR）部</span>\r\n            </p>\r\n            <p class=\"job_txt\">\r\n              お客様に、商品だけではなく安心感と満足感をお届けすることが信念です。<br />\r\n              ご注文や商品についてのお問合せ対応を担当しており、直接お客様とお話しする機会もありますので会社の顔としての誠実な仕事が求められます。<br />\r\n              もっと簡単に便利に楽しく、たくさんのお客様に使ってもらえるサイトを目指して、いろんな意見やアイデアを出せるポジションです。例えば、レビューやアンケートよりいただいたご意見をアイデア化したり、受注業務を効率化するためのシステム導入など、さまざまな改善・新しい企画にチャレンジできます。<br />\r\n              自分の意見が採用され、アイデアが形となっていくやりがいを感じることができます。\r\n            </p>\r\n            <div class=\"job_menu\">\r\n              <div class=\"job_last_img\">\r\n                <img src=\"../img/recruit/job/j5.jpg\" />\r\n              </div>\r\n              <div>\r\n                <p class=\"job_menu_title\">主な業務内容</p>\r\n                <hr />\r\n                <ul>\r\n                  <li>受注手配、お問い合わせ対応（TEL・メール）</li>\r\n                  <li>配送体制の構築・改善</li>\r\n                  <li>各メーカーへの問い合わせ・修理対応</li>\r\n                  <li>キャンペーン・アンケート・SNSの企画・実施</li>\r\n                </ul>\r\n              </div>\r\n            </div>\r\n          </dd>\r\n\r\n          <dt id=\"shouhin_kikaku\" class=\"job_name\">\r\n            <i class=\"fas fa-tshirt\"></i\r\n            ><span>マーチャンダイジング（MD）部</span\r\n            ><i class=\"fas fa-chevron-down down-arrow\"></i>\r\n          </dt>\r\n          <dd class=\"job_body\">\r\n            <div class=\"job_main_img\">\r\n              <img src=\"../img/recruit/job/kikaku.jpg\" />\r\n            </div>\r\n            <p class=\"job_copy\">商品を通してお客様の魅力的な姿を想像して</p>\r\n            <div class=\"job_other_wrap\">\r\n              <ul class=\"job_other_img\">\r\n                <li>\r\n                  <img src=\"../img/recruit/job/kikaku2.jpg\" />\r\n                </li>\r\n                <li>\r\n                  <img src=\"../img/recruit/job/kikaku3.jpg\" />\r\n                </li>\r\n                <li>\r\n                  <img src=\"../img/recruit/job/kikaku4.jpg\" />\r\n                </li>\r\n              </ul>\r\n            </div>\r\n            <p class=\"job_title\">\r\n              <i class=\"fas fa-edit\"></i><span>商品管理の仕事について</span>\r\n            </p>\r\n            <p class=\"job_txt\">\r\n              10万点に及ぶ在庫の管理を主軸にお取引先様など社外の方との連携を行います。<br />\r\n              納品時の入庫処理と在庫データの登録・棚卸作業等の在庫管理作業が主軸です。商品が納品された後、撮影・WEBぺ―ジ作成など他部署の業務が円滑に進み、より早くお客様に新着商品をご紹介できるようスピーディーで正確な対応に努めています。<br />\r\n              お客様と直接的なやり取りはありませんが、お届けしたその先でお客様の喜ばれる姿を常に想像しながら取り組んでいます。\r\n            </p>\r\n            <p class=\"job_title\">\r\n              <i class=\"fas fa-edit\"></i><span>商品企画部の仕事について</span>\r\n            </p>\r\n            <p class=\"job_txt\">\r\n              オリジナル・別注商品の企画・提案・生産管理、セレクト商品のバイイング・取扱商品の新規開拓を行います。<br />\r\n              売上の推移や動向分析から販売計画の立案を担当するため、数字を読み解く力・時流を読む感覚が求められます。また、商品情報の社内共有を含め、お客様にご案内するスタッフへの服育活動も行うなど、アパレル知識と経験を活かした活動が多いです。<br />商品を0から企画していくため、社外の方と連携して進める業務も多く複数のプロジェクトが並行した状態で進みます。\r\n            </p>\r\n            <div class=\"job_menu\">\r\n              <div class=\"job_last_img\">\r\n                <img src=\"../img/recruit/job/kikaku5.jpg\" />\r\n              </div>\r\n              <div>\r\n                <p class=\"job_menu_title\">主な業務内容</p>\r\n                <hr />\r\n                <ul>\r\n                  <li>商品登録、商品の入庫作業、在庫管理</li>\r\n                  <li>商品仕入、企画、提案</li>\r\n                  <li>販売計画</li>\r\n                  <li>メーカー対応</li>\r\n                </ul>\r\n              </div>\r\n            </div>\r\n          </dd>\r\n\r\n          <dt id=\"camera\" class=\"job_name\">\r\n            <i class=\"fas fa-camera\"></i><span>撮影部</span\r\n            ><i class=\"fas fa-chevron-down down-arrow\"></i>\r\n          </dt>\r\n          <dd class=\"job_body\">\r\n            <div class=\"job_main_img\">\r\n              <img src=\"../img/recruit/job/camera.jpg\" />\r\n            </div>\r\n            <p class=\"job_copy\">\r\n              <!--1カットに-->みんなの想いをのせて、魅力あふれる1枚を\r\n            </p>\r\n            <div class=\"job_other_wrap\">\r\n              <ul class=\"job_other_img\">\r\n                <li>\r\n                  <img src=\"../img/recruit/job/c2.jpg\" />\r\n                </li>\r\n                <li>\r\n                  <img src=\"../img/recruit/job/c3.jpg\" />\r\n                </li>\r\n                <li>\r\n                  <img src=\"../img/recruit/job/c4.jpg\" />\r\n                </li>\r\n              </ul>\r\n            </div>\r\n            <p class=\"job_title\">\r\n              <i class=\"fas fa-edit\"></i><span>撮影部の仕事について</span>\r\n            </p>\r\n            <p class=\"job_txt\">\r\n              より商品の魅力を引き出すためのカメラワークやライティングを意識しています。<br />\r\n              スタジオ/ロケのモデル撮影だけでなく、細部までお客様に伝わるようアイテム撮影にも力を入れ、一瞬のアイキャッチでワクワクするような写真を追求しています。<br />\r\n              また、商品を分かりやすく伝えるために動画の作成にも注力しており、商品詳細を伝えるものとブランドイメージに沿ったイメージ動画なども作成しています。<br />日々表現力を培い、新たな手法への挑戦を試みています。\r\n            </p>\r\n            <div class=\"job_menu\">\r\n              <div class=\"job_last_img\">\r\n                <img src=\"../img/recruit/job/c5.jpg\" />\r\n              </div>\r\n              <div>\r\n                <p class=\"job_menu_title\">主な業務内容</p>\r\n                <hr />\r\n                <ul>\r\n                  <li>モデル着用写真撮影</li>\r\n                  <li>商品写真撮影</li>\r\n                  <li>撮影スケジュールの作成</li>\r\n                  <li>撮影画像の事務処理等</li>\r\n                  <li>ショールームの変更</li>\r\n                </ul>\r\n              </div>\r\n            </div>\r\n          </dd>\r\n          <dt id=\"web\" class=\"job_name\">\r\n            <i class=\"fas fa-laptop-code\"></i><span>WEB事業部</span\r\n            ><i class=\"fas fa-chevron-down down-arrow\"></i>\r\n          </dt>\r\n          <dd class=\"job_body\">\r\n            <div class=\"job_main_img\">\r\n              <img src=\"../img/recruit/job/web.jpg\" />\r\n            </div>\r\n            <p class=\"job_copy\">\r\n              <!--バックエンド-->最後方からサイトを通じて最新の情報をお届け\r\n            </p>\r\n            <div class=\"job_other_wrap\">\r\n              <ul class=\"job_other_img\">\r\n                <li>\r\n                  <img src=\"../img/recruit/job/w2.jpg\" />\r\n                </li>\r\n                <li>\r\n                  <img src=\"../img/recruit/job/w3.jpg\" />\r\n                </li>\r\n                <li>\r\n                  <img src=\"../img/recruit/job/w4.jpg\" />\r\n                </li>\r\n              </ul>\r\n            </div>\r\n            <p class=\"job_title\">\r\n              <i class=\"fas fa-edit\"></i><span>WEB事業部の仕事について</span>\r\n            </p>\r\n            <p class=\"job_txt\">\r\n              HTML / CSSをはじめとするWEBスキルを活かし、商品ページのデザイン /\r\n              コピーライティングなどセンスを磨きます。正確で丁寧な仕事を目指し、お客様とロココを繋いでいきます。\r\n            </p>\r\n            <div class=\"job_menu\">\r\n              <div class=\"job_last_img\">\r\n                <img src=\"../img/recruit/job/w5.jpg\" />\r\n              </div>\r\n              <div>\r\n                <p class=\"job_menu_title\">主な業務内容</p>\r\n                <hr />\r\n                <ul>\r\n                  <li>新商品のWEBサイトへのアップ</li>\r\n                  <li>各サイト毎のセール・イベントの実施</li>\r\n                  <li>特集ページ/コンテンツページの作成、更新</li>\r\n                  <li>アクセス数/売上動向の分析</li>\r\n                  <li>社内の販促物のデザイン</li>\r\n                </ul>\r\n              </div>\r\n            </div>\r\n          </dd>\r\n          <dt id=\"web\" class=\"job_name\">\r\n            <i class=\"fas fa-signal\"></i><span>マーケティング部</span\r\n            ><i class=\"fas fa-chevron-down down-arrow\"></i>\r\n          </dt>\r\n          <dd class=\"job_body\">\r\n            <div class=\"job_main_img\">\r\n              <img src=\"../img/recruit/job/marketing.jpg\" />\r\n            </div>\r\n            <p class=\"job_copy\">多くのお客様にリーチして、魅力的にする</p>\r\n            <div class=\"job_other_wrap\">\r\n              <ul class=\"job_other_img\">\r\n                <li>\r\n                  <img src=\"../img/recruit/job/marketing2.jpg\" />\r\n                </li>\r\n                <li>\r\n                  <img src=\"../img/recruit/job/marketing3.jpg\" />\r\n                </li>\r\n                <li>\r\n                  <img src=\"../img/recruit/job/marketing4.jpg\" />\r\n                </li>\r\n              </ul>\r\n            </div>\r\n            <p class=\"job_title\">\r\n              <i class=\"fas fa-edit\"></i\r\n              ><span>マーケティング部の仕事について</span>\r\n            </p>\r\n            <p class=\"job_txt\">\r\n              服が好きな多くのお客様に出会うことを目的として、PPC、リターゲティング、facebook、googleなどの広告運用を行います。<br />マーケティングは、変化の流れが早く常に動向をチェック。また日頃からアンテナを張って研鑽を積みます。<br />楽天やYahooなどモールサイト、自社サイトのイベントのスケジューリング。販売促進につながるイベントなどを企画します。また特別なコンテンツのページも自部署で作成も。デザイン関係もWEB部と共に行います。<br />会社経費、戦略コストを多く費やすため責任の大きな部署になります。\r\n            </p>\r\n            <div class=\"job_menu\">\r\n              <div class=\"job_last_img\">\r\n                <img src=\"../img/recruit/job/marketing5.jpg\" />\r\n              </div>\r\n              <div>\r\n                <p class=\"job_menu_title\">主な業務内容</p>\r\n                <hr />\r\n                <ul>\r\n                  <li>広告運用</li>\r\n                  <li>イベント企画管理</li>\r\n                  <li>コンテンツ作成</li>\r\n                  <li>WEBデザイン管理</li>\r\n                </ul>\r\n              </div>\r\n            </div>\r\n          </dd>\r\n        </dl>\r\n        <p class=\"recruit_top_link\">\r\n          <a href=\"../entry/\" target=\"_blank\">\r\n            募集要項<i class=\"fas fa-chevron-circle-right\"></i>\r\n          </a>\r\n        </p>\r\n      </section>\r\n\r\n      <section id=\"figures\">\r\n        <hr />\r\n        <p class=\"sub_title\">数字で見るロココ</p>\r\n        <ul>\r\n          <li>\r\n            <img src=\"../img/recruit/figure/1.jpg\" />\r\n          </li>\r\n          <li>\r\n            <img src=\"../img/recruit/figure/2.jpg\" />\r\n          </li>\r\n          <li>\r\n            <img src=\"../img/recruit/figure/3.jpg\" />\r\n          </li>\r\n          <li>\r\n            <img src=\"../img/recruit/figure/4.jpg\" />\r\n          </li>\r\n        </ul>\r\n      </section>\r\n\r\n      <section id=\"plan\">\r\n        <div class=\"title\">\r\n          <div class=\"red_box\"><div class=\"white_box\"></div></div>\r\n          <p>In-company system</p>\r\n        </div>\r\n        <h2>全社員成長計画</h2>\r\n\r\n        <hr />\r\n        <p class=\"title_team sub_title\">部署横断型のチーム制プロジェクト</p>\r\n        <p class=\"plan_txt\">\r\n          部署にかかわらず、事業提案や新たなコンテンツ作成など、社員の「挑戦したい」気持ちを後押しします。<br />\r\n          <br />\r\n          提案者を中心に部署横断型チームを結成、様々な角度から検証し、議題解決に向けキャリアや部署を超えてフラットな環境で取り組みます。<br />\r\n          <br />\r\n          所属部署だけではなく他部署との連携して取り組むことで、社内の様々な仕事の繋がりを体感し、多角的な視点を得ることも目的のひとつ。<br />\r\n          <br />\r\n          会社運営を自分事と捉え、自ら会社づくりに参画していく主体的な姿勢を推奨しています。\r\n        </p>\r\n        <hr class=\"plan_line\" />\r\n\r\n        <hr />\r\n        <p class=\"title_mokuhyou sub_title\">目標管理制度</p>\r\n        <p class=\"plan_txt\">\r\n          目標管理にはOKRを採用しています。会社全体で目指す目標値に対し、チームごとに業務の特色にあった半期の目標（O：Objectives）を自分たちで掲げ、達成基準となる成果（KR:Key\r\n          Results）を設定。<br />\r\n          <br />\r\n          会社全体、各チーム、個人で目指す道筋をブレなく明確にし、スケジュールを立てて日々の業務に落とし込みます。<br />\r\n          <br />\r\n          社内での自分の役割を明確に認識できるため、主体的に業務に取り掛かることができ個人としての達成意欲とチーム一丸となってチャレンジする協働意識を養います。<br />\r\n          <br />\r\n          また社内の各チームの情報共有を行う機会を設けることで、チームを越えて社内全体でサポートしあう環境づくりに努めています。\r\n        </p>\r\n        <hr class=\"plan_line\" />\r\n        <hr />\r\n        <p class=\"title_mokuhyou sub_title\">給与制度</p>\r\n        <p class=\"plan_txt\">\r\n          ノーレーティングによる自己申告型の給与制度。<br />\r\n          人事評価における、レーティング（点数づけやランクづけ）を廃止し、メンバーの自己申告から直属のマネージャーと面談で給与額の決定をしていきます。その後マネージャーからなる給与委員会にて最終決定。この制度は、Googleやマイクロソフト、IBMなどアメリカの複数の企業で採用されています。<br /><br />\r\n          期が始まる前に「貢献内容シート」を作成。シートに記載された貢献内容に対し、マネージャーはメンバーからの申告額に対し、投資としてその金額を決定します。半年の期間での貢献内容シートをもとに投資を行うので、メンバーとマネージャーはその投資に責任をもって取組みを行います。<br /><br />\r\n          従来の評価制度では、決められた項目や目に見える貢献に対しては評価されますが、その人のすべての評価ではありません。マネージャーとの面談を通して自己申告することにより、より広域な評価が可能となります。\r\n        </p>\r\n        <hr class=\"plan_line\" />\r\n        <hr />\r\n        <p class=\"title_team sub_title\">1on1 ミーティング</p>\r\n        <p class=\"plan_txt\">\r\n          上長との1on1ミーティングを推奨しており、業務や目標・評価についてだけではなく、幅広い議題で自由度の高いミーティングを実施しています。<br />\r\n          <br />\r\n          社内における疑問点の解消、個人目標や課題についてのフィードバックを得たり、上長とのコミュニケーション向上をはかり働きやすい環境を整えています。\r\n        </p>\r\n        <hr class=\"plan_line\" />\r\n\r\n        <!--\t\t\r\n\t\t\t<hr>\r\n\t\t\t<p class=\"sub_title\">座談会</p>\r\n\t\t\t<p class=\"plan_txt\">\r\n\t\t\t\t希望者による少人数制でディスカッションを行う会合です。<br>\r\n\t\t\t\t<br>\r\n\t\t\t\t業務や社内のことに限らず、自身のキャリアについてや疑問の解決、チーム内での課題などを持ち寄り話し合いを行います。<br>\r\n\t\t\t\t<br>\r\n\t\t\t\t 自らの意見を率直に発信する力、他者の意見を柔軟に受け入れる力を養います。<br>\r\n\t\t\t\t<br>\r\n\t\t\t\tまた働く中で生じるすれ違いやミスコミュニケーションを事前に防ぎ、自らの業務に前向きに取り組める環境づくりを目指します。\r\n\t\t\t</p>\r\n\t\t\t<hr class=\"plan_line\">\r\n-->\r\n\r\n        <hr />\r\n        <p class=\"title_bonus sub_title\">業績分配型賞与</p>\r\n        <p class=\"plan_txt\">\r\n          「みんなで稼いで、みんなで公平に分ける」をテーマに、業績と連動させて賞与を決定する制度です。<br />\r\n          <br />\r\n          2019年度より導入し、「年間賞与総額」を個人の「貢献率」に応じて算出するため、個人の成長と貢献がカギとなります。<br />\r\n          <br />\r\n          賞与をみんなと分配するため、会社の業績と自身の成長に、より一層の責任とやりがいをもって臨んでいただけます。\r\n        </p>\r\n        <hr class=\"plan_line\" />\r\n\r\n        <hr />\r\n        <p class=\"title_benefit sub_title\">アパレルならではの福利厚生</p>\r\n        <p class=\"plan_txt\">\r\n          ファッション好きにはありがたい「社内割引販売」や、スキルアップのための「書籍購入補助」「セミナー参加補助」、柔軟な働き方を応援する「半休制度」、「時短勤務制度」などがあります。<br />\r\n          <br />\r\n          現在あるものに限らず、「こういう制度が欲しい！」と提案することで、さらなる環境整備が行えます。\r\n        </p>\r\n        <hr class=\"plan_line\" />\r\n      </section>\r\n\r\n      <section id=\"activity\">\r\n        <div class=\"title\">\r\n          <div class=\"red_box\"><div class=\"white_box\"></div></div>\r\n          <p>Internal activities</p>\r\n        </div>\r\n        <h2>社内活動</h2>\r\n        <hr />\r\n        <p class=\"sub_title\">ワークショップ</p>\r\n        <p class=\"activity_title\">\r\n          プロジェクトチームで、会社のお金の流れを学ぶワークショップを行いました。実際に経営するためのお金の流れをゲーム形式で学びます。ミッションを達成すべくチームワークも必要となるため、普段の仕事では知らなかった仲間の新しい一面や強みを発見することも。\r\n        </p>\r\n        <div class=\"activity_img\">\r\n          <ul>\r\n            <li>\r\n              <img\r\n                src=\"../img/recruit/activity/worksession/worksession_1.jpg\"\r\n              />\r\n            </li>\r\n            <li>\r\n              <img\r\n                src=\"../img/recruit/activity/worksession/worksession_2.jpg\"\r\n              />\r\n            </li>\r\n            <li>\r\n              <img\r\n                src=\"../img/recruit/activity/worksession/worksession_3.jpg\"\r\n              />\r\n            </li>\r\n          </ul>\r\n        </div>\r\n        <p class=\"activity_txt\">\r\n          ワークショップ終了後には、チームごとで飲み会を開催して、より親睦を深めました！\r\n        </p>\r\n        <hr class=\"activity_line\" />\r\n\r\n        <hr />\r\n        <p class=\"sub_title bbq\">BBQ / 歓送迎会</p>\r\n        <p class=\"activity_title\">\r\n          大きなセールを乗り切った後に、達成と労いを分かち合うために打ち上げを行っています。<br />\r\n        </p>\r\n        <div class=\"activity_img\">\r\n          <ul>\r\n            <li>\r\n              <img src=\"../img/recruit/activity/party/1.jpg\" />\r\n            </li>\r\n            <li>\r\n              <img src=\"../img/recruit/activity/party/2.jpg\" />\r\n            </li>\r\n            <li>\r\n              <img src=\"../img/recruit/activity/party/3.jpg\" />\r\n            </li>\r\n          </ul>\r\n        </div>\r\n        <p class=\"activity_txt\">\r\n          堅苦しい席ではなく、それぞれが思い思いに楽しむ和気あいあいとした食事会です。食事会の日は全員で業務に取り組み、早めに退社。楽しむことに備えます。\r\n        </p>\r\n        <hr class=\"activity_line\" />\r\n      </section>\r\n      <section id=\"company_overview\">\r\n        <div class=\"title\">\r\n          <div class=\"red_box\"><div class=\"white_box\"></div></div>\r\n          <p>Company overview</p>\r\n        </div>\r\n        <h2>会社概要</h2>\r\n        <table>\r\n          <tr>\r\n            <th>会社名</th>\r\n            <td>株式会社ロココ</td>\r\n          </tr>\r\n          <tr>\r\n            <th>本社</th>\r\n            <td>大阪府大阪市中央区博労町1-8-8<br />ピカソ堺筋本町ビル501</td>\r\n          </tr>\r\n          <tr>\r\n            <th>代表取締役社長</th>\r\n            <td>阿部 慎太郎</td>\r\n          </tr>\r\n          <tr>\r\n            <th>設立</th>\r\n            <td>2011 年 12 月</td>\r\n          </tr>\r\n          <tr>\r\n            <th>資本金</th>\r\n            <td>800万円</td>\r\n          </tr>\r\n          <tr>\r\n            <th>従業員数</th>\r\n            <td>26名</td>\r\n          </tr>\r\n          <tr>\r\n            <th>主な事業内容</th>\r\n            <td>アパレル小売業/ECサイトによる通信販売</td>\r\n          </tr>\r\n        </table>\r\n        <p class=\"attention\">※2023年3月現在</p>\r\n      </section>\r\n      <section id=\"access\">\r\n        <div class=\"title\">\r\n          <div class=\"red_box\"><div class=\"white_box\"></div></div>\r\n          <p>Access</p>\r\n        </div>\r\n        <h2>アクセス</h2>\r\n        <iframe\r\n          src=\"https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2320.034296839742!2d135.50782229601793!3d34.67934455531442!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f100!3m3!1m2!1s0x0%3A0x23fe61c24df3c808!2z5qCq5byP5Lya56S-44Ot44Kz44Kz77yIUk9DT0NPKQ!5e0!3m2!1sja!2sjp!4v1588242465354!5m2!1sja!2sjp\"\r\n          width=\"780\"\r\n          height=\"540\"\r\n          frameborder=\"0\"\r\n          style=\"border: 0\"\r\n          allowfullscreen=\"\"\r\n          aria-hidden=\"false\"\r\n          tabindex=\"0\"\r\n        ></iframe>\r\n        <table>\r\n          <tr>\r\n            <th>所在地</th>\r\n            <td>\r\n              〒541-0059<br />大阪府大阪市中央区博労町1-8-8　ピカソ堺筋本町ビル5階\r\n            </td>\r\n          </tr>\r\n          <tr>\r\n            <th>TEL・FAX</th>\r\n            <td>06-4708-6316</td>\r\n          </tr>\r\n        </table>\r\n        <hr />\r\n        <p id=\"contact\" class=\"sub_title\">お問い合わせ</p>\r\n        <p class=\"contactform_txt\">\r\n          弊社にご連絡いただく際は以下のフォームよりお問い合わせください。<br />\r\n          商品・ECサイトに関しては各サイトからお願い申し上げます。\r\n        </p>\r\n        <div class=\"company_form\">\r\n          <div role=\"form\" class=\"wpcf7\" id=\"company_form\" lang=\"ja\" dir=\"ltr\">\r\n            <div class=\"screen-reader-response\"></div>\r\n            <form\r\n              action=\"#\"\r\n              method=\"post\"\r\n              class=\"wpcf7-form\"\r\n              novalidate=\"novalidate\"\r\n            >\r\n              <input type=\"hidden\" name=\"mail_sent\" value=\"\" />\r\n              <input type=\"hidden\" name=\"mailform_token\" value=\"\" />\r\n              <p>\r\n                <label>\r\n                  お名前 <span class=\"cation\">(必須)</span><br />\r\n                  <span class=\"wpcf7-form-control-wrap your-name\"\r\n                    ><input\r\n                      type=\"text\"\r\n                      name=\"your-name\"\r\n         