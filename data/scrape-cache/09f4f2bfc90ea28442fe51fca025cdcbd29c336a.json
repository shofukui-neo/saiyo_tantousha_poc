r\">\n<script>\r\nconst setForm = () => {\r\n  const $formStatus = document.getElementById('form_current_status');\r\n  if($formStatus.value != 'entry') return false;\r\n  const id = document.querySelector('.section-form_formframework form').getAttribute('id');\r\n  if (!document.getElementById(id+'-emailcheck')) return false;\r\n\r\n  const $btnSubmit = document.getElementById(id+'-submit');\r\n  $btnSubmit.addEventListener('click', (e) => {\r\n    if (document.getElementById(id+'-email').value !== document.getElementById(id+'-emailcheck').value) {\r\n      e.preventDefault();\r\n      alert('メールアドレスと確認用メールアドレスが一致しないようです。入力されたメールアドレスを再度ご確認ください。');\r\n    }\r\n  });\r\n}\r\nsetForm();\r\n</script>\n</div>\n</div>\n</section>\n<!-- /.section -->\n\n\n\n\n\n\n</main>\n\n<footer class=\"footer-global\">\n<div class=\"container\">\n<address class=\"copyright\">Copyright &copy; New Otani Co., Ltd. All Rights Reserved.</address>\n</div>\n</footer>\n<!-- /.footer-global -->\n\n\n<div class=\"modal fade\" id=\"lightbox\" tabindex=\"-1\" role=\"dialog\" aria-hidden=\"true\">\n<div class=\"modal-dialog\">\n  <div class=\"modal-content\">\n  <div class=\"modal-header\"></div>\n  <div class=\"modal-body\"></div>\n  </div>\n</div>\n</div>\n\n<a class=\"overlay\" id=\"overlay\"></a>\n<div class=\"loading\" id=\"loading\"><div class=\"loader\"></div></div>\n\n\n</div>\n<script src=\"/_common/js/library.js?1700107643\"></script>\n<script src=\"/_common/js/common.js?1659420956\"></script>\n\n\n\n</body>\n</html>","finalUrl":"https://www.kys-newotani.co.jp/hakata/form/entry-arbeit/","rendered":false,"_cachedAt":"2026-06-22T17:45:25.451Z"}