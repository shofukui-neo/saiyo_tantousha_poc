{"url":"https://www.takizumi.com/recruit/detail/","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n<head prefix=\"og: http://ogp.me/ns#\">\n\t<!-- Google tag (gtag.js) -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-23HKB9BP8V\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'G-23HKB9BP8V');\n</script>\t<meta charset=\"UTF-8\">\n\t<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n\t<title>募集要項｜タキズミ採用サイト</title>\n  <meta name=\"description\" content=\"株式会社タキズミの募集要項です。営業職、施工管理職、事務職、退去立会職の募集をしています。ものづくりやインテリアに興味のある方、お客様とのコミュニケーションが得意な方は、ぜひ応募をご検討ください。\">\n  <meta name=\"keywords\" content=\"\">\n\n  <meta property=\"fb:app_id\" content=\"\">\n  <meta property=\"og:title\" content=\"募集要項｜タキズミ採用サイト\">\n  <meta property=\"og:description\" content=\"株式会社タキズミの募集要項です。営業職、施工管理職、事務職、退去立会職の募集をしています。ものづくりやインテリアに興味のある方、お客様とのコミュニケーションが得意な方は、ぜひ応募をご検討ください。\">\n  <meta property=\"og:type\" content=\"website\">\n  <meta property=\"og:image\" content=\"https://www.takizumi.com/recruit/images/ogp.jpg\">\n  <meta property=\"og:url\" content=\"https://www.takizumi.com/recruit/detail/\">\n  <meta property=\"og:site_name\" content=\"株式会社タキズミ\">\n  <meta property=\"og:locale\" content=\"ja_JP\">\n  <meta name=\"twitter:title\" content=\"募集要項｜タキズミ採用サイト\">\n  <meta name=\"twitter:description\" content=\"株式会社タキズミの募集要項です。営業職、施工管理職、事務職、退去立会職の募集をしています。ものづくりやインテリアに興味のある方、お客様とのコミュニケーションが得意な方は、ぜひ応募をご検討ください。\">\n  <meta name=\"twitter:image\" content=\"https://www.takizumi.com/recruit/images/ogp.jpg\">\n  <meta name=\"twitter:url\" content=\"https://www.takizumi.com/recruit/detail/\">\n  <meta name=\"twitter:card\" content=\"summary_large_image\">\n\t<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<link rel=\"icon\" href=\"/recruit/images/apple-touch-icon.png\">\n<link rel=\"shortcut icon\" href=\"/recruit/images/apple-touch-icon.png\">\n