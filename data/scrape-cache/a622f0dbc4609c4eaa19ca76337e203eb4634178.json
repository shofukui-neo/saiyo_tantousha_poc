t\t\t\t<li class=\"header_megamenu_item\"><a href=\"/recruit/welfare/\">福利厚生</a></li>\n\t\t\t\t\t\t\t</ul>\n\t\t\t\t\t\t</div>\n          </li>\n\t\t\t\t\t<li class=\"header_gnav_item header_gnav_item_04 header_gnav_item_mega\"><span>人を知る</span>\n\t\t\t\t\t\t<div class=\"header_gnav_mega\">\n\t\t\t\t\t\t\t<ul class=\"header_megamenu\">\n\t\t\t\t\t\t\t\t<li class=\"header_megamenu_item\"><a href=\"/recruit/Interview01/\">社員インタビュー01</a></li>\n\t\t\t\t\t\t\t\t<li class=\"header_megamenu_item\"><a href=\"/recruit/Interview02/\">社員インタビュー02</a></li>\n\t\t\t\t\t\t\t\t<!-- <li class=\"header_megamenu_item\"><a href=\"/recruit/Interview03/\">社員インタビュー03</a></li>  -->\n\t\t\t\t\t\t\t\t<!-- <li class=\"header_megamenu_item\"><a href=\"/recruit/Interview04/\">社員インタビュー04</a></li> -->\n\t\t\t\t\t\t\t</ul>\n\t\t\t\t\t\t</div>\n          </li>\n\t\t\t\t\t<li class=\"header_gnav_item header_gnav_item_05 header_gnav_item_solo\"><a href=\"/recruit/detail/\">募集要項</a></li>\n\t\t\t\t</ul>\n\t\t\t</nav>\n      <p class=\"header_corporate\"><a href=\"http://www.takizumi.com/\" target=\"_blank\">コーポレートサイトはこちら</a></p>\n\t\t\t<div class=\"header_entry\">\n\t\t\t\t<p class=\"header_entry_btn\"><a href=\"/recruit/detail/#message\">エントリー</a></p>\n\t\t\t</div>\n      <p class=\"header_copy\">&copy; 2022 TAKIZUMI All Right Reserved.</p>\n\t\t</div><!-- /.header_wrap_inner -->\n\t</div><!-- /.header_wrap -->\n</header>\n\n\t\t\t<main id=\"main\">\n\t\t\t\t<div class=\"all_m_mv\"><div class=\"all_m_mv_wrap\">\n          <div class=\"all_m_mv_title\">\n\t\t\t\t\t\t<h1 class=\"all_m_mv_title_text\">募集要項</h1>\n            <span class=\"all_m_mv_title_obj\"><img src=\"../images/detail_txt_obj.svg\" alt=\"Requirements\"></span>\n\t\t\t\t\t</div>\n          <figure class=\"all_m_mv_img\"><img src=\"../images/detail_img_mv.jpg\" width=\"2800\" height=\"1400\" alt=\"画像\"></figure>\n          <div class=\"all_m_mv_scroll\">\n            <p class=\"all_m_mv_scroll_img\"><img src=\"../images/all_img_mv_scroll.svg\" alt=\"SCROLL\"></p>\n          </div>\n\t\t\t\t</div></div><!-- /.all_m_mv -->\n\n        <div class=\"all_m_intro all_m_intro_flat\">\n          <div class=\"all_l_wrap\">\n            <h2 class=\"all_m_intro_title all_c_title_en\" data-anim=\"fadeup\">・welfare</h2>\n            <p class=\"all_m_intro_catch\" data-anim=\"fadeup\">オフィスや住空間をコーディネートする、<br class=\"all_mi_pc\">プロフェッショナルになりませんか。</p>\n            <p class=\"all_m_intro_text\" data-anim=\"fadeup\">私たちは、オフィスビルやマンション、商業施設などを中心にお客様のお困りごとにお応えしながら、快適で心地いい空間をコーディネートしています。また、その過程で地球環境に負担をかけないように「省エネ」「エコ」の視点を大切にしています。ものづくりやインテリアに興味のある方、お客様とのコミュニケーションが得意な方、ぜひ応募をご検討ください。</p>\n          </div>\n        </div><!-- /.all_m_intro -->\n\n        <div class=\"detail_contents\" data-anim=\"fadeup\">\n          <div class=\"all_l_wrap_l\">\n            <div class=\"detail_contents_body js-target-detailAcc\">\n              <h3 class=\"detail_contents_title\">求める人物像</h3>\n              <div class=\"detail_person\">\n                <ul class=\"detail_person_list\">\n                  <li class=\"detail_person_item\">\n                    <p class=\"detail_person_item_title\">いきいき</p>\n                    <p class=\"detail_person_item_text\">多くの人と接する仕事です。<br>挨拶・返事などあたりまえのこともいきいきと元気よくできる人。</p>\n                  </li>\n                  <li class=\"detail_person_item\">\n                    <p class=\"detail_person_item_title\">勇気</p>\n                    <p class=\"detail_person_item_text\">お客様から言われたことに「NO」と言わず、どうしたら応えられるか考え挑戦する勇気、新しいお客様・新しい仕事にも好奇心旺盛に取り組む勇気のある人。</p>\n                  </li>\n                  <li class=\"detail_person_item\">\n                    <p class=\"detail_person_item_title\">思いやり</p>\n                    <p class=\"detail_person_item_text\">お客様のやすらぎ、くつろぎを考えられ,また仲間のことを思いやり、助け合える人。<br>細やかで丁寧な仕事ができる人。</p>\n                  </li>\n                </ul>\n              </div>\n              <section id=\"message\" class=\"detail_contents_message\">\n                <h3 class=\"detail_contents_title\">応募者へのメッセージ</h3>\n                <div class=\"detail_contents_text\">\n                  <p>株式会社タキズミは、創業以来の理念「すべてお客様にお役に立つ」を基盤に、常に新しい挑戦を続けてきました。<br>\n                  ここで働くことは、単なる「仕事」ではなく、お客様の課題を解決し、社会に役立つ「価値を生み出す経験」そのものです。<br>\n                  そして今、私たちは「お困り事のその先へ」を見据え、お客様に新しい価値や安心を届ける企業を目指しています。<br>\n                  私たちは社員一人ひとりの成長を大切にし、学びと挑戦の機会を用意しているので、経験の有無に関わらず、意欲次第で大きなキャリアを築くことができます。</p>\n                  <p>あなたの可能性が広がる場所として、タキズミがあります。<br>未来を共に創る仲間として、ぜひ力を発揮してください。</p>\n                </div>\n              </section>\n              <p class=\"detail_contents_text-btn\">\n                <a href=\"https://doda.jp/DodaFront/View/CompanyJobs/j_id__10007722911/\" target=\"_blank\">\n                  <span class=\"detail_contents_text-btn-icon\">詳しい募集要項・エントリーは<br class=\"all_mi_sp\">こちらから\t<svg class=\"fill_white\" width=\"12\" height=\"12\"><use href=\"#another_tab\"></use></svg></span>\n                </a>\n              </p>\n\n              <!-- <h3 class=\"detail_contents_title\">募集要項</h3> -->\n\n              <!-- <div class=\"tab_box\">\n                <div class=\"btn_area\">\n                  <p class=\"tab_btn active\">新卒採用</p>\n                  <p class=\"tab_btn\">中途採用</p>\n                  <p class=\"tab_btn\">パート採用</p>\n                </div>\n                <div class=\"panel_area\">\n                  <div class=\"tab_panel active\">\n                <div class=\"detail_terms\">\n                <h4 class=\"detail_terms_hdg\">・営業職</h4>\n                <div class=\"detail_terms_body\">\n                  <div class=\"detail_terms_inline\">\n                    <div class=\"detail_terms_col\">\n                      <ul class=\"detail_terms_list\">\n                        <li class=\"detail_terms_item\">\n                          <h5 class=\"detail_terms_title\"><span class=\"detail_terms_title_inner\">雇用形態</span></h5>\n                          <p class=\"detail_terms_text\">正社員</p>\n                        </li>\n                        <li class=\"detail_terms_item\">\n                          <h5 class=\"detail_terms_title\"><span class=\"detail_terms_title_inner\">勤務地</span></h5>\n                          <p class=\"detail_terms_text\">本社（東京都文京区大塚3-38-8）<br>現場は都内がほとんどです</p>\n                        </li>\n                        <li class=\"detail_terms_item\">\n                          <h5 class=\"detail_terms_title\"><span class=\"detail_terms_title_inner\">勤務時間</span></h5>\n                          <p class=\"detail_terms_text\">\n                            9:00～18:00（実働8時間）<br>\n                            休憩時間1時間(12:00～13:00)\n                          </p>\n                        </li>\n                        <li class=\"detail_terms_item\">\n                          <h5 class=\"detail_terms_title\"><span class=\"detail_terms_title_inner\">休日休暇</span></h5>\n                          <p class=\"detail_terms_text\">\n                            土曜・日曜・祝日<br>\n                            年間休日：年間124日\n                          </p>\n                        </li>\n                        <li class=\"detail_terms_item\">\n                          <h5 class=\"detail_terms_title\"><span class=\"detail_terms_title_inner\">給与</span></h5>\n                          <p class=\"detail_terms_text\">\n                            基本給：178,900円<br>\n                            調整手当：10,000円<br>\n                            定額残業手当：21,100円(15時間分の時間外労働・所定休日労働を含む)<br>\n                            計：210,000円<br>\n                            <br>\n                            定額残業手当は、時間外労働・所定休日労働等の有無にかかわらず、定額残業手当として支給し、15時間を超える時間外労働・所定休日労働は追加で法所定の割増率で支給します。<br>\n                            <br>\n                            賞与(2022実績：4.5ヶ月分）、交通費：全額支給、家族手当：支給有、退職金：企業型確定拠出年金(401K)導入、昇給率：2022年度実績2.4％\n                          </p>\n                        </li>\n\n                      </ul>\n                      <ul class=\"detail_terms_list\">\n                        <li class=\"detail_terms_item\">\n                          <h5 class=\"detail_terms_title\"><span class=\"detail_terms_title_inner\">募集対象</span></h5>\n                          <p class=\"detail_terms_text\">大学卒以上、既卒(3年以内)<br>パソコン操作（Excel、Word、Eメール、等）が出来る方</p>\n                        </li>\n                        <li class=\"detail_terms_item\">\n                          <h5 class=\"detail_terms_title\"><span class=\"detail_terms_title_inner\">福利厚生</span></h5>\n                          <p class=\"detail_terms_text\">社会保険完備（雇用、健康、労災、厚生年金）、昇給年1回（11月）、賞与年2回（5月・11月）</p>\n                        </li>\n                        <li class=\"detail_terms_item\">\n                          <h5 class=\"detail_terms_title\"><span class=\"detail_terms_title_inner\">業務内容</span></h5>\n                          <p class=\"detail_terms_text\">主な営業先は大手不動産会社、賃貸会社へのルート営業で、オーナー企業、個人客との打合せをしてもらいます。慣れてくれば、自ら材料を決めて提案したり、現場を管理するための業者指導などもできるようになり、建築知識も知らず知らずのうちに身に付きます。</p>\n                        </li>\n                        <li class=\"detail_terms_item\">\n                          <h5 class=\"detail_terms_title\"><span class=\"detail_terms_title_inner\">応募方法</span></h5>\n                          <p class=\"detail_terms_text\"><a href=\"/entry/\">エントリーフォーム</a>またはお電話にてお問い合わせください。<br><a href=\"tel:0353957770\" class=\"num\">03-5395-7770</a>　担当：坂本</p>\n                        </li>\n                      </ul>\n                    </div>\n                    <ul class=\"detail_terms_list\">\n                      <li class=\"detail_terms_item\">\n                        <h5 class=\"detail_terms_title\"><span class=\"detail_terms_title_inner\">選考の流れ</span></h5>\n                        <p class=\"detail_terms_text\">面接・テストは、１日で行います。</p>\n                        <div class=\"detail_terms_flow_wrap all_m_sp_scroll\">\n                          <ol class=\"detail_terms_flow\">\n                            <li class=\"detail_terms_flow_item\">\n                              <p class=\"detail_terms_flow_num\">01</p>\n                              <p class=\"detail_terms_flow_title\">書類選考</p>\n                              <p class=\"detail_terms_flow_text\">エントリーしていただいた情報をもとに選考を行います。</p>\n                            </li>\n                            <li class=\"detail_terms_flow_item\">\n                              <p class=\"detail_terms_flow_num\">02</p>\n                              <p class=\"detail_terms_flow_title\">面接<span>(１回)</span></p>\n                              <p class=\"detail_terms_flow_text\">配属先の役職者が面接を行います。</p>\n                            </li>\n                            <li class=\"detail_terms_flow_item\">\n                              <p class=\"detail_terms_flow_num\">03</p>\n                              <p class=\"detail_terms_flow_title\">テスト</p>\n                              <p class=\"detail_terms_flow_text\">適性検査、SPI、タイピングテストを行います。</p>\n                            </li>\n                            <li class=\"detail_terms_flow_item\">\n                              <p class=\"detail_terms_flow_num\">04</p>\n                              <p class=\"detail_terms_flow_title\">採用</p>\n                              <p class=\"detail_terms_flow_text\">内定通知及び雇用条件を人事担当よりご連絡いたします。</p>\n                            </li>\n                          </ol>\n                        </div>\n                      </li>\n                    </ul>\n                  </div>\n                </div>\n              </div>\n            </div>\n\n            <div class=\"tab_panel\">\n              <div class=\"detail_terms\">\n                <h4 class=\"detail_terms_hdg\">・施工管理職</h4>\n                <div class=\"detail_terms_body\">\n                  <div class=\"detail_terms_inline\">\n                    <div class=\"detail_terms_col\">\n                      <ul class=\"detail_terms_list\">\n                        <li class=\"detail_terms_item\">\n                          <h5 class=\"detail_terms_title\"><span class=\"detail_terms_title_inner\">雇用形態</span></h5>\n                          <p class=\"detail_terms_text\">契約社員</p>\n                        </li>\n                        <li class=\"detail_terms_item\">\n                          <h5 class=\"detail_terms_title\"><span class=\"detail_terms_title_inner\">勤務地</span></h5>\n                          <p class=\"detail_terms_text\">本社（東京都文京区大塚3-38-8）<br>現場は都内がメインですが、千葉県、神奈川県、埼玉県等の現場をお願いさせていただく場合もあります。</p>\n                        </li>\n                        <li class=\"detail_terms_item\">\n                          <h5 class=\"detail_terms_title\"><span class=\"detail_terms_title_inner\">勤務時間</span></h5>\n                          <p class=\"detail_terms_text\">\n                            9:00～18:00（実働8時間）<br>\n                            休憩時間1時間(12:00～13:00)\n                          </p>\n                        </li>\n                        <li class=\"detail_terms_item\">\n                          <h5 class=\"detail_terms_title\"><span class=\"detail_terms_title_inner\">休日休暇</span></h5>\n                          <p class=\"detail_terms_text\">土曜・日曜・祝日</p>\n                        </li>\n                        <li class=\"detail_terms_item\">\n                          <h5 class=\"detail_terms_title\"><span class=\"detail_terms_title_inner\">給与</span></h5>\n                          <p class=\"detail_terms_text\">\n                          総額：300,000～350,000円<br>\n                            基本給：249,400円～279,700円<br>\n                            住宅手当：10,000円<br>\n                            資格手当：15,000円 ※1級施工管理技士の資格をお持ちの方<br>\n                            定額残業手当：40,600円～45,300円(20時間分の時間外労働・所定休日労働を含む)<br>\n                            交通費全額支給<br>\n                            <br>\n                            定額残業手当は、時間外労働・所定休日労働等の有無にかかわらず、定額残業手当として支給し、20時間を超える時間外労働・所定休日労働は追加で法所定の割増率で支給します。\n                          </p>\n                        </li>\n                      </ul>\n                      <ul class=\"detail_terms_list\">\n                 