{"url":"https://ishikawa-hino.com/company/","html":"<html lang=\"ja\">\n<translate=\"no\">\n<!DOCTYPE html PUBLIC \"-//W3C//DTD XHTML 1.0 Transitional//EN\" \"http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd\">\n<html xmlns=\"http://www.w3.org/1999/xhtml\"><!-- InstanceBegin template=\"/Templates/page.dwt\" codeOutsideHTMLIsLocked=\"false\" -->\n<head>\n<meta http-equiv=\"Content-Type\" content=\"text/html; charset=utf-8\" />\n<!-- InstanceBeginEditable name=\"doctitle\" -->\n<title>会社のご案内 - 石川日野自動車株式会社</title>\n<!-- InstanceEndEditable -->\n<link href=\"../shared/css/common.css\" rel=\"stylesheet\" type=\"text/css\" />\n<script type=\"text/javascript\" src=\"../holiday.js\"></script>\n<script type=\"text/javascript\" src=\"../shared/js/common.js\"></script>\n<!-- <script type=\"text/javascript\" src=\"../shared/js/jquery.min.js\"></script>\n<script type=\"text/javascript\" src=\"../calendar/calendar.js\"></script> -->\n<!-- InstanceBeginEditable name=\"head\" --><!-- InstanceEndEditable --><!-- InstanceParam name=\"bannerRecruit\" type=\"boolean\" value=\"true\" -->\n</head>\n\n<body>\n<div id=\"header\">\n<p id=\"logo\"><a href=\"../index.html\" class=\"alpha\"><img src=\"../shared/img/txt_logo.gif\" alt=\"石川日野自動車株式会社\" /></a></p>\n<p id=\"nh\"><a href=\"../sitemap/index.html\" class=\"alpha\"><img src=\"../shared/img/nh_sitemap.gif\" alt=\"サイトマップ\" /></a></p>\n</div><!-- /#header -->\n\n<div id=\"ng\">\n<ul>\n<li><a href=\"../index.html\" class=\"alpha\"><img src=\"../shared/img/ng_home.jpg\" alt=\"ホーム\" /></a></li>\n<li><a href=\"index.html\" class=\"alpha\"><img src=\"../shared/img/ng_company.jpg\" alt=\"会社のご案内\" /></a></li>\n<li><a href=\"../campaign/index.html\" class=\"alpha\"><img src=\"../shared/img/ng_campaign.jpg\" alt=\"おトクなキャンペーン\" /></a></li>\n<li><a href=\"https://www.hino.co.jp/products/\" target=\"_blank\" class=\"alpha\"><img src=\"../shared/img/ng_newcar.jpg\" alt=\"新車を見る\" /></a></li>\n<li><a href=\"http://www.hino.co.jp/inquiry/index.html/\" target=\"_blank\" class=\"alpha\"><img src=\"../shared/img/ng_inquiry.jpg\" alt=\"お問い合わせ\" /></a></li>\n</ul>\n</div><!-- /#ng -->\n\n<div id=\"body\">\n<!-- InstanceBeginEditable name=\"kv\" --><!-- InstanceEndEditable -->\n\n<div id=\"content\" class=\"after\">\n<div id=\"contentMain\">\n<!-- InstanceBeginEditable name=\"contentMain\" -->\n<h1><img src=\"img/h1.gif\" alt=\"会社のご案内\" /></h1>\n\n<div class=\"sectionBox\">\n<h2><span>会社概要</span></h2>\n\n<table class=\"sheetTbl\">\n<tr>\n<th>商号</th>\n<td>石川日野自動車株式会社</td>\n</tr>\n<tr>\n<th>役員</th>\n<td><table class=\"mb0\">\n<tr>\n<th><font size=\"2\">代表取締役会長</font></th>\n<td>小林 紀男</td>\n</tr>\n<tr>\n<th><font size=\"2\">代表取締役社長</font></th>\n<td>藤井　精二</td>\n</tr>\n<tr>\n<th><font size=\"2\">専務取締役</font></th>\n<td>河上 幸雄</td>\n</tr>\n<tr>\n<th><font size=\"2\">常務取締役</font></th>\n<td>苗代 一道</td></tr>\n<tr>\n<th><font size=\"2\">監査役</font></th>\n<td>小林 誠</td>\n</tr>\n</table></td>\n</tr>\n<tr>\n<th>資本金</th>\n<td>6000万円</td>\n</tr>\n<tr>\n<th>本社所在地</th>\n<td>〒920-3116　石川県金沢市南森本町ヘ７５番地１ <a href=\"https://www.google.co.jp/maps/search/%E9%87%91%E6%B2%A2%E5%B8%82%E5%8D%97%E6%A3%AE%E6%9C%AC%E7%94%BA%E3%81%B875-1/data=!4m2!2m1!4b1?sa=X&hl=ja\" target=\"_blank\">地図を見る</a></td>\n</tr>\n<tr>\n<th>従業員数</th>\n<td>109名（令和5年4月1日現在）</td>\n</tr>\n<tr>\n<th>売上高</th>\n<td>58億円（令和４年度）</td>\n</tr>\n<tr>\n<th rowspan=\"2\">古物商許可証番号</th>\n<td>許可公安委員会名：石川県公安委員会</td>\n</tr>\n<tr>\n<td>許可証番号：511020000483</td>\n</tr>\n<tr>\n<th>拠点</th>\n<td><table class=\"mb0\">\n<tr>\n<th><font size=\"2\">本社</font></th>\n<td>〒920-3116　石川県金沢市南森本町ヘ75番地１ <a href=\"https://www.google.co.jp/maps/search/%E9%87%91%E6%B2%A2%E5%B8%82%E5%8D%97%E6%A3%AE%E6%9C%AC%E7%94%BA%E3%81%B875-1/data=!4m2!2m1!4b1?sa=X&hl=ja\" target=\"_blank\">地図を見る</a></td>\n</tr>\n<tr>\n<th><font size=\"2\">七尾営業所</font></th>\n<td>〒926-0031　石川県七尾市古府町る部３０ <a href=\"https://www.google.co.jp/maps/search/%E7%9F%B3%E5%B7%9D%E7%9C%8C%E4%B8%83%E5%B0%BE%E5%B8%82%E5%8F%A4%E5%BA%9C%E7%94%BA%E3%82%8B%E9%83%A8%EF%BC%93%EF%BC%90/data=!4m2!2m1!4b1?sa=X&hl=ja\" target=\"_blank\">地図を見る</a></td>\n</tr>\n<tr>\n<th><font size=\"2\">小松能美営業所</font></th>\n<td>〒929-0112　石川県能美市福島町ほ１０４番地 <a href=\"https://www.google.co.jp/maps/@36.4587759,136.4699351,17z\" target=\"_blank\">地図を見る</a></td>\n</tr>\n</table></td>\n</tr>\n<th>主な事業内容</th>\n<td><table class=\"mb0\">\n<tr>\n<td>・日野自動車製トラック・バスの販売及び中古車の販売・買取 </td>\n</tr>\n<tr>\n<td>・自動車部品・用品の販売 </td>\n</tr>\n<tr>\n<td>・自動車の修理・車検整備 ・板金塗装</td>\n</tr>\n<tr>\n<td>・損害保険・生命保険代理業 </td>\n</tr>\n</table></td>\n</tr>\n</table></td>\n</div><!-- /.sectionBox -->\n\n<div class=\"sectionBox\">\n<h2><span>沿革</span></h2>\n\n<table class=\"sheetTbl\">\n<tr>\n<th>昭和42年10月</th>\n<td>石川日野自動車株式会社として設立</td>\n</tr>\n<tr>\n<th>昭和43年8月</th>\n<td>金沢市梅田町に本社新築移転</td>\n</tr>\n<tr>\n<th>昭和44年11月</th>\n<td>七尾市古府町に七尾営業所開設</td>\n</tr>\n<tr>\n<th>昭和49年4月</th>\n<td>小松市長田町に小松営業所開設</td>\n</tr>\n<tr>\n<th>昭和55年3月</th>\n<td>七尾営業所を全面改築</td>\n</tr>\n<tr>\n<th>昭和56年11月</th>\n<td>小松営業所車検検査場建設</td>\n</tr>\n<tr>\n<th>平成4年10月</th>\n<td>金沢市南森本町に本社新築移転</td>\n</tr>\n<tr>\n<th>平成5年10月</th>\n<td>小松営業所改築</td>\n</tr>\n<tr>\n<th>平成7年8月</th>\n<td>七尾営業所事務所改築</td>\n</tr>\n<tr>\n<th>平成9年9月</th>\n<td>金沢市南森本町に中古車センター開設</td>\n</tr>\n<tr>\n<th>平成10年3月</th>\n<td>本社に小型整備工場増築</td>\n</tr>\n<tr>\n<th>令和4年12月</th>\n<td>能美市福島産業団地に小松営業所移転。営業所名を小松能美営業所に変更</td>\n</tr>\n</table>\n</div><!-- /.sectionBox -->\n<!-- InstanceEndEditable -->\n</div><!-- /#contentMain -->\n\n<div id=\"contentSub\">\n\n<p id=\"recruiteBox\"><a href=\"../recruit/index.html\" class=\"light\"><img src=\"../shared/img/btn_recruit.jpg\" alt=\"採用情報「石川日野で働く」はこちら\" /></a></p>\n\n\n<div id=\"calendarBox\">\n<p style=\"margin-bottom:6px;\"><img src=\"../shared/img/txt_calendar.gif\" alt=\"休業日のご案内\" />&nbsp;（<span class=\"holidaySpan\">■</span>は休業日です）</p>\n<div id=\"calendar\"><script type=\"text/javascript\">getCalendar();</script></div>\n<p><img src=\"../shared/img/txt_calinfo.gif\" alt=\"\" /></p>\n</div><!-- /#calendarBox -->\n\n<div id=\"bannerBox\">\n<p><a href=\"http://www.hino.co.jp/index.html\" target=\"_blank\"><img src=\"../shared/img/bnr_hinoCorp.gif\" alt=\"日野自動車株式会社\"></a></p>\n<p><a href=\"http://www5.mediagalaxy.co.jp/hino/catalog/\" target=\"_blank\"><img src=\"../shared/img/bnr_document.gif\" alt=\"資料請求 日野自動車のカタログをHPからご請求頂けます！\"></a></p>\n<p><a href=\"../ibent/index.html\"><img src=\"../shared/img/info.gif\" alt=\"インフォメーション\"></a></p>\n<p><a href=\"../ibent/img/kenko.pdf#view=Fit\" target=\"_blank\"><img src=\"../shared/img/kenko.png\" alt=\"健康企業\"></a></p>\n</div><!-- /#bannerBox -->\n</div><!-- /#contentSub -->\n</div><!-- /#content -->\n\n<p id=\"toTop\"><a href=\"#header\" class=\"alpha\" onclick=\"toTop();return false;\"><img src=\"../shared/img/txt_toTop.gif\" alt=\"ページの先頭へ\" /></a></p><!-- /#toTop -->\n</div><!-- /#body -->\n\n<div id=\"footer\">\n<p><a href=\"http://www5.mediagalaxy.co.jp/hino/catalog/\" target=\"_blank\">資料請求</a>｜<a href=\"../shared/img/pri.pdf#view=Fit\" target=\"_blank\">個人情報の取り扱い</a></p>\n<p id=\"copyright\">石川日野自動車（株）　〒920-3116 石川県金沢市南森本町ヘ75-1<br />Copyright &copy; Ishikawa Hino All Right Reserved .</p>\n</div><!-- /#footer -->\n</body>\n<!-- InstanceEnd --></html>\n","finalUrl":"https://ishikawa-hino.com/company/","rendered":false,"_cachedAt":"2026-06-17T23:00:45.811Z"}