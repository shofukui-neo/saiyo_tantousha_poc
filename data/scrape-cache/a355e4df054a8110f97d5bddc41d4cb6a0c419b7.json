n                  <div class=\"col-3\"> <a href=\"../products/kensetsu/index.html\"> <img src=\"../img/m2_house.jpg\" alt>建設エンジニアリング部門</a>\r\n                    <ul>\r\n                      <li><a href=\"../products/kensetsu/kensetsu.html\">建設</a></li>\r\n                      <li><a href=\"../products/kensetsu/denki.html\">電気</a></li>\r\n                      <li><a href=\"../products/kensetsu/plant.html\">プラント</a></li>\r\n                      <li><a href=\"../products/kensetsu/rnd.html\">研究開発</a></li>\r\n                    </ul>\r\n                  </div>\r\n                  <div class=\"col-3\"> <a href=\"../products/hoken/index.html\"> <img src=\"../img/m2_hoken.jpg\" alt>保険部門</a>\r\n                    <ul>\r\n                      <li><a href=\"../products/hoken/main.html#hoken_01\">取扱商品</a></li>\r\n                      <li><a href=\"../products/hoken/main.html#hoken_02\">勧誘方針</a></li>\r\n                    </ul>\r\n                  </div>\r\n                </div>\r\n              </li>\r\n            </ul>\r\n          </li>\r\n          <li class=\"current-menu-item current_page_item rrr-mega-menu\"> <a href=\"index.html\">採用情報</a>\r\n            <ul class=\"mega-menu mega_mine\">\r\n              <li class=\"mega-menu-container\">\r\n                <h2>採用情報</h2>\r\n                <div class=\"row\">\r\n                  <div class=\"col-4\"> <a href=\"message.html\"> <img src=\"../img/m3_msg.jpg\" alt>採用担当者より </a> </div>\r\n                  <div class=\"col-4\"> <a href=\"list.html\"> <img src=\"../img/m3_list.jpg\" alt>社員インタビュー </a> </div>\r\n                  <div class=\"col-4\"> <a href=\"guideline.html\"> <img src=\"../img/m3_gd.jpg\" alt>募集要項 </a> </div>\r\n                </div>\r\n              </li>\r\n            </ul>\r\n          </li>\r\n          <li class=\"rrr-mega-menu\"> <a href=\"../csr/\">サステナビリティ</a>\r\n            <ul class=\"mega-menu mega_mine\">\r\n              <li class=\"mega-menu-container\">\r\n                <h2>サステナビリティ</h2>\r\n                <div class=\"row\">\r\n                  <div class=\"col-4\"> <a href=\"../csr/\"> <img src=\"../img/m4_csr.png\" alt>基本理念 </a> </div>\r\n                  <div class=\"col-4\"> <a href=\"../csr/graph.html\"> <img src=\"../img/m4_iso.png\" alt>環境への取り組み </a> </div>\r\n                  <div class=\"col-4\"> <a href=\"../csr/health.html\"> <img src=\"../img/m4_health.png\" alt>健康経営 </a> </div>\r\n                </div>\r\n              </li>\r\n            </ul>\r\n          </li>\r\n          <li class=\"m_catalog\">\r\n            <div class=\"m_catalog_inner\">\r\n              <div> <img src=\"../img/aaa.png\" alt> </div>\r\n              <div>\r\n                <p>Company Brochure</p>\r\n                <a href=\"../doc/nikkeisangyo_en.pdf?v=2508\" target=\"_blank\"><img src=\"../img/m_dl.png\" alt>English</a> <span>/</span> <a href=\"../doc/nikkeisangyo_jp.pdf?v=2604\" target=\"_blank\"><img src=\"../img/m_dl.png\" alt>日本語</a> </div>\r\n            </div>\r\n          </li>\r\n        </ul>\r\n      </nav>\r\n    </div>\r\n  </div>\r\n</header>\r\n<main class=\"r24p r24_shouji\">\r\n  \r\n  <div class=\"breadcrumbs breadcrumbs_r24\">\r\n    <ol>\r\n      <li><a href=\"/\">HOME</a></li>\r\n      <li><a href=\"index.html\">採用情報</a></li>\r\n      <li><a href=\"list.html\">社員インタビュー</a></li>\r\n      <li>インタビュー詳細</li>\r\n    </ol>\r\n  </div>  \r\n  \r\n  <section class=\"r24p_mainv\">  \r\n    <div class=\"txtbox\">\r\n      <div class=\"subttl\">\r\n        <span class=\"txt\">INTERVIEW</span>\r\n        <span class=\"num\">04</span>\r\n      </div>\r\n      <div class=\"info\">\r\n        <span class=\"job\">大阪支店</span>\r\n        <span class=\"year\">2020年入社</span>\r\n      </div>\r\n      <h1 class=\"words\">\r\n        <span>\r\n        本当に明るい雰囲気で<br>\r\n        働きやすい環境です\r\n        </span>\r\n      </h1>\r\n    </div>\r\n    <div class=\"image bgextend\">\r\n      <div class=\"bgappear\">\r\n        <img src=\"img/04/main.jpg\" alt>\r\n      </div>\r\n    </div>\r\n  </section>\r\n  \r\n  <section class=\"r24p_video\">\r\n  <div class=\"inner\">\r\n    \r\n    <a href=\"#iframe-v\" class=\"videobox\" data-lity>\r\n      <img class=\"video\" src=\"img/04/videoimg.jpg\" alt>\r\n      </a>\r\n    <div id=\"iframe-v\" class=\"jst_video lity-hide\" style=\"overflow:auto; background:#FDFDF6; width:800px; max-width:100%;\"> \r\n      <iframe src=\"https://api01-platform.stream.co.jp/apiservice/plt3/MzYyNQ%3d%3d%23NDgz%23280%23168%230%2337E6A0D86400%23OzEwOzEwOzEw%23\" width=\"100%\" height=\"100%\" style=\"position:absolute\" frameborder=\"0\" allowfullscreen referrerpolicy=\"no-referrer-when-downgrade\" ></iframe>\r\n      </div>\r\n    <div class=\"txtbox\">\r\n      <span class=\"backtxt\">VIDEO</span>\r\n      <h3>インタビュー動画</h3>\r\n      </div>\r\n    \r\n  </div>    \r\n  </section>  \r\n  \r\n  <section class=\"r24p_sec r24p_sec_1\">\r\n  <div class=\"inner\">\r\n    \r\n    <div class=\"qnabox\">   \r\n      <section class=\"r24p_qna\">\r\n        <p class=\"num\">#01\r\n          <span class=\"question\">Question</span>\r\n          </p>\r\n        <h2 class=\"\"><span>日軽産業を選んだ理由は</span></h2>\r\n        <p class=\"answer\">\r\n          最初は休日の多さで見てたんですけれども、実際に就職活動をするときの面接をやっていく中で、趣味の話であったりとか話を広げてくれたりとか、\r\n          非常に話しやすい雰囲気で声をかけてくれたというのがすごく好印象で、そこが決め手にはなりましたね。\r\n          </p>\r\n        </section>\r\n      <section class=\"r24p_qna\">\r\n        <p class=\"num\">#02\r\n          <span class=\"question\">Question</span>\r\n          </p>\r\n        <h2 class=\"\"><span>どんな雰囲気の会社ですか</span></h2>\r\n        <p class=\"answer\">\r\n          本当に明るい雰囲気で働きやすい環境だなと凄く思いましたね。仲は非常に良くて、飲み会も結構あります。\r\n          非常にアットホームというと、ちょっとうさんくさいワードにはなるんですけど、凄く本当にアットホームという言葉が合うような非常にいい雰囲気の会社ですね。\r\n          </p>\r\n        </section>\r\n      </div>\r\n    \r\n    <div class=\"imgbox\">   \r\n      <figure>\r\n        <img src=\"img/04/01.jpg\" alt>\r\n        </figure>\r\n      </div>\r\n    \r\n  </div>  \r\n  </section>\r\n  \r\n  <figure class=\"r24p_wide bgextend\">\r\n    <div class=\"bgappear\">\r\n      <img src=\"img/04/wide.jpg\" alt>\r\n    </div>  \r\n  </figure>  \r\n  \r\n  <section class=\"r24p_sec r24p_sec_2\">\r\n  <div class=\"inner\">\r\n    \r\n    <div class=\"qnabox\">   \r\n      <section class=\"r24p_qna\">\r\n        <p class=\"num\">#03\r\n          <span class=\"question\">Question</span>\r\n          </p>\r\n        <h2 class=\"\"><span>現在どんな仕事をしていますか</span></h2>\r\n        <p class=\"answer\">\r\n          主にアルミの製品であったりとか、リベットと呼ばれる締結部材を販売しています。\r\n          リベットというのはネジだったり、ボルトというようなものをイメージしていただくと分かりやすいです。\r\n          </p>\r\n        </section>\r\n      <section class=\"r24p_qna\">\r\n        <p class=\"num\">#04\r\n          <span class=\"question\">Question</span>\r\n          </p>\r\n        <h2 class=\"\"><span>今後はどんな仕事に<br>チャレンジしたいですか</span></h2>\r\n        <p class=\"answer\">\r\n          ゼロベースで新しく新規開拓というところで仕事を作り出して、次の世代の方々にバトンをパスしていけるような仕事を作っていきたいので、その活動をこれから始めていきたいなとは思っています。      \r\n          </p>\r\n        </section>\r\n      </div>\r\n    \r\n    <div class=\"imgbox\">   \r\n      <figure>\r\n        <img src=\"img/04/tate.jpg\" alt>\r\n        </figure>\r\n      </div>\r\n    \r\n  </div>  \r\n  </section>  \r\n  \r\n  <section class=\"r24p_sec r24p_sec_3\">\r\n  <div class=\"inner\">\r\n    \r\n    <div class=\"qnabox\">   \r\n      \r\n      <section class=\"r24p_qna\">\r\n        <p class=\"num\">#05\r\n          <span class=\"question\">Question</span>\r\n          </p>\r\n        <h2 class=\"\"><span>休日の過ごし方は</span></h2>\r\n        <p class=\"answer\">\r\n          休日は友達とテニスをしたりとか、有給休暇を取って旅行を行ったりというのが趣味ですね。\r\n          有給休暇はすごく取りやすい会社だなというのは思いますね。ほんまに誰でも気軽に有給休暇は取れるっていうところが、もうすごく働きやすい会社だなと思います。\r\n          </p>\r\n        </section>\r\n      <section class=\"r24p_qna\">\r\n        <p class=\"num\">#06\r\n          <span class=\"question\">Question</span>\r\n          </p>\r\n        <h2 class=\"\"><span>将来の夢はなんですか</span></h2>\r\n        <p class=\"answer\">\r\n          将来の夢は、日本全国47都道府県全部回ることです。一周したいですね。\r\n          </p>\r\n        </section>\r\n      </div>\r\n    \r\n    <div class=\"imgbox\">   \r\n      <figure>\r\n        <img src=\"img/04/02.jpg\" alt>\r\n        </figure>\r\n      </div>\r\n    \r\n  </div>  \r\n  </section>  \r\n  \r\n</main>  \r\n\t\r\n<section class=\"r24p_others\">\r\n  <div class=\"inner\">\r\n    <div class=\"ttl\"> <span class=\"eng\">Other Interviews</span>\r\n      <h2>社員インタビュー</h2>\r\n    </div>\r\n    <div class=\"memberlist\">\r\n      <div class=\"r24i_ppl r24i_ppl_shou\"> <a href=\"03.html\">\r\n        <div class=\"imgbox\"> <img src=\"img/03/r24i_03.png\" alt> </div>\r\n        <div class=\"txtbox\">\r\n          <p class=\"job\">静岡支店</p>\r\n          <p class=\"name\">2021年入社</p>\r\n        </div>\r\n        </a> </div>\r\n      <div class=\"r24i_ppl r24i_ppl_shou\"> <a href=\"04.html\">\r\n        <div class=\"imgbox\"> <img src=\"img/04/r24i_04.png\" alt> </div>\r\n        <div class=\"txtbox\">\r\n          <p class=\"job\">大阪支店</p>\r\n          <p class=\"name\">2020年入社</p>\r\n        </div>\r\n        </a> </div>\r\n      <div class=\"r24i_ppl r24i_ppl_kanr\"> <a href=\"05.html\">\r\n        <div class=\"imgbox\"> <img src=\"img/05/r24i_05.png\" alt> </div>\r\n        <div class=\"txtbox\">\r\n          <p class=\"job\">経理部</p>\r\n          <p class=\"name\">2017年入社</p>\r\n        </div>\r\n        </a> </div>\r\n      <div class=\"r24i_ppl r24i_ppl_kens\"> <a href=\"06.html\">\r\n        <div class=\"imgbox\"> <img src=\"img/06/r24i_06.png\" alt> </div>\r\n        <div class=\"txtbox\">\r\n          <p class=\"job\">建設エンジニアリング部</p>\r\n          <p class=\"name\">2020年入社</p>\r\n        </div>\r\n        </a> </div>\r\n      <div class=\"r24i_ppl r24i_ppl_kens\"> <a href=\"07.html\">\r\n        <div class=\"imgbox\"> <img src=\"img/07/r24i_07.png\" alt> </div>\r\n        <div class=\"txtbox\">\r\n          <p class=\"job\">建設エンジニ