{"url":"https://www.cmp.co.jp/recruit_fresh/work-people/","html":"<!doctype html>\n<html lang=\"ja\">\n<head>\n<meta charset=\"utf-8\" />\n<meta http-equiv=\"Content-Style-Type\" content=\"text/css\" />\n<meta http-equiv=\"Content-script-type\" content=\"text/javascript\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<meta name=\"format-detection\" content=\"telephone=no\">\n<meta name=\"robots\" content=\"noindex\">\n<title>中国塗料の職種と役割 | 新卒採用情報 | 中国塗料株式会社</title>\n<meta name=\"description\" content=\"中国塗料株式会社の採用情報サイトです。採用に関する情報をお知らせしています。「中国塗料の職種と役割」をご紹介します。\">\n<meta property=\"og:title\" content=\"中国塗料の職種と役割 | 新卒採用情報 | 中国塗料株式会社\">\n<meta property=\"og:site_name\" content=\"新卒採用情報 | 中国塗料株式会社\">\n<meta property=\"og:description\" content=\"中国塗料株式会社の採用情報サイトです。採用に関する情報をお知らせしています。「中国塗料の職種と役割」をご紹介します。\">\n<meta property=\"og:type\" content=\"article\">\n<meta property=\"og:image\" content=\"/recruit_fresh/common/img/ogp.jpg\">\n<meta property=\"og:url\" content=\"https://www.cmp.co.jp/recruit_fresh/work-people/\">\n<meta property=\"og:locale\" content=\"ja_JP\">\n\n<!-- このページで使用するcssを読み込む -->\n<link rel=\"icon\" href=\"https://www.cmp.co.jp/library/cmp_jpn/img/favicon.ico\">\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/yakuhanjp@4.1.1/dist/css/yakuhanjp.css\">\n<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n<link href=\"https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@100..900&family=Raleway:ital,wght@0,100..900;1,100..900&display=swap\" rel=\"stylesheet\">\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../common/css/common.css\" media=\"all, projection, print\" />\n<link href=\"https://unpkg.com/aos@2.3.1/dist/aos.css\" rel=\"stylesheet\">\n\t\n<link rel=\"stylesheet\" type=\"text/css\" href=\"css/style.css\" media=\"all, projection, print\" />\n\n<!-- Google Tag Manager -->\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n})(window,document,'script','dataLayer','GTM-5HSGBZXT');</script>\n<!-- End Google Tag Manager -->\n</head>\n<body>\n<!-- Google Tag Manager (noscript) -->\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-5HSGBZXT\"\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n<!-- End Google Tag Manager (noscript) -->\n\n\n\n\n\n\n\n<header id=\"header\">\n\t<div class=\"logo\">\n\t\t<a href=\"/recruit_fresh/\">\n\t\t\t<img src=\"../common/img/logo_white.svg\" alt=\"中国塗料株式会社\">\n\t\t\t<span class=\"en\">RECRUITING</span>\n\t\t</a>\n\t</div><!--- //logo --->\n\t\n\t<div class=\"catch\">\n\t\t<span class=\"en js_typing\">GO! CMP! </span>\n\t</div><!--- //catch --->\n\t\t\n\t<ul class=\"btn-list\">\n\t\t<li><a href=\"https://job.mynavi.jp/28/pc/search/corp53617/outline.html\" target=\"_blank\"><span class=\"en\">ENTRY</span><span class=\"jp\">エントリー</span></a></li>\n\t</ul><!--- //entry --->\n</header><!--- //header --->\n\n\n\n\n\n\n\n<nav id=\"menubtn\">\n\t<div class=\"menu hamburger\">\n\t  <span></span>\n\t  <span></span>\n\t</div><!--- //hamburger --->\n</nav><!--- //menubtn --->\n\t\n<div id=\"menubox\">\n\t<nav class=\"menunav\">\n\t\t\n\t\t<div class=\"list flex\">\n\t\t\t<div class=\"box\">\n\t\t\t\t<p class=\"head en\">HOME</p>\n\t\t\t\t<ul class=\"link\">\n\t\t\t\t\t<li><a href=\"/recruit_fresh/\">トップページ</a></li>\n\t\t\t\t</ul><!--- //link --->\n\t\t\t</div><!--- //box --->\n\n\t\t\t<div class=\"box\">\n\t\t\t\t<p class=\"head en\">ABOUT</p>\n\t\t\t\t<ul class=\"link\">\n\t\t\t\t\t<li><a href=\"/recruit_fresh/about/\">知ってる？塗料と中国塗料</a></li>\n\t\t\t\t\t<li><a href=\"/recruit_fresh/about/produce.html\">中国塗料が生み出すもの<br>～製品分野別領域～</a></li>\n\t\t\t\t\t<li><a hr