ge_image\">\n  <meta name=\"twitter:site\" content=\"@11nikko03\">\n  <meta name=\"twitter:creator\" content=\"@11nikko03\">\n  <link rel=\"preload\" as=\"style\" href=\"/recruit/assets/css/style.css?rev=dc3594b500da262a\">\n  <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n  <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin=\"\">\n  <link href=\"https://fonts.googleapis.com/css2?family=Commissioner:wght@600&amp;family=IBM+Plex+Sans+JP:wght@400;500;600&amp;display=swap\" rel=\"stylesheet\">\n  <link rel=\"stylesheet\" href=\"/recruit/assets/css/style.css?rev=dc3594b500da262a\"><!-- SMP Tracking Tag Ver 3 -->\n  <script type=\"text/javascript\">\n    <!--\n    if (typeof _cam !== 'function') {\n      (function(n) {\n        var w = window,\n          d = document;\n        w['ShanonCAMObject'] = n, w[n] = w[n] || function() {\n          (w[n].q = w[n].q || []).push(arguments)\n        };\n        w[n].date = 1 * new Date();\n        var e = d.createElement('script'),\n          t = d.getElementsByTagName('script')[0];\n        e.async = 1, e.type = 'text/javascript', e.charset = 'utf-8', e.src = 'https://tracker.shanon-services.com/static/js/cam3.js' + \"?_=\" + w[n].date;\n        t.parentNode.insertBefore(e, t);\n      })('_cam');\n      _cam('create', 'SXndFgwQRg-359', ['nikko.smktg.jp', 'nikko.bunguclub.co.jp']);\n      _cam('require', 'crossLinker');\n      _cam('crossLinker:allLink', ['nikko.smktg.jp', 'nikko.bunguclub.co.jp']);\n    }\n    if (window.location.href.indexOf(\"gtm-msr.appspot.com\") == -1) {\n      _cam('send');\n    }\n    //\n    -->\n  </script>\n</head>\n\n<body id=\"gotop\" class=\"education\"><!-- Google Tag Manager (noscript) --><noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-M4XXJ9V\" height=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript><!-- End Google Tag Manager (noscript) -->\n  <div class=\"l-body\"><header class=\"l-header\">\n  <div class