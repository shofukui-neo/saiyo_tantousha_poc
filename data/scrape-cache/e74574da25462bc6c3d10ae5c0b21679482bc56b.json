{"url":"https://www.furukawact.co.jp/recruit/","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n\n  <head>\n    <meta charset=\"UTF-8\">\n    <title>採用情報｜島根県出雲市の総合建設コンサルタント｜株式会社古川コンサルタント</title>\n    <meta name=\"keywords\" content=\"採用情報,島根県,出雲市,総合建設コンサルタント,設計,測量,地質調査,建築補償,採用情報\" />\n    <meta name=\"description\" content=\"採用情報 島根県出雲市の総合建設コンサルタント株式会社古川コンサルタントのホームページです。私たちだからこそできる「地域社会との共存」を目指し、農村・都市基盤整備の企画・調査から施工管理まで幅広いニーズに即応しています。\" />\n    <meta name=\"viewport\" content=\"width=device-width,initial-scale=1,minimum-scale=1\">\n    <meta name=\"format-detection\" content=\"telephone=no\">\n    <link rel=\"shortcut icon\" href=\"/favicon.ico\">\n    <!-- css -->\n    <link rel=\"stylesheet\" href=\"/theme/furukawa_consultant/js/drawer/drawer.min.css\">\n    <link rel=\"stylesheet\" href=\"/theme/furukawa_consultant/js/slick/slick.css\">\n    <link rel=\"stylesheet\" href=\"/theme/furukawa_consultant/js/slick/slick-theme.css\">\n    <link rel=\"stylesheet\" href=\"/theme/furukawa_consultant/js/colorbox/colorbox.css\">\n    <link rel=\"stylesheet\" href=\"/theme/furukawa_consultant/css/common.css\">\n    <link rel=\"stylesheet\" href=\"/theme/furukawa_consultant/css/import.css\">\n    <!-- js -->\n    <script src=\"/theme/furukawa_consultant/js/lib/jquery-1.11.2.min.js\"></script>\n    <script src=\"/theme/furukawa_consultant/js/jquery.matchHeight.js\"></script>\n    <script src=\"/theme/furukawa_consultant/js/drawer/drawer.min.js\"></script>\n    <script src=\"/theme/furukawa_consultant/js/drawer/iscroll.js\"></script>\n    <script src=\"/theme/furukawa_consultant/js/ofi.min.js\"></script>\n    <script src=\"/theme/furukawa_consultant/js/slick/slick.min.js\"></script>\n    <script src=\"/theme/furukawa_consultant/js/colorbox/jquery.colorbox-min.js\"></script>\n    <script src=\"/theme/furukawa_consultant/js/common.js\"></script>\n    <script type=\"text/javascript\">\n      var ua = navigator.userAgent.toLowerCase();\n      // iPhone\n      var isiPhone = (ua.indexOf('iphone') > -1);\n      // iPad\n      var isiPad = (ua.indexOf('ipad') > -1);\n      // Android\n      var isAndroid = (ua.indexOf('android') > -1) && (ua.indexOf('mobile') > -1);\n      // Android Tablet\n      var isAndroidTablet = (ua.indexOf('android') > -1) && (ua.indexOf('mobile') == -1);\n      // iOS\n      if(isiPhone || isAndroid) {\n        //document.write('<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">');\n        document.querySelector( 'meta[name=\"viewport\"]' ).setAttribute( 'content', 'width=device-width,initial-scale=1' );\n      }else if(isiPad) {\n        window.onorientationchange = directionCheck;\n      }else if(isAndroidTablet){\n        window.onresize = directionCheck;\n      }else{\n        //document.write('<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">');\n        document.querySelector( 'meta[name=\"viewport\"]' ).setAttribute( 'content', 'width=device-width,initial-scale=1' );\n      }\n      directionCheck();\n\n      function directionCheck() {\n        var direction = Math.abs(window.orientation);\n        if(direction == 90) {\n          //document.write('<meta name=\"viewport\" content=\"width=1200, maximum-scale=1.0\">');\n          document.querySelector( 'meta[name=\"viewport\"]' ).setAttribute( 'content', 'width=1200, maximum-scale=1' );\n        } else {\n          //document.write('<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">');\n          document.querySelector( 'meta[name=\"viewport\"]' ).setAttribute( 'content', 'width=device-width,initial-scale=1' );\n        }\n      }\n\n      $(function(){\n        $(window).on('orientationchange', (evt) => {\n          var angle;\n          angle = screen && screen.orientation && screen.orientation.angle;\n          if (angle == null) {\n            angle = window.orientation || 0;\n          }\n          if(angle % 180 !== 0) {\n            document.querySelector( 'meta[name=\"viewport\"]' ).setAttribute( 'content', 'width=device-width,initial-scale=1' );\n          } else {\n            if(isiPad){\n              document.querySelector( 'meta[name=\"viewport\"]' ).setAttribute( 'content', 'width=1200, maximum-scale=1' );\n            }\n          }\n        }).trigger('orientationchange');\n      });\n    </script>\n    <script>\n      (function(i,s,o,g,r,a,m){i['GoogleAnalyticsObject']=r;i[r]=i[r]||function(){\n        (i[r].q=i[r].q||[]).push(arguments)},i[r].l=1*new Date();a=s.createElement(o),\n        m=s.getElementsByTagName(o)[0];a.async=1;a.src=g;m.parentNode.insertBefore(a,m)\n                              })(window,document,'script','https://www.google-analytics.com/analytics.js','ga');\n\n      ga('create', 'UA-101754522-1', 'auto');\n      ga('send', 'pageview');\n    </script>\n    <!--[if lt IE 9]>\n<script src=\"http://html5shiv.googlecode.com/svn/trunk/html5.js\" type=\"text/javascript\"></script>\n<![endif]-->\n      </head>\n\n  <body class=\"drawer drawer--right\">\n\n    <!-- header -->\n    <header role=\"banner\" class=\"hearder\" id=\"is-headerFixed\">\n  <div class=\"l-container clearfix\">\n    <!-- logo -->\n    <div class=\"hearder__logo\">\n      <a href=\"/\">\n        <img src=\"/theme/furukawa_consultant/img/common/herder_logo_01.png\" alt=\"株式会社古川コンサルタント\" class=\"imgFit hearder__logo--01\">\n        <img src=\"/theme/furukawa_consultant/img/common/herder_logo_02.png\" alt=\"株式会社古川コンサルタント\" class=\"imgFit hearder__logo--02\">\n        <h1 class=\"dn\">株式会社古川コンサルタント</h1>\n      </a>\n    </div>\n    <!-- /logo -->\n    <!-- mobile menu -->\n    <div id=\"close\" class=\"hearder__menu dn-pc drawer-toggle\">\n      <img src=\"/theme/furukawa_consultant/img/common/btn_mobile_01.png\" alt=\"MENU\" class=\"imgFit\">\n    </div>\n    <!-- /mobile menu -->\n    <!-- global navi -->\n    <nav role=\"navigation\" class=\"gNav gNav-accordion drawer-nav\">\n  <ol class=\"clearfix drawer-menu\">\n    <li class=\"gNav__item gNav__item--normal dn-pc\">\n      <a href=\"/\">\n        <span class=\"gNav__item__inner\">\n          トップページ\n        </span>\n      </a>\n    </li>\n    <li class=\"gNav__item gNav__item--normal gNav__item--about\">\n      <a href=\"/about\">\n        <span class=\"gNav__item__inner\">\n          私たちの事業について\n        </span>\n      </a>\n    </li>\n    <li class=\"gNav__item gNav__item--normal gNav__item--news\">\n      <a href=\"/news/\">\n        <span class=\"gNav__item__inner\">\n          新着情報\n        </span>\n      </a>\n    </li>\n    <li class=\"gNav__item gNav__item--normal gNav__item--works\">\n      <a href=\"/casebook/casebooks/\">\n        <span class=\"gNav__item__inner\">\n          事業実績\n        </span>\n      </a>\n    </li>\n    <li class=\"gNav__item gNav__item--normal gNav__item--company\">\n      <a href=\"/company\">\n        <span class=\"gNav__item__inner\">\n          会社案内\n        </span>\n      </a>\n    </li>\n    <li class=\"gNav__item gNav__item--normal gNav__item--recruit\">\n      <a href=\"/recruit/index\">\n        <span class=\"gNav__item__inner\">\n          採用情報\n        </span>\n      </a>\n    </li>\n    <li class=\"gNav__item gNav__item--normal dn-pc\">\n            <a href=\"/recruit/voice\">\n              <span class=\"gNav__item__inner\">\n                先輩社員の声\n              </span>\n            </a>\n          </li>\n          <li class=\"gNav__item gNav__item--normal dn-pc\">\n            <a href=\"/guideline/guidelines/\">\n              <span class=\"gNav__item__inner\">\n                募集要項\n              </span>\n            </a>\n          </li>\n          <li class=\"gNav__item gNav__item--normal gNav__item--blog\">\n            <a href=\"/blog/\">\n              <span class=\"gNav__item__inner\">\n                社員ブログ\n              </span>\n            </a>\n          </li>\n    <li class=\"gNav__item gNav__item--normal dn-pc\">\n      <a href=\"/privacy\">\n        <span class=\"gNav__item__inner\">\n          プライバシーポリシー\n        </span>\n      </a>\n    </li>\n    <li class=\"gNav__item gNav__item--normal dn-pc\">\n      <a href=\"/information\">\n        <span class=\"gNav__item__inner\">\n          情報公開\n        </span>\n      </a>\n    </li>\n    <li class=\"gNav__item gNav__item--normal gNav__item--fb\">\n      <a href=\"https://www.facebook.com/profile.php?id=61553735414491\" target=\"_blank\">\n        <span class=\"dn-pc\">Facebook</span>\n      </a>\n    </li>\n    <li class=\"gNav__item gNav__item--normal gNav__item--contact\">\n            <a href=\"/contact/\">\n              <span class=\"gNav__item__inner\">\n                お問い合わせ\n              </span>\n            </a>\n          </li>\n    <li class=\"gNav__item gNav__item--close dn-pc\">\n      <a class=\"drawer-toggle\">\n        閉じる\n      </a>\n    </li>\n  </ol>\n</nav>    <!-- /global navi -->\n  </div>\n</header>    <!-- /header -->\n\n    <!-- main container -->\n    <main>\n      <div role=\"main\">\n                  <!-- BaserPageTagBegin -->\n<!-- BaserPageTagEnd -->\n\n<section><!-- h1 -->\r\n<div class=\"sub-h1\"><img alt=\"\" class=\"imgObjectFitCover\" src=\"/theme/furukawa_consultant/img/recruit/h1_bg.jpg\" />\r\n<div class=\"sub-h1__inner\"><img alt=\"採用情報 RECRUIT\" class=\"imgFit\" src=\"/theme/furukawa_consultant/img/recruit/h1_item_01.png\" />\r\n<h1 class=\"dn\">採用情報 RECRUIT</h1>\r\n</div>\r\n</div>\r\n<!-- /h1 --><!-- sub-container --><!-- foot-btn -->\r\n\r\n<div class=\"l-container recruit-footBtn recruit-footBtn__top mod-column-half clearfix\">\r\n<div class=\"mod-column-item\"><a class=\"recruit-footBtn__btn recruit-footBtn__btn--mes hoverNot\" href=\"/recruit/voice\"><span class=\"dn\">先輩社員の声 MESSAGE</span> </a></div>\r\n\r\n<div class=\"mod-column-item\"><a class=\"recruit-footBtn__btn recruit-footBtn__btn--ag hoverNot\" href=\"/recruit/guideline\"><span class=\"dn\">募集要項はこちら APPLICATION GUIDELINES</span> </a></div>\r\n</div>\r\n<!-- /foot-btn -->\r\n\r\n<div class=\"sub-container recruit-page\"><!-- 01 -->\r\n<section class=\"l-container\" id=\"message\">\r\n<h2 class=\"mod-hl-01\">代表メッセージ</h2>\r\n\r\n<div class=\"mod-column-half clearfix\">\r\n<div class=\"mod-column-item textCenter\"><img alt=\"代表取締役 古川 篤の写真\" class=\"imgFit\" src=\"/theme/furukawa_consultant/img/recruit/mes_item_01.jpg\" /> <img alt=\"代表取締役 古川 篤 Atsushi Frukawa\" class=\"imgFit recruit-mesName\" src=\"/theme/furukawa_consultant/img/recruit/mes_item_02.png\" /></div>\r\n\r\n<div class=\"mod-column-item\">\r\n<h3 class=\"mod-hl-03\">創造力は無限にあります!<br />\r\n創造力で未来は開けます！！</h3>\r\n\r\n<p class=\"recruit-textBox\">建設コンサルタントとは？一体どのような仕事なのでしょう？<br />\r\n私は、高校を卒業してすぐに県外の専門学校へ進学しました。特に何かやりたいという思いもなく 「なんとなくモノ作りの仕事に携わってみたい」 という中途半端な気持ちで測量を学び、測量設計の会社で働き始めました。言うまでもなく建設コンサルタントが何をするところなのか知るわけもなく･･･････。<br />\r\n将来の夢や希望もなくただただ働いてきた日々でしたが、ある時 「なんとなくモノ作りの仕事に携わってみたい」 から 「この仕事がしたい」 に変わった時がありました！<br />\r\nそれは、当時私が測量部に所属していた頃、自分が汗水流し現場で測量作業したものが図面に変わり、その図面をもとに道路や建物などが出来上がる･･･ 何もない状態から図面をおこし、それが形になっていくまでの過程、そして実際に出来上がったモノを目の前にして、なんとも言えぬ充実感に満たされた時からです。<br />\r\n現在は地元島根の地へ帰郷し、古川コンサルタントの社長として、「地域社会に貢献する」ことを経営理念とし、モノ作りの楽しさを次なる世代に伝えていこうと奮闘しております。<br />\r\n私達の仕事は、公共事業を主体にし、道路や河川、砂防や上下水道など様々な公共物の計画、設計等に対して創造力を駆使し、事業者への支援や提案を行なっております。このような仕事を建設コンサルタントと呼びます。<br />\r\n「創造力は無限にあります。創造力で未来は開けます！！」<br />\r\nぜひ、我が社で一緒に働き、地域社会とつながる楽しみ、社員一人ひとりが成長し活躍できる楽しみ、そしてモノが出来上がっていく時の充実感を味わってみませんか！</p>\r\n</div>\r\n</div>\r\n</section>\r\n<!-- /01 --><!-- 02 -->\r\n\r\n<section class=\"l-container recruit-charm\">\r\n<h2 class=\"mod-hl-01\">建設コンサルタントの<span class=\"d-inlineBlock\">魅力</span></h2>\r\n<!-- 2-1 -->\r\n\r\n<section class=\"mod-column-half-02 clearfix\">\r\n<div class=\"mod-column-item leftBox\"><img alt=\"\" class=\"imgFit\" src=\"/theme/furukawa_consultant/img/recruit/charm_item_01.png\" /></div>\r\n\r\n<div class=\"mod-column-item rightBox\">\r\n<h3 class=\"mod-hl-03\">みんなの暮らしに役立つ、<br />\r\n社会から求められる仕事です。</h3>\r\n\r\n<p class=\"recruit-textBox\">私たちの生活は、朝起きて使う水道や電気、通勤・通学で使う道路や鉄道といった社会資本のおかげで成り立っています。<br />\r\nそして建設コンサルタントは、これら公共事業として行われる社会資本の新規整備計画や維持管理計画にかかわっています。<br />\r\n私たちが仕事に立ち向かうときは、自然環境を傷つけないか？安全性は大丈夫か？工事にかかる金額に問題は無いか？など考えながら、お年寄りから子供、自然の生き物まで、みんなの喜びや笑顔を思い浮かべます。</p>\r\n</div>\r\n</section>\r\n<!-- /2-1 --><!-- 2-2 -->\r\n\r\n<section class=\"mod-column-half-02 recruit-charmTextBox--02 clearfix\">\r\n<div class=\"mod-column-item rightBox\"><img alt=\"\" class=\"imgFit\" src=\"/theme/furukawa_consultant/img/recruit/charm_item_02.png\" /></div>\r\n\r\n<div class=\"mod-column-item leftBox\">\r\n<h3 class=\"mod-hl-03\">街や人の未来を考え、<br />\r\n人々に幸せをもたらす夢のある仕事です。</h3>\r\n\r\n<p class=\"recruit-textBox\">私たちが暮らす日本では、いつでもきれいな水が飲め、車で行けない場所はほとんどない、たいへん便利な国になりました。<br />\r\nしかし、これからおこると言われる東南海・南海地震のような大きな地震への備え、古くなった街や道路の修理、お年寄りが増え働く人が少なくなる少子高齢化問題など、たくさんの課題があります。<br />\r\n私たち建設コンサルタントは、このような課題に対面し、人や街の未来を見つめ、さまざまな技術者たちと協力して知恵を使い、知的サービスを提供する、人や街の未来づくりに貢献できる誇りの持てる仕事です。<br />\r\nまた、先輩技術者たちの努力のおかげで、土木技術者の活躍の場は世界の発展途上の国々にまで広がっています。</p>\r\n</div>\r\n</section>\r\n<!-- /2-2 --></section>\r\n<!-- /02 --><!-- 03 -->\r\n\r\n<section class=\"l-container recruit-soyo\">\r\n<h2 class=\"mod-hl-01\">建設コンサルタントに<span class=\"d-inlineBlock\">求められる素養</span></h2>\r\n\r\n<div class=\"mod-column-half clearfix\">\r\n<div class=\"mod-column-item\"><img alt=\"\" class=\"imgFit\" src=\"/theme/furukawa_consultant/img/recruit/soyo_item_01.jpg\" /></div>\r\n\r\n<div class=\"mod-column-item\">\r\n<h3 class=\"mod-hl-03\">建設コンサルタントの資源は人財です</h3>\r\n\r\n<p class=\"recruit-textBox\">建設コンサルタントの資源は人財です<br />\r\n建設コンサルタントの仕事は責任のある、やりがいのある仕事です。これを行うためには、常に高度な技術力が求められ、経験や学習によって継続的に能力を伸ばすことが必要です。<br />\r\n専門能力の探究とコミュニケーション能力の向上は必須です。企業の役割・企業内の技術者の役割に応じて、自己の能力開発を継続的に維持・向上できる技術者、自己目標への道筋を意識して自らを鍛える技術者が求められています。正・不正を的確に判断できる倫理観を有し、適正な技術をもって問題解決する技術者が期待されています。倫理は技術者が堅持しなければならない規範であり、業務や役割に応じた固有の倫理があります。<br />\r\n関連法令の遵守は倫理堅持の前提条件です。</p>\r\n</div>\r\n</div>\r\n\r\n<div class=\"recruit-soyoItem02\"><img alt=\"企業に求められる能力（人財）の図\" class=\"imgFit\" src=\"/theme/furukawa_consultant/img/recruit/soyo_item_02.png\" /></div>\r\n</section>\r\n<!-- /03 --><!-- 04 -->\r\n\r\n<section class=\"l-container recruit-qa\" id=\"qa\">\r\n<h2 class=\"mod-hl-01\">よくある質問 Q&amp;A</h2>\r\n\r\n<div class=\"mod-column-half-02 clearfix\">\r\n<div class=\"mod-column-item leftBox\">\r\n<section class=\"recruit-qaBox\">\r\n<h3>有名出身校ではないのですが....</h3>\r\n\r\n<p>全く問題ございません。入社して研修をしっかりと受けていただきながら必要な専門知識と技術を習得していただきます。チャレンジ精神のある皆さまをお待ちしております。</p>\r\n</section>\r\n\r\n<section class=\"recruit-qaBox\">\r\n<h3>休日、休暇はどうなっていますか？</h3>\r\n\r\n<p>完全週休二日制（土日祝休み）です。年次有給休暇と夏季休暇及び年末年始も有ります。</p>\r\n</section>\r\n\r\n<section class=\"recruit-qaBox\">\r\n<h3>会社の雰囲気について教えてください。</h3>\r\n\r\n<p>社内では社員同士のミーティングも頻繁に行われ、また繁忙期には部署を超えて協力し合える環境です。みんな明るく活気がある職場だと思います。</p>\r\n</section>\r\n\r\n<section class=\"recruit-qaBox\">\r\n<h3>女性でも活躍できる職場でしょうか？</h3>\r\n\r\n<p>性別に関わらず、女性も活躍している職場です。男女ともに仲が良い職場なのが弊社の自慢です。</p>\r\n</section>\r\n\r\n<section class=\"recruit-qaBox\">\r\n<h3>研修制度はありますか？</h3>\r\n\r\n<p>研修制度はございます。また資格取得補助制度も設けておりますのでぜひ入社後はチャレンジしてください。社員の皆さんが新鮮に学んでいただけるよう新しい学びの場の模索を常に心がけています。</p>\r\n</section>\r\n</div>\r\n\r\n<div class=\"mod-column-item rightBox\">\r\n<section class=\"recruit-qaBox\">\r\n<h3>事前に会社見学はできますか？</h3>\r\n\r\n<p>随時行っておりますのでご希望の方はお気軽にご連絡ください。<br />\r\n<a href=\"/contact/\">当ホームページのお問い合わせフォーム</a>から、また直接お電話でも受け付けております。</p>\r\n</section>\r\n\r\n<section class=\"recruit-qaBox\">\r\n<h3>残業はありますか？</h3>\r\n\r\n<p>繁忙期には残業をお願いすることがございますが、労働時間管理は法令に基づきしっかりと行っており過度な残業やサービス残業は一切ございませんのでご安心ください。</p>\r\n</section>\r\n\r\n<section class=\"recruit-qaBox\">\r\n<h3>転勤や出張はありますか？</h3>\r\n\r\n<p>転勤は原則ございません。出張については、業務の内容や都合に応じて一時的にお願いすることがあります。</p>\r\n</section>\r\n\r\n<section class=\"recruit-qaBox\">\r\n<h3>レクリエーションはありますか？</h3>\r\n\r\n<p>レクリエーションとして、春はボーリング大会や卓球大会などのスポーツ系、秋はバスで小旅行をしたりお食事会などの親睦会を開催しています。最近では社内でスポーツ同好会ができました。</p>\r\n</section>\r\n\r\n<section class=\"recruit-qaBox\">\r\n<h3>どのようなPCソフトを使いますか？</h3>\r\n\r\n<p>部署によって変わりますが基本、CADやMicrosoft社Officeなどを使用します。その他の専門的なソフトは入社してからでも覚えられますのでご安心ください。</p>\r\n</section>\r\n</div>\r\n</div>\r\n</section>\r\n<!-- /04 --><!-- foot-btn -->\r\n\r\n<div class=\"l-container recruit-footBtn mod-column-half clearfix\">\r\n<div class=\"mod-column-item\"><a class=\"recruit-footBtn__btn recruit-footBtn__btn--mes hoverNot\" href=\"/recruit/voice\"><span class=\"dn\">先輩社員の声 MESSAGE</span> </a></div>\r\n\r\n<div class=\"mod-column-item\"><a class=\"recruit-footBtn__btn recruit-footBtn__btn--ag hoverNot\" href=\"/recruit/guideline\"><span class=\"dn\">募集要項はこちら APPLICATION GUIDELINES</span> </a></div>\r\n</div>\r\n<!-- /foot-btn --></div>\r\n<!-- /sub-container --></section>\r\n              </div>\n    </main>\n    <!-- /main container -->\n    \n    <!-- footer -->\n    <footer role=\"contentinfo\" class=\"footer\">\n  <!-- footer-menu -->\n  <div class=\"footerMenu\">\n    <div class=\"footerMenu__inner l-container\">\n      <div class=\"footerMenuBtn--home\">\n        <a href=\"/\" class=\"hoverNot\">HOME</a>\n      </div>\n      <div class=\"clearfix\">\n        <ul class=\"footerMenuList\">\n          <li>\n            <a href=\"/about\">私たちの事業について</a>\n            <ul class=\"footerMenuList--sub\">\n                                            <li><a href=\"/about#division\">弊社の事業部</a></li>\n                <li><a href=\"/about#field\">事業分野</a></li>\n                <li><a href=\"/about#award\">表彰実績</a></li>\n                          </ul>\n          </li>\n        </ul>\n        <ul class=\"footerMenuList\">\n          <li>\n            <a href=\"/casebook/casebooks/\">事業実績</a>\n            <ul class=\"footerMenuList--sub\">\n                                            <li><a href=\"/casebook/casebooks#research_design\">設計部の実績</a></li>\n                <li><a href=\"/casebook/casebooks#survrying_research\">測量部の実績</a></li>\n                <li><a href=\"/casebook/casebooks#geological_research\">地質部の実績</a></li>\n                <li><a href=\"/casebook/casebooks#architecture_compensation\">建築補償部の実績</a></li>\n                          </ul>\n          </li>\n        </ul>\n        <ul class=\"footerMenuList\">\n          <li>\n            <a href=\"/company\">会社案内</a>\n            <ul class=\"footerMenuList--sub\">\n                                            <li><a href=\"/company#vision\">会社指針 / 社是・社訓</a></li>\n                <li><a href=\"/company#outline\">会社概要</a></li>\n                <li><a href=\"/company#access\">アクセス</a></li>\n                <li><a href=\"/company#office\">支店営業所</a></li>\n                <li><a href=\"/company#business\">業務登録</a></li>\n                <li><a href=\"/company#history\">沿 革</a></li>\n                          </ul>\n          </li>\n        </ul>\n        <ul class=\"footerMenuList\">\n          <li>\n            <a href=\"/recruit/index\">採用情報</a>\n            <ul class=\"footerMenuList--sub\">\n                                            <li><a href=\"#message\">代表メッセージ</a></li>\n                <li><a href=\"/recruit/voice\">先輩社員の声</a></li>\n                <li><a href=\"#qa\">Q＆A</a></li>\n                <li><a href=\"/recruit/guideline#mid_career\">中途採用情報</a></li>\n                <li><a href=\"/recruit/guideline#new_grad\">新卒採用情報</a></li>\n                <li><a href=\"/recruit/guideline#internship\">インターンシップ情報</a></li>\n                          </ul>\n          </li>\n        </ul>\n        <ul class=\"footerMenuList\">\n          <li><a href=\"/news/\">新着情報</a></li>\n          <li><a href=\"/blog/\">社員ブログ</a></li>\n          <li><a href=\"/contact/\">お問い合わせ</a></li>\n          <li><a href=\"/privacy\">プライバシーポリシー</a></li>\n          <li><a href=\"/information\">情報公開</a></li>\n        </ul>\n      </div>\n    </div>\n  </div>\n  <!-- /footer-menu -->\n  <div class=\"is-footerBtnStop\">\n        <!-- footer-main -->\n    <div class=\"l-container footerMain\">\n      <a href=\"/\" class=\"footerMain__logo\">\n        <img src=\"/theme/furukawa_consultant/img/common/footer_logo.png\" alt=\"株式会社古川コンサルタント\" class=\"imgFit\">\n      </a>\n      <p class=\"footerMain__address\">\n        〒693-0021 島根県出雲市塩冶町1612番地1\n        <span class=\"footerMain__address__tel\">TEL.<a href=\"tel:0853215131\">0853-21-5131</a>　FAX.0853-21-5154</span>\n      </p>\n      <p class=\"footerMain__copylight\">\n        © Furukawa Consultant Co., Ltd. All rights reserved.\n      </p>\n    </div>\n    <!-- /footer-main -->\n  </div>\n</footer>    <!-- /footer -->\n\n    <!-- pageTop -->\n    <div class=\"pageTop-box\">\n      <div id=\"pageTop--top\" class=\"pageTop\">\n        <img src=\"/theme/furukawa_consultant/img/common/btn_pgtop.png\" alt=\"ページトップに戻る\" class=\"imgFit\">\n      </div>\n    </div>\n    <!-- /pageTop -->\n      </body>\n\n</html>","finalUrl":"https://www.furukawact.co.jp/recruit/","rendered":false,"_cachedAt":"2026-06-23T21:42:09.745Z"}