fz16 u_medium\">\r\n                  <a href=\"/saiyo/career/introduction/\" class=\"g_link_transp\">イオンリテールとは</a>\r\n                  <a href=\"/saiyo/career/data_keywords/\" class=\"g_link_transp\">数字で見るイオンリテール</a>\r\n                </li>\r\n              </ul>\r\n            </li>\r\n            <li class=\"nav_btm_itm\">\r\n              <ul class=\"nav_btm_itm_inr\">\r\n                <li class=\"nav_btm_itm_inrItm\">\r\n                  <a href=\"/saiyo/career/index.html#top_sec03\" class=\"g_menu_ttl nav_ttl_career\">キャリア・制度</a>\r\n                </li>\r\n                <li class=\"nav_btm_itm_inrItm mt_25 u_fz16 u_medium\">\r\n                  <a href=\"/saiyo/career/training/\" class=\"g_link_transp\">研修・キャリアアップ支援</a>\r\n                  <a href=\"/saiyo/career/career/\" class=\"g_link_transp\">キャリア</a>\r\n                  <a href=\"/saiyo/career/wellness/\" class=\"g_link_transp\">福利厚生</a>\r\n                </li>\r\n              </ul>\r\n            </li>\r\n            <li class=\"nav_btm_itm\">\r\n              <ul class=\"nav_btm_itm_inr\">\r\n                <li class=\"nav_btm_itm_inrItm\">\r\n                  <a href=\"#recruitment_info\" class=\"g_menu_ttl nav_ttl_recruitment\">採用情報</a>\r\n                </li>\r\n                <li class=\"nav_btm_itm_inrItm mt_25 u_fz16 u_medium\">\r\n                  <a href=\"/company\" target=\"_blank\" class=\"g_tab\">企業情報</a>\r\n                  <a href=\"https://www.aeon.info/company/concept/\" target=\"_blank\" class=\"g_tab\">イオンの基本理念</a>\r\n                  <a href=\"https://www.aeon.info/company/code_of_conduct/\" target=\"_blank\" class=\"g_tab\">イオングループ未来ビジョン</a>\r\n                </li>\r\n              </ul>\r\n            </li>\r\n          </ul>\r\n        </div>\r\n        <div class=\"nav_btm_exLinks mt_40_md mt_40_sm pb_40_md pb_40_sm\">\r\n          <div class=\"g_btn g_entry_btn g_tab l_wrap_inr\">\r\n            <a href=\"https://aeonretail-career.snar.jp/index.aspx?id=LKEUQ1HzFto\" target=\"_blank\">ENTRY</a>\r\n          </div>\r\n          <ul class=\"nav_btm_lst u_fz16 mt_60_md mt_60_sm l_wrap_inr\">\r\n            <li class=\"nav_btm_itm\">\r\n              <a href=\"/company\" class=\"g_link_transp g_tab\" target=\"_blank\">イオンリテールコーポレートサイト</a>\r\n            </li>\r\n            <li class=\"nav_btm_itm\">\r\n              <a href=\"/terms/\" class=\"g_link_transp g_tab\" target=\"_blank\">サイトポリシー</a>\r\n            </li>\r\n            <li class=\"nav_btm_itm\">\r\n              <a href=\"https://www.aeon.info/privacy/\" class=\"g_link_transp g_tab\" target=\"_blank\">個人情報保護方針</a>\r\n            </li>\r\n          </ul>\r\n        </div>\r\n      </div>\r\n    </header>\r\n    <!-- /header -->\r\n\r\n    <!-- contents -->\r\n    <main class=\"l_wrapper u_bold top_main_cnt top_page\">\r\n      <section class=\"top_mv_sec l_wrap\">\r\n        <h2 class=\"g_top_ttl l_wrap_inr js_fadeIn\">\r\n          想像しよう、<span class=\"g_c_pnk\"><br class=\"u_sp\" />今以上の自分</span>を\r\n        </h2>\r\n        <picture class=\"mv_img_fade1 u_img js_fadeIn delay\">\r\n          <source media=\"(max-width: 576px)\" srcset=\"/saiyo/career/img/top/top_01_sp.jpg\" />\r\n          <img src=\"/saiyo/career/img/top/top_01.jpg\" alt=\"\" />\r\n        </picture>\r\n        <picture class=\"mv_img_fade2 u_img js_fadeIn delay\">\r\n          <source media=\"(max-width: 576px)\" srcset=\"/saiyo/career/img/top/top_04_sp.jpg\" />\r\n          <img src=\"/saiyo/career/img/top/top_04.jpg\" alt=\"\" />\r\n        </picture>\r\n        <picture class=\"mv_img_fade3 u_img js_fadeIn delay\">\r\n          <source media=\"(max-width: 576px)\" srcset=\"/saiyo/career/img/top/top_02_sp.jpg\" />\r\n          <img src=\"/saiyo/career/img/top/top_02.jpg\" alt=\"\" />\r\n        </picture>\r\n        <picture class=\"mv_img_fade4 u_img js_fadeIn delay\">\r\n          <source media=\"(max-width: 576px)\" srcset=\"/saiyo/career/img/top/top_03_sp.jpg\" />\r\n          <img src=\"/saiyo/career/img/top/top_03.jpg\" alt=\"\" />\r\n        </picture>\r\n        <div class=\"top_mv_sec_wrap l_wrap_inr\">\r\n          <p class=\"top_mv_txt u_regular js_fadeIn\">\r\n            この場所で今よりもっと成長した自分へ。<br />\r\n            この場所から広がり、つながる人々の輪を<br />\r\n            ともに想像・創造していこう。\r\n          </p>\r\n          <figure class=\"mv_img u_img mt_50 mt_150_sm u_pc u_tbl\">\r\n            <img src=\"/saiyo/career/img/top/top_back_01.jpg\" alt=\"\" />\r\n          </figure>\r\n          <figure class=\"mv_img u_img u_sp\">\r\n            <img src=\"/saiyo/career/img/top/top_back_01_sp.jpg\" alt=\"\" />\r\n          </figure>\r\n        </div>\r\n        <div class=\"g_scrollDown u_ic\">\r\n          <span class=\"u_tt_up g_en u_medium\">scroll</span>\r\n        </div>\r\n      </section>\r\n      <div class=\"top_txt_sec l_wrap_inr mt_200 mt_80_md mt_80_sm\">\r\n        <div class=\"top_txtx_sec_inr u_fz18 u_fz16_md\">\r\n          <p class=\"top_txt\">イオンリテールは、お客さまの<span class=\"g_c_pnk\">笑顔</span>あふれる豊かな<span class=\"g_c_pnk\">暮らし</span>とは何かを考え続け、<span class=\"g_c_pnk\">挑戦</span>を繰り返してきました</p>\r\n          <p class=\"top_txt mt_50 mt_50_sm\">それは、プライベートブランド<span class=\"g_c_pnk\">商品</span>の展開、EC、ネットスーパー、<br />非接触型のレジ導入、専門性を高めた店舗展開など、多岐に渡ります</p>\r\n          <p class=\"top_txt mt_50 mt_50_sm\">これからも、お客さまの<span class=\"g_c_pnk\">声</span>を聴き、たえず挑戦を続けていきます</p>\r\n          <p class=\"top_txt mt_50 mt_50_sm\">そして、イオンリテールには、店舗という最前線でのキャリアのほか、商品企画、マーケティング、IT、物流、財務・経理・人事<br class=\"br_1151\" />・総務・教育があり、これまでの<span class=\"g_c_pnk\">経験</span>を活かし、さらなる<span class=\"g_c_pnk\">成長</span>が可能なフィールドが広がっています</p>\r\n          <p class=\"top_txt mt_50 mt_50_sm\">それを後押しする教育制度も充実しています</p>\r\n          <p class=\"top_txt mt_50 mt_50_sm\">自分自身の成長に<span class=\"g_c_pnk\">期待</span>し、わたしたちイオンピープルとともに、挑戦し続ける<span class=\"g_c_pnk\">仲間</span>を歓迎します</p>\r\n        </div>\r\n      </div>\r\n      <section class=\"top_people_sec l_wrap_inr g_sec\" id=\"top_sec01\">\r\n        <h3 class=\"g_se