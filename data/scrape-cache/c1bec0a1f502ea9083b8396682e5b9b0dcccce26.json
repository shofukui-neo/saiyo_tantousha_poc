co.jp/recruit/\">採用メッセージ</a></li>\n<li><a href=\"https://www.skypalace.co.jp/staff/\">社員・パートナー企業紹介</a></li>\n<li><a href=\"https://www.skypalace.co.jp/recruit/application/\">募集要項</a></li>\n</ul>\n</li>\n<li><a href=\"https://www.skypalace.co.jp/news/\">新着情報</a></li>\n<li><a href=\"https://www.skypalace.co.jp/contact/\">お問い合わせ</a></li>\n\n</ul>\n</nav>\n</div>\n<div class=\"btn-close\">\n<a href=\"javascript:void(0);\"><img src=\"/common/close.png\" alt=\"閉じる\"></a>\n</div>\n</div>\n</div>\n<!-- /SPMENU -->\n</header><div id=\"main\"><img src=\"/images/main.png\" alt=\"\"></div>\r\n<article class=\"clearfix\">\r\n  <div id=\"content\">\r\n    <section id=\"message\" class=\"onebox\">\r\n      <h2>\r\n        <div class=\"spParts\"><img src=\"/images/title_sp_message.png\" alt=\"Message\"></div>絆と感動をデザインする\r\n      </h2>\r\n      <p>スカイパレスアソシエイツは、宮城県・福島県・栃木県・茨城県で<br class=\"pcParts\">8の店舗を運営するブライダルサービス企業です。<br>\r\n        私たちはすべてのお客様を、まるで家族のようなおもてなしでお迎えし<br class=\"pcParts\">絆と感動をデザインしていくことで、<br\r\n          class=\"pcParts\">人と人がご縁や深い絆で繋がっていく世の中を目指しています。</p>\r\n      <div class=\"btnAbout\">\r\n        <a href=\"https://www.skypalace.co.jp/about/\">経営理念<br>\r\n          へ</a>\r\n      </div>\r\n    </section>\r\n    <section id=\"company\" class=\"onebox\">\r\n      <h2>\r\n        <div class=\"spParts\"><img src=\"/images/title_sp_company.png\" alt=\"Company\"></div>スカイパレスアソシエイツについて\r\n      </h2>\r\n      <ul class=\"thirdbox clearfix\">\r\n        <li><a href=\"https://www.skypalace.co.jp/company/\"><img src=\"/images/img_company2.jpg\"\r\n              alt=\"会社概要\"><span>会社概要</span></a></li>\r\n        <li><a href=\"https://www.skypalace.co.jp/company/message/\"><img src=\"/images/img_message.jpg?2112\"\r\n              alt=\"代表からのご挨拶\"><span>代表からのご挨拶</span></a></li>\r\n        <li><a href=\"https://www.skypalace.co.jp/recruit/\"><img src=\"/images/img_recruit.jpg?2112\"\r\n              alt=\"採用情報\"><span>採用情報</span></a></li>\r\n      </ul>\r\n    </section>\r\n    <section id=\"news\" class=\"onebox\">\r\n      <h2>\r\n        <div class=\"spParts\"><img src=\"/images/title_sp_news.png\" alt=\"News\"></div>新着News\r\n      </h2>\r\n      <div id=\"newsWrap\">\r\n        <dl>\r\n                              <dt>2026.05.21</dt>\r\n          <dd>\r\n                        <a href=\"https://www.skypalace.co.jp/news//\"\r\n              class=\"\"></a>            <a href=\"https://www.skypalace.co.jp/news/%e3%80%90%e6%b8%a9%e6%b3%89%e3%82%a6%e3%82%a8%e3%83%87%e3%82%a3%e3%83%b3%e3%82%b0%e9%96%8b%e5%82%ac%e3%80%91%ef%bd%81%ef%bd%8e%ef%bd%83%ef%bd%92%ef%bd%85%ef%bd%85%ef%bd%92_%e3%82%a2%e3%83%b3%e3%82%af/\">【温泉ウエディング開催】ＡＮＣＲＥＥＲ_アンクレエ_</a>          </dd>\r\n                    <dt>2026.04.01</dt>\r\n          <dd>\r\n                        <a href=\"https://www.skypalace.co.jp/news//\"\r\n              class=\"\"></a>            <a href=\"https://www.skypalace.co.jp/news/%e3%80%90%e7%a6%8f%e5%b3%b6%e3%83%9f%e3%83%bb%e3%83%94%e3%82%a2%e3%83%bc%e3%83%81%e3%82%a7%e3%80%91%e4%bc%9a%e8%b2%bb%e5%88%b6%e3%82%a6%e3%82%a8%e3%83%87%e3%82%a3%e3%83%b3%e3%82%b0%e3%81%ae%e3%81%94/\">【ミ・ピアーチェ・セントヴェルジェ教会】会費制ウエディングのご案内</a>          </dd>\r\n                    <dt>2026.01.01</dt>\r\n          <dd>\r\n                        <a href=\"https://www.skypalace.co.jp/news//\"\r\n              class=\"\"></a>            <a href=\"https://www.skypalace.co.jp/news/%e6%96%b0%e5%b9%b4%e3%81%ae%e3%81%94%e6%8c%a8%e6%8b%b6-4/\">新年のご挨拶</a>          </dd>\r\n                    <!-- リセット/ -->\r\n                    <!-- /リセット -->\r\n        </dl>\r\n        <p class=\"textRight text12\"><a href=\"https://www.skypalace.co.jp/news/\">more &gt;&gt;&gt;</a></p>\r\n      </div>\r\n      <div class=\"introduction\">\r\n        <a href=\"/introduction/?utm_source=skypalace.co.jp&utm_medium=banner&utm_campaign=introduction\">\r\n          <img class=\"pc-only\" src=\"/images/bn_introduction_pc.png\" width=\"532\" height=\"100\" alt=\"結婚式応援プロジェクト\">\r\n          <img class=\"sp-only\" src=\"/images/bn_introduction_sp.png\" width=\"100%\" height=\"auto\" alt=\"結婚式応援プロジェクト\">\r\n        </a>\r\n      </div>\r\n    </section>\r\n\r\n    <section id=\"business\" class=\"onebox\">\r\n      <h2>\r\n        <div class=\"spParts\"><img src=\"/images/title_sp_business.png\" alt=\"Business\"></div>事業紹介\r\n      </h2>\r\n      <p class=\"lead\">本物の調度品にこだわり、一つひとつオリジナルのコンセプトで結婚式場を展開しています。</p>\r\n      <div class=\"clearfix\">\r\n\r\n        <!-- <div class=\"fullbox\">\r\n<a href=\"http://marielcourt-ip.jp/\" target=\"_blank\">\r\n<h3><img src=\"/images/logo_marielcortIP.jpg\" alt=\"マリエルコート インターパーク\"><span class=\"blank\"><img src=\"/common/icon_blank.png\" alt=\"外部リンク\"></span></h3>\r\n<img src=\"/images/img_marielcortIP.jpg\" alt=\"マリエルコート インターパーク\">\r\n</a>\r\n<p>パリの街並みをイメージした<br class=\"spParts\">1軒家貸切ゲストハウス</p>\r\n</div> -->\r\n\r\n        <div class=\"clearfix bgFlash\">\r\n          <div class=\"halfbox\">\r\n            <a href=\"http://marielcourt-ip.jp/\" target=\"_blank\">\r\n              <h3><img src=\"/images/logo_marielcortIP.jpg\" alt=\"マリエルコート インターパーク\"><span class=\"blank\"><img\r\n                    src=\"/common/icon_blank.png\" alt=\"外部リンク\"></span></h3>\r\n              <img src=\"/images/img_marielcort.jpg\" alt=\"マリエルコート インターパーク\">\r\n            </a>\r\n            <p>パリの街並みをイメージした<br class=\"spParts\">1軒家貸切ゲストハウス</p>\r\n          </div>\r\n          <div class=\"halfbox\">\r\n            <a href=\"http://soranowa-ss30.jp/\" target=\"_blank\">\r\n              <h3><img src=\"/images/logo_soranowa.jpg\" alt=\"SORANOWA\"><span class=\"blank\"><img\r\n                    src=\"/common/icon_blank.png\" alt=\"外部リンク\"></span></h3>\r\n              <img src=\"/images/img_soranowa.jpg\" alt=\"SORANOWA\">\r\n            </a>\r\n            <p>地上135ｍ・仙台を一望できる<br class=\"spParts\">天空のゲストハウス</p>\r\n          </div>\r\n        </div>\r\n\r\n        <div class=\"clearfix bgFlash\">\r\n          <div class=\"halfbox\">\r\n            <a href=\"http://atelier-ss30.jp/\" target=\"_blank\">\r\n              <h3><img src=\"/images/logo_atelier02.jpg\" alt=\"Atelier アトリエ ザ ウエディングギャラリー\"><span class=\"blank\"><img\r\n                    src=\"/common/icon_blank.png\" alt=\"外部リンク\"></span></h3>\r\n              <img src=\"/images/img_atelier.jpg\" alt=\"Atelier アトリエ ザ ウエディングギャラリー\">\r\n            </a>\r\n            <p>ナチュラルな貸切空間で叶える<br class=\"spParts\">アットホームなゲストハウス</p>\r\n          </div>\r\n          <div class=\"halfbox\">\r\n            <a href=\"http://www.mi-piace.jp/\" target=\"_blank\">\r\n              <h3><img src=\"/images/logo_mipiace.jpg\" alt=\"ミ・ピアーチェ\"><span class=\"blank\"><img\r\n                    src=\"/common/icon_blank.png\" alt=\"外部リンク\"></span></h3>\r\n              <img src=\"/images/img_mipiace02.jpg\" alt=\"ミ・ピアーチェ\">\r\n            </a>\r\n            <p>ふたりを祝福する地中海リゾートをモチーフにした<br class=\"spParts\">ゲストハウス</p>\r\n          </div>\r\n        </div>\r\n\r\n        <div class=\"clearfix bgFlash\">\r\n          <div class=\"halfbox\">\r\n            <a href=\"http://www.brimarry-court.jp/\" target=\"_blank\">\r\n              <h3><img src=\"/images/logo_brimarrycourt.jpg\" alt=\"ブライマリーコート\"><span class=\"blank\"><img\r\n                    src=\"/common/icon_blank.png\" alt=\"外部リンク\"></span></h3>\r\n              <img src=\"/images/img_brimarrycourt.jpg\" alt=\"ブライマリーコート\">\r\n            </a>\r\n            <p>クラシックなヨーロッパの雰囲気をモチーフにした<br class=\"spParts\">ゲストハウス</p>\r\n          </div>\r\n          <div class=\"halfbox\">\r\n            <a href=\"http://www.st-verger.com/\" target=\"_blank\">\r\n              <h3><img src=\"/images/logo_st-verger.jpg\" alt=\"St.ヴェルジュ協会\"><span class=\"blank\"><img\r\n                    src=\"/common/icon_blank.png\" alt=\"外部リンク\"></span></h3>\r\n              <img src=\"/images/img_st-verger02.jpg\" alt=\"St.ヴェルジュ協会\">\r\n            </a>\r\n            <p>南仏プロヴァンスをモチーフにした<br class=\"spParts\">ガーデン付き貸切ゲストハウス</p>\r\n          </div>\r\n     