"home\"><a href=\"https://www.kurabun.co.jp/recruit/\" class=\"arrow\">ホーム</a></li><li><a href=\"https://www.kurabun.co.jp/recruitment/graduate/\">新卒採用 募集要項</a></li></ol>\n  </div>\n  <!-- ▲ topicpath =============================== -->\n\n<!-- ▼ container =================================================== -->\n<div class=\"container\">\n\n<!-- ▼ content =========================================== -->\n<div class=\"content\">\n<div id=\"jsChangeContents\">\n\n<article>\n\n\n\n\n<!-- 1記事▼▼ -->\n\n<div class=\"acms-form-group\">\n\n\n</div>\n<article class=\"acms-entry\">\n\t<div class=\"acms-inner\">\n\t\t\n\n\t\t\n\t\t<!-- エントリーのタイトル　開始▼▼ -->\n\t\t\n\t\t\n\t\t<!-- エントリーのタイトル　終了▲▲ -->\n\t\t\n\n\t\t<section class=\"acms-grid\">\n\t\t\t<div>\n\t\t\t\n\t\t\t\n\n\n\n<!-- テキスト -->\n\n<h2 >応募と選考（2027年度）</h2>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n<!-- テキスト -->\n\n<table class=\"length-table\">\n\t<colgroup>\n\t\t<col width=\"12%\">\n\t\t<col width=\"88%\">\n\t</colgroup>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th>採用人員</th>\n\t\t\t<td>10名程度</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<th>採用学科</th>\n\t\t\t<td>全学部全学科</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<th>採用職種</th>\n\t\t\t<td>・法人営業<br>・営業サポート<br>・店舗販売（うさぎや）<br>・SE（システムエンジニア）<br>・CE（カスタマーエンジニア）<br>・CS（カスタマーサポート）<br>\n\t\t\t※募集人数に達した職種は応募を締め切らせていただきます</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<th>応募方法</th>\n\t\t\t<td>就職サイト（<a href=\"https://job.mynavi.jp/27/pc/search/corp74398/outline.html\" target=\"_blank\">マイナビ2027</a>）から応募</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<th>選考方法</th>\n\t\t\t<td>適性検査、面接</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<th>採用実績校</th>\n\t\t\t<td>＜大学院＞<br>\n\t\t\t京都大学、岡山大学<br>\n\t\t\t＜大学＞<br>\n\t\t\t大阪大学、香川大学、神戸大学、広島大学、岡山大学、島根大学、徳島大学、岡山県立大学、同志社大学、立命館大学、関西大学、京都産業大学、近畿大学、岡山商科大学、岡山理科大学、倉敷芸術科学大学、福山大学、福山市立大学、福岡大学、松山大学、中京大学、神戸女子大学、ノートルダム清心女子大学、就実大学、愛知学院大学、青山学院大学、大分大学、大阪学院大学、兵庫県立大学、中国職業能力開発大学校（応用課程）、中部大学、東亜大学、横浜市立大学、四国学院大学、川崎医療福祉大学、山陽学園大学、愛媛大学、尾道市立大学<br>\n\t\t\t＜短大・高専・専門学校＞<br>\n\t\t\t就実短期大学、専門学校ビーマックス、岡山科学技術専門学校、コンピュータ総合学園HAL、専門学校岡山情報ビジネス学院、専門学校岡山ビジネスカレッジ 他</td>\n\t\t</tr>\n\t</tbody>\n</table>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n<!-- テキスト -->\n\n<h2 >待遇と勤務</h2>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n<!-- テキスト -->\n\n<table class=\"length-table\">\n\t<colgroup>\n\t\t<col width=\"12%\">\n\t\t<col width=\"18%\">\n\t\t<col width=\"70%\">\n\t</colgroup>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th rowspan=\"4\">初任給</th>\n\t\t\t<td><b>○大学院了</b></td>\n\t\t\t<td>267,200円</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<td><b>○四大卒（総合職）</b></td>\n\t\t\t<td>260,000円</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<td><b>○四大卒（一般職）</b></td>\n\t\t\t<td>250,400円</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<td><b>○短大・専門卒</b></td>\n\t\t\t<td>240,000円</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<th>諸手当</th>\n\t\t\t<td colspan=\"2\">残業手当、通勤手当、住宅手当、家族手当</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<th>昇給</th>\n\t\t\t<td colspan=\"2\">年1回（5月）</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<th>賞与</th>\n\t\t\t<td colspan=\"2\">年2回（6月、12月）</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<th>勤務地</th>\n\t\t\t<td colspan=\"2\">【法人営業】本社、岡山支店、福山営業所<br>【営業サポート】OSセンター<br>【店舗販売（うさぎや）】うさぎや各店舗<br>【SE（システムエンジニア）】本社<br>【CE（カスタマーエンジニア）】本社<br>【CS（カスタマーサポート）】技術・配送センター</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<th>勤務時間</th>\n\t\t\t<td colspan=\"2\">【店舗販売（うさぎや）以外】9:00-18:00<br>【店舗販売（うさぎや）】9:30-18:30&nbsp;または12:00-21:00のシフト制</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<th>休日休暇</th>\n\t\t\t<td colspan=\"2\">年間休日120日以上<br>\n\t\t\t土・日・祝（完全週休二日制）<br>\n\t\t\t夏期休暇、年末年始休暇、有給休暇、慶弔休暇有り</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<th>福利厚生</th>\n\t\t\t<td colspan=\"2\">各種社会保険、企業年金制度、保養所、クラブ活動（野球部、Sand and Buggy、コンテンツクリエイト、ゴルフ、釣り、アウトドア、ボウリング、ラケット、うどん、ちゃりんこ、エクストリームスポーツ、写真、一流会、軽音、新鮮組、美酒会、野球、フットボール）、社員研修旅行、ボウリング大会　他<br></td>\n\t\t</tr>\n\t</tbody>\n</table>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n<!-- テキスト -->\n\n<h2 >連絡先</h2>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\