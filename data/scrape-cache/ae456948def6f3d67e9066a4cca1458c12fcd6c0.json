<img src=\"../../2.1/img/logo_w.svg\" alt=\"金沢機工株式会社\"></div>\n  </div>\n</div>\n<header>\n  <div class=\"lang\">\n    <ul class=\"flex\">\n      <li><a href=\"https://www.kanazawakiko.jp/\" class=\"active\">JPN</a></li>\n      <li><a href=\"https://www.kanazawakiko.jp/cn/\">CH</a></li>\n    </ul>\n  </div>\n  <div class=\"flex\">\n    <h1 id=\"logo\" class=\"pc\"><span>ものづくりソリューションカンパニー</span><br>\n      <a href=\"https://www.kanazawakiko.jp/\"><img src=\"../../2.1/img/logo.svg\" alt=\"金沢機工株式会社\"></a></h1>\n    <h2>業務効率化・生産性向上のお悩みは金沢機工へ！<br>\n      私たちはこれからの商社の新しいカタチをご提案します</h2>\n    <ul class=\"searchBox\">\n      <script async src=\"https://cse.google.com/cse.js?cx=b6f306baba8764ea9\"></script>\n      <form id=\"cse-search-box\" action=\"https://google.com/cse\" autocomplete=\"on\">\n        <input type=\"hidden\" name=\"cx\" value=\"b6f306baba8764ea9\" />\n        <input type=\"hidden\" name=\"ie\" value=\"UTF-8\" />\n        <input id=\"search\" name=\"q\" type=\"text\" placeholder=\"検索キーワードを入力してください\">\n        <input id=\"search_submit\" name=\"sa\" value=\"Rechercher\" type=\"submit\">\n      </form>\n      <script src=\"https://www.google.com/cse/brand?form=cse-search-box&lang=ja\"></script>\n    </ul>\n  </div>\n  <nav class=\"navbar navbar-expand-lg navbar-dark\">\n    <div class=\"container-fluid\">\n      <h1 id=\"logo_sp\"><a class=\"navbar-brand sp\" href=\"https://www.kanazawakiko.jp/\"><span>ものづくりソリューションカンパニー</span><img src=\"../../2.1/img/logo.svg\" alt=\"金沢機工株式会社\"></a></h1>\n      <button class=\"navbar-toggler\" type=\"button\" data-bs-toggle=\"collapse\" data-bs-target=\"#main_nav\"  aria-expanded=\"false\" aria-label=\"Toggle navigation\"> <span class=\"navbar-toggler-icon\"></span> </button>\n      <div class=\"collapse navbar-collapse\" id=\"main_nav\">\n        <ul class=\"navbar-nav\">\n          <li class=\"nav-item dropdown\"> <a class=\"nav-link dropdown-toggle\" href=\"#\" id=\"nav_about\" role=\"button\" data-bs-toggle=\"dropdown\" aria-expanded=\"false\" aria-haspopup=\"true\">会社案内</a>\n            <ul class=\"dropdown-menu child-list\" aria-labelledby=\"nav_about\">\n              <li><a href=\"../../aboutus/#mission\">経営理念</a></li>\n              <li><a href=\"../../aboutus/#message\">代表ご挨拶</a></li>\n              <li><a href=\"../../aboutus/#profile\">会社概要</a></li>\n              <li><a href=\"../../aboutus/#officer\">役員紹介</a></li>\n              <li><a href=\"../../aboutus/#history\">沿革</a></li>\n              <li><a href=\"../../aboutus/#commendation\">受賞・認定・記事掲載歴</a></li>\n            </ul>\n          </li>\n          <li class=\"nav-item\"><a class=\"nav-link\" href=\"../../vision/\">ビジョン</a></li>\n          <li class=\"nav-item dropdown\"> <a class=\"nav-link dropdown-toggle\" href=\"#\" id=\"nav_sus\" role=\"button\" data-bs-toggle=\"dropdown\" aria-expanded=\"false\" aria-haspopup=\"true\">サスティナビリティ</a>\n            <ul class=\"dropdown-menu child-list\" aria-labelledby=\"nav_sus\">\n              <li><a href=\"../../environment/\">環境への取り組み</a></li>\n              <li><a href=\"../../category/sustainability-social-effort/\">社会的な取り組み</a></li>\n            </ul>\n          </li>\n          <li class=\"nav-item dropdown\"> <a class=\"nav-link dropdown-toggle\" href=\"#\" id=\"nav_original\" role=\"button\" data-bs-toggle=\"dropdown\" aria-expanded=\"false\">オリジナル商品</a>\n            <ul class=\"dropdown-menu child-list\" aria-labelledby=\"nav_original\">\n              <li><a href=\"../../original/kikouhou/\">機工報</a></li>\n\t\t\t  <li><a href=\"../../original/robottana/\">ROBOTTANA</a></li>\n\t\t\t  <li><a href=\"../../original/bolt-picking-system/\">ボルトピッキングシステム</a></li>\n            </ul>\n          </li>\n          <li class=\"nav-item dropdown\"> <a class=\"nav-link dropdown-toggle\" href=\"#\" id=\"nav_collabo\" role=\"button\" data-bs-toggle=\"dropdown\" aria-expanded=\"false\">コラボレーション</a>\n            <ul class=\"dropdown-menu child-list\" aria-labelledby=\"nav_collabo\">\n              <li><a href=\"../../collaboration/carbonizer/\">炭化装置</a></li>\n            </ul>\n          </li>\n          <li class=\"nav-item\"><a class=\"nav-link\" href=\"../../allnews/\">NEWS</a></li>\n          <li class=\"nav-item\"><a class=\"nav-link\" href=\"../../blog/\">コラム</a></li>\n          <li class=\"nav-item\"><a class=\"nav-link\" href=\"../../jobs/\">採用情報</a></li>\n          <li class=\"nav-item\"><a class=\"nav-link\" href=\"../../inquiry/\">お問い合わせ</a></li>\n          <li class=\"nav-item service_link\"><a class=\"nav-link\" href=\"https://service.kanazawakiko.jp/\">商材情報サイトへ</a></li>\n        </ul>\n      </div>\n    </div>\n  </nav>\n</header>\n\n<div class=\"page_ti\"><!-- InstanceBeginEditable name=\"page-img\" --><img src=\"../../2.1/img/jobs/voice/voice_ti.jpg\" alt=\"先輩たちの声\"><!-- InstanceEndEditable -->\n  <div class=\"wrap\">\n    <div class=\"page_ti_in\">\n      <h3><!-- InstanceBeginEditable name=\"page-title\" -->先輩たちの声<!-- InstanceEndEditable --></h3>\n    </div>\n  </div>\n</div>\n\n<article>\n  <main class=\"container\">\n    <ul class=\"list clearfix\">\n      <li><a href=\"https://www.kanazawakiko.jp/\">HOME</a></li>\n      <!-- InstanceBeginEditable name=\"list-page-title\" -->\n      <li><a href=\"../\">先輩たちの声</a></li>\n      <li>K・Wさん</li>\n      <!-- InstanceEndEditable -->\n    </ul>\n    <!-- InstanceBeginEditable name=\"main\" -->\n    <div id=\"interview_top\"> <img src=\"../../2.1/img/jobs/voice/employee01-1.jpg\" alt=\"\" oncontextmenu=\"alert('この画像は保存をお断りしております'); return false;\">\n      <div>\n        <p>大手企業を担当する彼の仕事への思いとは</p>\n        <p class=\"ini\">K・W　2014年入社</p>\n        <p>営業職の仕事について</p>\n      </div>\n    </div>\n    <div class=\"flex3 reverse mab32\">\n      <div class=\"interview_img\"><img src=\"../../2.1/img/jobs/voice/employee01-2.jpg\" alt=\"\" width=\"100%\" oncontextmenu=\"alert('この画像は保存をお断りしております'); return false;\"></div>\n      <div class=\"interviewR\">\n        <p class=\"kikite bold\">金沢機工に入社した理由を教えてください。</p>\n        <p class=\"mab20\">学生時代、飲食店でのアルバイトを通して接客の楽しさ・やりがいを実感し、人と関わる仕事がしたいと思い、営業職を志望していました。</p>\n        <p class=\"mab20\">営業職の中でも、地場で盛んなものづくりへの憧れがあったこともあり、その中で、当社の存在を知りました。</p>\n        <p>文系出身ということもあり、まったく未経験の分野でしたが、社是である「企業は人なり」という理念の通り、会社説明会や入社試験、インターンシップで訪問した際、右も左も分からない私に丁寧・親切に接していただき、この会社ならば絶対に成長出来ると確信出来たことが入社の決め手でした。</p>\n      </div>\n    </div>\n    <div class=\"flex3 mab32\">\n      <div class=\"interview_img\"><img src=\"../../2.1/img/jobs/voice/employee01-3.jpg\" alt=\"\" width=\"100%\" oncontextmenu=\"alert('この画像は保存をお断りしております'); return false;\"></div>\n      <div class=\"interviewR\">\n\t\t<p class=\"kikite bold\">仕事内容を教えてください。</p>\n        <p class=\"mab48\">「生産財」と呼ばれる、ものづくりを行うために使われる機器や機械・工具等のルートセールスを行っています。「生産財」と一口にいっても、当社の取り扱っている商品群はネジ1本から大きいものになると今流行りの産業用ロボットや工作機械等、非常に多岐に渡ります。数えきれない程の製品の中から最適な物を選定し、お客様の要望にあった製品を提案することが私の仕事です。</p>\n        <p class=\"kikite bold\">どのようなところに仕事のやりがいを感じますか？</p>\n        <p>ものづくりのプロであるお客様からお困り事を相談されることもあり、何度も打ち合わせを重ね、問題解決につなげることができた時などお客様と共にものづくりを行っていけることにやりがいを感じます。</p>\n      </div>\n    </div>\n    <div class=\"flex3 reverse mab32\">\n      <div class=\"interview_img\"><img src=\"../../2.1/img/jobs/voice/employee01-4.jpg\" alt=\"\" width=\"100%\" oncontextmenu=\"alert('この画像は保存をお断りしております'); return false;\"></div>\n      <div class=\"interviewR\">\n        <p class=\"kikite bold\">今後の目標を教えてください。</p>\n        <p class=\"mab20\">家族や周囲の人々に自慢できるような製品やサービスを世の中に提供する。</p>\n        <p>お客様はもちろん社会から「選ばれる会社」となり、継続して発展し続ける会社を目指し続けていくことです。</p>\n      </div>\n    </div>\n    <div class=\"mab32\">\n      <p class=\"kikite bold\">就職活動中の学生さんへのメッセージ</p>\n      <p class=\"mab20\">学生のうちは知名度のある会社や規模の大きい会社に憧れもあるかもしれませんが、大切なことは自分が将来どういった仕事で輝きたいかだと思います。</p>\n        <p class=\"mab20\">そして、自分が興味のあること、やりたいことを仕事にしなければモチベーションを保つことは難しいと思います。<br class=\"pc\">その幅を広げられるように少しでも多くの企業の会社説明会に参加し、実際に訪問して社内の雰囲気を自分の目で確かめることをお勧めします。</p>\n\t\t<p>就職活動は自分の今後の人生を大きく左右する分岐点です。悔いのない人生を送っていけるように、今しかできない就職活動を全力で楽しんでください。</p>\n    </div>\n    <div class=\"schedule\"> <span class=\"box-title\">1日の主なスケジュール</span>\n      <dl>\n        <div>\n          <dt>8:30</dt>\n          <dd>出社・訪問準備</dd>\n        </div>\n        <div>\n          <dt>8：30～10：00</dt>\n          <dd>事務処理（お客様からの問い合わせ回答、見積や提案資料の作成等）</dd>\n        </div>\n        <div>\n          <dt>10：00～16：00</dt>\n          <dd>外回り（金沢市内メイン）</dd>\n        </div>\n        <div>\n          <dt>16：00～18：00</dt>\n          <dd>事務処理、営業ミーティング、勉強と拡販のための製品講習会等</dd>\n        </div>\n      </dl>\n    </div>\n    <!-- InstanceEndEditable --></main>\n</article>\n\n<footer>\n  <div class=\"sns\">\n    <section class=\"wrap flex3 aic\">\n      <h3>KANAZAWA KIKO SNS</h3>\n      <ul>\n        <li class=\"x-twitter\"><a href=\"https://x.com/05qgL9AK7GT0cQd\"><i class=\"fa-brands fa-x-twitter fa-3x\"></i></a></li>\n        <li class=\"youtube\"><a href=\"https://www.youtube.com/channel/UCqj73e8UXUUahWiRbjbyxKg\"><i class=\"fab fa-youtube fa-3x\"></i></a></li>\n        <li class=\"instagram\"><a href=\"https://www.instagram.com/kanazawakiko/\"><i class=\"fab fa-instagram fa-3x\"></i></a></li>\n      </ul>\n    </section>\n  </div>\n  \n  <section class=\"bn_link\">\n    <h3>リンク<span>LINK</span></h3>\n    <ul class=\"flex4\">\n      <li class=\"trans\"><a href=\"http://www.keskyoto.org/kesinfo/\"><img src=\"../../2.1/img/bn_kes.jpg\" alt=\"KES・環境マネジメントシステム・スタンダード\"></a></li>\n      <li class=\"trans\"><a href=\"https://www.tekkokiden.jp/mex/\"><img src=\"../../2.1/img/bn_mex.jpg\" alt=\"MEX\"></a></li>\n      <li class=\"trans\"><a href=\"http://www.zweigen-kanazawa.jp/\"><img src=\"../../2.1/img/bn_zweigen.gif\" alt=\"ツウェーゲンオフィシャルサイト\"></a></li>\n    </ul>\n  </section>\n  <div class=\"wrap\">\n    <ul class=\"foot-link\">\n      <li><a href=\"../../pp/\">プライバシーポリシー</a></li>\n\t  <li><a href=\"../../pdf/isbp.pdf\" target=\"_blank\">情報セキュリティ基本方針</a></li>\n    </ul>\n  </div>\n  <div class=\"foot_end\">\n    <div class=\"wrap\">\n      <ul class=\"flex3 aic\">\n        <li><img src=\"../../2.1/img/logo_w.svg\" alt=\"金沢機工株式会社\"><br>\n          〒920-0332　石川県金沢市無量寺町ハ38番地2</li>\n        <li>\n          <p id=\"copy\">Copyright&copy;<script>    myDate = new Date();    myYear = myDate.getFullYear();    document.write(myYear);  </script>&nbsp;Kanazawa Kiko&nbsp;All&nbsp;Rights&nbsp;Reserved.</p>\n        </li>\n      </ul>\n    </div>\n  </div>\n</footer>\n<script src=\"https://cdn.jsdelivr.net/npm/bootstrap@5.0.0-beta2/dist/js/bootstrap.bundle.min.js\" crossorigin=\"anonymous\"></script> \n<script src=\"https://cdnjs.cloudflare.com/ajax/libs/jquery/3.1.1/jquery.min.js\"></script> \n<script defer src=\"https://use.fontawesome.com/releases/v5.10.2/js/all.js\"></script> \n<!-- bxSlider Javascript file --> \n<script src=\"../../2.1/js/jquery.bxslider.min.js\"></script> \n<script>\n\t$(document).ready(function(){\n\t\t$('.bxslider').bxSlider({\n\t\t\tmode: 'horizontal',\n\t\t\tmoveSlides: 1,\n\t\t\tslideMargin: 0,\n\t\t\tinfiniteLoop: true,\n\t\t\tauto:true,\n\t\t\tminSlides: 1,\n\t\t\tmaxSlides: 1,\n\t\t\tspeed: 3000,\n\t\t\tcontrols:true,\n\t\t\tpager:true,\n\t\t\thideControlOnEnd: true\n\t\t});\n\t});\n  </script> \n<script src=\"../../2.1/js/script2.js\"></script> \n<script src=\"../../2.1/js/script.js\"></script> \n\n<p id=\"page-top\"><a href=\"#top\"><i class=\"fas fa-chevron-circle-up\"></i><br>\n  page<br>\n  top</a></p>\n\n</body>\n<!-- InstanceEnd --></html>\n","finalUrl":"https://www.kanazawakiko.jp/jobs/voice/index01.html","rendered":false,"_cachedAt":"2026-06-23T20:46:45.136Z"}