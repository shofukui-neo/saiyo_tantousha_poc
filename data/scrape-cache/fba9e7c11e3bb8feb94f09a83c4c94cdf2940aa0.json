><!-- /.container -->\n  </nav>\n\n\n  <!-- スマホ用メニュー -->\n  <div class=\"visible-xs\">\n    <div class=\"menu-btn\">\n      <a class=\"btn-open\" href=\"javascript:void(0)\"><span class=\"menu-off\">MENU</span></a>\n    </div>\n    <div class=\"overlay\">\n      <div class=\"menu\">\n        <ul>\n          <li><a title=\"home\" href=\"./index.html\"><img src=\"./images/home_white.png\" alt=\"トップページ\"></a></li>\n          <li><a title=\"news\" href=\"./news/index.html\">お知らせ</a></li>\n          <li><a title=\"service\" href=\"./service/index.html\" class=\"line\">業務案内</a></li>\n          <li><a title=\"realestate\" href=\"./realestate/index.html\" class=\"line\">不動産情報</a></li>\n          <li><a title=\"company\" href=\"./company/index.html\" class=\"line\">会社案内</a></li>\n          <li><a title=\"recruit\" href=\"./recruit/index.html\" class=\"line\">採用情報</a></li>\n          <li><a title=\"access\" href=\"./access/index.html\" class=\"line\">アクセス</a></li>\n          <li><a title=\"privacy\" href=\"./privacy/index.html\">個人情報保護方針</a></li>\n        </ul>\n      </div>\n    </div>\n  </div>\n\n\n  <!-- Video Markup -->\n  <div>\n    <div class=\"masthead\">\n      <video id=\"video\" class=\"masthead-video\" autoplay loop muted poster=\"./images/top/poster.jpg\">\n        <source src=\"./videos/movie2019.mp4\" type=\"video/mp4\">\n      </video>\n\n      <div class=\"masthead-overlay\"></div>\n      <div class=\"masthead-arrow\"></div>\n      <div class=\"slide-inner-content\">\n        <h2>人と街に響きあう、<br class=\"visible-md\">いくつもの豊かさ、いくつもの快適<img src=\"./images/main_logo.png\" alt=\"株式会社ベルックス\"></h2>\n      </div>\n      <!--<h2>テキストテキストテキスト<br class=\"visible-xs\">テキスト<span>テキストテキスト<br class=\"visible-xs\">テキストテキストテキスト</span></h2>-->\n      <!-- <p class=\"soundCtr\"><span class=\"soundOn\">ON</span><span class=\"soundOff\">OFF</span></p> -->\n    </div>\n  </div>\n  <!-- /Video Markup -->\n\n  <div class=\"sp-main-image\">\n    <h2>人と街に響きあう、<br>いくつもの豊かさ、いくつもの快適<img src=\"./images/main_logo.png\" alt=\"株式会社ベルックス\"></h2>\n  </div><!--/ sp-main-image-->\n\n\n  <section class=\"content01\">\n    <div class=\"container\">\n      <div class=\"row wrap\">\n        <div class=\"wow fadeInUp\" data-wow-delay=\"0.1s\">\n\n          <!-- <div class=\"text-block\">\n            <h3 class=\"title\">快適で安心できる環境創造を<br>トータルに提案する総合企業です</h3>\n            <p>今日、都市環境や各種の建築物は、運営、管理維持、防犯・防災の面から多岐にわたるスペシャリストが求められ、それら公共性の高い建築物の管理は社会的な責任ともいわれています。</p>\n\n            <div class=\"hidden-lg hidden-md center\"><img src=\"./images/top/sp01.png\" alt=\"会社案内\"></div>\n          </div> -->\n\n          <h3 class=\"title\">快適で安心できる環境創造を<br class=\"visible-xs hidden-md\">トータルに提案する総合企業です</h3>\n          <p>今日、都市環境や各種の建築物は、運営、管理維持、防犯・防災の面から多岐にわたるスペシャリストが求められ、それら公共性の高い建築物の管理は社会的な責任ともいわれています。ベルックスでは、建物・施設の資産価値を維持・向上させるため、お客様のニーズに総合的なスタンスでお応えしさまざまなサービスを提供しております。</p>\n          <div><img src=\"./images/top/bg01_02.png\"></div>\n\n          <a class=\"link-btn\" href=\"./company/index.html\">会社案内</a>\n\n        </div>\n      </div>\n    </div>\n  </section>\n\n\n  <section class=\"content02\">\n    <div class=\"container\">\n      <div class=\"row wrap\">\n        <div class=\"wow fadeInUp\" data-wow-delay=\"0.1s\">\n\n          <!-- <div class=\"cf\">\n            <div class=\"text-block\">\n              <h3 class=\"title\">総合業務による高い精度と<br>コストパフォーマンス</h3>\n              <p>清掃、警備、設備・メンテナンス、ファシリティマネジメントなどのサービスを提供し、内容と質ともに、道内のトップランクにふさわしい水準と評価をいただいています。</p>\n\n              <div class=\"hidden-lg hidden-md center\"><img src=\"./images/top/sp02.png\" alt=\"会社案内\"></div>\n            </div>\n          </div> -->\n          <h3 class=\"title hidden-xs\">総合業務による高い精度とコストパフォーマンス</h3>\n          <h3 class=\"title visible-xs\">高い精度とコストパフォーマンス</h3>\n            <p>清掃、警備、設備・メンテナンス、ファシリティマネジメントなどのサービスを提供し、内容と質ともに、道内のトップランクにふさわしい水準と評価をいただいています。</p>\n            <div class=\"hidden-xs\"><img src=\"./images/top/bg02_02new.png\"></div>\n            <div class=\"visible-xs\"><img src=\"./images/top/bg02_02_sp_new.png\"></div>\n\n          <a class=\"link-btn\" href=\"./service/index.html\">業務案内</a>\n\n        </div>\n      </div>\n    </div>\n  </section>\n\n\n  <section class=\"content03\">\n    <div class=\"container\">\n      <div class=\"row wrap\">\n        <div class=\"wow fadeInUp\" data-wow-delay=\"0.1s\">\n\n            <h3 class=\"title\">ベルックスの自社管理物件</h3>\n            <p>ホームセキュリティ、設備･メンテンナンス、清掃などの業務を行っている弊社だからこそ、自信を持っておすすめできる管理物件です。<br class=\"visible-xs\">気になる物件がございましたらお気軽お問い合わせください。</p>\n\n            <ul class=\"mainte-list\">\n                <li>\n                  <img src=\"./images/top/pic01_01.jpg\" alt=\"ベルックス北５条ビル\">\n                  <p class=\"name\">ベルックス北５条ビル</p>\n                  <p class=\"mainte-comment\">札幌市中央区北5条西12丁目2番地</p>\n                </li>\n                <li>\n                  <img src=\"./images/top/pic01_02.jpg\" alt=\"ベルックス新宿ビル\">\n                  <p class=\"name\">ベルックス新宿ビル</p>\n                  <p class=\"mainte-comment\">東京都新宿区愛住町23番地14</p>\n                </li>\n                <li>\n                  <img src=\"./images/top/pic01_03.jpg\" alt=\"ベルックス新宿ビルⅡ\">\n                  <p class=\"name\">ベルックス新宿ビルⅡ</p>\n                  <p class=\"mainte-comment\">東京都新宿区愛住町23番地2</p>\n                </li>\n              </ul>\n\n\n          <a class=\"link-btn\" href=\"./realestate/index.html\">不動産情報</a>\n\n        </div>\n      </div>\n    </div>\n  </section>\n\n\n  <section class=\"news\">\n   <div class=\"container\">\n     <div class=\"row wrap\">\n       <div class=\"wow fadeInUp\" data-wow-delay=\"0.1s\">\n\n         <h3 class=\"title\">information</h3>\n\n         <div id=\"style-1\" class=\"scrollbar\">\n           <div id=\"news_block\">\n\n              <!--最新1行のみ表示-->\n            \n            <a href=\"./news/index.html?id=news-55\">\n              <dl>\n                <dt>2026年5月27日<span class=\"realestate\">不動産情報</span></dt>\n                <dd>不動産情報を更新しました</dd>\n              </dl>\n 