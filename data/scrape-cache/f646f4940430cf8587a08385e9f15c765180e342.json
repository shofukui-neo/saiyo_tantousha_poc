{"url":"https://www.imagiire.co.jp/company/","html":"<!DOCTYPE html>\r\n<html lang=\"ja\">\r\n<head>\r\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\r\n<meta charset=\"UTF-8\">\r\n<meta name=\"author\" content=\"株式会社 イマギイレ\">\r\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\r\n\r\n\r\n<title>採用情報｜建設機械レンタルのイマギイレ</title>\r\n<meta name=\"Keywords\" content=\"採用情報,建設機械,レンタル,イマギイレ\">\r\n<meta name=\"Description\" content=\"建設機械レンタルイマギイレの採用情報をご紹介しています。\">\r\n\r\n<meta property=\"og:title\" content=\"採用情報｜建設機械レンタルのイマギイレ\">\r\n<meta property=\"og:description\" content=\"建設機械レンタルイマギイレの採用情報をご紹介しています。\">\r\n<meta property=\"og:image\" content=\"\">\r\n<meta property=\"og:type\" content=\"website\">\r\n<meta property=\"og:site_name\" content=\"建設機械レンタルのイマギイレ\">\r\n<meta property=\"og:url\" content=\"https://www.imagiire.co.jp/employ/company/\">\r\n\r\n<link rel=\"home\" href=\"/\" title=\"建設機械レンタルのイマギイレ\" >\r\n<link rel=\"index\" href=\"/sitemap/\" title=\"建設機械レンタルのイマギイレ サイトマップ\" >\r\n<link rel=\"alternate\" media=\"handheld\" href=\"/employ/company/\" >\r\n\r\n<meta name=\"robots\" content=\"INDEX,FOLLOW\">\r\n<meta name=\"robots\" content=\"NOODP\">\r\n<meta name=\"robots\" content=\"NOYDIR\">\r\n\r\n\r\n\r\n<script src=\"https://www.google.com/jsapi\"></script>\r\n\r\n<!--<script type=\"text/javascript\" src=\"/files/user/common/js/default.js\"></script>-->\r\n<script type=\"text/javascript\" src=\"/files/user/common/js/jquery.js\"></script>\r\n<script type=\"text/javascript\" src=\"/js/default.v2.js\"></script>\r\n\r\n<script type=\"text/javascript\">\r\ngoogle.load(\"jquery\", \"1.7\");\r\n</script>\r\n\r\n<!--<script type=\"text/javascript\" src=\"/files/user/common/js/scrollsmoothly.js\"></script>-->\r\n<script type=\"text/javascript\" src=\"/files/user/common/js/jquery.corner.js\"></script>\r\n<script type=\"text/javascript\" src=\"/files/user/common/js/heightLine.js\"></script>\r\n<script type=\"text/javascript\" src=\"/files/use