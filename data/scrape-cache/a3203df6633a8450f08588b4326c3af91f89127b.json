{"url":"https://rococoweb.co.jp/","html":"<!DOCTYPE html>\n<html class=\"no-js\" lang=\"ja\">\n  <head>\n    <meta charset=\"UTF-8\" />\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n    <link rel=\"profile\" href=\"https://gmpg.org/xfn/11\" />\n    <title>株式会社ロココ</title>\n    <meta\n      name=\"description\"\n      content=\"大阪からECサイトを通じて全国へファッションアイテムをお届けする「ROCOCO」「Gochi」を運営する株式会社ロココです。\"\n    />\n    <meta\n      name=\"google-site-verification\"\n      content=\"Jv9ecWEw624Yqd5St43z8JPd1b_1I4acMU95bV6r3FE\"\n    />\n    <link rel=\"canonical\" href=\"https://rococoweb.co.jp/\" />\n    <script type=\"text/javascript\">\n      window.ga =\n        window.ga ||\n        function () {\n          (ga.q = ga.q || []).push(arguments);\n        };\n      ga.l = +new Date();\n      ga(\"create\", \"UA-164909322-1\", \"auto\");\n      // Plugins\n      ga(\"require\", \"outboundLinkTracker\");\n      ga(\"send\", \"pageview\");\n    </script>\n    <script async src=\"https://www.google-analytics.com/analytics.js\"></script>\n    <link rel=\"stylesheet\" href=\"./css/contact.css\" media=\"all\" />\n    <link\n      rel=\"stylesheet\"\n      id=\"parent-style-css\"\n      href=\"./css/style.css\"\n      media=\"all\"\n    />\n    <link\n      rel=\"stylesheet\"\n      id=\"twentytwenty-style-css\"\n      href=\"./css/child-style.css\"\n      media=\"all\"\n    />\n    <style id=\"custom-background-css\">\n      body.custom-background {\n        background-color: #ffffff;\n      }\n    </style>\n    <script src=\"./js/jquery-3.7.0.min.js\"></script>\n    <script\n      src=\"https://www.googletagmanager.com/gtag/js?id=UA-164909322-1\"\n      async\n    ></script>\n    <script>\n      window.dataLayer = window.dataLayer || [];\n      function gtag() {\n        dataLayer.push(arguments);\n      }\n      gtag(\"js\", new Date());\n      gtag(\"config\", \"UA-164909322-1\", { anonymize_ip: true });\n    </script>\n    <link\n      rel=\"icon\"\n      href=\"./img/uploads/2020/04/cropped-icon-32x32.png\"\n      sizes=\"32x32\"\n    />\n    <link\n      rel=\"icon\"\n      href=\"./img/uploads/2020/04/cropped-icon-192x192.png\"\n      sizes=\"192x192\"\n    />\n    <link\n      rel=\"apple-touch-icon\"\n      href=\"./img/uploads/2020/04/cropped-icon-180x180.png\"\n    />\n    <link\n      rel=\"stylesheet\"\n      href=\"https://use.fontawesome.com/releases/v5.15.4/css/all.css\"\n    />\n    <link href=\"./js/slick-theme.css\" rel=\"stylesheet\" type=\"text/css\" />\n    <link href=\"./js/slick.css\" rel=\"stylesheet\" type=\"text/css\" />\n    <script src=\"./js/slick.min.js\" type=\"text/javascript\"></script>\n  </head>\n\n  <body\n    data-rsssl=\"1\"\n    class=\"home page-template-default page page-id-59 custom-background wp-custom-logo wp-embed-responsive singular missing-post-thumbnail has-no-pagination not-showing-comments show-avatars footer-top-visible reduced-spacing\"\n  >\n    <a class=\"skip-link screen-reader-text\" href=\"#site-content\"\n      >コンテンツへスキップ</a\n    >\n    <header id=\"site-header\" class=\"header-footer-group\" role=\"banner\">\n      <div class=\"header-inner section-inner\">\n        <div class=\"header-navi_top\">\n          <div class=\"header-titles-wrapper\">\n            <div class=\"header-titles\">\n              <div class=\"site-logo faux-heading\">\n                <a href=\"./\" class=\"custom-logo-link\" rel=\"home\"\n                  ><img\n                    width=\"213\"\n                    height=\"42\"\n                    style=\"height: 42px\"\n                    src=\"./img/uploads/2020/04/logo.png\"\n                    class=\"custom-logo\"\n                    alt=\"株式会社ロココ\"\n                    srcset=\"\n                      ./img/uploads/2020/04/logo.png        426w,\n                      ./img/uploads/2020/04/logo-300x59.png 300w\n                    \"\n                    sizes=\"(max-width: 426px) 100vw, 426px\" /></a\n                ><span class=\"screen-reader-text\">ロココ</span>\n              </div>\n            </div>\n            <!-- .header-titles -->\n            <!--　モバイル用ハンバーガー　-->\n            <!--\n\t\t\t\t\t\t<button class=\"toggle nav-toggle mobile-nav-toggle\" data-toggle-target=\".menu-modal\"  data-toggle-body-class=\"showing-menu-modal\" aria-expanded=\"false\" data-set-focus=\".close-nav-toggle\">\n\t\t\t\t\t\t\t<span class=\"toggle-inner\">\n\t\t\t\t\t\t\t\t<span class=\"toggle-icon\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t</span>\n\t\t\t\t\t\t\t\t<span class=\"toggle-text\"></span>\n\t\t\t\t\t\t\t</span>\n\t\t\t\t\t\t</button>\n-->\n            <!-- .nav-toggle -->\n          </div>\n          <!-- .header-titles-wrapper -->\n\n          <div class=\"header_recruite_navi\">\n            <nav>\n              <ul>\n                <li\n                  id=\"menu-item-63\"\n                  class=\"menu-item menu-item-type-custom menu-item-object-custom menu-item-63\"\n                >\n                  <a href=\"./recruit/#contact\"\n                    ><i class=\"far fa-envelope\"></i\n                  ></a>\n                </li>\n                <li\n                  id=\"menu-item-62\"\n                  class=\"menu-item menu-item-type-custom menu-item-object-custom menu-item-62\"\n                >\n                  <a href=\"./recruit/\"\n                    ><p class=\"header_square_recruit\">採用情報</p></a\n                  >\n                </li>\n              </ul>\n            </nav>\n          </div>\n        </div>\n\n        <div class=\"header-navigation-wrapper\">\n          <nav class=\"primary-menu-wrapper\" aria-label=\"水平\" role=\"navigation\">\n            <ul class=\"primary-menu reset-list-style\">\n              <li\n                id=\"menu-item-73\"\n                class=\"menu-item menu-item-type-custom menu-item-object-custom menu-item-73\"\n              >\n                <a href=\"./#about\">私たちについて</a>\n              </li>\n              <li\n                id=\"menu-item-74\"\n                class=\"menu-item menu-item-type-custom menu-item-object-custom menu-item-74\"\n              >\n                <a href=\"./#message\">ヒストリー</a>\n              </li>\n              <li\n                id=\"menu-item-75\"\n                class=\"menu-item menu-item-type-custom menu-item-object-custom menu-item-75\"\n              >\n                <a href=\"./#company_overview\">会社概要</a>\n              </li>\n              <li\n                id=\"menu-item-76\"\n                class=\"menu-item menu-item-type-custom menu-item-object-custom menu-item-76\"\n              >\n                <a href=\"./#access\">アクセス</a>\n              </li>\n            </ul>\n          </nav>\n          <!-- .primary-menu-wrapper -->\n        </div>\n        <!-- .header-navigation-wrapper -->\n      </div>\n      <!-- .header-inner -->\n    </header>\n    <!-- #site-header -->\n\n    <div\n      class=\"menu-modal cover-modal header-footer-group\"\n      data-modal-target-string=\".menu-modal\"\n    >\n      <div class=\"menu-modal-inner modal-inner\">\n        <div class=\"menu-wrapper section-inner\">\n          <div class=\"menu-top\">\n            <button\n              class=\"toggle close-nav-toggle fill-children-current-color\"\n              data-toggle-target=\".menu-modal\"\n              data-toggle-body-class=\"showing-menu-modal\"\n              aria-expanded=\"false\"\n              data-set-focus=\".menu-modal\"\n            >\n              <span class=\"toggle-text\">メニューを閉じる</span>\n              <svg\n                class=\"svg-icon\"\n                aria-hidden=\"true\"\n                role=\"img\"\n                focusable=\"false\"\n                xmlns=\"http://www.w3.org/2000/svg\"\n                width=\"16\"\n                height=\"16\"\n                viewBox=\"0 0 16 16\"\n              >\n                <polygon\n                  fill=\"\"\n                  fill-rule=\"evenodd\"\n                  points=\"6.852 7.649 .399 1.195 1.445 .149 7.899 6.602 14.352 .149 15.399 1.195 8.945 7.649 15.399 14.102 14.352 15.149 7.899 8.695 1.445 15.149 .399 14.102\"\n                />\n              </svg></button\n            ><!-- .nav-toggle -->\n\n            <nav class=\"mobile-menu\" aria-label=\"モバイル\" role=\"navigation\">\n              <ul class=\"modal-menu reset-list-style\">\n                <li\n                  class=\"menu-item menu-item-type-custom menu-item-object-custom menu-item-73\"\n                >\n                  <div class=\"ancestor-wrapper\">\n                    <a href=\"./#about\">私たちについて</a>\n                  </div>\n                  <!-- .ancestor-wrapper -->\n                </li>\n                <li\n                  class=\"menu-item menu-item-type-custom menu-item-object-custom menu-item-74\"\n                >\n                  <div class=\"ancestor-wrapper\">\n                    <a href=\"./#message\">ヒストリー</a>\n                  </div>\n                  <!-- .ancestor-wrapper -->\n                </li>\n                <li\n                  class=\"menu-item menu-item-type-custom menu-item-object-custom menu-item-75\"\n                >\n                  <div class=\"ancestor-wrapper\">\n                    <a href=\"./#company_overview\">会社概要</a>\n                  </div>\n                  <!-- .ancestor-wrapper -->\n                </li>\n                <li\n                  class=\"menu-item menu-item-type-custom menu-item-object-custom menu-item-76\"\n                >\n                  <div class=\"ancestor-wrapper\">\n                    <a href=\"./#access\">アクセス</a>\n                  </div>\n                  <!-- .ancestor-wrapper -->\n                </li>\n              </ul>\n            </nav>\n          </div>\n          <!-- .menu-top -->\n\n          <div class=\"menu-bottom\"></div>\n          <!-- .menu-bottom -->\n        </div>\n        <!-- .menu-wrapper -->\n      </div>\n      <!-- .menu-modal-inner -->\n    </div>\n    <!-- .menu-modal -->\n\n    <main id=\"site-content\" role=\"main\">\n      <ul id=\"mv\">\n        <li>\n          <img src=\"./img/img3.jpg\" alt=\"\" />\n        </li>\n        <li>\n          <img src=\"./img/img2.jpg\" alt=\"\" />\n        </li>\n        <li>\n          <img src=\"./img/img4.jpg\" alt=\"\" />\n        </li>\n      </ul>\n\n      <section id=\"about\">\n        <div class=\"title\">\n          <div class=\"red_box\"><div class=\"white_box\"></div></div>\n          <p>About us</p>\n        </div>\n        <h2>私たちについて</h2>\n        <p class=\"sp\">\n          ロココは自社企画商品、独自の視点でセレクトした国内外の商品やサービスを、ウェブなどの独自メディアで販売する、ダイレクトマーケティングの会社です。<br />\n          <br />\n          これらの商品やサービスを通して、関わる全ての人を魅力的にすることを企業理念としています。\n        </p>\n        <hr />\n        <p class=\"sub_title\">運営サイト</p>\n        <ul>\n          <li>\n            <div>\n              <img src=\"./img/ec/rococo_ec_logo.png\" />\n            </div>\n            <p class=\"sp\">ROCOCO / ロココ（メンズファッション）</p>\n            <p class=\"sp\">\n              国内外からアイテムを厳選しています。<br />私たちのセレクトの根本にあるものは、コストパフォーマンスの高い商品を提供すること。情報、商品の提供により、「お客様を魅力的に」を理念として運営しています。\n            </p>\n            <img src=\"./img/ec/rococo_ec_image.jpg\" alt=\"ROCOCO ECサイト\" />\n            <ul class=\"link_rococo\">\n              <li>\n                <a href=\"https://www.roco2web.com/\" target=\"_blank\"\n                  >ROCOCO 本店</a\n                >\n              </li>\n              <li>\n                <a\n                  href=\"https://www.rakuten.ne.jp/gold/rococostore/\"\n                  target=\"_blank\"\n                  >楽天市場店</a\n                >\n              </li>\n              <li>\n                <a href=\"https://shopping.geocities.jp/rococo/\" target=\"_blank\"\n                  >Yahooショッピング店</a\n                >\n              </li>\n            </ul>\n            <p class=\"sns_icon\">\n              <a href=\"https://www.instagram.com/rococo_attractive_clothing/\"\n                ><i class=\"fab fa-instagram fa-2x\"></i\n              ></a>\n            </p>\n            <hr />\n          </li>\n          <li>\n            <div>\n              <img src=\"./img/ec/gochi_logo.png\" alt=\"gochi\" />\n            </div>\n            <p class=\"sp\">GochI / ゴチ（レディースECサイト）</p>\n            <p class=\"sp\">\n              GochI（ゴチ）で取り扱う商品は、普遍的でシンプルでありながら、ユニーク。<br />ファッションとして時流に沿いながらも、普遍的であり独自性に富むアイテムを世界中からお届けします。\n            </p>\n            <img src=\"./img/ec/gochi_ec_image.jpg\" alt=\"Gochi ECサイト\" />\n            <ul class=\"link_gochi\">\n              <li>\n                <a\n                  href=\"https://www.rakuten.ne.jp/gold/daigochi/\"\n                  target=\"_blank\"\n                  >楽天市場店</a\n                >\n              </li>\n              <li>\n                <a\n                  href=\"https://shopping.geocities.jp/daigochi/\"\n                  target=\"_blank\"\n                  >Yahooショッピング店</a\n                >\n              </li>\n            </ul>\n            <p class=\"sns_icon\">\n              <a href=\"https://www.instagram.com/gochi_selectshop/\"\n                ><i class=\"fab fa-instagram fa-2x\"></i\n              ></a>\n            </p>\n            <hr />\n          </li>\n          <li>\n            <div>\n              <img src=\"./img/ec/haku_logo.png\" alt=\"haku-clothing\" />\n            </div>\n            <p class=\"sp\">\n              HAKU CLOTHING / ハク クロージング（グローバルECサイト）\n            </p>\n            <p class=\"sp\">\n              日本にとって特別なカラー「白（ハク）」。<br />白に包まれて生まれ、白に包まれて亡くなります。始まりと終わりの色、白。<br />永遠に着るものとしてあなたと共にあり続けるように、「haku-clothing」と名付けています。<br /><small\n                >※海外のIPアドレスからのみご覧いただけます。</small\n              >\n            </p>\n            <ul class=\"link_koromobito\">\n              <li>\n                <a href=\"https://www.haku-clothing.com/\" target=\"_blank\"\n                  >HAKU CLOTHING</a\n                >\n              </li>\n            </ul>\n            <p class=\"sns_icon\">\n              <a href=\"https://www.instagram.com/haku_clothing_japan/\"\n                ><i class=\"fab fa-instagram fa-2x\"></i\n              ></a>\n            </p>\n            <hr />\n          </li>\n          <li>\n            <div>\n              <img src=\"./img/ec/koromobito_logo.png\" alt=\"コロモビト.\" />\n            </div>\n            <p class=\"sp\">コロモビト.（メディアサイト）</p>\n            <p class=\"sp\">\n              より広く深い服にまつわる情報を提供し、お客様・私たち・生産者が繋がる場所として「コロモビト.」を立ち上げました。<br />「衣」に関わる、すべての人が魅力的になることを願い、運営します。\n            </p>\n            <ul class=\"link_koromobito\">\n              <li>\n                <a href=\"https://roco2web.com/blogs/koromobito/\" target=\"_blank\"\n                  >コロモビト.</a\n                >\n              </li>\n            </ul>\n          </li>\n        </ul>\n      </section>\n      <section id=\"message\">\n        <div class=\"title\">\n          <div class=\"red_box\"><div class=\"white_box\"></div></div>\n          <p>History</p>\n        </div>\n        <h2>ヒストリー</h2>\n        <p class=\"sp\">\n          ロココは2004年に大阪・堀江にて実店舗、個人事業主として二人で創業。<br />\n          <br />\n          長くアメリカンヴィンテージ古着店にて、店長として販売、運営、仕入れなどを経験しお店を始めました。<br />\n          <br />\n          「良いモノ」はいつの時代も良い素材や良いディテールなど共通点があり、それは現在も受け継がれています。<br />\n          私たちがアメリカのヴィンテージクロージングから学んだ「良いモノ」、そして現在の技術の発展から生まれた新しい「良いモノ」を私たちのフィルターを通し、多くのお客様にお届けしてまいりました。\n        </p>\n        <div id=\"showroom\">\n          <p>創業当時の実店舗</p>\n          <img src=\"./img/rococo_sougyou.jpg\" alt=\"創業時の写真\" />\n        </div>\n        <hr />\n        <p id=\"company_history\" class=\"sub_title\">会社の沿革</p>\n        <table>\n          <tr>\n            <th>2004年8月</th>\n            <td>大阪・南堀江　実店舗「ROCOCO」オープン</td>\n          </tr>\n          <tr>\n            <th>2006年8月</th>\n            <td>ECサイト「ROCOCO 本店」オープン</td>\n          </tr>\n          <tr>\n            <th>2007年10月</th>\n            <td>ECサイト「ROCOCO 楽天市場店」オープン</td>\n          </tr>\n          <tr>\n            <th>2009年6月</th>\n            <td>ECサイト「ROCOCO Yahooショッピング店」オープン</td>\n          </tr>\n          <tr>\n            <th>2010年7月</th>\n            <td>大阪・北堀江　店舗拡大のため移転</td>\n          </tr>\n          <tr>\n            <th>2011年12月</th>\n            <td>法人成り</td>\n          </tr>\n          <tr>\n            <th>2015年3月</th>\n            <td>ECサイト「GochI 楽天市場店」オープン</td>\n          </tr>\n          <tr>\n            <th>2017年9月</th>\n            <td>大阪・堺筋本町に移転<br />実店舗→ショールームに変更</td>\n          </tr>\n          <tr>\n            <th>2020年2月</th>\n            <td>ECサイト「GochI Yahooショッピング店」オープン</td>\n          </tr>\n          <tr>\n            <th>2022年1月</th>\n            <td>ECサイト「HAKU（海外サイト）」オープン</td>\n          </tr>\n        </table>\n        <hr />\n        <p class=\"sub_title\">企業理念</p>\n        <div id=\"philosophy\">\n          <div class=\"slogan\">\n            <p>人を魅力的にする</p>\n            <hr />\n            <span\n              >私たちは、関わる全ての人々が<br />より魅力的になる世界を目指しています。</span\n            >\n          </div>\n          <img src=\"./img/philosophy.jpg\" alt=\"ロココ企業理念\" />\n        </div>\n        <div class=\"more_button\">\n          <a href=\"./philosophy/\"\n            >もっと詳しく見る<i class=\"fas fa-chevron-circle-right\"></i\n          ></a>\n        </div>\n      </section>\n      <section id=\"company_overview\">\n        <div class=\"title\">\n          <div class=\"red_box\"><div class=\"white_box\"></div></div>\n          <p>Company overview</p>\n        </div>\n        <h2>会社概要</h2>\n        <table>\n          <tr>\n            <th>会社名</th>\n            <td>株式会社ロココ</td>\n          </tr>\n          <tr>\n            <th>本社</th>\n            <td>大阪府大阪市中央区博労町1-8-8<br />ピカソ堺筋本町ビル5階</td>\n          </tr>\n          <tr>\n            <th>代表取締役社長</th>\n            <td>阿部 慎太郎</td>\n          </tr>\n          <tr>\n            <th>設立</th>\n            <td>2004年8月（2011年12月 法人化）</td>\n          </tr>\n          <tr>\n            <th>資本金</th>\n            <td>800万円</td>\n          </tr>\n          <tr>\n            <th>従業員数</th>\n            <td>26名</td>\n          </tr>\n          <tr>\n            <th>主な事業内容</th>\n            <td>アパレル小売業/ECサイトによる通信販売</td>\n          </tr>\n        </table>\n        <p class=\"attention\">※2023年3月現在</p>\n      </section>\n      <section id=\"access\">\n        <div class=\"title\">\n          <div class=\"red_box\"><div class=\"white_box\"></div></div>\n          <p>Access</p>\n        </div>\n        <h2>アクセス</h2>\n        <iframe\n          src=\"https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2320.034296839742!2d135.50782229601793!3d34.67934455531442!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f100!3m3!1m2!1s0x0%3A0x23fe61c24df3c808!2z5qCq5byP5Lya56S-44Ot44Kz44Kz77yIUk9DT0NPKQ!5e0!3m2!1sja!2sjp!4v1588242465354!5m2!1sja!2sjp\"\n          width=\"780\"\n          height=\"540\"\n          frameborder=\"0\"\n          style=\"border: 0\"\n          allowfullscreen=\"\"\n          aria-hidden=\"false\"\n          tabindex=\"0\"\n        ></iframe>\n        <table>\n          <tr>\n            <th>所在地</th>\n            <td>\n              〒541-0059<br />大阪府大阪市中央区博労町1-8-8　ピカソ堺筋本町ビル5階\n            </td>\n          </tr>\n          <tr>\n            <th>TEL</th>\n            <td>06-4708-4129<span>（平日10:00～18：00）</span></td>\n          </tr>\n        </table>\n        <hr />\n        <p id=\"contact\" class=\"sub_title\">お問い合わせ</p>\n        <p class=\"contactform_txt\">\n          弊社にご連絡いただく際は以下のフォームよりお問い合わせください。<br />\n          商品・ECサイトに関しては各サイトからお願い申し上げます。\n        </p>\n        <div class=\"company_form\">\n          <div role=\"form\" class=\"wpcf7\" id=\"company_form\" lang=\"ja\" dir=\"ltr\">\n            <div class=\"screen-reader-response\"></div>\n            <form\n              action=\"#\"\n              method=\"post\"\n              class=\"wpcf7-form\"\n              novalidate=\"novalidate\"\n            >\n              <input type=\"hidden\" name=\"mail_sent\" value=\"\" />\n              <input type=\"hidden\" name=\"mailform_token\" value=\"\" />\n              <p>\n                <label>\n                  お名前 <span class=\"cation\">(必須)</span><br />\n                  <span class=\"wpcf7-form-control-wrap your-name\"\n                    ><input\n                      type=\"text\"\n                      name=\"your-name\"\n                      value=\"\"\n                      size=\"40\"\n                      class=\"wpcf7-form-control wpcf7-text wpcf7-validates-as-required\"\n                      aria-required=\"true\"\n                      aria-invalid=\"false\"\n                    />\n                  </span>\n                </label>\n              </p>\n              <p>\n                <label>\n                  メールアドレス <span class=\"cation\">(必須)</span><br />\n                  <span class=\"wpcf7-form-control-wrap your-email\"\n                    ><input\n                      type=\"email\"\n                      name=\"your-email\"\n                      value=\"\"\n                      size=\"40\"\n                      class=\"wpcf7-form-control wpcf7-text wpcf7-email wpcf7-validates-as-required wpcf7-validates-as-email\"\n                      aria-required=\"true\"\n                      aria-invalid=\"false\"\n                  /></span>\n                </label>\n              </p>\n              <p>\n                <label>\n                  カテゴリ <span class=\"cation\">(必須)</span><br />\n                  <span class=\"wpcf7-form-control-wrap menu-973\"\n                    ><select\n                      name=\"menu-973\"\n                      class=\"wpcf7-form-control wpcf7-select wpcf7-validates-as-required\"\n                      aria-required=\"true\"\n                      aria-invalid=\"false\"\n                    >\n                      <option value=\"\">---</option>\n                      <option value=\"会社について\">会社について</option