/div>\n                </div>\n              </div>\n              <div class=\"topSpecialSec__navItem\">    \n                <figure class=\"topSpecialSec__navFig\"> <img src=\"../recruit_assets/images/top/topSpecialSec_img-02.png\" alt=\"\"></figure>\n                <div class=\"topSpecialSec__navInfo\">\n                  <div class=\"topSpecialSec__navInfoPretitle\">三菱UFJファクターの</div>\n                  <figure class=\"topSpecialSec__navInfoFigTtl\"> <img src=\"../recruit_assets/images/top/topSpecialSec_midokoro.png\" alt=\"\"></figure>\n                  <div class=\"topSpecialSec__navInfoBtnWrap\"><a class=\"u-button spSmall\" href=\"../recruit/special/midokoromuf/01/\"><span>VIEW MORE</span></a></div>\n                </div>\n              </div>\n            </div>\n          </div>\n        </section>\n        <section class=\"topCompanySec\">\n          <div class=\"topCompanySec__inner\">\n            <div class=\"topCompanySec__companyRow\">\n              <div class=\"topCompanySec__companyCol\"> \n                <div class=\"topCompanySec__ttlWrap\">\n                  <h4 class=\"u-titleSec\">\n                     COMPANY</h4>\n                  <p class=\"u-titleSecSub\">\n                     会社を知る</p>\n                </div>\n                <div class=\"u-textDescSec\">\n                     当社は、三菱UFJファイナンシャル・グループの一員であり、<br>\n                  商流ビジネスを専門に手掛ける戦略会社です。<br>\n                  1972年に日本初のファクタリング会社として創業し、<br class=\"u-pcDb\">\n                  業界をリードし続けています。\n                </div>\n                <div class=\"u-navSec\"> <a class=\"u-navSecLink\" href=\"../recruit/company/business/\">\n                    <div class=\"u-navSecArrow\"></div><span>業務紹介</span></a><a class=\"u-navSecLink\" href=\"../recruit/company/corporate/\">\n                    <div class=\"u-navSecArrow\"></div><span>企業情報</span></a></div>\n              </div>\n              <div class=\"topCompanySec__companyCol\"> \n                <figure class=\"topCompanySec_