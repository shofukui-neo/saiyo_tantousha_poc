igure> <img class=\"u-pcDb\" src=\"../recruit_assets/images/top/topKVSecFade_img-02.png\" alt=\"\"><img class=\"u-spDb\" src=\"../recruit_assets/images/top/topKVSecFade_img-02_sp.png\" alt=\"\"></figure>\n                </div>\n                <div class=\"fadeKv__item\">  \n                  <figure> <img class=\"u-pcDb\" src=\"../recruit_assets/images/top/topKVSecFade_img-03.png\" alt=\"\"><img class=\"u-spDb\" src=\"../recruit_assets/images/top/topKVSecFade_img-03_sp.png\" alt=\"\"></figure>\n                </div>\n                <div class=\"fadeKv__item\">  \n                  <figure> <img class=\"u-pcDb\" src=\"../recruit_assets/images/top/topKVSecFade_img-04.jpg\" alt=\"\"><img class=\"u-spDb\" src=\"../recruit_assets/images/top/topKVSecFade_img-04_sp.png\" alt=\"\"></figure>\n                </div>\n              </div>\n            </div>\n            <div class=\"topKVSec__titleWrap\">\n              <h1 class=\"topKVSec__title\">\n                 企業に、<br>人に、<br>可能性に、<br class=\"u-spDb\">寄り添う。</h1>\n            </div>\n            <div class=\"topKVSec__infoWrap\"> \n              <div class=\"topKVSec__info\">\n                <div class=\"topKVSec__date\">2026.01.26</div>\n                <div class=\"topKVSec__infoDesc\">\n                   2026年度イベント情報を更新いたしました</div>\n              </div>\n            </div>\n\n          </div>\n        </div>\n      </section>\n      <section class=\"topIntroSec\"> \n        <div class=\"topIntroSec__inner\"> \n          <div class=\"topIntroSec__box\" data-aos=\"fadeInUp\" data-aos-duration=\"1500\" data-aos-anchor-placement=\"center-bottom\">\n            <h2 class=\"topIntroSec__boxTitle\"> <span class=\"quote left\">“</span>\n              <div>企業運営<span class=\"fs-sm\">の</span><br class=\"u-spDb\">ベストパートナー</div><span class=\"quote right\">”</span>\n            </h2>\n            <div class=\"topIntroSec__row\"> \n              <div class=\"topIntroSec__col col01\">\n                <figure class=\"topIntroS