{"url":"https://www.aeonretail.jp/saiyo/challenged/work/","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n\n<head>\n  <!-- Google Tag Manager -->\n  <script>\n    (function (w, d, s, l, i) {\n      w[l] = w[l] || [];\n      w[l].push({\n        'gtm.start': new Date().getTime(),\n        event: 'gtm.js'\n      });\n      var f = d.getElementsByTagName(s)[0],\n        j = d.createElement(s),\n        dl = l != 'dataLayer' ? '&l=' + l : '';\n      j.async = true;\n      j.src =\n        'https://www.googletagmanager.com/gtm.js?id=' + i + dl;\n      f.parentNode.insertBefore(j, f);\n    })(window, document, 'script', 'dataLayer', 'GTM-M38PPC');\n  </script>\n  <!-- End Google Tag Manager -->\n  <meta charset=\"utf-8\">\n  <meta name=\"format-detection\" content=\"telephone=no\">\n  <meta name=\"viewport\" content=\"width=device-width\">\n  <link rel=\"shortcut icon\" href=\"/saiyo/challenged/img/common/apple-touch-icon.ico\">\n  <link rel=\"apple-touch-icon\" href=\"/saiyo/challenged/img/common/aeon_appletouchicon.png.webp\">\n\n  <title>仕事図鑑｜障がい者採用サイト｜イオンリテール株式会社</title>\n  <meta name=\"keywords\" content=\"\">\n  <meta name=\"description\" content=\"多様な業務から自分に「ぴったり」の働き方を見つけられる、イオンリテールで働けるお仕事をご紹介します。\">\n\n  <meta property=\"og:title\" content=\"仕事図鑑｜障がい者採用サイト｜イオンリテール株式会社\">\n  <meta property=\"og:description\" content=\"多様な業務から自分に「ぴったり」の働き方を見つけられる、イオンリテールで働けるお仕事をご紹介します。\">\n  <meta property=\"og:url\" content=\"https://www.aeonretail.jp/saiyo/challenged/work/\">\n  <meta property=\"og:type\" content=\"website\">\n  <meta property=\"og:locale\" content=\"ja_JP\">\n  <meta property=\"og:image\" content=\"/saiyo/challenged/img/common/og-image.jpg.webp\">\n  <meta property=\"og:site_name\" content=\"障がい者採用サイト｜イオンリテール株式会社\">\n\n  <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n  <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n  <link href=\"https://fonts.googleapis.com/css2?family=Quicksand:wght@500;700&family=Zen+Maru+Gothic:wght@500;700&display=swap\" rel=\"stylesheet\">\n\n  <link rel=\"stylesheet\" type=\"text/css\" href=\"/saiyo/challenged/css/lib/splide-core.min.css\">\n  <link rel=\"stylesheet\" type=\"text/css\" href=\"/saiyo/challenged/css/style.css\">\n\n\n  <script src=\"/saiyo/challenged/js/lib/b_browser_switcher.js\"></script>\n  <script src=\"/saiyo/challenged/js/lib/jquery-3.6.3.min.js\"></script>\n</head>\n\n\n<body>\n  <!-- Google Tag Manager (noscript) -->\n  <noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-M38PPC\" height=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n  <!-- End Google Tag Manager (noscript) -->\n  <div class=\"\" id=\"loading\">\n    <div class=\"fade-content\">\n      <div class=\"logo-area\">\n        <img src=\"/saiyo/challenged/img/common/aeon_logo.svg\" alt=\"AEON\">\n        <span class=\"txt\">障がい者採用サイト</span>\n      </div>\n    </div>\n  </div>\n  <div id=\"wrapper\">\n\n    <header></header>\n    <script>\n      $('header').load('/saiyo/challenged/inc/c-header.html');\n    </script>\n\n    <main class=\"work c-main-bg-pink\" id=\"main\" tabindex=\"-1\">\n      <section class=\"c-kv-section\">\n        <div class=\"white-bg l-blue\">\n          <div class=\"inner-block anim\">\n            <nav  aria-label=\"パンくずリスト\">\n              <ol class=\"crumb\">\n                <li><a href=\"/saiyo/challenged/\">ホーム</a></li>\n                <li class=\"current\" aria-current=\"location\">仕事図鑑</li>\n              </ol>\n            </nav>\n\n            <h1 class=\"c-ttl01 l-blue\">\n              <span class=\"ja\">仕事図鑑</span>\n              <span class=\"en\">JobMap</span>\n            </h1>\n            <div class=\"desc-area has-img\">\n              <p class=\"desc\">\n                イオンリテールでは、一人ひとりが持つ個性や強みを発揮できる、さまざまなお仕事があります。ご自身の特性に合った得意なお仕事がきっと見つかります。\n              </p>\n              <img src=\"/saiyo/challenged/img/work/kv-img.jpg.webp\" alt=\"\">\n            </div>\n          </div>\n        </div>\n\n      </section>\n\n      <section class=\"relation-section\" aria-labelledby=\"relation-section-title\">\n        <div class=\"inner-block\">\n          <h2 id=\"relation-section-title\" class=\"sr-only\">本社・店舗・お客さまの関係</h2>\n\n          <p class=\"sr-only\">\n            本社と店舗とお客さまの関係を示す図です。本社では、一般事務、ECサイト運営サポートなどのお仕事を通じて、店舗の運営を事務面から支えています。本社と店舗の間では、さまざまな情報を相互に共有しています。店舗では、品質管理や衛生管理、販売促進などに関するお仕事を通じて、お客さまにサービスを提供しています。\n          </p>\n          <div class=\"contents-wrap anim\">\n            <div class=\"company-store-area\">\n              <article class=\"work-area\">\n                <h3 class=\"ttl\">本社の仕事</h3>\n                <div class=\"img-area\">\n                  <img src=\"/saiyo/challenged/img/work/ico-building.png.webp\" alt=\"\">\n                  <span class=\"txt\" aria-hidden=\"true\">本社</span>\n                </div>\n                <ul class=\"c-dot-list\">\n                  <li>一般事務</li>\n                  <li>ECサイト<span class=\"ib\">運営サポート</span></li>\n                  <li>商品発注業務<span class=\"ib\">事務</span></li>\n                  <li>契約管理</li>\n                  <li>経理事務　　　など</li>\n                </ul>\n              </article>\n\n              <div class=\"arrow-area\">\n                <p class=\"arrow company\">\n                  <span class=\"txt\">店舗を<span class=\"ib\">支える</span></span>\n                  <svg class=\"ico-arrow\" viewBox=\"0 0 39 28\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n                    <path d=\"M2.5 14L32.5 14\" stroke-width=\"4\" stroke-linecap=\"round\" />\n                    <path d=\"M20.5 26L36.5 14L20.5 2\" stroke-width=\"4\" stroke-linecap=\"round\" stroke-linejoin=\"round\" />\n                  </svg>\n                </p>\n                <p class=\"arrow store\">\n                  <svg class=\"ico-arrow\" viewBox=\"0 0 39 28\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n                    <path d=\"M2.5 14L32.5 14\" stroke-width=\"4\" stroke-linecap=\"round\" />\n                    <path d=\"M20.5 26L36.5 14L20.5 2\" stroke-width=\"4\" stroke-linecap=\"round\" stroke-linejoin=\"round\" />\n                  </svg>\n\n                  <span class=\"txt\">情報共有</span>\n                </p>\n              </div>\n\n              <article class=\"work-area\">\n                <h3 class=\"ttl\">店舗の仕事</h3>\n                <div class=\"img-area\">\n                  <img src=\"/saiyo/challenged/img/work/ico-store.png.webp\" alt=\"\">\n                  <span class=\"txt\" aria-hidden=\"true\">店舗</span>\n                </div>\n                <ul class=\"c-dot-list\">\n                  <li>品質管理</li>\n                  <li>衛生管理</li>\n                  <li>後方事務</li>\n                  <li>接客</li>\n                  <li>商品管理</li>\n                  <li>カート回収</li>\n                  <li>品出し・補充・<span class=\"ib\">陳列</span></li>\n                  <li>レジ打ち</li>\n                  <li>薬に関する<span class=\"ib\">お仕事</span></li>\n                  <li>販売促進　　　など</li>\n                </ul>\n              </article>\n\n            </div>\n\n            <p class=\"arrow-area\">\n              <span class=\"txt\">サービスの<br>提供</span>\n              <svg class=\"ico-arrow\" viewBox=\"0 0 39 28\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n                <path d=\"M2.5 14L32.5 14\" stroke=\"#453741\" stroke-width=\"4\" stroke-linecap=\"round\" />\n                <path d=\"M20.5 26L36.5 14L20.5 2\" stroke=\"#453741\" stroke-width=\"4\" stroke-linecap=\"round\" stroke-linejoin=\"round\" />\n              </svg>\n            </p>\n\n            <article class=\"customer-area\">\n              <div class=\"img-area\">\n                <img src=\"/saiyo/challenged/img/work/ico-customer.png.webp\" alt=\"\">\n              </div>\n              <h3 class=\"ttl\">お客さま</h3>\n            </article>\n          </div>\n        </div>\n\n      </section>\n\n      <section class=\"work-section c-bg-white\">\n        <div class=\"inner-block\">\n          <h2 class=\"c-ttl02 anim\">イオンリテールの仕事</h2>\n          <p class=\"top-txt anim\">\n            見たいお仕事をクリックするとアンカーリンクで移動します。\n          </p>\n\n          <nav class=\"anchor-group-wrap anim\" aria-label=\"職種ナビゲーション\">\n            <ul class=\"anchor-group-area-list\">\n              <li class=\"anchor-group-area\">\n                <h3 class=\"c-ttl03\">店舗の仕事</h3>\n                <ul class=\"anchor-list\">\n                  <li>\n                    <a href=\"#job-hisitsukanri\" class=\"c-anchor-btn\" aria-label=\"品質管理 ページ内リンク\">\n                      <span class=\"inn-txt\">\n                        品質管理\n                      </span>\n                    </a>\n                  </li>\n                  <li>\n                    <a href=\"#job-eiseikanri\" class=\"c-anchor-btn\" aria-label=\"衛生管理 ページ内リンク\">\n                      <span class=\"inn-txt\">\n                        衛生管理\n                      </span>\n                    </a>\n                  </li>\n                  <li>\n                    <a href=\"#job-kouhoujimu\" class=\"c-anchor-btn\" aria-label=\"後方事務 ページ内リンク\">\n                      <span class=\"inn-txt\">\n                        後方事務\n                      </span>\n                    </a>\n                  </li>\n                  <li>\n                    <a href=\"#job-sekkyaku\" class=\"c-anchor-btn\" aria-label=\"接客 ページ内リンク\">\n                      <span class=\"inn-txt\">\n                        接客\n                      </span>\n                    </a>\n                  </li>\n                  <li>\n                    <a href=\"#job-syouhinkanri\" class=\"c-anchor-btn\" aria-label=\"商品管理 ページ内リンク\">\n                      <span class=\"inn-txt\">\n                        商品管理\n                      </span>\n                    </a>\n                  </li>\n                  <li>\n                    <a href=\"#job-cartkaisyu\" class=\"c-anchor-btn\" aria-label=\"カート回収 ページ内リンク\">\n                      <span class=\"inn-txt\">\n                        カート回収\n                      </span>\n                    </a>\n                  </li>\n                  <li>\n                    <a href=\"#job-shinadashi\" class=\"c-anchor-btn\" aria-label=\"品出し・補充・陳列 ページ内リンク\">\n                      <span class=\"inn-txt\">\n                        品出し・<span class=\"ib\">補充・陳列</span>\n                      </span>\n                    </a>\n                  </li>\n                  <li>\n                    <a href=\"#job-regiuchi\" class=\"c-anchor-btn\" aria-label=\"レジ打ち ページ内リンク\">\n                      <span class=\"inn-txt\">\n                        レジ打ち\n                      </span>\n                    </a>\n                  </li>\n                  <li>\n                    <a href=\"#job-medicine\" class=\"c-anchor-btn\" aria-label=\"薬に関するお仕事 ページ内リンク\">\n                      <span class=\"inn-txt\">\n                        薬に関する<span class=\"ib\">お仕事</span>\n                      </span>\n                    </a>\n                  </li>\n                  <li>\n                    <a href=\"#job-hanbaisokushin\" class=\"c-anchor-btn\" aria-label=\"販売促進 ページ内リンク\">\n                      <span class=\"inn-txt\">\n                        販売促進\n                      </span>\n                    </a>\n                  </li>\n                </ul>\n              </li>\n              <li class=\"anchor-group-area\">\n                <h3 class=\"c-ttl03\">本社の仕事</h3>\n                <ul class=\"anchor-list\">\n                  <li>\n                    <a href=\"#job-ippanjimu\" class=\"c-anchor-btn\" aria-label=\"一般事務 ページ内リンク\">\n                      <span class=\"inn-txt\">\n                        一般事務\n                      </span>\n                    </a>\n                  </li>\n                  <li>\n                    <a href=\"#job-ecsupport\" class=\"c-anchor-btn\" aria-label=\"ECサイト運営サポート ページ内リンク\">\n                      <span class=\"inn-txt\">\n                        ECサイト<span class=\"ib\">運営サポート</span>\n                      </span>\n                    </a>\n                  </li>\n                  <li>\n                    <a href=\"#job-shyouhinjimu\" class=\"c-anchor-btn\" aria-label=\"商品発注業務事務 ページ内リンク\">\n                      <span class=\"inn-txt\">\n                        商品発注業務<span class=\"ib\">事務</span>\n                      </span>\n                    </a>\n                  </li>\n                  <li>\n                    <a href=\"#job-keiyakukanri\" class=\"c-anchor-btn\" aria-label=\"契約管理 ページ内リンク\">\n                      <span class=\"inn-txt\">\n                        契約管理\n                      </span>\n                    </a>\n                  </li>\n                  <li>\n                    <a href=\"#job-keirijimu\" class=\"c-anchor-btn\" aria-label=\"経理事務 ページ内リンク\">\n                      <span class=\"inn-txt\">\n                        経理事務\n                      </span>\n                    </a>\n                  </li>\n                </ul>\n              </li>\n            </ul>\n          </nav>\n\n          <div class=\"anchor-group-wrap_sticky js--sticky-nav-wrap\">\n            <button class=\"nav-btn js--sticky-nav-btn\" type=\"button\" aria-controls=\"work-sticky-nav\">\n              <span class=\"inn-txt\">\n                仕事図鑑　目次\n              </span>\n            </button>\n            <nav class=\"anchor-group-wrap js--sticky-nav\" id=\"work-sticky-nav\" aria-label=\"職種ナビゲーション\">\n              <ul class=\"anchor-group-area-list\">\n                <li class=\"anchor-group-area\">\n                  <h3 class=\"c-ttl03\">店舗の仕事</h3>\n                  <ul class=\"anchor-list\">\n                    <li>\n                      <a href=\"#job-hisitsukanri\" class=\"c-anchor-btn\" aria-label=\"品質管理 ページ内リンク\">\n                        <span class=\"inn-txt\">\n                          品質管理\n                        </span>\n                      </a>\n                    </li>\n                    <li>\n                      <a href=\"#job-eiseikanri\" class=\"c-anchor-btn\" aria-label=\"衛生管理 ページ内リンク\">\n                        <span class=\"inn-txt\">\n                          衛生管理\n                        </span>\n                      </a>\n                    </li>\n                    <li>\n                      <a href=\"#job-kouhoujimu\" class=\"c-anchor-btn\" aria-label=\"後方事務 ページ内リンク\">\n                        <span class=\"inn-txt\">\n                          後方事務\n                        </span>\n                      </a>\n                    </li>\n                    <li>\n                      <a href=\"#job-sekkyaku\" class=\"c-anchor-btn\" aria-label=\"接客 ページ内リンク\">\n                        <span class=\"inn-txt\">\n                          接客\n                        </span>\n                      </a>\n                    </li>\n                    <li>\n                      <a href=\"#job-syouhinkanri\" class=\"c-anchor-btn\" aria-label=\"商品管理 ページ内リンク\">\n                        <span class=\"inn-txt\">\n                          商品管理\n                        </span>\n                      </a>\n                    </li>\n                    <li>\n                      <a href=\"#job-cartkaisyu\" class=\"c-anchor-btn\" aria-label=\"カート回収 ページ内リンク\">\n                        <span class=\"inn-txt\">\n                          カート回収\n                        </span>\n                      </a>\n                    </li>\n                    <li>\n                      <a href=\"#job-shinadashi\" class=\"c-anchor-btn\" aria-label=\"品出し・補充・陳列 ページ内リンク\">\n                        <span class=\"inn-txt\">\n                          品出し・<span class=\"ib\">補充・陳列</span>\n                        </span>\n                      </a>\n                    </li>\n                    <li>\n                      <a href=\"#job-regiuchi\" class=\"c-anchor-btn\" aria-label=\"レジ打ち ページ内リンク\">\n                        <span class=\"inn-txt\">\n                          レジ打ち\n                        </span>\n                      </a>\n                    </li>\n                    <li>\n                      <a href=\"#job-medicine\" class=\"c-anchor-btn\" aria-label=\"薬に関するお仕事 ページ内リンク\">\n                        <span class=\"inn-txt\">\n                          薬に関する<span class=\"ib\">お仕事</span>\n                        </span>\n                      </a>\n                    </li>\n                    <li>\n                      <a href=\"#job-hanbaisokushin\" class=\"c-anchor-btn\" aria-label=\"販売促進 ページ内リンク\">\n                        <span class=\"inn-txt\">\n                          販売促進\n                        </span>\n                      </a>\n                    </li>\n                  </ul>\n                </li>\n                <li class=\"anchor-group-area\">\n                  <h3 class=\"c-ttl03\">本社の仕事</h3>\n                  <ul class=\"anchor-list\">\n                    <li>\n                      <a href=\"#job-ippanjimu\" class=\"c-anchor-btn\" aria-label=\"一般事務 ページ内リンク\">\n                        <span class=\"inn-txt\">\n                          一般事務\n                        </span>\n                      </a>\n                    </li>\n                    <li>\n                      <a href=\"#job-ecsupport\" class=\"c-anchor-btn\" aria-label=\"ECサイト運営サポート ページ内リンク\">\n                        <span class=\"inn-txt\">\n                          ECサイト<span class=\"ib\">運営サポート</span>\n                        </span>\n                      </a>\n                    </li>\n                    <li>\n                      <a href=\"#job-shyouhinjimu\" class=\"c-anchor-btn\" aria-label=\"商品発注業務事務 ページ内リンク\">\n                        <span class=\"inn-txt\">\n                          商品発注業務<span class=\"ib\">事務</span>\n                        </span>\n                      </a>\n                    </li>\n                    <li>\n                      <a href=\"#job-keiyakukanri\" class=\"c-anchor-btn\" aria-label=\"契約管理 ページ内リンク\">\n                        <span class=\"inn-txt\">\n                          契約管理\n                        </span>\n                      </a>\n                    </li>\n                    <li>\n                      <a href=\"#job-keirijimu\" class=\"c-anchor-btn\" aria-label=\"経理事務 ページ内リンク\">\n                        <span class=\"inn-txt\">\n                          経理事務\n                        </span>\n                      </a>\n                    </li>\n                  </ul>\n                </li>\n              </ul>\n            </nav>\n          </div>\n\n          <div class=\"job-boxes-area\">\n            <h3 class=\"c-ttl02 anim\">店舗の仕事</h3>\n            <div class=\"job-box-area anim\">\n              <section id=\"job-hisitsukanri\" class=\"c-job-box bg-pink\" tabindex=\"-1\">\n                <h4 class=\"box-ttl\">\n                  品質管理\n                </h4>\n                <div class=\"white-area\">\n                  <p class=\"balloon anim\">\n                    <span class=\"inn-txt\">\n                      食品の安全を守るキーパー\n                    </span>\n                  </p>\n                  <div class=\"img-area\">\n                    <img src=\"/saiyo/challenged/img/home/job-img01.png.webp\" alt=\"食品の品質を管理するスタッフのイラスト\">\n                  </div>\n                  <p class=\"txt\">\n                    商品の品質を確認することが主な業務です。食品担当の場合は食品の鮮度が保たれているか、衣料品担当の場合は衣服がきれいに折りたたまれているかなどを確認。お客さまが安心して買い物いただける商品かどうかをチェックします。\n                  </p>\n                  <section class=\"desc-wrap\">\n                    <h5 class=\"desc-ttl\">\n                      最初はこんなお仕事をお任せ\n                    </h5>\n                    <p class=\"txt\">\n                      先輩と一緒に商品を品出しし、陳列する際に商品に不具合がないかをチェックします。\n                    </p>\n                  </section>\n                  <section class=\"desc-wrap\">\n                    <h5 class=\"desc-ttl\">\n                      こんな特性の方が活躍中\n                    </h5>\n                    <ul class=\"desc-list\">\n                      <li aria-label=\"視覚、該当しない\">視覚</li>\n                      <li class=\"ok\" aria-label=\"聴覚、該当する\">聴覚</li>\n                      <li aria-label=\"上肢、該当しない\">上肢</li>\n                      <li class=\"ok\" aria-label=\"下肢、該当する\">下肢</li>\n                      <li class=\"ok\" aria-label=\"内臓機能、該当する\">内臓機能</li>\n                      <li aria-label=\"精神、該当しない\">精神</li>\n                      <li aria-label=\"発達、該当しない\">発達</li>\n                      <li aria-label=\"知的、該当しない\">知的</li>\n                    </ul>\n                  </section>\n                </div>\n              </section>\n              <section id=\"job-eiseikanri\" class=\"c-job-box bg-pink\" tabindex=\"-1\">\n                <h4 class=\"box-ttl\">\n                  衛生管理\n                </h4>\n                <div class=\"white-area\">\n                  <p class=\"balloon anim\">\n                    <span class=\"inn-txt\">\n                      品質と衛生環境を維持する最後の砦\n                    </span>\n                  </p>\n                  <div class=\"img-area\">\n                    <img src=\"/saiyo/challenged/img/home/job-img02.png.webp\" alt=\"品質チェックと衛生管理をするスタッフのイラスト\">\n                  </div>\n                  <p class=\"txt\">\n                    消費期限がある商品に対して期限が近付いていないか、期限切れの商品がないかを確認します。さらに各作業場が清潔で整頓されているかなどの衛生管理も担当。各売場担当者が実施する品質管理のルールが守られているか、ダブルチェックする役割を担います。\n                  </p>\n                  <section class=\"desc-wrap\">\n                    <h5 class=\"desc-ttl\">\n                      最初はこんなお仕事をお任せ\n                    </h5>\n                    <p class=\"txt\">\n                      先輩と一緒に売場を見回りし、チェックシートをもとに作業場の衛生チェックや消費期限を確認します。\n                    </p>\n                  </section>\n                  <section class=\"desc-wrap\">\n                    <h5 class=\"desc-ttl\">\n                      こんな特性の方が活躍中\n                    </h5>\n                    <ul class=\"desc-list\">\n                      <li aria-label=\"視覚、該当しない\">視覚</li>\n                      <li class=\"ok\" aria-label=\"聴覚、該当する\">聴覚</li>\n                      <li class=\"ok\" aria-label=\"上肢、該当する\">上肢</li>\n                      <li aria-label=\"下肢、該当しない\">下肢</li>\n                      <li class=\"ok\" aria-label=\"内臓機能、該当する\">内臓機能</li>\n                      <li aria-label=\"精神、該当しない\">精神</li>\n                      <li aria-label=\"発達、該当しない\">発達</li>\n                      <li aria-label=\"知的、該当しない\">知的</li>\n                    </ul>\n                  </section>\n                </div>\n              </section>\n              <section id=\"job-kouhoujimu\" class=\"c-job-box bg-pink\" tabindex=\"-1\">\n                <h4 class=\"box-ttl\">\n                  後方事務\n                </h4>\n                <div class=\"white-area\">\n                  <p class=\"balloon anim\">\n                    <span class=\"inn-txt\">\n                      スムーズな店舗運営を支える縁の下の力持ち\n                    </span>\n                  </p>\n                  <div class=\"img-area\">\n                    <img src=\"/saiyo/challenged/img/home/job-img03.png.webp\" alt=\"パソコンを使いデスクワークするスタッフのイラスト\">\n                  </div>\n                  <p class=\"txt\">\n                    店舗の総務、人事教育、販売促進など、店舗運営をサポートするお仕事です。繁忙時は売場へのレジ応援や商品の品出し、抽選会など店頭イベントのサポートに入ることもあります。人事教育では採用選考会や新規入社者の受入準備などをお任せします。\n                  </p>\n                  <section class=\"desc-wrap\">\n                    <h5 class=\"desc-ttl\">\n                      最初はこんなお仕事をお任せ\n                    </h5>\n                    <p class=\"txt\">\n                      毎月11日に発行される幸せの黄色いレシート<sup>※</sup>を集めて、ハンディで読み込み、集計して合計額を出します。\n                    </p>\n                    <p class=\"txt small\">\n                      ※専用BOXに投函すると、レシート合計金額の1%にあたる品物が地域のボランティア団体などに寄付されます。\n                    </p>\n                  </section>\n                  <section class=\"desc-wrap\">\n                    <h5 class=\"desc-ttl\">\n                      こんな特性の方が活躍中\n                    </h5>\n                    <ul class=\"desc-list\">\n                      <li class=\"ok\" aria-label=\"視覚、該当する\">視覚</li>\n                      <li class=\"ok\" aria-label=\"聴覚、該当する\">聴覚</li>\n                      <li class=\"ok\" aria-label=\"上肢、該当する\">上肢</li>\n                      <li class=\"ok\" aria-label=\"下肢、該当する\">下肢</li>\n                      <li class=\"ok\" aria-label=\"内臓機能、該当する\">内臓機能</li>\n                      <li aria-label=\"精神、該当しない\">精神</li>\n                      <li aria-label=\"発達、該当しない\">発達</li>\n                      <li aria-label=\"知的、該当しない\">知的</li>\n                    </ul>\n                  </section>\n                </div>\n              </section>\n              <section id=\"job-sekkyaku\" class=\"c-job-box bg-pink\" tabindex=\"-1\">\n                <h4 class=\"box-ttl\">\n                  接客\n                </h4>\n                <div class=\"white-area\">\n                  <p class=\"balloon anim\">\n                    <span class=\"inn-txt\">\n                      笑顔と気配りでご対応する売場の顔\n                    </span>\n                  </p>\n                  <div class=\"img-area\">\n                    <img src=\"/saiyo/challenged/img/home/job-img04.png.webp\" alt=\"売場で接客をするスタッフのイラスト\">\n                  </div>\n                  <p class=\"txt\">\n                    食品売場や衣料品売場、家庭用品売場など各売場でのお客さま対応が主な業務です。お客さまからのご質問への応対や売場案内、商品をお勧めする場面もあります。売場や商品の特徴を知り、お客さま視点での接客、販売をします。\n                  </p>\n                  <section class=\"desc-wrap\">\n                    <h5 class=\"desc-ttl\">\n                      最初はこんなお仕事をお任せ\n                    </h5>\n                    <p class=\"txt\">\n                      配属された売場の商品や配置を覚えます。お客さまへの接客応対研修を受けるので、初めての方も安心です。\n                    </p>\n                  </section>\n                  <section class=\"desc-wrap\">\n                    <h5 class=\"desc-ttl\">\n                      こんな特性の方が活躍中\n                    </h5>\n                    <ul class=\"desc-list\">\n                      <li aria-label=\"視覚、該当しない\">視覚</li>\n                      <li aria-label=\"聴覚、該当しない\">聴覚</li>\n                      <li class=\"ok\" aria-label=\"上肢、該当する\">上肢</li>\n                      <li class=\"ok\" aria-label=\"下肢、該当する\">下肢</li>\n                      <li class=\"ok\" aria-label=\"内臓機能、該当する\">内臓機能</li>\n                      <li aria-label=\"精神、該当しない\">精神</li>\n                      <li aria-label=\"発達、該当しない\">発達</li>\n                      <li aria-label=\"知的、該当しない\">知的</li>\n                    </ul>\n                  </section>\n                </div>\n              </section>\n              <section id=\"job-syouhinkanri\" class=\"c-job-box bg-pink\" tabindex=\"-1\">\n                <h4 class=\"box-ttl\">\n                  商品管理\n                </h4>\n                <div class=\"white-area\">\n                  <p class=\"balloon anim\">\n                    <span class=\"inn-txt\">\n                      商品の数や状態をチェックするコツコツ作業\n                    </span>\n                  </p>\n                  <div class=\"img-area\">\n                    <img src=\"/saiyo/challenged/img/home/job-img05.png.webp\" alt=\"商品の数をチェックするスタッフのイラスト\">\n                  </div>\n                  <p class=\"txt\">\n                    入荷商品の搬入口での受け取り、運搬、検品、在庫のチェック、パソコンでの伝票管理を担当します。食品、衣料品、家庭用品などすべての売場に共通するお仕事です。また、定期的に在庫の棚卸をしたり売場に直接商品を運ぶこともあります。\n                  </p>\n                  <section class=\"desc-wrap\">\n                    <h5 class=\"desc-ttl\">\n                      最初はこんなお仕事をお任せ\n                    </h5>\n                    <p class=\"txt\">\n                      先輩の指示に沿って、商品の簡単な仕分けや荷さばきをお任せします。\n                    </p>\n                  </section>\n                  <section class=\"desc-wrap\">\n                    <h5 class=\"desc-ttl\">\n                      こんな特性の方が活躍中\n                    </h5>\n                    <ul class=\"desc-list\">\n                      <li aria-label=\"視覚、該当しない\">視覚</li>\n                      <li aria-label=\"聴覚、該当しない\">聴覚</li>\n                      <li aria-label=\"上肢、該当しない\">上肢</li>\n                      <li aria-label=\"下肢、該当しない\">下肢</li>\n                      <li aria-label=\"内臓機能、該当しない\">内臓機能</li>\n                      <li class=\"ok\" aria-label=\"精神、該当する\">精神</li>\n                      <li class=\"ok\" aria-label=\"発達、該当する\">発達</li>\n                      <li class=\"ok\" aria-label=\"知的、該当する\">知的</li>\n                    </ul>\n                  </section>\n                </div>\n              </section>\n              <section id=\"job-cartkaisyu\" class=\"c-job-box bg-pink\" tabindex=\"-1\">\n                <h4 class=\"box-ttl\">\n                  カート回収\n                </h4>\n                <div class=\"white-area\">\n                  <p class=\"balloon anim\">\n                    <span class=\"inn-txt\">\n                      カートや買い物カゴの整理担当\n                    </span>\n                  </p>\n                  <div class=\"img-area\">\n                    <img src=\"/saiyo/challenged/img/home/job-img06.png.webp\" alt=\"カートや買い物カゴを片付けるスタッフのイラスト\">\n                  </div>\n                  <p class=\"txt\">\n                    店舗の敷地内にあるカートや買い物カゴの回収、整理、入口や駐車場の清掃を担当します。店内や駐車場など店舗全体を見渡しながら、定位置に整列できているかを確認します。お客さまから売場の場所を質問されたときは応対します。\n                  </p>\n                  <section class=\"desc-wrap\">\n                    <h5 class=\"desc-ttl\">\n                      最初はこんなお仕事をお任せ\n                    </h5>\n                    <p class=\"txt\">\n                      先輩の指示に沿って、店内や駐車場でカートを回収し入口のカート置き場に集めます。\n                    </p>\n                  </section>\n                  <section class=\"desc-wrap\">\n                    <h5 class=\"desc-ttl\">\n                      こんな特性の方が活躍中\n                    </h5>\n                    <ul class=\"desc-list\">\n                      <li aria-label=\"視覚、該当しない\">視覚</li>\n                      <li class=\"ok\" aria-label=\"聴覚、該当する\">聴覚</li>\n                      <li aria-label=\"上肢、該当しない\">上肢</li>\n                      <li aria-label=\"下肢、該当しない\">下肢</li>\n                      <li aria-label=\"内臓機能、該当しない\">内臓機能</li>\n                      <li aria-label=\"精神、該当しない\">精神</li>\n                      <li class=\"ok\" aria-label=\"発達、該当する\">発達</li>\n                      <li class=\"ok\" aria-label=\"知的、該当する\">知的</li>\n                    </ul>\n                  </section>\n                </div>\n              </section>\n              <section id=\"job-shinadashi\" class=\"c-job-box bg-pink\" tabindex=\"-1\">\n                <h4 class=\"box-ttl\">\n                  品出し・補充・陳列\n                </h4>\n                <div class=\"white-area\">\n                  <p class=\"balloon anim\">\n                    <span class=\"inn-txt\">\n                      運んで並べて、売場の品揃えを豊かに\n                    </span>\n                  </p>\n                  <div class=\"img-area\">\n                    <img src=\"/saiyo/challenged/img/home/job-img12.png.webp\" alt=\"商品棚で品出しや補充、陳列をするスタッフのイラスト\">\n                  </div>\n                  <p class=\"txt\">\n                    品出しや補充、陳列が主な業務です。バックヤードから商品を運び、店頭の陳列棚に並べていきます。食品、衣料品、家庭用品などすべての売場に共通するお仕事です。経験を積むと、不足している商品を自分の判断で補充、陳列できるようになります。\n                  </p>\n                  <section class=\"desc-wrap\">\n                    <h5 class=\"desc-ttl\">\n                      最初はこんなお仕事をお任せ\n                    </h5>\n                    <p class=\"txt\">\n                      先輩の指示のもと、商品棚に商品の補充と陳列を行います。\n                    </p>\n                  </section>\n                  <section class=\"desc-wrap\">\n                    <h5 class=\"desc-ttl\">\n                      こんな特性の方が活躍中\n                    </h5>\n                    <ul class=\"desc-list\">\n                      <li aria-label=\"視覚、該当しない\">視覚</li>\n                      <li class=\"ok\" aria-label=\"聴覚、該当する\">聴覚</li>\n                      <li aria-label=\"上肢、該当しない\">上肢</li>\n                      <li aria-label=\"下肢、該当しない\">下肢</li>\n                      <li class=\"ok\" aria-label=\"内臓機能、該当する\">内臓機能</li>\n                      <li class=\"ok\" aria-label=\"精神、該当する\">精神</li>\n                      <li class=\"ok\" aria-label=\"発達、該当する\">発達</li>\n                      <li class=\"ok\" aria-label=\"知的、該当する\">知的</li>\n                    </ul>\n                  </section>\n                </div>\n              </section>\n              <section id=\"job-regiuchi\" class=\"c-job-box bg-pink\" tabindex=\"-1\">\n                <h4 class=\"box-ttl\">\n                  レジ打ち\n                </h4>\n                <div class=\"white-area\">\n                  <p class=\"balloon anim\">\n                    <span class=\"inn-txt\">\n                      ピッと手際よくお客さまのお会計をサポート\n                    </span>\n                  </p>\n                  <div class=\"img-area\">\n                    <img src=\"/saiyo/challenged/img/home/job-img13.png.webp\" alt=\"レジ打ちをするスタッフのイラスト\">\n                  </div>\n                  <p class=\"txt\">\n                    お客さまがレジにお持ちになった商品をスキャンして、袋詰めしやすいようにかごへ移すお仕事です。レジは商品登録と会計が別になっており、会計はお客さま自身で行うため金銭のやり取りをしないレジもあります。\n                  </p>\n                  <section class=\"desc-wrap\">\n                    <h5 class=\"desc-ttl\">\n                      最初はこんなお仕事をお任せ\n                    </h5>\n                    <p class=\"txt\">\n                      先輩の付き添いのもと、商品の登録方法、レジの打ち方、かごへの商品の入れ方を学びます。\n                    </p>\n                  </section>\n                  <section class=\"desc-wrap\">\n                    <h5 class=\"desc-ttl\">\n                      こんな特性の方が活躍中\n                    </h5>\n                    <ul class=\"desc-list\">\n                      <li aria-label=\"視覚、該当しない\">視覚</li>\n                      <li aria-label=\"聴覚、該当しない\">聴覚</li>\n                      <li aria-label=\"上肢、該当しない\">上肢</li>\n                      <li class=\"ok\" aria-label=\"下肢、該当する\">下肢</li>\n                      <li class=\"ok\" aria-label=\"内臓機能、該当する\">内臓機能</li>\n                      <li class=\"ok\" aria-label=\"精神、該当する\">精神</li>\n                      <li aria-label=\"発達、該当しない\">発達</li>\n                      <li aria-label=\"知的、該当しない\">知的</li>\n                    </ul>\n                  </section>\n                </div>\n              </section>\n              <section id=\"job-medicine\" class=\"c-job-box bg-pink\" tabindex=\"-1\">\n                <h4 class=\"box-ttl\">\n                  薬に関するお仕事\n                </h4>\n                <div class=\"white-area\">\n                  <p class=\"balloon anim\">\n                    <span class=\"inn-txt\">\n                      健康を気軽に相談できる薬の窓口\n                    </span>\n                  </p>\n                  <div class=\"img-area\">\n                    <img src=\"/saiyo/challenged/img/home/job-img14.png.webp\" alt=\"薬局で窓口対応をするスタッフのイラスト\">\n                  </div>\n                  <p class=\"txt\">\n                    薬局で、薬に関するお仕事を行います。薬剤師の資格をお持ちの方には、薬の調剤をお任せします。登録販売者の資格をお持ちの方は、店頭での医薬品販売を行います。資格をお持ちでない方は、処方箋の受付や会計、薬剤師のサポートをする調剤事務をお願いします。\n                  </p>\n                  <section class=\"desc-wrap\">\n                    <h5 class=\"desc-ttl\">\n                      最初はこんなお仕事をお任せ\n                    </h5>\n                    <p class=\"txt\">\n                      薬の配列や、売場にある商品の知識を覚えます。資格の有無によってお仕事内容が異なります。\n                    </p>\n                  </section>\n                  <section class=\"desc-wrap\">\n                    <h5 class=\"desc-ttl\">\n                      こんな特性の方が活躍中\n                    </h5>\n                    <ul class=\"desc-list\">\n                      <li aria-label=\"視覚、該当しない\">視覚</li>\n                      <li aria-label=\"聴覚、該当しない\">聴覚</li>\n                      <li class=\"ok\" aria-label=\"上肢、該当する\">上肢</li>\n                      <li class=\"ok\" aria-label=\"下肢、該当する\">下肢</li>\n                      <li class=\"ok\" aria-label=\"内臓機能、該当する\">内臓機能</li>\n                      <li class=\"ok\" aria-label=\"精神、該当する\">精神</li>\n                      <li aria-label=\"発達、該当しない\">発達</li>\n                      <li aria-label=\"知的、該当しない\">知的</li>\n                    </ul>\n                  </section>\n                </div>\n              </section>\n              <section id=\"job-hanbaisokushin\" class=\"c-job-box bg-pink\" tabindex=\"-1\">\n                <h4 class=\"box-ttl\">\n                  販売促進\n                </h4>\n                <div class=\"white-area\">\n                  <p class=\"balloon anim\">\n                    <span class=\"inn-txt\">\n                      買い物が楽しくなる売場をプロデュース\n                    </span>\n                  </p>\n                  <div class=\"img-area\">\n                    <img src=\"/saiyo/challenged/img/home/job-img15.png.webp\" alt=\"販促物の印刷や掲示をするスタッフのイラスト\">\n                  </div>\n                  <p class=\"txt\">\n                    本社が制作した販促物のデータを印刷し、各部署への配布や店内への掲示が主な業務です。販促物は、食品、衣料、家庭用品など多岐にわたります。また、店頭イベントの後方支援も行います。パソコン作業に自信のある方はスキルを活かせます。\n                  </p>\n                  <section class=\"desc-wrap\">\n                    <h5 class=\"desc-ttl\">\n                      最初はこんなお仕事をお任せ\n                    </h5>\n                    <p class=\"txt\">\n                      先輩による指導のもと、データ入力された販促物を印刷します。\n                    </p>\n                  </section>\n                  <section class=\"desc-wrap\">\n                    <h5 class=\"desc-ttl\">\n                      こんな特性の方が活躍中\n                    </h5>\n                    <ul class=\"desc-list\">\n                      <li aria-label=\"視覚、該当しない\">視覚</li>\n                      <li class=\"ok\" aria-label=\"聴覚、該当する\">聴覚</li>\n                      <li class=\"ok\" aria-label=\"上肢、該当する\">上肢</li>\n                      <li class=\"ok\" aria-label=\"下肢、該当する\">下肢</li>\n                      <li class=\"ok\" aria-label=\"内臓機能、該当する\">内臓機能</li>\n                      <li class=\"ok\" aria-label=\"精神、該当する\">精神</li>\n                      <li class=\"ok\" aria-label=\"発達、該当する\">発達</li>\n                      <li aria-label=\"知的、該当しない\">知的</li>\n                    </ul>\n                  </section>\n                </div>\n              </section>\n            </div>\n          \n            <h3 class=\"c-ttl02 anim\">本社の仕事</h3>\n            <div class=\"job-box-area anim\">\n              <section id=\"job-ippanjimu\" class=\"c-job-box bg-pink\" tabindex=\"-1\">\n                <h4 class=\"box-ttl\">\n                  一般事務\n                </h4>\n                <div class=\"white-area\">\n                  <p class=\"balloon anim\">\n                    <span class=\"inn-txt\">\n                      事務作業でチームを支える存在\n                    </span>\n                  </p>\n                  <div class=\"img-area\">\n                    <img src=\"/saiyo/challenged/img/home/job-img07.png.webp\" alt=\"パソコンで事務作業をするスタッフのイラスト\">\n                  </div>\n                  <p class=\"txt\">\n                    データ入力、データ集計、書類作成、ファイリング、部署メンバーへの郵便物の仕分け、備品管理などが主な業務です。パソコンを使ったデスクワークが中心で、障がい特性に応じて電話対応もお願いします。今までの事務経験やExcelのスキルを活かせます。\n                  </p>\n                  <section class=\"desc-wrap\">\n                    <h5 class=\"desc-ttl\">\n                      最初はこんなお仕事をお任せ\n                    </h5>\n                    <p class=\"txt\">\n                      パソコンを使って、データ入力作業をお任せします。\n                    </p>\n                  </section>\n                  <section class=\"desc-wrap\">\n                    <h5 class=\"desc-ttl\">\n                      こんな特性の方が活躍中\n                    </h5>\n                    <ul class=\"desc-list\">\n                      <li class=\"ok\" aria-label=\"視覚、該当する\">視覚</li>\n                      <li class=\"ok\" aria-label=\"聴覚、該当する\">聴覚</li>\n                      <li class=\"ok\" aria-label=\"上肢、該当する\">上肢</li>\n                      <li class=\"ok\" aria-label=\"下肢、該当する\">下肢</li>\n                      <li class=\"ok\" aria-label=\"内臓機能、該当する\">内臓機能</li>\n                      <li class=\"ok\" aria-label=\"精神、該当する\">精神</li>\n                      <li class=\"ok\" aria-label=\"発達、該当する\">発達</li>\n                      <li aria-label=\"知的、該当しない\">知的</li>\n                    </ul>\n                  </section>\n                </div>\n              </section>\n              <section id=\"job-ecsupport\" class=\"c-job-box bg-pink\" tabindex=\"-1\">\n                <h4 class=\"box-ttl\">\n                  ECサイト運営サポート\n                </h4>\n                <div class=\"white-area\">\n                  <p class=\"balloon anim\">\n                    <span class=\"inn-txt\">\n                      画像を整え、言葉を添えて、サイトにアップ\n                    </span>\n                  </p>\n                  <div class=\"img-area\">\n                    <img src=\"/saiyo/challenged/img/home/job-img08.png.webp\" alt=\"パソコンでECサイト運営サポートをするスタッフのイラスト\">\n                  </div>\n                  <p class=\"txt\">\n                    ネットスーパーなどのECサイト運営サポートのお仕事です。パソコンを使って商品画像データを加工し、タイトルや説明文をつけてサイトに商品を登録します。商品説明文は、取引先から共有を受けた情報をもとに、よりわかりやすい表現に修正します。\n                  </p>\n                  <section class=\"desc-wrap\">\n                    <h5 class=\"desc-ttl\">\n                      最初はこんなお仕事をお任せ\n                    </h5>\n                    <p class=\"txt\">\n                      パソコンを使って、ECサイトへの商品登録や入力サポートをお任せします。\n                    </p>\n                  </section>\n                  <section class=\"desc-wrap\">\n                    <h5 class=\"desc-ttl\">\n                      こんな特性の方が活躍中\n                    </h5>\n                    <ul class=\"desc-list\">\n                      <li class=\"ok\" aria-label=\"視覚、該当する\">視覚</li>\n                      <li class=\"ok\" aria-label=\"聴覚、該当する\">聴覚</li>\n                      <li class=\"ok\" aria-label=\"上肢、該当する\">上肢</li>\n                      <li class=\"ok\" aria-label=\"下肢、該当する\">下肢</li>\n                      <li class=\"ok\" aria-label=\"内臓機能、該当する\">内臓機能</li>\n                      <li class=\"ok\" aria-label=\"精神、該当する\">精神</li>\n                      <li aria-label=\"発達、該当しない\">発達</li>\n                      <li aria-label=\"知的、該当しない\">知的</li>\n                    </ul>\n                  </section>\n                </div>\n              </section>\n              <section id=\"job-shyouhinjimu\" class=\"c-job-box bg-pink\" tabindex=\"-1\">\n                <h4 class=\"box-ttl\">\n                  商品発注業務事務\n                </h4>\n                <div class=\"white-area\">\n                  <p class=\"balloon anim\">\n                    <span class=\"inn-txt\">\n                      商品情報を正確に登録し、円滑な運用をサポート\n                    </span>\n                  </p>\n                  <div class=\"img-area\">\n                    <img src=\"/saiyo/challenged/img/home/job-img09.png.webp\" alt=\"パソコンで商品の発注業務をするスタッフのイラスト\">\n                  </div>\n                  <p class=\"txt\">\n                    店舗の担当者が発注業務をできるように商品情報の登録を行います。また、独自の自動受発注システムを使った数量入力も行います。将来的には、店舗や売場ごとの販売データを分析して、会議資料を作成することもあります。\n                  </p>\n                  <section class=\"desc-wrap\">\n                    <h5 class=\"desc-ttl\">\n                      最初はこんなお仕事をお任せ\n                    </h5>\n                    <p class=\"txt\">\n                      パソコンを使って、データ入力作業のサポートをお任せします。\n                    </p>\n                  </section>\n                  <section class=\"desc-wrap\">\n                    <h5 class=\"desc-ttl\">\n                      こんな特性の方が活躍中\n                    </h5>\n                    <ul class=\"desc-list\">\n                      <li class=\"ok\" aria-label=\"視覚、該当する\">視覚</li>\n                      <li class=\"ok\" aria-label=\"聴覚、該当する\">聴覚</li>\n                      <li class=\"ok\" aria-label=\"上肢、該当する\">上肢</li>\n                      <li class=\"ok\" aria-label=\"下肢、該当する\">下肢</li>\n                      <li class=\"ok\" aria-label=\"内臓機能、該当する\">内臓機能</li>\n                      <li class=\"ok\" aria-label=\"精神、該当する\">精神</li>\n                      <li aria-label=\"発達、該当しない\">発達</li>\n                      <li aria-label=\"知的、該当しない\">知的</li>\n                    </ul>\n                  </section>\n                </div>\n              </section>\n              <section id=\"job-keiyakukanri\" class=\"c-job-box bg-pink\" tabindex=\"-1\">\n                <h4 class=\"box-ttl\">\n                  契約管理\n                </h4>\n                <div class=\"white-area\">\n                  <p class=\"balloon anim\">\n                    <span class=\"inn-txt\">\n                      安心と信頼をつくる書類のプロ\n                    </span>\n                  </p>\n                  <div class=\"img-area\">\n                    <img src=\"/saiyo/challenged/img/home/job-img10.png.webp\" alt=\"パソコンで契約関連のサポートをするスタッフのイラスト\">\n                  </div>\n                  <p class=\"txt\">\n                    取引先と契約を交わす際に、契約書の作成や内容確認を行います。契約内容が法令や規定に沿っているかをチェックし、期限管理やリスク管理も担当します。また、契約に関する問い合わせ対応や調整業務を行い、契約が円滑に進むようサポートします。\n                  </p>\n                  <section class=\"desc-wrap\">\n                    <h5 class=\"desc-ttl\">\n                      最初はこんなお仕事をお任せ\n                    </h5>\n                    <p class=\"txt\">\n                      パソコンを使って、データ入力作業のサポートをお任せします。\n                    </p>\n                  </section>\n                  <section class=\"desc-wrap\">\n                    <h5 class=\"desc-ttl\">\n                      こんな特性の方が活躍中\n                    </h5>\n                    <ul class=\"desc-list\">\n                      <li class=\"ok\" aria-label=\"視覚、該当する\">視覚</li>\n                      <li class=\"ok\" aria-label=\"聴覚、該当する\">聴覚</li>\n                      <li class=\"ok\" aria-label=\"上肢、該当する\">上肢</li>\n                      <li class=\"ok\" aria-label=\"下肢、該当する\">下肢</li>\n                      <li class=\"ok\" aria-label=\"内臓機能、該当する\">内臓機能</li>\n                      <li class=\"ok\" aria-label=\"精神、該当する\">精神</li>\n                      <li aria-label=\"発達、該当しない\">発達</li>\n                      <li aria-label=\"知的、該当しない\">知的</li>\n                    </ul>\n                  </section>\n                </div>\n              </section>\n              <section id=\"job-keirijimu\" class=\"c-job-box bg-pink\" tabindex=\"-1\">\n                <h4 class=\"box-ttl\">\n                  経理事務\n                </h4>\n                <div class=\"white-area\">\n                  <p class=\"balloon anim\">\n                    <span class=\"inn-txt\">\n                      ミスなくコツコツお金の記録係\n                    </span>\n                  </p>\n                  <div class=\"img-area\">\n                    <img src=\"/saiyo/challenged/img/home/job-img11.png.webp\" alt=\"パソコンで経理業務をするスタッフのイラスト\">\n                  </div>\n                  <p class=\"txt\">\n                    取引先からの請求書の確認や自社システムへのデータ入力、請求書や領収書の発行、管理、経費精算などが主な業務です。さらに、税金の申告書類や財務資料の作成補助も行います。正確さや細部への注意力が求められるお仕事です。\n                  </p>\n                  <section class=\"desc-wrap\">\n                    <h5 class=\"desc-ttl\">\n                      最初はこんなお仕事をお任せ\n                    </h5>\n                    <p class=\"txt\">\n                      パソコンを使って、データ入力作業のサポートをお任せします。\n                    </p>\n                  </section>\n                  <section class=\"desc-wrap\">\n                    <h5 class=\"desc-ttl\">\n                      こんな特性の方が活躍中\n                    </h5>\n                    <ul class=\"desc-list\">\n                      <li class=\"ok\" aria-label=\"視覚、該当する\">視覚</li>\n                      <li class=\"ok\" aria-label=\"聴覚、該当する\">聴覚</li>\n                      <li class=\"ok\" aria-label=\"上肢、該当する\">上肢</li>\n                      <li class=\"ok\" aria-label=\"下肢、該当する\">下肢</li>\n                      <li class=\"ok\" aria-label=\"内臓機能、該当する\">内臓機能</li>\n                      <li class=\"ok\" aria-label=\"精神、該当する\">精神</li>\n                      <li aria-label=\"発達、該当しない\">発達</li>\n                      <li aria-label=\"知的、該当しない\">知的</li>\n                    </ul>\n                  </section>\n                </div>\n              </section>\n            </div>\n          </div>\n\n        </div>\n      </section>\n    </main>\n\n    <footer></footer>\n    <script>\n      $('footer').load('/saiyo/challenged/inc/c-footer.html');\n    </script>\n  </div><!-- /wrapper -->\n\n  <script src=\"/saiyo/challenged/js/lib/splide.min.js\"></script>\n\n  <script src=\"/saiyo/challenged/js/lib/jquery.matchHeight-min.js\"></script>\n  <script src=\"/saiyo/challenged/js/common.js\"></script>\n</body>\n\n</html>","finalUrl":"https://www.aeonretail.jp/saiyo/challenged/work/","rendered":false,"_cachedAt":"2026-06-22T21:07:01.600Z"}