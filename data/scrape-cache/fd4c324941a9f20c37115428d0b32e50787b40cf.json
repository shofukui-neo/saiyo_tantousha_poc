{"url":"https://persol-hrpartners.co.jp/info/info01.html","html":"<!DOCTYPE html>\r\n<html lang=\"ja\">\r\n\r\n<head>\r\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\r\n<meta charset=\"utf-8\">\r\n<meta name=\"robots\" content=\"index, follow\">\r\n<meta name=\"keywords\" content=\"iPhone及びiPadをお使いの皆さまへ,派遣,派遣会社,人材派遣,パーソルエクセルHRパートナーズ\">\r\n<meta name=\"description\" content=\"iPhone及びiPadをお使いの皆さまへ。派遣、紹介予定派遣の求人・人材派遣会社はパーソルエクセルHRパートナーズ。\">\r\n<meta http-equiv=\"pragma\" content=\"no-cache\">\r\n<meta name=\"viewport\" content=\"width=device-width\">\r\n<title>iPhone及びiPadをお使いの皆さまへ【パーソルエクセルHRパートナーズ】人材派遣会社</title>\r\n<meta property=\"og:url\" content=\"https://persol-hrpartners.co.jp/company/profile.html\" />\r\n<meta property=\"og:type\" content=\"article\" />\r\n<meta property=\"og:title\" content=\"iPhone及びiPadをお使いの皆さまへ【パーソルエクセルHRパートナーズ】人材派遣会社\" />\r\n<meta property=\"og:description\" content=\"iPhone及びiPadをお使いの皆さまへ。派遣、紹介予定派遣の求人・人材派遣会社はパーソルエクセルHRパートナーズ。\" />\r\n<meta property=\"og:site_name\" content=\"事務・エンジニアの派遣・正社員のお仕事探し【パーソルエクセルHRパートナーズ】人材派遣会社\" />\r\n<meta property=\"og:image\" content=\"https://persol-hrpartners.co.jp/img/common/ogp_pphr.png\" />\r\n<meta content=\"summary_large_image\" property=\"twitter:card\" />\r\n\r\n<!-- Google Tag Manager -->\r\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\r\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\r\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\r\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\r\n})(window,document,'script','dataLayer','GTM-NTKXXD3');</script>\r\n<!-- End Google Tag Manager -->\r\n\r\n<!--common_css-->\r\n<link href=\"/css/common.css\" rel=\"stylesheet\">\r\n<link href=\"/css/style.css\" rel=\"stylesheet\">\r\n<!--local_CSS-->\r\n<link href=\"/css/info_info01.css\" rel=\"stylesheet\">\r\n</head>\r\n\r\n<body>\r\n\r\n<!-- Google Tag Manager (noscript) -->\r\n<noscript>\r\n<iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-NTKXXD3\"\r\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe>\r\n</noscript>\r\n<!-- End Google Tag Manager (noscript) -->\r\n\r\n  <div id=\"wrapper\">\r\n    <!-- header -->\r\n    <header data-include=\"header\"></header>\r\n    <!-- /header -->\r\n    <div id=\"category_sub\" class=\"container\">\r\n      <!-- main-visual -->\r\n      <div id=\"category_info\" class=\"main-visual\">\r\n        <div class=\"main-visual-inner\">\r\n          <h1 class=\"main-ttl\">iPhone及びiPadをお使いの皆さまへ</h1>\r\n        </div>\r\n      </div>\r\n      <!-- /main-visual -->\r\n      <div class=\"contents\">\r\n        <div class=\"contents-inner\">\r\n          <!-- breadcrumbs -->\r\n          <div class=\"breadcrumbs\">\r\n            <ul class=\"breadcrumbs-list\">\r\n              <li class=\"\"><a href=\"/\">トップページ</a></li>\r\n              <li>iPhone及びiPadをお使いの皆さまへ</li>\r\n            </ul>\r\n          </div>\r\n          <!-- /breadcrumbs -->\r\n        </div>\r\n        <div class=\"contents-inner\">\r\n          <!-- main-content -->\r\n          <div class=\"main-content\">\r\n            <div class=\"main-text-cont\">\r\n              <p class=\"text-block\">iPhone及びiPadから弊社事務系派遣サイト・エンジニア派遣サイトを開いた際に「以下のページは制限されているのでブラウズできません」というページが表示され、ページが開けない現象がございます。</p>\r\n              <p class=\"img aC\"><img src=\"/img/info_info01/pic_info01_error.png\" alt=\"error\"></p>\r\n              <p class=\"text-block\">対象サイト：事務系派遣・エンジニア派遣モバイルサイト</p>\r\n              <p class=\"text-block\">「WEBサイトを許可する」をタップいただくか、ご利用の端末の「コンテンツとプライバシーの制限」にて設定を変更していただく必要がございます。<br>\r\n              お手数ですが以下の手順に従って、「コンテンツ制限を無制限アクセス」か「Webサイトを追加」していただきますよう、お願いいたします。</p>\r\n            </div>\r\n            <h2 class=\"h2-ttl\">「コンテンツとプライバシーの制限」設定変更の手順</h2>\r\n            <div class=\"main-text-cont\">\r\n              <div class=\"col2\">\r\n                <p class=\"text-block left-cont\">（１）ホーム画面から設定を開き、「スクリーンタイム」をタップ</p>\r\n                <p class=\"img-block right-cont\"><img src=\"/img/info_info01/pic_info01_01.png\" alt=\"step01\"></p>\r\n              </div>\r\n            </div>\r\n            <div class=\"main-text-cont\">\r\n              <div class=\"col2\">\r\n                <p class=\"text-block left-cont\">（２）スクリーンタイムから「コンテンツとプライバシーの制限」をタップ</p>\r\n                <p class=\"img-block right-cont\"><img src=\"/img/info_info01/pic_info01_02.png\" alt=\"step02\"></p>\r\n              </div>\r\n            </div>\r\n            <div class=\"main-text-cont\">\r\n              <div class=\"col2\">\r\n                <p class=\"text-block left-cont\">（３）コンテンツとプライバシーの制限から「コンテンツ制限」をタップ</p>\r\n                <p class=\"img-block right-cont\"><img src=\"/img/info_info01/pic_info01_03.png\" alt=\"step03\"></p>\r\n              </div>\r\n            </div>\r\n            <div class=\"main-text-cont\">\r\n              <div class=\"col2\">\r\n                <p class=\"text-block left-cont\">（４）コンテンツ制限から「WEBコンテンツ」をタップ</p>\r\n                <p class=\"img-block right-cont\"><img src=\"/img/info_info01/pic_info01_04.png\" alt=\"step04\"></p>\r\n              </div>\r\n            </div>\r\n            <div class=\"main-text-cont\">\r\n              <div class=\"col2\">\r\n                <p class=\"text-block left-cont\">（５）WEBコンテンツから「無制限アクセス」か<br class=\"pc-only\">\r\n                「成人向けWebサイトを制限」または「許可されたWEBサイトのみ」をタップ</p>\r\n                <p class=\"img-block right-cont\"><img src=\"/img/info_info01/pic_info01_05.png\" alt=\"step05\"></p>\r\n              </div>\r\n            </div>\r\n            <div class=\"main-text-cont\">\r\n              <div class=\"col2\">\r\n                <p class=\"text-block left-cont\">（６）<span class=\"colR\">「無制限アクセス」をタップされた方は設定終了です。</span><br>\r\n                「成人向けWebサイトを制限」または「許可されたWebサイトのみ」をタップされた方は、「Webサイトを追加」をタップ</p>\r\n                <p class=\"img-block right-cont\"><img src=\"/img/info_info01/pic_info01_06.png\" alt=\"step06\"></p>\r\n              </div>\r\n            </div>\r\n            <div class=\"main-text-cont\">\r\n              <div class=\"col2\">\r\n                <p class=\"text-block left-cont\">（７）「Webサイトを追加」にて閲覧いただくサイトURLを入力ください。<br>\r\n                https://persol-hrpartners.co.jp</p>\r\n                <p class=\"img-block right-cont\"><img src=\"/img/info_info01/pic_info01_07.png\" alt=\"step07\"></p>\r\n              </div>\r\n            </div>\r\n            <div class=\"main-text-cont\">\r\n              <p class=\"text-block\">お手数をお掛けしますが、よろしくお願いいたします。</p>\r\n            </div>\r\n          </div>\r\n          <!-- /main-content -->\r\n        </div>\r\n      </div>\r\n      <!-- footerNavi -->\r\n      <div data-include=\"footerNavi\"></div>\r\n      <!-- /footerNavi -->\r\n    </div>\r\n    <!-- footer -->\r\n    <footer data-include=\"footer\"></footer>\r\n    <!-- /footer -->\r\n  </div><!-- /#wrapper -->\r\n  <!--common_JS-->\r\n  <script type=\"text/javascript\" src=\"/libs/jquery-3.3.1.min.js\"></script>\r\n  <script type=\"text/javascript\" src=\"/js/import.js\"></script>\r\n  <script type=\"text/javascript\" src=\"/js/script.js\"></script>\r\n</body>\r\n\r\n</html>","finalUrl":"https://persol-hrpartners.co.jp/info/info01.html","rendered":false,"_cachedAt":"2026-06-22T22:20:37.390Z"}