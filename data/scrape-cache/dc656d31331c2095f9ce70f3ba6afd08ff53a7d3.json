{"url":"https://www.pro-win.co.jp/recruit/department/","html":"<!doctype html>\r\n<html>\r\n<head>\r\n<meta charset=\"utf-8\">\r\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1, user-scalable=no\">\r\n<meta name=\"format-detection\" content=\"telephone=no\">\r\n<title>部署紹介｜株式会社ウイン 採用情報</title>\r\n<meta name=\"keywords\" content=\"\">\r\n<meta name=\"description\" content=\"\">\r\n<!-- common -->\r\n<link href=\"../common/css/base.css\" rel=\"stylesheet\" type=\"text/css\">\r\n<link href=\"../common/css/common.css\" rel=\"stylesheet\" type=\"text/css\">\r\n<link href=\"../common/css/contents.css\" rel=\"stylesheet\" type=\"text/css\">\r\n<link rel=\"icon\" href=\"/common/images/favicon.svg\" type=\"image/svg\">\r\n<!--[if lt IE 9]>\r\n<script src=\"http://html5shim.googlecode.com/svn/trunk/html5.js\"></script>\r\n<![endif]-->\r\n<script src=\"http://ajax.googleapis.com/ajax/libs/jquery/1.8.2/jquery.min.js\"></script>\r\n<script src=\"../common/js/jquery.cookie.js\" type=\"text/javascript\"></script>\r\n<script type=\"text/javascript\" src=\"../common/js/jquery.set.js\"></script>\r\n<script type=\"text/javascript\" src=\"../common/js/heightLine.js\"></script>\r\n<script type=\"text/javascript\" src=\"../common/js/scrollsmoothly.js\"></script>\r\n<script src=\"//kitchen.juicer.cc/?color=Hvo/yBbwnSM=\" async></script>\n<!-- Google tag (gtag.js) -->\n\t<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-3MKRWRKFDZ\"></script>\n\t<script>\n\t\twindow.dataLayer = window.dataLayer || [];\n\n\t\tfunction gtag() {\n\t\t\tdataLayer.push(arguments);\n\t\t}\n\t\tgtag('js', new Date());\n\n\t\tgtag('config', 'G-3MKRWRKFDZ');\n\n\t</script>\n<!-- Begin Mieruca Embed Code -->\n<script type=\"text/javascript\" id=\"mierucajs\">\nwindow.__fid = window.__fid || [];__fid.push([806551535]);\n(function() {\nfunction mieruca(){if(typeof window.__fjsld != \"undefined\") return; window.__fjsld = 1; var fjs = document.createElement('script'); fjs.type = 'text/javascript'; fjs.async = true; fjs.id = \"fjssync\"; var timestamp = new Date;fjs.src = ('https:' == document.location.protocol ? 'https' : 'http') + '://hm.mieru-ca.com/service/js/mieruca-hm.js?v='+ timestamp.getTime(); var x = document.getElementsByTagName('script')[0]; x.parentNode.insertBefore(fjs, x); };\nsetTimeout(mieruca, 500); document.readyState != \"complete\" ? (window.attachEvent ? window.attachEvent(\"onload\", mieruca) : window.addEventListener(\"load\", mieruca, false)) : mieruca();\n})();\n</script>\n<!-- End Mieruca Embed Code -->\n</head>\r\n\r\n<body id=\"PageDepartment\">\r\n<!-- skip_nav -->\r\n<div id=\"page_top\">\r\n  <p class=\"skip\">ページの先頭です。</p>\r\n  <p class=\"skip\"><a href=\"#skip_menu\">メインメニューへ移動します。</a></p>\r\n  <p class=\"skip\"><a href=\"#skip_honbun\">本文へ移動します。</a></p>\r\n  <p class=\"skip\"><a href=\"#skip_footer\">フッターへ移動します。</a></p>\r\n</div>\r\n<!-- /skip_nav --> \r\n\r\n<!-- // Header START // -->\r\n<header>\r\n<div id=\"HeadSubMenu\">\r\n<ul class=\"clearfix\">\r\n  <li><a href=\"/inquiry/\">お問い合わせ</a></li>\r\n  <li><a href=\"/profile/office.html\">アクセス</a></li>\r\n  <li><a href=\"/\">ウインコーポレートサイト</a></li>\r\n</ul>\r\n</div><!-- /#HeadSubMenu -->\r\n\r\n<p id=\"skip_menu\" class=\"skip\">メインメニューです。</p>\r\n<div id=\"HeadEntryMenu\" class=\"clearfix\">\r\n  <div class=\"innerBlock\">\r\n    <p><a href=\"/recruit/\"><img src=\"/recruit/common/images/logo.png\" width=\"388\" height=\"34\" alt=\"株式会社ウイン 採用情報\"/></a></p>\r\n    <ul class=\"clearfix button\">\r\n      <li><a href=\"/recruit/entry/#section01\">新卒採用</a></li>\r\n      <li><a href=\"/recruit/entry/#section02\">キャリア採用</a></li>\r\n    </ul>\r\n  </div>\r\n</div><!-- /#HeadEntryMenu --><div id=\"HeadGlobalMenu\">\r\n  <ul class=\"clearfix button\">\r\n    <li><a href=\"/recruit/vision/\">ビジョン</a></li>\r\n    <li><a href=\"/recruit/seek/\">求める人材</a></li>\r\n    <li><a href=\"/profile/approach.html\">ウインの取組み</a></li>\r\n    <li><a href=\"/recruit/department/\">部署紹介</a></li>\r\n    <li><a href=\"/recruit/jobcategory/\">募集職種</a></li>\r\n    <li><a href=\"/recruit/flow/\">採用の流れ</a></li>\r\n  </ul>\r\n</div><!-- /#HeadGlobalMenu --></header>\r\n<!-- // Header END // -->\r\n\r\n<!-- // Contents START // -->\r\n\r\n<!-- topicPath -->\r\n<div id=\"topicPath\">\r\n  <ul class=\"clearfix\">\r\n    <li><a href=\"/recruit/department/#section01\">営業課</a></li>\r\n    <li><a href=\"/recruit/department/#section02\">第一・第二システム課</a></li>\r\n    <li><a href=\"/recruit/department/#section03\">Webシステム課</a></li>\r\n    <!--\r\n    <li><a href=\"/recruit/department/message/\">社員からのメッセージ</a></li>\r\n    -->\r\n  </ul>\r\n</div>\r\n<!-- /topicPath -->\r\n\r\n<p id=\"skip_honbun\" class=\"skip\">本文です。</p>\r\n\r\n<h1>部署紹介<span>Department introduction</span></h1>\r\n\r\n<div id=\"tabMenu\">\r\n<ul class=\"clearfix\">\r\n  <li><a href=\"#section01\"><img class=\"imgover\" src=\"images/tab_sales.png\" width=\"150\" height=\"84\" alt=\"営業課\"/></a></li>\r\n  <li><a href=\"#section02\"><img class=\"imgover\" src=\"images/tab_system.png\" width=\"150\" height=\"84\" alt=\"第一・第二システム課\"/></a></li>\r\n  <li><a href=\"#section03\"><img class=\"imgover\" src=\"images/tab_web.png\" width=\"150\" height=\"84\" alt=\"Webシステム課\"/></a></li>\r\n<!--\r\n<li><a href=\"#section04\"><img class=\"imgover\" src=\"images/tab_branding.png\" width=\"150\" height=\"84\" alt=\"ブランディング戦略企画室\"/></a></li>\r\n-->\r\n\t</ul>\r\n</div>\r\n\r\n<div id=\"section01\">\r\n<section>\r\n  <h2><img src=\"../common/images/icon_sales.png\" width=\"120\" height=\"120\" alt=\"営業課\"/>営業課<span>Sales Division</span></h2>\r\n  <p class=\"blue\">営業課では、官公庁・自治体、大手・中小企業様の抱える問題の解決、<br>\r\n    また現状よりもっと良くしたいという思いにお応えすべく<br>さまざまなソリューションやサービスの提案活動を行っています。</p>\r\n  <div>\r\n  \t<h3>問題解決のためのサポート</h3>\r\n    <dl>\r\n    \t<dt class=\"no01\">ITに関するお悩み</dt>\r\n      <dd>当社の持つ自社製品パッケージソフト、他社製品パッケージソフト、ハードウェア、IT資産管理サービス等のさまざまなサービス、またITに関するヒューマンリソースの提案営業など、お客様のITに関するお悩みを、総合的にサポートしてまいります。</dd>\r\n      <dt class=\"no02\">クリエイティブに関するお悩み</dt>\r\n      <dd>ホームページの企画提案、デザインに関わるデジタル・リアルコンテンツ、また会社ロゴデザインや企業のイメージブランディングまで、クリエイティブに関するお悩みやご要望を、総合的にサポートいたします。</dd>\r\n    </dl>\r\n  </div>\r\n  <div>\r\n  \t<h3>ウインの営業スタイル</h3>\r\n    <p>当社の営業スタイルは、お客様に対し誠実に向き合い、お客様にとって何がよいのかを、常にお客様目線で考えることを心掛け、お客様からいただいたご意見を真摯に受けとめ、ご提案及びサービスの向上に努めています。</p>\r\n    <p>お客様の業種が幅広いことや、取り扱う営業品目が多岐にわたるため、長期の提案期間を要する案件や短期間勝負の案件など、さまざまございます。<br>また同じパッケージ製品を取り扱う案件であっても、お客様が違えば要望される内容もさまざまなため、一つとして同じ提案の繰り返しとなる案件はなく、日々新しい出来事との出会いとなるお仕事です。</p>\r\n  </div>\r\n</section>\r\n\r\n<!--\r\n<div id=\"staffBox\">\r\n<h4><img src=\"images/ttl_staff.png\" width=\"340\" height=\"40\" alt=\"この部署の社員はこちら\"/></h4>\r\n<ul class=\"clearfix\">\r\n  <li><a href=\"message/sales/m_y.html\"><img src=\"message/images/pic_m_y.png\" alt=\"Y.M\"/></a></li>\r\n  <li><a href=\"message/sales/d_s.html\"><img src=\"message/images/pic_d_s.png\" alt=\"S.D\"/></a></li>\r\n</ul>\r\n</div>--><!-- /#staffBox -->\r\n</div><!-- /#section01 -->\r\n\r\n\r\n<div id=\"section02\">\r\n<section>\r\n  <h2><img src=\"../common/images/icon_system.png\" width=\"120\" height=\"120\" alt=\"第一・第二システム課\"/>第一・第二システム課<span>First and Second System Division</span></h2>\r\n  <p class=\"blue\">第一・第二システム課では<br>\r\n    官公庁・自治体、大手・中小企業様に向けたソフトウェア製品の開発提供<br>\r\n    そのソフトウェアが動く基盤の構築提供<br>\r\n    そしてITサービスの提供を行っています。</p>\r\n  <div>\r\n  \t<h3>自社パッケージ製品の開発・カスタマイズ・保守対応</h3>\r\n    <p>当社が所有する自社パッケージ製品の開発・カスタマイズ・保守対応を行っています。</p>\r\n    <ul>\r\n    \t<li>販売管理システム</li>\r\n      <li>物流検品システム</li>\r\n      <li>不動産担保評価管理システム 等（一部抜粋）</li>\r\n    </ul>\r\n  </div>\r\n  <div>\r\n  \t<h3>オーダーメイドの受託開発業務</h3>\r\n    <p>お客様の独自の要望に合わせた、オーダーメイドの受託開発業務を行っています。</p>\r\n    <ul>\r\n      <li>会計システム、生産管理システム他、業務アプリケーション開発</li>\r\n      <li>営業支援システム、会員管理システム他、Webアプルケーション開発（一部抜粋）</li>\r\n    </ul>\r\n    </div>\r\n  <div>\r\n  \t<h3>モバイル製品、ハードウェア、ミドルウェア等の開発</h3>\r\n    <p>モバイル製品、ハードウェア、ミドルウェア等の開発を行っています。</p>\r\n    <ul>\r\n      <li>Android端末の開発</li>\r\n      <li>Android、iOSに実装されるアプリケーションの開発</li>\r\n      <li>その他制御プログラム、ミドルウェア等の開発</li>\r\n    </ul>\r\n    </div>\r\n  <div>\r\n  \t<h3 class=\"pickup\">技術者派遣・業務委託</h3>\r\n    <p>経験を積んだ技術者を必要とされるお客様先に常駐させていただき、技術者派遣や委託といった形で、多彩な技術を駆使してモバイル・Webアプリケーションから組込系ソフトウェアまで、幅広い分野において多様なフェーズで技術力の提供を行っています。</p>\r\n\t</div>\r\n</section>\r\n\r\n<!--\r\n<div id=\"staffBox\">\r\n<h4><img src=\"images/ttl_staff.png\" width=\"340\" height=\"40\" alt=\"この部署の社員はこちら\"/></h4>\r\n<ul class=\"clearfix\">\r\n  <li><a href=\"message/system/a_k.html\"><img src=\"message/images/pic_a_k.png\" alt=\"K.A\"/></a></li>\r\n  <li><a href=\"message/system/s_k.html\"><img src=\"message/images/pic_s_k.png\" alt=\"K.S\"/></a></li>\r\n</ul>\r\n</div>--><!-- /#staffBox -->\r\n</div><!-- /#section02 -->\r\n\r\n\r\n<div id=\"section03\">\r\n<section>\r\n  <h2><img src=\"../common/images/icon_web.png\" width=\"120\" height=\"120\" alt=\"Webシステム課\"/>Webシステム課<span>Web Systems Division</span></h2>\r\n  <p class=\"blue\">Webシステム課では<br>\r\n    官公庁・自治体、大手・中小企業様に向けたWebサイト制作のみでなく<br>\r\n    その企画提案からプロモーションまでの<br>\r\n    Webトータルソリューションの提供を行っています。<br>\r\n  </p>\r\n  <div>\r\n  \t<h3>Webプランニングサービス</h3>\r\n  \t<ul>\r\n  \t  <li>企画の提案、戦略の立案、課題の発見</li>\r\n      <li>綿密な設計、運用開始後のフォロー</li>\r\n      </ul>\r\n  \t<p>あらゆる角度から具体的な解決策の提案や、成果を上げるための改善案などをプランニングいたします。</p>\r\n  </div>\r\n  <div>\r\n  \t<h3>Webプロダクトサービス</h3>\r\n  \t<ul>\r\n  \t  <li>Webを中心としたコンテンツの構成、デザイン、コーディング</li>\r\n      <li>デザインと両立したシステムの設計、開発</li>\r\n      </ul>\r\n  \t<p>さまざまな実績から得たノウハウを元に、お客様にとって最適な方法で制作や構築を行います。</p>\r\n    </div>\r\n  <div>\r\n  \t<h3>Webプロモーションサービス</h3>\r\n  \t<ul>\r\n  \t  <li>SEO対策</li>\r\n      <li>Webサイト運用保守やアクセス解析レポート</li>\r\n      </ul>\r\n  \t<p>お客様のWebサイトに期待される効果を、現状の分析から成功への道筋をトータルに提案いたします。</p>\r\n    </div>\r\n\t<div>\r\n  \t<h3 class=\"pickup\">本当の効果を引き出す戦略</h3>\r\n    <p>デジタルコンテンツとリアルコンテンツの融合にて、Webだけで終わらせない本当の効果を引き出す戦略をご提案しています。</p>\r\n  </div>\r\n</section>\r\n\r\n<!--\r\n<div id=\"staffBox\">\r\n<h4><img src=\"images/ttl_staff.png\" width=\"340\" height=\"40\" alt=\"この部署の社員はこちら\"/></h4>\r\n<ul class=\"clearfix\">\r\n  <li><a href=\"message/web/y_o.html\"><img src=\"message/images/pic_y_o.png\" alt=\"O.Y\"/></a></li>\r\n</ul>\r\n</div>--><!-- /#staffBox -->\r\n</div><!-- /#section03 -->\r\n<!--\r\n<div id=\"section04\">\r\n<section>\r\n  <h2><img src=\"../common/images/icon_branding.png\" width=\"120\" height=\"120\" alt=\"ブランディング戦略企画室\"/>ブランディング戦略企画室<span>Branding Strategy Planning Office</span></h2>\r\n  <p class=\"blue\">ブランディング戦略企画室では<br>\r\n    「ブランディング戦略に特化したクリエイティブ事業」をコンセプトに<br>\r\n    県内外の官公庁・自治体、大手・中小企業様のサービス・商品の魅力を<br>\r\n    独自優位的に開発・構築・展開・運営までを一貫して行っています。 <br>\r\n  </p>\r\n  <div>\r\n  \t<h3>ブランディング開発（市場・ユーザー調査）</h3>\r\n  \t<p>サービスや商品、地域の魅力を掘り起こし、象徴化のためのマーケティングリサーチを行います。</p>\r\n  </div>\r\n  <div>\r\n  \t<h3>ブランディング構築（デザイニング）</h3>\r\n  \t<p>開発したUSP（独自優位性）を視覚化（ブランドマーク）、言語化（ブランドコピー）します。</p>\r\n    </div>\r\n  <div>\r\n  \t<h3>ブランディング展開（広告・販促プロモーション）</h3>\r\n  \t<p>ブランドマーク・コピーや、キーとなるビジュアルデザインを事業戦略に合わせ、各広告媒体を用いながら効果的に活用します。</p>\r\n    </div>\r\n  <div>\r\n  \t<h3>ブランディング運営（広告費運営）</h3>\r\n  \t<p>年間の広告費用を元に、経営戦略に合わせ効果的に運用します。</p>\r\n    </div>\r\n\t<div>\r\n  \t<h3 class=\"pickup\">中長期のクロスメディア展開</h3>\r\n    <p>経営ビジョンに即したブランディング戦略を行うことにより、紙・Webなどの媒体に依存しない、中長期のクロスメディア展開を行います。</p>\r\n  </div>\r\n</section>\r\n-->\r\n</div><!-- /#section04 -->\r\n\r\n<!-- // Contents END // -->\r\n\r\n\r\n<!-- // Footer START // -->\r\n<footer>\r\n<div id=\"FooterNavi\" class=\"button\">\r\n<ul class=\"col2 clearfix\">\r\n  <li><a href=\"/recruit/entry/#section01\">新卒採用</a></li>\r\n  <li><a href=\"/recruit/entry/#section02\">キャリア採用</a></li>\r\n</ul>\r\n<ul class=\"col3 clearfix\">\r\n  <li><a href=\"/recruit/department/\">部署紹介</a></li>\r\n  <li><a href=\"/recruit/jobcategory/\">募集職種</a></li>\r\n  <li><a href=\"/recruit/flow/\">採用の流れ</a></li>\r\n</ul>\r\n</div><!-- /#FooterNavi -->\r\n<div id=\"gotop\"><a href=\"#page_top\"><img class=\"imgover\" src=\"/recruit/common/images/btn_pagetop.png\" width=\"70\" height=\"70\" alt=\"このページの一番上へ\" /></a></div> \r\n<p id=\"skip_footer\" class=\"skip\">フッターです。</p>\r\n</footer>\r\n<!-- // Footer END // -->\r\n\r\n</body>\r\n</html>\r\n","finalUrl":"https://www.pro-win.co.jp/recruit/department/","rendered":false,"_cachedAt":"2026-06-22T16:48:09.308Z"}