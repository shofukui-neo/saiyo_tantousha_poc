{"url":"https://www.telecomsquare.net/recruit/","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n  <head prefix=\"og: https://ogp.me/ns# fb: https://ogp.me/ns/fb# article: https://ogp.me/ns/article#\">\n    <meta charset=\"UTF-8\">\n    <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n    <meta name=\"viewport\" content=\"width=device-width\">\n    <meta name=\"robots\" content=\"index,follow\">\n    <meta name=\"format-detection\" content=\"telephone=no\">\n    <meta name=\"description\" content=\"株式会社テレコムスクエアの採用情報についてご案内いたします。\">\n    <meta name=\"twitter:card\" content=\"summary_large_image\">\n    <meta name=\"twitter:image\" content=\"https://www.telecomsquare.net/assets/img/common/ogp.png\">\n    <meta name=\"twitter:url\" content=\"https://www.telecomsquare.net/recruit/\">\n    <meta name=\"twitter:description\" content=\"株式会社テレコムスクエアの採用情報についてご案内いたします。\">\n    <meta name=\"twitter:title\" content=\"採用情報 | 株式会社テレコムスクエア\">\n    <meta property=\"og:description\" content=\"株式会社テレコムスクエアの採用情報についてご案内いたします。\">\n    <meta property=\"og:site_name\" content=\"株式会社テレコムスクエア\">\n    <meta property=\"og:locale\" content=\"ja_JP\">\n    <meta property=\"og:type\" content=\"article\">\n    <meta property=\"og:image\" content=\"https://www.telecomsquare.net/assets/img/common/ogp.png\">\n    <meta property=\"og:url\" content=\"https://www.telecomsquare.net/recruit/\">\n    <meta property=\"og:title\" content=\"採用情報 | 株式会社テレコムスクエア\">\n    <title>採用情報 | 株式会社テレコムスクエア</title>\n    <link rel=\"icon\" href=\"/favicon.ico\">\n    <link rel=\"apple-touch-icon\" href=\"/apple-touch-icon.png\"><link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n    <link href=\"https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700&family=Noto+Sans+JP:wght@400;500;700&display=swap\" rel=\"stylesheet\">\n    <link href=\"/assets/css/style.css?230525\" rel=\"stylesheet\">\n    \n    <script src=\"/assets/js/script.js\" defer></script>\n<!-- Cookie Tag -->\n<script type=\"text/javascript\">\n  var _tscc_conf = _tscc_conf || {};\n  _tscc_conf['domain'] = '.telecomsquare.net';\n  _tscc_conf['cookie_policy_url'] = '/privacypolicy/';\n  _tscc_conf['cookie_expiry_days'] = { 'allow': 365, 'deny': 30 }; \n\n  /* ポップアップの表示オプション（任意） */\n  var _tsccwid_options = {\n    design: {\n      bg_color: \"#fff\", /* 背景色 */\n      text_color: \"#1c1c1c\", /* 文字色 */\n    },\n    content: {\n      ja: {\n        message: \"\",\n        link_text: \"\",\n        link_url: \"\",\n        allow_btn_text: \"\",\n        deny_btn_text: \"\"\n      },\n      en: {\n        message: \"\",\n        link_text: \"\",\n        link_url: \"\",\n        allow_btn_text: \"\",\n        deny_btn_text: \"\"\n      }\n    }\n  };\n\n  var _gaq = _gaq || [];\n  (function () {\n    var js_src = '/assets/js/tscc.min.js'; \n\n    var cc = document.createElement('script'); cc.type = 'text/javascript'; cc.async = true;\n    cc.src = js_src;\n\n    window.onload = () => {\n      var s = document.getElementsByTagName('script')[0];\n      s.parentNode.insertBefore(cc, s);\n    }\n  })();\n</script>\n<!-- Cookie Tag -->\n    \n    \n<!-- Google Tag Manager -->\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n})(window,document,'script','dataLayer','GTM-WWCBG9');</script>\n<!-- End Google Tag Manager -->\n  </head>\n  <body>\n    <!-- Google Tag Manager (noscript) -->\n    <noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-WWCBG9\" height=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n    <!-- End Google Tag Manager (noscript) -->\n    <header>\n      <p><a href=\"/\"><img src=\"/assets/img/common/logo.svg\" alt=\"Telecom Square\"></a></p>\n      <button data-toggle=\"menu\"><span>Menu</span></button>\n    </header>\n    <nav>\n      <ul class=\"nav\">\n        <li><a href=\"/\">Top</a></li>\n        <li>\n          <button data-toggle=\"accordion\">\n            <span>About us</span>\n            <img src=\"/assets/img/common/ico-arrow.svg\" alt=\"\">\n          </button>\n          <ul>\n            <li><a href=\"/aboutus/\">テレコムスクエアについて</a></li>\n            <li><a href=\"/aboutus/company/\">会社概要</a></li>\n            <li><a href=\"/aboutus/history/\">沿革</a></li>\n            <li><a href=\"/aboutus/ge_actionplan/\">一般事業主行動計画</a></li>\n            <li><a href=\"/aboutus/eruboshi_certification/\">女性活躍推進への取組み</a></li>\n          </ul>\n        </li>\n        <li>\n          <button data-toggle=\"accordion\">\n            <span>Service</span>\n            <img src=\"/assets/img/common/ico-arrow.svg\" alt=\"\"></button>\n          <ul>\n            <li><a href=\"/solution-service/\">サービス一覧</a></li>\n            <li><a href=\"/solution-service/#mobile-communications\">モバイル通信サービス</a></li>\n            <li><a href=\"/solution-service/#business\">モバイル通信サービスWi-Ho!</a></li>\n            <li><a href=\"/solution-service/#sharing\">バイクシェアサービス</a></li>\n            <li><a href=\"https://www.telecomsquare.net/media/?utm_source=corporate&utm_medium=referral&utm_campaign=none\" target=\"_blank\">Telecom Times</a></li>\n          </ul>\n        </li>\n        <li>\n          <button data-toggle=\"accordion\">\n            <span class=\"isActive\">Recruit</span>\n            <img src=\"/assets/img/common/ico-arrow.svg\" alt=\"\"></button>\n          <ul>\n            <li><a href=\"/recruit/\">採用情報</a></li>\n            <li><a href=\"/recruit/#interview\">社員インタビュー</a></li>\n            <li><a href=\"/recruit/careerplan/\">キャリアモデル</a></li>\n          </ul>\n        </li>\n        <li>\n          <button data-toggle=\"accordion\">\n            <span>News</span>\n            <img src=\"/assets/img/common/ico-arrow.svg\" alt=\"\">\n          </button>\n          \n            \n              \n                <ul>\n                  <li><a href=\"/news/\">ニュース一覧</a></li>\n              \n                  <li><a href=\"/news/press/\">プレスリリース</a></li>\n              \n            \n              \n                  <li><a href=\"/news/other/\">お知らせ</a></li>\n              \n            \n              \n                  <li><a href=\"/news/media/\">メディア</a></li>\n              \n            \n              \n                  \n              \n                </ul>\n              \n            \n          \n        </li>\n        <li>\n          <button data-toggle=\"accordion\">\n            <span>Sustainability</span>\n            <img src=\"/assets/img/common/ico-arrow.svg\" alt=\"\"></button>\n          <ul>\n            <li><a href=\"/sustainability/\">サスティナビリティについて</a></li>\n          </ul>\n        </li>\n        <li><a href=\"/contact/\">Contact</a></li>\n      </ul>\n      <div>\n        <p><a href=\"/\"><img src=\"/assets/img/common/logo.svg\" alt=\"Telecom Square\"></a></p>\n        \n        <ul>\n          <li><a class=\"isActive\" href=\"/\">JP</a></li>\n          <li><a href=\"/english/\">EN</a></li>\n        </ul>\n      </div>\n      <button data-toggle=\"menu\"><span>&times;</span></button>\n    </nav>\n    <main>\n\n      <div class=\"recruitHomeHeadingBlock\">\n        <div class=\"recruitHomeHeadingBlock__image\">\n          <picture>\n            <source srcset=\"/assets/img/recruit/kv_lg.jpg\" media=\"(min-width: 768px)\" width=\"1366\" height=\"683\"><img src=\"/assets/img/recruit/kv.jpg\" width=\"375\" height=\"320\" alt=\"\">\n          </picture>\n        </div>\n        <h1 data-scroll=\"heading\"><span class=\"en\"><span>R</span><span>e</span><span>c</span><span>r</span><span>u</span><span>i</span><span>t</span></span><span class=\"ja\"><span>採</span><span>用</span><span>情</span><span>報</span></span></h1>\n      </div>\n      <div class=\"recruitHomeMessage\" data-scroll=\"slide\">\n        <div class=\"recruitHomeMessage__image\">\n          <picture>\n            <source srcset=\"/assets/img/recruit/message_01_lg.jpg\" media=\"(min-width: 768px)\" width=\"234\" height=\"297\"><img src=\"/assets/img/recruit/message_01.jpg\" width=\"311\" height=\"175\" alt=\"\">\n          </picture>\n          <p>取締役CEO<br class=\"pc-hidden\">田村 正泰</p>\n        </div>\n        <div class=\"recruitHomeMessage__text\">\n          <p>株式会社テレコムスクエアに興味を持っていただきありがとうございます。<br>私たちはモバイル通信事業のパイオニアとして、長年多くの法人様の、そして一人一人のお客様の大切な海外渡航・旅行をサポートし信頼を獲得するとともに、通信以外の様々な事業にも挑戦を続けてきました。<br>その根幹にあるのは、常に変化を楽しみ、オーナーシップをもって、私たちだからこそ創造できる唯一無二の「新たな価値」を生み出す会社であり続けたいという思いです。</p>\n          <p>「新たな価値」を生み出すということは、簡単なことではありませんし、ましてや一人でできることではありません。<br>こうした思いに共感し集った仲間たち一人一人が、その大きな目標に向かって懸命に取り組んでこそ、生まれるものだと思います。</p>\n          <p>つまり私たちにとって人材とは「新たな価値の源泉」であるということです。</p>\n          <p>そして集った仲間たちの一人一人が、多様性を尊重し合い、自己実現できる、働くこと自体に喜びを感じる会社であり続けたいと考えています。<br>テレコムスクエアがどんな会社なのか、私たちの発信内容をお読みいただき、私たちの思いや取り組みに共感してくださる方がいらっしゃったらうれしいです。ともに挑戦してくれる新たな仲間を、心からお待ちしています。</p>\n        </div>\n      </div>\n      <div class=\"recruitHomeNav localNav\" data-scroll=\"slide\">\n        <ul>\n          <li><a href=\"#hiring\">募集職種<img src=\"/assets/img/common/ico-arrow.svg\" alt=\"\"></a></li>\n          <li><a href=\"#about\">事業内容<img src=\"/assets/img/common/ico-arrow.svg\" alt=\"\"></a></li>\n          <li><a href=\"#style\">働く環境<img src=\"/assets/img/common/ico-arrow.svg\" alt=\"\"></a></li>\n          <li><a href=\"#model\">キャリアモデル<img src=\"/assets/img/common/ico-arrow.svg\" alt=\"\"></a></li>\n          <li><a href=\"#interview\">インタビュー<img src=\"/assets/img/common/ico-arrow.svg\" alt=\"\"></a></li>\n          <li><a href=\"#community\">キャリアコミュニティ<img src=\"/assets/img/common/ico-arrow.svg\" alt=\"\"></a></li>\n        </ul>\n      </div>\n      <section class=\"recruitHomeSection -bg\" id=\"hiring\">\n        <h2 class=\"headingLv2WithSub\" data-scroll=\"heading\"><span class=\"en\"><span>N</span><span>o</span><span>w</span> <span>H</span><span>i</span><span>r</span><span>i</span><span>n</span><span>g</span></span><span class=\"ja\"><span>募</span><span>集</span><span>職</span><span>種</span></span></h2>\n        <ul class=\"recruitCards\">\n        <li class=\"-light\"><a class=\"card\" href=\"https://hrmos.co/pages/999214732621660161/jobs/0000165\" target=\"_blank\" rel=\"noopener\" data-scroll=\"slide\">\n              <p>営業職（営業経験者向け）</p>\n              <p>営業職（関西支店）を募集します。</p>\n              <p>\n                <object><a class=\"button\" href=\"https://hrmos.co/pages/999214732621660161/jobs/0000165\" target=\"_blank\"><span>詳しくみる</span><span><span class=\"button__ico\"></span></span></a>\n                </object>\n              </p></a></li>\n        <li class=\"-light\"><a class=\"card\" href=\"https://hrmos.co/pages/999214732621660161/jobs/0000164\" target=\"_blank\" rel=\"noopener\" data-scroll=\"slide\">\n              <p>営業職（未経験者歓迎）</p>\n              <p>営業職（関西支店）を募集します。</p>\n              <p>\n                <object><a class=\"button\" href=\"https://hrmos.co/pages/999214732621660161/jobs/0000164\" target=\"_blank\"><span>詳しくみる</span><span><span class=\"button__ico\"></span></span></a>\n                </object>\n              </p></a></li>\n        <li class=\"-light\"><a class=\"card\" href=\"https://hrmos.co/pages/999214732621660161/jobs/0000161\" target=\"_blank\" rel=\"noopener\" data-scroll=\"slide\">\n              <p>Webデザイナー</p>\n              <p>Webデザイナーを募集します。</p>\n              <p>\n                <object><a class=\"button\" href=\"https://hrmos.co/pages/999214732621660161/jobs/0000161\" target=\"_blank\"><span>詳しくみる</span><span><span class=\"button__ico\"></span></span></a>\n                </object>\n              </p></a></li>\n        <li class=\"-light\"><a class=\"card\" href=\"https://hrmos.co/pages/999214732621660161/jobs/0000134\" target=\"_blank\" rel=\"noopener\" data-scroll=\"slide\">\n              <p>成田空港接客スタッフ</p>\n              <p>成田空港カウンタースタッフを募集します。</p>\n              <p>\n                <object><a class=\"button\" href=\"https://hrmos.co/pages/999214732621660161/jobs/0000134\" target=\"_blank\"><span>詳しくみる</span><span><span class=\"button__ico\"></span></span></a>\n                </object>\n              </p></a></li>\n        </ul>\n        <!--<ul class=\"recruitCards\">\n          <li class=\"-light\"><div class=\"card\" target=\"_blank\" rel=\"noopener\" data-scroll=\"slide\">\n              <p>新卒採用</p>\n              <p>2027年新卒採用 カジュアル面談受付中</p>\n              <p>\n                <object><a class=\"button\" href=\"https://hrmos.co/pages/999214732621660161/jobs/0000157mendan\" target=\"_blank\"><span>詳しくみる</span><span><span class=\"button__ico\"></span></span></a>\n                </object>\n              </p></div></li>-->\n        </ul>\n      </section>\n      <section class=\"recruitHomeSection -about\" id=\"about\">\n        <h2 class=\"headingLv2WithSub\" data-scroll=\"heading\"><span class=\"en\"><span>A</span><span>b</span><span>o</span><span>u</span><span>t</span> <span>u</span><span>s</span></span><span class=\"ja\"><span>事</span><span>業</span><span>内</span><span>容</span></span></h2>\n        <p data-scroll=\"slide\">世界の旅人に<br class=\"pc-hidden\">&quot;新たな価値&quot;を</p>\n        <p data-scroll=\"slide\">インターネットが発達し、多量の情報をデバイスひとつで手に入れられることが容易となり、世界はさらにボーダレス化が進み、人々が国境を越えて旅に出る機会はますます増えるでしょう。そのように世界を旅する人々に、私たちはサービスを介して“新たな価値”を提供し続けていきたいと願っています。</p>\n        <section class=\"recruitHomeAboutCards\">\n          <div class=\"recruitHomeAboutCards__inner\">\n            <h3>数字で見るテレコムスクエア</h3>\n            <ul>\n              <li data-scroll=\"slide\">\n                <h4><span>従業員男女比</span></h4>\n                <div><img src=\"/assets/img/recruit/about_01.svg\"></div>\n                <p class=\"-min\"><span>男性</span><span class=\"-large\">45</span><span>%</span></p>\n                <p class=\"-min\"><span>女性</span><span class=\"-large\">55</span><span>%</span></p>\n              </li>\n              <li data-scroll=\"slide\">\n                <h4><span>平均年齢</span></h4>\n                <div><img src=\"/assets/img/recruit/about_02.svg\"></div>\n                <p><span class=\"-large\">38.3</span><span>歳</span></p>\n              </li>\n              <li data-scroll=\"slide\">\n                <h4><span>育休取得人数</span></h4>\n                <div><img src=\"/assets/img/recruit/about_03.svg\"></div>\n                <p class=\"-min\"><span>男性</span><span class=\"-large\">0</span><span>人</span></p>\n                <p class=\"-min\"><span>女性</span><span class=\"-large\">3</span><span>人</span></p>\n              </li>\n              <li data-scroll=\"slide\">\n                <h4><span>育休復帰率</span></h4>\n                <div><img src=\"/assets/img/recruit/about_04.svg\"></div>\n                <p><span class=\"-large\">100</span><span>%</span></p>\n              </li>\n              <li data-scroll=\"slide\">\n                <h4><span>平均有給取得日数</span></h4>\n                <div><img src=\"/assets/img/recruit/about_05.svg\"></div>\n                <p><span class=\"-large\">16.2</span><span>日</span></p>\n              </li>\n              <li data-scroll=\"slide\">\n                <h4><span>平均残業時間</span></h4>\n                <div><img src=\"/assets/img/recruit/about_06.svg\"></div>\n                <p><span class=\"-large\">9.5</span><span>時間</span></p>\n              </li>\n            </ul>\n            <p class=\"note\">※2024年実績</p>\n          </div>\n        </section>\n      </section>\n      <section class=\"recruitHomeSection -style\" id=\"style\">\n        <h2 class=\"headingLv2WithSub\" data-scroll=\"heading\"><span class=\"en\"><span>W</span><span>o</span><span>r</span><span>k</span> <span>S</span><span>t</span><span>y</span><span>l</span><span>e</span></span><span class=\"ja\"><span>働</span><span>く</span><span>環</span><span>境</span></span></h2>\n        <section data-scroll=\"slide\">\n          <h3>自律して働く人を支援する環境があります。</h3>\n          <ul>\n            <li>フレックスタイム制度</li>\n            <li>テレワーク制度（一部対象外部署あり）</li>\n            <li>両立支援（治療や介護・育児と仕事の両立を会社として支援）</li>\n          </ul>\n          <div class=\"image\">\n            <picture><img src=\"/assets/img/recruit/style_01.jpg\" width=\"408\" height=\"230\" alt=\"\"></picture>\n          </div>\n        </section>\n        <section data-scroll=\"slide\">\n          <h3>自ら学ぶ人を応援する制度があります。</h3>\n          <ul>\n            <li>資格取得支援制度</li>\n            <li>プロフェッショナルサポート制度</li>\n            <li>図書費購入支援制度</li>\n          </ul>\n          <div class=\"image\">\n            <picture><img src=\"/assets/img/recruit/style_02.jpg\" width=\"408\" height=\"230\" alt=\"\"></picture>\n          </div>\n        </section>\n        <section data-scroll=\"slide\">\n          <h3>研修体制</h3>\n          <ul>\n            <li>Future Search Project（新卒研修）</li>\n            <li>各種OJT</li>\n            <li>考課者被考課者研修</li>\n            <li>キャリアプラン支援</li>\n            <li>メンタルヘルス研修 等</li>\n          </ul>\n          <div class=\"image\">\n            <picture><img src=\"/assets/img/recruit/style_03.jpg\" width=\"408\" height=\"230\" alt=\"\"></picture>\n          </div>\n        </section>\n        <section data-scroll=\"slide\">\n          <h3>その他</h3>\n          <ul>\n            <li>クラブ活動</li>\n            <li>リフレッシュ休暇制度 等</li>\n          </ul>\n          <div class=\"image\">\n            <picture><img src=\"/assets/img/recruit/style_04.jpg\" width=\"408\" height=\"230\" alt=\"\"></picture>\n          </div>\n        </section>\n      </section>\n      <section class=\"recruitHomeSection -bg\" id=\"model\">\n        <h2 class=\"headingLv2WithSub\" data-scroll=\"heading\"><span class=\"en\"><span>C</span><span>a</span><span>r</span><span>e</span><span>e</span><span>r</span> <span>M</span><span>o</span><span>d</span><span>e</span><span>l</span></span><span class=\"ja\"><span>キ</span><span>ャ</span><span>リ</span><span>ア</span><span>モ</span><span>デ</span><span>ル</span></span></h2>\n        <div class=\"recruitHomeModel\" data-scroll=\"slide\">\n          <div class=\"recruitHomeModel__image\">\n            <picture>\n              <source srcset=\"/assets/img/recruit/model_01_lg.jpg\" media=\"(min-width: 768px)\" width=\"1127\" height=\"360\"><img src=\"/assets/img/recruit/model_01.jpg\" width=\"375\" height=\"136\" alt=\"\">\n            </picture>\n          </div>\n          <div class=\"recruitHomeModel__text\">\n            <p>自分のキャリアは自分で作る</p>\n            <p>当社では個々の適正や希望も踏まえてキャリアプランを選択できます。</p>\n            <p><a class=\"button\" href=\"/recruit/careerplan/\"><span>詳しくみる</span><span><span class=\"button__ico\"></span></span></a>\n            </p>\n          </div>\n        </div>\n      </section>\n      <section class=\"recruitHomeSection -interview\" id=\"interview\">\n        <h2 class=\"headingLv2WithSub\" data-scroll=\"heading\"><span class=\"en\"><span>I</span><span>n</span><span>t</span><span>e</span><span>r</span><span>v</span><span>i</span><span>e</span><span>w</span></span><span class=\"ja\"><span>イ</span><span>ン</span><span>タ</span><span>ビ</span><span>ュ</span><span>ー</span></span></h2>\n        <p data-scroll=\"slide\">テレコムスクエアで働く人を紹介します。<br>仕事内容ややりがいなど、テレコムスクエアで働く魅力を語っていただきました。</p>\n        <section class=\"recruitHomeInterview\">\n          <h3>キャリア採用インタビュー</h3>\n          <ul>\n            <li data-scroll=\"slide\"><a class=\"recruitHomeInterview__card\" href=\"/recruit/staff01/\">\n                <div class=\"recruitHomeInterview__image\">\n                  <picture><img src=\"/assets/img/recruit/staff01/thumb.jpg\" width=\"336\" height=\"189\" alt=\"\"></picture>\n                  <p>空港</p>\n                </div>\n                <div class=\"recruitHomeInterview__text\">\n                  <p>お客様の笑顔と満足が原動力。現場主義のプレイングマネージャー</p>\n                  <ul>\n                    <li>2018年入社</li>\n                    <li>前職:通信会社エリアマネージャー</li>\n                  </ul>\n                  <p>Y.R</p>\n                </div></a></li>\n            <li data-scroll=\"slide\"><a class=\"recruitHomeInterview__card\" href=\"/recruit/staff02/\">\n                <div class=\"recruitHomeInterview__image\">\n                  <picture><img src=\"/assets/img/recruit/staff02/thumb.jpg\" width=\"336\" height=\"189\" alt=\"\"></picture>\n                  <p>クリエイティブ</p>\n                </div>\n                <div class=\"recruitHomeInterview__text\">\n                  <p>デザインの本質は課題解決。自社ブランドの成長を担う事業会社デザイナーへの挑戦</p>\n                  <ul>\n                    <li>2024年入社</li>\n                    <li>前職:デザイン制作会社グラフィックデザイナー</li>\n                  </ul>\n                  <p>U.N</p>\n                </div></a></li>\n            <li data-scroll=\"slide\" style=\"display:none\">\n              <div class=\"recruitHomeInterview__card -commingsoon\">\n                <div class=\"recruitHomeInterview__image\">\n                  <picture><img src=\"/assets/img/recruit/thumb_comming.png\" width=\"336\" height=\"189\" alt=\"\"></picture>\n                  <p style=\"display:none;\">マーケティング</p>\n                </div>\n              </div>\n            </li>\n          </ul>\n        </section>\n        <section class=\"recruitHomeInterview\">\n          <h3>新卒採用インタビュー</h3>\n          <ul>\n            <li data-scroll=\"slide\"><a class=\"recruitHomeInterview__card\" href=\"/recruit/staff03/\">\n                <div class=\"recruitHomeInterview__image\">\n                  <picture><img src=\"/assets/img/recruit/staff03/thumb.jpg\" width=\"336\" height=\"189\" alt=\"\"></picture>\n                  <p>マーケティング</p>\n                </div>\n                <div class=\"recruitHomeInterview__text\">\n                  <p>憧れの空港。その先にあった未来の可能性</p>\n                  <ul>\n                    <li>2018年入社</li>\n                  </ul>\n                  <p>M.I</p>\n                </div></a></li>\n             <li data-scroll=\"slide\"><a class=\"recruitHomeInterview__card\" href=\"/recruit/staff04/\">\n                <div class=\"recruitHomeInterview__image\">\n                  <picture><img src=\"/assets/img/recruit/staff04/thumb.jpg\" width=\"336\" height=\"189\" alt=\"\"></picture>\n                  <p>通信営業</p>\n                </div>\n                <div class=\"recruitHomeInterview__text\">\n                  <p>営業一筋！多くのステークホルダーとの関わりが私の成長と誇りとなる</p>\n                  <ul>\n                    <li>2017年入社</li>\n                  </ul>\n                  <p>Y.U</p>\n                </div></a></li>\n             <li data-scroll=\"slide\"><a class=\"recruitHomeInterview__card\" href=\"/recruit/staff05/\">\n                <div class=\"recruitHomeInterview__image\">\n                  <picture><img src=\"/assets/img/recruit/staff05/thumb.jpg\" width=\"336\" height=\"189\" alt=\"\"></picture>\n                  <p>通信営業</p>\n                </div>\n                <div class=\"recruitHomeInterview__text\">\n                  <p>ボストンで出会ったテレコムスクエア。私の目指す舞台は世界</p>\n                  <ul>\n                    <li>2019年入社</li>\n                  </ul>\n                  <p>E.M</p>\n                </div></a></li>\n          </ul>\n        </section>\n        <section class=\"recruitHomeInterview\">\n          <h3>企画インタビュー</h3>\n          <ul>\n            <li data-scroll=\"slide\"><a class=\"recruitHomeInterview__card\" href=\"/recruit/club_activities/\">\n                <div class=\"recruitHomeInterview__image\">\n                  <picture><img src=\"/assets/img/recruit/club_activities/thumb.jpg\" width=\"336\" height=\"189\" alt=\"\"></picture>\n                  <p>クラブ活動</p>\n                </div>\n                <div class=\"recruitHomeInterview__text\">\n                  <p>クラブ活動インタビュー。突如現れた謎のクラブ活動『おさんぽ部』とは！？</p>\n                </div></a></li>\n            <li data-scroll=\"slide\"><a class=\"recruitHomeInterview__card\" href=\"/recruit/discussion/\">\n                <div class=\"recruitHomeInterview__image\">\n                  <picture><img src=\"/assets/img/recruit/discussion/thumb.jpg\" width=\"336\" height=\"189\" alt=\"\"></picture>\n                  <p>社員座談会</p>\n                </div>\n                <div class=\"recruitHomeInterview__text\">\n                  <p>テレコムスクエアにおける営業とは！？通信営業部の皆さんにお話をうかがいました。少しくだけたトークで社内のリアルをお届けします！</p>\n                </div></a></li>\n            <li data-scroll=\"slide\"><a class=\"recruitHomeInterview__card\" href=\"/recruit/staff07/\">\n                <div class=\"recruitHomeInterview__image\">\n                  <picture><img src=\"/assets/img/recruit/staff07/thumb.jpg\" width=\"336\" height=\"189\" alt=\"\"></picture>\n                  <p>採用担当（人事部執行役員）</p>\n                </div>\n                <div class=\"recruitHomeInterview__text\">\n                  <p>テレコムスクエアではどのような人材を求めているのか？採用を司る人事部の執行役員にお話をうかがいました。</p>\n                  <ul>\n                    <li>2006年入社</li>\n                  </ul>\n                  <p>A.K</p>\n                </div></a></li>\n            <li data-scroll=\"slide\" style=\"display:none;\">\n              <div class=\"recruitHomeInterview__card -commingsoon\">\n                <div class=\"recruitHomeInterview__image\">\n                  <picture><img src=\"/assets/img/recruit/thumb_comming.png\" width=\"336\" height=\"189\" alt=\"\"></picture>\n                  <p>人事部</p>\n                </div>\n              </div>\n            </li>\n          </ul>\n        </section>\n      </section>\n      <section class=\"recruitHomeSection -community\" id=\"community\">\n        <h2 class=\"headingLv2WithSub\" data-scroll=\"heading\"><span class=\"en\"><span>C</span><span>a</span><span>r</span><span>e</span><span>e</span><span>r</span> <span>C</span><span>o</span><span>m</span><span>m</span><span>u</span><span>n</span><span>i</span><span>t</span><span>y</span></span><span class=\"ja\"><span>キ</span><span>ャ</span><span>リ</span><span>ア</span><span>コ</span><span>ミ</span><span>ュ</span><span>ニ</span><span>テ</span><span>ィ</span></span></h2>\n        <div class=\"recruitHomeCommunity\" data-scroll=\"slide\">\n          <p>テレコムスクエアにご興味をお持ちの方で、現時点で希望する職種の募集がない場合や、今すぐではなく今後働いてみたい場合などは是非キャリアコミュニティへご参加ください。<br>今後のイベントや求人情報の通知などを受け取ることができます。</p>\n          <div>\n            <picture><img src=\"/assets/img/recruit/community_01.jpg\" width=\"638\" height=\"359\" alt=\"\"></picture>\n          </div>\n          <p><a class=\"button\" href=\"https://hrmos.co/pages/999214732621660161/jobs/0000126careercommunity\" target=\"_blank\"><span>詳しくみる</span><span><span class=\"button__ico\"></span></span></a>\n          </p>\n        </div>\n      </section>\n      <!--<div class=\"recruitHomeBottomNav\"><a href=\"https://job.mynavi.jp/25/pc/corpinfo/displaySeminarList/index?corpId=242817\" target=\"_blank\" rel=\"noopener\">2025年 新卒採用</a></div>-->\n\n<!--<!--<div class=\"recruitLocalNav\">\n  <ul class=\"recruitCards\">\n    <li class=\"-light\">\n      <div class=\"card\" target=\"_blank\" rel=\"noopener\" data-scroll=\"slide\">\n        <p>新卒採用</p>\n        <p>2026年卒採用のエントリーを開始しました。</p>\n        <p>\n        <object><a class=\"button\" href=\"https://job.mynavi.jp/26/pc/search/corp242817/outline.html\" target=\"_blank\"><span>エントリーする</span><span><span class=\"button__ico\"></span></span></a>\n          </object>\n        </p>\n      </div>\n    </li>\n  </ul>\n</div>-->-->\n<a class=\"contact\" href=\"/contact/\" data-scroll=\"slide\">\n  <div>\n    <p>Contact</p>\n    <p>お問い合わせ</p>\n    <span>\n      <picture>\n        <source media=\"(min-width: 768px)\" srcset=\"/assets/img/common/ico-button.svg\"><img src=\"/assets/img/common/ico-button-white.svg\" alt=\"\">\n      </picture>\n    </span>\n  </div>\n  <p>各種サービスに関するご意見・ご質問など、こちらからお願いいたします。</p>\n</a>\n<div class=\"breadcrumb\">\n  <ul>\n    <li><a href=\"/\">Top</a></li>\n    \n    \n    \n    <li><span>採用情報</span></li>\n  </ul>\n</div>\n<a class=\"prevTop\" href=\"#\"><img src=\"/assets/img/common/ico-button.svg\" alt=\"\"></a>\