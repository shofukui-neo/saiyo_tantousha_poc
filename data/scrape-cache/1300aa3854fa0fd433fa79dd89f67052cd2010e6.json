{"url":"https://www.ic-group.co.jp/recruitment/interview/p461/","html":"<!DOCTYPE html>\n<!--[if lt IE 7]><html class=\"no-js lt-ie9 lt-ie8 lt-ie7\" lang=\"ja\"><![endif]-->\n<!--[if IE 7]><html class=\"no-js lt-ie9 lt-ie8\" lang=\"ja\"><![endif]-->\n<!--[if IE 8]><html class=\"no-js lt-ie9\" lang=\"ja\"><![endif]-->\n<!--[if gt IE 8]><!-->\n<html class=\"no-js\" lang=\"ja\"><!--<![endif]-->\n\n<head>\n        <!-- Google Tag Manager -->\r\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\r\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\r\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\r\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\r\n})(window,document,'script','dataLayer','GTM-MDCL22');</script>\r\n<!-- End Google Tag Manager -->    <meta charset=\"UTF-8\">\n  <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n  <script>\n    if (navigator.userAgent.match(/(iPhone|Android.*Mobile)/)) {\n      document.write('<meta name=\"viewport\" content=\"width=device-width,initial-scale=1.0\">');\n    } else {\n      document.write('<meta name=\"viewport\" content=\"width=1400,maximum-scale=2.0,user-scalable=1\">');\n    };\n  </script>\n  <meta name=\"format-detection\" content=\"telephone=no\">\n  <title>施工管理｜先輩インタビュー｜岐阜県｜市川工務店</title>\n  \n<!-- This site is optimized with the Yoast SEO plugin v12.7.1 - https://yoast.com/wordpress/plugins/seo/ -->\n<meta name=\"robots\" content=\"max-snippet:-1, max-image-preview:large, max-video-preview:-1\"/>\n<link rel=\"canonical\" href=\"https://www.ic-group.co.jp/recruitment/interview/p461/\" />\n<meta property=\"og:locale\" content=\"ja_JP\" />\n<meta property=\"og:type\" content=\"article\" />\n<meta property=\"og:title\" content=\"施工管理｜先輩インタビュー｜岐阜県｜市川工務店\" />\n<meta property=\"og:url\" content=\"https://www.ic-group.co.jp/recruitment/interview/p461/\" />\n<meta property=\"og:site_name\" content=\"市川工務店 採用サイト\" />\n<meta property=\"og:image\" content=\"https://www.ic-group.co.jp/recruitment/wp/wp-content/uploads/2019/12/ogp.png\" />\n<meta property=\"og:image:secure_url\" content=\"https://www.ic-group.co.jp/recruitment/wp/wp-content/uploads/2019/12/ogp.png\" />\n<meta property=\"og:image:width\" content=\"1200\" />\n<meta property=\"og:image:height\" content=\"630\" />\n<meta name=\"twitter:card\" content=\"summary_large_image\" />\n<meta name=\"twitter:title\" content=\"施工管理｜先輩インタビュー｜岐阜県｜市川工務店\" />\n<script type='application/ld+json' class='yoast-schema-graph yoast-schema-graph--main'>{\"@context\":\"https://schema.org\",\"@graph\":[{\"@type\":\"WebSite\",\"@id\":\"https://www.ic-group.co.jp/recruitment/#website\",\"url\":\"https://www.ic-group.co.jp/recruitment/\",\"name\":\"\\u5e02\\u5ddd\\u5de5\\u52d9\\u5e97 \\u63a1\\u7528\\u30b5\\u30a4\\u30c8\",\"description\":\"Just another WordPress site\",\"potentialAction\":{\"@type\":\"SearchAction\",\"target\":\"https://www.ic-group.co.jp/recruitment/?s={search_term_string}\",\"query-input\":\"required name=search_term_string\"}},{\"@type\":\"WebPage\",\"@id\":\"https://www.ic-group.co.jp/recruitment/interview/p461/#webpage\",\"url\":\"https://www.ic-group.co.jp/recruitment/interview/p461/\",\"inLanguage\":\"ja\",\"name\":\"\\u65bd\\u5de5\\u7ba1\\u7406\\uff5c\\u5148\\u8f29\\u30a4\\u30f3\\u30bf\\u30d3\\u30e5\\u30fc\\uff5c\\u5c90\\u961c\\u770c\\uff5c\\u5e02\\u5ddd\\u5de5\\u52d9\\u5e97\",\"isPartOf\":{\"@id\":\"https://www.ic-group.co.jp/recruitment/#website\"},\"datePublished\":\"2022-04-25T10:14:24+00:00\",\"dateModified\":\"2024-10-18T01:44:01+00:00\",\"breadcrumb\":{\"@id\":\"https://www.ic-group.co.jp/recruitment/interview/p461/#breadcrumb\"}},{\"@type\":\"BreadcrumbList\",\"@id\":\"https://www.ic-group.co.jp/recruitment/interview/p461/#breadcrumb\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"item\":{\"@type\":\"WebPage\",\"@id\":\"https://www.ic-group.co.jp/recruitment/\",\"url\":\"https://www.ic-group.co.jp/recrui