javascript'; fjs.async = true; fjs.id = \"fjssync\"; var timestamp = new Date;fjs.src = ('https:' == document.location.protocol ? 'https' : 'http') + '://hm.mieru-ca.com/service/js/mieruca-hm.js?v='+ timestamp.getTime(); var x = document.getElementsByTagName('script')[0]; x.parentNode.insertBefore(fjs, x); };\nsetTimeout(mieruca, 500); document.readyState != \"complete\" ? (window.attachEvent ? window.attachEvent(\"onload\", mieruca) : window.addEventListener(\"load\", mieruca, false)) : mieruca();\n})();\n</script>\n<!-- End Mieruca Embed Code -->\n</head>\r\n\r\n<body id=\"PageFlow\">\r\n<!-- skip_nav -->\r\n<div id=\"page_top\">\r\n  <p class=\"skip\">ページの先頭です。</p>\r\n  <p class=\"skip\"><a href=\"#skip_menu\">メインメニューへ移動します。</a></p>\r\n  <p class=\"skip\"><a href=\"#skip_honbun\">本文へ移動します。</a></p>\r\n  <p class=\"skip\"><a href=\"#skip_footer\">フッターへ移動します。</a></p>\r\n</div>\r\n<!-- /skip_nav --> \r\n\r\n<!-- // Header START // -->\r\n<header>\r\n<div id=\"HeadSubMenu\">\r\n<ul class=\"clearfix\">\r\n  <li><a href=\"/inquiry/\">お問い合わせ</a></li>\r\n  <li><a href=\"/profile/office.html\">アクセス</a></li>\r\n  <li><a href=\"/\">ウインコーポレートサイト</a></li>\r\n</ul>\r\n</div><!-- /#HeadSubMenu -->\r\n\r\n<p id=\"skip_menu\" class=\"skip\">メインメニューです。</p>\r\n<div id=\"HeadEntryMenu\" class=\"clearfix\">\r\n  <div class=\"innerBlock\">\r\n    <p><a href=\"/recruit/\"><img src=\"/recruit/common/images/logo.png\" width=\"388\" height=\"34\" alt=\"株式会社ウイン 採用情報\"/></a></p>\r\n    <ul class=\"clearfix button\">\r\n      <li><a href=\"/recruit/entry/#section01\">新卒採用</a></li>\r\n      <li><a href=\"/recruit/entry/#section02\">キャリア採用</a></li>\r\n    </ul>\r\n  </div>\r\n</div><!-- /#HeadEntryMenu --><div id=\"HeadGlobalMenu\">\r\n  <ul class=\"clearfix button\">\r\n    <li><a href=\"/recruit/vision/\">ビジョン</a></li>\r\n    <li><a href=\"/recruit/seek/\">求める人材</a></li>\r\n    <li><a href=\"/profile/approach.html\">ウインの取組み</a></li>\r\n    <li><a href=\"/recruit/department/\">部署紹介</a></li>\r\n    <li><a href=\"/recruit/jobcategory/\">募集職種</a></li>\r\n    <li><a href=\"/recruit/flow/\">採用の流れ</a></li>\r\n  </ul>\r\n</div><!-- /#HeadGlobalMenu --></header>\r\n<!-- // Header END // -->\r\n\r\n\r\n<!-- // Contents START // -->\r\n\r\n<!-- topicPath -->\r\n<div id=\"topicPath\">\r\n  <ul class=\"clearfix\">\r\n    <li><a href=\"#section01\">エントリー</a></li>\r\n    <li><a href=\"#section02\">書類選考</a></li>\r\n    <li><a href=\"#section03\">一次面接</a></li>\r\n    <li><a href=\"#section04\">二次面接</a></li>\r\n    <li><a href=\"#section05\">採用</a></li>\r\n  </ul>\r\n</div>\r\n<!-- /topicPath -->\r\n\r\n<p id=\"skip_honbun\" class=\"skip\">本文です。</p>\r\n\r\n<h1>採用の流れ<span>Adoption of flow</span></h1>\r\n\r\n\r\n<section id=\"section01\">\r\n  <h2><img src=\"images/ttl01.png\" width=\"106\" height=\"105\" alt=\"エントリー\"/></h2>\r\n  <div>\r\n  <p>エントリーフォームより、ご応募ください。</p>\r\n  </div>\r\n</section>\r\n\r\n\r\n<section id=\"section02\">\r\n  <h2><img src=\"images/ttl02.png\" width=\"106\" height=\"105\" alt=\"書類選考\"/></h2>\r\n  <div>\r\n  <p>履歴書や実績を元に、最初の選考を行います。<br>\r\n    エントリー時に、履歴書や職務経歴書等の書類をご提出いただいていない方には、別途ご提出のお願いのご連絡をいたします。<br>\r\n    選考には１週間程度の選考期間をいただいた後、合否をご連絡いたします。<br>\r\n    通過された方には、一次面接の日時をご連絡させていただきます。</p>\r\n  </div>\r\n\t<p class=\"progress\">1週間程度</p>\r\n</section>\r\n\r\n\r\n<section id=\"section03\">\r\n<h2><img src=\"images/ttl03.png\" width=\"106\" height=\"105\" alt=\"一次面接\"/></h2>\r\n<div>\r\n<p>当社にて採用担当者との面接を行います。<br>\r\n  これまでの職歴や志望動機など、基本的なことをお伺いします。当社へのご質問にもすべてお答えします。<br>\r\n  一次面接後、1週間程度の選考期間を経て合否を連絡いたします。<br>\r\n  通過された方には、二次面接の日時をご連絡させていただきます。</p>\r\n</div>\r\n<p class=\"progress\">1週間程度</p>\r\n</section>\r\n\r\n\r\n<section id=\"section04\">\r\n<h2><img src=\"images/ttl04.png\" width=\"106\" height=\"105\" alt=\"二次面接\"/></h2>\r\n<div class=\"innerBlock\">\r\n  <p>当社にて採用担当者と部署担当者との面接を行います。<br>\r\n    実際の仕事を想定した内容をご説明するとともに、就業条件などを確認し、双方で最終的な意思決定を行います。二次面接後、1週間程度の選考期間を経て合否を連絡いたします。</p>\r\n</div>\r\n<p class=\"progress\">1週間程度</p>\r\n</section>\r\n\r\n\r\n<section id=\"section05\" class=\"bgno\">\r\n<h2><img src=\"images/ttl05.png\" width=\"106\" height=\"105\" alt=\"採用\"/></h2>\r\n<div class=\"innerBlock\">\r\n  <p>採用決定後、ご入社の承諾をいただきましたら、正式な採用通知書や入社手続き書類一式を郵送させていただきます。<br>\r\n    入社時期については、ご相談の上、決定いたします。</p>\r\n</div>\r\n</section>\r\n\r\n<div class=\"caution\">\r\n<p>※応募される方の特性に合わせて、選考プロセス・内容は変更になる場合があります。</p>\r\n※面接日、入社日等はご相談に応じます。</p>\r\n</div>\r\n\r\n<!-- // Contents END // -->\r\n\r\n\r\n<!-- // Footer START // -->\r\n<footer>\r\n<div id=\"FooterNavi\" class=\"button\">\r\n<ul class=\"col2 clearfix\">\r\n  <li><a href=\"/recruit/entry/#section01\">新卒採用</a></li>\r\n  <li><a href=\"/recruit/entry/#section02\">キャリア採用</a></li>\r\n</ul>\r\n<ul class=\"col3 clearfix\">\r\n  <li><a href=\"/recruit/department/\">部署紹介</a></li>\r\n  <li><a href=\"/recruit/jobcategory/\">募集職種</a></li>\r\n  <li><a href=\"/recruit/flow/\">採用の流れ</a></li>\r\n</ul>\r\n</div><!-- /#FooterNavi -->\r\n<div id=\"gotop\"><a href=\"#page_top\"><img class=\"imgover\" src=\"/recruit/common/images/btn_pagetop.png\" width=\"70\" height=\"70\" alt=\"このページの一番上へ\" /></a></div> \r\n<p id=\"skip_footer\" class=\"skip\">フッターです。</p>\r\n</footer>\r\n<!-- // Footer END // -->\r\n\r\n\r\n</body>\r\n</html>\r\n","finalUrl":"https://www.pro-win.co.jp/recruit/flow/","rendered":false,"_cachedAt":"2026-06-22T16:48:11.548Z"}