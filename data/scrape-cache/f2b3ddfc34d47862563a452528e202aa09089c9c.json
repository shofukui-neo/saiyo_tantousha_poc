{"url":"https://www.yokosyoku.co.jp/recruit/","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n<head>\n<!-- Google tag (gtag.js) -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-BE1WHWMFBG\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'G-BE1WHWMFBG');\n</script>\n<meta charset=\"utf-8\">\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>【正社員】求人情報｜株式会社横浜食品サービス</title>\n<meta name=\"Description\" content=\"株式会社横浜食品サービスは味・鮮度と安心・安全にこだわった生産地・加工者・水揚地よりお客様のニーズに対応した生鮮食品を供給しています。\" />\n<meta name=\"format-detection\" content=\"telephone=no\">\n<link rel=\"shortcut icon\" href=\"../images/favicon.ico\" >\n<link href=\"../css/bootstrap.min.css\" rel=\"stylesheet\" type=\"text/css\">\n<link href=\"../css/common.css\" rel=\"stylesheet\" type=\"text/css\">\n<link href=\"../css/style.css\" rel=\"stylesheet\" type=\"text/css\">\n<link rel=\"stylesheet\" href=\"https://maxcdn.bootstrapcdn.com/font-awesome/4.3.0/css/font-awesome.min.css\">\n<link rel=\"canonical\" href=\"https://www.yokosyoku.co.jp/recruit/\">\n\n<!--[if lt IE 9]>\n<script src=\"http://css3-mediaqueries-js.googlecode.com/svn/trunk/css3-mediaqueries.js\"></script>\n<script src=\"http://html5shiv.googlecode.com/svn/trunk/html5.js\"></script>\n<link href=\"css/ie.css\" rel=\"stylesheet\" type=\"text/css\">\n<![endif]-->\n</head>\n<body>\n\n\n<!-- ========== header =====================-->\n<header id=\"pt\">\n  <div class=\"logo\">\n    <img src=\"../images/logo.png\" alt=\"\" />\n      <h1><a href=\"../\" class=\"transition\">\n        株式会社横浜食品サービス<br>\n      <span>YOKOHAMA FOOD SERVICE Co.,Ltd.</span></a></h1>\n    <div class=\"pc-on\"><p class=\"text22\"><a href=\"../company/access.html\"><i class=\"fa fa-map-marker\" aria-hidden=\"true\"></i> アクセス</a></p></div>\n  </div>\n</header>\n<!-- =======