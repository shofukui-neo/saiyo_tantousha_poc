           </tr>-->\n              <tr>\n                <th scope=\"row\">職種</th>\n                <td>営業・事務・センター部門</td>\n              </tr>\n              <tr>\n                <th scope=\"row\">仕事内容</th>\n                <td><ul class=\"li-style1\">\n                  <li><strong>営業部門</strong><br>\n                    営業ノルマはなく、大手量販店への商品提案・価格交渉など</li>\n                  </ul>  \n                  <ul class=\"li-style1\">\n                  <li><strong>事務部門</strong><br>\n                    一般的な事務の他、商品の発注及び仕入れ管理など</li>\n                  <li><strong>センター部門</strong><br>\n                    原料準備、生産及び製品から物流手配などの一連の生産管理業務</li>\n                  <li><strong>システム部門</strong><br>\n                    社内の基幹システム及びセキュリティ管理など</li>\n                </ul>\n                <p>※配属先については入社時に決定します。</p>\n                </td>\n              </tr>\n              <tr>\n                <th scope=\"row\">勤務地</th>\n                <td>横浜市金沢区鳥浜町1-1</td>\n              </tr>\n              <tr>\n                <th scope=\"row\">勤務時間</th>\n                <td>9：00～18：00　（所定労働時間　8時間）他</td>\n              </tr>\n              <tr>\n                <th scope=\"row\">給与</th>\n                <td>月給（基本給）<br>\n                大　卒：　225,500円<br>\n                専門卒：　212,500円<br>\n                高　卒：　208,250円</td>\n              </tr>\n              <tr>\n                <th scope=\"row\">諸手当</th>\n                <td>通勤手当・家族手当・役職手当・時間外手当・家賃補助手当</td>\n              </tr>\n              <tr>\n                <th scope=\"row\">休日</th>\n                <td>一ヶ月単位の変形労働時間制　（年間休日110日）</td>\n              </tr>\n              <tr>\n                <th scope=\"row\">有給休暇</th>\n                <td>入社時に10日付与（年間10日~20日）</td>\n              </tr>\n              <tr>\n                <th scope=\"row\">待遇</th>\n                <td>賞与　年2回（7月・12月）<br>昇給　年1回（4月）</td>\n              </tr>\n              <tr>\n                <th scope=\"row\">社会保険</th>\n                <td>健康保険、厚生年金、雇用保険、労災保険</td>\n              </tr>\n              <tr>\n                <th scope=\"row\">福利厚生</th>\n                <td><ul class=\"li-style1\">\n                  <li>退職金制度あり（定年65歳）</li>\n                  <li>会社運営の飲食販売店の飲食代・物販購入代の補助</li>\n                  <li>子の看護休暇・介護休暇による有給あり（1人につき5日最大10日を有給とする）</li>\n                </ul></td>\n              </tr>\n              <!--<tr>\n                <th scope=\"row\">2024年<br>説明会スケジュール</th>\n                <td>2024年5月10日（金）10：00～<br>\n\t\t\t\t\t2024年6月7日（金）10：00～<br>\n\t\t\t\t\t2024年7月5日（金）10：00～<br>\n\t\t\t\t\tオンライン希望（遠方のかた）<br>\n                <p>※説明会への応募は<a href=\"http://www.yokosyoku.co.jp/contact2/\">【 専用フォーム 】</a>よりお願い致します。</p></td>\n              </tr>-->\n              <tr>\n                <th scope=\"row\">応募方法</th>\n                <td>現在募集は行なっておりません。<!--当社<a href=\"lp/\" target=\"_blank\">【 採用サイト 】</a>よりご応募ください-->\n                <!--電話又は<a href=\"http://www.yokosyoku.co.jp/contact1/\">フォーム</a>よりご応募ください<br>TEL : 045-779-2539<br>採用担当まで--></td>\n              </tr>\n              <!--<tr>\n                <th scope=\"row\">エントリー<br>随時受付中</th>\n                <td>応募は<a href=\"http://www.yokosyoku.co.jp/contact2/\">【専用フォーム】</a>よりお願い致します。</td>\n              </tr>-->\n            </table>\n          </div>\n\n      </div><!-- /col-sm-9-->\n    </div><!-- /row-->\n  </div><!-- /container-->\n<!-- ========== / contents ==================-->\n\n<p class=\"pagetop\"><a href=\"#pt\"><img src=\"../images/pagetop.png\" alt=\"PAGE TOP\" /></a></p>\n<!--=====================================================\nSP footerBtn Start\n===================================================-->\n<div class=\"fixed-btn\">\n  <p class=\"fixed-btn-entry\"><a href=\"/company/access.html\">アクセス</a></p>\n  <p class=\"fixed-btn-entry\"><a href=\"/contact/\">お問い合わせ</a></p>\n</div>\n<style>\n.fixed-btn {\n  display: none;\n}\n@media screen and (max-width: 767px){\n  .fixed-btn {\n    position: fixed;\n    bottom: 0;\n    left: 0;\n    width: 100%;\n    z-index: 100;\n  