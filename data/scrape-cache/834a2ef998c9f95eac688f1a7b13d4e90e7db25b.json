ttps://www.googletagmanager.com/ns.html?id=GTM-M38PPC\" height=\"0\" width=\"0\" style=\"display: none; visibility: hidden\"></iframe></noscript>\n    <!-- End Google Tag Manager (noscript) -->\n\n\n    <!-- ローディング画面 -->\n    <!-- <div class=\"js_loading\">\n    <div class=\"loader\"></div>\n  </div> -->\n\n    <!-- header -->\n    <header class=\"header l_wrap\">\n      <div class=\"header_wrap l_wrap_inr l_flex l_justifyContentBetween l_alignItemsCenter\">\n        <div class=\"header_logo l_flex l_gap_35 l_alignItemsCenter g_c_pnk\">\n          <div class=\"header_logo_wrap\">\n            <img src=\"./img/logo.svg\" alt=\"イオンリテール株式会社\">\n          </div>\n          <h1 class=\"header_ttl u_fz14 u_bold u_pc\">採用サイト</h1>\n        </div>\n        <div class=\"header_btn\">\n          <div class=\"g_btn g_entry_btn\">\n            <a href=\"https://aeonretail-career.snar.jp/entry.aspx?entryid=f3aa2035-eeda-48c1-82c7-28c0d543d238\" target=\"_blank\">entry</a>\n          </div>\n        </div>\n      </div>\n    </header>\n    <!-- /header -->\n\n    <!-- contents -->\n    <main class=\"l_wrapper\">\n      <div class=\"welcomeback_bg\">\n        <div class=\"welcomeback_bg_circle welcomeback_bg_circle01 u_img_def\">\n          <img src=\"/saiyo/welcomeback/img/circle01.png\" alt=\"\">\n        </div>\n        <div class=\"welcomeback_bg_circle welcomeback_bg_circle02 u_img_def u_pc\">\n          <img src=\"/saiyo/welcomeback/img/circle02.png\" alt=\"\">\n        </div>\n        <div class=\"welcomeback_bg_circle welcomeback_bg_circle03 u_img_def u_pc\">\n          <img src=\"/saiyo/welcomeback/img/circle03.png\" alt=\"\">\n        </div>\n        <div class=\"welcomeback_bg_circle welcomeback_bg_circle04 u_img_def u_pc\">\n          <img src=\"/saiyo/welcomeback/img/circle04.png\" alt=\"\">\n        </div>\n        <div class=\"welcomeback_bg_circle welcomeback_bg_circle05 u_img_def u_pc\">\n          <img src=\"/saiyo/welcomeback/img/circle05.png\" alt=\"\">\n        </div>\n        <div class=\"mv_sec\">\n          <div class=\"mv_inr l_wrap_inr\">\n            <h2 class=\"mv_ttl\">\n              <span class=\"\">再入社採用</span>\n              ウェルカムバック<br class=\"u_tbl u_sp\">制度\n            </h2>\n          </div>\n          <div class=\"mv_img_wrap\">\n            <div class=\"mv_img01 u_img_def\">\n              <img src=\"/saiyo/welcomeback/img/welcomeback_mv01.png\" alt=\"\">\n            </div>\n            <div class=\"mv_img02 u_img_def\">\n              <img src=\"/saiyo/welcomeback/img/welcomeback_mv02.png\" alt=\"\">\n            </div>\n            <div class=\"mv_img03 u_img_def\">\n              <img src=\"/saiyo/welcomeback/img/welcomeback_mv03.png\" alt=\"\">\n            </div>\n            <div class=\"mv_img04 u_img_def\">\n              <img src=\"/saiyo/welcomeback/img/welcomeback_mv04.png\" alt=\"\">\n            </div>\n            <div class=\"mv_img05 u_img_def\">\n              <img src=\"/saiyo/welcomeback/img/welcomeback_mv05.png\" alt=\"\">\n            </div>\n            <div class=\"mv_img06 u_img_def\">\n              <img src=\"/saiyo/welcomeback/img/welcomeback_mv06.png\" alt=\"\">\n            </div>\n          </div>\n        </div>\n        <section class=\"welcomeback_sec l_wrap g_sec__last\">\n          <div class=\"welcomeback_cnt l_wrap_inr\">\n            <div class=\"welcomeback_cnt_inr\">\n              <h3 class=\"welcomeback_cnt_ttl u_pc\"><span>イオンリテール＋αの経験を活かして</span><span>もう一度一緒に働きませんか</span></h3>\n              <h3 class=\"welcomeback_cnt_ttl u_tbl u_sp\"><span>イオンリテール＋α</span><span>の経験を活かして</span><span>もう一度一緒に働きませんか</span></h3>\n              <p class=\"welcomeback_cnt_txt\">イオンリテールには、キャリアアップのための転職や留学、ご結婚、育児、介護などの理由で退職された方を対象にした再入社制度「ウェルカムバック制度」があります。もう一度イオンリテールで働きたい時や、退職時から環境が変わり再び勤務できるようになったときは、ぜひこの制度をご利用ください。イオンリテールへ入社いただけますことを、心よりお待ちしています。</p>\n            </div>\n            <div class=\"welcomeback_cnt_summary\">\n              <table class=\"welcomeback_cnt_summary_table g_table\">\n                <tbody>\n                  <tr>\n                    <th>申込要件</th>\n                    <td>\n                      ■勤続年数1年以上<br>\n                      ■退職時の従業員区分が、日給月給社員、コミュニティ社員であること（アルバイト、GGパートナー、GGエキスパート、エルダー社員は除く）<br>\n                      ■退職理由はキャリアアップのための転職や留学、ご結婚、育児、介護などによるものであること<br>\n                      ■薬剤師及び公的資格・社内認定資格をお持ちの方歓迎\n                    </td>\n                  </tr>\n                  <tr>\n                    <th>申込後の流れ</th>\n                    <td>\n                      申込後、全員の方を対象に選考を実施<br>\n                      　STEP１　エントリー<br>\n                      　STEP２　書類選考　<br>\n                      　STEP３　面接選考\n                    </td>\n                  </tr>\n                </tbody>\n              </table>\n            </div>\n            <div class=\"welcomeback_cnt_btn\">\n              <div class=\"g_btn g_entry_btn g_tab\">\n                <a href=\"https://aeonretail-career.snar.jp/entry.aspx?entryid=f3aa2035-eeda-48c1-82c7-28c0d543d238\" target=\"_blank\">ENTRY</a>\n              </div>\n            </div>\n          </div>\n          <div class=\"u_ic\">\n            <div class=\"welcomeback_cnt l_wrap_inr\">\n              <div class=\"welcomeback_cnt_inr pb_0\">\n                <h3 class=\"welcomeback_cnt_ttl welcomeback_cnt_ttl__bgwh u_pc\"><span>「イオンリテールスポットジョブ」はじめました！</span></h3>\n                <h3 class=\"welcomeback_cnt_ttl welcomeback_cnt_ttl__bgwh u_tbl u_sp\"><span>「イオンリテールスポットジョブ」はじめました！</span></h3>\n                <p class=\"welcomeback_cnt_txt\">当社をご退職された方限定で「スポットワーク」を導入いたしました。スポットワークとは、単日・短時間で働ける新しい働き方です。日程や勤務場所を選べる仕組みとなっており、これまで培われた知識・スキルを活かして働くことができます。<br>ご興味のある方は、ぜひご登録をお願いいたします。</p>\n              </div>\n              <div class=\"welcomeback_cnt_btn\">\n                <div class=\"g_btn g_entry_btn g_entry_btn__spot g_tab\">\n                  <a href=\"https://www14.webcas.net/form/pub/aeonretail/spotjob\" target=\"_blank\">スポットワークの<br>登録フォームはこちら</a>\n                </div>\n              </div>\n              <div class=\"welcomeback_bg_circle welcomeback_bg_circle06 u_img_def u_pc\">\n                <img src=\"/saiyo/welcomeback/img/circle02.png\" alt=\"\">\n              </div>\n              <div class=\"welcomeback_bg_circle welcomeback_bg_circle07 u_img_def u_pc\">\n                <img src=\"/saiyo/welcomeback/img/circle03.png\" alt=\"\">\n              </div>\n            </div>\n          </div>\n          <div class=\"welcomeback_cnt_logo\">\n            <a href=\"https://www.aeon.info/sustainability/\" class=\"u_img_def\">\n              <img src=\"/saiyo/welcomeback/img/foot_bnr_trees.svg\" alt=\"木を植えています -私たちはイオンです-\">\n            </a>\n          </div>\n        </section>\n      </div>\n    </main>\n    <!-- /contents -->\n    <!-- footer -->\n    <footer class=\"footer l_wrap\">\n      <div class=\"footer_inr l_flex l_justifyContentBetween l_directionColumn_md l_wrap_inr\">\n        <ul class=\"footer_lst l_flex u_medium l_directionColumn_md\">\n          <li class=\"footer_itm\">\n            <a href=\"/\" class=\"footer_link g_link_transp\">イオンリテール株式会社企業情報</a>\n          </li>\n          <li class=\"footer_itm l_flex l_directionColumn_md\">\n            <a href=\"/privacy/\" class=\"footer_link g_link_transp\">プライバシーポリシー</a>\n          </li>\n          <li class=\"footer_itm l_flex l_directionColumn_md\">\n            <a href=\"/terms/\" class=\"footer_link g_link_transp\">ご利用規約</a>\n          </li>\n        </ul>\n        <p class=\"footer_copyright\">Copyright© AEON RETAIL Co.,LTD</p>\n      </div>\n    </footer>\n    <!-- /footer -->\n\n    <!-- GDPR -->\n    <!-- <div class=\"g_gdpr l_wrap\">\n    <div class=\"g_gdpr_wrp l_wrap_inr\">\n      <p class=\"g_gdpr_txt g_txt\">本サイトはユーザーエクスペリエンスの向上などを目的に、Cookieを使用しています。<br>右記のバナーで「同意する」をクリックする、または本サイトを利用することにより、<br>お客様は弊社の<a href=\"#\">Cookieポリシー</a>に同意したことになります。</p>\n        <div class=\"g_gdpr_btn\">同意します</div>\n    </div>\n  </div> -->\n    <!-- /GDPR -->\n\n    <!-- 