 class=\"intvw-s-txt-area\">\n\t\t\t\t\t<h5>\n\t\t\t\t\t\t<span>技術力に増して、</span><br>\n\t\t\t\t\t\t<span>対話力も求められる仕事</span>\n\t\t\t\t\t</h5>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t\t<div class=\"intvw-date\">\n\t\t\t\t\t<p>2020年入社　K.Yさん</p>\n\t\t\t\t\t<p>富山本社</p>\n\t\t\t\t\t<p>クラウドサービス部</p>\n\t\t\t\t</div>\n\t\t\t</a>\n\t\t\t</div>\n\t\t</li>\n\t\t<li class=\"splide__slide\">\n\t\t\t<div class=\"s-action\">\n\t\t\t<a href=\"/interview/staff-07/\">\n\t\t\t\t<div class=\"staff-intvw-area\">\n\t\t\t\t\t<div class=\"intvw-s-photo skshi\">\n\t\t\t\t\t\t<img src=\"/common/images/interview/00-03-02-07-01.webp\" alt=\"staff-07\">\n\t\t\t\t\t</div>\n\t\t\t\t\t<div class=\"intvw-s-txt-area\">\n\t\t\t\t\t<h5>\n\t\t\t\t\t\t<span>先輩のスキルを吸収し、</span><br>\n\t\t\t\t\t\t<span>自分らしい営業スタイルに</span>\n\t\t\t\t\t</h5>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t\t<div class=\"intvw-date\">\n\t\t\t\t\t<p>2024年入社　K.Sさん</p>\n\t\t\t\t\t<p>富山本社</p>\n\t\t\t\t\t<p>北陸営業部</p>\n\t\t\t\t</div>\n\t\t\t</a>\n\t\t\t</div>\n\t\t</li>\n\t</ul>\n\n\t</div><!-- class=\"splide__track\" -->\n\n\t<div class=\"splide__arrow-area\">\n\t  <div class=\"splide__arrows\">\n\t\t<button class=\"splide__arrow splide__arrow--prev\">\n\t\t  <img src=\"/common/images/parts/ctrl-l.svg\">\n\t\t</button>\n\t\t<button class=\"splide__arrow splide__arrow--next\">\n\t\t  <img src=\"/common/images/parts/ctrl-r.svg\">\n\t\t</button>\n\t  </div>\n\t</div>\n\n</div><!-- class=\"splide\" -->\n\n</div><!-- class=\"overflow-right__sliderWrap\" -->\n</div><!-- class=\"inner\" -->\n\n<p class=\"btn-continue\"><a href=\"/interview/\" class=\"cntn-pk\"><span>はたらく人たち</span></a></p>\n\n</section><!-- class=\"splide-intvw-area\" -->\n\n\n</div><!-- class=\"no-scroll-x\" はみ出し防止 --></article><!-- id=\"staff_interview-slider\" -->\n\n\n\n<article id=\"staff_interview-rt-link\" class=\"real-talk-btm\">\n\t\n<section class=\"r-talk-link-area\">\n<div class=\"container\">\n\t<a href=\"/real-talk/\">\n\t<div class=\"r-talk-box\">\n\t\t<p class=\"r-tal