\"l-header_gnav_list_inner\">\n          <li>\n            <a href=\"https://maruichi-logistics.com/service#bring\">幹線物流事業</a>\n          </li>\n          <li>\n            <a href=\"https://maruichi-logistics.com/service#keep\">営業冷蔵庫部門</a>\n          </li>\n          <li>\n            <a href=\"https://maruichi-logistics.com/service#connect\">物流受託部門</a>\n          </li>\n        </ul>\n      </li>\n      <li class=\"l-header_gnav_list_cont\">\n        <a href=\"https://maruichi-logistics.com/company/\" class=\"sp-recruit\"></a>\n        <p class=\"l-header_gnav_list_toggle\">\n          <a href=\"https://maruichi-logistics.com/company/\">会社案内</a>\n        </p>\n        <ul class=\"l-header_gnav_list_inner\">\n          <li>\n            <a href=\"https://maruichi-logistics.com/company#movie\">企業紹介動画</a>\n          </li>\n          <li>\n            <a href=\"https://maruichi-logistics.com/company#philosophy\">経営理念</a>\n          </li>\n          <li>\n            <a href=\"https://maruichi-logistics.com/company#summary\">会社概要</a>\n          </li>\n          <li>\n            <a href=\"https://maruichi-logistics.com/company#history\">会社沿革</a>\n          </li>\n          <li>\n            <a href=\"https://maruichi-logistics.com/company#list\">事業所一覧</a>\n          </li>\n        </ul>\n      </li>\n      <li class=\"l-header_gnav_list_cont\">\n          <a href=\"https://maruichi-logistics.com/csr/\" class=\"nomal\">CSRへの取り組み</a>\n      </li>\n      <li class=\"l-header_gnav_list_cont\">\n        <a href=\"https://maruichi-logistics.com/recruit/\" class=\"sp-recruit\"></a>\n        <p class=\"l-header_gnav_list_toggle\">\n          <a href=\"https://maruichi-logistics.com/recruit/\" class=\"recruit-now\">採用情報</a>\n        </p>\n        <ul class=\"l-header_gnav_list_inner\">\n          <li>\n            <a href=\"https://maruichi-logistics.com/people/\">先輩社員の声</a>\n          </li>\n          <li>\n            <a href=\"https://maruichi-logistics.com/training/\">教育制度</a>\n          </li>\n          <li>\n            <a href=\"https://maruichi-logistics.com/oneday/\">部署の一日</a>\n          </li>\n          <li>\n            <a href=\"https://maruichi-logistics.com/job-description/\">募集要項</a>\n          </li>\n          <li>\n            <a href=\"https://maruichi-logistics.com/entry/\">採用応募フォーム</a>\n          </li>\n        </ul>\n      </li>\n    </ul>\n    <div class=\"l-header_gnav_contact\">\n      <a href=\"https://maruichi-logistics.com/inquiry/\">お問い合わせ</a>\n    </div>\n  </nav></header>\n<!-- header end -->\n<!-- main -->\r\n<main class=\"l-main\">\r\n<!-- key -->\r\n<section class=\"c-key job-description\">\r\n<div class=\"c-key_inner\">\r\n<h1 class=\"c-key_ttl\">\r\n<span class=\"c-key_ttl_en\">RECRUITMENT INFORMATION</span>\r\n<span class=\"c-key_ttl_jp\">募集要項</span>\r\n</h1>\r\n</div>\r\n</section>\r\n<!-- key end -->\r\n\r\n<!-- パンくず -->\r\n<section class=\"c-pkz\">\r\n<div class=\"l-cont_l sp_no\">\r\n<ul itemscope itemtype=\"https://schema.org/BreadcrumbList\">\r\n<li itemprop=\"itemListElement\" itemscope itemtype=\"https://schema.org/ListItem\">\r\n<a itemprop=\"item\" href=\"../\">\r\n<span itemprop=\"name\">トップページ</span>\r\n</a>\r\n<meta itemprop=\"position\" content=\"1\" />\r\n</li>\r\n<li itemprop=\"itemListElement\" itemscope itemtype=\"https://schema.org/ListItem\">\r\n<a itemprop=\"item\" href=\"../job-description/\">\r\n<span itemprop=\"name\">募集要項</span>\r\n</a>\r\n<meta itemprop=\"position\" content=\"2\" />\r\n</li>\r\n</ul>\r\n</div>\r\n</section>\r\n<!-- パンくず end -->\r\n\r\n<!-- link -->\r\n<section class=\"p-company_link\">\r\n<div class=\"l-cont_s\">\r\n<ul class=\"p-company_link_list\">\r\n<li>\r\n<a href=\"#new\">\r\n<div class=\"icon\">\r\n<img decoding=\"async\" src=\"../assets/img/btn_icon.svg\" alt=\"btn\">\r\n</div>\r\n<p class=\"txt\">新卒採用</p>\r\n</a>\r\n</li>\r\n<li>\r\n<a href=\"#career\">\r\n<div class=\"icon\">\r\n<img decoding=\"async\" src=\"../assets/img/btn_icon.svg\" alt=\"btn\">\r\n</div>\r\n<p class=\"txt\">中途採用</p>\r\n</a>\r\n</li>\r\n</ul>\r\n</div>\r\n</section>\r\n<!-- link end -->\r\n\r\n<!-- 新卒採用 -->\r\n<section class=\"p-description\">\r\n<div class=\"l-cont_s\">\r\n\r\n<div class=\"p-description_content\" id=\"new\">\r\n\r\n<div class=\"p-description_content_item\">\r\n<h2 class=\"c-ttl_line\">\r\n新卒採用\r\n</h2>\r\n<p class=\"p-description_content_txt\">\r\n当社は、食品物流という社会の根源的な役割を担うことを誇りとし、仕事を通して社会に貢献しつつ、しあわせな人生を築いていきたいと願う方を募集しています。物流技術の習得や業務の改善、さらには物流業務の管理者を目指していただくことでご自身の成長を会社として支援していきます。当社は常にチームワークで仕事を行うことを重視しています。 こちらの求人に応募される方、\r\n<br class=\"u-only_sp\">お問い合せは <span class=\"red\">管理部採用担当</span> TEL: 026-286-0501 <br class=\"u-only_sp\">または、<a href=\"../entry/\" class=\"underline\">応募フォーム</a>からご連絡お願い致します。<br>※高校生のご応募は学校経由でお願いいたします。\r\n</p>\r\n\r\n<div class=\"p-description_content_list\">\r\n<ul>\r\n<li>\r\n<div class=\"p-description_content_list_cate\">\r\n<p>募集職種</p>\r\n</div>\r\n<p class=\"p-description_content_list_txt\">食品物流に関わる企画・運営・管理</p>\r\n</li>\r\n<li>\r\n<div class=\"p-description_content_list_cate\">\r\n<p>募集人数</p>\r\n</div>\r\n<p class=\"p-description_content_list_txt\">最新情報にてご確認ください</p>\r\n</li>\r\n<li>\r\n<div class=\"p-description_content_list_cate\">\r\n<p>仕事内容</p>\r\n</div>\r\n<p class=\"p-description_content_list_txt\">物流センター運営及び構内物流作業・総務経理等</p>\r\n</li>\r\n</ul>\r\n</div>\r\n\r\n<div class=\"c-tbl_company\">\r\n<table>\r\n<tr>\r\n<th>募集職種</th>\r\n<td>食品物流に関わる企画・運営・管理</td>\r\n</tr>\r\n<tr>\r\n<th>主な仕事内容</th>\r\n<td>物流センター運営及び構内物流作業・総務経理等</td>\r\n</tr>\r\n<tr>\r\n<th>勤務地</th>\r\n<td>長野県内外、適性により判断（転居を伴う転勤あり）</td>\r\n</tr>\r\n<tr>\r\n<th>主な勤務時間</th>\r\n<td>\r\n&#9312;物流センターの運営（生鮮）　1：00～10：00 <br> &#9313;営業冷蔵庫の運営　13：00～22：00 <br> &#9314;物流営業（企画設計）　8：30～17：30 <br> &#9315;受発注・総務経理　8：30～17：30 <br> ※上記は一例です。その他あり。\r\n</td>\r\n</tr>\r\n<tr>\r\n<th>基本給</th>\r\n<td>\r\n&#9312;大学　　　221,450円<br> &#9313;短大専門　206,000円\r\n<br> &#9314;高卒　　　195,700円\r\n</td>\r\n</tr>\r\n<tr>\r\n<th>昇給</th>\r\n<td>\r\n年1回　3月　（※前年度の評価による）\r\n</td>\r\n</tr>\r\n<tr>\r\n<th>賞与</th>\r\n<td>\r\n会社規定による<br> （※2025年度　実績　年2回（7月、12月）　合計２カ月分）\r\n</td>\r\n</tr>\r\n<tr>\r\n<th>休日</th>\r\n<td>\r\n年間休日　108日（1日の労働時間：8.0時間）<br> ※各休日はシフトにより決定。\r\n<br> 有給休暇　初年度10日・最高40日\r\n</td>\r\n</tr>\r\n<tr>\r\n<th>福利厚生/諸手当</th>\r\n<td>\r\n福利厚生<br>　&#9312;各種社会保険完備\r\n<br>　&#9313;財形貯蓄制度\r\n<br>　&#9314;再雇用制度\r\n<br>　&#9315;退職金制度\r\n<br>　&#9316;その他\r\n<br>諸手当\r\n<br>　&#9312;時間外手当、深夜割増手当あり\r\n<br>　&#9313;通勤手当（上限27,500円）\r\n</td>\r\n</tr>\r\n<tr>\r\n<th>最終学歴</th>\r\n<td>高卒以上</td>\r\n</tr>\r\n<tr>\r\n<th>応募条件</th>\r\n<td>入社時までに普通自動車免許を保有していること（AT限定可）</td>\r\n</tr>\r\n<tr>\r\n<th>選考場所・日程</th>\r\n<td>\r\n選考場所：本社　（〒381-2202　長野市市場3-43）<br> 日程：別途ご案内いたします。\r\n</td>\r\n</tr>\r\n<tr>\r\n<th>選考方法</th>\r\n<td>\r\n※2021年度実施内容です。選考の方法は変更となる場合があります。<br>&#9312;適性検査\r\n<br>&#9313;小論文\r\n<br>&#9314;面接（一回）\r\n</td>\r\n</tr>\r\n<tr>\r\n<th>提出書類</th>\r\n<td>\r\n&#9312;履歴書<br>&#9313;卒業見込証明書\r\n<br>&#9314;成績証明書\r\n</td>\r\n</tr>\r\n</table>\r\n</div>\r\n<div class=\"p-description_content_btn\">\r\n<div class=\"c-btn_red\">\r\n<a href=\"../entry/\">\r\n応募はこちらから\r\n</a>\r\n</div>\r\n</div>\r\n</div>\r\n</div>\r\n\r\n</div>\r\n</section>\r\n<!-- 新卒採用 end -->\r\n\r\n<!-- 中途採用 -->\r\n<section class=\"p-description\">\r\n<div class=\"l-cont_s\">\r\n\r\n<div class=\"p-description_content\" id=\"career\">\r\n\r\n<div class=\"p-description_content_item\">\r\n<h2 class=\"c-ttl_line\">\r\n中途採用\r\n</h2>\r\n<p class=\"p-description_content_txt\">\r\n物流業務の経験がある方も、まったく初めての方でも、業務を一緒に行いながら丁寧な指導であなたの成長をサポートしていきます。\r\n<br>こちらの求人に応募される方、お問い合せは、<br class=\"u-only_sp\"><span class=\"red\">管理部採用担当</span> TEL: 026-286-0501 <br class=\"u-only_sp\">または、<a href=\"../entry/\" class=\"underline\">応募フォーム</a>からご連絡お願い致します。\r\n</p>\r\n\r\n<div class=\"tab-area\">\r\n\r\n<input id=\"tab-btn1\" class=\"tab-btn\" name=\"tab\" type=\"radio\" checked>\r\n<input id=\"tab-btn2\" class=\"tab-btn\" name=\"tab\" type=\"radio\">\r\n<input id=\"tab-btn3\" class=\"tab-btn\" name=\"tab\" type=\"radio\">\r\n\r\n<ul class=\"tab-list-wrap\">\r\n<li><label id=\"tab-list1\" class=\"tab-list\" for=\"tab-btn1\">正社員</label></li>\r\n<li><label id=\"tab-list2\" class=\"tab-list\" for=\"tab-btn2\">契約社員</label></li>\r\n<li><label id=\"tab-list3\" class=\"tab-list\" for=\"tab-btn3\">パートタイマー</label></li>\r\n</ul>\r\n\r\n<div class=\"tab-content-wrap\">\r\n<div id=\"tab-content1\" class=\"tab-content\">\r\n<div class=\"p-description_content_list tab-item\">\r\n<ul>\r\n<li>\r\n<div class=\"p-description_content_list_cate\">\r\n<p>募集職種</p>\r\n</div>\r\n<p class=\"p-description_content_list_txt\">食品物流に関わる企画・運営・管理</p>\r\n</li>\r\n<li>\r\n<div class=\"p-description_content_list_cate\">\r\n<p>募集人数</p>\r\n</div>\r\n<p class=\"p-description_content_list_txt\">最新情報にてご確認ください</p>\r\n</li>\r\n<li>\r\n<div class=\"p-description_content_list_cate\">\r\n<p>仕事内容</p>\r\n</div>\r\n<p class=\"p-description_content_list_txt\">物流センター運営及び構内物流作業・総務経理等</p>\r\n</li>\r\n</ul>\r\n</div>\r\n\r\n<div class=\"c-tbl_company\">\r\n<table>\r\n<tr>\r\n<th>募集職種</th>\r\n<td>食品物流に関わる企画・運営・管理</td>\r\n</tr>\r\n<tr>\r\n<th>主な仕事内容</th>\r\n<td>物流センター運営及び構内物流作業・総務経理等</td>\r\n</tr>\r\n<tr>\r\n<th>勤務地</th>\r\n<td>長野県内外、適性により判断（転居を伴う転勤あり）</td>\r\n</tr>\r\n<tr>\r\n<th>主な勤務時間</th>\r\n<td>\r\n&#9312;物流センターの運営（生鮮）　1：00～10：00 <br> &#9313;営業冷蔵庫の運営　13：00～22：00 <br> &#9314;物流営業（企画設計）　8：30～17：30 <br> &#9315;受発注・総務経理　8：30～17：30 <br> ※上記は一例です。その他あり。\r\n</td>\r\n</tr>\r\n<tr>\r\n<th>基本給</th>\r\n<td>\r\nこれまでの経験等を考慮し、当社規定に従って決定させて頂きます。\r\n</td>\r\n</tr>\r\n<tr>\r\n<th>昇給</th>\r\n<td>\r\n通常の場合、年1回　3月\r\n<br>※入社の時期によっては、翌年の昇給対象となることがあります。\r\n</td>\r\n</tr>\r\n<tr>\r\n<th>賞与</th>\r\n<td>\r\n会社規定による<br> （※2025年度　実績　年2回（7月、12月）　合計２カ月分）\r\n</td>\r\n</tr>\r\n<tr>\r\n<th>休日</th>\r\n<td>\r\n年間休日　108日（1日の労働時間：8.0時間）<br> ※各休日はシフトにより決定。\r\n<br> 有給休暇　初年度10日・最高40日\r\n</td>\r\n</tr>\r\n<tr>\r\n<th>福利厚生/諸手当</th>\r\n<td>\r\n福利厚生<br>　&#9312;各種社会保険完備\r\n<br>　&#9313;財形貯蓄制度\r\n<br>　&#9314;再雇用制度\r\n<br>　&#9315;退職金制度\r\n<br>　&#9316;その他\r\n<br>諸手当\r\n<br>　&#9312;時間外手当、深夜割増手当あり\r\n<br>　&#9313;通勤手当（上限27,500円）\r\n</td>\r\n</tr>\r\n<tr>\r\n<th>最終学歴</th>\r\n<td>不問</td>\r\n</tr>\r\n<tr>\r\n<th>応募条件</th>\r\n<td>入社時までに普通自動車免許を保有していること（AT限定可）</td>\r\n</tr>\r\n<tr>\r\n<th>選考場所・日程</th>\r\n<td>\r\n選考場所：本社　（〒381-2202　長野市市場3-43）<br>日程：別途ご案内いたします。\r\n</td>\r\n</tr>\r\n<tr>\r\n<th>選考方法</th>\r\n<td>\r\n※2024年度実施内容です。選考の方法は変更となる場合があります。<br>&#9312;適性検査\r\n<br>&#9313;性格検査\r\n<br>&#9314;面接\r\n</td>\r\n</tr>\r\n<tr>\r\n<th>提出書類</th>\r\n<td>\r\n&#9312;履歴書<br>&#9313;職務経歴書\r\n</td>\r\n</tr>\r\n</table>\r\n</div>\r\n\r\n<div class=\"p-description_content_btn\">\r\n<div class=\"c-btn_red\">\r\n<a href=\"../entry/\">\r\n応募はこちらから\r\n</a>\r\n</div>\r\n</div>\r\n</div>\r\n\r\n<div id=\"tab-content2\" class=\"tab-content\">\r\n\r\n<div class=\"p-description_content_list tab-item\">\r\n<ul>\r\n<li>\r\n<div class=\"p-description_content_list_cate\">\r\n<p>募集職種</p>\r\n</div>\r\n<p class=\"p-description_content_list_txt\">物流業務（仕分等）、物流事務</p>\r\n</li>\r\n<li>\r\n<div class=\"p-description_content_list_cate\">\r\n<p>募集人数</p>\r\n</div>\r\n<p class=\"p-description_content_list_txt\">最新情報にてご確認ください</p>\r\n</li>\r\n<li>\r\n<div class=\"p-description_content_list_cate\">\r\n<p>仕事内容</p>\r\n</div>\r\n<p class=\"p-description_content_list_txt\">構内物流作業及びセンター運営・総務経理等</p>\r\n</li>\r\n</ul>\r\n</div>\r\n\r\n<div class=\"c-tbl_company\">\r\n<table>\r\n<tr>\r\n<th>募集職種</th>\r\n<td>物流業務（仕分等）、物流事務</td>\r\n</tr>\r\n<tr>\r\n<th>主な仕事内容</th>\r\n<td>構内物流作業及びセンター運営・総務経理等</td>\r\n</tr>\r\n<tr>\r\n<th>勤務地</th>\r\n<td>ご自宅から通うことのできる範囲にある当社各事業所</td>\r\n</tr>\r\n<tr>\r\n<th>主な勤務時間</th>\r\n<td>\r\n&#9312;物流センターの運営（生鮮）　1：00～9：30 <br> &#9313;営業冷蔵庫の運営　13：00～21：30 <br> &#9314;物流営業（企画設計）　8：30～17：00 <br> &#9315;受発注・総務経理　8：30～17：00 <br> ※上記は一例です。その他あり。\r\n</td>\r\n</tr>\r\n<tr>\r\n<th>基本給</th>\r\n<td>\r\nこれまでの経験等を考慮し、当社規定に従って決定させて頂きます。\r\n</td>\r\n</tr>\r\n<tr>\r\n<th>休日</th>\r\n<td>\r\n週休形態　月8～9日<br> 有給休暇　初年度10日・最高40日\r\n<br> 年間休日　106日（1日の労働時間：8時間）\r\n</td>\r\n</tr>\r\n<tr>\r\n<th>福利厚生/諸手当</th>\r\n<td>\r