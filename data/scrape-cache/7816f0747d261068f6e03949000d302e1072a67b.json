class=\"navlist\">\n \t\t\t\t\t\t<a href=\"https://www.mizuho.co.jp/recruit/entry/\" class='entry link-gnav'>\n \t\t\t\t\t\t\t<span class=\"en\">ENTRY</span>\n \t\t\t\t\t\t\t<span class=\"ja\">エントリー</span>\n \t\t\t\t\t\t</a>\n \t\t\t\t\t</li>\n\n \t\t\t\t</ul>\n \t\t\t</nav>\n \t\t</div>\n \t</div>\n\n </header>\n\n\n <main role=\"main\" class=\"main \">\n<div class=\"mv\">\n\t<div class=\"inner\">\n\t\t<p class=\"en txt\"><img src=\"https://www.mizuho.co.jp/recruit/wp-content/themes/mizuho1.2.7/img/common/txt-mv-en.png\" alt=\"Keep on challenging beyond the centuries\" class=\"img-responsive\"></p>\n\t\t<p class=\"ja txt\"><img src=\"https://www.mizuho.co.jp/recruit/wp-content/themes/mizuho1.2.7/img/common/txt-mv-ja.png\" alt=\"これからの100年に挑戦し続ける未来を描く\" class=\"img-responsive\"></p>\n\t\t<div class=\"people\">\n\t\t\t<div id=\"slider-mv\" class=\"slider-pro\">\n\t\t\t\t<div class=\"sp-slides\">\n\t\t\t\t\t<div class=\"sp-slide\">\n\t\t\t\t\t\t<img alt=\"\" class=\"sp-image\" src=\"https://www.mizuho.co.jp/recruit/wp-content/themes/mizuho1.2.7/img/common/mv-05.png\">\n\t\t\t\t\t</div>\n\t\t\t\t\t<div class=\"sp-slide\">\n\t\t\t\t\t\t<img alt=\"\" class=\"sp-image\" src=\"https://www.mizuho.co.jp/recruit/wp-content/themes/mizuho1.2.7/img/common/mv-04.png\">\n\t\t\t\t\t</div>\n\t\t\t\t\t<div class=\"sp-slide\">\n\t\t\t\t\t\t<img alt=\"\" class=\"sp-image\" src=\"https://www.mizuho.co.jp/recruit/wp-content/themes/mizuho1.2.7/img/common/mv-02.png\">\n\t\t\t\t\t</div>\n\t\t\t\t\t<div class=\"sp-slide\">\n\t\t\t\t\t\t<img alt=\"\" class=\"sp-image\" src=\"https://www.mizuho.co.jp/recruit/wp-content/themes/mizuho1.2.7/img/common/mv-01.png\">\n\t\t\t\t\t</div>\n\t\t\t\t\t<div class=\"sp-slide\">\n\t\t\t\t\t\t<img alt=\"\" class=\"sp-image\" src=\"https://www.mizuho.co.jp/recruit/wp-content/themes/mizuho1.2.7/img/common/mv-07.png\">\n\t\t\t\t\t</div>\n\t\t\t\t\t<div class=\"sp-slide\">\n\t\t\t\t\t\t<img alt=\"\" class=\"sp-image\" src=\"https://www.mizuho.co.jp/recruit/wp-content/themes/mizuho1.2.7/img/common/mv-08.png\">\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\t</div>\n</div>\n<section class=\"section-top-mission\">\n\t<div class=\"container-lg container-fluid\">\n\t\t<h2 class=\"txt-32 txt-eng txt-center ls-md lh-1 txt-main mb-40\">Our Mission</h2>\n\t\t<p class=\"txt-top-01 txt-18 mb-10\">\n\t\t\t当社は創業以来約100年以上の間、<br class=\"hidden-xs\">\n\t\t\t医療機器を製造から販売まで行ってきました。<br>\n\t\t\t長年、医療機器に向き合ってきた経験を活かし、<br class=\"hidden-xs\">\n\t\t\tこれからのグローバル競争にも立ち向かってまいります。\n\t\t</p>\n\t\t<p class=\"txt-top-01 txt-18\">\n\t\t\tグループの力を結集してアジアやヨーロッパへの<br class=\"hidden-xs\">\n\t\t\t進出を目指しています。\n\t\t</p>\n\t</div>\n</section>\n<div class=\"row-top\">\n\t<div class=\"container-lg container-fluid\">\n\t\t<div class=\"row\">\n\t\t\t<div class=\"col-sm-6 mb-10-xs\">\n\t\t\t\t<a href=\"https://www.mizuho.co.jp/recruit/environment/\" class=\"box-top match\">\n\t\t\t\t\t<div class=\"mb-30\">\n\t\t\t\t\t\t<p class=\"ttl txt-42 txt-eng lh-1 ls-md mb-10\">\n\t\t\t\t\t\t\tEnvironment\n\t\t\t\t\t\t</p>\n\t\t\t\t\t\t<h2 class=\"txt-18 txt-mincho lh-1 txt-bold\">働く環境</h2>\n\t\t\t\t\t</div>\n\t\t\t\t\t<p class=\"txt-14\">\n\t\t\t\t\t\tどのようなときも社員が働きやすい環境を整えることが、会社の使命であると考えます。<br>\n\t\t\t\t\t\tミズホでは、オフィスや工場などの環境整備からモチベーション維持の制度まで、社員がイキイキと働ける環境づくりを目指しています。\n\t\t\t\t\t</p>\n\t\t\t\t</a>\n\t\t\t</div>\n\t\t\t<div class=\"col-sm-6 mb-10-xs\">\n\t\t\t\t<a href=\"https://www.mizuho.co.jp/recruit/training/\" class=\"box-top match\">\n\t\t\t\t\t<div class=\"mb-30\">\n\t\t\t\t\t\t<p class=\"ttl txt-42 txt-eng lh-1 ls-md mb-10\">\n\t\t\t\t\t\t\tTraining\n\t\t\t\t\t\t</p>\n\t\t\t\t\t\t<h2 class=\"txt-18 txt-mincho lh-1 txt-bold\">人材育成</h2>\n\t\t\t\t\t</div>\n\t\t\t\t\t<p class=\"txt-14\">\n\t\t\t\t\t\tミズホが目指すのは“自分で考えて、学んで、行動する”ことができる人材づくりです。<br>\n\t\t\t\t\t\tそのために、学習する意欲のある社員を全面的にバックアップする制度を整えています。\n\t\t\t\t\t</p>\n\t\t\t\t</a>\n\t\t\t</div>\n\t\t</div>\n\t</div>\n</div>\n<section class=\"section-top-interview\">\n\t<div class=\"inner\">\n\t\t<div class=\"container-lg container-fluid\">\n\t\t\t<div class=\"txt-center txt-main mb-40\">\n\t\t\t\t<h2 class=\"txt-40 txt-eng ls-md mb-10\">Interview</h2>\n\t\t\t\t<p class=\"txt-18 txt-mincho txt-bold ls-md lh-1\">先輩インタビュー</p>\n\t\t\t</div>\n\t\t\t<p class=\"txt-mincho txt-center txt-18 mb-40\">\n\t\t\t\t個性豊かな社員たちが、<br class=\"visible-xs\">それぞれの専門分野で<br class=\"visible-xs\">自分らしく活躍しています。\n\t\t\t</p>\n\t\t\t<p class=\"txt-center\">\n\t\t\t\t<a href=\"https://www.mizuho.co.jp/recruit/interview/\" class=\"btn-base btn-simple txt-bold txt-mincho txt-18\">インタビュー一覧</a>\n\t\t\t</p>\n\t\t</div>\n\t</div>\n\t<img src=\"https://www.mizuho.co.jp/recruit/wp-content/themes/mizuho1.2.7/img/common/bg-top-recruit.jpg\" alt=\"\" class=\"img-people\">\n</section>\n<div class=\"section-top-infographics\">\n\t<div class=\"inner\">\n\t\t<div class=\"container-lg container-fluid\">\n\t\t\t<section class=\"mb-100 top\">\n\t\t\t\t<div class=\"mb-40\">\n\t\t\t\t\t<h2 class=\"txt-40 txt-eng ls-md mb-10\">Infographics</h2>\n\t\t\t\t\t<p class=\"txt-18 txt-mincho txt-bold ls-md lh-1\">数字で見るMizuho</p>\n\t\t\t\t</div>\n\t\t\t\t<p class=\"mb-30\">\n\t\t\t\t\t売上・従業員数の推移や人員構成比の数値をはじめ、社員への<br class=\"hidden-xs\">\n\t\t\t\t\tアンケートの結果など、より具体的にMizuhoを知って<br class=\"hidden-xs\">\n\t\t\t\t\tいただけるさまざまなデータを掲載しています。\n\t\t\t\t</p>\n\t\t\t\t<p class=\"txt-center-xs\">\n\t\t\t\t\t<a href=\"https://www.mizuho.co.jp/recruit/infographics/\" class=\"btn-base btn-lined white txt-eng ls-md txt-18\">View Detail</a>\n\t\t\t\t</p>\n\t\t\t</section>\n\t\t\t<div class=\"row mb-60\">\n\t\t\t\t<div class=\"col-sm-6 mb-10-xs\">\n\t\t\t\t\t<a href=\"https://www.mizuho.co.jp/recruit/systems/\" class=\"box-top-02\">\n\t\t\t\t\t\t<div class=\"inner-box\">\n\t\t\t\t\t\t\t<div class=\"icon\">\n\t\t\t\t\t\t\t\t<img alt=\"各種制度\" class=\"img-responsive center-block\" src=\"https://www.mizuho.co.jp/recruit/wp-content/themes/mizuho1.2.7/img/common/icon-top-system.png\">\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t<div class=\"content\">\n\t\t\t\t\t\t\t\t