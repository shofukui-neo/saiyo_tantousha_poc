{"url":"https://www.iwatanigas.co.jp/recruit/work/crosstalk.html","html":"<!doctype html>\n<html lang=\"ja\">\n<head>\n<!-- Google Tag Manager -->\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n})(window,document,'script','dataLayer','GTM-TNG4FCR');</script>\n<!-- End Google Tag Manager -->\n<!-- Google tag (gtag.js) -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-CS9J4SP782\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'G-CS9J4SP782');\n</script>\n<!-- // Google tag (gtag.js) -->\n<meta charset=\"utf-8\" />\n<meta http-equiv=\"Content-Style-Type\" content=\"text/css\" />\n<meta http-equiv=\"Content-script-type\" content=\"text/javascript\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<meta name=\"Keywords\" content=\"岩谷瓦斯,イワタニグループ,岩谷産業,新卒,採用,仕事,若手,新入社員,座談会,社風\">\n<meta name=\"description\" content=\"岩谷瓦斯の新卒採用情報の「若手社員座談会」ページです。入社間もない社員たちに、当社の社風や教育体制、岩谷瓦斯の印象などを語ってもらいました。\">\n<title>若手社員座談会｜新卒採用｜岩谷瓦斯</title>\n<meta property=\"og:site_name\" content=\"新卒採用｜岩谷瓦斯\">\n<meta property=\"og:title\" content=\"若手社員座談会｜新卒採用｜岩谷瓦斯\">\n<meta property=\"og:description\" content=\"岩谷瓦斯の新卒採用情報の「若手社員座談会」ページです。入社間もない社員たちに、当社の社風や教育体制、岩谷瓦斯の印象などを語ってもらいました。\">\n<meta property=\"og:type\" content=\"article\">\t\n<meta property=\"og:image\" content=\"/recruit/common/img/ogp.jpg\">\t\n<meta property=\"og:url\" content=\"http://www.iwatanigas.co.jp/recruit/work/crosstalk.html\">\n<meta property=\"og:locale\" content=\"ja_JP\">\n<meta name=\"format-detection\" content=\"telephone=no\">\n\n<!-- このページで使用するcssを読み込む -->\n<link rel=\"icon\" href=\"../common/img/favicon.ico\">\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/yakuhanjp@3.4.1/dist/css/yakuhanjp.min.css\">\n<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n<link href=\"https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500;700&family=Prompt:wght@300;400;500;600&family=Roboto+Condensed:wght@400;700&display=swap\" rel=\"stylesheet\">\n<link rel=\"stylesheet\" href=\"https://use.typekit.net/nja7gne.css\">\n<link href=\"https://unpkg.com/aos@2.3.1/dist/aos.css\" rel=\"stylesheet\">\n<link rel=\"stylesheet\" type=\"text/css\" href=\"css/crosstalk.css\" media=\"all, projection, print\" />\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../common/css/common.css\" media=\"all, projection, print\" />\n\n\t\n</head>\n<body>\n<!-- Google Tag Manager (noscript) -->\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-TNG4FCR\"\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n<!-- End Google Tag Manager (noscript) -->\n\n\t\n\n<!-------------- #c-header -------------->\n<header class=\"c-header\">\n\t<div class=\"lines\">\n\t\t<span></span><span></span><span></span>\n\t</div>\n\t<div class=\"inner\">\n\t\t<a href=\"/recruit/\" class=\"logo\">\n\t\t\t<img src=\"../common/img/logo.png\" alt=\"岩谷瓦斯株式会社\">\n\t\t</a>\t\t\n\t\t<a class=\"entry en mess\" href=\"/recruit/message/\"><span>Message</span></a>\t\n\t\t<a class=\"entry en\" href=\"https://www.iwatanigas.co.jp/entry/shinsotsu.php\" target=\"_blank\"><span>ENTRY</span></a>\n\t\n\t\t<div class=\"c-humburger\">\n\t\t\t<span class=\"bar bar_top\"></span>\n\t\t\t<span class=\"bar bar_middle\"></span>\n\t\t\t<span class=\"bar bar_bottom\"></span>\n\t\t</div>\n\t\t\n\t\t<nav class=\"c-nav\">\n\t\t\t<div class=\"nav-cntnts\">\n\t\t\t\t<a href=\"/recruit/about/\">\n\t\t\t\t\t<div>\n\t\t\t\t\t<p class=\"img\"><img src=\"../common/img/menu_icon01.svg\" alt=\"\"></p>\n\t\t\t\t\t<p class=\"ttl\">岩谷瓦斯の<br>事業</p>\n\t\t\t\t\t</div>\n\t\t\t\t</a>\n\t\t\t\t<a href=\"/recruit/about/social.html\">\n\t\t\t\t\t<div>\n\t\t\t\t\t<p class=\"img\"><img src=\"../common/img/menu_icon02.svg\" alt=\"\"></p>\n\t\t\t\t\t<p class=\"ttl\">社会が変化する、<br>その時に。</p>\n\t\t\t\t\t</div>\n\t\t\t\t</a>\t\n\t\t\t\t<a href=\"/recruit/about/keyword.html\">\n\t\t\t\t\t<div>\n\t\t\t\t\t<p class=\"img\"><img src=\"../common/img/menu_icon03.svg\" alt=\"\"></p>\n\t\t\t\t\t<p class=\"ttl\">キーワードで知る<br>岩谷瓦斯</p>\n\t\t\t\t\t</div>\n\t\t\t\t</a>\t\n\t\t\t\t<a href=\"/recruit/special/\">\n\t\t\t\t\t<div>\n\t\t\t\t\t<p class=\"img\"><img src=\"../common/img/menu_icon04.svg\" alt=\"\"></p>\n\t\t\t\t\t<p class=\"ttl\">そこに、<br>岩谷瓦斯がある理由。</p>\n\t\t\t\t\t</div>\n\t\t\t\t</a>\t\n\t\t\t\t<a href=\"/recruit/special/photo.html\">\n\t\t\t\t\t<div>\n\t\t\t\t\t<p class=\"img\"><img src=\"../common/img/menu_icon05.svg\" alt=\"\"></p>\n\t\t\t\t\t<p class=\"ttl\">写真で見る<br>岩谷瓦斯の現場</p>\n\t\t\t\t\t</div>\n\t\t\t\t</a>\n\t\t\t\t<a href=\"/recruit/work/people.html\">\n\t\t\t\t\t<div>\n\t\t\t\t\t<p class=\"img\"><img src=\"../common/img/menu_icon06.svg\" alt=\"\"></p>\n\t\t\t\t\t<p class=\"ttl\"><span class=\"en\">People</span><br>社員紹介</p>\n\t\t\t\t\t</div>\n\t\t\t\t</a>\t\n\t\t\t\t<a href=\"/recruit/work/\">\n\t\t\t\t\t<div>\n\t\t\t\t\t<p class=\"img\"><img src=\"../common/img/menu_icon07.svg\" alt=\"\"></p>\n\t\t\t\t\t<p class=\"ttl\"><span class=\"en\">Work</span><br>岩谷瓦斯の仕事を知る</p>\n\t\t\t\t\t</div>\n\t\t\t\t</a>\t\n\t\t\t\t<a href=\"/recruit/work/crosstalk.html\">\n\t\t\t\t\t<div>\n\t\t\t\t\t<p class=\"img\"><img src=\"../common/img/menu_icon08.svg\" alt=\"\"></p>\n\t\t\t\t\t<p class=\"ttl\"><span class=\"en\">Cross Talk</span><br>若手社員座談会</p>\n\t\t\t\t\t</div>\n\t\t\t\t</a>\t\n\t\t\t\t<a href=\"/recruit/work/parent.html\">\n\t\t\t\t\t<div>\n\t\t\t\t\t<p class=\"img\"><img src=\"../common/img/menu_icon09.svg\" alt=\"\"></p>\n\t\t\t\t\t<p class=\"ttl\"><span class=\"en\">Cross Talk</span><br>パパママ座談会</p>\n\t\t\t\t\t</div>\n\t\t\t\t</a>\t\n\t\t\t\t<a href=\"/recruit/work/faq.html\">\n\t\t\t\t\t<div>\n\t\t\t\t\t<p class=\"img\"><img src=\"../common/img/menu_icon10.svg\" alt=\"\"></p>\n\t\t\t\t\t<p class=\"ttl\"><span class=\"en\">FAQ</span><br>社員が本音で答えるFAQ</p>\n\t\t\t\t\t</div>\n\t\t\t\t</a>\t\n\t\t\t\t<a href=\"/recruit/work/training-diary.html\">\n\t\t\t\t\t<div>\n\t\t\t\t\t<p class=\"img\"><img src=\"../common/img/menu_icon11.svg\" alt=\"\"></p>\n\t\t\t\t\t<p class=\"ttl\"><span class=\"en\">Training</span><br>新人1年目の研修奮闘記</p>\n\t\t\t\t\t</div>\n\t\t\t\t</a>\t\n\t\t\t</div>\n\t\t\t<div class=\"und-btns\">\n\t\t\t\t<a href=\"/recruit/information/\"><span>募集要項</span></a>\n\t\t\t\t<a href=\"/recruit/information/welfare.html\"><span>ワークライフバランス＆<br>福利厚生</span></a>\n\t\t\t\t<a href=\"/recruit/information/faq.html\"><span>採用FAQ</span></a>\n\t\t\t</div>\n\t\t</nav>\n\t</div>\n</header>\n\t\n<div class=\"c-nav-bg\"></div>\n<!-------------- //#c-header -------------->\n\n\t\n\n\t\n\n\n<!-------------- #c-main -------------->\n<main class=\"c-main\">\n\t\n\t<section class=\"fv_area\">\n\t\t<p class=\"pagettl\"><img src=\"../work/img/crosstalk/pagettl.svg\" alt=\"CROSS TALK\"></p>\n\t\t<p class=\"fvbg\">\n\t\t\t<img src=\"img/crosstalk/fvbg.jpg\" alt=\"岩谷瓦斯の仕事を知る\">\n\t\t</p>\n\t</section>\n\t\n\t<div class=\"ttl_area\">\n\t\t<div class=\"lines\">\n\t\t\t<span></span><span></span><span></span>\n\t\t</div>\t\n\t\t<div class=\"c-inner\" data-aos=\"fade-up\" data-aos-duration=\"1600\" data-aos-once=\"true\">\n\t\t\t<h1><span>若手社員座談会</span></h1>\t\n\t\t\t<p class=\"copy\"><span class=\"gr\">社会に役立つ仕事</span>を通じ、<br>\n\t\t\t<span class=\"gr\">自身を成長させていける</span><br>\t\n\t\t\t環境で働くことに<br class=\"sp\">充実感がある</p>\n\t\t</div>\n\t</div>\n\t\n\t\n\t<div class=\"intro_area\">\n\t\t<div class=\"c-inner\">\n\t\t\t<div class=\"cntnt\" data-aos=\"fade-up\" data-aos-duration=\"1600\" data-aos-once=\"true\">\n\t\t\t\t<p class=\"pht\"><img src=\"../work/img/crosstalk/wakate01.jpg\" alt=\"R.O\"></p>\n\t\t\t\t<p class=\"yaku\">生産本部 神戸液化水素荷役実証ターミナル／製造職</p>\n\t\t\t\t<p class=\"name\">R.O</p>\n\t\t\t\t<p class=\"txt\">工学部 マテリアル工学科<br>2023年度入社</p>\n\t\t\t</div>\n\t\t\t<div class=\"cntnt\" data-aos=\"fade-up\" data-aos-duration=\"1600\" data-aos-once=\"true\">\n\t\t\t\t<p class=\"pht\"><img src=\"../work/img/crosstalk/wakate02.jpg\" alt=\"So.O\"></p>\n\t\t\t\t<p class=\"yaku\">生産本部 近畿エリア(生産担当)／製造職</p>\n\t\t\t\t<p class=\"name\">So.O</p>\n\t\t\t\t<p class=\"txt\">農学部 生物環境学科<br>2023年度入社</p>\n\t\t\t</div>\n\t\t\t<div class=\"cntnt\" data-aos=\"fade-up\" data-aos-duration=\"1600\" data-aos-once=\"true\">\n\t\t\t\t<p class=\"pht\"><img src=\"../work/img/crosstalk/wakate03.jpg\" alt=\"Su.O\"></p>\n\t\t\t\t<p class=\"yaku\">生産本部 大阪ヘリウムセンター／製造職</p>\n\t\t\t\t<p class=\"name\">Su.O</p>\n\t\t\t\t<p class=\"txt\">高等専門学校 創造技術工学科 化学コース<br>2023年度入社</p>\n\t\t\t</div>\n\t\t\t<div class=\"cntnt\" data-aos=\"fade-up\" data-aos-duration=\"1600\" data-aos-once=\"true\">\n\t\t\t\t<p class=\"pht\"><img src=\"../work/img/crosstalk/wakate04.jpg\" alt=\"S.K\"></p>\n\t\t\t\t<p class=\"yaku\">株式会社ハイドロエッジ 技術部 プラント課／製造職</p>\n\t\t\t\t<p class=\"name\">S.K</p>\n\t\t\t\t<p class=\"txt\">工学部 材料工学科<br>2023年度入社</p>\n\t\t\t</div>\n\t\t\t<p class=\"kome\" data-aos=\"fade-up\" data-aos-duration=\"1600\" data-aos-once=\"true\">※社員の所属部署は取材当時のものです。</p>\n\t\t</div>\n\t</div>\n\n\t<div class=\"theme_area\">\n\t\t<div class=\"c-inner\">\n\t\t\t\n\t\t\t<div class=\"theme_cntnt\">\n\t\t\t\t<div class=\"ttlarea\" data-aos=\"fade-up\" data-aos-duration=\"1600\" data-aos-once=\"true\">\n\t\t\t\t\t<p class=\"en\">Theme</p>\n\t\t\t\t\t<h2>就職活動時の印象は？</h2>\n\t\t\t\t</div>\n\t\t\t\t<div class=\"lines\">\n\t\t\t\t\t<span></span><span></span><span></span>\n\t\t\t\t</div>\t\n\t\t\t\t<h3 class=\"answer\" data-aos=\"fade-up\" data-aos-duration=\"1600\" data-aos-once=\"true\">\n\t\t\t\t\t社会貢献性だけでなく、<br>働きやすい環境も魅力だった\n\t\t\t\t</h3>\n\t\t\t\t\n\t\t\t\t<div class=\"half_layout mb\">\n\t\t\t\t\t<ul class=\"talk\">\n\t\t\t\t\t\t<li data-aos=\"fade-up\" data-aos-duration=\"1600\" data-aos-once=\"true\">\n\t\t\t\t\t\t\t<p class=\"name\">Su.O</p>\n\t\t\t\t\t\t\t<p class=\"txt\">私が岩谷瓦斯に惹かれたのは、世の中に必要とされている産業ガスの中でも、これからさらに伸びしろのある水素やヘリウムを扱っている、先進的で未来志向の考えを持っている会社だったことですね。</p>\n\t\t\t\t\t\t</li>\n\t\t\t\t\t\t<li data-aos=\"fade-up\" data-aos-duration=\"1600\" data-aos-once=\"true\">\n\t\t\t\t\t\t\t<p class=\"name\">So.O</p>\n\t\t\t\t\t\t\t<p class=\"txt\">確か、Su.Oさんは化学分野を学んでいたんですよね？ その知識が活かせるというのも理由でしたか？</p>\n\t\t\t\t\t\t</li>\n\t\t\t\t\t</ul>\n\t\t\t\t\t<div class=\"pht half\" data-aos=\"fade-up\" data-aos-duration=\"1600\" data-aos-once=\"true\"><img src=\"../work/img/crosstalk/cntnt04.jpg\" alt=\"若手社員座談会の様子\"></div>\n\t\t\t\t</div>\n\t\t\t\t<ul class=\"talk\">\n\t\t\t\t\t<li data-aos=\"fade-up\" data-aos-duration=\"1600\" data-aos-once=\"true\">\n\t\t\t\t\t\t<p class=\"name\">Su.O</p>\n\t\t\t\t\t\t<p class=\"txt\">実は、ガスのことは全く分かっていなくて最初は不安だったのですが、面接の中で「化学分析の知識が活かせる仕事もあるよ」と教えていただいたことも入社の決め手になりました。</p>\n\t\t\t\t\t</li>\n\t\t\t\t\t<li data-aos=\"fade-up\" data-aos-duration=\"1600\" data-aos-once=\"true\">\n\t\t\t\t\t\t<p class=\"name\">R.O</p>\n\t\t\t\t\t\t<p class=\"txt\">岩谷瓦斯には、いろんな分野の知識が活かせる仕事ありますからね。私の場合は、水素のトップサプライヤーであることが一番魅力に感じたところでした。それにあらゆる分野に携われることで、学生時代に学んだ機械系の知識も活かせると思えたのが、選考に応募したキッカケでした。So.Oさんは？</p>\n\t\t\t\t\t</li>\n\t\t\t\t\t<li data-aos=\"fade-up\" data-aos-duration=\"1600\" data-aos-once=\"true\">\n\t\t\t\t\t\t<p class=\"name\">So.O</p>\n\t\t\t\t\t\t<p class=\"txt\">私も水素が大きな理由でしたよ。もともとエネルギー分野に興味があったのもあり、水素でトップシェアを誇っている岩谷瓦斯は魅力的に映りましたね。</p>\n\t\t\t\t\t</li>\n\t\t\t\t\t<li data-aos=\"fade-up\" data-aos-duration=\"1600\" data-aos-once=\"true\">\n\t\t\t\t\t\t<p class=\"name\">S.K</p>\n\t\t\t\t\t\t<p class=\"txt\">ただ、私たちの就職活動の時期は、コロナ禍でインターンシップがなかったから、会社の雰囲気を掴むのは難しかった記憶があります。</p>\n\t\t\t\t\t</li>\n\t\t\t\t\t<li data-aos=\"fade-up\" data-aos-duration=\"1600\" data-aos-once=\"true\">\n\t\t\t\t\t\t<p class=\"name\">So.O</p>\n\t\t\t\t\t\t<p class=\"txt\">確かに。でも岩谷瓦斯は「ＷＥＢインターンシップ」という形で働く場所や雰囲気を見せていただけましたよね。そのおかげもあって、自分の働く姿をイメージしやすかったのも良かったです。S.Kさんはどこが魅力でしたか？</p>\n\t\t\t\t\t</li>\n\t\t\t\t\t<li data-aos=\"fade-up\" data-aos-duration=\"1600\" data-aos-once=\"true\">\n\t\t\t\t\t\t<p class=\"name\">S.K</p>\n\t\t\t\t\t\t<p class=\"txt\">私は「世の中に必要な人間となれ、世の中に必要なものこそ栄える」という企業理念に惹かれました。産業や人々の暮らしを支えるガスを扱っていることと直結しますし、個人的にも学生時代からずっと「人の役に立てる仕事、世の中から必要とされる会社で働きたい」と思っていましたから。</p>\n\t\t\t\t\t</li>\n\t\t\t\t\t<li data-aos=\"fade-up\" data-aos-duration=\"1600\" data-aos-once=\"true\">\n\t\t\t\t\t\t<p class=\"name\">R.O</p>\n\t\t\t\t\t\t<p class=\"txt\">その理念を表すように、コロナ禍でも業績が落ちていなかったですよね。社会に必要なものを扱っているから、安定感があるんだなと思えました。「ここならずっと長く働ける」というイメージを持てたのを覚えています。</p>\n\t\t\t\t\t</li>\n\t\t\t\t\t<li data-aos=\"fade-up\" data-aos-duration=\"1600\" data-aos-once=\"true\">\n\t\t\t\t\t\t<p class=\"name\">Su.O</p>\n\t\t\t\t\t\t<p class=\"txt\">それと労働環境面では、福利厚生が手厚いことも、社会人になって一人暮らしを始めた私にとっては安心でした。</p>\n\t\t\t\t\t</li>\n\t\t\t\t\t<li data-aos=\"fade-up\" data-aos-duration=\"1600\" data-aos-once=\"true\">\n\t\t\t\t\t\t<p class=\"name\">So.O</p>\n\t\t\t\t\t\t<p class=\"txt\">借り上げ社宅の家賃が実質月2,000円で住めるというのは、本当にすごくありがたいですよね。私は山口県から出てきて就職したので、特にその良さ・ありがたさを感じました。</p>\n\t\t\t\t\t</li>\n\t\t\t\t\t<li data-aos=\"fade-up\" data-aos-duration=\"1600\" data-aos-once=\"true\">\n\t\t\t\t\t\t<p class=\"name\">S.K</p>\n\t\t\t\t\t\t<p class=\"txt\">私も新潟県出身なので助かりました。こういった制度の充実や先輩たちの親しみやすさも含めて、社員のことをすごく大切に考えてくれる会社だというイメージがあります。働きやすい環境だろうなと実感したことも入社の決め手になりました。</p>\n\t\t\t\t\t</li>\n\t\t\t\t</ul>\n\t\t\t\t<div class=\"pht full\" data-aos=\"fade-up\" data-aos-duration=\"1600\" data-aos-once=\"true\"><img src=\"../work/img/crosstalk/cntnt01.jpg\" alt=\"若手社員座談会の様子\"></div>\n\t\t\t</div>\n\t\t\t\n\t\t\t\n\t\t\t<div class=\"theme_cntnt\">\n\t\t\t\t<div class=\"ttlarea\" data-aos=\"fade-up\" data-aos-duration=\"1600\" data-aos-once=\"true\">\n\t\t\t\t\t<p class=\"en\">Theme</p>\n\t\t\t\t\t<h2>入社後の働き方と成長をサポートする体制は？</h2>\n\t\t\t\t</div>\n\t\t\t\t<div class=\"lines\">\n\t\t\t\t\t<span></span><span></span><span></span>\n\t\t\t\t</div>\t\n\t\t\t\t<h3 class=\"answer\" data-aos=\"fade-up\" data-aos-duration=\"1600\" data-aos-once=\"true\">\n\t\t\t\t\t若手に裁量を与え、<br>挑戦を応援してくれる\n\t\t\t\t</h3>\n\t\t\t\t<ul class=\"talk\">\n\t\t\t\t\t<li data-aos=\"fade-up\" data-aos-duration=\"1600\" data-aos-once=\"true\">\n\t\t\t\t\t\t<p class=\"name\">S.K</p>\n\t\t\t\t\t\t<p class=\"txt\">私が働いている工場は、社員の約半数は20代と若い人が多いので、早い段階からいろんな仕事を任せてもらえています。分からないことがあったら、先輩や上司も丁寧に答えてくれますし、自己成長を実現しやすい環境だと感じています。他の部署はどうでしょう？</p>\n\t\t\t\t\t</li>\n\t\t\t\t\t<li data-aos=\"fade-up\" data-aos-duration=\"1600\" data-aos-once=\"true\">\n\t\t\t\t\t\t<p class=\"name\">So.O</p>\n\t\t\t\t\t\t<p class=\"txt\">私は、R.Oさんが所属している神戸液化水素荷役実証ターミナルで一年ちょっと勤務した後、今の「近畿エリア(生産担当)」に配属が変わりました。2つの部署を経験してみて感じるのは、「若手にまずチャレンジさせてみる」という企業風土が根付いているなということです。先輩や上司のサポートももちろんあるので、安心していろんなことに挑戦していけるなと。</p>\n\t\t\t\t\t</li>\n\t\t\t\t\t<li data-aos=\"fade-up\" data-aos-duration=\"1600\" data-aos-once=\"true\">\n\t\t\t\t\t\t<p class=\"name\">R.O</p>\n\t\t\t\t\t\t<p class=\"txt\">若手に大きな裁量を与えてくれますよね。責任のある仕事を任せてもらえることで、いろんな経験ができるというのは、私も良い環境だと感じています。あと、私は今の部署ではプラントの運転管理を任されているんですが、先輩社員はもちろん、グループ企業からの出向者の方にもいろいろな知識や経験を教えてもらえ、貴重な学びになっています。</p>\n\t\t\t\t\t</li>\n\t\t\t\t\t<li data-aos=\"fade-up\" data-aos-duration=\"1600\" data-aos-once=\"true\">\n\t\t\t\t\t\t<p class=\"name\">Su.O</p>\n\t\t\t\t\t\t<p class=\"txt\">私の所属する大阪ヘリウムセンターも皆さんと同じで、先輩や上司と話しやすく、若手でも提案や意見を言いやすい環境があると感じています。それと私は、今の担当業務だけでなく、配属直後に3つの部署をローテーションで回らせてもらって、工場全体の仕事を把握させてもらえました。全体像が見えたことで業務理解のスピードも上がりましたし、若手を育てようという想いが本当に強い会社なんだなと思っています。</p>\n\t\t\t\t\t</li>\n\t\t\t\t\t<li data-aos=\"fade-up\" data-aos-duration=\"1600\" data-aos-once=\"true\">\n\t\t\t\t\t\t<p class=\"name\">So.O</p>\n\t\t\t\t\t\t<p class=\"txt\">すごく共感です。実は、先輩から引き継ぐ形で若手勉強会を主催しているのですが、皆さん成長や育成への熱量はすごいですよ。月一回、いろんな部署の人が集まり、先輩から電気設備やガス設備、製造技術のことなどを学び合っていますから。たまに工場見学に行ったりもしているのですが、こういう学びの場を先輩が代々つくってくれているのはすごいですよね。</p>\n\t\t\t\t\t</li>\n\t\t\t\t\t<li data-aos=\"fade-up\" data-aos-duration=\"1600\" data-aos-once=\"true\">\n\t\t\t\t\t\t<p class=\"name\">Su.O</p>\n\t\t\t\t\t\t<p class=\"txt\">「意見が言いやすい」という部分では最近、上司がしていた高度な仕事を私が少しずつ担当するようになったんですが、そのキッカケは私が「やってみたい」と希望を伝えたことなんです。ちゃんと受け止めてくれていて嬉しいなと思いましたし、そのおかげで少しずつレベルアップできている実感も持てています。</p>\n\t\t\t\t\t</li>\n\t\t\t\t</ul>\n\t\t\t\t\n\t\t\t\t<div class=\"half_layout\">\n\t\t\t\t\t<ul class=\"talk\">\n\t\t\t\t\t\t<li data-aos=\"fade-up\" data-aos-duration=\"1600\" data-aos-once=\"true\">\n\t\t\t\t\t\t\t<p class=\"name\">S.K</p>\n\t\t\t\t\t\t\t<p class=\"txt\">「○○の資格を取りたい！」というスキルアップの希望も上司や先輩が聞いてくれて、取得する際には応援してくれますよね。私も高圧ガスやボイラー系の資格、危険物取扱者甲種などを取らせてもらいましたが、全てサポートしていただきました。</p>\n\t\t\t\t\t\t</li>\n\t\t\t\t\t\t<li data-aos=\"fade-up\" data-aos-duration=\"1600\" data-aos-once=\"true\">\n\t\t\t\t\t\t\t<p class=\"name\">R.O</p>\n\t\t\t\t\t\t\t<p class=\"txt\">私もいろいろなチャレンジをさせてもらっています。最近では、世の中に前例のなかった「液化水素に関する実証設備」のマニュアル作成を任せてもらいました。参考にできるものがない中でマニュアルをつくるのは大変でしたが、新たな知識と気づきを得られ、貴重な経験を積めたと思っています。積極的に挑戦させてもらえる環境に感謝です。</p>\n\t\t\t\t\t\t</li>\n\t\t\t\t\t</ul>\n\t\t\t\t\t<div class=\"pht half\" data-aos=\"fade-up\" data-aos-duration=\"1600\" data-aos-once=\"true\"><img src=\"../work/img/crosstalk/cntnt02.jpg\" alt=\"若手社員座談会の様子\"></div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t\t\n\t\t\t\n\t\t\t\n\t\t\t<div class=\"theme_cntnt\">\n\t\t\t\t<div class=\"ttlarea\" data-aos=\"fade-up\" data-aos-duration=\"1600\" data-aos-once=\"true\">\n\t\t\t\t\t<p class=\"en\">Theme</p>\n\t\t\t\t\t<h2>岩谷瓦斯で働く魅力は？</h2>\n\t\t\t\t</div>\n\t\t\t\t<div class=\"lines\">\n\t\t\t\t\t<span></span><span></span><span></span>\n\t\t\t\t</div>\t\n\t\t\t\t<h3 class=\"answer\" data-aos=\"fade-up\" data-aos-duration=\"1600\" data-aos-once=\"true\">\n\t\t\t\t\tさまざまなガスの提供を通じ、<br>社会を支えるやりがい\n\t\t\t\t</h3>\n\t\t\t\t\n\t\t\t\t<div class=\"half_layout mb\">\n\t\t\t\t\t<ul class=\"talk\">\n\t\t\t\t\t\t<li data-aos=\"fade-up\" data-aos-duration=\"1600\" data-aos-once=\"true\">\n\t\t\t\t\t\t\t<p class=\"name\">So.O</p>\n\t\t\t\t\t\t\t<p class=\"txt\">やっぱり一番は、私たちのつくったガスが産業を支えたり、暮らしの役に立ったりすることをイメージしながら働けるところが岩谷瓦斯で働く魅力ですよね。特に私は、ユーザー様の工場内で直接ガスを供給する設備を担当していて、メンテナンス等で現地に伺うことも多く、より手応えを実感できています。</p>\n\t\t\t\t\t\t</li>\n\t\t\t\t\t\t<li data-aos=\"fade-up\" data-aos-duration=\"1600\" data-aos-once=\"true\">\n\t\t\t\t\t\t\t<p class=\"name\">S.K</p>\n\t\t\t\t\t\t\t<p class=\"txt\">同じですね。私が製造に関わっている液化水素は、水素ステーションや水素エンジンでも使われており、クリーンなエネルギーとして環境にも貢献できている実感が持てるのは大きなやりがいです。少し違ったところでいうと、ロケット燃料にも使われていますから、ロケット打ち上げのニュースや映像を見ると「微力ながら、自分も宇宙分野を支えているんだ」と思えるのも醍醐味の一つだと思います。</p>\n\t\t\t\t\t\t</li>\n\t\t\t\t\t</ul>\n\t\t\t\t\t<div class=\"pht half\" data-aos=\"fade-up\" data-aos-duration=\"1600\" data-aos-once=\"true\"><img src=\"../work/img/crosstalk/n_cntnt02.jpg\" alt=\"若手社員座談会の様子\"></div>\n\t\t\t\t</div>\n\t\t\t\t<ul class=\"talk\">\n\t\t\t\t\t<li data-aos=\"fade-up\" data-aos-duration=\"1600\" data-aos-once=\"true\">\n\t\t\t\t\t\t<p class=\"name\">R.O</p>\n\t\t\t\t\t\t<p class=\"txt\">水素はS.Kさんの話のように、エネルギー業界の最先端で仕事をしているという実感が得られますよね。しかも、その重要な部分を若手の我々にも任せてもらえているのは、貴重かもしれません。</p>\n\t\t\t\t\t</li>\n\t\t\t\t\t<li data-aos=\"fade-up\" data-aos-duration=\"1600\" data-aos-once=\"true\">\n\t\t\t\t\t\t<p class=\"name\">So.O</p>\n\t\t\t\t\t\t<p class=\"txt\">3年目、4年目の若手であっても、ただ業務を遂行するだけではない大きなやりがいを得られる環境が、岩谷瓦斯で働く良さなのかもしれませんね。</p>\n\t\t\t\t\t</li>\n\t\t\t\t\t<li data-aos=\"fade-up\" data-aos-duration=\"1600\" data-aos-once=\"true\">\n\t\t\t\t\t\t<p class=\"name\">Su.O</p>\n\t\t\t\t\t\t<p class=\"txt\">私が関わっているヘリウムでも皆さんと同じように、社会に貢献していることを実感しています。入社前、岩谷瓦斯と言えば「水素のトップ企業」というイメージでしたが、液化ヘリウムがMRIなどの医療機器や大学の研究設備で使われていたり、ヘリウムガスは風船や気球などにも使われていたりなど、幅広い分野で役に立っていることを知り、自分の仕事に誇りを持つようになりました。</p>\n\t\t\t\t\t</li>\n\t\t\t\t\t<li data-aos=\"fade-up\" data-aos-duration=\"1600\" data-aos-once=\"true\">\n\t\t\t\t\t\t<p class=\"name\">R.O</p>\n\t\t\t\t\t\t<p class=\"txt\">会社全体として、さまざまなガスを取り扱い、そのどれもが日本の産業基盤の一端を担っているというやりがいは、まさに岩谷瓦斯だから味わえることですよね。それぞれ仕事内容は違いますが、どれも重要なことだと認識しながら働けるから、モチベーションを高く保てる人が多いんだと思います。</p>\n\t\t\t\t\t</li>\n\t\t\t\t\t<li data-aos=\"fade-up\" data-aos-duration=\"1600\" data-aos-once=\"true\">\n\t\t\t\t\t\t<p class=\"name\">S.K</p>\n\t\t\t\t\t\t<p class=\"txt\">目には見えないガスが、世の中の多くの人の生活の基盤を支えていると実感できることは、もっと頑張ろうという意欲につながりますからね。これから、岩谷瓦斯に興味を持っている人には、ガスの魅力をもっと知ってほしいですし、ガスで社会を支える喜びと感動を一緒に味わってほしいです。</p>\n\t\t\t\t\t</li>\n\t\t\t\t</ul>\n\t\t\t\t<div class=\"pht full\" data-aos=\"fade-up\" data-aos-duration=\"1600\" data-aos-once=\"true\"><img src=\"../work/img/crosstalk/cntnt03.jpg\" alt=\"若手社員座談会の様子\"></div>\n\t\t\t</div>\n\t\t</div>\n\t</div>\n\t\n\t\n</main>\n<!-------------- //#c-main -------------->\n\t\n\t\n\t\n\t\n<!-------------- #c-footer -------------->\n<footer class=\"c-footer\">\n\t<div class=\"c-inner\">\n\t\t<a href=\"http://www.iwatanigas.co.jp/index.html\" target=\"_blank\">コーポレートサイト</a>\n\t\t<a href=\"http://www.iwatanigas.co.jp/agreement/\" target=\"_blank\">プライバシーポリシー</a>\n\t</div>\n</footer>\n<!-------------- //#c-footer -------------->\n\t\n\n\n\n\n\t\n\n<script src=\"https://code.jquery.com/jquery-3.4.1.min.js\" integrity=\"sha256-CSXorXvZcTkaix6Yvo6HppcZGetbYMGWSFlBw8HfCJo=\" crossorigin=\"anonymous\"></script>\n<script type=\"text/javascript\" src=\"../common/js/common.js\"></script>\n<script type=\"text/javascript\" src=\"../common/js/jquery.matchHeight.js\"></script>\n<script src=\"https://unpkg.com/aos@2.3.1/dist/aos.js\"></script>\n<script>\n\tAOS.init();\n</script>\n<script>\n  $(function() {\n    $('.mht').matchHeight();\n  });\n</script>\n\t\n\n</body>\n</html>","finalUrl":"https://www.iwatanigas.co.jp/recruit/work/crosstalk.html","rendered":false,"_cachedAt":"2026-06-23T18:20:58.792Z"}