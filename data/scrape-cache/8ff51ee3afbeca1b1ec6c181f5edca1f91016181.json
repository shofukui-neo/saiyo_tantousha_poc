  <div id=\"breadcrumb\">\r\n        <div class=\"inner1\">\r\n            <ul class=\"cf\">\r\n                <li><a href=\"../\">ホーム</a></li>\r\n                <li>社長メッセージ</li>\r\n            </ul>\r\n        </div>\r\n    </div>\r\n\r\n    <section id=\"message\">\r\n        <div class=\"inner1\">\r\n            <div class=\"message_body\">\r\n                <figure><img src=\"images/message_image.png\" alt=\"\"></figure>\r\n                <dl class=\"message_name\">\r\n                    <dt><span>TADAHIRO NAKAYA</span>中谷 忠宏</dt>\r\n                    <dd>株式会社旭広告社<br class=\"br_768_none\"><span>代表取締役社長</span></dd>\r\n                </dl>\r\n\r\n                <h2>義は利の本なり</h2>\r\n                <p>私たちのビジネスである広告は、地域社会やお客様を元気にし、発展させる仕事です。<br>\r\n                    その仕事に誇りをもって、お客様のため、世の中のために尽くせば、<br class=\"br_768_none\">必ず「利」となって戻り、私たちの幸せにつながると考えています。</p>\r\n                <p>だから、私たちは、人を大切にしています。</p>\r\n                <p>社員が輝けば、会社も輝き、お客様を輝かせることができるからです。</p>\r\n                <p>自分が輝くだけでなく、他人をも輝かせながら、<br class=\"br_768_none\">自分たちの幸せを、自分たちの力で勝ちとっていきましょう。</p>\r\n\r\n                <h3>インタビュー動画</h3>\r\n                <div class=\"movie_box_wrapper\">\r\n                    <div class=\"movie_box\">\r\n                        <iframe width=\"560\" height=\"315\" src=\"https://www.youtube.com/embed/8cbfkdiZQO0\" title=\"YouTube video player\" frameborder=\"0\" allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture\" allowfullscreen></iframe>\r\n                    </div>\r\n                </div>\r\n                <ol class=\"movie_index\">\r\n                    <li class=\"cf\">\r\n                        <div class=\"movie_title\"><span>Chapter 01.</span>創業からこれまでの会社について</div>\r\n                        <div class=\"movie_btn\"><a href=\"https://www.youtube.com/watch?v=8cbfkdiZQO0\" target=\"_blank\">この回答を観る</a></div>\r\n                    </li>\r\n                    <li class=\"cf\">\r\n                        <div class=\"movie_title\"><span>Chapter 02.</span>旭広告社の事業について</div>\r\n                        <div class=\"movie_btn\"><a href=\"https://www.youtube.com/watch?v=8cbfkdiZQO0&t=98s\" target=\"_blank\">この回答を観る</a></div>\r\n                    </li>\r\n                    <li class=\"cf\">\r\n                        <div class=\"movie_title\"><span>Chapter 03.</span>企業理念とそこに込められた想い</div>\r\n                        <div class=\"movie_btn\"><a href=\"https://www.youtube.com/watch?v=8cbfkdiZQO0&t=155s\" target=\"_blank\">この回答を観る</a></div>\r\n                    </li>\r\n                    <li class=\"cf\">\r\n                        <div class=\"movie_title\"><span>Chapter 04.</span>旭広告社ってどんな会社ですか</div>\r\n                        <div class=\"movie_btn\"><a href=\"https://www.youtube.com/watch?v=8cbfkdiZQO0&t=214s\" target=\"_blank\">この回答を観る</a></div>\r\n                    </li>\r\n                    <li class=\"cf\">\r\n                        <div class=\"movie_title\"><span>Chapter 05.</span>社員に対する思い、期待すること</div>\r\n                        <div class=\"movie_btn\"><a href=\"https://www.youtube.com/watch?v=8cbfkdiZQO0&t=261s\" target=\"_blank\">この回答を観る</a></div>\r\n                    </li>\r\n                    <li class=\"cf\">\r\n                        <div class=\"movie_title\"><span>Chapter 06.</span>旭広告社が目指す姿、将来のビジョン</div>\r\n                        <div class=\"movie_btn\"><a href=\"https://www.youtube.com/watch?v=8cbfkdiZQO0&t=306s\" target=\"_blank\">この回答を観る</a></div>\r\n                    </li>\r\n                    <li class=\"cf\">\r\n                        <div class=\"movie_title\"><span>Chapter 07.</span>働く環境について取り組んでいること</div>\r\n                        <div class=\"movie_btn\"><a href=\"https://www.youtube.com/watch?v=8cbfkdiZQO0&t=370s\" target=\"_blank\">この回答を観る</a></div>\r\n                    </li>\r\n                    <li class=\"cf\">\r\n                        <div class=\"movie_title\"><span>Chapter 08.</span>旭広告社が求める人物像、就活中のみなさんへメッセージ</div>\r\n                        <div class=\"movie_btn\"><a href=\"https://www.youtube.com/watch?v=8cbfkdiZQO0&t=469s\" target=\"_blank\">この回答を観る</a></div>\r\n                    </li>\r\n                </ol>\r\n            </div>\r\n        </div>\r\n    </section>\r\n\r\n    <section id=\"foot_recruit\">\r\n        <div class=\"inner1 cf\">\r\n            <h2>採用情報</h2>\r\n            <ul class=\"cf\">\r\n                <li><a href=\"../recruit/#tab1\">\r\n                        <figure><img src=\"../images/foot_recruit2.png\" alt=\"新卒採用情報\"></figure>\r\n                        <p>新卒採用情報</p>\r\n                    </a></li>\r\n                <li><a href=\"../recruit/#tab2\">\r\n                        <figure><img src=\"../images/foot_recruit3.png\" alt=\"中途採用情報\"></figure>\r\n                        <p>中途採用情報</p>\r\n                    </a></li>\r\n            </ul>\r\n        </div>\r\n    </section>\r\n\r\n    <footer id=\"footer\">\r\n        <div class=\"inner1 cf\">\r\n            <div class=\"footer_txt\">\r\n                <p><a href=\"../\"><img src=\"../images/footer_logo.png\" alt=\"株式会社旭広告社\"></a></p>\r\n                <p class=\"p1\">〒231-0014　神奈川県横浜市中区常盤町2-19<br>TEL: 045-681-2831</p>\r\n            </div>\r\n            <ul class=\"ul1\">\r\n                <li><a href=\"../message/\">社長メッセージ</a></li>\r\n                <li><a href=\"../interview/\">社員インタビュー</a></li>\r\n                <li><a href=\"../job/\">旭広告社の仕事を知る</a></li>\r\n                <li><a href=\"../data/\">DATAで見る</a></li>\r\n            </ul>\r\n\r\n            <ul class=\"ul1\">\r\n                <li><a href=\"../welfare/\">福利厚生</a></li>\r\n                <li><a href=\"../environment/\">職場環境</a></li>\r\n                <li><a href=\"../recruit/#tab1\">新卒採用情報</a></li>\r\n                <li><a href=\"../recruit/#tab1\">中途採用情報</a></li>\r\n            </ul>\r\n\r\n            <ul class=\"ul2\">\r\n                <li><a href=\"https://asahi-ad.co.jp/\" target=\"_blank\"><i