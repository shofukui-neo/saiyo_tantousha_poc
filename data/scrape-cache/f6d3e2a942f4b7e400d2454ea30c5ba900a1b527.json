***************************/\r\nfunction checklogin(para1, para2) {\r\n\r\n\t//値の取得\r\n\tvar $input_name = $(para1).val();\t//GET NICKNAME\r\n\tvar $input_pass = $(para2).val();\t//GET PASS\r\n\r\n\t//nicknameチェック\r\n\tif($input_name == \"\"){\r\n\t\talert(\"名前を入力してください\");\r\n\t\t$(para1).focus();\r\n     \t\t$(para1).select();\r\n\t\treturn false;\r\n\t}else{\r\n\t\tif(checkZenkaku($input_name) == false){\r\n\t\t\t$(para1).focus();\r\n        \t\t$(para1).select();\r\n        \t\t//警告コメント\r\n        \t\talert(\"半角英数字を入力してください\")\r\n        \t\treturn false;\r\n\t\t}\r\n\t}\r\n\r\n\t//PASSチェック\r\n\tif($input_pass == \"\"){\r\n\t\talert(\"パスワードを入力してください\");\r\n\t\t$(para2).focus();\r\n     \t\t$(para2).select();\r\n\t\treturn false;\r\n\t}else if($input_pass.length < 6){\r\n\t\t$(para2).focus();\r\n     \t\t$(para2).select();\r\n\t\talert(\"6文字以上入力してください\");\r\n\t\treturn false;\r\n\t}else if(checkZenkaku($input_pass) == false){\r\n\t\t$(para2).focus();\r\n        \t$(para2).select();\r\n        \t//警告コメント\r\n        \talert(\"半角英数字を入力してください\")\r\n        \treturn false;\r\n\t}\r\n\r\n\treturn true;\r\n\r\n\t//全角文字列の判別\r\n\tfunction checkZenkaku(msg){\r\n\t    \tvar i,msg2,msg3;\r\n\t    \tvar char_length = (\"あ\".length);\r\n\t    \t//スペースを取り除く\r\n\t    \tmsg2 = msg.replace(/ /g,\"\");\r\n\t    \tif(msg2.length == 0){\r\n\t        \treturn false;\r\n\t    \t}\r\n\t    \tfor(i=0;i<msg2.length;i=i+char_length){\r\n\t        \tmsg3 = msg2.charAt(i);\r\n\t        \tif(msg3 >= \"　\" && msg3 <= \"～\"){\r\n\t            \treturn false;\r\n\t        \t}\r\n\t    \t}\r\n\t}\r\n}\r\n</script>\r\n<div id=\"pop1\" class=\"popBox\">\r\n\t<div class=\"popup\">\r\n\t\t<p class=\"title\">新規アカウント作成</p>\r\n\t\t<p>普段ご利用の外部IDでも新規登録することができます。</p>\r\n\t\t<ul class=\"ulLink clearfix\">\r\n\t\t\t<div id=\"wpg-login\"><li><a class=\"hover\" href=\"https://www.haruya.co.jp/twitter/login/?redirect_to=https%3A%2F%2Fwww.haruya.co.jp%2Fwp-admin%2Fprofile.php&amp;_wp_gianism_nonce=c85cd476cf\"><img src=\"https://www.haruya.co.jp/wp-content/themes/haruya/img/common/sp_link03.jpg\" alt=\"Twitterではじめる\"></a></li></div><!--\r\n\t\t\t<li><a href=\"#\"><img src=\"https://www.haruya.co.jp/wp-content/themes/haruya/img/common/pop_link02.jpg\" alt=\"f Facebookではじめる\"></a></li>\r\n\t\t\t<li><a href=\"#\"><img src=\"https://www.haruya.co.jp/wp-content/themes/haruya/img/common/pop_link03.jpg\" alt=\"Twitterではじめる\"></a></li>\r\n-->\r\n\t\t</ul>\r\n\t\t<p>\r\n\t\t\tログインを行うことにより、パソコンでクリップした記事を、スマートフォンで見ることも可能です。<br />\r\n\t\t\t（※）クリップとは、興味のある記事を保存しておける機能です。登録した記事はあとから簡単に参照できます。<br />\r\n\t\t\t記事をクリップするには、各記事に表示されている「クリップ」ボタンをクリックします。\r\n\t\t</p>\r\n\t\t<form action=\"https://www.haruya.co.jp\" method=\"post\" id=\"loginform3\" class=\"mailForm\">\r\n\r\n\t\t\t<dl class=\"clearfix\">\r\n\t\t\t\t<dt>ニックネーム<br>\r\n\t\t\t\t\t<span>（半角英数字）</span></dt>\r\n\t\t\t\t<dd>\r\n\t\t\t\t\t<input type=\"text\" value=\"\" name=\"nickname\">\r\n\t\t\t\t</dd>\r\n\t\t\t\t<dt>パスワード<br>\r\n\t\t\t\t\t<span>（半角英数字6文字以上）</span></dt>\r\n\t\t\t\t<dd>\r\n\t\t\t\t\t<input type=\"text\" value=\"\" name=\"newpass\">\r\n\t\t\t\t</dd>\r\n\t\t\t</dl>\r\n\t\t\t<ul class=\"submit\">\r\n\t\t\t\t<li>\r\n\t\t\t\t\t<input type=\"image\" src=\"https://www.haruya.co.jp/wp-content/themes/haruya/img/common/pop_link03.jpg\" alt=\"アカウントを作成する\" value=\"アカウントを作成する\" name=\"__submit__\" onClick=\"return checklogin('#loginform3 [name=nickname]','#loginform3 [name=newpass]');\">\r\n\t\t\t\t</li>\r\n\t\t\t</ul>\r\n\t\t</form>\r\n\t\t<p class=\"btmP\">ニックネーム・パスワードを紛失した場合、新規登録して新しいアカウントをご利用ください。</p>\r\n\t</div>\r\n</div>\r\n\r\n\t\t\t</div>\n\t\t</section>\n\t</section>\n\t<div style=\"visibility: hidden; position: absolute; top: 0px;\">S</div>\n</article>\n\t\t\t\t<div id=\"fb-root\"></div>\n\t\t\t\t<script type=\"text/javascript\">\n\t\twindow.fbAsyncInit = function() {\n\t\t\t\t\t\tFB._https = true;\n\t\t\t\t\t\tFB.init({\n\t\t\t\tappId: '579776752148495',\n\t\t\t\tcookie: true, \n\t\t\t\txfbml: true,\n\t\t\t\toauth: tru