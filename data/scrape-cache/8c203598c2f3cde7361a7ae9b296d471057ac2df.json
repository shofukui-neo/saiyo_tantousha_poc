vascript:void(0)\"><span>メニューを開く</span></a></p>\n            <ul>\n                <li class=\"parent\"><a href=\"../index.html\" class=\"pcmenu\">ホーム</a><a href=\"javascript:void(0)\" class=\"spmenu\">ホーム</a>\n\t\t\t\t\t<!-- home -->\n\t\t\t\t\t<ul class=\"submenu\">\n\t\t\t\t\t\t<li><a href=\"../index.html\" class=\"spmenu\">トップページ</a></li>\n                        <li><a href=\"../privacy/index.html\">プライバシーポリシー</a></li>\n                    </ul>\n\t\t\t\t\t<!-- /home -->\n\t\t\t\t</li>\n                <li class=\"parent\"><a href=\"../about/index.html\" class=\"pcmenu\">会社紹介</a><a href=\"javascript:void(0)\" class=\"spmenu\">会社紹介</a>\n                    <!-- about -->\n                    <ul class=\"submenu\">\n\t\t\t\t\t\t<li><a href=\"../about/index.html\" class=\"spmenu\">会社紹介TOP</a></li>\n                        <li><a href=\"../about/appeal/index.html\">サンタクシーとは？</a></li>\n                        <li><a href=\"../about/fine/index.html\">サンタクシーの魅力</a></li>\n                        <li><a href=\"../about/voice/index.html\">現役社員の声</a></li>\n                    </ul>\n                    <!-- /about -->\n                </li>\n                <li class=\"parent\"><a href=\"../driver/index.html\" class=\"pcmenu\">働き方色々</a><a href=\"javascript:void(0)\" class=\"spmenu\">働き方色々</a>\n\t\t\t\t\t<ul class=\"submenu\">\n\t\t\t\t\t\t<li><a href=\"../driver/index.html\" class=\"spmenu\">働き方色々TOP</a></li>\n\t\t\t\t\t\t<li><a href=\"../experienced/index.html\">ドライバー経験者</a></li>\n\t\t\t\t\t\t<li><a href=\"../inexperienced/index.html\">未経験者</a></li>\n\t\t\t\t\t\t<li><a href=\"../woman/index.html\">女性ドライバー</a></li>\n\t\t\t\t\t\t<li><a href=\"../senior/index.html\">シニアドライバー</a></li>\n\t\t\t\t\t</ul>\n\t\t\t\t</li>\n                <li class=\"parent\"><a href=\"../require/index.html\">募集要項・よくある質問</a></li>\n                <li class=\"parent\"><a href=\"../entry/index.html\">エントリー</a></li>\n                <li class=\"parent\"><a href=\"../../index.html\">コーポレートサイト</a></li>\n            </ul>\n            <!-- /.Nav -->\n        </nav>\n\t\t\t<p id=\"headinsta\"><a href=\"https://www.instagram.com/yokohama_suntaxi/\" title=\"サンタクシーのインスタグラムへ\" target=\"_blank\"><img src=\"../images/common/logo_instagram.png\" alt=\"サンタクシーのインスタグラムへ\"/></a></p>\n        </div>\n      <!-- /#header-->\n    </div>\n    <div class=\"intro\">\n        <div class=\"container\">\n            <h1>ドライバー経験者</h1>\n        </div>\n        <!-- /#intro-->\n    </div>\n    <div id=\"panlist\">\n        <div class=\"container\">\n            <p id=\"pan\"><a href=\"../index.html\">ホーム</a><em>&gt;</em><a href=\"../driver/index.html\">働き方色々</a><em>&gt;</em>ドライバー経験者</p>\n        </div>\n        <!--  /#panlist-->\n    </div>\n    <div id=\"contents\">\n        <div class=\"area_01\">\n            <div class=\"container\">\n                <h2>サンタクシーのここが魅力</h2>\n                <ul class=\"apl_h4_list\">\n                    <li class=\"trnklnk\">\n                        <a href=\"#appeal01\">\n                            <p class=\"apl_h_img\"><img src=\"../images/experienced/img_apl_01.jpg\" class=\"imgMax\" alt=\"画像：自分のペースで仕事ができるができる\"/></p>\n                            <p class=\"apl_h_capt\">自分のペースで仕事ができる</p>\n                        </a>\n                    </li>\n                    <li class=\"trnklnk\">\n                        <a href=\"#appeal02\">\n                            <p class=\"apl_h_img\"><img src=\"../images/experienced/img_apl_02.jpg\" class=\"imgMax\" alt=\"画像：しっかり稼げる\"/></p>\n                            <p class=\"apl_h_capt\">しっかり稼げる</p>\n                        </a>\n                    </li>\n                    <li class=\"trnklnk\">\n                        <a href=\"#appeal03\">\n                            <p class=\"apl_h_img\"><img src=\"../images/experienced/img_apl_03.jpg\" class=\"imgMax\" alt=\"画像：安心・充実の車両設備\"/></p>\n                            <p class=\"apl_h_capt\">安心・充実の車両設備</p>\n                        </a>\n                    </li>\n                    <li class=\"trnklnk\">\n                        <a href=\"#appeal04\">\n                            <p class=\"apl_h_img\"><img src=\"../images/experienced/img_apl_04.jpg\" class=\"imgMax\" alt=\"画像：プライベートが充実\"/></p>\n                            <p class=\"apl_h_capt\">プライベートが充実</p>\n                        </a>\n                    </li>\n                </ul>\n            </div>\n        </div>\n        <div class=\"area_apl\" id=\"appeal01\">\n            <div class=\"container\">\n              <h2>自分のペースで仕事ができる</h2>\n                <p class=\"bmbspc\">タクシードライバーは休みが少なく、収入も不安定と思われているかもしれませんが、そんなことはありません。<br>\n                    タクシーの勤務形態は大きく分けて「隔日勤務」「昼日勤」「夜日勤」がありますが、サンタクシーでは働く社員一人ひとりの事情に合わせて柔軟な勤務体制を取っています。</p>\n                <ul class=\"kintai_list\">\n                    <li class=\"kin_kj trnklnk\">\n                        <a href=\"#kinkei_kakukin\">\n                            <p class=\"kintai_img\"><img src=\"../images/common/img_kin01.png\" class=\"imgMax\" alt=\"画像：隔日勤務\"/></p>\n                            <h3>隔日勤務</h3>\n                            <p>1日働いて1日休み。プライベートが充実！</p>\n                        </a>\n                    </li>\n                    <li class=\"kin_nk trnklnk\">\n                        <a href=\"#kinkei_nikin\">\n                            <p class=\"kintai_img\"><img src=\"../images/common/img_kin02.png\" class=\"imgMax\" alt=\"画像：昼日勤\"/></p>\n                            <h3>昼日勤</h3>\n                            <p>朝から夕方までの勤務。日曜の休みもOK！</p>\n                        </a>\n                    </li>\n                    <li class=\"kin_yk trnklnk\">\n                        <a href=\"#kinkei_yakin\">\n                            <p class=\"kintai_img\"><img src=\"../images/common/img_kin03.png\" class=\"imgMax\" alt=\"画像：夜日勤\"/></p>\n                            <h3>夜日勤</h3>\n                            <p>夜間の勤務。しっかり稼ぎたい方におすすめ！</p>\n                        </a>\n                    </li>\n                </ul>\n                <div class=\"kinkei_box\" id=\"kinkei_kakukin\">\n                    <h3>隔日勤務</h3>\n                    <p class=\"pCtsL bmbspc\">1回の勤務で2日分の仕事を行い、翌日は必ず明け番（休養日）になる勤務形態です。<br>\n                        オンとオフのメリハリがあって時間が使いやすい勤務の仕方ですので、これが魅力でタクシードライバーに転職した、という社員もいます。</p>\n                    <h4>勤務シフト例</h4>\n                    <table class=\"tbl_shift\" summary=\"隔日勤務の勤務シフト例\">\n                        <thead>\n                            <tr>\n                                <th scope=\"col\">日</th>\n                                <th scope=\"col\">月</th>\n                                <th scope=\"col\">火</th>\n                                <th scope=\"col\">水</th>\n                                <th scope=\"col\">木</th>\n                                <th scope=\"col\">金</th>\n                                <th scope=\"col\">土</th>\n                            </tr>\n                        </thead>\n                        <tbody>\n                            <tr>\n                                <td>勤務<i class=\"fas fa-taxi\"></i></td>\n                                <td class=\"ake\">明け</td>\n                                <td>勤務<i class=\"fas fa-taxi\"></i></td>\n                                <td class=\"ake\">明け</td>\n                                <td>勤務<i class=\"fas fa-taxi\"></i></td>\n                                <td class=\"ake\">明け</td>\n                                <td class=\"kou\">公休</td>\n                            </tr>\n                            <tr>\n                                <td>勤務<i class=\"fas fa-taxi\"></i></td>\n                                <td class=\"ake\">明け</td>\n                                <td>勤務<i class=\"fas fa-taxi\"></i></td>\n                                <td class=\"ake\">明け</td>\n                                <td>勤務<i class=\"fas fa-taxi\"></i></td>\n                                <td class=\"ake\">明け</td>\n                                <td class=\"kou\">公休</td>\n                            </tr>\n                            <tr>\n                                <td class=\"kou\">公休</td>\n                                <td>勤務<i class=\"fas fa-taxi\"></i></td>\n                                <td class=\"ake\">明け</td>\n                                <td>勤務<i class=\"fas fa-taxi\"></i></td>\n                                <td class=\"ake\">明け</td>\n                                <td>勤務<i class=\"fas fa-taxi\"></i></td>\n                                <td class=\"ake\">明け</td>\n                            </tr>\n                            <tr>\n                                <td class=\"kou\">公休</td>\n                                <td>勤務<i class=\"fas fa-taxi\"></i></td>\n                                <td class=\"ake\">明け</td>\n                                <td>勤務<i class=\"fas fa-taxi\"></i></td>\n                                <td class=\"ake\">明け</td>\n                                <td>勤務<i class=\"fas fa-taxi\"></i></td>\n                                <td class=\"ake\">明け</td>\n                            </tr>\n                            <tr>\n                                <td class=\"kou\">公休</td>\n                                <td class=\"kou\">公休</td>\n                                <td>勤務<i class=\"fas fa-taxi\"></i></td>\n                                <td></td>\n                                <td></td>\n                                <td></td>\n                                <td></td>\n                            </tr>\n                        </tbody>\n                    </table>\n                    <h4>1日の流れ（例）</h4>\n                    <table class=\"tbl_jobflow\" summary=\"隔日勤務の1日の流れ(例)\">\n                        <thead>\n                            <tr>\n                                <th scope=\"col\">時刻</th>\n                                <th scope=\"col\">内容</th>\n                            </tr>\n                        </thead>\n                        <tbody>\n                            <tr>\n                                <th scope=\"row\">7:30</th>\n                                <td>出勤、点呼</td>\n                            </tr>\n                            <tr>\n                                <th scope=\"row\">8:00</th>\n                                <td>営業所から出庫</td>\n                            </tr>\n\t\t\t\t\t\t\t<tr>\n                                <th scope=\"row\">8:00～12:00</th>\n                                <td>乗務</td>\n                            </tr>\n                            <tr>\n                                <th scope=\"row\">12:00～13:00</th>\n                                <td>休憩</td>\n                            </tr>\n\t\t\t\t\t\t\t<tr>\n                                <th scope=\"row\">13:00～16:30</th>\n                                <td>乗務</td>\n                            </tr>\n                            <tr>\n                                <th scope=\"row\">16:30～17:30</th>\n                                <td>休憩</td>\n                            </tr>\n\t\t\t\t\t\t\t<tr>\n                                <th scope=\"row\">17:30～21:30</th>\n                                <td>乗務</td>\n                            </tr>\n                            <tr>\n                                <th scope=\"row\">21:30～22:30</th>\n                                <td>休憩</td>\n                            </tr>\n\t\t\t\t\t\t\t<tr>\n                                <th scope=\"row\">22:30～1:00</th>\n                                <td>乗務</td>\n                            </tr>\n                            <tr>\n                                <th scope=\"row\">1:00</th>\n                                <td>営業所に帰庫</td>\n                            </tr>\n                            <tr>\n                                <th scope=\"row\">1:30</th>\n                                <td>点検、清掃、退勤</td>\n                            </tr>\n                        </tbody>\n                    </table>\n                    <div class=\"kinkei_supple\">\n                        <p class=\"caution03\"><span>※</span>上記の勤務シフト、1日の流れは一例です。出勤曜日はシフトにより異なります。</p>\n                        <p class=\"caution03\"><span>※</span>出勤日や勤務時間についてはご希望に応じて柔軟に対応いたします。</p>\n                    </div>\n                    <!-- /.kinkei_box -->\n                </div>\n                <div class=\"kinkei_box\" id=\"kinkei_nikin\">\n                    <h3>昼日勤</h3>\n                    <p class=\"pCtsL bmbspc\">朝から夕方まで乗務する日中専門の勤務形態です。<br>\n                        昼間の時間帯なので病院や施設に向かう、ビジネスマンなどがお客様となります。<br>\n                        横浜は昼人口も多いので安定して収入が得られます。</p>\n                    <h4>勤務シフト例</h4>\n                    <table class=\"tbl_shift\" summary=\"昼日勤の勤務シフト例\">\n                        <thead>\n                            <tr>\n                                <th scope=\"col\">日</th>\n                                <th scope=\"col\">月</th>\n                                <th scope=\"col\">火</th>\n                                <th scope=\"col\">水</th>\n                                <th scope=\"col\">木</th>\n                                <th scope=\"col\">金</th>\n                                <th scope=\"col\">土</th>\n                            </tr>\n                        </thead>\n                        <tbody>\n                            <tr>\n                                <td class=\"kou\">公休</td>\n                                <td>勤務<i class=\"fas fa-taxi\"></i></td>\n                                <td>勤務<i class=\"fas fa-taxi\"></i></td>\n                                <td>勤務<i class=\"fas fa-taxi\"></i></td>\n                                <td>勤務<i class=\"fas fa-taxi\"></i></td>\n                                <td>勤務<i class=\"fas fa-taxi\"></i></td>\n                                <td>勤務<i class=\"fas fa-taxi\"></i></td>\n                            </tr>\n                            <tr>\n                                <td class=\"kou\">公休</td>\n                                <td>勤務<i class=\"fas fa-taxi\"></i></td>\n                                <td>勤務<i class=\"fas fa-taxi\"></i></td>\n                                <td>勤務<i class=\"fas fa-taxi\"></i></td>\n                                <td>勤務<i class=\"fas fa-taxi\"></i></td>\n                                <td>勤務<i class=\"fas fa-taxi\"></i></td>\n                                <td class=\"kou\">公休</td>\n                            </tr>\n                            <tr>\n                                <td class=\"kou\">公休</td>\n                                <td>勤務<i class=\"fas fa-taxi\"></i></td>\n                                <td>勤務<i class=\"fas fa-taxi\"></i></td>\n                                <td>勤務<i class=\"fas fa-taxi\"></i></td>\n                                <td>勤務<i class=\"fas fa-taxi\"></i></td>\n                                <td>勤務<i class=\"fas fa-taxi\"></i></td>\n                                <td>勤務<i class=\"fas fa-taxi\"></i></td>\n                            </tr>\n                            <tr>\n                                <td class=\"kou\">公休</td>\n                                <td>勤務<i class=\"fas fa-taxi\"></i></td>\n                                <td>勤務<i class=\"fas fa-taxi\"></i></td>\n                                <td>勤務<i class=\"fas fa-taxi\"></i></td>\n                                <td>勤務<i class=\"fas fa-taxi\"></i></td>\n                                <td>勤務<i class=\"fas fa-taxi\"></i></td>\n                                <td class=\"kou\">公休</td>\n                            </tr>\n                            <tr>\n                                <td class=\"kou\">公休</td>\n                                <td>勤務<i class=\"fas fa-taxi\"></i></td>\n                                <td>勤務<i class=\"fas fa-taxi\"></i></td>\n                                <td></td>\n                                <td></td>\n                                <td></td>\n                                <td></td>\n                            </tr>\n                        </tbody>\n                    </table>\n                    <h4>1日の流れ（例）</h4>\n                    <table class=\"tbl_jobflow\" summary=\"昼日勤の1日の流れ(例)\">\n                        <thead>\n                            <tr>\n                                <th scope=\"col\">時刻</th>\n                                <th scope=\"col\">内容</th>\n                            </tr>\n                        </thead>\n                        <tbody>\n                            <tr>\n                                <th scope=\"row\">7:30</th>\n                                <td>出勤、点呼</td>\n                            </tr>\n                            <tr>\n                                <th scope=\"row\">8:00</th>\n                                <td>営業所から出庫</td>\n                            </tr>\n                            <tr>\n                                <th scope=\"row\">8:00～12:00</th>\n                                <td>乗務</td>\n                            </tr>\n                            <tr>\n                                <th scope=\"row\">12:00～13:00</th>\n                                <td>休憩</td>\n                            </tr>\n                            <tr>\n                                <th scope=\"row\">13:00～15:30</th>\n                                <td>乗務</td>\n                            </tr>\n                            <tr>\n                                <th scope=\"row\">15:30～16:00</th>\n                                <td>休憩</td>\n                            </tr>\n                            <tr>\n                                <th scope=\"row\">16:00～17:00</th>\n                                <td>乗務</td>\n                            </tr>\n                            <tr>\n                                <th scope=\"row\">17:00</th>\n                                <td>営業所に帰庫</td>\n                            </tr>\n                            <tr>\n                                <th scope=\"row\">17:30</th>\n                                <td>点検、清掃、退勤</td>\n                            </tr>\n                        </tbody>\n                    </table>\n                    <div class=\"kinkei_supple\">\n                        <p class=\"caution03\"><span>※</span>上記の勤務シフト、1日の流れは一例です。出勤曜日はシフトにより異なります。</p>\n                        <p class=\"caution03\"><span>※</span>出勤日や勤務時間についてはご希望に応じて柔軟に対応いたします。</p>\n                    </div>\n                    <!-- /.kinkei_box -->\n                </div>\n                <div class=\"kinkei_box\" id=\"kinkei_yakin\">\n                    <h3>夜日勤</h3>\n                    <p class=\"pCtsL bmbspc\">夜間から翌朝まで乗務する勤務形態です。<br>\n                        公共交通機関が終わる時間帯になると長距離利用のお客様も増えるため、高収入が期待できます。</p>\n                    <h4>勤務シフト例</h4>\n                    <table class=\"tbl_shift\" summary=\"夜日勤の勤務シフト例\">\n                        <thead>\n                            <tr>\n                                <th scope=\"col\">日</th>\n                                <th scope=\"col\">月</th>\n                                <th scope=\"col\">火</th>\n                                <th scope=\"col\">水</th>\n                                <th scope=\"col\">木</th>\n                                <th scope=\"col\">金</th>\n                                <th scope=\"col\">土</th>\n                            </tr>\n                        </thead>\n                        <tbody>\n                            <tr>\n                                <td>勤務<i class=\"fas fa-taxi\"></i></td>\n                                <td>勤務<i class=\"fas fa-taxi\"></i></td>\n                                <td>勤務<i class=\"fas fa-taxi\"></i></td>\n                                <td>勤務<i class=\"fas fa-taxi\"></i></td>\n                                <td class=\"kou\">公休</td>\n                                <td>勤務<i class=\"fas fa-taxi\"></i></td>\n                                <td>勤務<i class=\"fas fa-taxi\"></i></td>\n            