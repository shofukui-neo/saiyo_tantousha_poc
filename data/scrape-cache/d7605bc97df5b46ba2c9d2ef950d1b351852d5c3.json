none;visibility:hidden\"></iframe></noscript>\n    <!-- End Google Tag Manager (noscript) -->\n    <header>\n      <p><a href=\"/\"><img src=\"/assets/img/common/logo.svg\" alt=\"Telecom Square\"></a></p>\n      <button data-toggle=\"menu\"><span>Menu</span></button>\n    </header>\n    <nav>\n      <ul class=\"nav\">\n        <li><a href=\"/\">Top</a></li>\n        <li>\n          <button data-toggle=\"accordion\">\n            <span>About us</span>\n            <img src=\"/assets/img/common/ico-arrow.svg\" alt=\"\">\n          </button>\n          <ul>\n            <li><a href=\"/aboutus/\">テレコムスクエアについて</a></li>\n            <li><a href=\"/aboutus/company/\">会社概要</a></li>\n            <li><a href=\"/aboutus/history/\">沿革</a></li>\n            <li><a href=\"/aboutus/ge_actionplan/\">一般事業主行動計画</a></li>\n            <li><a href=\"/aboutus/eruboshi_certification/\">女性活躍推進への取組み</a></li>\n          </ul>\n        </li>\n        <li>\n          <button data-toggle=\"accordion\">\n            <span>Service</span>\n            <img src=\"/assets/img/common/ico-arrow.svg\" alt=\"\"></button>\n          <ul>\n            <li><a href=\"/solution-service/\">サービス一覧</a></li>\n            <li><a href=\"/solution-service/#mobile-communications\">モバイル通信サービス</a></li>\n            <li><a href=\"/solution-service/#business\">モバイル通信サービスWi-Ho!</a></li>\n            <li><a href=\"/solution-service/#sharing\">バイクシェアサービス</a></li>\n            <li><a href=\"https://www.telecomsquare.net/media/?utm_source=corporate&utm_medium=referral&utm_campaign=none\" target=\"_blank\">Telecom Times</a></li>\n          </ul>\n        </li>\n        <li>\n          <button data-toggle=\"accordion\">\n            <span class=\"isActive\">Recruit</span>\n            <img src=\"/assets/img/common/ico-arrow.svg\" alt=\"\"></button>\n          <ul>\n            <li><a href=\"/recruit/\">採用情報</a></li>\n            <li><a href=\"/recruit/#interview\">社員インタビュー</a></li>\n            <li><a href=\"/recruit/careerplan/\">キャリアモデル</a></li>\n          </ul>\n        </li>\n        <li>\n          <button data-toggle=\"accordion\">\n            <span>News</span>\n            <img src=\"/assets/img/common/ico-arrow.svg\" alt=\"\">\n          </button>\n          \n            \n              \n                <ul>\n                  <li><a href=\"/news/\">ニュース一覧</a></li>\n              \n                  <li><a href=\"/news/press/\">プレスリリース</a></li>\n              \n            \n              \n                  <li><a href=\"/news/other/\">お知らせ</a></li>\n              \n            \n              \n                  <li><a href=\"/news/media/\">メディア</a></li>\n              \n            \n              \n                  \n              \n                </ul>\n              \n            \n          \n        </li>\n        <li>\n          <button data-toggle=\"accordion\">\n            <span>Sustainability</span>\n            <img src=\"/assets/img/common/ico-arrow.svg\" alt=\"\"></button>\n          <ul>\n            <li><a href=\"/sustainability/\">サスティナビリティについて</a></li>\n          </ul>\n        </li>\n        <li><a href=\"/contact/\">Contact</a></li>\n      </ul>\n      <div>\n        <p><a href=\"/\"><img src=\"/assets/img/common/logo.svg\" alt=\"Telecom Square\"></a></p>\n        \n        <ul>\n          <li><a class=\"isActive\" href=\"/\">JP</a></li>\n          <li><a href=\"/english/\">EN</a></li>\n        </ul>\n      </div>\n      <button data-toggle=\"menu\"><span>&times;</span></button>\n    </nav>\n    <main>\n\n<div class=\"recruitStaffHeadingBlock\">\r\n\t<div class=\"recruitStaffHeadingBlock__text\">\r\n\t\t<div class=\"recruitStaffHeadingBlock__tag\">\r\n\t\t\t<p>通信営業</p>\r\n\t\t</div>\r\n\t\t<h1>営業一筋！<br class=\"sp-hidden\">\r\n\t\t多くのステークホルダーとの関わりが私の成長と誇りとなる</h1>\r\n\t\t<div class=\"recruitStaffHeadingBlock__box\">\r\n\t\t\t<p class=\"recruitStaffHeadingBlock__name\">Y.U</p>\r\n\t\t\t<ul>\r\n\t\t\t\t<li>2017年入社</li>\r\n\t\t\t</ul>\r\n\t\t</div>\r\n\t</div>\r\n\t<div class=\"recruitStaffHeadingBlock__image\">\r\n\t\t<picture>\r\n\t\t\t<source srcset=\"/assets/img/recruit/staff04/kv_lg.jpg\" media=\"(min-width: 768px)\" width=\"1366\" height=\"500\"><img src=\"/assets/img/recruit/staff04/kv.jpg\" width=\"375\" height=\"211\" alt=\"\"> </picture>\r\n\t</div>\r\n</div>\r\n<div class=\"recruitStaff\">\r\n\t<section>\r\n\t\t<h2>まずは自己紹介と現在の仕事内容を教えてください</h2>\r\n\t\t<p>皆さん、こんにちは。名古屋支店で営業として働いているUと申します。<br />\r\n\t\t生まれも育ちも関西でしたが、テレコムスクエアへの入社を機に上京し、東京本社で営業職として約二年働いた後、名古屋支店に異動し現在に至ります。<br />\r\n\t\t仕事内容としては企業様に対して、Wi-Fiルーターをはじめとした通信サービスのソリューション営業を行っています。<br />\r\n\t\t基本的な業務内容は東京にいた頃と変わりませんが、お客様が重要視されるポイント（例えば、こちらでは製造業のお客様が多く、現地工場での通信品質が重要であったり）や仕事の進め方など、東京とは違った側面もあります。<br />\r\n\t\t私は異動してくるまで東海地方に関わりがなかったので、土地勘や地元の方の感覚が掴めておらず異動当初は苦労していました。<br />\r\n\t\tそれでも上司や同僚、お取引先の方の支えがあって最近少しは馴染んできたかなと感じています。</p>\r\n\t</section>\r\n\t<section>\r\n\t\t<h2>当社を志望したきっかけを教えてください</h2>\r\n\t\t<p>就職活動の際、実は通信にも旅行にも大して興味はなかったです(笑)<br />\r\n\t\t自分の知見を広げていくために「人と多く関われる仕事であること」「多種多様な業種と関われる仕事であること」、この2つをポイントに当時は就職活動を行っていました。<br />\r\n\t\t合同説明会でたまたまテレコムスクエアの話を聞く機会があり、「海外に行かれる全ての方がお客様」という点が、まさに自分の知見を広げられる環境なのではないかと感じ、志望しました。<br />\r\n\t\t当初からさまざまな業種の方と関わっていきたいと思っていたので、営業職を希望していたのですが、そこも希望通りとなりました。</p>\r\n\t</section>\r\n\t<section>\r\n\t\t<h2>実際に入社して感じた当社の魅力を教えてください</h2>\r\n\t\t<p>コミュニケーションが取りやすい雰囲気が一番の魅力に感じます。<br />\r\n\t\t従業員同士はもちろん、会長や役員の方も話しやすい雰囲気で接してくれる為、肩を張りすぎることなくコミュニケーションが取れます。<br />\r\n\t\tまた、上下関係を意識せずに意見を言うことができる環境が多くあり、若手が手を挙げれば尊重し応援してくれる社風も魅力です。そのおかげで週次営業報告会などでは若手・ベテラン関係なく、活発な意見がしばしば飛び交います。</p>\r\n\t\t<img src=\"/assets/img/recruit/staff04/img_01.jpg\">\r\n\t</section>\r\n\t<section>\r\n\t\t<h2>「これぞTS Way！」というようなご自身の取り組みをひとつ教えてください<span class=\"memo\">※「TS Way」とは、テレコムスクエアの企業理念、経営ビジョン、行動指針を指します</span></h2>\r\n\t\t<p>TS Wayの『私たちは、誇りの持てる仕事を通して、働く喜びを実現します。』<br />\r\n\t\t上記を感じられたエピソードとして、既存サービスのリニューアルに携わったことが印象に残っています。<br />\r\n\t\t当時、年々激化している競合他社とのせめぎ合いや市場動向の変化から、既存のサービスラインナップではなかなか差別化がしづらくなり、新たな商品開発（プラン造成）が必要だと感じていました。どのような商品がお客様にとってより有益なものになるか、お取引先様へ訪問する際などに直接声を拾い集め、ニーズを探りました。<br />\r\n\t\tそうしてたどり着いた答えが「マンスリーでお得にレンタルできる世界周遊プラン」でした。<br />\r\n\t\tこの実現には仕入れ部門との価格調整や、お申し込み方法が煩雑にならない新たなオペレーションの構築など、イチから進めるには少々重たい社内調整が必要でしたが、別のプロジェクトで調整する箇所が近い内容であったため、提案を急いでまとめ、相乗りする形で推進させることが出来ました。<br />\r\n\t\t結果、価格や顧客の要望を可能な限り反映した新プランを無事リリースすることができ、相乗り企画で推進出来たことで、約1か月という短期間でリリースさせることが出来ました。<br />\r\n\t\t現在、このプランは数多くの法人様にご導入いただき、主力商品のひとつとなっています。</p>\r\n\t</section>\r\n\t<section>\r\n\t\t<h2>休日は主に何をして過ごしていますか</h2>\r\n\t\t<p>神戸っ子なので地元球団オリックスの根っからのファンでして、野球観戦が中心の休日です。野球を見るために、試合時間に合わせてその他の予定を調整しています（笑）<br />\r\n\t\t主にネット中継で観戦していますが、友人と球場で観戦することもあります。<br />\r\n\t\t来シーズンは全国の球場に足を運びたいなと計画中です。<br />\r\n\t\tあと…山本由伸投手３年連続沢村賞おめでとう！！（笑）</p>\r\n\t</section>\r\n\t<section>\r\n\t\t<h2>これから当社でチャレンジしたいことを教えてください</h2>\r\n\t\t<p>これまではプレイヤーとしての仕事がほとんどであった為、営業所長などのマネジメントにもチャレンジしていきたいと考えています。<br />\r\n\t\t営業担当は個人で成績を上げてなんぼと思っておりましたが、テレコムスクエアの営業を通じて感じたのは、「個人実績のみならず、チームで実績を上げることが会社を強く、元気にするエネルギーとなる」ということです。<br />\r\n\t\tこれから自分自身もより知見を広め、成長し、個人の成果だけでなく、チームで結果を残せる強い組織に成長させられるリーダーになることが目標です。</p>\r\n\t\t<img src=\"/assets/img/recruit/staff04/img_02.jpg\">\r\n\t</section>\r\n\t<section>\r\n\t\t<h2>1日のスケジュール</h2>\r\n\t\t<div class=\"day-schedule-wrap\">\r\n\t\t\t<table class=\"day-schedule col3\">\r\n\t\t\t\t<tbody>\r\n\t\t\t\t\t<tr>\r\n\t\t\t\t\t\t<th>9:00～</th>\r\n\t\t\t\t\t\t<td>出勤、メールチェック</td>\r\n\t\t\t\t\t\t<td class=\"detail\">提案資料作成や報告書作成など</td>\r\n\t\t\t\t\t</tr>\r\n\t\t\t\t\t<tr>\r\n\t\t\t\t\t\t<th>11:00～</th>\r\n\t\t\t\t\t\t<td>商談</td>\r\n\t\t\t\t\t\t<td class=\"detail\">担当企業様へ新サービスの提案を実施</td>\r\n\t\t\t\t\t</tr>\r\n\t\t\t\t\t<tr>\r\n\t\t\t\t\t\t<th>13:00～</th>\r\n\t\t\t\t\t\t<td>商談</td>\r\n\t\t\t\t\t\t<td class=\"detail\">現状の困りごとのヒアリング、施策提案など代理店と打ち合わせを実施</td>\r\n\t\t\t\t\t</tr>\r\n\t\t\t\t\t<tr>\r\n\t\t\t\t\t\t<th>15:00～</th>\r\n\t\t\t\t\t\t<td>営業ミーティング</td>\r\n\t\t\t\t\t\t<td class=\"detail\">担当企業の実績報告、1週間の業務内容、新サービス提案の状況などを共有</td>\r\n\t\t\t\t\t</tr>\r\n\t\t\t\t\t<tr>\r\n\t\t\t\t\t\t<th>16:00～</th>\r\n\t\t\t\t\t\t<td>メール、電話対応など</td>\r\n\t\t\t\t\t\t<td class=\"detail\">その他、商談内容のまとめや社内調整、データ集計などを実施</td>\r\n\t\t\t\t\t</tr>\r\n\t\t\t\t\t<tr>\r\n\t\t\t\t\t\t<th>18:00～</th>\r\n\t\t\t\t\t\t<td>退勤</td>\r\n\t\t\t\t\t\t<td class=\"detail\"></td>\r\n\t\t\t\t\t</tr>\r\n\t\t\t\t</tbody>\r\n\t\t\t</table>\r\n\t\t</div>\r\n\t</section>\r\n</div>\n\n<!--<div class=\"recruitLocalNav\">\n  <ul class=\"recruitCards\">\n    <li class=\"-light\">\n      <div class=\"card\" target=\"_blank\" rel=\"noopener\" data-scroll=\"slide\">\n        <p>新卒採用</p>\n        <p>2026年卒採用のエントリーを開始しました。</p>\n        <p>\n        <object><a class=\"button\" href=\"https://job.mynavi.jp/26/pc/search/corp242817/outline.html\" target=\"_blank\"><span>エントリーする</span><span><span class=\"button__ico\"></span></span></a>\n          </object>\n        </p>\n      </div>\n    </li>\n  </ul>\n</div>-->\n<a class=\"contact\" href=\"/contact/\" data-scroll=\"slide\">\n  <div>\n    <p>Contact</p>\n    <p>お問い合わせ</p>\n    <span>\n      <picture>\n        <source media=\"(min-width: 768px)\" srcset=\"/assets/img/common/ico-button.svg\"><img src=\"/assets/img/common/ico-button-white.svg\" alt=\"\">\n      </picture>\n    </span>\n  </div>\n  <p>各種サービスに関するご意見・ご質問など、こちらからお願いいたします。</p>\n</a>\n<div class=\"breadcrumb\">\n  <ul>\n    <li><a href=\"/\">Top</a></li>\n    \n    <li><a href=\"/recruit/\">採用情報</a></li>\n    \n    <li><span>営業一筋！ 多くのステークホルダーとの関わりが 私の成長と誇りとなる</span></li>\n  </ul>\n</div>\n<a class=\"prevTop\" href=\"#\"><img src=\"/assets/img/common/ico-button.svg\" alt=\"\"></a>\n    </main>\n    <div class=\"footerNav\">\n      <div>\n        <ul class=\"nav\">\n        <li><a href=\"/\">Top</a></li>\n        <li>\n          <button data-toggle=\"accordion\">\n            <span>About us</span>\n            <img src=\"/assets/img/common/ico-arrow.svg\" alt=\"\">\n          </button>\n          <ul>\n            <li><a href=\"/aboutus/\">テレコムスクエアについて</a></li>\n            <li><a href=\"/aboutus/company/\">会社概要</a></li>\n            <li><a href=\"/aboutus/h