ig.js\" async></script>\r\n<script src=\"https://www.nabeya-mfg.co.jp/common/js/ajaxzip3.js\" async></script></head>\n\n<body>\n\t<!-- Google Tag Manager (noscript) -->\r\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-K2LSKFM\"\r\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\r\n<!-- End Google Tag Manager (noscript) -->\r\n\t<!-- header_START -->\n<header>\n\t\t\t<div class=\"logo\"><a href=\"https://www.nabeya-mfg.co.jp\"><img src=\"https://www.nabeya-mfg.co.jp/img/common/logo.png\" alt=\"株式会社 ナベヤ製作所\" width=\"219\" height=\"32\"></a></div>\n\t\t<div class=\"contact\"><a href=\"#contact\" class=\"fade\"><span class=\"pc\"><img src=\"https://www.nabeya-mfg.co.jp/img/common/icon_contact.png\" alt=\"\" width=\"24\" height=\"24\">お問い合わせ</span><span class=\"sp\"><img src=\"https://www.nabeya-mfg.co.jp/img/common/btn_contact.png\" alt=\"お問い合わせ\" width=\"61\" height=\"67\"></span></a></div>\n\t<nav id=\"menu\">\n\t\t<div class=\"btn\"><img src=\"https://www.nabeya-mfg.co.jp/img/common/btn_menu.png\" alt=\"MENU\" width=\"64\" height=\"67\"></div>\n\t\t<ul>\n\t\t\t<li><a href=\"https://www.nabeya-mfg.co.jp/company/\">会社概要</a></li>\n\t\t\t<li><a href=\"https://www.nabeya-mfg.co.jp/guideline/\">経営指針</a></li>\n\t\t\t<li><a href=\"https://www.nabeya-mfg.co.jp/manufacturing/\">品質情報</a></li>\n\t\t\t<li><a href=\"https://www.nabeya-mfg.co.jp/service/\">事業案内</a></li>\n\t\t\t<li><a href=\"https://www.nabeya-mfg.co.jp/facility/\">設備一覧</a></li>\n\t\t\t<li><a href=\"https://www.nabeya-mfg.co.jp/vr/\">工場見学</a></li>\n\t\t\t<li class=\"shop\"><a href=\"https://nabeya-mfg.shop-pro.jp/\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"fade\"><img src=\"https://www.nabeya-mfg.co.jp/img/common/icon_shop.png\" alt=\"\" width=\"24\" height=\"24\">オンラインショップ</a></li>\n\t\t\t<li class=\"recruit\"><a href=\"https://www.nabeya-mfg.co.jp/recruit/\" class=\"fade\"><img src=\"https://www.nabeya-mfg.co.jp/img/common/icon_recruit.png\" alt=\"\" width=\"24\" height=\"24\">採用情報</a></li>\n\t\t</ul>\n\t</nav>\n</header>\n<!-- header_END -->\n\t<!-- title_START -->\n\t<div id=\"title\" class=\"recruit\">\n\t\t<div class=\"inner\">\n\t\t\t<h1>採用情報<span>RECRUIT INFORMATION</span></h1>\n\t\t</div>\n\t</div>\n\t<!-- title_END -->\n\n\t<!-- path_START -->\n\t<ol id=\"path\" class=\"inner\" itemscope itemtype=\"https://schema.org/BreadcrumbList\">\n\t\t<li itemprop=\"itemListElement\" itemscope itemtype=\"https://schema.org/ListItem\"><a href=\"../\" itemprop=\"item\"><span\n\t\t\t\t\titemprop=\"name\">HOME</span></a>\n\t\t\t<meta itemprop=\"position\" content=\"1\">\n\t\t</li>\n\t\t<li itemprop=\"itemListElement\" itemscope itemtype=\"https://schema.org/ListItem\"><span itemprop=\"name\">採用情報</span>\n\t\t\t<meta itemprop=\"position\" content=\"2\">\n\t\t</li>\n\t</ol>\n\t<!-- path_END -->\n\n\t<!-- main_START -->\n\t<main id=\"recruit\">\n\t\t<div class=\"wrap_recruit\">\n\t\t\t<div class=\"widget_first\">\n\t\t\t\t<div class=\"bg_blue\">\n\t\t\t\t\t<div class=\"inner\">\n\t\t\t\t\t\t<p class=\"lead\"><span>「</span>地元でできる、<br>夢中になれる<br>仕事があります。<span>」</span></p>\n\t\t\t\t\t\t<p>ナベヤ製作所には様々な仕事があります。<br>仕事は違っても、それぞれがナベヤ製作所の一員として、自信を持って仕事をしています。</p>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\n\t\t\t<div class=\"staff\">\n\t\t\t\t<div class=\"reason\">\n\t\t\t\t\t<div class=\"bg_white\">\n\t\t\t\t\t\t<div class=\"inner\">\n\t\t\t\t\t\t\t<h2>ナベヤ製作所に入社した理由は？？<span>REASON FOR JOINING THE COMPANY</span></h2>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t\t<p class=\"balloon\"><img src=\"../img/recruit/balloon_reason.png\"\n\t\t\t\t\t\t\t\talt=\"「ものづくりがしたかった」「地元の歴史ある会社だから」「毎日違う作業でやりがいがありそうだった」\" width=\"844\" height=\"348\"></p>\n\t\t\t\t\t\t<div class=\"column inner\">\n\t\t\t\t\t\t\t<ul>\n\t\t\t\t\t\t\t\t<li>・ <span>溶接</span>に<span>興味</span>があった</li>\n\t\t\t\t\t\t\t\t<li>・ <span>測定事業</span>に<span>興味</span>があった</li>\n\t\t\t\t\t\t\t\t<li>・ <span>手に職</span>を付けたかった</li>\n\t\t\t\t\t\t\t\t<li>・ 家から近かった</li>\n\t\t\t\t\t\t\t</ul>\n\t\t\t\t\t\t\t<ul>\n\t\t\t\t\t\t\t\t<li>・ <span>地元の企業</span>で働きたかった</li>\n\t\t\t\t\t\t\t\t<li>・ <span>航空機業界</span>に<span>興味</span>があった</li>\n\t\t\t\t\t\t\t\t<li>・ <span>3D CAD</span>の仕事がしたかった</li>\n\t\t\t\t\t\t\t\t<li>・ <span></span>NC加工</span>に<span>興味</span>があった</li>\n\t\t\t\t\t\t\t</ul>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\n\t\t\t\t<div class=\"word\">\n\t\t\t\t\t<div class=\"bg_white\">\n\t\t\t\t\t\t<div class=\"inner\">\n\t\t\t\t\t\t\t<h2>ナベヤ製作所を一言で言うと？？<span>WHAT IS NABEYA MFG?</span></h2>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t\t<p class=\"balloon\"><img src=\"../img/recruit/balloon_word.png\" alt=\"「挑戦し続ける会社」「製造のプロ集団!!」「一生懸命ものづくりをする会社」\"\n\t\t\t\t\t\t\t\twidth=\"834\" height=\"348\"></p>\n\t\t\t\t\t\t<div class=\"column inner\">\n\t\t\t\t\t\t\t<ul>\n\t\t\t\t\t\t\t\t<li>・ <span>アットホーム</span>な会社</li>\n\t\t\t\t\t\t\t\t<li>・ <span>改善</span>を<span>続ける</span>会社</li>\n\t\t\t\t\t\t\t\t<li>・ <span>測定・機械加工・溶接・組立</span>様々な仕事に<span>対応</span> できる会社</li>\n\t\t\t\t\t\t\t</ul>\n\t\t\t\t\t\t\t<ul>\n\t\t\t\t\t\t\t\t<li>・ <span>製造のプロ</span>になれる！</li>\n\t\t\t\t\t\t\t\t<li>・ <span>将来が楽しみ</span>な会社</li>\n\t\t\t\t\t\t\t\t<li>・ 工場ごとに<span>個性</span>がある</li>\n\t\t\t\t\t\t\t\t<li>・ 毎日が<span>刺激的</span></li>\n\t\t\t\t\t\t\t</ul>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\n\t\t\t\t<div class=\"charm\">\n\t\t\t\t\t<div class=\"bg_white\">\n\t\t\t\t\t\t<div class=\"inner\">\n\t\t\t\t\t\t\t<h2>ナベヤ製作所の魅力は？？<span>WHAT IS THE CHARM OF NABEYA MFG?</span></h2>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t\t<p class=\"balloon\"><img src=\"../img/recruit/balloon_charm.png\" alt=\"「総合力の発揮」「ものづくりへの意識が高い!!」「個性が発揮できる」\"\n\t\t\t\t\t\t\t\twidth=\"834\" height=\"348\"></p>\n\t\t\t\t\t\t<div class=\"column inner\">\n\t\t\t\t\t\t\t<ul>\n\t\t\t\t\t\t\t\t<li>・ <span>職場の雰囲気</span>が<span>良い</span></li>\n\t\t\t\t\t\t\t\t<li>・ <span>改善意識</span>が<span>高い</span></li>\n\t\t\t\t\t\t\t\t<li>・ 型にはまった作業から、型にはまらない対応が必要な作業まで、<span>様々な職場がある</span>こと</li>\n\t\t\t\t\t\t\t</ul>\n\t\t\t\t\t\t\t<ul>\n\t\t\t\t\t\t\t\t<li>・ <span>ナベヤグループ</span>の<span>一員</span></li>\n\t\t\t\t\t\t\t\t<li>・ 個人を<span>尊重</span>してくれる</li>\n\t\t\t\t\t\t\t\t<li>・ <span>測定のレベル</span>が<span>高い</span></li>\n\t\t\t\t\t\t\t\t<li>・ <span>有休</span>が取りやすい</li>\n\t\t\t\t\t\t\t</ul>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\n\t\t\t\t<div class=\"rewarding\">\n\t\t\t\t\t<div class=\"bg_white\">\n\t\t\t\t\t\t<div class=\"inner\">\n\t\t\t\t\t\t\t<h2>仕事のやりがいは、どんな時に感じる？？<span>HOW REWARDING IS YOUR JOB?</span></h2>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t\t<p class=\"balloon\"><img src=\"../img/recruit/balloon_rewarding.png\"\n\t\t\t\t\t\t\t\talt=\"「製品が完成した時」「お客様から感謝された時」「自分で組んだプログラムで思い通りのものが出来た時」\" width=\"834\" height=\"348\"></p>\n\t\t\t\t\t\t<div class=\"column inner\">\n\t\t\t\t\t\t\t<ul>\n\t\t\t\t\t\t\t\t<li>・ <span>自分で考えて</span>仕事を進めている時</li>\n\t\t\t\t\t\t\t\t<li>・ 厳しい公差のものが<span>良品でできた時</span></li>\n\t\t\t\t\t\t\t\t<li>・ 形のないものから<span>製品ができた時</span></li>\n\t\t\t\t\t\t\t\t<li>・ <span>責任ある仕事を任せられた時</span></li>\n\t\t\t\t\t\t\t</ul>\n\t\t\t\t\t\t\t<ul>\n\t\t\t\t\t\t\t\t<li>・ <span>お客様の喜ぶ</span>ものづくりができた時</li>\n\t\t\t\t\t\t\t\t<li>・ <span>納期通りに</span>納品できた時</li>\n\t\t\t\t\t\t\t\t<li>・ 難しい仕事を<span>自分の手で完結させ、</span>早く終わった時</li>\n\t\t\t\t\t\t\t</ul>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\n\t\t\t<div class=\"data\">\n\t\t\t\t<div class=\"bg_gray\">\n\t\t\t\t\t<div class=\"inner\">\n\t\t\t\t\t\t<h2>データで見る「ナベヤ製作所」<span>View by data</span></h2>\n\t\t\t\t\t\t<ul>\n\t\t\t\t\t\t\t<li>\n\t\t\t\t\t\t\t\t<h3>売上高</h3>\n\t\t\t\t\t\t\t\t\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<p class=\"data-year\">− 2025年3月度決算 −</p>\n\t\t\t\t\t\t\t\t\t\t\t\t<p class=\"data-number\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t10<span class=\"data-number-small\">億</span>8200<span class=\"data-number-small\">万</span><span class=\"data-unit\">円</span>\n\t\t\t\t\t\t\t\t\t\t\t\t</p>\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<img src=\"../img/recruit/data_01.png\" alt=\"売上高\" width=\"130\" height=\"131\" loading=\"lazy\">\n\t\t\t\t\t\t\t</li>\n\t\t\t\t\t\t\t<li>\n\t\t\t\t\t\t\t\t<h3>従業員数</h3>\n\t\t\t\t\t\t\t\t<p class=\"data-year\">− 2026年1月現在 −</p>\n\t\t\t\t\t\t\t\t<p class=\"data-number\">109<span class=\"data-unit\">名</span>\n\t\t\t\t\t\t\t\t\t<br><span class=\"data-small-txt\">（パートを）含む</span>\n\t\t\t\t\t\t\t\t</p>\n\t\t\t\t\t\t\t\t<img src=\"../img/recruit/data_02.png\" alt=\"従業員数\" width=\"142\" height=\"131\" loading=\"lazy\">\n\t\t\t\t\t\t\t</li>\n\t\t\t\t\t\t\t<li>\n\t\t\t\t\t\t\t\t<h3>平均年齢</h3>\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<p class=\"data-year\">− 2025年3月度決算 −</p>\n\t\t\t\t\t\t\t\t\t\t\t<p class=\"data-number\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t41<span class=\"data-unit\">歳</span>\n\t\t\t\t\t\t\t\t\t\t\t</p>\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<img src=\"../img/recruit/data_03.png\" alt=\"平均年齢\" width=\"209\" height=\"133\" loading=\"lazy\">\n\t\t\t\t\t\t\t</li>\n\t\t\t\t\t\t\t<li>\n\t\t\t\t\t\t\t\t<h3>新卒：既卒</h3>\n\t\t\t\t\t\t\t\t<p class=\"data-number\">3：7</p>\n\t\t\t\t\t\t\t\t<img src=\"../img/recruit/data_04.png\" alt=\"平均年齢\" width=\"91\" height=\"131\" loading=\"lazy\">\n\t\t\t\t\t\t\t</li>\n\t\t\t\t\t\t\t<li>\n\t\t\t\t\t\t\t\t<h3>平均勤続年数</h3>\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<p class=\"data-number\">\n\t\t\t\t\t\t\t\t\t\t\t11.<span class=\"data-number-small\">7</span>\t\t\t\t\t\t\t\t\t\t\t<span class=\"data-unit\">年</span>\n\t\t\t\t\t\t\t\t\t\t</p>\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<img src=\"../img/recruit/data_05.png\" alt=\"平均勤続年数\" width=\"118\" height=\"131\" loading=\"lazy\">\n\t\t\t\t\t\t\t</li>\n\t\t\t\t\t\t\t<li>\n\t\t\t\t\t\t\t\t<h3>入社3年までの離職率</h3>\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<p class=\"data-number\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t18.<span class=\"data-number-small\">4</span><span class=\"data-unit\">%</span>\n\t\t\t\t\t\t\t\t\t\t\t</p>\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<img src=\"../img/recruit/data_06.png\" alt=\"入社3年までの離職率\" width=\"144\" height=\"130\" loading=\"lazy\">\n\t\t\t\t\t\t\t</li>\n\t\t\t\t\t\t\t<li>\n\t\t\t\t\t\t\t\t<h3>年間休日</h3>\n\t\t\t\t\t\t\t\t<p class=\"data-number\">125<span class=\"data-unit\">日</span></p>\n\t\t\t\t\t\t\t\t<img src=\"../img/recruit/data_07.png\" alt=\"年間休日\" width=\"119\" height=\"130\" loading=\"lazy\">\n\t\t\t\t\t\t\t</li>\n\t\t\t\t\t\t\t<li>\n\t\t\t\t\t\t\t\t<h3>月平均残業日数</h3>\n\t\t\t\t\t\t\t\t<p class=\"data-number\">9<span class=\"data-unit\">日</span></p>\n\t\t\t\t\t\t\t\t<img src=\"../img/recruit/data_08.png\" alt=\"平均年齢\" width=\"138\" height=\"132\" loading=\"lazy\">\n\t\t\t\t\t\t\t</li>\n\t\t\t\t\t\t\t<li>\n\t\t\t\t\t\t\t\t<h3>平均有給取得数</h3>\n\t\t\t\t\t\t\t\t<p class=\"data-number\">12<span class=\"data-unit\">日</span></p>\n\t\t\t\t\t\t\t\t<img src=\"../img/recruit/data_09.png\" alt=\"平均有給取得数\" width=\"112\" height=\"131\" loading=\"lazy\">\n\t\t\t\t\t\t\t</li>\n\t\t\t\t\t\t\t<li>\n\t\t\t\t\t\t\t\t<h3>平均通勤時間</h3>\n\t\t\t\t\t\t\t\t<img src=\"../img/recruit/data_10.png\" class=\"data-graph\" alt=\"平均通勤時間\" width=\"91\" height=\"131\" loading=\"lazy\">\n\t\t\t\t\t\t\t</li>\n\t\t\t\t\t\t</ul>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\n\t\t\t<div class=\"qualifications\">\n\t\t\t\t<div class=\"bg_white\">\n\t\t\t\t\t<div class=\"inner\">\n\t\t\t\t\t\t<h2>持っている資格は？<span>Qualifications</span></h2>\n\t\t\t\t\t\t<h3>技能検定</h3>\n\t\t\t\t\t\t<ul>\n\t\t\t\t\t\t\t<li>（機械加工）</li>\n\t\t\t\t\t\t\t<li>・普通旋盤作業</li>\n\t\t\t\t\t\t\t<li>・フライス盤作業</li>\n\t\t\t\t\t\t\t<li>・NCフライス盤作業</li>\n\t\t\t\t\t\t\t<li>・マシニングセンタ作業</li>\n\t\t\t\t\t\t</ul>\n\t\t\t\t\t\t<ul>\n\t\t\t\t\t\t\t<li>（機械検査）</li>\n\t\t\t\t\t\t\t<li>・機械検査作業</li>\n\t\t\t\t\t\t</ul>\n\t\t\t\t\t\t<ul>\n\t\t\t\t\t\t\t<li>（機械保全）</li>\n\t\t\t\t\t\t\t<li>・機械系保全作業</li>\n\t\t\t\t\t\t\t<li>・設備診断</li>\n\t\t\t\t\t\t</ul>\n\t\t\t\t\t\t<ul>\n\t\t\t\t\t\t\t<li>（機械・プラント製図）</li>\n\t\t\t\t\t\t\t<li>・機械製図CAD作業</li>\n\t\t\t\t\t\t</ul>\n\t\t\t\t\t\t<ul>\n\t\t\t\t\t\t\t<li>（仕上）</li>\n\t\t\t\t\t\t\t<li>・機械組立仕上げ作業</li>\n\t\t\t\t\t\t</ul>\n\t\t\t\t\t</div>\n\t\t\t\t\t<div class=\"inner\">\n\t\t\t\t\t\t<h3>各種資格・技能講習</h3>\n\t\t\t\t\t\t<ul>\n\t\t\t\t\t\t\t<li>・第一種衛生管理者</li>\n\t\t\t\t\t\t\t<li>・危険物取扱責任者乙種4類</li>\n\t\t\t\t\t\t\t<li>・3次元CAD利用技術者</li>\n\t\t\t\t\t\t\t<li>・玉掛け</li>\n\t\t\t\t\t\t\t<li>・クレーン</li>\n\t\t\t\t\t\t\t<li>・フォークリフト</li>\n\t\t\t\t\t\t\t<li>・フルハーネス型</li>\n\t\t\t\t\t\t\t<li>・有機溶剤作業主任者</li>\n\t\t\t\t\t\t</ul>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\n\t\t\t<div class=\"widget_solution\">\n\t\t\t\t<div class=\"inner\">\n\t\t\t\t\t<p class=\"lead\">体験入社を実施しています！</p>\n\t\t\t\t\t<p>ナベヤ製作所では当社のことをもっとよく知っていただくために、<br>選考をご希望の方向けに体験入社を実施しております。<br>ご興味のある方はお問い合わせ下さい。</p>\n\t\t\t\t\t<div class=\"tel\"><span>ナベヤ製作所 採用担当：三上</span><a href=\"tel:058-383-6351\"\n\t\t\t\t\t\t\tclass=\"font_Roboto\">TEL.058-383-6351</a>\n\t\t\t\t\t</div>\n\t\t\t\t\t<div class=\"widget_btn\"><a href=\"#contact\" class=\"white fade\">フォームから問い合わせる</a></div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\n\t\t<div class=\"widget_recruit\">\r\n\t<div class=\"bg_blue\">\r\n\t\t<div class=\"inner\">\r\n\t\t\t<h2>採用情報<span>RECRUIT</span></h2>\r\n\t\t\t<ul>\r\n\t\t\t\t<li><img src=\"https://www.nabeya-mfg.co.jp/img/recruit/navi_introduction.png\" alt=\"\" width=\"260\" height=\"200\"><div class=\"widget_btn\"><a href=\"https://www.nabeya-mfg.co.jp/recruit/introduction/\" class=\"fade\">仕事紹介</a></div></li>\r\n\t\t\t\t<li><img src=\"https://www.nabeya-mfg.co.jp/img/recruit/navi_interview.png\" alt=\"\" width=\"260\" height=\"200\"><div class=\"widget_btn\"><a href=\"https://www.nabeya-mfg.co.jp/recruit/interview/\" class=\"fade\">社員インタビュー</a></div></li>\r\n\t\t\t\t<li><img src=\"https://www.nabeya-mfg.co.jp/img/recruit/navi_faq.png\" alt=\"\" width=\"260\" height=\"200\"><div class=\"widget_btn\"><a href=\"https://www.nabeya-mfg.co.jp/recruit/faq/\" class=\"fade\">採用よくある質問</a></div></li>\r\n\t\t\t\t<li><img src=\"https://www.nabeya-mfg.co.jp/img/recruit/navi_guide.png\" alt=\"\" width=\"260\" height=\"200\"><div class=\"widget_btn\"><a href=\"https://www.nabeya-mfg.co.jp/guide/\" class=\"fade\">募集要項</a></div></li>\r\n\t\t\t</ul>\r\n\t\t</div>\r\n\t</div>\r\n</div>\r\n\t</main>\n\t<!-- main_END -->\n\n\t<!-- footer_START -->\n<footer>\n\t<!-- <script src=\"https://www.google.com/recaptcha/api.js?render=6LfEe8wiAAAAAMMyx-TquFyy2IbofhXq1H-9-xEa\"></script> -->\n\t<script>\n\t\t// document.addEventListener('DOMContentLoaded', function() {\n\n\t\t// \t//※サイトキーを設定\n\t\t// \tvar siteKey = '6LfEe8wiAAAAAMMyx-TquFyy2IbofhXq1H-9-xEa';\n\t\t// \t//フォーム要素を取得\n\t\t// \tvar formElem = document.querySelector('form');\n\n\t\t// \tgrecaptcha.ready(function() {\n\t\t// \t\tgrecaptcha.execute(siteKey).then(function(token) {\n\t\t// \t\t\tvar inputTokenElem = document.createElement('input');\n\t\t// \t\t\tinputTokenElem.type = 'hidden';\n\t\t// \t\t\tinputTokenElem.name = 'recaptchaResponse';\n\t\t// \t\t\tinputTokenElem.value = token;\n\t\t// \t\t\tformElem.appendChild(inputTokenElem);\n\t\t// \t\t});\n\t\t// \t});\n\t\t// });\n\t</script>\n\t<div class=\"fix\"><a href=\"#contact\"><img src=\"https://www.nabeya-mfg.co.jp/img/common/fix_contact.png\" alt=\"ナベヤ製作所に今すぐ問い合わせる\" width=\"110\" height=\"183\"></a></div>\n\t<div class=\"fix fix2\"><a href=\"/recruit/\"><img src=\"https://www.nabeya-mfg.co.jp/img/common/fix_contact2.png\" alt=\"ナベヤ製作所人材募集中\" width=\"110\" height=\"183\"></a></div>\n\t<div class=\"pagetop\"><span class=\"fade\">&uarr;</span></div>\n\t\t\t<div id=\"contact\">\n\t\t\t\t\t<h2>採用に関するお問い合わせ<span>RECRUITMENT INQUIRIES</span></h2>\n\t\t\t<p class=\"lead\">下記項目にご入力下さい。</p>\n\t\t\t<p>当社へのご相談、ご質問等ございましたらお気軽にお問い合わせ下さい。<br>※必要事項をご記入の上、[ 送信します ] のボタンを押して下さい。※必須項目は、必ずご記入下さい。<br>・機種依存文字を入力すると、文字化けする場合がありますので、使用しないで下さい。</p>\n\t\t\t<form method=\"post\" action=\"/form/re_mail_v3.php\" enctype=\"multipart/form-data\">\n\t\t\t\t<table>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<th>お名前<span>必須</span></th>\n\t\t\t\t\t\t<td><input type=\"text\" name=\"お名前\" placeholder=\"山田 太郎\" required></td>\n\t\t\t\t\t</tr>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<th>ふりがな<span>必須</span></th>\n\t\t\t\t\t\t<td><input type=\"text\" name=\"ふりがな\" placeholder=\"やまだ たろう\" required></td>\n\t\t\t\t\t</tr>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<th>電話番号</th>\n\t\t\t\t\t\t<td><input type=\"tel\" name=\"電話番号\" placeholder=\"000-0000-0000\"></td>\n\t\t\t\t\t</tr>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<th>メールアドレス<span>必須</span></th>\n\t\t\t\t\t\t<td><input type=\"email\" name=\"メールアドレス\" placeholder=\"&#105;&#110;&#102;&#111;&#64;&#115;&#111;&#107;&#117;&#116;&#101;&#105;&#46;&#99;&#111;&#46;&#106;&#112;\" required></td>\n\t\t\t\t\t</tr>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<th>メールアドレス<br>（確認）<span>必須</span></th>\n\t\t\t\t\t\t<td><input type=\"email\" name=\"メールアドレス（確認）\" placeholder=\"&#105;&#110;&#102;&#111;&#64;&#115;&#111;&#107;&#117;&#116;&#101;&#105;&#46;&#99;&#111;&#46;&#106;&#112;\" required></td>\n\t\t\t\t\t</tr>\n\t\t\t\t\t<tr class=\"textarea\">\n\t\t\t\t\t\t<th>お問い合わせ内容<span>必須</span></th>\n\t\t\t\t\t\t<td><textarea name=\"お問い合わせ内容\" rows=\"5\" required></textarea></td>\n\t\t\t\t\t</tr>\n\t\t\t\t</table>\n\t\t\t\t<div class=\"btn\"><button type=\"submit\" class=\"fade\">確認画面へ</button></div>\n\t\t\t</form>\n\n\t\t\t</div>\n\t\t<small>&copy;2022 株式会社ナベヤ製作所</small>\n</footer>\n<!-- footer_END --></body>\n\n</html>","finalUrl":"https://www.nabeya-mfg.co.jp/recruit/","rendered":false,"_cachedAt":"2026-06-17T23:21:24.697Z"}