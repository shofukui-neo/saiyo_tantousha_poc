{"url":"https://www.psc-cast.com/recruit/group_talk/","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n\t<head>\n\t\t<meta charset=\"utf-8\">\n\t\t<title>先輩社員座談会 | 大平洋特殊鋳造株式会社</title>\n<meta name=\"keywords\" content=\"\">\n<meta name=\"description\" content=\"\">\n\t\t<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n\t\t<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n\t\t<meta http-equiv=\"Content-Style-Type\" content=\"text/css\">\n\t\t<meta http-equiv=\"Content-Script-Type\" content=\"text/javascript\">\n\t\t<link href=\"//maxcdn.bootstrapcdn.com/font-awesome/4.2.0/css/font-awesome.min.css\" rel=\"stylesheet\">\n\t\t<link rel=\"apple-touch-icon\" href=\"media/images/common/logo_forapple.png\"/>\n\t\t<link rel=\"icon\" type=\"image/png\" href=\"media/images/common/favicon32CC.png\"/>\n\t\t<base href=\"https://www.psc-cast.com/\">\n\t\t<link href=\"css/common.css\" type=\"text/css\" rel=\"stylesheet\">\n<link href=\"css/recruit_style.css\" type=\"text/css\" rel=\"stylesheet\">\n<link href=\"css/recruit_common.css?v=2\" type=\"text/css\" rel=\"stylesheet\">\n<link href=\"css/recruit_lower.css\" type=\"text/css\" rel=\"stylesheet\">\n<style type=\"text/css\">\n\n\n#main img {\nmax-width: 100%;\n}\n\n</style><link href=\"css/recruit_lower.css\" type=\"text/css\" rel=\"stylesheet\">\n<style type=\"text/css\">\n\n#main .gt_member > li p,\n#main .chat .chat_content p {\ntext-align: justify;\n}\n</style>\n\t\t<style>\n\tul.depth1 .lm58 {\n\t\tdisplay: none!important;\n\t}\n</style>\n\t\t<script type=\"text/javascript\" src=\"assets/jquery.js\"></script>\n\n\t</head>\n\t<body class=\" \">\n\t\t<div id=\"wholewrapper\">\n\t\t\t<header><div id=\"header_area\">\n\t<h1><a href=\"./\"><img src=\"media/images/common/company_logo.png\"></a></h1>\n\t<div class=\"header_right\">\n\t\t<div id=\"lang\">\n\t\t\t<a href=\"./\">Japanese</a>\n\t\t\t<a href=\"english\">English</a>\n\t\t</div>\n\t\t<div class=\"fgq\">\n\t\t\t<img src=\"media/images/common/