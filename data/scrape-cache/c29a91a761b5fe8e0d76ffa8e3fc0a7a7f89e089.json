n     <div class=\"box\">\n      <div class=\"hd\">包装資材関連</div>\n      <div class=\"txt\">\n       <p>キムラユニティー（株）</p>\n      </div><!-txt-->\n     </div><!--box-->\n     \n     <div class=\"box\">\n      <div class=\"hd\">その他</div>\n      <div class=\"txt\">\n       <p>国立極地研究所 ／ スリーエムジャパン（株）</p>\n      </div><!-txt-->\n     </div><!--box-->\n     \n    </div><!--partner-list-->\n    \n  </div><!--partner--insert-->\n  \n </div><!--insert-->\n \n <a id=\"history\" name=\"history\"></a>\n <div class=\"outline--insert outline--insert__history\">\n  \n  <div class=\"history--insert\">\n   <div class=\"business-title\">\n     <div class=\"din\">OUTLINE</div>\n     <h2>沿革</h2>\n    </div><!--business-title-->\n    \n    <div class=\"history-list\">\n     \n     <div class=\"box\">\n      <div class=\"hd\">1950年〜</div>\n      <div class=\"txt\" style=\"padding-bottom: 0;\">\n       \n       <div class=\"history\">\n        <h3>親和パッケージ（旧　親和興業）の誕生・梱包事業を開始</h3>\n       </div><!--history-->\n       \n       <div class=\"history\">\n        <p>1950年2月</p>\n        <ul>\n         <li>親和興業（株）を設立</li>\n         <li>大阪事業所を開設、（株）淀川製鋼所他と取引開始</li>\n        </ul>\n       </div><!--history-->\n       \n       <div class=\"history\">\n        <p>1952年2月</p>\n        <ul>\n         <li>神戸事業所を開設、川崎製鉄（株）葺合工場における梱包開始</li>\n        </ul>\n       </div><!--history-->\n       \n      </div><!-txt-->\n     </div><!--box-->\n     \n     <div class=\"history-panel\">\n      <dl>\n       <dd>\n        \n        <div class=\"box\">\n         <div class=\"hd\" style=\"border: none;padding-top: 0;margin-top: 0;\"></div>\n         <div class=\"txt\" style=\"border: none;padding-top: 0;margin-top: 0;\">\n           \n           <div class=\"history\">\n            <p>1957年2月</p>\n            <ul>\n             <li>神戸工場を新設</li>\n            </ul>\n           </div><!--history-->\n           \n           <div class=\"history\">\n            <p>1958年5月</p>\n            <ul>\n             <li>千葉出張所を開設、川崎製鉄（株）千葉製鉄所における梱包開始</li>\n            </ul>\n           </div><!--history-->\n           \n           <div class=\"history\">\n            <p>1963年5月</p>\n            <ul>\n             <li>鳳梱包（株）設立</li>\n            </ul>\n           </div><!--history-->\n           \n           <div class=\"history\">\n            <p>1966年5月</p>\n            <ul>\n             <li>水島出張所を開設、川崎製鉄（株）水島製鉄所における梱包開始</li>\n            </ul>\n           </div><!--history-->\n           \n           <div class=\"history\">\n            <p>1969年2月</p>\n            <ul>\n             <li>水島出張所を発展解消し、親和パッケージ（株）を設立</li>\n            </ul>\n           </div><!--history-->\n           \n           <div class=\"history\">\n            <p>1969年10月</p>\n            <ul>\n             <li>知多事業所を開設、川崎製鉄（株）知多工場における梱包開始</li>\n            </ul>\n           </div><!--history-->\n           \n           <div class=\"history\">\n            <p>1970年3月</p>\n            <ul>\n             <li>水島工場を新設</li>\n            </ul>\n           </div><!--history-->\n           \n           <div class=\"history\">\n            <p>1973年4月</p>\n            <ul>\n             <li>神戸・大阪事業所を統合し、阪神事業所を開設</li>\n            </ul>\n           </div><!--history-->\n          \n         </div><!-txt-->\n        </div><!--box-->\n        \n        <div class=\"box\">\n         <div class=\"hd\">1980年〜</div>\n         <div class=\"txt\">\n          <div class=\"history\">\n           <h3>スチール製輸送容器（スチコン）を開発</h3>\n          </div><!--history-->\n          <div class=\"history\">\n           <p>1980年5月</p>\n           <ul>\n            <li>スチコンの研究開始</li>\n           </ul>\n          </div><!--history-->\n          <div class=\"history\">\n           <p>1983年6月</p>\n           <ul>\n            <li>親和パッケージ（株）を合併、社名を親和興業（株）から<br class=\"pc\"/>親和パッケージ（株）に改称</li>\n           </ul>\n          </div><!--history-->\n          \n         </div><!-txt-->\n        </div><!--box-->\n        \n        <div class=\"box\">\n         <div class=\"hd\">1984年〜</div>\n         <div class=\"txt\">\n          <div class=\"history\">\n           <h3>コイル梱包・スチコン製造ラインの自動化へ</h3>\n          </div><!--history-->\n\n          <div class=\"history\">\n           <p>1984年3月</p>\n           <ul>\n            <li>神戸工場で最初のスチコン製造ラインが完成、稼動<br/>\n            スチコンの販売開始<br/>\n            川崎製鉄（株）水島製鉄所で、初の自動コイル梱包ラインが完成、稼動</li>\n           </ul>\n          </div><!--history-->\n          <div class=\"history\">\n           <p>1986年10月</p>\n           <ul>\n            <li>東京パックにスチコンを初出展</li>\n           </ul>\n          </div><!--history-->\n          <div class=\"history\">\n           <p>1988年7月</p>\n           <ul>\n            <li>スチコンＲⅡが日本パッケージングコンテストにおいて電気・機械部門賞受賞</li>\n           </ul>\n          </div><!--history-->\n          <div class=\"history\">\n            <p>1989年7月</p>\n            <ul>\n             <li>（株）シンワコーポレーションを設立</li>\n            </ul>\n           </div><!--history-->\n           <div class=\"history\">\n            <p>1990年8月</p>\n            <ul>\n             <li>エアチェインで、ロジスティクス賞を受賞</li>\n            </ul>\n           </div><!--history-->\n           <div class=\"history\">\n            <p>1990年12月</p>\n            <ul>\n             <li>市原工場を新設</li>\n            </ul>\n           </div><!--history-->\n           <div class=\"history\">\n            <p>1993年5月</p>\n            <ul>\n             <li>本社、神戸工場竣工、移転</li>\n             <li>本社、阪神事業所を統合</li>\n            </ul>\n           </div><!--history-->\n           \n           </div><!-txt-->\n        </div><!--box-->\n        \n        <div class=\"box\">\n         <div class=\"hd\">1995年〜</div>\n         <div class=\"txt\">\n          <div class=\"history\">\n            <h3>スチコンの海外進出開始</h3>\n           </div><!--history-->\n          <div class=\"history\">\n            <p>1995年4月</p>\n            <ul>\n             <li>台湾都林工業と技術提携・契約調印</li>\n            </ul>\n           </div><!--history-->\n           <div class=\"history\">\n            <p>1995年10月</p>\n            <ul>\n             <li>台湾統一實業股ｲ分有限公司に自動コイル梱包ライン納入・稼動</li>\n            </ul>\n           </div><!--history-->\n           <div class=\"history\">\n            <p>1996年7月</p>\n            <ul>\n             <li>（株）シンワコーポレーションの本社を千葉に移転し、<br class=\"pc\"/>本社・神戸本社の２本社体制を導入</li>\n            </ul>\n           </div><!--history-->\n           <div class=\"history\">\n            <p>1996年10月</p>\n            <ul>\n             <li>東京パックにスチコンＥＤ・エアチェイン等出展</li>\n            </ul>\n           </div><!--history-->\n          <div class=\"history\">\n            <p>1996年11月</p>\n            <ul>\n             <li>タイにSHINPACK(THAILAND) CO.,LTD.を設立</li>\n            </ul>\n           </div><!--history-->\n           <div class=\"history\">\n            <p>1998年5月</p>\n            <ul>\n             <li>鳳梱包を鳳テックに社名変更</li>\n            </ul>\n           </div><!--history-->\n           <div class=\"history\">\n            <p>2000年2月</p>\n            <ul>\n             <li>創立50周年を迎える</li>\n            </ul>\n           </div><!--history-->\n           <div class=\"history\">\n            <p>2002年1月</p>\n            <ul>\n             <li>SHINPACK(THAILAND)CO.,LTD.新工場を設立（工場移転）</li>\n            </ul>\n           </div><!--history-->\n          \n         </div><!-txt-->\n        </div><!--box-->\n        \n        <div class=\"box\">\n         <div class=\"hd\">2006年〜</div>\n         <div class=\"txt\">\n          <div class=\"history\">\n            <h3>総合研究施設の強化</h3>\n           </div><!--history-->\n          <div class=\"history\">\n            <p>2006年4月</p>\n            <ul>\n             <li>愛知県東海市に名古屋工場、包装試験センターを新設</li>\n            </ul>\n           </div><!--history-->\n           <div class=\"history\">\n            <p>2008年7月</p>\n            <ul>\n             <li>（株）シンワコーポレーションの本社を神戸に移転</li>\n            </ul>\n           </div><!--history-->\n           <div class=\"history\">\n            <p>2009年10月</p>\n            <ul>\n             <li>親和パッケージ（株）と（株）シンワコーポレーションを合併、<br class=\"pc\"/>社名は親和パッケージ（株）を継承</li>\n            </ul>\n           </div><!--history-->\n           <div class=\"history\">\n            <p>2011年1月</p>\n            <ul>\n             <li>京浜事業所を新設</li>\n            </ul>\n           </div><!--history-->\n           <div class=\"history\">\n            <p>2012年1月</p>\n            <ul>\n             <li>SHINPACK（THAILAND）CO.,LTD.ピントン工場を新設</li>\n            </ul>\n           </div><!--history-->\n           <div class=\"history\">\n            <p>2015年3月</p>\n            <ul>\n             <li>インドネシアに PT.SHINWA PACKAGE INDONESIAを設立</li>\n            </ul>\n           </div><!--history-->\n           <div class=\"history\">\n            <p>2021年4月</p>\n            <ul>\n             <li>神奈川県藤沢市に藤沢ロジスティクスセンター、包装試験センターを新設</li>\n            </ul>\n           </div><!--history-->\n          \n         </div><!-txt-->\n        </div><!--box-->\n        \n       </dd>\n       <dt>\n        <div class=\"btn\">\n         <span class=\"close\">続きを見る</span>\n         <span class=\"open\">閉じる</span>\n        </div>\n       </dt>\n      </dl>\n     </div><!--history-panel-->\n     \n    </div><!--history-list-->\n    \n  </div><!--history--insert-->\n  \n </div><!--insert-->\n \n</section><!--container-->\n\n\n</article>\n\n\n<footer>\n \n <div class=\"footer__fix--sp\">\n  <div class=\"footer__fix--insert\">\n   <ul>\n  \t\t<li><a href=\"/product/\"><span><small><i class=\"ri-search-line\"></i></small>商品紹介</span></a></li>\n  \t\t<li><a href=\"/rental/\"><span style=\"background-color:#48cb3a\"><small><i class=\"ri-download-2-line rental_ico\"></i></i></small>レンタル</span></a></li>\n  \t\t<li><a href=\"/contact/\"><span><small><i class=\"ri-mail-line\"></i></small>お問合せ</span></a></li>\n  \t</ul>\n  </div><!--footer__fix--insert-->\n </div><!--footer__fix--sp-->\n\n <div class=\"fix-rental\">\n\n </div><!--fix-rental-->\n\n\n <div class=\"fix-menu\">\n  <!--<div class=\"link-panel\" ontouchstart=\"\">\n   <a href=\"/