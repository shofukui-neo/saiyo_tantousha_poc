{"url":"https://www.hanshin-tollkobe.co.jp/business/index02.html","html":"<!doctype html>\r\n<html lang=\"ja\"><!-- InstanceBegin template=\"/Templates/base.dwt\" codeOutsideHTMLIsLocked=\"false\" -->\r\n<head>\r\n<!-- Google tag (gtag.js) -->\r\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-D46ENBW51P\"></script>\r\n<script>\r\n  window.dataLayer = window.dataLayer || [];\r\n  function gtag(){dataLayer.push(arguments);}\r\n  gtag('js', new Date());\r\n\r\n  gtag('config', 'G-D46ENBW51P');\r\n  gtag('config', 'UA-87337378-1');\r\n</script>\r\n\r\n<meta charset=\"utf-8\">\r\n<!-- InstanceBeginEditable name=\"doctitle\" -->\r\n<title>料金所スタッフの仕事とは？｜阪神高速トール神戸</title>\r\n<meta name=\"Description\" content=\"阪神高速道路をご利用のお客様から通行料金を頂戴すること、 ETCや自動収受機をご利用のお客さまにトラブルがあった場合の応対があります。\" />\r\n<!-- InstanceEndEditable -->\r\n<meta http-equiv=\"Pragma\" content=\"no-cache\">\r\n<meta http-equiv=\"Cache-Control\" content=\"no-cache\">\r\n<meta name=\"author\" content=\"阪神高速トール神戸\" />\r\n<meta name=\"copyright\" content=\"阪神高速トール神戸\" />\r\n<meta name=\"robots\" content=\"all\" />\r\n<link href=\"../common/css/import.css?20260525121533\" rel=\"stylesheet\" type=\"text/css\" media=\"all\" />\r\n<!-- InstanceBeginEditable name=\"head\" -->\r\n<!-- InstanceEndEditable -->\r\n<!-- InstanceParam name=\"bodyID\" type=\"text\" value=\"\" -->\r\n<!-- InstanceParam name=\"g_menu\" type=\"text\" value=\"g_menu04\" -->\r\n<!-- InstanceParam name=\"contents\" type=\"text\" value=\"business\" -->\r\n<!-- InstanceParam name=\"filename\" type=\"text\" value=\"index02\" -->\r\n</head>\r\n\r\n<body id=\"business\" class=\"index02\">\r\n    <a name=\"top\" id=\"top\"></a>\r\n    <header id=\"header-frame\">\r\n\r\n      <div id=\"header\">\r\n        <h1>\r\n          <a href=\"/\">\r\n            <img src=\"/common/img/header01.png\" width=\"276\" height=\"38\" alt=\"阪神高速トール神戸株式会社\" />\r\n            <span>お客さまから愛される料金所を目指します</span>\r\n          </a>\r\n        </h1>\r\n        <div id=\"header_right\">\r\n          <p><a href=\"/sitemap/\">サイトマップ</a></p>\r\n          <div id=\"fontSize\">\r\n            <noscript><p>JavaScriptを使用しています。</p></noscript>\r\n            文字サイズ\r\n            <ul>\r\n              <li class=\"changeBtn\">小</li>\r\n              <li class=\"changeBtn\">中</li>\r\n              <li class=\"changeBtn\">大</li>\r\n            </ul>\r\n          </div>\r\n        </div>\r\n      </div><!-- //header -->\r\n\r\n      <nav id=\"nav\">\r\n        <ul>\r\n          <li class=\"nav01\"><a href=\"/\">トップページ<span>TOP PAGE</span></a></li>\r\n          <li class=\"nav02\"><a href=\"/corp_info/\">会社情報<span>CORPORATE INFORMATION</span></a></li>\r\n          <li class=\"nav03\"><a href=\"/corp_outline/\">会社概要<span>COMPANY PROFILE</span></a></li>\r\n          <li class=\"nav04\"><a href=\"/business/\">事業内容<span>BUSINESS CONTENTS</span></a></li>\r\n          <li class=\"nav05\">\r\n            <a href=\"javascript:void(0);\">採用情報<span>CAREER</span></a>\r\n            <ul class=\"nav--sub\">\r\n              <li><a href=\"/business_2/\">料金所スタッフ採用情報</a></li>\r\n              <li>\r\n                <a href=\"https://tenshoku.mynavi.jp/jobinfo-426307-3-6-1/?msockid=3d319ca12add6b111ec189be2b0f6a58\" target=\"_blank\" title=\"新しいウインドウが開きます。\" rel=\"noopener noreferrer\">\r\n                  本社採用情報\r\n                  <img src=\"/common/img/blank_icon--white.svg\" width=\"11\" height=\"10\" alt=\"\" class=\"blank\">\r\n                  <span class=\"note\">（マイナビ転職に移動します）</span>\r\n                </a>\r\n              </li>\r\n            </ul>\r\n          </li>\r\n        </ul>\r\n      </nav>\r\n\r\n    </header>\r\n\r\n\r\n\r\n\r\n<div id=\"changeArea\">\r\n<div id=\"main\">\r\n<!-- InstanceBeginEditable name=\"EditRegion3\" -->\r\n<h2><img src=\"img/h2.jpg\" width=\"950\" height=\"124\" alt=\"事業内容\" /></h2>\r\n<div class=\"clearfix mt25\">\r\n<div class=\"content\">\r\n<h3><img src=\"img/index02_tit01.jpg\" width=\"680\" height=\"41\" alt=\"料金所スタッフの仕事とは？\" /></h3>\r\n<p class=\"mt15 l160\">主な業務は、阪神高速道路をご利用のお客様から通行料金を頂戴すること、 ETCや自動収受機をご利用のお客さまにトラブルがあった場合の応対があります。<br />\r\nそれでは料金所スタッフの標準的な一日の仕事の流れをご紹介します。</p>\r\n<div class=\"clearfix\">\r\n<div>\t\r\n    <h4 class=\"mt30 mb30\"><img src=\"img/index02_img01.jpg\" width=\"445\" height=\"28\" alt=\"一日のタイムスケジュール\" /></h4>\r\n    \r\n    <div class=\"of-hide mb40\">\r\n      <h5 class=\"h-type3 mb20 flex flex-between\">\r\n        準備時間（朝礼等）\r\n        <span class=\"time\">8:15 a.m ～ 8:45 a.m</span>\r\n      </h5>\r\n      <div class=\"w445\">\r\n        <h6 class=\"h-type4 time mb20\">\r\n          <img src=\"img/img_time_815.png\" width=\"52\" height=\"52\" alt=\"8:15 a.m\" />\r\n          8:15 a.m ～ 8:30 a.m\r\n        </h6>\r\n        <div class=\"h-type5 ml25\">出勤</div>\r\n        <p class=\"business_p01\">出勤後、更衣、身だしなみチェック、携行品の確認等の業務の準備等を行う。</p>\r\n        <div class=\"center mt20 mb30\"><img src=\"img/index02_arrow.jpg\" alt=\"\"></div>\r\n    </div>\r\n      <div class=\"f_left w445\">\r\n        <h6 class=\"h-type4 time mb20\">\r\n          <img src=\"img/img_time_830.png\" width=\"52\" height=\"52\" alt=\"8:30 a.m\" />\r\n          8:30 a.m ～ 8:45a.m\r\n        </h6>\r\n        <div class=\"h-type5 ml25\">朝礼</div>\r\n        <p class=\"business_p01\">所長からの訓示とともに連絡事項や行事予定、工事情報などが伝達されます。</p>\r\n      </div>\r\n      <div class=\"f_right\">\r\n        <img src=\"img/index02_img08_v2.jpg\" width=\"210\" height=\"142\" alt=\"\" />\r\n      </div>\r\n    </div>\r\n    \r\n    <div class=\"of-hide mb40\">\r\n      <h5 class=\"h-type3 mb20 flex flex-between\">\r\n        勤務時間等\r\n        <span class=\"time note\">\r\n          <span><span class=\"notes\">（始業時間）</span>8:45 a.m</span> ～\r\n          <span><span class=\"notes\">（終業時間）</span>翌9:45a.m</span>\r\n        </span>\r\n      </h5>\r\n      <div class=\"f_left w445\">\r\n        <h6 class=\"h-type4 time mb20\">\r\n          <img src=\"img/img_time_845.png\" width=\"52\" height=\"52\" alt=\"8:45 a.m\" />\r\n          8:45 a.m ～ 9:15 a.m\r\n        </h6>\r\n        <div class=\"h-type5 ml25\">料金所へ移動</div>\r\n        <p class=\"business_p01\">営業所から料金所へ移動<br /><span class=\"bold color-red\">※料金所の場所によって移動時間が異なります。</span></p>\r\n        <div class=\"center mt20 mb30\"><img src=\"img/index02_arrow.jpg\" alt=\"\"></div>\r\n      </div>\r\n      <div class=\"f_right\">\r\n        <img src=\"img/index02_img09_v2.jpg\" width=\"210\" height=\"142\" alt=\"\" />\r\n      </div>\r\n      <div class=\"f_left w445\">\r\n        <h6 class=\"h-type4 time mb20\">\r\n          <img src=\"img/img_time_915.png\" width=\"52\" height=\"52\" alt=\"9:15 a.m\" />\r\n          9:15 a.m ～ 翌9:15 a.m\r\n        </h6>\r\n        <div class=\"h-type5 ml25\">料金所内での業務</div>\r\n        <p class=\"business_p01\">阪神高速道路の顔として、さまざまな面からお客さまのドライブをサポートします。</p>\r\n        <div class=\"ml25 mt5 l160 bold color-red\" style=\"padding-left: 1.2em;text-indent: -1.2em;\">\r\n          ※料金所での勤務時間は翌日の班が料金所へ到着後、交代となりますので料金所の場所によって勤務開始時間が異なります。\r\n        </div>\r\n        <div class=\"center mt20 mb30\"><img src=\"img/index02_arrow.jpg\" alt=\"\"></div>\r\n        <h6 class=\"h-type4 time mb20\">\r\n          <img src=\"img/img_time_915.png\" width=\"52\" height=\"52\" alt=\"9:15 a.m\" />\r\n          9:15 a.m ～ 9:45 a.m\r\n        </h6>\r\n        <div class=\"h-type5 ml25\">営業所へ帰所</div>\r\n        <p class=\"business_p01\">料金所から営業所へ帰所<br />\r\n        <span class=\"bold color-red\">※料金所の場所によって移動時間が異なります。</span></p>\r\n      </div>\r\n      <div class=\"f_right\">\r\n        <img src=\"img/index02_img10_v2.jpg\" width=\"210\" height=\"142\" alt=\"\" />\r\n      </div>\r\n    </div>\r\n    \r\n    <div class=\"of-hide mb40\">\r\n      <h5 class=\"h-type3 mb20 flex flex-between\">\r\n        整理時間（業務報告等）\r\n        <span class=\"time\">9:45 a.m ～ 10:15a.m</span>\r\n      </h5>\r\n      <div class=\"f_left w445\">\r\n        <h6 class=\"h-type4 time mb20\">\r\n          <img src=\"img/img_time_945.png\" width=\"52\" height=\"52\" alt=\"9:45 a.m\" />\r\n          9:45 a.m ～ 10:15 a.m\r\n        </h6>\r\n        <div class=\"h-type5 ml25\">業務報告</div>\r\n        <p class=\"business_p01\">営業所に帰所後、業務終了の報告、書類等の提出を行う。</p>\r\n        <div class=\"center mt20 mb30\"><img src=\"img/index02_arrow.jpg\" alt=\"\"></div>\r\n        <h6 class=\"h-type4 time mb20\">\r\n          <img src=\"img/img_time_1015.png\" width=\"52\" height=\"52\" alt=\"10:15 a.m\" />\r\n          10:15 a.m ～\r\n        </h6>\r\n        <div class=\"h-type5 ml25\">退社</div>\r\n        <p class=\"business_p01\">営業所への業務報告の終了後、勤務が終わります。お疲れ様でした。<br />自宅でゆっくり休んでください。</p>\r\n      </div>\r\n      <div class=\"f_right\">\r\n        <img src=\"img/index02_img11_v2.jpg\" width=\"210\" height=\"142\" alt=\"\" />\r\n      </div>\r\n    </div>\r\n    \r\n</div>\r\n\r\n</div>\r\n\r\n\r\n</div><!-- //content -->\r\n\r\n\t<div class=\"side\">\r\n\t\t<p><img src=\"img/side_tit.jpg\" width=\"240\" height=\"41\" alt=\"事業内容\" /></p>\r\n\t\t<ul>\r\n\t\t\t<li><a href=\"./\">事業内容</a></li>\r\n\t\t\t<li><a href=\"index02.html\" class=\"on\">料金所スタッフの仕事とは？</a></li>\r\n\t\t</ul>\r\n\t</div><!-- //side -->\r\n\r\n</div>\r\n<!-- InstanceEndEditable -->\r\n</div><!-- //main -->\r\n</div><!-- //changeArea -->\r\n\r\n<div id=\"pagetop\"><p><a href=\"#top\"><img src=\"/common/img/pagetop.jpg\" width=\"170\" height=\"26\" alt=\"ページトップへ戻る\" class=\"rollover\" /></a></p></div>\r\n<div id=\"footer\">\r\n\t<p><a href=\"/\">トップページ</a>　｜　\r\n    <a href=\"/corp_info/\">会社情報</a>　｜　\r\n    <a href=\"/corp_outline/\">会社概要</a>　｜　\r\n    <a href=\"/business/\">事業内容</a>　｜　\r\n    <a href=\"/news\">お知らせ</a>　｜　\r\n    <a href=\"/link/\">お役立ちリンク集</a>　｜　\r\n    <a href=\"/sitemap/\">サイトマップ</a>　｜　\r\n    <a href=\"/security/\">セキュリティポリシー</a>　｜　\r\n    <a href=\"/privacy/\">個人情報保護方針</a></p>\r\n</div><!-- //footer -->\r\n<div id=\"copyright\"><p>Copyright(c) Hanshin Expressway Toll KOBE Co., Ltd. All rights reserved.</p></div>\r\n\r\n<script type=\"text/javascript\" src=\"../common/js/jquery/jquery.min.js\"></script>\r\n<script type=\"text/javascript\" src=\"../common/js/fontsizechange.js\"></script>\r\n<script type=\"text/javascript\" src=\"../common/js/jquery.cookie.js\"></script>\r\n<script type=\"text/javascript\" src=\"../common/js/jquery.rollover.js\"></script>\r\n<script type=\"text/javascript\" src=\"../common/js/common.js\"></script>\r\n<!-- InstanceBeginEditable name=\"js\" -->\r\n<!-- InstanceEndEditable -->\r\n<script type=\"text/javascript\" src=\"/_Incapsula_Resource?SWJIYLWA=719d34d31c8e3a6e6fffd425f7e032f3&ns=9&cb=957378600\" async></script></body>\r\n<!-- InstanceEnd --></html>\r\n","finalUrl":"https://www.hanshin-tollkobe.co.jp/business/index02.html","rendered":false,"_cachedAt":"2026-06-22T17:43:19.645Z"}