                                     <span class=\"card-label-list\">\r\n                                                                                            <span class=\"text-label\">シティプロモーション</span>\r\n                                                                          <span class=\"text-label\">少子化・男女共同参画</span>\r\n                                                                          <span class=\"text-label\">地方創生</span>\r\n                                                                          <span class=\"text-label\">働き方改革</span>\r\n                                                                          <span class=\"text-label\">女性活躍</span>\r\n                                                                          <span class=\"text-label\">採用</span>\r\n                                                                          <span class=\"text-label\">WEB</span>\r\n                                                      </span>\r\n                                                      <span class=\"card-title\">ホームページ制作事業／気仙沼就労環境改善協議会（気仙沼 JOB BASE）様</span>\r\n                  <span class=\"card-date\">2025.10.31</span>\r\n                </span>\r\n              </a>\r\n            </li>\r\n\t\t\t\t\t            <li class=\"card-list-item\">\r\n              <a href=\"https://www.u-media.jp/media/case_study/a439\" class=\"card\">\r\n                <span class=\"card-img\">\r\n                                    <span class=\"blog-image-src\" style=\"background-image: url('https://www.u-media.jp/dcms_media/image/ネッツさん研修講師0418_サムネイル.jpg');\"></span>\r\n                                  </span>\r\n                <span class=\"card-body\">\r\n                                                                        <span class=\"card-label-list\">\r\n                                                        <span class=\"text-label\">トピックス</span>\r\n                                                                                           