{"url":"https://www.nishi-tc.co.jp/recruit/voice03.html","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n  <head>\n    <meta charset=\"utf-8\" />\n    <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge,chrome=1\" />\n    <meta\n      name=\"keywords\"\n      content=\"西谷技術,西谷技術コンサルタント,西谷技術コンサルタント,新卒採用,新卒,鳥取,設計,地質調査,測量調査\"\n    />\n    <meta\n      name=\"description\"\n      content=\"西谷技術コンサルタント株式会社 2014年入社の設計部の先輩の声をお届けします。女性社員にスポットをあて、インタビューしました。\"\n    />\n    <title>\n      先輩社員からのメッセージvol.3 2026年度新卒採用情報\n      西谷技術コンサルタント株式会社\n    </title>\n    <link href=\"css/reset.css\" rel=\"stylesheet\" type=\"text/css\" />\n    <link href=\"css/common.css\" rel=\"stylesheet\" type=\"text/css\" />\n    <link href=\"css/voice.css\" rel=\"stylesheet\" type=\"text/css\" />\n    <link rel=\"stylesheet\" href=\"css/drawer.min.css\" />\n    <link rel=\"stylesheet\" href=\"css/animate.css\" />\n    <script\n      type=\"text/javascript\"\n      src=\"https://ajax.googleapis.com/ajax/libs/jquery/1.9.1/jquery.min.js\"\n    ></script>\n    <script type=\"text/javascript\" src=\"js/yuga.js\"></script>\n    <script src=\"js/wow.min.js\"></script>\n    <script type=\"text/javascript\" charset=\"utf-8\">\n      new WOW().init();\n    </script>\n    <script type=\"text/javascript\" charset=\"utf-8\">\n      $(document).ready(function () {\n        $(\".drawer\").drawer();\n      });\n    </script>\n  </head>\n\n  <body class=\"drawer drawer--left\">\n    <!--ここからヘッダー-->\n    <header style=\"z-index: 1000\">\n      <div class=\"top_navi\">\n        <ul>\n          <li>\n            <a href=\"../index.html\"\n              ><img src=\"images/navi/navi_nishitani.png\"\n            /></a>\n          </li>\n          <li style=\"margin: 0px 100px 0px 50px\">\n            <a href=\"./index.html\"\n              ><img src=\"images/navi/recruit_title.png\"\n            /></a>\n          </li>\n          <li>\n            <a\n              href=\"https://job.mynavi.jp/28/pc/search/corp207090/outline.html\"\n              target=\"_blank\"\n              ><img src=\"images/navi/navi_my.png\"\n            /></a>\n          </li>\n          <li style=\"margin: 0px 0px 0px 50px\">\n            <a href=\"https://works.do/R/ti/p/saiyo@nishi-tc\" target=\"_blank\"\n              ><img src=\"images/navi/QRcode.png\"\n            /></a>\n          </li>\n        </ul>\n      </div>\n      <nav class=\"global_menu\">\n        <ul>\n          <li class=\"menu\"><a href=\"index.html\">採用トップ</a></li>\n          <li class=\"menu\">\n            <a href=\"#\">メッセージ</a>\n            <ul class=\"child_menu\">\n              <p class=\"navi_komidashi\">先輩社員からのメッセージ</p>\n              <li>\n                <a href=\"./voice01.html\"\n                  ><img src=\"images/navi/navi01.png\" class=\"icon_photo\" /><span\n                    class=\"navi_txt\"\n                    >調査部 防災設計</span\n                  ></a\n                >\n              </li>\n              <li>\n                <a href=\"./voice02.html\"\n                  ><img src=\"images/navi/navi02.png\" class=\"icon_photo\" /><span\n                    class=\"navi_txt\"\n                    >設計部 道路設計</span\n                  ></a\n                >\n              </li>\n              <li>\n                <a href=\"./voice03.html\"\n                  ><img src=\"images/navi/navi03.png\" class=\"icon_photo\" /><span\n                    class=\"navi_txt\"\n                    >調査部 地質調査</span\n                  ></a\n                >\n              </li>\n              <li>\n                <a href=\"./voice05.html\"\n                  ><img src=\"images/navi/navi04.png\" class=\"icon_photo\" /><span\n                    class=\"navi_txt\"\n                    >地籍調査部</span\n                  ></a\n                >\n              </li>\n              <li>\n                <a href=\"./voice06.html\"\n                  ><img src=\"images/navi/navi05.png\" class=\"icon_photo\" /><span\n                    class=\"navi_txt\"\n                    >測量調査部<br />補償コンサルタント</span\n                  ></a\n                >\n              </li>\n              <li>\n                <a href=\"./voice04.html\"\n                  ><img src=\"images/navi/navi06.png\" class=\"icon_photo\" /><span\n                    class=\"navi_txt\"\n                    >企画管理部 営業</span\n                  ></a\n                >\n              </li>\n\n              <p class=\"navi_komidashi\">\n                上司からのメッセージ／採用担当からのメッセージ\n              </p>\n              <li>\n                <a href=\"./career01.html\"\n                  ><img src=\"images/navi/navi07.png\" class=\"icon_photo\" /><span\n                    class=\"navi_txt\"\n                    >設計部 部長</span\n                  ></a\n                >\n              </li>\n              <li>\n                <a href=\"./career02.html\"\n                  ><img src=\"images/navi/navi08.png\" class=\"icon_photo\" /><span\n                    class=\"navi_txt\"\n                    >地籍調査部 課長</span\n                  ></a\n                >\n              </li>\n              <li>\n                <a href=\"./career03.html\"\n                  ><img src=\"images/navi/navi09.png\" class=\"icon_photo\" /><span\n                    class=\"navi_txt\"\n                    >調査部 維持保全課 課長</span\n                  ></a\n                >\n              </li>\n              <li>\n                <a href=\"./career04.html\"\n                  ><img src=\"images/navi/navi10.png\" class=\"icon_photo\" /><span\n                    class=\"navi_txt\"\n                    >企画経理部 企画管理課<br />総務担当課長</span\n                  ></a\n                >\n              </li>\n              <li>\n                <a href=\"./voice07.html\"\n                  ><img src=\"images/navi/navi_mess.png\" /><span\n                    class=\"navi_txt\"\n                  ></span\n                ></a>\n              </li>\n            </ul>\n          </li>\n\n          <li class=\"menu\">\n            <a href=\"#\">インタビュー</a>\n            <ul class=\"child_menu\">\n              <li class=\"inta\">\n                <a href=\"./job.html\"><img src=\"images/navi/navi_i01.png\" /></a>\n              </li>\n              <li class=\"inta\">\n                <a href=\"./staff.html\"\n                  ><img src=\"images/navi/navi_i02.png\"\n                /></a>\n              </li>\n              <li class=\"inta\">\n                <a href=\"./staff.html#hope\"\n                  ><img src=\"images/navi/navi_i03.png\"\n                /></a>\n              </li>\n            </ul>\n          </li>\n\n          <li class=\"menu\">\n            <a href=\"#\">募集要項</a>\n            <ul class=\"child_menu\">\n              <li>\n                <a href=\"./new-job-description.html\"\n                  ><img src=\"images/navi/job_description_01.png\"\n                /></a>\n              </li>\n              <li>\n                <a href=\"./mid-job-description.html\"\n                  ><img src=\"images/navi/job_description_02.png\"\n                /></a>\n              </li>\n            </ul>\n          </li>\n\n          <li class=\"menu_i\">\n            <a href=\"./internship.html\">インターンシップ</a>\n          </li>\n\n          <li class=\"menu_i\">\n            <a href=\"./explanation.html\">会社説明会</a>\n          </li>\n          <li class=\"menu_car\">\n            <a href=\"./mid-career.html\">キャリア採用はこちら</a>\n          </li>\n        </ul>\n      </nav>\n    </header>\n    <!--ここまでヘッダー-->\n    <h1 class=\"membertitle03\">\n      <span class=\"number\"\n        ><img\n          src=\"images/member/geological2011.png\"\n          width=\"240\"\n          height=\"240\"\n          alt=\"\"\n      /></span>\n    </h1>\n    <!--ここからメインコンテンツ-->\n    <div id=\"content\">\n      <!--ここからメッセージ-->\n      <ul class=\"message\">\n        <li class=\"no01q1\">\n          <p>\n            入社したきっかけを<br />\n            教えてください。\n          </p>\n        </li>\n        <li class=\"answer\">\n          私は、大学で地球科学について学びました。自分が育った鳥取県で、大学で学んだことを生かせる会社に就職したいと思い、採用試験に挑みました。当時は、リーマンショック後の建設業界全体が不景気な時代でしたが、その中でも採用募集を行っていたこの会社に将来性を感じました。\n        </li>\n        <li class=\"no01q1\">\n          <p>\n            現在の仕事内容を<br />\n            教えてください。\n          </p>\n        </li>\n\n        <li class=\"answer\">\n          私は地盤調査や防災分野に係る部署に所属しています。地盤調査といっても様々ですが、例えば社会インフラである橋梁や砂防堰堤などの設計では、目に見えない地中の情報（地層構成、地下水位、支持層の深度など）が不可欠となります。その情報を得るために、どのような調査を行ったらよいのかを計画し、発注者と打合せを行いながら業務を進めます。専門知識と経験から培った技術を駆使し、目的達成のための最適な調査を提案することが腕の見せ所です。目的によっては、調査によって得た地盤のモデルやパラメータを利用し、地震時の液状化、斜面安定、地盤沈下などの解析を行い、地盤が健全であるのかどうかを分析・評価します。\n        </li>\n\n        <li class=\"no01q1\">\n          <p>\n            キャリアアップ<br />\n            について\n          </p>\n        </li>\n\n        <li class=\"answer\">\n          当社は資格取得のための体系的なサポートが整っています（例えば技術士試験に対する年間を通した模擬試験、有資格者による添削指導など）。私もその場を利用し技術士を取得することができました。今後はさらなる技術力の向上および実務経験を身に着け、若手技術者とともに会社を盛り上げていきたいです。\n        </li>\n\n        <li class=\"q_blue\">休日の過ごし方は？</li>\n        <li class=\"a_blue\">\n          家族と過ごすことが多いです。天気が良い日は子供と妻と３人で公園など子供の遊び場に出かけたりします。近所の公園だけでなく、時にはお弁当を持って県内の遊び場をめぐっています。そこでも移動中に自分が携わって完成した道路などの施設や、散歩中に岩石や地層が見える露頭があるとついつい見てしまいます。自分を真似してか、いつの間にか子供も石ころを拾って帰ってくることがあります。\n        </li>\n        <li class=\"no01q1\">\n          <p>\n            後輩への<br />\n            メッセージを<br />\n            お願いします。\n          </p>\n        </li>\n        <li class=\"answer\">\n          私たちの専門は、自然を相手にします。大学時代に、地質学や土木工学を学んでいたからといって、すぐに業務をこなせるような簡単な仕事ではありません。また、専門知識以外にもコミュニケーション能力やマネジメント能力なども求められます。自身がそうであったように、OJTやOFF-JTを通して、技術者として一緒に成長しましょう。\n        </li>\n        <li class=\"photo\">\n          <img\n            src=\"images/member/no03photo_02.jpg\"\n            width=\"665\"\n            height=\"375\"\n            alt=\"\"\n          />\n        </li>\n      </ul>\n      <!--ここまでメッセージ-->\n\n      <!--ここからスケジュール-->\n\n      <div class=\"schedule\">\n        <p class=\"oneday\">ある1日のスケジュール</p>\n        <div class=\"timebox\">\n          <div class=\"time\">7:45</div>\n          <div class=\"more\">\n            <p class=\"txt\">出社</p>\n          </div>\n        </div>\n        <div class=\"timebox\">\n          <div class=\"time\">8:15</div>\n          <div class=\"more\">\n            <p class=\"txt\">始業・朝ミーティング</p>\n            <p>\n              朝礼後、課員で朝ミーティングを行います。この場では１日の作業内容の確認の他、業務の進捗状況や問題点などの情報を共有します。\n            </p>\n          </div>\n        </div>\n        <div class=\"timebox\">\n          <div class=\"time\">8:45</div>\n          <div class=\"more\">\n            <p class=\"txt\">現場作業</p>\n            <p>\n              自分が担当する現場へ行き、現地調査や観測を行います。地質調査の業務は、協力会社さんにボーリング作業を依頼することもあります。専門的な調査だけでなく、現地作業での安全管理や進捗管理を行うことも重要な仕事です。\n            </p>\n          </div>\n        </div>\n        <div class=\"timebox\">\n          <div class=\"time\">12:00</div>\n          <div class=\"more\">\n            <p class=\"txt\">昼休憩</p>\n            <p>\n              日によりますが、終日外業の日には、現場周辺で休憩することもあります。\n            </p>\n          </div>\n        </div>\n        <div class=\"timebox\">\n          <div class=\"time\">13:00</div>\n          <div class=\"more\">\n            <p class=\"txt\">内業</p>\n            <p>\n              現地で得た調査結果の整理を行ったり、その結果を基に地盤の解析を行います。解決し難い問題点が発生した時には、上司や他分野の技術者から意見を聞くなどして、解決策を導きます。\n            </p>\n          </div>\n        </div>\n        <div class=\"timebox\">\n          <div class=\"time\">15:30</div>\n          <div class=\"more\">\n            <p class=\"txt\">発注者（業務の委託者）との打ち合わせ</p>\n            <p>\n              調査や解析結果の報告を行います。業務の目的が達成できるよう、追加調査など技術的な提案を行うこともあります。また、打合せの後は、議事録を作成し記録を残しておきます。\n            </p>\n          </div>\n        </div>\n        <div class=\"timebox\">\n          <div class=\"time\">17:15</div>\n          <div class=\"more\">\n            <p class=\"txt\">定時</p>\n            <p>\n              作業の進捗状況に応じて、必要な場合は残業を行います。翌日の現場準備や予定を確認して退社します。\n            </p>\n          </div>\n        </div>\n        <div class=\"timebox\">\n          <div class=\"time\">19:00</div>\n          <div class=\"more\">\n            <p class=\"txt\">退社</p>\n          </div>\n        </div>\n\n        <div class=\"timebox2\">\n          <div class=\"time\">補足</div>\n          <div class=\"more\">\n            <p>\n              ※担当している業務や時期にもよりますが、外業（現場作業）と内業の割合は4：6が目安となります。\n            </p>\n          </div>\n        </div>\n      </div>\n      <!--ここまでスケジュール-->\n    </div>\n    <!--ここまでメインコンテンツ-->\n\n    <!--ここからメンバーリンク-->\n    <div class=\"members\">\n      <ul class=\"member_link\">\n        <li class=\"member01\">\n          <a href=\"voice01.html\"><em>設計部</em></a>\n        </li>\n        <li class=\"member02\">\n          <a href=\"voice02.html\"><em>設計部</em></a>\n        </li>\n        <li class=\"member03on\">\n          <a href=\"voice03.html\"><em>設計部</em></a>\n        </li>\n        <li class=\"member04\">\n          <a href=\"voice05.html\"><em>地籍調査部</em></a>\n        </li>\n        <li class=\"member05\">\n          <a href=\"voice06.html\"><em>地籍調査部</em></a>\n        </li>\n        <li class=\"member06\">\n          <a href=\"voice04.html\"><em>測量調査部</em></a>\n        </li>\n        <li class=\"member08\">\n          <a href=\"career01.html\"\n            ><em>上司からのメッセージ設計本部 設計部長</em></a\n          >\n        </li>\n        <li class=\"member09\">\n          <a href=\"career02.html\"\n            ><em>上司からのメッセージ地籍調査部 一課長</em></a\n          >\n        </li>\n        <li class=\"member10\">\n          <a href=\"career03.html\"\n            ><em>上司からのメッセージ調査部 維持保全課長</em></a\n          >\n        </li>\n        <li class=\"member11\">\n          <a href=\"career04.html\"\n            ><em>上司からのメッセージ企画管理部企画管理課総務担当課長</em></a\n          >\n        </li>\n        <li class=\"un-woman\">\n          <a href=\"staff.html\"><img src=\"images/member/un-woman.png\" /></a>\n        </li>\n      </ul>\n    </div>\n    <!--ここまでメンバーリンク-->\n    <!--ここからエントリーボックス-->\n    <div class=\"entry