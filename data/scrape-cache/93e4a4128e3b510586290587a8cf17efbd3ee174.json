{"url":"https://www.kidsfore.co.jp/recruit_voice/recruit-voice-kawai","html":"\n\n\n<!DOCTYPE html>\n<html>\n\n<head>\n    <meta charset=\"UTF-8\">\n\n    <title>キッズフォレ</title>\n\n    <link href=\"https://www.kidsfore.co.jp/wp/wp-content/themes/biz-vektor-child/recruit_style.css\" rel=\"stylesheet\" type=\"text/css\">\n\n</head>\n\n<body>\n\n    <header>\n        <div id=\"header-image\">\n            <div id=\"header-top\">\n                <div id=\"header-logo\">\n                    <a href=\"https://www.kidsfore.co.jp/recruit\"><img src=\"https://www.kidsfore.co.jp/wp/wp-content/themes/biz-vektor-child/images/header-logo.png\"></a>\n                </div>\n\t\t\t\t<!--\n                <div id=\"header-entry\">\n                    <a href=\"https://www.kidsfore.co.jp/recruit_entry\">エントリーする</a>\n                </div>\n\t\t\t\t-->\n            </div>\n                        <img src=\"https://www.kidsfore.co.jp/wp/wp-content/themes/biz-vektor-child/images/header-voice.png\">\n                    </div>\n        <div id=\"header-nav\">\n            <ul>\n                <li><a href=\"https://www.kidsfore.co.jp/recruit_message\" id=\"list-message\">メッセージ</a></li>\n                <li><a href=\"https://www.kidsfore.co.jp/recruit_voice\" id=\"list-voice\">先輩スタッフの声</a></li>\n                <li><a href=\"https://www.kidsfore.co.jp/recruit_support\" id=\"list-support\">スタッフサポート</a></li>\n\t\t\t\t<li><a href=\"https://www.kidsfore.com/\" id=\"list-requirement\" target=\"_blank\" rel=\"nofollow\">募集要項</a></li>\n              <!--  <li><a href=\"https://www.kidsfore.co.jp/recruit_requirements\" id=\"list-requirement\">募集要項</a></li>\n                -->\n<!--                <li><a href=\"https://www.kidsfore.co.jp/facilities\" id=\"list-facility\">施設紹介</a></li>\n -->\n                <li><a href=\"http://www.kidsfore.co.jp/facilities/  \" id=\"list-facility\">施設紹介</a></li>\n                <li><a href=\"http://www.kidsfore.co.jp/about/outline/\" id=\"list-company\">企業情報</a></li>\n<!---     \n                <li><a href=\"https://www.kidsfore.co.jp/about\" id=\"list-company\">企業情報</a></li>\n-->     \n            </ul>\n        </div>\n    </header>\n   \n    <div id=\"voice\" class=\"container\">\n        <div class=\"contents\">\n            <div id=\"voice-top\">\n                <h1>先輩スタッフの声</h1>\n            </div>\n            <div id=\"voice-content\">\n                <div id=\"voice-left\">\n                    <img src=\"https://www.kidsfore.co.jp/wp/wp-content/themes/biz-vektor-child/images/kawai_face.png\">\n                    <img id=\"voice-aki\" class=\"back-image\" src=\"https://www.kidsfore.co.jp/wp/wp-content/themes/biz-vektor-child/images/aki.png\">\n                </div>\n                <div id=\"voice-right\">\n                    <div class=\"voice-text\">\n                        <h2>先生たちが仕事への楽しさを感じ生き生きと取り組める環境を作りたい。\n</h2>\n  <!--                      <img src=\"https://www.kidsfore.co.jp/wp/wp-content/themes/biz-vektor-child/images/recruit_voice.png\">\n  -->\n                        <img src=\"https://www.kidsfore.co.jp/wp/wp-content/themes/biz-vektor-child/images/kawai_nn.png\">                        \n                    </div>\n                    <div class=\"voice-text\">\n                        <h3>この会社に決めた理由</h3>\n                        <p>\n   <!--                     <img src=\"https://www.kidsfore.co.jp/wp/wp-content/themes/biz-vektor-child/images/voice1.png\" align=\"left\">\n   -->\n                        園のホームページを見てみると、英語や自然体験活動、MUSICなど色々な活動に取り組んでいる子どもの園での様子がブログに載っていて、その写真の中の子どもたちの笑顔が生き生きとしいていました。色々な教育の要素が含まれる環境で、自己の保育や教育の幅を広げながら働き、子ども達が毎日ニコニコと笑顔で過ごす関わりが出来るのではないかという期待が就職の一番の決め手になりました。\n<br clear=\"left\">\n                        </p>\n                    </div>\n                    <div class=\"voice-text\">\n                        <h3>今の仕事のやりがい</h3>\n                        <p>\n  <!--                      <img src=\"https://www.kidsfore.co.jp/wp/wp-content/themes/biz-vektor-child/images/voice2.png\" align=\"right\">\n   -->\n                        園長や主任の立場を経験して、自分が仕事をしていることで、子ども達が楽しく幸せに過ごす日々を送り、保護者の方も「この園に預けてよかった」と思えるような園にすることです。そして、先生たちが仕事に対して楽しさを感じ、生き生きと仕事に取り組める環境を作っていきたいと思っています。一番のやりがいは、子どもや職員に教育する中で、その関わった人たちが成長したと実感したとき。その積み重ねで、関わった人が大きく成長していってもらいたいと思っています。\n                                                <br clear=\"right\">\n                        </p>\n                    </div>\n                    <div class=\"voice-text\">\n                        <h3>みなさまへのメッセージ</h3>\n                        <p>キッズフォレでは、保育以外の学びが多くあります。ENGLISHでは、外国人講師の先生との関わりや指導方法を学んだり、SPORTS、MUSIC、DANCEなどは、教えるプロである外部講師の先生の指導を身近に感じることが出来るので、保育の幅が広がったり、指導力の向上も出来ます。そして、他の保育園よりも社会に出る機会も多いため、閉鎖されている保育業界と捉われがちですが、良い意味で、そういった印象を払拭してくれる保育園だと思います。\n                        </p>\n                    </div>\n                </div>\n            </div>\n            <div id=\"voice-staff\">\n                <div class=\"staff\">\n                    <a href=\"https://www.kidsfore.co.jp/recruit_voice/recruit-voice-yamamoto\"><img src=\"https://www.kidsfore.co.jp/wp/wp-content/themes/biz-vektor-child/images/yamamoto.JPG\"></a>\n                    <h4>園長</h4>\n                    <p>山元 さおり先生</p>\n                </div>\n                <div class=\"staff\">\n                    <a href=\"https://www.kidsfore.co.jp/recruit_voice/\"><img src=\"https://www.kidsfore.co.jp/wp/wp-content/themes/biz-vektor-child/images/katou.png\">\n                    <h4>主任保育士</h4>\n                    <p>加藤 民歌先生</p>\n                </div>\n                <div class=\"staff\">\n                    <a href=\"https://www.kidsfore.co.jp/recruit_voice/recruit-voice-kawai\"><img src=\"https://www.kidsfore.co.jp/wp/wp-content/themes/biz-vektor-child/images/kawai.jpg\">\n                    <h4>指導主事</h4>\n                    <p>川井 健司先生</p>\n                </div>\n                <div class=\"staff\">\n                    <a href=\"https://www.kidsfore.co.jp/recruit_voice/recruit-voice-kasahara\"><img src=\"https://www.kidsfore.co.jp/wp/wp-content/themes/biz-vektor-child/images/sasabara.png\">\n                    <h4>管理栄養士</h4>\n                    <p>笠原 ひかる先生</p>\n                </div>\n                <div class=\"staff\">\n                    <a href=\"https://www.kidsfore.co.jp/recruit_voice/recruit-voice-koyama\"><img src=\"https://www.kidsfore.co.jp/wp/wp-content/themes/biz-vektor-child/images/koyama.JPG\">\n                    <h4>保育士</h4>\n                    <p>小山 雅美先生</p>\n                </div>\n                <div class=\"staff\">\n                    <a href=\"https://www.kidsfore.co.jp/recruit_voice/recruit-voice-urushihara\"><img src=\"https://www.kidsfore.co.jp/wp/wp-content/themes/biz-vektor-child/images/urushibara.JPG\">\n                    <h4>保育士</h4>\n                    <p>漆原 萌乃先生</p>\n                </div>\n                <img id=\"voice-bird\" class=\"back-image\" src=\"https://www.kidsfore.co.jp/wp/wp-content/themes/biz-vektor-child/images/bird.png\">\n                <img id=\"voice-plant\" class=\"back-image\" src=\"https://www.kidsfore.co.jp/wp/wp-content/themes/biz-vektor-child/images/plant.png\">\n            </div>\n        </div>\n    </div>\n    \n    <div id=\"bottom-menu\">\n        <ul>\n             <li><a href=\"https://www.kidsfore.co.jp/wp/wp-content/themes/biz-vektor-child/images/recruit_movie.mp4\"><img src=\"https://www.kidsfore.co.jp/wp/wp-content/themes/biz-vektor-child/images/kidsfore-btn.png\"></a></li>\n            <li><a href=\"https://www.kidsfore.co.jp/wp/wp-content/themes/biz-vektor-child/images/athoiku.pdf\"><img src=\"https://www.kidsfore.co.jp/wp/wp-content/themes/biz-vektor-child/images/atorie-btn.png\"></a></li>\n            <li><a href=\"https://www.kidsfore.co.jp/recruit_blog\"><img src=\"https://www.kidsfore.co.jp/wp/wp-content/themes/biz-vektor-child/images/blog-btn.png\"></a></li>\n        </ul>\n    </div>\n\n\n\n<footer>\n    <div id=\"footer-inner\">\n        <div id=\"footer-top\">\n            <