ilformpro/mailformpro.cgi\" method=\"post\">\r\n      <div class=\"form\">\r\n        <h3 class=\"form__title\">レンタル・商品に関するお問合せ</h3>\r\n        <div class=\"form__block\">\r\n          <div class=\"form__box\">\r\n            <p class=\"form__item\">件名<span style=\"color:#ff0000;\">（必須）</span></p>\r\n            <p class=\"form__input\"><input type=\"text\" name=\"件名\" class=\"form__input-txt\" required=\"required\"></p>\r\n          </div>\r\n          <div class=\"form__box\">\r\n            <p class=\"form__item\">お名前<span style=\"color:#ff0000;\">（必須）</span></p>\r\n            <p class=\"form__input\"><input type=\"text\" name=\"お名前\" class=\"form__input-txt\" required=\"required\"></p>\r\n          </div>\r\n          <div class=\"form__box\">\r\n            <p class=\"form__item\">ご住所<span style=\"color:#ff0000;\">（必須）</span></p>\r\n            <p class=\"form__input\">\r\n              <span class=\"zip\">〒</span>\r\n              <span><input type=\"text\" name=\"郵便番号\" class=\"form__input-txt input-zip\" required=\"required\"></span>\r\n              <span class=\"form__input__address\"><input type=\"text\" name=\"ご住所\" class=\"form__input-txt\" required=\"required\"></span></p>\r\n          </div>\r\n          <div class=\"form__box\">\r\n            <p class=\"form__item\">電話番号<span style=\"color:#ff0000;\">（必須）</span></p>\r\n            <p class=\"form__input\"><input type=\"text\" name=\"電話番号\" class=\"form__input-txt\" required=\"required\"></p>\r\n          </div>\r\n          <div class=\"form__box\">\r\n            <p class=\"form__item\">ＦＡＸ番号</p>\r\n            <p class=\"form__input\"><input type=\"text\" name=\"ＦＡＸ番号\" class=\"form__input-txt\"></p>\r\n          </div>\r\n          <div class=\"form__box\">\r\n            <p class=\"form__item\">Ｅ-ＭＡＩＬ<span style=\"color:#ff0000;\">（必須）</span></p>\r\n            <p class=\"form__input\"><input type=\"text\" data-type=\"email\" name=\"email\" class=\"form__input-txt\" required=\"required\"></p>\r