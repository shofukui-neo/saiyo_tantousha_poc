r>\r\n            たゆみない前進を続けていきます。</p>\r\n        </div>\r\n        <p><a class=\"btn key-btn\" href=\"./corporate/\">会社案内</a></p>\r\n      </div>\r\n    </div>\r\n  </section>\r\n<style>\r\ndiv.area{display:inline-block; margin-left:auto; margin-right:auto; text-align:left;}\r\na.news2{padding-left:172px!important;}\r\n@media screen and (max-width: 998px) {a.news2{padding-left:10px!important;}}\r\n@media screen and (max-width: 480px) {}\r\n</style>\r\n<section id=\"attentionNews\">\r\n<div class=\"area\">重要なお知らせ　＞<br class=\"sp\">\r\n<a href=\"news/20260512.html\" target=\"_blank\">セコム・ホームセキュリティご契約料金変更のお知らせ</a><br>\r\n<a class=\"news2\" href=\"news/20250813.html\" target=\"_blank\">AED(自動体外式除細動器)「AED360P／450P」自主回収と交換のお知らせ</a><br>\r\n<a class=\"news2\" href=\"news/20250515.html\" target=\"_blank\">セコムになりすました「不審電話・SMS」「メール」「ウェブサイト」にご注意ください</a><br>\r\n<a class=\"news2\" href=\"news/20241024.html\" target=\"_blank\">多発する強盗事件のお見舞いと対策について</a><br>\r\n<a class=\"news2\" href=\"news/20240819.html\" target=\"_blank\">法人向けセキュリティサービスご契約料金変更のお知らせ</a><br>\r\n<a class=\"news2\" href=\"news/20240806.html\" target=\"_blank\">セキュリティシステムの非常用バッテリーの不具合による液漏れのお詫び</a>\r\n</div>\r\n</section>\r\n\r\n  <section id=\"service\">\r\n    <div class=\"title\">\r\n      <p>SERVICE</p>\r\n      <h2>サービス・商品</h2>\r\n    </div>\r\n    <p class=\"text-center text-secondary f-14 mb-20\">山梨エリアで防犯・防災など、ご家庭・法人向けにトータルセキュリティをご提案しています。</p>\r\n    <div class=\"inner2\">\r\n      <div class=\"personal\"><a href=\"./personal/\"><img src=\"./common/images/top_personal.jpg\" alt=\"個人のお客さま\" class=\"fade\" width=\"100\">\r\n        <span class=\"bg\"><img src=\"./common/images/top_personal_bg.png\" alt=\"\" class=\"fade\"></span>\r\n        <div class=\"text fade\">\r\n          <h3>個人のお客さま</h3>\r\n          <p>ホームセキュリティ</p>\r\n        </div>\r\n        </a></div>\r\n      <div class=\"business\"><a href=\"./business/\"><img src=\"./common/images/top_business.jpg\" alt=\"法人のお客さま\" class=\"fade\">\r\n        <span class=\"bg\"><img src=\"./common/images/top_business_bg.png\" alt=\"\" class=\"fade\"></span>\r\n        <div class=\"text fade\">\r\n          <h3>法人のお客さま</h3>\r\n          <p>オフィスセキュリティ</p>\r\n        </div>\r\n        </a> </div>\r\n    </div>\r\n  </section>\r\n  <section id=\"rucruit\">\r\n  <div class=\"title\">\r\n      <p>RECRUIT</p>\r\n      <h2>採用情報</h2>\r\n    </div>\r\n    <p class=\"text-center text-secondary f-14 mb-20\">地元山梨に根ざして、変わりゆく社会に、変わらぬ安心を提供しています。</p>\r\n    <div class=\"inner\">\r\n      <div class=\"stripe\">\r\n        <ul>\r\n          <li><a class=\"btn\" href=\"./recruit/guidelines1.html\">\r\n            <p>新卒採用</p>\r\n            </a></li>\r\n          <li><a class=\"btn\" href=\"./recruit/guidelines2.html\">\r\n            <p>キャリア採用</p>\r\n            </a></li>\r\n          <li><a class=\"btn\" href=\"./recruit/guidelines4.html\">\r\n            <p>キャリア採用<br>\r\n              <span class=\"f-12\">（セコムジャスティック山梨）</span></p>\r\n            </a></li>\r\n        </ul>\r\n      </div>\r\n    </div>\r\n    <p class=\"text-center mt-20\"><a class=\"btn default large\" href=\"./recruit/\">採用情報</a></p>\r\n    <p class=\"text-center mt-20\">\r\n      <!-- Begin mynavi Navi Link -->\r\n      <a href=\"https://job.mynavi.jp/27/pc/search/corp214228/outline.html\" target=\"_blank\">\r\n        <img src=\"https://job.mynavi.jp/conts/kigyo/2027/logo/banner_entry_130_130.gif\" alt=\"マイナビ2027\" border=\"0\">\r\n      </a>\r\n      <!-- End mynavi Navi Link -->\r\n      エントリーをお待ちしています！\r\n    </p>\r\n<!--p class=\"text-center mt-20 rec_movie\">\r\n  <a href=\"https://youtu.be/8Ri1_eInl88?si=0YbNRlX6qlfbjLqQ\" target=\"_blank\"><img src=\"./common/images/202501recruit_yamanasi.png\" alt=\"動画イメージ\" border=\"0\"></a>\r\n  セコム山梨社員インタビュー動画<br>\r\n<a class=\"btn default\" href=\"https://youtu.be/8Ri1_eInl88?si=0YbNRlX6qlfbjLqQ\" target=\"_blank\">動画を見る</a>\r\n</p-->\r\n  </section>\r\n  <!--section id=\"newsArea\">\r\n    <div class=\"inner\">\r\n      <div cl