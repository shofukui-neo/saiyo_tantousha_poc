img src=\"img/top/btn_video_trg.png\" alt> </div>\r\n    </a> </section>\r\n  <div id=\"iframe-v\" class=\"jst_video lity-hide\" style=\"overflow:auto; background:#FDFDF6; width:800px; max-width:100%;\">\r\n    <iframe src=\"https://api01-platform.stream.co.jp/apiservice/plt3/MzYyNQ%3d%3d%23OTAy%23280%23168%230%2337E6A0D86400%23OzEwOzEwOzEw%23\" width=\"100%\" height=\"100%\" style=\"position:absolute\" frameborder=\"0\" allowfullscreen referrerpolicy=\"no-referrer-when-downgrade\" ></iframe>\r\n  </div>\r\n  <section class=\"r24t_about scTrig\">\r\n    <div class=\"inner\">\r\n      <div class=\"titlebox\">\r\n        <div class=\"title\"> <span class=\"subttl slidetxt\"><span>私たちについて</span></span>\r\n          <h2 class=\"mainttl eng slidetxt\"><span>ABOUT US</span></h2>\r\n        </div>\r\n        <div class=\"title_line\"></div>\r\n      </div>\r\n      <div class=\"txtbox\">\r\n        <h3 class=\"txt_1 fadeinup tdelay_1\"> 日軽産業株式会社は、アルミニウム総合メーカーである<br class=\"br_pc\">\r\n          日軽金グループの一員として、成長を続ける企業です。 </h3>\r\n        <p class=\"txt_2 fadeinup tdelay_1\"> 環境や生活様式が足早に変化し、社会のニーズが多様化する時代、<br class=\"br_pc\">\r\n          お客様の声をよく聞き、よりよい商品の提案やコーディネートを行い、<br class=\"br_pc\">\r\n          今後も社会への貢献を大事に発展し続けて参ります。 </p>\r\n        <div class=\"r24_btn fadeinup tdelay_2\"> <a href=\"message.html\">採用担当者の声</a> </div>\r\n      </div>\r\n      <figure class=\"img_1\"> <img src=\"img/top/01.jpg\" alt> </figure>\r\n      <figure class=\"img_2\"> <img src=\"img/03/tate.jpg\" alt> </figure>\r\n    </div>\r\n  </section>\r\n  <section class=\"r24t_intv\">\r\n    <div class=\"bgtxt_box\"> <span class=\"bgtxt\">INTERVIEW</span> </div>\r\n    <div class=\"inner scTrig\">\r\n      <div class=\"titlebox\">\r\n        <div class=\"title\"> <span class=\"subttl slidetxt\"><span>先輩社員インタビュー</span></span>\r\n          <h2 class=\"mainttl eng slidetxt\"><span>INTERVIEW</span></h2>\r\n        </div>\r\n      </div>\r\n      <div class=\"r24_btn\"> <a href=\"list.html\">インタビュー一覧</a> </div>\r\n      <div class=\"memberlist fadeinup\">\r\n        <div class=\"r24i_ppl r24i_ppl_shou\"> <a href=\"03.html\">\r\n          <div class=\"imgbox\"> <img src=\"img/03/r24i_03.png\" alt> </div>\r\n          <div class=\"txtbox\">\r\n            <p class=\"job\">静岡支店</p>\r\n            <p class=\"name\">2021年入社</p>\r\n          </div>\r\n          </a> </div>\r\n        <div class=\"r24i_ppl r24i_ppl_shin\"> <a href=\"09.html\">\r\n          <div class=\"imgbox\"> <img src=\"img/09/r24i_09.png\" alt> </div>\r\n          <div class=\"txtbox\">\r\n            <p class=\"job\">心線部 生産グループ</p>\r\n            <p class=\"name\">2009年入社</p>\r\n          </div>\r\n          </a> </div>\r\n        <div class=\"r24i_ppl r24i_ppl_kens\"> <a href=\"06.html\">\r\n          <div class=\"imgbox\"> <img src=\"img/06/r24i_06.png\" alt> </div>\r\n          <div class=\"txtbox\">\r\n            <p class=\"job\">建設エンジニアリング部</p>\r\n            <p class=\"name\">2020年入社</p>\r\n          </div>\r\n          </a> </div>\r\n        <div class=\"r24i_ppl r24i_ppl_hoke\"> <a href=\"10.html\">\r\n          <div class=\"imgbox\"> <img src=\"img/10/r24i_10.png\" alt> </div>\r\n          <div class=\"txtbox\">\r\n            <p class=\"job\">日軽パートナーズ　保険部</p>\r\n            <p class=\"name\">2020年入社</p>\r\n          </div>\r\n          </a> </div>\r\n        <div class=\"r24i_ppl r24i_ppl_kanr\"> <a href=\"05.html\">\r\n          <div class=\"imgbox\"> <img src=\"img/05/r24i_05.png\" alt> </div>\r\n          <div class=\"txtbox\">\r\n            <p class=\"job\">経理部</p>\r\n            <p class=\"name\">2017年入社</p>\r\n          </div>\r\n          </a> </div>\r\n        <div class=\"r24i_ppl r24i_ppl_kens\"> <a href=\"07.html\">\r\n          <div class=\"imgbox\"> <img src=\"img/07/r24i_07.png\" alt> </div>\r\n          <div class=\"txtbox\">\r\n            <p class=\"job\">建設エンジニアリング部</p>\r\n            <p class=\"name\">2019年入社</p>\r\n          </div>\r\n          </a> </div>\r\n        <div class=\"r24i_ppl r24i_ppl_shou\"> <a href=\"04.html\">\r\n          <div class=\"imgbox\"> <img src=\"img/04/r24i_04.png\" alt> </div>\r\n          <div class=\"txtbox\">\r\n            <p class=\"job\">大阪支店</p>\r\n            <p class=\"name\">2020年入社</p>\r\n          </div>\r\n          </a> </div>\r\n        <div class=\"r24i_ppl r24i_ppl_hoke\"> <a href=\"11.html\">\r\n          <div class=\"imgbox\"> <img src=\"img/11/r24i_11.png\" alt> </div>\r\n          <div class=\"txtbox\">\r\n            <p class=\"job\">日軽パートナーズ　保険部</p>\r\n            <p class=\"name\">2018年入社</p>\r\n          </div>\r\n          </a> </div>\r\n        <div class=\"r24i_ppl r24i_ppl_kens\"> <a href=\"08.html\">\r\n          <div class=\"imgbox\"> <img src=\"img/08/r24i_08.png\" alt> </div>\r\n          <div class=\"txtbox\">\r\n            <p class=\"job\">建設エンジニアリング部</p>\r\n            <p class=\"name\">2021年入社</p>\r\n          </div>\r\n          </a> </div>\r\n      </div>\r\n    </div>\r\n  </section>\r\n  <section class=\"r24t_program scTrig\">\r\n    <div class=\"bgtxt_box\"> <span class=\"bgtxt bgtxt_1\">PROGRAM</span> <span class=\"bgtxt bgtxt_2\">PROGRAM</span> </div>\r\n    <div class=\"inner\">\r\n      <div class=\"titlebox\">\r\n        <div class=\"title\"> <span class=\"subttl slidetxt\"><span>多彩な教育プログラム</span></span>\r\n          <h2 class=\"mainttl eng slidetxt\"><span>PROGRAM</span></h2>\r\n        </div>\r\n        <div class=\"r24_btn\"> <a href=\"program.html\">プログラム一覧</a> </div>\r\n      </div>\r\n      <ul class=\"prg_ul fadeinup tdelay_2\">\r\n        <li class=\"prg_item\"> <span class=\"prg_num eng\">PROGRAM / 01</span>\r\n          <h3 class=\"prg_ttl\">資格取得推奨制度</h3>\r\n          <figure class=\"prg_img\"> <img src=\"img/top/02.png\" alt> </figure>\r\n          <p class=\"prg_txt\">様々な資格を取得する為の制度を整えております。</p>\r\n        </li>\r\n        <li class=\"prg_item\"> <span class=\"prg_num eng\">PROGRAM / 02</span>\r\n          <h3 class=\"prg_ttl\">TOEIC</h3>\r\n          <figure class=\"prg_img\"> <img src=\"img/top/04.png\" alt> </figure>\r\n          <p class=\"prg_txt\">海外出張で必要な英語スキルも教育プログラムに含まれております。</p>\r\n        </li>\r\n        <li class=\"prg_item\"> <span class=\"prg_num eng\">PROGRAM / 03</span>\r\n          <h3 class=\"prg_ttl\">パソコン研修</h3>\r\n          <figure class=\"prg_img\"> <img src=\"img/top/03.png\" alt> </figure>\r\n          <p class=\"prg_txt\">入社時にエクセル・ワード・パワーポイントについて 基礎から応用まで学べます。</p>\r\n        </li>\r\n        <li class=\"prg_item\"> <span class=\"prg_num eng\">PROGRAM / 04</span>\r\n          <h3 class=\"prg_ttl\">メンタルヘルス講習</h3>\r\n          <figure class=\"prg_img\"> <img src=\"img/top/06.png\" alt> </figure>\r\n          <p class=\"prg_txt\">人間関係だけでなく職場環境や作業方法等に着目し、 働きやすい職場づくりへの取り組みをしております。</p>\r\n        </li>\r\n        <li class=\"prg_item\"> <span class=\"prg_num eng\">PROGRAM / 05</span>\r\n          <h3 class=\"prg_ttl\">フォルトゥナ研修</h3>\r\n          <figure class=\"prg_img\"> <img src=\"img/top/05.png\" alt> </figure>\r\n          <p class=\"prg_txt\">女性のための研修です。多くの気づきを得ることができ 活き活きと働くヒントを多く得られる研修を実施しています。</p>\r\n        </li>\r\n        <li class=\"prg_item\"> <span class=\"prg_num eng\">PROGRAM / 06</span>\r\n          <h3 class=\"prg_ttl\">普通救命講習</h3>\r\n          <figure class=\"prg_img\"> <img src=\"img/top/01.png\" alt> </figure>\r\n          <p class=\"prg_txt\">突然倒れた人を発見した場合の対処方法、 意識障害や呼吸・心肺蘇生方法の講習を実施しています。</p>\r\n        </li>\r\n      </ul>\r\n    </div>\r\n  </section>\r\n  <section class=\"r24t_entry scTrig\">\r\n    <div class=\"inner\">\r\n      <div class=\"data\">\r\n        <div class=\"titlebox\">\r\n          <div class=\"title\"> <span class=\"subttl slidetxt\"><span>エントリー</span></span>\r\n            <h2 class=\"mainttl eng slidetxt\"><span>ENTRY</span></h2>\r\n          </div>\r\n        </div>\r\n        <p class=\"txt fadeinup\"> 日軽金グループの一員として、<br>\r\n          私たち日軽産業でいっしょに働きませんか？ </p>\r\n        <div class=\"entbtn fadeinup\"> <a href=\"guideline.html\"> <span class=