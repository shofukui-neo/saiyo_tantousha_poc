=\"l-contW investorInfo\">\n        <span class=\"l-mauto bnr-w\">\n          <a href=\"https://job.mynavi.jp/27/pc/search/corp71402/outline.html\" target=\"_blank\" class=\"bnr_link\"><img src=\"/img/common_new/bnr_mynavi2027.png\" alt=\"マイナビ2027 2027年度入社予定の新卒者の方は「マイナビ2027」からエントリー\"></a>\n          <a href=\"https://www.hisaka.co.jp/company_info/library_movie.html#library_movie_sub06\" target=\"_blank\" class=\"bnr_link\"><img src=\"/img/common_new/bnr_conceptmovie.png\" alt=\"新卒採用コンセプトムービー\"></a>\n          <a href=\"/recruiting/opencompany/\" target=\"_blank\" class=\"bnr_link\"><img src=\"/img/common_new/bnr_opencompany.png\" alt=\"オープンカンパニー\"></a>\n        </span>\n        <p class=\"investorInfoCaution\">※2027年度入社予定の新卒者の方は「マイナビ2027」よりエントリーをお願いいたします。</p>\n\n        <div class=\"investorInfo_box\">\n          <dl class=\"investorInfo_boxList\">\n            <dt class=\"investorInfo_boxListTitle investorInfo_boxListTitle-top\">募集職種</dt>\n            <dd class=\"investorInfo_boxListItem\">【技術職（理系）】<br>\n            ・設計開発<br>\n            ・セールスエンジニア（技術営業）<br>\n            変更範囲（有無）：有　　変更の範囲：当社業務全般\n            </dd>\n          </dl>\n          <dl class=\"investorInfo_boxList\">\n            <dt class=\"investorInfo_boxListTitle investorInfo_boxListTitle-top\">初任給</dt>\n              <dd class=\"investorInfo_boxListItem\">\n              （2025年本採用時基本給）<br>\n              大学院（博士）卒　　月額　271,000円<br>\n              大学院（修士）卒　　月額　258,000円<br>\n  \t\t\t      大学卒　　　　　　　月額　240,000円\n             </dd>\n          </dl>\n          <dl class=\"investorInfo_boxList\">\n            <dt class=\"investorInfo_boxListTitle\">諸手当</dt>\n            <dd class=\"investorInfo_boxListItem\">残業手当、家族手当、通勤手当（実費）</dd>\n          </dl>\n          <dl class=\"investorInfo_boxList\">\n            <dt class=\"investorInfo_boxListTitle\">昇給</dt>\n            <dd class=\"investorInfo_boxListItem\">年1回（4月）18,500円（2025年度組合員平均実績）</dd>\n          </dl>\n          <dl class=\"investorInfo_boxList\">\n            <dt class=\"investorInfo_boxListTitle investorInfo_boxListTitle-top\">賞与</dt>\n              <dd class=\"investorInfo_boxListItem\">\n                年2回（6月・12月）年間実績171万円＋利益配分（業績による / 2024年度組合員平均実績）\n              </dd>\n          </dl>\n          <dl class=\"investorInfo_boxList\">\n            <dt class=\"investorInfo_boxListTitle investorInfo_boxListTitle-top\">休日休暇</dt>\n            <dd class=\"investorInfo_boxListItem\">完全週休2日制、年間休日124日（2025年度）、年次有給休暇初年度12日、慶弔特別休暇、<br>\n\t\t\t\t連続休暇（夏季/年末年始/ゴールデンウィーク）、リフレッシュ休暇、看護・介護休暇</dd>\n          </dl>\n          <dl class=\"investorInfo_boxList\">\n            <dt class=\"investorInfo_boxListTitle\">福利厚生・各種制度</dt>\n            <dd class=\"investorInfo_boxListItem\">各種社会保険、財形貯蓄、持株会、年金基金、福祉会、OB会、テレワーク制度（週2回、月8回<br class=\"pc\">まで取得可能）、クラブ活動、レクリエーション（補助）、ワンルームマンション斡旋、<br>家賃補助（単身者で通勤圏外の方を対象に最大45,000円／月［最大5年間］を弊社で負担）</dd>\n          </dl>\n          <dl class=\"investorInfo_boxList\">\n            <dt class=\"investorInfo_boxListTitle\">勤務地</dt>\n            <dd class=\"investorInfo_boxListItem\">\n              鴻池事業所（大阪府東大阪市東鴻池町2-1-48）<br>\n              <a href=\"/company_info/access.html#konoikeLink\" target=\"_blank\" class=\"investorInfo_boxListItemMail\">≫地図を見る</a><br>\n              生駒事業所（奈良県生駒市高山町8916-10）<br>\n              <a href=\"/company_info/access.html#ikomaLink\" target=\"_blank\" class=\"investorInfo_boxListItemMail\">≫地図を見る</a><br>\n              本社（大阪府大阪市北曾根崎2-12-7 清和梅田ビル20F）<br>\n              <a href=\"/company_info/access.html#homeLink\" target=\"_blank\" class=\"investorInfo_boxListItemMail\">≫地図を見る</a><br>\n              <br>\n              変更の範囲（有無）：有　　変更の範囲：国内外の全拠点\n              </dd>\n          </dl>\n          <dl class=\"investorInfo_boxList\">\n            <dt class=\"investorInfo_boxListTitle\">勤務時間</dt>\n            <dd class=\"investorInfo_boxListItem\">8:30～17:00（東京支店・北海道営業所・さいたま営業所・千葉営業所　9:00～17:30）</dd>\n          </dl>\n          <dl class=\"investorInfo_boxList\">\n            <dt class=\"investorInfo_boxListTitle\">教育制度</dt>\n            <dd class=\"investorInfo_boxListItem\">新入社員集合研修、職能別専門教育、OJT、ビジネス基礎力研修、自己研修、通信教育、外部研修</dd>\n          </dl>\n          <dl class=\"investorInfo_boxList\">\n            <dt class=\"investorInfo_boxListTitle investorInfo_boxListTitle-top\">採用実績校</dt>\n            <dd class=\"investorInfo_boxListItem\">\n              <ul class=\"investorInfo_boxListItemInner investorInfo_boxListItemInner-col3\">\n                <li class=\"investorInfo_boxListItemInnerText investorInfo_boxListItemInnerText-col3 investorInfo_boxListItemInnerText-border\">\n                愛媛大学 <br>\n\t\t\t\t        大阪市立大学<br>\n                大阪教育大学<br>\n                大阪工業大学<br>\n                大阪産業大学<br>\n                大阪大学<br>\n                大阪電気通信大学<br>\n                大阪府立大学<br>\n                岡山大学<br>\n\t\t\t\t岡山理科大学<br>\n                鹿児島大学<br>\n                神奈川大学<br>\n                金沢大学<br>\n\t\t\t\t金沢工業大学<br>\n                関西大学<br>\n                関西学院大学<br>\n                九州工業大学<br>\n                京都工芸繊維大学<br>\n                京都産業大学<br>\n\t\t\t\t京都大学<br>\n                <li class=\"investorInfo_boxListItemInnerText investorInfo_boxListItemInnerText-col3 investorInfo_boxListItemInnerText-border\">\n                近畿大学<br>\n                熊本大学<br>\n\t\t\t\t高知工科大学<br>\n                甲南大学<br>\n                神戸学院大学<br>\n                神戸大学<br>\n                佐賀大学<br>\n                滋賀県立大学<br>\n                四国職業能力開発大学校<br>\n\t\t\t\t芝浦工業大学<br>\n                島根大学<br>\n                信州大学<br>\n                水産大学<br>\n                摂南大学<br>\n\t\t\t\t創価大学<br>\n                千葉工業大学<br>\n                中央大学<br>\n                東京海洋大学<br>\n                東京都立大学<br>\n                同志社大学<br>\n                </li>\n                <li class=\"investorInfo_boxListItemInnerText investorInfo_boxListItemInnerText-col3 investorInfo_boxListItemInnerText-border\">\t\t\t\t\t\n                東北大学<br>\n                徳島大学<br>\n                鳥取大学<br>\n                富山県立大学<br>\n                豊橋技術科学大学<br>\n                長崎大学<br>\n                兵庫県立大学<br>\n                広島大学<br>\n                福井工業大学<br>\n                福井大学<br>\n                北陸先端科学技術大学院大学<br>\n                三重大学<br>\n\t\t\t\t宮崎大学<br>\n                山口大学<br>\n                山口東京理科大学<br>\n                立命館大学<br>\n                琉球大学<br>\n                龍谷大学<br>\n                早稲田大学<br>\n                </li>\n              </ul>\n\n            </dd>\n          </dl>\n          <dl class=\"investorInfo_boxList\">\n            <dt class=\"investorInfo_boxListTitle investorInfo_boxListTitle-top\">採用実績数</dt>\n            <dd class=\"investorInfo_boxListItem\">\n              2025年入社：13名（技術職12名、事務職1名）<br>\n\t\t\t  2024年入社：11名（技術職10名、事務職1名）<br>\n              2023年入社：15名（技術職14名、事務職1名）<br>\n              2022年入社：10名（技術職 9名、事務職1名）<br>\n              2021年入社： 7名<br>\n              2020年入社： 6名（技術職 5名、事務職1名）<br>\n            </dd>\n          </dl>\n          <dl class=\"investorInfo_boxList\">\n            <dt class=\"investorInfo_boxListTitle\">募集人数</dt>\n            <dd class=\"investorInfo_boxListItem\">【理系】10名程度</dd>\n          </dl>\n          <dl class=\"investorInfo_boxList\">\n            <dt class=\"investorInfo_boxListTitle\">募集学科</dt>\n            <dd class=\"investorInfo_boxListItem\">【理系】<br>機械工学系積極採用、電気・電子系、化学・化学工学系、情報系歓迎</dd>\n          </dl>\n          <dl class=\"investorInfo_boxList\">\n            <dt class=\"investorInfo_boxListTitle\">提出書類</dt>\n            <dd class=\"investorInfo_boxListItem\">履歴書（写真貼付）、成績証明書（含卒業見込証明書）</dd>\n          </dl>\n          <dl class=\"investorInfo_boxList\">\n            <dt class=\"investorInfo_boxListTitle\">選考方法</dt>\n            <dd class=\"investorInfo_boxListItem\">面接、適性検査</dd>\n          </dl>\n          <dl class=\"investorInfo_boxList\">\n            <dt class=\"investorInfo_boxListTitle investorInfo_boxListTitle-top\">求める人材像</dt>\n            <dd class=\"investorInfo_boxListItem\">\n            ■コミュニケーション能力があり、自分の意見を自分の言葉で表現できる方<br>\n            ■自ら考え、判断し、行動できる方<br>\n            ■物事を広く深く考えられる方<br>\n            ■熱意、諦めない強い気持ちを持っている方<br>\n            ■英語が好きな方（英文を読解することができる方）<br>\n            </dd>\n          </dl>\n\t\t  <span class=\"l-mauto l-mt60\">\n　\t　\t　<div style=\"text-align: center\">\n　　　\t　\t  <a href=\"https://www.hisaka.co.jp/company_info/pdf/recruitbook_202501.pdf\" target=\"_blank\" class=\"bnr_link\"><img src=\"/img/common_new/bnr_recruitbook_2025.png\" style=\"display: block; margin: auto;\" alt=\"技術者であれ、挑戦者であれ 日阪製作所採用案内\"></a>\n\t\t   <font size=\"2\">日阪製作所がもっとわかるリクルートBook</font><br>\n        　 </div>\n\t\t  </span>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"l-mt60 l-mb80\">\n      <div class=\"l-contW investorInfo\">\n        <h4 class=\"investorInfo_notoTitle\">お問い合わせ先</h4>\n\n        <div class=\"investorInfo_box\">\n          <dl class=\"investorInfo_boxList\">\n            <dt class=\"investorInfo_boxListTitle\">電話番号</dt>\n            <dd class=\"investorInfo_boxListItem\">06-6363-0006（代表）</dd>\n          </dl>\n          <dl class=\"investorInfo_boxList\">\n            <dt class=\"investorInfo_boxListTitle\">メールアドレス</dt>\n            <dd class=\"investorInfo_boxListItem\">\n              <a href=\"mailto:recruit@hisaka.co.jp\" class=\"investorInfo_boxListItemMail\">recruit@hisaka.co.jp</a>\n            </dd>\n          </dl>\n          <dl class=\"investorInfo_boxList\">\n            <dt class=\"investorInfo_boxListTitle\">採用担当者</dt>\n            <dd class=\"investorInfo_boxListItem\">髙室</dd>\n          </dl>\n        </div>\n\n        <span class=\"l-mauto l-mt60 bnr-w\">\n          <a href=\"https://job.mynavi.jp/27/pc/search/corp71402/outline.html\" target=\"_blank\" class=\"bnr_link\"><img src=\"/img/common_new/bnr_mynavi2027.png\" alt=\"マイナビ2027 2027年度入社予定の新卒者の方は「マイナビ2027」からエントリー\"></a>\n          <a href=\"https://www.hisaka.co.jp