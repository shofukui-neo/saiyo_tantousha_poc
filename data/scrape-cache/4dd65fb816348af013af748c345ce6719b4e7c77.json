iv>\r\n            <div class=\"footer-nav-layout__grid util-sp-hidden\">\r\n              <ul class=\"footer-nav-list-v1\">\r\n                <li>\r\n                  <a href=\"/corporate/ir/\">IR</a>\r\n                  <ul class=\"footer-nav-list-v2\">\r\n                    <li><a href=\"/corporate/ir/message/\">トップメッセージ</a></li>\r\n                    <li><a href=\"/corporate/ir/individual/\">個人投資家の皆様へ</a></li>\r\n                    <li><a href=\"/corporate/ir/policy/\">経営方針</a></li>\r\n                    <li><a href=\"/corporate/ir/highlight/\">財務・業績ハイライト</a></li>\r\n                    <li><a href=\"/corporate/ir/stock-info/\">株式・株主情報</a></li>\r\n                    <li><a href=\"/corporate/ir/library/\">IRライブラリー</a></li>\r\n                    <li><a href=\"/corporate/ir/events/\">IRイベント</a></li>\r\n                    <li><a href=\"/corporate/ir/faq/\">よくあるご質問</a></li>\r\n                    <li><a href=\"/corporate/ir/inquiry/\">IRに関するお問い合わせ</a></li>\r\n                    <li><a href=\"/corporate/ir/e-ad/\">電子公告</a></li>\r\n                    <li><a href=\"/corporate/ir/movies/\">動画配信</a></li>\r\n                    <li><a href=\"/corporate/ir/disclaimer.html\">免責事項</a></li>\r\n                    <li><a href=\"/news/?search_ext_col_64%5B%5D=06\">IRニュース一覧</a></li>\r\n                  </ul>\r\n                </li>\r\n              </ul>\r\n            </div>\r\n            <div class=\"footer-nav-layout__grid\">\r\n              <ul class=\"footer-nav-list-v1 is-1col--sp no-boder\">\r\n                <li><a href=\"/recruit/\" target=\"_blank\"><span class=\"link-blank\">採用情報</span></a></li>\r\n                <li><a href=\"/customer/\" target=\"_blank\"><span class=\"link-blank\">お問い合わせ</span></a></li>\r\n                <li><a href=\"https://search.nipponham.co.jp/?temp=news\" target=\"_blank\"><span class=\"link-blank\">ニュース</span></a></li>\r\n              </ul>\r\n              <ul class=\"footer-nav-list-other normal-link-list\">\r\n         