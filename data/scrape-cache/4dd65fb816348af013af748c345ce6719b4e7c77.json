ustainability/environment/plastic.html\">プラスチック</a></li>\r\n              <li><a href=\"/corporate/sustainability/environment/water.html\">水</a></li>\r\n              <li><a href=\"/corporate/sustainability/environment/food-loss.html\">食品ロス</a></li>\r\n              <li><a href=\"/corporate/sustainability/environment/waste.html\">廃棄物</a></li>\r\n              <li><a href=\"/corporate/sustainability/environment/biodiversity.html\">生物多様性</a></li>\r\n            </ul>\r\n          </li>\r\n        </ul>\r\n      </li>\r\n      <li class=\"tgl-btn\">社会</li>\r\n      <li class=\"tgl-cont\">\r\n        <ul class=\"ir-menu-cont-list tgl-list nl-1-nest\">\r\n          <li><a href=\"/corporate/sustainability/social/\">社会</a></li>\r\n          <li class=\"gray-area\">\r\n            <ul>\r\n              <li><a href=\"/corporate/sustainability/human/well-being.html\">健やかな心と体</a></li>\r\n              <li><a href=\"/corporate/sustainability/products/\">サステナブルな商品の提供</a></li>\r\n              <li><a href=\"/corporate/sustainability/social/creating-new-values.html\">新たな価値の創出</a></li>\r\n              <li><a href=\"/corporate/sustainability/human/human-rights.html\">人権の尊重</a></li>\r\n              <li><a href=\"/corporate/sustainability/human/diversity.html\">多様な人財の活躍に向けて</a></li>\r\n              <li><a href=\"/corporate/sustainability/human/health.html\">健康経営の推進</a></li>\r\n              <li><a href=\"/corporate/sustainability/social/supply-chain.html\">サプライチェーンマネジメント</a></li>\r\n              <li><a href=\"/corporate/sustainability/social/issue-resolution.html\">国内畜産業の課題解決</a></li>\r\n              <li><a href=\"/corporate/sustainability/social/animal-welfare.html\">アニマルウェルフェア</a></li>\r\n              <li><a href=\"/corporate/sustainability/human/education.html\">食育活動</a></li>\r\n              <li><a href=\"/corporate/sustainability/human/sports.html\">スポーツ振興</a></li>\r\n              <li><a href=\"/corporate/sustainability/social/ballpark.html\">北海道ボールパークFビレッジ</a></li>\r\n            </ul>\r\n          </li>\r\n        </ul>\r\n      </li>\r\n      <li class=\"tgl-btn\">ガバナンス</li>\r\n      <li class=\"tgl-cont\">\r\n        <ul class=\"ir-menu-cont-list tgl-list nl-1-nest\">\r\n          <li><a href=\"/corporate/sustainability/governance/\">ガバナンス</a></li>\r\n          <li class=\"gray-area\">\r\n            <ul>\r\n              <li><a href=\"/corporate/group/governance/risks.html\">リスクマネジメント</a></li>\r\n              <li><a href=\"https://www.nipponham.co.jp/corporate/group/compliance/index.html\">コンプライアンスへの取り組み</a></li>\r\n              <li><a href=\"/corporate/group/governance/cg/index.html\">コーポレート・ガバナンス</a></li>\r\n            </ul>\r\n          </li>\r\n        </ul>\r\n      </li>\r\n      <li class=\"link\"><a href=\"/corporate/sustainability/creation/\">共創の取り組み</a></li>\r\n      <li class=\"link\"><a href=\"/corporate/sustainability/membership/\">イニシアチブ・外部団体への参画</a></li>\r\n      <li class=\"link\"><a href=\"/corporate/sustainability/policylist/\">方針一覧</a></li>\r\n      <li class=\"link\"><a href=\"/corporate/sustainability/evaluation/\">第三者からの評価</a></li>\r\n      <li class=\"link\"><a href=\"/corporate/sustainability/gri-index/\">GRIスタンダード対照表</a></li>\r\n      <li class=\"link\"><a href=\"/corporate/sustainability/library/#anc02\">データブック</a></li>\r\n      <li class=\"link\"><a href=\"/corporate/sustainability/library/\">サステナビリティライブラリ</a></li>\r\n      <li class=\"link\"><a href=\"/news/?search_ext_col_64%5B%5D=05\">サステナビリティニュース一覧</a></li>\r\n    </ul>\r\n  </div>\r\n</section>\r\n\n<main id=\"main\" class=\"Main\">\n  <div class=\"Main__inner\">\n    <div class=\"Main__body\" data-sidebar=\"false\">\n      <div class=\"Main__content\">\n\n        <!-- START -->\n\n        <div class=\"contents\">\n          <h1 class=\"h1-s mod_s_mb0\">第三者からの評価</h1>\n          <div class=\"anchor-nav\">\n            <div class=\"anc-1-pcAuto-sp1\">\n              <p class=\"anc-1\"><a href=\"#anc-01\">ESGインデックスへの組み入れ</a></p>\n              <p class=\"anc-1\"><a href=\"#anc-02\">ESG関連の受賞・評価</a></p>\n            </div>\n          </div>\n          <div class=\"evaluation-block\" id=\"anc-01\">\n            <h2 class=\"h2-s\">ESGインデックスへの組み入れ</h2>\n            <div class=\"evaluation-block-item\">\n              <h3 class=\"h3-s\">FTSE4Good Index Series</h3>\n              <div class=\"md-1-2r-30w-01\">\n                <div class=\"md-img-box\">\n                  <div class=\"im-1 mod_s_mt0\">\n                    <img src=\"/corporate/sustainability/evaluation/img/index_im_001.png\" alt=\"\">\n                  </div>\n                </div>\n                <div class=\"md-txt\">\n                  <p>日本ハム（株）は、「FTSE4Good Index Series」の構成銘柄として、2011年より連続して選定されています。<br>本インデックスは、グローバルインデックスプロバイダーであるFTSE Russellにより構築された世界の代表的なESG（環境・社会・ガバナンス）投資指数で、ESGについて優れた対応を行っていると評価された企業が選定されています。</p>\n                  <ul class=\"mod_s_mt1e\">\n                    <li><a href=\"https://www.lseg.com/ja/ftse-russell/indices/ftse4good#featured-indices\" class=\"ll-1-blank\" target=\"_blank\">FTSE4Good Index</a></li>\n                  </ul>\n                </div>\n              </div>\n            </div>\n            <div class=\"evaluation-block-item\">\n              <h3 class=\"h3-s\">FTSE JPX Blossom Japan Index</h3>\n              <div class=\"md-1-2r-30w-01\">\n                <div class=\"md-img-box\">\n                  <div class=\"im-1 mod_s_mt0\">\n                    <img src=\"/corporate/sustainability/evaluation/img/index_im_002.png\" alt=\"\">\n                  </div>\n                </div>\n                <div class=\"md-txt\">\n                  <p>FTSE Russell (FTSE International Limited と Frank Russell Companyの登録商標)はここに日本ハム（株）が第三者調査の結果、FTSE JPX Blossom Japan Index組み入れの要件を満たし、本インデックスの構成銘柄となったことを証します。FTSE JPX Blossom Japan IndexはグローバルなインデックスプロバイダーであるFTSE Russellが作成し、環境、社会、ガバナンス（ESG）について特定の対応を行っている日本企業のパフォーマンスを測定するために設計されたものです。FTSE JPX Blossom Japan Indexはサステナブル投資のファンドや他の金融商品の作成・評価に広く利用されます。<br>日本ハム（株）は、2017年から連続で選定されています。</p>\n                  <ul class=\"mod_s_mt1e\">\n                    <li><a href=\"https://www.lseg.com/ja/ftse-russell/indices/ftse4good#featured-indices\" class=\"ll-1-blank\" target=\"_blank\">FTSE Blossom Index Series</a></li>\n                  </ul>\n                </div>\n              </div>\n            </div>\n            <div class=\"evaluation-block-item\">\n              <h3 class=\"h3-s\">FTSE JPX Blossom Japan Sector Relative Index</h3>\n              <div class=\"md-1-2r-30w-01\">\n                <div class=\"md-img-box\">\n                  <div class=\"im-1 mod_s_mt0\">\n                    <img src=\"/corporate/sustainability/evaluation/img/index_im_003.png\" alt=\"\">\n                  </div>\n                </div>\n                <div class=\"md-txt\">\n                  <p>FTSE Russell (FTSE International Limited と Frank Russell Companyの登録商標)はここに日本ハム（株）が第三者調査の結果、FTSE JPX Blossom Japan Sector Relative Index組み入れの要件を満たし、本インデックスの構成銘柄となったことを証します。FTSE JPX Blossom Japan Sector Relative Indexはサステナブル投資のファンドや他の金融商品の作成・評価に広く利用されます。<br>日本ハム（株）は、2022年から連続で選定されています。</p>\n                  <ul class=\"mod_s_mt1e\">\n                    <li><a href=\"https://www.lseg.com/en/ftse-russell/indices/blossom-japan\" class=\"ll-1-blank\" target=\"_blank\">FTSE Blossom Index Series</a></li>\n                  </ul>\n                </div>\n              </div>\n            </div>\n            <div class=\"evaluation-block-item\">\n              <h3 class=\"h3-s\">MSCI 日本株 ESG セレクト・リーダーズ 指数*</h3>\n              <div class=\"md-1-2r-30w-01\">\n                <div class=\"md-img-box\">\n                  <div class=\"im-1 mod_s_mt0\">\n                    <img src=\"/corporate/sustainability/evaluation/img/index_im_004.png\" alt=\"\">\n                  </div>\n                </div>\n                <div class=\"md-txt\">\n                  <p>日本ハム（株）は、米国のモルガン・スタンレー・キャピタル・インターナショナル（MSCI）の構成銘柄として「MSCI日本株ESGセレクト・リーダーズ指数」に選定されています。<br>この指数はMSCIによって作成され、「MSCI日本株IMI指数」の構成銘柄の中から各業種においてESG（環境・社会・ガバナンス）格付けが相対的に高い企業を選定します。<br>また世界最大の投資家とされる年金積立金管理運用独立行政法人（GPIF）が、ESGに関する投資を行う際に活用する指数のひとつです。</p>\n                </div>\n              </div>\n            </div>\n            <div class=\"evaluation-block-item\">\n              <h3 class=\"h3-s\">S&amp;P/JPXカーボン・エフィシエント指数</h3>\n              <div class=\"md-1-2r-30w-01\">\n                <div class=\"md-img-box\">\n                  <div class=\"im-1 mod_s_mt0\">\n                    <img src=\"/corporate/sustainability/evaluation/img/index_im_005.png\" alt=\"\">\n                  </div>\n                </div>\n                <div class=\"md-txt\">\n                  <p>日本ハム(株)は、「S&amp;P/JPXカーボン・エフィシエント指数」の構成銘柄として2018年の取得以来、連続して選定されています。<br>この指数は、日本取引所グループ、東京証券取引所、およびS&amp;P ダウ・ジョーンズインデックスが共同開発した、東証株価指数（TOPIX）をユニバースとし、環境情報の開示状況および炭素効率性（売上高当たり炭素排出量）の水準に着目して構成銘柄のウエイトを決定する株価指数です。<br>また世界最大の投資家とされる年金積立金管理運用独立行政法人（GPIF）が、ESGに関する投資を行う際に活用する指数のひとつです。</p>\n                </div>\n              </div>\n            </div>\n            <div class=\"evaluation-block-item\">\n              <h3 class=\"h3-s\">Morningstar日本株式ジェンダー・ダイバーシティ・ティルト指数（除くREIT）</h3>\n              <div class=\"md-1-2r-30w-01\">\n                <div class=\"md-img-box\">\n                  <div class=\"im-1 mod_s_mt0\">\n                    <img src=\"/corporate/sustainability/evaluation/img/index_im_009.png\" alt=\"\">\n                  </div>\n                </div>\n                <div class=\"md-txt\">\n                  <p>日本ハム（株）は、「Morningstar日本株式ジェンダー・ダイバーシティ・ティルト指数（除くREIT）」の構成銘柄に選定されています。この指数は、オランダEquileap社が提供するデータと評価手法を活用し、ジェンダーに関係なく従業員に対し平等な機会を約束している企業などを高く評価するものです。当社は、最高評価の「グループ1」に選定されました。</p>\n                </div>\n              </div>\n            </div>\n            <div class=\"evaluation-block-item\">\n              <p class=\"mod_s_fz_note nl-1-nest \">免責事項</p>\n              <div class=\"\">\n                <ul class=\"clr-gray\">\n                  <li class=\"note-style-ast mod_s_fz_note\">Morningstar, Inc., and/or one of its affiliated companies (individually and collectively, “Morningstar”) has authorized NH Foods Group&nbsp;to use of the Morningstar® Japan ex-REIT Gender Diversity Tilt Logo (“Logo”) to reflect the fact that, for the designated ranking year, NH Foods Group&nbsp;ranks within the top group of companies comprising the Morningstar® Japan ex-REIT Gender Diversity Tilt Index℠ (“Index”) on the issue of gender diversity in the workplace. Morningstar is making the Logo available for use by NH Foods Group&nbsp;solely for informational purposes. NH Foods Group&nbsp;’s use of the Logo should not be construed as an endorsement by Morningstar of NH Foods Group&nbsp;or as a recommendation, offer or solicitation to purchase, sell or underwrite any security associated with NH Foods Group&nbsp;.The Index is designed to reflect gender diversity in the workplace in Japan, but Morningstar does not guarantee the accuracy, completeness or timeliness of the Index or any data included in it. Morningstar makes no express or implied warranties regarding the Index or the Logo, and expressly disclaims all warranties of merchantability or fitness for a particular purpose or use with respect to the Index, any data included in it or the Logo. Without limiting any of the foregoing, in no event shall Morningstar or any of its third-party content providers have any liability for any damages (whether direct or indirect), arising from any party’s use or reliance on the Index or the Logo, even if Morningstar is notified of the possibility of such damages. The Morningstar name, Index name and the Logo are the trademarks or services marks of Morningstar, Inc. Past performance is no guarantee of future results.</li>\n                </ul>\n              </div>\n            </div>\n\n            <div class=\"evaluation-block-item\">\n              <h3 class=\"h3-s\">SOMPOサステナビリティ・インデックス</h3>\n              <div class=\"md-1-2r-30w-01\">\n                <div class=\"md-img-box\">\n                  <div class=\"im-1 mod_s_mt0\">\n                    <img src=\"/corporate/sustainability/evaluation/img/index_im_006.png\" alt=\"\">\n                  </div>\n                </div>\n                <div class=\"md-txt\">\n                  <p>日本ハム（株）は、SOMPOアセットマネジメント株式会社が運用する「SOMPOサステナビリティ・インデックス」の構成銘柄に選定されています。<br>本インデックスの構成銘柄はESG（環境、社会、ガバナンス）に優れた約300銘柄が毎年選定され、同社の「サステナブル運用」に活用されます。<br>2012年8月より運用を開始した「サステナブル運用」は、ESGの評価の高い企業に幅広く投資する年金基金・機関投資家向けの責任投資プロダクトです。調査会社によるESG評価を重視して選定した投資銘柄によって構成される「SNAMサステナビリティ・インデックス」に基づき、長期投資を志向する運用を行っています。</p>\n                </div>\n              </div>\n            </div>\n            <div class=\"evaluation-block-item\">\n              <p class=\"mod_s_fz_note nl-1-nest \">免責事項</p>\n              <div class=\"\">\n                <ul class=\"clr-gray\">\n                  <li class=\"note-style-ast mod_s_fz_note\">THE INCLUSION OF NH Foods Group IN ANY MSCI INDEX, AND THE USE OF MSCI LOGOS, TRADEMARKS, SERVICE MARKS OR INDEX NAMES HEREIN, DO NOT CONSTITUTE A SPONSORSHIP, ENDORSEMENT OR PROMOTION OF NH Foods Group BY MSCI OR ANY OF ITS AFFILIATES.THE MSCI INDEXES ARE THE EXCLUSIVE PROPERTY OF MSCI. MSCI AND THE MSCI INDEX NAMES AND LOGOS ARE TRADEMARKS OR SERVICE MARKS OF MSCI OR ITS AFFILIATES.</li>\n                </ul>\n              </div>\n            </div>\n          </div>\n          <div class=\"evaluation-block\" id=\"anc-02\">\n            <h2 class=\"h2-s\">ESG関連の受賞・評価</h2>\n            <div class=\"evaluation-block-item\">\n              <h3 class=\"h3-s\">健康経営優良法人</h3>\n              <div class=\"md-1-2r-30w-01\">\n                <div class=\"md-img-box\">\n                  <div class=\"im-1 mod_s_mt0\">\n                    <img src=\"/corporate/sustainability/evaluation/img/index_im_007.png\" alt=\"\">\n                  </div>\n                </div>\n                <div class=\"md-txt\">\n                  <p>健康経営優良法人認定制度とは、地域の健康課題に即した取り組みや日本健康会議が進める健康増進の取り組みをもとに、特に優良な健康経営を実践している大企業や中小企業等の法人を顕彰する制度です。<br>健康経営に取り組む優良な法人を「見える化」することで、従業員や求職者、関係企業や金融機関などから「従業員の健康管理を経営的な視点で考え、戦略的に取り組んでいる法人」として社会的に評価を受けることができる環境を整備することを目標としています。</p>\n              <h4 class=\"h4-s\">取得状況</h4>\n                <div class=\"tb-1\">\n                  <table>\n                    <tbody>\n                      <tr>\n                        <th class=\"tb-gray mod_s_taL\">大規模法人部門</th>\n                        <td>日本ハム（株）<br>日本ハムシステムソリューションズ（株）<br>日本ハム食品（株）<br>日本ハム惣菜（株）<br>東日本フード（株）</td>\n                      </tr>\n                      <tr>\n                        <th class=\"tb-gray mod_s_taL\">中小規模法人部門「ブライト500」<p class=\"mod_s_fz_note clr-gray mod_s_mt1e\">※中小規模法人の上位500社に認定</p></th>\n                        <td>協同食品（株）</td>\n                      </tr>\n                      <tr>\n                        <th class=\"tb-gray mod_s_taL\">中小規模法人部門</th>\n                        <td>東北日本ハム（株）</td>\n                      </tr>\n                    </tbody>\n                  </table>\n                </div>\n                </div>\n              </div>\n            </div>\n            <div class=\"evaluation-block-item\" id=\"anc-03\">\n              <h3 class=\"h3-s\">HDI格付けベンチマーク「問合せ窓口（電話）」三つ星</h3>\n              <div class=\"md-1-2r-30w-01\">\n                <div class=\"md-img-box\">\n                  <div class=\"im-1 mod_s_mt0\">\n                    <img src=\"/corporate/sustainability/evaluation/img/index_im_008.png\" alt=\"\">\n                  </div>\n                </div>\n                <div class=\"md-txt\">\n                  <p>「HDI格付けベンチマーク」 とは、サポートサービスにおける世界最大のメンバーシップ団体である HDI<sup>※</sup>の日本における組織（HDI-Japan）が主催するベンチマークです。HDI 格付けベンチマークは、調査対象企業を星なしから三つ星までの 4 段階で格付けします。この格付けは、 HDI の国際標準に基づいて設定された評価基準に沿って、審査員が顧客の視点で評価するものです。<br>お客様に質の高いサービスを提供するため、日々応対スキルを磨いています。毎年、評価項目の得点において3.5以上を目指し、三つ星評価の獲得を目標としています。<br>日本ハム(株)は、HDI格付けベンチマークの「問合せ窓口（電話）部門」において、2017年の獲得以来連続で最高評価の『三つ星』を獲得しています。</p>\n                  <ul class=\"nl-1-nest clr-gray\">\n                    <li class=\"note-style mod_s_fz_note\">HDI(米国コロラド州)は、世界最大のサポートサービス業界団体です。世界で50,000を超えるメンバーを有し、世界中に100の支部/地区会を有しています。米経済誌フォーチュン・世界企業上位の多数が加盟しています。</li>\n                  </ul>\n                </div>\n              </div>\n              <h4 class=\"h4-s\">問合せ窓口電話結果（評価項目平均 4点満点）</h4>\n              <div class=\"tb-1\">\n                <p class=\"mod_icon_tablescroll_red\">この表はスクロールしてご覧いただけます。</p>\n                <div class=\"tb-1-scroll\">\n                  <table>\n                    <tbody>\n                      <tr>\n                        <th class=\"mod_s_taC width-40-sp tb-yellow\"></th>\n                        <th class=\"mod_s_taC width-20-sp tb-yellow\">2020年</th>\n                        <th class=\"mod_s_taC width-20-sp tb-yellow\">2021年</th>\n                        <th class=\"mod_s_taC width-20-sp tb-yellow\">2022年</th>\n                        <th class=\"mod_s_taC width-20-sp tb-yellow\">2023年</th>\n                        <th class=\"mod_s_taC width-20-sp tb-yellow\">2024年</th>\n                      </tr>\n                      <tr>\n                        <th class=\"tb-gray mod_s_taL\">クオリティ結果</th>\n                        <td class=\"mod_s_taR\">3.87</td>\n                        <td class=\"mod_s_taR\">3.63</td>\n                        <td class=\"mod_s_taR\">3.67</td>\n                        <td class=\"mod_s_taR\">3.93</td>\n                        <td class=\"mod_s_taR\">3.87</td>\n                      </tr>\n                      <tr>\n                        <th class=\"tb-gray mod_s_taL\">パフォーマンス結果</th>\n                        <td class=\"mod_s_taR\">3.90</td>\n                        <td class=\"mod_s_taR\">3.83</td>\n                        <td class=\"mod_s_taR\">3.83</td>\n                        <td class=\"mod_s_taR\">3.97</td>\n                        <td class=\"mod_s_taR\">3.90</td>\n                      </tr>\n                    </tbody>\n                  </table>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n        <div class=\"breadcrumbs-wrap\">\n          <div class=\"breadcrumbs-box\">\n            <ul>\n              <li><a href=\"/\">ホーム</a></li>\n              <li><a href=\"/corporate/sustainability/\">サステナビリティ</a></li>\n              <li class=\"current\">第三者からの評価</li>\n            </ul>\n          </div>\n        </div>\n\n        <!-- END -->\n\n      </div><!--/Main__content-->\n    </div><!--/Main__body-->\n  </div><!--/Main__inner-->\n</main><!--/Main-->\n<footer id=\"footer\" class=\"Footer\">\r\n  <div class=\"Footer__inner\">\r\n    <div class=\"Footer__guide\">\r\n      <div class=\"footer-pagetop js-pagetop\">\r\n        <a href=\"#header\">ページ上部へ</a>\r\n      </div>\r\n    </div>\r\n    <div class=\"Footer__body\">\r\n      <div class=\"Footer__body__inner\">\r\n        <nav class=\"footer-nav\">\r\n          <div class=\"footer-nav-layout\">\r\n            <div class=\"footer-nav-layout__grid util-pc-hidden\">\r\n              <ul class=\"footer-nav-list-v1 is-1col--sp\">\r\n                <li><a href=\"/tanpaku-mirai/\" target=\"_blank\"><span class=\"link-blank\">ストーリー</span></a></li>\r\n                <li><a href=\"/corporate/group/\">企業情報</a></li>\r\n                <li><a href=\"/corporate/rd/\">研究・開発</a></li>\r\n                <li><a href=\"/corporate/quality/\">品質への取り組み</a></li>\r\n                <li><a href=\"/corporate/sustainability/\">サステナビリティ</a></li>\r\n                <li><a href=\"/corporate/ir/\">IR情報</a></li>\r\n              </ul>\r\n            </div>\r\n            <div class=\"footer-nav-layout__grid util-sp-hidden\">\r\n              <ul class=\"footer-nav-list-v1\">\r\n                <li><a href=\"/tanpaku-mirai/\" target=\"_blank\"><span class=\"link-blank\">ストーリー</span></a></li>\r\n                <li>\r\n                  <a href=\"/corporate/group/\">企業情報</a>\r\n                  <ul class=\"footer-nav-list-v2\">\r\n                    <li><a href=\"/corpor