?id=G-BXRZC9PHZN\"></script>\r\n<script>\r\n  window.dataLayer = window.dataLayer || [];\r\n  function gtag(){dataLayer.push(arguments);}\r\n  gtag('js', new Date());\r\n\r\n  gtag('config', 'G-BXRZC9PHZN');\r\n</script>\r\n\r\n</head>\r\n<body class=\"home page-template-default page page-id-421\" onLoad=\"initialize();\">\r\n<link rel='stylesheet' id='bones-stylesheet-css'  href='https://ohfas.co.jp/wp-content/themes/gamma/hol_style.css?1781737008' type='text/css' media='all' />\n<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n<link href=\"https://fonts.googleapis.com/css2?family=Archivo+Black&display=swap\" rel=\"stylesheet\">\n<section id=\"holtop\">\n\n<div id=\"hol_title\">\n  <h1 id=\"hol_h1\"> <img src=\"https://ohfas.co.jp/wp-content/themes/gamma/library/images/ohfas_currentlogo.png\" alt=\"ohfasホールディングス\"> </h1>\n  <h2 id=\"hol_h2\"> 株式会社OHFASホールディングス </h2>\n  <p id=\"hol_ms\"> 株式会社OHFASホールディングスは、環境ソリューションのプロフェッショナル集団として、人々の暮らしとビジネスを支える「安心・安全」の提供に邁進しております。<br>\n    私たちの使命は、単に課題を解決することに留まりません。グループ各社が持つ専門知識と技術を融合させ、お客様に寄り添い、共に持続可能な未来を築くパートナーであり続けることです。<br>\n    これからもOHFASグループは、皆様との信頼関係を何よりも大切に、より質の高いソリューションを追求し続けてまいります。<br>\n    <br>\n    今後とも、OHFASグループ各社をご愛顧いただきますようよろしくお願い申し上げます。 </p>\n</div>\n<div id=\"hol_list\">\n  <ul>\n    \n    <li>\n      <div class=\"hol_parts hol_parts hol_i\" id=\"hol_i01\"> \n        <!--画像マス--> \n      </div>\n      <a href=\"https://ohfas.co.jp/top\" class=\"hol_parts hol_block\">\n      <div class=\"hol_text\">\n        <h2> 株式会社オーファス </h2>\n        <span class=\"hol_link\"> VIEW SITE </span> </div>\n      </a> </li>\n    \n    <li>\n      <div class=\"hol_parts hol_i\" id=\"hol_i02\"> \n        <!--画像マス--> \n      </div>\n      <div class=\"hol_parts hol_block\">\n        <div class=\"hol_text\">\n          <h2> 大森産業株式会社 </h2>\n        </div>\n      </div>\n    </li>\n    \n    <li>\n      <div class=\"hol_parts hol_i\" id=\"hol_i03\"> \