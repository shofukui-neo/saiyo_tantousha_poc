ontents\">\r\n              <li><a href=\"/support/\">お客さまサポートトップ</a></li>\r\n              <li><a href=\"/support/faq/\">よくあるご質問</a></li>\r\n              <li>\r\n                <div>お問い合わせ・資料請求</div>\r\n                <ul class=\"c-header-nav-sp-list03\">\r\n                  <li><a href=\"https://qmnb.f.msgs.jp/webapp/form/26692_qmnb_1/index.do\" target=\"_blank\" rel=\"noopener\">ソリューション・製品に関するお問い合わせ</a></li>\r\n                  <li><a href=\"https://yagb.f.msgs.jp/webapp/form/21656_yagb_1/index.do\" target=\"_blank\" rel=\"noopener\">e-コレクト&reg;をご利用中の方のお問い合わせ</a></li>\r\n                  <li><a href=\"https://qmnb.f.msgs.jp/webapp/form/26692_qmnb_2/index.do\" target=\"_blank\" rel=\"noopener\">当社サービス以外のお問い合わせ</a></li>\r\n                  <li><a href=\"https://qmnb.f.msgs.jp/webapp/form/26692_qmnb_3/index.do\" target=\"_blank\" rel=\"noopener\">資料請求</a></li>\r\n                </ul>\r\n              </li>\r\n            </ul>\r\n          </li>\r\n          <li><a href=\"/strength/\">SGシステムの強み</a></li>\r\n          <li>\r\n            <button class=\"js-header-sp-item\" type=\"button\">採用情報</button>\r\n            <ul class=\"c-header-nav-sp-list02 js-header-sp-item__contents\">\r\n              <li><a href=\"/recruit/\">採用情報トップ</a></li>\r\n              <li><a href=\"/recruit/job/\">仕事を知る</a></li>\r\n              <li><a href=\"/recruit/people/\">人を知る</a></li>\r\n              <li><a href=\"/recruit/corporate/\">会社を知る</a></li>\r\n              <li><a href=\"/recruit/corporate/3min/\">数字で分かるSGシステム</a></li>\r\n              <li><a href=\"/recruit/guideline/\">募集要項</a></li>\r\n            </ul>\r\n          </li>\r\n          <li>\r\n            <button class=\"js-header-sp-item\" type=\"button\">企業情報</button>\r\n            <ul class=\"c-header-nav-sp-list02 js-header-sp-item__contents\">\r\n              <li><a href=\"/company/\">企業情報トップ</a></li>\r\n              <li><a href=\"/company/message/\">ごあいさつ</a></li>\r\n              <li><a href=\"/company/outline/\">会社概要</a></li>\r\n              <li><a href=\"/company/history/\">沿革</a></li>\r\n              <li><a href=\"/company/branch/\">事業所一覧</a></li>\r\n              <li><a href=\"/company/internal/\">内部統制基本方針</a></li>\r\n              <!--<li><a href=\"/company/faq/\">よくあるご質問</a></li>-->\r\n              <li><a href=\"https://www.sg-hldgs.co.jp/company/philosophy/\" target=\"_blank\" rel=\"noopener\">企業理念・行動憲章</a></li>\r\n            </ul>\r\n          </li>\r\n        </ul>\r\n      </div>\r\n      <div class=\"c-header-nav-sp__sub\">\r\n        <ul>\r\n          <li><a href=\"/service/e-collect/guide/\">e-コレクト&reg;のお申込</a></li>\r\n          <li><a href=\"https://www.e-service.sagawa-exp.co.jp/portal/do/login/show\" target=\"_blank\" rel=\"noopener\">スマートクラブログイン</a></li>\r\n        </ul>\r\n      </div>\r\n      <div class=\"c-header-nav-sp__contact\">\r\n        <a href=\"/support/#inquiry\">お問い合わせ</a>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</header>\r\n<div class=\"l-header__overlay\"></div>\n    <main class=\"l-main\">\n      <div class=\"l-title -service\">\n        <div class=\"l-title__inner\">\n          <div class=\"l-title__second-s\">SOLUTION<span>ソリューション・製品</span></div>\n          <h1 class=\"l-title__heading\">B2B決済サービス(カード払い)</h1>\n          <p class=\"l-title__lead\">受け取った請求書をカードで支払い、自社の<br class=\"sp:view\">支払期限を<br class=\"tb:view\">先延ばしするサービスです</p>\n            <div class=\"l-title__tag\">\n              <span>代金引換・決済</span>\n              <span>決済-IT</span>\n            </div>\n        </div>\n      </div>\n            <div class=\"l-block\">\r\n        <div class=\"l-block__inner\">\r\n          <ul class=\"c-pagelink u-mb-80 u-sp-mb-48\">\r\n            <li><a href=\"#about\" class=\"c-pagelink__item\"><span>サービス概要</span></a></li>\r\n            <li><a href=\"#reason\" class=\"c-pagelink__item\"><span>選ばれる理由</span></a></li>\r\n            <li><a href=\"#service\" class=\"c-pagelink__item\"><span>関連サービス</span></a></li>\r\n          </ul>\r\n          <section class=\"l-section\" id=\"about\">\r\n            <h2 class=\"c-heading -small -center -blue u-mb-20\">サービス概要</h2>\r\n            <h2 class=\"c-heading -large -center u-mb-32\">受け取った請求書を<wbr><span class=\"u-d-ib\">カードで支払い（※1）</span></h2>\r\n            <figure class=\"c-figure u-mb-40 u-sp-mb-24\"><img src=\"/assets/img/service/invoice/img_figure01.jpg\" alt=\"\" loading=\"lazy\"></figure>\r\n            <p>\r\n              受け取った請求書を手持ちのカードで支払えるサービスです。仕入先や購買先への入金を期日通りに当社が代行します。カードで支払うため、お客さまの支払期限を先延ばし（※2）にできます。<br>\r\n              ご利用は日本国内の法人・個人事業主であれば、どなたでも可能です。仕入先や購買先（請求書の発行元）がカード決済に対応していない場合にご利用いただけます。\r\n            </p>\r\n            <ul class=\"c-list -note-order u-mb-1em\">\r\n              <li>「請求書カード払い」は当社がサービスを提供し、株式会社デジタルガレージにサービス運営を委託しています</li>\r\n              <li>支払期日・期限の先延ばしの対象は、クレジットカードによる支払いに限ります</li>\r\n            </ul>\r\n            <div class=\"c-btn-wrap u-mb-40 u-sp-mb-24\">\r\n              <a href=\"https://sg-systems-invoice.jp/signup\" target=\"_blank\" rel=\"noopener\" class=\"c-btn -border handoverprm\"><span>無料で登録</span></a>\r\n              <a href=\"https://sg-systems-invoice.jp/signin\" target=\"_blank\" rel=\"noopener\" class=\"c-btn -border\"><span>ログイン</span></a>\r\n            </div>\r\n            <div class=\"service-mv\">\r\n              <img src=\"/assets/img/service/invoice/img_mv.png\" alt=\"\" loading=\"lazy\">\r\n            </div>\r\n          </section>\r\n          <div class=\"l-section\" id=\"reason\">\r\n            <div class=\"c-numbox u-mb-40 u-sp-mb-24\">\r\n              <div class=\"c-numbox__item\">\r\n                <div>1</div>\r\n                <div>\r\n                  受け取った請求書を手持ちのカードで支払い可能です<br>\r\n                  <ul class=\"c-list -dot u-ta-l\">\r\n                    <li>日本国内の法人が発行する銀行振込の請求書が対象（※1）</li>\r\n                    <li>カードの利用限度額まで利用可能（※2）</li>\r\n                    <li>お客さまご契約の法人カードや代表者個人カードが利用可能</li>\r\n                    <li>ご利用のカードによりポイントが貯まる</li>\r\n                  </ul>\r\n                  <ul class=\"c-list -note-order u-ta-l\">\r\n                    <li>海外企業や個人事業主が発行した請求書はご利用不可</li>\r\n                    <li>クレジットカードが対象</li>\r\n                  </ul>\r\n                </div>\r\n              </div>\r\n              <div class=\"c-numbox__item\">\r\n                <div>2</div>\r\n                <div>\r\n                  借り入れせずに支払いを延長することが可能です\r\n                  <ul class=\"c-list -dot u-ta-l\">\r\n                    <li>カード引き落とし日はお客さまの支払日に合わせるため、手元資金にゆとりを持たせることが可能（※3）</li>\r\n                    <li>銀行融資の担保や保証人、必要書類の準備や銀行に出向く時間と労力が不要</li>\r\n                    <li>仕入先や購買先ごとのバラバラな支払期日の統一が可能</li>\r\n                    <li>振り込みを代行することにより、振り込み遅延・振り込みミスを防止</li>\r\n                  </ul>\r\n                  <ul class=\"c-list -note-order -start-3 u-ta-l\">\r\n                    <li>支払期日・期限の先延ばしの対象は、クレジットカードによる支払いに限ります</li>\r\n                  </ul>\r\n                </div>\r\n              </div>\r\n              <div class=\"c-numbox__item\">\r\n                <div>3</div>\r\n                <div>\r\n                  支払者名義で振り込みを代行します\r\n                  <ul class=\"c-list -dot u-ta-l\">\r\n                    <li>振込日はカード決済手続きから最短3営業日（※4）</li>\r\n                    <li>事前連絡不要のため、仕入先や購入先に知られることなく利用可能</li>\r\n                  </ul>\r\n                  <ul class=\"c-list -note-order -start-4 u-ta-l\">\r\n                    <li>土日祝および年末年始を除く平日のみ</li>\r\n                  </ul>\r\n                </div>\r\n              </div>\r\n              <div class=\"c-numbox__item\">\r\n                <div>4</div>\r\n                <div>\r\n                  利用登録料は無料です\r\n                  <ul class=\"c-list -dot u-ta-l\">\r\n                    <li>本サービスをご利用いただいた際にのみ利用手数料3.0％（税抜き）が発生（※5）</li>\r\n                    <li>利用手数料はご利用のカード会社からの請求書金額と合算での請求</li>\r\n                  </ul>\r\n                  <ul class=\"c-list -note-order -start-5 u-ta-l\">\r\n                    <li>カード支払いに切り替えた税込み請求金額が対象で、振込金額が1万円以下の場合は、利用手数料は一律300円（税抜き）です</li>\r\n                  </ul>\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n          <section class=\"l-section\">\r\n            <h3 class=\"c-heading -medium -center u-mb-32 u-sp-mb-24\">このような課題を<wbr>お持ちのお客さまに<wbr>最適です</h3>\r\n            <div class=\"c-box\">\r\n              <ul class=\"c-list -dot u-font-bold\">\r\n                <li>現金で支払っている請求書をカードで支払いたい</li>\r\n                <li>手元にある請求書の支払いを先延ばししたい</li>\r\n                <li>急遽、仕入れ資金や事業資金が追加で必要になった</li>\r\n                <li>金融機関から借り入れせず期日通りに支払いたい</li>\r\n                <li>手続きが簡単で手数料が安いサービスを利用したい</li>\r\n                <li>仕入れや投資のスピードを上げたい</li>\r\n              </ul>\r\n            </div>\r\n          </section>\r\n          <section class=\"l-section\">\r\n            <h3 class=\"c-heading -medium u-mb-32 u-sp-mb-24\">ご利用可能なブランド</h3>\r\n            <figure class=\"c-figure u-mb-40 u-sp-mb-32\"><img src=\"/assets/img/service/invoice/img_figure02.jpg\" alt=\"クレジットカードのロゴ画像\" loading=\"lazy\"></figure>\r\n            <figure class=\"c-figure\"><img src=\"/assets/img/service/invoice/img_figure03.jpg\" alt=\"一連の流れ\" loading=\"lazy\"></figure>\r\n          </section>\r\n          <section class=\"l-section\">\r\n            <h3 class=\"c-heading -medium u-mb-32 u-sp-mb-24\">手続きの流れ</h3>\r\n            <h4 class=\"c-heading -small u-mb-16\">1. Webにて利用登録（無料）</h4>\r\n            <p class=\"u-mb-32\">最短当日からご利用いただけます</p>\r\n            <h4 class=\"c-heading -small u-mb-16\">2. 請求書・取引先の登録</h4>\r\n            <p class=\"u-mb-32\">必要書類は請求書のみ</p>\r\n            <h4 class=\"c-heading -small u-mb-16\">3. カード支払いの実行</h4>\r\n            <p class=\"u-mb-40 u-sp-mb-32\">当社が振り込みを代行します</p>\r\n            <ul class=\"c-list -note\">\r\n              <li>必要書類：請求書のみ（日本国内の法人が発行する銀行振込の請求書に限ります。海外企業や個人事業主が発行した請求書はご利用いただけません）</li>\r\n              <li>ご登録およびご利用時には当社所定の審査があります</li>\r\n              <li>ご入力内容によっては、当社からお客さまへ確認の連絡をさせていただきます。また、本サービスのご利用ができない場合もあります</li>\r\n            </ul>\r\n          </section>\r\n          <section class=\"l-section\">\r\n            <h3 class=\"c-heading -medium u-mb-32 u-sp-mb-24\">さらに便利なサービス</h3>\r\n            <p>請求書を発行する請求者としてもご利用可能です（請求者向け）</p>\r\n            <ul class=\"c-list -dot u-mb-24\">\r\n              <li>本サービス（※1）は請求書を発行する請求者の立場としても便利に利用可能</li>\r\n              <li>発行した請求書は、取引先に早期支払いを案内しカード支払いをしてもらうことで、入金を早めることが可能</li>\r\n              <li>請求金額に対して早期支払い割引の設定が可能（※2）</li>\r\n              <li>早期回収により資金繰りを改善</li>\r\n              <li>利用手数料3.0％（税抜き）は請求者にご負担いただきます</li>\r\n            </ul>\r\n            <ul class=\"c-list -note-order u-mb-40 u-sp-mb-32\">\r\n              <li>個人事業主は請求者向けサービスをご利用いただけません</li>\r\n              <li>任意の割引率（％）を設定することが可能です</li>\r\n            </ul>\r\n            <figure class=\"c-figure\"><img src=\"/assets/img/service/invoice/img_figure04.jpg\" alt=\"請求書カード払いご利用イメージ\" loading=\"lazy\"></figure>\r\n          </section>\r\n          <section class=\"l-section -bg-blue\">\r\n            <div class=\"l-block-cta\">\r\n              <h2 class=\"l-block-cta__heading\">資料請求・よくあるご質問・<br class=\"sp-tb:view\">お問い合わせ</h2>\r\n              <p class=\"l-block-cta__lead\">気になるサービスに関する資料請求、<br class=\"sp:view\">お問い合わせはこちらから</p>\r\n              <p class=\"u-mb-24\">サービス詳細に関して、お客さまから寄せられた<br class=\"sp-tb:view\">「よくあるご質問」を掲載しています。<br>お問い合わせ前にご確認ください。</p>\r\n              <a href=\"/support/faq/\" class=\"l-block-cta__btn\"><span>よくあるご質問はこちらから</span></a>\r\n              <div class=\"c-btn-wrap -sp-column u-mt-24\">\r\n                <a href=\"https://qmnb.f.msgs.jp/webapp/form/26692_qmnb_3/index.do\" target=\"_blank\" rel=\"noopener\" class=\"c-btn -request\"><span>資料請求</span></a>\r\n                <a href=\"https://qmnb.f.msgs.jp/webapp/form/26692_qmnb_1/index.do\" target=\"_blank\" rel=\"noopener\" class=\"c-btn -contact\"><span>お問い合わせ</span></a>\r\n              </div>\r\n            </div>\r\n          </section>\r\n          <section id=\"service\" class=\"l-section -bg-gray\">\r\n            <h2 class=\"c-heading -medium -center -blue u-mb-32 u-sp-mb-24\">関連サービス</h2>\r\n            <div class=\"c-slider -panel js-slider\" data-show=\"3\">\r\n              <div class=\"c-slider__inner js-slider__inner\">\r\n                <a href=\"/service/e-collect/\" class=\"c-panel02\">\r\n                  <div class=\"c-panel02__img\"><img src=\"/assets/img/service/e-collect/img_mv.png\" alt=\"\" loading=\"lazy\"></div>\r\n                  <div class=\"c-panel02__ttl\">代金引換サービス</div>\r\n                  <div class=\"c-panel02__txt\">お客さまのショッピングに、安心と手軽さを提供します</div>\r\n                  <div class=\"c-panel02__tag\">\r\n                    <ul>\r\n                      <li>代金引換・決済</li>\r\n                      <li>決済-IT</li>\r\n                    </ul>\r\n                  </div>\r\n                </a>\r\n                <a href=\"/service/web-payment/\" class=\"c-panel02\">\r\n                  <div class=\"c-panel02__img\"><img src=\"/assets/img/service/web-payment/img_mv.png\" alt=\"\" loading=\"lazy\"></div>\r\n                  <div class=\"c-panel02__ttl\">ネット決済サービス</div>\r\n                  <div class=\"c-panel02__txt\">オンラインショッピングに欠かせない決済メニューを最適な形で提案します</div>\r\n                  <div class=\"c-panel02__tag\">\r\n                    <ul>\r\n                      <li>代金引換・決済</li>\r\n                      <li>決済-IT</li>\r\n                    </ul>\r\n                  </div>\r\n                </a>\r\n                <a href=\"/service/sg-kakebarai/\" class=\"c-panel02\">\r\n                  <div class=\"c-panel02__img\"><img src=\"/assets/img/service/sg-kakebarai/img_mv.png\" alt=\"\" loading=\"lazy\"></div>\r\n                  <div class=\"c-panel02__ttl\">B2B決済サービス(電子請求)</div>\r\n                  <div class=\"c-panel02__txt\">与信から入金管理まで、BtoB（法人・個人事業主）へのデジタル請求はお任せください</div>\r\n                  <div class=\"c-panel02__tag\">\r\n                    <ul>\r\n                      <li>代金引換・決済</li>\r\n                      <li>決済-IT</li>\r\n                    </ul>\r\n                  </div>\r\n                </a>\r\n              </div>\r\n              <div class=\"c-slider__nav\">\r\n                <div class=\"c-slider__pause\"></div>\r\n              </div>\r\n            </div>\r\n          </section>\r\n          <section id=\"support\" class=\"l-section\">\r\n            <h2 class=\"c-heading -medium -center -blue u-mb-32 u-sp-mb-24\">お客さまサポート</h2>\r\n            <div class=\"c-faq js-accordion\">\r\n              <div class=\"c-faq__ttl js-accordion__btn\">\r\n                <h2>誰でも利用できますか？</h2>\r\n              </div>\r\n              <div class=\"c-faq__contents js-accordion__contents\">\r\n                <p>カードをお持ちの法人や個人事業主がご利用いただけます。<br>ただし、個人事業主においては一部サービスをご利用いただけません。まずはお気軽にお問い合わせください。</p>\r\n              </div>\r\n            </div>\r\n            <div class=\"c-faq js-accordion\">\r\n              <div class=\"c-faq__ttl js-accordion__btn\">\r\n                <h2>利用できるカードの種類を教えてください。</h2>\r\n              </div>\r\n              <div class=\"c-faq__contents js-accordion__contents\">\r\n                <p>JCB、VISA、MasterCardブランドのカードがご利用になれます。</p>\r\n              </div>\r\n            </div>\r\n            <div class=\"c-faq js-accordion\">\r\n              <div class=\"c-faq__ttl js-accordion__btn\">\r\n                <h2>事前に準備することはありますか？</h2>\r\n              </div>\r\n              <div class=\"c-faq__contents js-accordion__contents\">\r\n                <p>カード支払いに切り替えたい請求書と対象のカードをご用意いただくと手続きがスムーズです。まずはお気軽にお問い合わせください。</p>\r\n              </div>\r\n            </div>\r\n            <div class=\"c-faq js-accordion\">\r\n              <div class=\"c-faq__ttl js-accordion__btn\">\r\n                <h2>サービス料金体系について教えてください。</h2>\r\n              </div>\r\n              <div class=\"c-faq__contents js-accordion__contents\">\r\n                <p>利用手数料は、カード支払いに切り替えた税込み請求金額の3.0％（税抜き）です。ただし、振込金額が1万円以下の場合は、一律300円（税抜き）となります。</p>\r\n              </div>\r\n            </div>\r\n            <div class=\"c-faq js-accordion\">\r\n              <div class=\"c-faq__ttl js-accordion__btn\">\r\n                <h2>カード支払い金額の上限・下限はありますか？</h2>\r\n              </div>\r\n              <div class=\"c-faq__contents js-accordion__contents\">\r\n                <p>お客さまが利用するカードの利用限度額内でご利用いただけます。</p>\r\n              </div>\r\n            </div>\r\n            <div class=\"c-btn-wrap u-mt-60 u-sp-mt-40\">\r\n              <a href=\"/support/faq/\" class=\"c-btn -small -border\"><span>よくあるご質問一覧へ</span></a>\r\n            </div>\r\n          </section>\r\n        </div>\r\n      </div>\r\n      <div class=\"l-cta\">\r\n        <div class=\"l-cta__btn\">\r\n          <a href=\"https://qmnb.f.msgs.jp/webapp/form/26692_qmnb_1/index.do\" target=\"_blank\" rel=\"noopener\" class=\"c-btn -contact\"><span>お問い合わせはこちらから</span></a>\r\n        </div>\r\n      </div>\r\n      <div class=\"l-breadcrumb\">\r\n        <div class=\"l-breadcrumb__inner\">\r\n          <ol class=\"l-breadcrumb__list\">\r\n            <li class=\"l-breadcrumb__item\"><a href=\"/\">ホーム</a></li>\r\n            <li class=\"l-breadcrumb__item\"><a href=\"/service/\">ソリューション・製品</a></li>\r\n            <li class=\"l-breadcrumb__item\"><a href=\"/service/invoice/\">B2B決済サービス(カード払い)</a></li>\r\n          </ol>\r\n        </div>\r\n      </div>\r\n  <script src=\"/assets/js/service/invoice.js\" defer></script>\n    </main>\n    ﻿<footer class=\"l-footer\">\r\n  <div class=\"l-footer__pagetop\">\r\n    <a href=\"#\"></a>\r\n  </div>\r\n  <div class=\"l-footer__head\">\r\n    <div class=\"l-footer__logo\">\r\n      <div>\r\n        <span>物流×ITのリーディングカンパニー</span>\r\n        <div>\r\n          <a href=\"https://www.sg-hldgs.co.jp/\" target=\"_blank\" rel=\"noopener\"><img src=\"/assets/img/common/logo_sgh.svg\" alt=\"SGホールディングス\"></a>\r\n          <a href=\"/\"><img src=\"/assets/img/common/logo_sgsystem.svg\" alt=\"SGシステム株式会社\"></a>\r\n        </div>\r\n      </div>\r\n    </div