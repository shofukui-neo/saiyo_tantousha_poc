{"url":"http://www.rands-co.com/recruit/career.html","html":"<!DOCTYPE HTML>\n<html>\n<head>\n<meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\">\n<title>キャリア採用｜採用情報｜株式会社リサーチアンドソリューション</title>\n<link rel=\"shortcut icon\" href=\"/img/favicon.ico\" type=\"image/vnd.microsoft.icon\" />\n<meta name=\"description\" content=\"株式会社リサーチアンドソリューション採用情報サイト「中途（キャリア）採用」のページです。募集要項やお申込み、福利厚生、勤務時間などを掲載。チャレンジ精神旺盛で、たとえ失敗をしても明るく前向きに挑戦し続けられる人募集中！働く環境やサポート制度についても紹介。詳細はこちらからチェック！\"/>\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1,minimum-scale=1,maximum-scale=1,user-scalable=no\" />\n<link rel=\"canonical\" href=\"https://www.rands-co.com/recruit/career.html\">\n<link href=\"/common/css/global.css\" rel=\"stylesheet\" type=\"text/css\">\n<link href=\"/common/css/layout.css\" rel=\"stylesheet\" type=\"text/css\">\n<link href=\"/css/recruit.css\" rel=\"stylesheet\" type=\"text/css\">\n<link href=\"css/repair.css\" rel=\"stylesheet\" type=\"text/css\">\n<link href=\"css/navimenu.css\" rel=\"stylesheet\" type=\"text/css\">\n<link href=\"/assets/common/css/r-footer.css\" rel=\"stylesheet\" type=\"text/css\">\n<!--<link href='http://fonts.googleapis.com/css?family=Oswald|Roboto+Condensed' rel='stylesheet' type='text/css'>-->\n<link href=\"https://fonts.googleapis.com/css?family=Oswald|Roboto+Condensed\" rel=\"stylesheet\" type=\"text/css\">\n<link href=\"https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@100;300;400;500;700;900&amp;display=swap\" rel=\"stylesheet\">\n<link href=\"https://fonts.googleapis.com/icon?family=Material+Icons\" rel=\"stylesheet\">\n<script src=\"https://ajax.googleapis.com/ajax/libs/jquery/3.6.1/jquery.min.js\"></script>\n<script type=\"text/javascript\" src=\"../common/js/jquery-1.8.2.min.js\"></script>\n<script type=\"text/javascript\" src=\"../common/js/jquery.easing.1.3.js\"></script>\n<script type=\"text/javascript\" src=\"../common/js/jquery.overflowScroll.js\"></script>\n<!--<script type=\"text/javascript\" src=\"../common/js/common.js\"></script>-->\n<script type=\"text/javascript\" src=\"/assets/common/js/common.js\"></script>\n<script type=\"text/javascript\" src=\"../js/recruit.js\"></script>\n<script src=\"/common/js/jquery.mobile.js\"></script>\n<script type=\"text/javascript\" src=\"../common/js/gtag.js\"></script>\n<script type=\"text/javascript\">\n$(document).bind(\"mobileinit\", function(){\n//Loadingメッセージ非表示\n$.mobile.loadingMessage = false;\n});\n</script>\n\n</head>\n\n<body id=\"recruit\">\n  <div id=\"wrap\">\n  <header class=\"header\">\n    <div class=\"header__inner\">\n      <div class=\"header__logo\"><a href=\"/recruit/\"><img src=\"/img/recruit/logo_recruit.svg\" alt=\"株式会社リサーチアンドソリューション　リクルート\"/></a></div>\n      <nav id=\"gNavi\">\n        <ul class=\"globalmenu\">\n          <li class=\"header__navitem\"><a href=\"/recruit/fresh.html\" class=\"btn_fresh slide header__navitemlink\">新卒採用</a></li>\n          <li class=\"header__navitem\"><a href=\"/recruit/career.html\" class=\"btn_career slide header__navitemlink\">キャリア採用</a></li>\n          <li>\n            <div class=\"ham-menu\">\n              <input type=\"checkbox\" id=\"menu-btn-check\">\n              <label for=\"menu-btn-check\" class=\"spnav-btn\"><p><span></span></p></label>\n              <div class=\"spnav-content\">\n                <ul class=\"globalmenu\">\n                  <li class=\"header__navitem\"><a href=\"/recruit/fresh.html\" class=\"btn_fresh_sp slide header__navitemlink\">新卒採用</a></li>\n                  <li class=\"header__navitem\"><a href=\"/recruit/career.html\" class=\"btn_career_sp slide header__navitemlink\">キャリア採用</a></li>\n                </ul>\n                <div class=\"spnav-item__wrap\">\n                  <div class=\"spnav-item__txt\">\n                    <ul>\n                      <li class=\"cate-name\">会社を知る<span class=\"cate-e\">ABOUT US</span></li>\n                      <li class=\"link-item\"><a href=\"/recruit/message.html\">社長メッセージ</a></li>\n                      <li class=\"link-item\"><a href=\"/\">コーポレートサイト</a></li>\n                    </ul>\n                    <ul>\n                      <li class=\"cate-name\">仕事を知る<span class=\"cate-e\">WORK</span></li>\n                      <li class=\"link-item\"><a href=\"/recruit/voice.html\">先輩社員の声</a></li>\n                      <li class=\"link-item\"><a href=\"/recruit/data.html\">数字で見るリサーチアンドソリューション</a></li>\n                      <!--<li class=\"link-item\"><a href=\"/recruit/#\">職種紹介</a></li>-->\n                      <!--<li class=\"link-item\"><a href=\"/recruit/#\">リサーチアンドソリューションBlog</a></li>-->\n                    </ul>\n                  </div>\n                  <div class=\"spnav-item__txt\">\n                    <!--<ul>\n                      <li class=\"cate-name\">環境を知る<span class=\"cate-e\">ENVIRONMENT</span></li>\n                      <li class=\"link-item\"><a href=\"/recruit/#\">福利厚生</a></li>\n                      <li class=\"link-item\"><a href=\"/recruit/#\">研修内容</a></li>\n                    </ul>-->\n                    <!--<p class=\"cntent-mane\"><a href=\"/recruit/#\">FAQ</a></p>-->\n                    <ul>\n                      <li class=\"cate-name\"><a href=\"/recruit/\">採用TOP<span class=\"cate-e\">RECRUIT TOP</span></a></li>\n                    </ul>\n                  </div>\n                  <div class=\"spnav-item__bnr\">\n                    <ul class=\"bnr-entry\">\n                      <!--<li class=\"bnr-item\"><a href=\"/rands_form/toroku/form_recruit_entry_fresh.html\" class=\"btn__bnr__fresh\"><span>新卒<br>エントリー</span><img src=\"../img/recruit/icon_mail_fresh.svg\" alt=\"\"/></a></li>-->\n                      <li class=\"bnr-item\"><a href=\"/rands_form/toroku/form_contact3_sub.html\" class=\"btn__bnr__career\"><span>キャリア<br>エントリー</span><img src=\"../img/recruit/icon_mail_career.svg\" alt=\"\"/></a></li>\n                    </ul>\n                    <div class=\"bnr-box\">\n                      <!--<div class=\"bnr-ets\"><a href=\"/recruit/#\" class=\"bnr-discussion\"><img src=\"../img/recruit/bnr_discussion.svg\" alt=\"座談会エントリー\"/></a></div>\n                      <div class=\"bnr-ets-sp\"><a href=\"/recruit/#\" class=\"bnr-discussion\"></a></div>-->\n                      <ul class=\"bnr-prom\">\n                        <li class=\"prom-item\"><a href=\"https://note.com/rands/\" target=\"_blank\"><span>note</span><img src=\"../img/recruit/icon_exitlink.svg\" alt=\"\" class=\"exitlink\"/></a></li>\n                        <li class=\"prom-item mt-1em\"><a href=\"https://www.wantedly.com/companies/company_1826445\" target=\"_blank\"><span>wantedly</span><img src=\"../img/recruit/icon_exitlink.svg\" alt=\"\" class=\"exitlink\"/></a></li>\n                      </ul>\n                    </div>\n                  </div>\n                </div>\n              </div>\n              <div class=\"hamburger-demo-cover\"></div>\n            </div>\n          </li>\n        </ul>\n      </nav>\n    </div>\n  </header>\n    <div id=\"container\" class=\"career\">\n      <div id=\"mainBox\">\n        <div id=\"contents\">\n          <div id=\"main\">\n            <h1><span class=\"type-e\">RECRUIT INFORMATION</span><span class=\"type-j\">採用情報</span>キャリア採用</h1>\n          </div>\n          <div class=\"c-headline__wrap\">\n            <ul class=\"c-headline__slider\">\n              <li><img src=\"../img/recruit/img_slide_c1.png\" alt=\"\"></li>\n              <li class=\"even-img\"><img src=\"../img/recruit/img_slide_c2.png\" alt=\"\"></li>\n              <li><img src=\"../img/recruit/img_slide_c3.png\" alt=\"\"></li>\n              <li class=\"even-img\"><img src=\"../img/recruit/img_slide_c4.png\" alt=\"\"></li>\n            </ul>\n            <div class=\"c-headline__eyecatch-or\">\n              <div class=\"line1\"><span>社会を</span><span>変える。</span><span>会社を</span><span>変える。</span><span>自分が</span><span>変わる。</span></div>\n              <div class=\"line2\"><span>私</span><span>た</span><span>ち</span><span>と</span><span>一</span><span>緒</span><span>に</span></div>\n              <div class=\"line3\"><span>チ</span><span>ャ</span><span>レ</span><span>ン</span><span>ジ</span><span>し</span><span>て</span><span>み</span><span>ま</span><span>せ</span><span>ん</span><span>か</span><span>？</span></div>\n            </div>\n          </div>\n          <section class=\"c-lead\">\n            <div class=\"sec__inner\">\n              <h2 class=\"fc-or\">こんな方を求めています。</h2>\n              <h4><span>チャレンジ精神旺盛で最後まで諦めない粘り強さを兼ね備えた方</span></h4>\n              <h4><span>人と接することが好きな方、周囲への気配りを心掛ける方</span></h4>\n              <h4><span>同じ事をやるにも必ず工夫して、前よりうまくやろうと考える方</span></h4>\n              <div class=\"btn__entry\">\n                <a href=\"/rands_form/toroku/form_contact3_sub.html\" class=\"bgc-or\">エントリー<span>キャリア採用応募</span></a>\n              </div>\n            </div>\n          </section>\n          <section class=\"inset__bg-grey pt-100\">\n            <div class=\"sec__inner\">\n              <h3 class=\"orangeline\">募集職種</h3>\n              <div class=\"inset__wrap80\">\n                <ul class=\"c-recruiting__list\">\n                  <li>\n                    <p class=\"number\">01.</p>\n                    <p class=\"office\">福岡</p>\n                    <p class=\"job\">システムエンジニア（パッケージ開発・プロジェクトリーダー）</p>\n                    <p class=\"btn\"><a href=\"#recruiting1\">募集要項</a></p>\n                  </li>\n                  <li>\n                    <p class=\"number\">02.</p>\n                    <p class=\"office\">東京</p>\n                    <p class=\"job\">システムソリューション営業（プレイングマネージャー）</p>\n                    <p class=\"btn\"><a href=\"#recruiting2\">募集要項</a></p>\n                  </li>\n                  <li>\n                    <p class=\"number\">03.</p>\n                    <p class=\"office\">東京</p>\n                    <p class=\"job\">システムエンジニア</p>\n                    <p class=\"btn\"><a href=\"#recruiting3\">募集要項</a></p>\n                  </li>\n                </ul>\n              </div>\n            </div>\n          </section>\n          <section class=\"inset__bg-grey\">\n            <div class=\"sec__inner\">\n              <h3 class=\"orangeline\">募集要項</h3>\n              <div class=\"inset__wrap80\">\n                <div class=\"c-recruiting__ditail mb-80\" id=\"recruiting1\">\n                  <h4 class=\"c-recruiting__ditail__ttl\">\n                    <p class=\"number\">01.</p>\n                    <p class=\"office\">福岡</p>\n                    <p>システムエンジニア（パッケージ開発・プロジェクトリーダー）</p>\n                  </h4>\n                  <div class=\"c-recruiting__ditail__wrap\">\n                    <table>\n                      <tbody>\n                        <tr>\n                          <th scope=\"row\">募集職種&nbsp;</th>\n                          <td>システムエンジニア（プロジェクトリーダー）</td>\n                        </tr>\n                        <tr>\n                          <th scope=\"row\">雇用形態</th>\n                          <td>正社員</td>\n                        </tr>\n                        <tr>\n                          <th scope=\"row\">就業場所</th>\n                          <td>福岡本社（福岡県福岡市博多区上呉服町12-33）</td>\n                        </tr>\n                        <tr>\n                          <th scope=\"row\">仕事の内容</th>\n                          <td>自社パッケージのシステム構築、保守、受託開発業務の構築に関して、経験、スキル、適性などに応じた仕事をお任せします。<br>\n                            具体的には以下の内容となります。<br>\n                            ≪主たる作業≫<br>\n                            ■システム要件定義、システムの設計、プログラム、テスト等<br>\n                            具体的には…<br>\n                            ・パッケージシステムの機能強化、顧客要望のカスタマイズ、導入支援等。<br>\n                            ・受託開発業務のシステム設計、プログラム、テスト等。<br>\n                            ・グループ会社から依頼されたシステム開発業務（GIS、CADなど）<br>\n                            ≪主な開発環境（言語）≫<br>\n                            ■C#、Postgres、Java、PHP等</td>\n                        </tr>\n                        <tr>\n                          <th scope=\"row\">募集条件</th>\n                          <td>≪必須≫<br>\n                            ・プログラム開発経験（システム要件定義からシステムテストまで）<br>\n                            ≪尚可≫<br>\n                            ・10人月～50人月程度のPMとしてプロジェクト管理経験</td>\n                        </tr>\n                        <tr>\n                          <th scope=\"row\">就業時間</th>\n                          <td>当社規程による</td>\n                        </tr>\n                        <tr>\n                          <th scope=\"row\">休日</th>\n                          <td>土曜日、日曜日及び祝日、その他会社の指定する日</td>\n                        </tr>\n                        <tr                        <tr>\n                          <th scope=\"row\">就業開始希望日</th>\n                          <td>即日</td>\n                        </tr>\n                        <tr>\n                          <th scope=\"row\">学歴</th>\n                          <td>不問</td>\n                        </tr>\n                        <tr>\n                          <th scope=\"row\">資格</th>\n                          <td>不問</td>\n                        </tr>\n                        <tr>\n                          <th scope=\"row\">年次有給休暇等</th>\n                          <td>就業規則による</td>\n                        </tr>\n                        <tr>\n                          <th scope=\"row\">給与</th>\n                          <td>経験／スキル／能力を考慮の上、当社規程により支給</td>\n                        </tr>\n                        <tr>\n                          <th scope=\"row\">賞与</th>\n                          <td>当社規程による</td>\n                        </tr>\n                        <tr>\n                          <th scope=\"row\">退職金</th>\n                          <td>あり（入社3年目以降）</td>\n                        </tr>\n                        <tr>\n                          <th scope=\"row\">通勤手当</th>\n                          <td>支給する</td>\n                        </tr>\n                        <tr>\n                          <th scope=\"row\">昇格に関する事項</th>\n                          <td>昇降給は、年1回とする（能力考課を実施）</td>\n                        </tr>\n                      </tbody>\n                    </table>\n                    <div class=\"btn__entry\">\n                      <a href=\"/rands_form/toroku/form_contact3_sub.html\" class=\"bgc-or\">エントリー<span>キャリア採用応募</span></a>\n                    </div>\n                  </div>\n                </div>\n                <div class=\"c-recruiting__ditail mb-80\" id=\"recruiting2\">\n                  <h4 class=\"c-recruiting__ditail__ttl\">\n                    <p class=\"number\">02.</p>\n                    <p class=\"office\">東京</p>\n                    <p>システムソリューション営業（プレイングマネージャー）</p>\n                  </h4>\n                  <div class=\"c-recruiting__ditail__wrap\">\n                    <table>\n                      <tbody>\n                        <tr>\n                          <th scope=\"row\">募集職種&nbsp;</th>\n                          <td>システムソリューション営業マネージャー</td>\n                        </tr>\n                        <tr>\n                          <th scope=\"row\">雇用形態</th>\n                          <td>正社員</td>\n                        </tr>\n                        <tr>\n                          <th scope=\"row\">就業場所</th>\n                          <td>東京本社（東京都渋谷区本町4-12-7　泉西新宿ビル3階）</td>\n                        </tr>\n                        <tr>\n                          <th scope=\"row\">仕事の内容</th>\n                          <td>首都圏エリアにおける新規顧客獲得を中心とした、営業プレイングマネージャーを募集します。<br>\n                            ［具体的な仕事内容］<br>\n                            ・当社クラウドサービスを切り口とした新規顧客の開拓<br>\n                            ・当社グループ企業と連携した官公庁へのソリューション提案<br>\n                            ・チームメンバーのマネジメント、育成、評価<br>\n                            ・販売促進を目的とした展示会出展等のプロモーション企画<br>\n                            ・新製品、サービスの企画提案</td>\n                        </tr>\n                        <tr>\n                          <th scope=\"row\">募集条件</th>\n                          <td>１）ITソリューション営業部門にて3年以上のマネジメント経験<br>\n                            ２）プレイングマネージャーに抵抗がない方<br>\n                            ３）文書や提案資料作成に必要なExcel・Word・PowerPointの操作知識<br>\n                            ４）困難な状況でも最後まで粘り強く交渉を続ける事が出来る方<br>\n                            ５）人の意見に耳を傾ける事が出来る方</td>\n                        </tr>\n                        <tr>\n                          <th scope=\"row\">就業時間</th>\n                          <td>当社規程による</td>\n                        </tr>\n                        <tr>\n                          <th scope=\"row\">休日</th>\n                          <td>土曜日、日曜日及び祝日、その他会社の指定する日</td>\n                        </tr>\n                        <tr                        <tr>\n                          <th scope=\"row\">就業開始希望日</th>\n                          <td>即日</td>\n                        </tr>\n                        <tr>\n                          <th scope=\"row\">学歴</th>\n                          <td>不問</td>\n                        </tr>\n                        <tr>\n                          <th scope=\"row\">資格</th>\n                          <td>不問</td>\n                        </tr>\n                        <tr>\n                          <th scope=\"row\">年次有給休暇等</th>\n                          <td>就業規則による</td>\n                        </tr>\n                        <tr>\n                          <th scope=\"row\">給与</th>\n                          <td>経験／スキル／能力を考慮の上、当社規程により支給</td>\n                        </tr>\n                        <tr>\n                          <th scope=\"row\">賞与</th>\n                          <td>当社規程による</td>\n                        </tr>\n                        <tr>\n                          <th scope=\"row\">退職金</th>\n                          <td>あり（入社3年目以降）</td>\n                        </tr>\n                        <tr>\n                          <th scope=\"row\">通勤手当</th>\n                          <td>支給する</td>\n                        </tr>\n                        <tr>\n                          <th scope=\"row\">昇格に関する事項</th>\n                          <td>昇降給は、年1回とする（能力考課を実施）</td>\n                        </tr>\n                      </tbody>\n                    </table>\n                    <div class=\"btn__entry\">\n                      <a href=\"/rands_form/toroku/form_contact3_sub.html\" class=\"bgc-or\">エントリー<span>キャリア採用応募</span></a>\n                    </div>\n                  </div>\n                </div>\n\n                <div class=\"c-recruiting__ditail\" id=\"recruiting3\">\n                  <h4 class=\"c-recruiting__ditail__ttl\">\n                    <p class=\"number\">03.</p>\n                    <p class=\"office\">東京</p>\n                    <p>システムエンジニア</p>\n                  </h4>\n                  <div class=\"c-recruiting__ditail__wrap\">\n                    <table>\n                      <tbody>\n                        <tr>\n                          <th scope=\"row\">募集職種&nbsp;</th>\n                          <td>システムエンジニア</td>\n                        </tr>\n                        <tr>\n                          <th scope=\"row\">雇用形態</th>\n                          <td>正社員</td>\n                        </tr>\n                        <tr>\n                          <th scope=\"row\">就業場所</th>\n                          <td>東京本社（東京都渋谷区本町4-12-7　泉西新宿ビル3階）<br>\n                          及び労働者の自宅での勤務、または会社が定める場所</td>\n                        </tr>\n                        <tr>\n                          <th scope=\"row\">仕事の内容</th>\n                          <td>ITエンジニアとして、Web・オープン系などの案件を中心に携わっていただきます。\n                          幅広い案件の中からあなたの希望や適性に合ったプロジェクトをお任せします。<br><br>\n                            ＜案件例＞<br>\n                            ◎アミューズメント関連認証システムの機能追加・保守運用<br>\n                            └認証システムの機能追加、保守<br>\n                            <br>\n                            ◎販売管理の案件<br>\n                            └DX推進支援<br>\n                            <br>\n                            ◎公共分野の自社開発案件<br>\n                            └DX推進支援<br>\n                            └Web・スマートデバイス向けアプリケーションの設計・開発<br>\n                            <br>\n                            ◎公共分野のITサポート<br>\n                            <br>\n                            ◎某官庁の新機能追加<br>\n                            └贈与税の自動算出機能<br>\n                            └帳票出力機能<br>\n                            └共通機能ツール<br>\n                            └障害対応 等<br>\n                            <br>\n                            ◎携帯ショップの販売サイト制作<br>\n                            <br>\n                            ◎駐車場の管理システムの開発<br>\n                            <br>\n                            ◎貿易関連のシステム開発<br>\n                            <br>\n                            ◎宇宙衛星のシステム制御の構築<br>\n                            └衛星を活用した製造ラインの管理<br>\n                            <br>\n                            ◎公共インフラに関する請負開発<br>\n                            └河川水位予測案件 等<br>\n                            <br>\n                            ◎ICTソリューション事業<br>\n                            └公共積算パッケージソフトウェア開発<br>\n                            └GIS（地理情報システム）道路管理開発<br>\n                            └スマートデバイスソリューション 等<br>\n\n                            </td>\n                        </tr>\n                        <tr>\n                          <th scope=\"row\">募集条件</th>\n                          <td>システム開発の実務経験がある方（ジャンル不問）テスト・PGでも可<br>\n                            経験が浅い方（1年以上目安）から豊富な方まで歓迎<br>\n                            ≪主な開発環境（言語）≫<br>\n                            JAVA、C#、Python等\n                          </td>\n                        </tr>\n                        <tr>\n                          <th scope=\"row\">就業時間</th>\n                          <td>09:00～17:30（実働7時間15分／休憩1時間15分）</td>\n                        </tr>\n                        <tr>\n                          <th scope=\"row\">休日</th>\n                          <td>土曜日、日曜日及び祝日、その他会社の指定する日</td>\n                        </tr>\n                        <tr                        <tr>\n                          <th scope=\"row\">就業開始希望日</th>\n                          <td>ご希望にあわせます</td>\n                        </tr>\n                        <tr>\n                          <th scope=\"row\">学歴</th>\n                          <td>不問</td>\n                        </tr>\n                        <tr>\n                          <th scope=\"row\">資格</th>\n                          <td>不問</td>\n                        </tr>\n                        <tr>\n                          <th scope=\"row\">年次有給休暇等</th>\n                          <td>就業規則による</td>\n                        </tr>\n                        <tr>\n                          <th scope=\"row\">給与</th>\n                          <td>経験／スキル／能力を考慮の上、当社規程により支給</td>\n                        </tr>\n                        <tr>\n                          <th scope=\"row\">賞与</th>\n                          <td>当社規程による</td>\n                        </tr>\n                        <tr>\n                          <th scope=\"row\">退職金</th>\n                          <td>あり（入社3年目以降）</td>\n                        </tr>\n                        <tr>\n                          <th scope=\"row\">通勤手当</th>\n                          <td>支給する</td>\n                        </tr>\n                        <tr>\n                          <th scope=\"row\">昇格に関する事項</th>\n                          <td>昇降給は、年1回とする（能力考課を実施）</td>\n                        </tr>\n                      </tbody>\n                    </table>\n                    <div class=\"btn__entry\">\n                      <a href=\"/rands_form/toroku/form_contact3_sub.html\" class=\"bgc-or\">エントリー<span>キャリア採用応募</span></a>\n                    </div>\n                  </div>\n                </div>\n\n              </div>\n            </div>\n          </section>\n          <section class=\"c-data pb-none mt-100\">\n            <div class=\"sec__inner\">\n              <div class=\"btn__wrap\">\n                <div class=\"btn__ttl\">エントリーは<br>こちら</div>\n                <div class=\"btn__parts\"><a href=\"/recruit/fresh.html\" class=\"btn__entry-f inset__fx__sb-nwp\">新卒採用<span>ENTRY：FRESH</span></a></div>\n                <div class=\"btn__parts\"><a href=\"/recruit/career.html\" class=\"btn__entry-c inset__fx__sb-nwp\">キャリア採用<span>ENTRY：CAREER</span></a></div>\n              </div>\n            </div>\n          </section>\n          <section class=\"pb-none\">\n            <div class=\"sec__inner\">\n              <ul id=\"lNavi\">\n                <li id=\"lNavi01\" class=\"upper\"><a href=\"/recruit/message.html\"><span><span>MESSAGE</span>メッセージ</span></a></li>\n                <li id=\"lNavi02\" class=\"upper\"><a href=\"/recruit/voice/\"><span><span>VOICE</span>先輩の声</span></a></li>\n                <li id=\"lNavi05\" class=\"upper\"><a href=\"/recruit/data.html\"><span><span>ENVIRONMENT</span>働く環境</span></a></li>\n                <li id=\"lNavi03\" class=\"lower\"><a href=\"/recruit/fresh.html\"><span><span>ENTRY：FRESH</span>エントリー：新卒採用</span></a></li>\n                <li id=\"lNavi04\" class=\"lower\"><a href=\"/recruit/career.html\"><span><span>ENTRY：CAREER</span>エントリー：キャリア採用</span></a></li>\n              </ul>\n            </div>\n          </section>\n        </div>\n      </div>\n    </div>\n\n  <div id=\"pageTop\" style=\"display: block;\"><a href=\"#wrap\"><img src=\"../common/img/icon_pagetop.svg\" class=\"pagetop__arrow\" alt=\"\"></a></div>\n  <footer class=\"footer__outer mt-none pt-none\" id=\"parts_footer\">\n  </footer>\n\n  </div>\n\n<link rel=\"stylesheet\" type=\"text/css\" href=\"https://cdnjs.cloudflare.com/ajax/libs/slick-carousel/1.9.0/slick.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"https://cdnjs.cloudflare.com/ajax/libs/slick-carousel/1.9.0/slick-theme.css\">\n<!--<script src=\"https://ajax.googleapis.com/ajax/libs/jquery/3.6.1/jquery.min.js\"></script>-->\n<script type=\"text/javascript\" src=\"https://cdnjs.cloudflare.com/ajax/libs/slick-carousel/1.9.0/slick.m