=\"\" size=\"20\" autocomplete=\"current-password\" spellcheck=\"false\" required=\"required\" />\n\t\t\t\t\t<button type=\"button\" class=\"button button-secondary wp-hide-pw hide-if-no-js\" data-toggle=\"0\" aria-label=\"パスワードを表示\">\n\t\t\t\t\t\t<span class=\"dashicons dashicons-visibility\" aria-hidden=\"true\"></span>\n\t\t\t\t\t</button>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t\t\t\t\t<p class=\"forgetmenot\"><input name=\"rememberme\" type=\"checkbox\" id=\"rememberme\" value=\"forever\"  /> <label for=\"rememberme\">ログイン状態を保存する</label></p>\n\t\t\t<p class=\"submit\">\n\t\t\t\t<input type=\"submit\" name=\"wp-submit\" id=\"wp-submit\" class=\"button button-primary button-large\" value=\"ログイン\" />\n\t\t\t\t\t\t\t\t\t<input type=\"hidden\" name=\"redirect_to\" value=\"https://www.tbts.co.jp/members/wp-admin/\" />\n\t\t\t\t\t\t\t\t\t<input type=\"hidden\" name=\"testcookie\" value=\"1\" />\n\t\t\t</p>\n\t\t</form>\n\n\t\t\t\t\t<p id=\"nav\">\n\t\t\t\t<a class=\"wp-login-lost-password\" href=\"https://www.tbts.co.jp/members/wp-login.php?action=lostpassword\">パスワードをお忘れですか ?</a>\t\t\t</p>\n\t\t\t<script type=\"text/javascript\">\n/* <![CDATA[ */\nfunction wp_attempt_focus() {setTimeout( function() {try {d = document.getElementById( \"user_login\" );d.focus(); d.select();} catch( er ) {}}, 200);}\nwp_attempt_focus();\nif ( typeof wpOnload === 'function' ) { wpOnload() }\n/* ]]> */\n</script>\n\t\t<p id=\"backtoblog\">\n\t\t\t<a href=\"https://www.tbts.co.jp/members/\">&larr; サポートサイト | 東京貿易テクノシステム へ移動</a>\t\t</p>\n\t\t\t</div>\n\t\t\t\t<div class=\"language-switcher\">\n\t\t\t\t<form id=\"language-switcher\" method=\"get\">\n\n\t\t\t\t\t<label for=\"language-switcher-locales\">\n\t\t\t\t\t\t<span class=\"dashicons dashicons-translation\" aria-hidden=\"true\"></span>\n\t\t\t\t\t\t<span class=\"screen-reader-text\">\n\t\t\t\t\t\t\t言語\t\t\t\t\t\t</span>\n\t\t\t\t\t</label>\n\n\t\t\t\t\t<select name=\"wp_lang\" id=\"language-switcher-locales\"><option value=\"en_US\" lang=\"en