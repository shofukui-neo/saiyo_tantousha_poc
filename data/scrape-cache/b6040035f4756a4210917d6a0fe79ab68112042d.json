">内定</div>\r\n                                    </div>\r\n                                </li>\r\n                            </ol>\r\n                        </div>\r\n                        <div class=\"p-recruitment__schedule__block\">\r\n                            <h3 class=\"_ttl\">大学卒業の方</h3>\r\n                            <ol class=\"p-recruitment__schedule__list\">\r\n                                <li>\r\n                                    <div class=\"_circle\"><span class=\"_small\">step</span><span class=\"_num\">01</span></div>\r\n                                    <div class=\"_txt\">\r\n                                        <div class=\"_inner\">WEBエントリー</div>\r\n                                    </div>\r\n                                </li>\r\n                                <li>\r\n                                    <div class=\"_circle\"><span class=\"_small\">step</span><span class=\"_num\">02</span></div>\r\n                                    <div class=\"_txt\">\r\n                                        <div class=\"_inner\">会社説明会<span class=\"_kome\">※オンラインまたは対面</span></div>\r\n                                    </div>\r\n                                </li>\r\n                                <li>\r\n                                    <div class=\"_circle\"><span class=\"_small\">step</span><span class=\"_num\">03</span></div>\r\n                                    <div class=\"_txt\">\r\n                                        <div class=\"_inner\">応募受付<span class=\"_kome\">※ご応募いただいた方全員と面接をします。</span></div>\r\n                                    </div>\r\n                                </li>\r\n                                <li>\r\n                                    <div class=\"_circle\"><span class=\"_small\">step</span><span class=\"_num\">04</span></div>\r\n                                    <div class=\"_txt\">\r\n                                        <div class=\"_inner\">SPI受検<span class=\"_small\">（オンライン）</sp