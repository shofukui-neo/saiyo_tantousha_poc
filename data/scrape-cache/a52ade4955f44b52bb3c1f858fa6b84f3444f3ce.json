1x, /inc/image/top/kv/slider/pic_kvSlider-left02Sp@2x.png.webp 2x\" type=\"image/webp\">\n                          <img src=\"/inc/image/top/kv/slider/pic_kvSlider-left02Sp.png\" alt=\"\">\n                        </picture>\n                      </div>\n                      <div class=\"p-kvSubImage__bottom\">\n                        <picture class=\"p-kvSlider__img p-kvSlider__img--bottom\">\n                          <source srcset=\"/inc/image/top/kv/slider/pic_kvSlider-bottom02.png.webp 1x, /inc/image/top/kv/slider/pic_kvSlider-bottom02@2x.png.webp 2x\" type=\"image/webp\">\n                          <img src=\"/inc/image/top/kv/slider/pic_kvSlider-bottom02.png\" alt=\"\">\n                        </picture>\n                        <picture class=\"p-kvSlider__img p-kvSlider__img--bottomSp\">\n                          <source srcset=\"/inc/image/top/kv/slider/pic_kvSlider-bottom02Sp.png.webp 1x, /inc/image/top/kv/slider/pic_kvSlider-bottom02Sp@2x.png.webp 2x\" type=\"image/webp\">\n                          <img src=\"/inc/image/top/kv/slider/pic_kvSlider-bottom02Sp.png\" alt=\"\">\n                        </picture>\n                      </div>\n                    </div>\n                  </li>\n                  <li class=\"swiper-slide\">\n                    <div class=\"p-kvSlider p-kvSlider--main\">\n                      <picture class=\"p-kvSlider__img p-kvSlider__img--main\">\n                        <source srcset=\"/inc/image/top/kv/slider/pic_kvSlider-main03.png.webp 1x, /inc/image/top/kv/slider/pic_kvSlider-main03@2x.png.webp 2x\" type=\"image/webp\">\n                        <img src=\"/inc/image/top/kv/slider/pic_kvSlider-main03.png\" alt=\"\">\n                      </picture>\n                      <picture class=\"p-kvSlider__img p-kvSlider__img--mainSp\">\n                        <source srcset=\"/inc/image/top/kv/slider/pic_kvSlider-main03Sp.png.webp 1x, /inc/image/top/kv/slider/pic_kvSlider-main03Sp@2x.png.webp 2x\" type=\"image/webp\">\n                        <img src=\"/inc/image/top/kv/slider/pic_kvSlider-main03Sp.png\" alt=\"\">\n                      </picture>\n                    </div>\n                    <div class=\"p-kvSlider p-kvSlider--left\">\n                      <div class=\"p-kvSubImage__top\">\n                        <picture class=\"p-kvSlider__img p-kvSlider__img--left\">\n                          <source srcset=\"/inc/image/top/kv/slider/pic_kvSlider-left03.png.webp 1x, /inc/image/top/kv/slider/pic_kvSlider-left03@2x.png.webp 2x\" type=\"image/webp\">\n                          <img src=\"/inc/image/top/kv/slider/pic_kvSlider-left03.png\" alt=\"\">\n                        </picture>\n                        <picture class=\"p-kvSlider__img p-kvSlider__img--leftSp\">\n                          <source srcset=\"/inc/image/top/kv/slider/pic_kvSlider-left03Sp.png.webp 1x, /inc/image/top/kv/slider/pic_kvSlider-left03Sp@2x.png.webp 2x\" type=\"image/webp\">\n                          <img src=\"/inc/image/top/kv/slider/pic_kvSlider-left03Sp.png\" alt=\"\">\n                        </picture>\n                      </div>\n                      <div class=\"p-kvSubImage__bottom\">\n                        <picture class=\"p-kvSlider__img p-kvSlider__img--bottom\">\n                          <source srcset=\"/inc/image/top/kv/slider/pic_kvSlider-bottom03.png.webp 1x, /inc/image/top/kv/slider/pic_kvSlider-bottom03@2x.png.webp 2x\" type=\"image/webp\">\n                          <img src=\"/inc/image/top/kv/slider/pic_kvSlider-bottom03.png\" alt=\"\">\n                        </picture>\n                        <picture class=\"p-kvSlider__img p-kvSlider__img--bottomSp\">\n                          <source srcset=\"/inc/image/top/kv/slider/pic_kvSlider-bottom03Sp.png.webp 1x, /inc/image/top/kv/slider/pic_kvSlider-bottom03Sp@2x.png.webp 2x\" type=\"image/webp\">\n                          <img src=\"/inc/image/top/kv/slider/pic_kvSlider-bottom03Sp.png\" alt=\"\">\n                        </picture>\n                      </div>\n                    </div>\n                  </li>\n                </ul>\n              </div>\n              <picture class=\"p-kv__imageAreaBg\">\n                <source srcset=\"/inc/image/top/kv/img_kvMain.png.webp 1x, /inc/image/top/kv/img_kvMain@2x.png.webp 2x\" type=\"image/webp\">\n                <img src=\"/inc/image/top/kv/img_kvMain.png\" alt=\"\">\n              </picture>\n            </div>\n          </div>\n        </div>\n      </div>\n      <div id=\"wrapper\">\n        <div class=\"p-strength__wrapper\">\n          <section class=\"l-section l-section--full p-strength\">\n            <div class=\"l-section__inner p-strength__inner\">\n              <div class=\"p-strength__Grid\">\n                <picture class=\"p-strength__imageArea\">\n                  <source srcset=\"/inc/image/top/pic_strength.png.webp 1x, /inc/image/top/pic_strength@2x.png.webp 2x\" type=\"image/webp\">\n                  <img src=\"/inc/image/top/pic_strength.png\" alt=\"私たちの強み\">\n                </picture>\n                <div class=\"p-strength__textArea\">\n                  <h2 class=\"c-ttl-main c-ttl-main--mbShort\">\n                    <span class=\"c-ttl-main__sub\">OUR STRENGTH</span> 私たちの強み\n                  </h2>\n                  <p>私たちはお客様に最高品質のサービスを提供するため、日々努力しています。新たな価値を生む提案力と迅速な対応力で、お客様のあらゆるニーズにお応えします。</p>\n                  <ul class=\"p-strengthList\">\n                    <li class=\"p-strengthList__item\">\n                      <a href=\"/strength/#strength_01\" class=\"p-strengthList__link\"> ワンストップで<br> スピード感のある対応力 </a>\n                    </li>\n                    <li class=\"p-strengthList__item\">\n                      <a href=\"/strength/#strength_02\" class=\"p-strengthList__link\"> 多様性に富み<br> 新たな価値を生み出す提案力 </a>\n                    </li>\n                    <li class=\"p-strengthList__item\">\n                      <a href=\"/strength/#strength_03\" class=\"p-strengthList__link\"> 2つの事業領域で<br> 高めあうパートナーシップ </a>\n                    </li>\n                  </ul>\n                </div>\n              </div>\n            </div>\n          </section>\n        </div>\n        <div class=\"p-bussiness__wrapper\">\n          <section class=\"l-section p-bussiness\">\n            <div class=\"p-bussiness__infoArea\">\n              <h2 class=\"c-ttl-main p-bussiness__title\">\n                <span class=\"c-ttl-main__sub\">BUSINESS</span> 事業紹介\n              </h2>\n              <p class=\"p-bussiness__text\"> 産機事業と環境事業のリーディングカンパニーである山産は、2つの分野から未来に繋がるビジネスに貢献します。 </p>\n              <a href=\"/business/\" class=\"c-roundArrowBtn p-bussiness__btn\">事業紹介を<br class=\"u-only-xs\">詳しく見る</a>\n            </div>\n            <div class=\"p-bussinessContent\">\n              <a href=\"/business/industrial-machinery/about/\" class=\"p-bussinessContent__link\">\n                <div class=\"p-bussinessContent__Grid\">\n                  <div class=\"p-bussinessContent__infoArea\">\n                    <h3 class=\"p-bussinessContent__title\">産機事業</h3>\n                    <p class=\"p-bussinessContent__text\">エネルギー・ユーティリティー / 環境設備/ポンプ・ファン・風水力機械 /化学・食品・粉粒体機械 / 試験・検査・計測機械装置 / 物流機械</p>\n                    <span class=\"c-roundArrowBtn\">産機事業を詳しく見る</span>\n                  </div>\n                  <div class=\"p-bussinessContent__imageArea\">\n                    <picture class=\"p-bussinessContent__image\">\n                      <source srcset=\"/inc/image/top/pic_industrialBusinss-01.jpg.webp 1x, /inc/image/top/pic_industrialBusinss-01@2x.jpg.webp 2x\" type=\"image/webp\">\n                      <img src=\"/inc/image/top/pic_industrialBusinss-01.jpg\" alt=\"産機の写真\">\n                    </picture>\n                    <picture class=\"p-bussinessContent__image\">\n                      <source srcset=\"/inc/image/top/pic_industrialBusinss-02.jpg.webp 1x, /inc/image/top/pic_industrialBusinss-02@2x.jpg.webp 2x\" type=\"image/webp\">\n                      <img src=\"/inc/image/top/pic_industrialBusinss-02.jpg\" alt=\"\">\n                    </picture>\n                  </div>\n                </div>\n              </a>\n              <a href=\"/business/environmental-business/about/\" class=\"p-bussinessContent__link\">\n                <div class=\"p-bussinessContent__Grid\">\n                  <div class=\"p-bussinessContent__infoArea\">\n                    <h3 class=\"p-bussinessContent__title\">環境事業</h3>\n                    <p class=\"p-bussinessContent__text\">上水道設備 / 下水道設備 / 排水設備 / 灌漑用水設備 / ゲート設備 / 電気計装設備 / メンテナンス</p>\n                    <span class=\"c-roundArrowBtn\">環境事業を詳しく見る</span>\n                  </div>\n                  <div class=\"p-bussinessContent__imageArea\">\n                    <picture class=\"p-bussinessContent__image\">\n                      <source srcset=\"/inc/image/top/pic_environmentalBusiness-01.jpg.webp 1x, /inc/image/top/pic_environmentalBusiness-01@2x.jpg.webp 2x\" type=\"image/webp\">\n                      <img src=\"/inc/image/top/pic_environmentalBusiness-01.jpg\" alt=\"環境設備の写真\">\n                    </picture>\n                    <picture class=\"p-bussinessContent__image\">\n                      <source srcset=\"/inc/image/top/pic_environmentalBusiness-02.jpg.webp 1x, /inc/image/top/pic_environmentalBusiness-02@2x.jpg.webp 2x\" type=\"image/webp\">\n                      <img src=\"/inc/image/top/pic_environmentalBusiness-02.jpg\" alt=\"\">\n                    </picture>\n                  </div>\n                </div>\n              </a>\n            </div>\n          </section>\n        </div>\n        <section class=\"l-section l-section--full p-office\">\n          <div class=\"p-office__wrapper\">\n            <div class=\"p-office__inner\">\n              <picture class=\"p-office__map\">\n                <source srcset=\"/inc/image/top/img_office-map.jpg.webp 1x, /inc/image/top/img_office-map@2x.jpg.webp 2x\" type=\"image/webp\">\n                <img src=\"/inc/image/top/img_office-map.jpg\" alt=\"\">\n              </picture>\n              <div class=\"p-office__textArea\">\n                <h2 class=\"c-ttl-main c-ttl-main--mbShort\">\n                  <span class=\"c-ttl-main__sub\">OFFICE</span> 事業所案内\n                </h2>\n                <p class=\"p-office__text\">山口県に本社を構えながらも幅広いネットワークで全国へ展開しています。</p>\n                <a href=\"/office/\" class=\"c-btn p-office__btn\">詳しく見る</a>\n              </div>\n            </div>\n          </div>\n        </section>\n        <div class=\"p-company__wrapper\">\n          <section class=\"l-section p-company\">\n            <h2 class=\"c-ttl-main c-ttl--center\">\n              <span class=\"c-ttl-main__sub\">COMPANY</span> 会社情報\n            </h2>\n            <ul class=\"p-companyCard\">\n              <li class=\"p-companyCard__item\">\n                <a href=\"/company/message/\" class=\"c-card\">\n                  <picture class=\"c-card__img\">\n                    <source srcset=\"/inc/image/top/pic_card-greetings.jpg.webp 1x, /inc/image/top/pic_card-greetings@2x.jpg.webp 2x\" type=\"image/webp\">\n                    <img src=\"/inc/image/top/pic_card-greetings.jpg\" alt=\"代表挨拶\">\n                  </picture>\n                  <div class=\"c-card__info\">\n                    <h3 class=\"c-card__title\"><span class=\"c-card__title--eng\">GREETINGS</span>代表挨拶</h3>\n                  </div>\n                </a>\n              </li>\n              <li class=\"p-companyCard__item\">\n                <a href=\"/company/vision/\" class=\"c-card\">\n                  <picture class=\"c-card__img\">\n                    <source srcset=\"/inc/image/top/pic_card-vision.jpg.webp 1x, /inc/image/top/pic_card-vision@2x.jpg.webp 2x\" type=\"image/webp\">\n                    <img src=\"/inc/image/top/pic_card-vision.jpg\" alt=\"企業理念\">\n                  </picture>\n                  <div class=\"c-card__info\">\n                    <h3 class=\"c-card__title\"><span class=\"c-card__title--eng\">PHILOSOPHY</span>企業理念</h3>\n                  </div>\n                </a>\n              </li>\n              <li class=\"p-companyCard__item\">\n                <a href=\"/company/overview/\" class=\"c-card\">\n                  <picture class=\"c-card__img\">\n                    <source srcset=\"/inc/image/top/pic_card-profile.jpg.webp 1x, /inc/image/top/pic_card-profile@2x.jpg.webp 2x\" type=\"image/webp\">\n                    <img src=\"/inc/image/top/pic_card-profile.jpg\" alt=\"会社概要\">\n                  </picture>\n                  <div class=\"c-card__info\">\n                    <h3 class=\"c-card__title\"><span class=\"c-card__title--eng\">OVERVIEW</span>会社概要</h3>\n                  </div>\n                </a>\n              </li>\n              <li class=\"p-companyCard__item\">\n                <a href=\"/company/history/\" class=\"c-card\">\n                  <picture class=\"c-card__img\">\n                    <source srcset=\"/inc/image/top/pic_card-history.jpg.webp 1x, /inc/image/top/pic_card-history@2x.jpg.webp 2x\" type=\"image/webp\">\n                    <img src=\"/inc/image/top/pic_card-history.jpg\" alt=\"沿革\">\n                  </picture>\n                  <div class=\"c-card__info\">\n                    <h3 class=\"c-card__title\"><span class=\"c-card__title--eng\">HISTORY</span>沿革</h3>\n                  </div>\n                </a>\n              </li>\n            </ul>\n          </section>\n        </div>\n        <section class=\"p-recruit\">\n          <div class=\"p-recruit__decorationTracker\">\n            <ul class=\"p-recruit__decorationText\">\n              <li>YAMASAN Co.,LTD.</li>\n              <li>YAMASAN Co.,LTD.</li>\n              <li>YAMASAN Co.,LTD.</li>\n            </ul>\n            <ul class=\"p-recruit__decorationText\">\n              <li>YAMASAN Co.,LTD.</li>\n              <li>YAMASAN Co.,LTD.</li>\n              <li>YAMASAN Co.,LTD.</li>\n            </ul>\n          </div>\n          <div class=\"p-recruit__container-wrapper\">\n            <div class=\"p-recruit__container\">\n              <div class=\"p-recruit__inner\">\n                <div class=\"p-recruit__body\">\n                  <div class=\"p-recruitImg\">\n                    <picture>\n                      <source srcset=\"/inc/image/top/pic_recruit.png.webp 1x, /inc/image/top/pic_recruit@2x.png.webp 2x\" type=\"image/webp\">\n                      <img src=\"/inc/image/top/pic_recruit.png\" alt=\"\">\n                    </picture>\n                    <img src=\"/inc/image/top/img_recruit-message.svg\" alt=\"グレートを創り出せ\" class=\"p-recruitImg__copy\">\n                  </div>\n                  <div class=\"p-recruitText\">\n                    <div class=\"p-recruitText__inner\">\n                      <h2 class=\"c-ttl-main p-recruit__title\">\n                        <span class=\"c-ttl-main__sub\">RECRUIT</span> 採用情報\n                      </h2>\n                      <p class=\"p-recruitText__desc\">あなたにとってのグレートは何ですか？山産という会社は一人一人の個性を活かしながら実直に成長してきた会社です。世の中に興味を持つセンスに刺激するアイデア、丸くならない勇気にリードするパワー。より良い山産を創っていくにはどうしたら良いか、自分で考え行動し、可能性を見出し果敢にチャレンジしていける、新たな仲間を探しています。</p>\n                      <a href=\"/recruit/\" target=\"_blank\" rel=\"noopener\" class=\"c-roundArrowBtn c-roundArrowBtn--reverse\">採用情報を詳しく見る</a>\n                    </div>\n                  </div>\n                </div>\n              </div>\n            </div>\n          </div>\n        </section>\n      </div>\n    </main>\n    <!-- end of #main -->\n    <footer class=\"l-f\">\n      <div class=\"c-cvArea\">\n        <div class=\"c-cvTextArea\">\n          <h2 class=\"c-cvTextArea__title\"><span class=\"c-cvTextArea__subTitle\">CONTACT</span>お問い合わせ</h2>\n          <p class=\"c-cvTextArea__text\">製品に関するお問い合わせをはじめ、その他各種のお問い合わせをお受けしています。<br>\n            <span class=\"c-cvTextArea__text--pc\">どんな疑問もお気軽にご相談ください。</span>\n          </p>\n        </div>\n        <div class=\"c-cvBtnArea\">\n          <a href