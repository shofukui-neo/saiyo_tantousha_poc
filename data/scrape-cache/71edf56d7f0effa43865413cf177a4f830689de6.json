INQ/g==\" crossorigin=\"anonymous\"referrerpolicy=\"no-referrer\"></script>\n\t\t<script type=\"text/javascript\" src=\"../js/common.js\"></script>\n</head>\n\n<body>\n\t<section class=\"header\">\n\t\t<!--inc header-->\n\t\t<div class=\"head_nav\">\r\n\t<h1><a href=\"/honshitoso/index.html\"><img src=\"/honshitoso/img/logo.svg\" alt=\"\"/><span class=\"log_txt\"><span class=\"nav_jr\">ＪＲ四国グループ</span><br>本四塗装工業株式会社</span></a></h1>\r\n\r\n<!-- ボタン部分-->\r\n<div class=\"nav_btn\" id=\"nav_btn\">\r\n<span class=\"hamburger_line hamburger_line1\"></span>\r\n<span class=\"hamburger_line hamburger_line2\"></span>\r\n<span class=\"hamburger_line hamburger_line3\"></span>\r\n</div>\r\n<div class=\"nav_bg\" id=\"nav_bg\"></div>\r\n\r\n<nav>\r\n<ul id=\"navi\">\r\n<li><a href=\"/honshitoso/company.html\">会社情報</a></li>\r\n<li><a href=\"/honshitoso/business.html\">事業内容</a></li>\r\n<li><a href=\"/honshitoso/recruit/index.html\">採用情報</a></li>\r\n</ul>\r\n</nav>\r\n</div><!--head_nav-->\r\n\r\n\n\t\t<!--inc header end-->\n\t</section><!--header-->\n\n\t<div class=\"wrapper\">\n\t\t<div class=\"breadcrumbs\">\n\t\t\t<ol class=\"breadcrumb_list\" itemscope itemtype=\"https://schema.org/BreadcrumbList\">\n\t\t\t\t<li itemprop=\"itemListElement\" itemscope\n\t\t\t\t\titemtype=\"https://schema.org/ListItem\">\n\t\t\t\t\t<a itemprop=\"item\" href=\"/honshitoso/index.html\">\n\t\t\t\t\t\t<span itemprop=\"name\">ホーム</span>\n\t\t\t\t\t</a>\n\t\t\t\t\t<meta itemprop=\"position\" content=\"1\" />\n\t\t\t\t</li>\n\t\t\t\t<li itemprop=\"itemListElement\" itemscope\n\t\t\t\t\titemtype=\"https://schema.org/ListItem\">\n\t\t\t\t\t<a itemprop=\"item\" href=\"/honshitoso/recruit/index.html\">\n\t\t\t\t\t\t<span itemprop=\"name\">採用情報</span>\n\t\t\t\t\t</a>    \n\t\t\t\t\t<meta itemprop=\"position\" content=\"2\" />\n\t\t\t\t</li>\n\t\t\t\t<li itemprop=\"itemListElement\" itemscope\n\t\t\t\t\titemtype=\"https://schema.org/ListItem\">\n\t\t\t\t\t<a itemprop=\"item\" href=\"/honshitoso/recruit/staff.html\">\n\t\t\t\t\t\t<span itemprop=\"name\">社員インタビュー</span>\n\t\t\t\t\t</a>  \n\t\t\t\t\t<meta itemprop=\"position\" content=\"3\" />\n\t\t\t\t</li>\n\t\t\t</ol>\n\t\t</div><!--breadcrumbs-->\n\n\t\t<div class=\"box_area\">\n\t\t\t<h2>社員インタビュー</h2>\n\t\t\t<div class=\"staff_box\">\n\t\t\t\t<div class=\"staff_flex\">\n\t\t\t\t\t<p class=\"staff_img\"><img src=\"/honshitoso/img/recruit/staff01.jpg\" alt=\"社員01\"></p>\n\t\t\t\t\t<div class=\"staff_refer\">\n\t\t\t\t\t\t<p class=\"staff_name\">Ｔさん<br class=\"sp-only\"><span>（40代男性、中途入社3年目）</span></p>\n\t\t\t\t  <p class=\"staff_txt\"><span>前職について</span><br>建築系の現場で現場代理人をしていました。全国に出張する仕事でしたが、地元志向が高くなったこともあり転職を考えるようになりました。</p>\n\t\t\t\t  <p class=\"staff_txt\"><span>今の仕事について</span><br>今は、瀬戸大橋の橋梁の塗り替え塗装に携わっています。前職とは現場が違いますが、何かしら現場経験があれば人との関わり方など、扱うものが異なっても活かせる点が多いと思います。とはいえ鉄道案件に関しては徐々に覚えている最中です。</p>\n\t\t\t\t  <p class=\"staff_txt\"><span>入社を考えている方に一言</span><br>先輩が手取り足取り教えてくれる環境です。意欲があれば勤まらない仕事ではありません。周りもサポートしてくれるので、是非チャレンジしてみてください！</p>\n\t\t\t  </div>\n\t\t\t\t</div><!--staff_flex-->\n\t\t\t</div><!--staff_box-->\n\n\t\t\t<div class=\"staff_box\">\n\t\t\t\t<div class=\"staff_flex flex02\">\n\t\t\t\t\t<div class=\"staff_refer\">\n\t\t\t\t\t\t<p class=\"staff_name\">Ａさん<br class=\"sp-only\"><span>（20代女性、中途入社2年目）</span></p>\n\t\t\t\t  <p class=\"staff_txt\"><span>入社理由</span><br>転勤なしで働ける仕事を探していたのですが、橋に携わるスケール感に魅力を感じ、気が付けばこの会社の一員になっていました。前職でも土木に携わっていたものの、塗装については未経験でした。先輩方からイチから教えてもらえたことが嬉しかったです。</p>\n\t\t\t\t  <p class=\"staff_txt\"><span>仕事について</span><br>事務作業や調整業務など、難しい一面もありますが、だからこそ自分が手掛けた案件が無事終わったときは、達成感があります。面白い仕事ですよ。</p>\n\t\t\t\t  <p class=\"staff_txt\"><span>会社について</span><br>私は女性ですが、当社は性別問わず働ける環境が整っているので、安心してください。資格取得に係わる受験費補助や奨励金制度があり、スキルアップの向上心に繋がります。</p>\n\t\t\t  </div>\n\t\t\t\t\t<p class=\"staff_img\"><img src=\"/honshitoso/img/recruit/staff02.jpg\" alt=\"社員02\"></p>\n\t\t\t\t</div><!--staff_flex-->\n\n\t\t\t</div><!--staff_box-->\n\n\t\t</div><!--box_area-->\n\t</div><!--wrapper-->\n\n\t<div class=\"member_day\">\n\t\t<div class=\"member_daytime\">\n\t\t\t<div id=\"conference-timeline\">\n\t\t\t\t<div class=\"timeline-start\">とある1日のスケジュール</div>\n\t\t\t\t<div class=\"conference-center-line\"></div>\n\t\t\t\t<div class=\"conference-timeline-content\">\n\n\t\t\t\t\t<!-- Article -->\n\t\t\t\t\t<div class=\"timeline-article\">\n\n\t\t\t\t\t\t<div class=\"content-left-container\">\n\t\t\t\t\t\t\t<div class=\"content-left\">\n\t\t\t\t\t\t\t\t<p><span class=\"article-number\">08:00</span>検査の時間に合わせて少し早めの出勤。</p>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t\t<!--\n\t\t\t\t\t\t  <div class=\"content-right-container\">\n\t\t\t\t\t\t\t  <div class=\"content-right\">\n\t\t\t\t\t\t\t\t  <p>When I orbited the Earth in a spaceship, I saw for the first time how beautiful our planet is. <span class=\"article-number\">02</span></p>\n\t\t\t\t\t\t\t  </div>\n\t\t\t\t\t\t\t  <span class=\"timeline-author\">John Doe</span>\n\t\t\t\t\t\t  </div>\n-->\n\t\t\t\t\t\t<div class=\"meta-date\">\n\t\t\t\t\t\t\t<span class=\"date\">出社</span>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t\t<!-- // Article -->\n\n\t\t\t\t\t<!-- Article -->\n\t\t\t\t\t<div class=\"timeline-article\">\n\t\t\t\t\t\t<div class=\"content-right-container\">\n\t\t\t\t\t\t\t<div class=\"content-right\">\n\t\t\t\t\t\t\t\t<p><span class=\"article-number\">09:00</span>瀬戸大橋にて検査<br>施工範囲内で塗残しがないか入念にチェックします。\n\t\t\t\t\t\t\t\t\t<span class=\"timeline-author\"><img src=\"/honshitoso/img/recruit/daytime01.jpg\" alt=\"\"></span></p>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t\t<div class=\"meta-date\">\n\t\t\t\t\t\t\t<span class=\"date\">検査</span>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t\t<!-- // Article -->\n\n\t\t\t\t\t<!-- Article -->\n\t\t\t\t\t<div class=\"timeline-article\">\n\t\t\t\t\t\t<div class=\"content-left-container\">\n\t\t\t\t\t\t\t<div class=\"content-left\">\n\t\t\t\t\t\t\t\t<p><span class=\"article-number\">11:30</span>協力業者と進捗状況や今後の施工について確認をします。</p>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t\t<div class=\"meta-date\">\n\t\t\t\t\t\t\t<span class=\"date\">打合わせ</span>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t\t<!-- // Article -->\n\t\t\t\t\t<!-- Article -->\n\t\t\t\t\t<div class=\"timeline-article\">\n\t\t\t\t\t\t<div class=\"content-right-container\">\n\t\t\t\t\t\t\t<div class=\"content-right\">\n\t\t\t\t\t\t\t\t<p><span class=\"article-number\">12:00</span>検査終了、うどん屋さんに寄り道&#9834;</p>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t\t<div class=\"meta-date\">\n\t\t\t\t\t\t\t<span class=\"date\">昼<br>休憩</span>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t\t<!-- // Article -->\n\t\t\t\t\t<!-- Article -->\n\t\t\t\t\t<div class=\"timeline-article\">\n\t\t\t\t\t\t<div class=\"content-left-container\">\n\t\t\t\t\t\t\t<div class=\"content-left\">\n\t\t\t\t\t\t\t\t<p><span class=\"article-number\">14:00</span>事務所帰社後、工事書類の作成をします。<span class=\"timeline-author\"><img src=\"/honshitoso/img/recruit/daytime02.jpg\" alt=\"\"></span></p>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</div>\n\n\t\t\t\t\t\t<div class=\"meta-date\">\n\t\t\t\t\t\t\t<span class=\"date\">事務作業</span>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t\t<!-- // Article -->\n\t\t\t\t\t<!-- Article -->\n\t\t\t\t\t<div class=\"timeline-article\">\n\t\t\t\t\t\t<div class=\"content-right-container\">\n\t\t\t\t\t\t\t<div class=\"content-right\">\n\t\t\t\t\t\t\t\t<p><span class=\"article-number\">16:00</span>発注者と次週の工事内容について打ち合わせをします。</p>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t\t<div class=\"meta-date\">\n\t\t\t\t\t\t\t<span class=\"date\">打合わせ</span>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t\t<!-- // Article -->\n\t\t\t\t</div>\n\t\t\t\t<div class=\"timeline-end\">17:30　退社、お疲れ様でした！</div>\n\t\t\t</div><!--conference-timeline-->\n\t\t</div><!--member_daytime-->\n\t</div><!--member_day-->\n\n\t<div class=\"wrapper\">\n\t\t<button id=\"pagetop\" class=\"page-top\"><span class=\"page-top_icon\"></span></button>\n\t\t<!--inc footer-->\n\t\t<div class=\"footer\">\r\n\t<p class=\"policy\"><a h