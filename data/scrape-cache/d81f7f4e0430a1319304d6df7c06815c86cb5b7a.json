-hor.webp\" type=\"image/webp\" />\n\t\t\t\t\t\t<img src=\"/assets/img/message/bg3-hor.jpg\" />\n\t\t\t\t\t</picture>\n\t\t\t\t\t<picture class=\"show--vrt\">\n\t\t\t\t\t\t<source srcset=\"/assets/img/message/bg3-vrt.webp\" type=\"image/webp\" />\n\t\t\t\t\t\t<img src=\"/assets/img/message/bg3-vrt.jpg\" />\n\t\t\t\t\t</picture>\n\t\t\t\t</div>\n\t\t\t\t<div class=\"message__bg__ph ph-4\" data-bg=\"4\">\n\t\t\t\t\t<picture class=\"show--hor\">\n\t\t\t\t\t\t<source srcset=\"/assets/img/message/bg4-hor.webp\" type=\"image/webp\" />\n\t\t\t\t\t\t<img src=\"/assets/img/message/bg4-hor.jpg\" />\n\t\t\t\t\t</picture>\n\t\t\t\t\t<picture class=\"show--vrt\">\n\t\t\t\t\t\t<source srcset=\"/assets/img/message/bg4-vrt.webp\" type=\"image/webp\" />\n\t\t\t\t\t\t<img src=\"/assets/img/message/bg4-vrt.jpg\" />\n\t\t\t\t\t</picture>\n\t\t\t\t</div>\n\t\t\t\t<div class=\"message__bg__ph ph-5\" data-bg=\"5\">\n\t\t\t\t\t<picture class=\"show--hor\">\n\t\t\t\t\t\t<source srcset=\"/assets/img/message/bg5-hor.webp\" type=\"image/webp\" />\n\t\t\t\t\t\t<img src=\"/assets/img/message/bg5-hor.jpg\" />\n\t\t\t\t\t</picture>\n\t\t\t\t\t<picture class=\"show--vrt\">\n\t\t\t\t\t\t<source srcset=\"/assets/img/message/bg5-vrt.webp\" type=\"image/webp\" />\n\t\t\t\t\t\t<img src=\"/assets/img/message/bg5-vrt.jpg\" />\n\t\t\t\t\t</picture>\n\t\t\t\t</div>\n\t\t\t</div>\n\n\t\t\t<section class=\"container--sec adj--mt0\">\n\t\t\t\t<div class=\"message__sec\" data-key=\"1\">\n\t\t\t\t\t<div class=\"message__para-wrap\">\n\t\t\t\t\t\t<p class=\"message__para\">\n\t\t\t\t\t\t\t<i>困っている人がいたら、すぐに駆けつけてくれる。</i><br>\n\t\t\t\t\t\t\t<i>悩んでいる人がいたら、そっと寄り添ってくれる。</i>\n\t\t\t\t\t\t</p>\n\t\t\t\t\t\t<p class=\"message__para\">\n\t\t\t\t\t\t\t<i>そんな笑顔の優しい人がいてくれたら、どんなに心強いでしょう。</i><br>\n\t\t\t\t\t\t\t<i>もし、あなたがそう思うのなら、</i><br>\n\t\t\t\t\t\t\t<i>あなた自身がそんな存在になってみませんか？</i>\n\t\t\t\t\t\t</p>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\n\t\t\t\t<div class=\"message__sec\" data-key=\"2\">\n\t\t\t\t\t<div class=\"message__para-wrap\">\n\t\t\t\t\t\t<p class=\"message__para\">\n\t\t\t\t\t\t\t<i>あなたと同じように、だれかの役に立ちたいと思っている仲間と、</i><br>\n\t\t\t\t\t\t\t<i>力を出し合い、みんなの暮らしを守っていく。</i><br>\n\t\t\t\t\t\t\t<i>私たちTOKAIグループはそんな仕事をしています。</i>\n\t\t\t\t\t\t</p>\n\t\t\t\t\t\t<p class=\"message__para\">\n\t\t\t\t\t\t\t<i>ガス、ITシステム、クラウド、水、ケーブルテレビ、建築……。</i><br>\n\t\t\t\t\t\t\t<i>私たちが提供するものは、どれも一人の力でお届けすることはできません。</i><br>\n\t\t\t\t\t\t\t<i>一緒にはたらく仲間たちの個性とチームワークと笑顔で、</i><br>\n\t\t\t\t\t\t\t<i>社会と人々の安心・安全・快適を守っています。</i>\n\t\t\t\t\t\t</p>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\n\t\t\t\t<div class=\"message__sec\" data-key=\"3\">\n\t\t\t\t\t<div class=\"message__para-wrap\">\n\t\t\t\t\t\t<p class=\"message__para\">\n\t\t\t\t\t\t\t<i>誰かの住まいでなにか困りごとがあれば、私たちは迷わずに出かけていきます。</i><br>\n\t\t\t\t\t\t\t<i>バスや電車に揺られて、ときには軽トラックを運転して……。</i><br>\n\t\t\t\t\t\t\t<i>取引先から、「こんなシステムはできないか？」と</i><br>\n\t\t\t\t\t\t\t<i>聞かれたら諦めずに知恵を絞ります。</i><br>\n\t\t\t\t\t\t\t<i>自分たちに何が出来るのか、あれこれ意見を出し合いながら……。</i>\n\t\t\t\t\t\t</p>\n\t\t\t\t\t\t<p class=\"message__para\">\n\t\t\t\t\t\t\t<i>私たちが社会のために一生懸命に仕事をすることができるのは、</i><br>\n\t\t\t\t\t\t\t<i>TOKAIグループそのものが、社会の一員だから。</i><br>\n\t\t\t\t\t\t\t<i>華やかでなくても、オシャレでなくても、</i><br>\n\t\t\t\t\t\t\t<i>「ありがとう」という感謝の言葉と、心からの笑顔をしっかり受け取ることで、</i><br>\n\t\t\t\t\t\t\t<i>私たちも確かな仕事に笑顔というエネルギーを添えてお届けすることができるのです。</i>\n\t\t\t\t\t\t</p>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\n\t\t\t\t<div class=\"message__sec\" data-key=\"4\">\n\t\t\t\t\t<div class=\"message__para-wrap\">\n\t\t\t\t\t\t<p class=\"message__para\">\n\t\t\t\t\t\t\t<i>いま私たちは、目の前にある困りごとだけではなく、</i><br>\n\t\t\t\t\t\t\t<i>これから起こるかもしれない災害に向けて準備を整え、</i><br>\n\t\t\t\t\t\t\t<i>子どもたちの未来のために学びを支え、</i><br>\n\t\t\t\t\t\t\t<i>社会のための貢献にも取り組みはじめています。</i>\n\t\t\t\t\t\t</p>\n\t\t\t\t\t\t<p class=\"message__para\">\n\t\t\t\t\t\t\t<i>仕事をすることで私たちは社会に笑顔というエネルギーを注ぎ、</i><br>\n\t\t\t\t\t\t\t<i>そこにいる人々の感謝の言葉や笑顔を新たなエネルギーとして受け取ります。</i><br>\n\t\t\t\t\t\t\t<i>そんなエネルギーの循環の中心にいることが、</i><br>\n\t\t\t\t\t\t\t<i>私たちTOKAIグループの誇りであり、使命なのです。</i>\n\t\t\t\t\t\t</p>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\n\t\t\t\t<div class=\"message__sec\" data-key=\"5\">\n\t\t\t\t\t<div class=\"message__para-wrap\">\n\t\t\t\t\t\t<p class=\"message__para\">\n\t\t\t\t\t\t\t<i>人を助ける仕事なんだ！とかまえる必要はありません。</i><br>\n\t\t\t\t\t\t\t<i>誰かの笑顔に救われた経験がある人なら、</i><br>\n\t\t\t\t\t\t\t<i>今度は、あなたが誰かを元気にする、笑顔のエネルギーを提供すればいいのです。</i>\n\t\t\t\t\t\t</p>\n\t\t\t\t\t\t<p class=\"message__para\">\n\t\t\t\t\t\t\t<i>さあ、みんなで力を合わせて仕事をしながら、</i><br>\n\t\t\t\t\t\t\t<i>まずは、あなた自身に笑顔のエネルギーをチャージしましょう。</i><br>\n\t\t\t\t\t\t\t<i>そして、たっぷりエネルギーが貯まったところで、</i><br>\n\t\t\t\t\t\t\t<i>社会のために、たくさんの人たちのために、</i><br>\n\t\t\t\t\t\t\t<i>笑顔のエネルギーを届けましょう！</i>\n\t\t\t\t\t\t</p>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</section>\n\n\t\t\t<section class=\"message__copy\">\n\t\t\t\t<div class=\"message__copy__inner\">\n\t\t\t\t\t<div class=\"message__copy__ph\">\n\t\t\t\t\t\t<img src=\"/assets/img/message/ph-last.jpg?3\" alt=\"\">\n\t\t\t\t\t\t<div class=\"message__copy__ph__copy\"><img src=\"/assets/img/message/ph-last_copy.png\" alt=\"ぼくらの笑顔が、みんなのエネルギー！\"></div>\n\t\t\t\t\t</div>\n\t\t\t\t\t<div class=\"container--view\">\n\t\t\t\t\t\t<div class=\"message__back\">\n\t\t\t\t\t\t\t<a href=\"/\" class=\"btn-rect--primary-1 back\"><i class=\"arrow-link\"></i>TOPへ戻る</a>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</section>\n\t\t</div>\n\n\t</main>\n\n\t<!-- フッター -->\n\t<footer class=\"pagefooter\">\n\t\t<div class=\"pagefooter__upper\">\n\t\t\t<a href=\"/\" class=\"pagefooter__logo\">\n\t\t\t\t<img src=\"/assets/img/common/logo_tokai.svg\" alt=\"TOKAI GROUP\">\n\t\t\t</a>\n\t\t\t<div class=\"pagefooter__catch\">\n\t\t\t\t<img src=\"/assets/img/common/catch_footer.svg\" alt=\"ぼくらの笑顔が、みんなのエネルギー！\">\n\t\t\t</div>\n\t\t\t<div class=\"pagefooter__story\">\n\t\t\t\t<a href=\"/message/\">採用メッセージストーリー<i class=\"arrow-link\"></i></a>\n\t\t\t</div>\n\t\t\t<div class=\"pagefooter__bnr show--pc\">\n\t\t\t\t<a href=\"https://www.tokaiholdings.co.jp/stories/?utm_source=tokairecruit&utm_medium=banner&utm_campaign=stories\" target=\"_blank\">\n\t\t\t\t\t<