g' />\n<link rel=\"alternate\" type=\"application/rss+xml\" title=\"長野県交通警備株式会社 &raquo; 求人情報 フィード\" href=\"https://www.nk-keibi.co.jp/recruit/feed/\" />\n<link rel='https://api.w.org/' href='https://www.nk-keibi.co.jp/wp-json/' />\n<link rel=\"EditURI\" type=\"application/rsd+xml\" title=\"RSD\" href=\"https://www.nk-keibi.co.jp/xmlrpc.php?rsd\" />\n<link rel=\"wlwmanifest\" type=\"application/wlwmanifest+xml\" href=\"https://www.nk-keibi.co.jp/wp-includes/wlwmanifest.xml\" /> \n</head>\r\n<body id=\"recruit\" class=\"recruit page\">\r\n<h1 id=\"h1-text\">求人情報 &#8211; 長野県交通警備株式会社 | 交通誘導警備、施設常駐警備、巡回警備、高速道路警備、駐車場警備、イベント警備---私たちは各種警備により皆様の安心をサポートします。</h1>\r\n\r\n<div id=\"loader-bg\">\r\n  <div id=\"loader\">\r\n    <img src=\"https://www.nk-keibi.co.jp/wp-content/themes/nk_theme/assets/img/loader.gif\" width=\"128\" height=\"128\" alt=\"Now Loading...\" />\r\n    <p>Now Loading...</p>\r\n  </div>\r\n</div>\r\n\r\n<!-- { HEADER START } -->\r\n<header id=\"header\">\r\n  <div class=\"header-body\">\r\n    <figure id=\"site-id\">\r\n      <a href=\"/\">\r\n        <img src=\"https://www.nk-keibi.co.jp/wp-content/themes/nk_theme/assets/img/site_id.png\"\r\n           srcset=\"https://www.nk-keibi.co.jp/wp-content/themes/nk_theme/assets/img/site_id.png 1x,\r\n                  https://www.nk-keibi.co.jp/wp-content/themes/nk_theme/assets/img/site_id@2x.png 2x\"\r\n           alt=\"長野県交通警備株式会社 ホームページ\">\r\n      </a>\r\n    </figure>\r\n    <div id=\"sp-nav\">\r\n      <i></i>\r\n    </div>\r\n    <nav id=\"nav\">\r\n      <ul>\r\n        <li><a href=\"/outline/\">会社案内</a></li>\r\n        <li><a href=\"/office/\">営業所案内</a></li>\r\n        <li><a href=\"/business/\">業務案内</a></li>\r\n        <li><a href=\"/recruit/\">求人情報</a></li>\r\n      </ul>\r\n      <div class=\"nav-inquiry\">\r\n        <a href=\"/inquiry/\">お問い合わせ</a>\r\n        <a href=\"/ask\" class=\"op-ask\">警備業務のご依頼</a>\r\n      </div>\r\n    </nav>\r\n  </div>\r\n</header>\r\n<!-- { ./ HEADER START } -->\r\n\n<!-- { CATEGORY TITLE START } -->\n<section id=\"category-header\" class=\"outer category-header-recruit\">\n  <div class=\"wrap\">\n    <div class=\"category-title\">\n      <h2>求人情報</h2>\n      <p class=\"en\">JOB INFORMATION</p>\n    </div>\n    <div class=\"bread-crumbs\">\n      <a href=\"/\">TOP</a> / 求人情報    </div>\n  </div>\n</section>\n<!-- { ./ CATEGORY TITLE START } -->\n\n<!-- { MAIN START } -->\n<main id=\"main\">\n\n  <!-- 求人一覧 -->\n  <section id=\"recruit-archive-list\">\n    <div class=\"wrap\">\n      <div id=\"page-links\" class=\"page-links\"></div>\n      <h2 id=\"recruit-now\" class=\"title-h2\" data-en=\"MESSAGE\">現在募集中の求人<span>Recrutement</span></h2>\n      <section class=\"entry-segment\">\n        <p style=\"margin-bottom: 2em; font-size: 1.4em;\"><a style=\"text-decoration: underline;\" href=\"https://mil-to.com/nk-keibi\" target=\"_blank\">詳しい求人情報はこちら（別サイトへ）</a></p>\n        <img src=\"https://www.nk-keibi.co.jp/wp-content/themes/nk_theme/assets/img/recruit_thumbs.jpg\" alt=\"業務のイメージ\" style=\"margin-bottom: 2em;\">\n      </section>\n    </div>\n  </section>\n  <!-- 求人一覧 -->\n\n  <!-- 求人付帯情報 -->\n  <section id=\"recruit-archive-aside\" class=\"entry-post outer\">\n    <div class=\"wrap\">\n      <h2 id=\"entry-segment-id-1\" class=\"title-h2\">福利厚生<span>Employee Benefits</span></h2><h3 id=\"entry-segment-id-2\" class=\"title-h3\">社会保険・社内制度等</h3>\r\n<section id=\"entry-segment-id-3\" class=\"entry-segment entry-segment-list\">\r\n<div class=\"entry-body\">\r\n\r\n<ul class=\"list-ul2\"><li>健康保険、厚生年金保険、雇用保険等</li><li>入社お祝い金30,000円支給</li><li>入社時書類取得費用会社負担</li><li>退職金制度あり</li><li>資格取得支援制度あり</li><li>社内貸付制度あり</li><li>制服貸与</li><li>交通費支給</li></ul>\r\n</div>\r\n</section>\r\n<h3 id=\"entry-segment-id-4\" class=\"title-h3\">保養・レジャー</h3><h4 id=\"entry-segment-id-5\" class=\"title-h4\">会員制保養施設　「鹿教湯温泉　斎藤ホテル」</h4>\r\n<section id=\"entry-segment-id-6\" class=\"entry-segment entry-segment-text\">\r\n<div class=\"entry-body\">\r\n<p class=\"entry-note\">1部屋で大人6名まで宿泊でき、一年を通して利用することができます。</p>\r\n</div>\r\n</section>\r\n<h3 id=\"entry-segment-id-7\" class=\"title-h3\">社宅</h3><h4 id=\"entry-segment-id-8\" class=\"title-h4\">【 社員住宅　「南町ニュータウン」「パークタウン小諸」】</h4>\r\n<section id=\"entry-segment-id-9\" class=\"entry-segment entry-segment-text\">\r\n<div class=\"entry-body\">\r\n<p class=\"entry-note\">グループ企業が管理する「南町ニュータウン」と「パークタウン小諸」を社員特別価格で使用できます。</p>\r\n</div>\r\n</section>\r\n<h2 id=\"entry-segment-id-10\" class=\"title-h2\">教育制度<span>Education System</span></h2>\r\n<section id=\"entry-segment-id-11\" class=\"entry-segment entry-segment-text\">\r\n<div class=\"entry-body\">\r\n<p class=\"entry-note\">法定教育を行なうとともに、組織的かつ計画的に警備員個人に合せた指導と監督を行います。<br />\r\nまた、各種資格取得に関して社内独自の勉強会を開催し、スキルアップと合格率向上を目指します。</p>\r\n</div>\r\n</section>\r\n    </div>\n  </section>\n  <!-- ./ 求人付帯情報 -->\n</main>\n<!-- { ./ MAIN END } -->\n\n\n<!-- { FOOTER START } -->\n<div id=\"common-data-group\">\n  \n  <!-- { Sales Offiece } -->\n  <section id=\"sales-office\">\n    <div class=\"wrap\">\n      <div class=\"title\">\n        <h2>営業所一覧</h2>\n        <p class=\"en\">SALES OFFICE</p>\n      </div>\n\n      <ul class=\"sales-office-list\"><li><h3><a href=\"/office/#office-id-1\">東信支社</a></h3><ul><li class=\"telorfax\"><p class=\"office-name\">東信支社</p><span class=\"tel\">TEL</span>0267-31-6501<span class=\"fax\">FAX</span>0267-31-6509</li><li class=\"email\" data-email_user=\"toushin\" data-email_host=\"nk-keibi.co.jp\"></li></ul><ul></ul></li><li><h3><a href=\"/office/#office-id-2\">長野支社</a></h3><ul><li class=\"telorfax\"><p class=\"office-name\">長野支社</p><span class=\"tel\">TEL</span>026-251-1988<span class=\"fax\">FAX</span>026-251-1990</li><li class=\"email\" data-email_user=\"info\" data-email_host=\"nk-keibi.co.jp\"></li></ul><ul><li class=\"telorfax\"><p class=\"office-name\">管制センター</p><span class=\"tel\">TEL</span>026-251-1977<span class=\"fax\">FAX</span>026-251-1978</li></ul><ul></ul></li><li><h3><a href=\"/office/#office-id-3\">上田営業所</a></h3><ul><li class=\"telorfax\"><span class=\"tel\">TEL</span>0268-26-8585<span class=\"fax\">FAX</span>0268-26-8790</li><li class=\"email\" data-email_user=\"ueda\" data-email_host=\"nk-keibi.co.jp\"></li></ul><ul></ul></li><li><h3><a href=\"/office/#office-id-4\">松本営業所</a></h3><ul><li class=\"telorfax\"><span class=\"tel\">TEL</span>0263-48-5212<span class=\"fax\">FAX</span>0263-48-5213</li><li class=\"email\" data-email_user=\"matsumoto\" data-email_host=\"nk-keibi.co.jp\"></li></ul><ul></ul></li><li><h3><a href=\"/office/#office-id-5\">伊那営業所</a></h3><ul><li class=\"telorfax\"><span class=\"tel\">TEL</span>0265-73-7302<span class=\"fax\">FAX</span>0265-98-8303</li><li class=\"email\" data-email_user=\"ina\" data-email_host=\"nk-keibi.co.jp\"></li></ul><ul></ul></li><li><h3><a href=\"/office/#office-id-6\">高崎営業所</a></h3><ul><li class=\"telorfax\"><span class=\"tel\">TEL</span>090-9668-7737</li></ul><ul></ul></li></ul>    </div>\n  </section>\n  <!-- { ./ Sales Offiece } -->\n\n  <footer id=\"footer\">\n\n    <!-- { Inquiry & Recruit } -->\n    <section id=\"common-links\">\n      <div class=\"wrap\">\n        <div class=\"common-link common-link-ask\">\n          <p class=\"common-link-description\">\n            警備のご依頼・ご相談など、<br>\n            お申込みはこちら\n          </p>\n          <div class=\"common-link-btn-group\">\n            <a href=\"/ask\" class=\"common-link-btn\">警備業務のご依頼</a>\n            <p class=\"common-link-en\">ASK FOR PROTECTION</p>\n          </div>\n        </div>\n        <div class=\"common-link common-link-inquiry\">\n          <p class=\"common-link-description\">\n            警備のご依頼・ご相談など、<br>\n            お気軽にお問い合わせください。\n          </p>\n          <div class=\"common-link-btn-group\">\n            <a href=\"/inquiry/\" class=\"common-link-btn\">お問い合わせ</a>\n            <p class=\"common-link-en\">INQUIRY</p>\n          </div>\n        </div>\n        <div class=\"common-link common-link-recruit\">\n          <p class=\"common-link-description\">\n            警備スタッフ大募集！<br>\n            各営業所の求人情報についてのご案内\n          </p>\n          <div class=\"common-link-btn-group\">\n            <a href=\"/recruit/\" class=\"common-link-btn\">求人情報</a>\n            <p class=\"common-link-en\">JOB INFORMATION</p>\n          </div>\n        </div>\n      </div>\n    </section>\n    <!-- { ./ Inquiry & Recruit } -->\n    <div id=\"footer-text\"></div>\n    <section id=\"footer-sitemap\">\n      <div class=\"wrap\">\n        <figure class=\"footer-site-id\">\n          <img src=\"https://www.nk-keibi.co.jp/wp-content/themes/nk_theme/assets/img/ftr_logo.png\"\n               srcset=\"https://www.nk-keibi.co.jp/wp-content/themes/nk_theme/assets/img/ftr_logo.png 1x,\n                      https://www.nk-keibi.co.jp/wp-content/themes/nk_theme/assets/img/ftr_logo@2x.png 2x\"\n               alt=\"長野県交通警備株式会社\">\n        </figure>\n        <div class=\"footer-nav\">\n          <div class=\"footer-nav-list\">\n            <h3><a href=\"/outline/\">会社案内</a></h3>\n            <ul>\n              <li><a href=\"/outline/#entry-segment-id-1\">社長ご挨拶</a></li>\n              <li><a href=\"/outline/#entry-segment-id-7\">会社概要</a></li>\n              <li><a href=\"/outline/#entry-segment-id-9\">会社沿革</a></li>\n              <li><a href=\"/outline/#entry-segment-id-11\">組織図</a></li>\n              <li><a href=\"/policy/\">情報資産保護方針</a></li>\n            </ul>\n          </div>\n          <div class=\"footer-nav-list\">\n            <h3><a href=\"/office/\">営業所案内</a></h3>\n            <ul><li><a href=\"/office/#office-id-1\">東信支社</a></li><li><a href=\"/office/#office-id-2\">長野支社</a></li><li><a href=\"/office/#office-id-3\">上田営業所</a></li><li><a href=\"/office/#office-id-4\">松本営業所</a></li><li><a href=\"/office/#office-id-5\">伊那営業所</a></li><li><a href=\"/office/#office-id-6\">高崎営業所</a></li></ul>          </div>\n          <div class=\"footer-nav-list\">\n            <h3><a href=\"/business/\">業務案内</a></h3>\n            <ul>\n              <li><a href=\"/business/#entry-segment-id-2\">交通誘導警備</a></li>\n              <li><a href=\"/business/#entry-segment-id-5\">施設常駐/巡回警備</a></li>\n              <li><a href=\"/business/#entry-segment-id-7\">高速道路警備</a></li>\n              <li><a href=\"/business/#entry-segment-id-9\">新幹線警乗業務</a></li>\n              <li><a href=\"/business/#entry-segment-id-11\">駐車場/雑踏警備</a></li>\n              <li><a href=\"/business/#entry-segment-id-14\">列車見張警備</a></li>\n            </ul>\n          </div>\n          <div class=\"footer-nav-list\">\n            <h3><a href=\"/recruit/\">求人情報</a></h3>\n            <ul>\n              <!-- <li><a href=\"/recruit/#recruit-now\">各営業所求人情報</a></li> -->\n              <li><a href=\"https://mil-to.com/nk-keibi\" target=\"_blank\">各営業所求人情報(別サイトへ)</a></li>\n            </ul>\n          </div>\n        </div>\n      </div>\n    </section>\n    <div class=\"page-top\">\n      <a href=\"#\" id=\"page-top\">PAGE TOP</a>\n    </div>\n    <div class=\"copy\">\n      <div class=\"wrap\">\n        <small>&copy; 2018 Naganoken Koutsuukeibi Co.,Ltd.</small>\n      </div>\n    </div>\n  </footer>\n  <!-- { ./ FOOTER END } -->\n</div>\n\n<script src=\"https://www.nk-keibi.co.jp/wp-content/themes/nk_theme/assets/lib/jquery-3.3.1.min.js\"></script>\n<script src=\"https://www.nk-keibi.co.jp/wp-content/themes/nk_theme/assets/lib/jquery.bgswitcher.js\"></script>\n<script src=\"https://www.nk-keibi.co.jp/wp-content/themes/nk_theme/assets/js/script.js\"></script>\n<script src=\"https://www.nk-keibi.co.jp/wp-content/themes/nk_theme/assets/lib/lightbox.min.js\"></script>\n\n\n<script type='text/javascript' src='https://www.nk-keibi.co.jp/wp-includes/js/wp-embed.min.js'></script>\n</body>\n</html>\n","finalUrl":"https://www.nk-keibi.co.jp/recruit","rendered":false,"_cachedAt":"2026-06-22T21:01:09.156Z"}