{"url":"https://www.jfe-et.co.jp/recruit/facilities/","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n  <head>\n    <title>JETがつくるもの | JFE環境テクノロジー株式会社</title>\n    <meta charset=\"utf-8\">\n    <meta http-equiv=\"X-UA-Compatible\" content=\"IE=Edge\">\n    <meta name=\"format-detection\" content=\"telephone=no\">\n    <meta name=\"viewport\" content=\"width=device-width, user-scalable=1, initial-scale=1, viewport-fit=cover\">\n    <meta name=\"keywords\" content=\"this is meta keywords\">\n    <meta name=\"description\" content=\"JFE環境テクノロジー株式会社がつくる代表的な施設「クリーンセンター」「汚泥再生処理センター」をご紹介します。\">\n    <meta property=\"og:title\" content=\"JETがつくるもの│JFE環境テクノロジー株式会社\">\n    <meta property=\"og:type\" content=\"website\">\n    <meta property=\"og:description\" content=\"JFE環境テクノロジー株式会社がつくる代表的な施設「クリーンセンター」「汚泥再生処理センター」をご紹介します。\">\n    <meta property=\"og:url\" content=\"\">\n    <meta property=\"og:image\" content=\"https://jfe-et.co.jp/_assets/images/_etc/ogp.png\">\n    <meta property=\"fb:app_id\" content=\"XXXXXXXXXXXXXXXX\">\n    <meta name=\"twitter:card\" content=\"summary\">\n    <meta name=\"twitter:site\" content=\"@XXXXX\">\n    <meta name=\"twitter:creator\" content=\"@XXXXX\">\n    <meta name=\"twitter:image:src\" content=\"https://jfe-et.co.jp/_assets/images/_etc/ogp.png\">\n    <link rel=\"icon\" type=\"image/x-icon\" href=\"../../_assets/images/_etc/favicon.ico\">\n    <link rel=\"icon\" type=\"image/png\" href=\"../../_assets/images/_etc/favicon.png\">\n    <link rel=\"apple-touch-icon\" type=\"image/png\" href=\"../../_assets/images/_etc/custom-icon.png\">\n    <!-- Google Tag Manager -->\n    <script>\n      (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\n      new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\n      j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n      'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n      })(window,document,'script','dataLayer','GTM-WR7