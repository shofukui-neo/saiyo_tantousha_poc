duates/\" class=\"toc__link\">新卒採用</a>\n                  </li>\n              <li class=\"toc__item\">\n                      <a href=\"https://www.jono.co.jp/recruit/mid-career/\" class=\"toc__link\">中途採用</a>\n                  </li>\n              <li class=\"toc__item\">\n                      <a href=\"https://www.jono.co.jp/recruit/part-time/\" class=\"toc__link\">パート・アルバイト採用</a>\n                  </li>\n              <li class=\"toc__item\">\n                      <a href=\"https://www.jono.co.jp/recruit/company-visit/\" class=\"toc__link\">会社見学</a>\n                  </li>\n              <li class=\"toc__item\">\n                      <a href=\"https://www.jono.co.jp/recruit/message/\" class=\"toc__link\">社員メッセージ</a>\n                  </li>\n              <li class=\"toc__item\">\n                      <a href=\"https://www.jono.co.jp/recruit/employment-flow/\" class=\"toc__link\">採用の流れ</a>\n                  </li>\n              <li class=\"toc__item\">\n                      <span class=\"toc__current\">応募フォーム</span>\n                  </li>\n          </ul>\n  </nav>\n\n  <nav class=\"breadcrumbs\">\n<ol>\n<li><a href=\"https://www.jono.co.jp/\">トップページ</a></li>\n<li><a href=\"https://www.jono.co.jp/recruit/\">採用情報</a></li>\n<li><a href=\"https://www.jono.co.jp/recruit/entry/\">応募フォーム</a></li>\n</ol>\n<script type=\"application/ld+json\">{\"@context\":\"http://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"item\":{\"@id\":\"https://www.jono.co.jp/\",\"name\":\"トップページ\"}},{\"@type\":\"ListItem\",\"position\":2,\"item\":{\"@id\":\"https://www.jono.co.jp/recruit/\",\"name\":\"採用情報\"}},{\"@type\":\"ListItem\",\"position\":3,\"item\":{\"@id\":\"https://www.jono.co.jp/recruit/entry/\",\"name\":\"応募フォーム\"}}]}</script>\n</nav>\n<div class=\"site-content\">\n\t<main>\n\t\t<div class=\"post-93 page type-page status-publish\">\n    <section>\r\n  <h2>応募フォーム</h2>\r\n  <div class=\"form-block\">\r\n    <div class=\"form-lede\">\r\n      <p>求人にご応募いただく場合は弊社をより知っていただくために、まずは<a href=\"https://www.jono.co.jp/recruit/company-visit/\">会社見学</a>をご案内しています。 </p>\r\n      <p>こちらのフォームから、ご応募が可能です。 </p>\r\n      <p>必要事項を記入しご応募ください。お待ちしております。 </p>\r\n    </div>\r\n    \n<div class=\"wpcf7 no-js\" id=\"wpcf7-f92-p93-o1\" lang=\"ja\" dir=\"ltr\" data-wpcf7-id=\"92\">\n<div class=\"screen-reader-response\"><p role=\"status\" aria-live=\"polite\" aria-atomic=\"true\"></p> <ul></ul></div>\n<form action=\"/recruit/entry/#wpcf7-f92-p93-o1\" method=\"post\" class=\"wpcf7-form init h-adr\" aria-label=\"コンタクトフォーム\" enctype=\"multipart/form-data\" novalidate=\"novalidate\" data-status=\"init\">\n<fieldset class=\"hidden-fields-container\"><input type=\"hidden\" name=\"_wpcf7\" value=\"92\" /><input type=\"hidden\" name=\"_wpcf7_version\" value=\"6.1.2\" /><input type=\"hidden\" name=\"_wpcf7_locale\" value=\"ja\" /><input type=\"hidden\" name=\"_wpcf7_unit_tag\" value=\"wpcf7-f92-p93-o1\" /><input type=\"hidden\" name=\"_wpcf7_container_post\" value=\"93\" /><input type=\"hidden\" name=\"_wpcf7_posted_data_hash\" value=\"\" /><input type=\"hidden\" name=\"_wpcf7_recaptcha_response\" value=\"\" />\n</fieldset>\n<input type=\"hidden\" class=\"p-country-name\" value=\"Japan\">\n<div class=\"field\">\n  <label for=\"your-purpose\" class=\"field__label\">目的 <span class=\"required\">必須</span></label>\n  <div class=\"field__control\"><span class=\"wpcf7-form-control-wrap\" data-name=\"your-purpose\"><select class=\"wpcf7-form-control wpcf7-select wpcf7-validates-as-required\" id=\"your-purpose\" aria-required=\"true\" aria-invalid=\"false\" name=\"your-purpose\"><option value=\"\">&#8212;以下から選択してください&#8212;</option><option value=\"会社案内が欲しい\">会社案内が欲しい</option><option value=\"職場体験・インターン\">職場体験・インターン</option><option value=\"面接\">面接</option></select></span></div>\n</div>\n<div class=\"field\">\n  <label for=\"your-name\" class=\"field__label\">お名前 <span class=\"required\">必須</span></label>\n  <div class=\"field__control\">\n    <span class=\"wpcf7-form-control-wrap\" data-name=\"your-name\"><input size=\"40\" maxlength=\"400\" class=\"wpcf7-form-control wpcf7-text wpcf7-validates-as-required\" id=\"your-name\" aria-required=\"true\" aria-invalid=\"false\" value=\"\" type=\"text\" name=\"your-name\" /></span>\n  </div>\n</div>\n<div class=\"field\">\n  <label for=\"your-kana\" class=\"field__label\">ふりがな <span class=\"required\">必須</span></label>\n  <div class=\"field__control\">\n    <span class=\"wpcf7-form-control-wrap\" data-name=\"your-kana\"><input size=\"40\" maxlength=\"400\" class=\"wpcf7-form-control wpcf7-text wpcf7-validates-as-required\" id=\"your-kana\" aria-required=\"true\" aria-invalid=\"false\" value=\"\" type=\"text\" name=\"your-kana\" /></span>\n  </div>\n</div>\n<div class=\"field\">\n  <label for=\"your-birth-year\" class=\"field__label\">生年 <span class=\"required\">必須</span></label>\n  <div class=\"field__control\">\n    <span class=\"wpcf7-form-control-wrap\" data-name=\"your-birth-year\"><input class=\"wpcf7-form-control wpcf7-number wpcf7-validates-as-required wpcf7-validates-as-number input-year\" id=\"your-birth-year\" min=\"1900\" aria-required=\"true\" aria-invalid=\"false\" value=\"\" type=\"number\" name=\"your-birth-year\" /></span> 年\n  </div>\n</div>\n<div class=\"field\">\n  <label for=\"your-school\" class=\"field__label\">学校名 <span class=\"required\">必須</span></label>\n  <div class=\"field__control\">\n    <span class=\"wpcf7-form-control-wrap\" data-name=\"your-school\"><input size=\"40\" maxlength=\"400\" class=\"wpcf7-form-control wpcf7-text wpcf7-validates-as-required\" id=\"your-school\" aria-required=\"true\" aria-invalid=\"false\" value=\"\" type=\"text\" name=\"your-school\" /></span>\n    <p class=\"field__note\">※在学中の学校名、もしくは最終学歴の卒業校名の記入をお願いします。</p>\n  </div>\n</div>\n<div class=\"field\">\n  <label for=\"your-school-kana\" class=\"field__label\">学校名ふりがな <span class=\"required\">必須</span></label>\n  <div class=\"field__control\">\n    <span class=\"wpcf7-form-control-wrap\" data-name=\"your-school-kana\"><input size=\"40\" maxlength=\"400\" class=\"wpcf7-form-control wpcf7-text wpcf7-validates-as-required\" id=\"your-school-kana\" aria-required=\"true\" aria-invalid=\"false\" value=\"\" type=\"text\" name=\"your-school-kana\" /></span>\n  </div>\n</div>\n<div class=\"field\">\n  <label for=\"your-type\" class=\"field__label\">採用種別 <span class=\"required\">必須</span></label>\n  <div class=\"field__control\"><span class=\"wpcf7-form-control-wrap\" data-name=\"your-type\"><select class=\"wpcf7-form-control wpcf7-select wpcf7-validates-as-required\" id=\"your-type\" aria-required=\"true\" aria-invalid=\"false\" name=\"your-type\"><option value=\"\">&#8212;以下から選択してください&#8212;</option><option value=\"新卒\">新卒</option><option value=\"第二新卒\">第二新卒</option><option value=\"中途採用\">中途採用</option><option value=\"アルバイト\">アルバイト</option><option value=\"パート\">パート</option></select></span></div>\n</div>\n<div class=\"field\">\n  <label for=\"your-graduate\" class=\"field__label\">ご卒業 <span class=\"required\">必須</span></label>\n  <div class=\"field__control\"><span class=\"wpcf7-form-control-wrap\" data-name=\"your-graduate\"><select class=\"wpcf7-form-control wpcf7-select wpcf7-validates-as-required\" id=\"your-graduate\" aria-required=\"true\" aria-invalid=\"false\" name=\"your-graduate\"><option value=\"\">&#8212;以下から選択してください&#8212;</option><option value=\"高校\">高校</option><option value=\"短大\">短大</option><option value=\"大学\">大学</option><option value=\"専門\">専門</option></select></span></div>\n</div>\n<div class=\"field\">\n  <label for=\"your-graduate-year\" class=\"field__label\">卒業年月 <span class=\"required\">必須</span></label>\n  <div class=\"field__control\">\n    <div class=\"field-graduate-date\">\n      <div class=\"field-graduate-date__item\">西暦 <span class=\"wpcf7-form-control-wrap\" data-name=\"your-graduate-year\"><input class=\"wpcf7-form-control wpcf7-number wpcf7-validates-as-required wpcf7-validates-as-number input-year\" id=\"your-graduate-year\" min=\"1900\" aria-required=\"true\" aria-invalid=\"false\" value=\"\" type=\"number\" name=\"your-graduate-year\" /></span> 年</div>\n      <div class=\"field-graduate-date__item\"><span class=\"wpcf7-form-control-wrap\" data-name=\"your-graduate-month\"><select class=\"wpcf7-form-control wpcf7-select wpcf7-validates-as-required\" aria-required=\"true\" aria-invalid=\"false\" name=\"your-graduate-month\"><option value=\"1\">1</option><option value=\"2\">2</option><option value=\"3\">3</option><option value=\"4\">4</option><option value=\"5\">5</option><option value=\"6\">6</option><option value=\"7\">7</option><option value=\"8\">8</option><option value=\"9\">9</option><option value=\"10\">10</option><option value=\"11\">11</option><option value=\"12\">12</option></select></span> 月</div>\n      <div class=\"field-graduate-date__item\"><span class=\"wpcf7-form-control-wrap\" data-name=\"your-graduate-expected\"><span class=\"wpcf7-form-control wpcf7-checkbox\"><span class=\"wpcf7-list-item first last\"><label><input type=\"checkbox\" name=\"your-graduate-expected[]\" value=\"予定\" /><span class=\"wpcf7-list-item-label\">予定</span></label></span></span></span></div>\n    </div>\n  </div>\n</div>\n<div class=\"field\">\n  <label for=\"your-job-history\" class=\"field__label\">職歴 <span class=\"optional\">任意</span></label>\n  <div class=\"field__control\">\n    <span class=\"wpcf7-form-control-wrap\" data-name=\"your-job-history\"><textarea cols=\"40\" rows=\"4\" maxlength=\"2000\" class=\"wpcf7-form-control wpcf7-textarea\" id=\"your-job-history\" aria-invalid=\"false\" name=\"your-job-history\"></textarea></span>\n  </div>\n</div>\n<div class=\"field\">\n  <label for=\"your-postal-code\" class=\"field__label\">郵便番号 <span class=\"required\">必須</span></label>\n  <div class=\"field__control\">\n    <span class=\"wpcf7-form-control-wrap\" data-name=\"your-postal-code\"><input size=\"40\" maxlength=\"400\" class=\"wpcf7-form-control wpcf7-text wpcf7-validates-as-required p-postal-code\" id=\"your-postal-code\" aria-required=\"true\" aria-invalid=\"false\" value=\"\" type=\"text\" name=\"your-postal-code\" /></span>\n  </div>\n</div>\n<div class=\"field\">\n  <label for=\"your-address\" class=\"field__label\">住所 <span class=\"required\">必須</span></label>\n  <div class=\"field__control\">\n    <span class=\"wpcf7-form-control-wrap\" data-name=\"your-address\"><input size=\"40\" maxlength=\"400\" class=\"wpcf7-form-control wpcf7-text wpcf7-validates-as-required p-region p-locality p-stereet-address p-extended-address\" id=\"your-address\" aria-required=\"true\" aria-invalid=\"false\" value=\"\" type=\"text\" name=\"your-address\" /></span>\n  </div>\n</div>\n<div class=\"field\">\n  <label for=\"your-email\" class=\"field__label\">メールアドレス <span class=\"required\">必須</span></label>\n  <div class=\"field__control\">\n    <span class=\"wpcf7-form-control-wrap\" data-name=\"your-email\"><input size=\"40\" maxlength=\"400\" class=\"wpcf7-form-control wpcf7-email wpcf7-validates-as-required wpcf7-text wpcf7-validates-as-email\" id=\"your-email\" aria-required=\"true\" aria-invalid=\"false\" value=\"\" type=\"email\" name=\"your-email\" /></span>\n  </div>\n</div>\n<div class=\"field\">\n  <label for=\"your-tel\" class=\"field__label\">電話番号 <span class=\"optional\">任意</span></label>\n  <div class=\"field__control\">\n    <span class=\"wpcf7-form-control-wrap\" data-name=\"your-tel\"><input size=\"40\" maxlength=\"400\" class=\"wpcf7-form-control wpcf7-tel wpcf7-text wpcf7-validates-as-tel\" id=\"your-tel\" aria-invalid=\"false\" value=\"\" type=\"tel\" name=\"your-tel\" /></span>\n  </div>\n</div>\n<div class=\"field\">\n  <label for=\"your-message\" class=\"field__label\">問い合わせ内容 <span class=\"required\">必須</span></label>\n  <div class=\"field__control\">\n    <span class=\"wpcf7-form-control-wrap\" data-name=\"your-message\"><textarea cols=\"40\" rows=\"4\" maxlength=\"2000\" class=\"wpcf7-form-control wpcf7-textarea wpcf7-validates-as-required\" id=\"your-message\" aria-required=\"true\" aria-invalid=\"false\" placeholder=\"会社案内（パンフレット）の郵送をご希望の方はこちらに住所の記入をお願いします。\" name=\"your-message\"></textarea></span>\n  </div>\n</div>\n<div class=\"field\">\n  <label for=\"your-hope\" class=\"field__label\">ご希望部署 <span class=\"required\">必須</span></label>\n  <div class=\"field__control\"><span class=\"wpcf7-form-control-wrap\" data-name=\"your-hope\"><select class=\"wpcf7-form-control wpcf7-select wpcf7-validates-as-required\" id=\"your-hope\" aria-required=\"true\" aria-invalid=\"false\" name=\"your-hope\"><option value=\"\">&#8212;以下から選択してください&#8212;</option><option value=\"営業\">営業</option><option value=\"製版\">製版</option><option value=\"印刷\">印刷</option><option value=\"その他\">その他</option></select></span></div>\n</div>\n<div class=\"field\">\n  <label for=\"resume\" class=\"field__label\">履歴書 <span class=\"optional\">任意</span></label>\n  <div class=\"field__control\">\n    <span class=\"wpcf7-form-control-wrap\" data-name=\"resume\"><input size=\"40\" class=\"wpcf7-form-control wpcf7-file\" id=\"resume\" accept=\".jpg,.jpeg,.png,.pdf,.docx,.xlsx,.xlsm,.txt\" aria-invalid=\"false\" type=\"file\" name=\"resume\" /></span>\n    <p class=\"field__note\">添付可能なファイル：JPEG、PNG、PDF、Word、Excel、テキストファイル<br>ファイルサイズ：20MBまで</p>\n  </div>\n</div>\n<figure class=\"embed-privacy-policy\">\n  <section>\r\n  <h2>応募フォームにおける個人情報の取扱いについて</h2>\r\n  <section class=\"privacy-policy-part\">\r\n    <h3 class=\"privacy-policy-part__heading\">1. 事業者の氏名または名称</h3>\r\n    株式会社城野印刷所\r\n  </section>\r\n  <section class=\"privacy-policy-part\">\r\n    <h3 class=\"privacy-policy-part__heading\">2.個人情報保護管理者（若しくはその代理人）の氏名又は職名、所属及び連絡先</h3>\r\n    <p>個人情報保護管理者：坂田　祐輔<br>\r\n      電子メール：<a href=\"&#109;ailt&#111;&#58;i&#110;&#102;&#111;&#64;&#106;o&#110;o.c&#111;&#46;jp\">&#105;n&#102;o&#64;j&#111;&#110;&#111;&#46;c&#111;&#46;jp</a><br>\r\n      電話番号：<a href=\"tel:0962863366\">096-286-3366</a><br>\r\n    </p>\r\n  </section>\r\n  <section class=\"privacy-policy-part\">\r\n    <h3 class=\"privacy-policy-part__heading\">3. 個人情報の利用目的</h3>\r\n    <p>採用業務のため</p>\r\n  </section>\r\n  <section class=\"privacy-policy-part\">\r\n    <h3 class=\"privacy-policy-part__heading\">4. 個人情報の第三者提供について</h3>\r\n    <p>取得した個人情報は法令等による場合を除いて第三者に提供することはありません。</p>\r\n  </section>\r\n  <section class=\"privacy-policy-part\">\r\n    <h3 class=\"privacy-policy-part__heading\">5. 個人情報の取扱いの委託について</h3>\r\n    <p>取得した個人情報の取扱いの全部又は、一部を委託することはありません。</p>\r\n  </section>\r\n  <section class=\"privacy-policy-part\">\r\n    <h3 class=\"privacy-policy-part__heading\">6. 個人情報を与えなかった場合に生じる結果</h3>\r\n    <p>個人情報を与えることは任意です。個人情報に関する情報の一部をご提供いただけない場合は、お問い合わせ内容に回答できない可能性があります。</p>\r\n  </section>\r\n  <section class=\"privacy-policy-part\">\r\n    <h3 class=\"privacy-policy-part__heading\">7. 保有個人データの開示等および問い合わせ窓口について</h3>\r\n    <p>ご本人からの求めにより、当社が保有する保有個人データに関する開示、利用目的の通知、内容の訂正・追加または削除、利用停止、消去および第三者提供の停止(以下、開示等という)に応じます。</p>\r\n    <p>開示等に応ずる窓口は、下記「当社の個人情報の取扱いに関する苦情、相談等の問合せ先」を参照してください。</p>\r\n  </section>\r\n  <section class=\"privacy-policy-part\">\r\n    <h3 class=\"privacy-policy-part__heading\">8. 本人が容易に認識できない方法による個人情報の取得</h3>\r\n    <p>クッキーやウェブビーコン等を用いるなどして、本人が容易に認識できない方法による個人情報の取得は行っておりません。</p>\r\n  </section>\r\n  <section class=\"privacy-policy-part\">\r\n    <h3 class=\"privacy-policy-part__heading\">9. 個人情報の安全管理措置について</h3>\r\n    <p>取得した個人情報については、漏洩、減失またはき損の防止と是正、その他個人情報の安全管理のために必要かつ適切な措置を講じます。</p>\r\n    <p>お問合せへの回答後、取得した個人情報は当社内において削除致します。</p>\r\n  </section>\r\n  <section class=\"privacy-policy-part\">\r\n    <h3 class=\"privacy-policy-part__heading\">10. 個人情報保護方針</h3>\r\n    <p>当社ホームページの<a href=\"https://www.jono.co.jp/safety/privacy-policy/\" target=\"_blank\" rel=\"noopener noreferrer\">個人情報保護方針</a>をご覧下さい。</p>\r\n  </section>\r\n  <section class=\"privacy-policy-part\">\r\n    <h3 class=\"privacy-policy-part__heading\">11. 当社の個人情報の取扱いに関する苦情、相談等の問合せ先</h3>\r\n    <table class=\"privacy-policy-table\">\r\n      <tbody>\r\n        <tr>\r\n          <th>窓口の名称</th>\r\n          <td>個人情報問い合わせ窓口</td>\r\n        </tr>\r\n        <tr>\r\n          <th>連絡先</th>\r\n          <td>窓口責任者：坂田　祐輔<br>\r\n            住所：熊本県上益城郡益城町広崎1630-1<br>\r\n            電話/FAX：<a href=\"tel:0962863366\">096-286-3366</a>/096-286-3321<br>\r\n            電子メール：<a href=\"&#109;&#97;&#105;lt&#111;:&#105;&#110;&#102;o&#64;&#106;ono&#46;&#99;&#111;.jp\">i&#110;fo&#64;&#106;&#111;&#110;&#111;.c&#111;&#46;&#106;p</a></td>\r\n        </tr>\r\n      </tbody>\r\n    </table>\r\n  </section>\r\n</section></figure>\n\n<div class=\"acceptance\">\n  <div class=\"acceptance__item\"><label class=\"acceptance__label\"><span class=\"wpcf7-form-control-wrap\" data-name=\"your-acceptance1\"><span class=\"wpcf7-form-control wpcf7-acceptance\"><span class=\"wpcf7-list-item\"><input type=\"checkbox\" name=\"your-acceptance1\" value=\"1\" aria-invalid=\"false\" /></span></span></span> 入力内容に間違いありません</label></div>\n  <div class=\"acceptance__item\"><label class=\"acceptance__label\"><span class=\"wpcf7-form-control-wrap\" data-name=\"your-acceptance2\"><span class=\"wpcf7-form-control wpcf7-acceptance\"><span class=\"wpcf7-list-item\"><input type=\"checkbox\" name=\"your-acceptance2\" value=\"1\" aria-invalid=\"false\" /></span></span></span> 「応募フォームにおける個人情報の取扱いについて」に同意します</label></div>\n  <p>ご入力いただいた個人情報は、上記個人情報保護方針に則り利用させていただきます。</p>\n</div>\n<div class=\"wpcf7-response-output\" aria-hidden=\"true\"></div>\n<div class=\"submit\">\n  <input class=\"wpcf7-form-control wpcf7-submit has-spinner\" type=\"submit\" value=\"この内容で送信する\" />\n</div>\n</form>\n</div>\n\r\n  </div>\r\n</section>  </div>\n\t</main>\n<aside class=\"contactbox\">\n  <header class=\"contactbox__header\">\n    <h3 class=\"contactbox__heading\">Contact</h3>\n    <a href=\"https://www.jono.co.jp/support/\" class=\"contactbox__link\">お客様サポートはこちら</a>\n  </header>\n  <div class=\"contactbox__content\">\n    <p class=\"contactbox__tagline\">ご質問・お見積りのご要望がありましたらお気軽にご相談ください。</p>\n    <div class=\"contactbox-methods\">\n      <div class=\"contactbox-methods__tel\">\n        <div class=\"contactbox-tel\">\n          <a href=\"tel:0962863366\" class=\"contactbox-tel__tel\">096-286-3366</a>\n        </div>\n        <div class=\"contactbox-tel__hours\">受付時間 8:30〜17:30 日祝休み</div>\n      </div>\n      <div class=\"contactbox-methods__mail\">\n        <ul class=\"contactbox-mail\">\n          <li class=\"contactbox-mail__item\">\n            <a href=\"https://www.jono.co.jp/estimate/\" class=\"contactbox-mail__link btn\">お見積りフォーム</a>\n          </li>\n          <li class=\"contactbox-mail__item\">\n            <a href=\"https://www.jono.co.jp/contact/\" class=\"contactbox-mail__link btn\">お問い合わせ</a>\n          </li>\n        </ul>\n      </div>\n      <div class=\"contactbox-methods__sns\">\n        <ul class=\"contactbox-sns\">\n          <li class=\"contactbox-sns__item\">\n            <a href=\"https://twitter.com/jono_printing\" class=\"contactbox-sns__link\" target=\"_blank\"><span class=\"screen-reader-text\">Twitter</span></a>\n          </li>\n          <li class=\"contactbox-sns__item\">\n            <a href=\"https://www.facebook.com/jono.printing/\" class=\"contactbox-sns__link\" target=\"_blank\"><span class=\"screen-reader-text\">Facebook</span></a>\n          </li>\n        </ul>\n      </div>\n    </div>\n  </div>\n</aside>\n  <nav class=\"breadcrumbs-bottom\">\n    <ol>\n<li><a href=\"https://www.jono.co.jp/\">トップページ</a></li>\n<li><a href=\"https://www.jono.co.jp/recruit/\">採用情報</a></li>\n<li><a href=\"https://www.jono.co.jp/recruit/entry/\">応募フォーム</a></li>\n</ol>\n<script type=\"application/ld+json\">{\"@context\":\"http://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"item\":{\"@id\":\"https://www.jono.co.jp/\",\"name\":\"トップページ\"}},{\"@type\":\"ListItem\",\"position\":2,\"item\":{\"@id\":\"https://www.jono.co.jp/recruit/\",\"name\":\"採用情報\"}},{\"@ty