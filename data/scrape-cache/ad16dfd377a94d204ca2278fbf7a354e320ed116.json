{"url":"https://www.asahi.co.jp/saiyo/group/","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n\n<head>\n    <meta charset=\"utf-8\" />\n    <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\" />\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1, minimum-scale=1, maximum-scale=1, user-scalable=no\" />\n    <meta name=\"content-language\" content=\"ja\" />\n    <meta name=\"description\" content=\"2027年度朝日放送グループ採用情報のページです。\" />\n    <meta name=\"robots\" content=\"index,follow\" />\n    <meta name=\"google-site-verification\" content=\"4_zPsQJM-Wo6Z259HK0zrrLYlaSTG_0siVsrbnT8h0A\">\n    <!-- css -->\n    <link rel=\"stylesheet\" href=\"https://use.fontawesome.com/releases/v5.6.1/css/all.css\" />\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"css/style.min.css\" />\n    <!-- meta -->\n    <meta property=\"og:title\" content=\"2027年度朝日放送グループ新卒採用情報\" />\n    <meta property=\"og:description\" content=\"2027年度朝日放送グループ採用情報のページです。\" />\n    <meta property=\"og:type\" content=\"article\" />\n    <meta property=\"og:url\" content=\"https://www.asahi.co.jp/saiyo/group/\" />\n    <meta property=\"og:image\" content=\"https://www.asahi.co.jp/saiyo/group/img/ogp.png?202503\" />\n    <meta property=\"og:site_name\" content=\"2027年度朝日放送グループ採用情報\" />\n    <meta property=\"og:locale\" content=\"ja_JP\" />\n    <meta name=\"twitter:card\" content=\"summary_large_image\">\n    <meta name=\"twitter:image\" content=\"https://www.asahi.co.jp/saiyo/group/img/ogp.png?202503\">\n    <!-- analytics -->\n    <!-- <script type=\"text/javascript\" src=\"/common/js/analytics.min.js\" charset=\"UTF-8\"></script> -->\n\n    <title>朝日放送グループ新卒採用情報| 朝日放送グループホールディングス</title>\n    <!-- Google Tag Manager -->\n    <script>\n        (function (w, d, s, l, i) {\n            w[l] = w[l] || [];\n            w[l].push({\n                'gtm.start': new Date().getTime(),\n                event: 'gtm.js'\n            });\n            var f = d.getElementsByTagName(s)[0],\n                j = d.createElement(s),\n                dl = l != 'dataLayer' ? '&l=' + l : '';\n            j.async = true;\n            j.src =\n                'https://www.googletagmanager.com/gtm.js?id=' + i + dl;\n            f.parentNode.insertBefore(j, f);\n        })(window, document, 'script', 'dataLayer', 'GTM-WPBZTT4');\n    </script>\n    <!-- End Google Tag Manager -->\n</head>\n\n<body>\n    <!-- Google Tag Manager (noscript) -->\n    <noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-WPBZTT4\" height=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n    <!-- End Google Tag Manager (noscript) -->\n    <header>\n        <div class=\"wrap-out\">\n            <div class=\"wrap-top\">\n                <p class=\"topLogo\"><img src=\"./img/logo.png\" alt=\"朝日放送グループホールディングス\"></p>\n                <h1><span>2027年度</span>朝日放送グループ<br>採用情報</h1>\n                <p class=\"topTxt\">2027年度朝日放送グループ<br class=\"tab_l-only\">採用情報のページです。</p>\n            </div>\n            <div class=\"topImage\"><img src=\"./img/head_ill.png\" alt=\"\"></div>\n        </div>\n    </header>\n\n    <main>\n        <section class=\"wrap-out\">\n            <div class=\"wrap-inn\">\n\n                <!-- ABCフロンティア -->\n                <!-- <dl class=\"company-introduction box\">\n                    <dt class=\"company-title\">\n                        <h1>ABC フロンティア</h1>\n                        <div class=\"company-hp_date\">\n                            <p class=\"company-hp\"><a href=\"https://abc-frontier.co.jp/\" target=\"_blank\">https://abc-frontier.co.jp/</a></p>\n                            <p class=\"date\">掲載日：2025.3.14</p>\n                        </div>\n                    </dt>\n                    <dd>\n                        <ul class=\"company-detail\">\n                            <li class=\"company-logo_wrap\">\n                                <div class=\"company-logo\">\n                                    <a href=\"https://abc-frontier.co.jp/\" target=\"_blank\"><img src=\"./img/logo-abc-frontier.png\" alt=\"ABC フロンティア\"></a>\n                                </div>\n                            </li>\n                            <li class=\"company-copy\">\n                                <p class=\"company-txt\">\n                                    株式会社ABCフロンティアは朝日放送グループの一員として、国内販売、海外販売、動画配信、物販、イベント、音楽、ライセンス事業など多彩なコンテンツを展開する「総合コンテンツ企業」です。<br>\n                                    コロナ禍を経てエンターテインメントの世界においてもデジタルシフトが進み、それを伝える手段も急速に進化、普及する中、社名に込めた「開拓者精神」のもと、良質なコンテンツやサービスの提供にチャレンジしています。エンターテインメントの未来をともに切り拓く仲間を募集しています。あなたのアイデアや情熱を、当社で形にしませんか？\n                                </p>\n                                <p class=\"company-bt\">\n                                    <a href=\"https://abc-frontier.co.jp/recruit\" target=\"_blank\" class=\"ico-arrow\">採用情報はこちら</a>\n                                </p>\n                            </li>\n                        </ul>\n                    </dd>\n                </dl> -->\n                <!-- スカイA -->\n                <!-- <dl class=\"company-introduction box\">\n                    <dt class=\"company-title\">\n                        <h1>株式会社 スカイA</h1>\n                        <div class=\"company-hp_date\">\n                            <p class=\"company-hp\"><a href=\"https://sky-a.asahi.co.jp/\" target=\"_blank\">https://sky-a.asahi.co.jp/</a></p>\n                            <p class=\"date\">掲載日：2025.3.14</p>\n                        </div>\n                    </dt>\n                    <dd>\n                        <ul class=\"company-detail\">\n                            <li class=\"company-logo_wrap\">\n                                <div class=\"company-logo\">\n                                    <a href=\"https://sky-a.asahi.co.jp/\" target=\"_blank\"><img src=\"./img/logo-sky-a.png\" alt=\"株式会社 スカイA\"></a>\n                                </div>\n                            </li>\n                            <li class=\"company-copy\">\n                                <p class=\"company-txt\">\n                                    CSスポーツチャンネル「スカイA」は、1994年に放送を開始したCS放送局です。スカパーや、ケーブルテレビなどを通じて全国で視聴することが出来ます。阪神タイガースキャンプ、公式戦中継。プロ野球ドラフト会議。男女ゴルフトーナメント中継。人気のアウトドアなど、有料チャンネルならではの独自編成・専門性で、スポーツファンの皆様に好評をいただいています。<br>\n                                    自社での番組制作率が高いことに加え、近年ではスポーツメディアの将来性も見据えて、ネット配信による競技中継でも実績を重ねて来ました。<br>\n                                    朝日放送グループホールディングスの「CS放送事業」を担っており、福利厚生も手厚く、安心して働いて頂ける会社です。\n                                </p>\n                                <p class=\"company-bt\">\n                                    <a href=\"https://sky-a.asahi.co.jp/recruit/\" target=\"_blank\" class=\"ico-arrow\">採用情報はこちら</a>\n                                </p>\n                            </li>\n                        </ul>\n                    </dd>\n                </dl> -->\n\n                <!-- 株式会社エー・ビー・シーリブラ -->\n                <dl class=\"company-introduction box\">\n                    <dt class=\"company-title\">\n                        <h1>株式会社エー・ビー・シー<br class=\"sp-only\">リブラ</h1>\n                        <div class=\"company-hp_date\">\n                            <p class=\"company-hp\"><a href=\"http://www.abclibra.co.jp/\" target=\"_blank\">http://www.abclibra.co.jp/</a></p>\n                            <p class=\"date\">掲載日：2026.3.23</p>\n                        </div>\n                    </dt>\n                    <dd>\n                        <ul class=\"company-detail\">\n                            <li class=\"company-logo_wrap\">\n                                <div class=\"company-logo\">\n                                    <a href=\"http://www.abclibra.co.jp/\" target=\"_blank\"><img src=\"./img/logo-libra.png\" alt=\"株式会社エー・ビー・シーリブラ\"></a>\n                                </div>\n                            </li>\n                            <li class=\"company-copy\">\n                                <p class=\"company-txt\">\n                                朝日放送グループホールディングスの100％出資の映像コンテンツ制作会社（＝ハウスプロダクション）で、「朝だ生です！旅サラダ」「新婚さんいらっしゃい」「これ余談なんですけど」など朝日放送テレビの有名番組を多数手がけています。また、映像アーカイブにも力を入れており、朝日放送の莫大な映像資産も管理。オフィスもきれいで働きやすい環境が整っています、番組全体を統括し、スタジオ内ではディレクター卓に座り指示を出したり、全国の朝日放送テレビ系列局と連携して生中継を担当するなど、朝日放送テレビの社員ディレクターと同様の役割を担っているのが最大の特徴です。バラエティ以外にもドラマや報道記者など様々なジャンル手掛けているので途中でやってみたいジャンルを変えて挑戦できるのも大きいです。\n                                </p>\n                                <p class=\"company-bt\">\n                                    <a href=\"https://www.abclibra.co.jp/recruit/#creator\" target=\"_blank\" class=\"ico-arrow\">新卒採用情報はこちら</a>\n                                </p>\n                            </li>\n                        </ul>\n                    </dd>\n                </dl>\n\n                <!-- デジアサ --><!-- テキスト無し → class=\"company-introduction box none_txtlogo\" -->\n                <dl class=\"company-introduction box\">\n                    <dt class=\"company-title\">\n                        <h1>株式会社デジアサ</h1>\n                        <div class=\"company-hp_date\">\n                            <p class=\"company-hp\"><a href=\"https://www.digiasa.co.jp/\" target=\"_blank\">https://www.digiasa.co.jp/</a></p>\n                            <p class=\"date\">掲載日：2026.3.23</p>\n                        </div>\n                    </dt>\n                    <dd>\n                        <ul class=\"company-detail\">\n                            <li class=\"company-logo_wrap\">\n                                <div class=\"company-logo\">\n                                    <a href=\"https://www.digiasa.co.jp/\" target=\"_blank\"><img src=\"./img/logo-digiasa.png\" alt=\"株式会社デジアサ\"></a>\n                                </div>\n                            </li>\n                            <li class=\"company-copy\">\n                                <p class=\"company-txt\">\n                                朝日放送グループのデジタル領域をハックする「デジアサ」。総合職を募集します！<br>\n                               『M-1グランプリ』や『バーチャル高校野球』など、日本中の注目が集まる巨大トラフィックをクラウドで支えます。若いうちから大規模インフラに触れ、数百万人の「熱狂」を形にする手応えを味わえます。 また、放送局のアセットを活かして広告運用やデータ分析、AI活用を行い、クライアントの課題を解決。自ら仮説検証を回し、ビジネスをスケールさせる「仕掛け人」として活躍できます。<br>\n                               完璧なスキルより「データで新しい価値を生む」といった論理的思考を重視。柔軟な働き方も叶う環境で、デジタル領域の最適解を導く人材へ成長しませんか？\n\n                                </p>\n                                <p class=\"company-bt\">\n                                    <a href=\"https://www.digiasa.co.jp/recruit/\" target=\"_blank\" class=\"ico-arrow\">新卒採用情報はこちら</a>\n                                </p>\n                            </li>\n                        </ul>\n                    </dd>\n                </dl>\n\n                <!-- 株式会社アイネックス -->\n                <dl class=\"company-introduction box\">\n                    <dt class=\"company-title\">\n                        <h1>株式会社アイネックス</h1>\n                        <div class=\"company-hp_date\">\n                            <p class=\"company-hp\"><a href=\"https://www.i-nex.jp/\" target=\"_blank\">https://www.i-nex.jp/</a></p>\n                            <p class=\"date\">掲載日：2026.3.23</p>\n                        </div>\n                    </dt>\n                    <dd>\n                        <ul class=\"company-detail\">\n                            <li class=\"company-logo_wrap\">\n                                <div class=\"company-logo\">\n                                    <a href=\"https://www.i-nex.jp/\" target=\"_blank\"><img src=\"./img/logo-inex.png\" alt=\"株式会社アイネックス\"></a>\n                                </div>\n                            </li>\n                            <li class=\"company-copy\">\n                                <p class=\"company-txt\">\n                                    アイネックスは、コンテンツ制作・放送・配信を支える【技術プロダクション】です。<br>\n                                    撮影・編集・CG・美術・ラジオなど、幅広い分野で携わっています。バラエティ番組や情報番組、スポーツや報道といった あらゆる現場を経験できる環境です。<br>\n                                    また近年では、テレビ番組以外にも さまざまなイベントや配信に力を入れ、業務の幅を拡大中！テレビの仕事はもちろん、新規開拓のやりがいも感じられる職場です。<br>\n                                    放送の技術を学び、応用し、私たちとともに さらなる“新しいシゴト”を生み出しませんか。\n                                </p>\n                                <div class=\"company-bt-flex\">\n                                <p class=\"company-bt\">\n                                    <a href=\"https://job.mynavi.jp/27/pc/search/corp225970/outline.html\" target=\"_blank\" class=\"ico-arrow\">新卒採用情報はこちら</a>\n                                </p>\n                                <p class=\"company-bt\">\n                                    <a href=\"https://www.i-nex.jp/recruit/\" target=\"_blank\" class=\"ico-arrow\">キャリア採用情報は<br class=\"pc-only\">こちら</a>\n                                </p>\n                                </div>\n                            </li>\n                        </ul>\n                    </dd>\n                </dl>\n\n              <!-- 株式会社マッシュ -->\n                <dl class=\"company-introduction box\">\n                    <dt class=\"company-title\">\n                        <h1>株式会社マッシュ</h1>\n                        <div class=\"company-hp_date\">\n                            <p class=\"company-hp\"><a href=\"https://www.mash-japan.com/\" target=\"_blank\">https://www.mash-japan.com/</a></p>\n                            <p class=\"date\">掲載日：2026.3.23</p>\n                        </div>\n                    </dt>\n                    <dd>\n                        <ul class=\"company-detail\">\n                            <li class=\"company-logo_wrap\">\n                                <div class=\"company-logo\">\n                                    <a href=\"https://www.mash-japan.com/\" target=\"_blank\"><img src=\"./img/logo-mash.png\" alt=\"株式会社マッシュ\"></a>\n                                </div>\n                            </li>\n                            <li class=\"company-copy\">\n                                <p class=\"company-txt\">\n                                    ～ヒトが中心のコミュニケーションサービス企業を目指して～<br>\n                                    マッシュは、イベントの企画・制作・プロデュース会社です。イベントの企画から実施までワンストップでプロデュースします。<br>\n                                    私たちの会社は、「ヒト」の能力についているものが商品であり、50人いれば50通りの商品があります。<br>\n                                    つまり、個人力をアップさせ、 チームとして活かしていく場が、わが社の「仕事の場所」です。<br>\n                                    「世の中を少しだけ楽しくしてみたい」マインドで、一緒に働いてくれる仲間をお待ちしています。\n                                </p>\n                                <p class=\"company-bt\">\n                                    <a href=\"https://www.mash-japan.com/recruit\" target=\"_blank\" class=\"ico-arrow\">新卒採用・キャリア採用情報は<br>こちら</a>\n                                </p>\n                            </li>\n                        </ul>\n                    </dd>\n                </dl>\n\n                <!-- 株式会社ベスティ -->\n                <dl class=\"company-introduction box\">\n                    <dt class=\"company-title\">\n                        <h1>株式会社ベスティ</h1>\n                        <div class=\"company-hp_date\">\n                            <p class=\"company-hp\"><a href=\"https://bestie-sports.co.jp/\" target=\"_blank\">https://bestie-sports.co.jp/</a></p>\n                            <p class=\"date\">掲載日：2026.3.23</p>\n                        </div>\n                    </dt>\n                    <dd>\n                        <ul class=\"company-detail\">\n                            <li class=\"company-logo_wrap\">\n                                <div class=\"company-logo\">\n                                    <a href=\"https://bestie-sports.co.jp/\" target=\"_blank\"><img src=\"./img/logo-bestie.png\" alt=\"ベスティ\"></a>\n                                </div>\n                            </li>\n                            <li class=\"company-copy\">\n                                <p class=\"company-txt\">\n                                    ABCグループのスポーツコンテンツを生み出す会社です。プロ野球の地上波・CS阪神タイガース中継、虎バンチャンネル。夏の高校野球テレビ・ラジオ中継や「熱闘甲子園」「甲子園への道」「バーチャル高校野球」コンテンツも制作し、ゴルフ中継、バスケット、eスポーツ・・・<br>\n                                    スポーツに関するノウハウを活用してメディアの枠を超えた「クリエイティブ集団」として、アスリートとスポーツを愛する方々を結び社会貢献、地域創生を目指す新しいタイプのプロダクションです。<br>\n                                    また、阪神ファン感謝デー、高校ダンス部選手権（DCC)、高校野球テーマソングアーチストとブラスバンドが競演する熱闘JAMなどイベント事業も年間を通して多角的に展開しています。\n\n                                </p>\n                                <p class=\"company-bt\">\n                                    <a href=\"https://job.mynavi.jp/27/pc/search/corp264074/outline.html\" target=\"_blank\" class=\"ico-arrow\">新卒採用情報はこちら</a>\n                                </p>\n                            </li>\n                        </ul>\n                    </dd>\n                </dl>\n                \n                <!-- エー・ビー・シー開発株式会社 -->\n                <dl class=\"company-introduction box\">\n                    <dt class=\"company-title\">\n                        <h1>エー・ビー・シー開発<br class=\"sp-only\">株式会社</h1>\n                        <small>（※2026年4月1日より「ABCライフィズ株式会社」に社名変更）</small>\n                        <div class=\"company-hp_date\">\n                            <p class=\"company-hp\"><a href=\"https://www.abcd.ne.jp/\" target=\"_blank\">https://www.abcd.ne.jp/</a></p>\n                            <p class=\"date\">掲載日：2026.3.23</p>\n                        </div>\n                    </dt>\n                    <dd>\n                        <ul class=\"company-detail\">\n                            <li class=\"company-logo_wrap\">\n                                <div class=\"company-logo\">\n                                    <a href=\"https://www.abcd.ne.jp/\" target=\"_blank\"><img src=\"./img/logo-abcd.png\" alt=\"エー・ビー・シー開発株式会社\"></a>\n                                </div>\n                            </li>\n                            <li class=\"company-copy\">\n                                <p class=\"company-txt\">\n                                総合住宅展示場「ABCハウジング」の企画・運営を行っている会社です。<br>\n                                当社のハウジング事業は、住まいづくりを計画する消費者とハウスメーカーの橋渡し役として、住宅購入を検討している消費者をABCハウジングに呼び込む広告企画の立案や、会場の施設管理、ハウスメーカーへの営業活動などを行っています。<br>\n                                また、当社はハウジング事業の他にもHDC事業、広告代理業、不動産事業など多角的に事業を展開。いずれの事業も、自分のアイデアをカタチにする仕事です。当社の事業に興味のある方、好奇心旺盛で新しい事にチャレンジしたい方をお待ちしています。\n\n                                </p>\n                                <p class=\"company-bt\">\n                                    <a href=\"https://www.abcd.ne.jp/recruit/\" target=\"_blank\" class=\"ico-arrow\">新卒採用情報はこちら</a>\n                                </p>\n                            </li>\n                        </ul>\n                    </dd>\n                </dl>\n\n                 <!-- 株式会社トイジアム -->\n                <dl class=\"company-introduction box\">\n                    <dt class=\"company-title\">\n                        <h1>株式会社トイジアム</h1>\n                        <div class=\"company-hp_date\">\n                            <p class=\"company-hp\"><a href=\"https://toydium.co.jp/\" target=\"_blank\">https://toydium.co.jp/</a></p>\n                            <p class=\"date\">掲載日：2026.3.23</p>\n                        </div>\n                    </dt>\n                    <dd>\n                        <ul class=\"company-detail\">\n                            <li class=\"company-logo_wrap\">\n                                <div class=\"company-logo\">\n                                    <a href=\"https://toydium.co.jp/\" target=\"_blank\"><img src=\"./img/logo-toydium.png\" alt=\"株式会社トイジアム\"></a>\n                                </div>\n                            </li>\n                            <li class=\"company-copy\">\n                                <p class=\"company-txt\">\n                               真剣に、ただ面白いものづくりをしたい。<br>\n                               “おもちゃ”で家族や友人、その隣の人も笑顔にしたい。<br>\n\n                               株式会社トイジアムは、そんな思いを持って設立したゲーム/エンターテインメントの会社です。<br>\n                               ただつくるだけではなく、心から面白いと感じたものを素直に、<br>\n                               そして何より開発者自身が楽しみながらつくることを大切にしています。<br>\n                               そしてその楽しい気持ちがまた他の人を楽しませる活力になる、<br>\n                               そんな素晴らしい連鎖反応を起こす”おもちゃ”を一緒につくりましょう。\n                                </p>\n                                <p class=\"company-bt\">\n                                    <a href=\"https://www.wantedly.com/companies/company_1936505\" target=\"_blank\" class=\"ico-arrow\">キャリア採用情報はこちら</a>\n                                </p>\n                            </li>\n                        </ul>\n                    </dd>\n                </dl>\n\n            </div>\n        </section>\n    </main>\n\n    <footer>\n        <div id=\"page_top\"><a href=\"#\"></a></div>\n        <div class=\"wrap-out\">\n            <div class=\"footer-link_portal\">\n                <a href=\"../\"><img src=\"img/bnr_saiyo_portal.jpg\" alt=\"朝日放送グループホールディングス 採用情報\"></a>\n            </div>\n            <ul class=\"footer-link\">\n                <li><a href=\"https://corp.asahi.co.jp/ja/index.html\" target=\"_blank\">会社概要<i class=\"fas fa-external-link-alt\"></i></a></li>\n                <li><a href=\"https://www.asahi.co.jp/regulation/\" target=\"_blank\">サイトのご利用にあたって<i class=\"fas fa-external-link-alt\"></i></a></li>\n                <li><a href=\"https://www.asahi.co.jp/personal/\" target=\"_blank\">個人情報の取り扱い方針<i class=\"fas fa-external-link-alt\"></i></a></li>\n            </ul>\n        </div>\n        <p class=\"footer-cr\">©ABC TV All rights reserved.</p>\n    </footer>\n\n    <!-- js -->\n    <script src=\"js/lib/jquery.min.js\" type=\"text/javascript\"></script>\n    <script src=\"js/lib/scrollreveal.min.js\" type=\"text/javascript\"></script>\n    <script src=\"js/lib/anime.min.js\" type=\"text/javascript\"></script>\n    <script src=\"js/common.min.js\" type=\"text/javascript\"></script>\n</body>\n\n</html>\n","finalUrl":"https://www.asahi.co.jp/saiyo/group/","rendered":false,"_cachedAt":"2026-06-23T17:08:56.600Z"}