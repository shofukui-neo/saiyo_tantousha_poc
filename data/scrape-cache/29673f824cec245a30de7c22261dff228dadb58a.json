{"url":"http://recruit.kakuhiro.co.jp/entry/","html":"<!doctype html>\r\n<html>\r\n<head>\r\n<meta charset=\"utf-8\">\r\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\" />\r\n<meta name=\"viewport\" content=\"width=device-width\" />\r\n<meta name=\"description\" content=\"&nbsp; 待遇・福利厚生初任給(令和９年３月卒)総合職：高校卒166,000円、短大・専門卒175,000円、　　　　青森県内：大卒196,000円　　　　青森県外：大卒206,000円賞与賞与：...\">\r\n<meta property=\"og:title\" content=\"エントリー\"> \r\n<meta property=\"og:type\" content=\"website\"> \r\n<meta property=\"og:image\" content=\"http://recruit.kakuhiro.co.jp/wp-content/themes/original/contents_images/logo.png\">\r\n<meta property=\"og:url\" content=\"http://recruit.kakuhiro.co.jp/entry/\"> \r\n<meta property=\"og:site_name\" content=\"角弘リクルートサイト\"> \r\n<meta property=\"og:description\" content=\"&nbsp; 待遇・福利厚生初任給(令和９年３月卒)総合職：高校卒166,000円、短大・専門卒175,000円、　　　　青森県内：大卒196,000円　　　　青森県外：大卒206,000円賞与賞与：...\">\r\n<meta property=\"og:locale\" content=\"ja_JP\" />\r\n<meta property=\"fb:app_id\" content=\"App-ID（15文字の半角数字）\" />\r\n<meta name=\"twitter:card\" content=\"summary\" />\r\n<meta name=\"twitter:site\" content=\"@[Twitter ID]\" />\r\n\r\n<!-- 記事・ページだった場合はタイトルも表示 -->\r\n<title>エントリー  |  角弘リクルートサイト</title>\r\n\r\n<!-- 基本CSS読み込み -->\r\n<link rel=\"stylesheet\" href=\"http://recruit.kakuhiro.co.jp/wp-content/themes/original/style.css\" />\r\n<style type=\"text/css\" media=\"print\">body{width:1080px;}</style>\r\n\r\n<!-- js読み込み -->\r\n<script src=\"http://recruit.kakuhiro.co.jp/wp-content/themes/original/js/jquery-1.11.1.min.js\"></script>\r\n<script src=\"http://recruit.kakuhiro.co.jp/wp-content/themes/original/js/javascript.js\"></script>\r\n\r\n<!-- Global site tag (gtag.js) - Google Analytics -->\r\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=UA-111363109-1\"></script>\r\n<script>\r\n  window.dataLayer = window.dataLayer || [];\r\n  function gtag(){dataLayer.push(arguments);}\r\n  gtag('js', new Date());\r\n\r\n  gtag('config', 'UA-111363109-1');\r\n<