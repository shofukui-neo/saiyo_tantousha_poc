{"url":"https://ssfm.co.jp/","html":"<!doctype html>\n<html lang=\"\">\n<head>\n\t<meta charset=\"utf-8\">\n\t<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n\t<title>дҪҸеҸӢе•ҶдәӢгғ•гӮЈгғҠгғігӮ·гғЈгғ«гғһгғҚгӮёгғЎгғігғҲж ӘејҸдјҡзӨҫ</title>\n\t<meta name=\"description\" content=\"\">\n\t<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n\n\t<link rel=\"stylesheet\" href=\"common/css/common.css\">\n\t<link rel=\"stylesheet\" href=\"css/top.css\">\n\t<script src=\"common/js/vendor/jquery-2.2.4.min.js\"></script>\n\t<script src=\"common/js/common.js\"></script>\n\n</head>\n<body>\n<div id=\"wrapper\">\n\t<!-- gHeader -->\n\t<header id=\"gHeader\">\n\t\t<div class=\"layout-inner\">\n\t\t\t<h1 class=\"hLogo\"><a href=\"index.html\"><img class=\"autoImg\" src=\"common/img/logo01.png\" alt=\"дҪҸеҸӢе•ҶдәӢгғ•гӮЈгғҠгғігӮ·гғЈгғ«гғһгғҚгӮёгғЎгғігғҲж ӘејҸдјҡзӨҫ\"></a></h1>\n\t\t\t<div class=\"gNavTrigger\"><div class=\"gNavTrigger_border\"><span></span><span></span><span></span></div></div>\n\t\t</div>\n\t\t<nav id=\"gNav\">\n\t\t\t<div class=\"gNav_inner\">\n\t\t\t\t<div class=\"gNav_home\">\n\t\t\t\t\t<a class=\"gNav_home_link hover-opacity\" href=\"index.html\">HOME</a>\n\t\t\t\t</div>\n\t\t\t\t<div class=\"gNav_column\">\n\t\t\t\t\t<ul class=\"gNav_list gNav_list-01\">\n\t\t\t\t\t\t<li class=\"gNav_item gNav_item-first gNav_item-first-01\">\n\t\t\t\t\t\t\t<a class=\"gNav_link link-arrow\" href=\"company/index.html\">дјҡзӨҫжғ…е ұ</a>\n\t\t\t\t\t\t</li>\n\t\t\t\t\t</ul>\n\t\t\t\t\t<ul class=\"gNav_list-second\">\n\t\t\t\t\t\t<li class=\"gNav_item gNav_item-second gNav_item-second-02\">\n\t\t\t\t\t\t\t<a class=\"gNav_link link-arrow\" href=\"company/index.html#identity\">зөҢе–¶зҗҶеҝөгғ»иЎҢеӢ•жҢҮйҮқ</a>\n\t\t\t\t\t\t</li>\n\t\t\t\t\t\t<li class=\"gNav_item gNav_item-second gNav_item-second-03\">\n\t\t\t\t\t\t\t<a class=\"gNav_link link-arrow\" href=\"company/index.html#mission\">гғҹгғғгӮ·гғ§гғі</a>\n\t\t\t\t\t\t</li>\n\t\t\t\t\t\t<li class=\"gNav_i