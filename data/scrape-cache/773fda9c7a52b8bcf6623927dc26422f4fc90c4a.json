{"url":"https://www.kakihara.co.jp/recruit/recdata/recdata.html","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n<head>\n<!-- Google Tag Manager -->\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n})(window,document,'script','dataLayer','GTM-TJ6RC8D');</script>\n<!-- End Google Tag Manager -->\n\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1, minimum-scale=1, maximum-scale=1, user-scalable=no\">\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge,chrome=1\">\n<title>募集要項｜採用情報</title>\n<meta name=\"description\" content=\"柿原工業株式会社は、「あらゆる素材を独自のメタライジング技術によって高付加価値化する」を事業テーマに、その最先端を切り開きます。樹脂製品の一貫生産体制（金型、射出成形、表面処理-めっき-、塗装、組立、リサイクル）で高品質、短納期の製品をお届けします。\">\n<meta name=\"keywords\" content=\"メッキ,めっき,樹脂メッキ,樹脂めっき,マグネシウム合金代替,Mg合金代替,衝撃吸収PP樹脂メッキ,モノリスプロセス,金型,射出成形,表面処理,塗装,ISO14001,ISO9001,組立,環境対策,印刷,メインドア,スロットマシン,アルミ調,サテンめっき,サテンメッキ,3価クロムめっき,3価クロムメッキ,高品質,短納期,コストダウン,金メッキ,大型製品,樹脂メッキのリサイクル,樹脂めっきのリサイクル\">\n<meta name=\"copyright\" content=\"柿原工業株式会社\" />\n<meta name=\"robots\" content=\"noarchive\">\n<link href=\"../common/css/font-awesome.min.css\" rel=\"stylesheet\" media=\"screen,print\">\n<link href=\"../common/css/noto-sans-cjkjp.css\" rel=\"stylesheet\" media=\"screen,print\">\n<link href=\"../common/css/reset.css\" rel=\"stylesheet\" media=\"screen,print\">\n<link href=\"../common/css/common.css\" rel=\"stylesheet\" media=\"screen\">\n<link href=\"../common/css/layout.css\" rel=\"stylesheet\" media=\"screen\">\n<link href=\"../common/css/navi_l.css\" rel=\"stylesheet\" media=\"screen and (min-width:1280px)\">\n<link href=\"../common/css/navi_s.css\" rel=\"stylesheet\" media=\"screen and (max-width:1279px)\">\n<link href=\"../common/css/page_l.css\" rel=\"stylesheet\" media=\"screen and (min-width:700px)\">\n<link href=\"../common/css/page_s.css\" rel=\"stylesheet\" media=\"screen and (max-width:699px)\">\n<link href=\"../common/css/foot_l.css\" rel=\"stylesheet\" media=\"screen and (min-width:700px)\">\n<link href=\"../common/css/foot_s.css\" rel=\"stylesheet\" media=\"screen and (max-width:699px)\">\n<link href=\"../common/css/magnific-popup.css\" rel=\"stylesheet\" media=\"screen,print\">\n<link href=\"css/print.css\" rel=\"stylesheet\" media=\"print\">\n<link href=\"css/style.css\" rel=\"stylesheet\" media=\"screen\">\n<script src=\"../js/jquery-1.8.1.js\" type=\"text/javascript\"></script>\n<script src=\"../js/common.js\" type=\"text/javascript\"></script>\n<script src=\"../js/jquery.matchHeight.js\" type=\"text/javascript\"></script>\n<script type=\"text/javascript\">\n    // ナビゲーションのオープン・クローズの画面拡張処理\n\t$(function() {\n\t\t$(\"#panel-btn\").click(function() {\t\n\t\t$(\"#gNavi\").slideToggle(200);\n\t\t$(\"#panel-btn-icon\").toggleClass(\"close\");\n\t\t\treturn false;\n\t\t});\n\t\t$(window).resize(function(){\n\t\t\tvar win = $(window).width();\n\t\t\tvar p = 1279;\n\t\t\tif(win > p){\n\t\t\t\t$(\"#gNavi\").show();\n    \t\t} else {\n\t    \t\t//メニューが開いているかどうか判定、開いていないときはナビを閉じる\n\t    \t\tif($(\"#panel-btn-icon\").hasClass(\"close\")){\n\t\t    \t} else {\n\t\t\t\t\t$(\"#gNavi\").hide();\n\t\t\t\t}\n    \t\t}\n\t\t});\n\t});\n\t//フッタのロゴをマウスオーバーした際にCorporate Websaiteをアクティブにする\n\t$(function() {\n\t\t$(\"#corpBox img\").hover(\n\t\tfunction () {\n\t\t\t$(\"#corpBox p\").addClass('hover');\n\t\t},\n\t\tfunction () {\n\t\t\t$(\"#corpBox p\").removeClass('hover');\t\n\t\t}\n\t\t);\n\t});\n\t//フッタのリストを揃える\n\t$(function() {\n    \t$('#footerNavi li').matchHeight();\n\t});\n</script>\n</head>\n<body>\n<!-- Google Tag Manager (noscript) -->\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-TJ6RC8D\"\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n<!-- End Google Tag Manager (noscript) -->\n<div id=\"loader-bg\">\n    <div id=\"loading\">\n        <div class=\"spinner\">\n            <div class=\"circle\"></div>\n        </div>\n    </div>\n</div>\n<header id=\"header\">\n    <div id=\"headArea\">\n        <div id=\"sMenu\">\n            <div id=\"panel-btn-menu\">MENU</div>\n            <a href=\"javascript:void(0)\" id=\"panel-btn\"><span id=\"panel-btn-icon\"></span></a> </div>\n        <div id=\"logo\"><a href=\"../index.html\"><img src=\"../common/image/rogo.png\" alt=\"柿原工業株式会社\" width=\"169\" height=\"32\"></a></div>\n        <div id=\"corpo\"><a href=\"http://www.kakihara.co.jp/\" target=\"_blank\">コーポレートサイト</a></div>\n    </div>\n</header>\n<div id=\"gNavi\">\n    <div id=\"naviArea\">\n        <ul class=\"naviBox\">\n            <li> <span class=\"pcNone\"><a href=\"../index.html\">ホーム</a></span> </li>\n            <li> <a href=\"../about/about.html\">About Kakihara</a> </li>\n            <li> <a href=\"../interview/interview.html\">トップインタビュー</a> </li>\n            <li> <a href=\"../episode/episode.html\">開発エピソード</a> </li>\n            <li> <a href=\"../cross01/closs01.html\">クロストーク</a> </li>\n            <li> <a href=\"../worklife/worklife.html\">ワークライフ</a> </li>\n            <li> <a href=\"../staff/staff.html\">カキハラ4＋</a> </li>\n            <li> <a href=\"../works/works.html\">全仕事解説</a> </li>\n            <li> <a href=\"../recruit.html\">採用情報</a> </li>\n            <li> <a href=\"../entry/page.html\" class=\"mov-popup\">エントリー</a> </li>\n            <li> <span class=\"pcNone\"><a href=\"http://www.kakihara.co.jp/\" target=\"_blank\">コーポレートサイト</a></span> </li>\n        </ul>\n    </div>\n</div>\n<article id=\"imageContainer\">\n    <div class=\"imageBox\">\n        <h1>募集要項</h1>\n        <img src=\"../common/image/image.png\" alt=\"image\" width=\"1400\" height=\"642\" class=\"image\">\n        <div class=\"titleBox\"><img src=\"../common/image/title.png\" alt=\"title\" width=\"1400\" height=\"127\" class=\"title\"></div>\n    </div>\n    <div class=\"readBox\">\n        <div class=\"trightBox\">\n            \n                <h2>豊かな想像力で<br>\n道を切り拓く挑戦者であれ！\n</h2>\n                <p>水と空気以外のあらゆる新素材に展開できるメタライジング。メタライジング技術によって付加できる機能は実に様々で、可能性は無限に広がっています。さらにそのフィールドは、日本からタイ、そして世界へ。今までにない新しい技術、新しい価値を一緒に作っていきませんか。</p>\n            \n        </div>\n    </div>\n</article>\n<div id=\"bodyContainer\">\n    <article class=\"bodyinlineBox clearFix\">\n\t    <div class=\"inview\">\n        <aside class=\"midashi_left\">Recruiting Data</aside>\n        <div class=\"sBox\">\n            <h2>2027年新卒募集要項</h2><br>\n            \n            <table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" class=\"table_data\">\n                <tr>\n                    <th class=\"koumoku\">職　種</th>\n                    <td>●総合職<br>【主に理系】研究開発、設備技術、金型設計、生産技術、社内SE<br>\n【主に文系】海外業務、営業技術、品質管理、生産管理<br><br>\n\n<dl>           \n<dt>① 研究開発</dt><dd>メタライジング（めっき）の研究開発。</dd>\n<dt>② 設備技術</dt><dd>自社生産設備の開発、改造。</dd>\n<dt>③ 金型設計</dt><dd>CAD/CAM/CAEを用いての金型設計・製作。</dd>\n<dt>④ 生産技術</dt><dd>成形/メタライジングの生産に関わる技術開発・支援。</dd>\n<dt>⑤ 海外業務</dt><dd>海外顧客・拠点との調整業務、貿易業務、<br>将来の海外スタッフ。（英語・タイ語に対応出来る方）</dd>\n<dt>⑥ 営業技術</dt><dd>客先窓口、新規製品の立上げ。（各部署を経験の上で配属になります）</dd>\n<dt>⑦ 品質管理</dt><dd>製品の品質管理。客先との品質調整。</dd>\n<dt>⑧ 生産管理</dt><dd>生産に関する管理業務。</dd>\n<dt>⑨ 社内SE</dt><dd>受注から出荷までを管理するシステム等、社内ITの開発・運用</dd>\n</dl><br>\n\n                \t</td>\n\t\t\t\t</tr>\n                <tr>\n                    <th class=\"koumoku\">給　与</th>\n                    <td>\n●総合職　2027年度初任給[モデル月給例]<br>\n<B>[大学院了] 247,800円</B><br>\n*基本給：220,000円<br>\n*新卒若年手当：20,000円<br>\n*皆勤/食事手当：7,800円<br>\n<br>\n<B>[大学卒] 242,800円</B><br>\n*基本給：215,000円<br>\n*新卒若年手当：20,000円<br>\n*皆勤/食事手当：7,800円<br>\n<br>\n<B>[短大/専門学校卒] 227,800円</B><br>\n*基本給：200,000円<br>\n*新卒若年手当：20,000円<br>\n*皆勤/食事手当：7,800円<br>\n\t\t\t\t\t</td>\n                </tr>\n                <tr>\n                    <th class=\"koumoku\">諸手当</th>\n                    <td>皆勤・食事・通勤・時間外・家族・資格・語学・営業・役職・技能・新卒若年手当</td>\n                </tr>\n                <tr>\n                    <th class=\"koumoku\">賞　与</th>\n                    <td>年2回（8月、12月）</td>\n                </tr>\n                <tr>\n                    <th class=\"koumoku\">昇　給</th>\n                    <td>年1回（7月）</td>\n                </tr>\n                <tr>\n                    <th class=\"koumoku\">勤務地</th>\n                    <td><dl><dt>○ 本社工場・第2工場</dt><dd>広島県福山市</dd>\n<dt>○ タイ工場〈Siam Kakihara Co.,Ltd.〉※グローバル就職希望の方</dt><dd>タイ王国チャチュンサオ県GATEWAY CITY工業団地内（バンコクから東へ110km）</dd></dl></td>\n                </tr>\n                <tr>\n                    <th class=\"koumoku\">勤務時間</th>\n                    <td>8:30～17:35</td>\n                </tr>\n                <tr>\n                    <th class=\"koumoku\">休日休暇</th>\n                    <td>週休2日制（土曜、日曜）<br>\n慶弔・年次有給<br>\n長期休暇：GW・夏季・年末年始（各8～10日間）<br>\n※年間休日120日(一斉計画付与10日含む)</td>\n                </tr>\n                <tr>\n                    <th class=\"koumoku\">保　険</th>\n                    <td>社会保険完備（健康保険、厚生年金、雇用保険、労働災害補償保険）</td>\n                </tr>\n                <tr>\n                    <th class=\"koumoku\">福利厚生</th>\n                    <td>\t\n財形貯蓄制度・退職金制度・社員研修・慶弔見舞金・育児休暇・介護休暇・マイカー通勤可・企業基金・福利厚生バックアップ制度・同好会(ゴルフ・フットサル・バドミントン・アウトドア)・社員旅行(4月)</td>\n                </tr>\n                <tr>\n                    <th class=\"koumoku\">採用人員</th>\n                    <td>\t若干名</td>\n                </tr>\n                <tr>\n                    <th class=\"koumoku\">募集学科</th>\n                    <td>\t\n【理系】機械、電気電子、化学、制御、材料、情報、経営工学、環境、数学、物理など<br>\n【文系】外国語、国際、経済、経営、商、法学、政治、教育学系など<br>\n※文系，理系共、大学院を含む。</td>\n                </tr>\n                <tr>\n                    <th class=\"koumoku\">先輩の出身校</th>\n                    <td>\t\n愛媛大学、大阪工業大学、大阪電気通信大学、岡山商科大学、岡山大学、岡山理科大学、尾道市立大学、関東学院大学、九州工業大学、九州産業大学、京都産業大学、近畿大学、公立鳥取環境大学、佐賀大学、島根大学、東海大学、鳥取大学、同志社大学、富山大学、日本大学、広島経済大学、広島工業大学、広島修道大学、広島大学、福井県立大学、福岡大学、福山大学、福山市立大学、山口大学、龍谷大学　他</td>\n                </tr>\n                <tr>\n                    <th class=\"koumoku\">連絡先</th>\n                    <td>〒721-0956 広島県福山市箕沖町99-13<br>\n採用担当/総務課　楢崎 智彦<br>\n■TEL/(084)953-8100<br>\n■E-mailアドレス saiyou-kaki27@kakihara.co.jp</td>\n                </tr>\n                <tr>\n                    <th class=\"koumoku\">Webサイト</th>\n                    <td>柿原工業オフィシャルWebサイト<br>\nhttps://www.kakihara.co.jp/</td>\n                </tr>\n                <tr>\n                    <th class=\"koumoku\">交通機関</th>\n                    <td>\t\nJR福山駅からクルマで15分、箕沖工業団地内</td>\n                </tr>\n            </table>\n            <div class=\"linkb_b inview\"><a href=\"../entry/page.html\" class=\"mov-popup\"><i class=\"fa fa-arrow-circle-right\" aria-hidden=\"true\"></i> エントリーはこちら</a></div>\n        </div>\n\t    </div>\n    </article>\n    <article class=\"bodyinlineBox clearFix\">\n\t    <div class=\"blackBox inview\">\n        <aside class=\"midashi_left\">Recruit Menu</aside>\n        <ul class=\"pmBox\">\n            <li><a href=\"../recqa/recqa.html\"><span class=\"page\">採用Q&A</span><i class=\"fa fa-play\" aria-hidden=\"true\"></i><img src=\"../recruit/image/ps01.jpg\" alt=\"ps01\" width=\"900\" height=\"608\"></a></li>\n            <li class=\"smanone\"><a href=\"#Top\"><span class=\"page\">募集要項</span><i class=\"fa fa-play\" aria-hidden=\"true\"></i><img src=\"../recruit/image/ps02.jpg\" alt=\"ps02\" width=\"900\" height=\"608\"></a></li>\n            <li><a href=\"../recstep/recstep.html\"><span class=\"page\">Entry</span><i class=\"fa fa-play\" aria-hidden=\"true\"></i><img src=\"../recruit/image/ps03.jpg\" alt=\"ps03\" width=\"900\" height=\"608\"></a></li>\n        </ul>\n\t    </div>\n    </article>\n    <div id=\"panBox\">\n        <div id=\"panList\"><img src=\"../common/image/pan_rogo.png\" alt=\"kakihara Recruiting Website\" width=\"178\" height=\"15\"> |　<a href=\"../index.html\">Home</a>　|　<a href=\"../recruit.html\">採用情報一覧</a>　|　募集要項</div>\n    </div>\n</div>\n<footer id=\"footer\">\n    <div id=\"foo