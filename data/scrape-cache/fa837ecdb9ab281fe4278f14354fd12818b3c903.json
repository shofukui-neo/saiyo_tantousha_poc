 name=\"msapplication-TileImage\" content=\"https://www.seibustl.jp/wordpress/wp-content/uploads/2022/04/cropped-favicon-270x270.png\" />\n</head>\r\n\r\n<body data-rsssl=1 class=\"wp-singular page-template-default page page-id-994 page-parent wp-theme-seibustl\" ontouchstart=\"\">\r\n\r\n    <header class=\"p-header\">\r\n        <div class=\"p-header__logo\">\r\n                            <a href=\"https://www.seibustl.jp\"><img src=\"https://www.seibustl.jp/wordpress/wp-content/uploads/2022/04/logo.png\" alt=\"西部スチール\" /></a>\r\n                    </div>\r\n        <div class=\"p-header__side\">\r\n            <nav class=\"p-header__nav\">\r\n                <ul>\r\n                    <li><a href=\"https://www.seibustl.jp/information/\">お知らせ</a></li>\r\n                    <li class=\"has-child\"><a href=\"/business/\">事業案内</a>\r\n                        <ul>\r\n                            <li><a href=\"/business/biz1/\">鉄筋工事業</a></li>\r\n                            <li><a href=\"/business/biz2/\">DBヘッド事業</a></li>\r\n                            <li><a href=\"/business/biz3/\">鋼製ラス型枠工事業</a></li>\r\n                            <li><a href=\"/business/biz4/\">戸建事業</a></li>\r\n                                                    </ul>\r\n                    </li>\r\n                    <li><a href=\"https://www.seibustl.jp/company/\">会社情報</a></li>\r\n                    <li><a href=\"https://www.seibustl.jp/recruit/\">採用情報</a></li>\r\n                </ul>\r\n            </nav>\r\n            <nav class=\"p-header__btn\">\r\n                <ul>\r\n                    <li><a href=\"https://www.seibustl.jp/contact/\" class=\"contact\">お問い合わせ</a></li>\r\n                    <li><a href=\"https://www.seibustl.jp/entry/\" class=\"entry\">採用エントリー</a></li>\r\n                </ul>\r\n            </nav>\r\n\r\n            <!-- hamburger -->\r\n            <div class=\"hamburger-demo-menubox\">\r\n                <input id=\"hamburger-demo1\" type=\"checkbox\" class=\"input-hidden\">\r\n                <label for=\"hamburger-demo1\" class=\"hamburger-demo-switch hamburger-demo-switch1 btn-trigger\" id=\"btn01\">\r\n                    <span class=\"hamburger-switch-line1-before\"></span>\r\n                    <span class=\"hamburger-switch-line1\"></span>\r\n                    <span class=\"hamburger-switch-line1-after\"></span>\r\n                </label>\r\n                <div class=\"hamburger-demo-menuwrap\">\r\n                    <dl class=\"ac\">\r\n                        <dt class=\"ac-parent-none\"><a href=\"https://www.seibustl.jp\">トップ</a></dt>\r\n                        <dt class=\"ac-parent-none\"><a href=\"https://www.seibustl.jp/information/\">お知らせ</a></dt>\r\n                        <dt class=\"ac-parent ac-parent1\">\r\n                            <a href=\"https://www.seibustl.jp/business/\">事業内容</a>\r\n                            <span>&nbsp;</span>\r\n                        </dt>\r\n                        <dd class=\"ac-child ac-child1\">\r\n                            <ul>\r\n                                <li><a href=\"https://www.seibustl.jp/business/biz1/\">鉄筋工事業</a></li>\r\n                                <li><a href=\"https://www.seibustl.jp/business/biz2/\">DBヘッド事業</a></li>\r\n                                <li><a href=\"https://www.seibustl.jp/business/biz3/\">鋼製ラス型枠工事業</a></li>\r\n                                <li><a href=\"https://www.seibustl.jp/business/biz4/\">戸建事業</a></li>\r\n                                                            </ul>\r\n                        </dd>\r\n                        <dt class=\"ac-parent-none\"><a href=\"https://www.seibustl.jp/company/\">会社情報</a></dt>\r\n                        <dt class=\"ac-parent-none\"><a href=\"https://www.seibustl.jp/recruit/\">採用情報</a></dt>\r\n                    </dl>\r\n                    <ul class=\"spcv\">\r\n                        <li><a href=\" https://www.seibustl.jp/contact/\" class=\"contact\">お問い合わせ</a></li>\r\n                        <li><a href=\"https://www.seibustl.jp/entry/\" class=\"entry\">採用エントリー</a></li>\r\n                    </ul>\r\n                </div>\r\n                <div class=\"hamburger-demo-cover\"></div>\r\n            </div>\r\n            <!-- hamburger -->\r\n\r\n        </div>\r\n    </header>\r\n    <!-- ---------- //header ---------- -->\r\n\r\n    <div class=\"l-wrapper\">\r\n\r\n                    <div class=\"c-bread pc-only\" vocab=\"http://schema.org/\" typeof=\"BreadcrumbList\">\r\n                <!-- Breadcrumb NavXT 7.0.2 -->\n<span property=\"itemListElement\" typeof=\"ListItem\"><a property=\"item\" typeof=\"WebPage\" title=\"Go to 鉄筋工事・ラス型枠工事・鋼材販売・DBヘッド定着工法　西部スチール株式会社.\" href=\"https://www.seibustl.jp\" class=\"home\" ><span property=\"name\">TOP</span></a><meta property=\"position\" content=\"1\"></span>　&gt;　<span property=\"itemListElement\" typeof=\"ListItem\"><span property=\"name\" class=\"post post-page current-item\">採用エントリー</span><meta property=\"url\" content=\"https://www.seibustl.jp/entry/\"><meta property=\"position\" content=\"2\"></span>            </div>\r\n        \r\n        <main class=\"l-main\">\n            <div class=\"l-hero\">\r\n    <div class=\"p-hero-entry\">\r\n        <h1 class=\"c-page-header\">採用エントリー</h1>\r\n    </div>\r\n</div>\r\n\r\n<section class=\"p-contact wow fade-in-bottom\">\r\n    <div class=\"p-contact__intro\">\r\n        <p>\r\n            下記の入力フォームにご記入の上、<br class=\"sp-only\">「確認」ボタンをクリックして、確認画面へお進みください。<br>\r\n            ※半角カタカナや機種依存文字は使用しないでください。\r\n        </p>\r\n    </div>\r\n    <div id=\"mw_wp_form_mw-wp-form-993\" class=\"mw_wp_form mw_wp_form_input  \">\n\t\t\t\t\t<form method=\"post\" action=\"\" enctype=\"multipart/form-data\"><div class=\"p-form\">\r\n<table class=\"p-form__tbl\">\r\n<tbody>\r\n\r\n<tr>\r\n<th>採用種別<span>必須</span></th>\r\n<td>\t<span class=\"mwform-radio-field horizontal-item\">\n\t\t<label >\n\t\t\t<input type=\"radio\" name=\"your-type\" value=\"新卒\" />\n\t\t\t<span class=\"mwform-radio-field-text\">新卒</span>\n\t\t</label>\n\t</span>\n\t<span class=\"mwform-radio-field horizontal-item\">\n\t\t<label >\n\t\t\t<input type=\"radio\" name=\"your-type\" value=\"中途\" />\n\t\t\t<span class=\"mwform-radio-field-text\">中途</span>\n\t\t</label>\n\t</span>\n\n<input type=\"hidden\" name=\"__children[your-type][]\" value=\"{&quot;\\u65b0\\u5352&quot;:&quot;\\u65b0\\u5352&quot;,&quot;\\u4e2d\\u9014&quot;:&quot;\\u4e2d\\u9014&quot;}\" />\n</td>\r\n</tr>\r\n\r\n<tr>\r\n<th>第1希望職種<span>必須</span></th>\r\n<td>\r\n<div class=\"selectWrap\">\r\n\n<select name=\"your-hope\" class=\"select\">\n\t\t\t<option value=\"\" selected='selected'>\n\t\t\t希望職種をお選びください\t\t</option>\n\t\t\t<option value=\"鉄筋施工管理\" >\n\t\t\t鉄筋施工管理\t\t</option>\n\t</select>\n\r\n</div>\r\n</td>\r\n</tr>\r\n            \r\n<tr>\r\n<th>お名前<span>必須</span></th>\r\n<td>\r\n<div class=\"col-2\">\r\n<div>\n<input type=\"text\" name=\"your-name1\" size=\"60\" value=\"\" placeholder=\"姓\" />\n</div>\r\n<div>\n<input type=\"text\" name=\"your-name2\" size=\"60\" value=\"\" placeholder=\"名\" />\n</div>\r\n</div>\r\n</td>\r\n</tr>\r\n\r\n<tr>\r\n<th>お名前（フリガナ）<span>必須</span></th>\r\n<td>\r\n<div class=\"col-2\">\r\n<div>\n<input type=\"text\" name=\"your-kana1\" size=\"60\" value=\"\" placeholder=\"セイ\" />\n</div>\r\n<div>\n<input type=\"text\" name=\"your-kana2\" size=\"60\" value=\"\" placeholder=\"メイ\" />\n</div>\r\n</div>\r\n</td>\r\n</tr>\r\n\r\n<tr>\r\n<th>メールアドレス<span>必須</span></th>\r\n<td>\n<input type=\"email\" name=\"your-email\" size=\"60\" value=\"\" placeholder=\"メールアドレス\" data-conv-half-alphanumeric=\"true\"/>\n</td>\r\n</tr>\r\n\r\n<tr>\r\n<th>電話番号<span>必須</span></th>\r\n<td>\n<input type=\"text\" name=\"your-phone\" size=\"60\" value=\"\" placeholder=\"電話番号\" />\n</td>\r\n</tr>\r\n\r\n<tr>\r\n<th>住所</th>\r\n<td>\r\n\n<input type=\"text\" name=\"your-zip\" class=\"small\" size=\"60\" value=\"\" placeholder=\"〒\" />\n\r\n\n<input type=\"text\" name=\"your-address1\" size=\"60\" value=\"\" placeholder=\"都道府県・市区町村名・番地\" />\n\r\n\n<input type=\"text\" name=\"your-address2\" size=\"60\" value=\"\" placeholder=\"その他マンション名等\" />\n\r\n</td>\r\n</tr>\r\n\r\n<tr>\r\n<th>学校名<span>必須</span><small>（最終学歴・卒業予定）</small></th>\r\n<td>\r\n\n<input type=\"text\" name=\"your-school\" size=\"60\" value=\"\" placeholder=\"学校名\" />\n\r\n\n<input type=\"text\" name=\"your-class\" size=\"60\" value=\"\" placeholder=\"学部・学科\" />\n\r\n</td>\r\n</tr>\r\n\r\n<tr>\r\n<th>現在お勤めの会社<small>（離職中の方は前職の会社）</small></th>\r\n<td>\n<input type=\"text\" name=\"your-company\" size=\"60\" value=\"\" placeholder=\"会社名\" />\n</td>\r\n</tr>\r\n\r\n<tr>\r\n<th>資格などの<br>アピールポイント<span>必須</span></th>\r\n<td>\n<textarea name=\"your-appeal\" cols=\"50\" rows=\"5\" ></textarea>\n</td>\r\n</tr>\r\n\r\n</tbody>\r\n</table>\r\n\r\n<div class=\"p-form__privacy\">\r\n<div class=\"p-form__privacy-inner\">\r\n<div class=\"p-privacy__small \">\r\n  <h2>個人情報保護方針</h2>\r\n  <p>西部スチール株式会社（以下「当社」といいます）は、以下のとおり個人情報保護方針を定め、個人情報保護の仕組みを構築し、全従業員に個人情報保護の重要性の認識と取組みを徹底させることにより、個人情報の保護を推進致します。</p>\r\n  <ol>\r\n    <li>\r\n      <span>個人情報の管理</span>\r\n      当社は、お客さまの個人情報を正確かつ最新の状態に保ち、個人情報への不正アクセス・紛失・破損・改ざん・漏洩などを防止するため、セキュリティシステムの維持・管理体制の整備・社員教育の徹底等の必要な措置を講じ、安全対策を実施し個人情報の厳重な管理を行ないます。\r\n    </li>\r\n    <li>\r\n      <span>個人情報の利用目的</span>\r\n      お客さまからお預かりした個人情報は、当社からのご連絡や業務のご案内やご質問に対する回答として、電子メールや資料のご送付に利用いたします。\r\n    </li>\r\n    <li>\r\n      <span>個人情報の第三者への開示・提供の禁止</span>\r\n      当社は、お客さまよりお預かりした個人情報を適切に管理し、次のいずれかに該当する場合を除き、個人情報を第三者に開示いたしません。 \r\n      <ul class=\"c-list\">\r\n        <li>お客さまの同意がある場合</li>\r\n        <li class=\"u-mt0\">お客さまが希望されるサービスを行なうために当社が業務を委託する業者に対して開示する場合</li>\r\n        <li class=\"u-mt0\">法令に基づき開示することが必要である場合</li>\r\n      </ul>\r\n    </li>\r\n    <li>\r\n      <span>個人情報の安全対策</span>\r\n      当社は、個人情報の正確性及び安全性確保のために、セキュリティに万全の対策を講じています。\r\n    </li>\r\n    <li>\r\n      <span>ご本人の照会</span>\r\n      お客さまがご本人の個人情報の照会・修正・削除などをご希望される場合には、ご本人であることを確認の上、対応させていただきます。\r\n    </li>\r\n    <li>\r\n      <span>法令、規範の遵守と見直し</span>\r\n      当社は、保有する個人情報に関して適用される日本の法令、その他規範を遵守するとともに、本ポリシーの内容を適宜見直し、その改善に努めます。\r\n    </li>\r\n  </ol>\r\n  <p>\r\n    お問い合せ<br>\r\n    当社の個人情報の取扱に関するお問い合せは下記までご連絡ください。<br>\r\n    西部スチール株式会社<br>\r\n    〒356- 0045　埼玉県ふじみ野市鶴ヶ岡3-2-39<br>\r\n    TEL：<a href=\"tel:0492671181\" class=\"tel-link\">049-267-1181</a>\r\n  </p>\r\n</div>\r\n</div>\r\n</div>\r\n\r\n<div class=\"agree\">\r\n<div>「個人情報保護方針」について</div>\r\n<div>\n\t<span class=\"mwform-checkbox-field horizontal-item\">\n\t\t<label >\n\t\t\t<input type=\"checkbox\" name=\"your-agree[data][]\" value=\"同意します\" />\n\t\t\t<span class=\"mwform-checkbox-field-text\">同意します</span>\n\t\t</label>\n\t</span>\n\n<input type=\"hidden\" name=\"your-agree[separator]\" value=\",\" />\n\n<input type=\"hidden\" name=\"__children[your-agree][]\" value=\"{&quot;\\u540c\\u610f\\u3057\\u307e\\u3059&quot;:&quot;\\u540c\\u610f\\u3057\\u307e\\u3059&quot;}\" />\n</div>\r\n</div>\r\n<div class=\"submit\">\n<input type=\"submit\" name=\"submitConfirm\" value=\"確認\" />\n</div>\r\n\r\n</div><input type=\"hidden\" name=\"mw-wp-form-form-id\" value=\"993\" /><input type=\"hidden\" name=\"mw_wp_form_token\" value=\"0d6ee45d16da5d654442e5c0377dc169cf94ff29970cf0fca2a7fd95daa1b2ab\" /></form>\n\t\t\t\t<!-- end .mw_wp_form --></div>\r\n</section>    \n</main>\r\n<!-- ---------- //.l-main ---------- -->\r\n\r\n</div>\r\n<!-- ---------- //.l-wrapper ---------- -->\r\n\r\n\r\n<footer class=\"l-footer\">\r\n    <div class=\"p-footer\">\r\n        <div class=\"p-footer__inner\">\r\n            <div class=\"p-footer__company\">\r\n                <h2>⻄部スチール 株式会社</h2>\r\n                <p>\r\n                    本社<br>\r\n                    〒356-0045 埼⽟県ふじみ野市鶴ヶ岡3-2-39<br>\r\n                    電話:049-267-1181　FAX:049-267-1180\r\n                </p>\r\n                            </div>\r\n            <div class=\"p-footer__sitemap\">\r\n                <nav>\r\n                    <ul class=\"p-footer__nav\">\r\