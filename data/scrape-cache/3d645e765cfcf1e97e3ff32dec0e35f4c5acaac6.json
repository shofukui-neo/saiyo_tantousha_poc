a></li>\n\t\t\t</ul><!-- / .first -->\n\t\t\t<p class=\"pc\"><a href=\"./contact/\"><img src=\"./common/footnav_contact.png\"></a></p>\n\t\t</nav>\n\t</div><!-- / .inner -->\n\t<p class=\"copyright\">Copyright TAIYO KOGYO Co.Ltd., All rights reserved.</p>\n</footer>\n<div id=\"topagetop\">PAGE TOP</div>\n</body>\n</html>\n","finalUrl":"https://www.the-taiyo.com/","rendered":false,"_cachedAt":"2026-06-22T20:35:25.921Z"}