position\" content=\"3\" />\r\n            </li>\r\n\t\t</ol>\r\n\t<!-- .nav-breadcrumbs --></div>\r\n\r\n\t<div class=\"l-maincts__inner\">\r\n\t\t<!-- contents begin -->\r\n\t\t<h1 class=\"c-ttl_01\">\r\n\t\t\t<span>カムバック制度</span>\r\n\t\t</h1>\r\n        <div class=\"p-text_lead\">\r\n\t\t\t<p>当行では、結婚・出産・育児・介護・傷病・転職・配偶者の転勤などの理由で退職された方を応援するカムバック制度を導入しました。長年培った経験・スキルを活かし、再度当行で活躍したいとお考えの方からのご応募をお待ちしています。</p>\r\n\t\t</div>\r\n        <section>\r\n            <h2 class=\"c-ttl_02\">\r\n\t            <span>応募資格</span>\r\n            </h2>\r\n            <ul class=\"c-list_dot\">\r\n                <li>\r\n                    <div>原則3年以上の当行での勤務経験があり、結婚・出産・育児・介護・傷病・転職・配偶者の転勤などの理由により退職された方</div>\r\n                </li>\r\n                <li>\r\n                    <div>原則証券外務員資格（会員一種）をお持ちの方</div>\r\n                </li>\r\n            </ul>\r\n        </section>\r\n        \r\n        <section>\r\n            <h2 class=\"c-ttl_02\">\r\n\t            <span>募集職種</span>\r\n            </h2>\r\n            <p>銀行業務全般</p>\r\n        </section>\r\n        \r\n        <section>\r\n            <h2 class=\"c-ttl_02\">\r\n\t            <span>雇用形態</span>\r\n            </h2>\r\n            <h5 class=\"c-ttl_05\">\r\n\t\t\t    <span>＜退職後原則5年以内＞</span>\r\n            </h5>\r\n            <div class=\"u-mt-xs\">\r\n                <ul class=\"c-list_dot\">\r\n                    <li>\r\n                        <div>行員として採用</div>\r\n                    </li>\r\n                    <li>\r\n                        <div>資格は退職時の資格、退職後のキャリア等を勘案して決定します。</div>\r\n                    </li>\r\n                </ul>\r\n            </div>\r\n            <h5 class=\"u-mt-ss c-ttl_05\">\r\n\t\t\t    <span>＜その他＞</span>\r\n            </h5>\r\n            <div class=\"u-mt-xs\">\r\n                <ul class=\"c-list_dot\">\r\n                    <li>\r\n                        <div>原則、行員として採用</div>\r\n                    </li>\r\n                    <li>\r\n                        <div>職制・資格は退職時の資格、退職後のキャリア等を勘案して決定します。</div>\r\n                    </li>\r\n                </ul>\r\n            </div>\r\n        </section>\r\n        \r\n        <section>\r\n            <h2 class=\"c-ttl_02\">\r\n\t            <span>受動喫煙防止策</span>\r\n            </h2>\r\n            <ul class=\"c-list_dot\">\r\n                <li>\r\n                    <div>敷地内全面禁煙</div>\r\n                </li>\r\n                <li>\r\n                    <div>就業時間中禁煙</div>\r\n                </li>\r\n            </ul>\r\n        </section>\r\n        \r\n        <section>\r\n            <h2 class=\"c-ttl_02\">\r\n\t            <span>応募受付</span>\r\n            </h2>\r\n            <p>随時</p>\r\n        </section>\r\n        \r\n        <section>\r\n            <h2 class=\"c-ttl_02\">\r\n\t            <span>応募方法</span>\r\n            </h2>\r\n            <p>人事部採用担当者あて連絡の上、履歴書（写真貼付）・職務経歴書を郵送してください。</p>\r\n            <p class=\"text_notice\">応募書類により取得した個人情報につきましては、採用以外の目的では一切使用いたしません。</p>\r\n            <p class=\"text_notice\">応募書類は返却いたしませんので、ご了承願います。</p>\r\n        </section>\r\n        \r\n        <section>\r\n            <h2 class=\"c-ttl_02\">\r\n\t            <span>選考方法</span>\r\n            </h2>\r\n            <ul class=\"c-list_dot\">\r\n                <li>\r\n                    <div>書類選考</div>\r\n                </li>\r\n                <li>\r\n                    <div>面接</div>\r\n                </li>\r\n            </ul>\r\n        </section>\r\n        \r\n        <section>\r\n            <h2 class=\"c-ttl_02\">\r\n\t            <span>書類郵送先</span>\r\n            </h2>\r\n            <p>〒960-8633<br>\r\n            福島県福島市大町3-25<br>\r\n            株式会社東邦銀行　人事部人事課</p>\r\n        </section>\r\n        \r\n        <div class=\"u-mt-l p-inquiry\">\r\n\t\t\t<div class=\"inner_inquiry\">\r\n\t\t\t\t<p class=\"sttl_inquiry text_alignC\">お問い合わせ先</p>\r\n\t\t\t\t<div class=\"dtl_inquiry\">\r\n\t\t\t\t\t<div class=\"number_inquiry\">\r\n\t\t\t\t\t\t<div class=\"c-telno tel_free text_alignC\">\r\n\t\t\t\t\t\t\t<i class=\"icon_xl\"><img src=\"/assets/images/common/icon-freedial.png\" alt=\"フリーダイヤル\"></i>\r\n\t\t\t\t\t\t\t<a href=\"tel:0120225373\">0120-225-373</a>\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t<p class=\"text_caution text_alignC u-mt-xs\">平日9:00〜17:00<br>（土・日・祝日は除きます）</p>\r\n\t\t\t\t\t</div>\r\n\t\t\t\t</div>\r\n\t\t\t</div>\r\n\t\t</div>\r\n\t\t<!-- / contents end -->\r\n\t</div>\r\n<!-- /.l-maincts --></div>\r\n\r\n<!-- <div class=\"area-sidemenu u-pc-v\">\r\n\t<ul class=\"list-sidemenu\">\r\n\t\t<li><a href=\"/tenpo/\">\r\n\t\t\t<div>\r\n\t\t\t\t<p class=\"img\"><img src=\"/assets/images/home/icon-atm.png\" alt=\"\"></p>\r\n\t\t\t\t<p class=\"text\">店舗・ATM</p>\r\n\t\t\t</div>\r\n\t\t</a></li>\r\n\t\t<li><a href=\"/fee.html\">\r\n\t\t\t<div>\r\n\t\t\t\t<p class=\"img\"><img src=\"/assets/images/home/icon-fee.png\" alt=\"\"></p>\r\n\t\t\t\t<p class=\"text\">手数料一覧</p>\r\n\t\t\t</div>\r\n\t\t</a></li>\r\n\t\t<li><a href=\"/kinri/\">\r\n\t\t\t<div>\r\n\t\t\t\t<p class=\"img\"><img src=\"/assets/images/home/icon-exchange.png\" alt=\"\"></p>\r\n\t\t\t\t<p class=\"text\">金利・<br>為替相場</p>\r\n\t\t\t</div>\r\n\t\t</a></li>\r\n\t\t<li><a href=\"/jump/faq01.html\">\r\n\t\t\t<div>\r\n\t\t\t\t<p class=\"img\"><img src=\"/assets/images/home/icon-qanda.png\" alt=\"\"></p>\r\n\t\t\t\t<p class=\"text\">よくある<br>ご質問</p>\r\n\t\t\t</div>\r\n\t\t</a></li>\r\n\t\t<li><a href=\"/contact.html\">\r\n\t\t\t<div>\r\n\t\t\t\t<p class=\"img\"><img src=\"/assets/images/home/icon-inquiry.png\" alt=\"\"></p>\r\n\t\t\t\t<p class=\"text\">お問い合わせ</p>\r\n\t\t\t</div>\r\n\t\t</a></li>\r\n\t</ul>\r\n</div> -->\r\n\r\n<footer class=\"l-footer gtmAnalytics--footer\">\r\n\t<div class=\"l-mainfooter__inner\">\r\n\t\t<div class=\"l-backtohead\" id=\"pagetop\"><p><span>トップに戻る</span></p></div>\r\n\t\t<div class=\"l-footer__nav_wrp\">\r\n\t\t\t<ul class=\"list-footernav\">\r\n\t\t\t\t<li><a href=\"/fiduciary.html\">\r\n\t\t\t\t\t<p>お客さま本位の業務運営に関する基本方針・具体的取組方針</p>\r\n\t\t\t\t</a></li>\r\n\t\t\t\