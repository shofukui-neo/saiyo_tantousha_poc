font-size--medium) !important;}.has-large-font-size{font-size: var(--wp--preset--font-size--large) !important;}.has-x-large-font-size{font-size: var(--wp--preset--font-size--x-large) !important;}\n/*# sourceURL=global-styles-inline-css */\n</style>\n\n<style id='classic-theme-styles-inline-css' type='text/css'>\n/*! This file is auto-generated */\n.wp-block-button__link{color:#fff;background-color:#32373c;border-radius:9999px;box-shadow:none;text-decoration:none;padding:calc(.667em + 2px) calc(1.333em + 2px);font-size:1.125em}.wp-block-file__button{background:#32373c;color:#fff;text-decoration:none}\n/*# sourceURL=/wp-includes/css/classic-themes.min.css */\n</style>\n<link rel='stylesheet' id='contact-form-7-css' href='https://www.ibcsoft.ne.jp/wordpress/wp-content/plugins/contact-form-7/includes/css/styles.css?ver=6.1.4' type='text/css' media='all' />\n<link rel=\"canonical\" href=\"https://www.ibcsoft.ne.jp/recruit/\" />\n</head>\n\n<body> \n\n<!-- Google Tag Manager (noscript) -->\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-MK83ZDT\"\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n<!-- End Google Tag Manager (noscript) -->\n  \n<!-- ヘッダ -->\n<div id=\"header_wrap\">\n\t<div id=\"header_wrap_innner\" class=\"crearfix\">\n\t\t<p class=\"headtitle\">ソフトウェア開発・Web制作および人材派遣に関するコンサルティング</p>\n\t\t\t   \n\t\t<p class=\"telephone\">019-653-0118</p>\n\t</div>\n</div>\n  \n<div id=\"page_pertile_wrap\">\n\t<div id=\"page_pertile_area\" class=\"crearfix\">\n\t\t<div id=\"page_logo\"><a href=\"https://www.ibcsoft.ne.jp\">\n\t\t\t<img src=\"https://www.ibcsoft.ne.jp/wordpress/wp-content/themes/softalpha/img/logo_page.png\" alt=\"株式会社IBCソフトアルファ\"></a>\n\t\t</div>\n\t\t<div id=\"page_glb_menu\">\n        \t<ul>\n\t\t\t\t<li><a href=\"/company/\">会社案内</a></li>\n\t\t\t\t<li><a href=\"/mission/\" >経営理念</a></li>\n\t\t\t\t<li><a href=\"/system/\">システム開発</a></li>\n\t\t\t\t<li><a href=\"/haken/\">人材派遣</a></li>\n\t\t\t\t<li class=\"last\"><a href=\"kikaku/\">広告・事業</a></li>\n\t\t\t</ul>\n\t\t</div>\n\t</div>\n</div><!-- コンテンツ左 -->\n\n<div id=\"cont_wrap\" >\n\t<div id=\"cont_wrap_inner\" class=\"clearfix\">\n\t\t<div id=\"cont_left\">\n\t\t\t<div class=\"cont_page\">\n\t\t\t\t\n\t\t\t\t<h2>採用情報</h2>\n\t\t\t\t\n\t\t\t\t<p class=\"recruit-p01\">IBCソフトアルファでは、システム開発を行う正社員を募集しております。<br>現在募集している職種は以下のとおりです。</p>\n\t\t\t\t\n\t\t\n\t\t<h3>正社員募集要項（盛岡市）</h3>\r\n<div class=\"scroll\">\r\n<table class=\"B30\" width=\"100%\">\r\n<tbody>\r\n<tr>\r\n<th colspan=\"2\" scope=\"row\">募集職種</th>\r\n<td>システムエンジニア・プログラマー</td>\r\n</tr>\r\n<tr>\r\n<th colspan=\"2\" scope=\"row\">仕事の内容</th>\r\n<td>当社及びお客様事業所内において下記の業務を行っていただきます。\r\n<br><br>\r\n《業務系システム開発》<br>\r\n言語：ＪＡＶＡ／Ｃ＃．ｎｅｔ／ＶＢ．ｎｅｔ／ＡＳＰ．ｎｅｔ\r\n※上記言語のいずれか１つでも開発経験があればOKです。\r\nＤＢ：Ｏｒａｃｌｅ／ＳＱＬＳｅｒｖｅｒ等\r\n<br><!--<br>\r\n《ホームページ制作技術者》<br>\r\nホームページのデザイン及び、ホームページの制作<br>\r\n使用技術：Illustrator、Photoshop、XD、Wordpress、HTML、CSSなど</td>\r\n</tr>-->\r\n<tr>\r\n<th colspan=\"2\" scope=\"row\">就業場所</th>\r\n<td>盛岡市近郊及び岩手県内全域<br>\r\n〒020-8566<br>\r\n岩手県盛岡市志家町6-1　IBC放送会館</td>\r\n</tr>\r\n<tr>\r\n<th colspan=\"2\" scope=\"row\">雇用形態・人数</th>\r\n<td>正社員　若干名</td>\r\n</tr>\r\n<tr>\r\n<th rowspan=\"4\" scope=\"row\">応募資格</th>\r\n<th scope=\"row\">学歴</th>\r\n<td>専門、短大、高専卒業以上</td>\r\n</tr>\r\n<tr>\r\n<th scope=\"row\">年齢</th>\r\n<td>５９歳以下（定年年齢が６０歳のため）</td>\r\n</tr>\r\n<tr>\r\n<th scope=\"row\">経験</th>\r\n<td>《業務系システム開発》<br>\r\nプログラミング経験１年以上<br><!--<br>《ホームページ制作技術者》<br>ホームページ制作経験あり--></td>\r\n</tr>\r\n<tr>\r\n<th scope=\"row\">資格</th>\r\n<td>普通自動車運転免許（ＡＴ限定可）</td>\r\n</tr>\r\n<tr>\r\n<th rowspan=\"2\" scope=\"row\">勤怠</th>\r\n<th scope=\"row\">勤務時間</th>\r\n<td>フレックスタイム制<br>\r\n勤務時間　　9：00～17：30<br>\r\n始業時間帯　6：30～10：00の間<br>\r\n終業時間帯 15：00～21：00の間<br>\r\nコアタイム 10：00～15：00<br>\r\n時間外あり 月平均20時間 休憩時間60分</td>\r\n</tr>\r\n<tr>\r\n<th scope=\"row\">休日</th>\r\n<td>完全週休2日制、年間休日 123日<br>\r\n有給休暇、年末年始休暇、夏季休暇</td>\r\n</tr>\r\n<tr>\r\n<th rowspan=\"3\" scope=\"row\">給与等</th>\r\n<th scope=\"row\">基本給</th>\r\n<td>175,000円〜350,000円<br>\r\n（社内規定に従い、前職及び年齢、勤務地を考慮の上、決定します）</td>\r\n</tr>\r\n<tr>\r\n<th scope=\"row\">手当</th>\r\n<td>加給手当、時間外手当、資格手当、通勤費補助等</td>\r\n</tr>\r\n<tr>\r\n<th scope=\"row\">社会保険他</th>\r\n<td>社会保険、厚生年金保険、雇用保険、労災保険</td>\r\n</tr>\r\n<tr>\r\n<th rowspan=\"5\" scope=\"row\">応募方法</th>\r\n</tr>\r\n<tr>\r\n<th scope=\"row\">応募書類</th>\r\n<td>・履歴書（写真貼付）<br>\r\n・職務経歴書<br>\r\n応募書類を事業所所在地まで郵送してください。<br>\r\n書類選考後（到着から５日以内）、追って連絡いたします。</td>\r\n</tr>\r\n<tr>\r\n<th scope=\"row\">電話番号</th>\r\n<td>019-653-0118<br>\r\n（受付時間　月～金　9:30～17:30）</td>\r\n</tr>\r\n<tr>\r\n<th scope=\"row\">郵送先住所</th>\r\n<td>〒020-8566<br>\r\n岩手県盛岡市志家町6-1　IBC放送会館</td>\r\n</tr>\r\n<tr>\r\n<th scope=\"row\">担当者</th>\r\n<td>総務部　須藤、澤田</td>\r\n</tr>\r\n<tr>\r\n<th colspan=\"2\" scope=\"row\">その他</th>\r\n<td>●見学、給与規定等<br>\r\n・会社見学可<br>\r\n・給与は社内規定に従い、前職及び年齢、勤務地を考慮の上決定します。<br>\r\n・Ｕターン、Ｉターン、Ｊターン歓迎します。<br>\r\n・週数日の在宅勤務可能。●以下の制度の認証・宣言をしております。<br>\r\n・奨学金返還支援制度<br>\r\n・イクボス宣言<br>\r\n・いわて子育てにやさしい企業等<br>\r\n・いわて女性活躍認定企業等<br>\r\n「働き方改革関連認定企業」各制度・宣言についての詳細は岩手県のホームページをご参照ください。</td>\r\n</tr>\r\n</tbody>\r\n</table>\r\n</div>\r\n<h3>正社員募集要項（東京都）</h3>\r\n<div class=\"scroll\">\r\n<table class=\"B30\" width=\"100%\">\r\n<tbody>\r\n<tr>\r\n<th colspan=\"2\" scope=\"row\">募集職種</th>\r\n<td>システムエンジニア・プログラマー</td>\r\n</tr>\r\n<tr>\r\n<th colspan=\"2\" scope=\"row\">仕事の内容</th>\r\n<td>当社及びお客様事業所内において下記の業務を行っていただきます。\r\n<br><br>\r\n《オープン系もしくはホスト系システム開発》<br>\r\n《業務系システム開発》<br>\r\n言語：ＪＡＶＡ／Ｃ＃．ｎｅｔ／ＶＢ．ｎｅｔ／ＡＳＰ．ｎｅｔ<br>\r\n※上記言語のいずれか１つでも開発経験があればOKです。<br>\r\nＤＢ：Ｏｒａｃｌｅ／ＳＱＬＳｅｒｖｅｒ等\r\n<br><br>\r\n※大規模システム開発の請負から顧客先常駐まで、幅広い働き方の相談が可能です。</td>\r\n</tr>\r\n<tr>\r\n<th colspan=\"2\" scope=\"row\">就業場所</th>\r\n<td>東京都区内<br>\r\n〒103-0001<br>\r\n東京都中央区日本橋小伝馬町14-10　アソルティ小伝馬町Liens　11F<br>\r\n（株）ＩＢＣソフトアルファ　東京支社</td>\r\n</tr>\r\n<tr>\r\n<th colspan=\"2\" scope=\"row\">雇用形態・人数</th>\r\n<td>正社員　若干名</td>\r\n</tr>\r\n<tr>\r\n<th rowspan=\"4\" scope=\"row\">応募資格</th>\r\n<th scope=\"row\">学歴</th>\r\n<td>専門、短大、高専卒業以上</td>\r\n</tr>\r\n<tr>\r\n<th scope=\"row\">年齢</th>\r\n<td>５９歳以下<br>\r\n（定年年齢が６０歳のため）</td>\r\n</tr>\r\n<tr>\r\n<th scope=\"row\">経験</th>\r\n<td>プログラミング経験１年以上</td>\r\n</tr>\r\n<tr>\r\n<th scope=\"row\">資格</th>\r\n<td>不問</td>\r\n</tr>\r\n<tr>\r\n<th rowspan=\"2\" scope=\"row\">勤怠</th>\r\n<th scope=\"row\">勤務時間</th>\r\n<td>フレックスタイム制<br>\r\n勤務時間　　9：00～17：30<br>\r\n始業時間帯　6：30～10：00の間<br>\r\n終業時間帯 15：00～21：00の間<br>\r\nコアタイム 10：00～15：00<br>\r\n時間外あり 月平均20時間 休憩時間60分</td>\r\n</tr>\r\n<tr>\r\n<th scope=\"row\">休日</th>\r\n<td>完全週休2日制、年間休日 123日<br>\r\n有給休暇、年末年始休暇、夏季休暇</td>\r\n</tr>\r\n<tr>\r\n<th rowspan=\"3\" scope=\"row\">給与等</th>\r\n<th scope=\"row\">基本給</th>\r\n<td>175,000円〜350,000円<br>\r\n（社内規定に従い、前職及び年齢、勤務地を考慮の上、決定します）</td>\r\n</tr>\r\n<tr>\r\n<th scope=\"row\">手当</th>\r\n<td>加給手当、時間外手当、資格手当、通勤費補助等<br>\r\n地域手当（東京）、社宅制度あり（住宅本人負担20％）</td>\r\n</tr>\r\n<tr>\r\n<th scope=\"row\">社会保険他</th>\r\n<td>社会保険、厚生年金保険、雇用保険、労災保険</td>\r\n</tr>\r\n<tr>\r\n<th rowspan=\"5\" scope=\"row\">応募方法</th>\r\n</tr>\r\n<tr>\r\n<th scope=\"row\">応募書類</th>\r\n<td>・履歴書（写真貼付）<br>\r\n・職務経歴書<br>\r\n応募書類を事業所所在地まで郵送してください。<br>\r\n書類選考後（到着から５日以内）、追って連絡いたします。</td>\r\n</tr>\r\n<tr>\r\n<th scope=\"row\">電話番号</th>\r\n<td>019-653-0118<br>\r\n（受付時間　月～金　9:30～17:30）</td>\r\n</tr>\r\n<tr>\r\n<th scope=\"row\">郵送先住所</th>\r\n<td>〒020-8566<br>\r\n岩手県盛岡市志家町6-1　IBC放送会館</td>\r\n</tr>\r\n<tr>\r\n<th scope=\"row\">担当者</th>\r\n<td>総務部　須藤、澤田</td>\r\n</tr>\r\n<tr>\r\n<th colspan=\"2\" scope=\"row\">その他</th>\r\n<td>・給与は社内規定に従い、前職及び年齢、勤務地を考慮の上決定します。<br>\r\n・岩手県へのＵターン、Ｉターン、Ｊターン希望への相談に応じます。<br>\r\n・正社員としてお客様の事務所へ派遣をお願いする場合がありますが、働き方については相談に応じます。<br>\r\n・住居が賃貸になる場合、社宅借上げとなり本人社宅費として２割負担いただきます。</td>\r\n</tr>\r\n</tbody>\r\n</table>\r\n</div>\n\t\t\t\t\t\t\n\t\t\n        \n      </div>\n      <!-- /notice -->\n    </div>\n    <!-- /cont_left -->\n    <!-- コンテンツ右 -->\n    <div id=\"cont_right\">\n      <a href=\"/recruit/\" onclick=\"ga('send','event','内部リンク','クリック','採用情報',{'nonInteraction':1});\"><img src=\"/wordpress/wp-content/themes/softalpha/img/bunner_recruit.png\" alt=\"盛岡市のシムテム開発　求人情報・採用情報\" /></a>\n\n<a href=\"/recruit_haken/\" class=\"haken_2022\" onclick=\"ga('send','event','内部リンク','クリック','派遣社員採用情報',{'nonInteraction':1});\"><img src=\"/wordpress/wp-content/themes/softalpha/img/bunner_haken.png\" alt=\"盛岡市の派遣社員求人情報\" /></a>\n\n<!--ADマネ-->\n<a href=\"/ad-mana/\" class=\"haken_2022\"><img src=\"https://www.ibcsoft.ne.jp/wordpress/wp-content/uploads/2026/04/ADmana_bannar.png\" alt=\"ADマネ-α\" width=\"100%\" /></a>\n\n<!--給食ナビ-->\n<a href=\"/Q-shoku/\" class=\"haken_2022\"><img src=\"https://www.ibcsoft.ne.jp/wordpress/wp-content/uploads/2025/06/Qbanner.png\" alt=\"給食ナビ-α\" width=\"100%\" /></a>\n<!--グラウンアルファ-->\n<a href=\"/graun/\" class=\"haken_2022\"><img src=\"https://www.ibcsoft.ne.jp/wordpress/wp-content/uploads/2021/05/slider.png\" alt=\"Graun-α\" width=\"100%\" /></a>\n\n\n<div class=\"banner_flex\">\n\t\n\t<div><!--いわて子育てにやさしい企業等--><a href=\"https://www.ibcsoft.ne.jp/wordpress/wp-content/uploads/2025/08/20250804154909463.pdf\" target=\"_blank\" style=\"width: unset;\"><img src=\"/wordpress/wp-content/themes/softalpha/img/side_banner_yasashii.png\"></a></div>\n\t<div><!--いわて女性活躍認定企業--><a href=\"https://www.ibcsoft.ne.jp/wordpress/wp-content/uploads/2025/07/20250710164445432.pdf\" target=\"_blank\" style=\"width: unset;\"><img src=\"/wordpress/wp-content/themes/softalpha/img/side_banner_josei.png\"></a></div>\n</div>\n\n<div class=\"banner_flex\">\n\t<div><!--いわて健康経営宣言事業所--><img src=\"/wordpress/wp-content/uploads/2023/07/banner_kenkou.png\"></div>\n\t<div><!--奨学金返還支援--><img src=\"/wordpress/wp-content/uploads/2026/04/syougakukinn_sien_R8.png\"></div>\n</div>\n<!--<div class=\"side_kenkou\">\n\t<img src=\"/wordpress/wp-content/themes/softalpha/img/side_banner_kenkou.svg\">\n</div>-->\n\n<div class=\"isms\">\n\t<!--ISMS--><img src=\"/wordpress/wp-content/uploads/2019/04/new_isms_logo.png\" width=\"250\"/><br>\n\t<!--Xserver--><img src=\"/wordpress/wp-content/uploads/2023/11/xserver_partnerbadge.png\" width=\"250\"><br>\n</d