scrollTop: jQuery('#news').offset().top\n                }, 500);\n            }\n        }\n    });\n\n</script>\n<script>\n    window.addEventListener('load', function() {\n        setTimeout(function() {\n            document.querySelector('.act01').classList.add('first');\n        }, 500);\n        setTimeout(function() {\n            document.querySelector('.act02').classList.add('first');\n        }, 1000);\n        setTimeout(function() {\n            document.querySelector('.act03').classList.add('first');\n        }, 1500);\n        setTimeout(function() {\n            document.querySelector('.act04').classList.add('first');\n        }, 2000);\n    });\n</script>\n<script>\n    // ヘッダーの高さを取得し、メインコンテンツに適用する処理\n    function adjustContentPosition() {\n        // 実際に高さを持ち、固定されている要素のクラスを使用して高さを取得\n        const headerHeight = $('.header_square.fixed').outerHeight();\n\n        // ヘッダー直後のコンテンツ要素にマージンを設定\n        // index.php の構造: <body> の子要素で <header> の次に来る最初の <div>\n        $('body > header + div').css('margin-top', headerHeight + 'px');\n\n        // デバッグログ\n        console.log('SUCCESS: Header height applied.');\n        console.log('Header Height:', headerHeight + 'px');\n        console.log('Target Element:', $('body > header + div')[0]);\n    }\n\n    // ページ読み込み完了時（load）とリサイズ時に実行\n    $(window).on('load resize', function() {\n        adjustContentPosition();\n    });\n    // DOM準備完了時にも実行\n    $(document).ready(function() {\n        adjustContentPosition();\n    });\n</script>\n</body>\n\n</html>","finalUrl":"https://www.ryukei.okinawa/","rendered":false,"_cachedAt":"2026-06-17T23:17:18.181Z"}