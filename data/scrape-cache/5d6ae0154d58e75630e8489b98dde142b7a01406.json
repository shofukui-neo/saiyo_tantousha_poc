{"url":"https://www.shikokupak.co.jp/recruit/","html":"<!doctype html>\r\n<html lang=\"ja\">\r\n<head>\r\n<!-- Google tag (gtag.js) -->\r\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-PS3X62D6XF\"></script>\r\n<script>\r\n  window.dataLayer = window.dataLayer || [];\r\n  function gtag(){dataLayer.push(arguments);}\r\n  gtag('js', new Date());\r\n\r\n  gtag('config', 'G-PS3X62D6XF');\r\n</script>\r\n\r\n<meta charset=\"UTF-8\">\r\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\r\n<title>採用情報 | 四国パック株式会社</title>\r\n<meta name=\"description\" content=\"スーパーやコンビニでおなじみのヨーグルトやアイスクリームなどの紙容器は、私たちが手がけています。私たちと一緒に紙容器を通して多くの人々の食生活を彩ってみませんか。\">\r\n<meta name=\"keywords\" content=\"\">\r\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\r\n<meta name=\"format-detection\" content=\"telephone=no\">\r\n\r\n<meta property=\"og:url\" content=\"https://www.shikokupak.co.jp/recruit/\">\r\n<meta property=\"og:type\" content=\"article\">\r\n<meta property=\"og:title\" content=\"採用情報 | 四国パック株式会社\">\r\n<meta property=\"og:description\" content=\"スーパーやコンビニでおなじみのヨーグルトやアイスクリームなどの紙容器は、私たちが手がけています。私たちと一緒に紙容器を通して多くの人々の食生活を彩ってみませんか。\">\r\n<meta property=\"og:site_name\" content=\"四国パック株式会社\">\r\n<meta property=\"og:image\" content=\"https://www.shikokupak.co.jp/images/og.png\">\r\n\r\n<!-- サイト共通CSS読み込み -->\r\n<link rel=\"stylesheet\" href=\"/common/css/style.css\">\r\n<!-- サイト共通JS読み込み -->\r\n<script src=\"/common/js/jquery.min.js\"></script>\r\n<script src=\"/common/js/jquery.easing.js\"></script>\r\n<script src=\"/common/js/animation.min.js\"></script>\r\n<script src=\"/common/js/contents_common.js\"></script>\r\n<script src=\"/common/js/slick/slick.min.js\"></script>\r\n<script src=\"/common/js/common.js\"></script>\r\n\r\n\r\n<!-- ページ固有CSS読み込み -->\r\n<link rel=\"stylesheet\" href=\"/recruit/css/unique.css\">\r\n</head>\r\n<body>\r\n  <div class=\"l-wrap\">\r\n    <header class=\"l-header\"><div class=\"l-header__inr\">\r\n  <h1 class=\"l-header__logo\"><a href=\"/\"><img src=\"/common/images/logo.svg\" alt=\"四国パック株式会社\"></a></h1>\r\n  <nav class=\"l-header__nav\" data-hd-cts>\r\n    <ul class=\"l-header__navList\">\r\n      <li class=\"l-header__navItem\"><a href=\"/about/\">私たちの強み</a></li>\r\n      <li class=\"l-header__navItem\"><a href=\"/product/\">製品情報</a></li>\r\n      <li class=\"l-header__navItem\"><a href=\"/company/\">企業情報</a></li>\r\n      <li class=\"l-header__navItem\"><a href=\"/recruit/\">採用情報</a></li>\r\n    </ul>\r\n    <div class=\"l-header__contact\"><a href=\"/contact/\">お問い合わせ</a></div>\r\n  </nav>\r\n  <div class=\"l-header__btn sp\" data-hd-btn>\r\n    <div class=\"l-header__btnBar\"></div>\r\n    <p class=\"l-header__btnTxt\">MENU</p>\r\n  </div>\r\n  <div class=\"l-header__ol sp\"></div>\r\n</div></header>\r\n\r\n\r\n    <main class=\"l-main\">\r\n\r\n      <div class=\"c-idxTtl l-idt\"><div class=\"l-wid\">\r\n        <div class=\"c-idxTtl__txt js-fadeIn\">\r\n          <h1 class=\"jp\">採用情報</h1>\r\n          <p class=\"en\">Recruit</p>\r\n        </div>\r\n        <div class=\"c-idxTtl__link js-fadeIn\">\r\n          <div class=\"c-anchor\">\r\n            <p class=\"c-anchor__ttl\">Contents</p>\r\n            <ul class=\"c-anchor__list\">\r\n              <li class=\"c-anchor__item\"><a href=\"#recruit01\">新卒採用</a></li>\r\n              <li class=\"c-anchor__item\"><a href=\"#recruit02\">中途採用募集要項</a></li>\r\n            </ul>\r\n          </div>\r\n        </div>\r\n      </div></div>\r\n\r\n      <div class=\"c-fvSlide js-fadeIn\" data-js-auto-slider>\r\n        <div class=\"c-fvSlide__list\" data-js-slide data-auto-speed-ratio=\"0.6\">\r\n          <div class=\"c-fvSlide__item\"><img src=\"/recruit/images/fv_slider_img01.jpg\" alt=\"\"></div>\r\n          <div class=\"c-fvSlide__item --size-l\"><img src=\"/recruit/images/fv_slider_img02.jpg\" alt=\"\"></div>\r\n          <div class=\"c-fvSlide__item\"><img src=\"/recruit/images/fv_slider_img03.jpg\" alt=\"\"></div>\r\n          <div class=\"c-fvSlide__item\"><img src=\"/recruit/images/fv_slider_img04.jpg\" alt=\"\"></div>\r\n          <div class=\"c-fvSlide__item --size-l\"><img src=\"/recruit/images/fv_slider_img05.jpg\" alt=\"\"></div>\r\n        </div>\r\n      </div>\r\n\r\n      <section class=\"u-section01 l-section l-idt\"><div class=\"l-wid\">\r\n        <div class=\"c-ttlHead js-fadeIn\">\r\n          <div class=\"m-ttl\">\r\n            <p class=\"m-ttl__en\">Belief</p>\r\n            <h2 class=\"m-ttl__jp\">紙容器で食生活を彩る</h2>\r\n          </div>\r\n          <p class=\"m-txt__l\">スーパーやコンビニでおなじみのヨーグルトやアイスクリームなどの紙容器は、私たちが手がけています。私たちと一緒に紙容器を通して多くの人々の食生活を彩ってみませんか。</p>\r\n        </div>\r\n      </div></section>\r\n\r\n      <section id=\"recruit01\" class=\"u-section02 l-section l-idt\"><div class=\"l-wid\">\r\n        <h2 class=\"m-ttl05 js-faeIn\">新卒採用</h2>\r\n\r\n        <div class=\"u-imgGrid --img-r js-fadeIn\">\r\n          <div class=\"u-imgGrid__img\">\r\n            <picture>\r\n              <source srcset=\"/recruit/images/interview_img01.jpg\" media=\"(max-width: 768px)\">\r\n              <img src=\"/recruit/images/interview_img01.jpg\" alt=\"\">\r\n            </picture>\r\n          </div>\r\n          <div class=\"u-imgGrid__txt\">\r\n            <div class=\"m-ttl\">\r\n              <p class=\"m-ttl__en\"><span class=\"u-sub\">Interview <span class=\"bar\"></span> 01</span></p>\r\n              <h3 class=\"m-ttl__jp\">より良い条件設定ができたときは<br class=\"sp\">とても達成感があります。</h3>\r\n              <p class=\"m-txt__m\">四国パック本社工場で生産している紙容器の品質が確かなものであるか検査や検証を行っています。寸法や外観などの規格検査はもちろん、特に紙と紙の接着部分など内容物の漏れにつながる箇所は細心の注意を払って検査をしています。他にも生産ライン上の外観検査機の調整や、実際の生産工程でいつもと違う点がないか確認するため工場内の巡回なども行っています。</p>\r\n              <p class=\"u-label\">包装資材事業  品質管理 / 2020年新卒入社</p>\r\n            </div>\r\n          </div>\r\n        </div>\r\n        <div class=\"u-imgGrid --img-l js-fadeIn\">\r\n          <div class=\"u-imgGrid__img\">\r\n            <picture>\r\n              <source srcset=\"/recruit/images/interview_img02.jpg\" media=\"(max-width: 768px)\">\r\n              <img src=\"/recruit/images/interview_img02.jpg\" alt=\"\">\r\n            </picture>\r\n          </div>\r\n          <div class=\"u-imgGrid__txt\">\r\n            <div class=\"m-ttl\">\r\n              <p class=\"m-ttl__en\"><span class=\"u-sub\">Interview <span class=\"bar\"></span> 02</span></p>\r\n              <h3 class=\"m-ttl__jp\">スーパーやコンビニに並んでいて、<br>お客様が購入している光景を見ると、<br class=\"pc\">とても嬉しいです。</h3>\r\n              <p class=\"m-txt__m\">自分が製造現場で携わった製品がスーパーやコンビニに並んでいて、お客様が購入している光景を見ると、とても嬉しいです。日常業務において無心になって黙々と製品を作ることは、とても楽しくやりがいを感じています。</p>\r\n              <p class=\"u-label\">包装資材事業  生産 /  2017年新卒入社</p>\r\n            </div>\r\n          </div>\r\n        </div>\r\n        <div class=\"u-panel l-grid --panel-3-pc js-fadeIn\">\r\n          <div class=\"u-panel__item\">\r\n            <p class=\"u-panel__ttl\">社員の声</p>\r\n            <p class=\"m-txt__m\">仕事の魅力ややりがいについて、<br>活躍する社員へインタビューしました。</p>\r\n            <div class=\"u-panel__btn\"><a href=\"https://www.shikoku-kakoki.co.jp/recruiting/persons/\" target=\"_blank\" class=\"m-btn\">社員の声</a></div>\r\n          </div>\r\n          <div class=\"u-panel__item\">\r\n            <p class=\"u-panel__ttl\">募集要項</p>\r\n            <p class=\"m-txt__m\">募集対象・選考方法・採用後の<br class=\"sp\">待遇などを<br class=\"pc\">ご案内します。</p>\r\n            <div class=\"u-panel__btn\"><a href=\"https://www.shikoku-kakoki.co.jp/recruiting/recruit/requirement/?company=company_logo04\" target=\"_blank\" class=\"m-btn\">募集要項</a></div>\r\n          </div>\r\n          <div class=\"u-panel__item\">\r\n            <p class=\"u-panel__ttl\">採用エントリー</p>\r\n            <p class=\"m-txt__m\">採用エントリー、会社説明会予約は<br>こちらから受け付けております。</p>\r\n            <div class=\"u-panel__btn\"><a href=\"https://job.mynavi.jp/26/pc/search/corp202188/outline.html\" target=\"_blank\" class=\"m-btn\">エントリー</a></div>\r\n          </div>\r\n        </div>\r\n      </div></section>\r\n\r\n      <div class=\"u-bgBar\"></div>\r\n      \r\n      <section id=\"recruit02\" class=\"u-section03 l-section l-idt\"><div class=\"l-wid\">\r\n        <div class=\"m-ttlBar js-fadeIn\">\r\n          <h2 class=\"m-ttl05\">中途採用募集要項</h2>\r\n        </div>\r\n        <div class=\"u-info js-fadeIn\">\r\n          <dl class=\"u-info__item\">\r\n            <dt>募集職種</dt>\r\n            <dd>包材技術系（生産、装置技術、品質管理）、管理系</dd>\r\n          </dl>\r\n          <dl class=\"u-info__item\">\r\n            <dt>雇用形態</dt>\r\n            <dd>\r\n              <p>嘱託社員（1年間）</p>\r\n              <p>※1年間の嘱託社員の後、正社員登用予定</p>\r\n            </dd>\r\n          </dl>\r\n          <dl class=\"u-info__item\">\r\n            <dt>勤務地</dt>\r\n            <dd>\r\n              <p>静岡、滋賀</p>\r\n              <p>勤務地の詳細はこちらからご確認ください。</p>\r\n              <p><a href=\"https://www.shikoku-kakoki.co.jp/recruiting/job/area/\" target=\"_blank\">https://www.shikoku-kakoki.co.jp/recruiting/job/area/</a></p>\r\n            </dd>\r\n          </dl>\r\n          <dl class=\"u-info__item\">\r\n            <dt>勤務時間</dt>\r\n            <dd>\r\n              <p>8：00～17：00（実働8時間）</p>\r\n              <p>※製造課・品質管理課は交替勤務有り</p>\r\n            </dd>\r\n          </dl>\r\n          <dl class=\"u-info__item\">\r\n            <dt>給与</dt>\r\n            <dd>\r\n              <p>基本給：180,000円～330,000円</p>\r\n              <p>※経験・年齢を考慮の上、当社規定による</p>\r\n            </dd>\r\n          </dl>\r\n          <dl class=\"u-info__item\">\r\n            <dt>諸手当</dt>\r\n            <dd>\r\n              <ul>\r\n                <li>家族手当</li>\r\n                <li>通勤手当</li>\r\n                <li>時間外勤務手当</li>\r\n                <li>交替手当</li>\r\n                <li>他</li>\r\n              </ul>\r\n            </dd>\r\n          </dl>\r\n          <dl class=\"u-info__item\">\r\n            <dt>昇給</dt>\r\n            <dd>年1回（4月）</dd>\r\n          </dl>\r\n          <dl class=\"u-info__item\">\r\n            <dt>賞与</dt>\r\n            <dd>年2回（6月・12月）</dd>\r\n          </dl>\r\n          <dl class=\"u-info__item\">\r\n            <dt>休日休暇</dt>\r\n            <dd>\r\n              <ul>\r\n                <li>年間124日</li>\r\n                <li>年次有給休暇</li>\r\n                <li>慶弔特別休暇</li>\r\n                <li>リフレッシュ休暇</li>\r\n                <li>他</li>\r\n              </ul>\r\n            </dd>\r\n          </dl>\r\n          <dl class=\"u-info__item\">\r\n            <dt>福利厚生</dt>\r\n            <dd>\r\n              <ul>\r\n                <li>各種社会保険</li>\r\n                <li>確定給付企業年金</li>\r\n                <li>確定拠出年金制度</li>\r\n                <li>慶弔金制度</li>\r\n                <li>社員表彰制度</li>\r\n                <li>食事補助制度</li>\r\n                <li>退職金制度</li>\r\n                <li>育児・介護休業制度</li>\r\n                <li>他</li>\r\n              </ul>\r\n            </dd>\r\n          </dl>\r\n          <dl class=\"u-info__item\">\r\n            <dt>選考方法</dt>\r\n            <dd>\r\n              <ul>\r\n                <li>書類選考</li>\r\n                <li>適性検査</li>\r\n                <li>面接（1～2回）</li>\r\n              </ul>\r\n            </dd>\r\n          </dl>\r\n        </div>\r\n        <div class=\"u-box\">\r\n          <div class=\"u-box__txt\">\r\n            <p class=\"u-box__ttl\">中途採用エントリー</p>\r\n            <p class=\"m-txt__m\">中途採用ご希望の方はフォームより<br class=\"sp\">お問い合わせください。</p>\r\n          </div>\r\n          <div class=\"u-box__btn\"><a href=\"/contact/\" class=\"m-btn\">中途採用エントリー</a></div>\r\n        </div>\r\n      </div></section>\r\n      \r\n      <div class=\"c-breadcrumb l-idt\"><div class=\"l-wid\">\r\n        <ul class=\"c-breadcrumb__list\">\r\n          <li class=\"c-breadcrumb__item\"><a href=\"/\">トップ</a></li>\r\n          <li class=\"c-breadcrumb__item\">採用情報</li>\r\n        </ul>\r\n      </div></div>\r\n\r\n    </main>\r\n\r\n    <div class=\"l-footer__contact\"><div class=\"l-footer__contactInr\">\r\n  <div class=\"l-footer__body\">\r\n    <h2 class=\"l-footer__ttl\"><span class=\"en\"