<li class=\"l-footer__navGroupItem\"><a href=\"https://www.ueraku.co.jp/\" target=\"_blank\">植田酪農機工業株式会社</a></li>\r\n            <li class=\"l-footer__navGroupItem\"><a href=\"https://www.central-mc.co.jp/\" target=\"_blank\">セントラル機械商事株式会社</a></li>\r\n            <li class=\"l-footer__navGroupItem\"><a href=\"https://www.toyo-science.co.jp/\" target=\"_blank\">東洋科学株式会社</a></li>\r\n            <li class=\"l-footer__navGroupItem\"><a href=\"https://www.shikokusangyo.com/\" target=\"_blank\">四国産業株式会社</a></li>\r\n            <li class=\"l-footer__navGroupItem\"><a href=\"https://www.shikoku.com.cn/index.aspx\" target=\"_blank\">上海四国食品包装机械有限公司</a></li>\r\n            <li class=\"l-footer__navGroupItem\">Shikoku Kakoki Europe GmbH</li>\r\n            <li class=\"l-footer__navGroupItem\">Shikoku Kakoki (Thaland)Co.,Ltd.</li>\r\n            <li class=\"l-footer__navGroupItem\">Shikoku Kakoki America,Inc.</li>\r\n          </ul>\r\n        </div>\r\n        <div class=\"l-footer__navCopyright\">\r\n          <ul class=\"l-footer__navOther\">\r\n            <li class=\"l-footer__navOtherItem\"><a href=\"/contact/\">お問い合わせ</a></li>\r\n            <li class=\"l-footer__navOtherItem\"><a href=\"/privacy/\">プライバシーポリシー</a></li>\r\n          </ul>\r\n          <p class=\"l-footer__navCopyrightTxt\">© SHIKOKU PAK CO., LTD. All Rights Reserved.</p>\r\n          <p class=\"l-footer__navLogo sp\"><a href=\"/\"><img src=\"/common/images/logo.svg\" alt=\"四国パック株式会社\"></a></p>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div></div>\r\n</div></footer>\r\n\r\n  </div>\r\n</body>\r\n</html>\r\n","finalUrl":"https://www.shikokupak.co.jp/recruit/","rendered":false,"_cachedAt":"2026-06-22T19:52:21.040Z"}