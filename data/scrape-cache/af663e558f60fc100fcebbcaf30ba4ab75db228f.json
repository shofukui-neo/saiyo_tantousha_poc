{"url":"https://www.fukuda.co.jp/recruit/career/process.html","html":"<!DOCTYPE html>\r\n<html lang=\"ja\">\r\n\r\n<head prefix=\"og: http://ogp.me/ns#\">\r\n  <meta charset=\"UTF-8\">\r\n<!-- Google Tag Manager -->\r\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\r\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\r\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\r\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\r\n})(window,document,'script','dataLayer','GTM-PC6HWS');</script>\r\n<!-- End Google Tag Manager -->\r\n  <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\r\n  <meta name=\"viewport\" content=\"width=device-width\">\r\n  <meta name=\"format-detection\" content=\"telephone=no\">\r\n  <meta name=\"twitter:image:alt\" content=\"フクダ電子採用情報\">\r\n  <meta name=\"twitter:card\" content=\"summary_large_image\">\r\n  <meta name=\"description\" content=\"フクダ電子のキャリア採用選考フローをご確認いただけます。\">\r\n  <meta property=\"og:description\" content=\"フクダ電子のキャリア採用選考フローをご確認いただけます。\">\r\n  <meta name=\"keywords\" content=\"フクダ電子,医療機器,心電計,AED,フクダ電子グループ,在宅医療,地域医療\">\r\n  <meta property=\"og:url\" content=\"https://www.fukuda.co.jp/recruit/new/\">\r\n  <meta property=\"og:title\" content=\"キャリア採用：選考プロセス｜RECRUIT｜フクダ電子採用情報\">\r\n  <meta property=\"og:site_name\" content=\"フクダ電子採用情報\">\r\n  <meta property=\"og:type\" content=\"website\">\r\n  <meta property=\"og:locale\" content=\"ja_JP\">\r\n  <meta property=\"og:image\" content=\"https://www.fukuda.co.jp/recruit/new/thumb.jpg\">\r\n  <title>キャリア採用：選考プロセス｜RECRUIT｜フクダ電子採用情報</title>\r\n  <link rel=\"shortcut icon\" href=\"../favicon.ico\">\r\n  <link rel=\"stylesheet\" type=\"text/css\" href=\"../assets/css/common.css\" media=\"screen\" />\r\n  <link rel=\"stylesheet\" type=\"text/css\" media=\"print, screen and (min-width: 1024px)\" href=\"../assets/css/career/style.css\">\r\n  <link rel=\"stylesheet\" type=\"text/css\" media=\"screen and (max-width: 1023px) and (min-width: 0px)\"\r\n    href=\"../assets/css/mobile.css\">\r\n  <link rel=\"stylesheet\" type=\"text/css\" href=\"../assets/css/career/common.css\" media=\"screen\" />\r\n  <link rel=\"stylesheet\" type=\"text/css\" href=\"../assets/css/career/process.css\" media=\"screen\" />\r\n  <script type=\"text/javascript\" src=\"https://code.jquery.com/jquery-3.4.1.min.js\"></script>\r\n  <script type=\"text/javascript\" src=\"../assets/js/function.js\"></script>\r\n  <!-- Global site tag (gtag.js) - Google Analytics -->\r\n  <script async src=\"https://www.googletagmanager.com/gtag/js?id=UA-476156-1\"></script>\r\n  <script>\r\n    window.dataLayer = window.dataLayer || [];\r\n    function gtag() { dataLayer.push(arguments); }\r\n    gtag('js', new Date());\r\n\r\n    gtag('config', 'UA-476156-1');\r\n  </script>\r\n</head>\r\n\r\n<body class=\"basic career process\">\r\n<!-- Google Tag Manager (noscript) -->\r\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-PC6HWS\"\r\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\r\n<!-- End Google Tag Manager (noscript) -->\r\n  <header>\r\n    <div class=\"logo\"><a href=\"./\"><img src=\"../assets/img/common_img/logo.svg\" alt=\"フクダ電子株式会社\" /></a></div>\r\n    <script type=\"text/javascript\">\r\n      writeGmenuCareer(\"../\");\r\n    </script>\r\n  </header>\r\n\r\n\r\n  <div id=\"container\">\r\n\r\n    <div class=\"h1-box fin\">\r\n      <h1><span>RECRUIT</span>キャリア採用</h1>\r\n      <p class=\"txt-header\">選考プロセス</p>\r\n    </div>\r\n\r\n\r\n    <main>\r\n\r\n      <section class=\"section01 fin\">\r\n        <div class=\"content-box\">\r\n\r\n          <p class=\"text01\">キャリア採用選考の基本的な流れは以下の通りです。<br>\r\n            下記と若干異なるプロセスを経ていただくこともございますのでご了承ください。</p>\r\n\r\n          <div class=\"process-flow\">\r\n            <dl>\r\n              <dt>\r\n                <p>01</p>\r\n              </dt>\r\n              <dd>\r\n                <div class=\"ttl\">応募</div>\r\n                <p><a href=\"/recruit/career/\">募集状況</a>をみていただき、希望職種がございましたら、<a href=\"http://jobb.jp/DE687421/f/1\" target=\"_blank\">エントリーシート</a>よりご応募ください。</p>\r\n              </dd>\r\n            </dl>\r\n\r\n            <dl>\r\n              <dt>\r\n                <p>02</p>\r\n              </dt>\r\n              <dd>\r\n\r\n                <div class=\"ttl\">書類選考</div>\r\n                <ul class=\"c-list\">\r\n                  <li><a href=\"http://jobb.jp/DE687421/f/1\" target=\"_blank\">エントリーシート</a>をもとに、書類選考をいたします</li>\r\n                  <li>書類選考の結果、次のステップに進んでいただく方には、面接日を連絡いたします。<br>\r\n                    （結果は2週間以内に連絡いたします。履歴書と職務経歴書を郵送いただく際は送付先をお知らせいたします。）</li>\r\n                </ul>\r\n              </dd>\r\n            </dl>\r\n\r\n            <dl>\r\n              <dt>\r\n                <p>03</p>\r\n              </dt>\r\n              <dd>\r\n                <div class=\"ttl\">一次選考</div>\r\n                <ul class=\"c-list\">\r\n                  <li>一次面接を行います。専門スキルおよび人物評価をいたします。</li>\r\n                  <li>結果は1週間以内を目処にお知らせいたします。</li>\r\n                  <li>合格者へは、お電話もしくはメールにて二次面接のご案内をいたします。</li>\r\n                  <li>不合格者へは、書面等にてご連絡いたします。</li>\r\n                </ul>\r\n              </dd>\r\n            </dl>\r\n\r\n            <dl>\r\n              <dt>\r\n                <p>04</p>\r\n              </dt>\r\n              <dd>\r\n\r\n                <div class=\"ttl\">二次選考</div>\r\n                <ul class=\"c-list\">\r\n                  <li>役員面接を行います。</li>\r\n                  <li>結果は1週間以内を目処にお知らせいたします。</li>\r\n                  <li>合格者へは電話で内定および今後の手順をご連絡いたします。</li>\r\n                  <li>不合格者へは書面等にてご連絡いたします。</li>\r\n                </ul>\r\n              </dd>\r\n            </dl>\r\n\r\n            <dl class=\"last-row\">\r\n              <dt>\r\n                <p>05</p>\r\n              </dt>\r\n              <dd>\r\n                <p>入社予定日や処遇等について、ご相談させていただきます。</p>\r\n              </dd>\r\n            </dl>\r\n\r\n\r\n\r\n\r\n          </div>\r\n\r\n          <h3 class=\"h3-style01\">採用応募者個人情報の利用目的</h3>\r\n\r\n          <ul class=\"c-list\">\r\n            <li>採用応募者の個人情報は、当社の「<a href=\"/info/privacy.html\" target=\"_blank\">個人情報の利用目的について</a>」にのっとり、安全な管理を行います。</li>\r\n            <li>当社は、採用応募者の個人情報を次の利用目的の達成に必要な範囲においてのみ取り扱います。\r\n\r\n              <ul class=\"c-num-list\">\r\n                <li>採用選考申し込み受付のため</li>\r\n                <li>採用応募者への各種ご連絡のため（面接日時のご案内、選考結果通知、採用内定通知等）</li>\r\n                <li>採用選考を実施するため</li>\r\n                <li>採用決定後における雇用管理の基礎資料とするため</li>\r\n              </ul>\r\n            </li>\r\n          </ul>\r\n          <p class=\"text02\">なお、採用が決定されなかった方の個人情報は機密保護を守り、6ヶ月以内に破棄いたします。</p>\r\n        </div>\r\n      </section>\r\n\r\n      <section class=\"section02 job-entry-block fin\">\r\n        <div class=\"content-box\">\r\n          <div class=\"line-title\">勤務地からエントリー</div>\r\n          <ul class=\"job-entry\">\r\n\r\n\r\n            <li>\r\n              <a href=\"/recruit/career/area/area01.html\" class=\"abox\"></a>\r\n              <p>北海道・東北地区</p>\r\n           </li>\r\n           <li>\r\n              <a href=\"/recruit/career/area/area02.html\" class=\"abox\"></a>\r\n              <p>関東地区</p>\r\n           </li>\r\n           <li>\r\n              <a href=\"/recruit/career/area/area03.html\" class=\"abox\"></a>\r\n              <p>北陸・中部・東海地区</p>\r\n           </li>\r\n           <li>\r\n              <a href=\"/recruit/career/area/area04.html\" class=\"abox\"></a>\r\n              <p>近畿地区</p>\r\n           </li>\r\n           <li>\r\n              <a href=\"/recruit/career/area/area05.html\" class=\"abox\"></a>\r\n              <p>中国・四国地区</p>\r\n           </li>\r\n           <li>\r\n              <a href=\"/recruit/career/area/area06.html\" class=\"abox\"></a>\r\n              <p>九州・沖縄地区</p>\r\n           </li>\r\n          </ul>\r\n        </div>\r\n      </section>\r\n    </main>\r\n\r\n\r\n    <section class=\"other-contents\">\r\n      <p class=\"ttl\">OTHER CONTENTS</p>\r\n\r\n      <ul class=\"other-links\">\r\n        <li class=\"scale-btn\">\r\n          <a href=\"/recruit/career/process.html\" class=\"abox\"></a>\r\n          <div class=\"img-box\"><img src=\"../assets/img/other_img/other-message_pc.jpg\" class=\"sp_img\"\r\n              alt=\"選考プロセス\" /></div>\r\n          <p>選考プロセス</p>\r\n        </li>\r\n\r\n        <li class=\"scale-btn\">\r\n          <a href=\"/recruit/career/faq.html\" class=\"abox\"></a>\r\n          <div class=\"img-box\"><img src=\"../assets/img/other_img/other-faq_pc.jpg\" class=\"sp_img\" alt=\"よくある質問\" />\r\n          </div>\r\n          <p>よくある質問</p>\r\n        </li>\r\n      </ul>\r\n\r\n    </section>\r\n\r\n  </div>\r\n\r\n\r\n  <footer>\r\n\r\n    <div class=\"footer-logo\"><a href=\"../\"><img src=\"../assets/img/common_img/footer-logo.svg\"\r\n          alt=\"フクダ電子株式会社 RECRUIT SITE\" /></a></div>\r\n\r\n    <p class=\"copyright\">Copyright © FUKUDA DENSHI All Rights Reserved</p>\r\n  </footer>\r\n</body>\r\n\r\n</html>","finalUrl":"https://www.fukuda.co.jp/recruit/career/process.html","rendered":false,"_cachedAt":"2026-06-22T18:22:27.885Z"}