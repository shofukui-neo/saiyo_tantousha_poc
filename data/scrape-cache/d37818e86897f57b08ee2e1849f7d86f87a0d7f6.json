{"url":"https://ftecweb.net/recruit/","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n<head>\n<meta charset=\"utf-8\">\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\" >\n<meta name=\"format-detection\" content=\"telephone=no\">\n\n\n<!-- Viewport\n======================================================================-->\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1, maximum-scale=1, user-scalable=0\">\n\n\n<!-- SEO\n======================================================================-->\n<title>採用情報｜FTEC株式会社</title>\n<meta name=\"description\" content=\"FTEC株式会社の採用情報です。未来のエネルギー事業を支え、地域社会に貢献する高速増殖炉の研究開発、プラントメンテナンスの総合サポートを支援するお仕事です。\">\n<meta name=\"keywords\" content=\"\">\n\n\n<!-- Facebook\n======================================================================-->\n<meta property=\"og:title\" content=\"採用情報｜FTEC株式会社\">\n<meta property=\"og:type\" content=\"website\">\n<meta property=\"og:url\" content=\"https://ftecweb.net/\">\n<meta property=\"og:image\" content=\"https://ftecweb.net/images/share/OGP.png\">\n<meta property=\"og:site_name\" content=\"\">\n<meta property=\"og:description\" content=\"FTEC株式会社の採用情報です。未来のエネルギー事業を支え、地域社会に貢献する高速増殖炉の研究開発、プラントメンテナンスの総合サポートを支援するお仕事です。\" />\n<meta property=\"fb:app_id\" content=\"\">\n\n\n<!-- CSS\n======================================================================-->\n<link href=\"//fonts.googleapis.com/css?family=Fira+Sans:400,700\" rel=\"stylesheet\">\n<link rel=\"stylesheet\" href=\"//cdnjs.cloudflare.com/ajax/libs/animate.css/3.5.2/animate.min.css\">\n<link href=\"https://ftecweb.net/css/owl.carousel.css\" rel=\"stylesheet\">\n<link href=\"https://ftecweb.net/css/style.css\" rel=\"stylesheet\">\n<link href=\"https://ftecweb.net/css/custom.css\" rel=\"stylesheet\">\n\n<!-- Favicon\n======================================================================-->\n<link rel=\"icon\" href=\"https://ftecweb.net/images/favicons/favicon.ico\">\n<link rel=\"shortcut icon\" href=\"https://ftecweb.net