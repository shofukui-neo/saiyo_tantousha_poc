ontent=\"2\">\n    </li>\n    \t\t\t\t    <li itemprop=\"itemListElement\" itemscope=\"\" itemtype=\"http://schema.org/ListItem\">\n      &nbsp;&gt;&nbsp;\n            <span itemprop=\"name\">社長メッセージ</span>\n            <meta itemprop=\"position\" content=\"3\">\n    </li>\n    \t\t  </ul>\n</div><!--/TopicPath-->\n\t\t<div class=\"pagebody_inner\">\n                    <div class=\"content1\">\n          <div class=\"detail_img_top tac\"><img alt=\"\" height=\"221\" src=\"/userfiles/images/yamaguchi202604.jpg\" width=\"864\" /></div>\r\n\r\n<div class=\"inner_04 inner_in_inner\">\r\n<p>当社は、沖縄に根ざしたICT企業として、システムインテグレーションとシステムサービスを通じ、地域社会やお客様の課題解決に取り組んでまいりました。これまで培ってきた信頼と実績を大切にしながら、日立グループの総合力と先進技術を活かし、さらなる価値創出に挑戦してまいります。&nbsp;</p>\r\n\r\n<p>&nbsp;今後は、デジタルトランスフォーメーション（DX）や生成AIなど新たな技術潮流を的確に捉え、お客様起点のサービス提供と人財育成を通じた地域貢献を重要なテーマとして、持続的な成長をめざしてまいります。&nbsp;<br />\r\n沖縄に根ざした信頼されるITパートナーであり続けるため、社員一丸となって取り組んでまいりますので、今後とも変わらぬご支援を賜りますよう、よろしくお願い申し上げます。</p>\r\n\r\n<div class=\"ceo_message_block\">\r\n<div class=\"ceo_message_01\">沖縄日立ネットワークシステムズ株式会社<br />\r\n<strong>代表取締役　山口 宏</strong></div>\r\n</div>\r\n</div>\r\n\n        </div>\n      \t\t</div>\n\t</main>\n\t<!-- //pagebody --> \n\n\t<!-- widget_contact --> \n\t\t<div class=\"widget_contact_area\">\n\t\t<div class=\"inner_03\">\n\t\t\t<div class=\"widget_contact_name\">Contact</div>\n\t\t\t<p class=\"widget_contact_txt\">沖縄日立ネットワークシステムズについてご質問、お問い合わせはこちら。<br class=\"sp_none\">お気軽にご相談ください。</p>\n\t\t\t<div class=\"widget_contact_btn_block\">\n\t\t\t\t<a href=\"/contact/\" class=\"btn_02 widget_contact_btn\">資料請求・お問い合わせ</a>\n\t\t\t</div>\n\t\t</div>\n\t</div>\n \n\t<!-- //widget_contact --> \n\n\t<!-- site_footer --> \n\t<div id=\"FooterArea\">\n  <!-- コンテナ（幅1275px、レスポンシブ対応の場合）※「5. コンテナについて」を参照 -->\n  <div class=\"Container Wide\">\n    <a href=\"#top\" id=\"FooterPageTop\" aria-label=\"ページの先頭へ\"></a>\n    <!-- オプショナルフッタ 「7.3. オプショナルフッタ」を参照-->\n    <div id=\"Footer2\">\n            <!-- オプショナルフッタ項目「7.5. オプショナルフッタ項目」を参照 -->\n      <div id=\"Footer2Menu\">\n        <a href=\"/sitemap/\">サイトマップ</a>\n        <a href=\"/topics/\">新着情報</a>\n        <a href=\"/contact/\">お問い合わせ</a>\n      </div>\n    </div>\n    <!-- フッタ -->\n    <div id=\"Footer1\">\n      <!-- 日立グループTOP「7.6. 日立グループTOP」 -->\n      <div id=\"HitachiTop\">\n        <a href=\"https://www.hitachi.co.jp/\">日立グループTOP</a>\n      </div>\n      <!-- フッタ項目「7.7. フッタ項目」を参照 -->\n      <div id=\"Footer1Menu\">\n        <a href=\"https://www.hitachi.co.jp/utility/termofuse/index.html\">サイトの利用条件</a>\n        <a href=\"/privacy/\">個人情報保護に関して</a>\n      </div>\n      <!-- コピーライト「7.8. コピーライト」を参照 -->\n      <div id=\"Copyright\">&copy;Okinawa Hitachi Network Systems, Ltd. 2026. All rights reserved.</div>\n    </div>\n  </div>\n</div>\n\n \n\t<!-- //site_footer --> \n</div>\n\n<script type=\"text/javascript\" src=\"/js/lib/jquery.js\"></script>\n<script type=\"text/javascript\" src=\"/js/jp/r1/common.js\"></script>\n<script type=\"text/javascript\" src=\"/js/jp/r1/responsive.js\"></script>\n<script type=\"text/javascript\" src=\"/js/jp/r1/wide.js\"></script>\n<script type=\"text/javascript\" src=\"/js/jp/r1/common_option.js\"></script>\n<script type=\"text/javascript\" src=\"/js/jp/r1/common2.js\"></script>\n<script type=\"text/javascript\" charset=\"UTF-8\" src=\"https://module.hitachi.com/search/js/sug.js#sv=//mf2aps06.marsflag.com/hitachi__RGN_JAPAN__result_00\"></script>\n<script type=\"text/javascript\" src=\"/js/plugin.js\"></script>\n<script src=\"/js/site.js\"></script>\n\n<script type=\"text/javascript\" language=\"javascript\">\n\n\n\n</script>\n</body>\n</html>","finalUrl":"https://www.ohns.co.jp/about/message/","rendered":false,"_cachedAt":"2026-06-23T22:43:36.438Z"}