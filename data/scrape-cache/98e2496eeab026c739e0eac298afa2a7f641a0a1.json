__en\">ENTRY</span><span class=\"subtitle\">エントリー</span><span class=\"cv_arrow\"></span></a>\r\n  </div>\r\n  </button>\r\n\t<button class=\"intern_btn\">\r\n  <div class=\"intern_btn_in\">\r\n  <a href=\"https://www.ill.co.jp/recruit/internship/\" target=\"_blank\" class=\"btn_con\"><span class=\"h__en\">INTERNSHIP</span><span class=\"subtitle\">インターンシップ</span><span class=\"cv_arrow\"></span></a>\r\n  </div>\r\n  </button>\r\n  <!--スマホヘッダー-->\r\n  <div class=\"ill-headerInner__sp\">\r\n    <div class=\"openbtn1\"><span></span><span></span><span></span></div>\r\n    <nav id=\"g-nav\">\r\n      <div id=\"g-nav-list\"><!--ナビの数が増えた場合縦スクロールするためのdiv※不要なら削除-->\r\n        <div class=\"footer__t\">\r\n          <nav class=\"footer__t__in\">\r\n            <div class=\"footer__t__st\">\r\n              <ul class=\"footer__t__st__ls\">\r\n                <li>\r\n                  <div class=\"footer__t__st__ls__hd\"><a href=\"message.html\"><span class=\"c-navText\"><span class=\"__en\">MESSAGE</span><span class=\"__ja\">アイルの想い</span></span></a></div>\r\n                  <div class=\"footer__t__st__ls__bd\">\r\n                    <ul class=\"footer__t__st__ls__bd__ls\">\r\n                      <li><a href=\"message.html#message_or\"><span>アイルの役割</span></a></li>\r\n                      <li><a href=\"message.html#message_cp\"><span>企業ポリシー</span></a></li>\r\n                      <li><a href=\"message.html#message_ic\"><span>求める人物像</span></a></li>\r\n                    </ul>\r\n                  </div>\r\n                </li>\r\n              </ul>\r\n            </div>\r\n            <div class=\"footer__t__st\">\r\n              <ul class=\"footer__t__st__ls\">\r\n                <li>\r\n                  <div class=\"footer__t__st__ls__hd\"><a href=\"culture.html\"><span class=\"c-navText\"><span class=\"__en\">CULTURE</span><span class=\"__ja\">文化を知る</span></span></a></div>\r\n                  <div class=\"footer__t__st__ls__bd\">\r\n                    <ul class=\"footer__t__st__ls__bd__ls\">\r\n                      <li><a href=\"culture.html\"><span>企業文化</span></a></li>\r\n                      <li><a href=\"illword.html\"><span>アイル語</span></a></li>\r\n                    </ul>\r\n                  </div>\r\n                </li>\r\n              </ul>\r\n            </div>\r\n            <div class=\"footer__t__st\">\r\n              <ul class=\"footer__t__st__ls\">\r\n                <li>\r\n                  <div class=\"footer__t__st__ls__hd\"><a href=\"business.html\"><span class=\"c-navText\"><span class=\"__en\">BUSINESS</span><span class=\"__ja\">仕事を知る</span></span></a></div>\r\n                  <div class=\"footer__t__st__ls__bd\">\r\n                    <ul class=\"footer__t__st__ls__bd__ls\">\r\n                      <li><a href=\"business.html\"><span>ビジネスモデル</span></a></li>\r\n                      <li><a href=\"job.html\"><span>職種紹介</span></a></li>\r\n                    </ul>\r\n                  </div>\r\n                </li>\r\n              </ul>\r\n            </div>\r\n            <div class=\"footer__t__st\">\r\n              <ul class=\"footer__t__st__ls\">\r\n                <li>\r\n                  <div class=\"footer__t__st__ls__hd\"><a href=\"member.html\"><span class=\"c-navText\"><span class=\"__en\">MEMBER</span><span class=\"__ja\">人を知る</span></span></a></div>\r\n                  <div class=\"footer__t__st__ls__bd\">\r\n                    <ul class=\"footer__t__st__ls__bd__ls\">\r\n                      <li><a href=\"member.html\"><span>社員紹介</span></a></li>\r\n                      <li><a href=\"interview/index.html\"><span>若手社員の声</span></a></li>\r\n                    </ul>\r\n                  </div>\r\n                </li>\r\n              </ul>\r\n            </div>\r\n            <div class=\"footer__t__st\">\r\n              <ul class=\"footer__t__st__ls\">\r\n                <li>\r\n                  <div class=\"footer__t__st__ls__hd\"><a href=\"requirements.html\"><span class=\"c-navText\"><span class=\"__en\">RECRUIT</span><span class=\"__ja\">採用情報</span></span></a></div>\r\n                  <div class=\"footer__t__st__ls__bd\">\r\n                    <ul class=\"footer__t__st__ls__bd__ls\">\r\n                      <li><a href=\"requirements.html\"><span>募集要項</span></a></li>\r\n                      <li><a href=\"education.html\"><span>教育・評価制度</span></a></li>\r\n                      <li><a href=\"welfare.html\"><span>福利厚生</span></a></li>\r\n                      <li><a href=\"faq.html\"><span>採用FAQ</span></a></li>\r\n                    </ul>\r\n                  </div>\r\n                </li>\r\n              </ul>\r\n            </div>\r\n            <div class=\"footer__t__st\">\r\n              <ul class=\"footer__t__st__ls\">\r\n                <li>\r\n                  <div class=\"footer__t__st__ls__hd\"><a href=\"company.html\"><span class=\"c-navText\"><span class=\"__en\">COMPANY</span><span class=\"__ja\">会社概要</span></span></a></div>\r\n                </li>\r\n              </ul>\r\n            </div>\r\n            <div class=\"footer__t__st\">\r\n              <ul class=\"footer__t__st__ls\">\r\n                <li>\r\n                  <div class=\"footer__t__st__ls__hd\"><a href=\"https://www.ill.co.jp/recruit/entry_select.html\"><span class=\"c-navText\"><span class=\"__en\">ENTRY</span><span class=\"__ja\">エントリー</span></span></a></div>\r\n                </li>\r\n              </ul>\r\n            </div>\r\n          </nav>\r\n          <a href=\"https://www.ill.co.jp/\" class=\"page-link\"><img src=\"images/corporate.png\" alt=\"株式会社アイルコーポレートサイト\"></a>\r\n\t\t\t          <a href=\"https://www.ill.co.jp/recruit/internship/\" class=\"page-link\"><img src=\"images/intern.png\" alt=\"株式会社アイルインターン情報サイト\"></a>\r\n\t\t  </div>\r\n      </div>\r\n    </nav>\r\n    <div class=\"g-nav-bg\"></div>\r\n  </div>\r\n  <!--スマホヘッダー終了--> \r\n</header>\r\n<section class=\"top\">\r\n  <button class=\"entry_btn\">\r\n  <div class=\"entry_btn_in\">\r\n  <span class=\"h__en\"><a href=\"\" class=\"in-the-page\">ENTRY</a></span><span class=\"subtitle\">エントリー</span>\r\n  </div>\r\n  </button>\r\n</section>\r\n<div id=\"culture\">\r\n  <section class=\"key_visual bg__gradation\">\r\n    <div class=\"page_title bg_in\">\r\n      <div class=\"title_area\"> <span class=\"subtitle__en\">CULTURE</span> <span class=\"subtitle\">文化を知る</span> </div>\r\n      <h2>企業文化を育む取り組み</h2>\r\n    </div>\r\n  </section>\r\n  <section class=\"main main_top bg__w\">\r\n    <div class=\"main_cont\">\r\n      <h3 class=\"cont_title\"><span class=\"h__en\">CORPORATE CULTURE</span>企業文化</h3>\r\n      <p>アイルでは、「風通しの良さ」や「オープンな風土」を育むための<br>\r\n        独自の取り組みにより文化が根付いています。<br>\r\n        <br>\r\n        ここではそんなアイルの企業文化を支える取り組みについてご紹介します！ </p>\r\n    </div>\r\n  </section>\r\n  <section class=\"main bg__b\">\r\n    <figure class=\"cul_member\"><img src=\"images/culture/cul_member.png\" alt=\"アイルのメンバー\"></figure>\r\n    <div class=\"main_cont\">\r\n      <article class=\"cont__white fade_cont\">\r\n        <div class=\"column_sideimg\">\r\n          <div class=\"column_left\">\r\n            <h4 class=\"box_title\">月報会議</h4>\r\n            <p>創業から毎月欠かさず行っている最も重要な会議「月次報告会議」です。社長自らが全社員に向けて業績やビジョン、社員の活躍などをすべて伝えることで、社員ひとり一人が経営者感覚を持って仕事に取り組むことができ、アイルの現場力の強さに繋がっています。</p>\r\n          </div>\r\n          <div class=\"column_right\">\r\n            <figure><img src=\"images/culture/geppou.png\" alt=\"月報会議\"></figure>\r\n          </div>\r\n        </div>\r\n      </article>\r\n      <article class=\"fade_cont\" id=\"mail\">\r\n        <div class=\"column_sideimg\">\r\n          <div class=\"column_left\">\r\n            <h4 class=\"box_title\">メッセージメール</h4>\r\n            <p>社員が社長、役員へ直接メッセージを発信できる制度です。<br>\r\n              アイディアや会社の仕組みの改善案、お客様の声など現場の声をスムーズに経営トップへ届けることができます。<br>\r\n              また、社長から各社員へダイレクトに全てのメールに返信することによって、双方にとって重要なコミュニケーションツールとなっています。</p>\r\n          </div>\r\n          <div class=\"column_right\">\r\n            <figure><img src=\"images/culture/message_mail.png\" alt=\"メッセージメール\"></figure>\r\n          </div>\r\n        </div>\r\n      </article>\r\n      <article id=\"koukensya\" class=\"fade_cont\">\r\n        <div class=\"column_sideimg\">\r\n          <div class=\"column_left\">\r\n            <h4 class=\"box_title\">貢献者・準貢献者</h4>\r\n            <p>毎月、各事業部ごとに好成績を残した社員が貢献者又は準貢献者に選出され、一流料亭のお弁当やサーロインステーキなどの贈答品が自宅に送られます。さらに貢献者は、オンラインで社長との報告会に参加することができます。</p>\r\n            <p>貢献者選出・会食制度についての詳細記事はこちら！</p>\r\n            <p><a href=\"https://prtimes.jp/story/detail/ArY8DWcE7xG\" target=\"_blank\">『会社から社員の自宅に、高級弁当やステーキが届く。コロナでも中止しない評価制度の背景とは』</a></p>\r\n          </div>\r\n          <div class=\"column_right\">\r\n            <figure><img src=\"images/culture/contribution.png\" alt=\"貢献者・準貢献者\"></figure>\r\n          </div>\r\n        </div>\r\n      </article>\r\n      <article class=\"fade_cont\">\r\n        <div class=\"column_sideimg\">\r\n          <div class=\"column_left\">\r\n            <h4 class=\"box_title\">社長会食・役員会食</h4>\r\n            <p>四半期に一度、各月で選出された貢献者の中で、より好成績を残した社員が会食参加者にも選出され、社長又は役員と食事や会話を楽しみ、参加者だけが味わえる特別な時間を共有することができます。<br>\r\n              部署や上下関係に関わらず好成績を収めたメンバーとの交流もできるため、大きな刺激を受けてモチベーションを上げる貴重な場となっています。</p>\r\n          </div>\r\n          <div class=\"column_right\">\r\n            <figure><img src=\"images/culture/kaishoku.png\" alt=\"社長会食・役員会食\"></figure>\r\n          </div>\r\n        </div>\r\n      </article>\r\n        <article class=\"fade_cont\">\r\n        <div class=\"column_sideimg\">\r\n          <div class=\"column_left\">\r\n            <h4 class=\"box_title\">Web社内報 <span>＜AIREAL（アイリアル）＞</span></h4>\r\n            <p>社員の頑張りや元気な姿・表情・言葉をリアルタイムに届けるためのアイル社員限定のWeb社内報です。<br>\r\n              社員へのインタビュー記事をはじめ、なかなか知ることのできない他部署の取り組みなどを社内報を通して知ることができます。</p>\r\n          </div>\r\n          <div class=\"column_right\">\r\n            <figure><img src=\"images/culture/aireal.png\" alt=\"AIREAL\"></figure>\r\n          </div>\r\n        </div>\r\n      </article>\r\n      <article class=\"fade_cont\">\r\n        <div class=\"column_sideimg\">\r\n          <div class=\"column_left\">\r\n            <h4 class=\"box_title\">アイル公式note</h4>\r\n            <p>社外の方に向けて社内の取り組みや事業・文化の裏側を紹介する対外的な社内報「公式note」を公開しています。</p>\r\n              <a href=\"https://note.ill.co.jp/\" class=\"btn a__m_top\" target=\"_blank\"> <span class=\"round_arrow\">アイル公式noteはこちら</span></a>\r\n          </div>\r\n          <div class=\"column_right\">\r\n            <figure><img src=\"images/culture/note.png\" alt=\"アイル公式note\"></figure>\r\n          </div>\r\n        </div>\r\n      </article>\r\n      <article class=\"fade_cont\">\r\n        <div class=\"column_sideimg\">\r\n          <div class=\"column_left\">\r\n            <h4 class=\"box_title\">おきもチップ</h4>\r\n            <p>社員同士が日頃の仕事の成果や行動に感謝・賞賛するメッセージとともに、ポイントを送り合う制度です。<br>\r\n              他部署のメンバーの活躍や、感謝される行動を知ることで好循環を生み出すことができます。また、毎月ポイント数の多かった投稿の上位を選出し、投稿した人と投稿された人にそれぞれ\"おきもチップインセンティブ\"を支給しています。</p>\r\n          </div>\r\n          <div class=\"column_right\">\r\n            <figure><img src=\"images/culture/unipos.png\" alt=\"おきもチップ\"></figure>\r\n          </div>\r\n        </div>\r\n      </article>\r\n      <article class=\"fade_cont\">\r\n        <div class=\"column_sideimg\">\r\n          <div class=\"column_left\">\r\n            <h4 class=\"box_title\">ファインプレーカード<span>（入り札制度）</span></h4>\r\n            <p>仕事の中には、目に見えにくく、なかなか評価されにくい仕事もあります。<br>\r\n              <br>\r\n              そんな、社員同士が見えないところで頑張っている仲間を紹介し合い、社員同士の生の声から、入り札賞としてインセンティブが支給されます。</p>\r\n          </div>\r\n          <div class=\"column_right\">\r\n            <figure><img src=\"images/culture/fineplay.png\" alt=\"ファインプレーカード\"></figure>\r\n          </div>\r\n        </div>\r\n      </article>\r\n      <article class=\"fade_cont ill_word\">\r\n        <div class=\"column_left\">\r\n          <h4 class=\"box_title\">アイル語</h4>\r\n          <p>「アイル語」とは社員が日々のコミュニケーションを通じて、<br>\r\n            「社長所感」の中から自然とキーワード化された言葉です。<br>\r\n            <br>\r\n            社員が仕事を進めていく上での行動基準の一つになっています。</p>\r\n          <a href=\"illword.html\" class=\"btn a__m_top\"> <span class=\"round_arrow\">アイル語を見る</span> </a>\r\n          </div>\r\n        <figure class=\"no_sp\"><img src=\"images/culture/illwords.png\" alt=\"アイル語\"></figure>\r\n          <figure class=\"no_pc\"><img src=\"images/culture/illwords_sp.png\" alt=\"アイル語\"></figure>\r\n      </article>\r\n    </div>\r\n  </section>\r\n</div>\r\n<section class=\"cv\">\r\n    <div class=\"cv_bg\">\r\n      <div class=\"cv_bg_in\">\r\n        <h3>あなたも一緒に、思い切りバットを振っていこう。</h3>\r\n        <div class=\"cv_in_box\">\r\n          <div class=\"cv_in\">\r\n            <p class=\"cv_e_p\">新卒採用</p>\r\n            <a href=\"https://ill-recruit.snar.jp/index.aspx\" class=\"cv_btn\">\r\n            <div class=\"cv_box\">\r\n              <div class=\"cv_btn_in\"> <span class=\"h__en\">ENTRY</span><span class=\"subtitle\">新卒採用</span></div>\r\n              <p>新卒採用向け<br>\r\n                エントリーはこちら</p>\r\n              <span class=\"cv_arrow\"></span> </div>\r\n            </a> </div>\r\n          <div class=\"cv_in\">\r\n            <p class=\"cv_c_p\">キャリア採用</p>\r\n            <a href=\"entry_career.html\" class=\"cv_btn btn_gr\">\r\n            <div class=\"cv_box\">\r\n              <div class=\"cv_btn_in\"> <span class=\"h__en\">CAREER</span><span class=\"subtitle\">キャリア採用</span></div>\r\n              <p>キャリア採用向け<br>\r\n                募集要項はこちら</p>\r\n              <span class=\"cv_arrow\"></span> </div>\r\n            </a> </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </section>\r\n<footer class=\"footer\">\r\n  <div class=\"footer_all\"> <a href=\"#\" class=\"page-top\"><img src=\"images/airu_small.png\" alt=\"PAGE TOP\">PAGE TOP</a>\r\n    <div class=\"footer__t\">\r\n      <nav class=\"footer__t__in\">\r\n        <div class=\"footer__t__st\">\r\n          <ul class=\"footer__t__st__ls\">\r\n            <li>\r\n              <div class=\"