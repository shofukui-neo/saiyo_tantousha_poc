{"url":"https://www.melec.co.jp/recruit/affairs/","html":"<!DOCTYPE html>\n<html lang=\"ja\" prefix=\"og: http://ogp.me/ns# fb: http://ogp.me/ns/fb# website: http://ogp.me/ns/website#\">\n<head>\n<!-- Global site tag (gtag.js) - Google Analytics -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=UA-41737289-1\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'UA-41737289-1');\n</script><meta charset=\"UTF-8\">\n<title>総務部　社員インタビュー ｜ 株式会社メレック</title>\n<meta name=\"description\" content=\"総務部：株式会社メレックの社員インタビューです。\">\n<meta name=\"keyword\" content=\"太陽光発電,自動ドア修理,自動ドア施工,自動ドア保守\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0, user-scalable=no, minimum-scale=1.0, maximum-scale=1.0\">\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n<link rel=\"canonical\" href=\"https://www.melec.co.jp/recruit/affairs/\">\n<meta name=\"format-detection\" content=\"telephone=no\">\n<meta property=\"og:title\" content=\"株式会社メレック - 岡山の太陽光・自動ドア\" />\n<meta property=\"og:description\" content=\"信頼と実績のメレック。三菱電気代理店、自動ドアナブコの岡山代理店。太陽光発電と自動ドアの修理・施工・保守のことならおまかせください。\"/>\n<meta property=\"og:image\" content=\"https://www.melec.co.jp/common/img/common/ogimage.jpg\" />\n<meta property=\"og:site_name\" content=\"https://www.melec.co.jp/\" />\n<meta property=\"og:url\" content=\"https://www.melec.co.jp/recruit/affairs/\" />\n<meta property=\"og:type\" content=\"article\">\n<meta name=\"twitter:title\" content=\"株式会社メレック - 岡山の太陽光・自動ドア\" />\n<meta name=\"twitter:description\" content=\"信頼と実績のメレック。三菱電気代理店、自動ドアナブコの岡山代理店。太陽光発電と自動ドアの修理・施工・保守のことならおまかせください。\">\n<meta name=\"twitter:image\" content=\"https://www.melec.co.jp/common/img/common/ogimage.jpg\">\n<meta name=\"twitter:url\" content=\"https://www.melec.co.jp/recruit/affairs/\" />\n<meta name=\"twitter:card\" content=\"summary\" />\n<link rel=\"apple-touch-icon-precomposed\" href=\"https://www.melec.co.jp/common/img/common/apptouch.png\">\n<link rel=\"shortcut icon\" href=\"/common/img/common/favicon.ico\">\n<link rel=\"stylesheet\" href=\"/common/css/common.css\">\n<link rel=\"stylesheet\" href=\"/common/css/base.css\"><link rel=\"stylesheet\" href=\"/common/css/recruit.css\">\n</head>\n<body>\n  <div id=\"wrapper\" class=\"profile\">\n    <header class=\"header\" id=\"header\"><!-- header -->\n      <div class=\"wrap\">\n        <div class=\"header_top\">\n          <a href=\"/\" class=\"link_logo\"><img src=\"/common/img/common/logo.png\" alt=\"ロゴ：株式会社メレックのロゴです。\"></a>\n          <ul class=\"btn_sp_wrap for_sp\">\n            <li class=\"btn_sp tel\">\n              <a href=\"tel:0862550055\"><img src=\"/common/img/common/ico_tel.gif\" alt=\"ボタン：株式会社メレックに電話をかけます\"></a>\n            </li>\n            <li class=\"btn_sp nav\" id=\"btn_nav\">\n              <a href=\"\">\n                <span class=\"line\"></span>\n                <span class=\"line\"></span>\n                <span class=\"line\"></span>\n              </a>\n            </li>\n          </ul>\n          <a href=\"/contact/\" class=\"link_contact for_pc\">お問い合わせ</a>\n        </div>\n        <nav class=\"header_nav\" id=\"nav\">\n          <ul class=\"header_nav_in\">\n            <li class=\"link_par_wrap\"><a href=\"/solution/\" class=\"link_par img solution\">導入をご検討の方</a></li>\n            <li class=\"link_par_wrap\"><a href=\"/maintenance/\" class=\"link_par img maintenance\">保守をご検討の方</a></li>\n            <li class=\"link_par_wrap\"><a href=\"/repair/\" class=\"link_par img repair\">修理をご希望の方</a></li>\n            <li class=\"link_par_wrap js_btn_par\">\n              <span class=\"btn_inner\">事業情報</span>\n              <ul class=\"box_link_chi\">\n                <li class=\"link_chi_wrap\"><a href=\"/solution/?s=area_solution\" class=\"link_chi\">事業内容</a></li>\n                <li class=\"link_chi_wrap\"><a href=\"/service/\" class=\"link_chi\">取扱製品</a></li>\n                <li class=\"link_chi_wrap\"><a href=\"/case/\" class=\"link_chi\">納入事例</a></li>\n              </ul>\n            </li>\n            <li class=\"link_par_wrap js_btn_par\">\n              <span class=\"btn_inner\">会社情報</span>\n              <ul class=\"box_link_chi\">\n                <li class=\"link_chi_wrap\"><a href=\"/info/\" class=\"link_chi\">お知らせ</a></li>\n                <li class=\"link_chi_wrap\"><a href=\"/message/\" class=\"link_chi\">メッセージ</a></li>\n                <li class=\"link_chi_wrap\"><a href=\"/profile/\" class=\"link_chi\">会社概要</a></li>\n                <li class=\"link_chi_wrap\"><a href=\"/history/\" class=\"link_chi\">沿革</a></li>\n              </ul>\n            </li>\n            <li class=\"link_par_wrap js_btn_par\">\n              <span class=\"btn_inner\">採用情報</span>\n              <ul class=\"box_link_chi\">\n                <li class=\"link_chi_wrap\"><a href=\"/recruit/\" class=\"link_chi\">採用情報トップ</a></li>\n                <li class=\"link_chi_wrap\"><a href=\"/recruit/fresh/\" class=\"link_chi\">新卒採用情報</a></li>\n                <li class=\"link_chi_wrap\"><a href=\"/recruit/career/\" class=\"link_chi\">キャリア採用情報</a></li>\n                <li class=\"link_chi_wrap\"><a href=\"/recruit/event/\" class=\"link_chi\">採用イベント情報</a></li>\n                <li class=\"link_chi_wrap\"><a href=\"/recruit/sales/\" class=\"link_chi\">営業部</a></li>\n                <li class=\"link_chi_wrap\"><a href=\"/recruit/engineer/\" class=\"link_chi\">技術部</a></li>\n                <li class=\"link_chi_wrap\"><a href=\"/recruit/service/\" class=\"link_chi\">保守サービス部</a></li>\n                <li class=\"link_chi_wrap\"><a href=\"/recruit/affairs/\" class=\"link_chi\">総務部</a></li>\n              </ul>\n            </li>\n            <li class=\"link_par_wrap for_sp\"><a href=\"/info/\" class=\"link_par\">お知らせ</a></li>\n          </ul>\n          <a href=\"/contact/\" class=\"link_contact for_sp\">お問い合わせフォーム</a>\n        </nav>\n      </div>\n      <script>(function(){\n        var w=window,d=document;\n        var s=\"https://app.chatplus.jp/cp.js\";\n        d[\"__cp_d\"]=\"https://app.chatplus.jp\";\n        d[\"__cp_c\"]=\"420a45ed_1\";\n        var a=d.createElement(\"script\"), m=d.getElementsByTagName(\"script\")[0];\n        a.async=true,a.src=s,m.parentNode.insertBefore(a,m);})();\n      </script>\n    </header><!-- header/ -->\n  <div class=\"area_pginfo\">\n    <h1 class=\"ttl_page row2\">メレックをつくる人<span class=\"sub\">部署別社員インタビュー</span></h1>\n    <ol class=\"pnkz_wrap\">\n      <li class=\"pnkz\"><a href=\"/\">TOP</a></li>\n      <li class=\"pnkz\"><a href=\"/recruit/\">採用情報</a></li>\n      <li class=\"pnkz\">メレックをつくる人</li>\n    </ol>\n  </div>\n  <div class=\"bg\">\n    <section class=\"area_interview affairs\"><!-- area_interview -->\n      <h2 class=\"ttl_interview\">総務部</h2>\n      <article class=\"box_interview people01\"><!-- box_interview -->\n        <div class=\"wrap\">\n          <div class=\"box_top\">\n            <figure class=\"fig_img\"><img src=\"/common/img/recruit/affairs/img_main_01.jpg\" alt=\"\"></figure>\n            <div class=\"box_intro\">\n              <img src=\"/common/img/recruit/affairs/txt_01.gif\" class=\"catch\" alt=\"小さな幸せに感謝\">\n              <p class=\"txt\">総務部　企画調査課<br>2014年入社</p>\n            </div>\n          </div>\n          <div class=\"box_col2\">\n            <div class=\"box_main\"><!-- box_main -->\n              <div class=\"box_article\">\n                <h3 class=\"ttl_article\">人材育成は自分育成</h3>\n                <p class=\"txt\">2018年2月に新設された企画調査課で主に教育・リクルート、広報活動に携わっています。<br>\n                教育では、共通認識の構築および多様性に富んだ人材育成を目的に教育プログラム・支援体制の策定、整備、社内研修の企画、開催をしています。社内研修一つ開催するにしても情報収集、資料作成、積極的に学べる仕組みづくりの提案など時間を要しますが、参加者の「参加して良かった、よく分かった」などの声を聞くと、やりがいを感じます。</p>\n                <p class=\"txt\">メレックの価値を高めているものは「メレックで働く人たち」です。社員一人ひとりが強みを伸ばし意欲的に成長することは会社の発展へとつながるものと思っています。私自身、現在の業務は新しい分野への挑戦が多く、楽しいことも悩むこともありますが、メンバーに刺激を受け、支えられながら日々邁進しています。仲間とともに、さらなる高みを目指して成長していきたいと思っています。</p>\n              </div>\n              <div class=\"area_bg\">\n                <div class=\"box_graph\">\n                  <h3 class=\"ttl_graph\">性格グラフ</h3>\n                  <img src=\"/common/img/recruit/affairs/img_graph_01.png\" alt=\"優しさ10、冷静さ5、明るさ4、我慢強さ9、厳しさ7\">\n                </div>\n                <div class=\"box_comment\">\n                  <h3 class=\"ttl_comment\">同僚からひと言</h3>\n                  <img src=\"/common/img/recruit/affairs/txt_comment_01.png\" class=\"img_comment\" alt=\"たまに天然な頼れるお姉さん\">\n                  <img src=\"/common/img/recruit/img_people.png\" class=\"img_people\" alt=\"\">\n                </div>\n              </div>\n              <div class=\"box_will for_pc\">\n                <h3 class=\"ttl_will\"><img src=\"/common/img/recruit/ttl_will_pc.png\" alt=\"わたしの志\"></h3>\n                <p class=\"txt\">前進、挑戦、<br>ときどき一休み</p>\n              </div>\n            </div><!-- box_main/ -->\n            <div class=\"box_side\"><!-- box_side/ -->\n              <div class=\"box_day1\">\n                <h3 class=\"ttl_day1\">一日の流れ</h3>\n                <dl class=\"day1\">\n                  <dt class=\"time\">8:00</dt>\n                  <dd class=\"work\">\n                    <span class=\"main\">出社</span><br>当日すべきタスクを確認し、一日のスケジュールを決める\n                  </dd>\n                  <dt class=\"time\">8:10</dt>\n                  <dd class=\"work\">\n                    <span class=\"main\">課内朝礼</span><br>カスタムサービス課員との合同朝礼に参加\n                  </dd>\n                  <dt class=\"time\">8:25</dt>\n                  <dd class=\"work\">\n                    <span class=\"main\">体操・全体朝礼</span>\n                  </dd>\n                  <dt class=\"time\">8:40</dt>\n                  <dd class=\"work\">\n                    <span class=\"main\">事務処理</span><br>カスタムサービス課員の修理報告書チェック等\n                  </dd>\n                  <dt class=\"time\">11:00</dt>\n                  <dd class=\"work\">\n                    <span class=\"main\">資料作成</span><br>各企画についての情報収集、資料作成、ミーティング準備\n                  </dd>\n                  <dt class=\"time\">12:00</dt>\n                  <dd class=\"work\">\n                    <span class=\"main\">昼食</span>\n                  </dd>\n                  <dt class=\"time\">13:00</dt>\n                  <dd class=\"work\">\n                    <span class=\"main\">資料作成等　午前中の続き</span>\n                  </dd>\n                  <dt class=\"time\">14:00</dt>\n                  <dd class=\"work\">\n                    <span class=\"main\">企画ミーティング</span><br>各担当業務の進捗確認、企画内容の話し合い\n                  </dd>\n                  <dt class=\"time\">16:00</dt>\n                  <dd class=\"work\">\n                    <span class=\"main\">まとめ</span><br>ミーティング後のまとめ、タスク整理等\n                  </dd>\n                  <dt class=\"time\">18:30</dt>\n                  <dd class=\"work\">\n                    <span class=\"main\">退社</span>\n                  </dd>\n                </dl>\n              </div>\n              <div class=\"box_fav\">\n                <h3 class=\"ttl_fav\"><span class=\"txt\">わたしのイチオシ</span></h3>\n                <img src=\"/common/img/recruit/affairs/img_fav_01.jpg\" alt=\"\">\n              </div>\n              <div class=\"box_will for_sp\">\n                <h3 class=\"ttl_will\"><img src=\"/common/img/recruit/ttl_will_sp.png\" alt=\"わたしの志\"></h3>\n                <p class=\"txt\">前進、挑戦、<br>ときどき一休み</p>\n              </div>\n            </div><!-- box_side/ -->\n          </div>\n        </div>\n      </article><!-- box_interview/ -->\n\n      <article class=\"box_interview people02\"><!-- box_interview -->\n        <div class=\"wrap\">\n          <div class=\"box_top\">\n            <figure class=\"fig_img\"><img src=\"/common/img/recruit/affairs/img_main_02.jpg\" alt=\"\"></figure>\n            <div class=\"box_intro\">\n              <img src=\"/common/img/recruit/affairs/txt_02.gif\" class=\"catch\" alt=\"まずはやってみる\">\n              <p class=\"txt\">総務部　企画調査課<br>2017年入社</p>\n            </div>\n          </div>\n          <div class=\"box_col2\">\n            <div class=\"box_main\"><!-- box_main -->\n              <div class=\"box_article\">\n                <h3 class=\"ttl_article\">変化の流れを作り出す</h3>\n                <p class=\"txt\">私は主に、サービスエンジニアの行動、機器故障の発生頻度やトレンドを対象とした、自動ドア保守部門のデータ分析に携わっています。データとは、何かアクションが起こった結果に表れるもので、その中には動機(原因)とプロセス、結果が詰まっています。それを読み解き、分解して整理することでより効率的な行動へつなげたり、機器の故障リスクを軽減したりすることを目的としています。</p>\n                <p class=\"txt\">しかしながら、得られた結果から新たな行動を起こし、さらにその結果をフィードバックしてもらうためには実際に現場に赴く人に負担をかけない仕組み作りが重要で、現状での大きな課題の一つです。信頼性のある分析結果を提示して終わりではなく、その後の行動をどのように変えさせることができるか。行動を変えるための体制作りやフォローアップも含めて分析者の役目だと思っています。</p>\n                <p class=\"txt\">新たな発見と、それに伴う変化の流れを作り出すこと。非常に困難な仕事ではありますが、だからこそ面白くもあり日々自身の成長と達成感、充実感を得られるやりがいのある仕事だと思っています。</p>\n              </div>\n              <div class=\"area_bg\">\n                <div class=\"box_graph\">\n                  <h3 class=\"ttl_graph\">性格グラフ</h3>\n                  <img src=\"/common/img/recruit/affairs/img_graph_02.png\" alt=\"優しさ9、冷静さ10、明るさ6、我慢強さ2、厳しさ9\">\n                </div>\n                <div class=\"box_comment\">\n                  <h3 class=\"ttl_comment\">同僚からひと言</h3>\n                  <img src=\"/common/img/recruit/affairs/txt_comment_02.png\" class=\"img_comment\" alt=\"クールに見えて気さくな人\">\n                  <img src=\"/common/img/recruit/img_people.png\" class=\"img_people\" alt=\"\">\n                </div>\n              </div>\n              <div class=\"box_will for_pc\">\n                <h3 class=\"ttl_will\"><img src=\"/common/img/recruit/ttl_will_pc.png\" alt=\"わたしの志\"></h3>\n                <p class=\"txt\">小さな兆しを<br>見逃さない</p>\n              </div>\n            </div><!-- box_main/ -->\n            <div class=\"box_side\"><!-- box_side/ -->\n              <div class=\"box_day1\">\n                <h3 class=\"ttl_day1\">一日の流れ</h3>\n                <dl class=\"day1\">\n                  <dt class=\"time\">8:00</dt>\n                  <dd class=\"work\">\n                    <span class=\"main\">出社・メールチェック</span><br>\n                  </dd>\n                  <dt class=\"time\">8:10</dt>\n                  <dd class=\"work\">\n                    <span class=\"main\">課内朝礼</span><br>\n                    前日の報告<br>当日の点検・修理訪問先を課内で<br>情報共有\n                  </dd>\n                  <dt class=\"time\">8:25</dt>\n                  <dd class=\"work\">\n                    <span class=\"main\">体操・全体朝礼</span>\n                  </dd>\n                  <dt class=\"time\">8:30</dt>\n                  <dd class=\"work\">\n                    <span class=\"main\">事務処理</span><br>見積等提出物のチェック、回覧\n                  </dd>\n                  <dt class=\"time\">10:00</dt>\n                  <dd class=\"work\">\n                    <span class=\"main\">会議</span><br>担当しているプロジェクト会議\n                  </dd>\n                  <dt class=\"time\">12:00</dt>\n                  <dd class=\"work\">\n                    <span class=\"main\">昼食</span>\n                  </dd>\n                  <dt class=\"time\">13:00</dt>\n                  <dd class=\"work\">\n                    <span class=\"main\">分析</span><br>機器情報、行動結果等の分析\n                  </dd>\n                  <dt class=\"time\">17:00</dt>\n                  <dd class=\"work\">\n                    <span class=\"main\">修理受付処理</span><br>当日受け付けた修理受付の手配漏れチェック\n                  </dd>\n                  <dt class=\"time\">18:00</dt>\n                  <dd class=\"work\">\n                    <span class=\"main\">退社</span>\n                  </dd>\n                </dl>\n              </div>\n              <div class=\"box_fav\">\n                <h3 class=\"ttl_fav\"><span class=\"txt\">わたしのイチオシ</span></h3>\n                <img src=\"/common/img/recruit/affairs/img_fav_02.jpg\" alt=\"自転車\">\n              </div>\n              <div class=\"box_will for_sp\">\n                <h3 class=\"ttl_will\"><img src=\"/common/img/recruit/ttl_will_sp.png\" alt=\"わたしの志\"></h3>\n                <p class=\"txt\">小さな兆しを<br>見逃さない</p>\n              </div>\n            </div><!-- box_side/ -->\n          </div>\n        </div>\n      </article><!-- box_interview/ -->\n\n      <article class=\"box_interview people03\"><!-- box_interview -->\n        <div class=\"wrap\">\n          <div class=\"box_top\">\n            <figure class=\"fig_img\"><img src=\"/common/img/recruit/affairs/img_main_03.jpg\" alt=\"\"></figure>\n            <div class=\"box_intro\">\n              <img src=\"/common/img/recruit/affairs/txt_03.gif\" class=\"catch\" alt=\"感謝の気持ちを大切に\">\n              <p class=\"txt\">総務部<br>1995年入社</p>\n            </div>\n          </div>\n          <div class=\"box_col2\">\n            <div class=\"box_main\"><!-- box_main -->\n              <div class=\"box_article\">\n                <h3 class=\"ttl_article\">総務部として</h3>\n                <p class=\"txt\">総務部は、社員の皆様に働きやすい職場となるよう、職場環境の整備、健康管理等を行っています。また、性別・年齢に関係なく、社員の誰もが能力を発揮でき、満足感が得られるような環境を整え、社員の成長と併せて会社全体のレベルアップをサポートしていくことが使命です。このような部署で仕事ができることは、私にとってとてもやりがいがあることと感じています。</p>\n                <p class=\"txt\">更に2018年度は、社会的な環境変化への要請に対応し、社外への積極的な情報発信等を行うために総務部企画調査課が新設されました。ワーク・ライフ・バランスや子育て支援など、働き方が大きく変化していく時代にタイムリーに対応できるよう、会社の現状を把握し一歩先を行く取組みを考え、社員全員の満足度を高め、会社の活力の向上に少しでも寄与していきたいと思っています。</p>\n              </div>\n              <div class=\"area_bg\">\n                <div class=\"box_graph\">\n                  <h3 class=\"ttl_graph\">性格グラフ</h3>\n                  <img src=\"/common/img/recruit/affairs/img_graph_03.png\" alt=\"想像してね！\">\n                </div>\n                <div class=\"box_comment\">\n                  <h3 class=\"ttl_comment\">同僚からひと言</h3>\n                  <img src=\"/common/img/recruit/affairs/txt_comment_03.png\" class=\"img_comment\" alt=\"思いやりのある優しい女性\">\n                  <img src=\"/common/img/recruit/img_people.png\" class=\"img_people\" alt=\"\">\n                </div>\n              </div>\n              <div class=\"box_will for_pc\">\n                <h3 class=\"ttl_will\"><img src=\"/common/img/recruit/ttl_will_pc.png\" alt=\"わたしの志\"></h3>\n                <p class=\"txt\">誠実・日々進歩</p>\n              </div>\n            </div><!-- box_main/ -->\n            <div class=\"box_side\"><!-- box_side/ -->\n              <div class=\"box_day1\">\n                <h3 class=\"ttl_day1\">一日の流れ</h3>\n                <dl class=\"day1\">\n                  <dt class=\"time\">8:00</dt>\n                  <dd class=\"work\">\n                    <span class=\"main\">出社</span><br>メールチェック、当日の予定確認\n                  </dd>\n                  <dt class=\"time\">8:25</dt>\n                  <dd class=\"work\">\n                    <span class=\"main\">体操・全体朝礼</span>\n                  </dd>\n                  <dt class=\"time\">8:30</dt>\n                  <dd class=\"work\">\n                    <span class=\"main\">書類確認<br>総務・人事関連業務</span>\n                  </dd>\n                  <dt class=\"time\">12:00</dt>\n                  <dd class=\"work\">\n                    <span class=\"main\">昼食</span>\n                  </dd>\n                  <dt class=\"time\">13:00</dt>\n                  <dd class=\"work\">\n                    <span class=\"main\">入出金・預金残高確認<br>\n                    打合せ他<br>\n                    経理関連業務</span>\n                  </dd>\n                  <dt class=\"time\">18:30</dt>\n                  <dd class=\"work\">\n                    <span class=\"main\">退社</span>\n                  </dd>\n                </dl>\n              </div>\n              <div class=\"box_fav\">\n                <h3 class=\"ttl_fav\"><span class=\"txt\">わたしのイチオシ</span></h3>\n                <img src=\"/common/img/recruit/affairs/img_fav_03.jpg\" alt=\"\">\n              </div>\n              <div class=\"box_will for_sp\">\n                <h3 class=\"ttl_will\"><img src=\"/common/img/recruit/ttl_will_sp.png\" alt=\"わたしの志\"></h3>\n                <p class=\"txt\">誠実・日々進歩</p>\n              </div>\n            </div><!-- box_side/ -->\n          </div>\n        </div>\n      </article><!-- box_interview/ -->\n    </section><!-- area_interview/ -->\n\n    <ul class=\"link_depertment_wrap\">\n      <li class=\"link_depertment sales\"><a href=\"/recruit/sales/\"><span class=\"txt\">営業部</span></a></li>\n      <li class=\"link_depertment engineer\"><a href=\"/recruit/engineer/\"><span class=\"txt\">技術部</span></a></li>\n      <li class=\"link_depertment service\"><a href=\"/recruit/service/\"><span class=\"txt\">保守サービス部</span></a></li>\n      <li class=\"link_depertment affairs\"><a href=\"/recruit/affairs/\"><span class=\"txt\">総務部</span></a></li>\n    </ul>\n  </div>\n    <footer class=\"footer\"><!-- footer -->\n      <div class=\"wrap\">\n        <ul class=\"footer_menu_wrap\">\n          <li class=\"footer_menu\">\n            <a href=\"/solution/\" class=\"solution\">\n              <div class=\"box_img\"><img src=\"/common/img/common/ico_solution_w.png\" alt=\"\"></div>導入をご検討の方\n            </a>\n          </li>\n          <li class=\"footer_menu\">\n            <a href=\"/maintenance/\" class=\"maintenance\">\n              <div class=\"box_img\"><img src=\"/common/img/common/ico_maintenance_w.png\" alt=\"\"></div>保守をご検討の方\n            </a>\n          </li>\n          <li class=\"footer_menu\">\n            <a href=\"/repair/\" class=\"repair\">\n              <div class=\"box_img\"><img src=\"/common/img/common/ico_repair_w.png\" alt=\"\"></div>修理をご希望の方\n            </a>\n          </li>\n          <li class=\"footer_menu\">\n            <a href=\"/info/\" class=\"info\">\n              <div class=\"box_img\"><img src=\"/common/img/common/ico_info_w.gif\" alt=\"\"></div>お知らせ\n            </a>\n          </li>\n        </ul>\n        <div class=\"footer_bottom\">\n          <div class=\"box_cominfo\">\n            <a href=\"/\" class=\"link_top\"><img src=\"/common/img/common/logo.png\" alt=\"ロゴ：株式会社メレックのロゴです。\"></a>\n            <address class=\"box_ads\">〒700-0033　岡山市北区島田本町一丁目2番25