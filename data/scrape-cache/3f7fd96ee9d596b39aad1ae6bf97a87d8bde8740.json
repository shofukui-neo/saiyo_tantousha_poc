{"url":"https://map.jp/support/contactform/map_form/index.php","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>地図表記に関して お問い合わせフォーム</title>\n<link rel=\"icon\" type=\"image/x-icon\" href=\"../favicon.ico\">\n<link rel=\"stylesheet\" href=\"../css/style.css\">\n<style>\n:root {\n    --theme-color: #0C9000;\n    --base-color:  #DEF2D6;\n}\n</style>\n</head>\n<body>\n\n<div class=\"page-wrapper\">\n    <div class=\"form-header\">\n        <div class=\"product-title\">地図表記に関して</div>\n    </div>\n\n    <div class=\"form-container\">\n        <p class=\"form-intro\">\n            地図の表記に関するお問い合わせフォームです。<br>\n            必要事項をご入力の上、送信してください。担当者よりご連絡いたします。\n        </p>\n\n        \n        <form method=\"post\" action=\"index.php\" novalidate>\n            <input type=\"hidden\" name=\"csrf_token\" value=\"332921598046b57f8fb2457b966dc37e\">\n\n            <!-- 担当者名 -->\n            <div class=\"form-group\">\n                <label class=\"field-label\" for=\"name\">お名前 <span class=\"required-mark\">必須</span></label>\n                <input type=\"text\" id=\"name\" name=\"name\"\n                       value=\"\" maxlength=\"100\" autocomplete=\"name\"\n                       class=\"\">\n                \n                <label class=\"field-label\" for=\"furigana\" style=\"margin-top:10px;\">ふりがな <span class=\"required-mark\">必須</span></label>\n                <input type=\"text\" id=\"furigana\" name=\"furigana\"\n                       value=\"\" maxlength=\"100\" placeholder=\"やまだ たろう\"\n                       class=\"\">\n                            </div>\n\n            <!-- 法人名・部署・業種 -->\n            <div class=\"form-group\">\n                <label class=\"field-label\" for=\"company_name\">法人名（個人の場合は不要）</label>\n                <input type=\"text\" id=\"company_name\" name=\"company_name\"\n                       value=\"\" maxlength=\"100\" autocomplete=\"organization\">\n\n                <label class=\"field-label\" for=\"department\" style=\"margin-top:10px;\">部署名（個人の場合は不要）</label>\n                <input type=\"text\" id=\"department\" name=\"department\"\n                       value=\"\" maxlength=\"100\">\n\n                <label class=\"field-label\" for=\"industry\" style=\"margin-top:10px;\">業種（個人の場合は不要）</label>\n                <input type=\"text\" id=\"industry\" name=\"industry\"\n                       value=\"\" maxlength=\"100\">\n            </div>\n\n            <!-- 電話番号 -->\n            <div class=\"form-group\">\n                <label class=\"field-label\" for=\"phone\">電話番号 <span class=\"required-mark\">必須</span></label>\n                <p class=\"field-note\">半角でご入力ください</p>\n                <input type=\"tel\" id=\"phone\" name=\"phone\"\n                       value=\"\" placeholder=\"000-000-0000\" maxlength=\"15\"\n                       class=\"\">\n                            </div>\n\n            <!-- メールアドレス -->\n            <div class=\"form-group\">\n                <label class=\"field-label\" for=\"email\">Eメールアドレス <span class=\"required-mark\">必須</span></label>\n                <p class=\"field-note\">半角でご入力ください</p>\n                <input type=\"email\" id=\"email\" name=\"email\"\n                       value=\"\" maxlength=\"200\"\n                       class=\"\">\n                \n                <label class=\"field-label\" for=\"email_confirm\" style=\"margin-top:10px;\">Eメールアドレス（確認） <span class=\"required-mark\">必須</span></label>\n                <input type=\"email\" id=\"email_confirm\" name=\"email_confirm\"\n                       value=\"\" maxlength=\"200\"\n                       placeholder=\"もう一度入力してください\"\n                       class=\"\">\n                            </div>\n\n            <!-- 住所 -->\n            <div class=\"form-group\">\n                <label class=\"field-label\">住所（任意）</label>\n                <div class=\"address-row\" style=\"margin-bottom:6px;\">\n                    <span class=\"postal-mark\">〒</span>\n                    <input type=\"text\" id=\"postal_code\" name=\"postal_code\"\n                           value=\"\"\n                           placeholder=\"000-0000\" maxlength=\"8\" style=\"width:120px;\">\n                    <span style=\"font-size:12px;color:#888;margin-left:6px;\">入力すると住所が自動入力されます</span>\n                </div>\n                <input type=\"text\" id=\"address\" name=\"address\"\n                       value=\"\"\n                       placeholder=\"都道府県・市区町村・丁目番地・建物名等\" maxlength=\"300\"\n                       style=\"margin-top:0;\">\n            </div>\n\n            <hr class=\"section-divider\">\n\n            <!-- ご覧になった商品・サービス名 -->\n            <div class=\"form-group\">\n                <label class=\"field-label\" for=\"product_service\">ご覧になった商品・サービス名 <span class=\"required-mark\">必須</span></label>\n                <select id=\"product_service\" name=\"product_service\"\n                        onchange=\"toggleOther('product_service', 'ps_other_wrap')\"\n                        class=\"\">\n                    <option value=\"\">-- 選択してください --</option>\n                                        <option value=\"Dメーサイズ\" >Dメーサイズ</option>\n                                        <option value=\"スマートGIS標\" >スマートGIS標</option>\n                                        <option value=\"マイサイズ\" >マイサイズ</option>\n                                        <option value=\"校区地図\" >校区地図</option>\n                                        <option value=\"その他\" >その他</option>\n                                    </select>\n                <div id=\"ps_other_wrap\" style=\"display:none; margin-top:6px;\">\n                    <input type=\"text\" name=\"product_service_other\"\n                           value=\"\"\n                           placeholder=\"商品・サービス名を入力\" maxlength=\"100\">\n                </div>\n                            </div>\n\n            <!-- 指摘箇所とお客様の関係 -->\n            <div class=\"form-group\">\n                <label class=\"field-label\">指摘箇所とお客様の関係 <span class=\"required-mark\">必須</span></label>\n                <div class=\"radio-group\">\n                                        <label class=\"radio-label\">\n                        <input type=\"radio\" name=\"relationship\" value=\"責任者\"\n                               onclick=\"toggleOther2('relationship', 'rel_other_wrap')\"\n                               >\n                        責任者                    </label>\n                                        <label class=\"radio-label\">\n                        <input type=\"radio\" name=\"relationship\" value=\"関係者\"\n                               onclick=\"toggleOther2('relationship', 'rel_other_wrap')\"\n                               >\n                        関係者                    </label>\n                                        <label class=\"radio-label\">\n                        <input type=\"radio\" name=\"relationship\" value=\"世帯主\"\n                               onclick=\"toggleOther2('relationship', 'rel_other_wrap')\"\n                               >\n                        世帯主                    </label>\n                                        <label class=\"radio-label\">\n                        <input type=\"radio\" name=\"relationship\" value=\"同居家族\"\n                               onclick=\"toggleOther2('relationship', 'rel_other_wrap')\"\n                               >\n                        同居家族                    </label>\n                                        <label class=\"radio-label\">\n                        <input type=\"radio\" name=\"relationship\" value=\"その他\"\n                               onclick=\"toggleOther2('relationship', 'rel_other_wrap')\"\n                               >\n                        その他                    </label>\n                                    </div>\n                <div id=\"rel_other_wrap\" style=\"display:none; margin-top:6px;\">\n                    <input type=\"text\" name=\"relationship_other\"\n                           value=\"\"\n                           placeholder=\"関係を入力してください\" maxlength=\"100\">\n                </div>\n                            </div>\n\n            <!-- 訂正理由 -->\n            <div class=\"form-group\">\n                <label class=\"field-label\">訂正理由 <span class=\"required-mark\">必須</span></label>\n                <div class=\"radio-group\">\n                                        <label class=\"radio-label\">\n                        <input type=\"radio\" name=\"correction_reason\" value=\"開業\"\n                               onclick=\"toggleOther2('correction_reason', 'cr_other_wrap')\"\n                               >\n                        開業                    </label>\n                                        <label class=\"radio-label\">\n                        <input type=\"radio\" name=\"correction_reason\" value=\"新築\"\n                               onclick=\"toggleOther2('correction_reason', 'cr_other_wrap')\"\n                               >\n                        新築                    </label>\n                                        <label class=\"radio-label\">\n                        <input type=\"radio\" name=\"correction_reason\" value=\"移転\"\n                               onclick=\"toggleOther2('correction_reason', 'cr_other_wrap')\"\n                               >\n                        移転                    </label>\n                                        <label class=\"radio-label\">\n                        <input type=\"radio\" name=\"correction_reason\" value=\"変更\"\n                               onclick=\"toggleOther2('correction_reason', 'cr_other_wrap')\"\n                               >\n                        変更                    </label>\n                                        <label class=\"radio-label\">\n                        <input type=\"radio\" name=\"correction_reason\" value=\"誤記\"\n                               onclick=\"toggleOther2('correction_reason', 'cr_other_wrap')\"\n                               >\n                        誤記                    </label>\n                                        <label class=\"radio-label\">\n                        <input type=\"radio\" name=\"correction_reason\" value=\"その他\"\n                               onclick=\"toggleOther2('correction_reason', 'cr_other_wrap')\"\n                               >\n                        その他                    </label>\n                                    </div>\n                <div id=\"cr_other_wrap\" style=\"display:none; margin-top:6px;\">\n                    <input type=\"text\" name=\"correction_reason_other\"\n                           value=\"\"\n                           placeholder=\"訂正理由を入力してください\" maxlength=\"100\">\n                </div>\n                            </div>\n\n            <!-- 訂正前（誤）の情報 -->\n            <div class=\"form-group\">\n                <label class=\"field-label\" for=\"correction_before\">訂正前（誤）の情報 <span class=\"required-mark\">必須</span></label>\n                <p class=\"field-note\">名称、住所、番地等を具体的に記入してください。記入内容が不明瞭である場合、対応できない場合があります。</p>\n                <textarea id=\"correction_before\" name=\"correction_before\"\n                          class=\"\"></textarea>\n                            </div>\n\n            <!-- 訂正後（正）の情報 -->\n            <div class=\"form-group\">\n                <label class=\"field-label\" for=\"correction_after\">訂正後（正）の情報 <span class=\"required-mark\">必須</span></label>\n                <textarea id=\"correction_after\" name=\"correction_after\"\n                          class=\"\"></textarea>\n                            </div>\n\n            <!-- その他記入欄 -->\n            <div class=\"form-group\">\n                <label class=\"field-label\" for=\"other_notes\">その他記入欄（任意）</label>\n                <textarea id=\"other_notes\" name=\"other_notes\"></textarea>\n            </div>\n\n            <hr class=\"section-divider\">\n\n            <div class=\"privacy-box\">\n                <h3>お問い合わせに関する個人情報の取り扱い</h3>\n                <p>ご登録いただいた情報は、当社の<a href=\"https://map.jp/index/privacypolicy.html\" target=\"_blank\">プライバシーポリシー</a>に従い適正に管理しています。</p>\n                <p>ご登録いただいた情報は、お客様からのお問い合わせやご依頼内容に的確に対応することを目的に限定して利用します。</p>\n                <p>これ以外の目的で利用したり、第三者に提供もしくは預託することはありません。</p>\n                <label class=\"privacy-agree-label\">\n                    <input type=\"checkbox\" name=\"privacy_agree\" value=\"1\"\n                           >\n                    個人情報の取り扱いに同意する\n                    <span class=\"required-mark\">必須</span>\n                </label>\n                            </div>\n\n            <div class=\"red-notes\">\n                <p>※お問い合わせいただいたメールの返信は当社営業時間内となります。ご了承ください。</p>\n                <p>※返信メールアドレスに送信できない場合や、問い合わせの内容によってお電話させていただく場合がございます。</p>\n            </div>\n\n            <!-- ハニーポット：ボット対策（人間には見えません） -->\n            <div style=\"display:none !important; position:absolute; left:-9999px;\" aria-hidden=\"true\">\n                <input type=\"text\" name=\"website\" tabindex=\"-1\" autocomplete=\"off\">\n            </div>\n            <button type=\"submit\" class=\"btn-submit\">確認画面へ</button>\n        </form>\n    </div>\n</div>\n\n<script>\nfunction toggleOther(selId, wrapId) {\n    var sel = document.getElementById(selId);\n    document.getElementById(wrapId).style.display = (sel.value === 'その他') ? 'block' : 'none';\n}\nfunction toggleOther2(radioName, wrapId) {\n    var radios = document.getElementsByName(radioName);\n    var val = '';\n    for (var i = 0; i < radios.length; i++) {\n        if (radios[i].checked) { val = radios[i].value; break; }\n    }\n    document.getElementById(wrapId).style.display = (val === 'その他') ? 'block' : 'none';\n}\n\nvar PREFS = ['','北海道','青森県','岩手県','宮城県','秋田県','山形県','福島県','茨城県','栃木県','群馬県','埼玉県','千葉県','東京都','神奈川県','新潟県','富山県','石川県','福井県','山梨県','長野県','岐阜県','静岡県','愛知県','三重県','滋賀県','京都府','大阪府','兵庫県','奈良県','和歌山県','鳥取県','島根県','岡山県','広島県','山口県','徳島県','香川県','愛媛県','高知県','福岡県','佐賀県','長崎県','熊本県','大分県','宮崎県','鹿児島県','沖縄県'];\nfunction autoFillFromZip(code, addressField) {\n    var s = document.getElementById('_zs');\n    if (s) s.parentNode.removeChild(s);\n    window.$yubin = function(d) {\n        var v = d[code];\n        if (v) {\n            var pref = (typeof v[0] === 'number') ? (PREFS[v[0]] || '') : (v[0] || '');\n            addressField.value = pref + (v[1]||'') + (v[2]||'');\n        }\n    };\n    s = document.createElement('script');\n    s.id = '_zs';\n    s.src = 'https://yubinbango.github.io/yubinbango-data/data/' + code.substring(0,3) + '.js';\n    document.head.appendChild(s);\n}\nvar postalInput = document.getElementById('postal_code');\nvar addressInput = document.getElementById('address');\nif (postalInput && addressInput) {\n    postalInput.onblur = function() {\n        var raw = this.value.replace(/[^0-9]/g, '');\n        if (raw.length > 3) this.value = raw.substring(0,3) + '-' + raw.substring(3,7);\n        else this.value = raw;\n        if (raw.length === 7) autoFillFromZip(raw, addressInput);\n    };\n    postalInput.onkeyup = function() {\n        var raw = this.value.replace(/[^0-9]/g, '');\n        if (raw.length === 7) autoFillFromZip(raw, addressInput);\n    };\n}\n</script>\n\n<p class=\"site-copyright\">&copy; 2026 KANKOSHA Co., Ltd.</p>\n</body>\n</html>\n","finalUrl":"https://map.jp/support/contactform/map_form/index.php","rendered":false,"_cachedAt":"2026-06-23T20:42:51.871Z"}