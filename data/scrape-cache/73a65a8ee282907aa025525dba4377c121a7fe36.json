page\">\r\n<!-- Google Tag Manager (noscript) -->\r\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-MCBZZPJS\"\r\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\r\n<!-- End Google Tag Manager (noscript) -->\r\n  <header id=\"header-area\">\r\n  </header>\r\n  <div id=\"navi-global-area\">\r\n  </div>\r\n  <div class=\"bg\">\r\n    <div class=\"mask\"></div>\r\n    <div class=\"mv\">\r\n      <video webkit-playsinline playsinline autoplay loop muted>\r\n        <source src=\"img/mv.mp4\" type=\"video/mp4\" />\r\n      </video>\r\n    </div>\r\n  </div>\r\n  <article>\r\n    <div class=\"empty\">\r\n      <div class=\"ttl\">\r\n        <h1 class=\"fade-in fade-in-up\"><img src=\"img/catch.svg\" alt=\"\"/></h1>\r\n      </div>\r\n    </div>\r\n    <div class=\"top-text-area\">\r\n      <p class=\"fade-in fade-in-up\"><img src=\"img/txt01_pc.svg\" class=\"pc-ver\" alt=\"\"/><img src=\"img/txt01_sp.svg\" class=\"sp-ver\" alt=\"\"/></p>\r\n      <p class=\"fade-in fade-in-up\"><img src=\"img/txt02_pc.svg\" class=\"pc-ver\" alt=\"\"/><img src=\"img/txt02_sp.svg\" class=\"sp-ver\" alt=\"\"/></p>\r\n      <p class=\"fade-in fade-in-up\"><img src=\"img/txt03_pc.svg\" class=\"pc-ver\" alt=\"\"/><img src=\"img/txt03_sp.svg\" class=\"sp-ver\" alt=\"\"/></p>\r\n      <p class=\"fade-in fade-in-up\"><img src=\"img/txt04_pc.svg\" class=\"pc-ver\" alt=\"\"/><img src=\"img/txt04_sp.svg\" class=\"sp-ver\" alt=\"\"/></p>\r\n      <p class=\"fade-in fade-in-up\"><img src=\"img/txt05_pc.svg\" class=\"pc-ver\" alt=\"\"/><img src=\"img/txt05_sp.svg\" class=\"sp-ver\" alt=\"\"/></p>\r\n      <p class=\"fade-in fade-in-up\"><img src=\"img/txt06_pc.svg\" class=\"pc-ver\" alt=\"\"/><img src=\"img/txt06_sp.svg\" class=\"sp-ver\" alt=\"\"/></p>\r\n      <p class=\"fade-in fade-in-up\"><img src=\"img/txt07_pc.svg\" class=\"pc-ver\" alt=\"\"/><img src=\"img/txt07_sp.svg\" class=\"sp-ver\" alt=\"\"/></p>\r\n    </div>\r\n    <section class=\"news-sec fade-in fade-in-up\">\r\n      <h2>NEWS</h2>\r\n      <dl class=\"news\">\r\n        <div>\r\n          <dt>2025年7月</dt>\r\n          <dd><a href=\"https://www.i-note.jp/kaneka/2027event/index.html\" target=\"_blank\">2027 イベントページを開設しました。</a></dd>\r\n        </div>\r\n        <div>\r\n          <dt>2025年6月</dt>\r\n          <dd>スペシャルコンテンツ「カネカを早わかり！」および「採用情報」（初任給等）を更新しました。</dd>\r\n        </div>\r\n        <div>\r\n          <dt>2025年1月</dt>\r\n          <dd>採用サイトをリニューアルしました。</dd>\r\n        </div>\r\n      </dl>\r\n    </section>\r\n    <div class=\"special-contents\">\r\n      <section class=\"chikara-sec\">\r\n        <div class=\"images fade-in fade-in-up\">\r\n          <figure class=\"image image1\"></figure>\r\n          <figure class=\"image image2\"></figure>\r\n          <figure class=\"image image3\"></figure>\r\n          <figure class=\"image image4\"></figure>\r\n          <figure class=\"image image5\"><figcaption class=\"cr\">&copy;JAXA・NASA</figcaption></figure>\r\n        </div>\r\n        <div class=\"detail\">\r\n          <h2 class=\"fade-in fade-in-up\"><img src=\"img/ttl_chikara.svg\" alt=\"\"/></h2>\r\n          <div class=\"text fade-in fade-in-up\">\r\n            <p>カガクにはどのようなチカラがあり、社会に何をもたらすのか。<br>カガクが秘めるポテンシャルと、カネカの社会課題解決力を<br>わかりやすくひもときます。</p>\r\n            <a href=\"chikara/\" class=\"btn-more\"><span>MORE</span></a>\r\n          </div>\r\n        </div>\r\n      </section>\r\n      \r\n      <section class=\"guidebook-sec\">\r\n        <figure class=\"image fade-in fade-in-up\"><img src=\"img/img_guidebook.jpg\" alt=\"\"/></figure>\r\n        <div class=\"detail fade-in fade-in-up\">\r\n          <h2><img src=\"img/ttl_guidebook.svg\" alt=\"\"/></h2>\r\n          <p>さまざまな数字からカネカを概観するコンテンツです。</p>\r\n          <a href=\"guidebook/\" class=\"btn-more\"><span>MORE</span></a>\r\n        </div>\r\n      </section>\r\n      \r\n      <section class=\"fourbiz-sec\">\r\n        <figure class=\"image fade-in fade-in-up\"><img src=\"img/img_fourbiz.png\" alt=\"\"/></figure>\r\n        <div class=\"detail fade-in fade-in-up\">\r\n          <h2><img src=\"img/ttl_fourbiz.svg\" alt=\"\"/></h2>\r\n          <p>オリジナリティあふれる<br>価値を提供するカネカの4事業。<br>各分野における市場や社会への貢献についてご紹介します。</p>\r\n          <a href=\"fourbiz/\" class=\"btn-more\"><span>MORE</span></a>\r\n        </div>\r\n      </section>\r\n      \r\n      <section class=\"choose-sec\">\r\n        <div class=\"detail fade-in fade-in-up\">\r\n          <h2><img src=\"img/ttl_choose.svg\" alt=\"\"/></h2>\r\n          <p>世の中に数多ある業界・企業の中から、就職先にカネカを選ぶとはどういうことなのか？<br>どういう観点で検討・選択すればよいのか？<br>そんなみなさんの疑問に、さまざまな角度から採用担当者がお答えするシリーズコンテンツです。</p>\r\n        </div>\r\n        <div class=\"choose-list fade-in fade-in-up\">\r\n          <div class=\"swiper-wrapper\"> \r\n            <!-- ARTICLE -->\r\n            <section class=\"swiper-slide article-item\" data-category=\"all\">\r\n              <a href=\"choose/article001/index.html\">\r\n                <figure class=\"image\"><img src=\"choose/article001/img/thumb.jpg\" alt=\"\"/></figure>\r\n                <div class=\"detail\">\r\n                  <h3>カネカのキャリアに、<br>決まったレールはない</h3>\r\n                </div>\r\n              </a>\r\n            </section>\r\n            <!--// ARTICLE --> \r\n            <!-- ARTICLE -->\r\n            <section class=\"swiper-slide article-item\" data-category=\"all\">\r\n              <a href=\"choose/article002/index.html\">\r\n                <figure class=\"image\"><img src=\"choose/article002/img/thumb.jpg\" alt=\"\"/></figure>\r\n                <div class=\"detail\">\r\n                  <h3>他の化学メーカーとの間で<br>悩んでいるあなたへ</h3>\r\n                </div>\r\n              </a>\r\n            </section>\r\n            <!--// ARTICLE --> \r\n            <!-- ARTICLE -->\r\n            <section class=\"swiper-slide article-item\" data-category=\"tech\">\r\n              <a href=\"choose/article003/index.html\">\r\n                <figure class=\"image\"><img src=\"choose/article003/img/thumb.jpg\" alt=\"\"/></figure>\r\n                <div class=\"detail\">\r\n                  <h3>プラントエンジニアの魅力って？</h3>\r\n                </div>\r\n              </a>\r\n            </section>\r\n            <!--// ARTICLE --> \r\n            <!-- ARTICLE -->\r\n            <section class=\"swiper-slide article-item\" data-category=\"all\">\r\n              <a href=\"choose/article004/index.html\">\r\n                <figure class=\"image\"><img src=\"choose/article004/img/thumb.jpg\" alt=\"\"/></figure>\r\n                <div class=\"detail\">\r\n                  <h3>カネカをリアルに体感して、<br>マッチングを図ってみよう</h3>\r\n                </div>\r\n              </a>\r\n            </section>\r\n            <!--// ARTICLE --> \r\n            <!-- ARTICLE -->\r\n            <section class=\"swiper-slide article-item\" data-category=\"tech\">\r\n              <a href=\"choose/article005/index.html\">\r\n                <figure class=\"image\"><img src=\"choose/article005/img/thumb.jpg\" alt=\"\"/></figure>\r\n                <div class=\"detail\">\r\n                  <h3>技術系の面接で重視するのは<br>「技術者としての将来性」！</h3>\r\n                </div>\r\n              </a>\r\n            </section>\r\n            <!--// ARTICLE --> \r\n            <!-- ARTICLE -->\r\n            <section class=\"swiper-slide article-item\" data-category=\"office\">\r\n              <a href=\"choose/article006/index.html\">\r\n                <figure class=\"image\"><img src=\"choose/article006/img/thumb.jpg\" alt=\"\"/></figure>\r\n                <div class=\"detail\">\r\n                  <h3>事務系の選考で大切にしているのは「一人ひとりとのマッチング」！</h3>\r\n                </div>\r\n              </a>\r\n            </section>\r\n            <!--// ARTICLE --> \r\n            <!-- ARTICLE -->\r\n            <section class=\"swiper-slide article-item\" data-category=\"techcol\">\r\n              <a href=\"choose/article007/index.html\">\r\n                <figure class=\"image\"><img src=\"choose/article007/img/thumb.jpg\" alt=\"\"/></figure>\r\n                <div class=\"detail\">\r\n                  <h3>高専卒採用にかける想い</h3>\r\n                </div>\r\n              </a>\r\n            </section>\r\n            <!--// ARTICLE --> \r\n            <!-- ARTICLE -->\r\n            <section class=\"swiper-slide article-item\" data-category=\"highschool\">\r\n              <a href=\"choose/article008/index.html\">\r\n                <figure class=\"image\"><img src=\"choose/article008/img/thumb.jpg\" alt=\"\"/></figure>\r\n                <div class=\"detail\">\r\n                  <h3>カネカの高卒採用は「ココが違う！」</h3>\r\n                </div>\r\n              </a>\r\n            </section>\r\n            <!--// ARTICLE --> \r\n          </div>\r\n          <div class=\"control-set\">\r\n            <div class=\"swiper-pagination\"></div>\r\n            <div class=\"page-prevnext\">\r\n              <div class=\"swiper-button-prev\"></div>\r\n              <div class=\"swiper-button-next\"></div>\r\n            </div>\r\n            <a href=\"choose/index.html\" class=\"btn-all\"><span>ALL</span></a> </div>\r\n        </div>\r\n      </section>\r\n    </div>\r\n  </article>\r\n  <footer id=\"footer-area\">\r\n  </footer>\r\n<script src=\"//ajax.googleapis.com/ajax/libs/jquery/3.6.2/jquery.min.js\"></script>\r\n<script src=\"common/js/swiper.min.js\"></script>\r\n<script src=\"common/js/common.js\"></script>\r\n<script src=\"js/script.js\"></script>\r\n</body>\r\n</html>\r\n","finalUrl":"https://www.kaneka.co.jp/recruitment/","rendered":false,"_cachedAt":"2026-06-23T17:35:51.066Z"}