{"url":"https://www.nishi-tc.co.jp/recruit/career04.html","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n  <head>\n    <meta charset=\"utf-8\" />\n    <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge,chrome=1\" />\n    <meta\n      name=\"keywords\"\n      content=\"西谷技術,西谷技術コンサルタント,西谷技術コンサルタント,新卒採用,新卒,鳥取,設計,地質調査,測量調査\"\n    />\n    <meta\n      name=\"description\"\n      content=\"西谷技術コンサルタント株式会社 2014年入社の測量調査部の先輩の声をお届けします。仕事内容やタイムスケジュールをご覧いただけます。\"\n    />\n    <title>\n      上司からのメッセージ 2026年度新卒採用情報 西谷技術コンサルタント株式会社\n    </title>\n    <link href=\"css/reset.css\" rel=\"stylesheet\" type=\"text/css\" />\n    <link href=\"css/common.css\" rel=\"stylesheet\" type=\"text/css\" />\n    <link href=\"css/voice.css\" rel=\"stylesheet\" type=\"text/css\" />\n    <link rel=\"stylesheet\" href=\"css/drawer.min.css\" />\n    <link rel=\"stylesheet\" href=\"css/animate.css\" />\n    <script\n      type=\"text/javascript\"\n      src=\"https://ajax.googleapis.com/ajax/libs/jquery/1.9.1/jquery.min.js\"\n    ></script>\n    <script type=\"text/javascript\" src=\"js/yuga.js\"></script>\n    <script src=\"js/wow.min.js\"></script>\n    <script type=\"text/javascript\" charset=\"utf-8\">\n      new WOW().init();\n    </script>\n    <script type=\"text/javascript\" charset=\"utf-8\">\n      $(document).ready(function () {\n        $(\".drawer\").drawer();\n      });\n    </script>\n  </head>\n\n  <body class=\"drawer drawer--left\">\n    <!--ここからヘッダー-->\n    <header style=\"z-index: 1000\">\n      <div class=\"top_navi\">\n        <ul>\n          <li>\n            <a href=\"../index.html\"\n              ><img src=\"images/navi/navi_nishitani.png\"\n            /></a>\n          </li>\n          <li style=\"margin: 0px 100px 0px 50px\">\n            <a href=\"./index.html\"\n              ><img src=\"images/navi/recruit_title.png\"\n            /></a>\n          </li>\n          <li>\n            <a\n              href=\"https://job.mynavi.jp/28/pc/search/corp207090/outline.html\"