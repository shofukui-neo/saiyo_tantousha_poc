n options-hidden></mf-search-box>\n            </div>\n            <script src=\"https://ce.mf.marsflag.com/latest/js/mf-search.js\"></script>\n          </div>\n        </div><!--/#SearchFormArea-->\n      </div><!--/#SupportNavi-->\n      <button id=\"SpMenuBtn\" aria-label=\"メニュー\">\n        <span></span>\n        <span></span>\n        <span></span>\n      </button>\n    </div><!--/.Container-->\n  </div><!--/#HeaderArea1-->\n      <div id=\"HeaderArea2\">\n        <div class=\"Container Wide\">\n                  <h1 id=\"SiteID\">\n                    <a href=\"/\"><span>株式会社 日立ソリューションズ東日本</span></a>\n                  </h1>\n              <ul id=\"GlobalNaviMenu\">\n                  <li><a href=\"/products/\" onclick=\"\">商品/ソリューション</a></li>\n                  <li><a href=\"/case/\" onclick=\"\">導入事例</a></li>\n                  <li><a href=\"/seminar/\" onclick=\"\">セミナー/展示会</a></li>\n                  <li><a href=\"/company/\" onclick=\"\">会社情報/サステナビリティ</a></li>\n                  <li><a href=\"/recruitment/\" onclick=\"\">採用サイト</a></li>\n                  <li><a href=\"/download/\" onclick=\"\">カタログダウンロード</a></li>\n                  <li><a href=\"/owndmedia/\" onclick=\"\">ビジネスコラム</a></li>\n              </ul>\n        </div><!--/.Container-->\n      </div><!--/#HeaderArea2-->\n  <div id=\"TopicPath\">\n    <div id=\"breadCrumb\">\n      <ul class=\"clearfix\">\n        <li><a href=\"/index.html\">TOP</a></li>\n        <li><a href=\"/recruitment/\">採用サイト</a></li>\n        <li>募集要項</li>\n    </ul>\n    </div>\n  </div>\n  <!--/TopicPath-->\n\n  <div id=\"Contents\" class=\"er-reset\" data-dir=\"bosyuu\">\n    <div id=\"ContentsTop\"></div>\n    <!-- Nav -->\n    <nav id=\"er-l-navG\" class=\"js-globalNav\">\n      <a id=\"er-l-drawerBtn\" class=\"js-drawerbtn\">\n        <div class=\"er-l-drawerBtn_border\"><span></span><span></span></div>\n      </a>\n      <div class=\"er-l-drawer js-drawer\">\n        <div class=\"er-l-drawer_inner js-drawer_inner\">\n          <ul class=\"er-l-navG_item-a_wrapper\">\n            <li>\n              <a class=\"er-l-navG_item-a\" href=\"/recruitment/\"><span class=\"er-font-2\">TOP</span></a>\n            </li>\n            <li>\n              <a class=\"er-l-navG_item-a\" href=\"/recruitment/knowledge/\"><span class=\"er-font-2\">ABOUT</span><small>日立ソリューションズ東日本とは</small></a>\n            </li>\n            <li>\n              <a class=\"er-l-navG_item-a\" href=\"/recruitment/humanjob/\"><span class=\"er-font-2\">WORKS</span><small>私たちの仕事と人財</small></a>\n            </li>\n            <li>\n              <a class=\"er-l-navG_item-a\" href=\"/recruitment/career/\"><span class=\"er-font-2\">CAREER</span><small>自分らしいキャリアを実現する環境</small></a>\n            </li>\n            <li>\n              <a class=\"er-l-navG_item-a\" href=\"/recruitment/recruit/entry/\"><span class=\"er-font-2\">ENENT&ENTRY</span><small>イベント情報・エントリー</small></a>\n            </li>\n          </ul>\n        </div>\n      </div>\n    </nav>\n    <!-- /Nav -->\n    <!-- Side -->\n    <div id=\"er-l-side\" class=\"js-side\">\n      <a class=\"er-l-side_btn-1\" href=\"https://js02.jposting.net/hitachi-solutions-east/u/job.phtml\" target=\"_blank\">キャリア<br>採用</a>\n      <a class=\"er-l-side_btn-2\" href=\"/recruitment/recruit/bosyuu/\">新卒採用</a>\n    </div>\n    <!-- /Side -->\n    <div id=\"er-p-pageHead\">\n      <div class=\"er-p-pageHead_inner\">\n        <h1 class=\"er-p-pageHead_title\"><span>新卒採用</span></h1>\n      </div>\n    </div>\n    <div id=\"ep-p-pageContents\">\n      <div class=\"er-p-recruit er-p-bosyuu\">\n        <div class=\"er-p-contents\">\n          <p class=\"er-p-page-title\">募集に関して</p>\n          <ul class=\"er-p-careeriList\">\n            <li class=\"er-p-list-item\">\n              <dl class=\"er-listBox flex-box\">\n                <dt class=\"er-page-text\">仕事内容</dt>\n                <dd>\n                  <p class=\"er-page-text\">1.システムエンジニア<br>\n                    様々な業種・分野のお客様に対し、経営戦略の実現や業務効率化に向けた課題を分析した上で、解決策の提案、要件定義、システムの設計、開発(プログラミング・テスト)、運用までを一貫して行います。これらのソリューション提供にあたり、技術開発・研究、データ分析、コンサルティングといった領域の業務を担うエンジニアもいます。</p>\n                  <p class=\"er-page-text\">2.ソリューション営業<br>\n                    お客様と会社をつなぐ窓口として、システムエンジニアと連携してお客様の課題やニーズに応えます。<br>\n                    ソリューション提案に伴う見積作成や商談、契約締結までの諸対応を行います。またお客様に提供したシステムのアフターサポートや、 満足度の調査に基づいた改善を行い、継続的な取引に結びつけていきます。</p>\n                  <p class=\"er-page-text\">3.コーポレートスタッフ(人事)<br>\n                    職場と経営のニーズを総合的に把握して施策を企画・検討、実施していくことで社員や会社を支えていく仕事です。<br>\n                    基礎的な業務知識やスキルを習得していただく定型業務から、問い合わせ対応や他部門との調整といった非定型業務をはじめ、将来的には課題分析・経営層への提案や全社施策の企画・立案といった企画立案業務に携わっていただきます。</p>\n                </dd>\n              </dl>\n            </li>\n            <li class=\"er-p-list-item\">\n              <dl class=\"er-listBox flex-box\">\n                <dt class=\"er-page-text\">採用予定数</dt>\n                <dd class=\"er-page-text\">60名程度</dd>\n              </dl>\n            </li>\n            <li class=\"er-p-list-item\">\n              <dl class=\"er-listBox flex-box\">\n                <dt class=\"er-page-text\">応募資格</dt>\n                <dd class=\"er-page-text\">2027年3月 大学院、大学、高専、専門学校、短大を卒業予定の方(既卒者の応募可)<br>理系、文系とも全学科を対象としています。<br>\n                  プログラミング経験は問いません。</dd>\n              </dl>\n            </li>\n         </ul>\n\n          <p class=\"er-p-page-title fade-up\">勤務条件</p>\n          <ul class=\"er-p-careeriList fade-up\">\n            <li class=\"er-p-list-item\">\n              <dl class=\"er-listBox flex-box\">\n                <dt class=\"er-page-text\">給与</dt>\n                <dd class=\"er-page-text\">2026年度確定<br>\n                  大学院修了(修士)：284,000円<br>\n                  大学卒(学部)　　：259,000円<br>\n                  高専卒(専攻科)　：259,000円<br>\n                  高専卒(本科)　　：219,000円<br>\n                  専門学校卒(2年) ：219,000円<br>\n                  ※上記には地域手当10,000円(北海道・東北地区勤務の場合)を含みます。<br>\n                  京浜地区勤務の場合、地域手当は20,000円です。</dd>\n              </dl>\n            </li>\n            <li class=\"er-p-list-item\">\n              <dl class=\"er-listBox flex-box\">\n                <dt class=\"er-page-text\">諸手当</dt>\n                <dd class=\"er-page-text\">家族手当、 時間外勤務手当(全額支給)、 深夜勤務手当、 常駐手当、 住宅手当、 通勤手当(全額支給) など</dd>\n              </dl>\n            </li>\n            <li class=\"er-p-list-item\">\n              <dl class=\"er-listBox flex-box\">\n                <dt class=\"er-page-text\">休暇</dt>\n                <dd class=\"er-page-text\">年次有給休暇(24日／年(入社年度より)、 時間・半日単位で取得可)、<br>\n                  リフレッシュ休暇(勤続満10年以降5年毎に休暇付与)、<br>\n                  出産休暇(産前8週間 (法定6週間)、 産後8週間の休暇を取得可能)、<br>\n                  育児休暇(子が小学校1年生修了時の3月31日までの通算3年取得可能)、<br>\n                  配偶者出産休暇、 妊娠障害休暇、 妊娠通院休暇、 生理休暇、 不妊治療休暇、<br>\n                  介護休暇、 看護休暇、 転勤休暇、 慶弔休暇 など</dd>\n              </dl>\n            </li>\n          </ul>\n\n          <p class=\"er-p-page-title fade-up\">教育・研修</p>\n          <ul class=\"er-p-careeriList fade-up\">\n            <li class=\"er-p-list-item\">\n              <p class=\"er-page-text\">入社時：約3ヶ月間の新入社員教育 (ITの専門知識やビジネススキルを基礎から学びます)</p>\n              <p class=\"er-page-text\">配属後：日立グループの教育機関を利用した専門技術教育、各種階層別・テーマ別研修、海外派遣研修、経営研修など</p>\n            </li>\n          </ul>\n\n          <p class=\"er-p-page-title\">個人情報の取り扱いについて</p>\n          <ul class=\"er-p-careeriList\">\n            <li class=\"er-p-list-item er-page-text\"><a href=\"/recruitment/assets/pdf/kojinjoho.pdf\" target=\"_blank\">採用関連 個人情報取り扱い同意書</a>にてご確認ください。</li>\n          </ul>\n\n          <p class=\"er-p-page-title fade-up\">採用ステップ</p>\n          <ul class=\"er-p-saiyoFlow\">\n            <li class=\"er-p-saiyo-list flex-box fade-up\">\n              <div class=\"er-p-saiyo-num\">1</div>\n              <div class=\"er-p-saiyo-textarea\">\n                <p class=\"er-page-text\">エントリー<br class=\"disp-sp\">\n              (当社専用Webサイト「MyPage」より) <br class=\"disp-sp\"><a href=\"/recruitment/recruit/entry/\">エントリーはこちら</a> &gt;</p></div>\n            </li>\n            <li class=\"er-p-saiyo-list flex-box fade-up\">\n              <div class=\"er-p-saiyo-num\">2</div>\n              <div class=\"er-p-saiyo-textarea\">\n                <p class=\"er-page-text\">MyPage上での会社説明動画視聴</p>\n              </div>\n            </li>\n            <li class=\"er-p-saiyo-list flex-box fade-up\">\n              <div class=\"er-p-saiyo-num\">3</div>\n              <div class=\"er-p-saiyo-textarea\">\n                <p class=\"er-page-text\">エントリーシート選考 <br class=\"disp-sp\">※Web提出</p>\n              </div>\n            </li>\n            <li class=\"er-p-saiyo-list flex-box fade-up\">\n              <div class=\"er-p-saiyo-num\">4</div>\n              <div class=\"er-p-saiyo-textarea\">\n                <p class=\"er-page-text\">1次面接 <br class=\"disp-sp\">※オンライン実施</p>\n              </div>\n            </li>\n            <li class=\"er-p-saiyo-list flex-box fade-up\">\n              <div class=\"er-p-saiyo-num\">5</div>\n              <div class=\"er-p-saiyo-textarea\">\n                <p class=\"er-page-text\">最終面接 ※オンライン実施<br class=\"disp-sp\">(事前にWebテストあり)</p>\n              </div>\n            </li>\n            <li class=\"er-p-saiyo-list flex-box fade-up\">\n              <div class=\"er-p-saiyo-num\">6</div>\n              <div class=\"er-p-saiyo-textarea\">\n                <p class=\"er-page-text\">内々定</p>\n              </div>\n            </li>\n          </ul>\n\n          <p class=\"er-p-page-title fade-up\">選考日程</p>\n          <ul class=\"er-p-careeriList fade-up\">\n            <li class=\"er-p-list-item\">\n              <p class=\"er-page-text\">「MyPage」にてお知らせします。</p>\n              <div class=\"er-p-btnarea\">\n                <a href=\"https://job.axol.jp/bx/s/hse_27/entry/\" target=\"_blank\"><span>MyPageはこちらから</span></a>\n              </div>\n            </li>\n          </ul>\n\n          <p class=\"er-p-page-title fade-up\">採用関係連絡先</p>\n          <ul class=\"er-p-careeriList fade-up\">\n            <li class=\"er-p-list-item er-page-text\">株式会社 日立ソリューションズ東日本 人事部 採用担当<br>\n            〒980-0021 仙台市青葉区中央3丁目2番1号 青葉通プラザ5F<br>\n            大倉 すみれ：090-5565-1612<br>\n            清本 侑秀：070-4307-8099<br>\n            メール：hse-saiyou@hitachi-solutions.com\n            </li>\n          </ul>\n\n\n\n        </div>\n      </div>\n    </div>\n    <!-- FooterNav -->\n    <nav id=\"er-l-navF1\">\n      <ul class=\"er-l-navF1_list\">\n        <li>\n          <a class=\"er-l-navF1_link\" href=\"/recruitment/knowledge/\"><span class=\"er-font-2\">about</span></a>\n        </li>\n        <li>\n          <a class=\"er-l-navF1_link\" href=\"/recruitment/humanjob/\"><span class=\"er-font-2\">works</span></a>\n        </li>\n        <li>\n          <a class=\"er-l-navF1_link\" href=\"/recruitment/career/\"><span class=\"er-font-2\">career</span></a>\n        </li>\n        <li>\n          <a class=\"er-l-navF1_link\" href=\"/recruitment/recruit/entry/\"><span class=\"er-font-2\">event&entry</span></a>\n        </li>\n      </ul>\n    </nav>\n    <nav id=\"er-l-navF2\">\n      <ul class=\"er-l-navF2_list entry-nav\" data-dir=\"career\">\n        <li>\n          <a class=\"er-l-navF2_link\" href=\"https://js02.jposting.net/hitachi-solutions-east/u/job.phtml\" target=\"_blank\">キャリア採用</a>\n        </li>\n        <li>\n          <a class=\"er-l-navF2_link\" href=\"/recruitment/recruit/bosyuu/\">新卒採用</a>\n        </li>\n        <li>\n          <a class=\"er-l-navF2_link\" href=\"/recruitment/recruit/entry/\">イベント情報・<br class=\"disp-sp\">エントリー</a>\n        </li>\n      </ul>\n    </nav>\n    <!-- /FooterNav -->\n    <a href=\"#top\" class=\"PageTop SmoothScroll js-pagetop\"><span>TOP</span></a>\n  </div>\n  <!--/Contents-->\n\n  <div class=\"FatMenuWide\">\n    <div class=\"FatMenuSet\">\n      <div class=\"ClearFix\">\n        <h2 class=\"FMTitleLinkStyle2\">RECRUIT SITE</h2>\n      </div>\n      <div class=\"FMColumnMenuArea\">\n\n        <div class=\"FMGrid1\">\n          <div class=\"FMTop