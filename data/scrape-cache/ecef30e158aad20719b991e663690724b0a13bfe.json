onload=\"initialize();\">\n\n<script>\n    (function(i,s,o,g,r,a,m){i['GoogleAnalyticsObject']=r;i[r]=i[r]||function(){\n        (i[r].q=i[r].q||[]).push(arguments)},i[r].l=1*new Date();a=s.createElement(o),\n        m=s.getElementsByTagName(o)[0];a.async=1;a.src=g;m.parentNode.insertBefore(a,m)\n    })(window,document,'script','//www.google-analytics.com/analytics.js','ga');\n\n    ga('create', 'UA-57480345-1', 'auto');\n    ga('send', 'pageview');\n\n</script>\n<div id=\"wrapper\">\n\n    <div id=\"header_wrap\" class=\"wrap\">\n        <header id=\"header\">\n                        <p id=\"logo\"><a href=\"https://onozo.co.jp/en/\">ONOMICHI DOCKYARD</a></p>\n                        <nav id=\"gnav\">\n                <ul>\n                    <li class=\"\"><a href=\"https://onozo.co.jp/en/category/news\" class=\"gnav-news\">NEWS</a>\n  <ul>\n    <li><a href=\"https://onozo.co.jp/en/category/news\">WHAT'S NEWS</a></li>\n    <li><a href=\"https://onozo.co.jp/en/ceremony\">LAUNCHING CEREMONY</a></li>\n  </ul>\n</li>\n<li class=\"\"><a href=\"https://onozo.co.jp/en/products\" class=\"gnav-products\">SEGMENTS</a>\n  <ul>\n    <li><a href=\"https://onozo.co.jp/en/shipbuilding\">NEW SHIP BUILDING DIVISION</a></li>\n    <li><a href=\"https://onozo.co.jp/en/ship-repairing\">SHIP REPAIRING AND CONVERSION DIVISION</a></li>\n    <!--<li><a href=\"https://onozo.co.jp/en/industry-machinery\">INDUSTRIAL MACHINERY DIVISION</a></li>-->\n    <!--<li><a href=\"https://onozo.co.jp/en/auto-lashing\">Auto Lashing Device</a></li>-->\n  </ul>\n</li>\n<li class=\"\"><a href=\"https://onozo.co.jp/en/spirit\" class=\"gnav-spirit\">Management messages</a>\n  <ul>\n    <li><a href=\"https://onozo.co.jp/en/spirit\">PRESIDENT'S MESSAGE</a></li>\n    <li><a href=\"https://onozo.co.jp/en/directors\">BOARD OF DIRECTORS</a></li>\n    <li><a href=\"https://onozo.co.jp/en/company\">MANAGEMENT PRINCIPLES</a></li>\n  </ul>\n</li>\n<li class=\"current\"><a href=\"https://onozo.co.jp/en/company\" class=\"gnav-company\">COMPANY</a>\n  <ul>\n    <li><a href=\"https://onozo.co.jp/en/company\">COMPANY OUTLINE / MANAGEMENT PRINCIPLES</a></li>\n    <li><a href=\"https://onozo.co.jp/en/history\">HISTORY</a></li>\n    <li><a href=\"https://onozo.co.jp/en/organization\">ORGANIZATION CHART</a></li>\n    <li><a href=\"https://onozo.co.jp/en/plant\">FACTORY AND EQUIPMENT</a></li>\n    <li><a href=\"https://onozo.co.jp/en/group\">GROUP COMPANIES</a></li>\n    <li><a href=\"https://onozo.co.jp/en/action\">LOCAL CONTRIBUTION ACTIVITIES</a></li>\n    <li><a href=\"https://onozo.co.jp/en/compliance\">COMPLIANCE</a></li>\n    <li><a href=\"https://onozo.co.jp/en/iso\">ISO9001</a></li>\n    <li><a href=\"https://onozo.co.jp/en/company#place\">ACCESS</a></li>\n    <li><a href=\"https://onozo.co.jp/en/story\">THE STORY OF ONOMICHI</a></li>\n    <li><a href=\"https://onozo.co.jp/onozo_tour2019/PC_en/\" target=\"_blank\">VIRTUAL TOUR OF DOCKYARD</a></li>\n  </ul>\n</li>\n<li class=\"\"><a href=\"https://onozo.co.jp/en/contact\" class=\"gnav-contact\">CONTACT US</a></li>\n  <li><a href=\"https://onozo.co.jp/ja/company\" class=\"gnav-ja\" target=\"_blank\">to Japanese site</a></li>\n                </ul>\n            </nav>\n        </header>\n    </div><!-- /#header_wrap -->    <div id=\"main_wrap\" class=\"company\">\n        <div id=\"content_header_wrap\">\n            <div id=\"content_header_div\">\n                <div id=\"content_header\">\n                                    <div id=\"content_header_inner\">\n                        <h1>COMPANY OUTLINE</h1>\n                    </div>\n                </div>\n            </div>\n        </div>\n        <div id=\"main\">\n            <div id=\"content\">\n                <p style=\"margin-bottom: 40px\">Founded in 1943, we celebrated our 80th anniversary of business in 2023. <br />\r\n With our Head Office located in the city of Kobe in Hyogo Prefecture and our manufacturing bases in the city of Onomichi in eastern Hiroshima Prefecture, we are exploiting the full the technology and knowledge gained over those long years of our history as we aim for the world&#8217;s highest production yield per unit area of plant site.</p>\r\n<div style=\"margin: 0px auto 60px;text-align: center\"><img decoding=\"async\" loading=\"lazy\" src=\"https://onozo.co.jp/en/wp-content/themes/onozo-corporate-en-2014/img/txt_companyoutline_en01.jpg\" alt=\"Managemant Principles\" width=\"596\" height=\"333\" /></div>\r\n<table class=\"list_company\">\r\n<tbody>\r\n<tr>\r\n<th>\r\n<p>Company Name</p>\r\n</th>\r\n<td>Onomichi Dockyard Co., Ltd.</td>\r\n</tr>\r\n<tr>\r\n<th>President</th>\r\n<td>Takashi Nakabe　<a href=\"spirit\"><img decoding=\"async\" loading=\"lazy\" src=\"https://onozo.co.jp/en/wp-content/themes/onozo-corporate-en-2014/img/btn_pmessage_en.png\" alt=\"PRESIDENT'S MESSAGE\" width=\"130\" height=\"19\" /></a></td>\r\n</tr>\r\n<tr>\r\n<th>Established</th>\r\n<td>April 1, 1943</td>\r\n</tr>\r\n<tr>\r\n<th>Capital</th>\r\n<td>100 million yen</td>\r\n</tr>\r\n<tr>\r\n<th>Sales</th>\r\n<td>52,789 million yen (FY 2024 result)</td>\r\n</tr>\r\n<tr>\r\n<th>Business</th>\r\n<td>\r\n<ol>\r\n<li>1. Construction, repair, scrapping and operation of ships</li>\r\n</ol>\r\n<ol>\r\n<li>2. Manufacture and repair of structures and machines of various kinds</li>\r\n</ol>\r\n<ol>\r\n<li>3. Subcontracting of design, construction and supervision of civil engineering, <br />\r\n 　 construction, steel structures and piping work</li>\r\n</ol>\r\n<ol>\r\n<li>4. Leasing of ships</li>\r\n</ol>\r\n<ol>\r\n<li>5. All operations incidental to the foregoing</li>\r\n</ol>\r\n</td>\r\n</tr>\r\n<tr>\r\n<th>Productivity</th>\r\n<td>Shipbuilding　　 500,000 DWT/year<br />\r\n Ship repair　　4,000,000 DWT/year</td>\r\n</tr>\r\n<tr>\r\n<th>Employees</th>\r\n<td>431 employees (as of April 1, 2026)</td>\r\n</tr>\r\n<tr>\r\n<th id=\"place\">Locations</th>\r\n<td>\r\n<dl>\r\n<dt><span>Head Office</span></dt>\r\n<dd>104 Edo-machi,Chuo-ku, Kobe, Hyogo 650-0033<br />\r\n TEL: +81-78-391-3424<br />\r\n FAX: +81-78-391-3428</p>\r\n<section id=\"#tabs\"><a class=\"detailed\" href=\"#modal1\">Further details here</a></p>\r\n<div class=\"remodal modal_cont_company\" data-remodal-id=\"modal1\">\r\n<h3 class=\"modal_title\">Head Office</h3>\r\n<div class=\"modal_cont_company_left\">\r\n<p>104 Edo-machi,Chuo-ku, Kobe, Hyogo 650-0033<br />\r\n TEL: +81-78-391-3424<br />\r\n FAX: +81-78-391-3428</p>\r\n<div id=\"map_canvas1\" class=\"map\" style=\"width: 100%;height: 260px\"> </div>\r\n<p>Access: <br />\r\n About 10 minutes&#8217; walk from JR Sannomiya Station <br />\r\n About 10 minutes by taxi from Shinkansen Shin-kobe Station</p>\r\n<ul>\r\n<li><a href=\"http://www.westjr.co.jp/global/en/\" target=\"_blank\" rel=\"noopener\"> JR West Japan train times </a></li>\r\n<li><a href=\"http://www.kairport.co.jp/eng/index.html\" target=\"_blank\" rel=\"noopener\"> Kobe Airport </a></li>\r\n</ul>\r\n</div>\r\n<div class=\"modal_cont_company_right\"><img decoding=\"async\" loading=\"lazy\" src=\"https://onozo.co.jp/wp-content/themes/onozo-corporate-2014/img/pic_headOffice.jpg\" alt=\"\" width=\"200\" height=\"270\" /></div>\r\n</div>\r\n</section>\r\n</dd>\r\n</dl>\r\n<dl>\r\n<dt><span>Tokyo Branch</span></dt>\r\n<dd>Round Cross Otemachi Kita 4F, 2-5-5 Uchikanda, Chiyoda-ku, Tokyo 101-0047 <br />\r\n TEL: +81-3-6260-7455<br />\r\n FAX: +81-3-6260-7454</p>\r\n<section><a class=\"detailed\" href=\"#modal2\">Further details here</a></p>\r\n<div class=\"remodal modal_cont_company\" data-remodal-id=\"modal2\">\r\n<h3 class=\"modal_title\">Tokyo Branch</h3>\r\n<div class=\"modal_cont_company_left\">\r\n<p>Round Cross Otemachi Kita 4F, 2-5-5 Uchikanda, Chiyoda-ku, Tokyo 101-0047<br />\r\n TEL: +81-3-6260-7455<br />\r\n FAX: +81-3-6260-7454</p>\r\n<div id=\"map_canvas2\" class=\"map\" style=\"width: 100%;height: 260px\"> </div>\r\n<p>Access: <br />\r\n About 6 minutes’ walk from Exit A1 of Otemachi Subway Station<br />\r\n About 6 minutes’ walk from JR Kanda Station West Exit</p>\r\n<ul>\r\n<li><a href=\"http://www.jreast.co.jp/e/\" target=\"_blank\" rel=\"noopener\"> JR East Japan train times </a></li>\r\n<li><a href=\"http://www.tokyo-airport-bldg.co.jp/en/\" target=\"_blank\" rel=\"noopener\"> Haneda Airport </a></li>\r\n</ul>\r\n</div>\r\n<div class=\"modal_cont_company_right\"><img decoding=\"async\" loading=\"lazy\" src=\"https://onozo.co.jp/en/wp-content/uploads/sites/5/2021/03/pic_tokyoOffice2.jpg\" alt=\"\" width=\"200\" height=\"270\" /></div>\r\n</div>\r\n</section>\r\n</dd>\r\n</dl>\r\n<dl>\r\n<dt><span>Onomichi Shipyard</span></dt>\r\n<dd>1005 Sanba-cho, Onomichi, Hiroshima 722-8602<br />\r\n TEL: +81-848-37-1111<br />\r\n FAX: +81-848-20-2969</p>\r\n<section><a class=\"detailed\" href=\"#modal3\">Further details here</a></p>\r\n<div class=\"remodal modal_cont_company\" data-remodal-id=\"modal3\">\r\n<h3 class=\"modal_title\">Onomichi Shipyard</h3>\r\n<div class=\"modal_cont_company_left\">\r\n<p>1005 Sanba-cho, Onomichi, Hiroshima 722-8602<br />\r\n TEL: +81-848-37-1111<br />\r\n FAX: +81-848-20-2969</p>\r\n<div id=\"map_canvas3\" class=\"map\" style=\"width: 100%;height: 260px\"> </div>\r\n<p>Access: <br />\r\n About 20 minutes from JR Onomichi Station by bus (get off at the Onomichi-zosen-mae stop)<br />\r\n About 10 minutes from JR Onomichi Station by taxi<br />\r\n About 15 minutes from JR Higashi-onomichi Station by bus (get off at the Onomichi-zosen-mae stop)<br />\r\n About 10 minutes from JR Higashi-onomichi Station by taxi<br />\r\n About 15 minutes from Shinkansen Shin-onomichi Station by taxi</p>\r\n<ul>\r\n<li><a href=\"http://www.westjr.co.jp/global/en/\" target=\"_blank\" rel=\"noopener\"> JR West Japan train times </a></li>\r\n<li><a href=\"http://www.hij.airport.jp/english/\" target=\"_blank\" rel=\"noopener\"> Hiroshima Airport </a></li>\r\n</ul>\r\n</div>\r\n<div class=\"modal_cont_company_right\"><img decoding=\"async\" loading=\"lazy\" src=\"https://onozo.co.jp/en