{"url":"https://www.rands-co.com/recruit/faq.html","html":"<!DOCTYPE HTML>\n<html>\n<head>\n<meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\">\n<title>採用FAQ｜採用情報｜株式会社リサーチアンドソリューション</title>\n<link rel=\"shortcut icon\" href=\"/img/favicon.ico\" type=\"image/vnd.microsoft.icon\" />\n<meta name=\"description\" content=\"株式会社リサーチアンドソリューションの採用に関するよくあるご質問をご紹介。こちらで解決しない場合は、フォームからお問い合わせください。\"/>\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1,minimum-scale=1,maximum-scale=1,user-scalable=no\" />\n<link rel=\"canonical\" href=\"https://www.rands-co.com/recruit/faq.html\">\n<link href=\"../common/css/global.css\" rel=\"stylesheet\" type=\"text/css\">\n<link href=\"../common/css/layout.css\" rel=\"stylesheet\" type=\"text/css\">\n<link href=\"../css/recruit.css\" rel=\"stylesheet\" type=\"text/css\">\n<link href=\"css/repair.css\" rel=\"stylesheet\" type=\"text/css\">\n<link href=\"css/navimenu.css\" rel=\"stylesheet\" type=\"text/css\">\n<link href=\"/assets/common/css/r-footer.css\" rel=\"stylesheet\" type=\"text/css\">\n<link href=\"/recruit/css/faq.css\" rel=\"stylesheet\" type=\"text/css\">\n<link href=\"https://fonts.googleapis.com/css?family=Oswald|Roboto+Condensed\" rel=\"stylesheet\" type=\"text/css\">\n<link href=\"https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@100;300;400;500;700;900&amp;display=swap\" rel=\"stylesheet\">\n<link href=\"https://fonts.googleapis.com/icon?family=Material+Icons\" rel=\"stylesheet\">\n<link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css\">\n<script src=\"https://ajax.googleapis.com/ajax/libs/jquery/3.6.1/jquery.min.js\"></script>\n<script type=\"text/javascript\" src=\"../common/js/jquery-1.8.2.min.js\"></script>\n<script type=\"text/javascript\" src=\"../common/js/jquery.easing.1.3.js\"></script>\n<script type=\"text/javascript\" src=\"../common/js/jquery.overflowScroll.js\"></script>\n<!--<script type=\"text/javascript\" src=\"../common/js/common.js\"></script>-->\n<script type=\"text/javascript\" src=\"/assets/common/js/common.js\"></script>\n<script type=\"text/javascript\" src=\"../js/recruit.js\"></script>\n<script type=\"text/javascript\" src=\"/recruit/js/faq.js\"></script>\n<script src=\"../common/js/jquery.mobile.js\"></script>\n<script type=\"text/javascript\" src=\"../common/js/gtag.js\"></script>\n<script type=\"text/javascript\">\n$(document).bind(\"mobileinit\", function(){\n//Loadingメッセージ非表示\n$.mobile.loadingMessage = false;\n});\n</script>\n\n</head>\n\n<body id=\"recruit\">\n  <div id=\"wrap\">\n  <header class=\"header\">\n    <div class=\"header__inner\">\n      <div class=\"header__logo\"><a href=\"/recruit/\"><img src=\"/img/recruit/logo_recruit.svg\" alt=\"株式会社リサーチアンドソリューション　リクルート\"/></a></div>\n      <nav id=\"gNavi\">\n        <ul class=\"globalmenu\">\n          <li class=\"header__navitem\"><a href=\"/recruit/fresh.html\" class=\"btn_fresh slide header__navitemlink\">新卒採用</a></li>\n          <li class=\"header__navitem\"><a href=\"/recruit/career.html\" class=\"btn_career slide header__navitemlink\">キャリア採用</a></li>\n          <li>\n            <div class=\"ham-menu\">\n              <input type=\"checkbox\" id=\"menu-btn-check\">\n              <label for=\"menu-btn-check\" class=\"spnav-btn\"><p><span></span></p></label>\n              <div class=\"spnav-content\">\n                <ul class=\"globalmenu\">\n                  <li class=\"header__navitem\"><a href=\"/recruit/fresh.html\" class=\"btn_fresh_sp slide header__navitemlink\">新卒採用</a></li>\n                  <li class=\"header__navitem\"><a href=\"/recruit/career.html\" class=\"btn_career_sp slide header__navitemlink\">キャリア採用</a></li>\n                </ul>\n                <div class=\"spnav-item__wrap\">\n                  <div class=\"spnav-item__txt\">\n                    <ul>\n                      <li class=\"cate-name\">会社を知る<span class=\"cate-e\">ABOUT US</span></li>\n                      <li class=\"link-item\"><a href=\"/recruit/message.html\">社長メッセージ</a></li>\n                      <li class=\"link-item\"><a href=\"/\">コーポレートサイト</a></li>\n                    </ul>\n                    <ul>\n                      <li class=\"cate-name\">仕事を知る<span class=\"cate-e\">WORK</span></li>\n                      <li class=\"link-item\"><a href=\"/recruit/voice.html\">先輩社員の声</a></li>\n                      <li class=\"link-item\"><a href=\"/recruit/data.html\">数字で見るリサーチアンドソリューション</a></li>\n                      <!--<li class=\"link-item\"><a href=\"/recruit/#\">職種紹介</a></li>-->\n                      <!--<li class=\"link-item\"><a href=\"/recruit/#\">リサーチアンドソリューションBlog</a></li>-->\n                    </ul>\n                  </div>\n                  <div class=\"spnav-item__txt\">\n                    <!--<ul>\n                      <li class=\"cate-name\">環境を知る<span class=\"cate-e\">ENVIRONMENT</span></li>\n                      <li class=\"link-item\"><a href=\"/recruit/#\">福利厚生</a></li>\n                      <li class=\"link-item\"><a href=\"/recruit/#\">研修内容</a></li>\n                    </ul>-->\n                    <!--<p class=\"cntent-mane\"><a href=\"/recruit/#\">FAQ</a></p>-->\n                    <ul>\n                      <li class=\"cate-name\"><a href=\"/recruit/\">採用TOP<span class=\"cate-e\">RECRUIT TOP</span></a></li>\n                      <li class=\"link-item\"><a href=\"/recruit/faq.html\">FAQ</a></li>\n                    </ul>\n                  </div>\n                  <div class=\"spnav-item__bnr\">\n                    <ul class=\"bnr-entry\">\n                      <!--<li class=\"bnr-item\"><a href=\"/rands_form/toroku/form_recruit_entry_fresh.html\" class=\"btn__bnr__fresh\"><span>新卒<br>エントリー</span><img src=\"../img/recruit/icon_mail_fresh.svg\" alt=\"\"/></a></li>-->\n                      <li class=\"bnr-item\"><a href=\"/rands_form/toroku/form_contact3_sub.html\" class=\"btn__bnr__career\"><span>キャリア<br>エントリー</span><img src=\"../img/recruit/icon_mail_career.svg\" alt=\"\"/></a></li>\n                    </ul>\n                    <div class=\"bnr-box\">\n                      <!--<div class=\"bnr-ets\"><a href=\"/recruit/#\" class=\"bnr-discussion\"><img src=\"../img/recruit/bnr_discussion.svg\" alt=\"座談会エントリー\"/></a></div>\n                      <div class=\"bnr-ets-sp\"><a href=\"/recruit/#\" class=\"bnr-discussion\"></a></div>-->\n                      <ul class=\"bnr-prom\">\n                        <li class=\"prom-item\"><a href=\"https://note.com/rands/\" target=\"_blank\"><span>note</span><img src=\"../img/recruit/icon_exitlink.svg\" alt=\"\" class=\"exitlink\"/></a></li>\n                        <li class=\"prom-item mt-1em\"><a href=\"https://www.wantedly.com/companies/company_1826445\" target=\"_blank\"><span>wantedly</span><img src=\"../img/recruit/icon_exitlink.svg\" alt=\"\" class=\"exitlink\"/></a></li>\n                      </ul>\n                    </div>\n                  </div>\n                </div>\n              </div>\n              <div class=\"hamburger-demo-cover\"></div>\n            </div>\n          </li>\n        </ul>\n      </nav>\n    </div>\n  </header>\n    <div id=\"container\" class=\"data\">\n      <div id=\"mainBox\">\n        <div id=\"contents\">\n<div class=\"l-breadcrumb\">\n      <ul>\n        <li><a href=\"/recruit/\">採用TOP</a></li>\n        <li>採用FAQ</li>\n      </ul>\n    </div>\n          <div id=\"main\">\n            <h2 class=\"ttl__main\">採<span class=\"ttl__small\">用FAQ</span></h2>\n            <h4 class=\"ttl__lead\">株式会社リサーチアンドソリューションの採用に関するよくあるご質問をご紹介。<br>こちらで解決しない場合は、フォームからお問い合わせください。</h4>\n          </div>\n\n          <section class=\"inset__bg-grey pt-30\">\n            <div class=\"sec__inner\">\n              <!--FAQ 見出し-->\n              <h3 class=\"bleuline\">会社・制度について</h3>\n              <div class=\"faq\">\n                <div class=\"faq-item\">\n                  <div class=\"faq-question\">\n                    <!--FAQ 質問-->\n                    <span class=\"question\">どのような事業を行っている会社ですか？</span>\n                    <span class=\"icon\"></span>\n                  </div>\n                  <div class=\"answer-wrapper\">\n                    <!--FAQ 答え-->\n                    <p class=\"answer\">株式会社リサーチアンドソリューションは、創業45年※以上の実績を持つシステム開発・BPOサービス企業です。<br>全国400以上の自治体で採用される土木積算システム「明積」を中心に、生成AI・GIS・クラウドなどの先端技術を活用したソリューションを提供しています。<br>長年培ってきた公共分野での知見と最新技術を融合し、社会インフラの持続的な発展と業務の効率化を支援しています。※2023年4月時点</p>\n                  </div>\n                </div>\n              </div>\n\n              <div class=\"faq\">\n                <div class=\"faq-item\">\n                  <div class=\"faq-question\">\n                    <!--FAQ 質問-->\n                    <span class=\"question\">福利厚生にはどのようなものがありますか？</span>\n                    <span class=\"icon\"></span>\n                  </div>\n                  <div class=\"answer-wrapper\">\n                    <!--FAQ 答え-->\n                    <p class=\"answer\">当社では、各種社会保険の完備をはじめ、通勤交通費支給や健康診断、資格取得支援制度など、安心して働ける環境づくりに力を入れています。<br>\nまた、リモートワークやフリープラン休暇などの制度、社内懇親会費の補助といった、働きやすい職場環境も整えています。<br>\n詳しい内容は募集要項でもご案内していますので、ぜひご確認ください。</p>\n                  </div>\n                </div>\n              </div>\n\n              <div class=\"faq\">\n                <div class=\"faq-item\">\n                  <div class=\"faq-question\">\n                    <!--FAQ 質問-->\n                    <span class=\"question\">社風について教えてください。</span>\n                    <span class=\"icon\"></span>\n                  </div>\n                  <div class=\"answer-wrapper\">\n                    <!--FAQ 答え-->\n                    <p class=\"answer\">年齢やポジションに関係なく意見を交わせるフラットな文化が特徴です。<br>\nチームで協力しながら仕事を進めつつ、一人ひとりの挑戦や自主性も大切にしています。</p>\n                  </div>\n                </div>\n              </div>\n\n              <div class=\"faq\">\n                <div class=\"faq-item\">\n                  <div class=\"faq-question\">\n                    <!--FAQ 質問-->\n                    <span class=\"question\">配属部署や勤務地はどのように決まりますか？</span>\n                    <span class=\"icon\"></span>\n                  </div>\n                  <div class=\"answer-wrapper\">\n                    <!--FAQ 答え-->\n                    <p class=\"answer\">ご本人の希望や適性、会社のニーズを考慮して決定します。<br>\n配属前にしっかりと面談を行い、すり合わせを行っております。</p>\n                  </div>\n                </div>\n              </div>\n\n              <div class=\"faq\">\n                <div class=\"faq-item\">\n                  <div class=\"faq-question\">\n                    <!--FAQ 質問-->\n                    <span class=\"question\">リモートワークは可能ですか？</span>\n                    <span class=\"icon\"></span>\n                  </div>\n                  <div class=\"answer-wrapper\">\n                    <!--FAQ 答え-->\n                    <p class=\"answer\">基本可能です。<br>\n柔軟な働き方を推進しており、業務内容やプロジェクト状況に応じて調整を行っております。<br>\n※週1回以上出社規定あり<br>\n※入社後１年間は基本出社（要相談）<br>\n※業務内容により出社が必要な職種もあります</p>\n                  </div>\n                </div>\n              </div>\n\n              <div class=\"faq\">\n                <div class=\"faq-item\">\n                  <div class=\"faq-question\">\n                    <!--FAQ 質問-->\n                    <span class=\"question\">どのような方が活躍されていますか？</span>\n                    <span class=\"icon\"></span>\n                  </div>\n                  <div class=\"answer-wrapper\">\n                    <!--FAQ 答え-->\n                    <p class=\"answer\">活躍しているメンバーの特徴は、顧客満足度を意識してお客様のために仕事ができる方、責任感が強くポジティブでしっかりと最後までやり遂げる、目標に向かって行動ができる方が活躍しているように思います。</p>\n                  </div>\n                </div>\n              </div>\n\n              <!--FAQ 見出し-->\n              <h3 class=\"bleuline\">応募・選考について</h3>\n              <div class=\"faq\">\n                <div class=\"faq-item\">\n                  <div class=\"faq-question\">\n                    <!--FAQ 質問-->\n                    <span class=\"question\">未経験・異業種からの応募は可能ですか？</span>\n                    <span class=\"icon\"></span>\n                  </div>\n                  <div class=\"answer-wrapper\">\n                    <!--FAQ 答え-->\n                    <p class=\"answer\">はい、可能です。業務に必要な知識やスキルを入社後に学べる体制を整えております。未経験でも、先輩社員の仕事から学ぶ前向きな姿勢があれば問題ありません。</p>\n                  </div>\n                </div>\n              </div>\n\n              <div class=\"faq\">\n                <div class=\"faq-item\">\n                  <div class=\"faq-question\">\n                    <!--FAQ 質問-->\n                    <span class=\"question\">会社説明会は開催していますか？</span>\n                    <span class=\"icon\"></span>\n                  </div>\n                  <div class=\"answer-wrapper\">\n                    <!--FAQ 答え-->\n                    <p class=\"answer\">はい、オンライン・対面いずれも会社説明会を定期的に開催しています。<br>\n開催情報は採用サイト内で随時お知らせしますので、興味のある方はぜひフォームからお申込みください。</p>\n                  </div>\n                </div>\n              </div>\n\n              <div class=\"faq\">\n                <div class=\"faq-item\">\n                  <div class=\"faq-question\">\n                    <!--FAQ 質問-->\n                    <span class=\"question\">選考プロセスを教えてください。</span>\n                    <span class=\"icon\"></span>\n                  </div>\n                  <div class=\"answer-wrapper\">\n                    <!--FAQ 答え-->\n                    <p class=\"answer\">基本下記の流れになりますが、職種により異なる場合があります。<br>\n【新卒採用】<br>\n書類選考→一次（オンライン）→二次（オンライン）→最終（対面またはオンライン）<br>\n【中途採用】<br>\n書類選考→一次（オンライン）→最終（オンライン）→オファー面談（対面またはオンライン）</p>\n                  </div>\n                </div>\n              </div>\n\n              <div class=\"faq\">\n                <div class=\"faq-item\">\n                  <div class=\"faq-question\">\n                    <!--FAQ 質問-->\n                    <span class=\"question\">過去に不合格だったのですが、再応募はできますか？</span>\n                    <span class=\"icon\"></span>\n                  </div>\n                  <div class=\"answer-wrapper\">\n                    <!--FAQ 答え-->\n                    <p class=\"answer\">はい、可能です。以前の選考時から一定期間が経過している場合や、異なる職種での応募であれば再応募いただけます。</p>\n                  </div>\n                </div>\n              </div>\n\n\n              <div class=\"faq\">\n                <div class=\"faq-item\">\n                  <div class=\"faq-question\">\n                    <!--FAQ 質問-->\n                    <span class=\"question\">応募から内定までの期間はどのくらいですか？</span>\n                    <span class=\"icon\"></span>\n                  </div>\n                  <div class=\"answer-wrapper\">\n                    <!--FAQ 答え-->\n                    <p class=\"answer\">応募から内定までは、平均で2～3週間程度を予定しています。<br>\nご希望のスケジュールがある場合はできる限り配慮いたしますので、急ぎのご相談も含めお気軽にお申し付けください。</p>\n                  </div>\n                </div>\n              </div>\n\n\n              <div class=\"faq\">\n                <div class=\"faq-item\">\n                  <div class=\"faq-question\">\n                    <!--FAQ 質問-->\n                    <span class=\"question\">複数のポジションに同時に応募することはできますか？</span>\n                    <span class=\"icon\"></span>\n                  </div>\n                  <div class=\"answer-wrapper\">\n                    <!--FAQ 答え-->\n                    <p class=\"answer\">はい、複数のポジションへの応募も可能です。<br>\nご興味のある職種が複数ある場合は、エントリーフォームにご記入ください。<br>\n面接の中でご希望を伺いながら、一緒に最適なポジションを検討いたします。</p>\n                  </div>\n                </div>\n              </div>\n\n\n              <div class=\"faq\">\n                <div class=\"faq-item\">\n                  <div class=\"faq-question\">\n                    <!--FAQ 質問-->\n                    <span class=\"question\">既卒者（第2新卒）でも応募できますか？</span>\n                    <span class=\"icon\"></span>\n                  </div>\n                  <div class=\"answer-wrapper\">\n                    <!--FAQ 答え-->\n                    <p class=\"answer\">はい、既卒の方（第2新卒）のご応募も歓迎しています。<br>\nこれまでの経験や今後の意欲を大切にしていますので、ぜひお気軽にご応募ください。</p>\n                  </div>\n                </div>\n              </div>\n\n\n              <div class=\"faq\">\n                <div class=\"faq-item\">\n                  <div class=\"faq-question\">\n                    <!--FAQ 質問-->\n                    <span class=\"question\">海外からの応募は可能ですか? 外国籍でも応募できますか？</span>\n                    <span class=\"icon\"></span>\n                  </div>\n                  <div class=\"answer-wrapper\">\n                    <!--FAQ 答え-->\n                    <p class=\"answer\">日本国内での勤務が可能でしたら応募可能です。<br>\n※ただし、日本語能力試験「N4」相当以上の能力を必要とします。</p>\n                  </div>\n                </div>\n              </div>\n\n\n              <!--FAQ 見出し-->\n              <h3 class=\"bleuline\">働き方・キャリアについて</h3>\n              <div class=\"faq\">\n                <div class=\"faq-item\">\n                  <div class=\"faq-question\">\n                    <!--FAQ 質問-->\n                    <span class=\"question\">どのような研修制度がありますか？</span>\n                    <span class=\"icon\"></span>\n                  </div>\n                  <div class=\"answer-wrapper\">\n                    <!--FAQ 答え-->\n                    <p class=\"answer\">入社時研修をはじめ、OJT制度や社内外の勉強会、eラーニングなど、学べる機会を幅広く用意しています。<br>\n経験やスキルに応じて段階的に成長できるよう、しっかりサポートする環境を整えています。</p>\n                  </div>\n                </div>\n              </div>\n\n              <div class=\"faq\">\n                <div class=\"faq-item\">\n                  <div class=\"faq-question\">\n                    <!--FAQ 質問-->\n                    <span class=\"question\">キャリアパスについて教えてください。</span>\n                    <span class=\"icon\"></span>\n                  </div>\n                  <div class=\"answer-wrapper\">\n                    <!--FAQ 答え-->\n                    <p class=\"answer\">当社では、専門性を高めるスペシャリスト型と、チームをまとめるリーダー・マネジメント型の両方のキャリアを支援しています。<br>\n定期的なキャリア面談を通じて、一人ひとりの目標や希望に合わせた成長の機会を提供しています。</p>\n                  </div>\n                </div>\n              </div>\n\n              <div class=\"faq\">\n                <div class=\"faq-item\">\n                  <div class=\"faq-question\">\n                    <!--FAQ 質問-->\n                    <span class=\"question\">チーム体制で働くことが多いですか？</span>\n                    <span class=\"icon\"></span>\n                  </div>\n                  <div class=\"answer-wrapper\">\n                    <!--FAQ 答え-->\n                    <p class=\"answer\">はい、当社の仕事はチームで進めることが多いです。<br>\nメンバー同士で相談しながら役割分担を行い、協力してプロジェクトを進めていきます。</p>\n                  </div>\n                </div>\n              </div>\n\n              <div class=\"faq\">\n                <div class=\"faq-item\">\n                  <div class=\"faq-question\">\n                    <!--FAQ 質問-->\n                    <span class=\"question\">年次有給休暇は取得しやすいですか？</span>\n                    <span class=\"icon\"></span>\n                  </div>\n                  <div class=\"answer-wrapper\">\n                    <!--FAQ 答え-->\n                    <p class=\"answer\">はい、年次有給休暇は取得しやすい環境です。<br>\n業務の状況に合わせながら、希望するタイミングで多くの社員が利用しています。</p>\n                  </div>\n                </div>\n              </div>\n\n\n              <div class=\"faq\">\n                <div class=\"faq-item\">\n                  <div class=\"faq-question\">\n                    <!--FAQ 質問-->\n                    <span class=\"question\">勤務地や配属はいつ頃決定しますか？</span>\n                    <span class=\"icon\"></span>\n                  </div>\n                  <div class=\"answer-wrapper\">\n                    <!--FAQ 答え-->\n                    <p class=\"answer\">中途採用の場合、勤務地や配属部署は内定時に決定することが多いです。<br>\nご希望がある場合は、面談の際にぜひお聞かせください。状況をふまえて相談しながら進めていきます。</p>\n                  </div>\n                </div>\n              </div>\n\n\n              <div class=\"faq\">\n                <div class=\"faq-item\">\n                  <div class=\"faq-question\">\n                    <!--FAQ 質問-->\n                    <span class=\"question\">子育てや介護と両立しながら働くことは可能ですか？</span>\n                    <span class=\"icon\"></span>\n                  </div>\n                  <div class=\"answer-wrapper\">\n                    <!--FAQ 答え-->\n                    <p class=\"answer\">はい、子育てや介護と両立しながら働くことも可能です。<br>\n在宅勤務制度（リモートワーク）などを活用し、ライフステージに合わせた柔軟な働き方を支援しています。</p>\n                  </div>\n                </div>\n              </div>\n\n\n              <div class=\"faq\">\n                <div class=\"faq-item\">\n                  <div class=\"faq-question\">\n                    <!--FAQ 質問-->\n                    <span class=\"question\">評価や昇給の仕組みについて教えてください。</span>\n                    <span class=\"icon\"></span>\n                  </div>\n                  <div class=\"answer-wrapper\">\n                    <!--FAQ 答え-->\n                    <p class=\"answer\">半期ごとの目標設定とフィードバック面談を通じて評価を行っています。<br>\n日々の取り組みや成果を総合的に判断し、昇給や賞与にしっかり反映される仕組みです。</p>\n                  </div>\n                </div>\n              </div>\n\n\n            </div>\n          </section>\n\n          <section>\n            <div class=\"sec__inner\">\n              <div class=\"recruit-faq-btn\"><a href=\"/rands_form/toroku/form_contact3_sub.html\">採用に関するお問い合わせはこちら</a></div>\n              <div class=\"recruit-faq-btn_tx\">※営業日、3日以内での返信を予定しております</div>\n            </div>\n          </section>\n\n\n          <section class=\"c-data pb-none fade\">\n            <div class=\"sec__inner mt-none\">\n              <div class=\"btn__wrap\">\n                <div class=\"btn__ttl\">募集要項・エントリー</div>\n                <div class=\"btn__parts\"><a href=\"/recruit/fresh.html\" class=\"btn__entry-f inset__fx__sb-nwp\">新卒採用<span>ENTRY：FRESH</span></a></div>\n                <div class=\"btn__parts\"><a href=\"/recruit/career.html\" class=\"btn__entry-c inset__fx__sb-nwp\">キャリア採用<span>ENTRY：CAREER</span></a></div>\n              </div>\n            </div>\n          </section>\n          <section class=\"pb-none fade\">\n            <div class=\"sec__inner\">\n              <ul id=\"lNavi\">\n                <li id=\"lNavi01\" class=\"upper\"><a href=\"/recruit/message.html\"><span><span>MESSAGE</span>メッセージ</span></a></li>\n                <li id=\"lNavi02\" class=\"upper\"><a href=\"/recruit/voice/\"><span><span>VOICE</span>先輩の声</span></a></li>\n                <li id=\"lNavi05\" class=\"upper\"><a href=\"/recruit/data.html\"><span><span>ENVIRONMENT</span>働く環境</span></a></li>\n                <li id=\"lNavi03\" class=\"lower\"><a href=\"/recruit/fresh.html\"><span><span>ENTRY：FRESH</span>エントリー：新卒採用</span></a></li>\n                <li id=\"lNavi04\" class=\"lower\"><a href=\"/recruit/career.html\"><span><span>ENTRY：CAREER</span>エントリー：キャリア採用</span></a></li>\n              </ul>\n            </div>\n          </section>\n        </div>\n      </div>\n    </div>\n\n  <div id=\"pageTop\" style=\"display: block;\"><a href=\"#wrap\"><img src=\"../common/img/icon_pagetop.svg\" class=\"pagetop__arrow\" alt=\"\"></a></div>\n  <footer class=\"footer__outer mt-none pt-none\" id=\"parts_footer\">\n  </footer>\n\n  </div>\n\n<link rel=\"stylesheet\" type=\"text/css\" href=\"https://cdnjs.cloudflare.com/ajax/libs/slick-carousel/1.9.0/slick.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"https://cdnjs.cloudflare.com/ajax/libs/slick-carousel/1.9.0/slick-theme.css\">\n<script type=\"text/javascript\" src=\"https://cdnjs.cloudflare.com/ajax/libs/slick-carousel/1.9.0/slick.min.js\"></script>\n<script type=\"text/javascript\" src=\"js/slick-slide.js\"></script>\n<script type=\"text/javascript\" src=\"/assets/common/js/include.js\"></script>\n<script type=\"text/javascript\" src=\"/assets/common/js/fade.js\"></script>\n</body>\n</html>\n","finalUrl":"https://www.rands-co.com/recruit/faq.html","rendered":false,"_cachedAt":"2026-06-22T18:26:20.262Z"}