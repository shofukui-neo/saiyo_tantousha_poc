\"sp-globanav-child\">\n              <li><a href=\"/company/#nav-philosophy\">経営理念</a></li>\n              <li><a href=\"/company/#nav-message\">代表挨拶</a></li>\n              <li><a href=\"/company/#nav-profile\">会社概要</a></li>\n              <li><a href=\"/company/#nav-access\">アクセスマップ</a></li>\n              <!-- <li><a href=\"/company/#nav-history\">沿革</a></li> -->\n            </ul>\n          </li>\n          <li><a href=\"/contribution/\">社会貢献活動</a></li>\n          <li><a href=\"/archives/useful_information/\">お役立ち情報</a></li>\n          <li><a href=\"/contact/\">お問い合わせ</a></li>\n          <li>\n            <a class=\"js-chlid-btn child-btn\" href=\"#\">採用情報</a>\n            <ul class=\"sp-globanav-child\">\n              <li><a href=\"/recruitment/\">採用情報</a></li>\n              <li><a href=\"/recruitment/form/\">採用応募フォーム</a></li>\n            </ul>\n          </li>\n          <li><a href=\"/privacy/\">プライバシーポリシー</a></li>\n          <li><a href=\"/en/\">English</a></li>\n          <li><a href=\"/vn/\">Tiếng việt</a></li>\n        </ul>\n      </nav>\n\n    </div>\n\n\n  </header>\n\n    <main id=\"main\" class=\"l-main\">\n\n      <section class=\"sec-content\">\n        <h1 class=\"common-title__center\"><span class=\"common-title__en\">RECRUITMENT</span><span>採用情報</span></h1>\n        <section class=\"sec-child\">\n          <div class=\"l-container\">\n            <div class=\"bnr\">\n              <a href=\"../recruit\" target=\"_blank\">\n                <img src=\"../images/recruit/recruit_bnr.png\" alt=\"大塚実業株式会社採用特設サイト きれいな水を世界の子供たちへ Clean water for children around the world. 採用特設ページへ\">\n              </a>\n            </div>\n            <!-- <div class=\"bnr\">\n              <a href=\"https://cheercareer.jp/company/offer/3887/3538\" target=\"_blank\">\n                <img src=\"../images/recruit/cheercareer_banner.png\" alt=\"CheerCareer 外部サイトページへ\">\n              </a>\n            </div> -->\n            <h2 class=\"title-blue\">大塚実業の事業紹介</h2>\n            <div class=\"block-inner\">\n              <div class=\"recruit-movie\">\n                <div class=\"recruit-movie--inner\">\n                  <iframe width=\"560\" height=\"315\" src=\"https://www.youtube.com/embed/6ulA-_BHfeM?modestbranding=1&showinfo=0\" frameborder=\"0\" allow=\"autoplay; encrypted-media\" allowfullscreen></iframe>\n                </div>\n              </div>\n\n              <!-- <ul class=\"recruit--pic\">\n                <li><img src=\"/images/recruitment/pic_company_01.jpg\" srcset=\"/images/recruitment/pic_company_01.jpg 1x,/images/recruitment/pic_company_01@2x.jpg 2x\" alt=\"\"></li>\n                <li><img src=\"/images/recruitment/pic_company_02.jpg\" srcset=\"/images/recruitment/pic_company_02.jpg 1x,/images/recruitment/pic_company_02@2x.jpg 2x\" alt=\"\"></li>\n                <li><img src=\"/images/recruitment/pic_company_03.jpg\" srcset=\"/images/recruitment/pic_company_03.jpg 1x,/images/recruitment/pic_company_03@2x.jpg 2x\" alt=\"\"></li>\n              </ul> -->\n            </div>\n          </div>\n        </section>\n\n        <section class=\"sec-child\">\n          <div class=\"l-container\">\n            <h2 class=\"title-blue\">募集要項</h2>\n            <div class=\"block-inner\">\n\n              <div class=\"b-recruit\">\n                <div class=\"recruit-table\">\n                  <dl class=\"recruit-table--row\">\n                    <dt>雇用形態</dt>\n                    <dd>正社員</dd>\n                  </dl>\n                  <dl class=\"recruit-table--row\">\n                    <dt>募集職種</dt>\n                    <dd>営業職　技術職</dd>\n                  </dl>\n                  <dl class=\"recruit-table--row\">\n                    <dt>主な職務内容</dt>\n                    <dd>\n                      <dl class=\"recruit-table__child\">\n                        <dt>営業職</dt>\n                        <dd>新規・既存客への営業（提案型）</dd>\n                      </dl>\n                      <dl class=\"recruit-table__child\">\n                        <dt>技術職</dt>\n                        <dd>製品の加工、検査、<br class=\"u-pc-hide\">縫製、裁断、樹脂塗等</dd>\n                      </dl>\n                    </dd>\n                  </dl>\n                  <dl class=\"recruit-table--row\">\n                    <dt>応募資格</dt>\n                    <dd>\n                      <dl class=\"recruit-table__child\">\n                        <dt>営業職</dt>\n                        <dd>社会人経験３年以上優遇<br>（要）普通自動車運転免許証</dd>\n                      </dl>\n                      <dl class=\"recruit-table__child\">\n                        <dt>技術職</dt>\n                        <dd>未経験者可、<br>繊維の裁断・検査・縫製等<br class=\"u-pc-hide\">経験ありの場合は優遇</dd>\n                      </dl>\n                    </dd>\n                  </dl>\n                  <dl class=\"recruit-table--row\">\n                    <dt>応募方法</dt>\n                    <dd>下記Ｅメールアドレスに<br class=\"u-pc-hide\">お問い合わせください。<br>info@ohtsuka-jitsugyo.com<br>担当よりご連絡させていただきます。<br>（連絡後、履歴書・職務経歴書<br class=\"u-pc-hide\">を郵送ください。）</dd>\n                  </dl>\n                  <dl class=\"recruit-table--row\">\n                    <dt>勤務地</dt>\n                    <dd>\n                      <dl class=\"recruit-table__child\">\n                        <dt>営業職</dt>\n                        <dd>大阪営業所</dd>\n                      </dl>\n                      <dl class=\"recruit-table__child\">\n                        <dt>技術職</dt>\n                        <dd>栃木本社</dd>\n                      </dl>\n                    </dd>\n                  </dl>\n                  <dl class=\"recruit-table--row\">\n                    <dt>勤務時間</dt>\n                    <dd>\n                      <dl class=\"recruit-table__child\">\n                        <dt>営業職</dt>\n                        <dd>09:00－17:30</dd>\n                      </dl>\n                      <dl class=\"recruit-table__child\">\n                        <dt>技術職</dt>\n                        <dd>08:35－17:45うち休憩10分</dd>\n                      </dl>\n                    </dd>\n                  </dl>\n                  <dl class=\"recruit-table--row\">\n                    <dt>待遇・給与</dt>\n                    <dd>経験・能力を考慮の上、個別に決定します。</dd>\n                  </dl>\n                  <dl class=\"recruit-table--row\">\n                    <dt>昇給</dt>\n                    <dd>年１回</dd>\n                  </dl>\n                  <dl class=\"recruit-table--row\">\n                    <dt>賞与</dt>\n                    <dd>年３回（業績による）</dd>\n                  </dl>\n                  <dl class=\"recruit-table--row\">\n                    <dt>休日・休暇</dt>\n                    <dd>原則週休２日（社内カレンダーに準ずる）</dd>\n                  </dl>\n                  <dl class=\"recruit-table--row\">\n                    <dt>その他</dt>\n                    <dd>夏季休暇・年末年始休暇、<br class=\"u-pc-hide\">有給休暇入社６か月後より１０日<br>社会保険、厚生年金、退職金制度、<br class=\"u-pc-hide\">会員制宿泊施設利用</dd>\n                  </dl>\n                </div>\n\n                <div class=\"c-btn c-btn__center reqruit-banner\">\n                  <a class=\"btn btn-wide btn-blue\" href=\"/recruitment/form/\">応募フォームへ</a>\n                  <a href=\"../recruit\" target=\"_blank\">\n                    <img src=\"../images/recruit/banner.png\" alt=\"大塚実業株式会社採用特設サイト きれいな水を世界の子供たちへ Clean water for children around the world. 採用特設ページへ\">\n                  </a>\n                </div>\n\n                <div class=\"recruit-info recruit-info2\">\n                  <h4 class=\"recruit-info-title\">≪応募に関する個人情報の取り扱いについて≫</h4>\n                  <p>応募に際してご提出いただいた各書類は、個人情報保護法を遵守し採用関連業務にのみ利用させていただき、<br>採用活動以外の目的には使用いたしません。また、応募書類は返却いたしませんのでご了承ください。</p>\n                </div>\n              </div>\n            </div>\n          </div>\n        </section>\n\n      </section>\n\n    </main>\n    <!-- / main -->\n\n    <footer class=\"l-footer\">\n  <div class=\"l-container\">\n    <div class=\"footer-top\">\n      <ul class=\"u-pc-hide footer-list flex-col-sp flex-col-sp_2\">\n        <