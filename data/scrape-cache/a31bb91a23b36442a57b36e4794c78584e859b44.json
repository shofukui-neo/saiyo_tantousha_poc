ts/images/icon/apple-touch-icon.png\">\n    <link rel=\"icon\" type=\"image/png\" sizes=\"32x32\" href=\"assets/images/icon/favicon-32x32.png\">\n    <link rel=\"icon\" type=\"image/png\" sizes=\"16x16\" href=\"assets/images/icon/favicon-16x16.png\">\n    <link rel=\"manifest\" href=\"assets/images/icon/site.webmanifest.txt\">\n    <link rel=\"mask-icon\" href=\"assets/images/icon/safari-pinned-tab.svg\" color=\"#615ea8\">\n    <meta name=\"msapplication-TileColor\" content=\"#615ea8\">\n    <meta name=\"theme-color\" content=\"#ffffff\">\n</head>\n<body id=\"top\">\n  <div class=\"recruit\">\n\n    <header class=\"header add-scrolled add-reverse\" id=\"header\">\n        <div class=\"header-inner\">\n\n            <div class=\"header-ttl\">\n                <a class=\"header-ttlLink\" href=\"index.html\"><img src=\"assets/images/tis_logo.png\"><span>Recruit Site</span></a>\n            </div>\n\n            <nav class=\"header-nav\">\n                <button class=\"header-closeButton\" id=\"js-header_closeBtn\" type=\"button\">\n                    <span></span>\n                    <span></span>\n                </button>\n                <ul class=\"header-list\">\n                    <li class=\"header-item\">\n                        <div class=\"header-item_ttl\"><a class=\"header-itemLink-top js-unlink\" href=\"index.html#mission\">ビジョン</a></div>\n                    </li>\n                    <li class=\"header-item\">\n                        <div class=\"header-item_ttl\"><a class=\"header-itemLink-top js-unlink\" href=\"index.html#message\">メッセージ</a></div>\n                    </li>\n                    <li class=\"header-item\">\n                        <div class=\"header-item_ttl\"><a class=\"header-itemLink-top js-unlink\" href=\"index.html#business\">事業内容</a></div>\n                    </li>\n                    <li class=\"header-item\">\n                        <div class=\"header-item_ttl\"><a class=\"header-itemLink-top js-unlink\" href=\"index.html#interview\">社員インタビュー</a></div>\n                    </li>\n                    <li class=\"header-item\">\n                        <div class=\"header-item_ttl\"><a class=\"header-itemLink-top js-unlink\" href=\"index.html#culture\">TISの文化</a></div>\n                    </li>\n                    <li class=\"header-item\">\n                        <div class=\"header-item_ttl\"><a class=\"header-itemLink-top js-unlink\" href=\"index.html#company\">会社概要</a></div>\n                    </li>\n                    <li class=\"header-item\">\n                        <div class=\"header-item_ttl\"><a class=\"header-itemLink-top js-unlink\" href=\"recruit.html\">採用情報</a></div>\n                    </li>\n                    <li class=\"header-btnarea\">\n                        <a class=\"header-entry\" href=\"entry.html\" ><img src=\"assets/images/entry.svg\" alt=\"\"><tspan>エントリー</tspan>\n                        </a>\n                    </li>\n                </ul>\n            </nav>\n        </div>\n        <button class=\"header-navButton\" id=\"js-header_toggleBtn\" type=\"button\">\n            <span class=\"header-toggleBtn\">\n                <span></span>\n                <span></span>\n                <span></span>\n            </span>\n            <span class=\"header-toggleBtn-txt\">メニュー</span>\n        </button>\n        <a class=\"header-entryButton\" href=\"entry.html\" >\n            <img src=\"assets/images/entry.svg\"><tspan>エントリー</tspan></a>\n        <div class=\"header-bg js-headerBg\" id=\"js-headerBg\"></div>\n    </header>\n\n    <main class=\"entry-container\">\n      <div class=\"entry-formInner\">\n        <div class=\"culture-welfare__head\">\n          <h2 class=\"page-sec__ttl\">\n          <span class=\"t-en\">Recruit Entryform</span>\n          <span class=\"t-ja\">採用エントリーフォーム</span>\n          </h2>\n      </div>\n        <form id=\"mailformpro\" action=\"mailformpro/mailformpro.cgi\" method=\"POST\">\n          <div class=\"mailform\">\n            <input type=\"hidden\" name=\"お名前\" data-unjoin=\"姓+ +名+（+セイ+ +メイ+）\" value=\"\">\n            <div class=\"list-form__card\"><dt class=\"list-tbl__th\">基本情報</dt>               \n            </div>\n            <dl>\n                <dt class=\"\">希望職種<span class=\"must\">必須</span></dt>\n                <dd class=\"\">\n                <div class=\"mfp_rows mfp_radio\">\n                    <div class=\"mfp_col5\">\n                        <label><input type=\"radio\" name=\"希望職種\" value=\"【FA事業】営業職\" required=\"required\">【FA事業】営業職</label>\n                    </div>\n                    <div class=\"mfp_col5\">\n                        <label><input type=\"radio\" name=\"希望職種\" value=\"【FA事業】設計職\" required=\"required\">【FA事業】設計職</label>\n                    </div>\n                    <div class=\"mfp_col5\">\n                        <label><input type=\"radio\" name=\"希望職種\" value=\"【FA事業】製造技能職\" required=\"required\">【FA事業】製造技能職</label>\n                    </div>\n                    <div class=\"mfp_col5\">\n                        <label><input type=\"radio\" name=\"希望職種\" value=\"【FA事業】調達・購買\" required=\"required\">【FA事業】調達・購買</label>\n                    </div>\n                    <div class=\"mfp_col5\">\n                    <label><input type=\"radio\" name=\"希望職種\" value=\"【サービス事業】開発評価エンジニア\" required=\"required\">【サービス事業】開発評価エンジニア</label>\n                    </div>\n                    <div class=\"mfp_col5\">\n                    <label><input type=\"radio\" name=\"希望職種\" value=\"製造技能職\" required=\"required\">【エコシステム事業】営業職</label>\n                    </div>\n                    <div id=\"errormsg_希望職種\" class=\"mfp_err\"></div>\n                </div>\n                </dd>\n            </dl>\n            <dl>\n                <dt class=\"mfp\">お名前<span class=\"must\">必須</span></dt>\n                <dd class=\"mfp\">\n                <div class=\"mfp_rows\">\n                    <div class=\"mfp_col5\">\n                    <input type=\"text\" name=\"姓\" data-kana=\"セイ\" size=\"15\" required=\"required\" class=\"form-control\" placeholder=\"姓\">\n                    </div>\n                    <div class=\"mfp_col5\">\n                    <input type=\"text\" name=\"名\" data-kana=\"メイ\" size=\"15\" required=\"required\" class=\"form-control\" placeholder=\"名\">\n                    </div>\n                </div>\n                </dd>\n            </dl>\n            <dl>\n                <dt class=\"\">フリガナ<span class=\"must\">必須</span></dt>\n                <dd class=\"\">\n                <div class=\"mfp_rows\">\n                    <div class=\"mfp_col5\">\n                    <input type=\"text\" name=\"セイ\" size=\"15\" data-charcheck=\"zenkaku\" class=\"form-control\" placeholder=\"セイ\" required=\"required\">\n                    </div>\n                    <div class=\"mfp_col5\">\n                    <input type=\"text\" name=\"メイ\" size=\"15\" data-charcheck=\"kana\" class=\"form-control\" placeholder=\"メイ\" required=\"required\">\n                    </div>\n                </div>\n                </dd>\n            </dl>\n            <dl>\n                <dt class=\"\">性別<span class=\"must\">必須</span></dt>\n                <dd class=\"\">\n                <div class=\"mfp_rows mfp_radio\">\n                    <div class=\"mfp_col5\">\n                    <label><input type=\"radio\" name=\"性別\" value=\"男性\" required=\"required\"> 男性</label>\n                    </div>\n                    <div class=\"mfp_col5\">\n                    <label><input type=\"radio\" name=\"性別\" value=\"女性\" required=\"required\"> 女性</label>\n                    </div>\n                    <div id=\"errormsg_性別\" class=\"mfp_err\"></div>\n                </div>\n                </dd>\n            </dl>\n            <dl>\n                <dt class=\"\">メールアドレス<span class=\"must\">必須</span></dt>\n                <dd class=\"\">\n                <div class=\"mfp_rows\">\n                    <div class=\"mfp_col10\">\n                    <input type=\"email\" data-type=\"email\" name=\"email\" size=\"40\" required=\"required\" class=\"form-control\">\n                    </div>\n                </div>\n                </dd>\n            </dl>\n            <dl>\n                <dt class=\"\">確認のためもう一度<span class=\"must\">必須</span></dt>\n                <dd class=\"\">\n                <div class=\"mfp_rows\">\n                    <div class=\"mfp_col10\">\n                    <input type=\"email\" data-type=\"email\" name=\"confirm_email\" data-post-disable=\"1\" size=\"40\" required=\"required\" class=\"form-control\">\n                    </div>\n                </div>\n                </dd>\n            </dl>\n            <dl>\n                <dt class=\"\">郵便番号<span class=\"must\">必須</span></dt>\n                <dd class=\"\">\n                <input type=\"hidden\" name=\"ご住所\" data-unjoin=\"〒+郵便番号+\\n+都道府県+市区町村+丁目番地\" value=\"\">\n                <div class=\"mfp_rows\">\n                    <div class=\"mfp_col10\">\n                    <input type=\"text\" name=\"郵便番号\" size=\"30\" required=\"required\" data-address=\"都道府県,市区町村,市区町村\" autocomplete=\"off\" class=\"form-control\">\n                    </div>\n                </div>\n                </dd>\n            </dl>\n            <dl>\n                <dt class=\"\">ご住所<span class=\"must\">必須</span></dt>\n                <dd class=\"\">\n                <div class=\"mfp_rows mfp_address\">\n                    <div class=\"mfp_col10\">\n                    <select name=\"都道府県\" required=\"required\" class=\"form-control\">\n                        <option value=\"\" selected=\"selected\">【選択して下さい】</option>\n                        <optgroup label=\"北海道・東北地方\">\n                        <option value=\"北海道\">北海道</option>\n                        <option value=\"青森県\">青森県</option>\n                        <option value=\"岩手県\">岩手県</option>\n                        <option value=\"秋田県\">秋田県</option>\n                        <option value=\"宮城県\">宮城県</option>\n                        <option value=\"山形県\">山形県</option>\n                        <option value=\"福島県\">福島県</option>\n                        </optgroup>\n                        <optgroup label=\"関東地方\">\n                        <option value=\"栃木県\">栃木県</option>\n                        <option value=\"群馬県\">群馬県</option>\n                        <option value=\"茨城県\">茨城県</option>\n                        <option value=\"埼玉県\">埼玉県</option>\n                        <option value=\"東京都\">東京都</option>\n                        <option value=\"千葉県\">千葉県</option>\n                        <option value=\"神奈川県\">神奈川県</option>\n                        </optgroup>\n                        <optgroup label=\"中部地方\">\n                        <option value=\"山梨県\">山梨県</option>\n                        <option value=\"長野県\">長野県</option>\n                        <option value=\"新潟県\">新潟県</option>\n                        <option value=\"富山県\">富山県</option>\n                        <option value=\"石川県\">石川県</option>\n                        <option value=\"福井県\">福井県</option>\n                        <option value=\"静岡県\">静岡県</option>\n                        <option value=\"岐阜県\">岐阜県</option>\n                        <option value=\"愛知県\">愛知県</option>\n                        </optgroup>\n                        <optgroup label=\"近畿地方\">\n                        <option value=\"三重県\">三重県</option>\n                        <option value=\"滋賀県\">滋賀県</option>\n                        <option value=\"京都府\">京都府</option>\n                        <option value=\"大阪府\">大阪府</option>\n                        <option value=\"兵庫県\">兵庫県</option>\n                        <option value=\"奈良県\">奈良県</option>\n                        <option value=\"和歌山県\">和歌山県</option>\n                        </optgroup>\n                        <optgroup label=\"四国地方\">\n                        <option value=\"徳島県\">徳島県</option>\n                        <option value=\"香川県\">香川県</option>\n                        <option value=\"愛媛県\">愛媛県</option>\n                        <option value=\"高知県\">高知県</option>\n                        </optgroup>\n                        <optgroup label=\"中国地方\">\n                        <option value=\"鳥取県\">鳥取県</option>\n                        <option value=\"島根県\">島根県</option>\n                        <option value=\"岡山県\">岡山県</option>\n                        <option value=\"広島県\">広島県</option>\n                        <option value=\"山口県\">山口県</option>\n                        </optgroup>\n                        <optgroup label=\"九州・沖縄地方\">\n                        <option value=\"福岡県\">福岡県</option>\n                        <option value=\"佐賀県\">佐賀県</option>\n                        <option value=\"長崎県\">長崎県</option>\n                        <option value=\"大分県\">大分県</option>\n                        <option value=\"熊本県\">熊本県</option>\n                        <option value=\"宮崎県\">宮崎県</option>\n                        <option value=\"鹿児島県\">鹿児島県</option>\n                        <option value=\"沖縄県\">沖縄県</option>\n                        </optgroup>\n                    </select>\n                    </div>\n                    <div class=\"mfp_col10\">\n                    <input type=\"text\" name=\"市区町村\" placeholder=\"市区町村\" required=\"required\" size=\"50\" class=\"form-control\">\n                    </div>\n                    <div class=\"mfp_col10\">\n                    <input type=\"text\" name=\"丁目番地\" placeholder=\"丁目番地\" required=\"required\" size=\"50\" class=\"form-control\">\n                    </div>\n                    <div class=\"mfp_col10\">\n                    <input type=\"text\" name=\"建物名\" placeholder=\"建物名・号室\" size=\"50\" class=\"form-control\">\n                    </div>\n                </div>\n                </dd>\n            </dl>\n            <dl>\n                <dt class=\"\">電話番号<span class=\"must\">必須</span></dt>\n                <dd class=\"\">\n                <div class=\"mfp_rows\">\n                    <div class=\"mfp_col10\">\n                    <input type=\"tel\" data-type=\"tel\" name=\"電話番号\" size=\"16\" data-min=\"9\" class=\"form-control\" required=\"required\">\n                    </div>\n                </div>\n                </dd>\n            </dl>\n\n            <div class=\"list-form__card\"><dt class=\"list-tbl__th\">出身学校情報</dt>               \n            </div>\n            <dl>\n              <dt class=\"\">学校区分<span class=\"must\">必須</span></dt>\n              <dd class=\"\">\n              <div class=\"mfp_rows mfp_radio\">\n                  <div class=\"\">\n                  <label><input type=\"radio\" name=\"学校区分\" value=\"大学院\" required=\"required\"> 大学院</label>\n                  </div>\n                  <div class=\"\">\n                  <label><input type=\"radio\" name=\"学校区分\" value=\"大学\" required=\"required\"> 大学</label>\n                  </div>\n                  <div class=\"\">\n                    <label><input type=\"radio\" name=\"学校区分\" value=\"短期大学\" required=\"required\"> 短期大学</label>\n                  </div>\n                  <div class=\"\">\n                    <label><input type=\"radio\" name=\"学校区分\" value=\"高等専門学校\" required=\"required\"> 高等専門学校</label>\n                  </div>\n                  <div class=\"\">\n                    <label><input type=\"radio\" name=\"学校区分\" value=\"専門学校\" required=\"required\"> 専門学校</label>\n                  </div>\n                  <div id=\"errormsg_学校区分\" class=\"mfp_err\"></div>\n                </div>\n              </dd>\n            </dl>\n            <dl>\n                <dt class=\"\">学校名<span class=\"must\">必須</span></dt>\n                <dd class=\"\">\n                <div class=\"mfp_rows\">\n                    <div class=\"mfp_col10\">\n                    <input type=\"text\" name=\"学校名\" size=\"50\" data-charcheck=\"zenkaku\" class=\"form-control\" required=\"required\">\n                    </div>\n                </div>\n                </dd>\n            </dl>\n            <dl>\n              <dt class=\"\">学部・学科など</dt>\n              <dd class=\"\">\n              <div class=\"mfp_rows\">\n                  <div class=\"mfp_col10\">\n                  <input type=\"text\" name=\"学部・学科など\" size=\"50\" data-charcheck=\"zenkaku\" class=\"form-control\">\n                  </div>\n              </div>\n              </dd>\n          </dl>\n          <dl>\n              <dt class=\"\">卒業（予定）年月日<span class=\"must\">必須</span></dt>\n              <dd class=\"\">\n              <div class=\"mfp_rows\">\n                  <div class=\"mfp_col10\">\n                  <input type=\"date\" name=\"卒業（予定）年月日\" size=\"50\" class=\"form-control\" required=\"required\">\n                  </div>\n              </div>\n              </dd>\n          </dl>\n          <dl class=\"chk-privacy\">            \n              <dt class=\"\">個人情報のお取扱いについて<span class=\"must\">必須</span></dt>\n              <dd class=\"\">\n              <div class=\"mfp_rows\">\n                  <div class=\"mfp_col10\">\n                  <label><input type=\"checkbox\" required=\"required\" data-exc=\"1\" name=\"個人情報のお取扱いについて\" value=\"同意する\"> 同意する<br>※個人情報取扱いについて、弊社プライバシーポリシーの内容に同意頂く必要があります。<a href=\"https://www.tis-web.co.jp/privacypolicy.php\" target=\"_blank\">「プライバシーポリシー」</a>については<a href=\"https://www.tis-web.co.jp/privacypolicy.php\" target=\"_blank\">こちら</a>でご確認ください。</label>\n                  </div>\n              </div>\n              </dd>\n          </dl>\n          <section class=\"entryBtn\">\n            <div class=\"personal-carousel-boxBtn\">\n              <button type=\"submit\" class=\"btn\">確認画面へ</button>\n            </div>    \n          </section>\n          </div>\n        </form>\n      </div>\n    </main>\n</div>\n<footer class=\"footer\" id=\"js-footer\">\n    <div class=\"pagetop\">\n        <a href=\"#top\"><span><small>PAGE TOP</small></span></a>\n    </d