            </span>\r\n                                            </h2>\r\n                                            <div class=\"submenufr\">\r\n                                                <div class=\"submenuouter\">\r\n                                                    <div class=\"submenu\">\r\n                                                        <div class=\"submenuulfr\">\r\n                                                            <ul class=\"submenuul\">\r\n                                                                <li>\r\n                                                                    <h3 class=\"submenuultitlefr\">\r\n                                                                        <a class=\"submenuultitle\" href=\"/recruit/recruit_info/person/\">求める人物像</a>\r\n                                                                    </h3>\r\n                                                                </li>\r\n                                                            </ul>\r\n                                                            <ul class=\"submenuul\">\r\n                                                                <li>\r\n                                                                    <h3 class=\"submenuultitlefr\">\r\n                                                                        <a class=\"submenuultitle\" href=\"/recruit/recruit_info/career/\">教育研修制度・支援</a>\r\n                                                                    </h3>\r\n                                                                </li>\r\n                                                            </ul>\r\n                                                            <ul class=\"submenuul\">\r\n                                                                <li>\r\n                                                                    <h3 class=\"submenuultitlefr\">\r\n                                                                        <a class=\"submenuultitle\" href=\"/recruit/recruit_info/welfare/\">福利厚生</a>\r\n                                                                    </h3>\r\n                                                                </li>\r\n                                                            </ul>\r\n                                                            <ul class=\"submenuul\">\r\n                                                                <li>\r\n                                                                    <h3 class=\"submenuultitlefr\">\r\n                                                                        <a class=\"submenuultitle\" href=\"/recruit/recruit_info/requirements_freshman/\">募集要項（新卒・既卒）</a>\r\n                                                                    </h3>\r\n                                                                </li>\r\n                                                            </ul>\r\n                                                            <ul class=\"submenuul\">\r\n                                                                <li>\r\n                                                                    <h3 class=\"submenuultitlefr\">\r\n                                                                        <a class=\"submenuultitle\" href=\"/recruit/recruit_info/requirements_career/\">募集要項（キャリア）</a>\r\n                                                                    </h3>\r\n                                                                </li>\r\n                                                            </ul>\r\n                                                            <ul class=\"submenuul\">\r\n                                                                <li>\r\n                                                                    <h3 class=\"submenuultitlefr\">\r\n                                                                        <a class=\"submenuultitle\" href=\"/recruit/recruit_info/internship/\">インターンシップ</a>\r\n                                                                    </h3>\r\n                                                                </li>\r\n                                                            </ul>\r\n                                                            <ul class=\"submenuul\">\r\n                                                                <li>\r\n                                                                    <h3 class=\"submenuultitlefr\">\r\n                                                                        <a class=\"submenuultitle\" href=\"/recruit/recruit_info/faq/\">FAQ</a>\r\n                                                                    </h3>\r\n                                                                </li>\r\n                                                            </ul>\r\n                                                        </div>\r\n                                                    </div>\r\n                                                </div>\r\n                                            </div>\r\n                                        </li>\r\n                                        <li class=\"only-sp\">\r\n                                            <div class=\"btn-entry-wrap\">\r\n                                                <a class=\"btn-entry font-ls\" href=\"https://www.suwa.sansha.co.jp/entry/\" target=\"_blank\">entry</a>\r\n                                            </div>\r\n                                        </li>\r\n                                    </ul>\r\n                                </div>\r\n                            </div>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n            </nav>\r\n        </header>\r\n\t\t<main>\r\n            <span id=\"top\" valoffsety=\"0\"></span>\r\n            <div class=\"main-wrap main-wrap1\">\r\n                <div class=\"content-wrap\">\r\n                    <div class=\"content\">\r\n                        <div class=\"inner-wrap\">\r\n                            <div class=\"inner\">\r\n                                <h3 class=\"font-ls\">Internship Program</h3>\r\n                                <span>インターンシップ</span>\r\n                            </div>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n            <div class=\"main-wrap main-wrap2\">\r\n                <div class=\"content-wrap\">\r\n                    <div class=\"content\">\r\n                        <ul class=\"breadcrumbfr clearfix\">\r\n                            <li class=\"breadcrumb\"><a class=\"breadcrumblnk\" href=\"/recruit/\">Top</a><span class=\"breadcrumbborder\">／</span>\r\n                            </li>\r\n                            <li class=\"breadcrumb\"><a class=\"breadcrumblnk\" href=\"/recruit/recruit_info/\">採用情報</a><span class=\"breadcrumbborder\">／</span>\r\n                            </li>\r\n                            <li class=\"breadcrumb\"><span class=\"breadcrumblnk\">インターンシップ</span>\r\n                            </li>\r\n                        </ul>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n            <div class=\"main-wrap main-wrap3\">\r\n                <div class=\"content-wrap\">\r\n                    <div class=\"content\">\r\n                        <div class=\"inner-wrap\">\r\n                            <div class=\"inner\">\r\n\t\t\t\t\t\t\t\t<h4>\r\n                                \t<img class=\"only-pc\" src=\"images/main_01_pc.gif\" alt=\"インターンシップ・仕事体験\">\r\n                                \t<img class=\"only-sp\" src=\"images/main_01_sp.gif\" alt=\"インターンシップ・仕事体験\">\r\n\t\t\t\t\t\t\t\t</h4>\r\n\t\t\t\t\t\t\t\t<p>\r\n\t\t\t\t\t\t\t\t\t当社の開発する電源装置は、銀行・病院・工場・データセンター等の様々な場面で、国内外を問わずに社会に貢献しています。<br>\r\n\t\t\t\t\t\t\t\t\tメーカーでの設計開発職を目指す方向けの職場体験プログラムを実施します。<br>\r\n\t\t\t\t\t\t\t\t\tものづくりに興味のある方、大歓迎です。以下の要項をご覧のうえ、ぜひご参加ください。\r\n\t\t\t\t\t\t\t\t</p>\r\n\t\t\t\t\t\t\t\t<h5>\r\n\t\t\t\t\t\t\t\t\t電源製品の設計開発お仕事体験\r\n\t\t\t\t\t\t\t\t\t<span>（回路シミュレーション体験、ＣＡＤ体験（３Ｄ、２Ｄ、パターン設計）、コイル等の設計や試作・実験、マイコン制御体験など）</span>\r\n\t\t\t\t\t\t\t\t</h5>\r\n\t\t\t\t\t\t\t\t<p>\r\n\t\t\t\t\t\t\t\t\t電源機器の設計開発を得意とする当社の要、設計開発の現場でのお仕事体験です。<br>\r\n\t\t\t\t\t\t\t\t\t設計開発を担当する社員が丁寧に指導します。<br>\r\n\t\t\t\t\t\t\t\t\tご自身の専門分野を飛び越えた複合的な内容となっていますので、ぜひ挑戦してください。<br>\r\n\t\t\t\t\t\t\t\t\t当日の体験内容やプログラムは、オリエンテーション時にご案内します。<br>\r\n\t\t\t\t\t\t\t\t\t受入れ時期や期間、職場の状況により内容が変わります。\r\n\t\t\t\t\t\t\t\t</p>\r\n\t\t\t\t\t\t\t\t<h5>参加スケジュール例</h5>\r\n\t\t\t\t\t\t\t\t<div class=\"img\">\r\n\t\t\t\t\t\t\t\t\t<img class=\"only-pc\" src=\"images/main_02_pc.gif\" alt=\"参加スケジュール例\">\r\n\t\t\t\t\t\t\t\t\t<img class=\"only-sp\" src=\"images/main_02_sp.gif\" alt=\"参加スケジュール例\">\r\n\t\t\t\t\t\t\t\t</div>\r\n                            </div>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n\t\t\t<div class=\"main-wrap main-wrap4\">\r\n                <div class=\"content-wrap\">\r\n                    <div class=\"content\">\r\n                        <div class=\"inner-wrap\">\r\n                            <div class=\"inner\">\r\n\t\t\t\t\t\t\t\t<h4>募集要項</h4>\r\n                                <ul>\r\n                                    <li>\r\n                                        <span class=\"list-left\">応募資格</span>\r\n                                        <span class=\"list-right\">\r\n\t\t\t\t\t\t\t\t\t\t\t当社の事業分野に興味があり、業務を実体験したい方<br>\r\n\t\t\t\t\t\t\t\t\t\t\t2028年以降に大学（院）、高専、短大（理系）を卒業・修了見込みの方\r\n\t\t\t\t\t\t\t\t\t\t</span>\r\n                                    </li>\r\n                                    <li>\r\n                                        <span class=\"list-left\">実施時期</span>\r\n                                        <span class=\"list-right\">\r\n\t\t\t\t\t\t\t\t\t\t\t夏季　8月・9月 / 冬季　2月<br />\r\n\t\t\t\t\t\t\t\t\t\t\tお仕事体験（1～3日間）は随時受入れ可能\r\n\r\n\t\t\t\t\t\t\t\t\t\t</span>\r\n                                    </li>\r\n                                    <li>\r\n                                        <span class=\"list-left\">申込締切日</span>\r\n                                        <span class=\"list-right\">\r\n\t\t\t\t\t\t\t\t\t\t\tお仕事体験は随時マイナビにて受付中です。\r\n\t\t\t\t\t\t\t\t\t\t</span>\r\n                                    </li>\r\n                                    <li>\r\n                                        <span class=\"list-left\">実習時間</span>\r\n                                        <span class=\"list-right\">\r\n\t\t\t\t\t\t\t\t\t\t\t10：00～16：00\r\n\t\t\t\t\t\t\t\t\t\t</span>\r\n                                    </li>\r\n                                    <li>\r\n                                        <span class=\"list-left\">場所</span>\r\n                                        <span class=\"list-right\">\r\n\t\t\t\t\t\t\t\t\t\t\t本社（長野県茅野市豊平5335番地）\r\n\t\t\t\t\t\t\t\t\t\t</span>\r\n                                    </li>\r\n                                    <li>\r\n                                        <span class=\"list-left\">報酬</span>\r\n                                        <span class=\"list-right\">\r\n\t\t\t\t\t\t\t\t\t\t\t教育を目的とした実習となりますので報酬はありません。\r\n\t\t\t\t\t\t\t\t\t\t</span>\r\n                                    </li>\r\n                                    <li>\r\n                                        <span class=\"list-left\">交通費・宿泊</span>\r\n                                        <span class=\"list-right\">\r\n\t\t\t\t\t\t\t\t\t\t\t会社規定により実費分を補助します。\r\n\t\t\t\t\t\t\t\t\t\t</span>\r\n                                    </li>\r\n                                    <li>\r\n                                        <span class=\"list-left\">昼食</span>\r\n                                        <span class=\"list-right\">\r\n\t\t\t\t\t\t\t\t\t\t\t社員食堂にてお好きなメニューを選んでいただけます。（無料）\r\n\t\t\t\t\t\t\t\t\t\t</span>\r\n                                    </li>\r\n                                    <li>\r\n                                        <span class=\"list-left\">応募方法</span>\r\n                                        <span class=\"list-right\">\r\n\t\t\t\t\t\t\t\t\t\t\t<a href=\"https://job.mynavi.jp/28/pc/search/corp221137/outline.html\" target=\"_blank\" style=\"display: inline !important; border: none !important; background: transparent !important; padding: 0 !important; margin: 0 !important; text-decoration: underline !important; color: #0000EE !important;\">マイナビ2028</a> または entry より「インターンシップ参加希望」と記載ください。<br>\r\n\t\t\t\t\t\t\t\t\t\t\tお問合せ後、1週間たっても弊社から連絡のない場合は、お手数ですがお電話にてお問い合わせください。\r\n\r\n\t\t\t\t\t\t\t\t\t\t</span>\r\n                                    </li>\r\n                                </ul>\r\n\r\n\t\t\t\t\t<!-- Begin mynavi Navi Link -->\r\n\t\t\t\t\t<div style=\"text-align: center; margin-top: 30px;\">\r\n\t\t\t\t\t<a href=\"https://job.mynavi.jp/28/pc/search/corp221137/outline.html\" target=\"_blank\">\r\n\t\t\t\t\t<img src=\"https://job.mynavi.jp/conts/kigyo/2028/logo/banner_entry_160_45.gif\"alt=\"マイナビ28\" border=\"0\">\r\n\t\t\t\t\t\t</a>\r\n\t\t\t\t\t</div>\r\n\t\t\t\t\t<!-- End mynavi Navi Link -->\r\n\t\t\t\t\r\n                            </div>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n\t\t</main>\r\n\t\t\t\t<footer>\r\n\t\t\t<span id=\"footer\" class=\"\">\r\n\t\t\t\t<div class=\"footer-wrap\">\r\n\t\t\t        <div class=\"footergototop\">\r\n                        <div class=\"btn-entry-wrap\">\r\n                            <a class=\"btn-entry font-ls\" href=\"#top\">TO TOP</a>\r\n                        </div>\r\n                    </div>\r\n\t\t\t\t\t<div class=\"footer-in\">\r\n                        <div class=\"footer-in-inner\">\r\n                            <div class=\"footer-in-left\">\r\n                                <a href=\"/recruit/\"><img src=\"/recruit/common/images/footer_logo_01.png\"