{"url":"https://www.suwa.sansha.co.jp/recruit/recruit_info/internship/","html":"<!DOCTYPE html>\r\n<html lang=\"ja\" dir=\"ltr\">\r\n\t<head>\r\n\t\t<meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\">\r\n\t\t<meta equiv=\"X-UA-Compatible\" content=\"IE=edge,chrome=1\">\r\n\t\t<meta name=\"viewport\" content=\"width=device-width,initial-scale=1.0\">\r\n\t\t<title>インターンシップ｜採用情報｜株式会社諏訪三社電機｜採用サイト</title>\r\n\t\t<meta name=\"description\" content=\"新卒・中途採用に関する情報として、事業や先輩社員の紹介をはじめ、研修・キャリア制度や福利厚生、募集要項などをご紹介。仕事を知る、人を知る、など当社で働く環境を皆さまにお伝えします。諏訪三社電機は高効率で信頼性の高い電源機器をご提案します。\">\r\n\t\t<meta name=\"keywords\" content=\"採用,新卒,電源,電子機器,メーカー,リクルート\">\r\n\t\t<meta name=\"author\" content=\"Suwa Sansha Electric\">\r\n\t\t<!-- OGP -->\r\n\t\t<meta property=\"og:site_name\" content=\"株式会社諏訪三社電機\">\r\n\t\t<meta property=\"og:description\" content=\"株式会社諏訪三社電機オフィシャルサイト。電源装置等の電子機器の製造・販売について、小型化・コストダウン・フレキシブルなご対応などご要望にあわせてご提案いたします。\">\r\n\t\t<meta property=\"og:type\" content=\"website\">\r\n\t\t<meta property=\"og:url\" content=\"https://www.suwa.sansha.co.jp/\">\r\n\t\t<meta property=\"og:image\" content=\"https://www.suwa.sansha.co.jp/images/opengraph.png\">\r\n\t\t<meta property=\"og:locale\" content=\"ja\">\r\n\t\t<!-- / OGP -->\r\n\t\t<!-- Global site tag (gtag.js) - Google Analytics -->\r\n\t\t<script async src=\"https://www.googletagmanager.com/gtag/js?id=UA-86128310-2\"></script>\r\n\t\t<script>\r\n\t\twindow.dataLayer = window.dataLayer || [];\r\n\t\tfunction gtag(){dataLayer.push(arguments);}\r\n\t\tgtag('js', new Date());\r\n\r\n\t\tgtag('config', 'UA-86128310-2');\r\n\t\t</script>\r\n\t\t<meta http-equiv=\"pragma\" content=\"no-cache\">\r\n\t\t<meta http-equiv=\"cache-control\" content=\"no-cache, no-store\">\r\n\t\t<meta name=\"format-detection\" content=\"telephone=no\">\r\n\t\t<link rel=\"icon\" href=\"/favicon.ico\" type=\"image/x-icon\">\r\n\t\t<link rel=\"icon\" type=\"image/vnd.microsoft.icon\" href=\"/favicon.ico\">\r\n\t\t<link rel=\"Shortcut Icon\" type=\"image/x-icon\" href=\"/favicon.ico\">\r\n\t\t<link rel=\"shortcut icon\" href=\"/images/favicon.ico\">\r\n\t\t<link rel=\"icon\" type=\"image/vnd.microsoft.icon\" href=\"/images/favicon.ico\">\r\n\t\t<link rel=\"stylesheet\" type=\"text/css\" href=\"/recruit/common/css/reset.css\" media=\"all\">\r\n\t\t<link rel=\"stylesheet\" type=\"text/css\" href=\"/recruit/common/css/webfont.css\" media=\"all\">\r\n\t\t<link rel=\"stylesheet\" type=\"text/css\" href=\"/recruit/common/css/base.css\" media=\"all\">\r\n\t\t<link rel=\"stylesheet\" type=\"text/css\" href=\"/recruit/common/css/jquery.mCustomScrollbar.css\" media=\"all\">\r\n\t\t<script type=\"text/javascript\" src=\"/recruit/common/js/jquery-1.11.3.min.js\"></script>\r\n\t\t<script type=\"text/javascript\" src=\"/recruit/common/js/jquery.easing.1.3.js\"></script>\r\n\t\t<script type=\"text/javascript\" src=\"/recruit/common/js/init.js\"></script>\r\n\t\t<script type=\"text/javascript\" src=\"/recruit/common/js/iscroll.js\"></script>\r\n\t\t<script type=\"text/javascript\" src=\"/recruit/common/js/jquery.mCustomScrollbar.js\"></script>\r\n        <script type=\"text/javascript\" src=\"/recruit/common/js/gototop.js\"></script>\r\n\t\t<script type=\"text/javascript\" src=\"/recruit/common/js/header1.js\"></script>\r\n\t\t<!--※-->\r\n\t\t<link rel=\"stylesheet\" type=\"text/css\" href=\"css/index.css\" media=\"all\" />\r\n\t\t\r\n\t</head>\r\n\t<body><!--※-->\r\n\t\t\r\n\t\t\t\t<header class=\"clearfix\">\r\n            <nav id=\"header\">\r\n                <div class=\"navfr\">\r\n                    <div class=\"nav\">\r\n                        <h1 class=\"logo\">\r\n\t\t\t\t\t\t\t<a href=\"/recruit/\">\r\n\t\t\t\t\t\t\t\t<img class=\"only-pc\" alt=\"ロゴ\" src=\"/recruit/common/images/logo_01_pc.png\">\r\n\t\t\t\t\t\t\t\t<img class=\"only-sp\" alt=\"ロゴ\" src=\"/recruit/common/images/logo_01_sp.png\">\r\n\t\t\t\t\t\t\t</a>\r\n\t\t\t\t\t\t</h1>\r\n                        <a href=\"https://www.suwa.sansha.co.jp/ent