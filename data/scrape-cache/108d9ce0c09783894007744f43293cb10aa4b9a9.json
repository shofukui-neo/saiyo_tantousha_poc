{"url":"https://www.fuji-kougyou.jp/seizo_recruit/index.html","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n  <head>\n    <meta charset=\"UTF-8\" />\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n    <title>藤工業株式会社</title>\n\n    <!-- favicon -->\n    <link\n      rel=\"apple-touch-icon\"\n      sizes=\"180x180\"\n      href=\"./assets/ico/apple-touch-icon.png\"\n    />\n    <link\n      rel=\"icon\"\n      type=\"image/png\"\n      sizes=\"32x32\"\n      href=\"./assets/ico/favicon-32x32.png\"\n    />\n    <link\n      rel=\"icon\"\n      type=\"image/png\"\n      sizes=\"16x16\"\n      href=\"./assets/ico/favicon-16x16.png\"\n    />\n    <link rel=\"manifest\" href=\"./assets/ico/site.webmanifest\" />\n    <link\n      rel=\"mask-icon\"\n      href=\"./assets/ico/safari-pinned-tab.svg\"\n      color=\"#025602\"\n    />\n    <meta name=\"msapplication-TileColor\" content=\"#025602\" />\n    <meta name=\"theme-color\" content=\"#ffffff\" />\n\n    <!-- Adobe Fonts -->\n    <script>\n      (function (d) {\n        var config = {\n            kitId: \"mfs0iwu\",\n            scriptTimeout: 3000,\n            async: true,\n          },\n          h = d.documentElement,\n          t = setTimeout(function () {\n            h.className =\n              h.className.replace(/\\bwf-loading\\b/g, \"\") + \" wf-inactive\";\n          }, config.scriptTimeout),\n          tk = d.createElement(\"script\"),\n          f = false,\n          s = d.getElementsByTagName(\"script\")[0],\n          a;\n        h.className += \" wf-loading\";\n        tk.src = \"https://use.typekit.net/\" + config.kitId + \".js\";\n        tk.async = true;\n        tk.onload = tk.onreadystatechange = function () {\n          a = this.readyState;\n          if (f || (a && a != \"complete\" && a != \"loaded\")) return;\n          f = true;\n          clearTimeout(t);\n          try {\n            Typekit.load(config);\n          } catch (e) {}\n        };\n        s.parentNode.insertBefore(tk, s);\n      })(document);\n    </script>\n\n    <!-- reset.css -->\n    <link rel=\"stylesheet\" href=\"https://unpkg.com/ress/dist/ress.min.css\" />\n\n    <!-- style.css -->\n    <link rel=\"stylesheet\" href=\"./assets/css/style.css\" />\n  </head>\n  <body>\n    <!-- header -->\n    <header class=\"fjk-header\" id=\"header\">\n      <div class=\"fjk-header__bgColor\">\n        <div class=\"fjk-header__main\">\n          <div class=\"fjk-container__95\">\n            <a class=\"fjk-header__logo\" href=\"/\">\n              <img\n                src=\"./assets/img/global_logo_img.png\"\n                alt=\"藤工業株式会社\"\n              />\n            </a>\n          </div>\n          <a\n            href=\"https://en-gage.net/fuji-kougyou/\"\n            target=\"_blank\"\n            rel=\"noopener noreferrer\"\n            >ENTRY</a\n          >\n        </div>\n      </div>\n    </header>\n\n    <!-- mv -->\n    <div class=\"fjk-homeMv\">\n      <div class=\"fjk-homeMv__bgImg fjk-bgImg\">\n        <div class=\"fjk-homeMv__main\">\n          <h1>\n            確かな強度<span>と</span><br class=\"mq_sp\" />品質<span>で</span>\n            <br />\n            お客様<span>に</span>安心<span>を</span>\n          </h1>\n          <div class=\"fjk-homeMv__map\">\n            <div>\n              <img src=\"./assets/img/home_mv-japan_img.png\" alt=\"\" />\n              <ul>\n                <li class=\"fjk-homeMv__mapItem\">\n                  <ul>\n                    <li>\n                      千歳工場\n                      <br />\n                      岩見沢作業所\n                    </li>\n                  </ul>\n                </li>\n                <li class=\"fjk-homeMv__mapItem\">\n                  <ul>\n                    <li>秋田工場</li>\n                  </ul>\n                </li>\n                <li class=\"fjk-homeMv__mapItem\">\n                  <ul>\n                    <li>宮城工場</li>\n                  </ul>\n                </li>\n                <li class=\"fjk-homeMv__mapItem\">\n                  <ul>\n                    <li>本社・岩槻工場</li>\n                    <li>岩槻第二工場</li>\n                    <li>岩槻第三工場</li>\n                    <li>岩槻第四工場</li>\n                  </ul>\n                </li>\n                <li class=\"fjk-homeMv__mapItem\">\n                  <ul>\n                    <li>エフテック<br />株式会社</li>\n                  </ul>\n                </li>\n                <li class=\"fjk-homeMv__mapItem\">\n                  <ul>\n                    <li>\n                      トーエイ\n                      <br />\n                      コンストラクション\n                    </li>\n                  </ul>\n                </li>\n              </ul>\n            </div>\n          </div>\n          <p>\n            全力で稼げる環境に\n            <br />\n            連れて行く。\n          </p>\n          <span></span>\n          <span></span>\n          <span></span>\n        </div>\n      </div>\n    </div>\n\n    <!-- pride-->\n    <div class=\"fjk-homePride\">\n      <div class=\"fjk-homePride__bgColor\">\n        <div class=\"fjk-homePride__main\">\n          <h3>\n            現代の日本らしさ<br class=\"mq_sp\" />ともいえる、<br\n              class=\"mq_pc\"\n            />高層ビル・マンション。\n            <br />\n            その土台を、<br class=\"mq_sp\" />俺たちが組み上げる。\n          </h3>\n          <div class=\"fjk-homePride__tit\">\n            <h2>信念</h2>\n            <p>PRIDE</p>\n          </div>\n          <h4>世界に誇る日本の建設</h4>\n          <div class=\"fjk-homePride__cont\">\n            <p>\n              ビルやマンションといった<br\n                class=\"mq_sp\"\n              />スケールの大きな建物から木造住宅のような\n              <br />\n              小さな土台や木造住宅の建て方を手がけられます。\n              <br />\n              「それって、未経験には難しいんじゃ…」\n              <br />\n              いえ、そんなことはありません！\n              <br />\n              しっかり教えますし、<br\n                class=\"mq_sp\"\n              />【残業は少なめ×休みは豊富】なので、\n              <br />\n              未経験からでも十分始められます。\n              <br />\n              ムリのないペースで腕を上げていきましょう！\n            </p>\n            <a href=\"https://www.fuji-kougyou.jp/\">さらに詳しく</a>\n          </div>\n          <div class=\"fjk-homePride__img\">\n            <img\n              class=\"fjk-fixedRadioImg\"\n              src=\"./assets/img/home_pride_img.png\"\n              alt=\"\"\n            />\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <!-- point -->\n    <div class=\"fjk-homePoint\">\n      <div class=\"fjk-homePoint__main\">\n        <div class=\"fjk-homePoint__tit\">\n          <div class=\"fjk-maxWidth\">\n            <div class=\"fjk-container__85\">\n              <div class=\"fjk-baseTit\">\n                <h2>藤工業の強み</h2>\n                <p>POINT</p>\n              </div>\n            </div>\n          </div>\n        </div>\n        <div class=\"fjk-homePoint__slide\">\n          <div class=\"fjk-maxWidth\">\n            <div class=\"fjk-container__70\">\n              <div class=\"fjk-homePoint__slideFrame\" id=\"point-slide-frame\">\n                <ul>\n                  <li class=\"fjk-homePoint__slideItem\">\n                    <div>\n                      <div>\n                        <img\n                          class=\"fjk-fixedRadioImg\"\n                          src=\"./assets/img/home_point-1_img.jpg\"\n                          alt=\"\"\n                        />\n                      </div>\n                      <h3>\n                        キャリアステージが明確なため、着実にキャリアアップしていけます！\n                      </h3>\n                      <p>\n                        どの程度スキルを身につければ次のポストに就けるかがハッキリしているため、下積み時代も前向きに働けるのは大きな魅力の一つ！\n                        <br />\n                        もちろん経験がある方なら、これまでの経験を活かして早期のキャリアアップを目指せます。\n                      </p>\n                    </div>\n                  </li>\n                  <li class=\"fjk-homePoint__slideItem\">\n                    <div>\n                      <div>\n                        <img\n                          class=\"fjk-fixedRadioImg\"\n                          src=\"./assets/img/home_point-2_img.jpg\"\n                          alt=\"\"\n                        />\n                      </div>\n                      <h3>\n                        売上100億を目指す日本一の成長企業と共に働いてみませんか！\n                      </h3>\n                      <p>\n                        藤工業は社員だけでなく会社も成長します！売上100億を目指す挑戦を続けています！\n                        <br />\n                        日本一の企業を目指す意欲的なチームで、あなたの力を発揮してみませんか？あなたにピッタリの環境で、自分の能力や価値を実証するチャンスです！\n                      </p>\n                    </div>\n                  </li>\n                  <li class=\"fjk-homePoint__slideItem\">\n                    <div>\n                      <div>\n                        <img\n                          class=\"fjk-fixedRadioImg\"\n                          src=\"./assets/img/home_point-3_img.jpg\"\n                          alt=\"\"\n                        />\n                      </div>\n                      <h3>\n                        資格取得も全力応援！更なるステップアップを共に目指しましょう\n                        ！\n                      </h3>\n                      <p>\n                        外でも活かせるスキルを獲得可能。\n                        <br />\n                        業界標準の認定資格を取得し、キャリアの可能性を広げましょう！\n                      </p>\n                    </div>\n                  </li>\n                  <li class=\"fjk-homePoint__slideItem\">\n                    <div>\n                      <div>\n                        <img\n                          class=\"fjk-fixedRadioImg\"\n                          src=\"./assets/img/home_point-4_img.jpg\"\n                          alt=\"\"\n                        />\n                      </div>\n                      <h3>\n                        未経験からでもチャレンジ可能！安心のサポートで成長できる環境！\n                      </h3>\n                      <p>\n                        20〜30代の未経験も大歓迎！平均年齢44歳、20代〜60代の幅広い年齢の方が活躍しています。未経験からでも経験を積みながらキャリアを築けます。\n                        <br />\n                        若いうちから責任を持ち、チャレンジングな仕事に挑戦できるため、大きな成長を見込めます！\n                      </p>\n                    </div>\n                  </li>\n                  <li class=\"fjk-homePoint__slideItem\">\n                    <div>\n                      <div>\n                        <img\n                          class=\"fjk-fixedRadioImg\"\n                          src=\"./assets/img/home_point-5_img.jpg\"\n                          alt=\"\"\n                        />\n                      </div>\n                      <h3>\n                        トライアル入社可能！入社してからのギャップを感じさせない環境です！\n                      </h3>\n                      <p>\n                        藤工業はトライアル雇用も積極的に取り入れています！未経験からの入社でも、業界に慣れるまで全力でサポートします。\n                        <br />\n                        あなたにピッタリの環境で、自分の能力や価値を実証するチャンスです！\n                      </p>\n                    </div>\n                  </li>\n                  <li class=\"fjk-homePoint__slideItem\">\n                    <div>\n                      <div>\n                        <img\n                          class=\"fjk-fixedRadioImg\"\n                          src=\"./assets/img/home_point-6_img.jpg\"\n                          alt=\"\"\n                        />\n                      </div>\n                      <h3>\n                        経験者も大歓迎！アルムナイ採用で管理職へステップアップ！\n                      </h3>\n                      <p>\n                        元経験者も多数活躍中！アルムナイ採用を取り入れており、成長のチャンスが豊富な環境で管理職へのステップアップを目指していきませんか。\n                        <br />\n                        独立支援やグループ会社移籍も積極的に支援！\n                      </p>\n                    </div>\n                  </li>\n                  <li class=\"fjk-homePoint__slideItem\">\n                    <div>\n                      <div>\n                        <img\n                          class=\"fjk-fixedRadioImg\"\n                          src=\"./assets/img/home_point-7_img.jpg\"\n                          alt=\"\"\n                        />\n                      </div>\n                      <h3>\n                        ワークライフバランス重視！あなたにある働き方を実現していきましょう！\n                      </h3>\n                      <p>\n                        社員全員が充実した働き方を実現。\n                        <br />\n                        安定したキャリアパスと長期的なキャリアプランを描ける環境を約束します。\n                        <br />\n                        また65歳定年制ながら、延長で働く方も多数います。\n                      </p>\n                    </div>\n                  </li>\n                </ul>\n              </div>\n            </div>\n            <span class=\"fjk-homePoint__slideNav\" id=\"point-slide-prev\"></span>\n            <span class=\"fjk-homePoint__slideNav\" id=\"point-slide-next\"></span>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <!-- step -->\n    <div class=\"fjk-homeStep\">\n      <div class=\"fjk-homeStep__main\">\n        <div class=\"fjk-homeStep__tit\">\n          <div class=\"fjk-maxWidth\">\n            <div class=\"fjk-container__85\">\n              <div class=\"fjk-baseTit\">\n                <h2>入社後の流れ</h2>\n                <p>STEP UP</p>\n              </div>\n            </div>\n          </div>\n        </div>\n        <div class=\"fjk-maxWidth\">\n          <div class=\"fjk-container__75\">\n            <div class=\"fjk-homeStep__cont\">\n              <ul>\n                <li class=\"fjk-homeStep__contItem\">\n                  <p>\n                    STEP\n                    <br />\n                    <strong>1</strong>\n                  </p>\n                  <div class=\"fjk-homeStep__contItemTit\">\n                    <h3><span>見</span>習い</h3>\n                    <p>\n                      先輩と現場に出て、道具の使い方や工事の進め方の基礎を、作業しながら学んでいきます。\n                    </p>\n                  </div>\n                  <img src=\"./assets/img/home_step-1_img.png\" alt=\"\" />\n                </li>\n                <li class=\"fjk-homeStep__contItem\">\n                  <p>\n                    STEP\n                    <br />\n                    <strong>2</strong>\n                  </p>\n                  <div class=\"fjk-homeStep__contItemTit\">\n                    <h3><span>一</span>人前</h3>\n                    <p>\n                      スキルがある程度身につけば、国家資格の取得にもチャレンジ！一人で大体の仕事の段取りができるようになれば一人前の職人と呼べます。\n                    </p>\n                  </div>\n                  <img src=\"./assets/img/home_step-2_img.png\" alt=\"\" />\n                </li>\n                <li class=\"fjk-homeStep__contItem\">\n                  <p>\n                    STEP\n                    <br />\n                    <strong>3</strong>\n                  </p>\n                  <div class=\"fjk-homeStep__contItemTit\">\n                    <h3><span>職</span>長</h3>\n                    <p>\n                      元請けとの打ち合わせや工程調整など、一つの現場を管理できるようになれば職長にキャリアアップ。仕事の幅が広がるとその分給与も上がります。\n                    </p>\n                  </div>\n                  <img src=\"./assets/img/home_step-3_img.png\" alt=\"\" />\n                </li>\n                <li class=\"fjk-homeStep__contItem\">\n                  <p>\n                    STEP\n                    <br />\n                    <strong>4</strong>\n                  </p>\n                  <div class=\"fjk-homeStep__contItemTit\">\n                    <h3><span>ベ</span>テラン</h3>\n                    <p>\n                      経験もスキルも文句なしのレベルになれば、ベテランの仲間入り。他のスタッフのマネジメントを手がけるポジションを目指せます。\n                    </p>\n                  </div>\n                  <img src=\"./assets/img/home_step-4_img.png\" alt=\"\" />\n                </li>\n              </ul>\n              <div class=\"fjk-homeStep__supplement\">\n                <h3>\n                  少しずつ<br class=\"mq_sp\" />上を\n                  <br />\n                  目指そう！\n                </h3>\n                <img\n                  class=\"fjk-fijimaruImg\"\n                  src=\"./assets/img/global_fujimaru-2_img.png\"\n                  alt=\"\"\n                />\n              </div>\n            </div>\n          </div>\n          <div class=\"fjk-maxWidth\">\n            <div class=\"fjk-container__80\">\n              <div class=\"fjk-homeStep__btn\">\n                <a\n                  href=\"https://en-gage.net/fuji-kougyou/\"\n                  target=\"_blank\"\n                  rel=\"noopener noreferrer\"\n                  >応募はこちら</a\n                >\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <!-- president -->\n    <div class=\"fjk-homePresident\">\n      <div class=\"fjk-homePresident__bgColor\">\n        <div class=\"fjk-homePresident__main\">\n          <div class=\"fjk-maxWidth\">\n            <div class=\"fjk-container__85\">\n              <div class=\"fjk-homePresident__top\">\n                <div class=\"fjk-homePresident__topLeft\">\n                  <img\n                    class=\"fjk-fixedRadioImg\"\n                    src=\"./assets/img/home_president-top_img.jpg\"\n                    alt=\"\"\n                  />\n                </div>\n                <div class=\"fjk-homePresident__topRight\">\n                  <div class=\"fjk-homePresident__topRightTit\">\n                    <p>代表取締役社長</p>\n                    <h2>藤田 清志</h2>\n                    <p>FUJITA KIYOSHI</p>\n                  </div>\n                  <div class=\"fjk-homePresident__topRightCont\">\n                    <h3>\n                      鉄筋の総合デパートとして\n                      <br />\n                      「３Ｓ（創意工夫・スピード・信頼）」を心に地域Ｎｏ．１企業を目指します。\n                    </h3>\n                    <p>\n                      藤工業グループは、1977年創業以来、鉄筋工事請負業の豊富な経験と技術力を活かし戸建て向け製品、建材店向け製品とお客様のご期待に応えるべく努力を続けてまいりました。\n                      <br />\n                      <br />\n                      現在、藤工業グループがあるのは、お客様やお取引先様から単にお声かけを頂いているばかりではなく、社員一人一人の仕事に対する姿勢を評価いただいていると考えています。お客様やお取引様から頂いた、ご縁を大切に、支えてくれる皆様があって今がある。これからも「鉄筋の総合デパート」として、皆様方の期待に応えるべく努力、挑戦を続けてまいります。\n                      <br />\n                      <br />\n                      藤工業グループは鉄筋を通じて「人に、社会に、地域に」貢献し、社員一人一人が誠意、熱い想い、強い意志、そして高い技術を持ってお客様に「最高の品質、最高の安心、最高の満足」をお届けし\n                      お客様と共に挑戦、成長を続けていく事が、社員一人一人の幸せ、喜びに繋がっていきます。\n                      <br />\n                      人に心に「最高の感動」を、これが藤工業グループの「志命」です。\n                    </p>\n                  </div>\n                </div>\n              </div>\n            </div>\n          </div>\n          <div class=\"fjk-homePresident__bottom\">\n            <img\n              class=\"fjk-fixedRadioImg\"\n              src=\"./assets/img/home_president-bottom_img.jpg\"\n              alt=\"\"\n            />\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <!-- environment -->\n    <div class=\"fjk-homeEnvironment\">\n      <div class=\"fjk-homeEnvironment__bgImg fjk-bgImg\">\n        <div class=\"fjk-maxWidth\">\n          <div class=\"fjk-container__90\">\n            <div class=\"fjk-homeEnvironment__main\">\n              <div class=\"fjk-homeEnvironment__left\">\n                <ul>\n                  <li>残業少なめ</li>\n                  <li>資格取得支援あり</li>\n                  <li>借り上げ社宅あり</li>\n                  <li>出張・転勤なし</li>\n                  <li>ボーナス年2回支給</li>\n                  <li>リフレッシュ休暇あり</li>\n                </ul>\n              </div>\n              <div class=\"fjk-homeEnvironment__right\">\n                <h2>\n                  働く環境も\n                  <br />\n                  しっかり<br class=\"mq_sp\" />整えます！\n                </h2>\n                <div>\n                  <p>ふじ丸</p>\n                  <img\n                    class=\"fjk-fijimaruImg\"\n                    src=\"./assets/img/global_fujimaru-1_img.png\"\n                    alt=\"\"\n                  />\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <!-- about -->\n    <div class=\"fjk-homeAbout\">\n      <div class=\"fjk-homeAbout__main\">\n        <div class=\"fjk-homeAbout__tit\">\n          <h2>会社概要</h2>\n          <p>company overview</p>\n        </div>\n        <div class=\"fjk-maxWidth\">\n          <div class=\"fjk-container__65\">\n            <div class=\"fjk-homeAbout__cont\">\n              <ul>\n                <li class=\"fjk-homeAbout__contItem\">\n                  <p>会社名</p>\n                  <p>藤工業株式会社</p>\n                </li>\n                <li class=\"fjk-homeAbout__contItem\">\n                  <p>募集職種</p>\n                  <p>鉄筋組立工事・住宅基礎工事・住宅建て方工事</p>\n                </li>\n                <li class=\"fjk-homeAbout__contItem\">\n                  <p>勤務時間</p>\n                  <p>8:00～17:30 ★残業少なめ</p>\n                </li>\n                <li class=\"fjk-homeAbout__contItem\">\n                  <p>雇用区分</p>\n                  <p>正社員 ★トライアル雇用可能</p>\n                </li>\n                <li class=\"fjk-homeAbout__contItem\">\n                  <p>試用期間</p>\n                  <p>3ヶ月（条件変動なし）</p>\n                </li>\n                <li class=\"fjk-homeAbout__contItem\">\n                  <p>契約期間</p>\n                  <p>期間の定めなし</p>\n                </li>\n                <li class=\"fjk-homeAbout__contItem\">\n                  <p>勤務地</p>\n                  <p>〒339-0072 埼玉県さいたま市岩槻区古ヶ場2-7-1</p>\n                </li>\n                <li class=\"fjk-homeAbout__contItem\">\n                  <p>最寄駅</p>\n                  <p>東岩槻駅</p>\n                </li>\n                <li class=\"fjk-homeAbout__contItem\">\n                  <p>給与</p>\n                  <p>\n                    月給 300,000 - 500,000円\n                    <br />\n                    ※経験者は優遇します。お気軽にご相談ください\n                  </p>\n                </li>\n                <li class=\"fjk-homeAbout__contItem\">\n                  <p>本社所在地</p>\n                  <p>\n                    〒339-0072\n                    <br />\n                    埼玉県さいたま市岩槻区古ヶ場2-7-1\n                  </p>\n                </li>\n                <li clas