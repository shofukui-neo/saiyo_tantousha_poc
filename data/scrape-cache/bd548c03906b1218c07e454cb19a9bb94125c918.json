"text/css\" href=\"../_csslinkbtn/btn-import.css?1767099951882\" id=\"linkbtn-css\"> \n </head> \n <body id=\"l-2\" class=\"l-2 l-fixed-side -dress_pp013recruit bd-webp\" data-type=\"responsive\" data-layout-type=\"sidefixed\" data-view-pc-button=\"true\" data-view-pc-position=\"bottom\" data-page-animation=\"none\"> \n  <div id=\"page\" class=\"bg-window \"> \n   <div class=\"bg-document\"> \n    <noscript> \n     <div id=\"js-off\"> \n      <img src=\"../_module/images/noscript.gif\" alt=\"Enable JavaScript in your browser. このウェブサイトはJavaScriptをオンにしてご覧下さい。\"> \n     </div> \n    </noscript> \n    <div id=\"a-header\" data-float=\"false\" class=\"a-header   cssskin-_area_header\"> \n     <header> \n      <div class=\"site_frame\"> \n       <section> \n        <div id=\"bk5474\" class=\"b-plain c-space_normal c-sp-space_normal c-padding_narrow c-sp-padding_normal cssskin-_block_header\" data-bk-id=\"bk5474\" data-shared=\"true\" data-sharedname=\"HEADER2\"> \n         <div class=\" column -column1\"> \n          <div class=\" c-body\"> \n           <div class=\"c-img   \"> \n            <a href=\"../index.html\" data-pid=\"70\"> \n             <picture> \n              <source type=\"image/webp\" srcset=\"../_src/960/logo-credit-500.webp?v=1767099951882\"> \n              <img src=\"../_src/960/logo-credit-500.png?v=1767099951882\" width=\"2085\" height=\"327\" alt=\"\" id=\"imgsrc960_1\" class=\" c-no_adjust\" loading=\"lazy\"> \n             </picture></a> \n           </div> \n          </div> \n         </div> \n        </div> \n        <div id=\"bk5475\" class=\"b-plain -blog-article c-space_narrow c-sp-space_normal c-sp-padding_normal bd-webp -dress_white cssskin-_block_header\" data-bk-id=\"bk5475\" data-shared=\"true\" data-sharedname=\"HEADER\"> \n         <div class=\" column -column1\"> \n          <nav> \n           <div id=\"js-globalNavigation\" data-slide-type=\"rightSlide\" data-btn-position=\"rightTop\"> \n            <div class=\" js-motion\"> \n             <ul class=\"m-motion menu-parts -f\"> \n              <li class=\" c-left\"><a href=\"../company_profile/index.html\" data-pid=\"77\">ご挨拶</a></li> \n              <li class=\" c-left\"><a href=\"../company_profile/index1.html\" data-pid=\"78\">企業概要</a> \n               <ul> \n                <li class=\" c-left\"><a href=\"../company_profile/index1.html#profile\" data-pid=\"78\">会社概要</a></li> \n                <li class=\" c-left\"><a href=\"../company_profile/index1.html#history\" data-pid=\"78\">沿革</a></li> \n                <li class=\" c-left\"><a href=\"../company_profile/index1.html#maker\" data-pid=\"78\">取り扱いメーカー</a></li> \n               </ul></li> \n              <li class=\" c-left\"><a href=\"../Activities/index.html\" data-pid=\"123\">事業案内</a></li> \n              <li class=\" c-left\"><a href=\"../base/location.html\" data-pid=\"103\">事業所一覧</a></li> \n              <li class=\" c-left\"><a href=\"../Product_guide/product01.html\" data-pid=\"90\">取扱商品</a></li> \n              <li class=\" c-left\"><a href=\"../festa2022/index.html\" data-pid=\"79\">ツールdeフェスタ</a></li> \n              <li class=\" c-left\"><a href=\"https://job-gear.net/sankotech/\">採用情報</a></li> \n              <li class=\" c-left\"><a href=\"../Information/index.html\" data-pid=\"122\">お問い合わせ</a></li> \n              <li class=\" c-left\"><a href=\"../info.html\" data-pid=\"72\">Information</a> \n               <ul> \n                <li class=\" c-left\"><a href=\"../info.html\" data-pid=\"72\">新着情報</a></li> \n                <li class=\" c-left\"><a href=\"../stj.html\" data-pid=\"73\">STジャーナル</a></li> \n               </ul></li> \n             </ul> \n            </div> \n           </div> \n           <div id=\"spNavigationTrigger\" class=\" c-sp_navigation_btn\"></div> \n          </nav> \n         </div> \n        </div> \n       </section> \n      </div> \n     </header> \n    </div> \n    <div id=\"a-billboard\" class=\"a-billboard    cssskin-_area_billboard\"> \n     <div class=\"site_frame\"> \n      <section> \n       <div id=\"bk5476\" class=\"b-plain c-space_normal c-sp-space_normal c-sp-padding_init cssskin-_block_billboard\" data-bk-id=\"bk5476\"> \n        <div class=\" column -column1\"> \n         <div class=\" c-body\"> \n          <div class=\"c-img   \"> \n           <picture> \n            <source type=\"image/webp\" srcset=\"../_src/7138/information_banner_20190526095941163.webp?v=1767099951882\"> \n            <img src=\"../_src/7138/information_banner_20190526095941163.jpg?v=1767099951882\" width=\"1000\" height=\"300\" alt=\"\" id=\"imgsrc7138_1\" loading=\"lazy\"> \n           </picture> \n          </div> \n         </div> \n        </div> \n       </div> \n       <div id=\"bk5477\" class=\"b-plain c-space_normal c-sp-space_normal c-sp-padding_normal cssskin-h2_midashi2\" data-bk-id=\"bk5477\"> \n        <div class=\" column -column1\" id=\"top\"> \n         <h4 class=\" c-small_headline\">&nbsp; <span style=\"color:#ffffff;\">&nbsp;&nbsp;新着情報</span></h4> \n        </div> \n       </div> \n      </section> \n     </div> \n    </div> \n    <main> \n     <div id=\"a-site_contents\" class=\"a-site_contents  noskin\"> \n      <article> \n       <div class=\"site_frame\"> \n        <div class=\"g-column\"> \n         <div id=\"a-main\" class=\"a-main column -col8 \"> \n          <section> \n           <div id=\"bk5490\" class=\"b-plain c-space_normal c-sp-space_normal c-padding_normal c-sp-padding_normal cssskin-_block_main\" data-bk-id=\"bk5490\"> \n            <div class=\" column -column1\" id=\"241125\"> \n             <p class=\" c-body\"><span class=\" d-large_font\"><span class=\" d-bold\"><span style=\"color:#073763;\">冬季休暇の御案内</span></span></span></p> \n             <div class=\" c-body c-right\"> \n              <hr class=\"c-hr\"> 2024.11.25 \n             </div> \n             <div class=\" c-body c-left\">\n               平素は格別のご高配を賜り、厚く御礼を申し上げます \n             </div> \n             <div class=\" c-body c-left\">\n               &nbsp; \n             </div> \n             <div class=\" c-body c-left\"> \n              <span style=\"color:#434343;\" data-sitecolor-text=\"\">弊社では下記の期間を冬季休暇とさせて頂きます</span> \n              <br> \n              <span style=\"color:#434343;\">期間中は何かとご不便をお掛けいたしますが、宜しくお願い申し上げます　</span> \n              <br> \n              <br> \n              <span class=\" d-bold\"><span style=\"color:#a61c00;\" data-sitecolor-text=\"\">2024年12月28日(土曜日)〜2025年1月5日(日曜日</span></span> \n              <span class=\" d-bold\"><span style=\"color:#a61c00;\" data-sitecolor-text=\"\">)</span></span> \n              <br> \n              <br> \n              <span style=\"color:#434343;\" data-sitecolor-text=\"\">レンタル商品の納品・引取は、お早めに御連絡くださいますようお願い申し上げます</span> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk5491\" class=\"b-plain c-space_normal c-sp-space_normal c-padding_normal c-sp-padding_normal cssskin-_block_main\" data-bk-id=\"bk5491\"> \n            <div class=\" column -column1\" id=\"241020\"> \n             <p class=\" c-body\"><span class=\" d-large_font\"><span class=\" d-bold\"><span style=\"color:#073763;\">第74回 リーダー会議実施</span></span></span></p> \n             <div class=\" c-body c-right\"> \n              <hr class=\"c-hr\"> 2024.10.20 \n             </div> \n             <div class=\" c-body c-right\">\n               &nbsp; \n             </div> \n             <div class=\" c-body\">\n               9月27日・28日の2日間に渡ってリーダー会議を行いました。 \n              <br>今回は営業所ではなく、仙台の秋保温泉（ホテルニュー水戸屋）の会議室をお借りしての開催となりました \n              <br> \n              <br>1日目は終日ディスカッションを行い、参加メンバー各々の意見を出し合うことが出来ました。 \n              <br>普段とは違う場所で、有意義な会議となりました。 \n              <br> \n              <br>温泉での会議という事で、夜は美味しいごはんを頂きました。 \n              <br>少し緊張のほぐれたその様子は、Instagramをご覧ください。 \n              <br>&nbsp; \n              <br>サンコーテック公式インスタグラム　 \n              <br>こちらから→ \n              <div class=\"c-img   \"> \n               <a href=\"https://www.instagram.com/sankotech_official/\" target=\"_blank\" rel=\"noopener noreferrer\"> \n                <picture> \n                 <source type=\"image/webp\" srcset=\"../_src/7147/instagram_glyph_gradient_rgb_20211128202843326.webp?v=1767099951882\"> \n                 <img src=\"../_src/7147/instagram_glyph_gradient_rgb_20211128202843326.png?v=1767099951882\" width=\"30\" height=\"30\" alt=\"\" id=\"imgsrc7147_1\" loading=\"lazy\"> \n                </picture></a> \n              </div> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk5492\" class=\"b-plain c-space_narrow c-sp-space_normal c-padding_narrow c-sp-padding_normal cssskin-_block_main\" data-bk-id=\"bk5492\"> \n            <div class=\" g-column -col2 -sp-col1\"> \n             <div class=\" column -column1\"> \n              <div class=\" c-body\"> \n               <div class=\"c-img   \"> \n                <picture> \n                 <source type=\"image/webp\" srcset=\"../_src/7149/img20241019212444296536.webp?v=1767099951882\"> \n                 <img src=\"../_src/7149/img20241019212444296536.png?v=1767099951882\" width=\"1280\" height=\"855\" alt=\"\" id=\"imgsrc7149_1\" loading=\"lazy\"> \n                </picture> \n               </div> \n              </div> \n             </div> \n             <div class=\" column -column2 -column-lasts\"> \n              <div class=\" c-body\"> \n               <div class=\"c-img   \"> \n                <picture> \n                 <source type=\"image/webp\" srcset=\"../_src/7151/img20241019212444296301.webp?v=1767099951882\"> \n                 <img src=\"../_src/7151/img20241019212444296301.png?v=1767099951882\" width=\"1280\" height=\"854\" alt=\"\" id=\"imgsrc7151_1\" loading=\"lazy\"> \n                </picture> \n               </div> \n              </div> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk5493\" class=\"b-plain c-space_normal c-sp-space_normal c-padding_normal c-sp-padding_normal cssskin-_block_main\" data-bk-id=\"bk5493\"> \n            <div class=\" column -column1\" id=\"240930\"> \n             <p class=\" c-body\"><span class=\" d-large_font\"><span class=\" d-bold\"><span style=\"color:#073763;\">営業部署統合のご案内</span></span></span></p> \n             <div class=\" c-body c-right\"> \n              <hr class=\"c-hr\"> 2024.9.30 \n             </div> \n             <p class=\" c-body\">平素は格別のご愛顧を賜り厚く御礼を申し上げます。<br>この度、諸般の都合により特販チーム東京の販売業務全般を、一時的に「千葉営業所」に統合・集約させる事となりましたのでご案内を申し上げます。<br>お取引様には何かとご不便をお掛け致しますが、ご迷惑とならぬよう努力してまいりますので、何卒ご理解とご協力をお願い申し上げます。<br>なお既存の特販チーム東京のＴＥＬおよびＦＡＸは、千葉営業所に転送されますことを合わせてお伝えいたします。<br>&nbsp;<br>【業務統合先】<br>名称　　　　サンコーテック株式会社　千葉営業所<br>郵便番号　　２６２－００３３<br>所在地　　　千葉県千葉市花見川区幕張本郷２丁目４０番３号<br>ＴＥＬ　　　０４３（３０６）７３０１<br>ＦＡＸ　　　０４３（３０６）７３０２</p> \n             <div class=\" c-body c-left\">\n               &nbsp; \n             </div> \n             <div class=\" c-body c-left\">\n               &nbsp; \n             </div> \n            </div> \n           </div> \n           <div id=\"bk5494\" class=\"b-plain c-space_normal c-sp-space_normal c-padding_normal c-sp-padding_normal cssskin-_block_main\" data-bk-id=\"bk5494\"> \n            <div class=\" column -column1\" id=\"240802\"> \n             <p class=\" c-body\"><span class=\" d-large_font\"><span class=\" d-bold\"><span style=\"color:#073763;\">夏季休暇の御案内</span></span></span></p> \n             <div class=\" c-body c-right\"> \n              <hr class=\"c-hr\"> 2024.8.2 \n             </div> \n             <div class=\" c-body c-left\">\n               平素は格別のご高配を賜り、厚く御礼を申し上げます \n             </div> \n             <div class=\" c-body c-left\">\n               &nbsp; \n             </div> \n             <div class=\" c-body c-left\"> \n              <span style=\"color:#434343;\" data-sitecolor-text=\"\">弊社では下記の期間を夏季休暇とさせて頂きます</span> \n              <br> \n              <span style=\"color:#434343;\">期間中は何かとご不便をお掛けいたしますが、宜しくお願い申し上げます　</span> \n              <br> \n              <br> \n              <span class=\" d-bold\"><span style=\"color:#a61c00;\" data-sitecolor-text=\"\">2024年8月10日(土曜日)〜2024年8月16日(金曜日)</span></span> \n              <br> \n              <br> \n              <span style=\"color:#434343;\" data-sitecolor-text=\"\">レンタル商品の納品・引取は、お早めに御連絡くださいますようお願い申し上げます</span> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk5495\" class=\"b-plain c-space_normal c-sp-space_normal c-sp-padding_normal cssskin-_block_main\" data-bk-id=\"bk5495\"> \n            <div class=\" column -column1\" id=\"240623\"> \n             <p class=\" c-body\"><span style=\"color:#073763;\" class=\" d-large_font\"><span class=\" d-bold\">関東グランドフェア参加のご案内</span></span></p> \n             <div class=\" c-body c-right\"> \n              <hr class=\"c-hr\"> \n              <span style=\"color:#434343;\" data-sitecolor-text=\"\">2024.6.23&nbsp;</span> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk5496\" class=\"b-plain c-space_normal c-sp-space_normal c-padding_narrow c-sp-padding_normal cssskin-_block_main\" data-bk-id=\"bk5496\"> \n            <div class=\" g-column -col2 -sp-col1\" id=\"230105\"> \n             <div class=\" column -column1\"> \n              <p class=\" c-body\">7月<span>5</span>日<span>(</span>金<span>)</span>～<span>7</span>月<span>6</span>日<span>(</span>土<span>)</span>に開催されます「関東グランドフェア<span>2024</span>」のご案内です。当社も主催社として参加いたします。<br>最新の技術や製品に触れる絶好の機会ですので、ぜひご来場いただき最新の情報をご覧ください。<br>ご参加いただくには事前登録が必要です。パンフレットに記載されている<span>QR</span>コードをスキャンして、事前登録の手続きをお願いします。<br>皆さまのご来場を心よりお待ちしております。<br>&nbsp;<br>関東グランドフェア2024<br><a href=\"https://grandfair.jp/gf2024/venue/kanto/\" target=\"_blank\" rel=\"noopener noreferrer\">https://grandfair.jp/gf2024/venue/kanto/</a><br>&nbsp;<br>開催日時：<br><span>2024</span>年<span>7</span>月<span>5</span>日<span>(</span>金<span>)</span>　<span>10:00</span>～<span>17:30</span><br><span>2024</span>年<span>7</span>月<span>6</span>日<span>(</span>土<span>)</span>　<span> 9:30</span>～<span>16:00</span><br>&nbsp;<br>開催場所：<br>幕張メッセ<span> 9</span>～<span>11</span>ホール<br>&nbsp;</p> \n             </div> \n             <div class=\" column -column2 -column-lasts\"> \n              <div class=\" c-body\"> \n               <div class=\"c-img   \"> \n                <a href=\"https://www.sankotech.co.jp/Information/pdf/グランドフェア%20パンフレット（サンコーテック）.pdf\" target=\"_blank\" rel=\"noopener noreferrer\"> \n                 <picture> \n                  <source type=\"image/webp\" srcset=\"../_src/7153/img20240623135728871845.webp?v=1767099951882\"> \n                  <img src=\"../_src/7153/img20240623135728871845.jpg?v=1767099951882\" width=\"2479\" height=\"3508\" alt=\"\" id=\"imgsrc7153_1\" loading=\"lazy\"> \n                 </picture></a> \n               </div> \n              </div> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk5497\" class=\"b-plain c-space_normal c-sp-space_normal c-sp-padding_normal cssskin-_block_main\" data-bk-id=\"bk5497\"> \n            <div class=\" column -column1\" id=\"240516\"> \n             <p class=\" c-body\"><span style=\"color:#073763;\" class=\" d-large_font\"><span class=\" d-bold\">レンタル新商品のご案内</span></span></p> \n             <div class=\" c-body c-right\"> \n              <hr class=\"c-hr\"> \n              <span style=\"color:#434343;\" data-sitecolor-text=\"\">2024.5.16&nbsp;</span> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk5498\" class=\"b-plain c-space_normal c-sp-space_normal c-padding_narrow c-sp-padding_normal cssskin-_block_main\" data-bk-id=\"bk5498\"> \n            <div class=\" g-column -col2 -sp-col1\"> \n             <div class=\" column -column1\"> \n              <div class=\" c-body\"> \n               <div class=\"c-img   \"> \n                <a href=\"https://www.sankotech.co.jp/Information/pdf/レンタル新商品のご案内%20ハンガーパレット%202024.04.pdf\" target=\"_self\"> \n                 <picture> \n                  <source type=\"image/webp\" srcset=\"../_src/7155/img20240517113400670598.webp?v=1767099951882\"> \n                  <img src=\"../_src/7155/img20240517113400670598.jpg?v=1767099951882\" width=\"2480\" height=\"3507\" alt=\"\" id=\"imgsrc7155_1\" loading=\"lazy\"> \n                 </picture></a> \n               </div> \n               <br> \n               <span class=\" d-small_font\">画像クリックで拡大表示します</span> \n              </div> \n             </div> \n             <div class=\" column -column2 -column-lasts\"> \n              <div class=\" c-body\"> \n               <div class=\"c-img   \"> \n                <a href=\"https://www.sankotech.co.jp/Information/pdf/レンタル新商品のご案内%20小型冷蔵ショーケース%202024.03.pdf\" target=\"_self\"> \n                 <picture> \n                  <source type=\"image/webp\" srcset=\"../_src/7157/img20240517113400677843.webp?v=1767099951882\"> \n                  <img src=\"../_src/7157/img20240517113400677843.jpg?v=1767099951882\" width=\"2480\" height=\"3507\" alt=\"\" id=\"imgsrc7157_1\" loading=\"lazy\"> \n                 </picture></a> \n               </div> \n               <br> \n               <span class=\" d-small_font\">画像クリックで拡大表示します</span> \n              </div> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk5499\" class=\"b-plain c-space_normal c-sp-space_normal c-sp-padding_normal cssskin-_block_main\" data-bk-id=\"bk5499\"> \n            <div class=\" column -column1\" id=\"240213\"> \n             <p class=\" c-body\"><span style=\"color:#073763;\" class=\" d-large_font\"><span class=\" d-bold\">公式SNS開設！</span></span></p> \n             <div class=\" c-body c-right\"> \n              <hr class=\"c-hr\"> \n              <span style=\"color:#434343;\" data-sitecolor-text=\"\">2024.2.13&nbsp;</span> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk5500\" class=\"b-plain c-space_normal c-sp-space_normal c-padding_normal c-sp-padding_normal cssskin-_block_main\" data-bk-id=\"bk5500\"> \n            <div class=\" column -column1\" id=\"240213\"> \n             <div class=\" c-body c-left\"> \n              <span style=\"color:#000000;\">この度サンコーテック株式会社では、</span> \n              <br> \n              <span style=\"color:#000000;\">公式のyoutubeチャンネルとinstagramアカウントを新しく開設いたしました！</span> \n              <br> \n              <br> \n              <span style=\"color:#000000;\">商品情報や拠点紹介だけではなく、当社の取り組みや社員の日常などを発信することで、</span> \n              <br> \n              <span style=\"color:#000000;\">サンコーテックの雰囲気をより身近に感じて頂けるようなSNSを目指していきます。</span> \n              <br> \n              <span style=\"color:#000000;\">気になる投稿がございましたら、ぜひ「いいね！」をよろしくお願いいたします！</span> \n             </div> \n             <div class=\" c-body c-left\">\n               &nbsp; \n             </div> \n             <div class=\" c-body c-left\"> \n              <span style=\"color:#000000;\">公式Youtube では全国の拠点紹介動画を中心にアップしています</span> \n             </div> \n             <div class=\" c-body c-left\"> \n              <span style=\"color:#000000;\">サンコーテック公式チャンネルはこちらから！→</span> \n              <div class=\"c-img   \"> \n               <a href=\"https://www.youtube.com/channel/UCIFZwakTqfs8CJzHYwjUKUg\" target=\"_blank\" rel=\"noopener noreferrer\"> \n                <picture> \n                 <source type=\"image/webp\" srcset=\"../_src/7161/icons8-youtube-48.webp?v=1767099951882\"> \n                 <img src=\"../_src/7161/icons8-youtube-48.png?v=1767099951882\" width=\"48\" height=\"48\" alt=\"\" id=\"imgsrc7161_1\" loading=\"lazy\"> \n                </picture></a> \n              </div> \n             </div> \n             <div class=\" c-body c-left\">\n               &nbsp; \n             </div> \n             <div class=\" c-body c-left\"> \n              <span style=\"color:#000000;\">公式Instagram では全国のスタッフの日常をベースにアップしています</span>　 \n             </div> \n             <div class=\" c-body c-left\">\n               サンコーテック公式Instagramはこちらから！→ \n              <div class=\"c-img   \"> \n               <a href=\"https://www.instagram.com/sankotech_official/\" target=\"_blank\" rel=\"noopener noreferrer\"> \n                <picture> \n                 <source type=\"image/webp\" srcset=\"../_src/7159/instagram_glyph_gradient_rgb_20211128202843326.webp?v=1767099951882\"> \n                 <img src=\"../_src/7159/instagram_glyph_gradient_rgb_20211128202843326.png?v=1767099951882\" width=\"30\" height=\"30\" alt=\"\" id=\"imgsrc7159_1\" loading=\"lazy\"> \n                </picture></a> \n              </div> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk5501\" class=\"b-plain c-space_normal c-sp-space_normal c-sp-padding_normal cssskin-_block_main\" data-bk-id=\"bk5501\"> \n            <div class=\" column -column1\" id=\"240101\"> \n             <p class=\" c-body\"><span style=\"color:#073763;\" class=\" d-large_font\"><span class=\" d-bold\">新年のご挨拶</span></span></p> \n             <div class=\" c-body c-right\"> \n              <hr class=\"c-hr\"> \n              <span style=\"color:#434343;\" data-sitecolor-text=\"\">2024.1.5&nbsp;</span> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk5502\" class=\"b-plain c-space_normal c-sp-space_normal c-padding_narrow c-sp-padding_normal cssskin-_block_main\" data-bk-id=\"bk5502\"> \n            <div class=\" g-column -col2 -sp-col1\" id=\"230105\"> \n             <div class=\" column -column1\"> \n              <div class=\" c-body\"> \n               <div class=\"c-img   \"> \n                <picture> \n                 <source type=\"image/webp\" srcset=\"../_src/7163/img_4446.webp?v=1767099951882\"> \n                 <img src=\"../_src/7163/img_4446.jpg?v=1767099951882\" width=\"1108\" height=\"1477\" alt=\"\" id=\"imgsrc7163_1\" loading=\"lazy\"> \n                </picture> \n               </div> \n              </div> \n             </div> \n             <div class=\" column -column2 -column-lasts\"> \n              <p class=\" c-body\">&nbsp;<br><span style=\"color:#000000;\" data-sitecolor-text=\"\">謹んで新年のお慶びを申し上げます。</span><br><span style=\"color:#000000;\">元日に石川県能登地方を震源とする震度7の大きな地震が発生いたしましたが、</span><br><span style=\"color:#000000;\">この地震でお亡くなりになられた多くの方々に哀悼の意を表しますと共に、</span><br><span style=\"color:#000000;\">年初から困難な状況に遭遇された皆様方に心からお見舞いを申し上げます。</span><br><span style=\"color:#000000;\">弊社は今年より新中期経営計画をスタートさせますが、</span><br><span style=\"color:#000000;\">「レンタルでお客様の問題解決を図る」を使命と捉え、</span><br><span style=\"color:#000000;\">来る５０周年に向け前進してまいります。</span><br><span style=\"color:#000000;\">本年もどうぞ宜しくお願い申し上げます。</span><br><span style=\"color:#000000;\">&nbsp;</span><br><span style=\"color:#000000;\">２０２４年１月５日</span><br><span style=\"color:#000000;\">サンコーテック株式会社</span><br><span style=\"color:#000000;\">代表取締役　髙橋　桂</span></p> \n             </div> \n            </div> \n           </div> \n          </section> \n         </div> \n         <div id=\"a-side-a\" data-float=\"false\" class=\"a-side-a column -col4 \" data-fixed-size=\"200px\"> \n          <section> \n           <div id=\"bk5503\" class=\"b-plain c-space_normal c-sp-space_normal c-sp-padding_normal bd-webp -dress_navy cssskin-_block_side_a\" data-bk-id=\"bk5503\" data-shared=\"true\" data-sharedname=\"info_archive\" data-sticky=\"true\"> \n            <div class=\" column -column1\"> \n             <nav> \n              <div class=\" -menu_center\"> \n               <ul class=\"c-menu -menu_e menu-parts -v\"> \n                <li><span class=\" c-unlink\"><span class=\" d-bold\">Back Number</span></span></li> \n               </ul> \n              </div> \n             </nav> \n             <div class=\" c-body\"> \n              <span class=\"bindicon-angle-right-circle\"></span> \n              <a href=\"pg271.html\" target=\"_blank\" rel=\"noopener noreferrer\" data-mypid=\"271\">2024年</a> \n              <br> \n              <span class=\"bindicon-angle-right-circle\"></span> \n              <a href=\"../info_arch/pg265.html\" target=\"_blank\" rel=\"noopener noreferrer\" data-pid=\"265\">2023年</a> \n              <br> \n              <span class=\"bindicon-angle-right-circle\"></span> \n              <a href=\"../info_arch/pg261.html\" target=\"_blank\" rel=\"noopener noreferrer\" data-pid=\"261\">2022年</a> \n              <br> \n              <span class=\"bindicon-angle-right-circle\"></span> \n              <a href=\"../info_arch/info2021.html\" target=\"_blank\" rel=\"noopener noreferrer\" data-pid=\"173\">2021年</a> \n              <br> \n              <span class=\"bindicon-angle-right-circle\"></span> \n              <a href=\"../info_arch/info2020.html\" target=\"_blank\" rel=\"noopener noreferrer\" data-pid=\"133\">2020年</a> \n              <br>&nbsp; \n              <br> \n              <div class=\"c-img   \"> \n               <a href=\"../stj.html\" data-pid=\"73\"> \n                <picture> \n                 <source type=\"image/webp\" srcset=\"../_src/3484/test_small2.webp?v=1767099951882\"> \n                 <img src=\"../_src/3484/test_small2.jpg?v=1767099951882\" width=\"200\" height=\"100\" alt=\"\" id=\"imgsrc3484_1\" loading=\"lazy\"> \n                </picture></a> \n              </div> \n             </div> \n             <div class=\" c-body c-right\"> \n              <span class=\" d-small_font\"> <a href=\"../info_arch/info2021.html\" data-pid=\"173\">STジャーナルへ</a></span> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk5504\" class=\"b-plain cssskin-_block_side_a\" data-bk-id=\"bk5504\"> \n            <div class=\" column -column1\"> \n            </div> \n           </div> \n          </section> \n         </div> \n        </div> \n       </div> \n      </article> \n     </div> \n    </main> \n    <div id=\"a-footer\" data-float=\"false\" class=\"a-footer   cssskin-_area_footer\"> \n     <footer> \n      <div class=\"site_frame\"> \n       <div id=\"bk5506\" class=\"b-plain 