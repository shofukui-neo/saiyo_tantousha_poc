{"url":"https://www.kidsfore.co.jp/recruit_message","html":"\n<!DOCTYPE html>\n<html>\n\n<head>\n    <meta charset=\"UTF-8\">\n\n    <title>キッズフォレ</title>\n\n    <link href=\"https://www.kidsfore.co.jp/wp/wp-content/themes/biz-vektor-child/recruit_style.css\" rel=\"stylesheet\" type=\"text/css\">\n\n</head>\n\n<body>\n\n    <header>\n        <div id=\"header-image\">\n            <div id=\"header-top\">\n                <div id=\"header-logo\">\n                    <a href=\"https://www.kidsfore.co.jp/recruit\"><img src=\"https://www.kidsfore.co.jp/wp/wp-content/themes/biz-vektor-child/images/header-logo.png\"></a>\n                </div>\n\t\t\t\t<!--\n                <div id=\"header-entry\">\n                    <a href=\"https://www.kidsfore.co.jp/recruit_entry\">エントリーする</a>\n                </div>\n\t\t\t\t-->\n            </div>\n                        <img src=\"https://www.kidsfore.co.jp/wp/wp-content/themes/biz-vektor-child/images/header-message.png\">\n                    </div>\n        <div id=\"header-nav\">\n            <ul>\n                <li><a href=\"https://www.kidsfore.co.jp/recruit_message\" id=\"list-message\">メッセージ</a></li>\n                <li><a href=\"https://www.kidsfore.co.jp/recruit_voice\" id=\"list-voice\">先輩スタッフの声</a></li>\n                <li><a href=\"https://www.kidsfore.co.jp/recruit_support\" id=\"list-support\">スタッフサポート</a></li>\n\t\t\t\t<li><a href=\"https://www.kidsfore.com/\" id=\"list-requirement\" target=\"_blank\" rel=\"nofollow\">募集要項</a></li>\n              <!--  <li><a href=\"https://www.kidsfore.co.jp/recruit_requirements\" id=\"list-requirement\">募集要項</a></li>\n                -->\n<!--                <li><a href=\"https://www.kidsfore.co.jp/facilities\" id=\"list-facility\">施設紹介</a></li>\n -->\n                <li><a href=\"http://www.kidsfore.co.jp/facilities/  \" id=\"list-facility\">施設紹介</a></li>\n                <li><a href=\"http://www.kidsfore.co.jp/about/outline/\" id=\"list-company\">企業情報</a></li>\n<!---     \n                <li><a href=\"https://www.kidsfore.co.jp/about\" id=\"list-company\">企業情報</a></li>\n-->     \n            </ul>\n        </div>\n    </header>\n\n    <div id=\"message\" class=\"container\">\n        <div class=\"contents\">\n           <div id=\"message-box\">\n               <div id=\"message-text\">\n                   <p>人生にはタイミングがあり、</p>\n                   <p>逃すこともあれば捕まえることもある</p>\n                   <p>遅かったのか早かったのか、その時はわからない</p>\n                   <p>時には迷うこともあるでしょう</p>\n                   <p>とりあえず、一歩進む気持ちがあるので、</p>\n                   <p>私のメッセージと出会っているあなた</p>\n                   <p class=\"message-margin\">キッズフォレファミリーはあなたとの出会いを待っています</p>\n                   <p>子どもの溢れるエネルギーは</p>\n                   <p>あなたの力をより育てます</p>\n                   <p class=\"message-margin\">私は、前向きに生きたいあなたの人生を応援し、</p>\n                   <p>ともに栄えることを願っています</p>\n               </div>\n               <div id=\"message-sign\">\n                   <p>キッズフォレグループ代表</p>\n                   <h3>松原慶子</h3>\n               </div>\n           </div>\n        </div>\n    </div>\n    <div id=\"bottom-menu\">\n        <ul>\n             <li><a href=\"https://www.kidsfore.co.jp/wp/wp-content/themes/biz-vektor-child/images/recruit_movie.mp4\"><img src=\"https://www.kidsfore.co.jp/wp/wp-content/themes/biz-vektor-child/images/kidsfore-btn.png\"></a></li>\n            <li><a href=\"https://www.kidsfore.co.jp/wp/wp-content/themes/biz-vektor-child/images/athoiku.pdf\"><img src=\"https://www.kidsfore.co.jp/wp/wp-content/themes/biz-vektor-child/images/atorie-btn.png\"></a></li>\n            <li><a href=\"https://www.kidsfore.co.jp/recruit_blog\"><img src=\"https://www.kidsfore.co.jp/wp/wp-content/themes/biz-vektor-child/images/blog-btn.png\"></a></li>\n        </ul>\n    </div>\n\n<footer>\n    <div id=\"footer-inner\">\n        <div id=\"footer-top\">\n            <div id=\"footer-left\">\n                <ul>\n                    <li><a href=\"http://www.kidsfore.co.jp/\">キッズフォレTOP</a></