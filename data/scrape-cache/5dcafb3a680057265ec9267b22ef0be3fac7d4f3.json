7N4KJ9\"\r\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\r\n<!-- End Google Tag Manager (noscript) -->\r\n<div id=\"header-area\">\r\n <header id=\"header\">\r\n  <p class=\"header-logo\"><a href=\"/careers/\"><img src=\"/careers/common/images/logo_header.webp\" alt=\"ダイナパック株式会社\" width=\"224\" height=\"34\"></a></p>\r\n  <div id=\"toggle-nav\" class=\"toggle-menu\"><span></span></div>\r\n  <div class=\"gnav-wrap\">\r\n   <nav class=\"gnav\">\r\n    <ul class=\"gnav-lv1\">\r\n     <li class=\"nav-home\"><a href=\"/careers/\">ホーム</a></li>\r\n     <li><a href=\"/careers/about/\"><span>ダイナパックを知る</span></a></li>\r\n     <li><a href=\"/careers/interview/\"><span>ダイナパックで働く人</span></a></li>\r\n     <li><a href=\"/careers/internship/\"><span>1day仕事体験</span></a></li>\r\n     <li><a href=\"/careers/description/\"><span>募集要項</span></a></li>\r\n     <li class=\"gnav-contact\"><a href=\"https://www.dynapac-gr.co.jp/contact/\" target=\"_blank\" class=\"icon-arrow\">資料請求・お問い合わせ</a></li>\r\n    </ul>\r\n    <div class=\"sub-nav\">\r\n     <ul>\r\n      <li class=\"pc-none\"><a href=\"/careers/highschool/\">高校生新卒採用</a></li>\r\n      <li><a href=\"/careers/recruit_policy/\">採用ポリシー</a></li>\r\n      <li><a href=\"https://www.dynapac-gr.co.jp/privacy/index.html\" target=\"_blank\">プライバシーポリシー<i class=\"ai-out\"></i></a></li>\r\n      <li><a href=\"https://www.dynapac-gr.co.jp/\" target=\"_blank\">ダイナパック企業サイト<i class=\"ai-out\"></i></a></li>\r\n      <li><a href=\"/careers/sitemap/\">サイトマップ</a></li>\r\n     </ul>\r\n    </div>\r\n   </nav>\r\n   <!--/#gnav-->\r\n  </div>\r\n </header>\r\n <!--/#header-area-->\r\n <div id=\"drawer\"></div>\r\n <!--/#drawer-->\r\n</div>\r\n\r\n<div id=\"content-area\">\r\n  <div id=\"h1-area\">\r\n    <h1>ダイナパックを知る<div class=\"en\">ABOUT US</div></h1>\r\n  </div>\r\n  <div id=\"main-content\">\r\n   <p class=\"lead\">客観的にダイナパックを知るための情報を集めました。<br>\r\n    説明会では会社の雰囲気について多くの質問をいただきます。<br>\r\n   雰囲気も伝わるよう紹介しています。</p>\r\n   <section>\r\n    <div class=\"index-pattern pattern1-1-1 index-about\">\r\n       <div class=\"col\"> <a href=\"numbers/\">\r\n        <figure><img src=\"images/index_01.webp\" alt=\"\" width=\"560\" height=\"420\"></figure>\r\n        <div class=\"head\"><span class=\"sub en\">DYNAPAC BY THE NUNBERS</span>数字で見るダイナパック<i class=\"circle-arrow\"></i></div>\r\n         <p class=\"txt\">歴史、売上高などの会社情報から働きやすい環境、成長に関わる情報、さらには社員の姿などを紹介します。</p>\r\n       </a> </div>\r\n       <div class=\"col\"> <a href=\"society/\">\r\n        <figure><img src=\"images/index_02.webp\" alt=\"\" width=\"560\" height=\"420\"></figure>\r\n        <div class=\"head\"><span class=\"sub en\">DYNAPAC IN SOCIETY</span>社会の中のダイナパック<i class=\"circle-arrow\"></i></div>\r\n        <p class=\"txt\">ダイナパックの製品は、さまざまな“運ぶ”を支えています。みなさんの暮らしにもお役に立っているはずです。</p>\r\n       </a></div>\r\n       <div class=\"col\"> <a href=\"base/\">\r\n        <figure><img src=\"images/index_03.webp\" alt=\"\" width=\"560\" height=\"420\"></figure>\r\n        <div class=\"head\"><span class=\"sub en\">BUSINESS BASES</span>ダイナパックの事業拠点<i class=\"circle-arrow\"></i></div>\r\n        <p class=\"txt\">時代の変化とともにお客様の悩みや課題が複雑化する中で、お客様に寄り添う製品を生み出していきます。</p>\r\n       </a></div>\r\n       <div class=\"col\"> <a href=\"job/\">\r\n       <figure><img src=\"images/index_04.webp\" alt=\"\" width=\"560\" height=\"420\"></figure>\r\n        <div class=\"head\"><span class=\"sub en\">JOB INTRODUCTION</span>ダイナパックのお仕事<i class=\"circle-arrow\"></i></div>\r\n        <p class=\"txt\">段ボール、包装・梱包資材などの製品を提供。お客さまへ価値を創造する各部門を紹介します。</p>\r\n       </a></div>\r\n       <div class=\"col\"> <a href=\"workplace/\">\r\n        <figure><img src=\"images/index_05.webp\" alt=\"\" width=\"560\" height=\"420\"></figure>\r\n        <div class=\"head\"><span class=\"sub en\">COMMITMENT TO WORKPLACES</span>働きやすさへの取り組み<i class=\"circle-arrow\"></i></div>\r\n        <p class=\"txt\">働きやすさを大切にしています。ここでは福利厚生制度や、働きやすさへの取り組みについて紹介します。</p>\r\n       </a></div>\r\n       <div class=\"col\"> <a href=\"careerup/\">\r\n        <figure><img src=\"images/index_06.webp\" alt=\"\" width=\"560\" height=\"420\"></figure>\r\n        <div class=\"head\"><span class=\"sub en\">THE FUTURE WE AIM FOR</span>キャリアアップと人事制度<i class=\"circle-arrow\"></i></div>\r\n        <p class=\"txt\">成長とやりがいのために各種取り組みを実施しています。キャリアアップ制度や人事制度について紹介します。</p>\r\n       </a></div>\r\n    </div>\r\n   </section>\r\n   <div id=\"bottom-bn-area\">\r\n    <div class=\"col\"><a href=\"../interview/\">\r\n     <div class=\"txt\">\r\n      <div class=\"en\">WHO WORKS AT DYNAPAC</div>\r\n      <div class=\"head\">ダイナパックで<br>\r\n働く人</div>\r\n     </div>\r\n     <i class=\"circle-arrow\"></i></a></div>\r\n    <div class=\"col\"><a href=\"faq/\">\r\n     <div class=\"txt\">\r\n      <div class=\"en\">FAQ</div>\r\n      <div class=\"head\">よくあるご質問</div>\r\n     </div>\r\n     <i class=\"circle-arrow\"></i></a></div>\r\n   </div>\r\n<section id=\"footer-entry-area\" class=\"bg-full\">\r\n <h2 class=\"h2-footer-entry\">エントリー<span class=\"en\">ENTRY</span></h2>\r\n <div class=\"footer-entry\">\r\n  <div class=\"wrap\">\r\n   <div class=\"col\">\r\n    <h3>新卒者</h3>\r\n    <p>新卒採用に応募される方は、こちらをご覧ください。</p>\r\n    <div class=\"entry-btn-area\">\r\n     <div class=\"link-btn\"> <a href=\"/careers/description/new/\">募集要項<i class=\"circle-arrow\"></i></a> </div>\r\n     <div class=\"link-btn mynavi\"><a href=\"https://job.mynavi.jp/27/pc/search/corp276378/outline.html\" target=\"_blank\"><img src=\"/careers/common/images/logo_mynavi.svg\" alt=\"マイナビ\" class=\"img-mynavi\"><i class=\"arrow-out\"></i></a></div>\r\n    </div>\r\n   </div>\r\n   <div class=\"col\">\r\n    <h3>経験者</h3>\r\n    <p>経験者採用・中途採用をご希望の方は、こちらをご覧ください。</p>\r\n    <div class=\"entry-btn-area\">\r\n     <div class=\"link-btn\"> <a href=\"/careers/description/career/\">募集要項<i class=\"circle-arrow\"></i></a></div>\r\n     <div class=\"link-btn\"><a href=\"https://www.dynapac-gr.co.jp/recruit/entry/\" target=\"_blank\">エントリー<i class=\"circle-arrow\"></i></a></div>\r\n    </div>\r\n   </div>\r\n  </div>\r\n  <div class=\"recruit-contact\">\r\n   <h3>採用に関するお問い合わせ</h3>\r\n   <p>疑問点・不明点の確認や質問など、採用に関することでしたらこちらからお問い合わせください。</p>\r\n   <div class=\"link-btn\"> <a href=\"https://www.dynapac-gr.co.jp/contact/\" target=\"_blank\">お問い合わせはこちら<i class=\"circle-arrow\"></i></a> </div>\r\n  </div>\r\n </div>\r\n<div id=\"footer-bnr-area\">\r\n <ul id=\"footer-bnr\">\r\n  <li><a href=\"https://www.dynapac-gr.co.jp/video/\" target=\"_blank\"><img src=\"/careers/common/images/footer_bnr_video.webp\" alt=\"ダイナパックが3分でわかる　ダイナパック早わかり\"></a></li>\r\n  <li><a href=\"https://www.dynapac-gr.co.jp/results/\" target=\"_blank\"><img src=\"/careers/common/images/footer_bnr_results.webp\" alt=\"ダイナパック実績紹介\"></a></li>\r\n  <li><a href=\"https://www.dynapac-gr.co.jp/winning/\" target=\"_blank\"><img src=\"/careers/common/images/footer_bnr_awards.webp\" alt=\"ダイナパック受賞実績\"></a></li>\r\n </ul>\r\n</div>\r\n\r\n</section>\r\n\r\n    <div id=\"breadcrumb\">\r\n     <ul class=\"inner\">\r\n      <li><a href=\"/careers/\">ホーム</a></li>\r\n      <li>ダイナパックを知る</li>\r\n     </ul>\r\n    </div>\r\n  </div>\r\n  <!--/#main-content-->\r\n</div>\r\n<div id=\"to-top\"><a href=\"#header-area\"></a></div>\r\n<div id=\"footer-area\">\r\n  <footer id=\"footer\">\r\n   <div class=\"fnav-wrap\">\r\n      <div class=\"left-col\">\r\n        <p class=\"footer-logo\"><a href=\"/careers/\"><img src=\"/careers/common/images/logo_footer.webp\" alt=\"ダイナパック株式会社\" width=\"222\" height=\"34\"></a><span>採用事務局</span></p>\r\n        <div class=\"footer-adress\">\r\n          <adress>〒460-0003<br>\r\n           愛知県名古屋市中区錦三丁目14番15号　<br>\r\n           カゴメビル7階・8階（受付）<br>\r\n          電話番号：<span class=\"tel-link\">052-971-2651</span>（代表）</adress>\r\n        </div>\r\n        <div class=\"sub-nav\">\r\n     <ul>\r\n      <li><a href=\"/careers/recruit_policy/\">採用ポリシー</a></li>\r\n      <li><a href=\"https://www.dynapac-gr.co.jp/privacy/\" target=\"_blank\">プライバシーポリシー<