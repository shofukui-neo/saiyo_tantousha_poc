">\n  <meta name=\"twitter:site\" content=\"https://www.k-yamasan.co.jp/recruit/member/interview01/\">\n  <meta name=\"twitter:image\" content=\"https://www.k-yamasan.co.jp/recruit/inc/image/common/img_ogp.jpg\">\n  <link href=\"https://fonts.googleapis.com/css?family=Noto+Sans+JP:400,500,700&display=swap&subset=japanese\" rel=\"stylesheet\">\n  <link rel=\"stylesheet\" type=\"text/css\" href=\"/recruit/inc/css/style.css\">\n  <link rel=\"stylesheet\" type=\"text/css\" href=\"/recruit/inc/css/project/interview.css\">\n</head>\n\n<body id=\"interview01\">\n  <!-- Google Tag Manager (noscript) -->\n  <noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-PJDQ96SJ\" height=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n  <!-- End Google Tag Manager (noscript) -->\n  <div id=\"container\">\n    <header class=\"l-header\">\n      <div class=\"l-header__inner\">\n        <div class=\"l-header__modules\">\n          <a href=\"/recruit\" class=\"logo\">\n            <span class=\"logo-main\"><img src=\"/recruit/inc/image/common/img_logo.svg\" alt=\"株式会社山産 採用サイト\"></span>\n            <span class=\"logo-sub\"><img src=\"/recruit/inc/image/common/img_headerLogocaption.svg\" alt=\"RECRUIT SITE\"></span>\n          </a>\n        </div>\n        <nav class=\"l-header__btnArea\">\n          <button class=\"l-header__btn js-naviBtn\" data-cat=\"gnavi\">\n            <span class=\"c-toggleBtn\" id=\"toggle\">\n              <span></span>\n              <span></span>\n              <span></span>\n            </span>\n          </button>\n        </nav>\n      </div>\n      <!-- グローバルナビゲーション -->\n      <div class=\"l-navigation__wrapper\" id=\"gnavi\">\n        <nav class=\"l-navigation\">\n          <!-- 1列目 -->\n          <ul class=\"l-navigation__list\">\n            <!-- トップ -->\n            <li class=\"l-navigation__item\">\n              <a class=\"current\" href=\"/recruit\">トップ</a>\n            </li>\n            <!-- トップ -->\n            <!-- 山産を知る -->\n            <li class=\"l-navigation__item\">\n              <button class=\"js-hasDropdown l-navigation__item\">山産を知る</button>\n              <ul class=\"l-navigation__list-sub\">\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/about/message/\">採用メッセージ</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/about/business/\">山産の事業について</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/about/data/\">数字で見る山産</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/about/case/\">こんなところに山産</a></li>\n              </ul>\n            </li>\n            <!-- 山産を知る -->\n          </ul>\n          <!-- 1列目 -->\n          <!-- 2列目 -->\n          <ul class=\"l-navigation__list\">\n            <!-- 仕事を知る -->\n            <li class=\"l-navigation__item\">\n              <a href=\"/recruit/about/work/\">仕事を知る</a>\n            </li>\n            <!-- 仕事を知る -->\n            <!-- 山産の人 -->\n            <li class=\"l-navigation__item\">\n              <button class=\"js-hasDropdown l-navigation__item\">人を知る</button>\n              <ul class=\"l-navigation__list-sub\">\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/member/\" class=\"js-naviAnchor\">人を知るTOP</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/member/interview01/\" class=\"js-naviAnchor\">環境事業グループ D.F.</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/member/interview06/\" class=\"js-naviAnchor\">環境事業グループ Y.O.</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/member/interview07/\" class=\"js-naviAnchor\">産機事業グループ S.K.</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/member/interview02/\" class=\"js-naviAnchor\">産機事業グループ Y.T.</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/member/interview03/\" class=\"js-naviAnchor\">総務部 K.I.</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/member/interview04/\" class=\"js-naviAnchor\">産機事業グループ S.I.</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/member/interview05/\" class=\"js-naviAnchor\">環境事業グループ H.M.</a></li>\n              </ul>\n            </li>\n            <!-- 山産の人 -->\n          </ul>\n          <!-- 2列目 -->\n          <!-- 3列目 -->\n          <ul class=\"l-navigation__list\">\n            <!-- 環境・制度を知る -->\n            <li class=\"l-navigation__item\">\n              <button class=\"js-hasDropdown l-navigation__item\">環境・制度を知る</button>\n              <ul class=\"l-navigation__list-sub\">\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/info/culture/\">文化・社風</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/info/benefits/\">福利厚生</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/info/training/\">教育制度・キャリアステップ</a></li>\n              </ul>\n            </li>\n            <!-- 働く人を知る -->\n          </ul>\n          <!-- 3列目 -->\n          <!-- 4列目 -->\n          <ul class=\"l-navigation__list\">\n            <!-- 採用情報 -->\n            <li class=\"l-navigation__item\">\n              <button class=\"js-hasDropdown l-navigation__item\">採用情報</button>\n              <ul class=\"l-navigation__list-sub\">\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/info/guideline/\">募集要項・選考の流れ</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/info/faq/\">よくあるご質問</a></li>\n              </ul>\n            </li>\n            <!-- 採用情報 -->\n            <!-- エントリー -->\n            <li class=\"l-navigation__item\">\n              <button class=\"js-hasDropdown l-navigation__item\">エントリー</button>\n              <ul class=\"l-navigation__list-sub\">\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/new-graduate-entry/\">新卒採用エントリー</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/entry/\">経験者採用エントリー</a></li>\n              </ul>\n            </li>\n            <!-- エントリー -->\n          </ul>\n          <!-- 4列目 -->\n        </nav>\n      </div>\n      <!-- グローバルナビゲーション -->\n    </header>\n    <!-- /header -->\n    <main id=\"main\">\n      <div class=\"l-lowerCaption\">\n        <div class=\"l-lowerCaption__inner\">\n          <h1 class=\"l-lowerCaption__title\">D.F.</h1>\n          <ol class=\"c-topicspath\">\n            <li><a href=\"/recruit\">ホーム</a></li>\n            <li><a href=\"/recruit/member/\">人を知る</a></li>\n            <li>D.F.</li>\n          </ol>\n        </div>\n      </div>\n      <div class=\"l-lowerCaption__bottom\">\n        <img src=\"/recruit/inc/image/common/lower/img_lowerCaption-bottom.svg\" alt=\"\">\n      </div>\n      <div id=\"contents\" class=\"l-lower\">\n        <section class=\"l-section\">\n          <div class=\"l-section__inner\">\n            <div class=\"l-mw p-interviewHero\">\n              <picture class=\"p-interviewHero__image\">\n                <source srcset=\"/recruit/inc/image/member/interview01/pic_interview-main.jpg.webp 1x, /recruit/inc/image/member/interview01/pic_interview-main@2x.jpg.webp 2x\" type=\"image/webp\">\n                <img src=\"/recruit/inc/image/member/interview01/pic_interview-main.jpg\" alt=\"D.F.\">\n              </picture>\n              <div class=\"p-interviewHero__text\">\n                <h2 class=\"p-interviewHero__title\"><span>自由な裁量で</span><span>自分の仕事に責任を持つ</span></h2>\n                <p class=\"p-interviewHero__affiliation\"><span>2021年度入社 環境事業グループ 施工管理</span></p>\n                <p class=\"p-interviewHero__name\"><span>D.F.</span></p>\n              </div>\n            </div>\n          </div>\n          <!-- 本文 -->\n          <div class=\"l-section__inner l-section__inner--pbSmall-sm\">\n            <div class=\"l-mw l-mw--800\">\n              <p class=\"p-interview__question\">山産で働きたいと思うようになった理由、きっかけは？</p>\n              <h3 class=\"c-ttl-small\">単身者にも家賃補助 社員の生活を守る企業風土</h3>\n              <p>前職では、発電所内の電気工事を中心とした修繕を行なっていました。現場作業だけでなく施工管理の仕事もしたいと思い、転職サイトに登録。そのサイトを通じて山産に声を掛けてもらいました。元来、機械いじりが好きでしたので、対象が電気から上下水道に変わることに対して心配はありませんでした。当時、福山市内の事業所に勤務し、会社の寮で暮らしていましたが、転職するとなると寮を出て賃貸住宅を借りることになります。山産は独身者にも家賃補助制度がありました。生活のバックアップまで考えてくれる企業であることに感銘を受け、入社を決意しました。</p>\n            </div>\n          </div>\n          <div class=\"l-section__inner l-section__inner--pbSmall-sm\">\n            <div class=\"l-mw l-mw--800\">\n              <p class=\"p-interview__question\">どんな仕事をしていますか？</p>\n              <h3 class=\"c-ttl-small\">暮らしを支えるインフラの問題をワンストップで解決</h3>\n              <p>主な仕事は、三原市、竹原市の上下水道施設の修繕やメンテナンスです。「調子が悪い」「故障した」などの連絡があった施設を調査し、修繕方法や機器の選定などを担当者に提案し、工事の計画を策定。自分で考えて計画した通りに施工されていく現場を見届けることは、大きな喜びです。また上下水道という、地域の人々の暮らしにつながる生活インフラを支えていることに、大きな責任も感じています。大規模な入札案件では工事部分のみを担当することもありますが、基本的には先方へのヒアリングも、見積もり作業も含めて、全て一人で行っています。福山営業所の環境事業グループは、7人の社員全員が施工管理者でありながら、営業的な動きもしています。</p>\n            </div>\n          </div>\n          <div class=\"l-section__inner l-section__inner--pbSmall-sm\">\n            <div class=\"l-mw l-mw--800\">\n              <p class=\"p-interview__question\">山産の良い部分は？</p>\n              <h3 class=\"c-ttl-small\">社員の裁量が大きく、工程も時間管理も自分次第</h3>\n              <p>一言で表すと「自由」です。仕事の裁量は担当社員に与えられているので、自分が考えていることにチャレンジしやすい環境です。経験のない工事でも、まずは自分で考えて計画し、そこに経験者がアドバイスをする、といったバックアップ体制ができています。社員は仕事に対して意欲的な人ばかり。自分の仕事に関係していなくても、新しい知識や希少な経験を共有し合っています。スケジュールの管理も社員に任されていて、工事の進捗に問題がなければ、有給休暇の申請は前日でも大丈夫。日々の業務も上手に管理すれば定時退社も可能です。月間の残業時間は少ない月は6時間程度、繁忙期でも30時間といったところです。</p>\n            </div>\n          </div>\n          <div class=\"l-section__inner l-section__inner--pbSmall-sm\">\n            <div class=\"l-mw l-mw--800\">\n              <picture class=\"c-imageWrapper\">\n                <source srcset=\"/recruit/inc/image/member/interview01/pic_interviewBody01.jpg.webp 1x, /recruit/inc/image/member/interview01/pic_interviewBody01@2x.jpg.webp 2x\" type=\"image/webp\">\n                <img src=\"/recruit/inc/image/member/interview01/pic_interviewBody01.jpg\" alt=\"業務風景\">\n              </picture>\n            </div>\n          </div>\n          <div class=\"l-section__inner l-section__inner--pbSmall-sm\">\n            <div class=\"l-mw l-mw--800\">\n              <p class=\"p-interview__question\">仕事をしていて大変なことは？どうやって楽しみ乗り越えてますか？</p>\n              <h3 class=\"c-ttl-small\">職人さんとの良好な関係は、積極的なコミュニケーションから</h3>\n              <p>一番は現場のコミュニケーションです。自分の考えを周囲に理解してもらえるよう、段取りをする時から、職人さんと良好な関係を築くよう気を配っています。常に明るく振る舞って、雑談もこちらから積極的に。指示を出すときは「なぜそうするのか」という根拠をしっかりと示すようにしています。逆に、職人さんからの良い提案があれば、それを採用して工事を進めることも。自分の考えが絶対だとは思わないことも大切です。職人さんに信頼してもらうためには、幅広い知識も必要。業務のフィードバックも含め、日々の勉強時間を確保するように工夫しています。</p>\n            </div>\n          </div>\n          <div class=\"l-section__inner l-section__inner--pbSmall-sm\">\n            <div class=\"l-mw l-mw--800\">\n              <p class=\"p-interview__question\">グレートを創り出す為に心がけていることや、これから挑戦したいことがあれば教えてください</p>\n              <h3 class=\"c-ttl-small\">人口減少社会にマッチした施工管理と、新たな資格取得を目指す</h3>\n              <p>山産は、大規模な工事の経験が豊富で、若い人が多く馬力があり、「パワフル」な会社だと思います。これを「グレート」に昇華させるためには、人口減少社会に適応していかねばならないと思っています。職人さんや協力業者の高齢化がさらに進む中でも安定した外注先を確保できるように、先方の事務所に足を運んで良い関係を維持するように努めています。<br> 個人的には、社内で誰も持っていない「技術士」資格を取得して、コンサルティング業務に挑戦したいです。山産のネームバリューに国家資格がプラスされれば、信頼に厚みが増し、新しい業務のフィールドが開けるのではないでしょうか。</p>\n            </div>\n          </div>\n          <div class=\"l-section__inner l-section__inner--pbSmall-sm\">\n            <div class=\"l-mw l-mw--800\">\n              <picture class=\"c-imageWrapper\">\n                <source srcset=\"/recruit/inc/image/member/interview01/pic_interviewBody02.jpg.webp 1x, /recruit/inc/image/member/interview01/pic_interviewBody02@2x.jpg.webp 2x\" type=\"image/webp\">\n                <img src=\"/recruit/inc/image/member/interview01/pic_interviewBody02.jpg\" alt=\"業務風景\">\n              </picture>\n            </div>\n          </div>\n          <!-- 一日の流れ -->\n          <div class=\"l-section__inner l-section__inner--pbSmall-sm\">\n            <div class=\"l-mw l-mw--800\">\n              <h3 class=\"c-ttl-small c-ttl-middle--mbLarge\">1日の流れ</h3>\n              <div class=\"c-timeline\">\n                <ol class=\"c-timeline__list\">\n                  <li class=\"c-timeline__itemWrapper\">\n                    <dl class=\"c-timeline__item\">\n                      <dt class=\"c-timeline__time\"><span><span>6:00</span></span></dt>\n                      <dd class=\"c-timeline__content\">\n                        <h4 class=\"c-timeline__heading\">起床</h4>\n                        <p></p>\n                      </dd>\n                    </dl>\n                  </li>\n                  <li class=\"c-timeline__itemWrapper\">\n                    <dl class=\"c-timeline__item\">\n                      <dt class=\"c-timeline__time\"><span><span>6:40</span></span></dt>\n                      <dd class=\"c-timeline__content\">\n                        <h4 class=\"c-timeline__heading\">家を出る</h4>\n                        <p></p>\n                      </dd>\n                    </dl>\n                  </li>\n                  <li class=\"c-timeline__itemWrapper\">\n                    <dl class=\"c-timeline__item\">\n                      <dt class=\"c-timeline__time\"><span><span>7:00</span></span></dt>\n                      <dd class=\"c-timeline__content\">\n                        <h4 class=\"c-timeline__heading\">出社</h4>\n                        <p></p>\n                      </dd>\n                    </dl>\n                  </li>\n                  <li class=\"c-timeline__itemWrapper\">\n                    <dl class=\"c-timeline__item\">\n                      <dt class=\"c-timeline__time\"><span><span>7:20</span></span></dt>\n                      <dd class=\"c-timeline__content\">\n                        <h4 class=\"c-timeline__heading\">現場へ向かう</h4>\n                        <p></p>\n                      </dd>\n                    </dl>\n                  </li>\n                  <li class=\"c-timeline__itemWrapper\">\n                    <dl class=\"c-timeline__item\">\n                      <dt class=\"c-timeline__time\"><span><span>8:30</span></span></dt>\n                      <dd class=\"c-timeline__content\">\n                        <h4 class=\"c-timeline__heading\">現場到着・段取り</h4>\n                        <p>12:00まで作業</p>\n                      </dd>\n                    </dl>\n                  </li>\n                  <li class=\"c-timeline__itemWrapper\">\n                    <dl class=\"c-timeline__item\">\n                      <dt class=\"c-timeline__time\"><span><span>12:00</span></span></dt>\n                      <dd class=\"c-timeline__content\">\n                        <h4 class=\"c-timeline__heading\">昼休み</h4>\n                        <p></p>\n                      </dd>\n                    </dl>\n                  </li>\n                  <li class=\"c-timeline__itemWrapper\">\n                    <dl class=\"c-timeline__item\">\n                      <dt class=\"c-timeline__time\"><span><span>13:00</span></span></dt>\n                      <dd class=\"c-timeline__content\">\n                        <h4 class=\"c-timeline__heading\">作業</h4>\n                        <p>16:00まで作業</p>\n                      </dd>\n                    </dl>\n                  </li>\n                  <li class=\"c-timeline__itemWrapper\">\n                    <dl class=\"c-timeline__item\">\n                      <dt class=\"c-timeline__time\"><span><span>17:00</span></span></dt>\n                      <dd class=\"c-timeline__content\">\n                        <h4 class=\"c-timeline__heading\">帰社</h4>\n                        <p>書類整理・翌日段取り</p>\n                      </dd>\n                    </dl>\n                  </li>\n                  <li class=\"c-timeline__itemWrapper\">\n                    <dl class=\"c-timeline__item\">\n                      <dt class=\"c-timeline__time\"><span><span>17:30</span></span></dt>\n                      <dd class=\"c-timeline__content\">\n                        <h4 class=\"c-timeline__heading\">退勤</h4>\n                        <p>～18:00</p>\n                      </dd>\n                    </dl>\n                  </li>\n                </ol>\n              </div>\n            </div>\n          </div>\n          <!-- 一日の流れ -->\n          <div class=\"l-section__inner l-section__inner--pbSmall-sm\">\n            <div class=\"l-mw l-mw--800\">\n              <picture class=\"c-imageWrapper\">\n                <source srcset=\"/recruit/inc/image/member/interview01/pic_interviewBody03.jpg.webp 1x, /recruit/inc/image/member/interview01/pic_interviewBody03@2x.jpg.webp 2x\" type=\"image/webp\">\n                <img src=\"/recruit/inc/image/member/interview01/pic_interviewBody03.jpg\" alt=\"業務風景\">\n              </picture>\n            </div>\n          </div>\n          <div class=\"l-section__inner l-section__inner--pbSmall-sm\">\n            <div class=\"l-mw l-mw--800\">\n              <h3 class=\"c-ttl-small\">応募を考えている人へメッセージをお願いします!!</h3>\n              <p>山産の仕事は、たくさんの人と打ち合わせをして進めていくのが特徴。人と話すことが好きな人、機械が好きな人こそ楽しめる会社です。業界未経験者や、学生時代の学部が畑違いでも、活躍している先輩が多数在籍。頑張れば頑張っただけ、賞与で還元してもらえます。自由な社風で、個人の融通が利くのも魅力の一つ。自分らしく生きたい、プライベートも大切にしたい人にはぴったりだと思っています。</p>\n            </div>\n          </div>\n          <!-- 本文 -->\n        </section>\n        <!-- 他インタビューへのリンク-->\n        <div class=\"l-bg l-bg--bgColor\">\n          <div class=\"l-section l-section--pb2x u-border-top\">\n            <h2 class=\"c-ttl-main c-ttl-main c-ttl--center c-ttl--keycolor c-ttl--oblique\"> 他のメンバーのインタビューを見る </h2>\n            <div class=\"l-Grid--18\">\n              <!-- 他ページへのリンク -->\n              <ul class=\"grid\">\n                <li class=\"col-4_md-6_sm-12\">\n                  <a href=\"/recruit/member/interview06\" class=\"c-hasImageCard\">\n                    <picture class=\"c-hasImageCard__image\">\n                      <source srcset=\