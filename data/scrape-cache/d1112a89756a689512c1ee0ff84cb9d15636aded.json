\">\n                    <source media=\"(max-width:768px)\"\n                        srcset=\"/mt-static/support/theme_static/recruit/images/about_us/img_kv_about-us_sp.png\">\n                    <img src=\"/mt-static/support/theme_static/recruit/images/about_us/img_kv_about-us_pc.png\" alt=\"\">\n                </picture>\n                <div class=\"page-title\">\n                    <h1><span class=\"font-quattro bold\">ABOUT US</span><small>会社情報</small></h1>\n                </div>\n            </div>\n            \n\n        <section class=\"about-us-index\">\n    <div class=\"l-inner\">\n      <div class=\"index-read\">\n          <p>クリーク･アンド･リバー社は、映像、ゲーム、Web、広告・出版、作家、建築、ファッション、食、コンピュータサイエンス、舞台芸術、ライフサイエンス、アスリート、CXOの分野でエージェンシー事業、プロデュース事業、ライツマネジメント事業を展開しています。<br>その他、医療、IT、法曹、会計分野を手掛けるグループ会社があり、クリーク･アンド･リバー社をはじめとするC&Rグループでは、プロフェッショナルの方々の持てる力を最大限に発揮できる環境を提供し、その能力を通じてクライアントの企業価値向上に貢献することを目指しています。</p>\n      </div>\n      <ul class=\"index-list\">\n        <li>\n          <a href=\"vision/\">\n            <div class=\"thumb\"><img src=\"/mt-static/support/theme_static/recruit/images/about_us/img_index_01.png\" alt=\"\"></div>\n            <h2><span class=\"num font-quattro bold\">01</span><span class=\"title\">経営理念・ミッション</span></h2>\n          </a>\n        </li>\n        <li>\n          <a href=\"business/\">\n            <div class=\"thumb\"><img src=\"/mt-static/support/theme_static/recruit/images/about_us/img_index_02.png\" alt=\"\"></div>\n            <h2><span class=\"num font-quattro bold\">02</span><span class=\"title\">事業内容・強み</span></h2>\n          </a>\n        </li>\n        <li>\n          <a href=\"infographics/\">\n            <div class=\"thumb\"><img src=\"/mt-static/support/theme_static/recruit/images/about_us/img_index_03.png\" alt=\"\"></div>\n            <h2><span class=\"num font-quattro bold\">03</span><span class=\"title\">数字でみるクリーク・アンド・リバー社</span></h2>\n          </a>\n        </li>\n        <li>\n          <a href=\"culture/\">\n       