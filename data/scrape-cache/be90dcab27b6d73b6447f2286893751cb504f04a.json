{"url":"https://recruit.jops.co.jp/interview/staff-06/","html":"<!DOCTYPE html>\n<html lang=\"ja\" id=\"ja\">\n<head>\n<meta charset=\"utf-8\">\n\n<!-- meta -->\n<!-- 20251008-3 -->\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1, shrink-to-fit=no\">\n<meta name=\"author\" content=\"（株）日本オープンシステムズ\">\n<meta name=\"format-detection\" content=\"telephone=no\">\n\n<!-- CSS -->\n<link rel=\"stylesheet\" href=\"/common/css/style.css?20260619-1\">\n<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n<link href=\"https://fonts.googleapis.com/css2?\n\tfamily=Noto+Sans+JP:wght@100..900&\n\tfamily=Noto+Serif+JP:wght@200..900&\n\tfamily=M+PLUS+Rounded+1c&\n\tfamily=Lato:wght@100;300;400;700;900&\ndisplay=swap\" rel=\"stylesheet\">\n<script src=\"/common/js/bootstrap.bundle5.3.js\"></script>\n<script src=\"/common/js/common.js\"></script>\n<script src=\"/common/js/css_browser_selector.js\"></script>\n<script src=\"/common/js/anime.min.js\"></script>\n<script src=\"/common/js/animate/wow.js\"></script>\n<script src=\"https://cdnjs.cloudflare.com/ajax/libs/lottie-web/5.7.4/lottie.min.js\"></script>\n<script src=\"/common/js/scroll-hint.js\"></script>\n\n<link rel=\"stylesheet\" href=\"/common/js/splide/splide-core.min.css\">\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/glightbox/dist/css/glightbox.min.css\" />\n<link href=\"https://unpkg.com/aos@2.3.1/dist/aos.css\" rel=\"stylesheet\">\n<link rel=\"apple-touch-icon\" href=\"/common/images/parts/favicon.png\">\n<link rel=\"shortcut icon\" href=\"/common/images/parts/favicon.png\">\n<meta property=\"og:image\" content=\"/common/images/parts/favicon.png\">\n\n<!-- Google tag (gtag.js) -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-J2W1236FVP\"></script>\n<script>\n window.dataLayer = window.dataLayer || [];\n function gtag(){dataLayer.push(arguments);}\n gtag('js', new Date());\n\n gtag('config', 'G-J2W1236FVP');\n</script>\n\n\n\n<!-- keywords -->\n<meta name=\"keywords\" content=\"\">\n\n<meta name=\"description\" content=\"\">\n<title>はたらく人たち｜（株）日本オープンシステムズ\n\n</title>\n\n</head>\n\n<body id=\"staff-06\" class=\"alpha-beta-gamma\">\n\n<!-- 左の図形アニメーション用 -->\n<div class=\"bg-zukei-left\">\n  <div class=\"lottie-bg-zukei-l\"></div>\n</div>\n\n<!-- 右の図形アニメーション用 -->\n<div class=\"bg-zukei-right\">\n  <div class=\"lottie-bg-zukei-r\"></div>\n</div>\n\n\n<div id=\"content-wrap\">\n\n<!-- header -->\n<header>\n\n<div id=\"header-dw\">\n\n<!-- menu-logo -->\n<div class=\"menu-logo\">\n\t<a href=\"/\">\n\t\t<p class=\"d-none\">株式会社 日本オープンシステムズ</p>\n\t</a>\n</div>\n<div class=\"h-entry-btn-top d-none d-xl-block\">\n\t<p class=\"btn-continue\"><a href=\"/job-info/\" class=\"cntn-bl\"><span>募集要項</span></a></p>\n\t<p class=\"btn-continue\"><a href=\"/inquiry/\" class=\"cntn-pk\"><span>ENTRY</span></a></p>\n</div>\n\n\n<div id=\"menu-btn\">\n\t<div class=\"bg-a inverted\">\n\t\t<span></span>\n\t\t<span></span>\n\t\t<span></span>\n\t\t<span></span>\n\t</div>\n</div>\n\n</div><!-- id=\"header-dw\" -->\n\n\n<div id=\"drawer_bg\"></div>\n\n\n<div id=\"header-main\">\n\n<!-- menu-logo -->\n<div class=\"menu-logo\">\n\t<a href=\"/\">\n\t\t<p class=\"d-none\">株式会社 日本オープンシステムズ</p>\n\t</a>\n</div>\n\n<div class=\"menu\"><!-- menu-main -->\n<div class=\"menu-main acl\">\n\t<ul>\n\t\t<li class=\"home line\"><a href=\"/\"><span>HOME</span></a></li>\n\t\t<li class=\"business line\"><a href=\"/about/\"><span>JOPSを知る</span></a></li>\n\t\t<li class=\"business line\"><a href=\"/work-style/\"><span>はたらく環境</span></a></li>\n\t</ul>\n\n\t<ul class=\"menu-plus\">\n\t\t<li class=\"recruit line\"><a href=\"/interview/\"><span>はたらく人たち</span></a>\n\t\t<span class=\"h-acmenu h-acmenu-open\"></span> <!-- 開いている状態にする -->\n\t\t\t<ul class=\"small-cate\" style=\"display:block;\"> <!-- 最初から表示させる -->\n\t\t\t\t<li class=\"staff-01\"><a href=\"/interview/staff-01/\"><span>東京・名古屋システム開発部 [名古屋] M.Iさん</span></a></li>\n\t\t\t\t<li class=\"staff-02\"><a href=\"/interview/staff-02/\"><span>ソリューションサービス部 [東京] M.Kさん</span></a></li>\n\t\t\t\t<li class=\"staff-03\"><a href=\"/interview/staff-03/\"><span>東京・名古屋システム開発部 [東京] M.Kさん</span></a></li>\n\t\t\t\t<li class=\"staff-04\"><a href=\"/interview/staff-04/\"><span>長野システム開発部 [長野] A.Hさん</span></a></li>\n\t\t\t\t<li class=\"staff-05\"><a href=\"/interview/staff-05/\"><span>クラウドサービス部 [富山] N.Tさん</span></a></li>\n\t\t\t\t<li class=\"staff-06\"><a href=\"/interview/staff-06/\"><span>クラウドサービス部 [富山] K.Yさん</span></a></li>\n\t\t\t\t<li class=\"staff-07\"><a href=\"/interview/staff-07/\"><span>北陸営業部 [富山] K.Sさん</span></a></li>\n\t\t\t</ul>\n\t\t</li>\n\t</ul>\n\n\t<ul>\n\t\t<li class=\"real-talk line\"><a href=\"/real-talk/\"><span>若手座談会</span></a></li>\n\t\t<li class=\"product line\"><a href=\"/info/\"><span>お知らせ</span></a></li>\n\t\t<li class=\"job-info line\"><a href=\"/job-info/\"><span>募集要項</span></a></li>\n\t\t<li class=\"company line\"><a href=\"/inquiry/\"><span>お問い合わせ</span></a></li>\n\t</ul>\n</div><!-- class=\"menu-main\" -->\n\n</div><!--class=\"menu\"-->\n<div class=\"sub\">\n<div class=\"h-sns-tel-area\">\n<!-- sns -->\n<div class=\"menu-sns\">\n<p class=\"menu-policy\"><a href=\"https://www.jops.co.jp/policy/\" target=\"_blank\">プライバシーポリシー</a></p>\n<ul class=\"sns-list\">\n\t<li class=\"sns-twitter\"><a href=\"https://x.com/JOPS_JP\" target=\"_blank\"><span>JOPS公式X</span></a></li>\n\t<li class=\"sns-youtube\"><a href=\"https://www.youtube.com/@%E6%A0%AA%E5%BC%8F%E4%BC%9A%E7%A4%BE%E6%97%A5%E6%9C%AC%E3%82%AA%E3%83%BC%E3%83%97%E3%83%B3%E3%82%B7%E3%82%B9%E3%83%86%E3%83%A0\" target=\"_blank\"><span>公式YouTube</span></a></li>\n\t<li class=\"sns-blog\"><a href=\"https://www.jops.co.jp/news/president-blog/\" target=\"_blank\"><span>社長ブログ</span></a></li>\n</ul>\n</div><!-- class=\"menu-sns\" -->\n\n<!-- tel -->\n<div class=\"menu-tel\">\n\t<ul>\n\t\t<li class=\"phone-number\">\n\t\t\t<p class=\"phone-comment\"><span>お電話でのお問い合わせ</span></p>\n\t\t\t<a href=\"tel:076-403-9010\">\n\t\t\t\t<p class=\"d-none\">076-403-9010</p>\n\t\t\t</a>\n\t\t\t<p class=\"phone-time\">受付時間　平日 9:00-17:00</p>\n\t\t</li>\n\t</ul>\n\n\t<p class=\"others-btn\"><a href=\"/inquiry/\"><span>採用・その他のお問い合わせ</span></a></p>\n</div><!-- class=\"menu-tel\" -->\n</div>\n\n<div class=\"h-entry-btn-area\">\n\t<p class=\"btn-entry\"><a href=\"/job-info/\" class=\"b-bl\"><span>募集要項</span></a></p>\n\t<p class=\"btn-entry\"><a href=\"/inquiry/\" class=\"b-pk\"><span>ENTRY</span></a></p>\n</div>\n\n</div><!--class=\"sub\"-->\n\n</div><!-- id=\"header-main\" -->\n\n\n</header>\n\n\n\n<div id=\"content\">\n<main role=\"main\" id=\"alpha\">\n\n\n<div class=\"bg-bokashi\"><!-- class=\"bg-bokashi\" 背景のぼかし -->\n\n<div class=\"heading-title\">\n<div class=\"container\">\n\t<h1><span>はたらく人たち</span></h1>\n\t<p>はたらく人たち スタッフインタビュー</p>\n</div><!-- class=\"container\" -->\n</div><!-- class=\"heading-title\" -->\n\n\n<nav aria-label=\"breadcrumb\" class=\"container\">\n\t<ol class=\"breadcrumb\">\n\t\t<li class=\"breadcrumb-item\"><a href=\"/\"><span>HOME</span></a></li>\n\t\t<li class=\"breadcrumb-item\"><a href=\"/interview/\"><span>はたらく人たち</span></a></li>\n\t\t<li class=\"breadcrumb-item active\" aria-current=\"page\">クラウドサービス部 [富山] K.Yさん</li>\n\t</ol>\n</nav>\n\n\n\n<article id=\"staff-06_introduction\">\n<section class=\"staff-mv\">\n\n<div class=\"staff-mv-area\">\n\t<div class=\"staff-mv-photo skshi\">\n\t\t<img src=\"../../common/images/interview/staff-06/00-04-06-01.webp\" alt=\"メインビジュアル\">\n\t</div>\n\n\t<ul class=\"staff-mv-box\">\n\t\t<li class=\"staff-mv-title\">\n\t\t\t<h5>\n\t\t\t\t<span>技術力に増して、</span><br>\n\t\t\t\t<span>対話力も求められる仕事</span>\n\n\t\t\t</h5>\n\t\t</li>\n\t\t<li class=\"staff-mv-txt\">\n\t\t\t<p>2020年入社　K.Yさん</p>\n\t\t\t<p>富山本社</p>\n\t\t\t<p>クラウドサービス部</p>\n\t\t</li>\n\t\t<li class=\"staff-mv-profile\">\n\t\t\t<h6>プロフィール</h6>\n\t\t\t<p>石川県出身。長野県の大学で情報工学を専攻し、脳科学や人工知能について研究。\n\t\t\t3年次、当社のインターンシップに参加し、事業内容や社内の雰囲気の良さに魅力を感じ、入社を決めた。\n\t\t\t現在は富山本社に勤務。</p>\n\n\t\t\t<span class=\"line-pink-a\"></span>\n\t\t\t<span class=\"line-green-a\"></span>\n\t\t\t<span class=\"line-pink-b\"></span>\n\t\t\t<span class=\"line-green-b\"></span>\n\t\t</li>\n\t</ul>\n</div>\n\n<div class=\"loop-wrapper\"><!-- ループ英語 -->\n  <p class=\"deco-en-loop\">\n    Staff interview&nbsp;Staff interview&nbsp;Staff interview&nbsp;Staff interview\n  </p>\n  <p class=\"deco-en-loop\">\n    Staff interview&nbsp;Staff interview&nbsp;Staff interview&nbsp;Staff interview\n  </p>\n</div><!-- class=\"loop-wrapper\"ループ英語 -->\n\n</section><!-- class=\"staff-mv\" -->\n</article><!-- id=\"staff-06_introduction\" -->\n\n\n\n<article id=\"staff-06_summary\">\n<div class=\"container\">\n\n<section class=\"staff-summary-area\">\n\n<ul class=\"staff-smry-list\">\n\t<li class=\"staff-smry-row r-photo\">\n\t\t<div class=\"staff-smry-photo skshi\" data-aos=\"fade-up\" data-aos-delay=\"100\" data-aos-easing=\"ease-in-out\">\n\t\t\t<img src=\"../../common/images/interview/staff-06/00-04-06-02.webp\" alt=\"インタビュー写真-02\">\n\t\t</div>\n\n\t\t<div class=\"staff-smry-txt\">\n\t\t\t<div data-aos=\"fade-up\" data-aos-delay=\"400\" data-aos-easing=\"ease-in-out\">\n\t\t\t\t<h3 class=\"staff-smry-title smry-num01\">\n\t\t\t\t\t<span>入社1年目にビッグプロジェクトに参加、<br class=\"d-none d-md-inline\">\n\t\t\t\t\t先輩のサポートのおかげで乗り越えられました。</span>\n\t\t\t\t</h3>\n\t\t\t</div>\n\n\t\t\t<p>入社1年目、エネルギー関連会社の基幹業務システムの再構築プロジェクトに関わったことが印象に残っています。\n\t\t\t私は打ち合わせや資料作成、情報整理などを担当しました。\n\t\t\tその基幹業務システムは規模が大きく、連携しているシステムも多かったので、内容を把握するのが大変でした。\n\t\t\t専門用語が飛び交う打ち合わせは、かなりのプレッシャーでした。\n\t\t\tでも、先輩が「分からなかったらすぐに聞いて！」、「今のとこ、大丈夫？」と気遣ってくれ、何とか乗り越えることができました。\n\t\t\tあの数カ月間は濃厚な時間だったと思います。</p>\n\t\t</div>\n\t</li>\n\n\t<li class=\"staff-smry-row\">\n\t\t<div class=\"staff-smry-photo skshi\" data-aos=\"fade-up\" data-aos-delay=\"100\" data-aos-easing=\"ease-in-out\">\n\t\t\t<img src=\"../../common/images/interview/staff-06/00-04-06-03.webp\" alt=\"インタビュー写真-03\">\n\t\t</div>\n\n\t\t<div class=\"staff-smry-txt\">\n\t\t\t<div data-aos=\"fade-up\" data-aos-delay=\"400\" data-aos-easing=\"ease-in-out\">\n\t\t\t\t<h3 class=\"staff-smry-title smry-num02\">\n\t\t\t\t\t<span>自分の思いをどう伝えるか、<br class=\"d-none d-md-inline\">\n\t\t\t\t\t分かりやすい資料作りを意識しています。</span>\n\t\t\t\t</h3>\n\t\t\t</div>\n\n\t\t\t<p>ITの仕事は一人で黙々とパソコンに向かっているイメージがあると思います。\n\t\t\tでも、実際はお客様と対話することが多く、コミュニケーションの重要性を実感しました。\n\t\t\t例えば打ち合わせでは何を伝え、何を決めるのかを事前に整理し、分かりやすい資料を作成することが大事。\n\t\t\t新人の頃は、簡潔にまとめることを重視していましたが、最近は自分が思っているより少し多めに、丁寧に書くことが重要だと思うようになりました。\n\t\t\t特にリモートの会議では資料の書き方が大事。まずは伝えたいことを列挙して、整理しながらまとめていくよう心がけています。</p>\n\t\t</div>\n\t</li>\n\n\t<li class=\"staff-smry-row r-photo\">\n\t\t<div class=\"staff-smry-photo skshi\" data-aos=\"fade-up\" data-aos-delay=\"100\" data-aos-easing=\"ease-in-out\">\n\t\t\t<img src=\"../../common/images/interview/staff-06/00-04-06-04.webp\" alt=\"インタビュー写真-04\">\n\t\t</div>\n\n\t\t<div class=\"staff-smry-txt\">\n\t\t\t<div data-aos=\"fade-up\" data-aos-delay=\"400\" data-aos-easing=\"ease-in-out\">\n\t\t\t\t<h3 class=\"staff-smry-title smry-num03\">\n\t\t\t\t\t<span>いろんな業界の現状が分かる仕事、<br class=\"d-none d-md-inline\">\n\t\t\t\t\tプロジェクトが変わる度、好奇心が掻き立てられます。</span>\n\t\t\t\t</h3>\n\t\t\t</div>\n\n\t\t\t<p>クラウドサービス部の仕事を簡単に言うと、お客様の困り事や問題点をヒアリングし、システム構築によって解決すること。\n\t\t\tお客様の企業は規模も業種も様々なので、自分が知らなかった業界の方と会うこともあります。\n\t\t\t知らないこと、経験したことのないことに触れるのは好きなので、毎回、新しい情報をインプットし、学びながら仕事を進めています。\n\t\t\t仕事を通して外の世界、未知の世界を知ることができるのは役得だと思っています。</p>\n\t\t</div>\n\t</li>\n\n\t<li class=\"staff-smry-row\">\n\t\t<div class=\"staff-smry-photo skshi\" data-aos=\"fade-up\" data-aos-delay=\"100\" data-aos-easing=\"ease-in-out\">\n\t\t\t<img src=\"../../common/images/interview/staff-06/00-04-06-05.webp\" alt=\"インタビュー写真-05\">\n\t\t</div>\n\n\t\t<div class=\"staff-smry-txt\">\n\t\t\t<div data-aos=\"fade-up\" data-aos-delay=\"400\" data-aos-easing=\"ease-in-out\">\n\t\t\t\t<h3 class=\"staff-smry-title smry-num04\">\n\t\t\t\t\t<span>好きな座席を選ぶフリーアドレス制、<br class=\"d-none d-md-inline\">\n\t\t\t\t\t他部署の社員と親しくなるきっかけになっています。</span>\n\t\t\t\t</h3>\n\t\t\t</div>\n\n\t\t\t<p>デスクフロアはフリーアドレス制を採用していて、翌日に着きたい席をネット予約します。\n\t\t\t当社はリモートワークの社員も多いのですが、私は出社する方が気持ちの切り替えができるし、刺激を受けることもできるので、ほぼ毎日出社しています。\n\t\t\t社風はとてもフランクですね。上下関係もわりと緩いので、部長にも課長にも気軽に相談できる雰囲気があります。\n\t\t\t違う部署の社員とも接しやすいですよ！</p>\n\t\t</div>\n\t</li>\n</ul>\n</section><!-- class=\"staff-summary-area\" -->\n\n</div><!-- class=\"container\" -->\n</article><!-- id=\"staff-06_summary\" -->\n\n\n\n<article id=\"schedule-off\">\n<div class=\"container\">\n\n<section class=\"sche-off-area\">\n<div class=\"bg-wh-s\">\n<div class=\"sche-off-box\">\n\t<div class=\"sche-area\">\n\t\t<div class=\"sche-area-title\">\n\t\t\t<p><img src=\"../../common/images/interview/skjr-icon.svg\" alt=\"SCHEDULE\"></p>\n\t\t\t<h5>1日のスケジュール</h5>\n\t\t</div>\n\t\t<ul class=\"timeline\">\n\t\t\t<li>\n\t\t\t\t<span class=\"time\">8：40</span>\n\t\t\t\t<p>マイカーで出社</p>\n\t\t\t</li>\n\t\t\t<li>\n\t\t\t\t<span class=\"time\">9：00</span>\n\t\t\t\t<p>作業開始</p>\n\t\t\t</li>\n\t\t\t<li>\n\t\t\t\t<span class=\"time\">10：30</span>\n\t\t\t\t<p>コーヒーブレイク</p>\n\t\t\t</li>\n\t\t\t<li>\n\t\t\t\t<span class=\"time\">12：00</span>\n\t\t\t\t<p>先輩と一緒に外食ランチ</p>\n\t\t\t</li>\n\t\t\t<li>\n\t\t\t\t<span class=\"time\">13：30</span>\n\t\t\t\t<p>お客様企業を訪問して打ち合わせ</p>\n\t\t\t</li>\n\t\t\t<li>\n\t\t\t\t<span class=\"time\">15：30</span>\n\t\t\t\t<p>帰社して別件の見積書を作成</p>\n\t\t\t</li>\n\t\t\t<li>\n\t\t\t\t<span class=\"time\">18：00</span>\n\t\t\t\t<p>退社</p>\n\t\t\t</li>\n\t\t</ul>\n\t</div>\n\n\t<div class=\"off-area\">\n\t\t<div class=\"off-area-title\">\n\t\t\t<p><img src=\"../../common/images/interview/off-icon.svg\" alt=\"OFF TIME\"></p>\n\t\t\t<h5>最近、ハマっていることは？</h5>\n\t\t</div>\n\t\t<div class=\"off-smry\">\n\t\t\t<p class=\"off-photo\"><img src=\"../../common/images/interview/staff-06/off-01.webp\" alt=\"趣味の写真\"></p>\n\t\t\t<p class=\"off-txt\">基本的にはインドア派。\n\t\t\t休日は電子書籍を読んだり、動画を観たりして過ごすことが多いです。\n\t\t\tでも、体も動かさないといけないので、最近はマラソンを楽しんでいます。\n\t\t\t仲間と一緒にリレーマラソンに参加した際、走り終えた時の爽快感は格別でしたよ！</p>\n\t\t</div>\n\t</div>\n</div><!-- class=\"sche-off-box\" -->\n</div><!-- class=\"bg-wh-s\" -->\n</section><!-- class=\"sche-off-area\" -->\n\n</div><!-- class=\"container\" -->\n</article><!-- id=\"schedule-off\" -->\n\n</div><!-- class=\"bg-bokashi\" 背景のぼかし -->\n\n\n\n<article id=\"staff-message\">\n<div class=\"container\">\n\n<section class=\"staff-msg-area\">\n<div class=\"staff-msg-box\">\n\t<div class=\"staff-msg-title\">\n\t\t<p class=\"message-en\"></p>\n\t\t<h4 data-aos=\"fade-up\" data-aos-delay=\"100\" data-aos-easing=\"ease-in-out\">就活生へのメッセージ</h4>\n\t</div>\n\n\t<p class=\"staff-msg-txt\" data-aos=\"fade-up\" data-aos-delay=\"400\" data-aos-easing=\"ease-in-out\">自分はどんな仕事がしたいのか、自分が望む仕事がそこにあるのかを知るには、インターンシップが最適だと思います。\n\t業務内容がよくわかるし、社風や福利厚生なども見えてきます。\n\t実感できることが多ければ、入社してからのギャップは小さくなると思いますよ！</p>\n</div>\n</section>\n\n</div><!-- class=\"container\" -->\n</article>\n\n\n\n<div class=\"bg-bokashi\"><!-- class=\"bg-bokashi\" 背景のぼかし -->\n\n<article id=\"staff_interview-slider\" class=\"splide-btm\">\n<div class=\"no-scroll-x\"><!-- はみ出し防止 -->\n\n<div class=\"container\">\n<div id=\"s-intvw-title-box\">\n\t<div class=\"s-intvw-title\">\n\t\t<div class=\"lt-anime-area\">\n\t\t\t<p class=\"title-b\"><span>はたらく人たち・スタッフインタビュー</span></p>\n\t\t\t<h2 class=\"title-a\">JOPSの中の人</h2>\n\n\t\t\t<span class=\"line-pink-a\"></span>\n\t\t\t<span class=\"line-green-a\"></span>\n\t\t\t<span class=\"line-pink-b\"></span>\n\t\t\t<span class=\"line-green-b\"></span>\n\n\t\t</div>\n\t\t<p class=\"deco-en\">Staff <br class=\"d-md-none\">interview</p>\n\t</div>\n\t<p class=\"s-intvw-txt\">「JOPSの中の人」ってどんな人？<br>入社のきっかけや日々の仕事、感じているやりがいをご紹介します。</p>\n</div>\n</div><!-- class=\"container\" -->\n\n\n<section class=\"splide-intvw-area\">\n<div class=\"inner\">\n<div class=\"overflow-right\">\n\n<div class=\"splide js-intvw-slider\">\n\n<div class=\"splide__track\">\n\n\t<ul class=\"splide__list\">\n\t\t<li class=\"splide__slide\">\n\t\t\t<div class=\"s-action\">\n\t\t\t<a href=\"/interview/staff-01/\">\n\t\t\t\t<div class=\"staff-intvw-area\">\n\t\t\t\t\t<div class=\"intvw-s-photo skshi\">\n\t\t\t\t\t\t<img src=\"/common/images/interview/00-03-02-01-01.webp\" alt=\"staff-01\">\n\t\t\t\t\t</div>\n\t\t\t\t\t<div class=\"intvw-s-txt-area\">\n\t\t\t\t\t<h5>\n\t\t\t\t\t\t<span>「文系、未経験でも大丈夫！」</span><br>\n\t\t\t\t\t\t<span>先輩の言葉が入社の決め手に</span>\n\t\t\t\t\t</h5>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t\t<div class=\"intvw-date\">\n\t\t\t\t\t<p>2020年入社　M.Iさん</p>\n\t\t\t\t\t<p>名古屋事業所</p>\n\t\t\t\t\t<p>東京・名古屋システム開発部</p>\n\t\t\t\t</div>\n\t\t\t</a>\n\t\t\t</div>\n\t\t</li>\n\t\t<li class=\"splide__slide\">\n\t\t\t<div class=\"s-action\">\n\t\t\t<a href=\"/interview/staff-02/\">\n\t\t\t\t<div class=\"staff-intvw-area\">\n\t\t\t\t\t<div class=\"intvw-s-photo skshi\">\n\t\t\t\t\t\t<img src=\"/common/images/interview/00-03-02-02-01.webp\" alt=\"staff-02\">\n\t\t\t\t\t</div>\n\t\t\t\t\t<div class=\"intvw-s-txt-area\">\n\t\t\t\t\t<h5>\n\t\t\t\t\t\t<span>誰にでも、何でも気軽に話せる</span><br>\n\t\t\t\t\t\t<span>雰囲気が好きです</span>\n\t\t\t\t\t</h5>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t\t<div class=\"intvw-date\">\n\t\t\t\t\t<p>2023年入社　M.Kさん</p>\n\t\t\t\t\t<p>東京事業所</p>\n\t\t\t\t\t<p>ソリューションサービス部</p>\n\t\t\t\t</div>\n\t\t\t</a>\n\t\t\t</div>\n\t\t</li>\n\t\t<li class=\"splide__slide\">\n\t\t\t<div class=\"s-action\">\n\t\t\t<a href=\"/interview/staff-03/\">\n\t\t\t\t<div class=\"staff-intvw-area\">\n\t\t\t\t\t<div class=\"intvw-s-photo skshi\">\n\t\t\t\t\t\t<img src=\"/common/images/interview/00-03-02-03-01.webp\" alt=\"staff-03\">\n\t\t\t\t\t</div>\n\t\t\t\t\t<div class=\"intvw-s-txt-area\">\n\t\t\t\t\t<h5>\n\t\t\t\t\t\t<span>リモートワークで</span><br>\n\t\t\t\t\t\t<span>自分らしく働ける職場環境</span>\n\t\t\t\t\t</h5>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t\t<div class=\"intvw-date\">\n\t\t\t\t\t<p>2023年入社　M.Kさん</p>\n\t\t\t\t\t<p>東京事業所</p>\n\t\t\t\t\t<p>東京・名古屋システム開発部</p>\n\t\t\t\t</div>\n\t\t\t</a>\n\t\t\t</div>\n\t\t</li>\n\t\t<li class=\"splide__slide\">\n\t\t\t<div class=\"s-action\">\n\t\t\t<a href=\