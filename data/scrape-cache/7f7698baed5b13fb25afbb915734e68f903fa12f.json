\t\t<!-- [START .lib-child__item]-->\r\n                                    </ul>\r\n                                </div>\r\n                            </div>\r\n                        </li>\r\n\t\t\t\t\t\t<!-- [END li.lib-nav__item]-->\r\n\t\t\t\t\t\t<!-- [START li.lib-nav__item]-->\r\n\t\t\t\t\t\t<li class=\"lib-nav__item\"><a class=\"lib-nav__btn js-child__focus\" href=\"/recruit/\"><span\r\n\t\t\t\t\t\t\t\t\tclass=\"txt\">採用情報</span></a></li>\r\n\t\t\t\t\t\t<!-- [END li.lib-nav__item]-->\r\n\t\t\t\t\t</ul>\r\n\t\t\t\t\t<ul class=\"lib-induce__outer\">\r\n\t\t\t\t\t\t<li><a class=\"lib-induce__btn ico-before-mail bg-fill bg-main\" href=\"/contact/\"><span class=\"txt\">お問い合わせ</span></a></li>\r\n\t\t\t\t\t\t<li><a class=\"lib-induce__btn ico-before-dl bg-fill bg-accent\" href=\"/download/\"><span\r\n\t\t\t\t\t\t\t\t\tclass=\"txt\">資料ダウンロード</span></a></li>\r\n\t\t\t\t\t</ul>\r\n\t\t\t\t\t<!-- [END lib-induce__outer]-->\r\n\t\t\t\t</div>\r\n\t\t\t\t<!-- [END lib-nav__outer]-->\r\n\t\t\t</div>\r\n\t\t\t<!-- [END lib-nav__cover]-->\r\n\t\t</nav>\r\n\t\t<!-- [END lib-nav__panel]-->\r\n\t</div>\r\n\t<!-- [END lib-header__inner]-->\r\n</div>\r\n<!-- [END lib-header__outer]--></div></span>\n\r\n  <nav class=\"lib-breadcrumb__outer\" aria-label=\"Breadcrumbs\">\r\n    <div class=\"lib-breadcrumb__inside\">\r\n      <ol class=\"lib-breadcrumb__list\" itemscope itemtype=\"http://schema.org/BreadcrumbList\">\r\n      <li itemprop=\"itemListElement\" itemscope itemtype=\"http://schema.org/ListItem\"><a href=\"https://www.takayasu-rf.co.jp/\" itemprop=\"item\"><span itemprop=\"name\">HOME</span></a><meta itemprop=\"position\" content=\"1\" /></li><li itemprop=\"itemListElement\" itemscope itemtype=\"http://schema.org/ListItem\"><a href=\"https://www.takayasu-rf.co.jp/recruit/\" itemprop=\"item\"><span itemprop=\"name\">採用情報</span></a><meta itemprop=\"position\" content=\"2\" /></li><li itemprop=\"itemListElement\" itemscope itemtype=\"http://schema.org/ListItem\"><a href=\"https://www.takayasu-rf.co.jp/recruit/mid-career-requirements/\" itemprop=\"item\" aria-current=\"location\"><span itemprop=\"name\">募集要項（中途採用）</span></a><meta itemprop=\"position\" content=\"3\" /></li>\r\n      </ol>\r\n    </div>\r\n  </nav>\r\n  \r\n  <main id=\"contents\">\r\n    <!-- ブロック貼り付けエリア -->\r\n    <div id=\"dcms_layoutPageBlockPasteArea\">\r\n    <!-- ブロック -->\r\n    <div id=\"dcms_layoutPageBlock\">\r\n    <div class=\"lib-hero__outer js-page-main\">\n<div class=\"lib-hero__txtarea wrap\">\n<div class=\"lib-hero__inner\">\n<h1 class=\"lib-hero__title title\">募集要項（中途採用）</h1>\n</div>\n</div>\n</div>\n<div class=\"lib-title__outer container --typeD\">\n<h2 class=\"title\">採用スタッフからのメッセージ</h2>\n</div>\n<span>当社の採用情報をご覧いただき、ありがとうございます。</span><br /><span>当社は、廃棄物の中でも特に再生が困難であるプラスチックのリサイクルに取り組む会社です。<br /><br />そして、すべての部門で「資源の再利用」というテーマに取り組んでいる、少々異色ともいえる企業です。<br />そのくらい、地球環境のことを真剣に考え、企業活動を通して実践している会社です。<br /><br />当社では、超エリートだけを求めていません。 そのかわり、日々の仕事の先にある「人への思い」を大切にする人材を求めています。<br />仕事を通してコツコツと積み重ねてきたその思いが、いずれ人を動かし、社会へ波及する大きな力となります。それが「社会貢献」と呼ばれる活動の根源であると当社は考えます。<br /><br />あなたはこれまで、そして今も、何を思い、何を大切にして働いていますか？</span>\n<div class=\"lib-title__outer container --typeD\">\n<h2 class=\"title\">募集職種一覧</h2>\n</div>\n<div class=\"container\">\n<div class=\"lib-grid__outer row row-cols-1 row-cols-md-2 row-cols-lg-3 gy-5 gx-md-3\">\n<div class=\"lib-grid__col col d-flex\">\n<div class=\"lib-card__item\">\n<div class=\"lib-card__txtarea\">\n<div class=\"lib-card__inside\">\n<h3 class=\"lib-card__title tcenter\">①職種 営業職<br />（本社・各務原）</h3>\n</div>\n<!-- // lib-card__inside-->\n<div class=\"lib-card__btn\"><a class=\"lib-link__btn\" href=\"https://www.hellowork.mhlw.go.jp/kensaku/GECA110010.do?screenId=GECA110010&amp;action=kyujinhyoBtn&amp;kJNo=2101011343561&amp;kJKbn=1&amp;iNFTeikyoRiyoDtiID=&amp;kSNo=\"><span class=\"txt\">求人票はこちら</span></a></div>\n<div class=\"lib-card__btn mt-3\"><a class=\"lib-link__btn\" href=\"https://www.hellowork.mhlw.go.jp/kensaku/GECA110010.do?scree