s=\"192x192\" />\n<link rel=\"stylesheet preconnect dns-prefetch\" href=\"/assets/css/style.min.css?ver101\">\n<link rel=\"preconnect dns-prefetch\" href=\"https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@100;300;400;500;700;900&family=Ubuntu:wght@300;400;500;700&display=swap\">\n</head>\n\n<body id=\"ja\">\n  \n<!-- Google Tag Manager (noscript) -->\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-TM7DPN8\"\n  height=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n  <!-- End Google Tag Manager (noscript) -->\n  \n\n<div class=\"_loaderFilm\"></div>\n\n\n<header id=\"HEADER\" class=\"\" >\n  <div class=\"_topCo\">\n    <div class=\"_inner\" id=\"HEAD-IN\">\n      <div class=\"_columnLeft\">\n        <p class=\"_logo\">\n          <a href=\"/\"><img src=\"/assets/images/common/logo_color_01.png\" alt=\"秋田東北ダイケン\" id=\"HEAD-LOGO\"></a>\n        </p>\n                  <p class=\"des\">総合ビルメンテナンス業なら<br />株式会社 秋田東北ダイケン</p>\n              </div>\n\n      <div class=\"_columnRight\">\n        <p class=\"_tel\"><i><img src=\"/assets/images/common/ico_phone_black_01.svg\" alt=\"電話\"></i><span>018-832-0401</span><br />受付時間／8:30〜17:30</p>\n        <p class=\"_download\">\n          <a href=\"/download/\"><span>指定請求書様式ダウンロード</span></a>\n        </p>\n        <p class=\"_contact _cm_button\">\n          <a href=\"/contact/\"><span>お問い合わせ</span></a>\n        </p>\n      </div>\n    </div>\n\n    <div class=\"_gnav\" id=\"GNAV\">\n      <div class=\"_gnv-inner\">\n        <nav>\n\n          <ul>\n            <li><a href=\"/\"><span><img src=\"/assets/images/common/ico_home_blue_01.svg\" alt=\"HOME\" /></span><span>HOME</span></a></li>\n            <li><a href=\"/information/\"><span>お知らせ</span></a></li>\n            <li><a href=\"/elected/\"><span>選ばれる理由</span></a></li>\n            <li class=\"_menu\">\n              <a href=\"/works/\"><span>事業内容</span></a>\n              <div class=\"_megaMenu\">\n                <div class=\"_inner\">\n                  <div>\n                    <a href=\"/works/maintenance/\">\n                      <figure>\n                        <img src=\"/assets/images/common/mega_works_img_01.jpg\" alt=\"\">\n                      </figure>\n                      <p class=\"_en\">Maintenance</p>\n                      <p class=\"_jp\">ビルメンテナンス事業</p>\n                    </a>\n                  </div>\n                  <div>\n                    <a href=\"/works/engineering/\">\n                      <figure>\n                        <img src=\"/assets/images/common/mega_works_img_02.jpg\" alt=\"\">\n                      </figure>\n                      <p class=\"_en\">Engineering / Energy saving</p>\n                      <p class=\"_jp\">エンジニアリング・省エネ事業</p>\n                    </a>\n                  </div>\n                  <div>\n                    <a href=\"/works/administrator/\">\n                      <figure>\n                        <img src=\"/assets/images/common/mega_works_img_03.jpg\" alt=\"\">\n                      </figure>\n                      <p class=\"_en\">Designated Administrator</p>\n                      <p class=\"_jp\">指定管理者事業</p>\n                    </a>\n                  </div>\n                </div>\n              </div>\n            </li>\n            <li><a href=\"/aboutus/\"><span>私たちについて</span></a></li>\n\n            <!--<li><a href=\"/csr/\"><span>取り組み</span></a></li>-->\n            <li><a href=\"/group/\"><span>グループ会社</span></a></li>\n            <li><a href=\"/recruit/\"><span>採用情報</span></a></li>\n          </ul>\n        </nav>\n      </div>\n    </div>\n\n\n  </header>\n  <div id=\"NAVI-BUTTON\" class=\"navi__button\">\n  <div class=\"nbInner\">\n    <i></i>\n  </div>\n</div>\n\n<nav id=\"SP__MENU\" class=\"slide_menu\">\n\n  <div class=\"menu_inner\">\n    <div>\n      <p class=\"_tel\"><span><i><img src=\"/assets/images/common/ico_phone_black_01.svg\" /></i>018-832-0401</span><br />受付時間／9:00〜18:00</p>\n      <p class=\"_download\">\n        <a href=\"/download/\"><span>指定請求書様式ダウンロード</span></a>\n      </p>\n      <p class=\"_contact\">\n        <a href=\"/contact/\"><span>お問い合わせ</span></a>\n      </p>\n      <ul>\n        <li><a href=\"/information/\"><span>お知らせ</span></a></li>\n        <li><a href=\"/elected/\"><span>選ばれる理由</span></a></li>\n        <li><a href=\"/works/\" class=\"_accordion\">\n          <span>事業内容</span></a>\n          <div>\n            <ul>\n              <li><a href=\"/works/maintenance/\"><span>ビルメンテナンス事業</span></a></li>\n              <li><a href=\"/works/engineering/\"><span>エンジニアリング・省エネ事業</span></a></li>\n              <li><a href=\"/works/administrator/\"><span>指定管理者事業</span></a></li>\n            </ul>\n          </div>\n        </li>\n        <li><a href=\"/aboutus/\"><span>私たちについて</span></a></li>\n        <!--<li><a href=\"/csr/\"><span>取り組み</span></a></li>-->\n        <li><a href=\"/group/\"><span>グループ会社</span></a></li>\n        <li><a href=\"/recruit/\"><span>採用情報</span></a></li>\n      </ul>\n    </div>\n  </div>\n</nav>\n  <div class=\"wrappar\" id=\"RECRUIT\">\n    <main>\n      <div class=\"_cm_mv_type1\">\n        <figure>\n          <i class=\"ppLazyBg\" data-bg=\"/assets/images/recruit/recruit_mv_01.jpg\"></i>\n        </figure>\n        <div class=\"_in\">\n          <div>\n            <p class=\"_en\">RECRUIT</p>\n            <h1 class=\"_jp\">採用情報</h1>\n          </div>\n        </div>\n        <div class=\"_cm_breadcrumb\">\n          <ul><li><a href='https://tohoku-daiken.co.jp'>TOP</a></li><li><span>採用情報</span></li></ul>        </div><!-- breadcrumb -->\n      </div>\n\n\n\n      <div class=\"_intro\">\n        <p>\n          当社には、多種多様な勤務地があります。その分、働き方も多種多様。<br />\n          働き方が変化した現代で、ここにはあなたの求めている働き方があるかも知れません。<br />\n          未経験者の方、新たなスキルを身に付けたい方、どういった方でも共に働く仲間として歓迎しております。<br />\n          ご興味がある方は、ぜひお問い合わせ下さい。\n        </p>\n      </div>\n\n      <div class=\"_recruitment\">\n        <div class=\"_left\">\n          <div>\n            <h2>\n              <img src=\"/assets/images/recruit/recruit_tit_01.svg\" alt=\"募集要項\">\n            </h2>\n          </div>\n\n        </div>\n        <div class=\"_right\">\n\n                                <h3>総合職（部門管理業務）正社員</h3>\n            <table>\n                          <tr>\n                <th>仕事内容</th>\n                <td>契約先の対応、従業員の指導・管理、担当職種の経営数値の分析等<br />\r\n（適用に合わせ、担当職種を決定します）</td>\n              </tr>\n                          <tr>\n                <th>勤務場所</th>\n                <td>秋田市中通２丁目２－３２<br />\r\n山二ビル５階</td>\n              </tr>\n                          <tr>\n                <th>勤務時間</th>\n                <td>8：30～17：30</td>\n              </tr>\n                          <tr>\n                <th>休日</th>\n                <td>土、日、祝（年間休日118日）</td>\n              </tr>\n                          <tr>\n                <th>給与</th>\n                <td>200，000　～　250，000円<br />\r\n他、通勤手当（会社規定により）</td>\n              </tr>\n                          <tr>\n                <th>その他</th>\n                <td>○作業着・スマートフォン貸与<br />\r\n○経験や能力に応じて給与額も考慮いたします<br />\r\n○雇用保険、健康保険、厚生年金、労災保険加入<br />\r\n</td>\n              </tr>\n                      </table>\n                      <h3>清掃スタッフ募集</h3>\n            <table>\n                          <tr>\n                <th>職 種</th>\n                <td>清掃スタッフ</td>\n              </tr>\n                          <tr>\n                <th>仕事内容</th>\n                <td>施設の玄関、ロビー、共用通路、事務室、トイレ、浴室</td>\n              </tr>\n                          <tr>\n                <th>勤務場所</th>\n                <td>生協さくら病院（①社会福祉法人虹事務所ビル、②介護支援センター八甲、③あけぼの薬局妙見店）</td>\n              </tr>\n                          <tr>\n                <th>勤務時間</th>\n                <td>①②10：00～11：30<br />\r\n③12：30～14：30（休憩60分）<br />\r\n</td>\n              </tr>\n                          <tr>\n                <th>休　日</th>\n                <td>①土、日<br />\r\n②③土、日、祝</td>\n              </tr>\n                          <tr>\n                <th>給　与</th>\n                <td>時給900円～923円<br />\r\n（月収　55，000円程度）</td>\n              </tr>\n                          <tr>\n                <th>その他</th>\n                <td>○通勤手当支給<br />\r\n○車通勤可（駐車場料金会社負担）<br />\r\n</td>\n              </tr>\n                          <tr>\n                <th>問い合わせ先</th>\n                <td>0120-390-980　おさない</td>\n              </tr>\n                      </table>\n                      <h3>清掃スタッフ募集</h3>\n            <table>\n                          <tr>\n                <th>勤務場所</th>\n                <td>生協さくら病院（青森市問屋町）</td>\n              </tr>\n                          <tr>\n                <th>仕事内容</th>\n                <td>施設の玄関、ロビー、共用通路、事務室、トイレ、浴室</td>\n              </tr>\n                          <tr>\n                <th>勤務時間</th>\n                <td>7：30～11：30<br />\r\n</td>\n              </tr>\n                          <tr>\n                <th>休　日</th>\n                <td>月8日　シフト制　※ご相談に応じます</td>\n              </tr>\n                          <tr>\n                <th>給　与</th>\n                <td>時給900円～923円<br />\r\n（月収85，000円程度）</td>\n              </tr>\n                          <tr>\n                <th>その他</th>\n                <td>○無料駐車場あり<br />\r\n○制服・作業靴貸与<br />\r\n○受動喫煙対策あり（喫煙室設置）<br />\r\n<br />\r\n</td>\n              </tr>\n                          <tr>\n                <th>問い合わせ先</th>\n                <td>0120-390-980　おさない<br />\r\n</td>\n              </tr>\n                      </table>\n                      <h3>建物設備の保守・管理スタッフ　※正社員</h3>\n            <table>\n                          <tr>\n                <th>勤務場所</th>\n                <td>青森第二合同庁舎／青森市長島一丁目<br />\r\n</td>\n              </tr>\n                          <tr>\n                <th>仕事内容</th>\n                <td>・設備機器のメーター検針<br />\r\n・管球交換<br />\r\n・年間定期点検業務、設備機器の改修<br />\r\n・施設休館日、夜間の緊急時の対応<br />\r\n</td>\n              </tr>\n                          <tr>\n                <th>勤務時間</th>\n                <td>7：30～16：30（休憩６０分）</td>\n              </tr>\n                          <tr>\n                <th>休日</th>\n                <td>完全週休２日制（土日、施設休館日）</td>\n              </tr>\n                          <tr>\n                <th>給与</th>\n                <td>○月給173,000～230,000円+各種手当　　試用期間2カ月間も同条件<br />\r\n○昇給（規定）<br />\r\n○土日待機手当　2000円／回（月4回程度）<br />\r\n○平日夜間待機手当　500円／回（月9回程度）<br />\r\n</td>\n              </tr>\n                          <tr>\n                <th>その他</th>\n                <td>○賞与　年３回<br />\r\n○受動喫煙対策あり（屋内禁煙）<br />\r\n○年間休日121日　年始休みもあり<br />\r\n○甲種危険物取扱者または甲種4類危険物取扱者があれば尚可</td>\n              </tr>\n                          <tr>\n                <th>問合せ先</th>\n                <td>0120-390-980（オサナイ）</td>\n              </tr>\n                      </table>\n          \n\n        </div>\n      </div>\n\n\n    </main>\n\n    \n\n<footer>\n  <div class=\"_bg\"></div>\n  <div class=\"_rowTop _footerContents\">\n    <p>\n      <img src=\"/assets/images/common/logo_color_01.png\" alt=\"秋田東北ダイケン\">\n    </p>\n    <nav>\n      <ul>\n        <li><a href=\"/information/\"><span>お知らせ</span></a></li>\n        <li><a href=\"/elected/\"><span>選ばれる理由</span></a></li>\n        <li><a href=\"/works/\"><span>事業内容</span></a></li>\n        <li><a href=\"/aboutus/\"><span>私たちについて</span></a></li>\n        <!--<li><a href=\"/csr/\"><span>取り組み</span></a></li>-->\n        <li><a href=\"/group/\"><span>グループ会社</span></a></li>\n        <li><a href=\"/recruit/\"><span>採用情報</span></a></li>\n      </ul>\n    </nav>\n  </div>\n  <div class=\"_rowBottom _footerContents\">\n    <div>\n      <h2>秋田本社</h2>\n      <div>\n        <p>\n          〒010-0001<br />\n          秋田市中通2-2-32 山二ビル\n        </p>\n        <p>\n          TEL /018-832-0401<br />\n          FAX /018-832-8699\n        </p>\n      </div>\n    </div>\n\n    <div>\n      <h2>青森営業所</h2>\n      <div>\n        <p>\n          〒030-0861<br />\n          青森市長島2-25-1 太陽生命青森ビル\n        </p>\n        <p>\n          TEL /017-776-8553<br />\n          FAX /017-776-8557\n        </p>\n      </div>\n    </div>\n    <div>\n      <h2>大仙営業所</h2>\n      <div>\n        <p>\n          〒014-0047<br />\n          大仙市大曲須和町1-6-24\n        </p>\n        <p>\n          TEL /080-2845-7735\n        </p>\n      </div>\n    </div>\n\n\n  </div>\n\n  <div class=\"_footerLink _footerContents\">\n    <ul>\n      <li>\n        <a href=\"/download\">指定請求書様式ダウンロード</a>\n      </li>\n      <li>\n        <a href=\"/privacy\">プライバシーポリシー</a>\n      </li>\n    </ul>\n  </div>\n  <div class=\"_copyright _footerContents\">\n    <p>\n      (c) Copyright. Akita Tohoku Daiken, Ltd. All right reserved.\n    </p>\n  </div>\n</footer>\n  </div>\n\n\n  <script src=\"/assets/js/dist/vendor.min.js\"></script>\n  <script src=\"/assets/js/dist/all.min.js\"></script>\n  <script src=\"/assets/js/settings/setting.core.js\"></script>\n\n</body>\n</html>\n","finalUrl":"https://tohoku-daiken.co.jp/recruit/","rendered":false,"_cachedAt":"2026-06-17T23:29:38.612Z"}