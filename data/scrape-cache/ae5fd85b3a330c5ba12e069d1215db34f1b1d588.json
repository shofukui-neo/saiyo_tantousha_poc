{"url":"https://www.jfe-steel.co.jp/saiyou/company/outline.html","html":"<!DOCTYPE HTML>\n<html lang=\"ja\">\n<head>\n<!-- webtru tag -->\n<script src=\"https://cmp.datasign.co/v2/42a7e0c2b9/cmp.js\" async></script>\n\n<!-- Google Tag Manager -->\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n})(window,document,'script','dataLayer','GTM-P847MB');</script>\n<!-- End Google Tag Manager -->\n\n<meta charset=\"UTF-8\">\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n<meta name=\"format-detection\" content=\"telephone=no\">\n<meta name=\"viewport\" content=\"width=device-width\">\n<title>企業概要｜JFEスチール 新卒採用サイト</title>\n<link href=\"https://cdn.jsdelivr.net/npm/yakuhanjp@3.4.1/dist/css/yakuhanjp-noto.min.css\" rel=\"stylesheet\">\n<link href=\"../css/default.css\" rel=\"stylesheet\">\n<link href=\"../css/common.css\" rel=\"stylesheet\">\n<link href=\"../css/common-s.css\" rel=\"stylesheet\">\n<link href=\"../css/style/slick.css\" rel=\"stylesheet\">\n<link href=\"../css/style/company.css\" rel=\"stylesheet\">\n<link href=\"../css/style/company-s.css\" rel=\"stylesheet\">\n<script src=\"https://cdnjs.cloudflare.com/ajax/libs/gsap/3.8.0/gsap.min.js\"></script>\n<script src=\"https://cdnjs.cloudflare.com/ajax/libs/gsap/3.8.0/ScrollTrigger.min.js\"></script>\n<script src=\"https://ajax.googleapis.com/ajax/libs/jquery/1.12.4/jquery.min.js\"></script>\n<script src=\"https://cdnjs.cloudflare.com/ajax/libs/jquery-easing/1.4.1/jquery.easing.min.js\"></script>\n<script src=\"../script/jquery.inview.min.js\"></script>\n<script src=\"../script/slick.min.js\"></script>\n</head>\n<body class=\"company-outline\">\n\n<!-- Google Tag Manager (noscript) -->\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-P847MB\"\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n<!-- End Google Tag Manager (noscript) -->\n\n<!-- ヘッダー -->\n<header id=\"header\">\n  <div id=\"logo\">\n    <p><a href=\"../\"><img src=\"../image/common/logo.png\" srcset=\"../image/common/logo.png 1x, ../image/common/logo@2x.png 2x\" alt=\"JFEスチール\">RECRUITING <br class=\"sp\">SITE</a></p>\n  </div>\n  <nav id=\"megamenu\">\n    <ul id=\"gnavi\">\n      <li>\n        <p><a href=\"javascript:;\"><span class=\"line\">鉄の可能性を知る</span></a></p>\n        <div class=\"submenu\">\n          <ul>\n            <li><a href=\"../steel/future.html\"><div class=\"image\"><img src=\"../image/common/mmenu-01-01.jpg\" alt=\"鉄の可能性と未来の可能性\"></div><div class=\"cname\"><span>鉄の可能性と未来の可能性</span></div></a></li>\n            <li><a href=\"../steel/global.html\"><div class=\"image\"><img src=\"../image/common/mmenu-01-02.jpg\" alt=\"グローバルビジネスとしての鉄\"></div><div class=\"cname\"><span>グローバルビジネスとしての鉄</span></div></a></li>\n            <li><a href=\"../steel/attempt.html\"><div class=\"image\"><img src=\"../image/common/mmenu-01-03.jpg\" alt=\"JFEスチールの最新の取り組み\"></div><div class=\"cname\"><span>JFEスチールの最新の取り組み</span></div></a></li>\n            <li><a href=\"../steel/each-person.html\"><div class=\"image\"><img src=\"../image/common/mmenu-01-04.jpg\" alt=\"一人ひとりが考える鉄の可能性\"></div><div class=\"cname\"><span>一人ひとりが考える鉄の可能性</span></div></a></li>\n          </ul>\n        </div>\n      </li>\n      <li>\n        <p><a href=\"javascript:;\"><span class=\"line\">企業と事業を知る</span></a></p>\n        <div class=\"submenu\">\n          <ul>\n            <li><a href=\"../company/outline.html\"><div class=\"image\"><img src=\"../image/common/mmenu-02-01.jpg\" alt=\"企業概要\"></div><div class=\"cname\"><span>企業概要</span></div></a></li>\n            <li><a href=\"../company/office.html\"><div class=\"image\"><img src=\"../image/common/mmenu-02-02.jpg\" alt=\"写真で見るオフィス\"></div><div class=\"cname\"><span>写真で見るオフィス</span></div></a></li>\n            <li><a href=\"../company/onsite.html\"><div class=\"image\"><img src=\"../image/common/mmenu-02-03.jpg\" alt=\"鉄が生まれる現場〈製鉄所〉\"></div><div class=\"cname\"><span>鉄が生まれる現場〈製鉄所〉</span></div></a></li>\n          </ul>\n        </div>\n      </li>\n      <li>\n        <p><a href=\"javascript:;\"><span class=\"line\">職種と社員を知る</span></a></p>\n        <div class=\"submenu\">\n          <ul>\n            <li><a href=\"../job/\"><div class=\"image\"><img src=\"../image/common/mmenu-03-01.jpg\" alt=\"職種紹介\"></div><div class=\"cname\"><span>職種紹介</span></div></a></li>\n            <li><a href=\"../job/person-index.html\"><div class=\"image\"><img src=\"../image/common/mmenu-03-02.jpg\" alt=\"社員紹介 ｜ INDEX\"></div><div class=\"cname\"><span>社員紹介 ｜ INDEX</span></div></a></li>\n          </ul>\n        </div>\n      </li>\n      <li>\n        <p><a href=\"javascript:;\"><span class=\"line\">プロジェクトを知る</span></a></p>\n        <div class=\"submenu\">\n          <ul>\n            <li><a href=\"../project/jdscom.html\"><div class=\"image\"><img src=\"../image/common/mmenu-04-01.jpg\" alt=\"異常早期検知システムJ-dscom\"></div><div class=\"cname\"><span>異常早期検知システム</span><br><span>J-dscom&reg;</span></div></a></li>\n            <li><a href=\"../project/mexico.html\"><div class=\"image\"><img src=\"../image/common/mmenu-04-02.jpg\" alt=\"メキシコでの溶融亜鉛めっき鋼板製造設備建設\"></div><div class=\"cname\"><span>メキシコでの溶融亜鉛</span><br><span>めっき鋼板製造設備建設</span></div></a></li>\n            <li><a href=\"../project/7cc.html\"><div class=\"image\"><img src=\"../image/common/mmenu-04-03.jpg\" alt=\"第7スラブ連続鋳造機建設プロジェクト\"></div><div class=\"cname\"><span>第7スラブ連続鋳造機</span><br><span>建設プロジェクト</span></div></a></li>\n          </ul>\n        </div>\n      </li>\n      <li>\n        <p><a href=\"javascript:;\"><span class=\"line\">成長とキャリアを知る</span></a></p>\n        <div class=\"submenu\">\n          <ul>\n            <li><a href=\"../career/training.html\"><div class=\"image\"><img src=\"../image/common/mmenu-05