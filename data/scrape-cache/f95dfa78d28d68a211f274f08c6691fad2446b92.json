);\r\n\t console.log(\"nextPage：\"+nextPage);\r\n\r\n\t//画像の重なり順の初期表示\r\n\t//nextPageを先頭にするのは初回のインターバルで前面に来る画像なのでこれをfadeOutするため\r\n\t  $(\"#index_pic img\").css(\"z-index\",\"-3\");\r\n\t  $(\"#index_pic img\").eq(nextPage).css(\"z-index\",\"-1\");\r\n\r\n\t//ページ切換関数\r\n\tfunction changePage(){\r\n\t console.log(\"page：\"+page);\r\n\t console.log(\"nextPage：\"+nextPage);\r\n\t//まず全部最背面へ\r\n\t  $(\"#index_pic img\").css(\"z-index\",\"-3\");\r\n\t//pageを最前面へ\r\n\t  $(\"#index_pic img\").eq(page).css(\"z-index\",\"-1\");\r\n\t//nextPageを２番目へ\r\n\t  $(\"#index_pic img\").eq(nextPage).css(\"z-index\",\"-2\");\r\n\t//毎回全部display blockする\r\n\t  $(\"#index_pic img\").css(\"display\",\"block\");\r\n\t//最前面のpageをfadeOutすると２番目nextPageが見えてくる\r\n\t  $(\"#index_pic img\").eq(page).fadeOut(2500);\r\n\t};\r\n\r\n\t//カウントアップ関数\r\n\tfunction countUp(){\r\n\t  if(page === lastPage){\r\n\t\tpage = 0;\r\n\t\tnextPage = 1;\r\n\t\tchangePage();\r\n\t   }else if(nextPage===lastPage){\r\n\t\tpage ++;\r\n\t\tnextPage = 0;\r\n\t\tchangePage();\r\n\t   }else{\r\n\t\t page ++;\r\n\t\t nextPage = page+1;\r\n\t\t changePage();\r\n\t   } \r\n\t };\r\n\r\n\t//～秒間隔でイメージ切換の発火設定\r\n\tvar Timer;\r\n\tfunction startTimer(){\r\n\tTimer =setInterval(function(){\r\n\t\t\t  countUp();\r\n\t\t },8000);\r\n\t};\r\n\r\n\t//～秒間隔でイメージ切換の停止設定\r\n\tfunction stopTimer(){\r\n\tclearInterval(Timer);\r\n\t};\r\n\r\n\t//タイマースタート\r\n\tstartTimer();\r\n\r\n\t});\r\n\r\n\t//医療者確認ポップアップ\r\n\t//歯科材料：取扱製品\r\n\tfunction POP_dental(){\r\n\t\tif(confirm(\"貴方は歯科医療関係者ですか？ OK(YES)／キャンセル(NO)\")){window.open(\"prdct_dental/index.html\",\"_self\",\"\")}\r\n\t\telse{void(0);}\r\n\t}\r\n\t//歯科材料：パンフレット\r\n\tfunction POP_pamphlet(){\r\n\t\tif(confirm(\"貴方は歯科医療関係者ですか？ OK(YES)／キャンセル(NO)\")){window.open(\"technical_support/webrequest/pamphlet.html\",\"_self\",\"\")}\r\n\t\telse{void(0);}\r\n\t}\r\n\t//歯科材料：院内ツール\r\n\tfunction POP_tools(){\r\n\t\tif(confirm(\"貴方は歯科医療関係者ですか？ OK(YES)／キャンセル(NO)\")){window.open(\"technical_support/webrequest/to