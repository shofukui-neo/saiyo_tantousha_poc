i><a href=\"https://nissyo-net.co.jp/topics\">TOPICS</a></li>\n              </ul>\n            </li>\n          </ul>\n        </div>\n        <div class=\"nav-block --company\">\n          <div class=\"nav-block-heading\">グループ会社</div>\n          <ul>\n            <li>日商物産株式会社</li>\n            <li>株式会社日商龍磨</li>\n            <li>株式会社日商セントラル</li>\n            <li>\n              <a href=\"https://www.hutm.jp/index.php\" target=\"_blank\">ヒュートムグループ</a>\n            </li>\n            <li>\n              <a href=\"https://tokaisyaryo.co.jp/\" target=\"_blank\">株式会社東海車輌</a>\n            </li>\n          </ul>\n        </div>\n        <div class=\"nav-block --recruit\">\n          <a href=\"https://nissyo-net.co.jp/recruit/newgraduate\" class=\"nav-block-heading\">採用情報</a>\n        </div>\n      </div>\n    </div>\n    <div class=\"back-to-top\">\n      <a href=\"#\">\n        <span class=\"line\"></span>\n        <span class=\"text\">BACK TO<br />TOP</span>\n      </a>\n    </div>\n  </div>\n  <div class=\"footer-bottom\"><small>©2024 Nissyo Company, Ltd.</small></div>\n</footer>\n\n<script>\n\n// ハンバーガーメニュー\n$(document).ready(function() {\n  $('.drawer').drawer();\n});\n\n//ハンバーガーメニューのリストを押したらトグル（アコーディオン ）\n$(function () {\n  $(document).on(\"click\",\".toggle-on\",function(){\n    var locate = $(this).hasClass('change');\n    if ( locate ){\n      $(this).next('ul').slideUp();\n      $(this).removeClass('change');\n    } else {\n      $(this).next('ul').slideDown();\n      $(this).addClass('change');\n    }\n  });\n});\n\njQuery(function() {\n  let tabs = jQuery(\".tab\"); // tabのクラスを全て取得し、変数tabsに配列で定義\n  jQuery(\".tab\").on(\"click\", function() { // tabをクリックしたらイベント発火\n    jQuery(\".active\").removeClass(\"active\"); // activeクラスを消す\n    jQuery(this).addClass(\"active\"); // クリックした箇所にactiveクラスを追加\n    const index = tabs.index(this); // クリックした箇所がタブの何番目か判定し、定数indexとして定義\n    jQuery(\".content\").removeClass(\"show\").eq(index).addClass(\"show\"); // showクラスを消して、contentクラスのindex番目にshowクラスを追加\n  })\n})\n\n$(document).ready(function() {\n  $('.drawer').drawer();\n\n  var query = location.search;\n  var value = query.split('=');\n  let tabs = jQuery(\".tab\"); // tabのクラスを全て取得し、変数tabsに配列で定義\n\n  if (value[1] == 'office') {\n    let ele = $(\"#tab_office\");\n    jQuery(\".active\").removeClass(\"active\"); // activeクラスを消す\n    jQuery(\"#tab_office\").addClass(\"active\"); // クリックした箇所にactiveクラスを追加\n    const index = tabs.index(ele); // クリックした箇所がタブの何番目か判定し、定数indexとして定義\n    jQuery(\".content\").removeClass(\"show\").eq(index).addClass(\"show\"); // showクラスを消して、contentクラスのindex番目にshowクラスを追加\n  } else if (value[1] == 'logistics') {\n    let ele = $(\"#tab_logistics\");\n    jQuery(\".active\").removeClass(\"active\"); // activeクラスを消す\n    jQuery(\"#tab_logistics\").addClass(\"active\"); // クリックした箇所にactiveクラスを追加\n    const index = tabs.index(ele); // クリックした箇所がタブの何番目か判定し、定数indexとして定義\n    jQuery(\".content\").removeClass(\"show\").eq(index).addClass(\"show\"); // showクラスを消して、contentクラスのindex番目にshowクラスを追加\n  } else if (value[1] == 'shop') {\n    let ele = $(\"#tab_shop\");\n    jQuery(\".active\").removeClass(\"active\"); // activeクラスを消す\n    jQuery(\"#tab_shop\").addClass(\"active\"); // クリックした箇所にactiveクラスを追加\n    const index = tabs.index(ele); // クリックした箇所がタブの何番目か判定し、定数indexとして定義\n    jQuery(\".content\").removeClass(\"show\").eq(index).addClass(\"show\"); // showクラスを消して、contentクラスのindex番目にshowクラスを追加\n  } else if (value[1] == 'gasorin') {\n    let ele = $(\"#tab_gasorin\");\n    jQuery(\".active\").removeClass(\"active\"); // activeクラスを消す\n    jQuery(\"#tab_gasorin\").addClass(\"active\"); // クリックした箇所にactiveクラスを追加\n    const index = tabs.index(ele); // クリックした箇所がタブの何番目か判定し、定数indexとして定義\n    jQuery(\".content\").removeClass(\"show\").eq(index).addClass(\"show\"); // showクラスを消して、contentクラスのindex番目にshowクラスを追加\n  }\n});\n\n//100pxスクロールしたらtoTop表示\njQuery(window).on(\"scroll\", function($) {\n  if (jQuery(this).scrollTop() > 100) {\n    jQuery('.toTop').show();\n  } else {\n    jQuery('.toTop').hide();\n  }\n});\n\njQuery('.toTop').click(function () {\n  jQuery('body,html').animate({\n    scrollTop: 0\n  }, 500);\n  return false;\n});\n\n\n\n//スムーススクロール\njQuery('a[href^=\"#\"]').click(function() {\n  // .headerクラスがついた要素の高さを取得\n  let header = jQuery(\".header\").innerHeight();\n  let speed = 1000;\n  let id = jQuery(this).attr(\"href\");\n  let target = jQuery(\"#\" == id ? \"html\" : id);\n  // トップからの距離からヘッダー分の高さを引く\n  let position = jQuery(target).offset().top - header;\n  if (\"fixed\" !== jQuery(\".header\").css(\"position\")) {\n    position = jQuery(target).offset().top;\n  }\n  if (0 > position) {\n    position = 0;\n  }\n  jQuery(\"html, body\").animate({\n    scrollTop: position\n  },\n  speed\n);\nreturn false;\n});\n\n\n//拠点一覧toggle\njQuery('.map').on('click', function() {\n  jQuery(this).next().slideToggle();\n});\n\n//ページ遷移時にヘダー分下げる\n$(window).on('load', function() {\n  var url = $(location).attr('href');\n  if(url.indexOf(\"#\") != -1){\n    var anchor = url.split(\"#\");\n    var target = $('#' + anchor[anchor.length - 1]);\n    if(target.length){\n      var pos = Math.floor(target.offset().top) - 100;\n      $(\"html, body\").animate({scrollTop:pos}, 500);\n    }\n  }\n});\n</script>\n<!-- <script type=\"text/javascript\" src=\"https://nissyo-net.co.jp/wp/wp-content/themes/original-theme/js/common-dist.js\"></script> -->\n</body>\n</html>\n","finalUrl":"https://nissyo-net.co.jp/recruit/newgraduate/","rendered":false,"_cachedAt":"2026-06-22T21:29:55.263Z"}