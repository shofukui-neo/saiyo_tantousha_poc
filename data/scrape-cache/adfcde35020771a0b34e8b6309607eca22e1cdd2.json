" href=\"https://toshin-truck.com/wp-json/oembed/1.0/embed?url=https%3A%2F%2Ftoshin-truck.com%2Frecruit-list%2F%25e6%2597%25a5%25e5%258b%25a4%25e3%2581%25ae%25e3%2581%25bf%25ef%25bc%2581%25e3%2580%2580%25e4%25b8%25ad%25e5%259e%258b%25e3%2583%2588%25e3%2583%25a9%25e3%2583%2583%25e3%2582%25af%25e3%2581%25a7%25e3%2583%25ab%25e3%2583%25bc%25e3%2583%2588%25e9%2585%258d%25e9%2580%2581%25e3%2583%2589%25e3%2583%25a9%25e3%2582%25a4%25e3%2583%2590%2F\" />\n<link rel=\"alternate\" title=\"oEmbed (XML)\" type=\"text/xml+oembed\" href=\"https://toshin-truck.com/wp-json/oembed/1.0/embed?url=https%3A%2F%2Ftoshin-truck.com%2Frecruit-list%2F%25e6%2597%25a5%25e5%258b%25a4%25e3%2581%25ae%25e3%2581%25bf%25ef%25bc%2581%25e3%2580%2580%25e4%25b8%25ad%25e5%259e%258b%25e3%2583%2588%25e3%2583%25a9%25e3%2583%2583%25e3%2582%25af%25e3%2581%25a7%25e3%2583%25ab%25e3%2583%25bc%25e3%2583%2588%25e9%2585%258d%25e9%2580%2581%25e3%2583%2589%25e3%2583%25a9%25e3%2582%25a4%25e3%2583%2590%2F&#038;format=xml\" />\n\n<!-- Analytics -->\n<!-- Global site tag (gtag.js) - Google Analytics -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=UA-121862001-1\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'UA-121862001-1');\n</script>\n\n<!-- Global site tag (gtag.js) - Google Ads: 773888251 -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=AW-773888251\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'AW-773888251');\n</script>\n</head>\n\n<body id=\"body\">\n\n<header role=\"banner\" class=\"header\">\n\n<div class=\"copy\">\n<p>街から街へ、人から人へ、安全・確実・迅速に、心を込めて荷物をお届けする「藤伸」</p>\n</div>\n\n<div class=\"flexbox flex-justify-between flex-align-center\">\n<h1><a href=\"https://toshin-truck.com/\"><img src=\"https://toshin-truck.com/cont/wp-content/themes/toshin_theme/img/common/logo.png\" alt=\"TOSHIN 株式会社 藤伸\"></a></h1>\n<nav id=\"gnav\" class=\"gnav collapse\" role=\"navigation\"> \n<ul class=\"flexbox flex-justify-between\">\n  <li><a href=\"https://toshin-truck.com/service/\">藤伸のサービス</a></li>\n  <li><a href=\"https://toshin-truck.com/activities/\">藤伸の取り組み</a></li>\n  <li><a href=\"https://toshin-truck.com/recruit/\">採用情報</a></li>\n  <li><a href=\"https://toshin-truck.com/company/\">会社案内</a></li>\n  <li class=\"contact\"><a href=\"https://toshin-truck.com/contact/\">お問い合わせ</a></li>\n</ul>\n</nav>\n    <button type=\"button\" id=\"toggle\" class=\"toggle\" data-toggle=\"collapse\" data-target=\"#gnav\" aria-controls=\"gnav\" aria-expanded=\"false\">\n      <span class=\"toggle__bar\"></span>\n      <span class=\"toggle__title\"></span>\n    </button>\n</div>\n</header>\n\n\n<main role=\"main\" class=\"main\">\n\n<section class=\"under-visual-a entry\">\n<h2><span class=\"recruit-list-ttl\">RECRUIT</span>募集要項</h2>\n</section>\n\n<div class=\"breadcrumbs\">\n  <div class=\"container\">\n    <ol typeof=\"BreadcrumbList\" vocab=\"http://schema.org/\">\n      <!-- Breadcrumb NavXT 5.7.1 -->\n<li class=\"home\"><span property=\"itemListElement\" typeof=\"ListItem\"><a property=\"item\" typeof=\"WebPage\" title=\"\" href=\"https://toshin-truck.com/\" class=\"home\"><span property=\"name\">TOP</span></a><meta property=\"position\" content=\"1\"></span></li>\n\n<li><span property=\"itemListElement\" typeof=\"ListItem\"><a property=\"item\" typeof=\"WebPage\" title=\"\" href=\"https://toshin-truck.com/recruit/\" class=\"home\"><span property=\"name\">採用情報</span></a><meta property=\"position\" content=\"2\"></span></li>\n\n<li class=\"current_item\"><span property=\"itemListElement\" typeof=\"ListItem\"><span property=\"name\">日勤のみ！　中型トラックでルート配送ドライバー</span><meta property=\"position\" content=\"3\"></span></li>\n\n    </ol>\n  </div>\n</div>\n\n<section class=\"recruit-list recruit04\">\n<div class=\"container\">\n  <h3 class=\"heading-a\">日勤のみ！　中型トラックでルート配送ドライバー</h3>\n\n      <table>\n\n                  <tr>\n            <th>雇用形態</th>\n            <td>正社員</td>\n          </tr>\n        \n                  <tr>\n            <th>就業形態</th>\n            <td>★働きやすいワークライフバランス<br />\r\n…8:00～17:30/土日休み<br />\r\n<br />\r\n★未経験者・女性活躍中！<br />\r\n…6割以上がドライバー経験なし<br />\r\n　入社後1ヵ月は同乗研修あり<br />\r\n<br />\r\n★配送先は広島県内がメイン！<br />\r\n…荷物はすでに、かご台車に準備済みなので<br />\r\n　手積み・手下ろしはありません。<br />\r\n<br />\r\n★職場見学受付中<br />\r\n…快適な勤務環境を追求しています。<br />\r\n　職場の雰囲気を見てみたい方は<br />\r\n　お気軽にお問い合わせください。</td>\n          </tr>\n        \n                  <tr>\n            <th>仕事の内容</th>\n            <td>3tトラックで介護用品(車いすや介護ベッド)などを<br />\r\n配送するルートドライバーのお仕事です。<br />\r\n<br />\r\n廿日市のセンター(会社からすぐ)から介護用品取り扱い会社に配送していただきます。<br />\r\n1日1～3件、広島県内が中心です。<br />\r\n<br />\r\n荷物はあらかじめかご台車に準備されているので手積み・手下ろしはありません。<br />\r\n力仕事はないので女性も活躍しています。<br />\r\n<br />\r\n入社後1ヵ月程度は先輩が同乗してしっかり指導します。<br />\r\n配送ルートや運転技術、商品・製品の扱い方まで研修を通して学べますので未経験の方もご安心ください。<br />\r\n<br />\r\nトラックは1人1台★<br />\r\n専用のトラックをご用意！<br />\r\nあなたが仕事しやすいように車内をカスタマイズしてもOK！<br />\r\n<br />\r\n準中型免許が必要になりますが、MTへの免許切り換え費用は一部会社が負担いたします。</td>\n          </tr>\n        \n                  <tr>\n            <th>給与</th>\n            <td>月給27万2178円～<br />\r\n※年齢・経験などを考慮した優遇制度あり<br />\r\n<br />\r\n手当<br />\r\n残業手当　他<br />\r\n<br />\r\n昇給あり(随時)<br />\r\n賞与あり(年2回)<br />\r\n<br />\r\n研修期間1ヶ月は20万1388円<br />\r\n<br />\r\nその他待遇<br />\r\n車通勤可<br />\r\nバイク通勤可<br />\r\n自転車通勤可<br />\r\n<br />\r\n無事故無違反表彰制度<br />\r\n社内懇親会あり<br />\r\n<br />\r\n資格取得支援制度あり<br />\r\n研修制度充実<br />\r\n<br />\r\n制服貸与<br />\r\nマスク支給あり<br />\r\n携帯用アルコール消毒貸出あり<br />\r\n<br />\r\n転勤なし<br />\r\n<br />\r\n休憩スペースやお昼を食べる場所あり<br />\r\n仮眠室・シャワールーム等完備<br />\r\n<br />\r\n受動喫煙対策あり(喫煙室完備)<br />\r\n<br />\r\n職場見学OK</td>\n          </tr>\n        \n                  <tr>\n            <th>勤務時間</th>\n            <td>8:00～17:30(休憩あり)<br />\r\n<br />\r\n平均所定労働時間(1ヶ月当たり)：160時間</td>\n          </tr>\n        \n                  <tr>\n            <th>勤務地</th>\n            <td>広島県広島市佐伯区五日市港4丁目2-1<br />\r\n<br />\r\n最寄駅<br />\r\nJR山陽本線/五日市駅<br />\r\nJR山陽本線/廿日市駅<br />\r\n広電２号線/広電廿日市駅<br />\r\n広電２号線/山陽女学園前駅<br />\r\n広電２号線/楽々園駅</td>\n          </tr>\n        \n                  <tr>\n            <th>休日</th>\n            <td>週休2日制<br />\r\n※土日休み<br />\r\n<br />\r\n産休、育休、慶弔休暇、連続休暇あり<br />\r\n(お盆、年末年始)<br />\r\n有給休暇も取得しやすい環境です</td>\n          </tr>\n        \n                  <tr>\n            <th>必要な経験等</th>\n            <td>準中型免許 必須(AT限定可)<br />\r\n※MTへの免許切り換え<br />\r\n　費用は一部会社負担<br />\r\n<br />\r\n未経験者歓迎<br />\r\n職務経験不問<br />\r\n経験者歓迎<br />\r\n経験者優遇<br />\r\n学歴不問<br />\r\n年齢不問<br />\r\n異業種からの転職歓迎<br />\r\n既卒・第二新卒歓迎<br />\r\nU・Iターン歓迎<br />\r\nブランクOK<br />\r\nハローワークでお仕事を<br />\r\nお探しの方も歓迎<br />\r\n<br />\r\n☆以下のような方も大歓迎です！<br />\r\n・運転が好きな方<br />\r\n・プライベートを充実させたい方<br />\r\n・1人時間が好きな方</td>\n          </tr>\n        \n\n                  <tr>\n            <th>加入保険</th>\n            <td>各種社会保険完備<br />\r\n※健康保険/厚生年金/雇用保険/労災保険</td>\n          </tr>\n        \n                  <tr>\n            <th>定年</th>\n            <td>60歳<br />\r\n※再雇用制度あり</td>\n          </tr>\n        \n        \n        \n                  <tr>\n            <th>選考日時</th>\n            <td>ご応募の際は下記のエントリーボタン、もしくはお電話にてご応募ください！<br />\r\n<br />\r\nご不明点やご質問、職場見学等も受け付けておりますのでまずは見学だけでもお気軽にご連絡ください！<br />\r\n<br />\r\n担当者名 : 高杦(タカスギ)<br />\r\n電話番号 : 082-943-8100</td>\n          </tr>\n        \n                  <tr>\n            <th>備考</th>\n            <td>当社は創業40年以上にわたり、山陽エリアを中心にあらゆる業種の配送業務に対応しています。<br />\r\n<br />\r\n本社・広島営業所をはじめ、尾道、岡山、山口に営業所を展開、社員数は約250名の安定企業です。<br />\r\n<br />\r\n従業員の安全維持のために、交通事故や労働災害防止の取り組みを行っています。<br />\r\n<br />\r\n安全運転を支援する機器の導入、健康診断の確実な実施、運輸安全マネジメント会議の実施など、安全に安心して就業できる職場作りに取り組んでいます。<br />\r\n<br />\r\n現在、20代・30代・40代・50代の若手・中高年・ミドル世代の幅広い年代が活躍しています。<br />\r\n<br />\r\n［こんな仕事に興味のある方］<br />\r\nトラック運転手<br />\r\nルート配送ドライバー<br />\r\nルートドライバー<br />\r\n納品ドライバー<br />\r\n軽貨物ドライバー<br />\r\n中型ドライバー<br />\r\n配送ドライバー<br />\r\n配達ドライバー<br />\r\n近距離ドライバー<br />\r\n中距離ドライバー<br />\r\n運送業</td>\n          </tr>\n        \n    </table>\n\n    <p align=\"center\" class=\"mt-60\"><a href=\"https://toshin-truck.com/recruit/#guidelines\" class=\"btn-a\">募集要項一覧に戻る</a></p>\n\n</div>\n</section>\n\n<section class=\"recruit05\">\n<div class=\"container\">\n\n    <div class=\"entry\">\n        <h2>採用エントリーはこちら</h2>\n        <a href=\"https://toshin-truck.com/entry\" class=\"btn-b\">エントリーフォーム</a>\n    </div>\n\n</div>\n</section>\n\n\n</main>\n\n<footer class=\"footer\">\n\n<div class=\"footer-company container\">\n<h1><a href=\"https://toshin-truck.com/\"><img src=\"https://toshin-truck.com/cont/wp-content/themes/toshin_theme/img/common/f_logo.png\" alt=\"TOSHIN 株式会社 藤伸\"></a></h1>\n<div class=\"add\">\n<p>広島県広島市佐伯区五日市港4丁目2-1</p>\n<p>TEL:<a href=\"tel:0829438100\">082-943-8100</a> / FAX:082-943-7800</p>\n</div>\n</div>\n\n<div class=\"sub-nav container\">\n<ul>\n<li><a href=\"https://toshin-truck.com/\">トップページ</a></li>\n</ul>\n<ul>\n<li><a href=\"https://toshin-truck.com/service/\">藤伸のサービス</a></li>\n<li class=\"under\"><a href=\"https://toshin-truck.com/service/transport/\">輸送事業</a></li>\n<li class=\"under\"><a href=\"https://toshin-truck.com/service/warehouse/\">保管事業</a></li>\n</ul>\n<ul>\n<li><a href=\"https://toshin-truck.com/activities/\">藤伸の取り組み</a></li>\n<li class=\"under\"><a href=\"https://toshin-truck.com/activities/safety/\">安全について</a></li>\n<li class=\"under\"><a href=\"https://toshin-truck.com/activities/environment/\">品質と環境</a></li>\n</ul>\n<ul>\n<li><a href=\"https://toshin-truck.com/recruit/\">採用情報</a></li>\n<li class=\"under\"><a href=\"https://toshin-truck.com/recruit/interview/\">インタビュー</a></li>\n\n<li class=\"under\"><a href=\"https://toshin-truck.com/recruit/entry/\">エントリー</a></li>\n</ul>\n<ul>\n<li><a href=\"https://toshin-truck.com/company/\">会社案内</a></li>\n<li class=\"under\"><a href=\"https://toshin-truck.com/company/greeting/\">ごあいさつ</a></li>\n<li class=\"under\"><a href=\"https://toshin-truck.com/company/management/\">経営方針</a></li>\n<li class=\"under\"><a href=\"https://toshin-truck.com/company/overview/\">会社概要・沿革</a></li>\n</ul>\n<ul>\n<li><a href=\"https://toshin-truck.com/contact/\">お問い合わせ</a></li>\n<li><a href=\"https://toshin-truck.com/news/\">新着情報</a></li>\n<li><a href=\"https://toshin-truck.com/privacy/\">個人情報保護方針</a></li>\n</ul>\n</div>\n\n<div class=\"footer-bottom-wrap\">\n<div class=\"footer-bottom container\">\n<a id=\"pageTop\"><span><img src=\"https://toshin-truck.com/cont/wp-content/themes/toshin_theme/img/common/ar_c.png\"></span>TOP</a>\n<small>Copyright © Toshin Corp. All right reserverd.</small>\n</div>\n</div>\n\n\n\n\n</footer>\n\n<script src=\"https://ajax.googleapis.com/ajax/libs/jquery/1.9.1/jquery.min.js\"></script>\n<script src=\"https://toshin-truck.com/cont/wp-content/themes/toshin_theme/js/libs/bootstrap.min.js\"></script>\n<script src=\"https://toshin-truck.com/cont/wp-content/themes/toshin_theme/js/libs/slick.min.js\"></script>\n<script src=\"https://toshin-truck.com/cont/wp-content/themes/toshin_theme/js/box-slider-all.jquery.min.js\"></script>\n<script src=\"https://toshin-truck.com/cont/wp-content/themes/toshin_theme/js/app.js\"></script>\n<script>\n(function($){\n  // scripts\n})(jQuery);\n</script>\n</body>\n</html>\n","finalUrl":"https://toshin-truck.com/recruit-list/%e6%97%a5%e5%8b%a4%e3%81%ae%e3%81%bf%ef%bc%81%e3%80%80%e4%b8%ad%e5%9e%8b%e3%83%88%e3%83%a9%e3%83%83%e3%82%af%e3%81%a7%e3%83%ab%e3%83%bc%e3%83%88%e9%85%8d%e9%80%81%e3%83%89%e3%83%a9%e3%82%a4%e3%83%90/","rendered":false,"_cachedAt":"2026-06-22T20:36:10.358Z"}