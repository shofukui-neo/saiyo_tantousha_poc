{"url":"http://www.r-ehm.co.jp/recruit/interview/interview02/","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n\n<head>\n  <meta charset=\"utf-8\">\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n  <title>【管理部】 田中 延明-トヨタレンタリース西四国</title>\n  <meta name=\"description\" content=\"よいクルマ、よいサービス。愛媛県と高知県のレンタカー予約はトヨタレンタリース西四国へ！\">\n  <meta name=\"title\" content=\"【管理部】 田中 延明-トヨタレンタリース西四国\">\n  <meta content=\"IE=edge\" http-equiv=\"X-UA-Compatible\">\n  <meta name=\"format-detection\" content=\"telephone=no,address=no,email=no\">\n  <!-- seo -->\n  <meta property=\"og:title\" content=\"【管理部】 田中 延明-トヨタレンタリース西四国\" />\n  <meta property=\"og:type\" content=\"website\" />\n  <meta property=\"og:url\" content=\"https://www.r-ehm.co.jp/recruit/interview/interview02/\" />\n  <meta property=\"og:image\" content=\"https://www.r-ehm.co.jp/assets/img/ogp.jpg\" />\n  <meta property=\"og:site_name\" content=\"【管理部】 田中 延明-トヨタレンタリース西四国\" />\n  <meta property=\"og:description\" content=\"よいクルマ、よいサービス。愛媛県と高知県のレンタカー予約はトヨタレンタリース西四国へ！\" />\n  <meta name=\"twitter:card\" content=\"summary\" />\n  <meta name=\"twitter:title\" content=\"【管理部】 田中 延明-トヨタレンタリース西四国\" />\n  <meta name=\"twitter:description\" content=\"よいクルマ、よいサービス。愛媛県と高知県のレンタカー予約はトヨタレンタリース西四国へ！\" />\n  <meta name=\"twitter:image\" content=\"https://www.r-ehm.co.jp/assets/img/ogp.jpg\" />\n\n  <!-- faviconの指定 -->\n  <link rel=\"icon\" type=\"img/x-icon\" href=\"/assets/img/favicon.ico\">\n  <link rel=\"icon\" href=\"/assets/img/favicon.ico\">\n  <link rel=\"shortcut icon\" type=\"img/vnd.microsoft.icon\" href=\"/assets/img/favicon.ico\">\n  <link rel=\"icon\" type=\"img/vnd.microsoft.icon\" href=\"/assets/img/favicon.ico\">\n  <link rel=\"apple-touch-icon\" href=\"/apple-touch-icon.png\" sizes=\"180x180\">\n  <link rel=\"apple-touch-icon-precomposed\" href=\"/apple-touch-icon.png\" sizes=\"180x180\">\n  <link rel=\"stylesheet\" href=\"https://unpkg.com/swiper/swiper-bundle.min.css\">\n  <link rel=\"stylesheet\" href=\"/assets/css/scss/pages/common.css\">\n  <link rel=\"stylesheet\" href=\"/assets/css/scss/pages/detail.css\">\n</head>\n\n<body>\n  <div class=\"wrap\">\n    <div class=\"l-content\">\n      <!-- l-header -->\n      <header class=\"l-header js-header\">\n        <div class=\"l-header-logo\">\n          <h1 class=\"l-header-logo__ttl\">\n            <a class=\"-link\" href=\"/\">\n              <img src=\"/assets/img/common/logo.svg\" alt=\"TOYOTA Rent a Car\">\n            </a>\n          </h1>\n        </div>\n        <div id=\"js-drawermenu\" class=\"l-header-area\">\n          <ul class=\"l-header-area__list\">\n            <li class=\"l-header-area__list-item\"><a class=\"-link\" href=\"/\">ホーム</a></li>\n            <li class=\"l-header-area__list-item\"><a class=\"-link\" href=\"/company/\">会社概要</a></li>\n            <div class=\"l-header-area__list-item l-header-area__list-item--linkaccd\">\n              <a class=\"-link\" href=\"/recruit/\">採用情報</a>\n              <span class=\"l-header-area__list-item--linkaccd-btn js-accd\"></span>\n              <ul class=\"l-header-area__list-ul\" style=\"display:none;\">\n                <li class=\"l-header-area__list-section l-header-area__list-section--mt\"><a href=\"/recruit/interview/\">-\n                    社員インタビュー</a></li>\n                <li class=\"l-header-area__list-section\"><a href=\"/recruit/data/\">- 数字で見る</a></li>\n                <li class=\"l-header-area__list-section\"><a href=\"/recruit/training/\">- 研修制度</a></li>\n                <li class=\"l-header-area__list-section\"><a href=\"/recruit/faq/\">- よくあるご質問</a></li>\n                <li class=\"l-header-area__list-section\"><a href=\"/recruit/description/\">- 募集要項</a></li>\n              </ul>\n            </div>\n          </ul>\n          <div class=\"l-header-area__targetbox\">\n            <div class=\"l-header-area__shop\">\n              <a href=\"/shop/\"><span class=\"-icon\">店舗を探す</span></a>\n            </div>\n            <div class=\"l-header-area__info\">\n              <a href=\"https://rent.toyota.co.jp/static/guide/\" target=\"_blank\"><span class=\"-icon\">ご利用案内</span></a>\n            </div>\n            <div class=\"l-header-area__reservation\">\n              <a href=\"https://rent.toyota.co.jp/\" target=\"_blank\"><span class=\"-icon\">インターネット予約</span></a>\n            </div>\n          </div>\n        </div>\n        <div id=\"js-btnTrigger\" class=\"js-navbtn l-header-humbtn\">\n          <span class=\"l-header-humbtn__line\">\n            <!--btn-->\n          </span>\n          <span class=\"l-header-humbtn__line\">\n            <!--btn-->\n          </span>\n        </div>\n      </header>\n      <!-- l-snsbox -->\n      <div class=\"l-snsbox\">\n        <div class=\"l-snsbox-block l-snsbox-block--01\">\n          <a href=\"/recruit/\">\n            <p class=\"-txt\">採用情報</p>\n          </a>\n        </div>\n        <div class=\"l-snsbox-block l-snsbox-block--02\">\n          <a href=\"https://www.instagram.com/toyota_nishishikoku/\" target=\"_blank\">\n            <p class=\"-txt\">インスタグラム</p>\n          </a>\n        </div>\n      </div>\n      <div class=\"l-content-main\">\n        <section class=\"c-submv\">\n          <div class=\"c-submv-bg\"></div>\n          <div class=\"inner c-submv--inner\">\n            <div class=\"c-submv-img c-submv-img--interview02\">\n              <div class=\"c-submv-img__txtbox\">\n                <p class=\"-ttl\">interview #02</p>\n                <p class=\"-txt\">車好きが導いたこの会社との縁</p>\n                <p class=\"-info\">管理部 / 2008年入社</p>\n              </div>\n            </div>\n            <div class=\"c-submv-area flex is-between\">\n              <h1 class=\"-ttl\">【管理部】 田中 延明</h1>\n              <div class=\"-breadcrumbs\">\n                <ul class=\"flex\">\n                  <li><a href=\"/\">トップ</a></li>\n                  <li><a href=\"/recruit/\">採用情報</a></li>\n                  <li><a href=\"/recruit/interview/\">インタビュー一覧</a></li>\n                  <li>田中 延明</li>\n                </ul>\n              </div>\n            </div>\n          </div>\n        </section>\n\n        <!-- p-detail-block -->\n        <section class=\"p-detail-block\">\n          <p class=\"p-detail-block__bgttl\">Question 01</p>\n          <div class=\"inner p-detail-block--inner\">\n            <div class=\"p-detail-block__area flex js-anime\">\n              <div class=\"p-detail-block__area-img\">\n                <picture>\n                  <source srcset=\"/assets/img/detail/detail02-01-sp.jpg\" media=\"(max-width: 768px)\">\n                  <img src=\"/assets/img/detail/detail02-01-pc.jpg\">\n                </picture>\n              </div>\n              <div class=\"p-detail-block__area-txtbox\">\n                <div class=\"-group\">\n                  <p class=\"-group-en\">Q1-Reason for Joining</p>\n                  <h2 class=\"-group-question\">入社の決め手は何でしたか？</h2>\n                  <p class=\"-group-answer\">車好きが導いたこの会社との縁</p>\n                </div>\n                <p class=\"-txt\">\n                  もともと別の業界にいましたが、車が好きで車関係の仕事を探していました。2008年、トヨタレンタリース四国でリース営業の募集があり縁があって入社しました。父が長年トヨタ車を使っていたこともあり、トヨタに関わる仕事をしたいという思いが叶ったタイミングでの挑戦でした。\n                </p>\n              </div>\n            </div>\n          </div>\n        </section>\n\n        <!-- p-detail-block -->\n        <section class=\"p-detail-block p-detail-block--pattern02\">\n          <p class=\"p-detail-block__bgttl\">Question 02</p>\n          <div class=\"inner p-detail-block--inner\">\n            <div class=\"p-detail-block__area flex js-anime\">\n              <div class=\"p-detail-block__area-img\">\n                <picture>\n                  <source srcset=\"/assets/img/detail/detail02-02-sp.jpg\" media=\"(max-width: 768px)\">\n                  <img src=\"/assets/img/detail/detail02-02-pc.jpg\">\n                </picture>\n              </div>\n              <div class=\"p-detail-block__area-txtbox\">\n                <div class=\"-group\">\n                  <p class=\"-group-en\">Q2-Job description</p>\n                  <h2 class=\"-group-question\">現在の仕事内容と、仕事に対する姿勢について教えてください。</h2>\n                  <p class=\"-group-answer\">財務管理とシステムによって<br>お客様とスタッフの笑顔になれる環境づくりを</p>\n                </div>\n                <p class=\"-txt\">\n                  私は管理部で主に財務を担当しています。加えてシステム担当として、基幹システムの保守や新規導入にも携わっています。経理・総務と連携しながら、社内の仕組みを整えることで、業務がスムーズに回るよう支えるのが私の役割で、会社全体が円滑に動くようにすることにやりがいを感じています。<br>仕事に対する姿勢に関して、私はスタッフの笑顔を大切にしています。忙しさや大変さで気持ちが下がらないよう、システムを活用して負担を軽減したり、楽しいことを考えたりしながら、会社全体がより良くなることを目指しています。みんなで考え、共有し、実行できる環境をつくることを心がけています。\n                </p>\n              </div>\n            </div>\n          </div>\n        </section>\n\n        <!-- p-detail-layout -->\n        <section class=\"p-detail-layout js-anime\">\n          <div class=\"p-detail-layout__img\">\n            <picture>\n              <source srcset=\"/assets/img/detail/detail02-03-sp.jpg\" media=\"(max-width: 768px)\">\n              <img src=\"/assets/img/detail/detail02-03-pc.jpg\">\n            </picture>\n          </div>\n          <div class=\"p-detail-layout__bgttl\">Question 03</div>\n          <div class=\"inner\">\n            <div class=\"p-detail-layout__txtbox\">\n              <div class=\"-group\">\n                <p class=\"-group-en\">Q3-Why This Company</p>\n                <h2 class=\"-group-question\">会社に感じる魅力を聞かせてください。</h2>\n                <p class=\"-group-answer\">挑戦を後押ししてくれる社風</p>\n              </div>\n              <p class=\"-txt\">\n                やりたいことや改善案を口にすれば、すぐに挑戦させてもらえる環境です。失敗しても学びになるからやってみなさい、と後押ししてくれる風土があり、無駄な否定や制限はありません。自由に考え、実行できる安心感とチャレンジを支えてくれる会社の姿勢が大きな魅力です。\n              </p>\n            </div>\n          </div>\n        </section>\n\n        <!-- p-detail-block -->\n        <section class=\"p-detail-block p-detail-block--pattern03\">\n          <p class=\"p-detail-block__bgttl\">Question 04</p>\n          <div class=\"inner p-detail-block--inner\">\n            <div class=\"p-detail-block__area flex js-anime\">\n              <div class=\"p-detail-block__area-img\">\n                <picture>\n                  <source srcset=\"/assets/img/detail/detail02-04-sp.jpg\" media=\"(max-width: 768px)\">\n                  <img src=\"/assets/img/detail/detail02-04-pc.jpg\">\n                </picture>\n              </div>\n              <div class=\"p-detail-block__area-txtbox\">\n                <div class=\"-group\">\n                  <p class=\"-group-en\">Q4-Future Goals</p>\n                  <h2 class=\"-group-question\">これからチャレンジしたいことや、<br class=\"pc\">将来の目標は？</h2>\n                  <p class=\"-group-answer\">社員も会社も成長する未来へ</p>\n                </div>\n                <p class=\"-txt\">\n                  会社がもっと多くの人から選ばれる存在になることが目標です。システムや売上、利益を向上させ、社員の給与を上げ、魅力的な職場にすることで、「ここで働きたい」「この会社に入りたい」と思う方を増やしていきたいと考えています。将来に向けた価値を創る仕事をしていきます。\n                </p>\n              </div>\n            </div>\n          </div>\n        </section>\n\n        <!-- p-detail-btn -->\n        <div class=\"p-detail-btn\">\n          <div class=\"c-btn01 p-detail-btn--btn\">\n            <a href=\"/recruit/interview/\">\n              <p class=\"-txt\">社員インタビュー一覧</p>\n            </a>\n          </div>\n        </div>\n\n\n\n        <!-- c-recruit-layout -->\n        <section class=\"c-recruit-layout\">\n          <div class=\"inner c-recruit-layout--inner\">\n            <div class=\"c-recruit-layout__area flex\">\n              <div class=\"c-recruit-layout__area-left\">\n                <div class=\"c-ttl02box c-recruit-layout__area-left--ttl\">\n                  <h2 class=\"c-ttl02 js-anime\">recruit<span class=\"-jp\">採用情報</span></h2>\n                </div>\n                <p class=\"-catch\">地域と共に、人も育つ。<br>トヨタレンタリース西四国の<br><span class=\"-color\">未来</sapn>を一緒に。</p>\n                <p class=\"c-recruit-layout-txt\">\n                  愛媛・高知のあたたかさそのままに、職場も明るく居心地の良い環境が自慢です。役職や年齢に関係なく、意見を出し合い、助け合える関係性が根づいています。<br>地域の方々に寄り添いながら、自分らしくのびのびと働ける職場で、一緒に成長していきませんか？\n                </p>\n                <div class=\"c-btn01 c-recruit-layout--btn\">\n                  <a href=\"/recruit/\">\n                    <p class=\"-txt\">採用情報を見る</p>\n                  </a>\n                </div>\n              </div>\n              <div class=\"c-recruit-layout__area-right\">\n                <div class=\"-bgicon\">\n                  <img src=\"/assets/img/top/recruit-bg.png\">\n                </div>\n                <div class=\"-imgbox01 js-anime\">\n                  <div class=\"-in js-pararax\">\n                    <img src=\"/assets/img/top/recruit-img01.jpg\">\n                  </div>\n                </div>\n                <div class=\"-imgbox02 js-anime\">\n                  <div class=\"-in js-pararax\">\n                    <img src=\"/assets/img/top/recruit-img02.jpg\">\n                  </div>\n                </div>\n                <div class=\"-imgbox03 js-anime\">\n                  <div class=\"-in js-pararax\">\n                    <img src=\"/assets/img/top/recruit-img03.jpg\">\n                  </div>\n                </div>\n              </div>\n            </div>\n          </div>\n          <p class=\"c-recruit-layout__icon js-anime\">\n            <img src=\"/assets/img/top/recruitsec-icon.png\">\n          </p>\n        </section>\n        <div class=\"c-link-area\">\n          <div class=\"inner c-link-area--inner\">\n            <div class=\"c-link-area__block flex\">\n              <!-- c-link-area__block-item -->\n              <div class=\"c-link-area__block-item\">\n                <a class=\"-link\" href=\"/company/\">\n                  <div class=\"-img -img01\"></div>\n                  <div class=\"-txtbox\">\n                    <h3 class=\"-ttl\"><span class=\"-en\">Company</span>会社概要</h3>\n                  </div>\n                  <div class=\"-arrow\"></div>\n                </a>\n              </div>\n              <!-- c-link-area__block-item -->\n              <div class=\"c-link-area__block-item\">\n                <a class=\"-link\" href=\"/recruit/\">\n                  <div class=\"-img -img02\"></div>\n                  <div class=\"-txtbox\">\n                    <h3 class=\"-ttl\"><span class=\"-en\">Recruit</span>採用情報</h3>\n                  </div>\n                  <div class=\"-arrow\"></div>\n                </a>\n              </div>\n              <!-- c-link-area__block-item -->\n              <div class=\"c-link-area__block-item\">\n                <a class=\"-link\" href=\"/recruit/data/\">\n                  <div class=\"-img -img03\"></div>\n                  <div class=\"-txtbox\">\n                    <h3 class=\"-ttl\"><span class=\"-en\">Date</span>数字で見る</h3>\n                  </div>\n                  <div class=\"-arrow\"></div>\n                </a>\n              </div>\n              <!-- c-link-area__block-item -->\n              <div class=\"c-link-area__block-item\">\n                <a class=\"-link\" href=\"/recruit/interview/\">\n                  <div class=\"-img -img04\"></div>\n                  <div class=\"-txtbox\">\n                    <h3 class=\"-ttl\"><span class=\"-en\">Interview</span>社員インタビュー一覧</h3>\n                  </div>\n                  <div class=\"-arrow\"></div>\n                </a>\n              </div>\n              <!-- c-link-area__block-item -->\n              <div class=\"c-link-area__block-item\">\n                <a class=\"-link\" href=\"/recruit/training/\">\n                  <div class=\"-img -img05\"></div>\n                  <div class=\"-txtbox\">\n                    <h3 class=\"-ttl\"><span class=\"-en\">Training</span>研修制度</h3>\n                  </div>\n                  <div class=\"-arrow\"></div>\n                </a>\n              </div>\n\n            </div>\n          </div>\n        </div>\n        <!-- l-footer -->\n        <footer class=\"l-footer\">\n          <div class=\"l-footer-area\">\n            <div class=\"l-footer-area__pagetop\">\n              <a href=\"#\">\n                <p class=\"l-footer-area__pagetop-txt\">page top</p>\n              </a>\n            </div>\n            <div class=\"l-footer-area__block inner\">\n              <div class=\"l-footer-area__block-top flex is-between\">\n                <div class=\"-left flex\">\n                  <div class=\"-logo\">\n                    <a href=\"/\">\n                      <img src=\"/assets/img/common/f-logo.svg\">\n                    </a>\n                  </div>\n                  <p class=\"-access\">株式会社トヨタレンタリース西四国<br>〒791-8042 松山市南吉田町2750-12</p>\n                </div>\n                <div class=\"-insta\">\n                  <a href=\"https://www.instagram.com/toyota_nishishikoku/\" target=\"_blank\"><img\n                      src=\"/assets/img/common/insta-icon-wh.svg\"></a>\n                </div>\n              </div>\n              <div class=\"l-footer-area__block-list\">\n                <ul class=\"flex\">\n                  <li><a href=\"/csr/\">CSR基本方針</a></li>\n                  <li><a href=\"/pp/\">プライバシーポリシー</a></li>\n                  <li><a href=\"/solicitation/\">勧誘方針</a></li>\n                  <li><a href=\"/antisocial/\">暴力団等反社会的勢力排除宣言</a></li>\n                  <li><a href=\"/company/\">会社概要</a></li>\n                </ul>\n              </div>\n              <div class=\"l-footer-area__block-shop flex\">\n                <p class=\"-ttl\">店舗を探す</p>\n                <ul class=\"flex\">\n                  <li><a href=\"/shop/matsuyama.html\">松山店</a></li>\n                  <li><a href=\"/shop/matsuyama-port.html\">松山観光港店</a></li>\n                  <li><a href=\"/shop/matsuyama-ap.html\">松山空港店</a></li>\n                  <li><a href=\"/shop/imabari.html\">今治店</a></li>\n                  <li><a href=\"/shop/saijo-st.html\">JR伊予西条駅店</a></li>\n                  <li><a href=\"/shop/niihama-st.html\">新居浜駅前店</a></li>\n                  <li><a href=\"/shop/iyomishima-st.html\">JR伊予三島駅店</a></li>\n                  <li><a href=\"/shop/yawatahama-st.html\">JR八幡浜駅店</a></li>\n                  <li><a href=\"/shop/uwajima-st.html\">JR宇和島駅店</a></li>\n                  <li><a href=\"/shop/kochi-st.html\">高知駅前店</a></li>\n                  <li><a href=\"/shop/kochi-ap.html\">高知空港店</a></li>\n                  <li><a href=\"/shop/nakamura.html\">中村店</a></li>\n                </ul>\n              </div>\n              <div class=\"l-footer-area__block-recruit flex\">\n                <p class=\"-ttl\">採用情報</p>\n                <ul class=\"flex\">\n                  <li><a href=\"/recruit/interview/\">社員インタビュー</a></li>\n                  <li><a href=\"/recruit/data/\">数字で見る</a></li>\n                  <li><a href=\"/recruit/training/\">研修制度</a></li>\n                  <li><a href=\"/recruit/faq/\">よくあるご質問</a></li>\n                  <li><a href=\"/recruit/description/\">募集要項</a></li>\n                </ul>\n              </div>\n            </div>\n          </div>\n          <p class=\"l-footer-area__copy\">&copy; 2025, 株式会社トヨタレンタリース西四国</p>\n        </footer>\n      </div>\n    </div>\n    <script src=\"/assets/js/jquery-3.6.0.min.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/simple-parallax-js@5.6.2/dist/simpleParallax.min.js\"></script>\n    <script src=\"/assets/js/common.js\"></script>\n\n  </div>\n\n</body>\n\n</html>","finalUrl":"http://www.r-ehm.co.jp/recruit/interview/interview02/","rendered":false,"_cachedAt":"2026-06-23T16:27:31.943Z"}