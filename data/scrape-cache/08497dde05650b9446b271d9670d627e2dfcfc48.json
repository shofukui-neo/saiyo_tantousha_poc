\"HeadNavBody\">\r\n                <ul class=\"HeadNavMain\">\r\n                    <li class=\"\"><a href=\"/recruit/\"><span class=\"NavPc\"><img src=\"/recruit/assets/images/header/nav_top.svg\" alt=\"TOP トップページ\" width=\"66\" height=\"35\"></span><span class=\"NavSp\"><img src=\"/recruit/assets/images/header/nav_top_sp.svg\" alt=\"TOP\" width=\"52\" height=\"18\"><span>トップページ</span></span></a></li>\r\n                    <li class=\"HeadNavActive\"><div>\r\n                        <span class=\"NavPc\"><img src=\"/recruit/assets/images/header/nav_com.svg\" alt=\"Company 太陽を知る\" width=\"88\" height=\"35\"></span><span class=\"NavSp\"><img src=\"/recruit/assets/images/header/nav_com_sp.svg\" alt=\"Company\" width=\"94\" height=\"18\"><span>太陽を知る</span></span>\r\n                        <ul class=\"HeadNavDown\">\r\n                            <li><a href=\"/recruit/company/message.html\">トップメッセージ</a></li>\r\n                            <li><a href=\"/recruit/company/future.html\">太陽で輝く仕事と未来</a></li>\r\n                            <li><a href=\"/recruit/company/allabout.html\">ひと目でわかる太陽</a></li>\r\n                            <li><a href=\"/recruit/company/viewing.html\">TAIYO VIEWING 〜社内風景〜</a></li>\r\n                        </ul>\r\n                    </div></li>\r\n                    <li class=\"\"><div>\r\n                        <span class=\"NavPc\"><img src=\"/recruit/assets/images/header/nav_work.svg\" alt=\"Work Style 社員・仕事を知る\" width=\"107\" height=\"35\"></span><span class=\"NavSp\"><img src=\"/recruit/assets/images/header/nav_work_sp.svg\" alt=\"Work Style\" width=\"111\" height=\"18\"><span>社員・仕事を知る</span></span>\r\n                        <ul class=\"HeadNavDown\">\r\n                            <li><a href=\"/recruit/workstyle/philosophy.html\">社員の幸せのためにできること</a></li>\r\n                            <li><a href=\"/recruit/workstyle/profession.html\">太陽で働こう -職種紹介-</a></li>\r\n                            <li><a href=\"/recruit/workstyle/interview.html\">社員インタビュー</a></li>\r\n                            <li><a href=\"/recruit/workstyle/career.html\">キャリアステップ</a></li>\r\n                            <li><a href=\"/recruit/workstyle/female.html\">女性社員が輝く職場</a></li>\r\n                        </ul>\r\n                    </div></li>\r\n                    <li class=\"\"><div>\r\n                        <span class=\"NavPc\"><img src=\"/recruit/assets/images/header/nav_rec.svg\" alt=\"Recruitment 採用情報を知る\" width=\"118\" height=\"35\"></span><span class=\"NavSp\"><img src=\"/recruit/assets/images/header/nav_rec_sp.svg\" alt=\"Recruitment\" width=\"150\" height=\"18\"><span>採用情報を知る</span></span>\r\n                        <ul class=\"HeadNavDown\">\r\n                            <li><a href=\"/recruit/recruitment/flow.html\">応募要項・選考フロー</a></li>\r\n                            <li><a href=\"/recruit/recruitment/faq.html\">採用Q&A</a></li>\r\n                        </ul>\r\n                    </div></li>\r\n                    <li class=\"HeadForm\"><a href=\"https://www.renewal-taiyo.co.jp/form/recruit/\">採用応募フォームはこちら</a></li>\r\n                </ul>\r\n            </nav>\r\n        </div>\r\n    </header>\r\n</div>\r\n<aside class=\"BreadCrumb\">\r\n    <ul>\r\n        <li><a href=\"/recruit/\"><img src=\"/recruit/assets/images/header/pan_icon_home.svg\" alt=\"TOP\" width=\"15\" height=\"14\"></a></li>\r\n        <li><span>&rsaquo;</span>太陽を知る</li>\r\n        <li><span>&rsaquo;</span>TAIYO VIEWING ～社内風景～</li>\r\n            </ul>\r\n</aside>\r\n\r\n\r\n<!-- Contents -->\r\n<article class=\"Container\">\r\n\t<div class=\"CommonTitleMove\">\r\n\t\t<span class=\"CommonMoveTitle\"></span>\r\n\t\t<span class=\"CommonMoveTitle\"></span>\r\n\t\t<span class=\"CommonMoveTitle\"></span>\r\n\t\t<span></span>\r\n\t</div>\r\n\t<h1>\r\n\t\t<img src=\"/recruit/assets/images/company/viewing/title.svg\" alt=\"TAIYO VIEWING ～社内風景～\" width=\"415\" height=\"85\">\r\n\t</h1>\r\n\t<p class=\"ViewingTitleCopy\">太陽本社の一日を定点カメラで撮影。<br>会社のリアルな雰囲気や社員が実際に働く様子を映像と写真で紹介します。</p>\r\n\t<section class=\"ViewingBody ViewingMovie\">\r\n\t\t<h2><img src=\"/recruit/assets/images/company/viewing/movie_subtit.svg\" alt=\"movie\" width=\"75\" height=\"70\"></h2>\r\n\t\t<p class=\"ViewingBodyCopy\">執務室での作業風景とリラクゼーションルームでの休憩の様子を<br>早回しでご覧ください。</p>\r\n\t\t<ul class=\"ViewingMovieColumn\">\r\n\t\t\t<li>\r\n\t\t\t\t<h3>2F 執務室</h3>\r\n\t\t\t\t<div>\r\n\t\t\t\t\t<video muted autoplay playsinline loop poster=\"/recruit/assets/images/company/viewing/movie_poster.png\">\r\n\t\t\t\t\t\t<source src=\"/recruit/assets/images/company/viewing/movie_1.mp4?re\" type=\"video/mp4\">\r\n\t\t\t\t\t\t<p>動画の再生ができません。</p>\r\n\t\t\t\t\t</video>\r\n\t\t\t\t</div>\r\n\t\t\t\t<p>一人ひとりがアクティブに働く太陽の職場！</p>\r\n\t\t\t</li>\r\n\t\t\t<li>\r\n\t\t\t\t<h3>1F リラクゼーションルーム</h3>\r\n\t\t\t\t<div>\r\n\t\t\t\t\t<video muted autoplay playsinline loop poster=\"/recruit/assets/images/company/viewing/movie_poster.png\">\r\n\t\t\t\t\t\t<source src=\"/recruit/assets/images/company/viewing/movie_2.mp4?re\" type=\"video/mp4\">\r\n\t\t\t\t\t\t<p>動画の再生ができません。</p>\r\n\t\t\t\t\t</video>\r\n\t\t\t\t</div>\r\n\t\t\t\t<p>昼食や休憩をとるのに最適なリラックス空間！</p>\r\n\t\t\t</li>\r\n\t\t</ul>\r\n\t</section>\r\n\r\n\t<section class=\"ViewingBody ViewingPhoto\">\r\n\t\t<h2><img src=\"/recruit/assets/images/company/viewing/photo_subtit.svg\" alt=\"photo\" width=\"82\" height=\"75\"></h2>\r\n\t\t<p class=\"ViewingBodyCopy\">業務に集中できるワークスペースや社員が集まるフリースペースなど、<br>太陽本社の各エリアを紹介します。</p>\r\n\t\t<p class=\"ViewingPhotoCaption\">写真を選ぶと拡大してご覧いただけます。</p>\r\n\t\t<ul class=\"ViewingPhotoColumn\">\r\n\t\t\t<li>\r\n\t\t\t\t<a href=\"#ModalPhoto01\" class=\"ModalLink\"><img src=\"/recruit/assets/images/company/viewing/photo_thumb_1.jpg\" alt=\"執務室を拡大して見る\" width=\"228\" height=\"127\"></a>\r\n\t\t\t</li>\r\n\t\t\t<li>\r\n\t\t\t\t<a href=\"#ModalPhoto02\" class=\"ModalLink\"><img src=\"/recruit/assets/images/company/viewing/photo_thumb_2.jpg\" alt=\"リラクゼーションルームを拡大して見る\" width=\"228\" height=\"127\"></a>\r\n\t\t\t</li>\r\n\t\t\t<li>\r\n\t\t\t\t<a href=\"#ModalPhoto03\" class=\"ModalLink\"><img src=\"/recruit/assets/images/company/viewing/photo_thumb_3.jpg\" alt=\"応接室を拡大して見る\" width=\"228\" height=\"127\"></a>\r\n\t\t\t</li>\r\n\t\t\t<li>\r\n\t\t\t\t<a href=\"#ModalPhoto04\" class=\"ModalLink\"><img src=\"/recruit/assets/images/company/viewing/photo_thumb_4.jpg\" alt=\"会議室を拡大して見る\" width=\"228\" height=\"127\"></a>\r\n\t\t\t</li>\r\n\t\t</ul>\r\n\t</section>\r\n</article>\r\n<!-- /Contents -->\r\n<aside id=\"ModalCover\">\r\n\t<div class=\"ModalOuter\"><div class=\"ModalInner\">\r\n\t\t\t<div id=\"ModalPhoto01\" class=\"ModalBody ModalPhoto\">\r\n\t\t\t\t<div class=\"ModalPhotoBody\">\r\n\t\t\t\t\t<img src=\"/recruit/assets/images/company/viewing/photo_big_1.jpg\" alt=\"執務室：写真\">\r\n\t\t\t\t\t<div>\r\n\t\t\t\t\t\t<h3>執務室</h3>\r\n\t\t\t\t\t\t<p>社員一人ひとりが太陽を支えるブレーンとして、業務全般に関わる各種作業を行っています。</p>\r\n\t\t\t\t\t</div>\r\n\t\t\t\t</div>\r\n\t\t\t\t<ul>\r\n\t\t\t\t\t<li class=\"ModalBtnNext\"><a href=\"#ModalPhoto02\"><span>Next</span></a></li>\r\n\t\t\t\t\t<li class=\"ModalBtnPrev\"><a href=\"#ModalPhoto04\"><span>Prev</span></a></li>\r\n\t\t\t\t\t<li class=\"ModalBtnClose\"><a href=\"javascript:void(0)\">Close</a></li>\r\n\t\t\t\t</ul>\r\n\t\t\t</div>\r\n\t\t\t<div id=\"ModalPhoto02\" class=\"ModalBody ModalPhoto\">\r\n\t\t\t\t<div class=\"ModalPhotoBody\">\r\n\t\t\t\t\t<img src=\"/recruit/assets/images/company/viewing/photo_big_2.jpg\" alt=\"リラクゼーションルーム：写真\">\r\n\t\t\t\t\t<div>\r\n\t\t\t\t\t\t<h3>リラクゼーションルーム</h3>\r\n\t\t\t\t\t\t<p>社員たちがくつろげる落ち着いた空間。ランチに使う社員も多くいます。</p>\r\n\t\t\t\t\t</div>\r\n\t\t\t\t</div>\r\n\t\t\t\t<ul>\r\n\t\t\t\t\t<li class=\"ModalBtnNext\"><a href=\"#ModalPhoto03\"><span>Next</span></a></li>\r\n\t\t\t\t\t<li class=\"ModalBtnPrev\"><a href=\"#ModalPhoto01\"><span>Prev</span></a></li>\r\n\t\t\t\t\t<li class=\"ModalBtnClose\"><a href=\"javascript:void(0)\">Close</a></li>\r\n\t\t\t\t</ul>\r\n\t\t\t</div>\r\n\t\t\t<div id=\"ModalPhoto03\" class=\"ModalBody ModalPhoto\">\r\n\t\t\t\t<div class=\"ModalPhotoBody\">\r\n\t\t\t\t\t<img src=\"/recruit/assets/images/company/viewing/photo_big_3.jpg\" alt=\"応接室：写真\">\r\n\t\t\t\t\t<div>\r\n\t\t\t\t\t\t<h3>応接室</h3>\r\n\t\t\t\t\t\t<p>経営理念を掲げるこの部屋で、お客様や取引先と“熱く”向き合います。</p>\r\n\t\t\t\t\t</div>\r\n\t\t\t\t</div>\r\n\t\t\t\t<ul>\r\n\t\t\t\t\t<li class=\"ModalBtnNext\"><a href=\"#ModalPhoto04\"><span>Next</span></a></li>\r\n\t\t\t\t\t<li class=\"ModalBtnPrev\"><a href=\"#ModalPhoto02\"><span>Prev</span></a></li>\r\n\t\t\t\t\t<li class=\"ModalBtnClose\"><a href=\"javascript:void(0)\">Close</a></li>\r\n\t\t\t\t</ul>\r\n\t\t\t</div>\r\n\t\t\t<div id=\"ModalPhoto04\" class=\"ModalBody ModalPhoto\">\r\n\t\t\t\t<div class=\"ModalPhotoBody\">\r\n\t\t\t\t\t<img src=\"/recruit/assets/images/company/viewing/photo_big_4.jpg\" alt=\"会議室：写真\">\r\n\t\t\t\t\t<div>\r\n\t\t\t\t\t\t<h3>会議室</h3>\r\n\t\t\t\t\t\t<p>日々の打ち合わせはもちろん、勉強会などにも活用。活発な意見が飛び交う情報共有の場です。</p>\r\n\t\t\t\t\t</div>\r\n\t\t\t\t</div>\r\n\t\t\t\t<ul>\r\n\t\t\t\t\t<li class=\"ModalBtnNext\"><a href=\"#ModalPhoto01\"><span>Next</span></a></li>\r\n\t\t\t\t\t<li class=\"ModalBtnPrev\"><a href=\"#ModalPhoto03\"><span>Prev</span></a></li>\r\n\t\t\t\t\t<li class=\"ModalBtnClose\"><a href=\"javascript:void(0)\">Close</a></li>\r\n\t\t\t\t</ul>\r\n\t\t\t</div>\r\n\t</div><div class=\"ModalOverlay\"></div></div>\r\n</aside>\r\n\r\n\n<footer class=\"Footer\">\n    <aside class=\"FooterPageTop\">\n        <a href=\"#PageTop\"><span>PAGE TOP</span></a>\n    </aside>\n    <div class=\"FooterLinkColumn\">\n        <div>\n            <h3>太陽を知る</h3>\n            <ul>\n                <li><a href=\"/recruit/company/message.html\">トップメッセージ</a></li>\n                <li><a href=\"/recruit/company/future.html\">太陽で輝く仕事と未来</a></li>\n                <li><a href=\"/recruit/company/allabout.html\">ひと目でわかる太陽</a></li>\n                <li><a href=\"/recruit/company/viewing.html\">TAIYO VIEWING 〜社内風景〜</a></li>\n            </ul>\n        </div>\n\n        <div>\n            <h3>社員・仕事を知る<