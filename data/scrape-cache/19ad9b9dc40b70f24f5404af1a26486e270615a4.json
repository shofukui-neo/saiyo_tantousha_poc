\" href=\"../assets/styles/index.css\" media=\"all\">\r\n\t<link rel=\"stylesheet\" type=\"text/css\" href=\"../assets/styles/style_new.css\" media=\"all\">\r\n\t<link rel=\"stylesheet\" type=\"text/css\" href=\"../assets/styles/251224_style.css\" media=\"all\">\r\n\t<link rel=\"stylesheet\" type=\"text/css\" href=\"../assets/styles/products/style.css\" media=\"all\">\r\n\r\n\t<script src=\"../assets/scripts/jquery-3.6.1.min.js\"></script>\r\n\r\n</head>\r\n<body id=\"top\">\r\n\r\n\r\n\r\n<!-- Google Tag Manager (noscript) -->\r\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-MD5J4F\" height=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\r\n<!-- End Google Tag Manager (noscript) -->\r\n<div class=\"page\">\r\n\t<header>\r\n\t\t<div class=\"header-inner\">\r\n\t\t\t<div class=\"logo\"><a href=\"/5g-info/\">\r\n\t\t\t\t<picture>\r\n\t\t\t\t\t<source srcset=\"../assets/images/logo_sp.png\" media=\"(max-width: 767px)\">\r\n\t\t\t\t\t<img src=\"../assets/images/logo.png\" alt=\"FUJISOFT\">\r\n\t\t\t\t</picture>\r\n\t\t\t</a></div>\r\n\t\t<a href=\"javascript:void(0);\" class=\"sp_show nav_tgl_btn\">\r\n\t\t\t<span class=\"nav_tgl_icn nav_tgl_icn--01\"></span>\r\n\t\t\t<span class=\"nav_tgl_icn nav_tgl_icn--02\"></span>\r\n\t\t</a>\r\n\t\t<nav class=\"header-nav\">\r\n\t\t\t<ul>\r\n\t\t\t\t\t<li class=\"sp_show\"><a href=\"/5g-info/\" class=\"nav_link\">TOP</a></li>\r\n\t\t\t\t\t<li><a href=\"/5g-info/incorporate/\" class=\"nav_link\">導入検討中の企業様</a></li>\r\n\t\t\t\t\t<li><a href=\"/5g-info/partnership/\" class=\"nav_link\">協業検討中の企業様</a></li>\r\n\t\t\t\t\t<li><a href=\"/5g-info/products/\" class=\"nav_link\">製品・ソリューション</a></li>\r\n\t\t\t\t\t<li><a href=\"https://sem-inq.fsi.co.jp/public/application/add/6744\" class=\"contact-btn contact-btn--01\" target=\"_blank\">無料でお問い合わせ</a></li>\r\n\t\t\t\t\t<li class=\"sp_show\"><a href=\"https://sem-inq.fsi.co.jp/public/application/add/6745\" class=\"contact-btn contact-btn--02\" target=\"_blank\">資料請求</a></li>\r\n\t\t\t</ul>\r\n\t\t</nav>\r\n\t\t</div>\r\n\t</header>\r\n\t<main>\r\n\t\t<div id=\"main_visual\">\r\n\t\t\t<div class=\"ly-container\">\r\n\t\t\t\t<h1 class=\"main-ttl\">富士ソフトの製品・<br class=\"sp-br\">ソリューション</h1>\r\n\t\t\t\t<p class=\"main-txt\">富士ソフトが取り扱っている製品と<br class=\"pc-br\">ネットワーク<br class=\"sp-br\">構築のサービスについてご紹介します。<br>お客様のユースケースに合わせた<br class=\"sp-br\">ソリューションをご提供できます。</p>\r\n\t\t\t</div>\r\n\t\t</div>\r\n  <section class=\"type_bg_bl\" id=\"intro\">\r\n    <div class=\"ly-container\">\r\n\t\t\t<p class=\"intro_txt\">\r\n\t\t\t\t富士ソフトはPEGATRON Corporationと国内初の販売代理店契約を締結しており、<br>当社の最先端かつ高品質な製品とソリューションをご提供することができます。\r\n\t\t\t</p>\r\n      <div class=\"intro_anchor\">\r\n        <a href=\"#product_list\">製品一覧</a>\r\n        <a href=\"#solution\">ソリューション</a>\r\n      </div>\r\n    </div>\r\n  </section>\r\n\t\t<section id=\"product_list\" class=\"type_bg_bk\">\r\n\t\t\t<div class=\"ly-container\">\r\n\t\t\t\t<h2 class=\"heading_wh\">製品一覧</h2>\r\n\t\t\t\t<ul class=\"product_anchor\">\r\n\t\t\t\t\t<li><a href=\"#router\">CPEルーター</a></li>\r\n\t\t\t\t\t<li><a href=\"#camera\">5Gカメラ</a></li>\r\n\t\t\t\t\t<li><a href=\"#usb\">USBドングル</a></li>\r\n\t\t\t\t\t<li><a href=\"#odu\">ODU</a></li>\r\n\t\t\t\t</ul>\r\n\t\t\t\t<ul class=\"product_cts\">\r\n\t\t\t\t\t<li id=\"router\">\r\n\t\t\t\t\t\t<h3 class=\"product_ttl\">CPEルーター</h3>\r\n\t\t\t\t\t\t<div class=\"product_information\">\r\n\t\t\t\t\t\t\t<div class=\"product_img_wrap\">\r\n\t\t\t\t\t\t\t\t<p class=\"product_img\">\r\n\t\t\t\t\t\t\t\t\t<picture>\r\n\t\t\t\t\t\t\t\t\t\t<source srcset=\"../assets/images/products/products_img_router_sp.png\" media=\"(max-width: 767px)\">\r\n\t\t\t\t\t\t\t\t\t\t<img src=\"../assets/images/products/products_img_router.png\" alt=\"\">\r\n\t\t\t\t\t\t\t\t\t</picture>\r\n\t\t\t\t\t\t\t\t</p>\r\n\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t<div class=\"accordion-wrap\">\r\n\t\t\t\t\t\t\t\t<button class=\"js-accordion js-accordion--bk sp_only\"><p>もっと見る</p></button>\r\n\t\t\t\t\t\t\t\t<div class=\"product_detail accordion-box\">\r\n\t\t\t\t\t\t\t\t\t<h4 class=\"product_detail_ttl\">MG54AX<span>PEGATRON <br class=\"spD\">Corporation製</span></h4>\r\n\t\t\t\t\t\t\t\t\t<div class=\"product_detail_cts\">\r\n\t\t\t\t\t\t\t\t\t\t<p class=\"product_detail_txt\">5G Sub6/4Gに対応し、Wi-Fi 6（2.4GHz 2x2 + 5GHz 4x4）を搭載した高性能な無線LANルーターとして機能します。<br>豊富な5G/LTEバンドに対応しており、多様な地域やキャリアのネットワークで利用可能です。<br>サイズも比較的小型（221mm x 110mm x 105mm）なため、設置場所を選びません。</p>\r\n\t\t\t\t\t\t\t\t\t\t<div class=\"use_case\">\r\n\t\t\t\t\t\t\t\t\t\t\t<p class=\"use_case_ttl\">主なユースケース</p>\r\n\t\t\t\t\t\t\t\t\t\t\t<div class=\"use_case_cts\">\r\n\t\t\t\t\t\t\t\t\t\t\t\t<dl>\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t<dt>【ブロードバンド代替】</dt>\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t<dd>光回線などの有線インフラの敷設が困難な地域や、一時的な設置が必要な場所での高速インターネット接続</dd>\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t<dt>【ローカル5G端末】</dt>\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t<dd>構築されたローカル5Gネットワークに接続し、PCや各種デバイスをインターネットや内部ネットワークに接続するためのゲートウェイとして機能</dd>\r\n\t\t\t\t\t\t\t\t\t\t\t\t</dl>\r\n\t\t\t\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t\t\t<a href=\"https://sem-inq.fsi.co.jp/public/application/add/6745\" class=\"contact-btn contact-btn--02\" target=\"_blank\">資料請求</a>\r\n\t\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t</li>\r\n          <li id=\"camera\">\r\n            <h3 class=\"product_ttl\">5Gカメラ</h3>\r\n            <div class=\"product_information\">\r\n              <div class=\"product_img_wrap\">\r\n                <p class=\"product_img\">\r\n                  <picture>\r\n                    <source srcset=\"../assets/images/products/products_img_camera_01_sp.png\" media=\"(max-width: 767px)\">\r\n                    <img src=\"../assets/images/products/products_img_camera_01.png\" alt=\"\">\r\n                  </picture>\r\n                </p>\r\n              </div>\r\n              <div class=\"accordion-wrap\">\r\n                <button class=\"js-accordion js-accordion--bk sp_only\">\r\n                  <p>もっと見る</p>\r\n                </button>\r\n                <div class=\"product_detail accordion-box\">\r\n                  <h4 class=\"product_detail_ttl\">Nura4K<span>PEGATRON <br class=\"spD\">Corporation製</span></h4>\r\n                  <div class=\"product_detail_cts\">\r\n                    <p class=\"product_detail_txt\">4K（Ultra\r\n                      HD）の映像を撮影・伝送することができる5G対応カメラです。<br>5Gモジュールを内蔵しているため、別途ルーターなどを介さずに、直接5Gネットワークに接続し、大容量の映像データを低遅延で伝送できます。<br>防滴仕様もあるため、屋外や過酷な環境下での設置を想定した防滴設計を施すことができます。\r\n                    </p>\r\n                    <div class=\"use_case\">\r\n                      <p class=\"use_case_ttl\">主なユースケース</p>\r\n                      <div class=\"use_case_cts\">\r\n                        <dl>\r\n                          <dt>【スマートシティ】</dt>\r\n                          <dd>交通監視、人流解析、公共の安全監視など、都市インフラの高度化</dd>\r\n                          <dt>【産業・建設現場】</dt>\r\n                          <dd>遠隔地からの高精細な作業監視、危険区域のモニタリング</dd>\r\n                          <dt>【ライブ配信】</dt>\r\n                          <dd>イベントやスポーツ中継など、高品質な映像を低遅延で伝送する必要があるライブブロードキャスト</dd>\r\n                        </dl>\r\n                      </div>\r\n                    </div>\r\n                    <a href=\"https://sem-inq.fsi.co.jp/public/application/add/6745\" class=\"contact-btn contact-btn--02\" target=\"_blank\">資料請求</a>\r\n                  </div>\r\n                </div>\r\n              </div>\r\n            </div>\r\n            <div class=\"product_information\">\r\n              <div class=\"product_img_wrap\">\r\n                <p class=\"product_img\">\r\n                  <picture>\r\n                    <source srcset=\"../assets/images/products/products_img_camera_02_sp.png\" media=\"(max-width: 767px)\">\r\n                    <img src=\"../assets/images/products/products_img_camera_02.png\" alt=\"\">\r\n                  </picture>\r\n                </p>\r\n              </div>\r\n              <div class=\"accordion-wrap\">\r\n                <button class=\"js-accordion js-accordion--bk sp_only\">\r\n                  <p>もっと見る</p>\r\n                </button>\r\n                <div class=\"product_detail accordion-box\">\r\n                  <h4 class=\"product_detail_ttl\">Muscat<span>PEGATRON <br class=\"spD\">Corporation製</span></h4>\r\n                  <div class=\"product_detail_cts\">\r\n                    <p class=\"product_detail_txt\">5G RedCap対応のカメラです。<br>3GPP Release\r\n                      17に準拠しており、標準5Gよりも低消費電力・低コストなスペックなため、IoT/M2M用途に最適です。<br>AI\r\n                      SoCも内蔵しているため、エッジでのリアルタイム画像解析処理が可能で、産業・屋外環境での設置を想定した堅牢な設計となっております。</p>\r\n                    <div class=\"use_case\">\r\n                      <p class=\"use_case_ttl\">主なユースケース</p>\r\n                      <div class=\"use_case_cts\">\r\n                        <dl>\r\n                          <dt>【スマートシティ】</dt>\r\n                          <dd>交通量解析、人流監視、公共エリアのセキュリティ監視</dd>\r\n                          <dt>【産業監視】</dt>\r\n                          <dd>製造ラインでのAIによるリアルタイム品質検査、遠隔地の設備監視</dd>\r\n                          <dt>【バッテリー駆動監視】</dt>\r\n                          <dd>建設現場や仮設イベントなど、電源確保が難しい場所での高信頼性監視</dd>\r\n                        </dl>\r\n                      </div>\r\n                    </div>\r\n                    <a href=\"https://sem-inq.fsi.co.jp/public/application/add/6745\" class=\"contact-btn contact-btn--02\" target=\"_blank\">資料請求</a>\r\n                  </div>\r\n                </div>\r\n              </div>\r\n            </div>\r\n            <p class=\"product_note\">※今後取扱い予定の製品となります。</p>\r\n          </li>\r\n          <li id=\"usb\">\r\n            <h3 class=\"product_ttl\">USBドングル</h3>\r\n            <div class=\"product_information\">\r\n              <div class=\"product_img_wrap\">\r\n                <p class=\"product_img\">\r\n                  <picture>\r\n                    <source srcset=\"../assets/images/products/products_img_usb_01_sp.png\" media=\"(max-width: 767px)\">\r\n                    <img src=\"../assets/images/products/products_img_usb_01.png\" alt=\"\">\r\n                  </picture>\r\n                </p>\r\n              </div>\r\n              <div class=\"accordion-wrap\">\r\n                <button class=\"js-accordion js-accordion--bk sp_only\">\r\n                  <p>もっと見る</p>\r\n                </button>\r\n                <div class=\"product_detail accordion-box\">\r\n                  <h4 class=\"product_detail_ttl\">MD100<span>PEGATRON <br class=\"spD\">Corporation製</span></h4>\r\n                  <div class=\"product_detail_cts\">\r\n                    <p class=\"product_detail_txt\">42mm x 93mm x 20mmという極めて小型なサイズで、携帯性に優れたUSBドングルです。<br>標準的な5Gドングルとして活用でき、USB\r\n                      3.0接続にも対応しており、産業機器やタブレット、PCなどに容易に接続できます。</p>\r\n                    <div class=\"use_case\">\r\n                      <p class=\"use_case_ttl\">主なユースケース</p>\r\n                      <div class=\"use_case_cts\">\r\n                        <dl>\r\n                          <dt>【産業機器のIoT化】</dt>\r\n                          <dd>既存の産業用PCやコントローラーに接続し、5Gネットワーク経由でのデータ収集や遠隔制御を実現</dd>\r\n                          <dt>【モバイル端末の高速化】</dt>\r\n                          <dd>タブレットやノートPCに接続し、Wi-Fi環境がない場所でも高速な5G通信を利用</dd>\r\n                        </dl>\r\n                      </div>\r\n                    </div>\r\n                    <a href=\"https://sem-inq.fsi.co.jp/public/application/add/6745\" class=\"contact-btn contact-btn--02\" target=\"_blank\">資料請求</a>\r\n                  </div>\r\n                </div>\r\n              </div>\r\n            </div>\r\n            <div class=\"product_information\">\r\n              <div class=\"product_img_wrap\">\r\n                <p class=\"product_img\">\r\n                  <picture>\r\n                    <source srcset=\"../assets/images/products/products_img_usb_02_sp.png\" media=\"(max-width: 767px)\">\r\n                    <img src=\"../assets/images/products/products_img_usb_02.png\" alt=\"\">\r\n                  </picture>\r\n                </p>\r\n              </div>\r\n              <div class=\"accordion-wrap\">\r\n                <button class=\"js-accordion js-accordion--bk sp_only\">\r\n                  <p>もっと見る</p>\r\n                </button>\r\n                <div class=\"product_detail accordion-box\">\r\n                  <h4 class=\"product_detail_ttl\">MD200<span>PEGATRON <br class=\"spD\">Corporation製</span></h4>\r\n                  <div class=\"product_detail_cts\">\r\n                    <p class=\"product_detail_txt\">3GPP Release 17に準拠した、5G RedCap対応のUSBドングルです。<br>小型サイズでUSB\r\n                      Type-Cへの接続が可能なため、既存機器への組み込みが容易です。<br>MD100より低コスト・低消費電力かつRedCap対応機器として十分な速度（DL 223Mbps / UL\r\n                      123Mbps程度）と高信頼性を両立しています。</p>\r\n                    <div class=\"use_case\">\r\n                      <p class=\"use_case_ttl\">主なユースケース</p>\r\n                      <div class=\"use_case_cts\">\r\n                        <dl>\r\n                          <dt>【M2M通信】</dt>\r\n                          <dd>産業用センサー、計測機器、スマートメーターからのデータ収集</dd>\r\n                          <dt>【デジタルサイネージ】</dt>\r\n                          <dd>確実なコンテンツ配信と遠隔管理</dd>\r\n                          <dt>【ウェアラブル端末】</dt>\r\n                          <dd>作業員の位置情報やバイタルデータの高信頼性伝送</dd>\r\n                        </dl>\r\n                      </div>\r\n                    </div>\r\n                    <a href=\"https://sem-inq.fsi.co.jp/public/application/add/6745\" class=\"contact-btn contact-btn--02\" target=\"_blank\">資料請求</a>\r\n                  </div>\r\n                </div>\r\n              </div>\r\n            </div>\r\n            <p class=\"product_note\">※今後取扱い予定の製品となります。</p>\r\n          </li>\r\n          <li id=\"odu\">\r\n            <h3 class=\"product_ttl\">ODU</h3>\r\n            <div class=\"product_information\">\r\n              <div class=\"product_img_wrap\">\r\n                <p class=\"product_img\">\r\n                  <picture>\r\n                    <source srcset=\"../assets/images/products/products_img_odu_sp.png\" media=\"(max-width: 767px)\">\r\n                    <img src=\"../assets/images/products/products_img_odu.png\" alt=\"\">\r\n                  </picture>\r\n                </p>\r\n              </div>\r\n              <div class=\"accordion-wrap\">\r\n                <button class=\"js-accordion js-accordion--bk sp_only\">\r\n                  <p>もっと見る</p>\r\n                </button>\r\n                <div class=\"product_detail accordion-box\">\r\n                  <h4 class=\"product_detail_ttl\">M2U300<span>PEGATRON <br class=\"spD\">Corporation製</span></h4>\r\n                  <div class=\"product_detail_cts\">\r\n                    <p class=\"product_detail_txt\">\r\n                      IP65等級の屋外設置型（ODU）の機器です。<br>堅牢な筐体で過酷な屋外環境に対応することができます。<br>5Gミリ波（FR2）とSub6GHzの両対応で柔軟な周波数帯域の利用が可能で、10GbE\r\n                      PoEにも対応しているため超高速通信を活かすための高速有線インターフェースを実現することができます。</p>\r\n                    <div class=\"use_case\">\r\n                      <p class=\"use_case_ttl\">主なユースケース</p>\r\n                      <div class=\"use_case_cts\">\r\n                        <dl>\r\n                          <dt>【ハイブリッドFWA】</dt>\r\n                          <dd>ミリ波エリア内では超高速、エリア外ではSub6GHzで広域をカバーする固定無線アクセス</dd>\r\n                          <dt>【工場・倉庫間の超高速データ伝送】</dt>\r\n                          <dd>敷地内の建物間を光ファイバー敷設なしで10Gbps級の速度で接続</dd>\r\n                          <dt>【ローカル5Gのエリア拡張】</dt>\r\n                          <dd>既存のSub6GHzエリアにミリ波の超高速エリアをスポットで追加</dd>\r\n                        </dl>\r\n                      </div>\r\n                    </div>\r\n                    <a href=\"https://sem-inq.fsi.co.jp/public/application/add/6745\" class=\"contact-btn contact-btn--02\" target=\"_blank\">資料請求</a>\r\n                  </div>\r\n                </div>\r\n              </div>\r\n            </div>\r\n            <p class=\"product_note\">※今後取扱い予定の製品となります。</p>\r\n          </li>\r\n\t\t\t\t</ul>\r\n\t\t\t</div>\r\n\t\t</section>\r\n    <section id=\"solution\" class=\"type_bg_bl\">\r\n      <div class=\"ly-container\">\r\n        <h2 class=\"heading_lb\">ソリューション</h2>\r\n        <div class=\"box\">\r\n          <div class=\"box_thumb\">\r\n            <img src=\"../assets/images/products/solution_thumb.png\" alt=\"\" class=\"pcD\">\r\n            <img src=\"../assets/images/products/solution_thumb_sp.png\" alt=\"\" class=\"spD\">\r\n            <h3 class=\"box_ttl\">Prime Link 5G</h3>\r\n            <p>PEGATRON Corporation製</p>\r\n          </div>\r\n          <a href=\"https://sem-inq.fsi.co.jp/public/application/add/6745\" class=\"contact-btn contact-btn--02 spD\" target=\"_blank\">資料請求</a>\r\n          <button class=\"js-accordion spD\">\r\n            もっと見る\r\n          </button>\r\n          <div class=\"accordion-box\">\r\n            <div class=\"box_txt\">\r\n              <p>国内初のPEGATRON Corporationの代理店である富士ソフトが提供する、パッケージ化された基地局設置ソリューションです。Open Radio Access Network (O-RAN)\r\n                規格に準拠しており、異なるベンダーの機器との相互接続性や、柔軟なネットワーク構成を可能にします。<br>\r\n                企業や自治体が自営で構築するローカル5Gネットワークの基盤とすることができ、基地局（RU/DU/CU）だけでなく、Microsoft Azure Private 5G\r\n                Coreなどのコアネットワーク機能と連携させることで、すぐに利用可能なシステムとしてご提供します。</p>\r\n            </div>\r\n            <div class=\"box_ex\">\r\n              <p class=\"box_ex_ttl\">主なユースケース</p>\r\n              <p>【スマートファクトリー】<br>\r\n                リアルタイム監視、AGV（無人搬送車）の超低遅延制御、AIによる画像解析を伴う精密検査など製造現場のDXを推進</p>\r\n              <p>【高精細映像伝送】<br>\r\n                建設現場や災害対策など、広範囲で高精細な4K/8K映像を遅延なく伝送する</p>\r\n            </div>\r\n            <a href=\"https://sem-inq.fsi.co.jp/public/application/add/6745\" class=\"contact-btn contact-btn--02 pcD\" target=\"_blank\">資料請求</a>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </section>\r\n  <section class=\"type_bg_bk\" id=\"more\">\r\n    <div class=\"ly-container txt_wh\">\r\n      <h2 class=\"heading_wh\">その他サービス</h2>\r\n      <div class=\"box\">\r\n        <div class=\"box_thumb\">\r\n          <img src=\"../assets/images/products/more_thumb.png\" alt=\"\" class=\"pcD\">\r\n          <img src=\"../assets/images/products/more_thumb_sp.png\" alt=\"\" class=\"spD\">\r\n          <h3 class=\"box_ttl\">無線LANサイトサーベイ</h3>\r\n        </div>\r\n        <a href=\"https://sem-inq.fsi.co.jp/public/application/add/6745\" class=\"contact-btn contact-btn--02 spD\" target=\"_blank\">資料請求</a>\r\n        <button class=\"js-accordion spD\">\r\n              もっと見る\r\n        </button>\r\n        <div class=\"accordion-box\">\r\n          <div class=\"box_txt\">\r\n            <p>富士ソフトが提供する、Wi-Fiの電波測定サービスです。<br>\r\n              専用の測定ツールを用いて、Wi-Fiの電波強度、カバレッジエリア、チャネル干渉の状況などを詳細に調査・分析し、電波の「見える化」を実現します。<br>\r\n              調査結果に基づき、アクセスポイントの最適な設置場所、台数、チャネル設定などもご提案可能です。</p>\r\n          </div>\r\n          <div class=\"box_ex\">\r\n            <p class=\"box_ex_ttl\">主なユースケース</p>\r\n            <p>【導入前調査】<br>\r\n              新たにWi-Fi環境を構築する際、必要なアクセスポイントの数や設置場所を正確に把握し、設計ミスによる通信不良を防ぐ</p>\r\n            <p>【トラブルシューティング】<br>\r\n              既存のWi-Fi環境で通信速度の低下や接続切れが発生している場合、電波干渉やカバレッジ不足などの原因を特定し、改善策を講じる</p>\r\n          </div>\r\n          <a href=\"https://sem-inq.fsi.co.jp/public/application/add/6745\" class=\"contact-btn contact-btn--02 pcD\" target=\"_blank\">資料請求</a>\r\n        </div>\r\n      </div>\r\n      <div class=\"check box\">\r\n        <div class=\"check_thumb\"><img src=\"../assets/images/products/more_figure.png\" alt=\"\">\r\n          <h3 class=\"check_ttl\">検証サービス</h3>\r\n        </div>\r\n        <button class=\"js-accordion spD\">\r\n          もっと見る\r\n        </button>\r\n        <div class=\"accordion-box\">\r\n          <p class=\"check_txt\">ローカル5G機器の性能・互換性・運用性の事前検証を弊社のラボにて実施できます。<br>\r\n            5G NR（Sub-6／mmWave）対応機器を対象に、通信品質、接続安定性、ネットワークスライシング、MDM管理機能などの項目を専門環境で評価し、品質改善のコンサルティングをします。</p>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </section>\r\n\t<section class=\"contact contact_02\">\r\n\t\t<div class=\"ly-container\">\r\n\t\t\t<div class=\"contact-box\">\r\n\t\t\t\t<p class=\"contact-txt\">\r\n\t\t\t\t\t<span>＼個別相談・ラボ見学・実証実験の実施まで／</span>\r\n\t\t\t\t\t導入を検討されている方、<br class=\"spD\">不安や疑問をお持ちの方<br>お気軽にご相談ください。\r\n\t\t\t\t</p>\r\n\t\t\t\t<div class=\"contact-btn_wrap\">\r\n\t\t\t\t\t<a href=\"https://sem-inq.fsi.co.jp/public/application/add/6744\" class=\"contact-btn contact-btn--01\" target=\"_blank\">無料でお問い合わせ</a>\r\n\t\t\t\t\t<a href=\"https://sem-inq.fsi.co.jp/public/application/add/6745\" class=\"contact-btn contact-btn--02\" target=\"_blank\">資料請求</a>\r\n\t\t\t\t</div>\r\n\t\t\t</div>\r\n\t\t</div>\r\n\t</section>\r\n\t</main>\r\n\t<div class=\"page_top_wrap\">\r\n\t\t<a href=\"index.html#top\" class=\"page_top\">ページトップへ戻る</a>\r\n\t</div>\r\n\t<footer>\r\n\t\t<div class=\"footer_inr\">\r\n\t\t\t<div class=\"ly-container\">\r\n\t\t\t\t<div class=\"logo\">\r\n\t\t\t\t\t<picture>\r\n\t\t\t\t\t\t<source srcset=\"../assets/images/footer_logo_sp.png\" media=\"(max-width: 767px)\">\r\n\t\t\t\t\t\t<img src=\"../assets/images/footer_logo.png\" alt=\"FUJISOFT\">\r\n\t\t\t\t\t</picture>\r\n\t\t\t\t</div>\r\n\t\t\t\t<nav>\r\n\t\t\t\t\t<div class=\"top\"><a href=\"/5g-info/\">TOP</a></div>\r\n\t\t\t\t\t<ul>\r\n\t\t\t\t\t\t<li><a href=\"/5g-info/incorporate/\" class=\"nav_link\">導入検討中の企業様</a></li>\r\n\t\t\t\t\t\t<li><a href=\"/5g-info/partnership/\" class=\"nav_link\">協業検討中の企業様</a></li>\r\n\t\t\t\t\t\t<li><a href=\"/5g-info/products/\" class=\"nav_link\">製品・ソリューション</a></li>\r\n\t\t\t\t\t\t<li><a href=\"https://sem-inq.fsi.co.jp/public/application/add/6744\" class=\"contact-btn contact-btn--01\" target=\"_blank\">無料でお問い合わせ</a></li>\r\n\t\t\t\t\t</ul>\r\n\t\t\t\t</nav>\r\n\t\t\t</div>\r\n\t\t</div>\r\n\t\t<div class=\"footer_inr\">\r\n\t\t\t<div class=\"link_area\">\r\n\t\t\t\t<a href=\"/sustainability/governance/security.html\">情報セキュリティ基本方針</a>\r\n\t\t\t\t<a href=\"/privacy.html\">個人情報保護方針</a>\r\n\t\t\t\t<a href