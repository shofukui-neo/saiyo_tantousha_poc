\"heading bg-blue\">\n  <div class=\"bg-grid\">\n    <div class=\"bg-grid__block --block6\"><span class=\"p1\"></span></div>\n    <div class=\"bg-grid__block --block4\"><span class=\"p1\"></span><span class=\"p2 r270\"></span><span class=\"p1\"></span></div>\n    <div class=\"bg-grid__block --block4\"><span class=\"p1\"></span><span class=\"p2 r270\"></span><span class=\"p1\"></span></div>\n    <div class=\"bg-grid-sm\">\n      <div class=\"bg-grid-sm__block --block-sm2\"><span class=\"p1\"></span><span class=\"p1\"></span></div>\n    </div>\n  </div>\n  <div class=\"heading__cont\">\n    <div class=\"heading__en\">Application guideline</div>\n    <h1 class=\"heading__ja\">営業職</h1>\n          <div class=\"heading__sub\">募集要項 / 中途採用</div>\n      </div>\n      <div class=\"pnkz heading__pnkz\">\n  <ul class=\"pnkz__list\">\n    <li class=\"pnkz__item\"><a class=\"pnkz__name\" href=\"/\">TOP</a></li>\n    <li class=\"pnkz__item\"><a class=\"pnkz__name\" href=\"/recruit\">採用</a></li>\n    <li class=\"pnkz__item --current\"><span class=\"pnkz__name\">中途採用 営業職</span></li>\n  </ul>\n</div></div>\n    <div class=\"guide\">\n        <div class=\"bg-grid\">\n            <div class=\"bg-grid__block --block5\"><span class=\"p1\"></span><span class=\"p2 r270\"></span></div>\n            <div class=\"bg-grid__block --block8\"><span class=\"p1\"></span><span class=\"p2 r270\"></span><span class=\"p2 r180\"></span></div>\n        </div>\n        <div class=\"guide__inner inner\">\n              <div class=\"ttl guide__ttl inView fadeUp\">\n  <h2 class=\"ttl__ja\">営業職</h2>\n  <div class=\"ttl__en\">Sales Position</div>\n</div>\n            <section class=\"guide__sec inView fadeUp\">\n                  <div class=\"ttl2 guide__sec-ttl\">\n  <h3 class=\"ttl2__ja\">職務内容</h3>\n</div>                <p class=\"guide__txt\">\n                    当社製品の提案及び受注営業\n                </p>\n            </section>\n\n                            <section class=\"guide__sec inView fadeUp\">\n                      <div class=\"ttl2 guide__sec-ttl\">\n  <h3 class=\"ttl2__ja\">求める人物像</h3>\n</div>                    <ul class=\"guide__list\">\n                                                    <li class=\"guide__list-item\">\n                                <div class=\"guide__list-label\">必ず必要な<br class=\"sp\">資格・<br>スキル・<br class=\"sp\">経験年数等</div>\n                                <div class=\"guide__list-txt\">\n                                    ・普通自動車免許\n                                </div>\n                            </li>\n                                                                            <li class=\"guide__list-item\">\n                                <div class=\"guide__list-label\">学歴</div>\n                                <div class=\"guide__list-txt\">\n                                    短大・高専・専門学校卒以上\n                                </div>\n                            </li>\n                                            </ul>\n                </section>\n            \n            <section class=\"guide__sec inView fadeUp\">\n                  <div class=\"ttl2 guide__sec-ttl\">\n  <h3 class=\"ttl2__ja\">待遇</h3>\n</div>                <ul class=\"guide__list\">\n                                            <li class=\"guide__list-item\">\n                            <div class=\"guide__list-label\">雇用形態</div>\n                            <div class=\"guide__list-txt\">\n                                正社員\n                            </div>\n                        </li>\n                                                                <li class=\"guide__list-item\">\n                            <div class=\"guide__list-label\">給与</div>\n                            <div class=\"guide__list-txt\">\n                                月給169,900～265,000\n                            </div>\n                        </li>\n                                                                <li class=\"guide__list-item\">\n                            <div class=\"guide__list-label\">給与形態</div>\n                            <div class=\"guide__list-txt\">\n                                月給制（残業代別途）+賞与\n                            </div>\n                        </li>\n                                                                <li class=\"guide__list-item\">\n                            <div class=\"guide__list-label\">諸手当</div>\n                            <div class=\"guide__list-txt\">\n                                通勤手当、住宅手当、家族手当、資格手当等\n                            </div>\n                        </li>\n                                                                <li class=\"guide__list-item\">\n                            <div class=\"guide__list-label\">勤務時間</div>\n                            <div class=\"guide__list-txt\">\n                                8:30～17:15\n                            </div>\n                        </li>\n                                                                <li class=\"guide__list-item\">\n                            <div class=\"guide__list-label\">休日休暇</div>\n                            <div class=\"guide__list-txt\">\n                                122日<br />\r\n土曜、日曜、祝日、盆休暇、年末年始休暇は原則休み。ただし、土曜日については年間３日間ほど出勤日有。有給休暇は半年経過後に10日間付与。\n                            </div>\n                        </li>\n                                                                <li class=\"guide__list-item\">\n                            <div class=\"guide__list-label\">勤務地</div>\n                            <div class=\"guide__list-txt\">\n                                東京、神奈川、新潟、富山、石川、福井、静岡、愛知、大阪<br />\r\n※将来的に転勤となる可能性があります。\n                            </div>\n                        </li>\n                                                                <li class=\"guide__list-item\">\n                            <div class=\"guide__list-label\">福利厚生</div>\n                            <div class=\"guide__list-txt\">\n                                各種社会保険、退職金制度、文化会活動、勤続10周年海外旅行、勤続20周年リフレッシュ休暇、<br />\r\n勤続30周年ハッピー休暇、勤続40周年サンクス休暇、資格取得祝金、誕生月休暇 等\n                            </div>\n                        </li>\n                                    </ul>\n            </section>\n        </div>\n    </div>\n\n\n         \n<div class=\"gallery\">\n    <div class=\"gallery__inner\">\n        <div class=\"gallery__block --to-r\">\n            <div class=\"gallery__item\">  \t      <picture>\n              <source srcset=\"/bundles/web/img/recruit/index/gallery/img-gallery1-1@2x.jpg\" media=\"screen and (min-width: 1441px)\">\n    <img class=\"\" src=\"/bundles/web/img/recruit/index/gallery/img-gallery1-1.jpg\" srcset=\"/bundles/web/img/recruit/index/gallery/img-gallery1-1@2x.jpg 2x\" alt=\"\"  >\n  </picture>\n</div>\n            <div class=\"gallery__item\">  \t      <picture>\n              <source srcset=\"/bundles/web/img/recruit/index/gallery/img-gallery1-2@2x.jpg\" media=\"screen and (min-width: 1441px)\">\n    <img class=\"\" src=\"/bundles/web/img/recruit/index/gallery/img-gallery1-2.jpg\" srcset=\"/bundles/web/img/recruit/index/gallery/img-gallery1-2@2x.jpg 2x\" alt=\"\"  >\n  </picture>\n</div>\n            <div class=\"gallery__item\">  \t      <picture>\n              <source srcset=\"/bundles/web/img/recruit/index/gallery/img-gallery1-3@2x.jpg\" media=\"screen and (min-width: 1441px)\">\n    <img class=\"\" src=\"/bundles/web/img/recruit/index/gallery/img-gallery1-3.jpg\" srcset=\"/bundles/web/img/recruit/index/gallery/img-gallery1-3@2x.jpg 2x\" alt=\"\"  >\n  </picture>\n</div>\n            <div class=\"gallery__item\">  \t      <picture>\n              <source srcset=\"/bundles/web/img/recruit/index/gallery/img-gallery1-4@2x.jpg\" media=\"screen and (min-width: 1441px)\">\n    <img class=\"\" src=\"/bundles/web/img/recruit/index/gallery/img-gallery1-4.jpg\" srcset=\"/bundles/web/img/recruit/index/gallery/img-gallery1-4@2x.jpg 2x\" alt=\"\"  >\n  </picture>\n</div>\n        </div>\n        <div class=\"gallery__block --to-l\">\n    