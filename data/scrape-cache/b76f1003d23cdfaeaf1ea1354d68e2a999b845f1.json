: 20px;\n      padding: 10px 20px;\n      background: #fff;\n      border: none;\n      cursor: pointer;\n      font-size: 16px;\n    }\n    .about-sp-mordal-3 {\n      display: none;\n      position: fixed;\n      top: 0;\n      left: 0;\n      width: 100%;\n      height: 100%;\n      background: rgba(0, 0, 0, 0.5);\n      z-index: 1000;\n      justify-content: center;\n      align-items: center;\n      flex-direction: column;\n    }\n    .about-sp-mordal-3 img {\n      max-width: 90%;\n      max-height: 80%;\n      border: none;\n      cursor: pointer;\n    }\n    .about-sp-mordal-3 .about-sp-mordal-close-3 {\n      margin-top: 20px;\n      padding: 10px 20px;\n      background: #fff;\n      border: none;\n      cursor: pointer;\n      font-size: 16px;\n    }\n  </style>\n\n  <!-- Google Tag Manager -->\n  <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\n  new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\n  j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n  'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n  })(window,document,'script','dataLayer','GTM-56JFC64');</script>\n  <!-- End Google Tag Manager -->\n  <script src=\"https://ajax.googleapis.com/ajax/libs/jquery/3.3.1/jquery.min.js\"></script>\n</head>\n\n<body>\n  <!-- Google Tag Manager (noscript) -->\n  <noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-56JFC64\"\n  height=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n  <!-- End Google Tag Manager (noscript) -->\n\n    \n  <div class=\"desktop-view about screen\">\n    <div id=\"header\"></div>\n    <div class=\"container\">\n      <div class=\"overlap-group1\">\n        <img class=\"image-bg02-1\" src=\"images/common/section-title-bg.jpg\" alt=\"BG02 1\">\n\n        <h1 id=\"about-us\" class=\"title\">About us</h1>\n      </div>\n\n      <div class=\"scrollable-area\">\n        <div class=\"scrollable-menu\">\n          <ul class=\"scrollable-list\">\n            <li class=\"check\" data-section=\"about-business\">SMFLレンタルについて</li>\n            <li data-section=\"about-keywords\">キーワードで見るSMFLレンタル</li>\n            <li data-section=\"about-company\">会社情報</li>\n            <li data-section=\"about-philosophy\">経営理念</li>\n          </ul>\n        </div>\n        <section id=\"about-business\" class=\"section-content\">\n          <div class=\"about-us-smfl about-us-2\">\n            <div class=\"flex-col\">\n              <div class=\"lower-section-title\">\n                <div class=\"overlap-group-1 overlap-group-5\">\n                  <img class=\"ellipse-1\" src=\"images/about/ellipse-1-2.svg\" alt=\"Ellipse 1\">\n                  <div class=\"smfl notosanscjkjp-bold-blue-whale-40px\">SMFLレンタルについて</div>\n                </div>\n              </div>\n              <div class=\"lower-subtitle\">\n                <div class=\"ellipse-2\"></div>\n                <div class=\"text notosanscjkjp-medium-blue-whale-24px\">当社の価値</div>\n              </div>\n              <div class=\"text_label notosanscjkjp-medium-blue-whale-16px\">\n                ただモノをリースしてお金を得るのではなく、モノを介して機器の設定や保守などの付加価値を提供することが私たちの役割。企業力を活かし、幅広い商材を取り扱っています。また、お客さまの課題に挑むソリューションサービスに注力していることも私たちの強みです。\n              </div>\n              <div class=\"lower-subtitle-1\">\n                <div class=\"ellipse-2\"></div>\n                <div class=\"text notosanscjkjp-medium-blue-whale-24px\">当社の未来</div>\n              </div>\n              <div class=\"text_label notosanscjkjp-medium-blue-whale-16px\">\n                「所有から利用へ」。いまサブスクリプションやシェアリングエコノミーといったサービスが普及する中、人々の価値観や消費行動は急激に変化しています。一方、SDGsの浸透で廃棄物削減などの環境配慮に社会的関心が高まっています。こうした背景のもと、モノのライフサイクルに責任を持って取り組むレンタル産業の市場は年々拡大し続けています。\n              </div>\n              <div class=\"overlap-group1-1\">\n              </div>\n            </div>\n          </div>\n        </section>\n\n        <section id=\"about-keywords\" class=\"section-content\">\n          <div class=\"about-us-smfl-1\">\n            <div class=\"lower-section-title-1 lower-section-title-3\">\n              <div class=\"overlap-group-2 overlap-group-5\">\n                <img class=\"ellipse-1\" src=\"images/about/ellipse-1-3.svg\" alt=\"Ellipse 1\">\n                <div class=\"smfl notosanscjkjp-bold-blue-whale-40px\">キーワードで見るSMFLレンタル</div>\n              </div>\n            </div>\n            <div class=\"kw\">\n              <div class=\"kw-item\">\n                <div class=\"text-67 notosanscjkjp-bold-white-32px\">コンサルティング＆提案力</div>\n                <div class=\"text-68 notosanscjkjp-medium-white-16px\">人材のチカラこそが当社の原動力！</div>\n              </div>\n              <div class=\"kw-modal\">\n                <div class=\"kw-item\">\n                  <div class=\"text-69 notosanscjkjp-bold-white-32px\">5年連続増収増益！</div>\n                  <div class=\"view js-modal-open\" data-modal=\"modal1\">\n                    <div class=\"text-2 notosanscjkjp-medium-blue-jeans-14px\">詳細をみる</div>\n                    <img src=\"images/about/-----1.svg\" class=\"image\">\n                  </div>\n                </div>\n                <div class=\"modal js-modal\" id=\"modal1\">\n                  <img src=\"images/about/modal1.png\" style=\"width:520px; height: auto;\" alt=\"5年連続増収増益\">\n                  <div class=\"modal-close js-modal-close\" style=\"top:55px; right:60px;\">\n                    <img src=\"images/about/close-button.png\" alt=\"閉じる\">\n                  </div>\n                </div>\n              </div>\n              <div class=\"kw-item\">\n                <div class=\"win-win-win notosanscjkjp-bold-white-32px\">win-win-winの営業スタイル</div>\n                <div class=\"text-71 notosanscjkjp-medium-white-16px\">お客様・メーカー/サプライヤーそれぞれにメリットを提供</div>\n              </div>\n              <div class=\"kw-item\">\n                <div class=\"text-72 notosanscjkjp-bold-white-32px\">テクニカルセンター</div>\n                <div class=\"text-73 notosanscjkjp-medium-white-16px\">当社が誇る製品保管・メンテナンス拠点</div>\n              </div>\n              <div class=\"kw-modal\">\n                <div class=\"kw-item\">\n                  <div class=\"text-74 notosanscjkjp-bold-white-32px\">全国5ヶ所の拠点</div>\n                  <div class=\"text-75 notosanscjkjp-medium-white-16px\">全国各地のお客様に、サービスを提供</div>\n                  <div class=\"view\">\n                    <div class=\"view js-modal-open\" data-modal=\"modal2\">\n                      <div class=\"text-2 notosanscjkjp-medium-blue-jeans-14px\">詳細をみる</div>\n                      <img src=\"images/about/-----1.svg\" class=\"image\">\n                    </div>\n                  </div>\n                </div>\n                <div class=\"modal js-modal\" id=\"modal2\">\n                  <img src=\"images/about/modal2.png\" alt=\"全国5ヶ所の拠点\">\n                  <div class=\"modal-close js-modal-close\"></div>\n                </div>\n              </div>\n              <div class=\"kw-item\">\n                <div class=\"text-77 notosanscjkjp-bold-white-32px\">レンタルビジネスの開拓者になれる</div>\n                <div class=\"text-78 notosanscjkjp-medium-white-16px\">まだ世の中に出回っていないモノやサービスを見つけ出し、新たなレンタルサービスを社会に提供できる\n                </div>\n              </div>\n              <div class=\"kw-item\">\n                <div class=\"text-79 notosanscjkjp-bold-white-32px\">最先端の技術に関われる</div>\n                <div class=\"it notosanscjkjp-medium-white-16px\">レンタルサービスを通じて、新しいモノや技術の発展に貢献することができる</div>\n              </div>\n              <div class=\"kw-modal\">\n                <div class=\"kw-item\">\n                  <div class=\"text-80 notosanscjkjp-bold-white-32px\">信頼の三井住友ファイナンス<br>＆リースグループ</div>\n                  <div class=\"view\">\n                    <div class=\"view js-modal-open\" data-modal=\"modal3\">\n                      <div class=\"text-2 notosanscjkjp-medium-blue-jeans-14px\">詳細をみる</div>\n                      <img src=\"images/about/-----1.svg\" class=\"image\">\n                    </div>\n                  </div>\n                </div>\n                <div class=\"modal js-modal\" id=\"modal3\">\n                  <img src=\"images/about/modal3.png\" alt=\"5年連続増収増益の詳細\">\n                  <div class=\"modal-close js-modal-close\"></div>\n                </div>\n              </div>\n            </div>\n          </div>\n        </section>\n        <section id=\"about-company\" class=\"section-content\">\n          <div class=\"about-us\">\n            <div class=\"lower-section-title-3\">\n              <div class=\"overlap-group-3 overlap-group-5\">\n                <img class=\"ellipse-1\" src=\"images/about/ellipse-1-4.svg\" alt=\"Ellipse 1\">\n                <div class=\"smfl notosanscjkjp-bold-blue-whale-40px\">会社情報</div>\n              </div>\n            </div>\n            <a href=\"https://www.smfl-r.co.jp/company/profile/\" class=\"button-2\">\n              <div class=\"text-44 valign-text-bottom\">会社情報はこちら</div>\n              <img class=\"icon-1\" src=\"images/top/icon-4.svg\" alt=\"icon\">\n            </a>\n          </div>\n        </section>\n        <section id=\"about-philosophy\" class=\"section-content\">\n          <div class=\"philosophy\">\n            <div class=\"lower-section-title-3\">\n              <div class=\"overlap-group-3 overlap-group-5\">\n                <img class=\"ellipse-1\" src=\"images/about/ellipse-1-4.svg\" alt=\"Ellipse 1\">\n                <div class=\"smfl notosanscjkjp-bold-blue-whale-40px\">経営理念</div>\n              </div>\n            </div>\n            <img src=\"images/about/Frame.jpg\" class=\"frame\">\n          </div>\n        </section>\n      </div>\n\n    </div>\n    <div id=\"footer\"></div>\n  </div>\n\n  <div class=\"mobile-view about-sp screen\">\n    <div class=\"smp-lower-top\">\n      <div class=\"overlap-group\">\n        <div class=\"bg\">\n          <img class=\"image-bg02-1\" src=\"images/about/image---bg02-1.png\" alt=\"BG02 1\">\n        </div>\n        <h1 id=\"about-us\" class=\"title en48px\">About us</h1>\n        <div id=\"header-sp\"></div>\n      </div>\n    </div>\n\n    <div class=\"smp-about-us-smfl smp-about-us-2\">\n      <div class=\"flex-col\">\n        <div class=\"smp-lower-section-title-1\">\n          <div class=\"overlap-group-1 overlap-group-5\">\n            <img class=\"ellipse-1\" src=\"images/about/ellipse-1-2.svg\" alt=\"Ellipse 1\">\n            <div class=\"smfl notosanscjkjp-bold-blue-whale-24px\">SMFLレンタルについて</div>\n          </div>\n        </div>\n        <div class=\"smp-lower-subtitle\">\n          <div class=\"ellipse-2\"></div>\n          <div class=\"text notosanscjkjp-medium-blue-whale-16px\">当社の価値</div>\n        </div>\n        <div class=\"text_label notosanscjkjp-medium-blue-whale-14px\">\n          ただモノをリースしてお金を得るのではなく、モノを介して機器の設定や保守などの付加価値を提供することが私たちの役割。企業力を活かし、幅広い商材を取り扱っています。また、お客さまの課題に挑むソリューションサービスに注力していることも私たちの強みです。\n        </div>\n        <div class=\"smp-lower-subtitle-1\">\n          <div class=\"ellipse-2\"></div>\n          <div class=\"text notosanscjkjp-medium-blue-whale-16px\">当社の未来</div>\n        </div>\n        <div class=\"text_label-1 notosanscjkjp-medium-blue-whale-14px\">\n          「所有から利用へ」。いまサブスクリプションやシェアリングエコノミーといったサービスが普及する中、人々の価値観や消費行動は急激に変化しています。一方、SDGsの浸透で廃棄物削減などの環境配慮に社会的関心が高まっています。こうした背景のもと、モノのライフサイクルに責任を持って取り組むレンタル産業の市場は年々拡大し続けています。\n        </div>\n        <div class=\"overlap-group1\">\n        </div>\n      </div>\n    </div>\n\n    <div class=\"smp-about-us-smfl-1\">\n      <div class=\"smp-lower-section-title-2 smp-lower-section-title-3\">\n        <div class=\"overlap-group-2 overlap-group-5\">\n          <img class=\"ellipse-1\" src=\"images/about/ellipse-1-1.svg\" alt=\"Ellipse 1\" />\n          <div class=\"smfl-1 notosanscjkjp-bold-blue-whale-24px\">キーワードで見る<br />SMFLレンタル</div>\n        </div>\n      </div>\n    </div>\n    <div class=\"kw\">\n      <div class=\"kw-item kw-2\">\n        <div class=\"text-3-1 inter-bold-white-16px\">コンサルティ