ion(btn) {\n        btn.addEventListener(\"click\", function() {\n          var modalName = this.getAttribute(\"data-modal\");\n          var modal = document.getElementById(\"about-sp-mordal-3\");\n          if(modal) {\n            modal.style.display = \"flex\";\n          }\n        });\n      });\n      var modalCloseBtn = document.querySelector(\".about-sp-mordal-close-3\");\n      if(modalCloseBtn) {\n        modalCloseBtn.addEventListener(\"click\", function() {\n          var modal = document.getElementById(\"about-sp-mordal-3\");\n          if(modal) {\n            modal.style.display = \"none\";\n          }\n        });\n      }\n    });\n  </script>\n</body>\n\n</html>","finalUrl":"https://www.smfl-r.co.jp/saiyo/about.html","rendered":false,"_cachedAt":"2026-06-22T22:46:10.405Z"}