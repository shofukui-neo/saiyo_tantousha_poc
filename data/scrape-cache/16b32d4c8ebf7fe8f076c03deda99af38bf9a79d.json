     <!-- /logo -->\n      <!-- global navi -->\n      <nav role=\"navigation\" class=\"gNav gNav-accordion drawer-nav\">\n        <ol class=\"clearfix drawer-menu\">\n          <li class=\"gNav__item gNav__item--normal gNav__item--message\">\n            <a href=\"message_index.html\" class=\"hoverNot\">\n              <span class=\"en\">MESSAGE</span>先輩メッセージ\n            </a>\n          </li>\n          <li class=\"gNav__item gNav__item--normal gNav__item--crosstalk\">\n            <a href=\"crosstalk.html\" class=\"hoverNot\">\n              <span class=\"en\">CROSSTALK</span>新人座談会\n            </a>\n          </li>\n          <li class=\"gNav__item gNav__item--normal gNav__item--work\">\n            <a href=\"work.html\" class=\"hoverNot\">\n              <span class=\"en\">WORK</span>今岡工業の仕事\n            </a>\n          </li>\n          <li class=\"gNav__item gNav__item--guide accordion close\">\n            <a href=\"guide_new_grad.html\" class=\"trigger hoverNot\">\n              <span class=\"en\">GUIDE</span>募集要項\n            </a>\n            <ul class=\"accordionMenu--mobile accordionMenu--pc\">\n              <li><a href=\"guide_new_grad.html\"><span>新卒の方</span></a></li>\n              <li><a href=\"guide_kisotsu_kentiku.html\"><span>既卒 建築技術</span></a></li>\n              <li><a href=\"guide_kisotsu_doboku.html\"><span>既卒 土木技術</span></a></li>\n              <li><a href=\"guide_kisotsu_eigyou.html\"><span>既卒 営業職</span></a></li>\n            </ul>\n          </li>\n          <li class=\"gNav__item gNav__item--normal gNav__item--faq\">\n            <a href=\"faq.html\" class=\"hoverNot\">\n              <span class=\"en\">FAQ</span>よくある質問\n            </a>\n          </li>\n          <li class=\"gNav__item gNav__item--normal gNav__item--entry\">\n            <a href=\"/recruite_form/index\" class=\"hoverNot\">\n              <span class=\"en\">ENTRY</span>エントリー\n            </a>\n          </li>\n          <li class=\"gNav__item gNav__item--close dn-pc\">\n            <a class=\"drawer-toggle\">\n              閉じる\n            </a>\n          </li>\n        </ol>\n      </nav>\n      <!-- /global navi -->\n      <!-- mobile menu -->\n      <div id=\"close\" class=\"headerArea__menuBtn dn-pc drawer-toggle\">\n        <span class=\"dn\">MENU</span>\n      </div>\n      <!-- /mobile menu -->\n    </div>\n  </header>\n  <!-- /header -->\n\n  <!-- main container -->\n  <main>\n    <div role=\"main\">\n      <!-- h1 -->\n      <h1 class=\"sub-category sub-category--massage\">\n        <span class=\"sub-category__inner\">\n          <span class=\"catNameEn\">MESSAGE</span>\n          <span class=\"catName\">先輩メッセージ</span>\n        </span>\n      </h1>\n      <!-- /h1 -->\n\n      <!-- breadcrumbs -->\n      <div class=\"sub-breadcrumbs dn-mobile\">\n        <ol class=\"l-container-sub clearfix\">\n          <li><a href=\"index.html\">トップページ</a></li>\n          <li><a href=\"message_index.html\">先輩メッセージ</a></li>\n          <li>三原 尚悟</li>\n        </ol>\n      </div>\n      <!-- /breadcrumbs -->\n\n      <!-- l-container-sub -->\n      <div class=\"l-container-sub sub-container\">\n        <section>\n          <!-- h2 -->\n          <h2 class=\"mod-hl-01 mod-hl-01--catTag\">\n            <span class=\"icon-training icon\">&thinsp;</span>\n            三原 尚悟\n            <span class=\"en\">Mihara Shougo</span>\n            <span class=\"small\">2015年に入社</span>\n            <span class=\"catTag\">建築施工管理</span>\n          </h2>\n          <!-- /h2 -->\n          <!-- articleBox-01 -->\n          <div class=\"column-articleBox-subRight--w300 l-innerBox clearfix\">\n            <div class=\"mod-column-sub\">\n              <img src=\"img/massage/bnr_06.jpg\" alt=\"スタッフ写真\" class=\"imgFit\">\n            </div>\n            <div class=\"mod-column-main\">\n              <div class=\"mod-column-main__inner\">\n                <section>\n                  <h3 class=\"mod-hl-02\">\n                    <span class=\"icon\">Q</span>今岡工業に入社したきっかけは何ですか？\n                  </h3>\n                  <p>\n                    中学生の頃に自宅の増築があったのですが、その時に働いている大工さんの姿をみて、建築への興味が湧きました。<br>\n                    高校卒業後に京都の建築関係の大学で建築構造や設計について勉強し、卒業後に地元出雲にUターンしました。\n                  </p>\n                  <p class=\"marginTop10\">\n                    もともと地元で就職したいと思っていたのと、学生時代の先輩で今岡工業に入社していた方がいたことで興味を持ちました。<br>\n                    先輩は忙しそうにされていたのですが、仕事にやりがいを持って働いている印象で、自分も今岡工業でやりがいのある仕事がしたいと思い、入社を決めました。\n                  </p>\n                </section>\n                <section class=\"marginTop30\">\n                  <h3 class=\"mod-hl-02\">\n                    <span class=\"icon\">Q</span>実際に働いてみていかがでしょうか？\n                  </h3>\n                  <p>\n                    やはり実際の現場にでてみると分からないことも多く、最初は上司や先輩に教えてもらって一生懸命に覚えました。<br>\n                    大変でしたが、上司や先輩の様子を見ながら自分の頭で考えて学んだことも多く、それが今では大切な経験になっています。\n                  </p>\n                </section>\n              </div>\n            </div>\n          </div>\n          <!-- /articleBox-01 -->\n          <!-- articleBox-02 -->\n          <div class=\"column-articleBox-subLeft--w300 l-innerBox marginTop60 clearfix\">\n            <div class=\"mod-column-sub\">\n              <img src=\"img/massage/pic_face06.jpg\" alt=\"スタッフ写真\" class=\"imgFit\">\n            </div>\n            <div class=\"mod-column-main\">\n              <div class=\"mod-column-main__inner\">\n                <section>\n                  <h3 class=\"mod-hl-02\">\n                    <span class=\"icon\">Q</span>この仕事のやりがいはなんですか？\n                  </h3>\n                  <p>\n                    日々、建物が出来上がっていく様子を目の当たりにするのは楽しい体験です。最後まで完成したときの達成感、喜びも大きく、そうした事がやりがいになっていると思います。<br>\n                    また、業務の進行について自分で考え、段取りをつけたことがスムーズに進捗したときは嬉しく感じます。自分が考え、経験し、学んできたことが活かされている実感があるからです。\n                  </p>\n                </section>\n                <section class=\"marginTop30\">\n                  <h3 class=\"mod-hl-02\">\n                    <span class=\"icon\">Q</span>今後の目標があれば教えて下さい。\n                  </h3>\n                  <p>\n                    いまは一級建築士を目指して勉強しています。資格の学校に通ったり、休みの日に勉強したりしていますが、上司や先輩など同僚が気にかけてくれたり応援してくれたりします。<br>\n                    本当にありがたいと思います。難しい資格だとは思いますが、自分の好きな仕事なので乗り切れると思っています。\n                  </p>\n                </section>\n              </div>\n            </div>\n          </div>\n          <!-- /articleBox-02 -->\n          <!-- articleBox-03 -->\n          <!-- <div class=\"column-articleBox-subRight--w300 l-innerBox marginTop60 clearfix\">\n              <div class=\"mod-column-sub\">\n                <img src=\"img/massage/pic_sample.jpg\" alt=\"スタッフ写真\" class=\"imgFit\">\n              </div>\n              <div class=\"mod-column-main\">\n                <div class=\"mod-column-main__inner\">\n                  <section>\n                    <h3 class=\"mod-hl-02\">\n                      <span class=\"icon\">Q</span>プライベートは何をしていますか？\n                    </h3>\n                    <p>\n                      この文章はダミーです。文字の大きさ、量、字間、行間等を確認するために入れています。この文章はダミーです。文字の大きさ、量、字間、行間等を確認するために入れています。この文章はダミーです。文字の大きさ、量、字間、行間等を確認するために入れています。\n                      この文章はダミーです。文字の大きさ、量、字間、行間等を確認するために入れています。この文章はダミーです。文字の大きさ、量、字間、行間等を確認するために入れています。この文章はダミーです。文字の大きさ、量、字間、行間等を確認するために入れています。\n                    </p>\n                  </section>\n                </div>\n              </div>\n            </div> -->\n          <!-- /articleBox-03 -->\n          <!-- btn -->\n          <div class=\"marginTop60 textCenter\">\n            <a href=\"message_index.html\" class=\"mod-btn-02 mod-btn-w300\">\n              <span class=\"icon-menu\">&thinsp;</span> 一覧に戻る\n            </a>\n          </div>\n          <!-- /btn -->\n        </section>\n      </div>\n      <!-- /l-container-sub -->\n    </div>\n  </main>\n  <!-- /main container -->\n\n  <!-- footer -->\n  <footer role=\"contentinfo\" class=\"mod-bg-cSub\">\n    <!-- footer -->\n    <div class=\"footer clearfix\">\n      <!-- main -->\n      <div class=\"footer_