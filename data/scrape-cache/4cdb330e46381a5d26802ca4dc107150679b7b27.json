n                  <div class=\"col-3\"> <a href=\"../products/kensetsu/index.html\"> <img src=\"../img/m2_house.jpg\" alt>建設エンジニアリング部門</a>\r\n                    <ul>\r\n                      <li><a href=\"../products/kensetsu/kensetsu.html\">建設</a></li>\r\n                      <li><a href=\"../products/kensetsu/denki.html\">電気</a></li>\r\n                      <li><a href=\"../products/kensetsu/plant.html\">プラント</a></li>\r\n                      <li><a href=\"../products/kensetsu/rnd.html\">研究開発</a></li>\r\n                    </ul>\r\n                  </div>\r\n                  <div class=\"col-3\"> <a href=\"../products/hoken/index.html\"> <img src=\"../img/m2_hoken.jpg\" alt>保険部門</a>\r\n                    <ul>\r\n                      <li><a href=\"../products/hoken/main.html#hoken_01\">取扱商品</a></li>\r\n                      <li><a href=\"../products/hoken/main.html#hoken_02\">勧誘方針</a></li>\r\n                    </ul>\r\n                  </div>\r\n                </div>\r\n              </li>\r\n            </ul>\r\n          </li>\r\n          <li class=\"current-menu-item current_page_item rrr-mega-menu\"> <a href=\"index.html\">採用情報</a>\r\n            <ul class=\"mega-menu mega_mine\">\r\n              <li class=\"mega-menu-container\">\r\n                <h2>採用情報</h2>\r\n                <div class=\"row\">\r\n                  <div class=\"col-4\"> <a href=\"message.html\"> <img src=\"../img/m3_msg.jpg\" alt>採用担当者より </a> </div>\r\n                  <div class=\"col-4\"> <a href=\"list.html\"> <img src=\"../img/m3_list.jpg\" alt>社員インタビュー </a> </div>\r\n                  <div class=\"col-4\"> <a href=\"guideline.html\"> <img src=\"../img/m3_gd.jpg\" alt>募集要項 </a> </div>\r\n                </div>\r\n              </li>\r\n            </ul>\r\n          </li>\r\n          <li class=\"rrr-mega-menu\"> <a href=\"../csr/\">サステナビリティ</a>\r\n            <ul class=\"mega-menu mega_mine\">\r\n              <li class=\"mega-menu-container\">\r\n                <h2>サステナビリティ</h2>\r\n                <div class=\"row\">\r\n                  <div class=\"col-4\"> <a href=\"../csr/\"> <img src=\"../img/m4_csr.png\" alt>基本理念 </a> </div>\r\n                  <div class=\"col-4\"> <a href=\"../csr/graph.html\"> <img src=\"../img/m4_iso.png\" alt>環境への取り組み </a> </div>\r\n                  <div class=\"col-4\"> <a href=\"../csr/health.html\"> <img src=\"../img/m4_health.png\" alt>健康経営 </a> </div>\r\n                </div>\r\n              </li>\r\n            </ul>\r\n          </li>\r\n          <li class=\"m_catalog\">\r\n            <div class=\"m_catalog_inner\">\r\n              <div> <img src=\"../img/aaa.png\" alt> </div>\r\n              <div>\r\n                <p>Company Brochure</p>\r\n                <a href=\"../doc/nikkeisangyo_en.pdf?v=2508\" target=\"_blank\"><img src=\"../img/m_dl.png\" alt>English</a> <span>/</span> <a href=\"../doc/nikkeisangyo_jp.pdf?v=2604\" target=\"_blank\"><img src=\"../img/m_dl.png\" alt>日本語</a> </div>\r\n            </div>\r\n          </li>\r\n        </ul>\r\n      </nav>\r\n    </div>\r\n  </div>\r\n</header>\r\n<main class=\"r24p r24_hoke\">\r\n  \r\n  <div class=\"breadcrumbs breadcrumbs_r24\">\r\n    <ol>\r\n      <li><a href=\"/\">HOME</a></li>\r\n      <li><a href=\"index.html\">採用情報</a></li>\r\n      <li><a href=\"list.html\">社員インタビュー</a></li>\r\n      <li>インタビュー詳細</li>\r\n    </ol>\r\n  </div>  \r\n  \r\n  <section class=\"r24p_mainv\">  \r\n    \r\n    <div class=\"txtbox\">\r\n      <div class=\"subttl\">\r\n        <span class=\"txt\">INTERVIEW</span>\r\n        <span class=\"num\">11</span>\r\n      </div>\r\n      <div class=\"info\">\r\n        <span class=\"job\">日軽パートナーズ保険部</span>\r\n        <span class=\"year\">2018年入社</span>\r\n      </div>\r\n      <h1 class=\"words\">\r\n        <span>\r\n        立派な一流の<br>\r\n        営業マンになりたいです\r\n        </span>\r\n      </h1>\r\n    </div>\r\n    <div class=\"image bgextend\">\r\n      <div class=\"bgappear\">\r\n        <img src=\"img/11/main.jpg\" alt>\r\n      </div>\r\n    </div>\r\n  </section>\r\n  \r\n  <section class=\"r24p_video\">\r\n  <div class=\"inner\">\r\n    \r\n    <a href=\"#iframe-v\" class=\"videobox\" data-lity>\r\n      <img class=\"video\" src=\"img/11/videoimg.jpg\" alt>\r\n      </a>\r\n    <div id=\"iframe-v\" class=\"jst_video lity-hide\" style=\"overflow:auto; background:#FDFDF6; width:800px; max-width:100%;\"> \r\n      <iframe src=\"https://api01-platform.stream.co.jp/apiservice/plt3/MzYyNQ%3d%3d%23NDkw%23280%23168%230%2337E6A0D86400%23OzEwOzEwOzEw%23\" width=\"100%\" height=\"100%\" style=\"position:absolute\" frameborder=\"0\" allowfullscreen referrerpolicy=\"no-referrer-when-downgrade\" ></iframe>\r\n      </div>\r\n    <div class=\"txtbox\">\r\n      <span class=\"backtxt\">VIDEO</span>\r\n      <h3>インタビュー動画</h3>\r\n      </div>\r\n    \r\n  </div>    \r\n  </section>  \r\n  \r\n  <section class=\"r24p_sec r24p_sec_1\">\r\n  <div class=\"inner\">\r\n    \r\n    <div class=\"qnabox\">   \r\n      <section class=\"r24p_qna\">\r\n        <p class=\"num\">#01\r\n          <span class=\"question\">Question</span>\r\n          </p>\r\n        <h2 class=\"\"><span>日軽産業を選んだ理由は</span></h2>\r\n        <p class=\"answer\">\r\n          もともと私は前職が金融関係の仕事をしていたんですが、引き続き金融というお仕事をしてお客様ですとか、人々のために役に立ちたいっていうことを思っていまして、そういった面で日軽産業保険部を選びました。\r\n          </p>\r\n        </section>\r\n      <section class=\"r24p_qna\">\r\n        <p class=\"num\">#02\r\n          <span class=\"question\">Question</span>\r\n          </p>\r\n        <h2 class=\"\"><span>どんな雰囲気の会社ですか</span></h2>\r\n        <p class=\"answer\">\r\n          日軽産業の雰囲気はとても和気藹々としていて、とても働きやすい職場だと思っています。困ったことがありましたら先輩ですとか、上司に気軽に相談できます。\r\n          </p>\r\n        </section>\r\n      </div>\r\n    \r\n    <div class=\"imgbox\">   \r\n      <figure>\r\n        <img src=\"img/11/01.jpg\" alt>\r\n        </figure>\r\n      </div>\r\n    \r\n  </div>  \r\n  </section>\r\n  \r\n  <figure class=\"r24p_wide bgextend\">\r\n    <div class=\"bgappear\">\r\n      <img src=\"img/11/wide.jpg\" alt>\r\n    </div>\r\n  </figure>  \r\n  \r\n  <section class=\"r24p_sec r24p_sec_2\">\r\n  <div class=\"inner\">\r\n    \r\n    <div class=\"qnabox\">   \r\n      <section class=\"r24p_qna\">\r\n        <p class=\"num\">#03\r\n          <span class=\"question\">Question</span>\r\n          </p>\r\n        <h2 class=\"\"><span>現在どんな仕事をしていますか</span></h2>\r\n        <p class=\"answer\">\r\n          保険の法人向けの保険代理店営業を行っておりまして、具体的には自動車保険ですとか、火災保険ですとか、そういった保険を企業様に対して提案するという仕事を行っています。\r\n          様々なリスクがあると思いますので、そういったリスクを的確にヒアリングして、そこからニーズを引き出してこちらが最適な商品を提案するといったことを主にやっております。\r\n          </p>\r\n        </section>\r\n      <section class=\"r24p_qna\">\r\n        <p class=\"num\">#04\r\n          <span class=\"question\">Question</span>\r\n          </p>\r\n        <h2 class=\"\"><span>一番やりがいを感じるのは<br>どんな時ですか</span></h2>\r\n        <p class=\"answer\">\r\n          何度も何度も足を運ぶことで、やっと社長様ですとか、担当者様がお話を聞いてくれて、ぜひこれ採用しようということでお話をいただけることがありまして、その提案が通った時がやっぱり一番やりがいがあるなと感じております。\r\n          </p>\r\n        </section>\r\n      <section class=\"r24p_qna\">\r\n        <p class=\"num\">#05\r\n          <span class=\"question\">Question</span>\r\n          </p>\r\n        <h2 class=\"\"><span>今後はどんな仕事に<br>チャレンジしたいですか</span></h2>\r\n        <p class=\"answer\">\r\n          今は、法人向けの損害保険業というのは火災保険、自動車保険ですとか、賠償責任保険ですとか、そういった企業様向けの保険を提案しているんですけども、\r\n          今度はですね、社長様ですとか従業員様ですとか、そういった働いている方々に対して医療保険を提案したいなと思ってます。\r\n          </p>\r\n        </section>\r\n      </div>\r\n    \r\n    <div class=\"imgbox\">   \r\n      <figure>\r\n        <img src=\"img/11/tate.jpg\" alt>\r\n        </figure>\r\n      </div>\r\n    \r\n  </div>  \r\n  </section>  \r\n  \r\n  <section class=\"r24p_sec r24p_sec_3\">\r\n  <div class=\"inner\">\r\n    \r\n    <div class=\"qnabox\">   \r\n      \r\n      <section class=\"r24p_qna\">\r\n        <p class=\"num\">#06\r\n          <span class=\"question\">Question</span>\r\n          </p>\r\n        <h2 class=\"\"><span>趣味はなんですか</span></h2>\r\n        <p class=\"answer\">\r\n          ウィスキーを飲むことです。週末に地元の友人と飲んだり、また仕事がえりですとか、会社が新橋ですのでバーに行ったりして、ウイスキーを沢山飲んだりします。\r\n          </p>\r\n        </section>\r\n      <section class=\"r24p_qna\">\r\n        <p class=\"num\">#07\r\n          <span class=\"question\">Question</span>\r\n          </p>\r\n        <h2 class=\"\"><span>将来の夢はなんですか</span></h2>\r\n        <p class=\"answer\">\r\n          目指している、こうなりたいという先輩がいます。\r\n          先輩のようになれるように商品の勉強や、営業方法の勉強ですとか、そういったことを日々精進して学んで、立派な一流の営業マンになりたいなと思ってます。\r\n          それが私の夢です。\r\n          </p>\r\n        </section>\r\n      </div>\r\n    \r\n    <div class=\"imgbox\">   \r\n      <figure>\r\n        <img src=\"img/11/02.jpg\" alt>\r\n        </figure>\r\n      </div>\r\n    \r\n  </div>  \r\n  </section>  \r\n  \r\n</main>  \r\n\t\r\n<section class=\"r24p_others\">\r\n  <div class=\"inner\">\r\n    <div class=\"ttl\"> <span class=\"eng\">Other Interviews</span>\r\n      <h2>社員インタビュー</h2>\r\n    </div>\r\n    <div class=\"memberlist\">\r\n      <div class=\"r24i_ppl r24i_ppl_shou\"> <a href=\"03.html\">\r\n        <div class=\"imgbox\"> <img src=\"img/03/r24i_03.png\" alt> </div>\r\n        <div class=\"txtbox\">\r\n          <p class=\"job\">静岡支店</p>\r\n          <p class=\"name\">2021年入社</p>\r\n        </div>\r\n        </a> </div>\r\n      <div class=\"r24i_ppl r24i_ppl_shou\"> <a href=\"04.html\">\r\n        <div class=\"imgbox\"> <img src=\"img/04/r24i_04.png\" alt> </div>\r\n        <div class=\"txtbox\">\r\n          <p class=\"job\">大阪支店</p>\r\n          <p class=\"name\">2020年入社</p>\r\n        </div>\r\n        </a> </div>\r\n      <div class=\"r24i_ppl r24i_ppl_kanr\"> <a href=\"05.html\">\r\n        <div class=\"imgbox\"> <img src=\"img/05/r24i_05.png\" alt> </div>\r\n        <div class=\"txtbox\">\r\n          <p class=\"job\">経理部</p>\r\n          <p class=\"name\">2017年入社</p>\r\n        </div>\r\n        </a> </div>\r\n      <div class=\"r24i_ppl r24i_ppl_kens\"> <a 