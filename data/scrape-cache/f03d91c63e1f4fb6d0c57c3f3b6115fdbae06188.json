/javascript\" src=\"/niigata-hitachi/js/jp/r1/wide.js\"></script>\n<script type=\"text/javascript\" src=\"/niigata-hitachi/js/jp/r1/common_option.js\"></script>\n<script type=\"text/javascript\" src=\"/niigata-hitachi/js/jp/r1/common2.js\"></script>\n</head>\n<body>\n\n<p id=\"top\"><a href=\"#body\">ページの本文へ</a></p>\n\n<div id=\"HeaderArea1\">\n\t<div class=\"Container Wide\">\n\n\t\t<div id=\"Statement\"><a href=\"https://www.hitachi.co.jp/\"><img src=\"/niigata-hitachi/image/jp/r1/common2/corp_id.png\" alt=\"Hitachi\"></a></div>\n\n\t\t<div id=\"SupportNavi\" class=\"SupportNaviIconText\">\n\n\t\t\t<a href=\"/niigata-hitachi/inquiry/\"><img src=\"/niigata-hitachi/image/jp/r1/common2/icon_mail.png\" alt=\"お問い合わせ\"><span>お問い合わせ</span></a>\n\n\t\t\t<button type=\"button\" id=\"SupportNaviSearch\" aria-expanded=\"false\" aria-controls=\"SearchFormArea\"><span><img src=\"/niigata-hitachi/image/jp/r1/common2/icon_search.png\" alt=\"検索\"><span>検索</span></span></button>\n\t\t\t<div id=\"SearchFormArea\">\n\t\t\t\t<div>\n\t\t\t\t\t<button class=\"BtnClose\" aria-label=\"閉じる\"></button>\n\t\t\t\t\t<div class=\"mf_finder_container\">\n\t\t\t\t\t\t<mf-search-box\n\t\t\t\t\t\t\tajax-url=\"https://finder.api.mf.marsflag.com/api/v1/finder_service/documents/b3df513a/search\"\n\t\t\t\t\t\t\tserp-url=\"https://module.hitachi.com/search/RGN_JAPAN.html\"\n\t\t\t\t\t\t\tplaceholder=\"日立グループ全体から検索\"\n\t\t\t\t\t\t\tsubmit-text=\"検索\"\n\t\t\t\t\t\t\timgsize-default=\"3\"\n\t\t\t\t\t\t\tdoctype-hidden \n\t\t\t\t\t\t\toptions-hidden\n\t\t\t\t\t\t></mf-search-box>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div><!--/#SearchFormArea-->\n\t\t</div><!--/#SupportNavi-->\n\n\t\t<button id=\"SpMenuBtn\" aria-label=\"メニュー\">\n\t\t\t<span></span>\n\t\t\t<span></span>\n\t\t\t<span></span>\n\t\t</button>\n\n\t</div><!--/.Container-->\n</div><!--/#HeaderArea1-->\n\n<div id=\"HeaderArea2\">\n\t<div class=\"Container Wide\">\n\t\t<div id=\"SiteID\">\n\t\t\t<a href=\"https://www.hitachi-hansya.jp/niigata-hitachi/\"><img src=\"/niigata-hitachi/image/jp/r1/site_id.gif\" alt=\"株式会社新潟日立\"><span>株式会社新潟日立</span></a>\n\t\t</div>\n\t\t<ul id=\"GlobalNaviMenu\">\n\t\t\t<li><a href=\"/niigata-hitachi/news/\">お知らせ</a></li>\n\t\t\t<li><a href=\"/niigata-hitachi/product/\">取扱製品</a></li>\n\t\t\t<li><a href=\"/niigata-hitachi/kouji/\">工事</a></li>\n\t\t\t<li><a href=\"/niigata-hitachi/service/\">保守・メンテナンス</a></li>\n\t\t\t<li><a href=\"/niigata-hitachi/about/\">会社情報</a></li>\n\t\t\t<li><a href=\"/niigata-hitachi/new-building/\">新社屋紹介</a></li>\n\t\t\t<li class=\"Current\"><a href=\"/niigata-hitachi/recruit/\"><em>採用情報</em></a></li>\n\t\t\t<li><a href=\"/niigata-hitachi/sports/\">イベント</a></li>\n\t\t</ul>\n\t</div><!--/.Container-->\n</div><!--/#HeaderArea2-->\n\n<div id=\"TopicPath\">\n<ul>\n<li class=\"FirstItem\"><a href=\"/niigata-hitachi/\">サイトトップ</a></li>\n<li><a href=\"/niigata-hitachi/recruit/\">採用情報</a></li>\n<li><strong>経験者採用</strong></li>\n</ul>\n</div><!--/TopicPath-->\n<div id=\"Contents\">\n<div class=\"GridSet\">\n<div class=\"Grid3\">\n\n<div class=\"PageTitleStyle1\">\n<h1><a name=\"body\" id=\"body\">経験者採用</a></h1>\n</div><!--/PageTitle-->\n<!--Hitachi Website Generator:Start of Component[niigata-hitachi/recruit/experience/index.html]-->\n<div class=\"Section\">\n<h2><span>採用情報</span></h2>\n<table class=\"TableStyle3\">\n<caption>採用情報</caption>\n<colgroup><col width=\"90\" /><col /></colgroup>\n<tr>\n<th scope=\"row\">募集職種</th>\n<td>\n\t空調・衛生設備工事の施工管理\n</td>\n</tr>\n<tr>\n<th scope=\"row\">募集人数</th>\n<td>若干名</td>\n</tr>\n<tr>\n<th scope=\"row\">応募資格</th>\n<td>\n\t空調・衛生設備工事に興味がある方<br />\n\t　未経験からでもチャレンジできます。<br />\n\t　経験のある方、管工事施工管理技士（一級・二級）の方は優遇いたします。\n</td>\n</tr>\n</table>\n</div><!--/Section-->\n\n<div class=\"Section\">\n<ul class=\"PageTop\"><li><a href=\"#top\">ページの先頭へ</a></li></ul>\n</div><!--/Section-->\n\n<div class=\"Section\">\n<h2><span>待遇と勤務</span></h2>\n<table class=\"TableStyle3\">\n<caption>待遇と勤務</caption>\n<colgroup><col width=\"90\" /><col /></colgroup>\n<tr>\n<th scope=\"row\">賃金</th>\n<td>基本給　215,000～295,000円<br />\n子供・介護等支援手当　対象となる扶養親族1人につき6,000円/月</td>\n</tr>\n<tr>\n<th scope=\"row\">昇給</th>\n<td>年1回</td>\n</tr>\n<tr>\n<th scope=\"row\">賞与</th>\n<td>年2回</td>\n</tr>\n<tr>\n<th scope=\"row\">勤務時間</th>\n<td>8:00～17:15（昼休み12:00～13:00）<br />\n    フレックスタイムでの勤務可能（コアタイムなし）<br />\n\t残業時間月平均19.9時間(2024年度)</td>\n</tr>\n<tr>\n<th scope=\"row\">休日</th>\n<td>完全週休2日制（2026年度126日）</td>\n</tr>\n<tr>\n<th scope=\"row\">休暇</th>\n<td>年次有給休暇（24日）取得日数平均18.2日/人（2024年度)<br />\n    1時間単位の年次有給休暇取得も可能<br />\n\t家族看護休暇、育児休暇等　育児休暇取得実績有</td>\n</tr>\n<tr>\n<th scope=\"row\">諸手当</th>\n<td>通勤手当、家族手当、住宅手当 他</td>\n</tr>\n<tr>\n<th scope=\"row\">福利厚生</th>\n<td>各種社会保険、社宅、社員持株会、慶弔見舞金</td>\n</tr>\n<tr>\n<th scope=\"row\">労働組合</th>\n<td>なし</td>\n</tr>\n<tr>\n<th scope=\"row\">勤務地</th>\n<td>新潟県内</td>\n</tr>\n</table>\n</div><!--/Section-->\n\n<div class=\"Section\">\n<ul class=\"PageTop\"><li><a href=\"#top\">ページの先頭へ</a></li></ul>\n</div><!--/Section-->\n\n<div class=\"Section\">\n<h2><span>応募要項</span></h2>\n<table class=\"TableStyle3\">\n<caption>応募要項</caption>\n<colgroup><col width=\"90\" /><col /></colgroup>\n<tr>\n<th scope=\"row\">提出書類</th>\n<td>履歴書<br />\n職務経歴書<br />\n健康診断書</td>\n</tr>\n<tr>\n<th scope=\"row\">選考方法</th>\n<td>書類、筆記、面接</td>\n</tr>\n<tr>\n<th scope=\"row\">応募方法</th>\n<td>下記メール又は電話にて</td>\n</tr>\n<tr>\n<th scope=\"row\">連絡先</th>\n<td>総務部　佐々木まで<br />\nTEL：025-273-1160<br />\nFAX：025-272-0100<br />\nMail：<a href=\"mailto:info@niigatahitachi.co.jp\">info@niigatahitachi.co.jp</a>\n</td>\n\n</tr>\n</table>\n</div><!--/Section-->\n\n<div class=\"Section\">\n<p class=\"TextStyle1\">送信された個人情報は、お問い合わせに回答した時点で消去し、個人情報を保有することはありません。弊社の個人情報保護に関しましては<a href=\"../../privacy/index.html\">こちら</a>をご参照ください。</p>\n</div><!--/Section-->\n\n<!--Hitachi Website Generator:End of Component[niigata-hitachi/recruit/experience/index.html]-->\n<div class=\"Section\">\n<ul class=\"PageTop\"><li><a href=\"#top\">ページの先頭へ</a></li></ul>\n</div>\n\n</div><!--/Grid3