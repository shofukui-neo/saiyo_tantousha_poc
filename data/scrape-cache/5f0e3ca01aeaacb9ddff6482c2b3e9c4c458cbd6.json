ef='https://www.kbs-web.com/docomo/recruit/wp-includes/css/dist/block-library/style.min.css?ver=5.4.1' type='text/css' media='all' />\n<link rel='https://api.w.org/' href='https://www.kbs-web.com/docomo/recruit/wp-json/' />\n<link rel=\"EditURI\" type=\"application/rsd+xml\" title=\"RSD\" href=\"https://www.kbs-web.com/docomo/recruit/xmlrpc.php?rsd\" />\n<link rel=\"wlwmanifest\" type=\"application/wlwmanifest+xml\" href=\"https://www.kbs-web.com/docomo/recruit/wp-includes/wlwmanifest.xml\" /> \n<meta name=\"generator\" content=\"WordPress 5.4.1\" />\n<link rel=\"canonical\" href=\"https://www.kbs-web.com/docomo/recruit/message/matters/\" />\n<link rel='shortlink' href='https://www.kbs-web.com/docomo/recruit/?p=102' />\n<link rel=\"alternate\" type=\"application/json+oembed\" href=\"https://www.kbs-web.com/docomo/recruit/wp-json/oembed/1.0/embed?url=https%3A%2F%2Fwww.kbs-web.com%2Fdocomo%2Frecruit%2Fmessage%2Fmatters%2F\" />\n<link rel=\"alternate\" type=\"text/xml+oembed\" href=\"https://www.kbs-web.com/docomo/recruit/wp-json/oembed/1.0/embed?url=https%3A%2F%2Fwww.kbs-web.com%2Fdocomo%2Frecruit%2Fmessage%2Fmatters%2F&#038;format=xml\" />\n<link rel=\"icon\" href=\"https://www.kbs-web.com/docomo/recruit/wp-content/uploads/sites/2/2017/09/logo_mark.png\" sizes=\"32x32\" />\n<link rel=\"icon\" href=\"https://www.kbs-web.com/docomo/recruit/wp-content/uploads/sites/2/2017/09/logo_mark.png\" sizes=\"192x192\" />\n<link rel=\"apple-touch-icon\" href=\"https://www.kbs-web.com/docomo/recruit/wp-content/uploads/sites/2/2017/09/logo_mark.png\" />\n<meta name=\"msapplication-TileImage\" content=\"https://www.kbs-web.com/docomo/recruit/wp-content/uploads/sites/2/2017/09/logo_mark.png\" />\n\t\t<style type=\"text/css\" id=\"wp-custom-css\">\n\t\t\t* {\n-webkit-appearance: none;\n}\n\n.link_talent {\ncolor:#cc0033;\nfont-weight:bold;\ntext-shadow:#fff 2px 2px 5px, #fff -2px 2px 5px,\n    #fff 2px -2px 5px, #fff -2px -5px 2px,\n    #fff 1px 2px 5px, #fff -1px 2px 5px,\n    #fff 1px -2px 5px, #fff -1px -2px 5px,\n    #fff 2px 1px 5px, #fff -2px 1px 5px,\n    #fff 2px -1px 5px, #fff -2px -1px 5px,\n    #fff 1px 1px 5px, #fff -1px 1px 5px,\n    #fff 1px -1px 5px, #fff -1px -1px 5px;\n}\n\n.link_talent:hover {\n   color:#cc0033;\n   text-decoration:none;\n}\n\n.link_talent:visited {\n   color:#cc0033;\n   text-decoration:none;\n}\n\n.tri::before{\n\tcontent: \"\";\n    padding-left:25px;\nbackground: url(https://www.kbs-web.com/docomo/recruit/wp-content/uploads/sites/2/2017/10/img_tri_red.png\n) no-repeat 0px center;\n}\n\n#content input[type=\"submit\"]:hover {\n\tbackground-color: #ccc;\n}\n\n\n\n\n\t\t</style>\n\t\t\n</head>\n\n<body id=\"\" class=\"page-template-default page page-id-102 page-child parent-pageid-100\">\n<div id=\"\">\n\n\n<div class=\"header_wrap\">\n<div id=\"header\">\n<div class=\"logo\">\n<a href=\"https://www.kbs-web.com/docomo/recruit/\"><img src=\"https://www.kbs-web.com/docomo/recruit/wp-content/themes/original2/contents_images/logo.png\" width=\"332px\" height=\"70px\" alt=\"KBSドコモ求人サイト｜株式会社ビジネスサービス\"/></a>\n</div>\n\n<div class=\"navi\">\n\t\t\t<div class=\"textwidget\"><p><a class=\"link_talent tri\" href=\"https://www.kbs-web.com/docomo/recruit/message/matters/\">募集要項・ご応募</a>　　<a href=\"https://www.kbs-web.com/\"><img class=\"image wp-image-41 attachment-full size-full\" style=\"max-width: 100%; height: auto;\" src=\"https://www.kbs-web.com/docomo/recruit/wp-content/uploads/sites/2/2017/09/logo_company.png\" alt=\"\" width=\"242\" height=\"38\" /></a></p>\n</div>\n\t\t</div>\n<div style=\"clear: both;\"></div>\n</div>\n</div>\n\n\n<div id=\"menu\">\n\t<div class=\"menu-main-menu-container\"><ul id=\"menu-main-menu\" class=\"menu\"><li id=\"menu-item-141\" class=\"menu-item menu-item-type-custom menu-item-object-custom menu-item-141\"><a href=\"https://www.kbs-web.com/docomo/recruit/message/\">私たちの想い</a></li>\n<li id=\"menu-item-144\" class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-144\"><a href=\"https://www.kbs-web.com/docomo/recruit/favorite/\">ココが好き！</a></li>\n<li id=\"menu-item-146\" class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-146\"><a href=\"https://www.kbs-web.com/docomo/recruit/shop/\">ショップ紹介</a></li>\n<li id=\"menu-item-150\" class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-150\"><a href=\"https://www.kbs-web.com/docomo/recruit/company/\">企業情報</a></li>\n</ul></div><div style=\"clear: both;\"></div>\n</div>\n\n<div id=\"wrap\">\n<div id=\"content\">\n\n\n<h1>募集要項・ご応募</h1>\n\n<div class=\"post\">\n\n<p><img class=\"alignnone size-full wp-image-1110\" src=\"https://www.kbs-web.com/docomo/recruit/wp-content/uploads/sites/2/2022/01/slider_02-1-1024x467-1.jpg\" alt=\"\" width=\"1024\" height=\"467\" srcset=\"https://www.kbs-web.com/docomo/recruit/wp-content/uploads/sites/2/2022/01/slider_02-1-1024x467-1.jpg 1024w, https://www.kbs-web.com/docomo/recruit/wp-content/uploads/sites/2/2022/01/slider_02-1-1024x467-1-300x137.jpg 300w, https://www.kbs-web.com/docomo/recruit/wp-content/uploads/sites/2/2022/01/slider_02-1-1024x467-1-768x350.jpg 768w\" sizes=\"(max-width: 1024px) 100vw, 1024px\" /></p>\n<h2>募集要項</h2>\n<p>地域限定正社員の募集です。（青森、弘前、八戸地域のご希望地域での勤務になります）</p>\n<table style=\"width: 100%\" border=\"1\" cellspacing=\"10\">\n<tbody>\n<tr>\n<th>勤務時間</th>\n<td>\n<p>◎シフト制（実働8時間）</p>\n<p>9:45～18:45<br />\n10:30～19:30</p>\n</td>\n</tr>\n<tr>\n<th>給与</th>\n<td>月給170,000円～200,000円<br />\n※経験、年齢等を考慮し当社規定により優遇します。</td>\n</tr>\n<tr>\n<th>昇給・賞与</th>\n<td>昇給：年1回<br />\n賞与：年2回</td>\n</tr>\n<tr>\n<th>諸手当</th>\n<td>通勤手当<br />\n役付手当<br />\n家族手当<br />\n資格手当</td>\n</tr>\n<tr>\n<th>休日・休暇</th>\n<td>◎年間休日123日<br />\n月9日以上シフト制<br />\n有給休暇<br />\n慶弔休暇<br />\n育児休業制度<br />\n介護休業制度<br />\n看護等休暇制度<br />\n結婚特別休暇<br />\n出産立合特別休暇<br />\n勤続慰労休暇</td>\n</tr>\n<tr>\n<th>雇用期間</th>\n<td>雇用期間の定めなし<br />\n※試用期間期間2か月あり。（期間中の待遇に変更はありません。）</td>\n</tr>\n<tr>\n<th>勤務地</th>\n<td>\n<p>青森県内 8店舗</p>\n<p>青森市/弘前市/八戸市/十和田市/三沢市</p>\n<p>希望を最大限考慮します。</p>\n</td>\n</tr>\n<tr>\n<th>\n<p>応募資格</p>\n</th>\n<td>\n<ul>\n<li>高卒以上</li>\n<li>週5日勤務できる方</li>\n<li>未経験OK</li>\n<li>既婚者歓迎</li>\n</ul>\n</td>\n</tr>\n<tr>\n<th>\n<p>待遇・福利厚生</p>\n</th>\n<td>\n<ul>\n<li>研修制度あり</li>\n<li>経験者優遇</li>\n<li>制服貸与</li>\n<li>社会保険完備</li>\n<li>有給休暇</li>\n<li>昇給制度</li>\n<li>社割あり</li>\n</ul>\n</td>\n</tr>\n<tr>\n<th>求人事業所名</th>\n<td>株式会社ビジネスサービス</td>\n</tr>\n</tbody>\n</table>\n<h2>ご応募</h2>\n<p>～当社では地域限定正社員制度を導入しております～<br />\nご希望の地域に根差し、地域のお客様に貢献しながら活躍できます。</p>\n<h3>送付書類</h3>\n<p>◆応募の際は、必要書類を下記送付先へ郵送または持参して下さい◆<br />\n※地域限定正社員の募集です。（青森、弘前、八戸地域のご希望地域での勤務になります）</p>\n</p>\n<p>◆履歴書（顔写真貼付）<br />\n◆募集採用時における個人情報の取扱い同意書（当社指定の様式）<br />\n※事前にお問い合わせの上、お取り寄せ下さい。</p>\n</p>\n<h3>お問い合わせ先／履歴書送付先</h3>\n<p><span style=\"font-size: 120%\"><strong>青森地域（ドコモショップ青森新町店、青森東店）</strong></span></p>\n<p style=\"padding-left: 30px\">〒030-0843　青森市浜田豊田156-2<br />\n株式会社ビジネスサービス　青森支店人事担当　宛<br />\nTEL：０１７－７６２－０２３１</p>\n</p>\n<p><span style=\"font-size: 120%\"><strong>弘前地域（ドコモショップ弘前城東店、イオンタウン弘前樋の口店）</strong></span></p>\n<p style=\"padding-left: 30px\">〒036-8084　弘前市高田3丁目6-7<br />\n株式会社ビジネスサービス　弘前支店人事担当　宛<br />\nTEL：０１７２－２８－５２００</p>\n</p>\n<p><span style=\"font-size: 120%\"><strong>八戸地域（ドコモショップ八戸根城店、南類家店、十和田店、三沢店）</strong></span></p>\n<p style=\"padding-left: 30px\">〒031-0022　八戸市糠塚字下道16<br />\n株式会社ビジネスサービス　八戸支店人事担当　宛<br />\nTEL：０１７８－４６－２０８３</p>\n</p>\n<p>応募は随時受付しております。試験日等については後日連絡致します。</p>\n</p>\n<h3>メールでのお問い合わせ</h3>\n<p>募集採用時における個人情報の取扱い同意書・その他質問に関して、メールでのお問い合わせはこちらから承ります。</p>\n<p><a class=\"more2\" href=\"https://www.kbs-web.com/docomo/recruit/privacy/\"><span class=\"link\">メールでのお問い合わせ</span></a></p>\n</p>\n<h3>採用プロセス</h3>\n<p><span style=\"font-size: 120%\"><strong>１．書類選考</strong></span></p>\n<p>　お送りいただいた書類をもとに選考いたします。<br />\n※選考後、今後の面接日程等については追ってご連絡いたします。<br />\n面接の希望日時等がある方は、ご相談下さい。</p>\n<p><span style=\"font-size: 120%\"><strong>２．面接＋採用試験</strong></span></p>\n<p>　書類選考後、面接、一般常識試験、適性検査、性格検査を実施します。</p>\n<p>　当社での展望や意欲などを、ぜひアピールして下さい。</p>\n<p><span style=\"font-size: 120%\"><strong>３．内定</strong></span></p>\n<p>　入社日はご相談に応じます。在職中の方も気兼ねなくエントリーして下さい。<br />\n※試験結果の合否は1週間程でご連絡します。</p>\n</p>\n<h3>選考の特徴</h3>\n<p>・面接日程応相談</p>\n<p>・入社時期応相談</p>\n\n\n</div>\n \n\t\n</div>\n\n<div id=\"column\">\n\n<!-- ▼親ページ取得▼ -->\n<div class=\"categorytitle\">\n<a href=\"https://www.kbs-web.com/docomo/recruit/message/\">メッセージ</a>\n</div>\n<!-- ▲親ページ取得▲ -->\n\n\n\n<!-- ▼子・孫ページ取得▼ -->\n<ul class=\"categorymenu\">\n<li class=\"page_item page-item-98\"><a href=\"https://www.kbs-web.com/docomo/recruit/message/talent/\">求める人材</a></li>\n<li class=\"page_item page-item-102 current_page_item\"><a href=\"https://www.kbs-web.com/docomo/recruit/message/matters/\" aria-current=\"page\">募集要項・ご応募</a></li>\n<li class=\"page_item page-item-268\"><a href=\"https://www.kbs-web.com/docomo/recruit/message/faq/\">FAQ</a></li>\n<li class=\"page_item page-item-643\"><a href=\"https://www.kbs-web.com/docomo/recruit/message/privacy/\">メールでのお問い合わせ</a></li>\n</ul>\n<!-- ▲子・孫ページ取得▲ -->\n\n\n</div><div style=\"clear: both;\"></div>\n\n</div>\n\n\n\n<div class=\"footer_banner\">\n<div class=\"wrap\">\n    \t\t\t<div class=\"block banner\">\n\t\t\t\t\t<p><a href=\"https://www.kbs-web.com/docomo/recruit/message/matters/\"></a><a href=\"https://www.kbs-web.com/docomo/recruit/message/matters/\"><img class=\"alignnone size-full wp-image-368\" src=\"https://www.kbs-web.com/docomo/recruit/wp-content/uploads/sites/2/2017/10/img_otoiawase.jpg\" alt=\"\" width=\"487\" height=\"123\" srcset=\"https://www.kbs-web.com/docomo/recruit/wp-content/uploads/sites/2/2017/10/img_otoiawase.jpg 487w, https://www.kbs-web.com/docomo/recruit/wp-content/uploads/sites/2/2017/10/img_otoiawase-300x76.jpg 300w\" sizes=\"(max-width: 487px) 100vw, 487px\" /></a><a href=\"https://www.kbs-web.com/docomo/recruit/message/faq/\"><img class=\"alignnone size-full wp-image-367\" src=\"https://www.kbs-web.com/docomo/recruit/wp-content/uploads/sites/2/2017/10/img_faq.jpg\" alt=\"\" width=\"487\" height=\"123\" srcset=\"https://www.kbs-web.com/docomo/recruit/wp-content/uploads/sites/2/2017/10/img_faq.jpg 487w, https://www.kbs-web.com/docomo/recruit/wp-content/uploads/sites/2/2017/10/img_faq-300x76.jpg 300w\" sizes=\"(max-width: 487px) 100vw, 487px\" /></a></p>\n\t\t\t\t\t\t\t\t\t</div>\n\t\t\t</div>\n</div>\n\n<div id=\"footerwrap\">\n\n<div class=\"ga_about\" ><span style=\"font-size: 80%;\"></span><span style=\"font-size: 80%;\">\nGoogle Analyticsについて<br />\n当サイトでは、Google Analytics（Google アナリティクス）を利用したアクセス解析を行っています。<br />\nGoogle Analytics は、サイトへのアクセス解析データを収集しますが、取得される情報は匿名のものであり、アクセス情報と閲覧者の個人情報を関連づけるものではありません。解析結果は、当サイトの質の向上、より良いコンテンツの提供を目的として利用するものです。<br />\n</span></div> \n    \n<div id=\"footer\">\n<a href=\"http://www.kbs-web.com/\" target=\"_blank\"><img src=\"https://www.kbs-web.com/docomo/recruit/wp-content/themes/original2/contents_images/footerlogo.png\" width=\"245\" height=\"37\" alt=\"\"/></a>\n<a class=\"link_docomo\" href=\"/docomo/\" target=\"_blank\">KBSドコモショップサイト</a>\n<span class=\"copy\">Copyright (c) 2017 Business Service Co.,LTD. All Rights Reserved. </span> </div></div>\n<a href=\"#\" id=\"page-top\"></a>\n\n<script type='text/javascript'>\n/* <![CDATA[ */\nvar SlimStatParams = {\"ajaxurl\":\"https:\\/\\/www.kbs-web.com\\/docomo\\/recruit\\/wp-admin\\/admin-ajax.php\",\"baseurl\":\"\\/docomo\\/recruit\",\"dnt\":\"noslimstat,ab-item\",\"ci\":\"YTozOntzOjEyOiJjb250ZW50X3R5cGUiO3M6NDoicGFnZSI7czoxMDoiY29udGVudF9pZCI7aToxMDI7czo2OiJhdXRob3IiO3M6OToia2Fucml1c2VyIjt9.faee8c4c5cd75197351ad048663e3136\"};\n/* ]]> */\n</script>\n<script type='text/javascript' src='https://cdn.jsdelivr.net/wp/wp-slimstat/tags/4.8.8.1/wp-slimstat.min.js'></script>\n<script type='text/javascript' src='https://www.kbs-web.com/docomo/recruit/wp-includes/js/wp-embed.min.js?ver=5.4.1'></script>\n\n</div>\n</body>\n</html>","finalUrl":"https://www.kbs-web.com/docomo/recruit/message/matters/","rendered":false,"_cachedAt":"2026-06-24T00:03:58.884Z"}