 setTimeout(() => {\n        textElement.classList.add(\"is-active\");\n    }, 500);\n});\n</script>\n<!-- InstanceEndEditable --> \n<script src=\"js/script.js\"></script>\n</body>\n<!-- InstanceEnd --></html>\n","finalUrl":"http://www.asahi-metal.com/","rendered":false,"_cachedAt":"2026-06-14T19:08:46.392Z"}