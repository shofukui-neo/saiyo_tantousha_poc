{"url":"https://www.kwl.co.jp/recruit.html","html":"<!doctype html>\n<html lang=\"ja\"><!-- InstanceBegin template=\"/Templates/base.dwt\" codeOutsideHTMLIsLocked=\"false\" -->\n<head>\n<meta http-equiv=\"Content-Type\" content=\"text/html; charset=utf-8\" />\n<!-- InstanceBeginEditable name=\"PageMetaArea\" -->\n<title>リクルート</title>\n<meta name=\"Description\" content=\"\">\n<meta name=\"Keywords\" content=\"\"> \n<!-- InstanceEndEditable -->\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1, minimum-scale=1, maximum-scale=4, user-scalable=yes\">\n<meta name=\"format-detection\" content=\"telephone=no\">\n<link rel=\"apple-touch-icon\" href=\"https://www.kwl.co.jp/images/common/webclip.png\">\n<link rel=\"shortcut icon\" type=\"image/x-icon\" href=\"favicon.ico\">\n<link href=\"css/reset.css\" rel=\"stylesheet\" type=\"text/css\">\n<link href=\"css/main.css\" rel=\"stylesheet\" type=\"text/css\">\n<script src=\"//ajax.googleapis.com/ajax/libs/jquery/1.11.1/jquery.min.js\"></script>\n<script src=\"js/slide_pagetop.js\" type=\"text/javascript\"></script>\n<script src=\"js/myScript.js\" type=\"text/javascript\"></script>\n<!--[if lt IE 9]> \n<script src=\"../js/html5shiv.js\"></script> \n<script src=\"../js/ie9.js\"></script>\n<script src=\"../js/flexibility.js\"></script>\n<![endif]-->\n<!-- InstanceBeginEditable name=\"HeadScript_BodyClassArea\" -->\n<link href=\"/css/recruit.css\" rel=\"stylesheet\" type=\"text/css\">\n</head>\n<body class=\"P_recruit recruit\">\n\n<!-- InstanceEndEditable -->\n\n<header class=\"Header\">\n\t<div id=\"menubtn\"><!-- スマホ／タブレット時に表示する -->\n\t\t<img src=\"images/common/menubtn_open.png\" class=\"menubtn-open\" alt=\"メニューを開く\">\n\t\t<img src=\"images/common/menubtn_close.png\" class=\"menubtn-close\" alt=\"メニューを閉じる\">\n\t</div>\n\n\t<div class=\"Header__head\"><!-- ロゴ -->\n\t\t<h1>\n\t\t\t<a href=\"/\"><img src=\"images/common/logo_header.png\" alt=\"SoBaNi 株式会社協同\"></a>\n\t\t</h1>\n\t</div>\n\n\t<nav class=\"Header__body\"><!-- グローバルメニュー -->\n\t\t<ul class=\"Menu\">\n\t\t\t<li class=\"Menu__category\">\n\t\t\t\t<a class=\"Menu__item\" href=\"/category/name/name_design.html\">CATEGORY<span>商品カテゴリー</span></a>\n\t\t\t\t<ul class=\"Menu__subMenu\">\n\t\t\t\t\t<li><a href=\"/category/name/name_design.html\" class=\"Menu__subItem\">ネーム</a></li>\n\t\t\t\t\t<li><a href=\"/category/labeltag/labeltag_design.html\" class=\"Menu__subItem\">ラベル・タグ</a></li>\n\t\t\t\t\t<li><a href=\"/category/wappen/wappen_design.html\" class=\"Menu__subItem\">ワッペン</a></li>\n\t\t\t\t\t<li><a href=\"/category/patch/patch_design.html\" class=\"Menu__subItem\">パッチ</a></li>\n\t\t\t\t\t<li><a href=\"/category/package/package_bag.html\" class=\"Menu__subItem\">包装資材・パッケージ</a></li>\n\t\t\t\t\t<li><a href=\"/category/marking/marking.html\" class=\"Menu__subItem\">マーキング・プリント加工</a></li>\n\t\t\t\t\t<li><a href=\"/category/printing/inji_method.html\" class=\"Menu__subItem\">印字</a></li>\n\t\t\t\t\t<li><a href=\"/category/sp_tool/sp_store.html\" class=\"Menu__subItem\">販促ツール</a></li>\n\t\t\t\t\t<li><a href=\"/category/planning/kikaku.html\" class=\"Menu__subItem\">企画・デザイン</a></li>\n\t\t\t\t</ul>\n\t\t\t</li>\n\t\t\t<li><a class=\"Menu__item\" href=\"/works/\">WORKS<span>事例紹介</span></a></li>\n\t\t\t<li><a class=\"Menu__item\" href=\"/topics/\">TOPICS<span>トピックス</span></a></li>\n\t\t\t<li><a class=\"Menu__item\" href=\"/recruit.html\">RECRUIT<span>リクルート</span></a></li>\n\t\t\t<li class=\"Menu__category\">\n\t\t\t\t<a class=\"Menu__item\" href=\"/about.html\">ABOUT<span>会社概要</span></a>\n\t\t\t\t<ul class=\"Menu__subMenu about\">\n\t\t\t\t\t<li><a href=\"/about.html\" class=\"Menu__subItem\">私たちについて</a></li>\n\t\t\t\t\t<li><a href=\"/csr.html\" class=\"Menu__subItem\">福利厚生・CSR</a></li>\n\t\t\t\t</ul>\n\t\t\t</li>\n\t\t\t<li><a class=\"Menu__item\" href=\"/contact/\">CONTACT<span>お問い合わせ</span></a></li>\n\t\t</ul>\n\t</nav>\n</header>\n\n<!-- InstanceBeginEditable name=\"ContentsArea\" -->\n\n\t<div class=\"VisualHeader\">\n\t\t<div class=\"l-max1300\">\n\t\t\t<img src=\"/images/recruit/V_recruit.jpg\" alt=\"トップイメージ\" class=\"fixed\">\n\t\t</div>\n\t</div>\n\n\t<main class=\"Main\">\n\t\t<div class=\"Main__head\">\n\t\t\t<h1 class=\"pageHeader\">リクルート</h1>\n\t\t</div>\n\t\t\n\t\t<div class=\"Section recruit\">\n\t\t\t<h2 class=\"Section__header with_underbar mincho\">リクルート</h2>\n\t\t\t<div class=\"Section__body\">\n\t\t\t\t<p class=\"leadText\">アイデアが生み出す、新しい可能性を追求し、<br>\n                ブランドネーム、ラベル、パッケージの企画・制作を<br>\n                共に手掛けるスタッフを求めています。<br>\n                </p>\n\t\t\t</div><!-- .Section__body -->\n\t\t</div><!-- .recruit -->\n\n\n\t\t<div class=\"Section point\">\n\t\t\t<h2 class=\"Section__header mincho\">募集のポイント</h2>\n\t\t\t<div class=\"Section__body\">\n\t\t\t\t<div class=\"l-tile\">\n\t\t\t\t\t<div class=\"pointItem top\">\n\t\t\t\t\t\t<h3 class=\"mincho\">ワッペン・タグの<br>トップクラス企業</h3>\n\t\t\t\t\t\t<p class=\"leadText\">ジーンズやユニフォーム、カジュアル<br>のメジャーブランドや、学生服の<br>業界大手などが<br>クライアントです。</p>\n\t\t\t\t\t</div>\n\n\t\t\t\t\t<div class=\"pointItem idea\">\n\t\t\t\t\t\t<h3 class=\"mincho\">アイデアが<br>求められる企画提案型</h3>\n\t\t\t\t\t\t<p class=\"leadText\">ゼロから作る企画商品がメイン。<br>「売る」だけでなく提案力・<br>企画力を磨ける職場です。</p>\n\t\t\t\t\t</div>\n\n\t\t\t\t\t<div class=\"pointItem tech\">\n\t\t\t\t\t\t<h3 class=\"mincho\">創業から60年を<br>超える信頼と技術力</h3>\n\t\t\t\t\t\t<p class=\"leadText\">積み重ねてきた信頼と技術力を<br>持つ安定した企業です。</p>\n\t\t\t\t\t</div>\n\n\t\t\t\t\t<div class=\"pointItem welcome\">\n\t\t\t\t\t\t<h3 class=\"mincho\">未経験者も<br>大歓迎</h3>\n\t\t\t\t\t\t<p class=\"leadText\">新風を吹き込む存在、<br>次世代の育成を図るため、<br>未経験者にも門戸を<br>広げて募集しています。</p>\n\t\t\t\t\t</div>\n\n\t\t\t\t</div>\n\t\t\t</div><!-- .Section__body -->\n\t\t</div><!-- .point -->\n\n\n\t\t<div class=\"Section routine\">\n\t\t\t<h2 class=\"Section__header mincho\">営業スタッフの1日</h2>\n\t\t\t<div class=\"l-column\">\n\t\t\t\t<div class=\"Section__main\">\n\t\t\t\t\t<dl class=\"schedule clearfix\">\n\t\t\t\t\t\t<dt>8:30</dt>\n\t\t\t\t\t\t<dd>\n\t\t\t\t\t\t\t<h3>「出社」</h3>\n\t\t\t\t\t\t\t<p>メールチェックをして今日の予定を確認。</p>\n\t\t\t\t\t\t</dd>\n\n\t\t\t\t\t\t<dt>9:30</dt>\n\t\t\t\t\t\t<dd>\n\t\t\t\t\t\t\t<h3>「社内ミーティング」</h3>\n\t\t\t\t\t\t\t<p>前日の商談結果やその日のスケジュールを報告・相談。</p>\n\t\t\t\t\t\t</dd>\n\n\t\t\t\t\t\t<dt>10:00</dt>\n\t\t\t\t\t\t<dd>\n\t\t\t\t\t\t\t<h3>「商談」</h3>\n\t\t\t\t\t\t\t<p>都市部は主に電車や徒歩で、地方は社用車で取引先へ。<br>事前にアポイントを取り、商談資料を準備し持参します。<br>出先でランチをとれるのは、外回りの楽しみの1つ♪</p>\n\t\t\t\t\t\t</dd>\n\n\t\t\t\t\t\t<dt>13:00</dt>\n\t\t\t\t\t\t<dd>\n\t\t\t\t\t\t\t<h3>「納品」</h3>\n\t\t\t\t\t\t\t<p>仕上がりに喜んでいただけるか...<br>納品する時は少し緊張します。<br>無事納品が済んだら、ほっと一息。<br>実際に店頭に並ぶ日が待ち遠しい！</p>\n\t\t\t\t\t\t</dd>\n\n\t\t\t\t\t\t<dt>16:00</dt>\n\t\t\t\t\t\t<dd>\n\t\t\t\t\t\t\t<h3>「発注」</h3>\n\t\t\t\t\t\t\t<p>1社のお客様に、営業担当（新規受注、商談）と<br>アシスタント（リピート受注、出荷等）の<br>2人セットで対応しています。<br>仕入先とやりとりするのも大切な勉強の一つ、<br>お客様からいただいたご注文を満足につなげるためには<br>ここの働きが大切です。</p>\n\t\t\t\t\t\t</dd>\n\n\t\t\t\t\t\t<dt class=\"small\">18：00～<br>19：00</dt>\n\t\t\t\t\t\t<dd>\n\t\t\t\t\t\t\t<h3>「退社」</h3>\n\t\t\t\t\t\t\t<p>翌日の段取りを確認してから退社します。</p>\n\t\t\t\t\t\t</dd>\n\t\t\t\t\t</dl>\n\n\t\t\t\t</div><!-- .Section__main -->\n\t\t\t\t<div class=\"Section__sub\">\n\t\t\t\t\t<img src=\"/images/recruit/img_routine1_test.jpg\" alt=\"営業スタッフの1日\">\n\t\t\t\t\t<img src=\"/images/recruit/img_routine2.jpg\" alt=\"納品\">\n\t\t\t\t</div><!-- .Section__sub -->\n\t\t\t</div>\n\t\t</div><!-- .routine -->\n\n\t\t<div class=\"Section voice\">\n\t\t\t<h2 class=\"Section__header mincho\">INTERVIEW</h2>\n\t\t\t<div class=\"Section__body\">\n\t\t\t\t<div class=\"VoiceItem octaBoxWH\">\n\t\t\t\t\t<div class=\"VoiceItem__main\">\n\t\t\t\t\t\t<div class=\"VoiceItem_youtube\">\n\t\t\t\t\t\t\t<iframe width=\"560\" height=\"315\" src=\"https://www.youtube.com/embed/H0J2JgYQpBg?si=w_B8SIJ_o-Stqd4J\" title=\"YouTube video player\" frameborder=\"0\" allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share\" referrerpolicy=\"strict-origin-when-cross-origin\" allowfullscreen></iframe>\n\t\t\t\t\t\t  </div>\n\t\t\t\t\t\t<article>\n\t\t\t\t\t\t\t<h4 class=\"mincho\">協同ってどんな会社？<br class=\"only-sp\">どんな人たちが働いているの？</h4>\n\t\t\t\t\t\t\t<p>社員自身が入社の動機や実際の仕事内容について紹介します。</p>\n\t\t\t\t\t\t</article>\n\t\t\t\t\t</div><!-- .VoiceItem__main -->\n\t\t\t\t\t\n\t\t\t\t</div><!-- .VoiceItem -->\n\t\t\t\t<!-- .VoiceItem -->\n\t\t\t\t\n\t\t\t</div><!-- .Section__body -->\n\t\t</div><!-- .voice -->\n\n\n\t\t<div class=\"Section requirements\">\n\t\t\t<h2 class=\"Section__header mincho\">募集要項</h2>\n\t\t\t<div class=\"Section__body octaBoxWH\">\n\t\t\t\t<ul class=\"detailSheet\">\n\t\t\t\t\t<dt>募集職種</dt>\n\t\t\t\t\t<dd>\n\t\t\t\t\t\t<p>■営業部門（営業・プランニング業務） ■企画部門（商品企画・デザイン業務）</p>\n\t\t\t\t\t</dd>\n\t\t\t\t\t<dt>応募資格</dt>\n\t\t\t\t\t<dd>\n\t\t\t\t\t\t<p>■30歳までの方（若年層の長期キャリア形成を図る為）<br>■普通自動車運転免許</p>\n\t\t\t\t\t\t<p>≪あれば生かせる経験≫ ※必須ではありません<br>■営業・接客の実務経験（業界年数不問）</p>\n\t\t\t\t\t</dd>\n\t\t\t\t\t<dt>求める人材</dt>\n\t\t\t\t\t<dd>\n\t\t\t\t\t\t<p>≪こんな方を求めています≫<br>■人の話を聴く、人と話すのが好き<br>■新しいアイデアを出すことにワクワクする<br>■ファッションに興味がある<br>■マーケットを調査し、提案に生かしたい<br>■自分のスキルや得意を活かしたい<br>　※過去には企画・マーケティングが得意な人を中心に課を新設した例もあります</p>\n\t\t\t\t\t</dd>\n\t\t\t\t\t<dt>勤務地</dt>\n\t\t\t\t\t<dd>\n\t\t\t\t\t\t<p>■岡山本社<br>　岡山県倉敷市児島下の町9丁目12番コ2号<br>■東京営業所<br>　東京都中央区日本橋富沢町7番14号 岡島ビル6Ｆ<br>■大阪営業所<br>　大阪市中央区博労町1-7-2 堺筋トラストビル404号<br>■岡山店<br>　岡山県岡山市北区今２丁目7−1<br>　※勤務地は希望を考慮します。</p>\n\t\t\t\t\t</dd>\n\n    \t\t\t\t<dt>勤務時間</dt>\n\t\t\t\t\t<dd>\n\t\t\t\t\t\t<p>■9：00～18:00<br>　※土曜日の出勤時は9：00～17：00</p>\n\t\t\t\t\t</dd>\n\t\t\t\t\t<dt>給与例<br>（営業職）</dt>\n\t\t\t\t\t<dd>\n\t\t\t\t\t\t<p class=\"dashLine\">■月給23万6000円～25万円＋諸手当<br>　※経験、能力を考慮の上、優遇します。<br>　※試用期間3ヶ月あり（試用期間中も給与は同額）。<br>　※上記の金額には、20時間分の見込み残業代が含まれます（営業職の場合）<br>　（20時間を超えた場合も残業手当は100％支給）。</p>\n\t\t\t\t\t\t\n\t\t\t\t\t\t<!--<p class=\"dashLine\">■モデル年収例<br>年収410万円<br>経験5年／基本給 23.5万円+役職手当1万円×12ヶ月分<br>　　　　  +賞与80万円（※残業手当含む）<br>年収550万円<br>経験10年／基本給 31万円+役職手当5万円×12ヶ月分<br>　　　　  +賞与100万円（※残業手当含む）</p>-->\n\t\t\t\t\t\t\n\t\t\t\t\t\t<p>■昇給／年1回<br>■賞与／年2回</p>\n\t\t\t\t\t</dd>\n\t\t\t\t\t<dt>諸手当</dt>\n\t\t\t\t\t<dd>\n\t\t\t\t\t\t<p>■通勤手当（通勤距離に応じて、上限1万8,700円まで。<br>　通勤手当の支給の代わりに、営業車を貸与する場合もあります。）<br>■残業手当<br>■地域手当（東京営業所・大阪営業所のみ）</p>\n\t\t\t\t\t</dd>\n\t\t\t\t\t<dt>休日・休暇</dt>\n\t\t\t\t\t<dd>\n\t\t\t\t\t\t<p>■休日／週休二日制（月1回程度土曜・日曜・祝日）（年間休日114日）<br>■休暇／ＧＷ・夏季休暇・年末年始休暇・有給休暇・ライフサポートSoBaNi休暇（取得目的が自由な法定外の有給休暇・年間5日）</p>                        \n                        \n\t\t\t\t\t</dd>\n\t\t\t\t\t<dt>福利厚生</dt>\n\t\t\t\t\t<dd>\n\t\t\t\t\t\t<p>■社会保険完備 ■退職金制度（確定拠出年金・中小企業退職金共済）<br>■AIG業務災害総合保険加入<br>　（日常生活で被ったケガから病気での入院まで幅広く補償。掛金会社負担)<br>■各種研修制度（産業能率大学:通信研修制度あり。受講料会社負担)<br>■資格取得支援制度（繊維製品品質管理士など、会社が推奨する資格に合格した際、<br>　奨励金支給。受験料会社負担)<br>■岡山シーガルズの優待観戦（弊社は岡山シーガルズを応援しています。)</p>\n\t\t\t\t\t</dd>\n\t\t\t\t\t\n\t\t\t\t\t<dt>表彰制度</dt>\n\t\t\t\t\t<dd>\n\t\t\t\t\t<p>■永年勤続表彰（勤続20年・30年）<br>\n\t\t\t\t\t■カエルシート表彰（改善への貢献）<br>\n\t\t\t\t\t■社長賞・部長賞表彰（業績への貢献）<br>\n\t\t\t\t\t■SoBaNiカード表彰（行動指針の実践）<br>\n\t\t\t\t\t■年間優秀社員表彰</p>\n\t\t\t\t\t</dd>\t\t\t\t\t\n\t\t\t\t\t\n\t\t\t\t\t<dt>くるみん認定</dt>\n\t\t\t\t\t<dd>\n\t\t\t\t\t\t<p>あなたが転職先を選ぶ際、会社の成長性や仕事のやりがいはもちろんですが「将来、結婚して子供を持ったとき、どんな働き方ができるのか？」も気になるところだと思います。協同では2016年10月、厚生労働大臣より「子育てサポート企業」として「くるみん認定」を取得しました。<br>\n\t\t\t\t\t    会社として、仕事と子育ての両立を応援しています。</p>\n\t\t\t\t\t</dd>\n\t\n\t\t\t\t</ul>\n\t\t\t\t\n\t\t\t</div><!-- .Section__body -->\n\t\t</div><!-- .requirements -->\n\n\n\t\t<div class=\"Section method\">\n\t\t\t<h2 class=\"Section__header mincho\">応募方法</h2>\n\t\t\t<div class=\"Section__body octaBoxWH\">\n\t\t\t\t<ul class=\"detailSheet\">\n\t\t\t\t\t<dt>募集職種</dt>\n\t\t\t\t\t<dd>\n\t\t\t\t\t\t<p>このページ下の「応募フォームへ」ボタンをクリックして、<br>お名前・ご連絡先（メールアドレス・TEL・住所）などをご記入の上、<br>フォームよりご応募ください。</p>\n\t\t\t\t\t</dd>\n\t\t\t\t\t<dt>応募受付<br>後の連絡</dt>\n\t\t\t\t\t<dd>\n\t\t\t\t\t\t<p class=\"dashLine\">ご応募いただいた皆様につきましては、後日弊社よりご連絡させていただきます。</p>\n\t\t\t\t\t</dd>\n\t\t\t\t\t<dt>会社説明会</dt>\n\t\t\t\t\t<dd>\n\t\t\t\t\t\t<p>■会社説明・見学会<br>　開催日などはニュースにてお知らせいたします。<br>　日程の都合が合わない場合は、お気軽にご相談ください。</p>\n\t\t\t\t\t</dd>\n\t\t\t\t\t<dt>書類選考の<br>ポイント</dt>\n\t\t\t\t\t<dd>\n\t\t\t\t\t\t<p>≪人柄＆やる気重視の採用です≫<br>今回の募集では、原則として経験は問いません。<br>アパレル副資材を扱う企業として一定の成熟を迎えた当社に、<br>新たな息吹を吹き込んでくれる、ヤル気ある人材を求めています。<br>当社を志望する理由や、入社後どのように成長したいかなど、<br>あなたの想いを率直にお聞かせください。</p>\n\t\t\t\t\t</dd>\n\t\t\t\t\t<dt>面接地</dt>\n\t\t\t\t\t<dd>\n\t\t\t\t\t\t<p>≪面接は希望の面接地で受けられます。≫<br>■岡山本社 （岡山県倉敷市児島下の町9丁目12番コ2号）<br>■東京営業所 （東京都中央区日本橋富沢町7番14号 岡島ビル6Ｆ）<br>■大阪営業所 （大阪市中央区博労町1−7−2堺筋トラストビル404号）<br>■岡　山　店 （岡山県岡山市北区今２丁目7−1）</p>\n\t\t\t\t\t</dd>        \n\t\t\t\t</ul>\n\t\t\t\t\n\t\t\t\t<div class=\"buttonArea\">\n\t\t\t\t\t<a href=\"/contact/\" class=\"entryForm\">応募フォームへ</a>\n\t\t\t\t</div>\n\t\t\t</div><!-- .Section__body -->\n\t\t</div><!-- .method -->\n\n\t</main>\n\n<!-- InstanceEndEditable -->\n\n<footer class=\"Footer\">\n\t<div class=\"FooterInner l-column\">\n\t\t<div class=\"FooterInner__main\">\n\t\t\t<div class=\"footerLogo\">\n\t\t\t\t<a href=\"/\"><span>株式会社協同</span></a>\n\t\t\t</div>\n\t\t\t<ul class=\"footerMenu\">\n\t\t\t\t<li><a href=\"/about.html\">会社概要</a></li>\n\t\t\t\t<li><a href=\"/contact/\">お問い合わせ</a></li>\n\t\t\t\t<li><a href=\"/policy.html\">情報セキュリティ基本方針</a></li>\n\t\t\t</ul>\n\t\t</div>\n\t\t\n\t\t<div class=\"FooterInner__sub\">\n\t\t\t<div id=\"pageTop\">\n\t\t\t\t<a href=\"#\">ページトップ</a>\n\t\t\t</div>\n\t\t\t\n\t\t\t<ul class=\"btnGroup\">\n\t\t\t\t<li class=\"num01\"><a href=\"https://www.meti.go.jp/policy/sme_chiiki/chiiki_kenin_kigyou/index.html\" target=\"_blank\">地域未来牽引企業</a></li>\n\t\t\t\t<li class=\"num02\"><a href=\"http://www.mhlw.go.jp/stf/seisakunitsuite/bunya/kodomo/shokuba_kosodate/kurumin/index.html\" target=\"_blank\">くるみん</a></li>\n\t\t\t\t<li class=\"num03\"><a href=\"https://www.ipa.go.jp/security/security-action/\" target=\"_blank\">セキュリティ</a></li>\n\t\t\t\t<li class=\"num04\"><a href=\"https://www.meti.go.jp/policy/mono_info_service/healthcare/kenkoukeiei_yuryouhouzin.html\" target=\"_blank\">健康経営優良法人</a></li>\n\t\t\t</ul>\n\t\t\t\n\t\t\t<!--<div class=\"kuruminLogo\">\n\t\t\t\t<a href=\"http://www.mhlw.go.jp/stf/seisakunitsuite/bunya/kodomo/shokuba_kosodate/kurumin/index.html\" target=\"_blank\">くるみん</a>\n\t\t\t</div>-->\n\t\t\t\n\t\t</div>\n\t\t\n\t\t<div class=\"FooterInner__foot\">\n\t\t\t<small><span>&copy;</span> 2016 Kyodo co.,ltd.</small>\n\t\t</div>\n\t</div>\n</footer>\n\n<!-- InstanceBeginEditable name=\"FooterScriptArea\" -->\n<script type=\"text/javascript\">// Smooth-Scroll\n$(function(){\n  $(\"a[href^=#]\").click(function(){\n  $(\"html,body\").animate({ scrollTop: $($(this).attr(\"href\")).offset().top }, 500 ,\"swing\");\n  return false;\n  })\n});\n</script>\n\n<!-- InstanceEndEditable -->\n  (function(i,s,o,g,r,a,m){i['GoogleAnalyticsObject']=r;i[r]=i[r]||function(){\n  (i[r].q=i[r].q||[]).push(arguments)},i[r].l=1*new Date();a=s.createElement(o),\n  m=s.getElementsByTagName(o)[0];a.async=1;a.src=g;m.parentNode.insertBefore(a,m)\n  })(window,document,'script','https://www.google-analytics.com/analytics.js','ga');\n\n  ga('create', 'UA-61899631-5', 'auto');\n  ga('send', 'pageview');\n\n</script>\n</body>\n<!-- InstanceEnd --></html>\n","finalUrl":"https://www.kwl.co.jp/recruit.html","rendered":false,"_cachedAt":"2026-06-14T18:49:50.024Z"}