e itemtype=\"https://schema.org/ListItem\">\n        <a itemscope itemtype=\"https://schema.org/WebPage\" itemprop=\"item\" itemid=\"https://www.hisinaka.jp/recruit/\" href=\"https://www.hisinaka.jp/recruit/\">\n            <span itemprop=\"name\">採用情報</span>\n        </a>\n        <meta itemprop=\"position\" content=\"2\">\n        </li>\n\n        <li class=\"page_breadcrumb_item\" itemprop=\"itemListElement\" itemscope itemtype=\"https://schema.org/ListItem\">\n        <span itemprop=\"name\">社員インタビュー</span>\n        <meta itemprop=\"position\" content=\"3\">\n        </li>\n\n    <!-- 固定ページの場合 -->\n        </ol>\n              </div>\n            <div class=\"page_head_title_area\">\n                <div class=\"page_head_title_en\">INTERVIEW</div>\n                <h1 class=\"page_head_title\">社員インタビュー</h1>\n            </div>\n        </div>\n    </div>\n    <div class=\"page_inner_m\">\n        <div class=\"main_wrap\">\n            <div class=\"main_body\">\n                <div class=\"contents_wrap\">\n                    <div class=\"interview_list\">\n                                                <div class=\"interview_list_item\">\n                            <a href=\"https://www.hisinaka.jp/recruit/interview/interview01/\">\n                                                                <figure class=\"thumbnail\">\n                                    <img src=\"https://www.hisinaka.jp/wp2310hs/wp-content/uploads/2023/11/interview01_eye_catch.jpg\" alt=\"\">\n                                </figure>\n                                <div class=\"catch_copy\">大規模プロジェクトで得られる達成感と、仲間と共に成長できる喜びがある</div>\n                                <div class=\"name_box\">\n                                    <span class=\"name\">S・Aさん</span>\n                                    <span class=\"affiliation_joining\">\n                                        <span class=\"affiliation\">土木部 工事課 所属</span>\n                                        <span class=\"joining\">2022年 入社</span>\n                                    </span>\n                                </div>\n                            </a>\n                        </div>\n                                                <div class=\"interview_list_item\">\n                            <a href=\"https://www.hisinaka.jp/recruit/interview/interview04/\">\n                                                                <figure class=\"thumbnail\">\n                                    <img src=\"https://www.hisinaka.jp/wp2310hs/wp-content/uploads/2023/11/interview04_eye_catch.jpg\" alt=\"\">\n                                </figure>\n                                <div class=\"catch_copy\">完成までの困難なプロセスがあるからこそ、見合った達成感を得ることができる</div>\n                                <div class=\"name_box\">\n                                    <span class=\"name\">H・Dさん</span>\n                                    <span class=\"affiliation_joining\">\n                                        <span class=\"affiliation\">建築部 工事課 所属</span>\n                                        <span class=\"joining\">2013年 入社</span>\n                                    </span>\n                                </div>\n                            </a>\n                        </div>\n                                                <div class=\"interview_list_item\">\n                            <a href=\"https://www.hisinaka.jp/recruit/interview/interview05/\">\n                                                                <figure class=\"thumbnail\">\n                                    <img src=\"https://www.hisinaka.jp/wp2310hs/wp-content/uploads/2023/12/interview_eye_catch.jpg\" alt=\"\">\n                                </figure>\n                                <div class=\"catch_copy\">地元への恩返しの機会を、建設業界ならではの地域貢献が大きな魅力</div>\n                                <div class=\"name_box\">\n                                    <span class=\"name\">M・Cさん</span>\n                                    <span class=\"affiliation_joining\">\n                                        <span class=\"affiliation\">本社 営業部営業課 所属</span>\n                                        <span class=\"joining\">2021年 入社</span>\n                                    </span>\n                                </div>\n                            </a>\n                        </div>\n                                                <div class=\"interview_list_item\">\n                            <a href=\"https://www.hisinaka.jp/recruit/interview/interview06/\">\n                                                                <figure class=\"thumbnail\">\n                                    <img src=\"https://www.hisinaka.jp/wp2310hs/wp-content/uploads/2023/12/interview06_eye_catch.jpg\" alt=\"\">\n                                </figure>\n                                <div class=\"catch_copy\">建築を通じて地域社会に貢献し、その成果が数十年後にも残る喜びを感じられる</div>\n                                <div class=\"name_box\">\n                                    <span class=\"name\">F・Tさん</span>\n                                    <span class=\"affiliation_joining\">\n                                        <span class=\"affiliation\">建築部 工事課 所属</span>\n                                        <span class=\"joining\">2019年 入社</span>\n                                    </span>\n                                </div>\n                            </a>\n                        </div>\n                                            </div>\n                    <div class=\"interview_list_back_btn\">\n                        <div class=\"all_pages\">\n                            <a href=\"https://www.hisinaka.jp/recruit\">採用情報TOPに戻る</a>\n                        </div>\n                    </div>\n                    <div class=\"interview_detail_entry\">\n                        <div class=\"title\">ENTRY</div>\n                        <p class=\"text\">採用条件・応募方法・エントリーにつきましては<br class=\"sp_inline\">「募集要項」ページからご確認ください</p>\n                        <a href=\"https://www.hisinaka.jp/recruit/application/\" class=\"btn\">募集要項を見る</a>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n\n</main><!-- //.main_contents -->\n<!-- footer -->\n<footer class=\"footer\">\n    <div class=\"page_inner_m\">\n        <div class=\"footer_upper\">\n            <div class=\"footer_upper_flex\">\n                <div class=\"footer_upper_left\">\n                    <div class=\"footer_left_flex\">\n                        <div class=\"footer_logo\"><img src=\"https://www.hisinaka.jp/wp2310hs/wp-content/themes/hishinaka/img/common/logo_footer.svg\" alt=\"菱中建設株式会社 次の100年を創造するため、安心、信頼の実績を刻み続けていきます。\"></div>\n                    </div>\n                </div>\n                <div class=\"footer_upper_right\">\n                    <nav class=\"footer_nav\">\n                        <ul class=\"footer_nav_list\">\n                            <li class=\"footer_nav_item\"><a href=\"https://www.hisinaka.jp\">ホーム</a></li>\n                            <li class=\"footer_nav_item\"><a href=\"https://www.hisinaka.jp/news\">最新情報</a></li>\n                            <li class=\"footer_nav_item\"><a href=\"https://www.hisinaka.jp/company\">会社案内</a>\n                                <ul class=\"footer_nav_child_list\">\n                                    <li class=\"footer_nav_child_item\"><a href=\"https://www.hisinaka.jp/history\">沿革</a></li>\n                                    <li class=\"footer_nav_child_item\"><a href=\"https://www.hisinaka.jp/organization\">組織図</a></li>\n                                </ul>\n                            </li>\n                        </ul>\n                        <ul class=\"footer_nav_list\">\n                            <li class=\"footer_nav_item\"><a href=\"https://www.hisinaka.jp/sdgs\">SDGsへの取り組み</a></li>\n                            <li class=\"footer_nav_item\"><a href=\"https://www.hisinaka.jp/works\">施工実績</a></li>\n                            <li cl