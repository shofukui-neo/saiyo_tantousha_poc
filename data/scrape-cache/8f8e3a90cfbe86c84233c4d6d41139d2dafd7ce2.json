{"url":"https://www.jr-shikoku.co.jp/04_company/recruit/kousotsu/index.html","html":"<!doctype html>\n<html lang=\"ja\">\n<head prefix=\"og: http://ogp.me/ns# fb: http://ogp.me/ns/fb# article: http://ogp.me/ns/article#\">\n<!-- Google Tag Manager --> \n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n})(window,document,'script','dataLayer','GTM-PZ4X4CF');</script> \n<!-- End Google Tag Manager -->\n<meta charset=\"UTF-8\">\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<meta name=\"description\" content=\"ＪＲ四国高校生新卒採用情報ページです。\">\n<meta name=\"keywords\" content=\"高校生新卒採用情報,JR四国,四国旅客鉄道株式会社\">\n<meta property=\"og:type\" content=\"article\">\n<meta property=\"og:image\" content=\"https://www.jr-shikoku.co.jp/04_company/recruit/common/img/ogp.png\">\n<title>高校生新卒採用情報｜ＪＲ四国</title>\n<link rel=\"shortcut icon\" href=\"/favicon.ico\">\n<link rel=\"apple-touch-icon\" href=\"/04_company/recruit/common/img/apple-touch-icon.png\">\n<link rel=\"icon\" type=\"image/png\" href=\"/04_company/recruit/common/img/android-chrome.png\">\n<link href=\"https://cdn.jsdelivr.net/npm/destyle.css@1.0.15/destyle.css\" rel=\"stylesheet\">\n<link href=\"../common/css/common.css\" rel=\"stylesheet\">\n<link href=\"css/index.css\" rel=\"stylesheet\">\n</head>\n\n<body>\n<!-- Google Tag Manager (noscript) -->\n<noscript>\n<iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-PZ4X4CF\"\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe>\n</noscript>\n<!-- End Google Tag Manager (noscript) --> \n<!-- HEADER -->\r\n  <header id=\"header-area\">\r\n\t  <div class=\"logo-main\"><a href=\"/04_company/recruit/index.html\"><b><span class=\"sub\"></span><span class=\"main\">四国旅客鉄道株式会社</span></b><span>採用情報<br>総合TOP</span></a></div>\r\n  </header>\r\n  <!--// HEADER -->\n<div class=\"image-main-heading\">\n  <div class=\"main-heading\">\n    <h1 class=\"jp\">高校生新卒<br>\n      採用情報</h1>\n  </div>\n</div>\n<main class=\"comeback-wrap\">\n  <div class=\"inner\">\n    <ul class=\"page-navi\">\n      <li> <a href=\"#sec1\"><span>採用情報</span></a> </li>\n      <li> <a href=\"#sec2\"><span>応募方法</span></a> </li>\n      <li> <a href=\"#sec3\"><span>職場見学及び会社説明会（2025年7月13日・20日）</span></a> </li>\n    </ul>\n    <section id=\"sec1\" class=\"comeback-sec\">\n      <h2 class=\"line-section-heading jp\"><span>採用情報</span></h2>\n      <div class=\"comeback-sec-inner\">\n        <section class=\"comeback-sub-sec\">\n          <h3 class=\"comeback-sub-heading jp\">募集職種</h3>\n          <ul class=\"dot-list mg-top0\">\n            <li>現業職</li>\n            <li>現業職（エリア採用）①香川県内、②徳島県内、③愛媛県内、④高知県内</li>\n          </ul>\n        </section>\n        <section class=\"comeback-sub-sec\">\n          <h3 class=\"comeback-sub-heading jp\">仕事の内容</h3>\n          <table style=\"width:100%\">\n            <tbody class=\"flex-column\">\n              <tr class=\"t-style\">\n                <th>1.保線・土木業務</th>\n                <td>線路、土木構造物の工事計画、検査及び保守業務</td>\n              </tr>\n              <tr class=\"t-style\">\n                <th>2.建築業務</th>\n                <td>建築物の工事計画、検査及び保守業務</td>\n              </tr>\n              <tr class=\"t-style\">\n                <th>3.電気業務</th>\n                <td>電気設備の工事計画、検査及び保守業務</td>\n              </tr>\n              <tr class=\"t-style\">\n                <th>4.機械業務</th>\n                <td>機械設備の工事計画、検査及び保守業務</td>\n              </tr>\n              <tr class=\"t-style\">\n                <th>5.車両検修業務</th>\n                <td>鉄道車両の開発、検査及び修繕業務</td>\n              </tr>\n              <tr class=\"t-style\">\n                <th>6.駅業務</th>\n                <td>接客・切符の販売及び運転業務（車両の入換誘導）等</td>\n              </tr>\n              <tr class=\"t-style\">\n                <th>7.車掌業務</th>\n                <td>駅業務経験後、列車に乗車し切符販売、接客業務等に従事</td>\n              </tr>\n              <tr class=\"t-style\">\n                <th>8.運転士業務</th>\n                <td>駅、車掌業務を経験後社内研修を経て国家資格を取得し列車の運転業務に従事</td>\n              </tr>\n            </tbody>\n          </table>\n        </section>\n        <section class=\"comeback-sub-sec\">\n          <h3 class=\"comeback-sub-heading jp\">応募資格</h3>\n          <p>2026年3月に高等学校を卒業見込みの方</p>\n        </section>\n        <section class=\"comeback-sub-sec\">\n          <h3 class=\"comeback-sub-heading jp\">募集人員</h3>\n          <p>各系統あわせて50名程度</p>\n        </section>\n        <section class=\"comeback-sub-sec\">\n          <h3 class=\"comeback-sub-heading jp\">応募受付期間</h3>\n          <table style=\"width:100%\">\n            <tbody class=\"flex-column\">\n              <tr class=\"t-style-oubokkn\">\n                <th>前期募集</th>\n                <td>9月5日（金）～9月9日（火）</td>\n              </tr>\n              <tr class=\"t-style-oubokkn\">\n                <th>後期募集</th>\n                <td>10月1日（水）～10月10日（金）</td>\n              </tr>\n              <tr class=\"t-style-oubokkn\">\n                <th>三次募集※</th>\n                <td>11月1日（土）～11月7日（金）</td>\n              </tr>\n            </tbody>\n          </table>\n          <p>※ 採用状況により実施しない場合があります。</p>\n        </section>\n        <section class=\"comeback-sub-sec\" id=\"sec2\">\n          <h3 class=\"comeback-sub-heading jp\">応募方法</h3>\n          <p>各学校を通じての応募となります。受験を希望される方は、学校の就職担当の先生にご相談ください。</p>\n        </section>\n        <section class=\"comeback-sub-sec\">\n          <h3 class=\"comeback-sub-heading jp\">初任給</h3>\n          <p>178,000円（2025年4月入社実績額）</p>\n        </section>\n        <section class=\"comeback-sub-sec\">\n          <h3 class=\"comeback-sub-heading jp\">諸手当</h3>\n          <p>扶養手当、指定勤務地手当、通勤手当、業務手当、技能手当など</p>\n        </section>\n        <section class=\"comeback-sub-sec\">\n          <h3 class=\"comeback-sub-heading jp\">昇給</h3>\n          <p>昇給／年1回、賞与／年2回</p>\n        </section>\n        <section class=\"comeback-sub-sec\">\n          <h3 class=\"comeback-sub-heading jp\">勤務地</h3>\n          <ul class=\"dot-list come\">\n            <li>現業職\n              <ul class=\"dot-list\">\n                <li>ＪＲ四国の各現業機関（保線区・電気区・駅・運転所 等）</li>\n              </ul>\n            </li>\n            <li>現業職（エリア採用）\n              <ul class=\"dot-list\">\n                <li>香川県内の現業機関（保線区・電気区・駅・運転所 等）</li>\n                <li>愛媛県内の現業機関（保線区・電気区・駅・運転所 等）</li>\n                <li>徳島県内の現業機関（保線区・電気区・駅・運転所 等）</li>\n                <li>高知県内の現業機関（保線区・電気区・駅・運転所 等）</li>\n              </ul>\n              ※　駅長等現場長となるための試験を受験し、合格した場合は県外に異動する可能性があります。 </li>\n          </ul>\n        </section>\n        <section class=\"comeback-sub-sec\">\n          <h3 class=\"comeback-sub-heading jp\">勤務時間</h3>\n          <ul class=\"dot-list come\">\n            <li>本社等 ： 平日／9：00～18：00 ※時差勤務制度あり</li>\n            <li>その他\n              <ul class=\"dot-list\">\n                <li>日　勤／8：30～17：30　など</li>\n                <li>交代制／4週に160時間勤務の変形労働時間制など職種により異なります</li>\n              </ul>\n            </li>\n          </ul>\n        </section>\n        <section class=\"comeback-sub-sec\">\n          <h3 class=\"comeback-sub-heading jp\">休日・休暇</h3>\n          <ul class=\"dot-list come\">\n            <li>本社及び工務系現業機関等 ： 年間120日程度（完全週休2日制）</li>\n            <li>その他 ： 年間110日</li>\n          </ul>\n          <ul class=\"notes-list mg-top0\">\n            <li>職種により異なります</li>\n          </ul>\n          <p>年次有給休暇、慶弔休暇など（育児・介護休職制度あり）</p>\n        </section>\n        <section class=\"comeback-sub-sec\">\n          <h3 class=\"comeback-sub-heading jp\">福利厚生</h3>\n          <ul class=\"dot-list come\">\n            <li>制度 ： 各種社会保険、互助会、住宅補給金など</li>\n            <li>施設 ： 社宅、独身寮、診療所（高松）など</li>\n            <li>クラブ活動\n              <ul class=\"dot-list\">\n                <li>専門部／ 硬式野球部、応援部</li>\n                <li>運動部／ テニス部、ヨット部、スキー部、山岳部、剣道部、陸上競技部、ソフトテニス部、卓球部、ラグビー部、柔道部、軟式野球部、サッカー部、少林寺拳法部、バドミントン部、ゴルフ部、水泳部、バスケットボール部</li>\n                <li>文化部／ 釣りクラブ、吹奏楽部、阿波踊り鳴り物クラブ、奇術部、四国鉄道文学会、鉄道模型クラブ</li>\n              </ul>\n            </li>\n          </ul>\n        </section>\n        <section class=\"comeback-sub-sec\">\n          <h3 class=\"comeback-sub-heading jp\">教育制度</h3>\n          <p>「<a href=\"/04_company/recruit/fresh/working_environment/index.html\" target=\"_blank\">働く環境</a>」をご確認下さい。</p>\n        </section>\n        \n        <!-- 以下のページにインクルード\r\n■新卒 | 総合職\r\n/04_company/recruit/fresh/information/sogo.html#average-data\r\n■新卒 | プロフェッショナル職\r\n/04_company/recruit/fresh/information/professional.html#average-data\r\n■経験者採用\r\n/04_company/recruit/career/information/employ.html#average-data\r\n■高校生新卒\r\n/04_company/recruit/kousotsu/index.html\r\n-->\r\n<section class=\"requirements-child-sec\" id=\"average-data\">\r\n\t<h3 class=\"requirements-child-heading jp\">平均勤続年数</h3>\r\n\t<p>13.6年</p>\r\n\t<ul class=\"notes-list\">\r\n\t\t<li>2026年4月現在</li>\r\n\t</ul>\r\n</section>\r\n\r\n<section class=\"requirements-child-sec\">\r\n\t<h3 class=\"requirements-child-heading jp\">平均年齢</h3>\r\n\t<p>34.9歳</p>\r\n\t<ul class=\"notes-list\">\r\n\t\t<li>2026年4月現在</li>\r\n\t</ul>\r\n</section>\r\n\r\n<section class=\"requirements-child-sec\">\r\n\t<h3 class=\"requirements-child-heading jp\">月平均所定外労働時間</h3>\r\n\t<p>13.5時間</p>\r\n\t<ul class=\"notes-list\">\r\n\t\t<li>2025年度実績</li>\r\n\t</ul>\r\n</section>\r\n\r\n<section class=\"requirements-child-sec\">\r\n\t<h3 class=\"requirements-child-heading jp\">有給休暇平均取得率</h3>\r\n\t<p>88.4％</p>\r\n\t<ul class=\"notes-list\">\r\n\t\t<li>2025年度実績</li>\r\n\t</ul>\r\n</section>\r\n\r\n<section class=\"requirements-child-sec\">\r\n\t<h3 class=\"requirements-child-heading jp\">育休取得率</h3>\r\n\t<p>男性92.3%　女性100％</p>\r\n\t<ul class=\"notes-list\">\r\n\t\t<li>2025年度実績</li>\r\n\t</ul>\r\n</section> \n        </div>\n\t</section>\n\t  <section id=\"sec3\" class=\"comeback-sec\">\n\t\t  <h2 class=\"line-section-heading jp\"><span>職場見学及び会社説明会</span></h2>\n\t\t  <h5 class=\"h5-ttl\">以下の日程で職場見学及び会社説明会を実施します。<br>各職場を見て頂くとともに、当社の事業内容、入社後の仕事内容のご紹介のほか、先輩との座談会についても予定しています。当社に関心のある方は是非ご参加ください。</h5>\n\t\t  <div class=\"comeback-sec-inner\">\n\t\t\t  <section class=\"comeback-sub-sec\">\n\t\t\t\t  <h3 class=\"comeback-sub-heading jp\">開催日時</h3>\n\t\t\t\t  <table style=\"width:100%\">\n\t\t\t\t\t  <tbody class=\"flex-column\">\n\t\t\t\t\t\t  <tr class=\"t-style-oubokkn\">\n\t\t\t\t\t\t\t  <th>第一回</th>\n\t\t\t\t\t\t\t  <td>2025年7月13日（日）11：00～16：00</td>\n\t\t\t\t\t\t  </tr>\n\t\t\t\t\t\t  <tr class=\"t-style-oubokkn\">\n\t\t\t\t\t\t\t  <th>第二回</th>\n\t\t\t\t\t\t\t  <td>2025年7月20日（日）11：00～16：00</td>\n\t\t\t\t\t\t  </tr>\n\t\t\t\t\t  </tbody>\n\t\t\t\t  </table>\n\t\t\t  </section>\n\t\t\t  \n\t\t\t  <section class=\"comeback-sub-sec\">\n\t\t\t\t  <h3 class=\"comeback-sub-heading jp\">内 容</h3>\n\t\t\t\t  <p>ＪＲ四国の会社概要・求人説明及び業務内容の紹介、職場見学 等</p>\n\t\t\t\t  <ul class=\"astelisk\">\n\t\t\t\t\t  <li>業務内容・職場見学は、各系統（駅、車掌・運転士・車両、保線・土木、機械・建築、電気）の社員からご説明します。</li>\n\t\t\t\t  </ul>\n\t\t\t  </section>\n\t\t\t  \n\t\t\t  <section class=\"comeback-sub-sec\">\n\t\t\t\t  <h3 class=\"comeback-sub-heading jp\">会 場</h3>\n\t\t\t\t  <p>ＪＲ四国 本社８Ｆ（香川県高松市浜ノ町8番33号） ＪＲ高松駅から徒歩約10分</p>\n\t\t\t  </section>\n\t\t\t  \n\t\t\t  <section class=\"comeback-sub-sec\">\n\t\t\t\t  <h3 class=\"comeback-sub-heading jp\">対象者</h3>\n\t\t\t\t  <p>応募資格に該当する高校生および保護者の方</p>\n\t\t\t  </section>\n\t\t\t  \n\t\t\t  <section class=\"comeback-sub-sec\">\n\t\t\t\t  <h3 class=\"comeback-sub-heading jp\">申込方法</h3>\n\t\t\t\t  <p>各高等学校を通じてお申し込みください。</p>\n\t\t\t  </section>\n\t\t</div>\n\t</section>\n\t  \n    <!-- 以下のページにインクルード\r\n■新卒 | 総合職\r\n/04_company/recruit/fresh/information/sogo.html#company-profile\r\n■新卒 | プロフェッショナル職\r\n/04_company/recruit/fresh/information/professional.html#company-profile\r\n■会社説明会情報・インターンシップ情報\r\n/04_company/recruit/fresh/information/internship.html#company-profile\r\n■募集要項 | 経験者採用\r\n/04_company/recruit/career/information/employ.html#company-profile\r\n■契約社員(観光列車アテンダント 四国まんなか千年ものがたり)\r\n/04_company/recruit/attendant/sennen/index.html#company-profile\r\n■契約社員(観光列車アテンダント 志国土佐　時代の夜明けのものがたり)\r\n/04_company/recruit/attendant/yoake/index.html#company-profile\r\n■乗務員専門職\r\n/04_company/recruit/train_crew/employ/index.html#company-profile\r\n■高校生新卒\r\n/04_company/recruit/kousotsu/index.html#company-profile\r\n-->\r\n<section class=\"requirements-sec\" id=\"company-profile\">\r\n\t<h2 class=\"requirements-sec-heading jp\">会社概要</h2>\r\n\t<div class=\"requirements-inner\">\r\n\t\t<ul class=\"dot-list\">\r\n\t\t\t<li>設立 ： 1987年4月</li>\r\n\t\t\t<li>資本金 ： 35億円</li>\r\n\t\t\t<li>社員数 ： 2,050人</li>\r\n\t\t\t<li>事業内容 ： 旅客鉄道事業、旅行業、その他事業</li>\r\n\t\t</ul>\r\n\t\t<ul class=\"notes-list\">\r\n\t\t\t<li>2026年4月現在</li>\r\n\t\t</ul>\r\n\t</div>\r\n</section>\n    \n    <section class=\"requirements-sec\">\n      <h2 class=\"requirements-sec-heading jp\">お問い合わせ先</h2>\n      <div class=\"requirements-inner\">\n        <p>四国旅客鉄道株式会社<br>\n          総務部 人事課 採用担当<br>\n          〒760-8580　香川県高松市浜ノ町8番33号<br>\n          TEL 087-825-1627<br>\n          Mail <a href=\"mailto:saiyou@jr-shikoku.co.jp\">saiyou@jr-shikoku.co.jp</a></p>\n      </div>\n    </section>\n    <section> <a href=\"https://job-draft.com/jobs/6865\" target=\"_blank\" class=\"job-draft-a\"><img class=\"job-draft-btn\" src=\"/04_company/recruit/kousotsu/img/job-draft.jpg\" alt=\"ジョブドラフト\"/></a>\n      <p class=\"job-draft-p\">上のアイコンをクリック</p>\n    </section>\n  </div><!-- .inner -->\n</main>\n<!-- FOOTER -->\r\n<footer id=\"footer-area\">\r\n  <div class=\"footer-inner\">\r\n    <div class=\"footer-upper\">\r\n      <div class=\"footer-logo\"><img src=\"/04_company/recruit/common/img/logo_footer.png\" alt=\"四国旅客鉄道株式会社\"/>\r\n      <span>採用情報</span></div>\r\n    </div>\r\n    <div class=\"footer-lower\">\r\n      <a href=\"https://www.jr-shikoku.co.jp/\" class=\"offcial\" target=\"_blank\">オフィシャルサイト</a>\r\n      <small class=\"copyright\">Copyright(C) Shikoku Railway Company. All rights reserved.</small>\r\n    </div>\r\n  </div>\r\n</footer>\r\n<!--// FOOTER --> \n<script src=\"//cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js\" integrity=\"sha512-v2CJ7UaYy4JwqLDIrZUI/4hqeoQieOmAZNXBeQyjo21dadnwR+8ZaIJVT8EE2iyI61OV8e6M8PP2/4hpQINQ/g==\" crossorigin=\"anonymous\"referrerpolicy=\"no-referrer\"></script> \n<script src=\"../common/js/common.js\"></script>\n</body>\n</html>\n","finalUrl":"https://www.jr-shikoku.co.jp/04_company/recruit/kousotsu/index.html","rendered":false,"_cachedAt":"2026-06-23T21:59:39.545Z"}