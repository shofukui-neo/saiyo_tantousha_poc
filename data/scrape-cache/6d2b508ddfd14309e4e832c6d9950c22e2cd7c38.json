\r\n\r\n<div id=\"bodybox\">\r\n  <div id=\"headerbase\">\r\n    <header>\r\n      <div id=\"obione\">\r\n        \r\n        <a id=\"headlogo01\" href=\"./\">\r\n          <h1 class=\"logo01\"><img src=\"images/common/logo01.svg?rev=2\" alt=\"株式会社 GSタカハシ\"></h1>\r\n          <p class=\"cne\"><span>GS</span> TAKAHASHI</p>\r\n        </a>\r\n        \r\n        <div id=\"menubox\">\r\n          <ul id=\"menucont\">\r\n            <li><a href=\"outline.html\"><p class=\"mtj\">会社概要</p><p class=\"mte\"><span>O</span>UTLINE</p></a></li>\r\n            <li><a href=\"airwash.html\"><p class=\"mtj\"><span class=\"cd01\">エアウォッシュとは</span></p><p class=\"mte\"><span>A</span>IR WASH</p></a></li>\r\n            <li><a href=\"original.html\"><p class=\"mtj\">オリジナル商品</p><p class=\"mte\"><span>O</span>RIGINAL <span>P</span>RODUCTS</p></a></li>\r\n            <li><a href=\"handled.html\"><p class=\"mtj\">取扱メーカー</p><p class=\"mte\"><span>P</span>RODUCTS <span>H</span>ANDLED</p></a></li>\r\n            <li><a href=\"sdgs.html\"><p class=\"mtj\">SDGs</p><p class=\"mte\"><span>SDGs</span></p></a></li>\r\n            <li><a href=\"recruit.html\"><p class=\"mtj\">採用情報</p><p class=\"mte\"><span>R</span>ECRUIT</p></a></li>\r\n          </ul> <!-- /#menucont -->\r\n        </div> <!-- /#menubox -->\r\n        \r\n        <div id=\"headtoibox\">\r\n          <a href=\"contact.html\">\r\n            <img class=\"icon\" src=\"images/common/icon_mail01.svg\" alt=\"\">\r\n            <p class=\"mtj\">お問合せ</p><p class=\"mte\"><span>C</span>ONTACT</p>\r\n          </a>\r\n        </div> <!-- /#headtoibox -->\r\n        \r\n      </div> <!-- /#obione -->\r\n      \r\n      <div id=\"thibox01\">\r\n        <div class=\"thitem\"><img src=\"images/recruit/thiph01.jpg\" alt=\"\"></div>\r\n        <div class=\"thitem\"><img src=\"images/recruit/thiph02.jpg?rev=2\" alt=\"\"></div>\r\n        <div class=\"thitem\"><img src=\"images/recruit/thiph03_2.jpg\" alt=\"\"></div>\r\n        <div class=\"thitem\"><img src=\"images/recruit/thiph04.jpg\" alt=\"\"></div>\r\n        <div class=\"thitem\"><img src=\"images/recruit/thiph05.jpg\" alt=\"\"></div>\r\n      </div> <!-- /#thibox01 -->\r\n      \r\n    </header>\r\n  </div> <!-- /#headerbase -->\r\n  <div id=\"midbase01\" class=\"midbase\">\r\n    <div id=\"midbox01\" class=\"midbox\">\r\n      \r\n      \r\n      <div class=\"calbar\">\r\n        <div class=\"calcore\">\r\n          <ul class=\"calcont\">\r\n            <li><a href=\"#message\"><p>メッセージ</p></a></li>\r\n            <li><a href=\"#newgraduate\"><p>新卒募集</p></a></li>\r\n            <li><a href=\"#career\"><p>中途募集</p></a></li>\r\n            <li><a href=\"#entryform\"><p>エントリーフォーム</p></a></li>\r\n            <li><a href=\"#movie\"><p>ムービー</p></a></li>\r\n            <li><a href=\"https://www.gakujo.ne.jp/2024/company/baseinfo/25736/\" target=\"_blank\"><p>採用サイト</p></a></li>\r\n          </ul> <!-- /.calcont -->\r\n        </div> <!-- /.calcore -->\r\n      </div> <!-- /.calbar -->\r\n      \r\n      \r\n      <a id=\"message\" class=\"anc01\"></a>\r\n      \r\n      \r\n      <div id=\"stcb01_01\" class=\"stcont\">\r\n        <div id=\"stb01_01\" class=\"stbox01\">\r\n          <p class=\"ste\"><span>R</span>ECRUIT</p>\r\n          <h3 class=\"stj\">採用情報</h3>\r\n        </div>\r\n        \r\n        \r\n        <div id=\"ccatchbox01\">\r\n          <h4 id=\"ccatch01\">メッセージ <br class=\"mbbr\">〜GSタカハシを知る〜</h4>\r\n          <p id=\"cccom01\">\r\n            インテリア商材を扱う福岡の商社で創業83年目を迎えました。<br>\r\n            福岡天神地区の再開発や高齢化に伴い<br class=\"mbbr\">住環境に対する変化を読み取り、<br>\r\n            お客様の期待にしっかり応えていきたいと思ってます。<br>\r\n            そのためフレッシュな力が必要です。<br class=\"mbbr\">あなたらしく仕事を楽しんで力を存分に発揮してください。\r\n          </p>\r\n        </div> <!-- /#ccatchbox01 -->\r\n        \r\n        \r\n        <div id=\"rcbox01\">\r\n          \r\n          <div id=\"psn01\" class=\"rcbitem\">\r\n            <div class=\"ib\"><img src=\"images/recruit/rcph01.jpg\" alt=\"\"></div>\r\n            <div class=\"info\">\r\n              <div class=\"ihb\">\r\n                <p class=\"it\">谷村 彰彦</p>\r\n                <p class=\"ii\">福岡本社 営業部 部長 / 1984年入社</p>\r\n              </div>\r\n              <div class=\"icb\">\r\n                <p class=\"ic\">\r\n                  若い社員の成長を感じられるところがやりがいです。我社、㈱ＧＳタカハシは、人間関係が他社と比較にならないくらい良好だと思っています。\r\n                </p>\r\n              </div>\r\n              <div class=\"lb\">\r\n                <a class=\"dtbtn\" href=\"recdetail.html#psn01\">メッセージを見る</a>\r\n              </div>\r\n            </div> <!-- /.info -->\r\n          </div> <!-- /.rcbitem -->\r\n          \r\n          <div id=\"psn02\" class=\"rcbitem\">\r\n            <div class=\"ib\"><img src=\"images/recruit/rcph02.jpg\" alt=\"\"></div>\r\n            <div class=\"info\">\r\n              <div class=\"ihb\">\r\n                <p class=\"it\">古賀 優希</p>\r\n                <p class=\"ii\">福岡南営業所 営業部 主任 / 2007年入社</p>\r\n              </div>\r\n              <div class=\"icb\">\r\n                <p class=\"ic\">\r\n                  臨機応変な対応が出来てお客様から頼りになるという言葉をもらった時がやりがいを感じます。\r\n                </p>\r\n              </div>\r\n              <div class=\"lb\">\r\n                <a class=\"dtbtn\" href=\"recdetail.html#psn02\">メッセージを見る</a>\r\n              </div>\r\n            </div> <!-- /.info -->\r\n          </div> <!-- /.rcbitem -->\r\n          \r\n          <div id=\"psn03\" class=\"rcbitem\">\r\n            <div class=\"ib\"><img src=\"images/recruit/rcph03.jpg\" alt=\"\"></div>\r\n            <div class=\"info\">\r\n              <div class=\"ihb\">\r\n                <p class=\"it\">宮原 杏花</p>\r\n                <p class=\"ii\">福岡本社 営業部 / 2021年入社</p>\r\n              </div>\r\n              <div class=\"icb\">\r\n                <p class=\"ic\">\r\n                  ここで働いている事務の方も営業の方も皆さん本当に人が良いなと思います。\r\n                </p>\r\n              </div>\r\n              <div class=\"lb\">\r\n                <a class=\"dtbtn\" href=\"recdetail.html#psn03\">メッセージを見る</a>\r\n              </div>\r\n            </div> <!-- /.info -->\r\n          </div> <!-- /.rcbitem -->\r\n          \r\n          <div id=\"psn04\" class=\"rcbitem\">\r\n            <div class=\"ib\"><img src=\"images/recruit/rcph04_2.jpg\" alt=\"\"></div>\r\n            <div class=\"info\">\r\n              <div class=\"ihb\">\r\n                <p class=\"it\">黒岩 宏士朗</p>\r\n                <p class=\"ii\">福岡西営業所 / 2018年入社</p>\r\n              </div>\r\n              <div class=\"icb\">\r\n                <p class=\"ic\">\r\n                  社員がお互いに助け合う雰囲気の良い働きやすい職場です。\r\n                </p>\r\n              </div>\r\n              <div class=\"lb\">\r\n                <a class=\"dtbtn\" href=\"recdetail.html#psn04\">メッセージを見る</a>\r\n              </div>\r\n            </div> <!-- /.info -->\r\n          </div> <!-- /.rcbitem -->\r\n          \r\n          <div id=\"psn05\" class=\"rcbitem\">\r\n            <div class=\"ib\"><img src=\"images/recruit/rcph05.jpg?rev=3\" alt=\"\"></div>\r\n            <div class=\"info\">\r\n              <div class=\"ihb\">\r\n                <p class=\"it\">古賀 宏章</p>\r\n                <p class=\"ii\">大分営業所 所長 / 1995年入社</p>\r\n              </div>\r\n              <div class=\"icb\">\r\n                <p class=\"ic\">\r\n                  当社には大企業にないアットホーム的な雰囲気がたくさんあります。ぜひ入社して家族になってみませんか。\r\n                </p>\r\n              </div>\r\n              <div class=\"lb\">\r\n                <a class=\"dtbtn\" href=\"recdetail.html#psn05\">メッセージを見る</a>\r\n              </div>\r\n            </div> <!-- /.info -->\r\n          </div> <!-- /.rcbitem -->\r\n          \r\n          <div id=\"psn06\" class=\"rcbitem\">\r\n            <div class=\"ib\"><img src=\"images/recruit/rcph06.jpg\" alt=\"\"></div>\r\n            <div class=\"info\">\r\n              <div class=\"ihb\">\r\n                <p class=\"it\">山口 滉樹</p>\r\n                <p class=\"ii\">福岡南営業所 営業部 主任 / 2016年入社</p>\r\n              </div>\r\n           