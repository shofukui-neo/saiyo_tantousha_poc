n.footer__content--purpose {\n  margin-top: -14px;\n  margin-bottom: 10px;\n}\n.footer__content--purpose a:hover {\n  opacity: 0.9;\n  color: #fff;\n}\n@media (max-width: 1023px) {\n  .footer__content--purpose {\n    margin: 0;\n  }\n}\n</style>\n\n      <div class=\"overlay\"></div>\n    </div>\n    <script type=\"text/javascript\" src=\"/js/fitie.js\"></script>\n  </body>\n</html>\n","finalUrl":"https://www.dai-ichi-building.co.jp/career/staff/2","rendered":false,"_cachedAt":"2026-06-22T16:59:43.384Z"}