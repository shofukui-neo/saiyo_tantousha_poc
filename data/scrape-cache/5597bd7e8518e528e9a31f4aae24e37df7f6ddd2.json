r\n<!-- End Google Tag Manager -->\r\n\r\n</head>\r\n\r\n<body>\r\n    <!-- Google Tag Manager (noscript) -->\r\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-PZFRMBD\"\r\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\r\n<!-- End Google Tag Manager (noscript) -->\r\n\r\n    <!-- =================================================== -->\r\n\r\n    <div class=\"wrap\" id=\"pagetop\">\r\n        <header>\r\n            <div class=\"headLogo\">\r\n                <div class=\"logo\"><a href=\"../index.html\"><img src=\"../assets/img/common/logo.png\" alt=\"日本紙通商株式会社\"></a></div>\r\n                <p class=\"text\">RECRUIT</p>\r\n            </div>\r\n            <div class=\"humburgerBtn\">\r\n                <span class=\"top\"></span>\r\n                <span class=\"middle\"></span>\r\n                <span class=\"bottom\"></span>\r\n            </div>\r\n            <div class=\"headMenu\">\r\n                <nav>\r\n                    <ul class=\"navList\">\r\n                        <li class=\"item -parent\">\r\n                            <a href=\"../about\"><span>日本紙通商について</span></a>\r\n                            <span class=\"accordionBtn\"></span>\r\n                            <ul class=\"child\">\r\n                                <li class=\"item\"><a href=\"../about/message.html\">メッセージ</a></li>\r\n                                <li class=\"item\"><a href=\"../about/introduction.html\">事業紹介</a></li>\r\n                                <li class=\"item\"><a href=\"../about/company_profile.html\">会社概要</a></li>\r\n                            </ul>\r\n                        </li>\r\n                        <li class=\"item\">\r\n                            <a href=\"../interview\"><span>インタビュー</span></a>\r\n                        </li>\r\n                        <li class=\"item\"><a href=\"../career_plan\"><span>キャリアプラン</span></a></li>\r\n                        <li class=\"item -sp\"><a href=\"../access\"><span>アクセスマップ</span></a></li>\r\n                        <li class=\"item -sp\"><a href=\"../gallery\"><span>社内風景</span></a></li>\r\n                        <li class=\"item\"><a href=\"../faq\"><span>FAQ</span></a></li>\r\n                        <li class=\"item\"><a href=\"../guideline\"><span>募集要項</span></a></li>\r\n                        <li class=\"item -entry\"><a href=\"https://job.mynavi.jp/24/pc/search/corp235178/outline.html\" target=\"_blank\"><span>ENTRY</span></a></li>\r\n                    </ul>\r\n                </nav>\r\n            </div>\r\n        </header>\r\n\r\n        <div class=\"lContainer -sub\">\r\n            <!-- InstanceBeginEditable name=\"container\" -->\r\n            <!-- =================================================== -->\r\n            <div class=\"secContainer -interview -career\">\r\n                <div class=\"pageLabel\">\r\n                    <div class=\"inner\">\r\n                        <h1 class=\"labelMain\">\r\n                            <span class=\"main\"><img src=\"../assets/img/career_plan/ttl-career.png\" alt=\"Career plans\"></span>\r\n                            <sub class=\"labelSub -white\">キャリアプラン</sub>\r\n                        </h1>\r\n                        <div class=\"intro\">\r\n                            <div class=\"thumbImg\">\r\n                                <img src=\"../assets/img/career_plan/career-img01.jpg\" alt=\"\">\r\n                            </div>\r\n                            <section class=\"textarea\">\r\n                                <h2 class=\"catch\">豊富な教育制度で、自分の進みたい<br>道をじっくりと決めていく。</h2>\r\n                            </section>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n                <div class=\"mainWrap\">\r\n                    <div class=\"inner\">\r\n                        <div class=\"grayWrap -intro\">\r\n                            <div class=\"thumbImg\"><img src=\"../assets/img/career_plan/career-img02.jpg\" alt=\"\"></div>\r\n                            <section class=\"textarea\">\r\n                                <h2 class=\"ttl\">内定から入社まで</h2>\r\n                                <section class=\"sub\">\r\n                                    <p>内定者には入社までの半年間、社会人に必要な知識・マインド・スキルを身につけるためe-ラーニングを実施しています。新入社員研修は、社内システム説明・業務概要研修、外部講師によるビジネスマナー・マインド、シミュレーション研修、工場等の外部見学研修を約2週間行います。1年目は英会話研修も実施しております。</p>\r\n                                </section>\r\n                            </section>\r\n                        </div>\r\n                        <div class=\"flowList\">\r\n                            <div class=\"paragraph\">\r\n                                <div class=\"textarea\">\r\n                                    <section class=\"item\">\r\n                                        <h2 class=\"ttl\"><span class=\"num\"><img src=\"../assets/img/career_plan/num01.png\" alt=\"01\"></span><span class=\"txt\">入社2年目以降も続く豊富なフォローアップ</span></h2>\r\n                                        <section class=\"sub\">\r\n                                            <p>入社後2年間は育成教育期間と捉え、配属先にて2年間の育成教育計画書を作成し実行しています。2年目以降も英会話研修を受けることができます。また2年目には、これまでを振り返りながら立場・役目を再確認し、今後あるべき姿を考えるためフォローアップ研修を行っております。</p>\r\n                                        </section>\r\n                                    </section>\r\n                                </div>\r\n                                <div class=\"thumbImg\">\r\n                                    <img src=\"../assets/img/career_plan/career-img03.jpg\" alt=\"\">\r\n                                </div>\r\n                            </div>\r\n                            <div class=\"paragraph\">\r\n                                <div class=\"textarea\">\r\n                                    <section class=\"item\">\r\n                                        <h2 class=\"ttl\"><span class=\"num\"><img src=\"../assets/img/career_plan/num02.png\" alt=\"02\"></span><span class=\"txt\">働く不安のない、充実した教育制度</span></h2>\r\n                                        <section class=\"sub\">\r\n                                            <p>入社時の新入社員研修を皮切りに、2年目フォローアップ研修、日常のOJT（職場内教育）の他に、英会話研修や海外留学制度、自己啓発型通信教育など、充実した教育制度により社員のスキルアップを目指しています。</p>\r\n                                        </section>\r\n                                    </section>\r\n                                </div>\r\n                                <div class=\"thumbImg\">\r\n                                    <img src=\"../assets/img/career_plan/career-img04.jpg\" alt=\"\">\r\n                                    <div class=\"subImg -right\">\r\n                                        <img src=\"../assets/img/career_plan/sub-img01.jpg\" alt=\"\">\r\n                                        <p>教育用パンフレット</p>\r\n                                    </div>\r\n                                </div>\r\n                            </div>\r\n                            <div class=\"paragraph\">\r\n                                <div class=\"textarea\">\r\n                                    <section class=\"item\">\r\n                                        <h2 class=\"ttl\"><span class=\"num\"><img src=\"../assets/img/career_plan/num03.png\" alt=\"03\"></span><span class=\"txt\">やりがいを最も感じられる<br>自立･リーダーへ向けての取り組み</span></h2>\r\n                                        <section class=\"sub\">\r\n                                            <p>入社7〜10年目を対象に、自律型リーダー研修を行い、専門商社に期待される”ビジネスセンス”を身につけ、業務運営に必要な一連のビジネススキルを学び、次世代の管理者を育成しています。</p>\r\n                                        </section>\r\n                                    </section>\r\n                                </div>\r\n                                <div class=\"thumbImg\">\r\n                                    <img src=\"../assets/img/career_plan/career-img05.jpg\" alt=\"\">\r\n                                    <!--<div class=\"subImg -left -pc\">\r\n                                    <img src=\"../assets/img/career_plan/sub-img02.jpg\" alt=\"\">\r\n                                    <p class=\"white\">入社年数に合わせた研修</p>\r\n                                </div>\r\n                                <div class=\"subImg -left -sp\">\r\n                                    <img src=\"../assets/img/career_plan/sub-img02.jpg\" alt=\"\">\r\n                                    <p class=\"white\">入社年数に合わせた研修</p>\r\n                                </div>-->\r\n                                </div>\r\n                            </div>\r\n                        </div>\r\n                        <div class=\"grayWrap -off\">\r\n                            <div class=\"thumbImg\"><img src=\"../assets/img/career_plan/career-img06.jpg\" alt=\"\"></div>\r\n                            <section class=\"textarea\">\r\n                                <span class=\"off\"><img src=\"../assets/img/career_plan/off.png\" alt=\"OFF\"></span>\r\n                                <h2 class=\"ttl\">働く体制が整っている会社ならではの、予定の立てやすいオフ。</h2>\r\n                                <p>仕事をとことん頑張って、ＯＦＦタイムは徹底的に遊ぶ社風。福利厚生倶楽部（リロクラブ）に加入しおり、社員のＯＦＦタイムをサポートしています。</p>\r\n                            </section>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n\r\n            <!-- InstanceEndEditable -->\r\n        </div>\r\n\r\n        <div class=\"linkArea\">\r\n            <div class=\"inner\">\r\n                <div class=\"siteLink\">\r\n                    <ul class=\"linkList\">\r\n                        <li class=\"item\">\r\n                            <a href=\"../guideline\">\r\n                                <div class=\"thumb\"><img src=\"../assets/img/common/bottomMenu-guideline.jpg\" alt=\"募集要項\"></div>\r\n                                <div class=\"textarea\">\r\n                                    <p>募集要項</p>\r\n                                </div>\r\n                            </a>\r\n                        </li>\r\n                        <li class=\"item\">\r\n                  