rgin-left:-2%;\r\n\t\tmargin-right:-2%;\r\n\t}\r\n\t.jigyousyo_block{\r\n\t\twidth:46%;\r\n\t\tfloat:left;\r\n\t\tmargin:1%;\r\n\t\tmargin-bottom:2em;\r\n\t}\r\n}\r\n.jigyousyo_block h4{\r\n\tmargin-bottom:0.5em;\r\n}\r\n.jigyousyo_block li{\r\n\tmargin-left:0.5em;\r\n}\r\n.jigyousyo_block li{\r\n\tpadding:0.1em 0em;\r\n\tmargin-bottom:0em !important;\r\n}\n</style>\n\n</head>\n\n<body itemscope=\"itemscope\" itemtype=\"http://schema.org/WebPage\" id=\"top\">\n<div class=\"bg_shadow\"></div>\n\n<div class=\"all_wraps\">\n\n<header class=\"header\" id=\"header\" itemscope=\"itemscope\" itemtype=\"http://schema.org/WPHeader\">\n<div class=\"header_main\">\n\t\t\t<p class=\"logo\">\n\t\t\t<a href=\"https://kanseikogyo.com/\" title=\"環清工業株式会社\" class=\"fade\">\n\t\t\t\t<img src=\"https://kanseikogyo.com/wp/wp-content/themes/kansei2022/css/images/common/head_logo_mark.png\" alt=\"環清工業株式会社\" width=\"274\" height=\"48\">\n\t\t\t</a>\n\t\t</p>\n\t\n\t\t\t\t<div id=\"nav-toggle\">\n\t\t\t<div class=\"sp_head_navi_inner\">\n\t\t\t\t<div>\n\t\t\t\t\t<span></span>\n\t\t\t\t\t<span></span>\n\t\t\t\t\t<span></span>\n\t\t\t\t</div>\n\t\t\t</div><!-- sp_head_navi_inner -->\n\t\t</div><!-- nav-toggle -->\n\n\n\t\t<div id=\"global-nav\">\n\t\t<nav id=\"nav_block\">\n\t\t<ul class=\"head_menu clearfix\">\n\t\t\t<li><a class=\"link_block ntop_link\" href=\"https://kanseikogyo.com/info_01.html\" itemprop=\"url\"><span itemprop=\"name\">会社概要</span></a></li>\n\t\t\t<li><a class=\"link_block ntop_link\" href=\"https://kanseikogyo.com/service.html\" itemprop=\"url\"><span itemprop=\"name\">事業内容</span></a></li>\n\t\t\t<li><a class=\"link_block ntop_link\" href=\"https://kanseikogyo.com/policy.html\" itemprop=\"url\"><span itemprop=\"name\">環境方針</span></a></li>\n\t\t\t<li><a class=\"link_block ntop_link\" href=\"https://kanseikogyo.com/recruit.html\" itemprop=\"url\"><span itemprop=\"name\">採用情報</span></a></li>\n\t\t</ul><!-- head_menu -->\n\t\t</nav><!-- nav_block -->\n\t</div><!-- global-nav -->\n</div><!-- header_main -->\n\n\t\t\t<span class=\"head_50th\">\n\t\t\t\t<img src=\"https://kanseikogyo.com/wp/wp-content/themes/kansei2022/css/images/common/head_50th.png\" alt=\"50周年\" width=\"99\">\n\t\t\t</span>\n\t\t\t<span class=\"head_banner\"><a href=\"https://kanseikogyo.com/03_water_repair.html\" class=\"fade\">\n\t\t\t\t<img src=\"https://kanseikogyo.com/wp/wp-content/themes/kansei2022/css/images/common/head_banner_2.png\" alt=\"水もれ・水まわりのトラブル\" width=\"339\">\n\t\t\t</a></span>\n\n\n</header>\n\n\n\n\n\n\n\n\n<div id=\"wrap\">\n<main id=\"main\" itemscope=\"itemscope\" itemtype=\"http://schema.org/WebPageElement\">\n<article>\n\n\n\t\t\t\t<div class=\"page_title\"><div class=\"inner_block\"><h1>会社概要</h1></div></div>\n\t\n\t\n\t\n\t\n\t\n\t\n\t\t<div id=\"breadcrumb\" typeof=\"BreadcrumbList\" vocab=\"https://schema.org/\">\n\t<div class=\"inner_block\">\n\t<!-- Breadcrumb NavXT 7.1.0 -->\n<span property=\"itemListElement\" typeof=\"ListItem\"><a property=\"item\" typeof=\"WebPage\" title=\"Go to 環清工業株式会社.\" href=\"https://kanseikogyo.com\" class=\"home\" ><span property=\"name\">ホーム</span></a><meta property=\"position\" content=\"1\"></span> &gt; <span property=\"itemListElement\" typeof=\"ListItem\"><a property=\"item\" typeof=\"WebPage\" title=\"Go to 会社案内.\" href=\"https://kanseikogyo.com/contents.html\" class=\"post post-page\" ><span property=\"name\">会社案内</span></a><meta property=\"position\" content=\"2\"></span> &gt; <span property=\"itemListElement\" typeof=\"ListItem\"><span property=\"name\" class=\"post post-page current-item\">会社概要</span><meta property=\"url\" content=\"https://kanseikogyo.com/contents/info_01.html\"><meta property=\"position\" content=\"3\"></span>\t</div>\n\t</div>\n\n\t\t\t\t<div class=\"inner_block page_wrap clearfix\" itemprop=\"articleBody\">\n\t\n<style>\n\n</style>\n\n\n\t\t\t\t\t\t\t<div class=\"contents_css page_content clearfix\">\n\t\t\t\t<section>\r\n<h2>会社概要</h2>\r\n<div class=\"text_center\"><img src=\"/images/2022/kanseikogyo_exterior.jpg\" alt=\"環清工業株式会社　本社\"></div>\r\n</section>\r\n\r\n<section>\r\n<table>\r\n<tbody>\r\n<tr>\r\n<th>商号</th>\r\n<td>環清工業株式会社</td>\r\n</tr>\r\n<tr>\r\n<th>所在地</th>\r\n<td>本社<br>\r\n〒998-0112<br>\r\n山形県酒田市浜中字八間山135番地の1</td>\r\n</tr>\r\n<tr>\r\n<th>代表者</th>\r\n<td>代表取締役　青山　武</td>\r\n</tr>\r\n<tr>\r\n<th>設立</th>\r\n<td>昭和47年3月8日</td>\r\n</tr>\r\n<tr>\r\n<th>資本金</th>\r\n<td>2,400万円</td>\r\n</tr>\r\n</tbody>\r\n</table>\r\n</section>\r\n\r\n<section>\r\n<div class=\"jigyousyo clearfix\">\r\n<div class=\"jigyousyo_block\">\r\n<h4>本社</h4>\r\n<ul>\r\n<li>〒998-0112<br>山形県酒田市浜中字八間山135番地の1</li>\r\n<li>TEL　：　0234-92-3111</li>\r\n<li>FAX　：　0234-92-3115</li>\r\n<li>フリーダイヤル　：　0120-35-4415</li>\r\n<li>HP　：　https://www.kanseikogyo.com/</li>\r\n</ul>\r\n</div>\r\n\r\n<div class=\"jigyousyo_block\">\r\n<h4>遊佐事業所　/　技術研究所</h4>\r\n<ul>\r\n<li>〒999-8437<br>山形県飽海郡遊佐町藤崎字茂り松61-120</li>\r\n<li>TEL　：　0234-75-3350</li>\r\n<li>FAX　：　0234-75-3868</li>\r\n</ul>\r\n</div>\r\n</div>\r\n<div class=\"jigyousyo clearfix\">\r\n<div class=\"jigyousyo_block\">\r\n<h4>山形営業所</h4>\r\n<ul>\r\n<li>〒990-0022<br>山形県山形市東山形一丁目15-1<br>山形蔵王インター前ビル1階Ａ</li>\r\n<li>TEL　：　023-625-0553</li>\r\n<li>FAX　：　023-625-0576</li>\r\n</ul>\r\n</div>\r\n\r\n<div class=\"jigyousyo_block\">\r\n<h4>秋田支店</h4>\r\n<ul>\r\n<li>〒018-0311<br>\r\n秋田県にかほ市金浦字川向28-1</li>\r\n<li>TEL　：　0184-38-4131</li>\r\n<li>FAX　：　0184-38-4132</li>\r\n</div>\r\n</div>\r\n</section>\r\n\r\n\r\n\r\n<section>\r\n<h3>各種設備工事の主な実績</h3>\r\n\r\n\r\n<ul class=\"sekou_list clearfix\">\r\n<!--\r\n<li><span>下水道切替工事</span></li>\r\n-->\r\n<li><span>給排水衛生設備工事</span></li>\r\n<li><span>上下水道工事</span></li>\r\n</ul>\r\n\r\n<div class=\"waku_block2\">\r\n<h4>令和5年度</h4>\r\n<h5>公共</h5>\r\n<div class=\"pl1\">\r\n<ul>\r\n<li class=\"indent1em\">・令和４年度山形県立庄内中高一貫校（仮称）高等学校校舎増築その他（衛生設備）工事</li>\r\n<li class=\"indent1em\">・庄内検診センター施設空調機更新整備</li>\r\n<li class=\"indent1em\">・令和５年度酒田市北新橋一丁目地内ほか配水管改良工事</li>\r\n<li class=\"indent1em\">・令和５年度東町一丁目地内ほか配水管改良工事</li>\r\n</ul>\r\n</div>\r\n<h5>民間</h5>\r\n<div class=\"pl1\">\r\n<ul>\r\n<li class=\"indent1em\">・A 社　蒸留所新築工事（機械設備工事）</li>\r\n<li class=\"indent1em\">・B 社　店舗改装工事（機械設備工事一式）</li>\r\n<li class=\"indent1em\">・若竹町一丁目外２地内低圧経年管取替工事</li>\r\n<li class=\"indent1em\">・C 社　遊佐小学校低学年トイレ改修工事（機械設備工事一式）</li>\r\n</ul>\r\n</div>\r\n</div>\r\n</section>\r\n\r\n<section>\r\n<div class=\"waku_block2\">\r\n<h4>令和4年度</h4>\r\n<h5>公共</h5>\r\n<div class=\"pl1\">\r\n<ul>\r\n<li class=\"indent1em\">・大町団地給排水管改修工事（第６号棟）</li>\r\n<li class=\"indent1em\">・庄内検診センター施設東側空調機更新工事</li>\r\n<li class=\"indent1em\">・令和４年度四ツ興野地内ほか配水管改良工事</li>\r\n<li class=\"indent1em\">・令和４年度米島地内配水管改良工事</li>\r\n</ul>\r\n</div>\r\n<h5>民間</h5>\r\n<div class=\"pl1\">\r\n<ul>\r\n<li class=\"indent1em\">・秋田市D マンション管理組合　排水管4 系統更生・管入替工事</li>\r\n<li class=\"indent1em\">・E 社　庄内営業所新築工事（機械設備工事一式）</li>\r\n<li class=\"indent1em\">・中町一丁目外１地内低圧経年管取替工事</li>\r\n<li class=\"indent1em\">・F 社　しらい自然館ボイラー更新工事（機械設備配管工事）</li>\r\n</ul>\r\n</div>\r\n</div>\r\n</section>\r\n\r\n<section>\r\n<div class=\"waku_block2\">\r\n<h4>令和3年度</h4>\r\n<h5>公共</h5>\r\n<div class=\"pl1\">\r\n<ul>\r\n<li class=\"indent1em\">・新消防本部・本署庁舎建設工事(機械設備工事)</li>\r\n<li class=\"indent1em\">・遊佐町立図書館空調設備更新工</li>\r\n<li class=\"indent1em\">・令和２年度（繰越）山形県立加茂水産高等学校エアコン施設工事</li>\r\n<li class=\"indent1em\">・令和3年度大宮町二丁目地内配水管改良工事</li>\r\n</ul>\r\n</div>\r\n<h5>民間</h5>\r\n<div class=\"pl1\">\r\n<ul>\r\n<li class=\"indent1em\">・A JV　酒田中町二丁目地区第一種市街地再開発事業施設建築物新築工事　機械設備工事</li>\r\n<li class=\"indent1em\">・B社　遊佐小学校校舎増築工事（機械設備工事一式）</li>\r\n<li class=\"indent1em\">・H社　酒田港整備事業費東ふ頭交流施設改修工事のうち機械設備工事</li></ul>\r\n</div>\r\n</div>\r\n</section>\r\n\r\n<section>\r\n<div class=\"waku_block2\">\r\n<h4>令和2年度</h4>\r\n<h5>公共</h5>\r\n<div class=\"pl1\">\r\n<ul>\r\n<li class=\"indent1em\">・令和2年度庄内食肉流通センター蒸気設備及び加圧給湯設備改修工事</li>\r\n<li class=\"indent1em\">・令和2年度庄内食肉流通センター空調設備改修工事</li>\r\n<li class=\"indent1em\">・宮野浦学区コミュニティ振興会トイレ改修工事</li>\r\n<li class=\"indent1em\">・酒田拘置支所職員宿舎集中検針盤修繕工事</li>\r\n</ul>\r\n</div>\r\n<h5>民間</h5>\r\n<div class=\"pl1\">\r\n<ul>\r\n<li class=\"indent1em\">・ＡＡ管理組合　排水管2系統更生・管入替工事</li>\r\n<li class=\"indent1em\">・A社　GHPエアコン更新工事</li>\r\n<li class=\"indent1em\">・K社　店舗改築工事　（衛生設備工事）</li>\r\n<li class=\"indent1em\">・S銀行　支店空調機更新工事</li>\r\n</ul>\r\n</div>\r\n</div>\r\n</section>\r\n\r\n<section>\r\n<div class=\"waku_block2 mb1\">\r\n<h4>令和元年度</h4>\r\n<h5>公共</h5>\r\n<div class=\"pl1\">\r\n<ul>\r\n<li class=\"indent1em\">・令和元年度遊佐特定環境保全公共下水道マンホールポンプ設置工事（その１）</li>\r\n<li class=\"indent1em\">・中学校普通教室ｴｱｺﾝ設置工事（四中、六中、鳥海八幡中、東部中）（機械設備工事）</li>\r\n<li class=\"indent1em\">・大町団地給排水管改修工事（第3号棟）</li>\r\n<li class=\"indent1em\">・蕨岡・遊佐小学校エアコン設置工事</li>\r\n<li class=\"indent1em\">・遊佐中学校エアコン設置工事</li>\r\n<li class=\"indent1em\">・平成30年度（繰越）山形県立酒田特別支援学校エアコン整備工事</li>\r\n</ul>\r\n</div>\r\n<h5>民間</h5>\r\n<div class=\"pl1\">\r\n<ul>\r\n<li class=\"indent1em\">・M社会福祉法人　ｳｫｰﾀｰﾁﾘﾝｸﾞﾕﾆｯﾄ及び真空式温水発生機設備更新工事</li>\r\n</ul>\r\n</div>\r\n</div>\r\n<p class=\"text_right\">など、この他民間企業様からも多数ご用命いただいております。</p>\r\n</section>\r\n\r\n\r\n<section>\r\n<h3>関連リンク</h3>\r\n<ul class=\"icon_list\">\r\n<li><span class=\"other_site\"><a href=\"http://www.yamagata-suisituhozen.or.jp/\" target=\"_blank\" rel=\"noopener\">公益社団法人 山形県水質保全協会</a></span></li>\r\n<li><span class=\"other_site\"><a href=\"http://www.yamagata-sanpai.or.jp/\" target=\"_blank\" rel=\"noopener\">一般社団法人 山形県産業資源循環協会</a></span></li>\r\n<li><span class=\"other_site\"><a href=\"http://www.jascoma.com/\" target=\"_blank\" rel=\"noopener\">公益社団法人 日本下水道管路管理業協会</a></span></li>\r\n<li><span class=\"other_site\"><a href=\"http://senjo.or.jp/\" target=\"_blank\" rel=\"noopener\">公益社団法人 日本洗浄技能開発協会</a></span></li>\r\n<li><span class=\"other_site\"><a href=\"http://www.sakata-kankoji.com/\" target=\"_blank\" rel=\"noopener\">酒田管工事協同組合</a></span></li>\r\n<li><span class=\"other_site\"><a href=\"http://nihonkankyohozen.jp/\" target=\"_blank\" rel=\"noopener\">一般社団法人 日本環境保全協会</a></span></li>\r\n<li><span class=\"other_site\"><a href=\"http://jwrca.or.jp/\" target=\"_blank\" rel=\"noopener\">一般社団法人 日本水中ロボット調査清掃協会</a></span></li>\r\n<li><span class=\"other_site\"><a href=\"http://www.all-liner.jp/\" target=\"_blank\" rel=\"noopener\">オールライナー協会</a></span></li>\r\n<li><span class=\"other_site\"><a href=\"http://www.pcgtexas.co.jp/\" target=\"_blank\" rel=\"noopener\">Ｐ・Ｃ・Ｇ工法</a></span></li>\r\n<li><span class=\"other_site\"><a href=\"http://www.epr-koho.com/\" target=\"_blank\" rel=\"noopener\">ＥＰＲ工法協会</a></span></li>\r\n<li><span class=\"other_site\"><a href=\"http://re-model.jp/\" target=\"_blank\" rel=\"noopener\">ＴＯＴＯリモデルクラブ</a></span></li>\r\n<li><span class=\"other_site\"><a href=\"http://www.icepig.org/\" target=\"_blank\" rel=\"noopener\">アイスピグ研究会</a></span></li>\r\n</ul>\r\n</section>\t\t\t</div><!-- content -->\n\t\t\t\t\n\t\t<div class=\"page_sidebar\">\n\t\t\t<section>\n\t\t\t<h2 class=\"sidebar_title_page\">会社案内</h2>\n\t\t\t<ul class=\"side_page_menu\">\n\t\t\t<li><a href=\"https://kanseikogyo.com/contents/info_01.html\" title=\"会社概要\" itemprop=\"url\"><span itemprop=\"name\">会社概要</span></a></li><li><a href=\"https://kanseikogyo.com/contents/info_02.html\" title=\"トップメッセージ\" itemprop=\"url\"><span itemprop=\"name\">トップメッセージ</span></a></li><li><a href=\"https://kanseikogyo.com/contents/info_03.html\" title=\"経営方針\" itemprop=\"url\"><span itemprop=\"name\">経営方針</span></a></li><li><a href=\"https://kanseikogyo.com/contents/info_04.html\" title=\"沿革\" itemprop=\"url\"><span itemprop=\"name\">沿革</span></a></li><li><a href=\"https://kanseikogyo.com/contents/info_09.html\" title=\"施工実績\" itemprop=\"url\"><span itemprop=\"name\">施工実績</span></a></li><li><a href=\"https://kanseikogyo.com/contents/info_05.html\" title=\"営業拠点\" itemprop=\"url\"><span itemprop=\"name\">営業拠点</span></a></li><li><a href=\"https://kanseikogyo.com/contents/info_06.html\" title=\"主な事業概要\" itemprop=\"url\"><span itemprop=\"name\">主な事業概要</span></a></li><li><a href=\"https://kanseikogyo.com/contents/info_07.html\" title=\"許認可・登録・主要資格\" itemprop=\"url\"><span item