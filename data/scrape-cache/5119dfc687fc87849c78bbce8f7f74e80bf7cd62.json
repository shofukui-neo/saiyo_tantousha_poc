01 -->\n    </div>\n    <!--#include virtual=\"/dealer/dairi/_inc/_localNav_recruit.html\" -->\n    <div class=\"bl_N01 recruit-menu\">\n  <div class=\"ly_body\">\n    <ul class=\"bl_N01_list js_matchHeightChildren\">\n      <li class=\"bl_N01_list_child\"><div class=\"bl_N01_list_child_inner\"><span><a href=\"/dealer/sj-matsuyama/recruit/\">採用情報</a></span></div></li>\n      <li class=\"bl_N01_list_child graduate-guideline\"><div class=\"bl_N01_list_child_inner\"><span><a href=\"/dealer/sj-matsuyama/recruit/graduate-guideline/\">【新卒採用】<br>募集要項</a></span></div></li>\n      <li class=\"bl_N01_list_child career-guideline\"><div class=\"bl_N01_list_child_inner\"><span><a href=\"/dealer/sj-matsuyama/recruit/career-guideline/\">【中途採用】<br>募集要項</a></span></div></li>\n      <li class=\"bl_N01_list_child workplace_information\"><div class=\"bl_N01_list_child_inner\"><span><a href=\"/dealer/sj-matsuyama/recruit/workplace_information/\">職場情報</a></span></div></li>\n      <li class=\"bl_N01_list_child briefing\"><div class=\"bl_N01_list_child_inner\"><span><a href=\"/dealer/sj-matsuyama/recruit/briefing/\">説明会情報</a></span></div></li>\n      <li class=\"bl_N01_list_child message\"><div class=\"bl_N01_list_child_inner\"><span><a href=\"/dealer/sj-matsuyama/recruit/message/\">みなさんへの<br />メッセージ</a></span></div></li>\n      <li class=\"bl_N01_list_child workplace\"><div class=\"bl_N01_list_child_inner\"><span><a href=\"/dealer/sj-matsuyama/recruit/workplace/\">職場紹介</a></span></div></li>\n      <li class=\"bl_N01_list_child shop\"><div class=\"bl_N01_list_child_inner\"><span><a href=\"/dealer/sj-matsuyama/recruit/shop/\">拠点紹介</a></span></div></li>\n      <li class=\"bl_N01_list_child topic\"><div class=\"bl_N01_list_child_inner\"><span><a href=\"/dealer/sj-matsuyama/recruit/topic/\">採用トピックス</a></span></div></li>\n    </ul>\n  </div>\n</div>\n<!-- /.bl_N01 -->\n\n\n    <div id=\"workplace_information\">\n        <div class=\"ly_bgGray ly_padding ly_padding__bottom\">\n                <div class=\"ly_body ly_body__mainContents ly_bgWhite\">\n                    <section class=\"bl_sect02\">\n                        <h2 class=\"el_sectTtl__lv2\">職場情報</h2>\n                                                            <table class=\"bl_table__std bl_T01\">\n                                    <tbody>\n                                                                                    <tr>\n                                                <th class=\"bl_table__std_hd__mid\">過去3年間の新卒採用者数・離職者数</th>\n                                                <td>【採用者数】2025年度：7名　2024年度：4名　2023年度：2名　<br />\r\n　　　　　　　　<br />\r\n　　　　　　　　　　<br />\r\n【離職者数】2025年度：1名　2024年度：2名　2023年度：1名　　(2026年1月時点)</td>\n                                            </tr>\n                                                                                    <tr>\n                                                <th class=\"bl_table__std_hd__mid\">過去3年間の男女別新卒採用者数</th>\n                                                <td>2025年度：男性5名　女性2名<br />\r\n2024年度：男性1名　女性3名<br />\r\n2023年度：男性1名　女性1名<br />\r\n2022年度：男性1名　女性8名<br />\r\n</td>\n                                            </tr>\n                                                                                    <tr>\n                                                <th class=\"bl_table__std_hd__mid\">平均勤続年数</th>\n                                                <td>12.6年</td>\n                                            </tr>\n                                                                                    <tr>\n                                                <th class=\"bl_table__std_hd__mid\">平均年齢</th>\n                                                <td>40.5歳</td>\n                                            </tr>\n                                                                                    <tr>\n                                                <th class=\"bl_table__std_hd__mid\">研修</th>\n                                                <td>新入社員研修、入社２年目研修、保険募集人資格講習、中古自動車査定士資格講習等</td>\n                                            </tr>\n                                                                                    <tr>\n                                                <th class=\"bl_table__std_hd__mid\">自己啓発支援</th>\n                                                <td>通信教育受講援助制度</td>\n                                            </tr>\n                                                                                    <tr>\n                                                <th class=\"bl_table__std_hd__mid\">メンター制度</th>\n                                                <td>あり</td>\n                                            </tr>\n                                                                                    <tr>\n                                                <th class=\"bl_table__std_hd__mid\">キャリアコンサルティング制度</th>\n                                                <td>半期ごとの目標設定と結果について上司と面談あり</td>\n                                            </tr>\n                                                                                    <tr>\n                                                <th class=\"bl_table__std_hd__mid\">社内検定等の制度</th>\n                                                <td>スズキ販売士制度（営業職）、スズキサービス技能資格制度（整備職）</td>\n                                            </tr>\n                                                                                    <tr>\n                                                <th class=\"bl_table__std_hd__mid\">月平均所定外労働時間</th>\n                                                <td>13.0時間</td>\n                                            </tr>\n                                                                                    <tr>\n                                                <th class=\"bl_table__std_hd__mid\">有給休暇の平均取得日数</th>\n                                                <td>12.9日</td>\n                                            </tr>\n                     