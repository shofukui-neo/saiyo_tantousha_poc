v__swiper swiper swiper__main\">\n          <div class=\"swiper-wrapper\">\n            <div class=\"kv__swiper--item swiper-slide\">\n              <figure class=\"kv__img\"><span class=\"swiper__imgwrap\"><img src=\"https://okuigumi.co.jp/saiyo-new/wp/wp-content/themes/try-csh/img/top/kv01.jpg\" alt=\"メインビジュアル\"></span></figure>\n            </div>\n            <div class=\"kv__swiper--item swiper-slide\">\n              <figure class=\"kv__img\"><span class=\"swiper__imgwrap\"><img src=\"https://okuigumi.co.jp/saiyo-new/wp/wp-content/themes/try-csh/img/top/kv02.jpg\" alt=\"メインビジュアル\"></span></figure>\n            </div>\n            <div class=\"kv__swiper--item swiper-slide\">\n              <figure class=\"kv__img\"><span class=\"swiper__imgwrap\"><img src=\"https://okuigumi.co.jp/saiyo-new/wp/wp-content/themes/try-csh/img/top/kv03.jpg\" alt=\"メインビジュアル\"></span></figure>\n            </div>\n            <div class=\"kv__swiper--item swiper-slide\">\n              <figure class=\"kv__img\"><span class=\"swiper__imgwrap\"><img src=\"https://okuigumi.co.jp/saiyo-new/wp/wp-content/themes/try-csh/img/top/kv04.jpg\" alt=\"メインビジュアル\"></span></figure>\n            </div>\n          </div>\n        </div>\n        <div class=\"swiper-pagination\"></div>\n      </div>\n\n      <h2 class=\"kv__copy\">\n        <img class=\"txt\" src=\"https://okuigumi.co.jp/saiyo-new/wp/wp-content/themes/try-csh/img/top/kv_copy.png\" alt=\"でかい夢を、でかい力で 叶える仕事\">\n      </h2>\n    </div>\n  </section>\n\n  <section class=\"greeting section ps-r\" id=\"greeting\">\n    <div class=\"inner\">\n      <div class=\"gre__flex flex jc-between\">\n        <div class=\"gre__left\">\n          <h2 class=\"gre__copy color-ma  fs-30 lh-2\">\n            右も左もわからない。<br>\n            それが<br>\n            新人らしさであり<br>\n            <span class=\"large\">“強み”</span>\n          </h2>\n        </div>\n        <div class=\"gre__right\">\n          <p class=\"gre__txt fs-18\">\n            「でかい夢」「でかい力」。<br>\n            そう言われるとなんだか尻込みしてしまいますよね。<br>\n            「自分にできるだろうか」「なにもわからないのに…」と。<br>\n            でも安心してください。最初はなにもわからなくて当然です。<br>\n            奥井組は何もかもが　“はじめて”　のあなたを歓迎します。<br>\n            会社が一丸となって、「何も知らないあなた」から<br class=\"spnone\">\n            「なんでもできるあなた」になれるよう、全力でサポートします。<br>\n            そのままのあなたのままで、安心して入社してください。<br>\n            そして、あなたの「若さ溢れる考えや想い」を存分に生かしてください。<br>\n            「子供たちの未来を豊かに」するために、<br class=\"spnone\">\n            共に進み続けましょう。\n          </p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"about ps-r\" id=\"about\">\n    <div class=\"inner\">\n      <h2 class=\"about__ttl section__ttl mb-50\"><span class=\"txt color-wh\">奥井組を知る</span><span class=\"font-en\">ABOUT US</span></h2>\n      <p class=\"about__txt fs-18 bold mb-40 color-wh\">奥井組は、昭和29年の創業以来、ワンストップサービスを実現するべく着実に事業を拡大してきました。そんな私たちの事業に懸ける想いやこれまでの道のり、環境への取り組み姿勢などをお伝えします。</p>\n      <p class=\"about__btn font-en\"><a class=\"link__btn\" href=\"https://okuigumi.co.jp/saiyo-new/about/\">VIEW\n          MORE<i class=\"arw fa-solid fa-chevron-right\"></i></a></p>\n    </div>\n  </section>\n\n  <section class=\"business  ps-r\" id=\"business\">\n    <div class=\"busi__flex flex jc-between align-items\">\n      <div class=\"busi__left\">\n        <div class=\"busi__left--inner\">\n          <h2 class=\"business__ttl section__ttl mb-50\"><span class=\"txt color-wh\">事業を知る</span><span class=\"font-en\">BUSINESS</span></h2>\n          <p class=\"busi__txt fs-18 bold mb-40 color-wh\">株式会社奥井組は、運輸、物流、機工、プラント建設、サブリース、CFS建築を主軸に、クレーンリース、環境を加えた8部門によるワンストップサービス「テクノソリューション」を提供しております。</p>\n          <p class=\"busi__btn font-en\"><a class=\"link__btn white\" href=\"https://okuigumi.co.jp/saiyo-new/business/\">VIEW MORE<i class=\"arw fa-solid fa-chevron-right\"></i></a></p>\n        </div>\n      </div>\n      <div class=\"busi__right\">\n        <figure class=\"busi__img\"><img src=\"https://okuigumi.co.jp/saiyo-new/wp/wp-content/themes/try-csh/img/top/business_img.png\" alt=\"事業\"></figure>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"person section  ps-r\" id=\"person\">\n    <div class=\"person__flex flex jc-between\">\n      <div class=\"person__left\">\n        <div class=\"person__left--inner\">\n          <h2 class=\"person__ttl section__ttl mb-50\"><span class=\"txt color-ma\">人を知る</span><span class=\"font-en\">PERSON</span></h2>\n          <p class=\"person__txt fs-18 bold mb-40\">\n            若手からベテランまで、<br>\n            奥井組で働く現役社員に入社のきっかけから日々の仕事内容ややりがい、<br>\n            そして未来への展望について聞きました。\n          </p>\n          <!-- 第２フェーズ用▼ -->\n          <p class=\"person__btn font-en\"><a class=\"link__btn green\" href=\"https://okuigumi.co.jp/saiyo-new/person/\">VIEW MORE<i class=\"arw fa-solid fa-chevron-right\"></i></a></p>\n        </div>\n      </div>\n      <div class=\"person__right\">\n        <div class=\"person__atcwarp flex  ps-r\">\n          <article class=\"person__atc atc01 swiper-slide\">\n            <a href=\"https://okuigumi.co.jp/saiyo-new/person/voice01/\">\n              <figure class=\"person__img\"><img src=\"https://okuigumi.co.jp/saiyo-new/wp/wp-content/themes/try-csh/img/top/person_img01.jpg\" alt=\"スタッフ\"></figure>\n              <div class=\"person__txtwrap flex jc-between\">\n                <h3 class=\"person__h3 fs-20\">\n                  <span class=\"position color-ma fs-14 block\">物流部門</span>\n                  佐藤 竜二\n                </h3>\n                <p class=\"person__arw\">\n                  <img src=\"https://okuigumi.co.jp/saiyo-new/wp/wp-content/themes/try-csh/img/cmn/link_arw_gr.png\" alt=\"矢印\">\n                </p>\n              </div>\n            </a>\n          </article>\n          <article class=\"person__atc atc03\">\n            <a href=\"https://okuigumi.co.jp/saiyo-new/person/voice02/\">\n              <figure class=\"person__img\"><img src=\"https://okuigumi.co.jp/saiyo-new/wp/wp-content/themes/try-csh/img/top/person_img02.jpg\" alt=\"スタッフ\"></figure>\n      