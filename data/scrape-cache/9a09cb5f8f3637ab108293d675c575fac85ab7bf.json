{"url":"https://www.abeam-s.com/recruit/training/","html":"<!doctype html>\n<html lang=\"ja\">\n<head>\n\t<!-- Google tag (gtag.js) -->\n\t<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-XSBP9CBXSR\"></script>\n\t<script>\n\t  window.dataLayer = window.dataLayer || [];\n\t  function gtag(){dataLayer.push(arguments);}\n\t  gtag('js', new Date());\n\n\t  gtag('config', 'G-XSBP9CBXSR');\n\t</script>\n\t<meta charset=\"utf-8\">\n\t<meta name=\"format-detection\" content=\"telephone=no\">\n\t<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n\t<meta name=\"description\" content=\"アビームシステムズの新卒採用サイトです。新卒入社される方を対象とした内定者・新入社員研修をご紹介します。\">\n\t<meta name=\"keywords\" content=\"新卒採用,内定者研修,,新入社員研修,プログラミングスキル,内定者懇親会,プログラミング学習,新入社員研修,ビジネス研修,IT研修,専門教育,OPEN系研修,SAP研修\">\n\t<title>内定者・新入社員研修｜アビームシステムズ株式会社　新卒採用サイト</title>\n\t<meta property=\"og:title\" content=\"内定者・新入社員研修｜アビームシステムズ株式会社　新卒採用サイト\">\n\t<meta property=\"og:type\" content=\"article\">\n\t<meta property=\"og:description\" content=\"アビームシステムズの新卒採用サイトです。新卒入社される方を対象とした内定者・新入社員研修をご紹介します。\">\n    <meta property=\"og:url\" content=\"https://www.abeam-s.com/recruit/training/\">\n\t<link rel=\"stylesheet\" href=\"https://site-assets.fontawesome.com/releases/v6.4.0/css/all.css\">\n\t<link rel=\"stylesheet\" type=\"text/css\" href=\"../../assets/style.css\">\n\t<script src=\"../../js/head.js\"></script>\n</head>\n<body>\n\t<div id=\"container\"><!-- #BeginLibraryItem \"/Library/header.lbi\" -->\n<header id=\"gHeader\">\n<div class=\"hBox flexB\">\n    <div class=\"hInfo flex\">\n        <div class=\"logo\"><a href=\"/\" target=\"_blank\"><img src=\"../../assets/images/common/logo_img.png\" alt=\"ABeam Systems&reg;\"></a></div>\n        <h1>アビームシステムズ 採用サイト</h1>\n    </div>\n    <div class=\"hInner flex\">\n        <nav id=\"gNavi\">\n            <ul class=\"flex\">\n                <li><a href=\"../../recruit\">新卒採用<i class=\"fa-regular fa-angle-down\"></i></a>\n                    <div class=\"naviBox\">\n  