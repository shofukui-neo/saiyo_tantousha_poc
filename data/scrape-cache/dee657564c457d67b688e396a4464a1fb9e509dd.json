p-content/uploads/2018/04/contact.png\"  width=\"171\">\n\t\t\t\t\t\t\t</a>\n\t\t</li>\n\t</ul>\n</nav></header>\t<div id=\"contents__wrapper\"><div class=\"contents\" data-namespace=\"home\">\n\t<div class=\"main home\">\n\t\t<div class=\"swiper-container home-container\">\n\t\t\t<div class=\"swiper-wrapper\">\n\t\t\t\t<div class=\"swiper-slide\" style=\"background-image:url(https://www.sakura-kobo.co.jp/wp-content/themes/po_tmp/assets/images/home/hero-img.png);\"></div>\n\t\t\t\t<div class=\"swiper-slide\" style=\"background-image:url(https://www.sakura-kobo.co.jp/wp-content/themes/po_tmp/assets/images/home/hero-img2.png);\"></div>\n\t\t\t\t<div class=\"swiper-slide\" style=\"background-image:url(https://www.sakura-kobo.co.jp/wp-content/themes/po_tmp/assets/images/home/hero-img3.png);\"></div>\n\t\t\t\t<div class=\"swiper-slide\" style=\"background-image:url(https://www.sakura-kobo.co.jp/wp-content/themes/po_tmp/assets/images/home/hero-img4.png);\"></div>\n\t\t\t</div>\n\t\t\t<div class=\"swiper-pagination\"></div>\n\t\t</div>\n\t\t<div class=\"home-info\">\n\t\t\t<div class=\"inner\">\n\t\t\t\t<h2 class=\"home-info-ttl free__otherinfo__title\">\n\t\t\t\t\t馬刺し一筋、五十年。\n\t\t\t\t</h2>\n\t\t\t\t<p class=\"home-info-text\">\n\t\t\t\t\t「世界一美味しくて、安心・安全な馬肉をお客様に提供すること」それが私たちの信念です。<br>\n\t\t\t\t\t創業から50年を迎える大成は、「さくら工房」という自社ブランドに誇りと責任を持ち、<br>\n\t\t\t\t\t馬肉のプロフェッショナルとして、より良い商品を皆様にお届けできるよう、日々邁進してまいります。<br>\n\t\t\t\t\t<br>\n\t\t\t\t\t大地の恵みに感謝を忘れずに。<br>\n\t\t\t\t\t「美味しい」と「安心」を追求した、さくら工房の馬肉を是非ご堪能ください。<br>\n\t\t\t\t</p>\n\t\t\t</div>\n\t\t</div>\n\t</div>\n\t<div class=\"home-menu\">\n\t\t<div class=\"inner\">\n\t\t\t<ul class=\"home-menu-list\">\n\t\t\t\t<li class=\"home-menu-item\">\n\t\t\t\t\t<a href=\"/about/\" class=\"home-menu-item-link\">\n\t\t\t\t\t\t<img src='https://www.sakura-kobo.co.jp/wp-content/themes/po_tmp/assets/images/home/top-img01.jpg' width=\"250\">\n\t\t\t\t\t\t<span>大成のさくら肉</span>\n\t\t\t\t\t</a>\n\t\t\t\t</li>\n\t\t\t\t<li class=\"home-menu-item\">\n\t\t\t\t\t<a href=\"/products/\" class=\"home-menu-item-link\">\n\t\t\t\t\t\t<img src='https://www.sakura-kobo.co.jp/wp-content/themes/po_tmp/assets/images/home/top-img02.jpg' width=\"250\">\n\t\t\t\t\t\t<span>商品案内</span>\n\t\t\t\t\t</a>\n\t\t\t\t</li>\n\t\t\t\t<li class=\"home-menu-item\">\n\t\t\t\t\t<a href=\"/voice/\" class=\"home-menu-item-link\">\n\t\t\t\t\t\t<img src='https://www.sakura-kobo.co.jp/wp-content/themes/po_tmp/assets/images/home/top-img03.jpg' width=\"250\">\n\t\t\t\t\t\t<span>生産者の声</span>\n\t\t\t\t\t</a>\n\t\t\t\t</li>\n\t\t\t\t<li class=\"home-menu-item\">\n\t\t\t\t\t<a href=\"/company/\" class=\"home-menu-item-link\">\n\t\t\t\t\t\t<img src='https://www.sakura-kobo.co.jp/wp-content/themes/po_tmp/assets/images/home/top-img04.jpg' width=\"250\">\n\t\t\t\t\t\t<span>会社情報</span>\n\t\t\t\t\t</a>\n\t\t\t\t</li>\n\t\t\t</ul>\n\t\t</div>\n\t</div>\n\t<div class=\"home-news\">\n\t\t<div class=\"inner\">\n\t\t\t<h1 class=\"home-news-ttl\">\n\t\t\t\t新着情報\n\t\t\t</h1>\n\t\t\t<section class=\"news__list\"><li class=\"news__item\">\n\t<a href=\"https://www.sakura-kobo.co.jp/news/929/\" class=\"news__item__link\">\n\t\t<p class=\"news__item__date\">2025年12月5日</p>\n\t\t<p class=\"news__item__title\">年末年始及び12月・1月　休業日のお知らせ</p>\n\t</a>\n</li><li class=\"news__item\">\n\t<a href=\"https://www.sakura-kobo.co.jp/news/926/\" class=\"news__item__link\">\n\t\t<p class=\"news__item__date\">2025年12月5日</p>\n\t\t<p class=\"news__item__title\">2025年　年末ギフト商品のご案内</p>\n\t</a>\n</li><li class=\"news__item\">\n\t<a href=\"https://www.sakura-kobo.co.jp/news/923/\" class=\"news__item__link\">\n\t\t<p class=\"news__item__date\">2025年9月30日</p>\n\t\t<p class=\"news__item__title\">10月休業日のお知らせ</p>\n\t</a>\n</li><li class=\"news__item\">\n\t<a href=\"https://www.sakura-kobo.co.jp/news/920/\" class=\"news__item__link\">\n\t\t<p class=\"news__item__date\">2025年9月11日</p>\n\t\t<p class=\"news__item__title\">SDGｓの取り組みとして地元の小中学校に馬肉を提供しました</p>\n\t</a>\n</li><li class=\"news__item\">\n\t<a href=\"https://www.sakura-kobo.co.jp/news/917/\" class=\"news__item__link\">\n\t\t<p class=\"news__item__date\">2025年8月28日</p>\n\t\t<p class=\"news__item__title\">9月休業日のお知らせ</p>\n\t</a>\n</li></section>\t\t\t<div class=\"more\">\n\t\t\t\t<a href=\"/news/\"><span>記事一覧</span></a>\n\t\t\t</div>\n\t\t</div>\n\t</div>\n\t<div class=\"home-map\">\n\t\t<div class=\"inner\">\n\t\t\t<div class=\"home-map-info\">\n\t\t\t\t<h2 class=\"home-map-ttl\">\n\t\t\t\t\t<span>より良い商品を、より求めやすく。</span>\n\t\t\t\t</h2>\n\t\t\t\t<p class=\"home-map-text\">\n\t\t\t\t\tさくら工房の馬刺しの原料は、主にポーランド産、カナダ産を使用しています。<br>\n\t\t\t\t\tなかでもポーランドの重種馬からは希少部位を豊富に取る事ができます。<br>\n\t\t\t\t\t生産体制整備により、霜降りから赤身まですべてのランクの安全供給と価格の安定に努めています。\n\t\t\t\t</p>\n\t\t\t\t<div class=\"detail-wrap\">\n\t\t\t\t\t<a href=\"/about/\" class=\"detail\">\n\t\t\t\t\t\t<span>DETAIL</span>\n\t\t\t\t\t</a>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\t</div>\n\t<div class=\"home-quality\">\n\t\t<div class=\"inner\">\n\t\t\t<div class=\"home-quality-info\">\n\t\t\t\t<h2 class=\"home-quality-ttl\">\n\t\t\t\t\t<span>徹底した品質管理、衛生管理</span>\n\t\t\t\t</h2>\n\t\t\t\t<p class=\"home-quality-text\">\n\t\t\t\t\t大成の生食用馬肉は、食用の衛生基準（H10.9.11）に沿った加工処理をしています。<br>\n\t\t\t\t\tまた生食用食品はすべてLotにより安全性の管理を行っています。<br>\n\t\t\t\t\t賞味期限や加工者を明記し、万一の場合にも製造状況と検査結果の調査が可能です。\n\t\t\t\t</p>\n\t\t\t\t<div class=\"detail-wrap\">\n\t\t\t\t\t<a href=\"/feature/\" class=\"detail\">\n\t\t\t\t\t\t<span>DETAIL</span>\n\t\t\t\t\t</a>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\t</div>\n\t<div class=\"home-footer\">\n\t\t<div class=\"inner\">\n\t\t\t<div class=\"home-footer-info\">\n\t\t\t\t<div class=\"home-footer-info-logo\">\n\t\t\t\t\t<img src='https://www.sakura-kobo.co.jp/wp-content/themes/po_tmp/assets/images/home/logo.png' width=\"187\">\n\t\t\t\t</div>\n\t\t\t\t<div class=\"home-footer-info-inner\">\n\t\t\t\t\t<h2>さくら工房  株式会社 大成</h2>\n\t\t\t\t\t<p class=\"\">\n\t\t\t\t\t\t〒399-3701<br>長野県上伊那郡飯島町大字田切1212-400\n\t\t\t\t\t</p>\n\t\t\t\t\t<ul>\n\t\t\t\t\t\t<li>TEL　0265-86-5111</li>\n\t\t\t\t\t\t<li>FAX　0265-86-4284</li>\n\t\t\t\t\t</ul>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t\t<div class=\"home-footer-bnr\">\n\t\t\t\t<a href=\"http://viande1129.com/\" target=\"_blank\">\n\t\t\t\t\t<img src='https://www.sakura-kobo.co.jp/wp-content/themes/po_tmp/assets/images/home/bnr.jpg' width=\"253\">\n\t\t\t\t</a>\n\t\t\t</div>\n\t\t</div>\n\t</div>\n\n</div>\t</div><!--//end-contents__wrap//-->\n\t<footer>\n\t<div class=\"footer__pagetop\">\n\t\t<a href=\"\" class=\"footer__pagetop__link\">\n\t\t\t<span>トップへ戻る</span>\n\t\t</a>\n\t</div>\n\t<nav class=\"glovalNav\">\n\t<ul class=\"glovalNav__inner\">\n\t\t<li class=\"glovalNav__item\">\n\t\t\t<a href=\"/\" class=\"glovalNav__link a-home\">\n\t\t\t\tホーム\n\t\t\t</a>\n\t\t</li>\n\t\t<li class=\"glovalNav__item\">\n\t\t\t<a href=\"/news/\" class=\"glovalNav__link a-news\">\n\t\t\t\t新着情報\n\t\t\t</a>\n\t\t</li>\n\t\t<li class=\"glovalNav__item\">\n\t\t\t<a href=\"/about/\" class=\"glovalNav__link a-about\">\n\t\t\t\t大成のさくら肉\n\t\t\t</a>\n\t\t</li>\n\t\t<li class=\"glovalNav__item\">\n\t\t\t<span class=\"glovalNav__link a-free\">\n\t\t\t\t商品案内\n\t\t\t</span>\n\t\t\t<ul class=\"glovalNav__item__subItem\">\n\t\t\t\t<li><a href=\"/feature/\">冷凍馬刺しの特徴</a></li>\n\t\t\t\t<li><a href=\"/products/\">商品一覧</a></li>\n\t\t\t</ul>\n\t\t</li>\n\t\t<li class=\"glovalNav__item\">\n\t\t\t<a href=\"/voice/\" class=\"glovalNav__link a-voice\">\n\t\t\t\t生産者の声\n\t\t\t</a>\n\t\t</li>\n\t\t<li class=\"glovalNav__item\">\n\t\t\t<span class=\"glovalNav__link a-company\">\n\t\t\t\t会社情報\n\t\t\t</span>\n\t\t\t<ul class=\"glovalNav__item__subItem\">\n\t\t\t\t<li><a href=\"/company/philosophy/\">企業理念</a></li>\n\t\t\t\t<li><a href=\"/company/profile/\">会社概要</a></li>\n\t\t\t\t<li><a href=\"/company/business/\">事業内容</a></li>\n\t\t\t</ul>\n\t\t</li>\n\t\t<li class=\"glovalNav__item\">\n\t\t\t<a href=\"/recruit\" class=\"glovalNav__link a-recruit\">\n\t\t\t\t採用情報\n\t\t\t</a>\n\t\t</li>\n\t\t<li class=\"glovalNav__item glovalNav__item--sp\">\n\t\t\t<a href=\"\" class=\