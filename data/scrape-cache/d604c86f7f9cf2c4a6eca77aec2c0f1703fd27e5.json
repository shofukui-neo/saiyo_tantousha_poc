<link rel=\"stylesheet\" type=\"text/css\" href=\"/asset/lovelycl/js/slick.css\">\n  <link href=\"https://fonts.googleapis.com/css?family=Lato:400,700|Noto+Sans+JP:400,700\" rel=\"stylesheet\">\n  <script src=\"https://ajax.googleapis.com/ajax/libs/jquery/1.8.3/jquery.min.js\"></script>\n  <script src=\"/asset/lovelycl/js/common.js\"></script>\n  <script src=\"/asset/lovelycl/js/slick.min.js\"></script>\n  <script>\n    \n      </script>\n  <style type=\"text/css\" media=\"screen\">\n    .sponsor_bnr {\n      margin-top: 30px;\n    }\n    .sponsor_bnr img {\n      width: 100%;\n      max-width: 840px;\n    }\n  </style>\n<!-- Global site tag (gtag.js) - Google Analytics -->\n<!-- / Global site tag (gtag.js) - Google Analytics -->\n\n</head>\n\n  <body class=\"page-contact\">\n\n<div class=\"header-wrap\">\n  <header class=\"header\">\n    <div id=\"top-head\">\n      <div class=\"header-inner inner\">\n        <div id=\"mobile-head\" class=\"logo-wrap\">\n          <div class=\"logo\">\n            <h1><a href=\"/\"><img src=\"/asset/lovelycl/img/logo.png\" alt=\"ラブリークリーニング\" width=\"386px\" height=\"93px\"></a></h1>\n          </div>\n          <div class=\"navToggle\">\n            <span></span><span></span><span></span><span>メニュー</span>\n          </div>\n        </div>\n        <nav class=\"global-nav l_header_nav globalMenuSp\">\n          <ul>\n            <li>\n              <a href=\"/service/\">サービス<span>Service</span></a>\n            </li>\n            <li>\n              <a href=\"/cleaningmenu/\">クリーニングメニュー<span>Cleaning Menu</span></a>\n            </li>\n            <li>\n              <a href=\"/price/\">料金について<span>Price</span></a>\n            </li>\n            <li>\n              <a href=\"/shoplist/\">店舗一覧<span>Shop List</span></a>\n            </li>\n            <li>\n              <a href=\"/customer/\">法人のお客様<span>Customer</span></a>\n            </li>\n          </ul>\n          <div class=\"link-sub\">\n            <a href=\"/company/\">会社概要</a>\n            <a href=\"https://lovely-cl-recruit.jp/-/top/\" target=\"_blank\" rel=\"nofollow\">採用情報</a>\n            <a href=\"/contact/\">お問合せ</a>\n          </div>\n        </nav>\n      </div>\n    </div>\n  </header>\n\n\n  <section class=\"page-header\">\n        <h2><img src=\"https://www.lovely-cl.co.jp/wp/wp-content/uploads/2019/07/ttl-contact.png\" alt=\"お問合せ\"></h2>\n  </section>\n  <section class=\"bread-crumbs\">\n    <div>\n      <!-- Breadcrumb NavXT 6.4.0 -->\n<a property=\"item\" typeof=\"WebPage\" title=\"Go to 横浜・川崎のクリーニングなら｜ラブリークリーニング.\" href=\"https://www.lovely-cl.co.jp\" class=\"home\" ><span property=\"name\">TOP</span></a><meta property=\"position\" content=\"1\"> <span class=\"bleak\">&gt;</span> <span class=\"post post-page current-item\">お問合せ</span>    </div>\n  </section>\n</div>\n\n<div class=\"wrapper\">\n<main class=\"\">\n\n   <div class=\"wrapper\">\r\n<main class=\"\">\r\n  <section class=\"contact-form\">\r\n    <div class=\"container\">\r\n      <p class=\"fs-big\">料金やサービスに関するお問い合わせは、ご利用の店舗へ直接お電話にてお問い合わせ下さい。</p>\r\n      <div class=\"contact-other-links\">\r\n        <a href=\"/shoplist/\" class=\"icon-circle-triangle\">店舗一覧へ</a>\r\n      </div>\r\n      <!--<p>※店舗により料金が異なりますので、料金やサービスに関しましては直接店舗へお問い合わせください。</p>-->\r\n      <p>※お問い合わせ頂きました内容についてのご返信ですが、お時間頂く場合がございますので予めご了承ください。</p>\r\n      <p>※記入頂きました内容、入力情報は、お客様へのご返事の他、当社の品質向上、品質管理に利用させて頂き、それ以外には使用致しません。</p>\r\n      <p>※入力頂きました情報は<a href=\"https://lovely-cl.co.jp/privacy/\" target=\"_blank\" rel=\"noopener noreferrer\">当社プライバシーポリシー</a>に基づいて取扱い致します。</p>\r\n      <p>※お問い合わせ頂きましたご質問にはメール、お電話等でお返事致しますがお問い合わせ内容によってはご返信出来ませんので予めご了承ください。</p>\r\n        <div id=\"mw_wp_form_mw-wp-form-395\" class=\"mw_wp_form mw_wp_form_input  \">\n\t\t\t\t\t<form method=\"post\" action=\"\" enctype=\"multipart/form-data\">&nbsp;\r\n<table>\r\n<tbody>\r\n<tr>\r\n<th>\r\n<p class=\"require\">メールアドレス</p>\r\n</th>\r\n<td>\n<input type=\"email\" name=\"メールアドレス\" class=\"mail\" size=\"60\" value=\"\" placeholder=\"(例)lovely@example.com\" data-conv-half-alphanumeric=\"true\"/>\n</td>\r\n</tr>\r\n<tr>\r\n<th>\r\n<p class=\"require\">お名前</p>\r\n</th>\r\n<td>\n<input type=\"text\" name=\"お名前\" class=\"name\" size=\"60\" value=\"\" placeholder=\"(例)らぶりー　花子\" />\n</td>\r\n</tr>\r\n<tr>\r\n<th>\r\n<p class=\"require\">電話番号</p>\r\n</th>\r\n<td>\n<span class=\"mwform-tel-field\">\n\t<input type=\"text\" name=\"電話番号[data][0]\" class=\"tel\" size=\"6\" maxlength=\"5\" value=\"\" data-conv-half-alphanumeric=\"true\" />\n\t-\t<input type=\"text\" name=\"電話番号[data][1]\" class=\"tel\" size=\"5\" maxlength=\"4\" value=\"\" data-conv-half-alphanumeric=\"true\" />\n\t-\t<input type=\"text\" name=\"電話番号[data][2]\" class=\"tel\" size=\"5\" maxlength=\"4\" value=\"\" data-conv-half-alphanumeric=\"true\" />\n</span>\n\n<input type=\"hidden\" name=\"電話番号[separator]\" value=\"-\" />\n</td>\r\n</tr>\r\n<tr>\r\n<th>お問合せ種別</th>\r\n<td>\n<select name=\"お問合せ種別\" >\n\t\t\t<option value=\"選択してください\" >\n\t\t\t選択してください\t\t</option>\n\t\t\t<option value=\"品質に関するお問合せ\" >\n\t\t\t品質に関するお問合せ\t\t</option>\n\t\t\t<option value=\"法人様のお問合せ\" >\n\t\t\t法人様のお問合せ\t\t</option>\n\t\t\t<option value=\"集配依頼\" >\n\t\t\t集配依頼\t\t</option>\n\t\t\t<option value=\"その他のお問合せ\" >\n\t\t\tその他のお問合せ\t\t</option>\n\t</select>\n\n<input type=\"hidden\" name=\"__children[お問合せ種別][]\" value=\"{&quot;\\u9078\\u629e\\u3057\\u3066\\u304f\\u3060\\u3055\\u3044&quot;:&quot;\\u9078\\u629e\\u3057\\u3066\\u304f\\u3060\\u3055\\u3044&quot;,&quot;\\u54c1\\u8cea\\u306b\\u95a2\\u3059\\u308b\\u304a\\u554f\\u5408\\u305b&quot;:&quot;\\u54c1\\u8cea\\u306b\\u95a2\\u3059\\u308b\\u304a\\u554f\\u5408\\u305b&quot;,&quot;\\u6cd5\\u4eba\\u69d8\\u306e\\u304a\\u554f\\u5408\\u305b&quot;:&quot;\\u6cd5\\u4eba\\u69d8\\u306e\\u304a\\u554f\\u5408\\u305b&quot;,&quot;\\u96c6\\u914d\\u4f9d\\u983c&quot;:&quot;\\u96c6\\u914d\\u4f9d\\u983c&quot;,&quot;\\u305d\\u306e\\u4ed6\\u306e\\u304a\\u554f\\u5408\\u305b&quot;:&quot;\\u305d\\u306e\\u4ed6\\u306e\\u304a\\u554f\\u54