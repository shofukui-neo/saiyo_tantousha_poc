{"url":"https://www.token.co.jp/estate/online-consultation/","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n  <head>\n    <!-- common -->\r\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\r\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\r\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\r\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\r\n})(window,document,'script','dataLayer','GTM-M4FXRTR');</script>\r\n<meta charset=\"utf-8\">\r\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0, user-scalable=no\">\r\n<meta http-equiv=\"x-ua-compatible\" content=\"ie=edge\">\r\n<meta name=\"format-detection\" content=\"telephone=no\">\r\n<link rel=\"icon\" href=\"/favicon.ico\">\r\n<link rel=\"apple-touch-icon\" href=\"/homeicon.png\">\r\n<!-- common End -->    <link rel=\"canonical\" href=\"https://www.token.co.jp/inquiry/estate/\" />\n    <title>土地活用のお問い合わせ｜東建コーポレーション</title>\n    <meta name=\"robots\" content=\"ALL\" />\n    <meta name=\"apple-mobile-web-app-title\" content=\"東建ｺｰﾎﾟﾚｰｼｮﾝ\" />\n    <meta name=\"description\" content=\"土地活用に関するご相談はこちら。相続、税金、アパート経営など、専門家があなたの土地のお悩みにお答えします。\" />\n    <meta property=\"og:title\" content=\"土地活用のお問い合わせ｜東建コーポレーション\" />\n    <meta property=\"og:type\" content=\"website\" />\n    <meta property=\"og:url\" content=\"https://www.token.co.jp/inquiry/estate/\" />\n    <!--<meta property=\"og:image\" content=\"https://www.token.co.jp/estate/image/img_main.jpg\" />-->\n    <meta property=\"og:site_name\" content=\"土地活用のお問い合わせ｜東建コーポレーション\" />\n    <meta property=\"og:description\" content=\"土地活用に関するご相談はこちら。相続、税金、アパート経営など、専門家があなたの土地のお悩みにお答えします。\" />\n    <meta name=\"twitter:card\" content=\"summary_large_image\" />\n    <meta name=\"twitter:site\" content=\"@tokencorp\" />\n    <link rel=\"SHORTCUT ICON\" href=\"/favicon.ico\" />\n    <link rel=\"apple-touch-icon-precomposed\" href=\"/homeicon_estate.png\" />\n    <!--#config timefmt=\"%Y%m%d%H%I%S\" -->\n    <!-- common css-->\r\n<link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/normalize/4.2.0/normalize.min.css\">\r\n<link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css\">\r\n<link rel=\"stylesheet\" href=\"https://fonts.googleapis.com/icon?family=Material+Icons+Round\">\r\n<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\r\n<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\r\n<link href=\"https://fonts.googleapis.com/css2?family=Barlow:ital,wght@0,500;0,700;1,500;1,700&family=Jost:ital,wght@0,500;1,500&family=Noto+Sans+JP:wght@100..900&family=Zen+Old+Mincho&display=swap\" rel=\"stylesheet\">\r\n<link rel=\"stylesheet\" href=\"/responsive/token_estate/css/common-760.css\">\r\n<link rel=\"stylesheet\" href=\"/responsive/css-cmn/bass-sp-760.css\">\r\n<link rel=\"stylesheet\" href=\"/responsive/css-cmn/content-sp-760.css\">\r\n<link rel=\"stylesheet\" href=\"/responsive/js-cmn/slick/slick.css\">\r\n<link rel=\"stylesheet\" href=\"/responsive/css-cmn/estate/common.css?20250604\">\r\n<!-- リニューアル後削除 -->\r\n<link rel=\"stylesheet\" href=\"/responsive/css-cmn/estate/former.css\">\r\n<!-- common css End -->    <!-- Local css -->\n    <link rel=\"stylesheet\" href=\"/responsive/js-cmn/slick/slick.css\" />\n    <link rel=\"stylesheet\" href=\"css/estate.css?20251218135224\" />\n    <!-- Local css end -->\n    <!-- common js-->\r\n  <script src=\"https://ajax.googleapis.com/ajax/libs/jquery/3.1.1/jquery.min.js\"></script>\r\n<!-- common js End -->    <link rel=\"stylesheet\" href=\"/responsive/js-cmn/fancybox/jquery.fancybox.css\" />\n    <script src=\"/responsive/js-cmn/slick/slick.min.js\"></script>\n    <!--<script src=\"js/simulation.js\"></script>-->\n\n  </head>\n\n  <body>\n    <div id=\"wrap\">\n      <!-- header -->\n      <div class=\"header_wrap\">\r\n  <div class=\"gnav-bg\">\r\n    <header id=\"globalNav\">\r\n      <div class=\"header-logo\"><a href=\"/\"><img src=\"/responsive/image_cmn/estate/logo-token.png\" alt=\"Token\" width=\"156\" height=\"48\"></a></div>\r\n      <span class=\"keyword\">土地活用<br><span class=\"dot\">・</span>賃貸経営</span>\r\n      <dl class=\"freedial\">\r\n        <dt>土地活用、アパート経営・賃貸経営に関するご相談</dt>\r\n        <dd><img src=\"/responsive/image_cmn/estate/ico-tel.png\" alt=\"Freedial\" width=\"32\" height=\"32\">0120-51-8200</dd>\r\n      </dl>\r\n      <ul class=\"gnav-link\">\r\n        <li><a class=\"contact\" href=\"/estate/online-consultation/\"><img src=\"/responsive/image_cmn/estate/ico-header-contact.png\" alt=\"お問い合わせ\">土地活用の<br>お問い合わせ</a></li>\r\n        <li><a class=\"request\" href=\"/inquiry/estate_request/\"><img src=\"/responsive/image_cmn/estate/ico-header-shiryou.png\" alt=\"資料請求\">資料請求</a></li>\r\n        <li><span class=\"contact_sp\"><img src=\"/responsive/image_cmn/estate/ico-header-contact.png\" alt=\"お問い合わせ\">&emsp;資料請求<br>お問い合わせ</span></li>\r\n      </ul>\r\n    </header>\r\n  </div>\r\n  <div class=\"estate_menu_bg\">\r\n    <div class=\"sp_contact none_pc\">\r\n      <p>まずは、お気軽に<br>ご相談ください。</p>\r\n      <dl class=\"tel_contact\">\r\n        <dt>お電話でのお問い合わせ</dt>\r\n        <dd class=\"tel\"><img class=\"ico\" src=\"/responsive/image_cmn/estate/ico-footer-tel.png\" alt=\"Freedial\">0120-51-8200</dd>\r\n        <dd class=\"time\">平日：9〜12時、13〜17時<br class=\"none_pc\">（土・日・祝日、夏季・年末年始休暇は休業）</dd>\r\n      </dl>\r\n      <ul class=\"content_btns\">\r\n        <li><a href=\"/corporate/branch/\"><img class=\"ico\" src=\"/responsive/image_cmn/estate/ico-shiten.png\" alt=\"お近くの東建コーポレーション\">お近くの東建コーポレーション<i class=\"arrow\"></i></a></li>\r\n        <li><a href=\"/estate/online-consultation/\"><img class=\"ico\" src=\"/responsive/image_cmn/estate/ico-contact.png\" alt=\"お問い合わせ\">土地活用の<br class=\"none_sp\">お問い合わせ<i class=\"arrow\"></i></a></li>\r\n        <li><a href=\"/inquiry/estate_request/\"><img class=\"ico\" src=\"/responsive/image_cmn/estate/ico-shiryou.png\" alt=\"資料請求\">資料請求<i class=\"arrow\"></i></a></li>\r\n      </ul>\r\n    </div>\r\n  </div>\r\n</div>      <!-- /header -->\n      <div id=\"wrap_inner\">\n        <!-- contentsここから -->\n        <div id=\"contents\">\n          <h1>土地活用のお問い合わせ</h1>\n          <ul id=\"flow\">\n            <li class=\"current\">&#9312;お問い合わせの入力</li>\n            <li>&#9313;入力内容のご確認</li>\n            <li>&#9314;送信完了</li>\n          </ul>\n          <section>\n            <h2>お問い合わせの入力</h2>\n            <div class=\"explanation_text\">\n              <p>土地活用や賃貸経営に関するご相談を受け付けております。<br>\n                オンライン相談をご希望の方は、<br class=\"none_sp\"><a href=\"/inquiry/estate_online/\">「オンライン相談の予約申し込み」</a>よりご予約ください。</p>\n            </div>\n            \n            <form id=\"form\" class=\"h-adr\" method=\"post\" action=\"./\"><span class=\"p-country-name\" style=\"display:none;\">Japan</span>\n              <table>\n                <tbody>\n                  <tr>\n                    <th class=\"required\">お名前<br><span class=\"f_small\">（フルネーム）</span></th>\n                    <td>\n                      <div class=\"input_wrap\">\n                        <input id=\"name_kanji\" type=\"text\" name=\"name\" maxlength=\"20\" value=\"\" placeholder=\"例：東建太郎\" required><i class=\"fa-solid fa-circle-check\"></i>\n                        <p class=\"caution_msg check_name_kanji\" style=\"display: none;\">お名前（フルネーム）を入力してください。</p>\n                                              </div>\n                    </td>\n                  </tr>\n                  <tr>\n                    <th class=\"required\">ふりがな</th>\n                    <td>\n                      <div class=\"input_wrap\">\n                        <input id=\"name_kana\" type=\"text\" name=\"kana\" maxlength=\"20\" value=\"\" placeholder=\"例：とうけんたろう\" required><i class=\"fa-solid fa-circle-check\"></i>\n                        <p class=\"caution_msg check_name_kana\" style=\"display: none;\">お名前（ひらがな）を入力してください。</p>\n                                              </div>\n                    </td>\n                  </tr>\n                  <tr>\n                    <th class=\"required\">電話番号<br><span class=\"f_small\">（ハイフン不要）</span></th>\n                    <td>\n                      <ul>\n                        <li>\n                          <div class=\"input_wrap\">\n                            <input id=\"tel\" type=\"tel\" name=\"tel\" maxlength=\"11\" value=\"\" placeholder=\"例：0522328000\" required><i class=\"fa-solid fa-circle-check\"></i>\n                            <p class=\"caution_msg check_tel\" style=\"display: none;\">⁩⁩電話番号（半角数字・ハイフンなし）を入力してください。</p>\n                                                      </div>\n                        </li>\n                      </ul>\n                    </td>\n                  </tr>\n                  <tr>\n                    <th class=\"required\">メール<br class=\"none_pc\">アドレス</th>\n                    <td>\n                      <ul>\n                        <li>\n                          <div class=\"input_wrap\">\n                            <input id=\"email\" type=\"email\" name=\"email\" maxlength=\"50\" value=\"\" placeholder=\"info@token.co.jp\" required><i class=\"fa-solid fa-circle-check\"></i>\n                            <p class=\"caution_msg check_email\" style=\"display: none;\">⁩メールアドレスを入力してください。</p>\n                                                      </div>\n                        </li>\n                      </ul>\n                    </td>\n                  </tr>\n                  <tr class=\"post\">\n                    <th class=\"required\">郵便番号</th>\n                    <td>\n                      <div class=\"input_wrap\">\n                        <input id=\"post_code\" class=\"p-postal-code\" type=\"text\" name=\"zip\" maxlength=\"7\" value=\"\" placeholder=\"4600008\" maxlength=\"8\"><i class=\"fa-solid fa-circle-check\"></i>\n                                              </div><!--<button type=\"button\" class=\"postal-search\">郵便番号を調べる</button>-->\n                    </td>\n                  </tr>\n                  <tr class=\"address\">\n                    <th class=\"v-top required\">ご住所</th>\n                    <td>\n                      <div class=\"input_flex\">\n                        <div class=\"select_wrap\">\n                          <select id=\"prefecture\" class=\"p-region-id\" name=\"prf\" required>\n                            <option value=\"\" disabled selected>都道府県</option>\n                            <option value=\"1\">北海道</option>\n<option value=\"2\">青森県</option>\n<option value=\"3\">岩手県</option>\n<option value=\"4\">宮城県</option>\n<option value=\"5\">秋田県</option>\n<option value=\"6\">山形県</option>\n<option value=\"7\">福島県</option>\n<option value=\"8\">茨城県</option>\n<option value=\"9\">栃木県</option>\n<option value=\"10\">群馬県</option>\n<option value=\"11\">埼玉県</option>\n<option value=\"12\">千葉県</option>\n<option value=\"13\">東京都</option>\n<option value=\"14\">神奈川県</option>\n<option value=\"15\">新潟県</option>\n<option value=\"16\">富山県</option>\n<option value=\"17\">石川県</option>\n<option value=\"18\">福井県</option>\n<option value=\"19\">山梨県</option>\n<option value=\"20\">長野県</option>\n<option value=\"21\">岐阜県</option>\n<option value=\"22\">静岡県</option>\n<option value=\"23\">愛知県</option>\n<option value=\"24\">三重県</option>\n<option value=\"25\">滋賀県</option>\n<option value=\"26\">京都府</option>\n<option value=\"27\">大阪府</option>\n<option value=\"28\">兵庫県</option>\n<option value=\"29\">奈良県</option>\n<option value=\"30\">和歌山県</option>\n<option value=\"31\">鳥取県</option>\n<option value=\"32\">島根県</option>\n<option value=\"33\">岡山県</option>\n<option value=\"34\">広島県</option>\n<option value=\"35\">山口県</option>\n<option value=\"36\">徳島県</option>\n<option value=\"37\">香川県</option>\n<option value=\"38\">愛媛県</option>\n<option value=\"39\">高知県</option>\n<option value=\"40\">福岡県</option>\n<option value=\"41\">佐賀県</option>\n<option value=\"42\">長崎県</option>\n<option value=\"43\">熊本県</option>\n<option value=\"44\">大分県</option>\n<option value=\"45\">宮崎県</option>\n<option value=\"46\">鹿児島県</option>\n<option value=\"47\">沖縄県</option>\n                          </select><!--<i class=\"fa-solid fa-circle-check\"></i>-->\n                        </div>\n                        <div class=\"input_wrap municipalities\">\n                          <input id=\"municipalities\" class=\"p-locality p-street-address\" type=\"text\" name=\"adr\" maxlength=\"50\" value=\"\" placeholder=\"市区郡\" required><i class=\"fa-solid fa-circle-check\"></i>\n                          <p class=\"caution_msg check_municipalities\" style=\"display: none;\">市区郡を入力してください。</p>\n                                                  </div>\n                      </div>\n                      <div class=\"input_wrap\">\n                        <input id=\"house_number\" type=\"text\" name=\"adr2\" maxlength=\"50\" value=\"\" placeholder=\"丸の内ニ丁目1番33号\" required><i class=\"fa-solid fa-circle-check\"></i>\n                        <p class=\"caution_msg check_house_number\" style=\"display: none;\">⁩番地まで入力してください</p>\n                                              </div>\n                      <p class=\"kome\">※丁目・番地・号までご入力ください</p>\n                      <div class=\"input_wrap\">\n                        <input id=\"building_name\" type=\"text\" name=\"adr3\" maxlength=\"50\" value=\"\" placeholder=\"東建本社丸の内ビル101\" required><i class=\"fa-solid fa-circle-check\"></i>\n                                              </div>\n                      <!--<p class=\"caution_msg check_building_name\" style=\"display: none;\">⁩番地・建物・部屋番号などを入力してください。</p>-->\n                      <p class=\"kome\">※建物名＋部屋番号までご入力ください</p>\n                    </td>\n                  </tr>\n                  <tr>\n                    <th class=\"v-top\">現在の<br class=\"none_pc\">活用状況<br><span class=\"f_small\">（複数選択可）</span></th>\n                    <td>\n                      <div class=\"checkbox_wrap\">\n                        <label><input type=\"checkbox\" name=\"cond[]\" value=\"1\">節税対策について話を聞きたい</label>\n<label><input type=\"checkbox\" name=\"cond[]\" value=\"2\">土地活用・アパート経営の話を聞きたい</label>\n<label><input type=\"checkbox\" name=\"cond[]\" value=\"3\">所有する土地の活用方法の相談にのってほしい</label>\n<label><input type=\"checkbox\" name=\"cond[]\" value=\"4\">具体的な土地活用プランを提案してほしい</label>\n                      </div>\n                    </td>\n                  </tr>\n                  <tr class=\"comments\">\n                    <th class=\"v-top required\">ご意見・<br class=\"none_pc\">ご質問</th>\n                    <td>\n                      <textarea name=\"comment\" id=\"comments\" placeholder=\"全角2000文字以内でご入力ください\" maxlength=\"2000\"></textarea>\n                      <p id=\"textCounter\"><var>0</var>／2000文字</p>\n                                          </td>\n                  </tr>\n                </tbody>\n              </table>\n              <input type=\"hidden\" name=\"conf\" value=\"1\">\n            </form>\n            \n            <p class=\"privacy\"><a href=\"/privacy/\" target=\"_blank\">個人情報の取り扱い</a>について</p>\n            <div class=\"submit\"><button type=\"submit\" id=\"complete\">個人情報に同意し入力内容を確認</button></div>\n          </section>\n        </div>\n        <!-- contentsここまで -->\n      </div>\n      <!-- /#wrap_inner -->\n    </div>\n    <!-- /#wrap -->\n    <!-- footerここから -->\n    <footer class=\"slim\">\r\n  <ul class=\"foot_gl_links\">\r\n    <li><a href=\"/inquiry/\">お問い合わせ</a></li>\r\n    <li><a href=\"/sitemap/\">サイトマップ</a></li>\r\n    <li><a href=\"/corporate/charter/\">東建グループ企業行動憲章</a></li>\r\n    <li><a href=\"/privacy/\">個人情報保護に関する基本方針</a></li>\r\n    <li><a href=\"/personal_info/\">特定個人情報の適切な取扱いの基本方針</a></li>\r\n    <li><a href=\"/corporate/control_policy/\">内部統制システム構築に関する基本方針</a></li>\r\n    <li><a href=\"/corporate/customer-harassment/\">東建グループカスタマーハラスメント対応ポリシー</a></li>\r\n    <li><a href=\"/corporate/trading-policy/\">取引