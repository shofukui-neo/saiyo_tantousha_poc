n    <li><a href=\"/recruit/seek/\">求める人材</a></li>\r\n    <li><a href=\"/profile/approach.html\">ウインの取組み</a></li>\r\n    <li><a href=\"/recruit/department/\">部署紹介</a></li>\r\n    <li><a href=\"/recruit/jobcategory/\">募集職種</a></li>\r\n    <li><a href=\"/recruit/flow/\">採用の流れ</a></li>\r\n  </ul>\r\n</div><!-- /#HeadGlobalMenu --></header>\r\n<!-- // Header END // -->\r\n\r\n\r\n\r\n<!-- // Contents START // -->\r\n\r\n<!-- topicPath -->\r\n<div id=\"topicPath\">\r\n\t<ul class=\"clearfix\">\r\n  \t<li><a href=\"/recruit/entry/#section01\">新卒採用</a></li>\r\n    <li><a href=\"/recruit/entry/#section02\">キャリア採用</a></li>\r\n  </ul>\r\n</div>\r\n<!-- /topicPath -->\r\n\r\n<p id=\"skip_honbun\" class=\"skip\">本文です。</p>\r\n\r\n<h1>応募フォーム<span>Application Form</span></h1>\r\n\r\n<section id=\"section00\">\r\n<div>\r\n\t<p>ご記入いただいた内容は、採用選考以外の目的で開示することはありません。</p>\r\n</div>\r\n</section>\r\n\r\n<section id=\"form\">\r\n<div>\r\n\t<h2>エントリー（入力画面）</h2>\r\n  <form action=\"check.php\" method=\"POST\" enctype=\"multipart/form-data\">\r\n  <dl class=\"clearfix\">\r\n  \t<dt>応募職種<span>必須</span></dt>\r\n    <dd>\r\n        <input type=\"hidden\" name=\"jobtype\" value=\"営業職\">営業職</select>    </dd>\r\n    <dt>応募種別<span>必須</span></dt>\r\n    <dd>\r\n      <label><input name=\"adopt\" type=\"radio\" value=\"1\" disabled> 新卒採用</label><label><input name=\"adopt\" type=\"radio\" value=\"2\" > キャリア採用</label></dd>\r\n    <dt>業界経験<span>必須</span></dt>\r\n    <dd>\r\n    \t<select name=\"experience\">\r\n        <option value='0'>未経験</option><option value='1'>1年未満</option><option value='2'>1～2年以内</option><option value='3'>2～3年以内</option><option value='4'>3～5年以内</option><option value='5'>5年以上</option>      </select>\r\n    </dd>\r\n    <dt>お名前（漢字）<span>必須</span></dt>\r\n    <dd><input class=\"kana sizeM\" type=\"text\" name=\"name\" ></dd>\r\n    <dt>お名前（ふりがな）<span>必須</span></dt>\r\n    <dd><input class=\"kana sizeM\" type=\"text\" name=\"kana\" ></dd>\r\n    <dt>性別<span>必須</span></dt>\r\n    <dd>\r\n      <label><input type=\"radio\" name=\"sex\" value=\"1\"> 男性</label><label><input type=\"radio\" name=\"sex\" value=\"2\"> 女性</label></dd>\r\n    <dt>生年月日<span>必須</span></dt>\r\n    <dd>\r\n      <select name=\"year1\">\r\n        <option value=\"昭和\"  >昭和</option>\r\n        <option value=\"平成\"  >平成</option>\r\n      </select>\r\n      <input name=\"year2\" class=\"eisu sizeS\" type=\"text\" value=\"\" /> 年&nbsp;\r\n      <input name=\"month\" class=\"eisu sizeS\" type=\"text\" value=\"\" /> 月&nbsp;\r\n      <input name=\"day\" class=\"eisu sizeS\" type=\"text\" value=\"\" /> 日\r\n    </dd>\r\n    <dt>現住所<span>必須</span></dt>\r\n    <dd>\r\n      〒&nbsp;&nbsp;<input class=\"eisu sizeS\" type=\"text\" name=\"zip01\" id=\"zip01\" value=\"\" maxlength=\"3\" />&nbsp;-&nbsp;<input class=\"eisu sizeS\" type=\"text\" name=\"zip02\" id=\"zip02\" value=\"\" maxlength=\"4\" onkeyup=\"AjaxZip3.zip2addr('zip01','zip02','address01','address02');\" /><br />\r\n      都道府県&nbsp;&nbsp;<select id=\"address01\" name=\"address01\">\r\n      <option value=\"\">選択してください</option>\r\n      <optgroup label='北海道'><option value='北海道'>北海道</option></optgroup><optgroup label='東北'><option value='青森県'>青森県</option><option value='岩手県'>岩手県</option><option value='宮城県'>宮城県</option><option value='秋田県'>秋田県</option><option value='山形県'>山形県</option><option value='福島県'>福島県</option></optgroup><optgroup label='関東'><option value='茨城県'>茨城県</option><option value='栃木県'>栃木県</option><option value='群馬県'>群馬県</option><option value='埼玉県'>埼玉県</option><option value='千葉県'>千葉県</option><option value='東京都'>東京都</option><option value='神奈川県'>神奈川県</option></optgroup><optgroup label='北陸'><option value='富山県'>富山県</option><option value='石川県'>石川県</option><option value='福井県'>福井県</option></optgroup><optgroup label='甲信越'><option value='新潟県'>新潟県</option><option value='山梨県'>山梨県</option><option value='長野県'>長野県</option></optgroup><optgroup label='東海'><option value='岐阜県'>岐阜県</option><option value='静岡県'>静岡県</option><option value='愛知県'>愛知県</option><option value='三重県'>三重県</option></optgroup><optgroup label='関西'><option value='滋賀県'>滋賀県</option><option value='京都府'>京都府</option><option value='大阪府'>大阪府</option><option value='兵庫県'>兵庫県</option><option value='奈良県'>奈良県</option><option value='和歌山県'>和歌山県</option></optgroup><optgroup label='中四国'><option value='鳥取県'>鳥取県</option><option value='島根県'>島根県</option><option value='岡山県'>岡山県</option><option value='広島県'>広島県</option><option value='山口県'>山口県</option><option value='徳島県'>徳島県</option><option value='香川県'>香川県</option><option value='愛媛県'>愛媛県</option><option value='高知県'>高知県</option></optgroup><optgroup label='九州'><option value='福岡県'>福岡県</option><option value='佐賀県'>佐賀県</option><option value='長崎県'>長崎県</option><option value='熊本県'>熊本県</option><option value='大分県'>大分県</option><option value='宮崎県'>宮崎県</option><option value='鹿児島県'>鹿児島県</option></optgroup><optgroup label='沖縄県'><option value='沖縄県'>沖縄県</option></optgroup>      </select><br>\r\n      市区町村<br><input type=\"text\" class=\"kana sizeL\" name=\"address02\" id=\"address02\" value=\"\"><br>\r\n      番地、マンション名等<br><input type=\"text\" class=\"kana sizeL\" name=\"address03\" id=\"address03\" value=\"\">\r\n    </dd>\r\n    <dt>メールアドレス<span>必須</span></dt>\r\n    <dd><input name=\"email\" class=\"eisu sizeL\" type=\"text\"></dd>\r\n    <dt>電話番号<span>必須</span></dt>\r\n    <dd><input name=\"tel\"class=\"eisu sizeM\" type=\"text\"></dd>\r\n    <dt>自己PR<span>必須</span></dt>\r\n    <dd><textarea name=\"profile\" rows=\"5\" class=\"sizeL\"></textarea></dd>\r\n    <dt>資格・免許<span>必須</span></dt>\r\n    <dd><textarea name=\"certificate\" rows=\"5\" class=\"sizeL\"></textarea></dd>\r\n    <dt>就業可能時期<span>必須</span></dt>\r\n    <dd><input name=\"employ_month\" class=\"eisu sizeS\" type=\"text\"> 月&nbsp;&nbsp;&nbsp;&nbsp;<input name=\"employ_day\" class=\"eisu sizeS\" type=\"text\"> 日</dd>\r\n  </dl>\r\n\r\n\r\n  <h3>添付ファイル</h3>\r\n  <p>※ファイル形式は Excel、PDF、PowerPoint、Word、テキストのみです。<br>※1ファイルあたりのファイルサイズは 2MB までです。<br>※ファイル名は、半角英数字としてください。</p>\r\n  <dl>\r\n    <dt>履歴書</dt>\r\n    <dd><input name=\"resume\" type=\"file\" class=\"sizeM\"><br>\r\n    </dd>\r\n    <dt>職務経歴書</dt>\r\n    <dd><input name=\"career\" type=\"file\" class=\"sizeM\"><br>\r\n    </dd>\r\n    <dt>その他書類（スキルシート等）</dt>\r\n    <dd><input name=\"skill\" type=\"file\" class=\"sizeM\"><br>\r\n    </dd>\r\n  </dl>\r\n\r\n  <h3>その他</h3>\r\n  <dl>\r\n  \t<dt>作品（URLなど）</dt>\r\n    <dd><textarea name=\"product\" rows=\"2\" class=\"sizeL\"></textarea></dd>\r\n    <dt>その他</dt>\r\n    <dd><textarea name=\"other\" rows=\"5\" class=\"sizeL\"></textarea></dd>\r\n  </dl>\r\n  <div align=\"center\">\r\n  <input name=\"agreement\" type=\"checkbox\" id=\"agreement\" class=\"agreement\"><span class=\"agreementTxt\"><a href=\"/site/privacy.html\" target=\"_blank\">個人情報保護方針</a>に同意する</span>\r\n  </div>\r\n<!--\r\n  <button class=\"btn\">入力内容を確認する</button>\r\n-->\r\n  <input type=\"submit\" class=\"btn\" value=\"入力内容を確認する\" id=\"submitBtn\" disabled>\r\n\t</form>\r\n</div>\r\n</section>\r\n\r\n<!-- // Contents END // -->\r\n\r\n\r\n<!-- // Footer START // -->\r\n<footer>\r\n<div id=\"FooterNavi\" class=\"button\">\r\n<ul class=\"col2 clearfix\">\r\n  <li><a href=\"/recruit/entry/#section01\">新卒採用</a></li>\r\n  <li><a href=\"/recruit/entry/#section02\">キャリア採用</a></li>\r\n</ul>\r\n<ul class=\"col3 clearfix\">\r\n  <li><a href=\"/recruit/department/\">部署紹介</a></li>\r\n  <li><a href=\"/recruit/jobcategory/\">募集職種</a></li>\r\n  <li><a href=\"/recruit/flow/\">採用の流れ</a></li>\r\n</ul>\r\n</div><!-- /#FooterNavi -->\r\n<div id=\"gotop\"><a href=\"#page_top\"><img class=\"imgover\" src=\"/recruit/common/images/btn_pagetop.png\" width=\"70\" height=\"70\" alt=\"このページの一番上へ\" /></a></div> \r\n<p id=\"skip_footer\" class=\"skip\">フッターです。</p>\r\n</footer>\r\n<!-- // Footer END // -->\r\n\r\n\t<script>\r\n\t\t\tconst agreeCheckbox = document.getElementById(\"agreement\");\r\n\t\t\tconst submitBtn = document.getElementById(\"submitBtn\");\r\n\t\t\tagreeCheckbox.addEventListener('change', function() {\r\n\t\t\t\tif (agreeCheckbox.checked === true) {\r\n\t\t\t\t\tsubmitBtn.disabled = false;\r\n\t\t\t\t} else {\r\n\t\t\t\t\tsubmitBtn.disabled = true;\r\n\t\t\t\t}\r\n\t\t\t}, false);\r\n\r\n/*\r\n\t\t$(function() {\r\n\t\t\tconst agreeCheckbox = document.getElementById(\"agreement\");\r\n\t\t\tconst submitBtn = document.getElementById(\"submitBtn\");\r\n\t\t\tagreeCheckbox.addEventListener(\"change\", () => {\r\n\t\t\t\tif (agreeCheckbox.checked === true) {\r\n\t\t\t\t\tsubmitBtn.disabled = false;\r\n\t\t\t\t} else {\r\n\t\t\t\t\tsubmitBtn.disabled = true;\r\n\t\t\t\t}\r\n\t\t\t});\r\n\t\t});\r\n*/\r\n\t\twindow.onpageshow = function(){\r\n\t\t\t document.getElementById(\"agreement\").checked = false;\r\n\t\t\t$('input[type=\"checkbox\"]').eq(0).trigger('change');\r\n\t\t};\r\n\t</script>\r\n</body>\r\n</html>\r\n","finalUrl":"https://www.pro-win.co.jp/recruit/entry/form/entry.html?param=%E5%96%B6%E6%A5%AD%E8%81%B7","rendered":false,"_cachedAt":"2026-06-22T16:48:16.048Z"}