/common/img_header_blank.gif\">\r\n<img src=\"/uoavdk00000001rc-img/pmsojb0000001ivd.jpg\" alt=\"\">\r\n</picture>\r\n</div><!-- image -->\r\n\r\n<div class=\"child-button\">\r\n<button class=\"close-buttton\"><span>閉じる</span></button>\r\n</div><!-- child-button -->\r\n</div><!-- child-grid -->\r\n</div><!-- inner -->\r\n</div><!-- header-globalLink-child -->\r\n\r\n</li>\r\n\r\n</ul>\r\n</div><!-- header-links-bottom -->\r\n<div class=\"header-links-close\">\r\n<button class=\"header-links-close-buttton\">閉じる<span></span></button>\r\n</div>\r\n</div><!-- header-links -->\r\n</div><!-- toggle-menu -->\r\n</div><!-- header-main -->\r\n</div><!-- header-inner -->\r\n<span id=\"header-bg\"></span>\r\n</header>\r\n<div id=\"contents\">\r\n    \r\n    \r\n<section class=\"section template-area full\">\r\n<div class=\"section-inner\">\r\n<div class=\"swiper-container mv swiper-no-swiping\">\r\n<div class=\"swiper-wrapper mv-wrapper \">\r\n\r\n<div class=\"swiper-slide mv-slide\">\r\n\r\n<picture>\r\n<source media=\"(max-width: 767px)\" srcset=\"/jp/uoavdk0000000aw1-img/sfr1l100000006w8.jpg\">\r\n<img src=\"/jp/uoavdk0000000aw1-img/sfr1l100000006w7.jpg\" alt=\"\">\r\n</picture>\r\n\r\n</div>\r\n\r\n<div class=\"swiper-slide mv-slide\">\r\n<a href=\"/jp/business/environment/index.html\" target=\"_top\">\r\n<picture>\r\n<source media=\"(max-width: 767px)\" srcset=\"/jp/uoavdk0000000aw1-img/sfr1l100000006y9.jpg\">\r\n<img src=\"/jp/uoavdk0000000aw1-img/sfr1l100000006y8.jpg\" alt=\"\">\r\n</picture>\r\n</a>\r\n</div>\r\n\r\n<div class=\"swiper-slide mv-slide\">\r\n<a href=\"/jp/business/marine/index.html\" target=\"_top\">\r\n<picture>\r\n<source media=\"(max-width: 767px)\" srcset=\"/jp/uoavdk0000000aw1-img/sfr1l100000006yj.jpg\">\r\n<img src=\"/jp/uoavdk0000000aw1-img/sfr1l100000006yi.jpg\" alt=\"\">\r\n</picture>\r\n</a>\r\n</div>\r\n\r\n<div class=\"swiper-slide mv-slide\">\r\n<a href=\"/jp/business/aerospace_combustion/index.html\" target=\"_top\">\r\n<picture>\r\n<source media=\"(max-width: 767px)\" srcset=\"/jp/uoavdk0000000aw1-img/sfr1l100000006yx.jpg\">\r\n<img src=\"/jp/uoavdk0000000aw1-img/sfr1l100000006yw.jpg\" alt=\"\">\r\n</picture>\r\n</a>\r\n</div>\r\n\r\n</div><!-- swiper-wrapper -->\r\n<div class=\"swiper-pagination mv-pagination\"></div>\r\n<div class=\"swiper-button-prev mv-button-prev\"></div>\r\n<div class=\"swiper-button-next mv-button-next\"></div>\r\n</div>\r\n</div>\r\n</section>\r\n\r\n    <main id=\"main\" role=\"main\">\r\n      \r\n\r\n      <section class=\"section component-area\">\r\n        <div class=\"section-inner\">\r\n          <div class=\"bg-box\">\r\n            <ul class=\"link-list mb-middle\">\r\n\r\n<li>\r\n\r\n<p><a href=\"/jp/news/pmsojb0000001l8f.html\" target=\"_blank\">【ご注意】当社を装った不審なメールにご注意ください。。</a></p>\r\n\r\n</li>\r\n\r\n</ul>\r\n\r\n          </div>\r\n        <hr class=\"margin-utility\">\r\n        </div>\r\n      </section>\r\n\r\n<section class=\"section template-area wide section-margin\">\r\n<div class=\"section-inner\">\r\n  <h2 class=\"align-center\">\r\n    <a href=\"/jp/business/index.html\">事業紹介</a>\r\n  </h2>\r\n  <div class=\"column-box-wrapper\">\r\n    <div class=\"column-box col3 overlap\">\r\n      \r\n      <div>\r\n        <a href=\"/jp/business/environment/index.html\" target=\"_top\">\r\n          <div class=\"media-box\">\r\n            <div>\r\n              <div class=\"media\">\r\n                <img src=\"/jp/uoavdk0000000aw1-img/uoavdk0000000bk7.jpg\" alt=\"環境計測事業\">\r\n              </div>\r\n            </div>\r\n          </div>\r\n          <h3 class=\"align-center\"><span class=\"link\">環境計測事業</span></h3>\r\n          <div class=\"bg-box\">\r\n            <p>地球規模の気候変動のなか自然環境の変化を的確に捉え、いち早く情報発信する「正確で安定した観測が可能なシステム」をご提供することにより、自然災害による被災の軽減に寄与し、人々の生活に安心と安全をご提供します。</p>\r\n          </div>\r\n        </a>\r\n      </div>\r\n      \r\n      <div>\r\n        <a href=\"/jp/business/marine/index.html\" target=\"_top\">\r\n          <div class=\"media-box\">\r\n            <div>\r\n              <div class=\"media\">\r\n                <img src=\"/jp/uoavdk0000000aw1-img/uoavdk0000000bt1.jpg\" alt=\"航海事業\">\r\n              </div>\r\n            </div>\r\n          </div>\r\n          <h3 class=\"align-center\"><span class=\"link\">航海事業</span></h3>\r\n          <div class=\"bg-box\">\r\n            <p>高度な計測制御技術と精密加工技術を駆使し、開発設計から生産、販売まで一貫して手がけています。タッチパネルによる操作性の向上や操船の負担を大幅に軽減する航法支援システムの開発など、船舶の安全性や効率性を高め、海運・造船・水産業界の発展に寄与し続けています。</p>\r\n          </div>\r\n        </a>\r\n      </div>\r\n      \r\n      <div>\r\n        <a href=\"/jp/business/aerospace_combustion/index.html\" target=\"_top\">\r\n          <div class=\"media-box\">\r\n            <div>\r\n              <div class=\"media\">\r\n                <img src=\"/jp/uoavdk0000000aw1-img/uoavdk0000000btc.jpg\" alt=\"航空・燃焼事業\">\r\n              </div>\r\n            </div>\r\n          </div>\r\n          <h3 class=\"align-center\"><span class=\"link\">航空・燃焼事業</span></h3>\r\n          <div class=\"bg-box\">\r\n            <p>空の安全を支えるとともに航空宇宙産業の発展に貢献するため、高度な技術が要求される航空エンジンやロケットエンジン用の搭載機器をご提供しております。お客様の多様なニーズに応え、耐環境性と信頼性に優れた製品を供給するため、開発から生産を一貫した体制で行っております。</p>\r\n          </div>\r\n        </a>\r\n      </div>\r\n      \r\n    </div>\r\n  </div>\r\n</div>\r\n</section>\r\n\r\n      <section class=\"section template-area wide section-margin-l\">\r\n        <div class=\"section-inner\">\r\n          <div class=\"column-box-wrapper\">\r\n            <div class=\"overhang-img-box\">\r\n              <div class=\"overhang-img-box-bg\">\r\n                <img src=\"/jp/uoavdk0000000aw1-img/uoavdk0000000bki.jpg\" alt=\"製品紹介\">\r\n              </div>\r\n              <div class=\"overhang-img-box-text\">\r\n                <div class=\"bg-box\">\r\n                  <h2 class=\"align-center\">\r\n                    製品紹介\r\n                  </h2>\r\n                  <p class=\"mb-40\">ＹＤＫテクノロジーズでは、品質管理および品質保証の国際規格ISO9001、JISQ9100の認証取得し、システムの継続的な改善と向上を図っています。</p>\r\n           