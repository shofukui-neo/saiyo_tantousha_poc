\"><!-- start module menu loop -->\r\n<!-- end module menu loop -->\r</div>\n                        \n<ul class=\"MGR-smBtn GMR-loBtn\">\n          <li><a href=\"https://www.magara.co.jp/modules/works/\"><img src=\"https://www.magara.co.jp/themes/p240201/img/sm_btn_1_0.gif\" alt=\"竣工作品集\" width=\"190\" height=\"39\" border=\"0\" /></a></li>\n    \n          <li><a href=\"https://www.magara.co.jp/modules/technology/\"><img src=\"https://www.magara.co.jp/themes/p240201/img/sm_btn_2_0.gif\" alt=\"技術情報\" width=\"190\" height=\"39\" border=\"0\" id=\"sm_btn_2\" name=\"sm_btn_2\" /></a></li>\n    \n\n<li><a href=\"http://www.magara-v.com/2016-11VEL/index.html\" target=\"_blank\"><img src=\"https://www.magara.co.jp/themes/p240201/img/sm_btn_3_0.gif\" alt=\"ミクロ・ベル工法\" width=\"190\" height=\"39\" border=\"0\" id=\"sm_btn_3\" name=\"sm_btn_3\" /></a></li>\n</ul>\n\n                                    <div class=\"blockContent2\"><ul class=\"MGR-sm-bnr GMR-loBtn\">\r\n<li><a href=\"https://www.magara.co.jp/modules/company/index.php?content_id=27\"><img src=\"https://www.magara.co.jp/img/bahrain-banner.jpg\" width=\"190\" height=\"106\" alt=\"EXPO\" /></a></li>\r\n<li><a href=\"https://www.magara.co.jp/modules/company/index.php?content_id=28\"><img src=\"https://www.magara.co.jp/img/recovery-banner.jpg\" width=\"190\" height=\"66\" alt=\"災害復旧\" /></a></li>\r\n        <li><a href=\"https://www.magara.co.jp/modules/finance/\"><img src=\"https://www.magara.co.jp/img/sm_bnr_fr.jpg\" width=\"190\" height=\"66\" alt=\"財務情報\" /></a></li>\r\n        <li><a href=\"https://www.magara.co.jp/modules/company/index.php?content_id=6\"><img src=\"https://www.magara.co.jp/img/sm_bnr_env.jpg\" width=\"190\" height=\"66\" alt=\"環境方針\" /></a></li>\r\n        <li><a href=\"https://www.magara.co.jp/modules/company/index.php?content_id=14\"><img src=\"https://www.magara.co.jp/img/sm_bnr_cs.jpg\" alt=\"お客様相談室\" width=\"190\" height=\"66\" /></a></li>\r\n        <li><a href=\"https://www.magara.co.jp/modules/company/index.php?content_id=17\"><img src=\"https://www.magara.co.jp/img/sm_bnr_bc.jpg\" alt=\"お取引業者の皆様へ\" width=\"190\" height=\"66\" /></a></li>\r\n        <li><a href=\"https://www.magara.co.jp/modules/recruit/index.php?content_id=10\"><img src=\"https://www.magara.co.jp/img/sm_bnr_employ.jpg\" width=\"190\" height=\"66\" alt=\"採用情報\" /></a></li>\r\n\r\n\r\n<li><a href=\"http://www.magara.co.jp/PBA/kfe/index.html\" target=\"_blank\"><img src=\"https://www.magara.co.jp/img/banner_kfe.gif\" width=\"190\"  /></a></li>\r\n\r\n\r\n\r\n      </ul></div>\n            \n\n\n\n\n</div>\n\n\n<!-- コンテンツ -->\n<div id=\"MGR-cnt-area\">\n  <div id=\"content\">\n\n<h3>新卒採用情報　2027卒</h3>\n\n    <div class=\"pico_container\" id=\"recruit_container\">\r\n\r\n\r\n\r\n\r\n\r\n<!-- tags -->\r\n\r\n<!-- content (body) -->\r\n<a name=\"top_of_pico_body\" id=\"top_of_pico_body\"></a>\r\n<div class=\"pico_body\" id=\"recruit_body\">\r\n<table cellpadding=\"5\">\r\n    <tbody>\r\n        <tr>\r\n            <td colspan=\"3\">【 募集職種 】&nbsp;</td>\r\n        </tr>\r\n        <tr>\r\n            <td>&nbsp;</td>\r\n            <td colspan=\"2\">◆　建築工事の施工管理職 ： 6名 〔北陸、東京、大阪事業部の希望地に配属〕</td>\r\n        </tr>\r\n        <tr>\r\n            <td>&nbsp;</td>\r\n            <td colspan=\"2\">◆　土木工事の施工管理職 ： 6名 〔北陸、東京、大阪事業部の希望地に配属〕</td>\r\n        </tr>\r\n        <tr>\r\n            <td>&nbsp;</td>\r\n            <td colspan=\"2\">◆　営業・事務職 ： 若干名 〔北陸、東京、大阪事業部の希望地に配属〕</td>\r\n        </tr>\r\n        <tr>\r\n            <td>&nbsp;</td>\r\n            <td colspan=\"2\">&nbsp;</td>\r\n        </tr>\r\n        <tr>\r\n            <td colspan=\"3\">【 勤 務 地 】&nbsp;</td>\r\n        </tr>\r\n        <tr>\r\n            <td>&nbsp;</td>\r\n            <td colspan=\"2\">◆　本　　　社 ： 石川県金沢市彦三町 1-13-43</td>\r\n        </tr>\r\n        <tr>\r\n            <td>&nbsp;</td>\r\n            <td colspan=\"2\">◆　東京事業部 ： 東京都中央区日本橋室町 4-1-5 共同ビル（室町４丁目）５階</td>\r\n        </tr>\r\n        <tr>\r\n            <td>&nbsp;</td>\r\n            <td colspan=\"2\">◆　大阪事業部 ： 大阪市淀川区宮原 4-4-63</td>\r\n        </tr>\r\n        <tr>\r\n            <td>&nbsp;</td>\r\n            <td colspan=\"2\">◆　北陸事業部 ： 石川県金沢市彦三町 1-13-43</td>\r\n        </tr>\r\n        <tr>\r\n            <td>&nbsp;</td>\r\n            <td colspan=\"2\">◆　営　業　所 ： 愛知県名古屋市東区泉 1-8-19</td>\r\n        </tr>\r\n        <tr>\r\n            <td>&nbsp;</td>\r\n            <td colspan=\"2\">&nbsp;</td>\r\n        </tr>\r\n        <tr>\r\n            <td>【勤務時間】</td>\r\n            <td colspan=\"2\">◆　施工管理職　　：8：00～17：30 （実働 8 時間）&nbsp;</td>\r\n        </tr>\r\n        <tr>\r\n            <td>&nbsp;</td>\r\n            <td colspan=\"2\">◆　営業・事務職　：8：30～17：30 （実働 8 時間）　</td>\r\n        </tr>\r\n        <tr>\r\n            <td>&nbsp;</td>\r\n            <td colspan=\"2\">&nbsp;</td>\r\n        </tr>\r\n        <tr>\r\n            <td colspan=\"3\">【採用スケジュール】</td>\r\n        </tr>\r\n        <tr>\r\n            <td>&nbsp;</td>\r\n            <td colspan=\"2\">当社に関心をもっていただき、ありがとうございます。<br />\r\n            まずは、『マイナビ2027』よりお気軽にエントリーください。</td>\r\n        </tr>\r\n        <tr>\r\n            <td>&nbsp;</td>\r\n            <td colspan=\"2\">▼　マイナビよりエントリー</td>\r\n        </tr>\r\n        <tr>\r\n            <td>&nbsp;</td>\r\n            <td colspan=\"2\">▼　個別説明会予約</td>\r\n        </tr>\r\n        <tr>\r\n            <td>&nbsp;</td>\r\n            <td colspan=\"2\">▼　個別説明会<br />\r\n            （じっくり１時間程。仕事に対する志向などもぜひここでお聞かせください。）</td>\r\n        </tr>\r\n        <tr>\r\n            <td>&nbsp;</td>\r\n            <td colspan=\"2\">▼　一次面接　＆　能力検査</td>\r\n        </tr>\r\n        <tr>\r\n            <td>&nbsp;</td>\r\n            <td colspan=\"2\">▼　適正検査　　</td>\r\n        </tr>\r\n        <tr>\r\n            <td>&nbsp;</td>\r\n            <td colspan=\"2\">▼　最終選考（役員面接）</td>\r\n        </tr>\r\n        <tr>\r\n            <td>&nbsp;</td>\r\n            <td colspan=\"2\">▼　内々定</td>\r\n        </tr>\r\n        <tr>\r\n            <td>&nbsp;</td>\r\n            <td colspan=\"2\">◎&nbsp;最終選考（役員面接）は金沢本社で開催予定です。</td>\r\n        </tr>\r\n        <tr>\r\n            <td>&nbsp;</td>\r\n            <td colspan=\"2\">&nbsp;　遠方より最終選考にご参加いただく皆さんについては、交通費はもちろん、<br />\r\n            宿泊が必要な場合は宿泊費も全て当社規程によりお支払いしますので<br />\r\n            ご安心ください！</td>\r\n        </tr>\r\n        <tr>\r\n            <td>　　　　　　</td>\r\n            <td colspan=\"2\">&nbsp;</td>\r\n        </tr>\r\n        <tr>\r\n            <td colspan=\"3\">【給与・福利厚生（待遇）】&nbsp;</td>\r\n        </tr>\r\n        <tr>\r\n            <td colspan=\"3\">≪給　　与≫</td>\r\n        </tr>\r\n        <tr>\r\n            <td>&nbsp;</td>\r\n            <td colspan=\"2\">〈施工管理職〉</td>\r\n        </tr>\r\n        <tr>\r\n            <td>&nbsp;</td>\r\n            <td colspan=\"2\">◆　大学院卒 ：&nbsp;東京勤務278,000 円、大阪勤務273,000 円、北陸勤務265,000 円&nbsp;</td>\r\n        </tr>\r\n        <tr>\r\n            <td>&nbsp;</td>\r\n            <td colspan=\"2\">◆　大　学　卒 ： 東京勤務273,000 円、大阪勤務268,000 円、北陸勤務260,000 円</td>\r\n        </tr>\r\n        <tr>\r\n            <td>&nbsp;</td>\r\n            <td colspan=\"2\">◆　専　門　卒 ：&nbsp;東京勤務248,900 円、大阪勤務243,900 円、北陸勤務235,900 円</td>\r\n        </tr>\r\n        <tr>\r\n            <td>&nbsp;</td>\r\n            <td colspan=\"2\">〈事務・営業職〉</td>\r\n        </tr>\r\n        <tr>\r\n            <td>&nbsp;</td>\r\n            <td colspan=\"2\">◆　大学院卒 ： 東京勤務234,000 円、大阪勤務232,000 円、北陸勤務227,000 円</td>\r\n        </tr>\r\n        <tr>\r\n            <td>&nbsp;</td>\r\n            <td colspan=\"2\">◆　大　学　卒 ： 東京勤務229,000 円、大阪勤務227,000 円、北陸勤務222,000 円</td>\r\n        </tr>\r\n        <tr>\r\n            <td>&nbsp;</td>\r\n            <td colspan=\"2\">◆　専　門　卒 ：&nbsp;東京勤務204,900 円、大阪勤務202,900 円、北陸勤務197,900 円</td>\r\n        </tr>\r\n        <tr>\r\n            <td>&nbsp;</td>\r\n            <td colspan=\"2\">&nbsp;※家族と50km以上離れて別居勤務する独身社員には、上記に住宅手当（東京勤務46,000 円、大阪勤務36,000 円）を加算、150km以上なら更に独身者帰省手当7,000円を加算</td>\r\n        </tr>\r\n        <tr>\r\n            <td>≪諸 手 当≫</td>\r\n            <td colspan=\"2\">住宅手当、単身赴任手当、通勤手当、資格手当 他&nbsp;</td>\r\n        </tr>\r\n        <tr>\r\n            <td>≪昇　　給≫</td>\r\n            <td colspan=\"2\">年１回&nbsp;</td>\r\n        </tr>\r\n        <tr>\r\n            <td>≪賞　　与≫</td>\r\n            <td colspan=\"2\">年２回（７月、１２月）&nbsp;</td>\r\n        </tr>\r\n        <tr>\r\n            <td>≪休日休暇≫</td>\r\n            <td colspan=\"2\">週休２日制、祝日、夏季・年末年始休暇・慶弔休暇・特別休暇 他&nbsp;</td>\r\n        </tr>\r\n        <tr>\r\n            <td>≪保　　険≫</td>\r\n            <td colspan=\"2\">健康保険、厚生年金保険、雇用保険、労災保険等　社会保険完備&nbsp;</td>\r\n        </tr>\r\n        <tr>\r\n            <td>≪福利厚生≫</td>\r\n            <td colspan=\"2\">寮・社宅あり（北陸のみ）</td>\r\n        </tr>\r\n        <tr>\r\n            <td>≪そ の 他≫</td>\r\n            <td colspan=\"2\">社内持株会制度、退職金制度、奨学金助成制度あり</td>\r\n        </tr>\r\n        <tr>\r\n            <td>&nbsp;</td>\r\n            <td colspan=\"2\">&nbsp;</td>\r\n        </tr>\r\n        <tr>\r\n            <td>&nbsp;</td>\r\n            <td colspan=\"2\">&nbsp;</td>\r\n        </tr>\r\n        <tr>\r\n            <td>【参　　考】</td>\r\n            <td colspan=\"2\">&nbsp;</td>\r\n        </tr>\r\n        <tr>\r\n            <td>≪提出書類≫</td>\r\n            <td colspan=\"2\">履歴書、成績証明書、卒業（見込）証明書、健康診断書</td>\r\n        </tr>\r\n        <tr>\r\n            <td>≪推　　薦≫</td>\r\n            <td colspan=\"2\">&nbsp;学校推薦、自由応募　両方可能です。</td>\r\n        </tr>\r\n        <tr>\r\n            <td>&nbsp;</td>\r\n            <td colspan=\"2\"><b>&nbsp;</b></td>\r\n        </tr>\r\n        <tr>\r\n            <td>&nbsp;</td>\r\n            <td>&nbsp;</td>\r\n        </tr>\r\n        <tr>\r\n            <td>&nbsp;</td>\r\n            <td colspan=\"2\">&nbsp;</td>\r\n        </tr>\r\n        <tr>\r\n            <td>　　　　　　</td>\r\n            <td colspan=\"2\">不明な点ございましたらお気軽にお問い合わせください。</td>\r\n        </tr>\r\n        <tr>\r\n            <td>　　　　　　</td>\r\n            <td colspan=\"2\">　　採用窓口 ： 事務本部　総務部　人事課</td>\r\n        </tr>\r\n        <tr>\r\n            <td>　　　　　　</td>\r\n            <td colspan=\"2\">　　担　当　者 ： 東（ヒガシ）　　　</td>\r\n        </tr>\r\n        <tr>\r\n            <td>　　　　　　</td>\r\n            <td colspan=\"2\">　　受付電話 ： 076-231-1266　</td>\r\n        </tr>\r\n    </tbody>\r\n</table>\r\n<p>&nbsp;</p>\r\n</div>\r\n\r\n<!-- print icon -->\r\n\r\n<!-- tell a friend -->\r\n\r\n<!-- vote -->\r\n\r\n<!-- jump to top -->\r\n<div class=\"bottom_of_content_body\"><a href=\"#top_of_pico_body\">この記事の1行目に飛ぶ</a></div>\r\n\r\n\r\n\r\n<!-- page navigation -->\r\n\r\n\r\n<!-- d3forum comment integration -->\r\n\r\n<hr class=\"notification\" />\r\n\r\n</div>\n\n    <br />\n    <hr class=\"notification\" />\n    <div class=\"MGR-btn-pageTop\"><p class=\"GMR-loBtn\"><a href=\"#top\"><img src=\"https://www.magara.co.jp/themes/p240201/img/all_btn_pup.gif\" width=\"120\" height=\"23\" alt=\"ページトップへ\" /></a></p></div>\n\n      <!-- Start center-center blocks loop -->\n            <!-- End center-center blocks loop -->\n\n  </div>\n</div>\n\n\n\n</div>\n</div>\n\n\n\n\n\n<!-- FOOTER -->\n<div id=\"MGR-wrapper-ft\">\n<div id=\"MGR-footer\">\n<p class=\"btn-pp\"><a href=\"https://www.magara.co.jp/modules/privacy/\"><img src=\"https://www.magara.co.jp/themes/p240201/img/ft_btn_pp.gif\" width=\"123\" height=\"29\" alt=\"個人情報保護方針\" /></a></p>\n<p class=\"copyright\">Copyrights &copy; Magara Construction Co., Ltd. All Rights Reserved.\n</p>\n</div>\n</div>\n\n\n<map name=\"Map\" id=\"Map\">\n<area shape=\"rect\" coords=\"94,1,177,28\" href=\"https://www.magara.co.jp/modules/construction/\" alt=\"建設事業\" />\n<area shape=\"rect\" coords=\"187,1,307,28\" href=\"https://www.magara.co.jp/modules/renewal/\" alt=\"リニューアル事業\" />\n<area shape=\"rect\" coords=\"315,1,444,28\" href=\"https://www.magara.co.jp/modules/energy/\" alt=\"総合エネルギー事業\" />\n</map>\n\n\n</body>\n</html>","finalUrl":"https://www.magara.co.jp/modules/recruit/index.php?content_id=33","rendered":false,"_cachedAt":"2026-06-23T23:49:06.452Z"}