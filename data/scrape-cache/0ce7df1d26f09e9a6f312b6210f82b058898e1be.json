\t\t\t\t\t\t\t\t<option value=\"宮崎県\">宮崎県</option>\n\t\t\t\t\t\t\t\t\t<option value=\"鹿児島県\">鹿児島県</option>\n\t\t\t\t\t\t\t\t\t<option value=\"沖縄県\">沖縄県</option>\n\t\t\t\t\t\t\t\t</select>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</td>\n\t\t\t\t\t</tr>\n\t\t\t\t\t<tr class=\"bond-row\">\n\t\t\t\t\t\t<td class=\"table-quest-bond-cell\"><span class=\"table-quest-cell-name\">市区郡</span><input type=\"text\" placeholder=\"例）稲城市\" name=\"quest-country\" id=\"quest-country\" value=\"\" /></td>\n\t\t\t\t\t</tr>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<td class=\"table-quest-bond-cell\"><span class=\"table-quest-cell-name\">丁目・番地</span><input type=\"text\" placeholder=\"例）百村1625-2　1号館2F\" name=\"quest-town\" id=\"quest-town\" value=\"\" /></td>\n\t\t\t\t\t</tr>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<th scope=\"row\" class=\"tag-hissu\">電話番号（ハイフンあり）</th>\n\t\t\t\t\t\t<td><input type=\"text\" placeholder=\"例）050-3803-8115\" name=\"quest-phone\" id=\"quest-phone\" value=\"\" /></td>\n\t\t\t\t\t</tr>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<th scope=\"row\" class=\"tag-nini\">お問い合わせ内容</th>\n\t\t\t\t\t\t<td>\n\t\t\t\t\t\t\t<textarea rows=\"10\" cols=\"50\" placeholder=\"例）システムを新しく導入したいため商談したい。\" name=\"quest-desc\" id=\"quest-desc\"></textarea>\n\t\t\t\t\t\t</td>\n\t\t\t\t\t</tr>\n\t\t\t\t</tbody>\n\t\t\t</table>\n<!-- 折り畳み展開ポインタstart -->\n\t\t\t\t<div class=\"center\">\n\t\t\t\t\t<div onclick=\"obj=document.getElementById('privacy').style; obj.display=(obj.display=='none')?'block':'none';\">\n\t\t\t\t\t<a style=\"cursor:pointer\"><img src=\"./images/privacyOpen.png\" alt=\"個人情報の取扱いに関する事項\"></a></div>\n\t\t\t\t\t</div>\n\t\t\t\t<!--p class=\"quest-privacy\"><a href=\"https://www.ksk.co.jp/privacy.html\" target=\"_blank\">個人情報の取り扱いについて</a></p-->\n\n<br>\n<!--// 折り畳み展開ポインタ -->\n<!-- 折り畳まれ部分 -->\n<div id=\"privacy\" style=\"clear:both;display:none\">\n<!--ここの部分が折りたたまれる＆展開される部分-->\n  <div class=\"table01\">\n   <p>　　■ 事業者の名称</p>\n   <p>　　　株式会社KSK</p>\n<br>\n   <p>　　■ 個人情報保護管理者</p>\n   <p>　　　株式会社KSK　取締役執行役員　リスク管理担当</p>\n   <p>　　　TEL： 042-378-1100</p>\n   <p>　　　受付時間： 9:00〜17:00（土･日・祝日を除く）</p>\n<br>\n   <p>　　■ 個人情報の利用目的</p>\n   <p>　　　●製品、サービスに関する情報提供</p>\n   <p>　　　●製品、サービスの販売、提供</p>\n   <p>　　　●セミナー、展示会、イベントのご案内送付</p>\n   <p>　　　●製品、サービス等のサポート対応</p>\n   <p>　　　●お問い合わせ対応</p>\n   <p>　　　●アンケート調査実施、分析</p>\n   <p>　　　●契約の履行</p>\n   <p>　　　●商談、打ち合わせ、連絡</p>\n<br>\n   <p>　　■ 個人情報の第三者提供について</p>\n   <p>　　　ご本人の同意がある場合または法令に基づく場合を除き、今回ご入力いただく個人情報は第三者に提供しません。</p>\n<br>\n   <p>　　■ 個人情報の委託について</p>\n   <p>　　　個人情報の取扱いを外部に委託する場合は、当社が規定する個人情報管理基準を満たす企業を選定して委託を行い、</p>\n   <p>　　　適切な取扱いが行われるよう監督します。</p>\n<br>\n   <p>　　■ 取得した個人情報の開示等及びお問い合わせ窓口</p>\n   <p>　　　当社が本件により取得した個人情報に関して、利用目的の通知、開示、内容の訂正、追加又は削除、利用の停止、</p>\n   <p>　　　消去、第三者への提供の停止、第三者への提供に関する記録の開示（以下「開示等」という）についてのご本人からの</p>\n   <p>　　　お申し出に対しては、すみやかに対応いたします。</p>\n   <p>　　　開示等に応じる窓口は、下記「個人情報お問い合わせ窓口」になります。</p>\n<br>\n   <p>　　＜ 個人情報お問い合わせ窓口 ＞</p>\n   <p>　　　 担当者： ビジネスソリューション事業部　事業部長</p>\n   <p>　　　 TEL： 042-378-1131</p>\n   <p>　　　 受付時間： 9:00〜17:00（土･日・祝日を除く）</p>\n<br>\n</div>\n</div>\n\n<br>\n<!-- 折り畳み展開ポインタend -->\n\t\t\t\t\n\t\t\t\t<p class=\"quest-privacy-submit\">\n\t\t\t\t\t<input type=\"checkbox\" id=\"quest-conform\" />\n\t\t\t\t\t<label for=\"quest-conform\" class=\"quest-conform-label\">個人情報の取り扱いに同意する</label>\n\t\t\t\t</p>\n\t\t\t\t<button type=\"submit\" id=\"submit\" class=\"button form-next prohibited\">入力内容を確認する</button>\n\t\t\t</form>\n\t\t</div>\n\t</div><!-- /#contents -->\n\t<footer id=\"footer\">\n\t\t<a class=\"pagetop\">TOP</a>\n\t\t<div class=\"footer-upper\">\n\t\t\t<div class=\"footer-row\">\n\t\t\t\t<div class=\"footer-col\">\n\t\t\t\t\t<div class=\"footer-logo\">\n\t\t\t\t\t\t<img class=\"footer-logomark\" src=\"../common/images/common/footer-logo-ksk.png\" alt=\"KSKLOGO\" />\n\t\t\t\t\t\t<img class=\"footer-logotype\" src=\"../common/images/common/footer-logotype-ksk.png\" alt=\"KSK\" />\n\t\t\t\t\t\t<img class=\"footer-tagline\" src=\"../common/images/common/footer-tagline-ksk.png\" srcset=\"../common/images/common/footer-tagline-ksk.pn