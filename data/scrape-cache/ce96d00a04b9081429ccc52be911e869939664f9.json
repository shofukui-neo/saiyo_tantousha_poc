\n    loopsliderPositionDetail();\n});\nfunction loopTopSliderDetail(){\n    var sliderSizeDetail = $('.loopSlider .loopslider_wrap ul').width();\n    $('.loopSlider .loopslider_wrap').css({'width': sliderSizeDetail * 2 + 'px'});\n    $('.loopSlider .loopslider_wrap').find('ul').clone().appendTo('.loopSlider .loopslider_wrap');\n};\nfunction loopsliderPositionDetail(){\n    var sliderSizeDetail = $('.loopSlider .loopslider_wrap ul:first-of-type').width();\n    $('.loopSlider .loopslider_wrap').css({left: '-' + sliderSizeDetail + 'px'}); // 初期位置を左へ\n    $('.loopSlider .loopslider_wrap').stop().animate({left: '0px'}, 60000, 'linear'); // 左から右へ移動\n    setTimeout(function(){\n        loopsliderPositionDetail();\n    }, 60000);\n};\n\t\n$(function() {\n\t$('.tab li').click(function() {\n\t\tvar index = $('.tab li').index(this);\n\t\t$('.tab-cont').css('display','none');\n\t\t$('.tab-cont').eq(index).css('display','block');\n\t\t$('.tab li').removeClass('select');\n\t\t$(this).addClass('select')\n\t});\n});\n</script>\n\t\n<script>\n</script>\n</body>\n</html>","finalUrl":"https://www.cmp.co.jp/recruit_fresh/voice/index.html","rendered":false,"_cachedAt":"2026-06-22T17:33:53.839Z"}