ordpress/wp-includes/js/jquery/jquery.min.js?ver=3.6.0' id='jquery-core-js'></script>\n<script type='text/javascript' src='https://www.nakamuradoken.co.jp/wordpress/wp-includes/js/jquery/jquery-migrate.min.js?ver=3.3.2' id='jquery-migrate-js'></script>\n<link rel=\"https://api.w.org/\" href=\"https://www.nakamuradoken.co.jp/wp-json/\" /><link rel=\"alternate\" type=\"application/json\" href=\"https://www.nakamuradoken.co.jp/wp-json/wp/v2/interviews/3399\" /><link rel=\"EditURI\" type=\"application/rsd+xml\" title=\"RSD\" href=\"https://www.nakamuradoken.co.jp/wordpress/xmlrpc.php?rsd\" />\n<link rel=\"wlwmanifest\" type=\"application/wlwmanifest+xml\" href=\"https://www.nakamuradoken.co.jp/wordpress/wp-includes/wlwmanifest.xml\" /> \n<meta name=\"generator\" content=\"WordPress 5.8.2\" />\n<link rel=\"canonical\" href=\"https://www.nakamuradoken.co.jp/recruit_information/interview/3399\" />\n<link rel='shortlink' href='https://www.nakamuradoken.co.jp/?p=3399' />\n<link rel=\"alternate\" type=\"application/json+oembed\" href=\"https://www.nakamuradoken.co.jp/wp-json/oembed/1.0/embed?url=https%3A%2F%2Fwww.nakamuradoken.co.jp%2Frecruit_information%2Finterview%2F3399\" />\n<link rel=\"alternate\" type=\"text/xml+oembed\" href=\"https://www.nakamuradoken.co.jp/wp-json/oembed/1.0/embed?url=https%3A%2F%2Fwww.nakamuradoken.co.jp%2Frecruit_information%2Finterview%2F3399&#038;format=xml\" />\n</head>\n\n\n<body>\n    \n    \n    <div class=\"root 3399 interviews interview color2 \" id=\"root\">\n        <div class=\"sentinal\"></div>\n        \n<div class=\"header\" id=\"header\">\r\n  <div class=\"header__inner row\">\r\n    <div class=\"header__inner__item row\">\r\n      <h1 class=\"header__logo logo-company\"><a href=\"/\"><img src=\"/assets/images/common/logo_white.svg?v=6e1fed8d7f987818aa169baae4358029\" alt=\"中村土建\" loading=\"lazy\"/></a></h1>\r\n      <ul class=\"header__menu header__menu--01 show-pc row\"> \r\n        <li><a href=\"/news/\">お知らせ</a></li>\r\n        <li><a href=\"/business/\">事業案内</a></li>\r\n        <li> <a href=\"/company/\">会社案内</a></li>\r\n        <li> <a href=\"/esg/\">ESG（SDGs）</a></li>\r\n        <li><a href=\"/technology/\">技術&ソリューション</a></li>\r\n      </ul>\r\n    </div>\r\n    <div class=\"header__inner__item row\">\r\n      <div class=\"header__logo logo-labo show-pc\"><a href=\"https://kensetsu-labo.jp/\" target=\"_blank\"><img src=\"/assets/images/common/labo_white.svg?v=58ac6d8de06e0886624b4e474500c5e6\" alt=\"建設LABO\" loading=\"lazy\"/></a></div>\r\n      <ul class=\"header__menu header__menu--02 row\">\r\n        <li> <a class=\"recruit\" href=\"https://nakamuradoken-recruit.com/\" target=\"_blank\"\">採用情報</a></li>\r\n        <li><a class=\"inquiry\" href=\"/inquiry/\">お問い合わせ</a></li>\r\n      </ul><a class=\"header__navi__button\" href=\"javascript:void(0);\" id=\"trigger\"></a>\r\n    </div>\r\n  </div>\r\n  <div class=\"header__navi\"> \r\n    <div class=\"header__navi__inner\">\r\n      <div class=\"row\">\r\n        <ul> \r\n          <li><a href=\"/\">ホーム</a></li>\r\n          <li><a href=\"/news/\">お知らせ</a></li>\r\n          <li><a href=\"/business/\">事業案内</a></li>\r\n          <li><a href=\"/company/\">会社案内</a></li>\r\n          <li><a href=\"/esg/\">ESG（SDGs）</a></li>\r\n        </ul>\r\n        <ul> \r\n          <li><a href=\"/technology/\">技術&ソリューション</a></li>\r\n          <li><a href=\"/recruit_information/\">採用情報</a>\r\n            <div class=\"header__navi__childlink\"> <a href=\"/recruit_information/data/\">数字で見る中村土建</a><a href=\"/recruit_information/environment/\">働く環境</a><a href=\"/recruit_information/interview/\">社員紹介</a><a href=\"/recruit_information/requirements/\">募集要項</a></div>\r\n          </li>\r\n          <li><a href=\"/privacy_policy/\">プライバシーポリシー</a></li>\r\n        </ul>\r\n      </div>\r\n      <div class=\"header__navi__inquiry\"><a class=\"inquiry\" href=\"/inquiry/\">お問い合わせ</a><a class=\"tel\" href=\"tel:028-622-6581\">028-622-6581</a></div>\r\n    </div>\r\n  </div>\r\n</div>        <main>\n<div class=\"interview__mv row\">\n    <div class=\"text-area\">\n        <div class=\"text-area__inner intersect-elem\">\n            <h2> <span>INTERVIEW</span></h2>\n\n            <p class=\"name\"> <span class=\"jp\">早川  心</span><span\n                    class=\"en\">Shin  Hayakawa</span>\n            </p>\n\n            <div class=\"tag row\">\n                <p>#土木部                </p>\n                <p>#2021年\n                    入社\n                </p>\n            </div>\n            <div class=\"profile\">\n                <p class=\"profile__ttl\">PROFILE</p>\n                <p>私は高卒（工業高校出身）で入社したのですが、意外と学校で行ったことが仕事に活きています。在学中はわかりませんでしたが、一つひとつのことをしっかり学んで、きちんと授業を受けたほうが今後の身のためにもいいと思います！                </p>\n            </div>\n        </div>\n    </div>\n    <div class=\"image-area intersect-elem\"> <img src=\"https://www.nakamuradoken.co.jp/wordpress/wp-content/uploads/2022/03/bg-のコピー-2.jpg\"\n            alt=\"\" loading=\"lazy\" />\n    </div>\n</div>\n\n<div class=\"breadcrumbs\">\n    <div class=\"inner\">\n        <ul class=\"row\">\n            <li><a class=\"link__alpha home\" href=\"/\">HOME</a></li>\n            <li><a class=\"link__alpha\" href=\"/recruit_information/\">採用情報</a></li>\n            <li> <a class=\"link__alpha\" href=\"/recruit_information/interview/\">社員紹介</a></li>\n            <li> <span>早川  心</span>\n            </li>\n        </ul>\n    </div>\n</div>\n\n<div class=\"content\">\n    <div class=\"interview-detail\">\n        <div class=\"interview__story__wrap\">\n            <div class=\"inner\">\n                <div class=\"interview__story\">\n\n\n                    \n                    <div class=\"interview__story__item row intersect-elem\">\n                        <div class=\"text-area\">\n                            <div class=\"text-area__inner\">\n                                <p class=\"story__label\">STORY 01                                </p>\n                                <h3>入社した理由                                </h3>\n                                <p>\n                                    『この橋、私が作ったんだ！』とか言ってみたいなと思っていたところ、現場において最後まで構造物のできあがっていく過程を見ることができるのは“現場監督”だけだと聞いて、現場監督になろうと決意しました。<br />\r\n実際に現場に出るようになって、自分が施工を担当している構造物が間近でできあがっていく様子を見るのは、とてもウキウキします。                                </p>\n                            </div>\n                        </div>\n                        <div class=\"image-area\"> <img\n                                src=\"https://www.nakamuradoken.co.jp/wordpress/wp-content/uploads/2022/03/Clip-3.jpg\" alt=\"\"\n                                loading=\"lazy\" />\n                        </div>\n                    </div>\n\n\n                    \n                    <div class=\"interview__story__item row intersect-elem\">\n                        <div class=\"text-area\">\n                            <div class=\"text-area__inner\">\n                                <p class=\"story__label\">STORY 02                                </p>\n                                <h3>仕事内容について                                </h3>\n                                <p>\n                                    現在入社１年目ですが、外での作業だけでなくさまざまなデスクワークも行っています。<br />\r\n外での作業としては、測量を所長や年齢の近い先輩と一緒に行ったり、工事の写真を撮ったりしています。<br />\r\nデスクワークは、現場で撮影した工事写真の整理・管理、掲示物関係の作成、日々の点検表のチェック、書類整理やCADなどをしています。                                </p>\n                            </div>\n                        </div>\n                        <div class=\"image-area\"> <img\n                                src=\"https://www.nakamuradoken.co.jp/wordpress/wp-content/uploads/2022/03/base-10.jpg\" alt=\"\"\n                                loading=\"lazy\" />\n                        </div>\n                    </div>\n\n\n                    \n                    <div class=\"interview__story__item row intersect-elem\">\n                        <div class=\"text-area\">\n                            <div class=\"text-area__inner\">\n                                <p class=\"story__label\">STORY 03                                </p>\n                                <h3>仕事のやりがい                                </h3>\n                                <p>\n                                    まだ入社したばかりで知識もほとんどない自分が資料等を作成しても、先輩や所長にチェックしてもらったり、直してもらったりすることで、余計な時間を割かせてしまっているのではないかと感じることもありました。しかし、一度自分でよく確認したり、分からない点はその場で聞きながら行ったりして、いろいろ工夫することでスムーズに仕事が進むととても嬉しいです。                                </p>\n                            </div>\n                        </div>\n                        <div class=\"image-area\"> <img\n                                src=\"https://www.nakamuradoken.co.jp/wordpress/wp-content/uploads/2022/03/base-9.jpg\" alt=\"\"\n                                loading=\"lazy\" />\n                        </div>\n                    </div>\n\n\n                    \n                    <div class=\"interview__story__item row intersect-elem\">\n                        <div class=\"text-area\">\n                            <div class=\"text-area__inner\">\n                                <p class=\"story__label\">STORY 04                                </p>\n                                <h3>今後の目標                                </h3>\n                                <p>\n                                    まずは、仕事の流れを一通り覚えていきたいです。現在、河川工事の現場で施工前の準備段階から関われているので、完工するまでの間にどんな時にどのような仕事があるのかをしっかり覚えて、次に繋げていきたいと思っています。<br />\r\nまだまだ知識もあまりないためわからないことばかりですが、その場その場で解決していくようにしています。                                </p>\n                            </div>\n                        </div>\n                        <div class=\"image-area\"> <img\n                                src=\"https://www.nakamuradoken.co.jp/wordpress/wp-content/uploads/2022/03/base-8.jpg\" alt=\"\"\n                                loading=\"lazy\" />\n                        </div>\n                    </div>\n\n\n                    \n\n\n\n\n\n\n                </div>\n            </div>\n        </div>\n        <div class=\"interview__message\">\n            <div class=\"inner intersect-elem\">\n                <p class=\"message__ttl\"><span class=\"en\">MESSAGE</span><span class=\"jp\">学生へのメッセージ</span>\n                </p>\n                <p>\n                    私は高卒（工業高校出身）で入社したのですが、意外と学校で行ったことが仕事に活きています。<br />\r\n在学中はわかりませんでしたが、一つひとつのことをしっかり学んで、<br />\r\nきちんと授業を受けたほうが今後の身のためにもいいと思います！                </p>\n            </div>\n        </div>\n        <div class=\"back-to-list more-link\"><a href=\"./\">BACK</a></div>\n    </div>\n</div>\n\n\n\n</main>\n\n<div class=\"footer\"> \r\n  <div class=\"footer__top\">\r\n    <ul class=\"row\">\r\n      <li><a class=\"link__alpha\" href=\"/news/\">お知らせ</a></li>\r\n      <li><a class=\"link__alpha\" href=\"/business/\">事業案内</a></li>\r\n      <li><a class=\"link__alpha\" href=\"/company/\">会社案内</a></li>\r\n      <li><a class=\"link__alpha\" href=\"/esg/\">ESG（SDGs）</a></li>\r\n      <li><a class=\"link__alpha\" href=\"/technology/\">技術&ソリューション</a></li>\r\n      <li><a class=\"link__alpha\" href=\"https://nakamuradoken-recruit.com/\" target=\"_blank\">採用情報</a></li>\r\n      <li><a class=\"link__alpha\" href=\"/inquiry/\">お問い合わせ</a></li>\r\n      <li><a class=\"link__alpha\" href=\"/privacy_policy/\">プライバシーポリシー</a></li>\r\n    </ul>\r\n  </div>\r\n  <div class=\"footer__bottom\">\r\n    <p class=\"footer__copyright\">Copyright©2018 Nakamuradoken co.,ltd. <br class=\"show-sp\"/>all rights reserved.</p>\r\n  </div>\r\n</div>\n</div>\n\n\n<script src=\"/assets/js/vendor.js\" defer></script>\n<script src=\"/assets/js/runtime.js\" defer></script>\n<script src=\"/assets/js/bundle.js\" defer></script>\n\n<script type='text/javascript' id='toc-front-js-extra'>\n/* <![CDATA[ */\nvar tocplus = {\"visibility_show\":\"show\",\"visibility_hide\":\"hide\",\"width\":\"Auto\"};\n/* ]]> */\n</script>\n<script type='text/javascript' src='https://www.nakamuradoken.co.jp/wordpress/wp-content/plugins/table-of-contents-plus/front.min.js?ver=2106' id='toc-front-js'></script>\n<script type='text/javascript' src='https://www.nakamuradoken.co.jp/wordpress/wp-includes/js/wp-embed.min.js?ver=5.8.2' id='wp-embed-js'></script>\n</body>\n\n</html>","finalUrl":"https://www.nakamuradoken.co.jp/recruit_information/interview/3399","rendered":false,"_cachedAt":"2026-06-23T23:40:36.989Z"}