{"url":"https://k-e-g.co.jp/recruit/","html":"<!DOCTYPE html>\r\n<html lang=\"ja\">\r\n<head>\r\n  <!-- Google Tag Manager -->\r\n  <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\r\n  new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\r\n  j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\r\n  'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\r\n  })(window,document,'script','dataLayer','GTM-KPX3DMJN');</script>\r\n  <!-- End Google Tag Manager -->\r\n  <!-- Google Tag Manager -->\r\n  <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\r\n  new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\r\n  j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\r\n  'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\r\n  })(window,document,'script','dataLayer','GTM-MHHTS2');</script>\r\n  <!-- End Google Tag Manager -->\r\n\r\n  <script type=\"text/javascript\">\r\n    (function(c,l,a,r,i,t,y){\r\n        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};\r\n        t=l.createElement(r);t.async=1;t.src=\"https://www.clarity.ms/tag/\"+i;\r\n        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);\r\n    })(window, document, \"clarity\", \"script\", \"vf4yadxzgh\");\r\n  </script>\r\n\r\n  <meta charset=\"UTF-8\">\r\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n  <meta http-equiv=\"X-UA-Compatible\" content=\"ie=edge\">\r\n  <meta name=\"Description\" content=\"総合教育業【株式会社KEGキャリア・アカデミー】の採用募集サイトです。得意を活かしながら、和歌山から教育業界を盛り上げていきましょう。みなさまからのご応募をお待ちしております。\">\r\n  <meta name=\"Keywords\" content=\"求人,募集,応募,採用,アルバイト,パート,正社員,株式会社KEGキャリア・アカデミー,和歌山,教育,塾,認可小規模保育園,幼児教室,学習塾,資格検定スクール,通信単位制高校,職業訓練校,障がい者支援事業所,塾講師,保育士,\">\r\n  <title>株式会社KEGキャリア・アカデミー｜採用情報サイト</title>\r\n  \r\n  <link rel=\"icon\" href=\"favicon.ico\">\r\n  <link rel=\"stylesheet\" href=\"css/reset.css\">\r\n  <link rel=\"stylesheet\" href=\"css/animate.css\">\r\n  <link rel=\"stylesheet\" href=\"css/remodal-default-theme.css\">\r\n  <link rel=\"stylesheet\" href=\"css/remodal.css\">\r\n  <link href=\"recruit_map/recruit_map.css\" rel=\"stylesheet\">\r\n  <link rel=\"stylesheet\" href=\"css/style.css\">\r\n\r\n  <!-- font -->\r\n  <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\r\n  <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\r\n  <link href=\"https://fonts.googleapis.com/css2?family=Lato:wght@400;900&family=Noto+Sans+JP:wght@100..900&display=swap\" rel=\"stylesheet\">\r\n</head>\r\n\r\n<body>\r\n  <!-- Google Tag Manager (noscript) -->\r\n  <noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-KPX3DMJN\"\r\n  height=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\r\n  <!-- End Google Tag Manager (noscript) -->\r\n  <!-- Google Tag Manager (noscript) -->\r\n  <noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-MHHTS2\"\r\n  height=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\r\n  <!-- End Google Tag Manager (noscript) -->\r\n\r\n  <header id=\"header\" class=\"header\">\r\n    <h1 class=\"header_logo\"><a href=\"https://k-e-g.co.jp/\" target=\"_blank\" rel=\"noopener\"><img src=\"images/logo_kadono-educational-group.png\" alt=\"KADONO EDUCATIONAL GROUP\" loading=\"eager\" width=\"601\" height=\"43\"></a></h1>\r\n    <div id=\"entry-btn\" class=\"entry-btn-group\">\r\n      <a class=\"entry-btn entry-btn--full\" href=\"/job/-/info/list?es=07\">正社員志望の方はこちら</a>\r\n      <a class=\"entry-btn entry-btn--part\" href=\"/job/-/info/list?es=01\">パート・アルバイト<br>志望の方はこちら</a>\r\n    </div>\r\n  </header>\r\n\r\n<main>\r\n  <div class=\"mv\">\r\n    <picture>\r\n      <source srcset=\"images//mv.jpg\" media=\"(min-width: 769px)\">\r\n      <img src=\"images/mv_sp.jpg\" alt=\"教育を通して社会貢献\" width=\"750\" height=\"1261\">\r\n    </picture>\r\n  </div>\r\n\r\n  <section class=\"message\">\r\n    <div class=\"inner inner--l\">\r\n      <h2 class=\"heading wow fadeInUp\">MESSAGE</h2>\r\n    </div>\r\n\r\n      <div class=\"message_body container\">\r\n        <img src=\"images/image_01.jpg\" alt=\"\" class=\"message_img wow fadeInUp\" width=\"1100\" height=\"2011\" loading=\"lazy\">\r\n        <div class=\"inner\">\r\n          <div class=\"message_cont\">\r\n            <h3 class=\"message_cont-heading wow fadeInUp\">毎年成長し続ける会社<br>上場目指して！！</h3>\r\n            <div class=\"message_txt-container wow fadeInUp\">\r\n              <p class=\"message_txt\">KADONO EDUCATIONAL GROUPは<br>地域の子どもたちのための学習塾からスタートした会社です。<br>総合教育業の会社として和歌山に本社を置き、<br class=\"u-pc\">関西一円と東京に拠点があります。</p>\r\n              <p class=\"message_txt\">日々立ち止まらず新事業を開拓し<br class=\"u-pc\">従業員数、売上高は年々増加しています。<br>現在では0才児の赤ちゃんからシニア、<br class=\"u-pc\">障がいをお持ちの方、そして日本で働く外国の方まで<br class=\"u-pc\">私たちのステークホルダーは非常に多様化しています。</p>\r\n              <p class=\"message_txt\">成長し続ける、活気ある会社で新しい仲間を<br class=\"u-pc\"><span class=\"u-word\">お待ちしています！</span></p>\r\n            </div>\r\n\r\n            <div class=\"message_signature\">\r\n              <p class=\"message_signature-txt\">代表取締役</p>\r\n              <img src=\"images/text_kadono.svg\" alt=\"角野 寛典\" class=\"message_signature-img\">\r\n            </div>\r\n          </div>\r\n        </div><!-- /.inner -->\r\n      </div><!-- /.message_body -->\r\n\r\n      <div class=\"message_vision\">\r\n        <div class=\"inner wow fadeInUp\">\r\n          <img src=\"images/image_02.png\" alt=\"誰もが活躍できる場がある会社！\" class=\"message_vision-img\" width=\"1697\" height=\"961\" loading=\"lazy\">\r\n        </div><!-- /.inner -->\r\n      </div><!-- /.message_vision -->\r\n\r\n      <div class=\"message_person container message_container\">\r\n        <div class=\"inner\">\r\n          <h3 class=\"sub-heading wow fadeInUp\">求める人物像</h3>\r\n\r\n          <ul class=\"message_person-list wow fadeInUp\">\r\n            <li class=\"message_person-item\">\r\n              <p class=\"message_person-txt\">笑顔で前向きに<br>仕事に取り組む方</p>\r\n            </li>\r\n            <li class=\"message_person-item\">\r\n              <p class=\"message_person-txt\">仕事を進める上で<br>コミュニケーションを<br>大切にする方</p>\r\n            </li>\r\n            <li class=\"message_person-item\">\r\n              <p class=\"message_person-txt\">新しい事柄に<br>向上心を持って<br>取り組む方</p>\r\n            </li>\r\n          </ul>\r\n\r\n          <p class=\"message_person-message wow fadeInUp\">年齢、性別、国籍は問いません。<br>人物像に合う方、<span class=\"u-word\">お待ちしております。</span></p>\r\n        </div><!-- /.inner -->\r\n      </div>\r\n\r\n      <div class=\"gallery\">\r\n        <div class=\"slider-wrapper\">\r\n          <div class=\"slide-pic\"><img src=\"images/image_04.jpg\" alt=\"\" width=\"753\" height=\"557\"></div>\r\n          <div class=\"slide-pic\"><img src=\"images/image_05.jpg\" alt=\"\" width=\"753\" height=\"557\"></div>\r\n          <div class=\"slide-pic\"><img src=\"images/image_09.jpg\" alt=\"\" width=\"753\" height=\"557\"></div>\r\n          <div class=\"slide-pic\"><img src=\"images/image_06.jpg\" alt=\"\" width=\"753\" height=\"557\"></div>\r\n          <div class=\"slide-pic\"><img src=\"images/image_07.jpg\" alt=\"\" width=\"753\" height=\"557\"></div>\r\n          <div class=\"slide-pic\"><img src=\"images/image_08.jpg\" alt=\"\" width=\"753\" height=\"557\"></div>\r\n          <div class=\"slide-pic\"><img src=\"images/image_04.jpg\" alt=\"\" width=\"753\" height=\"557\"></div>\r\n          <div class=\"slide-pic\"><img src=\"images/image_05.jpg\" alt=\"\" width=\"753\" height=\"557\"></div>\r\n          <div class=\"slide-pic\"><img src=\"images/image_09.jpg\" alt=\"\" width=\"753\" height=\"557\"></div>\r\n          <div class=\"slide-pic\"><img src=\"images/image_06.jpg\" alt=\"\" width=\"753\" height=\"557\"></div>\r\n          <div class=\"slide-pic\"><img src=\"images/image_07.jpg\" alt=\"\" width=\"753\" height=\"557\"></div>\r\n          <div class=\"slide-pic\"><img src=\"images/image_08.jpg\" alt=\"\" width=\"753\" height=\"557\"></div>\r\n        </div>\r\n      </div><!-- /.gallery -->\r\n  </section>\r\n\r\n  <section class=\"about\">\r\n    <div class=\"inner inner--l\">\r\n      <h2 class=\"heading wow fadeInUp\">ABOUT US</h2>\r\n    </div>\r\n\r\n    <div class=\"container about_container\">\r\n      <div class=\"inner\">\r\n        <h3 class=\"sub-heading wow fadeInUp\">事業内容</h3>\r\n\r\n        <ul class=\"about_list wow fadeInUp\">\r\n          <li class=\"about_item\">\r\n            <img src=\"images/image_11.jpg\" alt=\"\" class=\"about_item-img\">\r\n            <h3 class=\"about_item-name\">人材支援事業局</h3>\r\n            <ul class=\"about_item-detail\">\r\n              <li>外国人材紹介事業</li>\r\n              <li>職業訓練事業</li>\r\n              <li>無料・有料職業紹介事業</li>\r\n            </ul>\r\n          </li>\r\n          <li class=\"about_item\">\r\n            <img src=\"images/image_12.jpg\" alt=\"\" class=\"about_item-img\">\r\n            <h3 class=\"about_item-name\">福祉事業局</h3>\r\n            <ul class=\"about_item-detail\">\r\n              <li>障がい者支援事業</li>\r\n              <li>介護事業</li>\r\n              <li>保育事業</li>\r\n            </ul>\r\n          </li>\r\n          <li class=\"about_item\">\r\n            <img src=\"images/image_13.jpg\" alt=\"\" class=\"about_item-img\">\r\n            <h3 class=\"about_item-name\">教育事業局</h3>\r\n            <ul class=\"about_item-detail\">\r\n              <li>学習塾事業</li>\r\n              <li>映像事業</li>\r\n              <li>通信・単位制高校事業</li>\r\n            </ul>\r\n          </li>\r\n          <li class=\"about_item\">\r\n            <img src=\"images/image_14.jpg\" alt=\"\" class=\"about_item-img\">\r\n            <h3 class=\"about_item-name\">特命事業局</h3>\r\n            <ul class=\"about_item-detail\">\r\n              <li>新規事業</li>\r\n            </ul>\r\n          </li>\r\n          <li class=\"about_item\">\r\n            <img src=\"images/image_15.jpg\" alt=\"\" class=\"about_item-img\">\r\n            <h3 class=\"about_item-name\">地域づくり事業局</h3>\r\n            <ul class=\"about_item-detail\">\r\n              <li>ふるさと納税事業</li>\r\n              <li>まちづくり事業</li>\r\n              <li>指定管理事業</li>\r\n              <li>学童保育事業</li>\r\n            </ul>\r\n          </li>\r\n        </ul>\r\n      </div><!-- /.inner -->\r\n    </div>\r\n  </section>\r\n\r\n  <section class=\"interview\">\r\n    <div class=\"inner inner--l\">\r\n      <h2 class=\"heading wow fadeInUp\">INTERVIEW</h2>\r\n    </div>\r\n    <div class=\"inner\">\r\n      <div class=\"interview_item-group wow fadeInUp\">\r\n        <div class=\"interview_item\" data-remodal-target=\"modal_m\">\r\n          <img src=\"images/image_m_01.jpg\" alt=\"\" class=\"interview_item-img\" width=\"940\" height=\"849\" loading=\"lazy\">\r\n          <div class=\"interview_item-body\">\r\n            <h3 class=\"interview_item-info\">アップル保育園 / 保育士<span class=\"interview_item-name\">Mさん</span></h3>\r\n            <button class=\"btn\">インタビューを見る</button>\r\n          </div><!-- /.interview_item-body -->\r\n        </div><!-- /.interview_item-->\r\n        <div class=\"interview_item\" data-remodal-target=\"modal_s\">\r\n          <img src=\"images/image_s_01.jpg\" alt=\"\" class=\"interview_item-img\" width=\"940\" height=\"849\" loading=\"lazy\">\r\n          <div class=\"interview_item-body\">\r\n            <h3 class=\"interview_item-info\">河合塾マナビス / 校舎長<span class=\"interview_item-name\">Sさん</span></h3>\r\n            <button class=\"btn\">インタビューを見る</button>\r\n          </div><!-- /.interview_item-body -->\r\n        </div><!-- /.interview_item-->\r\n      </div><!-- /.interview_item-group -->\r\n    </div><!-- /.inner -->\r\n\r\n\r\n    <div class=\"remodal\" data-remodal-id=\"modal_m\">\r\n      <div class=\"modal inner\">\r\n        <div class=\"modal_top\">\r\n          <div class=\"modal_top-body\">\r\n            <p class=\"modal_copy\">子供の成長を見ていると<br>実感できるところが喜びです</p>\r\n            <p class=\"modal_info\">アップル保育園 / 保育士</p>\r\n            <p class=\"modal_name\">Mさん</p>\r\n          </div>\r\n          <img src=\"images/image_m_02.jpg\" alt=\"\" width=\"1052\" height=\"773\" class=\"modal_img\">\r\n        </div>\r\n\r\n        <div class=\"qa\">\r\n          <ul class=\"qa_list\">\r\n            <li class=\"qa_item\">\r\n              <p class=\"qa_question\">保育士を目指したきっかけは？</p>\r\n              <p class=\"qa_answer\">小さいころ通った幼稚園の先生に憧れたのがきっかけです。とても印象に残る先生で高校進学を控え、将来を考えたときに今まで漠然と描いていた保育士さんになりたい、という夢を現実にしたいと思い、保育科のある高校に進学しました。</p>\r\n            </li>\r\n            <li class=\"qa_item\">\r\n              <p class=\"qa_question\">アップル保育園を選んだ理由は？</p>\r\n              <p class=\"qa_answer\">短大の時に実習に行った保育園で担当していただいた先生が、「あなたのいいところは、子供と一生懸命向き合って1対1で深く関われるところがいいところですね」と言っていただきました。それならその自分の長所を生かせるところがいいなと考え、自分には大規模園より小規模園が合っているんじゃないかと思い、探してアップル保育園東住吉園に見学に行かせてもらいました。その時のお散歩の雰囲気や先生方が声をかけてくれる雰囲気がとても優しく、ふんわりしたところがとても気に入って入職させていただくことになりました。</p>\r\n            </li>\r\n            <li class=\"qa_item\">\r\n              <p class=\"qa_question\">実際仕事をしてどうですか？</p>\r\n              <p class=\"qa_answer\">外から見ているのとでは全然印象が変わりました。小規模保育は0.1.2歳児の園児がいます。赤ちゃんだと思っていたのに、日々こんなことができるんだ、できることがこんなに増えていくんだ、と感動しました。また、小規模園だからこそ、保護者さんとの距離が近く、一緒に子供の成長を見ている、と実感できるところが喜びです。<br>また保育にはこれという正解がないと思っているので、各先生方とコミュニケーションをとって話し合いながら一人一人の子供の成長の過程を話しあって決めていくことに日々のやりがいを感じます。</p>\r\n            </li>\r\n          </ul>\r\n        </div>\r\n\r\n        <button class=\"btn\" data-remodal-action=\"close\">閉じる</button>\r\n        <button class=\"modal_close-btn\" data-remodal-action=\"close\"></button>\r\n      </div>\r\n    </div>\r\n\r\n    <div class=\"remodal\" data-remodal-id=\"modal_s\">\r\n      <div class=\"modal inner\">\r\n        <div class=\"modal_top\">\r\n          <div class=\"modal_top-body\">\r\n            <p class=\"modal_copy\">合格報告を受けることが<br>一番うれしいです</p>\r\n            <p class=\"modal_info\">河合塾マナビス / 校舎長</p>\r\n            <p class=\"modal_name\">Sさん</p>\r\n          </div>\r\n          <img src=\"images/image_s_02.jpg\" alt=\"\" width=\"1052\" height=\"773\" class=\"modal_img\">\r\n        </div>\r\n\r\n        <div class=\"qa\">\r\n          <ul class=\"qa_list\">\r\n            <li class=\"qa_item\">\r\n              <p class=\"qa_question\">この仕事を選んだきっかけは？</p>\r\n              <p class=\"qa_answer\">私はとても充実した大学生活を過ごすことができました。当時は深く考えずに日々楽しく過ごしていたのですが、就職を考える時期になり、友人たちとの会話の中で高校の進路指導の先生にとても親身になって相談にのってもらい、そこから一気に大学受験に向かう気持ち、将来への夢を強く持つようになり大学受験にも合格することができた、ということを思い出しました。自分の導きでその人の人生に関わることができたらと思い、教員や進路指導に関わるような仕事につきたいと思うようになりました。</p>\r\n            </li>\r\n            <li class=\"qa_item\">\r\n              <p class=\"qa_question\">実際仕事をしてどうですか？</p>\r\n              <p class=\"qa_answer\">大学、進路の選択は幅広く、生徒、また保護者の方との考え方の違いがあったり、そもそも将来の夢や目標がなかなか見つからない生徒もいます。そういった生徒とともに正解のない答えを探す手助けをすることはやはり難しいと感じます。また、最終的に進路を決めるのは生徒一人ひとりですが、進路を決定するまでにご家族や学校、多くの方々が生徒を支えているということを再認識しています。私たちもその中で大げさに言うと一人の人生を変えるのかもしれない、という大きな存在意義と責任を感じて仕事をしています。</p>\r\n            </li>\r\n            <li class=\"qa_item\">\r\n              <p class=\"qa_question\">やりがいを感じるのは？</p>\r\n              <p class=\"qa_answer\">やはり合格報告を受けることが一番うれしいです。時には苦しみ、スランプを乗り越えて、笑って、泣いて、という生徒の姿を見てきて、それが結果となって表れたときは、自分のことのように喜びを感じます。また卒業していった生徒たちの後輩や兄弟姉妹が続けて入会してくれることで、信頼を感じますし、卒業生が大学生活を満喫しているという近況を聞くことができるのもうれしいです。</p>\r\n            </li>\r\n          </ul>\r\n        </div>\r\n\r\n        <button class=\"btn\" data-remodal-action=\"close\">閉じる</button>\r\n        <button class=\"modal_close-btn\" data-remodal-action=\"close\"></button>\r\n      </div>\r\n    </div>\r\n  </section>\r\n\r\n  <section class=\"data\">\r\n    <div class=\"inner inner--l\">\r\n      <h2 class=\"heading wow fadeInUp\">DATA</h2>\r\n      <p class=\"data_subheading wow fadeInUp\">KADONO EDUCATIONAL GROUP</p>\r\n    </div>   \r\n      <div class=\"inner\">\r\n        <ul class=\"data_list wow fadeInUp\">\r\n          <li class=\"data_item data_item--01\">\r\n            <h3 class=\"data_item-heading\">売上</h3>\r\n            <div class=\"data_item-cont\">\r\n              <div>\r\n                <p class=\"data_item-txt\"><span class=\"emphasis\">33</span>億円</p>\r\n                <p class=\"data_item-note\">（2025年グループ合計）</p>\r\n              </div>\r\n              <img src=\"images/image_data_sales.svg\" class=\"data_item-img\" alt=\"2024年27億円、2025年年33億円、2030年100億円\" width=\"175\" height=\"232\" loading=\"lazy\">\r\n            </div>\r\n\r\n          </li>\r\n          <li class=\"data_item data_item--02\">\r\n            <h3 class=\"data_item-heading\">事業所数</h3>\r\n            <p class=\"data_item-txt\"><span class=\"emphasis\">127</span>事業所</p>\r\n          </li>\r\n          <li class=\"data_item data_item--03\">\r\n            <h3 class=\"data_item-heading\">社員数</h3>\r\n            <p class=\"data_item-txt\"><span class=\"emphasis\">1,852</span>名</p>\r\n            <p class=\"data_item-note\">平均年齢38.6歳</p>\r\n          </li>\r\n          <li class=\"data_item data_item--04\">\r\n            <h3 class=\"data_item-heading\">有給取得<span class=\"u-word\">平均日数</span></h3>\r\n            <p class=\"data_item-txt\"><span class=\"emphasis\">10</span>日/年</p>\r\n          </li>\r\n          <li class=\"data_item data_item--05\">\r\n            <h3 class=\"data_item-heading\">平均実働時間</h3>\r\n            <p class=\"data_item-txt\"><span class=\"emphasis\">173<span class=\"small\">.4</span></span>時間</p>\r\n          </li>\r\n          <li class=\"data_item data_item--06\">\r\n            <h3 class=\"data_item-heading\">従業員男女比率</h3>\r\n            <img src=\"images/image_data_gender-ratio.svg\" class=\"data_item-img\" alt=\"男性36%,女性64%\" width=\"264\" height=\"146\" loading=\"lazy\">\r\n          </li>\r\n          <li class=\"data_item data_item--07\">\r\n            <h3 class=\"data_item-heading\">退職率</h3>\r\n            <p class=\"data_item-txt\"><span class=\"emphasis\">13<span class=\"small\">.5</span></span>%</p>\r\n            <p class=\"data_item-note\">（2025年グループ全体）</p>\r\n            <p class=\"data_item-attention\">※正社員のみ</p>\r\n          </li>\r\n          <li class=\"data_item data_item--08\">\r\n            <h3 class=\"data_item-heading\">産休・育休後<span class=\"u-word\">復帰率</span></h3>\r\n            <p class=\"data_item-txt\"><span class=\"emphasis\">98</span>%</p>\r\n          </li>\r\n        </ul>\r\n      </div><!-- /.inner -->\r\n  </section>\r\n\r\n\r\n  <section class=\"search\">\r\n    <div class=\"search_body container\">\r\n      <div class=\"inner inner--l\">\r\n        <h2 class=\"heading wow fadeInUp\">JOB SEARCH</h2>\r\n      </div>\r\n      <div class=\"inner\">\r\n        <h3 class=\"sub-heading wow fadeInUp\">雇用形態から探す</h3>\r\n        <div class=\"search_btn-group search_btn-group--type wow fadeInUp\">\r\n          <a href=\"/job/-/info/list?es=07\" class=\"btn\">正社員</a>\r\n          <a href=\"/job/-/info/list?es=01\" class=\"btn\">パート・アルバイト</a>\r\n        </div>\r\n        <h3 class=\"sub-heading wow fadeInUp\">職種から探す</h3>\r\n        <div class=\"search_btn-group wow fadeInUp\">\r\n          <a href=\"/job/-/info/list?brand=B0001\" class=\"btn\">事務</a>\r\n          <a href=\"/job/-/info/list?brand=B0002\" class=\"btn\">営業</a>\r\n          <a href=\"/job/-/info/list?brand=B0003\" class=\"btn\">運営管理</a>\r\n          <a href=\"/job/-/info/list?brand=B0004\" class=\"btn\">保育士</a>\r\n          <a href=\"/job/-/info/list?brand=B0006\" class=\"btn\">障がい者支援</a>\r\n          <a href=\"/job/-/info/list?brand=B0005\" class=\"btn\">講師</a>\r\n          <a href=\"/job/-/info/list?brand=B0007\" class=\"btn\">学童保育</a>\r\n          <a href=\"/job/-/info/list?brand=B0008\" class=\"btn\">その他</a>\r\n        </div>\r\n        <h3 class=\"sub-heading wow fadeInUp\">地域から探す</h3>\r\n        <div class=\"search_btn-group wow fadeInUp\">\r\n          <a href=\"/job/-/info/list?area=5&pref=30\" class=\"btn\">和歌山県</a>\r\n          <a href=\"/job/-/info/list?area=5&pref=27\" class=\"btn\">大阪府</a>\r\n          <a href=\"/job/-/info/list?area=5&pref=28\" class=\"btn\">兵庫県</a>\r\n          <a href=\"/job/-/info/list?area=5&pref=26\" class=\"btn\">京都府</a>\r\n          <a href=\"/job/-/info/list?area=5&pref=29\" class=\"btn\">奈良県</a>\r\n          <a href=\"/job/-/info/list?area=2&pref=13\" class=\"btn\">東京都</a>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n\r\n    <div class=\"box_map-container\">\r\n      <div class=\"box_map wow fadeInUp\">\r\n        <!-- フリーワード検索 -->\r\n        <form method=\"get\" action=\"/job/-/info/list\">\r\n          <label>Free Word</label><input type=\"text\" maxlength=\"100\" name=\"word\" value=\"\" placeholder=\"検索ワード\"><button type=\"submit\"><img src=\"recruit_map/search-solid.png\" alt=\"検索する\"></button>\r\n        </form>\r\n        <a class=\"box_map-txt\" href=\"/job/-/info/list\">全ての求人はこちら</a>\r\n      </div>\r\n    </div><!-- /.box_map-container -->\r\n  </section>\r\n</main>\r\n\r\n\r\n  <footer id=\"footer\" class=\"footer\">\r\n    <div class=\"footer-nav\">\r\n      <a href=\"https://k-e-g.co.jp/\" target=\"_blank\" rel=\"noopener\">コーポレートサイト</a>\r\n      <a href=\"https://k-e-g.co.jp/privacy-policy/\" target=\"_blank\" rel=\"noopener\">プライバシーポリシー</a>\r\n      <a href=\"/-/top/informativedata.pdf\" target=\"_blank\" rel=\"noopener\">インフォマティブデータの利用について</a>\r\n    </div>\r\n    <p class=\"copyright\"><small>Copyright © 株式会社KEGキャリア・アカデミー ALL RIGHTS RESERVED.</small></p>\r\n  </footer>\r\n\r\n  <script src=\"https://code.jquery.com/jquery-3.4.1.min.js\" integrity=\"sha256-CSXorXvZcTkaix6Yvo6HppcZGetbYMGWSFlBw8HfCJo=\" crossorigin=\"anonymous\"></script>\r\n  <script src=\"recruit_map/recruit_map.js\"></script>\r\n  <script>\r\n    $(function () {\r\n      $.recruitMap();\r\n    });\r\n  </script>\r\n  <script src=\"js/wow.min.js\"></script>\r\n  <script src=\"js/remodal.js\"></script>\r\n  <script src=\"js/script.js\"></script>\r\n</body>\r\n</html>","finalUrl":"https://k-e-g-recruit.jp/-/top/index.html","rendered":false,"_cachedAt":"