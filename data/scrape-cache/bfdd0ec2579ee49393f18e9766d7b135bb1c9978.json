   <ul class=\"c-navChildList\">\n                                    <li>\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<a href=\"https://a-tic.co.jp/recruit/about/compare-years/\">4年目と8年目を比べてみた</a>\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<a href=\"https://a-tic.co.jp/recruit/about/compare-years-1-8/\">1年目と8年目を比べてみた</a>\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t</li>\n                                    <li><a href=\"https://a-tic.co.jp/recruit/about/data/\">数字でみるエーティック</a></li>\n                                </ul>\n                            </li>\n                            <li>\n                                <div class=\"flex\"><a href=\"https://a-tic.co.jp/recruit/recruit/\" class=\"en -BoldItalic\">RECRUIT</a><span class=\"c-icon\"></span></div>\n                                <ul class=\"c-navChildList\">\n                                    <li><a href=\"https://a-tic.co.jp/recruit/recruit/#person\">求める人物像・キャリアアップ</a></li>\n                                    <li><a href=\"https://a-tic.co.jp/recruit/recruit/#description\">募集要項</a></li>\n                                </ul>\n                            </li>\n                            <li>\n                                <div><a href=\"https://a-tic.co.jp/recruit/faq/\" class=\"en -BoldItalic\">Q&A</a></div>\n                            </li>\n                            <li>\n                                <div><a href=\"https://a-tic.co.jp/recruit/information/\" class=\"en -BoldItalic\">INFORMATION</a></div>\n                            </li>\n                        </ul>\n                    </div>\n                    <div class=\"sns\">\n                        <a href=\"https://www.facebook.com/atic.jp/?locale=ja_JP\" target=\"_blank\"><img src=\"https://a-tic.co.jp/recruit/src/img/common/facebook-icon.svg\" alt=\"facebook\"></a>\n                        <a href=\"https://x.com/atic2845?s=21&t=O8Dfe1-TJpRZW6nKaPl01w\" target=\"_blank\"><img src=\"https://a-tic.co.jp/recruit/src/img/common/x-icon.svg\" alt=\"X\"></a>\n                        <a href=\"https://www.instagram.com/atic2845\" target=\"_blank\"><img src=\"https://a-tic.co.jp/recruit/src/img/common/instagram-icon.svg\" alt=\"instagram\"></a>\n                    </div>\n                </div>\n            </nav>\n        </div><main class=\"l-main\" id=\"swup\">\n            <div class=\"c-page-mv relative\">\n                <div class=\"c-page-mv__head\">\n                    <h2 class=\"en -BoldItalic\">RECRUIT</h2>\n                    <ul class=\"c-breadcrumb\">\n                        <li class=\"en\"><a href=\"https://a-tic.co.jp/recruit/\"><span>TOP</span></a></li>\n                        <li class=\"en\"><span>RECRUIT</span></li>\n                    </ul>\n                </div>\n                <div class=\"c-page-mv__body relative\">\n                    <picture class=\"c-page-mv__img\">\n                        <source srcset=\"https://a-tic.co.jp/recruit/src/img/recruit/mv-bg_sp.webp\" media=\"(max-width: 767px)\" />\n                        <img src=\"https://a-tic.co.jp/recruit/src/img/recruit/mv-bg_pc.webp\" alt=\"\" />\n                    </picture>\n                    <div class=\"c-scroll\">\n                        <span class=\"en\">SCROLL DOWN</span>\n                    </div>\n                </div>\n            </div>\n            <div class=\"p-recruit\">\n                <div class=\"c-tab w1000 reveal fade-in-up\">\n                    <div class=\"c-tab__list p-recruit__list flex\">\n                        <a href=\"#person\" class=\"c-tab__item\"><span>求める人物像</span></a>\n                        <a href=\"#career\" class=\"c-tab__item\"><span>キャリアパス・福利厚生</span></a>\n                        <a href=\"#description\" class=\"c-tab__item\"><span>募集要項</span></a>\n                    </div>\n                </div>\n                <section class=\"p-recruit__sec person w1200\" id=\"person\">\n\n                    <div class=\"c-head\">\n                        <h3 class=\"reveal fade-in-up\"><span>求める人物像</span></h3>\n                    </div>\n                    <div class=\"block reveal fade-in-up\">\n                    <div class=\"line line__001 animation-trigger mb\" data-animation=\"https://a-tic.co.jp/recruit/src/json/r-line1_mb.json\"></div>\n                      <div class=\"line line__001 animation-trigger pc\" data-animation=\"https://a-tic.co.jp/recruit/src/json/r-line1.json\"></div>\n                      <div class=\"person__pickup\">\n                        <h4>一言人財像</h4>\n                        <p><span class=\"bold\">自我の壁</span>を突破し、<br><span class=\"bold\">できることを分かち合う</span>という<br class=\"mb\">経験を通じて、<br><span class=\"bold\">目的理解</span>と<span class=\"bold\">課題解決力</span>を発揮し、<br><span class=\"bold\">セルフマネジメント</span>と<br class=\"mb\"><span class=\"bold\">協力姿勢</span>を持ち、<br class=\"pc\"><span class=\"bold\">素直</span>で<br class=\"mb\"><span class=\"bold\">チャレンジング</span>な人財</p>\n                      </div>\n                      <div class=\"line line__002 animation-trigger mb\" data-animation=\"https://a-tic.co.jp/recruit/src/json/r-line2_mb.json\"></div>\n                      <div class=\"line line__002 animation-trigger pc\" data-animation=\"https://a-tic.co.jp/recruit/src/json/r-line2.json\"></div>\n                    </div>\n\n                    <div class=\"other\">\n\n                      <div class=\"person__other reveal fade-in-up\">\n                        <div class=\"contents\">\n                          <div class=\"item\">\n                            <h4 class=\"head\">\n                              <span>個人に求めるもの</span>\n                            </h4>\n                            <div class=\"list\">\n                              <dl>\n                                <dt>\n                                  <span class=\"txt-stroke en -BoldItalic\">01</span>\n                                  <div class=\"ttl\">\n                                    <p class=\"ttl_ja\">専門スキル</p>\n                                    <p class=\"ttl_en\">Specialized skills</p>\n                                  </div>\n                                </dt>\n                                <dd>自分の仕事への情熱を見出し、自己成長を遂げ、必要な周辺知識を補完しながら、専門分野で実績を築く力を求めます。</dd>\n                              </dl>\n                              <dl>\n                                <dt>\n                                  <span class=\"txt-stroke en -BoldItalic\">02</span>\n                                  <div class=\"ttl\">\n                                    <p class=\"ttl_ja\">自律</p>\n                                    <p class=\"ttl_en\">Self-reliance</p>\n                                  </div>\n                                </dt>\n                                <dd>自己信頼を持ち、自らビジョンを描き、逆算思考でプロセスを設計し、ビジョン達成のために決めたことをやりきる力を求めます。</dd>\n                              </dl>\n                              <dl>\n                                <dt>\n                                  <span class=\"txt-stroke en -BoldItalic\">03</span>\n                                  <div class=\"ttl\">\n                                    <p class=\"ttl_ja\">コラボレーション</p>\n                                    <p class=\"ttl_en\">Collaboration</p>\n                                  </div>\n                                </dt>\n                                <dd>総合建設コンサルタント企業の一員として、異なる視点や専門知識を持つ個々が協力し、集合知でお客様の課題を解決する力を求めます。</dd>\n                              </dl>\n                              <dl>\n                                <dt>\n                                  <span class=\"txt-stroke en -BoldItalic\">04</span>\n                                  <div class=\"ttl\">\n                                    <p class=\"ttl_ja\">協働・協創</p>\n                                    <p class=\"ttl_en\">Collaborative Innovation</p>\n                                  </div>\n                                </dt>\n                                <dd>周囲の力を活かし協力し合い、個々の能力や状況を考慮しつつ、共に働き新しい価値を創造することで社内貢献を目指す力を求めます。</dd>\n                              </dl>\n                            </div>\n                          </div>\n                          <div class=\"item\">\n                            <h4 class=\"head\">\n                              <span>会社が提供するもの</span>\n                            </h4>\n                            <div class=\"list\">\n                              <dl>\n                                <dt>\n                                  <span class=\"txt-stroke en -BoldItalic\">01</span>\n                                  <p class=\"ttl_ja\">専門スキル<span class=\"small\">と</span><br class=\"mb\">内発的な学び<span class=\"small\">の機会拡充</span></p>\n                                </dt>\n                                <dd>内発的な、外部研修の参加、社内勉強会の開催支援、学習環境の整備を通じて、社員の成長を包括的に支援し、企業全体の競争力を高めます。</dd>\n                              </dl>\n                              <dl>\n                                <dt>\n                                  <span class=\"txt-stroke en -BoldItalic\">02</span>\n                                  <p class=\"ttl_ja\">コラボレーション<span class=\"small\">と</span><br class=\"mb\">協働・協創<span class=\"small\">を</span><br class=\"pc\">賞賛する文化<span class=\"small\">の醸成</span></p>\n                                <dd>コラボレーションや協働・協創の活動を支援し、その力を発揮した個人やチームに定期的に表彰や感謝の言葉を贈る文化を醸成していきます。</dd>\n                              </dl>\n                              <dl>\n                                <dt>\n                                  <span class=\"txt-stroke en -BoldItalic\">03</span>\n                                  <p class=\"ttl_ja\">成果<span class=\"small\">に応じた</span><br class=\"mb\">正当な報酬と評価<span class=\"small\">の推進</span></p>\n                                </dt>\n                                <dd>会社が期待する役割や成果に対して活躍した個々人に、公平に報酬で報いる仕組みを推進します。</dd>\n                              </dl>\n                            </div>\n                          </div>\n                        </div>\n\n                      </div>\n                    </div>\n                </section>\n                <section class=\"p-recruit__sec career w1200\" id=\"career\">\n                    <div class=\"c-head\">\n                        <h3 class=\"reveal fade-in-up\"><span>キャリアパス</span></h3>\n                    </div>\n                    <div class=\"block soon reveal fade-in-up\">\n                      <p class=\"coming_soon\">Coming soon</p>\n                    </div>\n                </section>\n                <section class=\"p-recruit__sec benefits\">\n                    <div class=\"c-head\">\n                        <h3 class=\"reveal fade-in-up\"><span>福利厚生</span></h3>\n                    </div>\n                    <div class=\"top_text_wrap reveal fade-in-up\">\n                      <h4 class=\"benefits_title\">法定福利</h4>\n                      <p>健康保険／厚生年金／労災・雇用保険</p>\n                    </div>\n                    <div class=\"benefits__block reveal fade-in-up w1200\">\n                      <h4 class=\"benefits_title\">法定外福利</h4>\n                      <div class=\"contents\">\n                        <div class=\"item\">\n                          <h4 class=\"head\">\n                            <span>ライフサポート</span>\n                          </h4>\n                          <ul>\n                            <li>U・Iターン支援<br><span class=\"small\">入社に伴う転居費用や赴任旅費を会社が負担します</span></li>\n                            <li>育児支援・託児所あり</li>\n                            <li>時短勤務制度あり</li>\n                            <li>星野リゾート・トマム会員権利用可</li>\n                            <li>さぽーとさっぽろ加入<br><span class=\"small\">契約保養施設、提携スポーツクラブ、<br>各種チケット割引など</span></li>\n                          </ul>\n                        </div>\n                        <div class=\"item\">\n                          <h4 class=\"head\">\n                            <span>各種手当・慶弔関係</span>\n                          </h4>\n                          <ul>\n                            <li>資格取得支援・手当</span></li>\n                            <li>役職手当</li>\n                            <li>資格手当（社内規定あり）</li>\n                            <li>家族手当<br><span class=\"small\">扶養家族1人目：月5,000円、<br>2人目以降：月2,000円</span></li>\n                            <li>各種慶弔金</li>\n                            <li>退職金</li>\n                          </ul>\n                        </div>\n                        <div class=\"item\">\n                          <h4 class=\"head\">\n                            <span>その他</span>\n                          </h4>\n                          <ul>\n                            <li>親睦会</li>\n                            <li>同好会</li>\n                            <li>フリーアドレス</li>\n                            <li>社内フリードリンクあり<br><span class=\"small\">コーヒーメーカー完備</span></li>\n                            <li>年間休日120日以上</li>\n                            <li>各種研修制度</li>\n                          </ul>\n                        </div>\n                      </div>\n                    </div>\n                </section>\n                <section class=\"p-recruit__sec description\" id=\"description\">\n                    <div class=\"c-head\">\n                        <h3 class=\"reveal fade-in-up\"><span>募集要項</span></h3>\n                    </div>\n                    <div class=\"flex reveal fade-in-up\">\n                        <a href=\"\" class=\"c-btn --bgWhite h-ani\" target=\"_blank\"><span>新卒採用<small>(外部サイト)</small></span></a>\n                        <a href=\"https://a-tic.co.jp/recruit/recruit-career\" class=\"c-btn --bgWhite h-ani\"><span>キャリア採用</span></a>\n                    </div>\n                </section>\n                <div class=\"p-recruit__sec entry\"><a href=\"https://a-tic.co.jp/recruit/entry/\" class=\"h-ani\"><span class=\"en -BoldItalic\">ENTRY</span></a></div>\n            </div>\n        </main>\n        <footer class=\"l-footer relative\">\n            <div id=\"page-top\" class=\"hide\"><a href=\"#\"><img src=\"https://a-tic.co.jp/recruit/src/img/common/to-top-btn.svg\"></a></div>\n            <