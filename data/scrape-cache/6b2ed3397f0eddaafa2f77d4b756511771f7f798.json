>\r\n\r\n    <section>\r\n        <h2 class=\"heading heading-m heading-border2\">取り組み</h2>\r\n        <div class=\"col\">\r\n            <ul class=\"list\">\r\n                <li class=\"list-item\">育児・介護との両立を支援する制度と取組みを実施。</li>\r\n                <li class=\"list-item\">テレワーク勤務制度を導入し、多様な働き方へ対応。</li>\r\n                <li class=\"list-item\">\r\n                    加えて、休み方改革を推進するため年間計画年休日の設定(8日)、アニバーサリー・ワークライフバランス機会での<br>年休取得推進、時間外自粛日(ふれあいの日、イベントライトダウンの日)を展開、時間単位の年休取得制度の導入\r\n                </li>\r\n            </ul>\r\n        </div>\r\n    </section>\r\n\r\n    <section class=\"mt-100\">\r\n        <h2 class=\"heading heading-m heading-border2\">魅力ある会社づくりに向けた「働きがい」「働きやすさ」「心身の健康」</h2>\r\n        <div class=\"workStyleReform\">\r\n            <div class=\"workStyleReform-layout\">\r\n                <div class=\"workStyleReform-top\">\r\n                    <div class=\"workStyleReform-circle\">\r\n                        <div class=\"circle\">\r\n                            <h3 class=\"circle-heading\">働きがい<span>＜個の成長・社会への貢献＞</span></h3>\r\n                            <div class=\"workStyleReform-content\">\r\n                                <div class=\"circle-label\">会社・上司・職場の満足度</div>\r\n                                <div class=\"circle-label\">仕事への満足度</div>\r\n                                <ul class=\"list\">\r\n                                    <li class=\"list-item\">評価制度</li>\r\n                                    <li class=\"list-item\">表彰制度</li>\r\n                                </ul>\r\n                            </div>\r\n                        </div>\r\n                    </div>\r\n                    <div class=\"workStyleReform-circle\">\r\n                        <div class=\"circle\">\r\n                            <h3 class=\"circle-heading\">働きやすさの<br>実感</h3>\r\n                            <div class=\"workStyleReform-content\">\r\n                                <div class=\"circle-label\">仕事とライフイベントとの両立</div>\r\n                                <div class=\"circle-label\">ダイバーシティ&インクルージョン</div>\r\n                                <div class=\"circle-label\">仕事とプライベートの相互充実</div>\r\n                            </div>\r\n                        </div>\r\n                    </div>\r\n                    <div class=\"workStyleReform-attempt\">\r\n                        <div class=\"attempt-card\">\r\n                            <div class=\"attempt-heading\">職場環境への満足度</div>\r\n                            <p>毎年職場環境アンケートによる実態把握</p>\r\n                        </div>\r\n                        <div class=\"attempt-card\">\r\n                            <div class=\"attempt-heading\">仕事の質と量の適正</div>\r\n                            <p>プロジェクト会議</p>\r\n                        </div>\r\n                        <div class=\"attempt-card\">\r\n                            <div class=\"attempt-heading\">労働時間の適正化<br class=\"display-pc-none\">・<br class=\"display-pc-none\">メリハリある就業</div>\r\n                            <p>労働時間等設定改善委員会</p>\r\n                        </div>\r\n                    </div>\r\n                    <div class=\"workStyleReform-circle\">\r\n                        <div class=\"circle\">\r\n                            <h3 class=\"circle-heading\">心身の健康</h3>\r\n                            <div class=\"workStyleReform-content\">\r\n                                <div class=\"circle-label\">４つのケア</div>\r\n                                <div class=\"circle-label\">人間ドック等の受診</div>\r\n                                <div class=\"circle-label\">健康施策の展開</div>\r\n                            </div>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n                <div class=\"workStyleReform-bottom\">\r\n                    <div class=\"workStyleReform-purpose\">心身の健康維持・増進</div>\r\n                    <!-- <div class=\"workStyleReform-purpose\">社内・社外から<br class=\"display-pc-none\">見た会社の魅力</div> -->\r\n                </div>\r\n            </div>\r\n       