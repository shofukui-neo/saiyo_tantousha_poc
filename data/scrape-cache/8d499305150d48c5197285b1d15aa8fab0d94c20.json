ylesheet\" href=\"/assets/css/scss/pages/common.css\">\n  <link rel=\"stylesheet\" href=\"/assets/css/scss/pages/detail.css\">\n</head>\n\n<body>\n  <div class=\"wrap\">\n    <div class=\"l-content\">\n      <!-- l-header -->\n      <header class=\"l-header js-header\">\n        <div class=\"l-header-logo\">\n          <h1 class=\"l-header-logo__ttl\">\n            <a class=\"-link\" href=\"/\">\n              <img src=\"/assets/img/common/logo.svg\" alt=\"TOYOTA Rent a Car\">\n            </a>\n          </h1>\n        </div>\n        <div id=\"js-drawermenu\" class=\"l-header-area\">\n          <ul class=\"l-header-area__list\">\n            <li class=\"l-header-area__list-item\"><a class=\"-link\" href=\"/\">ホーム</a></li>\n            <li class=\"l-header-area__list-item\"><a class=\"-link\" href=\"/company/\">会社概要</a></li>\n            <div class=\"l-header-area__list-item l-header-area__list-item--linkaccd\">\n              <a class=\"-link\" href=\"/recruit/\">採用情報</a>\n              <span class=\"l-header-area__list-item--linkaccd-btn js-accd\"></span>\n              <ul class=\"l-header-area__list-ul\" style=\"display:none;\">\n                <li class=\"l-header-area__list-section l-header-area__list-section--mt\"><a href=\"/recruit/interview/\">-\n                    社員インタビュー</a></li>\n                <li class=\"l-header-area__list-section\"><a href=\"/recruit/data/\">- 数字で見る</a></li>\n                <li class=\"l-header-area__list-section\"><a href=\"/recruit/training/\">- 研修制度</a></li>\n                <li class=\"l-header-area__list-section\"><a href=\"/recruit/faq/\">- よくあるご質問</a></li>\n                <li class=\"l-header-area__list-section\"><a href=\"/recruit/description/\">- 募集要項</a></li>\n              </ul>\n            </div>\n          </ul>\n          <div class=\"l-header-area__targetbox\">\n            <div class=\"l-header-area__shop\">\n              <a href=\"/shop/\"><span class=\"-icon\">店舗を探す</span></a>\n            </div>\n            <div class=\"l-header-area__info\">\n              <a href=\"https://rent.toyota.co.jp/static/guide/\" target=\"_blank\"><span class=\"-icon\">ご利用案内</span></a>\n            </div>\n            <div class=\"l-header-area__reservation\">\n              <a href=\"https://rent.toyota.co.jp/\" target=\"_blank\"><span class=\"-icon\">インターネット予約</span></a>\n            </div>\n          </div>\n        </div>\n        <div id=\"js-btnTrigger\" class=\"js-navbtn l-header-humbtn\">\n          <span class=\"l-header-humbtn__line\">\n            <!--btn-->\n          </span>\n          <span class=\"l-header-humbtn__line\">\n            <!--btn-->\n          </span>\n        </div>\n      </header>\n      <!-- l-snsbox -->\n      <div class=\"l-snsbox\">\n        <div class=\"l-snsbox-block l-snsbox-block--01\">\n          <a href=\"/recruit/\">\n            <p class=\"-txt\">採用情報</p>\n          </a>\n        </div>\n        <div class=\"l-snsbox-block l-snsbox-block--02\">\n          <a href=\"https://www.instagram.com/toyota_nishishikoku/\" target=\"_blank\">\n            <p class=\"-txt\">インスタグラム</p>\n          </a>\n        </div>\n      </div>\n      <div class=\"l-content-main\">\n        <section class=\"c-submv\">\n          <div class=\"c-submv-bg\"></div>\n          <div class=\"inner c-submv--inner\">\n            <div class=\"c-submv-img c-submv-img--interview03\">\n              <div class=\"c-submv-img__txtbox\">\n                <p class=\"-ttl\">interview #03</p>\n                <p class=\"-txt\">小さな気配りを大切に<br>チームでお客様をお迎えする</p>\n                <p class=\"-info\">レンタル部 / 2015年入社</p>\n              </div>\n            </div>\n            <div class=\"c-submv-area flex is-between\">\n              <h1 class=\"-ttl\">【レンタル部】竹内 くるみ</h1>\n              <div class=\"-breadcrumbs\">\n                <ul class=\"flex\">\n                  <li><a href=\"/\">トップ</a></li>\n                  <li><a href=\"/recruit/\">採用情報</a></li>\n                  <li><a href=\"/recruit/interview/\">インタビュー一覧</a></li>\n                  <li>竹内 くるみ</li>\n                </ul>\n              </div>\n            </div>\n          </div>\n        </section>\n\n        <!-- p-detail-block -->\n        <section class=\"p-detail-block\">\n          <p class=\"p-detail-block__bgttl\">Question 01</p>\n          <div class=\"inner p-detail-block--inner\">\n            <div class=\"p-detail-block__area flex js-anime\">\n              <div class=\"p-detail-block__area-img\">\n                <picture>\n                  <source srcset=\"/assets/img/detail/detail03-01-sp.jpg\" media=\"(max-width: 768px)\">\n                  <img src=\"/assets/img/detail/detail03-01-pc.jpg\">\n                </picture>\n              </div>\n              <div class=\"p-detail-block__area-txtbox\">\n                <div class=\"-group\">\n                  <p class=\"-group-en\">Q1-Reason for Joining</p>\n                  <h2 class=\"-group-question\">入社の決め手は何でしたか？</h2>\n                  <p class=\"-group-answer\">先生のすすめがきっかけ<br>明るい職場の雰囲気に惹かれました</p>\n                </div>\n                <p class=\"-txt\">\n                  高校3年生のとき、就職は決めていたけれど具体的な職種までは考えていませんでした。そんなときに先生から「すごくいい会社があるよ」と紹介されたのがきっかけです。見学に行くと、若いスタッフも多くて、雰囲気がとても明るくて。「ここなら楽しく働けそう」と感じました。最初は何となくのきっかけだったけど、今ではこの会社を選んで本当に良かったと思っています。\n                </p>\n              </div>\n            </div>\n          </div>\n        </section>\n\n        <!-- p-detail-block -->\n        <section class=\"p-detail-block p-detail-block--pattern02\">\n          <p class=\"p-detail-block__bgttl\">Question 02</p>\n          <div class=\"inner p-detail-block--inner\">\n            <div class=\"p-detail-block__area flex js-anime\">\n              <div class=\"p-detail-block__area-img\">\n                <picture>\n                  <source srcset=\"/assets/img/detail/detail03-02-sp.jpg\" media=\"(max-width: 768px)\">\n                  <img src=\"/assets/img/detail/detail03-02-pc.jpg\">\n                </picture>\n              </div>\n              <div class=\"p-detail-block__area-txtbox\">\n                <div class=\"-group\">\n                  <p class=\"-group-en\">Q2-Job description</p>\n                  <h2 class=\"-group-question\">現在の仕事内容と、仕事に対する姿勢について教えてください。</h2>\n                  <p class=\"-group-answer\">お客様に気持ちよく利用していただける店舗づくりを目指して</p>\n                </div>\n                <p class=\"-txt\">\n                  現在は店舗の店長として、スタッフ全体をまとめながら、日々の接客や店舗運営を行っています。お客様に気持ちよくご利用いただけるよう、清潔で明るい雰囲気づくりを大切にしています。観光やビジネスなど、さまざまな目的でご来店されるお客様が「またここを利用したい」と思っていただけるよう、スタッフ一同でチームワークを意識して取り組んでいます。店舗全体で大切にしているのは、お客様を全員でお迎えするという気持ちです。誰かが入店されたら全員が立ち上がって「いらっしゃいませ」と声をかける。小さなことですが、そういうところで印象は変わると思っています。お客様に安心して利用してもらえるよう、スタッフ同士の連携も欠かさず、常にチームとして動くことを意識しています。\n                </p>\n              </div>\n            </div>\n          </div>\n        </section>\n\n        <!-- p-detail-layout -->\n        <section class=\"p-detail-layout js-anime\">\n          <div class=\"p-detail-layout__img\">\n            <picture>\n              <source srcset=\"/assets/img/detail/detail03-03-sp.jpg\" media=\"(max-width: 768px)\">\n              <img src=\"/assets/img/detail/detail03-03-pc.jpg\">\n            </picture>\n          </div>\n          <div class=\"p-detail-layout__bgttl\">Question 03</div>\n          <div class=\"inner\">\n            <div class=\"p-detail-layout__txtbox\">\n              <div class=\"-group\">\n                <p class=\"-group-en\">Q3-Why This Company</p>\n                <h2 class=\"-group-question\">会社に感じる魅力を聞かせてください。</h2>\n                <p class=\"-group-answer\">年齢関係なく支え合える、あたたかい職場環境</p>\n              </div>\n              <p class=\"-txt\">\n                年齢や立場に関係なく、誰とでも話しやすく、相談しやすい雰囲気があるのが魅力です。困ったときや悩んでいるときも、上司や同僚がすぐに話を聞いてくれるので、とても心強いです。お互いにサポートし合える関係性が自然にできていて、仕事のモチベーションにもつながっています。人の温かさを一番感じられる会社だと思います。\n              </p>\n            </div>\n          </div>\n        </section>\n\n        <!-- p-detail-block -->\n        <section class=\"p-detail-block p-detail-block--pattern03\">\n          <p class=\"p-detail-block__bgttl\">Question 04</p>\n          <div class=\"inner p-detail-block--inner\">\n            <div class=\"p-detail-block__area flex js-anime\">\n              <div class=\"p-detail-block__area-img\">\n                <picture>\n                  <source srcset=\"/assets/img/detail/detail03-04-sp.jpg\" media=\"(max-width: 768px)\">\n                  <img src=\"/assets/img/detail/detail03-04-pc.jpg\">\n                </picture>\n              </div>\n              <div class=\"p-detail-block__area-txtbox\">\n                <div class=\"-group\">\n                  <p class=\"-group-en\">Q4-Future Goals</p>\n                  <h2 class=\"-group-question\">これからチャレンジしたいことや、<br class=\"pc\">将来の目標は？</h2>\n                  <p class=\"-group-answer\">スタッフ一人ひとりが“ここで働けて良かった”と<br class=\"pc\">思える職場へ</p>\n                </div>\n                <p class=\"-txt\">\n                  店長として一番意識しているのは、スタッフ一人ひとりがやりがいを持って働ける環境をつくることです。名前を呼んで声をかけたり、ちょっとした会話をすることで距離が縮まり、気持ちよく働けると思っています。「このお店で働けて良かった」と思ってもらえるような職場にしたい。そのために、日々のコミュニケーションを大切にしていきたいです。\n                </p>\n              </div>\n            </div>\n          </div>\n        </section>\n\n        <!-- p-detail-btn -->\n        <div class=\"p-detail-btn\">\n          <div class=\"c-btn01 p-detail-btn--btn\">\n            <a href=\"/recruit/interview/\">\n              <p class=\"-txt\">社員インタビュー一覧</p>\n            </a>\n          </div>\n        </div>\n\n\n\n        <!-- c-recruit-layout -->\n        <section class=\"c-recruit-layout\">\n          <div class=\"inner c-recruit-layout--inner\">\n            <div class=\"c-recruit-layout__area flex\">\n              <div class=\"c-recruit-layout__area-left\">\n                <div class=\"c-ttl02box c-recruit-layout__area-left--ttl\">\n                  <h2 class=\"c-ttl02 js-anime\">recruit<span class=\"-jp\">採用情報</span></h2>\n                </div>\n                <p class=\"-catch\">地域と共に、人も育つ。<br>トヨタレンタリース西四国の<br><span class=\"-color\">未来</sapn>を一緒に。</p>\n                <p class=\"c-recruit-layout-txt\">\n                  愛媛・高知のあたたかさそのままに、職場も明るく居心地の良い環境が自慢です。役職や年齢に関係なく、意見を出し合い、助け合える関係性が根づいています。<br>地域の方々に寄り添いながら、自分らしくのびのびと働ける職場で、一緒に成長していきませんか？\n                </p>\n                <div class=\"c-btn01 c-recruit-layout--btn\">\n                  <a href=\"/recruit/\">\n                    <p class=\"-txt\">採用情報を見る</p>\n                  </a>\n                </div>\n              </div>\n              <div class=\"c-recruit-layout__area-right\">\n                <div class=\"-bgicon\">\n                  <img src=\"/assets/img/top/recruit-bg.png\">\n                </div>\n                <div class=\"-imgbox01 js-anime\">\n                  <div class=\"-in js-pararax\">\n                    <img src=\"/assets/img/top/recruit-img01.jpg\">\n                  </div>\n                </div>\n                <div class=\"-imgbox02 js-anime\">\n                  <div class=\"-in js-pararax\">\n                    <img src=\"/assets/img/top/recruit-img02.jpg\">\n                  </div>\n                </div>\n                <div class=\"-imgbox03 js-anime\">\n                  <div class=\"-in js-pararax\">\n                    <img src=\"/assets/img/top/recruit-img03.jpg\">\n                  </div>\n                </div>\n              </div>\n            </div>\n          </div>\n          <p class=\"c-recruit-layout__icon js-anime\">\n            <img src=\"/assets/img/top/recruitsec-icon.png\">\n          </p>\n        </section>\n        <div class=\"c-link-area\">\n          <div class=\"inner c-link-area--inner\">\n            <div class=\"c-link-area__block flex\">\n              <!-- c-link-area__block-item -->\n              <div class=\"c-link-area__block-item\">\n                <a class=\"-link\" href=\"/company/\">\n                  <div class=\"-img -img01\"></div>\n                  <div class=\"-txtbox\">\n                    <h3 class=\"-ttl\"><span class=\"-en\">Company</span>会社概要</h3>\n                  </div>\n                  <div class=\"-arrow\"></div>\n                </a>\n              </div>\n              <!-- c-link-area__block-item -->\n              <div class=\"c-link-area__block-item\">\n                <a class=\"-link\" href=\"/recruit/\">\n                  <div class=\"-img -img02\"></div>\n                  <div class=\"-txtbox\">\n                    <h3 class=\"-ttl\"><span class=\"-en\">Recruit</span>採用情報</h3>\n                  </div>\n                  <div class=\"-arrow\"></div>\n                </a>\n              </div>\n              <!-- c-link-area__block-item -->\n              <div class=\"c-link-area__block-item\">\n                <a class=\"-link\" href=\"/recruit/data/\">\n                  <div class=\"-img -img03\"></div>\n                  <div class=\"-txtbox\">\n                    <h3 class=\"-ttl\"><span class=\"-en\">Date</span>数字で見る</h3>\n                  </div>\n                  <div class=\"-arrow\"></div>\n                </a>\n              </div>\n              <!-- c-link-area__block-item -->\n              <div class=\"c-link-area__block-item\">\n                <a class=\"-link\" href=\"/recruit/interview/\">\n                  <div class=\"-img -img04\"></div>\n                  <div class=\"-txtbox\">\n                    <h3 class=\"-ttl\"><span class=\"-en\">Interview</span>社員インタビュー一覧</h3>\n                  </div>\n                  <div class=\"-arrow\"></div>\n                </a>\n              </div>\n              <!-- c-link-area__block-item -->\n              <div class=\"c-link-area__block-item\">\n                <a class=\"-link\" href=\"/recruit/training/\">\n                  <div class=\"-img -img05\"></div>\n                  <div class=\"-txtbox\">\n                    <h3 class=\"-ttl\"><span class=\"-en\">Training</span>研修制度</h3>\n                  </div>\n                  <div class=\"-arrow\"></div>\n                </a>\n              </div>\n\n            </div>\n          </div>\n        </div>\n        <!-- l-footer -->\n        <footer class=\"l-footer\">\n          <div class=\"l-footer-area\">\n            <div class=\"l-footer-area__pagetop\">\n              <a href=\"#\">\n                <p class=\"l-footer-area__pagetop-txt\">page top</p>\n              </a>\n            </div>\n            <div class=\"l-footer-area__block inner\">\n              <div class=\"l-footer-area__block-top flex is-between\">\n                <div class=\"-left flex\">\n                  <div class=\"-logo\">\n                    <a href=\"/\">\n                      <img src=\"/assets/img/common/f-logo.svg\">\n                    </a>\n                  </div>\n                  <p class=\"-access\">株式会社トヨタレンタリース西四国<br>〒791-8042 松山市南吉田町2750-12</p>\n                </div>\n                <div class=\"-insta\">\n                  <a href=\"https://www.instagram.com/toyota_nishishikoku/\" target=\"_blank\"><img\n                      src=\"/assets/img/common/insta-icon-wh.svg\"></a>\n                </div>\n              </div>\n              <div class=\"l-footer-area__block-list\">\n                <ul class=\"flex\">\n                  <li><a href=\"/csr/\">CSR基本方針</a></li>\n                  <li><a href=\"/pp/\">プライバシーポリシー</a></li>\n                  <li><a href=\"/solicitation/\">勧誘方針</a></li>\n                  <li><a href=\"/antisocial/\">暴力団等反社会的勢力排除宣言</a></li>\n                  <li><a href=\"/company/\">会社概要</a></li>\n                </ul>\n              </div>\n              <div class=\"l-footer-area__block-shop flex\">\n                <p class=\"-ttl\">店舗を探す</p>\n                <ul class=\"flex\">\n                  <li><a href=\"/shop/matsuyama.html\">松山店</a></li>\n                  <li><a href=\"/shop/matsuyama-port.html\">松山観光港店</a></li>\n                  <li><a href=\"/shop/matsuyama-ap.html\">松山空港店</a></li>\n                  <li><a href=\"/shop/imabari.html\">今治店</a></li>\n                  <li><a href=\"/shop/saijo-st.html\">JR伊予西条駅店</a></li>\n                  <li><a href=\"/shop/niihama-st.html\">新居浜駅前店</a></li>\n                  <li><a href=\"/shop/iyomishima-st.html\">JR伊予三島駅店</a></li>\n                  <li><a href=\"/shop/yawatahama-st.html\">JR八幡浜駅店</a></li>\n                  <li><a href=\"/shop/uwajima-st.html\">JR宇和島駅店</a></li>\n                  <li><a href=\"/shop/kochi-st.html\">高知駅前店</a></li>\n                  <li><a href=\"/shop/kochi-ap.html\">高知空港店</a></li>\n                  <li><a href=\"/shop/nakamura.html\">中村店</a></li>\n                </ul>\n              </div>\n              <div class=\"l-footer-area__block-recruit flex\">\n                <p class=\"-ttl\">採用情報</p>\n                <ul class=\"flex\">\n                  <li><a href=\"/recruit/interview/\">社員インタビュー</a></li>\n                  <li><a href=\"/recruit/data/\">数字で見る</a></li>\n                  <li><a href=\"/recruit/training/\">研修制度</a></li>\n                  <li><a href=\"/recruit/faq/\">よくあるご質問</a></li>\n                  <li><a href=\"/recruit/description/\">募集要項</a></li>\n                </ul>\n              </div>\n            </div>\n          </div>\n          <p class=\"l-footer-area__copy\">&copy; 2025, 株式会社トヨタレンタリース西四国</p>\n        </footer>\n      </div>\n    </div>\n    <script src=\"/assets/js/jquery-3.6.0.min.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/simple-parallax-js@5.6.2/dist/simpleParallax.min.js\"></script>\n    <script src=\"/assets/js/common.js\"></script>\n\n  </div>\n\n</body>\n\n</html>","finalUrl":"http://www.r-ehm.co.jp/recruit/interview/interview03/","rendered":false,"_cachedAt":"2026-06-23T16:27:37.051Z"}