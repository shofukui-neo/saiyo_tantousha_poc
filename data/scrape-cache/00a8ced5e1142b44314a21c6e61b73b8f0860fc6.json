{"url":"http://www.chugai-af.co.jp","html":"<!DOCTYPE html>\n<html lang=\"ja\" prefix=\"og: http://ogp.me/ns#\">\n\n<head>\n<!-- Google Tag Manager -->\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start': new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\n  j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n  })(window,document,'script','dataLayer','GTM-WK85SH6');</script>\n  <!-- End Google Tag Manager -->\n  <!-- Yahoo Tag -->\n  <script async src=\"https://s.yimg.jp/images/listing/tool/cv/ytag.js\"></script>\n  <script>\n  window.yjDataLayer = window.yjDataLayer || [];\n  function ytag() { yjDataLayer.push(arguments); }\n  ytag({\"type\":\"ycl_cookie\"});\n  ytag({\"type\":\"ycl_cookie_extended\"});\n  </script>\n  <!-- End Yahoo Tag -->\n  <meta charset=\"utf-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1, shrink-to-fit=no\">\n  <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n  <meta name=\"format-detection\" content=\"telephone=no\">\n  <meta name=\"skype_toolbar\" content=\"skype_toolbar_parser_compatible\">\n  <title>中外商工株式会社</title>\n  <meta name=\"description\" content=\"中外商工株式会社は、建築物や構造物の長寿命化を実現する機能性塗料のメーカーです。創業以来、メーカー責任施工を信条としており、製品を知り尽くす技術者が現場で確かな施工を行い、マンションや工場、施設などの改修・保全をご支援します。\">\n  <meta name=\"keywords\" content=\"中外商工,マンション大規模修繕,大規模改修,修繕,資産価値,外壁,塗装,リノベーション,建物診断,お問い合わせ,見積,RAM\">\n  <link rel=\"shortcut icon\" type=\"image/x-icon\" href=\"/img/common/favicon.ico\">\n  <link rel=\"apple-touch-icon-precomposed\" sizes=\"192x192\" href=\"/img/common/touch-icon.png\">\n  <!-- search setting START -->\n  <meta name=\"robots\" content=\"index,follow\"><!-- すべての検索エンジン用 -->\n  <meta name=\"googlebot\" content=\"index,follow\"><!-- Google用 -->\n  <!-- search setting END -->\n  <!-- style START -->\n  <link rel=\"stylesheet\" href=\"/css/common/base.css\">\n  <link href=\"https://fonts.googleapis.com/earlyaccess/notosansjapanese.css\" rel=\"stylesheet\">\n  <!-- style END -->\n</head>\n\n<body id=\"anc_pagetop\" class=\"newtop\">\n  <!-- Google Tag Manager (noscript) -->\n  <noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-WK85SH6\" height=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n  <!-- End Google Tag Manager (noscript) -->\n\n  <!-- wrapper START -->\n  <!-- toppage -->\n  <div id=\"toppage\" class=\"wrapper\">\n    <header class=\"header\" role=\"banner\">\n  <div class=\"header__in\">\n    <h1 class=\"header-logo\"><a href=\"/\" class=\"inner\"><img src=\"/img/common/logo2.svg\" alt=\"中外商工株式会社\"></a></h1>\n    <div class=\"header-contact\">\n      <div class=\"header-contact__in\">\n        <div class=\"header-contact__item\">\n          <div class=\"header-contact-tel\">\n            <a href=\"tel:0120957096\" class=\"header-contact-tel__in\"　onclick=\"ga('send','event','button','click','tel_header');\">\n              <p class=\"header-contact-tel__title\">お電話で<br class=\"spbr\">お問い合わせ<span class=\"pctext\">・見積相談</span></p>\n              <p class=\"header-contact-tel__number\"><img src=\"/img/common/img_tel_number_01.svg\" alt=\"0120-957-096\"></p>\n            </a>\n            <p class=\"header-contact-tel__description\">受付時間／月曜日から金曜日の 8：30〜17：30（休日を除く）</p>\n          </div>\n        </div>\n        <div class=\"header-contact__item\">\n          <a href=\"/contact/\" target=\"_blank\" class=\"header-contact-mail\"　onclick=\"ga('send','event','link','click','contact_fixed');\">\n            <div class=\"header-contact-mail__in\">\n              <p class=\"header-contact-mail__title\">メールで<br>お問い合わせ<span class=\"pctext\">・<br>見積相談</span></p>\n            </div>\n          </a>\n        </div>\n        <button id=\"js-menuTrigger\" class=\"header-menu-button\" type=\"button\" aria-label=\"メニューボタン\">\n          <span class=\"header-menu-button__bar\" aria-hidden=\"true\"></span>\n          <span class=\"header-menu-button__text\">MENU</span>\n        </button>\n      </div>\n    </div><!-- /header-contact -->\n  </div>\n</header>\n    <nav class=\"nav-global\">\n  <ul class=\"nav-global__in\">\n    <li class=\"nav-global__item\">\n      <a href=\"/daikibo-shuzen/\" class=\"nav-global__link has-child\">マンション大規模修繕</a>\n      <ul class=\"nav-global-child\">\n        <li class=\"nav-global-child__item\"><a href=\"/daikibo-shuzen/menu/\" class=\"nav-global-child__link\">部位別修繕工事<br class=\"pcbr\">メニュー</a></li>\n        <li class=\"nav-global-child__item\"><a href=\"/daikibo-shuzen/original_case/\" class=\"nav-global-child__link\">独自技術による<br class=\"pcbr\">課題解決例</a></li>\n        <li class=\"nav-global-child__item\"><a href=\"/daikibo-shuzen/construction/\" class=\"nav-global-child__link\">安心工事のお約束</a></li>\n        <li class=\"nav-global-child__item\"><a href=\"/daikibo-shuzen/flow/\" class=\"nav-global-child__link\">大規模修繕工事の流れ</a></li>\n        <li class=\"nav-global-child__item\"><a href=\"/daikibo-shuzen/case/\" class=\"nav-global-child__link\">全国の施工事例</a></li>\n        <li class=\"nav-global-child__item\"><a href=\"/daikibo-shuzen/faq/\" class=\"nav-global-child__link\">よくある質問</a></li>\n      </ul>\n    </li>\n    <li class=\"nav-global__item\">\n      <a href=\"/product/\" class=\"nav-global__link has-child\">取扱製品</a>\n      <ul class=\"nav-global-child\">\n        <li class=\"nav-global-child__item\"><a href=\"/product/floor/\" class=\"nav-global-child__link\">塗り床工事</a></li>\n        <li class=\"nav-global-child__item\"><a href=\"/product/pavement/\" class=\"nav-global-child__link\">景観工事</a></li>\n        <li class=\"nav-global-child__item\"><a href=\"/product/waterproof/\" class=\"nav-global-child__link\">防水工事</a></li>\n        <li class=\"nav-global-child__item\"><a href=\"/product/corrosion/\" class=\"nav-global-child__link\">防食工事</a></li>\n        <li class=\"nav-global-child__item\"><a href=\"/product/protection/\" class=\"nav-global-child__link\">外装保護・<br class=\"sp_none\">下地調整工事</a></li>\n        <li class=\"nav-global-child__item\"><a href=\"/product/insulation/\" class=\"nav-global-child__link\">省エネ・<br class=\"sp_none\">環境改善工事</a></li>\n        <li class=\"nav-global-child__item\"><a href=\"/product/parts/\" class=\"nav-global-child__link\">工業用パーツ</a></li>\n      </ul>\n    </li>\n    <li class=\"nav-global__item\"><a href=\"/construction/\" class=\"nav-global__link\">責任施工</a></li>\n    <li class=\"nav-global__item\"><a href=\"/development/\" class=\"nav-global__link\">技術開発・製造</a></li>\n    <li class=\"nav-global__item\"><a href=\"/office/\" class=\"nav-global__link\">事業所一覧</a></li>\n    <li class=\"nav-global__item\"><a href=\"/about/\" class=\"nav-global__link has-child\">会社概要</a>\n      <ul class=\"nav-global-child\">\n        <li class=\"nav-global-child__item\"><a href=\"/about/way/\" class=\"nav-global-child__link\">Chugai way</a></li>\n        <li class=\"nav-global-child__item\"><a href=\"/about/outline/\" class=\"nav-global-child__link\">中外商工の<br class=\"pcbr\">あゆみ</a></li>\n      </ul>\n    </li>\n    <li class=\"nav-global__item item--recruit\"><a href=\"https://recruit-chugai.com/\" target=\"_blank\" rel=\"noopener\" class=\"nav-global__link\">採用情報</a></li>\n  </ul>\n</nav>\n\n\n<nav id=\"js-menuTarget\" class=\"nav-global-sp\">\n  <ul class=\"nav-global__in\">\n    <li class=\"nav-global__item\">\n      <p href=\"/daikibo-shuzen/\" class=\"nav-global__link has-child\">マンション大規模修繕</p>\n      <ul class=\"nav-global-child\">\n        <li class=\"nav-global-child__item\"><a href=\"/daikibo-shuzen/\" class=\"nav-global-child__link\">マンション大規模修繕トップ</a>\n        </li>\n        <li class=\"nav-global-child__item\"><a href=\"/daikibo-shuzen/menu/\" class=\"nav-global-child__link\">部位別修繕工事メニュー</a>\n        </li>\n        <li class=\"nav-global-child__item\"><a href=\"/daikibo-shuzen/original_case/\" class=\"nav-global-child__link\">独自技術による<br class=\"pcbr\">課題解決例</a></li>\n        <li class=\"nav-global-child__item\"><a href=\"/daikibo-shuzen/construction/\" class=\"nav-global-child__link\">安心工事のお約束</a>\n        </li>\n        <li class=\"nav-global-child__item\">\n          <a href=\"/daikibo-shuzen/construction/management/\" class=\"nav-global-child__link child__link-inner\">徹底した品質管理</a>\n        </li>\n        <li class=\"nav-global-child__item\">\n          <a href=\"/daikibo-shuzen/construction/security/\" class=\"nav-global-child__link child__link-inner\">施工中の安全・防犯対策</a>\n        </li>\n        <li class=\"nav-global-child__item\">\n          <a href=\"/daikibo-shuzen/construction/after/\" class=\"nav-global-child__link child__link-inner\">アフターサービス</a>\n        </li>\n        <li class=\"nav-global-child__item\"><a href=\"/daikibo-shuzen/flow/\" class=\"nav-global-child__link\">大規模修繕工事の流れ</a></li>\n        <li class=\"nav-global-child__item\"><a href=\"/daikibo-shuzen/case/\" class=\"nav-global-child__link\">全国の施工事例</a></li>\n        <li class=\"nav-global-child__item\"><a href=\"/daikibo-shuzen/faq/\" class=\"nav-global-child__link\">よくある質問</a></li>\n      </ul>\n    </li>\n    <li class=\"nav-global__item\">\n      <p href=\"/product/\" class=\"nav-global__link has-child\">取扱製品</p>\n      <ul class=\"nav-global-child\">\n        <li class=\"nav-global-child__item\"><a href=\"/product/\" class=\"nav-global-child__link\">取扱製品一覧</a></li>\n        <li class=\"nav-global-child__item\"><a href=\"/product/floor/\" class=\"nav-global-child__link child__link-inner\">塗り床工事</a></li>\n        <li class=\"nav-global-child__item\"><a href=\"/product/pavement/\" class=\"nav-global-child__link child__link-inner\">景観工事</a></li>\n        <li class=\"nav-global-child__item\"><a href=\"/product/waterproof/\" class=\"nav-global-child__link child__link-inner\">防水工事</a></li>\n        <li class=\"nav-global-child__item\"><a href=\"/product/corrosion/\" class=\"nav-global-child__link child__link-inner\">防食工事</a></li>\n        <li class=\"nav-global-child__item\"><a href=\"/product/protection/\" class=\"nav-global-child__link child__link-inner\">外装保護・下地調整工事</a></li>\n        <li class=\"nav-global-child__item\"><a href=\"/product/insulation/\" class=\"nav-global-child__link child__link-inner\">省エネ・環境改善工事</a></li>\n        <li class=\"nav-global-child__item\"><a href=\"/product/parts/\" class=\"nav-global-child__link child__link-inner\">工業用パーツ</a></li>\n      </ul>\n    </li>\n    <li class=\"nav-global__item\"><a href=\"/construction/\" class=\"nav-global__link\">責任施工</a></li>\n    <li class=\"nav-global__item\"><a href=\"/development/\" class=\"nav-global__link\">技術開発・製造</a></li>\n    <li class=\"nav-global__item\"><a href=\"/office/\" class=\"nav-global__link\">事業所一覧</a></li>\n    <li class=\"nav-global__item child-open\"><a href=\"/about/\" class=\"nav-global__link\">会社概要</a>\n      <ul class=\"nav-global-child\">\n        <li class=\"nav-global-child__item\"><a href=\"/about/way/\" class=\"nav-global-child__link child__link-inner\">Chugai way</a></li>\n        <li class=\"nav-global-child__item\"><a href=\"/about/outline/\" class=\"nav-global-child__link child__link-inner\">中外商工の<br class=\"pcbr\">あゆみ</a></li>\n      </ul>\n    </li>\n    <li class=\"nav-global__item\"><a href=\"https://recruit-chugai.com/\" target=\"_new\" rel=\"noopener\" class=\"nav-global__link\">採用情報</a></li>\n  </ul>\n</nav>\n\n        <article class=\"contents top\" role=\"main\">\n          <div class=\"hero-top sp_none\">\n\n            <div class=\"hero-top-image\">\n              <video id=\"mainVideo\" class=\"pc\" autoplay muted preload=\"metadata\">\n                <source src=\"/mp4/chugai_top.mp4\" type=\"video/mp4\">\n              </video>\n            </div>\n            <a class=\"hero-top-sp__scroll js-scroll\" href=\"#area-top-reading\">\n              <img src=\"/img/common/ico_top_hero_arrow_01.svg\" alt=\"scroll\">\n            </a>\n          </div>\n\n          <div class=\"hero-top-sp pc_none\">\n            <div class=\"hero-top-image pc_none\">\n              <div class=\"hero-top-sp__txt1\">\n                <img src=\"/img/top/mv_txt01-sp.png\">\n              </div>\n              <div class=\"hero-top-sp__txt2\">\n                <img class=\"hero-top-sp__txt2-1\" src=\"/img/top/mv_txt02-sp.png\">\n                <img class=\"hero-top-sp__txt2-2\" src=\"/img/top/mv_txt03-sp.png\">\n              </div>\n            </div>\n            <a class=\"hero-top-sp__scroll js-scroll\" href=\"#area-top-reading\">\n              <img src=\"/img/common/ico_top_hero_arrow_01.svg\" alt=\"scroll\">\n            </a>\n          </div>\n\n          <section class=\"sec-top\">\n\n            <section class=\"area-top-award\">\n            \n              <figure class=\"area-top-award__image\"><img src=\"/img/common/logo_ldtech2025.png\" alt=\"環境省 LD-Tech 2025 国内最高性能の脱炭素設備・機器\"></figure>\n              <p class=\"area-top-award__catch\">低放射遮熱塗料<br class=\"pc_none\">「サーモレジンSV600」が<br><span class=\"font-sans\"><strong>2025年度LD-Tech認証</strong></span>を<br class=\"pc_none\">取得しました。</p>\n              <dl class=\"area-top-award__desc\">\n                <dt class=\"area-top-award__desc-ttl\">LD-Tech 認証とは</dt>\n                <dd class=\"area-top-award__desc-txt\">2050年のカーボンニュートラル達成に向け、エネルギー起源CO<sub>2</sub>の排出削減に最大の効果をもたらす先導的な技術 (Leading Decarbonization Technology)を環境省が認証する制度。国策として普及・導入促進を進める観点から認証製品の利用時には各種補助金をご利用いただける場合があります。</dd>\n              </dl>\n\n              <div class=\"area-top-award-item\">\n                <div class=\"item-fig\">\n                  <figure class=\"area-top-award-item__image\"><img src=\"/img/top/area-top-award.jpg\" alt=\"\"></figure>\n                </div>\n                <div class=\"item-intro\">\n                  <p class=\"area-top-award-item__txt\">炉などが外部に放出する<br>無駄な熱量を低減する<br>低放射遮熱塗料</p>\n                  <p class=\"area-top-award-item__logo\"><img src=\"/img/product/insulation/ttl_pr_main_01.svg\" alt=\"低放射遮熱塗料 サーモレジン\"></p>\n                  <div class=\"button pc_none\">\n                    <a class=\"mod-top-about-button\" href=\"/product/insulation/\"><span class=\"inner\">詳しくはこちら</span></a>\n                  </div>\n                  <a class=\"button btn-base-border sp_none\" href=\"/product/insulation/\"><span class=\"inner\">詳しくはこちら</span></a>\n                </div>\n              </div>\n              <!-- /.area-top-award-item -->\n            </section>\n            <!-- /.area-top-award -->\n\n            <div class=\"mod-news mod-news--top\">\n              <h2 class=\"mod-news__title\">最新のお知らせ</h2>\n              <ul class=\"list-news\">\n                \n                \n                  <li class=\"list-news__item\">\n                    <a href=\"https://www.chugai-af.co.jp/info/20260410.html\" class=\"list-news__link\">\n                      <div class=\"list-news__heading\">\n                        <time class=\"date\" datetime=\" 2026-04-10\">2026.04.10</time>\n                        <span class=\"icon icon-new\">NEW</span>\n                      </div>\n                      <div class=\"list-news__body\">\n                        <p class=\"title\">\n                          ゴールデンウィーク期間（4/29～5/6）の営業に関するお知らせ\n                        </p>\n                      </div>\n                    </a>\n                  </li>\n                \n                  <li class=\"list-news__item\">\n                    <a href=\"https://www.chugai-af.co.jp/info/20260409.html\" class=\"list-news__link\">\n                      <div class=\"list-news__heading\">\n                        <time class=\"date\" datetime=\" 2026-04-09\">2026.04.09</time>\n                        <span class=\"icon icon-new\">NEW</span>\n                      </div>\n                      <div class=\"list-news__body\">\n                        <p class=\"title\">\n                          健康経営優良法人2026（中小規模法人部門）に認定されました。\n                        </p>\n                      </div>\n                    </a>\n                  </li>\n                \n                  <li class=\"list-news__item\">\n                    <a href=\"https://www.chugai-af.co.jp/info/20260331.html\" class=\"list-news__link\">\n                      <div class=\"list-news__heading\">\n                        <time class=\"date\" datetime=\" 2026-03-31\">2026.03.31</time>\n                        <span class=\"icon icon-new\">NEW</span>\n                      </div>\n                      <div class=\"list-news__body\">\n                        <p class=\"title\">\n                          中東情勢に伴う当社製品の供給に関するご案内とお願い\n                        </p>\n                      </div>\n                    </a>\n                  </li>\n                \n              </ul>\n              <div class=\"mod-news__button\"><a class=\"btn-base-border-gray\" href=\"/info/\"><span class=\"inner\">お知らせ一覧はこちら</span></a></div>\n            </div>\n            <!-- /.mod-news--top -->\n\n            <section class=\"area-top-reading\">\n              <div class=\"area-top-reading__box\" id=\"area-top-reading\">\n                <div class=\"area-top-reading__txt\">\n                  <img class=\"pc_none\" src=\"/img/top/area-top-reading__txt.png\" alt=\"製・工・監一貫体制でムダを省く中外商工のマンション大規模修繕とは？\">\n                  <p class=\"sp_none\">\n                    製・工・監一貫体制でムダを省く<br>中外商工のマンション大規模修繕とは？\n                  </p>\n                </div>\n                <div class=\"button\">\n                  <a class=\"mod-top-about-button\" href=\"/daikibo-shuzen/\"><span class=\"inner\">マンション大規模修繕</span></a>\n                </div>\n              </div>\n            </section>\n\n            <section class=\"area-top-product\">\n              <h2 class=\"ttl-top-product top-ttl01\"><span class=\"inner\">私たちの製品</span></h2>\n              <div class=\"area-top-product__in\">\n                <h3 class=\"top-ttl02\">建物の床や壁を守る保護材や景観を<br class=\"pc_none\">改善する製品などをご提供</h3>\n\n                <ul class=\"area-top-product__imglist\">\n                  <li><img src=\"/img/top/product_list01.jpg\"></li>\n                  <li><img src=\"/img/top/product_list02.jpg\"></li>\n                  <li><img src=\"/img/top/product_list03.jpg\"></li>\n                  <li><img src=\"/img/top/product_list04.jpg\"></li>\n                  <li><img src=\"/img/top/product_list05.jpg\"></li>\n                  <li><img src=\"/img/top/product_list06.jpg\"></li>\n                </ul>\n                <div class=\"area-top-product__txt\">\n                  <p>中外商工は、1953年に工場や施設などの床を保護する合成樹脂塗床「アートフロアー」を開発して以来、建築物・構造物の劣化を防ぐ独自の機能性塗料製品を次々に開発してきました。現在そのラインナップは、景観舗装、防水、防食ライニング、遮熱・断熱などの分野に広がり、多様な施設の長寿命化の実現を支えています。</p>\n                </div>\n              </div>\n\n              <div class=\"button pc_none\">\n                <a class=\"mod-top-about-button\" href=\"/product/\"><span class=\"inner\">取扱製品</span></a>\n              </div>\n\n              <a class=\"button btn-base-border sp_none\" href=\"/product/\"><span class=\"inner\">取扱製品</span></a>\n            </section>\n\n            <section class=\"area-top-construction\">\n              <h2 class=\"ttl-top-construction top-ttl01\"><span class=\"inner\">責任施工</span></h2>\n              <div class=\"area-top-construction__in\">\n                <h3 class=\"top-ttl02\">機能性塗料メーカーによる<br class=\"pc_none\">自社施工で、確かな仕上がりをお約束</h3>\n\n                <div class=\"area-top-maining\">\n                  <img src=\"/img/top/top-construction.jpg\">\n                </div>\n\n                <div class=\"area-top-product__txt\">\n                  <p>付加価値の高い機能性塗料は、対象物の状態と施工現場の条件を正しく判断し、適切な方法で使用してこそ、本当の効力を発揮します。中外商工は創業当時からその状況判断と適正使用の重要性を理解しており、製品の特性を最もよく知る自社担当者が現場で施工まで行う「責任施工」のスタイルを現在も頑なに守り続けています。</p>\n                </div>\n              </div>\n\n              <div class=\"button pc_none\">\n                <a class=\"mod-top-about-button\" href=\"/construction/\"><span class=\"inner\">責任施工</span></a>\n              </div>\n\n              <a class=\"button btn-base-border sp_none\" href=\"/construction/\"><span class=\"inner\">責任施工</span></a>\n            </section>\n\n            <section class=\"area-top-development\">\n              <h2 class=\"ttl-top-development top-ttl01\"><span class=\"inner\">研究開発</span></h2>\n              <div class=\"area-top-development__in\">\n                <h3 class=\"top-ttl02\">現場で課題を発見し、対応する<br class=\"pc_none\">独自視点がユニークな製品を生む</h3>\n\n                <div class=\"area-top-maining\">\n                  <img src=\"/img/top/top-development.jpg\">\n                </div>\n\n                <div class=\"area-top-product__txt\">\n                  <p>当社の研究開発は社内で行われるのではありません。創業当初より技術研究所の所員がエンジニアとして現場を訪れ、作業者に正しい施工方法を指導すると共に、現場の課題を直接発見し、お客様のお悩みを解決する技術を開発する現場密着の開発スタイルを貫いてきました。その蓄積されたノウハウこそが当社の最大の強みです。</p>\n                </div>\n              </div>\n\n              <div class=\"button pc_none\">\n                <a class=\"mod-top-about-button\" href=\"/development/\"><span class=\"inner\">技術開発・製造</span></a>\n              </div>\n              <a class=\"button btn-base-border sp_none\" href=\"/development/\"><span class=\"inner\">技術開発・製造</span></a>\n            </section>\n\n            <section class=\"area-top-twocolumn_area\">\n              <ul>\n                <li>\n                  <h2 class=\"top-ttl01\"><span class=\"inner\">事業エリア</span></h2>\n                  <div class=\"area-top-twocolumn_area__in\">\n                    <div class=\"area-top-maining\">\n                      <img src=\"/img/top/top-business_area.jpg\">\n                    </div>\n                  </div>\n\n                  <div class=\"button pc_none\">\n                    <a class=\"mod-top-about-button\" href=\"/office/\"><span class=\"inner\">事業所一覧</span></a>\n                  </div>\n\n                  <a class=\"button btn-base-border sp_none\" href=\"/office/\"><span class=\"inner\">事業所一覧</span></a>\n                </li>\n                <li>\n                  <h2 class=\"top-ttl01\"><span class=\"inner\">会社概要</span></h2>\n                  <div class=\"area-top-twocolumn_area__in\">\n                    <div class=\"area-top-maining\">\n                      <img src=\"/img/top/top-company_overview.jpg\">\n                    </div>\n                  </div>\n\n                  <div class=\"button pc_none\">\n                    <a class=\"mod-top-about-button\" href=\"/about/\"><span class=\"inner\">会社概要</span></a>\n                  </div>\n\n                  <a class=\"button btn-base-border sp_none\" href=\"/about/\"><span class=\"inner\">会社概要</span></a>\n                </li>\n              </ul>\n            </section>\n          \n            <section class=\"link-unit--recruitment\">\n              <a class=\"unit-button recruit-button\" href=\"https://recruit-chugai.com/\" target=\"_blank\" rel=\"noopener\">\n                <div class=\"button__image\">\n                  <img src=\"/img/top/link_img_recruit.webp\" alt=\"\">\n                </div>\n                <p class=\"button__text\">採用情報</p>\n              </a>\n              <a class=\"unit-button partner-company\" href=\"https://partner-chugai.com/\" target=\"_blank\" rel=\"noopener\">\n                <div class=\"button__image\">\n                  <img src=\"/img/top/link_img_partner.webp\" alt=\"\">\n                </div>\n                <p class=\"button__text text--partner\">施工<br>パートナー様<br>募集</p>\n              </a>\n            </section>\n\n            <section class=\"top-link\">\n              <ul>\n                <li>\n                  <a href=\"/daikibo-shuzen/\" class=\"top-link__bg-img\">\n                    <p><span>常識を変える</span>中外商工の<br class=\"pc_none\">マンション大規模修繕</p>\n                  </a>\n                </li>\n              </ul>\n            </section>\n\n          </section>\n        </article>\n        <footer class=\"footer\" role=\"contentinfo\">\n  <div class=\"footer__in\">\n    <div class=\"footer-top\">\n      <a href=\"/contact/\" target=\"_blank\" class=\"footer-contact-mai