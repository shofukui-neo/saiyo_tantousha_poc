ass=\"footer-copyright\"><small>Copyright(c)  All right reserved by <br class=\"spbr\">Chugai Shoko Co., Ltd.</small></p>\n    </div>\n  </div>\n</footer>\n  </div>\n  <!-- wrapper END -->\n  <!-- script START -->\n  <script src=\"/js/common/lib.js\"></script>\n  <script src=\"/js/common/jquery.inview.min.js\"></script>\n  <script src=\"/js/common/common.js\"></script>\n  <script src=\"/js/top/top.js\"></script>\n  <!-- script END -->\n</body>\n\n</html>","finalUrl":"https://www.chugai-af.co.jp/","rendered":false,"_cachedAt":"2026-06-14T19:08:11.925Z"}