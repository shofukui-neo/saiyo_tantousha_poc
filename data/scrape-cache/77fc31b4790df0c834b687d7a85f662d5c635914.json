perty=\"og:title\" content=\"アシスタントプロデューサーを募集します – 日本デザインセンター\"><meta property=\"og:description\" content=\"日本デザインセンターは、東京・名古屋・北京・ロサンゼルスに拠点を持つグローバルなデザイン会社です。このページでは採用情報を掲載しています。\"><meta property=\"og:url\" content=\"https://www.ndc.co.jp/recruit/k-z7ay1tk/\"><meta property=\"og:image\" content=\"https://www.ndc.co.jp/og-image.png\"><meta property=\"og:site_name\" content=\"日本デザインセンター\"><meta property=\"og:locale\" content=\"ja_JP\"><meta name=\"twitter:card\" content=\"summary_large_image\"><meta name=\"twitter:title\" content=\"アシスタントプロデューサーを募集します – 日本デザインセンター\"><meta name=\"twitter:description\" content=\"日本デザインセンターは、東京・名古屋・北京・ロサンゼルスに拠点を持つグローバルなデザイン会社です。このページでは採用情報を掲載しています。\"><script src=\"https://webfont.fontplus.jp/accessor/script/fontplus.js?c2AO4PkCgW4%3D&box=Nf0UPKeRUic%3D&chws=1&aa=1&ab=1\"></script><link rel=\"stylesheet\" href=\"/_astro/_slug_.C9jqwfW1.css\">\n<link rel=\"stylesheet\" href=\"/_astro/index.Csge5Rdy.css\">\n<link rel=\"stylesheet\" href=\"/_astro/index.RBFjVP99.css\">\n<link rel=\"stylesheet\" href=\"/_astro/_slug_.95Dno4ZE.css\">\n<link rel=\"stylesheet\" href=\"/_astro/index.8rCQkfQX.css\">\n<link rel=\"stylesheet\" href=\"/_astro/_slug_.DRHV6Ez-.css\">\n<link rel=\"stylesheet\" href=\"/_astro/index.DgmACu1Z.css\">\n<link rel=\"stylesheet\" href=\"/_astro/_slug_.C4HuPdRe.css\"></head> <body>  <!-- Google Tag Manager (noscript) --> <noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-KJPFSG9\" height=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript> <!-- End Google Tag Manager (noscript) -->  <header class=\"_root_vdakj_1\" data-js=\"header\" data-menu-open=\"false\"> <a href=\"/\" class=\"_logo_vdakj_28\" data-js=\"header-logo\" aria-label=\"topページへ\"> <span class=\"_logoBody_vdakj_38\"> <svg width=\"50\" height=\"29\" viewBox=\"0 0 50 29\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" aria-label=\"Nippon Design Center\" role=\"img\"> <title>Nippon Design Center</title> <path d=\"M27.66