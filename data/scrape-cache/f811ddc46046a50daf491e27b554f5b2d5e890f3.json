 </div>\n                                        <div class=\"section--link scrt-to-top\">\n                                            <a class=\"button\" ontouchmove=\"\" href=\"company.html\" data-scroll>\n                                                        More\n                                                    </a>\n                                        </div>\n                                    </div>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                </section>\n\n                <section id=\"index--service\">\n                    <div class=\"content-inner-lg-y pos-r\">\n                        <div id=\"bg02-2\">\n                            <div class=\"custom-filter-right-1\"></div>\n                        </div>\n                        <div class=\"container\">\n                            <div class=\"row\">\n                                <div class=\"offset-lg-6 col-lg-6\">\n                                    <div class=\"wrapper2\">\n                                        <h3 class=\"section--title mb20 scrt-to-top mvBox reveal-ser\">\n                                            <font face=\"Rajdhani\">SERVICE</font><span class=\"scrt-to-top\">事業内容</span>\n                                        </h3>\n                                        <h4 id=\"effect_06\" class=\"section--heading mvFade scrt-to-top\">\n                                            お客様からのご要望をもとに<br>現場や地域の安心を確保します。\n                                        </h4>\n                                        <div id=\"effect_07\" class=\"inner mvBox scrt-to-top\">\n                                            <font face=\"Sawarabi Gothic\">交通誘導、雑踏警備、施設警備を主な業務としており、警備計画に基づいた方法で皆さまの生命・身体・財産の安全をお守りします。</font>\n                                        </div>\n                                        <div class=\"section--link scrt-to-top\">\n                                            <a class=\"button\" ontouchmove=\"\" href=\"service.html\" data-scroll>\n                                                        More\n                                                    </a>\n                                        </div>\n                                    </div>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                </section>\n\n                <div class=\"content-inner-lg-y pos-r top-under\">\n                    <div id=\"aside--recruit-bg\">\n                        <div id=\"aside--bg03\">\n                            <div class=\"custom-filter-left-1\"></div>\n                        </div>\n                    </div>\n                    <aside id=\"aside--recruit\">\n                        <div class=\"content-inner-lg-y pos-r\">\n                            <div class=\"container\">\n                                <div class=\"row\">\n                                    <div class=\"col-lg-6\">\n                                        <div class=\"wrapper3\">\n                                            <h3 class=\"section--title mb20 mvBox scrt-to-top\">\n                                                <font face=\"Rajdhani\">RECRUIT</font><span class=\"scrt-to-top\">採用情報</span>\n                                            </h3>\n                                            <h4 id=\"effect_09\" class=\"section--heading mvFade scrt-to-top\">\n                                                時代や個人に適した理想の<br>職場環境を目指しています。\n                                            </h4>\n                                            <div id=\"effect_10\" class=\"inner mvBox scrt-to-top\">\n                                                <font face=\"Sawarabi Gothic\">入社時および毎月のヒアリングを行いひとりひとりの 働き方に最適なシフトを構成しています。 より良い職場環境をつくるための新たな制度や取り組みを常に行っている会社です。\n\n                                                </font>\n                                            </div>\n                                            <div class=\"section--link scrt-to-top\">\n                                                <a class=\"button\" ontouchmove=\"\" href=\"http://www.patroad.co.jp/recruit/\" target=\"_blank\">\n                                                            More\n                                                        </a>\n                                            </div>\n                                        </div>\n                                    </div>\n                                    <div class=\"col-lg-6\">\n                                        <a href=\"//www.youtube.com/watch?v=A4uETx62tdU\" class=\"popup-youtube\"><img class=\"img-fluid pull-right\" src=\"images/works-04.jpg\" alt=\"\"></a>\n                                    </div>\n                                </div>\n                            </div>\n                        </div>\n                    </aside>\n                </div>\n\n\n            </main>\n            <!-- / #index -->\n\n\n\n            <div class=\"index-box-3\">\n                <div class=\"item\">\n                    <div class=\"footer--logo\">\n                        <a href=\"index.html\">\n                            <img src=\"images/header-logo_n.svg\" alt=\"パトロード富山\">\n                        </a>\n                    </div>\n                    <h4><img src=\"images/logo.png\" alt=\"パトロード富山\" width=\"170px\"></h4>\n                    <address>\n                                    〒939-8003　富山市西公文名町10-28\n                                </address>\n                    <div class=\"tel\"><a href=\"tel:0764216220\"><span>TEL </span>076-421-6220</a></div>\n                    <div class=\"section--link scrt-to-top\" data-scroll>\n                        <a class=\"button\" ontouchmove=\"\" href=\"company.html?id=page01\">More</a>\n                    </div>\n                </div>\n                <div class=\"item pc\">\n                </div>\n            