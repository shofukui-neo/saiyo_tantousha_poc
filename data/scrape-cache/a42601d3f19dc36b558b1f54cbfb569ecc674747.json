{"url":"https://www.mic-west.co.jp/recruit/entry/","html":"<!doctype html>\n<html class=\"no-js\" lang=\"ja\">\n<head>\n  <meta charset=\"utf-8\">\n  <title>エントリーフォーム | MIC GROUP</title>\n  <meta name=\"description\" content=\"各種業務ソフトやWeb系、FA系のソフトウェアの受託開発を行う。\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n  <meta property=\"og:site_name\" content=\"MIC GROUP\">\n  <meta property=\"og:title\" content=\"MIC GROUP\">\n  <meta property=\"og:type\" content=\"website\">\n  <meta property=\"og:url\" content=\"https://www.mic-west.co.jp//\">\n  <meta property=\"og:description\" content=\"各種業務ソフトやWeb系、FA系のソフトウェアの受託開発を行う。\" />\n  <meta property=\"og:image\" content=\"/ogp.png\">\n  <link rel=\"icon\" href=\"/favicon.ico\">\n  <link rel=\"stylesheet\" href=\"../../common/css/reset.css?ver51\">\n  <link rel=\"stylesheet\" href=\"../../common/css/common.css?ver51\">\n  <link rel=\"stylesheet\" href=\"../common/css/recruit.css?ver51\">\n</head>\n<body>\n  <button id=\"spnav\" class=\"spnav\"><span class=\"spnav1\"></span><span class=\"spnav2\"></span><span class=\"spnav3\"></span></button>\n  <header>\n    <h2 class=\"logo\"><a href=\"../\"><img src=\"../common/img/logo.svg\" alt=\"MIC GROUP\"></a></h2>\n    <nav id=\"gnav\">\n      <ul class=\"main\">\n        <li><a href=\"../#\"><span class=\"en\">TOP</span><span class=\"ja\">トップページ</span></a></li>\n        <li><a href=\"../#message\"><span class=\"en\" class=\"en\">MESSAGE</span><span class=\"ja\">採用メッセージ</span></a></li>\n        <li><a href=\"../#works\"><span class=\"en\">OUR WORKS</span><span class=\"ja\">事業領域</span></a></li>\n        <li><a href=\"../#person\"><span class=\"en\">PERSON</span><span class=\"ja\">社員/職種紹介</span></a></li>\n        <li><a href=\"../#benefits\"><span class=\"en\">BENEFITS</span><span class=\"ja\">福利厚生/研修制度</span></a></li>\n        <li><a href=\"../#gallery\"><span class=\"en\">GALLERY</span><span class=\"ja\">フォトギャラリー</span></a></li>\n        <li><a href=\"../requirements/\"><span class=\"en\">REQUIREMENTS</span><span class=\"ja\">募集要項</span></a></li>\n        <li class=\"entry\"><a href=\"../entry/\"><span class=\"en\">ENTRY</span><span class=\"ja\">エントリー</span></a></li>\n        <!--\n        <li class=\"corrporate sp\"><a href=\"../../\"><span class=\"en\">CORPORATE SITE</span><span class=\"ja\">企業サイト</span></a></li>\n        -->\n        <!-- add -->\n        <li class=\"corrporate pc\"><a href=\"../../\"><span class=\"en\">CORPORATE SITE</span></a></li>\n      </ul>\n      <div class=\"white\">\n        <ul class=\"sub sp\">\n          <li><a href=\"../../privacypolicy/\">プライバシーポリシー</a></li>\n          <li><a href=\"../../sitepolicy/\">サイトポリシー</a></li>\n        </ul>\n        <a class=\"instagram\" href=\"https://www.instagram.com/micgroup_since1979/\"><img class=\"white\" src=\"../common/img/icon_instagram.svg\" alt=\"Instagram\"><img class=\"blue\" src=\"../common/img/icon_instagram_blue.svg\" alt=\"Instagram\"></a>\n        <small class=\"copyright sp\">© Management Information Center Co., Ltd. All Rights Reserved.</small>\n      </div>\n    </nav>\n  </header>\n\n  <main id=\"entry\" class=\"lower\">\n    <div class=\"main_inner\">\n      <div class=\"hgroup\">\n        <h2>ENTRY</h2>\n        <h1>エントリーフォーム</h1>\n        <p class=\"lead\">下記フォームよりエントリーください。後日、当社よりご連絡させて頂きます。</p>\n      </div>\n      <section class=\"contents\">\n        <p class=\"note\"><span class=\"essential\"></span>は必須項目です。</p>\n        <form class=\"input\" method=\"post\" enctype=\"multipart/form-data\">\n          <input type=\"hidden\" name=\"csrf_token\" value=\"3da0a834e42d140ea68e488f6a2adedf\">\n          <p class=\"note\"><span class=\"dot\"></span></p>\n          <dl class=\"form\">\n            <dt><span class=\"txt\">エントリー先企業</span><span class=\"essential\"></span></dt>\n            <dd>\n              <ul class=\"company\">\n                <li><input type=\"checkbox\" id=\"company1\" name=\"エントリー先企業[]\" value=\"株式会社経営情報センター\" ><label for=\"company1\">株式会社経営情報センター</label></li>\n                <li><input type=\"checkbox\" id=\"company2\" name=\"エントリー先企業[]\" value=\"株式会社エムアイシー・コンサルティング\" ><label for=\"company2\">株式会社エムアイシー・コンサルティング</label></li>\n                <li><input type=\"checkbox\" id=\"company3\" name=\"エントリー先企業[]\" value=\"株式会社GSS\" ><label for=\"company3\">株式会社GSS</label></li>\n                <li><input type=\"checkbox\" id=\"company4\" name=\"エントリー先企業[]\" value=\"株式会社GSP\" ><label for=\"company4\">株式会社GSP</label></li>\n                <li><input type=\"checkbox\" id=\"company5\" name=\"エントリー先企業[]\" value=\"株式会社ビー・アイ・スクエア\" ><label for=\"company5\">株式会社ビー・アイ・スクエア</label></li>\n              </ul>\n              <input type=\"hidden\" name=\"required[]\" value=\"エントリー先企業\">\n              \n            </dd>\n            <dt>志望職種</dt>\n            <dd>\n              <ul class=\"boxs\">\n                <li><input type=\"checkbox\" id=\"job1\" name=\"志望職種[]\" value=\"システムエンジニア\" ><label for=\"job1\">システムエンジニア</label></li>\n                <li><input type=\"checkbox\" id=\"job2\" name=\"志望職種[]\" value=\"ネットワークエンジニア\" ><label for=\"job2\">ネットワークエンジニア</label></li>\n                <li><input type=\"checkbox\" id=\"job3\" name=\"志望職種[]\" value=\"ソリューション営業\" ><label for=\"job3\">ソリューション営業</label></li>\n                <li><input type=\"checkbox\" id=\"job4\" name=\"志望職種[]\" value=\"経営企画\" ><label for=\"job4\">経営企画</label></li>\n              </ul>\n            </dd>\n            <dt>希望勤務地</dt>\n            <dd>\n              <ul class=\"boxs\">\n                <li><input type=\"checkbox\" id=\"place1\" name=\"希望勤務地]\" value=\"大阪\" ><label for=\"place1\">大阪</label></li>\n                <li><input type=\"checkbox\" id=\"place2\" name=\"希望勤務地[]\" value=\"東京\" ><label for=\"place2\">東京</label></li>\n              </ul>\n            </dd>\n            <dt>卒業年度</dt>\n            <dd>\n              <ul class=\"boxs\">\n                <!-- <li><input type=\"checkbox\" id=\"year1\" name=\"卒業年[]\" value=\"2024年3月卒\" ><label for=\"year1\">2024年3月卒</label></li> -->\n                <li><input type=\"checkbox\" id=\"year1\" name=\"卒業年[]\" value=\"2027年卒\" ><label for=\"year1\">2027年卒</label></li>\n                <li><input type=\"checkbox\" id=\"year2\" name=\"卒業年[]\" value=\"2028年卒\" ><label for=\"year2\">2028年卒</label></li>\n                <li><input type=\"checkbox\" id=\"year3\" name=\"卒業年[]\" value=\"2029年卒\" ><label for=\"year3\">2029年卒</label></li>\n                <li><input type=\"checkbox\" id=\"year4\" name=\"卒業年[]\" value=\"既卒\" ><label for=\"year4\">既卒</label></li>\n              </ul>\n            </dd>\n            <dt class=\"vam\"><span class=\"txt\">学校名／<br class=\"pc\">学部（専攻）</span><span class=\"essential\"></span></dt>\n            <dd><input type=\"text\" name=\"学校名\" value=\"\" placeholder=\"例）○○大学　理工学部\">\n              <input type=\"hidden\" name=\"required[]\" value=\"学校名\">\n              \n            </dd>\n            <dt class=\"vam\"><span class=\"txt\">お名前</span><span class=\"essential\"></span></dt>\n            <dd><input type=\"text\" name=\"お名前\" value=\"\" placeholder=\"例）山田 太郎\">\n              <input type=\"hidden\" name=\"required[]\" value=\"お名前\">\n              \n            </dd>\n            <dt class=\"vam\"><span class=\"txt\">ふりがな</span><span class=\"essential\"></span></dt>\n            <dd><input type=\"text\" name=\"ふりがな\" value=\"\" placeholder=\"例）やまだ たろう\">\n              <input type=\"hidden\" name=\"required[]\" value=\"ふりがな\">\n              \n            </dd>\n            <dt class=\"vam\"><span class=\"txt\">メールアドレス</span><span class=\"essential\"></span></dt>\n            <dd><input type=\"text\" name=\"メールアドレス\" value=\"\" placeholder=\"例）mail@example.com\">\n              <input type=\"hidden\" name=\"email[]\" value=\"メールアドレス\">\n              \n              <input type=\"hidden\" name=\"required[]\" value=\"メールアドレス\">\n              \n            </dd>\n            <dt class=\"vam\"><span class=\"txt\">電話番号</span><span class=\"essential\"></span></dt>\n            <dd><input type=\"text\" name=\"電話番号\" value=\"\" placeholder=\"例）090-0000-0000\">\n              <input type=\"hidden\" name=\"num_hyphen[]\" value=\"電話番号\">\n              \n              <input type=\"hidden\" name=\"required[]\" value=\"電話番号\">\n              \n            </dd>\n            <dt><span class=\"txt\">お問合せ内容</span></dt>\n            <dd>\n              <textarea rows=\"6\" cols=\"30\" name=\"お問合せ内容\" placeholder=\"例）選考参加希望／2026年9月卒業予定／2025年3月既卒\"></textarea>\n            </dd>\n          </dl>\n          <div class=\"policy\">\n            <input id=\"policycheck\" type=\"checkbox\" name=\"プライバシーポリシー\" value=\"同意\" ><label for=\"policycheck\"><a href=\"../../privacypolicy/\" target=\"_blank\">プライバシーポリシー<img src=\"./img/newwin.svg\" alt=\"\"></a>に同意する</label>\n            <input type=\"hidden\" name=\"required[]\" value=\"プライバシーポリシー\">\n            \n          </div>\n          <div class=\"form_submit\"><span class=\"\"><input class=\"btn_submit\" type=\"submit\" value=\"入力内容を確認する\" class=\"\" /></span></div>\n        </form>\n      </section>\n      <nav class=\"local\">\n        <ul>\n          <li><a href=\"../requirements/\">\n            <p class=\"en\">REQUIREMENTS</p>\n            <p class=\"ja\">募集要項</p>\n          </a></li>\n        </ul>\n      </nav>\n    </div>\n    <section id=\"corporate\" class=\"switch section block6\">\n      <a href=\"../../\">\n        <div class=\"inner\">\n          <div>コーポレートサイトはこちら<span class=\"btn\"><i></i></span></div>\n        </div>\n      </a>\n    </section>\n  </main>\n  <footer id=\"footer\">\n    <div class=\"white\">\n      <div class=\"inner\">\n        <div class=\"upper\">\n          <h2 class=\"logo\"><a href=\"../\"><img src=\"../../common/img/logo.svg\" alt=\"\"></a></h2>\n          <nav class=\"sp\">\n            <ul class=\"arrows\">\n              <li class=\"ej\"><a href=\"../../\"><span class=\"en\">Corporate s