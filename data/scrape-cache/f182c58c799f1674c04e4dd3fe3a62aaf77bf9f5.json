at:400,400i,500,500i\" rel=\"stylesheet\">\r\n\r\n<!-- js -->\r\n<script type=\"text/javascript\" src=\"../resource/js/jquery-1.11.3.min.js\"></script>\r\n<script type=\"text/javascript\" src=\"../resource/js/jquery.easing.1.3.js\"></script>\r\n<script type=\"text/javascript\" src=\"../resource/js/jquery.heightLine.js\"></script>\r\n<script type=\"text/javascript\" src=\"../resource/js/jquery.smoothscroll.js\"></script>\r\n<script type=\"text/javascript\" src=\"../resource/js/jquery.inview.min.js\"></script>\r\n<script type=\"text/javascript\" src=\"../resource/js/TweenMax.min.js\"></script>\r\n<script type=\"text/javascript\" src=\"../resource/js/common.js\"></script>\r\n<script type=\"text/javascript\" src=\"../resource/js/analytics.js\"></script>\r\n\r\n</head>\r\n\r\n\r\n<body class=\"ctg_company\" id=\"pg_nittoh\">\r\n<div id=\"pgtop\" class=\"has_subnavi\">\r\n\r\n<!---------- header ---------->\r\n<header id=\"hdpage\">\r\n\r\n\t<h1><a href=\"../index.php\">NITTOH RECRUIT SITE（採用情報）</a></h1>\r\n\t\r\n\t<ul id=\"sp_menu\">\r\n\t\t<li class=\"icon-menu\"></li>\r\n\t\t<li class=\"icon-cancel\"></li>\r\n\t</ul>\r\n\t\r\n\t<nav>\r\n\t\r\n\t\t<ul>\r\n\t\t\t<li class=\"nv_company\"><a href=\"../company/message.html\">会社を知る<i class=\"icon-down-open\"></i></a>\r\n\t\t\t\t<div>\r\n\t\t\t\t\t<ul>\r\n\t\t\t\t\t\t<li><a href=\"../company/message.html\">代表メッセージ<i class=\"icon-right-open\"></i></a></li>\r\n\t\t\t\t\t\t<li class=\"active\"><a href=\"../company/nittoh.html\">NITTOHで働くとは<i class=\"icon-right-open\"></i></a></li>\r\n\t\t\t\t\t\t<li><a href=\"../company/number.html\">数字で見るNITTOH<i class=\"icon-right-open\"></i></a></li>\r\n\t\t\t\t\t\t<li><a href=\"../company/photo.html\">写真で見るNITTOH<i class=\"icon-right-open\"></i></a></li>\r\n\t\t\t\t\t</ul>\r\n\t\t\t\t</div>\r\n\t\t\t</li>\r\n\t\t\t<li class=\"nv_work\"><a href=\"../work/index.html\">仕事を知る<i class=\"icon-down-open\"></i></a>\r\n\t\t\t\t<div>\r\n\t\t\t\t\t<ul>\r\n\t\t\t\t\t\t<li class=\"nv_sponly\"><a href=\"../work/index.html\">仕事を知る トップ<i class=\"icon-right-open\"></i></a></li>\r\n\t\t\t\t\t\t<li><a href=\"../work/manager.html\">総合職<i class=\"icon-right-open\"></i></a></li>\r\n\t\t\t\t\t\t<li><a href=\"../work/field_worker.html\">工務職<i class=\"icon-right-open\"></i></a></li>\r\n\t\t\t\t\t\t<li><a href=\"../work/office_worker.html\">事務職<i class=\"icon-right-open\"></i></a></li>\r\n\t\t\t\t\t</ul>\r\n\t\t\t\t</div>\r\n\t\t\t</li>\r\n\t\t\t<li class=\"nv_person\"><a href=\"../person/index.html\">人を知る<i class=\"icon-down-open\"></i></a>\r\n\t\t\t\t<div>\r\n\t\t\t\t\t<ul>\r\n\t\t\t\t\t\t<li class=\"nv_sponly\"><a href=\"../person/index.html\">人を知る トップ<i class=\"icon-right-open\"></i></a></li>\r\n\t\t\t\t\t\t<li><a href=\"../person/index.html\">インタビュー<i class=\"icon-right-open\"></i></a></li>\r\n\t\t\t\t\t\t<li><a href=\"../person/discussion.html\">座談会<i class=\"icon-right-open\"></i></a></li>\r\n\t\t\t\t\t</ul>\r\n\t\t\t\t</div>\r\n\t\t\t</li>\r\n\t\t\t<li class=\"nv_information\"><a href=\"../information/index.php\">採用情報<i class=\"icon-right-open\"></i></a></li>\r\n\t\t\t<li class=\"nv_sponly\"><a href=\"../faq/index.html\">FAQ<i class=\"icon-right-open\"></i></a></li>\r\n\t\t\t<li class=\"nv_sponly\"><a href=\"../contact/form.html\">お問い合わせ<i class=\"icon-right-open\"></i></a></li>\r\n\t\t</ul>\r\n\t\r\n\t</nav>\r\n\r\n</header>\r\n<!---------- /header ---------->\r\n\r\n\r\n<!---------- contents ---------->\r\n<main>\r\n\t<article>\r\n\t\t\r\n\t\t<header class=\"title_middle\">\r\n\t\t\t<div class=\"inner\">\r\n\t\t\t\t<h1>NITTOHで働くとは</h1>\r\n\t\t\t\t<p>WORK INFORMATION</p>\r\n\t\t\t</div>\r\n\t\t</header>\r\n\t\t\r\n\t\t<div class=\"inner\">\r\n\t\t\r\n\t\t\t<h2 class=\"sub_title\">お客様の満足が、<br class=\"sp_only\">社員の満足へとつながる。<br>\r\n\t\t\t\t働きがいのある職場環境を創造。</h2>\r\n\t\t\t<p class=\"txt_lead\">NITTOHでは、社員一人ひとりが仕事に集中でき、安心して働ける環境を提供することが、<br class=\"pc_only\">結果としてお客様の満足につながると考えています。<br>\r\n\t\t\t\tここでは、その想いを実現するための心構えや主だった取り組みをご紹介します。 </p>\r\n\t\t\t\t\r\n\t\t\t<section class=\"sec_nittoh sec_nittoh_left\">\r\n\t\t\t\t<div><img src=\"../resource/img/company/nittoh/pct_01.jpg\" width=\"490\" height=\"379\" alt=\"名古屋証券取引所\"></div>\r\n\t\t\t\t<h3><i class=\"icon-minus\"></i>上場企業としての使命と責務</h3>\r\n\t\t\t\t<p>NITTOHは2000年に名古屋証券取引所メイン市場に上場を果たしています。結果、弊社で働くということは、上場企業の一員になるということです。透明性のある経営と安定した事業基盤を確立している反面、ステークホルダーに対する使命と責務を背負っています。大げさに捉える必要はありませんが、信頼を宝とする弊社では、良識ある社会人としての行動と、常に成長する意欲を持っていただきたいと思っています。</p>\r\n\t\t\t</section>\r\n\t\t\t\t\r\n\t\t\t<section class=\"sec_nittoh sec_nittoh_right\">\r\n\t\t\t\t<div><img src=\"../resource/img/company/nittoh/pct_02.jpg\" width=\"490\" height=\"379\" alt=\"\"></div>\r\n\t\t\t\t<h3><i class=\"icon-minus\"></i>建設に関わる様々な事業に携わる</h3>\r\n\t\t\t\t<p>NITTOHの事業は、建設工事・住宅サービス・ビルメンテナンスという3つの事業を柱としています。建設というと「戸建住宅」や「ビル」を建てるイメージが強いと思いますが、弊社では、建てることはもちろん、既存建築物に対するリフォームやメンテナンス、防虫、防水、ハウスクリーニングなど建物に関連したサービスの豊富さで他社との差別化を図っています。結果、お客様は一般の方からハウスメーカーやゼネコンまで幅が広く、総合職・工務職・事務職を問わず、日々柔軟なコミュニケーション能力が必要となります。</p>\r\n\t\t\t</section>\r\n\r\n\r\n\t\t\t<section class=\"sec_location\">\r\n\t\t\t\t<h3><i class=\"icon-minus\"></i>自宅に近い職場も希望できる</h3>\r\n\t\t\t\t<p>NITTOHは、本社を含む営業所・店舗が関東・東海・北陸・関西にあり、現在もエリアを拡大中です。全拠点を対象とする広域採用と勤務地域を限定した地域採用、また転勤をしない条件での勤務も可能です。ご自分のライフスタイルにあった働き方で、会社全体を盛り上げていただきたいと考えています。</p>\r\n\t\t\t\t<div id=\"map\">&nbsp;</div>\r\n\t\t\t</section>\r\n\r\n\t\t\t\t\r\n\t\t\t<section class=\"sec_nittoh sec_nittoh_left\">\r\n\t\t\t\t<div><img src=\"../resource/img/company/nittoh/pct_03.jpg\" width=\"490\" height=\"379\" alt=\"名古屋証券取引所\"></div>\r\n\t\t\t\t<h3><i class=\"icon-minus\"></i>風通しのいいアットホームな職場</h3>\r\n\t\t\t\t<p>弊社スタッフにNITTOHの印象を聞くと、声を揃えて「アットホーム」と言います。これは社長の人柄が影響しているかもしれませんが、笑顔でコミュニケーション能力が高いメンバーが多く、身近なことでも気軽に上司に相談できるのが特徴です。新卒定着率80%以上というデータも、そうした職場環境が影響しているのだと思います。</p>\r\n\t\t\t</section>\r\n\t\t\t\t\r\n\t\t\t<section class=\"sec_nittoh sec_nittoh_right\">\r\n\t\t\t\t<div><img src=\"../resource/img/company/nittoh/pct_04.jpg\" width=\"490\" height=\"379\" alt=\"\"></div>\r\n\t\t\t\t<h3><i class=\"icon-minus\"></i>女性にも働きやすい環境</h3>\r\n\t\t\t\t<p>会社全体の約3割が女性社員です。女性ならではの視点、きめ細やかな仕事ぶりが、弊社にとって不可欠な戦力となっています。また育児休業制度の利用率100%と、ダイバーシティの促進制度も活用されており、復帰後も多くの女性が活躍しています。その影響か、建設業界では珍しく女性の応募も多い状況です。</p>\r\n\t\t\t</section>\r\n\r\n\t\t\t<section class=\"sec_nittoh sec_nittoh_left\">\r\n\t\t\t\t<div><img src=\"../resource/img/company/nittoh/pct_05.jpg\" width=\"490\" height=\"379\" alt=\"名古屋証券取引所\"></div>\r\n\t\t\t\t<h3><i class=\"icon-minus\"></i>各種研修と福利厚生</h3>\r\n\t\t\t\t<p>NITTOHでは、建設業界未経験者のキャリア採用においても各種研修を行うなど安心して働ける環境づくりに取り組んでいます。新卒採用の方には、社会人としてのマナーを身につける入社時の新人研修をはじめ、その後、配属業務にあった技術研修・OJTを先輩社員がマンツーマンで指導します。また、社会保険の完備をはじめ、資格取得した際の手当てなど福利厚生面も充実しています。</p>\r\n\t\t\t</section>\r\n\t\t\t\r\n\t\t\t<aside class=\"sec_official_site\">\r\n\t\t\t\t<a href=\"http://www.nittoh-info.co.jp\" target=\"_blank\">\r\n\t\t\t\t<div class=\"picture\"><img src=\"../resource/img/company/nittoh/pct_site_new.jpg\" width=\"483\" height=\"155\" alt=\"\"></div>\r\n\t\t\t\t<h3>（株）NITTOHコーポレートサイト</h3>\r\n\t\t\t\t<p>さらに詳しい情報はNITTOHコーポレートサイトをご覧ください。</p>\r\n\t\t\t\t<p>https://www.nittoh-info.co.jp/</p>\r\n\t\t\t\t</a>\r\n\t\t\t</aside>\r\n\t\t\t\r\n\t\t</div>\r\n\t\t\r\n\t</article>\r\n</main>\r\n<!---------- /contents ---------->\r\n\r\n\r\n<!---------- footer ---------->\r\n<footer>\r\n\t<div class=\"inner01\">\r\n\t\t\r\n\t\t<nav>\r\n\t\t\t<ul class=\"clearfix\">\r\n\t\t\t\t<li><a href=\"../faq/index.html\">FAQ<i class=\"icon-right-open-big\"></i></a></li>\r\n\t\t\t\t<li><a href=\"../contact/form.html\">お問い合わせ<i class=\"icon-right-open-big\"></i></a></li>\r\n\t\t\t</ul>\r\n\t\t</nav>\r\n\t\t\r\n\t</div>\r\n\t<div class=\"inner02\">\r\n\t\t\r\n\t\t<nav>\r\n\t\t\t<ul>\r\n\t\t\t\t<li><a href=\"http://www.nittoh-info.co.jp/\" target=\"_blank\">コーポレートサイト<i class=\"icon-popup\"></i></a></li>\r\n\t\t\t\t<li><a href=\"http://www.nittoh-info.co.jp/privacy/\" target=\"_blank\">個人情報保護方針<i class=\"icon-popup\"></i></a></li>\r\n\t\t\t</ul>\r\n\t\t</nav>\r\n\t\t\r\n\t\t<p class=\"logo\">NITTOH RECRUIT SITE（採用情報）</p>\r\n\t\t\r\n\t\t<p class=\"copyright\"><small>Copyright &copy; NITTOH Co., Ltd. All Rights Reserved.</small></p>\r\n\t\t\r\n\t</div>\r\n</footer>\r\n<!---------- /footer ---------->\r\n\r\n\r\n\r\n</div>\r\n\r\n<div id=\"btn_return_top\"><a href=\"#pgtop\"><i class=\"icon-up-open\"></i></a></div>\r\n\r\n<script>\r\nfunction initMap() {\r\n\r\n\t//各種設定\r\n\tvar icnPath = \"../resource/img/company/nittoh/icon_marker.png\";\t//マーカー画像\r\n\tvar icnSize = new google.maps.Size(14, 20);\r\n\tvar latLng0 = new google.maps.LatLng( 35.654777, 137.787893 );\t// 地図の中心座標\r\n\tvar latLng1 = new google.maps.LatLng( 35.150982, 136.880350 );\t// NITTOH本社、名古屋営業所\r\n\tvar latLng2 = new google.maps.LatLng( 35.628421, 139.398825 );\t// 東京西営業所\r\n\tvar latLng3 = new google.maps.LatLng( 35.697873, 139.781114 );\t// 東京中央営業所・株式会社ビルワーク\r\n\tvar latLng4 = new google.maps.LatLng( 36.1811778, 137.9326813 );\t// 甲信営業所\r\n\tvar latLng5 = new google.maps.LatLng( 34.955303, 138.418142 );\t// 静岡営業所\r\n\tvar latLng6 = new google.maps.LatLng( 34.922451, 137.147210 );\t// 三河営業所・デアール岡崎店\r\n\tvar latLng7 = new google.maps.LatLng( 35.249373, 136.936285 );\t// 春日井営業所・デアール春日井店\r\n\tvar latLng8 = new google.maps.LatLng( 35.4071527, 136.8405284 );\t// 岐阜営業所・デアール各務原店\r\n\t//var latLng9 = new google.maps.LatLng( 35.475704, 137.480770 );// 中津川店\r\n\tvar latLng10 = new google.maps.LatLng( 34.941020, 137.151387 );// セブンハウス事業部\r\n\tvar latLng11 = new google.maps.LatLng( 35.025036, 135.995914 );// 京滋営業所・デアール栗東店\r\n\tvar latLng12 = new google.maps.LatLng( 34.537842, 135.7940824 );// 奈良営業所・デアール奈良店\r\n\tvar latLng13 = new google.maps.LatLng( 34.778350, 135.454974 );// 大阪事業所\r\n\tvar latLng14 = new google.maps.LatLng( 35.1282515, 136.9399044 );// デアール瑞穂店\r\n\tvar latLng15 = new google.maps.LatLng( 35.169804496622504, 137.05001683680663 );// デアール名古屋東店\r\n\tvar latLng16 = new google.maps.LatLng( 36.5988175, 136.618735 );// 北陸営業所\r\n\t\r\n\tvar map = new google.maps.Map(\r\n\t\t// getElementByIdには、地図を表示するための領域に\r\n\t\t// 指定したidを設定すること。（今回は「map」）\r\n\t\tdocument.getElementById(\"map\"),\r\n\t\t{\r\n\t\t\tzoom: 7,  // 地図の初期拡大率\r\n\t\t\tcenter: latLng0, // 先ほど設定した中心座標を設定\r\n\t\t\tscrollwheel: false  // マウスホイールで拡縮しなくなる\r\n\t\t}\r\n\t);\r\n\t\r\n\t/*====================================\r\n\t// マーカーの設定\r\n\t====================================*/\r\n\t//●本社\r\n\tvar marker1 = new google.maps.Marker({\r\n\t\tposition: latLng1,\r\n\t\tmap: map,\r\n\t\ticon: { url: icnPath, scaledSize: icnSize },\r\n\t\tplace: { location: latLng1, query: \"（株）ニットー（ＮＩＴＴＯＨ）\" }\r\n\t});\r\n\t//●東京西営業所\r\n\tvar marker2 = new google.maps.Marker({\r\n\t\tposition: latLng2,\r\n\t\tmap: map,\r\n\t\ticon: { url: icnPath, scaledSize: icnSize },\r\n\t\tplace: { location: latLng2, query: \"（株）ＮＩＴＴＯＨ 東京営業所\" }\r\n\t});\r\n\t//●東京中央営業所\r\n\tvar marker3 = new google.maps.Marker({\r\n\t\tposition: latLng3,\r\n\t\tmap: map,\r\n\t\ticon: { url: icnPath, scaledSize: icnSize },\r\n\t\tplace: { location: latLng3, query: \"東京都台東区浅草橋四丁目4番1号\" }\r\n\t});\r\n\t//●甲信営業所\r\n\tvar marker4 = new google.maps.Marker({\r\n\t\tposition: latLng4,\r\n\t\tmap: map,\r\n\t\ticon: { url: icnPath, scaledSize: icnSize },\r\n\t\tplace: { location: latLng4, query: \"（株）ニットー 甲信営業所（ＮＩＴＴＯＨ）\" }\r\n\t});\r\n\t//●静岡営業所\r\n\tvar marker5 = new google.maps.Marker({\r\n\t\tposition: latLng5,\r\n\t\tmap: map,\r\n\t\ticon: { url: icnPath, scaledSize: icnSize },\r\n\t\tplace: { location: latLng5, query: \"（株）ＮＩＴＴＯＨ静岡（営）\" }\r\n\t});\r\n\t//●三河営業所\r\n\tvar marker6 = new google.maps.Marker({\r\n\t\tposition: latLng6,\r\n\t\tmap: map,\r\n\t\ticon: { url: icnPath, scaledSize: icnSize },\r\n\t\tplace: { location: latLng6, query: \"（株）ニットー（ＮＩＴＴＯＨ） 三河営業所\" }\r\n\t});\r\n\t//●春日井営業所\r\n\tvar marker7 = new google.maps.Marker({\r\n\t\tposition: latLng7,\r\n\t\tmap: map,\r\n\t\ticon: { url: icnPath, scaledSize: icnSize },\r\n\t\tplace: { location: latLng7, query: \"株式会社NITTOH春日井営業所\" }\r\n\t});\r\n\t//●岐阜営業所\r\n\tvar marker8 = new google.maps.Marker({\r\n\t\tposition: latLng8,\r\n\t\tmap: map,\r\