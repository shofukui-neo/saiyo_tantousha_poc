         <div class=\"l-footer__acc-content\" data-accordion-content=\"content\">\n                          <div class=\"l-footer__acc-content-inner\">\n                            <ul class=\"l-footer__menulist is-sub\">\n                              <li><span class=\"is-sub-head\">2027卒</span><a class=\"is-sub-link\" href=\"https://mypage.3030.i-webs.jp/nipponshinyaku2027/applicant/entry/baitai-entry/entrycd/HP1\" target=\"_blank\">エントリー</a><a class=\"is-sub-link\" href=\"https://mypage.3030.i-webs.jp/nipponshinyaku2027/applicant/login/baitai-entry/entrycd/HP1\" target=\"_blank\">マイページ</a><span class=\"is-sub-head\">2028卒</span><a class=\"is-sub-link\" href=\"https://mypage.3030.i-webs.jp/nipponshinyaku2028/applicant/entry/baitai-entry/entrycd/HP1/\" target=\"_blank\">エントリー</a><a class=\"is-sub-link\" href=\"https://mypage.3030.i-webs.jp/nipponshinyaku2028/applicant/login/baitai-entry/entrycd/HP1\" target=\"_blank\">マイページ</a>\n                              </li>\n                            </ul>\n                          </div>\n                        </div>\n                      </details>\n                    </li>\n                  </ul>\n                </div>\n              </div>\n            </div>\n            <div class=\"l-footer__links\"><a class=\"l-footer__link\" href=\"../../career/\" target=\"_blank\">キャリア採用</a><a class=\"l-footer__link\" href=\"../../disabilities/\" target=\"_blank\">障がい者採用</a><a class=\"l-footer__link is-blank\" href=\"https://www.nippon-shinyaku.co.jp/\" target=\"_blank\">コーポレートサイト</a>\n            </div>\n            <div class=\"l-footer__bottom\"><a class=\"l-footer__link\" href=\"../../fair-recruitment/\">日本新薬 公正採用方針</a><small class=\"l-footer__copyright\">© NIPPON SHINYAKU CO., LTD.</small>\n            </div>\n          </div>\n        </div>\n      </footer>\n    </div>\n    <script src=\"../../assets/js/app.js\"></script>\n  </body>\n</html>","finalUrl":"https://www.nippon-shinyaku.co.jp/recruit/real/crosstalk/","rendered":false,"_cachedAt":"2026-06-22T22:33:46.747Z"}