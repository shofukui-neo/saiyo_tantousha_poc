e\">\n    <meta name=\"twitter:site\" content=\"zynasCorp\">\n\n    <!-- 電話番号自動リンク化解除 -->\n    <meta name=\"format-detection\" content=\"telephone=no\">\n\n    <!-- Favicon -->\n    <link rel=\"icon\" type=\"image/x-icon\" href=\"https://recruit.zynas.co.jp/favicon/favicon.ico\">\n    <link rel=\"apple-touch-icon\" href=\"https://recruit.zynas.co.jp/favicon/apple-touch-icon.png\">\n\n    <!-- Font -->\n    <script>\n        (function(d) {\n            var config = {\n                kitId: 'mqa6mvk',\n                scriptTimeout: 3000,\n                async: true\n            },\n            h=d.documentElement,t=setTimeout(function(){h.className=h.className.replace(/\\bwf-loading\\b/g,\"\")+\" wf-inactive\";},config.scriptTimeout),tk=d.createElement(\"script\"),f=false,s=d.getElementsByTagName(\"script\")[0],a;h.className+=\" wf-loading\";tk.src='https://use.typekit.net/'+config.kitId+'.js';tk.async=true;tk.onload=tk.onreadystatechange=function(){a=this.readyState;if(f||a&&a!=\"complete\"&&a!=\"loaded\")return;f=true;clearTimeout(t);try{Typekit.load(config)}catch(e){}};s.parentNode.insertBefore(tk,s)\n        })(document);\n    </script>\n\n    <!-- CSS -->\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"./css/reset.css\">\n        <link rel=\"stylesheet\" type=\"text/css\" href=\"./css/common.css\">\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"./css/global-joinUs.css\">\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"./css/global-header.css\">\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"./css/global-footer.css\">\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"./css/culture.css\">\n</head>\n<body>\n    <!-- Google Tag Manager -->\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n})(window,document,'script','dataLayer','GTM-TLL4QPTD');</script>\n<!-- End Google Tag Manager -->    <header id=\"header\">\n    \n    <h1 id=\"headerLogo\"><a href=\"./\"><img src=\"./img/logo/logo-zynas.svg\" alt=\"Zynas Recruit Site\"></a></h1>\n\n    <div id=\"headerNavMenu\">\n        <nav id=\"headerNavMenu--global\">\n            <h1>採用サイトコンテンツ</h1>\n            <ul>\n                <li><a href=\"./\">ホーム<span aria-hidden=\"true\">HOME</span></a></li>\n                <li><a href=\"./culture\">カルチャー<span aria-hidden=\"true\">CULTURE</span></a></li>\n                <li><a href=\"./workers\">働く人<span aria-hidden=\"true\">PERSON</span></a></li>\n                <li><a href=\"./environment\">働く環境<span aria-hidden=\"true\">WORK STYLE</span></a></li>\n                <li><a href=\"./data\">数字で見るザイナス<span aria-hidden=\"true\">DATA</span></a></li>\n                <li><a href=\"./faq\">よくある質問<span aria-hidden=\"true\">Q&A</span></a></li>\n            </ul>\n        </nav>\n\n        <nav id=\"headerNavMenu--banner\">\n            <h1>関連バナー</h1>\n            <ul>\n                <li><a href=\"https://note.com/zynas/m/m729c646de512\" target=\"_blank\" rel=\"noopener noreferrer\"><img src=\"./img/common/header/header-banner--01.jpg\" alt=\"note インタビュー記事一覧\"></a></li>\n                <li><a href=\"https://note.com/zynas/m/m13b3151ba6fb\" target=\"_blank\" rel=\"noopener noreferrer\"><img src=\"./img/common/header/header-banner--02.jpg\" alt=\"note 25卒・26卒 採用向けマガジン\"></a></li>\n            </ul>\n        </nav>\n\n        <nav id=\"headerNavMenu--sns\">\n            <h1>FOLLOW US!</h1>\n            <ul>\n                <li><a class=\"note\" href=\"https://note.com/zynas/\" target=\"_blank\" rel=\"noopener noreferrer\" aria-label=\"noteのリンク\"></a></li>\n                <li><a class=\"x\" href=\"https://twitter.com/zynasCorp\" target=\"_blank\" rel=\"noopener noreferrer\" aria-label=\"Xのリンク\"></a></li>\n                <li><a class=\"instagram\" href=\"https://www.instagram.com/zynas_corp\" target=\"_blank\" rel=\"noopener noreferrer\" aria-label=\"Instagramのリンク\"></a></li>\n                <li><a class=\"facebook\" href=\"https://www.facebook.com/zynas.inc\" target=\"_blank\" rel=\"noopener noreferrer\" aria-label=\"Facebookのリンク\"></a></li>\n            </ul>\n        </nav>\n    </div>\n\n    <div id=\"headerEntry\">\n        <button id=\"headerEntryBtn\" aria-label=\"募集要項・エントリーメニューボタン\">募集要項・エントリー</button>\n        <nav id=\"headerEntryMenu\">\n            <h1>募集要項・エントリー</h1>\n            <ul>\n                <li><a href=\"https://open.talentio.com/r/1/c/zynas/homes/3087\" target=\"_blank\" rel=\"noopener noreferrer\">中途採用</a></li>\n                <!-- <li><a href=\"https://job.rikunabi.com/2025/company/r450110032/\" target=\"_blank\" rel=\"noopener noreferrer\">新卒採用（25卒）</a></li> -->\n                <!-- <li><a href=\"https://job.mynavi.jp/26/pc/search/corp244872/outline.html\" target=\"_blank\" rel=\"noopener noreferrer\">新卒採用（26卒）</a></li> -->\n                 <li><a href=\"https://job.mynavi.jp/27/pc/search/corp244872/outline.html\" target=\"_blank\" rel=\"noopener noreferrer\">新卒採用（27卒）</a></li>\n                <li><a href=\"https://zynas.co.jp/recruit-contact\" target=\"_blank\" rel=\"noopener noreferrer\">カジュアル面談・<br>採用お問い合わせ</a></li>\n            </ul>\n        </nav>\n    </div>\n\n    <button id=\"headerNavBtn\" aria-label=\"メニューボタン\"></button>\n\n</header>\n\n    <main id=\"main\">\n\n\n        <div id=\"pageHeader\">\n            <div id=\"pageHeaderTitle\" class=\"js-fadeIn\">\n                <h1 class=\"title--ja\">カルチャー</h1>\n                <p class=\"title--en\">CULTURE</p>\n                <p class=\"title--lead\">ザイナスが会社として何を目指し、どう実現しようとしているのかをお伝えします。また、ザイナスの文化や、それを形成している考え方、心がけている行動指針を紹介します。</p>\n            </div>\n            <div id=\"pageHeaderImg\" class=\"js-fadeIn\"><img src=\"./img/page-culture/pageHeaderImg--culture.png\" alt=\"\"></div>\n        </div>\n        <!-- / #pageHeader -->\n\n\n        <section id=\"message\">\n            <div class=\"wrapper\">\n                <div id=\"messageContent\">\n                    <div class=\"message-container js-fadeUp\">\n                        <h1 class=\"heading\">MESSAGE</h1>\n                        <div class=\"content\">\n                            <h2 class=\"lead\">\n                                <picture>\n                                    <source srcset=\"./img/page-culture/culture-message-lead--sp.svg\" media=\"(max-width: 767px)\">\n                                    <img src=\"./img/page-culture/culture-message-lead--pc.svg\" alt=\"ザイナスの描く「明日」\">\n                                </picture>\n                            </h2>\n                            <div class=\"comment\">\n                                <p class=\"message\">\n                                    ザイナスは2025年5月に、創業25年目を迎えます。<br>\n                                    これまで20年以上にわたり、時代のニーズに合わせた様々なサービスを提供してきました。その根底にはIT技術を活用し、お客様の課題を解決したいという想いがあります。<br>\n                                    <br>\n                                    昨今、IT技術の広がりは目まぐるしく、インフラ業、製造業、販売業、生産業などの様々な業界において、活用が進み、そこで働く人々の業務効率を上げ、生産性を向上させるだけでなく、これまでなかった新しい価値を創出しています。<br>\n                                    今すでに、AIをはじめとした様々な技術があらゆる場面で活用され、私たちの生活や社会に根付いてきています。さらなるテクノロジーの進歩により、社会はますます多様に大きく変化していくでしょう。<br>\n                                    ザイナスは人とテクノロジーの懸け橋となり、明るい未来を目指し、社会に貢献していきます。<br>\n                                    <br>\n                                    未来は皆さんの活躍を待っています。ともに「明日」を描きましょう。\n                                </p>\n                                <p class=\"position\">株式会社ザイナス 代表取締役社長</p>\n                                <p class=\"commenter\">江藤彰悟</p>\n                            </div>\n                        </div>\n                    </div>\n                    <img class=\"message-thumbnail js-fadeUp\" src=\"./img/page-culture/culture-message-thumbnail.png\" alt=\"江藤社長の写真\">\n                </div>\n            </div>\n        </section>\n        <!-- / #message -->\n\n\n        <section id=\"mission\">\n            <div class=\"wrapper\">\n                <div id=\"missionContent\">\n                    <h1 class=\"heading js-fadeUp\">MISSION</h1>\n                    <div class=\"content\">\n                        <h2 class=\"lead js-fadeUp\">\n                            <picture>\n                                <source srcset=\"./img/page-culture/culture-mission-lead--sp.svg\" media=\"(max-width: 767px)\">\n                                <img src=\"./img/page-culture/culture-mission-lead--pc.svg\" alt=\"もっといいシステムで、もっといい明日を\">\n                            </picture>\n                        </h2>\n                        <p class=\"message js-fadeUp\">\n                            ザイナスが目指すのは、誰もが平等に正しくITの恩恵を受け取れる社会です。<br>\n                            私たちが作り手となり、人々が思い描く未来を実現していきます。<br>\n                            人々の「明日」がより良い未来につながるよう、人々に寄り添ったシステム作りをしていきます。<br>\n                            一人ひとりの幸せが、社会の豊かな「明日」に繋がることを信じています。\n                        </p>\n                    </div>\n                </div>\n            </div>\n        </section>\n        <!-- / #mission -->\n\n\n        <section id=\"ourValues\">\n            <div class=\"wrapper\">\n                <div id=\"ourValuesContent\">\n                    <h1 class=\"heading js-fadeUp\">OUR VALUES</h1>\n                    <div class=\"content js-fadeUp\">\n                        <h2 class=\"lead\">\n                            <picture>\n                                <source srcset=\"./img/page-culture/culture-ourvalues-lead--sp.svg\" media=\"(max-width: 767px)\">\n                                <img src=\"./img/page-culture/culture-ourvalues-lead--pc.svg\" alt=\"ZYNAS STANDARD\">\n                            </picture>\n                        </h2>\n                        <p class=\"message\">Missionを実現するための行動指針です。社員全員がZynas Standardを体現することで、もっといい「明日」を目指します。</p>\n                    </div>\n\n                    <article class=\"value-container js-fadeUp\">\n                        <hgroup class=\"value-heading\">\n                            <h1 class=\"title\">VALUE 01</h1>\n                            <div class=\"lead\">\n                                <h2 class=\"lead__title\">技術は深く広く、志は高く</h2>\n                                <p class=\"lead__description\">世界の技術は日々、進歩しています。常に様々なことに目を配り学び、そして、自分のものにできるようにしよう。</p>\n                            </div>\n                        </hgroup>\n                        <hr>\n                        <p class=\"value-comment\">\n                            変化の移り変わりが速いIT業界。自ら調べ、学ぶ力がとても大事です。知識を積むことでお客様に合ったご提案をすることができます。<br>\n                            学び続け、自分の知識を更新することで、さらに高い目標に向かっていきます。\n                        </p>\n                        <a class=\"value-permalink\" href=\"./environment#skillUp\"><span>スキルアップを支援する<br>福利厚生を見る</span></a>\n                    </article>\n                    <!-- / 01 -->\n\n                    <article class=\"value-container js-fadeUp\">\n                        <hgroup class=\"value-heading\">\n                            <h1 class=\"title\">VALUE 02</h1>\n                            <div class=\"lead\">\n                                <h2 class=\"lead__title\">ニーズの一歩先を創造する、真摯に応える</h2>\n                                <p class=\"lead__description\">相手の “本当の” ニーズは何なのか、コミュニケーションを図って、とことん探求しよう。</p>\n                            </div>\n                        </hgroup>\n                        <hr>\n                        <p class=\"value-comment\">お客様自身も気づいてない潜在的なニーズに気づくことが、課題解決以上のプラスに繋がります。ニーズを探るために、お客様とのやり取りを大事にしています。</p>\n                        <a class=\"value-permalink\" href=\"./workers\"><span>社員それぞれの、業務やお客様に<br>対する向き合い方を見る</span></a>\n                    </article>\n                    <!-- / 02 -->\n\n                    <article class=\"value-container js-fadeUp\">\n                        <hgroup class=\"value-heading\">\n                            <h1 class=\"title\">VALUE 03</h1>\n                            <div class=\"lead\">\n                                <h2 class=\"lead__title\">自分と相手の本音を大切にし、認め合う</h2>\n                                <p class=\"lead__description\">一人ひとりの豊かさが、会社や社会の成長、成熟に繋がります。相手はもちろん、自分も大切な一人として尊重しよう。</p>\n                            </div>\n                        </hgroup>\n                        <hr>\n                        <p class=\"value-comment\">自分らしい働き方を大事にしています。お客様や他の社員はもちろん自分とも向き合い、内面を育んでいくことが成長にも繋がります。</p>\n                        <a class=\"value-permalink\" href=\"./environment#benefits\"><span>ワークライフバランスを実現する<br>福利厚生を見る</span></a>\n                    </article>\n                    <!-- / 03 -->\n                </div>\n            </div>\n        </section>\n        <!-- / #ourValues -->\n\n\n        <section id=\"joinUs\">\n    <img class=\"thumbnail\" src=\"./img/common/img-common-join-us-thumbnail.png\" alt=\"\">\n    <div class=\"content\">\n        <h1>JOIN US</h1>\n        <p>きかせて、「明日」のこと</p>\n        <a href=\"https://zynas.co.jp/recruit-contact\" target=\"_blank\" rel=\"noopener noreferrer\">カジュアル面談に応募する</a>\n    </div>\n</section>        \n\n    </main>\n\n\n    <footer id=\"footer\">\n    <div id=\"footerInner\">\n\n        <h1 id=\"footerTop\">\n            <a class=\"home-link\" href=\"./\"><img class=\"logo\" src=\"./img/logo/logo-zynas.svg\" alt=\"Zynas Recruit Site\"></a>\n        </h1>\n\n        <div id=\"footerMiddle\">\n\n            <div id=\"footerMiddle-left\">\n                <ul id=\"footerList-office\">\n                    <li>\n                        <p class=\"office--name\">大分本社</p>\n                        <address class=\"office--content\">\n                            <p class=\"address\">\n                                〒870-0839<br>\n                                大分市金池南1丁目5番1号 コレジオ大分 5階\n                            </p>\n                            <a class=\"googlemaps\" href=\"https://maps.app.goo.gl/J9sYdSpQtp72BwLg7\" target=\"_blank\" rel=\"noopener noreferrer\">Google maps</a>\n                            <p class=\"tel\">TEL&nbsp;：&nbsp;097-547-8639</p>\n                            <p class=\"fax\">FAX&nbsp;：&nbsp;097-547-8619</p>\n                        </address>\n                    </li>\n                    <!-- / item -->\n\n                    <li>\n                        <p class=\"office--name\">東京本社</p>\n                        <address class=\"office--content\">\n                            <p class=\"address\">\n                                〒108-0075<br>\n                                東京都港区港南2丁目16番5号 NBF品川タワー 5階\n                            </p>\n                            <a class=\"googlemaps\" href=\"https://maps.app.goo.gl/mRZkL2NAskAwjdQD7\" target=\"_blank\" rel=\"noopener noreferrer\">Google Maps</a>\n                            <p class=\"tel\">TEL&nbsp;：&nbsp;03-4567-6328</p>\n                        </address>\n                    </li>\n                    <!-- / item -->\n                </ul>\n            </div>\n            <!-- / #footerMiddle-left -->\n\n            <div id=\"footerMiddle-right\">\n\n                <div id=\"footerMiddle-right-01\">\n                    <nav id=\"footerNav-recruit\">\n                        <h1>採用サイトコンテンツ</h1>\n                        <ul>\n                            <li><a href=\"./culture\">カルチャー</a></li>\n                            <li><a href=\"./workers\">働く人</a></li>\n                            <li><a href=\"./environment\">働く環境</a></li>\n                            <li><a href=\"./data\">数字で見るザイナス</a></li>\n                            <li><a href=\"./faq\">よくある質問</a></li>\n                        </ul>\n                    </nav>\n                </div>\n                <!-- / #footerMiddle-02 -->\n\n                <div id=\"footerMiddle-right-02\">\n                    <nav id=\"footerNav-entry\">\n                        <h1>募集要項・エントリー</h1>\n                        <ul>\n                            <li><a href=\"https://open.talentio.com/r/1/c/zynas/homes/3087\" target=\"_blank\" rel=\"noopener noreferrer\">中途採用</a></li>\n                            <!-- <li><a href=\"https://job.rikunabi.com/2025/company/r450110032/\" target=\"_blank\" rel=\"noopener noreferrer\">新卒採用（25卒）</a></li> -->\n                            <!-- <li><a href=\"https://job.mynavi.jp/26/pc/search/corp244872/outline.html\" target=\"_blank\" rel=\"noopener noreferrer\">新卒採用（26卒）</a></li> -->\n                            <li><a href=\"https://job.mynavi.jp/27/pc/search/corp244872/outline.html\" target=\"_blank\" rel=\"noopener noreferrer\">新卒採用（27卒）</a></li>\n                            <li><a href=\"https://zynas.co.jp/recruit-contact\" target=\"_blank\" rel=\"noopener noreferrer\">カジュアル面談・採用お問い合わせ</a></li>\n                        </ul>\n                    </nav>\n\n                    <nav id=\"footerNav-sns\">\n                        <h1>FOLLOW US!</h1>\n                        <ul>\n                            <li><a class=\"note\" href=\"https://note.com/zynas/\" target=\"_blank\" rel=\"noopener noreferrer\" aria-label=\"noteのリンク\"></a></li>\n                            <li><a class=\"x\" href=\"https://twitter.com/zynasCorp\" target=\"_blank\" rel=\"noopener noreferrer\" aria-label=\"Xのリンク\"></a></li>\n                            <li><a class=\"instagram\" href=\"https://www.instagram.com/zynas_corp\" target=\"_blank\" rel=\"noopener noreferrer\" aria-label=\"Instagramのリンク\"></a></li>\n                            <li><a class=\"facebook\" href=\"https://www.facebook.com/zynas.inc\" target=\"_blank\" rel=\"noopener noreferrer\" aria-label=\"Facebookのリンク\"></a></li>\n                        </ul>\n                    </nav>\n                </div>\n                <!-- / #footerMiddle-03 -->\n            </div>\n\n        </div>\n\n        <div id=\"footerBottom\">\n            <nav id=\"footerNav-related\">\n                <h1>関連リンク</h1>\n                <ul>\n                    <li><a class=\"corporation\" href=\"https://zynas.co.jp\" target=\"_blank\" rel=\"noopener noreferrer\">Zynas コーポレートサイト</a></li>\n                    <li><a class=\"privacypolicy\" href=\"https://zynas.co.jp/privacypolicy\" target=\"_blank\" rel=\"noopener noreferrer\">プライバシーポリシー</a></li>\n                </ul>\n            </nav>\n            <p id=\"copyright\">&copy;2026 Zynas Corporation. All Rights Reserved.</p>\n        </div>\n\n    </div>\n</footer>    <!-- JS -->\n    <script src=\"./js/common.js\"></script>\n    <script src=\"./js/header.js\"></script>\n    <script src=\"./js/motion.js\"></script>\n</body>\n\n</html>","finalUrl":"https://zynas.co.jp/recruit/culture","rendered":false,"_cachedAt":"2026-06-23T22:29:49.520Z"}