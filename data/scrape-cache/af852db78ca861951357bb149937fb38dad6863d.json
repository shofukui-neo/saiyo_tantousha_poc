      </nav>\r\n            <nav class=\"p-header__btn\">\r\n                <ul>\r\n                    <li><a href=\"https://www.seibustl.jp/contact/\" class=\"contact\">お問い合わせ</a></li>\r\n                    <li><a href=\"https://www.seibustl.jp/entry/\" class=\"entry\">採用エントリー</a></li>\r\n                </ul>\r\n            </nav>\r\n\r\n            <!-- hamburger -->\r\n            <div class=\"hamburger-demo-menubox\">\r\n                <input id=\"hamburger-demo1\" type=\"checkbox\" class=\"input-hidden\">\r\n                <label for=\"hamburger-demo1\" class=\"hamburger-demo-switch hamburger-demo-switch1 btn-trigger\" id=\"btn01\">\r\n                    <span class=\"hamburger-switch-line1-before\"></span>\r\n                    <span class=\"hamburger-switch-line1\"></span>\r\n                    <span class=\"hamburger-switch-line1-after\"></span>\r\n                </label>\r\n                <div class=\"hamburger-demo-menuwrap\">\r\n                    <dl class=\"ac\">\r\n                        <dt class=\"ac-parent-none\"><a href=\"https://www.seibustl.jp\">トップ</a></dt>\r\n                        <dt class=\"ac-parent-none\"><a href=\"https://www.seibustl.jp/information/\">お知らせ</a></dt>\r\n                        <dt class=\"ac-parent ac-parent1\">\r\n                            <a href=\"https://www.seibustl.jp/business/\">事業内容</a>\r\n                            <span>&nbsp;</span>\r\n                        </dt>\r\n                        <dd class=\"ac-child ac-child1\">\r\n                            <ul>\r\n                                <li><a href=\"https://www.seibustl.jp/business/biz1/\">鉄筋工事業</a></li>\r\n                                <li><a href=\"https://www.seibustl.jp/business/biz2/\">DBヘッド事業</a></li>\r\n                                <li><a href=\"https://www.seibustl.jp/business/biz3/\">鋼製ラス型枠工事業</a></li>\r\n                                <li><a href=\"https://www.seibustl.jp/business/biz4/\">戸建事業</a></li>\r\n                                                            </ul>\r\n                        </dd>\r\n                        <dt class=\"ac-parent-none\"><a href=\"https://www.seibustl.jp/company/\">会社情報</a></dt>\r\n                        <dt class=\"ac-parent-none\"><a href=\"https://www.seibustl.jp/recruit/\">採用情報</a></dt>\r\n                    </dl>\r\n                    <ul class=\"spcv\">\r\n                        <li><a href=\" https://www.seibustl.jp/contact/\" class=\"contact\">お問い合わせ</a></li>\r\n                        <li><a href=\"https://www.seibustl.jp/entry/\" class=\"entry\">採用エントリー</a></li>\r\n                    </ul>\r\n                </div>\r\n                <div class=\"hamburger-demo-cover\"></div>\r\n            </div>\r\n            <!-- hamburger -->\r\n\r\n        </div>\r\n    </header>\r\n    <!-- ---------- //header ---------- -->\r\n\r\n    <div class=\"l-wrapper\">\r\n\r\n                    <div class=\"l-hero\">\r\n                <div class=\"p-hero-home\">\r\n                    <img src=\"https://www.seibustl.jp/wordpress/wp-content/themes/seibustl/images/p-hero-home.jpg\" alt=\"\">\r\n                    <div class=\"p-hero-home__catch\">\r\n                        <h1 class=\"p-hero-home__h1\">人の未来の暮らしを豊かに<br>人々の暮らしを、基礎から支える</h1>\r\n                        <p>確かな素材、確かな技術を提供する<br class=\"sp-only\">建築工事のベストパートナー</p>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n        \r\n        <main class=\"l-main\">\n<section class=\"p-information-home wow fade-in-bottom\">\n    <div class=\"l-container\">\n        <div class=\"c-section-header\">\n            <h2>お知らせ</h2>\n            <span>Information</span>\n        </div>\n                                            <ul>\n                    <li>\n                        <a href=\"https://www.seibustl.jp/information/%e6%b1%82%e4%ba%ba%e9%9a%8f%e6%99%82%e5%8f%97%e4%bb%98%e4%b8%ad%e3%81%a7%e3%81%99%e3%80%82%e3%82%a8%e3%83%b3%e3%83%88%e3%83%aa%e3%83%bc%e3%81%8b%e3%82%89%e3%81%8a%e7%94%b3%e8%be%bc%e3%81%bf%e3%81%8f/\">\n                            <span>2023.04.27</span>\n                            <span>\n                                                                                            </span>\n                            <span>求人随時受付中です。エントリーからお申込みください。</span>\n                        </a>\n                    </li>\n                </ul>\n                            <ul>\n                    <li>\n                        <a href=\"https://www.seibustl.jp/information/%e8%a5%bf%e9%83%a8%e3%82%b9%e3%83%81%e3%83%bc%e3%83%ab%e3%83%9b%e3%83%bc%e3%83%a0%e3%83%9a%e3%83%bc%e3%82%b8%e3%83%aa%e3%83%8b%e3%83%a5%e3%83%bc%e3%82%a2%e3%83%ab%e3%81%ae%e3%81%8a%e7%9f%a5%e3%82%89/\">\n                            <span>2022.06.21</span>\n                            <span>\n                                                                                                    <span>\n                                        <object>\n                                            <a href=\"https://www.seibustl.jp/information_tax/news/\">ニュース</a>                                        </object>\n                                    </span>\n                                                            </span>\n                            <span>西部スチールホームページリニューアルのお知らせ</span>\n                        </a>\n                    </li>\n                </ul>\n                                    <p class=\"more\">\n            <a href=\"https://www.seibustl.jp/information/\" class=\"c-btn-white\">お知らせ一覧</a>\n        </p>\n    </div>\n</section>\n<!-- //.p-information-home -->\n\n<section class=\"p-feature-home wow fade-in-bottom\">\n    <div class=\"l-container\">\n        <div class=\"c-section-header\">\n            <h2>西部スチールだから<br class=\"sp-only\">できること</h2>\n            <span>What we can do</span>\n        </div>\n    </div>\n    <div class=\"p-feature-home__left\">\n        <div class=\"grid-img\">\n            <img src=\"https://www.seibustl.jp/wordpress/wp-content/themes/seibustl/images/p-feature-home-img01.jpg\" alt=\"\">\n        </div>\n        <div class=\"grid-txt\">\n            <h3>絶対の品質</h3>\n            <p>鋼材商社として新たな工法や部品を導入し、鉄筋工事のプロフェッショナル集団としてさまざまな現場を施工。長年のノウハウをもとに、現代の建築に求められる高い品質を追求し続けています。</p>\n            <span>QUALITY</span>\n        </div>\n        <div class=\"grid-btn\">\n            <a href=\"https://www.seibustl.jp/company/#anchor12\" class=\"c-btn-white\">品質に対する取り組み</a>\n        </div>\n    </div>\n    <div class=\"p-feature-home__right\">\n        <div class=\"grid-img\">\n            <img src=\"https://www.seibustl.jp/wordpress/wp-content/themes/seibustl/images/p-feature-home-img02.jpg\" alt=\"\">\n        </div>\n        <div class=\"grid-txt\">\n            <h3>柔軟な建築工事の対応</h3>\n            <p>マンションや商業ビルなどの大規模な現場から、看板の基礎など小規模な現場、戸建住宅まで、ありとあらゆる建造物の鉄筋工事・基礎工事に対応。首都圏一円に約50の協力会社とのネットワークを築いています。</p>\n            <span>FLEXIBILITY</span>\n        </div>\n        <div class=\"grid-btn\">\n            <a href=\"https://www.seibustl.jp/business/\" class=\"c-btn-white\">事業内容</a>\n        </div>\n    </div>\n    <div class=\"p-feature-home__left\">\n        <div class=\"grid-img\">\n            <img src=\"https://www.seibustl.jp/wordpress/wp-content/themes/seibustl/images/p-feature-home-img03.jpg\" alt=\"\">\n        </div>\n        <div class=\"grid-txt\">\n            <h3>安心・安全の現場環境</h3>\n            <p>安全管理の専門部署を中心に、各現場を専任の安全管理責任者がパトロール。建築基準法に適合していることはもちろん、施工の段階ごとに厳格な自主検査を行い、現場の安全・安心を守っています。</p>\n            <span>SAFETY</span>\n        </div>\n        <div class=\"grid-btn\">\n            <a href=\"https://www.seibustl.jp/company/#anchor11\" class=\"c-btn-white\">安心・安全の取り組み</a>\n        </div>\n    </div>\n    <div class=\"p-feature-home__right\">\n        <div class=\"grid-img\">\n            <img src=\"https://www.seibustl.jp/wordpress/wp-content/themes/seibustl/images/p-feature-home-img04.jpg\" alt=\"\">\n        </div>\n        <div class=\"grid-txt\">\n            <h3>低コスト&amp;スピード</h3>\n            <p>独自の「鋼製ラス型枠」製作・施工や、新たな機械式定着工法「DBヘッド」の製造・販売・施工を推進。鉄筋工事の低コスト化と工期スピードアップを実現するとともに、環境への配慮にもつなげています。</p>\n            <span>COST &amp; SPEED</span>\n        </div>\n        <div class=\"grid-btn\">\n            <ul>\n                <li><a href=\"https://www.seibustl.jp/business/biz2/\" class=\"c-btn-white block\">DBヘッド事業</a></li>\n                <li><a href=\"https://www.seibustl.jp/business/biz3/\" class=\"c-btn-white block\">鋼製ラス型枠⼯事業</a></li>\n                <li><a href=\"https://www.seibustl.jp/business/biz4/#anchor01\" class=\"c-btn-white block\">溶接組立鉄筋事業</a></li>\n            </ul>\n        </div>\n    </div>\n</section>\n<!-- //.p-feature-home -->\n\n<section class=\"p-business-home wow fade-in-bottom\">\n    <div class=\"l-container\">\n        <div class=\"c-section-header\">\n            <h2>事業案内</h2>\n            <span>Business info</span>\n        </div>\n        <div class=\"p-business-home__title\">\n            <h3 class=\"c-block-header\">培った鉄筋の専⾨技術と<br class=\"pc-only\">最新技術の融合</h3>\n            <h4>鉄筋工事のプロフェッショナル集団として<br class=\"pc-only\">ありとあらゆる現場をお手伝いします</h4>\n        </div>\n        <div class=\"p-business-home__flex\">\n            <div class=\"p-business-home__txt\">\n                <div>\n                    <p>西部スチールは、鋼材商社としての事業を原点とする鉄筋工事のプロフェッショナル集団です。長年にわたる経験・ノウハウに加え、最新の工法や独自施工技術を生かして、大型ビルや戸建住宅、小規模建造物の基礎工事まで対応。大手にはない機動力と柔軟性で、首都圏一円の現場をお手伝いします。</p>\n                    <div class=\"btn\">\n                        <a href=\"https://www.seibustl.jp/business/\" class=\"c-btn-white\">事業案内</a>\n                    </div>\n                </div>\n            </div>\n            <div class=\"p-business-home__img\">\n                <div class=\"hexagon hexagon01\">\n                    <a href=\"https://www.seibustl.jp/business/biz1/\">\n                        <h4>鉄筋工事業</h4>\n                        <img src=\"https://www.seibustl.jp/wordpress/wp-content/themes/seibustl/images/hexagon01.jpg\" alt=\"鉄筋工事業\">\n                    </a>\n                </div>\n                <div class=\"hexagon hexagon02\">\n                    <a href=\"https://www.seibustl.jp/business/biz2/\">\n                        <h4>DBヘッド<br>定着⼯法</h4>\n                        <img src=\"https://www.seibustl.jp/wordpress/wp-content/themes/seibustl/images/hexagon02.jpg\" alt=\"DBヘッド定着⼯法\">\n                    </a>\n                </div>\n                <div class=\"hexagon hexagon03\">\n                    <a href=\"https://www.seibustl.jp/business/biz3/\">\n                        <h4>鋼製ラス型枠<br>⼯事業</h4>\n                        <img src=\"https://www.seibustl.jp/wordpress/wp-content/themes/seibustl/images/hexagon03.jpg\" alt=\"鋼製ラス型枠⼯事業\">\n                    </a>\n                </div>\n                <div class=\"hexagon hexagon04\">\n                    <a href=\"https://www.seibustl.jp/business/biz4/\">\n                        <h4>⼾建事業</h4>\n                        <img src=\"https://www.seibustl.jp/wordpress/wp-content/themes/seibustl/images/hexagon04.jpg\" alt=\"⼾建事業\">\n                    </a>\n                </div>\n                <div class=\"hexagon hexagon05\">\n                    <a href=\"https://www.seibustl.jp/business/biz4/#anchor01\">\n                        <h4>溶接組⽴鉄筋<br>事業</h4>\n                        <img src=\"https://www.seibustl.jp/wordpress/wp-content/themes/seibustl/images/hexagon05.jpg\" alt=\"溶接組⽴鉄筋事業\">\n                    </a>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>\n<!-- //.p-business-home -->\n\n<section class=\"p-company-home wow fade-in-bottom\">\n    <div class=\"l-container\">\n        <div class=\"c-section-header\">\n            <h2>会社案内</h2>\n            <span>Corporate</span>\n        </div>\n    </div>\n    <div class=\"p-company-home__grid\">\n        <div class=\"grid-txt\">\n            <h3 class=\"c-block-header\">未来の建築と<br>施工現場を創造</h3>\n        </div>\n        <div class=\"grid-img\">\n            <img src=\"https://www.seibustl.jp/wordpress/wp-content/themes/seibustl/images/p-company-home.jpg\" alt=\"\">\n        </div>\n        <div class=\"grid-btn\">\n            <ul>\n                <li><a href=\"https://www.seibustl.jp/company/#anchor01\" class=\"c-btn-white block\">代表メッセージ</a></li>\n                <li><a href=\"https://www.seibustl.jp/company/#anchor02\" class=\"c-btn-white block\">私たちの取り組み</a></li>\n                <li><a href=\"https://www.seibustl.jp/company/#anchor03\" class=\"c-btn-white block\">会社概要</a></li>\n                <li><a href=\"https://www.seibustl.jp/company/#anchor04\" class=\"c-btn-white block\">西部スチールグループ</a></li>\n            </ul>\n        </div>\n    </div>\n</section>\n<!-- //.p-company-home -->\n\n<section class=\"p-recruit-home wow fade-in-bottom\">\n    <div class=\"l-container\">\n        <div class=\"c-section-header\">\n            <h2>採用情報</h2>\n            <span>Recruit</span>\n        </div>\n    </div>\n    <div class=\"p-recruit-home__grid\">\n        <div class=\"grid-img\">\n            <img src=\"https://www.seibustl.jp/wordpress/wp-content/themes/seibustl/images/p-recruit-home.jpg\" alt=\"\">\n        </div>\n        <div class=\"grid-txt\">\n            <h3 class=\"c-block-header\">街の未来をつくる<br>刺激的な仕事</h3>\n            <p>\n                確かな技術と知識を学び、<br>\n                プロフェッショナルを目指せる場があります。\n            </p>\n            <p class=\"en\">BUILD <br class=\"sp-only\">THE FUTURE</p>\n            <ul>\n                <li><a href=\"https://www.seibustl.jp/recruit/\" class=\"c-btn-blue\">採用情報</a></li>\n                <li><a href=\"https://www.seibustl.jp/entry/\" class=\"c-btn-blue\">採用エントリー</a></li>\n            </ul>\n        </div>\n    </div>\n</section>\n<!-- //.p-company-home -->\n\n</main>\r\n<!-- ---------- //.l-main ---------- -->\r\n\r\n</div>\r\n<!-- ---------- //.l-wrapper ---------- -->\r\n\r\n    <div class=\"l-cta\">\r\n        <div class=\"p-cta\">\r\n            <div class=\"l-container\">\r\n                <h2>お