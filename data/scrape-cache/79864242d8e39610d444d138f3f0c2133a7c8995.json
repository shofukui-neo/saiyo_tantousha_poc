{"url":"http://www.tsuyamagroup.co.jp/recruit.html","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n<head>\n  <!-- Google Tag Manager -->\n  <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\n  new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\n  j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n  'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n  })(window,document,'script','dataLayer','GTM-MHHTS2');</script>\n  <!-- End Google Tag Manager -->\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <meta http-equiv=\"X-UA-Compatible\" content=\"ie=edge\">\n  <meta name=\"description\" content=\"昭和59年3月に設立以来、地域に根ざし時代と共に変わりゆく食のニーズに応え福祉施設や学校、産業の食事の提供を行なってきました。食べる方の喜びや健康維持の為、安全安心美味しい食事の提供をいたします。\">\n  <meta name=\"keywords\" content=\"津山商店,新潟,南魚沼,浦佐,給食,衛生,求人,栄養士,調理師,クックチル,ケータリング,物流,調達\">\n  <title>株式会社津山商店</title>\n  <link rel=\"stylesheet\" href=\"css/style.css\">\n  <link rel=\"stylesheet\" href=\"assets/css/style.css\">\n\t<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\">\n\t<link href=\"https://fonts.googleapis.com/css2?family=Kalam:wght@300;400;700&family=Noto+Sans+JP:wght@400;500;700&family=Oswald:wght@400;500;600&display=swap\" rel=\"stylesheet\">\n\t<link rel=\"shortcut icon\" href=\"favicon.ico\">\n</head>\n<body>\n  <!-- Google Tag Manager (noscript) -->\n  <noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-MHHTS2\"\n  height=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n  <!-- End Google Tag Manager (noscript) -->\n\n\t<header class=\"header\">\n\t\t<div class=\"header-top\">\n\t\t\t<h1 class=\"header__tit\"><a href=\"index.html\"><img src=\"img/header-logo.png\" alt=\"株式会社 津山商店\"></a></h1>\n\t\t\t<nav class=\"gnav js-nav\">\n\t\t\t\t<div class=\"gnav-inner\">\n\t\t\t\t\t<ul class=\"gnav__list\">\n\t\t\t\t\t\t<li class=\"gnav__list__item\"><a href=\"service.html\">サービス紹介</a></li>\n\t\t\t\t\t\t<li class=\"gnav__list__item\"><a href=\"recruit.html\">採用情報</a></li>\n\t\t\t\t\t\t<li class=\"gnav__list__item\"><a href=\"company.html\">会社案内</a></li>\n\t\t\t\t\t\t<li class=\"gnav__list__item\"><a href=\"group.html\">グループ会社</a></li>\n\t\t\t\t\t\t<li class=\"gnav__list__item snsicon\">\n\t\t\t\t\t\t\t<div>\n\t\t\t\t\t\t\t\t<a href=\"https://www.instagram.com/tsuyamagroup/?hl=ja\" target=\"_blank\"><img\n\t\t\t\t\t\t\t\t\t\tsrc=\"img/ig_icon.png\" alt=\"Instagram\"></a>\n\t\t\t\t\t\t\t\t<a href=\"https://www.facebook.com/tsuyamagroup/\" target=\"_blank\"><img\n\t\t\t\t\t\t\t\t\t\tsrc=\"img/fb_icon.png\" alt=\"Facebook\"></a>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</li>\n\t\t\t\t\t</ul>\n\t\t\t\t\t<div class=\"gnav-contact\"><a href=\"mailto:info@tsuyamagroup.co.jp\">お問い合わせ</a></div>\n\t\t\t\t</div>\n\t\t\t\t<div class=\"gnav-overlay js-nav-overlay hidden-pc\"></div>\n\t\t\t</nav>\n\t\t</div>\n\t\t<div class=\"main_img\">\n\t\t\t<img src=\"img/main_img01_pc.jpg\" alt=\"RECRUIT 株式会社津山商店　採用情報サイト\" class=\"main_img_img hidden-sp\">\n\t\t\t<img src=\"img/main_img01_sp.jpg\" alt=\"RECRUIT 株式会社津山商店　採用情報サイト\" class=\"main_img_img hidden-pc\">\n\t\t</div>\n\t\t<div class=\"navBtn js-nav-btn hidden-pc\"><span></span><span></span><span></span></div>\n\t</header>\n\n\t<main>\n\n\t\t<section class=\"secMessage\">\n\t\t\t<div class=\"c-inner01\">\n\t\t\t\t<h2 class=\"secMessage__tit\">新潟で頑張りたい！<br>\n\t\t\t\tそんなスタッフを募集しています</h2>\n\t\t\t\t<p class=\"secMessage__txt\">津山商店は、病院・福祉施設<br class=\"hidden-sp\">（特別養護老人ホームや介護福祉施設、学生食堂、社員食堂）の給食受託を行っています。<br>\n\t\t\t\t当業界では、現在日本全体が高齢化へ進み行く中、更に需要が高まって来ると考えます。<br>\n\t\t\t\t現在、津山商店では新潟県を中心に約80箇所の事業所があります。<br>\n\t\t\t\t管理栄養士・栄養士・調理師の免許をお持ちの方、<br class=\"hidden-sp\">経験者はもちろん、経験の無い方も、どなたでも津山商店の<br class=\"hidden-sp\">研修を受けて頂ければ勤めて頂く事ができます。<br class=\"hidden-sp\">楽しく皆んなで一緒にお仕事しませんか？</p>\n\t\t\t\t<div class=\"go-list-btn\"><a href=\"mailto:info@tsuyamagroup.co.jp\">お問い合わせ</a></div>\n\t\t\t\t<!-- <div class=\"go-list-btn\"><a href=\"https://tsuyamagroup-saiyo.jp/job/-/info/list\">求人一覧へ</a></div> -->\n\t\t\t</div>\n\t\t</section>\n\t\t<!-- .secMessage -->\n\n\t\t<!-- <section class=\"secArea\">\n\t\t\t<div class=\"c-inner01\">\n\t\t\t\t<h2 class=\"secArea__tit c-tit01 is-center\"><span class=\"c-tit01__en\">SEARCH BY AREA</span>エリアから探す</h2>\n\t\t\t\t<div class=\"secArea-select js-select-set\">\n\t\t\t\t\t<select class=\"area01 js-select-parent\" name=\"area01\">\n\t\t\t\t\t\t<option value=\"\" selected=\"selected\">都道府県を選択してください</option>\n\t\t\t\t\t\t<option value=\"新潟県\">新潟県</option>\n\t\t\t\t\t\t<option value=\"東京都\">東京都</option>\n\t\t\t\t\t\t<option value=\"https://tsuyamagroup-saiyo.jp/job/-/info/list?word=%E3%81%9D%E3%81%AE%E4%BB%96%E3%81%AE%E3%82%A8%E3%83%AA%E3%82%A2\">その他</option>\n\t\t\t\t\t</select>\n\t\t\t\t\t<select class=\"area02 js-select-children\" name=\"area02\" disabled>\n\t\t\t\t\t\t<option value=\"\" selected=\"selected\">市区町村を選択してください</option>\n\t\t\t\t\t\t<option value=\"https://tsuyamagroup-saiyo.jp/job/-/info/list?area=3&pref=15&city=15226\" data-val=\"新潟県\">南魚沼市</option>\n\t\t\t\t\t\t<option value=\"https://tsuyamagroup-saiyo.jp/job/-/info/list?area=3&pref=15&city=15461\" data-val=\"新潟県\">南魚沼郡湯沢町</option>\n\t\t\t\t\t\t<option value=\"https://tsuyamagroup-saiyo.jp/job/-/info/list?area=3&pref=15&city=15225\" data-val=\"新潟県\">魚沼市</option>\n\t\t\t\t\t\t<option value=\"https://tsuyamagroup-saiyo.jp/job/-/info/list?area=3&pref=15&city=15202\" data-val=\"新潟県\">長岡市</option>\n\t\t\t\t\t\t<option value=\"https://tsuyamagroup-saiyo.jp/job/-/info/list?area=3&pref=15&city=15210\" data-val=\"新潟県\">十日町市</option>\n\t\t\t\t\t\t<option value=\"https://tsuyamagroup-saiyo.jp/job/-/info/list?area=3&pref=15&city=15208\" data-val=\"新潟県\">小千谷市</option>\n\t\t\t\t\t\t<option value=\"https://tsuyamagroup-saiyo.jp/job/-/info/list?area=3&pref=15&city=15211\" data-val=\"新潟県\">見附市</option>\n\t\t\t\t\t\t<option value=\"https://tsuyamagroup-saiyo.jp/job/-/info/list?area=3&pref=15&city=15205\" data-val=\"新潟県\">柏崎市</option>\n\t\t\t\t\t\t<option value=\"https://tsuyamagroup-saiyo.jp/job/-/info/list?area=3&pref=15&city=15204\" data-val=\"新潟県\">三条市</option>\n\t\t\t\t\t\t<option value=\"https://tsuyamagroup-saiyo.jp/job/-/info/list?area=3&pref=15&city=15107\" data-val=\"新潟県\">新潟市西区</option>\n\t\t\t\t\t\t<option value=\"https://tsuyamagroup-saiyo.jp/job/-/info/list?area=3&pref=15&city=15103\" data-val=\"新潟県\">新潟市中央区</option>\n\t\t\t\t\t\t<option value=\"https://tsuyamagroup-saiyo.jp/job/-/info/list?area=3&pref=15&city=15105\" data-val=\"新潟県\">新潟市秋葉区</option>\n\t\t\t\t\t\t<option value=\"https://tsuyamagroup-saiyo.jp/job/-/info/list?area=3&pref=15&city=15106\" data-val=\"新潟県\">新潟市南区</option>\n\t\t\t\t\t\t<option value=\"https://tsuyamagroup-saiyo.jp/job/-/info/list?area=3&pref=15&city=15102\" data-val=\"新潟県\">新潟市東区</option>\n\t\t\t\t\t\t<option value=\"https://tsuyamagroup-saiyo.jp/job/-/info/list?area=3&pref=15&city=15222\" data-val=\"新潟県\">上越市</option>\n\t\t\t\t\t\t<option value=\"https://tsuyamagroup-saiyo.jp/job/-/info/list?area=3&pref=15&city=15217\" data-val=\"新潟県\">妙高市</option>\n\t\t\t\t\t\t<option value=\"https://tsuyamagroup-saiyo.jp/job/-/info/list?area=2&pref=13&city=13201\" data-val=\"東京都\">八王子市</option>\n\t\t\t\t\t\t<option value=\"https://tsuyamagroup-saiyo.jp/job/-/info/list?area=2&pref=13&city=13212\" data-val=\"東京都\">日野市</option>\n\t\t\t\t\t</select>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</section> -->\n\t\t<!-- .secArea -->\n\n\t\t<!-- <section class=\"secPlace\">\n\t\t\t<div class=\"secPlace-inner c-inner01\">\n\t\t\t\t<h2 class=\"secPlace__tit c-tit01 is-center\"><span class=\"c-tit01__en\">SEARCH BY WORKPLACE</span>職場から探す</h2>\n\t\t\t\t<ul class=\"secPlace-list\">\n\t\t\t\t\t<li class=\"secPlace-list__item\">\n\t\t\t\t\t\t<a href=\"https://tsuyamagroup-saiyo.jp/job/-/info/list?brand=B0001\">\n\t\t\t\t\t\t\t<img src=\"img/img_service01.jpg\" alt=\"\" class=\"secPlace-list__item__img\">\n\t\t\t\t\t\t\t<p class=\"secPlace-list__item_