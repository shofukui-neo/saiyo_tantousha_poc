{"url":"https://www.asahitatemonokanri.co.jp/inquiry/","html":"<!doctype html>\n<html>\n<head prefix=\"og: http://ogp.me/ns# fb: http://ogp.me/ns/fb# article: http://ogp.me/ns/article#\">\n<meta charset=\"utf-8\">\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n<title>お問い合わせ | 朝日建物管理株式会社</title>\n<meta name=\"keywords\" content=\"朝日,管理,不動産,清掃,ビルメン,警備,設備,技術,総合管理,貸しビル,大阪,東京,名古屋,ビル管理,ビル設備\">\n<meta name=\"description\" content=\"朝日建物管理株式会社ウェブサイト\">\n<!--#include virtual=\"/common/inc/common.inc\"-->\n<!--#include virtual=\"/common/inc/common_css.inc\"-->\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<meta name=\"format-detection\" content=\"telephone=no\">\n<meta http-equiv=\"content-language\" content=\"ja\">\n<link rel=\"stylesheet\" href=\"/common/css/reset.css\">\n<link rel=\"stylesheet\" href=\"/common/css/print.css\" media=\"print\">\n<link rel=\"stylesheet\" href=\"/common/css/common.css\">\n<link rel=\"stylesheet\" href=\"/common/css/common_sp.css\">\n<link rel=\"stylesheet\" href=\"/inquiry/css/inquiry.css\">\n<link rel=\"stylesheet\" href=\"/inquiry/css/inquiry_sp.css\">\n<!--#include virtual=\"/common/inc/common_js.inc\"-->\n<script src=\"/common/js/jquery.js\"></script>\n<script src=\"/common/js/jquery.easing.js\"></script>\n<script src=\"/common/js/common.js?ver=1\"></script>\n<script src=\"/inquiry/js/inquiry.js\"></script>\n<!--#include virtual=\"/common/inc/gtm.inc\"-->\n<!-- Google Tag Manager -->\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n})(window,document,'script','dataLayer','GTM-KM9NWHL');</script>\n<!-- End Google Tag Manager -->\n<!-- Global site tag (gtag.js) - Google Analytics -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=UA-38894027-1\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n  gtag('config', 'UA-38894027-1');\n</script>\n<link rel=\"stylesheet\" href=\"css/validationEngine.jquery.css\" type=\"text/css\"/>\n<script src=\"js/jquery-1.10.2.min.js\" type=\"text/javascript\"></script>\n<script src=\"js/jquery.validationEngine.js\" type=\"text/javascript\" charset=\"utf-8\"></script>\n<script src=\"js/jquery.validationEngine-ja.js\" type=\"text/javascript\" charset=\"utf-8\"></script>\n<script>\n\tjQuery(document).ready(function(){\n\tjQuery(\"#formmail\").validationEngine('attach', {\n\tpromptPosition:\"bottomLeft\"\n\t});\n});\n</script>\n</head>\n<body id=\"inquiry\" class=\"idxPage\">\n<!--#include virtual=\"/common/inc/gtm_no.inc\"-->\n<!-- Google Tag Manager (noscript) -->\r\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-KM9NWHL\"\r\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\r\n<!-- End Google Tag Manager (noscript) -->\r\n<div id=\"container\">\n  <!--#include virtual=\"/common/inc/header.inc\"-->\n  <p class=\"skip-link\"><a href=\"#contentsWrap\">メインコンテンツへ移動</a></p>\n<header id=\"siteHeader\">\n  <div id=\"headerWrap\" class=\"cf\">\n    <h1>\n      <a href=\"/\"><img src=\"/common/images/header_img_logo.gif\" alt=\"朝日建物管理株式会社\" /></a>\n    </h1>\n    <div id=\"gNaviSection\">\n      <nav aria-label=\"グローバルナビゲーション\">\n        <ul>\n          <li><a href=\"/\">ホーム</a></li>\n          <li><a href=\"/business/\">業務案内</a></li>\n          <li><a href=\"/recruit/\">求人案内</a></li>\n          <li><a href=\"/company/\">会社案内</a></li>\n          <li><a href=\"/inquiry/\">お問い合わせ</a></li>\n        </ul>\n      </nav>\n    </div>\n    <p id=\"spMenuBtn\">\n      <button type=\"button\" aria-label=\"メニューを開く\" aria-controls=\"gNaviSection\" aria-expanded=\"false\">\n        <img src=\"/common/images/header_btn_menu_open.gif\" alt=\"\" />\n      </button>\n    </p>\n  </div>\n</header>\n  <main id=\"main\" tabindex=\"-1\">\n    <div id=\"mvWrap\">\n      <div id=\"mvSection\">\n        <h2>お問い合わせ</h2>\n      </div>\n    </div>\n    <div id=\"breadCrumbWrap\">\n      <ul id=\"breadCrumbList\">\n        <li><a href=\"/\">ホーム</a></li>\n        <li>お問い合わせ</li>\n      </ul>\n    </div>\n    <div id=\"contentsWrap\">\n      <div class=\"contentsSection\">\n\t\t  \n\t\t  \n        <div class=\"contentsArea\">\n          <p>下記お問い合わせフォームに必要事項をご記入の上、送信してください。<br>\n          （こちらのお問い合わせフォームからのセールス・勧誘などは固くお断りいたします。）<br>\n          尚、<a href=\"/privacy/\" target=\"_blank\">当社の個人情報保護に関しましてはこちら</a>をご参照ください。</p>\n          \n          <div>\n            <form action=\"index.html\" method=\"post\" name=\"form\" id=\"formmail\">\n\t\t      <input type=\"hidden\" name=\"mode\" value=\"confirm\">\n              <table class=\"type01Table mt20 spMt5per\">\n                <tr>\n                  <th><label for=\"subject\">件名<span class=\"txtColor01\">（必須）</span></label></th>\n                  <td><input class=\"w600 spW100per validate[required]\" name=\"subject\" type=\"text\"></td>\n                </tr>\n                <tr>\n                  <th><label for=\"content\">お問合せ内容<span class=\"txtColor01\">（必須）</span></label></th>\n                  <td><textarea class=\"w600 spW100per validate[required]\" name=\"content\"></textarea></td>\n                </tr>\n                <tr>\n                  <th><label for=\"name\">お名前<span class=\"txtColor01\">（必須）</span></label></th>\n                  <td><input class=\"w200 spW100per validate[required]\" name=\"name\" type=\"text\"></td>\n                </tr>\n                <tr>\n                  <th><label for=\"kana\">フリガナ<span class=\"txtColor01\">（必須）</span></label></th>\n                  <td><input class=\"w200 spW100per validate[required]\" name=\"kana\" type=\"text\"></td>\n                </tr>\n                <tr>\n                  <th><label for=\"cname\">会社名</label></th>\n                  <td><input class=\"w400 spW100per\" name=\"cname\" type=\"text\"></td>\n                </tr>\n                <tr>\n                  <th><label for=\"busho\">所属部署</label></th>\n                  <td><input class=\"w400 spW100per\" name=\"busho\" type=\"text\"></td>\n                </tr>\n                <tr>\n                  <th><label for=\"yakushoku\">役職</label></th>\n                  <td><input class=\"w400 spW100per\" name=\"yakushoku\" type=\"text\"></td>\n                </tr>\n                <tr>\n                  <th><label for=\"zip\">郵便番号</label></th>\n                  <td><input class=\"w80 spW100per\" name=\"zip\" type=\"text\"></td>\n                </tr>\n                <tr>\n                  <th><label for=\"addr\">ご住所</label></th>\n                  <td><input class=\"w500 spW100per\" name=\"addr\" type=\"text\"></td>\n                </tr>\n                <tr>\n                  <th><label for=\"tel\">電話番号<span class=\"txtColor01\">（必須）</span></label></th>\n                  <td><input class=\"w200 spW100per validate[required,custom[phone]]\" name=\"tel\" type=\"text\"></td>\n                </tr>\n                <tr>\n                  <th><label for=\"fax\">FAX</label></th>\n                  <td><input class=\"w200 spW100per\" name=\"fax\" type=\"text\"></td>\n                </tr>\n                <tr>\n                  <th><label for=\"email\">email<span class=\"txtColor01\">（必須）</span></label></th>\n                  <td><input class=\"w340 spW100per validate[required,custom[email]]\" name=\"email\" type=\"text\"></td>\n                </tr>\n              </table>\n              <p class=\"mt50 spMt5per\">ご記入頂きました内容は「当ページにご入力いただく個人情報の取り扱いについて」をお読みになり同意いただける方は、画面下の同意ボタンを押して次にお進みください。</p>\n              <input name=\"個人情報の取り扱い\" value=\"同意\" type=\"hidden\">\n              <div class=\"iframeBox\">\n                <iframe src=\"/privacy/privacy.html\" frameborder=\"0\"></iframe>\n              </div>\n              <div class=\"txtCenter mt30 spMt5per\">\n                <p class=\"formBtn\"><input name=\"\" value=\"リセット\" type=\"reset\">　<input name=\"\" value=\"同意\" type=\"submit\"></p>\n              </div>\n            </form>\n          </div>\n\n        </div>\n\t\t      </div>\n    </div>\n  </main>\n\n  <!--#include virtual=\"/common/inc/footer.inc\"-->\n    <footer>\n    <div id=\"footerWrap\">\n      <p id=\"pageTopBtn\"><a href=\"#container\"><img src=\"/common/images/footer_btn_pagetop.gif\" alt=\"ページトップ\"></a></p>\n      <div id=\"footerTopSection\" class=\"cf\">\n        <ul>\n          <li><a href=\"/privacy/\">プライバシーポリシー</a></li>\n          <li><a href=\"/sitemap/\">サイトマップ</a></li>\n        </ul>\n      </div>\n      <div id=\"footerBottomSection\" class=\"cf\">\n        <p>Copyright(C) 2004-2026 朝日建物管理株式会社</p>\n      </div>\n    </div>\n  </footer>\n</div>\n<!--#include virtual=\"/common/inc/container_eof.inc\"-->\n</body>\n</html>\n","finalUrl":"https://www.asahitatemonokanri.co.jp/inquiry/","rendered":false,"_cachedAt":"2026-06-22T22:15:34.427Z"}