{"url":"https://www.tsdm.co.jp/tsdm/webapp/ssl/contact/index_j.htm","html":"<!DOCTYPE HTML>\r\n\r\n<html lang=\"ja\">\r\n\r\n<head><script src=\"/_fec_sbu/fec_wrapper.js\"></script>\n<script id=\"wsyzwdbq\" src=\"/_fec_sbu/hxk_fec_16b50213.js\">kcBwMYepZ5BjdIvq5uKzMcAOMKmygZFb,6s6A1qcGfi6mdW3T0S6K5AasfD1E0Ebo,s9ob9l1Fy6zU4mN7oKdMp9k7b5tbyffr,9OYaIsB5w3BGQ7vu6lIPUzc3NTiPzHq6,SQrNWoRnO0e0s580ANJIqbgRc0m5Bmfa,VcFD1V46CDjkehMHdF7XbGeG16ZTIsea,V636KUz7ifZiNC8WdNUe22y0GSQS1Ti6,8VDhX30Q6GNCjfta9HpYgPJR9hfSsTOj,Pqt20VnBVadT2mqfz42v6dtbp1v0naFu,NK2JSGLiOvkhQk5TA3szOeWXqjPZrD6a,</script>\n\r\n\r\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\r\n\r\n<meta charset=\"utf-8\">\r\n\r\n<meta http-equiv=\"Content-Type\" content=\"text/html; charset=utf-8\">\r\n\r\n\r\n\r\n<meta name=\"viewport\" content=\"width=device-width,user-scalable=yes\">\r\n\r\n<meta name=\"format-detection\" content=\"telephone=no\">\r\n\r\n\r\n\r\n<meta name=\"Keywords\" content=\"東芝電材マーケティング,電材,電設資材,照明器具,LED,蓄電池,太陽光発電,お問い合わせ\">\r\n\r\n<meta name=\"Description\" content=\"東芝電材マーケティング株式会社のお問い合わせフォームのページです。東芝電材マーケティングは、太陽光発電からLED照明、高圧受変電設備などの電気設備をはじめ、住宅設備や通信情報設備などを幅広く販売する総合電設資材商社です。\">\r\n\r\n<title>お問い合わせ | 東芝電材マーケティング株式会社</title>\r\n\r\n<link rel=\"start\" href=\"/tsdm/index_j.htm\" title=\"東芝電材マーケティング株式会社トップページ\">\r\n\r\n<link rel=\"help\" href=\"/tsdm/sitemap.htm\" title=\"サイトマップ\">\r\n\r\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/tsdm/common/css/2013/import_contents.css\" media=\"all\">\r\n\r\n<!-- for_pc -->\r\n\r\n<link href=\"/tsdm/css/structure_pc.css\" rel=\"stylesheet\" type=\"text/css\" media=\"only screen and (min-width:481px)\">\r\n\r\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/tsdm/css/contact.css\" media=\"all\">\r\n\r\n<!-- for_handheld -->\r\n\r\n<link href=\"/tsdm/css/structure_sp.css\" rel=\"stylesheet\" type=\"text/css\" media=\"only screen and (max-width:480px)\">\r\n\r\n\r\n<script type=\"text/javascript\" src=\"/tsdm/common/jvs/2013/analytics.js\"></script>\r\n<script type=\"text/javascript\" src=\"/tsdm/common/jvs/2011b/mjl.js\"></script>\r\n<script type=\"text/javascript\" src=\"/tsdm/jvs/jquery-3.6.0.min.js\"></script>\r\n<script type=\"text/javascript\" src=\"/tsdm/common/jvs/2013/linkoff.js\"></script>\r\n<script type=\"text/javascript\" src=\"/tsdm/common/jvs/2013/run.js\"></script>\r\n<script type=\"text/javascript\" src=\"/tsdm/jvs/input.js\"></script> <!--[if lt IE 9]> \r\n\r\n<script src=\"/tsdm/jvs/html5shiv.js\"></script>\r\n\r\n<![endif]-->\r\n\r\n</head>\r\n\r\n<body>\r\n<!-- Google Tag Manager (noscript) -->\r\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-WTJD8K3\"\r\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\r\n<!-- End Google Tag Manager (noscript) -->\r\n<header id=\"gHeader\">\r\n\r\n\t<section id=\"tos_line\">\r\n\r\n  \t<div id=\"logo\"><a href=\"https://www.global.toshiba/jp/top.html\"><img src=\"/tsdm/common/img/head/logo_l.gif\" alt=\"東芝トップページ\" width=\"161\" height=\"64\" id=\"totop\"></a><a href=\"#mainContents\" class=\"jumpContents\">本文へジャンプ</a></div>\r\n\r\n    \r\n\r\n    <p id=\"identifier\"><a href=\"https://www.tsdm.co.jp/tsdm/index_j.htm\"><img src=\"/tsdm/common/img/head/identifier.png\" alt=\"東芝電材マーケティング\" width=\"218\" height=\"16\"></a></p>\r\n\r\n\t\t<p id=\"switch_menu\"><a href=\"#\"><img src=\"/tsdm/images/common/icon-spmenu.png\" alt=\"ナビ\" /></a></p>\r\n\r\n    </section>\r\n\r\n\t<nav id=\"mainNav\">\r\n\r\n\t\t<ul id=\"globalNav\">\r\n\r\n\t\t\t<li id=\"g_home\"><a href=\"http://www.tsdm.co.jp/tsdm/index_j.htm\">トップページ</a></li>\r\n\r\n\t\t\t<li id=\"g_guide\"><a href=\"http://www.tsdm.co.jp/tsdm/guide/index_j.htm\">事業内容</a></li>\r\n\r\n            <li id=\"g_products\"><a href=\"http://www.tsdm.co.jp/tsdm/products/index_j.htm\">取扱商品</a></li>\r\n\r\n            <li id=\"g_company\"><a href=\"http://www.tsdm.co.jp/tsdm/company/index_j.htm\">企業情報</a></li>\r\n\r\n            <li id=\"g_office\"><a href=\"http://www.tsdm.co.jp/tsdm/company/office.htm\">事業所</a></li>\r\n\r\n            <li id=\"g_closeup\"><a href=\"http://www.tsdm.co.jp/tsdm/customer/index_j.htm\">得意先向け情報</a></li>\r\n\r\n\t    </ul>\r\n\r\n\r\n\r\n        <ul id=\"headerSubNav\" class=\"doAct\">\r\n\r\n            <li class=\"sitemap\"><a href=\"http://www.tsdm.co.jp/tsdm/sitemap.htm\">サイトマップ</a></li>\r\n\r\n            <li class=\"contact\"><a href=\"http://www.tsdm.co.jp/tsdm/contact/index_j.htm\">お問い合わせ</a></li>\r\n\r\n            <li class=\"closemenu\"><a href=\"#\">閉じる</a></li>\r\n\r\n        </ul>\r\n\r\n\t</nav>\r\n\r\n</header>\r\n\r\n\r\n\r\n<section id=\"mainContents\">\r\n\r\n<div class=\"container clear\">\r\n\r\n\t<div id=\"stepNav\"><span id=\"stephome\"><a href=\"http://www.tsdm.co.jp/tsdm/index_j.htm\">東芝電材マーケティングトップページ</a></span> &gt; <a href=\"http://www.tsdm.co.jp/tsdm/contact/index_j.htm\">お問い合わせ</a> &gt; お問い合わせフォーム</div>\r\n\r\n</div>\r\n\r\n<div class=\"container clear\">\r\n\r\n<h1 class=\"tit_lv1\">お問い合わせ</h1>\r\n\r\n<div id=\"contact\">\r\n\r\n  <p class=\"indent-lv1 pb10\">お問い合わせいただく前に、<a href=\"#notice\">お問い合わせいただく前の注意</a>をお読みください。</p>\r\n\r\n  <p class=\"indent-lv1 brsg4\">（注1） Ｅメール以外の方法で回答させていただく場合もございますので、ご記入の際には以下をご注意いただき、\r\n\r\n    <span class=\"required\"><img src=\"images/icon_required.png\" width=\"40\" height=\"17\" alt=\"必須\"></span>と表記されている項目には必ずご記入・ご選択ください。</p>\r\n\r\n  <p class=\"indent-lv1 brsg4\">（注2） 半角カタカナや外字、特殊記号は使用出来ません（正常に表示されない場合があります）。</p><br>\r\n\r\n  \r\n\r\n  \r\n\r\n  <h2>お問い合わせ内容</h2>\r\n\r\n  \r\n\r\n  <form method=\"post\" action=\"#\">\r\n\r\n    <h3>お問い合わせ分類（お問い合わせの分類をお選びください） <span class=\"required\"><img src=\"images/icon_required.png\" width=\"40\" height=\"17\" alt=\"必須\"></span></h3>\r\n\r\n    <div class=\"answer\">\r\n\r\n      <select name=\"Category\" id=\"Category\">\r\n\r\n    <option value=\"\">▼ご選択ください</option><br /><option value=\"営業拠点のお問い合わせ\">営業拠点のお問い合わせ</option><br /><option value=\"取扱商品のお問い合わせ\">取扱商品のお問い合わせ</option><br /><option value=\"再エネアグリゲーションサービスのお問い合わせ\">再エネアグリゲーションサービスのお問い合わせ</option><br /><option value=\"会社全般のお問い合わせ\">会社全般のお問い合わせ</option><br /><option value=\"リンクや画像利用のお問い合わせ\">リンクや画像利用のお問い合わせ</option><br /><option value=\"当サイトに関するお問い合わせ\">当サイトに関するお問い合わせ</option><br /><option value=\"その他のお問い合わせ\">その他のお問い合わせ</option><br />\r\n\r\n    </select>\r\n\r\n      <span class=\"msg\"></span>\r\n\r\n      </div>\r\n\r\n    \r\n\r\n    <h3>件名 <span class=\"required\"><img src=\"images/icon_required.png\" width=\"40\" height=\"17\" alt=\"必須\"></span></h3>\r\n\r\n    <div class=\"answer\">\r\n\r\n      <input class=\"input1\" type=\"text\" name=\"Subject\" id=\"Subject\" value=\"\" maxlength=\"64\">\r\n\r\n      <span class=\"msg\"></span>\r\n\r\n      </div>\r\n\r\n    \r\n\r\n    <h3>お問い合わせ内容 <span class=\"required\"><img src=\"images/icon_required.png\" width=\"40\" height=\"17\" alt=\"必須\"></span>（内容はできるだけ詳しくご記入ください）（全角１０００文字以内）</h3>\r\n\r\n    <div class=\"answer\">\r\n\r\n      <textarea class=\"input1\" name=\"Inquiry\" id=\"Inquiry\" rows=\"4\" wrap=\"soft\"></textarea>\r\n\r\n      <span class=\"msg\"></span>\r\n\r\n      </div>\r\n\r\n    \r\n\r\n    <h2>お客様情報</h2>\r\n\r\n    \r\n\r\n    <h3>お名前 <span class=\"required\"><img src=\"images/icon_required.png\" width=\"40\" height=\"17\" alt=\"必須\"></span></h3>\r\n\r\n    <div class=\"answer\">\r\n\r\n      <input class=\"input1\" type=\"text\" name=\"Name\" id=\"Name\" value=\"\" maxlength=\"64\" /><span class=\"note\">（漢字、または全角ひらがな、全角カタカナでご記入ください）</span>\r\n\r\n      <span class=\"msg\"></span>\r\n\r\n      </div>\r\n\r\n    \r\n\r\n    <h3>メールアドレス <span class=\"required\"><img src=\"images/icon_required.png\" width=\"40\" height=\"17\" alt=\"必須\"></span></h3>\r\n\r\n    <div class=\"answer\">\r\n\r\n      <input class=\"input1\" type=\"text\" name=\"Email1\" id=\"Email1\" value=\"\" maxlength=\"256\" /><span class=\"note\">（半角英数記号でご記入ください）</span><br />\r\n\r\n      <span class=\"msg\"></span>\r\n\r\n      </div>\r\n\r\n    \r\n\r\n    <h3>メールアドレス(確認用) <span class=\"required\"><img src=\"images/icon_required.png\" width=\"40\" height=\"17\" alt=\"必須\"></span></h3>\r\n\r\n    <div class=\"answer\">\r\n\r\n      <input class=\"input1\" type=\"text\" name=\"Email2\" id=\"Email2\" value=\"\" maxlength=\"256\" /><span class=\"note\">（間違い防止のため、もう一度メールアドレスをご記入ください）</span><br />\r\n\r\n      <span class=\"msg\"></span>\r\n\r\n      </div>\r\n\r\n    \r\n\r\n    <h3>電話番号 <span class=\"required\"><img src=\"images/icon_required.png\" width=\"40\" height=\"17\" alt=\"必須\"></span></h3>\r\n\r\n    <div class=\"answer\">\r\n\r\n      <input class=\"input3\" type=\"text\" name=\"Tel:1\" id=\"Tel:1\" value=\"\" maxlength=\"5\" />-\r\n\r\n      <input class=\"input3\" type=\"text\" name=\"Tel:2\" value=\"\" maxlength=\"4\" />- \r\n\r\n      <input class=\"input3\" type=\"text\" name=\"Tel:3\" value=\"\" maxlength=\"4\" />\r\n\r\n      <span class=\"note\">（半角数字記号でご記入ください　例：03-1234-5678）</span>\r\n\r\n      <span class=\"msg\"></span>\r\n\r\n      </div>\r\n\r\n    \r\n\r\n    <h3>平日昼間の連絡先</h3>\r\n\r\n    <div class=\"answer\">\r\n\r\n      <input class=\"input3\" type=\"text\" name=\"ContactTel:1\" id=\"ContactTel:1\" value=\"\" maxlength=\"5\" />-\r\n\r\n      <input class=\"input3\" type=\"text\" name=\"ContactTel:2\" value=\"\" maxlength=\"4\" />-\r\n\r\n      <input class=\"input3\" type=\"text\" name=\"ContactTel:3\" value=\"\" maxlength=\"4\" />\r\n\r\n      <span class=\"note\">（半角数字記号でご記入ください　例：03-1234-5678）</span>\r\n\r\n      <span class=\"msg\"></span>\r\n\r\n      </div>\r\n\r\n    \r\n\r\n    <h3>都道府県 <span class=\"required\"><img src=\"images/icon_required.png\" width=\"40\" height=\"17\" alt=\"必須\"></span></h3>\r\n\r\n    <div class=\"answer\">\r\n\r\n      <select name=\"Tdfk\" id=\"Tdfk\">\r\n\r\n    <option value=\"\">▼ご選択ください</option><br /><option value=\"北海道\">北海道</option><br /><option value=\"青森県\">青森県</option><br /><option value=\"岩手県\">岩手県</option><br /><option value=\"宮城県\">宮城県</option><br /><option value=\"秋田県\">秋田県</option><br /><option value=\"山形県\">山形県</option><br /><option value=\"福島県\">福島県</option><br /><option value=\"茨城県\">茨城県</option><br /><option value=\"栃木県\">栃木県</option><br /><option value=\"群馬県\">群馬県</option><br /><option value=\"埼玉県\">埼玉県</option><br /><option value=\"千葉県\">千葉県</option><br /><option value=\"東京都\">東京都</option><br /><option value=\"神奈川県\">神奈川県</option><br /><option value=\"新潟県\">新潟県</option><br /><option value=\"富山県\">富山県</option><br /><option value=\"石川県\">石川県</option><br /><option value=\"福井県\">福井県</option><br /><option value=\"山梨県\">山梨県</option><br /><option value=\"長野県\">長野県</option><br /><option value=\"岐阜県\">岐阜県</option><br /><option value=\"静岡県\">静岡県</option><br /><option value=\"愛知県\">愛知県</option><br /><option value=\"三重県\">三重県</option><br /><option value=\"滋賀県\">滋賀県</option><br /><option value=\"京都府\">京都府</option><br /><option value=\"大阪府\">大阪府</option><br /><option value=\"兵庫県\">兵庫県</option><br /><option value=\"奈良県\">奈良県</option><br /><option value=\"和歌山県\">和歌山県</option><br /><option value=\"鳥取県\">鳥取県</option><br /><option value=\"島根県\">島根県</option><br /><option value=\"岡山県\">岡山県</option><br /><option value=\"広島県\">広島県</option><br /><option value=\"山口県\">山口県</option><br /><option value=\"徳島県\">徳島県</option><br /><option value=\"香川県\">香川県</option><br /><option value=\"愛媛県\">愛媛県</option><br /><option value=\"高知県\">高知県</option><br /><option value=\"福岡県\">福岡県</option><br /><option value=\"佐賀県\">佐賀県</option><br /><option value=\"長崎県\">長崎県</option><br /><option value=\"熊本県\">熊本県</option><br /><option value=\"大分県\">大分県</option><br /><option value=\"宮崎県\">宮崎県</option><br /><option value=\"鹿児島県\">鹿児島県</option><br /><option value=\"沖縄県\">沖縄県</option><br /><option value=\"その他\">その他</option><br />\r\n\r\n    </select>\r\n\r\n      <span class=\"msg\"></span>\r\n\r\n      </div>\r\n\r\n    \r\n\r\n    <h3>市区町村／番地</h3>\r\n\r\n    <div class=\"answer\">\r\n\r\n      <input class=\"input1\" type=\"text\" name=\"Address\" id=\"Address\" value=\"\" maxlength=\"128\" />\r\n\r\n      <span class=\"msg\"></span>\r\n\r\n      </div>\r\n\r\n    \r\n\r\n    <h3>貴社名</h3>\r\n\r\n    <div class=\"answer\">\r\n\r\n      <input class=\"input1\" type=\"text\" name=\"Company\" id=\"Company\" value=\"\" maxlength=\"64\">\r\n\r\n      <span class=\"note\">（法人様の場合はご記入ください）</span>\r\n\r\n      <span class=\"msg\"></span>\r\n\r\n      </div>\r\n\r\n    \r\n\r\n    <h2>以下のアンケートにご協力をお願いいたします。（ビジネスのお客様向け）</h2>\r\n\r\n    \r\n\r\n    <h3>業種</h3>\r\n\r\n    <div class=\"answer\">\r\n\r\n      <select name=\"Industry\" id=\"Industry\">\r\n\r\n    <option value=\"\">▼ご選択ください</option><br /><option value=\"電気工事店\">電気工事店</option><br /><option value=\"建設会社\">建設会社</option><br /><option value=\"ハウスメーカー\">ハウスメーカー</option><br /><option value=\"メンテ保守\">メンテ保守</option><br /><option value=\"量販店\">量販店</option><br /><option value=\"小売店\">小売店</option><br /><option value=\"店装\">店装</option><br /><option value=\"電材卸店\">電材卸店</option><br /><option value=\"官自治体\">官自治体</option><br /><option value=\"設計事務所\">設計事務所</option><br /><option value=\"デザイン事務所\">デザイン事務所</option><br /><option value=\"その他\">その他</option><br />\r\n\r\n    </select>\r\n\r\n      <span class=\"msg\"></span>\r\n\r\n      </div>\r\n\r\n    \r\n\r\n    <h3>職種</h3>\r\n\r\n    <div class=\"answer\">\r\n\r\n      <select name=\"Job\" id=\"Job\">\r\n\r\n    <option value=\"\">▼ご選択ください</option><br /><option value=\"工事\">工事</option><br /><option value=\"資材調達・購買\">資材調達・購買</option><br /><option value=\"営業\">営業</option><br /><option value=\"販売\">販売</option><br /><option value=\"経営\">経営</option><br /><option value=\"設計\">設計</option><br /><option value=\"積算\">積算</option><br /><option value=\"その他\">その他</option><br />\r\n\r\n    </select>\r\n\r\n      <span class=\"msg\"></span>\r\n\r\n      </div>\r\n\r\n    \r\n\r\n    <h3>関心のある商材（複数回答可）</h3>\r\n\r\n    <div class=\"answer\">\r\n\r\n      <input type=\"checkbox\" name=\"Product[]\" value=\"照明器具（LED除く）\"id=\"Product1\" /><label for=\"Product1\">照明器具（LED除く）</label><br /><input type=\"checkbox\" name=\"Product[]\" value=\"ＬＥＤ照明\"id=\"Product2\" /><label for=\"Product2\">ＬＥＤ照明</label><br /><input type=\"checkbox\" name=\"Product[]\" value=\"電線・ケーブル\"id=\"Product3\" /><label for=\"Product3\">電線・ケーブル</label><br /><input type=\"checkbox\" name=\"Product[]\" value=\"電線管・配管\"id=\"Product4\" /><label for=\"Product4\">電線管・配管</label><br /><input type=\"checkbox\" name=\"Product[]\" value=\"分電盤・開閉器\"id=\"Product5\" /><label for=\"Product5\">分電盤・開閉器</label><br /><input type=\"checkbox\" name=\"Product[]\" value=\"配線器具\"id=\"Product6\" /><label for=\"Product6\">配線器具</label><br /><input type=\"checkbox\" name=\"Product[]\" value=\"制御機器\"id=\"Product7\" /><label for=\"Product7\">制御機器</label><br /><input type=\"checkbox\" name=\"Product[]\" value=\"家電住設機器\"id=\"Product8\" /><label for=\"Product8\">家電住設機器</label><br /><input type=\"checkbox\" name=\"Product[]\" value=\"工具・計測器\"id=\"Product9\" /><label for=\"Product9\">工具・計測器</label><br /><input type=\"checkbox\" name=\"Product[]\" value=\"空調\"id=\"Product10\" /><label for=\"Product10\">空調</label><br /><input type=\"checkbox\" name=\"Product[]\" value=\"エコキュート\"id=\"Product11\" /><label for=\"Product11\">エコキュート</label><br /><input type=\"checkbox\" name=\"Product[]\" value=\"太陽光発電\"id=\"Product12\" /><label for=\"Product12\">太陽光発電</label><br /><input type=\"checkbox\" name=\"Product[]\" value=\"ＩＨ調理器\"id=\"Product13\" /><label for=\"Product13\">ＩＨ調理器</label><br /><input type=\"checkbox\" name=\"Product[]\" value=\"その他\"id=\"Product14\" /><label for=\"Product14\">その他</label><br />\r\n\r\n      <span class=\"msg\"></span>\r\n\r\n      \r\n\r\n      <input class=\"input1\" type=\"text\" name=\"Product_Other\" value=\"\" maxlength=\"64\" />\r\n\r\n      <span class=\"note\">（具体的にご記入ください）</span>\r\n\r\n      <span class=\"msg\"></span>\r\n\r\n      </div>\r\n\r\n    \r\n\r\n    <h3>電材卸売業者へ期待すること（２つ選択）</h3>\r\n\r\n    <div class=\"answer\">\r\n\r\n      <input type=\"