-decoration: line-through;\n}</style></head>\n\n<body class=\"home blog\">\n\n<!-- Google Tag Manager (noscript) 許可証DL計測用-->\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-5ZZNXSH3\"\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n<!-- End Google Tag Manager (noscript) -->\n\n<header class=\"header\">\n    <h1 class=\"logo\"><a href=\"https://www.moroo.co.jp\"><img src=\"https://www.moroo.co.jp/H3eKBzra/wp-content/themes/moroo-www/img/common/logo.svg\" alt=\"MOROO\"></a></h1>\n    <button class=\"btn_menu\" type=\"button\"><span><i></i></span></button>\n    <nav class=\"nav_menu\">\n        <div class=\"wrap\">\n            <div class=\"left\">\n                <section>\n                    <h2>企業情報</h2>\n                    <ul>\n                        <li><a href=\"https://www.moroo.co.jp/company/vision/\">企業方針</a></li>\n                        <li><a href=\"https://www.moroo.co.jp/company/about/\">会社概要</a></li>\n                        <li><a href=\"https://www.moroo.co.jp/company/office/\">事業所一覧</a></li>\n                        <li><a href=\"https://www.moroo.co.jp/company/group/\">グループ企業について</a></li>\n                        <li><a href=\"https://www.moroo.co.jp/company/philanthropy/\">社会貢献</a></li>\n                    </ul>\n                </section>\n                <section>\n                    <h2>事業内容</h2>\n                    <ul>\n                        <li><a href=\"https://www.moroo.co.jp/business/pharmaceutical/\">医薬品卸売事業</a></li>\n                        <li><a href=\"https://www.moroo.co.jp/business/support/\">クリニック開業支援</a></li>\n                    </ul>\n                </section>\n            </div>\n            <div class=\"right\">\n                <section>\n                    <h2><a href=\"https://www.moroo.co.jp/service/\">製品・サービス</a></h2>\n                </section>\n                <section>\n                    <h2><a href=\"https://www.moroo.co.jp/news/\">お知らせ</a></h2>\n                </section>\n                <section>\n                    <h2><a href=\"https://recruit.moroo.co.jp\" target=\"_blank\">採用情報</a></h2>\n                </section>\n                <section>\n                    <h2><a href=\"https://www.moroo.co.jp/contact/\">お問い合わせ</a></h2>\n                </section>\n                <section class=\"exclude\">\n                    <ul>\n                        <li><a href=\"https://www.moroo.co.jp/privacypolicy/\">個人情報保護方針</a></li>\n                    </ul>\n                </section>\n            </div>\n        </div>\n    </nav>\n</header><!-- //.header -->\n\n\n<main class=\"main_contents\">\n\n\n<section class=\"sec_mv anime_fade-up\">\n    <div class=\"bg splide\" aria-label=\"メインビジュアル\">\n        <div class=\"splide__track\">\n            <ul class=\"splide__list\">\n                                <li class=\"splide__slide slide01\">\n                    <div>\n                        <img class=\"svg_img pc\" src=\"https://www.moroo.co.jp/H3eKBzra/wp-content/themes/moroo-www/img/top/mv_line1.svg\" alt=\"\">\n                        <img class=\"svg_img sp_tab\" src=\"https://www.moroo.co.jp/H3eKBzra/wp-content/themes/moroo-www/img/top/mv_line1_sp.svg\" alt=\"\">\n                        <picture>\n                            <source srcset=\"https://www.moroo.co.jp/H3eKBzra/wp-content/themes/moroo-www/img/top/mv_bg1_sp.jpg?240719\" media=\"(max-width: 919px)\">\n                            <img src=\"https://www.moroo.co.jp/H3eKBzra/wp-content/themes/moroo-www/img/top/mv_bg1.jpg?240719\" alt=\"\">\n                        </picture>\n                    </div>\n                </li>\n                            </ul>\n        </div>\n    </div>\n    <!-- <div class=\"bg swiper-container\">\n        <div class=\"swiper-wrapper\">\n            <div class=\"swiper-slide slide01\">\n                <img class=\"svg_img pc\" src=\"https://www.moroo.co.jp/H3eKBzra/wp-content/themes/moroo-www/img/top/mv_line1.svg\" alt=\"\">\n                <img class=\"svg_img sp_tab\" src=\"https://www.moroo.co.jp/H3eKBzra/wp-content/themes/moroo-www/img/top/mv_line1_sp.svg\" alt=\"\">\n                <picture>\n                    <source srcset=\"https://www.moroo.co.jp/H3eKBzra/wp-content/themes/moroo-www/img/top/mv_bg1_sp.jpg\" media=\"(max-width: 920px)\">\n                    <img src=\"https://www.moroo.co.jp/H3eKBzra/wp-content/themes/moroo-www/img/top/mv_bg1.jpg\" alt=\"\">\n                </picture>\n            </div>\n        </div>\n    </div> -->\n    <div class=\"text\">\n        <strong class=\"catch\">\n            <picture>\n                <source srcset=\"https://www.moroo.co.jp/H3eKBzra/wp-content/themes/moroo-www/img/top/mv_catch.svg?240719\" media=\"(max-width: 920px)\">\n                <img src=\"https://www.moroo.co.jp/H3eKBzra/wp-content/themes/moroo-www/img/top/mv_catch_w.svg?240719\" alt=\"人と人をつなぐ　人と健康をつなぐ\"></strong>\n            </picture>\n        <p>私たちモロオは、北海道に根をおろし、<br>生活者と医療従事者のまんなかで<br class=\"sp\">健やかな笑顔づくりに貢献しています。</p>\n    </div>\n</section>\n\n<section class=\"sec_about\">\n    <div class=\"inner\">\n        <div class=\"text anime_fade-up\">\n            <h2><i>ABOUT US</i></h2>\n            <strong class=\"catch anime_line-draw\">多様化するニーズに呼応する<br>医薬品の供給。<br>それがモロオの役割です。<img class=\"svg_img sp_tab\" src=\"https://www.moroo.co.jp/H3eKBzra/wp-content/themes/moroo-www/img/top/about_line_sp.svg\" alt=\"\"></strong>\n            <p>1917年の創業以来、モロオは医薬品の供給と情報の提供を通じ、<br class=\"pc\">健康と生活に貢献する企業を目指してまいりました。<br>「ヘルス＆ライフの総合企業モロオを創造する」という理念のもと、<br class=\"pc\">お客様のニーズに応じて「情報」「モノ」「サービス」の提供を<br class=\"pc\">トータル的に行なっています。</p>\n            <a class=\"detail\" href=\"/company/vision/\">企業方針について<i aria-hidden=\"true\">→</i></a>\n        </div>\n        <div class=\"image anime_line-draw\">\n            <picture class=\"ph1\">\n                <source srcset=\"https://www.moroo.co.jp/H3eKBzra/wp-content/themes/moroo-www/img/top/about_ph1_sp.jpg?240711\" media=\"(max-width: 920px)\">\n                <img class=\"anime_fade-up\" src=\"https://www.moroo.co.jp/H3eKBzra/wp-content/themes/moroo-www/img/top/about_ph1.jpg?240711\" alt=\"\">\n            </picture>\n            <picture class=\"ph2\">\n                <source srcset=\"https://www.moroo.co.jp/H3eKBzra/wp-content/themes/moroo-www/img/top/about_ph2_sp.jpg\" media=\"(max-width: 920px)\">\n                <img class=\"anime_fade-up\" src=\"https://www.moroo.co.jp/H3eKBzra/wp-content/themes/moroo-www/img/top/about_ph2.jpg?240527\" alt=\"\">\n            </picture>\n            <img class=\"svg_img sp_tab\" src=\"https://www.moroo.co.jp/H3eKBzra/wp-content/themes/moroo-www/img/top/about_line2.svg\" alt=\"\">\n            <img class=\"svg_img pc\" src=\"https://www.moroo.co.jp/H3eKBzra/wp-content/themes/moroo-www/img/top/about_line.svg\" alt=\"\">\n        </div>\n    </div>\n</section>\n\n<section class=\"sec_business\">\n    <div class=\"inner\">\n        <h2 class=\"anime_fade-up\"><i>BUSINESS</i>事業内容</h2>\n        <article>\n            <div class=\"text anime_fade-up\">\n                <span class=\"mark anime_line-draw\">物流<img class=\"svg_img\" src=\"https://www.moroo.co.jp/H3eKBzra/wp-content/themes/moroo-www/img/top/mark.svg\" alt=\"\"></span>でつなぐ\n                <h3 class=\"pharmaceutical\">医薬品卸売事業</h3>\n                <strong class=\"catch\">お客様ファーストの物流システムを<br>構築しています。</strong>\n                <p>数多くの製薬メーカーの医薬品をまとめて取り扱う医薬品流通を担っています。物流業務の高品質化に取り組み、迅速･正確に提供できる体制を構築しています。</p>\n                <a class=\"detail\" href=\"/business/pharmaceutical/\">詳しく見る<i aria-hidden=\"true\">→</i></a>\n            </div>\n            <picture>\n                <source srcset=\"https://www.moroo.co.jp/H3eKBzra/wp-content/themes/moroo-www/img/top/business_ph1_sp.jpg\" media=\"(max-width: 920px)\">\n                <img class=\"anime_fade-up\" src=\"https://www.moroo.co.jp/H3eKBzra/wp-content/themes/moroo-www/img/top/business_ph1.jpg?240527\" alt=\"\">\n            </picture>\n        </article>\n        <article class=\"anime_fade-up\">\n            <div class=\"text anime_fade-up\">\n                <span class=\"mark anime_line-draw\">情報<img class=\"svg_img\" src=\"https://www.moroo.co.jp/H3eKBzra/wp-content/themes/moroo-www/img/top/mark.svg\" alt=\"\"></span>でつなぐ\n                <h3 class=\"support\">開業支援・情報提供</h3>\n                <strong class=\"catch\">医療機関が抱える経営課題に<br>最適なソリューションをご提案。</strong>\n                <p>良質な医療サービスの提供と経営の安定化を目指す医療機関の経営支援など、幅広い開業支援・情報提供事業を行なっています。</p>\n                <a class=\"detail\" href=\"/business/support/\">詳しく見る<i aria-hidden=\"true\">→</i></a>\n            </div>\n            <picture>\n                <source srcset=\"https://www.moroo.co.jp/H3eKBzra/wp-content/themes/moroo-www/img/top/business_ph2_sp.jpg\" media=\"(max-width: 920px)\">\n                <img class=\"anime_fade-up\" src=\"https://www.moroo.co.jp/H3eKBzra/wp-content/themes/moroo-www/img/top/business_ph2.jpg?240527\" alt=\"\">\n            </picture>\n        </article>\n    </div>\n</section>\n\n<section class=\"sec_company\">\n    <div class=\"inner\">\n        <h2 class=\"anime_fade-up\"><i>COMPANY</i>企業情報</h2>\n        <div class=\"text anime_fade-up\">\n            <span class=\"mark anime_line-draw\">北海道の医療<img class=\"svg_img\" src=\"https://www.moroo.co.jp/H3eKBzra/wp-content/themes/moroo-www/img/top/mark_wide.svg\" alt=\"\"></span>をつなぐ\n            <strong class=\"catch\">地域に根ざした<br class=\"sp\">ヘルス&amp;ライフの総合企業</strong>\n        </div>\n        <ul class=\"anime_fade-up\">\n            <li><a href=\"/company/about/\">会社概要<i aria-hidden=\"true\">→</i></a></li>\n            <li><a href=\"/company/vision/\">代表メッセージ<i aria-hidden=\"true\">→</i></a></li>\n            <li><a href=\"/company/philanthropy/\">社会貢献<i aria-hidden=\"true\">→</i></a></li>\n        </ul>\n    </div>\n</section>\n\n<section class=\"sec_news\">\n    <div class=\"inner\">\n        <div class=\"left anime_fade-up\">\n            <h2 class=\"anime_fa