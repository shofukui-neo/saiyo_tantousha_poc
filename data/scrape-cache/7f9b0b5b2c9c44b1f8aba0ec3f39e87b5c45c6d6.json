                 </div>\n                                            </div>\n                                        </div>\n                                        <div class=\"g-menu-middle\">\n                                            <nav class=\"g-main-menu\">\n                                                <ul>\n                                                    <li class=\"has-child\">\n                                                        <a class=\"g-nav-title\" tabindex=\"-1\">会社案内</a>\n                                                        <ul>\n                                                            <li><a href=\"../message/\">社長ご挨拶</a></li>\n                                                            <li><a href=\"../company/\">企業情報</a></li>\n                                                            <li><a href=\"../access/\">本社・事業所・関連会社</a></li>\n                                                            <li><a href=\"../permit/\">許認可</a></li>\n                                                            <li><a href=\"../company/#company-movie\">会社紹介MOVIE</a></li>\n                                                        </ul>\n                                                    </li>\n                                                    <li class=\"has-child\">\n                                                        <a class=\"g-nav-title\" tabindex=\"-1\">サービス</a>\n                                                        <ul>\n                                                            <li><a href=\"../building/\">ビルメンテナンス事業</a></li>\n                                                            <li><a href=\"../designated/\">指定管理者事業・PFI事業</a></li>\n                                                            <li><a href=\"../welfare/\">介護福祉事業</a></li>\n                                                            <li><a href=\"../other/\">その他の事業</a></li>\n                                                        </ul>\n                                                    </li>\n                                                    <li class=\"has-child\">\n                                                        <a class=\"g-nav-title\" tabindex=\"-1\">リクルート</a>\n                                                        <ul>\n                                                            <li><a href=\"../work/\">私たちの仕事</a></li>\n                                                            <li><a href=\"../data/\">数字で見る第一商事</a></li>\n                                                            <li><a class=\"external\" href=\"https://www.talent-clip.jp/dai-ichi-recruit\" target=\"_blank\" rel=\"noopener noreferrer\">求人サイト</a></li>\n                                                        </ul>\n                                                    </li>\n                                                    <li class=\"no-child\"><a class=\"g-nav-title\" href=\"../news/\">新着情報</a></li>\n                                                    <li class=\"no-child\"><a class=\"g-nav-title\" href=\"../privacy/\">個人情報保護について</a></li>\n                                                    <li class=\"no-child\"><a class=\"g-nav-title\" href=\"../employee-portal/\">社員専用ページ</a></li>\n                                                </ul>\n                                            </nav>    \n                                        </div>\n                                        <div class=\"g-menu-bottom\">\n                                            <div class=\"inner-wrap flex-container\">\n                                                <div class=\"left-box\">\n                                                    <p class=\"tel-title\">お電話でのお問い合わせ</p>\n                                                    <p class=\"tel-number\">019-651-3241</p>\n                                                    <p class=\"tel-time\">受付時間：平日9:00～17:00</p>\n                                                </div>\n                                                <div class=\"right-box\">\n                                                    <div class=\"g-contact-button\">\n                                                        <a href=\"../contact/\">お問い合わせフォーム</a>\n                                                    </div>                                  \n                                                </div>    \n                                            </div>\n                                        </div>\n                                    </div>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </header>\n            <main>\n                <div class=\"lower-pagetitle-center\">\n                    <h1 class=\"pagetitle-h1\">\n                        <span class=\"font-rubik\">Message</span>\n                        社長ご挨拶\n                    </h1>\n                    <div class=\"pagetitle-photo\">\n                        <img src=\"../images/company/lower-pagetitle.jpg\" alt=\"ページタイトル画像\">\n                    </div>\n                    <div class=\"scroll-box pc-on\"><p class=\"font-rubik\">SCROLL</p></div>\n                    <nav class=\"breadcrumb\">\n                        <ul class=\"flex-container\">\n                            <li><a href=\"../\">HOME</a></li>\n                            <li><a tabindex=\"-1\">会社案内</a></li>\n                            <li><a href=\"./\">社長ご挨拶</a></li>\n                        </ul>\n                    </nav>\n                </div>\n                <div class=\"lower-content\">\n                    <div class=\"lower-content-wrapper\">\n                        <section id=\"message-president\">\n                            <h2 class=\"lower-h2-left\">社長ご挨拶</h2>\n                            <div class=\"flex-container\">\n                                <div class=\"text-box\">\n                                    <p class=\"read-copy\">\n                                        <span class=\"text-line\">笑顔あふれる会社</span> を目指して\n                                    </p>\n                                    <p>当社は1961（昭和36）年、岩手県初のビルメンテナンス事業者として創業しました。1989（平成1）年には、介護者の視点に立った福祉用具を取り扱う株式会社レディーズ・アイ（現・レディーズ・アイ事業部）を創設し、現在は介護施設の運営も行なっています。ビルメンテナンス事業と介護福祉事業は、いずれも人々の健康かつ安全な暮らしを支える仕事です。当社では高度な技能や専門的知識、プロとしての誇りとやりがいを持ち、お客様に質の高いサービスを提供できるよう、社員の資格取得支援や、働きやすい職場環境の整備、職域の枠を超えた交流に力を入れています。社員一人ひとりが喜びを実感しながら働くことにより、お客様の期待に応える成果を生み出し、それがお客様の喜びにつながります。事業を通じて関わるすべての人が幸せを感じ、笑顔あふれる場をつくることを、当社は目指しています。</p>\n                                    <p class=\"president-name\">代表取締役社長<span>　柴田　千春</span></p>\n                                </div>\n                                <div class=\"image-box\">\n                                    <img src=\"../images/message/photo-president.jpg\" alt=\"代表取締役社長の写真\">\n                                </div>\n                            </div>\n                        </section>\n                        <section id=\"message-important\">\n                            <h2 class=\"lower-h2-left\">大切にしていること</h2>\n                            <div class=\"yellow-line-box\">\n                                <dl class=\"flex-container\">\n                                    <dt>社訓</dt>\n                                    <dd>\n                                        <ul class=\"ul-list\">\n                                            <li>事業はすべて業界の首位を前進する</li>\n                                            <li>良い仕事を通じてお得意様に奉仕する</li>\n                                        </ul>\n                                    </dd>\n                                </dl>\n                                <dl class=\"flex-container\">\n                                    <dt>社是</dt>\n                                    <dd>\n                                        <ul class=\"ul-list\">\n                                            <li>自分の仕事には常に誇りと責任と研究心をもつ</li>\n                                            <li>七転び八起き</li>\n                                        </ul>\n                                    </dd>\n                                </dl>\n                            </div>\n                        </section>\n                    </div>\n                </div>\n            </main>\n            <footer id=\"footer\">\n                <section class=\"footer-contact\">\n                    <div class=\"flex-container\">\n                        <div class=\"left-box\">\n                            <h2 class=\"title-h2\">Contact<span class=\"title-small\">お問い合わせ</span></h2>\n                            <p>各種サービスご依頼の際は、<br class=\"pc-on\">\n                                お電話またはお問い合わせフォームより<br class=\"pc-on\">\n                                お気軽にご相談ください。\n                            </p>\n                        </div>\n                        <div class=\"right-box\">\n                            <p class=\"title\">お電話でのお問い合わせ</p>\n                            <div class=\"contact-info flex-container\">\n                                <p class=\"tel-number\">019-651-3241</p>\n                                <p class=\"tel-time\">受付時間：平日9:00～17:00</p>\n                            </div>\n                            <div class=\"button-mail\">\n                                <a href=\"../contact/\">お問い合わせフォーム</a>\n                            </div>\n                        </div>\n                    </div>\n                </section>\n                <section class=\"footer-nav\">\n                    <div class=\"top-wave pc-on\"><img src=\"../images/common/wave-blue.png\"></div>\n                    <div class=\"top-wave sp-on\"><img src=\"../images/common/wave-blue-sp-footer.png\"></div>\n                    <div class=\"footer-nav-top flex-container\">\n                        <div class=\"logo flex-container\">\n                            <a href=\"../\"><img src=\"../images/common/logo-white.png\"></a>\n                            <div class=\"address\">\n                                <p>〒020-0887　岩手県盛岡市上ノ橋町8番8号<br>\n                                    TEL：019-651-3241　　FAX：019-651-3245\n                                </p>\n                            </div>\n                        </div>\n                        <ul class=\"sns flex-container\">\n                            <li>\n                                <a href=\"https://www.instagram.com/daiichishoji/\" target=\"_blank\" rel=\"noopener noreferrer\">\n                                    <img src=\"../images/common/sns-instagram.svg\">\n                                </a>\n                            </li>\n                            <li>\n                                <a href=\"https://www.facebook.com/people/%E7%AC%AC%E4%B8%80%E5%95%86%E4%BA%8B%E6%A0%AA%E5%BC%8F%E4%BC%9A%E7%A4%BE/100063544652436/\" target=\"_blank\" rel=\"noopener noreferrer\">\n                                    <img src=\"../images/common/sns-facebook.svg\">\n                                </a>\n                            </li>\n                            <li>\n                                <a href=\"https://x.com/daiichi3241\" target=\"_blank\" rel=\"noopener noreferrer\">\n                                    <img src=\"../images/common/sns-x.svg\">\n                                </a>\n                            </li>\n                        </ul>\n                    </div>\n                    <div class=\"footer-nav-main flex-container\">\n                        <div class=\"flex-container\">\n                            <div class=\"category\">\n                                <p class=\"category-title\">会社案内</p>\n                                <ul>\n                                    <li><a href=\"../message/\">社長ご挨拶</a></li>\n                                    <li><a href=\"../company/\">企業情報</a></li>\n                                    <li><a href=\"../access/\">本社・事業所・関連会社</a></li>\n                                    <li><a href=\"../permit/\">許認可</a></li