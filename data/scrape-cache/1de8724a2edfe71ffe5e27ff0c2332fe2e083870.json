/' href='https://www.kinkiyoken.co.jp/wp-json/' />\n<link rel=\"EditURI\" type=\"application/rsd+xml\" title=\"RSD\" href=\"https://www.kinkiyoken.co.jp/xmlrpc.php?rsd\" />\n<link rel=\"wlwmanifest\" type=\"application/wlwmanifest+xml\" href=\"https://www.kinkiyoken.co.jp/wp-includes/wlwmanifest.xml\" /> \n<meta name=\"generator\" content=\"WordPress 4.5.32\" />\n<script>var ms_grabbing_curosr = 'https://www.kinkiyoken.co.jp/wp-content/plugins/master-slider/public/assets/css/common/grabbing.cur', ms_grab_curosr = 'https://www.kinkiyoken.co.jp/wp-content/plugins/master-slider/public/assets/css/common/grab.cur';</script>\n<meta name=\"generator\" content=\"MasterSlider 2.7.1 - Responsive Touch Image Slider | www.avt.li/msf\" />\n<style>.simplemap img{max-width:none !important;padding:0 !important;margin:0 !important;}.staticmap,.staticmap img{max-width:100% !important;height:auto !important;}.simplemap .simplemap-content{display:none;}</style>\n<script src=\"https://ajax.googleapis.com/ajax/libs/jquery/1.8/jquery.min.js\"></script>\n<script src=\"http://ajaxzip3.googlecode.com/svn/trunk/ajaxzip3/ajaxzip3-https.js\"></script>\n<script>\n$(function(){\n  $('#zip2').keyup(function(event){\n    AjaxZip3.zip2addr(this,'','pref1','addr1');\n  })\n})\n</script>\n<!-- Google tag (gtag.js) -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-CHZCVMQW5G\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'G-CHZCVMQW5G');\n  gtag('config', 'UA-25468045-1');\n</script>\n</head>\n<body id=\"information\" class=\"blog paged paged-4 _masterslider _ms_version_2.7.1\">\n<div id=\"top\">\n  <div id=\"header\" data-uk-sticky=\"{top:-200, animation: 'uk-animation-slide-top'}\">\n    <header id=\"header_inner\">\n      <hgroup>\n        <h1 class=\"logo\"><a href=\"https://www.kinkiyoken.co.jp\"><img src=\"/common/img/logo.png\" alt=\"株式会社 近畿予防医学研究所 | 滋賀・京都・三重の臨床検査／調剤薬局\" width=\"240\" height=\"35\"/></a></h1>\n      </hgroup>\n      <div id=\"globalnav\">\n        <nav id=\"globalnav_inner\">\n          <nav class=\"menu_main group\"><ul id=\"menu-global-navi\" class=\"menu\"><li id=\"menu-item-100\" class=\"menu-item menu-item-type-post_type menu-item-object-page\"><a href=\"https://www.kinkiyoken.co.jp/company/\"><span class=\"menu_title\">会社情報</span><span class=\"menu_description\">COMPANY</span></a></li>\n<li id=\"menu-item-99\" class=\"menu-item menu-item-type-post_type menu-item-object-page current-menu-item page_item page-item-7 current_page_item current_page_parent\"><a href=\"https://www.kinkiyoken.co.jp/information/\"><span class=\"menu_title\">インフォメーション</span><span class=\"menu_description\">INFORMATION</span></a></li>\n<li id=\"menu-item-102\" class=\"menu-item menu-item-type-post_type menu-item-object-page\"><a href=\"https://www.kinkiyoken.co.jp/clinical-testing/\"><span class=\"menu_title\">事業内容</span><span class=\"menu_description\">SERVICE</span></a></li>\n<li id=\"menu-item-1042\" class=\"menu-item menu-item-type-custom menu-item-object-custom\"><a href=\"#footer\"><span class=\"menu_title\">採用情報</span><span class=\"menu_description\">RECRUIT</span></a></li>\n<li id=\"menu-item-101\" class=\"menu-item menu-item-type-post_type menu-item-object-page\"><a href=\"https://www.kinkiyoken.co.jp/contact/\"><span class=\"menu_title\">お問い合せ</span><span class=\"menu_description\">CONTACT</span></a></li>\n</ul></nav>        </nav>\n      </div>\n      <!--/globalnav -->\n      <div class=\"toggle\"><a href=\"#offcanvas\" class=\"uk-navbar-toggle\" data-uk-offcanvas></a></div>\n    </header>\n    <!--/header_inner --> \n  </div>\n  <!--/header --> \n</div>\n\n<div id=\"contents\">\n  <div id=\"contents_inner\">\n    <section id=\"contents_main2\">\n      <div class=\"title\">\n        <h1>インフォメーション</h1>\n        <p>INFORMATION</p>\n      </div>\n      <div id=\"topicpath\"><div class=\"topicpath_inner\"><p><!-- Breadcrumb NavXT 5.4.0 -->\n<a href=\"https://www.kinkiyoken.co.jp\" class=\"home\">HOME</a> &gt; <span property=\"itemListElement\" typeof=\"ListItem\"><span property=\"name\">インフォメーション</span><meta property=\"position\" content=\"2\"></span></p></div></div><!--/topicpath -->      <div id=\"conbox\">\n                <div class=\"post_header\">\n          <p class=\"post_date\">2017年09月06日</p>\n          <h2><a href=\"https://www.kinkiyoken.co.jp/news/598/\">\n            メディカルフィットネスここあ守山が9月1日で1周年を迎えました            </a></h2>\n        </div>\n        <div class=\"post_contents\">\n          <p>昨年9月に滋賀県守山市にオープンしました「メディカルフィットネスここあ守山」が、1周年を迎えることができました。多くのみなさまに御利用いただき心よりお礼申し上げます。</p><p>1周年記念キャンペーンといたしまして、以下のキャンペーンを実施中です。</p><p><br />開催期間　　　：　　9月1日～10月31日<br />キャンペーン　：　　入会金12,000円　⇒　6,000円　　入会金50％オフ！<br />　　　　　　　　　　さらに、伊勢志摩サミットでも採用されました「極上200％完熟トマトジュース」<br />　　　　　　　　　　もしくは<br />　　　　　　　　　　「極上完熟トマトジャム」<br />　　　　　　　　　　どちらか1点をプレゼントいたします！</p><p>&nbsp;</p><p>無料体験も受付中です。<br />この機会にぜひメディカルフィットネスここあ守山へお越しください。</p><p>くわしくはメディカルフィットネスここあ守山ＨＰへ</p><p>⇒<a href=\"http://www.fitness.kokoa.jp/\">『メディカルフィットネスここあ守山』</a></p>        </div>\n                <div class=\"post_header\">\n          <p class=\"post_date\">2017年06月14日</p>\n          <h2><a href=\"https://www.kinkiyoken.co.jp/news/566/\">\n            2017年6月1日に「すこやか薬局・白梅」を開局しました            </a></h2>\n        </div>\n        <div class=\"post_contents\">\n          <p>ふれあい薬局グループ28店舗目となる「すこやか薬局・白梅」が2017年6月1日に開局しました！<br /> 近隣には大型スーパーや、京福電鉄北野白梅町駅、クリニック等もあって毎日多くの方が通行されにぎやかな通りです。<br /> 南側の北野下白梅町にはふれあい薬局・白梅もあり、今後 店舗間で連携をして地域の患者様に選ばれる薬局を目指していきます。</p><p>&nbsp;</p><p>◆開局時間◆<br /> 　月～金曜日　　　9：00～18：00<br /> 　第2・第4土曜日　9：00～13：00</p><p>北野白梅町駅　すぐです！</p><p>〒603-8325<br /> 　京都市北区北野上白梅町66番地　カーメル北野１－D<br /> 　TEL：075-278-1266 <br />    FAX：075-278-1228 <br /><br /></p><p><span style=\"color: #ff0000;\">★すこやか薬局・白梅は、2023年6月に閉局しました。</span></p><p>&nbsp;</p><p><img width=\"500\" height=\"800\" class=\"alignnone size-full wp-image-567 colorbox-566\" alt=\"すこやか白梅 011\" src=\"https://www.kinkiyoken.co.jp/wp-content/uploads/2017/06/5290628a6c4050ae841d0c09276b7191.jpg\" /></p><p>&nbsp;</p>        </div>\n                <div class=\"post_header\">\n          <p class=\"post_date\">2017年05月31日</p>\n          <h2><a href=\"https://www.kinkiyoken.co.jp/news/558/\">\n            2017年4月1日新入社員の入社式を実施いたしました            </a></h2>\n        </div>\n        <div class=\"post_contents\">\n          2017年4月1日（土）に本社棟会議室にて入社式が実施されました。\r\nオー・ピー・エル8名（新卒採用者6名、中途採用者2名）・ライフケア事業2名(新卒採用者1名、中途採用者1名)の計10名の入社がありました。\r\n3日(月)、4日(火)の計３日間の研修が行われ、社内研修の他にも、社外研修としてここあ石山、ここあ守山のサービス付き高齢者向け住宅や\r\nふれあい薬局（守山）、2016年9月にオープンしたメディカルフィットネスここあ守山の見学も行われました。<img src=\"https://www.kinkiyoken.co.jp/wp-content/uploads/2017/05/IMG_0063.jpg\" alt=\"IMG_0063\" width=\"2048\" height=\"1536\" class=\"alignnone size-full wp-image-560 colorbox-558\" srcset=\"https://www.kinkiyoken.co.jp/wp-content/uploads/2017/05/IMG_0063.jpg 2048w, https://www.kinkiyoken.co.jp/wp-content/uploads/2017/05/IMG_0063-300x225.jpg 300w, https://www.kinkiyoken.co.jp/wp-content/uploads/2017/05/IMG_0063-768x576.jpg 768w, https://www.kinkiyoken.co.jp/wp-content/uploads/2017/05/IMG_0063-1024x768.jpg 1024w\" sizes=\"(max-width: 2048px) 100vw, 2048px\" />        </div>\n                <div class=\"post_header\">\n          <p class=\"post_date\">2017年01月17日</p>\n          <h2><a href=\"https://www.kinkiyoken.co.jp/news/537/\">\n            メディカルフィットネスここあ守山　お試し体験受付中！            </a></h2>\n        </div>\n        <div class=\"post_contents\">\n          <p>2016年9月にオープンしたメディカルフィットネスここあ守山！</p><p>ただ今、無料お試し体験を受付中です☆</p><p>&nbsp;</p><p>＊＊＊＊＊＊＊＊＊＊＊＊＊＊＊＊＊＊＊＊＊＊＊＊＊＊＊＊＊＊＊＊＊＊＊</p><p>&nbsp;</p><p>今だけ！期間限定のキャンペーンを実施中！</p><p><span style=\"font-size: 18pt;\"><strong><span style=\"color: #ff9900;\">2月末</span></strong></span>までにご入会の方限定で、</p><p><span style=\"color: #ff0000; font-size: 14pt;\"><strong>入会金12,000円　→　0円</strong></span>　　に！</p><p>さらに！！夫婦でご入会頂くと・・・</p><p><span style=\"font-size: 14pt;\"><strong><span style=\"color: #ff0000;\">月会費が　7,000円　→　6,000円</span></strong></span>　になります！！</p><p>お得に入会できるチャンスです！</p><p>ぜひ一度お試し体験にお越しください☆★</p><p>※完全予約制となりますので、見学等ご希望の方は下記までご連絡ください。</p><p><span style=\"color: #ff9900;\"><strong><span style=\"font-size: 14pt;\">TEL　077-514-0514　</span></strong><span style=\"font-size: 14pt;\"><span style=\"color: #000000; font-size: 12pt;\">(受付時間：10：00～19：00)</span></span></span></p><p>&nbsp;</p><p><img width=\"900\" height=\"410\" class=\"alignnone size-full wp-image-540 colorbox-537\" alt=\"image1\" src=\"https://www.kinkiyoken.co.jp/wp-content/uploads/2017/01/image1.jpg\" srcset=\"https://www.kinkiyoken.co.jp/wp-content/uploads/2017/01/image1.jpg 900w, https://www.kinkiyoken.co.jp/wp-content/uploads/2017/01/image1-300x137.jpg 300w, https://www.kinkiyoken.co.jp/wp-content/uploads/2017/01/image1-768x350.jpg 768w\" sizes=\"(max-width: 900px) 100vw, 900px\" /></p>        </div>\n                <div class=\"post_header\">\n          <p class=\"post_date\">2016年08月19日</p>\n          <h2><a href=\"https://www.kinkiyoken.co.jp/news/451/\">\n            メディカルフィットネスここあ守山　　無料体験受付中            </a></h2>\n        </div>\n        <div class=\"post_contents\">\n          <p><strong><span style=\"color: #ff0000;\"> メディカルフィットネスここあ守山が9月1日にオープンします！</span></strong></p><p><span style=\"font-size: 12pt;\"><img width=\"377\" height=\"251\" class=\"alignnone  wp-image-458 colorbox-451\" alt=\"IMG_9916\" src=\"https://www.kinkiyoken.co.jp/wp-content/uploads/2016/08/IMG_9916.jpg\" srcset=\"https://www.kinkiyoken.co.jp/wp-content/uploads/2016/08/IMG_9916.jpg 1685w, https://www.kinkiyoken.co.jp/wp-content/uploads/2016/08/IMG_9916-300x200.jpg 300w, https://www.kinkiyoken.co.jp/wp-content/uploads/2016/08/IMG_9916-768x512.jpg 768w, https://www.kinkiyoken.co.jp/wp-content/uploads/2016/08/IMG_9916-1024x682.jpg 1024w\" sizes=\"(max-width: 377px) 100vw, 377px\" /></span></p><p>現在、無料体験＆見学を受付中です。</p><p><span style=\"font-size: 12pt;\">◆無料体験＆見学スケジュール◆</span></p><p><strong>　　8月20日（土)　・　8月22日（月）　</strong></p><p><strong>　　8月23日（火）　・　　8月24日（水）</strong></p><p>　①10：00－11：00　　②11：00－12：00</p><p>　③12：00－13：00　　④13：00－14：00</p><p>　⑤14：00－15：00　　⑥15：00－16：00</p><p>　⑦16：00－17：00　　</p><p>&nbsp;</p><p>さらに、10月末までにご入会頂いた方は入会金が無料となるキャンペーンを行っています。</p><p>詳しくは無料体験へ</p><p>※完全予約制と致しますので、見学等ご希望の方は下記までご連絡下さい。<br /><span style=\"font-size: 12pt;\"><strong>ＴＥＬ　　077-514-0514</strong></span>（受付時間　10：00～19：00）</p><p>9月以降の無料体験についても随時受付しております。</p><p><br /><span style=\"color: #ff0000;\"><img width=\"504\" height=\"336\" class=\"alignnone  wp-image-457 colorbox-451\" alt=\"IMG_9887\" src=\"https://www.kinkiyoken.co.jp/wp-content/uploads/2016/08/IMG_9887.jpg\" srcset=\"https://www.kinkiyoken.co.jp/wp-content/uploads/2016/08/IMG_9887.jpg 1685w, https://www.kinkiyoken.co.jp/wp-content/uploads/2016/08/IMG_9887-300x200.jpg 300w, https://www.kinkiyoken.co.jp/wp-content/uploads/2016/08/IMG_9887-768x512.jpg 768w, https://www.kinkiyoken.co.jp/wp-content/uploads/2016/08/IMG_9887-1024x682.jpg 1024w\" sizes=\"(max-width: 504px) 100vw, 504px\" /></span></p>        </div>\n                <div class=\"post_header\">\n          <p class=\"post_date\">2016年06月03日</p>\n          <h2><a href=\"https://www.kinkiyoken.co.jp/news/433/\">\n            2016年６月１日『ふれあいメディカルモール守山』内の『ふれあい薬局　コープもりやま前』が開局しました。            </a></h2>\n        </div>\n        <div class=\"post_contents\">\n          <p>６月１日（水）の開局に先立ち、５月２８日（土）にふれあいメディカルモール守山の内覧会が開催されました。<br />メディカルフィットネスここあは今秋オープン予定です。</p><p><img src=\"https://www.kinkiyoken.co.jp/wp-content/uploads/2016/07/CIMG0400.jpg\" alt=\"CIMG0400\" class=\"alignnone size-full wp-image-434 colorbox-433\" height=\"346\" width=\"461\" srcset=\"https://www.kinkiyoken.co.jp/wp-content/uploads/2016/07/CIMG0400.jpg 461w, https://www.kinkiyoken.co.jp/wp-content/uploads/2016/07/CIMG0400-300x225.jpg 300w\" sizes=\"(max-width: 461px) 100vw, 461px\" /></p>        </div>\n                <div class=\"post_header\">\n          <p class=\"post_date\">2016年06月03日</p>\n          <h2><a href=\"https://www.kinkiyoken.co.jp/news/430/\">\n            2016年4月1日ふれあい薬局グループの店舗として「すずらん薬局」が加わりました。            </a></h2>\n        </div>\n        <div class=\"post_contents\">\n          <p><img src=\"https://www.kinkiyoken.co.jp/wp-content/uploads/2016/07/d07170462812cd3e2671cedce0a219bb.jpg\" alt=\"すずらん\" class=\"alignnone size-full wp-image-431 colorbox-430\" height=\"461\" width=\"346\" srcset=\"https://www.kinkiyoken.co.jp/wp-content/uploads/2016/07/d07170462812cd3e2671cedce0a219bb.jpg 346w, https://www.kinkiyoken.co.jp/wp-content/uploads/2016/07/d07170462812cd3e2671cedce0a219bb-225x300.jpg 225w\" sizes=\"(max-width: 346px) 100vw, 346px\" /></p>        </div>\n                <div class=\"post_header\">\n          <p class=\"post_date\">2016年04月26日</p>\n          <h2><a href=\"https://www.kinkiyoken.co.jp/news/425/\">\n            2016年4月1日新入社員の入社式を実施致しました。            </a></h2>\n        </div>\n        <div class=\"post_contents\">\n          <p>2016年4月1日（金）に本社棟会議室にて入社式が実施されました。<br />オー・ピー・エル５名（新卒採用者）・薬局事業部３名・ライフケア事業３名１１名の入社がありました。<br />土、日曜日を挟んで４日（月）、５日（火）計３日間の研修が行われ、社内研修の他にも、社外研修としてここあ石山、ここあ守山のサービス付き高齢者向け住宅やふれあい薬局（守山）、いずみ薬局　高雄支店の各薬局の見学も行われました。</p><p><img src=\"https://www.kinkiyoken.co.jp/wp-content/uploads/2016/07/24a145d58706ee35ffe234ad36ef03f7.jpg\" alt=\"入社式1\" class=\"alignnone wp-image-426 size-full colorbox-425\" height=\"387\" width=\"516\" srcset=\"https://www.kinkiyoken.co.jp/wp-content/uploads/2016/07/24a145d58706ee35ffe234ad36ef03f7.jpg 516w, https://www.kinkiyoken.co.jp/wp-content/uploads/2016/07/24a145d58706ee35ffe234ad36ef03f7-300x225.jpg 300w\" sizes=\"(max-width: 516px) 100vw, 516px\" /></p>        </div>\n                <div class=\"post_header\">\n          <p class=\"post_date\">2016年04月26日</p>\n          <h2><a href=\"https://www.kinkiyoken.co.jp/news/423/\">\n            ふれあい薬局グループとして『いずみ薬局　高雄支店』『いずみ薬局　醍醐支店』の２店舗が加わりました。            </a></h2>\n        </div>\n        <div class=\"post_contents\">\n          <p>ふれあい薬局グループとして『いずみ薬局　高雄支店』『いずみ薬局　醍醐支店』の２店舗が加わりました。</p>        </div>\n                <div class=\"post_header\">\n          <p class=\"post_date\">2016年04月20日</p>\n          <h2><a href=\"https://www.kinkiyoken.co.jp/news/420/\">\n            2015年９月２４日新社屋が完成しました。            </a></h2>\n        </div>\n        <div class=\"post_contents\">\n          <p>従業員待望の本社棟が完成し、シルバーウィークの９月２０日～２３日で引っ越し作業を行いました。<br /> 引き続き旧管理棟は改装を行い、ラボ棟は１１月～１ヶ月かけて取り壊しが行われます。</p><p><img src=\"https://www.kinkiyoken.co.jp/wp-content/uploads/2016/07/69a144438013a9ef071221a3388c0d1e.png\" alt=\"1新社屋\" class=\"alignnone size-full wp-image-421 colorbox-420\" height=\"235\" width=\"314\" srcset=\"https://www.kinkiyoken.co.jp/wp-content/uploads/2016/07/69a144438013a9ef071221a3388c0d1e.png 314w, https://www.kinkiyoken.co.jp/wp-content/uploads/2016/07/69a144438013a9ef071221a3388c0d1e-300x225.png 300w\" sizes=\"(max-width: 314px) 100vw, 314px\" /></p>        </div>\n                <div class='wp-pagenavi'>\n<span class='pages'>4 / 5</span><a class=\"previouspostslink\" rel=\"prev\" href=\"https://www.kinkiyoken.co.jp/information/page/3/\">&laquo;</a><a class=\"page smaller\" href=\"https://www.kinkiyoken.co.jp/information/\">1</a><a class=\"page smaller\" href=\"https://www.kinkiyoken.co.jp/information/page/2/\">2</a><a class=\"page smaller\" href=\"https://www.kinkiyoken.co.jp/information/page/3/\">3</a><span class='current'>4</span><a class=\"page larger\" href=\"https://www.kinkiyoken.co.jp/information/page/5/\">5</a><a class=\"nextpostslink\" rel=\"next\" href=\"https://www.kinkiyoken.co.jp/information/page/5/\">&raquo;</a>\n</div>      </div>\n    </section>\n    <!--/contents_main2 -->\n    <aside id=\"sidebar\">\n  <div id=\"wpmenu\">\n        <ul>\n      <li id=\"calendar-2\" class=\"widget-container widget_calendar\"><div id=\"calendar_wrap\" class=\"calendar_wrap\"><table id=\"wp-calendar\">\n\t<caption>2026年6月</caption>\n\t<thead>\n\t<tr>\n\t\t<th scope=\"col\" title=\"月曜日\">月</th>\n\t\t<th scope=\"col\" title=\"火曜日\">火</th>\n\t\t