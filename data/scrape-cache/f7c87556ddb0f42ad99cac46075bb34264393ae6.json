var timeHtml = '';\n\t\t\t\t\tif (category) {\n\t\t\t\t\t\t$.each(category, function(index, cat) {\n\t\t\t\t\t\t\tif (cat.indexOf(\"1-\") != -1 || cat.indexOf(\"2-\") != -1) {\n\t\t\t\t\t\t\t\ttagHtml += '<span>#' + $('a[data-value=' + cat + ']').html() + '</span>';\n\t\t\t\t\t\t\t} else {\n\t\t\t\t\t\t\t\ttagHtml += '<span>' + $('a[data-value=' + cat + ']').html() + '</span>';\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t\tif (cat.indexOf(\"1-\") != -1) {\n\t\t\t\t\t\t\t\ttimeHtml += $('a[data-value=' + cat + ']').html();\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t});\n\t\t\t\t\t}\n\t\t\t\t\toutput += '<li data-tag=\"' + category + '\"><a href=\"staff' + id + '.html\">';\n\t\t\t\t\toutput += '<span class=\"ttl\">' + name + '</span>';\n\t\t\t\t\toutput += '<span class=\"img\"><img src=\"../../assets/images/common/interview/staff_img' + id + '.jpg\" alt=\"' + name.replace(/<br>/g, '') + '\"></span>';\n\t\t\t\t\toutput += '<span class=\"date\">' + time + ' ' + timeHtml + '</span>';\n\t\t\t\t\toutput += '<span class=\"text\">' + text + '</span>';\n\t\t\t\t\toutput += '<span class=\"staffTagList\">' + tagHtml + '</span>';\n\t\t\t\t\toutput += '</a></li>';\n\t\t\t\t});\n\t\t\t\t$(\".comInterviewList\").html(output);\n\t\t\t\t$('.comInterviewList li:visible .ttl').matchHeight();\n\t\t\t\tjssearch();\n\t\t\t});\n\t\t\t$('#interview .topBox .lBox .link a').on('click', function() {\n\t\t\t\t$('#interview .topBox .sort a[data-value]').removeClass('on');\n\t\t\t\tjssearch();\n\t\t\t});\n\t\t\t$('#interview .topBox .sort a[data-value]').on('click', function() {\n\t\t\t\t$(this).toggleClass('on').siblings('a').removeClass('on');\n\t\t\t\tjssearch();\n\t\t\t\treturn false;\n\t\t\t});\n\n\t\t\tfunction jssearch() {\n\t\t\t\tvar workplaceval = new Array();\n\t\t\t\tvar facultyval = new Array();\n\t\t\t\tvar keywordval = new Array();\n\t\t\t\t$('#interview .topBox .sort a.on[data-value^=\"1-\"]').each(function() {\n\t\t\t\t\tvar datavalue = $(this).attr('data-value');\n\t\t\t\t\tworkplaceval.push(datavalue);\n\t\t\t\t});\n\t\t\t\t$('#interview .topBox .sort a.on[data-value^=\"2-\"]').each(function() {\n\t\t\t\t\tfacultyval.push($(this).attr('data-value'));\n\t\t\t\t});\n\t\t\t\t$('#interview .topBox .sort a.on[data-value^=\"3-\"]').each(function() {\n\t\t\t\t\tkeywordval.push($(this).attr('data-value'));\n\t\t\t\t});\n\t\t\t\t// console.log(workplaceval,facultyval,keywordval);\n\t\t\t\tvar _modelsElem = $('.comInterviewList > li');\n\t\t\t\t$.each(_modelsElem, function() {\n\t\t\t\t\tvar _thisTag = $(this).attr('data-tag').split(',');\n\t\t\t\t\tif (_thisTag) {\n\t\t\t\t\t\tshow1 = false;\n\t\t\t\t\t\tshow2 = false;\n\t\t\t\t\t\tshow3 = false;\n\t\t\t\t\t\tif (!workplaceval.length) {\n\t\t\t\t\t\t\tshow1 = true;\n\t\t\t\t\t\t} else {\n\t\t\t\t\t\t\tfor (var i = 0; i < workplaceval.length; i++) {\n\t\t\t\t\t\t\t\tif (_thisTag.indexOf(workplaceval[i]) > -1) {\n\t\t\t\t\t\t\t\t\tshow1 = true;\n\t\t\t\t\t\t\t\t\tbreak;\n\t\t\t\t\t\t\t\t}\n\t\t\t\t\t\t\t};\n\t\t\t\t\t\t}\n\t\t\t\t\t\tif (!facultyval.length) {\n\t\t\t\t\t\t\tshow2 = true;\n\t\t\t\t\t\t} else {\n\t\t\t\t\t\t\tfor (var i = 0; i < facultyval.length; i++) {\n\t\t\t\t\t\t\t\tif (_thisTag.indexOf(facultyval[i]) > -1) {\n\t\t\t\t\t\t\t\t\tshow2 = true;\n\t\t\t\t\t\t\t\t\tbreak;\n\t\t\t\t\t\t\t\t}\n\t\t\t\t\t\t\t};\n\t\t\t\t\t\t}\n\t\t\t\t\t\tif (!keywordval.length) {\n\t\t\t\t\t\t\tshow3 = true;\n\t\t\t\t\t\t} else {\n\t\t\t\t\t\t\tfor (var i = 0; i < keywordval.length; i++) {\n\t\t\t\t\t\t\t\tif (_thisTag.indexOf(keywordval[i]) > -1) {\n\t\t\t\t\t\t\t\t\tshow3 = true;\n\t\t\t\t\t\t\t\t\tbreak;\n\t\t\t\t\t\t\t\t}\n\t\t\t\t\t\t\t};\n\t\t\t\t\t\t}\n\t\t\t\t\t\tif (show1 && show2 && show3) {\n\t\t\t\t\t\t\t$(this).show();\n\t\t\t\t\t\t} else {\n\t\t\t\t\t\t\t$(this).hide();\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t});\n\t\t\t\tvar newElement = $('<p class=\"emptyText\">該当する記事がありません</p>');\n\t\t\t\tvar existingElement = $('.emptyText');\n\t\t\t\tif(!$('.comInterviewList > li:visible').length){\n\t\t\t\t\tif (!existingElement.length) {\n\t\t\t\t\t\tnewElement.insertBefore($('.comInterviewList'));\n\t\t\t\t\t}\n\t\t\t\t}else{\n\t\t\t\t\tnewElement.remove();\n\t\t\t\t\texistingElement.remove();\n\t\t\t\t}\n\t\t\t\t$('.comInterviewList > li:visible').each(function(index, element) {\n\t\t\t\t\t$(this).attr('col', index % 4 + 1);\n\t\t\t\t});\n\t\t\t\t$.fn.matchHeight._apply($('.comInterviewList li:visible .ttl'));\n\t\t\t}\n\t\t});\n\t</script>\n</body>\n</html>","finalUrl":"https://www.abeam-s.com/common/interview/","rendered":false,"_cachedAt":"2026-06-22T21:22:49.999Z"}