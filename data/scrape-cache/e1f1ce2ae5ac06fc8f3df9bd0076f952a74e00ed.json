a itemprop=\"position\" content=\"2\" />\n    </li>\n    <!--li-->\n  </ol>\n</div>\n<!--breadcrumbBox-->\n\n<!--header-->\n<i id=\"x_1\" class=\"x_item\"></i><i id=\"x_2\" class=\"x_item\"></i>\n\n<div id=\"mvPage\" class=\"mv\">\n</div>\n<!--mv-->\n\n<div id=\"contents\">\n  <main id=\"main\">\n    <section>\n      <article>\n\n        <div class=\"titleBox_whiteBox titleBox_whiteBox_center markParent\">\n          <i class=\"mark\"><img src=\"/group/web_parts/img/tsukada/cmn/mark_1.png\"></i>\n          <div class=\"titleBox center\">\n            <h2 class=\"jp\"><strong>採用情報</strong></h2><br>\n            <p class=\"en keyColor\"><span>RECRUIT</span></p>\n          </div>\n        </div>\n\n        <p class=\"max1200 w90 centerBox btm100px\"><a href=\"https://www.ttk-g.co.jp/recruit/group/\" target=\"_blank\"><img src=\"/group/web_parts/img/tsukada/cmn/recBNR.png\" width=\"100%\" alt=\"TTK採用サイト\"></a></p>\n\n\n        <div class=\"recWrap markParent\">\n          <i class=\"mark\"><img src=\"/group/web_parts/img/tsukada/cmn/mark_1.png\"></i>\n          <div class=\"titleBox center\">\n            <h2 class=\"jp\"><strong>採用情報</strong></h2><br>\n            <p class=\"en keyColor\"><span>RECRUIT</span></p>\n          </div>\n\n\n\n          <div class=\"ancBox ancBox_3\">\n            <ul>\n              <li><a href=\"#newGraduate\"><span>新卒採用情報</span></a></li>\n              <li><a href=\"#mid_career\"><span>中途採用情報</span></a></li>\n              <li><a href=\"#career\"><span>キャリア採用情報</span></a></li>\n            </ul>\n          </div>\n\n\n          <div class=\"ancParent\">\n            <i class=\"ancPoint\" id=\"newGraduate\"></i>\n            <div class=\"recBox w90 max1000 centerBox ckBox\">\n              <div class=\"simpleTBL baseTBL\">\n                                  <table>\n<thead>\n<tr>\n<th colspan=\"2\">新卒採用情報</th>\n</tr>\n</thead>\n<tbody>\n<tr>\n<th>募集内容</th>\n<td>&nbsp;正社員（電気設備工事の設計・施工管理業務）</td>\n</tr>\n<tr>\n<th>勤務地</th>\n<td>本社勤務<br />\n所在地：〒989-3124　宮城県仙台市青葉区上愛子字松原47-19<br />\n※工事現場に直接通勤する場合あり</td>\n</tr>\n<tr>\n<th>勤務時間</th>\n<td>8:30～17:00</td>\n</tr>\n<tr>\n<th>休日・休暇</th>\n<td>＜完全週休2日制＞土・日・祝祭日<br />\n・創立記念日：2/4<br />\n・夏季休暇：8月中に指定する3日間<br />\n・年末年始休暇：12/29～1/3<br />\n・年次有給休暇<br />\n・特別有給休暇</td>\n</tr>\n<tr>\n<th>給与支給額</th>\n<td>208,500円～<br />\n（基本給：193,500円　業務手当：15,000円）</td>\n</tr>\n<tr>\n<th>昇給・賞与</th>\n<td>昇給：年1回　賞与（年2回支給）</td>\n</tr>\n<tr>\n<th>諸手当</th>\n<td>・資格手当（例：1種電気工事士　5,000円/月　など）<br />\n・通勤費　・業務手当　・役職手当　・家族手当　・住宅手当</td>\n</tr>\n<tr>\n<th>福利厚生</th>\n<td>\n<p>・社会保険完備</p>\n\n<p>・福利厚生サービス「ベネフィット・ステーション」加入</p>\n</td>\n</tr>\n<tr>\n<th>募集対象</th>\n<td>高校卒業(見込)以上</td>\n</tr>\n<tr>\n<th>応募方法</th>\n<td>①履歴書を本社に郵送してください。<br />\n②書類確認後、面接選考実施日時を郵送で通知します。<br />\n③本社にて面接選考<br />\n　※選考会場までの旅費（交通費）を支給します。<br />\n④選考結果を郵送で通知します。（面談後7日以内）</td>\n</tr>\n<tr>\n<th>受付期間</th>\n<td>随時受付（事前に電話にてご確認ください）</td>\n</tr>\n<tr>\n<th>問合せ先</th>\n<td>022-397-7192（代表）<br />\n　　担当者：総務部　千田　昌幸</td>\n</tr>\n</tbody>\n</table>\n                              </div>\n            </div>\n            <!--recBox-->\n\n            <div class=\"recBTN_box w90 max1000 centerBox\">\n              <p class=\"contactBTN\"><a href=\"/contact/\"><span class=\"inr\">お問い合わせはこちらから</span></a></p>\n              <p class=\"telBTN\"><a href=\"tel:0223977192\"><span class=\"inr\"><span class=\"fa-stack fa-lg\"><i class=\"fa fa-circle fa-stack-2x\"></i><i class=\"fa fa-phone fa-stack-1x fa-inverse\"></i> </span> 022-397-7192</span></a></p>\n            </div>\n            <!--recBTN_box-->\n\n          </div>\n\n\n          <div class=\"ancParent\">\n            <i class=\"ancPoint\" id=\"mid_career\"></i>\n            <div class=\"recBox w90 max1000 centerBox ckBox\">\n              <div class=\"simpleTBL baseTBL\">\n                                  <table>\n<thead>\n<tr>\n<th colspan=\"2\">中途採用情報</th>\n</tr>\n</thead>\n<tbody>\n<tr>\n<th>業務内容</th>\n<td>&nbsp;正社員（電気設備工事の設計・施工管理業務）</td>\n</tr>\n<tr>\n<th>勤務地</th>\n<td>本社勤務<br />\n所在地：〒989-3124　宮城県仙台市青葉区上愛子字松原47-19<br />\n※工事現場に直接通勤する場合あり</td>\n</tr>\n<tr>\n<th>勤務時間</th>\n<td>８：３０～１７：００</td>\n</tr>\n<tr>\n<th>休日休暇</th>\n<td>＜完全週休2日制＞土・日・祝祭日<br />\n・創立記念日：2/4<br />\n・夏季休暇：8月中に指定する3日間<br />\n・年末年始休暇：12/29～1/3<br />\n・年次有給休暇<br />\n・特別有給休暇</td>\n</tr>\n<tr>\n<th>給与</th>\n<td>208,500円～318,000円<br />\n（基本給：193,500円～　業務手当：15,000円他）</td>\n</tr>\n<tr>\n<th>昇給・賞与</th>\n<td>昇給：年1回　賞与（年2回支給）</td>\n</tr>\n<tr>\n<th>諸手当</th>\n<td>・資格手当（例：1種電気工事士　5,000円/月　など）<br />\n ・通勤費　・業務手当　・役職手当　・家族手当　・住宅手当</td>\n</tr>\n<tr>\n<th>福利厚生</th>\n<td>\n<p>・社会保険完備</p>\n\n<p>・福利厚生サービス「ベネフィット・ステーション」加入</p>\n</td>\n</tr>\n<tr>\n<th>募集対象</th>\n<td>高校卒業以上</td>\n</tr>\n<tr>\n<th>応募方法</th>\n<td>①履歴書を本社に郵送してください。<br />\n②書類確認後、面接選考実施日時を郵送で通知します。<br />\n③本社にて面接選考<br />\n　※選考会場までの旅費（交通費）を支給します。<br />\n④選考結果を郵送で通知します。（面談後7日以内）</td>\n</tr>\n<tr>\n<th>既卒応募</th>\n<td>随時受付（事前に電話で確認して下さい）</td>\n</tr>\n<tr>\n<th>問合せ先</th>\n<td>022-397-7192（代表）<br />\n　　担当者：総務部　千田　昌幸</td>\n</tr>\n</tbody>\n</table>\n                              </div>\n            </div>\n            <!--recBox-->\n\n            <div class=\"recBTN_box w90 max1000 centerBox\">\n              <p class=\"contactBTN\"><a href=\"/contact/\"><span class=\"inr\">お問い合わせはこちらから</span></a></p>\n              <p class=\"telBTN\"><a href=\"tel:0223977192\"><span class=\"inr\"><span class=\"fa-stack fa-lg\"><i class=\"fa fa-circle fa-stack-2x\"></i><i class=\"fa fa-phone fa-stack-1x fa-inverse\"></i> </span> 022-397-7192</span></a></p>\n            </div>\n            <!--recBTN_box-->\n\n          </div>\n\n\n          <div class=\"ancParent\">\n            <i class=\"ancPoint\" id=\"career\"></i>\n            <div class=\"recBox w90 max1000 centerBox ckBox\">\n              <div class=\"simpleTBL baseTBL\">\n                                  <table>\n                    <thead>\n                    <tr>\n                      <th colspan=\"2\">キャリア採用情報</th>\n                    </tr>\n                    </thead>\n                    <tbody>\n      