!-- /box-title -->\r\n\r\n      <div class=\"nav-breadcrumb\">\r\n        <ul>\r\n          <li><a href=\"/\">HOME</a></li>\r\n          <li><a href=\"/recruit/\">採用情報</a></li>\r\n          <li>キャリア採用情報</li>\r\n        </ul>\r\n      </div><!-- /nav-breadcrumb -->\r\n\r\n    </div><!-- /hero-cmn-01 -->\r\n\r\n    <div class=\"contents\">\r\n      <div class=\"contents-in\">\r\n        <div class=\"contents-container\">\r\n\r\n         <section class=\"section-about-global\">\r\n             <div class=\"section_head-career\">\r\n                 <h2 class=\"section_head-title\">グローバル職</h2>\r\n            </div>\r\n            <div class=\"section_inner\">\r\n                <div class=\"section_flex-box_clickable\">\r\n                    <a href=\"../global_career/\" target=\"_blank\">\r\n                    <div class=\"section_flex-box_clickable_image\">\r\n                        <img src=\"/assets/images/recruit/img_recruit_13.jpg\" alt=\"\">\r\n                    </div>\r\n                    <div class=\"section_flex-box_clickable_text only-lead\">\r\n                        <p class=\"section_flex-box_clickable_text-lead\">「営業」「法務」「財務」「プラントエンジニア」「ITエンジニア」「商品開発」など、多種多様なポジションで挑戦者を求めています。今までに培ってきた経験やスキルを当社で存分に発揮し、社会に大きな影響を与える挑戦を行なってください。</p>\r\n                        <span class=\"icon_new-window\"></span>\r\n                    </div>\r\n                    </a>\r\n                </div>\r\n            </div>\r\n         </section>\r\n\r\n         <section class=\"section-about-occupation\">\r\n            <div class=\"section_head-career\">\r\n                <h2 class=\"section_head-title\">オペレーター・設備メンテナンス業務</h2>\r\n           </div>\r\n           <div class=\"section_inner\">\r\n               <div class=\"section_flex-box_clickable\">\r\n                   <a href=\"/recruit/ss/career/\" target=\"_blank\">\r\n                   <div class=\"section_flex-box_clickable_image\">\r\n                       <img src=\"/assets/images/recruit/img_recruit_10.png\" alt=\"\">\r\n                   </div>\r\n                   <div class=\"section_flex-box_clickable_text only-lead\">\r\n                       <p class=\"section_flex-box_clickable_text-lead\">「機械・電気・製造知識」「製造・安全・工程管理」「課題発見解決能力」「人材育成、リーダーシップ」など、働く中で様々な知識やスキルが身につきます。技術のエキスパートとして活躍してください。</p>\r\n                       <span class=\"icon_new-window\"></span>\r\n                   </div>\r\n                   </a>\r\n               </div>\r\n               <div class=\"section_link\">\r\n                <a href=\"/recruit/career.html\" target=\"_blank\">\r\n                    <div class=\"section_link-title\">\r\n                        <h3>キャリア登録受付中<br class=\"only-sp\">（オペレーター・<br class=\"only-sp\">設備メンテナンス業務）</h3>\r\n                    </div>\r\n                    <p class=\"section_link-lead\">\r\n                        日本製鉄へのご転職を少しでもお考えの方が、ご自身の情報をご登録頂くことからスタートし、その後、ご希望に適した勤務地での募集があった際に、当社から都度その選考に関する情報をご紹介する制度です。</p>\r\n                </a>\r\n               </div>\r\n               \r\n           </div>\r\n        </section>\r\n\r\n\r\n        <div class=\"box-cont-recruit-01\">\r\n          <div class=\"box-cmn-card-01\">\r\n            <div class=\"box-cmn-title-01\">\r\n              <h2 class=\"ttl-cmn-02\">STEELWORKS</h2>\r\n              <div class=\"box-title-in\">\r\n                <div class=\"box-title-left\">\r\n                  <p class=\"txt-cmn-02\">製鉄所一覧</p>\r\n                </div>\r\n                <!-- /box-title-left -->\r\n              </div>\r\n              <!-- /box-title-in -->\r\n            </div>\r\n            <!-- /box-cmn-title-01 -->\r\n            <div class=\"table-cmn-02 two-col\">\r\n              <div class=\"box-table-detail\">\r\n                <div class=\"box-title\">北海道</div>\r\n                <div class=\"box-link\">\r\n                  <ul class=\"list-links-01\">\r\n                    <li><a class=\"link-cmn-01\" href=\"/works/north_nippon/muroran/recruit/\">北日本製鉄所 室蘭地区</a></li>\r\n                  </ul>