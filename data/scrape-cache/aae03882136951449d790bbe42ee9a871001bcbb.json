{"url":"https://www.yaskawa.co.jp/recruit/recruit/faq.html","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n\n<head>\n\t<meta charset=\"utf-8\">\n\t<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n\t<meta name=\"format-detection\" content=\"telephone=no\">\n\t<title>採用FAQ｜株式会社安川電機｜採用情報</title>\n\t<meta name=\"description\" content=\"採用にまつわるよくある質問はこちらをご覧ください。安川電機は、独自の技術力と製品で、世界中のものづくりの品質と生産効率の向上に貢献しています。\">\n\t<link rel=\"stylesheet\" href=\"../assets/css/style.css\">\n\t<link rel=\"stylesheet\" href=\"../assets/css/add202112.css\">\n\t<script src=\"../assets/js/main-bundle.js\" defer></script>\n\t<script src=\"/recruit/assets/js/common.js\" defer></script>\n\t<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\">\n\t<!-- Noto Sans 400 500 900 -->\n\t<link href=\"https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&display=swap\" rel=\"stylesheet\">\n\t<!-- Roboto 500 italic -->\n\t<link href=\"https://fonts.googleapis.com/css2?family=Roboto:ital,wght@1,500&display=swap\" rel=\"stylesheet\">\n\t<!-- Roboto 400 700 -->\n\t<link href=\"https://fonts.googleapis.com/css2?family=Roboto:wght@400;700&display=swap\" rel=\"stylesheet\">\n\t<!-- Hind 400 700 -->\n\t<link href=\"https://fonts.googleapis.com/css2?family=Hind:wght@400;700&display=swap\" rel=\"stylesheet\">\n\t<!-- Google Tag Manager -->\n\t<script>\n\t\t(function(w, d, s, l, i) {\n\t\t\tw[l] = w[l] || [];\n\t\t\tw[l].push({\n\t\t\t\t'gtm.start': new Date().getTime(),\n\t\t\t\tevent: 'gtm.js'\n\t\t\t});\n\t\t\tvar f = d.getElementsByTagName(s)[0],\n\t\t\t\tj = d.createElement(s),\n\t\t\t\tdl = l != 'dataLayer' ? '&l=' + l : '';\n\t\t\tj.async = true;\n\t\t\tj.src = 'https://www.googletagmanager.com/gtm.js?id=' + i + dl;\n\t\t\tf.parentNode.insertBefore(j, f);\n\t\t})(window, document, 'script', 'dataLayer', 'GTM-KJJZWHQ');\n\n\t</script>\n\t<!-- End Google Tag Manager -->\n</head>\n\n<body>\n\t<!-- Google Tag Manager (noscript) -->\n\t<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-KJJZWHQ\" height=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n\t<!-- End Google Tag Manager (noscript) -->\n\t<div class=\"wrap\">\n\t\t<header class=\"header no-animation\">\n\t\t\t<div id=\"js-header-h\" class=\"header__top\">\n\t\t\t\t<div class=\"header__logo\">\n\t\t\t\t\t<a href=\"..\">\n\t\t\t\t\t\t<h1>\n\t\t\t\t\t\t\t<picture>\n\t\t\t\t\t\t\t\t<source media=\"(max-width: 900px)\" srcset=\"../assets/images/logo_sp.svg\">\n\t\t\t\t\t\t\t\t<img src=\"../assets/images/logo.svg\" alt=\"YASKAWA 安川電機 RECRUITMENT SITE\">\n\t\t\t\t\t\t\t</picture>\n\t\t\t\t\t\t</h1>\n\t\t\t\t\t</a>\n\t\t\t\t</div>\n\t\t\t\t<div class=\"header__link _mypage \">\n\t\t\t\t\t<div><span>2027年卒<br>MYPAGE</span></div>\n\t\t\t\t\t<div class=\"header__child-link _02\">\n\t\t\t\t\t\t<a href=\"https://job.axol.jp/bx/s/yaskawa_27/entry/\" target=\"_blank\" rel=\"noopener noreferrer\"><span>新規登録</span></a>\n\t\t\t\t\t\t<a href=\"https://job.axol.jp/bx/s/yaskawa_27/mypage/\" target=\"_blank\" rel=\"noopener noreferrer\"><span>LOGIN</span></a>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t\t<div class=\"header__link _internship \">\n\t\t\t\t\t<div><span>2028年卒<br>MYPAGE</span></div>\n\t\t\t\t\t<div class=\"header__child-link _02\">\n\t\t\t\t\t\t<a href=\"https://axol.jp/zw/s/yaskawa_28/entry/agreement\" target=\"_blank\" rel=\"noopener noreferrer\"><span>新規登録</span></a>\n\t\t\t\t\t\t<a href=\"https://axol.jp/zw/s/yaskawa_28/mypage/login\" target=\"_blank\" rel=\"noopener noreferrer\"><span>LOGIN</span></a>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t\t<div class=\"header__hamburger no-animation\">\n\t\t\t\t\t<div class=\"header__hamburger-inner\">\n\t\t\t\t\t\t<span class=\"header__hamburger-line _01\"></span>\n\t\t\t\t\t\t<span class=\"header__hamburger-line _02\"></span>\n\t\t\t\t\t\t<span class=\"header__hamburger-line _03\"></span>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t\t<div class=\"header__top-bg\"></div>\n