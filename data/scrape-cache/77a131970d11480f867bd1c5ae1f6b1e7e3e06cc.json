"service_type[kouza]\" >\n                                <span class=\"checkmark\"></span>\n                            </label>\n                        </div>\n\n                        <div class=\"formField__row\">\n                            <label class=\"custom-checkbox\">コンビニ支払い\n                                <input type=\"checkbox\" onchange=\"changeToComplete(this,'必須')\" value=\"コンビニ支払い\" name=\"service_type[conbini]\" >\n                                <span class=\"checkmark\"></span>\n                            </label>\n                        </div>\n\n                        <div class=\"formField__row\">\n                            <label class=\"custom-checkbox\">その他\n                                <input type=\"checkbox\" onchange=\"changeToComplete(this,'必須')\" onclick=\"modifyCustomMessage1()\" value=\"その他\" name=\"service_type[other]\" >\n                                <span class=\"checkmark\"></span>\n                            </label>\n                        </div>\n                                                                    </div>\n                </div>\n                <div class=\"formCont__divider\"></div>\n                <div class=\"formField formField--center\">\n                    <div class=\"formField__label\">\n                        <label class=\"formField__labelText u-line-height\">委託者番号・収納企業番号</label>\n                        <span class=\"formField__labelRequired js-is-status\">必須</span>\n                    </div>\n                    <div class=\"formField__input\">\n                        <span class=\"formField__inputNotice\">※半角英数字5桁</span>\n                        <input class=\"formField__inputText js-inputText\" onchange=\"changeToComplete(this,'必須')\" placeholder=\"例）00000\" type=\"text\" name=\"contact_phonenumber_1\" value=\"\">\n                                            </div>\n                </div>\n                <div class=\"formCont__divider\"></div>\n                <div class=\"formField\">\n                    <div class=\"formField__label\">\n                        <label class=\"formField__labelText\">貴社名</label>\n                        <span class=\"formField__labelRequired js-is-status\">必須</span>\n                    </div>\n                    <div class=\"formField__input\">\n                        <input class=\"formField__inputText js-inputText\" onchange=\"changeToComplete(this,'必須')\" placeholder=\"例）三菱UFJファクター株式会社\" type=\"text\" name=\"contact_phonenumber_2\" value=\"\">\n                                            </div>\n                </div>\n\n                <div class=\"formCont__divider\"></div>\n\n                <div class=\"formField\">\n                    <div class=\"formField__label\">\n                        <label class=\"formField__labelText\">ご担当者名</label>\n                        <span class=\"formField__labelRequired js-is-status\">必須</span>\n                    </div>\n                    <div class=\"formField__input\">\n                        <div class=\"formField__column\">\n                            <div class=\"formField__columnItem u-mb_20 u-spmb_10\">\n                                <div class=\"formField__inputLabel\">\n                                    <span class=\"formField__inputLabelText\">姓</span>\n                                    <input class=\"formField__inputText\" onchange=\"changeToComplete(this,'必須')\" placeholder=\"例) 三菱\" type=\"text\" name=\"c_rep_gender\" value=\"\">\n                                                                    </div>\n                            </div>\n\n                            <div class=\"formField__columnItem u-mb_20 u-spmb_10\">\n                                <div class=\"formField__inputLabel\">\n                                    <span class=\"formField__inputLabelText\">名</span>\n                                    <input class=\"formField__inputText\" onchange=\"changeToComplete(this,'必須')\" placeholder=\"例) 太郎\" type=\"text\" name=\"c_rep_firstname\" value=\"\">\n                                                                    </div>\n                            </div>\n\n                            <div class=\"formField__columnItem\">\n                                <div class=\"formField__inputLabel\">\n                                    <span class=\"formField__inputLabelText\">セイ</span>\n                                    <input class=\"formField__inputText\" onchange=\"changeToComplete(this,'必須')\" placeholder=\"例) ミツビシ\" type=\"text\" name=\"c_rep_surname\" value=\"\">\n                                                                    </div>\n                            </div>\n\n                            <div class=\"formField__columnItem\">\n                                <div class=\"formField__inputLabel\">\n                                    <span class=\"formField__inputLabelText\">メイ</span>\n                                    <input class=\"formField__inputText\" onchange=\"changeToComplete(this,'必須')\" placeholder=\"例) タロウ\" type=\"text\" name=\"c_rep_middlename\" value=\"\">\n                                                                    </div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n\n                <div class=\"formCont__divider\"></div>\n\n                <div class=\"formField\">\n                    <div class=\"formField__label formField--center\">\n                        <label class=\"formField__labelText\">メールアドレス</label>\n                        <span class=\"formField__labelRequired js-is-status\">必須</span>\n                    </div>\n                    <div class=\"formField__input js-harai-dealings\">\n\n                        <div class=\"formField__radioWrap\">\n                            <label class=\"custom-radiobutton\">あり\n                                <input type=\"radio\" value=\"yes\" name=\"email\" onchange=\"changeToComplete(this,'必須')\"  class=\"js-radio-yes\">\n                                <span class=\"radiobtn\"></span>\n                            </label>\n\n                            <label class=\"custom-radiobutton\">なし\n                                <input type=\"radio\" value=\"no\" name=\"email\" onchange=\"changeToComplete(this,'必須')\" checked class=\"js-radio-no\">\n                                <span class=\"radiobtn\"></span>\n                            </label>\n                        </div>\n\n                        <div class=\"formField__inputLabel js-is-form form--display\">\n                            <span class=\"formField__inputNotice\"><span class=\"u-kome\">※SMS、MMS、iMessage不可</span></span>\n                            <input class=\"formField__inputText\" onchange=\"changeToComplete(this,'必須')\" placeholder=\"例）factor_taro@muf.co.jp\" type=\"text\" name=\"branch_name\" value=\"\">\n                                                    </div>\n                    </div>\n                </div>\n\n                <div class=\"formCont__divider\"></div>\n\n\n                <div class=\"formField formField--center\">\n                    <div class=\"formField__label\">\n                        <label class=\"formField__labelText\">電話番号</label>\n                        <span class=\"formField__labelRequired js-is-status\">必須</span>\n                    </div>\n                    <div class=\"formField__input\">\n                        <span class=\"formField__inputNotice\"><span class=\"u-kome\">※</span>ハイフンなし</span>\n                        <input class=\"formField__inputNumber  js-phone\" onchange=\"changeToComplete(this,'必須')\" placeholder=\"例) 0312345678\" type=\"number\" min=\"0\" name=\"contact_phonenumber_3\" value=\"\">\n                                            </div>\n                </div>\n\n                <div class=\"formCont__divider\"></div>\n\n                <div class=\"formField\">\n                    <div class=\"formField__label\">\n        