{"url":"https://www.cnw.co.jp/recruit/","html":"<!DOCTYPE html>\r\n<html lang=\"ja\">\r\n<head>\r\n  <meta charset=\"UTF-8\">\r\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n  <title>採用サイト| 株式会社キャリアネットワーク</title>\r\n  <link href=\"https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@300;400;500;600;700&family=Noto+Sans+JP:wght@300;400;500;700&family=Inter:wght@300;400;500;600;700&display=swap\" rel=\"stylesheet\">\r\n  <link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@fortawesome/fontawesome-free@6.4.0/css/all.min.css\">\r\n  <link rel=\"stylesheet\" href=\"css/sub.css\">\r\n  <link rel=\"stylesheet\" href=\"css/mockup.css\">\r\n  \r\n</head>\r\n<body><div id=\"wrapper\">\r\n\r\n\r\n\r\n<!-- ========================================\r\n     HEADER\r\n======================================== -->\r\n<header class=\"site-header\" id=\"\">\r\n  <div class=\"site-header__inner\">\r\n    <a href=\"#\" class=\"site-header__logo\">\r\n      <img src=\"images/logo.webp\" width=\"200\">\r\n      <span class=\"site-header__logo-text\">採用サイト<span>RECRUIT</span></span>\r\n    </a>\r\n    <nav class=\"site-header__nav\" id=\"headerNav\">\r\n      <ul>\r\n        <li><a href=\"#about\">会社を知る</a></li>\r\n        <li><a href=\"work.html\">仕事を知る</a></li>\r\n        <li><a href=\"people.html\">人を知る</a></li>\r\n        <li><a href=\"jobs.html\">採用情報</a></li>\r\n      </ul>\r\n    </nav>\r\n    <a href=\"#final-cta\" class=\"site-header__cta\">ENTRY</a>\r\n    <button class=\"site-header__hamburger\" id=\"hamburger\" aria-label=\"メニュー\">\r\n      <span></span><span></span><span></span>\r\n    </button>\r\n  </div>\r\n</header>\r\n\r\n<!-- SP メニュー -->\r\n<div class=\"sp-menu\" id=\"spMenu\">\r\n  <ul>\r\n    <li><a href=\"#about\" class=\"sp-menu__link\">会社を知る</a></li>\r\n    <li><a href=\"work.html\" class=\"sp-menu__link\">仕事を知る</a></li>\r\n    <li><a href=\"people.html\" class=\"sp-menu__link\">人を知る</a></li>\r\n    <li><a href=\"jobs.html\" class=\"sp-menu__link\">採用情報</a></li>\r\n  </ul>\r\n  <a href=\"#final-cta\" class=\"sp-menu__cta\">まず話を聞いてみる（無料）</a>\r\n  <a href=\"#final-cta\" class=\"sp-menu__cta sp-menu__cta--sub\">30秒でENTRY →</a>\r\n</div>\r\n\r\n<!-- ========================================\r\n     SEC 00: FIRST VIEW\r\n======================================== -->\r\n<section class=\"fv\" id=\"fv\">\r\n  <div class=\"fv__bg\">\r\n    <!-- 動画背景レイヤー -->\r\n    <div class=\"fv__video-layer\">\r\n      <video\r\n        class=\"fv__video\"\r\n        autoplay\r\n        muted\r\n        \r\n        playsinline\r\n        webkit-playsinline\r\n        preload=\"auto\"\r\n        poster=\"images/fv-main.jpg\"\r\n      >\r\n        <source src=\"images/fv-b.mp4\" type=\"video/mp4\">\r\n        <!-- フォールバック：動画が読み込めない場合は背景画像を表示 -->\r\n      </video>\r\n    </div>\r\n\r\n    <div class=\"fv__gradient-layer\"></div>\r\n  </div>\r\n\r\n  <!-- FVコンテンツ：左右分割型 -->\r\n  <div class=\"fv__layout\">\r\n    <!-- 左：テキスト -->\r\n    <div class=\"fv__content\">\r\n      <h1 class=\"fv__copy\">\r\n        <span>学歴より、熱意。</span><br>\r\n        <span>未経験から、<br class=\"sp-only\">人材のプロへ。</span>\r\n      </h1>\r\n      <p class=\"fv__subcopy\">\r\n        <span>人の人生に本気で向き合う仕事を、あなたと一緒につくっていきたい。</span>\r\n      </p>\r\n      <div class=\"fv__ctas\">\r\n        <a href=\"#final-cta\" class=\"fv__cta fv__cta--primary\">\r\n          まず話を聞いてみる\r\n          <small>カジュアル面談・選考なし・無料</small>\r\n        </a>\r\n        <a href=\"#final-cta\" class=\"fv__cta fv__cta--secondary\">\r\n          30秒でENTRY <i class=\"fa-solid fa-arrow-right\"></i>\r\n        </a>\r\n      </div>\r\n\r\n      <!-- FV 数値ハイライト -->\r\n      <div class=\"fv__stats\">\r\n        <div class=\"fv__stat\">\r\n          <span class=\"fv__stat-num\">85<span class=\"fv__stat-unit\">%</span></span>\r\n          <span class=\"fv__stat-label\">未経験入社率</span>\r\n        </div>\r\n        <div class=\"fv__stat-divider\"></div>\r\n        <div class=\"fv__stat\">\r\n          <span class=\"fv__stat-num\">1,200<span class=\"fv__stat-unit\">名</span></span>\r\n          <span class=\"fv__stat-label\">累計支援実績</span>\r\n        </div>\r\n        <div class=\"fv__stat-divider\"></div>\r\n        <div class=\"fv__stat\">\r\n          <span class=\"fv__stat-num\">23<span class=\"fv__stat-unit\">年</span></span>\r\n          <span class=\"fv__stat-label\">地域での実績</span>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- 右：写真フレーム（PCのみ表示） -->\r\n    <!--<div class=\"fv__photo-frame-col pc-only\">\r\n      <div class=\"fv__photo-card\">\r\n        <img src=\"images/staff-a.jpg\" alt=\"先輩社員\" class=\"fv__photo-card-img\">\r\n        <div class=\"fv__photo-card-caption\">\r\n          <span class=\"fv__photo-card-badge\">未経験入社</span>\r\n          <span class=\"fv__photo-card-text\">アパレル出身 → 人材のプロへ</span>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>-->\r\n\r\n  <div class=\"fv__scroll-hint\">\r\n    <div class=\"fv__scroll-line\"></div>\r\n    <span>SCROLL</span>\r\n  </div>\r\n</section>\r\n\r\n<!-- ========================================\r\n     SEC 01: BRIDGE COPY\r\n======================================== -->\r\n<section class=\"section-bridge\" id=\"bridge\">\r\n  <div class=\"container\">\r\n    <div class=\"bridge__line\"></div>\r\n    <p class=\"bridge__label\">MISSION</p>\r\n    <h2 class=\"bridge__heading\">\r\n      人の可能性と、企業の未来をつなぐ。\r\n    </h2>\r\n    <p class=\"bridge__body\">\r\n      それが、キャリアネットワークという仕事です。<br>\r\n      未経験から始めた先輩たちが証明している。<br>\r\n      学歴より、熱意。姿勢こそが、この仕事の資本です。\r\n    </p>\r\n    <div class=\"bridge__line\"></div>\r\n  </div>\r\n</section>\r\n\r\n<!-- ========================================\r\n     SEC 02: 仕事を知る\r\n======================================== -->\r\n<section class=\"section-work\" id=\"work\">\r\n  <div class=\"container\">\r\n    <div class=\"section-header\">\r\n      <span class=\"section-header__en\">WHAT WE DO</span>\r\n      <h2 class=\"section-header__ja\">仕事を知る</h2>\r\n      <p class=\"section-header__desc\">一人の就職が、一つの人生を変える。<br>私たちは、人と仕事を最良のかたちでつなぐ専門家です。</p>\r\n    </div>\r\n\r\n    <div class=\"work-blocks\">\r\n      <!-- ブロック1 -->\r\n      <div class=\"work-block work-block--img-right\">\r\n        <div class=\"work-block__text\">\r\n          <span class=\"work-block__label\">派遣コーディネーター</span>\r\n          <h3 class=\"work-block__title\">企業の\"採用力\"を<br>一緒につくる仕事。</h3>\r\n          <p class=\"work-block__body\">福井県の中小企業の人事課題に向き合い、最適な人材を提案します。ただ「人を送る」のではなく、企業文化や成長段階を深く理解した上で、双方にとって本当に良いマッチングを追求します。</p>\r\n          <div class=\"work-block__tags\">\r\n            <span>未経験OK</span><span>法人営業</span><span>コーディネート</span>\r\n          </div>\r\n        </div>\r\n        <div class=\"work-block__img\">\r\n          <img src=\"images/work-proposal.jpg\" alt=\"派遣コーディネーターの提案シーン\" class=\"work-block__photo\">\r\n        </div>\r\n      </div>\r\n\r\n      <!-- ブロック2 -->\r\n      <div class=\"work-block work-block--img-left\">\r\n        <div class=\"work-block__img\">\r\n          <img src=\"images/work-consultation.jpg\" alt=\"キャリアアドバイザーの相談シーン\" class=\"work-block__photo\">\r\n        </div>\r\n        <div class=\"work-block__text\">\r\n          <span class=\"work-block__label\">キャリアアドバイザー</span>\r\n          <h3 class=\"work-block__title\">求職者の\"一歩\"に<br>伴走する仕事。</h3>\r\n          <p class=\"work-block__body\">転職・就職を考える方の不安や希望を丁寧にヒアリングし、その人の人生にとって本当に良い選択ができるよう伴走します。「ありがとう」の一言が、この仕事の最大のやりがいです。</p>\r\n          <div class=\"work-block__tags\">\r\n            <span>未経験OK</span><span>個人向け</span><span>キャリア支援</span>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <div class=\"work-link-wrap\">\r\n      <a href=\"#\" class=\"text-link\">仕事の詳細を見る <i class=\"fa-solid fa-arrow-right\"></i></a>\r\n    </div>\r\n  </div>\r\n</section>\r\n\r\n<!-- ========================================\r\n     SEC 03: 数字で見る会社\r\n======================================== -->\r\n<section class=\"section-numbers\" id=\"numbers\">\r\n  <div class=\"container\">\r\n    <div class=\"section-header section-header--center\">\r\n      <span class=\"section-header__en\">BY THE NUMBERS</span>\r\n      <h2 class=\"section-header__ja\">数字で見る会社</h2>\r\n    </div>\r\n    <div class=\"numbers-grid\">\r\n      <div class=\"number-item\">\r\n        <div class=\"number-item__num\" data-count=\"23\">0<span class=\"number-item__unit\">年</span></div>\r\n        <div class=\"number-item__label\">創業年数</div>\r\n        <div class=\"number-item__note\">地域に根ざした実績</div>\r\n      </div>\r\n      <div class=\"number-item\">\r\n        <div class=\"number-item__num\" data-count=\"85\">0<span class=\"number-item__unit\">%</span></div>\r\n        <div class=\"number-item__label\">未経験入社率</div>\r\n        <div class=\"number-item__note\">入社者の約8割が未経験から</div>\r\n      </div>\r\n      <div class=\"number-item\">\r\n        <div class=\"number-item__num\" data-count=\"1500\">0<span class=\"number-item__unit\">社</span></div>\r\n        <div class=\"number-item__label\">取引先企業数</div>\r\n        <div class=\"number-item__note\">地域企業との深い信頼関係</div>\r\n      </div>\r\n      <div class=\"number-item\">\r\n        <div class=\"number-item__num\" data-count=\"1200\">0<span class=\"number-item__unit\">名</span></div>\r\n        <div class=\"number-item__label\">累計支援人数</div>\r\n        <div class=\"number-item__note\">一人ひとりの人生に向き合った数</div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</section>\r\n\r\n<!-- ========================================\r\n     SEC 04: 未経験でも活躍できる理由\r\n======================================== -->\r\n<section class=\"section-reasons\" id=\"reasons\">\r\n  <div class=\"container\">\r\n    <div class=\"section-header\">\r\n      <span class=\"section-header__en\">WHY YOU CAN</span>\r\n      <h2 class=\"section-header__ja\">未経験でも活躍できる理由</h2>\r\n      <p class=\"section-header__desc\">\r\n        「自分には無理かも…」と思っているあなたへ。<br>\r\n        入社者の約8割が未経験スタートです。\r\n      </p>\r\n    </div>\r\n\r\n    <div class=\"reasons-steps\">\r\n      <div class=\"reason-step\">\r\n        <div class=\"reason-step__num\">01</div>\r\n        <div class=\"reason-step__img\">\r\n          <div class=\"reason-step__img-ph reason-step__img-ph--photo\" style=\"background-image:url('images/reasons-team.jpg')\">\r\n          </div>\r\n        </div>\r\n        <div class=\"reason-step__body\">\r\n          <h3 class=\"reason-step__title\">充実の研修制度</h3>\r\n          <p class=\"reason-step__text\">入社後3ヶ月は研修期間。業界知識・業務フロー・接客ロールプレイングをOJTと集合研修で体系的に学べる環境を整えています。</p>\r\n        </div>\r\n      </div>\r\n      <div class=\"reason-step__arrow\"><i class=\"fa-solid fa-arrow-right\"></i></div>\r\n      <div class=\"reason-step\">\r\n        <div class=\"reason-step__num\">02</div>\r\n        <div class=\"reason-step__img\">\r\n          <div class=\"reason-step__img-ph reason-step__img-ph--photo\" style=\"background-image:url('images/senpai.jpg')\">\r\n          </div>\r\n        </div>\r\n        <div class=\"reason-step__body\">\r\n          <h3 class=\"reason-step__title\">先輩が必ずフォロー</h3>\r\n          <p class=\"reason-step__text\">1on1メンター制度を導入。困ったことや不安なことがあれば、専属の先輩社員がいつでも相談に乗ります。「一人でやれ」とは言いません。</p>\r\n        </div>\r\n      </div>\r\n      <div class=\"reason-step__arrow\"><i class=\"fa-solid fa-arrow-right\"></i></div>\r\n      <div class=\"reason-step\">\r\n        <div class=\"reason-step__num\">03</div>\r\n        <div class=\"reason-step__img\">\r\n          <div class=\"reason-step__img-ph reason-step__img-ph--photo\" style=\"background-image:url('images/hyouka.jpg')\">\r\n          </div>\r\n        </div>\r\n        <div class=\"reason-step__body\">\r\n          <h3 class=\"reason-step__title\">スキルより姿勢を評価</h3>\r\n          <p class=\"reason-step__text\">私たちが採用基準にしているのは「素直に学び続けられるか」。過去の経歴より、今どれだけ本気でいられるかを重視します。</p>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <div class=\"reasons-cta\">\r\n      <p class=\"reasons-cta__text\">あなたも挑戦してみませんか？</p>\r\n      <a href=\"#final-cta\" class=\"reasons-cta__btn\">\r\n        <i class=\"fa-solid fa-calendar-check\"></i>\r\n        カジュアル面談を予約する（無料・選考なし）\r\n      </a>\r\n    </div>\r\n  </div>\r\n</section>\r\n\r\n<!-- ========================================\r\n     SEC 05: 人を知る（社員インタビュー）\r\n======================================== -->\r\n<section class=\"section-people\" id=\"people\">\r\n  <div class=\"container\">\r\n    <div class=\"section-header\">\r\n      <span class=\"section-header__en\">PEOPLE</span>\r\n      <h2 class=\"section-header__ja\">人を知る</h2>\r\n      <p class=\"section-header__desc\">ここで働く人たちを、知ってほしい。<br>未経験からスタートした先輩たちのリアルな声。</p>\r\n    </div>\r\n\r\n    <div class=\"people-cards\" id=\"peopleCards\">\r\n      <!-- カード1 -->\r\n      <article class=\"staff-card\">\r\n        <div class=\"staff-card__img\">\r\n          <img src=\"images/staff-a-s.jpg\" alt=\"N.Yさん\" class=\"staff-card__photo\">\r\n          <div class=\"staff-card__badge\">未経験入社</div>\r\n        </div>\r\n        <div class=\"staff-card__body\">\r\n          <div class=\"staff-card__meta\">\r\n            <span class=\"staff-card__year\">2022年入社</span>\r\n            <span class=\"staff-card__job\">キャリアアドバイザー</span>\r\n          </div>\r\n          <div class=\"staff-card__prev\">前職：アパレル販売</div>\r\n          <h3 class=\"staff-card__name\">N.Yさん <small>（26歳）</small></h3>\r\n          <blockquote class=\"staff-card__quote\">\r\n            \"接客の経験が、意外なほど活きています。人の話を聞く姿勢って、教えてもらうより自分で積み重ねるものだと気づきました。\"\r\n          </blockquote>\r\n          <a href=\"people/a.html\" class=\"staff-card__link\">インタビューを読む <i class=\"fa-solid fa-arrow-right\"></i></a>\r\n        </div>\r\n      </article>\r\n\r\n      <!-- カード2 -->\r\n      <article class=\"staff-card\">\r\n        <div class=\"staff-card__img\">\r\n          <img src=\"images/staff-b-s.jpg\" alt=\"K.Aさん\" class=\"staff-card__photo\">\r\n          <div class=\"staff-card__badge\">未経験入社</div>\r\n        </div>\r\n        <div class=\"staff-card__body\">\r\n          <div class=\"staff-card__meta\">\r\n            <span class=\"staff-card__year\">2021年入社</span>\r\n            <span class=\"staff-card__job\">派遣コーディネーター</span>\r\n          </div>\r\n          <div class=\"staff-card__prev\">前職：飲食店スタッフ</div>\r\n          <h3 class=\"staff-card__name\">K.Aさん <small>（29歳）</small></h3>\r\n          <blockquote class=\"staff-card__quote\">\r\n            \"入社前は『自分に営業なんて無理』と思っていました。でも3ヶ月で案件を担当できた時、ここを選んで良かったって心から思いました。\"\r\n          </blockquote>\r\n          <a href=\"people/b.html\" class=\"staff-card__link\">インタビューを読む <i class=\"fa-solid fa-arrow-right\"></i></a>\r\n        </div>\r\n      </article>\r\n\r\n      <!-- カード3 -->\r\n      <article class=\"staff-card\">\r\n        <div class=\"staff-card__img\">\r\n          <img src=\"images/staff-c-s.jpg\" alt=\"N.Aさん\" class=\"staff-card__photo\">\r\n          <div class=\"staff-card__badge\">第二新卒</div>\r\n        </div>\r\n        <div class=\"staff-card__body\">\r\n          <div class=\"staff-card__meta\">\r\n            <span class=\"staff-card__year\">2023年入社</span>\r\n            <span class=\"staff-card__job\">キャリアアドバイザー</span>\r\n          </div>\r\n          <div class=\"staff-card__prev\">前職：事務職（新卒1年目）</div>\r\n          <h3 class=\"staff-card__name\">N.Aさん <small>（24歳）</small></h3>\r\n          <blockquote class=\"staff-card__quote\">\r\n            \"人の人生に関わる仕事がしたかった。求職者から『転職して良かった』と言われる瞬間に、この仕事を選んだ意味を感じます。\"\r\n          </blockquote>\r\n          <a href=\"people/c.html\" class=\"staff-card__link\">インタビューを読む <i class=\"fa-solid fa-arrow-right\"></i></a>\r\n        </div>\r\n      </article>\r\n    </div>\r\n\r\n    <div class=\"people-more-wrap\">\r\n      <a href=\"people.html\" class=\"text-link\">社員インタビューをもっと見る <i class=\"fa-solid fa-arrow-right\"></i></a>\r\n    </div>\r\n  </div>\r\n</section>\r\n\r\n<!-- ========================================\r\n     SEC 06: 代表メッセージ導線\r\n======================================== -->\r\n<section class=\"section-president\" id=\"president\">\r\n  <div class=\"container\">\r\n    <div class=\"president-inner\">\r\n      <div class=\"president__img\">\r\n        <img src=\"images/president.jpg\" alt=\"代表取締役\" class=\"president__photo\">\r\n        <div class=\"president__img-accent\"></div>\r\n      </div>\r\n      <div class=\"president__text\">\r\n        <span class=\"president__label\">PRESIDENT MESSAGE</span>\r\n        <h2 class=\"president__heading\">\r\n          人の可能性を信じることが、<br>\r\n          この会社の根底にある。\r\n        </h2>\r\n        <p class=\"president__body\">\r\n          人材ビジネスとは、突き詰めると「人を信じる仕事」だと思っています。\r\n          履歴書に書かれた過去ではなく、これから何者になれるかを見る。\r\n          それができる組織でありたいと、私たちは日々考えています。\r\n        </p>\r\n        <p class=\"president__sign\">— 代表取締役　中山 喜雄</p>\r\n        <a href=\"president.html\" class=\"text-link\">代表メッセージを読む <i class=\"fa-solid fa-arrow-right\"></i></a>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</section>\r\n\r\n<!-- ========================================\r\n     SEC 07: 会社を知る（フルワイド）\r\n======================================== -->\r\n<section class=\"section-company\" id=\"about\">\r\n  <div class=\"section-company__bg\">\r\n    <img src=\"images/hero-company.jpg\" alt=\"\" class=\"section-company__bg-img\">\r\n    <div class=\"section-company__overlay\"></div>\r\n  </div>\r\n  <div class=\"section-company__content container\">\r\n    <span class=\"section-header__en section-header__en--white\">ABOUT US</span>\r\n    <h2 class=\"section-company__heading\">福井県の未来を、人でつくる。</h2>\r\n    <p class=\"section-company__body\">\r\n      私たちが向き合うのは、履歴書ではなく人生です。<br>\r\n      地域企業と求職者の間に立ち、双方にとって<br>\r\n      最良のかたちを追い求け続けています。\r\n    </p>\r\n    <div class=\"section-company__values\">\r\n      <div class=\"company-value\">\r\n        <i class=\"fa-solid fa-compass\"></i>\r\n        <div class=\"company-value__title\">MISSION</div>\r\n        <div class=\"company-value__text\">福井県の雇用と人の可能性をつなぐ</div>\r\n      </div>\r\n      <div class=\"company-value\">\r\n        <i class=\"fa-solid fa-eye\"></i>\r\n        <div class=\"company-value__title\">VISION</div>\r\n        <div class=\"company-value__text\">誰もが自分らしく働ける地域社会</div>\r\n      </div>\r\n      <div class=\"company-value\">\r\n        <i class=\"fa-solid fa-heart\"></i>\r\n        <div class=\"company-value__title\">VALUE</div>\r\n        <div class=\"company-value__text\">誠実・熱意・伴走</div>\r\n      </div>\r\n    </div>\r\n    <a href=\"company.html\" class=\"company-link\">会社を知る <i class=\"fa-solid fa-arrow-right\"></i></a>\r\n  </div>\r\n</section>\r\n\r\n<!-- ========================================\r\n     SEC 08: 募集職種\r\n======================================== -->\r\n<section class=\"section-jobs\" id=\"jobs\">\r\n  <div class=\"container\">\r\n    <div class=\"section-header section-header--center\">\r\n      <span class=\"section-header__en\">OPEN POSITIONS</span>\r\n      <h2 class=\"section-header__ja\">今、あなたを求めています</h2>\r\n      <p class=\"section-header__desc\">現在募集中の職種をご確認ください。</p>\r\n    </div>\r\n\r\n    <div class=\"job-cards\">\r\n      <div class=\"job-card\">\r\n        <div class=\"job-card__header\">\r\n          <div class=\"job-card__badges\">\r\n            <span class=\"job-badge job-badge--new\">新規募集</span>\r\n            <span class=\"job-badge job-badge--ok\">未経験OK</span>\r\n          </div>\r\n        </div>\r\n        <h3 class=\"job-card__title\">派遣コーディネーター</h3>\r\n        <div class=\"job-card__details\">\r\n          <div class=\"job-detail\"><i class=\"fa-solid fa-briefcase\"></i> 正社員</div>\r\n          <div class=\"job-detail\"><i class=\"fa-solid fa-location-dot\"></i> 福井県福井市</div>\r\n          <div class=\"job-detail\"><i class=\"fa-solid fa-yen-sign\"></i> 月給 22〜28万円</div>\r\n        </div>\r\n        <p class=\"job-card__desc\">企業への人材派遣提案・コーディネートをお任せします。業界経験は問いません。</p>\r\n        <a href=\"#\" class=\"job-card__btn\">求人詳細を見る <i class=\"fa-solid fa-arrow-right\"></i></a>\r\n      </div>\r\n\r\n      <div class=\"job-card\">\r\n        <div class=\"job-card__header\">\r\n          <div class=\"job-card__badges\">\r\n            <span class=\"job-badge job-badge--ok\">未経験OK</span>\r\n            <span class=\"job-badge job-badge--secondcareer\">第二新卒歓迎</span>\r\n          </div>\r\n        </div>\r\n        <h3 class=\"job-card__title\">キャリアアドバイザー</h3>\r\n        <div class=\"job-card__details\">\r\n          <div class=\"job-detail\"><i class=\"fa-solid fa-briefcase\"></i> 正社員</div>\r\n          <div class=\"job-detail\"><i class=\"fa-solid fa-location-dot\"></i> 福井県福井市</div>\r\n          <div class=\"job-detail\"><i class=\"fa-solid fa-yen-sign\"></i> 月給 22〜28万円</div>\r\n        </div>\r\n        <p class=\"job-card__desc\">求職者のキャリア相談・求人提案・面接サポートをお任せします。</p>\r\n        <a href=\"#\" class=\"job-card__btn\">求人詳細を見る <i class=\"fa-solid fa-arrow-right\"></i></a>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</section>\r\n\r\n<!-- ========================================\r\n     SEC 08.5: 選考フロー\r\n======================================== -->\r\n<section class=\"section-flow\" id=\"flow\">\r\n  <div class=\"container\">\r\n    <div class=\"section-header section-header--center\">\r\n      <span class=\"section-header__en\">FLOW</span>\r\n      <h2 class=\"section-header__ja\">選考の流れ</h2>\r\n      <p class=\"section-header__desc\">まずは気軽に話してみてください。<br>平均2〜3週間でお返事しています。</p>\r\n    </div>\r\n\r\n    <div class=\"flow-steps\">\r\n      <div class=\"flow-step\">\r\n        <div class=\"flow-step__icon\">\r\n          <i class=\"fa-solid fa-comment-dots\"></i>\r\n        </div>\r\n        <div class=\"flow-step__label\">STEP 01</div>\r\n        <h4 class=\"flow-step__title\">カジュアル面談<br><small>（任意）</small></h4>\r\n        <p class=\"flow-step__desc\">選考なし・無料。まず会社の雰囲気を確かめてください。オンライン可。</p>\r\n        <div class=\"flow-step__note\">\r\n          <i class=\"fa-regular fa-clock\"></i> 約30〜45分\r\n        </div>\r\n      </div>\r\n      <div class=\"flow-step__connector\"><i class=\"fa-solid fa-chevron-right\"></i></div>\r\n\r\n      <div class=\"flow-step\">\r\n        <div class=\"flow-step__icon\">\r\n          <i class=\"fa-solid fa-file-lines\"></i>\r\n        </div>\r\n        <div class=\"flow-step__label\">STEP 02</div>\r\n        <h4 class=\"flow-step__title\">エントリー<br><small>（書類選考）</small></h4>\r\n        <p class=\"flow-step__desc\">30秒応募・LINE応募など、お好きな方法でエントリーください。履歴書不要の方法もあり。</p>\r\n        <div class=\"flow-step__note\">\r\n          <i class=\"fa-regular fa-clock\"></i> 3〜5営業日以内に連絡\r\n        </div>\r\n      </div>\r\n      <div class=\"flow-step__connector\"><i class=\"fa-solid fa-chevron-right\"></i></div>\r\n\r\n      <div class=\"flow-step\">\r\n        <div class=\"flow-step__icon\">\r\n          <i class=\"fa-solid fa-laptop\"></i>\r\n        </div>\r\n        <div class=\"flow-step__label\">STEP 03</div>\r\n        <h4 class=\"flow-step__title\">一次面接<br><small>（オンライン可）</small></h4>\r\n        <p class=\"flow-step__desc\">担当者と1対1でお話しします。志望動機より、あなた自身のことを教えてください。</p>\r\n        <div class=\"flow-step__note\">\r\n          <i class=\"fa-regular fa-clock\"></i> 約60分\r\n        </div>\r\n      </div>\r\n      <div class=\"flow-step__connector\"><i class=\"fa-solid fa-chevron-right\"></i></div>\r\n\r\n      <div class=\"flow-step\">\r\n        <div class=\"flow-step__icon\">\r\n          <i class=\"fa-solid fa-handshake\"></i>\r\n        </div>\r\n        <div class=\"flow-step__label\">STEP 04</div>\r\n        <h4 class=\"flow-step__title\">二次面接<br><small>（対面）</small></h4>\r\n        <p class=\"flow-step__desc\">代表も交えた最終面接。オフィスの雰囲気も感じてもらえます。</p>\r\n        <div class=\"flow-step__note\">\r\n          <i class=\"fa-regular fa-clock\"></i> 約60分\r\n        </div>\r\n      </div>\r\n      <div class=\"flow-step__connector\"><i class=\"fa-solid fa-chevron-right\"></i></div>\r\n\r\n      <div class=\"flow-step flow-step--last\">\r\n        <div class=\"flow-step__icon flow-step__icon--offer\">\r\n          <i class=\"fa-solid fa-star\"></i>\r\n        </div>\r\n        <div class=\"flow-step__label\">GOAL</div>\r\n        <h4 class=\"flow-step__title\">内定<br><small>（ご入社）</small></h4>\r\n        <p class=\"flow-step__desc\">内定後も入社前面談・研修計画の共有など、丁寧にフォローします。</p>\r\n        <div class=\"flow-step__note\">\r\n          <i class=\"fa-solid fa-check\"></i> 入社日は応相談\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <div class=\"flow-cta\">\r\n      <p>まずはカジュアル面談から。選考には関係ありません。</p>\r\n      <a href=\"#final-cta\" class=\"flow-cta__btn\">\r\n        <i class=\"fa-solid fa-calendar-check\"></i>\r\n        カジュアル面談を予約する（無料）\r\n      </a>\r\n    </div>\r\n  </div>\r\n</section>\r\n\r\n<!-- ========================================\r\n     SEC 09: FAQ\r\n======================================== -->\r\n<section class=\"section-faq\" id=\"faq\">\r\n  <div class=\"container\">\r\n    <div class=\"section-header section-header--center\">\r\n      <span class=\"section-header__en\">FAQ</span>\r\n      <h2 class=\"section-header__ja\">よくある質問</h2>\r\n    </div>\r\n\r\n    <div class=\"faq-list\">\r\n      <div class=\"faq-item\">\r\n        <button class=\"faq-q\" aria-expanded=\"false\">\r\n          <span class=\"faq-q__icon\">Q</span>\r\n          <span class=\"faq-q__text\">未経験でも応募できますか？</span>\r\n          <i class=\"fa-solid fa-chevron-down faq-q__arrow\"></i>\r\n        </button>\r\n        <div class=\"faq-a\" hidden>\r\n          <span class=\"faq-a__icon\">A</span>\r\n          <p>はい、もちろんです。入社者の約78%が業界未経験からのスタートです。充実した研修制度と1on1メンター制度があるため、ゼロからでも安心して成長できる環境を整えています。</p>\r\n        </div>\r\n      </div>\r\n\r\n      <div class=\"faq-item\">\r\n        <button class=\"faq-q\" aria-expanded=\"false\">\r\n          <span class=\"faq-q__icon\">Q</span>\r\n          <span class=\"faq-q__text\">人材業界の経験がなくても大丈夫ですか？</span>\r\n          <i class=\"fa-solid fa-chevron-down faq-q__arrow\"></i>\r\n        </button>\r\n        <div class=\"faq-a\" hidden>\r\n          <span class=\"faq-a__icon\">A</span>\r\n          <p>大丈夫です。前職で培ったコミュニケーション力・接客経験・事務スキルなど、様々なバックグラウンドがこの仕事で活きています。スキルより「人の役に立ちたい」という気持ちを大切にしています。</p>\r\n        </div>\r\n      </div>\r\n\r\n      <div class=\"faq-item\">\r\n        <button class=\"faq-q\" aria-expanded=\"false\">\r\n          <span class=\"faq-q__icon\">Q</span>\r\n          <span class=\"faq-q__text\">研修はどのくらいの期間ですか？</span>\r\n          <i class=\"fa-solid fa-chevron-down faq-q__arrow\"></i>\r\n        </button>\r\n        <div class=\"faq-a\" hidden>\r\n          <span class=\"faq-a__icon\">A</span>\r\n          <p>入社後3ヶ月を研修期間として設けています。座学・OJT・ロールプレイングを組み合わせた体系的なカリキュラムで、業界知識から実務スキルまで段階的に習得できます。</p>\r\n        </div>\r\n      </div>\r\n\r\n      <div class=\"faq-item\">\r\n        <button class=\"faq-q\" aria-expanded=\"false\">\r\n          <span class=\"faq-q__icon\">Q</span>\r\n          <span class=\"faq-q__text\">選考はどんな流れですか？</span>\r\n          <i class=\"fa-solid fa-chevron-down faq-q__arrow\"></i>\r\n        </button>\r\n        <div class=\"faq-a\" hidden>\r\n          <span class=\"faq-a__icon\">A</span>\r\n          <p>書類選考 → 一次面接（オンライン可） → 二次面接（対面） → 内定、の流れです。平均2〜3週間でお返事しています。「まず話を聞いてみたい」という方はカジュアル面談（選考なし）もご活用ください。</p>\r\n        </div>\r\n      </div>\r\n\r\n      <div class=\"faq-item\">\r\n        <button class=\"faq-q\" aria-expanded=\"false\">\r\n          <span class=\"faq-q__icon\">Q</span>\r\n          <span class=\"faq-q__text\">転勤や残業はありますか？</span>\r\n          <i class=\"fa-solid fa-chevron-down faq-q__arrow\"></i>\r\n        </button>\r\n        <div class=\"faq-a\" hidden>\r\n          <span class=\"faq-a__icon\">A</span>\r\n          <p>基本的に転勤はありません。残業については月平均10〜20時間程度で、繁閑差があります。働き方については面接時に詳しくお伝えしますので、お気軽にお聞きください。</p>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <div class=\"faq-contact\">\r\n      <p>他にもご質問があれば</p>\r\n      <a href=\"#final-cta\" class=\"text-link\">お気軽にLINEでお問い合わせください <i class=\"fa-solid fa-arrow-right\"></i></a>\r\n    </div>\r\n  </div>\r\n</section>\r\n\r\n<!-- ========================================\r\n     SEC 10: 最終CTA\r\n======================================== -->\r\n<section class=\"section-final-cta\" id=\"final-cta\">\r\n  <div class=\"container\">\r\n    <div class=\"final-cta__heading-wrap\">\r\n      <span class=\"section-header__en section-header__en--white\">JOIN US</span>\r\n      <h2 class=\"final-cta__heading\">あなたの一歩を、<br>待っています。</h2>\r\n      <p class=\"final-cta__subheading\">まずは気軽に話を聞いてみてください。<br>選考前に会社の雰囲気を知ることもできます。</p>\r\n    </div>\r\n\r\n    <div class=\"final-cta__options\">\r\n      <!-- 30秒応募 -->\r\n      <div class=\"cta-option cta-option--primary\">\r\n        <div class=\"cta-option__icon\"><i class=\"fa-solid fa-bolt\"></i></div>\r\n        <div class=\"cta-option__label\">APPLY NOW</div>\r\n        <h3 class=\"cta-option__title\">30秒で応募</h3>\r\n        <p class=\"cta-option__desc\">名前とメールアドレスだけで今すぐ応募。詳しい話は担当者からご連絡します。履歴書不要。</p>\r\n        <a href=\"#\" class=\"cta-option__btn cta-option__btn--primary\">今すぐENTRY →</a>\r\n      </div>\r\n\r\n      <!-- LINE応募 -->\r\n      <div class=\"cta-option cta-option--line\">\r\n        <div class=\"cta-option__icon\"><i class=\"fa-brands fa-line\"></i></div>\r\n        <div class=\"cta-option__label\">LINE APPLY</div>\r\n        <h3 class=\"cta-option__title\">LINEで応募</h3>\r\n        <p class=\"cta-option__desc\">LINEで気軽にメッセージを送るだけ。スマホからかんたんに問い合わせができます。</p>\r\n        <a href=\"#\" class=\"cta-option__btn cta-option__btn--line\">\r\n          <i class=\"fa-brands fa-line\"></i> LINEで問い合わせる\r\n        </a>\r\n      </div>\r\n\r\n      <!-- カジュアル面談 -->\r\n      <div class=\"cta-option cta-option--casual\">\r\n        <div class=\"cta-option__icon\"><i class=\"fa-solid fa-calendar-check\"></i></div>\r\n        <div class=\"cta-option__label\">CASUAL TALK</div>\r\n        <h3 class=\"cta-option__title\">カジュアル面談</h3>\r\n        <p class=\"cta-option__desc\">選考なし・無料。「まず雰囲気を知りたい」方へ。オンラインでの参加もOKです。</p>\r\n        <a href=\"#\" class=\"cta-option__btn cta-option__btn--casual\">面談を予約する（無料）</a>\r\n      </div>\r\n    </div>\r\n\r\n    <p class=\"final-cta__note\">\r\n      <i class=\"fa-solid fa-shield-halved\"></i>\r\n      個人情報は厳重に管理し、採用目的以外には使用しません。\r\n    </p>\r\n  </div>\r\n</section>\r\n\r\n<!-- ========================================\r\n     FOOTER\r\n======================================== -->\r\n<footer class=\"site-footer\">\r\n  <div class=\"container\">\r\n    <div class=\"site-footer__top\">\r\n      <div class=\"site-footer__brand\">\r\n        <div class=\"site-footer__logo\">\r\n          <img src=\"images/logo.webp\" width=\"200\">\r\n          <span class=\"site-footer__logo-text\">キャリアネットワーク<span>RECRUIT</span></span>\r\n        </div>\r\n        <p class=\"site-footer__catchcopy\">学歴より、熱意。<br>未経験から、人材のプロへ。</p>\r\n        <div class=\"site-footer__sns\">\r\n          <a href=\"https://www.instagram.com/fukui_tenshoku/\" aria-label=\"Instagram\"><i class=\"fa-brands fa-instagram\"></i></a>\r\n          <a href=\"https://x.com/fukui_tenshoku\" aria-label=\"Twitter/X\"><i class=\"fa-brands fa-x\"></i></a>\r\n          <a href=\"https://page.line.me/824ylbtv?openQrModal=true\" aria-label=\"LINE\"><i class=\"fa-brands fa-line\"></i></a>\r\n        </div>\r\n      </div>\r\n      <div class=\"site-footer__nav\">\r\n        <div class=\"site-footer__nav-group\">\r\n          <div class=\"site-footer__nav-title\">会社を知る</div>\r\n          <ul>\r\n            <li><a href=\"company.html\">会社概要</a></li>\r\n            <li><a href=\"#\">代表メッセージ</a></li>\r\n            <li><a href=\"#\">理念・ビジョン</a></li>\r\n          </ul>\r\n        </div>\r\n        <div class=\"site-footer__nav-group\">\r\n          <div class=\"site-footer__nav-title\">仕事を知る</div>\r\n          <ul>\r\n            <li><a href=\"work.html#coordinator\">派遣コーディネーター</a></li>\r\n            <li><a href=\"work.html#advisor\">キャリアアドバイザー</a></li>\r\n            <li><a href=\"work.html#timeline\">1日の流れ</a></li>\r\n          </ul>\r\n        </div>\r\n        <div class=\"site-footer__nav-group\">\r\n          <div class=\"site-footer__nav-title\