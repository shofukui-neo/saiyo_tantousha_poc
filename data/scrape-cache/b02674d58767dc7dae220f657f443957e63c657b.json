{"url":"https://www.denso-wisetech.co.jp/recruit/recommended/index.html","html":"<!doctype html>\n<html lang=\"ja\">\n<head>\n<!-- Google Tag Manager -->\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n})(window,document,'script','dataLayer','GTM-KL36MS6F');</script>\n<!-- End Google Tag Manager -->\n<meta charset=\"UTF-8\">\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1, viewport-fit=cover\">\n<meta name=\"format-detection\" content=\"telephone=no\">\n<title>岐阜・三重のおすすめ情報 | 採用サイト｜株式会社デンソーワイズテック</title>\n<meta name=\"keywords\" content=\"デンソー,デンソーワイズテック,岐阜県,可児市,三重県,東員町,自動車部品,製造,ワイヤハーネス,センサ,メータ,回路,成型,電装\" />\n<meta name=\"description\" content=\"デンソーワイズテックの大卒採用、高卒採用、キャリア採用情報はこちら。個性や能力を発揮し、活躍している社員紹介をしています。\" />\n    \n<!-- OGP -->\n<meta property=\"og:locale\" content=\"ja_JP\">\n<meta property=\"og:title\" content=\"採用サイト｜株式会社デンソーワイズテック\">\n<meta property=\"og:description\" content=\"デンソーワイズテックの大卒採用、高卒採用、キャリア採用情報はこちら。個性や能力を発揮し、活躍している社員紹介をしています。\">\n<meta property=\"og:type\" content=\"article\">\n<meta property=\"og:url\" content=\"https://www.denso-wisetech.co.jp/recruit/\">\n<meta property=\"og:image\" content=\"https://www.denso-wisetech.co.jp/recruit/ogp.png\">\n<!-- /OGP -->\n    \n<link rel=\"shortcut icon\" href=\"https://www.denso-wisetech.co.jp/favicon.ico\">\n    \n<!-- CSS -->\n<link type=\"text/css\" href=\"../common/css/vendor/sanitize.css\" rel=\"stylesheet\" media=\"all\">\n<link type=\"text/css\" href=\"../common/css/fonts.css\" rel=\"stylesheet\" media=\"all\">\n<link type=\"text/css\" href=\"../common/css/common.css\" rel=\"stylesheet\" media=\"all\">\n<link type=\"text/css\" href=\"../common/css/base.css\" rel=\"stylesheet\" media=\"all\">\n<link type=\"text/css\" href=\"../common/css/page.css\" rel=\"stylesheet\" media=\"all\">\n<link type=\"text/css\" href=\"../common/css/add_style.css\" rel=\"stylesheet\" media=\"all\">\n\n<!-- CSS -->\n<link rel=\"stylesheet\" href=\"../common/js/vendor/aos.css\" />\n\n<!-- Javascript -->\n<script type=\"text/javascript\" src=\"../common/js/vendor/jquery-3.4.1.min.js\" charset=\"UTF-8\"></script>\n<script type=\"text/javascript\" src=\"../common/js/vendor/smooth-scroll.min.js\" charset=\"UTF-8\"></script>\n<script type=\"text/javascript\" src=\"../common/js/slide_menu.js\" charset=\"UTF-8\"></script>\n<script type=\"text/javascript\" src=\"../common/js/function.js\" charset=\"UTF-8\"></script>\n\n</head>\n\n<body>\n<!-- Google Tag Manager (noscript) -->\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-KL36MS6F\"\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n<!-- End Google Tag Manager (noscript) -->\n<div id=\"wrapper\" class=\"recommended\">\n    <!-- header -->\n\t<header class=\"top\">\n\t\t<!-- inner -->\n\t\t<div id=\"header-inner\">\n\t\t\t<h1 id=\"header-logo\"><a href=\"../index.html\"><img src=\"../images/logo.png\" alt=\"デンソーワイズテック\" /></a></h1>\n\t\t\t<div class=\"header-spmenu\"><img src=\"../common/images/sp_menu_bar.png\" alt=\"spmenu\"></div>\n\t\t\t<!-- sp overlayer-->\n    \t\t<div class=\"layer\"></div>\n\t\t\t<!-- navi -->\n\t\t\t<nav>\n\t\t\t\t<ul id=\"navi-inner\">\n                    <li class=\"sp-only category\">\n                        <a href=\"../u_graduate/index.html\">大卒採用の方は<br>こちら</a>\n                        <a href=\"../h_graduate/index.html\">高卒採用の方は<br>こちら</a>\n                        <a href=\"../career/index.html\">キャリア採用の方は<br>こちら</a>\n                        <a href=\"https://arwrk.net/recruit/denso-wisetech/\" target=\"_blank\">パート採用の方は<br>こちら</a>\n                    </li>\n                    <li><a href=\"../message/index.html\">採用メッセージ</a></li>\n                    <li><a href=\"../about/index.html\">よくわかる！<br>デンソーワイズテック</a></li>\n                    <li><a href=\"../job/index.html\">職種紹介</a></li>\n                    <li><a href=\"../number/index.html\">数字で見る<br>デンソーワイズテック</a></li>\n                    <li><a href=\"../recommended/index.html\">岐阜・三重の<br>おすすめ情報</a></li>\n                    <li><a href=\"../welfare/index.html\">福利厚生</a></li>\n                    <li><a href=\"../contact/index.html\">お問い合わせ</a></li>\n\t\t\t  \t  \t<li class=\"close-button sp-only\">CLOSE</li>\n\t\t  \t  \t</ul>\n\t\t\t</nav>\n\t\t</div>\n\t\t<!-- inner  end -->\n\t</header>\n    <div class=\"header-option\">\n        <ul>\n            <li><a href=\"../u_graduate/index.html\">大卒採用の方は<br>こちら</a></li>\n            <li><a href=\"../h_graduate/index.html\">高卒採用の方は<br>こちら</a></li>\n            <li><a href=\"../career/index.html\">キャリア採用の方は<br>こちら</a></li>\n            <li><a href=\"https://arwrk.net/recruit/denso-wisetech/\" target=\"_blank\">パート採用の方は<br>こちら</a></li>\n        </ul>\n    </div>\n    <div class=\"top-image\">\n        <div class=\"txt\" data-aos=\"fade-left\"><h1>岐阜・三重の<br>おすすめ情報</h1></div>\n        <div class=\"photo wh\" data-aos=\"fade-in\"></div>\n    </div>\n    <main id=\"contents\">\n        <section data-aos=\"fade-up\">\n              <div class=\"inner\">\n                <h1>岐阜県可児市</h1>\n                <dl>\n                  <dt>\n                      <img src=\"images/recommended_p1.png\" width=\"550\" height=\"382\" alt=\"\"/>\n                      <small>ぎふワールド・ローズガーデン</small>\n                  </dt>\n                      <dd>\n                        <h2 class=\"s-title\">ロケーション・特長</h2>\n                          <h3>市街地の利便性と緑豊かな自然が共存。</h3>\n                          <p>\n                              広大な岐阜県の南部、愛知県との境に位置し、名古屋市と岐阜市のどちらへもクルマで約1時間（約30km）の距離。北部～西部には名古屋のベッドタウンとして発展した市街地・住宅地がJRと名鉄の沿線を中心に広がり、生活にも便利です。南部～東部の丘陵地は、広々とした風景の中に県下最大級の工業団地や田畑、ゴルフ場が点在し、デンソーワイズテックの本社もその一角にあります。世界中のバラが楽しめる「ぎふワールド・ローズガーデン」、コンサートや演劇が開催される可児市文化創造センター「ala」、明智光秀のふるさと明智荘や森蘭丸の居城であった美濃金山城跡など、自然・文化・歴史の見どころが豊富。NHK連続テレビ小説「半分、青い」や大河ドラマ「麒麟がくる」、サッカー漫画「ジュニオール」などの舞台・ロケ地でもあります。\n                          </p>\n                      </dd>\n                </dl>\n                <h2 class=\"s-title\">土地事情<span>※公示価格　都道府県ランキング　2023年</span></h2>\n                <table cellspacing=\"0\">\n                    <tbody>\n                        <tr>\n                            <th>&nbsp;</th>\n                          <th>基準地価平均</th>\n                          <th>坪単価平均</th>\n                        </tr>\n                        <tr>\n                          <td>岐阜県</td>\n                            <td>5万5434円/㎡</td>\n                            <td>18万3255円/坪</td>\n                        </tr>\n                        <tr>\n                            <td>可児市</td>\n                            <td>4万0930円/㎡</td>\n                            <td>13万5305円/坪</td>\n                        </tr>\n                        <tr>\n                            <td>日本全国</td>\n                            <td>15万8381円/㎡</td>\n                            <td>52万3573円/坪</td>\n                        </tr>\n                    </tbody>\n                </table>\n                <small>参考：都道府県別戸建て率／2018年　岐阜県　全国9位　75.24％（東京都：28.02％）</small>\n                <p class=\"strong\">工場が多い可児市内には手ごろな賃貸物件も豊富！</p>\n                <h2 class=\"s-title\">岐阜県のおすすめスポット</h2>\n                <ul>\n                    <li>\n                        <img src=\"images/sp_1.jpg\" width=\"280\" height=\"200\" alt=\"\"/>\n                        <h4>土岐プレミアム・アウトレット</h4>\n                        <p><span>ブランドショップや</span><span>レストランが充実して</span><span>いる人気のアウトレットモール。</span></p>\n                    </li>\n                    <li>\n                        <img src=\"images/sp_2.jpg\" width=\"280\" height=\"200\" alt=\"\"/>\n                        <h4>下呂温泉</h4>\n                        <p><span>サラサラした肌触りで</span><span>「美人の湯」ともいわれる、</span><span>日本三名泉の一つ。</span></p>\n                    </li>\n                    <li>\n                        <img src=\"images/sp_3.jpg\" width=\"280\" height=\"200\" alt=\"\"/>\n                        <h4>牧歌の里</h4>\n                        <p><span>動物とのふれあいやグルメ、</span><span>大日ヶ岳の雄大な風景が</span><span>楽しめる体験型牧場。</span></p>\n                    </li>\n                    <li>\n                        <img src=\"images/sp_4.jpg\" width=\"280\" height=\"200\" alt=\"\"/>\n                        <h4>世界淡水魚園水族館<br>アクア・トトぎふ</h4>\n                        <p><span>世界最大級の、</span><span>淡水魚に特化した水族館。</span></p>\n                    </li>\n                    <li>\n                        <img src=\"images/sp_5.jpg\" width=\"280\" height=\"200\" alt=\"\"/>\n                        <h4>世界遺産白川郷合掌造り集落</h4>\n                        <p><span>かやぶき屋根の合掌造りに</span><span>今も人が暮らす。</span><br><span>外国人観光客にも人気。</span></p>\n                    </li>\n                    <li>\n                        <img src=\"images/sp_6.jpg\" width=\"280\" height=\"200\" alt=\"\"/>\n                        <h4>新穂高ロープウェイ</h4>\n                        <p><span>紅葉や雪山など四季の</span><span>風景を楽しみながら、</span><span>標高2156ｍへ。</span></p>\n                    </li>\n                    <li>\n                        <img src=\"images/sp_7.jpg\" width=\"280\" height=\"200\" alt=\"\"/>\n                        <h4>キャンプ場</h4>\n                        <p><span>山や川が近い岐阜は</span>キャンプ場の宝庫。<br><span>ひるがの高原や、</span><span>平湯、奥飛騨温泉郷など</span><span>温泉が楽しめるキャンプ場も。</span></p>\n                    </li>\n                    <li>\n                        <img src=\"images/sp_8.jpg\" width=\"280\" height=\"200\" alt=\"\"/>\n                        <h4>スキー場</h4>\n                        <p><span>山が近いからスキー場も</span><span>選び放題。</span><br><span>めいほう、鷲ヶ岳をはじめ、</span><span>西日本最大級18コースを</span><span>誇るダイナランドなど。</span></p>\n                    </li>\n                </ul>\n            </div>\n        </section>\n        <section data-aos=\"fade-up\">\n              <div class=\"inner\">\n                <h1>三重県東員町</h1>\n                <dl>\n                  <dt>\n                      <img src=\"images/recommended_p2.png\" width=\"550\" height=\"382\" alt=\"\"/>\n                      <small>中部公園</small>\n                  </dt>\n                      <dd>\n                        <h2 class=\"s-title\">ロケーション・特長</h2>\n                          <h3>子育て世代にうれしい環境が充実。</h3>\n                          <p>\n                              三重県北部にあり、桑名市の西、四日市市の北。名古屋市までクルマで約1時間（約30km）の距離で、東海環状自動車道の東員ICから各方面へのアクセスも便利です。東西5km、南北7.3kmとコンパクトなまちで、農村風景が残ります。注目すべきは、子育てに関する施策。町内６つの小学校区すべてに、町立の幼稚園・保育園を「幼保一体化施設」として整備し、待機児童ゼロを実現しています。他にも中学校卒業までの医療費無料など手厚い施策があり、町の中心部にある複合大型遊具やバーベキュー施設などを備えた憩いの場「中部公園」など遊び場所も豊富で、子育て世帯の移住に最適。過去30年にわたり、土石流、地滑りの土砂災害が発生しておらず、三重県公表の「津波浸水予想図」の対象地域にも含まれていないなど、自然災害が少ないことも特長です。\n                          </p>\n                      </dd>\n                </dl>\n                <h2 class=\"s-title\">土地事情<span>※公示価格　都道府県ランキング　2023年</span></h2>\n                <table cellspacing=\"0\">\n                    <tbody>\n                        <tr>\n                            <th>&nbsp;</th>\n                          <th>基準地価平均</th>\n                          <th>坪単価平均</th>\n                        </tr>\n                        <tr>\n                          <td>三重県</td>\n                            <td>4万4763円/㎡</td>\n                            <td>14万7978円/坪</td>\n                        </tr>\n                        <tr>\n                            <td>東員町</td>\n                            <td>3万4880円/㎡</td>\n                            <td>11万5305円/坪</td>\n                        </tr>\n                        <tr>\n                            <td>日本全国</td>\n                            <td>15万8381円/㎡</td>\n                            <td>52万3573円/坪</td>\n                        </tr>\n                    </tbody>\n                </table>\n                <small>参考：都道府県別戸建て率／2018年　三重県　全国10位　75.21％（東京都：28.02％）</small>\n                <p class=\"strong\">三重県の中でも持ち家の夢を実現しやすいエリア！</p>\n                <h2 class=\"s-title\">三重県のおすすめスポット</h2>\n                <ul>\n                    <li>\n                        <img src=\"images/sp2_1.jpg\" width=\"280\" height=\"200\" alt=\"\"/>\n                        <h4>ナガシマスパーランド</h4>\n                        <p><span>多数のアトラクションと</span><span>ジャンボ海水プールで知られる遊園地。</span><span>アウトレットモール</span><span>「ジャズドリーム長島」も隣接。</span></p>\n                    </li>\n                    <li>\n                        <img src=\"images/sp2_2.jpg\" width=\"280\" height=\"200\" alt=\"\"/>\n                        <h4>鈴鹿サーキット</h4>\n                        <p><span>国際レーシングコースに、</span><span>子どもも楽しめる</span><span>遊園地「モートピア」が併設。</span></p>\n                    </li>\n                    <li>\n                        <img src=\"images/sp2_3.jpg\" width=\"280\" height=\"200\" alt=\"\"/>\n                        <h4>志摩スペイン村パルケエスパーニャ</h4>\n                        <p><span>まるでスペイン！ アトラクションや</span><span>ショーが人気のテーマパーク。</span></p>\n                    </li>\n                    <li>\n                        <img src=\"images/sp2_4.jpg\" width=\"280\" height=\"200\" alt=\"\"/>\n                        <h4>鳥羽水族館</h4>\n                        <p><span>日本で唯一のジュゴンや</span><span>人気のラッコをはじめ、</span><span>約1200種を飼育。</span></p>\n                    </li>\n                    <li>\n                        <img src=\"images/sp2_5.jpg\" width=\"280\" height=\"200\" alt=\"\"/>\n                        <h4>伊勢神宮・おかげ横丁</h4>\n                        <p><span>神社のなかでも特別な存在である</span><span>伊勢神宮。門前町には、</span><span>江戸～明治期の風情を再現。</span></p>\n                    </li>\n                    <li>\n                        <img src=\"images/sp2_6.jpg\" width=\"280\" height=\"200\" alt=\"\"/>\n                        <h4>湯の山温泉・御在所岳</h4>\n                        <p><span>温泉にハイキング、スキーが</span><span>楽しめるエリア。</span><br>会社からクルマで約30分。</p>\n                    </li>\n                    <li>\n                        <img src=\"images/sp2_7.jpg\" width=\"280\" height=\"200\" alt=\"\"/>\n                        <h4>赤目四十八滝</h4>\n                        <p><span>渓谷沿いの約4kmに大小23以上の</span><span>滝が連なり、散策路が整備。</span></p>\n                    </li>\n                    <li>\n                        <img src=\"images/sp2_8.jpg\" width=\"280\" height=\"200\" alt=\"\"/>\n                        <h4>マリンスポーツ</h4>\n                        <p><span>リアス海岸で、波穏やかな</span><span>英虞湾（あごわん）では</span><span>シーカヤックツアーが人気。</span></p>\n                    </li>\n                </ul>\n            </div>\n        </section>\n    </main>\n    <!-- page top -->\n    <div class=\"pagetop\"><a href=\"#wrapper\"><img src=\"../common/images/pagetop.png\" width=\"150\" height=\"45\" alt=\"pagetop\"/></a></div>\n    <!-- footer -->\n  \t<footer>\n        <div class=\"footer-bottom\">\n            <div class=\"inner\">\n                <div class=\"footer-logo\">\n                    <h1><img src=\"../images/logo_footer.png\" alt=\"デンソーワイズテック\" width=\"280\" height=\"20\"/></h1>\n                    <p>〒509-0249　岐阜県可児市姫ケ丘3-1<br>TEL:0574-60-5220</p>\n                    <a href=\"https://www.denso-wisetech.co.jp/\" target=\"_blank\" class=\"link-b\">コーポレートサイト</a>\n                </div>\n                <div class=\"footer-menu\">\n                    <ul class=\"category\">\n                        <li><a href=\"../u_graduate/index.html\">大卒採用の方は<br>こちら</a></li>\n                        <li><a href=\"../h_graduate/index.html\">高卒採用の方は<br>こちら</a></li>\n                        <li><a href=\"../career/index.html\">キャリア採用の方は<br>こちら</a></li>\n                        <li><a href=\"https://arwrk.net/recruit/denso-wisetech/\" target=\"_blank\">パート採用の方は<br>こちら</a></li>\n                    </ul>\n                    <ul class=\"cont\">\n                        <li><a href=\"../message/index.html\">採用メッセージ</a></li>\n                        <li><a href=\"../about/index.html\">よくわかる！<br class=\"sp-only\">デンソーワイズテック</a></li>\n                        <li><a href=\"../job/index.html\">職種紹介</a></li>\n                        <li><a href=\"../number/index.html\">数字で見る<br class=\"sp-only\">デンソーワイズテック</a></li>\n                        <li><a href=\"../recommended/index.html\">岐阜・三重のおすすめ情報</a></li>\n                        <li><a href=\"../welfare/index.html\">福利厚生</a></li>\n                        <li><a href=\"../contact/index.html\">お問い合わせ</a></li>\n                        <li><a href=\"../contact/privacy.html\">個人情報の取り扱いについて</a></li>\n                    </ul>\n                    <div class=\"copyright\">\n                        <p class=\"copy\">Copyright(C) 2023 DENSO WISETECH CORPORATION. All rights reserved.</p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </footer>\n</div>\n<script src=\"../common/js/vendor/aos.js\"></script>\n<script>\nAOS.init({\n\tstartEvent: 'load',\n\teasing: 'ease',\n\tduration: 800,\n\tonce: true,\n    disable: 'mobile'\n});\n</script>\n</body>\n</html>\n","finalUrl":"https://www.denso-wisetech.co.jp/recruit/recommended/index.html","rendered":false,"_cachedAt":"2026-06-22T18:03:29.236Z"}