{"url":"https://www.shinko.co.jp/recruit/highschool/guideline/","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>募集要項・Q＆A | 高校生採用サイト | 新光電気工業株式会社</title>\n<meta name=\"keywords\" content=\"新光電気工業,高校生,採用情報,半導体業界,ものづくり,募集要項,Q&amp;A\">\n<meta name=\"description\" content=\"新光電気工業の高校生採用、募集要項・Q&amp;Aのページです。募集要項と皆さんからよくあるご質問を掲載しています。共に未来につながる“ものづくり”をしてみませんか。\">\n<link rel=\"stylesheet\" href=\"/recruit/highschool/assets/css/style.css\">\n\n<script>\r\n// Do not delete this line. This is to prevent CSS transition in Chrome.\r\n</script>\r\n\r\n<!-- Global site tag (gtag.js) - Google Analytics -->\r\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=UA-113455841-1\"></script>\r\n<script>\r\n  window.dataLayer = window.dataLayer || [];\r\n  function gtag(){dataLayer.push(arguments);}\r\n  gtag('js', new Date());\r\n\r\n  gtag('config', 'UA-113455841-1');\r\n</script>\r\n\n</head>\n<body id=\"guideline\">\n\n<div id=\"page\">\n\n\n\n<div id=\"js-loader\" class=\"loader\"></div>\n\n<header class=\"l-header  l-header--2022\">\n\n  <h1 class=\"l-header-logo  l-header-logo--2022\">\n    <a href=\"/recruit/highschool/\" class=\"l-header-logo__link\">\n      <span class=\"l-header-logo__image\"><img src=\"/recruit/highschool/assets/img/common/logo.svg\" width=\"190\" height=\"47\" alt=\"新光電気工業株式会社\"></span>\n      <span class=\"l-header-logo__text\"><img src=\"/recruit/highschool/assets/img/common/logo_text.svg\" width=\"101\" height=\"27\" alt=\"新光電気 高校生採用サイト\"></span>\n    </a>\n  </h1>\n\n  <nav class=\"l-header-nav\">\n    <div class=\"l-header-nav__inner\">\n      <ul class=\"l-header-nav__list\">\n        <li class=\"l-header-nav__item\"><a href=\"/recruit/highschool/\" class=\"l-header-nav__link  js-home-anchor-target\">高校生採用トップ</a></li>\n        <li class=\"l-header-nav__item\"><a href=\"/recruit/highschool/#anchor05\" class=\"l-header-nav__link  js-home-anchor-target\">高校生・保護者・学校関係者の皆さまへ</a></li>\n        <li class=\"l-header-nav__item\"><a href=\"/recruit/highschool/#anchor01\" class=\"l-header-nav__link  js-home-anchor-target\">新光電気ってどんな会社？</a></li>\n        <li class=\"l-header-nav__item\"><a href=\"/recruit/highschool/#anchor02\" class=\"l-header-nav__link  js-home-anchor-target\">新光電気の仕事を知る</a></li>\n        <li class=\"l-header-nav__item\"><a href=\"/recruit/highschool/#anchor03\" class=\"l-header-nav__link  js-home-anchor-target\">先輩社員に聞いてみた！</a></li>\n        <li class=\"l-header-nav__item\"><a href=\"/recruit/highschool/#anchor04\" class=\"l-header-nav__link  js-home-anchor-target\">採用担当者の顔</a></li>\n        <li class=\"l-header-nav__item\"><a href=\"/recruit/highschool/guideline/#guideline02\" class=\"l-header-nav__link  js-guideline-anchor-target\">募集要項</a></li>\n        <li class=\"l-header-nav__item\"><a href=\"/recruit/highschool/guideline/#guideline01\" class=\"l-header-nav__link  js-guideline-anchor-target\">Q &amp; A</a></li>\n        <li class=\"l-header-nav__item\"><a href=\"/recruit/entry/\" target=\"_blank\" class=\"l-header-nav__link\">お問い合わせ</a></li>\n      </ul>\n\n    <!-- /.l-header-nav__inner --></div>\n  </nav>\n\n\n\n  <button class=\"l-header-button\" id=\"js-header-button\">\n    <span class=\"l-header-button__item\"></span>\n    <span class=\"l-header-button__item\"></span>\n    <span class=\"l-header-button__item\"></span>\n  </button>\n\n</header>\n\n\n<main>\n\n\n<div class=\"c-page-header\">\n  <div class=\"c-page-header__inner\">\n    <p class=\"c-page-header__bg\"><img src=\"/recruit/highschool/assets/img/common/header_bg.svg\" width=\"463\" height=\"824\" alt=\"\"></p>\n    <h1 class=\"c-page-header__title\">募集要項・<span class=\"c-page-header__en01\">Q</span><span class=\"c-page-header__en02\">＆</span><span class=\"c-page-header__en01\">A</span></h1>\n    <p class=\"c-page-header__text\">RECRUITMENT INFORMATION・Q&amp;A</p>\n    <div class=\"c-page-header-character\">\n      <p class=\"c-page-header-character__image01\"><img src=\"/recruit/highschool/assets/img/home/visual_main01.svg\" width=\"314\" height=\"429\" alt=\"\"></p>\n      <p class=\"c-page-header-character__image02\"><img src=\"/recruit/highschool/assets/img/home/visual_main02.svg\" width=\"239\" height=\"403\" alt=\"\"></p>\n    <!-- /.c-page-header-character --></div>\n  <!-- /.c-page-header__inner --></div>\n<!-- /.c-page-header --></div>\n\n\n<div class=\"c-page-nav  c-page-nav--guideline\">\n  <ul class=\"c-page-nav__list\">\n    <li class=\"c-page-nav__item\"><a href=\"#guideline02\" class=\"c-page-nav__link\">募集要項</a></li>\n    <li class=\"c-page-nav__item\"><a href=\"#guideline01\" class=\"c-page-nav__link\">Q＆A</a></li>\n  </ul>\n<!-- /.c-page-nav --></div>\n\n\n<div class=\"p-guideline-section  p-guideline-section--guideline\" id=\"guideline02\">\n  <div class=\"p-guideline-section__inner\">\n    <h2 class=\"p-guideline-section__title\">募集要項</h2>\n    <div class=\"p-guideline-table\">\n      <table>\n\n\n\n\n\n\n\n\n  <tr>\n    <th>募集職種</th>\n    <td><p>組立・機械加工・保全・めっき・検査要員</p>\r\n<p>［変更の範囲］　会社の定める職務</p></td>\n  </tr>\n\n\n\n\n\n\n\n\n\n  <tr>\n    <th>給与</th>\n    <td><p>215,000円（2026年度初任給実績）</p></td>\n  </tr>\n\n\n\n\n\n\n\n\n\n  <tr>\n    <th>諸手当</th>\n    <td><p>交替勤務手当、時間外勤務手当、通勤手当　ほか</p></td>\n  </tr>\n\n\n\n\n\n\n\n\n\n  <tr>\n    <th>昇給</th>\n    <td><p>年1回</p></td>\n  </tr>\n\n\n\n\n\n\n\n\n\n  <tr>\n    <th>賞与</th>\n    <td><p>年2回</p></td>\n  </tr>\n\n\n\n\n\n\n\n\n\n  <tr>\n    <th>勤務地</th>\n    <td><ul>\r\n<li><strong>工場</strong></li>\r\n</ul>\r\n<p>本社・更北工場（長野県長野市）、若穂工場（長野市）、<span style=\"font-size: 17px;\">千曲工場（長野県千曲市）、</span><span style=\"font-size: 17px;\">高丘工場（長野県中野市）、新井工場（新潟県妙高市）、</span><span style=\"font-size: 17px;\">京ヶ瀬工場（新潟県阿賀野市）</span></p>\r\n<p></p>\r\n<ul>\r\n<li><strong>開発拠点</strong></li>\r\n</ul>\r\n<p>新光開発センター（長野市）</p>\r\n<p>［変更の範囲］　会社の定める場所（在宅勤務を行う場所を含む）</p></td>\n  </tr>\n\n\n\n\n\n\n\n\n\n  <tr>\n    <th>勤務時間</th>\n    <td><p>［交替勤務］（例）</p>\r\n<ul>\r\n<li>三班二交替 8:10~17:40、20:10~4:55</li>\r\n<li>四班二交替 7:30~19:30、19:30~7:30</li>\r\n<li>三交替 7:00~15:15、15:00~23:15、23:00~7:15</li>\r\n</ul>\r\n<p>※拠点ごとにより勤務時間帯は異なります。</p></td>\n  </tr>\n\n\n\n\n\n\n\n\n\n  <tr>\n    <th>休日休暇</th>\n    <td><p>週休2日制（年間休日126日：2024年度）、有給休暇（年間20日支給）、リフレッシュ休暇、積立休暇　など<br>※シフト制の交替勤務により、土日以外が休日になる場合もあります。</p></td>\n  </tr>\n\n\n\n\n\n\n\n\n\n  <tr>\n    <th>保険</th>\n    <td><p>厚生年金保険・健康保険・雇用保険・労災保険</p></td>\n  </tr>\n\n\n\n\n\n\n\n\n\n  <tr>\n    <th>福利厚生</th>\n    <td><p>育児休職制度、介護休職制度、企業年金基金、ファミリーアシスト給付、家賃補助、各種クラブ活動、全国に契約保養所有り</p></td>\n  </tr>\n\n\n\n\n\n\n\n\n\n  <tr>\n    <th>教育研修</th>\n    <td><p>各種階層別研修（新入社員研修等）、社外派遣教育（各種外部講習会、資格試験等）等</p></td>\n  </tr>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n      </table>\n    <!-- /.p-guideline-table --></div>\n  <!-- /.p-guideline-section__inner --></div>\n<!-- /.p-guideline-section --></div>\n\n\n<div class=\"p-guideline-section  p-guideline-section--faq\" id=\"guideline01\">\n  <div class=\"p-guideline-section__inner\">\n    <h2 class=\"p-guideline-section__title  p-guideline-section__title--en\">Q<span>＆</span>A</h2>\n    <p class=\"p-guideline-section__text\">よくあるご質問にお答えします。</p>\n    <div class=\"p-guideline-faq\">\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    <div class=\"p-guideline-faq__item  js-accordion-target\">\n        <div class=\"p-guideline-faq__header  js-accordion-header\">\n          <h3 class=\"p-guideline-faq__title\">交替勤務とは？</h3>\n        <!-- /.p-guideline-faq__header --></div>\n        <div class=\"p-guideline-faq__content  js-accordion-content\">\n          <p>工場を24時間フル稼働させるために実施している勤務形態です。例えば下のイラストのように1日を3つに分け、3つの班の人がそれぞれの担当時間に出勤します。勤務シフトには早番/遅番/夜番などがあり、24時間工場が稼働することで、途切れることなく製品を作ることができるようになっています。<br><span>交替勤務には多くのパターンがあり、土日休日（サイクルで休日が決定する）のパターンもあります。</span></p>\r\n<p></p>\r\n<p><img alt=\"nikkin.jpg\" src=\"/recruit/images/nikkin.jpg\" width=\"400\" height=\"337\" class=\"mt-image-none\" loading=\"lazy\" decoding=\"async\"><img alt=\"koutai_ver03.png\" src=\"/recruit/images/koutai_ver03.png\" width=\"480\" height=\"402\" class=\"mt-image-none\" loading=\"lazy\" decoding=\"async\"></p>\r\n<p><img alt=\"table2.jpg\" src=\"/recruit/images/table2.jpg\" width=\"891\" height=\"453\" class=\"mt-image-none\" loading=\"lazy\" decoding=\"async\"></p>\n        <!-- /.p-guideline-faq__content --></div>\n      <!-- /.p-guideline-faq__item --></div>\n\n\n\n    <div class=\"p-guideline-faq__item  js-accordion-target\">\n        <div class=\"p-guideline-faq__header  js-accordion-header\">\n          <h3 class=\"p-guideline-faq__title\">採用にあたって、どのような人材(生徒)を求めていますか？</h3>\n        <!-- /.p-guideline-faq__header --></div>\n        <div class=\"p-guideline-faq__content  js-accordion-content\">\n          <p>一番は元気がある人です！また、幅広い年代の方とコミュニケーションをとりますので、協調性がある方も求めています。真面目にコツコツとやり抜く力がある方も活躍できます。</p>\n        <!-- /.p-guideline-faq__content --></div>\n      <!-- /.p-guideline-faq__item --></div>\n\n\n\n    <div class=\"p-guideline-faq__item  js-accordion-target\">\n        <div class=\"p-guideline-faq__header  js-accordion-header\">\n          <h3 class=\"p-guideline-faq__title\">取得しておくべき資格等はありますか？</h3>\n        <!-- /.p-guideline-faq__header --></div>\n        <div class=\"p-guideline-faq__content  js-accordion-content\">\n          <p>特段必要な資格は指定していませんが、入社後の通勤を考慮し、普通自動車運転免許を入社までに取得していただくことをおすすめします。</p>\n        <!-- /.p-guideline-faq__content --></div>\n      <!-- /.p-guideline-faq__item --></div>\n\n\n\n    <div class=\"p-guideline-faq__item  js-accordion-target\">\n        <div class=\"p-guideline-faq__header  js-accordion-header\">\n          <h3 class=\"p-guideline-faq__title\">社内はどんな雰囲気ですか？</h3>\n        <!-- /.p-guideline-faq__header --></div>\n        <div class=\"p-guideline-faq__content  js-accordion-content\">\n          <p>仕事の中で分からないことや不安なことは気軽に同じ職場の先輩に聞くことができる雰囲気があります。休日に職場の友人と一緒に遊びに行く方もいます。</p>\n        <!-- /.p-guideline-faq__content --></div>\n      <!-- /.p-guideline-faq__item --></div>\n\n\n\n    <!-- /.p-guideline-faq --></div>\n  <!-- /.p-guideline-section__inner --></div>\n<!-- /.p-guideline-section --></div>\n\n\n<div class=\"p-guideline-home-nav\">\n  <div class=\"p-home-nav\">\n    <ul class=\"p-home-nav__list\">\n      <li class=\"p-home-nav__item\"><a href=\"/recruit/highschool/#anchor01\" class=\"p-home-nav__link\">新光電気って<br>どんな会社？</a></li>\n      <li class=\"p-home-nav__item\"><a href=\"/recruit/highschool/#anchor02\" class=\"p-home-nav__link\">新光電気の<br>仕事を知る</a></li>\n      <li class=\"p-home-nav__item\"><a href=\"/recruit/highschool/#anchor03\" class=\"p-home-nav__link\">先輩社員に<br>聞いてみた！</a></li>\n      <li class=\"p-home-nav__item\"><a href=\"/recruit/highschool/#anchor04\" class=\"p-home-nav__link\">採用担当者の顔</a></li>\n    </ul>\n  <!-- /.p-home-nav --></div>\n<!-- /.p-guideline-home-nav --></div>\n\n<p class=\"c-page-top\"><a href=\"#page\" class=\"c-page-top__link\"><img src=\"/recruit/highschool/assets/img/common/page_top.svg\" width=\"26\" height=\"42\" alt=\"\"></a></p>\n\n</main>\n\n\n<footer class=\"l-footer\">\r\n  <div class=\"l-footer__upper\">\r\n    <div class=\"l-footer__inner  l-footer__inner--01\">\r\n      <div class=\"l-footer-title\">\r\n        <div class=\"l-footer-title__logo\">\r\n          <a href=\"/recruit/highschool/\" class=\"l-footer-title__link\">\r\n            <p class=\"l-footer-title__logo01\"><img src=\"/recruit/highschool/assets/img/common/logo.svg\" width=\"190\" height=\"47\" alt=\"新光電気工業株式会社\"></p>\r\n            <p class=\"l-footer-title__logo02\"><img src=\"/recruit/highschool/assets/img/common/logo_text.svg\" width=\"101\" height=\"27\" alt=\"新光電気 高校生採用サイト\"></p>\r\n          </a>\r\n        <!-- /.l-footer-title__logo --></div>\r\n        <p class=\"l-footer-title__tagline01\"><img src=\"/recruit/highschool/assets/img/common/footer_tagline01.svg\" width=\"214\" height=\"81\" alt=\"君のチカラは、世界のチカラ\"></p>\r\n        <p class=\"l-footer-title__tagline02\"><img src=\"/recruit/highschool/assets/img/common/footer_tagline02.svg\" width=\"218\" height=\"18\" alt=\"未来につながる &quot;ものづくり&quot;\"></p>\r\n      <!-- /.l-footer-title --></div>\r\n\r\n      <ul class=\"l-fooer-nav01\">\r\n        <li class=\"l-fooer-nav01__item\"><a href=\"/recruit/highschool/\" class=\"l-fooer-nav01__link\">トップページ</a></li>\r\n        <li class=\"l-fooer-nav01__item\"><a href=\"/recruit/highschool/#anchor05\" class=\"l-fooer-nav01__link  js-home-anchor-target\">高校生・学校関係者者・保護者の皆さまへ</a></li>\r\n        <li class=\"l-fooer-nav01__item\"><a href=\"/recruit/highschool/#anchor01\" class=\"l-fooer-nav01__link  js-home-anchor-target\">新光電気ってどんな会社？</a></li>\r\n        <li class=\"l-fooer-nav01__item\"><a href=\"/recruit/highschool/#anchor02\" class=\"l-fooer-nav01__link  js-home-anchor-target\">新光電気の仕事を知る</a></li>\r\n        <li class=\"l-fooer-nav01__item\"><a href=\"/recruit/highschool/#anchor03\" class=\"l-fooer-nav01__link  js-home-anchor-target\">先輩社員に聞いてみた！</a></li>\r\n        <li class=\"l-fooer-nav01__item\"><a href=\"/recruit/highschool/#anchor04\" class=\"l-fooer-nav01__link  js-home-anchor-target\">採用担当者の顔</a></li>\r\n        <li class=\"l-fooer-nav01__item\"><a href=\"/recruit/highschool/guideline/#guideline02\" class=\"l-fooer-nav01__link  js-guideline-anchor-target\">募集要項</a></li>\r\n        <li class=\"l-fooer-nav01__item\"><a href=\"/recruit/highschool/guideline/#guideline01\" class=\"l-fooer-nav01__link  js-guideline-anchor-target\">Q&A</a></li>\r\n        <li class=\"l-fooer-nav01__item\"><a href=\"/recruit/entry/\" target=\"_blank\" class=\"l-fooer-nav01__link\">お問い合わせ</a></li>\r\n      </ul>\r\n    <!-- /.l-footer__inner --></div>\r\n  <!-- /.l-footer__upper --></div>\r\n\r\n  <div class=\"l-footer__lower\">\r\n    <div class=\"l-footer__inner  l-footer__inner--02\">\r\n      <ul class=\"l-fooer-nav02\">\r\n        <li class=\"l-fooer-nav02__item\"><a href=\"/\" target=\"_blank\" class=\"l-fooer-nav02__link\">新光電気サイトTOP</a></li>\r\n        <li class=\"l-fooer-nav02__item\"><a href=\"/recruit/\" target=\"_blank\" class=\"l-fooer-nav02__link\">採用情報サイトTOP</a></li>\r\n        <li class=\"l-fooer-nav02__item\"><a href=\"/privacy/\" target=\"_blank\" class=\"l-fooer-nav02__link\">個人情報保護ポリシー</a></li>\r\n        <li class=\"l-fooer-nav02__item\"><a href=\"/about_site/\" target=\"_blank\" class=\"l-fooer-nav02__link\">このサイトについて</a></li>\r\n        <li class=\"l-fooer-nav02__item\"><a href=\"/recruit/sitemap/\" target=\"_blank\" class=\"l-fooer-nav02__link\">サイトマップ</a></li>\r\n      </ul>\r\n      <p class=\"l-footer__copyright\">&copy; SHINKO ELECTRIC INDUSTRIES CO., LTD.</p>\r\n    <!-- /.l-footer__inner --></div>\r\n  <!-- /.l-footer__lower --></div>\r\n</footer>\r\n\n\n<!-- /#page --></div>\n\n\n<script src=\"/recruit/highschool/assets/js/libraries.js\"></script>\r\n<script src=\"/recruit/highschool/assets/js/main.js?v=1.01\"></script>\r\n\n</body>\n</html>","finalUrl":"https://www.shinko.co.jp/recruit/highschool/guideline/","rendered":false,"_cachedAt":"2026-06-23T23:09:34.428Z"}