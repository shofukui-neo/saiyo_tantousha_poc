{"url":"https://zynas.co.jp/recruit/environment","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n<head prefix=\"og: http://ogp.me/ns# fb: http://ogp.me/ns/fb# website: http://ogp.me/ns/website#\">\n<head>\n    <!-- Google tag (gtag.js) -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-G55V1BGKK4\"></script>\n<script>\n    window.dataLayer = window.dataLayer || [];\n    function gtag(){dataLayer.push(arguments);}\n    gtag('js', new Date());\n\n    gtag('config', 'G-G55V1BGKK4');\n</script>    <!-- Google Tag Manager -->\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n})(window,document,'script','dataLayer','GTM-TLL4QPTD');</script>\n<!-- End Google Tag Manager -->\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n        <title>働く環境｜採用情報｜株式会社ザイナス</title>\n    <meta name=\"description\" content=\"ザイナスでは、社員全員が安心して働くことができるように、様々な環境づくりに取り組んでいます。誰もが自分らしく、能力を発揮できる職場を目指し、日々アップデートしています。\">\n    <link rel=\"canonical\" href=\"https://recruit.zynas.co.jp\">\n    <meta property=\"og:locale\" content=\"ja_JP\">\n    <meta property=\"og:type\" content=\"website\">\n    <meta property=\"og:image\" content=\"https://recruit.zynas.co.jp/ogp/ogp.png\">\n    <meta property=\"og:title\" content=\"働く環境｜採用情報｜株式会社ザイナス\">\n    <meta property=\"og:description\" content=\"ザイナスでは、社員全員が安心して働くことができるように、様々な環境づくりに取り組んでいます。誰もが自分らしく、能力を発揮できる職場を目指し、日々アップデートしています。\">\n    <meta property=\"og:url\" content=\"https://recruit.zynas.co.jp\">\n    <meta property=\"og:site_name\" content=\"採用情報｜株式会社ザイナス\">\n    <meta property=\"fb:app_id\" content=\"1445068859685997\">\n    <meta property=\"fb:admins\" content=\"100081903395611\">\n    <meta name=\"twitter:card\" content=\"summary_large_image\">\n    <meta name=\"twitter:site\" content=\"zynasCorp\">\n\n    <!-- 電話番号自動リンク化解除 -->\n    <meta name=\"format-detection\" content=\"telephone=no\">\n\n    <!-- Favicon -->\n    <link rel=\"icon\" type=\"image/x-icon\" href=\"https://recruit.zynas.co.jp/favicon/favicon.ico\">\n    <link rel=\"apple-touch-icon\" href=\"https://recruit.zynas.co.jp/favicon/apple-touch-icon.png\">\n\n    <!-- Font -->\n    <script>\n        (function(d) {\n            var config = {\n                kitId: 'mqa6mvk',\n                scriptTimeout: 3000,\n                async: true\n            },\n            h=d.documentElement,t=setTimeout(function(){h.className=h.className.replace(/\\bwf-loading\\b/g,\"\")+\" wf-inactive\";},config.scriptTimeout),tk=d.createElement(\"script\"),f=false,s=d.getElementsByTagName(\"script\")[0],a;h.className+=\" wf-loading\";tk.src='https://use.typekit.net/'+config.kitId+'.js';tk.async=true;tk.onload=tk.onreadystatechange=function(){a=this.readyState;if(f||a&&a!=\"complete\"&&a!=\"loaded\")return;f=true;clearTimeout(t);try{Typekit.load(config)}catch(e){}};s.parentNode.insertBefore(tk,s)\n        })(document);\n    </script>\n\n    <!-- CSS -->\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"./css/reset.css\">\n        <link rel=\"stylesheet\" type=\"text/css\" href=\"./css/common.css\">\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"./css/global-joinUs.css\">\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"./css/global-header.css\">\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"./css/global-footer.css\">\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"./css/environment.css\">\n</head>\n<body>\n    <!-- Google Tag Manager -->\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n})(window,document,'script','dataLayer','GTM-TLL4QPTD');</script>\n<!-- End Google Tag Manager -->    <header id=\"header\">\n    \n    <h1 id=\"headerLogo\"><a href=\"./\"><img src=\"./img/logo/logo-zynas.svg\" alt=\"Zynas Recruit Site\"></a></h1>\n\n    <div id=\"headerNavMenu\">\n        <nav id=\"headerNavMenu--global\">\n            <h1>採用サイトコンテンツ</h1>\n            <ul>\n                <li><a href=\"./\">ホーム<span aria-hidden=\"true\">HOME</span></a></li>\n                <li><a href=\"./culture\">カルチャー<span aria-hidden=\"true\">CULTURE</span></a></li>\n                <li><a href=\"./workers\">働く人<span aria-hidden=\"true\">PERSON</span></a></li>\n                <li><a href=\"./environment\">働く環境<span aria-hidden=\"true\">WORK STYLE</span></a></li>\n                <li><a href=\"./data\">数字で見るザイナス<span aria-hidden=\"true\">DATA</span></a></li>\n                <li><a href=\"./faq\">よくある質問<span aria-hidden=\"true\">Q&A</span></a></li>\n            </ul>\n        </nav>\n\n        <nav id=\"headerNavMenu--banner\">\n            <h1>関連バナー</h1>\n            <ul>\n                <li><a href=\"https://note.com/zynas/m/m729c646de512\" target=\"_blank\" rel=\"noopener noreferrer\"><img src=\"./img/common/header/header-banner--01.jpg\" alt=\"note インタビュー記事一覧\"></a></li>\n                <li><a href=\"https://note.com/zynas/m/m13b3151ba6fb\" target=\"_blank\" rel=\"noopener noreferrer\"><img src=\"./img/common/header/header-banner--02.jpg\" alt=\"note 25卒・26卒 採用向けマガジン\"></a></li>\n            </ul>\n        </nav>\n\n        <nav id=\"headerNavMenu--sns\">\n            <h1>FOLLOW US!</h1>\n            <ul>\n                <li><a class=\"note\" href=\"https://note.com/zynas/\" target=\"_blank\" rel=\"noopener noreferrer\" aria-label=\"noteのリンク\"></a></li>\n                <li><a class=\"x\" href=\"https://twitter.com/zynasCorp\" target=\"_blank\" rel=\"noopener noreferrer\" aria-label=\"Xのリンク\"></a></li>\n                <li><a class=\"instagram\" href=\"https://www.instagram.com/zynas_corp\" target=\"_blank\" rel=\"noopener noreferrer\" aria-label=\"Instagramのリンク\"></a></li>\n                <li><a class=\"facebook\" href=\"https://www.facebook.com/zynas.inc\" target=\"_blank\" rel=\"noopener noreferrer\" aria-label=\"Facebookのリンク\"></a></li>\n            </ul>\n        </nav>\n    </div>\n\n    <div id=\"headerEntry\">\n        <button id=\"headerEntryBtn\" aria-label=\"募集要項・エントリーメニューボタン\">募集要項・エントリー</button>\n        <nav id=\"headerEntryMenu\">\n            <h1>募集要項・エントリー</h1>\n            <ul>\n                <li><a href=\"https://open.talentio.com/r/1/c/zynas/homes/3087\" target=\"_blank\" rel=\"noopener noreferrer\">中途採用</a></li>\n                <!-- <li><a href=\"https://job.rikunabi.com/2025/company/r450110032/\" target=\"_blank\" rel=\"noopener noreferrer\">新卒採用（25卒）</a></li> -->\n                <!-- <li><a href=\"https://job.mynavi.jp/26/pc/search/corp244872/outline.html\" target=\"_blank\" rel=\"noopener noreferrer\">新卒採用（26卒）</a></li> -->\n                 <li><a href=\"https://job.mynavi.jp/27/pc/search/corp244872/outline.html\" target=\"_blank\" rel=\"noopener noreferrer\">新卒採用（27卒）</a></li>\n                <li><a href=\"https://zynas.co.jp/recruit-contact\" target=\"_blank\" rel=\"noopener noreferrer\">カジュアル面談・<br>採用お問い合わせ</a></li>\n            </ul>\n        </nav>\n    </div>\n\n    <button id=\"headerNavBtn\" aria-label=\"メニューボタン\"></button>\n\n</header>\n\n    <main id=\"main\">\n\n\n        <div id=\"pageHeader\">\n            <div id=\"pageHeaderTitle\" class=\"js-fadeIn\">\n                <h1 class=\"title--ja\">働く環境</h1>\n                <p class=\"title--en\">WORK STYLE</p>\n            </div>\n            <div id=\"pageHeaderImg\" class=\"js-fadeIn\"><img src=\"./img/page-environment/pageHeaderImg--environment.png\" alt=\"\"></div>\n        </div>\n        <!-- / #pageHeader -->\n\n\n        <nav id=\"pageAnchor\" class=\"js-fadeUp\">\n            <h1 class=\"nav__heading\">セクションナビゲーション</h1>\n            <ul class=\"nav__list\">\n                <li class=\"nav__list__item\">\n                    <a class=\"permalink\" href=\"#benefits\">\n                        <img class=\"symbol\" src=\"./img/page-environment/environment-symbol--benefits.svg\" alt=\"\">\n                        <hgroup class=\"label\">\n                            <h2 class=\"label__ja\">福利厚生</h2>\n                            <p class=\"label__en\">BENEFITS</p>\n                        </hgroup>\n                    </a>\n                </li>\n                <!-- / 01 -->\n                <li class=\"nav__list__item\">\n                    <a class=\"permalink\" href=\"#event\">\n                        <img class=\"symbol\" src=\"./img/page-environment/environment-symbol--event.svg\" alt=\"\">\n                        <hgroup class=\"label\">\n                            <h2 class=\"label__ja\">社内行事</h2>\n                            <p class=\"label__en\">EVENT</p>\n                        </hgroup>\n                    </a>\n                </li>\n                <!-- / 02 -->\n                <li class=\"nav__list__item\">\n                    <a class=\"permalink\" href=\"#training\">\n                        <img class=\"symbol\" src=\"./img/page-environment/environment-symbol--training.svg\" alt=\"\">\n                        <hgroup class=\"label\">\n                            <h2 class=\"label__ja\">研修制度</h2>\n                            <p class=\"label__en\">TRAINING</p>\n                        </hgroup>\n                    </a>\n                </li>\n                <!-- / 03 -->\n            </ul>\n        </nav>\n        <!-- / #pageAnchor -->\n\n\n        <section id=\"benefits\">\n            <div class=\"wrapper\">\n                <div id=\"benefitsHeading\" class=\"js-fadeUp\">\n                    <hgroup>\n                        <h1>福利厚生</h1>\n                        <p>BENEFITS</p>\n                    </hgroup>\n                    <img src=\"./img/page-environment/environment-symbol--benefits.svg\" alt=\"\">\n                </div>\n\n                <article id=\"worklifeBalance\" class=\"article\">\n                    <h1 class=\"article__heading js-fadeUp\">ワークライフバランス</h1>\n\n                    <ul class=\"article__list js-fadeUp\">\n                        <li class=\"article__list__item\">\n                            <div class=\"content\">\n                                <h2>休日</h2>\n                                <p>\n                                    <b>本社勤務</b><br>\n                                    土･日・祝日・年末年始・創立記念日(年間120日以上がお休み)<br>\n                                    <b>客先常駐</b><br>\n                                    お客様先によって変動(週休2日以上)\n                                </p>\n                            </div>\n                        </li>\n                        <!-- / 01 -->\n                        <li class=\"article__list__item\">\n                            <div class=\"content\">\n                                <h2>有給休暇</h2>\n                                <p>入社初日から付与されます。初年度 10日、次年度 15日、3年目以降 20日 です。</p>\n                            </div>\n                        </li>\n                        <!-- / 02 -->\n                        <li class=\"article__list__item\">\n                            <div class=\"content\">\n                                <h2>特別休暇</h2>\n                                <p>慶事・弔事・配偶者の出産時の休暇など、有給休暇と別に付与されます。</p>\n                            </div>\n                        </li>\n                        <!-- / 03 -->\n                        <li class=\"article__list__item\">\n                            <div class=\"content\">\n                                <h2>産休・育休制度</h2>\n                                <p>くるみん認定企業として、男女を問わず子育てと仕事を両立する環境づくりに努めています。</p>\n                            </div>\n                        </li>\n                        <!-- / 04 -->\n                        <li class=\"article__list__item\">\n                            <div class=\"content\">\n                                <h2>住宅手当</h2>\n                                <p>1人暮らしの場合、29歳まで月々1万円を支給します。</p>\n                            </div>\n                        </li>\n                        <!-- / 05 -->\n                        <li class=\"article__list__item\">\n                            <div class=\"content\">\n                                <h2>地域手当</h2>\n                                <p>東京本社勤務は、月々2万円を支給します。</p>\n                            </div>\n                        </li>\n                        <!-- / 06 -->\n                        <li class=\"article__list__item col--2\">\n                            <div class=\"content\">\n                                <h2>フルフレックス</h2>\n                                <p>\n                                    フルフレックス制度を導入しており、コアタイムは設けていません。<br>\n                                    フレキシブルタイムである5:00-22:00の間、いつでも出社・退社できる柔軟な勤務形態です。<br>\n                                    月ごとに所定労働時間（大体160〜170時間）が設定され、超過した場合は残業代が支払われます。<br>\n                                    当月内で所定労働時間を満たせばよいので、仕事のボリューム等に合わせ、1日の労働時間を自身で調整できます。\n                                </p>\n                            </div>\n                            <img class=\"thumbnail\" src=\"./img/page-environment/benefits-fullflex-thumbnail.png\" alt=\"\">\n                        </li>\n                        <!-- / 07 -->\n                    </ul>\n\n                    <div class=\"article__comment js-fadeUp\">\n                        <div class=\"commenter\">\n                            <img src=\"./img/page-environment/benefits-commenter--eto.png\" alt=\"江藤社長の写真\">\n                            <p>江藤社長</p>\n                        </div>\n                        <div class=\"content\">\n                            <h2>COMMENT</h2>\n                            <p>2020年にフルフレックス制度を導入しました。忙しさに波がある業界なので、メリハリをつけた働き方を目指しています。コアタイムを設けないため、働き方を自身でカスタマイズすることができ、週休３日の実現も可能です。</p>\n                        </div>\n                    </div>\n                </article>\n                <!-- / #worklifeBalance -->\n\n                <article id=\"skillUp\" class=\"article\">\n                    <h1 class=\"article__heading js-fadeUp\">スキルアップ</h1>\n\n                    <ul class=\"article__list js-fadeUp\">\n                        <li class=\"article__list__item\">\n                            <div class=\"content\">\n                                <h2>書籍購入補助</h2>\n                                <p>業務に関する書籍を、年間2冊まで購入できます。</p>\n                            </div>\n                        </li>\n                        <!-- / 01 -->\n                        <li class=\"article__list__item\">\n                            <div class=\"content\">\n                                <h2>Udemy購入補助</h2>\n                                <p>会社指定のオンライン学習動画を、年間2つまで購入できます。</p>\n                            </div>\n                        </li>\n                        <!-- / 02 -->\n                        <li class=\"article__list__item\">\n                            <div class=\"content\">\n                                <h2>資格保持手当</h2>\n                                <p>業務に関する資格を保持する社員に、毎月手当を支給します。（基本情報・応用情報など）</p>\n                            </div>\n                        </li>\n                        <!-- / 03 -->\n                        <li class=\"article__list__item\">\n                            <div class=\"content\">\n                                <h2>資格受験料補助</h2>\n                                <p>既定の資格試験を受験した場合、合否に関わらず年2回まで受験費用を支給します。</p>\n                            </div>\n                        </li>\n                        <!-- / 04 -->\n                    </ul>\n\n                    <div class=\"article__comment js-fadeUp\">\n                        <div class=\"commenter\">\n                            <img src=\"./img/page-environment/benefits-commenter--eto.png\" alt=\"江藤社長の写真\">\n                            <p>江藤社長</p>\n                        </div>\n                        <div class=\"content\">\n                            <h2>COMMENT</h2>\n                            <p>社員の自己学習のサポートのために、2020年より書籍購入補助を、2022年よりUdemy購入補助を開始しました。利用率が高い制度で、多くの社員が利用しています。</p>\n                        </div>\n                    </div>\n                </article>\n                <!-- / #skillUp -->\n\n                <article id=\"internalSystem\" class=\"article\">\n                    <h1 class=\"article__heading js-fadeUp\">社内制度</h1>\n\n                    <ul class=\"article__list js-fadeUp\">\n                        <li class=\"article__list__item\">\n                            <div class=\"content\">\n                                <h2>昇給・賞与</h2>\n                                <p>\n                                    昇給：年2回<br>\n                                    賞与：年2回(年間2か月分)\n                                </p>\n                            </div>\n                        </li>\n                        <!-- / 01 -->\n                        <li class=\"article__list__item\">\n                            <div class=\"content\">\n                                <h2>服装自由</h2>\n                                <p>一部規定はありますが、ジーンズやTシャツなど自由な服装で働くことができます。</p>\n                            </div>\n                        </li>\n                        <!-- / 02 -->\n                        <li class=\"article__list__item\">\n                            <div class=\"content\">\n                                <h2>退職金制度</h2>\n                                <p>入社3年経過後、退職時に退職金を支給します。</p>\n                            </div>\n                        </li>\n                        <!-- / 03 -->\n                        <li class=\"article__list__item\">\n                            <div class=\"content\">\n                                <h2>勤続表彰制度</h2>\n                                <p>勤続年数10年ごとに、表彰金10万円と特別休暇5日を付与します。</p>\n                            </div>\n                        </li>\n                        <!-- / 04 -->\n                        <li class=\"article__list__item\">\n                            <div class=\"content\">\n                                <h2>職場積立NISA</h2>\n                                <p>資産形成の支援として、職場積立NISAを利用できます。積立額の3％を会社が奨励金として補助します。</p>\n                            </div>\n                        </li>\n                        <!-- / 05 -->\n                    </ul>\n\n                    <div class=\"article__comment js-fadeUp\">\n                        <div class=\"commenter\">\n                            <img src=\"./img/page-environment/benefits-commenter--eto.png\" alt=\"江藤社長の写真\">\n                            <p>江藤社長</p>\n                        </div>\n                        <div class=\"content\">\n                            <h2>COMMENT</h2>\n                            <p>会社への長年の貢献を表彰する目的で、2021年に勤続表彰制度を新設しました。表彰金のほかに5日間の休暇が取得でき、自分へのご褒美として長期休暇を取る方もいます。</p>\n                        </div>\n                    </div>\n                </article>\n                <!-- / #internalSystem -->\n\n                <article id=\"internalExchange\" class=\"article\">\n                    <h1 class=\"article__heading js-fadeUp\">社内交流・支援制度</h1>\n\n                    <ul class=\"article__list js-fadeUp\">\n                        <li class=\"article__list__item\">\n                            <div class=\"content\">\n                                <h2>歓送迎会/懇親会費用補助</h2>\n                                <p>参加者一人あたり1,000円を上限に、支給します。</p>\n                            </div>\n                        </li>\n                        <!-- / 01 -->\n                        <li class=\"article__list__item\">\n                            <div class=\"content\">\n                                <h2>所有宿泊施設の割引</h2>\n                                <p>社員および家族は、割引価格で利用できます。</p>\n                            </div>\n                        </li>\n                        <!-- / 02 -->\n                        <li class=\"article__list__item\">\n                            <div class=\"content\">\n                                <h2>インフルエンザ予防接種の補助</h2>\n                                <p>接種希望者に、費用の一部を補助します。</p>\n                            </div>\n                        </li>\n                        <!-- / 03 -->\n                        <li class=\"article__list__item\">\n                            <div class=\"content\">\n                                <h2>社外活動補助</h2>\n                                <p>スポーツや文化活動での社員交流費用を参加人数に応じて支給します。</p>\n                            </div>\n                        </li>\n                        <!-- / 04 -->\n                        <li class=\"article__list__item\">\n                            <div class=\"content\">\n                                <h2>デバイス補助</h2>\n                                <p>業務で使用するデバイスの購入費用を一部補助します。</p>\n                            </div>\n                        </li>\n                        <!-- / 05 -->\n                    </ul>\n\n                    <div class=\"article__comment js-fadeUp\">\n                        <div class=\"commenter\">\n                            <img src=\"./img/page-environment/benefits-commenter--eto.png\" alt=\"江藤社長の写真\">\n                            <p>江藤社長</p>\n                        </div>\n                        <div class=\"content\">\n                            <h2>COMMENT</h2>\n                            <p>歓送迎会や懇親会の費用を補助し、交流の機会を増やしています。宿泊やインフルエンザの予防接種の補助も行い、積極的に制度を整備しています。</p>\n                        </div>\n                    </div>\n                </article>\n                <!-- / #internalExchange -->\n            </div>\n        </section>\n        <!-- / #benefits -->\n\n\n        <section id=\"event\">\n            <div class=\"wrapper\">\n                <div id=\"eventHeading\" class=\"js-fadeUp\">\n                    <hgroup>\n                        <h1>社内行事</h1>\n                        <p>EVENT</p>\n                    </hgroup>\n                    <img src=\"./img/page-environment/environment-symbol--event.svg\" alt=\"\">\n                </div>\n\n                <div id=\"eventContent\">\n                    <picture class=\"js-fadeUp\">\n                        <source srcset=\"./img/page-environment/event-thumbnail--sp.png\" media=\"(max-width: 767px)\">\n                        <img class=\"event-thumbnail\" src=\"./img/page-environment/event-thumbnail--pc.png\" alt=\"\">\n                    </picture>\n                    <div class=\"article-container js-fadeUp\">\n                        <article>\n                            <h2>社内交流イベント（定期開催）</h2>\n                            <p>スポーツレクリエーションや読書会、社員交流会などを定期的に実施します。</p>\n                        </article>\n                        <!-- / 01 -->\n                        <article>\n                            <h2>新入社員発表会</h2>\n                            <p>新卒の社員は、入社1年後に成果発表会を実施します。</p>\n                        </article>\n                        <!-- / 02 -->\n                        <article>\n                            <h2>若手成果発表会</h2>\n                            <p>入社3年後に成果発表会を実施します。</p>\n                        </article>\n                        <!-- / 03 -->\n                    </div>\n                </div>\n            </div>\n        </section>\n        <!-- / #event -->\n\n\n        <section id=\"training\">\n            <div class=\"wrapper\">\n                <div id=\"trainingHeading\" class=\"js-fadeUp\">\n                    <hgroup>\n                        <h1>研修制度</h1>\n                        <p>TRAINING</p>\n                    </hgroup>\n                    <img src=\"./img/page-environment/environment-symbol--training.svg\" alt=\"\">\n                </div>\n\n                <article id=\"trainingContent\">\n                    <hgroup class=\"heading js-fadeUp\">\n                        <h1 class=\"heading__title\">新卒向け研修プログラム</h1>\n                        <p class=\"heading__description\">ビジネスマナーとプログラミングの授業を、2ヶ月間通して行います。</p>\n                    </hgroup>\n                    <img class=\"schedule-img js-fadeUp\" src=\"./img/page-environment/training-schedule-img.png\" alt=\"例：2023年度の新人向け研修スケジュール\">\n                </article>\n            </div>\n        </section>\n        <!-- / #training -->\n\n\n        <section id=\"joinUs\">\n    <img class=\"thumbnail\" src=\"./img/common/img-common-join-us-thumbnail.png\" alt=\"\">\n    <div class=\"content\">\n        <h1>JOIN US</h1>\n        <p>きかせて、「明日」のこと</p>\n        <a href=\"https://zynas.co.jp/recruit-contact\" target=\"_blank\" rel=\"noopener noreferrer\">カジュアル面談に応募する</a>\n    </div>\n</section>    </main>\n\n\n    <footer id=\"footer\">\n    <div id=\"footerInner\">\n\n        <h1 id=\"footerTop\">\n            <a class=\"home-link\" href=\"./\"><img class=\"logo\" src=\"./img/logo/logo-zynas.svg\" alt=\"Zynas Recruit Site\"></a>\n        </h1>\n\n        <div id=\"footerMiddle\">\n\n            <div id=\"footerMiddle-left\">\n                <ul id=\"footerList-office\">\n                    <li>\n                        <p class=\"office--name\">大分本社</p>\n                        <address class=\"office--content\">\n                            <p class=\"address\">\n                                〒870-0839<br>\n                                大分市金池南1丁目5番1号 コレジオ大分 5階\n                            </p>\n                            <a class=\"googlemaps\" href=\"https://maps.app.goo.gl/J9sYdSpQtp72BwLg7\" target=\"_blank\" rel=\"noopener noreferrer\">Google maps</a>\n                            <p class=\"tel\">TEL&nbsp;：&nbsp;097-547-8639</p>\n                            <p class=\"fax\">FAX&nbsp;：&nbsp;097-547-8619</p>\n                        </address>\n                    </li>\n                    <!-- / item -->\n\n                    <li>\n                        <p class=\"office--name\">東京本社</p>\n                        <address class=\"office--content\">\n                            <p class=\"address\">\n                                〒108-0075<br>\n                                東京都