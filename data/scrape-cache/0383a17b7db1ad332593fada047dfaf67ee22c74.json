{"url":"https://www.hanshin-dw.co.jp/entry-internship.html","html":"<!DOCTYPE html>\n<html lang=\"ja\" class=\"medium\">\n<head>\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n<meta http-equiv=\"Content-Type\" content=\"text/html; charset=utf-8\">\n<meta http-equiv=\"Pragma\" content=\"no-cache\">\n<meta http-equiv=\"Cache-Control\" content=\"no-cache\">\n<meta http-equiv=\"Expires\" content=\"Thu, 01 Jan 1970 00:00:00 GMT\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>インターンシップ申し込み</title>\n<link href=\"static/wad/design_tpl/2/common.css\" rel=\"stylesheet\" type=\"text/css\" charset=\"UTF-8\">\n<link href=\"static/wad/design_tpl/2/normalize.css\" rel=\"stylesheet\" type=\"text/css\" charset=\"UTF-8\">\n<link href=\"static/wad/design_tpl/2/green/css/green.css\" rel=\"stylesheet\" type=\"text/css\" charset=\"UTF-8\">\n<script language=\"JavaScript\" type=\"text/javascript\" src=\"static/wad/js/common.js\" charset=\"UTF-8\"></script>\n<script language=\"JavaScript\" type=\"text/javascript\" src=\"static/wad/js/ajax.js\" charset=\"UTF-8\"></script>\n<script language=\"JavaScript\" type=\"text/javascript\" src=\"static/wad/js/formcgi/initialize.js\" charset=\"UTF-8\"></script>\n<script language=\"JavaScript\" type=\"text/javascript\" src=\"static/wad/js/formcgi/formcgi.js?v=3.5\" charset=\"UTF-8\"></script>\n<script language=\"JavaScript\" type=\"text/javascript\" src=\"static/wad/design_tpl/2/green/js/jquery-3.7.0.min.js\" charset=\"UTF-8\"></script>\n<script language=\"JavaScript\" type=\"text/javascript\" src=\"static/wad/design_tpl/2/green/js/common.js\" charset=\"UTF-8\"></script>\n<script language=\"JavaScript\" type=\"text/javascript\">\n<!--\nfunction onloadProc()\n{\n\t_relativePath = \"\";\n\trestoreForm();\n}\n\nfunction validate()\n{\n\tvar frm = document.form1;\n\n\tif (!checkInputValue(frm.name, \"氏名\")) return false;\n\tif (!checkInputLength(frm.name, \"氏名\" , 50)) return false;\n\tif (!checkInputValue(frm.zip_code1, \"郵便番号\")) return false;\n\tif (!checkInputValue(frm.zip_code2, \"郵便番号\")) return false;\n\tif (!checkInputHankakuNumber(frm.zip_code1, \"郵便番号\")) return false;\n\tif (!checkInputHankakuNumber(frm.zip_code2, \"郵便番号\")) return false;\n\tif (!checkInputLength(frm.zip_code1, \"郵便番号\", \"3\" )) return false;\n\tif (!checkInputLength(frm.zip_code2, \"郵便番号\", \"4\" )) return false;\n\tif (!checkInputValue(frm.address, \"住所\")) return false;\n\tif (!checkInputLength(frm.address, \"住所\" , 100)) return false;\n\tif (!checkInputValue(frm.phone1, \"電話番号\")) return false;\n\tif (!checkInputValue(frm.phone2, \"電話番号\")) return false;\n\tif (!checkInputValue(frm.phone3, \"電話番号\")) return false;\n\tif (!checkInputHankakuNumber(frm.phone1, \"電話番号\")) return false;\n\tif (!checkInputHankakuNumber(frm.phone2, \"電話番号\")) return false;\n\tif (!checkInputHankakuNumber(frm.phone3, \"電話番号\")) return false;\n\tif (!checkInputLength(frm.phone1, \"電話番号\", 10)) return false;\n\tif (!checkInputLength(frm.phone2, \"電話番号\", 10)) return false;\n\tif (!checkInputLength(frm.phone3, \"電話番号\", 10)) return false;\n\tif (!checkInputValue(frm.e_mail, \"メールアドレス\")) return false;\n\tif (!checkInputHankaku(frm.e_mail, \"メールアドレス\")) return false;\n\tif (!checkInputMailAddressFormat(frm.e_mail, \"メールアドレス\")) return false;\n\tif (!checkInputLength(frm.e_mail, \"メールアドレス\" , 256)) return false;\n\tif (!checkInputValue(frm.inp1, \"質問項目１\")) return false;\n\tif (!checkInputValue(frm.inp2, \"質問項目２\")) return false;\n\tif (!checkInputValue(frm.inp3, \"質問項目３\")) return false;\n\tif (!checkInputValue(frm.inp4, \"質問項目４\")) return false;\n\tif (!checkInputList(frm.inp5, \"質問項目５\")) return false;\n\tif (!checkInputList(frm.inp6, \"質問項目６\")) return false;\n\n\treturn true;\n}\n\n// -->\n</script>\n</head>\n<body onload=\"onloadProc()\" onunload=\"\">\n<form name=\"form1\" method=\"post\" action=\"script/formcgi/formcgi.php\" onsubmit=\"return validate()\" id=\"form1\">\n<div id=\"wrapper\">\n<div class=\"header\">\n<h1>インターンシップ申し込み</h1>\n</div>\n<div class=\"container\">\n<div class=\"comment-area\"><p>インターンシップ申し込み画面です。<br />弊社にて交通費負担、遠方からお越しの方は交通費・宿泊費も負担いたします。<br />社員一同、心よりお待ちしております。</p></div>\n<div class=\"form-table\">\n<dl class=\"basic required \">\n<dt><label>氏名</label></dt>\n<dd><input name=\"name\" maxlength=\"50\" type=\"text\" id=\"name\" size=\"50\"class=\"required-field empty\"></dd>\n</dl>\n<dl class=\"basic  required zip_code\">\n<dt><label>郵便番号</label></dt>\n<dd><input name=\"zip_code1\" maxlength=\"3\" type=\"text\" id=\"zip_code1\" size=\"3\" style=\"ime-mode:disabled;\"class=\"required-field empty\">\n - <input name=\"zip_code2\" maxlength=\"4\" type=\"text\" id=\"zip_code2\" size=\"4\" style=\"ime-mode:disabled;\"class=\"required-field empty\"></dd>\n</dl>\n<dl class=\"basic required \">\n<dt><label>住所</label></dt>\n<dd><textarea name=\"address\" maxlength=\"100\" id=\"address\" cols=\"40\" rows=\"4\"class=\"required-field empty\">\n</textarea></dd>\n</dl>\n<dl class=\"basic required phone\">\n<dt><label>電話番号</label></dt>\n<dd><input name=\"phone1\" maxlength=\"10\" type=\"text\" id=\"phone1\" size=\"6\" style=\"ime-mode:disabled;\"class=\"required-field empty\">\n - <input name=\"phone2\" maxlength=\"10\" type=\"text\" id=\"phone2\" size=\"6\" style=\"ime-mode:disabled;\"class=\"required-field empty\">\n - <input name=\"phone3\" maxlength=\"10\" type=\"text\" id=\"phone3\" size=\"6\" style=\"ime-mode:disabled;\"class=\"required-field empty\"></dd>\n</dl>\n<dl class=\"basic required \">\n<dt><label>メールアドレス</label></dt>\n<dd><input name=\"e_mail\" maxlength=\"256\" type=\"text\" id=\"e_mail\" size=\"50\" style=\"ime-mode:disabled;\"class=\"required-field empty\"></dd>\n</dl>\n<dl class=\"basic  required \">\n<dt><label>１．年齢</label></dt>\n<dd><input name=\"inp1\" type=\"text\" id=\"inp1\" size=\"2\" class=\"required-field empty\">\n</dd>\n</dl>\n<dl class=\"basic  required \">\n<dt><label>２．学校名</label></dt>\n<dd><input name=\"inp2\" type=\"text\" id=\"inp2\" size=\"50\" class=\"required-field empty\">\n</dd>\n</dl>\n<dl class=\"basic  required \">\n<dt><label>３．学部学科</label></dt>\n<dd><input name=\"inp3\" type=\"text\" id=\"inp3\" size=\"50\" class=\"required-field empty\">\n</dd>\n</dl>\n<dl class=\"basic  required \">\n<dt><label>４．学年</label></dt>\n<dd><input name=\"inp4\" type=\"text\" id=\"inp4\" size=\"2\" class=\"required-field empty\">\n</dd>\n</dl>\n<dl class=\"radio basic  required \">\n<dt><label>５．コース（2025年度）　※下記コースは、大学生・第二期新卒向け応募になります。</label></dt>\n<dd><span class=\"fm_nowrap required-radio\"><input type=\"radio\" name=\"inp5\" id=\"inp5_1\" value=\"1day（申し込み完了後、日程調整いたします。）\"><label for=\"inp5_1\">&nbsp;1day（申し込み完了後、日程調整いたします。）</label>&nbsp;&nbsp;</span>\n<span class=\"fm_nowrap required-radio\"><input type=\"radio\" name=\"inp5\" id=\"inp5_2\" value=\"【製造部門 3day】 9/3-9/5（〆8/19）\"><label for=\"inp5_2\">&nbsp;【製造部門 3day】 9/3-9/5（〆8/19）</label>&nbsp;&nbsp;</span>\n<span class=\"fm_nowrap required-radio\"><input type=\"radio\" name=\"inp5\" id=\"inp5_3\" value=\"【技術部門 3day】 9/3-9/5（〆8/19）\"><label for=\"inp5_3\">&nbsp;【技術部門 3day】 9/3-9/5（〆8/19）</label>&nbsp;&nbsp;</span>\n<span class=\"fm_nowrap required-radio\"><input type=\"radio\" name=\"inp5\" id=\"inp5_4\" value=\"【製造＆技術部門 5day】 9/8-9/12（〆8/22）\"><label for=\"inp5_4\">&nbsp;【製造＆技術部門 5day】 9/8-9/12（〆8/22）</label>&nbsp;&nbsp;</span>\n</dd>\n</dl>\n<dl class=\"radio basic  required \">\n<dt><label>６．宿泊を希望しますか（目安：明石工場まで片道1時間30分以上を要する方）</label></dt>\n<dd><span class=\"fm_nowrap required-radio\"><input type=\"radio\" name=\"inp6\" id=\"inp6_1\" value=\"希望する\"><label for=\"inp6_1\">&nbsp;希望する</label>&nbsp;&nbsp;</span>\n<span class=\"fm_nowrap required-radio\"><input type=\"radio\" name=\"inp6\" id=\"inp6_2\" value=\"希望しない\"><label for=\"inp6_2\">&nbsp;希望しない</label>&nbsp;&nbsp;</span>\n</dd>\n</dl>\n<dl class=\"basic \">\n<dt><label>７．その他要望欄（内容、期間等で要望等あればご記入ください）</label></dt>\n<dd><textarea name=\"inp7\" id=\"inp7\" cols=\"100\" rows=\"5\">\n</textarea>\n</dd>\n</dl>\n<ul class=\"send-btn\">\n<li class=\"reset\"><input type=\"reset\" value=\"リセット\"></li>\n<li class=\"submit\"><input type=\"submit\" value=\"次へ\"></li>\n</ul>\n</div>\n</div>\n<input type=\"hidden\" name=\"load_datafile\" value=\"718966a1b0a07e3e2\">\n<input type=\"hidden\" name=\"domain\" value=\"hanshin-dw.co.jp\">\n<input type=\"hidden\" name=\"formVersion\" id=\"formVersion\" value=\"3.5\">\n</div>\n</form>\n</body>\n</html>\n","finalUrl":"https://www.hanshin-dw.co.jp/entry-internship.html","rendered":false,"_cachedAt":"2026-06-22T18:45:10.064Z"}