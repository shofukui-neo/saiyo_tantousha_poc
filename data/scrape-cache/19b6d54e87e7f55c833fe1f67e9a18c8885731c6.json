dt>メール（必須）</dt>\n          <dd><input type=\"text\" name=\"email\" id=\"email\"  class=\"form_text chkrequired chkemail\" value=\"\"></dd>\n          <dt>お問い合わせ内容（必須）</dt>\n          <dd><textarea name=\"text\" id=\"text\" class=\"form_text chkrequired\" ></textarea></dd>\n        </dl>\n        <section class=\"corner \">\n          <section class=\"corner\">\n            <section class=\"button-box\">\n                <input class=\"button-M blue_submit\" type=\"submit\" alt=\"送信内容を確認する\" value=\"入力内容の確認\">\n            </section>\n          </section>\n        </section>\n\t\t\n<!--==========================================================================\n ▲▲ここまで記事▲▲ \n==========================================================================-->\n\n      </section>\n    </section>\n  </section>\n\n</main><!-- #BeginLibraryItem \"/Library/footer.lbi\" --><footer>\n  <section class=\"sec-wrap\">\n    <section class=\"corner\">\n     <section class=\"corner\">\n      <div class=\"contact\">\n        <section class=\"contact-item\">\n          <p>お電話でのお問い合わせ</p>\n          <h2>☎︎0198-26-4151</h2>\n        </section>\n        <section class=\"contact-item\">\n          <p>メールでのお問い合わせ </p>\n          <section class=\"button-box\">\n            <div class=\"button-M white\"><a href=\"index.php\">メールフォームはこちら</a></div>\n          </section>\n        </section>\n      </div>\n      </section>\n      <section class=\"f-nav -u-SpNonePcBlock\">\n      <ul>\n        <li><a href=\"../index.html\">ホーム</a></li>\n        <li><a href=\"../company/index.html\">会社案内</a></li>\n        <li><a href=\"../office-list/index.html\">営業所一覧</a></li>\n        <li><a href=\"../introduction/index.html\">事業紹介</a></li>\n        <li><a href=\"../recruit/index.html\">採用情報</a></li>\n        <li><a href=\"../whatsnew/index.html\">新着情報</a></li>\n        <li><a href=\"index.php\">お問い合わせ</a></li>\n      </ul>\n    </section>\n    </section>\n  </section> \n  <section class=\"footer-wrap\">\n    <section 