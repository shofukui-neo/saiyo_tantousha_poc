{"url":"http://www.kagaku-k.co.jp/recruit.html","html":"<!doctype html>\r\n<html lang=\"ja\">\r\n<head>\r\n<meta charset=\"utf-8\">\r\n \t\r\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1, minimum-scale=1, maximum-scale=1, user-scalable=no\">\r\n<title>カガク興商株式会社｜求人情報</title>\r\n\r\n<link rel=\"stylesheet\" type=\"text/css\" href=\"css/base.css\">\r\n<link rel=\"stylesheet\" type=\"text/css\" href=\"css/style.css\">\r\n\r\n<link rel=\"stylesheet\" type=\"text/css\" href=\"css/print.css\" media=\"print\">\r\n\r\n<script type=\"text/javascript\" src=\"js/jquery.js\"></script>\r\n<script type=\"text/javascript\" src=\"js/pagetop.js\"></script>\r\n\r\n<script src=\"https://ajax.googleapis.com/ajax/libs/jquery/1.8.1/jquery.min.js\" type=\"text/javascript\"></script>\r\n<script type=\"text/javascript\">\r\njQuery(function($) {\r\n  \r\nvar nav    = $('#fixedBox'),\r\n    offset = nav.offset();\r\n  \r\n$(window).scroll(function () {\r\n  if($(window).scrollTop() > offset.top) {\r\n    nav.addClass('fixed');\r\n  } else {\r\n    nav.removeClass('fixed');\r\n  }\r\n});\r\n  \r\n});\r\n</script>\r\n\r\n<link rel=\"stylesheet\" type=\"text/css\" href=\"css/sp_menu.css\">\r\n<script type=\"text/javascript\">\r\n$(function() {\r\n      var gnav = $('.gnav');\r\n      gnav.css('display','none');\r\n      $('.gnav-btn').on('click', function() {\r\n        gnav.slideToggle(500);\r\n        if ($(this).hasClass('is-open')) {\r\n          $(this).removeClass('is-open');\r\n        } else {\r\n          $(this).addClass('is-open');\r\n        }\r\n      });\r\n    });\r\n</script>\r\n\r\n<script type=\"text/javascript\">\r\n$(function(){  \r\n  $(\".gnav p\").click(function(){\r\n      $(this).next(\"ul\").slideToggle();\r\n      $(this).children(\"span\").toggleClass(\"open\");\r\n  });  \r\n});\r\n</script>\r\n\r\n<script type=\"text/javascript\">\r\n$(function(){\r\n    var ua = navigator.userAgent;\r\n    if(ua.indexOf('iPhone') > 0 || ua.indexOf('Android') > 0){\r\n        $('.tel-link').each(function(){\r\n            var str = $(this).text();\r\n            $(this).html($('<a>').attr('href', 'tel:' + str.replace(/-/g, '')).append(str + '</a>'));\r\n        });\r\n    }\r\n});\r\n</script>\r\n\r\n<script type=\"text/javascript\">\r\n(function($) {\r\n\t// 読み込んだら開始\r\n\t$(function() {\r\n\t\t// アコーディオン\r\n\t\tvar accordion = $(\".accordion\");\r\n\t\taccordion.each(function () {\r\n\t\t\tvar noTargetAccordion = $(this).siblings(accordion);\r\n\t\t\t$(this).find(\".switch\").click(function() {\r\n\t\t\t$(this).next(\".contentWrap\").slideToggle();\r\n\t\t\t$(this).toggleClass(\"open\");\r\n\t\t\tnoTargetAccordion.find(\".contentWrap\").slideUp();\r\n\t\t\tnoTargetAccordion.find(\".switch\").removeClass(\"open\");\r\n\t\t\t});\r\n\t\t});\r\n\t});\r\n})(jQuery);\r\n\r\n</script>\r\n\r\n\r\n\r\n<!-- Global site tag (gtag.js) - Google Analytics -->\r\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=UA-106470999-1\"></script>\r\n<script>\r\n  window.dataLayer = window.dataLayer || [];\r\n  function gtag(){dataLayer.push(arguments);}\r\n  gtag('js', new Date());\r\n\r\n  gtag('config', 'UA-106470999-1');\r\n</script>\r\n<!-- GoogleAnalytics -->\r\n\r\n</head>\r\n\r\n<body>\r\n\r\n<div id=\"wrapper\" class=\"recruit\">\r\n\r\n<header>\r\n  <div class=\"pc h_inner_top\">\r\n    <h1>カガク興商株式会社の求人情報</h1>\r\n  </div>\r\n  <div id=\"fixedBox\" class=\"pc h_inner\">\r\n    <ul class=\"menu clearfix\">\r\n      <li>\r\n        <a href=\"./\">\r\n          <img src=\"img/common/h_logo.png\" width=\"287px\" height=\"33px\" alt=\"\" >\r\n        </a>\r\n      </li>\r\n      <li>\r\n        <img src=\"img/common/nav01.png\" alt=\"\" >\r\n        <ul class=\"clearfix\">\r\n          <li>\r\n            <a href=\"material.html\">\r\n              溶材部\r\n            </a>\r\n          </li>\r\n          <li>\r\n            <a href=\"oil.html\">\r\n              石油販売部\r\n            </a>\r\n          </li>\r\n          <li>\r\n            <a href=\"gas.html\">\r\n              石油ガス部\r\n            </a>\r\n          </li>          \r\n        </ul>\r\n      </li>\r\n      <li>\r\n        <a href=\"company.html\">\r\n          <img src=\"img/common/nav02.png\" alt=\"\" >\r\n        </a>\r\n      </li>      \r\n      <li class=\"current\">\r\n        <a href=\"recruit.html\">\r\n          <img src=\"img/common/nav03.png\" alt=\"\" >\r\n        </a>\r\n      </li> \r\n      <li>\r\n        <a href=\"sdgs.html\">\r\n          <img src=\"img/common/nav05.png\" alt=\"\" >\r\n        </a>\r\n      </li>\t\t\t\r\n      <li>\r\n        <a href=\"contact.html\">\r\n          <img src=\"img/common/nav04.png\" alt=\"\" >\r\n        </a>\r\n      </li>\r\n    </ul>\r\n  </div>\r\n  <div class=\"pc main01\">\r\n    <a href=\"./\">ホーム</a>　＞　求人情報\r\n  </div>\r\n\r\n  <div id=\"fixedBox\" class=\"sp h_inner\">\r\n    <div class=\"nav-wrap\">\r\n      <div class=\"menu\">\r\n        <a href=\"./\">\r\n          <img src=\"img/common/sp_h_logo.png\" width=\"250px\" height=\"44px\" alt=\"\" >\r\n        </a>\r\n        <div class=\"gnav-btn\">\r\n          <div class=\"icon-animation\">\r\n            <span class=\"top\"></span>\r\n            <span class=\"middle\"></span>\r\n            <span class=\"bottom\"></span>\r\n          </div>\r\n        </div>\r\n      </div>\r\n      <nav>\r\n        <ul class=\"gnav\">\r\n          <li><a href=\"./\">ホーム</a></li>\r\n          <li>\r\n            <p><span>業務内容　&#9661;</span></p>\r\n            <ul>\r\n              <li><a href=\"material.html\">　溶材部</a></li>\r\n              <li><a href=\"oil.html\">　石油販売部</a></li>\r\n              <li><a href=\"gas.html\">　石油ガス部</a></li>\r\n            </ul>\r\n          </li>\r\n          <li><a href=\"company.html\">会社案内</a></li>\r\n          <li><p><span>求人情報　&#9661;</span></p>\r\n            <ul>\r\n              <li><a href=\"recruit.html\">　求人情報</a></li>\r\n              <li><a href=\"voice.html\">　先輩社員の声</a></li>\r\n            </ul>\r\n          </li>\r\n          <li><a href=\"sdgs.html\">SDGsへの取り組み</a></li>\t\t\t\r\n          <li><a href=\"contact.html\">お問い合わせ</a></li>\r\n          <li><a href=\"information.html\">個人情報の取扱について</a></li>\r\n          <li><a href=\"about.html\">当サイトご利用について</a></li>\r\n        </ul>\r\n      </nav>\r\n    </div>\r\n  </div><!-- / sp -->  \r\n\r\n  <div class=\"sp h_img\">\r\n    <img src=\"img/recruit/sp_recruit_main.jpg\" width=\"1050px\" height=\"577px\" alt=\"\" >\r\n  </div>  \r\n\r\n</header>\r\n\r\n<div id=\"main\">\r\n  <article class=\"main02\">\r\n    <section>\r\n      <img src=\"img/recruit/recruit_main02_b.jpg\" width=\"1050px\" height=\"568px\" alt=\"\" >\r\n    </section>\r\n  </article>\r\n  <article class=\"main_b01\">\r\n    <section>\r\n      <div id=\"voice\" class=\"ttl01\">\r\n        <img src=\"img/recruit/recruit_voice.png\" width=\"255px\" height=\"76px\" alt=\"先輩の声\" >\r\n      </div>\r\n      <div class=\"recruit_txt01\">\r\n        カガク興商株式会社の仕事のやりがい、社内の雰囲気などリアルな声をご紹介します。\r\n      </div>\r\n\t\t\r\n<div class=\"recruit_03\">\r\n   <div class=\"item\">\r\n\t   <p><a href=\"voice.html#voice_01\"><img src=\"img/recruit/recruit_voice_01.jpg\"></a></p>\r\n   </div>\r\n   <div class=\"item\">\r\n      <p><a href=\"voice.html#voice_02\"><img src=\"img/recruit/recruit_voice_02.jpg\"></a></p>\r\n   </div>\r\n\t<!--\r\n   <div class=\"item\">\r\n      <p><a href=\"voice.html#voice_03\"><img src=\"img/recruit/recruit_voice_03.jpg\"></a></p>\r\n   </div>\r\n\t-->\r\n   <div class=\"item\">\r\n      <p><a href=\"voice.html#voice_03\"><img src=\"img/recruit/recruit_voice_04.jpg\"></a></p>\r\n   </div>\r\n   <div class=\"item\">\r\n      <p><a href=\"voice.html#voice_04\"><img src=\"img/recruit/recruit_voice_05.jpg\"></a></p>\r\n   </div>\r\n   <div class=\"item\">\r\n      <p><a href=\"voice.html#voice_05\"><img src=\"img/recruit/recruit_voice_06.jpg\"></a></p>\r\n   </div>\t\r\n\t<div class=\"item\"></div>\r\n\t\r\n</div>\t\t\r\n\t\t\r\n\t\t\r\n\t\t\r\n\t\t<!-- ２列の場合\r\n      <ul class=\"recruit_btn01 clearfix\">\r\n       <li>\r\n         <a href=\"voice01.html\">\r\n           <img src=\"img/recruit/recruit_voice01.jpg\" width=\"501px\" height=\"507px\" alt=\"\" >\r\n         </a>\r\n       </li>\r\n       <li>\r\n         <a href=\"voice02.html\">\r\n           <img src=\"img/recruit/recruit_voice02.jpg\" width=\"501px\" height=\"507px\" alt=\"\" >\r\n         </a>\r\n       </li>\r\n      </ul>\r\n\t\t-->\r\n    </section>\r\n\t  \r\n<!--\t  \r\n    <section>\r\n      <div id=\"guideline\" class=\"ttl01\">\r\n        <img src=\"img/recruit/recruit_guideline.png\" width=\"183px\" height=\"76px\" alt=\"募集要項\" >\r\n      </div>\r\n\r\n      <div class=\"accordion\">\r\n        <p class=\"switch\">&nbsp;&nbsp;正社員一覧　</p>\r\n          <div class=\"contentWrap displayNone\">\r\n\r\n            <div class=\"ttl04\">正社員＜高卒求人＞</div>\r\n\r\n\r\n            <div class=\"pc\">\r\n            <table class=\"two\">\r\n              <tr>\r\n                <th class=\"r_ttl\">職種</th>\r\n                <td class=\"r_ttl c_ttl br1\">ガソリンスタンドスタッフ</td>\r\n                <td class=\"r_ttl c_ttl\">営業スタッフ</td>\r\n              </tr>\r\n              <tr>\r\n                <th>勤務地</th>\r\n                <td class=\"br1\">\r\n                  ・石巻市緑町2-7-15（松並SS）<br>\r\n                  ・石巻市大街道東1-1-8（石巻SS）<br>\r\n                  ・石巻市中里1-3-8（セルフBP東SS）<br>\r\n                  ・東松島市大曲字堺堀122（セルフ矢本SS）<br>\r\n                  ・石巻市前谷地字黒沢前166-2（前谷地SS）<br>\r\n                  ・石巻市大街道南5-1-85（セルフ大街道SS）<br>\r\n                  のいずれかの配属になります。\r\n                </td>\r\n                <td>\r\n                  ・石巻市三ツ股1-2-77（石油ガス部・石油販売部）<br>\r\n                  ・石巻市湊字隠里山11-1（溶材部）<br>\r\n                  ・仙台市若林区鶴代町4-60-1（溶材部仙台営業所）<br>\r\n                  のいずれかの配属になります。\r\n                </td>\r\n              </tr>\r\n              <tr>\r\n                <th>勤務時間</th>\r\n                <td class=\"br1\">\r\n                  1ヶ月単位変形労働時間<br>\r\n                  ・7:00～16:00<br>\r\n                  ・8:00～17:00<br>\r\n                  ・8:30～17:30<br>\r\n                  ・9:00～18:00<br>\r\n                  ・10:00～19:00<br>\r\n                  ・11:00～20:00<br>\r\n                  等、シフト制により決定します。\r\n                </td>\r\n                <td>\r\n                  1年単位変形労働時間<br>8:30～17:30\r\n                </td>\r\n              </tr>\r\n              <tr>\r\n                <th>仕事内容</th>\r\n                <td class=\"br1\">\r\n                  ・ガソリンスタンドでの接客サービス<br>\r\n                  ・給油、洗車、車両点検<br>\r\n                  ・タイヤ、バッテリー等のおすすめ販売<br>\r\n                  ・その他　\r\n                </td>\r\n                <td>\r\n                  （1）燃料（重油・軽油・灯油）、工業用潤滑油<br>\r\n                  （2）産業用高圧ガス、医療用ガス、溶接機器、産業用機械　他<br>\r\n                  （3）ＬＰガス（家庭用、業務用）、住宅リフォーム、太陽光発電システム<br>\r\n                  上記の取り扱い商品を中心に各配属部署にて、顧客との接客業務が主となる仕事です。<br>\r\n                  販売だけでなく、納品、メンテナンス作業、顧客へのプレゼン、技術的アドバイス、<br>\r\n                  提案販売、新規客開拓等の業務を行って頂きます。\r\n                </td>\r\n              </tr>\r\n              <tr>\r\n                <th>応募資格</th>\r\n                <td class=\"br1\">普通自動車免許（マニュアル）</td>\r\n                <td>\r\n                  普通自動車免許（マニュアル）<br>\r\n                  但し、入社後には中型自動車免許取得が<br>\r\n                  必須になる場合があります。\r\n                </td>\r\n              </tr>\r\n              <tr>\r\n                <th>給与</th>\r\n                <td colspan=\"2\" class=\"c_ttl\">\r\n                  月給　170,000円<br>\r\n                  住宅手当　5,000円<br>\r\n                </td>\r\n              </tr>\r\n              <tr>\r\n                <th rowspan=\"2\">休日・休暇</th>\r\n                <td class=\"br1\">\r\n                  ・各SSのシフト表により平均週2日<br>\r\n                  ・別途　諸休暇制度　有　\r\n                </td>\r\n                <td>\r\n                  ・会社休日カレンダーによる<br>\r\n                  ・日祝日及び第１～３土曜日\r\n                </td>\r\n              </tr>\r\n              <tr>\r\n                <td colspan=\"2\" class=\"c_ttl\">・年間休日107日</td>\r\n              </tr>\r\n              <tr>\r\n                <th>通勤手当</th>\r\n                <td colspan=\"2\" class=\"c_ttl\">特記事項参照</td>\r\n              </tr>\r\n              <tr>\r\n                <th>求人にかかる<br>特記事項</th>\r\n                <td colspan=\"2\">\r\n                  賃金の追記<br>\r\n                  ＊住宅手当：5,000円（実家居住）と、家賃に応じて支給（アパート居住）の2通りあります<br>\r\n                  ＊通勤手当<br>\r\n                  4,200円（10kmまで）　7,100円（15kmまで）<br>\r\n                  12,900円（25kmまで）　18,700円（35kmまで）<br>\r\n                  ＊資格手当：2,000円（必須資格取得後1個に付き　月額）<br>\r\n                  ＊家族手当：扶養家族の人数に応じて支給されます。<br>\r\n                  ○接客に自信のある方を希望します<br>\r\n                  ○専門的、技術的な知識・資格を定期的な訓練、研修により習得できます<br>\r\n                  ○応募前に会社見学を受けることをおすすめします　随時受け付けています<br>\r\n                  <br>\r\n                  ＊受付方法：事前に応募書類を郵送してください。追って選考日を連絡します。<br>\r\n                  ＊既卒者の応募：ハローワークの紹介状が必要となります<br>\r\n                  ＊入社日：既卒者、新卒者とも2020年4月1日<br>\r\n                  ※募集期間　2019年9月16日～2020年1月31日\r\n                </td>\r\n              </tr>\r\n            </table>\r\n            </div>\r\n\r\n            <div class=\"sp\">\r\n            <table>\r\n              <tr>\r\n                <th class=\"r_ttl\">職種</th>\r\n                <td class=\"r_ttl c_ttl\">ガソリンスタンドスタッフ</td>\r\n              </tr>\r\n              <tr>\r\n                <th>勤務地</th>\r\n                <td>\r\n                  ・石巻市緑町2-7-15（松並SS）<br>\r\n                  ・石巻市大街道東1-1-8（石巻SS）<br>\r\n                  ・石巻市中里1-3-8（セルフBP東SS）<br>\r\n                  ・東松島市大曲字堺堀122（セルフ矢本SS）<br>\r\n                  ・石巻市前谷地字黒沢前166-2（前谷地SS）<br>\r\n                  ・石巻市大街道南5-1-85（セルフ大街道SS）<br>\r\n                  のいずれかの配属になります。\r\n                </td>\r\n              </tr>\r\n              <tr>\r\n                <th>勤務時間</th>\r\n                <td>\r\n                  1ヶ月単位変形労働時間<br>\r\n                  ・7:00～16:00<br>\r\n                  ・8:00～17:00<br>\r\n                  ・8:30～17:30<br>\r\n                  ・9:00～18:00<br>\r\n                  ・10:00～19:00<br>\r\n                  ・11:00～20:00<br>\r\n                  等、シフト制により決定します。\r\n                </td>\r\n              </tr>\r\n              <tr>\r\n                <th>仕事内容</th>\r\n                <td>\r\n                  ・ガソリンスタンドでの接客サービス<br>\r\n                  ・給油、洗車、車両点検<br>\r\n                  ・タイヤ、バッテリー等のおすすめ販売<br>\r\n                  ・その他　\r\n                </td>\r\n              </tr>\r\n              <tr>\r\n                <th>応募資格</th>\r\n                <td class=\"br1\">普通自動車免許（マニュアル）</td>\r\n              </tr>  \r\n              <tr>\r\n                <th>給与</th>\r\n                <td>\r\n                  月給　170,000円<br>\r\n                  住宅手当　5,000円<br>\r\n                </td>\r\n              </tr>         \r\n              <tr>\r\n                <th>休日・休暇</th>\r\n                <td>\r\n                  ・各SSのシフト表により平均週2日<br>\r\n                  ・別途　諸休暇制度　有<br>\r\n                  ・年間休日107日　\r\n                </td>\r\n              </tr>\r\n              <tr>\r\n                <th>通勤手当</th>\r\n                <td>特記事項参照　</td>\r\n              </tr>\r\n              <tr>\r\n                <th>求人条件にかかる特記事項</th>\r\n                <td>\r\n                  賃金の追記<br>\r\n                  ＊住宅手当：5,000円（実家居住）と、家賃に応じて支給（アパート居住）の2通りあります<br>\r\n                  ＊通勤手当<br>\r\n                  4,200円（10kmまで）　7,100円（15kmまで）<br>\r\n                  12,900円（25kmまで）　18,700円（35kmまで）<br>\r\n                  ＊資格手当：2,000円（必須資格取得後1個に付き　月額）<br>\r\n                  ＊家族手当：扶養家族の人数に応じて支給されます。<br>\r\n                  ○接客に自信のある方を希望します<br>\r\n                  ○専門的、技術的な知識・資格を定期的な訓練、研修により習得できます<br>\r\n                  ○応募前に会社見学を受けることをおすすめします　随時受け付けています<br>\r\n                  <br>\r\n                  ＊受付方法：事前に応募書類を郵送してください。追って選考日を連絡します。<br>\r\n                  ＊既卒者の応募：ハローワークの紹介状が必要となります<br>\r