   </li>\r\n          <li>\r\n            <a href=\"https://x.com/doggyman_pr/\" target=\"_blank\" rel=\"noopener noreferrer\">\r\n              <figure><img src=\"../../assets/img/sns_x_01.png\" alt=\"ドギーマンX\"></figure>\r\n            </a>\r\n          </li>\r\n          <li>\r\n            <a href=\"https://x.com/cattymancam\" target=\"_blank\" rel=\"noopener noreferrer\">\r\n              <figure><img src=\"../../assets/img/sns_x_02.png\" alt=\"キャティーマンX\"></figure>\r\n            </a>\r\n          </li>\r\n          <li>\r\n            <a href=\"https://www.youtube.com/channel/UC6OvqzIxns7JJXYC3gTuRig\" target=\"_blank\" rel=\"noopener noreferrer\">\r\n              <figure><img src=\"../../assets/img/sns_youtube.png\" alt=\"ドギーマン公式youtube\"></figure>\r\n            </a>\r\n          </li>\r\n          <li>\r\n            <a href=\"https://www.tiktok.com/@doggyman_official\" target=\"_blank\" rel=\"noopener noreferrer\">\r\n              <figure><img src=\"../../assets/img/sns_tiktok.png\" alt=\"ドギーマン公式tiktok\"></figure>\r\n            </a>\r\n          </li>\r\n        </ul>\r\n\r\n\r\n    <div class=\"footer_line\"></div>\r\n\r\n\r\n    <figure class=\"footer_logo\">\r\n      <a href=\"https://www.doggyman.com/\" target=\"_blank\">\r\n        <span>コーポレートサイト</span>\r\n      </a>\r\n    </figure>\r\n\r\n\r\n\r\n    <small>Copyright(C)DoggyMan H.A.Co.,Ltd.All rights reserved.</small>\r\n\r\n  </div>\r\n\r\n</footer>\r\n\r\n\r\n<!-- Google Tag Manager (noscript) -->\r\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-KPBT95R\" height=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\r\n<!-- End Google Tag Manager (noscript) -->\r\n\r\n\r\n<script>\r\n  const btn2a = document.querySelector(\".navToggle\");\r\n  const list = document.querySelector(\".short_btn_unit_sp\");\r\n\r\n  btn2a.addEventListener(\"click\", function () {\r\n    list.classList.toggle(\"hidden\");\r\n  });\r\n</script>\r\n\r\n\r\n  </div>\r\n