\n      }),\r\n      start: \"top 55%\",\r\n      once: true,\r\n      ease: \"power1.in\",\r\n    });\r\n  </script>\r\n\r\n\r\n\r\n</body>\r\n\r\n</html>","finalUrl":"https://www.doggyman.com/recruit/people/development/","rendered":false,"_cachedAt":"2026-06-22T20:53:24.520Z"}