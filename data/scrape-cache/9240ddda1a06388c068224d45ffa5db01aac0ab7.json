{"url":"https://www.cnw.co.jp/recruit/jobs.html","html":"<!DOCTYPE html>\r\n<html lang=\"ja\">\r\n<head>\r\n  <meta charset=\"UTF-8\">\r\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n  <title>採用情報 | キャリアネットワーク採用サイト</title>\r\n  <link href=\"https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@300;400;500;600;700&family=Noto+Sans+JP:wght@300;400;500;700&family=Inter:wght@300;400;500;600;700&display=swap\" rel=\"stylesheet\">\r\n  <link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@fortawesome/fontawesome-free@6.4.0/css/all.min.css\">\r\n  <link rel=\"stylesheet\" href=\"css/sub.css\">\r\n  <link rel=\"stylesheet\" href=\"css/jobs.css\">\r\n</head>\r\n<body><div id=\"wrapper\">\r\n\r\n<!-- ========================================\r\n     HEADER\r\n======================================== -->\r\n<header class=\"site-header\">\r\n  <div class=\"site-header__inner\"><a href=\"index.html\" class=\"site-header__logo\">\r\n      <img src=\"images/logo.webp\" width=\"200\">\r\n      <span class=\"site-header__logo-text\">採用サイト<span>RECRUIT</span></span>\r\n    </a>\r\n    <nav class=\"site-header__nav\" id=\"headerNav\">\r\n      <ul>\r\n        <li><a href=\"company.html\">会社を知る</a></li>\r\n        <li><a href=\"work.html\">仕事を知る</a></li>\r\n        <li><a href=\"people.html\">人を知る</a></li>\r\n        <li><a href=\"jobs.html\" class=\"active\">採用情報</a></li>\r\n      </ul>\r\n    </nav>\r\n    <a href=\"#apply\" class=\"site-header__cta\">ENTRY</a>\r\n    <button class=\"site-header__hamburger\" id=\"hamburger\" aria-label=\"メニュー\">\r\n      <span></span><span></span><span></span>\r\n    </button>\r\n  </div>\r\n</header>\r\n\r\n<div class=\"sp-menu\" id=\"spMenu\">\r\n  <ul>\r\n    <li><a href=\"company.html\" class=\"sp-menu__link\">会社を知る</a></li>\r\n    <li><a href=\"work.html\" class=\"sp-menu__link\">仕事を知る</a></li>\r\n    <li><a href=\"people.html\" class=\"sp-menu__link\">人を知る</a></li>\r\n    <li><a href=\"jobs.html\" class=\"sp-menu__link active\">採用情報</a></li>\r\n  </ul>\r\n  <a href=\"#apply\" class=\"sp-menu__cta\">まず話を聞いてみる（無料）</a>\r\n  <a href=\"#apply\" class=\"sp-menu__cta sp-menu__cta--sub\">30秒でENTRY →</a>\r\n</div>\r\n\r\n<!-- ========================================\r\n     PAGE HERO\r\n======================================== -->\r\n<section class=\"page-hero\">\r\n  <div class=\"container page-hero__inner\">\r\n    <nav class=\"breadcrumb\" aria-label=\"パンくずリスト\">\r\n      <a href=\"index.html\">HOME</a>\r\n      <i class=\"fa-solid fa-chevron-right\"></i>\r\n      <span>採用情報</span>\r\n    </nav>\r\n    <span class=\"page-hero__en\">RECRUIT INFO</span>\r\n    <h1 class=\"page-hero__title\">採用情報</h1>\r\n    <p class=\"page-hero__desc\">\r\n      まず、気軽に話を聞いてみてください。<br>\r\n      選考なしのカジュアル面談から始められます。\r\n    </p>\r\n  </div>\r\n</section>\r\n\r\n<!-- ========================================\r\n     SEC 01: 募集職種\r\n======================================== -->\r\n<section class=\"section-positions\" id=\"positions\">\r\n  <div class=\"container\">\r\n    <div class=\"section-header\" data-fade>\r\n      <span class=\"section-header__en\">OPEN POSITIONS</span>\r\n      <h2 class=\"section-header__ja\">募集職種</h2>\r\n      <p class=\"section-header__desc\">現在募集中の2職種をご紹介します。どちらも未経験歓迎です。</p>\r\n    </div>\r\n\r\n    <!-- 職種01 -->\r\n    <div class=\"position-block\" id=\"coordinator\" data-fade>\r\n      <div class=\"position-block__header\">\r\n        <div class=\"position-block__badges\">\r\n          <span class=\"pos-badge pos-badge--new\">新規募集</span>\r\n          <span class=\"pos-badge pos-badge--ok\">未経験OK</span>\r\n        </div>\r\n        <h3 class=\"position-block__title\">派遣コーディネーター</h3>\r\n        <p class=\"position-block__catch\">企業の\"採用力\"を一緒につくる仕事。</p>\r\n      </div>\r\n\r\n      <div class=\"position-block__body\">\r\n        <div class=\"position-detail-table\">\r\n          <div class=\"pdt-row\">\r\n            <div class=\"pdt-label\"><i class=\"fa-solid fa-briefcase\"></i> 雇用形態</div>\r\n            <div class=\"pdt-val\">正社員（試用期間3ヶ月、条件変わらず）</div>\r\n          </div>\r\n          <div class=\"pdt-row\">\r\n            <div class=\"pdt-label\"><i class=\"fa-solid fa-yen-sign\"></i> 給与</div>\r\n            <div class=\"pdt-val\">\r\n              月給 220,000〜280,000円<br>\r\n              <span class=\"pdt-note\">※経験・スキルを考慮の上、優遇します</span>\r\n            </div>\r\n          </div>\r\n          <div class=\"pdt-row\">\r\n            <div class=\"pdt-label\"><i class=\"fa-regular fa-clock\"></i> 勤務時間</div>\r\n            <div class=\"pdt-val\">9:00〜18:00（休憩60分）<br>\r\n              <span class=\"pdt-note\">残業：月平均10〜20時間程度</span>\r\n            </div>\r\n          </div>\r\n          <div class=\"pdt-row\">\r\n            <div class=\"pdt-label\"><i class=\"fa-regular fa-calendar\"></i> 休日・休暇</div>\r\n            <div class=\"pdt-val\">\r\n              完全週休2日制（土日祝）<br>\r\n              年間有給休暇10〜20日、年末年始、慶弔休暇\r\n            </div>\r\n          </div>\r\n          <div class=\"pdt-row\">\r\n            <div class=\"pdt-label\"><i class=\"fa-solid fa-location-dot\"></i> 勤務地</div>\r\n            <div class=\"pdt-val\">福井県福井市（転勤なし）</div>\r\n          </div>\r\n          <div class=\"pdt-row\">\r\n            <div class=\"pdt-label\"><i class=\"fa-solid fa-gift\"></i> 福利厚生</div>\r\n            <div class=\"pdt-val\">\r\n              社会保険完備（健保・厚生年金・雇用・労災）<br>\r\n              交通費全額支給 / 資格取得支援 / 研修制度充実<br>\r\n              1on1メンター制度 / 産育休取得実績あり\r\n            </div>\r\n          </div>\r\n          <div class=\"pdt-row\">\r\n            <div class=\"pdt-label\"><i class=\"fa-solid fa-user-tie\"></i> 応募資格</div>\r\n            <div class=\"pdt-val\">\r\n              学歴・業界経験不問<br>\r\n              <strong>歓迎：</strong>接客・営業・事務・サービス業経験者\r\n            </div>\r\n          </div>\r\n        </div>\r\n\r\n        <div class=\"position-cta\">\r\n          <a href=\"#apply\" class=\"btn-primary\">\r\n            <i class=\"fa-solid fa-bolt\"></i> この職種にENTRY\r\n          </a>\r\n          <a href=\"work.html#coordinator\" class=\"btn-outline\">\r\n            <i class=\"fa-solid fa-arrow-right\"></i> 仕事の詳細を見る\r\n          </a>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- 職種02 -->\r\n    <div class=\"position-block\" id=\"advisor\" data-fade>\r\n      <div class=\"position-block__header\">\r\n        <div class=\"position-block__badges\">\r\n          <span class=\"pos-badge pos-badge--ok\">未経験OK</span>\r\n          <span class=\"pos-badge pos-badge--second\">第二新卒歓迎</span>\r\n        </div>\r\n        <h3 class=\"position-block__title\">キャリアアドバイザー</h3>\r\n        <p class=\"position-block__catch\">求職者の\"一歩\"に伴走する仕事。</p>\r\n      </div>\r\n\r\n      <div class=\"position-block__body\">\r\n        <div class=\"position-detail-table\">\r\n          <div class=\"pdt-row\">\r\n            <div class=\"pdt-label\"><i class=\"fa-solid fa-briefcase\"></i> 雇用形態</div>\r\n            <div class=\"pdt-val\">正社員（試用期間3ヶ月、条件変わらず）</div>\r\n          </div>\r\n          <div class=\"pdt-row\">\r\n            <div class=\"pdt-label\"><i class=\"fa-solid fa-yen-sign\"></i> 給与</div>\r\n            <div class=\"pdt-val\">\r\n              月給 220,000〜280,000円<br>\r\n              <span class=\"pdt-note\">※経験・スキルを考慮の上、優遇します</span>\r\n            </div>\r\n          </div>\r\n          <div class=\"pdt-row\">\r\n            <div class=\"pdt-label\"><i class=\"fa-regular fa-clock\"></i> 勤務時間</div>\r\n            <div class=\"pdt-val\">9:00〜18:00（休憩60分）<br>\r\n              <span class=\"pdt-note\">残業：月平均10〜20時間程度</span>\r\n            </div>\r\n          </div>\r\n          <div class=\"pdt-row\">\r\n            <div class=\"pdt-label\"><i class=\"fa-regular fa-calendar\"></i> 休日・休暇</div>\r\n            <div class=\"pdt-val\">完全週休2日制（土日祝）<br>年間有給休暇10〜20日、年末年始、慶弔休暇</div>\r\n          </div>\r\n          <div class=\"pdt-row\">\r\n            <div class=\"pdt-label\"><i class=\"fa-solid fa-location-dot\"></i> 勤務地</div>\r\n            <div class=\"pdt-val\">福井県福井市（転勤なし）</div>\r\n          </div>\r\n          <div class=\"pdt-row\">\r\n            <div class=\"pdt-label\"><i class=\"fa-solid fa-gift\"></i> 福利厚生</div>\r\n            <div class=\"pdt-val\">\r\n              社会保険完備 / 交通費全額支給 / 資格取得支援<br>\r\n              1on1メンター制度 / 産育休取得実績あり\r\n            </div>\r\n          </div>\r\n          <div class=\"pdt-row\">\r\n            <div class=\"pdt-label\"><i class=\"fa-solid fa-user-tie\"></i> 応募資格</div>\r\n            <div class=\"pdt-val\">\r\n              学歴・業界経験不問<br>\r\n              <strong>歓迎：</strong>接客・教育・福祉・医療・事務経験者\r\n            </div>\r\n          </div>\r\n        </div>\r\n\r\n        <div class=\"position-cta\">\r\n          <a href=\"#apply\" class=\"btn-primary\">\r\n            <i class=\"fa-solid fa-bolt\"></i> この職種にENTRY\r\n          </a>\r\n          <a href=\"work.html#advisor\" class=\"btn-outline\">\r\n            <i class=\"fa-solid fa-arrow-right\"></i> 仕事の詳細を見る\r\n          </a>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</section>\r\n\r\n<!-- ========================================\r\n     SEC 02: 選考フロー\r\n======================================== -->\r\n<section class=\"section-flow\" id=\"flow\">\r\n  <div class=\"container\">\r\n    <div class=\"section-header section-header--center\" data-fade>\r\n      <span class=\"section-header__en\">SELECTION FLOW</span>\r\n      <h2 class=\"section-header__ja\">選考の流れ</h2>\r\n      <p class=\"section-header__desc\">平均2〜3週間でお返事しています。<br>カジュアル面談からスタートすることもできます。</p>\r\n    </div>\r\n\r\n    <div class=\"flow-timeline\">\r\n      <div class=\"flow-step-card flow-step-card--optional\" data-fade>\r\n        <div class=\"flow-step-card__num\">STEP 00</div>\r\n        <div class=\"flow-step-card__icon\"><i class=\"fa-solid fa-comment-dots\"></i></div>\r\n        <h4 class=\"flow-step-card__title\">カジュアル面談</h4>\r\n        <p class=\"flow-step-card__desc\">選考なし・無料。「まず話を聞いてみたい」方向け。会社の雰囲気や仕事内容を気軽に確認できます。</p>\r\n        <div class=\"flow-step-card__tag\">任意 / オンライン可 / 約30〜45分</div>\r\n      </div>\r\n\r\n      <div class=\"flow-arrow\" data-fade><i class=\"fa-solid fa-chevron-down\"></i></div>\r\n\r\n      <div class=\"flow-step-card\" data-fade>\r\n        <div class=\"flow-step-card__num\">STEP 01</div>\r\n        <div class=\"flow-step-card__icon\"><i class=\"fa-solid fa-file-lines\"></i></div>\r\n        <h4 class=\"flow-step-card__title\">エントリー</h4>\r\n        <p class=\"flow-step-card__desc\">このページの応募フォーム・LINE・30秒応募など、お好きな方法でどうぞ。書類選考は3〜5営業日以内に連絡します。</p>\r\n        <div class=\"flow-step-card__tag\">履歴書不要のエントリーも可</div>\r\n      </div>\r\n\r\n      <div class=\"flow-arrow\" data-fade><i class=\"fa-solid fa-chevron-down\"></i></div>\r\n\r\n      <div class=\"flow-step-card\" data-fade>\r\n        <div class=\"flow-step-card__num\">STEP 02</div>\r\n        <div class=\"flow-step-card__icon\"><i class=\"fa-solid fa-laptop\"></i></div>\r\n        <h4 class=\"flow-step-card__title\">一次面接</h4>\r\n        <p class=\"flow-step-card__desc\">担当者との1対1の面接です。志望動機より、あなた自身のこと・これからやりたいことを教えてください。</p>\r\n        <div class=\"flow-step-card__tag\">オンライン可 / 約60分</div>\r\n      </div>\r\n\r\n      <div class=\"flow-arrow\" data-fade><i class=\"fa-solid fa-chevron-down\"></i></div>\r\n\r\n      <div class=\"flow-step-card\" data-fade>\r\n        <div class=\"flow-step-card__num\">STEP 03</div>\r\n        <div class=\"flow-step-card__icon\"><i class=\"fa-solid fa-handshake\"></i></div>\r\n        <h4 class=\"flow-step-card__title\">二次面接（最終）</h4>\r\n        <p class=\"flow-step-card__desc\">代表も同席します。オフィスにもお越しいただき、実際の職場の雰囲気を感じていただける機会です。</p>\r\n        <div class=\"flow-step-card__tag\">対面 / 約60分</div>\r\n      </div>\r\n\r\n      <div class=\"flow-arrow\" data-fade><i class=\"fa-solid fa-chevron-down\"></i></div>\r\n\r\n      <div class=\"flow-step-card flow-step-card--offer\" data-fade>\r\n        <div class=\"flow-step-card__num\">GOAL</div>\r\n        <div class=\"flow-step-card__icon\"><i class=\"fa-solid fa-star\"></i></div>\r\n        <h4 class=\"flow-step-card__title\">内定・ご入社</h4>\r\n        <p class=\"flow-step-card__desc\">内定後も入社前面談・研修計画の共有など、丁寧にフォローします。入社日はご相談ください。</p>\r\n        <div class=\"flow-step-card__tag\">入社日は応相談</div>\r\n      </div>\r\n    </div>\r\n\r\n    <div class=\"flow-note\" data-fade>\r\n      <i class=\"fa-solid fa-circle-info\"></i>\r\n      <p>選考中でのご質問はLINEからでもお気軽にどうぞ。担当者が丁寧にお答えします。</p>\r\n    </div>\r\n  </div>\r\n</section>\r\n\r\n<!-- ========================================\r\n     SEC 03: FAQ\r\n======================================== -->\r\n<section class=\"section-faq\" id=\"faq\">\r\n  <div class=\"container\">\r\n    <div class=\"section-header section-header--center\" data-fade>\r\n      <span class=\"section-header__en\">FAQ</span>\r\n      <h2 class=\"section-header__ja\">よくある質問</h2>\r\n    </div>\r\n\r\n    <div class=\"faq-list\">\r\n      <div class=\"faq-item\" data-fade>\r\n        <button class=\"faq-q\" aria-expanded=\"false\">\r\n          <span class=\"faq-q__icon\">Q</span>\r\n          <span class=\"faq-q__text\">未経験でも本当に応募できますか？</span>\r\n          <i class=\"fa-solid fa-chevron-down faq-q__arrow\"></i>\r\n        </button>\r\n        <div class=\"faq-a\" hidden>\r\n          <span class=\"faq-a__icon\">A</span>\r\n          <p>はい、大歓迎です。入社者の約78%が業界未経験スタートです。入社後3ヶ月の研修期間と1on1メンター制度で、ゼロから丁寧に育てます。「やってみたい」という気持ちが一番の資格です。</p>\r\n        </div>\r\n      </div>\r\n\r\n      <div class=\"faq-item\" data-fade>\r\n        <button class=\"faq-q\" aria-expanded=\"false\">\r\n          <span class=\"faq-q__icon\">Q</span>\r\n          <span class=\"faq-q__text\">第二新卒でも応募できますか？</span>\r\n          <i class=\"fa-solid fa-chevron-down faq-q__arrow\"></i>\r\n        </button>\r\n        <div class=\"faq-a\" hidden>\r\n          <span class=\"faq-a__icon\">A</span>\r\n          <p>もちろんです。第二新卒の方も積極的に採用しています。新卒で入った会社が合わなかった、やりたいことが変わった、そういった方が活躍しています。面接では「なぜ辞めたか」より「これから何がしたいか」を重視します。</p>\r\n        </div>\r\n      </div>\r\n\r\n      <div class=\"faq-item\" data-fade>\r\n        <button class=\"faq-q\" aria-expanded=\"false\">\r\n          <span class=\"faq-q__icon\">Q</span>\r\n          <span class=\"faq-q__text\">カジュアル面談と選考面接は何が違いますか？</span>\r\n          <i class=\"fa-solid fa-chevron-down faq-q__arrow\"></i>\r\n        </button>\r\n        <div class=\"faq-a\" hidden>\r\n          <span class=\"faq-a__icon\">A</span>\r\n          <p>カジュアル面談は選考に関係ありません。「どんな会社か知りたい」「自分に向いているか確認したい」という方のための場です。会社説明・Q&Aがメインで、服装も普段着でOKです。参加後に選考を受けるかどうかも自由です。</p>\r\n        </div>\r\n      </div>\r\n\r\n      <div class=\"faq-item\" data-fade>\r\n        <button class=\"faq-q\" aria-expanded=\"false\">\r\n          <span class=\"faq-q__icon\">Q</span>\r\n          <span class=\"faq-q__text\">在職中でも応募できますか？</span>\r\n          <i class=\"fa-solid fa-chevron-down faq-q__arrow\"></i>\r\n        </button>\r\n        <div class=\"faq-a\" hidden>\r\n          <span class=\"faq-a__icon\">A</span>\r\n          <p>はい、在職中の方の応募も多いです。面接日程の調整や、入社日についても柔軟に対応しますので、まずはご相談ください。</p>\r\n        </div>\r\n      </div>\r\n\r\n      <div class=\"faq-item\" data-fade>\r\n        <button class=\"faq-q\" aria-expanded=\"false\">\r\n          <span class=\"faq-q__icon\">Q</span>\r\n          <span class=\"faq-q__text\">転勤はありますか？</span>\r\n          <i class=\"fa-solid fa-chevron-down faq-q__arrow\"></i>\r\n        </button>\r\n        <div class=\"faq-a\" hidden>\r\n          <span class=\"faq-a__icon\">A</span>\r\n          <p>転勤はありません。福井県内での勤務のみです。地元で長く働き続けられる環境を整えています。</p>\r\n        </div>\r\n      </div>\r\n\r\n      <div class=\"faq-item\" data-fade>\r\n        <button class=\"faq-q\" aria-expanded=\"false\">\r\n          <span class=\"faq-q__icon\">Q</span>\r\n          <span class=\"faq-q__text\">残業はどのくらいありますか？</span>\r\n          <i class=\"fa-solid fa-chevron-down faq-q__arrow\"></i>\r\n        </button>\r\n        <div class=\"faq-a\" hidden>\r\n          <span class=\"faq-a__icon\">A</span>\r\n          <p>月平均10〜20時間程度です。繁忙期（3月・4月・9月）は少し多くなることがありますが、閑散期は定時で帰れる日も多いです。プライベートとのメリハリを大切にする文化があります。</p>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</section>\r\n\r\n<!-- ========================================\r\n     SEC 04: 応募フォーム（3ルート）\r\n======================================== -->\r\n<section class=\"section-apply\" id=\"apply\">\r\n  <div class=\"container\">\r\n    <div class=\"section-header section-header--center\" data-fade>\r\n      <span class=\"section-header__en\">APPLY NOW</span>\r\n      <h2 class=\"section-header__ja\">あなたの一歩を、待っています。</h2>\r\n      <p class=\"section-header__desc\">3つの方法から、あなたに合ったやり方でどうぞ。</p>\r\n    </div>\r\n\r\n    <div class=\"apply-options\">\r\n      <!-- 30秒応募 -->\r\n      <div class=\"apply-option apply-option--primary\" data-fade>\r\n        <div class=\"apply-option__icon\"><i class=\"fa-solid fa-bolt\"></i></div>\r\n        <div class=\"apply-option__label\">APPLY NOW</div>\r\n        <h3 class=\"apply-option__title\">30秒で応募</h3>\r\n        <p class=\"apply-option__desc\">名前とメールアドレスだけで今すぐ応募できます。履歴書は不要。担当者から詳しいご案内をお送りします。</p>\r\n        <form class=\"apply-form\" id=\"applyForm30\">\r\n          <div class=\"apply-form__group\">\r\n            <input type=\"text\" placeholder=\"お名前\" required class=\"apply-form__input\">\r\n          </div>\r\n          <div class=\"apply-form__group\">\r\n            <input type=\"email\" placeholder=\"メールアドレス\" required class=\"apply-form__input\">\r\n          </div>\r\n          <div class=\"apply-form__group\">\r\n            <select class=\"apply-form__input apply-form__select\">\r\n              <option value=\"\">希望職種を選択</option>\r\n              <option>派遣コーディネーター</option>\r\n              <option>キャリアアドバイザー</option>\r\n              <option>どちらでもよい</option>\r\n            </select>\r\n          </div>\r\n          <button type=\"submit\" class=\"apply-form__btn\">\r\n            <i class=\"fa-solid fa-paper-plane\"></i> 今すぐENTRY\r\n          </button>\r\n          <p class=\"apply-form__note\">個人情報は採用目的のみに使用します</p>\r\n        </form>\r\n      </div>\r\n\r\n      <!-- LINE応募 -->\r\n      <div class=\"apply-option apply-option--line\" data-fade>\r\n        <div class=\"apply-option__icon\"><i class=\"fa-brands fa-line\"></i></div>\r\n        <div class=\"apply-option__label\">LINE APPLY</div>\r\n        <h3 class=\"apply-option__title\">LINEで応募</h3>\r\n        <p class=\"apply-option__desc\">\r\n          LINEで「応募したい」と送るだけ。スマホからかんたんに問い合わせできます。<br>\r\n          質問・相談もOKです。\r\n        </p>\r\n        <div class=\"apply-option__line-qr\">\r\n          <div class=\"line-qr-mock\">\r\n            <img src=\"images/qr.png\" />\r\n          </div>\r\n        </div>\r\n        <a href=\"https://page.line.me/824ylbtv?openQrModal=true\" class=\"apply-option__btn apply-option__btn--line\">\r\n          <i class=\"fa-brands fa-line\"></i> LINEで問い合わせる\r\n        </a>\r\n        <p class=\"apply-option__note\">返信は通常1営業日以内</p>\r\n      </div>\r\n\r\n      <!-- カジュアル面談 -->\r\n      <div class=\"apply-option apply-option--casual\" data-fade>\r\n        <div class=\"apply-option__icon\"><i class=\"fa-solid fa-calendar-check\"></i></div>\r\n        <div class=\"apply-option__label\">CASUAL TALK</div>\r\n        <h3 class=\"apply-option__title\">カジュアル面談</h3>\r\n        <p class=\"apply-option__desc\">\r\n          選考なし・無料。「まず雰囲気を知りたい」方へ。<br>\r\n          オンラインでのご参加もOKです。\r\n        </p>\r\n        <div class=\"casual-features\">\r\n          <div class=\"casual-feature\"><i class=\"fa-solid fa-check\"></i> 選考には関係しません</div>\r\n          <div class=\"casual-feature\"><i class=\"fa-solid fa-check\"></i> 服装・履歴書自由</div>\r\n          <div class=\"casual-feature\"><i class=\"fa-solid fa-check\"></i> オンライン参加OK</div>\r\n          <div class=\"casual-feature\"><i class=\"fa-solid fa-check\"></i> 約30〜45分</div>\r\n        </div>\r\n        <a href=\"#\" class=\"apply-option__btn apply-option__btn--casual\">\r\n          <i class=\"fa-solid fa-calendar-check\"></i> 面談を予約する（無料）\r\n        </a>\r\n        <p class=\"apply-option__note\">週2〜3回開催。土曜日も対応可</p>\r\n      </div>\r\n    </div>\r\n\r\n    <p class=\"apply-privacy\">\r\n      <i class=\"fa-solid fa-shield-halved\"></i>\r\n      ご提供いただいた個人情報は、採用選考目的のみに利用し、第三者への提供・開示は行いません。\r\n    </p>\r\n  </div>\r\n</section>\r\n\r\n<!-- ========================================\r\n     FOOTER\r\n======================================== -->\r\n<footer class=\"site-footer\">\r\n  <div class=\"container\">\r\n    <div class=\"site-footer__top\">\r\n      <div class=\"site-footer__brand\">\r\n        <div class=\"site-footer__logo\">\r\n          <img src=\"images/logo.webp\" width=\"200\">\r\n          <span class=\"site-footer__logo-text\">キャリアネットワーク<span>RECRUIT</span></span>\r\n        </div>\r\n        <p class=\"site-footer__catchcopy\">学歴より、熱意。<br>未経験から、人材のプロへ。</p>\r\n        <div class=\"site-footer__sns\">\r\n          <a href=\"https://www.instagram.com/fukui_tenshoku/\" aria-label=\"Instagram\"><i class=\"fa-brands fa-instagram\"></i></a>\r\n          <a href=\"https://x.com/fukui_tenshoku\" aria-label=\"Twitter/X\"><i class=\"fa-brands fa-x\"></i></a>\r\n          <a href=\"https://page.line.me/824ylbtv?openQrModal=true\" aria-label=\"LINE\"><i class=\"fa-brands fa-line\"></i></a>\r\n        </div>\r\n      </div>\r\n      <div class=\"site-footer__nav\">\r\n        <div class=\"site-footer__nav-group\">\r\n          <div class=\"site-footer__nav-title\">会社を知る</div>\r\n          <ul><li><a href=\"company.html\">会社概要</a></li><li><a href=\"president.html\">代表挨拶</a></li></ul>\r\n        </div>\r\n        <div class=\"site-footer__nav-group\">\r\n          <div class=\"site-footer__nav-title\">仕事を知る</div>\r\n          <ul><li><a href=\"work.html#coordinator\">派遣コーディネーター</a></li><li><a href=\"work.html#advisor\">キャリアアドバイザー</a></li></ul>\r\n        </div>\r\n        <div class=\"site-footer__nav-group\">\r\n          <div class=\"site-footer__nav-title\">人を知る</div>\r\n          <ul><li><a href=\"people.html\">社員インタビュー</a></li></ul>\r\n        </div>\r\n        <div class=\"site-footer__nav-group\">\r\n          <div class=\"site-footer__nav-title\">採用情報</div>\r\n          <ul><li><a href=\"jobs.html\">募集職種一覧</a></li><li><a href=\"jobs.html#flow\">選考フロー</a></li><li><a href=\"jobs.html#faq\">よくある質問</a></li><li><a href=\"jobs.html#apply\">ENTRY</a></li></ul>\r\n        </div>\r\n      </div>\r\n    </div>\r\n    <div class=\"site-footer__bottom\">\r\n      <div class=\"site-footer__legal\">\r\n        <a href=\"https://www.cnw.co.jp/privacy\" target=\"_blank\">個人情報の取り扱い</a><a href=\"https://www.cnw.co.jp/form/contact#no-back\" target=\"_blank\">お問い合わせ</a>\r\n      </div>\r\n      <p class=\"site-footer__copy\">© 2026 株式会社キャリアネットワーク All Rights Reserved.</p>\r\n    </div>\r\n  </div>\r\n</footer>\r\n\r\n<div class=\"sticky-cta-bar\" id=\"stickyCta\">\r\n  <div class=\"sticky-cta-bar__inner\">\r\n    <p class=\"sticky-cta-bar__text\">あなたの一歩を待っています</p>\r\n    <div class=\"sticky-cta-bar__btns\">\r\n      <a href=\"#apply\" class=\"sticky-btn sticky-btn--apply\"><i class=\"fa-solid fa-bolt\"></i> <span>30秒応募</span></a>\r\n      <a href=\"#apply\" class=\"sticky-btn sticky-btn--line\"><i class=\"fa-brands fa-line\"></i> <span>LINE</span></a>\r\n      <a href=\"#apply\" class=\"sticky-btn sticky-btn--casual\"><i class=\"fa-solid fa-calendar-check\"></i> <span>面談予約</span></a>\r\n    </div>\r\n    <button class=\"sticky-cta-bar__close\" id=\"stickyClose\" aria-label=\"閉じる\"><i class=\"fa-solid fa-xmark\"></i></button>\r\n  </div>\r\n</div>\r\n\r\n<script src=\"js/sub.js\"></script>\r\n<script>\r\n// FAQアコーディオン\r\ndocument.querySelectorAll('.faq-q').forEach(function(btn) {\r\n  btn.addEventListener('click', function() {\r\n    const isOpen = this.getAttribute('aria-expanded') === 'true';\r\n    document.querySelectorAll('.faq-q').forEach(function(b) {\r\n      b.setAttribute('aria-expanded','false');\r\n      b.nextElementSibling.hidden = true;\r\n    });\r\n    if (!isOpen) {\r\n      this.setAttribute('aria-expanded','true');\r\n      this.nextElementSibling.hidden = false;\r\n    }\r\n  });\r\n});\r\n// 応募フォーム（モック）\r\nconst form = document.getElementById('applyForm30');\r\nif (form) {\r\n  form.addEventListener('submit', function(e) {\r\n    e.preventDefault();\r\n    const btn = form.querySelector('.apply-form__btn');\r\n    btn.innerHTML = '<i class=\"fa-solid fa-check\"></i> 送信完了！担当者より連絡します';\r\n    btn.style.background = '#2E7D32';\r\n    btn.disabled = true;\r\n  });\r\n}\r\n</script>\r\n</div></body>\r\n</html>\r\n","finalUrl":"https://www.cnw.co.jp/recruit/jobs.html","rendered":false,"_cachedAt":"2026-06-23T21:23:17.513Z"}