iv class=\"p-header-global__menu__thumbnail\">\n                                <a href=\"https://hanshintigers.jp/community/society/\"><img src=\"/img/2026/header/menu_community.jpg\" alt=\"社会貢献活動報告\"><span>社会貢献活動報告</span></a>\n                            </div>\n                            <div class=\"p-header-global__menu__block\">\n                                <p class=\"p-header-global__menu__heading\"><a href=\"https://hanshintigers.jp/community/\">社会貢献活動</a></p>\n                                <ul class=\"p-header-global__submenu\">\n                                    <li><a href=\"https://hanshintigers.jp/community/wakabayashi/\">若林忠志賞</a></li>\n                                    <li><a href=\"https://hanshintigers.jp/community/charity/\">チャリティー活動</a></li>\n                                    <li><a href=\"https://hanshintigers.jp/community/donation/\">選手による寄付・寄贈</a></li>\n                                    <li><a href=\"https://hanshintigers.jp/community/baseball_invite/\">少年少女野球招待</a></li>\n                                </ul>\n                            </div>\n\n                        </div>\n                    </div>\n                </li>\n                <li class=\"p-header-global__menu js-perent-menu\"><a href=\"https://hanshintigers.jp/home/sponsor/\"><span>スポンサー</span></a>\n\n\n                    <div class=\"p-header-global__menu__wrapper\">\n                        <div class=\"p-header-global__menu__inner\">\n                            <div class=\"p-header-global__menu__thumbnail\">\n                                <a href=\"https://hanshintigers.jp/home/sponsor/\"><img src=\"/img/2026/header/menu_sponsor.jpg\" alt=\"オフィシャルスポンサー\"><span>オフィシャルスポンサー</span></a>\n                            </div>\n                            <ul class=\"p-header-global__menu__block p-header-global__submenu\">\n                                <li><a href=\"https://hanshintigers.jp/home/sponsor/farm.html\">ファームスポンサー</a></li>\n                                <li><a href=\"https://hanshintigers.jp/data/hanshintigers_women/\">Womenスポンサー</a></li>\n                                <li><span href=\"https://hanshintigers.jp/home/sponsor/society.html\">社会貢献スポンサー</span></li>\n                                <li><a href=\"https://hanshintigers.jp/promotion/\">野球振興スポンサー</a></li>\n                            </ul>\n                            <ul class=\"p-header-global__menu__block p-header-global__submenu\">\n                                <li><a href=\"https://hanshintigers.jp/home/sponsor/\">オフィシャルスポンサー</a></li>\n                                <li><a href=\"https://hanshintigers.jp/home/sponsor/partner.html\">パートナー一覧</a></li>\n                                <li><a href=\"https://hanshintigers.jp/home/sponsor/supported.html\">冠試合</a></li>\n                                <li><a href=\"https://hanshintigers.jp/home/sponsor/presented.html\">公式戦賞品提供</a></li>\n                                <li><a href=\"https://hanshintigers.jp/home/sponsor/campaign.html\">キャンペーン</a></li>\n                            </ul>\n                            <!-- <div class=\"p-header-global__menu__block\">\n                                <p class=\"p-header-global__menu__heading\">イベントスポンサー</p>\n                                <ul class=\"p-header-global__submenu\">\n                                    <li><a href=\"https://hanshintigers.jp/90th/#legends-day\">Tigers Legends Day</a></li>\n                                    <li><span href=\"\">ウル虎の夏2025</span></li>\n                                    <li><span href=\"\">TIGERS B-LUCK DYNAMITE SERIES</span></li>\n                                </ul>\n                            </div> -->\n                        </div>\n                    </div>\n                </li>\n            </ul>\n            <!--GN-->\n        </div>\n        <!--HEADER-->\n    </div>\n</div>\n    <div id=\"container\">\n      <div class=\"wrap\"> \n        <!--CONTAINER-->\n        <h2 class=\"ct\">ホーム</h2>\n        <div id=\"side\"> \n          <!--SIDE--> \n             <div id=\"ln\"><!--LN-->\n    <ul>\n     <li id=\"ln_corporate\"><a href=\"/home/corporate/\">会社概要</a></li>\n     <li id=\"ln_company\"><a href=\"/home/company/\">球団の基本姿勢</a></li>\n     <li id=\"ln_policy\"><a href=\"/home/policy/\">サイト運営管理方針</a></li>\n     <li id=\"ln_privacy\"><a href=\"/home/privacy/\">個人情報の取り扱い</a></li>\n     <li id=\"ln_ad\"><a href=\"/home/ad/\">広告掲載のご案内</a></li>\n     <li id=\"ln_qa\"><a href=\"/home/qa/\">お問い合わせ・Q&A</a></li>\n     <li id=\"ln_social\"><a href=\"/home/social/\">ソーシャルメディア</a></li>\n     <li id=\"ln_userpolicy\" class=\"low\"><a href=\"/home/social/userpolicy.html\">ソーシャルメディア利用規約</a></li>\n     <li id=\"ln_mailmagazine\"><a href=\"/home/mailmagazine/\">メールマガジン</a></li>\n     <li id=\"ln_mobile\"><a href=\"/home/mobile/\">公式モバイルサイト</a></li>\n     <li id=\"ln_torapo\"><a href=\"/home/torapo/\">虎ポイント</a></li>\n     <li id=\"ln_toratele\"><a href=\"/home/toratele/\">虎テレ</a></li>\n     <li id=\"ln_tigersnet\"><a href=\"/home/tigersnet/\">タイガースネット.コム</a></li>\n     <li id=\"ln_link\"><a href=\"/home/link/\">リンク集</a></li>\n    </ul>\n   <!--LN--></div> \n          <div id=\"sp-banner\"><!--BANNER-->\n<p id=\"sp-banner-area\">\n<a href=\"http://hanshintigers.jp/banner/cc/cotra_2026.html\" target=\"_blank\" data-gtm-click=\"/banner/img/bnr_con_cotra2026.png\" onclick=\"ga('send', 'event', 'banner_con_rect', 'click', this.href);\"><img src=\"/banner/img/bnr_con_cotra2026.png\" alt=\"レクタングルバナー\" width=\"200\" height=\"200\" /></a>\n</p><!--BANNER--></div>           \n          <!--SIDE--> \n        </div>\n        <div id=\"main\"> \n          <!--MAIN-->\n          <h3 class=\"pt\">問い合わせ・Q&amp;A・お問い合わせ</h3>\n          <p id=\"tp\"><a href=\"/\">TOP</a> &gt; <a href=\"./\">お問い合わせ・Q&amp;A</a> &gt; ご意見・その他お問い合わせ</p>\n          <div id=\"article\"> \n            <!--ARTICLE-->\n            <h4 class=\"qa-ttl\"><span>ご意見・その他お問い合わせ</span></h4>\n            <h5 class=\"qa-stl\" id=\"category2\"><span class=\"mark\">■</span>球団・選手に関すること</h5>\n            <dl class=\"acMenu\" id=\"qa10\">\n              <dt>阪神甲子園球場・ゼロカーボンベースボールパークへの行き方を知りたいのですが？</dt>\n              <dd> <strong>阪神甲子園球場</strong><br />\n                【大阪方面】阪神電車『大阪梅田駅』、【神戸方面】阪神電車『神戸三宮駅』から阪神電車『甲子園駅』（約15分）にて下車、徒歩2分。<br />\n                詳しくはこちらのページをご覧下さい。<br />\n                <a href=\"/ticket/stadium/koshien.html\"><strong>＞阪神甲子園球場</strong></a><br />\n                <br />\n                <strong>ゼロカーボンベースボールパーク</strong><br />\n                阪神電車『大物駅』にて下車、徒歩5分。<br />\n                詳しくはこちらのページをご覧下さい。<br />\n                <a href=\"https://zerocarbon-bp.hanshin.co.jp/park/access.html\" target=\"_blank\"><strong>＞ゼロカーボンベースボールパーク</strong></a> </dd>\n            </dl>\n            <dl class=\"acMenu\" id=\"qa11\">\n              <dt>選手にファンレターを送りたいのですが？</dt>\n              <dd>球団事務所にお送りいただければ、選手へお渡しします。<br />\n                <strong>〒663-8152　兵庫県西宮市甲子園町２番３３号<br>\n                株式会社阪神タイガース『○○選手』係</strong>　まで</dd>\n            </dl>\n            <dl class=\"acMenu\" id=\"qa12\">\n              <dt>選手の成績を知りたいのですが？</dt>\n              <dd>選手の成績についてはこちらのページをご覧下さい。<br />\n                <a href=\"/data/player/\" target=\"_self\"><strong>＞選手プロフィール</strong></a><br />\n                <br />\n                各選手ページに詳細な年度別成績を掲載しております。</dd>\n            </dl>\n            <dl class=\"acMenu\" id=\"qa13\">\n              <dt>選手の移動スケジュールを知りたいのですが？</dt>\n              <dd><strong>遠征移動の予定はご案内できません。</strong><br />\n                また、監督・コーチ・選手の公共交通機関での移動時、ならびに宿舎周辺におきましては、ファンの皆さま、ご通行中の皆さま、および関係者の安全確保の観点から、サイン・握手・写真撮影等の対応は控えさせていただきます。皆さまに安心・安全な環境を維持するため、節度ある行動にご協力いただきますようお願い申し上げます。 </dd>\n            </dl>\n            <dl class=\"acMenu\" id=\"qa14\">\n              <dt>球団の歴史を知りたいのですが？</dt>\n              <dd>球団の歴史についてはこちらのページをご覧ください。<br />\n                <a href=\"/data/history/\" target=\"_self\"><strong>＞阪神タイガースヒストリー</strong></a> <br />\n                <br />\n                また阪神甲子園球場にお越しの際は、阪神タイガースをはじめとする甲子園の歴史が一同にご覧いただける甲子園歴史館へぜひお立ち寄りください。<br />\n                <a href=\"https://koshien-rekishikan.hanshin.co.jp/\" target=\"_blank\"><strong>＞甲子園歴史館</strong></a></dd>\n            </dl>\n            <dl class=\"acMenu\" id=\"qa15\">\n              <dt>一般入団テストは行っていますか？</dt>\n              <dd>阪神タイガースでは現在のところ、一般向け入団テストを実施する予定はございません。</dd>\n            </dl>\n            <dl class=\"acMenu\" id=\"qa16\">\n              <dt>球団職員は一般募集していますか？</dt>\n              <dd>阪神タイガースでは現在のところ、球団職員は募集しておりません。ファンサービス・ゲームスタッフ募集の際は、当公式サイトに随時掲載いたします。</dd>\n            </dl>\n            <h5 class=\"qa-stl\" id=\"category5\"><span class=\"mark\">■</span>ポイント利用に関すること</h5>\n            <dl class=\"acMenu\" id=\"qa22\">\n              <dt>貯めた虎ポイントを店舗で割引販売に使えますか？</dt>\n              <dd>貯めた虎ポイントをグッズ購入にて利用できるのはオンラインショップT-SHOPのみです。</dd>\n            </dl>\n            <h5 class=\"qa-stl\" id=\"category3\"><span class=\"mark\">■</span>月刊タイガースについて</h5>\n            <dl class=\"acMenu\" id=\"qa17\">\n              <dt>年間購読（定期購読）の申し込み方法を知りたいのですが？</dt>\n              <dd>富士山マガジンサービスへご連絡くださいませ。<br />\n                <span class=\"tel\">0570-200-223</span> 営業時間（平日10:00～17:00） </dd>\n            </dl>\n            <dl class=\"acMenu\" id=\"qa18\">\n              <dt>どこの書店で購入できますか？</dt>\n              <dd>書店によっては常設していない場合もございますので、インターネットで単号販売をしております。【月刊タイガース　fujisan】でご購入可能でございます。 </dd>\n            </dl>\n            <dl class=\"acMenu\" id=\"qa19\">\n              <dt>誌面についてのお問い合わせについて。</dt>\n              <dd>月刊タイガース編集室へお問い合わせください。<br />\n                <span class=\"tel\">06-6567-5678</span> （平日10:00～18:00） </dd>\n            </dl>\n            <h5 class=\"qa-stl\" id=\"category1\"><span class=\"mark\">■</span>キャンプに関すること</h5>\n           <p class=\"mt10\"> 詳細が決まり次第、当サイト内にてご案内いたします。</p>\n            <!--<dl class=\"acMenu\" id=\"qa01\">\n              <dt>2026年春季キャンプの日程を教えてほしい。</dt>\n              <dd><a href=\"/news/camp2026/schedule/\"><strong>春季キャンプ特設サイト</strong></a>をご確認ください。</dd>\n            </dl>\n            <dl class=\"acMenu\" id=\"qa02\">\n              <dt>キャンプ地に行きたいが、どうしたらいいですか。</dt>\n              <dd>詳細は、<a href=\"/news/camp2026/access/\"><strong>春季キャンプ特設サイト</strong></a>をご確認ください。<br>\n                <br>\n                ご来場の際は下記注意事項を必ずご確認ください。\n                <ul class=\"indent\">\n                  <li class=\"red\">※席取りの行為は禁止とさせていただきます。貼られているシート等は、練習終了後、すべて撤去いたしますので予めご了承ください。</li>\n                  <li>※練習中の選手へのサインのご依頼はお断りさせていただきます。</li>\n                  <li>※場合によっては入場制限を行う場合がございます。なお、整理券の配布はございません。</li>\n                  <li>※ペットを連れてご入場いただくことは出来ません。</li>\n                  <li>※打撃練習や試合の際、ボールがスタンドや球場外に飛び出る可能性がございます。ボールの行方には十分ご注意ください。</li>\n                  <li>※スケジュールは予告なく変更する場合がございます。</li>\n                </ul>\n              </dd>\n            </dl>\n            <dl class=\"acMenu\" id=\"qa04\">\n              <dt>キャンプ地の映像を見るにはどうしたらいいですか。</dt>\n              <dd>スカイA(CS放送)の猛虎キャンプレポートや、球団公式動画配信サービス「虎テレ」ではキャンプ休日を除き、連日キャンプ地の映像を配信いたします。 <br>\n                <a href=\"https://www.sky-a.co.jp/category/tigers/1000060/\" target=\"_blank\"><strong>＞スカイA</strong></a><br>\n                <a href=\"/home/toratele/\"><strong>＞球団公式動画配信サービス虎テレ</strong></a><br>\n                <br />\n                また球団公式SNSでもキャンプ地の様子を随時配信いたします。<br>\n                <a href=\"https://www.youtube.com/channel/UCqm35j3ustKFyXQVnX5tlXw/\" target=\"_blank\"><strong>＞球団公式YouTube</strong></a><br>\n                <a href=\"https://www.instagram.com/hanshintigers_official/\" target=\"_blank\"><strong>＞球団公式Instagram</strong></a><br>\n                <a href=\"https://x.com/TigersDreamlink\" target=\"_blank\"><strong>＞球団公式X</strong></a> </dd>\n            </dl>\n            <dl class=\"acMenu\" id=\"qa05\">\n              <dt>春季キャンプ地限定グッズを購入したいが、どこで販売していますか。</dt>\n              <dd>バイトするならエントリー宜野座スタジアム売店エリア、うるま市具志川野球場売店エリアのグッズ店舗にて販売いたします。</dd>\n            </dl>-->\n            <h5 class=\"qa-stl\" id=\"category4\"><span class=\"mark\">■</span>その他</h5>\n            <dl class=\"acMenu\" id=\"qa20\">\n              <dt>自分のホームページからリンクを張っても良いですか？</dt>\n              <dd>阪神タイガース公式サイトではトップページに限り、リンクを張っていただいて構いません。<br />\n                ただし、宗教、公序良俗に反するサイト、誹謗中傷を行うサイト、商行為に利用するなどでのリンクはお断り致します。 </dd>\n            </dl>\n            <dl class=\"acMenu\" id=\"qa21\">\n              <dt>自分のホームページに選手の写真や球団ロゴマークなどを使用してもいいですか？</dt>\n              <dd>選手の写真や球団ロゴマーク、当サイト内の記事や情報などは阪神タイガースおよび関係各社の著作物となっております。<br />\n                特別に球団から許可された場合を除き、ホームページ等でのご使用は禁止しています。 </dd>\n            </dl>\n            <div class=\"contact_btn\">\n              <p>上記で解決しない方は以下のフォームよりお問い合わせいただけます｡</p>\n              <div class=\"btn\"><a href=\"https://m.hanshintigers.jp/inquiry/?category=9\"><img src=\"./img/btn_form.jpg\" alt=\"お問い合わせフォームはこちら\" width=\"235\" height=\"50\"></a></div>\n            </div>\n            <!--ARTICLE--> \n          </div>\n          <!--MAIN--> \n        </div>\n        <!--CONTAINER--> \n      </div>\n    </div>\n     \n    <div id=\"footer\" class=\"p-footer\">\n    <!--FOOTER-->\n    <div class=\"p-footer__sponsor\">\n        <div class=\"p-footer__inner\">\n            <div class=\"p-footer__sponsor\">\n                <p class=\"p-footer__heading\"><a href=\"//hanshintigers.jp/home/sponsor/\">OFFICIAL SPONSOR</a></p>\n                <ul class=\"p-footer__sponsor__list\">\n                    <li><a href=\"https://shop.joshin.co.jp/\" target=\"_blank\" data-gtm-click=\"banner_footer_joshin\"><img src=\"/img/2026/footer/sp_joshin.jpg\" alt=\"上新電機株式会社\" width=\"160\" height=\"54\" /></a></li>\n                    <li><a href=\"https://www.mizuno.jp/\" target=\"_blank\" data-gtm-click=\"banner_footer_mizuno\"><img src=\"/img/2026/footer/sp_mizuno.jpg\" alt=\"ミズノ株式会社\" width=\"160\" height=\"54\" /></a></li>\n                    <li><a href=\"https://www.lawson.co.jp/index.html\" target=\"_blank\" data-gtm-click=\"banner_footer_lawson\"><img src=\"/img/2026/footer/sp_lawson.jpg\" alt=\"LAWSON\" width=\"160\" height=\"54\" /></a></li>\n                    <li><a href=\"https://www.asahibeer.co.jp/\" target=\"_blank\" data-gtm-click=\"banner_footer_asahi\"><img src=\"/img/2026/footer/sp_asahi.jpg\" alt=\"アサヒビール\" width=\"160\" height=\"54\" /></a></li>\n                    <li><a href=\"https://www.jibunbank.co.jp/?code=JB0010211201\" target=\"_blank\" data-gtm-click=\"banner_footer_jibun\"><img src=\"/img/2026/footer/sp_jibun.jpg\" alt=\"auじぶん銀行株式会社\" width=\"160\" height=\"54\" /></a></li>\n                </ul>\n            </div>\n            <div id=\"season_logo\"><a href=\"/data/info/\"><img src=\"/img/2026/footer/season_logo.png\" width=\"184\" height=\"100\" alt=\"2026シーズンロゴ\"></a></div>\n        </div>\n    </div>\n\n    <div class=\"p-footer__menu\">\n        <div class=\"p-footer__inner\">\n            <ul class=\"p-footer__menu__list\">\n                <li><a href=\"//hanshintigers.jp/home/corporate/\">会社概要</a></li>\n                <li><a href=\"//hanshintigers.jp/home/company/\">球団の基本姿勢</a></li>\n                <li><a href=\"//hanshintigers.jp/home/policy/\">公式サイト運営管理方針</a></li>\n                <li><a href=\"//hanshintigers.jp/home/privacy/\">個人情報の取り扱い</a></li>\n                <li><a href=\"//hanshintigers.jp/home/ad/\">広告掲載のご案内</a></li>\n                <li><a href=\"//hanshintigers.jp/home/qa/\">問い合わせ・Q&amp;A</a></li>\n                <li><a href=\"//hanshintigers.jp/home/link/\">リンク集</a></li>\n            </ul>\n            <p id=\"copyrights\">&copy; HANSHIN Tigers</p>\n        </div>\n    </div>\n    <!--FOOTER-->\n</div>\n \n    <!--LAYOUT--> \n  </div>\n</div>\n</body>\n</html>","finalUrl":"https://hanshintigers.jp/home/qa/detail_other.html","rendered":false,"_cachedAt":"2026-06-22T17:03:34.515Z"}