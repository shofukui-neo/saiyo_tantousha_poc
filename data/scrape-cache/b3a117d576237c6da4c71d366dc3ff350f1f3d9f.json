\">ポイントの交換について</a>\r\n                </div>\r\n                <div class=\"g-nav-link-branch -level02\">\r\n                  <a href=\"../../raracard-agree/rara-preca/index.html\" title=\"ポイントの有効期限について\">ポイントの有効期限について</a>\r\n                </div>\r\n                <div class=\"g-nav-link-branch -level02\">\r\n                  <a href=\"../../raracard-agree/rara-point/index.html\" title=\"アークスRARAカードポイント提携加盟店について\">アークスRARAカードポイント提携加盟店について</a>\r\n                </div>\r\n              </div>\r\n            </li>\r\n            <li class=\"g-nav-link-branch -level01\">\r\n              <button class=\"treeOpener js-treeOpener\"></button><a href=\"../../corporate/index.html\"\r\n                title=\"法人の皆様へ\">法人の皆様へ</a>\r\n              <div class=\"subWrap\">\r\n                <div class=\"g-nav-link-branch -level02\">\r\n                  <a href=\"../../corporate/site/index.html\" title=\"出店用地・建物募集・テナント募集\">出店用地・建物募集・テナント募集</a>\r\n                </div>\r\n                <div class=\"g-nav-link-branch -level02\">\r\n                  <a href=\"../../corporate/rarapartner/index.html\" title=\"アークスRARAポイント提携加盟店募集\">アークスRARAポイント提携加盟店募集</a>\r\n                </div>\r\n              </div>\r\n            </li>\r\n            <li class=\"g-nav-link-branch -level01\"><a href=\"../../contact/index.html\">お問い合わせ</a></li>\r\n            <li class=\"g-nav-link-branch -level01\"><a href=\"../../sitemap/index.html\">サイトマップ</a></li>\r\n            <li class=\"g-nav-link-branch -myStore\"><a href=\"\">My店舗</a>\r\n              <div class=\"storeList\">\r\n                <div class=\"listItem\">\r\n                  <img src=\"../../shared/img/store/logo_store_arcs.png\" alt=\"スーパーアークス\" />\r\n                  <a href=\"https://www.arcs-g.co.jp/group/ralse/shop/?id=42\" target=\"_blank\"\r\n                    title=\"スーパーアークス山鼻店\">スーパーアークス山鼻店</a>\r\n                </div>\r\n                <div class=\"listItem\">\r\n                  <img src=\"../../shared/img/store/logo_store_arcs.png\" alt=\"スーパーアークス\" />\r\n                  <a href=\"https://www.arcs-g.co.jp/group/ralse/shop/?id=42\" target=\"_blank\"\r\n                    title=\"スーパーアークス山鼻店\">スーパーアークス山鼻店</a>\r\n                </div>\r\n                <div class=\"listItem\">\r\n                  <img src=\"../../shared/img/store/logo_store_arcs.png\" alt=\"スーパーアークス\" />\r\n                  <a href=\"https://www.arcs-g.co.jp/group/ralse/shop/?id=42\" target=\"_blank\"\r\n                    title=\"スーパーアークス山鼻店\">スーパーアークス山鼻店</a>\r\n                </div>\r\n                <div class=\"listItem\">\r\n                  <img src=\"../../shared/img/store/logo_store_arcs.png\" alt=\"スーパーアークス\" />\r\n                  <a href=\"https://www.arcs-g.co.jp/group/ralse/shop/?id=42\" target=\"_blank\"\r\n                    title=\"スーパーアークス山鼻店\">スーパーアークス山鼻店</a>\r\n                </div>\r\n              </div>\r\n            </li>\r\n            <li class=\"g-nav-link-branch -contact\">\r\n              <ul class=\"langSelector\">\r\n                <div class=\"langItem\">日本語</div>\r\n                <div class=\"langItem\">\r\n                  <a href=\"../../en/index.html\">English</a>\r\n                </div>\r\n              </ul>\r\n            </li>\r\n          </ul>\r\n        </div>\r\n      </div>\r\n    </div>\r\n    <div class=\"global-nav-overlay js-global-menu-overlay\"></div>\r\n      <main class=\"d-main -blockParts\">\r\n    <div class=\"inner\">\r\n      <div id=\"VcArea-Heading\">\r\n    <div class=\"h-parts -p2-1 -p2-1-color\">\r\n        <h2><span><span>お問い合わせに関するよくある質問</span></span></h2>\r\n    </div>\r\n      </div>\r\n      <div class=\"breadcrumb\">\r\n        <div>\r\n<a href=\"../../index.html\">TOP</a>&nbsp;<a href=\"../index.html\">お問い合わせ</a>&nbsp;お問い合わせに関するよくある質問\r\n        </div>\r\n      </div>\r\n      <div class=\"d-sec -dParts\">\r\n        <div class=\"inner\" id=\"VcArea-MainColum\">\r\n<div class=\"d-parts -p1 _mt\">\r\n  <h3>よくあるご質問</h3>\r\n</div>\r\n          <div class=\"b-parts -p14-1 \">\r\n            <div class=\"body\">\r\n              <dl>\r\n                <dt><span>Q.</span><span id=\"vcb00000188-40-86-BasicParts14-1-01\" class=\"vcAnchor\">アークスグループとは何ですか</span></dt>\r\n                <dd><span>A.</span>アークスグループは、北海道・東北・北関東の各地に拠点を置く食品スーパー10社とその他の事業会社1社を擁する食品流通グループです。株式会社アークスは、事業会社の株式を保有する純粋持株会社であり、親会社としてグループ全体の統括及び戦略の策定を行っております。事業会社は、株式会社アークスの全体戦略の下、地域に根ざした食品スーパー事業及び関連事業を行っております。詳しくは、以下のページをご覧ください。<br /><br /><a href=\"../../about/group/index.html\" title=\"アークスグループについて\" target=\"_self\">企業・グループ情報の「アークスグループについて」へリンク</a></dd>\r\n              </dl>\r\n              <dl>\r\n                <dt><span>Q.</span><span id=\"vcb00000188-40-88-BasicParts14-1-01\" class=\"vcAnchor\">アークスグループにはどのような企業がありますか。</span></dt>\r\n                <dd><span>A.</span>食品スーパーマーケット10社とその他の事業会社1社で構成されております。詳しくは、以下のページをご覧ください。<br /><br /><a href=\"../../about/group/index.html\" title=\"アークスグループについて\" target=\"_self\">企業・グループ情報の「アークスグループについて」へリンク</a></dd>\r\n              </dl>\r\n              <dl>\r\n                <dt><span>Q.</span><span id=\"vcb00000188-40-89-BasicParts14-1-01\" class=\"vcAnchor\">各食品スーパーの特徴や提供する商品について教えてください。</span></dt>\r\n                <dd><span>A.</span>アークスグループの各食品スーパーは、地域に合った商品ラインナップやサービスを提供しております。詳細については、各事業会社のウェブサイトをご覧ください。<br /><br /><a href=\"https://www.ralse.co.jp/\" title=\"ラルズ\" target=\"_blank\">株式会社ラルズ</a>　<a href=\"https://www.universe.co.jp/\" title=\"ユニバース\" target=\"_blank\">株式会社ユニバース</a><br /><a href=\"https://www.beljois.co.jp/\" title=\"ベルジョイス\" target=\"_blank\">株式会社ベルジョイス</a>　<a href=\"https://www.fukuhara-arcs.co.jp/\" title=\"福原\" target=\"_blank\">株式会社福原</a><br /><a href=\"https://www.douhoku-arcs.co.jp/\" title=\"道北アークス\" target=\"_blank\">株式会社道北アークス</a>　<a href=\"https://www.tokou-store.co.jp/\" title=\"東光ストア\" target=\"_blank\">株式会社東光ストア</a><br /><a href=\"https://www.dounan-ralse.co.jp/\" title=\"道南ラルズ\" target=\"_blank\">株式会社道南ラルズ</a>　<a href=\"https://www.doutou-arcs.co.jp/\" title=\"道東アークス\" target=\"_blank\">株式会社道東アークス</a><br /><a href=\"https://www.itochain.com/\" title=\"伊藤チェーン\" target=\"_blank\">株式会社伊藤チェーン</a>　<a href=\"https://www.sp-otani.com/\" title=\"オータニ\" target=\"_blank\">株式会社オータニ</a><br /><br /><br /></dd>\r\n              </dl>\r\n              <dl>\r\n                <dt><span>Q.</span>店舗の営業時間を知りたい。</dt>\r\n                <dd><span>A.</span>ご利用いただく店舗のページをご確認いただくか、店舗へ直接お問い合わせください。<br />店舗検索から各店舗のページを表示いただけます。<br /><br /><a href=\"../../store/index.html\" title=\"店舗検索\" target=\"_self\">店舗検索のページへ</a></dd>\r\n              </dl>\r\n              <dl>\r\n                <dt><span>Q.</span><span id=\"vcb00000188-40-81-BasicParts14-1-01\" class=\"vcAnchor\">店舗ではどのような決済方法が使用できますか。</span></dt>\r\n                <dd><span>A.</span>アークスRARAカードのプリカ払いのほか、現金、各種クレジットカード、各種コード決済がご利用いただけます。詳しくはご利用いただく店舗のページをご覧ください。<br /><br /><a href=\"../../store/index.html\" title=\"店舗検索\" target=\"_self\">店舗検索のページへ</a></dd>\r\n              </dl>\r\n              <dl>\r\n                <dt><span>Q.</span><span id=\"vcb00000188-40-91-BasicParts14-1-01\" class=\"vcAnchor\">求人について知りたい。</span></dt>\r\n                <dd><span>A.</span>アークスでは、アークスグループ行動指針（Arcs Way）を定め、人材を最も重要な経営資源と考えております。採用情報のページをご覧ください。<br /><br /><a href=\"../../recruit/index.html\" title=\"採用情報\" target=\"_self\">採用情報のページへ</a></dd>\r\n              </dl>\r\n              <dl>\r\n                <dt><span>Q.</span><span id=\"vcb00000188-40-83-BasicParts14-1-01\" class=\"vcAnchor\">アークスRARAカードとは何ですか。</span></dt>\r\n                <dd><span>A.</span>アークスグループ統一のポイントカードです。お客様のお買い物スタイルに合わせて、ご使用いただくカード（全4種類）を選択する事ができます。また、アークスグループの店舗でのお買い物だけではなく、ガソリンスタンドやタクシー会社等の「ポイント提携加盟店」のご利用時にもカードを提示いただくとポイントがたまるお得なカードです。詳しくは以下のページをご覧ください。<br /><br /><a href=\"../../raracard/index.html#vcb00000166-13-57-Default1-01\" target=\"_self\" title=\"アークスRARAカード\">アークスRARAカードのページへ</a></p></dd>\r\n              </dl>\r\n              <dl>\r\n                <dt><span>Q.</span><span id=\"vcb00000188-40-84-BasicParts14-1-01\" class=\"vcAnchor\">アークスアプリとは何ですか。</span></dt>\r\n                <dd><span>A.</span>アークスグループ各店のチラシやおすすめ情報などをご覧いただけるほか、アークスRARAカードの会員様は、プリカ払いやクレジットカード払い、ポイントをプリカへチャージすることが可能なスマートフォン用アプリです。詳しくは以下のページをご覧ください。<br /><br /><a href=\"../../arcsapp/index.html#vcb00000172-13-36-Default1-01\" title=\"アークスアプリ\" target=\"_self\">アークスアプリのページへ</a></dd>\r\n              </dl>\r\n              <dl>\r\n                <dt><span>Q.</span><span id=\"vcb00000188-40-82-BasicParts14-1-01\" class=\"vcAnchor\">株主優待について知りたい。</span></dt>\r\n                <dd><span>A.</span>株主優待に関するよくある質問をご覧ください。<br /><br /><a href=\"../../ir/benefit/faq/index.html\" title=\"株主優待\" target=\"_self\">株主優待に関するよくある質問のページへ</a></dd>\r\n              </dl>\r\n              <dl>\r\n                <dt><span>Q.</span><span id=\"vcb00000188-40-90-BasicParts14-1-01\" class=\"vcAnchor\">サステナビリティの取組みについて知りたい。</span></dt>\r\n                <dd><span>A.</span>アークスグループでは持続的な社会を実現するため、サステナビリティ推進方針及びマテリアリティを策定し、グループ横断でサステナビリティ経営を推進しております。詳しくは以下のページをご覧ください。<br /><br /><a href=\"../../sustainability/index.html\" title=\"サステナビリティ\" target=\"_self\">サステナビリティのページへ</a></dd>\r\n              </dl>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n      </main>\r\n    <div id=\"VcArea-NaviColum\">\r\n<!-- ▼▼▼ ラベル ▼▼▼ -->\r\n<ol>\r\n<li><a href=\"../index.html\">お問い合わせ</a>\r\n<ol>\r\n<li><strong>お問い合わせに関するよくある質問</strong></li>\r\n</ol>\r\n</li>\r\n</ol>\r\n<!-- ▲▲▲ ラベル ▲▲▲ -->\r\n    </div>\r\n    <div id=\"storeSearch\"><a href=\"../../store/index.html\"><img src=\"../../shared/img/common/icon_store_search_arcs-g.svg\" alt=\"店舗検索\"></a></div>\r\n    <footer class=\"d-footer\" id=\"VcArea-Footer\">\r\n<div class=\"inner\">\r\n  <nav class=\"footer-nav -nav01\">\r\n    <div class=\"d-sitemap js-simple-accord\"><a>サイトマップ</a></div>\r\n    <div class=\"inner\">\r\n      <div class=\"listWrap\">\r\n        <div class=\"footer-link-tree -bottom\" style=\"mar