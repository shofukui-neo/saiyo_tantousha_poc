r\n        <div class=\"l-nav_sp__ttl -acc\">\r\n          <p class=\"l-nav_sp__ttl__en\">ABOUT</p>\r\n          <p class=\"l-nav_sp__ttl__jp\">尾道造船を知る</p>\r\n        </div>\r\n        <ul class=\"l-nav_sp__submenu\">\r\n          <li><a href=\"/recruitment/about/\">キーワード＆データで知る尾道造船</a></li>\r\n          <li><a href=\"/recruitment/photo/\">PHOTO TOUR</a></li>\r\n        </ul>\r\n        <a href=\"/recruitment/onozonow/\" class=\"l-nav_sp__ttl -link\">\r\n          <p class=\"l-nav_sp__ttl__en\">ONOZO NOW</p>\r\n          <p class=\"l-nav_sp__ttl__jp\">尾道造船の今</p>\r\n        </a>\r\n        <a href=\"/recruitment/environment/\" class=\"l-nav_sp__ttl -link\">\r\n          <p class=\"l-nav_sp__ttl__en\">ENVIRONMENT</p>\r\n          <p class=\"l-nav_sp__ttl__jp\">働く環境</p>\r\n        </a>\r\n        <div class=\"l-nav_sp__ttl -acc\">\r\n          <p class=\"l-nav_sp__ttl__en\">RECRUIT</p>\r\n          <p class=\"l-nav_sp__ttl__jp\">採用情報</p>\r\n        </div>\r\n        <ul class=\"l-nav_sp__submenu\">\r\n          <li><a href=\"/recruitment/new/\">新卒募集要項</a></li>\r\n          <li><a href=\"/recruitment/technical/\">技能職採用情報</a></li>\r\n          <li><a href=\"/recruitment/career/\">キャリア採用募集要項</a></li>\r\n          <li><a href=\"https://job.mynavi.jp/27/pc/search/corp51214/is.html\" target=\"_blank\"><span>インターンシップ情報</span></a></li>\r\n          <li><a href=\"/recruitment/disability/\">障がい者採用情報</a></li>\r\n        </ul>\r\n      </div>\r\n      <ul class=\"l-nav_sp__btn\">\r\n        <li>\r\n          <a href=\"https://www.instagram.com/onomichizousen/\" target=\"_blank\" class=\"l-nav_sp__btn__official u-hover\">採用公式アカウント</a>\r\n        </li>\r\n        <li>\r\n          <a href=\"https://onozo.co.jp/ja/\" target=\"_blank\" class=\"l-nav_sp__btn__outside u-hover\">コーポレートサイト</a>\r\n        </li>\r\n        <li class=\"l-nav_sp_entry\">\r\n          <p>ENTRY</p>\r\n        </li>\r\n      </ul>\r\n    </div>\r\n    <!-- //sp nav -->\r\n  </div>\r\n\r\n<div class=\"l-entry\">\r\n  <div class=\"l-entry__content\">\r\n    <div class=\"l-entry__content__inner\">\r\n      <h2 class=\"l-entry__content__inner__ttl\">エントリー</h2>\r\n      <p class=\"l-entry__content__inner__lead\">下記からご希望の種別をクリックしてください。<br class=\"u-sp\">それぞれのエントリーフォームへリンクします。</p>\r\n      <div class=\"l-entry__content__link__container\">\r\n        <ul class=\"l-entry__content__link__list\">\r\n    <li>\r\n      <a href=\"https://job.mynavi.jp/26/pc/search/corp51214/outline.html\"\r\n        class=\"l-entry__content__link u-hover\"\r\n        target=\"_blank\"\r\n        rel=\"noopener noreferrer\">\r\n        <span>新卒採用  2026年卒</span>\r\n        <div class=\"arrow_r\"></div>\r\n      </a>\r\n    </li>\r\n    <li>\r\n      <a href=\"https://job.mynavi.jp/27/pc/search/corp51214/outline.html\"\r\n        class=\"l-entry__content__link u-hover\"\r\n        target=\"_blank\"\r\n        rel=\"noopener noreferrer\">\r\n        <span>新卒採用  2027年卒</span>\r\n        <div class=\"arrow_r\"></div>\r\n      </a>\r\n    </li>\r\n    <li>\r\n      <a href=\"https://onozo.co.jp/ja/contact/\"\r\n        class=\"l-entry__content__link u-hover\"\r\n        target=\"_blank\"\r\n        rel=\"noopener noreferrer\">\r\n        <span>キャリア採用</span>\r\n        <div class=\"arrow_r\"></div>\r\n      </a>\r\n    </li>\r\n    <li>\r\n      <a href=\"https://onozo.co.jp/ja/contact/\"\r\n        class=\"l-entry__content__link u-hover\"\r\n        target=\"_blank\"\r\n        rel=\"noopener noreferrer\">\r\n        <span>採用に関するお問い合わせ</span>\r\n        <div class=\"arrow_r\"></div>\r\n      </a>\r\n    </li>\r\n\r\n        </ul>\r\n      </div>\r\n    </div>\r\n  </div>\r\n  <div class=\"l-entry__close\"></div>\r\n</div>  <!-- // template header -->\r\n\r\n  <div class=\"e__bg\">\r\n    <img src=\"/recruitment/wp/wp-content/themes/onozo_recruit/assets/images/environment/kv.jpg\" class=\"u-pc\" alt=\"\">\r\n    <img src=\"/recruitment/wp/wp-content/themes/onozo_recruit/assets/images/environment/kv_sp.jpg\" class=\"u-sp\" alt=\"\">\r\n  </div>\r\n\r\n  <div class=\"e-wrapper\">\r\n    <ul class=\"l-breadcrumb\">\r\n      <li><a href=\"/recruitment/\">トップ</a></li>\r\n      <li><a href=\"/recruitment/environment/\">働く環境</a></li>\r\n    </ul>\r\n\r\n    <h2 class=\"e-ttl u-first_fade\">\r\n      <span class=\"e-ttl__jp\">働く環境</span>\r\n    </h2>\r\n\r\n    <div class=\"e-content\">\r\n      <p class=\"e-content__catch u-ani_fade\">\r\n        「企業は人なり」といわれるように、企業の発展・繁栄には、社員一人ひとりが活き活きと輝き、高い能力を発揮していることが大切です。ONOZOでは、各人が強い責任感や実行力、幅広い視野での物事の捉え方など、常に成長していけるように、さまざまな教育研修制度を設けています。\r\n      </p>\r\n      <div class=\"e-content__bg\">\r\n        <div class=\"u-ani_slide\">\r\n          <div class=\"u-ani_slide_inner\">\r\n            <h3>\r\n              <span class=\"e-ttl-h3__en\">TRAINING</span>\r\n              <span class=\"e-ttl-h3__jp\">教育研修について</span>\r\n            </h3>\r\n          </div>\r\n        </div>\r\n        <div class=\"e-content__inner\">\r\n          <p class=\"e-content__inner__txt u-ani_fade\">新入社員研修、階層別研修に加え、社内選抜研修や各人のキャリアアップにつながる制度を整えています。</p>\r\n        </div>\r\n      </div>\r\n\r\n      <div class=\"e-content__block\">\r\n        <div class=\"e-content__inner__container u-ani_fade\">\r\n          <div class=\"e-content__inner__txt\">\r\n            <h4>新入社員研修</h4>\r\n            <p>\r\n              ONOZOの一員としてスムーズにキャリアをスタートできるよう、充実した研修を用意しています。\r\n            </p>\r\n            <h5>基本的な造船知識の習得</h5>\r\n            <h5>社会人としての心構えや実務上のマナー、ルールの習得</h5>\r\n            <h5>チームワークの推進</h5>\r\n          </div>\r\n          <div class=\"e-content__inner__img u-ani_fade\">\r\n            <img src=\"/recruitment/wp/wp-content/themes/onozo_recruit/assets/images/environment/training_01.jpg\" alt=\"\">\r\n          </div>\r\n        </div>\r\n        <div class=\"e-content__inner__container u-ani_fade\">\r\n          <div class=\"e-content__inner__txt\">\r\n            <h4>社内選抜研修</h4>\r\n            <p>\r\n              社内で選抜されたメンバーを対象に、マネジメント・リーダーシップを身に付けるための研修を用意しています。\r\n            </p>\r\n            <h5>リーダーとしての役割認識やマネジメント能力の習得</h5>\r\n            <ul class=\"e-content__inner__list\">\r\n              <li>業務改善能力</li>\r\n              <li>課題解決能力</li>\r\n            </ul>\r\n            <h5>リーダーとしてのコミュニケーション能力の向上</h5>\r\n            <ul class=\"e-content__inner__list\">\r\n              <li>後輩指導スキル</li>\r\n            </ul>\r\n            <h5>他部署との協働による連携強化</h5>\r\n          </div>\r\n          <div class=\"e-content__inner__img u-ani_fade\">\r\n            <img src=\"/recruitment/wp/wp-content/themes/onozo_recruit/assets/images/environment/training_02.jpg\" alt=\"\">\r\n          </div>\r\n        </div>\r\n        <div class=\"e-content__inner__container u-ani_fade\">\r\n          <div class=\"e-content__inner__txt\">\r\n            <h4>階層別研修</h4>\r\n            <p>\r\n              キャリアアップに合わせ、各階層ごとに求められるスキルを身に付けるための研修を用意しています。\r\n            </p>\r\n            <h5>各階層に必要な基礎知識やノウハウの習得</h5>\r\n            <ul class=\"e-content__inner__list\">\r\n              <li>人材育成スキル</li>\r\n              <li>計数管理力</li>\r\n              <li>ハラスメントへの対応力</li>\r\n              <li>目的達成のためのマネジメント力</li>\r\n            </ul>\r\n          </div>\r\n          <div class=\"e-content__inner__img u-ani_fade\">\r\n            <img src=\"/recruitment/wp/wp-content/themes/onozo_recruit/assets/images/environment/training_03.jpg\" alt=\"\">\r\n          </div>\r\n        </div>\r\n        <div class=\"e-content__inner__container-txt u-ani_fade\">\r\n          <div class=\"e-content__inner__container-txt__block\">\r\n            <h4>社内英会話講座</h4>\r\n            <h5>英会話能力の向上</h5>\r\n            <ul class=\"e-content__inner__list\">\r\n              <li>ビジネス英会話、日常英会話、文法習得など<br class=\"u-pc\">各個人の目的に合ったさまざまなカリキュラムの提供</li>\r\n            </ul>\r\n          </div>\r\n          <div class=\"e-content__inner__container-txt__block\">\r\n            <h4>能力開発支援制度</h4>\r\n            <h5>社員の能力向上を幅広く支援する制度</h5>\r\n            <ul class=\"e-content__inner__list\">\r\n              <li>資格試験料や通信教育の受講料などの半額補助</li>\r\n            </ul>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <div class=\"e-content\">\r\n      <div class=\"e-content__bg\">\r\n        <div class=\"u-ani_slide\">\r\n          <div class=\"u-ani_slide_inner\">\r\n            <h3>\r\n              <span class=\"e-ttl-h3__en\">BENEFITS</span>\r\n              <span class=\"e-ttl-h3__jp\">福利厚生について</span>\r\n            </h3>\r\n          </div>\r\n        </div>\r\n        <div class=\"e-content__inner\">\r\n          <p class=\"e-content__inner__txt u-ani_fade\">\r\n            ONOZOでは、社員一人ひとりが安心して働けるように、生活面・健康面に関してもサポートをしています。\r\n          </p>\r\n        </div>\r\n      </div>\r\n\r\n      <div class=\"e-content__block\">\r\n        <div class=\"e-content__inner__container u-ani_fade\">\r\n          <div class=\"e-content__inner__txt\">\r\n            <h4>独身寮</h4>\r\n            <p>\r\n              独身者向けの住居を整備しています。\r\n            </p>\r\n            <h5>独身寮</h5>\r\n            <h5>完全個室</h5>\r\n            <h5>バス、トイレ、冷暖房、冷蔵庫、洗濯機付き</h5>\r\n          </div>\r\n          <div class=\"e-content__inner__img u-ani_fade\">\r\n            <img src=\"/recruitment/wp/wp-content/themes/onozo_recruit/assets/images/environment/benefits_01.jpg\" alt=\"\">\r\n          </div>\r\n        </div>\r\n        <div class=\"e-content__inner__container u-ani_fade\">\r\n          <div class=\"e-content__inner__txt\">\r\n            <h4>地域との交流、社内イベント</h4>\r\n            <h5>尾道みなと祭り</h5>\r\n            <h5>地域清掃活動</h5>\r\n            <h5>サンクスディ</h5>\r\n            <h5>カープ・スポンサードゲーム</h5>\r\n            <h5>ビーチボールバレー大会</h5>\r\n          </div>\r\n          <div class=\"e-content__inner__img u-ani_fade\">\r\n            <img src=\"/recruitment/wp/wp-content/themes/onozo_recruit/assets/images/environment/benefits_02.jpg\" alt=\"\">\r\n          </div>\r\n        </div>\r\n        <div class=\"e-content__inner__container u-ani_fade\">\r\n          <div class=\"e-content__inner__txt\">\r\n            <h4>クラブ活動</h4>\r\n            <p>\r\n              スポーツ活動を通じて地域や社会との交流を促進し、地域貢献の一つとしてクラブ活動をサポートしています。\r\n            </p>\r\n            <h5>ソフトボール部（若手）　全国大会出場経験あり</h5>\r\n            <h5>ソフトボール部（壮年）　全国大会出場経験あり</h5>\r\n          </div>\r\n          <div class=\"e-content__inner__img u-ani_fade\">\r\n            <img src=\"/recruitment/wp/wp-content/themes/onozo_recruit/assets/images/environment/benefits_03.jpg\" alt=\"\">\r\n          </div>\r\n        </div>\r\n        <div class=\"e-content__inner__container-txt\">\r\n          <div class=\"e-content__inner__container-txt__block u-ani_fade\">\r\n            <h4>各種制度</h4>\r\n            <p>\r\n              社会保険制度をはじめ、社員の互助親睦を深めるため共済会制度を整備しています。\r\n            </p>\r\n            <h5>\r\n              社会保険<br>\r\n              <span>健康保険、厚生年金、介護保険、雇用保険、労災保険</span>\r\n            </h5>\r\n            <h5>\r\n              共済会制度<br>\r\n              <span>傷病見舞金、旅行補助金、食事補助金、火災特別融資　など</span>\r\n            </h5>\r\n            <h5>\r\n              その他<br>\r\n              <span>退職金制度、育児・介護休業制度、各種祝金、住宅資金貸付制度　など</span>\r\n            </h5>\r\n          </div>\r\n          <div class=\"e-content__inner__container-txt__block u-ani_fade\">\r\n            <h4>休日／休暇</h4>\r\n            <p>\r\n              ワークライフバランスの充実のため、休日ならびに各種休暇を整備しています。\r\n            </p>\r\n            <h5>\r\n              休日<br>\r\n              <span>年間123日（週休2日制　※当社カレンダーに準ずる）</span>\r\n            </h5>\r\n            <h5>\r\n              休暇<br>\r\n              <span>年次有給休暇、慶弔休暇、リフレッシュ休暇、年末年始休暇、産前産後休暇、ボランティア休暇など</span>\r\n            </h5>\r\n          </div>\r\n          <div class=\"e-content__inner__container-txt__block u-ani_fade\">\r\n            <h4>健康管理</h4>\r\n            <p>\r\n              健康管理として各種健康診断を実施しています。\r\n            </p>\r\n            <h5>定期健康診断（春・秋）</h5>\r\n            <h5>診療所の設置</h5>\r\n            <h5>ストレスチェック</h5>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n\r\n  <!-- template footer -->\r\n    <div class=\"l-footer_bg\">\r\n    <div class=\"l-footer u-ani_fade\">\r\n      <p class=\"l-footer__logo\">\r\n        <a href=\"/recruitment/\">何より夢中になれる、ものづくりに挑もう。｜採用情報｜尾道造船株式会社／ONOMICHI DOCKYARD RECRUITING SITE</a>\r\n      </p>\r\n      <ul class=\"l-footer__btn\">\r\n        <li>\r\n          <a href=\"https://www.instagram.com/onomichizousen/\" target=\"_blank\" class=\"l-footer__btn__official u-hover\">採用公式アカウント</a>\r\n        </li>\r\n        <li>\r\n          <a href=\"https://onozo.co.jp/ja/\" target=\"_blank\" class=\"l-header__btn__outside u-hover\">コーポレートサイト</a>\r\n        </li>\r\n      </ul>\r\n\r\n      <div class=\"l-footer__nav\">\r\n        <div class=\"l-footer__nav__content\">\r\n          <div class=\"l-footer__nav__content__ttl\">\r\n            <p class=\"l-footer__nav__content__ttl__en\">ABOUT</p>\r\n            <p class=\"l-footer__nav__content__ttl__jp\">尾道造船を知る</p>\r\n          </div>\r\n          <div class=\"l-footer__nav__content__list\">\r\n            <ul>\r\n              <li><a href=\"/recruitment/about/\" class=\"u-hover\">キーワード＆データで知る尾道造船</a></li>\r\n            </ul>\r\n            <ul>\r\n              <li><a href=\"/recruitment/photo/\" class=\"u-hover\">PHOTO TOUR</a></li>\r\n            </ul>\r\n          </div>\r\n        </div>\r\n        <div class=\"l-footer__nav__flex\">\r\n          <div class=\"l-footer__nav__content\">\r\n            <div class=\"l-footer__nav__content__ttl\">\r\n              <p class=\"l-footer__nav__content__ttl__en\">ONOZO NOW</p>\r\n              <p class=\"l-footer__nav__content__ttl__jp\"><a href=\"/recruitment/onozonow/\" class=\"u-hover\">尾道造船の今</a></p>\r\n            </div>\r\n          </div>\r\n          <div class=\"l-footer__nav__content\">\r\n            <div class=\"l-footer__nav__content__ttl\">\r\n              <p class=\"l-footer__nav__content__ttl__en\">ENVIRONMENT</p>\r\n              <p class=\"l-footer__nav__content__tt