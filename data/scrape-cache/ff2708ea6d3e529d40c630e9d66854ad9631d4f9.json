2.jpg);\"></div>\n    <div class=\"hero-slide\" style=\"background-image:url(./common/img/hero-pc-04.jpg);\"></div>\n    <div class=\"hero-slide\" style=\"background-image:url(./common/img/hero-pc-05.jpg);\"></div>\n    <div class=\"hero-slide\" style=\"background-image:url(./common/img/hero-pc-03.jpg);\"></div>\n  </div>\n\n  <div class=\"hero-text\">\n    <p class=\"hero-en\">THE SCIENCE OF SEASONING</p>\n    <h1 class=\"hero-title\">\n      こんな味が<br>\n      欲しかったを<br>\n      <span class=\"hero-title_main\">「形」</span>にします。\n    </h1>\n    <p class=\"hero-lead\">\n      調味料研究会社として<br>\n      お客様の求める「理想の味」の実現をサポートします。\n    </p>\n  </div>\n\n  <div class=\"hero-indicator hero-indicator-sp\">\n    <span class=\"is-active\"></span>\n    <span></span>\n    <span></span>\n    <span></span>\n    <span></span>\n  </div>\n</section>\n<!-- /MAINVISUAL -->\n<!-- NAV -->\n <nav class=\"global-nav\">\n  <ul class=\"global-nav-list\">\n\n    <li class=\"global-nav-item\">\n      <a href=\"#product\">\n        <span class=\"nav-en\">PRODUCT</span>\n        <span class=\"nav-jp\">製品案内</span>\n      </a>\n    </li>\n\n    <li class=\"global-nav-item\">\n      <a href=\"#materials\">\n        <span class=\"nav-en\">MATERIALS</span>\n        <span class=\"nav-jp\">独自素材</span>\n      </a>\n    </li>\n\n    <li class=\"global-nav-item\">\n      <a href=\"#casestudies\">\n        <span class=\"nav-en\">CASE STUDIES</span>\n        <span class=\"nav-jp\">開発事例</span>\n      </a>\n    </li>\n\n    <li class=\"global-nav-item\">\n      <a href=\"#strengths\">\n        <span class=\"nav-en\">STRENGTHS</span>\n        <span class=\"nav-jp\">5つの強み</span>\n      </a>\n    </li>\n\n    <li class=\"global-nav-item\">\n      <a href=\"#support\">\n        <span class=\"nav-en\">SUPPORT</span>\n        <span class=\"nav-jp\">技術支援</span>\n      </a>\n    </li>\n\n    <li class=\"global-nav-item\">\n      <a href=\"#news\">\n        <span class=\"nav-en\">NEWS</span>\n        <span class=\"nav-jp\">ニュース</span>\n      </a>\n    </li>\n\n  </ul>\n</nav>\n<!-- /NAV -->\n\n<!-- ===== NAV / SP ===== -->\n<nav class=\"global-nav-sp\">\n  <ul class=\"global-nav-sp-list\">\n\n    <li class=\"global-nav-sp-item is-current\">\n      <a href=\"#product\">\n        <span class=\"nav-en\">PRODUCT</span>\n        <span class=\"nav-jp\">製品案内</span>\n      </a>\n    </li>\n\n    <li class=\"global-nav-sp-item\">\n      <a href=\"#materials\">\n        <span class=\"nav-en\">MATERIALS</span>\n        <span class=\"nav-jp\">独自素材</span>\n      </a>\n    </li>\n\n    <li class=\"global-nav-sp-item\">\n      <a href=\"#casestudies\">\n        <span class=\"nav-en\">CASE STUDIES</span>\n        <span class=\"nav-jp\">開発事例</span>\n      </a>\n    </li>\n\n    <li class=\"global-nav-sp-item\">\n      <a href=\"#strengths\">\n        <span class=\"nav-en\">STRENGTHS</span>\n        <span class=\"nav-jp\">5つの強み</span>\n      </a>\n    </li>\n\n    <li class=\"global-nav-sp-item\">\n      <a href=\"#support\">\n        <span class=\"nav-en\">SUPPORT</span>\n        <span class=\"nav-jp\">技術支援</span>\n      </a>\n    </li>\n\n    <li class=\"global-nav-sp-item\">\n      <a href=\"#news\">\n        <span class=\"nav-en\">NEWS</span>\n        <span class=\"nav-jp\">ニュース</span>\n      </a>\n    </li>\n\n  </ul>\n</nav>\n<!-- ===== NAV / SP ===== -->\n\n\n<section class=\"features_area\" id=\"product\">\n<div class=\"container pb80\">\n<div class=\"mod_title1\">\n<p class=\"title-en\">PRODUCT</p>\n<h2 class=\"title\">製品案内</h2>\n<p class=\"title_sub\">厳選された素材と独自の技術から生まれる、多彩なラインナップ</p>\n<a class=\"viewall\" href=\"https://www.tokaibsn.co.jp/seasoning/\">VIEW  ALL</a>\n</div>\n\n<div class=\"section-title\">\n  <span class=\"section-title-text\">素材から選ぶ</span>\n  <span class=\"section-title-line\"></span>\n</div>\n\n<div class=\"card-list\">\n  \n<a href=\"https://www.tokaibsn.co.jp/seasoning/meat/\" class=\"card\">\n    <div class=\"card-image\">\n      <img src=\"./img/card01.jpg\" alt=\"畜肉系調味料\">\n    </div>\n    <div class=\"card-body\">\n      <p class=\"card-en\">Meat Extract</p>\n      <h3 class=\"card-title\">畜肉系調味料</h3>\n      <p class=\"card-text\">\n        チキン・ポーク・ビーフをベースとして、お客様の商品の特長を引き出し差別化が可能となる「高」付加価値商品をご提供しております。\n      </p>\n    </div>\n  </a>\n\n<a href=\"https://www.tokaibsn.co.jp/seasoning/fisheries/\" class=\"card\">\n    <div class=\"card-image\">\n      <img src=\"./img/card02.jpg\" alt=\"魚介系調味料\">\n    </div>\n    <div class=\"card-body\">\n      <p class=\"card-en\">Seafood Extract</p>\n      <h3 class=\"card-title\">魚介系調味料</h3>\n      <p class=\"card-text\">\n        こだわった原料を使用して加工しました。<br>\n        海産物の調味技術により優れた風味を有します。\n      </p>\n    </div>\n  </a>\n\n  \n<a href=\"https://www.tokaibsn.co.jp/seasoning/vegetable/\" class=\"card\">\n    <div class=\"card-image\">\n      <img src=\"./img/card03.jpg\" alt=\"野菜系調味料\">\n    </div>\n    <div class=\"card-body\">\n      <p class=\"card-en\">Vegetable &amp; Plant</p>\n      <h3 class=\"card-title\">野菜系調味料</h3>\n      <p class=\"card-text\">\n        北海道に工場がある立地を生かし、\n        たまねぎをはじめ、にんじん・じゃがいも・\n        かぼちゃなどの野菜を調味料に加工しています。\n      </p>\n    </div>\n  </a>\n\n</div>\n<div class=\"section-title mt-60\">\n  <span class=\"section-title-text\">用途から選ぶ</span>\n  <span class=\"section-title-line\"></span>\n</div>\n\n<div class=\"card-list\">\n  \n<a href=\"https://www.tokaibsn.co.jp/seasoning/grant/\" class=\"card\">\n    <div class=\"card-image\">\n      <img src=\"./img/card04.jpg\" alt=\"調理感付与調味料\">\n    </div>\n    <div class=\"card-body\">\n      <p class=\"card-en\">Culinary Note Seasonings</p>\n      <h3 class=\"card-title\">調理感付与調味料</h3>\n      <p class=\"card-text\">\n        焼いた風味や濃厚で深みのある味など、「手間」と「時間」をかけて作られるおいしさやシズル感を手軽に再現できます。\n      </p>\n    </div>\n  </a>\n\n<a href=\"https://www.tokaibsn.co.jp/seasoning/up/\" class=\"card\">\n    <div class=\"card-image\">\n      <img src=\"./img/card05.jpg\" alt=\"アップUP調味料\">\n    </div>\n    <div class=\"card-body\">\n      <p class=\"card-en\">App-Up Flavor Boosters</p>\n      <h3 class=\"card-title\">アップUP調味料</h3>\n      <p class=\"card-text\">\n        味に深みを与え、おいしさを引き上げることで原料の使用量を減らしコストダウンを可能にします。\n      </p>\n    </div>\n  </a>\n\n  \n<a href=\"https://www.tokaibsn.co.jp/seasoning/taste/\" class=\"card\">\n    <div class=\"card-image\">\n      <img src=\"./img/card06.jpg\" alt=\"うま味付与調味料\">\n    </div>\n    <div class=\"card-body\">\n      <p class=\"card-en\">Umami Enhancers</p>\n      <h3 class=\"card-title\">うま味付与調味料</h3>\n      <p class=\"card-text\">\n        おいしさの要である「うま味」を探究してきました。<br>食材本来の風味を活かし「おいしさ」へのこだわりにお応えいたします。\n      </p>\n    </div>\n  </a>\n\n</div>\n\n</div>\n</section>\n<section class=\"products_area bg_1\" id=\"materials\">\n<div class=\"container\">\n<div class=\"mod_title1\">\n<p class=\"title-en\">MATERIALS</p>\n<h2 class=\"title\">美味しさと<br class=\"br_sp\">健康を両立させる、<br>独自素材。</h2>\n<p class=\"title_sub\">長年の経験で培った技術とノウハウを生かし、<br>健康機能性素材の研究・開発に取り組んでいます。</p>\n<a class=\"viewall\" href=\"https://www.tokaibsn.co.jp/material/\">VIEW  ALL</a>\n</div>\n</div>\n\n<div class=\"materials-section\">\n  <div class=\"materials-scroll\">\n  <div class=\"materials-grid\">\n\n    <a href=\"https://www.tokaibsn.co.jp/material/imidazole/\" class=\"materials-card\">\n      <div class=\"materials-card-image\">\n        <img src=\"./img/materials_card01.jpg\" alt=\"\">\n      </div>\n      <div class=\"materials-card-body\">\n        <p class=\"materials-card-en\">Imidazoledipeptide</p>\n        <h3 class=\"materials-card-title\">イミダゾールジペプチド</h3>\n        <p class=\"materials-card-text\">\n          渡り鳥や回遊魚の持久力を支える筋肉成分。加齢で失われがちな活力を効率的に補い、現代人の健康維持に寄与します。\n        </p>\n      </div>\n    </a>\n\n    <a href=\"https://www.tokaibsn.co.jp/material/quercetin/\" class=\"materials-card\">\n      <div class=\"materials-card-image\">\n        <img src=\"./img/materials_card02.jpg\" alt=\"\">\n      </div>\n      <div class=\"materials-card-body\">\n        <p class=\"materials-card-en\">Quercetin / Cycloalliin</p>\n        <h3 class=\"materials-card-title\">ケルセチンシクロアリイン</h3>\n        <p class=\"materials-card-text\">\n          玉ねぎの有用成分を、独自の精製技術で凝縮。ケルセチンとシクロアリインが、効率的な健康習慣をサポートします。\n        </p>\n      </div>\n    </a>\n\n    <a href=\"https://www.tokaibsn.co.jp/material/gaba/\" class=\"materials-card\">\n      <div class=\"materials-card-image\">\n        <img src=\"./img/materials_card03.jpg\" alt=\"\">\n      </div>\n      <div class=\"materials-card-body\">\n        <p class=\"materials-card-en\">Gamma-Amino Butyric Acid</p>\n        <h3 class=\"materials-card-title\">GABA</h3>\n        <p class=\"materials-card-text\">\n          ストレス社会に寄り添うアミノ酸。<br>乳酸菌の力で産生し、現代人の健やかな毎日を多角的にバックアップします。\n        </p>\n      </div>\n    </a>\n\n    <a href=\"https://www.tokaibsn.co.jp/material/fucoidan/\" class=\"materials-card\">\n      <div class=\"materials-card-image\">\n        <img src=\"./img/materials_card04.jpg\" alt=\"\">\n      </div>\n      <div class=\"materials-card-body\">\n        <p class=\"materials-card-en\">Fucoidan</p>\n        <h3 class=\"materials-card-title\">フコイダン</h3>\n        <p class=\"materials-card-text\">\n          海藻に宿る「ネバネバ成分」の恵み。古くから親しまれる水溶性食物繊維が、確かな健康維持に貢献します。\n        </p>\n      </div>\n    </a>\n\n  </div>\n  </div>\n</div>\n\n\n</section>\n<section class=\"case_area\" id=\"casestudies\">\n<div class=\"container pb0\">\n<div class=\"mod_title1\">\n<p class=\"title-en\">CASE STUDIES</p>\n<h2 class=\"title\">課題を解決した<br class=\"br_sp\">開発事例</h2>\n<p class=\"title_sub\">難題を「新しい価値」へ。<br>お客様と歩み、課題を価値へと変えてきた事例をご紹介します。</p>\n<a class=\"viewall\" href=\"https://www.tokaibsn.co.jp/case/\">VIEW  ALL</a>\n</div>\n</div>\n<a href=\"https://www.tokaibsn.co.jp/case/002/\" class=\"case-card\">\n\n  <!-- 左：画像 -->\n  <div class=\"case-card-image\">\n\t\t\t\t<picture>\n\t\t\t\t\t<source media=\"(max-width: 768px)\" srcset=\"./img/case_card01-sp.jpg\">\n\t\t\t\t\t<img src=\"./img/case_card01.jpg\" width=\"610\" height=\"502\" fetchpriority=\"high\" decoding=\"async\" alt=\" \">\n\t\t\t\t</picture>\n  </div>\n\n  <!-- 右：内容 -->\n  <div class=\"case-card-content\">\n\n    <p class=\"case-card-meta\">\n      <span class=\"quote\"></span>\n      食品メーカーC社 商品開発部\n    </p>\n\n    <h3 class=\"case-card-title\">\n      おいしさへのこだわりを技術で叶えた、<br>\n      優れた食品原料とは？\n    </h3>\n\n    \n<div class=\"case-flow\">\n\n  <div class=\"case-block\">\n    <span class=\"case-label is-problem\">課題</span>\n    <p class=\"case-text\">\n      イミダゾールジペプチドを含有しているおいしい原料が見つからない…\n    </p>\n  </div>\n\n  <div class=\"case-block is-solution\">\n\n    <span class=\"case-label is-solution\">解決</span>\n\n    <div class=\"case-blur-area\">\n      <p class=\"case-text\">\n        原料の選定から配合設計までを一貫して見直し、\n        味と機能性を両立させた原料開発に成功しました。\n      </p>\n    </div>\n\n    \n<div class=\"case-button-wrap\">\n  <img\n    src=\"./img/btn-more.png\"\n    alt=\"詳しく読む\"\n    class=\"case-button-image\"\n  >\n</div>\n\n\n  </div>\n\n</div>\n\n\n  </div>\n</a>\n\n\n<a href=\"https://www.tokaibsn.co.jp/case/001/\" class=\"case-card is-reverse\">\n  <div class=\"case-card-image\">\n\t\t\t\t<picture>\n\t\t\t\t\t<source media=\"(max-width: 768px)\" srcset=\"./img/case_card02-sp.jpg\">\n\t\t\t\t\t<img src=\"./img/case_card02.jpg\" width=\"610\" height=\"502\" fetchpriority=\"high\" decoding=\"async\" alt=\" \">\n\t\t\t\t</picture>\n  </div>\n\n  <div class=\"case-card-content\">\n    <p class=\"case-card-meta\">\n      <span class=\"quote\"></span>健康食品メーカーM社 商品開発部\n    </p>\n\n    <h3 class=\"case-card-title\">\n      無味・無臭により近づけたイミダゾールジペプチドで、飲みやすく褐変しないサプリを商品化！\n    </h3>\n\n    <div class=\"case-flow\">\n    <div class=\"case-block\">\n      <span class=\"case-label is-problem\">課題</span>\n      <p class=\"case-text\">\n        鶏の味やにおいが残り飲みにくく、経時変化テストでは褐変も…\n      </p>\n    </div>\n\n    <div class=\"case-block is-solution\">\n      <span class=\"case-label is-solution\">解決</span>\n\n      <div class=\"case-blur-area\">\n        <p class=\"case-text\">\n          独自の原料設計により、味と機能の両立が可能となり、\n          製品の競争力向上に成功しました。\n        </p>\n      </div>\n\n      <div class=\"case-button-wrap\">\n  <img\n    src=\"./img/btn-more.png\"\n    alt=\"詳しく読む\"\n    class=\"case-button-image\"\n  >\n</div>\n    </div>\n    </div>\n  </div>\n</a>\n\n<a href=\"https://www.tokaibsn.co.jp/case/008/\" class=\"case-card\">\n\n  <!-- 左：画像 -->\n  <div class=\"case-card-image\">\n\t\t\t\t<picture>\n\t\t\t\t\t<source media=\"(max-width: 768px)\" srcset=\"./img/case_card03-sp.jpg\">\n\t\t\t\t\t<img src=\"./img/case_card03.jpg\" width=\"610\" height=\"502\" fetchpriority=\"high\" decoding=\"async\" alt=\" \">\n\t\t\t\t</picture>\n  </div>\n\n  <!-- 右：内容 -->\n  <div class=\"case-card-content\">\n\n    <p class=\"case-card-meta\">\n      <span class=\"quote\"></span>\n      健康食品メーカーS社 商品企画部\n    </p>\n\n    <h3 class=\"case-card-title\">\n      決め手はストーリー性？高品質とおいしさを両立したGABA配合エキス粉末とは\n    </h3>\n\n    \n<div class=\"case-flow\">\n\n  <div class=\"case-block\">\n    <span class=\"case-label is-problem\">課題</span>\n    <p class=\"case-text\">\n      売れ行きが好調な青汁に、高付加価値をつけたプレミアムラインを拡充したい…\n    </p>\n  </div>\n\n  <div class=\"case-block is-solution\">\n\n    <span class=\"case-label is-solution\">解決</span>\n\n    <div class=\"case-blur-area\">\n      <p class=\"case-text\">\n        原料の選定から配合設計までを一貫して見直し、\n        味と機能性を両立させた原料開発に成功しました。\n      </p>\n    </div>\n\n    \n<div class=\"case-button-wrap\">\n  <img\n    src=\"./img/btn-more.png\"\n    alt=\"詳しく読む\"\n    class=\"case-button-image\"\n  >\n</div>\n\n\n  </div>\n\n</div>\n\n\n  </div>\n</a>\n\n\n</section>\n<section class=\"strengths_area bg_gl\" id=\"strengths\">\n<div class=\"container pb0\">\n<div class=\"mod_title1\">\n<p class=\"title-en\">STRENGTHS</p>\n<h2 class=\"title color1\">東海物産の<br class=\"br_sp\">５つの強み</h2>\n<p class=\"title_sub color1\">素材の調達から研究開発、徹底した品質管理まで。<br>私たちはお客様の製品価値を最大化するパートナーです。</p>\n<a class=\"viewall_white color1\" href=\"https://www.tokaibsn.co.jp/feature/\">VIEW  ALL</a>\n</div>\n</div>\n\n\n<div class=\"feature-section\">\n  <ul class=\"feature-list\">\n\n    <li class=\"feature-item\">\n      <span class=\"feature-num\">01</span>\n      <h3 class=\"feature-title\">長年培った味の<br>研究技術</h3>\n      <p class=\"feature-text\">\n        独自の探索技術で、理想の「本格的な味」や独自の「隠し味」を具現化します。\n      </p>\n    </li>\n\n    <li class=\"feature-item\">\n      <span class=\"feature-num\">02</span>\n      <h3 class=\"feature-title\">特許技術で<br>作り出す独自性</h3>\n      <p class=\"feature-text\">\n        他社には真似できない高品質でユニークな独自ソリューションを提案します。\n      </p>\n    </li>\n\n    <li class=\"feature-item\">\n      <span class=\"feature-num\">03</span>\n      <h3 class=\"feature-title\">コストダウンと<br>満足感の両立</h3>\n      <p class=\"feature-text\">\n        食材コストを抑えながら満足感を維持・向上させる「アップ調味料」を提供。\n      </p>\n    </li>\n\n    <li class=\"feature-item\">\n      <span class=\"feature-num\">04</span>\n      <h3 class=\"feature-title\">「美味しさ」と<br>「健康」を両立</h3>\n      <p class=\"feature-text\">\n        20年の研究実績で、美味しさに健康価値を加えた「機能性調味料」を提案。\n      </p>\n    </li>\n\n    <li class=\"feature-item\">\n      <span class=\"feature-num\">05</span>\n      <h3 class=\"feature-title\">天然由来原料<br>へのこだわり</h3>\n      <p class=\"feature-text\">\n        原料の特性を活かし、旨味とコクを最大限に引き出します。\n      </p>\n    </li>\n\n  </ul>\n</div>\n\n</section>\n<section class=\"support_area\" id=\"support\">\n<div class=\"container\">\n<div class=\"mod_title1\">\n<p class=\"title-en\">SUPPORT</p>\n<h2 class=\"title\">東海物産の開発・<br class=\"br_sp\">技術サポート</h2>\n<p class=\"title_sub\">私たちが長年培ってきた開発技術で、<br>御社の「これが欲しかった！」を形にします。</p>\n<a class=\"viewall\" href=\"https://www.tokaibsn.co.jp/feature/\">VIEW  ALL</a>\n</div>\n</div>\n\n<div class=\"service-section\">\n  <div class=\"service-grid\">\n\n    <div class=\"service-card\">\n\n      <!-- ICON + SP用 TAG -->\n      <div class=\"service-icon-wrap\">\n        <img class=\"service-icon-image\" src=\"./img/icon-solution.png\" alt=\"\">\n        <span class=\"service-tag-sp\">SOLUTION</span>\n      </div>\n\n      <div class=\"service-body\">\n        <!-- PC用 TAG -->\n        <span class=\"service-tag\">SOLUTION</span>\n\n        <h3 class=\"service-title\">コストダウン<br class=\"br_sp\">リプレイス提案</h3>\n        <p class=\"service-text\">\n          既存レシピの見直しで、品質を維持しながらコスト削減を実現します。\n        </p>\n      </div>\n\n    </div>\n\n    <div class=\"service-card\">\n\n      <div class=\"service-icon-wrap\">\n        <img class=\"service-icon-image\" src=\"./img/icon-analysis.png\" alt=\"\">\n        <span class=\"service-tag-sp\">ANALYSIS</span>\n      </div>\n\n      <div class=\"service-body\">\n        <span class=\"service-tag\">ANALYSIS</span>\n\n        <h3 class=\"service-title\">味覚設計・再現技術</h3>\n        <p class=\"service-text\">\n          ターゲット製品の味を科学的に分析し、高精度で再現・設計します。\n        </p>\n      </div>\n\n    </div>\n\n    <div class=\"service-card\">\n\n      <div class=\"service-icon-wrap\">\n        <img class=\"service-icon-image\" src=\"./img/icon-technology.png\" alt=\"\">\n        <span class=\"service-tag-sp\">TECHNOLOGY</span>\n      </div>\n\n      <div class=\"service-body\">\n        <span class=\"service-tag\">TECHNOLOGY</span>\n\n        <h3 class=\"service-title\">天然素材を活かした味の開発</h3>\n        <p class=\"service-text\">\n          当社独自の配合技術で「美味しい」を<br>実現する技術があります。\n        </p>\n      </div>\n\n    </div>\n\n    <div class=\"service-card\">\n\n      <div class=\"service-icon-wrap\">\n        <img class=\"service-icon-image\" src=\"./img/icon-support.png\" alt=\"\">\n        <span class=\"service-tag-sp\">SUPPORT</span>\n      </div>\n\n      <div class=\"service-body\">\n        <span class=\"service-tag\">SUPPORT</span>\n\n        <h3 class=\"service-title\">差別化素材・隠し味選定</h3>\n        <p class=\"service-text\">\n          他社商品と差をつける、独自の隠し味や<br>機能性素材をご提案します。\n        </p>\n      </div>\n\n    </div>\n\n  </div>\n</div>\n\n\n</section>\n<section class=\"support_area\" id=\"news\">\n<div class=\"container\">\n<div class=\"mod_title1\">\n<p class=\"title-en\">NEWS</p>\n<h2 class=\"ti