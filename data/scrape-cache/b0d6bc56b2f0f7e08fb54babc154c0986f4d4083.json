{"url":"https://www.tobuzoo.com/contact/","html":"<!doctype html>\n<html lang=\"ja\">\n\n<head>\n<meta charset=\"UTF-8\" />\n<title>お問い合わせ｜ ハイブリッド・レジャーランド東武動物公園公式Webサイト</title>\n<link rel=\"stylesheet\" href=\"/assets/cms/public.css\" media=\"all\" />\n<link rel=\"stylesheet\" href=\"/assets/jplayer.css\" media=\"all\" />\n<script src=\"/assets/cms/compat.js\"></script>\n<script src=\"/assets/cms/public.js\"></script>\n<script src=\"/assets/jplayer.js\"></script>\n<script>\n//<![CDATA[\n\n  SS.config = {\"site_url\":\"/\",\"kana_url\":\"/kana/\",\"translate_url\":\"/translate/\",\"theme\":{},\"recommend\":{}};\n\n//]]>\n</script><meta name=\"description\" content=\"東武動物公園のお問い合わせページです。\" />\n\r\n    <!-- Google Tag Manager -->\r\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\r\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\r\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\r\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\r\n})(window,document,'script','dataLayer','GTM-TM4GVW');</script>\r\n<!-- End Google Tag Manager -->\r\n    <script src=\"//msta.j-server.com/MSTA/LUC2TOBUZO/js/msta.js\"></script>\r\n    <meta name=\"viewport\" content=\"width=device-width,initial-scale=1.0,user-scalable=yes,minimum-scale=1.0,maximum-scale=2.0\">\r\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\r\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\r\n    <link href=\"https://fonts.googleapis.com/css2?family=M+PLUS+Rounded+1c:wght@300;400;500;700&family=Noto+Sans+JP:wght@100..900&display=swap\" rel=\"stylesheet\">\r\n    <link href=\"/development/css/splide-core.min.css\" media=\"all\" rel=\"stylesheet\" />\r\n    <link href=\"/development/css/style.css\" media=\"all\" rel=\"stylesheet\" />\r\n    <script src=\"/development/js/splide.min.js\"></script>\r\n    <script src=\"/development/js/common.js\"></script>\r\n    <link rel=\"shortcut icon\" href=\"/development/img/common/favicon.ico \">\r\n<link rel=\"apple-touch-icon\" href=\"/development/img/common/apple-touch-icon.png\">\r\n  \n\n\n\n</head>\n\n<body id=\"body--contact-index\" class=\"body--contact underPage_layout contact__layout\">\r\n    <!-- Google Tag Manager (noscript) -->\r\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-TM4GVW\"\r\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\r\n<!-- End Google Tag Manager (noscript) -->\r\n\r\n    <div id=\"pageContent\">\r\n      <div id=\"top\">\r\n<p class=\"skip inner\"><a href=\"#main\">このページの本文へ</a></p>\r\n</div>\r\n      <!-- Facebook JavaScript SDK -->\r\n<div id=\"fb-root\"></div>\r\n<script async defer crossorigin=\"anonymous\" src=\"https://connect.facebook.net/ja_JP/sdk.js#xfbml=1&version=v12.0\" nonce=\"ECJdN7MV\"></script>\r\n<!-- End Facebook JavaScript SDK -->\r\n      <header id=\"commonHeader\">\r\n        <div class=\"header_inner\">\r\n          <div class=\"logo\"><a href=\"/\"><img src=\"/development/img/common/logo.svg\" alt=\"ハイブリッド・レジャーランド　東武動物公園\" width=\"320\" height=\"90\" /></a></div>\r\n          <div class=\"header_right\">\r\n            <div class=\"header_tool\">\r\n              <ul>\r\n  <li class=\"guide\"><a href=\"/servicelist/\">ご利用ガイド</a></li>\r\n  <li class=\"faq\"><a href=\"/faq/\">よくあるご質問</a></li>\r\n  <li class=\"grouop\"><a href=\"/school/\">学校・団体の方へ</a></li>\r\n</ul>\r\n              <!-- PC表示 -->\r\n              <div class=\"dropdown\" id=\"langDropdown\">\r\n  <div id=\"msta_langArea\" class=\"msta-default\" lang=\"ja\">\r\n  </div>\r\n</div>\r\n\r\n<script>\r\n  (function() {\r\n    const breakpoint = 1060;\r\n    const body = document.body;\r\n\r\n    function moveLangSelector() {\r\n      const langDropdown = document.getElementById('langDropdown');\r\n      const moveTarget = document.getElementById('langMoveTarget');\r\n\r\n      if (!langDropdown || !moveTarget) {\r\n        //console.log('要素が見つかりません' );\r\n        return;\r\n      }\r\n\r\n      // 初回実行時に元の位置を保存\r\n      if (!window.langSelectorOriginal) {\r\n        window.langSelectorOriginal = {\r\n          parent: langDropdown.parentNode,\r\n          nextSibling: langDropdown.nextSibling\r\n        };\r\n      }\r\n\r\n      const isHeaderFixed = body.classList.contains('isHeaderFixed');\r\n      const isMobile = window.innerWidth <= breakpoint;\r\n\r\n      // 1060px以下 または isHeaderFixedがある場合に移動\r\n      if (isMobile || isHeaderFixed) {\r\n        // 移動先に移動\r\n        if (langDropdown.parentNode !== moveTarget) {\r\n          moveTarget.appendChild(langDropdown);\r\n          //console.log('移動しました');\r\n        }\r\n      } else {\r\n        // 元の位置に戻す\r\n        if (langDropdown.parentNode !== window.langSelectorOriginal.parent) {\r\n          window.langSelectorOriginal.parent.insertBefore(\r\n            langDropdown,\r\n            window.langSelectorOriginal.nextSibling\r\n          );\r\n          //console.log('元に戻しました');\r\n        }\r\n      }\r\n    }\r\n\r\n    // ページ読み込み完了後に実行\r\n    if (document.readyState === 'loading') {\r\n      document.addEventListener('DOMContentLoaded', function() {\r\n        moveLangSelector();\r\n      });\r\n    } else {\r\n      moveLangSelector();\r\n    }\r\n\r\n    // リサイズ時\r\n    window.addEventListener('resize', moveLangSelector);\r\n\r\n    // bodyのクラス変更をobserverで監視\r\n    const observer = new MutationObserver(function() {\r\n      //console.log('isHeaderFixedを検出');\r\n      moveLangSelector();\r\n    });\r\n\r\n    observer.observe(body, {\r\n      attributes: true,\r\n      attributeFilter: ['class']\r\n    });\r\n  })();\r\n</script>\r\n            </div>\r\n            <div class=\"header_navi\">\r\n              <nav id=\"globalNav\">\r\n                <ul>\r\n  <li class=\"zoo\">\r\n    <a href=\"/zoo/\">\r\n      <span class=\"naviIcon\" aria-hidden=\"true\"></span>\r\n      動物園\r\n    </a>\r\n  </li>\r\n  <li class=\"park\">\r\n    <a href=\"/park/\">\r\n      <span class=\"naviIcon\" aria-hidden=\"true\"></span>\r\n      遊園地\r\n    </a>\r\n  </li>\r\n  <li class=\"pool\">\r\n    <a href=\"/pool/\">\r\n      <span class=\"naviIcon\" aria-hidden=\"true\"></span>\r\n      プール\r\n    </a>\r\n  </li>\r\n  <li class=\"food-shop\">\r\n    <a href=\"/food-shop/\">\r\n      <span class=\"naviIcon\" aria-hidden=\"true\"></span>\r\n      フード＆<br>ショップ\r\n    </a>\r\n  </li>\r\n  <li class=\"ticket\">\r\n    <a href=\"/ticket/\">\r\n      <span class=\"naviIcon\" aria-hidden=\"true\"></span>\r\n      料金・<br>チケット\r\n    </a>\r\n  </li>\r\n  <li class=\"access\">\r\n    <a href=\"/access/\">\r\n      <span class=\"naviIcon\" aria-hidden=\"true\"></span>\r\n      アクセス\r\n    </a>\r\n  </li>\r\n</ul>\r\n              </nav>\r\n              <!-- SP表示 -->\r\n              <div id=\"langMoveTarget\"></div>\r\n              <div class=\"header_ticket\"><a href=\"/ticket/\"><span class=\"ticket_icon\"></span><span class=\"ticket_text\">チケット</span></a></div>\r\n              <div id=\"menuBtn\"><button aria-controls=\"menuNav\" aria-expanded=\"false\"><span class=\"hamburger\"><span></span></span><span class=\"scrText\">メニュー</span></button></div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </header>\r\n\r\n      <header id=\"pageHeader\">\r\n        <div class=\"pageHeader_inner\">\r\n          <div class=\"bread\">\r\n            <div class=\"crumbs\">\n    <div class=\"crumb\" itemscope itemtype=\"https://schema.org/BreadcrumbList\">\n      <span class=\"page\" itemprop=\"itemListElement\" itemscope itemtype=\"https://schema.org/ListItem\"><span itemprop=\"name\"><a itemprop=\"item\" href=\"/\">トップ</a></span><meta itemprop=\"position\" content=\"1\"></span><span class=\"separator\">&rsaquo;</span><span class=\"page\" itemprop=\"itemListElement\" itemscope itemtype=\"https://schema.org/ListItem\"><span itemprop=\"name\">お問い合わせ</span><meta itemprop=\"position\" content=\"2\"></span>\n    </div>\n</div>\n\r\n          </div>\r\n          <h1 class=\"pageHeader_stay\">\r\n            お問い合わせ\r\n          </h1>\r\n        </div>\r\n      </header>\r\n\r\n      <main id=\"main\">\r\n\r\n        <!-- layout_yield --><script>\n//<![CDATA[\nSS.ready(function() {\nInquiry_Form.render({ confirm: false, requiredLabel: \"※必須入力\" });\n});\n//]]>\n</script>\n<div class=\"inquiry-html\">\n  <div class=\"section_wrap\">\r\n<h2 class=\"section_wrap__heading2\">お問い合わせの前に</h2>\r\n\r\n<p class=\"fType18 marginB60 fBold\">多く寄せられるご質問と回答を掲載しています。お問い合わせ前にご覧ください。</p>\r\n\r\n<ul class=\"category_list marginB80\">\r\n\t<li class=\"more white_base\"><a href=\"/faq/guide/\">営業案内</a></li>\r\n\t<li class=\"more white_base\"><a href=\"/faq/access/\">交通・アクセス</a></li>\r\n\t<li class=\"more white_base\"><a href=\"/faq/service/\">園内サービス・設備</a></li>\r\n\t<li class=\"more white_base\"><a href=\"/faq/zoo-park/\">動物園・遊園地</a></li>\r\n\t<li class=\"more white_base\"><a href=\"/faq/pool/\">プール</a></li>\r\n\t<li class=\"more white_base\"><a href=\"/faq/others/\">その他</a></li>\r\n</ul>\r\n\r\n<div class=\"box_bgLightblue marginB160\">\r\n<h3 class=\"section_wrap__heading3\">取材・撮影について</h3>\r\n\r\n<div class=\"flex_spacebetween_g60\">\r\n<p class=\"fType18 fMedium\">報道関係者からの取材・撮影等に関するお問い合わせは、こちらからお願いします。</p>\r\n\r\n<div class=\"more white_base width452\"><a href=\"https://user.pr-automation.jp/pr-automation/coverage_request.php?key=SvhSRC-zvqRi_u2XIBdxDw%3D%3D\">お問い合わせフォーム</a></div>\r\n</div>\r\n</div>\r\n\r\n<div class=\"box_bgLightblue marginB160\">\r\n<h3 class=\"section_wrap__heading3\">学園祭協賛</h3>\r\n\r\n<div class=\"flex_spacebetween_g60\">\r\n<p class=\"fType18 fMedium\">専用フォームよりお申込みください。<br />\r\n申し込み方法の詳細や受付期間については、随時下記ページでお知らせいたします。</p>\r\n\r\n<div class=\"more white_base width452\"><a href=\"/news/kyosan.html\">学園祭協賛のお申込みについて</a></div>\r\n</div>\r\n</div>\r\n\r\n<h2 class=\"section_wrap__heading2\">お問い合わせ</h2>\r\n\r\n<div class=\"boxBlue\">\r\n<p class=\"fType18 marginB12 fMedium\">必要事項をご入力いただき、「入力内容を確認する」ボタンを押してください。お問い合わせの際は必ずinformation@tobuzoo.co.jpからのメールを受信可能に設定し、お問い合わせください。</p>\r\n\r\n<ul class=\"smallNotice\">\r\n\t<li class=\"fAlertRed\">メールでのお問い合わせには回答までお時間をいただきます。また、お問い合わせの内容や休園等により、ご返信に日数がかかる場合もございますので、ご了承ください。</li>\r\n\t<li class=\"fAlertRed\">お急ぎの場合はお電話（0480-93-1200）にてお問い合わせください。</li>\r\n\t<li>お問合せ内容によっては、お電話でお答えさせていただく場合がございます。</li>\r\n\t<li>お問い合わせの内容によっては、回答できない場合がございます。</li>\r\n\t<li>お客様へのご回答につきましては、当社よりお客様個人宛にお送りするものであり、一部または全体を転用することは著作権法上認められておりません。</li>\r\n</ul>\r\n</div>\r\n</div>\n</div>\n\n  <form enctype=\"multipart/form-data\" action=\"/contact/confirm.html\" accept-charset=\"UTF-8\" method=\"post\">\n  <div class=\"inquiry-form\">\n    \n    <div class=\"columns\">\n  <fieldset class=\"column\"><legend><span class=\"label\">ご用件</span><span class=\"required\">※必須入力</span></legend><div class=\"fields\">\n      \n          <label for=\"item_14_0\">\n            <input type=\"radio\" name=\"item[14]\" id=\"item_14_0\" value=\"ご質問\" /><span>ご質問</span>\n</label>          <label for=\"item_14_1\">\n            <input type=\"radio\" name=\"item[14]\" id=\"item_14_1\" value=\"ご意見・ご要望\" /><span>ご意見・ご要望</span>\n</label></div></fieldset>  <fieldset class=\"column\"><legend><label for=\"item_15\">お問い合わせ内容</label><span class=\"required\">※必須入力</span></legend><div class=\"fields\">\n      \n        <textarea id=\"form_contents\" name=\"item[15]\">\n</textarea>\n</div></fieldset>  <fieldset class=\"column\"><legend><label for=\"item_16\">お名前</label><span class=\"required\">※必須入力</span></legend><div class=\"fields\">\n      \n        <input type=\"text\" name=\"item[16]\" id=\"item_16\" />\n</div></fieldset>  <fieldset class=\"column\"><legend><label for=\"item_17\">電話番号</label></legend><div class=\"fields\">\n      <p><span style=\"white-space: pre-wrap;\">※半角数字/ハイフンなし</span></p>\n        <input type=\"text\" name=\"item[17]\" id=\"item_17\" />\n</div></fieldset>  <fieldset class=\"column\"><legend><label for=\"item_18\">メールアドレス</label><span class=\"required\">※必須入力</span></legend><div class=\"fields\">\n      <p><span style=\"white-space: pre-wrap;\">※半角英数字</span></p>\n        <input type=\"email\" name=\"item[18]\" id=\"item_18\" />\n</div></fieldset>      <fieldset class=\"column\"><legend><label for=\"item_18_confirm\">メールアドレス確認用</label><span class=\"required\">※必須入力</span></legend><div class=\"fields\">\n      <p>もう一度、同じメールアドレスを入力してください。</p>\n      <input value=\"\" type=\"email\" name=\"item[18_confirm]\" id=\"item_18_confirm\" />\n</div></fieldset>  <fieldset class=\"column\"><legend><label for=\"item_19\">年齢</label></legend><div class=\"fields\">\n      \n        <input id=\"age_box\" type=\"text\" name=\"item[19]\" />\n</div></fieldset>  <fieldset class=\"column\"><legend><span class=\"label\">性別</span></legend><div class=\"fields\">\n      \n          <label for=\"item_20_0\">\n            <input type=\"radio\" name=\"item[20]\" id=\"item_20_0\" value=\"男性\" /><span>男性</span>\n</label>          <label for=\"item_20_1\">\n            <input type=\"radio\" name=\"item[20]\" id=\"item_20_1\" value=\"女性\" /><span>女性</span>\n</label>          <label for=\"item_20_2\">\n            <input type=\"radio\" name=\"item[20]\" id=\"item_20_2\" value=\"回答しない\" /><span>回答しない</span>\n</label></div></fieldset>  <fieldset class=\"column\"><legend><label for=\"item_21\">添付ファイル(5Mまで)</label></legend><div class=\"fields\">\n      \n          <input type=\"hidden\" name=\"item[21]\" value=\"\" autocomplete=\"off\" />\n          <input type=\"file\" name=\"item[21]\" id=\"item_21\" /><br />\n          \n</div></fieldset></div>\n\n    <input type=\"hidden\" name=\"item[source_url]\" autocomplete=\"off\" />\n    \n    \n    <footer class=\"send\">\n    <input type=\"submit\" name=\"confirm\" value=\"確認画面へ\" data-disable-with=\"確認画面へ\" />\n    </footer>\n  </div>\n</form><!-- /layout_yield -->\r\n\r\n        <script>\r\n          document.addEventListener('DOMContentLoaded', function () {\r\n\r\n            /* ===== 年齢inputをJSでラップ（「歳」を表示）===== */\r\n            const ageInput = document.querySelector('#age_box');\r\n            if (ageInput && !ageInput.closest('.age-wrap')) {\r\n              const wrap = document.createElement('span');\r\n              wrap.className = 'age-wrap';\r\n\r\n              // inputをwrapで囲む\r\n              ageInput.parentNode.insertBefore(wrap, ageInput);\r\n              wrap.appendChild(ageInput);\r\n            }\r\n\r\n            /* ===== ファイルinputの擬似ボタン ===== */\r\n            const fileInput = document.querySelector('.columns input[type=\"file\"]');\r\n            if (fileInput) {\r\n\r\n              // file input を視覚的に隠す\r\n              fileInput.style.position = 'absolute';\r\n              fileInput.style.opacity = '0';\r\n              fileInput.style.pointerEvents = 'none';\r\n\r\n              // 擬似ボタン作成\r\n              const fakeButton = document.createElement('button');\r\n              fakeButton.type = 'button';\r\n              fakeButton.className = 'file-fake-button';\r\n              fakeButton.textContent = 'ファイルを選択';\r\n\r\n              // ファイル名表示（初期は空）\r\n              const fileName = document.createElement('span');\r\n              fileName.className = 'file-name';\r\n              fileName.textContent = '';\r\n\r\n              // 挿入\r\n              fileInput.parentNode.insertBefore(fakeButton, fileInput.nextSibling);\r\n              fileInput.parentNode.insertBefore(fileName, fakeButton.nextSibling);\r\n\r\n              // 擬似ボタンクリック\r\n              fakeButton.addEventListener('click', function () {\r\n                fileInput.click();\r\n              });\r\n\r\n              // ファイル選択時\r\n              fileInput.addEventListener('change', function () {\r\n                if (this.files && this.files.length > 0) {\r\n                  fileName.textContent = this.files[0].name;\r\n                  fakeButton.textContent = 'ファイルを再選択';\r\n                } else {\r\n                  fileName.textContent = '';\r\n                  fakeButton.textContent = 'ファイルを選択';\r\n                }\r\n              });\r\n\r\n              /* ===== confirm画面対策 ===== */\r\n              if (location.pathname.includes('confirm')) {\r\n                fakeButton.style.display = 'none';\r\n              }\r\n            }\r\n\r\n            /* ===== 個人情報保護方針の同意チェックをJSで生成して挿入 ===== */\r\n            const sendFooter = document.querySelector('footer.send');\r\n            const submitButton = document.querySelector('footer.send input[type=\"submit\"][name=\"confirm\"]');\r\n\r\n            if (sendFooter && submitButton) {\r\n              // 既に挿入済みなら二重追加しない（戻る/再描画対策）\r\n              if (!document.getElementById('contact_agree')) {\r\n                const wrap = document.createElement('div');\r\n\r\n                // 必要最小限のHTMLを生成\r\n                wrap.innerHTML = `\r\n<div class=\"p-contact__agree\">\r\n<label>\r\n<input type=\"hidden\" name=\"contact[agree]\" value=\"0\" autocomplete=\"off\">\r\n<input type=\"checkbox\" name=\"contact[agree]\" id=\"contact_agree\" value=\"1\">\r\n<a href=\"/privacy/\" target=\"_blank\" rel=\"noopener\">当園の個人情報保護方針</a>に同意する\r\n          </label>\r\n          </div>\r\n`;\r\n\r\n                // footer.send の直前に挿入（ボタンのすぐ上に出る）\r\n                sendFooter.parentNode.insertBefore(wrap.firstElementChild, sendFooter);\r\n              }\r\n\r\n              const agreeCheckbox = document.getElementById('contact_agree');\r\n\r\n              // 状態反映\r\n              const updateSubmitState = () => {\r\n                submitButton.disabled = !agreeCheckbox.checked;\r\n              };\r\n\r\n              // 初期状態\r\n              updateSubmitState();\r\n\r\n              // 変更時\r\n              agreeCheckbox.addEventListener('change', updateSubmitState);\r\n            }\r\n\r\n\r\n            /* ===== メールアドレス確認用文言の先頭に「※」を付与 ===== */\r\n            document\r\n              .querySelectorAll('.inquiry-form fieldset')\r\n              .forEach(function (fieldset) {\r\n\r\n              // _confirm で終わる name を持つ input を探す\r\n              const confirmInput = fieldset.querySelector(\r\n                'input[name$=\"_confirm\"], input[name*=\"_confirm\"]'\r\n              );\r\n\r\n              if (!confirmInput) return;\r\n\r\n              // 同じ fieldset 内の説明文 p\r\n              const textP = fieldset.querySelector('.fields p');\r\n              if (!textP) return;\r\n\r\n              // すでに ※ が付いていれば何もしない（再描画対策）\r\n              if (textP.textContent.trim().startsWith('※')) return;\r\n\r\n              textP.textContent = '※' + textP.textContent;\r\n            });\r\n\r\n            /* ===== 「※必須入力」→「※必須」に変更 ===== */\r\n            document.querySelectorAll('span.required').forEach(function (el) {\r\n              if (el.textContent.trim() === '※必須入力') {\r\n                el.textContent = '※必須';\r\n              }\r\n            });\r\n          });\r\n\r\n          /* ===== fields直下の注意文(p)を入力要素の下へ移動 ===== */\r\n          document.querySelectorAll('.fields').forEach(function (fields) {\r\n\r\n            // fields直下のクラスなし p\r\n            const noteP = Array.from(fields.children).find(el =>\r\n                                                           el.tagName === 'P' && el.className === ''\r\n                                                          );\r\n\r\n            if (!noteP) return;\r\n\r\n            // p の直後にある入力要素\r\n            const nextInput = noteP.nextElementSibling;\r\n            if (\r\n              !nextInput ||\r\n              !['INPUT', 'TEXTAREA', 'SELECT'].includes(nextInput.tagName)\r\n            ) {\r\n              return;\r\n            }\r\n\r\n            // すでに input の後ろにある場合は何もしない\r\n            if (nextInput.nextElementSibling === noteP) return;\r\n\r\n            // input の直後に移動\r\n            nextInput.after(noteP);\r\n          });\r\n        </script>\r\n\r\n\r\n      </main>\r\n\r\n      <footer id=\"commonFooter\">\r\n  <div class=\"inner\">\r\n    <