{"url":"http://www.odashima-shouji.co.jp/company/","html":"<!DOCTYPE html>\n<!--[if lt IE 7]> <html class=\"no-js ie6\" lang=\"ja\"> <![endif]-->\n<!--[if IE 7]> <html class=\"no-js ie7\" lang=\"ja\"> <![endif]-->\n<!--[if IE 8]> <html class=\"no-js ie8\" lang=\"ja\"> <![endif]-->\n<!--[if gt IE 8]><!--> <html class=\"no-js\" lang=\"ja\"> <!--<![endif]-->\n<head>\n<meta charset=\"utf-8\">\n<meta http-equiv=\"x-ua-compatible\" content=\"ie=edge\">\n<title>小田島商事株式会社｜会社案内</title>\n<meta name=\"description\" content=\"小田島商事株式会社では、岩手県内・東北・北海道で、農薬、動物薬、防疫殺虫剤、人体用・動物用ワクチン、畜産器具・器材、農業用資材、食品添加物、種子、石油類等の卸・小売及びプレミックス製品販売、畜産衛生食品検査等を行っています。\">\n<meta name=\"keywords\" content=\"小田島商事, 岩手, 農薬, 防疫殺虫剤, 薬剤,会社案内\">\n\n<script type=\"text/javascript\">\n if ((navigator.userAgent.indexOf('iPhone') > 0) || navigator.userAgent.indexOf('iPod') > 0 || navigator.userAgent.indexOf('Android') > 0) {\n  document.write('<meta name=\"viewport\" content=\"width=device-width,initial-scale=1.0\">');\n }else{\n  document.write('<meta name=\"viewport\" content=\"width=1000\">');\n }\n</script>\n<link rel=\"stylesheet\" href=\"../common/css/normalize.css\">\n<link rel=\"stylesheet\" href=\"../common/css/default.css\">\n<link rel=\"stylesheet\" href=\"../common/css/common.css\">\n<link rel=\"stylesheet\" href=\"company.css\">\n<script src=\"../common/js/vendor/modernizr-2.8.3.min.js\"></script>\n<script src=\"http://ajax.googleapis.com/ajax/libs/jquery/1.11.1/jquery.min.js\"></script>\n</head>\n<body>\n<div id=\"top\"></div><!-- #BeginLibraryItem \"/Library/header.lbi\" --><header>\n\t<div class=\"menu -u-PcNoneSpBlock\"><img src=\"../common/img/menu.png\" alt=\"\"></div>\n\t<section class=\"sec-wrap\">\n\t\t<h1 class=\"site-logo clear-text\"><a href=\"../index.html\">小田島商事株式会社</a></h1>\n\t\t<div class=\"g-nav -u-SpNonePcBlock\">\n\t\t\t<ul>\n\t\t\t\t<li><a href=\"index.html\">会社案内<span>Company</span></a></li>\n\t\t\t\t<li><a href=\"../office-list/index.html\">営業所一覧<span>Office</span></a></li>\n\t\t\t\t<li><a href=\"../introduction/index.html\">事業紹介<span>Business</span></a></li>\n\t\t\t\t<li><a href=\"../recruit/index.html\">採用情報<span>Recruit</span></a></li>\n\t\t\t\t<li><a href=\"../whatsnew/index.html\">新着情報<span>News</span></a></li>\n\t\t\t\t<li><a href=\"../inquery/index.php\">お問い合わせ<span>Contact</span></a></li>\n\t\t\t</ul>\n\t\t</div>\n\t</section>\n</header><!-- #EndLibraryItem --><main>\n  <section class=\"sub-title\">\n\t\t<h2 class=\"title\">会社案内<span>Company</span></h2>\n\t</section>\n\t<section class=\"sec-wrap\">\n\t\t<ul class=\"breadcrumb\">\n\t\t\t<li><a href=\"../index.html\">ホーム</a></li>\n\t\t\t<li>会社案内</li>\n\t\t</ul>\n  </section>\n  <section id=\"overview\">\n    <section class=\"sec-wrap\">\n      <h2 class=\"title-M\">会社概要</h2>\n      <section class=\"column-2\">\n        <section class=\"column-item right\">\n          <img width=\"100%\" height=\"auto\" src=\"img/overview-01.jpg\" alt=\"\">\n        </section>\n        <section class=\"column-item left\">\n          <dl class=\"table gray\">\n            <dt>社名</dt>\n            <dd>小田島商事株式会社</dd>\n            <dt>所在地</dt>\n            <dd>〒025-0311 岩手県花巻市卸町66番地</dd>\n            <dt>電話・FAX</dt>\n            <dd>TEL.0198-26-4151 FAX.0198-30-2421</dd>\n            <dt>設立</dt>\n            <dd>昭和40年9月30日（1965年）</dd>\n            <dt>代表者</dt>\n            <dd>代表取締役社長　松野　祐哉</dd>\n            <dt>事業内容</dt>\n            <dd>\n              農薬・肥料・動物用医薬品・農業用資材・畜産用器具機材・防疫剤・<br>\n              人体用及び動物用ワクチン・食品添加物・種子・石油類の卸、<br>\n              小売ならびに畜産用各種プレミックスの製造販売\n            </dd>\n            <dt>資本金</dt>\n            <dd>4,000万円</dd>\n            <dt>年商</dt>\n            <dd>114億円</dd>\n            <dt>従業員数</dt>\n            <dd>200名</dd>\n            <dt>取引金融機関</dt>\n            <dd>岩手銀行・北日本銀行・東北銀行・三菱UFJ銀行・商工中金</dd>\n          </dl>\n        </section>\n      </section>\n    </section>\n    <section class=\"origin\">\n      <section class=\"origin-item\">\n        <h3 class=\"title\">理念</h3>\n        <p>\n          社会の平和と幸福をもたらす<br>\n          最大の要因は、人間の健康にある。\n        </p>\n        <p>\n          我々は其の健康維持増進の為、<br>\n          業務に全力を挙げて<br>\n          努力することに誇りを持つ。\n        </p>\n      </section>\n      <section class=\"origin-item\">\n        <h3 class=\"title\">社是</h3>\n        <p>企業は社会の為に存在し、<br>\n            社会の伸展と共に発展繁栄する。 \n            </p>\n        <p>\n          我社は顧客のよりよき理解と好意を求め、<br>\n          常に正しい経営に総力を結集し、<br>\n          顧客の利益と会社の繁栄と、<br>\n          社員の幸福を通じて広く社会に奉仕する。\n        </p>\n      </section>\n      <section class=\"origin-item\">\n        <h3 class=\"title\">社訓</h3>\n        <p>\n          <span>誠実信義</span>\n          知性をもって判断し、<br>\n          自分の良心に恥じない行動をする。<br>\n          <span>熟慮断行</span>\n          あらゆる知識を正確に且つ速やかに集め検討し、<br>\n          最も有効な結論を出し、<br>\n          勇気と信念をもって実行する。<br>\n          <span>実践力行</span>\n          創意を生かし情熱をもって<br>\n          弛まずに努力する。\n        </p>\n      </section>\n    </section>\n  </section>\n\n  <section id=\"history\">\n    <section class=\"sec-wrap\">\n      <h2 class=\"title-M\">沿革</h2>\n      <section class=\"column-2\">\n        <section class=\"column-item\">\n          <h4 class=\"title-M\">文化</h4>\n          <dl class=\"table gray\">\n            <dt>4年（1807）</dt>\n            <dd>\n              創業<br>\n              近江八幡の薬問屋であったところを南部藩主に召し抱えられ、藩内の薬草を集荷して江戸、大阪の問屋に卸したのが始まり。近江からは、商人・職人・文化人など多くの人が来てそれぞれ県内各地に根付き、花巻には商人が根付いたようです。祖先は代々好奇心旺盛な文化人としての一面をもっており南部藩の通産大臣のような仕事をしていたようです。\n              </dd>\n          </dl>\n          <h4 class=\"title-M\">昭和</h4>\n          <dl class=\"table gray\">\n            <dt>40年（1965）<span>9月</span></dt>\n            <dd>(株)小田島化成品部より分離独立し設立</dd>\n            <dt>41年（1966）<span>1月</span></dt>\n            <dd>桜給油所　開設</dd>\n            <dt><span>4月</span></dt>\n            <dd>大船渡営業所　開設</dd>\n            <dt>42年（1967）<span>9月</span></dt>\n            <dd>盛岡営業所　開設</dd>\n            <dt>44年（1969）<span>8月</span></dt>\n            <dd>東北薬業(株)の営業譲受</dd>       \n            <dt><span>10月</span></dt>\n            <dd>水沢営業所　開設</dd>\n            <dt>48年（1973）<span>3月</span></dt>\n            <dd>大館営業所　開設</dd>\n            <dt>49年（1974）<span>3月</span></dt>\n            <dd>ビニール加工場　設置</dd>\n            <dt>50年（1975）<span>8月</span></dt>\n            <dd>青森営業所　開設</dd>\n            <dt><span>9月</span></dt>\n            <dd>横手営業所　開設</dd>\n            <dt>51年（1976）<span>4月</span></dt>\n            <dd>本社社屋　新築移転</dd>\n            <dt><span>7月</span></dt>\n            <dd>八戸営業所　開設</dd>\n\t\t\t <dt><span>8月</span></dt>\n            <dd>大館営業所　移転　現在に至る</dd>\n            <dt>53年（1978）<span>3月</span></dt>\n            <dd>湯本くみあい共栄(株)との共同出資により花巻商事(株)開設</dd>\n            <dt>54年（1979）<span>5月</span></dt>\n            <dd>古川営業所　開設</dd>\n            <dt>56年（1981）<span>2月</span></dt>\n            <dd>山形営業所　開設</dd>\n\t\t\t<dt>57年（1982）<span>6月</span></dt>\n            <dd>八戸営業所　移転　現在に至る</dd>\n\t\t\t  <dt><span>11月</span></dt>\n            <dd>家畜衛生食品検査センター　設置</dd>\n\t\t\t<dt>58年（1983）<span>3月</span></dt>\n\t\t\t  <dd>青森営業所　移転　現在に至る</dd>\n            <dt>59年（1984）<span>1月</span></dt>\n            <dd>酒田営業所　開設</dd>\n\t\t\t<dt><span>3月</span></dt>\n            <dd>大船渡営業所　移転</dd>\n            <dt>60年（1985）<span>4月</span></dt>\n            <dd>福島営業所　開設</dd>\n            <dt>63年（1988）<span>6月</span></dt>\n            <dd>北海道のアサヒ器薬(株)より営業譲受し札幌・旭川・帯広営業所　開設</dd>\n\t\t\t<dt><span>6月</span></dt>\n            <dd>盛岡営業所・家畜衛生食品検査センター　移転</dd>\n            <dt><span>9月</span></dt>\n            <dd>古川営業所　新築移転　現在に至る</dd>\n          </dl>\n        </section>\n        <section class=\"column-item\">\n          <h4 class=\"title-M\">平成</h4>\n          <dl class=\"table gray\">\n            <dt>元年（1989）<span>2月</span></dt>\n            <dd>山形営業所　移転</dd>\n\t\t\t <dt><span>5月</span></dt>\n            <dd>帯広営業所　移転　現在に至る</dd>\n            <dt><span>10月</span></dt>\n            <dd>水沢営業所を閉鎖し、花巻営業所に統合移転</dd>\n            <dt>2年（1990）<span>7月</span></dt>\n            <dd>(株)小田島産業より営業譲受し、中ノ橋給油所　開設</dd>\n\t\t\t  <dt>4年（1992）<span>7月</span></dt>\n            <dd>旭川営業所　移転　現在に至る</dd>\n            <dt><span>12月</span></dt>\n            <dd>プレミックス工場・管理センター・新農薬倉庫　設置</dd>\n            <dt>5年（1993）<span>9月</span></dt>\n            <dd>家畜衛生食品検査センター　移転　現在に至る</dd>\n            <dt>6年（1994）<span>7月</span></dt>\n            <dd>福島営業所　移転　現在に至る</dd>\n            <dt>8年（1996）<span>4月</span></dt>\n            <dd>中ノ橋給油所　閉鎖</dd>\n            <dt><span>11月</span></dt>\n            <dd>酒田営業所を酒田出張所に改称し移転　現在に至る</dd>\n            <dt>10年（1998）<span>3月</span></dt>\n            <dd>横手営業所　移転　現在に至る</dd>\n            <dt><span>4月</span></dt>\n            <dd>花巻商事(株)を解散し、卸センター給油所　開設</dd>\n            <dt><span>4月</span></dt>\n            <dd>(株)田島屋薬局より営業譲受し、北上店（北上農薬）開設</dd>\n\t\t\t  <dt><span>9月</span></dt>\n            <dd>ビニール加工場　閉鎖</dd>\n            <dt>12年（2000）<span>11月</span></dt>\n            <dd>八戸営業所　新築建て替え</dd>\n            <dt>13年（2001）<span>12月</span></dt>\n            <dd>札幌営業所　移転　現在に至る</dd>\n            <dt>14年（2002）<span>10月</span></dt>\n            <dd>大船渡営業所　改築</dd>\n            <dt>15年（2003）<span>7月</span></dt>\n            <dd>北上店（北上農薬）　閉鎖</dd>\n            <dt>16年（2004）<span>1月</span></dt>\n            <dd>釧路出張所　開設</dd>\n\t\t\t<dt><span>5月</span></dt>\n            <dd>新潟駐在所　開設</dd>\n            <dt>17年（2005）<span>5月</span></dt>\n            <dd>桜給油所　閉鎖</dd>\n            <dt>18年（2006）<span>11月</span></dt>\n            <dd>酒田出張所　移転　現在に至る</dd>\n            <dt>20年（2008）<span>10月</span></dt>\n            <dd>山形営業所　移転　現在に至る</dd>\n            <dt>22年（2010）<span>9月</span></dt>\n            <dd>新潟駐在所　閉鎖</dd>\n            <dt>23年（2011）<span>1月</span></dt>\n            <dd>本社社屋　移転　現在に至る<br>\n花巻及び盛岡営業所　統合（花巻営業所）移転　現在に至る<br>\n釧路出張所　移転 　現在に至る</dd>\n            <dt><span>3月</span></dt>\n            <dd>東日本大震災により大船渡営業所　全壊</dd>\n            <dt>24年（2012）<span>6月</span></dt>\n            <dd>大船渡営業所　新築移転　現在に至る</dd>\n          </dl>\n        </section>\n\t      <section class=\"column-item\">\n          <h4 class=\"title-M\">令和</h4>\n          <dl class=\"table gray\">\n            <dt>3年（2021）<span>12月</span></dt>\n            <dd>大館営業所　閉鎖</dd>\n            <dt>5年（2023）<span>8月</span></dt>\n            <dd>北海道物流センター　帯広市に開設<br>帯広営業所を同場所に移転</dd>\n\t\t\t<dt>6年（2024）<span>12月</span></dt>\n            <dd>家畜衛生食品検査センター　閉鎖</dd>\n            <dt>7年（2025）<span>7月</span></dt>\n            <dd>M&Oホールディングス（株）の完全子会社となり、同社グループに参入</dd>\n          </dl>\n        </section>\n      </section>\n    </section>\n  </section>\n\n  <section id=\"info\">\n      <section class=\"sec-wrap\">\n        <section class=\"button-box\">\n          <div class=\"button-M blue\"><a href=\"../introduction/index.html\">事業内容を見る</a></div>\n          <div class=\"button-M blue\"><a href=\"../recruit/index.html\">採用情報を見る</a></div>\n        </section>\n      </section>\n    </section>\n\n</main><!-- #BeginLibraryItem \"/Library/footer.lbi\" --><footer>\n  <section class=\"sec-wrap\">\n    <section class=\"corner\">\n     <section class=\"corner\">\n      <div class=\"contact\">\n        <section class=\"contact-item\">\n          <p>お電話でのお問い合わせ</p>\n          <h2>☎︎0198-26-4151</h2>\n        </section>\n        <section class=\"contact-item\">\n          <p>メールでのお問い合わせ </p>\n          <section class=\"button-box\">\n            <div class=\"button-M white\"><a href=\"../inquery/index.php\">メールフォームはこちら</a></div>\n          </section>\n        </section>\n      </div>\n      </section>\n      <section class=\"f-nav -u-SpNonePcBlock\">\n      <ul>\n        <li><a href=\"../index.html\">ホーム</a></li>\n        <li><a href=\"index.html\">会社案内</a></li>\n        <li><a href=\"../office-list/index.html\">営業所一覧</a></li>\n        <li><a href=\"../introduction/index.html\">事業紹介</a></li>\n        <li><a href=\"../recruit/index.html\">採用情報</a></li>\n        <li><a href=\"../whatsnew/index.html\">新着情報</a></li>\n        <li><a href=\"../inquery/index.php\">お問い合わせ</a></li>\n      </ul>\n    </section>\n    </section>\n  </section> \n  <section class=\"footer-wrap\">\n    <section class=\"sec-wrap\">\n      <h1 class=\"site-logo clear-text\"><a href=\"../index.html\">小田島商事株式会社</a></h1>\n      <ul>\n        <li class=\"-u-SpNonePcBlock\"><a href=\"../index.html\">ホームに戻る</a></li>\n        <li><a href=\"../privacy/index.html\">個人情報保護方針</a></li>\n      </ul>\n      <address>\n        〒025-0311 岩手県花巻市卸町66番地<br>\n        TEL.0198-26-4151 FAX.0198-30-2421\n      </address>\n      <p class=\"copy-right -u-PcNoneSpBlock\">© Odashima shouji Corporation. All rights reserved.</p>\n    </section>\n  </section>\n  <p class=\"copy-right -u-SpNonePcBlock\">© Odashima shouji Corporation. All rights reserved.</p>\n</footer><!-- #EndLibraryItem --><script>window.jQuery || document.write('<script src=\"common/js/vendor/jquery-1.11.2.min.js\"><\\/script>')</script><!-- #BeginLibraryItem \"/Library/pagetop.lbi\" --><div class=\"pagetop\"><a href=\"#top\"><img src=\"../common/img/try-pagetop.png\" alt=\"\"><p>先頭に戻る</p></a></div>\n<script src=\"../common/js/spmenu.js\"></script>\n<!--<script src=\"//ajax.googleapis.com/ajax/libs/jquery/1.11.2/jquery.min.js\"></script>-->\n<script src=\"../common/js/plugins.js\"></script>\n<script src=\"../common/js/main.js\"></script>\n<!-- Global site tag (gtag.js) - Google Analytics -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=UA-127197119-1\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'UA-127197119-1');\n</script><!-- #EndLibraryItem --></body>\n</html>\n","finalUrl":"http://www.odashima-shouji.co.jp/company/","rendered":false,"_cachedAt":"2026-06-17T23:03:23.038Z"}