b68f5c380\"><input type=\"hidden\" name=\"mce-180f4b68f5c380\">\r\n </div>\r\n </section><section class=\"\" id=\"newcont-180f4b7a086dd\" style=\"\">\r\n <div class=\"section_top\">\r\n <div class=\"text_area pattern_hanyou mce-content-body\" id=\"mce-180f4b7a088116\" contenteditable=\"false\" style=\"position: relative;\" spellcheck=\"false\"><h3>私たちこんな活動しています！</h3></div><input type=\"hidden\" name=\"mce-180f4b7a088116\"><input type=\"hidden\" name=\"mce-180f4b7a088116\"><input type=\"hidden\" name=\"mce-180f4b7a088116\">\r\n </div>\r\n </section><section class=\"\" id=\"newcont-180f4b910f510d\" style=\"\">\r\n <div class=\"section_top\">\r\n <div class=\"contents_box\">\r\n <div class=\"left_text_parts text_area mce-content-body\" id=\"mce-180f4b910f635e\" contenteditable=\"false\" style=\"position: relative;\" spellcheck=\"false\"><p><strong><span style=\"font-size: 16px;\" data-mce-style=\"font-size: 16px;\"><br>&nbsp;現在、12名の学生ジョブメイトが活躍中！その一部を紹介します。　</span></strong>　　　　　　　　　　　　<br></p><table height=\"339\" style=\"border-collapse: collapse; width: 105.582%; height: 395px;\" class=\"mce-item-table\"><tbody><tr style=\"height: 200px;\" data-mce-style=\"height: 200px;\"><td style=\"width: 8.45008%; height: 177px; text-align: center;\"><img src=\"/storage/cms/Page/86b966ca-f59c-4472-8c67-f6c4ad81cfae.png\" alt=\"準備.png\" style=\"max-width: 100%;\" class=\"mce-img\" data-before-name=\"準備.png\" data-flg=\"true\" data-mce-src=\"/storage/cms/Page/86b966ca-f59c-4472-8c67-f6c4ad81cfae.png\" data-mce-style=\"max-width: 100%;\"></td><td style=\"width: 52.5834%; height: 177px;\"><p>これからの企業訪問の前にジョブメイトオリジナル名刺<br>を作りました。<br>もちろん企業さんとの名刺交換を想定してしっかり練習！<br><span><br></span></p></td><td style=\"width: 38.9201%; height: 177px;\"><img src=\"/storage/cms/Page/af0cadfc-6bea-42a8-b81c-f1d8bc9f8575.JPG\" alt=\"IMG_0417.JPG\" style=\"max-width: 100%;\" class=\"mce-img\" data-before-name=\"IMG_0417.JPG\" data-flg=\"true\" data-mce-src=\"/storage/cms/Page/af0cadfc-6bea-42a8-b81c-f1d8bc9f8575.JPG\" data-mce-style=\"max-width: 100%;\"> <img src=\"/storage/cms/Page/b4c6c6c6-d811-40a8-aa26-38b1a8b9a401.JPG\" alt=\"IMG_0442.JPG\" style=\"max-width: 100%;\" class=\"mce-img\" data-before-name=\"IMG_0442.JPG\" data-flg=\"true\" data-mce-src=\"/storage/cms/Page/b4c6c6c6-d811-40a8-aa26-38b1a8b9a401.JPG\" data-mce-style=\"max-width: 100%;\"><br><img src=\"/storage/cms/Page/ca039bbe-c5c6-4ec0-b7b6-46015aaa690b.jpg\" alt=\"IMG20231013153237.jpg\" style=\"max-width: 100%;\" class=\"mce-img\" data-before-name=\"IMG20231013153237.jpg\" data-flg=\"true\" data-mce-src=\"/storage/cms/Page/ca039bbe-c5c6-4ec0-b7b6-46015aaa690b.jpg\" data-mce-style=\"max-width: 100%;\"> <img src=\"/storage/cms/Page/d63ef5bf-a53c-49ca-ae2b-83da914a813b.JPG\" alt=\"IMG_0440.JPG\" style=\"max-width: 100%;\" class=\"mce-img\" data-before-name=\"IMG_0440.JPG\" data-flg=\"true\" data-mce-src=\"/storage/cms/Page/d63ef5bf-a53c-49ca-ae2b-83da914a813b.JPG\" data-mce-style=\"max-width: 100%;\"></td></tr><tr><td style=\"width: 8.45008%; text-align: center;\"><br></td><td style=\"width: 52.5834%;\"><p><br></p></td><td style=\"width: 38.9201%;\"><br></td></tr><tr style=\"height: 200px;\" data-mce-style=\"height: 200px;\"><td style=\"width: 8.45008%; text-align: center; height: 30px;\"><img src=\"/storage/cms/Page/41fd6b33-933a-42a6-8956-0404d51978ae.png\" alt=\"企画.png\" style=\"max-width: 100%;\" class=\"mce-img\" data-before-name=\"企画.png\" data-flg=\"true\" data-mce-src=\"/storage/cms/Page/41fd6b33-933a-42a6-8956-0404d51978ae.png\" data-mce-style=\"max-width: 100%;\"></td><td style=\"width: 52.5834%; height: 30px; text-align: left;\">ジョブカフェしまねのイベント「しまねジャンボ企業博」でジョブ<br>メイト初企画！<br>「しまねジャンボ企業博を参加学生に楽しんでもらおう！」アイデア<br>が溢れます。</td><td style=\"width: 38.9201%; height: 30px;\"><img src=\"/storage/cms/Page/edf16bdb-b6f8-4695-bae9-1babdda288c8.jpg\" alt=\"IMG20231013141405.jpg\" style=\"max-width: 100%;\" class=\"mce-img\" data-before-name=\"IMG20231013141405.jpg\" data-flg=\"true\" data-mce-src=\"/storage/cms/Page/edf16bdb-b6f8-4695-bae9-1babdda288c8.jpg\" data-mce-style=\"max-width: 100%;\"> <img src=\"/storage/cms/Page/59470efa-e547-44e7-9902-0b4243925259.jpg\" alt=\"IMG20230926142332.jpg\" style=\"max-width: 100%;\" class=\"mce-img\" data-before-name=\"IMG20230926142332.jpg\" data-flg=\"true\" data-mce-src=\"/storage/cms/Page/59470efa-e547-44e7-9902-0b4243925259.jpg\" data-mce-style=\"max-width: 100%;\"></td></tr><tr><td style=\"width: 8.45008%; text-align: center;\"><br></td><td style=\"width: 52.5834%; text-align: left;\"><br></td><td style=\"width: 38.9201%;\"><br></td></tr><tr style=\"height: 200px;\" data-mce-style=\"height: 200px;\"><td style=\"width: 8.45008%; height: 188px; text-align: center;\"><img src=\"/storage/cms/Page/dee5eb5f-641d-4fd7-85de-2966cf8eedaa.png\" alt=\"企業訪問.png\" style=\"max-width: 100%;\" class=\"mce-img\" data-before-name=\"企業訪問.png\" data-flg=\"true\" data-mce-src=\"/storage/cms/Page/dee5eb5f-641d-4fd7-85de-2966cf8eedaa.png\" data-mce-style=\"max-width: 100%;\"></td><td style=\"width: 52.5834%; height: 188px;\"><p>興味のある業界の企業を訪問し、合説では聞けないことや、会社の<br>雰囲気をリアルに感じることができるのもメイトの特権です。</p></td><td style=\"width: 38.9201%; height: 188px; text-align: left;\"><img src=\"/storage/cms/Page/07268002-6f39-4b24-bb75-a97263fa1797.JPG\" alt=\"IMG_1718.JPG\" style=\"max-width: 100%;\" class=\"mce-img\" data-before-name=\"IMG_1718.JPG\" data-flg=\"true\" data-mce-src=\"/storage/cms/Page/07268002-6f39-4b24-bb75-a97263fa1797.JPG\" data-mce-style=\"max-width: 100%;\"> <img src=\"/storage/cms/Page/dbf17b3a-ed1c-4bf3-bba5-e22eefbad622.JPG\" alt=\"IMG_1751.JPG\" style=\"max-width: 100%;\" class=\"mce-img\" data-before-name=\"IMG_1751.JPG\" data-flg=\"true\" data-mce-src=\"/storage/cms/Page/dbf17b3a-ed1c-4bf3-bba5-e22eefbad622.JPG\" data-mce-style=\"max-width: 100%;\"><br><img src=\"/storage/cms/Page/94c3082f-b1de-48a1-8759-8e4673e06ca4.png\" alt=\"昼食風景.png\" style=\"max-width: 100%;\" class=\"mce-img\" data-before-name=\"昼食風景.png\" data-flg=\"true\" data-mce-src=\"/storage/cms/Page/94c3082f-b1de-48a1-8759-8e4673e06ca4.png\" data-mce-style=\"max-width: 100%;\"> <img src=\"/storage/cms/Page/ebe7217a-c761-4bdf-b2aa-54dc2e234544.png\" alt=\"MicrosoftTeams-image (1).png\" style=\"max-width: 100%;\" class=\"mce-img\" data-before-name=\"MicrosoftTeams-image (1).png\" data-flg=\"true\" data-mce-src=\"/storage/cms/Page/ebe7217a-c761-4bdf-b2aa-54dc2e234544.png\" data-mce-style=\"max-width: 100%;\"></td></tr></tbody></table></div><input type=\"hidden\" name=\"mce-180f4b910f635e\"><input type=\"hidden\" name=\"mce-180f4b910f635e\"><input type=\"hidden\" name=\"mce-180f4b910f635e\"><input type=\"hidden\" name=\"mce-180f4b910f635e\"><input type=\"hidden\" name=\"mce-180f4b910f635e\"><input type=\"hidden\" name=\"mce-180f4b910f635e\"><input type=\"hidden\" name=\"mce-180f4b910f635e\"><input type=\"hidden\" name=\"mce-180f4b910f635e\"><input type=\"hidden\" name=\"mce-180f4b910f635e\"><input type=\"hidden\" name=\"mce-180f4b910f635e\">\r\n </div>\r\n </div>\r\n </section><section class=\"\" id=\"newcont-18c8b6a46f53de\" style=\"\">\r\n <div class=\"section_top\">\r\n <div class=\"text_area pattern_hanyou pattern_hanyou_h2 mce-content-body\" id=\"mce-18c8b6a46f5243\" contenteditable=\"false\" style=\"position: relative;\" spellcheck=\"false\"><h2>学生ジョブメイトからのメッセージ</h2></div><input type=\"hidden\" name=\"mce-18c8b6a46f5243\">\r\n </div>\r\n </section><section class=\"\" id=\"newcont-180f4bc11ca2be\" style=\"\">\r\n <div class=\"section_top\">\r\n <div class=\"contents_box\">\r\n <div class=\"left_text_parts text_area mce-content-body mce-edit-focus\" id=\"mce-180f4bc11ca23a\" contenteditable=\"false\" style=\"position: relative;\" spellcheck=\"false\"><p>■「何か挑戦してみたいけど何を始めよう<span>…</span>」私はそう思っていた時にジョブメイトの活動を知り、参加しました。自分の都合に合わせて活動できるので無理なく続けられるのはもちろん、自分が興味のある業種を選んで企業の取材に行ったり、就活イベントに向けて仲間と企画や準備をしたり、自然と企業の方との接点が増えるので、活動しながら業界研究・就活イベントの情報収集ができます。就活中分からないことがあれば、ジョブカフェの皆さんに気軽に質問できるのも魅力の<span>1</span>つです！【島根大学　3年】</p><p>■はじめは企業訪問をすることに不安がありましたが、ジョブカフェのスタッフさんの手厚いサポートにより、楽しく訪問することができました。行きたい企業がはっきりとしていなかったので、興味のある業界から企業を勧めてもらい、訪問しました。訪問での目標を立てて、事前にいろいろ調べることで自分がもっと知りたいということや大切にしていることに気づくことができました。【島根大学　3年】<br><br>■一番のメリットは取材に行くことで面接など人と話す場に慣れることができます。他にも様々な経験が出来るので、私たちと一緒に活動しませんか！</p><p>・ガクチカになる　　・企画力が養われる　　・学生主体の活動が多いため、何事にも主体的になれる<br>・一足早く就活などの情報を手に入れることができる　　【島根県立大学　3年】<span>&nbsp;</span></p></div><input type=\"hidden\" name=\"mce-180f4bc11ca23a\"><input type=\"hidden\" name=\"mce-180f4bc11ca23a\"><input type=\"hidden\" name=\"mce-180f4bc11ca23a\"><input type=\"hidden\" name=\"mce-180f4bc11ca23a\"><input type=\"hidden\" name=\"mce-180f4bc11ca23a\">\r\n </div>\r\n </div>\r\n </section><section class=\"\" id=\"newcont-180f4bfbf20b5\" style=\"\">\r\n <div class=\"section_top\">\r\n <div class=\"text_area pattern_hanyou mce-content-body\" id=\"mce-180f4bfbf201d5\" contenteditable=\"false\" style=\"position: relative;\" spellcheck=\"false\"><h3>参加するメリット</h3></div><input type=\"hidden\" name=\"mce-180f4bfbf201d5\">\r\n </div>\r\n </section><section class=\"\" id=\"newcont-180f4c044dd11f\" style=\"\">\r\n <div class=\"section_top\">\r\n <div class=\"contents_box\">\r\n <div class=\"left_text_parts text_area mce-content-body\" id=\"mce-180f4c044dd2c3\" contenteditable=\"false\" style=\"position: relative;\" spellcheck=\"false\"><p>〇企業や社会人へ取材することでビジネスマナーが身につく<br>〇島根の魅力を知ることができる<br>〇就活の流れを人より早く知ることができる<br>〇ジョブメイトの経験を就職活動でアピールできる　　・・・など、盛りだくさん！<br></p></div><input type=\"hidden\" name=\"mce-180f4c044dd2c3\"><input type=\"hidden\" name=\"mce-180f4c044dd2c3\"><input type=\"hidden\" name=\"mce-180f4c044dd2c3\">\r\n </div>\r\n </div>\r\n </section><section class=\"\" id=\"newcont-180f4e319721a9\" style=\"\">\r\n <div class=\"section_top\">\r\n <div class=\"contents_box\">\r\n <div class=\"left_text_parts text_area mce-content-body\" id=\"mce-180f4e31972b0\" contenteditable=\"false\" style=\"position: relative;\" spellcheck=\"false\"><p>対　象：4年制大学の1～3年生、2年制短大・専修学校の1年生など、卒業前年次までの学生<br>活動日：ジョブメイトのメンバーで相談の上、決定します。都合の合う日程のみの参加でもOKです。<br>活動場所：松江・浜田周辺　※県外ジョブメイトも活動中<br>申込み：参加希望の方は、申込みフォームよりお気軽にお申込みください。</p></div><input type=\"hidden\" name=\"mce-180f4e31972b0\">\r\n </div>\r\n </div>\r\n </section><section class=\"\" id=\"newcont-180f4e72f59c0\" style=\"\">\r\n <div class=\"section_top\">\r\n <div class=\"contents_box\">\r\n <div class=\"center_btn_parts\">\r\n <div class=\"text_area mce-content-body\" id=\"mce-180f4e72f5a385\" contenteditable=\"false\" style=\"position: relative;\" spellcheck=\"false\"><p class=\"link_btn big_font\"><a class=\"flash\" href=\"https://forms.office.com/r/e441rAhkQJ\" data-mce-href=\"https://forms.office.com/r/e441rAhkQJ\">「しまね学生ジョブメイト」のお申込みはコチラ</a></p></div><input type=\"hidden\" name=\"mce-180f4e72f5a385\"><input type=\"hidden\" name=\"mce-180f4e72f5a385\"><input type=\"hidden\" name=\"mce-180f4e72f5a385\">\r\n </div>\r\n </div><!-- /.黄色ボタン -->\r\n </div>\r\n </section><section class=\"\" id=\"newcont-180f4e8999a271\" style=\"\">\r\n <div class=\"section_top\">\r\n <div class=\"contents_box\">\r\n <div class=\"left_text_parts text_area mce-content-body\" id=\"mce-180f4e8999a120\" contenteditable=\"false\" style=\"position: relative;\" spellcheck=\"false\"><p>【お問合せ先】<br>ジョブカフェしまね（公益財団法人ふるさと島根定住財団）<br>しまね学生ジョブメイト担当<br>TEL：0120-67-4510／0852-28-0694</p></div><input type=\"hidden\" name=\"mce-180f4e8999a120\">\r\n </div>\r\n </div>\r\n </section>\n        </div>\n    </div><!-- /.contents_area -->\n</div><!-- /.contents_block -->\n\n        <div class=\"contents_inner\">\n            <!doctype html>\n<div class=\"page_sns_wrap\">\n  <div class=\"page_top_link\">\n      <a href=\"https://www.gogo-jobcafe-shimane.jp\">トップページへ</a>\n  </div>\n\n\n    <!-- <div class=\"page_sns_box\">\n  <ul>\n    <li>\n      <span class=\"sns_logo\">\n        <img src=\"/image/jobcafe/common/icon_sns_logo.png\" alt=\"ジョブカフェしまねOfficial SNS\">\n      </span>\n      <span class=\"sns_facebook\">\n        <a href=\"https://www.facebook.com/jobcafeshimane/\" target=\"_blank\">\n          <img src