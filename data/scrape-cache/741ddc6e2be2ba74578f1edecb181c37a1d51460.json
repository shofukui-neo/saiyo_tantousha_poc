nate\" type=\"text/xml+oembed\" href=\"https://www.kk-tosan.co.jp/wp-json/oembed/1.0/embed?url=https%3A%2F%2Fwww.kk-tosan.co.jp%2Fcompany%2F&#038;format=xml\" />\n<!-- customizer CSS -->\n<style>\nhtml {\nfont-size: 62.5%;\n}\n\nbody {\nbackground-color: #fff;\n}\n\na {\n}\n\na:focus,\na:hover {\n}\n\n/* .footCopy {\n} */\n</style>\n\t\t<style type=\"text/css\" id=\"wp-custom-css\">\n\t\t\t/*\nここに独自の CSS を追加することができます。\n\n詳しくは上のヘルプアイコンをクリックしてください。\n*/\n\n.tablestyletype001 {\n}\n.tablestyletype001 th{\nwidth:50%;\n}\n.tablestyletype001 td{\nwidth:50%;\n}\t\t</style>\n\t<link rel=\"alternate\" type=\"application/rss+xml\" title=\"RSS\" href=\"https://www.kk-tosan.co.jp/feed/\" />\r\n<link rel=\"alternate\" type=\"application/atom+xml\" title=\"Atom\" href=\"https://www.kk-tosan.co.jp/feed/atom/\" />\r\n\r\n</head>\r\n\r\n\r\n\r\n\r\n\r\n<body class=\"page-template-default page page-id-10 page-parent company\">\r\n<a id=\"top\"></a>\r\n<!-- Facebook JavaScript SDK -->\r\n<div id=\"fb-root\"></div>\r\n<script>(function(d, s, id) {\r\n  var js, fjs = d.getElementsByTagName(s)[0];\r\n  if (d.getElementById(id)) return;\r\n  js = d.createElement(s); js.id = id;\r\n  js.src = \"//connect.facebook.net/ja_JP/sdk.js#xfbml=1&version=v2.9\";\r\n  fjs.parentNode.insertBefore(js, fjs);\r\n}(document, 'script', 'facebook-jssdk'));</script>\r\n<!-- Facebook JavaScript SDK -->\r\n\r\n\r\n<header id=\"top\">\r\n<div class=\"container-fluid headOuterContainer\">\r\n<div class=\"container headContainer\">\r\n\r\n\r\n<div class=\"siteTitleContainer\">\r\n<p class=\"siteTitle h1\"><a href=\"https://www.kk-tosan.co.jp/\" rel=\"home\"><img src=\"https://www.kk-tosan.co.jp/wp/wp-content/themes/kktosan/img/common/logo.jpg\" alt=\"株式会社 東酸\" /></a></p></div><!-- / .siteTitleContainer -->\r\n\r\n\r\n<div class=\"globalNaviContainer\">\r\n\r\n\r\n<div class=\"headerButton\">\r\n<ul class=\"headerButtonList\">\r\n<li><a \r\n\thref=\"tel:0177362125\"><img src=\"https://www.kk-tosan.co.jp/wp/wp-content/themes/kktosan/img/common/headbanner1_tel.gif\" alt=\"電話でのお問い合わせは 017-736-2125（代表）\" /></a></li><li><a \r\n\thref=\"/kk-tosan/contact\"><img src=\"https://www.kk-tosan.co.jp/wp/wp-content/themes/kktosan/img/common/headbanner1_mail.gif\" alt=\"メールでお問い合わせ\" /></a></li>\r\n</ul><!-- / .headerButtonList -->\r\n</div><!-- / .headerButton -->\r\n\r\n\r\n<div id=\"openNavi\" class=\"openNavi\"><a><span><img src=\"https://www.kk-tosan.co.jp/wp/wp-content/themes/kktosan/img/common/menuopen_icon.png\" alt=\"MENU\" /></span></a></div>\r\n<div id=\"globalNavi\" class=\"globalNavi clearfix\">\r\n<ul id=\"globalMainNavi\" class=\"globalMainNavi\"><li><a href=\"https://www.kk-tosan.co.jp/\">HOME</a></li><!-- \n --><li class=\"current-menu-item current_page_item\"><a href=\"https://www.kk-tosan.co.jp/company/\">会社案内</a></li><!-- \n --><li><a href=\"https://www.kk-tosan.co.jp/catalog/\">取扱品目</a></li><!-- \n --><li><a href=\"https://www.kk-tosan.co.jp/office/\">営業所案内</a></li><!-- \n --><li><a href=\"https://www.kk-tosan.co.jp/news/\">新着情報</a></li><!-- \n --></ul>\r\n</div><!-- / #globalNavi .globalNavi .clearfix -->\r\n\r\n\r\n</div><!-- / .globalNaviContainer -->\r\n\r\n\r\n\r\n\r\n</div><!-- / .container .headContainer -->\r\n\r\n\r\n</div><!-- / .container-fluid .headOuterContainer -->\r\n</header><!-- / -->\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n<div class=\"container\">\r\n\r\n\r\n<div class=\"row row-sm84pad80\">\r\n\n\n<div class=\"col-sm-12\">\n<div class=\"mainArticleCol1\">\n\n\n\n<article id=\"post-10\" class=\"post-10 page type-page status-publish hentry\">\t\n\n\n<div class=\"pageTitleContainer\">\n<h1 class=\"h1 pageTitle\">会社案内</h1><div id=\"breadcrumb\" class=\"breadcrumb clearfix\">\n<ul class=\"clearfix\"><li><a href=\"https://www.kk-tosan.co.jp\">TOP</a></li><li>会社案内</li></ul>\n</div></div><!-- / .pageTitleContainer -->\n\n\n<div class=\"entryContent clearfix\">\n<h2>東酸について</h2>\n<p>当社は、昭和23年に設立、圧縮酸素ガス製造を開始いたしました。創業以来、各種ガスや医療用酸素の製造・販売、石油製品の販売など事業を広げながら、青森市を中心に、県下にサービス拠点を設け地域に密着した事業を展開してまいりました。その間、お客様は勿論のこと、お取引先各位のご指導、ご支援を得て、今日の営業基盤を確立しております。</p>\n<p>現在では、酸素、窒素、アルゴンなどの各種工業ガスは、鉄鋼、自動車、化学、機械金属、半導体など、さまざまな産業分野で幅広くご利用いただいています。</p>\n<p>今では各種高圧ガスはなくてはならないものであり、私たちはこれらのガスをより安全に、安定して供給しています。</p>\n<p>今後、ますます高度化、多様化するニーズに応えお客様に満足していただける行き届いたサービスを提供してゆきたいと考えております。</p>\n<p>私たち東酸は、これからも社会から信頼される企業を目指して、さらに努力を重ねてまいります。今後とも一層のご支援、ご指導のほど、よろしくお願い申し上げます。</p>\n<p style=\"text-align: right;\">代表取締役社長<br />\n葛西信二</p>\n<h2>経営理念・方針</h2>\n<h3>経営理念</h3>\n<p>「社員一人一人が創意・工夫・努力し、生産性の向上を図り、企業として存続しつづけ、事業を通じて社会に貢献できる企業となること。又、社会から信用、信頼される企業であり続けること」</p>\n<h3>方針</h3>\n<p>「経営理念に基づき、社内規則及び法令の遵守を徹底し、企業人としての責任と誇りを持って社業発展に寄与するように努めなければならない」</p>\n<ol>\n<li>社内規則、法令に即した規律、責任ある行動、言動。</li>\n<li>法令に即した適正な営業取引の実施。</li>\n<li>社内の不正行為の排除。</li>\n<li>情報の共有、開示。</li>\n<li>個人情報の保護の徹底。</li>\n</ol>\n<h4>会社概要</h4>\n<table>\n<tbody>\n<tr>\n<th>商号</th>\n<td>株式会社 東酸</td>\n</tr>\n<tr>\n<th>資本金</th>\n<td>7,500万円</td>\n</tr>\n<tr>\n<th>設立</th>\n<td>昭和23年1月6日</td>\n</tr>\n<tr>\n<th>本社所在地</th>\n<td>〒030-0921 青森市原別5丁目11番56号<br />\nTEL：017-736-2125　FAX：017-736-2194</td>\n</tr>\n<tr>\n<th>従業員</th>\n<td>113名（2025年6月15日現在）</td>\n</tr>\n</tbody>\n</table>\n<h2>役員</h2>\n<table class=\"tablestyletype001\">\n<tbody>\n<tr>\n<th>代表取締役社長</th>\n<td>葛西 信二</td>\n</tr>\n<tr>\n<th>常務取締役　営業本部長</th>\n<td>桑田 亮</td>\n</tr>\n<tr>\n<th>常務取締役　管理本部長</th>\n<td>北村 節夫</td>\n</tr>\n<tr>\n<th>取締役　三八地区担当部長</th>\n<td>小野 隆之</td>\n</tr>\n<tr>\n<th>取締役　総務部長</th>\n<td>室谷 富幸</td>\n</tr>\n<tr>\n<th>取締役　機械営業部長</th>\n<td>白鳥 徹哉</td>\n</tr>\n<tr>\n<th>取締役</th>\n<td>堀内 秀敏</td>\n</tr>\n<tr>\n<th>監査役</th>\n<td>木村 克也</td>\n</tr>\n<tr>\n<th>監査役</th>\n<td>高橋 雄一</td>\n</tr>\n<tr>\n<th>監査役</th>\n<td>小泉 健</td>\n</tr>\n</tbody>\n</table>\n<h2>事業案内</h2>\n<ul>\n<li>酸素ガスの製造及び販売</li>\n<li>各種ガスの製造及び販売</li>\n<li>医療用酸素ガスの製造及び販売</li>\n<li>石油製品の販売</li>\n<li>計量器の販売</li>\n<li>不動産の売買、賃貸、仲介及び土地の造成、造園、建築工事の施工ならびに建築関係機器資材の販売</li>\n<li>貴金属、宝石及び装飾品の仕入販売</li>\n<li>化学薬品ならびに食品添加物の製造及び販売</li>\n<li>衣料並びに布地等の仕入販売</li>\n<li>食品類の仕入販売</li>\n<li>熔接・切断器具、熔接材料、カーバイトの仕入販売</li>\n<li>電熔機械、その他電気器具、工具、機械等の仕入販売</li>\n<li>医薬品、医療用器具機械、医療用ガス供給装置の仕入販売、医療用配管工事の施工</li>\n<li>高圧ガス容器の仕入販売</li>\n<li>建設機器、各種プレス機械、資材等の仕入販売</li>\n<li>中古機械及び工具の仕入販売</li>\n<li>厨房、給湯、冷暖房機器、その他住宅設備機器の仕入販売</li>\n<li>管工事、電気工事、機械器具設置工事の施工</li>\n<li>古物営業法施行規則による機械工具類及び時計・宝飾品類の仕入販売</li>\n<li>前各号に関連する一切の事業</li>\n</ul>\n<h2 class=\"commonButton companyButtonHistoryTitle\"><a href=\"https://www.kk-tosan.co.jp/company/history/\">株式会社東酸 沿革</a></h2>\n<h2 class=\"commonButton companyButtonCsrTitle\"><a href=\"https://www.kk-tosan.co.jp/company/csr/\">株式会社東酸 CSR憲章</a></h2>\n</div><!-- .entryContent .clearfix -->\n\n\n</article><!-- / #post-10 -->\n\n\n\n</div><!-- / .mainArticleCol1 -->\n</div><!-- / .col-sm-12 -->\n\n\n\n\n\n\r\n\r\n</div><!-- / .row -->\r\n\r\n\r\n</div><!-- / .container -->\r\n\r\n\r\n\r\n\r\n\r\n<footer>\r\n<div class=\"footContentOuterContainer\">\r\n<div class=\"container footContentInnerContainer\">\r\n\r\n\r\n<div class=\"row row-colpad80 footContent sameHeightParent768\">\r\n\r\n<div class=\"col-sm-12\">\r\n<p class=\"gotoPageTop textright\"><a href=\"#top\" title=\"このページの先頭に戻る\"><img src=\"https://www.kk-tosan.co.jp/wp/wp-content/themes/kktosan/img/common/gotopagetop.png\" alt=\"↑\" /></a></p>\r\n</div><!-- / .col-sm-12 -->\r\n\r\n\r\n\r\n\r\n<div class=\"col-sm-4 sameHeightChild768\">\r\n<div class=\"footCompanyInfo\">\r\n<h2>株式会社東酸</h2>\r\n<dl class=\"footCompanyAddress\">\r\n<dt>本社</dt>\r\n<dd>青森県青森市原別5-11-56</dd>\r\n</dl>\r\n<table class=\"footCompanyTel\">\r\n<tr>\r\n<th rowspan=\"2\">TEL</th>\r\n<td>017-736-2125（代表）</td>\r\n</tr>\r\n<tr>\r\n<td>017-736-2121（代表）</td>\r\n</tr>\r\n</table>\r\n<p class=\"footCompanyImg\"><img src=\"https://www.kk-tosan.co.jp/wp/wp-content/themes/kktosan/img/common/aomori_ext1b.jpg\" alt=\"株式会社東酸 本社社屋\" /></p>\r\n</div><!-- / .footCompanyInfo -->\r\n</div><!-- / .col-sm-4 -->\r\n\r\n<div class=\"col-sm-5 sameHeightChild768\">\r\n<div class=\"footCompanyGmap\">\r\n<iframe src=\"https://www.google.com/maps/embed