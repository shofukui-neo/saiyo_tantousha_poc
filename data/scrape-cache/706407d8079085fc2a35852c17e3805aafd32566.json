       </div>\n          <div id=\"navigation\">\n            <div class=\"navBtn\"><span></span></div>\n            <div class=\"in\">\n              <div class=\"navlogo\">\n                <a href=\"./\"\n                  ><img src=\"./assets/images/common/nav_logo.png\" alt=\"\"\n                /></a>\n              </div>\n              <div class=\"link_area\">\n                <div class=\"flex\">\n                  <ul class=\"link01\">\n                    <li><a href=\"./\">TOP</a></li>\n                    <li><a href=\"./jobs/\">Def tribeの魅力</a></li>\n                    <li><a href=\"./idealcandidate/\">求める人材・部署</a></li>\n                    <li><a href=\"./welfare/\">福利厚生・研修制度</a></li>\n                  </ul>\n                  <ul class=\"link02\">\n                    <li><a href=\"../\">コーポレートサイトトップ</a></li>\n                    <li><a href=\"../company.html\">企業情報</a></li>\n                    <li><a href=\"../contact/\">お問い合わせ</a></li>\n                    <li>\n                      <a href=\"../privacy-policy.html\">プライバシーポリシー</a>\n                    </li>\n                    <li>\n                      <a href=\"../security.html\">情報セキュリティポリシー</a>\n                    </li>\n                  </ul>\n                </div>\n              </div>\n              <div class=\"collabo\">\n                <a href=\"./welfare/#techgym\"\n                  ><img src=\"./assets/images/common/nav_collabo.png\" alt=\"\"\n                /></a>\n              </div>\n              <!-- <ul class=\"icon\">\n                            <li>\n                                <a href=\"https://www.facebook.com/profile.php?id=100070377188634\" target=\"_blank\"><img class=\"svg\" src=\"./assets/img/common/icon_fb.svg\" alt=\"\"></a>\n                            </li>\n                            <li>\n                                <a href=\"https://twitter.com/deftribe0315\" target=\"_blank\"><img class=\"svg\" src=\"./assets/images/icon/icon_tw.svg\" alt=\"\"></a>\n                            </li>\n                            <li>\n                                <a href=\"https://www.instagram.com/deftribe0315/\" target=\"_blank\"><img class=\"svg\" src=\"./assets/images/icon/icon_inst.svg\" alt=\"\"></a>\n                            </li>\n                        </ul> -->\n            </div>\n          </div>\n          <div class=\"btnbox\">\n            <div class=\"navBtn\"><span></span></div>\n            <div class=\"entrybtn pc\">\n              <a\n                href=\"https://en-gage.net/e-deftribe_saiyopage/\"\n                target=\"_blank\"\n                ><span class=\"en\">ENTRY<small>&amp;</small></span\n                ><span class=\"txt\"\n                  >現在の募集情報\n                  <div class=\"icon\">\n                    <img\n                      class=\"svg\"\n                      src=\"./assets/images/icon/icon_blank.svg\"\n                      alt=\"\"\n                    /></div></span\n              ></a>\n            </div>\n          </div>\n        </div>\n      </header>\n      <main id=\"main\">\n        <div id=\"mainvisual\">\n          <div class=\"inner\">\n            <div class=\"textbox\">\n              <h1 class=\"title\">\n                <span class=\"ttl\"\n                  ><img\n                    class=\"svg\"\n                    src=\"./assets/images/top/visual_title.svg\"\n                    alt=\"\"\n                /></span>\n              </h1>\n              <p class=\"text\">手は口ほどに<br class=\"pc\" />モノを言う</p>\n            </div>\n            <div class=\"hand hand01\">\n              <img src=\"./assets/images/top/visual_hand01.png\" alt=\"\" />\n            </div>\n            <div class=\"hand hand02\">\n              <img src=\"./assets/images/top/visual_hand02.png\" alt=\"\" />\n            </div>\n            <div class=\"hand hand03\">\n              <img\n                class=\"pc\"\n                src=\"./assets/images/top/visual_hand03.png\"\n                alt=\"\"\n              /><img\n                class=\"sp\"\n                src=\"./assets/images/top/visual_hand03_sp.png\"\n                alt=\"\"\n              />\n            </div>\n            <div class=\"hand hand04\">\n              <img\n                class=\"pc\"\n                src=\"./assets/images/top/visual_hand04.png\"\n                alt=\"\"\n              /><img\n                class=\"sp\"\n                src=\"./assets/images/top/visual_hand04_sp.png\"\n                alt=\"\"\n              />\n            </div>\n          </div>\n        </div>\n        <div class=\"top\" id=\"contents\">\n          <div class=\"bodyline\"></div>\n          <div class=\"in\">\n            <section id=\"top_outline\">\n              <div class=\"inner\">\n                <div class=\"titlearea\">\n                  <div class=\"title\">\n                    <img\n                      class=\"svg\"\n                      src=\"./assets/images/top/outline.svg\"\n                      alt=\"\"\n                    />\n                  </div>\n                  <p class=\"sub\">ZOKUZOKU</p>\n                </div>\n                <div class=\"textbox\">\n                  <p class=\"midashi01 center\">属して属さない働き方を一緒に</p>\n                  <div class=\"textarea\">\n                    <p>\n                      Def\n                      tribeにいろいろな人がいる理由。それは、「◯◯な人がいい！」などの決まりや縛りがない<strong>柔軟な考えを持ったIT企業</strong>だから。「やる気」があれば、会社も社会も変えることができる場所で、<strong\n                        >自分らしい働き方、見つけませんか？</strong\n                      >\n                    </p>\n                  </div>\n                </div>\n                <div class=\"collabo_box\">\n                  <div class=\"collabo_top\">\n                    <h2 class=\"ttl\">\n                      <img\n                        src=\"./assets/images/common/ttl_collabo_black.png\"\n                        srcset=\"\n                          ./assets/images/common/ttl_collabo_black.png    1x,\n                          ./assets/images/common/ttl_collabo_black@2x.png 2x\n                        \"\n                        alt=\"NEW Collaboration\"\n                      />\n                    </h2>\n                  </div>\n                  <div class=\"collabo_body\">\n                    <div class=\"img\">\n                      <img\n                        src=\"./assets/images/common/collabo_img01.png\"\n                        srcset=\"\n                          ./assets/images/common/collabo_img01.png    1x,\n                          ./assets/images/common/collabo_img01@2x.png 2x\n                        \"\n                        alt=\"IT企業 Def tribe プログラミング塾 techgym 梅田港\"\n                      />\n                    </div>\n                    <p>\n                      <strong\n                        >エンジニアのスキルアップを支える<br />画期的業務提携がスタート！</strong\n                      >\n                    </p>\n                  </div>\n                  <div class=\"collabo_bottom\">\n                    <div class=\"btnArea\">\n                      <a class=\"arrowbtn\" href=\"./welfare/#techgym\"\n                        >詳しく見る</a\n                      >\n                    </div>\n                  </div>\n                </div>\n              </div>\n            </section>\n            <section class=\"top_column\" id=\"new_challenge\">\n              <div class=\"inner\">\n                <div class=\"collayout\">\n                  <div class=\"textbox\">\n                    <h2 class=\"midashi02\">新しいことに挑む<br />新しい企業</h2>\n                    <div class=\"textarea\">\n                      <p>\n                        給料・労働時間・休日。Def\n                        tribeは、どれをとっても<strong>「条件がいい」会社です。</strong>遊びも大切にするスタイルだから、仲間との絆も深く、<strong\n                          >働きやすさは抜群です。</strong\n                        >\n                      </p>\n                    </div>\n                    <div class=\"btnArea\">\n                      <a class=\"arrowbtn\" href=\"./jobs/\">Def tribeの魅力</a>\n                    </div>\n                  </div>\n                  <div class=\"imgarea\">\n                    <div class=\"hand\">\n                      <img src=\"./assets/images/top/column01_hand.png\" alt=\"\" />\n                    </div>\n                    <div class=\"text\">\n                      <p class=\"txt\">NEW<span>Challenge</span></p>\n                    </div>\n                  </div>\n                </div>\n              </div>\n            </section>\n            <section class=\"top_column\" id=\"ten_character\">\n              <div class=\"inner\">\n                <div class=\"collayout reverse\">\n                  <div class=\"textbox\">\n                    <h2 class=\"midashi02\">十人十色が<br />武器になる</h2>\n                    <div class=\"textarea\">\n                      <p>\n                        部署は「ITソリューション部」「管理＋企画部」「営業部」の3つ。それぞれの武器を生かして、一人ひとりが能力を伸ばし、<strong\n                          >もっと面白い会社を一緒に創りましょう。</strong\n                        >\n                      </p>\n                    </div>\n                    <div class=\"btnArea\">\n                      <a class=\"arrowbtn\" href=\"./idealcandidate/\"\n                        >求める人材・部署</a\n                      >\n                    </div>\n                  </div>\n                  <div class=\"imgarea\">\n                    <div class=\"hand\">\n                      <img src=\"./assets/images/top/column02_hand.png\" alt=\"\" />\n                    </div>\n                    <div class=\"text number\">\n                      <p class=\"num\">10</p>\n                      <p class=\"sub\">Character</p>\n                    </div>\n                  </div>\n                </div>\n              </div>\n            </section>\n            <section class=\"top_column\" id=\"team_positive\">\n              <div class=\"inner\">\n                <div class=\"collayout\">\n                  <div class=\"textbox\">\n                    <h2 class=\"midashi02\">個人戦にみえて<br />実は団体戦</h2>\n                    <div class=\"textarea\">\n                      <p>\n                        社風はとてもカジュアルでフランク。<strong>「やりたいこと」が言えて、それを実現できる前向きな企業</strong>である秘訣は、スタッフの団結力にあります。\n                      </p>\n                    </div>\n                    <!-- <div class=\"btnArea\"><a class=\"arrowbtn\" href=\"./staffvoice/\">スタッフの声</a></div> -->\n                  </div>\n                  <div class=\"imgarea\">\n                    <div class=\"hand\">\n                      <img src=\"./assets/images/top/column03_hand.png\" alt=\"\" />\n                    </div>\n                    <div class=\"text\">\n                      <p class=\"txt left\">TEAM<span>Positive</span></p>\n                    </div>\n                  </div>\n                </div>\n              </div>\n            </section>\n            <section class=\"top_column\" id=\"progress_evolution\">\n              <div class=\"inner\">\n                <div class=\"collayout reverse\">\n                  <div class=\"textbox\">\n                    <h2 class=\"midashi02\">進化しているから<br />進歩できる</h2>\n                    <div class=\"textarea\">\n                      <p>\n                        スーツ・ビジネス用品手当、引越し補助金、介護負担金支援制度など、オリジナリティあふれる福利厚生は、<strong\n                          >「あったら嬉しい」を今後もカタチにする予定です。</strong\n                        >\n                      </p>\n                    </div>\n                    <div class=\"btnArea\">\n                      <a class=\"arrowbtn\" href=\"./welfare/\"\n                        >福利厚生・研修制度</a\n                      >\n                    </div>\n                  </div>\n                  <div class=\"imgarea\">\n                    <div class=\"hand\">\n                      <img src=\"./assets/images/top/column04_hand.png\" alt=\"\" />\n                    </div>\n                    <div class=\"text type2\">\n                      <p class=\"txt\">PROG</p>\n                      <p class=\"txt\">RESS</p>\n                      <p class=\"top\">Evolution</p>\n                    </div>\n                  </div>\n                </div>\n              </div>\n            </section>\n          </div>\n        </div>\n      </main>\n      <div id=\"entryblock\">\n        <div class=\"inner\">\n          <div class=\"title_area\">\n            <p class=\"en\">ENTRY</p>\n            <h2 class=\"title\">\n              【現在の募集情報】と<br class=\"sp\" />【採用エントリー】はこちら\n            </h2>\n          </div>\n          <div class=\"btnArea\">\n            <a\n              class=\"btnStyle01\"\n              href=\"https://en-gage.net/e-deftribe_saiyopage/\"\n              target=\"_blank\"\n              ><span\n                >採用エントリー／現在の募集情報\n                <div class=\"icon\">\n                  <img\n                    class=\"svg\"\n                    src=\"./assets/images/icon/icon_blank.svg\"\n                    alt=\"\"\n                  /></div></span\n            ></a>\n          </div>\n        </div>\n      </div>\n      <footer id=\"footer\">\n        <div class=\"inner\">\n          <div class=\"ftarea\">\n            <div class=\"in\">\n              <div class=\"linkarea\">\n                <h2 class=\"ftlogo\">\n                  <a href=\"./\"\n                    ><img src=\"./assets/images/common/ft_logo.png\" alt=\"\"\n                  /></a>\n                </h2>\n                <ul>\n                  <li><a href=\"./\">TOP</a></li>\n                  <li><a href=\"./jobs/\">Def tribeの魅力</a></li>\n                  <li><a href=\"./idealcandidate/\">求める人材・部署</a></li>\n                  <li><a href=\"./welfare/\">福利厚生・研修制度</a></li>\n                  <li><a href=\"./welfare/#techgym\">Def tribe×techgym</a></li>\n                </ul>\n              </div>\n              <div class=\"iconarea\">\n                <ul class=\"icon01\">\n                  <li class=\"pj\">\n                    <a href=\"http://www.pjr.jp/\" target=\"_blank\"\n                      ><img src=\"./assets/images/icon/icon_pj.png\" alt=\"\"\n                    /></a>\n                  </li>\n                  <li class=\"isms\">\n                    <a href=\"https://isms.jp/\" target=\"_blank\"\n                      ><img src=\"./assets/images/icon/icon_isms.png\" alt=\"\"\n                    /></a>\n                  </li>\n                </ul>\n                <!-- <ul class=\"icon02\">\n                                <li>\n                                    <a href=\"https://www.facebook.com/profile.php?id=100070377188634\" target=\"_blank\"><img class=\"svg\" src=\"./assets/img/common/icon_fb.svg\" alt=\"\"></a>\n                                </li>\n                                <li>\n                                    <a href=\"https://twitter.com/def_tribe\" target=\"_blank\"><img class=\"svg\" src=\"./assets/images/icon/icon_tw.svg\" alt=\"\"></a>\n                                </li>\n                                <li>\n                                    <a href=\"https://www.instagram.com/deftribe0315/\" target=\"_blank\"><img class=\"svg\" src=\"./assets/images/icon/icon_inst.svg\" alt=\"\"></a>\n                                </li>\n                            </ul> -->\n              </div>\n            </div>\n          </div>\n          <div class=\"ftbottom\">\n            <div class=\"in\">\n              <div class=\"linkarea\">\n                <h3 class=\"name\"><a href=\"../\">株式会社Def tribe</a></h3>\n                <ul>\n                  <li><a href=\"../company.html\">企業情報</a></li>\n                  <li><a href=\"../contact/\">お問い合わせ</a></li>\n                  <li>\n                    <a href=\"../privacy-policy.html\">プライバシーポリシー</a>\n                  </li>\n                  <li>\n                    <a href=\"../security.html\">情報セキュリティポリシー</a>\n                  </li>\n                </ul>\n              </div>\n              <p class=\"copyright\"