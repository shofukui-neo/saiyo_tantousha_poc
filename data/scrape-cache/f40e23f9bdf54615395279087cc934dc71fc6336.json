-arrow\"></use>\n                            </svg>\n                          </a>\n                        </li>\n                        <li class=\"item\">\n                          <a href=\"/recruit/welfare#care\">\n                            <span class=\"txt\">育児・介護に関わる<span class=\"ib\">制度</span></span>\n                            <svg class=\"arrow\">\n                              <use xlink:href=\"/recruit/img/svg/sprite-symbol.svg#icon-arrow\"></use>\n                            </svg>\n                          </a>\n                        </li>\n                        <li class=\"item\">\n                          <a href=\"/recruit/welfare#relo\">\n                            <span class=\"txt\">リロクラブ</span>\n                            <svg class=\"arrow\">\n                              <use xlink:href=\"/recruit/img/svg/sprite-symbol.svg#icon-arrow\"></use>\n                            </svg>\n                          </a>\n                        </li>\n                      </ul>\n                    </div>\n                  </div>\n                </div>\n              </div>\n              <!-- Top, Faq, Corporate -->\n              <div class=\"wrap no-flex max-1399\">\n                <a href=\"/recruit/\" class=\"c-title01 c-title01__left pc\">\n                  <span class=\"en\">Top</span>\n                  <span class=\"ja\">採用トップ</span>\n                  <svg class=\"arrow sp\">\n                    <use xlink:href=\"/recruit/img/svg/sprite-symbol.svg#icon-arrow\"></use>\n                  </svg>\n                </a>\n                <a href=\"/recruit/faq/\" class=\"c-title01 c-title01__left\">\n                  <span class=\"en\">Faq</span>\n                  <span class=\"ja\">よくあるご質問</span>\n                  <svg class=\"arrow sp\">\n                    <use xlink:href=\"/recruit/img/svg/sprite-symbol.svg#icon-arrow\"></use>\n                  </svg>\n                </a>\n                <a href=\"/\" class=\"link link__blank\">-コーポレートサイトトップへ</a>\n              </div>\n            </nav>\n          </div>\n\n          <div class=\"pick-wrap\">\n            <a href=\"/recruit/application/\" class=\"btn btn__type01\">\n              <div class=\"c-title01 c-title01__left c-title01__revers\">\n                <span class=\"en\">Application</span>\n                <span class=\"ja\">募集要項</span>\n              </div>\n              <div class=\"c-btn_arrow02\">\n                <svg class=\"arrow\">\n                  <use xlink:href=\"/recruit/img/svg/sprite-symbol.svg#icon-arrow\"></use>\n                </svg>\n              </div>\n            </a>\n            <a href=\"/recruit/entry/\" class=\"btn btn__type01\">\n              <div class=\"c-title01 c-title01__left c-title01__revers\">\n                <span class=\"en\">Entry</span>\n                <span class=\"ja\">エントリー</span>\n              </div>\n              <div class=\"c-btn_arrow02\">\n                <svg class=\"arrow\">\n                  <use xlink:href=\"/recruit/img/svg/sprite-symbol.svg#icon-arrow\"></use>\n                </svg>\n              </div>\n            </a>\n            <a href=\"/recruit/movie/\" class=\"btn btn__type02 movie\">\n              <div class=\"c-title01 c-title01__revers\">\n                <span class=\"en\">Special Movie</span>\n                <span class=\"ja\">スペシャルムービー</span>\n              </div>\n            </a>\n            <a href=\"/recruit/product/\" class=\"btn btn__type02 scene\">\n              <div class=\"c-title01 c-title01__revers\">\n                <span class=\"en\">Scene of Use</span>\n                <span class=\"ja\">暮らしの中の大鐵</span>\n              </div>\n            </a>\n          </div>\n        </div>\n      </header>\n<main class=\"page_top\">\n  <section class=\"main-block\">\n    <div class=\"inner\">\n      <div class=\"txt-wrap\">\n        <h1 class=\"main-copy\">\n          <img src=\"/recruit/img/top/logo-main.svg\" alt=\"Open Up the Future 未来を切り拓け We may work in different places and at different times, but even though we are separated, we are connected by the same feelings.\" class=\"type_pc\">\n          <img src=\"/recruit/img/top/sp/logo-main.svg\" alt=\"Open Up the Future 未来を切り拓け We may work in different places and at different times, but even though we are separated, we are connected by the same feelings.\" class=\"type_sp\">\n        </h1>\n      </div>\n    </div>\n    <div class=\"inner mask-wrapper\" data-image=''>\n      <div class=\"txt-wrap\">\n        <div class=\"main-copy\">\n          <img src=\"/recruit/img/top/logo-main_white.svg\" alt=\"\" class=\"type_pc\">\n          <img src=\"/recruit/img/top/sp/logo-main_white.svg\" alt=\"\" class=\"type_sp\">\n        </div>\n      </div>\n    </div>\n\n    <div class=\"movie-wrap\">\n      <a href=\"/recruit/movie/\"><img src=\"/recruit/img/top/img-movie.jpg\" alt=\"OSAKA STEEL CO.,LTD. CONCEPT FOR RECRUIT 未来を切り拓け OPEN UP THE FUTURE\"></a>\n    </div>\n\n    <!-- splide(PC) -->\n    <div class=\"splide\" id=\"splide_pc\" role=\"group\" aria-label=\"MV_Splide_PC\">\n      <div class=\"splide__track\">\n        <ul class=\"splide__list\">\n          <li class=\"splide__slide\">\n            <img src=\"/recruit/img/top/img-mv01_1.webp\" alt=\"\">\n            <img src=\"/recruit/img/top/img-mv01_2.webp\" alt=\"\">\n          </li>\n          <li class=\"splide__slide\">\n            <img src=\"/recruit/img/top/img-mv02_1.webp\" alt=\"\">\n            <img src=\"/recruit/img/top/img-mv02_2.webp\" alt=\"\">\n          </li>\n          <li class=\"splide__slide\">\n            <img src=\"/recruit/img/top/img-mv03_1.webp\" alt=\"\">\n            <img src=\"/recruit/img/top/img-mv03_2.webp\" alt=\"\">\n          </li>\n          <li class=\"splide__slide\">\n            <img src=\"/recruit/img/top/img-mv04_1.webp\" alt=\"\">\n            <img src=\"/recruit/img/top/img-mv04_2.webp\" alt=\"\">\n          </li>\n        </ul>\n      </div>\n    </div>\n\n    <!-- splide(SP, Tab) -->\n    <div class=\"splide\" id=\"splide_sp\" role=\"group\" aria-label=\"MV_Splide_SP\">\n      <div class=\"splide__track\">\n        <ul class=\"splide__list\">\n          <li class=\"splide__slide\">\n            <img src=\"/recruit/img/top/sp/img-mv01_1.webp\" alt=\"\">\n            <img src=\"/recruit/img/top/sp/img-mv01_2.webp\" alt=\"\">\n          </li>\n          <li class=\"splide__slide\">\n            <img src=\"/recruit/img/top/sp/img-mv02_1.webp\" alt=\"\">\n            <img src=\"/recruit/img/top/sp/img-mv02_2.webp\" alt=\"\">\n          </li>\n          <li class=\"splide__slide\">\n            <img src=\"/recruit/img/top/sp/img-mv03_1.webp\" alt=\"\">\n            <img src=\"/recruit/img/top/sp/img-mv03_2.webp\" alt=\"\">\n          </li>\n          <li class=\"splide__slide\">\n            <img src=\"/recruit/img/top/sp/img-mv04_1.webp\" alt=\"\">\n            <img src=\"/recruit/img/top/sp/img-mv04_2.webp\" alt=\"\">\n          </li>\n        </ul>\n      </div>\n    </div>\n  </section>\n\n\n  <section class=\"intro\">\n    <div class=\"inner\">\n      <div class=\"intro__txt\">\n        <h2 class=\"c-title02\">\n          <span class=\"en\">Introduction</span>\n          <span class=\"ja\">これから実現したいこと<span class=\"ib\">その舞台として</span><span class=\"ib\">大阪製鐵を選んでほしい</span></span>\n        </h2>\n        <p class=\"txt\">\n          「これまでの経験」を踏まえ、<span class=\"ib\">「これからの自分」を想像してみてください。</span><br>さて、将来は何がしたいですか？<span class=\"ib\">どうしたらそれが実現できるでしょうか？</span><br>\n          企業選びは、世間のイメージ以上に<br>\n          「この企業であれば自分自身が成長できる。<span class=\"ib\">そして、やりたいことが実現できる！」</span><br>\n          そう感じられるかどうかが重要だと思います。<br>\n          たくさんの企業をみて、人に会い、考えた結果として<br>\n          大阪製鐵を選んでいただけるのなら、<span class=\"ib\">これほど嬉しいことはありません。</span>\n        </p>\n      </div>\n      <div class=\"intro__img\"><img src=\"/recruit/img/top/img-message.webp\" alt=\"\"></div>\n    </div>\n  </section>\n\n  <div class=\"gsap_target gsap_target_img\">\n    <div cl