      </div>\n                    </div>\n                    <!--fot-bnr-inner-->\n                </a>\n                <div class=\"btn\"><a href=\"/career\">\n                        <div class=\"btn01 btn-navy2 hvr-forward\">MORE<span class=\"triangle01\"></span></div>\n                    </a></div>\n\n            </div>\n        </div>\n        <!--fot-bnr-org-->\n    </div>\n</div><!--fot-bnr-->\n\n    \n    \n  \n<!--  \n  <div class=\"fot-bnr2\">\n    <a href=\"https://job.rikunabi.com/2020/company/r704800073/\" target=\"_blank\"><h4>INTERNSHIP　<span>インターンはコチラ</span></h4></a>\n  </div>\n-->\n\n<script type=\"text/javascript\">\n  setTimeout(function() {\nityped.init(document.querySelector(\"#ityped\"), {\n      loop: false,\n      showCursor: false,\n    showCursor: true,\n    cursorChar: \"_\",\n      strings: [\"TELEWORK\"]\n    })\n    }, 2000);\n</script>\n\n\n\n\n\n<footer id=\"footer\">\n  <div class=\"footer-hed\">\n      <h5 class=\"fot-logo\"><a href=\"https://www.cds-japan.jp/ja/recruit/\"><img src=\"https://www.cds-japan.jp/_wp/wp-content/themes/cds/img/common/fot-logo.png\" width=\"235\" height=\"78\" alt=\"cds\"></a></h5>\n      \n      <p class=\"footer-top\"><a href=\"/recruit\">採用トップに戻る</a></p>\n      <div class=\"btn\"><a href=\"/entry\"><div class=\"btn01 btn-red2\">　ENTRY　</div></a></div>\n      <div class=\"btn btn02\"><a href=\"https://www.cds-japan.jp/ja/recruit_contact/\" target=\"_blank\"><div class=\"btn01 btn-org\">お問い合わせ</div></a></div>\n      \n      <table id=\"gf-table\" class=\"hidden-xs hidden-sm hidden-md\">\n        <tr>\n          <th>CDSについて</th>\n          <th>募集要項</th>\n          <th><a href=\"/work\">仕事紹介</a></th>\n          <th><a href=\"/entry\">エントリー</a></th>\n          </tr>\n        <tr>\n          <td><a href=\"/message\">トップメッセージ</a></td>\n          <td><a href=\"/newgraduate\">新卒採用</a></td>\n          <td><a href=\"/work/job-category\">職種紹介</a></td>\n          <td class=\"link-icon\"><a href=\"https://www.cds-