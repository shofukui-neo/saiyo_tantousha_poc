{"url":"https://www.kinon.co.jp/recruit/interview-03.shtml","html":"<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\">\n<meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width\" />\n<meta name=\"format-detection\" content=\"telephone=no\">\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/common.css\" />\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/zone.css\" />\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/bpts.css\" />\n<!-- Basic parts -->\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/unit.css\" />\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/col.css\" />\n<!-- 本文領域レイアウタ -->\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/other.css\" />\n<!-- インタビュー用CSS -->\n<link rel=\"stylesheet\" type=\"text/css\" href=\"css/interview.css\" />\n<title>システムエンジニア│社員の声│Recruit│キノンビクス株式会社</title>\n<style>\n.interview_fv {\n\tbackground-image: url(\"image/interview-03-00.jpg\");\n\tcolor: #fff;\n}\n#zone_substage h1 {\n\tfont-size: clamp(2.563rem, 0.767rem + 8.98vw, 7.5rem);\n\theight: auto;\n\tdisplay: block;\n\tpadding: 0;\n\tline-height: 1.5;\n\tfont-weight: normal;\n\tmargin: 1em 0 0 .5em;\n}\n</style>\n<!-- スクリプトのインクルード（事前呼び出し） --> \n<meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\" />\n<link rel=\"icon\" href=\"../favicon.ico\">\n\n<!-- fontawesome -->\n<link href=\"https://use.fontawesome.com/releases/v5.6.1/css/all.css\" rel=\"stylesheet\">\n\n\n</head>\n<body>\n<div id=\"zone_sheet\"> \n  <!-- ヘッダーのインクルード --> \n  <meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\" />\n<!--\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/css/other.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/css/bpts.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/css/common.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/css/zone.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/css/unit.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/css/col.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/css/other.css\"/>\n -->\n<div class=\"header_bg\">\n<div class=\"header_logo\"><a href=\"../../\"><img src=\"../image/common/logo.svg\"></a></div>\n<nav class=\"pc_menu\">\n  <div class=\"o_mainmenu\">\n    <ul>\n      <li><a href=\"../about/\">About us</a>\n        <ul>\n          <li><a href=\"/about/index.shtml\">代表挨拶</a></li>\n          <li><a href=\"/about/overview.shtml\">会社概要</a></li>\n          <li><a href=\"/about/philosophy.shtml\">経営理念</a></li>\n          <li><a href=\"/about/promises.shtml\">7つのお約束</a></li>\n          <li><a href=\"/about/history.shtml\">沿革</a></li>\n          <li><a href=\"/about/employee.shtml\">社員保有資格一覧</a></li>\n          <li><a href=\"/about/certifications.shtml\">各種認定と宣言</a></li>\n        </ul>\n      </li>\n      <li><a href=\"../culture/\">Culture</a></li>\n      <li><a href=\"../solution/\">Solution</a>\n        <ul>\n          <li><a href=\"../solution/index.shtml#jump_01\">システムソリューション</a></li>\n          <li><a href=\"../solution/index.shtml#s_index_section02\">場所から探す</a></a></li>\n          <li><a href=\"../solution/index.shtml#s_index_section03\">納入事例</a></a></li>\n        </ul>\n      </li>\n      <li><a href=\"../recruit/\">Recruit</a>\n        <ul>\n          <li><a href=\"/recruit/\">採用情報</a></li>\n          <li><a href=\"/recruit/job.shtml\">職種紹介</a></li>\n          <li><a href=\"/recruit/interview.shtml\">社員インタビュー</a></li>\n          <li><a href=\"/recruit/requirements.shtml\">募集要項</a></li>\n        </ul>\n      </li>\n      <li><a href=\"../misc/contact.shtml\">Contact</a></li>\n    </ul>\n  </div>\n</nav>\n</div>\n<!-- レスポンシブメニュー　 -->\n<header>\n<div class=\"header-logo-menu\">\n<div id=\"nav-drawer\">\n<input id=\"nav-input\" type=\"checkbox\" class=\"nav-unshown\">\n<label id=\"nav-open\" for=\"nav-input\">\n<span></span>\n<p class=\"label_txt_menu\">MENU</p>\n</label>\n<label class=\"nav-unshown\" id=\"nav-close\" for=\"nav-input\"></label>\n<div id=\"nav-content\">\n<!--  ----------------- -->\n<div class=\"accordion\"> \n  <!-- menu1 -->\n  <div class=\"option\">\n    <input type=\"checkbox\" id=\"toggle1\" class=\"toggle\">\n    <label class=\"title item10\" for=\"toggle1\">About us</label>\n    <div class=\"content\">\n      <ul>\n        <li class=\"f_m10_10\"><a href=\"/about/index.shtml\">代表挨拶</a></li>\n        <li class=\"f_m10_20\"><a href=\"/about/overview.shtml\">会社概要</a></li>\n        <li class=\"f_m10_30\"><a href=\"/about/philosophy.shtml\">経営理念</a></li>\n        <li class=\"f_m10_40\"><a href=\"/about/promises.shtml\">7つのお約束</a></li>\n        <li class=\"f_m10_50\"><a href=\"/about/history.shtml\">沿革</a></li>\n        <li class=\"f_m10_60\"><a href=\"/about/employee.shtml\">社員保有資格一覧</a></li>\n        <li class=\"f_m10_70\"><a href=\"/about/certifications.shtml\">各種認定と宣言</a></li>\n      </ul>\n    </div>\n  </div>\n  <!-- menu2 -->\n  <div class=\"option\">\n    <div class=\"one_link\"><a href=\"../culture/\">Culture</a></div>\n  </div>\n  <!-- menu3 -->\n  <div class=\"option\">\n    <input type=\"checkbox\" id=\"toggle3\" class=\"toggle\">\n    <label class=\"title item50\" for=\"toggle3\">Solution</label>\n    <div class=\"content\">\n      <ul>\n        <li class=\"f_m30_10\"><a href=\"../solution/index.shtml#sp_jump_01\">システムソリューション</a></li>\n        <li class=\"f_m30_20\"><a href=\"../solution/index.shtml#jump_15\">場所から探す</a></a></li>\n        <li class=\"f_m30_30\"><a href=\"../solution/index.shtml#jump_02\">納入事例</a></a></li>\n      </ul>\n    </div>\n  </div>\n  <!-- menu4 -->\n  <div class=\"option\">\n    <input type=\"checkbox\" id=\"toggle4\" class=\"toggle\">\n    <label class=\"title item60\" for=\"toggle4\">Recruit</label>\n    <div class=\"content\">\n      <ul>\n        <li class=\"f_m40_10\"><a href=\"/recruit/\">採用情報</a></li>\n        <li class=\"f_m40_20\"><a href=\"/recruit/job.shtml\">職種紹介</a></li>\n        <li class=\"f_m40_30\"><a href=\"/recruit/interview.shtml\">社員インタビュー</a></li>\n        <li class=\"f_m40_40\"><a href=\"/recruit/requirements.shtml\">募集要項</a></li>\n      </ul>\n    </div>\n  </div>\n  <!-- menu5 -->\n  <div class=\"option\">\n    <div class=\"one_link\"><a href=\"../misc/contact.shtml\">Contact</a></div>\n  </div>\n<!-- menu6 -->\n  <div class=\"option\">\n    <div class=\"one_link\"><a href=\"../\">Home</a></div>\n  </div>\n</div alt=\"eod:accordion\">\n</header>\n<!-- --------------------------------------------------- --> \n\n \n  <!-- ヘッダーのインクルード 終わり　--> \n  \n  <!-- ステージ-->\n  <div id=\"zone_substage\">\n    <div>\n      <h1>Interview</h1>\n    </div>\n    <!--- パンくず -->\n    <ol class=\"zone_pankuzu\">\n      <li><a href=\"../\">HOME</a></li>\n      <li><a href=\"/recruit/\">Recruit</a></li>\n      <li><a href=\"/recruit/interview.shtml\">社員の声</a></li>\n      <li>システムエンジニア</li>\n    </ol>\n    <!-- パンくず --> \n  </div alt=\"eod:zone_substage\">\n  <!-- ステージ　終わり --> \n  <!-- 第2層 -->\n  <div id=\"zone_middle_floor\"> \n    <!--　ボディ領域　-->\n    <div id=\"zone_body\"> \n      <!--　メインエリア　-->\n      <div id=\"zone_mainarea_1col\">\n        <div class=\"sp_padding\"> \n          \n          <!--　▼▼▼　本文領域　▼▼▼　-->\n          <div class=\"col_textarea_full\">\n            <div class=\"interview_fv\">\n              <div class=\"interview_fv-box\">\n                <h2>「向いている、向いていないよりも、まずはやってみる。<br>\n                  迷いながらの一歩が自分を変えました」</h2>\n                <p>本社　システムエンジニア<span class=\"bpts_br\"></span>（システムデザインチーム）<br>\n                  40代　在職歴：2年半</p>\n              </div>\n            </div>\n            <section id=\"interview_section01\">\n              <div class=\"l_overview_box\">\n                <p>現在はシステムエンジニアとして働く私ですが、もともとシステム関係の業務経験は全くありません。当社には営業職で入社したのですが、電気関係・電気設備の仕事は初めてだったので、不安を抱えながらのスタートでした。自分の性格上、営業トークが得意ではなかったのもあり、苦労しました。上司の方々に相談させていただくうちに、設計チームでやってみようか？というお話をいただいたのが部署異動のきっかけです。</p>\n                <p>設計の経験がなく不安もありましたが、考えたシステムが形になり無事に納入され、異動後に初めてお客様にご満足いただいた時の達成感は忘れられません。向いている、向いていないよりも、やってみないと分からないことがある。だから色々とやってみたい、と思うようにもなりました。</p>\n                <p>私の場合は上司が適正を考えてくださり、部署異動を提案していただきましたが、当社には営業、設計、施工部門など、本当に様々な業務や仕事があります。もし入社後に「興味があって、こういう仕事がしたい！」とポジティブに思うことがあれば、上司に相談して自分でチャンスや経験を掴むことができる。キノンビクス株式会社はそんな会社です。 </p>\n              </div>\n              \n              <!-- 大見出し -->\n              <h2 class=\"col_midashi_pagetop\" data-en=\"About the Job\"> <span>業務について</span> </h2 alt=\"eod:col_midashi_pagetop\">\n              <ul>\n                <li>\n                  <h3><span><img src=\"image/no-01.svg\"></span>どのような業務を担当していますか？</h3>\n                  <p class=\"pad-left\">少し前までは、主に監視カメラ設備の設計業務や納入時の設定業務を行っていました。現在はその業務に加えて、映像や音響システムの設計業務についても勉強中です。システムを組むときには、営業の方を通じてお客様のご要望を伺い、そこからどのように設計を進めていくか、という基本的な流れは同じです。しかし『監視カメラ』と『音響』ではシステムの性質が別物なので、1からの覚え直しではないですが、少しずつ知識を積み重ねているところです。</p>\n                  <p class=\"pad-left\">設計デザインチームに所属して一年半ほど経ちますが、まだまだ先輩や上司に助けてもらいながら業務をこなしています。設計に取り組むときには、システムや図面を完成させることだけが目的ではなく、『相手の立場に立ち、分かりやすく、間違いの無いものを作る』という意識を常に持つよう心がけています。</p>\n                </li>\n                <li>\n                  <h3><span><img src=\"image/no-02.svg\"></span>設計業務に慣れるまでに、どのような壁がありましたか？</h3>\n                  <div class=\"bpts_flexbox_onoff justify flexbox\">\n                    <div>\n                      <p>今も完全に慣れてはいないので難しいですね（笑）。</p>\n                      <p>設計はシステム全体に関わる重要な工程のため、一つでもうまく動作しなかったり、互換性がなかったりするとトラブルに繋がります。施工段階で不適合が判明した場合は、仕入れからやり直しになるなど、納期に大きな影響が出てお客様にご迷惑をおかけする可能性もあります。</p>\n                      <p>そのため、簡単なシステムでも常に緊張感をもって作業しています。特に、重点的に見ていない部分に限って不具合が起きる事もありますし、上司からの指摘で初めて気付くこともあるので、設計の難しさを実感することが多いです。 </p>\n                      <p>また、お客様とのやり取りでは、事前準備をしっかりしていても意図がうまく伝わらなかったり、ご要望と完全には一致しないこともあるため、柔軟にお話を伺って次回の設計に活かすこともあります。いずれにしても、上司が毎回丁寧にチェックとフィードバックをしてくださるおかげで、少しずつ成長できている実感があります。今後も「慣れ」に頼らず、業務には慎重に取り組んでいきたいと思っています。</p>\n                    </div>\n                    <img src=\"image/interview-03-01.jpg\" alt=\"\"> </div>\n                </li>\n                <li>\n                  <h3><span><img src=\"image/no-03.svg\"></span>やりがいを感じる瞬間や、嬉しかったことはありますか？ </h3>\n                  <p class=\"pad-left\">最初の頃も今もわからない事は多いですが、上司や先輩方に相談したり、自分でも調べながら知識を積み重ねてきました。そうして取り組んだ案件で、営業の方が受注してくださり、無事に納入して、お客様から評価をいただいた時は、本当にホッとした気持ちと「やりきったな」という達成感があります。こうした気持ちはこれからも変わらず持ち続けていられると思いますし、私はお客様と直接やり取りをする立場でもあるので、「お客様と一緒に喜べる」瞬間も大きなやりがいになっています。</p>\n                  <p class=\"pad-left\">最近は同世代や入社間もない方々と一緒に仕事をする機会も増えていて、お互いに相談しながら苦労を乗り越えた現場もありました。そうした経験も、とても思い出深いです。 </p>\n                </li>\n              </ul>\n              \n              <!-- 大見出し -->\n              <h2 class=\"col_midashi_pagetop\" data-en=\"About KINONVICS\"> <span>キノンビクスについて</span> </h2 alt=\"eod:col_midashi_pagetop\">\n              <ul>\n                <li>\n                  <h3><span><img src=\"image/no-01.svg\"></span>福利厚生・社内制度について教えてください</h3>\n                  <p class=\"pad-left\">去年の秋に日帰りのバス旅行があり、大阪でバーベキューをした後に関空の見学ツアーも行いました。旅行は自由参加で、家族も同伴可能だったため私は家族全員で参加させていただきました。滋賀本社と京都支店から集まり、バス2台での移動となったのでかなりの人数が集まっていたと思います。子どもも楽しんでくれて、私もリラックスして過ごすことができ、良いリフレッシュになりました。</p>\n                  <p class=\"pad-left\">また、年度ごとにチームの目標達成度に対する実績によって奨励賞が頂けます。この奨励賞を活用してチームの食事会を開き、苦労話や普段の思いを共有して、また次の年度に向けてのやる気や元気を蓄えています。</p>\n                  <p class=\"pad-left\">社内の勉強会は開催スケジュールが固定ではありませんが、不定期に頻繁に開催されていますね。それ以外にも、先輩方が個人的に時間を作って教えてくださったり、メーカーさんが弊社に来て商材の説明や使い方を教えてくださることもあります。実機を操作させていただくこともあるので、机上で仕様を見るよりも理解が深まる実感があります。社外でも様々なセミナーがあるのでそちらにも参加させてもらったりと、学ぶ環境が非常に整っています。</p>\n                </li>\n                <li>\n                  <h3><span><img src=\"image/no-02.svg\"></span>キノンビクス株式会社への転職について、家族の評判はどうですか？ </h3>\n                  <div class=\"bpts_flexbox_onoff justify flexbox\">\n                    <div>\n                      <p>以前勤めていた会社では勤務時間がとても長く、家族との時間がほとんど取れませんでした。家事も任せきりでしたが、今は基本的に週2日お休みがもらえていますし、特に妻からは転職して良かったと思ってもらっています。子どもたちと過ごす時間も増えたので、週1日は必ず外に出て色々なところに遊びに行くように心がけています。</p>\n                      <p>子どもがまだ小さいので、仕事中に保育園から「熱があるので迎えに来てほしい」と電話がかかってきたときも、会社は非常に融通を利かせてくれます。お昼から休ませてもらったりも結構しているので、柔軟な対応には本当に助かっています。</p>\n                    </div>\n                    <img src=\"image/interview-03-02.jpg\" alt=\"\"> </div>\n                </li>\n                <li>\n                  <h3><span><img src=\"image/no-03.svg\"></span>社内の雰囲気や、周囲との関係性について教えて下さい</h3>\n                  <p class=\"pad-left\">滋賀本社では、私と年齢が近い社員や入社時期の近い社員も多く在籍しています。お互いにわからないことが重なることも多いので、そんな時はそれぞれが持っている知識を出し合い、助け合いながら切磋琢磨しています。上下関係が厳しすぎることもなく、分からないことも気軽に聞ける環境ですし、上司や先輩方も手を止めて時間を割いてくださいます。口頭説明以外にも、倉庫に機材がある場合は一緒に見に行って、「これはこういうものだよ」と実物を使って教えてくださることもあります。とても親身に、フランクに相談しやすい関係を築いてくださっていると感じます。 </p>\n                </li>\n              </ul>\n              \n              <!-- 大見出し -->\n              <h2 class=\"col_midashi_pagetop\" data-en=\"Message\"> <span>入社・応募を考えている方へのメッセージ</span> </h2 alt=\"eod:col_midashi_pagetop\">\n              <ul>\n                <li>\n                  <div class=\"bpts_flexbox_onoff justify flexbox rev\">\n                    <div class=\"wrap\">\n                      <p>私自身、入社前は製造業やサービス業に勤めていて、全く畑違いからやってきてそろそろ2年半経ちます。もちろん簡単な事ばかりではありませんでしたが、その分、実際に携わった案件が実際に使用されている時には大きな達成感が得られます。別業種で働いていた方も、その時の知識を生かして新しい風を持ち込んでくれることで、すごく活躍できるかもしれません。いろんな方が来ていただければ、もっと賑やかな会社になると思いますので、ぜひお願いしたいです。 </p>\n                      <p>先輩や上司、同僚も含めて皆さんが丁寧に接してくださり、教えてくださるので、職場環境としては本当に素晴らしい会社だと思います。もし少しでも電気設備に興味がある方がいらっしゃったら、ぜひチャレンジする気持ちを持ってもらえたらと思います。そんな方にはキノンビクス株式会社はおすすめなので、ぜひともご応募くださいね。 </p>\n                    </div>\n                    <img src=\"image/interview-03-03.jpg\" alt=\"\" style=\"margin-top: 0;\"> </div>\n                </li>\n              </ul>\n            </section>\n            <section id=\"interview_section02\">\n              <h2>1日のスケジュール</h2>\n              <ul>\n                <li>\n                  <h3>8：30</h3>\n                  <div class=\"txt\">\n                    <p>出社　業務開始<br>\n                      チーム内ミーティングで各自の行動予定や連絡を共有<br>\n                      メールの確認、対応 </p>\n                  </div>\n                </li>\n                <li>\n                  <h3>9:00</h3>\n                  <div class=\"txt\">\n                    <p>外出<br>\n                      日中は現場での機器設定作業、打ち合わせ、システムの仕様確認など<br>\n                      外出予定がないときは社内でシステムの検討や図面の作成<br>\n                      ＊外出頻度は時期によって変わります </p>\n                  </div>\n                </li>\n                <li>\n                  <h3>12:00</h3>\n                  <div class=\"txt\">\n                    <p>昼食</p>\n                  </div>\n                </li>\n                <li>\n                  <h3>16:00</h3>\n                  <div class=\"txt\">\n                    <p>帰社<br>\n                      現場の情報共有、設定内容の資料作りなど事務処理</p>\n                  </div>\n                </li>\n                <li>\n                  <h3>17:30</h3>\n                  <div class=\"txt\">\n                    <p>退社<br>\n                      翌日以降の作業準備や整理を行い、退勤</p>\n                  </div>\n                </li>\n              </ul>\n            </section>\n            <section id=\"interview_section03\">\n              <h2>その他INTERVIEW</h2>\n              <ul class=\"l_grid_interview_list\">\n                <!--  -->\n                <li class=\"eigyo\"> <a href=\"interview-01.shtml\">\n                  <div>\n                    <p>京都支店　営業<span class=\"pre\">（教育ソリューションチーム）</span></p>\n                    <h5>本当に納得できる選択をしていただくために、伝えるべきことを、誠実に伝える。</h5>\n                    <span>30代 在職歴：8年</span> </div>\n                  </a> </li>\n                <!--  -->\n                <li class=\"support\"> <a href=\"interview-02.shtml\">\n                  <div>\n                    <p>京都支店　保守・サポート<span class=\"pre\">（京都サービスチーム）</span></p>\n                    <h5>“この先もずっと続けられる仕事を。”<br>\n                      夢を追いかけた先に見つけた、新しい働き方のかたち。</h5>\n                    <span> 20代　在職歴：半年</span> </div>\n                  </a> </li>\n                <!--  -->\n                <li class=\"engineer\"> <a href=\"interview-04.shtml\">\n                  <div>\n                    <p>本社　施工管理<span class=\"pre\">（滋賀システム技術チーム）</span></p>\n                    <h5>現場ごとに違う景色が、今の自分にちょうどいい。</h5>\n                    <span>30代　在職歴：1年</span> </div>\n                  </a> </li>\n              </ul>\n            </section>\n          </div alt=\"col_textarea_full\">\n          <!--　▲▲▲　本文領域　終わり　▲▲▲　--> \n        </div>\n        <!-- eod:sp_padding --> \n      </div alt=\"eod:zone_mainarea\">\n      <!--　メインエリア　終わり　--> \n    </div alt=\"eod:zone_body\">\n    <!--　ボディ領域　終わり　--> \n  </div alt=\"eod:zone_middle\">\n  <!--　第2層　終わり　--> \n  <!-- リクルート用　お問い合わせフッターのインクルード --> \n  <meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\" />\n<meta name=\"format-detection\" content=\"telephone=no\">\n<!-- \n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/common.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/zone.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/bpts.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/unit.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/col.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/other.css\"/>\n-->\n<!-- リクルートフッターここから -->\n<div class=\"bpts_footer_recruit\"> \n  <!-- ▼ 左ボックス -->\n  <div>\n    <h4>採用に関するお問い合わせ</h4>\n    <table>\n      <tr>\n        <th>担当</th>\n        <td><span>管理グループ</span><br>\n          西村 伸宏</td>\n      </tr>\n      <tr>\n        <th>TEL</th>\n        <td>077-552-1144</td>\n      </tr>\n<!--      <tr>\n        <th>Mail　</th>\n        <td><a href=\"mailto:\"></a></td>\n      </tr>-->\n    </table>\n  </div>\n  <!-- ▲ 左ボックス --> \n  <!-- ▼ 右ボックス -->\n  <div> <a href=\"requirements.shtml\">\n    <h6>募集要項</h6></a> </div>\n  <!-- ▲ 右ボックス --> \n</div>\n<!-- ▲リクルートフッターここまで --> \n\n<!-- お問い合わせfooterここから -->\n<div class=\"bpts_footer_contact_area recruit_wrap\">\n  <h6 class=\"recruit_fotter\">ご相談等ありましたら<span>お気軽にお問い合わせください</span></h6>\n  <div class=\"center\"> <a 