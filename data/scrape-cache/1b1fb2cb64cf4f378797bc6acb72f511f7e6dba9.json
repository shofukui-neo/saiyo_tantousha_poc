/vnd.microsoft.icon\" href=\"https://okayamalaundry.co.jp/recruit/wp-content/themes/okayama_landry_tm/img/common/favicon.ico\" />\n\t<style type=\"text/css\" id=\"xeory_extension-header-css\">\n\t\n\t\n\t</style>\n\t\n    \n    <script type=\"text/javascript\" src=\"//cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick.min.js\"></script>\n\n    <script src=\"https://cdnjs.cloudflare.com/ajax/libs/babel-standalone/6.26.0/babel.min.js\"></script>\n\n\n    <!-- Adobe Font -->\n    <link rel=\"stylesheet\" href=\"https://use.typekit.net/tzh5one.css\">\n\t<!-- Google Tag Manager -->\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n})(window,document,'script','dataLayer','GTM-W7PTBMH');</script>\n<!-- End Google Tag Manager -->\n</head>\n\n<body data-rsssl=1 class=\"wp-singular page-template-default page page-id-8 wp-theme-xeory_extension wp-child-theme-okayama_landry_tm \" itemschope=\"itemscope\" itemtype=\"http://schema.org/WebPage\">\n<!-- Google Tag Manager (noscript) -->\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-W7PTBMH\"\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n<!-- End Google Tag Manager (noscript) -->\n<header id=\"header\">\n    <div class=\"header-logo\">\n        <h1>\n            <a href=\"https://okayamalaundry.co.jp/recruit/\"><img src=\"https://okayamalaundry.co.jp/recruit/wp-content/themes/okayama_landry_tm/img/common/header-logo.svg\" alt=\"OKAYAMA LANDRY\"/></a>\n        </h1>\n    </div>\n    <div class=\"header-menu\">\n        <nav>\n            <ul>\n                <li><a href=\"https://okayamalaundry.co.jp/recruit/\">TOP</a></li>\n                <li><a href=\"https://okayamalaundry.co.jp/recruit/concept/\">CONCEPT</a></li>\n                <li><a href=\"https://okayamalaundry.co.jp/recruit/data/\">DATA</a></li>\n                <li><a href=\"https://okayamalaundry.co.jp/recruit/works/\">WORKS</a></li>\n                <li><a href=\"https://okayamalaundry.co.jp/recruit/interview/\">INTERVIEW</a></li>\n                <li><a href=\"https://okayamalaundry.co.jp/recruit/welfare/\">WELFARE</a></li>\n                <li><a href=\"https://okayamalaundry.co.jp/recruit/topics/\">TOPICS</a></li>\n                <li><a href=\"https://okayamalaundry.co.jp/recruit/company/\">COMPANY</a></li>\n                <li><a href=\"https://okayamalaundry.co.jp/recruit/job-info/\" class=\"adjust\">JOB INFO</a></li>\n            </ul>\n        </nav>\n    </div>\n    <div class=\"nav-toggle-wrap\">\n        <div class=\"nav-toggle\">\n            <span></span>\n            <span></span>\n            <span></span>\n        </div>\n    </div>\n    <div id=\"drawer\">\n        <nav>\n            <ul>\n                <li><a href=\"https://okayamalaundry.co.jp/recruit/\">TOP</a></li>\n                <li><a href=\"https://okayamalaundry.co.jp/recruit/concept/\">CONCEPT</a></li>\n                <li><a href=\"https://okayamalaundry.co.jp/recruit/data/\">DATA</a></li>\n                <li><a href=\"https://okayamalaundry.co.jp/recruit/works/\">WORKS</a></li>\n                <li><a href=\"https://okayamalaundry.co.jp/recruit/interview/\">INTERVIEW</a></li>\n                <li><a href=\"https://okayamalaundry.co.jp/recruit/welfare/\">WELFARE</a></li>\n                <li><a href=\"https://okayamalaundry.co.jp/recruit/topics/\">TOPICS</a></li>\n                <li><a href=\"https://okayamalaundry.co.jp/recruit/company/\">COMPANY</a></li>\n                <li><a href=\"https://okayamalaundry.co.jp/recruit/job-info/\" class=\"adjust\">JOB INFO</a></li>\n                <li><a href=\"https://okayamalaundry.co.jp/recruit/entry/\" class=\"adjust orange\">ENTRY</a></li>\n            </ul>\n        </nav>\n    </div>\n</header>\n\n<aside id=\"aside\">\n    <a href=\"https://okayamalaundry.co.jp/recruit/entry/\"><img src=\"https://okayamalaundry.co.jp/recruit/wp-content/themes/okayama_landry_tm/img/common/sidebar-link.svg\" alt=\"ENTRY NOW\"/></a>\n</aside>    <main>\n        <div class=\"mv page-mv company-mv\">\n            <div class=\"mv-slider-wrap\">\n                <ul class=\"mv-slider\">\n                    <li><img src=\"https://okayamalaundry.co.jp/recruit/wp-content/themes/okayama_landry_tm/img/company/mv.png\" alt=\"COMPANY\"/></li>\n                </ul>\n            </div>\n            <div class=\"page-mv-text-box fadein\">\n                <div class=\"title white\">\n                    <img src=\"https://okayamalaundry.co.jp/recruit/wp-content/themes/okayama_landry_tm/img/title/company-white.svg\" alt=\"COMPANY\" class=\"ps-ab\"/>\n                    <h1 class=\"title-en\">07.COMPANY</h1>\n                    <h2 class=\"title-text\">会社概要</h2>\n                </div>\n                <p class=\"text\">\n                    確かな技術と誠意あるサービスで、<br />\n                    皆さまと身近なところで出会い、綺麗をお届けする。\n                </p>\n            </div>\n        </div>\n        <div class=\"company-sec01 ps-re\">\n            <div class=\"blue-bg sc\"></div>\n            <div class=\"wrap ps-re\">\n                <h3 class=\"text top fadein ts1\">\n                    素材に応じた確かな技術と仕上げ。<br />\n                    大切な衣類を、いつも綺麗に美しく。\n                </h3>\n                <p class=\"text fadein ts1\">\n                    季節ごとに街を彩るファッショナブルな装い。<br />\n                    衣類はデザインや色柄はもちろんのこと、素材や風合いも多種多様で、とてもデリケートです。<br />\n                    素材の性質や状態に応じたクリーニング技術が求められています。<br />\n                    当社では先進の確かな技術カのもと、専門のスタッフが素材ごとにベストの方法で<br />\n                    クリーニング処理から加工、仕上げまで責任を持って行ないます。<br />\n                    また、多様化するニーズにお応えし、リフォームや修理、各種のサービス加工を実施しています。<br />\n                    岡山市内を中心にサービスショップでお預かりするほか、<br />\n                    ご自宅にお伺いする集配サービスも行っています。<br />\n                    皆さまと身近なところで出会い、綺麗をお届けする。<br />\n                    確かな技術と誠意あるサービスで多大な信頼を得ています。\n                </p>\n                <div class=\"img fadein ts1\"><img src=\"https://okayamalaundry.co.jp/recruit/wp-content/themes/okayama_landry_tm/img/company/img01.png\" alt=\"COMPANY\"/></div>\n            </div>\n        </div>\n        <div class=\"company-sec02 ps-re\">\n            <div class=\"gray-bg sc\"></div>\n            <div class=\"wrap\">\n                <div class=\"title sc\">\n                    <img src=\"https://okayamalaundry.co.jp/recruit/wp-content/themes/okayama_landry_tm/img/company/philosophy.svg\" alt=\"PHILOSOPHY\" class=\"ps-ab\"/>\n                    <h3 class=\"title-en fadein ts1\">PHILOSOPHY</h3>\n                    <h4 class=\"title-text fadein ts1\">経営理念</h4>\n                </div>\n                <div class=\"flex\">\n                    <div class=\"box fadeinl\">\n                        <p class=\"num\"><img src=\"https://okayamalaundry.co.jp/recruit/wp-content/themes/okayama_landry_tm/img/company/num01.svg\" alt=\"1\"/></p>\n                        <p class=\"text\">綺麗と清潔を通じて<br />社会に貢献する<br />会社づくり\n                        </p>\n                    </div>\n                    <div class=\"box fadein\">\n                        <p class=\"num\"><img src=\"https://okayamalaundry.co.jp/recruit/wp-content/themes/okayama_landry_tm/img/company/num02.svg\" alt=\"2\"/></p>\n                        <p class=\"text\">安心して<br />衣類が委ねられ<br />顧客に愛される<br />会社づくり\n                        </p>\n                    </div>\n                    <div class=\"box fadeinr\">\n                        <p class=\"num\"><img src=\"https://okayamalaundry.co.jp/recruit/wp-content/themes/okayama_landry_tm/img/company/num03.svg\" alt=\"3\"/></p>\n                        <p class=\"text\">社員とその家族が<br />幸せで<br />生きがいのもてる<br />会社づくり\n                        </p>\n                    </div>\n                </div>\n                <div class=\"box-flex\">\n                    <div class=\"text-box fadeinl\">\n                        <div class=\"subtitle\">\n                            <h5 class=\"subtitle-text\">VISION</h5>\n                            <h6 class=\"subtitle-subtext\">目指す方向性</h6>\n                        </div>\n                        <p class=\"text\">\n                            「衛生のインフラ」として<br />\n                            「おしゃれのインフラ」として<br />\n                            豊かな暮らしをつくります\n                        </p>\n                    </div>\n                    <div class=\"text-box fadeinr\">\n                        <div class=\"subtitle\">\n                            <h5 class=\"subtitle-text\">MISSION</h5>\n                            <h6 class=\"subtitle-subtext\">使命/存在意義</h6>\n                        </div>\n                        <p class=\"text\">\n                            クリーニング技術を正しく継承し<br />\n                            お客様との強力な結びつきを継続させ<br />\n                            サスティナブルな経営を実現します\n                        </p>\n                    </div>\n                </div>\n                <div class=\"img img-animation sc\"><img src=\"https://okayamalaundry.co.jp/recruit/wp-content/themes/okayama_landry_tm/img/company/img02.png\" alt=\"COMPANY\"/></div>\n            </div>\n        </div>\n        <div class=\"company-sec03 ps-re\">\n            <div class=\"blue-bg sc\"></div>\n            <div class=\"wrap\">\n                <div class=\"title sc\">\n                    <img src=\"https://okayamalaundry.co.jp/recruit/wp-content/themes/okayama_landry_tm/img/company/overview.svg\" alt=\"OVERVIEW\" class=\"ps-ab\"/>\n                    <h3 class=\"title-en fadein ts1\">OVERVIEW</h3>\n                    <h4 class=\"title-text fadein ts1\">会社情報</h4>\n                </div>\n                <div class=\"company-content n1 fadein\">\n                    <div class=\"common-table\">\n                        <table>\n                            <tbody>\n                                <tr>\n                                    <th>社名</th>\n                                    <td>株式会社岡山ランドリー</td>\n                                </tr>\n                                <tr>\n                                    <th>創業</th>\n                                    <td>1931年（昭和6年）6月</td>\n                                </tr>\n                                <tr>\n                                    <th>設立</th>\n                                    <td>1949年（昭和24年）5月</td>\n                                </tr>\n                                <tr>\n                                    <th>代表取締役社長</th>\n                                    <td>佐々木　篤</td>\n                                </tr>\n                                <tr>\n                                    <th>住所</th>\n                                    <td>\n                                        <dl>\n                                            <dt>管理本部・総務課</dt>\n                                            <dd>〒702-8051 岡山市南区築港元町13-2<br />TEL　086-262-3399<br>※点在している営業・工場・事務部門を新社屋に集約し、2022年4月1日 正式稼働予定</dd>\n                                        </dl>\n                                    </td>\n                                </tr>\n                                <tr>\n                                    <th>所属団体</th>\n                                    <td>日本リネンサプライ協会、日本病院寝具協会、日本ダイアパー事業振興会、<br>\n                                        日本クリーニング経営者協会、日本クリーニング生産性協議会、<br>\n                                        日本折目加工クリーナーズ協議会、日本ドライクリーニング協会、日本繊維製品消費科学会、<br>\n                                        日本クリーナーズ防炎協会、全国クリーニング協議会</td>\n                                </tr>\n                            </tbody>\n                        </table>\n                    </div>\n                    <div class=\"company-map\">\n                        <iframe src=\"https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d26256.540410147638!2d133.93681725689652!3d34.65299691577637!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x35540630d9783b23%3A0x76efb06a861d980a!2z77yI5qCq77yJ5bKh5bGx44Op44Oz44OJ44Oq44O8IOacrOW6lw!5e0!3m2!1sja!2sjp!4v1642740361831!5m2!1sja!2sjp\" width=\"600\" height=\"450\" style=\"border:0;\" allowfullscreen=\"\" loading=\"lazy\"></iframe>\n                    </div>\n                </div>\n                <div class=\"company-content n2\">\n                    <div class=\"subtitle fadein\">\n                        <h5 class=\"subtitle-text\">HISTORY</h5>\n                        <h6 class=\"subtitle-subtext\">会社沿革</h6>\n                    </div>\n                    <div class=\"history-map\">\n                        <dl class=\"sin-dl\">\n                            <dt class=\"fadein\">1931</dt>\n                            <dd>\n                                <dl class=\"sec-dl fadein\">\n                                    <dt>\n                                        <span>1931年（昭和6年）</span>6月\n                                    </dt>\n                                    <dd>矢一明雄（初代社長）により「駿河屋」として創業される。</dd>\n                                </dl>\n                                <dl class=\"sec-dl fadein\">\n                                    <dt>\n                                        <span>1945年（昭和20年）</span>10月\n                                    </dt>\n                                    <dd>終戦により進駐軍が岡山市に駐屯するため、<br />当局の指示により本社地にクリーニング工場を新設し営業を始める。</dd>\n                                </dl>\n                                <dl class=\"sec-dl fadein\">\n                                    <dt>\n                                        <span>1949年（昭和24年）</span>5月\n                                    </dt>\n                                    <dd>進駐軍の接収解除に伴い、有限会社岡山ランドリーを設立し、一般のクリーニングの営業を開始する。</dd>\n                                </dl>\n                            </dd>\n                        </dl>\n                        <dl class=\"sin-dl\">\n                            <dt class=\"fadein\">1950</dt>\n                            <dd>\n                                <dl class=\"sec-dl fadein\">\n                                    <dt>\n                                        <span>1960年（昭和35年）</span>8月\n                                    </dt>\n                                    <dd>岡山市三浜町に福島工場を新設する。<br />これを機会に有限会社を株式会社に改め、<br />株式会社岡山ランドリーとして発足する。</dd>\n                                </dl>\n                                <dl class=\"sec-dl fadein\">\n                                    <dt>\n                                        <span>1963年（昭和38年）</span>8月\n                                    </dt>\n                                    <dd>\n                                        倉敷市連島に水島工場を新設する。<br>\n                                        同工場は、県内病院基準寝具の実施に伴い外註クリーニング及びリネンサプライ事業を取扱う。\n                                    </dd>\n                                </dl>\n                                <dl class=\"sec-dl fadein\">\n                                    <dt>\n                                        <span>1965年（昭和40年）</span>5月\n                                    </dt>\n                                    <dd>\n                                        岡山市都市計画実施により本社地に本社屋及び附属工場を新設する。\n                                    </dd>\n                                </dl>\n                                <dl class=\"sec-dl fadein\">\n                                    <dt>\n                                        <span>1969年（昭和44年）</span>5月\n                                    </dt>\n                                    <dd>\n                                        岡山市福浜町に「いずみ寮」を新設する。\n                                    </dd>\n                                </dl>\n                                <dl class=\"sec-dl fadein\">\n                                    <dt>\n                                        <span>1981年（昭和56年）</span>3月\n                                    </dt>\n                                    <dd>\n                                        岡山市三浜町福島工場隣接地1,156m2を購入。\n                                    </dd>\n                                </dl>\n                                <dl class=\"sec-dl fadein\">\n                                    <dt>\n                                        <span>1981年（昭和56年）</span>6月\n                                    </dt>\n                                    <dd>\n                                        福島工場の増築工事を完了。\n                                    </dd>\n                                </dl>\n                                <dl class=\"sec-dl fadein\">\n                                    <dt>\n                                        <span>1983年（昭和58年）</span>10月\n                                    </dt>\n                                    <dd>\n                                        水島工場にダイアパー専用工場を増設。\n                                    </dd>\n                                </dl>\n                                <dl class=\"sec-dl fadein\">\n                                    <dt>\n                                        <span>1983年（昭和58年）</span>12月\n                                    </dt>\n                                    <dd>\n                                        増資新資本金4,000万円\n                                    </dd>\n                                </dl>\n                                <dl class=\"sec-dl fadein\">\n                                    <dt>\n                                        <span>1984年（昭和59年）</span>7月\n                                    </dt>\n                                    <dd>\n                                        岡山市三浜町福島工場隣接地に倉庫を新設\n                                    </dd>\n                                </dl>\n                                <dl class=\"sec-dl fadein\">\n                                    <dt>\n                                        <span>1984年（昭和59年）</span>7月\n                                    </dt>\n                                    <dd>\n                                        ふとん丸洗い機一式新設に伴い福島工場一部増改築。\n                                    </dd>\n                                </dl>\n                                <dl class=\"sec-dl fadein\">\n                                    <dt>\n                                        <span>1984年（昭和59年）</span>12月\n                                    </dt>\n                                    <dd>\n                                        増資新資本金4,500万円\n                                    </dd>\n                                </dl>\n                                <dl class=\"sec-dl fadein\">\n                                    <dt>\n                                        <span>1985年（昭和60年）</span>1月\n                                    </dt>\n                                    <dd>\n                                        本社工場をドライクリーニング専門工場とし、本社及び本社工場を一部増改築する。\n                                    </dd>\n                                </dl>\n                                <dl class=\"sec-dl fadein\">\n                                    <dt>\n                                        <span>1985年（昭和60年）</span>1月\n                                    </dt>\n                                    <dd>\n                                        リネンサプライ業務拡張に伴い福島工場をリネンサプライ及びランドリー専門工場とし、福島工場の一部増改築及び機械の新設をする。\n                                    </dd>\n                                </dl>\n                                <dl class=\"sec-dl fadein\">\n                                    <dt>\n                                        <span>1986年（昭和61年）</span>9月\n                                    </dt>\n                                    <dd>（有）第一ランドリーと共栄住宅（有）を吸収合併する。</dd>\n                                </dl>\n                                <dl class=\"sec-dl fadein\">\n                                    <dt>\n                                        <span>1993年（平成5年）</span>1月\n                                    </dt>\n                                    <dd>倉敷市松島の川崎学園内に川崎学園工場を新設。</dd>\n                                </dl>\n                                <dl class=\"sec-dl fadein\">\n                                    <dt>\n                                        <span>1994年（平成6年）</span>5月\n                                    </dt>\n                                    <dd>岡山市豊成に病院基準寝具事業事務所を新設。</dd>\n                                </dl>\n                                <dl class=\"sec-dl fadein\">\n                                    <dt>\n                                        <span>1995年（平成7年）</span>1月\n                                    </dt>\n                                    <dd>岡山市泉田にランドリー専門の泉田工場を新設。</dd>\n                                </dl>\n                                <dl class=\"sec-dl fadein\">\n                                    <dt>\n                                        <span>1996年（平成8年）</span>10月\n                                    </dt>\n                                    <dd>岡山市青江に水島工場の病院基準寝具の代替えとして青江工場を新設。</dd>\n                                </dl>\n                                <dl class=\"sec-dl fadein\">\n                                    <dt>\n                                        <span>1997年（平成9年）</span>4月\n                                    </dt>\n                                    <dd>岡山市中山下の川崎病院内に川崎病院工場を新設。</dd>\n                                </dl>\n                            </dd>\n                        </dl>\n                        <dl class=\"sin-dl\">\n                            <dt class=\"fadein\">2000</dt>\n                            <dd>\n                                <dl class=\"sec-dl fadein\">\n                                    <dt>\n                                        <span>2001年（平成13年）</span>2月\n                                    </dt>\n                                    <dd>株主総会にて代表取締役会長　佐々木宣夫、代表取締役社長　佐々木篤が承認される。</dd>\n                                </dl>\n                                <dl class=\"sec-dl fadein\">\n                                    <dt>\n                                        <span>2003年（平成15年）</span>10月\n                                    </dt>\n                                    <dd>岡山市辰巳に新形態ピュアウォッシュ辰巳店を出店。</dd>\n                                </dl>\n                                <dl class=\"sec-dl fadein\">\n                                    <dt>\n                                        <span>2005年（平成17年）</span>3月\n                                    </dt>\n                                    <dd>岡山市三浜町の福島店を改装、ピュアウォッシュ福島店を併設。</dd>\n                                </dl>\n                                <dl class=\"sec-dl fadein\">\n                                    <dt>\n                                        <span>2006年（平成18年）</span>3月\n                                    </dt>\n                                    <dd>岡山市学南町にピュアウォッシュ学南町店を新設。</dd>\n                                </dl>\n                                <dl class=\"sec-dl fadein\">\n                                    <dt>\n                                        <span>2007年（平成19年）</span>9月\n                                    </dt>\n                                    <dd>\n                                        管理本部を岡山市表町から岡山市三浜町に移転。<br>\n                                        外交本部、店舗本部を同所に設置\n                                    </dd>\n                                </dl>\n                                <dl class=\"sec-dl fadein\">\n                                    <dt>\n                                        <span>2009年（平成21年）</span>12月\n                                    </dt>\n                                    <dd>岡山市北区野田にグランドリー野田店を新設。</dd>\n                                </dl>\n                                <dl class=\"sec-dl fadein\">\n                                    <dt>\n                                        <span>2010年（平成22年）</span>5月\n                                    </dt>\n                                    <dd>レンタル事業部を岡山市南区豊成から岡山市南区青江に移転。</dd>\n                                </dl>\n                                <dl class=\"sec-dl fadein\">\n                                    <dt>\n                                        <span>2011年（平成23年）</span>2月\n                                    </dt>\n                                    <dd>倉敷市東町にピュアウオッシュ倉敷東町店を新設。</dd>\n                                </dl>\n                                <dl class=\"sec-dl fadein\">\n                                    <dt>\n                                        <span>2014年（平成26年）</span>10月\n                                    </dt>\n                                    <dd>岡山市南区泉田にピュアウオッシュ泉田店を新設。</dd>\n                                </dl>\n                                </dd>\n                        </dl><dl class=\"sin-dl\">\n                            <dt class=\"fadein\">2020</dt>\n                            <dd>\n                                <dl class=\"sec-dl fadein\">\n                                    <dt>\n                                        <span>2022年（令和4年）</span>4月\n                                    </dt>\n                                    <dd>点在していた拠点を集約。新社屋にて稼働を開始。</dd>\n                                </dl>\n                            </dd>\n                        </dl>\n                    </div>\n                    <div class=\"img img-animation sc\"><img src=\"https://okayamalaundry.co.jp/recruit/wp-content/themes/okayama_landry_tm/img/company/img03.png\" alt=\"岡山ランドリー\"/></div>\n                </div>\n            </div>\n        </div>\n    </main>\n<footer id=\"footer\">\n    <div class=\"footer-link\">\n        <div class=\"flex\">\n            <div class=\"box n1 sc\">\n                <div class=\"title white sc\">\n                    <img src=\"https://okayamalaundry.co.jp/recruit/wp-content/themes/okayama_landry_tm/img/common/company-white.svg\" alt=\"COMPANY\" class=\"ps-ab\"/>\n                    <img src=\"https://okayamalaundry.co.jp/recruit/wp-content/themes/okayama_landry_tm/img/common/company.svg\" alt=\"COMPANY\" class=\"ps-ab hover-text\"/>\n                    <h2 cla