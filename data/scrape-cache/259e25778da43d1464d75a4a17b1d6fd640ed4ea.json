-anime-wrap -->\n\n<div class=\"under-line-anime-fatwrap pos-lefttop_fat\">\n<div class=\"under-line-fat\"></div>\n</div>\n<!-- /under-line-anime-wrap -->\n\n    <div class=\"text-wrap\">\n        <h1 class=\"title\">お問い合わせ</h1>\n\n        <ul class=\"breadcrumbs\">\n        <li><a href=\"/\">Home</a></li>\n        <li>お問い合わせ</li>\n        </ul>\n\n    </div>\n    <!-- /text-wrap -->\n\n<div class=\"under-line-anime-narrowwrap pos-rightbottom_narrow\">\n<div class=\"under-line-narrow\"></div>\n</div>\n<!-- /under-line-anime-wrap -->\n\n<div class=\"under-line-anime-fatwrap pos-rightbottom_fat\">\n<div class=\"under-line-fat\"></div>\n</div>\n<!-- /under-line-anime-wrap -->\n\n</div>\n<!-- /undercon-category-wrap-inner -->\n</div>\n<!-- /undercon-category-wrap -->\n\n\n<div class=\"section-wrap__under\">\n<div class=\"section\">\n\n<div class=\"title-wrap\">\n<h2 class=\"under-title\">お問い合わせ</h2>\n</div>\n<!-- /title-wrap -->\n\n<p class=\"parag\">メールアドレスはご返信の際に必要になりますので、お間違いのないようご確認お願い致します。<br>\nまたご利用になる前に<a href=\"../../privacy.html\" target=\"_blank\">プライバシー・ポリシー</a>をお読み下さい。</p>\n\n\t<form id=\"mailformpro\">\n    <table class=\"ruledLine\">\n      <tr>\n        <th><span class=\"must\">必須</span>お名前</th>\n        <td><input type=\"text\" name=\"お名前\" class=\"input-maxwidth\" required=\"required\" /></td>\n      </tr>\n      <tr>\n        <th><span class=\"must\">必須</span>会社名</th>\n        <td><input type=\"text\" name=\"会社名\" class=\"input-maxwidth\" required=\"required\" /></td>\n      </tr>\n      <tr>\n        <th>ご住所</th>\n        <td>〒\n          <input type=\"hidden\" name=\"ご住所\" data-unjoin=\"〒+郵便番号+ +都道府県\" />\n          <input type=\"text\" name=\"郵便番号\" data-address=\"都道府県,都道府県,都道府県\" class=\"input-minwidth\" /> ※ハイフン無し<br />\n          <input type=\"text\" name=\"都道府県\" class=\"input-maxwidth\" /></td>\n      </tr>      \n      <tr>\n        <th><span class=\"must\">必須</span>電話番号</th>\n        <td>※ハイフン無し<br><input type=\"text\" name=\"電話番号\" class=\"input-maxwidth\" required=\"required\" /></td>\n      </tr>      \n      <tr>\n        <th><span class=\"must\">必須</span>メールアドレス</th>\n        <td><input type=\"email\" data-type=\"email\" name=\"email\" class=\"input-maxwidth\" required=\"required\" /></td>\n      </tr>\n      <tr>\n        <th><span class=\"must\">必須</span>確認用メールアドレス</th>\n        <td><input type=\"email\" data-type=\"email\" name=\"confirm_email\" class=\"input-maxwidth\" required=\"required\" /></td>\n      </tr>      \n      <tr>\n        <th><span class=\"must\">必須</span>お問い合わせ内容</th>\n        <td>お問い合わせ・ご相談内容をできるだけ詳しくご入力ください。<br />\n          <textarea name=\"お問い合わせ内容\" data-max=\"500\" class=\"textarea-width\" required=\"required\"></textarea>\n        </td>\n      </tr>\n      <tr>\n        <th><span class=\"must\">必須</span>プライバシー・ポリシー</th>\n        <td><label><input type=\"checkbox\" name=\"プライバシー・ポリシー\" value=\"同意する\" size=\"30\" required=\"required\" />同意する</label></td>\n      </tr>      \n    </table>\n\n    \n    <div class=\"btn-wrap__center\">\n    <button type=\"submit\" class=\"submit-btn\">入力内容を確認する</button>\n    </div>\n    \n    </form>\n    <script type=\"text/javascript\" id=\"mfpjs\" src=\"mailformpro/mailformpro.cgi\" charset=\"UTF-8\"></script>\n\n\n\n</div>\n<!-- /section -->\n</div>\n<!-- /section-wrap -->\n\n\n</div>\n<!-- / id wrapper -->\n\n\n\n\n<footer id=\"footer\">\n\n<div class=\"footer-inner\">\n\n<div class=\"footer-menu-wrap\">\n\n<ul class=\"footer-menu-col1\">\n<li><p class=\"footer-menu--title\"><a href=\"https://www.trust-ltd.co.jp/about/index.html\">企業・グループ情報</a></p>\n\t<ul class=\"level1\">\n\t\t<li><a href=\"https://www.trust-ltd.co.jp/about/message.html\">トップメッセージ</a></li>\n\t\t<li><a href=\"https://www.trust-ltd.co.jp/about/philosophy.html\">企業理念</a></li>\n\t\t<li><a href=\"https://www.trust-ltd.co.jp/about/bussiness/index.html\">事業案内</a>\n\t\t\t<ul class=\"level2\">\n\t\t\t<li><a href=\"https://www.trust-ltd.co.jp/about/bussiness/usedcar-export.html\">