jquery-core-js\"></script>\n<script type=\"text/javascript\" src=\"https://www.nj-aac.com/wordpress/wp-includes/js/jquery/jquery-migrate.min.js?ver=3.4.1\" id=\"jquery-migrate-js\"></script>\n<link rel=\"https://api.w.org/\" href=\"https://www.nj-aac.com/wp-json/\" /><link rel=\"alternate\" title=\"JSON\" type=\"application/json\" href=\"https://www.nj-aac.com/wp-json/wp/v2/pages/9\" /><link rel=\"EditURI\" type=\"application/rsd+xml\" title=\"RSD\" href=\"https://www.nj-aac.com/wordpress/xmlrpc.php?rsd\" />\n\n<link rel=\"canonical\" href=\"https://www.nj-aac.com/\" />\n<link rel='shortlink' href='https://www.nj-aac.com/' />\n<link rel=\"alternate\" title=\"oEmbed (JSON)\" type=\"application/json+oembed\" href=\"https://www.nj-aac.com/wp-json/oembed/1.0/embed?url=https%3A%2F%2Fwww.nj-aac.com%2F\" />\n<link rel=\"alternate\" title=\"oEmbed (XML)\" type=\"text/xml+oembed\" href=\"https://www.nj-aac.com/wp-json/oembed/1.0/embed?url=https%3A%2F%2Fwww.nj-aac.com%2F&#038;format=xml\" />\n</head>\r\n\r\n<body class=\"home wp-singular page-template-default page page-id-9 wp-theme-nj-aac front-page\">\r\n\t<div class=\"site-wrap\">\r\n\t\t<div class=\"site-header site-header--default\" id=\"ancher-top\">\r\n\t\t\t<header class=\"site-header--fixed\">\r\n\t\t\t\t<h1 class=\"header-logo\"><img src=\"https://www.nj-aac.com/wordpress/wp-content/themes/nj-aac/img/logo.png\" alt=\"株式会社 北日本朝日航洋\"></h1>\r\n\t\t\t\t<div class=\"header-nav-wrap\">\r\n\t\t\t\t\t<a href=\"#\" class=\"nav-toggle menu\" id=\"nav-toggle\"><span class=\"icon\"></span></a>\r\n\t\t\t\t\t<nav class=\"header-nav\" id=\"header-nav\">\r\n\t\t\t\t\t\t<ul class=\"menu\"><li class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-538\"><a href=\"https://www.nj-aac.com/business\"><span class=\"ja\">事業紹介</span><span class=\"en\">Business</span></a></li>\n<li class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-1430\"><a href=\"https://www.nj-aac.com/find\"><span class=\"ja\">目的から事業を探す</span><span class=\"en\">Find business</span></a></li>\n<li class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-82\"><a href=\"https://www.nj-aac.com/company\"><span class=\"ja\">企業情報</span><span class=\"en\">Information</span></a></li>\n<li class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-964\"><a target=\"_blank\" href=\"https://www.nj-aac.com/recruit\"><span class=\"ja\">採用情報</span><span class=\"en\">Recruit</span></a></li>\n<li class=\"menu-item-contact menu-item menu-item-type-post_type menu-item-object-page menu-item-84\"><a href=\"https://www.nj-aac.com/contact\"><span class=\"ja\">お問い合わせ</span><span class=\"en\">Contact</span></a></li>\n</ul>\t\t\t\t\t</nav>\r\n\t\t\t\t\t<div id=\"nav-bg\" class=\"nav-bg\"></div>\r\n\t\t\t\t</div>\r\n\t\t\t\t\r\n\t\t\t</header>\r\n\t\t</div>\r\n\r\n\t\t<div class=\"site-content\">\r\n\r\n\r\n\t<div class=\"site-content\">\r\n\r\n\t\t\n<figure class=\"wp-block-image alignfull size-full main-visual mt-0\"><img fetchpriority=\"high\" decoding=\"async\" width=\"1640\" height=\"740\" src=\"https://www.nj-aac.com/wordpress/wp-content/uploads/2021/09/mainvisual3.jpg\" alt=\"\" class=\"wp-image-1257\" srcset=\"https://www.nj-aac.com/wordpress/wp-content/uploads/2021/09/mainvisual3.jpg 1640w, https://www.nj-aac.com/wordpress/wp-content/uploads/2021/09/mainvisual3-390x176.jpg 390w, https://www.nj-aac.com/wordpress/wp-content/uploads/2021/09/mainvisual3-1200x541.jpg 1200w, https://www.nj-aac.com/wordpress/wp-content/uploads/2021/09/mainvisual3-768x347.jpg 768w, https://www.nj-aac.com/wordpress/wp-content/uploads/2021/09/mainvisual3-1536x693.jpg 1536w\" sizes=\"(max-width: 1640px) 100vw, 1640px\" /></figure>\n\n\n\n\n\n\n<div class=\"wp-block-group front-company\"><div class=\"wp-block-group__inner-container is-layout-flow wp-block-group-is-layout-flow\">\n<figure class=\"wp-block-image size-full\"><img decoding=\"async\" width=\"466\" height=\"135\" src=\"https://www.nj-aac.com/wordpress/wp-content/uploads/2021/08/front-company-ttl.png\" alt=\"お客様と地域社会をつなぐ。 それが、私たちの役割です。\" class=\"wp-image-943\" srcset=\"https://www.nj-aac.com/wordpress/wp-content/uploads/2021/08/front-company-ttl.png 466w, https://www.nj-aac.com/wordpress/wp-content/uploads/2021/08/front-company-ttl-390x113.png 390w\" sizes=\"(max-width: 466px) 100vw, 466px\" /></figure>\n\n\n\n<p>より地域の皆様の「安全」かつ「安心」な生活や暮らしに貢献できるよう、防災コンサルタント業務、設計・補償コンサルタント業務、各種測量、三次元レーザ計測及び地理空間解析業務、地方自治体における統合型GIS構築支援業務や固定資産税賦課事務支援業務などを主力商品としております。</p>\n\n\n\n<div class=\"wp-block-buttons is-layout-flex wp-block-buttons-is-layout-flex\">\n<div class=\"wp-block-button is-style-outline is-style-outline--1\"><a class=\"wp-block-button__link wp-element-button\" href=\"https://www.nj-aac.com/company\">企業情報</a></div>\n</div>\n</div></div>\n\n\n\n<div class=\"wp-block-group mb-0 front-news\"><div class=\"wp-block-group__inner-container is-layout-constrained wp-block-group-is-layout-constrained\">\n<div class=\"wp-block-cover front-news-ttl\"><img decoding=\"async\" width=\"1280\" height=\"987\" class=\"wp-block-cover__image-background wp-image-618\" alt=\"\" src=\"https://www.nj-aac.com/wordpress/wp-content/uploads/2021/08/435cd9c9e7139939e9076427e886bf4e.png\" style=\"object-position:0% 100%\" data-object-fit=\"cover\" data-object-position=\"0% 100%\"/><span aria-hidden=\"true\" class=\"wp-block-cover__background has-background-dim-0 has-background-dim\"></span><div class=\"wp-block-cover__inner-container is-layout-flow wp-block-cover-is-layout-flow\">\n<h2 class=\"wp-block-heading\">お知らせ</h2>\n\n\n\n<p>Information</p>\n\n\n\n<div class=\"wp-block-buttons is-layout-flex wp-block-buttons-is-layout-flex\">\n<div class=\"wp-block-button is-style-outline is-style-outline--2\"><a class=\"wp-block-button__link wp-element-button\" href=\"https://www.nj-aac.com/news/\">お知らせ一覧</a></div>\n</div>\n</div></div>\n\n\n\n<div class=\"wp-block-group inner\"><div class=\"wp-block-group__inner-container is-layout-constrained wp-b