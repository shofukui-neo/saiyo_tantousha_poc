incol\">\n<!-- InstanceBeginEditable name=\"main\" -->\n<div class=\"inner\">\n<article>\n\n<h2>お電話でのお問い合わせ・お申し込み</h2>\n\n<div class=\"clerk_txt\">\n\n<p><strong>四国ガス燃料のLPガスをご利用のお客さま専用となっております。<br>\n四国ガスの都市ガスをご利用のお客さまは、四国ガスへお問い合わせください。</strong></p>\n<ul class=\"arr\">\n<li><a href=\"https://www.shikoku-gas.co.jp/\" target=\"_blank\">四国ガスホームページ</a></li>\n</ul>\n\n<p><strong>ガス機器の修理、ガス料金、ガス開栓・閉栓、その他ガスに関するご用件をお電話で受け付けております。</strong></p>\n<p style=\"margin-top: 2em;\"><strong class=\"txt_sennasi\">受付時間　午前9時〜午後5時（土日・祝日は除く）<br>\n※日、祝日、年末年始は保安担当者による受付となります。</strong></p>\n</div>\n\n\n<table summary=\"連絡先の一覧\" class=\"shoplist\">\n<tbody>\n<tr>\n<td class=\"clerk_shop\">今治営業所</td>\n<td class=\"clerk_phone\"><a href=\"tel:0898-32-4145\">0898-32-4145</a></td>\n<td><p><a href=\"imabari/\">愛媛県今治市クリエイティブヒルズ2番地5</a></p></td>\n</tr>\n<tr>\n<td class=\"clerk_shop\">上浦出張所</td>\n<td class=\"clerk_phone\"><a href=\"tel:0897-87-2115\">0897-87-2115</a></td>\n<td><p><a href=\"kamiura/\">愛媛県今治市上浦町井口5853番地</a></p></td>\n</tr>\n<tr>\n<td class=\"clerk_shop\">松山営業所</td>\n<td class=\"clerk_phone\"><a href=\"tel:089-923-1001\">089-923-1001</a></td>\n<td><p><a href=\"matsuyama/\">愛媛県松山市山越5丁目2番12号</a></p></td>\n</tr>\n<tr>\n<td class=\"clerk_shop\">東温出張所</td>\n<td class=\"clerk_phone\"><a href=\"tel:089-990-1200\">089-990-1200</a></td>\n<td><p><a href=\"toon/\">愛媛県東温市志津川南5丁目8番地7</a></p></td>\n</tr>\n<tr>\n<td class=\"clerk_shop\">宇和島営業所</td>\n<td class=\"clerk_phone\"><a href=\"tel:0895-25-2834\">0895-25-2834</a></td>\n<td><p><a href=\"uwazima/\">愛媛県宇和島市明倫町1丁目1番16号</a></p></td>\n</tr>\n\n\n<tr>\n<td class=\"clerk_shop\">宇和出張所</td>\n<td class=\"clerk_phone\"><a href=\"tel:0894-62-5577\">0894-62-5577</a></td>\n<td><p><a href=\"uwa/\">愛媛県西予市宇和町坂戸654番1</a></p></td>\n</tr>\n\n<tr>\n<td class=\"clerk_shop\">宿毛出張所</td>\n<td class=\"clerk_phone\"><a href=\"tel:0880-63-9860\">0880-63-9860</a></td>\n<td><p><a href=\"sukumo/\">高知県宿毛市高砂27-34　湘南ビル1F</a></p></td>\n</tr>\n<tr>\n<td class=\"clerk_shop\">新居浜営業所</