mmon/import.css\">\n<LINK rel=\"shortcut icon\" href=\"//www.nta.co.jp/favicon.ico\" type=\"image/x-icon\">\n<LINK rel=\"stylesheet\" href=\"//www.nta.co.jp/hokkaido/css/ver4.css\" type=\"text/css\">\n<LINK rel=\"stylesheet\" href=\"//www.nta.co.jp/hokkaido/css/common/import.css\" type=\"text/css\" media=\"screen,tv,print\">\n<!--//// 共通 CSS↑ ////-->\n<!--//// 共通 JavaScript↓ ////-->\n<script type=\"text/javascript\" src=\"https://www.nta.co.jp/hokkaido/js/jquery-1.7.2.min.js\"></script>\n<SCRIPT language=\"JavaScript\" src=\"https://www.nta.co.jp/hokkaido/js/common.js\" type=\"text/javascript\" charset=\"shift_jis\"></SCRIPT>\n<!--[if lt IE 7]>\n    <script src=\"http://ie7-js.googlecode.com/svn/version/2.0(beta3)/IE7.js\" type=\"text/javascript\"></script>\n<![endif]-->\n<!--//// 共通 JavaScript↑ ////-->\n<!--//// 個別 CSS↓ ////-->\n<LINK rel=\"stylesheet\" type=\"text/css\" href=\"//www.nta.co.jp/hokkaido/css/index.css\" media=\"screen,tv,print\">\n<LINK href=\"//www.nta.co.jp/hokkaido/company/css/list.css\" rel=\"stylesheet\" type=\"text/css\">\n<LINK href=\"//www.nta.co.jp/hokkaido/company/css/box.css\" rel=\"stylesheet\" type=\"text/css\">\n<LINK href=\"//www.nta.co.jp/hokkaido/company/css/title.css\" rel=\"stylesheet\" type=\"text/css\">\n<link href=\"//www.nta.co.jp/hokkaido/company/css/table.css\" rel=\"stylesheet\" type=\"text/css\">\n<LINK href=\"//www.nta.co.jp/hokkaido/company/css/img.css\" rel=\"stylesheet\" type=\"text/css\">\n\n<!--//// 個別 CSS↑ ////-->\n\n</head>\n\n<!-- WRAPPER START -->\n<body>\n<div id=\"wrapper\">\n\n<script type=\"text/javascript\" src=\"//www.nta.co.jp/shared2015/common/js/header.js\" charset=\"shift_jis\"></script>\n\n<!-- PASTLIST START -->\n<div id=\"pastlist\" class=\"t10\"><a href=\"//www.nta.co.jp/\">日本旅行 トップ</a>&nbsp;&gt;&nbsp;<a href=\"//www.nta.co.jp/hokkaido/\">北海道旅行 北海道ツアー</a>&nbsp;&gt;&nbsp;日本旅行北海道　採用情報</div>\n<!-- /PASTLIST END -->\n\n<!-- OUTLINE START -->\n<div id=\"middleArea\" class=\"clearfix t12\">\n<p class=\"hide\">[ <a id=\"SKIPPED\" name=\"SKIPPED\">ここから本文です</a> ]</p>\n\n<!-- 期間内外で表示を変更　どちらかひとつ　idで切り替え -->\n<!--<div id=\"contentperiod\"></div>\n<div id=\"contentend\">※現在は募集しておりません※</div> -->\n\n<!-- /期間内外で表示を変更　どちらかひとつ　idで切り替え -->\n\n<!-- 埋め込み -->\n<h1>[採用情報…個人情報の取扱～日本旅行北海道]</h1>\n\n<div id=\"bg\">\n\n\n<div class=\"box2\"> 　\n\n<h2 class=\"title01_top\">個人情報のお取扱いについて</h2>\n<p>\n      <table summary=\"個人情報の取扱\" class=\"text\" align=\"center\">\n        <tr>\n          <td class=\"text\">\n<span class=\"blue\">■採用試験に応募される場合は、以下の「個人情報のお取扱いについて」を必ずご確認の上、\n\nエントリーシート提出及びエントリーに伴う個人情報のご提供をお願いいたします。</span><br>\n<br>\n\n\n<span class=\"bold\">【個人情報のお取扱いについて】</span> <br>\n<br>\n株式会社日本旅行北海道（以下、当社といいます）は、個人情報保護関係法令及び当社の個人情報保護方針ならびに個人情報保護規則に基づき、個人情報を以下のようにお取扱しその保護に努めております。<br>\n\n当社への個人情報のご提供にあたっては、下記の内容にご同意の上でご提供いただきますようお願い申し上げます。<br>\n\n<br>\n\n１．個人情報利用目的<br>\n\n当社は、採用への応募にあたってエントリーシート・エントリー入力を通じてお預かりする個人情報につきまして、\n応募者へのご連絡等、採用業務に必要な範囲でのみ利用させていただきます。<br>\n<br>\n\n\n２．個人情報の第三者への提供及び外部委託<br>\n\n当社は、前項に記載した利用目的でお預かりした個人情報につきましては、\n社内業務のみに利用し、第三者への提供及び外部委託はいたしません。<br>\n<br>\n\n\n３．個人情報入力にあたっての注意事項<br>\n\n当社ホームページでのエントリー及びエントリーシート等、個人情報の記載内容に誤りがあった場合又は個人情報のご入力をいただけない場合は、応募者へのご連絡及び採用業務に支障をきたす恐れがございますのでご了承願います。<br>\n<br>\n\n\n４.本人が容易に認識できない方法による個人情報の取得<br>\n当社ホームページでは、お客様にいっそう便利にご利用いただく為、一部のサイトで「Cookie」を使用しております。なお、お客様ご利用のブラウザが「Cookie」の機能を制限している場合は、一部のサービスがご利用になれないことがございます。<br>\n 「Cookie（クッキー）」とは、ウェブサイトがお客様のコンピュータを識別する技術です。<br>\n\n<br>\n\n５．個人情報に関するお問合せ・開示・訂正・削除のご請求手続きについて<br>\n\n当社が保有する個人情報について、利用目的の通知、個人情報の開示、個人情報の訂正・追加・削除、個人情報の利用停止、個人情報の削除をご希望の場合は、必要となる手続方についてご案内いたしますので、下記のお問合せ先までお申出ください。\n<br>\n<br>\n\n【個人情報に関するお問合せ、苦情等のお申し出先】<br>\n\n株式会社日本旅行北海道　本社業務部<br>\n個人情報保護管理責任者（業務担当責任者）<br>\n℡０１１－２０８－０１５０<br>\ne-mail　 <a href=\"/cdn-cgi/l/email-protection\" class=\"__cf_email__\" data-cfemail=\"c5b6aaa1a4ab9aadaea185abb1a4eba6aaebafb5\">[email&#160;protected]</a>\n<br>\n<br><br>\n<br>\n\n<center>\n\n\n  <p>上記に同意いただける方は「同意する」ボタンより次の画面にお進みください。<br><br>\n\n    <a href=\"//www.nta.co.jp/hokkaido/company/recruit/index.html\"><img src=\"//www.nta.co.jp/hokkaido/image/button1.gif\" alt=\"同意する\"></a>\n\t  　　<a href=\"//www.nta.co.jp/hokkaido/\"><img src=\"//www.nta.co.jp/hokkaido/image/button2.gif\" alt=\"同意しない\"></a>\n\n  </p>\n</center>\n\n          </td>\n        </tr>\n      </table>\n\n</div>\n<!--　メインコンテンツ・会社概要ほか【ここまで】　-->\n\n\n\n\n\n<!-- /埋め込み -->\n</div></div>\n<!-- コンテンツ部分ここまで ↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑ -->\n\n\n\n<!-- crosslinks -->\n<div id=\"anchorlinks\" class=\"fs01\">\n<p id=\"pageback\"><a href=\"//www.nta.co.jp/hokkaido/\">←日本旅行北海道 トップ　ページへ戻る</a></p>\n<p id=\"pagetop2\"><a href=\"#wrapper\">↑ページ上部へ</a></p>\n</div>\n<br class=\"clear\">\n<!-- /crosslinks -->\n\n<!--pc_footer-->\n<!--footer//-->\n<div id=\"Foot\">\n<p id=\"pagetop\"><a href=\"#top\"><img src=\"//www.nta.co.jp/shared2015/common/images/pagetop.png\" width=\"72\" height=\"73\" alt=\"pagetop\" /></a></p>\n\n<div class=\"footTop\">\n<div class=\"footTopInner\">\n<ul class=\"linkTop bold\">\n<li><a href=\"//www.nta.co.jp/\">日本旅行総合トップ</a></li>\n<li>｜</li>\n<li><a href=\"//www.nta.co.jp/jr/\">JR＋宿泊</a></li>\n<li>｜</li>\n<li><a href=\"//www.nta.co.jp/kokunai/\">国内旅行（ツアー）</a></li>\n<li>｜</li>\n<li><a href=\"//www.nta.co.jp/yado/\">ホテル・旅館（宿泊）</a></li>\n<li>｜</li>\n<li><a href=\"//www.nta.co.jp/bus/\">高速バス</a></li>\n<li>｜</li>\n<li><a href=\"//www.nta.co.jp/rentacar/\">レンタカー</a></li>\n<li>｜</li>\n<li><a href=\"//www.nta.co.jp/aso/\">遊び・体験</a></li>\n</ul>\n<ul class=\"linkTop bold\">\n<li><a href=\"//www.nta.co.jp/kaigai/\">海外旅行（ツアー）</a></li>\n<li>｜</li>\n<li><a href=\"//www.nta.co.jp/kaigai_air/\">海外航空券</a></li>\n<li>｜</li>\n<li><a href=\"//www.nta.co.jp/kaigai_hotel/\">海外ホテル</a></li>\n<li>｜</li>\n<li><a href=\"//www.nta.co.jp/kaigai_dp/\">海外航空券＋海外ホテル</a></li>\n</ul>\n<ul class=\"linkTop\">\n<li><a href=\"//www.nta.co.jp/tavira/\">女子旅「たびーら」</a></li>\n<li>｜</li>\n<li><a href=\"//www.nta.co.jp/theme/\">こだわりのテーマで探す旅</a></li>\n<li>｜</li>\n<li><a href=\"https://www.nta.co.jp/media/tripa/\">trip