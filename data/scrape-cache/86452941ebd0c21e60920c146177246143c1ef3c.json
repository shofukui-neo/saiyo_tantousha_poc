ji{display:inline !important;border:none !important;box-shadow:none !important;height:1em !important;width:1em !important;margin:0 .07em !important;vertical-align:-.1em !important;background:0 0 !important;padding:0 !important}</style><link rel='stylesheet' id='wp-block-library-css'  href='https://www.kakuhan.com/wordpress/wp-includes/css/dist/block-library/style.min.css?ver=5.6.17' type='text/css' media='all' /><link rel=\"https://api.w.org/\" href=\"https://www.kakuhan.com/wp-json/\" /><link rel=\"alternate\" type=\"application/json\" href=\"https://www.kakuhan.com/wp-json/wp/v2/interview/78\" /><link rel=\"EditURI\" type=\"application/rsd+xml\" title=\"RSD\" href=\"https://www.kakuhan.com/wordpress/xmlrpc.php?rsd\" /><link rel=\"wlwmanifest\" type=\"application/wlwmanifest+xml\" href=\"https://www.kakuhan.com/wordpress/wp-includes/wlwmanifest.xml\" /><meta name=\"generator\" content=\"WordPress 5.6.17\" /><link rel='shortlink' href='https://www.kakuhan.com/?p=78' /><link rel=\"alternate\" type=\"application/json+oembed\" href=\"https://www.kakuhan.com/wp-json/oembed/1.0/embed?url=https%3A%2F%2Fwww.kakuhan.com%2Frecruit%2Finterview%2Fkurokawa%2F\" /><link rel=\"alternate\" type=\"text/xml+oembed\" href=\"https://www.kakuhan.com/wp-json/oembed/1.0/embed?url=https%3A%2F%2Fwww.kakuhan.com%2Frecruit%2Finterview%2Fkurokawa%2F&#038;format=xml\" /><link rel=\"icon\" href=\"https://www.kakuhan.com/wordpress/wp-content/uploads/2020/09/favicon.png\" sizes=\"32x32\" /><link rel=\"icon\" href=\"https://www.kakuhan.com/wordpress/wp-content/uploads/2020/09/favicon.png\" sizes=\"192x192\" /><link rel=\"apple-touch-icon\" href=\"https://www.kakuhan.com/wordpress/wp-content/uploads/2020/09/favicon.png\" /><meta name=\"msapplication-TileImage\" content=\"https://www.kakuhan.com/wordpress/wp-content/uploads/2020/09/favicon.png\" /></head><body class=\"page--interview\"><header class=\"global-header\"><div class=\"uk-container uk-container-expand\"><nav class=\"uk-navbar-container uk-navbar-transparent\" uk-navbar><div class=\"uk-flex uk-width-expand uk-hidden@l\"><div class=\"uk-navbar-center\"><a class=\"uk-logo\" href=\"https://www.kakuhan.com\"><img src=\"https://www.kakuhan.com/wordpress/wp-content/themes/kakuhan/images/common/logo.png\" alt=\"株式会社角繁のロゴ\"></a></div><div class=\"uk-navbar-right\"><a class=\"offcanvas-btn\" id=\"offcanvas-btn\" href=\"#offcanvas\" uk-toggle><span></span><span></span><span></span></a></div></div><div class=\"uk-flex uk-width-expand uk-visible@l\"><div class=\"uk-navbar-left\"><a class=\"uk-logo\" href=\"https://www.kakuhan.com\"><img src=\"https://www.kakuhan.com/wordpress/wp-content/themes/kakuhan/images/common/logo.png\" alt=\"\"></a></div><div class=\"uk-navbar-right\"><ul class=\"uk-navbar-nav gnav\"><li class=\"gnav-list\"><a href=\"https://www.kakuhan.com/works/\">WORKS</a></li><li class=\"gnav-list\"><a href=\"https://www.kakuhan.com/about/\">ABOUT</a></li><li class=\"gnav-list\"><a href=\"https://www.kakuhan.com/map/\">MAP</a></li><li class=\"gnav-list\"><a href=\"https://www.kakuhan.com/recruit/\">RECRUIT</a></li><li class=\"gnav-list\"><a href=\"https://www.kakuhan.com/news/\">NEWS</a></li><li class=\"gnav-list\"><a href=\"https://www.kakuhan.com/gallery/\">GALLERY</a></li><li class=\"gnav-list\"><a href=\"https://www.kakuhan.com/group/\">GROUP</a></li></ul></div></div></nav></div></header><main><div class=\"sub-page-mv uk-background-cover uk-position-relative recruit-interview-mv\" style=\"background-image: url(https://www.kakuhan.com/wordpress/wp-content/themes/kakuhan/images/mv/recruit_mv_4.jpg);\"><div class=\"uk-container\"><div class=\"sub-page-mv__inner\"><div class=\"component-header recruit-interview-mv\"><h2 class=\"title\">RECRUIT<span class=\"slug\">採用情報</span></h2></div></div></div></div><div class=\"uk-section-xsmall breadcrumb uk-padding-remove-bottom\"><div class=\"uk-container\"><ul class=\"uk-breadcrumb\"><li><a class=\"uk-icon-link\" href=\"https://www.kakuhan.com\" uk-icon=\"home\"></a></li><li><a href=\"https://www.kakuhan.com/recruit/\">採用情報</a></li><li><span>社員インタビュー(第三営業部　黒川さん)</span></li></ul></div></div><section class=\"interview-component component uk-margin-remove-bottom\"><div class=\"uk-container\"><div class=\"interview-component__thumnailgrid\"><div class=\"block uk-cover-container\"><canvas width=\"1200\" height=\"900\"></canvas><img src=\"https://www.kakuhan.com/wordpress/wp-content/uploads/2020/03/リクルート黒川ＴＯＰ.jpg\" alt=\"\" uk-cover loading=\"lazy\"></div><div class=\"block\"><div class=\"component-header\"><div class=\"inner-contents\"><h2 class=\"title\">様々な部署を経験したからこそ、<br /> 今の自分があります</h2><div class=\"data-block\"><p class=\"text\"><span>2005年</span><span>入社</span></p></div><div class=\"postname\"><p class=\"post\">第三営業部　営業三課　課長</p><p class=\"name\">黒川さん</p></div></div></div></div></div><div class=\"interview-component__works interview-contents\"><h3 class=\"interview-contents__title\">第三営業部ってどんな仕事？</h3><p>角繁は営業部が3つあり、エリアや販売先によって分かれています。<br /> 第一営業部は主に秋田県外のお客様への対応、第二営業部は秋田県内の木材店等に資材を販売する部門、<strong>私の所属する第三営業部は木材・建材・住宅設備機器などを販売する部門で商品ラインナップが多い部署です。</strong><br /> 私は見積作成・お客様への訪問（打ち合わせ）・配送などが主な業務です。<br /> 専門業務を行っている部署とのコミュニケーションを密に取って仕事をしています。</p></div><div class=\"uk-margin-large interview-component__history interview-contents\"><h2>角繁に採用〜入社まで</h2><div class=\"uk-margin-large\"><h3 class=\"interview-contents__title\">まず、角繁を知ったきっかけはなんですか？</h3><p>私は18歳で角繁に入社したのですが、高校生の時は漠然と「家」が好きだったので住宅関係の仕事を地元秋田で<br /> できたら良いな・・と思っていました。その時に高校に来た求人票で木材に関わることができる角繁を知って応募しました。<br /> 角繁1本に絞って採用活動を行っていたのですが無事に受かって良かったという気持ちです。</p></div><div class=\"uk-margin-large\"><h3 class=\"interview-contents__title\">18歳という多感な時期ですと、東京や仙台に上京して働きたいとは思いませんでしたか？</h3><p>友人も秋田に残りたいと思っている人が多く、自分も地元のお祭りなど地域行事に<br /> ずっと参加していたかったので特に思いませんでした！</p></div></div><div class=\"uk-margin-large interview-component__images interview-contents\"><figure><img src=\"https://www.kakuhan.com/wordpress/wp-content/uploads/2020/03/リクルート黒川_1.jpg\"></figure></div><div class=\"uk-margin-large interview-component__career interview-contents\"><h2>業務内容・キャリアアップについて</h2><h3 class=\"interview-contents__title\">黒川さんは様々な部署を経験されていますね。</h3><p>はい。<br /> ・配送・商品管理(4年)<br /> ・プレカットオペレーター(5年)<br /> ・プレカットＣＡＤ(1年)<br /> を経て、第三営業部に配属されました。</p><h3 class=\"interview-contents__title\">入社時からすぐに営業部に配属という訳ではないのですね。</h3><p>幅広い商品を取り扱っており尚且つ住宅に関する知識も必要となるため、覚えることはたくさんあります。<br /> <strong>もちろん未経験のまま、いきなりお客様の所に出向いて仕事をする（させる）事はありません。</strong>何度か部署異動を経験して<br /> 自分に一番合っている部署を選択する事ができます。<br /> 私の場合は10年ほど働いたあとに上司から営業部へ異動しないかと打診されたのでやってみよう！という感じで今の部署にいます。</p><h3 class=\"interview-contents__title\">営業部に異動しないかと打診されるということは、商品についてしっかりと<br /> 知識がついているというお墨付きをいただいた証拠なのですね。</h3><p>そうですね。<strong>10年ほど働いて様々な対応に慣れた事と、様々な部署を経験したからこそ幅広く知識を得ることができました。</strong><br /> 木材だけでなく最適な提案ができるように建材や最新の建築技術であったり、<br /> 法改正などの勉強も日々行って都度情報をアップデートしています。<br /> 提案した商材が採用になったり、お客様が喜ばれる顔を直接見ることができると営業担当になって良かったなと思います。</p><h3 class=\"interview-contents__title\">新人の頃に苦労したことを教えていただけますか。</h3><p>新人の頃は、大工さんや工務店の方が設計・構造のプロなので知識が豊富です。「知識負け」してしまってうまく言葉が返せない、<br /> 良い提案ができなかった・・という事があり、非常に悔しかったです。ただその場で取り繕う為に間違った事を言わないように<br /> 「受け答えできない事は一旦社内に持ち帰るように」と当時の上司からアドバイスを頂けたので少し精神的に楽になりました。<br /> また、<strong>お客様に教わる気持ち</strong>で働くことも大事だと思います。</p><h3 class=\"interview-contents__title\">今後はどのようにキャリアアップしていきたいですか。</h3><p>住宅業界は設備の進化や法改正、補助金等常に変化があります。<br /> 木材の販売は当社のメインですが、今は構造材に付随した建材、住設やお客様に有利になる補助金等の知識も必要です。自分はもちろんですが部門内でもそういった情報を共有し、部門全体でのレベルアップを図って行きたいです。<strong>上司、先輩方には理解力もあり、いつも的確なアドバイスを頂いています。</strong><br /> そしてどんなことがあっても常に冷静で、新人の頃から今になってもその姿に憧れ、尊敬しています。私もそういった姿を目指し、部門の仲間達に対して業務的にも精神的にも負担を軽減出来る存在になれればと思います。</p></div><div class=\"uk-margin-large interview-component__images interview-contents\"><figure><img src=\"https://www.kakuhan.com/wordpress/wp-content/uploads/2020/03/MG_3722-1.jpg\"></figure></div><div class=\"uk-margin-large interview-component__other interview-contents\"><h2>プライベート・その他について</h2><h3 class=\"interview-contents__title\">黒川さんはお子さんがいますが、仕事と育児の両立はうまくいっていますか？</h3><p>子どもが幼い頃、保育園のお迎えなどは時間が決まっているので多少苦労しましたが、夫婦の協力で充分にカバーできました。<br /> それ以外に仕事が原因で育児との両立が苦しかった事はありません。家庭を持っている人が社内に多く、<br /> 理解もしていただいているので働きやすいです。帰宅後は子どもをお風呂に入れたりリラックスする時間もちゃんとありますよ。</p><h3 class=\"interview-contents__title\">では最後に、角繁へ入社を検討している方に一言お願いいたします。</h3><p>私もですが、周りの社員も未経験で入社した人が多いです。資格や知識不足が不安という方でも少しずつ<br /> 業務を覚えていけるような環境なので安心して応募してみてください。<br /> 皆親切なので話しかけやすい環境です。分からない事があったらなんでも聞いてくださいね。</p></div><div class=\"uk-margin-large interview-component__images interview-contents\"><figure><img src=\"https://www.kakuhan.com/wordpress/wp-content/uploads/2020/03/リクルート黒川_3.jpg\"></figure></div><div class=\"uk-margin-large interview-component__oneday interview-contents\"><h2>営業部　黒川さんの1日</h2><table class=\"uk-table\"><tbody><tr><td>08:00</td><td>朝礼<br /></td></tr><tr><td>08:00〜12:00</td><td>見積作成・前日の売上入力・発注作業などを午前中に行います。<br /> 特に発注作業は午前のうちに終えておかないと間に合わない案件もありますので、<br /> 優先順位をつけて作業します。</td></tr><tr><td>12:00〜13:00</td><td>昼休憩<br /></td></tr><tr><td>13:00〜16:00</td><td>お客様の元へ訪問・打ち合わせ・配送など外にいることがほとんどです。<br /></td></tr><tr><td>16:00〜17:00</td><td>訪問時にいただいた見積依頼や発注作業などを行います。<br /></td></tr><tr><td>17:00〜18:00</td><td>翌日の段取りや部門内の状況確認・指示を行います。</td></tr><tr><td>18:00</td><td>お疲れ様でした。<br /></td></tr></tbody></table></div></div><section class=\"interview-component__contact uk-background-norepeat uk-background-fixed uk-background-cover uk-position-relative uk-background-center-center\" style=\"background-image: url(https://www.kakuhan.com/wordpress/wp-content/themes/kakuhan/images/top/contact_bg.jpg);\"><div class=\"contact-grid\"><div class=\"block\"><h2>採用に関する<br>お問い合わせはこちらから</h2><p class=\"contact-tel\"><span uk-icon=\"receiver\"></span><a class=\"tel-text\" href=\"tel:0188339461\">018-833-9461</a><span class=\"ex\">平日 8:00〜17:00</span><span uk-icon=\"print\"></span>018-833-9464</p><a class=\"btn\" href=\"mailto:info@kakuhan.com\"><span uk-icon=\"mail\"></span>info@kakuhan.com</a></div><div class=\"block\"><p>募集要項を見る</p><div class=\"btn-block\"><a href=\"https://www.kakuhan.com/recruit/guideline/#career\">中途採用<svg class=\"arrow\" xmlns=\"http://www.w3.org/2000/svg\" width=\"86.679\" height=\"57.786\" viewBox=\"0 0 86.679 57.786\"><path id=\"パス_95\" data-name=\"パス 95\" d=\"M74.732,193.263l21.883-20.21H22.329v-7.318H96.615L74.732,145.523l4.587-5.023,29.689,28.677v.432L79.319,198.286Z\" transform=\"translate(-22.329 -140.5)\" fill=\"#fff\"></path></svg></a><a href=\"https://www.kakuhan.com/recruit/guideline/#new\">新卒採用<svg class=\"arrow\" xmlns=\"http://www.w3.org/2000/svg\" width=\"86.679\" height=\"57.786\" viewBox=\"0 0 86.679 57.786\"><path id=\"パス_95\" data-name=\"パス 95\" d=\"M74.732,193.263l21.883-20.21H22.329v-7.318H96.615L74.732,145.523l4.587-5.023,29.689,28.677v.432L79.319,198.286Z\" transform=\"translate(-22.329 -140.5)\" fill=\"#fff\"></path></svg></a></div></div></div></section></section></main><div id=\"offset\"><div class=\"totop\" id=\"totop\"><a href=\"#top\" uk-scroll><img src=\"https://www.kakuhan.com/wordpress/wp-content/themes/kakuhan/images/common/totop.png\" alt=\"\"></a></div></div><footer class=\"global-footer\" id=\"global-footer\"><div class=\"uk-container\"><div class=\"uk-child-width-1-4 uk-visible@l\" uk-grid><div><div class=\"f_nav__content\"><a class=\"f_nav\" href=\"https://www.kakuhan.com\">TOPページ</a></div><div class=\"f_nav__content\"><a class=\"f_nav\" href=\"https://www.kakuhan.com/about/\">会社案内</a></div><div class=\"f_nav__content\"><ul class=\"uk-nav uk-nav-default\"><li class=\"uk-parent\"><a class=\"parent-link\" href=\"https://www.kakuhan.com/works/\">業務内容</a><ul class=\"uk-nav-sub line\"><li><a class=\"sub_link\" href=\"https://www.kakuhan.com/works/wood\">木材</a></li><li><a class=\"sub_link\" href=\"https://www.kakuhan.com/works/materials\">建材・住宅設備機器</a></li><li><a class=\"sub_link\" href=\"https://www.kakuhan.com/works/delivery\">配送</a></li><li><a class=\"sub_link\" href=\"https://www.kakuhan.com/works/precut\">プレカット</a></li><li><a class=\"sub_link\" href=\"https://www.kakuhan.com/works/service\">施工サービス</a></li><li><a class=\"sub_link\" href=\"https://www.