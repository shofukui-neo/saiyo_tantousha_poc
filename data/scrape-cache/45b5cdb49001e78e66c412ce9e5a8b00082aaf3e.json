{"url":"https://www.furukawact.co.jp/guideline/guidelines","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n\n  <head>\n    <meta charset=\"UTF-8\">\n    <title>募集要項一覧｜島根県出雲市の総合建設コンサルタント｜株式会社古川コンサルタント</title>\n    <meta name=\"keywords\" content=\"募集要項一覧,島根県,出雲市,総合建設コンサルタント,設計,測量,地質調査,建築補償,採用情報\" />\n    <meta name=\"description\" content=\"募集要項一覧 島根県出雲市の総合建設コンサルタント株式会社古川コンサルタントのホームページです。私たちだからこそできる「地域社会との共存」を目指し、農村・都市基盤整備の企画・調査から施工管理まで幅広いニーズに即応しています。\" />\n    <meta name=\"viewport\" content=\"width=device-width,initial-scale=1,minimum-scale=1\">\n    <meta name=\"format-detection\" content=\"telephone=no\">\n    <link rel=\"shortcut icon\" href=\"/favicon.ico\">\n    <!-- css -->\n    <link rel=\"stylesheet\" href=\"/theme/furukawa_consultant/js/drawer/drawer.min.css\">\n    <link rel=\"stylesheet\" href=\"/theme/furukawa_consultant/js/slick/slick.css\">\n    <link rel=\"stylesheet\" href=\"/theme/furukawa_consultant/js/slick/slick-theme.css\">\n    <link rel=\"stylesheet\" href=\"/theme/furukawa_consultant/js/colorbox/colorbox.css\">\n    <link rel=\"stylesheet\" href=\"/theme/furukawa_consultant/css/common.css\">\n    <link rel=\"stylesheet\" href=\"/theme/furukawa_consultant/css/import.css\">\n    <!-- js -->\n    <script src=\"/theme/furukawa_consultant/js/lib/jquery-1.11.2.min.js\"></script>\n    <script src=\"/theme/furukawa_consultant/js/jquery.matchHeight.js\"></script>\n    <script src=\"/theme/furukawa_consultant/js/drawer/drawer.min.js\"></script>\n    <script src=\"/theme/furukawa_consultant/js/drawer/iscroll.js\"></script>\n    <script src=\"/theme/furukawa_consultant/js/ofi.min.js\"></script>\n    <script src=\"/theme/furukawa_consultant/js/slick/slick.min.js\"></script>\n    <script src=\"/theme/furukawa_consultant/js/colorbox/jquery.colorbox-min.js\"></script>\n    <script src=\"/theme/furukawa_consultant/js/common.js\"></script>\n    <script type=\"text/javascript\">\n      var ua = navigator.userAgent.toLowerCase();\n      // iPhone\n      var isiPhone = (ua.indexOf('iphone') > -1);\n      // iPad\n      var isiPad = (ua.indexOf('ipad') > -1);\n      // Android\n      var isAndroid = (ua.indexOf('android') > -1) && (ua.indexOf('mobile') > -1);\n      // Android Tablet\n      var isAndroidTablet = (ua.indexOf('android') > -1) && (ua.indexOf('mobile') == -1);\n      // iOS\n      if(isiPhone || isAndroid) {\n        //document.write('<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">');\n        document.querySelector( 'meta[name=\"viewport\"]' ).setAttribute( 'content', 'width=device-width,initial-scale=1' );\n      }else if(isiPad) {\n        window.onorientationchange = directionCheck;\n      }else if(isAndroidTablet){\n        window.onresize = directionCheck;\n      }else{\n        //document.write('<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">');\n        document.querySelector( 'meta[name=\"viewport\"]' ).setAttribute( 'content', 'width=device-width,initial-scale=1' );\n      }\n      directionCheck();\n\n      function directionCheck() {\n        var direction = Math.abs(window.orientation);\n        if(direction == 90) {\n          //document.write('<meta name=\"viewport\" content=\"width=1200, maximum-scale=1.0\">');\n          document.querySelector( 'meta[name=\"viewport\"]' ).setAttribute( 'content', 'width=1200, maximum-scale=1' );\n        } else {\n          //document.write('<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">');\n          document.querySelector( 'meta[name=\"viewport\"]' ).setAttribute( 'content', 'width=device-width,initial-scale=1' );\n        }\n      }\n\n      $(function(){\n        $(window).on('orientationchange', (evt) => {\n          var angle;\n          angle = screen && screen.orientation && screen.orientation.angle;\n          if (angle == null) {\n            angle = window.orientation || 0;\n          }\n          if(angle % 180 !== 0) {\n            document.querySelector( 'meta[name=\"viewport\"]' ).setAttribute( 'content', 'width=device-width,initial-scale=1' );\n          } else {\n            if(isiPad){\n              document.querySelector( 'meta[name=\"viewport\"]' ).setAttribute( 'content', 'width=1200, maximum-scale=1' );\n            }\n          }\n        }).trigger('orientationchange');\n      });\n    </script>\n    <script>\n      (function(i,s,o,g,r,a,m){i['GoogleAnalyticsObject']=r;i[r]=i[r]||function(){\n        (i[r].q=i[r].q||[]).push(arguments)},i[r].l=1*new Date();a=s.createElement(o),\n        m=s.getElementsByTagName(o)[0];a.async=1;a.src=g;m.parentNode.insertBefore(a,m)\n                              })(window,document,'script','https://www.google-analytics.com/analytics.js','ga');\n\n      ga('create', 'UA-101754522-1', 'auto');\n      ga('send', 'pageview');\n    </script>\n    <!--[if lt IE 9]>\n<script src=\"http://html5shiv.googlecode.com/svn/trunk/html5.js\" type=\"text/javascript\"></script>\n<![endif]-->\n      </head>\n\n  <body class=\"drawer drawer--right\">\n\n    <!-- header -->\n    <header role=\"banner\" class=\"hearder\" id=\"is-headerFixed\">\n  <div class=\"l-container clearfix\">\n    <!-- logo -->\n    <div class=\"hearder__logo\">\n      <a href=\"/\">\n        <img src=\"/theme/furukawa_consultant/img/common/herder_logo_01.png\" alt=\"株式会社古川コンサルタント\" class=\"imgFit hearder__logo--01\">\n        <img src=\"/theme/furukawa_consultant/img/common/herder_logo_02.png\" alt=\"株式会社古川コンサルタント\" class=\"imgFit hearder__logo--02\">\n        <h1 class=\"dn\">株式会社古川コンサルタント</h1>\n      </a>\n    </div>\n    <!-- /logo -->\n    <!-- mobile menu -->\n    <div id=\"close\" class=\"hearder__menu dn-pc drawer-toggle\">\n      <img src=\"/theme/furukawa_consultant/img/common/btn_mobile_01.png\" alt=\"MENU\" class=\"imgFit\">\n    </div>\n    <!-- /mobile menu -->\n    <!-- global navi -->\n    <nav role=\"navigation\" class=\"gNav gNav-accordion drawer-nav\">\n  <ol class=\"clearfix drawer-menu\">\n    <li class=\"gNav__item gNav__item--normal dn-pc\">\n      <a href=\"/\">\n        <span class=\"gNav__item__inner\">\n          トップページ\n        </span>\n      </a>\n    </li>\n    <li class=\"gNav__item gNav__item--normal gNav__item--about\">\n      <a href=\"/about\">\n        <span class=\"gNav__item__inner\">\n          私たちの事業について\n        </span>\n      </a>\n    </li>\n    <li class=\"gNav__item gNav__item--normal gNav__item--news\">\n      <a href=\"/news/\">\n        <span class=\"gNav__item__inner\">\n          新着情報\n        </span>\n      </a>\n    </li>\n    <li class=\"gNav__item gNav__item--normal gNav__item--works\">\n      <a href=\"/casebook/casebooks/\">\n        <span class=\"gNav__item__inner\">\n          事業実績\n        </span>\n      </a>\n    </li>\n    <li class=\"gNav__item gNav__item--normal gNav__item--company\">\n      <a href=\"/company\">\n        <span class=\"gNav__item__inner\">\n          会社案内\n        </span>\n      </a>\n    </li>\n    <li class=\"gNav__item gNav__item--normal gNav__item--recruit\">\n      <a href=\"/recruit/index\">\n        <span class=\"gNav__item__inner\">\n          採用情報\n        </span>\n      </a>\n    </li>\n    <li class=\"gNav__item gNav__item--normal dn-pc\">\n            <a href=\"/recruit/voice\">\n              <span class=\"gNav__item__inner\">\n                先輩社員の声\n              </span>\n            </a>\n          </li>\n          <li class=\"gNav__item gNav__item--normal dn-pc\">\n            <a href=\"/guideline/guidelines/\">\n              <span class=\"gNav__item__inner\">\n                募集要項\n              </span>\n            </a>\n          </li>\n          <li class=\"gNav__item gNav__item--normal gNav__item--blog\">\n            <a href=\"/blog/\">\n              <span class=\"gNav__item__inner\">\n                社員ブログ\n              </span>\n            </a>\n          </li>\n    <li class=\"gNav__item gNav__item--normal dn-pc\">\n      <a href=\"/privacy\">\n        <span class=\"gNav__item__inner\">\n          プライバシーポリシー\n        </span>\n      </a>\n    </li>\n    <li class=\"gNav__item gNav__item--normal dn-pc\">\n      <a href=\"/information\">\n        <span class=\"gNav__item__inner\">\n          情報公開\n        </span>\n      </a>\n    </li>\n    <li class=\"gNav__item gNav__item--normal gNav__item--fb\">\n      <a href=\"https://www.facebook.com/profile.php?id=61553735414491\" target=\"_blank\">\n        <span class=\"dn-pc\">Facebook</span>\n      </a>\n    </li>\n    <li class=\"gNav__item gNav__item--normal gNav__item--contact\">\n            <a href=\"/contact/\">\n              <span class=\"gNav__item__inner\">\n                お問い合わせ\n              </span>\n            </a>\n          </li>\n    <li class=\"gNav__item gNav__item--close dn-pc\">\n      <a class=\"drawer-toggle\">\n        閉じる\n      </a>\n    </li>\n  </ol>\n</nav>    <!-- /global navi -->\n  </div>\n</header>    <!-- /header -->\n\n    <!-- main container -->\n    <main>\n      <div role=\"main\">\n                  <section>\n  <!-- h1 -->\n  <div class=\"sub-h1\">\n    <img src=\"/theme/furukawa_consultant/img/recruit/h1_bg.jpg\" alt=\"\" class=\"imgObjectFitCover\">\n    <div class=\"sub-h1__inner\">\n      <img src=\"/theme/furukawa_consultant/img/recruit/h1_item_02.png\" alt=\"募集要項 APPLICATION GUIDELINES\" class=\"imgFit\">\n      <h1 class=\"dn\">募集要項 APPLICATION GUIDELINES</h1>\n    </div>\n  </div>\n  <!-- /h1 -->\n  <!-- page link -->\n  <div id=\"is-pageLink\">\n    <div class=\"sub-pageLinkMenu\">\n      <span class=\"sub-btnPageLInkMenu\">MENU</span>\n      <span class=\"dn sub-btnPageLInkMenu sub-btnPageLInkMenu--close\">CLOSE</span>\n    </div>\n    <ul class=\"sub-pageLink sub-pageLinkHide\">\n      <li><a href=\"#new_grad\"><span>新卒<br>採用</span></a></li>\n      <li><a href=\"#internship\"><span>イン<br>ターン</span></a></li>\n      <li><a href=\"#mid_career\"><span>中途<br>採用</span></a></li>\n    </ul>\n  </div>\n  <!-- /page link -->\n  <!-- sub-container -->\n  <div class=\"sub-container\">\n                  <!-- section -->\n    <section class=\"l-container--w750 marginBottom90\" id=\"new_grad\">\n      <h2 class=\"mod-hl-01\">新卒採用情報</h2>\n                              <table class=\"mod-table-01\">\n                        <tr>\n              <th>募集職種</th>\n              <td>○技術職（土木設計）<br />\r\n○技術職（地質調査）<br />\r\n○技術職（建築補償）</td>\n            </tr>\n                                    <tr>\n              <th>仕事内容</th>\n              <td>【土木設計】<br />\r\n設計部にて、建設コンサルタントの設計関係を中心とした仕事を担当していただき<br />\r\nます。※パソコンはエクセル他、専用ソフトを使用します。<br />\r\n【地質調査】<br />\r\n地質部にて、地盤調査・土壌汚染調査関係を中心とした仕事を担当していただきま<br />\r\nす。※パソコンはエクセル他、専用ソフトを使用します。<br />\r\n【建築補償】<br />\r\n建築補償部にて、補償建物の調査関係を中心とした仕事を担当していただきます。<br />\r\n※パソコンはエクセル他、専用ソフトを使用します。</td>\n            </tr>\n                                    <tr>\n              <th>雇用形態</th>\n              <td>正社員</td>\n            </tr>\n                                    <tr>\n              <th>勤務地</th>\n              <td>【土木設計・地質調査・建築補償】本社・広島支店</td>\n            </tr>\n                                    <tr>\n              <th>会社説明見学会</th>\n              <td>毎月第3水曜日に開催します。<br />\r\n※事前にお問い合わせください。</td>\n            </tr>\n                                    <tr>\n              <th>選考方法</th>\n              <td>① 書類選考<br />\r\n② 面接（web）<br />\r\n③ 適性検査<br />\r\n④ 面接（来社）</td>\n            </tr>\n                                    <tr>\n              <th>給　与</th>\n              <td>大学215,000円、高専210,000円、短大・専修学校200,000円</td>\n            </tr>\n                                    <tr>\n              <th>諸手当</th>\n              <td>時間外・資格・通勤・家族</td>\n            </tr>\n                                    <tr>\n              <th>通勤手当</th>\n              <td>実費支給（上限20,000円）</td>\n            </tr>\n                                    <tr>\n              <th>賞　与</th>\n              <td>年２回　（６月・１２月）</td>\n            </tr>\n                                    <tr>\n              <th>勤務時間</th>\n              <td>8：30～17：30（休憩60分）</td>\n            </tr>\n                                    <tr>\n              <th>休日・休暇</th>\n              <td>土、日曜日（完全週休二日制）・祝日・年末年始・夏季【会社カレンダー・休日数125日：R6年度】<br />\r\n年次有給休暇（R4年度取得率：約70%）</td>\n            </tr>\n                                    <tr>\n              <th>各種社会保険</th>\n              <td>健康保険・厚生年金保険・雇用保険・企業年金・労災保険</td>\n            </tr>\n                                    <tr>\n              <th>福利厚生</th>\n              <td>各種レクリエーション・中小企業退職金共済・資格取得等費用補助制度・資格取得お祝い金制度・スポーツ同好会・つみたてNISA(20歳以上)・インフルエンザ予防接<br />\r\n種費用援助制度・ジョイメイトしまね<br />\r\n☆時間有給休暇制度　☆奨学金返還支援制度　☆家賃補助支援制度</td>\n            </tr>\n                                    <tr>\n              <th>研　修</th>\n              <td>各種研修・講習・資格取得制度有り</td>\n            </tr>\n                                    <tr>\n              <th>定　年</th>\n              <td>65歳</td>\n            </tr>\n                                    <tr>\n              <th>応募方法</th>\n              <td><a href=\"/contact/\">当HPのお問い合わせフォーム</a>か電話でお問い合わせ下さい。<br />\r\n電話：0853-21-5131　担当：総務部　藤原<br />\r\nマイナビでも募集しております。<a href=\"https://job.mynavi.jp/25/pc/search/corp232337/outline.html\" target=\"_blank\" rel=\"noopener noreferrer\">マイナビはこちらからどうぞ。</a></td>\n            </tr>\n                                                                                                                                                                                  </table>\n                    <div class=\"recruit-agAttention\">\n            <p>＜採用活動において提供された個人情報の取り扱いについて＞<br />\r\n　① 採用選考以外の目的で使用いたしません。<br />\r\n　② 個人情報は管理者のもと厳重に保持・管理を行い第三者に開示・漏洩いたしません。<br />\r\n　③ 選考が終了した個人情報については当社責任の下、破棄処分を行います。</p>\n          </div>\n                          <div class=\"recruit-agContactBtn\">\n          <a href=\"/contact/\" class=\"mod-btn-01 mod-btn-w450\">\n            <span class=\"mod-btn-01__inner\">応募・お問い合わせはこちら</span>\n          </a>\n        </div>\n          </section>\n    <!-- /section -->\n              <!-- section -->\n    <section class=\"l-container--w750 marginBottom90\" id=\"internship\">\n      <h2 class=\"mod-hl-01\">インターンシップ情報</h2>\n                              <table class=\"mod-table-01\">\n                        <tr>\n              <th>応募対象</th>\n              <td>当社または建設コンサルタント業に興味がある方</td>\n            </tr>\n                                    <tr>\n              <th>実習期間</th>\n              <td>毎週水・木曜日に開催します。（2日間、1日も可）<br />\r\n※事前にお問い合わせください。</td>\n            </tr>\n                                    <tr>\n              <th>実習場所</th>\n              <td>本　社（公共交通機関の料金支給あり）</td>\n            </tr>\n                                    <tr>\n              <th>申し込み方法</th>\n              <td><a href=\"/contact/\">当HPのお問い合わせフォーム</a>か電話でお問い合わせ下さい。<br />\r\n電話：0853-21-5131　担当：総務部　藤原</td>\n            </tr>\n                                                                                                                                                                                                                                                                                                                                              </table>\n                    <div class=\"recruit-agAttention\">\n            <p>＜個人情報の取り扱いについて＞<br />\r\n　① インターンシップ制度以外の目的で使用いたしません。<br />\r\n　② 個人情報は管理者のもと厳重に保持・管理を行い第三者に開示・漏洩いたしません。<br />\r\n　③ インターンシップ制度が終了した個人情報については当社責任の下、破棄処分を行います。</p>\n          </div>\n                          <div class=\"recruit-agContactBtn\">\n          <a href=\"/contact/\" class=\"mod-btn-01 mod-btn-w450\">\n            <span class=\"mod-btn-01__inner\">申し込み・お問い合わせはこちら</span>\n          </a>\n        </div>\n          </section>\n    <!-- /section -->\n              <!-- section -->\n    <section class=\"l-container--w750 marginBottom90\" id=\"mid_career\">\n      <h2 class=\"mod-hl-01\">中途者採用情報</h2>\n                              <table class=\"mod-table-01\">\n                        <tr>\n              <th>募集職種</th>\n              <td>○技術職（土木設計）<br />\r\n○技術職（建築補償）</td>\n            </tr>\n                                    <tr>\n              <th>仕事内容</th>\n              <td>【土木設計】<br />\r\n設計部にて、建設コンサルタントの設計関係を中心とした仕事を担当していただき<br />\r\nます。※パソコンはエクセル他、専用ソフトを使用します。<br />\r\n【建築補償】<br />\r\n建築補償部にて、補償建物の調査関係を中心とした仕事を担当していただきます。<br />\r\n※パソコンはエクセル他、専用ソフトを使用します。</td>\n            </tr>\n                                    <tr>\n              <th>雇用形態</th>\n              <td>正社員</td>\n            </tr>\n                                    <tr>\n              <th>勤務地</th>\n              <td>【土木設計・建築補償】本社・広島支店</td>\n            </tr>\n                                    <tr>\n              <th>マイカー通勤可</th>\n              <td>駐車場あり</td>\n            </tr>\n                                    <tr>\n              <th>年　齢</th>\n              <td>年齢不問（ただし定年年齢65歳を上限とする）</td>\n            </tr>\n                                    <tr>\n              <th>必要な資格等</th>\n              <td>【土木設計】<br />\r\n技術士・RCCM 優遇　入社後資格取得を目指す<br />\r\n【建築補償】<br />\r\n一級建築士、二級建築士、補償業務管理士（物件部門）優遇　入社後資格取得を目指す</td>\n            </tr>\n                                    <tr>\n              <th>試用期間</th>\n              <td>6か月</td>\n            </tr>\n                                    <tr>\n              <th>給　与</th>\n              <td>【土木設計】250,000円～500,000円<br />\r\n【建築補償】250,000円～350,000円</td>\n            </tr>\n                                    <tr>\n              <th>諸手当</th>\n              <td>時間外・資格・通勤・家族<br />\r\n＜資格手当例＞<br />\r\n【土木設計】RCCM ：10,000円<br />\r\n【建築補償】一級建築士 ：10,000円</td>\n            </tr>\n                                    <tr>\n              <th>通勤手当</th>\n              <td>実費支給（上限20,000円）</td>\n            </tr>\n                                    <tr>\n              <th>賞　与</th>\n              <td>年２回　（６月・１２月）</td>\n            </tr>\n                                    <tr>\n              <th>勤務時間</th>\n              <td>8：30～17：30（休憩60分）</td>\n            </tr>\n                                    <tr>\n              <th>休日・休暇</th>\n              <td>土、日曜日（完全週休二日制）・祝日・年末年始・夏季【会社カレンダー・休日数125日：R6年度】<br />\r\n年次有給休暇（R4年度取得率：約70%）</td>\n            </tr>\n                                    <tr>\n              <th>各種社会保険</th>\n              <td>健康保険・厚生年金保険・雇用保険・企業年金・労災保険</td>\n            </tr>\n                                    <tr>\n              <th>福利厚生</th>\n              <td>各種レクリエーション・中小企業退職金共済・資格取得等費用補助制度・資格取得お祝い金制度・スポーツ同好会・つみたてNISA(20歳以上)・<br />\r\nインフルエンザ予防接種費用援助制度・ジョイメイトしまね<br />\r\n☆時間有給休暇制度</td>\n            </tr>\n                                    <tr>\n              <th>研　修</th>\n              <td>各種研修・講習・資格取得制度有り</td>\n            </tr>\n                                    <tr>\n              <th>定　年</th>\n              <td>65歳</td>\n            </tr>\n                                    <tr>\n              <th>応募方法</th>\n              <td><a href=\"/contact/\">当HPのお問い合わせフォーム</a>か電話でお問い合わせ下さい。<br />\r\n電話：0853-21-5131　担当：総務部　藤原</td>\n            </tr>\n                                                                                                                                                          </table>\n                    <div class=\"recruit-agAttention\">\n            <p>＜採用活動において提供された個人情報の取り扱いについて＞<br />\r\n　① 採用選考以外の目的で使用いたしません。<br />\r\n　② 個人情報は管理者のもと厳重に保持・管理を行い第三者に開示・漏洩いたしません。<br />\r\n　③ 選考が終了した個人情報については当社責任の下、破棄処分を行います。</p>\n          </div>\n                          <div class=\"recruit-agContactBtn\">\n          <a href=\"/contact/\" class=\"mod-btn-01 mod-btn-w450\">\n            <span class=\"mod-btn-01__inner\">応募・お問い合わせはこちら</span>\n          </a>\n        </div>\n          </section>\n    <!-- /section -->\n              <!-- section -->\n    <section class=\"l-container--w750 marginBottom90\" id=\"\">\n      <h2 class=\"mod-hl-01\">中途採用情報（急募）</h2>\n                              <table class=\"mod-table-01\">\n                        <tr>\n              <th>募集職種</th>\n              <td>〇技術職（地質調査）</td>\n            </tr>\n                                    <tr>\n              <th>仕事内容</th>\n              <td>【地質調査】<br />\r\n地質部にて、公共事業に伴う構造物設計に必要な基礎地盤データを得ることを目的とした地質調査及び公共工事による影響で、近隣排水施設を流れる水路や地下水等の水質調査等の仕事を担当していただきます。</td>\n            </tr>\n                                    <tr>\n              <th>雇用形態</th>\n              <td>正社員</td>\n            </tr>\n                                    <tr>\n              <th>勤務地</th>\n              <td>本社・広島支店・山口支店</td>\n            </tr>\n                                    <tr>\n              <th>マイカー通勤可</th>\n              <td>駐車場あり</td>\n            </tr>\n                                    <tr>\n              <th>年齢</th>\n              <td>年齢不問（ただし定年年齢65歳を上限とする）</td>\n            </tr>\n                                    <tr>\n              <th>必要な資格等</th>\n              <td>技術士<br />\r\n　応用理学部門地質　または　建設部門土質及び基礎</td>\n            </tr>\n                                    <tr>\n              <th>試用期間</th>\n              <td>６か月</td>\n            </tr>\n                                    <tr>\n              <th>給与</th>\n              <td>年俸制　420万円～600万円</td>\n            </tr>\n                                    <tr>\n              <th>諸手当</th>\n              <td>月給に固定残業代（月40時間相当）、資格手当、家族手当を含む</td>\n            </tr>\n                                    <tr>\n              <th>通勤手当</th>\n              <td>実費支給（上限20,000円）</td>\n            </tr>\n                                    <tr>\n              <th>賞与</th>\n              <td>なし</td>\n            </tr>\n                                    <tr>\n              <th>勤務時間</th>\n              <td>8：30～17：30（休憩60分）</td>\n            </tr>\n                                    <tr>\n              <th>休日・休暇</th>\n              <td>土、日曜日（完全週休二日制）・祝日・年末年始・夏季【会社カレンダー・休日数125日：R6年度】<br />\r\n年次有給休暇（R4年度取得率：約70%）</td>\n            </tr>\n                                    <tr>\n              <th>各種社会保険</th>\n              <td>健康保険・厚生年金保険・雇用保険・企業年金・労災保険</td>\n            </tr>\n                                    <tr>\n              <th>福利厚生</th>\n              <td>各種レクリエーション・中小企業退職金共済・資格取得等費用補助制度・資格取得お祝い金制度・スポーツ同好会・つみたてNISA(20歳以上)・<br />\r\nインフルエンザ予防接種費用援助制度・ジョイメイトしまね<br />\r\n☆時間有給休暇制度</td>\n            </tr>\n                                    <tr>\n              <th>研修</th>\n              <td>各種研修・講習・資格取得制度有り</td>\n            </tr>\n                                    <tr>\n              <th>定年</th>\n              <td>65歳</td>\n            </tr>\n                                    <tr>\n              <th>応募方法</th>\n              <td>当HPのお問い合わせフォームか電話でお問い合わせ下さい。<br />\r\n電話：0853-21-5131　担当：総務部　藤原</td>\n            </tr>\n                                                                                                                                                          </table>\n                    <div class=\"recruit-agAttention\">\n            <p>＜採用活動において提供された個人情報の取り扱いについて＞<br />\r\n　① 採用選考以外の目的で使用いたしません。<br />\r\n　② 個人情報は管理者のもと厳重に保持・管理を行い第三者に開示・漏洩いたしません。<br />\r\n　③ 選考が終了した個人情報については当社責任の下、破棄処分を行います。</p>\n          </div>\n                          <div class=\"recruit-agContactBtn\">\n          <a href=\"/contact/\" class=\"mod-btn-01 mod-btn-w450\">\n            <span class=\"mod-btn-01__inner\">応募・お問い合わせはこちら</span>\n          </a>\n        </div>\n          </section>\n    <!-- /section -->\n        <!-- foot-btn -->\n    <div class=\"l-container recruit-footBtn recruit-footBtn--sg clearfix marginTop100\">\n      <a href=\"/recruit/voice\" class=\"recruit-footBtn__btn recruit-footBtn__btn--mes hoverNot\">\n        <span class=\"dn\">先輩社員の声 MESSAGE</span>\n      </a>\n    </div>\n    <!-- /foot-btn -->\n  </div>\n  <!-- /sub-container -->\n</section>              </div>\n    </main>\n    <!-- /main container -->\n    \n    <!-- footer -->\n    <footer role=\"contentinfo\" class=\"footer\">\n  <!-- footer-menu -->\n  <div class=\"footerMenu\">\n    <div class=\"footerMenu__inner l-container\">\n      <div class=\"footerMenuBtn--home\">\n        <a href=\"/\" class=