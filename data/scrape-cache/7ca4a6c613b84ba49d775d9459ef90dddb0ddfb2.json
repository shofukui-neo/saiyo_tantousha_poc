                  <div>\r\n                    <dl class=\"recruit-corp-3min-item__list\">\r\n                      <div>\r\n                        <dt>2026年</dt>\r\n                        <dd class=\"recruit-corp-3min-item__num\"><span>47</span>名</dd>\r\n                      </div>\r\n                      <div>\r\n                        <dt>2025年</dt>\r\n                        <dd class=\"recruit-corp-3min-item__num\"><span>38</span>名</dd>\r\n                      </div>\r\n                      <div>\r\n                        <dt>2024年</dt>\r\n                        <dd class=\"recruit-corp-3min-item__num\"><span>46</span>名</dd>\r\n                      </div>\r\n                    </dl>\r\n                  </div>\r\n                </div>\r\n              </div>\r\n            </div>\r\n            <div class=\"recruit-corp-grid__item -col-12\">\r\n              <div class=\"recruit-corp-3min-item\">\r\n                <h3 class=\"recruit-corp-3min-item__ttl u-mb-15\">文理の割合</h3>\r\n                <div class=\"recruit-corp-3min-item__contents\">\r\n                  <div class=\"recruit-corp-3min-item__grid\">\r\n                    <div>\r\n                      <h4 class=\"recruit-corp-3min-item__ttl-sub\">2024年</h4>\r\n                      <div class=\"recruit-corp-3min-item__img\"><img src=\"/recruit/assets/img_item14.svg\" alt=\"4割理系 6割文系\" loading=\"lazy\"></div>\r\n                    </div>\r\n                    <div>\r\n                      <h4 class=\"recruit-corp-3min-item__ttl-sub\">2025年</h4>\r\n                      <div class=\"recruit-corp-3min-item__img\"><img src=\"/recruit/assets/img_item14.svg\" alt=\"4割理系 6割文系\" loading=\"lazy\"></div>\r\n                    </div>\r\n                    <div>\r\n                      <h4 class=\"recruit-corp-3min-item__ttl-sub\">2026年</h4>\r\n                      <div class=\"recruit-corp-3min-item__img\"><img src=\"/assets/img/recruit/corporate/3min/img_item04.svg\" alt=\"5割理系 5割文系\" loading=\