r\n\t\t<script src=\"js/respond.min.js\"></script>\r\n\t<![endif]-->\r\n</head>\r\n<body id=\"page-top\">\r\n\r\n<!-- Google Tag Manager (noscript) -->\r\n<noscript>\r\n<iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-5SW5XMB\"\r\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe>\r\n</noscript>\r\n<!-- End Google Tag Manager (noscript) -->\r\n<header class=\"pc-header\">\r\n  <div class=\"header__top-area\">\r\n    <div class=\"header__logo\"> <a href=\"../../index.html\"><img src=\"../common/img/ricruit_header_logo.png\" alt=\"株式会社浜銀総合研究所\"></a>\r\n      <p class=\"sp-header_logo_txt\">採用情報サイト</p>\r\n    </div>\r\n    <nav class=\"header__navi\">\r\n      <ul class=\"header_navi-parent\">\r\n        <li class=\"\"> <a href=\"../index.html\">TOP</a> </li>\r\n        <li class=\"\"><a href=\"../message/index.html\">MESSAGE</a> </li>\r\n        <li class=\"pc-header_active\"><a href=\"index.html\">INTERVIEW</a> </li>\r\n        <li class=\"\"><a href=\"../project/index.html\">PROJECT</a> </li>\r\n      </ul>\r\n      <div class=\"pc-header_btn_wrap\">\r\n        <p class=\"btn shinjin-adopt\"><a href=\"../new_graduate/index.html\">新卒採用</a></p>\r\n        <p class=\"btn career-adopt\"><a class=\"disabled\">キャリア採用</a></p>\r\n      </div>\r\n    </nav>\r\n  </div>\r\n</header>\r\n<header class=\"sp-header\">\r\n  <div class=\"sp-header__hamagin\">\r\n    <div class=\"sp-header_logo_icn\"><img src=\"../common/img/ricruit_header_logo.png\" alt=\"株式会社浜銀総合研究所\"></div>\r\n    <p class=\"sp-header_logo_txt\">採用情報サイト</p>\r\n  </div>\r\n  <div class=\"sp-header_btn_wrap\">\r\n    <p class=\"btn shinjin-adopt\"><a href=\"../new_graduate/index.html\">新卒採用</a></p>\r\n    <p class=\"btn career-adopt\"><a class=\"disabled\">キャリア採用</a></p>\r\n  </div>\r\n</header>\r\n<div class=\"neader__nav-bg\">\r\n  <div id=\"header__nav-btn\">\r\n    <div id=\"header__nav-btn-inner\"> <span></span> <span></span> <span></span> </div>\r\n  </div>\r\n  <nav class=\"sp_header__nav-list\">\r\n    <ul>\r\n      <li></li>\r\n      <li class=\"btn-arrow01\"><a href=\"../index.html\">TOP</a> </li>\r\n      <li class=\"btn-arrow01\"><a href=\"../message/index.html\">MESSAGE</a> </li>\r\n      <li class=\"btn-arrow01\"> <a href=\"index.html\">INTERVIEW</a> </li>\r\n      <li class=\"btn-arrow01\"><a href=\"../project/index.html\">PROJECT</a></li>\r\n    </ul>\r\n    <div class=\"sp-header_btn_wrap\">\r\n      <p class=\"btn shinjin-adopt\"><a href=\"../new_graduate/index.html\">新卒採用</a></p>\r\n      <p class=\"btn career-adopt\"><a class=\"disabled\">キャリア採用</a></p>\r\n    </div>\r\n  </nav>\r\n</div>\r\n<!--/header-->\r\n<section class=\"mv\"> \r\n  <!--パンくずリスト-->\r\n  <div class=\"breadcrumb\">\r\n    <ul>\r\n      <li><u><a href=\"../index.html\">浜銀総合研究所 採用情報サイト トップ</a></u></li>\r\n      <li><a>INTERVIEW</a></li>\r\n      <li>松本 靖生</li>\r\n    </ul>\r\n  </div>\r\n  <div class=\"mv_ttl-wrap\">\r\n    <h1 class=\"mv__h1\">INTERVIEW</h1>\r\n    <p class=\"mv_sub-ttl\">先輩社員インタビュー</p>\r\n  </div>\r\n</section>\r\n<section class=\"recruit_mainarea\">\r\n  <div class=\"interview__ttl-area\">\r\n    <div class=\"interview__ttl-inner\">\r\n<!--\r\n      <div class=\"interview__ttl-img\"><img src=\"img/recruit_interview02_img01a.jpg\" alt=\"経営コンサルティング部 松本靖生\"></div>\r\n-->\r\n      <div class=\"interview__ttl-content\">\r\n        <p class=\"interview__ttl-txt\">若手のうちから、<br class=\"pc-in\">\r\n          主体的にプロジェクトを推進できる。</p>\r\n        <p class=\"interview__ttl-name\">経営コンサルティング部　松本靖生</p>\r\n        <p class=\"interview__ttl\">INTERVIEW 02</p>\r\n      </div>\r\n    </div>\r\n  </div>\r\n  <div class=\"interview__content-area area01\">\r\n    <div class=\"interview__content-area-wrap\">\r\n      <div class=\"interview__content-ttl-wrap\">\r\n        <p class=\"interview__content-ttl ttl-line02\">社員のモチベーションを高めることが、事業成長へつながる。</p>\r\n        <span class=\"ttl-line-after01\"></span> </div>\r\n      <div class=\"interview__content-txt\" style=\"line-height:2;\">私は街づくりや地域創生に興味があり、学生時代にさまざまな学外の活動に参加していました。ある東北の被災地を訪問するプログラムに参加した際、経営者の話を聞いたり、工場を見学させてもらったりするなかで、経営者の地元への強い想いや企業戦略に触れ、経営に興味を持ちました。経営で重要なヒト、モノ、カネのなかで私が特に興味をもったのはヒト。従業員のモチベーションを高めることが、企業力の底上げにつながることを実感し、将来は人材コンサルタントになり、すべての従業員が活躍できるような仕組みを作りたいと思ったのです。<br>\r\n       当社を選んだのは、若手でもアシスタント業務からスタートするのではなく、最初から大きな仕事を任せてくれる環境だったから。私は神奈川生まれ、神奈川育ちで、地元へ貢献できるのも魅力でした。\r\n      </div>\r\n    </div>\r\n  </div>\r\n  <div class=\"interview__content-area area02\">\r\n    <div class=\"interview__content-area-wrap\">\r\n      <div class=\"interview__content-ttl-wrap\">\r\n        <p class=\"interview__content-ttl ttl-line02\">お客さまのパートナーとして、一緒に課題を解決する喜び。</p>\r\n        <span class=\"ttl-line-after01\"></span> </div>\r\n\r\n        <div class=\"interview__content-txt\" style=\"line-height:2;\">入社前から、人事系のコンサルティングに携わりたいと希望を伝え、現在、希望通りに経営コンサルティング部で評価制度の策定、給与体系の見直しなど人事面から企業をサポートしています。企業の課題はさまざまですが、今までは社長が独断で決めていたが、社員が増えてきたので、社員が納得できる評価制度を確立したい、過去に自社で人事制度を作成・改定したものの思うように機能していないので、きちんと運用できるようメンテナンスを図りたい等、企業の抱える課題のニーズによって様々な依頼を受けています、。評価者の基準を合わるための研修、セクハラ、パワハラへ対処するための研修など、企業の状況にあわせてプログラムを考え実施したり、各種法令改正に伴って社内規定の整備をしたりと、仕事の幅がどんどん広がっています。人事関連の領域の知識のほか、業界に関する知識や法的な知識等多岐にわたる分野の知見が必要ですので、常に勉強が欠かせません。</div>\r\n\r\n<!--\r\n      <div class=\"interview__content-txt-wrap\">\r\n        <div class=\"interview__content-txt\" style=\"line-height:2;\">入社前から、人事系のコンサルティングに携わりたいと希望を伝え、現在、希望通りに経営コンサルティング部で評価制度の策定、給与体系の見直しなど人事面から企業をサポートしています。企業の課題はさまざまですが、今までは社長が独断で決めていたが、社員が増えてきたので、社員が納得できる評価制度を確立したい、過去に自社で人事制度を作成・改定したものの思うように機能していないので、きちんと運用できるようメンテナンスを図りたい等、企業の抱える課題のニーズによって様々な依頼を受けています、。評価者の基準を合わるための研修、セクハラ、パワハラへ対処するための研修など、企業の状況にあわせてプログラムを考え実施したり、各種法令改正に伴って社内規定の整備をしたりと、仕事の幅がどんどん広がっています。人事関連の領域の知識のほか、業界に関する知識や法的な知識等多岐にわたる分野の知見が必要ですので、常に勉強が欠かせません。</div>\r\n        <div class=\"interview__content-txt-img pc\"><img src=\"img/recruit_interview02_img02a.jpg\" alt=\"経営コンサルティング部 松本靖生\"></div>\r\n      </div>\r\n-->\r\n\r\n    </div>\r\n  </div>\r\n  <div class=\"interview__content-area area03\">\r\n    <div class=\"interview__content-area-wrap\">\r\n      <div class=\"interview__content-ttl-wrap\">\r\n        <p class=\"interview__content-ttl ttl-line02\">若手のうちから、プロジェクトマネジメントを経験。</p>\r\n        <span class=\"ttl-line-after01\"></span> </div>\r\n      <div class=\"interview__content-txt\" style=\"line-height:2;\">最初は「浜銀さんのお力を借りたい」と呼ばれていたのが、お客さまと打ち合わせを重ね制度が出来上がった時に、「松本さんのおかげでいい制度ができた」と言ってくださることが何よりの生きがいになっています。お客さまのお役にたてること、コンサルタントとして認められることが嬉しくて、仕事をしているようなものです。<br>\r\n       人事制度を変えたからといって、魔法のように、すぐに企業が変わるわけではなく、変化が実感できるようになるまで、3～5年の時間がかかります。制度を作って終わりではなく、研修の講師を務めたり、アドバイザーとしてかかわったり、クライアントと一緒に変化を生み出していけるのがうれしいです。入社からまだ日が浅いですが、ほとんどの案件を私がプロジェクトマネジャーとして推進していて、入社前のイメージ通りの働き方ができ嬉しいです。\r\n    </div>\r\n  </div>\r\n  <div class=\"interview__content-area area04\">\r\n    <div class=\"interview__content-area-wrap\">\r\n      <div class=\"interview__content-ttl-wrap\">\r\n        <p class=\"interview__content-ttl ttl-line02\">大学時代に将来の仕事の原動力となる体験を。</p>\r\n        <span class=\"ttl-line-after01\"></span> </div>\r\n      <div class=\"interview__content-txt\" style=\"line-height:2;\">学生時代に、仕事の原動力になる経験をしてもらいたいと思っています。裁量が大きい、年収が高いとかも企業選びの大切なポイントですが、自身の経験に基づいて「この課題を解決したい」「この領域を突き詰めたい」と心からやりたいと思うことがあれば、入社後もずっと成長し続けられると思います。<br>\r\n       あなたのやりたいことが、当社のビジョンや方向性と同じなら、ぜひ入社して欲しいですね。特別な知識やスキルは必要ありません。情熱だけ抱いて入社してください。あなたの想いを実現できるよう、全力でバックアップしていきます。\r\n      </div>\r\n    </div>\r\n  </div>\r\n  <!--他の社員のインタビューを読む-->\r\n  <section class=\"interview__onther-content\">\r\n    <h3 class=\"interview__onther-ttl\">他の社員のインタビューを読む</h3>\r\n    <ul class=\"interview__onther-list-wrap\">\r\n      <li class=\"interview__onther-item\"> <a href=\"index.html\">\r\n        <div class=\"interview__onther-item-wrap\">\r\n          <div class=\"interview__onther-item-img\"><img src=\"img/recruit_interview-side_img01.jpg\" alt=\"情報戦略コンサルティング部 太田葉月\"></div>\r\n          <p class=\"interview__onther-item-ttl\">情報戦略コンサルティング部</p>\r\n          <p class=\"interview__onther-item-txt\">勘や経験で判断していた仕事を、データ分析を活用し基準を可視化。</p>\r\n        </div>\r\n        </a> </li>\r\n      <li class=\"interview__onther-item\"> <a href=\"index3.html\">\r\n        <div class=\"interview__onther-item-wrap\">\r\n          <div class=\"interview__onther-item-img\"><img src=\"img/recruit_interview-side_img03.jpg\" alt=\"地域戦略研究部 江川湧\"></div>\r\n          <p class=\"interview__onther-item-ttl\">地域戦略研究部</p>\r\n          <p class=\"interview__onther-item-txt\">自治体の意思決定に携われる。やりがいがあるし、面白い。</p>\r\n        </div>\r\n        </a> </li>\r\n      <li class=\"interview__onther-item\"> <a href=\"index4.html\">\r\n        <div class=\"interview__onther-item-wrap\">\r\n          <div class=\"interview__onther-item-img\"><img src=\"img/recruit_interview-side_img04.jpg\" alt=\"調査部　遠藤裕基\"></div>\r\n          <p class=\"interview__onther-item-ttl\">調査部</p>\r\n          <p class=\"interview__onther-item-txt\">「地域」×「雇用」を切り口に、今までなかった新しい情報・価値を提供。</p>\r\n        </div>\r\n        </a> </li>\r\n    </ul>\r\n  </section>\r\n</section>\r\n<footer>\r\n  <div class=\"footer_contents\">\r\n    <div class=\"footer_contents-inner\">\r\n      <div class=\"footer_contents_ttl\">\r\n        <p class=\"footer_contents_main-ttl\">新卒採用情報</p>\r\n        <p class=\"footer_contents_sub-ttl ttl-line01\">NEW GRADUATE</p>\r\n        <span class=\"ttl-line-after01\"></span> </div>\r\n      <div class=\"footer_contents_btn-wrap\">\r\n        <div class=\"footer_contents-btn shinjin-adopt\">\r\n          <p class=\"btn btn-arrow04\"><a href=\"../new_graduate/index.html\">新卒採用情報はこちら</a></p>\r\n        </div>\r\n        <div class=\"footer_contents-btn career-adopt\">\r\n          <p>\r\n\r\n</p>\r\n        </div>\r\n      </div>\r\n      <div class=\"footer_contents_ttl career-adopt\">\r\n        <p class=\"footer_contents_main-ttl\">キャリア採用情報</p>\r\n        <p class=\"footer_contents_sub-ttl ttl-line01\">CAREER</p>\r\n        <span class=\"ttl-line-after01\"></span> </div>\r\n      <p class=\"footer_contents_txt\">下記までお問合せください。</p>\r\n      <div class=\"footer_contents_apoint-wrap\">\r\n        <div class=\"footer_contents_apoint_txt\">\r\n          <p class=\"footer_contents_apoint_txt-xsize\">お問合せ・ご相談は<span class=\"sp-in\">...</span></p>\r\n          お電話にてお伺いいたします。<br>\r\n          お気軽にご連絡ください。</div>\r\n        <span class=\"footer_contents_apoint_tel tel-link\" data-action=\"call\" data-tel=\"tel:0452252374\">\r\n        <div class=\"footer_contents_apoint_tel-wrap\">\r\n          <div class=\"footer_contents_tel-icn\"><img src=\"../common/img/tel_btn_icn.png\" alt=\"045-225-2374\"></div>\r\n          <div class=\"footer_contents_tel-info-wrap\">\r\n            <p class=\"footer_contents_tel-number\">045-225-2374</p>\r\n            <p class=\"footer_contents_tel-personnel\">株式会社浜銀総合研究所　企画総務部</p>\r\n          </div>\r\n        </div>\r\n        </span> </div>\r\n    </div>\r\n  </div>\r\n  <div class=\"footer-navi-wrap\">\r\n    <nav class=\"top__footer-navi\">\r\n      <ul>\r\n        <li class=\"footer_btn-arrow01\"><a href=\"../../html/site_map\">サイトマップ</a></li>\r\n        <li class=\"footer_btn-arrow01\"><a href=\"../../html/regulation/index.html\">免責・利用規定</a></li>\r\n        <li class=\"footer_btn-arrow01\"><a href=\"../../html/security_policy/index.html\">情報セキュリティ基本方針</a></li>\r\n        <li class=\"footer_btn-arrow01\"><a href=\"../../html/regulation/person.html\">個人情報保護について</a></li>\r\n      </ul>\r\n    </nav>\r\n    <p class=\"footer__txt\"> 【浜銀総合研究所は、横浜銀行グループのシンクタンク・コンサルティング会社。地元神奈川、横浜、川崎、東京に密着した調査から全国規模および海外にいたるまでの専門的研究を手がけています。】<br>\r\n      このホームページに関するご意見、お問合せは、<a href=\"../../html/inquiry/inquiry.html\">こちら</a>までお願いします。このホームページの内容を、許可無く転載・複製することを禁止します。 </p>\r\n    <small>Copyright 2019 (C) Hamagin Research Institute,Ltd.All rights reserved.</small></div>\r\n</footer>\r\n<div class=\"page-top_btn\"> <a href=\"#page-top\">&nbsp;</a> </div>\r\n</body>\r\n</html>","finalUrl":"https://www.yokohama-ri.co.jp/recruit/brain/index2.html","rendered":false,"_cachedAt":"2026-06-22T21:47:06.802Z"}