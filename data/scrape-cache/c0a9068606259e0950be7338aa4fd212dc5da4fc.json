alc(.667em + 2px) calc(1.333em + 2px);font-size:1.125em}.wp-block-file__button{background:#32373c;color:#fff;text-decoration:none}\n/*# sourceURL=/wp-includes/css/classic-themes.min.css */\n</style>\n\n\n<link rel='stylesheet' id='twentynineteen-style-css' href='https://www.alae.co.jp/cms_21_ala/wp-content/themes/alae/style.css?ver=1.0' media='all' />\n<link rel='stylesheet' id='twentynineteen-print-style-css' href='https://www.alae.co.jp/cms_21_ala/wp-content/themes/alae/print.css?ver=1.0' media='print' />\n<link rel=\"canonical\" href=\"https://www.alae.co.jp/\" />\n<link rel='shortlink' href='https://www.alae.co.jp/' />\n<link rel=\"icon\" href=\"https://www.alae.co.jp/favicon.ico\"><link rel=\"apple-touch-icon\" sizes=\"180x180\" href=\"https://www.alae.co.jp/apple-touch-icon-180x180.png\"><title>株式会社エイリイ・エンジニアリング</title>\r\n<meta name=\"keywords\" content=\"エイリイ・エンジニアリング,航空機搭載機器,軌道衛星ユニット,航空,防衛,防衛産業,航空機,無線\" />\r\n<meta name=\"description\" content=\"株式会社エイリイ・エンジニアリングは、空を守るためのワンチームとして国防のための製品開発や技術を提供する「防衛産業」を行っています。国防の一端を担う企業として、「いのちを守る産業」を信念に、恒久的な空の平和を目指していきます。\" />\r\n<link rel=\"stylesheet\" type=\"text/css\" media=\"all\" href=\"https://www.alae.co.jp/css/style.css\" />\r\n<!-- Google Tag Manager -->\r\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\r\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\r\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\r\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\r\n})(window,document,'script','dataLayer','GTM-TVS4PMP');</script>\r\n<!-- End Google Tag Manager -->\r\n</head>\r\n\r\n<body>\r\n<!-- Google Tag Manager (noscript) -->\r\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-TVS4PMP\"\r\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\r\n<!-- End Google Tag Manager (noscript) -->\r\n\r\n<header>\r\n    <!-- スマホ用ヘッダー -->\r\n      <div class=\"cp_cont\">\r\n        <h1 id=\"sp_logo\">\r\n          <a href=\"https://www.alae.co.jp/\"><img src=\"https://www.alae.co.jp/common/img/hd_logo.svg\" alt=\"株式会社エイリイ・エンジニアリング\"/></a></h1>\r\n        <div class=\"cp_offcm01\">\r\n          <input type=\"checkbox\" id=\"cp_toggle01\" value=\"\" />\r\n          <label for=\"cp_toggle01\"><span></span><span></span><span></span></label>\r\n          <div class=\"cp_menu\">\r\n            <ul class=\"ff_ul\">\r\n              <li class=\"ff_li\"><a href=\"https://www.alae.co.jp/service/\">事業内容</a></li>\r\n              <li class=\"ff_li\"><a href=\"https://www.alae.co.jp/belief/\">エイリイ・エンジニアリングの理念</a></li>\r\n              <li class=\"ff_li\"><a href=\"https://www.alae.co.jp/company/\">会社概要</a></li>\r\n              <li class=\"ff_li\"><a href=\"https://www.alae.co.jp/recruit/\">採用情報</a></li>\r\n              <li class=\"ff_li\"><a href=\"https://www.alae.co.jp/topics/\">お知らせ</a></li>\r\n              <li class=\"ff_li\"><a href=\"https://www.alae.co.jp/sitemap/\">サイトマップ</a></li>\r\n              <li class=\"ff_li\"><a href=\"https://www.alae.co.jp/privacy/\">プライバシーポリシー</a></li>\r\n              <li class=\"ff_li\"><a href=\"https://www.alae.co.jp/contact/\">お問い合わせ</a></li>\r\n            </ul>\r\n          </div>\r\n        </div>\r\n      </div>\t\r\n  </header>    \r\n    <main>\r\n    <section class=\"mv\">\r\n\t\t  <div class=\"mv_inner\">\r\n              <video src=\"https://www.alae.co.jp/img/movie.mp4\" playsinline loop autoplay muted></video>\r\n\t\t  </div>\r\n    <div class=\"pc_block\">\r\n      <div class=\"hidden_box re_cover mv_copy\">\r\n    <input type=\"checkbox\" id=\"label1\" autocomplete=\"off\" />\r\n    <label for=\"label1\"></label>\r\n    <div class=\"hidden_show\">\r\n      <div class=\"all\"><a href=\"https://www.alae.co.jp/recruit/\"></a>\r\n      <!--非表示ここから-->     \r\n          <p class=\"re_copy\"><img src=\"https://www.alae.co.jp/img/recruit_logo.png\" alt=\"エイリイ・エンジニアリング\"></p>\r\n          <p class=\"re_text all\"><a href=\"https://www.alae.co.jp/recruit/\"></a>採用情報</p>\r\n      <!--ここまで-->\r\n        </div>\r\n    </div>\r\n  </div></div>\r\n      \r\n\t\t  <div class=\"mv_cover\">\r\n\t\t\t  <p class=\"mv_copy\"><img src=\"https://www.alae.co.jp/img/mv_copy.png\" alt=\"いつもの空はだれかの技術が守っている\"></p>\r\n\t\t  </div>\r\n<nav class=\"hd_inner fadein\">\r\n\t\t\t  <div class=\"nav_box\">\r\n                  <ul class=\"hd_nav\">\r\n                      <li class=\"hd_item\"><a href=\"https://www.alae.co.jp/company/\"><span class=\"bold sub_font\">About us</span><br><span>会社概要</span></a></li>\r\n                      <li class=\"hd_item\"><a href=\"https://www.alae.co.jp/service/\"><span class=\"bold sub_font\">Business</span><br><span>事業案内</span></a></li>\r\n                  </ul>\r\n                  <h1 class=\"hd_logo\">\r\n                      <a href=\"https://www.alae.co.jp/\"><img src=\"https://www.alae.co.jp/common/img/hd_logo.svg\" alt=\"株式会社エイリイ・エンジニアリング\" width=\"300\" height=\"79\"></a>\r\n                  </h1>\r\n                  <ul class=\"hd_nav\">\r\n                      <li class=\"hd_item\"><a href=\"https://www.alae.co.jp/recruit/\"><span class=\"bold sub_font\">Recruit</span><br><span>採用情報</span></a></li>\r\n                      <li class=\"hd_item\"><a href=\"https://www.alae.co.jp/contact/\"><span class=\"bold sub_font\">Contact</span><br><span>お問い合わせ</span></a></li>\r\n                  </ul>\r\n\t\t\t  </div>\r\n          </nav>    </section><!--mv-->\r\n\t  \r\n\t  <section class=\"philosophy\">\r\n          <div class=\"phi_bg\">\r\n            <div class=\"phi_inner list-mv07 scrollreveal_left\">\r\n                <h2 class=\"phi_title\">\r\n                    エイリイ・エンジニアリングの<br><span class=\"cyan bold\">理念</span>\r\n                </h2>\r\n                <p class=\"phi_comment\">弊社は国防のための製品開発や技術を提供する「防衛産業」を行っている会社です。</p>\r\n                <p class=\"phi_comment\">しかし、私たちの産業は、誰かと戦ったり、傷つけることが目的ではなく、普段の生活を守り、災害時にも人々を助けられる。そんな「いのちを守る産業」を理念に掲げている会社です。</p>\r\n                <p class=\"more_btn more_btn--white\"><a href=\"https://www.alae.co.jp/belief/\">理念について詳しく見る</a></p>\r\n            </div>\r\n          </div>\r\n\t  </section><!--philosophy-->\r\n\t  \r\n\t  <section class=\"business\">\r\n\t\t  <div class=\"bus_inner list-mv07\">\r\n\t\t\t  <h2 class=\"midashi\">\r\n                  <span class=\"midashi_main sub_font\">Business</span><br>\r\n                  <span class=\"midashi_sub\">事業内容</span>\r\n              </h2>\r\n              <div class=\"bus_list\">\r\n\t\t\t\t  \r\n                  <div class=\"bus_card\">\r\n                      <p class=\"bus_img\"><img src=\"https://www.alae.co.jp/img/business_img_01.png\" alt=\"整備・メンテナンス\"></p>\r\n                      <div class=\"bus_text\">\r\n                          <p class=\"bus_midashi\">整備・メンテナンス</p>\r\n                          <p class=\"bus_sub cyan sub_font\">Maintenance</p>\r\n\t\t\t\t\t\t  <p class=\"bus_comment\">航空自衛隊で使用される無線などの通信機器、光学電子機器や装備のメンテナンスを行い、確かな技術でサポートを行います。</p>\r\n\t\t\t\t\t\t  <p class=\"more_btn more_btn--blue\"><a href=\"https://www.alae.co.jp/service/maintenance/\">整備・メンテナンス<br>について詳しく見る</a></p>\r\n                      </div>\r\n                  </div><!--bus_card-->\r\n\t\t\t\t  \r\n                  <div class=\"bus_card\">\r\n                      <p class=\"bus_img\"><img src=\"https://www.alae.co.jp/img/business_img_02.png\" alt=\"開発・製造\"></p>\r\n                      <div class=\"bus_text\">\r\n                          <p class=\"bus_midashi\">開発・製造</p>\r\n                          <p class=\"bus_sub cyan sub_font\">Manufacturing</p>\r\n\t\t\t\t\t\t  <p class=\"bus_comment\">自衛隊や大手メーカーとの契約で、装備品や検査装置を自社で開発・製造しております。最新の3D CADも導入しております。</p>\r\n\t\t\t\t\t\t  <p class=\"more_btn more_btn--blue\"><a href=\"https://www.alae.co.jp/service/development/\">開発・製造<br>について詳しく見る</a></p>\r\n                      </div>\r\n                  </div><!--bus_card-->\r\n\t\t\t\t  \r\n                  <div class=\"bus_card\">\r\n                      <p class=\"bus_img\"><img src=\"https://www.alae.co.jp/img/business_img_03.png\" alt=\"機動衛生ユニット\"></p>\r\n                      <div class=\"bus_text\">\r\n                          <p class=\"bus_midashi\">機動衛生ユニット</p>\r\n                          <p class=\"bus_sub cyan sub_font\">Aeromedical Evacuation Unit</p>\r\n\t\t\t\t\t\t  <p class=\"bus_comment\">航空機の中で高度な手術が行える、いわば空飛ぶ救急車。現在、航空自衛隊で使われている4台の内3台が弊社の製品で、災害時にも命を救うユニットです。</p>\r\n\t\t\t\t\t\t  <p class=\"more_btn more_btn--blue\"><a href=\"https://www.alae.co.jp/service/unit/\">機動衛生ユニット<br>について詳しく見る</a></p>\r\n                      </div>\r\n                  </div><!--bus_card-->\r\n\t\t\t\t  \r\n              </div><!--bus_list-->\r\n\t\t  </div><!--bus_inner-->\r\n\t  </section><!--business-->\r\n\t  \r\n\t  <section class=\"about\">\r\n\t\t  <div class=\"about_inner list-mv07 scrollreveal_left\">\r\n\t\t\t  <h2 class=\"midashi\">\r\n                  <span class=\"midashi_main sub_font\">About us</span><br>\r\n                  <span class=\"midashi_sub\">会社案内</span>\r\n              </h2>\r\n\t\t\t  <div class=\"about_box\">\r\n                  <div class=\"about_card\">\r\n                      <a class=\"cover_link\" href=\"https://www.alae.co.jp/company/greeting/\"></a>\r\n                      <p class=\"about_icon\"><img src=\"https://www.alae.co.jp/img/icon_message.svg\" alt=\"代表挨拶\"></p>\r\n                      <p class=\"about_midashi\">代表挨拶</p>\r\n                      <p class=\"about_text\">会社の在り方を<br class=\"pc_br\">代表自らがご紹介</p>\r\n                  </div><!--about_card-->\r\n                  <div class=\"about_card\">\r\n                      <a class=\"cover_link\" href=\"https://www.alae.co.jp/company/access/\"></a>\r\n                      <p class=\"about_icon\"><img src=\"https://www.alae.co.jp/img/icon_access.svg\" alt=\"アクセス\"></p>\r\n                      <p class=\"about_midashi\">アクセス</p>\r\n                      <p class=\"about_text\">弊社までのアクセスを詳しく見る</p>\r\n                  </div><!--about_card-->\r\n\t\t\t  </div>\r\n\t\t  </div>\r\n\t  </section><!--about-->\r\n\t  \r\n\t  <section class=\"recruit\">\r\n\t\t  <div class=\"rec_inner list-mv07 scrollreveal_right\">\r\n\t\t\t  <h2 class=\"midashi\">\r\n                  <span class=\"midashi_main sub_font\">Recruit</span><br>\r\n                  <span class=\"midashi_sub\">採用情報</span>\r\n              </h2>\r\n\t\t\t  <div class=\"rec_box\">\r\n                  <div class=\"rec_card\">\r\n                      <a class=\"cover_link\" href=\"https://www.alae.co.jp/recruit/voice#voice\"></a>\r\n                      <p class=\"rec_icon\"><img src=\"https://www.alae.co.jp/img/icon_voice.svg\" alt=\"社員の声 社員の1日\"></p>\r\n                      <p class=\"rec_midashi\">社員の声</p>\r\n                      <p class=\"rec_text\">社員のリアルな<br>現場の声はこちら</p>\r\n                  </div><!--rec_card-->\r\n                  <div class=\"rec_card\">\r\n                      <a class=\"cover_link\" href=\"https://www.alae.co.jp/recruit/numbers#number\"></a>\r\n                      <p class=\"rec_icon\"><img src=\"https://www.alae.co.jp/img/icon_data.svg\" alt=\"数字でわかるエイリイ・エンジニアリング\"></p>\r\n                      <p class=\"rec_midashi\">数字でわかるエイリイ<br class=\"pc_br\">・エンジニアリング</p>\r\n                      <p class=\"rec_text\">国を守る会社の仕事とは？</p>\r\n                  </div><!--rec_card-->\r\n\t\t\t  </div>\r\n\t\t  </div>\r\n\t  </section><!--recruit-->\r\n\t  \r\n\t  <section class=\"news\">\r\n\t\t  <div class=\"news_inner list-mv07\">\r\n\t\t\t  <h2 class=\"midashi\">\r\n                  <span class=\"midashi_main sub_font\">News</span><br>\r\n                  <span class=\"midashi_sub\">お知らせ</span>\r\n              </h2>\r\n\t\t\t  <div class=\"news_box\">\r\n\t\t\t\t  <!--<div class=\"news_row\">\r\n                      <p class=\"news_time\">2021年〇月〇日</p>\r\n                      <p class=\"news_content\">テキストテキストテキストテキストテキストテキスト</p>\r\n\t\t\t\t  </div>-->\r\n      