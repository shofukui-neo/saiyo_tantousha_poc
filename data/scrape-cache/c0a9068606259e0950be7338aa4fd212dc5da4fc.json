{"url":"https://www.alae.co.jp/recruit/requirements/","html":"<!DOCTYPE html>\r\n<html lang=\"ja\">\r\n<head>\r\n<meta charset=\"UTF-8\" />\r\n<meta name=\"viewport\" content=\"width=device-width\" />\r\n<meta name=\"format-detection\" content=\"telephone=no\" />\r\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\" />\r\n\r\n<!-- CSS -->\r\n<link rel=\"stylesheet\" type=\"text/css\" media=\"all\" href=\"https://www.alae.co.jp/common/css/cmn_reset.css\" />\r\n<link rel=\"stylesheet\" type=\"text/css\" media=\"all\" href=\"https://www.alae.co.jp/common/css/cmn_style.css\" />\r\n<link rel=\"stylesheet\" type=\"text/css\" media=\"all\" href=\"https://www.alae.co.jp/common/css/cmn_responsive.css\" />\r\n<link rel=\"stylesheet\" type=\"text/css\" href=\"https://www.alae.co.jp/common/css/slick-theme.css\" media=\"all\" />\r\n<link rel=\"stylesheet\" type=\"text/css\" href=\"https://www.alae.co.jp/common/css/slick.css\" media=\"all\" />\r\n\r\n<!-- jS -->\r\n<script src=\"https://www.alae.co.jp/common/js/jquery-3.1.1.min.js\"></script>\r\n<script src=\"https://www.alae.co.jp/common/js/slick.min.js\"></script>\r\n<script src=\"https://www.alae.co.jp/common/js/backtop.js\"></script>\r\n<script src=\"https://www.alae.co.jp/common/js/jquery.inview.js\"></script>\r\n<script src=\"https://www.alae.co.jp/common/js/common.js\"></script>\r\n\r\n  <title>エイリイ・エンジニアリング &#8211; 株式会社エイリイ・エンジニアリングは、空を守るためのワンチームとして国防のための製品開発や技術を提供する「防衛産業」を行っています。</title>\n<meta name='robots' content='max-image-preview:large' />\n<link rel=\"alternate\" title=\"oEmbed (JSON)\" type=\"application/json+oembed\" href=\"https://www.alae.co.jp/wp-json/oembed/1.0/embed?url=https%3A%2F%2Fwww.alae.co.jp%2F\" />\n<link rel=\"alternate\" title=\"oEmbed (XML)\" type=\"text/xml+oembed\" href=\"https://www.alae.co.jp/wp-json/oembed/1.0/embed?url=https%3A%2F%2Fwww.alae.co.jp%2F&#038;format=xml\" />\n<style id=\"wp-img-auto-sizes-contain-inline-css\">\nimg:is([sizes=auto i],[sizes^=\"auto,\" i]){contain-intrinsic-