{"url":"https://www.secom-yamanashi.co.jp/recruit/guidelines4.html","html":"<!DOCTYPE HTML>\r\n<html lang=\"ja\">\r\n<head>\r\n\t<meta http-equiv=\"content-type\" content=\"text/html; charset=UTF-8\" />\r\n\t<meta name=\"viewport\" content=\"width=device-width,user-scalable=no,maximum-scale=1\">\r\n\t<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\r\n    <meta name=\"format-detection\" content=\"telephone=no\">\r\n    <meta name=\"keyword\" content=\"セコム,山梨,防犯,警備,セキュリティ,防災,防犯対策,セキュリティサービス,警備会社,セコム,SECOM,\">\r\n\t<meta name=\"description\" content=\"山梨のセキュリティサービス（防犯対策・警備会社）のセコム山梨株式会社の公式サイト。ホームセキュリティ、ココセコムなどのセキュリティ各商品サービス情報。\">\r\n\t<title>セコムジャスティック山梨　募集要項｜採用情報｜セコム山梨株式会社</title>\r\n\t<link rel=\"stylesheet\" media=\"all\" type=\"text/css\" href=\"../common/css/normalize.css\">\r\n\t<link rel=\"stylesheet\" media=\"all\" type=\"text/css\" href=\"../common/fontawesome-free-5.0.8/web-fonts-with-css/css/fontawesome-all.min.css\">\r\n\t<link rel=\"stylesheet\" type=\"text/css\" href=\"../common/css/base-pc.css\">\r\n\t<link rel=\"stylesheet\" type=\"text/css\" href=\"../common/css/base-tb.css\">\r\n\t<link rel=\"stylesheet\" type=\"text/css\" href=\"../common/css/base-sp.css\">\r\n\t<script type=\"text/javascript\" src=\"../common/js/jquery-3.4.1.min.js\" charset=\"utf-8\"></script>\r\n\t<script type=\"text/javascript\" src=\"../common/js/common.js\" charset=\"utf-8\"></script>\r\n</head>\r\n<body id=\"\" ontouchstart=\"\">\r\n<header id=\"top-head\">\n  <div class=\"inner\">\n    <div id=\"mobile-head\">\n      <p class=\"logo\"><a href=\"../\"><img src=\"../common/images/logo_yamanashi.gif\" alt=\"セコム山梨\"></a></p>\n      <div id=\"nav-toggle\">\n        <div> <span></span> <span></span> <span></span> </div>\n      </div>\n    </div>\n    <nav id=\"gnav\">\n      <ul>\n        <li class=\"toggle\"><a href=\"../personal/\">個人のお客さま</a>\n          <div class=\"menu\">\n            <div class=\"menu_wrap\">\n              <div class=\"menu_title\"> <a href=\"../personal/\"><span>PERSONAL</span>個人のお客さま</a> </div>\n              <ul class=\"menu_inner\">\n                <li><a href=\"../personal/goods.html\">防犯・防災商品</a></li>\n                <li><a href=\"../personal/insuarance.html\">損害保険</a></li>\n              </ul>\n            </div>\n          </div>\n        </li>\n        <li><a href=\"../business/\">法人のお客さま</a>\n          <div class=\"menu\">\n            <div class=\"menu_wrap\">\n              <div class=\"menu_title\"> <a href=\"../business/\"><span>BUSINESS</span>法人のお客さま</a> </div>\n              <ul class=\"menu_inner\">\n                <li><a href=\"../business/guard.html\">常駐警備</a></li>\n                <li><a href=\"../business/sales.html\">現金護送</a></li>\n                <li><a href=\"../business/insuarance.html\">損害保険</a></li>\n                <li><a href=\"../business/anpi.html\">安否確認サービス</a></li>\n              </ul>\n            </div>\n          </div>\n        </li>\n        <li><a href=\"../recruit/\">採用情報</a>\n          <div class=\"menu\">\n            <div class=\"menu_wrap\">\n              <div class=\"menu_title\"> <a href=\"../recruit/\"><span>RECRUIT</span>採用情報</a> </div>\n              <ul class=\"menu_inner\">\n                <li><a href=\"../recruit/idea.html\">理念と風土</a></li>\n                <li><a href=\"../recruit/system.html\">人事制度</a></li>\n                <li><a href=\"../recruit/guidelines.html\">募集要項</a></li>\n\t\t\t\t<li><a href=\"https://www.secom.co.jp/recruit/portal/wellbeing/\" target=\"_blank\" class=\"ex\">働きやすさの推進</a></li>\n              </ul>\n            </div>\n          </div>\n        </li>\n        <li><a href=\"../corporate/\">会社案内</a>\n          <div class=\"menu\">\n            <div class=\"menu_wrap\">\n              <div class=\"menu_title\"> <a href=\".../corporate/\"><span>COMPANY</span>会社案内</a> </div>\n              <ul class=\"menu_inner\">\n                <li><a href=\"../corporate/history.html\">沿革</a></li>\n                <li><a href=\"../corporate/about.html\">会社概要</a></li>\n                <li><a href=\"../corporate/group.html\">支社・営業所</a></li>\n                <li><a href=\"../corporate/jastic.html\">セコムジャスティック山梨</a></li>\n              </ul>\n            </div>\n          </div>\n        </li>\n        <li><a href=\"../contact/\">お問い合わせ</a></li>\n      </ul>\n    </nav>\n  </div>\n</header>\r\n<div class=\"contents\">\r\n  <section id=\"main-head\" class=\"recruit\">\r\n    <div class=\"breadcrumb\">\r\n      <ul>\r\n        <li><a href=\"../\">ホーム</a></li>\r\n        <li><a href=\"./\">採用情報</a></li>\r\n        <li>セコムジャスティック山梨　募集要項</li>\r\n      </ul>\r\n    </div>\r\n    <div class=\"inner\">\r\n      <div class=\"title\"> <img src=\"./images/recruit_i.png\" alt=\"採用情報\" width=\"60\">\r\n        <p>RECRUIT</p>\r\n        <h1>採用情報</h1>\r\n      </div>\r\n    </div>\r\n  </section>\r\n  <section class=\"main-title\">\r\n    <h2>セコムジャスティック山梨　募集要項</h2>\r\n  </section>\r\n  <section id=\"main\" class=\"inner\">\r\n  <h3>セコムジャスティック山梨株式会社　キャリア採用　募集要項</h3>\r\n    <table class=\"baseT\">\r\n          \t<tr>\r\n          \t\t<th>採用職種</th>\r\n          \t\t<td>常駐セキュリティスタッフ</td>\r\n       \t\t </tr>\r\n          \t<tr>\r\n          \t\t<th>仕事内容</th>\r\n          \t\t<td><p><strong>（出入管理）</strong><br>\r\n\t\t\t\tご契約先において、人、車、物の出入りを管理し、犯罪や事故の発生を未然に防止する業務です。</p>\r\n            \t\t\t<p><strong>（巡回）</strong><br>\r\n\t\t\t\tセキュリティプランニングに基づいて、ご契約先の施設を点検し、安全確認を行い、問題がある場合については適切に処置し、適正化する業務です。</p>\r\n            \t\t\t<p><strong>（緊急対処）</strong><br>\r\n         \t\t\t\t\t 派遣されたご契約先に何らかの異常が発生した場合、その異常の原因、状況を確認し、正常化する業務です。</p>\r\n            \t\t\t<p><strong>（設備監視）</strong><br>\r\n\t\t\t\tご契約先の防災センター内の各種設備の監視及び異常発生時の対応業務です。</p>\r\n            \t\t\t<p>未経験者歓迎！！</p>\r\n       \t\t\t </td>\r\n       \t\t </tr>\r\n          \t<tr>\r\n          \t\t<th>応募資格</th>\r\n          \t\t<td>高卒以上<br>\r\n\t\t\t普通自動車運転免許（マニュアル） </td>\r\n       \t\t </tr>\r\n          \t<tr>\r\n          \t\t<th>対象年齢</th>\r\n          \t\t<td>18歳～39歳迄</td>\r\n       \t\t </tr>\r\n          \t<tr>\r\n          \t\t<th>初任給</th>\r\n          \t\t<td>164,400円（18歳）～197,450円（39歳）</td>\r\n       \t\t </tr>\r\n          \t<tr>\r\n          \t\t<th>諸手当</th>\r\n          \t\t<td>都市、通勤、家族他</td>\r\n       \t\t </tr>\r\n          \t<tr>\r\n          \t\t<th>昇給</th>\r\n          \t\t<td>年１回（４月）</td>\r\n       \t\t </tr>\r\n          \t<tr>\r\n          \t\t<th>賞与</th>\r\n          \t\t<td>年２回（６月、12月）</td>\r\n       \t\t </tr>\r\n          \t<tr>\r\n          \t\t<th>勤務時間</th>\r\n          \t\t<td>週39時間を基準とした、1ヶ月単位の変形労働時間制</td>\r\n       \t\t </tr>\r\n          \t<tr>\r\n          \t\t<th>休日</th>\r\n          \t\t<td>４週を平均して月４回以上の法定休日と他に法定外休日あり<br>\r\n\t\t\t（休日日数は就業場所の勤務日程表による）</td>\r\n       \t\t </tr>\r\n          \t<tr>\r\n          \t\t<th>休暇</th>\r\n          \t\t<td>年次有給休暇、フレックス休暇・リフレッシュ休暇等長期休暇、慶弔、育児・介護休暇制度有り</td>\r\n       \t\t </tr>\r\n          \t<tr>\r\n          \t\t<th>福利厚生</th>\r\n          \t\t<td>各種社会保険、企業年金制度、財形制度、社員持株制度（セコム(株)）、保養所（軽井沢・御殿場・名張）、ジム法人契約</td>\r\n       \t\t </tr>\r\n          \t<tr>\r\n          \t\t<th>研修制度</th>\r\n          \t\t<td>新入社員研修、新任マネージャー研修、通信教育助成制度</td>\r\n       \t\t </tr>\r\n          \t<tr>\r\n          \t\t<th>選考方法</th>\r\n          \t\t<td>適性検査、面接</td>\r\n       \t\t </tr>\r\n          \t<tr>\r\n          \t\t<th>提出書類</th>\r\n          \t\t<td>履歴書（写真貼付）</td>\r\n       \t\t </tr>\r\n          \t<tr>\r\n          \t\t<th>問い合わせ先</th>\r\n         \t\t <td>管理部総務課　採用担当宛<br>\r\n\t\t\t〒400-0047　山梨県甲府市徳行3-12-25　セコム山梨ビル<br>\r\n\t\t\tTEL　055-220-7700<br>\r\n\t\t\tFAX　055-220-7391\r\n\t\t\t</td>\r\n       \t\t </tr>\r\n          \t</table>\r\n            <p class=\"text-center\"><a href=\"recruit2_agree.html\" class=\"btn\">エントリーフォーム</a></p>\r\n  </section>\r\n  <section id=\"subArea\">\r\n    <div class=\"inner\">\r\n      <h4><span>採用情報</span></h4>\n<ul>\n    <li><a class=\"fade\" href=\"./\"><i class=\"fas fa-chevron-circle-right\"></i><span class=\"ls0\">セコムの目指すもの</span></a></li>\n    <li><a class=\"fad