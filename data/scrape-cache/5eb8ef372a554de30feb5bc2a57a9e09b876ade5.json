{"url":"https://www.cnw.co.jp/recruit/people.html","html":"<!DOCTYPE html>\r\n<html lang=\"ja\">\r\n<head>\r\n  <meta charset=\"UTF-8\">\r\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n  <title>人を知る | キャリアネットワーク採用サイト</title>\r\n  <link href=\"https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@300;400;500;600;700&family=Noto+Sans+JP:wght@300;400;500;700&family=Inter:wght@300;400;500;600;700&display=swap\" rel=\"stylesheet\">\r\n  <link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@fortawesome/fontawesome-free@6.4.0/css/all.min.css\">\r\n  <link rel=\"stylesheet\" href=\"css/sub.css\">\r\n  <link rel=\"stylesheet\" href=\"css/people.css\">\r\n</head>\r\n<body><div id=\"wrapper\">\r\n\r\n<!-- ========================================\r\n     HEADER\r\n======================================== -->\r\n<header class=\"site-header\">\r\n  <div class=\"site-header__inner\"><a href=\"index.html\" class=\"site-header__logo\">\r\n      <img src=\"images/logo.webp\" width=\"200\">\r\n      <span class=\"site-header__logo-text\">採用サイト<span>RECRUIT</span></span>\r\n    </a>\r\n    <nav class=\"site-header__nav\" id=\"headerNav\">\r\n      <ul>\r\n        <li><a href=\"company.html\">会社を知る</a></li>\r\n        <li><a href=\"work.html\">仕事を知る</a></li>\r\n        <li><a href=\"people.html\" class=\"active\">人を知る</a></li>\r\n        <li><a href=\"jobs.html\">採用情報</a></li>\r\n      </ul>\r\n    </nav>\r\n    <a href=\"jobs.html#apply\" class=\"site-header__cta\">ENTRY</a>\r\n    <button class=\"site-header__hamburger\" id=\"hamburger\" aria-label=\"メニュー\">\r\n      <span></span><span></span><span></span>\r\n    </button>\r\n  </div>\r\n</header>\r\n\r\n<div class=\"sp-menu\" id=\"spMenu\">\r\n  <ul>\r\n    <li><a href=\"company.html\" class=\"sp-menu__link\">会社を知る</a></li>\r\n    <li><a href=\"work.html\" class=\"sp-menu__link\">仕事を知る</a></li>\r\n    <li><a href=\"people.html\" class=\"sp-menu__link active\">人を知る</a></li>\r\n    <li><a href=\"jobs.html\" class=\"sp-menu__link\">採用情報</a></li>\r\n  </ul>\r\n  <a href=\"jobs.html#apply\" class=\"sp-menu__cta\">まず話を聞いてみる（無料）</a>\r\n  <a href=\"jobs.html#apply\" class=\"sp-menu__cta sp-menu__cta--sub\">30秒でENTRY →</a>\r\n</div>\r\n\r\n<!-- ========================================\r\n     PAGE HERO\r\n======================================== -->\r\n<section class=\"page-hero\">\r\n  <div class=\"container page-hero__inner\">\r\n    <nav class=\"breadcrumb\" aria-label=\"パンくずリスト\">\r\n      <a href=\"index.html\">HOME</a>\r\n      <i class=\"fa-solid fa-chevron-right\"></i>\r\n      <span>人を知る</span>\r\n    </nav>\r\n    <span class=\"page-hero__en\">PEOPLE</span>\r\n    <h1 class=\"page-hero__title\">人を知る</h1>\r\n    <p class=\"page-hero__desc\">\r\n      ここで働くのはどんな人たちか。<br>\r\n      未経験から入社した先輩たちの、リアルな声をお届けします。\r\n    </p>\r\n  </div>\r\n</section>\r\n\r\n<!-- ========================================\r\n     SEC 01: イントロ\r\n======================================== -->\r\n<section class=\"section-people-intro\">\r\n  <div class=\"container\">\r\n    <div class=\"people-intro\" data-fade>\r\n      <div class=\"accent-line accent-line--center\"></div>\r\n      <h2 class=\"people-intro__heading\">\r\n        入社者の約8割が、<br>あなたと同じ「未経験スタート」です。\r\n      </h2>\r\n      <p class=\"people-intro__body\">\r\n        アパレル、飲食、事務、教育……様々なバックグラウンドを持つメンバーが、<br class=\"pc-only\">\r\n        ここで「人の役に立てる仕事」を見つけました。\r\n      </p>\r\n    </div>\r\n  </div>\r\n</section>\r\n\r\n<!-- ========================================\r\n     SEC 02: インタビュー一覧グリッド\r\n======================================== -->\r\n<section class=\"people-list-section\">\r\n  <div class=\"container\">\r\n\r\n    <div class=\"people-list-header\" data-fade>\r\n      <div class=\"people-list-header__filters\">\r\n        <button class=\"people-filter-btn is-active\" data-filter=\"all\">すべて</button>\r\n        <button class=\"people-filter-btn\" data-filter=\"coordinator\">キャリアアドバイザー・コーディネーター</button>\r\n        <button class=\"people-filter-btn\" data-filter=\"jimu\">営業事務</button>\r\n      </div>\r\n    </div>\r\n\r\n    <div class=\"people-grid\" id=\"peopleGrid\">\r\n\r\n      <!-- スタッフ A -->\r\n      <article class=\"people-card\" data-category=\"coordinator\" data-fade>\r\n        <a href=\"people/a.html\" class=\"people-card__link-wrap\" tabindex=\"-1\" aria-hidden=\"true\">\r\n          <div class=\"people-card__img-wrap\">\r\n            <img src=\"images/staff-a-s.jpg\" alt=\"N.Yさん\" class=\"people-card__photo\" loading=\"lazy\">\r\n            <div class=\"people-card__img-overlay\">\r\n              <span><i class=\"fa-solid fa-arrow-right\"></i> インタビューを読む</span>\r\n            </div>\r\n          </div>\r\n        </a>\r\n        <div class=\"people-card__body\">\r\n          <div class=\"people-card__meta\">\r\n            <span class=\"people-card__badge\">未経験入社</span>\r\n            <span class=\"people-card__job\">キャリアアドバイザー</span>\r\n          </div>\r\n          <h2 class=\"people-card__name\">N.Yさん</h2>\r\n          <p class=\"people-card__quote\">福井で転職や採用を考える方にとって、「まず相談したい」と思っていただける存在になることが目標です。</p>\r\n          <div class=\"people-card__tags\">\r\n            <span>未経験スタート</span>\r\n            <span>人の人生に関わる</span>\r\n          </div>\r\n          <a href=\"people/a.html\" class=\"people-card__more\">\r\n            インタビューを読む <i class=\"fa-solid fa-arrow-right\"></i>\r\n          </a>\r\n        </div>\r\n      </article>\r\n\r\n      <!-- スタッフ B -->\r\n      <article class=\"people-card\" data-category=\"jimu\" data-fade>\r\n        <a href=\"people/b.html\" class=\"people-card__link-wrap\" tabindex=\"-1\" aria-hidden=\"true\">\r\n          <div class=\"people-card__img-wrap\">\r\n            <img src=\"images/staff-b-s.jpg\" alt=\"K.Aさん\" class=\"people-card__photo\" loading=\"lazy\">\r\n            <div class=\"people-card__img-overlay\">\r\n              <span><i class=\"fa-solid fa-arrow-right\"></i> インタビューを読む</span>\r\n            </div>\r\n          </div>\r\n        </a>\r\n        <div class=\"people-card__body\">\r\n          <div class=\"people-card__meta\">\r\n            <span class=\"people-card__badge\">未経験入社</span>\r\n            <span class=\"people-card__job\">営業事務</span>\r\n          </div>\r\n          <h2 class=\"people-card__name\">K.Aさん </h2>\r\n          <p class=\"people-card__quote\">求人の状況は日々変化するため、スピード感を持って取り組むことを大切にしています。</p>\r\n          <div class=\"people-card__tags\">\r\n            <span>未経験スタート</span>\r\n            <span>飲食→人材へ転職</span>\r\n            <span>人の人生に関わる</span>\r\n          </div>\r\n          <a href=\"people/b.html\" class=\"people-card__more\">\r\n            インタビューを読む <i class=\"fa-solid fa-arrow-right\"></i>\r\n          </a>\r\n        </div>\r\n      </article>\r\n\r\n      <!-- スタッフ C -->\r\n      <article class=\"people-card\" data-category=\"jimu\" data-fade>\r\n        <a href=\"people/c.html\" class=\"people-card__link-wrap\" tabindex=\"-1\" aria-hidden=\"true\">\r\n          <div class=\"people-card__img-wrap\">\r\n            <img src=\"images/staff-c-s.jpg\" alt=\"N.Aさん\" class=\"people-card__photo\" loading=\"lazy\">\r\n            <div class=\"people-card__img-overlay\">\r\n              <span><i class=\"fa-solid fa-arrow-right\"></i> インタビューを読む</span>\r\n            </div>\r\n          </div>\r\n        </a>\r\n        <div class=\"people-card__body\">\r\n          <div class=\"people-card__meta\">\r\n            <span class=\"people-card__job\">営業事務</span>\r\n          </div>\r\n          <h2 class=\"people-card__name\">N.Aさん </h2>\r\n          <p class=\"people-card__prev\">前職：一般事務職</p>\r\n          <p class=\"people-card__quote\">「確認すること」と、「周りを見ること」を大切に。</p>\r\n          <div class=\"people-card__tags\">\r\n            <span>自分の経験を活かす</span>\r\n            <span>話しかけやすい職場</span>\r\n          </div>\r\n          <a href=\"people/c.html\" class=\"people-card__more\">\r\n            インタビューを読む <i class=\"fa-solid fa-arrow-right\"></i>\r\n          </a>\r\n        </div>\r\n      </article>\r\n      \r\n      \r\n      \r\n      <!-- スタッフ d -->\r\n      <article class=\"people-card\" data-category=\"coordinator\" data-fade>\r\n        <a href=\"people/d.html\" class=\"people-card__link-wrap\" tabindex=\"-1\" aria-hidden=\"true\">\r\n          <div class=\"people-card__img-wrap\">\r\n            <img src=\"images/staff-d-s.jpg\" alt=\"K.Aさん\" class=\"people-card__photo\" loading=\"lazy\">\r\n            <div class=\"people-card__img-overlay\">\r\n              <span><i class=\"fa-solid fa-arrow-right\"></i> インタビューを読む</span>\r\n            </div>\r\n          </div>\r\n        </a>\r\n        <div class=\"people-card__body\">\r\n          <div class=\"people-card__meta\">\r\n            <span class=\"people-card__badge\">未経験入社</span>\r\n            <span class=\"people-card__job\">キャリアアドバイザー</span>\r\n          </div>\r\n          <h2 class=\"people-card__name\">K.Aさん </h2>\r\n          <p class=\"people-card__prev\">前職：小学校教員</p>\r\n          <p class=\"people-card__quote\">人と企業をつなぎ、誰かの役に立てる仕事に魅力</p>\r\n          <div class=\"people-card__tags\">\r\n            <span>教育→人材へ転職</span>\r\n            <span>自分の経験を活かす</span>\r\n            <span>話しかけやすい職場</span>\r\n          </div>\r\n          <a href=\"people/d.html\" class=\"people-card__more\">\r\n            インタビューを読む <i class=\"fa-solid fa-arrow-right\"></i>\r\n          </a>\r\n        </div>\r\n      </article>\r\n      \r\n      \r\n      \r\n      <!-- スタッフ e -->\r\n      <article class=\"people-card\" data-category=\"coordinator\" data-fade>\r\n        <a href=\"people/e.html\" class=\"people-card__link-wrap\" tabindex=\"-1\" aria-hidden=\"true\">\r\n          <div class=\"people-card__img-wrap\">\r\n            <img src=\"images/staff-e-s.jpg\" alt=\"K.Kさん\" class=\"people-card__photo\" loading=\"lazy\">\r\n            <div class=\"people-card__img-overlay\">\r\n              <span><i class=\"fa-solid fa-arrow-right\"></i> インタビューを読む</span>\r\n            </div>\r\n          </div>\r\n        </a>\r\n        <div class=\"people-card__body\">\r\n          <div class=\"people-card__meta\">\r\n            <span class=\"people-card__badge\">未経験入社</span>\r\n            <span class=\"people-card__job\">キャリアアドバイザー</span>\r\n          </div>\r\n          <h2 class=\"people-card__name\">K.Kさん </h2>\r\n          <p class=\"people-card__prev\">前職：フォークリフト作業員</p>\r\n          <p class=\"people-card__quote\">分からないことがあれば相談できる環境があり、一人で抱え込まずに仕事ができるところも魅力</p>\r\n          <div class=\"people-card__tags\">\r\n            <span>自分の経験を活かす</span>\r\n            <span>話しかけやすい職場</span>\r\n          </div>\r\n          <a href=\"people/e.html\" class=\"people-card__more\">\r\n            インタビューを読む <i class=\"fa-solid fa-arrow-right\"></i>\r\n          </a>\r\n        </div>\r\n      </article>\r\n\r\n    </div><!-- /.people-grid -->\r\n  </div>\r\n</section>\r\n\r\n<!-- ========================================\r\n     SEC 03: 社内の雰囲気\r\n======================================== -->\r\n<section class=\"section-culture\">\r\n  <div class=\"container\">\r\n    <div class=\"section-header section-header--center\" data-fade>\r\n      <span class=\"section-header__en\">CULTURE</span>\r\n      <h2 class=\"section-header__ja\">チームの雰囲気</h2>\r\n      <p class=\"section-header__desc\">数字だけでは伝わらない、私たちのリアルな職場環境。</p>\r\n    </div>\r\n\r\n    <div class=\"culture-grid\">\r\n      <div class=\"culture-card\" data-fade>\r\n        <div class=\"culture-card__icon\"><i class=\"fa-solid fa-comments\"></i></div>\r\n        <h3 class=\"culture-card__title\">なんでも言いやすい雰囲気</h3>\r\n        <p class=\"culture-card__body\">上司への「報連相」がしやすい。困ったことをすぐに相談できる距離感。縦割りでなく、フラットなチームです。</p>\r\n      </div>\r\n      <div class=\"culture-card\" data-fade>\r\n        <div class=\"culture-card__icon\"><i class=\"fa-solid fa-cake-candles\"></i></div>\r\n        <h3 class=\"culture-card__title\">メンバーの誕生日を祝う文化</h3>\r\n        <p class=\"culture-card__body\">小さな会社ならではの温かさ。メンバーの誕生日にはランチに行くことも。仕事仲間が友人みたいな存在です。</p>\r\n      </div>\r\n      <div class=\"culture-card\" data-fade>\r\n        <div class=\"culture-card__icon\"><i class=\"fa-solid fa-trophy\"></i></div>\r\n        <h3 class=\"culture-card__title\">成果をちゃんと認めてくれる</h3>\r\n        <p class=\"culture-card__body\">頑張りは数字だけでなく、プロセスも評価される。「よくやったね」と言ってくれる上司がいることが、モチベーションになっています。</p>\r\n      </div>\r\n      <div class=\"culture-card\" data-fade>\r\n        <div class=\"culture-card__icon\"><i class=\"fa-regular fa-clock\"></i></div>\r\n        <h3 class=\"culture-card__title\">メリハリのある働き方</h3>\r\n        <p class=\"culture-card__body\">残業は月平均10〜20時間程度。業務時間内に集中して動き、定時には帰れることが多い。プライベートも大切にできます。</p>\r\n      </div>\r\n      <div class=\"culture-card\" data-fade>\r\n        <div class=\"culture-card__icon\"><i class=\"fa-solid fa-seedling\"></i></div>\r\n        <h3 class=\"culture-card__title\">学び続けられる環境</h3>\r\n        <p class=\"culture-card__body\">資格取得費用の補助あり。社内勉強会も定期開催。学ぶことを歓迎し、成長を全力でサポートする文化があります。</p>\r\n      </div>\r\n      <div class=\"culture-card\" data-fade>\r\n        <div class=\"culture-card__icon\"><i class=\"fa-solid fa-location-dot\"></i></div>\r\n        <h3 class=\"culture-card__title\">地域に根ざした安心感</h3>\r\n        <p class=\"culture-card__body\">転勤なし。生まれ育った地域で、地元の企業と人をつなぐ。地域社会への貢献を実感できる仕事です。</p>\r\n      </div>\r\n    </div>\r\n\r\n    <div class=\"culture-photo-strip\" data-fade>\r\n      <img src=\"images/company-wide.jpg\" alt=\"オフィスの雰囲気\" class=\"culture-photo-strip__img\">\r\n      <div class=\"culture-photo-strip__overlay\">\r\n        <p class=\"culture-photo-strip__text\">「ここなら、自分らしく働ける」<br>そう感じてもらえる場所でありたい。</p>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</section>\r\n\r\n<!-- ========================================\r\n     BOTTOM CTA\r\n======================================== -->\r\n<section class=\"section-cta-band\">\r\n  <div class=\"container\">\r\n    <p class=\"cta-band__en\">JOIN US</p>\r\n    <h2 class=\"cta-band__heading\">あなたも、この仲間になりませんか。</h2>\r\n    <p class=\"cta-band__sub\">まずはカジュアル面談で、チームの雰囲気を直接感じてみてください。<br>選考なし・無料です。</p>\r\n    <div class=\"cta-band__btns\">\r\n      <a href=\"jobs.html#apply\" class=\"cta-band__btn--primary\">\r\n        <i class=\"fa-solid fa-calendar-check\"></i> カジュアル面談を予約（無料）\r\n      </a>\r\n      <a href=\"jobs.html#apply\" class=\"cta-band__btn--line\">\r\n        <i class=\"fa-brands fa-line\"></i> LINEで問い合わせ\r\n      </a>\r\n      <a href=\"jobs.html#apply\" class=\"cta-band__btn--casual\">\r\n        <i class=\"fa-solid fa-bolt\"></i> 30秒でENTRY\r\n      </a>\r\n    </div>\r\n  </div>\r\n</section>\r\n\r\n<!-- ========================================\r\n     FOOTER\r\n======================================== -->\r\n<footer class=\"site-footer\">\r\n  <div class=\"container\">\r\n    <div class=\"site-footer__top\">\r\n      <div class=\"site-footer__brand\">\r\n        <div class=\"site-footer__logo\">\r\n          <img src=\"images/logo.webp\" width=\"200\">\r\n          <span class=\"site-footer__logo-text\">キャリアネットワーク<span>RECRUIT</span></span>\r\n        </div>\r\n        <p class=\"site-footer__catchcopy\">学歴より、熱意。<br>未経験から、人材のプロへ。</p>\r\n        <div class=\"site-footer__sns\">\r\n          <a href=\"https://www.instagram.com/fukui_tenshoku/\" aria-label=\"Instagram\"><i class=\"fa-brands fa-instagram\"></i></a>\r\n          <a href=\"https://x.com/fukui_tenshoku\" aria-label=\"Twitter/X\"><i class=\"fa-brands fa-x\"></i></a>\r\n          <a href=\"https://page.line.me/824ylbtv?openQrModal=true\" aria-label=\"LINE\"><i class=\"fa-brands fa-line\"></i></a>\r\n        </div>\r\n      </div>\r\n      <div class=\"site-footer__nav\">\r\n        <div class=\"site-footer__nav-group\">\r\n          <div class=\"site-footer__nav-title\">会社を知る</div>\r\n          <ul><li><a href=\"company.html\">会社概要</a></li><li><a href=\"president.html\">代表挨拶</a></li></ul>\r\n        </div>\r\n        <div class=\"site-footer__nav-group\">\r\n          <div class=\"site-footer__nav-title\">仕事を知る</div>\r\n          <ul><li><a href=\"work.html#coordinator\">派遣コーディネーター</a></li><li><a href=\"work.html#advisor\">キャリアアドバイザー</a></li></ul>\r\n        </div>\r\n        <div class=\"site-footer__nav-group\">\r\n          <div class=\"site-footer__nav-title\">人を知る</div>\r\n          <ul>\r\n            <li><a href=\"people.html\">スタッフ一覧</a></li>            <li><a href=\"people/a.html\">N.Yさんのインタビュー</a></li>\r\n            <li><a href=\"people/b.html\">K.Aさんのインタビュー</a></li>\r\n            <li><a href=\"people/c.html\">N.Aさんのインタビュー</a></li>\r\n            <li><a href=\"people/d.html\">K.Aさんのインタビュー</a></li>\r\n            <li><a href=\"people/e.html\">K.Kさんのインタビュー</a></li>\r\n          </ul>\r\n        </div>\r\n        <div class=\"site-footer__nav-group\">\r\n          <div class=\"site-footer__nav-title\">採用情報</div>\r\n          <ul><li><a href=\"jobs.html\">募集職種一覧</a></li><li><a href=\"jobs.html#flow\">選考フロー</a></li><li><a href=\"jobs.html#apply\">ENTRY</a></li></ul>\r\n        </div>\r\n      </div>\r\n    </div>\r\n    <div class=\"site-footer__bottom\">\r\n      <div class=\"site-footer__legal\">\r\n        <a href=\"https://www.cnw.co.jp/privacy\" target=\"_blank\">個人情報の取り扱い</a><a href=\"https://www.cnw.co.jp/form/contact#no-back\" target=\"_blank\">お問い合わせ</a>\r\n      </div>\r\n      <p class=\"site-footer__copy\">© 2026 株式会社キャリアネットワーク All Rights Reserved.</p>\r\n    </div>\r\n  </div>\r\n</footer>\r\n\r\n<div class=\"sticky-cta-bar\" id=\"stickyCta\">\r\n  <div class=\"sticky-cta-bar__inner\">\r\n    <p class=\"sticky-cta-bar__text\">あなたの一歩を待っています</p>\r\n    <div class=\"sticky-cta-bar__btns\">\r\n      <a href=\"jobs.html#apply\" class=\"sticky-btn sticky-btn--apply\"><i class=\"fa-solid fa-bolt\"></i> <span>30秒応募</span></a>\r\n      <a href=\"jobs.html#apply\" class=\"sticky-btn sticky-btn--line\"><i class=\"fa-brands fa-line\"></i> <span>LINE</span></a>\r\n      <a href=\"jobs.html#apply\" class=\"sticky-btn sticky-btn--casual\"><i class=\"fa-solid fa-calendar-check\"></i> <span>面談予約</span></a>\r\n    </div>\r\n    <button class=\"sticky-cta-bar__close\" id=\"stickyClose\" aria-label=\"閉じる\"><i class=\"fa-solid fa-xmark\"></i></button>\r\n  </div>\r\n</div>\r\n\r\n<script src=\"js/sub.js\"></script>\r\n<script>\r\n// フィルターボタン処理\r\n(function () {\r\n  const btns  = document.querySelectorAll('.people-filter-btn');\r\n  const cards = document.querySelectorAll('.people-card');\r\n\r\n  btns.forEach(function (btn) {\r\n    btn.addEventListener('click', function () {\r\n      btns.forEach(function (b) { b.classList.remove('is-active'); });\r\n      btn.classList.add('is-active');\r\n\r\n      const filter = btn.dataset.filter;\r\n      cards.forEach(function (card) {\r\n        const match = filter === 'all' || card.dataset.category === filter;\r\n        card.style.display = match ? '' : 'none';\r\n        // フェードアニメーションのリセット\r\n        if (match) {\r\n          card.classList.remove('in');\r\n          setTimeout(function () { card.classList.add('in'); }, 30);\r\n        }\r\n      });\r\n    });\r\n  });\r\n})();\r\n</script>\r\n</div></body>\r\n</html>\r\n","finalUrl":"https://www.cnw.co.jp/recruit/people.html","rendered":false,"_cachedAt":"2026-06-23T21:23:16.473Z"}