{"url":"https://www.khi-saiyo.jp/people/goroku/","html":"<!DOCTYPE html>\r\n<html lang=\"ja\">\r\n  <head prefix=\"og: http://ogp.me/ns#\">\r\n    <meta charset=\"UTF-8\">\r\n    <script type=\"text/javascript\" src=\"//nexus.ensighten.com/uw-kawasaki/dev/Bootstrap.js\"></script>\r\n    <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n    <meta name=\"format-detection\" content=\"telephone=no\">\r\n    <title>川崎語録｜川崎重工業株式会社 総合採用サイト</title>\r\n    <meta name=\"description\" content=\"キャリア入社の社員が川崎重工に感じている魅力や転職のきっかけをお伝えします。\">\r\n    <meta name=\"keywords\" content=\"kawasaki,KAWASAKI,カワサキ,川崎重工,川崎重工業,川重,KHI,khi,採用,キャリア,中途\">\r\n    <meta property=\"og:title\" content=\"川崎重工業株式会社 総合採用サイト\">\r\n    <meta property=\"og:locale\" content=\"ja\">\r\n    <meta property=\"og:type\" content=\"website\">\r\n    <meta property=\"og:image\" content=\"https://www.khi-saiyo.jp/assets/images/common/ogp.png\">\r\n    <meta property=\"og:url\" content=\"https://www.khi-saiyo.jp/people/goroku\">\r\n    <meta property=\"og:description\" content=\"キャリア入社の社員が川崎重工に感じている魅力や転職のきっかけをお伝えします。\">\r\n    <meta property=\"og:site_name\" content=\"川崎重工業株式会社 総合採用サイト\">\r\n    <script async src=\"https://www.googletagmanager.com/gtag/js?id=G-DJP17ZHGMW\"></script>\r\n    <script>window.dataLayer = window.dataLayer || [];function gtag(){dataLayer.push(arguments);}gtag('js', new Date());gtag('config', 'G-DJP17ZHGMW');</script>\r\n    <link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/yakuhanjp@3.4.1/dist/css/yakuhanjp-noto.min.css\">\r\n    <link rel=\"stylesheet\" href=\"/assets/css/main.css\">\r\n  </head>\r\n  <body id=\"top\">\r\n    <div class=\"js-loading\" id=\"js-loading\"><span class=\"label\">LOADING</span></div>\r\n    <header class=\"head-root\" id=\"head-root\">\r\n      <div class=\"hgroup\"><a href=\"/\">\r\n          <h1 class=\"title\">Kawasaki</h1></a>\r\n        <p class=\"sub-title\"><span class=\"ja\">川崎重工業株式会社 </span><span class=\"en\">RECRUITING SITE</span></p>\r\n      </div>\r\n      <div class=\"nav-menu\"><a class=\"button mypage\" href=\"https://job.axol.jp/jn/s/khi_24/mypage/\" target=\"_blank\">\r\n          <div class=\"inner\"><span class=\"label\">MY<br> PAGE</span></div></a><a class=\"button entry\" href=\"/entry/\">\r\n          <div class=\"inner\"><span class=\"label\">ENTRY/<br>MYPAGE</span></div></a>\r\n        <button class=\"button menu-opener\" id=\"menu-opener\"><span class=\"top\"></span><span class=\"mid\"></span><span class=\"bot\"></span></button>\r\n      </div>\r\n      <div class=\"global-menu people/goroku\" id=\"global-menu\">\r\n        <div class=\"container\">\r\n          <div class=\"menu\">\r\n            <div class=\"item n1\">\r\n              <div class=\"title\"><span class=\"num\">01</span><span class=\"ja\">川崎重工について</span><span class=\"en\">About KHI</span></div>\r\n              <div class=\"links\"><a class=\"link\" href=\"/about/value.html\"> 川崎重工の存在意義</a><a class=\"link\" href=\"/about/aboutkhi.html\">川崎重工について</a></div>\r\n            </div>\r\n            <div class=\"item n2\">\r\n              <div class=\"title\"><span class=\"num\">02</span><span class=\"ja\">事業領域</span><span class=\"en\">Work Field</span></div>\r\n              <div class=\"links\"><a class=\"link\" href=\"/field/pronoun/\"> 未来の代名詞・川崎重工</a><a class=\"link\" href=\"/field/company.html\">COMPANY COLOR</a></div>\r\n            </div>\r\n            <div class=\"item n3\">\r\n              <div class=\"title\"><span class=\"num\">03</span><span class=\"ja\">川崎重工の描く未来</span><span class=\"en\">Vision </span></div>\r\n              <div class=\"links\"> <a class=\"link\" href=\"/vision/history.html\">未来創造ヒストリー</a>\r\n                <p class=\"link\">近未来プロジェクト</p><a class=\"link c\" href=\"/vision/project_01.html\">近未来プロジェクト01</a><a class=\"link c\" href=\"/vision/project_02.html\">近未来プロジェクト02  </a>\r\n              </div>\r\n            </div>\r\n            <div class=\"item n4\">\r\n              <div class=\"title\"><span class=\"num\">04</span><span class=\"ja\">川崎重工を支える人</span><span class=\"en\">People </span></div>\r\n              <div class=\"links\"> <a class=\"link\" href=\"/people/work.html\">職種紹介</a><a class=\"link\" href=\"/people/\">社員紹介 INDEX</a><a class=\"link\" href=\"/people/career/\">キャリア入社社員の声</a><a class=\"link\" href=\"/people/crosstalk/\"> CROSS TALK <br class=\"sp\">働き方を知る座談会</a><a class=\"link\" href=\"/people/goroku/\"> 川崎語録 </a></div>\r\n            </div>\r\n            <div class=\"item n5\">\r\n              <div class=\"title\"><span class=\"num\">05</span><span class=\"ja\">働く環境</span><span class=\"en\">Environment</span></div>\r\n              <div class=\"links\"><a class=\"link\" href=\"/environment/life/\">川崎重工での暮らし</a><a class=\"link c\" href=\"/environment/life/kobe.html\">神戸編</a><a class=\"link c\" href=\"/environment/life/akashi.html\">明石編</a><a class=\"link c\" href=\"/environment/life/gifu.html\">岐阜編</a><a class=\"link\" href=\"/environment/benefitsystem.html\">人財育成と<br class=\"sp\">教育研修制度/福利厚生制度</a><a class=\"link\" href=\"/environment/diversity.html\">ダイバーシティ推進</a></div>\r\n            </div>\r\n            <div class=\"item n6\">\r\n              <div class=\"title\"><span class=\"num\">06</span><span class=\"ja\">採用情報</span><span class=\"en\">Recruit</span></div>\r\n              <div class=\"links\"><a class=\"link\" href=\"/recruit/internship.html\">インターンシップ情報</a><a class=\"link\" href=\"/recruit/newgraduate.html\">新卒採用募集要項 (川崎重工・川崎車両)</a><a class=\"link blank\" href=\"https://www.khi-saiyo.jp/kmcrecruit/recruit/info/\" target=\"_blank\">カワサキモータース採用募集要項</a><a class=\"link blank\" href=\"https://progres01.jposting.net/pgkhi/u/job.phtml\" target=\"_blank\">キャリア採用募集要項</a><a class=\"link blank\" href=\"https://app.crm.i-myrefer.jp/entry/khi/uBHs7VOnvgPwQ9GSw5Dv\" target=\"_blank\">アルムナイ・ネットワークへの登録はこちら（カムバック採用含む）</a><a class=\"link blank\" href=\"https://app.crm.i-myrefer.jp/entry/khi/RY3jtL6DwPKcSmmekUjm\" target=\"_blank\">キャリア採用に興味のある方はこちら</a><a class=\"link\" href=\"/recruit/handicapped.html\">障がい者雇用について </a><a class=\"link blank\" href=\"https://www.khi-gr.jp/\" target=\"_blank\">関係会社募集要項 </a><a class=\"button mypage\" href=\"https://job.axol.jp/jn/s/khi_24/mypage/\" target=\"_blank\">MY PAGE</a><a class=\"button entry\" href=\"/entry/\">ENTRY/MYPAGE</a></div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </header>\r\n    <main class=\"main people-goroku\">\r\n      <section class=\"sec-second-index people-job\">\r\n        <header class=\"head-sec\">\r\n          <p class=\"label-page\"><span class=\"num\">04</span><span class=\"text\">People</span></p>\r\n          <div class=\"block-title\">\r\n            <h1 class=\"title\">川崎語録</h1>\r\n          </div>\r\n        </header>\r\n      </section>\r\n      <div class=\"sec-breadcrumb\">\r\n        <div class=\"breadcrumb\"><a class=\"item\" href=\"/\"> TOP</a><span class=\"gt\">&gt;</span><a class=\"item\" href=\"../\"> PEOPLE</a><span class=\"gt\">&gt;\t</span><span class=\"item\">川崎語録</span></div>\r\n      </div>\r\n      <section class=\"sec-people-goroku\">\r\n        <div class=\"container\">\r\n          <div class=\"blocks m1\">\r\n            <div class=\"block n1\" data-aos=\"fade-right\" data-aos-duration=\"1000\" data-aos-delay=\"100\" data-aos-offset=\"200\">\r\n              <div class=\"title hr\" data-micromodal-trigger=\"modal1\" role=\"button\">\r\n                <h2 class=\"text\"><span class=\"l\">日本企業<span class=\"s\">に</span></span><br class=\"sp\"><span class=\"l ll\">就職<span class=\"s\">したと</span>思うな！ </span></h2>\r\n                <div class=\"detail\">Show detail<span class=\"mark\"></span></div>\r\n              </div>\r\n              <div class=\"body\">\r\n                <p class=\"text\">配属された当初、上司から、そう言われました。私が所属する部署では、扱う案件の約8割が海外のもの。仕事を進める上で、英語力は欠かせないスキルです。それに加えて、グローバルに物事を考える幅広い視野も求められます。今も、まったくもって正しい考え方だと、いつも肝に銘じています。</p>\r\n              </div>\r\n            </div>\r\n            <div class=\"block n2\" data-aos=\"fade-down\" data-aos-duration=\"1000\" data-aos-delay=\"600\" data-aos-offset=\"200\">\r\n              <div class=\"title vr vr-sp\" data-micromodal-trigger=\"modal2\" role=\"button\">\r\n                <h2 class=\"text\"><span class=\"l\">水素<span class=\"s\">の</span>力<span class=\"s\">で</span></span><br><span class=\"l\">子どもたち<span class=\"s\">に</span></span><br><span class=\"l\">綺麗<span class=\"s\">な</span>未来<span class=\"s\">を</span></span><br><span class=\"l\">残したい</span></h2>\r\n                <div class=\"detail\">Show detail<span class=\"mark\"></span></div>\r\n              </div>\r\n              <div class=\"body\">\r\n                <p class=\"text\">現在建造中の液化水素運搬船（パイロット船）に関する設計業務を担当しています。最近相次いで子どもが生まれたこともあり、豊かな自然やきれいな空気の重要性を再認識し、水素エネルギーをより身近なテーマとして感じるようになりました。子どもたちに美しく豊かな未来を残していくためにも、この仕事を全うしたいと感じています。</p>\r\n              </div>\r\n            </div>\r\n            <div class=\"block n3\" data-aos=\"fade-up\" data-aos-duration=\"1000\" data-aos-delay=\"300\" data-aos-offset=\"200\">\r\n              <div class=\"title vr vr-sp\" data-micromodal-trigger=\"modal3\" role=\"button\">\r\n                <h2 class=\"text\"><span class=\"l\">製品<span class=\"s\">を</span></span><br class=\"sp\"><span class=\"l ll\">つくるより先<span class=\"s\">に</span></span><br class=\"sp\"><span class=\"l ll\">人<span class=\"s\">を</span>つくれ</span></h2>\r\n                <div class=\"detail\">Show detail<span class=\"mark\"></span></div>\r\n              </div>\r\n              <div class=\"body\">\r\n                <p class=\"text\">私のモットーは「製品をつくるより先に人をつくれ」であり、KPM（UK）はこれまであらゆる層、あらゆる職種の従業員に研修プログラムを提供し、人材育成面での認証も取得してきました。この熱心な取り組みは、人材投資で実績のあった企業にイギリス政府などから贈られる「Investors in People」賞を受賞することができたほどです。</p>\r\n              </div>\r\n            </div>\r\n            <div class=\"block n4\" data-aos=\"fade-left\" data-aos-duration=\"1000\" data-aos-delay=\"1000\" data-aos-offset=\"200\">\r\n              <div class=\"title hr\" data-micromodal-trigger=\"modal4\" role=\"button\">\r\n                <h2 class=\"text\"><span class=\"l\">「誰にもわからない」</span><br><span class=\"l\">ということ<span class=\"s\">を</span></span><br><span class=\"l\">わかっている<span class=\"s\">ことが</span>重要</span></h2>\r\n                <div class=\"detail\">Show detail<span class=\"mark\"></span></div>\r\n              </div>\r\n              <div class=\"body\">\r\n                <p class=\"text\">新しいことを始めようとした時に、私がいつも考えていることです。「知るための努力」はもちろん必要ですが、実は「誰にもわからないこと」もたくさんあります。これは「誰にもわからない」ということをわかっていることが重要で、それはどこかに絶対的な正解があるということでもないのです。</p>\r\n              </div>\r\n            </div>\r\n          </div>\r\n          <div class=\"blocks m2\">\r\n            <div class=\"block n5\" data-aos=\"fade-down\" data-aos-duration=\"1000\" data-aos-delay=\"0\" data-aos-offset=\"200\">\r\n              <div class=\"title hr\" data-micromodal-trigger=\"modal5\" role=\"button\">\r\n                <h2 class=\"text\"><span class=\"l\">究極<span class=\"s\">の</span>エネルギー</span><br><span class=\"l\">「水素」<span class=\"s\">を</span>活用<span class=\"s\">する</span></span><br><span class=\"l\">トップランナー</span></h2>\r\n                <div class=\"detail\">Show detail<span class=\"mark\"></span></div>\r\n              </div>\r\n              <div class=\"body\">\r\n                <p class=\"text\">脱炭素社会実現のエネルギーとして「水素」が大きな注目を集めています。川崎重工は水素エネルギー技術におけるトップランナー企業として技術革新を推進しています。</p>\r\n              </div>\r\n            </div>\r\n            <div class=\"block n6\" data-aos=\"fade-up\" data-aos-duration=\"1000\" data-aos-delay=\"900\" data-aos-offset=\"200\">\r\n              <div class=\"title vr vr-sp\" data-micromodal-trigger=\"modal6\" role=\"button\">\r\n                <h2 class=\"text\"><span class=\"l\">ＩＴ技術<span class=\"s\">などが</span>どれほど</span><br><span class=\"l\">急速<span class=\"s\">に</span>発達<span class=\"s\">しても、</span></span><br><span class=\"l\">ものづくり<span class=\"s\">の</span>根幹<span class=\"s\">は</span></span><br><span class=\"l\">変わらない</span></h2>\r\n                <div class=\"detail\">Show detail<span class=\"mark\"></span></div>\r\n              </div>\r\n              <div class=\"body\">\r\n                <p class=\"text\">IT技術などがどれほど急速に発達しても、ものづくりの根幹は変わらないと考えます。例えば、液体水素を-253℃でキープする、大量に運ぶ船やタンクなど、技術の大切さは変わりません。変わるのは、情報活用による生産性の効率アップ、ほしい人に届けるスピードなどです。今後は、私たちにしかできないものづくりの技術はしっかりキープしながら、それ以外は他社と協力しアライアンスを進めていく必要があります。全てを自分たちでやろうとすると、国際競争力を失い国内市場をも奪われてしまい、ガラパゴス化されてしまいます。これからはますます、グローバルな視点での戦略が重要となるでしょう。詳しくはこちらをご覧ください。</p>\r\n              </div>\r\n            </div>\r\n            <div class=\"block n7\" data-aos=\"fade-left\" data-aos-duration=\"1000\" data-aos-delay=\"300\" data-aos-offset=\"200\">\r\n              <div class=\"title hr\" data-micromodal-trigger=\"modal7\" role=\"button\">\r\n                <h2 class=\"text\"><span class=\"l\">目指す<span class=\"s\">のは、</span></span><br><span class=\"l\"><span class=\"s\">誰もが</span>等しく良質な</span><br><span class=\"l\">医療<span class=\"s\">を</span>享受<span class=\"s\">できる</span>社会</span></h2>\r\n                <div class=\"detail\">Show detail<span class=\"mark\"></span></div>\r\n              </div>\r\n              <div class=\"body\">\r\n                <p class=\"text\">5Gと「hinotori&trade;」が作り出そうとしているのは、誰もが等しく良質な医療を享受できる社会。手術支援ロボットが広く社会に実装されれば、専門医が常駐していない街でも、海を隔てた辺境の地でも、高度な手術を受けることができます。詳しくはこちらをご覧ください。</p>\r\n              </div>\r\n            </div>\r\n            <div class=\"block n8\" data-aos=\"fade-up\" data-aos-duration=\"1000\" data-aos-delay=\"700\" data-aos-offset=\"200\">\r\n              <div class=\"title hr\" data-micromodal-trigger=\"modal8\" role=\"button\">\r\n                <h2 class=\"text\"><span class=\"l\">技術<span class=\"s\">の</span>独り歩き<span class=\"s\">を</span>戒め、</span><br class=\"sp\"><span class=\"l ll\">社会<span class=\"s\">と</span>強調<span class=\"s\">して</span>「水素文化」<span class=\"s\">を</span>育てる</span></h2>\r\n                <div class=\"detail\">Show detail<span class=\"mark\"></span></div>\r\n              </div>\r\n              <div class=\"body\">\r\n                <p class=\"text\">水素技術の世界はよく「仲間の多い世界」と言われます。一部のメジャープレーヤーが独占的に主導権を握るのではなく、多くの人々や企業が、それぞれの役割・立場で利用方法検討や技術開発に取り組むことができるからです。そして、この水素エネルギーの流れを牽引し続けてきた川崎重工は、水素の未来に誰よりも深い確信を持ち続けており、リード役であるとの自負もあります。詳しくはこちらをご覧ください。</p>\r\n              </div>\r\n            </div>\r\n          </div>\r\n          <div class=\"blocks m3\">\r\n            <div class=\"block n9\" data-aos=\"fade-left\" data-aos-duration=\"1000\" data-aos-delay=\"100\" data-aos-offset=\"200\">\r\n              <div class=\"title hr\" data-micromodal-trigger=\"modal9\" role=\"button\">\r\n                <h2 class=\"text\"><span class=\"l\">「これなら大丈夫」<span class=\"s\">というところまで</span></span><br class=\"tb\"><span class=\"l\">開発<span class=\"s\">を</span>究め、自ら<span class=\"s\">の</span>ノウハウ<span class=\"s\">としていきたい</span></span></h2>\r\n                <div class=\"detail\">Show detail<span class=\"mark\"></span></div>\r\n              </div>\r\n              <div class=\"body\">\r\n                <p class=\"text\">航空機は安全性が第一なので、下地材一つをとっても確かな代替品質がないと技術交代は進みません。私たちには設計責任があるので、「これなら大丈夫」というところまで開発を究め、自らのノウハウとしていきたい。各種の規制を先取りした開発への取り組みは、当社の優位性を確保することにもつながります。詳しくはこちらをご覧ください。</p>\r\n              </div>\r\n            </div>\r\n            <div class=\"block n10\" data-aos=\"fade-up\" data-aos-duration=\"1000\" data-aos-delay=\"1100\" data-aos-offset=\"200\">\r\n              <div class=\"title vr vr-sp\" data-micromodal-trigger=\"modal10\" role=\"button\">\r\n                <h2 class=\"text\"><span class=\"l\">できなかった<span class=\"s\">ことを、</span></span><br><span class=\"l\">できるように<span class=\"s\">する</span></span></h2>\r\n                <div class=\"detail\">Show detail<span class=\"mark\"></span></div>\r\n              </div>\r\n              <div class=\"body\">\r\n                <p class=\"text\">私が若きエンジニアだった頃から大切にしていることは、「できなかったことを、できるようにする」ということ。これは他メーカーとの差別化や、市場ニーズにどう応えるかというところで非常に重要だと思っています。今では国内に限らず、社内外の方々と関わり合いを持つことも増えています。水素サプライチェーンは大変やりがいのある大きなプロジェクトですので、関係省庁やさまざまな企業との連携、ご協力のもと、水素社会の実現に向け歩んでいきたいと思います。詳しくはこちらをご覧ください。</p>\r\n              </div>\r\n            </div>\r\n            <div class=\"block n11\" data-aos=\"fade-right\" data-aos-duration=\"1000\" data-aos-delay=\"300\" data-aos-offset=\"200\">\r\n              <div class=\"title hr\" data-micromodal-trigger=\"modal11\" role=\"button\">\r\n                <h2 class=\"text\"><span class=\"l\">「地下から宇宙まで」<span class=\"s\">の</span></span><br><span class=\"l\">製品群<span class=\"s\">を</span>製造してきた、</span><br><span class=\"l\">当社<span class=\"s\">の</span>技術<span class=\"s\">を</span>結集</span></h2>\r\n                <div class=\"detail\">Show detail<span class=\"mark\"></span></div>\r\n              </div>\r\n              <div class=\"body\">\r\n                <p class=\"text\">「断熱性ではLNG運搬船の10倍の性能が必要ですが、その製造にはLNG用輸送タンクの知見や当社が種子島宇宙センターに設置した液化水素タンクの製造技術が生かされています」と語ります。「世界初の液化水素運搬船となることから、その安全性には十分配慮しており、緊急時の水素放出に対する安全評価も含めながら、輸送用タンクの技術開発を進めてきました。液化水素はLNGと比較して、蒸発しやすく、分子が小さいことから漏れやすい性質があります。これまで培ったLNG用タンクの製造ノウハウに、「地下から宇宙まで」の製品群を製造してきた、当社の技術を結集しています」。詳しくはこちらをご覧ください。</p>\r\n              </div>\r\n            </div>\r\n            <div class=\"block n12\" data-aos=\"fade-down\" data-aos-duration=\"1000\" data-aos-delay=\"200\" data-aos-offset=\"200\">\r\n              <div class=\"title hr\" data-micromodal-trigger=\"modal12\" role=\"button\">\r\n                <h2 class=\"text\"><span class=\"l\">見えない部分<span class=\"s\">での</span>不具合<span class=\"s\">を</span></span><span class=\"l\">絶対<span class=\"s\">に</span>見逃さないノウハウ</span></h2>\r\n                <div class=\"detail\">Show detail<span class=\"mark\"></span></div>\r\n              </div>\r\n              <div class=\"body\">\r\n                <p class=\"text\">当社の航空機用ギアの最大の特徴は、素材加工から熱処理、最終検査までの一貫した作業を行い、見えない部分での不具合を絶対に見逃さないノウハウを備えていることです。航空機用ギアの分野で、一貫したノウハウをもつのは世界に通用する強みです。詳しくはこちらをご覧ください。</p>\r\n              </div>\r\n            </div>\r\n          </div>\r\n          <div class=\"nav-block\" id=\"js-nav-goroku\"><a class=\"modal n1\" data-micromodal-trigger=\"modal1\" role=\"button\">GLOSSARY 01</a><a class=\"modal n2\" data-micromodal-trigger=\"modal2\" role=\"button\">GLOSSARY 02</a><a class=\"modal n3\" data-micromodal-trigger=\"modal3\" role=\"button\">GLOSSARY 03</a><a class=\"modal n4\" data-micromodal-trigger=\"modal4\" role=\"button\">GLOSSARY 04</a><a class=\"modal n5\" data-micromodal-trigger=\"modal5\" role=\"button\">GLOSSARY 05</a><a class=\"modal n6\" data-micromodal-trigger=\"modal6\" role=\"button\">GLOSSARY 06</a><a class=\"modal n7\" data-micromodal-trigger=\"modal7\" role=\"button\">GLOSSARY 07</a><a class=\"modal n8\" data-micromodal-trigger=\"modal8\" role=\"button\">GLOSSARY 08</a><a class=\"modal n9\" data-micromodal-trigger=\"modal9\" role=\"button\">GLOSSARY 09</a><a class=\"modal n10\" data-micromodal-trigger=\"modal10\" role=\"button\">GLOSSARY 10</a><a class=\"modal n11\" data-micromodal-trigger=\"modal11\" role=\"button\">GLOSSARY 11</a><a class=\"modal n12\" data-micromodal-trigger=\"modal12\" role=\"button\">GLOSSARY 12</a></div>\r\n        </div>\r\n      </section>\r\n    </main>\r\n    <div class=\"modal micromodal-slide\" id=\"modal1\" aria-hidden=\"true\">\r\n      <div class=\"modal__overlay\" tabindex=\"-1\" data-micromodal-close>\r\n        <div class=\"modal__container modal-goroku n1\" role=\"dialog\" aria-modal=\"true\">\r\n          <button class=\"close modal__close\" aria-label=\"Close modal\" data-micromodal-close></button>\r\n          <div class=\"inner\">\r\n            <p class=\"label\">GLOSSARY 01</p>\r\n            <div class=\"shim\"></div>\r\n            <div class=\"body\">\r\n              <p class=\"title\">日本企業<span class=\"s\">に</span><br>就職<span class=\"s\">したと</span>思うな！ </p>\r\n              <p class=\"text\">配属された当初、上司から、そう言われました。私が所属する部署では、扱う案件の約8割が海外のもの。仕事を進める上で、英語力は欠かせないスキルです。それに加えて、グローバルに物事を考える幅広い視野も求められます。今も、まったくもって正しい考え方だと、いつも肝に銘じています。</p>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n    <div class=\"modal micromodal-slide\" id=\"modal2\" aria-hidden=\"true\">\r\n      <div class=\"modal__overlay\" tabindex=\"-1\" data-micromodal-close>\r\n        <div class=\"modal__container modal-goroku n2\" role=\"dialog\" aria-modal=\"true\">\r\n          <button class=\"close modal__close\" aria-label=\"Close modal\" data-micromodal-close></button>\r\n          <div class=\"inner\">\r\n            <p class=\"label\">GLOSSARY 02</p>\r\n            <div class=\"shim\"></div>\r\n            <div class=\"body\">\r\n              <p class=\"title\">水素<span class=\"s\">の</span>力<span class=\"s\">で</span>子どもたち<span class=\"s\">に</span><br class=\"tb\">綺麗<span class=\"s\">な</span>未来<span class=\"s\">を</span>残したい</p>\r\n              <p class=\"text\">現在建造中の液化水素運搬船（パイロット船）に関する設計業務を担当しています。最近相次いで子どもが生まれたこともあり、豊かな自然やきれいな空気の重要性を再認識し、水素エネルギーをより身近なテーマとして感じるようになりました。子どもたちに美しく豊かな未来を残していくためにも、この仕事を全うしたいと感じています。</p>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n    <div class=\"modal micromodal-slide\" id=\"modal3\" aria-hidden=\"true\">\r\n      <div class=\"modal__overlay\" tabindex=\"-1\" data-micromodal-close>\r\n        <div class=\"modal__container modal-goroku n3\" role=\"dialog\" aria-modal=\"true\">\r\n          <button class=\"close modal__close\" aria-label=\"Close modal\" data-micromodal-close></button>\r\n          <div class=\"inner\">\r\n            <p class=\"label\">GLOSSARY 03</p>\r\n            <div class=\"shim\"></div>\r\n            <div class=\"body\">\r\n              <p class=\"title\">製品<span class=\"s\">を</span>つくるより先<span class=\"s\">に</span><br>人<span class=\"s\">を</span>つくれ</p>\r\n              <p class=\"text\">私のモットーは「製品をつくるより先に人をつくれ」であり、KPM（UK）はこれまであらゆる層、あらゆる職種の従業員に研修プログラムを提供し、人材育成面での認証も取得してきました。この熱心な取り組みは、人材投資で実績のあった企業にイギリス政府などから贈られる「Investors in People」賞を受賞することができたほどです。 詳しくは<a class=\"link-blue\" href=\"https://answers.khi.co.jp/ja/energy-environment/20190131j-02/\" target=\"_blank\">こちら</a></p>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n    <div class=\"modal micromodal-slide\" id=\"modal4\" aria-hidden=\"true\">\r\n      <div class=\"modal__overlay\" tabindex=\"-1\" data-micromodal-close>\r\n        <div class=\"modal__container modal-goroku n4\" role=\"dialog\" aria-modal=\"true\">\r\n          <button class=\"close modal__close\" aria-label=\"Close modal\" data-micromodal-close></button>\r\n          <div class=\"inner\">\r\n            <p class=\"label\">GLOSSARY 04</p>\r\n            <div class=\"shim\"></div>\r\n            <div class=\"body\">\r\n              <p class=\"title\">「誰にもわからない」<br>ということ<span class=\"s\">を</span><br>わかっている<span class=\"s\">ことが</span>重要</p>\r\n              <p class=\"text\">新しいことを始めようとした時に、私がいつも考えていることです。「知るための努力」はもちろん必要ですが、実は「誰にもわからないこと」もたくさんあります。これは「誰にもわからない」ということをわかっていることが重要で、それはどこかに絶対的な正解があるということでもないのです。</p>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n    <div class=\"modal micromodal-slide\" id=\"modal5\" aria-hidden=\"true\">\r\n      <div class=\"modal__overlay\" tabindex=\"-1\" data-micromodal-close>\r\n        <div class=\"modal__container modal-goroku n5\" role=\"dialog\" aria-modal=\"true\">\r\n          <button class=\"close modal__close\" aria-label=\"Close modal\" data-micromodal-close></button>\r\n          <div class=\"inner\">\r\n            <p class=\"label\">GLOSSARY 05</p>\r\n            <div class=\"shim\"></div>\r\n            <div class=\"body\">\r\n              <p class=\"title\">究極<span class=\"s\">の</span>エネルギー<br>「水素」<span class=\"s\">を</span>活用<span class=\"s\">する</span><br>トップランナー</p>\r\n              <p class=\"text\">脱炭素社会実現のエネルギーとして「水素」が大きな注目を集めています。川崎重工は水素エネルギー技術におけるトップランナー企業として技術革新を推進しています。</p>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n    <div class=\"modal micromodal-slide\" id=\"modal6\" aria-hidden=\"true\">\r\n      <div class=\"modal__overlay\" tabindex=\"-1\" data-micromodal-close>\r\n        <div class=\"modal__container modal-goroku n6\" role=\"dialog\" aria-modal=\"true\">\r\n          <button class=\"close modal__close\" aria-label=\"Close modal\" data-micromodal-close></button>\r\n          <div class=\"inner m2\">\r\n            <p class=\"label\">GLOSSARY 06</p>\r\n            <div class=\"shim\"></div>\r\n            <div class=\"body\">\r\n              <p class=\"title\">IT技術<span class=\"s\">などが</span>どれほど急速<span class=\"s\">に</span>発達<span class=\"s\">しても、</span><br class=\"tb\">ものづくり<span class=\"s\">の</span>根幹<span class=\"s\">は</span>変わらない</p>\r\n              <p class=\"text\">IT技術などがどれほど急速に発達しても、ものづくりの根幹は変わらないと考えます。例えば、液体水素を-253℃でキープする、大量に運ぶ船やタンクなど、技術の大切さは変わりません。変わるのは、情報活用による生産性の効率アップ、ほしい人に届けるスピードなどです。今後は、私たちにしかできないものづくりの技術はしっかりキープしながら、それ以外は他社と協力しアライアンスを進めていく必要があります。全てを自分たちでやろうとすると、国際競争力を失い国内市場をも奪われてしまい、ガラパゴス化されてしまいます。これからはますます、グローバルな視点での戦略が重要となるでしょう。 詳しくは<a class=\"link-blue\" href=\"https://answers.khi.co.jp/ja/energy-environment/20210731j-01/\" target=\"_blank\">こちら</a></p>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n    <div class=\"modal micromodal-slide\" id=\"modal7\" aria-hidden=\"true\">\r\n      <div class=\"modal__overlay\" tabindex=\"-1\" data-micromodal-close>\r\n        <div class=\"modal__container modal-goroku n7\" role=\"dialog\" aria-modal=\"true\">\r\n          <button class=\"close modal__close\" aria-label=\"Close modal\" data-micromodal-close></button>\r\n          <div class=\"inner\">\r\n            <p class=\"label\">GLOSSARY 07</p>\r\n            <div class=\"shim\"></div>\r\n            <div class=\"body\">\r\n              <p class=\"title\">目指す<span class=\"s\">のは、</span><br><span class=\"s\">誰もが</span>等しく良質な<br>医療<span class=\"s\">を</span>享受<span class=\"s\">できる</span>社会</p>\r\n              <p class=\"text\">5Gと「hinotori&trade;」が作り出そうとしているのは、誰もが等しく良質な医療を享受できる社会。手術支援ロボットが広く社会に実装されれば、専門医が常駐していない街でも、海を隔てた辺境の地でも、高度な手術を受けることができます。 詳しくは<a class=\"link-blue\" href=\"https://answers.khi.co.jp/ja/connected-society/20210131j-01/\" target=\"_blank\">こちら</a></p>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n    <div class=\"modal micromodal-slide\" id=\"modal8\" aria-hidden=\"true\">\r\n      <div class=\"modal__overlay\" tabindex=\"-1\" data-micromodal-close>\r\n        <div class=\"modal__container modal-goroku n8\" role=\"dialog\" aria-modal=\"true\">\r\n          <button class=\"close modal__close\" aria-label=\"Close modal\" data-micromodal-close></button>\r\n          <div class=\"inner\">\r\n            <p class=\"label\">GLOSSARY 08</p>\r\n            <div class=\"shim\"></div>\r\n            <div class=\"body\">\r\n              <p class=\"title\">技術<span class=\"s\">の</span>独り歩き<span class=\"s\">を</span>戒め、<br>社会<span class=\"s\">と</span>強調<span class=\"s\">して</span><br>「水素文化」<span class=\"s\">を</span>育てる</p>\r\n              <p class=\"text\">水素技術の世界はよく「仲間の多い世界」と言われます。一部のメジャープレーヤーが独占的に主導権を握るのではなく、多くの人々や企業が、それぞれの役割・立場で利用方法検討や技術開発に取り組むことができるからです。そして、この水素エネルギーの流れを牽引し続けてきた川崎重工は、水素の未来に誰よりも深い確信を持ち続けており、リード役であるとの自負もあります。詳しくは<a class=\"link-blue\" href=\"https://answers.khi.co.jp/ja/energy-environment/20180731j-02/\" target=\"_blank\"> こちら</a></p>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n    <div class=\"modal micromodal-slide\" id=\"modal9\" aria-hidden=\"true\">\r\n      <div class=\"modal__overlay\" tabindex=\"-1\" data-micromodal-close>\r\n        <div class=\"modal__container modal-goroku n9\" role=\"dialog\" aria-modal=\"true\">\r\n          <button class=\"close modal__close\" aria-label=\"Close modal\" data-micromodal-close></button>\r\n          <div class=\"inner\">\r\n            <p class=\"label\">GLOSSARY 09</p>\r\n            <div class=\"shim\"></div>\r\n            <div class=\"body\">\r\n              <p class=\"title\">「これなら大丈夫」<br><span class=\"s\">というところまで</span>開発<span class=\"s\">を</span>究め、<br>自ら<span class=\"s\">の</span>ノウハウ<span class=\"s\">としていきたい</span></p>\r\n              <p class=\"text\">航空機は安全性が第一なので、下地材一つをとっても確かな代替品質がないと技術交代は進みません。私たちには設計責任があるので、「これなら大丈夫」というところまで開発を究め、自らのノウハウとしていきたい。各種の規制を先取りした開発への取り組みは、当社の優位性を確保することにもつながります。 詳しくは<a class=\"link-blue\" href=\"https://answers.khi.co.jp/ja/energy-environment/20140731j-01/\" target=\"_blank\"> こちら</a></p>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n    <div class=\"modal micromodal-slide\" id=\"modal10\" aria-hidden=\"true\">\r\n      <div class=\"modal__overlay\" tabindex=\"-1\" data-micromodal-close>\r\n        <div class=\"modal__container modal-goroku n10\" role=\"dialog\" aria-modal=\"true\">\r\n          <button class=\"close modal__close\" aria-label=\"Close modal\" data-micromodal-close></button>\r\n          <div class=\"inner\">\r\n            <p class=\"label\">GLOSSARY 10</p>\r\n            <div class=\"shim\"></div>\r\n            <div class=\"body\">\r\n              <p class=\"title\">できなかった<span class=\"s\">ことを、</span><br>できるように<span class=\"s\">する</span></p>\r\n              <p class=\"text\">私が若きエンジニアだった頃から大切にしていることは、「できなかったことを、できるようにする」ということ。これは他メーカーとの差別化や、市場ニーズにどう応えるかというところで非常に重要だと思っています。今では国内に限らず、社内外の方々と関わり合いを持つことも増えています。水素サプライチェーンは大変やりがいのある大きなプロジェクトですので、関係省庁やさまざまな企業との連携、ご協力のもと、水素社会の実現に向け歩んでいきたいと思います。 詳しくは<a class=\"link-blue\" href=\"https://answers.khi.co.jp/ja/energy-environment/20170930j-01/\" target=\"_blank\"> こちら</a></p>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n    <div class=\"modal micromodal-slide\" id=\"modal11\" aria-hidden=\"true\">\r\n      <div class=\"modal__overlay\" tabindex=\"-1\" data-micromodal-close>\r\n        <div class=\"modal__container modal-goroku n11\" role=\"dialog\" aria-modal=\"true\">\r\n          <button class=\"close modal__close\" aria-label=\"Close modal\" data-micromodal-close></button>\r\n          <div class=\"inner m2\">\r\n            <p class=\"label\">GLOSSARY 11</p>\r\n            <div class=\"shim\"></div>\r\n            <div class=\"body\">\r\n              <p class=\"title\">「地下から宇宙まで」<span class=\"s\">の</span>製品群<span class=\"s\">を</span><br class=\"tb\">製造してきた、当社<span class=\"s\">の</span>技術<span class=\"s\">を</span>結集</p>\r\n              <p class=\"text\">「断熱性ではLNG運搬船の10倍の性能が必要ですが、その製造にはLNG用輸送タンクの知見や当社が種子島宇宙センターに設置した液化水素タンクの製造技術が生かされています」と語ります。「世界初の液化水素運搬船となることから、その安全性には十分配慮しており、緊急時の水素放出に対する安全評価も含めながら、輸送用タンクの技術開発を進めてきました。液化水素はLNGと比較して、蒸発しやすく、分子が小さいことから漏れやすい性質があります。これまで培ったLNG用タンクの製造ノウハウに、「地下から宇宙まで」の製品群を製造してきた、当社の技術を結集しています」。 詳しくは<a class=\"link-blue\" href=\"https://answers.khi.co.jp/ja/energy-environment/20210731-j02/\" target=\"_blank\"> こちら</a></p>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n    <div class=\"modal micromodal-slide\" id=\"modal12\" aria-hidden=\"true\">\r\n      <div class=\"modal__overlay\" tabindex=\"-1\" data-micromodal-close>\r\n        <div class=\"modal__container modal-goroku n12\" role=\"dialog\" aria-modal=\"true\">\r\n          <button class=\"close modal__close\" aria-label=\"Close modal\" data-micromodal-close></button>\r\n          <div class=\"inner\">\r\n            <p class=\"label\">GLOSSARY 12</p>\r\n            <div class=\"shim\"></div>\r\n            <div class=\"body\">\r\n              <p class=\"title\">見えない部分<span class=\"s\">での</span>不具合<span class=\"s\">を</span><br>絶対<span class=\"s\">に</span>見逃さないノウハウ</p>\r\n              <p class=\"text\">当社の航空機用ギアの最大の特徴は、素材加工から熱処理、最終検査までの一貫した作業を行い、見えない部分での不具合を絶対に見逃さないノウハウを備えていることです。航空機用ギアの分野で、一貫したノウハウをもつのは世界に通用する強みです。 詳しくは<a class=\"link-blue\" href=\"https://answers.khi.co.jp/ja/energy-environment/20181031j-01/\" target=\"_blank\"> こちら</a></p>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n    <div class=\"sec-pickup foot\" id=\"js-foot-pickup\">\r\n      <div class=\"content\">\r\n        <h2 class=\"title-underbar white\"><span class=\"label\" data-splitting>PICKUP</span><span class=\"label-c\" data-splitting>CONTENTS</span></h2>\r\n      </div>\r\n      <div class=\"wrapper\">\r\n        <div class=\"container swiper-container\" id=\"js-carousel-foot\">\r\n          <div class=\"swiper-np\">\r\n            <div class=\"button-prev\"></div>\r\n            <div class=\"button-next\"></div>\r\n          </div>\r\n          <div class=\"wrap-carousel swiper-wrapper\">\r\n            <div class=\"item swiper-slide\"><a class=\"box n15\" href=\"/recruit/internship.html\">\r\n                <h3 class=\"title-bar\"><span class=\"en\"><span class=\"label\" data-splitting>Recruit</span></span><span class=\"ja\"><span class=\"label\" data-splitting>インターンシップ情報</span></span></h3>\r\n                <figure class=\"fig\"><img src=\"/assets/images/home/fig_content_a_15.jpg\" alt=\"\"></figure>\r\n                <p class=\"link\"><span class=\"label\">詳細をみる</span></p></a></div>\r\n            <div class=\"item swiper-slide\"><a class=\"box n14\" href=\"https://answers.khi.co.jp/ja/special/visionmap2030/\" target=\"_blank\">\r\n                <h3 class=\"title-bar\"><span class=\"en\"><span class=\"label\" data-splitting>ANSWERS</span></span><span class=\"ja\"><span class=\"label\" data-splitting>Kawasaki ViSiON MAP 2030</span></span></h3>\r\n                <figure class=\"fig\"><img src=\"/assets/images/home/fig_content_a_14.jpg\" alt=\"\"></figure>\r\n                <p class=\"link blank\"><span class=\"label\">詳細をみる</span></p></a></div>\r\n            <div class=\"item swiper-slide\"><a class=\"box n13\" href=\"/field/pronoun/\">\r\n                <h3 class=\"title-bar\"><span class=\"en\"><span class=\"label\" data-splitting>Work Field</span></span><span class=\"ja\"><span class=\"label\" data-splitting>未来の代名詞・川崎重工</span></span></h3>\r\n                <figure class=\"fig\"><img src=\"/assets/images/home/fig_content_a_13.jpg\" alt=\"\"></figure>\r\n                <p class=\"link\"><span class=\"label\">詳細をみる</span></p></a></div>\r\n            <div class=\"item swiper-slide\"><a class=\"box n12\" href=\"/vision/project_02.html\">\r\n                <h3 class=\"title-bar\"><span class=\"en\"><span class=\"label\" data-splitting>Vision</span></span><span class=\"ja\"><span class=\"label\" data-splitting>国産初の手術支援ロボット</span></span><span class=\"ja\"><span class=\"label\" data-splitting>「hinotori」開発プロジェクト</span></span></h3>\r\n                <figure class=\"fig\"><img src=\"/assets/images/home/fig_content_a_12.jpg\" alt=\"\"></figure>\r\n                <p class=\"link\"><span class=\"label\">詳細をみる</span></p></a></div>\r\n            <div class=\"item swiper-slide\"><a class=\"box n11\" href=\"/vision/project_01.html\">\r\n                <h3 class=\"title-bar\"><span class=\"en\"><span class=\"label\" data-splitting>Vision</span></span><span class=\"ja\"><span class=\"label\" data-splitting>カーボンニュートラル</span></span><span class=\"ja\"><span class=\"label\" data-splitting>実現プロジェクト</span></span></h3>\r\n                <figure class=\"fig\"><img src=\"/assets/images/home/fig_content_a_11.jpg\" alt=\"\"></figure>\r\n                <p class=\"link\"><span class=\"label\">詳細をみる</span></p></a></div>\r\n            <div class=\"item swiper-slide\"><a class=\"box n10\" href=\"/people/goroku/\">\r\n                <h3 class=\"title-bar\"><span class=\"en\"><span class=\"label\" data-splitting>People</span></span><span class=\"ja\"><span class=\"label\" data-splitting>川崎語録</span></span></h3>\r\n                <figure class=\"fig\"><img src=\"/assets/images/home/fig_content_a_10.png\" alt=\"\"></figure>\r\n                <p class=\"link\"><span class=\"label\">詳細をみる</span></p></a></div>\r\n            <div class=\"item swiper-slide\"><a class=\"box n9\" href=\"/about/value.html\">\r\n                <h3 class=\"title-bar\"><span class=\"en\"><span class=\"label\" data-splitting>About KHI</span></span><span class=\"ja\"><span class=\"label\" data-splitting>川崎重工の存在意義</span></span></h3>\r\n                <figure class=\"fig\"><img src=\"/assets/images/home/fig_content_a_09.jpg\" alt=\"\"></figure>\r\n                <p class=\"link\"><span class=\"label\">詳細をみる</span></p></a></div>\r\n            <div class=\"item swiper-slide\"><a class=\"box n8\" href=\"https://youtu.be/N7f8htRD5vQ\" target=\"_blank\">\r\n                <h3 class=\"title-bar\"><span class=\"en\"><span class=\"label\" data-splitting>Changing forward</span></span><span class=\"ja\"><span class=\"label\" data-splitting>カワる、サキへ。</span></span></h3>\r\n                <figure class=\"fig\"><img src=\"/assets/images/home/fig_content_a_08.jpg\" alt=\"\"></figure>\r\n                <p class=\"link blank\"><span class=\"label\">詳細をみる</span></p></a></div>\r\n            <div class=\"item swiper-slide\"><a class=\"box\" href=\"/about/aboutkhi.html\">\r\n                <h3 class=\"title-bar\"><span class=\"en\"><span class=\"label\" data-splitting>About KHI</span></span><span class=\"ja\"><span class=\"label\" data-splitting>川崎重工について</span></span></h3>\r\n                <figure class=\"fig\"><img src=\"/assets/images/home/fig_content_a_01.jpg\" alt=\"\"></figure>\r\n                <p class=\"link\"><span class=\"label\">詳細をみる</span></p></a></div>\r\n            <div class=\"item swiper-slide\"><a class=\"box n7\" href=\"/people/crosstalk/\">\r\n                <h3 class=\"title-bar\"><span class=\"en\"><span class=\"label\" data-splitting>People</span></span><span class=\"ja\"><span class=\"label\" data-splitting>CROSS TALK 働き方を知る座談会</span></span></h3>\r\n                <figure class=\"fig\"><img src=\"/assets/images/home/fig_content_a_07.png\" alt=\"\"></figure>\r\n                <p class=\"link\"><span class=\"label\">詳細をみる</span></p></a></div>\r\n            <div class=\"item swiper-slide\"><a class=\"box n2\" href=\"/people/career/\">\r\n                <h3 class=\"title-bar\"><span class=\"en\"><span class=\"label\" data-splitting>People</span></span><span class=\"ja\"><span class=\"label\" data-splitting>キャリア入社社員の声</span></span></h3>\r\n                <figure class=\"fig\"><img src=\"/assets/images/home/fig_content_a_02.jpg\" alt=\"\"></figure>\r\n                <p class=\"link\"><span class=\"label\">詳細をみる</span></p></a></div>\r\n            <div class=\"item swiper-slide\"><a class=\"box n3\" data-aos-delay=\"300\" href=\"/people/\">\r\n                <h3 class=\"title-bar\"><span class=\"en\"><span class=\"label\" data-splitting>People</span></span><span class=\"ja\"><span class=\"label\" data-splitting>社員紹介index</span></span></h3>\r\n                <figure class=\"fig\"><img src=\"/assets/images/home/fig_content_a_03.jpg\" alt=\"\"></figure>\r\n                <p class=\"link\"><span class=\"label\">詳細をみる</span></p></a></div>\r\n            <div class=\"item swiper-slide\"><a class=\"box n4\" href=\"https://answers.khi.co.jp/ja/energy-environment/20210731j-01/\" target=\"_blank\">\r\n                <h3 class=\"title-bar\"><span class=\"en\"><span class=\"label\" data-splitting>ANSWERS</span></span><span class=\"ja\"><span class=\"label\" data-splitting>日本がめざすカーボンニュートラルとは？</span></span><span class=\"ja\"><span class=\"label\" data-splitting>脱炭素を成長の原動力へ</span></span></h3>\r\n                <figure class=\"fig\"><img src=\"/assets/images/home/fig_content_a_04.jpg\" alt=\"\"></figure>\r\n                <p class=\"link blank\"><span class=\"label\">詳細をみる</span></p></a></div>\r\n            <div class=\"item swiper-slide\"><a class=\"box n5\" data-aos-delay=\"300\" href=\"https://answers.khi.co.jp/ja/voices/20200731j-02/\" target=\"_blank\">\r\n                <h3 class=\"title-bar\"><span class=\"en\"><span class=\"label\" data-splitting>ANSWERS</span></span><span class=\"ja\"><span class=\"label large\" data-splitting>「つぎの社会へ、信頼のこたえを」</span></span></h3>\r\n                <figure class=\"fig\"><img src=\"/assets/images/home/fig_content_a_05.jpg\" alt=\"\"></figure>\r\n                <p class=\"link blank\"><span class=\"label\">詳細をみる</span></p></a></div>\r\n            <div class=\"item swiper-slide\"><a class=\"box n6\" data-aos-delay=\"600\" href=\"https://answers.khi.co.jp/ja/connected-society/20210131j-01/\" target=\"_blank\">\r\n                <h3 class=\"title-bar\"><span class=\"en\"><span class=\"label\" data-splitting>ANSWERS</span></span><span class=\"ja\"><span class=\"label\" data-splitting>患者と医師を支えるテクノロジー。</span></span><span class=\"ja\"><span class=\"label\" data-splitting>手術支援ロボットが起こす革命</span></span></h3>\r\n                <figure class=\"fig\"><img src=\"/assets/images/home/fig_content_a_06.jpg\" alt=\"\"></figure>\r\n                <p class=\"link blank\"><span class=\"label\">詳細をみる</span></p></a></div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n    <footer class=\"foot-root\" id=\"js-foot-root\">\r\n      <div class=\"links\"><a class=\"text blank\" href=\"https://www.khi.co.jp/\" target=\"_blank\"> 川崎重工業株式会社オフィシャルサイト</a><a class=\"banner\" data-aos=\"fade-up\" href=\"https://answers.khi.co.jp/\" target=\"_blank\"><img src=\"/assets/images/common/thm_foot_01.png\" width=\"170\" alt=\"\"></a><a class=\"link\" data-aos=\"fade-down\" href=\"https://www.youtube.com/channel/UCzfhPd8i2-rpMSE6Ey0Oeyg\" target=\"_blank\"><img src=\"/assets/images/common/thm_foot_02.png\" width=\"96\" alt=\"\"></a></div>\r\n      <div class=\"foot\">\r\n        <address class=\"cr\">Copyright &copy; Kawasaki Heavy Industries, Ltd. All rights reserved.</address>\r\n        <div class=\"misc\"><a class=\"link\" href=\"https://www.khi.co.jp/cookie_policy/\" target=\"_blank\">クッキーポリシー</a><a class=\"link\" href=\"javascript:Bootstrapper.gateway.openModal();\"> クッキー詳細設定</a></div><a class=\"totop js-smooth-scroll\" href=\"#top\"></a>\r\n      </div>\r\n    </footer>\r\n    <script src=\"/assets/js/main.js\"></script>\r\n  <script type=\"text/javascript\" src=\"https://api.crm.i-myrefer.jp/track/L2wH15crfNBkkAhVWzd3ie7AYljigUSnS7tWHHDFFXdq310o6X/mt.js\"></script>\r\n</body>\r\n</html>","finalUrl":"https://www.khi-saiyo.jp/people/goroku/","rendered":false,"_cachedAt":"2026-06-23T23:17:03.781Z"}