=\"../aboutus/#mission\">経営理念</a></li>\n              <li><a href=\"../aboutus/#message\">代表ご挨拶</a></li>\n              <li><a href=\"../aboutus/#profile\">会社概要</a></li>\n              <li><a href=\"../aboutus/#officer\">役員紹介</a></li>\n              <li><a href=\"../aboutus/#history\">沿革</a></li>\n              <li><a href=\"../aboutus/#commendation\">受賞・認定・記事掲載歴</a></li>\n            </ul>\n          </li>\n          <li class=\"nav-item\"><a class=\"nav-link\" href=\"../vision/\">ビジョン</a></li>\n          <li class=\"nav-item dropdown\"> <a class=\"nav-link dropdown-toggle\" href=\"#\" id=\"nav_sus\" role=\"button\" data-bs-toggle=\"dropdown\" aria-expanded=\"false\" aria-haspopup=\"true\">サスティナビリティ</a>\n            <ul class=\"dropdown-menu child-list\" aria-labelledby=\"nav_sus\">\n              <li><a href=\"../environment/\">環境への取り組み</a></li>\n              <li><a href=\"../category/sustainability-social-effort/\">社会的な取り組み</a></li>\n            </ul>\n          </li>\n          <li class=\"nav-item dropdown\"> <a class=\"nav-link dropdown-toggle\" href=\"#\" id=\"nav_original\" role=\"button\" data-bs-toggle=\"dropdown\" aria-expanded=\"false\">オリジナル商品</a>\n            <ul class=\"dropdown-menu child-list\" aria-labelledby=\"nav_original\">\n              <li><a href=\"../original/kikouhou/\">機工報</a></li>\n\t\t\t  <li><a href=\"../original/robottana/\">ROBOTTANA</a></li>\n\t\t\t  <li><a href=\"../original/bolt-picking-system/\">ボルトピッキングシステム</a></li>\n            </ul>\n          </li>\n          <li class=\"nav-item dropdown\"> <a class=\"nav-link dropdown-toggle\" href=\"#\" id=\"nav_collabo\" role=\"button\" data-bs-toggle=\"dropdown\" aria-expanded=\"false\">コラボレーション</a>\n            <ul class=\"dropdown-menu child-list\" aria-labelledby=\"nav_collabo\">\n              <li><a href=\"../collaboration/carbonizer/\">炭化装置</a></li>\n            </ul>\n          </li>\n          <li class=\"nav-item\"><a class=\"nav-link\" href=\"../allnews/\">NEWS</a></li>\n          <li class=\"nav-item\"><a class=\"nav-link\" href=\"../blog/\">コラム</a></li>\n          <li class=\"nav-item\"><a class=\"nav-link\" href=\"../jobs/\">採用情報</a></li>\n          <li class=\"nav-item\"><a class=\"nav-link\" href=\"../inquiry/\">お問い合わせ</a></li>\n          <li class=\"nav-item service_link\"><a class=\"nav-link\" href=\"https://service.kanazawakiko.jp/\">商材情報サイトへ</a></li>\n        </ul>\n      </div>\n    </div>\n  </nav>\n</header>\n\n<div class=\"page_ti\"><!-- InstanceBeginEditable name=\"page-img\" --><img src=\"../2.1/img/inquiry/inquiry_ti.jpg\" alt=\"お問い合わせ\"><!-- InstanceEndEditable -->\n  <div class=\"wrap\">\n    <div class=\"page_ti_in\">\n      <h3><!-- InstanceBeginEditable name=\"page-title\" -->お問い合わせ<!-- InstanceEndEditable --></h3>\n    </div>\n  </div>\n</div>\n\n<article>\n  <main class=\"container\">\n    <ul class=\"list clearfix\">\n      <li><a href=\"https://www.kanazawakiko.jp/\">HOME</a></li>\n      <!-- InstanceBeginEditable name=\"list-page-title\" -->\n      <li>お問い合わせ</li>\n      <!-- InstanceEndEditable -->\n    </ul>\n    <!-- InstanceBeginEditable name=\"main\" -->\n    <dl class=\"accordion js-accordion\">\n      <div class=\"accordion__item js-accordion-trigger\">\n        <dt class=\"accordion__title\">お問い合わせ方法一覧</dt>\n        <dd class=\"accordion__content\">\n          <ul class=\"anchor\">\n            <li><a href=\"#mailform\">メールフォーム</a></li>\n\t\t\t<li><a href=\"#by_phone\">お電話でのお問い合わせ</a></li>\n            <li><a href=\"#by_phone02\">採用に関するお問い合わせ</a></li>\n          </ul>\n        </dd>\n      </div>\n    </dl>\n    <section id=\"mailform\">\n      <h3>メールフォーム<span>MAILFORM</span></h3>\n      <div class=\"wrap\">\n        <p class=\"pc_center_txt\">弊社へのご連絡・お問い合わせ等、お気軽に送信ください。</p>\n        <div class=\"linebox w600\">\n          <p class=\"blue bold\">お客様へ</p>\n          <p>こちらからのご連絡は数日中（弊社休日を除く）にしております。<br>\n            万が一返信が届かない場合は恐れ入りますが076-266-8008までご連絡ください。</p>\n        </div>\n        <form action=\"https://www.kanazawakiko.jp/cgi-bin/corp-fm/postmail.cgi\" method=\"post\">\n          <div class=\"form\">\n            <dl>\n              <div>\n                <dt class=\"need\">送信内容</dt>\n                <dd>\n                  <select name=\"_select\" id=\"cho\" class=\"validate[required]\" data-errormessage-value-missing=\"* 項目を選択してください。\">\n                    <optgroup label=\"\">\n                    <option selected=\"selected\" value=\"\">選択してください</option>\n                    <option value=\"商品に関するお問い合わせ\">商品に関するお問い合わせ</option>\n                    <option value=\"技術的なお問い合わせ\" disabled>技術的なお問い合わせ</option>\n                    <option value=\"AI／IoT／「機工報」関連\">┣AI／IoT／「機工報」関連</option>\n                    <option value=\"ソリューション／「ROBOTTANA」関連\">┣ソリューション／「ROBOTTANA」関連</option>\n                    <option value=\"SiCウエハ／GaN基板関連\">┣SiCウエハ／GaN基板関連</option>\n                    <option value=\"その他、ご相談\">┗その他、ご相談</option>\n                    <option value=\"採用について\">採用について</option>\n                    <option value=\"その他お問い合わせ\">その他お問い合わせ</option>\n                    </optgroup>\n                  </select>\n                </dd>\n              </div>\n              <div>\n                <dt class=\"need\">お客様のお名前</dt>\n                <dd>\n                  <input type=\"text\" id=\"name\" name=\"_お客様のお名前\" value=\"\" placeholder=\"例)山田太郎\" class=\"validate[required]\">\n\t\t\t\t\t<div class=\"error-message\"></div>\n                </dd>\n              </div>\n              <div>\n                <dt>ふりがな</dt>\n                <dd>\n                  <input type=\"text\" id=\"name2\" name=\"ふりがな\" value=\"\" placeholder=\"例)やまだたろう\">\n                </dd>\n              </div>\n              <div>\n                <dt class=\"need\">メールアドレス</dt>\n                <dd>\n                  <input type=\"email\" id=\"mail\" name=\"_email\" value=\"\" class=\"validate[required,custom[email]\">\n                </dd>\n              </div>\n              <div>\n                <dt class=\"need\">お電話番号（携帯可）</dt>\n                <dd>\n                  <input type=\"tel\" id=\"phone\" name=\"_お電話番号（携帯可）\" value=\"\" placeholder=\"例)076-266-8001\" class=\"validate[required,custom[phone]\">\n\t\t\t\t\t半角数字で入力してください。\n                </dd>\n              </div>\n              <div>\n                <dt class=\"need\">お問い合わせ内容</dt>\n                <dd>\n                  <textarea name=\"_お問い合わせ内容\" id=\"comment\" placeholder=\"お問い合わせ内容を入力してください\" class=\"validate[required]\"></textarea>\n                </dd>\n              </div>\n            </dl>\n\t\t\t  <p><span class=\"marker\">資料をご請求の方は下記入力もお願いいたします。</span></p>\n            <dl>\n              <div>\n                <dt>郵便番号</dt>\n                <dd>\n                  <input type=\"text\" name=\"郵便番号\" id=\"zip\" style=\"ime-mode:inactive\" onkeyup=\"AjaxZip3.zip2addr(this,'','ご住所','ご住所');\">\n                </dd>\n              </div>\n              <div>\n                <dt>ご住所</dt>\n                <dd>\n                  <input type=\"text\" id=\"add\" name=\"ご住所\" value=\"\">\n                </dd>\n              </div>\n              <div>\n                <dt>貴社名</dt>\n                <dd>\n                  <input type=\"text\" id=\"corpname\" name=\"貴社名\" value=\"\" placeholder=\"例)金沢機工株式会社\">\n                </dd>\n              </div>\n              <div>\n                <dt>所属部署</dt>\n                <dd>\n                  <input type=\"text\" id=\"department\" name=\"所属部署\" value=\"\" placeholder=\"例)営業部\">\n                </dd>\n              </div>\n              <div>\n                <dt>役職名</dt>\n                <dd>\n                  <input type=\"text\" id=\"position\" name=\"役職\" value=\"\" placeholder=\"例)部長\">\n                </dd>\n              </div>\n              <div>\n                <dt>FAX</dt>\n                <dd>\n                  <input type=\"tel\" id=\"fax\" name=\"FAX\" value=\"\" placeholder=\"例)076-266-8002\">\n                </dd>\n              </div>\n            </dl>\n\t\t\t<p class=\"center\">\n                <input type=\"submit\" class=\"bt\" value=\"送信内容の確認\">\n              </p>\n          </div>\n        </form>\n      </div>\n    </section>\n\t<section id=\"by_phone\">\n      <h3>お電話でのお問い合わせ<span>CONTACT US (PHONE NUMBERS)</span></h3>\n      <dl class=\"w48 malr-auto mab40\">\n        <div>\n          <dt><span class=\"arrow_box\">弊社へのお問い合わせ</span><span class=\"features_detail\">代表</span></dt>\n          <dd>\n            <p class=\"pc pc_center_txt s25 bold\"><i class=\"fas fa-phone-alt\"></i> 076-266-8001</p>\n            <p class=\"bt_tel sp\"><a href=\"tel:0762668001\"><i class=\"fas fa-phone-alt\"></i> 076-266-8001</a></p>\n          </dd>\n        </div>\n      </dl>\n      <dl class=\"flex3\">\n        <div class=\"w48 mab40\">\n          <dt><span class=\"arrow_box\">工具、産業用機器等の<br class=\"sp\">ご用命・お問い合わせ</span><span class=\"features_detail\">営業部（代表）</span></dt>\n          <dd>\n            <p class=\"pc pc_center_txt s25 bold\"><i class=\"fas fa-phone-alt\"></i> 076-266-8001</p>\n            <p class=\"bt_tel sp\"><a href=\"tel:0762668001\"><i class=\"fas fa-phone-alt\"></i> 076-266-8001</a></p>\n          </dd>\n        </div>\n        <div class=\"w48 mab40\">\n          <dt><span class=\"arrow_box\">設備、工作機械の<br class=\"sp\">ご用命・お問い合わせ</span><span class=\"features_detail\">機械部</span></dt>\n          <dd>\n            <p class=\"pc pc_center_txt s25 bold\"><i class=\"fas fa-phone-alt\"></i> 076-266-8003</p>\n            <p class=\"bt_tel sp\"><a href=\"tel:0762668003\"><i class=\"fas fa-phone-alt\"></i> 076-266-8003</a></p>\n          </dd>\n        </div>\n\t\t<div class=\"w48 mab40\">\n          <dt><span class=\"arrow_box\">半導体関連（洗浄装置・化合物ウェハ）、<br>環境関連設備（炭化装置等）の<br class=\"sp\">ご用命・お問い合わせ</span><span class=\"features_detail\">ソーシャルイノベーション事業部</span></dt>\n          <dd>\n            <p class=\"pc pc_center_txt s25 bold\"><i class=\"fas fa-phone-alt\"></i