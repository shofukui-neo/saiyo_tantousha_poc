m_flow_list\">\n      <li class=\"all_m_form_flow_item\">入力画面</li>\n      <li class=\"all_m_form_flow_item\">確認画面</li>\n      <li class=\"all_m_form_flow_item\">送信完了</li>\n    </ul>\n  </div>\n\n  <form method=\"post\" action=\"./?act=conf\" enctype=\"multipart/form-data\">\n    <input type=\"hidden\" name=\"MAX_FILE_SIZE\" value=\"10485760\">\n    <div class=\"all_m_form\">\n      <div class=\"all_m_form_inline\">\n        \n        <dl class=\"all_m_form_table\">\n          <dt class=\"all_m_form_table_title\"><div class=\"inline\">お名前<span class=\"ico_inquiry\">必須</span></div></dt>\n          <dd class=\"all_m_form_table_input\"><input type=\"text\" name=\"kname\" maxlength=\"128\" value=\"\" class=\"all_c_input\" placeholder=\"例：山田太郎\"></dd>\n          <dt class=\"all_m_form_table_title is_group\"><div class=\"inline\">お名前カナ<span class=\"ico_inquiry\">必須</span></div></dt>\n          <dd class=\"all_m_form_table_input is_group\"><input type=\"text\" name=\"fname\" maxlength=\"128\" value=\"\" class=\"all_c_input\" placeholder=\"例：ヤマダタロウ\"></dd>\n          <dt class=\"all_m_form_table_title\"><div class=\"inline\">メールアドレス<span class=\"ico_inquiry\">必須</span></div></dt>\n          <dd class=\"all_m_form_table_input\"><input type=\"text\" name=\"email\" maxlength=\"128\" value=\"\" class=\"all_c_input\" placeholder=\"例：takizumi@gmail.com\"></dd>\n          <dt class=\"all_m_form_table_title is_group\"><div class=\"inline\">メールアドレス<small>（確認用）</small><span class=\"ico_inquiry\">必須</span></div></dt>\n          <dd class=\"all_m_form_table_input is_group\"><input type=\"text\" name=\"email2\" maxlength=\"128\" value=\"\" class=\"all_c_input\" placeholder=\"例：takizumi@gmail.com\"></dd>\n          <dt class=\"all_m_form_table_title\"><div class=\"inline\">電話番号<span class=\"ico_inquiry\">必須</span></div></dt>\n          <dd class=\"all_m_form_table_input\"><input type=\"text\" name=\"tel\" maxlength=\"128\" value=\"\" class=\"all_c_input\" placeholder=\"例：00-0000-0000\"></dd>\n          <dt class=\"all_m_form_table_title\"><div class=\"inline\">生年月日<span class=\"ico_inquiry\">必須</span></div></dt>\n          <dd class=\"all_m_form_table_input all_m_form_table_input_birth\">\n            <div class=\"all_c_select all_c_select_y\">\n              <select name=\"birthY\">\n                <option value='0'>----</option><option value='1'>1986</option><option value='2'>1987</option><option value='3'>1988</option><option value='4'>1989</option><option value='5'>1990</option><option value='6'>1991</option><option value='7'>1992</option><option value='8'>1993</option><option value='9'>1994</option><option value='10'>1995</option><option value='11'>1996</option><option value='12'>1997</option><option value='13'>1998</option><option value='14'>1999</option><option value='15'>2000</option><option value='16'>2001</option><option value='17'>2002</option><option value='18'>2003</option><option value='19'>2004</option><option value='20'>2005</option><option value='21'>2006</option>\n              </select>\n            </div>\n            年\n            <div class=\"all_c_select all_c_select_m\">\n              <select name=\"birthM\">\n                <option value='0'>--</option><option value='1'>1</option><option value='2'>2</option><option value='3'>3</option><option value='4'>4</option><option value='5'>5</option><option value='6'>6</option><option value='7'>7</option><option value='8'>8</option><option value='9'>9</option><option value='10'>10</option><option value='11'>11</option><option value='12'>12</option>\n              </select>\n            </div>\n            月\n            <div class=\"all_c_select all_c_select_d\">\n              <select name=\"birthD\">\n                <option value='0'>--</option><option value='1'>1</option><option value='2'>2</option><option value='3'>3</option><option value='4'>4</option><option value='5'>5</option><option value='6'>6</option><option value='7'>7</option><option value='8'>8</option><option value='9'>9</option><option value='10'>10</option><option value='11'>11</option><option value='12'>12</option><option value='13'>13</option><option value='14'>14</option><option value='15'>15</option><option value='16'>16</option><option value='17'>17</option><option value='18'>18</option><option value='19'>19</option><option value='20'>20</option><option value='21'>21</option><option value='22'>22</option><option value='23'>23</option><option value='24'>24</option><option value='25'>25</option><option value='26'>26</option><option value='27'>27</option><option value='28'>28</option><option value='29'>29</option><option value='30'>30</option><option value='31'>31</option>\n              </select>\n            </div>\n            日\n            \n          </dd>\n          <dt class=\"all_m_form_table_title all_m_form_table_title_job\"><div class=\"inline\">希望職種<span class=\"ico_inquiry\">必須</span></div></dt>\n          <dd class=\"all_m_form_table_input\">\n            <div class=\"all_c_radio\">\n              <input type=\"radio\" name=\"job\" value=\"1\" id=\"job1\"><label for=\"job1\">営業（正社員）</label>\n            </div>\n            <div class=\"all_c_radio\">\n              <input type=\"radio\" name=\"job\" value=\"2\" id=\"job2\"><label for=\"job2\">施工管理（契約社員）</label>\n            </div>\n            <div class=\"all_c_radio\">\n              <input type=\"radio\" name=\"job\" value=\"3\" id=\"job3\"><label for=\"job3\">事務（パート）</label>\n            </div>\n            <div class=\"all_c_radio\">\n              <input type=\"radio\" name=\"job\" value=\"4\" id=\"job4\"><label for=\"job4\">退去立会（パート）</label>\n            </div>\n            \n          </dd>\n          \n          <dt class=\"all_m_form_table_title\"><div class=\"inline\">自由事項</div></dt>\n          <dd class=\"all_m_form_table_input\"><textarea name=\"douki\" maxlength=\"1000\" rows=\"5\" cols=\"20\" class=\"all_c_txtarea\" placeholder=\"例）応募動機・自己PRなど\"></textarea></dd>\n          <dt class=\"all_m_form_table_title\"><div class=\"inline\">ご質問</div></dt>\n          <dd class=\"all_m_form_table_input\"><textarea name=\"question\" maxlength=\"1000\" rows=\"5\" cols=\"20\" class=\"all_c_txtarea\" placeholder=\"お問い合わせ内容を入力してください。\"></textarea></dd>\n        </dl>\n\n        <div class=\"all_m_form_bottom\">\n          <dl class=\"all_m_form_privacy\">\n            <dt class=\"all_m_form_privacy_title\">個人情報保護方針への同意<span class=\"ico_inquiry\">必須</span></dt>\n            <dd class=\"all_m_form_privacy_input all_c_checkbox\">\n              <input type=\"checkbox\" name=\"agree[1]\" value=\"1\" id=\"agree1\"><label for=\"agree1\"><a href=\"http://www.takizumi.com/privacy\" target=\"_blank\">個人情報保護方針</a>に同意します</label>\n              \n              <p class=\"cap\">上記個人情報保護方針をご確認の上、同意していただける場合はチェックを入れてください。</p>\n            </dd>\n          </dl>\n        </div>\n      </div><!-- /.all_m_form_inline -->\n\n      <div class=\"all_m_form_input\">\n        <p class=\"all_m_form_btn\"><input type=\"submit\" name=\"b_conf\" value=\"内容を確認する\" id=\"btn-send\"></p>\n      </div>\n    </div><!-- /.all_m_form -->\n    <input type=\"hidden\" name=\"token\" value=\"4f1bd14c2f1d80f9b89de54954f028e8\">\n  </form>\n</div>\n                    </div>\n                </div><!-- /.entry_contents -->\n\n                <div class=\"all_m_breadcrumb\">\n                    <div class=\"all_l_wrap\">\n                        <ul class=\"all_m_breadcrumb_list\">\n                            <li class=\"all_m_breadcrumb_item\"><a href=\"../\">トップ</a></li>\n                            <li class=\"all_m_breadcrumb_item _current\">エントリーフォーム</li>\n                        </ul>\n                    </div>\n                </div><!-- /.all_m_breadcrumb -->\n            </main><!-- /#main -->\n\n            <div class=\"all_m_entry\">\n  <div class=\"all_m_entry_boxes\">\n    <div class=\"all_m_entry_box all_m_entry_recruitment\"><a href=\"/recruit/detail/\">\n      <span class=\"all_m_entry_box_fi