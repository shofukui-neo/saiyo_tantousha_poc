jectBoundingBox\"><path transform=\"scale(0.00066666666,0.00125)\" d=\"M299 0C282.5 0 269 13.5 269 30V50C269 66.5 255.5 80 239 80H30C13.5 80 0 93.5 0 110V770C0 786.5 13.5 800 30 800H1470C1486.5 800 1500 786.5 1500 770L1499.5 0H299Z\"></clippath></defs></svg><svg width=\"0\" height=\"0\" viewBox=\"0 0 864 960\"><defs><clipPath id=\"clip_sp\" clipPathUnits=\"objectBoundingBox\"><path transform=\"scale(0.0011574074,0.00104166666)\" d=\"M354 0C337.5 0 324 13.5 324 30V50C324 66.5 310.5 80 294 80H30C13.5 80 0 93.5 0 110V930C0 946.5 13.5 960 30 960H834C850.5 960 864 946.5 864 930V0L354 0Z\"></clippath></defs></svg></div></div><div class=\"block_bg_grid frontpage_looking\">\n<div class=\"frontpage_looking_img1\">\n<figure class=\"img1 animation fade_in_up random_delay\"><img loading=\"lazy\" decoding=\"async\" class=\"alignnone size-full wp-image-80\" src=\"https://www.staffad.co.jp/mW3R3yDMhkf7wNVk/wp-content/uploads/2025/08/img_looking_pic_1.jpg\" alt=\"\" width=\"600\" height=\"800\" srcset=\"https://www.staffad.co.jp/mW3R3yDMhkf7wNVk/wp-content/uploads/2025/08/img_looking_pic_1.jpg 600w, https://www.staffad.co.jp/mW3R3yDMhkf7wNVk/wp-content/uploads/2025/08/img_looking_pic_1-225x300.jpg 225w\" sizes=\"auto, (max-width: 600px) 100vw, 600px\" /></figure>\n<figure class=\"img2 animation fade_in_up random_delay\"><img loading=\"lazy\" decoding=\"async\" class=\"alignnone size-full wp-image-81\" src=\"https://www.staffad.co.jp/mW3R3yDMhkf7wNVk/wp-content/uploads/2025/08/img_looking_pic_2.jpg\" alt=\"\" width=\"800\" height=\"600\" srcset=\"https://www.staffad.co.jp/mW3R3yDMhkf7wNVk/wp-content/uploads/2025/08/img_looking_pic_2.jpg 800w, https://www.staffad.co.jp/mW3R3yDMhkf7wNVk/wp-content/uploads/2025/08/img_looking_pic_2-300x225.jpg 300w, https://www.staffad.co.jp/mW3R3yDMhkf7wNVk/wp-content/uploads/2025/08/img_looking_pic_2-768x576.jpg 768w\" sizes=\"auto, (max-width: 800px) 100vw, 800px\" /></figure>\n</div>\n<div class=\"frontpage_looking_content ff_maru\">\n<h2><span class=\"span1\">福島県・岩手県を中心に<span class=\"span2\">求人多数あります</span></span></h2>\n<p>多岐にわたる派遣先のなかから<br />\n派遣スタッフの要望により職種を決定し、<br />\n派遣スタッフと派遣先企業の双方の<br />\n満足度を向上させます。<br />\n就業後も万全なフォロー体制で<br />\nサポートいたします。</p>\n<p><a class=\"btn_normal\" title=\"お仕事をお探しの方\" href=\"https://www.staffad.co.jp/for_staff/\">お仕事をお探しの方</a></p>\n</div>\n<div class=\"frontpage_looking_img2\">\n<figure class=\"img3 animation fade_in_up random_delay\"><img loading=\"lazy\" decoding=\"async\" class=\"alignnone size-full wp-image-82\" src=\"https://www.staffad.co.jp/mW3R3yDMhkf7wNVk/wp-content/uploads/2025/08/img_looking_pic_3.jpg\" alt=\"\" width=\"800\" height=\"600\" srcset=\"https://www.staffad.co.jp/mW3R3yDMhkf7wNVk/wp-content/uploads/2025/08/img_looking_pic_3.jpg 800w, https://www.staffad.co.jp/mW3R3yDMhkf7wNVk/wp-content/uploads/2025/08/img_looking_pic_3-300x225.jpg 300w, https://www.staffad.co.jp/mW3R3yDMhkf7wNVk/wp-content/uploads/2025/08/img_looking_pic_3-768x576.jpg 768w\" sizes=\"auto, (max-width: 800px) 100vw, 800px\" /></figure>\n<figure class=\"img4 animation fade_in_up random_delay\"><img loading=\"lazy\" decoding=\"async\" class=\"alignnone size-full wp-image-83\" src=\"https://www.staffad.co.jp/mW3R3yDMhkf7wNVk/wp-content/uploads/2025/08/img_looking_pic_4.jpg\" alt=\"\" width=\"600\" height=\"800\" srcset=\"https://www.staffad.co.jp/mW3R3yDMhkf7wNVk/wp-content/uploads/2025/08/img_looking_pic_4.jpg 600w, https://www.staffad.co.jp/mW3R3yDMhkf7wNVk/wp-content/uploads/2025/08/img_looking_pic_4-225x300.jpg 225w\" sizes=\"auto, (max-width: 600px) 100vw, 600px\" /></figure>\n<figure class=\"img5 animation fade_in_up random_delay\"><img loading=\"lazy\" decoding=\"async\" class=\"alignnone size-full wp-image-84\" src=\"https://www.staffad.co.jp/mW3R3yDMhkf7wNVk/wp-content/uploads/2025/08/img_looking_pic_5.jpg\" alt=\"\" width=\"1000\" height=\"600\" srcset=\"https://www.staffad.co.jp/mW3R3yDMhkf7wNVk/wp-content/uploads/2025/08/img_looking_pic_5.jpg 1000w, https://www.staffad.co.jp/mW3R3yDMhkf7wNVk/wp-content/uploads/2025/08/img_looking_pic_5-300x180.jpg 300w, https://www.staffad.co.jp/mW3R3yDMhkf7wNVk/wp-content/uploads/2025/08/img_looking_pic_5-768x461.jpg 768w\" sizes=\"auto, (max-width: 1000px) 100vw, 1000px\" /></figure>\n</div>\n</div>\n<div class=\"frontpage_service introduce\">\n<div class=\"frontpage_service_content\">\n<div class=\"frontpage_service_content_header ff_maru\">\n<h3>紹介予定派遣<span class=\"slug ff_montserrat\">INTRODUCE</span></h3>\n<p>派遣期間中に双方の意思を確認できるため、<span class=\"pc_block\">就職のミスマッチを軽減できます。</span></p>\n</div>\n<p>正社員としての採用をご希望の企業様へ最高６ヶ月の派遣期間を設け、その後双方の合意があれば正社員として就業していただくシステムです。</p>\n</div>\n<figure><img loading=\"lazy\" decoding=\"async\" class=\"alignnone size-large wp-image-86 animation slide_left\" src=\"https://www.staffad.co.jp/mW3R3yDMhkf7wNVk/wp-content/uploads/2025/08/img_introduce_1-1024x998.jpg\" alt=\"\" width=\"1024\" height=\"998\" srcset=\"https://www.staffad.co.jp/mW3R3yDMhkf7wNVk/wp-content/uploads/2025/08/img_introduce_1-1024x998.jpg 1024w, https://www.staffad.co.jp/mW3R3yDMhkf7wNVk/wp-content/uploads/2025/08/img_introduce_1-300x292.jpg 300w, https://www.staffad.co.jp/mW3R3yDMhkf7wNVk/wp-content/uploads/2025/08/img_introduce_1-768x749.jpg 768w, https://www.staffad.co.jp/mW3R3yDMhkf7wNVk/wp-content/uploads/2025/08/img_introduce_1.jpg 1420w\" sizes=\"auto, (max-width: 1024px) 100vw, 1024px\" /></figure>\n</div>\n<div class=\"frontpage_service outsourcing\">\n<div class=\"frontpage_service_content\">\n<div class=\"frontpage_service_content_header ff_maru\">\n<h3>製造業アウトソーシング<span class=\"slug ff_montserrat\">OUTSOURCING</span></h3>\n<p>アウトソーシングとは業務の一部を社外や<span class=\"pc_block\">お客様の構内で委託するサービスです。</span></p>\n</div>\n<p>弊社はアウトソーシングサービスも行っております。<br />\n業務の効率化や従業員をコア業務へ注力させることを目的としております。</p>\n</div>\n<figure><img loading=\"lazy\" decoding=\"async\" class=\"alignnone size-large wp-image-88 animation slide_right\" src=\"https://www.staffad.co.jp/mW3R3yDMhkf7wNVk/wp-content/uploads/2025/08/img_outsourcing_1-1024x998.jpg\" alt=\"\" width=\"1024\" height=\"998\" srcset=\"https://www.staffad.co.jp/mW3R3yDMhkf7wNVk/wp-content/uploads/2025/08/img_outsourcing_1-1024x998.jpg 1024w, https://www.staffad.co.jp/mW3R3yDMhkf7wNVk/wp-content/uploads/2025/08/img_outsourcing_1-300x292.jpg 300w, https://www.staffad.co.jp/mW3R3yDMhkf7wNVk/wp-content/uploads/2025/08/img_outsourcing_1-768x749.jpg 768w, https://www.staffad.co.jp/mW3R3yDMhkf7wNVk/wp-content/uploads/2025/08/img_outsourcing_1.jpg 1420w\" sizes=\"auto, (max-width: 1024px) 100vw, 1024px\" /></figure>\n</div>\n<div class=\"frontpage_service introduction\">\n<div class=\"frontpage_service_content\">\n<div class=\"frontpage_service_content_header ff_maru\">\n<h3>職業紹介<span class=\"slug ff_montserrat\">INTRODUCTION</span></h3>\n<p>職業紹介とは初めから即戦力となる人材を<span class=\"pc_block\">お客様の正社員としてご紹介するサービスです。</span></p>\n</div>\n<p>企業の人材採用においては、即戦力となる人材の発掘が重要になります。優秀な人材を企業と結びつけ、求人のニーズに合致した人材を提供することにより企業の採用ニーズを満たし、信頼性の高いサービスの提供に努めています。</p>\n</div>\n<figure><img loading=\"lazy\" decoding=\"async\" class=\"alignnone size-large wp-image-92 animation slide_left\" src=\"https://www.staffad.co.jp/mW3R3yDMhkf7wNVk/wp-content/uploads/2025/08/img_introduction_1-1024x998.jpg\" alt=\"\" width=\"1024\" height=\"998\" srcset=\"https://www.staffad.co.jp/mW3R3yDMhkf7wNVk/wp-content/uploads/2025/08/img_introduction_1-1024x998.jpg 1024w, https://www.staffad.co.jp/mW3R3yDMhkf7wNVk/wp-content/uploads/2025/08/img_introduction_1-300x292.jpg 300w, https://www.staffad.co.jp/mW3R3yDMhkf7wNVk/wp-content/uploads/2025/08/img_introduction_1-768x749.jpg 768w, https://www.staffad.co.jp/mW3R3yDMhkf7wNVk/wp-content/uploads/2025/08/img_introduction_1.jpg 1420w\" sizes=\"auto, (max-width: 1024px) 100vw, 1024px\" /></figure>\n</div>\n</div><div class=\"page_section page_footer\"><div class=\"block_grid_2 block_text_large page_footer_link\">\n<div class=\"page_footer_link_list\">\n<h3 class=\"ff_maru\">人材をお探しの企業様</h3>\n<figure><img loading=\"lazy\" decoding=\"async\" class=\"alignnone size-large wp-image-70\" src=\"https://www.staffad.co.jp/mW3R3yDMhkf7wNVk/wp-content/uploads/2025/08/img_handshake_1-1024x547.jpg\" alt=\"\" width=\"1024\" height=\"547\" srcset=\"https://www.staffad.co.jp/mW3R3yDMhkf7wNVk/wp-content/uploads/2025/08/img_handshake_1-1024x547.jpg 1024w, https://www.staffad.co.jp/mW3R3yDMhkf7wNVk/wp-content/uploads/2025/08/img_handshake_1-300x160.jpg 300w, https://www.staffad.co.jp/mW3R3yDMhkf7wNVk/wp-content/uploads/2025/08/img_handshake_1-768x410.jpg 768w, https://www.staffad.co.jp/mW3R3yDMhkf7wNVk/wp-content/uploads/2025/08/img_handshake_1.jpg 1124w\" sizes=\"auto, (max-width: 1024px) 100vw, 1024px\" /></figure>\n<p>「希望のスキルを持っている応募者が来ない…」<br />\n「応募が来ても面接採用に繋がらない…」<br />\nそんな貴社の採用のお悩みを<br />\nスタッフアドバンスが解決します</p>\n<p><a class=\"btn_normal\" title=\"人材をお探しの企業様\" href=\"https://www.staffad.co.jp/for_company/\">詳細はこちら</a></p>\n</div>\n<div class=\"page_footer_link_list\">\n<h3 class=\"ff_maru\">会社概要</h3>\n<figure><img loading=\"lazy\" decoding=\"async\" class=\"alignnone size-full wp-image-71\" src=\"https://www.staffad.co.jp/mW3R3yDMhkf7wNVk/wp-content/uploads/2025/08/img_sunlight_1.jpg\" alt=\"\" width=\"1000\" height=\"500\" srcset=\"https://www.staffad.co.jp/mW3R3yDMhkf7wNVk/wp-content/uploads/2025/08/img_sunlight_1.jpg 1000w, https://www.staffad.co.jp/mW3R3yDMhkf7wNVk/wp-content/uploads/2025/08/img_sunlight_1-300x150.jpg 300w, https://www.staffad.co.jp/mW3R3yDMhkf7wNVk/wp-content/uploads/2025/08/img_sunlight_1-768x384.jpg 768w\" sizes=\"auto, (max-width: 1000px) 100vw, 1000px\" /></figure>\n<p>「スタッフ一人ひとりの幸せを追求します」<br />\nという経営理念のもと、<br />\nスタッフ一人ひとりが思い描く<br />\n幸せを追求していきます。</p>\n<p><a class=\"btn_normal\" title=\"会社概要\" href=\"https://www.staffad.co.jp/company/\">会社概要</a></p>\n</div>\n</div>\n<div class=\"page_footer_contact\">\n<dl class=\"page_footer_contact_tel\">\n<dt class=\"ff_maru\">お電話でのお問い合わせ</dt>\n<dd><span class=\"num\">0120-450-345</span><span class=\"note\">【受付時間】平日8：30～17：30</span></dd>\n</dl>\n<dl class=\"page_footer_contact_web\">\n<dt class=\"ff_maru\">WEBからのお問い合わせ</dt>\n<dd><a class=\"btn_normal\" title=\"お問い合わせ\" href=\"https://www.staffad.co.jp/contact_us/\">お問い合わせフォーム</a></dd>\n</dl>\n</div>\n</div></main>\n<!--main end -->\n<!--footer -->\n<footer id=\"footer\" class=\"footer\">\n    <nav id=\"footer_nav\" class=\"footer_nav\"><ul id=\"footer_nav_mainmenu\" class=\"footer_nav_mainmenu\"><li class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-32\"><a href=\"https://www.staffad.co.jp/for_staff/\">お仕事をお探しの方</a></li>\n<li class=\"menu-item menu-item-type-custom menu-item-object-custom menu-item-37\"><a target=\"_blank\" href=\"https://jp.indeed.com/cmp/%E6%A0%AA%E5%BC%8F%E4%BC%9A%E7%A4%BE%E3%82%B9%E3%82%BF%E3%83%83%E3%83%95%E3%82%A2%E3%83%89%E3%83%90%E3%83%B3%E3%82%B9-1\">お仕事を探す</a></li>\n<li class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-33\"><a href=\"https://www.staffad.co.jp/for_company/\">人材をお探しの企業様</a></li>\n<li class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-34\"><a href=\"https://www.staffad.co.jp/company/\">会社概要</a></li>\n<li class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-35\"><a href=\"https://www.staffad.co.jp/contact_us/\">お問い合わせ</a></li>\n<li class=\"sp_link menu-item menu-item-type-post_type menu-item-object-page menu-item-home current-menu-item page_item page-item-24 current_page_item menu-item-31\"><a href=\"https://www.staffad.co.jp/\" aria-current=\"page\">トップページ</a></li>\n</ul><p class=\"footer_nav_banner\"><a href=\"https://www.meihogroup.com/\" target=\"_blank\"><img src=\"https://www.staffad.co.jp/mW3R3yDMhkf7wNVk/wp-content/themes/staffad/assets/images/img_banner_meiho_1.svg\" alt=\"メイホーグループ\" title=\"メイホーグループ\"></a></p></nav><div class=\"footer_content\"><p class=\"footer_content_logo\"><a href=\"https://www.staffad.co.jp/\"><img src=\"https://www.staffad.co.jp/mW3R3yDMhkf7wNVk/wp-content/themes/staffad/assets/images/logo_2.png\" alt=\"株式会社スタッフアドバンス\" 