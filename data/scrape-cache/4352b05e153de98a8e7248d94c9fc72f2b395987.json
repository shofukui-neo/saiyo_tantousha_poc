 <div id=\"menu02\" class=\"section\">\r\n      <p class=\"menu__item\"><a href=\"kyuzin.html\" class=\"trans\">求人情報TOP</a></p>\r\n      <p class=\"menu__item\"><a href=\"kyuzin_1.html\" class=\"trans\">新卒採用</a></p>\r\n      <p class=\"menu__item\"><a href=\"kyuzin_toi.html\" class=\"trans\">新卒採用Q&A</a></p>\r\n      <p class=\"menu__item\"><a href=\"kyuzin_2.html\" class=\"trans\">キャリア採用</a></p>\r\n      <p class=\"menu__item\"><a href=\"kyuzin_3.html\" class=\"trans\">スタッフ・パート採用</a></p>\r\n    </div>\r\n    <div id=\"menu03\" class=\"section\">\r\n      <p class=\"menu__item\"><a href=\"toi_all_1.html\" class=\"trans\">会社全体に対するお問合せ</a></p>\r\n      <p class=\"menu__item\"><a href=\"toi_all_2.html\" class=\"trans\">レンタル・商品に関する<br>お問合せ</a></p>\r\n      <p class=\"menu__item\"><a href=\"toi_all_3.html\" class=\"trans\">求人に対するお問合せ</a></p>\r\n    </div>\r\n    <div id=\"menu04\" class=\"section\">\r\n      <p class=\"menu__item\"><a href=\"gyoumu_kaigo.html\" class=\"trans\">介護関連業務について</a></p>\r\n      <p class=\"menu__item\"><a href=\"gyoumu_kaigo_1.html\" class=\"trans\">レンタルの仕組みについて</a></p>\r\n      <p class=\"menu__item\"><a href=\"gyoumu_kaigo_2.html\" class=\"trans\">レンタル商品</a></p>\r\n      <p class=\"menu__item\"><a href=\"gyoumu_kaigo_3.html\" class=\"trans\">販売商品</a></p>\r\n    </div>\r\n  </ul>\r\n</header>\r\n\r\n<main class=\"kyuzin\">\r\n  <section class=\"mv\">\r\n    <h2 class=\"mv__title\">キャリア採用</h2>\r\n    <p><img src=\"images/kyuzin/mv02.jpg\" alt=\"キャリア採用\"></p>\r\n  </section>\r\n\r\n  <div class=\"contents inner career\">\r\n    <section class=\"info\">\r\n      <h3 class=\"kyuzin__title\">求人情報－キャリア採用</h3>\r\n      <table class=\"info__table\">\r\n        <tbody>\r\n          <tr class=\"info__tr\">\r\n            <th class=\"info__th01\">募集職種</th>\r\n            <th class=\"info__th02\">職種</th>\r\n            <td class=\"info__td\">営業職、技術職　※未経験者歓迎</td>\r\n          </tr>\r\n          <tr class=\"info__tr\">\r\n            <th class=\"info__th01\" rowspan=\"4\">待遇</th>\r\n            <th class=\"info__th02\">基本給</th>\r\n            <td class=\"info__td\">配属地域、セクションにより異なる</td>\r\n          </tr>\r\n          <tr class=\"info__tr\">\r\n            <th class=\"info__th02\">初任給与支払日</th>\r\n            <td class=\"info__td\">毎月２５日（銀行振込）、給与計算締切日：毎月１５日</td>\r\n          </tr>\r\n          <tr class=\"info__tr\">\r\n            <th class=\"info__th02\">賞与</th>\r\n            <td class=\"info__td\">年２回（7月、１２月）</td>\r\n          </tr>\r\n          <tr class=\"info__tr\">\r\n            <th class=\"info__th02\">昇給</th>\r\n            <td class=\"info__td\">年１回（毎年４月）</td>\r\n          </tr>\r\n          <tr class=\"info__tr\">\r\n            <th class=\"info__th01\" rowspan=\"4\">働く環境</th>\r\n            <th class=\"info__th02\">勤務地</th>\r\n            <td class=\"info__td\">富山本社・金沢支店・信越支店・新潟営業所・福井営業所・能登営業所</td>\r\n          </tr>\r\n          <tr class=\"info__tr\">\r\n            <th class=\"info__th02\">勤務時間</th>\r\n            <td class=\"info__td\">\r\n              【富山本社・金沢・信越・新潟・福井・能登】<br>\r\n              午前８時３０分～午後５時（実働７時間３０分／休憩1時間）\r\n            </td>\r\n          </tr>\r\n          <tr class=\"info__tr\">\r\n            <th class=\"info__th02\">休日</th>\r\n            <td class=\"info__td\">週休２日制　お盆・年末年始休暇　年間１１２日</td>\r\n          </tr>\r\n          <tr class=\"info__tr\">\r\n            <th class=\"info__th02\">休暇</th>\r\n            <td class=\"info__td\">年次有給休暇（１日、半日単位で休暇取得が可能）、特別休暇（慶弔休暇　等）</td>\r\n          </tr>\r\n          <tr class=\"info__tr\">\r\n            <th class=\"info__th01\">加入保険</th>\r\n            <th class=\"info__th02\">社会保険</th>\r\n            <td class=\"info__td\">健康保険、厚生年金保険、雇用保険、労災保険へ加入</td>\r\n          </tr>\r\n          <tr class=\"info__tr\">\r\n            <th class=\"info__th01\" rowspan=\"4\">福利厚生</th>\r\n            <th class=\"info__th02\">退職金制度</th>\r\n            <td class=\"info__td\">あり</td>\r\n          </tr>\r\n          <tr class=\"info__tr\">\r\n            <th class=\"info__th02\">厚生施設</th>\r\n            <td class=\"info__td\">食堂（本社、信越工場、関東工場）</td>\r\n          </tr>\r\n          <tr class=\"info__tr\">\r\n            <th class=\"info__th02\">社内割引</th>\r\n            <td class=\"info__td\">社内割引価格で当社仕入商品を購入可能</td>\r\n          </tr>\r\n          <tr class=\"info__tr\">\r\n            <th class=\"info__th02\">その他制度</th>\r\n            <td class=\"info__td\">慶弔見舞金（結婚・出産お祝金　等）、業務外傷病時見舞金</td>\r\n          </tr>\r\n          <tr class=\"info__tr\">\r\n            <th class=\"info__th01\">社内制度</th>\r\n            <th class=\"info__th02\">各種制度</th>\r\n            <td class=\"info__td\">出産休暇、育児休業休暇、介護休暇、定年制／再雇用：６０歳定年／再雇用あり</td>\r\n          </tr>\r\n          <tr class=\"info__tr\">\r\n            <th class=\"info__th01\">住まい</th>\r\n            <th class=\"info__th02\">借上社宅</th>\r\n            <td class=\"info__td\">\r\n              【大卒・短大卒】<br>\r\n              遠距離通勤となる場合は借上社宅制度適用　※家賃は会社負担85%（上限あり）\r\n            </td>\r\n          </tr>\r\n        </tbody>\r\n      </table>\r\n    </section>\r\n\r\n    <section class=\"flow\">\r\n      <h3 class=\"kyuzin__title\">採用フロー</h3>\r\n      <ul class=\"flow__list fb\">\r\n        <li class=\"flow__item\">\r\n          <p class=\"flow__num\">\r\n            <span class=\"flow__step\">STEP</span><br>\r\n            <span class=\"flow__n\">1</span>\r\n          </p>\r\n          <div class=\"flow__txt\">\r\n            <p>応募<br class=\"pc\"><span class=\"flow__txt-s\">(採用ＨＰ｜書類郵送)</span></p>\r\n          </div>\r\n        </li>\r\n        <li class=\"flow__item\">\r\n          <p class=\"flow__num\">\r\n            <span class=\"flow__step\">STEP</span><br>\r\n            <span class=\"flow__n\">2</span>\r\n          </p>\r\n          <p class=\"flow__txt\">書類選考</p>\r\n        </li>\r\n        <li class=\"flow__item\">\r\n          <p class=\"flow__num\">\r\n            <span class=\"flow__step\">STEP</span><br>\r\n            <span class=\"flow__n\">3</span>\r\n          </p>\r\n          <p class=\"flow__txt\">適性検査</p>\r\n        </li>\r\n        <li class=\"flow__item\">\r\n          <p class=\"flow__num\">\r\n            <span class=\"flow__step\">STEP</span><br>\r\n            <span class=\"flow__n\">4</span>\r\n          </p>\r\n          <p class=\"flow__txt\">人事面接</p>\r\n        </li>\r\n        <li class=\"flow__item\">\r\n          <p class=\"flow__num\">\r\n            <span class=\"flow__step\">STEP</span><br>\r\n            <span class=\"flow__n\">5</span>\r\n          </p>\r\n          <p class=\"flow__txt\">所属部署面接</p>\r\n        </li>\r\n        <li class=\"flow__item\">\r\n          <p class=\"flow__num\">\r\n            <span class=\"flow__step\">STEP</span><br>\r\n            <span class=\"flow__n\">6</span>\r\n          </p>\r\n          <p class=\"flow__txt\">役員面接</p>\r\n        </li>\r\n        <li class=\"flow__item\">\r\n          <p class=\"flow__num\">\r\n            <span class=\"flow__step\">STEP</span><br>\r\n            <span class=\"flow__n\">7</span>\r\n          </p>\r\n          <p class=\"flow__txt\">内定</p>\r\n        </li>\r\n      </ul>\r\n    </section>\r\n    \r\n    <section class=\"link\">\r\n      <ul class=\"link__list\">\r\n        <li class=\"link__item\">\r\n          <a href=\"kyuzin_1.html\" class=\"trans\">\r\n            <p class=\"link__txt\">新卒採用</p>\r\n            <p class=\"link__more\">詳しくはこちら ＞</p>\r\n            <p class=\"link__img\"><img src=\"images/kyuzin/bg_link01.jpg\" alt=\"新卒採用 詳しくはこちら ＞\"></p>\r\n          </a>\r\n        </li>\r\n        <li class=\"link__item\">\r\n          <a href=\"kyuzin_3.html\" class=\"trans\">\r\n            <p class=\"link__txt\">スタッフ・パート採用</p>\r\n            <p class=\"link__more\">詳しくはこちら ＞</p>\r\n            <p class=\"link__img\"><img src=\"images/kyuzin/bg_link03.jpg\" alt=\"スタッフ・パート採用 詳しくはこちら ＞\"></p>\r\n          </a>\r\n        </li>\r\n      </ul>\r\n    </section>\r\n  </div>\r\n</main>\r\n\r\n<footer class=\"footer\">\r\n  <ul class=\"footer__list fb\"