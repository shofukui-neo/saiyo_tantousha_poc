ader-nav-sns-icon\" src=\"https://yagi.co.jp/wp-content/themes/yagi.co.jp/img/common/icon-x-l.svg\" alt=\"X\">\n              </picture>\n            </a>\n          </li>\n          <li>\n            <a class=\"header-nav-sns-anchor\" href=\"https://www.facebook.com/profile.php?id=100069700185328\" target=\"_blank\">\n              <picture>\n                <source srcset=\"https://yagi.co.jp/wp-content/themes/yagi.co.jp/img/common/icon-facebook-t.svg\" media=\"(min-width: 1156px)\">\n                <img class=\"header-nav-sns-icon\" src=\"https://yagi.co.jp/wp-content/themes/yagi.co.jp/img/common/icon-facebook-l.svg\" alt=\"facebook\">\n              </picture>\n            </a>\n          </li>\n        </ul>\n      </div>\n\n      <nav class=\"header-nav-global header-nav-entry\">\n        <ul class=\"header-nav-global-list\">\n          <li class=\"header-nav-global-item\">\n            <a class=\"header-nav-global-anchor\" href=\"#\">エントリー</a>\n\n            <div class=\"header-nav-global-sublist-wrap\">\n              <ul class=\"header-nav-global-sublist\">\n                <li class=\"header-nav-global-subitem\">\n                  <a class=\"header-nav-global-subanchor\" target=\"_blank\" href=\"https://job.mynavi.jp/27/pc/search/corp277537/outline.html\">\n                    <span class=\"header-nav-global-subanchor-main\">新卒採用エントリー</span>\n                    <img class=\"header-nav-sns-icon\" src=\"https://yagi.co.jp/wp-content/themes/yagi.co.jp/img/common/icon-windows-l.svg\" alt=\"\">\n                  </a>\n                </li>\n                <li class=\"header-nav-global-subitem\">\n                  <a class=\"header-nav-global-subanchor\" target=\"_blank\" href=\"https://tenshoku.mynavi.jp/jobinfo-113582-3-22-1/\">\n                    <span class=\"header-nav-global-subanchor-main\">キャリア採用エントリー</span>\n                    <img class=\"header-nav-sns-icon\" src=\"https://yagi.co.jp/wp-content/themes/yagi.co.jp/img/common/icon-windows-l.svg\" alt=\"\">\n                  </a>\n                </li>\n              </ul>\n            </div>\n          </li>\n        </ul>\n      </nav>\n    </div>\n  </div>\n</header>\n\n<main class=\"main\">\n  <div class=\"kv\">\n    <picture>\n      <source srcset=\"https://yagi.co.jp/wp-content/themes/yagi.co.jp/img/recruit/about-us/kv-lt.jpg\" media=\"(min-width: 1156px)\">\n      <img class=\"kv-img\" src=\"https://yagi.co.jp/wp-content/themes/yagi.co.jp/img/recruit/about-us/kv-sp.jpg\" alt=\"\">\n    </picture>\n  </div>\n\n  <div class=\"page-title\">\n    <div class=\"page-title-section\">\n      <h1 class=\"page-title-hl\">\n        <span class=\"page-title-hl-main\">私たちについて</span>\n        <span class=\"page-title-hl-sub\">ABOUT US</span>\n      </h1>\n    </div>\n  </div>\n\n  <div class=\"wrap-subsection lead\">\n    <div class=\"row-subsection\">\n      <p class=\"text-common\">\n        ヤギコーポレーションは、1948年創業、石川県金沢市に本社を構える業界でもファッションユニフォームのパイオニアとして確かな実績を誇るユニフォームメーカーです。オフィスウェアや医療・ケアウェアなど、さまざまな業種向けのユニフォームの企画・製造・販売を行っています。<br>\n        多様化するお客さまのニーズに応えるためには、多彩な人材が能力を発揮できる企業であることが大切だと考えています。 個性を活かして、ユニフォームの可能性を共に広げていく仲間をお待ちしています。\n      </p>\n    </div>\n  </div>\n\n  <div class=\"wrap-section\">\n    <div class=\"row-section\">\n      <h2 class=\"hl-multi\">\n        <span class=\"hl-multi-main\">数字で見るYAGI</span>\n        <span class=\"hl-multi-sub\">YAGI BY NUMBER</span>\n      </h2>\n\n      <ul class=\"number-list\">\n        <li class=\"number-item\">\n          <span class=\"number-hl\">平均年齢</span>\n\n          <span class=\"number-img\">\n            <img class=\"number-img-icon\" src=\"https://yagi.co.jp/wp-content/themes/yagi.co.jp/img/recruit/about-us/img-number-age.png\" alt=\"41.8歳\">\n          </span>\n        </li>\n        <li class=\"number-item\">\n          <span class=\"number-hl\">男女比率</span>\n\n          <span class=\"number-img\">\n            <img class=\"number-img-icon\" src=\"https://yagi.co.jp/wp-content/themes/yagi.co.jp/img/recruit/about-us/img-number-gender.png\" alt=\"男性 4：女性 6\">\n          </span>\n        </li>\n        <li class=\"number-item\">\n          <span class=\"number-hl\">月平均所定外労働時間</span>\n\n          <span class=\"number-img\">\n            <img class=\"number-img-icon\" src=\"https://yagi.co.jp/wp-content/themes/yagi.co.jp/img/recruit/about-us/img-number-hour.png\" alt=\"10時間前後\">\n          </span>\n        </li>\n        <li class=\"number-item\">\n          <span class=\"number-hl\">平均有給休暇取得日数</span>\n\n          <span class=\"number-img\">\n            <img class=\"number-img-icon\" src=\"https://yagi.co.jp/wp-content/themes/yagi.co.jp/img/recruit/about-us/img-number-paid-holiday.png\" alt=\"11日\">\n          </span>\n        </li>\n        <li class=\"number-item\">\n          <span class=\"number-hl\">育児休暇取得率</span>\n\n          <span class=\"number-img\">\n            <img class=\"number-img-icon\" src=\"https://yagi.co.jp/wp-content/themes/yagi.co.jp/img/recruit/about-us/img-number-parental-leave.png\" alt=\"100%\">\n          </span>\n        </li>\n        <li class=\"number-item\">\n          <span class=\"number-hl\">役員及び管理的地位に<span class=\"block-lt\"></span>ある者に占める女性の割合</span>\n\n          <span class=\"number-img\">\n            <img class=\"number-img-icon\" src=\"https://yagi.co.jp/wp-content/themes/yagi.co.jp/img/recruit/about-us/img-number-female.png\" alt=\"14.3%\">\n          </span>\n        </li>\n      </l>\n    </div>\n  </div>\n</main>\n\n  <div class=\"wrap-section voices-alias\">\n    <div class=\"row-section\">\n      <h2 class=\"hl-multi\">\n        <span class=\"hl-multi-main\">先輩インタビュー</span>\n        <span class=\"hl-multi-sub\">SENIOR INTERVIEW</span>\n      </h2>\n\n      <ul class=\"voices-alias-list\">\n        <li class=\"voices-alias-item\">\n          <a class=\"voices-alias-anchor\" href=\"/recruit/voices/design/\">\n            <img class=\"img-rounded\" src=\"https://yagi.co.jp/wp-content/themes/yagi.co.jp/img/recruit/voices/img-person-design.jpg\" alt=\"\">\n            <span class=\"voices-alias-person\">デザイン課</span>\n          </a>\n        </li>\n        <li class=\"voices-alias-item\">\n          <a class=\"voices-alias-anchor\" href=\"/recruit/voices/sales/\">\n            <img class=\"img-rounded\" src=\"https://yagi.co.jp/wp-content/themes/yagi.co.jp/img/recruit/voices/img-person-sales.jpg\" alt=\"\">\n            <span class=\"voices-alias-person\">営業課</span>\n          </a>\n        </li>\n        <li class=\"voices-alias-item\">\n          <a class=\"voices-alias-anchor\" href=\"/recruit/voices/pattern/\">\n            <img class=\"img-rounded\" src=\"https://yagi.co.jp/wp-content/themes/yagi.co.jp/img/recruit/voices/img-person-pattern.jpg\" alt=\"\">\n            <span class=\"voices-alias-person\">パターン課</span>\n          </a>\n        </li>\n        <li class=\"voices-alias-item\">\n          <a class=\"voices-alias-anchor\" href=\"/recruit/voices/manufacturing/\">\n            <img class=\"img-rounded\" src=\"https://yagi.co.jp/wp-content/themes/yagi.co.jp/img/recruit/voices/img-person-manufacturing.jpg\" alt=\"\">\n            <span class=\"voices-alias-person\">製造課</span>\n          </a>\n        </li>\n      </ul>\n    </div>\n  </div>\n\n<div class=\"wrap-section footer-entry\">\n  <div class=\"row-section\">\n    <h2 class=\"hl-multi\">\n      <span class=\"hl-multi-main\">エントリー</span>\n      <span class=\"hl-multi-sub\">ENTRY</span>\n    </h2>\n\n    <p class=\"footer-entry-buttons\">\n      <a class=\"footer-entry-button\" target=\"_blank\" href=\"https://job.mynavi.jp/27/pc/search/corp277537/outline.html\">\n        新卒採用エントリー\n        <img class=\"header-nav-sns-icon\" src=\"https://yagi.co.jp/wp-content/themes/yagi.co.jp/img/common/icon-windows-l.svg\" alt=\"\">\n      </a>\n      <a class=\"footer-entry-button\" target=\"_blank\" href=\"https://tenshoku.mynavi.jp/jobinfo-113582-3-22-1/\">\n        キャリア採用エントリー\n        <img class=\"header-nav-sns-icon\" src=\"https://yagi.co.jp/wp-content/themes/yagi.co.jp/img/common/icon-windows-l.svg\" alt=\"\">\n      </a>\n    </p>\n  </div>\n</div>\n\n<footer class=\"footer\">\n  <div class=\"footer-section\">\n    <div class=\"footer-flex\">\n      <div class=\"footer-flex-first\">\n        <p class=\"footer-logo\">\n          <a class=\"footer-logo-anchor\" href=\"/\">\n            <img class=\"footer-logo-img\" src=\"https://yagi.co.jp/wp-content/themes/yagi.co.jp/img/common/logo-t.svg\" alt=\"ヤギコーポレーション\">\n          </a>\n        </p>\n\n        <address class=\"footer-address\">\n          <p class=\"footer-address-name\">\n            株式会社ヤギコーポレーション\n          </p>\n\n          <p class=\"footer-address-main\">\n            〒920-8503 石川県金沢市問屋町2-80<br>\n            TEL：<a href=\"tel:076-237-1122\">076 (237) 1122</a>（代）/ FAX：076（237）1125\n          </p>\n        </address>\n      </div>\n\n      <div class=\"footer-flex-second\">\n        <div class=\"footer-nav\">\n          <div class=\"footer-nav-global\">\n            <ul class=\"footer-nav-global-list\">\n              <li class=\"footer-nav-global-item\">\n                <a class=\"footer-nav-global-anchor\" href=\"/\">ヤギコーポレーション</a>\n              </li>\n              <li class=\"footer-nav-global-item\">\n                <a class=\"footer-nav-global-anchor\" href=\"/sennentaisyo/\">千年大賞</a>\n              </li>\n            </ul>\n          </div>\n\n          <div class=\"footer-nav-sns\">\n            <ul class=\"footer-nav-sns-list\">\n              <li>\n                <a class=\"footer-nav-sns-anchor\" href=\"https://www.instagram.com/yagi_corporation/\" target=\"_blank\">\n                  <img class=\"footer-nav-sns-instagram\" src=\"https://yagi.co.jp/wp-content/themes/yagi.co.jp/img/common/icon-instagram-t.svg\" alt=\"Instagram\">\n                </a>\n              </li>\n              <li>\n                <a class=\"footer-nav-sns-anchor\" href=\"https://www.youtube.com/@%E6%A0%AA%E5%BC%8F%E4%BC%9A%E7%A4%BE%E3%83%A4%E