p><span class=\"required-icon fl\">必須</span>メールアドレス\n\t\t\t\t\t</p>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t\t<div class=\"col-md-8 form-right form-seeds\">\n\t\t\t\t<p><span class=\"wpcf7-form-control-wrap\" data-name=\"your-email\"><input size=\"40\" class=\"wpcf7-form-control wpcf7-email wpcf7-validates-as-required wpcf7-text wpcf7-validates-as-email\" autocomplete=\"email\" aria-required=\"true\" aria-invalid=\"false\" placeholder=\"例）example@mail.com\" value=\"\" type=\"email\" name=\"your-email\" /></span>\n\t\t\t\t</p>\n\t\t\t</div>\n\t\t</div>\n\t\t<div class=\"form-group\">\n\t\t\t<div class=\"col-md-4 form-left clearfix\">\n\t\t\t\t<div class=\"clearfix contact-form_head\">\n\t\t\t\t\t<p><span class=\"required-icon fl\">必須</span>電話番号\n\t\t\t\t\t</p>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t\t<div class=\"col-md-8 form-right form-seeds\">\n\t\t\t\t<p><span class=\"wpcf7-form-control-wrap\" data-name=\"tel\"><input size=\"40\" class=\"wpcf7-form-control wpcf7-tel wpcf7-validates-as-required wpcf7-text wpcf7-validates-as-tel\" aria-required=\"true\" aria-invalid=\"false\" placeholder=\"例）09012345678\" value=\"\" type=\"tel\" name=\"tel\" /></span>\n\t\t\t\t</p>\n\t\t\t</div>\n\t\t</div>\n\t</div>\n<div class=\"wpcf7-response-output\" aria-hidden=\"true\"></div>\n\t<div class=\"row\">\n\t\t<div class=\"step01 col-sm-12 text-center mt40\">\n\t\t\t<p>「<a href=\"/privacy/#terms\" target=\"_blank\" rel=\"noopener\">個人情報の取り扱い</a>」を一読の上、 同意いただけますようお願いいたします。\n\t\t\t</p>\n\t\t</div>\n\t\t<div class=\"col-sm-6 col-sm-offset-3 text-center form-seeds mt30 mb30\">\n\t\t\t<p><span class=\"form-seeds-send\"><br />\n<input class=\"wpcf7-form-control wpcf7-submit has-spinner\" type=\"submit\" value=\"同意して入力内容を確認する\" /><br />\n<input type=\"hidden\" name=\"_cf7msm_multistep_tag\" class=\"wpcf7-form-control wpcf7-multistep cf7msm-multistep\" value=\"{&quot;first_step&quot;:1,&quot;skip_save&quot;:1,&quot;next_url&quot;:&quot;\\/inquiry\\/contact_indivisual\\/confirmation&quot;}\" /><input type=\"hidden\" name=\"cf7msm-no-ss\" value=\"\" /><br />\n</span>\n\t\t\t</p>\n\t\t</div>\n\t</div>\n</div><p style=\"display: none !important;\"><label>&#916;<textarea name=\"_wpcf7_ak_hp_textarea\" cols=\"45\" rows=\"8\" maxlength=\"100\"></textarea></label><input type=\"hidden\" id=\"ak_js_1\" name=\"_wpcf7_ak_js\" value=\"53\"/><script>document.getElementById( \"ak_js_1\" ).setAttribute( \"value\", ( new Date() ).getTime() );</script></p>\n</form>\n</div>\n\n\n\n\n<style>\n@media only screen and (min-width: 768px) {\n.cd-multi-steps.text-top li.visited > *::before,\n.cd-multi-steps.text-top li.current > *::before,\n.cd-multi-steps.text-bottom li.visited > *::before,\n.cd-multi-steps.text-bottom li.current > *::before,\n.cd-multi-steps li.visited::after {\nbackground-color: #179ce3;\n}\n}\n\n@media only screen and (max-width: 768px) {\n.cd-breadcrumb li.current > *, .cd-multi-steps li.current > *,\n.no-touch .cd-breadcrumb a:hover, .no-touch .cd-multi-steps a:hover {\ncolor: #179ce3;\n}\n}\n\n.introduction{\nmargin-top: 4rem;\nmargin-bottom: 4rem;\ntext-align: center;\n}\n\n.introduction > p{\ndisplay: inline-block;\ntext-align: left;\nline-height: 2.5;\n}\n\n.seminar p{\nfont-size: 14px;\n}\n\n.wpcf7-radio > .wpcf7-list-item{\ndisplay: block;\n}\n\n/* -----------------------\n   退会注意メッセージ全体\n   ----------------------- */\n.withdrawal-notice {\n  width: 100%;\n  margin: 32px 0 24px;\n  padding: 28px 32px;\n  background: #fffaf0;\n  border-left: 6px solid #e6b25c;\n  border-radius: 4px;\n  box-shadow: 0 2px 6px rgba(0,0,0,0.05);\n\n  font-size: 15px;         /* ← 指定に合わせて統一 */\n  line-height: 1.8;\n}\n\n/* 段落 */\n.withdrawal-notice p {\n  margin: 0 0 16px;\n  font-size: 15px;         /* ← pタグも明示的に指定 */\n}\n\n/* セクションタイトル */\n.withdrawal-notice__title {\n  font-size: 17px;\n  font-weight: bold;\n  margin-bottom: 20px;\n  color: #c27b00;\n}\n\n/* 小見出し（メルマガ／SEEDS IDなど） */\n.withdrawal-notice__subtitle {\n  margin: 22px 0 10px;\n  font-weight: bold;\n  font-size: 15px;\n  color: #c27b00;\n}\n\n/* メルマガ強調部分 */\n.withdrawal-notice__point {\n  margin: 18px 0 10px;\n  font-weight: bold;\n  font-size: 15px;\n}\n\n@media (max-width: 768px) {\n  .withdrawal-notice {\n    padding: 18px 18px;\n    margin: 24px 0 20px;\n    font-size: 15px;\n    line-height: 1.6;\n    border-left-width: 4px;\n  }\n\n  .withdrawal-notice p {\n    margin: 0 0 12px;\n  }\n\n  .withdrawal-notice__title {\n    font-size: 16px;\n    margin-bottom: 16px;\n  }\n\n  .withdrawal-notice__subtitle {\n    font-size: 15px;\n    margin-top: 16px;\n  }\n\n  .withdrawal-notice__list li {\n    margin-bottom: 4px;\n  }\n}\n</style>\n\n<script>\ndocument.addEventListener('DOMContentLoaded', function () {\n  // フォーム本体\n  var cf7Form = document.querySelector('.wpcf7 form');\n  if (!cf7Form) return;\n\n  // 「お問い合わせ内容」ラジオボタン\n  var subjectRadios = cf7Form.querySelectorAll('input[name=\"your-subject\"]');\n  if (!subjectRadios.length) return;\n\n  // 送信ボタン（存在確認用）\n  var submitBtn = cf7Form.querySelector('input[type=\"submit\"], button[type=\"submit\"]');\n  if (!submitBtn) return;\n\n  // 基準位置とする .seminar を取得\n  var seminarBlock = cf7Form.querySelector('.seminar');\n\n  // .seminar が使えなかった場合の考慮\n  var submitBlock = submitBtn;\n  while (submitBlock.parentElement && submitBlock.parentElement !== cf7Form) {\n    submitBlock = submitBlock.parentElement;\n  }\n  if (submitBlock.parentElement !== cf7Form) {\n    submitBlock = null;\n  }\n\n  // どちらも見つからない場合は終了\n  if (!seminarBlock && !submitBlock) return;\n\n  // 注意メッセージのボックスを作成\n  var noticeBox = document.createElement('div');\n  noticeBox.id = 'withdrawal-notice';\n  noticeBox.className = 'withdrawal-notice';\n  noticeBox.style.display = 'none';\n  noticeBox.setAttribute('aria-hidden', 'true');\n\n  // 表示する文章\n  noticeBox.innerHTML = ''\n    + '<div class=\"withdrawal-notice__title\">退会前にご確認ください</div>'\n    + '<p>ご利用中のサービスを退会されると「SEEDS ID」が無効となり、株式会社シーズが提供する各サービス（アルバイトドットコム・オカジョブ転職・ヒロジョブ転職）へのログインがご利用いただけなくなります。今後利用されるご予定のサービスがある場合はご注意ください。</p>'\n    + '<p class=\"withdrawal-notice__point\">★メルマガの停止のみ行うことも可能です。</p>'\n    + '<p>・アルバイトドットコム<br>'\n    + '[マイページ] > [プロフィール設定] > [新着おシゴト通知登録] のチェックを解除して [登録情報変更] ボタンから更新</p>'\n    + '<p>・オカジョブ転職/ヒロジョブ転職<br>'\n    + '[マイページ] > [新着おシゴト通知設定] > [新着おシゴト通知登録] のチェックを解除して [登録情報変更] ボタンから更新</p>'\n    + '<div class=\"withdrawal-notice__subtitle\">SEEDS IDとは</div>'\n    + '<p>株式会社シーズが提供する各サービス（アルバイトドットコム・オカジョブ転職・ヒロジョブ転職）で利用可能なログイン情報です。ご登録いただいたアカウント名・パスワードで各サービスにログインできます。</p>'\n    + '<p>また、退会後に再びサービスをご利用いただく場合は、新規会員登録を行い「SEEDS ID」をご作成ください（以前の情報は引き継がれませんのでご注意ください）。</p>';\n\n  // 注意メッセージの挿入位置を決定\n  if (seminarBlock) {\n    // .seminar の下に挿入\n    if (seminarBlock.nextSibling) {\n      seminarBlock.parentNode.insertBefore(noticeBox, seminarBlock.nextSibling);\n    } else {\n      seminarBlock.parentNode.appendChild(noticeBox);\n    }\n  } else if (submitBlock) {\n    // フォールバックとして送信ボタンを含むブロックの直前に挿入\n    cf7Form.insertBefore(noticeBox, submitBlock);\n  }\n\n  // ラジオ選択状態に応じて注意メッセージの表示切り替え\n  function toggleNotice() {\n    var checked = cf7Form.querySelector('input[name=\"your-subject\"]:checked');\n    if (checked && checked.value === '退会したい') {\n      noticeBox.style.display = '';\n      noticeBox.setAttribute('aria-hidden', 'false');\n    } else {\n      noticeBox.style.display = 'none';\n      noticeBox.setAttribute('aria-hidden', 'true');\n    }\n  }\n\n  subjectRadios.forEach(function (radio) {\n    radio.addEventListener('change', toggleNotice);\n  });\n\n  // ページ読み込み時にも一度実行\n  toggleNotice();\n});\n</script>\n\t\t\t</div><!-- /.content -->\r\n\t\t  </section>\r\n\t  \t</div><!-- /.col -->\r\n  </div><!-- /.row -->\r\n</div><!-- /.container -->\r\n\r\n<footer>\r\n\r\n\t<div class=\"pc-footerMark col-sm-8 col-sm-offset-2 form-inner mb30\">\r\n\r\n\t\t<div class=\"footerPrivacyLeft\">\r\n\t\t\t<a href=\"https://privacymark.jp/\" target=\"_blank\"><img src=\"https://www.seedsjp.com/wp-content/themes/seeds/images/common/privacy.gif\" alt=\"プライバシーマーク\"></a>\r\n\t\t</di