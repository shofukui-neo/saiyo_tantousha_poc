{"url":"https://www.shinwa-giken.co.jp/recruit/new-graduate/","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n<head>\n<meta charset=\"utf-8\">\n\n<title>2027年 新卒者採用情報 | シンワ技研コンサルタント株式会社</title>\n<meta name=\"robots\" content=\"index,follow\" />\n<meta name=\"description\" content=\"建設工事の基礎となる測量、設計、地質調査、土質調査及び用地補償に係る補償物件の調査、積算、工事施工管理業務などを行う建設コンサルタント会社。\">\n\t\n\n<meta property=\"og:image\" content=\"http://www.shinwa-giken.co.jp/user/common/images/ogp_image.jpg\">\n<meta property=\"og:locale\" content=\"ja_jp\">\n<meta property=\"og:site_name\" content=\"シンワ技研コンサルタント株式会社\">\n\n\n<meta property=\"og:type\" content=\"article\">\n\n\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0, viewport-fit=cover\">\n\t\n<link rel=\"apple-touch-icon\" href=\"/user/common/images/i_icon.png\">\n<link rel=\"shortcut icon\" href=\"/user/common/images/favicon.ico?2019\">\n\n\n\t\n<link type=\"text/css\" href=\"/user/common/css/html5reset.css\" rel=\"stylesheet\" media=\"all\">\n<link type=\"text/css\" href=\"/user/common/css/common.css?20260319\" rel=\"stylesheet\" media=\"all\">\n<link type=\"text/css\" href=\"/user/common/css/style.css?20260319\" rel=\"stylesheet\" media=\"all\">\n<link type=\"text/css\" href=\"/user/common/css/jquery.bxslider.css\" rel=\"stylesheet\" media=\"all\">\n<link type=\"text/css\" href=\"/user/common/css/additional_slide.css\" rel=\"stylesheet\" media=\"all\">\n<link type=\"text/css\" href=\"/user/common/css/print_top.css\" rel=\"stylesheet\" media=\"print\">\n\n\n\n\t\n<script src=\"//code.jquery.com/jquery-3.1.1.min.js\" integrity=\"sha256-hVVnYaiADRTO2PzUGmuLJr8BLUSjGIZsDYGmIJLv2b8=\" crossorigin></script>\n<script src=\"/user/common/js/common.js?20260319\" charset=\"UTF-8\"></script>\n<script src=\"/user/common/js/jquery.matchHeight.js\" charset=\"UTF-8\"></script>\n<script src=\"/user/common/js/smoothscroll.js\" charset=\"UTF-8\"></script>\n<script src=\"/user/common/js/share.js\" charset=\"UTF-8\"></script>\n\n\t\n\n<!-- Google tag (gtag.js) -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-CW4L3XGBLS\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'G-CW4L3XGBLS');\n</script>\n\n</head>\n\n<body class=\"page\">\n\n\n<div class=\"entry-content\">\n<div id=\"all\">\n\t<noscript><div class=\"no_script\">※当サイトはJavaScriptが有効になっていないと正常に表示されません。ブラウザ設定でJavaScriptを有効にしてご利用ください。</div></noscript>\n\t  \n<!-- ▼ヘッダ背景 -->\n<div id=\"cont-headerimg\"\n\t\t\t class=\"recruit\"\n\t\t\t\n>\n\t\n\n\t\n<div class=\"all-width\">\n\n<!-- ▼ヘッダ -->\n<header class=\"header\"><div class=\"all-width\">\n\t<div id=\"shinwa\"><a href=\"/\"><img class=\"logo\" src=\"/user/common/images/logo.png\" alt=\"シンワ技研コンサルタント株式会社\" width=\"332\"></a></div>\n\t<div class=\"pc-g-nav pc\">\n\t\t\t\n\t\t<ul>\n\t\t\t<li><a href=\"/\">HOME</a></li>\n\t\t\t<li><a href=\"/company/\">会社概要</a></li>\n\t\t\t<li><a href=\"/service/\">事業内容</a></li>\n\t\t\t<li><a href=\"/recruit/\" class=\"here\">採用情報</a></li>\n\t\t</ul>\n\t\t\n\t</div>\n\t<div class=\"pc-mail pc\"><a href=\"/form/\">お問い合わせ</a></div></div>\n\n\n\t<!-- ▼ドロワーメニュー -->\n\t<nav class=\"global-nav sp\">\n\t\t<div class=\"logo-top\"><img class=\"logo\" src=\"/user/common/images/logo.png\" alt=\"シンワ技研コンサルタント株式会社\" height=\"38\"></div>\n\t\t<div class=\"home\"><a href=\"/\">HOMEに戻る</a></div>\n\t\t<ul class=\"global-nav__list\">\n\t\t\t<li class=\"global-nav__item\"><a href=\"/company/\">会社概要<span class=\"blue barlow-sb\">About us</span></a></li>\n\t\t\t<li class=\"global-nav__item\"><a href=\"/service/\">事業内容<span class=\"blue barlow-sb\">Service</span></a></li>\n\t\t\t<li class=\"global-nav__item\"><a href=\"/recruit/\">採用情報<span class=\"blue barlow-sb\">Recruit</span></a></li>\n\t\t</ul>\n\t\t<div class=\"mail\"><div class=\"inner\"><a href=\"/form/\"><div class=\"mail-icon\">お問い合わせ</div></a></div></div>\n\t\t<div class=\"social\">\n\t\t\t\n\t\t\t<span id=\"socialarea_line_in\"><a href=\"https://lin.ee/rUKxvnB\" target=\"_blank\" title=\"line\"><img src=\"/user/common/images/social03.png\" alt=\"LINE\" width=\"36\"></a></span>\n\t\t</div>\n\t\t<div class=\"close\" id=\"js-black-bg\">閉じる</div>\n\t</nav>\n\n\t<div class=\"hamburger\" id=\"js-hamburger\">\n\t\t<span class=\"hamburger__line hamburger__line--1\"></span>\n\t\t<span class=\"hamburger__line hamburger__line--2\"></span>\n\t\t<span class=\"hamburger__line hamburger__line--3\"></span>\n\t</div>\n\t<div class=\"black-bg\" id=\"js-black-bg\"></div>\n</header>\n\t\n\t\n<div class=\"all-width\"><div class=\"pc-social pc\">\n\t\t\t\n\t\t\t<span id=\"socialarea_line\"><a href=\"https://lin.ee/rUKxvnB\" target=\"_blank\" title=\"line\"><img src=\"/user/common/images/social03.png\" alt=\"LINE\" width=\"36\"></a></span>\n</div></div>\n\n\n<!-- ▼h1ページタイトル -->\n<div class=\"title-box\">\n\t<h1 class=\"page_title\">\n\t\t\n\t\t\t\n\t\t\n\t\t2027年 新卒者採用情報\n\t</h1>\n</div>\n\n\t\n\n<!-- ▼ぱんくず -->\n<div class=\"breadcrumb\">\n\t<p>\n<a href=\"/\">ホーム</a> ＞ \n\n<span><a href=\"/recruit/\">採用情報</a></span> ＞ \n\n\n\n\n<span>2027年 新卒者採用情報</span>\n\n\n</p>\n\n</div>\n\n\t\n</div>\n</div>\n<!-- ▲ヘッダ背景 -->\n\t\n\n<!-- #container/-->\n<main id=\"container\">\n\t\t\n\n\n\n\n<div class=\"all-width\">\n<article id=\"conts\">\n\t\t\n\n\n\n<div class=\"flame\"><div class=\"page-menu\">\n<div class=\"all-width\">\n<ul>\n\t<li><a href=\"#recruit\">募集要項</a></li>\n\t<li><a href=\"#treatment\">採用後の待遇</a></li>\n\t<li><a href=\"#howto\">応募方法</a></li>\n\t<li><a href=\"#briefing\">会社説明会</a></li>\n</ul>\n</div>\n</div></div>\n<div class=\"flame\"><h3>現在、【2027年3月卒業予定】新卒者採用の募集を行っております。</h3>\n\n<p style=\"text-align: center;\">マイナビよりエントリーを行ってください。 <a target=\"_blank\" href=\"https://job.mynavi.jp/27/pc/search/corp207085/outline.html\"> <img border=\"0\" src=\"https://job.mynavi.jp/conts/kigyo/2027/logo/banner_logo_195_60.gif\" alt=\"マイナビ2027\"> </a></p>\n\n<div><a name=\"recruit\"></a></div>\n\n<h2>募集要項</h2></div>\n<div class=\"flame\"><h3 class=\"line\">設計技術者</h3>\n\n<table class=\"table_line table_sp_block\">\n\t<tbody>\n\t\t<tr>\n\t\t\t<th class=\"text-nowrap text-right\">仕事内容</th>\n\t\t\t<td>設計部門は、測量部門・調査部門から提供される地形や地質情報などを基に、道路・河川・砂防・橋梁・防災施設などの設計、補修・補強設計なども行います。また、道路付属物やトンネルなどの点検を主体とした維持管理業務や三次元設計を見据えた BIM/CIM への取組みも進めています。</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<th class=\"text-nowrap text-right\">勤務予定地</th>\n\t\t\t<td>米子本社（鳥取県米子市道笑町4丁目12-24）</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<th class=\"text-nowrap text-right\">募集対象</th>\n\t\t\t<td>\n\t\t\t<ul>\n\t\t\t\t<li>2027 年 3 月卒業見込みの方、あるいは卒業後 3 年以内の方</li>\n\t\t\t\t<li>既卒業者は随時入社可能</li>\n\t\t\t</ul>\n\t\t\t</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<th class=\"text-nowrap text-right\">募集学部・学科</th>\n\t\t\t<td>全学部生（全学部・全学科）、理系・文系を問いません。</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<th class=\"text-nowrap text-right\">募集人数</th>\n\t\t\t<td>2 名</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<th class=\"text-nowrap text-right\">内定までの所要日数</th>\n\t\t\t<td>採用試験から採用決定までは 1 週間以内</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<th class=\"text-nowrap text-right\">選考方法</th>\n\t\t\t<td>\n\t\t\t<ol>\n\t\t\t\t<li>書類審査</li>\n\t\t\t\t<li>Web適性検査（SPI）</li>\n\t\t\t\t<li>筆記試験（一般常識、専門科目）</li>\n\t\t\t\t<li>最終面接</li>\n\t\t\t</ol>\n\t\t\t</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<th class=\"text-nowrap text-right\">提出書類</th>\n\t\t\t<td>履歴書、学業成績証明書、卒業見込証明書</td>\n\t\t</tr>\n\t</tbody>\n</table></div>\n<div class=\"flame\"><h3 class=\"line\">測量技術者</h3>\n\n<table class=\"table_line table_sp_block\">\n\t<tbody>\n\t\t<tr>\n\t\t\t<th class=\"text-nowrap text-right\">仕事内容</th>\n\t\t\t<td>測量部門は、道路・河川などの社会資本整備に資する地形・基準点測量や最新技術（ＧＰＳ・ドローン・３Ｄレーザなど）を用いた空間情報の提供を行います。また、海上や湖上にソナー搭載のラジコンボートを航行させての深浅測量や河川の流量観測、水質調査・地籍調査などを行ないます。</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<th class=\"text-nowrap text-right\">勤務予定地</th>\n\t\t\t<td>米子本社（鳥取県米子市道笑町4丁目12-24）</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<th class=\"text-nowrap text-right\">募集対象</th>\n\t\t\t<td>\n\t\t\t<ul>\n\t\t\t\t<li>2027 年 3 月卒業見込みの方、あるいは卒業後 3 年以内の方</li>\n\t\t\t\t<li>既卒業者は随時入社可能</li>\n\t\t\t</ul>\n\t\t\t</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<th class=\"text-nowrap text-right\">募集学部・学科</th>\n\t\t\t<td>全学部生（全学部・全学科）、理系・文系を問いません。</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<th class=\"text-nowrap text-right\">募集人数</th>\n\t\t\t<td>1 名</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<th class=\"text-nowrap text-right\">内定までの所要日数</th>\n\t\t\t<td>採用試験から採用決定までは 1 週間以内</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<th class=\"text-nowrap text-right\">選考方法</th>\n\t\t\t<td>\n\t\t\t<ol>\n\t\t\t\t<li>書類審査</li>\n\t\t\t\t<li>Web適性検査（SPI）</li>\n\t\t\t\t<li>筆記試験（一般常識、専門科目）</li>\n\t\t\t\t<li>最終面接</li>\n\t\t\t</ol>\n\t\t\t</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<th class=\"text-nowrap text-right\">提出書類</th>\n\t\t\t<td>履歴書、学業成績証明書、卒業見込証明書</td>\n\t\t</tr>\n\t</tbody>\n</table></div>\n<div class=\"flame\"><h3 class=\"line\">地質調査技術者</h3>\n\n<table class=\"table_line table_sp_block\">\n\t<tbody>\n\t\t<tr>\n\t\t\t<th class=\"text-nowrap text-right\">仕事内容</th>\n\t\t\t<td>社会インフラに係る設計に必要となる基礎のデータを収集します。地中にある地質の性質を調査、情報取得および解析を行い、その場所に構造物が設置できるかなど安全性を確かめたり、地下水などの調査・計測および解析を行います。</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<th class=\"text-nowrap text-right\">勤務予定地</th>\n\t\t\t<td>本社</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<th class=\"text-nowrap text-right\">募集対象</th>\n\t\t\t<td>\n\t\t\t<ul>\n\t\t\t\t<li> 2027 年 3 月卒業見込みの方、あるいは卒業後 3 年以内の方</li>\n\t\t\t\t<li>既卒業者は随時入社可能</li>\n\t\t\t</ul>\n\t\t\t</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<th class=\"text-nowrap text-right\">募集学部・学科</th>\n\t\t\t<td>地質・土質系の分野を学ばれている方</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<th class=\"text-nowrap text-right\">募集人数</th>\n\t\t\t<td>1 名</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<th class=\"text-nowrap text-right\">内定までの所要日数</th>\n\t\t\t<td>採用試験から採用決定までは 1 週間以内</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<th class=\"text-nowrap text-right\">選考方法</th>\n\t\t\t<td>\n\t\t\t<ol>\n\t\t\t\t<li>書類審査</li>\n\t\t\t\t<li>Web適性検査（SPI）</li>\n\t\t\t\t<li>筆記試験（一般常識、専門科目）</li>\n\t\t\t\t<li>最終面接</li>\n\t\t\t</ol>\n\t\t\t</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<th class=\"text-nowrap text-right\">提出書類</th>\n\t\t\t<td>履歴書、学業成績証明書、卒業見込証明書</td>\n\t\t</tr>\n\t</tbody>\n</table></div>\n<div class=\"flame\"><p> </p>\n\n<div><a name=\"treatment\"></a></div>\n\n<h2>採用後の待遇</h2>\n\n<table class=\"table_line table_sp_block\">\n\t<tbody>\n\t\t<tr>\n\t\t\t<th class=\"text-nowrap text-right span2\">初任給</th>\n\t\t\t<td>\n\t\t\t<ul>\n\t\t\t\t<li><strong>4年制大学</strong>　222,200円</li>\n\t\t\t\t<li><strong>大学院卒　</strong>231,700円</li>\n\t\t\t\t<li><strong>短大　</strong>210,700円</li>\n\t\t\t\t<li><strong>高専　</strong>210,700円</li>\n\t\t\t\t<li><strong>専修学校（2年）　</strong>210,700円</li>\n\t\t\t\t<li><strong>専修学校（1年）　</strong>204,950円</li>\n\t\t\t\t<li><strong>高校　</strong>199,200円</li>\n\t\t\t</ul>\n\t\t\t</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<th class=\"text-nowrap text-right\">諸手当</th>\n\t\t\t<td>\n\t\t\t<ul>\n\t\t\t\t<li><strong>資格手当</strong>　1,000円～100,000円</li>\n\t\t\t\t<li><strong>通勤手当　</strong>会社規程による</li>\n\t\t\t\t<li><strong>住宅手当　</strong>10,000円～15,000円</li>\n\t\t\t\t<li><strong>家族手当　</strong>5,000円～</li>\n\t\t\t\t<li><strong>転勤手当</strong>　会社規定による</li>\n\t\t\t</ul>\n\t\t\t</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<th class=\"text-nowrap text-right\">昇給</th>\n\t\t\t<td>年1回（4月）</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<th class=\"text-nowrap text-right\">賞与</th>\n\t\t\t<td>\n\t\t\t<p>年2回（7月、12月）</p>\n\n\t\t\t<ul>\n\t\t\t\t<li>1年目 2ヶ月</li>\n\t\t\t\t<li>2年目以降 約4.5ヶ月（<small>※前事業年度実績</small>）</li>\n\t\t\t</ul>\n\t\t\t</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<th class=\"text-nowrap text-right\">休日休暇</th>\n\t\t\t<td>\n\t\t\t<p>土曜・日曜（完全週休２日制）、祝日、創立記念休暇、夏季休暇、年末年始休暇、年次有給休暇、転勤休暇、慶弔休暇、育児目的休暇、介護休暇など<br>\n\t\t\t（年間休日数125日）</p>\n\t\t\t</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<th class=\"text-nowrap text-right\">福利厚生及び社内制度</th>\n\t\t\t<td>\n\n<a href=\"/company/employee-benefits/\">\n\t\t\n\t\t\t\t「福利厚生・社内制度」ページ\n\t\t\t\t\n\t\t\t\t\n\t</a>\nをご覧ください</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<th class=\"text-nowrap text-right\">勤務地</th>\n\t\t\t<td>米子本社（鳥取県米子市道笑町4丁目12-24）</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<th class=\"text-nowrap text-right\">勤務時間</th>\n\t\t\t<td>8：30～17：30（休憩1時間）</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<th class=\"text-nowrap text-right\">教育制度</th>\n\t\t\t<td>\n\t\t\t<ul>\n\t\t\t\t<li>ISOを活用したOJT・OFF-JTで技術者育成</li>\n\t\t\t\t<li>メンター制度</li>\n\t\t\t\t<li>資格取得時の費用の全額会社負担（会社が認めた資格）</li>\n\t\t\t</ul>\n\t\t\t</td>\n\t\t</tr>\n\t</tbody>\n</table>\n\n<p> </p></div>\n<div class=\"flame\"><div><a name=\"howto\"></a></div>\n\n<section class=\"section_box common_box right\">\n<h2>応募方法</h2>\n\n<p class=\"img_box\"><a target=\"_blank\" href=\"https://job.mynavi.jp/27/pc/search/corp207085/outline.html\"><img border=\"0\" src=\"https://job.mynavi.jp/conts/kigyo/2027/logo/banner_logo_195_60.gif\" alt=\"マイナビ2027\"> </a></p>\n\n<p>マイナビよりエントリーを行ってください。<br>\nエントリーをしてくださった方には、会社説明会のご案内や選考に関する情報を随時送信します。</p>\n</section></div>\n<div class=\"flame\"><div><a name=\"briefing\"></a></div>\n\n<section class=\"section_box common_box\">\n<h2>会社説明会</h2>\n\n<p class=\"img_box\"><img class=\"filer_image \" alt=\"会社説明会\" src=\"/user/filer_public_thumbnails/filer_public/de/40/de4071a6-d36f-4c93-b292-65b8f21480e7/session_image.jpg__470x352_q95_crop_subject_location-320%2C241_subsampling-2_upscale.jpg\" />\n</p>\n\n<p>新卒者向けの会社説明会を開催いたします。<br>\n当日は、社内見学のほか、実際に現場で働く社員から「リアルな声」直接聞ける貴重な機会となっております。</p>\n\n<p>土木系を学んできた方には、これまで学んできた専門知識をどのように仕事へ活かしていくのか、具体的な仕事内容とあわせてご紹介いたします。</p>\n\n<p>土木系以外の分野を学んできた方もご安心ください。<br>\n当社では新入社員研修などを通して基礎から学べる環境を整えており、実際に土木系以外を専攻していた社員がどのように活躍しているのかについてもご紹介したいと思います。</p>\n\n<p>専門性を深めたい方も、新しい分野に挑戦したい方も、地域を支える仕事に少しでも興味があれば、ぜひ説明会へお越しください！</p>\n\n<p>参加をご希望の方は、マイナビよりエントリー、またはお電話にてご連絡ください。</p>\n\n<p style=\"text-align: right;\"><a target=\"_blank\" href=\"https://job.mynavi.jp/27/pc/search/corp207085/outline.html\"><img border=\"0\" src=\"https://job.mynavi.jp/conts/kigyo/2027/logo/banner_entry_160_45.gif\" alt=\"マイナビ2027\"> </a></p>\n\n<h3 class=\"line\">スケジュール</h3>\n\n<table cellpadding=\"1\" class=\"table_line table_sp_block\" border=\"1\" cellspacing=\"1\">\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\"><span style=\"font-size: 19.68px;\">2026年4月3日（金）</span></th>\n\t\t\t<td>\n\t\t\t<ul>\n\t\t\t\t<li><strong>時間</strong>　13:30～16:00</li>\n\t\t\t\t<li><strong>場所</strong>　米子本社</li>\n\t\t\t\t<li><strong>対象</strong>　2027年度新卒者</li>\n\t\t\t\t<li><strong>備考</strong>　筆記用具をお持ちください。</li>\n\t\t\t</ul>\n\t\t\t</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\"><span style=\"font-size: 19.68px;\">2026年4月28日（火）</span></th>\n\t\t\t<td>\n\t\t\t<ul>\n\t\t\t\t<li><strong>時間</strong>　13:30～16:00</li>\n\t\t\t\t<li><strong>場所</strong>　米子本社</li>\n\t\t\t\t<li><strong>対象</strong>　2027年度新卒者</li>\n\t\t\t\t<li><strong>備考</strong>　筆記用具をお持ちください。</li>\n\t\t\t</ul>\n\t\t\t</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\"><span style=\"font-size: 19.68px;\">2026年5月25日（月）</span></th>\n\t\t\t<td>\n\t\t\t<ul>\n\t\t\t\t<li><strong>時間</strong>　13:30～16:00</li>\n\t\t\t\t<li><strong>場所</strong>　米子本社</li>\n\t\t\t\t<li><strong>対象</strong>　2027年度新卒者</li>\n\t\t\t\t<li><strong>備考</strong>　筆記用具をお持ちください。</li>\n\t\t\t</ul>\n\t\t\t</td>\n\t\t</tr>\n\t</tbody>\n</table>\n \n\n<div class=\"color_box\">\n<h3 style=\"text-align: center;\">会社説明会に関するお問い合わせはこちら</h3>\n\n<p class=\"mab0\" style=\"text-align: center;\">シンワ技研コンサルタント株式会社<br>\n<strong>人事採用担当／未来戦略チーム 田中</strong><br>\nTEL: 0859-34-2141<span class=\"sp_off\">　　</span><br class=\"sp\">\nFAX: 0859-33-2844<br>\nE-mail: recruit@shinwa-giken.co.jp</p>\n</div>\n</section></div>\n\n\n\t\n\n\n\t\n\n\n\n\n\n\t\t\n</article></div>\n<!-- /.all-width -->\n\n\n\t\n</main>\n<!-- /#container-->\n\n\t\n\t\n\t\n<!-- ▼お問い合わせ -->\n<section id=\"contact\">\n\t<div class=\"all-width\">\n\t\t<div class=\"inner\">\n\t\t\t<h2 class=\"l-box\">\n\t\t\t\t<div class=\"barlow-sb\">Contact</div><div class=\"jp\">お問い合わせ</div>\n\t\t\t\t<div class=\"time\">受付時間  9:00～17:00<span class=\"jyogai\">（土日祝・弊社指定休日は除く）</span></div>\n\t\t\t</h2>\n\t\t\t<div class=\"r-box\"><a href=\"tel:0859342141\"><div class=\"tel\">電話</div><div class=\"number\">0859-34-2141</div></a></div>\n\t\t\t<div class=\"r-box\"><a href=\"/form/\"><div class=\"