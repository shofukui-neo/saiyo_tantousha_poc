{"url":"https://www.neco-net.co.jp/career_formation/index.html","html":"<!doctype html>\n<html lang=\"ja\">\n<head>\n<title>キャリア形成｜原子力エンジニアリング株式会社</title>\n<meta name=\"description\" content=\"原子力関連施設において、試験研究炉、核燃料取扱施設、核融合装置など、施設の運転保守管理業務、それら施設に設置される、さまざまな実験・試験装置を使用した研究開発の支援業務や廃棄物管理業務などを通じて、原子力の研究開発の土台を支える業務を行っています。\">\n<meta name=\"keywords\" content=\"原子力,エネルギー,環境,研究,開発,原子力発電所,エネルギー環境,実験,試験,放射性,廃棄物,点検,検査,原子力エンジニアリング\">\n\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<meta name=\"format-detection\" content=\"telephone=no\">\n\n<meta property=\"og:type\" content=\"article\">\n<meta property=\"og:title\" content=\"キャリア形成｜原子力エンジニアリング株式会社\">\n<meta property=\"og:description\" content=\"原子力関連施設において、試験研究炉、核燃料取扱施設、核融合装置など、施設の運転保守管理業務、それら施設に設置される、さまざまな実験・試験装置を使用した研究開発の支援業務や廃棄物管理業務などを通じて、原子力の研究開発の土台を支える業務を行っています。\">\n<meta property=\"og:site_name\" content=\"原子力エンジニアリング株式会社\">\n<meta property=\"og:url\" content=\"https://www.neco-net.co.jp/career_formation/\">\n<meta property=\"og:image\" content=\"https://www.neco-net.co.jp/ogp.jpg\">\n<link rel=\"stylesheet\" href=\"../css/import.css\">\n<link rel=\"icon\" type=\"image/svg+xml\" href=\"../favicon.svg\" />\n<link rel=\"icon\" type=\"image/vnd.microsoft.icon\" href=\"../favicon.png\" />\n<link rel=\"apple-touch-icon\" href=\"../apple-touch-icon.png\">\n\n<script src=\"../js/jquery-1.7.2.min.js\" type=\"text/javascript\"></script>\n<script src=\"../js/viewport.js\" type=\"text/javascript\"></script>\n<script src=\"../js/hover.js\" type=\"text/javascript\"></script>\n<script src=\"../js/menu.js\" type=\"text/javascript\"></script>\n<script src=\"../js/inview.js\" type=\"text/javascript\"></script>\n<script src=\"../js/inview_op.js\" type=\"text/javascript\"></script>\n<script src=\"../js/smaller.js\" type=\"text/javascript\"></script>\n<script src=\"../js/scroll.js\" type=\"text/javascript\"></script>\n<script src=\"../js/ScrollTrigger.min.js\" type=\"text/javascript\"></script>\n<script src=\"../js/jquery.easing.1.3.js\" type=\"text/javascript\"></script>\n\n<!-- Googleアナリティクス開始【原子力エンジニアリング株式会社】 -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-CW27MV4TRW\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'G-CW27MV4TRW');\n</script>\n<!-- Googleアナリティクス終了【原子力エンジニアリング株式会社】 -->\n</head>\n\n<body id=\"career_formation\">\n<header>\n<div id=\"menu\">\n<div class=\"header_nav\">\n<div class=\"flex\">\n<a href=\"../index.html\" class=\"logo\"><img src=\"../images/logo.svg\" alt=\"原子力エンジニアリング株式会社\" width=\"379\" height=\"48\"></a>\n<a href=\"../index.html\" class=\"logo_short\"><img src=\"../images/logo_short.svg\" alt=\"原子力エンジニアリング株式会社\" width=\"266\" height=\"48\"></a>\n<a href=\"../index.html\" class=\"logo_icon\"><img src=\"../images/logo_icon.svg\" alt=\"原子力エンジニアリング株式会社\" width=\"60\" height=\"48\"></a>\n<div>\n<nav class=\"global_nav\">\n<ul>\n<li><a href=\"../about/index.html\">NECOについて</a></li>\n<li><a href=\"../works/index.html\">私たちの仕事</a></li>\n<li><a href=\"../people/index.html\">NECOの仲間</a></li>\n<li><a href=\"../career_formation/index.html\">キャリア形成</a></li>\n<li><a href=\"../benefit/index.html\">環境と制度</a></li>\n<li><a href=\"../recruit/index.html\">採用情報</a></li>\n<li class=\"contact\"><a href=\"../contact/index.html\"><span>お問い合わせ</span></a></li>\n</ul>\n</nav>\n<!-- /global_nav -->\n</div>\n</div>\n<!-- /flex -->\n</div>\n<!-- /header_nav -->\n</div>\n<!-- /menu -->\n\t\n<nav class=\"floating_contact\">\n<ul class=\"flex\">\n<li><a href=\"../recruit/index.html#entry\">採用エントリー</a></li>\n<li><a href=\"../recruit/index.html#requirements\">募集要項</a></li>\n</ul>\n</nav>\n<!-- /floating_contact -->\n\n<div class=\"global_nav_sp\">\n<div class=\"menu\">\n<a href=\"../index.html\" class=\"logo_sp\"><img src=\"../images/logo.svg\" alt=\"原子力エンジニアリング株式会社\"></a>\n<div class=\"toggle\">\n<div class=\"bar top\"></div>\n<div class=\"bar middle\"></div>\n<div class=\"bar bottom\"></div>\n</div>\n<!-- /toggle -->\n<nav class=\"menu_sp\">\n<ul>\n<li><a href=\"../about/index.html\">NECOについて</a></li>\n<li><a href=\"../works/index.html\">私たちの仕事</a></li>\n<li><a href=\"../people/index.html\">NECOの仲間</a></li>\n<li><a href=\"../career_formation/index.html\">キャリア形成</a></li>\n<li><a href=\"../benefit/index.html\">環境と制度</a></li>\n<li><a href=\"../recruit/index.html\">採用情報</a></li>\n<li class=\"contact\"><a href=\"../contact/index.html\">お問い合わせ</a></li>\n</ul>\n</nav>\n</div>\n<!-- /menu -->\n</div>\n<!-- /global_nav_sp -->\n</header>\n\n\n<div class=\"mainvisual\">\n<div class=\"inner\">\n<ul>\n    <li>\n        <picture>\n        <img src=\"../images/entry_title/bg_title_career_formation.jpg\" alt=\"\" width=\"1680\" height=\"750\">\n        </picture>\n    </li>\n</ul>\n</div>\n<!-- /inner -->\n<div class=\"wrap\">\n    <h1><a href=\"index.html\"><span>キャリア形成</span>CAREER <br class=\"pc\">FORMATION</a></h1>\n    <img src=\"../images/entry_title/deco/career_formation.png\" alt=\"\" width=\"233\" height=\"160\">\n</div>\n<nav class=\"bread clearfix\">\n<ol>\n    <li><a href=\"../index.html\">HOME</a></li>\n    <li>キャリア形成</li>\n</ol>\n</nav>\n<!-- /bread -->\n</div>\n<!-- /mainvisual -->\n\n\n<main>\n<h1><span>私たちは「人」の教育に<br class=\"sp\">注力しています</span></h1>\n\n<section class=\"intro_box\">\n<div class=\"inner\">\n<h2>人材育成の取り組み</h2>\n<div class=\"wrap flex\">\n    <div class=\"image_wrap\">\n        <img src=\"images/main.jpg\" alt=\"\" width=\"600\" height=\"450\">\n    </div>\n    <div class=\"text_wrap\">\n        <p class=\"catch\">どんな先端技術も支えているのは人である。<br>モチベーションを高く、成長し続けるための取り組みをしています。</p>\n        <p>私たちはどんな先端技術も支えているのは人であると考えています。<br>何かを成し遂げようという「人」の強い意志が起点であり、それを前進するための「人」の恒常的な修練・努力こそが技術の向上に繋がり終着点はありません。</p>\n    </div>\n</div>\n</div>\n<!-- /inner -->\n</section>\n<!-- /intro_box -->\n\n<div id=\"contents\">\n<section class=\"adjust_group\">\n<div class=\"inner\">\n    <a id=\"route\" class=\"anchor\"></a>\n\t<h3>充実した研修制度とキャリアアップへの道筋</h3>\n\t<div class=\"imgC\">\n\t\t<img src=\"../career_formation/images/training.svg\" alt=\"\" width=\"1000\" height=\"450\">\n\t</div>\n\t<p>NECOテクニカルスクールを開設し、会社全体で人材育成に取り組んでいます。</p>\n\t<p class=\"mb_normal\">「独り立ちプログラム」では、現場の知識が豊富な上司と相談しながら毎年の目標を設定します。4年間で現場の仕事に直結したスキルを身につけ、配属先に負担なく適応できるようサポートします。その他にも、それぞれのキャリアステージに合った世代別・階層別・海外の研修などを用意しています。</p>\n\t<div class=\"column mb_high\">\n\t\t<ul class=\"row3\">\n\t\t\t<li><img src=\"images/image01.jpg\" alt=\"\" width=\"450\" height=\"300\">\n\t\t\t<p class=\"txtC\">フォローアップ研修</p>\n\t\t\t</li>\n\t\t\t<li><img src=\"images/image02.jpg\" alt=\"\" width=\"450\" height=\"300\">\n\t\t\t<p class=\"txtC\">中堅社員研修</p>\n\t\t\t</li>\n\t\t\t<li><img src=\"images/image03.jpg\" alt=\"\" width=\"450\" height=\"300\">\n\t\t\t<p class=\"txtC\">海外研修</p>\n\t\t\t</li>\n\t\t</ul>\n\t</div>\n\t<h3>NECOテクニカルスクール</h3>\n\t<p class=\"mb_row\">近年、NECOは社を挙げて人材育成に全力で取り組んでいます。お客様からは高度な専門的技術力や企業倫理などが要求されるため、技術力向上と資格取得を目指し、人材育成プログラムを策定した「NECOテクニカルスクール」を設立しました。下記のように教育理念を定めています。</p>\n\t<div class=\"area01 mb_high\">\n\t<div class=\"inner\">\n\t<h4>教育理念</h4>\n\t<p class=\"yu_min mb_no\">本スクールは科学技術に対する謙虚な姿勢と豊かな人間性を基盤とし、地域社会に貢献できる原子力技術者を目指します。<br>\n\t\tまた技術者としての倫理観、一般教養および専門知識を身に付け、新入社員の持つ能力を最大限に発揮できるよう支援し、将来にわたって原子力の発展に寄与できる人材の育成を目指します。</p>\n\t</div>\n\t<!-- /inner -->\n\t</div>\n\t<!-- /area01 -->\n\t\n\t<h3>資格取得支援制度</h3>\n\t<div class=\"imgC\">\n\t\t<img src=\"images/support.svg\" alt=\"\" width=\"1000\" height=\"200\">\n\t</div>\n\t<div class=\"wrap clearfix\">\n\t\t<figure class=\"floatR\">\n\t\t\t<img src=\"images/image04.jpg\" alt=\"\" width=\"450\" height=\"300\">\n\t\t\t<figcaption  class=\"txtC\">放射線取扱主任者の勉強会</figcaption>\n\t\t</figure>\n\t\t<p>社員の技術力向上のために、業務に必要な資格の推奨制度を設けています。個人任せではなく、会社全体として資格取得をサポートする環境が整っており、費用支援として受験料・交通費を全額支給しています。</p>\n\t\t<p>また、試験の難易度と業務関連度で資格をランク別に分類しました。取得した資格のポイントを加算する「マイスター制度」を設け、加算ポイントに応じて「シルバーマイスター」「ゴールドマイスター」に分類し、給与が優遇されます。社内の合格者が指導にあたる勉強会・講座や社外の講習会を合わせて活用することもでき、社員からも大変好評です。</p>\n\t</div>\n\t<div class=\"area02\">\n\t<div class=\"inner\">\n\t<h4>主要保有資格一覧</h4>\n\t<ul class=\"disc col_wrap row2\">\n    <li>技術士（原子力・放射線部門）</li>\n    <li>原子炉主任技術者</li>\n    <li>核燃料取扱主任者</li>\n\t<li>第1種　放射線取扱主任者</li>\n\t<li>第2種　放射線取扱主任者</li>\n\t<li>第1種　作業環境測定士（放射性物質）</li>\n\t<li>環境計量士（濃度関係、騒音・振動関係）</li>\n\t<li>第1種　電気主任技術者</li>\n\t<li>第2種　電気主任技術者</li>\n\t<li>第3種　電気主任技術者</li>\n\t<li>第1種　電気工事士</li>\n\t<li>第2種　電気工事士</li>\n\t<li>1級 施工管理技士( 電気・建築・土木)</li>\n\t<li>2級 施工管理技士( 電気・建築・土木)</li>\n\t<li>高圧ガス製造保安責任者　甲種</li>\n\t<li>高圧ガス製造保安責任者　乙種機械</li>\n\t<li>高圧ガス製造保安責任者　丙種化学</li>\n\t<li>高圧ガス製造保安責任者　1種冷凍機械</li>\n\t<li>高圧ガス製造保安責任者　2種冷凍機械</li>\n\t<li>高圧ガス製造保安責任者　3種冷凍機械</li>\n\t<li>1級　建築士</li>\n\t<li>2級　建築士</li>\n\t<li>1級　ボイラー技士</li>\n\t<li>2級　ボイラー技士</li>\n\t<li>ボイラー整備士</li>\n\t<li>データーベーススペシャリスト</li>\n\t<li>情報セキュリティスペシャリスト</li>\n\t<li>応用情報処理技術者</li>\n\t<li>基本情報処理技術者</li>\n\t<li>危険物取扱責任者（甲・乙）</li>\n\t<li>クレーン運転士</li>\n\t<li>エックス線作業主任者</li>\n\t<li>エネルギー管理士（電気）</li>\n\t<li>第1種　衛生管理者</li>\n\t<li>第2種　レーザ機器取扱技術者</li>\n\t</ul>\n\t</div>\n\t<!-- /inner -->\n\t</div>\n\t<!-- /area01 -->\n\t<h3>放射線業務従事者のための各種教育</h3>\n\t<p>原子力施設等の管理区域内で業務に従事するには、放射線に関する正しい知識が必要です。</p>\n\t<p class=\"mb_normal\">私たちは本社研修室にて、法律で義務付けられた放射線業務従事者教育訓練を実施しています。他にも、放射線入門講座、第2種放射線取扱主任者試験対策講座などの、放射線業務従事者のための教育・研修を実施しています。</p>\n\t<div class=\"column\">\n\t<ul class=\"row3\">\n\t\t<li><img src=\"images/image05.jpg\" alt=\"\" width=\"450\" height=\"300\"></li>\n\t\t<li><img src=\"images/image06.jpg\" alt=\"\" width=\"450\" height=\"300\">\n\t\t\t<p class=\"txtC\">放射線業務従事者教育</p>\n\t\t</li>\n\t\t<li><img src=\"images/image07.jpg\" alt=\"\" width=\"450\" height=\"300\"></li>\n\t</ul>\n\t</div>\n</div>\n<!-- /inner -->\n</section>\n<!-- /adjust_group -->\n</div>\n<!-- contents -->\n</main>\n\n\n<footer>\n<div class=\"inner\">\n<nav class=\"footer_area_nav sp\">\n<ul>\n<li><a href=\"../about/index.html\">NECOについて</a></li>\n<li><a href=\"../works/index.html\">私たちの仕事</a></li>\n<li><a href=\"../people/index.html\">NECOの仲間</a></li>\n<li><a href=\"../career_formation/index.html\">キャリア形成</a></li>\n<li><a href=\"../benefit/index.html\">環境と制度</a></li>\n<li><a href=\"../recruit/index.html\">採用情報</a></li>\n<li><a href=\"../privacy/index.html\">プライバシーポリシー</a></li>\n<li><a href=\"../contact/index.html\">お問い合わせ</a></li>\n<li><a href=\"../sitemap/index.html\">サイトマップ</a></li>\n</ul>\n</nav>\n<!-- /footer_area_nav -->\n<div class=\"vcard_area\">\n    <div class=\"fn org\"><a href=\"../index.html\"><img src=\"../images/logo.svg\" alt=\"原子力エンジニアリング株式会社\" class=\"footer_logo\"></a></div>\n    <dl class=\"flex\">\n        <dt>本社</dt>\n        <dd class=\"adr\">\n            <span class=\"postal-code\">〒319-1112</span><span class=\"region\">茨城県</span><span class=\"locality\">那珂郡東海村</span><span class=\"street-address\">村松字平原3129-29</span>\n            <br>\n            <span class=\"tel\"><span class=\"type\">TEL：</span><span class=\"value\">029-287-2828</span></span>/\n            <span class=\"fax\">\n                <span class=\"type\">FAX：</span><span class=\"value\">029-287-3399</span>\n            </span>\n        </dd>\n    </dl>\n</div>\n<!-- /vcard_area -->\n</div>\n<!-- /inner -->\n\n<div class=\"footer_area_nav pc\">\n<div class=\"inner\">\n<ul class=\"flex\">\n<li><a href=\"../privacy/index.html\">プライバシーポリシー</a></li>\n<li><a href=\"../contact/index.html\">お問い合わせ</a></li>\n<li><a href=\"../sitemap/index.html\">サイトマップ</a></li>\n</ul>\n<div class=\"copyright\">\n<small >Copyright Nuclear Engineering Co.,Ltd. All Rights Reserved.</small>\n</div>\n</div>\n<!-- /inner -->\n</div>\n<!-- /footer_area_nav -->\n\n<div class=\"copyright sp\">\n    <small >Copyright Nuclear Engineering Co.,Ltd. All Rights Reserved.</small>\n</div>\n</footer>\n\n\n<nav class=\"floating_menu sp\">\n<ul>\n<!--<li class=\"contact full\"><a href=\"../contact/index.html\">お問い合わせ</a></li>-->\n<li class=\"entry\"><a href=\"../recruit/index.html#entry\">採用エントリー</a></li>\n<li class=\"requirements\"><a href=\"../recruit/index.html#requirements\">募集要項</a></li>\n</ul>\n</nav>\n\n\n</body>\n</html>\n","finalUrl":"https://www.neco-net.co.jp/career_formation/","rendered":false,"_cachedAt":"2026-06-22T16:48:20.482Z"}