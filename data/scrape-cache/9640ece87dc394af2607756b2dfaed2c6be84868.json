{"url":"http://www.nihon-setsubi.co.jp/contact.html","html":"\n<!DOCTYPE html>\n<html lang=\"ja\">\n<head>\n    <meta charset=\"utf-8\">\n    <title>お問い合わせ：日本設備管理株式会社</title>\n    <meta name=\"keywords\" content=\"\">\n    <meta name=\"description\" content=\"\">\n    <meta http-equiv=\"X-UA-Compatible\" content=\"IE=Edge\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n\n<link rel=\"shortcut icon\" type=\"image/x-icon\" href=\"images/favicon.ico\">\n\n    <link rel=\"stylesheet\" href=\"css/animate.min.css\">\n    <link rel=\"stylesheet\" href=\"css/bootstrap.min.css\">\n    <link rel=\"stylesheet\" href=\"css/font-awesome.min.css\">\n    <link rel=\"stylesheet\" href=\"css/nsk-style.css\">\n    <script src=\"js/jquery.js\"></script>\n    <script src=\"js/bootstrap.min.js\"></script>\n    <script src=\"js/jquery.singlePageNav.js\"></script>\n    <script src=\"js/wow.min.js\"></script>\n    <script src=\"js/parallax.js\"></script>\n    <script src=\"js/custom.js\"></script>\n    \n<!-- Piwik -->\n<script type=\"text/javascript\">\n  var _paq = _paq || [];\n  /* tracker methods like \"setCustomDimension\" should be called before \"trackPageView\" */\n  _paq.push([\"setDocumentTitle\", document.domain + \"/\" + document.title]);\n  _paq.push(['trackPageView']);\n  _paq.push(['enableLinkTracking']);\n  (function() {\n    var u=\"//www.nihon-setsubi.co.jp/piwik/\";\n    _paq.push(['setTrackerUrl', u+'piwik.php']);\n    _paq.push(['setSiteId', '1']);\n    var d=document, g=d.createElement('script'), s=d.getElementsByTagName('script')[0];\n    g.type='text/javascript'; g.async=true; g.defer=true; g.src=u+'piwik.js'; s.parentNode.insertBefore(g,s);\n  })();\n</script>\n<!-- End Piwik Code -->\n\n    \n</head>\n<body id=\"top\">\n\n<!-- start preloader -->\n<div class=\"preloader\">\n    <div class=\"sk-spinner sk-spinner-wave\">\n        <div class=\"sk-rect1\"></div>\n        <div class=\"sk-rect2\"></div>\n        <div class=\"sk-rect3\"></div>\n        <div class=\"sk-rect4\"></div>\n        <div class=\"sk-rect5\"></div>\n    </div>\n</div>\n<!-- end preloader -->\n\n<!-- start header -->\n<header>\n    <div class=\"container\" id=\"header\">\n        <div class=\"row\">\n            <div class=\"col-md-12 col-sm-12 col-xs-12\">\n                <a href=\"index.html\" class=\"navbar-brand\">日本設備管理株式会社</a>\n            </div>\n        </div>\n    </div>\n</header>\n<!-- end header -->\n\n<!-- start navigation -->\n<nav class=\"navbar navbar-default nsk-nav\" role=\"navigation\">\n    <div class=\"container\">\n        <div class=\"navbar-header\">\n            <button class=\"navbar-toggle\" data-toggle=\"collapse\" data-target=\".navbar-collapse\">\n                <span class=\"icon icon-bar\"></span>\n                <span class=\"icon icon-bar\"></span>\n                <span class=\"icon icon-bar\"></span>\n            </button>\n        </div>\n        <div class=\"collapse navbar-collapse\">\n            <ul class=\"nav navbar-nav\">\n                <li><a href=\"index.html#top\" class=\"external\"><i class=\"fa fa-home\"></i> HOME</a></li>\n                <li><a href=\"index.html#vision\" class=\"external\"><i class=\"fa fa-line-chart\"></i> 経営ビジョン</a></li>\n                <li class=\"dropdown\">\n                    <a href=\"index.html#item\" class=\"external dropdown-toggle\" data-toggle=\"dropdown\" role=\"button\"><i class=\"fa fa-list\"></i> 業務内容</a>\n                    <ul class=\"dropdown-menu\" role=\"menu\">\n                        <li><a href=\"b-management.html\" class=\"external\">ビルマネジメント業務</a></li>\n                        <li><a href=\"s-kanri.html\" class=\"external\">設備管理業務</a></li>\n                        <li><a href=\"k-maintenance.html\" class=\"external\">工事メンテナンス業務</a></li>\n                        <li><a href=\"c-kanri.html\" class=\"external\">清掃管理業務</a></li>\n                        <li><a href=\"e-kanri.html\" class=\"external\">衛生管理業務</a></li>\n                        <li><a href=\"s-keibi.html\" class=\"external\">保安警備業務</a></li>\n                        <li><a href=\"k-service.html\" class=\"external\">管理サービス業務</a></li>\n                    </ul>\n                </li>\n                <li><a href=\"aboutus.html\" class=\"external\"><i class=\"fa fa-info\"></i> 会社概要</a></li>\n                <li><a href=\"access.html\" class=\"external\"><i class=\"fa fa-map-marker\"></i> アクセス</a></li>\n                <li><a href=\"contact.html\" class=\"active\"><i class=\"fa fa-envelope\"></i> お問い合わせ</a></li>\n                <li><a href=\"https://www.facebook.com/nihonnsetsubikanri/\" target=\"_blank\" class=\"external\"><i class=\"fa fa-facebook-square\"></i> Facebook</a></li>\n            </ul>\n        </div>\n    </div>\n</nav>\n<!-- end navigation -->\n\n<!-- start contact -->\n<section id=\"contact\">\n    <div class=\"container\">\n        <div class=\"row\">\n            <div class=\"col-md-12\">\n                <h2 class=\"wow fadeInDown\" data-wow-offset=\"50\" data-wow-delay=\"0.3s\">お問い合わせ</h2>\n            </div>\n            <div class=\"col-md-6 col-sm-6 col-xs-12 wow fadeInLeft\" data-wow-offset=\"50\" data-wow-delay=\"0.9s\">\n                <form action=\"/contact.html\" method=\"post\">\n\n                    <input type=\"hidden\" name=\"action\" value=\"\" id=\"sc\">\n\n                    <label>御社名<span style=\"font-size: 90%; color: #CC0000;\" >　必須</span></label>\n                    <input name=\"companyname\" type=\"text\" class=\"form-control\" id=\"company\" required>\n\n                    <label>お電話番号</label>\n                    <input name=\"call_no\" type=\"text\" class=\"form-control\" id=\"call\">\n\n                    <label>ご担当者名<span style=\"font-size: 90%; color: #CC0000;\" >　必須</span></label>\n                    <input name=\"personnel\" type=\"text\" class=\"form-control\" id=\"fullname\" required>\n\n                    <label>メールアドレス<span style=\"font-size: 90%; color: #CC0000;\" >　必須</span></label>\n                    <input name=\"email\" type=\"email\" class=\"form-control\" id=\"email\" required>\n\n                    <label>お問い合わせ内容<span style=\"font-size: 90%; color: #CC0000;\" >　必須</span></label>\n                    <textarea name=\"message\" rows=\"8\" class=\"form-control\" id=\"message\" required></textarea>\n\n                    <input type=\"checkbox\" id=\"chk\" class=\"checkbox-inline\"><label for=\"chk\"> 当社の個人情報保護方針に同意し、内容を送信します</label><br>\n\n                    <input type=\"hidden\" name=\"useragent\" id=\"useragent\" value=\"MochicaResearchBot/0.1 (+mailto:your-email@example.com)\"><input type=\"hidden\" name=\"ipaddress\" id=\"ipaddress\" value=\"133.200.158.128\"><input type=\"hidden\" name=\"remotehost\" id=\"remotehost\" value=\"flh2-133-200-158-128.tky.mesh.ad.jp\">\n\n\n                    <input type=\"submit\" value=\"送信\" class=\"form-control\" id=\"submission\" disabled=\"disabled\">\n                </form>\n            </div>\n            \n\n            <div id=\"inquiry\" class=\"col-md-6 col-sm-6 col-xs-12 wow fadeInRight\" data-wow-offset=\"50\" data-wow-delay=\"0.6s\">\n                <h3>個人情報保護方針（プライバシーポリシー）</h3>\n                <h5>個人情報保護方針</h5>\n                <p>日本設備管理株式会社（以下「当社」）は個人情報の重要性を深く認識するとともに、プライバシーの保護に努め、個人情報の取り扱いに関して徹底した管理を実施しております。</p>\n                <h5>個人情報の取得</h5>\n                <p>当社は、お預かりする個人情報の利用目的を明確化するよう努力し、業務上必要な範囲で、適法かつ公正な手段により個人情報を取得します。</p>\n                <h5>個人情報の利用・目的</h5>\n                <p>当社は、取得した個人情報をあらかじめ定めた利用目的もしくは、それと合理的な関連性のある範囲内で、業務の遂行上必要な限りにおいて利用します。お預かりした個人情報は、法令に定められている場合を除き、同意を得ることなく第三者に提供・開示などをする事はありません。</p>\n                <h5>個人情報の外部委託</h5>\n                <p>当社は、個人情報を第三者との間で共同利用、または、個人情報の取り扱いを第三者に委託する場合は、共同利用の相手方及び委託先に対し、適正な調査を実施の上、秘密を保持させるために適切な契約や指導・管理を行います。</p>\n                <h5>個人情報の管理・取り扱い</h5>\n                <p>当社は、お預かりした個人情報は、適切かつ厳重に管理し、個人情報への不正アクセス・紛失・破壊・改ざんおよび漏洩などを防止するため、適正な情報セキリュティ対策を講じます。</p>\n                <h5>個人情報の開示など</h5>\n                <p>当社は、ご自身の個人情報の開示・変更および削除などを希望される場合には、お申し込み者ご本人様であることを確認の上、法令に従って速やかに対応します。</p>\n            </div>\n        </div>\n    </div>\n</section>\n\n<script type=\"text/javascript\">\n    $(function(){\n        $(\"#sc\").val(\"send\");\n    });\n</script>\n<!-- end contact -->\n\n<!-- start nsk_footer -->\n<footer id=\"nsk_footer\">\n    <div class=\"container\">\n        <div class=\"row\">\n            <div class=\"col-md-9 col-sm-8 col-xs-12\">\n                <ul class=\"list-inline\">\n                    <li><a href=\"index.html#top\"><i class=\"fa fa-home\"></i> 日本設備管理トップ</a></li>\n                    <li><a href=\"aboutus.html\"> 会社情報</a></li>\n                    <li><a href=\"contact.html\"> お問い合わせ</a></li>\n                    <li><a href=\"privacypolicy.html\"> 個人情報保護方針</a></li>\n                    <li><a href=\"aboutus.html#sil\">警備業法に基づく標識の掲示について</a></li>\n                </ul>\n                <p class=\"wow fadeIn\" data-wow-offset=\"50\" data-wow-delay=\"0.3s\">\n                    日本設備管理株式会社 &copy; Copyright&nbsp; 2026</p>\n            </div>\n            <div class=\"col-md-3 col-sm-4 col-xs-12 text-center\">\n                <img src=\"images/svg/nsk_logo_dark4footer.svg\" alt=\"総合ビルメンテナンス 日本設備管理株式会社\" title=\"総合ビルメンテナンス 日本設備管理株式会社\" class=\"footer_logo img-responsive wow fadeInRight\">\n            </div>\n        </div>\n    </div>\n</footer>\n<!-- end nsk_footer -->\n</body>\n</html>","finalUrl":"http://www.nihon-setsubi.co.jp/contact.html","rendered":false,"_cachedAt":"2026-06-22T20:10:27.953Z"}