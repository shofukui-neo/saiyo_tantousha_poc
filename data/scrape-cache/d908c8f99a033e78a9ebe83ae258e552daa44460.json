ill.co.jp/recruit/entry_select.html\" class=\"btn_con\"><span class=\"h__en\">ENTRY</span><span class=\"subtitle\">エントリー</span><span class=\"cv_arrow\"></span></a>\r\n  </div>\r\n  </button>\r\n\t<button class=\"intern_btn\">\r\n  <div class=\"intern_btn_in\">\r\n  <a href=\"https://www.ill.co.jp/recruit/internship/\" target=\"_blank\" class=\"btn_con\"><span class=\"h__en\">INTERNSHIP</span><span class=\"subtitle\">インターンシップ</span><span class=\"cv_arrow\"></span></a>\r\n  </div>\r\n  </button>\r\n  <!--スマホヘッダー-->\r\n  <div class=\"ill-headerInner__sp\">\r\n    <div class=\"openbtn1\"><span></span><span></span><span></span></div>\r\n    <nav id=\"g-nav\">\r\n      <div id=\"g-nav-list\"><!--ナビの数が増えた場合縦スクロールするためのdiv※不要なら削除-->\r\n        <div class=\"footer__t\">\r\n          <nav class=\"footer__t__in\">\r\n            <div class=\"footer__t__st\">\r\n              <ul class=\"footer__t__st__ls\">\r\n                <li>\r\n                  <div class=\"footer__t__st__ls__hd\"><a href=\"message.html\"><span class=\"c-navText\"><span class=\"__en\">MESSAGE</span><span class=\"__ja\">アイルの想い</span></span></a></div>\r\n                  <div class=\"footer__t__st__ls__bd\">\r\n                    <ul class=\"footer__t__st__ls__bd__ls\">\r\n                      <li><a href=\"message.html#message_or\"><span>アイルの役割</span></a></li>\r\n                      <li><a href=\"message.html#message_cp\"><span>企業ポリシー</span></a></li>\r\n                      <li><a href=\"message.html#message_ic\"><span>求める人物像</span></a></li>\r\n                    </ul>\r\n                  </div>\r\n                </li>\r\n              </ul>\r\n            </div>\r\n            <div class=\"footer__t__st\">\r\n              <ul class=\"footer__t__st__ls\">\r\n                <li>\r\n                  <div class=\"footer__t__st__ls__hd\"><a href=\"culture.html\"><span class=\"c-navText\"><span class=\"__en\">CULTURE</span><span class=\"__ja\">文化を知る</span></span></a></div>\r\n                  <div class=\"footer__t__st__ls__bd\">\r\n                    <ul class=\"footer__t__st__ls__bd__ls\">\r\n                      <li><a href=\"culture.html\"><span>企業文化</span></a></li>\r\n                      <li><a href=\"illword.html\"><span>アイル語</span></a></li>\r\n                    </ul>\r\n                  </div>\r\n                </li>\r\n              </ul>\r\n            </div>\r\n            <div class=\"footer__t__st\">\r\n              <ul class=\"footer__t__st__ls\">\r\n                <li>\r\n                  <div class=\"footer__t__st__ls__hd\"><a href=\"business.html\"><span class=\"c-navText\"><span class=\"__en\">BUSINESS</span><span class=\"__ja\">仕事を知る</span></span></a></div>\r\n                  <div class=\"footer__t__st__ls__bd\">\r\n                    <ul class=\"footer__t__st__ls__bd__ls\">\r\n                      <li><a href=\"business.html\"><span>ビジネスモデル</span></a></li>\r\n                      <li><a href=\"job.html\"><span>職種紹介</span></a></li>\r\n                    </ul>\r\n                  </div>\r\n                </li>\r\n              </ul>\r\n            </div>\r\n            <div class=\"footer__t__st\">\r\n              <ul class=\"footer__t__st__ls\">\r\n                <li>\r\n                  <div class=\"footer__t__st__ls__hd\"><a href=\"member.html\"><span class=\"c-navText\"><span class=\"__en\">MEMBER</span><span class=\"__ja\">人を知る</span></span></a></div>\r\n                  <div class=\"footer__t__st__ls__bd\">\r\n                    <ul class=\"footer__t__st__ls__bd__ls\">\r\n                      <li><a href=\"member.html\"><span>社員紹介</span></a></li>\r\n                      <li><a href=\"interview/index.html\"><span>若手社員の声</span></a></li>\r\n                    </ul>\r\n                  </div>\r\n                </li>\r\n              </ul>\r\n            </div>\r\n            <div class=\"footer__t__st\">\r\n              <ul class=\"footer__t__st__ls\">\r\n                <li>\r\n                  <div class=\"footer__t__st__ls__hd\"><a href=\"requirements.html\"><span class=\"c-navText\"><span class=\"__en\">RECRUIT</span><span class=\"__ja\">採用情報</span></span></a></div>\r\n                  <div class=\"footer__t__st__ls__bd\">\r\n                    <ul class=\"footer__t__st__ls__bd__ls\">\r\n                      <li><a href=\"requirements.html\"><span>募集要項</span></a></li>\r\n                      <li><a href=\"education.html\"><span>教育・評価制度</span></a></li>\r\n                      <li><a href=\"welfare.html\"><span>福利厚生</span></a></li>\r\n                      <li><a href=\"faq.html\"><span>採用FAQ</span></a></li>\r\n                    </ul>\r\n                  </div>\r\n                </li>\r\n              </ul>\r\n            </div>\r\n            <div class=\"footer__t__st\">\r\n              <ul class=\"footer__t__st__ls\">\r\n                <li>\r\n                  <div class=\"footer__t__st__ls__hd\"><a href=\"company.html\"><span class=\"c-navText\"><span class=\"__en\">COMPANY</span><span class=\"__ja\">会社概要</span></span></a></div>\r\n                </li>\r\n              </ul>\r\n            </div>\r\n            <div class=\"footer__t__st\">\r\n              <ul class=\"footer__t__st__ls\">\r\n                <li>\r\n                  <div class=\"footer__t__st__ls__hd\"><a href=\"https://www.ill.co.jp/recruit/entry_select.html\"><span class=\"c-navText\"><span class=\"__en\">ENTRY</span><span class=\"__ja\">エントリー</span></span></a></div>\r\n                </li>\r\n              </ul>\r\n            </div>\r\n          </nav>\r\n          <a href=\"https://www.ill.co.jp/\" class=\"page-link\"><img src=\"images/corporate.png\" alt=\"株式会社アイルコーポレートサイト\"></a>\r\n\t\t\t          <a href=\"https://www.ill.co.jp/recruit/internship/\" class=\"page-link\"><img src=\"images/intern.png\" alt=\"株式会社アイルインターン情報サイト\"></a>\r\n\t\t  </div>\r\n      </div>\r\n    </nav>\r\n    <div class=\"g-nav-bg\"></div>\r\n  </div>\r\n  <!--スマホヘッダー終了--> \r\n</header>\r\n<section class=\"top\">\r\n  <button class=\"entry_btn\">\r\n  <div class=\"entry_btn_in\">\r\n  <span class=\"h__en\"><a href=\"\" class=\"in-the-page\">ENTRY</a></span><span class=\"subtitle\">エントリー</span>\r\n  </div>\r\n  </button>\r\n</section>\r\n<div id=\"business\">\r\n\t<section class=\"key_visual bg__gradation\">\r\n\t\t<div class=\"page_title bg_in\">\r\n\t\t\t<div class=\"title_area\">\r\n\t\t\t\t<span class=\"subtitle__en\">BUSINESS</span>\r\n\t\t\t\t<span class=\"subtitle\">仕事を知る</span>\r\n\t\t\t</div>\r\n\t\t\t<h2>ビジネスモデル</h2>\r\n\t\t</div>\r\n\t</section>\r\n  <section class=\"co main main_top bg__w\">\r\n\t\t<div class=\"main_cont\">\r\n\t\t\t<h3 class=\"cont_title\"><span class=\"h__en\">CROSS-OVER</span>CROSS-OVER戦略</h3>\r\n      <p>現在の市場では、特定の「顧客ニーズ」を中心に様々な商品が緊密に結びついています。<br>その結果、様々な商品が集まって一種の「生態系」を形成しており、これを「商品生態系」といいます。<br>アイルの「CROSS-OVER」戦略は、一つひとつの独立した「事業」がそれぞれに有機的に結合し効力をもつことで<br class=\"no_sp\">強力な「相乗効果を発揮する」ことを狙ったものです。</p>\r\n\t\t</div>\r\n    <div class=\"synergy overlap\">\r\n      <div class=\"main_cont\">\r\n        <div class=\"round_cont bg__b\">\r\n          <h4>「<span>Real</span>」と「<span>Web</span>」の相乗効果</h4>\r\n          <p>アイルでは現実空間における経営資産管理や実店舗、訪問営業など対面型でのオフライン販売などの「Real」領域ビジネスと、BtoB・BtoCにおけるECチャネルやモバイルアプリ、クラウドインフラなどの「Web」領域ビジネスを切り分けることなく、「Real」と「Web」が掛け合わさることで相乗効果を生み出し、DXによる企業のビジネス変革を支援しています。</p>\r\n        </div>\r\n        <div class=\"co_img\">\r\n          <img src=\"images/business/co_img.png\" alt=\"アイルのCROSS-OVER戦略\">\r\n        </div>\r\n      </div>\r\n      <div class=\"left_outside\">\r\n        <img src=\"images/business/business_bg1.png\" alt=\"アイルのCROSS-OVER戦略\">\r\n      </div>\r\n    </div>\r\n    <div class=\"co_txt main_cont\">\r\n      <h4 class=\"box_title box_title_c\">市場を創造する</h4>\r\n      <p>急速に進化する市場においては、現在のルールに基づいた戦略を考えるよりも、<br class=\"no_sp\">むしろ積極的にルールそのものを書き換える方が優れた戦略だといえます。</p>\r\n      <p>要するに<span>新しいビジネスモデルを開発</span>していくのです。<br class=\"no_sp\">未来を予測するのではなく、「これから市場をこのようにしていこう！」、<br class=\"no_sp\">「市場のルールを作ってしまおう！」という明確なビジョンを描き、<br class=\"no_sp\"> 積極的に市場を創造するための戦略を展開しています。</p>\r\n      <p>この<span>「CROSS-OVER」を基本戦略</span>とし、<br class=\"no_sp\">「Real」と「Web」の両面から商品サービスを開発・提案し、<br class=\"no_sp\">顧客の企業力強化を高めることがアイルのビジネスモデルです。</p>\r\n    </div>\r\n\t</section>\r\n\t<section class=\"main bg__b cont_bottom o_hidden\">\r\n\t\t<div class=\"main_cont\">\r\n      <h3 class=\"cont_title\"><span class=\"h__en\">MAIN BUSINESS</span>アイルの主な事業</h3>\r\n    </div>\r\n    <article class=\"s_solution cont__white\">\r\n      <p class=\"midashi\">システムソリューション</p>\r\n      <div class=\"column3\">\r\n        <div class=\"col bold_cont\">\r\n          <img src=\"images/business/icon01.png\" alt=\"システムソリューションサービス\">\r\n          <h4 class=\"box_title box_title_c\">システムソリューションサービス</h4>\r\n          <p class=\"text\">基幹業務システム「アラジンオフィス」の開発から販売・運用・保守 までトータルで行っています。システムをただ販売するのではなく、導入前の業務分析から導入後の保守までアイル1社で全て行います。「アラジンオフィス」を核に、他のサービスも含めて複合的に提供することで、お客様の企業経営力アップを支援しています。</p>\r\n          <div class=\"job_list\">\r\n            <ul>\r\n              <li><a href=\"#con1\" class=\"modal-open modalLink\">ITソリューション営業</a></li>\r\n              <li><a href=\"#con2\" class=\"modal-open modalLink\">パートナー営業</a></li>\r\n              <li><a href=\"#con3\" class=\"modal-open modalLink\">システムエンジニア</a></li>\r\n              <li><a href=\"#con4\" class=\"modal-open modalLink\">カスタマーサポート</a></li>\r\n              <li><a href=\"#con5\" class=\"modal-open modalLink\">ネットワークエンジニア</a></li>\r\n              <li><a href=\"#con6\" class=\"modal-open modalLink\">プログラマー・製品開発</a></li>\r\n            </ul>\r\n          </div>\r\n        </div>\r\n        <div class=\"col bold_cont\">\r\n          <img src=\"images/business/icon02.png\" alt=\"ネットワークシステム構築及びテクニカルサポートサービス\">\r\n          <h4 class=\"box_title box_title_c\">ネットワークシステム構築及びテクニカルサポートサービス</h4>\r\n          <p class=\"text\">ネットワーク設計・構築、サーバー設計・構築・インターネット環境構築など、企業のITインフラを支援する事業です。</p>\r\n          <div class=\"job_list\">\r\n            <ul>\r\n              <li><a href=\"#con3\" class=\"modal-open modalLink\">システムエンジニア</a></li>\r\n              <li><a href=\"#con5\" class=\"modal-open modalLink\">ネットワークエンジニア</a></li>\r\n            </ul>\r\n          </div>\r\n        </div>\r\n        <div class=\"col bold_cont\">\r\n          <img src=\"images/business/icon03.png\" alt=\"セキュリティ対策、セキュリティ診断サポートサービス\">\r\n          <h4 class=\"box_title box_title_c\">セキュリティ対策、セキュリティ診断サポートサービス</h4>\r\n          <p class=\"text\">セキュリティツール支援、セキュリティポリシー策定、情報漏洩対策、コンプライアンス管理など、現在注目が高まるセキュリティ強化を実現する事業です。</p>\r\n          <div class=\"job_list\">\r\n            <ul>\r\n              <li><a href=\"#con3\" class=\"modal-open modalLink\">システムエンジニア</a></li>\r\n              <li><a href=\"#con5\" class=\"modal-open modalLink\">ネットワークエンジニア</a></li>\r\n            </ul>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </article>\r\n    \r\n    <article class=\"w_solution cont__white\">\r\n      <p class=\"midashi\">WEBソリューション</p>\r\n      <div class=\"column3\">\r\n        <div class=\"col bold_cont\">\r\n          <img src=\"images/business/icon04.png\" alt=\"EC・ネットショップ支援サービス\">\r\n          <h4 class=\"box_title box_title_c mini\">EC・ネットショップ支援サービス</h4>\r\n          <p class=\"text\">複数ネットショップの一括管理ができるASPサービス「CROSS MALL（クロスモール）」や、ECサイト/ネットショップと実店舗のポイントを一元管理できる「CROSS POINT（クロスポイント）」等のWEB商材の開発・運用も行っています。</p>\r\n          <div class=\"job_list\">\r\n            <ul>\r\n              <li><a href=\"#con7\" class=\"modal-open modalLink\">カスタマーサクセス</a></li>\r\n              <li><a href=\"#con8\" class=\"modal-open modalLink\">WEBシステム開発</a></li>\r\n            </ul>\r\n          </div>\r\n        </div>\r\n        <div class=\"col bold_cont\">\r\n          <img src=\"images/business/icon05.png\" alt=\"WEBシステムサービス\">\r\n          <h4 class=\"box_title box_title_c\">WEBシステムサービス</h4>\r\n          <p class=\"text\">WEBサイトの設計・構築を軸とし、プログラミング・システム開発など統合的なWEBソリューションを行います。企業間取引サイト（「WEB受発注システム」「卸売サイト」「営業支援システム」）や消費者向けECサイトの構築などを行っています。</p>\r\n          <div class=\"job_list\">\r\n            <ul>\r\n              <li><a href=\"#con8\" class=\"modal-open modalLink\">WEBシステム開発</a></li>\r\n              <li><a href=\"#con9\" class=\"modal-open modalLink\">WEBディレクター・デザイナー</a></li>\r\n            </ul>\r\n          </div>\r\n        </div>\r\n        <div class=\"col bold_cont\">\r\n          <img src=\"images/business/icon06.png\" alt=\"WEBマーケティングサービス\">\r\n          <h4 class=\"box_title box_title_c\">WEBマーケティングサービス</h4>\r\n          <p class=\"text\">WEBサイトの分析、WEB広告戦略支援、WEBマーケティング戦略支援など、WEBを切り口に新たな経営戦略を立案するコンサルティングサービスです。</p>\r\n          <div class=\"job_list\">\r\n            <ul>\r\n              <li><a href=\"#con9\" class=\"modal-open modalLink\">WEBディレクター・デザイナー</a></li>\r\n            </ul>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </article>\r\n\t\t<div class=\"main_cont\">\r\n\t\t\t<div class=\"business_movie\">\r\n\t\t\t\t<h3 class=\"cont_title\"><span class=\"h__en\">MOVIE</span>事業内容＆副社長インタビュー</h3>\r\n\t\t\t\t<iframe src=\"https://www.youtube.com/embed/-8_gYy79DN0?si=iLbo5TaBxTu9e-F-\" title=\"YouTube video player\" frameborder=\"0\" allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share\" referrerpolicy=\"strict-origin-when-cross-origin\" allowfullscreen></iframe>\r\n          </div>\r\n\t\t\t</div>\r\n    \r\n    <article class=\"left_outside__white\">\r\n      <div class=\"main_cont\">\r\n        <h3 class=\"cont_title\"><span class=\"h__en\">ADVANTAGE</span>独立系企業としての優位性</h3>\r\n        <div class=\"column2\">\r\n          <div class=\"col\">\r\n            <p>創業よりアイルは親会社を持たない、資本的に独立した独立系企業です。</p>\r\n            <p>企業系列に属することがないため、特定のメーカーやプラットフォームに限定されることなく、お客様にとって最適な技術・製品・サービスを開発、提供することができます。</p>\r\n            <p>刻々と変化するITの分野において、常に最新のソリューションサービスが求められるため、様々な分野のビジネスパートナーと連携し、自由な発想で新しいビジネスモデルを展開しています。</p>\r\n          </div>\r\n          <div class=\"col\">\r\n            <img src=\"images/business/superiority.png\" alt=\"独立系企業としての優位性\">\r\n            <p class=\"caption\">ソフトウェア企業の分類</p>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </article>\r\n    \r\n    <article class=\"right_outside__white\">\r\n      <div class=\"main_cont\">\r\n        <h3 class=\"cont_title\"><span class=\"h__en\">REVENUE</span>高い自社製品比率による安定収益</h3>\r\n        <div class=\"column2\">\r\n          <div class=\"col\">\r\n            <p>アイルでは、価格変動に左右されやすいハードウェア等の他社製品に依存しない収益構造を経営方針の重要事項と考えてきました。</p><p>利益における「自社製品・サービス比率」は「約80％」です。</p><p>アイルの収益の大部分は、自社開発の製品やサービス（ソフトウェア・運用・保守・会費等）で構成されており、安定した収益構造を確立しています。</p>\r\n          </div>\r\n          <div class=\"col\">\r\n            <div class=\"pie-chart-1\">約<span>80</span>％</div>\r\n            <p class=\"caption\">自社製品・サービス比率</p>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </article>\r\n    \r\n    <article class=\"left_outside__white\">\r\n      <div class=\"main_cont\">\r\n        <h3 class=\"cont_title\"><span class=\"h__en\">CUSTOMER IMPRESSION</span>数字が語る顧客感動度</h3>\r\n        <div class=\"column2\">\r\n          <div class=\"col\">\r\n            <p>アイルのシステムやWEBサービスを導入していただいていて、入れ替えの際に、他社のシステムではなくアイルのシステムを再度選んでいただく「リピート率」は「98.6％」（2025年7月末現在）です。</p><p>サービスを導入して終わりではなく、成果がでるまでしっかりとサポートを行っているからこその数字。この数字がアイルの強さの証です。</p>\r\n          </div>\r\n          <div class=\"col\">\r\n            <div class=\"pie-chart-2\">約<span>98</span>.6％</div>\r\n            <p class=\"caption\">ユーザーリピート率</p>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </article>\r\n    \r\n\t</section>\r\n  \r\n  <section id=\"con1\" class=\"modal-content\">\r\n    <div class=\"job\">\r\n      <h5>ITソリューション営業</h5>\r\n      <p>基幹業務システムの企画・提案営業を行います。基幹業務システムとは、どの企業でも必ず管理している「モノ」と「お金」を管理するシステムです。新人の内は経験として飛び込みや電話営業も行っています。お客様の困ったの声に耳を傾けて、最適な提案をし、ITの力を駆使して企業をコンサルティングするお仕事です。お客様との最初の接点であり、直接的に会社の受注を生み出す職種のため、よく花形の職種と言われています。数多くのお客様と関わることが出来ます。</p>\r\n      <p class=\"member_list\">先輩社員の1日を見る</p>\r\n      <ul>\r\n        <li><a href=\"member_01.html\"><img src=\"images/member/member01_04.png\" alt=\"ITソリューション営業の１日を見る\"></a></li>\r\n        <li><a href=\"member_02.html\"><img src=\"images/member/member02_04.jpg\" alt=\"ITソリューション営業の１日を見る\"></a></li>\r\n        <li><a href=\"member_03.html\"><img src=\"images/member/member03_04.jpg\" alt=\"ITソリューション営業の１日を見る\"></a></li>\r\n      </ul>\r\n    </div>\r\n  </section>\r\n  <section id=\"con2\" class=\"modal-content\">\r\n    <div class=\"job\">\r\n        <h5>パートナー営業</h5>\r\n        <p>主にパートナー企業（金融機関、コンサルタント、OA販社、SIer等）に訪問し、自社製品である「アラジンオフィス」「アラジンEC」「CROSSシリーズ」などの紹介や営業支援を行います。パートナー企業と取引のあるお客様のご紹介をいただき、「ITソリューション営業」へのトスアップを行います。また、ウェビナーや展示会等の販促用施策の企画・運営も行います。「ITソリューション営業」は直接販売ですが、「パートナー営業」は主に支援を目的とした間接販売になります。</p>\r\n      </div>\r\n  </section>\r\n  <section id=\"con3\" class=\"modal-content\">\r\n    <div class=\"job\">\r\n      <h5>システムエンジニア</h5>\r\n      <p>お客様に提供する基幹業務システムの設計、運用、保守などを行います。お客様と直接打合せをして業務内容をより詳しくヒアリングし、システムのパッケージソフトにどのようなカスタマイズを加えたらお客様の業務効率化のお手伝いが出来るかを考え、お客様専用のシステムを構築するための設計書を作成します。そのため、専門知識よりもコミュニケーション能力が大切な職種になります。またシステム完成後に使い方を説明したり、使用中に不明点やトラブルが起きた際に助けてあげることもお仕事のひとつです。担当したお客様と長く深く関わることが出来ます。</p>\r\n      <p class=\"member_list\">先輩社員の1日を見る</p>\r\n      <ul>\r\n        <li><a href=\"member_04.html\"><img src=\"images/member/member04_04.jpg\" alt=\"システムエンジニアの１日を見る\"></a></li>\r\n        <li><a href=\"member_05.html\"><img src=\"images/member/member05_04.jpg\" alt=\"システムエンジニアの１日を見る\"></a></li>\r\n        <li><a href=\"member_09.html\"><img src=\"images/member/member09_04.jpg\" alt=\"システムエンジニアの１日を見る\"></a></li>\r\n        <li><a href=\"member_12.html\"><img src=\"images/member/member12_04.jpg\" alt=\"システムエンジニアの１日を見る\"></a></li>\r\n      </ul>\r\n    </div>\r\n  </section>\r\n  <section id=\"con4\" class=\"modal-content\">\r\n    <div class=\"job\">\r\n      <h5>カスタマーサポート</h5>\r\n      <p>自社製品である基幹業務システムを導入していただいたお客様へ、電話を通してシステムの操作指導・問題解決などのサポートを行います。企業にとって重要な業務システムを止めないことを使命とし、スピード感もって状況把握に努め、最良の回答を導き出します。時には、社内外関係者との調整を行いながら円滑にお客様対応をしていく為、高いコミュニケーション能力が求められます。継続したスキルアップの必要性も高く、自部署内に留まらず、社内の教育ツールの拡充にも力を注いでいます。</p>\r\n      <p class=\"member_list\">先輩社員の1日を見る</p>\r\n      <ul>\r\n        <li><a href=\"member_13.html\"><img src=\"images/member/member13_04.jpg\" alt=\"カスタマーサポートの１日を見る\"></a></li>\r\n      </ul>\r\n    </div>\r\n  </section>\r\n  <section id=\"con5\" class=\"modal-content\">\r\n    <div class=\"job\">\r\n      <h5>ネットワークエンジニア</h5>\r\n      <p>基幹業務システムを使用するための、ネットワークやサーバーの設計、構築、保守管理を行います。またエンジニアの立場からセールスサポートも行います。お客様のデジタル化を促進するために「クラウド化」「セキュリティ対策」「テレワーク支援」「災害対策」などを行い、幅広い知識を習得することができます。安全かつ適切なインフラを提供することでトラブルを未然に防ぎ、障害発生時は問題点を的確に捉えて、お客様の立場に立って保守対応を行います。お客様に安定と安心を届ける重要なお仕事です。</p>\r\n      <p class=\"member_list\">先輩社員の1日を見る</p>\r\n      <ul>\r\n        <li><a href=\"member_08.html\"><img src=\"images/member/member08_04.jpg\" alt=\"ネットワークエンジニアの１日を見る\"></a></li>\r\n      </ul>\r\n    </div>\r\n  </section>\r\n  <section id=\"con6\" class=\"modal-content\">\r\n    <div class=\"job\">\r\n      <h5>プログラマー・製品開発</h5>\r\n      <p>システムを構築するためのプログラミングや、パッケージソフトの開発を行います。システムエンジニアが作成した設計書を基に、プログラミング言語を用いて実際にシステムを構築します。思い描いているシステムを自分の手で現物化することのできる職種になります。また、様々なお客様から多くのご要望をいただくので、そのお声を基に、パッケージソフトをよりフィット感のあるモノへと改修し、より専門性の高いパッケージソフトへとアップデートさせたりしています。常駐は一切なく、全て自社でプログラミング・開発を行なっています。</p>\r\n      <p class=\"member_list\">先輩社員の1日を見る</p>\r\n      <ul>\r\n        <li><a href=\"member_07.html\"><img src=\"images/member/member07_04.jpg\" alt=\"プログラマーの１日を見る\"></a></li>\r\n      </ul>\r\n    </div>\r\n  </section>\r\n  <section id=\"con7\" class=\"modal-content\">\r\n    <div class=\"job\">\r\n      <h5>カスタマーサクセス</h5>\r\n      <p>自社開発のWEBサービス（サブスク、クラウド）を利用したお客様の業務の改善提案から、利用開始までの支援、運用中のフォローなどを行います。例えば自社製品のCROSSMALL（クロスモール）ではネットショップ運営で必要な商品の登録や、出荷業務を効率化する機能を提供しており、どのようにサービスを利用すれば効率的になるか相談に乗りながら、サポートを行います。お客様からの機能改善要望などもヒアリングし、機能開発チームへ共有して、より良いサービスへ成長させるための窓口の役割も果たします。</p>\r\n      <p class=\"member_list\">先輩社員の1日を見る</p>\r\n      <ul>\r\n        <li><a href=\"member_14.html\"><img src=\"images/member/member14_04.jpg\" alt=\"カスタマーサクセスの１日を見る\"></a></li>\r\n      </ul>\r\n    </div>\r\n  </section>\r\n  <section id=\"con8\" class=\"modal-content\">\r\n    <div class=\"job\">\r\n      <h5>WEBシステム開発</h5>\r\n      <p>自社開発のクラウドサービス「CROSSMALL」「CROSSPOINT」等の機能開発及び強化、加えて、これらに続くアイルの次世代製品のクラウドサービス開発を行っています。アイルの頭脳集団として、知識や技術の習得しながら、システムの利用者やニーズをイメージして開発を行います。また、サービスを通してお客様の利益・喜びを支援できる仕事です。</p>\r\n    </div>\r\n  </section>\r\n  <section id=\"con9\" class=\"modal-content\">\r\n    <div class=\"job\">\r\n      <h5>WEBディレクター・デザイナー</h5>\r\n      <p>お客様のコーポレートサイトやネットショップ（ECサイト）の構築・運用を行います。ディレクターは全体のプロジェクト管理、コンセプトや課題解決の企画提案、スケジュール管理などを行います。デザイナーはターゲットや目的に合わせた最適なデザイン作成、WEBサイト構築を行います。デザインやユーザーインターフェース（UI）を自身で作りながら、お客様とプロジェクトを推進するクリエイティブディレクターという役割もあります。「WEB」という枠にとどまらず、お客様のブランド構築支援や紙媒体などの課題解決を行うこともあります。</p>\r\n      <p class=\"member_list\">先輩社員の1日を見る</p>\r\n      <ul>\r\n        <li><a href=\"member_11.html\"><img src=\"images/member/member11_04.jpg\" alt=\"Webディレクターの１日を見る\"></a></li>\r\n        <li><a href=\"member_10.html\"><img src=\"images/member/member10_04.jpg\" alt=\"Webデザイナーの１日を見る\"></a></li>\r\n      </ul>\r\n    </div>\r\n  </section>\r\n</div>\r\n<section class=\"cv\">\r\n    <div class=\"cv_bg\">\r\n      <div class=\"cv_bg_in\">\r\n        <h3>あなたも一緒に、思い切りバットを振っていこう。</h3>\r\n        <div class=\"cv_in_box\">\r\n          <div class=\"cv_in\">\r\n            <p class=\"cv_e_p\">新卒採用</p>\r\n            <a href=\"https://ill-recruit.snar.jp/index.aspx\" class=\"cv_btn\">\r\n            <div class=\"cv_box\">\r\n              <div class=\"cv_btn_in\"> <span class=\"h__en\">ENTRY</span><span class=\"subtitle\">新卒採用</span></div>\r\n              <p>新卒採用向け<br>\r\n                エントリーはこちら</p>\r\n              <span class=\"cv_arrow\"></span> </div>\r\n            </a> </div>\r\n          <div class=\"cv_in\">\r\n            <p class=\"cv_c_p\">キャリア採用</p>\r\n            <a href=\"entry_career.html\" class=\"cv_btn btn_gr\">\r\n            <div class=\"cv_box\">\r\n              <div class=\"cv_btn_in\"> <span class=\"h__en\">CAREER</span><span class=\"subtitle\">キャリア採用</span></div>\r\n              <p>キャリア採用向け<br>\r\n                募集要項はこちら</p>\r\n              <span class=\"cv_arrow\"></span> </div>\r\n            </a> </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </section>\r\n<footer class=\"footer\">\r\n  <div class=\"footer_all\"> <a href=\"#\" class=\"page-top\"><img src=\"images/airu_small.png\" alt=\"PAGE TOP\">PAGE TOP</a>\r\n    <div class=\"footer__t\">\r\n      <nav class=\"footer__t__in\">\r\n        <div class=\"footer__t__st\">\r\n          <ul class=\"footer__t__st__ls\">\r\n            <li>\r\n              <div class=\"footer__t__st__ls__hd\"><a href=\"message.html\"><span class=\"c-navText\"><span class=\"__en\">MESSAGE</span><span class=\"__ja\">アイルの想い</span></span></a></div>\r\n              <div class=\"footer__t__st__ls__bd\">\r\n                <ul class=\"footer__t__st__ls__bd__ls\">\r\n                  <li><a href=\"message.html#message_or\"><span>アイルの役割</span></a></li>\r\n                  <li><a href=\"message.html#message_cp\"><span>企業ポリシー</span></a></li>\r\n                  <li><a href=\"message.html#message_ic\"><span>求める人物像</span></a></li>\r\n                </ul>\r\n              </div>\r\n            </li>\r\n          </ul>\r\n        </div>\r\n        <div class=\"footer__t__st\">\r\n          <ul class=\"footer__t__st__ls\">\r\n            <li>\r\n              <div class=\"footer__t__st__ls__hd\"><a href=\"culture.html\"><span class=\"c-navText\"><span class=\"__en\">CULTURE</span><span class=\"__ja\">文化を知る</span></span></a></div>\r\n              <div class=\"footer__t__st__ls__bd\">\r\n                <ul class=\"footer__t__st__ls__bd__ls\">\r\n                  <li><a href=\"culture.html\"><span>企業文化</span></a></li>\r\n                  <li><a href=\"illword.html\"><span>アイル語</span></a></li>\r\n                </ul>\r\n              </div>\r\n            </li>\r\n          </ul>\r\n        </div>\r\n        <div class=\"footer__t__st\">\r\n      