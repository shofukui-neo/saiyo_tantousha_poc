/tr>\n                <tr>\n                  <th>初任給</th>\n                  <td>\n                    【大卒】 225,500円<br />\n                    【大学院卒】 230,900円<br />\n                    ※業務手当は、所定外手当を含みます</td>\n                </tr>\n                <tr>\n                  <th>昇給</th>\n                  <td>年1回（1月）</td>\n                </tr>\n                <tr>\n                  <th>賞与</th>\n                  <td>年2回（7月、12月）</td>\n                </tr>\n                <tr>\n                  <th>手当</th>\n                  <td>通勤手当、家族手当等</td>\n                </tr>\n                <tr>\n                  <th>勤務地</th>\n                  <td><p>本社工場・事務所：愛知県名古屋市南区豊4-26-3<br />\n                  中部PDセンター：愛知県犬山市七ツ屋51-3<br />\n                  （営業・各拠点）<br />\n                  札幌、埼玉、名古屋、大阪、広島、福岡</p></td>\n                </tr>\n                <tr>\n                  <th>勤務時間</th>\n                  <td>8:50～18:00（休憩70分）</td>\n                </tr>\n                <tr>\n                  <th>休日</th>\n                  <td>完全週休二日制、年末年始・夏季休暇　他（年間120日）</td>\n                </tr>\n                <tr>\n                  <th>有給休暇</th>\n                  <td>労働基準法による</td>\n                </tr>\n                <tr>\n                  <th>福利厚生</th>\n                  <td>社会保険（健康、雇用、厚生、労災）、退職金制度、社員旅行、各種親睦会</td>\n                </tr>\n                <tr>\n                  <th>選考場所</th>\n                  <td>三貴ホールディングス株式会社</td>\n                </tr>\n                <tr>\n                  <th>選考方法</th>\n                  <td>面接、適正検査、書類選考</td>\n                </tr>\n                <tr>\n                  <th>問い合わせ先</th>\n                  <td>株式会社ミキ<br />\n                    Tel：052-694-1200<br />\n<a href=\"&#109;&#97;&#105;&#108;&#116;&#111;&#58;&#104;&#114;&#100;&#101;&#112;&#116;&#64;&#107;&#117;&#114;&#117;&#109;&#97;&#105;&#115;&#117;&#45;&#109;&#105;&#107;&#105;&#46;&#99;&#111;&#46;&#106;&#112;\">&#104;&#114;&#100;&#101;&#112;&#116;&#64;&#107;&#117;&#114;&#117;&#109;&#97;&#105;&#115;&#117;&#45;&#109;&#105;&#107;&#105;&#46;&#99;&#111;&#46;&#106;&#112;</a></td>\n                </tr>\n              </table>\n              <!-- <h4>会社説明会</h4>\n              <p>7/27（水）14：00～16：30<br />\n              名古屋港湾会館　第2会議室（名古屋市港区港町1-11）<br />\n              <br />\n              </p>\n              <h4>合同説明会</h4>\n              <p>\n                7/12・13（火・水）10：00〜17：00<br />\n                吹上ホール　第1ファッション展示場 名古屋市千種区吹上二丁目6番3号<br />\n              <a href=\"http://www.jobway.jp/member/index.php?c_func=memcompanyview&amp;c_open=1&amp;c_id=13654&amp;c_popup=1\" target=\"_blank\">詳しくはこちらのWebサイトをご参照ください。</a>説明会・エントリーに関しては、<a href=\"https://job.mynavi.jp/19/pc/search/corp214700/outline.html\" target=\"_blank\">マイナビ2019</a>をご参照ください。<br />\n              </p>\n              <p>\n              <a href=\"https://job.mynavi.jp/19/pc/search/corp214700/outline.html\" target=\"_blank\">\n<img src=\"image/19logo_l.gif\" alt=\"マイナビ2019\" style=\"margin: 8px 0; border: 1px solid #999;\">\n</a>\n\t\t\t\t</p> -->\n\n\t\t\t</div>\n\t\t<!--\t<div class=\"section\">\n\t\t\t  <h3><span>新卒採用</span></h3>\n              <table>\n                <tr>\n                  <th style=\"width:150px;\">募集職種</th>\n                  <td>生産管理、品質保証、設計開発、生産技術</td>\n                </tr>\n                <tr>\n                  <th>応募資格</th>\n                  <td>2014年 大学・大学院卒業見込みの方</td>\n                </tr>\n                <tr>\n                  <th>採用学科</th>\n                  <td>工学系学科優先</td>\n                </tr>\n                <tr>\n                  <th>応募書類</th>\n                  <td><p>履歴書（写真付）、成績証明書、卒業見込証明書、健康診断書</p></td>\n                </tr>\n                <tr>\n                  <th>初任給</th>\n                  <td>200,000円</td>\n                </tr>\n                <tr>\n                  <th>昇給</th>\n                  <td>年1回</td>\n                </tr>\n                <tr>\n                  <th>賞与</th>\n                  <td>年2回</td>\n 