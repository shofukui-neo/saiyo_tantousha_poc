{"url":"https://www.khknoda.co.jp/","html":"<!doctype html>\n<html lang=\"ja\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1, maximum-scale=1\">\n<meta name=\"format-detection\" content=\"telephone=no\">\n<title>株式会社KHK野田　KHK標準歯車の製造工場</title>\n<meta name=\"Description\" content=\"歯車メーカー小原歯車工業のウェブサイト。KHK標準歯車からオーダー歯車までの豊富な製品案内と歯車ガイドを掲載。歯車計算ができるウェブカタログもあり。\">\n<meta name=\"Keywords\" content=\"小原 歯車,設計,強度,計算,加工,標準,製図,精度,KHK\">\t\n<link href=\"https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@100;300;400;500;700;900&family=Source+Sans+Pro:wght@200;300;400;600;700;900&display=swap\" rel=\"stylesheet\">\n<link href=\"https://fonts.googleapis.com/css2?family=Source+Sans+Pro:wght@400;600;700;900&display=swap\" rel=\"stylesheet\">\n\t\n<link rel=\"stylesheet\" type=\"text/css\" href=\"./js/slick/slick.css\" media=\"all\">\n\t\n<link rel=\"stylesheet\" type=\"text/css\" href=\"./css/common.css\" media=\"all\">\n<link rel=\"stylesheet\" type=\"text/css\" href=\"./css/index.css\" media=\"all\">\n\t\n<!-- Global site tag (gtag.js) - Google Analytics -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-3Y5PQ64CQG\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'G-3Y5PQ64CQG');\n</script>\n\n</head>\n<body>\n<div id=\"wrap\">\n\t<header id=\"header\">\n\t\t<div class=\"headWrap\">\n\t\t\t<h1 class=\"hdLogo\"><a href=\"./\"><img src=\"./image/common/hd_logo.svg\" alt=\"KHK STOCK GEARS\"></a></h1>\n\t\t\t\n\t\t\t<ul class=\"hdNav\">\n\t\t\t\t<li><a href=\"#vol01\">事業内容・製品</a></li>\n\t\t\t\t<li><a href=\"#vol02\">環境制度</a></li>\n\t\t\t\t<li><a href=\"#vol03\">レクリエーション施設</a></li>\n\t\t\t\t<li><a href=\"#vol04\">福利厚生</a></li>\n\t\t\t\t<li><a href=\"#vol05\">募集要項</a></li>\n\t\t\t\t<li><a href=\"#vol06\">会社概要</a></li>\n\t\t\t</ul>\n\t\t\t\n\t\t\t<a href=\"mailto:&#107;&#104;&#107;&#110;&#111;&#100;&#97;&#45;&#106;&#105;&#110;&#106;&#105;&#64;&#107;&#104;&#107;&#103;&#101;&#97;&#114;&#115;&#46;&#99;&#111;&#46;&#106;&#112;\" class=\"hdContact\">電話・メールで<br>お問い合わせください。</a>\n\t\t\t\n\t\t\t<div class=\"navbtn\">\n\t\t\t\t<div>\n\t\t\t\t\t<span></span>\n\t\t\t\t\t<span></span>\n\t\t\t\t\t<span></span>\n\t\t\t\t\t\n\t\t\t\t</div>\n\t\t\t\t<p class=\"mName\">MENU</p>\n\t\t\t<!-- navbtn -->\n\t\t\t</div>\n\t\t<!-- headWrap -->\n\t\t</div>\n\t\t<nav id=\"global-nav\">\n    \t<ul class=\"smpNav\">\n\t\t\t\t<li><a href=\"#vol01\">事業内容・製品</a></li>\n\t\t\t\t<li><a href=\"#vol02\">環境制度</a></li>\n\t\t\t\t<li><a href=\"#vol03\">レクリエーション施設</a></li>\n\t\t\t\t<li><a href=\"#vol04\">福利厚生</a></li>\n\t\t\t\t<li><a href=\"#vol05\">募集要項</a></li>\n\t\t\t\t<li><a href=\"#vol06\">会社概要</a></li>\n\t\t\t\t<li><a href=\"mailto:&#107;&#104;&#107;&#110;&#111;&#100;&#97;&#45;&#106;&#105;&#110;&#106;&#105;&#64;&#107;&#104;&#107;&#103;&#101;&#97;&#114;&#115;&#46;&#99;&#111;&#46;&#106;&#112;\" class=\"contLink\">電話・メールでお問い合わせください。</a></li>\n\t\t\t</ul>\n\t\t</nav>\t\n\t<!-- header -->\n\t</header>\n\t\n\t<div id=\"mainVisual\">\n\t\t<div class=\"relaWrap\">\n\t\t<figure class=\"mainImg\"><img src=\"./image/index/main_bg_pc.jpg\" alt=\"ものづくりの原点未来もここから始まる\" class=\"js-image-switch\"></figure>\n\t\t<div class=\"intoWrap\">\n\t\t\t\t<dl>\n\t\t\t\t\t<dt>ものづくりの原点<br>\n\t\t\t\t\t未来も<br class=\"sp\">ここから始まる</dt>\n\t\t\t\t\t<dd>千葉県野田市にあるKHK野田は<br class=\"pc\"\n\t\t\t\t\t>創業1935年、産業向け汎用歯車からロボコン用の歯車まで<br class=\"pc\"\n\t\t\t\t\t>業界随一の品揃えを誇る標準歯車のリーディングカンパニーであり、<br class=\"pc\"\n\t\t\t\t\t>歯車一筋の歯車専業メーカーの小原歯車工業株式会社（KHK）のグループ会社です</dd>\n\t\t\t\t</dl>\n\t\t\t</div>\n\t\t</div>\t\n\t<!-- mainVisual -->\n\t</div>\n\t\n\t<section id=\"sec01\" class=\"relaLink\">\n\t\t<div id=\"vol01\">&nbsp;</div>\n\t\t\n\t\t<div class=\"grayFlex rvs\">\n\t\t\t\n\t\t\t<div class=\"grayInner\">\n\t\t\t\t<div class=\"grayHarf fadein03\">\n\t\t\t\t\t\n\t\t\t\t\t<h2 class=\"redLine\">事業内容・製品</h2>\n\t\t\t\t\t\n\t\t\t\t\t<h3 class=\"grayTitle\">日本から<br>\n\t\t\t\t\t\t世界をまわす<br>\n\t\t\t\t\t\tKHKの歯車</h3>\n\t\t\t\t\t\n\t\t\t\t\t<p class=\"mb30\">豊富な品揃えで<br>\n\t\t\t\t\t\tあらゆるニーズに即応。<br>\n\t\t\t\t\t\t信頼と満足のKHK製品をお届けします。</p>\n\t\t\t\t\t\n\t\t\t\t\t<p>KHK野田ではお客様の声を反映させた歯車の開発にベストを尽くし、高品質の製品をモノづくりの最前線にお届けしています。<br>\n\t\t\t\t\t\t便利で使い易い豊富な標準品ラインナップをご用意するとともに、現場ニーズに合わせたオーダー品にも対応しています。</p>\n\t\t\t\t<!-- grayHarf -->\n\t\t\t\t</div>\n\t\t\t<!-- grayInner -->\n\t\t\t</div>\n\t\t\t\n\t\t\t<figure class=\"graySame\"><img src=\"./image/index/sec01_img01.jpg\" alt=\"日本から世界をまわすKHKの歯車\"></figure>\n\t\t<!-- grayFlex -->\n\t\t</div>\n\t<!-- sec01 -->\n\t</section>\n\t\n\t<section id=\"sec02\">\n\t\t<div class=\"inner iconFlex\">\n\t\t\t<dl class=\"iconSame mov01\">\n\t\t\t\t<dt>KHKグループ創業</dt>\n\t\t\t\t<dd><img src=\"./image/index/sec02_img01.png\" alt=\"KHKグループ創業\"></dd>\n\t\t\t</dl>\n\t\t\t<dl class=\"iconSame mov02\">\n\t\t\t\t<dt>標準歯車</dt>\n\t\t\t\t<dd><img src=\"./image/index/sec02_img02.png\" alt=\"標準歯車\"></dd>\n\t\t\t</dl>\n\t\t\t<dl class=\"iconSame mov03\">\n\t\t\t\t<dt>年間休日</dt>\n\t\t\t\t<dd><img src=\"./image/index/sec02_img03.png\" alt=\"年間休日\"></dd>\n\t\t\t</dl>\n\t\t\n\t\t<!-- iconFlex -->\n\t\t</div>\n\t\n\t<!-- sec02 -->\n\t</section>\n\t\n\t<section id=\"sec03\">\n\t\t<div class=\"inner\">\n\t\t\t<h2 class=\"subTitle\">KHKグループが取り扱っている製品ラインナップ</h2>\n\t\t\t\n\t\t\t<div class=\"secFlex\">\n\t\t\t\t\n\t\t\t\t<div class=\"secSame fdmov01\">\n\t\t\t\t\t<figure class=\"secHarf\"><a href=\"https://khkgears.co.jp/khk_products/\" target=\"_blank\"><img src=\"./image/index/sec03_img01.jpg\" alt=\"KHK標準歯車\"></a></figure>\n\t\t\t\t\t<dl class=\"secHarf\">\n\t\t\t\t\t\t<dt class=\"capTitle\"><a href=\"https://khkgears.co.jp/khk_products/\" target=\"_blank\" class=\"iconLink\"><span class=\"redTxt\">K</span>HK標準歯車</a></dt>\n\t\t\t\t\t\t<dd class=\"capText\">KHKでは「すぐに使える」をコンセプトに200品目、30,000種の標準歯車をご用意しています。設計意図に合わせて最適な歯車が選定いただけます。</dd>\n\t\t\t\t\t</dl>\n\t\t\t\t<!-- secSame -->\n\t\t\t\t</div>\n\t\t\t\t\n\t\t\t\t<div class=\"secSame fdmov01\">\n\t\t\t\t\t<figure class=\"secHarf\"><a href=\"https://khkgears.co.jp/khk_products/j_series.html\" target=\"_blank\"><img src=\"./image/index/sec03_img02.jpg\" alt=\"Jシリーズ\"></a></figure>\n\t\t\t\t\t<dl class=\"secHarf\">\n\t\t\t\t\t\t<dt class=\"capTitle\"><a href=\"https://khkgears.co.jp/khk_products/j_series.html\" target=\"_blank\" class=\"iconLink\"><span class=\"redTxt\">J</span>シリーズ</a>\n\t\t\t\t\t\t\t<span class=\"smlTxt\">- 穴、キー、タップを標準化 -</span></dt>\n\t\t\t\t\t\t<dd class=\"capText\">標準歯車の下穴製品をベースに穴径、キー溝、取付穴の寸法をKHK独自の規格でシリーズ化した「76品目18,700種」の製品です。</dd>\n\t\t\t\t\t</dl>\n\t\t\t\t<!-- secSame -->\n\t\t\t\t</div>\n\t\t\t\t\n\t\t\t\t<div class=\"secSame fdmov01\">\n\t\t\t\t\t<figure class=\"secHarf\"><a href=\"https://khkgears.co.jp/khk_products/haguruma_koubou.html\" target=\"_blank\"><img src=\"./image/index/sec03_img03.jpg\" alt=\"歯車工房\"></a></figure>\n\t\t\t\t\t<dl class=\"secHarf\">\n\t\t\t\t\t\t<dt class=\"capTitle\"><a href=\"https://khkgears.co.jp/khk_products/haguruma_koubou.html\" target=\"_blank\" class=\"iconLink\"><span class=\"redTxt\">歯</span>車工房</a><span class=\"smlTxt\">- 標準歯車の追加工 -</span></dt>\n\t\t\t\t\t\t<dd class=\"capText\">KHK標準歯車の追加工を短納期、リーズナブルプライスで承ります。追加工専用「ＪＩＴライン」を使用した一環したシステムで、お見積から製作までスピーディーに対応いたします！</dd>\n\t\t\t\t\t</dl>\n\t\t\t\t<!-- secSame -->\n\t\t\t\t</div>\n\t\t\t\t\n\t\t\t\t<div class=\"secSame fdmov01\">\n\t\t\t\t\t<figure class=\"secHarf\"><a href=\"https://khkgears.co.jp/khk_products/f_series.html\" target=\"_blank\"><img src=\"./image/index/sec03_img04.jpg\" alt=\"Fシリーズ\"></a></figure>\n\t\t\t\t\t<dl class=\"secHarf\">\n\t\t\t\t\t\t<dt class=\"capTitle\"><a href=\"https://khkgears.co.jp/khk_products/f_series.html\" target=\"_blank\" class=\"iconLink\"><span class=\"redTxt\"> F</span>シリーズ</a><span class=\"smlTxt\">- ブッシング一体・摩擦締結歯車 -</span></dt>\n\t\t\t\t\t\t<dd class=\"capText\">KHK標準歯車の追加工を短納期、リーズナブルプライスで承ります。追加工専用「ＪＩＴライン」を使用した一環したシステムで、お見積から製作までスピーディーに対応いたします！</dd>\n\t\t\t\t\t</dl>\n\t\t\t\t<!-- secSame -->\n\t\t\t\t</div>\n\t\t\t\t\n\t\t\t\t<div class=\"secSame fdmov01\">\n\t\t\t\t\t<figure class=\"secHarf\"><a href=\"https://khkgears.co.jp/khk_products/laser.html\" target=\"_blank\"><img src=\"./image/index/sec03_img05.jpg\" alt=\"レーザー焼入れラック\"></a></figure>\n\t\t\t\t\t<dl class=\"secHarf\">\n\t\t\t\t\t\t<dt class=\"capTitle\"><a href=\"https://khkgears.co.jp/khk_products/laser.html\" target=\"_blank\" class=\"iconLink\"><span class=\"redTxt\">レ</span>ーザー焼入れラック</a></dt>\n\t\t\t\t\t\t<dd class=\"capText\">歯面レーザ焼入れを標準化 価格と歪を抑え、従来のSRFラックより歯面強さを2倍以上アップ！</dd>\n\t\t\t\t\t</dl>\n\t\t\t\t<!-- secSame -->\n\t\t\t\t</div>\n\t\t\t\t\n\t\t\t\t<div class=\"secSame fdmov01\">\n\t\t\t\t\t<figure class=\"secHarf\"><a href=\"https://khkgears.co.jp/khk_products/order_gears_introduction.html\" target=\"_blank\"><img src=\"./image/index/sec03_img06.jpg\" alt=\"オーダー歯車\"></a></figure>\n\t\t\t\t\t<dl class=\"secHarf\">\n\t\t\t\t\t\t<dt class=\"capTitle\"><a href=\"https://khkgears.co.jp/khk_products/order_gears_introduction.html\" target=\"_blank\" class=\"iconLink\"><span class=\"redTxt\">オ</span>ーダー歯車</a></dt>\n\t\t\t\t\t\t<dd class=\"capText\">標準歯車以外の製品を、長年蓄積した独自のノウハウと高度な加工技術、最新の生産システムのもとで、オーダー歯車として承る万全の受入体制を整えています。</dd>\n\t\t\t\t\t</dl>\n\t\t\t\t<!-- secSame -->\n\t\t\t\t</div>\n\t\t\t\t\n\t\t\t\t\n\t\t\t<!-- secFlex -->\n\t\t\t</div>\n\t\t\t<p class=\"linkBtn\"><a href=\"https://khkgears.co.jp/\" target=\"_blank\">小原歯車工業サイト</a></p>\n\t\t\t\t\n\t\t\n\t\t<!-- inner -->\n\t\t</div>\n\t<!-- sec03 -->\n\t</section>\n\t\n\t<section id=\"sec04\" class=\"relaLink\">\n\t\t<div id=\"vol02\">&nbsp;</div>\n\t\t<h2 class=\"redLine inner mb20\">環境制度</h2>\n\t\t<div class=\"environment\">\n\t\t\t<dl class=\"envWrap fadein\">\n\t\t\t\t<dt>「ここまで」なんてない<br>\n\t\t\t\t\t目指せば<br class=\"sp\">どこまでもいける</dt>\n\t\t\t\t<dd>KHK野田は日常の中で、人生の中で必要な環境制度が充実しています。<br>\n\t\t\t\t\t日々の健康のためにはかかせない、<br>\n\t\t\t\t\t社内で体を動かせる多種多様なレクリエーション設備や<br>\n\t\t\t\t\t社外での部活・イベント、働く中で起こる様々な人生の岐路をサポートする制度。<br>\n\t\t\t\t\tまた、入社後のキャリアステップを含めた資格・研修なども豊富です。<br><br>\n\t\t\t\t\t心身ともに健康で、安心して働ける環境やキャリアステップを用意しています。</dd>\n\t\t\t</dl>\n\t\t<!-- environment -->\n\t\t</div>\n\t<!-- sec04 -->\n\t</section>\n\t\n\t<section id=\"sec05\">\n\t\t<div class=\"inner\">\n\t\t\t<p class=\"leadTxt\">製造ラインでの現場もキャリアステップすると、企画からの立ち上げや世界の工場へ視察にいくこともあります。</p>\n\t\t\t\n\t\t\t<div class=\"cstepWrap\">\n\t\t\t\t<dl class=\"caStep\">\n\t\t\t\t\t<dt>キャリアステップの一例</dt>\n\t\t\t\t\t<dd>\n\t\t\t\t\t\t<ul>\n\t\t\t\t\t\t\t<li>製造企画</li>\n\t\t\t\t\t\t\t<li>納期管理</li>\n\t\t\t\t\t\t\t<li>購買</li>\n\t\t\t\t\t\t\t<li>品質管理</li>\n\t\t\t\t\t\t\t<li>製品管理（修理・事業設計）</li>\n\t\t\t\t\t\t</ul>\n\t\t\t\t\t</dd>\n\t\t\t\t</dl>\n\t\t\t<!-- cstepWrap -->\n\t\t\t</div>\n\t\t\t\n\t\t<!-- inner -->\n\t\t</div>\n\t<!-- sec05 -->\n\t</section>\n\t\n\t<section id=\"sec06\" class=\"relaLink\">\n\t\t<div id=\"vol03\">&nbsp;</div>\n\t\t<div class=\"grayFlex rvs\">\n\t\t\t\n\t\t\t<div class=\"grayInner\">\n\t\t\t\t<div class=\"grayHarf fadein03\">\n\t\t\t\t\t\n\t\t\t\t\t<h2 class=\"redLine\">レクリエーション施設</h2>\n\t\t\t\t\t\n\t\t\t\t\t<h3 class=\"grayTitle\">仕事やプライベートも<br>\n\t\t\t\t\t\t充実を<br>\n\t\t\t\t\t\tどちらも全力で楽しむ</h3>\n\t\t\t\t\t\n\t\t\t\t\t<p>KHK野田は、仕事もプライベートも全力で楽しめるように応援しています。<br>\n\t\t\t\t\t\t充実したレクリエーション施設も充実しており、心身共に健康を保てるようにしています。<br>\n\t\t\t\t\t\tまた、レクリエーションでBBQを開催したりしています。<br>\n\t\t\t\t\t\t（現在は、ゴルフコンペ、釣りなど屋外少人数のみのレクリエーションのみ実施しています）</p>\n\t\t\t\t<!-- grayHarf -->\n\t\t\t\t</div>\n\t\t\t<!-- grayInner -->\n\t\t\t</div>\n\t\t\t\n\t\t\t<div class=\"graySame\">\n\t\t\t\t<ul class=\"slick\">\n\t\t\t\t\t<li><img src=\"./image/index/sec06_slide01.jpg\" alt=\"レクリエーション施設\"></li>\n\t\t\t\t\t<li><img src=\"./image/index/sec06_slide02.jpg\" alt=\"レクリエーション施設\"></li>\n\t\t\t\t\t<li><img src=\"./image/index/sec06_slide03.jpg\" alt=\"レクリエーション施設\"></li>\n\t\t\t\t\t<li><img src=\"./image/index/sec06_slide04.jpg\" alt=\"レクリエーション施設\"></li>\t\n\t\t\t\t</ul>\n\t\t\t</div>\n\t\t<!-- grayFlex -->\n\t\t</div>\n\t\n\t<!-- sec06 -->\n\t</section>\n\t\n\t<section id=\"sec07\">\n\t\t<div class=\"inner\">\n\t\t\t<h2 class=\"subTitle\">レクリエーション施設</h2>\n\t\t\t<div class=\"trdFlex\">\n\t\t\t\t<div class=\"trdSame fdmov02\">\n\t\t\t\t\t<figure class=\"trdHarf\"><img src=\"./image/index/sec07_img01.jpg\" alt=\"トレーニングジム\"></figure>\n\t\t\t\t\t<dl class=\"trdHarf\">\n\t\t\t\t\t\t<dt class=\"capTitle\"><span class=\"redTxt\">ト</span>レーニングジム</dt>\n\t\t\t\t\t\t<dd class=\"capText\">エアロバイク<br>\n\t\t\t\t\t\t\t各種ウエイトトレーニング<br>\n\t\t\t\t\t\t\t各種ストレッチ機器<br>\n\t\t\t\t\t\t\tがあります。</dd>\n\t\t\t\t\t</dl>\n\t\t\t\t<!-- trdSame -->\n\t\t\t\t</div>\n\t\t\t\t\n\t\t\t\t<div class=\"trdSame fdmov02\">\n\t\t\t\t\t<figure class=\"trdHarf\"><img src=\"./image/index/sec07_img02.jpg\" alt=\"卓球台\"></figure>\n\t\t\t\t\t<dl class=\"trdHarf\">\n\t\t\t\t\t\t<dt class=\"capTitle\"><span class=\"redTxt\">卓</span>球台</dt>\n\t\t\t\t\t\t<dd class=\"capText\">3台あります。<br>\n\t\t\t\t\t\t\t自由に使えるラケットもあります。</dd>\n\t\t\t\t\t</dl>\n\t\t\t\t<!-- trdSame -->\n\t\t\t\t</div>\n\t\t\t\t\n\t\t\t\t<div class=\"trdSame fdmov02\">\n\t\t\t\t\t<figure class=\"trdHarf\"><img src=\"./image/index/sec07_img04.jpg\" alt=\"ゴルフ練習場\"></figure>\n\t\t\t\t\t<dl class=\"trdHarf\">\n\t\t\t\t\t\t<dt class=\"capTitle\"><span class=\"redTxt\">ゴ</span>ルフ練習場</dt>\n\t\t\t\t\t\t<dd class=\"capText\">2面あります。<br>\n\t\t\t\t\t\t\tナイター設備も完備しています！</dd>\n\t\t\t\t\t</dl>\n\t\t\t\t<!-- trdSame -->\n\t\t\t\t</div>\n\t\t\t\t\n\t\t\t\t<div class=\"trdSame fdmov02\">\n\t\t\t\t\t<figure class=\"trdHarf\"><img src=\"./image/index/sec07_img05.jpg\" alt=\"ボルダリング\"></figure>\n\t\t\t\t\t<dl class=\"trdHarf\">\n\t\t\t\t\t\t<dt class=\"capTitle\"><span class=\"redTxt\">ボ</span>ルダリング</dt>\n\t\t\t\t\t\t<dd class=\"capText\">2コースあります。<br>\n\t\t\t\t\t\t\tロープを使ってトレーニングも！</dd>\n\t\t\t\t\t</dl>\n\t\t\t\t<!-- trdSame -->\n\t\t\t\t</div>\n\t\t\t\t\n\t\t\t<!-- trdFlex -->\t\n\t\t\t</div>\n\t\t<!-- inner -->\n\t\t</div>\n\t<!-- sec07 -->\n\t</section>\n\t\n\t<section id=\"sec08\" class=\"relaLink\">\n\t\t<div id=\"vol04\">&nbsp;</div>\n\t\t<div class=\"grayFlex\">\n\t\t\t\n\t\t\t<div class=\"grayInner rvs\" id=\"extra\">\n\t\t\t\t<div class=\"grayHarf fadein02\">\n\t\t\t\t\t\n\t\t\t\t\t<h2 class=\"redLine\">福利厚生</h2>\n\t\t\t\t\t\n\t\t\t\t\t<h3 class=\"grayTitle\">安心して働けることを<br>\n\t\t\t\t\t\t当たり前に<br>\n\t\t\t\t\t\t全力で全方位から<br>\n\t\t\t\t\t\tサポート</h3>\n\t\t\t\t\t\n\t\t\t\t\t<p class=\"mb30\">KHK野田の福利厚生は、社員が安心して働けることを当たり前に感じて頂けるために<br>\n\t\t\t\t\t\t様々な制度を設けています。家計に優しい昼食補助や、住宅購入の際には会社が貸付など。<br>\n\t\t\t\t\t\t将来にわたって、いつまでも安心をサポートしています。</p>\n\t\t\t\t\t\n\t\t\t\t\t<figure class=\"mb30\"><a href=\"https://khkgears.co.jp/about_khk/kenko.html\" target=\"_blank\"><img src=\"./image/index/health_bnr.jpg\" alt=\"健康経営優良法人\"></a></figure>\n\t\t\t\t\t\n\t\t\t\t\t<p>従業員の健康と会社の活力を高める取り組みを行い、健康経営優良法人の認定をされました。</p>\n\t\t\t\t<!-- grayHarf -->\n\t\t\t\t</div>\n\t\t\t<!-- grayInner -->\n\t\t\t</div>\n\t\t\t\n\t\t\t<figure class=\"graySame\"><img src=\"./image/index/sec08_img01.jpg\" alt=\"福利厚生\"></figure>\n\t\t<!-- grayFlex -->\n\t\t</div>\n\t<!-- sec08 -->\n\t</section>\n\t\n\t<section id=\"sec09\">\n\t\t<div class=\"inner\">\n\t\t\t<div class=\"iconFlex mb150\">\n\t\t\t\t<dl class=\"iconSame mov04\">\n\t\t\t\t\t<dt>社員平均年齢</dt>\n\t\t\t\t\t<dd class=\"aCenter\"><img src=\"./image/index/sec09_img01.png\" alt=\"社員平均年齢\"></dd>\n\t\t\t\t</dl>\n\t\t\t\t<dl class=\"iconSame mov05\">\n\t\t\t\t\t<dt>有給取得日</dt>\n\t\t\t\t\t<dd class=\"aCenter\"><img src=\"./image/index/sec09_img02.png\" alt=\"有給取得日\"></dd>\n\t\t\t\t</dl>\n\t\t\t\t<dl class=\"iconSame mov06\">\n\t\t\t\t\t<dt>平均残業時間</dt>\n\t\t\t\t\t<dd class=\"aCenter\"><img src=\"./image/index/sec09_img03.png\" alt=\"平均残業時間\"></dd>\n\t\t\t\t</dl>\n\t\t\t<!-- iconFlex -->\n\t\t\t</div>\n\t\t\t\n\t\t\t<h2 class=\"subTitle\">制度・福利厚生</h2>\n\t\t\t\n\t\t\t<div class=\"trdIcon\">\n\t\t\t\t<div class=\"tiSame fdmov03\">\n\t\t\t\t\t<figure class=\"icons\"><img src=\"./image/index/sec09_icon01.png\" alt=\"短時間勤務制度\"></figure>\n\t\t\t\t\t<dl>\n\t\t\t\t\t\t<dt class=\"capTitle\"><span class=\"redTxt\">短</span>時間勤務制度</dt>\n\t\t\t\t\t\t<dd class=\"capText\">育児や介護のために短時間勤務ができる制度を設けています。</dd>\n\t\t\t\t\t</dl>\n\t\t\t\t<!-- tiSame -->\n\t\t\t\t</div>\n\t\t\t\t\n\t\t\t\t<div class=\"tiSame fdmov03\">\n\t\t\t\t\t<figure class=\"icons\"><img src=\"./image/index/sec09_icon02.png\" alt=\"休暇・休職制度\"></figure>\n\t\t\t\t\t<dl>\n\t\t\t\t\t\t<dt class=\"capTitle\"><span class=\"redTxt\">休</span>暇・休職制度</dt>\n\t\t\t\t\t\t<dd class=\"capText\">出産・育児や家族の介護を支援するための休職制度を設けています。</dd>\n\t\t\t\t\t</dl>\n\t\t\t\t<!-- tiSame -->\n\t\t\t\t</div>\n\t\t\t\t\n\t\t\t\t<div class=\"tiSame fdmov03\">\n\t\t\t\t\t<figure class=\"icons\"><img src=\"./image/index/sec09_icon03.png\" alt=\"特別有給休暇\"></figure>\n\t\t\t\t\t<dl>\n\t\t\t\t\t\t<dt class=\"capTitle\"><span class=\"redTxt\">特</span>別有給休暇</dt>\n\t\t\t\t\t\t<dd class=\"capText\">慶弔時、人間ドックの際には年次有給休暇とは別に特別休暇が取得できます。</dd>\n\t\t\t\t\t</dl>\n\t\t\t\t<!-- tiSame -->\n\t\t\t\t</div>\n\t\t\t\t\n\t\t\t\t<div class=\"tiSame fdmov03\">\n\t\t\t\t\t<figure class=\"icons\"><img src=\"./image/index/sec09_icon04.png\" alt=\"年次有給休暇（時間有給休暇）\"></figure>\n\t\t\t\t\t<dl>\n\t\t\t\t\t\t<dt class=\"capTitle\"><span class=\"redTxt\">年</span>次有給休暇（時間有給休暇）</dt>\n\t\t\t\t\t\t<dd class=\"capText\">1日単位のほかに半日単位・1時間単位での有給休暇が取得できます。</dd>\n\t\t\t\t\t</dl>\n\t\t\t\t<!-- tiSame -->\n\t\t\t\t</div>\n\t\t\t\t\n\t\t\t\t<div class=\"tiSame fdmov03\">\n\t\t\t\t\t<figure class=\"icons\"><img src=\"./image/index/sec09_icon05.png\" alt=\"財産形成貯蓄\"></figure>\n\t\t\t\t\t<dl>\n\t\t\t\t\t\t<dt class=\"capTitle\"><span class=\"redTxt\">財</span>産形成貯蓄</dt>\n\t\t\t\t\t\t<dd class=\"capText\">月々の給与や賞与から財形形成の積み立てができます。積立Nisa、マッチング拠出。</dd>\n\t\t\t\t\t</dl>\n\t\t\t\t<!-- tiSame -->\n\t\t\t\t</div>\n\t\t\t\t\n\t\t\t\t<div class=\"tiSame fdmov03\">\n\t\t\t\t\t<figure class=\"icons\"><img src=\"./image/index/sec09_icon06.png\" alt=\"昼食補助\"></figure>\n\t\t\t\t\t<dl>\n\t\t\t\t\t\t<dt class=\"capTitle\"><span class=\"redTxt\">昼</span>食補助</dt>\n\t\t\t\t\t\t<dd class=\"capText\">社員の負担軽減のため昼食代の半額を補助しています。1カ月の昼食が3,500円/月でまかなえます。</dd>\n\t\t\t\t\t</dl>\n\t\t\t\t<!-- tiSame -->\n\t\t\t\t</div>\n\t\t\t\t\n\t\t\t\t<div class=\"tiSame fdmov03\">\n\t\t\t\t\t<figure class=\"icons\"><img src=\"./image/index/sec09_icon07.png\" alt=\"退職金制度\"></figure>\n\t\t\t\t\t<dl>\n\t\t\t\t\t\t<dt class=\"capTitle\"><span class=\"redTxt\">退</span>職金制度</dt>\n\t\t\t\t\t\t<dd class=\"capText\">社員の定年後の生活設計のために会社が掛金を拠出し、社員が自分で運用ができる「確定拠出年金制度」を採用しています。</dd>\n\t\t\t\t\t</dl>\n\t\t\t\t<!-- tiSame -->\n\t\t\t\t</div>\n\t\t\t\t\n\t\t\t\t<div class=\"tiSame fdmov03\">\n\t\t\t\t\t<figure class=\"icons\"><img src=\"./image/index/sec09_icon08.png\" alt=\"住宅福祉資金貸付\"></figure>\n\t\t\t\t\t<dl>\n\t\t\t\t\t\t<dt class=\"capTitle\"><span class=\"redTxt\">住</span>宅福祉資金貸付</dt>\n\t\t\t\t\t\t<dd class=\"capText\">住宅等を購入や福祉に必要な資金を会社が貸付します。</dd>\n\t\t\t\t\t</dl>\n\t\t\t\t<!-- tiSame -->\n\t\t\t\t</div>\n\t\t\t\t\n\t\t\t\t<div class=\"tiSame fdmov03\">\n\t\t\t\t\t<figure class=\"icons\"><img src=\"./image/index/sec09_icon09.png\" alt=\"資格取得奨励金\"></figure>\n\t\t\t\t\t<dl>\n\t\t\t\t\t\t<dt class=\"capTitle\"><span class=\"redTxt\">資</span>格取得奨励金</dt>\n\t\t\t\t\t\t<dd class=\"capText\">自己啓発・キャリア促進のため、技能資格を取得した社員に奨励金を支給する制度を設けています。</dd>\n\t\t\t\t\t</dl>\n\t\t\t\t<!-- tiSame -->\n\t\t\t\t</div>\n\t\t\t\t\n\t\t\t\t<div class=\"tiSame fdmov03\">\n\t\t\t\t\t<figure class=\"icons\"><img src=\"./image/index/sec09_icon10.png\" alt=\"健康診断・人間ドック補助\"></figure>\n\t\t\t\t\t<dl>\n\t\t\t\t\t\t<dt class=\"capTitle\"><span class=\"redTxt\">健</span>康診断・人間ドック補助</dt>\n\t\t\t\t\t\t<dd class=\"capText\">社員とその家族の健康を守るために、健康診断などの受診料の一部を会社と健康保険組合が補助します。</dd>\n\t\t\t\t\t</dl>\n\t\t\t\t<!-- tiSame -->\n\t\t\t\t</div>\n\t\t\t\t\n\t\t\t\t<div class=\"tiSame fdmov03\">\n\t\t\t\t\t<figure class=\"icons\"><img src=\"./image/index/sec09_icon11.png\" alt=\"福利厚生のアウトソーシングサービス\"></figure>\n\t\t\t\t\t<dl>\n\t\t\t\t\t\t<dt class=\"capTitle\"><span class=\"redTxt\">福</span>利厚生のアウトソーシングサービス</dt>\n\t\t\t\t\t\t<dd class=\"capText\">川口勤労福祉センターよりショッピング、宿泊やレジャー施設などを割引価格で利用できるというサービス提供しています。</dd>\n\t\t\t\t\t</dl>\n\t\t\t\t<!-- tiSame -->\n\t\t\t\t</div>\n\t\t\t<!-- trdIcon -->\n\t\t\t</div>\n\t\t<!-- inner -->\n\t\t</div>\n\t<!--  sec09-->\n\t</section>\n\t\n\t<section id=\"sec10\" class=\"relaLink\">\n\t\t<div id=\"vol05\">&nbsp;</div>\n\t\t<div class=\"inner\">\n\t\t\t<h2 class=\"redLine\">募集要項</h2>\n\t\t\t<p class=\"catchText fadein\">一つ一つは小さな歯車<br>\n\t\t\t\tTEAMでまわせば<br class=\"sp\">大きな原動力へ</p>\n\t\t<!-- inner -->\t\n\t\t</div>\n\t<!-- sec10 -->\n\t</section>\n\t\n\t<section id=\"sec11\">\n\t\t<div class=\"inWrap\">\n\t\t\t<h2 class=\"subTitle\">採用情報</h2>\n\t\t\t<table class=\"tbMain mb70\">\n\t\t\t\t<tr>\n\t\t\t\t\t<th>職種</th>\n\t\t\t\t\t<td>製造補助　現在募集は行っておりません。</td>\n\t\t\t\t</tr>\n\t\t\t\t<tr>\n\t\t\t\t\t<th>加入保険等</th>\n\t\t\t\t\t<td>雇用・労災・健康・厚生・財形/企業年金：確定拠出年金</td>\n\t\t\t\t</tr>\n\t\t\t\t<tr>\n\t\t\t\t\t<th>就業時間</th>\n\t\t\t\t\t<td>8：30～17：15</td>\n\t\t\t\t</tr>\n\t\t\t\t<tr>\n\t\t\t\t\t<th>休日</th>\n\t\t\t\t\t<td>土・日曜日・祝日</td>\n\t\t\t\t</tr>\n\t\t\t\t\n\t\t\t</table>\n\t\t\t\n\t\t\t<h2 class=\"subTitle\">高校生の採用情報</h2>\n\t\t\t<table class=\"tbMain mb70\">\n\t\t\t\t<tr>\n\t\t\t\t\t<th>職種</th>\n\t\t\t\t\t<td>マシンオペレーター</td>\n\t\t\t\t</tr>\n\t\t\t\t<tr>\n\t\t\t\t\t<th>加入保険等</th>\n\t\t\t\t\t<td>歯車を製造に関する加工及び検査<br>\n\t\t\t\t\t  主に扱う機械設備はNC旋盤、NC歯切盤、NC研削盤です。<br>\n\t\t\t\t  必要な知識または技能　不問　入社後の教育訓練でマスターできます。</td>\n\t\t\t\t</tr>\n\t\t\t\t<tr>\n\t\t\t\t\t<th>就業時間</th>\n\t\t\t\t\t<td>8：30～17：15、19：00～3：45　交代制　</td>\n\t\t\t\t</tr>\n\t\t\t\t<tr>\n\t\t\t\t\t<th>休日</th>\n\t\t\t\t\t<td>週休二日制　夏休み・年末年始　年間休日125日</td>\n\t\t\t\t</tr>\n\t\t\t\t<tr>\n\t\t\t\t\t<th>福利厚生</th>\n\t\t\t\t\t<td>社会保険は完備、確定拠出年金、退職金制度、トレーニング設備　</td>\n\t\t\t\t</tr>\n\t\t\t\t<tr>\n\t\t\t\t\t<th>選考方法</th>\n\t\t\t\t\t<td>面接・適性検査</td>\n\t\t\t\t</tr>\n\t\t\t\t<tr>\n\t\t\t\t\t<th>応募方法</th>\n\t\t\t\t\t<td>進路ご担当の先生を通じてお問い合わせください。応募前会社見学を実施しています。</td>\n\t\t\t\t</tr>\n\t\t\t\t<tr>\n\t\t\t\t\t<th>採用スケジュール</th>\n\t\t\t\t\t<td>7月1日求人票公開　7月下旬工場見学会　9月中旬選考<br>\n\t\t\t\t  職業や企業を紹介する動画「埼玉しごと発見」をご覧ください。仕事内容が理解できます。</td>\n\t\t\t\t</tr>\n\t\t\t\t\n\t\t\t</table>\n\t\t\t\n\t\t\t<p class=\"recText\">チームワークを大事にできるあなたを歓迎します。<br>\n\t\t\t\tご応募お待ちしております。</p>\n\t\t\t\n\t\t\t<p class=\"alignCenter mb10\">電話・メールでお問い合わせください。</p>\n\t\t\t\n\t\t\t<p class=\"alignCenter\"><a href=\"mailto:&#107;&#104;&#107;&#110;&#111;&#100;&#97;&#45;&#106;&#105;&#110;&#106;&#105;&#64;&#107;&#104;&#107;&#103;&#101;&#97;&#114;&#115;&#46;&#99;&#111;&#46;&#106;&#112;\" class=\"redLink\">お問い合わせ</a></p>\n\t\t<!-- inWrap -->\n\t\t</div>\n\t<!-- sec11 -->\n\t</section>\n\t\n\t<section id=\"sec12\" class=\"relaLink\">\n\t\t<div id=\"vol06\">&nbsp;</div>\n\t\t<div class=\"inWrap\">\n\t\t\t<h2 class=\"subTitle mb40\">会社概要</h2>\n\t\t\t<div class=\"corpFlex mb30\">\n\t\t\t\t<div class=\"corpSame\">\n\t\t\t\t\t<table class=\"tbMain\">\n\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t<th>社名</th>\n\t\t\t\t\t\t\t<td>株式会社KHK野田<br></td>\n\t\t\t\t\t\t</tr>\n\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t<th>設立 </th>\n\t\t\t\t\t\t\t<td>1993年</td>\n\t\t\t\t\t\t</tr>\n\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t<th>代表者</th>\n\t\t\t\t\t\t\t<td>代表取締役社長 小原敏治</td>\n\t\t\t\t\t\t</tr>\n\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t<th>資本金</th>\n\t\t\t\t\t\t\t<td>8,000万円</td>\n\t\t\t\t\t\t</tr>\n\t\t\t\t\t</table>\n\t\t\t\t\t\n\t\t\t\t<!-- corpSame -->\n\t\t\t\t</div>\n\t\t\t\t\n\t\t\t\t<div class=\"corpSame\">\n\t\t\t\t\t<table class=\"tbMain\">\n\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t<th>事業目的</th>\n\t\t\t\t\t\t\t<td>歯車及びKHK標準歯車の製造</td>\n\t\t\t\t\t\t</tr>\n\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t<th>社員</th>\n\t\t\t\t\t\t\t<td>123名（2023年3月現在）</td>\n\t\t\t\t\t\t</tr>\n\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t<th>所在地</th>\n\t\t\t\t\t\t\t<td>事務所・工場／第１工場・事務所棟<br>\n\t\t\t\t\t\t\t  〒270-0237　千葉県野田市中里143番地<br>\n\t\t\t\t\t\t  TEL：04-7129-4921（代）FAX：04-7127-1271</td>\n\t\t\t\t\t\t</tr>\n\t\t\t\t\t</table>\n\t\t\t\t<!-- corpSame -->\n\t\t\t\t</div>\n\t\t\t\n\t\t\t<!-- corpFlex -->\n\t\t\t</div>\n\t\t\t<ul class=\"compFlex\">\n\t\t\t\t<li>\n\t\t\t\t\t<div class=\"imgRela mb10\">\n\t\t\t\t\t<figure><img src=\"./image/index/chiba_sdgs.png\" alt=\"ちばSDGS\"></figure>\n\t\t\t\t\t<p class=\"relaTxt\">チーバくん</p>\n\t\t\t\t</div>\n\t\t\t\t<p>ちばSDGsパートナー1130号</p>\n\t\t\t\t</li>\n\t\t\t\t<li>\n\t\t\t\t\t<a href=\"./image/index/pdf/actionplan.pdf\" target=\"_blank\" class=\"borderLink\">次世代法に基づく<br>一般事業主行動計画</a>\n\t\t\t\t</li>\n\t\t\t\t<li>\n\t\t\t\t\t<a href=\"./image/index/pdf/womensparticipation.pdf\" target=\"_blank\" class=\"borderLink\">女性活躍推進法に基づく<br>行動計画</a>\n\t\t\t\t</li>\n\t\t\t</ul>\n\t\t<!-- inWrap -->\n\t\t</div>\n\t<!-- sec12 -->\n\t</section>\n\t\n\t<section class=\"whiteBg\">\n\t\t<div class=\"inWrap\">\n\t\t\t<h2 class=\"subTitle\">パートナーシップ構築宣言</h2>\n\t\t\t<p class=\"alignCenter\">\n\t\t\t\t<a href=\"./image/index/pdf/partnership.pdf\" target=\"_blank\" class=\"glassLink\"><img src=\"./image/index/partnership_logo.png\" alt=\"パートナーシップ構築宣言\"></a>\n\t\t\t</p>\n\t\t<!-- inWrap -->\n\t\t</div>\n\t<!-- whiteBg -->\n\t</section>\n\t\n\t<section class=\"gmapWrap\">\n\t\t<iframe src=\"https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3228.069139404706!2d139.83486331541667!3d35.99417722035223!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x6018bcbe80328947%3A0x5ca654e67bf25a7d!2z44CSMjcwLTAyMzcg5Y2D6JGJ55yM6YeO55Sw5biC5Lit6YeM77yR77yU77yTIO-8q--8qO-8q-mHjueUsA!5e0!3m2!1sja!2sjp!4v1655467964382!5m2!1sja!2sjp\" allowfullscreen=\"\" loading=\"lazy\" referrerpolicy=\"no-referrer-when-downgrade\"></iframe>\n\t<!-- gmapWrap -->\n\t</section>\n\t\n\t<footer id=\"footer\">\n\t\t<p id=\"pagetop\"><a href=\"#\" class=\"pageTop\">&nbsp;</a></p>\n\t\t\n\t\t<div class=\"ftWrap\">\n\t\t\t\n\t\t\t<p><a href=\"./privacy.html\">プライバシーポリシー</a></p>\n\t\t\t<address>&copy;2022　KHK Kohara Gear Industry Co., Ltd. </address>\n\t\t\t\n\t\t<!-- ftWrap -->\n\t\t</div>\n\t\n\t<!-- footer -->\n\t</footer>\n\t\n<!-- wrap -->\t\n</div>\t\n<script src=\"https://ajax.googleapis.com/ajax/libs/jquery/3.4.1/jquery.min.js\"></script>\n<script type=\"text/javascript\" src=\"./js/slick/slick.min.js\"></script>\t\