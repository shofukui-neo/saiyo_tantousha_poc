();\nmyDay     = myD.getDay();\nmyHours   = myD.getHours();\nmyMinutes = myD.getMinutes();\nmySeconds = myD.getSeconds();\n\nmyMess1   = myYear + \"年\" + myMonth + \"月\";\n/* 1行コメント(改行のケースBK) myMess1   = myYear + \"年<br>\" + myMonth + \"月\";　*/\nmyMess2   = myTbl[myDay] + \"曜日\";\nmyMess    = myMess1;\nmyMess3   = myMonth + \"月\";\n\ndocument.write( myMess );\n// -->\n</SCRIPT><!--月--></h2></th>\n    <td><h2><!--2022_12_15保留<span class=\"col01\">-->「お仕事のご相談」<!--2022_12_15保留</span>-->や「ドライバー求人情報」については、お気軽にお問合せください。</h2></td>\n\n</tr>\n\n\n\n\n\n\n\n\n<tr>\n  <th><h2>2026年4月</h2></th>\n    <td><h2><a href=\"javascript:void(0);\" onclick=\"window.open('topics/202604-1.html', '202604-1', 'width=713,height=850,menubar=no, toolbar=no,scrollbars=yes,top=100,left=630');\">\n運転者職場環境良好度認証制度（働きやすい職場）で☆☆を取得しました。</a>\n</h2></h2></td>\n</tr>  \n\n\n\n\n\n\n\n\n<tr>\n  <th><h2>2025年12月</h2></th>\n    <td><h2>宅配研修を実施しました。<br>（商品養生の徹底）</h2></td>\n</tr>\n\n<tr>\n  <th><h2>2025年11月</h2></th>\n    <td><h2>無事故表彰を行いました。</h2></td>\n</tr>\n\n<tr>\n  <th><h2>2025年11月</h2></th>\n    <td><h2>山形支所を閉鎖しました。<br>山形エリアの配送は仙台営業所で担当します。</h2></td>\n</tr>\n\n<tr>\n  <th><h2>2025年10月</h2></th>\n    <td><h2>宅配研修を実施しました。<br>（お客様との納品立ち合い徹底）</h2></td>\n</tr>\n\n<!--2026_01_14修正前 tr>-->\n<tr>\n  <th><h2>2025年10月</h2></th>\n    <td><h2><a href=\"javascript:void(0);\" onclick=\"window.open('topics/202510-1.html', '202510-1', 'width=743,height=570,menubar=no, toolbar=no,scrollbars=yes,top=100,left=630');\">\n郡山営業所の事務所のリニューアルが完了しました。</a>\n</h2></h2></td>\n</tr>\n\n<tr>\n  <th><h2>2025年7月</h2></th>\n    <td><h2>新卒者の採用に向けて学校訪問を開始しました。<br>（宮城県・福島県）</h2></td>\n</tr>\n\n<tr>\n  <th><h2>2025年7月</h2></th>\n    <td><h2>営業所に「熱中症予防」の注意喚起をしました。<br>\n（こまめな水分・塩分の補給、適切なエアコン使用、<br>\n　見守り・声がけ！）\n</h2></td>\n</tr>\n\n<tr>\n  <th><h2>2025年6月</h2></th>\n    <td><h2><a href=\"javascript:void(0);\" onclick=\"window.open('topics/202506-1.html', '202506-1', 'width=743,height=570,menubar=no, toolbar=no,scrollbars=yes,top=100,left=630');\">\n郡山営業所の屋根の塗装が完了しました。</a>\n</h2></h2></td>\n</tr>  \n\n<tr>\n  <th><h2>2025年6月</h2></th>\n    <td><h2>宅配研修を実施しました。<br>（商品搬入前後のお客様との確認 … 統一トーク）</h2></td>\n</tr>\n\n<tr>\n  <th><h2>2025年4月</h2></th>\n    <td><h2>福利厚生の充実に向けて外部の会員制サービスを導入しました。</h2></td>\n</tr>\n\n<tr>\n  <th><h2>2025年2月</h2></th>\n    <td><h2>宅配研修を実施しました。<br>（事故防止、安全対策）</h2></td>\n</tr>\n\n<tr>\n  <th><h2>2024年12月</h2></th>\n    <td><h2>アイスバーンや危険な雪道の運転について注意喚起しました。<br>（３つのアイスバーン、「急」の動作禁止）</h2></td>\n</tr>\n\n<tr>\n  <th><h2>2024年11月</h2></th>\n    <td><h2>宅配研修を実施しました。<br>（基本ルールの再確認Ⅱ）</h2></td>\n</tr>\n\n<tr>\n<th><h2>2024年10月</h2></th>\n<td><h2>仙台営業所が下記に移転しました。<br>\n所在地：〒983-0035<br>\n宮城県仙台市宮城野区日の出町３丁目３－１０<br>\n（営業所）<br>\nＴＥＬ：０２２－３５２－６７７１<br>\nＦＡＸ：０２２－３５２－６７７７<br>\n（配車センター）<br>\nＴＥＬ：０２２－３５２－６７９２<br>\nＦＡＸ：０２２－３５２－６７９３<br>\n</h2></td>\n</tr>\n\n<tr>\n  <th><h2>2024年8月</h2></th>\n    <td><h2><a href=\"javascript:void(0);\" onclick=\"window.open('topics/202408-1.html', '202408-1', 'width=713,height=850,menubar=no, toolbar=no,scrollbars=yes,top=100,left=630');\">\n郡山営業所にシャワー室が完成しました。</a>\n</h2></h2></td>\n</tr>  \n\n<tr>\n  <th><h2>2024年8月</h2></th>\n    <td><h2>宅配研修を実施しました。<br>（基本ルールの再確認）</h2></td>\n</tr>\n\n<tr>\n  <th><h2>2024年7月</h2></th>\n    <td><h2><a href=\"javascript:void(0);\" onclick=\"window.open('topics/202407-1.html', '202407-1', 'width=713,height=850,menubar=no, toolbar=no,scrollbars=yes,top=100,left=630');\">\nポスターを作成して、営業所に「熱中症予防」の注意喚起をしました。</a>\n</h2></h2></td>\n</tr>  \n\n<tr>\n  <th><h2>2024年7月</h2></th>\n    <td><h2>新卒者の採用に向けて学校訪問を開始しました。<br>（宮城県・福島県）</h2></td>\n</tr>\n\n<tr>\n  <th><h2>2024年5月</h2></th>\n    <td><h2>宅配研修を実施しました。<br>（接客・お客様との相互確認）</h2></td>\n</tr>\n\n<tr>\n  <th><h2>2024年4月</h2></th>\n    <td><h2><a href=\"javascript:void(0);\" onclick=\"window.open('topics/202404-1.html', '202404-1', 'width=713,height=570,menubar=no, toolbar=no,scrollbars=yes,top=100,left=630');\">\n入社式・新入社員研修を実施しました。</a></h2></td>\n</tr>  \n\n<tr>\n  <th><h2>2024年4月</h2></th>\n    <td><h2>2024年問題の適用開始にあたり、営業所に的確な業務コントロールを行うよう指示しました。</h2></td>\n</tr>\n\n<tr>\n  <th><h2>2024年3月</h2></th>\n    <td><h2><a href=\"javascript:void(0);\" onclick=\"window.open('topics/202403-1.html', '202403-1', 'width=713,height=780,menubar=no, toolbar=no,scrollbars=yes,top=100,left=630');\">\nポスターを作成して、営業所に「事故防止」の注意喚起をしました。</a>\n<br/>\n<h2>（家屋・商品事故、車両事故）</h2></h2></td>\n</tr>  \n\n<tr>\n  <th><h2>2024年2月</h2></th>\n    <td><h2>宅配研修を実施しました。<br>（搬入時の助手との連携、コミュニケーション）</h2></td>\n</tr>\n\n<tr>\n  <th><h2>2024年1月</h2></th>\n    <td><h2><a href=\"javascript:void(0);\" onclick=\"window.open('topics/202401-1.html', '202401-1', 'width=713,height=850,menubar=no, toolbar=no,scrollbars=yes,top=100,left=630');\">\nテールゲートリフターの特別教育を実施しました。</a></h2></td>\n</tr>  \n\n<tr>\n  <th><h2>2023年12月</h2></th>\n    <td><h2>宅配研修を実施しました。<br>（お客様の期待を「満足」に変える接客）</h2></td>\n</tr>\n\n<tr>\n  <th><h2>2023年12月</h2></th>\n    <td><h2><a href=\"javascript:void(0);\" onclick=\"window.open('topics/202312-1.html', '202312-1', 'width=713,height=780,menubar=no, toolbar=no,scrollbars=yes,top=100,left=630');\">\n運転者職場環境良好度認証制度に合格しました。</a></h2></td>\n</tr>  \n\n<tr>\n<th><h2>2023年11月</h2></th>\n    <td><h2><a href=\"javascript:void(0);\" onclick=\"window.open('topics/202311-1.html', '202311-1', 'width=713,height=850,menubar=no, toolbar=no,scrollbars=yes,top=100,left=630');\">\n無事故表彰を行いました。</a></h2></td>\n</tr>\n\n<tr>\n  <th><h2>2023年10月</h2></th>\n    <td><h2><a href=\"javascript:void(0);\" onclick=\"window.open('topics/202310-1.html', '202310-1', 'width=713,height=780,menubar=no, toolbar=no,scrollbars=yes,top=100,left=630');\">\n宅配研修を実施しました。（商品・家屋養生）</a></h2></td>\n</tr>  \n\n<tr>\n  <th><h2>2023年9月</h2></th>\n    <td><h2>インフルエンザ感染の流行が始まったため、営業所に「早期予防接種」を指示しました。</h2></td>\n</tr>\n\n<tr>\n  <th><h2>2023年8月</h2></th>\n    <td><h2>新型コロナウイルス感染第9波拡大ため、営業所に「感染防止対策の徹底」」をしました。</h2></td>\n</tr>\n\n<tr>\n  <th><h2>2023年8月</h2></th>\n    <td><h2>川口営業所駐車場の出入口を整備しました。</h2></td>\n</tr>\n\n<tr>\n  <th><h2>2023年7月</h2></th>\n    <td><h2>営業所に「熱中症予防」の注意喚起をしました。<br>\n（こまめな水分・塩分の補給、適切なエアコン使用、<br>\n　見守り・声がけ！）\n</h2></td>\n</tr>\n\n<tr>\n  <th><h2>2023年6月</h2></th>\n    <td><h2>改正労働安全衛生規則等説明会に参加しました。<br>\n（テールゲートリフター・昇降設備及び保安帽の改正）\n</h2></td>\n</tr>\n\n<tr>\n  <th><h2>2023年5月</h2></th>\n    <td><h2><a href=\"javascript:void(0);\" onclick=\"window.open('topics/202305-1.html', '202305-1', 'width=713,height=780,menubar=no, toolbar=no,scrollbars=yes,top=100,left=630');\">\n宅配研修を実施しました。（吊上げ搬入）</a></h2></td>\n</tr>  \n\n<tr>\n  <th><h2>2023年4月</h2></th>\n    <td><h2><a href=\"javascript:void(0);\" onclick=\"window.open('topics/202304-1.html', '202304-1', 'width=713,height=570,menubar=no, toolbar=no,scrollbars=yes,top=100,left=630');\">\n入社式・新入社員研修を実施しました。</a></h2></td>\n</tr>  \n\n<tr>\n<th><h2>2023年2月</h2></th>\n    <td><h2><a href=\"javascript:void(0);\" onclick=\"window.open('topics/202303-1.html', '202303-1', 'width=713,height=850,menubar=no, toolbar=no,scrollbars=yes,top=100,left=630');\">\n宅配研修を実施しました。（冷蔵庫搬入）</a><br />\n（仙台・郡山・いわき・盛岡営業所）</h2></td>\n<!--2026_01_14修正追加-->\n</tr>\n\n<tr>\n  <th><h2>2022年7月</h2></th>\n    <td><h2>営業所に「熱中症対策」の注意喚起をしました。<br>\n（体調管理・こまめな休憩、水分・塩分の補給、対策グッズの使用）</h2></td>\n  </tr>\n\n   <tr>\n  <th><h2>2022年6月</h2></th>\n    <td><h2>技術物流連合会（ＳＵＪ）主催の発表会に参加しました。<br>\n<br>\n新型コロナウイルス感染の拡大ため、営業所に「感染防止対策の徹底」」をしました。</h2></td>\n  </tr>\n\n   <tr>\n  <th><h2>2021年1月</h2></th>\n    <td><h2>戸田営業所移転のご案内<br><br>戸田営業所が移転に伴い\nこのたび 川口営業所と名称を変更しましたのでご案内申し上げます。\n<br>\n所在地：埼玉県川口市戸塚南1丁目1-23-202\n<br><br>\n今後とも変わらぬご愛顧を賜りますようお願い申し上げます</h2></td>\n  </tr>\n\n   <tr>\n  <th><h2>2019年5月</h2></th>\n    <td><h2>仙台営業所移転のご案内<br><br>\nこのたび 仙台営業所は下記に移転することになりましたのでご案内申し上げます。<br>\n所在地：〒983-0001<br>\n宮城県仙台市宮城野区港４丁目１５－１３<br>\nＤＰＬ仙台港１階Ａ区画<br><br>\n営業所直通<br>\nＴＥＬ：０２２－３５２－６７７１<br>\nＦＡＸ：０２２－３５２－６７７７<br><br>\n配車センター直通<br>\nＴＥＬ：０２２－３５２－６７９２<br>\nＦＡＸ：０２２－３５２－６７９３<br><br>\n今後とも変わらぬご愛顧を賜りますようお願い申し上げます。</h2></td>\n</tr>\n  \n<tr>\n  <th><h2>2019年2月</h2></th>\n    <td><h2>山形営業所が移転しました。</h2></td>\n  </tr>\n    \n  <tr>\n  <th><h2>2017年6月</h2></th>\n    <td><h2>盛岡営業所が移転しました。<br>\n仙台営業所を実施側としてと5営業所間でIT点呼を開始しました。</h2></td>\n  </tr>\n  \n  <tr>\n  <th><h2>2016年12月</h2></th>\n    <td><h2>久喜、新潟、盛岡営業所にて新規Gマーク認定取得。<br>\n      仙台、郡山と合わせて、5営業所がGマーク認定事業所となりました。</h2></td>\n  </tr>\n    \n  <tr>\n  <th><h2>2016年10月</h2></th>\n    <td><h2>運行管理者試験合格者4名 資格保有者36名となりました。</h2></td>\n  </tr>\n  \n  <tr>\n  <th><h2>2016年5月</h2></th>\n    <td><h2>仙台に統括配車センターを設立しました。</h2></td>\n  </tr>\n  \n  <tr>\n  <th><h2>2016年4月</h2></th>\n    <td><h2>関東エリアにてダンプ車両稼働しました。</h2></td>\n  </tr>\n  \n  <tr>\n  <th><h2>2016年1月</h2></th>\n    <td><h2>産業廃棄物中間処分場として事業開始いたしました。</h2></td>\n  </tr>\n  \n  <th><h2>2015年12月</h2></th>\n    <td><h2>産業廃棄物処分業許可産業廃棄物中間処分場として許可が下りました。</h2></td>  \n  <tr>\n    <th><h2>2015年1月</h2></th>\n    <td><h2>川崎営業所開設<br>\n      一般貨物自動車運送事業/自動車運送取扱事業<br>\n      の営業を開始いたしました。</h2></td>\n  </tr>\n  \n  <tr>\n    <th><h2>2014年12月<!--2023_02_16コメントアウト　2日--></h2></th>\n    <td><h2>株式会社 LJP(エルジェイピー) <br>\n      一般貨物自動車運送事業/貨物運送取扱事業/自動車運送取扱事業 -ウェブサイトをリニューアル致しました。</h2></td>\n  </tr>\n</table>\n\n  \n  </div><!--scroll01 End-->\n   \n  </div><!--t-box01 End--> \n  \n  </div><!-- leftBox01 End-->\n  \n  \n  \n   <div class=\"rightBox01\">\n  \n  <div class=\"t-box02\">\n  \n  \n  <h2>宮城県仙台市を起点に、東北および関東エリアにおいて<br>\n主に「大型幹線輸送」と「宅配サービス」を展開しています！<br>\n<br>\n長年の物流業で培ったノウハウを活かし、物流のプロとして<br>\n多くのお客様にソリューションを提供しています。</h2>\n\n<img src=\"img/top/map.png\" alt=\"株式会社 LJP(エルジェイピー)一般貨物自動車運送事業/貨物運送取扱事業/自動車運送取扱事業は、宮城県仙台市を起点に、東北および関東エリアにおいて主に「大型幹線輸送」と「宅配サービス」を展開しています。\" class=\"max-width\">\n\n<div class=\"insta\"><a href=\"https://www.instagram.com/logistics.joint.project/\" target=\"_blank\"><img src=\"img/top/InstagramIcon.png\" alt=\"ＬＪＰのｉｎｓｔａｇｒａｍ(インスタグラム)もご覧ください！\" width=\"35\" height=\"36\">\n<h2>ＬＪＰのInstagramもご覧ください！</h2></a>\n</div><!-- / insta -->  \n  \n   \n  </div><!--t-box02 End-->\n  \n  </div><!-- rightBox01 End-->\n  \n  </div><!--box002 End-->   \n  \n\n<div class=\"height-space80\"></div><!-- / height-space80 -->\n\n<div class=\"gmark\">\n  <p><img src=\"img/body/gmark.png\" width=\"69\" height=\"68\">ＬＪＰは国土交通省が推進するＧマークを取得して、輸送の安全確保に積極的に取り組んでいます。<br>\n    （法令順守、安全運転、安全対策）</p>\n</div><!-- / gmark -->\n\n\n<div class=\"height-space20\"></div><!-- / height-space20 -->\n\n\n  \n<p>当社の個人情報保護方針は<span class=\"privacy\"><a href=\"privacy/index.html\"><span class=\"privacy\">プライバシーポリシー</span></a></span>をご覧ください。</p>\n\n \n<div class=\"pagetop\">\n  \n  <div class=\"top\"><a href=\"#top\"><em>株式会社 LJP(エルジェイピー)このページのトップ</em></a></div><!--top End-->\n    \n </div><!--upBtn End-->\n \n \n </div><!--bodyContents End-->\n \n \n \n<!-- #BeginLibraryItem \"/Library/lowerNavi01.lbi\" -->\n<div id=\"footNavi\">\n \n   <table width=\"510\" border=\"0\" class=\"t002\">\n  <tr>\n    <td><a href=\"index.html\">ホーム</a></td>\n    <td><a href=\"company/index.html\">会社案内</a></td>\n    <td><a href=\"philosophy/index.html\">企業理念</a></td>\n    <td><a href=\"business/index.html\">事業案内</a></td>\n    <td><a href=\"office_guide/index.html\"><!--事業所案内-->ネットワーク</a></td>\n    <td><a href=\"cgi-bin/recruit/index.html\">リクルート</a></td>\n    <td><a href=\"safety/index.html\"><span class=\"font03\">安全への取り組み</span></a></td>\n    <td><a href=\"cgi-bin/job/index.html\"><!--お問い合わせ-->お問合せ</a></td>\n  </tr>\n  <tr>\n  <!--  <td><a href=\"http://www.ljp.co.jp/greeting/\">代表挨拶</a></td>\n    <td><a href=\"http://www.ljp.co.jp/history/\">沿革</a></td>\n    <td><a href=\"http://www.ljp.co.jp/company/\">会社概要</a></td>\n    <td><a href=\"http://www.ljp.co.jp/philosophy/\">経営理念</a></td>　-->\n    <td><a href=\"business/index.html#guide01\">大型幹線部門</a></td>\n  <!--  <td><a href=\"http://www.ljp.co.jp/business/index.html#guide02\"><span class=\"font03\">復興支援事業<br>\n      部門</span></a></td>　-->\n    <td><a href=\"business/index.html#guide03\">宅配事業部門</a></td>\n    <td><a href=\"business/index.html#guide04\"><!--家電・<br>-->工事部門</a></td>\n    <td><a href=\"business/index.html#guide05\">産業廃棄物処理<!--<br>事業--></a></td>\n    <td><a href=\"office_guide