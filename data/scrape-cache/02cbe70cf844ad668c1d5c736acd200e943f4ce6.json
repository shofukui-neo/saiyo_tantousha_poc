{"url":"https://www.pro-win.co.jp/recruit/vision/","html":"<!doctype html>\r\n<html>\r\n<head>\r\n<meta charset=\"utf-8\">\r\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1, user-scalable=no\">\r\n<meta name=\"format-detection\" content=\"telephone=no\">\r\n<title>ビジョン｜株式会社ウイン 採用情報</title>\r\n<meta name=\"keywords\" content=\"\">\r\n<meta name=\"description\" content=\"\">\r\n<!-- common -->\r\n<link href=\"../common/css/base.css\" rel=\"stylesheet\" type=\"text/css\">\r\n<link href=\"../common/css/common.css\" rel=\"stylesheet\" type=\"text/css\">\r\n<link href=\"../common/css/contents.css\" rel=\"stylesheet\" type=\"text/css\">\r\n<link rel=\"icon\" href=\"/common/images/favicon.svg\" type=\"image/svg\">\r\n<!--[if lt IE 9]>\r\n<script src=\"http://html5shim.googlecode.com/svn/trunk/html5.js\"></script>\r\n<![endif]-->\r\n<script src=\"http://ajax.googleapis.com/ajax/libs/jquery/1.8.2/jquery.min.js\"></script>\r\n<script src=\"../common/js/jquery.cookie.js\" type=\"text/javascript\"></script>\r\n<script type=\"text/javascript\" src=\"../common/js/jquery.set.js\"></script>\r\n<script type=\"text/javascript\" src=\"../common/js/heightLine.js\"></script>\r\n<script type=\"text/javascript\" src=\"../common/js/scrollsmoothly.js\"></script>\r\n<script src=\"//kitchen.juicer.cc/?color=Hvo/yBbwnSM=\" async></script>\n<!-- Google tag (gtag.js) -->\n\t<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-3MKRWRKFDZ\"></script>\n\t<script>\n\t\twindow.dataLayer = window.dataLayer || [];\n\n\t\tfunction gtag() {\n\t\t\tdataLayer.push(arguments);\n\t\t}\n\t\tgtag('js', new Date());\n\n\t\tgtag('config', 'G-3MKRWRKFDZ');\n\n\t</script>\n<!-- Begin Mieruca Embed Code -->\n<script type=\"text/javascript\" id=\"mierucajs\">\nwindow.__fid = window.__fid || [];__fid.push([806551535]);\n(function() {\nfunction mieruca(){if(typeof window.__fjsld != \"undefined\") return; window.__fjsld = 1; var fjs = document.createElement('script'); fjs.type = 'text/javascript'; fjs.async = true; fjs.id = \"fjssync\"; var timestamp = new Date;fjs.src = ('https:' == document.location.protocol ? 'https' : 'http') + '://hm.mieru-ca.com/service/js/mieruca-hm.js?v='+ timestamp.getTime(); var x = document.getElementsByTagName('script')[0]; x.parentNode.insertBefore(fjs, x); };\nsetTimeout(mieruca, 500); document.readyState != \"complete\" ? (window.attachEvent ? window.attachEvent(\"onload\", mieruca) : window.addEventListener(\"load\", mieruca, false)) : mieruca();\n})();\n</script>\n<!-- End Mieruca Embed Code -->\n</head>\r\n\r\n<body id=\"PageVision\">\r\n<!-- skip_nav -->\r\n<div id=\"page_top\">\r\n  <p class=\"skip\">ページの先頭です。</p>\r\n  <p class=\"skip\"><a href=\"#skip_menu\">メインメニューへ移動します。</a></p>\r\n  <p class=\"skip\"><a href=\"#skip_honbun\">本文へ移動します。</a></p>\r\n  <p class=\"skip\"><a href=\"#skip_footer\">フッターへ移動します。</a></p>\r\n</div>\r\n<!-- /skip_nav --> \r\n\r\n<!-- // Header START // -->\r\n<header>\r\n<div id=\"HeadSubMenu\">\r\n<ul class=\"clearfix\">\r\n  <li><a href=\"/inquiry/\">お問い合わせ</a></li>\r\n  <li><a href=\"/profile/office.html\">アクセス</a></li>\r\n  <li><a href=\"/\">ウインコーポレートサイト</a></li>\r\n</ul>\r\n</div><!-- /#HeadSubMenu -->\r\n\r\n<p id=\"skip_menu\" class=\"skip\">メインメニューです。</p>\r\n<div id=\"HeadEntryMenu\" class=\"clearfix\">\r\n  <div class=\"innerBlock\">\r\n    <p><a href=\"/recruit/\"><img src=\"/recruit/common/images/logo.png\" width=\"388\" height=\"34\" alt=\"株式会社ウイン 採用情報\"/></a></p>\r\n    <ul class=\"clearfix button\">\r\n      <li><a href=\"/recruit/entry/#section01\">新卒採用</a></li>\r\n      <li><a href=\"/recruit/entry/#section02\">キャリア採用</a></li>\r\n    </ul>\r\n  </div>\r\n</div><!-- /#HeadEntryMenu --><div id=\"HeadGlobalMenu\">\r\n  <ul class=\"clearfix button\">\r\n    <li><a href=\"/recruit/vision/\">ビジョン</a></li>\r\n    <li><a href=\"/recruit/seek/\">求める人材</a></li>\r\n    <li><a href=\"/profile/approach.html\">ウインの取組み</a></li>\r\n    <li><a href=\"/recruit/department/\">部署紹介</a></li>\r\n    <li><a href=\"/recruit/jobcategory/\">募集職種</a></li>\r\n    <li><a href=\"/recruit/flow/\">採用の流れ</a></li>\r\n  </ul>\r\n</div><!-- /#HeadGlobalMenu --></header>\r\n<!-- // Header END // -->\r\n\r\n\r\n<!-- // Contents START // -->\r\n\r\n<!-- topicPath -->\r\n<div id=\"topicPath\">\r\n</div>\r\n<!-- /topicPath -->\r\n\r\n<p id=\"skip_honbun\" class=\"skip\">本文です。</p>\r\n\r\n<h1>ビジョン<span>Vision</span></h1>\r\n\r\n\r\n<p class=\"copy\">当社は、「お客さま」の夢を<strong>叶え</strong>、「従業員」と共に<strong>成長</strong>し、<br>\r\n「ビジネスパートナー様」に<strong>感謝</strong>し、そして「地域社会」に<strong>貢献</strong>し、<br>\r\nそれらに広く愛され、皆様からの信頼を得るとともに、法令・企業倫理を厳守し、<br>地域の模範企業となるべく、努力を惜しまず続けてまいります。</p>\r\n\r\n<section class=\"clearfix\">\r\n\t<div>\r\n    <h2>お客様の夢を叶える</h2>\r\n    <p>お客様への提案スタンスは、ただ問題を解決するためのソリューションを提供するだけではありません。</p>\r\n    <p>お客様の現状維持が目的ではなく、現状からの更なる発展、そして将来的な目標の達成に向けて、共に足並みを揃え、時には一歩先を行き、さまざまな角度から夢の実現をご提案します。</p>\r\n  </div>\r\n\r\n\t<div class=\"no\">\r\n    <h2>従業員と共に成長</h2>\r\n    <p>従業員の成長が企業を成長させるという考えのもとに、企業と従業員が共に成長できる環境づくりを日々目指しています。</p>\r\n    <p>また、従業員とその家族の発展も大切なものと考え、子育て支援や介護支援にも積極的に取り組んでいます。</p>\r\n  </div>\r\n\r\n\t<div>\r\n    <h2>ビジネスパートナー様に感謝</h2>\r\n    <p>当社のビジネスは、ご協業いただくビジネスパートナー様の存在無くして、成り立つものではありません。</p>\r\n    <p>提供いただくソリューション・リソース、そしてご提案に感謝の気持ちを忘れず、win-winの関係を築くことを基本方針としています。</p>\r\n  </div>\r\n\r\n\t<div class=\"no\">\r\n    <h2>地域社会に貢献</h2>\r\n    <p>当社は、地域社会の発展に貢献することが、愛媛県松山市発進の企業として、地元地域社会の一員としての存在意義と考えています。</p>\r\n    <p>「地域スポーツ活動の応援」「地域清掃」「防犯協力」その他さまざまなCSR活動に積極的に取組み、地域の皆様から信頼される企業として、役割と責任を果たすことに努めます。</p>\r\n  </div>\r\n</section>\r\n\r\n<!-- // Contents END // -->\r\n\r\n\r\n<!-- // Footer START // -->\r\n<footer>\r\n<div id=\"FooterNavi\" class=\"button\">\r\n<ul class=\"col2 clearfix\">\r\n  <li><a href=\"/recruit/entry/#section01\">新卒採用</a></li>\r\n  <li><a href=\"/recruit/entry/#section02\">キャリア採用</a></li>\r\n</ul>\r\n<ul class=\"col3 clearfix\">\r\n  <li><a href=\"/recruit/department/\">部署紹介</a></li>\r\n  <li><a href=\"/recruit/jobcategory/\">募集職種</a></li>\r\n  <li><a href=\"/recruit/flow/\">採用の流れ</a></li>\r\n</ul>\r\n</div><!-- /#FooterNavi -->\r\n<div id=\"gotop\"><a href=\"#page_top\"><img class=\"imgover\" src=\"/recruit/common/images/btn_pagetop.png\" width=\"70\" height=\"70\" alt=\"このページの一番上へ\" /></a></div> \r\n<p id=\"skip_footer\" class=\"skip\">フッターです。</p>\r\n</footer>\r\n<!-- // Footer END // -->\r\n\r\n\r\n</body>\r\n</html>\r\n","finalUrl":"https://www.pro-win.co.jp/recruit/vision/","rendered":false,"_cachedAt":"2026-06-22T16:02:08.286Z"}