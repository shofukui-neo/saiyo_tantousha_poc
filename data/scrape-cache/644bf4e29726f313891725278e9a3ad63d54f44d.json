lex\">\n                                <li><a class=\"logo\" href=\"../\"><img src=\"../assets/img/common/header_logo.png\" alt=\"住商エアロシステム株式会社\"></a></li>\n                                <li><p>新卒採用サイト</p></li>\n                            </ul>\n                        </div>\n                        <div class=\"right\">\n                            <ul class=\"flex\">\n                                <li><a id=\"menu-entry\" href=\"../info/requirements.html#entry\"><p>ENTRY</p></a></li>\n                                <li><button id=\"menu-btn\"><span class=\"icon\"></span></button></li>\n                            </ul>\n                        </div>\n                    </div>\n                </div>\n            </header>\n\n\n\n            <div id=\"menu\">\n                <div id=\"menu-overlay\"></div>\n                <div id=\"menu-list\">\n                    <div class=\"inner900\">\n                        <div class=\"flex\">\n                            <div class=\"col\">\n                                <div class=\"box\">\n                                    <div class=\"parent\"><a href=\"../\"><p class=\"font--serif\">TOP</p></a></div>\n                                </div>\n\n                                <div class=\"box\">\n                                    <div class=\"parent\"><a href=\"../message/\"><p class=\"font--serif\">社長メッセージ</p></a></div>\n                                </div>\n\n                                <div class=\"box\">\n                                    <div class=\"parent\"><a class=\"accordion-btn--sp\"><p class=\"font--serif\">会社を知る</p></a></div>\n                                    <ul class=\" accordion-body--sp\">\n                                        <li class=\"child\"><a href=\"../company/\"><p>企業概要</p></a></li>\n                                        <li class=\"child\"><a href=\"../company/info.html\"><p>住商エアロシステムの機能</p></a></li>\n                                        <li class=\"child\"><a href=\"../company/movie.html\"><p>動画ギャラリー</p></a></li>\n                                    </ul>\n                                </div>\n\n                                <div class=\"box\">\n                                    <div class=\"parent\"><a class=\"accordion-btn--sp\"><p class=\"font--serif\">ビジネスを知る</p></a></div>\n                                    <ul class=\" accordion-body--sp\">\n                                        <li class=\"child\"><a href=\"../business/#business-pro\"><p>防衛・航空宇宙の専門商社</p></a></li>\n                                        <li class=\"child\"><a href=\"../business/#business-sas\"><p>SAS Business</p></a></li>\n                                    </ul>\n                                </div>\n                            </div>\n                            <div class=\"col\">\n                                <div class=\"box\">\n                                    <div class=\"parent\"><a class=\"accordion-btn--sp\"><p class=\"font--serif\">社員を知る</p></a></div>\n                                    <ul class=\" accordion-body--sp\">\n                                        <li class=\"child\"><a href=\"../staff/member04.html\"><p>総合職</p></a></li>\n                                        <li class=\"child\"><a href=\"../staff/member02.html\"><p>総合職</p></a></li>\n                                        <li class=\"child\"><a href=\"../staff/member03.html\"><p>管理職</p></a></li>\n                                    </ul>\n                                </div>\n                                <div class=\"box\">\n                                    <div class=\"parent\"><a class=\"accordion-btn--sp\"><p class=\"font--serif\">採用情報</p></a></div>\n                                    <ul class=\" accordion-body--sp\">\n                                        <li class=\"child\"><a href=\"../info/requirements.html\"><p>募集要項</p></a></li>\n                                        <li class=\"child\"><a href=\"../info/personality.html\"><p>求める人材像</p></a></li>\n                                        <li class=\"child\"><a href=\"../info/event.html\"><p>イベント情報</p></a></li>\n                                    </ul>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n\n            <div id=\"mv\" class=\"size--default\">\n                <div class=\"bg\"></div>\n\n                <div class=\"inside\">\n                    <h1>募集要項</h1>\n                </div>\n            </div>\n\n\n\n            <main>\n                <article>\n                    <section id=\"info-requirements-body\">\n                        <div class=\"inner900\">\n                            <div class=\"h2\"><h2 class=\"font--serif\">2027年度入社の方向け募集要項</h2></div>\n                            <div class=\"list--basic\">\n                                <ul>\n                                    <li>\n                                        <div class=\"dt\"><p>募集内容</p></div>\n                                        <div class=\"dd\">\n                                            <p>\n                                                総合職：東京本社・中部支社配属<br>\n                                                ※配属予定：営業、管理<br>\n                                                ※総合職は転勤あり<br>\n                                                ※海外駐在（ニューヨーク、ロンドン）<br>\n                                                ※事務職募集については決定次第公表します\n                                            </p>\n                                        </div>\n                                    </li>\n\n                                    <li>\n                                        <div class=\"dt\"><p>初任給</p></div>\n                                        <div class=\"dd\">\n                                            <p>\n                                                総合職（月給）<br>\n                                                大卒　269,000円<br>\n                                                院卒　277,000円\n                                            </p>\n                                        </div>\n                                    </li>\n\n                                    <li>\n                                        <div class=\"dt\"><p>勤務地</p></div>\n                                        <div class=\"dd\">\n                                            <p>\n                                                東京、名古屋\n                                            </p>\n                                        </div>\n                                    </li>\n\n                                    <li>\n                                        <div class=\"dt\"><p>勤務時間</p></div>\n                                        <div class=\"dd\">\n                                            <p>\n                                                9：15 ～ 17：30 または9：30～17：45　(12：00～13：00休憩)<br>\n                                                ※フレックスタイム制度あり\n                                            </p>\n                                        </div>\n                                    </li>\n\n                                    <li>\n                                        <div class=\"dt\"><p>福利厚生</p></div>\n                                        <div class=\"dd\">\n                                            <p>\n                                                通勤費支給、各種社会保険、確定拠出年金、<br class=\"pcshow\">企業年金制度、財形制度、福利厚生倶楽部会員　等\n                                            </p>\n                                        </div>\n                                    </li>\n\n                                    <li>\n                                        <div class=\"dt\"><p>休日休暇</p></div>\n                                        <div class=\"dd\">\n                                            <p>\n                                                土・日・祝日　他、当社規定に定める休暇　等\n                                            </p>\n                                        </div>\n                                    </li>\n\n                                    <li>\n                                        <div class=\"dt\"><p>昇給・賞与・諸手当</p></div>\n                                        <div class=\"dd\">\n                                            <p>\n                                                昇給／年１回<br>\n                                                賞与／年２回<br>\n                                                手当／残業手当　他\n                                            </p>\n                                        </div>\n                                    </li>\n\n                                    <li>\n                                        <div class=\"dt\"><p>採用実績校</p></div>\n                                        <div class=\"dd\">\n                                            <p>\n                                                青山学院大学・大阪大学・お茶の水女子大学・関西大学・関西外国語大学・関西学院大学・神田外語大学・京都大学・慶應義塾大学・神戸大学・駒澤大学・上智大学・成城大学・清泉女子大学・千葉大学・中央大学・津田塾大学・東京理科大学大学院・同志社大学・奈良女子大学大学院・南山大学・明治大学・立教大学・立命館大学・早稲田大学　他\n                                            </p>\n                                        </div>\n                                    </li>\n\n                                    <li>\n                                        <div class=\"dt\"><p>採用予定学部学科</p></div>\n                                        <div class=\"dd\">\n                                            <p>\n                                                四年制大学、大学院\n                                            </p>\n                                        </div>\n                                    </li>\n\n                                    <li>\n                                        <div class=\"dt\"><p>採用予定数／実績</p></div>\n                                        <div class=\"dd\">\n                                            <p>\n                                                2027年4月　採用予定　若干名（総合職）<br>\n                                                2026年4月　予定1名（総合職1名）<br>\n                                                2025年4月　実績2名（総合職2名）<br>\n                                                2023年4月　実績 2名（総合職2名）<br>\n                                                2022年4月　実績 2名（総合職2名）<br>\n                                                2021年4月　実績 2名（総合職2名）<br>\n                                                2020年4月　実績 8名（総合職4名、事務職4名）<br>\n                                                2019年4月　実績 6名（総合職4名、事務職2名）\n                                            </p>\n                                        </div>\n                                    </li>\n\n                                    <li>\n                                        <div class=\"dt\"><p>　</p></div>\n                                        <div class=\"dd\">\n                                            <p class=\"color--red\">※イベント情報・エントリー詳細情報については<a href=\"event.html\">こちら</a></p>\n                                        </div>\n                                    </li>\n                                </ul>\n                            </div>\n                        </div>\n                    </section>\n\n\n\n                    <section id=\"entry\">\n                        <div class=\"inner900\">\n                            <div class=\"h2\"><h2 class=\"font--serif\">エントリー</h2></div>\n                            <div class=\"inside\">\n\n                                <div class=\"end-message\"><p>2027年度新卒採用・総合職の<br class=\"spshow\">新規エントリーについて</p></div>\n                                <div class=\"box\">\n                                    <p>\n                                        <span class=\"color--red bold\">第1期・第2期のエントリーは終了いたしました。<br>\n                                        たくさんのご応募をいただき、ありがとうございました。<br>\n                                        今後の採用情報は、採用ホームページにて随時ご案内いたします。</span>\n\n                                        <!--<span class=\"color--red bold\">エントリーは下記リンクよりお願いいたします。</span><br>\n                                        なお、当社の新卒採用においては、会社説明会へのご参加を必須としております。<br>\n                                        日程は「<a href=\"event.html\">イベント情報</a>」にも記載しておりますが、<br>\n                                        エントリー後、マイページよりご予約をお願いいたします。<br>\n                                        <span class=\"color--red bold\">※第2期会社説明会の予約開始しています。</span>-->\n                                    </p>\n                                    <div class=\"btn\">\n                                        <!--<a href=\"https://sc-aero-recruit.snar.jp/jobboard/detail.aspx?id=t1o0ACf8ltE\" target=\"_blank\"><p>エントリー</p></a>-->\n                                        <a class=\"cs\" href=\"https://sc-aero-recruit.snar.jp/jobboard/detail.aspx?id=t1o0ACf8ltE\" target=\"_blank\"><p>エントリー受付終了</p></a>\n                                    </div>\n                                </div>\n                            </div>\n                        </div>\n                    </section>\n                </article>\n            </main>\n\n            <div id=\"footer-message\">\n                <div class=\"inside\">\n                    <div class=\"ph\"><img src=\"../assets/img/common/footer_copy.png\" alt=\"あたりまえを衞り続ける\"></div>\n                </div>\n            </div>\n            <footer class=\"child info requirements\">\n                <div class=\"upper\">\n                    <div class=\"inner1000\">\n                        <ul class=\"flex\">\n                            <li>\n                                <ol>\n                                    <li class=\"parent\"><a href=\"../\"><p>TOP</p></a></li>\n                                    <li class=\"child\"><a href=\"../info/requirements.html#entry\"><p>エントリー</p></a></li>\n                                    <li class=\"child\"><a class=\"blank\" href=\"https://www.sc-aero.co.jp/index.html\" target=\"_blank\"><p>コーポレートサイト</p></a></li>\n                                </ol>\n                            </li>\n                            <li>\