{"url":"http://meinyuu-matsuura.co.jp/","html":"<!doctype html>\n<html lang=\"ja\">\n  <head>\n    <!-- Google Tag Manager -->\n    <script>\n      (function (w, d, s, l, i) {\n        w[l] = w[l] || [];\n        w[l].push({ \"gtm.start\": new Date().getTime(), event: \"gtm.js\" });\n        var f = d.getElementsByTagName(s)[0],\n          j = d.createElement(s),\n          dl = l != \"dataLayer\" ? \"&l=\" + l : \"\";\n        j.async = true;\n        j.src = \"https://www.googletagmanager.com/gtm.js?id=\" + i + dl;\n        f.parentNode.insertBefore(j, f);\n      })(window, document, \"script\", \"dataLayer\", \"GTM-MHHTS2\");\n    </script>\n    <!-- End Google Tag Manager -->\n    <meta charset=\"UTF-8\" />\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n    <meta http-equiv=\"X-UA-Compatible\" content=\"ie=edge\" />\n    <meta\n      name=\"Description\"\n      content=\"広島県福山市に本社のある株式会社 明乳松浦は、(株)明治特約店です。お客様の健康を第一に考えて、健康と安心をお届けしています。\"\n    />\n    <meta\n      name=\"Keywords\"\n      content=\"牛乳,宅配,サービス,明乳松浦,まつうら,明治,明治乳業\"\n    />\n    <title>株式会社 明乳松浦</title>\n    <link rel=\"stylesheet\" href=\"css/style.css\" />\n  </head>\n  <body>\n    <!-- Google Tag Manager (noscript) -->\n    <noscript\n      ><iframe\n        src=\"https://www.googletagmanager.com/ns.html?id=GTM-MHHTS2\"\n        height=\"0\"\n        width=\"0\"\n        style=\"display: none; visibility: hidden\"\n      ></iframe\n    ></noscript>\n    <!-- End Google Tag Manager (noscript) -->\n\n    <header class=\"l-header\">\n      <h1 class=\"l-header__logo\">\n        <a href=\"\" target=\"_blank\" rel=\"noopener\"\n          ><img\n            src=\"img/header-logo.webp\"\n            alt=\"株式会社明乳松浦\"\n            width=\"108\"\n            height=\"171\"\n        /></a>\n      </h1>\n      <p class=\"l-header__joblist hidden-sp\">\n        <a href=\"recruit/index.html\">求人情報はこちら</a>\n      </p>\n      <p class=\"l-header__sampleform hidden-sp\">\n        <a href=\"contact/index.html\">サンプル申し込みフォーム</a>\n      </p>\n      <nav class=\"l-nav js-nav\">\n        <div class=\"l-nav-inner\">\n          <ul class=\"l-nav-list\">\n            <li class=\"l-nav-list__item\"><a href=\"index.html\">TOP</a></li>\n            <li class=\"l-nav-list__item\">\n              <a href=\"products/index.html\">明乳松浦のおすすめ商品</a>\n            </li>\n            <li class=\"l-nav-list__item\">\n              <a href=\"office/index.html\">営業所案内</a>\n            </li>\n            <li class=\"l-nav-list__item\">\n              <a href=\"contact/index.html\">サンプル申し込みフォーム</a>\n            </li>\n          </ul>\n          <p class=\"l-nav__joblist\">\n            <a href=\"recruit/index.html\">求人情報はこちら</a>\n          </p>\n          <p class=\"l-nav__sampleform\">\n            <a href=\"contact/index.html\">サンプル申し込みフォーム</a>\n          </p>\n        </div>\n        <div class=\"l-nav-overlay js-nav-overlay\"></div>\n      </nav>\n      <div class=\"gnavBtn js-nav-btn\">\n        <span></span><span></span><span></span>\n      </div>\n    </header>\n\n    <div class=\"homeMv l-mv\">\n      <div class=\"homeMv-txtBox l-mv-txtBox\">\n        <p class=\"homeMv__txt01\">\n          <img\n            src=\"img/home/txt_mv01.svg\"\n            alt=\"株式会社 明乳松浦\"\n            width=\"615\"\n            height=\"65\"\n          />\n        </p>\n        <p class=\"homeMv__txt02\">\n          <img\n            src=\"img/home/txt_mv02_pc.svg\"\n            alt=\"広島県福山市に本社のある株式会社 明乳松浦は、お客様の健康を第⼀に考えて、健康と安心をお届けしています。\"\n            width=\"774\"\n            height=\"74\"\n            class=\"hidden-sp\"\n          />\n          <img\n            src=\"img/home/txt_mv02_sp.svg\"\n            alt=\"広島県福山市に本社のある株式会社 明乳松浦は、お客様の健康を第⼀に考えて、健康と安心をお届けしています。\"\n            width=\"390\"\n            height=\"170\"\n            class=\"hidden-pc\"\n          />\n        </p>\n      </div>\n      <img\n        src=\"img/home/img_mv01_pc.webp\"\n        alt=\"\"\n        width=\"1760\"\n        height=\"860\"\n        class=\"homeMv__img l-mv__img hidden-sp\"\n      />\n      <img\n        src=\"img/home/img_mv01_sp.webp\"\n        alt=\"\"\n        width=\"\"\n        height=\"\"\n        class=\"homeMv__img l-mv__img hidden-pc\"\n      />\n    </div>\n\n    <main class=\"l-main\">\n      <!-- <section class=\"homeNews c-bg02 js-view is-fadeInUp\">\n\t\t\t<div class=\"homeNews-inner inner\">\n\t\t\t\t<h2 class=\"homeNews__secTit c-tit01\"><img src=\"img/home/tit_news01.svg\" alt=\"お知らせ\" width=\"166\" height=\"37\" loading=\"lazy\"></h2>\n\t\t\t\t<div class=\"homeNews-box\">\n\t\t\t\t\t<ul class=\"homeNews-list\">\n\t\t\t\t\t\t<li class=\"homeNews-list__item\">\n\t\t\t\t\t\t\t<p class=\"homeNews-list__date\">2022.03.18</p>\n\t\t\t\t\t\t\t<p class=\"homeNews-list__txt\">ホームページをリニューアルしました！</p>\n\t\t\t\t\t\t</li>\n\t\t\t\t\t\t<li class=\"homeNews-list__item\">\n\t\t\t\t\t\t\t<p class=\"homeNews-list__date\">2022.02.01</p>\n\t\t\t\t\t\t\t<p class=\"homeNews-list__txt\">お知らせが入ります。お知らせが入ります。お知らせが入ります。お知らせが入ります。お知らせが入ります。</p>\n\t\t\t\t\t\t</li>\n\t\t\t\t\t\t<li class=\"homeNews-list__item\">\n\t\t\t\t\t\t\t<p class=\"homeNews-list__date\">2022.02.01</p>\n\t\t\t\t\t\t\t<p class=\"homeNews-list__txt\">お知らせが入ります。お知らせが入ります。お知らせが入ります。お知らせが入ります。お知らせが入ります。</p>\n\t\t\t\t\t\t</li>\n\t\t\t\t\t</ul>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</section> -->\n\n      <section class=\"homeMessage c-bg01 js-view is-fadeInUp\">\n        <div class=\"homeMessage-inner inner\">\n          <h2 class=\"homeMessage__secTit c-tit01\">\n            <img\n              src=\"img/home/tit_message01.svg\"\n              alt=\"代表メッセージ\"\n              width=\"305\"\n              height=\"38\"\n              loading=\"lazy\"\n            />\n          </h2>\n          <div class=\"homeMessage-box\">\n            <div class=\"homeMessage-box-txtBox\">\n              <p class=\"homeMessage-box__tit\">心と体の健康に貢献</p>\n              <p class=\"homeMessage-box__txt\">\n                当社は、宅配事業を通じて「地域の健康サポーター」として地域の方々の心と体の健康に貢献する事業を目指しています。お客さま一人ひとりの現状に合わせた商品をご提案するため、食生活アドバイザーなどの資格取得を奨励し、社員もスキルアップに努めています。変化する時代の中、お客様の健康習慣をサポートするため、これからも宅配を中心に社会に貢献したいと考えています。\n              </p>\n              <p class=\"homeMessage-box__name f-serif\">代表取締役 松浦 伸明</p>\n            </div>\n            <div class=\"homeMessage-box-imgBox\">\n              <img\n                src=\"img/home/img_message01.webp\"\n                alt=\"\"\n                width=\"320\"\n                height=\"400\"\n                loading=\"lazy\"\n              />\n            </div>\n          </div>\n        </div>\n      </section>\n\n      <section class=\"homeRecommend c-bg01 js-view is-fadeInUp\">\n        <div class=\"homeRecommend-imgBox\">\n          <img\n            src=\"img/home/img_recommend01.webp\"\n            alt=\"\"\n            width=\"1450\"\n            height=\"550\"\n            loading=\"lazy\"\n          />\n        </div>\n        <div class=\"homeRecommend-txtBox\">\n          <h2 class=\"homeRecommend__secTit\">おすすめ商品</h2>\n          <p class=\"homeRecommend__txt\">\n            株式会社明治の特約店である明乳松浦では<br\n              class=\"hidden-sp\"\n            />種類豊富な商品を取り揃えております。\n          </p>\n          <p class=\"homeRecommend__btn c-btn01\">\n            <a href=\"products/index.html\">おすすめ商品はこちら</a>\n          </p>\n        </div>\n      </section>\n\n      <section class=\"homeWorks c-bg01 js-view is-fadeInUp\">\n        <div class=\"homeWorks-inner inner\">\n          <h2 class=\"homeWorks__secTit c-tit01\">\n            <img\n              src=\"img/home/tit_works01.svg\"\n              alt=\"事業案内\"\n              width=\"168\"\n              height=\"38\"\n              loading=\"lazy\"\n            />\n          </h2>\n          <ul class=\"homeWorks-list\">\n            <li class=\"homeWorks-list__item\">\n              <div class=\"homeWorks-list-txtBox\">\n                <h3 class=\"homeWorks-list__tit\">\n                  <img\n                    src=\"img/home/tit_works02.svg\"\n                    alt=\"宅配部門\"\n                    width=\"235\"\n                    height=\"53\"\n                    loading=\"lazy\"\n                  />\n                </h3>\n                <img\n                  src=\"img/home/img_works01.webp\"\n                  alt=\"\"\n                  width=\"405\"\n                  height=\"377\"\n                  loading=\"lazy\"\n                  class=\"homeWorks-list__img\"\n                />\n                <p class=\"homeWorks-list__txt\">\n                  各ご家庭に牛乳・ヨーグルト等宅配専用商品をお届けしています。<br\n                    class=\"hidden-sp\"\n                  />毎週決まった曜日に定期的にお届けすることにより、お客さまに毎日飲む習慣を付けて頂き、健康維持へのお手伝いをすることを目指しています。\n                </p>\n              </div>\n            </li>\n            <li class=\"homeWorks-list__item\">\n              <div class=\"homeWorks-list-txtBox\">\n                <h3 class=\"homeWorks-list__tit\">\n                  <img\n                    src=\"img/home/tit_works03.svg\"\n                    alt=\"給食・卸部門\"\n                    width=\"367\"\n                    height=\"55\"\n                    loading=\"lazy\"\n                  />\n                </h3>\n                <img\n                  src=\"img/home/img_works02.webp\"\n                  alt=\"\"\n                  width=\"405\"\n                  height=\"377\"\n                  loading=\"lazy\"\n                  class=\"homeWorks-list__img\"\n                />\n                <p class=\"homeWorks-list__txt\">\n                  病院・高齢者施設・保育所等に給食用の牛乳やヨーグルトなどを納品しています。また、給食用以外にも飲食店・ホテル等にも牛乳・生クリーム・チーズなどを納品しています。\n                </p>\n                <p class=\"homeWorks-list__txt\">\n                  お問い合わせは、<br class=\"hidden-pc\" />本社<span\n                    ><a href=\"tel:0849251703\">084-925-1703</a></span\n                  >\n                </p>\n              </div>\n            </li>\n          </ul>\n        </div>\n      </section>\n\n      <section class=\"homeRecruit c-bg01 js-view is-fadeInUp\">\n        <div class=\"homeRecruit-imgBox\">\n          <img\n            src=\"img/home/img_recruit01.webp\"\n            alt=\"\"\n            width=\"1450\"\n            height=\"550\"\n            loading=\"lazy\"\n          />\n        </div>\n        <div class=\"homeRecruit-txtBox\">\n          <h2 class=\"homeRecruit__secTit\">採用情報</h2>\n          <p class=\"homeRecruit__txt\">\n            ⼀緒に働く仲間を募集しております。<br\n              class=\"hidden-sp\"\n            />詳しいお仕事内容や、募集中の求⼈はこちらから。\n          </p>\n          <p class=\"homeRecruit__btn c-btn01\">\n            <a href=\"recruit/index.html\" target=\"_blank\"\n              >求人情報をチェックする</a\n            >\n          </p>\n        </div>\n      </section>\n\n      <section class=\"homeSdgs c-bg01 js-view is-fadeInUp\">\n        <div class=\"homeSdgs-inner inner\">\n          <h2 class=\"homeSdgs__secTit c-tit01\">\n            <img\n              src=\"img/home/tit_sdgs01.svg\"\n              alt=\"SDGsの取り組み\"\n              width=\"347\"\n              height=\"38\"\n              loading=\"lazy\"\n            />\n          </h2>\n          <img\n            src=\"img/home/img_sdgs01.webp\"\n            alt=\"株式会社明乳松浦 SDGs宣言\"\n            width=\"980\"\n            height=\"1386\"\n            loading=\"lazy\"\n            class=\"homeSdgs__img\"\n          />\n        </div>\n      </section>\n\n      <section class=\"homeArea c-bg01 js-view is-fadeInUp\">\n        <div class=\"homeArea-inner inner\">\n          <h2 class=\"homeArea__secTit c-tit01\">\n            <img\n              src=\"img/home/tit_area01.svg\"\n              alt=\"地域の取り組み\"\n              width=\"308\"\n              height=\"38\"\n              loading=\"lazy\"\n            />\n          </h2>\n          <section class=\"homeArea-box\">\n            <h3 class=\"homeArea-box__tit\">\n              地域見守り<br />\n              ネットワーク活動への参加\n            </h3>\n            <img\n              src=\"img/home/img_area01.webp\"\n              alt=\"\"\n              width=\"405\"\n              height=\"377\"\n              loading=\"lazy\"\n              class=\"homeArea-box__img\"\n            />\n            <p class=\"homeArea-box__txt\">\n              明乳松浦は地⽅⾃治体と連携し、地域⾒守りネットワーク活動に参加しています。<br\n                class=\"hidden-sp\"\n              />⾒守りサポートは、宅配商品をお届けするスタッフが異変に気付いた際、速やかに地⽅⾃治体やご家族へ連絡・対応を⾏うサービスです。<br\n                class=\"hidden-sp\"\n              />毎週定期的に牛乳を配達しているからこそ気付くことができるので、<br\n                class=\"hidden-sp\"\n              />今では約1500名の⽅へ⾒守りサポートを実施しています。費⽤は無料なのでぜひお申込みください。\n            </p>\n          </section>\n        </div>\n      </section>\n\n      <section class=\"homeSupport c-bg01 js-view is-fadeInUp\">\n        <div class=\"homeSupport-inner inner\">\n          <h2 class=\"homeSupport__secTit c-tit02\">\n            <img\n              src=\"img/home/tit_support01.svg\"\n              alt=\"見守りサポートの流れ（安否確認）\"\n              width=\"440\"\n              height=\"70\"\n              loading=\"lazy\"\n            />\n          </h2>\n          <ol class=\"homeSupport-list\">\n            <li class=\"homeSupport-list__item\">\n              <img\n                src=\"img/home/ico_num01.svg\"\n                alt=\"01\"\n                width=\"50\"\n                height=\"50\"\n                loading=\"lazy\"\n                class=\"homeSupport-list__num\"\n              />\n              <img\n                src=\"img/home/img_support01.webp\"\n                alt=\"\"\n                width=\"280\"\n                height=\"260\"\n                loading=\"lazy\"\n                class=\"homeSupport-list__img\"\n              />\n              <p class=\"homeSupport-list__txt\">\n                配達員が商品をお届けする際、<br\n                  class=\"hidden-sp\"\n                />お声がけをします。<br />\n                <span>（ご不在の場合は、宅配箱へお届けします）</span>\n              </p>\n            </li>\n            <li class=\"homeSupport-list__item\">\n              <img\n                src=\"img/home/ico_num02.svg\"\n                alt=\"02\"\n                width=\"50\"\n                height=\"50\"\n                loading=\"lazy\"\n                class=\"homeSupport-list__num\"\n              />\n              <img\n                src=\"img/home/img_support02.webp\"\n                alt=\"\"\n                width=\"280\"\n                height=\"260\"\n                loading=\"lazy\"\n                class=\"homeSupport-list__img\"\n              />\n              <p class=\"homeSupport-list__txt\">\n                前回の商品が箱の中へ残っており、連絡がとれない場合\n              </p>\n            </li>\n            <li class=\"homeSupport-list__item\">\n              <img\n                src=\"img/home/ico_num03.svg\"\n                alt=\"03\"\n                width=\"50\"\n                height=\"50\"\n                loading=\"lazy\"\n                class=\"homeSupport-list__num\"\n              />\n              <img\n                src=\"img/home/img_support03.webp\"\n                alt=\"\"\n                width=\"280\"\n                height=\"260\"\n                loading=\"lazy\"\n                class=\"homeSupport-list__img\"\n              />\n              <p class=\"homeSupport-list__txt\">\n                ⾃治体またはご家族さまへ<br\n                  class=\"hidden-sp\"\n                />ご連絡いたします。\n              </p>\n            </li>\n          </ol>\n          <div class=\"homeSupport-contact\">\n            お問い合わせは、<br class=\"hidden-pc\" />本社<span\n              ><a href=\"tel:0849251703\">084-925-1703</a></span\n            >\n          </div>\n          <h3 class=\"homeSupport__ttlVoice\">\n            たとえば、こんなことがありました！\n          </h3>\n          <div class=\"balloon_l\">\n            <div class=\"faceicon\">\n              <img src=\"img/home/voice01.webp\" alt=\"\" />\n            </div>\n            <p class=\"says\">\n              見守りサポートのお客さまのところに配達に行くと留守で、前回の商品を取り忘れておられました。ピンポンを押しても声をかけても応答なし。いつもは、テレビの音が聞こえるのに静かでした。会社に帰って電話をしても出られない為、緊急連絡先として登録されている息子さんに連絡をしました。\n              翌日息子さんから連絡を頂き、『脱水症状で家の中で倒れていたので、すぐ病院に連れて行き入院しました。早く連絡をくれて助かりました。ありがとうございました』とお礼の電話をいただきました。\n            </p>\n          </div>\n          <div class=\"balloon_r\">\n            <div class=\"faceicon\">\n              <img src=\"img/home/voice02.webp\" alt=\"\" />\n            </div>\n            <p class=\"says\">\n              見守りサポートのお客さまと話しをしていると、知り合いの方が亡くなられて悲しんでおられました。詳しく話を聞くと、知り合いの方は独り暮らしだった為、亡くなられた事が４日後にわかったそうです。\n              そのお客さまが、『でも私は独り暮らしだけど、まつうらさんが配達に来てくれるから、何かあっても\n              あなたがいるから安心だわ。いつも声をかけてくれてありがとうね』とお礼を言われました。\n            </p>\n          </div>\n        </div>\n      </section>\n\n      <section class=\"homeEvent c-bg01 is-view is-fadeInUp\">\n        <div class=\"homeEvent-inner inner\">\n          <h2 class=\"homeEvent__secTit c-tit02\">\n            <img\n              src=\"img/home/tit_event01_pc.svg\"\n              alt=\"出張健康イベントのご案内\"\n              width=\"580\"\n              height=\"40\"\n              loading=\"lazy\"\n              class=\"hidden-sp\"\n            />\n            <img\n              src=\"img/home/tit_event01_sp.svg\"\n              alt=\"出張健康イベントのご案内\"\n              width=\"580\"\n              height=\"40\"\n              loading=\"lazy\"\n              class=\"hidden-pc\"\n            />\n          </h2>\n          <ul class=\"homeEvent-list\">\n            <li class=\"homeEvent-list__item\">\n              <div class=\"homeEvent-list-txtBox\">\n                <h3 class=\"homeEvent-list__tit\">骨の健康チェック</h3>\n                <img\n                  src=\"img/home/img_event01.webp\"\n                  alt=\"\"\n                  width=\"490\"\n                  height=\"377\"\n                  loading=\"lazy\"\n                  class=\"homeEvent-list__img\"\n                />\n                <p class=\"homeEvent-list__txt\">\n                  測定器にて、骨の健康度を測ります。<br />加齢とともに気になる骨粗鬆症や骨折リスクを見る上で参考となります。\n                </p>\n              </div>\n            </li>\n            <li class=\"homeEvent-list__item\">\n              <div class=\"homeEvent-list-txtBox\">\n                <h3 class=\"homeEvent-list__tit\">歩き方提案</h3>\n                <img\n                  src=\"img/home/img_event02.webp\"\n                  alt=\"\"\n                  width=\"490\"\n                  height=\"377\"\n                  loading=\"lazy\"\n                  class=\"homeEvent-list__img\"\n                />\n                <p class=\"homeEvent-list__txt\">\n                  「中之条研究」に基づく歩く事での健康効果を分かりやすく説明、実演いたします。\n                </p>\n              </div>\n            </li>\n          </ul>\n          <div class=\"homeEvent-guidance\">\n            <h2 class=\"homeEvent-guidance__tit\">宅配専用商品の無料試飲会</h2>\n            <p class=\"homeEvent-guidance__txt\">\n              スーパーやコンビニでは販売されていない宅配専用商品を無料でお試しいただけます。<br />\n              1日分のカルシウムと鉄分が入った「明治ミルクでPREMIUM」やTVCM等でお馴染みの1073R-1乳酸菌が入った「明治プロビオヨーグルトR-1」など毎日の健康を応援する商品をたくさんご用意しております。\n            </p>\n            <p class=\"homeEvent-guidance__caution\">\n              職場・サークル等のお仲間、ご近所のお友達数名以上からお申込みいただけます。<br />\n              お申込み受付後、実施スケジュール等につきまして、後日、弊社担当者よりご連絡をさせていただきます。お気軽にご相談ください。\n            </p>\n            <p class=\"homeEvent-guidance__note\">\n              ※開催日時につきましてはお時間をいただく場合がございますのでご了承ください。<br />※地域によりご対応できない場合がございますので、ご了承ください。\n            </p>\n            <div class=\"homeEvent-contact\">\n              <span><a href=\"tel:0849251703\">084-925-1703</a></span\n              ><br class=\"hidden-pc\" />健康イベント担当まで\n            </div>\n          </div>\n        </div>\n      </section>\n\n      <section class=\"homePhoto c-bg01 js-view is-fadeInUp\">\n        <div class=\"homePhoto-inner inner\">\n          <h2 class=\"homePhoto__secTit c-tit01\">\n            <img\n              src=\"img/home/tit_photo01.svg\"\n              alt=\"写真館（ギャラリー）\"\n              width=\"298\"\n              height=\"40\"\n              loading=\"lazy\"\n            />\n          </h2>\n          <ul class=\"homePhoto-list\">\n            <li class=\"homePhoto-list__item\">\n              <div class=\"homePhoto-list-txtBox\">\n                <h3 class=\"homePhoto-list__tit\">\n                  <img\n                    src=\"img/home/tit_photo02.svg\"\n                    alt=\"方針会議\"\n                    width=\"233\"\n                    height=\"61\"\n                    loading=\"lazy\"\n                  />\n                </h3>\n                <img\n                  src=\"img/home/img_photo01.webp\"\n                  alt=\"\"\n                  width=\"405\"\n                  height=\"377\"\n                  loading=\"lazy\"\n                  class=\"homePhoto-list__img\"\n                />\n                <p class=\"homePhoto-list__txt\">\n                  全社の社員・事務員が集まって今年の方針を聞きます。\n                </p>\n              </div>\n            </li>\n            <li class=\"homePhoto-list__item\">\n              <div class=\"homePhoto-list-txtBox\">\n                <h3 class=\"homePhoto-list__tit\">\n                  <img\n                    src=\"img/home/tit_photo03.svg\"\n                    alt=\"バーベキューやハイキングなど\"\n                    width=\"354\"\n                    height=\"94\"\n                    loading=\"lazy\"\n                    class=\"homePhoto-list__tit__img\"\n                  />\n                </h3>\n                <img\n                  src=\"img/home/img_photo02.webp\"\n                  alt=\"\"\n                  width=\"405\"\n                  height=\"377\"\n                  loading=\"lazy\"\n                  class=\"homePhoto-list__img\"\n                />\n                <p class=\"homePhoto-list__txt\">\n                  家族も参加出来る楽しい集まりもあります。\n                </p>\n              </div>\n            </li>\n            <li class=\"homePhoto-list__item\">\n              <div class=\"homePhoto-list-txtBox\">\n                <h3 class=\"home