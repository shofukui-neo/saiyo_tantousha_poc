    <p class=\"copy\">\n        <small>&copy; <span itemref=\"copyrightYear\">2021</span> <a href=\"https://www.h-seiken.co.jp/\" itemref=\"copyrightHolder\" class=\"lnk_color_inherit\">広島精研工業株式会社</a>\n                    </small>\n    </p>\n</footer>\n\n<div id=\"pagetop\">\n    <transition name=\"fade\">\n        <p class=\"pagetop\" v-show=\"scrollYSet > 300\" @click=\"scrollTop\"><img src=\"https://www.h-seiken.co.jp/wp/wp-content/themes/rcnt/images/pagetop.png\"></p>\n    </transition>\n</div>\n\n</div><!-- /body-inner -->\n\n<!--<p class=\"pagetop\"><img src=\"https://www.h-seiken.co.jp/wp/wp-content/themes/rcnt/images/pagetop.png\" class=\"pc\"><span class=\"tab_und pagetop_tab\"><i class=\"fa fa-angle-up\" aria-hidden=\"true\"></i></span></p>-->\n<!-- <p class=\"pagetop\" ><img src=\"/images/pagetop.png\"></p> -->\n\n<script type='text/javascript' src='//ajax.googleapis.com/ajax/libs/jquery/1.7.1/jquery.min.js?ver=1.7.1' id='jquery-js'></script>\n<script type='text/javascript' src='//cdn.jsdelivr.net/npm/vue@2.6.10/dist/vue.js' id='vue-cdn-js'></script>\n<script type='text/javascript' src='https://www.h-seiken.co.jp/wp/wp-content/themes/rcnt/js/bundle.js' id='js-bundle-js'></script>\n<script type='text/javascript' src='//use.fontawesome.com/releases/v5.0.6/js/all.js?ver=5.0.6' id='fontawesome-js'></script>\n<script type='text/javascript' src='https://www.h-seiken.co.jp/wp/wp-content/plugins/easy-fancybox/js/jquery.fancybox.min.js?ver=1.3.24' id='jquery-fancybox-js'></script>\n<script type='text/javascript' id='jquery-fancybox-js-after'>\nvar fb_timeout, fb_opts={'overlayShow':true,'hideOnOverlayClick':true,'showCloseButton':true,'margin':20,'centerOnScroll':false,'enableEscapeButton':true,'autoScale':true };\nif(typeof easy_fancybox_handler==='undefined'){\nvar easy_fancybox_handler=function(){\njQuery('.nofancybox,a.wp-block-file__button,a.pin-it-button,a[href*=\"pinterest.com/pin/create\"],a[href*=\"facebook.com/share\"],a[href*=\"twitter.com/share\"]').ad