      var value = document.createElement(\"input\");\n                value.setAttribute(\"type\", \"hidden\");\n                value.setAttribute(\"name\", \"recaptcha\");\n                value.setAttribute(\"value\", token);\n                form.appendChild(value);\n                var action = document.createElement(\"input\");\n                action.setAttribute(\"type\", \"hidden\");\n                action.setAttribute(\"name\", \"action\");\n                action.setAttribute(\"value\", \"next\");\n                form.appendChild(action);\n                form.submit();\n            },\n            \"error-callback\": function(){\n                var _submitErrorFormChildren = form.querySelectorAll(\"button[type='submit'][value='next'], input[type='submit'][value='next']\")\n                for (var j = 0; j < _submitErrorFormChildren.length; j++) {\n                    _submitErrorFormChildren[j].addEventListener(\"click\", function(){\n                        var value = document.createElement(\"input\");\n                        value.setAttribute(\"type\", \"hidden\");\n                        value.setAttribute(\"name\", \"recaptcha\");\n                        var action = document.createElement(\"input\");\n                        action.setAttribute(\"type\", \"hidden\");\n                        action.setAttribute(\"name\", \"action\");\n                        action.setAttribute(\"value\", \"next\");\n                        form.appendChild(action);\n                        form.submit();\n                    });\n                }\n            }\n        });\n    }\n}</script><script>window.addEventListener(\"load\", function() {var form = document.querySelector(\"form[data-bid='db6bf3e1798bdd40b41c27fb245d70083']\");\nvar agreement = form.querySelector(\"input[type='checkbox'][name='agreement']\");\nvar submits = form.querySelectorAll(\"button[type='submit'][name='action'][value='next'], input[type='submit'][name='action'][value='next']\");\nfor (var i = 0; i < submits.length; i++) {\n  submits[i].disabled = true\n}\nagreement.addEventListener(\"change\", function(e) {\n    var fileError = form.querySelector(\".fa-exclamation-circle.error-icon\");\n  if (!fileError && agreement.checked) {\n    for (var i = 0; i < submits.length; i++) {\n      if (submits[i].className.includes('sp-form-file-button-disabled')) {\n        submits[i].className = \"sp-form-next-button\";\n      }\n      submits[i].disabled = false\n    }\n  } else {\n    for (var i = 0; i < submits.length; i++) {\n      submits[i].disabled = true\n    }\n  }\n});});</script><script>/*\n* This fileTransfertStatusesObjects is used to share fileTransfertStatuses_blockId._field.name's value\n* from one field to another. For example, you click file field f01, in that case you cannot use file field f03\n* you have to store f03's value in the fileTransfertStatusesObjects to f03' value in f01.\n* You can use this keyword to search for the existing sample code \"fileTransfertStatusesObjectKeys\"\n*/\nvar fileTransfertStatusesObjects = { }\nvar fileFieldStatus = { }</script><script>window.addEventListener(\"DOMContentLoaded\", function() {\n    const form = document.querySelector(\"form[data-bid='db6bf3e1798bdd40b41c27fb245d70083']\");\n    if (form) {\n        const submitList = form.querySelectorAll(\"button[type='submit'], input[type='submit']\");\n        if (submitList.length) {\n            let submit = null;\n            Array.prototype.slice.call(submitList).forEach(function(s) {\n                s.addEventListener(\"click\", function() {\n                    submit = this;\n                });\n            });\n            form.addEventListener(\"submit\", function(e) {\n                if (submit && submit.disabled) {\n                    e.preventDefault();\n                } else {\n                    if (submit.name && submit.value) {\n                        const action = document.createElement(\"input\");\n                        action.setAttribute(\"type\", \"hidden\");\n                        action.setAttribute(\"name\", submit.name);\n                        action.setAttribute(\"value\", submit.value);\n                        form.appendChild(action);\n                    }\n                    submit.dataset.submitClicked = 'true';\n                    submit.disabled = true;\n                }\n            });\n        }\n    }\n});\nwindow.addEventListener(\"pageshow\", function() {\n    const form = document.querySelector(\"form[data-bid='db6bf3e1798bdd40b41c27fb245d70083']\");\n    if (form) {\n        const submitlicked = form.querySelector(\"button[type='submit'][data-submit-clicked='true'], input[type='submit'][data-submit-clicked='true']\");\n        if (submitlicked) {\n            delete submitlicked.dataset.submitClicked;\n            submitlicked.disabled = false;\n        }\n    }\n});</script>\n</head>\n<body>\n    <form method=\"post\" data-bid=\"db6bf3e1798bdd40b41c27fb245d70083\" autocomplete=\"off\"><div class=\"sp-form-container\"> \n  <div class=\"sp-form-item sp-form-html\"><p><a href=\"https://www.penta-techno.co.jp/index.html\" target=\"_blank\" datalinkid=\"mbr56\" behavior=\"redirect\" style=\"font-size: 18pt; color: rgb(59, 126, 155);\"><img src=\"/_media/pts.png\" alt=\"pts\" width=\"200\" type=\"px\" style=\"max-width: 100%; cursor: pointer !important;\"></a></p><h2>応募フォーム</h2><p><br></p><p>セキュリティ上、メールでのご応募は受け付けておりませんので、以下のフォームにご入力ください。</p><p>後日、弊社担当者よりご連絡させていただきます。</p></div> \n  <div class=\"sp-step-flow-f12037\"> \n    <div class=\"large-setting arrow sp-clearfix\"> \n      <div class=\"step active\" title=\"1.必要事項のご入力\">\n        <span>1.必要事項のご入力</span>\n      </div> \n      <div class=\"step\" title=\"2.入力内容のご確認\">\n        <span>2.入力内容のご確認</span>\n      </div> \n      <div class=\"step\" title=\"3.送信完了\">\n        <span>3.送信完了</span>\n      </div> \n    </div> \n    <div class=\"small-setting arrow sp-clearfix\"> \n      <div class=\"step active\" title=\"1.必要事項のご入力\">\n        <span>1.必要事項のご入力</span>\n      </div> \n      <div class=\"step\" title=\"2.入力内容のご確認\">\n        <span>2.入力内容のご確認</span>\n      </div> \n      <div class=\"step\" title=\"3.送信完了\">\n        <span>3.送信完了</span>\n      </div> \n    </div> \n  </div> \n  <div class=\"sp-form-item sp-form-html\"><p><br></p><p style=\"text-align: center;\"><span style=\"color: rgb(230, 0, 0);\">＊</span><span style=\"color: rgb(34, 34, 34);\">は必須項目です。必ずご入力ください。</span></p><p style=\"text-align: center;\"><br></p><p style=\"text-align: center;\">※<span style=\"color: rgb(34, 34, 34);\">機種依存文字は文字化けする可能性がありますのでご使用はご遠慮ください。</span></p><p style=\"text-align: center;\"><br></p></div> \n   \n   \n  <div class=\"sp-form-item sp-form-field\"> \n    <div class=\"sp-form-label\"> \n      応募区分 \n      <span class=\"sp-form-required\">*</span>\n    </div> \n    <div class=\"sp-form-data\"> \n      <div class=\"sp-form-selection-horizontal\">\n        <label class=\"sp-form-selection\">\n          <input type=\"radio\" name=\"f01\" value=\"1\">\n          <span class=\"sp-form-selection-label\">新卒</span>\n        </label><label class=\"sp-form-selection\">\n          <input type=\"radio\" name=\"f01\" value=\"2\">\n          <span class=\"sp-form-selection-label\">キャリア</span>\n        </label>\n      </div> \n      \n      \n    </div> \n  </div> \n   \n   \n  <div class=\"sp-form-item sp-form-field\"> \n    <div class=\"sp-form-label\"> \n      職種 \n      <span class=\"sp-form-required\">*</span>\n    </div> \n    <div class=\"sp-form-data\"> \n      <div class=\"sp-form-dropdown\">\n        <select class=\"sp-form-control\" name=\"f02\">\n          <option value=\"\" selected=\"selected\">----- 選択してください -----</option>\n          <option value=\"1\">実験</option>\n          <option value=\"2\">ICT</option>\n          <option value=\"3\">情報技術</option>\n        </select>\n        <span class=\"sp-form-dropdown-icon\"></span>\n      </div> \n      \n      \n    </div> \n  </div> \n   \n   \n  <div class=\"sp-form-item sp-form-field\"> \n    <div class=\"sp-form-label\"> \n      お名前 \n      <span class=\"sp-form-required\">*</span>\n    </div> \n    <div class=\"sp-form-data\">\n      <input type=\"text\" class=\"sp-form-control\" name=\"f03\" placeholder=\"例）那須　太郎\" value=\"\"> \n      <!--ZipCode Option--> \n       \n      <span class=\"sp-form-noted\">姓名の間にスペースを入力してください</span>\n      <span class=\"sp-form-error\" data-zipcode=\"zipCodeErrorf03\"></span>\n    </div> \n  </div> \n   \n   \n  <div class=\"sp-form-item sp-form-field\"> \n    <div class=\"sp-form-label\"> \n      フリガナ \n      <span class=\"sp-form-required\">*</span>\n    </div> \n    <div class=\"sp-form-data\">\n      <input type=\"text\" class=\"sp-form-control\" name=\"f04\" placeholder=\"例）ナス　タロウ\" value=\"\"> \n      <!--ZipCode Option--> \n       \n      <span class=\"sp-form-noted\">全角カタカナ　姓名の間にスペースを入力してください</span>\n      <span class=\"sp-form-error\" data-zipcode=\"zipCodeErrorf04\"></span>\n    </div> \n  </div> \n   \n   \n  <div class=\"sp-form-item sp-form-field\"> \n    <div class=\"sp-form-label\"> \n      生年月日 \n      <span class=\"sp-form-required\">*</span>\n    </div> \n    <div class=\"sp-form-data\"> \n      <div class=\"sp-form-datetimes\"> \n        <div class=\"sp-form-date\">\n          <input type=\"number\" class=\"sp-form-control\" name=\"f05:year\" placeholder=\"年\" value=\"\">\n          <span class=\"sp-form-date-separator\">/</span>\n          <input type=\"number\" class=\"sp-form-control\" name=\"f05:month\" placeholder=\"月\" value=\"\">\n          <span class=\"sp-form-date-separator\">/</span>\n          <input type=\"number\" class=\"sp-form-control\" name=\"f05:day\" placeholder=\"日\" value=\"\">\n        </div> \n      </div> \n      <span class=\"sp-form-noted\">西暦から半角数字を入力してください</span>\n      \n    </div> \n  </div> \n   \n   \n  <div class=\"sp-form-item sp-form-field\"> \n    <div class=\"sp-form-label\"> \n      性別 \n      \n    </div> \n    <div class=\"sp-form-data\"> \n      <div class=\"sp-form-selection-horizontal\">\n        <label class=\"sp-form-selection\">\n          <input type=\"radio\" name=\"f06\" value=\"1\">\n          <span class=\"sp-form-selection-label\">男</span>\n        </label><label class=\"sp-form-selection\">\n          <input type=\"radio\" name=\"f06\" value=\"2\">\n          <span class=\"sp-form-selection-label\">女</span>\n        </label>\n      </div> \n      \n      \n    </div> \n  </div> \n   \n   \n  <div class=\"sp-form-item sp-form-field\"> \n    <div class=\"sp-form-label\"> \n      郵便番号 \n      <span class=\"sp-form-required\">*</span>\n    </div> \n    <div class=\"sp-form-data\">\n       \n      <!--ZipCode Option--> \n      <div class=\"sp-form-zip-code\">\n        <input type=\"text\" class=\"sp-form-control\" name=\"f07\" placeholder=\"例）1234567\" value=\"\">\n        \n      </div> \n      <span class=\"sp-form-noted\">半角・ハイフンなしで入力してください</span>\n      <span class=\"sp-form-error\" data-zipcode=\"zipCodeErrorf07\"></span>\n    </div> \n  </div> \n   \n   \n  <div class=\"sp-form-item sp-form-field\"> \n    <div class=\"sp-form-label\"> \n      住所 \n      <span class=\"sp-form-required\">*</span>\n    </div> \n    <div class=\"sp-form-data\">\n      <input type=\"text\" class=\"sp-form-control\" name=\"f08\" placeholder=\"例）栃木県那須塩原市四区町1534-1\" value=\"\"> \n      <!--ZipCode Option--> \n       \n      <span class=\"sp-form-noted\">都道府県から入力ください</span>\n      <span class=\"sp-form-error\" data-zipcode=\"zipCodeErrorf08\"></span>\n    </div> \n  </div> \n   \n   \n  <div class=\"sp-form-item sp-form-field\"> \n    <div class=\"sp-form-label\"> \n      希望連絡方法 \n      <span class=\"sp-form-required\">*</span>\n    </div> \n    <div class=\"sp-form-data\"> \n      <div class=\"sp-form-selection-horizontal\">\n        <label class=\"sp-form-selection\">\n          <input type=\"radio\" name=\"f09\" value=\"1\">\n          <span class=\"sp-form-selection-label\">メール</span>\n        </label><label class=\"sp-form-selection\">\n          <input type=\"radio\" name=\"f09\" value=\"2\">\n          <span class=\"sp-form-selection-label\">電話</span>\n        </label>\n      </div> \n      \n      \n    </div> \n  </div> \n   \n   \n  <div class=\"sp-form-item sp-form-field\"> \n    <div class=\"sp-form-label\"> \n      メールアドレス \n      <span class=\"sp-form-required\">*</span>\n    </div> \n    <div class=\"sp-form-data\">\n      <input type=\"email\" class=\"sp-form-control\" name=\"f010\" placeholder=\"例）saiyo@mail.co.jp　または　saiyo@mobile.ne.jp\" value=\"\"> \n       \n      \n      \n    </div> \n  </div> \n   \n   \n  <div class=\"sp-form-item sp-form-field\"> \n    <div class=\"sp-form-label\"> \n      電話番号 \n      <span class=\"sp-form-required\">*</span>\n    </div> \n    <div class=\"sp-form-data\"> \n      <div class=\"sp-form-phone\"> \n         \n        <input type=\"tel\" class=\"sp-form-control\" name=\"f011\" placeholder=\"例）0123456789　または　09012345678\" value=\"\">\n      </div> \n      <span class=\"sp-form-noted\">半角・ハイフンなし　市外局番から入力してください</span>\n      \n    </div> \n  </div> \n  <div class=\"sp-form-item sp-form-html\"><h3><br></h3><h3>新卒の方のみご記入ください</h3></div> \n   \n   \n  <div class=\"sp-form-item sp-form-field\"> \n    <div class=\"sp-form-label\"> \n      学校名 \n      \n    </div> \n    <div class=\"sp-form-data\">\n      <input type=\"text\" class=\"sp-form-control\" name=\"f012\" value=\"\"> \n      <!--ZipCode Option--> \n       \n      \n      <span class=\"sp-form-error\" data-zipcode=\"zipCodeErrorf012\"></span>\n    </div> \n  </div> \n   \n   \n  <div class=\"sp-form-item sp-form-field\"> \n    <div class=\"sp-form-label\"> \n      学部・学科・専攻 \n      \n    </div> \n    <div class=\"sp-form-data\">\n      <input type=\"text\" class=\"sp-form-control\" name=\"f013\" placeholder=\" 例）工学部　機械工学科　機械工学専攻\" value=\"\"> \n      <!--ZipCode Option--> \n       \n      \n      <span class=\"sp-form-error\" data-zi