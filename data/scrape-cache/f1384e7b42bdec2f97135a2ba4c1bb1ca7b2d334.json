n\t\t\t\t\t</ul>\n\t\t\t\t</li>\n\t\t\t</ul>\n\t\t</nav>\n\t<!-- /#hd_inner --></div>\n</header>\n\n<div id=\"wrapper\">\n\n\t\t\t<div class=\"mainimg01 main_info\">\n\t\t<div class=\"inner01\">\n\t\t\t<div class=\"maintxt02\">\n\t\t\t\t<h1>見積依頼 / お問い合わせ</h1>\n\t\t\t<!-- /.maintxt01 --></div>\n\t\t<!-- /.inner01 --></div>\n\t<!-- /.mainimg_top --></div>\n\n\t<main id=\"main\" role=\"main\">\n\t\t<div class=\"outer01\">\n\t\t\t<div class=\"inner01\">\n<article>\n<h2 class=\"contactH2\">WEBでのお問い合わせ</h2>\n<p class=\"leed\">WEBでのお問い合わせは、下記フォームより必要事項をご入力の上、返信してください。<br>後日、担当者よりご連絡いたします。</p>\n<ul class=\"flow\">\n<li class=\"current\">入 力</li>\n<li>確 認</li>\n<li>送 信</li>\n</ul>\n<form method=\"post\" action=\"/service/inquiry/confirm/\">\n<table class=\"formtable\">\n<tr>\n<th>氏名<span>必須</span></th>\n<td><input type=\"text\" class=\"Txt01\" required name=\"inquiry_name\"></td>\n</tr>\n<tr>\n<th>会社名<span>必須</span></th>\n<td><input type=\"text\" class=\"Txt01\" required name=\"inquiry_company\"></td>\n</tr>\n<tr>\n<th>電話番号<span>必須</span></th>\n<td><input type=\"tel\" class=\"Txt01\" required name=\"inquiry_tel\"></td>\n</tr>\n<tr>\n<th>メールアドレス<span>必須</span></th>\n<td><input type=\"email\" class=\"Txt01\" required name=\"inquiry_email\"></td>\n</tr>\n<tr>\n<th>お問合わせ内容<span>必須</span></th>\n<td><textarea id=\"\" required name=\"inquiry_body\"></textarea></td>\n</tr>\n</table>\n<input type=\"submit\" value=\"上記内容で確認する\" class=\"subBtn\">\n</form>\n</article>\n\t\t\t<!-- /.inner01 --></div>\n\t\t<!-- /.outer01 --></div>\n\t</main>\n\r\n\r\n\n<!-- /.wrapper --></div>\n\n<footer id=\"footer\" role=\"contentinfo\">\n\t<div class=\"pagetop_fixed\"><p><img src=\"/common/img/top.png\" alt=\"このページの先頭へ\"></p><!-- /.pagetop_fixed --></div>\n\t<div id=\"ft_outer\">\n\t\t<div id=\"ft_inner\">\n\t\t\t<div id=\"ft_navi01\">\n\t\t\t\t<ul class=\"ft_nav_top\">\n\t\t\t\t\t<li><a href=\"/\">トップページ</a></li>\n\t\t\t\t</ul>\n\t\t\t\t<ul class=\"ft_nav_top\">\n\t\t\t\t\t<li>\n\t\t\t\t\t\t<a href=\"