\" content=\"https://www.nagano-toshi-gas.co.jp/\" />\n  <meta property=\"og:image\" content=\"https://www.nagano-toshi-gas.co.jp/assets/img/ogp.jpg\"  />\n  <meta property=\"og:image:secure_url\" content=\"https://www.nagano-toshi-gas.co.jp/assets/img/ogp.jpg\" />\n  <meta property=\"twitter:card\" content=\"summary_large_image\" />\n  <meta property=\"twitter:domain\" content=\"https://www.nagano-toshi-gas.co.jp/\" />\n  <meta property=\"twitter:title\" content=\"長野都市ガスのリフォーム｜長野都市ガス\" />\n  <meta name=\"twitter:image\" content=\"https://www.nagano-toshi-gas.co.jp/assets/img/ogp.jpg\" />\n  <meta property=\"twitter:description\" content=\"長野都市ガスのリフォームページです。キッチン、お風呂、トイレ、洗面台など水回りを中心に、リフォーム事業に取り組んでいます。ガスの専門家として培ってきたエネルギーの知見を活かし、お客様の暮らしをより快適にするリフォームをご提案いたします。\" />\n</head>\n\n<body id=\"request\">\n\t<!-- Google Tag Manager (noscript) -->\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-WWHKHVR\"\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n<!-- End Google Tag Manager (noscript) -->\n\n<!-- Google Tag Manager (noscript) AA -->\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-KWQ9RCJP\"\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n<!-- End Google Tag Manager (noscript) AA -->\n\n<header id=\"header\" class=\"l-header\">\n            <div class=\"l-header__wrap\">\n                <!--ロゴ-->\n                <h1>\n                    <a href=\"/reform/\" class=\"l-header__logo-area\">\n                        <img src=\"/assets/img/common/logo.svg\" alt=\"長野都市ガス\" width=\"90px\" height=\"30px\" class=\"l-header__logo\">\n                        <span>リフォーム</span>\n                    </a>\n                </h1>\n                <!--ナビゲーション-->\n                <nav class=\"l-header__nav c-drawer\" id=\"global-nav\">\n                    <div class=\"l-header__nav__container\">\n                        <div class=\"l-header__nav__outer\">\n