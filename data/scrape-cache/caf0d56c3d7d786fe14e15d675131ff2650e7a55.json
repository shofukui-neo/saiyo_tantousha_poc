it/faq/\"><span class=\"site-map-child__ja\">よくあるご質問</span><i class=\"site-map-child__icon icon-chevron-right\"></i></a>\n                  </li>\n                  <li class=\"site-map-child__item\"><a class=\"site-map-child__link\" href=\"../recruit/voice/\"><span class=\"site-map-child__ja\">内定者コンテンツ</span><i class=\"site-map-child__icon icon-chevron-right\"></i></a>\n                  </li>\n                </ul>\n              </li>\n            </ul>\n          </div>\n          <div class=\"site-map-bottom\">\n            <div class=\"site-map-bottom-logo\"><a class=\"site-map-bottom-logo__link\" href=\"\"><img class=\"site-map-bottom-logo__image\" src=\"../assets/images/common/site_map_logo.jpg\" srcset=\"../assets/images/common/site_map_logo.jpg 1x, ../assets/images/common/site_map_logo@2x.jpg 2x\" width=\"148\" height=\"65\" decoding=\"async\" loading=\"lazy\" alt=\"株式会社内田洋行\"></a></div>\n            <div class=\"site-map-bottom__inner\">\n              <div class=\"site-map-nav\">\n                <ul class=\"site-map-nav__list\">\n                  <li class=\"site-map-nav-item\"><a class=\"site-map-nav-item__link\" href=\"https://www.uchida.co.jp/\" target=\"_blank\">コーポレートサイト</a></li>\n                  <li class=\"site-map-nav-item\"><a class=\"site-map-nav-item__link\" href=\"https://www.uchida.co.jp/privacy/index.html\" target=\"_blank\">個人情報保護方針</a></li>\n                </ul>\n              </div>\n              <div class=\"site-map-copyright\">©UCHIDA YOKO CO., LTD</div>\n            </div>\n          </div>\n        </nav>\n      </div>\n    </header>\n    <div class=\"header-site-name\">RECRUIT<br>SITE</div>\n    <div class=\"wrap\">\n      <div class=\"hero js-inview inview-wrap\">\n        <figure class=\"hero__figure\"><img class=\"hero__image\" src=\"../assets/images/introduction/hero_pc.jpg\" srcset=\"../assets/images/introduction/hero_pc.jpg 1x, ../assets/images/introduction/hero_pc@2x.jpg 2x\" width=\"1440\" height=\"900\" decoding=\"async\" loading=\"eager\" alt=\"内田洋行を知る\">\n        </figure>\n        <div class=\"hero__content\">\n          <h1 class=\"title-02\"><span class=\"title-02__en slide-in__wrapper\"><span class=\"slide-in__inner\">ABOUT</span></span><span class=\"title-02__ja tr-fade-in tr-fade-in--delay-03\">内田洋行を知る</span></h1>\n        </div>\n      </div>\n      <!-- question-->\n      <section class=\"question\">\n        <div class=\"question__title\">\n          <h2 class=\"title-03 js-inview inview-wrap\"><span class=\"title-03-bg-text marquee-text tr-fade-in\" aria-hideen=\"true\"><span class=\"title-03-bg-text__inner marquee-text__inner\">QUESTION QUESTION</span><span class=\"title-03-bg-text__inner marquee-text__inner\">QUESTION QUESTION</span></span><span class=\"slide-in__wrapper\"><span class=\"slide-in__inner title-03__en\">Q1</span></span><span class=\"title-03__ja title-03__ja--white tr-fade-in tr-fade-in--delay-03\">内田洋行ってどんな会社？</span></h2>\n        </div>\n        <!-- answer-->\n        <div class=\"answer answer--01\">\n          <div class=\"answer__title\">\n            <h3 class=\"title-03 js-inview inview-wrap\"><span class=\"title-03-bg-text tr-fade-in\" aria-hideen=\"true\"><span class=\"title-03-bg-text__inner title-03-bg-text__inner--gradient\">ANSWER</span></span><span class=\"slide-in__wrapper\"><span class=\"slide-in__inner title-03__en title-03__en--pink\">A.</span></span><span class=\"title-03__ja tr-fade-in tr-fade-in--delay-03\">民間企業・学校・自治体に向けて<br>ICTと環境構築を提供している会社です</span></h3>\n          </div>\n          <div class=\"answer__subtitle answer__subtitle--small js-inview tr-fade-in tr-fade-in--bottom\">お客様が抱える課題例</div>\n          <ul class=\"task\">\n            <li class=\"task-item js-inview tr-fade-in tr-fade-in--bottom\">\n              <figure class=\"task__figure\"><img class=\"task__image\" src=\"../assets/images/introduction/q1_icon_01.png\" srcset=\"../assets/images/introduction/q1_icon_01.png 1x, ../assets/images/introduction/q1_icon_01@2x.png 2x\" width=\"170\" height=\"170\" decoding=\"async\" loading=\"lazy\" alt=\"民間企業\"></figure>\n              <p class=\"task-item__title\">民間企業</p>\n              <p class=\"task-item__body\">コミュニケーションを活発に<br>・<br>生産性の向上</p>\n            </li>\n            <li class=\"task-item js-inview tr-fade-in tr-fade-in--bottom\">\n              <figure class=\"task__figure\"><img class=\"task__image\" src=\"../assets/images/introduction/q1_icon_02.png\" srcset=\"../assets/images/introduction/q1_icon_02.png 1x, ../assets/images/introduction/q1_icon_02@2x.png 2x\" width=\"170\" height=\"170\" decoding=\"async\" loading=\"lazy\" alt=\"学校\"></figure>\n              <p class=\"task-item__title\">学校</p>\n              <p class=\"task-item__body\">よりよい授業へ<br>・<br>主体性を育む教育</p>\n            </li>\n            <li class=\"task-item js-inview tr-fade-in tr-fade-in--bottom\">\n              <figure class=\"task__figure\"><img class=\"task__image\" src=\"../assets/images/introduction/q1_icon_03.png\" srcset=\"../assets/images/introduction/q1_icon_03.png 1x, ../assets/images/introduction/q1_icon_03@2x.png 2x\" width=\"170\" height=\"170\" decoding=\"async\" loading=\"lazy\" alt=\"自治体\"></figure>\n              <p class=\"task-item__title\">自治体</p>\n              <p class=\"task-item__body\">住民に提供する<br>サービスの向上</p>\n            </li>\n          </ul>\n          <h3 class=\"answer__subtitle answer__subtitle--small js-inview tr-fade-in tr-fade-in--bottom\">「こたえ」を生むソリューション</h3>\n          <div class=\"answer__inner js-scrollable\">\n            <table class=\"answer__table table-01 js-inview tr-fade-in tr-fade-in--bottom\">\n              <thead>\n                <tr>\n                  <th class=\"blank\"></th>\n                  <th colspan=\"2\">民間</th>\n                  <th colspan=\"2\">公共</th>\n                </tr>\n              </thead>\n              <tbody>\n                <tr>\n                  <th>ICT関連事業<br><span class=\"en l\">65</span><span class=\"en m\">%</span></th>\n                  <td>\n                    <ul class=\"list-02\">\n                      <li>-ネットワークソリューション</li>\n                      <li>-ソフトウェアライセンス</li>\n                      <li>-IT資産管理</li>\n                      <li>-クラウドマネージドサービス</li>\n                    </ul>\n                  </td>\n                  <td>\n                    <ul class=\"list-02\">\n                      <li>-業種別ソリューション</li>\n                      <li>-業種別クラウドサービス</li>\n                      <li>-業種別マネージドサービス</li>\n                    </ul>\n                  </td>\n                  <td>\n                    <ul class=\"list-02\">\n                      <li>-教育ICT</li>\n                      <li>-大学ICT</li>\n                      <li>-教育クラウドサービス</li>\n                    </ul>\n                  </td>\n                  <td>\n                    <ul class=\"list-02\">\n                      <li>-官公庁・自治体向け<br>ICTソリューション</li>\n                      <li>-福祉業務ソリューション</li>\n                      <li>-ICT図書館ソリューション</li>\n                      <li>-公共クラウドサービス</li>\n                    </ul>\n                  </td>\n                </tr>\n                <tr>\n                  <th>環境構築関連事業<br>その他<br><span class=\"en l\">35</span><span class=\"en m\">%</span></th>\n                  <td>\n                    <ul class=\"list-02\">\n                      <li>-ドキュメントソリューション</li>\n                      <li>-ECOソリューション</li>\n                    </ul>\n                  </td>\n                  <td>\n                    <ul class=\"list-02\">\n                      <li>-オフィス家具の企画・開発</li>\n                      <li>-オフィス空間の設計・<br>構築・移転ビジネス</li>\n                      <li>-「働き方変革」コンサル<br>ティングサービス</li>\n                    </ul>\n                  </td>\n                  <td>\n                    <ul class=\"list-02\">\n                      <li>-理化学機器・教育機器</li>\n                      <li>-特別支援</li>\n                      <li>-学校向け通販サービス</li>\n                    </ul>\n                  </td>\n                  <td>\n                    <ul class=\"list-02\">\n                      <li>-学校・公共施設設備</li>\n                      <li>-官公庁・自治体向け<br>オフィス構築</li>\n                      <li>-大学コンサルティング・<br>教育環境構築</li>\n                    </ul>\n                  </td>\n                </tr>\n              </tbody>\n            </table>\n          </div>\n        </div>\n      </section>\n      <!-- question-->\n      <section class=\"functions question\">\n        <div class=\"question__title\">\n          <h2 class=\"title-03 js-inview inview-wrap\"><span class=\"title-03-bg-text marquee-text tr-fade-in\" aria-hideen=\"true\"><span class=\"title-03-bg-text__inner marquee-text__inner\">QUESTION QUESTION</span><span class=\"title-03-bg-text__inner marquee-text__inner\">QUESTION QUESTION</span></span><span class=\"slide-in__wrapper\"><span class=\"slide-in__inner title-03__en\">Q2</span></span><span class=\"title-03__ja title-03__ja--white tr-fade-in tr-fade-in--delay-03\">どのように「こたえ」を提供しているのか？</span></h2>\n        </div>\n        <!-- answer-->\n        <div class=\"answer answer--02\">\n          <div class=\"answer__title\">\n            <h3 class=\"title-03 js-inview inview-wrap\"><span class=\"title-03-bg-text tr-fade-in\" aria-hideen=\"true\"><span class=\"title-03-bg-text__inner title-03-bg-text__inner--gradient\">ANSWER</span></span><span class=\"slide-in__wrapper\"><span class=\"slide-in__inner title-03__en title-03__en--pink\">A.</span></span><span class=\"title-03__ja tr-fade-in tr-fade-in--delay-03\">商社機能と開発機能を併せ持ち、<br>お客様の課題・ニーズに対する<br>最適なソリューションを提供しています</span></h3>\n          </div>\n          <div class=\"answer__subtitle answer__subtitle--middle js-inview tr-fade-in tr-fade-in--bottom\">商社機能と開発機能</div>\n          <div class=\"company-function js-inview tr-fade-in tr-fade-in--bottom\">\n            <!-- company-function-item-->\n            <div class=\"company-function-item company-function-item--01\">\n              <p class=\"company-function-item__title\">仕入先</p>\n              <div class=\"company-function-item__content\">\n                <ul class=\"function-list-01\">\n                  <li class=\"function-list-01-item\">\n                    <p class=\"function-list-01-item__title\">メーカー</p>\n                    <figure class=\"function-list-01-item__figure\"><img class=\"function-list-01-item__image\" src=\"../assets/images/introduction/q2_icon_01.png\" srcset=\"../assets/images/introduction/q2_icon_01.png 1x, ../assets/images/introduction/q2_icon_01@2x.png 2x\" width=\"70\" height=\"70\" decoding=\"async\" loading=\"lazy\" alt=\"メーカー\"></figure>\n                  </li>\n                  <li class=\"function-list-01-item\">\n                    <p class=\"function-list-01-item__title\">システム<br>開発会社</p>\n                    <figure class=\"function-list-01-item__figure\"><img class=\"function-list-01-item__image\" src=\"../assets/images/introduction/q2_icon_02.png\" srcset=\"../assets/images/introduction/q2_icon_02.png 1x, ../assets/images/introduction/q2_icon_02@2x.png 2x\" width=\"70\" height=\"70\" decoding=\"async\" loading=\"lazy\" alt=\"システム開発会社\"></figure>\n                  </li>\n                </ul>\n              </div>\n            </div>\n            <div class=\"company-function__arrows\">\n              <div class=\"company-function__arrow company-function__arrow--01\">調達</div>\n              <div class=\"company-function__arrow company-function__arrow--02\">納品</div>\n            </div>\n            <!-- company-function-item-->\n            <div class=\"company-function-item company-function-item--02\">\n              <p class=\"company-function-item__title\">内田洋行</p>\n              <div class=\"company-function-item__content\">\n                <ul class=\"function-list-02\">\n                  <li class=\"function-list-02-item\">\n                    <p class=\"function-list-02-item__title\">商社機能</p>\n                  </li>\n                  <li class=\"function-list-02-item\">\n                    <p class=\"function-list-02-item__title\">開発機能</p>\n                  </li>\n                </ul>\n              </div>\n            </div>\n            <div class=\"company-function__arrows\">\n              <div class=\"company-function__arrow company-function__arrow--01 letter-spacing--narrow\">ヒアリング</div>\n              <div class=\"company-function__arrow company-function__arrow--02\">提案</div>\n            </div>\n            <!-- company-function-item-->\n            <div class=\"company-function-item company-function-item--03\">\n              <p class=\"company-function-item__title\">お客様</p>\n              <div class=\"company-function-item__content\">\n                <ul class=\"function-list-01\">\n                  <li class=\"function-list-01-item\">\n                    <p class=\"function-list-01-item__title\">民間企業</p>\n                    <figure class=\"function-list-01-item__figure\"><img class=\"function-list-01-item__image\" src=\"../assets/images/introduction/q2_icon_03.png\" srcset=\"../assets/images/introduction/q2_icon_03.png 1x, ../assets/images/introduction/q2_icon_03@2x.png 2x\" width=\"70\" height=\"70\" decoding=\"async\" loading=\"lazy\" alt=\"メーカー\"></figure>\n                  </li>\n                  <li class=\"function-list-01-item\">\n                    <p class=\"function-list-01-item__title\">学校・自治体</p>\n                    <figure class=\"function-list-01-item__figure\"><img class=\"function-list-01-item__image\" src=\"../assets/images/introduction/q2_icon_04.png\" srcset=\"../assets/images/introduction/q2_icon_04.png 1x, ../assets/images/introduction/q2_icon_04@2x.png 2x\" width=\"70\" height=\"70\" decoding=\"async\" loading=\"lazy\" alt=\"システム開発会社\"></figure>\n                  </li>\n                </ul>\n              </div>\n            </div>\n          </div>\n          <div class=\"answer__text js-inview tr-fade-in tr-fade-in--bottom\">\n            <p><span class=\"purple\">商社機能</span>：<br class=\"is-sp\">仕入先となるメーカー・システム開発会社のソリューションを活用<br></p>\n            <p><span class=\"purple\">開発機能</span>：<br class=\"is-sp\">自社オリジナル商品の開発・提供</p>\n          </div>\n        </div>\n      </section>\n      <!-- question-->\n      <section class=\"question\">\n        <div class=\"question__title\">\n          <h2 class=\"title-03 js-inview inview-wrap\"><span class=\"title-03-bg-text marquee-text tr-fade-in\" aria-hideen=\"true\"><span class=\"title-03-bg-text__inner marquee-text__inner\">QUESTION QUESTION</span><span class=\"title-03-bg-text__inner marquee-text__inner\">QUESTION QUESTION</span></span><span class=\"slide-in__wrapper\"><span class=\"slide-in__inner title-03__en\">Q3</span></span><span class=\"title-03__ja title-03__ja--white tr-fade-in tr-fade-in--delay-03\">「こたえ」を生みだし続けることで内田洋行が目指すものとは？</span></h2>\n        </div>\n        <!-- answer-->\n        <div class=\"answer answer--03\">\n          <div class=\"answer__title\">\n            <h3 class=\"title-03 js-inview inview-wrap\"><span class=\"title-03-bg-text tr-fade-in\" aria-hideen=\"true\"><span class=\"title-03-bg-text__inner title-03-bg-text__inner--gradient\">ANSWER</span></span><span class=\"slide-in__wrapper\"><span class=\"slide-in__inner title-03__en title-03__en--pink\">A.</span></span><span class=\"title-03__ja tr-fade-in tr-fade-in--delay-03\">「働き方変革」「学び方変革」を実現し、<br>これからの日本に待ち受ける社会課題の解決を目指します</span></h3>\n          </div>\n          <div class=\"answer__subtitle answer__subtitle--middle js-inview tr-fade-in tr-fade-in--bottom\">創業以来、フロンティア<br class=\"is-sp\">精神を持ち続け、<br>時代に応じて扱う<br class=\"is-sp\">ソリューションを変えてきた<br class=\"is-sp\">内田洋行。<br>これからも課題に対する<br class=\"is-sp\">最適な「こたえ」を<br class=\"is-sp\">考え続けながら、<br>お客様の変革を支援します</div>\n          <ul class=\"task\">\n            <li class=\"task-item js-inview tr-fade-in tr-fade-in--bottom\">\n              <figure class=\"task__figure\"><img class=\"task__image\" src=\"../assets/images/introduction/q3_icon_01.png\" srcset=\"../assets/images/introduction/q3_icon_01.png 1x, ../assets/images/introduction/q3_icon_01@2x.png 2x\" width=\"170\" height=\"170\" decoding=\"async\" loading=\"lazy\" alt=\"働き方変革\"></figure>\n              <p class=\"task-item__body\">働き方変革</p>\n            </li>\n            <li class=\"task-item js-inview tr-fade-in tr-fade-in--bottom\">\n              <figure class=\"task__figure\"><img class=\"task__image\" src=\"../assets/images/introduction/q3_icon_02.png\" srcset=\"../assets/images/introduction/q3_icon_02.png 1x, ../assets/images/introduction/q3_icon_02@2x.png 2x\" width=\"170\" height=\"170\" decoding=\"async\" loading=\"lazy\" alt=\"学び方変革\"></figure>\n              <p class=\"task-item__body\">学び方変革</p>\n            </li>\n          </ul>\n        </div>\n      </section>\n      <!-- banner-->\n      <section class=\"banner banner--wide\">\n        <h2 class=\"banner__title title-03 title-03--ja-only js-inview inview-wrap\"><span class=\"title-03-bg-text marquee-text tr-fade-in\" aria-hideen=\"true\"><span class=\"title-03-bg-text__inner title-03-bg-text__inner--gradient marquee-text__inner\">FRONTIER SPIRIT FRONTIER SPIRIT</span><span class=\"title-03-bg-text__inner title-03-bg-text__inner--gradient marquee-text__inner\">FRONTIER SPIRIT FRONTIER SPIRIT</span></span><span class=\"title-03__ja tr-fade-in tr-fade-in--delay-03\">内田洋行のフロンティア精神を知る</span></h2>\n        <div class=\"banner__inner\">\n          <div class=\"banner-item js-inview tr-fade-in tr-fade-in--bottom\"><a class=\"banner-item__link scale-up\" href=\"../introduction/result/\">\n              <figure class=\"banner-item__figure\">\n                <picture>\n                  <source srcset=\"../assets/images/common/banner/result_sp.jpg\" media=\"(max-width: 767px)\"><img class=\"banner-item__image\" src=\"../assets/images/common/banner/result_pc.jpg\" srcset=\"../assets/images/common/banner/result_pc.jpg 1x, ../assets/images/common/banner/result_pc@2x.jpg 2x\" width=\"1160\" height=\"260\" decoding=\"async\" loading=\"lazy\" 