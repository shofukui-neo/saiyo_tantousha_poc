container-fluid vh-100 d-flex justify-content-center align-items-center js-scroll\" data-add-class=\"animated-fade-in\" data-is-main-image-scroll=\"true\" data-src=\"https://assets.toroo.jp/images/company/1085/390fce77-230d-4df2-be8e-4b17bfd72099.png\" data-template-position=\"50\"><div class=\"mv-dark js-mv-dark\"></div><div class=\"position-relative text-center\"><h1 class=\"mv-logo text-white mb-5\"><img alt=\"株式会社建美装社\" class=\"mv-logo-image img-fluid\" src=\"https://assets.toroo.jp/images/company/1085/e6eae53f-66cf-4fe9-9637-1552e44230ac.png\" /><span class=\"font-weight-bold d-block mt-4 mv-logo-text\">株式会社建美装社 RECRUIT</span></h1><p class=\"mv-lead font-weight-bold mt-5\" style=\"color:#fff;\">人と環境を大切にする会社<br />▼お気軽にエントリーください▼</p></div></section><script>var pos = parseInt($('.js-main-image-position').data('templatePosition'))\n$('.js-main-image-position').css({'background-position': pos + '% center'})\n\nif (window.matchMedia('(max-width:768px)').matches) {\n  if ($('.js-main-image-position').data('is-main-image-scroll')) {\n    var sec = 20\n    pos = 0\n    $('.js-main-image-position').css({\n      animation: 'scroll ' + sec + 's linear infinite',\n      'animation-delay': -sec * (pos / 100) + \"s\"\n    })\n    $('.js-mv-dark').css({\n      animation: 'scroll_bg ' + sec + 's linear infinite',\n      'animation-delay': -sec * (pos / 100) + \"s\"\n    })\n  }\n}else{\n  $('.js-main-image-position').css({'background-position': '50% center'})\n}</script><style type=\"text/css\">@keyframes scroll{0%{background-position:0%}100%{background-position:100%}}@keyframes scroll_bg{0%{opacity:1}10%{opacity:0.45}90%{opacity:0.45}100%{opacity:1}}.btn-gradation{z-index:1}</style><div class=\"main-contents\"><input type=\"hidden\" name=\"about\" id=\"key\" value=\"true\" readonly=\"readonly\" /><input type=\"hidden\" name=\"culture\" id=\"key\" value=\"true\" readonly=\"readonly\" /><input type=\"hidden\" name=\"sdg_public\" id=\"key\" value=\"\" readonly=\"readonly\" /><input type=\"hidden\" name=\"sdg\" id=\"key\" value=\"false\" readonly=\"readonly\" /><input type=\"hidden\" name=\"interview\" id=\"key\" value=\"true\" readonly=\"readonly\" /><input type=\"hidden\" name=\"job\" id=\"key\" value=\"true\" readonly=\"readonly\" /><input type=\"hidden\" name=\"event\" id=\"key\" value=\"false\" readonly=\"readonly\" /><input type=\"hidden\" name=\"movie_public\" id=\"key\" value=\"false\" readonly=\"readonly\" /><input type=\"hidden\" name=\"movie_location\" id=\"key\" value=\"\" readonly=\"readonly\" /><input type=\"hidden\" name=\"freepage_public\" id=\"key\" value=\"false\" readonly=\"readonly\" /><input type=\"hidden\" name=\"freepage_location\" id=\"key\" value=\"\" readonly=\"readonly\" /><div class=\"display-none\" id=\"youtube-video-check-main-image\"></div><div class=\"display-none\" id=\"freepage-check-main-image\"></div><div id=\"orig-about\"><section class=\"section\"><div class=\"container js-scroll\" data-add-class=\"animated-fade-in-up\"><h2 class=\"heading-cmn text-center position-relative mb-5\">About us<small class=\"heading-cmn-jp d-block mt-4\">私たちについて</small></h2><div class=\"row js-read-more-top read-more-top outer-alternate-text-color\" data-add-class=\"read-more\"><figure class=\"col-md-5\"><a href=\"https://recruit-kenbisosha.com/about\"><img class=\"shadow img-fluid js-lazy\" data-src=\"https://assets.toroo.jp/images/company/1085/7b0bf1ed-3290-4450-bdb3-42f2fb2dfcc6.png\" /></a></figure><div class=\"col-md-7 js-read-more-text inner-alternate-text-color\"><p class=\"lead font-weight-bold mb-4\">人と環境を大切にする総合ビルメンテナンス会社</p><div class=\"custom-body-text-color\"><div class=\"simple_format\">当社採用サイトをご覧いただき、ありがとうございます！<br>当社は2023年に50周年を迎える、1973年設立の総合ビルメンテナンス会社です。ビルやマンションなどの貯水槽清掃事業からスタートした当社は、お客様のニーズに応えるカタチで事業範囲を拡大していきました。<br><br>現在は、建物管理におけるトータルなサポートを行える体制を実現しています。また、実直な経営を続けることで従業員数約200名を超える規模まで成長。現在も右肩上がりの成長を続けている会社です！</div></div><div class=\"read-more-btn text-center\"><a href=\"https://recruit-kenbisosha.com/about\"><u><span>続きを見る</span><div class=\"fas fa-chevron-right d-inline\"></div></u></a></div></div></div><a class=\"btn btn-lg btn-cmn btn-custom-color d-block shadow my-0 mx-auto mt-5\" href=\"https://recruit-kenbisosha.com/about\"><div class=\"row align-items-center\"><span class=\"col-8 offset-2 d-block font-weight-bold\">私たちについて</span><i class=\"fas fa-chevron-right d-block col-2\"></i></div></a></div></section></div><div class=\"display-none about-us\" id=\"youtube-video-check-about-us\"></div><div class=\"display-none about-us\" id=\"freepage-check-about-us\"></div><div id=\"orig-culture\"><section class=\"section\"><div class=\"container js-scroll\" data-add-class=\"animated-fade-in-up\"><h2 class=\"heading-cmn text-center position-relative mb-5\">Culture<small class=\"heading-cmn-jp d-block mt-4\">制度・環境・文化</small></h2><div class=\"row flex-column-reverse flex-md-row js-read-more-top read-more-top outer-alternate-text-color\" data-add-class=\"read-more\"><div class=\"col-md-7 js-read-more-text inner-alternate-text-color\"><p class=\"lead font-weight-bold mb-4\">■ 働きやすさ、職場環境 ■</p><div class=\"custom-body-text-color\"><div class=\"simple_format\">従業員の平均残業時間は月20時間程度で、もちろん残業代は全て支給します。年間休日は105日で、希望を優先したシフト制です。土日祝での取得も可能で、希望の休みを最大限考慮して取得いただけます。<br><br>積極的な有給の取得も推奨しており、全従業員5日以上は取得しています。中には有給20日中15日以上取得する従業員も！余暇時間も充実して過ごせる環境です。今後も従業員がより働きやすくなるよう環境の整備に努めてまいります！<br></div></div><div class=\"read-more-btn text-center\"><a href=\"https://recruit-kenbisosha.com/culture\"><u><span>続きを見る</span><div class=\"fas fa-chevron-right d-inline\"></div></u></a></div></div><figure class=\"col-md-5\"><a href=\"https://recruit-kenbisosha.com/culture\"><img alt=\"■ 働きやすさ、職場環境 ■\" class=\"shadow img-fluid js-lazy\" data-src=\"https://assets.toroo.jp/images/company/1085/156262e5-8867-4d4b-8d29-727d5c30ae60.png\" /></a></figure></div><a class=\"btn btn-lg btn-cmn btn-custom-color d-block shadow my-0 mx-auto mt-5\" href=\"https://recruit-kenbisosha.com/culture\"><div class=\"row align-items-center\"><span class=\"col-8 offset-2 d-block font-weight-bold\">制度・環境・文化</span><i class=\"fas fa-chevron-right d-block col-2\"></i></div></a></div></section></div><div class=\"display-none cluture\" id=\"youtube-video-check-culture\"></div><div class=\"display-none cluture\" id=\"freepage-check-culture\"></div><div class=\"display-none sdgs\" id=\"youtube-video-check-sdgs\"></div><div class=\"display-none sdgs\" id=\"freepage-check-sdgs\"></div><div id=\"orig-interview\"><section class=\"section\"><div class=\"container js-scroll\" data-add-class=\"animated-fade-in-up\"><h2 class=\"heading-cmn text-center position-relative mb-5\">Interview<small class=\"heading-cmn-jp d-block mt-4\">社員インタビュー</small></h2><div class=\"row mb-5 justify-content-center\"><div class=\"mb-5 mb-sm-0 col-sm-4\"><a class=\"card d-block text-white text-decoration-none bg-primary shadow h-100\" href=\"https://recruit-kenbisosha.com/interviews/1460\"><div alt=\"ビルメンテナンス部 工事課 リーダー/猿渡\" class=\"bg-white js-lazy bg-img interview_1e1584a3-cb9a-4be1-bc93-142524e23c30\" data-src=\"https://assets.toroo.jp/images/company/1085/b59e7ed4-cd4c-4e5d-9f9e-5b6e03b5c6ee.png\"></div><div class=\"card-body d-flex py-4 px-3 px-lg-5 align-items-center\"><div class=\"font-weight-bold\"><p>ビルメンテナンス部 工事課 リーダー</p><p class=\"card-title card-title-large mb-3\">猿渡</p><p class=\"card-text card-txt-small\">2018年3月入社</p></div></div></a></div><div class=\"mb-5 mb-sm-0 col-sm-4\"><a class=\"card d-block text-white text-decoration-none bg-primary shadow h-100\" href=\"https://recruit-kenbisosha.com/interviews/1461\"><div alt=\"ビルメンテナンス部 工事課 一般社員/梶本\" class=\"bg-white js-lazy bg-img interview_1e1584a3-cb9a-4be1-bc93-142524e23c30\" data-src=\"https://assets.toroo.jp/images/company/1085/7e8f19b8-e6b4-430b-8f7d-ce1936d2258f.png\"></div><div class=\"card-body d-flex py-4 px-3 px-lg-5 align-items-center\"><div class=\"font-weight-bold\"><p>ビルメンテナンス部 工事課 一般社員</p><p class=\"card-title card-title-large mb-3\">梶本</p><p class=\"card-text card