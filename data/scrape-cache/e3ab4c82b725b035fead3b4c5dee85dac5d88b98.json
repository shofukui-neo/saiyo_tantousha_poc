{"url":"https://www.takizumi.com/recruit/business/","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n<head prefix=\"og: http://ogp.me/ns#\">\n\t<!-- Google tag (gtag.js) -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-23HKB9BP8V\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'G-23HKB9BP8V');\n</script>\t<meta charset=\"UTF-8\">\n\t<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n\t<title>事業紹介｜タキズミ採用サイト</title>\n  <meta name=\"description\" content=\"株式会社タキズミの事業紹介です。オフィスビル・商業施設などの設備リニューアルやデザイン改修を行うPMソリューション事業と、賃貸物件における退去時のトラブルを防ぎ、スムーズな契約終了をサポートする管理ソリューション事業の2つの事業でお客様のお困りごとを解決します。\">\n  <meta name=\"keywords\" content=\"\">\n\n  <meta property=\"fb:app_id\" content=\"\">\n  <meta property=\"og:title\" content=\"事業紹介｜タキズミ採用サイト\">\n  <meta property=\"og:description\" content=\"株式会社タキズミの事業紹介です。オフィスビル・商業施設などの設備リニューアルやデザイン改修を行うPMソリューション事業と、賃貸物件における退去時のトラブルを防ぎ、スムーズな契約終了をサポートする管理ソリューション事業の2つの事業でお客様のお困りごとを解決します。\">\n  <meta property=\"og:type\" content=\"website\">\n  <meta property=\"og:image\" content=\"https://www.takizumi.com/recruit/images/ogp.jpg\">\n  <meta property=\"og:url\" content=\"https://www.takizumi.com/recruit/business/\">\n  <meta property=\"og:site_name\" content=\"株式会社タキズミ\">\n  <meta property=\"og:locale\" content=\"ja_JP\">\n  <meta name=\"twitter:title\" content=\"事業紹介｜タキズミ採用サイト\">\n  <meta name=\"twitter:description\" content=\"株式会社タキズミの事業紹介です。オフィスビル・商業施設などの設備リニューアルやデザイン改修を行うPMソリューション事業と、賃貸物件における退去時のトラブルを防ぎ、スムーズな契約終了をサポートする管理ソリューション事業の2つの事業でお客様のお困りごとを解決します。\">\n  <meta name=\"twitter:image\" content=\"https://www.takizumi.com/recruit/images/ogp.jpg\">\n  <meta name=\"twitter:url\" content=\"https://www.takizumi.com/recruit/business/\">\n\t<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<link rel=\"icon\" href=\"/recruit/images/apple-touch-icon.png\">\n<link rel=\"shortcut icon\" href=\"/recruit/images/apple-touch-icon.png\">\n<link rel=\"shortcut icon\" type=\"image/x-icon\" href=\"/recruit/favicon.ico\">\n<link rel=\"apple-touch-icon\" href=\"/recruit/images/apple-touch-icon.png\">\n<link rel=\"apple-touch-icon-precomposed\" href=\"/recruit/images/apple-touch-icon-precomposed.png\">\n\n\t<link rel=\"stylesheet\" href=\"../css/reset.css\">\n  <link rel=\"stylesheet\" href=\"../css/style.css\">\n</head>\n<body>\n\t\n  <div id=\"wrapper\" class=\"business\">\n  <div id=\"Loader\"><span class=\"base\"></span><span class=\"progress\"></span></div>\n\n\t\t<div id=\"page\">\n\t\t\t<header id=\"header\" class=\"header\">\n  <div class=\"header_logo_area\"><a href=\"/recruit/\">\n    <p class=\"header_logo\"><img src=\"/recruit/images/all_logo.jpg\" alt=\"株式会社タキズミ\"></p>\n    <p class=\"header_logo_recruit\">RECRUIT SITE</p>\n  </a></div>\n\t<div class=\"header_menubtn\">\n\t\t<div class=\"header_menubtn_lines\">\n\t\t\t<span></span>\n\t\t\t<span></span>\n\t\t</div>\n\t</div>\n\t<div class=\"header_wrap\">\n\t\t<div class=\"header_wrap_inner\">\n\t\t\t<nav class=\"header_gnav\">\n\t\t\t\t<ul class=\"header_gnav_nav\">\n\t\t\t\t\t<li class=\"header_gnav_item header_gnav_item_01 header_gnav_item_solo\"><a href=\"/recruit/business/\">事業紹介</a></li>\n\t\t\t\t\t<li class=\"header_gnav_item header_gnav_item_02 header_gnav_item_mega\"><span>仕事を知る</span>\n\t\t\t\t\t\t<div class=\"header_gnav_mega\">\n\t\t\t\t\t\t\t<ul class=\"header_megamenu\">\n\t\t\t\t\t\t\t\t<li class=\"header_megamenu_item\"><a href=\"/recruit/crosstalk/\">社員クロストーク</a></li>\n\t\t\t\t\t\t\t\t<li class=\"header_megamenu_item\"><a href=\"/recruit/workflow/\">1日の仕事の流れ</a></li>\n\t\t\t\t\t\t\t</ul>\n\t\t\t\t\t\t</div>\n          </li>\n\t\t\t\t\t<li class=\"header_gnav_item header_gnav_item_03 header_gnav_item_mega\"><span>働く環境を知る</span>\n\t\t\t\t\t\t<div class=\"header_gnav_mega\">\n\t\t\t\t\t\t\t<ul class=\"header_megamenu\">\n\t\t\t\t\t\t\t\t<li class=\"header_megamenu_item\"><a href=\"/recruit/training/\">キャリア・研修制度</a></li>\n\t\t\t\t\t\t\t\t<li class=\"header_megamenu_item\"><a href=\"/recruit/welfare/\">福利厚生</a></li>\n\t\t\t\t\t\t\t</ul>\n\t\t\t\t\t\t</div>\n          </li>\n\t\t\t\t\t<li class=\"header_gnav_item header_gnav_item_04 header_gnav_item_mega\"><span>人を知る</span>\n\t\t\t\t\t\t<div class=\"header_gnav_mega\">\n\t\t\t\t\t\t\t<ul class=\"header_megamenu\">\n\t\t\t\t\t\t\t\t<li class=\"header_megamenu_item\"><a href=\"/recruit/Interview01/\">社員インタビュー01</a></li>\n\t\t\t\t\t\t\t\t<li class=\"header_megamenu_item\"><a href=\"/recruit/Interview02/\">社員インタビュー02</a></li>\n\t\t\t\t\t\t\t\t<!-- <li class=\"header_megamenu_item\"><a href=\"/recruit/Interview03/\">社員インタビュー03</a></li>  -->\n\t\t\t\t\t\t\t\t<!-- <li class=\"header_megamenu_item\"><a href=\"/recruit/Interview04/\">社員インタビュー04</a></li> -->\n\t\t\t\t\t\t\t</ul>\n\t\t\t\t\t\t</div>\n          </li>\n\t\t\t\t\t<li class=\"header_gnav_item header_gnav_item_05 header_gnav_item_solo\"><a href=\"/recruit/detail/\">募集要項</a></li>\n\t\t\t\t</ul>\n\t\t\t</nav>\n      <p class=\"header_corporate\"><a href=\"http://www.takizumi.com/\" target=\"_blank\">コーポレートサイトはこちら</a></p>\n\t\t\t<div class=\"header_entry\">\n\t\t\t\t<p class=\"header_entry_btn\"><a href=\"/recruit/detail/#message\">エントリー</a></p>\n\t\t\t</div>\n      <p class=\"header_copy\">&copy; 2022 TAKIZUMI All Right Reserved.</p>\n\t\t</div><!-- /.header_wrap_inner -->\n\t</div><!-- /.header_wrap -->\n</header>\n\n\t\t\t<main id=\"main\">\n\t\t\t\t<div class=\"all_m_mv\"><div class=\"all_m_mv_wrap\">\n          <div class=\"all_m_mv_title\">\n\t\t\t\t\t\t<h1 class=\"all_m_mv_title_text\">事業紹介</h1>\n            <span class=\"all_m_mv_title_obj\"><img src=\"../images/business_txt_obj.svg\" alt=\"Business\"></span>\n\t\t\t\t\t</div>\n          <figure class=\"all_m_mv_img\"><img src=\"../images/business_img_mv.jpg\" alt=\"事業紹介\"></figure>\n          <div class=\"all_m_mv_scroll\">\n            <p class=\"all_m_mv_scroll_img\"><img src=\"../images/all_img_mv_scroll.svg\" alt=\"SCROLL\"></p>\n          </div>\n\t\t\t\t</div></div><!-- /.all_m_mv -->\n\n        <div class=\"all_m_intro all_m_intro_flat\">\n          <div class=\"all_l_wrap\">\n            <h2 class=\"all_m_intro_title all_c_title_en\" data-anim=\"fadeup\">・Introduction</h2>\n            <p class=\"all_m_intro_catch\" data-anim=\"fadeup\">お客様のお困りごとを<br class=\"all_mi_sp\">解決するため、<br>２つの事業部に分かれ、<br>環境に配慮した業務を<br class=\"all_mi_sp\">展開しています。</p>\n            <p class=\"all_m_intro_text\" data-anim=\"fadeup\">私たちの仕事は、ビルのオーナー様や不動産会社様など、お客様のお困りごとを解決し、独自のご提案をプラスすることで、社会全体に快適な空間を増やすことです。また、それを通じて、現代社会の共通課題である環境問題にも貢献したいと考えています。そんな私たちが創業以来30年以上にわたり、多くの実績を積み上げながら確立した２つのソリューション事業部についてご紹介します。</p>\n          </div>\n        </div><!-- /.all_m_intro -->\n\n        <div class=\"all_l_wrap_l\">\n          <div class=\"business_contents\">\n            <div class=\"business_division\">\n              <div class=\"business_division_bg\">\n                <span class=\"business_division_bg_img\">\n                  <picture>\n                    <source media=\"(min-width:768px)\" srcset=\"../images/business_bg_pmsolution.jpg\">\n                    <source media=\"(max-width:767px)\" srcset=\"../images/business_bg_pmsolution_sp.jpg\">\n                    <img src=\"../images/business_bg_pmsolution.jpg\" alt=\"画像\">\n                  </picture>\n                </span>\n                <span class=\"business_division_bg_color\"></span>\n              </div>\n              <span class=\"business_division_obj\"><img src=\"../images/business_txt_obj_solution.svg\" alt=\"Solution\"></span>\n              <div class=\"all_l_wrap\">\n                <div class=\"business_division_header\" data-anim=\"fadeup\">\n                  <div class=\"business_division_header_inner\">\n                    <h3 class=\"business_division_title\">PMソリューション事業部</h3>\n                    <p class=\"business_division_lead\">オフィスビル・商業施設などの設備リニューアルや<br class=\"all_mi_pc\">デザイン改修を行う部署。私たちにしかできない付加価値の提案と<br class=\"all_mi_pc\">環境への配慮を心がけています。</p>\n                  </div>\n                </div>\n              </div>\n              <div class=\"business_division_content\">\n                <ul class=\"business_division_conetnt_list\">\n                  <li class=\"business_division_content_item\" data-anim=\"fadeup\">\n                    <div class=\"business_division_content_item_image\">\n                      <figure class=\"business_division_content_item_img\">\n                        <img src=\"../images/business_img_pmsolution01.jpg\" width=\"440\" height=\"293\" alt=\"設備リニューアルソリューション\">\n                      </figure>\n                    </div>\n                    <div class=\"business_division_content_item_body\">\n                      <h4 class=\"business_division_content_item_title\">・設備リニューアルソリューション</h4>\n                      <p class=\"business_division_content_item_lead\">空調機器の更新、照明のLED化を行い、<br class=\"all_mi_pc\">エネルギー消費量とコストの削減を<br class=\"all_mi_pc\">サポートします。</p>\n                      <p class=\"business_division_content_item_text\">建物の中で快適に暮らし、仕事をするために空調や照明は欠かせないもの。しかし、エネルギー消費の5～7割を占めるなど、コスト負担や地球環境への影響も軽視できません。私たちは、古くなった空調機器の更新や照明のLED化などを建物全体で実施。コスト削減に貢献することでオーナー様にご満足をいただくと共に、環境保全にも寄与しています。</p>\n                    </div>\n                  </li>\n                  <li class=\"business_division_content_item\" data-anim=\"fadeup\">\n                    <div class=\"business_division_content_item_image\">\n                      <figure class=\"business_division_content_item_img\">\n                        <img src=\"../images/business_img_pmsolution02.jpg\" width=\"440\" height=\"293\" alt=\"デザイン改修ソリューション\">\n                      </figure>\n                    </div>\n                    <div class=\"business_division_content_item_body\">\n                      <h4 class=\"business_division_content_item_title\">・デザイン改修ソリューション</h4>\n                      <p class=\"business_division_content_item_lead\">お客様のご要望にプラスαの価値を提供して、<br class=\"all_mi_pc\">見違えるような空間を演出します</p>\n                      <p class=\"business_division_content_item_text\">築年数が経過したオフィスビルやマンションなどのエントランス、共用廊下、共用トイレといった箇所の全面的なリニューアルを行い、まるで新築のような空間をご提供します。改修のご要望をいただくと、企画、デザイン、設計、施工まで全ての工程を担当。既存の建物が美しく蘇ることで、オーナー様、入居者様にお喜びいただくだけでなく、空室化を防ぎ長年使用されることにつながるため、地域活性化・環境にもやさしい取り組みです。</p>\n                    </div>\n                  </li>\n                </ul>\n              </div>\n            </div><!-- /.business_division -->\n            <div class=\"business_division _reverse\">\n              <div class=\"business_division_bg\">\n                <span class=\"business_division_bg_img\">\n                  <picture>\n                    <source media=\"(min-width:768px)\" srcset=\"../images/business_bg_management.jpg\">\n                    <source media=\"(max-width:767px)\" srcset=\"../images/business_bg_management_sp.jpg\">\n                    <img src=\"../images/business_bg_management.jpg\" alt=\"画像\">\n                  </picture>\n                </span>\n                <span class=\"business_division_bg_color\"></span>\n              </div>\n              <span class=\"business_division_obj\"><img src=\"../images/business_txt_obj_management.svg\" alt=\"Management\"></span>\n              <div class=\"all_l_wrap\">\n                <div class=\"business_division_header\" data-anim=\"fadeup\">\n                  <div class=\"business_division_header_inner\">\n                    <h3 class=\"business_division_title\">管理ソリューション事業部</h3>\n                    <p class=\"business_division_lead\">賃貸物件における退去時のトラブルを防ぎ、<br class=\"all_mi_pc\">不動産会社様(管理会社様)と入居者様の<br class=\"all_mi_pc\">スムーズな契約終了をサポートさせていただきます。</p>\n                  </div>\n                </div>\n              </div>\n              <div class=\"business_division_content\">\n                <ul class=\"business_division_conetnt_list\">\n                  <li class=\"business_division_content_item\" data-anim=\"fadeup\">\n                    <div class=\"business_division_content_item_image\">\n                      <figure class=\"business_division_content_item_img\">\n                        <img src=\"../images/business_img_management.jpg\" width=\"440\" height=\"293\" alt=\"管理ソリューション\">\n                      </figure>\n                    </div>\n                    <div class=\"business_division_content_item_body\">\n                      <h4 class=\"business_division_content_item_title\">・管理ソリューション</h4>\n                      <p class=\"business_division_content_item_lead\">退去時の立ち会いや<br class=\"all_mi_pc\">原状回復工事をはじめ、<br class=\"all_mi_pc\">効率的なリーシングをお手伝いします。</p>\n                      <p class=\"business_division_content_item_text\">不動産会社様や管理会社様にとって、賃貸物件の退去時の管理は負担の大きな業務。私たちは都内に管理受託物件15,000室以上・管理棟数215棟を持ち、入居者様の退去時期に立ち会い、室内の状態の入念な確認と解約業務を代行します。またその後、新しい入居者様が気持ちよくお部屋に住むことができる状態にするための原状回復工事を行うことで、次につながる物件に仕立てます。</p>\n                    </div>\n                  </li>\n                </ul>\n              </div>\n            </div><!-- /.business_division -->\n            <div class=\"all_l_wrap\">\n              <div class=\"business_flow\" data-anim=\"fadeup\">\n                <h5 class=\"business_flow_title\">業務フローの一例</h5>\n                <ol class=\"business_flow_list\">\n                  <li class=\"business_flow_item\">\n                    <p class=\"business_flow_item_number\">01</p>\n                    <p class=\"business_flow_item_title\">営業プロセス</p>\n                    <p class=\"business_flow_item_text\">・営業活動(案件獲得)</p>\n                  </li>\n                  <li class=\"business_flow_item\">\n                    <p class=\"business_flow_item_number\">02</p>\n                    <p class=\"business_flow_item_title\">企画プロセス</p>\n                    <p class=\"business_flow_item_text\">・調査＋プランニング<br>・デザイン提案＋見積<br>・受注・契約</p>\n                  </li>\n                  <li class=\"business_flow_item\">\n                    <p class=\"business_flow_item_number\">03</p>\n                    <p class=\"business_flow_item_title\">実施計画プロセス</p>\n                    <p class=\"business_flow_item_text\">・施工計画＋職人手配</p>\n                  </li>\n                  <li class=\"business_flow_item\">\n                    <p class=\"business_flow_item_number\">04</p>\n                    <p class=\"business_flow_item_title\">工事実施プロセス</p>\n                    <p class=\"business_flow_item_text\">・工事詳細計画＋安全管理<br>・工事詳細指示＋近隣対応</p>\n                  </li>\n                  <li class=\"business_flow_item\">\n                    <p class=\"business_flow_item_number\">05</p>\n                    <p class=\"business_flow_item_title\">竣工プロセス</p>\n                    <p class=\"business_flow_item_text\">・工事詳細確認<br>・引き渡し</p>\n                  </li>\n                </ol>\n              </div><!-- /.business_flow -->\n            </div><!-- /.all_l_wrap -->\n          </div><!-- /.business_contents -->\n        </div><!-- /.all_l_wrap_l -->\n\n        <div class=\"all_m_breadcrumb\">\n          <div class=\"all_l_wrap\">\n            <ul class=\"all_m_breadcrumb_list\">\n              <li class=\"all_m_breadcrumb_item\"><a href=\"../\">トップ</a></li>\n              <li class=\"all_m_breadcrumb_item _current\">事業紹介</li>\n            </ul>\n          </div>\n        </div><!-- /.all_m_breadcrumb -->\n\t\t\t</main><!-- /#main -->\n\n\t\t\t<div class=\"all_m_entry\">\n  <div class=\"all_m_entry_boxes\">\n    <div class=\"all_m_entry_box all_m_entry_recruitment\"><a href=\"/recruit/detail/\">\n      <span class=\"all_m_entry_box_filter\"></span>\n      <div class=\"all_m_entry_box_inner\">\n        <div class=\"all_m_entry_box_title_area\">\n          <p class=\"all_m_entry_box_title\">募集要項</p>\n        </div>\n        <div class=\"all_m_entry_box_btn\">\n          <span class=\"all_m_entry_box_btn_mark\"></span>\n        </div>\n      </div>\n      <span class=\"all_m_entry_box_obj\"><img src=\"/recruit/images/all_footer_txt_recruitment.svg\" alt=\"recruitment\"></span>\n    </a></div>\n    <div class=\"al