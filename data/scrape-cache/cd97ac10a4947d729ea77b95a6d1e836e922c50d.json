-tile ItemWrap\">\n                    <div class=\"Item\">\n                        <div class=\"Item__sub\">\n                            <img src=\"/images/home_tesst230609/variousServices_img01.jpg\" alt=\"様々なご要望に応じた制作も対応いたします\">\n                        </div>\n                    </div>\n                    <div class=\"Item\">\n                        <div class=\"Item__sub\">\n                            <img src=\"/images/home_tesst230609/variousServices_img02.jpg\" alt=\"細かい刺繍も承ります\">\n                        </div>\n                    </div>\n                </div>\n                <ul class=\"subNavi\">\n                    <li><a href=\"/category/sustainability/sustainability.html\">サステナブル</a></li>\n                    <li><a href=\"/category/planning/kikaku.html\">企画・デザイン</a></li>\n                    <li><a href=\"/category/sp_tool/sp_store.html\">販促ツール</a></li>\n                </ul>\n            </div>\n        </section><!-- .various -->\n\n\n        <section class=\"l-max1300 Section askingRecruit\">\n\n            <div class=\"halfSection asking \">\n                    <div class=\"secBG asking\"></div>\n                <div class=\"Section__head\">\n                    <h2 class=\"Section__header mincho\">ASKING</h2>\n                </div>\n                <div class=\"Section__body\">\n                    <div class=\"Item\">\n                    <div class=\"Item__sub\">\n                        <img src=\"/images/home/asking_img01.png\" alt=\"ASKING\">\n                    </div>\n                    <div class=\"Item__main\">\n                        <p class=\"itemText\">\n                        こんな事できるかな？と思ったら、何でもご相談ください。ご相談の内容に応じた資料やサンプルを持ってお伺いします。遠方のお客様でもメールと電話できちんと対応いたします。\n                        </p>\n                        <ul class=\"subNavi\">\n                        <li><a href=\"/contact/\" class=\"linkBtn\">ご相談はこちら</a></li>\n                        </ul>\n                    </div>\n                    </div><!-- .Item -->