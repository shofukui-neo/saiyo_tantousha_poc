/-/media/image/jp/r1/common2/icon_mail.png\" alt=\"お問い合わせ\"><span>お問い合わせ</span></a>\r\n\t\t\t\t<button type=\"button\" id=\"SupportNaviSearch\" aria-expanded=\"false\" aria-controls=\"SearchFormArea\"><span><img src=\"/-/media/image/jp/r1/common2/icon_search.png\" alt=\"検索\"><span>検索</span></span></button>\r\n\t\t\t\t<div id=\"SearchFormArea\">\r\n\t\t\t\t\t<div>\r\n\t\t\t\t\t\t<button class=\"BtnClose\" aria-label=\"閉じる\"></button>\r\n\t\t\t\t\t\t<form action=\"/search/index.html\" method=\"get\" accept-charset=\"UTF-8\">\r\n\t\t\t\t\t\t\t<div class=\"SearchGroup\">\r\n\t\t\t\t\t\t\t\t<input type=\"text\" name=\"q\" size=\"20\" maxlength=\"40\" accesskey=\"s\" title=\"検索キーワード\" placeholder=\"日立システムズから検索\" autocomplete=\"off\" class=\"SearchPhrease\">\r\n\t\t\t\t\t\t\t\t<button class=\"SearchBtn\" type=\"submit\">検索</button>\r\n\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t</form>\r\n\t\t\t\t\t\t<form action=\"https://module.hitachi.com/search/RGN_JAPAN.html\" method=\"get\" accept-charset=\"UTF-8\">\r\n\t\t\t\t\t\t\t<input type=\"hidden\" name=\"imgsize\" value=\"3\">\r\n\t\t\t\t\t\t\t<input type=\"hidden\" name=\"pagemax\" value=\"10\">\r\n\t\t\t\t\t\t\t<div class=\"SearchGroup\">\r\n\t\t\t\t\t\t\t\t<input type=\"text\" name=\"q\" size=\"20\" maxlength=\"40\" accesskey=\"s\" title=\"検索キーワード\" placeholder=\"日立グループ全体から検索\" autocomplete=\"off\" class=\"SearchPhrease\" id=\"MF_form_phrase\">\r\n\t\t\t\t\t\t\t\t<button class=\"SearchBtn\" type=\"submit\">検索</button>\r\n\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t</form>\r\n\t\t\t\t\t</div>\r\n\t\t\t\t</div><!--/#SearchFormArea-->\r\n\t\t\t</div><!--/#SupportNavi-->\r\n\t\t\t<button id=\"SpMenuBtn\" aria-label=\"メニュー\">\r\n\t\t\t\t<span></span>\r\n\t\t\t\t<span></span>\r\n\t\t\t\t<span></span>\r\n\t\t\t</button>\r\n\t\t</div><!--/.Container-->\r\n\t</div><!--/#HeaderArea1-->\r\n\r\n    \t<div id=\"HeaderArea2\" >\r\n\t\t<div class=\"Container Wide\">\r\n\t\t\t<div id=\"SiteID\">\r\n\t\t\t\t<a href=\"/index.html\">\r\n                    <span>日立システムズ</span>\r\n                </a>\r\n\t\t\t\t<a href=\"/recruit/return-entry/index.html\">\r\n                    <span>社員リターン・エントリー制度（退職者再雇用制度）</span>\r\n                </a>\r\n\t\t\t</div>\r\n\t\t\t<ul id=\"GlobalNaviMenu\">\r\n                                                                                                                \t\t\t</ul>\r\n\t\t</div><!--/.Container-->\r\n\t</div><!--/#HeaderArea2-->\r\n\r\n\r\n\r\n    <div id=\"Contents\">\r\n                \t\t<div class=\"GridSet\">\n\t\t\t<div class=\"Grid4\">\n\t\t\t\t<div class=\"PageTitleStyle3\">\n\t\t\t\t\t<h1>\n\t\t\t\t\t\t<img src=\"/-/media/recruit/return-entry/image/branding.png\" alt=\"社員リターン・エントリー制度（退職者再雇用制度）\">\n\t\t\t\t\t</h1>\n\t\t\t\t</div><!--PageTitleStyle3-->\n\t\t\t\t<div class=\"Section\" id=\"Sec01\">\n\t\t\t\t\t<div class=\"Inner\">\n\t\t\t\t\t\t<h2>日立システムズ <br class=\"Mobile\">社員リターン・エントリー制度<br class=\"Mobile\">（退職者再雇用制度）とは</h2>\n\t\t\t\t\t\t<p class=\"TextStyle1 Center\">過去、日立システムズに在籍していた方に再度日立システムズで活躍していただける場を提供する制度です。<br class=\"PC\">イノベーション創出に向けて、再度日立システムズで働く意欲のある方の応募をお待ちしております。</p>\n\n\t\t\t\t\t</div><!--Inner-->\n\t\t\t\t</div><!--Section-->\n\t\t\t\t<div class=\"Section LGY\" id=\"Sec02\">\n\t\t\t\t\t<div class=\"Inner\">\n\t\t\t\t\t\t<h2>募集要項</h2>\n\t\t\t\t\t\t<table class=\"TableStyle3\">\n\t\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t\t<th>応募資格</th>\n\t\t\t\t\t\t\t\t<td>\n\t\t\t\t\t\t\t\t\t<ul class=\"ListStye1 TextStyle1\">\n\t\t\t\t\t\t\t\t\t\t<li>（1）当社の正社員であった方</li>\n\t\t\t\t\t\t\t\t\t\t<li>（2）育児、介護、配偶者の転勤、留学・社会貢献活動、転職を理由に退職した方</li>\n\t\t\t\t\t\t\t\t\t</ul>\n\n\t\t\t\t\t\t\t\t</td>\n\t\t\t\t\t\t\t</tr>\n\t\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t\t<th>応募方法</th>\n\t\t\t\t\t\t\t\t<td>\n\t\t\t\t\t\t\t\t\t<p class=\"TextStyle1\">本画面の「制度登録はこちら」より登録フォームへ進み、必要事項を記入の上、制度登録願います。<br>制度登録後、退職者専用ツール上（MyRefer）から希望する求人にエントリー願います。</p>\n\t\t\t\t\t\t\t\t\t<p class=\"TextStyle2\">※制度への登録・求人への応募は株式会社TalentXのサービス「MyRefer」を利用します。</p>\n\t\t\t\t\t\t\t\t</td>\n\t\t\t\t\t\t\t</tr>\n\t\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t\t<th>選考方法</th>\n\t\t\t\t\t\t\t\t<td>\n\t\t\t\t\t\t\t\t\t<p class=\"TextStyle1\">書類選考・面接等による選考を行います。<br>\n\t\t\t\t\t\t\t\t\t\t応募いただいた方に、詳細をご連絡いたします。</p>\n\t\t\t\t\t\t\t\t</td>\n\t\t\t\t\t\t\t</tr>\n\t\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t\t<th>雇用時の処遇等</th>\n\t\t\t\t\t\t\t\t<td>\n\t\t\t\t\t\t\t\t\t<p class=\"TextStyle1\">再雇用を行う場合の処遇等については、経験・能力を考慮の上、決定します。</p>\n\t\t\t\t\t\t\t\t</td>\n\t\t\t\t\t\t\t</tr>\n\t\t\t\t\t\t</table>\n\t\t\t\t\t</div><!--Inner-->\n\t\t\t\t</div><!--Section-->\n\t\t\t\t<div class=\"Section BLK\" id=\"Sec03\">\n\t\t\t\t\t<div class=\"Inner\">\n\t\t\t\t\t\t<h2>制度登録</h2>\n\t\t\t\t\t\t<ul class=\"Flexbox Two\">\n\t\t\t\t\t\t\t<li class=\"BaseBox\">\n\t\t\t\t\t\t\t\t<h3>社員リターン・エントリー制度<br class=\"\">（退職者再雇用制度）への登録</h3>\n\n\t\t\t\t\t\t\t\t<a class=\"Button\" href=\"https://i-myrefer.jp/recruiter/apply/?token=8fdb826f7c83c3ed32437a338a6a5e4f192ca637\" target=\"_blank\" rel=\"noopener noreferrer\" title=\"アルムナイネットワークはこちら：外部サイトが表示されます\">制度登録はこちら</a>\n\t\t\t\t\t\t\t\t<div class=\"Flexbox\">\n\t\t\t\t\t\t\t\t\t<p class=\"TextStyle2\">※制度登録後、退職者専用ツール（MyRefer）から求人に応募いただけます。また、日立システムズの最新情報を定期的に配信いたします。</p>\n\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t</li>\n\n\t\t\t\t\t\t</ul>\n\t\t\t\t\t</div><!--Inner-->\n\t\t\t\t</div><!--Section-->\n\t\t\t\t<div class=\"Section LGY\" id=\"Sec04\">\n\t\t\t\t\t<div class=\"Inner\">\n\t\t\t\t\t\t<h2>制度に関するお問い合わせ・ご質問</h2>\n\t\t\t\t\t\t<p class=\"TextStyle2 Center\">* 運用の一部について株式会社TalentXに委託しております。</p>\n\t\t\t\t\t\t<p class=\"TextStyle1 Center\">株式会社日立システムズ <br class=\"Mobile\">社員リターン・エントリー制度事務局<br>E-mail：hisys-alumni@myrefer.co.jp</p>\n\t\t\t\t\t</div><!--Inner-->\n\t\t\t\t</div><!--Section-->\n\t\t\t</div><!--Grid4-->\n\t\t</div><!--GridSet-->\r\n    </div><!--/Contents-->\r\n\r\n    \r\n\r\n<script type=\"text/javascript\" src=\"/-/media/js/fat_menu.js\"></script><div id=\"FooterArea\">\r\n    <div class=\"Container Wide\">\r\n        <div id=\"Footer2\">\r\n            <div id=\"SnsButton\">\r\n\t<a target=\"_blank\" rel=\"noopener\" href=\"https://www.facebook.com/hitachisystems.jp/\"><img src=\"/-/media/image/jp/r1/common2/icon_sns_facebook.png\" alt=\"Facebook公式ページ\"></a>\r\n\t<a target=\"_blank\" rel=\"noopener\" href=\"https://www.youtube.com/user/HitachiSystemsCh\"><img src=\"/-/media/image/jp/r1/common2/icon_sns_youtube.png\" alt=\"YouTube公式チャンネル\"></a>\r\n</div>\r\n            <div id=\"Footer2Menu\">\r\n                <a href=\"/sitemap/index.html\">サイトマップ</a>\r\n                <a href=\"/contactus/index.html\">お問い合わせ</a>\r\n                <a href=\"/security/index.html\">情報セキュリティポリシー</a>\r\n            </div>\r\n        </div><!--/#Footer2-->\r\n        <div id=\"Footer1\">\r\n            <div id=\"HitachiTop\">\r\n                <a href=\"https://www.hitachi.co.jp/\">日立グループTOP</a>\r\n            </div>\r\n            <div id=\"Footer1Menu\">\r\n                <a href=\"/termofuse/index.html\">サイトの利用条件</a>\r\n                <a href=\"/webaccessibility/index.html\">アクセシビリティへの対応方針</a>\r\n                <a href=\"/privacy/index.html\">個人情報保護に関して</a>\r\n            </div>\r\n            <script type=\"text/javascript\" src=\"/-/media/js/copyright.js\"></script>\r\n        </div><!--/#Footer1-->\r\n    </div><!--/.Container-->\r\n</div><!--/#FooterArea-->\r\n\r\n    <div id=\"Controler\">\r\n<button type=\"button\" class=\"pagetop\">pagetop</button>\r\n</div>\r\n</body>\r\n</html>","finalUrl":"https://www.hitachi-systems.com/recruit/return-entry/","rendered":false,"_cachedAt":"2026-06-23T17:02:32.171Z"}