'https://fic.co.jp/cms/wp-content/plugins/contact-form-7-add-confirm/includes/css/styles.css?ver=5.1-20210630' media='all' />\n<script id=\"jquery-core-js\" src=\"https://fic.co.jp/cms/wp-includes/js/jquery/jquery.min.js?ver=3.7.1\"></script>\n<script id=\"jquery-migrate-js\" src=\"https://fic.co.jp/cms/wp-includes/js/jquery/jquery-migrate.min.js?ver=3.4.1\"></script>\n</head>\n\n \n<body id=\"p-rec\" class=\"page-interview-staff\">\r\n<header id=\"top\">\r\n<p id=\"sp-name\"><a href=\"https://fic.co.jp/\"><img decoding=\"async\" src=\"https://fic.co.jp/cms/wp-content/themes/fic/images/img-common/logo_color.svg\" alt=\"株式会社福島情報処理センター\"></a></p>\n<div class=\"menu-container\">\n  <nav class=\"menu sp\">\n    <ul class=\"cl-effect-3\">\n      <li id=\"name-box\">\n        <h1><img decoding=\"async\" src=\"https://fic.co.jp/cms/wp-content/themes/fic/images/img-common/logo_color.svg\" alt=\"株式会社福島情報処理センター\"></h1>\n        <p><a href=\"https://fic.co.jp/\"><img decoding=\"async\" src=\"https://fic.co.jp/cms/wp-content/themes/fic/images/img-common/logo_color.svg\" alt=\"株式会社福島情報処理センター\"></a></p>\n      </li>\n      <li id=\"nav-rechome\"><a href=\"https://fic.co.jp/recruitment/\">Home</a></li>\n      <li id=\"nav-about\"><a href=\"https://fic.co.jp/recruitment/about/\">About</a></li>\n      <li id=\"nav-workstyle\"><a href=\"https://fic.co.jp/recruitment/workstyle/\">Work style</a></li>\n      <li id=\"nav-interview\"><a href=\"https://fic.co.jp/recruitment/interview/\">Interview</a></li>\n      <li id=\"nav-yoko\"><a href=\"https://fic.co.jp/recruitment/newface/\">募集要項</a></li>\n      <li id=\"nav-contact\"><a href=\"https://fic.co.jp/contact/\">お問い合わせ</a></li>\n    </ul>\n  </nav>\n</div>\r\n<div id=\"head-vis\" data-aos=\"slide-down\" data-aos-offset=\"300\">\r\n  <h2>インタービュー</h2>\r\n  <p>Interview</p>\r\n</div>\r\n</header>\r\n\r\n<main>\r\n\r\n<section id=\"staff03\" class=\"staff-wrap\">\r\n<header>\r\n<div class=\"ph-face\"><img decoding=\"async\" src=\"https://fic.co.jp/cms/wp-content/themes/fic/images/recruitment/ph-inter03-1.jpg\" alt=\"公共営業部　稲場友未香\"></div>\r\n<div class=\"name-box\">\r\n<p>2015年入社 公共営業部</p>\r\n<h3><span>営 業</span>稲場 友未香</h3>\r\n</div>\r\n<p class=\"copy01\">女性の管理職になって</p>\r\n<p class=\"copy02\">会社の発展に貢献したい。</p>\r\n</header>\r\n\r\n<dl class=\"inter-body\">\r\n<dt>現在の仕事内容を教えてください</dt>\r\n<dd>\r\n<p>自治体の営業として「お客様に価値ある提案を」を目標に、日々動向を確認しながら、その時々に合ったご提案ができるように努めています。</p>\r\n</dd>\r\n\r\n<dt>FICへの入社の決め手はなんですか?</dt>\r\n<dd>\r\n<p>大学時代に学んだことを発揮でき、地域社会に貢献できる会社であったこと。</p>\r\n</dd>\r\n\r\n<dt>1日のスケジュールを教えてください</dt>\r\n<dd class=\"time-line\">\r\n<dl>\r\n<dt>8:00</dt>\r\n<dd>出社</dd>\r\n<dt>8:30</dt>\r\n<dd>朝礼</dd>\r\n<dt>9:00</dt>\r\n<dd>見積書作成</dd>\r\n\r\n<dt>13:00</dt>\r\n<dd>お客様先訪問<br>\r\nご要望等がないか直接お伺いします。</dd>\r\n\r\n<dt>16:00</dt>\r\n<dd>報告書作成<br>頂いたご意見についてまとめ、社内で調整します。\r\n</dd>\r\n\r\n<dt>18:00</dt>\r\n<dd>退社</dd>\r\n<dt>19:00</dt>\r\n<dd>夕食</dd>\r\n<dt>0:30</dt>\r\n<dd>就寝</dd>\r\n</dl>\r\n<aside><img decoding=\"async\" src=\"https://fic.co.jp/cms/wp-content/themes/fic/images/recruitment/ph-inter03-2.jpg\" alt=\"\"></aside>\r\n</dd>\r\n\r\n<dt>会社のどんなところが好きですか?</dt>\r\n<dd>\r\n<p>ひとの温かみが感じられるところです。みなさん親切にしてくださいます。<br>\r\n休暇も取りやすいので、プライベートとの両立が可能です。(誕生日休暇も取得できます)</p>\r\n</dd>\r\n\r\n<dt>入社してからのキャリアパスを教えてください</dt>\r\n<dd>\r\n<p class=\"title\">入社1年目〜4年目</p>\r\n<p>インストラクターとして社外に出向しました。<br>\r\nパッケージシステムのデモ員として、全国各地へ訪問していました。</p>\r\n<p class=\"title\">4年目〜現在</p>\r\n<p>公共部門の営業として活動しています。</p>\r\n</dd>\r\n\r\n<dt>これからチャレンジしたいこと・夢・ビジョンを教えてください</dt>\r\n<dd>\r\n<p>現在女性の管理職が少ないので、将来管理職になってさらに会社の発展に貢献したいと考えています。</p>\r\n\r\n</dd>\r\n\r\n<dt>仕事のやりがい・探求心を教えてください</dt>\r\n<dd>\r\n\r\n<p>お客様のニーズに沿った提案が必要であり、様々な最先端の製品情報に触れられるため日々自分の知識・ノウハウ等を蓄えることができます。<br>\r\nお客様の課題解決や要望に応えることができ、お礼の言葉を頂いた時にやりがいを感じます。</p>\r\n</dd>\r\n\r\n<dt>上司や所属チーム、仲間の印象は?</dt>\r\n<dd>\r\n\r\n<p>営業部にはベテランが多いので、知識の幅が広く、お客様とのやり取りもスムーズで目標にさせていただくところが多いです。</p>\r\n</dd>\r\n<aside><img decoding=\"async\" src=\"https://fic.co.jp/cms/wp-content/themes/fic/images/recruitment/ph-inter03-3.jpg\" alt=\"\"></aside>\r\n<dt>社会人になって一番変わったことはなんですか</dt>\r\n<dd>\r\n<p>入社以前より様々な年齢層の方とお話しする機会が増え、今まで知り得なかったこと(趣味のお話や人生経験談など)を聞けること。</p>\r\n\r\n</dd>\r\n\r\n<dt>あなたの仕事でのターニングポイントはどこですか<br>\r\n(失敗から成功へのきっかけ、印象的な一言など)</dt>\r\n<dd>\r\n<p>出向先から本社に戻ってきて、今までとは全く異なる業務内容になりました。<br>\r\n営業経験もない中、戸惑うことも多くありましたが、活躍している女性が多く、仕事に対する姿勢や取り組み方を見ることで、自分もこうなりたいと思うようになりました。</p>\r\n</dd>\r\n\r\n<dt>休みの日の過ごし方は</dt>\r\n<dd>\r\n<p>\r\n基本的にインドアなので、映画を観たりゲームをしたりして1日過ごすことが多いです。</p>\r\n</dd>\r\n\r\n<dt class=\"last-item\">学生へメッセージをお願いします</dt>\r\n<dd class=\"last-item\">\r\n<p>最初は誰でも経験のないことばかりです。<br>\r\nためらわずに周りの先輩方に聞くようにすると、コミュニケーションもとれるので積極的に話しかけられるといいかなと思います。<br>\r\nFICの社員はみなさん気さくでいい先輩方ばかりなので安心してください。</p>\r\n</dd>\r\n</dl>\r\n</section>\r\n\r\n<div id=\"inter-bk\"></div>\n<dl id=\"inter-wrap\">\n  <dt>[スタッフインタビュー]<p>学歴や学部はいろいろ。多彩な個性が光ってる。</p><div class=\"zabuton\"><a href=\"https://fic.co.jp/recruitment/interview/?id=zadankai\" data-aos=\"fade-down\" data-aos-offset=\"300\"><img decoding=\"async\" src=\"https://fic.co.jp/cms/wp-content/themes/fic/images/recruitment/btn-interview.svg\" alt=\"グループインタビューこちら\"></a></div></dt>\n  <dd>\n  <a href=\"https://fic.co.jp/recruitment/interview-staff01/\"><div class=\"inter01\"><img decoding=\"async\" src=\"https://fic.co.jp/cms/wp-content/themes/fic/images/recruitment/ph-inter01-murakami.jpg\" alt=\"村上　俊政\"><div><span>開発・保守</span>村上　俊政</div></div></a>\n  <a href=\"https://fic.co.jp/recruitment/interview-staff02/\"><div class=\"inter02\"><img decoding=\"async\" src=\"https://fic.co.jp/cms/wp-content/themes/fic/images/recruitment/ph-inter02-aitai.jpg\" alt=\"會田　純平\"><div><span>運用・保守</span>會田　純平</div></div></a> \n  <a href=\"https://fic.co.jp/recruitment/interview-staff03/\"><div class=\"inter03\"><img decoding=\"async\" src=\"https://fic.co.jp/cms/wp-content/themes/fic/images/recruitment/ph-inter03-inaba.jpg\" alt=\"稲葉　友美香\"><div><span>営　業</span>稲葉　友美香</div></div></a>\n  <a href=\"https://fic.co.jp/recruitment/interview-staff04/\"><div class=\"inter04\"><img decoding=\"async\" src=\"https://fic.co.jp/cms/wp-content/themes/fic/images/recruitment/ph-inter04-endo.jpg\" alt=\"遠藤　卓哉\"><div><span>設計構築</span>遠藤　卓哉</div></div></a>\n  <a href=\"https://fic.co.jp/recruitment/interview-staff05/\"><div class=\"inter05\"><img decoding=\"async\" src=\"https://fic.co.jp/cms/wp-content/themes/fic/images/recruitment/ph-inter05-wakabayashi.jpg\" alt=\"若林　柊太\"><div><span>電算運用</span>若林　柊太</div></div></a>\n  </dd>\n</dl>\r\n<dl id=\"group-wrap\">\n  <dt>GROUP INTERVIEW</dt>\n  <dd>\n  <a href=\"https://fic.co.jp/recruitment/zadankai-flesh/\"><div class=\"gr01\"><img decoding=\"async\" src=\"https://fic.co.jp/cms/wp-content/themes/fic/images/recruitment/ph-zadankai01.jpg\" alt=\"座談会：新入社員\"><p>興味・関心・向上心を持ち続けること。</p><p>座談会：新入社員</p></div></a>\n  <a href=\"https://fic.co.jp/recruitment/zadankai-sankyu/\"><div class=\"gr02\"><img decoding=\"async\" src=\"https://fic.co.jp/cms/wp-content/themes/fic/images/recruitment/ph-zadankai02.jpg\" alt=\"座談会：産休・育休\"><p>FICの環境は子育てに優しい会社。</p><p>座談会：産休・育休</p></div></a>\n  <a href=\"https://fic.co.jp/recruitment/zadankai-josei/\"><div class=\"gr03\"><img decoding=\"async\" src=\"https://fic.co.jp/cms/wp-content/themes/fic/images/recruitment/ph-zadankai03.jpg\" alt=\"座談会：新入社員\"><p>皆が存分に頑張れる会社。</p><p>座談会：女性社員</p></div></a>\n  </dd>\n</dl>\r\n<hr>\r\n<div id=\"cont-bana\" class=\"sprits\">\n  <dl>\n    <dt>[会社理念・概要など]</dt>\n    <dd>\n    <p>About</p>\n    <a href=\"https://fic.co.jp/recruitment/about/\"><div><img decoding=\"async\" src=\"https://fic.co.jp/cms/wp-content/themes/fic/images/recruitment/ph-about-thum.jpg\" alt=\"会社理念・概要など\"></div></a>\n    </dd>\n  </dl>\n  <dl>\n    <dt>[仕事環境]</dt>\n    <dd>\n    <p>Work style</p>\n    <a href=\"https://fic.co.jp/recruitment/workstyle/\"><div><img decoding=\"async\" src=\"https://fic.co.jp/cms/wp-content/themes/fic/images/recruitment/ph-work-thum.jpg\" alt=\"仕事環境\"></div></a>\n    </dd>\n  </dl>\n</div>\r\n\r\n<div id=\"QAWebChat\"></div> \r\n</main>