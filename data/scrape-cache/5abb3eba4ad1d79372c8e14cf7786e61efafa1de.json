{"url":"https://www.super-marui.com/recruit/characteristic.html","html":"<!DOCTYPE html>\n<html lang=\"ja-JP\">\n <head> \n  <meta charset=\"UTF-8\"> \n  <meta http-equiv=\"content-type\" content=\"text/html; charset=UTF-8\"> \n  <meta name=\"robots\" content=\"index\"> \n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"> \n  <meta name=\"description\" content=\"スーパーマルイは、地域密着スーパーとして株式会社マルイならではの特徴ある会社作りを目指します。\"> \n  <meta property=\"og:title\" content=\"スーパーマルイの特徴|リクルート採用情報サイト\"> \n  <meta property=\"og:type\" content=\"website\"> \n  <meta property=\"og:image\" content=\"https://www.super-marui.com/recruit/bdflashinfo/thumbnail-large.png\"> \n  <meta property=\"og:url\" content=\"https://www.super-marui.com/recruit/characteristic.html\"> \n  <meta property=\"og:site_name\" content=\"リクルート採用情報サイト | 株式会社マルイ\"> \n  <meta property=\"og:description\" content=\"スーパーマルイは、地域密着スーパーとして株式会社マルイならではの特徴ある会社作りを目指します。\"> \n  <meta name=\"twitter:card\" content=\"summary_large_image\"> \n  <meta name=\"twitter:image\" content=\"https://www.super-marui.com/recruit/bdflashinfo/thumbnail-large.png\"> \n  <meta name=\"note:card\" content=\"summary_large_image\"> \n  <link rel=\"canonical\" href=\"https://www.super-marui.com/recruit/characteristic.html\"> \n  <title>スーパーマルイの特徴|リクルート採用情報サイト</title> \n  <link rel=\"stylesheet\" type=\"text/css\" href=\"_module/styles/bind.css?v=17.0.6\" id=\"bind-css\"> \n  <link rel=\"stylesheet\" type=\"text/css\" href=\"_dress/b014006/base.css?1777131008361\"> \n  <link rel=\"stylesheet\" type=\"text/css\" href=\"_dress/b14006Navi/base.css?1777131008361\"> \n  <link rel=\"stylesheet\" type=\"text/css\" href=\"_dress/b14006Main1/base.css?1777131008361\"> \n  <link rel=\"stylesheet\" type=\"text/css\" href=\"_dress/00bca8d34607437494a664ba54041520/base.css?1777131008361\"> \n  <link rel=\"stylesheet\" type=\"text/css\" href=\"https://fonts.googleapis.com/css?family=Noto+Sans+JP:100,200,300,regular,500,600,700,800,900&amp;display=s