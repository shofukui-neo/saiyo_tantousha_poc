 class=\"b-both_diff -right_large -sp-single_column c-space_narrow c-sp-space_normal c-sp-padding_normal is-sp-hide bd-webp -dress_b14006Navi cssskin-_block_header init-block_animation init-sp-block_animation\" data-bk-id=\"bk2939\" data-shared=\"true\" data-sharedname=\"_グローバルナビ2\" data-animated=\"fadeIn\" data-sp-animated=\"fadeIn\"> \n         <div class=\" g-column\"> \n          <div class=\" column -col4 -col_sub\"> \n           <h1 class=\" c-page_title\"> \n            <div class=\"c-img   \"> \n             <picture> \n              <source type=\"image/webp\" srcset=\"_src/2239/img20150831145800040553.webp?v=1769645477911\"> \n              <img src=\"_src/2239/img20150831145800040553.png?v=1769645477911\" width=\"380\" height=\"100\" alt=\"株式会社マルイ_2025年新卒採用情報\" id=\"imgsrc2239_1\" class=\" c-no_adjust\" loading=\"lazy\"> \n             </picture> \n            </div></h1> \n          </div> \n          <div class=\" column -col8 -col_main\"> \n           <nav> \n            <div class=\" js-motion\"> \n             <ul class=\"m-motion menu-parts -f\"> \n              <li><a href=\"./\" data-pid=\"175\">ホーム</a></li> \n              <li><a href=\"message.html\" data-pid=\"176\">メッセージ</a></li> \n              <li><span class=\" c-unlink\">チームで取り組む</span> \n               <ul> \n                <li><a href=\"fisheries/session1.html\" data-pid=\"180\">マルイが挑むプロジェクト</a></li> \n                <li><a href=\"deli/session2.html\" data-pid=\"183\">新人社員の教育現場</a></li> \n                <li><a href=\"colleague/session3.html\" data-pid=\"189\">新人社員の研修</a></li> \n               </ul></li> \n              <li class=\" c-current\"><a href=\"characteristic.html\" data-mypid=\"177\">スーパーマルイの特徴</a></li> \n              <li><a href=\"career_plan.html\" data-pid=\"178\">キャリアプラン</a></li> \n              <li><a href=\"entry.html\" data-pid=\"179\" class=\"entry\">エントリー</a></li> \n             </ul> \n            </div> \n           </nav> \n          </div> \n         </div> \n        </div> \n       </section> \n      </div> \n     </header> \n    </div> \n    <div id=\"a-billboard\" class=\"a-billboard    cssskin-_area_billboard\"> \n     <div class=\"site_frame\"> \n      <section> \n       <div id=\"bk3049\" class=\"b-plain cssskin-_block_billboard\" data-bk-id=\"bk3049\"> \n        <div class=\" column -column1\"> \n        </div> \n       </div> \n      </section> \n     </div> \n    </div> \n    <main> \n     <div id=\"a-site_contents\" class=\"a-site_contents  noskin\"> \n      <article> \n       <div class=\"site_frame\"> \n        <div class=\"g-column\"> \n         <div id=\"a-main\" class=\"a-main column -col12 \"> \n          <section> \n           <div id=\"bk2940\" class=\"b-plain c-space_normal c-sp-space_normal c-padding_wide is-sp-hide bd-webp -dress_b14006Main1 cssskin-_block_main init-block_animation init-sp-block_animation\" data-bk-id=\"bk2940\" data-animated=\"fadeIn\" data-sp-animated=\"fadeIn\"> \n            <div class=\" column -column1\"> \n             <p class=\"c-lead\">スーパーマルイの特徴</p> \n             <h2 class=\"none c-title c-center\">本当の“地域密着”スーパーを目指して</h2> \n            </div> \n           </div> \n           <div id=\"bk2979\" class=\"b-plain c-space_normal c-sp-space_normal is-pc-hide bd-webp -dress_b14006Main1 cssskin-_block_main init-block_animation init-sp-block_animation\" data-bk-id=\"bk2979\" data-animated=\"fadeIn\" data-sp-animated=\"fadeIn\"> \n            <div class=\" column -column1\"> \n             <p class=\"c-lead\">スーパーマルイの特徴</p> \n             <h2 class=\"none c-title c-center\">本当の“地域密着”<br>スーパーを目指して</h2> \n            </div> \n           </div> \n           <div id=\"bk2941\" class=\"b-plain c-space_normal c-sp-space_normal c-padding_wide c-sp-padding_normal is-sp-hide bd-webp -dress_00bca8d34607437494a664ba54041520 cssskin-_block_main init-block_animation init-sp-block_animation\" data-bk-id=\"bk2941\" data-animated=\"fadeInUp\" data-sp-animated=\"fadeInUp\"> \n            <div class=\" g-column -col2 -sp-col1\"> \n             <div class=\" column -column1\"> \n              <p class=\"c-lead\">ローカルだからアピールできる</p> \n              <h2 class=\"lead c-title c-center\">そして、ローカルから<br>“グローバル”を考える</h2> \n              <p class=\" c-body\">新潟は、「コシヒカリ」に代表されるように“食”の宝庫。<br>私たちマルイは、地元の農家の方との提携や地魚を使った刺身の盛り合わせや、唐揚げといった惣菜商品など、<span class=\" d-bold\">新鮮かつ美味しい地元食材</span>をお客様にお届けしてきました。<br>一方でバイヤーは、“<span class=\" d-bold\">新しい付加価値の高い商品</span>”を追い求めて、様々なチャンネルから情報を収集しています。ローカルだからできる地域の食文化への貢献、そして<span class=\" d-bold\">ローカルをより豊かに</span>するために、広い「<span class=\" d-bold\">グローバル</span>」な視点から果たせる貢献。<br>様々な方面から、食品スーパーが果たせる『<span class=\" d-bold\">地域貢献</span>』を一緒に考えてみませんか。</p> \n             </div> \n             <div class=\" column -column2 -column-lasts\"> \n              <div class=\" c-body c-center\"> \n               <div class=\"c-img   \"> \n                <picture> \n                 <source type=\"image/webp\" srcset=\"_src/2250/img20220107151342852061.webp?v=1769645477911\"> \n                 <img src=\"_src/2250/img20220107151342852061.png?v=1769645477911\" width=\"720\" height=\"720\" alt=\"ローカルからグローバルを考える\" id=\"imgsrc2250_1\" class=\" c-no_adjust\" loading=\"lazy\"> \n                </picture> \n               </div> \n              </div> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk2975\" class=\"b-plain c-space_normal c-sp-space_normal c-padding_wide is-pc-hide bd-webp -dress_00bca8d34607437494a664ba54041520 cssskin-_block_main init-block_animation init-sp-block_animation\" data-bk-id=\"bk2975\" data-animated=\"fadeInUp\" data-sp-animated=\"fadeInUp\"> \n            <div class=\" g-column -col2 -sp-col1\"> \n             <div class=\" column -column1\"> \n              <p class=\"c-lead\">ローカルだからアピールできる</p> \n              <h2 class=\" c-title c-center\">そして、ローカルから<br>“グローバル”を考える</h2> \n             </div> \n             <div class=\" column -column2 -column-lasts\"> \n              <div class=\" c-body c-center\"> \n               <div class=\"c-img   \"> \n                <picture> \n                 <source type=\"image/webp\" srcset=\"_src/2256/img20220107151342852061.webp?v=1769645477911\"> \n                 <img src=\"_src/2256/img20220107151342852061.png?v=1769645477911\" width=\"720\" height=\"720\" alt=\"ローカルからグローバルを考える\" id=\"imgsrc2256_1\" class=\" c-no_adjust\" loading=\"lazy\"> \n                </picture> \n               </div> \n              </div> \n             </div> \n             <div class=\" column -column1\"> \n              <p class=\" c-body\">新潟は、「コシヒカリ」に代表されるように“食”の宝庫。<br>私たちマルイは、地元の農家の方との提携や地魚を使った刺身の盛り合わせや、唐揚げといった惣菜商品など、<span class=\" d-bold\">新鮮かつ美味しい地元食材</span>をお客様にお届けしてきました。<br>一方でバイヤーは、“<span class=\" d-bold\">新しい付加価値の高い商品</span>”を追い求めて、様々なチャンネルから情報を収集しています。ローカルだからできる地域の食文化への貢献、そして<span class=\" d-bold\">ローカルをより豊かに</span>するために、広い「<span class=\" d-bold\">グローバル</span>」な視点から果たせる貢献。<br>様々な方面から、食品スーパーが果たせる『<span class=\" d-bold\">地域貢献</span>』を一緒に考えてみませんか。</p> \n              <div class=\"c-none\">\n                &nbsp; \n              </div> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk2921\" class=\"b-plain c-space_normal c-sp-space_normal c-padding_wide c-sp-padding_normal is-sp-hide bd-webp -dress_b14006Main1 cssskin-_block_main init-block_animation init-sp-block_animation\" data-bk-id=\"bk2921\" data-animated=\"fadeInUp\" data-sp-animated=\"fadeInUp\"> \n            <div class=\" g-column -col2 -sp-col1\"> \n             <div class=\" column -column1\"> \n              <h4 class=\"none c-small_headline c-center\"> \n               <div class=\"c-img   \"> \n                <picture> \n                 <source type=\"image/webp\" srcset=\"_src/2203/image3_2.webp?v=1769645477911\"> \n                 <img src=\"_src/2203/image3_2.png?v=1769645477911\" width=\"720\" height=\"720\" alt=\"お客様に食を楽しんでいただくために\" id=\"imgsrc2203_1\" class=\" c-no_adjust\" loading=\"lazy\"> \n                </picture> \n               </div></h4> \n             </div> \n             <div class=\" column -column2 -column-lasts\"> \n              <div class=\"c-lead c-left\">\n                プレゼンするスーパー \n               <br> \n               <span></span> \n              </div> \n              <h2 class=\" c-title c-left\"><span>お客様に“食”を楽しんでいただくために</span></h2> \n              <div class=\"c-none\">\n                &nbsp; \n              </div> \n              <p class=\" c-body\">私たちマルイはこの不変の目標に向かって、まず自らが商品に触れ、用い、味わい、そこで感じた“想い”を持つことが何より大切だと考えています。そして、その想いを手書きのコトPOPや店内放送、毎週日曜日開催の大試食会（現在は中止）など、様々な手段を通じ、お客様に伝えていきたい。それが、当社の目指す<span>&nbsp;</span><span>「<span class=\" d-bold\">プレゼンするスーパー</span>」</span>です。<br>お客様に“<span class=\" d-bold\">食</span>”を楽しんでいただくためには、まず働く私たちが<span class=\" d-bold\">“仕事”を楽しむ</span>ことがスタート。「<span>&nbsp;</span><span>食べて、感じて、考えた」</span>１人１人の率直な“想い”を、売り場を通じてお客様に<span>&nbsp;</span><span>『<span class=\" d-bold\">プレゼン</span>』</span>することで、食卓に小さな発見や面白さ、そして笑顔が生まれるように。</p> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk2976\" class=\"b-plain c-space_normal c-sp-space_normal c-padding_wide is-pc-hide bd-webp -dress_b14006Main1 cssskin-_block_main init-block_animation init-sp-block_animation\" data-bk-id=\"bk2976\" data-animated=\"fadeInUp\" data-sp-animated=\"fadeInUp\"> \n            <div class=\" g-column -col2 -sp-col1\"> \n             <div class=\" column -column1\"> \n              <div class=\"c-lead c-left\">\n                プレゼンするスーパー \n               <br> \n               <span></span> \n              </div> \n              <h2 class=\" c-title c-left\"><span>お客様に“食”を楽しんでいただくために</span></h2> \n             </div> \n             <div class=\" column -column2 -column-lasts\"> \n              <h4 class=\" c-small_headline c-center\"> \n               <div class=\"c-img   \"> \n                <picture> \n                 <source type=\"image/webp\" srcset=\"_src/2258/image3_2.webp?v=1769645477911\"> \n                 <img src=\"_src/2258/image3_2.png?v=1769645477911\" width=\"720\" height=\"720\" alt=\"お客様に食を楽しんでいただくために\" id=\"imgsrc2258_1\" class=\" c-no_adjust\" loading=\"lazy\"> \n                </picture> \n               </div></h4> \n             </div> \n             <div class=\" column -column1\"> \n              <p class=\" c-body\">私たちマルイはこの不変の目標に向かって、まず自らが商品に触れ、用い、味わい、そこで感じた“想い”を持つことが何より大切だと考えています。そして、その想いを手書きのコトPOPや店内放送、毎週日曜日開催の大試食会（現在は中止）など、様々な手段を通じ、お客様に伝えていきたい。それが、当社の目指す<span>&nbsp;</span><span>「<span class=\" d-bold\">プレゼンするスーパー</span>」</span>です。<br>お客様に“<span class=\" d-bold\">食</span>”を楽しんでいただくためには、まず働く私たちが<span class=\" d-bold\">“仕事”を楽しむ</span>ことがスタート。「<span>&nbsp;</span><span>食べて、感じて、考えた」</span>１人１人の率直な“想い”を、売り場を通じてお客様に<span>&nbsp;</span><span>『<span class=\" d-bold\">プレゼン</span>』</span>することで、食卓に小さな発見や面白さ、そして笑顔が生まれるように。</p> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk2971\" class=\"b-plain c-space_normal c-sp-space_normal c-sp-padding_normal is-sp-hide bd-webp -dress_00bca8d34607437494a664ba54041520 cssskin-_block_main init-block_animation init-sp-block_animation\" data-bk-id=\"bk2971\" data-animated=\"fadeInUp\" data-sp-animated=\"fadeInUp\"> \n            <div class=\" g-column -col2 -sp-col1\"> \n             <div class=\" column -column1\"> \n              <p class=\"c-lead\">“チーム”で取り組む強み</p> \n              <h2 class=\"lead c-title c-left\">コトＰＯＰやサンプルでＰＲ！</h2> \n              <p class=\" c-body\">イラストが得意な人もそうでない人も、食べた感想からでいいので、まず書いてみましょう！！<br>コトＰＯＰは、新入社員がまず始めに取り組む『<span class=\" d-bold\">プレゼン</span>』です。<br>最初は何を書いたら良いか戸惑うかもしれませんが、大丈夫！<br>食べた感想から、飾り気のない言葉のほうが、お客様には響きます。自分が書いたコトＰＯＰに足を止めているお客様の姿は、何ものにも替えがたい“自信”になります。<br>パートさん、アルバイトさんを含め、売り場担当者のアイデアを柔軟に売り場に反映し、個店それぞれの特色を前面に出していく。<span class=\" d-bold\">売り場づくりを“チーム”で取り組むわが社の強みです。</span><br>バイヤーや店長だけでなく、<span class=\" d-bold\">現場担当者にも売り場の企画立案ができます</span>。<br>皆さんも、自分のアイデアを売り場にぶつけてみませんか。</p> \n             </div> \n             <div class=\" column -column2 -column-lasts\"> \n              <div class=\" c-body c-center\"> \n               <div class=\"c-img   \"> \n                <picture> \n                 <source type=\"image/webp\" srcset=\"_src/2252/img20220107153441519443.webp?v=1769645477911\"> \n                 <img src=\"_src/2252/img20220107153441519443.jpg?v=1769645477911\" width=\"480\" height=\"480\" alt=\"ことPOPやサンプルでPR！\" id=\"imgsrc2252_1\" class=\" c-no_adjust\" loading=\"lazy\"> \n                </picture> \n               </div> \n              </div> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk2977\" class=\"b-plain c-space_normal c-sp-space_normal is-pc-hide bd-webp -dress_00bca8d34607437494a664ba54041520 cssskin-_block_main init-block_animation init-sp-block_animation\" data-bk-id=\"bk2977\" data-animated=\"fadeInUp\" data-sp-animated=\"fadeInUp\"> \n            <div class=\" g-column -col2 -sp-col1\"> \n             <div class=\" column -column1\"> \n              <p class=\"c-lead\">“チーム”で取り組む強み</p> \n              <h2 class=\" c-title c-left\">コトＰＯＰやサンプルでＰＲ！</h2> \n             </div> \n             <div class=\" column -column2 -column-lasts\"> \n              <div class=\" c-body c-center\"> \n               <div class=\"c-img   \"> \n                <picture> \n                 <source type=\"image/webp\" srcset=\"_src/2468/img20220107153441519443.webp?v=1769645477911\"> \n                 <img src=\"_src/2468/img20220107153441519443.jpg?v=1769645477911\" width=\"480\" height=\"480\" alt=\"コトPOPやサンプルでPR！\" id=\"imgsrc2468_1\" class=\" c-no_adjust\" loading=\"lazy\"> \n                </picture> \n               </div> \n              </div> \n             </div> \n             <div class=\" column -column1\"> \n              <p class=\" c-body\">イラストが得意な人もそうでない人も、食べた感想からでいいので、まず書いてみましょう！！<br>コトＰＯＰは、新入社員がまず始めに取り組む『<span class=\" d-bold\">プレゼン</span>』です。<br>最初は何を書いたら良いか戸惑うかもしれませんが、大丈夫！<br>食べた感想から、飾り気のない言葉のほうが、お客様には響きます。自分が書いたコトＰＯＰに足を止めているお客様の姿は、何ものにも替えがたい“自信”になります。<br>パートさん、アルバイトさんを含め、売り場担当者のアイデアを柔軟に売り場に反映し、個店それぞれの特色を前面に出していく。<span class=\" d-bold\">売り場づくりを“チーム”で取り組むわが社の強みです。</span><br>バイヤーや店長だけでなく、<span class=\" d-bold\">現場担当者にも売り場の企画立案ができます</span>。<br>皆さんも、自分のアイデアを売り場にぶつけてみませんか。</p> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk2972\" class=\"b-plain c-space_normal c-sp-space_normal c-sp-padding_normal is-sp-hide bd-webp -dress_b14006Main1 cssskin-_block_main init-block_animation init-sp-block_animation\" data-bk-id=\"bk2972\" data-animated=\"fadeInUp\" data-sp-animated=\"fadeInUp\"> \n            <div class=\" g-column -col2 -sp-col1\"> \n             <div class=\" column -column1\"> \n              <h4 class=\"none c-small_headline c-center\"> \n               <div class=\"c-img   \"> \n                <picture> \n                 <source type=\"image/webp\" srcset=\"_src/2254/img20220107153747935315.webp?v=1769645477911\"> \n                 <img src=\"_src/2254/img20220107153747935315.png?v=1769645477911\" width=\"720\" height=\"720\" alt=\"ハレの日をもっと楽しく！\" id=\"imgsrc2254_1\" class=\" c-no_adjust\" loading=\"lazy\"> \n                </picture> \n               </div></h4> \n             </div> \n             <div class=\" column -column2 -column-lasts\"> \n              <div class=\"c-lead c-left\">\n                “幸せな情報発信” \n              </div> \n              <h2 class=\" c-title\">「ハレの日」をもっと楽しく！</h2> \n              <div class=\"c-none\">\n                &nbsp; \n              </div> \n              <p class=\" c-body\"><span class=\" d-bold\">地域密着スーパー</span>だからこそ、マルイは運動会や遠足といったイベントで、売り場が大きく変わります。コロナ禍の中、様々なイベントが中止や延期になっていますが、だからこそ、自宅で、小さな集まりの中で、制限のあるなかで楽しめるものを、マルイは積極的に提案してきました。<br>マルイの企業理念は、『<span class=\" d-bold\">私たちは食生活の提案を通じ、人々の暮らしの満足と笑顔を創造します</span>』です。<br>この企業理念の実現が、マルイの生命線です。生鮮の素材は、当たり前に調理されてテーブルに並びます。その美味しい食べ方を提案することで、<span class=\" d-bold\">お客様に『驚き』と『感動』を</span>感じていただきたい。『<span class=\" d-bold\">誰かに喜んでいただきたい</span>』こんな想いが伝われば、みんなが幸せな気分になれます。こういったみんなが<span class=\" d-bold\">嬉しい『情報発信』</span>をどんどんしていきたいと考えています。</p> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk2978\" class=\"b-plain c-space_normal c-sp-space_normal is-pc-hide bd-webp -dress_b14006Main1 cssskin-_block_main init-block_animation init-sp-block_animation\" data-bk-id=\"bk2978\" data-animated=\"fadeInUp\" data-sp-animated=\"fadeInUp\"> \n            <div class=\" g-column -col2 -sp-col1\"> \n             <div class=\" column -column1\"> \n              <p class=\"c-lead\">“幸せな情報発信”</p> \n              <h2 class=\"none c-title c-left\">「ハレの日」をもっと楽しく！</h2> \n             </div> \n             <div class=\" column -column2 -column-lasts\"> \n              <h4 class=\" c-small_headline c-center\"> \n               <div class=\"c-img   \"> \n                <picture> \n                 <source type=\"image/webp\" srcset=\"_src/2260/img20220107153747935315.webp?v=1769645477911\"> \n                 <img src=\"_src/2260/img20220107153747935315.png?v=1769645477911\" width=\"720\" height=\"720\" alt=\"ハレの日をもっと楽しく\" id=\"imgsrc2260_1\" class=\" c-no_adjust\" loading=\"lazy\"> \n                </picture> \n               </div></h4> \n             </div> \n             <div class=\" column -column1\"> \n              <p class=\" c-body\"><span class=\" d-bold\">地域密着スーパー</span>だからこそ、マルイは運動会や遠足といったイベントで、売り場が大きく変わります。コロナ禍の中、様々なイベントが中止や延期になっていますが、だからこそ、自宅で、小さな集まりの中で、制限のあるなかで楽しめるものを、マルイは積極的に提案してきました。<br>マルイの企業理念は、『<span class=\" d-bold\">私たちは食生活の提案を通じ、人々の暮らしの満足と笑顔を創造します</span>』です。<br>この企業理念の実現が、マルイの生命線です。生鮮の素材は、当たり前に調理されてテーブルに並びます。その美味しい食べ方を提案することで、<span class=\" d-bold\">お客様に『驚き』と『感動』を</span>感じていただきたい。『<span class=\" d-bold\">誰かに喜んでいただきたい</span>』こんな想いが伝われば、みんなが幸せな気分になれます。こういったみんなが<span class=\" d-bold\">嬉しい『情報発信』</span>をどんどんしていきたいと考えています。</p> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk2973\" class=\"b-plain c-space_normal c-sp-space_normal c-sp-padding_init is-sp-hide cssskin-_block_main\" data-bk-id=\"bk2973\" data-shared=\"true\" data-sharedname=\"fwave1\"> \n            <div class=\" column -column1\"> \n             <div class=\" c-body c-center\"> \n              <div class=\"c-img   \"> \n               <picture> \n                <source type=\"image/webp\" srcset=\"_src/2228/wave_20220112143151277.webp?v=1769645477911\"> \n                <img src=\"_src/2228/wave_20220112143151277.png?v=1769645477911\" width=\"1920\" height=\"76\" alt=\"マルイ_リクルート求人\" id=\"imgsrc2228_1\" class=\" c-no_adjust\" loading=\"lazy\"> \n               </picture> \n              </div> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk2974\" class=\"b-plain c-space_normal c-sp-space_normal c-sp-padding_init is-pc-hide cssskin-_block_main\" data-bk-id=\"bk2974\" data-shared=\"true\" data-sharedname=\"fwave2\"> \n            <div class=\" column -column1\"> \n             <div class=\" c-body c-center\"> \n              <div class=\"c-img   \"> \n               <picture> \n                <source type=\"image/webp\" srcset=\"_src/2235/wave800.webp?v=1769645477911\"> \n                <img src=\"_src/2235/wave800.png?v=1769645477911\" width=\"800\" height=\"102\" alt=\"マルイ_リクルート求人\" id=\"imgsrc2235_1\" class=\" c-no_adjust\" loading=\"lazy\"> \n               </picture> \n              </div> \n             </div> \n            </div> \n           </div> \n          </section> \n         </div> \n        </div> \n       </div> \n      </article> \n     </div> \n    </main> \n    <div id=\"a-footer\" data-float=\"false\" class=\"a-footer   cssskin-_area_footer\"> \n     <footer> \n      <div class=\"site_frame\"> \n       <div id=\"bk2924\" class=\"b-both_diff -left_large -sp-single_column c-space_normal c-sp-space_normal cssskin-_block_footer\" data-bk-id=\"bk2924\" data-shared=\"true\" data-sharedname=\"_フッタメニュー\"> \n        <div class=\" g-column\"> \n         <div class=\" column -col8 -col_main\"> \n          <nav> \n           <div c