{"url":"https://www.tis-web.co.jp/recruit/index.html","html":"<!DOCTYPE html>\n<html lang=\"ja\" prefix=\"og: http://ogp.me/ns#\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta content=\"IE=edge\" http-equiv=\"X-UA-Compatible\">\n    <meta content=\"initial-scale=1,width=device-width\" name=\"viewport\">\n    <title>株式会社ティ・アイ・エス新卒採用</title>\n    <link href=\"#\" rel=\"canonical\">\n    <meta content=\"株式会社ティ・アイ・エスの採用特設サイトです。福岡・佐賀を拠点に産業機械製作のFA事業、太陽光発電システム販売・メンテナンスの太陽光事業、機器の導入支援・メンテナンスのサービス事業を行っている企業です。\" name=\"description\">\n    <meta content=\"ja_JP\" property=\"og:locale\">\n    <meta content=\"株式会社ティ・アイ・エス新卒採用\" property=\"og:site_name\">\n    <meta content=\"株式会社ティ・アイ・エス新卒採用\" property=\"og:title\">\n    <meta content=\"website\" property=\"og:type\">\n    <meta content=\"#\" property=\"og:url\">\n    <meta content=\"assets/images/ogimage.jpg\" property=\"og:image\">\n    <meta content=\"株式会社ティ・アイ・エスの採用特設サイトです。福岡・佐賀を拠点に産業機械製作のFA事業、太陽光発電システム販売・メンテナンスの太陽光事業、機器の導入支援・メンテナンスのサービス事業を行っている企業です。\" property=\"og:description\">\n    <meta content=\"summary_large_image\" name=\"twitter:card\">\n    <meta content=\"株式会社ティ・アイ・エス新卒採用\" name=\"twitter:title\">\n    <meta content=\"株式会社ティ・アイ・エスの採用特設サイトです。福岡・佐賀を拠点に産業機械製作のFA事業、太陽光発電システム販売・メンテナンスの太陽光事業、機器の導入支援・メンテナンスのサービス事業を行っている企業です。\" name=\"twitter:description\">\n    <meta content=\"assets/images/ogimage.jpg\" name=\"twitter:image\">\n    <link href=\"assets/css/style.css\" rel=\"stylesheet\">\n    <script src=\"https://ajax.googleapis.com/ajax/libs/jquery/2.2.4/jquery.min.js\"></script>\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n    <link href=\"https://fonts.googleapis.com/css2?family=Azeret+Mono:wght@700&family=Rubik+Mono+One&display=swap\" rel=\"stylesheet\">\n    <link rel=\"apple-touch-icon\" sizes=\"180x180\" href=\"assets/images/icon/apple-touch-icon.png\">\n    <link rel=\"icon\" type=\"image/png\" sizes=\"32x32\" href=\"assets/images/icon/favicon-32x32.png\">\n    <link rel=\"icon\" type=\"image/png\" sizes=\"16x16\" href=\"assets/images/icon/favicon-16x16.png\">\n    <link rel=\"manifest\" href=\"assets/images/icon/site.webmanifest.txt\">\n    <link rel=\"mask-icon\" href=\"assets/images/icon/safari-pinned-tab.svg\" color=\"#615ea8\">\n    <meta name=\"msapplication-TileColor\" content=\"#615ea8\">\n    <meta name=\"theme-color\" content=\"#ffffff\">\n</head>\n<body id=\"top\">\n\n<div class=\"recruit\">\n\n    <header class=\"header add-scrolled add-reverse\" id=\"header\">\n        <div class=\"header-inner\">\n\n            <div class=\"header-ttl\">\n                <a class=\"header-ttlLink\" href=\"index.html\"><img src=\"assets/images/tis_logo.png\"><span>Recruit Site</span></a>\n            </div>\n\n            <nav class=\"header-nav\">\n                <button class=\"header-closeButton\" id=\"js-header_closeBtn\" type=\"button\">\n                    <span></span>\n                    <span></span>\n                </button>\n                <ul class=\"header-list\">\n                    <li class=\"header-item\">\n                        <div class=\"header-item_ttl\"><a class=\"header-itemLink-top js-unlink\" href=\"#mission\">ビジョン</a></div>\n                    </li>\n                    <li class=\"header-item\">\n                        <div class=\"header-item_ttl\"><a class=\"header-itemLink-top js-unlink\" href=\"#message\">メッセージ</a></div>\n                    </li>\n                    <li class=\"header-item\">\n                        <div class=\"header-item_ttl\"><a class=\"header-itemLink-top js-unlink\" href=\"#business\">事業内容</a></div>\n                    </li>\n                    <li class=\"header-item\">\n                        <div class=\"header-item_ttl\"><a class=\"header-itemLink-top js-unlink\" href=\"#interview\">社員インタビュー</a></div>\n                    </li>\n                    <li class=\"header-item\">\n                        <div class=\"header-item_ttl\"><a class=\"header-itemLink-top js-unlink\" href=\"#culture\">TISの文化</a></div>\n                    </li>\n                    <li class=\"header-item\">\n                        <div class=\"header-item_ttl\"><a class=\"header-itemLink-top js-unlink\" href=\"#company\">会社概要</a></div>\n                    </li>\n                    <li class=\"header-item\">\n                        <div class=\"header-item_ttl\"><a class=\"header-itemLink-top js-unlink\" href=\"recruit.html\">採用情報</a></div>\n                    </li>\n                    <li class=\"header-btnarea\">\n                        <a class=\"header-entry\" href=\"entry.html\" ><img src=\"assets/images/entry.svg\" alt=\"\"><tspan>エントリー</tspan>\n                        </a>\n                    </li>\n                </ul>\n            </nav>\n        </div>\n        <button class=\"header-navButton\" id=\"js-header_toggleBtn\" type=\"button\">\n            <span class=\"header-toggleBtn\">\n                <span></span>\n                <span></span>\n                <span></span>\n            </span>\n            <span class=\"header-toggleBtn-txt\">メニュー</span>\n        </button>\n        <a class=\"header-entryButton\" href=\"entry.html\" >\n            <img src=\"assets/images/entry.svg\"><tspan>エントリー</tspan></a>\n        <div class=\"header-bg js-headerBg\" id=\"js-headerBg\"></div>\n    </header>\t\n    <main class=\"top-main\">\n        <section class=\"top-kv\">\n            <h1 class=\"top-kv_ttl is-show\" id=\"js-top-kv_ttl\">\n                <span class=\"top-kv_ttl_txt\">Technology<br> for<br> society</span>\n            </h1>\n            <ul class=\"top-kv_imgList js-kv js-inView add-inView\" id=\"js-recruitTop\">\n                <li class=\"top-kv_imgItem\"></li>\n            </ul>\n        </section>\n        <section class=\"home-hero\">\n            <a id=\"mission\" class=\"anchor\"></a>\n            <div class=\"home-hero__body\">\n                <h3 class=\"home-hero__heading heading--highlighter\"><span>もっとこうしたい</span><br><span>もっとこうなればいいな</span></h3>\n                <p class=\"home-hero__lead\">そんな小さな気付きが、<br class=\"sp-onlyHidden\">いつか新しい「何か」を生み出せる可能性に繋がります。<br class=\"sp-onlyHidden\">「ゼロから自分が構想したものがカタチになる」<br class=\"sp-onlyHidden\">お客様にとって、社会にとって、最適なものを<br class=\"sp-onlyHidden\">模索し、提案し、満足していただく。<br class=\"sp-onlyHidden\">それが、私たちの仕事です。</p>\n            </div>\n        </section>\n        <section class=\"message-01\">\n            <a id=\"message\" class=\"anchor\"></a>\n\t\t\t<div class=\"ttl-messagepg\">\n\t\t\t\t<div class=\"herovisual\">\n\t\t\t\t\t<img src=\"assets/images/top_ceo.jpg\" alt=\"\" class=\"view-pc\">\n\t\t\t\t\t<img src=\"assets/images/top_ceo_sp.jpg\" alt=\"\" class=\"view-sp\">\n\t\t\t\t</div>\n\t\t\t\t<div class=\"ttl ceo\">\n\t\t\t\t\t<div class=\"left ceo\">\n\t\t\t\t\t\t<h3 class=\"\"><span>毎日</span>一歩ずつ<br class=\"sp-onlyHidden\"><span>チャレンジ</span>し続けています。</h3>\n\t\t\t\t\t\t<dl>\n\t\t\t\t\t\t\t<dt>取締役　副社長</dt>\n\t\t\t\t\t\t\t<dd>\n\t\t\t\t\t\t\t\t平川　良\n\t\t\t\t\t\t\t\t<small>Hirakawa Ryo</small>\n\t\t\t\t\t\t\t</dd>\n\t\t\t\t\t\t</dl>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n            <div class=\"team-feature__head\">\n                <p class=\"team-feature__desc\">毎日一歩ずつチャレンジし続けています。<br>我が社が続けている事業（３つの柱）を紹介します。</p>\n                <p class=\"team-feature__desc\">■FA事業<br>産業用ロボット等を活用し、お客様工場の省力化/自動化を推進し、<br>設備の構想～製作・お客様への納品・メンテナンスまで自社完結型のモノづくりを実施。</p>\n                <p class=\"team-feature__desc\">■サービス事業<br>半導体関連の大手メーカーとの協力体制で、考え・行動するモノづくりを実施。</p>\n                <p class=\"team-feature__desc\">■エコシステム事業<br>住宅用太陽光発電システムの販売～現地工事までを一貫体制で実施。</p>\n                <p class=\"team-feature__desc\">今、お客様（世の中）が一番求めている分野に関する事業を展開しています。<br>　・ロボットを使った人口減少へのチャレンジ<br>　・現代の動くモノに必要不可欠な半導体の進化へのチャレンジ<br>　・環境・温暖化・再生可能エネルギーへのチャレンジ</p>\n                <p class=\"team-feature__desc\">３本柱の業務で自らの力を存分に発揮してみませんか！</p>\n            </div>\n\t\t</section>\n        <section class=\"project-boxOdd\">\n            <a id=\"business\" class=\"anchor\"></a>\n            <div class=\"project-boxOddTop js-inView rise add-inView\">\n                <div class=\"project-boxOddTopImage\">\n                  <img alt=\"\" class=\"project-boxOddTopImage_img\" src=\"assets/images/top_business.jpg\">\n                </div>\n                <div class=\"home-culture__head\">\n                    <h2 class=\"home-culture__head--ttl heading--ej\"><span class=\"t-en\">Business</span><span class=\"t-ja\">事業内容</span></h2>\n                </div>\n                <div class=\"project-boxOddTopWrap\">\n                  <div class=\"project-boxOddTopInner\">\n                    <h2 class=\"project-boxOddTtl\"><span>FA事業</span></h2>\n                    <h3 class=\"home-hero__heading heading--highlighter\">依頼に応じて<span>ゼロから設計</span><br><span>開発する</span>実績とノウハウ</h3>\n                    <div class=\"project-boxOddTopText\">\n                      <p class=\"project-boxText_txt\">FA事業部では取引先からの依頼を受け、自動化装置の設計・製造を行っています。</p>\n                      <p class=\"project-boxText_txt\">依頼内容は商品の搬送や箱詰め、外観検査など様々あり、多種多様な業界から依頼が寄せられています。数多くの依頼を受け培った技術力で自信をもって装置の提案・設計を行っており、提案～設計～製造～納品～アフターフォローまで一貫して行っているため取引先の要望に迅速に対応しています。</p>\n                      <p class=\"project-boxText_txt\">また、FA事業部では取引先の依頼による装置だけでなく「煎自動マイスター」という漢方薬の自動生薬煎じ包装機を開発しており、メーカーとしての役割も担っています。</p>\n                      <p class=\"project-boxText_txt\">数多くの薬局で利用をしていただいており、患者様にとって有益となる煎じパックの普及に貢献しています。</p>\n                    </div>\n                  </div>\n                  <section class=\"personal-carousel-boxBtn whiteBtn\">\n                    <a class=\"common-btn\" href=\"bs_fa.html\"><span>仕事内容を見る</span></a>    \n                </section>        \n                </div>\n                <div class=\"project-boxOddTopWrap\">\n                    <div class=\"project-boxOddTopInner\">\n                      <h2 class=\"project-boxOddTtl\"><span>サービス事業</span></h2>\n                      <h3 class=\"home-hero__heading heading--highlighter\"><span>ティ・アイ・エスの原点</span><br>メカ・ハード・ソフトの<span>すべてに対応</span></h3>\n                      <div class=\"project-boxOddTopText\">\n                        <p class=\"project-boxText_txt\">サービス事業部では大手電機メーカーの協力会社として高品質、高効率の電子部品実装を実現する設備やシステムのメンテナンス、開発支援、製品評価支援、導入支援等を実施しています。</p>\n                        <p class=\"project-boxText_txt\">EV・自動運転、AI、VR、5Gの普及など、デジタル化の加速に伴う半導体・デバイス需要の拡大で今後も成長が予測される先端技術分野での社会貢献を目指しています。</p>\n                        <p class=\"project-boxText_txt\">サービス事業はティ・アイ・エスの原点ということもあり、メカ・ハード・ソフトのすべてに対応できる数少ない協力企業として取引先からの信頼をさらに向上させるべく取組んでいます。</p>\n                      </div>\n                    </div>\n                    <section class=\"personal-carousel-boxBtn whiteBtn\">\n                        <a class=\"common-btn\" href=\"bs_ser.html\"><span>仕事内容を見る</span></a>    \n                    </section>            \n                  </div>\n                  <div class=\"project-boxOddTopWrap\">\n                    <div class=\"project-boxOddTopInner\">\n                      <h2 class=\"project-boxOddTtl\"><span>エコシステム事業</span></h2>\n                      <h3 class=\"home-hero__heading heading--highlighter\">国内外のメーカーと連携する<br><span>太陽光発電</span>と<span>蓄電システム</span></h3>\n                      <div class=\"project-boxOddTopText\">\n                        <p class=\"project-boxText_txt\">九州北部（福岡・佐賀・長崎（一部）・熊本（一部））を中心に地場のハウスメーカー様と連携して住宅用太陽光発電システム及び蓄電システムの提案から施工までを一貫して行っております。</p>\n                        <p class=\"project-boxText_txt\">2002年より動き始めた事業ですが、施工実績は2024年度時点で5000件を超えました。</p>\n                        <p class=\"project-boxText_txt\">国内外の様々なメーカーの製品を取り扱っており近年多様化しているお客様それぞれの希望に沿ったシステムをご提案できるよう日々取り組んでいます。</p>\n                        <p class=\"project-boxText_txt\">部署は、新規取引先開拓やお客様への提案や見積作成、お引き渡し時の説明等を行う営業課、現地の調査や実際の施工を担う工事課、電力会社や経産省への申請、部材等の手配・受入を行う業務課で構成されています。</p>\n                      </div>\n                    </div>\n                    <section class=\"personal-carousel-boxBtn whiteBtn\">\n                        <a class=\"common-btn\" href=\"bs_eco.html\"><span>仕事内容を見る</span></a>    \n                    </section>            \n                  </div>\n                </div>\n        </section>\n        <a id=\"interview\" class=\"anchor\"></a>\n        <section class=\"crosstalk-box\">\n            <div class=\"crosstalk__head\">\n                <h2 class=\"crosstalk__head--ttl\"><span class=\"t-en\">InterView</span><span class=\"t-ja\">社員インタビュー</span></h2>\n            </div>\n\t\t\t<img src=\"assets/images/top_interview.jpg\" alt=\"\" class=\"\">\n            <div class=\"crosstalk-boxTopWrap\">\n                <div class=\"crosstalk-boxTopInner\">\n                  <h3 class=\"home-hero__heading heading--highlighter\">それぞれの<span>「役割」を担い、</span><br><span>一丸となって</span>仕事に取り組む集団</h3>\n                </div>\n              </div>\n              <div class=\"people-inner js-inView rise add-inView\">\n                <ul class=\"people-list people-list-pc\">\n                    <li class=\"people-item\">\n                        <a class=\"people-itemLink\" href=\"inv01.html\">\n                            <div class=\"people-itemLink-off\">\n                                <img alt=\"\" src=\"assets/images/top_interview01.jpg\" class=\"people-itemImg\">\n                            </div>\n                            <div class=\"people-itemLink-on\">\n                                <div class=\"people-itemLink-onInner\">\n                                    <p class=\"people-itemLink_txt-top\">子育てしながら働く女性の<br>ロールモデルに</p>\n                                </div>\n                            </div>\n                            <dl class=\"people-itemBox\">\n                                <dt class=\"people-itemBox_position\">管理部</dt>\n                                <dd class=\"people-itemBox_name\">森部さん</dd>\n                            </dl>\n                        </a>\n                    </li>  \n                    <li class=\"people-item\">\n                        <a class=\"people-itemLink\" href=\"inv02.html\">\n                            <div class=\"people-itemLink-off\">\n                                <img alt=\"\" src=\"assets/images/top_interview02.jpg\" class=\"people-itemImg\">\n                            </div>\n                            <div class=\"people-itemLink-on\">\n                                <div class=\"people-itemLink-onInner\">\n                                    <p class=\"people-itemLink_txt-top\">世の中にないものを<br>作れる面白さ</p>\n                                </div>\n                            </div>\n                            <dl class=\"people-itemBox\">\n                                <dt class=\"people-itemBox_position\">FA事業部</dt>\n                                <dd class=\"people-itemBox_name\">式町さん</dd>\n                            </dl>\n                        </a>\n                    </li>  \n                    <li class=\"people-item\">\n                        <a class=\"people-itemLink\" href=\"inv03.html\">\n                            <div class=\"people-itemLink-off\">\n                                <img alt=\"\" src=\"assets/images/top_interview03.jpg\" class=\"people-itemImg\">\n                            </div>\n                            <div class=\"people-itemLink-on\">\n                                <div class=\"people-itemLink-onInner\">\n                                    <p class=\"people-itemLink_txt-top\">業界にこだわらず<br>いろんな機械を作れる</p>\n                                </div>\n                            </div>\n                            <dl class=\"people-itemBox\">\n                                <dt class=\"people-itemBox_position\">FA事業部</dt>\n                                <dd class=\"people-itemBox_name\">本田さん</dd>\n                            </dl>\n                        </a>\n                    </li>  \n                    <li class=\"people-item\">\n                        <a class=\"people-itemLink\" href=\"inv04.html\">\n                            <div class=\"people-itemLink-off\">\n                                <img alt=\"\" src=\"assets/images/top_interview04.jpg\" class=\"people-itemImg\">\n                            </div>\n                            <div class=\"people-itemLink-on\">\n                                <div class=\"people-itemLink-onInner\">\n                                    <p class=\"people-itemLink_txt-top\">自分のやりたいことは<br>伝えることができる</p>\n                                </div>\n                            </div>\n                            <dl class=\"people-itemBox\">\n                                <dt class=\"people-itemBox_position\">サービス事業部</dt>\n                                <dd class=\"people-itemBox_name\">田島さん</dd>\n                            </dl>\n                        </a>\n                    </li>  \n                    <li class=\"people-item\">\n                        <a class=\"people-itemLink\" href=\"inv05.html\">\n                            <div class=\"people-itemLink-off\">\n                                <img alt=\"\" src=\"assets/images/top_interview05.jpg\" class=\"people-itemImg\">\n                            </div>\n                            <div class=\"people-itemLink-on\">\n                                <div class=\"people-itemLink-onInner\">\n                                    <p class=\"people-itemLink_txt-top\">成長を実感でき<br>やりがいにつながる</p>\n                                </div>\n                            </div>\n                            <dl class=\"people-itemBox\">\n                                <dt class=\"people-itemBox_position\">サービス事業部</dt>\n                                <dd class=\"people-itemBox_name\">西村さん</dd>\n                            </dl>\n                        </a>\n                    </li>  \n                    <li class=\"people-item\">\n                        <a class=\"people-itemLink\" href=\"inv06.html\">\n                            <div class=\"people-itemLink-off\">\n                                <img alt=\"\" src=\"assets/images/top_interview06.jpg\" class=\"people-itemImg\">\n                            </div>\n                            <div class=\"people-itemLink-on\">\n                                <div class=\"people-itemLink-onInner\">\n                                    <p class=\"people-itemLink_txt-top\">何でも話ができる<br>風通しの良さがある</p>\n                                </div>\n                            </div>\n                            <dl class=\"people-itemBox\">\n                                <dt class=\"people-itemBox_position\">エコ事業部</dt>\n                                <dd class=\"people-itemBox_name\">木下さん</dd>\n                            </dl>\n                        </a>\n                    </li>  \n                    <li class=\"people-item\">\n                        <a class=\"people-itemLink\" href=\"inv07.html\">\n                            <div class=\"people-itemLink-off\">\n                                <img alt=\"\" src=\"assets/images/top_interview07.jpg\" class=\"people-itemImg\">\n                            </div>\n                            <div class=\"people-itemLink-on\">\n                                <div class=\"people-itemLink-onInner\">\n                                    <p class=\"people-itemLink_txt-top\">「比嘉さんでよかった」<br>と言われるやりがい</p>\n                                </div>\n                            </div>\n                            <dl class=\"people-itemBox\">\n                                <dt class=\"people-itemBox_position\">エコ事業部</dt>\n                                <dd class=\"people-itemBox_name\">比嘉さん</dd>\n                            </dl>\n                        </a>\n                    </li>\n                    <li class=\"people-item\">\n                        <a class=\"people-itemLink\" href=\"inv08.html\">\n                            <div class=\"people-itemLink-off\">\n                                <img alt=\"\" src=\"assets/images/top_interview08.jpg\" class=\"people-itemImg\">\n                            </div>\n                            <div class=\"people-itemLink-on\">\n                                <div class=\"people-itemLink-onInner\">\n                                    <p class=\"people-itemLink_txt-top\">知識を吸収して<br>自己成長できる</p>\n                                </div>\n                            </div>\n                            <dl class=\"people-itemBox\">\n                                <dt class=\"people-itemBox_position\">サービス事業部</dt>\n                                <dd class=\"people-itemBox_name\">板谷さん</dd>\n                            </dl>\n                        </a>\n                    </li>\n                    <li class=\"people-item\">\n                        <a class=\"people-itemLink\" href=\"crosstalk.html\">\n                            <div class=\"people-itemLink-off\">\n                                <img alt=\"\" src=\"assets/images/top_interview09.jpg\" class=\"people-itemImg\">\n                            </div>\n                            <div class=\"people-itemLink-on\">\n                                <div class=\"people-itemLink-onInner\">\n                                    <p class=\"people-itemLink_txt-top\">それぞれの仕事のリアル<br>若手クロストーク</p>\n                                </div>\n                            </div>\n                            <dl class=\"people-itemBox\">\n                                <dt class=\"people-itemBox_position\">若手クロストーク「若手同士で語るTISで働く理由」</dt>\n                                <dd class=\"people-itemBox_name\">稲田さん/孝橋さん/床嶋さん</dd>\n                            </dl>\n                        </a>\n                    </li>\n                </ul>\n            </div>\n\t\t</section>\n        <a id=\"culture\" class=\"anchor\"></a>\n        <section class=\"culture-boxTop\">\n\t\t\t<!-- <div class=\"ttl-messagepg\">\n\t\t\t\t<div class=\"herovisual\">\n\t\t\t\t\t<img src=\"assets/images/top_culture.jpg\" alt=\"やりたい（やるべき）ことが社内で解決する環境\" class=\"view-pc\">\n\t\t\t\t\t<img src=\"assets/images/top_culture_sp.jpg\" alt=\"やりたい（やるべき）ことが社内で解決する環境\" class=\"view-sp\">\n\t\t\t\t</div>\n\t\t\t</div> -->\n            <div class=\"team-feature__head culture-boxList\">\n                <h2 class=\"page-sec__ttl\">\n                    <span class=\"t-en\">Culture</span>\n                    <span class=\"t-ja\">やりたい（やるべき）ことが社内で解決する環境</span>\n                </h2>\n                <ul>\n                    <li>\n                        <img src=\"assets/images/top_culture01.jpg\" alt=\"\">\n                        <dl>\n                            <dt>いつでも相談できる環境</dt>\n                            <dd>若いうちから業務をある程度任せていきます。<br class=\"sp-onlyHidden\">ただ、１人で業務をこなすのではなく、分からないことはすぐに先輩や上司に確認・相談できる文化があります。</dd>\n                            <dd>毎日やることは変わっていくため、その都度、発生する問題を先輩や上司と共に解決し、経験を通して自己成長できます。</dd>\n                            <dd>一人前と言われるまで5年以上かかると考えているため、ゆっくり時間をかけて育成を行います。</dd>\n                        </dl>\n                    </li>\n                    <li>\n                        <img src=\"assets/images/top_culture02.jpg\" alt=\"\">\n                        <dl>\n                            <dt>資格取得支援</dt>\n                            <dd>会社の取組みとして、部署・職種ごとに様々な資格取得を推奨しています。</dd>\n                            <dd>資格を取得することで、知識の習得ができ業務の幅が広がるだけではなく、該当資格の取得することで資格手当もつきます。</dd>\n                        </dl>\n                    </li>\n                    <li>\n                        <img src=\"assets/images/top_culture03.jpg\" alt=\"\">\n                        <dl>\n                            <dt>スキルアップ研修制度</dt>\n                            <dd>・新卒社員研修</dd>\n                            <dd>・若手社員向け研修</dd>\n                            <dd>・次世代リーダー研修</dd>\n                            <dd>・全社員に対し、全体研修会</dd>\n                            <dd>・OJTによる研修</dd>\n                        </dl>\n                    </li>\n                </ul>\n            </div>\n\t\t</section>\n        <a id=\"company\" class=\"anchor\"></a>\n        <section class=\"crosstalk-box\">\n            <div class=\"crosstalk__head\">\n              <h2 class=\"crosstalk__head--ttl\"><span class=\"t-en\">Company Data</span><span class=\"t-ja\">会社概要</span></h2>\n            </div> <img src=\"assets/images/top_company.jpg\" alt=\"\" class=\"\">\n            <div class=\"data-box\">\n              <ul class=\"data-boxList\">\n                <li class=\"data-boxItem\">\n                  <h2 class=\"data-boxItem_ttl\">会社名</h2>\n                  <div class=\"data-boxItem_content\"> 株式会社ティ・アイ・エス　／　Technical Information Service Co.,LTD </div>\n                </li>\n                <li class=\"data-boxItem\">\n                  <h2 class=\"data-boxItem_ttl\">設立</h2>\n                  <div class=\"data-boxItem_content\"> 1994年2月18日</div>\n                </li>\n                <li class=\"data-boxItem\">\n                  <h2 class=\"data-boxItem_ttl\">所在地</h2>\n                  <div class=\"data-boxItem_content\"> 【本社】 〒812-0014 福岡県福岡市博多区比恵町3番25号（<a href=\"https://goo.gl/maps/L7VHC5bDb6UwZQhe7\" target=\"_blank\" rel=\"noreferrer\">MAP<span class=\"icon-link\"></span></a>）<br> [代表]TEL : 092-414-8156 FAX : 092-414-8158 <br>[エコシステム直通]TEL : 092-414-8161 FAX : 092-414-8158</div>\n                  <div class=\"data-boxItem_content\">【鳥栖工場】 〒841-0048 佐賀県鳥栖市藤木町若桜4番8（<a href=\"https://goo.gl/maps/QKYHxQ4zeZ2MTJVA9\" target=\"_blank\" rel=\"noreferrer\">MAP<span class=\"icon-link\"></span></a>）<br> TEL : 0942-48-0755 FAX : 0942-48-0756 </div>\n                </li>\n                <li class=\"data-boxItem\">\n                  <h2 class=\"data-boxItem_ttl\">業務内容</h2>\n                  <div class=\"data-boxItem_content\">\n                    <ul class=\"data-listContent\">\n                      <li class=\"data-itemContent\"> <span class=\"data-itemContent_inline\">FA事業</span>\n                        <div class=\"data-itemContent_box\">\n                          <div class=\"data-itemContent_boxInner\">産業用ロボット等を活用した自動化/省力化装置および各種検査装置等の提案・基本構想・詳細設計・製作・納品・アフターフォロー<br>対応分野：半導体・食品・プラスチック・金属・医療・バイオ・社会公共等<br>自社製品「煎自動マイスター」の開発・製造・販売<br>（建設業許可：福岡県知事許可（般-30）第112020号）</div>\n                        </div>\n                      </li>\n                      <li class=\"data-itemContent\"> <span class=\"data-itemContent_inline\">サービス事業</span>\n                        <div class=\"data-itemContent_box\">\n                          <div class=\"data-itemContent_boxInner\">大手企業開発・評価支援および国内外の機器メンテナンス<br>（納品先支援・開発設備のテスト評価・生産支援ソフトの開発評価・ソフト開発業務）<br>（労働者派遣事業許可：派 40-301682）</div>\n                        </div>\n                      </li>\n                      <li class=\"data-itemContent\"> <span class=\"data-itemContent_inline\">エコシステム事業</span>\n                        <div class=\"data-itemContent_box\">\n                          <div class=\"data-itemContent_boxInner\">住宅用太陽光発電システムの販売・施工<br>蓄電池、HEMS関連機器、オール家電製品の販売\n                        ・施工<br>（建設業許可：福岡県知事許可（般-30）第112020号）</div>\n                        </div>\n                      </li>\n                    </ul>\n                  </div>\n                </li>\n                <li class=\"data-boxItem\">\n                    <h2 class=\"data-boxItem_ttl\">売上高</h2>\n                    <div class=\"data-boxItem_content\">17億7,400万円</div>\n                    <div class=\"data-boxItem_term\">（2025年1月実績）</div>\n                </li>\n                 <li class=\"data-boxItem\">\n                    <h2 class=\"data-boxItem_ttl\">従業員数</h2>\n                    <div class=\"data-boxItem_content\">122名</div>\n                    <div class=\"data-boxItem_term\">（2025年4月現在）</div>\n                </li>\n                <li class=\"data-boxItem\">\n                    <h2 class=\"data-boxItem_ttl\">月平均所定外労働時間</h2>\n                    <div class=\"data-boxItem_content\">12.4時間</div>\n                    <div class=\"data-boxItem_term\">（前年度実績）</div>\n                </li>\n                <li class=\"data-boxItem\">\n                    <h2 class=\"data-boxItem_ttl\">平均有給休暇取得日数</h2>\n                    <div class=\"data-boxItem_content\">13.1日</div>\n                    <div class=\"data-boxItem_term\">（前年度実績）</div>\n                </li>\n                <li class=\"data-boxItem\">\n                    <h2 class=\"data-boxItem_ttl\">育児休業取得率</h2>\n                    <div class=\"data-boxItem_content\">83%</div>\n                    <div class=\"data-boxItem_term\">（前年度実績）</div>\n                </li>\n                <li class=\"data-boxItem\">\n                    <h2 class=\"data-boxItem_ttl\">役員及び管理的地位にある者に占める女性の割合</h2>\n                    <div class=\"data-boxItem_content\">9.3%</div>\n                    <div class=\"data-boxItem_term\">（32名中3名）</div>\n                </li>\n              </ul>\n            </div>\n        </section>\n        <section class=\"entryBtn\">\n            <div class=\"personal-carousel-boxBtn\">\n            <a class=\"common-btn\" href=\"recruit.html\"><span>採用情報を見る</span></a>\n            </div>    \n        </section>\n\n    </main>\n</div>\n<footer class=\"footer\" id=\"js-footer\">\n    <div class=\"pagetop\">\n        <a href=\"#top\"><span><small>PAGE TOP</small></span></a>\n    </div>\n\t<div class=\"footer-inner\">\n\t\t<ul class=\"footer-list\">\n\t\t\t<li class=\"footer-item\">\n\t\t\t\t<dl class=\"footer-boxList\">\n\t\t\t\t\t<dt class=\"footer-boxItem_ttl\"><a class=\"footer-itemLink\" href=\"#mission\">ビジョン</a></dt>\n\t\t\t\t</dl>\n\t\t\t</li>\n\t\t\t<li class=\"footer-item\">\n\t\t\t\t<dl class=\"footer-boxList\">\n\t\t\t\t\t<dt class=\"footer-boxItem_ttl\"><a class=\"footer-itemLink\" href=\"#message\">メッセージ</a></dt>\n\t\t\t\t</dl>\n\t\t\t</li>\n\t\t\t<li class=\"footer-item\">\n\t\t\t\t<dl class=\"footer-boxList\">\n\t\t\t\t\t<dt class=\"footer-boxItem_ttl\"><a class=\"footer-itemLink\" href=\"#business\">事業内容</a>\n\t\t\t\t\t</dt>\n                    <dd class=\"footer-boxItem\">\n                        <a class=\"footer-boxItemLink\" href=\"bs_fa.html