form-content\">\n                    <dt>※確認のためにもう一度メールアドレスを入力してください。<span class=\"icon-required\">必須</span></dt>\n                    <dd><input class=\"input-40\" type=\"text\" name=\"confirm_email\" class=\"mf\"></dd>\n                  </dl>\n                  <dl class=\"form-content\">\n                    <dt>お問い合わせ内容<span class=\"icon-required\">必須</span></dt>\n                    <dd><textarea name=\"お問い合わせ内容(必須)\"></textarea></dd>\n                  </dl>\n\n                  <div class=\"c-btn c-btn__center submit-btn--list\">\n                    <button class=\"submit-btn\" type=\"submit\" name=\"submit\">確認する</button>\n                  </div>\n\n                </form>\n                <link rel=\"stylesheet\" href=\"mailform/mailform.css\" type=\"text/css\">\n                <script type=\"text/javascript\" src=\"mailform/mailform.js\" charset=\"utf-8\"></script>\n                <script type=\"text/javascript\" src=\"mailform/postcodes/get.cgi?js\" charset=\"utf-8\"></script>\n              </div>\n            </div>\n\n          </div>\n        </div>\n\n\n      </section>\n\n    </main>\n    <!-- / main -->\n\n    \n    <footer class=\"l-footer\">\n  <div class=\"l-container\">\n    <div class=\"footer-top\">\n      <ul class=\"u-pc-hide footer-list flex-col-sp flex-col-sp_2\">\n        <li><a href=\"/\">ホーム</a></li>\n        <li><a href=\"/company/\">会社概要</a></li>\n        <li><a href=\"/news/\">ニュース</a></li>\n        <li><a href=\"/contribution/\">社会貢献活動</a></li>\n        <li><a href=\"/archives/useful_information/\">お役立ち情報</a></li>\n        <li><a href=\"/filter-cloth/\">ろ布について</a></li>\n        <li><a href=\"/contact/\">お問い合わせ</a></li>\n        <li><a href=\"/product/\">製品紹介</a></li>\n        <li><a href=\"/recruitment/\">採用情報</a></li>\n        <li><a href=\"/case-study/\">導入事例</a></li>\n        <li><a href=\"/privacy/\">プライバシーポリシー</a></li>\n        <li class=\"footer_menu_en\"><a href=\"/en/\">English</a></li>\n      </ul>\n\n      <div class