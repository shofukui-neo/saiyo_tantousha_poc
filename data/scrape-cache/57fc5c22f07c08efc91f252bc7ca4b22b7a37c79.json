ics.co.jp/wp-content/themes/komatsu/build/img/common/instagram-gradient.svg\" width=\"32\" height=\"32\" style=\"width:32px;height:auto;\" alt=\"インスタグラム\"></a>\n      </div>\n    </div><!-- .gnav -->\n\n    <div class=\"sp_nav\">\n      <a class=\"a_komtrax\" href=\"https://cfm.komtrax.komatsu/c/fm/\" target=\"_blank\"><img src=\"https://www.kics.co.jp/wp-content/themes/komatsu/build/img/common/sp_komtrax.png\" alt=\"komtrax\"></a>\n      <a class=\"a_logo\" href=\"https://www.kics.co.jp/\"><img src=\"https://www.kics.co.jp/wp-content/themes/komatsu/build/img/common/sp_toplogo.png\" alt=\"コマツ福島\"></a>\n      <div></div>\n    </div>\n\n    <div id=\"sp_nav_insta\">\n      <a class=\"a_insta\" href=\"https://www.instagram.com/komatsu_fukushima/\" target=\"_blank\"><img src=\"https://www.kics.co.jp/wp-content/themes/komatsu/build/img/common/instagram-gradient.svg\" alt=\"instagram\"></a>\n    </div>\n    <div id=\"sp_nav_open\">\n      <span></span><span></span><span></span>\n    </div>\n    <div id=\"sp_menu\">\n      <ul class=\"menu_ul\">\n        <li>\n          <span class=\"down_p li_m\">製品案内</span>\n          <ul class=\"down_c\">\n            <li class=\"li_s\"><a href=\"https://www.kics.co.jp/product\">新車販売</a></li>\n            <li class=\"li_s\"><a href=\"https://www.kics.co.jp/usedcar\">中古車販売</a></li>\n            <li class=\"li_s\"><a href=\"https://kcsj.komatsu/ict/smartconstruction/lineup\" target=\"_blank\">ICT建機</a></li>\n          </ul>\n        </li>\n        <li class=\"li_m\">\n          <a href=\"https://www.kics.co.jp/serviceguide\">サービス・サポート</a>\n        </li>\n        <li class=\"li_m\">\n          <a href=\"https://www.kics.co.jp/ict-construction\">ICT施工</a>\n        </li>\n        <li class=\"li_m\">\n          <a href=\"https://www.kics.co.jp/outline\">会社案内</a>\n        </li>\n        <li class=\"li_m\">\n          <a href=\"https://www.kics.co.jp/recruit\">採用情報</a>\n        </li>\n      </ul>\n    </div>\n\n    <div id=\"to_top\">\n      <a class=\"to_top\" href=\"#\">\n        <img src=\"https://www.kics.co.jp/wp-content/themes/komatsu/build/img/common/btn_arrow_w.png\" alt=\"ページのトップへ\">\n      </a>\n    </div>\n\n\t</header>\n<main class=\"under_layer recruit_guide\">\n\t<div class=\"under_head\">\n\t\t<h2 class=\"top_pgttl\"><span class=\"showin_pageH\"><span class=\"showin_c\">採用情報</span></span></h2>\n\t</div>\n\t<div class=\"lnav_wrap\">\n\t\t<ul class=\"lnav_cntn\">\n\t\t\t<li>\n\t\t\t\t<a class=\"lnav_a\" href=\"https://www.kics.co.jp/recruit\">\n\t\t\t\t\t<div class=\"square_btn\">\n\t\t\t\t\t\t<p>募集要項</p>\n\t\t\t\t\t\t<span class=\"btn_arrow\"></span>\n\t\t\t\t\t</div>\n\t\t\t\t</a>\n\t\t\t</li>\n\t\t\t<li>\n\t\t\t\t<a class=\"lnav_a\" href=\"https://www.kics.co.jp/training\">\n\t\t\t\t\t<div class=\"square_btn\">\n\t\t\t\t\t\t<p>教育・研修</p>\n\t\t\t\t\t\t<span class=\"btn_arrow\"></span>\n\t\t\t\t\t</div>\n\t\t\t\t</a>\n\t\t\t</li>\n\t\t\t<li>\n\t\t\t\t<a class=\"lnav_a\" href=\"https://www.kics.co.jp/staff-interview\">\n\t\t\t\t\t<div class=\"square_btn\">\n\t\t\t\t\t\t<p>スタッフインタビュー</p>\n\t\t\t\t\t\t<span class=\"btn_arrow\"></span>\n\t\t\t\t\t</div>\n\t\t\t\t</a>\n\t\t\t</li>\n\t\t</ul>\n\t</div>\n\n\t<section class=\"rec_guide inner\">\n\t\t<h4 class=\"line_ttl\"><span class=\"img showin_pageH\"><span class=\"showin_c\">キャリア採用募集要項</span></span></h4>\n\t\t\t<div class=\"custom_dl_wrap\">\n\t\t\t\t<dl class=\"custom_dl\">\n\t\t\t\t\t<dt>募集職種</dt>\n\t\t\t\t\t<dd>①営業職<br />\r\n②サービス職<br />\r\n③スマートコンストラクション推進職</dd>\n\t\t\t\t</dl>\n\t\t\t\t<dl class=\"custom_dl\">\n\t\t\t\t\t<dt>仕事内容</dt>\n\t\t\t\t\t<dd>①営業職：コマツ製建設機械の販売・レンタル営業<br />\r\n②サービス職：コマツ製建設機械の修理・メンテナンス<br />\r\n③スマートコンストラクション推進職：お客様の様々な現場においてコマツのICT施工をサポート</dd>\n\t\t\t\t</dl>\n\t\t\t\t<dl class=\"custom_dl\">\n\t\t\t\t\t<dt>募集人数</dt>\n\t\t\t\t\t<dd>若干名</dd>\n\t\t\t\t</dl>\n\t\t\t\t<dl class=\"custom_dl\">\n\t\t\t\t\t<dt>雇用形態</dt>\n\t\t\t\t\t<dd>正社員</dd>\n\t\t\t\t</dl>\n\t\t\t\t<dl class=\"custom_dl\">\n\t\t\t\t\t<dt>勤務地</dt>\n\t\t\t\t\t<dd>①営業職②サービス職：会津支店、いわき支店、郡山支店、福島支店、原町支店、白河支店<br />\r\n③スマートコンストラクション推進職：郡山本社</dd>\n\t\t\t\t</dl>\n\t\t\t\t<dl class=\"custom_dl\">\n\t\t\t\t\t<dt>勤務時間</dt>\n\t\t\t\t\t<dd>8:30～17:30 （休憩 ： 60分）<br />\r\n※ただしサービス職は休憩80分</dd>\n\t\t\t\t</dl>\n\t\t\t\t<dl class=\"custom_dl\">\n\t\t\t\t\t<dt>給与<br class=\"pc\"></dt>\n\t\t\t\t\t<dd>207,100円（サービス職：22歳例）／256,900円（サービス職：36歳例）<br />\r\n＋基本給＋資格手当＋シーズン手当</dd>\n\t\t\t\t</dl>\n\t\t\t\t<dl class=\"custom_dl\">\n\t\t\t\t\t<dt>諸手当</dt>\n\t\t\t\t\t<dd>・子供手当<br />\r\n・通勤手当<br />\r\n・時間外手当<br />\r\n・報奨金（営業職）<br />\r\n・資格手当（サービス職）<br />\r\n・シーズン手当（サービス職）</dd>\n\t\t\t\t</dl>\n\t\t\t\t<dl class=\"custom_dl\">\n\t\t\t\t\t<dt>賞与</dt>\n\t\t\t\t\t<dd>年3回（7月、12月、3月）、 計7ヶ月分<br />\r\n※令和6年度実績</dd>\n\t\t\t\t</dl>\n\t\t\t\t<dl class=\"custom_dl\">\n\t\t\t\t\t<dt>昇給</dt>\n\t\t\t\t\t<dd>年1回（4月）</dd>\n\t\t\t\t</dl>\n\t\t\t\t<dl class=\"custom_dl\">\n\t\t\t\t\t<dt>有給</dt>\n\t\t\t\t\t<dd>試用期間終了後10日付与<br />\r\n※試用期間3ヶ月</dd>\n\t\t\t\t</dl>\n\t\t\t\t<dl class=\"custom_dl\">\n\t\t\t\t\t<dt>休日</dt>\n\t\t\t\t\t<dd>年間休日126日（土日祝日、年末年始休暇、夏期休暇）</dd>\n\t\t\t\t</dl>\n\t\t\t\t<dl class=\"custom_dl\">\n\t\t\t\t\t<dt>各種保険</dt>\n\t\t\t\t\t<dd>社保完備（雇用、健保、労災、厚生年金）、退職金制度あり（勤続3年以上）</dd>\n\t\t\t\t</dl>\n\t\t\t\t<dl class=\"custom_dl\">\n\t\t\t\t\t<dt>福利厚生</dt>\n\t\t\t\t\t<dd>コマツグループ共済会、各保険団体割引等</dd>\n\t\t\t\t</dl>\n\t\t\t\t<dl class=\"custom_dl\">\n\t\t\t\t\t<dt>必要資格</dt>\n\t\t\t\t\t<dd>普通自動車運転免許</dd>\n\t\t\t\t</dl>\n\t\t\t\t<dl class=\"custom_dl\">\n\t\t\t\t\t<dt>必要経験</dt>\n\t\t\t\t\t<dd>不問（整備・溶接・レンタル業務の経験あれば尚可）</dd>\n\t\t\t\t</dl>\n\t\t\t\t<dl class=\"custom_dl\">\n\t\t\t\t\t<dt>選考方法</dt>\n\t\t\t\t\t<dd>① 履歴書、職務経歴書を郵送（本社業務部 ・ 採用担当宛）<br />\r\n ↓<br />\r\n② 書類選考<br />\r\n ↓<br />\r\n③ 筆記試験、適正検査、面接<br />\r\n ↓<br />\r\n④ 採用</dd>\n\t\t\t\t</dl>\n\t\t\t\t<dl class=\"custom_dl\">\n\t\t\t\t\t<dt>選考場所</dt>\n\t\t\t\t\t<dd>〒963-8032<br />\r\n福島県郡山市下亀田16-3<br />\r\nコマツ福島株式会社　本社業務部</dd>\n\t\t\t\t</dl>\n\t\t\t</div>\n\t</section>\n\n\t<section class=\"to_contact inner\">\n\t\t<h4 class=\"line_ttl\"><span class=\"img showinB\"><span class=\"showin_c\">お問い合わせ先</span></span></h4>\n\t\t\t<div class=\"custom_dl_wrap\">\n\t\t\t\t<dl class=\"custom_dl\">\n\t\t\t\t\t<dt>住所</dt>\n\t\t\t\t\t<dd>〒963-8032<br />\r\n福島県郡山市下亀田16-3<br />\r\nコマツ福島株式会社　本社業務部</dd>\n\t\t\t\t</dl>\n\t\t\t\t<dl class=\"custom_dl\">\n\t\t\t\t\t<dt>電話番号</dt>\n\t\t\t\t\t<dd><a class=\"tel\" href=\"tel:024-922-2111\">024-922-2111</a></dd>\n\t\t\t\t</dl>\n\t\t\t\t<dl class=\"custom_dl\">\n\t\t\t\t\t<dt>採用担当</dt>\n\t\t\t\t\t<dd class=\"tanto_mail\">\n\t\t\t\t\t\t<span class=\"tanto_name\">本社業務部　荒明</span>\n\t\t\t\t\t\t<span>メールアドレス　</span>\n\t\t\t\t\t\t<div>\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<span class=\"mail\"><img src=\"https://www.kics.co.jp/wp-content/uploads/2022/07/saiyo_mailaddress_a.png\" alt=\"\"></span>\n\t\t\t\t\t\t\t\t\t\t\t\t\t<span class=\"mail\"><img src=\"\" alt=\"\"></span>\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t</dd>\n\t\t\t\t</dl>\n\t\t\t</div>\n\t</section>\n\n\t<div class=\"inner\">\n\t\t<div class=\"link_cntn\">\n\t\t\t<a class=\"link_banner int_banner\" href=\"https://www.kics.co.jp/staff-interview\"><img class=\"txt\" src=\"https://www.kics.co.jp/wp-content/themes/komatsu/build/img/top/int_link_txt.png\" alt=\"スタッフインタビュー\"><span class=\"btn_arrow\"></span></a>\n\t\t</div>\n\t</div>\n</main>\n\n\t<footer>\n\t\t<div class=\"foot_cntn inner\">\n\t\t\t<dl>\n\t\t\t\t<dt>製品･サービスに関するお問い合わせ</dt>\n\t\t\t\t<dd>\n\t\t\t\t\t<a class=\"to_contact\" href=\"https://www.kics.co.jp/contact\">\n\t\t\t\t\t\t<div class=\"square_btn\">\n\t\t\t\t\t\t<p>お問い合わせ</p>\n\t\t\t\t\t\t<span class=\"btn_arrow\"></span>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</a>\n\t\t\t\t\t<p><a class=\"tel\" href=\"tel:024-922-2111\">TEL 024-922-2111</a><br>FAX 024-983-3302</p>\n\t\t\t\t</dd>\n\t\t\t</dl>\n\t\t\t<div>\n\t\t\t\t<a href=\"https://www.kics.co.jp/\"><img src=\"https://www.kics.co.jp/wp-content/themes/komatsu/build/img/common/logo_footer.png\" alt=\"コマツ福島\"></a>\n\t\t\t\t<p>〒963-8032 <br