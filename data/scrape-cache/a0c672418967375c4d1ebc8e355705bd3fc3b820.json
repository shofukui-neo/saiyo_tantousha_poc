{"url":"https://www.yoshinodenka.com/recruit/","html":"<!DOCTYPE html>\n<html lang=\"ja\" class=\"swiper_mode\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width\">\n  <meta name=\"format-detection\" content=\"telephone=no\">\n  <title>吉野電化工業株式会社</title>\n  <meta name=\"description\" content=\"吉野電化工業は、金属めっき・樹脂めっき・表面処理・熱処理を手掛ける企業です。研究開発や品質管理にも注力し、多様なニーズに対応しています。\">\n\t\n\t<!-- css -->\n  <link rel=\"stylesheet\" href=\"common/css/cmn_style.css\">\n  <link rel=\"stylesheet\" href=\"css/style.css\">\n\t\n\t<!-- fonts -->\n  <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n  <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n  <link href=\"https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;700;900&display=swap\" rel=\"stylesheet\">\n\t\n\t<!-- favicon -->\n  <link rel=\"shortcut icon\" href=\"https://www.yoshinodenka.com/favicon.ico\">\n  <link rel=\"apple-touch-icon\" href=\"https://www.yoshinodenka.com/apple-touch-icon.png\">\n  \n  <!-- Google Tag Manager -->\n  <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\n  new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\n  j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n  'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n  })(window,document,'script','dataLayer','GTM-WKF9WF3L');</script>\n  <!-- End Google Tag Manager -->\n</head>\n<body id=\"top\" class=\"swiper_mode\">\n<!-- Google Tag Manager (noscript) -->\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-WKF9WF3L\"\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n<!-- End Google Tag Manager (noscript) -->\n<header id=\"header\" class=\"header\" data-include=\"common\"></header>\n<main id=\"main\" class=\"main\">\n  <div class=\"top_mv\">\n    <video class=\"top_mv--video\" autoplay loop muted playsinline poster=\"img/poster.webp\">\n      <source media=\"(max-width:767px)\" type=\"video/mp4\" src=\"video/mv_sp.mp4\">\n      <source type=\"video/mp4\" src=\"video/mv.mp4\">\n    </video>\n    <div class=\"top_mv--txt\">\n      <p class=\"top_mv--main\">めっき技術に自信あり。</p>\n      <p class=\"top_mv--sub\">金属めっき・熱処理、樹脂めっき、電解研磨など表面処理加工はお任せください。<br>また、新たなめっき技術の開発・試作を積極的に行っております。</p>\n      <svg width=\"502\" height=\"317\" viewBox=\"0 0 502 317\" role=\"img\" aria-hidden=\"true\"><path opacity=\"0.25\" d=\"M261.819 113.862L226.765 232.618H163.554L204.183 86.1724H255.11C267.393 86.1724 266.259 98.9431 261.819 113.862ZM93.0679 233.215H23.4323L0 317H236.213C274.007 317 304.526 230.231 304.526 230.231L330.698 135.823C330.698 135.823 372.177 173.419 372.177 194.664V317H453.529V194.664C453.529 166.019 420.365 122.456 420.365 122.456L502 0H402.791L343.548 88.5595C343.548 88.5595 337.218 0 293.471 0H157.696L132.279 92.0207L89.572 0H5.29117L100.532 205.764L93.0679 233.215Z\" fill=\"#00CDD6\"/></svg>\n    </div>\n    <!--<article id=\"topNews\" class=\"top_topics\">\n      <h2 class=\"top_topics--title\">Topics</h2>\n      <p><time datetime=\"\">&emsp;</time><span class=\"top_topics--txt\">&emsp;</span></p>\n    </article>-->\n    <div class=\"top_contact\">\n      <a href=\"contact/\">\n        <span class=\"top_contact--icon\"><svg class=\"fill_color\" width=\"50\" height=\"54\" viewBox=\"0 0 50 54\" role=\"img\" aria-hidden=\"true\"><use href=\"/common/img/icons.svg#icon-kako\"></use></svg>加工の<br>ご依頼</span>\n        <span class=\"top_contact--icon\"><svg class=\"fill_color\" width=\"41\" height=\"57\" viewBox=\"0 0 41 57\" role=\"img\" aria-hidden=\"true\"><use href=\"/common/img/icons.svg#icon-kaihatsu\"></use></svg>委託開発<br>共同開発</span>\n        <span class=\"top_contact--txt\">お見積もり・<br>お問い合わせ</span>\n      </a>\n    </div>\n    <figure class=\"top_mv--img\"><img src=\"img/mv_bg.webp\" width=\"1280\" height=\"133\" alt=\"\" aria-hidden=\"true\" loading=\"lazy\"></figure>\n  </div>\n  <section class=\"top_news\">\n    <div class=\"container flex\">\n      <div class=\"top_news--left\">\n        <hgroup>\n          <p class=\"cmn_heading--en\"><img src=\"img/h2_news.webp\" width=\"372\" height=\"107\" alt=\"NEWS\" loading=\"lazy\"></p>\n          <h2 class=\"cmn_heading\">お知らせ</h2>\n        </hgroup>\n        <p class=\"more_btn\"><a href=\"news/\" data-color=\"sub\" aria-label=\"お知らせ一覧を見る\">詳しく見る</a></p>\n      </div>\n      <div class=\"news_box\" id=\"newsList\"></div>\n    </div>\n  </section>\n  <section class=\"top_massage\">\n    <div class=\"container top_massage--inner\">\n      <p class=\"top_massage--lead\"><span>低環境負荷な</span><span>次世代のめっき技術</span></p>\n      <div class=\"top_massage--txt\">\n        <hgroup>\n          <p class=\"cmn_heading--en\" data-color=\"white\"><img src=\"img/h2_massage.webp\" width=\"599\" height=\"107\" alt=\"MASSAGE\" loading=\"lazy\"></p>\n          <h2 class=\"cmn_heading\">メッセージ</h2>\n        </hgroup>\n        <p class=\"main_txt\">YDKグループは表面処理業界のパイオニアとして<br class=\"pc_block\">金属素材の機械・化学・電気的性質向上を図る<br class=\"pc_block\">めっきと電解研磨を提供します。</p>\n        <p class=\"main_txt\">また、中長期の社会動向を見据え、<br class=\"pc_block\">持続可能な社会の実現手段としての<br class=\"pc_block\">低環境負荷なめっき技術開発にチャレンジしております。</p>\n        <p class=\"more_btn\"><a href=\"ydk/\">チームYDK</a></p>\n      </div>\n    </div>\n  </section>\n  <section class=\"top_product\">\n    <h2 class=\"cmn_heading--en\"><img src=\"img/h2_product.webp\" width=\"705\" height=\"107\" alt=\"PRODUCT\" loading=\"lazy\"></h2>\n    <section class=\"container flex\">\n      <div class=\"top_product--left\">\n        <h2 class=\"cmn_heading\">表面処理<br class=\"pc_block\">加工を探す</h2>\n        <p>小型部品の必要箇所のみを所望形状にする“精密クロムめっき”をはじめとした弊社めっき技術は、特に自動車分野で高い評価をいただいております。</p>\n      </div>\n      <div class=\"top_product--right tabgroup\">\n        <div class=\"tabs\" role=\"tablist\" aria-label=\"項目選択\">\n          <button class=\"tab -active\" role=\"tab\" id=\"tab1\" aria-controls=\"tab-panel1\" aria-selected=\"true\">\n            <svg width=\"49\" height=\"49\" viewBox=\"0 0 49 49\" role=\"img\" aria-hidden=\"true\"><use href=\"/common/img/icons.svg#icon-search\"></use></svg>\n            <span><em>活用業界</em><br>から探す</span>\n          </button>\n          <button class=\"tab\" role=\"tab\" id=\"tab2\" aria-controls=\"tab-panel2\" aria-selected=\"false\" tabindex=\"-1\">\n            <svg width=\"49\" height=\"49\" viewBox=\"0 0 49 49\" role=\"img\" aria-hidden=\"true\"><use href=\"/common/img/icons.svg#icon-search\"></use></svg>\n            <span><em>加工処理</em><br>から探す</span>\n          </button>\n        </div>\n        <div id=\"tab-panel1\" class=\"tab_content -active\" role=\"tabpanel\" aria-labelledby=\"tab1\" aria-hidden=\"false\">\n          <div class=\"top_product--industry\">\n            <a href=\"plating/#field01\">\n              <svg width=\"68\" height=\"34\" viewBox=\"0 0 68 34\" role=\"img\" aria-hidden=\"true\"><use href=\"/common/img/icons.svg#icon-industry01\"></use></svg>\n              自動車\n            </a>\n          </div>\n          <div class=\"top_product--industry\">\n            <a href=\"plating/#field02\">\n              <svg width=\"62\" height=\"44\" viewBox=\"0 0 62 44\" role=\"img\" aria-hidden=\"true\"><use href=\"/common/img/icons.svg#icon-industry07\"></use></svg>\n              建設機械\n            </a>\n          </div>\n          <div class=\"top_product--industry\">\n            <a href=\"plating/#field03\">\n              <svg width=\"48\" height=\"48\" viewBox=\"0 0 48 48\" role=\"img\" aria-hidden=\"true\"><use href=\"/common/img/icons.svg#icon-industry02\"></use></svg>\n              半導体製造装置\n            </a>\n          </div>\n          <div class=\"top_product--industry\">\n            <a href=\"plating/#field03\">\n              <svg width=\"38\" height=\"49\" viewBox=\"0 0 38 38\" role=\"img\" aria-hidden=\"true\"><use href=\"/common/img/icons.svg#icon-industry03\"></use></svg>\n              電子・<br class=\"sp_block\">通信機器\n            </a>\n          </div>\n          <div class=\"top_product--industry\">\n            <a href=\"plating/#field03\">\n              <svg width=\"25\" height=\"48\" viewBox=\"0 0 25 48\" role=\"img\" aria-hidden=\"true\"><use href=\"/common/img/icons.svg#icon-industry06\"></use></svg>\n              電力関係\n            </a>\n          </div>\n          <div class=\"top_product--industry\">\n            <a href=\"plating/#field04\">\n              <svg width=\"48\" height=\"47\" viewBox=\"0 0 48 47\" role=\"img\" aria-hidden=\"true\"><use href=\"/common/img/icons.svg#icon-industry04\"></use></svg>\n              医療機器\n            </a>\n          </div>\n          <div class=\"top_product--industry\">\n            <a href=\"plating/#field05\">\n              <svg width=\"52\" height=\"52\" viewBox=\"0 0 52 52\" role=\"img\" aria-hidden=\"true\"><use href=\"/common/img/icons.svg#icon-industry05\"></use></svg>\n              航空宇宙\n            </a>\n          </div>\n          <p class=\"tab_content--btn more_btn\"><a data-color=\"white\" href=\"plating/#field\" aria-label=\"活用業界一覧を見る\">一覧を見る</a></p>\n        </div>\n        <div id=\"tab-panel2\" class=\"tab_content\" role=\"tabpanel\" aria-labelledby=\"tab2\" aria-hidden=\"true\">\n          <div class=\"top_product--processing\">\n            <p class=\"top_product--\"><a href=\"plating/metal/\">金属めっき</a></p>\n            <ul class=\"top_product--processing-child\">\n              <li><a href=\"plating/metal/#Cr\">クロム</a></li>\n              <li><a href=\"plating/metal/#Ni\">ニッケル</a></li>\n              <li><a href=\"plating/metal/#Zn\">亜鉛</a></li>\n              <li><a href=\"plating/metal/#other\">その他</a></li>\n            </ul>\n          </div>\n          <div class=\"top_product--processing\">\n            <p class=\"top_product--\"><a href=\"plating/surface/\">金属熱処理</a></p>\n            <ul class=\"top_product--processing-child\">\n              <li><a href=\"plating/surface/#heat\">焼入れ</a></li>\n            </ul>\n          </div>\n          <div class=\"top_product--processing\">\n            <p class=\"top_product--\"><a href=\"plating/plastic/\">樹脂めっき</a></p>\n            <ul class=\"top_product--processing-child\">\n              <li><a href=\"plating/plastic/#plastic\">樹脂</a></li>\n            </ul>\n          </div>\n          <p class=\"tab_content--btn more_btn\"><a data-color=\"white\" href=\"plating/#processing\" aria-label=\"加工処理一覧を見る\">一覧を見る</a></p>\n        </div>\n        <p class=\"top_product--btn more_btn\"><a href=\"plating/\" aria-label=\"表面処理加工を詳しく見る\">詳しく見る</a></p>\n      </div>\n    </section>\n    <section class=\"container flex\">\n      <h2 class=\"cmn_heading\">表面処理<br class=\"pc_block\">加工一覧</h2>\n      <div data-include=\"plating\" data-target=\"aside\"></div>\n    </section>\n  </section>\n  <section class=\"top_development\">\n    <div class=\"container\">\n      <hgroup>\n        <p class=\"cmn_heading--en\"><img src=\"img/h2_development.webp\" width=\"961\" height=\"107\" alt=\"DEVELOPMENT\" loading=\"lazy\"></p>\n        <h2 class=\"cmn_heading\" data-color=\"white\">研究開発・試作</h2>\n      </hgroup>\n      <p class=\"main_txt\">\n        YDKは「次世代めっき開発」「試作」「委託開発」「共同開発」を行う研究開発部を設けています。<br>\n        また、YDKは中長期の社会動向を予測した独自の技術ロードマップを作成し、ロードマップを通して、<br class=\"pc_block\">\n        循環型社会が求める技術開発にチャレンジしています。\n      </p>\n    </div>\n    <p class=\"top_development--txt\">\n      <img class=\"top_development--txt01 pc_block\" src=\"img/development_txt01.webp\" width=\"825\" height=\"337\" alt=\"2020 コロナ禍によるDX進展サプライチェーン再構築、2025 脱石油・省エネ、2030 循環型社会\" loading=\"lazy\">\n      <img class=\"top_development--txt02 pc_block\" src=\"img/development_txt02.webp\" width=\"883\" height=\"280\" alt=\"\" loading=\"lazy\">\n      <img class=\"top_development--txtsp sp_block\" src=\"img/development_txtsp.svg\" width=\"377\" height=\"411\" alt=\"2020 コロナ禍によるDX進展サプライチェーン再構築、2025 脱石油・省エネ、2030 循環型社会\" loading=\"lazy\">\n    </p>\n    <div class=\"top_development--bottom\">\n      <p class=\"more_btn\"><a data-color=\"white\" href=\"research/\">研究開発について詳しく見る</a></p>\n      <figure class=\"top_development--img\"><img src=\"img/development_img01.webp\" width=\"718\" height=\"354\" alt=\"\" loading=\"lazy\"></figure>\n    </div>\n  </section>\n  <section class=\"top_research container\">\n    <h2 class=\"cmn_heading\">開発事例</h2>\n    <div class=\"top_development--slides\">\n      <section class=\"top_development--box\">\n        <div class=\"top_development--head\">\n          <h2 class=\"cmn_heading\" data-color=\"main\">次世代開発<br>委託・共同開発</h2>\n          <p class=\"more_btn\"><a href=\"research/case/#next_generation\" aria-label=\"次世代開発を詳しく見る\">詳しく見る</a></p>\n        </div>\n        <div class=\"swiper_container\">\n          <div class=\"swiper-wrapper\">\n            <div class=\"swiper-slide\">\n              <img src=\"img/development_img01-1.webp\" width=\"232\" height=\"229\" alt=\"\" loading=\"lazy\">\n              <span class=\"swiper-slide-txt\">メタサーフェスめっき</span>\n            </div>\n            <div class=\"swiper-slide\">\n              <img src=\"img/development_img01-2.webp\" width=\"232\" height=\"229\" alt=\"\" loading=\"lazy\">\n              <span class=\"swiper-slide-txt\">CFRPプリプレグへのめっき</span>\n            </div>\n            <div class=\"swiper-slide\">\n              <img src=\"img/development_img01-3.webp\" width=\"232\" height=\"229\" alt=\"\" loading=\"lazy\">\n              <span class=\"swiper-slide-txt\">多孔質導電体</span>\n            </div>\n          </div>\n        </div>\n      </section>\n      <section class=\"top_development--box\">\n        <div class=\"top_development--head\">\n          <h2 class=\"cmn_heading\" data-color=\"main\">めっき試作<br><br></h2>\n          <p class=\"more_btn\"><a href=\"research/case/#prototype\" aria-label=\"めっき試作を詳しく見る\">詳しく見る</a></p>\n        </div>\n        <div class=\"swiper_container\">\n          <div class=\"swiper-wrapper\">\n            <div class=\"swiper-slide\">\n              <img src=\"img/development_img02-1.webp\" width=\"232\" height=\"229\" alt=\"\" loading=\"lazy\">\n              <span class=\"swiper-slide-txt\">難めっき材</span>\n            </div>\n            <div class=\"swiper-slide\">\n              <img src=\"img/development_img02-2.webp\" width=\"232\" height=\"229\" alt=\"\" loading=\"lazy\">\n              <span class=\"swiper-slide-txt\">MID</span>\n            </div>\n            <div class=\"swiper-slide\">\n              <img src=\"img/development_img02-3.webp\" width=\"232\" height=\"229\" alt=\"\" loading=\"lazy\">\n              <span class=\"swiper-slide-txt\">高耐食性光沢黒色めっき</span>\n            </div>\n          </div>\n        </div>\n      </section>\n    </div>\n  </section>\n  <section class=\"top_equipment\">\n    <div class=\"container\">\n      <hgroup>\n        <p class=\"cmn_heading--en\"><img src=\"img/h2_technical.webp\" width=\"735\" height=\"107\" alt=\"TECHNICAL\" loading=\"lazy\"></p>\n        <h2 class=\"cmn_heading\" data-color=\"white\">技術情報</h2>\n      </hgroup>\n      <p class=\"main_txt\">\n        YDKグループの高度な技術力と徹底した品質管理でお客様のご要望にお応えいたします。先進的なめっき・熱処理技術と生産設備、分析・検査設備を多数備えています。\n      </p>\n    </div>\n    <div class=\"top_equipment--list\" data-include=\"technology\" data-target=\"aside\"></div>\n    <p class=\"more_btn\"><a data-color=\"white\" href=\"technology/\" aria-label=\"技術情報を詳しく見る\">詳しく見る</a></p>\n  </section>\n  <section class=\"top_strengths\">\n    <div class=\"top_strengths--container\">\n      <figure class=\"top_strengths--map\"><img src=\"common/img/strengths_img01.webp\" width=\"673\" height=\"909\" alt=\"拠点情報：（日本）山形、石川、静岡、群馬、茨城、埼玉、神奈川、（ベトナム）Hai Phong、（インドネシア）Balikpapan\" loading=\"lazy\"></figure>\n      <div class=\"top_strengths--right\">\n        <hgroup>\n          <p class=\"cmn_heading--en\"><img src=\"img/h2_strengths.webp\" width=\"781\" height=\"107\" alt=\"STRENGTHS\" loading=\"lazy\"></p>\n          <h2 class=\"cmn_heading\">吉野電化工業の強み</h2>\n        </hgroup>\n        <p class=\"main_txt\">\n          吉野電化工業は全国8か所にわたる事業所を展開し、高度な技術でご要望にお応えします。グループ全体の力で高品質な加工を提供し、柔軟に対応できる体制を整えています。\n        </p>\n        <ul class=\"top_strengths--txts\">\n          <li>\n            <h3 class=\"top_strengths--num\"><span>技術力 × 多様な表面処理対応力</span></h3>\n            <p>めっき・熱処理の両分野に強く、鉄・非鉄・樹脂など幅広い素材や複雑形状にも対応可能。長年の蓄積と最新技術の融合により、自動車・建機・精密部品など多様な業界から高評価を得ています。</p>\n          </li>\n          <li>\n            <h3 class=\"top_strengths--num\"><span>110年以上の信頼と実績</span></h3>\n            <p>創業1914年。大手メーカーや研究機関とも連携する“技術パートナー”としての安定感。試作から量産、品質管理まで一貫対応し、継続的な受託研究や共同開発の実績も多数。</p>\n          </li>\n          <li>\n            <h3 class=\"top_strengths--num\"><span>環境への先進的取り組み</span></h3>\n            <p>LED化・太陽光発電・パラジウム削減など、環境と技術の両立を追求。再生可能エネルギー活用や脱炭素型めっき技術の開発を進め、持続可能なものづくりに貢献しています。</p>\n          </li>\n        </ul>\n      </div>\n    </div>\n  </section>\n  <section class=\"top_company\">\n    <div class=\"container\">\n      <hgroup>\n        <p class=\"cmn_heading--en\"><img src=\"img/h2_company.webp\" width=\"637\" height=\"107\" alt=\"COMPANY\" loading=\"lazy\"></p>\n        <h2 class=\"cmn_heading\">会社情報</h2>\n      </hgroup>\n      <p class=\"more_btn\"><a href=\"/company/\" aria-label=\"会社情報を詳しく見る\">詳しく見る</a></p>\n      <div data-include=\"company\" data-target=\"aside\"></div>\n    </div>\n  </section>\n  <section class=\"top_group tabgroup\">\n    <div class=\"top_group--head\">\n      <div class=\"container\">\n        <hgroup>\n          <p class=\"cmn_heading--en\"><img src=\"img/h2_group.webp\" width=\"467\" height=\"107\" alt=\"GROUP\" loading=\"lazy\"></p>\n          <h2 class=\"cmn_heading\">グループ企業一覧</h2>\n        </hgroup>\n        <ul class=\"group_btns\" role=\"tablist\">\n          <li class=\"group_btns--item\">\n            <button class=\"group_btns--btn\" type=\"button\" role=\"tab\" id=\"groupTab01\" aria-controls=\"group01\" aria-selected=\"true\" tabindex=\"0\">\n              <span class=\"broup_btns--logo\"><img src=\"com