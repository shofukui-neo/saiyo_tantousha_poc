//www.isimotoshouji.co.jp/recruit/\" />\n<link rel='shortlink' href='https://www.isimotoshouji.co.jp/?p=19' />\n<link rel=\"alternate\" type=\"application/json+oembed\" href=\"https://www.isimotoshouji.co.jp/wp-json/oembed/1.0/embed?url=https%3A%2F%2Fwww.isimotoshouji.co.jp%2Frecruit%2F\" />\n<link rel=\"alternate\" type=\"text/xml+oembed\" href=\"https://www.isimotoshouji.co.jp/wp-json/oembed/1.0/embed?url=https%3A%2F%2Fwww.isimotoshouji.co.jp%2Frecruit%2F&#038;format=xml\" />\n</head>\n\n<body class=\"page-template-default page page-id-19\">\n\n\n<!-- header start ---------------------------------------------------------------------------->\n<header>\n\n<div id=\"header\" class=\"wrapper\">\n  <h1 class=\"logo\"><a href=\"https://www.isimotoshouji.co.jp/\"><img src=\"https://www.isimotoshouji.co.jp/wp/wp-content/themes/ishimoto_temp/images/logo_b.png\" alt=\"石本商事株式会社\"></a></h1>\n<nav>\n  <input type=\"checkbox\" id=\"menu-btn-check\">\n  <label for=\"menu-btn-check\" class=\"menu-btn\"><span></span></label>\n  <div class=\"wrap-g-navi\">\n      <ul class=\"g-navi\">\n        <li class=\"first\">\n          <a href=\"https://www.isimotoshouji.co.jp/\">HOME</a>\n        </li>\n        <li class=\"\" ontouchstart=\"\">\n          <a href=\"https://www.isimotoshouji.co.jp/company\">会社概要</a>\n        </li>\n        <li class=\"\" ontouchstart=\"\">\n          <a href=\"https://www.isimotoshouji.co.jp/service\">サービス内容</a>\n        </li>\n        <li class=\"\" ontouchstart=\"\">\n          <a href=\"https://www.isimotoshouji.co.jp/process\">導入までのプロセス</a>\n        </li>\n        <li class=\"\" ontouchstart=\"\">\n          <a href=\"https://www.isimotoshouji.co.jp/recruit\">採用情報</a>\n        </li>\n        <li class=\"contact\" ontouchstart=\"\">\n          <a href=\"mailto:kk_isimoto@isimotoshouji.co.jp\">お問い合わせ</a>\n        </li>\n      </ul>\n  </div>\n </nav>\n\n  <div class=\"sns-ara2 pc\">\n    <div class=\"icon insta\">\n      <a href=\"https://instagram.com/ishimoto_shouji?igshid=MzRlODBiNWFlZA==\" target=\"_blank\" class=\"\"><img src=\"https://www.isimotoshouji.co.jp/wp/wp-content/themes/ishimoto_temp/images/logo_instagram.png\" alt=\"\"></a>\n    </div>\n    <div class=\"icon youutbe\">\n        <a href=\"https://youtube.com/@ishimoto.kyu-syoku?si=SprepLiyML4hAXR7\" target=\"_blank\" class=\"\"><img src=\"https://www.isimotoshouji.co.jp/wp/wp-content/themes/ishimoto_temp/images/logo_icon_youtube.png\" alt=\"\"></a>\n    </div>\n    <div class=\"icon line\">\n        <a href=\"https://line.me/R/ti/p/@009zpfth?oat_content=url\" target=\"_blank\" class=\"\"><img src=\"https://www.isimotoshouji.co.jp/wp/wp-content/themes/ishimoto_temp/images/logo_icon_line.png\" alt=\"\"></a>\n    </div>\n  </div>\n\n</div><!--  header end --->\n\n</header>\n\n\n\n\n\n\n<div class=\"contents second recruit\">\r\n<div class=\"h-obi\">\r\n<p class=\"header-text\">RECRUIT SITE</p>\r\n<!--\r\n<p class=\"header-text\"><a href=\"recruit\">RECRUIT SITE</a>|<a href=\"interview\">先輩社員インタビュー</a>|<a href=\"training\">人材育成・研修制度・よくある質問</a>|<a href=\"message\">先輩社員のメッセージ</a>|</p>\r\n-->\r\n</div>\r\n\r\n\r\n<div class=\"background_movie_wrap mainvisual\">\r\n  <video autoplay muted loop src=\"//www.isimotoshouji.co.jp/wp/wp-content/themes/ishimoto_temp/images/movie_recruit.mp4\" class=\"background_movie\"></video>\r\n <div class=\"background_movie_text\">\r\n  <h2 class=\"r-maincopy1\">Welcome to ISHIMOTO!</h2>\r\n<!--\r\n  <h2 class=\"r-maincopy2\">食<span>を</span>彩る<br class=\"\">\r\n自分<span>を</span>彩る毎日<span>を</span></h2>\r\n-->\r\n </div>\r\n</div>\r\n\r\n\r\n<div class=\"block01\">\r\n<div class=\"wrapper\">\r\n<h3 class=\"b-title\">INTERVIEW</h3>\r\n<p class=\"b-title\">先輩社員インタビュー</p>\r\n\r\n<div class=\"flex\">\r\n<div class=\"box\">\r\n<p class=\"tb-rl\">「何事も率先」を心がけて</p>\r\n\r\n<div class=\"img-area\">\r\n<a href=\"https://www.isimotoshouji.co.jp/interview#interview01\" class=\"box\">\r\n<img src=\"https://www.isimotoshouji.co.jp/wp/wp-content/themes/ishimoto_temp/images/recruit_img101.png\">\r\n</a></div>\r\n<div class=\"text-area\">\r\n<p class=\"eng\">Nutritionist</p>\r\n<p class=\"dct\">栄養士</p>\r\n<p class=\"name\">M・U(2009年入社)</p>\r\n\r\n</div>\r\n</div>\r\n<div class=\"box\">\r\n<p class=\"tb-rl\">献立に季節感を取り入れて</p>\r\n\r\n<div class=\"img-area\">\r\n        <a href=\"https://www.isimotoshouji.co.jp/interview#interview02\" class=\"box\">\r\n<img src=\"https://www.isimotoshouji.co.jp/wp/wp-content/themes/ishimoto_temp/images/recruit_img102.png\">\r\n</a></div>\r\n<div class=\"text-area\">\r\n<p class=\"eng\">Dietitian</p>\r\n<p class=\"dct\">管理栄養士</p>\r\n<p class=\"name\">N・K(2014年入社)</p>\r\n\r\n</div>\r\n</div>\r\n<div class=\"box\">\r\n<p class=\"tb-rl\">「おいしかったよ」が喜びに</p>\r\n\r\n<div class=\"img-area\">\r\n        <a href=\"https://www.isimotoshouji.co.jp/interview/#interview03\" class=\"box\">\r\n<img src=\"https://www.isimotoshouji.co.jp/wp/wp-content/themes/ishimoto_temp/images/recruit_img103.png\">\r\n</a></div>\r\n<div class=\"text-area\">\r\n<p class=\"eng\">Professional chef</p>\r\n<p class=\"dct\">調理師</p>\r\n<p class=\"name\">R・T(2018年入社)</p>\r\n\r\n</div>\r\n</div>\r\n</div>\r\n</div>\r\n</div>\r\n<div class=\"block02\">\r\n<div class=\"wrapper\">\r\n<div class=\"text-area\">\r\n<h3 class=\"b-title\">TRAINING</h3>\r\n<p class=\"b-title\">人材育成・研修制度<br class=\"\">\r\nよくある質問</p>\r\n<p>私たちは当日調理にこだわった手づくり給食の提供を通して、自ら考え行動できる人を育みます。こちらのページでは一人ひとりの着実な成長を支える研修体系や入社後のキャリアモデルの紹介、学生の皆さんからよくいただく質問に回答しています。</p>\r\n<p class=\"btn01\"><a href=\"https://www.isimotoshouji.co.jp/training\">詳しくはこちら</a></p>\r\n\r\n</div>\r\n<div class=\"img-area\">\r\n        <img src=\"https://www.isimotoshouji.co.jp/wp/wp-content/themes/ishimoto_temp/images/recruit_img201.jpg\"></div>\r\n</div>\r\n</div>\r\n<div class=\"block03\">\r\n<div class=\"wrapper\">\r\n<div class=\"text-area\">\r\n<h3 class=\"b-title\">MESSAGE</h3>\r\n<p class=\"b-title\">会社の雰囲気教えます!<br class=\"\">\r\n先輩社員のメッセージ</p>\r\n<p>「石本商事に入社してよかったこと」「社内の雰囲気」「一緒に働く仲間」について先輩社員にアンケートを実施！ 先輩たちの声を通して、当社の雰囲気をぜひ感じてください。人事担当から当社を目指す学生の皆さんへのメッセージも掲載しています。</p>\r\n<p class=\"btn01\"><a href=\"https://www.isimotoshouji.co.jp/message\">詳しくはこちら</a></p>\r\n\r\n</div>\r\n<div class=\"img-area\">\r\n        <img src=\"https://www.isimotoshouji.co.jp/wp/wp-content/themes/ishimoto_temp/images/recruit_img202.jpg\"></div>\r\n</div>\r\n</div>\r\n<!--\r\n<div class=\"block04\">\r\n<div class=\"wrapper\">\r\n<div class=\"text-area\">\r\n<h3 class=\"b-title\">MOVIE</h3>\r\n<p class=\"b-title\">先輩社員の実際の<br class=\"\">\r\n仕事の様子をご覧ください。</p>\r\n\r\n</div>\r\n<div class=\"img-area\">\r\n        <a href=\"#\" target=\"_blank\" rel=\"noopener\"><img src=\"[template_url]/images/recruit_img_youtube.jpg\" class=\"shadow\"></a></div>\r\n</div>\r\n-->\r\n<div class=\"block05\">\r\n<div class=\"wrapper\">\r\n<div class=\"text-area\">\r\n<h3 class=\"b-title\">ENTRY</h3>\r\n<p class=\"b-title\">エントリーはこちらより<br class=\"\">\r\nお願いします。</p>\r\n\r\n</div>\r\n<div class=\"bnr-area\">\r\n<div class=\"bnr shadow\"><a href=\"https://job.mynavi.jp/27/pc/search/corp87510/outline.html\" target=\"_blank\" rel=\"noopener\"><img src=\"https://www.isimotoshouji.co.jp/wp/wp-content/uploads/2026/01/27logo_l.gif\"></a></div>\r\n<div class=\"bnr shadow\"><a href=\"https://isimotoshouji-saiyo.jp/-/top/index.html\" target=\"_blank\" rel=\"noopener\">中途採用・パート採用の<br class=\"\">\r\n求人情報・応募はこちら</a></div>\r\n</div>\r\n</div>\r\n</div>\r\n</div>\n\n\n<!-- footer start ---------------------------------------------------------------------------->\n<div class=\"f-navi-wrapper\">\n  <ul class=\"f-navi\">\n    <li class=\"first\">\n        <a href=\"https://www.isimotoshouji.co.jp/\">HOME</a>\n    </li>\n    <li class=\"\">\n      <a href=\"https://www.isimotoshouji.co.jp/company\">会社概要</a>\n    </li>\n    <li class=\"\">\n      <a href=\"https://www.isimotoshouji.co.jp/service\">サービス内容</a>\n    </li>\n    <li class=\"\">\n      <a href=\"https://www.isimotoshouji.co.jp/process\">導入までのプロセス</a>\n    </li>\n    <li class=\"\">\n      <a href=\"https://www.isimotoshouji.co.jp/recruit\">採用情報</a>\n    </li>\n    <li class=\"\">\n      <a href=\"https://job.mynavi.jp/26/pc/search/corp87510/outline.html\" target=\"_blank\" rel=\"noopener\">新卒採用</a>\n    </li>\n    <li class=\"\">\n      <a href=\"https://isimotoshouji-saiyo.jp/-/top/index.html\" target=\"_blank\" rel=\"noopener\">中途・パート採用</a>\n    </li>\n  </ul>\n</div>\n\n<footer>\n  <div id=\"footer\" class=\"clearfix\">\n  <div class=\"wrapper clearfix\">\n\n    <!--\n    <div class=\"pagetop\">\n        <a href=\"#\"></a>\n    </div>\n    -->\n\n    <div class=\"text-area single\">\n      <h3 class=\"logo\"><a href=\"https://www.isimotoshouji.co.jp/\"><img src=\"https://www.isimotoshouji.co.jp/wp/wp-content/themes/ishimoto_temp/images/logo_b.png\" alt=\"石本商事株式会社\"></a></h3>\n      <p class=\"tel\"><img src=\"https://www.isimotoshouji.co.jp/wp/wp-content/themes/ishimoto_temp/images/icon_tel.png\">025-285-6221<span>(代表)</span></p>\n      <p class=\"tel\"><img src=\"https://www.isimotoshouji.co.jp/wp/wp-content/themes/ishimoto_temp/images/icon_tel.png\">025-284-7508<span>(人事部)</span></p>\n      <p class=\"btn01 f-mail\"><a href=\"mailto:kk_isimoto@isimotoshouji.co.jp\"><img src=\"https://www.isimotoshouji.co.jp/wp/wp-content/themes/ishimoto_temp/images/icon_mail.png\">メールでお問い合わせ</a></p>\n      <p class=\"address\"><本社> <br class=\"sp\">〒950-0973 新潟市中央区上近江3丁目19番22号<br>\n      <a href=\"https://goo.gl/maps/AKinjKy7PDLZZjQ39\" target=\"_blank\">Google MAP</a>\n      </p>\n    <div class=\"sns-ara-footer2\">\n        <div class=\"icon insta\">\n          <a href=\"https://instagram.com/ishimoto_shouji?igshid=MzRlODBiNWFlZA==\" target=\"_blank\" class=\"\"><img src=\"https://www.isimotoshouji.co.jp/wp/wp-content/themes/ishimoto_temp/images/logo_instagram.png\" alt=\"\"></a>\n        </div>\n        <div class=\"icon youutbe\">\n          <a href=\"https://youtube.com/@ishimoto.kyu-syoku?si=SprepLiyML4hAXR7\" target=\"_bl