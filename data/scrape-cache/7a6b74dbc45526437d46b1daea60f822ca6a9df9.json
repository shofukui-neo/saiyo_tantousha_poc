{"url":"https://www.iwatanigas.co.jp/recruit/work/training-diary.html","html":"<!doctype html>\n<html lang=\"ja\">\n<head>\n<!-- Google Tag Manager -->\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n})(window,document,'script','dataLayer','GTM-TNG4FCR');</script>\n<!-- End Google Tag Manager -->\n<!-- Google tag (gtag.js) -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-CS9J4SP782\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'G-CS9J4SP782');\n</script>\n<!-- // Google tag (gtag.js) -->\n<meta charset=\"utf-8\" />\n<meta http-equiv=\"Content-Style-Type\" content=\"text/css\" />\n<meta http-equiv=\"Content-script-type\" content=\"text/javascript\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<meta name=\"Keywords\" content=\"岩谷瓦斯,イワタニグループ,岩谷産業,新卒,採用,仕事,職種,業務内容\">\n<meta name=\"description\" content=\"岩谷瓦斯の新卒採用情報の「新人1年目の研修奮闘記」ページです。当社での業務内容をご紹介します。\">\n<title>新人1年目の研修奮闘記｜新卒採用｜岩谷瓦斯</title>\n<meta property=\"og:site_name\" content=\"新卒採用｜岩谷瓦斯\">\n<meta property=\"og:title\" content=\"新人1年目の研修奮闘記｜新卒採用｜岩谷瓦斯\">\n<meta property=\"og:description\" content=\"岩谷瓦斯の新卒採用情報の「新人1年目の研修奮闘記」ページです。当社での業務内容をご紹介します。\">\n<meta property=\"og:type\" content=\"article\">\t\n<meta property=\"og:image\" content=\"/recruit/common/img/ogp.jpg\">\t\n<meta property=\"og:url\" content=\"http://www.iwatanigas.co.jp/recruit/work/training-diary.html\">\n<meta property=\"og:locale\" content=\"ja_JP\">\n<meta name=\"format-detection\" content=\"telephone=no\">\n\n<!-- このページで使用するcssを読み込む -->\n<link rel=\"icon\" href=\"../common/img/favicon.ico\">\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/yakuhanjp@3.4.1/dist/css/yakuhanjp.min.css\">\n<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n<link href=\"https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500;700&family=Prompt:wght@300;400&family=Roboto+Condensed:wght@400;700&display=swap\" rel=\"stylesheet\">\n<link rel=\"stylesheet\" href=\"https://use.typekit.net/nja7gne.css\">\n<link href=\"https://unpkg.com/aos@2.3.1/dist/aos.css\" rel=\"stylesheet\">\n<link rel=\"stylesheet\" type=\"text/css\" href=\"css/training-diary.css\" media=\"all, projection, print\" />\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../common/css/common.css\" media=\"all, projection, print\" />\n\n\t\n</head>\n<body>\n<!-- Google Tag Manager (noscript) -->\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-TNG4FCR\"\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n<!-- End Google Tag Manager (noscript) -->\n\n\t\n\n<!-------------- #c-header -------------->\n<header class=\"c-header\">\n\t<div class=\"lines\">\n\t\t<span></span><span></span><span></span>\n\t</div>\n\t<div class=\"inner\">\n\t\t<a href=\"/recruit/\" class=\"logo\">\n\t\t\t<img src=\"../common/img/logo.png\" alt=\"岩谷瓦斯株式会社\">\n\t\t</a>\t\t\n\t\t<a class=\"entry en mess\" href=\"/recruit/message/\"><span>Message</span></a>\t\n\t\t<a class=\"entry en\" href=\"https://www.iwatanigas.co.jp/entry/shinsotsu.php\" target=\"_blank\"><span>ENTRY</span></a>\n\t\n\t\t<div class=\"c-humburger\">\n\t\t\t<span class=\"bar bar_top\"></span>\n\t\t\t<span class=\"bar bar_middle\"></span>\n\t\t\t<span class=\"bar bar_bottom\"></span>\n\t\t</div>\n\t\t\n\t\t<nav class=\"c-nav\">\n\t\t\t<div class=\"nav-cntnts\">\n\t\t\t\t<a href=\"/recruit/about/\">\n\t\t\t\t\t<div>\n\t\t\t\t\t<p class=\"img\"><img src=\"../common/img/menu_icon01.svg\" alt=\"\"></p>\n\t\t\t\t\t<p class=\"ttl\">岩谷瓦斯の<br>事業</p>\n\t\t\t\t\t</div>\n\t\t\t\t</a>\n\t\t\t\t<a href=\"/recruit/about/social.html\">\n\t\t\t\t\t<div>\n\t\t\t\t\t<p class=\"img\"><img src=\"../common/img/menu_icon02.svg\" alt=\"\"></p>\n\t\t\t\t\t<p class=\"ttl\">社会が変化する、<br>その時に。</p>\n\t\t\t\t\t</div>\n\t\t\t\t</a>\t\n\t\t\t\t<a href=\"/recruit/about/keyword.html\">\n\t\t\t\t\t<div>\n\t\t\t\t\t<p class=\"img\"><img src=\"../common/img/menu_icon03.svg\" alt=\"\"></p>\n\t\t\t\t\t<p class=\"ttl\">キーワードで知る<br>岩谷瓦斯</p>\n\t\t\t\t\t</div>\n\t\t\t\t</a>\t\n\t\t\t\t<a href=\"/recruit/special/\">\n\t\t\t\t\t<div>\n\t\t\t\t\t<p class=\"img\"><img src=\"../common/img/menu_icon04.svg\" alt=\"\"></p>\n\t\t\t\t\t<p class=\"ttl\">そこに、<br>岩谷瓦斯がある理由。</p>\n\t\t\t\t\t</div>\n\t\t\t\t</a>\t\n\t\t\t\t<a href=\"/recruit/special/photo.html\">\n\t\t\t\t\t<div>\n\t\t\t\t\t<p class=\"img\"><img src=\"../common/img/menu_icon05.svg\" alt=\"\"></p>\n\t\t\t\t\t<p class=\"ttl\">写真で見る<br>岩谷瓦斯の現場</p>\n\t\t\t\t\t</div>\n\t\t\t\t</a>\n\t\t\t\t<a href=\"/recruit/work/people.html\">\n\t\t\t\t\t<div>\n\t\t\t\t\t<p class=\"img\"><img src=\"../common/img/menu_icon06.svg\" alt=\"\"></p>\n\t\t\t\t\t<p class=\"ttl\"><span class=\"en\">People</span><br>社員紹介</p>\n\t\t\t\t\t</div>\n\t\t\t\t</a>\t\n\t\t\t\t<a href=\"/recruit/work/\">\n\t\t\t\t\t<div>\n\t\t\t\t\t<p class=\"img\"><img src=\"../common/img/menu_icon07.svg\" alt=\"\"></p>\n\t\t\t\t\t<p class=\"ttl\"><span class=\"en\">Work</span><br>岩谷瓦斯の仕事を知る</p>\n\t\t\t\t\t</div>\n\t\t\t\t</a>\t\n\t\t\t\t<a href=\"/recruit/work/crosstalk.html\">\n\t\t\t\t\t<div>\n\t\t\t\t\t<p class=\"img\"><img src=\"../common/img/menu_icon08.svg\" alt=\"\"></p>\n\t\t\t\t\t<p class=\"ttl\"><span class=\"en\">Cross Talk</span><br>若手社員座談会</p>\n\t\t\t\t\t</div>\n\t\t\t\t</a>\t\n\t\t\t\t<a href=\"/recruit/work/parent.html\">\n\t\t\t\t\t<div>\n\t\t\t\t\t<p class=\"img\"><img src=\"../common/img/menu_icon09.svg\" alt=\"\"></p>\n\t\t\t\t\t<p class=\"ttl\"><span class=\"en\">Cross Talk</span><br>パパママ座談会</p>\n\t\t\t\t\t</div>\n\t\t\t\t</a>\t\n\t\t\t\t<a href=\"/recruit/work/faq.html\">\n\t\t\t\t\t<div>\n\t\t\t\t\t<p class=\"img\"><img src=\"../common/img/menu_icon10.svg\" alt=\"\"></p>\n\t\t\t\t\t<p class=\"ttl\"><span class=\"en\">FAQ</span><br>社員が本音で答えるFAQ</p>\n\t\t\t\t\t</div>\n\t\t\t\t</a>\t\n\t\t\t\t<a href=\"/recruit/work/training-diary.html\">\n\t\t\t\t\t<div>\n\t\t\t\t\t<p class=\"img\"><img src=\"../common/img/menu_icon11.svg\" alt=\"\"></p>\n\t\t\t\t\t<p class=\"ttl\"><span class=\"en\">Training</span><br>新人1年目の研修奮闘記</p>\n\t\t\t\t\t</div>\n\t\t\t\t</a>\t\n\t\t\t</div>\n\t\t\t<div class=\"und-btns\">\n\t\t\t\t<a href=\"/recruit/information/\"><span>募集要項</span></a>\n\t\t\t\t<a href=\"/recruit/information/welfare.html\"><span>ワークライフバランス＆<br>福利厚生</span></a>\n\t\t\t\t<a href=\"/recruit/information/faq.html\"><span>採用FAQ</span></a>\n\t\t\t</div>\n\t\t</nav>\n\t</div>\n</header>\n\t\n<div class=\"c-nav-bg\"></div>\n<!-------------- //#c-header -------------->\n\n\t\n\n\t\n\n\n<!-------------- #c-main -------------->\n<main class=\"c-main\">\n\t\n\t<section class=\"fv_area\">\n\t\t<div class=\"c-inner\">\n\t\t\t<div class=\"ttlarea\" data-aos=\"fade-up\" data-aos-duration=\"1600\" data-aos-once=\"true\">\n\t\t\t\t<h1>\n\t\t\t\t\t<span class=\"pc\">新人1年目の研修奮闘記</span>\n\t\t\t\t\t<div class=\"sp\"><span class=\"\">新人1年目の</span><br><span>研修奮闘記</span></div>\n\t\t\t\t</h1>\n\t\t\t\t<p class=\"img\">\n\t\t\t\t\t<img src=\"img/training-diary/fv_txt.svg\" alt=\"TRAINING\">\n\t\t\t\t</p>\n\t\t\t</div>\n\t\t</div>\n\t\t<p class=\"fvbg\">\n\t\t\t<img src=\"img/training-diary/fvbg.jpg\" alt=\"新人1年目の研修奮闘記\">\n\t\t</p>\n\t</section>\n\t\n\t<div class=\"lead_area\">\n\t\t<div class=\"lines\">\n\t\t\t<span></span><span></span><span></span>\n\t\t</div>\t\n\t\t<div class=\"c-inner\" data-aos=\"fade-up\" data-aos-duration=\"1600\" data-aos-once=\"true\" data-aos=\"fade-up\" data-aos-duration=\"1600\" data-aos-once=\"true\">\n\t\t\t<h2 class=\"ttl\">あなたの「やりたい」と<br class=\"sp\">「興味がある」ことから、<br>最適な職務を<br class=\"sp\">見つけるための若手期間</h2>\n\t\t\t<p class=\"txt\">新卒で岩谷瓦斯へ入社する方のそのほとんどが、<br class=\"sp\">実はガスのことを詳しく知りません。<br>1年目の研修を通じて、<br class=\"sp\">幅広くガスへの理解を深める中で、<br class=\"sp\">やりたいこと・興味が持てることを見つけ、<br class=\"sp\">自身のキャリアを描き始めるのです。<br>そんな自分のキャリア形成につながる、<br class=\"sp\">1年目の研修の流れをご紹介します。</p>\n\t\t\t\n\t\t</div>\n\t</div>\n\t<div class=\"step_area c-inner\">\n\t\t<div class=\"step-cntnr\" data-aos=\"fade-up\" data-aos-duration=\"1600\" data-aos-once=\"true\">\n\t\t\t<div class=\"ttl\">\n\t\t\t\t<img src=\"img/training-diary/step1-ttl.svg\" alt=\"1st step\">\n\t\t\t\t<div class=\"txt\">\n\t\t\t\t\t<h2>入社・新入社員研修</h2>\n\t\t\t\t\t<h3>社会人の基礎固めと<span><br class=\"sp\">岩谷瓦斯の風土に慣れる</span></h3>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t\t<div class=\"flex\">\n\t\t\t\t<div class=\"txt\">\n\t\t\t\t\t<h3>主な研修内容</h3>\n\t\t\t\t\t<p>ビジネスマナー研修、チームビルディング研修、部門概要説明、工場見学など、総務人事部が中心となって全体研修を行います。</p>\n\t\t\t\t</div>\n\t\t\t\t<div class=\"pht\">\n\t\t\t\t\t<img src=\"img/training-diary/step1-pht.jpg\" alt=\"\">\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t\t<div class=\"skill\">\n\t\t\t\t<h3>この研修で得られる<br class=\"sp\">知識・スキル・経験</h3>\n\t\t\t\t<p>岩谷瓦斯を「働く場所」として見たときに、必要な基礎知識・能力を固めていく期間。<br>当社で働くことのやりがい・醍醐味を知り、あなたの「やってみたい」につながる部分を探ります。</p>\n\t\t\t\t<ul>\n\t\t\t\t\t<li>岩谷瓦斯への深い企業理解</li>\n\t\t\t\t\t<li>社会人としての基礎力</li>\n\t\t\t\t\t<li>部門ごとの業務内容理解</li>\n\t\t\t\t\t<li>組織で動くことの重要性</li>\n\t\t\t\t</ul>\n\t\t\t</div>\n\t\t</div>\n\t\t<div class=\"step-cntnr\" data-aos=\"fade-up\" data-aos-duration=\"1600\" data-aos-once=\"true\">\n\t\t\t<div class=\"ttl\">\n\t\t\t\t<img src=\"img/training-diary/step2-ttl.svg\" alt=\"2nd step\">\n\t\t\t\t<div class=\"txt\">\n\t\t\t\t\t<h2>各種資格取得研修</h2>\n\t\t\t\t\t<h3>業務で必要となる資格取得に向けて、<span><br class=\"sp\">同期とともに座学＆実技</span></h3>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t\t<div class=\"flex\">\n\t\t\t\t<div class=\"txt\">\n\t\t\t\t\t<h3>主な研修内容</h3>\n\t\t\t\t\t<p>高圧ガス資格取得、フォークリフト・玉掛け・クレーン・ガス溶接の資格取得に向けた研修を行います。</p>\n\t\t\t\t</div>\n\t\t\t\t<div class=\"pht\">\n\t\t\t\t\t<img src=\"img/training-diary/step2-pht.jpg\" alt=\"\">\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t\t<div class=\"skill\">\n\t\t\t\t<h3>この研修で得られる<br class=\"sp\">知識・スキル・経験</h3>\n\t\t\t\t<p>ガスに関する知識や資格取得といった、業務の基礎スキル向上を促す期間。<br>学習を通じて、当社の業務領域の幅広さも理解していきます。</p>\n\t\t\t\t<ul>\n\t\t\t\t\t<li>仕事で携わる業務領域の広さ</li>\n\t\t\t\t\t<li>工場勤務するための基礎力</li>\n\t\t\t\t</ul>\n\t\t\t</div>\n\t\t</div>\n\t\t<div class=\"step-cntnr\" data-aos=\"fade-up\" data-aos-duration=\"1600\" data-aos-once=\"true\">\n\t\t\t<div class=\"ttl\">\n\t\t\t\t<img src=\"img/training-diary/step3-ttl.svg\" alt=\"3rd step\">\n\t\t\t\t<div class=\"txt\">\n\t\t\t\t\t<h2>現場研修1</h2>\n\t\t\t\t\t<h3>関西にある複数の主要工場で<span><br class=\"sp\">実際の業務を体感</span></h3>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t\t<div class=\"flex\">\n\t\t\t\t<div class=\"txt\">\n\t\t\t\t\t<h3>主な研修内容</h3>\n\t\t\t\t\t<p>いくつかのチームに分かれて、関西の各工場を数ヶ月ごとにローテーション。先輩社員の指導を受けながら、業務を体感します。</p>\n\t\t\t\t</div>\n\t\t\t\t<div class=\"pht\">\n\t\t\t\t\t<img src=\"img/training-diary/step3-pht.jpg\" alt=\"\">\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t\t<div class=\"skill\">\n\t\t\t\t<h3>この研修で得られる<br class=\"sp\">知識・スキル・経験</h3>\n\t\t\t\t<p>座学で学んだ内容を現場で活かすために、実践的なスキルを身につける期間。<br>それぞれの工場で扱うガスが変わると業務内容も変化するため、その違いも理解していきます。</p>\n\t\t\t\t<ul>\n\t\t\t\t\t<li>座学で学んだ内容の実践経験</li>\n\t\t\t\t\t<li>各工場の業務内容理解</li>\n\t\t\t\t\t<li>ガスごとの取り扱い方の違い</li>\n\t\t\t\t\t<li>実際の製造現場の雰囲気</li>\n\t\t\t\t</ul>\n\t\t\t</div>\n\t\t</div>\n\t</div>\n\t<div class=\"deep_area\">\n\t\t<div class=\"c-inner\" data-aos=\"fade-up\" data-aos-duration=\"1600\" data-aos-once=\"true\">\n\t\t\t<h3>この期間内により<br class=\"sp\">業務理解を深める研修も</h3>\n\t\t\t<ul>\n\t\t\t\t<li>\n\t\t\t\t\t<h4>全国工場での実地研修</h4>\n\t\t\t\t\t<div class=\"pht\">\n\t\t\t\t\t\t<img src=\"img/training-diary/deep-pht.jpg\" alt=\"全国工場での実地研修の様子\">\n\t\t\t\t\t</div>\n\t\t\t\t\t<p>関東エリア～九州エリアにある複数の拠点で1週間の出張を行い、現場の経験値をさらに増やします。</p>\n\t\t\t\t</li>\n\t\t\t\t<li>\n\t\t\t\t\t<h4>製造技術講習・溶接研修・技術営業研修</h4>\n\t\t\t\t\t<p>全国の工場を回る中で現場ごとの違いを比較することで、業務内容に対する理解をさらに深めます。</p>\n\t\t\t\t</li>\n\t\t\t</ul>\n\t\t</div>\n\t</div>\n\t<div class=\"step_area c-inner\">\n\t\t<div class=\"step-cntnr\" data-aos=\"fade-up\" data-aos-duration=\"1600\" data-aos-once=\"true\">\n\t\t\t<div class=\"ttl\">\n\t\t\t\t<img src=\"img/training-diary/step4-ttl.svg\" alt=\"4th step\">\n\t\t\t\t<div class=\"txt\">\n\t\t\t\t\t<h2>中間研修発表会</h2>\n\t\t\t\t\t<h3>数ヶ月の研修の<span>成果を振り返り</span></h3>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t\t<div class=\"flex\">\n\t\t\t\t<div class=\"txt\">\n\t\t\t\t\t<h3>主な研修内容</h3>\n\t\t\t\t\t<p>これまでに学んだことや、実践を積んでできるようになったこと、現場を体験したことでの気づき（働くやりがい、ヒヤリハットなど）を個人ごとにまとめてもらい、この数か月の学びを振り返ります。</p>\n\t\t\t\t</div>\n\t\t\t\t<div class=\"pht\">\n\t\t\t\t\t<img src=\"img/training-diary/step4-pht.jpg\" alt=\"\">\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t\t<div class=\"skill\">\n\t\t\t\t<h3>この研修で得られる<br class=\"sp\">知識・スキル・経験</h3>\n\t\t\t\t<p>身につけてきたさまざまなことを整理し、自身の成長を確認する期間。<br>研修を通じて着実にステップアップしていることを実感するタイミングです。</p>\n\t\t\t\t<ul>\n\t\t\t\t\t<li>現場研修で学んだことの整理</li>\n\t\t\t\t\t<li>自身のスキルアップの確認</li>\n\t\t\t\t\t<li>自分の適性に合った仕事イメージ</li>\n\t\t\t\t</ul>\n\t\t\t</div>\n\t\t</div>\n\t\t<div class=\"step-cntnr\" data-aos=\"fade-up\" data-aos-duration=\"1600\" data-aos-once=\"true\">\n\t\t\t<div class=\"ttl\">\n\t\t\t\t<img src=\"img/training-diary/step5-ttl.svg\" alt=\"5th step\">\n\t\t\t\t<div class=\"txt\">\n\t\t\t\t\t<h2>国家試験対策講習</h2>\n\t\t\t\t\t<h3><span>高圧ガス製造保安責任者資格試験</span>の<br class=\"sp\">知識を深める</h3>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t\t<div class=\"flex\">\n\t\t\t\t<div class=\"txt\">\n\t\t\t\t\t<h3>主な研修内容</h3>\n\t\t\t\t\t<p>岩谷瓦斯で働くにあたり取得が推奨されている、「高圧ガス製造保安責任者資格」の試験合格に向けた専門知識を学習します。</p>\n\t\t\t\t</div>\n\t\t\t\t<div class=\"pht\">\n\t\t\t\t\t<img src=\"img/training-diary/step5-pht.jpg\" alt=\"\">\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t\t<div class=\"skill\">\n\t\t\t\t<h3>この研修で得られる<br class=\"sp\">知識・スキル・経験</h3>\n\t\t\t\t<p>現場での経験も積んだタイミングで、より幅広く業務に携わるために必要な資格取得を目指す期間。<br>当社が持つ数多くのノウハウも活用しながら、試験合格に向けた学習をしていきます。</p>\n\t\t\t\t<ul>\n\t\t\t\t\t<li>試験合格に必要な知識の学習</li>\n\t\t\t\t\t<li>ガスに関わる国家資格の取得</li>\n\t\t\t\t\t<li>学習を通じた新入社員同士の交流</li>\n\t\t\t\t</ul>\n\t\t\t</div>\n\t\t</div>\n\t\t<div class=\"step-cntnr\" data-aos=\"fade-up\" data-aos-duration=\"1600\" data-aos-once=\"true\">\n\t\t\t<div class=\"ttl\">\n\t\t\t\t<img src=\"img/training-diary/step6-ttl.svg\" alt=\"6th step\">\n\t\t\t\t<div class=\"txt\">\n\t\t\t\t\t<h2>現場研修2</h2>\n\t\t\t\t\t<h3>関西にある複数の主要工場で<span><br class=\"sp\">実際の業務を体感</span></h3>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t\t<div class=\"flex\">\n\t\t\t\t<div class=\"txt\">\n\t\t\t\t\t<h3>主な研修内容</h3>\n\t\t\t\t\t<p>前回とは違う関西の工場で、新たな業務を体感。先輩社員に指導してもらいながら、これまでとは違った知識・技術を習得します。</p>\n\t\t\t\t</div>\n\t\t\t\t<div class=\"pht\">\n\t\t\t\t\t<img src=\"img/training-diary/step6-pht.jpg\" alt=\"\">\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t\t<div class=\"skill\">\n\t\t\t\t<h3>この研修で得られる<br class=\"sp\">知識・スキル・経験</h3>\n\t\t\t\t<p>前回とは扱っているガスが違う工場へ向かい、業務に必要な知識をさらに広げていく期間。<br>岩谷瓦斯で働く人としてふさわしい現場技術の習得を目指します。</p>\n\t\t\t\t<ul>\n\t\t\t\t\t<li>当社で働くことに対する<br class=\"sp\">深い業務理解</li>\n\t\t\t\t\t<li>工場勤務に必要な<br class=\"sp\">基礎力のさらなる向上</li>\n\t\t\t\t\t<li>「自分がやりたいことは何か」<br class=\"sp\">の気づき</li>\n\t\t\t\t\t<li>先輩社員との関係性構築</li>\n\t\t\t\t</ul>\n\t\t\t</div>\n\t\t</div>\n\t\t<div class=\"step-cntnr\" data-aos=\"fade-up\" data-aos-duration=\"1600\" data-aos-once=\"true\">\n\t\t\t<div class=\"ttl\">\n\t\t\t\t<img src=\"img/training-diary/step7-ttl.svg\" alt=\"7th step\">\n\t\t\t\t<div class=\"txt\">\n\t\t\t\t\t<h2>配属面談</h2>\n\t\t\t\t\t<h3><span>配属先の希望を聞く</span><br class=\"sp\">総務人事部との面談</h3>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t\t<div class=\"flex\">\n\t\t\t\t<div class=\"txt\">\n\t\t\t\t\t<h3>主な研修内容</h3>\n\t\t\t\t\t<p>研修で学んだことを踏まえて、自分が興味を持ったこと、向いていると感じたことなどを面談で聞きながら、配属先の希望を伺います。</p>\n\t\t\t\t</div>\n\t\t\t\t<div class=\"pht\">\n\t\t\t\t\t<img src=\"img/training-diary/step7-pht.jpg\" alt=\"\">\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\t</div>\n\t<div class=\"deep_area\">\n\t\t<div class=\"c-inner\" data-aos=\"fade-up\" data-aos-duration=\"1600\" data-aos-once=\"true\">\n\t\t\t<h3>この期間内により<br class=\"sp\">業務理解を深める研修も</h3>\n\t\t\t<ul>\n\t\t\t\t<li>\n\t\t\t\t\t<h4>分析基礎研修</h4>\n\t\t\t\t\t<p>工場で用いる分析計の基本原理や、機器校正・日常点検作業などの講義を通じて、品質および分析の基礎知識を身に着けていただきます。</p>\n\t\t\t\t</li>\n\t\t\t\t<li>\n\t\t\t\t\t<h4>海外事業研修</h4>\n\t\t\t\t\t<p>イワタニグループの海外での産業ガス事業の展開をくわしく学ぶことで、事業に対する理解を深めていきます。</p>\n\t\t\t\t</li>\n\t\t\t</ul>\n\t\t</div>\n\t</div>\n\t<div class=\"step_area c-inner\">\n\t\t<div class=\"step-cntnr\" data-aos=\"fade-up\" data-aos-duration=\"1600\" data-aos-once=\"true\">\n\t\t\t<div class=\"ttl\">\n\t\t\t\t<img src=\"img/training-diary/finalstep-ttl.svg\" alt=\"Final step\">\n\t\t\t\t<div class=\"txt\">\n\t\t\t\t\t<h2>研修まとめ・発表会・配属辞令</h2>\n\t\t\t\t\t<h3>研修の成果発表会と配属の決定</h3>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t\t<div class=\"flex\">\n\t\t\t\t<div class=\"txt\">\n\t\t\t\t\t<h3>主な研修内容</h3>\n\t\t\t\t\t<p>1年目の研修全体を振り返って、自身の成果を発表。<br>新人としての区切りを付けると同時に、正式配属先が伝えられ、着任に向けた準備を進めます。</p>\n\t\t\t\t</div>\n\t\t\t\t<div class=\"pht\">\n\t\t\t\t\t<img src=\"img/training-diary/step-final-pht.jpg\" alt=\"\">\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\t</div>\n\t\n\n\t\n\t\n\t\n</main>\n<!-------------- //#c-main -------------->\n\t\n\t\n\t\n\t\n<!-------------- #c-footer -------------->\n<footer class=\"c-footer\">\n\t<div class=\"c-inner\">\n\t\t<a href=\"http://www.iwatanigas.co.jp/index.html\" target=\"_blank\">コーポレートサイト</a>\n\t\t<a href=\"http://www.iwatanigas.co.jp/agreement/\" target=\"_blank\">プライバシーポリシー</a>\n\t</div>\n</footer>\n<!-------------- //#c-footer -------------->\n\t\n\n\n\n\n\t\n\n<script src=\"https://code.jquery.com/jquery-3.4.1.min.js\" integrity=\"sha256-CSXorXvZcTkaix6Yvo6HppcZGetbYMGWSFlBw8HfCJo=\" crossorigin=\"anonymous\"></script>\n<script type=\"text/javascript\" src=\"../common/js/common.js\"></script>\n<script type=\"text/javascript\" src=\"../common/js/jquery.matchHeight.js\"></script>\n<script src=\"https://unpkg.com/aos@2.3.1/dist/aos.js\"></script>\n<script>\n\tAOS.init();\n</script>\n<script>\n  $(function() {\n    $('.mht').matchHeight();\n  });\n</script>\n\t\n\n</body>\n</html>","finalUrl":"https://www.iwatanigas.co.jp/recruit/work/training-diary.html","rendered":false,"_cachedAt":"2026-06-23T18:21:02.971Z"}