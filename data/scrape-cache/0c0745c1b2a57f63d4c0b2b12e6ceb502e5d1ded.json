{"url":"https://map.jp/support/contactform/shirube/index.php","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>標 お問い合わせフォーム</title>\n<link rel=\"icon\" type=\"image/x-icon\" href=\"../favicon.ico\">\n<link rel=\"stylesheet\" href=\"../css/style.css\">\n<style>\n:root {\n    --theme-color: #A90002;\n    --base-color:  #FAE8E2;\n}\n</style>\n</head>\n<body>\n\n<div class=\"page-wrapper\">\n\n    <div class=\"form-header\">\n                    <img src=\"../images/logo_shirube.svg\" alt=\"標\" class=\"product-logo\">\n            </div>\n\n    <div class=\"form-container\">\n\n        <p class=\"form-intro\">\n            シリアルナンバー、電話番号、法人名、担当者名、返信先メールアドレス、具体的なお問合せ内容を入力の上、送信してください。<br>\n            返信先メールアドレスにご連絡いたします。\n        </p>\n\n        \n        <form method=\"post\" action=\"index.php\" novalidate>\n            <input type=\"hidden\" name=\"csrf_token\" value=\"cd047f952cef2ae48314c5a498683295\">\n\n            <!-- シリアルナンバー -->\n            <div class=\"form-group\">\n                <label class=\"field-label\" for=\"serial_number\">シリアルナンバー（ご登録済みの方）</label>\n                <input type=\"text\" id=\"serial_number\" name=\"serial_number\"\n                       value=\"\"\n                       placeholder=\"00000-00000-00000\" maxlength=\"17\" autocomplete=\"off\"\n                       inputmode=\"numeric\"\n                       class=\"\">\n                                <p class=\"field-note\">※ご登録済みの方で、わからない場合は入力不要です</p>\n            </div>\n\n            <!-- 電話番号 -->\n            <div class=\"form-group\">\n                <label class=\"field-label\" for=\"phone\">電話番号 <span class=\"required-mark\">必須</span></label>\n                <input type=\"tel\" id=\"phone\" name=\"phone\"\n                       value=\"\"\n                       placeholder=\"000-000-0000\" maxlength=\"15\" autocomplete=\"tel\"\n                       class=\"\">\n                            </div>\n\n            <!-- 法人名 -->\n            <div class=\"form-group\">\n                <label class=\"field-label\" for=\"company_name\">法人名（個人利用の場合は入力不要）</label>\n                <input type=\"text\" id=\"company_name\" name=\"company_name\"\n                       value=\"\"\n                       maxlength=\"100\" autocomplete=\"organization\">\n            </div>\n\n            <!-- 担当者名 -->\n            <div class=\"form-group\">\n                <label class=\"field-label\" for=\"contact_name\">お名前 <span class=\"required-mark\">必須</span></label>\n                <input type=\"text\" id=\"contact_name\" name=\"contact_name\"\n                       value=\"\"\n                       maxlength=\"100\" autocomplete=\"name\"\n                       class=\"\">\n                \n                <label class=\"field-label\" for=\"contact_furigana\" style=\"margin-top:10px;\">ふりがな <span class=\"required-mark\">必須</span></label>\n                <input type=\"text\" id=\"contact_furigana\" name=\"contact_furigana\"\n                       value=\"\"\n                       maxlength=\"100\" placeholder=\"やまだ たろう\"\n                       class=\"\">\n                            </div>\n\n            <!-- 返信用メールアドレス -->\n            <div class=\"form-group\">\n                <label class=\"field-label\" for=\"email\">返信用メールアドレス <span class=\"required-mark\">必須</span></label>\n                <input type=\"email\" id=\"email\" name=\"email\"\n                       value=\"\"\n                       maxlength=\"200\" autocomplete=\"email\"\n                       class=\"\">\n                \n                <label class=\"field-label\" for=\"email_confirm\" style=\"margin-top:10px;\">返信用メールアドレス（確認） <span class=\"required-mark\">必須</span></label>\n                <input type=\"email\" id=\"email_confirm\" name=\"email_confirm\"\n                       value=\"\"\n                       maxlength=\"200\" autocomplete=\"email\" placeholder=\"もう一度入力してください\"\n                       class=\"\">\n                            </div>\n\n            <!-- お問い合わせ内容 -->\n            <div class=\"form-group\">\n                <label class=\"field-label\" for=\"inquiry_content\">お問い合わせ内容 <span class=\"required-mark\">必須</span></label>\n                <textarea id=\"inquiry_content\" name=\"inquiry_content\"\n                          placeholder=\"具体的なお問い合わせ内容を入力してください\"\n                          class=\"\"></textarea>\n                                <div class=\"inquiry-example\">\n                    ＊例：ユーザーキーを忘れてしまい、ログインが出来ません。<br>\n                    　　　使用するパソコンを変更したい。等\n                </div>\n            </div>\n\n            <hr class=\"section-divider\">\n\n            <!-- 個人情報 -->\n            <div class=\"privacy-box\">\n                <h3>お問い合わせに関する個人情報の取り扱い</h3>\n                <p>ご登録いただいた情報は、当社の<a href=\"https://map.jp/index/privacypolicy.html\" target=\"_blank\">プライバシーポリシー</a>に従い適正に管理しています。</p>\n                <p>ご登録いただいた情報は、お客様からのお問い合わせやご依頼内容に的確に対応することを目的に限定して利用します。</p>\n                <p>これ以外の目的で利用したり、第三者に提供もしくは預託することはありません。</p>\n                <label class=\"privacy-agree-label\">\n                    <input type=\"checkbox\" name=\"privacy_agree\" value=\"1\"\n                           >\n                    個人情報の取り扱いに同意する\n                    <span class=\"required-mark\">必須</span>\n                </label>\n                            </div>\n\n            <!-- 赤字注釈 -->\n            <div class=\"red-notes\">\n                <p>※お問い合わせいただいたメールの返信は当社営業時間内となります。ご了承ください。</p>\n                <p>※返信メールアドレスに送信できない場合や、問い合わせの内容によってお電話させていただく場合がございます。</p>\n            </div>\n\n            <!-- ハニーポット：ボット対策（人間には見えません） -->\n            <div style=\"display:none !important; position:absolute; left:-9999px;\" aria-hidden=\"true\">\n                <input type=\"text\" name=\"website\" tabindex=\"-1\" autocomplete=\"off\">\n            </div>\n            <button type=\"submit\" class=\"btn-submit\">確認画面へ</button>\n        </form>\n    </div>\n</div>\n\n<script>\ndocument.getElementById('serial_number').onkeyup = function() {\n    var raw = this.value.replace(/[^0-9A-Za-z]/g, '');\n    var fmt = '';\n    if (raw.length > 0)  fmt  = raw.substring(0, 5);\n    if (raw.length > 5)  fmt += '-' + raw.substring(5, 10);\n    if (raw.length > 10) fmt += '-' + raw.substring(10, 15);\n    this.value = fmt;\n};\n\n\n</script>\n\n<p class=\"site-copyright\">&copy; 2026 KANKOSHA Co., Ltd.</p>\n</body>\n</html>\n","finalUrl":"https://map.jp/support/contactform/shirube/index.php","rendered":false,"_cachedAt":"2026-06-23T20:42:47.601Z"}