{"url":"https://www.icc.co.jp/contact/contact.php?blog_id=medical","html":"<!DOCTYPE HTML>\n<html lang=\"ja\">\n<head id=\"wrap\">\n<title>医療に関するお問い合わせ｜お問い合わせ｜ICC 石川コンピュータ・センター</title>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"initial-scale=1.0,width=device-width,user-scalable=no\">\n<link href=\"/common/images/favicon.png\" rel=\"icon\" type=\"image/png\" />\n<link href=\"/common/images/favicon.ico\" rel=\"shortcut icon\" />\n<link rel=\"stylesheet\" href=\"/common/css/reset.css?date=20190805034616\" />\n<link rel=\"stylesheet\" href=\"/common/css/bootstrap-grid.css?date=20190805034616\" />\n<link rel=\"stylesheet\" href=\"/common/css/slider-pro.css?date=20190805034616\" />\n<link rel=\"stylesheet\" href=\"/common/css/common.css?date=20190805034616\" />\n<script src=\"/common/js/jquery.min.js?date=20190805034616\" ></script>\n<script src=\"/common/js/bootstrap.js?date=20190805034616\" ></script>\n<script src=\"/common/js/jquery.sliderPro.js?date=20190805034616\" ></script>\n<script src=\"/common/js/common.js?date=20190805034616\" ></script>\n<script src=\"/common/js/footerFixed.js?date=20190805034616\" ></script>\n<script src=\"/common/js/ajaxzip3.js?date=20190805034616\" ></script>\n<script type=\"text/javascript\">var Kairos3Tracker = \"iccmktg\"</script><script type=\"text/javascript\" charset=\"utf-8\" src=\"//c.k3r.jp\"></script>\n<script type=\"text/javascript\">\n$(function () {\n\t// 読み込み時、エラー表示DIVclassで全初期化（非表示）\n\t$(\".error_message\").css(\"display\",\"none\");\n});\n// 入力チェック\nfunction chk_form(blog_type){\n\tvar form = document.forms[\"form1\"];\n\tvar error_flg = \"0\";\n\t\n\t// エラー表示DIVclassで全初期化（非表示）\n\t$(\".error_message\").css(\"display\",\"none\");\n\t\n\t//----------------------------\n\t// 全フォーム共通のチェック（未入力チェック）\n\t//----------------------------\n\t// 個人情報に同意する\n\tif(form.elements[\"chk_agree\"].checked == false){\n\t\terror_flg = \"1\";\n\t\t$(\"#id_chk_agree\").css(\"display\",\"block\");\n\t\t$(\"#id_chk_agree\").html(\"個人情報のお取り扱いについて同意されていません\");\n\t}\n\t// 会社名\n\tif(form.elements[\"txt_company\"].value == \"\"){\n\t\terror_flg = \"1\";\n\t\t$(\"#id_txt_company\").css(\"display\",\"block\");\n\t\t$(\"#id_txt_company\").html(\"会社名を入力してください\");\n\t}\n\t// 部署名\n\tif(form.elements[\"txt_section\"].value == \"\"){\n\t\terror_flg = \"1\";\n\t\t$(\"#id_txt_section\").css(\"display\",\"block\");\n\t\t$(\"#id_txt_section\").html(\"部署名を入力してください\");\n\t}\n\t// 氏名（漢字）\n\tif(form.elements[\"txt_name1\"].value == \"\" || form.elements[\"txt_name2\"].value == \"\"){\n\t\terror_flg = \"1\";\n\t\t$(\"#id_txt_name\").css(\"display\",\"block\");\n\t\t$(\"#id_txt_name\").html(\"氏名（漢字）を入力してください\");\n\t}\n\t// フリガナ\n\tif(form.elements[\"txt_kana1\"].value == \"\" || form.elements[\"txt_kana2\"].value == \"\"){\n\t\terror_flg = \"1\";\n\t\t$(\"#id_txt_kana\").css(\"display\",\"block\");\n\t\t$(\"#id_txt_kana\").html(\"フリガナを入力してください\");\n\t}\n\t// 郵便番号\n\tif(form.elements[\"txt_zip1\"].value == \"\" || form.elements[\"txt_zip2\"].value == \"\"){\n\t\terror_flg = \"1\";\n\t\t$(\"#id_txt_zip\").css(\"display\",\"block\");\n\t\t$(\"#id_txt_zip\").html(\"郵便番号を入力してください\");\n\t}\n\t// 都道府県\n\tif(form.elements[\"sel_pref\"].value == \"\"){\n\t\terror_flg = \"1\";\n\t\t$(\"#id_sel_pref\").css(\"display\",\"block\");\n\t\t$(\"#id_sel_pref\").html(\"都道府県を選択してください\");\n\t}\n\t// 住所\n\tif(form.elements[\"txt_address1\"].value == \"\"){\n\t\terror_flg = \"1\";\n\t\t$(\"#id_txt_address1\").css(\"display\",\"block\");\n\t\t$(\"#id_txt_address1\").html(\"住所を入力してください\");\n\t}\n\t// 電話番号\n\tif(form.elements[\"txt_tel1\"].value == \"\" || form.elements[\"txt_tel2\"].value == \"\" || form.elements[\"txt_tel3\"].value == \"\"){\n\t\terror_flg = \"1\";\n\t\t$(\"#id_txt_tel\").css(\"display\",\"block\");\n\t\t$(\"#id_txt_tel\").html(\"電話番号を入力してください\");\n\t}\n\t// メールアドレス\n\tif(form.elements[\"txt_mail\"].value == \"\"){\n\t\terror_flg = \"1\";\n\t\t$(\"#id_txt_mail\").css(\"display\",\"block\");\n\t\t$(\"#id_txt_mail\").html(\"メールアドレスを入力してください\");\n\t}\n\t// メールアドレス（確認）\n\tif(form.elements[\"txt_mail_confirm\"].value == \"\"){\n\t\terror_flg = \"1\";\n\t\t$(\"#id_txt_mail_confirm\").css(\"display\",\"block\");\n\t\t$(\"#id_txt_mail_confirm\").html(\"メールアドレス（確認）を入力してください\");\n\t}\n\t\t// ICCからのご案内について\n\tif(form.elements[\"rad_magazine\"].value == \"\"){\n\t\terror_flg = \"1\";\n\t\t$(\"#id_rad_magazine\").css(\"display\",\"block\");\n\t\t$(\"#id_rad_magazine\").html(\"ICCからのご案内についてを選択してください\");\n\t}\n\t\t//----------------------------\n\t// 全フォーム共通のチェック（形式チェック）\n\t//----------------------------\n\t// フリガナ\n\tif(form.elements[\"txt_kana1\"].value != \"\" && form.elements[\"txt_kana2\"].value != \"\"){\n\t\t//文字列連結\n\t\tvar mix_kana = form.elements[\"txt_kana1\"].value + form.elements[\"txt_kana2\"].value;\n\t\tif(mix_kana.match( /[^0-9ァ-ヶー]+/ )){\n\t\t\terror_flg = \"1\";\n\t\t\t$(\"#id_txt_kana\").css(\"display\",\"block\");\n\t\t\t$(\"#id_txt_kana\").html(\"フリガナは全角カタカナで入力してください\");\n\t\t}\n\t}\n\t// 郵便番号\n\tif(form.elements[\"txt_zip1\"].value != \"\" && form.elements[\"txt_zip2\"].value != \"\"){\n\t\t//文字列連結\n\t\tvar mix_zip = form.elements[\"txt_zip1\"].value + form.elements[\"txt_zip2\"].value;\n\t\tif(mix_zip.match( /[^0-9]+/ )){\n\t\t\terror_flg = \"1\";\n\t\t\t$(\"#id_txt_zip\").css(\"display\",\"block\");\n\t\t\t$(\"#id_txt_zip\").html(\"郵便番号は半角数字で入力してください\");\n\t\t}\n\t}\n\t// 電話番号\n\tif(form.elements[\"txt_tel1\"].value != \"\" && form.elements[\"txt_tel2\"].value != \"\" && form.elements[\"txt_tel3\"].value != \"\"){\n\t\t//文字列連結\n\t\tvar mix_tel = form.elements[\"txt_tel1\"].value + form.elements[\"txt_tel2\"].value + form.elements[\"txt_tel3\"].value;\n\t\tif(mix_tel.match( /[^0-9]+/ )){\n\t\t\terror_flg = \"1\";\n\t\t\t$(\"#id_txt_tel\").css(\"display\",\"block\");\n\t\t\t$(\"#id_txt_tel\").html(\"電話番号は半角数字で入力してください\");\n\t\t}\n\t}\n\t\t// FAX\n\tif(form.elements[\"txt_fax1\"].value != \"\" && form.elements[\"txt_fax2\"].value != \"\" && form.elements[\"txt_fax3\"].value != \"\"){\n\t\t//文字列連結\n\t\tvar mix_tel = form.elements[\"txt_fax1\"].value + form.elements[\"txt_fax2\"].value + form.elements[\"txt_fax3\"].value;\n\t\tif(mix_tel.match( /[^0-9]+/ )){\n\t\t\terror_flg = \"1\";\n\t\t\t$(\"#id_txt_fax\").css(\"display\",\"block\");\n\t\t\t$(\"#id_txt_fax\").html(\"FAXは半角数字で入力してください\");\n\t\t}\n\t}\n\t// FAX\n\tif(form.elements[\"txt_fax1\"].value != \"\" || form.elements[\"txt_fax2\"].value != \"\" || form.elements[\"txt_fax3\"].value != \"\"){\n\t\tif(form.elements[\"txt_fax1\"].value == \"\" || form.elements[\"txt_fax2\"].value == \"\" || form.elements[\"txt_fax3\"].value == \"\"){\n\t\t\terror_flg = \"1\";\n\t\t\t$(\"#id_txt_fax\").css(\"display\",\"block\");\n\t\t\t$(\"#id_txt_fax\").html(\"FAXの入力が不完全です\");\n\t\t}\n\t}\n\t\t// メールアドレスの比較\n\tif(form.elements[\"txt_mail\"].value != \"\" && form.elements[\"txt_mail_confirm\"].value != \"\"){\n\t\t//前後の空白をチェック\n\t\tif(form.elements[\"txt_mail\"].value != form.elements[\"txt_mail_confirm\"].value){\n\t\t\terror_flg = \"1\";\n\t\t\t$(\"#id_txt_mail\").css(\"display\",\"block\");\n\t\t\t$(\"#id_txt_mail\").html(\"確認用メールアドレスと異なります\");\n\t\t}\n\t}\n\t// メールアドレス\n\tif(form.elements[\"txt_mail\"].value != \"\"){\n\t\t//前後の空白をチェック\n\t\tif(form.elements[\"txt_mail\"].value.match(/^\\s+|\\s+$/g)){\n\t\t\terror_flg = \"1\";\n\t\t\t$(\"#id_txt_mail\").css(\"display\",\"block\");\n\t\t\t$(\"#id_txt_mail\").html(\"メールアドレスの前後にスペースは入力できません\");\n\t\t}else if(!form.elements[\"txt_mail\"].value.match(/.+@.+\\..+/)){\n\t\t\terror_flg = \"1\";\n\t\t\t$(\"#id_txt_mail\").css(\"display\",\"block\");\n\t\t\t$(\"#id_txt_mail\").html(\"メールアドレスはメールアドレスの形式で入力してください\");\n\t\t}\n\t}\n\t// メールアドレス（確認）\n\tif(form.elements[\"txt_mail_confirm\"].value != \"\"){\n\t\t//前後の空白をチェック\n\t\tif(form.elements[\"txt_mail_confirm\"].value.match(/^\\s+|\\s+$/g)){\n\t\t\terror_flg = \"1\";\n\t\t\t$(\"#id_txt_mail_confirm\").css(\"display\",\"block\");\n\t\t\t$(\"#id_txt_mail_confirm\").html(\"メールアドレスの前後にスペースは入力できません\");\n\t\t}else if(!form.elements[\"txt_mail_confirm\"].value.match(/.+@.+\\..+/)){\n\t\t\terror_flg = \"1\";\n\t\t\t$(\"#id_txt_mail_confirm\").css(\"display\",\"block\");\n\t\t\t$(\"#id_txt_mail_confirm\").html(\"メールアドレスはメールアドレスの形式で入力してください\");\n\t\t}\n\t}\n\t\n\t//----------------------------\n\t// フォーム毎のチェックボックス値取得\n\t//----------------------------\n\t// 初期化\n\tvar checkbox01_txt = \"\";\n\tvar checkbox02_txt = \"\";\n\t// 製品情報\n\tif(form.elements[\"checkbox01\"]){\n\t\tfor (var i = 0;i < form.elements[\"checkbox01\"].length; i++){\n\t\t\tif (form.elements[\"checkbox01\"][i].checked){\n\t\t\t\tif(checkbox01_txt == \"\"){\n\t\t\t\t\tcheckbox01_txt += form.elements[\"checkbox01\"][i].value;\n\t\t\t\t}else{\n\t\t\t\t\tcheckbox01_txt += \",\" + form.elements[\"checkbox01\"][i].value;\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\t\t// お問い合わせ内容\n\tif(form.elements[\"checkbox02\"]){\n\t\tfor (var i = 0;i < form.elements[\"checkbox02\"].length; i++){\n\t\t\tif (form.elements[\"checkbox02\"][i].checked){\n\t\t\t\tif(checkbox02_txt == \"\"){\n\t\t\t\t\tcheckbox02_txt += form.elements[\"checkbox02\"][i].value;\n\t\t\t\t}else{\n\t\t\t\t\tcheckbox02_txt += \",\" + form.elements[\"checkbox02\"][i].value;\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\t// エラー表示\n\tif(error_flg == \"1\"){\n\t\t$(\"#id_error_message\").css(\"display\",\"block\");\t\t// エラーメッセージ表示\n\t\t$('body,html').animate({\n\t\t\tscrollTop: 0\n\t\t}, 500);\n\t\treturn false;\n\t}else{\n\t// 正常（確認画面へ）\n\t\t$(\"#id_error_message\").css(\"display\",\"none\");\n\t\t// チェックボックス1(製品・サービス)と2(お問い合わせ内容)の値を格納\n\t\tform.elements[\"hid_checkbox01\"].value = checkbox01_txt;\n\t\tform.elements[\"hid_checkbox02\"].value = checkbox02_txt;\n\t\tform1.submit();\n\t}\n}\n//通常submit\nfunction send_form(f_action){\n\tform1.action = f_action;\n\tform1.submit();\n}\n</script>\n<style type='text/css'>\nh1, h4, .contact-submit{\n\tbackground:#16a1b4 !important;\n}\nh2{\n\tbackground-image:url(/common/images/bar_midashi_medical.gif) !important;\n}\nh5{\n\tcolor:#16a1b4 !important;\n}\ntable.tbl-contact tr th{\n\tbackground:#edfbfd !important;\n}\n</style><meta name='description' content='ICCのお問い合わせページです。医療向けサービス、製品に関するお問い合せを、インターネット利用のお問い合せフォームとお電話で対応しています。'></head>\n<body>\n<header>\n                <!-- pc_header -->\n                <div class=\"header-area d-none d-sm-block\">\n                    <a href=\"/\" style=\"float:left;\"><img src=\"/common/images/logo.png\" width=\"250\" alt=\"ICCロゴ\" /></a>\n                        <div class=\"global-navi-area\">\n                            <label id=\"id_font_large\" class=\"chg-font-off\">大</label>\n                            <label id=\"id_font_default\" class=\"chg-font-on\">標準</label>\n\n                            <form method=\"get\" id=\"search\" action=\"https://www.icc.co.jp/cgi-bin/uwnb5u9z44p3/dcc57kpu.cgi\" style=\"display:inline;\">\n                                <input type=\"text\" name=\"search\" value=\"\" class=\"txt-search-area\" placeholder=\"サイト内検索\">\n                                <input class=\"submit\" src=\"/common/images/icon_search.png\" type=\"image\" value=\"\" />\n                                <input type=\"hidden\" name=\"IncludeBlogs\" value=\"all\">\n                            </form>\n\n                            <a href=\"/en/\" class=\"btn-language\">English</a>\n                        </div>\n                        <div class=\"global-menu-area\">\n                            <a href=\"/\">HOME</a>|<a href=\"/product.html\">ソリューション・製品</a>|<a href=\"/casestudy/\">導入事例</a>|<a href=\"/exhibition/\">展示会・セミナー</a>|<a href=\"/company/\">会社情報</a>|<a href=\"/employment/\">採用情報</a>|<a href=\"/contact/\">お問い合わせ</a>\n                        </div>\n                </div>\n                <!-- mobile_header -->\n                <div class=\"d-block d-sm-none\">\n                    <a href=\"/\"><img src=\"/common/images/logo.png\" width=\"220\" height=\"45\" alt=\"ICCロゴ\" /></a>\n                    <div id=\"nav-toggle\">\n                    