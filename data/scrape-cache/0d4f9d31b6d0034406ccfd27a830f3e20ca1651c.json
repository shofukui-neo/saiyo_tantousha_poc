n  $(function () {\n    const $header = $('.header');\n\n    $('.btn-border').on('click', () => $header.toggleClass('is-active'));\n\n    $('.menu-wrapper a[href^=\"#\"]').on('click', function (e) {\n      const $target = $($(this).attr('href'));\n      if ($target.length) {\n        e.preventDefault();\n        $header.removeClass('is-active');\n        $('html, body').animate({ scrollTop: $target.offset().top }, 500);\n      }\n    });\n  });\n</script> -->\n\n<script>\n  $(function () {\n    const $header = $('.header');\n\n    // ハンバーガーメニューの開閉\n    $('.btn-border').on('click', () => $header.toggleClass('is-active'));\n\n    // メニュー内の「#」が含まれるリンクすべてに対応\n    $('.menu-wrapper a[href*=\"#\"]').on('click', function (e) {\n      const href = $(this).attr('href');\n      const hashIndex = href.indexOf('#');\n      const hasHash = hashIndex !== -1;\n\n      if (hasHash) {\n        const path = href.substring(0, hashIndex);\n        const hash = href.substring(hashIndex);\n        const currentPath = location.pathname.replace(/\\/$/, '');\n\n        // 同じページ内へのアンカーか確認\n        if (location.pathname.endsWith(path.replace(/\\/$/, ''))) {\n          const $target = $(hash);\n          if ($target.length) {\n            e.preventDefault();\n            $('html, body').animate({ scrollTop: $target.offset().top }, 500);\n          }\n        }\n      }\n\n      // いずれにしてもメニューは閉じる\n      $header.removeClass('is-active');\n    });\n  });\n</script>\n\n\n<!-- 同ページ内でアンカーリンククリック時に、ハンバーガーメニュー閉じないのに対応 -->\n<!-- <script>\n\t$(function(){\n\t\tvar state = false;\n\t\t$('.menu-wrapper a').click(function(e){\n\t\t\t$header.removeClass('is-active');\n\t\t});\n\t});\n</script> -->\n\n<!-- ギミックの兼ね合いで、/about/index.htmlでは読み込まない。 -->\n\n<script>\n  $(function () {\n    $('a[href^=\"#\"]').click(function (e) {\n      e.preventDefault();\n      var speed = 500;\n      var href = $(this).attr('href');\n      var target = $(href);\n      if (target.length) {\n        var position = target.offset().top;\n        $('html, body').animate({ scrollTop: position }, speed, 'swing');\n      }\n    });\n  });\n</script>\n\n\n\n<script>\n\t$(window).on('load scroll resize', function(){\n\t\tvar scroll = $(window).scrollTop();\n\t\tvar windowHeight = $(window).height();\n\t\t$('.trigger').each(function(){\n\t\t\tvar imgPos = $(this).offset().top;\n\t\t\tif (scroll > imgPos - windowHeight + windowHeight / 3){\n\t\t\t\t$(this).addClass('is-show');\n\t\t\t// } else {\n\t\t\t// \t$(this).removeClass('is-show');\n\t\t\t}\n\t\t});\n\t});\n</script>\n\n<script>\n  document.addEventListener('DOMContentLoaded', () => {\n    const items = document.querySelectorAll('.link-list li');\n\n    document.addEventListener('click', () => {\n      items.forEach(i => i.classList.remove('is-active'));\n    });\n\n    items.forEach(item => {\n      item.addEventListener('click', e => {\n        e.stopPropagation();\n        if (item.classList.contains('is-active')) {\n          item.classList.remove('is-active');\n        } else {\n          items.forEach(i => i.classList.remove('is-active'));\n          item.classList.add('is-active');\n        }\n      });\n    });\n  });\n</script>\n\n\n\n\t\n</body>\n</html>","finalUrl":"https://www.itx-corp.co.jp/recruit/environment/growth-story.html","rendered":false,"_cachedAt":"2026-06-22T22:24:45.808Z"}