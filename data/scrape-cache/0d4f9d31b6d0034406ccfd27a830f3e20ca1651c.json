11.5,3.8-11.5,9.2,4,9.7,14.8,16.2c9,5.4,26.6,16.9,26.6,38s-14.4,40.3-45,40.3-31.3-9.5-34.7-13.9c-1.4-1.8-1.1-3.4,0-5Z\"/>\n\t\t\t\t\t<path class=\"st1 tex02\" d=\"M858.4,31h-22c-1.8,0-2.9-1.6-2.7-3.4l2.9-19.6c.2-1.8,1.8-3.4,3.4-3.4h72.7c1.8,0,2.9,1.6,2.7,3.4l-2.9,19.6c-.2,1.8-1.6,3.4-3.4,3.4h-22.1l-13.5,96.1c-.2,1.8-2,3.4-3.6,3.4h-22.3c-1.6,0-2.9-1.6-2.7-3.4l13.5-96.1Z\"/>\n\t\t\t\t\t<path class=\"st1 tex02\" d=\"M977.7,2.7c27.9,0,50.2,25.2,50.2,56.3s-29.9,73.3-67.7,73.3-50.2-24.8-50.2-55.8S940.3,2.7,977.7,2.7ZM998.4,62.5c0-16.9-10.1-31-24.5-31s-34.4,18.9-34.4,41.2,10.1,30.8,24.3,30.8,34.6-18.7,34.6-41Z\"/>\n\t\t\t\t\t<path class=\"st1 tex02\" d=\"M1053.4,7.9c.2-1.8,1.8-3.4,3.4-3.4h48.6c18.9,0,31.7,15.3,31.7,33.8s-11,35.5-29.5,41.2l15.7,45.7c.9,2.3-.7,5.2-3.4,5.2h-23.2c-1.3,0-2.3-.7-2.5-1.6l-14.8-47.7h-7.9l-6.5,45.9c-.2,1.8-1.8,3.4-3.4,3.4h-22.3c-1.8,0-2.9-1.6-2.5-3.4l16.7-119.2ZM1094.3,58.3c8.5,0,14.6-7.9,14.6-16.6s-3.2-11.5-9.7-11.5h-20.7l-4,28.1h19.8Z\"/>\n\t\t\t\t\t<path class=\"st1 tex02\" d=\"M1168.8,69.8l-26.6-60.1c-.9-2.3.7-5.2,3.2-5.2h22.7c1.4,0,2.2.7,2.5,1.6l14.9,36.9,25.4-36.9c.5-.7,1.3-1.6,2.9-1.6h25.4c2.7,0,3.6,2.9,2,5.2l-44.1,59.9-7.9,57.4c-.2,1.8-2,3.4-3.6,3.4h-22.3c-1.8,0-2.7-1.6-2.5-3.4l8.1-57.2Z\"/>\n\t\t\t\t\t</svg>\n\t\t\t\t\t<span class=\"jp-copy\">新卒スタッフの1年の成長ストーリー</span>\n\t\t\t\t</h3>\n\t\t\t</div>\n\t\t</div>\n\n\t\t<div class=\"anchor-position\" id=\"growth-story01\"></div>\n\t\t<div class=\"content-section\">\n\t\t\t<div class=\"growth-story-bg-inner story01\">\n\t\t\t\t<h4 class=\"growth-story-title\">メンター制度について</h4>\n\t\t\t\t<div class=\"column-wrapper trigger\">\n\t\t\t\t\t<div class=\"text-box\">\n\t\t\t\t\t\t<p class=\"bg-copy\">\n\t\t\t\t\t\t\t<span>傍で見守り、</span><br>\n\t\t\t\t\t\t\t<span>長期的に心の支えとなる存在</span>\n\t\t\t\t\t\t</p>\n\t\t\t\t\t\t<p class=\"text\">\n\t\t\t\t\t\t\t学生から社会人へのギャップと戦う新入社員にとっての精神的な柱となり、お客様軸で考えることができるように導く存在として「メンター制度」を取り入れています。<br>新入社員の不安や悩みに寄り添いながら、楽しんで仕事をしていただけるようサポートします。\n\t\t\t\t\t\t</p>\n\t\t\t\t\t\t<div class=\"img-wrap\">\n\t\t\t\t\t\t\t<div class=\"box\">\n\t\t\t\t\t\t\t\t<img src=\"../assets/images/environment/growth-story-story01-img01.webp\" alt=\"\">\n\t\t\t\t\t\t\t\t<p class=\"caption\">先輩がメンターとしてサポート。すぐ相談ができて安心♪</p>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t<div class=\"box\">\n\t\t\t\t\t\t\t\t<img src=\"../assets/images/environment/growth-story-story01-img02.webp\" alt=\"\">\n\t\t\t\t\t\t\t\t<p class=\"caption\">ONもOFFも共に楽しめる、心強い先輩とのつながり！</p>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t\t<div class=\"img-box\">\n\t\t\t\t\t\t<img src=\"../assets/images/environment/growth-story-story01-img03.webp\" alt=\"\">\n\t\t\t\t\t\t<p class=\"bg-text\">\n\t\t\t\t\t\t\tメンターは定期的な面談やコミュニケーションを通じて、メンティー（育成を受ける側）が抱えている不安や悩みを聞いて一緒に解決策を考え、挑戦を全力で後押しをしてくれます。\n\t\t\t\t\t\t</p>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t\t<dl class=\"comment-wrapper trigger\">\n\t\t\t\t\t<dt>\n\t\t\t\t\t\t<!-- <p class=\"caption-arch\">HR部 育成グループ長</p> -->\n\t\t\t\t\t\t<img src=\"../assets/images/environment/growth-story-story01-img04.webp\" alt=\"\">\n\t\t\t\t\t</dt>\n\t\t\t\t\t<dd>\n\t\t\t\t\t\t<p class=\"midashi\">COMMENT</p>\n\t\t\t\t\t\t<p class=\"bg-text\">\n\t\t\t\t\t\t\t業務を教えるだけの「トレーナー」ではなく、当社は長期的に心の支えとなる「メンター」を導入することにより、業務の育成は店舗全体で関わりを持つことを促し、新入社員の方がより学びやすい環境を整えています。\n\t\t\t\t\t\t</p>\n\t\t\t\t\t</dd>\n\t\t\t\t</dl>\n\t\t\t</div>\n\n\t\t\t<div class=\"growth-story-bg-inner story02\">\n\t\t\t\t<h4 class=\"growth-story-title\">ペア販買・フォロー販買</h4>\n\t\t\t\t<div class=\"column-wrapper trigger\">\n\t\t\t\t\t<div class=\"text-box\">\n\t\t\t\t\t\t<p class=\"bg-copy\">\n\t\t\t\t\t\t\t<span>先輩の応対を参考に、</span><br>\n\t\t\t\t\t\t\t<span>一人前になるための第一歩</span>\n\t\t\t\t\t\t</p>\n\t\t\t\t\t\t<p class=\"text\">\n\t\t\t\t\t\t\t先輩スタッフの応対を後ろで見て、「接客の姿勢」や「ご紹介トーク」などを学んで貰う『ペア販買』と、新人スタッフの応対を先輩スタッフが近くで見守り、分からない所や行き詰っている様子を見かけた際に、フォローに入り接客の手助けをする『フォロー販買』で仕事のやり方を身につけます。\n\t\t\t\t\t\t</p>\n\t\t\t\t\t\t<div class=\"img-wrap\">\n\t\t\t\t\t\t\t<div class=\"box\">\n\t\t\t\t\t\t\t\t<img src=\"../assets/images/environment/growth-story-story02-img01.webp\" alt=\"\">\n\t\t\t\t\t\t\t\t<p class=\"caption\">応対の見学から、必要に応じて応対後の振り返りも。</p>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t<div class=\"box\">\n\t\t\t\t\t\t\t\t<img src=\"../assets/images/environment/growth-story-story02-img02.webp\" alt=\"\">\n\t\t\t\t\t\t\t\t<p class=\"caption\">インカムを使用して、応対中に連携を取ることもできます。</p>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t\t<div class=\"img-box\">\n\t\t\t\t\t\t<img src=\"../assets/images/environment/growth-story-story02-img03.webp\" alt=\"\">\n\t\t\t\t\t\t<p class=\"bg-text\">\n\t\t\t\t\t\t\t上手く応対できた時はたくさん褒め、上手くでき出来なかったとしても、すぐフォローしてくれます。上手くいかなかった理由を考え、次に向けて一緒にトレーニングしています。\n\t\t\t\t\t\t</p>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t\t<dl class=\"comment-wrapper trigger\">\n\t\t\t\t\t<dt>\n\t\t\t\t\t\t<!-- <p class=\"caption-arch\">HR部 育成グループ長</p> -->\n\t\t\t\t\t\t<img src=\"../assets/images/environment/growth-story-story02-img04.webp\" alt=\"\">\n\t\t\t\t\t</dt>\n\t\t\t\t\t<dd>\n\t\t\t\t\t\t<p class=\"midashi\">COMMENT</p>\n\t\t\t\t\t\t<p class=\"bg-text\">\n\t\t\t\t\t\t\t最初はペア販買でお客様とどのように話しているかを注目し、知識が増えてきたらどのようにご紹介しているかの流れやトークを学びます。そして、今まで見たものを今度は自分で実践していくというのが基本的な流れです。\n\t\t\t\t\t\t</p>\n\t\t\t\t\t</dd>\n\t\t\t\t</dl>\n\t\t\t</div>\n\n\t\t\t<div class=\"growth-story-bg-inner story03\">\n\t\t\t\t<h4 class=\"growth-story-title\">ロールプレイング</h4>\n\t\t\t\t<div class=\"column-wrapper trigger\">\n\t\t\t\t\t<div class=\"text-box\">\n\t\t\t\t\t\t<p class=\"bg-copy\">\n\t\t\t\t\t\t\t<span>苦手を得意に、得意を自信に。</span><br>\n\t\t\t\t\t\t\t<span>練習を重ねた回数だけ</span>\n\t\t\t\t\t\t\t<span>自信に変わる。</span>\n\t\t\t\t\t\t</p>\n\t\t\t\t\t\t<p class=\"text\">\n\t\t\t\t\t\t\t商品やサービスについての知識やトーク習得はもちろん、接客態度やお客様とのコミュニケーションの取り方など、先輩社員がお客様役になり、実際の接客に近い状態で学んでいただきます。また、たくさん練習をする事で新入社員の方が自信を持ってお客様対応ができるように事前準備をしています。\n\t\t\t\t\t\t</p>\n\t\t\t\t\t\t<div class=\"img-wrap\">\n\t\t\t\t\t\t\t<div class=\"box\">\n\t\t\t\t\t\t\t\t<img src=\"../assets/images/environment/growth-story-story03-img01.webp\" alt=\"\">\n\t\t\t\t\t\t\t\t<p class=\"caption\">私たちが取り扱う商材は、携帯電話以外にも様々！</p>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t<div class=\"box\">\n\t\t\t\t\t\t\t\t<img src=\"../assets/images/environment/growth-story-story03-img02.webp\" alt=\"\">\n\t\t\t\t\t\t\t\t<p class=\"caption\">実際の窓口でロープレをすることもあります。臨場感抜群！</p>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t\t<div class=\"img-box\">\n\t\t\t\t\t\t<img src=\"../assets/images/environment/growth-story-story03-img03.webp\" alt=\"\">\n\t\t\t\t\t\t<p class=\"bg-text\">\n\t\t\t\t\t\t\t練習だから、間違えても上手く言葉がまとまらなくてもOK！上手く出来るようにするためのロープレです。事前に考えてきたものを先輩に見て貰って、ブラッシュアップして本番に臨みましょう。\n\t\t\t\t\t\t</p>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t\t<dl class=\"comment-wrapper trigger\">\n\t\t\t\t\t<dt>\n\t\t\t\t\t\t<!-- <p class=\"caption-arch\">HR部 育成グループ長</p> -->\n\t\t\t\t\t\t<img src=\"../assets/images/environment/growth-story-story03-img04.webp\" alt=\"\">\n\t\t\t\t\t</dt>\n\t\t\t\t\t<dd>\n\t\t\t\t\t\t<p class=\"midashi\">COMMENT</p>\n\t\t\t\t\t\t<p class=\"bg-text\">\n\t\t\t\t\t\t\tロープレは新入社員の方だけではなく、新サービスの提供時や成長のため、全ての社員が日常的にロープレを行い、お客様対応の質を高める努力をしていただいています。練習の数が自信に繋がるので、時間を見つけてどんどん実践あるのみ。\n\t\t\t\t\t\t</p>\n\t\t\t\t\t</dd>\n\t\t\t\t</dl>\n\t\t\t</div>\n\n\t\t\t<div class=\"growth-story-bg-inner story04\">\n\t\t\t\t<h4 class=\"growth-story-title\">日報</h4>\n\t\t\t\t<div class=\"column-wrapper trigger\">\n\t\t\t\t\t<div class=\"text-box\">\n\t\t\t\t\t\t<p class=\"bg-copy\">\n\t\t\t\t\t\t\t<span>毎日の振り返りが成長への近道。</span><br>\n\t\t\t\t\t\t\t<span>コミュニケーションツールとしても、</span><br>\n\t\t\t\t\t\t\t<span>モチベーション向上へ繋げる</span>\n\t\t\t\t\t\t</p>\n\t\t\t\t\t\t<p class=\"text\">\n\t\t\t\t\t\t\t当社では、その日の自分を振り返り、反省や気づきを記録して個人の成長に繋げることを目的に、「日報」を活用しています。<br>また、面と向かっては伝えにくい疑問や悩みも、日報というツールを活用する事で、店舗内のスタッフ間で共有する事ができます。\n\t\t\t\t\t\t</p>\n\t\t\t\t\t\t<div class=\"img-wrap\">\n\t\t\t\t\t\t\t<div class=\"box\">\n\t\t\t\t\t\t\t\t<img src=\"../assets/images/environment/growth-story-story04-img01.webp\" alt=\"\">\n\t\t\t\t\t\t\t\t<p class=\"caption\">社員全員、出勤した日には必ず日報を記載しています。</p>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t<div class=\"box\">\n\t\t\t\t\t\t\t\t<img src=\"../assets/images/environment/growth-story-story04-img02.webp\" alt=\"\">\n\t\t\t\t\t\t\t\t<p class=\"caption\">日報以外にも、社内チャットや独自AIなど、便利ツールも色々！</p>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t\t<div class=\"img-box\">\n\t\t\t\t\t\t<img src=\"../assets/images/environment/growth-story-story04-img03.webp\" alt=\"\">\n\t\t\t\t\t\t<p class=\"bg-text\">\n\t\t\t\t\t\t\t日報はお互いにコメントをし合うことができるので、上手くいかなかった日には先輩から励ましのコメントが書かれることも。店舗スタッフ全員が新入社員の皆さんを気にかけています！\n\t\t\t\t\t\t</p>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t\t<dl class=\"comment-wrapper trigger\">\n\t\t\t\t\t<dt>\n\t\t\t\t\t\t<!-- <p class=\"caption-arch\">HR部 育成グループ長</p> -->\n\t\t\t\t\t\t<img src=\"../assets/images/environment/growth-story-story04-img04.webp\" alt=\"\">\n\t\t\t\t\t</dt>\n\t\t\t\t\t<dd>\n\t\t\t\t\t\t<p class=\"midashi\">COMMENT</p>\n\t\t\t\t\t\t<p class=\"bg-text\">\n\t\t\t\t\t\t\tエースコンサルタント(お客様対応の手本となる役職)の方の日報も公開されているので、様々なノウハウや好事例を学ぶことが出来ます。また、AIを使った当社独自システム「AIコンサル」がリリースされ、お客様対応で困った時の自己学習のツールが充実しています。\n\t\t\t\t\t\t</p>\n\t\t\t\t\t</dd>\n\t\t\t\t</dl>\n\t\t\t</div>\n\n\t\t\t<div class=\"growth-story-bg-inner story05\">\n\t\t\t\t<h4 class=\"growth-story-en-title trigger\">GROW UP!</h4>\n\t\t\t\t<div class=\"column-wrapper trigger\">\n\t\t\t\t\t<div class=\"text-box\">\n\t\t\t\t\t\t<p class=\"bg-copy white\">\n\t\t\t\t\t\t\t<span>喜ばれる人財を目指して、</span><br>\n\t\t\t\t\t\t\t<span>輝く方法は無限大！</span>\n\t\t\t\t\t\t</p>\n\t\t\t\t\t\t<p class=\"text white\">\n\t\t\t\t\t\t\t弊社ロゴの「X」には、無限を意味する「∞」が含まれています。新入社員の成長する姿は、先輩社員にとっても自分のことのように嬉しく、時に刺激を与えてくれる存在にもなります。この成長のサイクルを進めていくことこそ、仲間と共に『永遠の成長』をしていくための秘訣です。\n\t\t\t\t\t\t</p>\n\t\t\t\t\t</div>\n\t\t\t\t\t<div class=\"img-box\">\n\t\t\t\t\t\t<img src=\"../assets/images/environment/growth-story-story05-img01.webp\" alt=\"\">\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\n\t\t\t<div class=\"growth-story-bg-inner story06\">\n\t\t\t\t<h4 class=\"growth-story-img-title\">\n\t\t\t\t\t<img src=\"../assets/images/environment/growth-story-story06-img01.webp\" alt=\"\">\n\t\t\t\t</h4>\n\t\t\t\t<div class=\"column-wrapper trigger\">\n\t\t\t\t\t<div class=\"text-box\">\n\t\t\t\t\t\t<div class=\"title-column\">\n\t\t\t\t\t\t\t<img src=\"../assets/images/environment/growth-story-story06-img02.webp\" alt=\"\">\n\t\t\t\t\t\t\t<p class=\"bg-copy\">\n\t\t\t\t\t\t\t\t<span>色んなところに</span><br>\n\t\t\t\t\t\t\t\t<span>出かけることを</span><br>\n\t\t\t\t\t\t\t\t<span>楽しんでます！</span>\n\t\t\t\t\t\t\t</p>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t\t<p class=\"text\">\n\t\t\t\t\t\t\t元々出かけることは好きで、社会人になったことで旅行をする頻度が増えましたね。リフレッシュにもなりますし、頑張っている自分へのご褒美にもなっています。近いうちに韓国にも遊びに行く予定です！\n\t\t\t\t\t\t</p>\n\t\t\t\t\t</div>\n\t\t\t\t\t<div class=\"img-box\">\n\t\t\t\t\t\t<img src=\"../assets/images/environment/growth-story-story06-img03.webp\" alt=\"\">\n\t\t\t\t\t\t<p class=\"bg-text\">\n\t\t\t\t\t\t\t一見、誰かわからないかもしれませんが、スノーボードを楽しんでいる時の私です。\n\t\t\t\t\t\t</p>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\n\t\t<div class=\"content-section\">\n\t\t\t<div class=\"content-inner\">\n\t\t\t\t<div class=\"environment-common-instagram-content\">\n\t<a href=\"https://www.instagram.com/itx.saiyou/\" target=\"_blank\" class=\"column-box\">\n\t\t<img src=\"../assets/images/environment/common-instagram-img.webp\" alt=\"\">\n\t\t<p class=\"bg-circle\">\n\t\t\tInstagramで<br>\n\t\t\t新卒スタッフの<br>\n\t\t\t奮闘ぶりを<br>\n\t\t\tチェック！\n\t\t</p>\n\t</a>\n\t<a href=\"https://www.instagram.com/itx.saiyou/\" target=\"_blank\" class=\"instagram-link\">\n\t\t<p class=\"bg-text\">ITXの採用Instagramはこちら</p>\n\t</a>\n</div>\n\t\t\t</div>\n\t\t</div>\n\n\n\n\t</div>\n\n\t<div class=\"footer-recruit-content\">\n\t<ul class=\"recruit-link-list\">\n\t\t<li>\n\t\t\t<a href=\"../recruitment/\">\n\t\t\t\t<p class=\"title\">新卒採用</p>\n\t\t\t\t<div class=\"img-box\">\n\t\t\t\t\t<img src=\"../assets/images/common/footer-link-img01.webp\" alt=\"\">\n\t\t\t\t</div>\n\t\t\t</a>\n\t\t</li>\n\t\t<li>\n\t\t\t<a href=\"..