ute; left: 0; right: 0; top: 10px; }\n#wrapper #header #menuNav li.sns { position: absolute; }\n#wrapper #header #menuNav li.sns::before { content: none; }\n#menuNav .sns strong { display: none; }\n#menuNav .sns div { display: flex; }\n#menuNav .sns a { margin-left: 16px; width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; }\n#menuNav .sns img { width: 24px; height: 24px; object-fit: cover; filter: brightness(0) invert(1); }\n#menuNav .sns .ig { background: #d6249f; background: radial-gradient(circle at 30% 107%, #fdf497 0%, #fdf497 5%, #fd5949 45%, #d6249f 60%, #285AEB 90%); }\n#menuNav .sns .x { background: #000; }\n#menuNav .sns .x img { width: 18px; height: 18px; }\n#menuNav .sns .tt img { width: 40px; height: 40px; filter: none; }\n\n@media screen and (max-width: 767px){\n  #wrapper #header #menuNav li:nth-child(5)::after { display: none; }\n  #wrapper #header #menuNav li:nth-child(5) span { padding-right: 0; background: none; }\n  #menuNav .sns { width: 100%; position: static; }\n  #wrapper #header #menuNav li.sns { position: static; border: none; }\n  #menuNav .sns strong { margin: 20px 0 10px; width: 100%; color: #fff; display: block; }\n  #menuNav .sns div { margin: 0 auto; width: 160px; display: flex; justify-content: space-between; }\n  #menuNav .sns a { margin: 0; padding: 0 !important; display: flex !important; }\n}\n</style>  </div>\n\n<!--======================================================\ncontainer\n======================================================-->\n<div id=\"container\" class=\"lower\">\n  <div class=\"widthWrap\">\n    <div id=\"topicPath\" class=\"clearfix\"><ul itemprop=\"breadcrumb\"><li class=\"bcHome\" itemscope itemtype=\"http://data-vocabulary.org/Breadcrumb\"><a href=\"https://www.doramori.co.jp/\" itemprop=\"url\"><span itemprop=\"title\">Home</span></a></li><li>&nbsp;&gt;&nbsp;</li><li itemscope itemtype=\"http://data-vocabulary.org/Breadcrumb\"><a href=\"https://www.doramori.co.jp/recruit/\" itemprop=\"url\"><span itemprop=\"title\">採用情報</span></a></li><li>&nbsp;&gt;&nbsp;</li><li itemscope itemtype=\"http://data-vocabulary.org/Breadcrumb\"><span itemprop=\"title\"><strong>ドラモリの教育</strong></span></li></ul></div>  </div>\n  <div class=\"widthWrap\">\n    <div id=\"content\">\n      <div class=\"inner_margin\">\n                        <h1 class=\"ttl ttl_decoration\"><span>ドラモリの教育</span></h1>\n                <div class=\"wrap\"><img decoding=\"async\" src=\"https://www.doramori.co.jp/wordpress/wp-content/uploads/2025/06/education_head_image.jpg\" alt=\"\" class=\"aligncenter\" /></div>\r\n<h3 class=\"ft_xxxl mt_03 mb_02\"><span style=\"color: #003399;\"><strong>私達の使命・・・健康と美容のお客様サポート</strong></span></h3>\r\n<p class=\"mb_02\"><strong>自己啓発とスキルアップを従業員全員が、高い目的意識をもって実践し、日々の接客に活かすことが大切です。私達は、お客様から喜ばれ、信頼のできる情報提供をおこない、「より健康で、より美しく、より若くて長生き」を実践していきます。</strong></p>\r\n<p><strong>お客様サポートのプロフェッショナルを目指して！</strong></p>\r\n<h2 class=\"ttl mt_02\">入社後ステップ１</h2>\r\n<div class=\"col_from2to1_caption ratio40\">\r\n<div class=\"wrap\">\r\n<h3 class=\"ft_xl mb_01\"><span style=\"color: #003399;\"><strong>☆トレーナー制度</strong></span></h3>\r\n<p class=\"mb_02\">入社後は先輩社員がサポートします。<br /> 小売業のノウハウや業務の相談など、質問しやすい環境で安心です。</p>\r\n</div>\r\n<div class=\"wrap\"><img decoding=\"async\" src=\"https://www.doramori.co.jp/wordpress/wp-content/uploads/2017/09/trainer-1.jpg\" alt=\"\" /></div>\r\n</div>\r\n<div class=\"col_from2to1_caption reverse ratio40 mt_03\">\r\n<div class=\"wrap\"><img decoding=\"async\" src=\"https://www.doramori.co.jp/wordpress/wp-content/uploads/2025/06/beginner_study-1.jpg\" alt=\"\" /></div>\r\n<div class=\"wrap\">\r\n<h3 class=\"ft_xl mb_01\"><span style=\"color: #003399;\"><strong>☆初級基礎勉強会（１年目・２年目正社員全員）<br />毎月開催</strong></span></h3>\r\n<p class=\"mb_02\">体の構造、疾患別の症状、医薬品の基礎知識、漢方の基礎、養生訓（生活アドバイス）などの基礎学習をおこないます。本社、佐賀、熊本、大分、宮崎、鹿児島、長崎、四国、山口、沖縄、宮城にて開催。<!--<br /> ここがドラモリポイント⇒初級基礎勉強会では、勉強会の出席に応じたポイント制を導入し、全てのポイントを取得した方が、次の中級勉強会へすすむことができます。--></p>\r\n</div>\r\n</div>\r\n<div class=\"col_from2to1_caption reverse ratio40\">\r\n<div class=\"wrap\"><img decoding=\"async\" src=\"https://www.doramori.co.jp/wordpress/wp-content/uploads/2025/06/practice.jpg\" alt=\"\" /></div>\r\n<div class=\"wrap\">\r\n<h3 class=\"ft_xl mb_01\"><span style=\"color: #003399;\"><strong>☆合宿研修</strong></span></h3>\r\n<p class=\"mb_02\">接客・マナー実践実習を、入社3年目までに3回合宿研修にておこないます。</p>\r\n<h3 class=\"ft_xl\"><span style=\"color: #003399;\"><strong>☆業務実務研修（１年目正社員全員）</strong></span></h3>\r\n<p class=\"mb_02\">日々の店舗業務の確認をおこないます。</p>\r\n</div>\r\n</div>\r\n<h3 class=\"ft_xl mb_01\"><span style=\"color: #003399;\"><strong>☆登録販売者試験対策勉強会（全従業員）</strong></span></h3>\r\n<p class=\"mb_02\">登録販売者試験対策講座を各地域にて開催します。福岡県（本社、博多、北九州）、大分県、佐賀県（佐賀市、多久市）、熊本県、宮崎県、鹿児島県、沖縄県、山口県、愛媛県、徳島県、長崎県、宮城県の15会場にて開催（受験者、全員合格を目指します）</p>\r\n<p><img decoding=\"async\" src=\"https://www.doramori.co.jp/wordpress/wp-content/uploads/2025/06/qualification-1-1.jpg\" alt=\"\" /></p>\r\n<h2 class=\"ttl mt_02\">ステップ２（日々の学習とスキルアップ）</h2>\r\n<h3 class=\"ft_xl mb_01\"><span style=\"color: #003399;\"><strong>社内中級・上級勉強会（３年目以上の正社員）毎月開催</strong></span></h3>\r\n<p class=\"mb_02\">医薬品、漢方薬、化粧品、介護用品、日用品、食品までのハイレベルの商品知識の取得を目指します。また各メーカー様を招いての専門分野の勉強や、介護用品を目で見て触る実践研修をおこないます。本社、佐賀、熊本、大分、宮崎、鹿児島、長崎、四国、山口、沖縄、宮城にて開催</p>\r\n<p class=\"mb_02\"><img decoding=\"async\" src=\"https://www.doramori.co.jp/wordpress/wp-content/uploads/2025/06/advanced_level.jpg\" alt=\"\" /></p>\r\n<h3 class=\"ft_xl mb_01\"><span style=\"color: #003399;\"><strong>登録販売者実践勉強会（登録販売者パートタイマー・アルバイト）毎月サテライトで実施</strong></span></h3>\r\n<p class=\"mb_02\">登録販売者取得後の実践勉強会として、登録販売者のパートタイマー、アルバイトの方に専門知識の習得をおこないます。医薬品の情報提供をはじめ、適正使用や安全対策について実施。サテライトで実施。</p>\r\n<div class=\"col_from2to1_caption reverse ratio32\">\r\n<div class=\"wrap\"><img decoding=\"async\" class=\"fullSize\" src=\"https://www.doramori.co.jp/wordpress/wp-content/uploads/2025/06/web_pr-1.jpg\" alt=\"\" /></div>\r\n<div class=\"wrap\">\r\n<h3 class=\"ft_xl mb_01\"><span style=\"color: #003399;\"><strong>薬剤師・登録販売者ＷＥＢ勉強会（薬剤師・登録販売者全員）</strong></span></h3>\r\n<p class=\"mb_02\">ＷＥＢ上での各個人のステップアップを目的として、医薬品に共通する特性と基本知識、人体の働きと医薬品、一般用医薬品の作用、薬事に関する法規と制度、一般用医薬品の適正使用、リスク区分の変更、薬剤師、登録販売者の理念、倫理に関する勉強をおこないます。</p>\r\n</div>\r\n</div>\r\n<h2 class=\"ttl mt_02\">ステップ３（専門の職能を活かす）</h2>\r\n<div class=\"col_from2to1_caption reverse ratio32\">\r\n<div class=\"wrap\"><img decoding=\"async\" class=\"fullSize\" src=\"https://www.doramori.co.jp/wordpress/wp-content/uploads/2025/06/makeup_pr.jpg\" alt=\"\" /></div>\r\n<div class=\"wrap\">\r\n<h3 class=\"ft_xl mb_01\"><span style=\"color: #003399;\"><strong>☆ 化粧品地区勉強会</strong></span></h3>\r\n<p class=\"mb_02\">全店対象の化粧品集中勉強会です。化粧品の基礎知識からタッチアップまで、徹底した化粧品のスペシャリスト育成をおこないます。福岡（本社、博多、北九州）、大分、愛媛、熊本、宮城、鹿児島、徳島、山口、長崎、宮崎、沖縄、佐賀にて開催。</p>\r\n</div>\r\n</div>\r\n<h3 class=\"ft_xl mb_01\"><span style=\"color: #003399;\"><strong>☆ 管理栄養士・栄養士全体勉強会</strong></span></h3>\r\n<p class=\"mb_02\">栄養士の育成を目的として、全栄養士が集まって実施しています。<br>栄養相談会でよくある相談に関する講義や育児相談のQ&#038;Aを通した知識の向上だけでなく、ロールプレイング等の実践的な内容も行っています。また、栄養士の観点を活かした新商品開発のグループワークを行うなど、専門の職能を発揮するための勉強会です。</p>\r\n<p class=\"mb_02\"><img decoding=\"async\" src=\"https://www.doramori.co.jp/wordpress/wp-content/uploads/2025/08/dietician.jpg\" alt=\"\" /></p>\r\n<h3 class=\"ft_xl mb_01\"><span style=\"color: #003399;\"><strong>☆ 調剤薬剤師勉強会</strong></span></h3>\r\n<p class=\"mb_02\">調剤店舗における薬剤師の方に、服薬指導、薬歴管理や『ヒヤリ・ハット事例』の周知徹底及び、新規採用医薬品の勉強会をおこないます。</p>\r\n<h3 class=\"ft_xl mb_01\"><span style=\"color: #003399;\"><strong>☆ 店長実務研修会</strong></span></h3>\r\n<p class=\"mb_02\">各店長への実務指導、人材育成、マネジメントの集中研修会です。</p>          <!-- 下層巡回リンク -->\n          <div class=\"recruit_lowers\">\n        <div class=\"col_from4to2\">\n                    <div class=\"wrap\">\n            <a href=\"https://www.doramori.co.jp/recruit/education/\">\n              <p><img src=\"https://www.doramori.co.jp/wordpress/wp-content/themes/doramori/resources/img/recruit/recruit_lowers05.jpg\" alt=\"ドラモリの教育\" /></p>\n              <p>ドラモリの教育</p>\n            </a>\n          </div>\n          <div class=\"wrap\">\n            <a href=\"https://www.doramori.co.jp/recruit/faq/\">\n              <p><img src=\"https://www.doramori.co.jp/wordpress/wp-content/themes/doramori/resources/img/recruit/recruit_lowers04.jpg\" alt=\"ドラモリのQ＆A\" /></p>\n              <p>ドラモリのQ＆A</p>\n            </a>\n          </div>\n        </div>\n      </div>\n            </div>\n    </div><!--content-->\n  </div>\n  <div id=\"footer\">\n    <div id=\"footerNavi\">\n  <div class=\"primary clearfix\">\n    <div id=\"cashless\">\n      <a href=\"https://www.doramori.co.jp/wordpress/wp-content/themes/doramori/resources/img/common/cashless.pdf\" target=\"_blank\">\n        <div class=\"title\">\n          <strong>キャッシュレス決済<span>ご利用いただけます</span></strong>\n        </div>\n        <p>お買い物がさらに便利！ お支払いもスピーディ！</p>\n        <div class=\"inner\">\n          <div class=\"type typeA\">\n            <div>クレジットカード</div>\n            <ul>\n              <li><img alt=\"\" src=\"https://www.doramori.co.jp/wordpress/wp-content/themes/doramori/resources/img/common/cashless/a01.png\"></li>\n              <li><img alt=\"\" src=\"https://www.doramori.co.jp/wordpress/wp-content/themes/doramori/resources/img/common/cashless/a02.png\"></li>\n              <li><img alt=\"\" src=\"https://www.doramori.co.jp/wordpress/wp-content/themes/doramori/resources/img/common/cashless/a03.png\"></li>\n              <li><img alt=\"\" src=\"https://www.doramori.co.jp/wordpress/wp-content/themes/doramori/resources/img/common/cashless/a04.png\"></li>\n              <li><img alt=\"\" src=\"https://www.doramori.co.jp/wordpress/wp-content/themes/doramori/resources/img/common/cashless/a05.png\"></li>\n              <li><img alt=\"\" src=\"https://www.doramori.co.jp/wordpress/wp-content/themes/doramori/resources/img/common/cashless/a06.png\"></li>\n              <li><img alt=\"\" src=\"https://www.doramori.co.jp/wordpress/wp-content/themes/doramori/resources/img/common/cashless/a07.png\"></li>\n     