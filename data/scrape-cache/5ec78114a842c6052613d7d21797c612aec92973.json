-navi__utility__links\">\n</ul>\n</div>\n</div>\n</div>\n</nav><!-- /.global-navi -->\n\r\n</div><!-- /.head-navi-inner -->\r\n</div><!-- /.head-navi -->\r\n\r\n<nav class=\"c-breadcrumb\" aria-label=\"パンくずリスト\">\r\n<ol>\r\n<li><a href=\"/\">ホーム</a></li>\r\n<li><a aria-current=\"page\">お問い合わせ</a></li>\r\n</ol>\r\n</nav><!-- /.c-breadcrumb -->\r\n\r\n<main class=\"main\">\r\n<div class=\"main-inner\">\r\n\r\n<h1 class=\"c-heading-a\">お問い合わせ</h1>\r\n\r\n<div class=\"c-panel c-panel--grey\">\r\n<h2 class=\"panel-title\">お問い合わせをされる前に</h2>\r\n\r\n<p class=\"panel-text u-mt-08\">製品・ソリューション情報、企業情報をお探しの際はこちらをご利用ください。</p>\r\n\r\n<ul class=\"c-link-list c-link-list--inline-block u-mt-00\">\r\n<li><a href=\"/consumer/search/?r=1%3Ab2c&q=\" class=\"c-link-icon\">サイト内検索｜個人のお客様<span class=\"c-icon\"><img src=\"/assets/img/icon_search_gray.svg\" width=\"16\" height=\"16\" alt=\"\"></span></a></li>\r\n<li><a href=\"/business/search/?r=1%3Ab2b&q=\" class=\"c-link-icon\">サイト内検索｜法人のお客様<span class=\"c-icon\"><img src=\"/assets/img/icon_search_gray.svg\" width=\"16\" height=\"16\" alt=\"\"></span></a></li>\r\n<li><a href=\"/company/search/?r=1%3Acorp&q=\" class=\"c-link-icon\">サイト内検索｜企業情報<span class=\"c-icon\"><img src=\"/assets/img/icon_search_gray.svg\" width=\"16\" height=\"16\" alt=\"\"></span></a></li>\r\n<li><a href=\"/company/sitemap/\">サイトマップ｜企業情報</a></li>\r\n</ul><!-- /.c-link-list -->\r\n\r\n<p class=\"panel-text u-mt-08\">製品安全や品質不具合に関するお知らせはこちらをご覧ください。</p>\r\n\r\n<ul class=\"c-link-list\">\r\n<li class=\"index-productNotice-link\"><a href=\"/products_info/\" class=\"c-link-icon\">製品に関する大切なお知らせ</a></li>\r\n</ul><!-- /.c-link-list -->\r\n</div><!-- /.c-panel -->\r\n\r\n<p class=\"c-text c-text--lead u-mt-10\">各種お問い合わせ窓口をご案内します。</p>\r\n\r\n<ul class=\"c-link-local u-mt-05\">\r\n<li><a href=\"#link-01\">製品・ソリューションに関するお問い合わせ</a></li>\r\n<li><a href=\"#link-02\">企業情報に関するお問い合わせ</a></li>\r\n</ul><!-- /.c-link-local -->\r\n\r\n<h2 class=\"c-heading-b\" id=\"link-01\">製品・ソリューションに関するお問い