{"url":"https://www.pref.saitama.lg.jp/a1101/library-info/20260720.html","html":"<!doctype html>\r\n<html lang=\"ja\">\r\n<head>\r\n<meta charset=\"utf-8\">\r\n\r\n<title>けやきひろば水かけまつり -Keyaki Water Splash- - 埼玉県</title>\r\n<meta name=\"keywords\" content=\"飲食,DJ,&nbsp;水かけ,夏祭り,音楽\" />\r\n<meta name=\"description\" content=\"2026年7月にさいたま新都心で開催される「けやきひろば水かけまつり」は、20年以上の歴史を持つ夏の風物詩です&nbsp;。水かけと音楽、食を融合させ、子供から大人まで楽しめる体験型イベントを提供します。\" />\r\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\r\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\r\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\r\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\r\n})(window,document,'script','dataLayer','GTM-T855884');</script>\r\n\r\n<meta name=\"author\" content=\"埼玉県\">\r\n<meta property=\"og:title\" content=\"けやきひろば水かけまつり&nbsp;-Keyaki&nbsp;Water&nbsp;Splash-\">\r\n<meta property=\"og:type\" content=\"article\">\r\n<meta property=\"og:description\" content=\"2026年7月にさいたま新都心で開催される「けやきひろば水かけまつり」は、20年以上の歴史を持つ夏の風物詩です&nbsp;。水かけと音楽、食を融合させ、子供から大人まで楽しめる体験型イベントを提供します。\">\r\n<meta property=\"og:url\" content=\"https://www.pref.saitama.lg.jp/a1101/library-info/20260720.html\">\r\n<meta property=\"og:image\" content=\"https://www.pref.saitama.lg.jp/shared/images/sns/logo.png\">\r\n<meta property=\"og:site_name\" content=\"埼玉県\">\r\n<meta property=\"og:locale\" content=\"ja_jp\">\r\n<meta name=\"dept_code_1\" content=\"110000000\">\r\n<meta name=\"dept_code_2\" content=\"110010000\">\r\n<meta name=\"dept_code_3\" content=\"110010010\">\r\n<meta name=\"cate_code_1\" content=\"006000000000\">\r\n<meta name=\"cate_code_2\" content=\"\">\r\n<meta name=\"cate_code_3\" content=\"\">\r\n<meta name=\"cate_code_4\" content=\"\">\r\n<meta name=\"publish_start\" content=\"2026-05-11 09:00:00\">\r\n<meta name=\"publish_end\" content=\"2026-07-20 23:45:00\">\r\n<meta name=\"template_id\" content=\"7\">\r\n<meta name=\"te