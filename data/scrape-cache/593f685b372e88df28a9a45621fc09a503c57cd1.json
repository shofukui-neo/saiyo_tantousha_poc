gle Tag Manager (noscript) -->\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-M4N5D4J\"\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n<!-- End Google Tag Manager (noscript) -->\n<div id=\"wrapper\">\n\t<div id=\"header_wrap\">\n\t\t<div id=\"header\">\n\t\t\t<div class=\"logo\"><a href=\"/\" target=\"_blank\" rel=\"noopener\"><img src=\"/images/form/logo.jpg\" width=\"182\" height=\"64\" alt=\"翻訳センター\" /></a></div>\n\t\t</div>\n\t\t<!-- #header -->\n\t</div>\n\t<!-- #header -->\n\t<div id=\"article\">\n\n\t\t<noscript>\n\t\t<div class=\"js_off\">\n\t\t\t<p>JavaScriptが無効となっています。ご利用のブラウザでJavaScriptをオンにしてからご利用ください。</p>\n\t\t</div>\n\t\t</noscript>\n\n\t\t<div class=\"title_wrap\">\n\t\t\t<h1 class=\"title\">サービスに関するお問い合わせ</h1>\n\t\t</div>\n\n\t<div class=\"description\">\n    \t<p>\n\t\t\tメールでのお問い合わせの場合は、<a href=\"mailto:estimate@honyakuctr.co.jp?subject=【お問い合わせ】\n\t\t\t\t&amp;body=\n\t\t\t\t※以下の項目を記入し、そのまま送信してください。※%0d%0a\n----------------------------%0d%0a\n会社名（個人の場合は空欄）：%0d%0a\nお名前：%0d%0a\n電話番号：%0d%0a\n勤務地の都道府県（または国）：%0d%0a\nお問い合わせ内容：%0d%0a\n例）見積前のNDA締結について%0d%0a\n例）字幕翻訳の事前トライアルや依頼方法について%0d%0a\n%0d%0a\n※メールの送信をもって 「個人情報保護方針」に同意します。%0d%0a\n個人情報保護方針%0d%0a\nhttps://www.honyakuctr.com/privacypolicy.html%0d%0a\n----------------------------\" target=\"_blank\" class=\"txtlink\">estimate@honyakuctr.co.jp</a> までご連絡ください。\n        </p>\n        <!-- 20260218 add --><p>ビザ申請用翻訳の無料お見積もり依頼は <a href=\"/app/visa/?from=inquiry_service\" style=\"text-decoration: underline\">こちら</a></p>\n\t\t</div>\n\n\t\t\n\t\t<script type=\"text/javascript\">\n<!--\naform = new Object;\naform.id = '5';\naform.logger_url = 'https://www.honyakuctr.com/confirm/aform_logger.cgi';\naform.checker_url = 'https://www.honyakuctr.com/confirm/aform_checker.cgi';\naform.phrases = {\"Input error:\": \"入力エラー:\"};\naform.static_uri = '/_mtadmin/mt-static/';\naform.require_ajax_check = '';\naform.is_active = 'published';\naform.check_immediate = '1';\naform.parameters = new Object;\naform.datepickers = new Object;\naform.relations = new Object;\naform.relations = {}\naform.payment = { parts_id: '', field_id: '', methods: {} };\naform.recaptcha = new Object;\naform.pages = [{\"next\":null,\"parts_id\":[\"INQUIRY_SERVICE_TYPE\",\"INQUIRY_SERVICE_TEXT\",\"INQUIRY_SERVICE_NAME\",\"INQUIRY_SERVICE_KANA\",\"INQUIRY_SERVICE_COMPANYNAME\",\"INQUIRY_SERVICE_TEAM\",\"INQUIRY_SERVICE_EMAIL\",\"INQUIRY_SERVICE_TEL\",\"INQUIRY_SERVICE_POLICY\"],\"prev\":null}];\naform.auto_status = '1';\naform.enabled_report = parseInt('0');\n//-->\n</script>\n\n\n  <script src=\"/_mtadmin/mt-static/plugins/AForm/js/zenhanconv.js\" type=\"text/javascript\"></script>\n\n\n\n\n\n\n<div id=\"aform-5\" class=\"aform ja\">\n<div class=\"aform-header\">サービスに関するお問い合わせ</div>\n<div class=\"aform-checking\" style=\"display:none;\">フォームの状態を確認しています...</div>\n<div class=\"aform-content\">\n\n<form enctype=\"multipart/form-data\" name=\"aform-form-5\" id=\"aform-form-5\" method=\"post\" action=\"https://www.honyakuctr.com/confirm/aform_engine.cgi?form_id=5\"  novalidate=\"novalidate\" >\n    <input type=\"hidden\" name=\"blog_id\" value=\"1\" />\n    <input type=\"hidden\" name=\"id\" value=\"5\" />\n    <input type=\"hidden\" name=\"run_mode\" value=\"confirm\" />\n    <input type=\"hidden\" name=\"aform_url\" value=\"\" />\n    <input type=\"hidden\" name=\"aform_path\" value=\"\" />\n    <input type=\"hidden\" name=\"entry_id\" value=\"\" />\n    \n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n  \n  <div\n        \n        class=\"aform-input aform-hdln INQUIRY_SERVICE_HEADING01 \">お問い合わせ内容のご入力</div>\n\n\n\n\n\n<dl class=\"dl_INQUIRY_SERVICE_TYPE\">\n  <dt><label for=\"INQUIRY_SERVICE_TYPE\" class=\"aform-label INQUIRY_SERVICE_TYPE\">お問い合わせ項目<span class=\"aform-required\">必須</span></label>\n  </dt>\n  <dd>\n      <select \n        id=\"INQUIRY_SERVICE_TYPE\"\n        class=\"aform-input aform-select INQUIRY_SERVICE_TYPE aform-validate  validate-selection\" \n        name=\"aform-field-91\"\n        required\n        \n        title=\"選択してください\"><option value=\"\">選択してください</option><option value=\"1\">翻訳サービス（ビザ申請用を除く）</option><option value=\"2\">ビザ申請用翻訳サービス</option><option value=\"3\">多言語WEBサイト制作</option><option value=\"4\">その他</option></select>\n      <div class=\"aform-error INQUIRY_SERVICE_TYPE\" id=\"INQUIRY_SERVICE_TYPE-error\"></div></dd>\n</dl>\n\n\n\n\n\n<dl class=\"dl_INQUIRY_SERVICE_TEXT\">\n  <dt><label for=\"INQUIRY_SERVICE_TEXT\" class=\"aform-label INQUIRY_SERVICE_TEXT\">お問い合わせ内容<span class=\"aform-required\">必須</span></label>\n  </dt>\n  <dd>\n      <textarea\n        id=\"INQUIRY_SERVICE_TEXT\"\n        class=\"aform-input aform-textarea INQUIRY_SERVICE_TEXT aform-validate  required\"\n        name=\"aform-field-92\"\n        cols=\"40\"\n        rows=\"6\"\n        placeholder=\"\"\n        \n        \n        required\n        ></textarea>\n      <div class=\"aform-error INQUIRY_SERVICE_TEXT\" id=\"INQUIRY_SERVICE_TEXT-error\"></div></dd>\n</dl>\n\n\n\n\n\n  \n  <div\n        \n        class=\"aform-input aform-hdln INQUIRY_SERVICE_HEADING02 \">お客様情報のご入力</div>\n\n\n\n\n\n<dl class=\"dl_INQUIRY_SERVICE_NAME\">\n  <dt><label for=\"INQUIRY_SERVICE_NAME\" class=\"aform-label INQUIRY_SERVICE_NAME\">お名前<span class=\"aform-required\">必須</span></label>\n  </dt>\n  <dd><div class=\"aform-input-example INQUIRY_SERVICE_NAME\">例）翻訳　太郎</div>\n      <ul class=\"aform-name-ul\"><li><label for=\"INQUIRY_SERVICE_NAME-lastname\">姓</label>\n      <input \n        id=\"INQUIRY_SERVICE_NAME-lastname\"\n        class=\"aform-input aform-name INQUIRY_SERVICE_NAME validate-name aform-validate  required\" \n        name=\"aform-field-94-lastname\" \n        type=\"text\" \n        \n        size=\"20\" \n        placeholder=\"\"\n        title=\"お名前(姓)を入力してください\"\n        \n        \n        required\n         /></li><li><label for=\"INQUIRY_SERVICE_NAME-firstname\">名</label>\n      <input \n        id=\"INQUIRY_SERVICE_NAME-firstname\"\n        class=\"aform-input aform-name INQUIRY_SERVICE_NAME validate-name aform-validate  required\" \n        name=\"aform-field-94-firstname\" \n        type=\"text\" \n        \n        size=\"20\" \n        placeholder=\"\"\n        title=\"お名前(名)を入力してください\"\n        \n        \n        required\n         /></li></ul>\n      <div class=\"aform-error INQUIRY_SERVICE_NAME\" id=\"INQUIRY_SERVICE_NAME-lastname-error\"></div><div class=\"aform-error INQUIRY_SERVICE_NAME\" id=\"INQUIRY_SERVICE_NAME-firstname-error\"></div></dd>\n</dl>\n\n\n\n\n\n<dl class=\"dl_INQUIRY_SERVICE_KANA\">\n  <dt><label for=\"INQUIRY_SERVICE_KANA\" class=\"aform-label INQUIRY_SERVICE_KANA\">お名前（フリガナ）<span class=\"aform-required\">必須</span></label>\n  </dt>\n  <dd><div class=\"aform-input-example INQUIRY_SERVICE_KANA\">例）ホンヤク　タロウ</div>\n      <ul class=\"aform-kana-ul\"><li><label for=\"INQUIRY_SERVICE_KANA-lastname-kana\">セイ(カタカナ)</label>\n      <input \n        id=\"INQUIRY_SERVICE_KANA-lastname-kana\"\n        class=\"aform-input aform-kana INQUIRY_SERVICE_KANA aform-validate  required validate-name-kana\" \n        name=\"aform-field-95-lastname-kana\" \n        type=\"text\" \n         \n        size=\"20\" \n        placeholder=\"\"\n        title=\"お名前（フリガナ）(セイ)をカタカナで入力してください\"\n        \n        \n        required\n         /></li><li><label for=\"INQUIRY_SERVICE_KANA-firstname-kana\">メイ(カタカナ)</label>\n      <input \n        id=\"INQUIRY_SERVICE_KANA-firstname-kana\"\n        class=\"aform-input aform-kana INQUIRY_SERVICE_KANA aform-validate  required validate-name-kana\" \n        name=\"aform-field-95-firstname-kana\" \n        type=\"text\" \n         \n        size=\"20\" \n        placeholder=\"\"\n        title=\"お名前（フリガナ）(メイ)をカタカナで入力してください\"\n        \n        \n        required\n         /></li></ul>\n      <div class=\"aform-error INQUIRY_SERVICE_KANA\" id=\"INQUIRY_SERVICE_KANA-lastname-kana-error\"></div><div class=\"aform-error INQUIRY_SERVICE_KANA\" id=\"INQUIRY_SERVICE_KANA-firstname-kana-error\"></div></dd>\n</dl>\n\n\n\n\n\n<dl class=\"dl_INQUIRY_SERVICE_COMPANYNAME\">\n  <dt><label for=\"INQUIRY_SERVICE_COMPANYNAME\" class=\"aform-label INQUIRY_SERVICE_COMPANYNAME\">法人名（団体名、事務所名）<span class=\"aform-required\">必須</span></label>\n  </dt>\n  <dd><div class=\"aform-input-example INQUIRY_SERVICE_COMPANYNAME\">例）株式会社翻訳センター<br>※個人名義でのお問い合わせの場合は、「個人」とご記入ください。</div>\n      <input \n        id=\"INQUIRY_SERVICE_COMPANYNAME\"\n        class=\"aform-input aform-text INQUIRY_SERVICE_COMPANYNAME aform-validate  required\" \n        name=\"aform-field-96\" \n        type=\"text\" \n         \n        size=\"40\" \n        placeholder=\"\"\n        title=\"法人名（団体名、事務所名）を入力してください\"\n        \n        required\n        \n         />\n      <div class=\"aform-error INQUIRY_SERVICE_COMPANYNAME\" id=\"INQUIRY_SERVICE_COMPANYNAME-error\"></div></dd>\n</dl>\n\n\n\n\n\n<dl class=\"dl_INQUIRY_SERVICE_TEAM\">\n  <dt><label for=\"INQUIRY_SERVICE_TEAM\" class=\"aform-label INQUIRY_SERVICE_TEAM\">部署名</label>\n  </dt>\n  <dd><div class=\"aform-input-example INQUIRY_SERVICE_TEAM\">例）総務部</div>\n      <input \n        id=\"INQUIRY_SERVICE_TEAM\"\n        class=\"aform-input aform-text INQUIRY_SERVICE_TEAM aform-validate \" \n        name=\"aform-field-97\" \n        type=\"text\" \n         \n        size=\"40\" \n        placeholder=\"\"\n        title=\"部署名を入力してください\"\n        \n        \n        \n         />\n      <div class=\"aform-error INQUIRY_SERVICE_TEAM\" id=\"INQUIRY_SERVICE_TEAM-error\"></div></dd>\n</dl>\n\n\n\n\n\n<dl class=\"dl_INQUIRY_SERVICE_EMAIL\">\n  <dt><label for=\"INQUIRY_SERVICE_EMAIL\" class=\"aform-label INQUIRY_SERVICE_EMAIL\">メールアドレス<span class=\"aform-required\">必須</span></label>\n  </dt>\n  <dd><div class=\"aform-input-example INQUIRY_SERVICE_EMAIL\">例）honyaku.taro@honyakuctr.co.jp<br><em>※入力間違いがないか、必ずご確認ください。</em></div>\n      <input \n        id=\"INQUIRY_SERVICE_EMAIL\"\n        class=\"aform-input aform-email INQUIRY_SERVICE_EMAIL aform-validate  hankaku validate-email required\" \n        name=\"aform-field-98\" \n        type=\"email\" \n         \n        size=\"40\" \n        placeholder=\"\"\n        title=\"メールアドレス(英数記号のみ)を入力してください 例）foo@example.com\"\n        \n        required\n        \n         />\n      <div class=\"aform-error INQUIRY_SERVICE_EMAIL\" id=\"INQUIRY_SERVICE_EMAIL-error\"></div></dd>\n</dl>\n\n\n\n\n\n<dl class=\"dl_INQUIRY_SERVICE_TEL\">\n  <dt><label for=\"INQUIRY_SERVICE_TEL\" class=\"aform-label INQUIRY_SERVICE_TEL\">電話番号<span class=\"aform-required\">必須</span></label>\n  </dt>\n  <dd><div class=\"aform-input-example INQUIRY_SERVICE_TEL\">例）06-1234-5678</div>\n      <input \n        id=\"INQUIRY_SERVICE_TEL\"\n        class=\"aform-input aform-tel INQUIRY_SERVICE_TEL aform-validate  hankaku validate-tel required\" \n        name=\"aform-field-99\" \n        type=\"tel\" \n         \n        size=\"40\" \n        placeholder=\"\"\n        title=\"電話番号(数字とハイフンのみ)を入力してください 例）03-1234-5678\"\n        \n        required\n        \n         />\n      <div class=\"aform-error INQUIRY_SERVICE_TEL\" id=\"INQUIRY_SERVICE_TEL-error\"></div></dd>\n</dl>\n\n\n\n\n\n  \n  <div\n        \n        class=\"aform-input aform-hdln INQUIRY_SERVICE_HEADING03 \">個人情報の取り扱いについて</div>\n\n\n\n\n\n  \n  <div\n        \n        class=\"aform-input aform-note INQUIRY_SERVICE_POLICYTEST \">お知らせいただく個人情報につきましては、最適なご対応窓口やご対応方法等を判断するために必要な範囲で、当社グループ会社と共同利用させていただきます。<br>\nまた、ご対応窓口となる当社グループ会社から直接ご連絡を差し上げる場合がございます。<br>\n<br>\n上記の第三者提供の取扱いについてご同意いただける場合は、下記の「同意しました」をチェックしてください。<br>\n当社のその他の個人情報の取り扱いについては「個人情報保護方針」をご覧ください。<br>\n<br>\n<a href=\"/privacypolicy.html\" target=\"_blank\">個人情報保護方針</a></div>\n\n\n\n\n\n<dl class=\"dl_INQUIRY_SERVICE_POLICY\">\n  <dt><span class=\"aform-label INQUIRY_SERVICE_POLICY\">個人情報保護方針<span class=\"aform-required\">必須</span></span>\n  </dt>\n  <dd>\n      <ul class=\"aform-checkbox-ul aform-field-102 INQUIRY_SERVICE_POLICY aform-vertical-ul\"><li><input\n            class=\"aform-input aform-checkbox INQUIRY_SERVICE_POLICY aform-validate  validate-privacy\" \n            id=\"INQUIRY_SERVICE_POLICY-1\" \n            name=\"aform-field-102-1\"\n            type=\"checkbox\" \n            value=\"1\" \n            required\n            \n            title=\"個人情報保護方針に同意してください。規約にご同意いただける場合チェックを入れてください（ご同意いただけない場合は送信できません）\" /><label for=\"INQUIRY_SERVICE_POLICY-1\">同意しました。</label></li></ul>\n      <div class=\"aform-error INQUIRY_SERVICE_POLICY\" id=\"INQUIRY_SERVICE_POLICY-error\"></div></dd>\n</dl>\n\n\n\n\n\n\n\n\t<div class=\"aform-button-area\"><input id=\"aform_btn_confirm_5\" type=\"submit\" name=\"Submit\" value=\"確認\" /></div>\n\n\n</form>\n\n\n\n\n</div>\n</div>\n  \n\n</div>\n\t<div id=\"footer_wrap\">\n\t\t<div id=\"footer\">\n\t\t\t<p class=\"copyright\"><img src=\"/images/form/text_copyright.jpg\" width=\"121\" height=\"15\" alt=\"©Honyaku Center Inc.\" /></p>\n\t\t</div>\n\t\t<!-- #footer -->\n\t</div>\n\t<!-- #footer_wrap -->\n\n</div>\n<!-- #wrapper -->\n\n<script type=\"text/javascript\" language=\"javascript\">\n/* <![CDATA[ */\nvar yahoo_retargeting_id = 'JS8GYMN4UK';\nvar yahoo_retargeting_label = '';\n/* ]]> */\n</script>\n<script type=\"text/javascript\" language=\"javascript\" src=\"//b92.yahoo.co.jp/js/s_retargeting.js\"></script>\n<script src=\"https://www.honyakuctr.com/_mtadmin/mt-static/plugins/AForm/js/jquery.validate.js?t=20260612095040\" type=\"text/javascript\"></script>\n<script src=\"https://www.honyakuctr.com/_mtadmin/mt-static/plugins/AForm/js/js.cookie.min.js?t=20260612095040\" type=\"text/javascript\"></script>\n<script type=\"text/javascript\">jQuery.query = { numbers: false };</script>\n<script src=\"https://www.honyakuctr.com/_mtadmin/mt-static/plugins/AForm/js/jquery.query-object.js?t=20260612095040\" type=\"text/javascript\"></script>\n<script src=\"https://www.honyakuctr.com/_mtadmin/mt-static/plugins/AForm/js/jquery-ui.min.js?t=20260612095040\" type=\"text/javascript\"></script>