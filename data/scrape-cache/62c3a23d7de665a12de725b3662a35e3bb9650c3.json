www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\r\n})(window,document,'script','dataLayer','GTM-TLWT6JLC');</script>\r\n<!-- End Google Tag Manager --><link href=\"../../css/entry.css\" rel=\"stylesheet\" type=\"text/css\">\r\n</head>\r\n\r\n<body>\r\n<section class=\"bg_imgbox\">\r\n<div class=\"title_box\">\r\n<h2 class=\"page_title\">New graduates</h2>\r\n<p class=\"page_sub_title\">新卒採用募集要項</p>\r\n</div>\r\n\r\n<div class=\"scroll_bar\">\r\n<a href=\"#\"></a>\r\n</div>\r\n<!--end bg_imgbox -->\r\n</section>\r\n\r\n<header id=\"header\">\r\n<h1 class=\"header_logo\"><a href=\"../../index.php\"><img src=\"../../img/common/head_logo.svg\" alt=\"ネクスト・ワン株式会社 採用特設サイト\"/></a></h1>\r\n\r\n<nav class=\"g_navi\">\r\n<ul>\r\n<li><a href=\"../../message/\"><span class=\"roll_txt\"><span class=\"en\">MESSAGE</span><span class=\"ja\">メッセージ</span></span></a></li>\r\n<li><a href=\"../../company/\"><span class=\"roll_txt\"><span class=\"en\">COMPANY</span><span class=\"ja\">会社を知る</span></span></a></li>\r\n<li><a href=\"../../service/\"><span class=\"roll_txt\"><span class=\"en\">SERVICE</span><span class=\"ja\">仕事を知る</span></span></a></li>\r\n<li><a href=\"../../interview/\"><span class=\"roll_txt\"><span class=\"en\">INTERVIEW</span><span class=\"ja\">人を知る</span></span></a></li>\r\n<li><a href=\"../../culture/\"><span class=\"roll_txt\"><span class=\"en\">CULTURE</span><span class=\"ja\">環境・制度</span></span></a></li>\r\n<li><a href=\"../../faq/\"><span class=\"roll_txt\"><span class=\"en\">FAQ</span><span class=\"ja\">質問</span></span></a></li>\r\n<li><a href=\"../../contact/\"><span class=\"roll_txt\"><span class=\"en\">CONTACT</span><span class=\"ja navi_contact\">お問い合わせ</span></span></a></li>\r\n</ul>\r\n\r\n<div class=\"entry_box\">\r\n<a href=\"../../entry/\">\r\n<span class=\"roll_txt\">\r\n<span class=\"en\">ENTRY</span>\r\n<span class=\"ja\">エントリー</span>\r\n</span>\r\n</a>\r\n</div>\r\n</nav>\r\n</header>\r\n\r\n\r\n<div class=\"openbtn\"><span></span><span></span><span></span></div>\r\n<nav id=\"open_navi\">\r\n<div class=\"open_navi_list\">\r\n<p class=\"ham_logo\"><img src=\"../../img/common/ham_logo.svg\" alt=\"\"/></p>\r\n<ul>\r\n<li><a href=\"../../\">TOP<span class=\"ham_menu_ja\">トップ</span></a></li> \r\n<li><a href=\"../../message/\">MESSAGE<span class=\"ham_menu_ja\">メッセージ</span></a></li>\r\n<li><a href=\"../../company/\">COMPANY<span class=\"ham_menu_ja\">会社を知る</span></a></li> \r\n<li><a href=\"../../service/\">SERVICE<span class=\"ham_menu_ja\">仕事を知る</span></a></li> \r\n<li><a href=\"../../interview/\">INTERVIEW<span class=\"ham_menu_ja\">人を知る</span></a></li>\r\n<li><a href=\"../../culture/\">CULTURE<span class=\"ham_menu_ja\">環境・制度</span></a></li> \r\n<li><a href=\"../../faq/\">FAQ<span class=\"ham_menu_ja\">よくあるご質問</span></a></li> \r\n<li><a href=\"../../contact/\">CONTACT<span class=\"ham_menu_ja\">お問い合わせ</span></a></li> \r\n<li><a href=\"../../entry/\">ENTRY<span class=\"ham_menu_ja\">エントリー</span></a></li> \r\n</ul>\r\n</div>\r\n</nav>\r\n\r\n<main>\r\n<div class=\"content page_requirements\">\r\n<section class=\"box box_s\">\r\n\r\n<h4 class=\"prologue_title\">新卒採用募集要項</h4>\r\n<p class=\"prologue_title_en\">New Graduates Job Description</p>\r\n\r\n<p class=\"prologue_txt\">応募を検討される方は以下の募集要項をご確認いただき、「この求人に応募する」ボタンをクリックしてください。<br class=\"sp-hidden\">\r\n※外部の提携サイトへリンクいたします。<br class=\"pc-hidden\">皆様のご応募お待ちしております。</p>\r\n<!--end .sec_prologue -->\r\n</section>\r\n\r\n\r\n<section class=\"box_s\">\r\n<h5 class=\"job_box_title\">新卒採用募集要項</h5>\r\n\r\n<div class=\"job_info_box\">\r\n<dl>\r\n<dt>募集職種</dt>\r\n<dd><p>・営業職(総合職)<br />\r\n地域に密着し、お客様からの幅広いニーズを汲み取り、既存商品から先進の高度化機器等を提案・販売していきます。<br />\r\n</p>\r\n</dd>\r\n</dl>\r\n\r\n<dl>\r\n<dt>募集人数</dt>\r\n<dd><p>6～10名</p></dd>\r\n</dl>\r\n\r\n<dl>\r\n<dt>応募資格(学歴)</dt>\r\n<dd><p>大学卒業または大学院修了予定者（全学部／全学科）</p>\r\n</dd>\r\n</dl>\r\n\r\n<dl>\r\n<dt>免許・資格</dt>\r\n<dd><p>普通自動車免許</p>\r\n</dd>\r\n</dl>\r\n\r\n<dl>\r\n<dt>提出書類</dt>\r\n<dd><p>履歴書</p>\r\n</dd>\r\n</dl>\r\n\r\n<dl>\r\n<dt>選考方法</dt>\r\n<dd><p>面接を重視しています。<br />\r\n弊社でやりたいこと、自分自身のキャリアアップも含めて面接の中でお互いの価値観を見出したいと思います。</p>\r\n</dd>\r\n</dl>\r\n\r\n<dl>\r\n<dt>初任給</dt>\r\n<dd><p>・営業職　大卒・大学院了：月給 270,000円（諸手当含む）<br />\r\n・営業職　短大等：月給 255,000円（諸手当含む）</p>\r\n</dd>\r\n</dl>\r\n\r\n<dl>\r\n<dt>諸手当</dt>\r\n<dd>\r\n<p>通勤手当<br />\r\n住宅手当（世帯主で扶養者がある場合に限る）<br />\r\n扶養手当<br />\r\n資格手当<br />\r\n地域手当（特定地域のみ）</p>\r\n</dd>\r\n</dl>\r\n\r\n<dl>\r\n<dt>昇給</dt>\r\n<dd><p>年1回（4月）</p>\r\n</dd>\r\n</dl>\r\n\r\n<dl>\r\n<dt>賞与</dt>\r\n<dd><p>年2回（6月、12月）<br />\r\n決算状況により決算賞与実績あり</p>\r\n</dd>\r\n</dl>\r\n\r\n<dl>\r\n<dt>休日/休暇</dt>\r\n<dd>\r\n<p>年間休日数：124日<br />\r\n土日・祝、夏季休暇、年末年始休暇、特別休暇他</p>\r\n</dd>\r\n</dl>\r\n\r\n<dl>\r\n<dt>福利厚生</dt>\r\n<dd><p>各種資格取得のための支援<br />\r\n福利厚生クラブ、ベネフィット・ワン加盟</p>\r\n</dd>\r\n</dl>\r\n\r\n<dl>\r\n<dt>勤務地</dt>\r\n<dd><p>群馬、東京、京都、大阪、兵庫、岡山、広島、香川</p>\r\n</dd>\r\n</dl>\r\n\r\n<dl>\r\n<dt>勤務時間</dt>\r\n<dd><p>8:30～17:15 or 9:00～17:45<br />\r\n実働7.75時間／1日</p>\r\n</dd>\r\n</dl>\r\n\r\n<dl>\r\n<dt>教育制度</dt>\r\n<dd><p>新入社員導入研修、フォローアップ研修、各階層別教育　他</p>\r\n</dd>\r\n</dl>\r\n\r\n<dl>\r\n<dt>備考</dt>\r\n<dd><p>詳細は、「マイナビ」サイトをご確認ください。</p>\r\n</dd>\r\n</dl>\r\n\r\n<!--end div.rental_info_box -->\r\n</div>\r\n\r\n\r\n\t\t<div class=\"link_btn_wrap\">\r\n\t\t\t\t<div class=\"link_btn_box\">\r\n\t\t<a href=\"https://job.mynavi.jp/26/pc/search/corp64792/outline.html\" target=\"_blank\" class=\"link_btn btn_arrow\">2026年卒の応募はこちら</a>\r\n\t\t</div>\r\n\t\t\t\t<div class=\"link_btn_box\">\r\n\t\t<a href=\"https://job.mynavi.jp/27/pc/search/corp64792/outline.html\" target=\"_blank\" class=\"link_btn btn_arrow\">2027年卒の応募はこちら</a>\r\n\t\t</div>\r\n\t\t\t\t</div>\r\n\t\r\n<!--end box -->\r\n</section>\r\n\r\n</div>\r\n</main>\r\n<footer>\r\n<section class=\"sec_movie\">\r\n<div class=\"entry_pv_wrap\">\r\n<video class=\"entry_pvbox\" muted autoplay loop playsinline>\r\n<source src=\"../../img/common/entry_pv.mp4\" type=\"video/mp4\" class=\"entry_pv\">\r\n</video>\r\n\r\n<div class=\"entry_title_wrap\">