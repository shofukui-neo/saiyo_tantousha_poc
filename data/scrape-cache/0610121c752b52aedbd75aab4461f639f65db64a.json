li><a href=\"../about/\">About us</a>\n        <ul>\n          <li><a href=\"/about/index.shtml\">代表挨拶</a></li>\n          <li><a href=\"/about/overview.shtml\">会社概要</a></li>\n          <li><a href=\"/about/philosophy.shtml\">経営理念</a></li>\n          <li><a href=\"/about/promises.shtml\">7つのお約束</a></li>\n          <li><a href=\"/about/history.shtml\">沿革</a></li>\n          <li><a href=\"/about/employee.shtml\">社員保有資格一覧</a></li>\n          <li><a href=\"/about/certifications.shtml\">各種認定と宣言</a></li>\n        </ul>\n      </li>\n      <li><a href=\"../culture/\">Culture</a></li>\n      <li><a href=\"../solution/\">Solution</a>\n        <ul>\n          <li><a href=\"../solution/index.shtml#jump_01\">システムソリューション</a></li>\n          <li><a href=\"../solution/index.shtml#s_index_section02\">場所から探す</a></a></li>\n          <li><a href=\"../solution/index.shtml#s_index_section03\">納入事例</a></a></li>\n        </ul>\n      </li>\n      <li><a href=\"../recruit/\">Recruit</a>\n        <ul>\n          <li><a href=\"/recruit/\">採用情報</a></li>\n          <li><a href=\"/recruit/job.shtml\">職種紹介</a></li>\n          <li><a href=\"/recruit/interview.shtml\">社員インタビュー</a></li>\n          <li><a href=\"/recruit/requirements.shtml\">募集要項</a></li>\n        </ul>\n      </li>\n      <li><a href=\"../misc/contact.shtml\">Contact</a></li>\n    </ul>\n  </div>\n</nav>\n</div>\n<!-- レスポンシブメニュー　 -->\n<header>\n<div class=\"header-logo-menu\">\n<div id=\"nav-drawer\">\n<input id=\"nav-input\" type=\"checkbox\" class=\"nav-unshown\">\n<label id=\"nav-open\" for=\"nav-input\">\n<span></span>\n<p class=\"label_txt_menu\">MENU</p>\n</label>\n<label class=\"nav-unshown\" id=\"nav-close\" for=\"nav-input\"></label>\n<div id=\"nav-content\">\n<!--  ----------------- -->\n<div class=\"accordion\"> \n  <!-- menu1 -->\n  <div class=\"option\">\n    <input type=\"checkbox\" id=\"toggle1\" class=\"toggle\">\n    <label class=\"title item10\" for=\"toggle1\">About us</label>\n    <div class=\"content\">\n      <ul>\n        <li class=\"f_m10_10\"><a href=\"/about/index.shtml\">代表挨拶</a></li>\n        <li class=\"f_m10_20\"><a href=\"/about/overview.shtml\">会社概要</a></li>\n        <li class=\"f_m10_30\"><a href=\"/about/philosophy.shtml\">経営理念</a></li>\n        <li class=\"f_m10_40\"><a href=\"/about/promises.shtml\">7つのお約束</a></li>\n        <li class=\"f_m10_50\"><a href=\"/about/history.shtml\">沿革</a></li>\n        <li class=\"f_m10_60\"><a href=\"/about/employee.shtml\">社員保有資格一覧</a></li>\n        <li class=\"f_m10_70\"><a href=\"/about/certifications.shtml\">各種認定と宣言</a></li>\n      </ul>\n    </div>\n  </div>\n  <!-- menu2 -->\n  <div class=\"option\">\n    <div class=\"one_link\"><a href=\"../culture/\">Culture</a></div>\n  </div>\n  <!-- menu3 -->\n  <div class=\"option\">\n    <input type=\"checkbox\" id=\"toggle3\" class=\"toggle\">\n    <label class=\"title item50\" for=\"toggle3\">Solution</label>\n    <div class=\"content\">\n      <ul>\n        <li class=\"f_m30_10\"><a href=\"../solution/index.shtml#sp_jump_01\">システムソリューション</a></li>\n        <li class=\"f_m30_20\"><a href=\"../solution/index.shtml#jump_15\">場所から探す</a></a></li>\n        <li class=\"f_m30_30\"><a href=\"../solution/index.shtml#jump_02\">納入事例</a></a></li>\n      </ul>\n    </div>\n  </div>\n  <!-- menu4 -->\n  <div class=\"option\">\n    <input type=\"checkbox\" id=\"toggle4\" class=\"toggle\">\n    <label class=\"title item60\" for=\"toggle4\">Recruit</label>\n    <div class=\"content\">\n      <ul>\n        <li class=\"f_m40_10\"><a href=\"/recruit/\">採用情報</a></li>\n        <li class=\"f_m40_20\"><a href=\"/recruit/job.shtml\">職種紹介</a></li>\n        <li class=\"f_m40_30\"><a href=\"/recruit/interview.shtml\">社員インタビュー</a></li>\n        <li class=\"f_m40_40\"><a href=\"/recruit/requirements.shtml\">募集要項</a></li>\n      </ul>\n    </div>\n  </div>\n  <!-- menu5 -->\n  <div class=\"option\">\n    <div class=\"one_link\"><a href=\"../misc/contact.shtml\">Contact</a></div>\n  </div>\n<!-- menu6 -->\n  <div class=\"option\">\n    <div class=\"one_link\"><a href=\"../\">Home</a></div>\n  </div>\n</div alt=\"eod:accordion\">\n</header>\n<!-- --------------------------------------------------- --> \n\n \n  <!-- ヘッダーのインクルード 終わり　--> \n  \n  <!-- ステージ-->\n  <div id=\"zone_substage\">\n    <div>\n      <h1>Recruit</h1>\n    </div>\n\t <!--- パンくず -->\n    <ol class=\"zone_pankuzu\">\n      <li><a href=\"../\">HOME</a></li>\n      <li>Recruit</li>\n    </ol>\n    <!-- パンくず -->\n  </div alt=\"eod:zone_substage\">\n  <!-- ステージ　終わり --> \n  <!-- 第2層 -->\n  <div id=\"zone_middle_floor\"> \n    <!--　ボディ領域　-->\n    <div id=\"zone_body\"> \n      <!--　メインエリア　-->\n      <div id=\"zone_mainarea_1col\">\n        <div class=\"sp_padding\"> \n          \n          <!--　▼▼▼　本文領域　▼▼▼　-->\n          <div class=\"col_textarea_full\">\n            <div class=\"fv\"> <img src=\"image/topstage.jpg\" alt=\"京都支社\">\n              <div class=\"fixed-btn\"><a href=\"requirements.shtml\"><span>→</span>募集要項</a></div>\n            </div>\n            <section id=\"section01\">\n              <h2>代表メッセージ<span>Message</span></h2>\n              <div class=\"l_message_photo\">\n              <img src=\"image/message-01.jpg\" alt=\"代表写真\">\n              <h3><img src=\"image/img-catchcopy.svg\"></h3>\n\t\t\t\t</div>\n              <div class=\"message_panel\">\n                <p>キノンビクスは、1970年に放送・電話設備の工事会社として創業しました。以来、時代の変化やニーズに応えるかたちで事業を広げ、現在では、映像・音響・ICT・サービス・ソフトウェアなど、さまざまな分野に挑戦するマルチベンダーへと進化しています。 </p>\n                <p>私たちの強みは、営業・設計・技術・サービスなど、異なる部門同士が互いに信頼し合い、力を合わせて価値を届けられるチームワークです。それぞれの専門性が連携することで、お客様だけでなく、その先にいる利用者や社会全体にとって本当に意味のある提案やサービスが実現できる。そうした“つながりの力”が、私たちの誇りです。 </p>\n                <p>当社が目指しているのは、規模の大きさではなく、「小さくてもキラリと光る優良企業」であることです。知識や経験の有無にかかわらず、「やってみたい」「挑戦したい」という気持ちを何より大切にしており、あなたの成長が、そのまま会社の成長につながっていく。そして、やがて自分の仕事がこれほどお客様や社会に貢献しているんだと思える、そんな実感を持つことができる会社です。 </p>\n                <p>また、そんな社員のチャレンジを後押しするために、働きやすさや福利厚生の充実にも力を入れています。心と体の健康を第一に考え、組織マネジメント力の向上や公正で納得感のある評価制度の整備など、やりがいをもちながら長く安心して働ける環境づくりに取り組んでいます。 </p>\n               <p>これからもキノンビクスは、地域に根ざしながら新しい分野や技術に挑み、成長し続ける組織を目指します。私たちとともに豊かな未来をつくりましょう。 </p>\n              </div>\n            </section>\n            <section id=\"section02\">\n              <h2>職種紹介<span>Job</span></h2>\n              <ul class=\"bpts_flexbox_onoff justify items wrap\">\n                <li> <a href=\"job-01.shtml\"> <span>Sales Consultant</span>\n                  <h3>営業</h3>\n                  <img src=\"image/job-01-01.jpg\" alt=\"営業\">\n                  <p class=\"txt\">あなたの提案で未来が変わる！映像・音響・ICTシステムの営業職とは？</p>\n                  </a> </li>\n                <li><a href=\"job-02.shtml\"> <span>Construction Management</span>\n                  <h3>施工管理</h3>\n                  <img src=\"image/job-02-01.jpg\" alt=\"施工管理\">\n                  <p class=\"txt\">未来をカタチにする職人！映像・音響・ICTシステムの技術職とは？</p>\n                  </a> </li>\n                <li><a href=\"job-03.shtml\"> <span>System Engineer</span>\n                  <h3>システムエンジニア</h3>\n                  <img src=\"image/job-03-01.jpg\" alt=\"システムエンジニア\">\n                  <p class=\"txt\">アイデアで未来を創造する！映像・音響・ICTシステムのエンジニア職とは？</p>\n                  </a></li>\n                <li><a href=\"job-04.shtml\"> <span>Maintenance/Support</span>\n                  <h3>保守・サポート</h3>\n                  <img src=\"image/job-04-01.jpg\" alt=\"image/job-04.jpg\">\n                  <p class=\"txt\">知識で未来を輝かせる！映像・音響・ICTシステムのサポート職！ </p>\n                  </a></li>\n              </ul>\n              <ul class=\"bpts_flexbox_onoff justify icons\">\n                <li> <a href=\"interview.shtml\" class=\"bpts_flexbox_nobloc column\"> <img src=\"image/job-icon-01.svg\" alt=\"社員の声\"> <span>Interview</span>\n                  <h3>社員の声</h3>\n                  </a> </li>\n                <li> <a href=\"/culture/\" class=\"bpts_flexbox_nobloc column center\"> <img src=\"image/job-icon-02.svg\" alt=\"キノンビクスを知る\"> <span>Culture</span>\n                  <h3>キノンビクスを知る</h3>\n                  </a> </li>\n                <li> <a href=\"/about/certifications.shtml\" class=\"bpts_flexbox_nobloc column center\"> <img src=\"image/job-icon-03.svg\" alt=\"各種認定と宣言\"> <span>Certifications &amp; Declarations</span>\n                  <h3>各種認定と宣言</h3>\n                  </a> </li>\n              </ul>\n            </section>\n            <section id=\"section03\">\n              <ul class=\"grid_flow\">\n                <li> <span>1</span>\n                  <h3>書類選考</h3>\n                  <p>電話又はメール連絡の上、履歴書（写真貼付）・技術（職務）経歴書をメール又は郵送して下さい。<br>\n                    ※選考の結果にかかわらず、書類の返却はいたしません。</p>\n                </li>\n                <li> <span>2</span>\n                  <h3>一次面接</h3>\n                  <p>原則WEB面接</p>\n                </li>\n                <li> <span>3</span>\n                  <h3>SPI適性検査</h3>\n                </li>\n                <li> <span>4</span>\n                  <h3>二次面接</h3>\n                </li>\n                <li> <span>5</span>\n                  <h3>内定<br>\n                  </h3>\n                </li>\n              </ul>\n              <p class=\"center\">※会社見学も受け付けています</p>\n            </section>\n            <section id=\"section04\">\n              <h2>インターンシップ</h2>\n              <div class=\"box\">\n                <p>弊社の業務がより理解できる映像、音響等機器を見ていただけます。<br>\n                  また、施工実績なども映像でご確認いただけます。</p>\n                <div class=\"l_internship_grid\">\n                  <ul>\n                    <li>\n                      <h3>期間</h3>\n                      <p><strong>申込期間</strong>　通年<br>\n                        <strong>受入期間</strong>　3月、8月を除く通年</p>\n                    </li>\n                    <li>\n                      <h3>実習日程</h3>\n                      <p>1days<br>\n                        午前、午後の約2時間程度</p>\n                    </li>\n                    <li>\n                      <h3>開催場所</h3>\n                      <p>キノンビクス株式会社　京都支店</p>\n                    </li>\n                  </ul>\n                  <ul>\n                    <li>\n                      <h3>募集人数</h3>\n                      <p>1～5名</p>\n                    </li>\n                    <li>\n                      <h3>対象者</h3>\n                      <p>対象学年／全学年<br>\n                        理系大学院生、理系学部生、文系大学院生、文系学部生<br>\n                        短大生、高専生、専門学校生、留学生</p>\n                    </li>\n                    <li>\n                      <h3>給与</h3>\n                      <p>なし</p>\n                    </li>\n                    <li>\n                      <h3>実施概要 </h3>\n                      <p>対面形式<br>\n                        職場見学、先輩社員との座談会ほか</p>\n                    </li>\n                  </ul> </div>\n              </div>\n            </section>\n            \n           \n            \n          </div alt=\"col_textarea_full\">\n          <!--　▲▲▲　本文領域　終わり　▲▲▲　--> \n        </div>\n        <!-- eod:sp_padding --> \n      </div alt=\"eod:zone_mainarea\">\n      <!--　メインエリア　終わり　--> \n    </div alt=\"eod:zone_body\">\n    <!--　ボディ領域　終わり　--> \n  </div alt=\"eod:zone_middle\">\n  <!--　第2層　終わり　--> \n  <!-- リクルート用　お問い合わせフッターのインクルード --> \n  <meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\" />\n<meta name=\"format-detection\" content=\"telephone=no\">\n<!-- \n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/common.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/zone.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/bpts.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/unit.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/col.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/other.css\"/>\n-->\n<!-- リクルートフッターここから -->\n<div class=\"bpts_footer_recruit\"> \n  <!-- ▼ 左ボックス -->\n  <div>\n    <h4>採用に関するお問い合わせ</h4>\n    <table>\n      <tr>\n        <th>担当</th>\n        <td><span>管理グループ</span><br>\n          西村 伸宏</td>\n      </tr>\n      <tr>\n        <th>TEL</th>\n        <td>077-552-1144</td>\n     