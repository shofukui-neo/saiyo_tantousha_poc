ass=\"u-hover\">\r\n            <span class=\"l-footer__flex__nav__no\">08</span><span class=\"l-footer__flex__nav__txt\">DX</span>\r\n          </a>\r\n          <a href=\"/recruit/works/people/09/\" class=\"u-hover\">\r\n            <span class=\"l-footer__flex__nav__no\">09</span><span class=\"l-footer__flex__nav__txt\">デジタル・システム</span>\r\n          </a>\r\n        </dd>\r\n      </dl>\r\n      <dl class=\"l-footer__flex__nav\">\r\n        <dt>働く環境</dt>\r\n        <dd>\r\n          <a href=\"/recruit/environment/career/\" class=\"u-hover\">キャリア・教育研修</a>\r\n        </dd>\r\n        <dd>\r\n          <a href=\"/recruit/environment/welfare/\" class=\"u-hover\">働く環境・福利厚生</a>\r\n        </dd>\r\n        <dt class=\"-second\">採用情報</dt>\r\n        <dd>\r\n          <a href=\"/recruit/recruit/ideal/\" class=\"u-hover\">人事部長メッセージ</a>\r\n        </dd>\r\n        <dd>\r\n          <a href=\"/recruit/recruit/information/\" class=\"u-hover\">募集要項／選考フロー</a>\r\n        </dd>\r\n        <dd>\r\n          <a href=\"/recruit/recruit/faq/\" class=\"u-hover\">よくある質問</a>\r\n        </dd>\r\n      </dl>\r\n      <dl class=\"l-footer__flex__nav\">\r\n        <dt>インターンシップ情報</dt>\r\n        <dd>\r\n          <a href=\"/recruit/internship/\" class=\"u-hover\">インターンシップ</a>\r\n        </dd>\r\n        <dd>\r\n          <a href=\"/recruit/internship/information/\" class=\"u-hover\">募集要項</a>\r\n        </dd>\r\n      </dl>\r\n    </div>\r\n    <div class=\"l-footer__bottom\">\r\n      <ul class=\"l-footer__bottom__left\">\r\n            <li>\r\n              <a href=\"/recruit/integration/\" class=\"u-hover\">合併について</a>\r\n            </li>\r\n            <li>\r\n              <a href=\"/recruit/integration_inform/\" class=\"u-hover\">デジタル・システムコース 積極採用中！</a>\r\n            </li>\r\n            <li>\r\n              Special Movie: <a href=\"javascript:void(0)\" class=\"u-hover\" onclick=\"openMovie('6ivHyPt1O3o'); return false;\">Life at HNBK</a>\r\n            </li>\r\n          </ul>\r\n    