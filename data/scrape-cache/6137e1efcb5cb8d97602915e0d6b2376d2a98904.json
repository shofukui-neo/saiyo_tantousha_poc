ck-flexible-table-block-table>table tr td{background-color:#ffffff;}@media screen and (min-width:769px){.wp-block-flexible-table-block-table.is-scroll-on-pc{overflow-x:scroll;}.wp-block-flexible-table-block-table.is-scroll-on-pc table{max-width:none;align-self:self-start;}}@media screen and (max-width:768px){.wp-block-flexible-table-block-table.is-scroll-on-mobile{overflow-x:scroll;}.wp-block-flexible-table-block-table.is-scroll-on-mobile table{max-width:none;align-self:self-start;}.wp-block-flexible-table-block-table table.is-stacked-on-mobile th,.wp-block-flexible-table-block-table table.is-stacked-on-mobile td{width:100%!important;display:block;}}\n</style>\n<link rel='stylesheet' id='wpcf7-redirect-script-frontend-css' href='https://www.hokutetsu.co.jp/_wp/wp-content/plugins/wpcf7-redirect/build/assets/frontend-script.css?ver=a0c286e30e803dfa8dc4' type='text/css' media='all' />\n<link rel='stylesheet' id='wp-pagenavi-css' href='https://www.hokutetsu.co.jp/_wp/wp-content/plugins/wp-pagenavi/pagenavi-css.css?ver=2.70' type='text/css' media='all' />\n<link rel='stylesheet' id='cf7cf-style-css' href='https://www.hokutetsu.co.jp/_wp/wp-content/plugins/cf7-conditional-fields/style.css?ver=2.5.10' type='text/css' media='all' />\n<script type=\"text/javascript\" src=\"https://www.hokutetsu.co.jp/_wp/wp-includes/js/jquery/jquery.min.js?ver=3.7.1\" id=\"jquery-core-js\"></script>\n<script type=\"text/javascript\" src=\"https://www.hokutetsu.co.jp/_wp/wp-includes/js/jquery/jquery-migrate.min.js?ver=3.4.1\" id=\"jquery-migrate-js\"></script>\n<link rel=\"canonical\" href=\"https://www.hokutetsu.co.jp/recruit/event/recruit_event-5406/\" />\n</head>\n<body class=\"template\">\n    <div class=\"wrapper\">\n    <header id=\"pageHeader\" class=\"l-header\">\n  <div class=\"l-header__inner\">\n    <h1 class=\"l-header__logo\">\n      <a href=\"https://www.hokutetsu.co.jp/recruit/\">\n        <img src=\"/assets/img/common/logo.png\" alt=\"北陸鉄道株式会社\">\n      </a>\n    </h1>\n\n    <nav class=\"l-header__gnav l-gnav\">\n      <div class=\"l-gnav__inner\">\n        <ul class=\"l-gnav__list\">\n          <li class=\"l-gnav__item\"><a href=\"https://www.hokutetsu.co.jp/news/news-category/recruit/\" class=\"l-gnav__link uni-btn\"><span class=\"link-text\">お知らせ</span><span class=\"arrow\"></span></a></li>\n          <li class=\"l-gnav__item\"><a href=\"https://www.hokutetsu.co.jp/recruit/bus-driver/\" class=\"l-gnav__link uni-btn\"><span class=\"link-text\">バス運転士採用</span><span class=\"arrow\"></span></a></li>\n          <li class=\"l-gnav__item\"><a href=\"https://www.hokutetsu.co.jp/recruit/general/\" class=\"l-gnav__link uni-btn\"><span class=\"link-text\">総合職採用</span><span class=\"arrow\"></span></a></li>\n          <li class=\"l-gnav__item\"><a href=\"https://www.hokutetsu.co.jp/recruit/event/\" class=\"l-gnav__link uni-btn\"><span class=\"link-text\">イベント</span><span class=\"arrow\"></span></a></li>\n        </ul>\n        <div class=\"l-gnav__btn\">\n          <a href=\"https://www.hokutetsu.co.jp\" target=\"_blank\" rel=\"noopener noreferrer\">コーポレートサイト</a>\n        </div>\n      </div>\n      <div id=\"js-focus-trap\" tabindex=\"0\"></div>\n    </nav>\n\n    <button type=\"button\" id=\"js-hamburger\" class=\"l-header__menu\" aria-controls=\"navigation\" aria-expanded=\"false\" aria-label=\"Menu\">\n      <span class=\"text\"></span>\n      <span class=\"line\"></span>\n    </button>\n  </div>\n  <div class=\"l-header__bg\"></div>\n</header>    <main id=\"pageRecruitBusDriverJob\" class=\"pageMain p-recruitJob\">\n      <section class=\"l-section p-recruit-subMainv03\">\n        <div class=\"l-container --uni-m\">\n          <div class=\"l-inner p-recruit-subMainv03__inner\">\n            <div class=\"p-recruit-subMainv03__heading\">\n              <h2 class=\"title\">バス運転士募集CMを制作しました</h2>\n            </div>\n            <div class=\"p-recruit-subMainv03__bg --bg01\"></div>\n          </div>\n        </div>\n      </section>\n\n      <section class=\"l-section l-recruitSection --white p-recruitJob-comp\">\n        <div class=\"l-container --uni-m\">\n          <div class=\"l-inner wysiwyg\">\n          \n<p>このたび新たにバス運転士募集CMを制作しました。子どもたちの憧れるバス運転士を「まちとまち」「人と人」をつなぐヒーローとして表現しました。</p>\n\n\n\n<p>石川県内民放4局で放送中です。是非ご覧ください。<br></p>\n\n\n\n<p>北陸鉄道グループではバス運転士採用募集を随時受付をしております。皆さまのご応募を心よりお待ちしています。</p>\n\n\n\n<p></p>\n\n\n\n<figure class=\"wp-block-embed is-type-video is-provider-youtube wp-block-embed-youtube wp-embed-aspect-16-9 wp-has-aspect-ratio !mt-8\"><div class=\"wp-block-embed__wrapper\">\n<iframe title=\"北陸鉄道CM ヒーロー篇 30秒\" width=\"500\" height=\"281\" src=\"https://www.youtube.com/embed/E9US-DCEkqQ?feature=oembed\" frameborder=\"0\" allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share\" referrerpolicy=\"strict-origin-when-cross-origin\" allowfullscreen></iframe>\n</div></figure>\n          </div>\n        </div>\n      </section>\n\n      <div class=\"l-section p-recruitDeco-comp\">\n        <div class=\"l-container --uni-m\">\n          <div class=\"l-inner p-recruitDeco-comp__inner\">\n            <div class=\"p-recruitDeco-comp__bg --bg01\"></div>\n            <div class=\"p-recruitDeco-comp__deco01\">\n              <figure>\n                <img src=\"/assets/img/recruit/deco_landscape02.svg\" alt=\"\" width=\"383\" height=\"217\">\n              </figure>\n            </div>\n            <div class=\"p-recruitDeco-comp__deco02\">\n              <figure>\n                <img src=\"/assets/img/sub/bus2.svg\" alt=\"\">\n              </figure>\n            </div>\n            <div class=\"p-recruitDeco-comp__deco03\">\n              <figure>\n                <img src=\"/assets/img/sub/bus1.svg\" alt=\"\">\n              </figure>\n            </div>\n          </div>\n        </div>\n      </div>\n    </main>\n    <footer id=\"footer\" class=\"l-footer\">\n  <div class=\"l-footer__container\">\n    <div class=\"l-footer__top\">\n      <div class=\