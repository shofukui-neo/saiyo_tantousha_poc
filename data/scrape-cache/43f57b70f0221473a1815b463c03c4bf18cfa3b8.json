bnav-child__inner js-subnav-inner js-accordion-body\">\n                    <ul class=\"lst-subnav-child\">\n                      <li class=\"lst-subnav-child__item\"><a class=\"lst-subnav-child__link\" href=\"/services/real-estate/\" tabindex=\"6\">不動産事業</a></li>\n                      <li class=\"lst-subnav-child__item\"><a class=\"lst-subnav-child__link\" href=\"/services/greening/\" tabindex=\"7\">緑化事業</a></li>\n                      <li class=\"lst-subnav-child__item\"><a class=\"lst-subnav-child__link\" href=\"/services/construction/\" tabindex=\"8\">建設事業</a></li>\n                      <li class=\"lst-subnav-child__item\"><a class=\"lst-subnav-child__link\" href=\"/services/community-development/\" tabindex=\"9\">まちづくり事業</a></li>\n                    </ul>\n                  </div>\n                </div>\n              </div>\n            </div>\n            <div class=\"subnav__container js-subnav-container\" id=\"case\">\n              <div class=\"subnav__content\">\n                <div class=\"subnav-parent\">\n                  <div class=\"subnav-parent__inner js-subnav-inner\"><a class=\"subnav-parent__link\" href=\"/works/\" tabindex=\"11\">実績・事例紹介</a>\n                    <button class=\"subnav-parent__accordion-button js-accordion-button\" type=\"button\" aria-label=\"アコーディオンの切り替え\"></button>\n                  </div>\n                </div>\n                <div class=\"subnav-child\">\n                  <div class=\"subnav-child__inner js-subnav-inner js-accordion-body\">\n                    <ul class=\"lst-subnav-child\">\n                      <li class=\"lst-subnav-child__item\"><a class=\"lst-subnav-child__link\" href=\"/works/real-estate/\" tabindex=\"12\">不動産事業実績・事例</a></li>\n                      <li class=\"lst-subnav-child__item\"><a class=\"lst-subnav-child__link\" href=\"/works/greening/\" tabindex=\"13\">緑化事業実績・事例</a></li>\n                      <li class=\"lst-subnav-child__item\"><a class=\"lst-subnav-child__link\" href=\"/works/construction/\" tabindex=\"14\">建設事業実績・事例</a></li>\n                    </ul>\n                  </div>\n                </div>\n              </div>\n            </div>\n            <div class=\"subnav__container js-subnav-container\" id=\"company\">\n              <div class=\"subnav__content\">\n                <div class=\"subnav-parent\">\n                  <div class=\"subnav-parent__inner js-subnav-inner\"><a class=\"subnav-parent__link\" href=\"/company/\" tabindex=\"17\">会社紹介</a>\n                    <button class=\"subnav-parent__accordion-button js-accordion-button\" type=\"button\" aria-label=\"アコーディオンの切り替え\"></button>\n                  </div>\n                </div>\n                <div class=\"subnav-child\">\n                  <div class=\"subnav-child__inner js-subnav-inner js-accordion-body\">\n                    <ul class=\"lst-subnav-child\">\n                      <li class=\"lst-subnav-child__item\"><a class=\"lst-subnav-child__link\" href=\"/company/message/\" tabindex=\"18\">社長挨拶</a></li>\n                      <li class=\"lst-subnav-child__item\"><a class=\"lst-subnav-child__link\" href=\"/company/location/\" tabindex=\"19\">事業所所在地</a></li>\n                      <li class=\"lst-subnav-child__item\"><a class=\"lst-subnav-child__link\" href=\"/company/outline/\" tabindex=\"20\">会社概要・沿革</a></li>\n                      <li class=\"lst-subnav-child__item\"><a class=\"lst-subnav-child__link\" href=\"/company/compliance/\" tabindex=\"21\">コンプライアンスの推進</a></li>\n                      <li class=\"lst-subnav-child__item\"><a class=\"lst-subnav-child__link\" href=\"/company/privacy/\" tabindex=\"22\">個人情報保護方針</a></li>\n\n                    </ul>\n                  </div>\n                </div>\n              </div>\n            </div>\n            <div class=\"subnav__container js-subnav-container\" id=\"recruit\">\n              <div class=\"subnav__content\">\n                <div class=\"subnav-parent\">\n                  <div class=\"subnav-parent__inner js-subnav-inner\"><a class=\"subnav-parent__link\" href=\"/recruit/\" tabindex=\"24\">採用情報</a>\n                    <button class=\"subnav-parent__accordion-button js-accordion-button\" type=\"button\" aria-label=\"アコーディオンの切り替え\"></button>\n                  </div>\n                </div>\n                <div class=\"subnav-child\">\n                  <div class=\"subnav-child__inner js-subnav-inner js-accordion-body\">\n                    <ul class=\"lst-subnav-child\">\n                      <li class=\"lst-subnav-child__item\"><a class=\"lst-subnav-child__link\" href=\"/recruit/newgraduates/\" tabindex=\"25\">新卒採用</a></li>\n                      <li class=\"lst-subnav-child__item\"><a class=\"lst-subnav-child__link\" href=\"/recruit/career/\" tabindex=\"26\">キャリア採用</a></li>\n                    </ul>\n                  </div>\n                </div>\n              </div>\n            </div>\n            <div class=\"subnav-group-logo\"><a class=\"subnav-group-logo__link\" href=\"https://www.chuden.co.jp/\" target=\"_blank\" rel=\"noopener\"><img class=\"subnav-group-logo__image\" src=\"/common/assets/images/group-logo.png\" alt=\"中部電力グループ\"></a></div>\n          </div>\n        </nav>\n        <div class=\"menu\" id=\"menu\">\n          <div class=\"menu__text\">メニュー</div>\n        </div>\n      </header></div>\n      \n  </div>\n\n  \n\n  \n\n        <div data-drupal-messages-fallback class=\"hidden\"></div>\n\n  \n\n  <main class=\"l-main\">\n          <div id=\"block-chudenfudosan-content\" class=\"block block-system block-system-main-block\">\n  \n    \n      <div class=\"views-element-container\">\n\n\n  \n  \n  \n\n            <section class=\"sec-mainvisual\">\n  <div class=\"mainvisual mainvisual--recruit\">\n    <div class=\"mainvisual__inner\"><img class=\"mainvisual__image is-visible-pc\" src=\"/common/assets/images/recruit/pct-mainvisual-pc.jpg\" alt=\"\"><img class=\"mainvisual__image is-visible-sp\" src=\"/common/assets/images/recruit/pct-mainvisual-sp.jpg\" alt=\"\">\n      <div class=\"breadcrumb\">\n        <div class=\"l-container\">\n          <ul class=\"lst-breadcrumb\">\n            <li class=\"lst-breadcrumb__item\"><a class=\"lst-breadcrumb__link\" href=\"/\">トップページ</a>\n            <li class=\"lst-breadcrumb__item\">採用情報</li>\n            </li>\n          </ul>\n        </div>\n      </div>\n      <div class=\"mainvisual__heading\">\n        <div class=\"l-container\">\n          <h1 class=\"hdg-large\">採用情報</h1>\n        </div>\n      </div>\n    </div>\n    <div class=\"mainvisual__content\">\n      <div class=\"l-container\">\n        <p class=\"txt\">当社は、中部電力グループにおける総合的な不動産事業会社として、<br class=\"is-visible-pc\">時代を先取りした多様なニーズにお応えし、<br class=\"is-visible-pc\">社会的な変化や要請にスピード感を持って取り組んでいきます。<br>こうした中、従業員１人１人に必要とされるのが、<br class=\"is-visible-pc\">経営方針に掲げる「チャレンジ精神」と「前向きな行動力」という２つの要素です。<br>当社の採用職種は、建築・造園施工管理や建物設備管理などを行う「総合職（技術系）」と、不動産開発・管理、一般管理などを行う「総合職（不動産・事務系）」<br class=\"is-visible-pc\">ですが、どちらの職種も共通して、この２つの要素が求められます。<br>中部電力グループの一員として、<br>ともに力を合わせて前向きにチャレンジしていける方をお待ちしています！</p>\n      </div>\n    </div>\n  </div>\n</section>\n<section>\n  <ul class=\"inpage-nav\">\n    <li class=\"inpage-nav__item\"><a href=\"/recruit/newgraduates/\"><img class=\"is-visible-pc\" src=\"/common/assets/images/recruit/pct-nav-newgrads.png\" alt=\"\"><img class=\"is-visible-sp\" src=\"/common/assets/images/recruit/pct-nav-newgrads-sp.png\" alt=\"\"><span>新卒採用<small>募集要項はこちら</small></span></a></li>\n    <li class=\"inpage-nav__item\"><a href=\"/recruit/career/\"><img class=\"is-visible-pc\" src=\"/common/assets/images/recruit/pct-nav-career.png\" alt=\"\"><img class=\"is-visible-sp\" src=\"/common/assets/images/recruit/pct-nav-career-sp.png\" alt=\"\"><span>キャリア採用<small>募集要項はこちら</small></span></a></li>\n  </ul>\n</section>\n<section class=\"section-recruit-benefit\">\n  <div class=\"l-container\">\n    <h2 class=\"hdg-medium hdg-noline\">安心の職場環境\n              <p class=\"hdg-sub\">benefits</p>\n            </h2>\n    <ul class=\"lst-benefit\">\n      <li>\n        <div class=\"lst-benefit__item\">\n          <p class=\"lst-benefit__title\">休日・休暇</p>\n          <p class=\"lst-benefit__text\">・年間休日123日<br>\n・有給休暇20日/年付与<br>　（1年目のみ15日/年）<br>\n・夏季休暇、結婚休暇、産前産後休暇、配偶者出産休暇<br>\n・リフレッシュ休暇（永年勤続）\n</p>\n        </div>\n      </li>\n      <li>\n        <div class=\"lst-benefit__item\">\n          <p class=\"lst-benefit__title\">各種制度・福利厚生</p>\n          <p class=\"lst-benefit__text\">・フレックスタイム勤務制度<br>\n・テレワーク制度（在宅勤務等）<br>\n・育児休職、育児時短勤務<br>\n・人間ドック全額補助<br>\n・資格合格祝金制度<br>\n・中部電力健康保険等各種保険\n</p>\n        </div>\n      </li>\n      <li>\n        <div class=\"lst-benefit__item\">\n          <p class=\"lst-benefit__title\">各種手当</p>\n          <p class=\"lst-benefit__text\">・通勤費全額支給<br>\n・時間外勤務手当<br>\n・家族手当<br>\n・資格手当<br>\n・住宅手当（賃借料の一部補助）\n</p>\n        </div>\n      </li>\n\n\n    </ul>\n  </div>\n  <div class=\"box-benefit-wrap\">\n    <div class=\"l-container\">\n      <h3 class=\"hdg-small\">「健康経営優良法人2026　ネクストブライト1000」に認定されました</h3>\n      <div class=\"box-benefit\">\n        <div class=\"box-benefit__text\">\n          <p class=\"box-benefit__image is-visible-sp\"><img src=\"/common/assets/images/recruit/pct-benefit.png?20260401\" alt=\"\"></p>\n          <p class=\"box-benefit__text__text\">当社は、「健康経営優良法人2026　ネクストブライト1000」中小規模法人部門の認定を受けています。健康経営優良法人2026（中小企業部門23,085法人）の中でも優れた企業かつ、地域において健康経営の発信を行っている企業上位501〜1,500法人に対して「ネクストブライト1000」の名称が付与されています。<br>\n当社は、健康経営に積極的に取り組み、従業員の健康を何より大切にするとともに、組織全体の活性化を図り、企業価値や業績の向上につなげてまいります。</p>\n          <h4 class=\"hdg-minimum\">【健康経営優良法人認定制度とは】</h4>\n          <p class=\"box-benefit__text__text\">健康経営優良法人認定制度とは、日本健康会議が認定する制度で、地域の健康課題に即した取組や日本健康会議が進める健康増進の取組をもとに、従業員の健康の保持・増進に対して特に優良な健康経営を実践している大企業や中小企業等の法人を顕彰する制度です。</p>\n        </div>\n        <div class=\"box-benefit__image\"><img src=\"/common/assets/images/recruit/pct-benefit.png?0329\" alt=\"\"></div>\n      </div>\n    </div>\n  </div>\n  <div class=\"l-container\">\n    <div class=\"hdg-date-wrap\">\n      <h3 class=\"hdg-small\">有資格者数</h3><small>2025年7月1日現在</small>\n    </div>\n    <ul class=\"lst-table lst-qualified\">\n      <li class=\"lst-table__item\">宅地建物取引士　103名</li>\n    </ul>\n    <ul class=\"lst-table lst-qualified mb0\">\n      <li class=\"lst-table__item\">一級建築士　57名</li>\n      <li class=\"lst-table__item\">一級建築施工管理技士　95名</li>\n    </ul>\n    <ul class=\"lst-attention\">\n      <li class=\"lst-attention__item\">2025年7月1日時点従業員数567名（建設部門171名）のうち</li>\n    </ul>\n  </div>\n</section>\n<style>\n.lst-benefit__item{\npadding:55px 20px 60px;\n}\n</style>\n<section id=\"block-views-blockrecruit-list-block-1\" class=\"block block-views block-views-blockrecruit-list-block-1 section-recruit-interview\">\n  \n  \n\n  <div class=\"section__title\">\n    <div class=\"l-container\">\n      <h2 class=\"hdg-medium hdg-noline\">仕事を知る\n        <p class=\"hdg-sub\">interview</p>\n      </h2>\n    </div>\n  </div>\n  <div class=\"box-recruit-slider\">\n    <div class=\"l-container\">\n      <h3 class=\"hdg-small\">技術職</h3>\n      <div class=\"common-slider common-slider--recruit\">\n        <div class=\"swiper-container js-recruit-slider\">\n          <div class=\"swiper-wrapper\">\n      \n          <div class=\"swiper-slide\">\n        <a href=\"/recruit/interview-tech/01.html\">\n          <img class=\"fluid-image\" src=\"/sites/default/files/2020-09/main_10.jpg\" alt=\"\">\n          <span>建設工事<small>本社　建設・緑化部　名古屋工事センター　工事第3グループ　2018年入社</small></span>\n        </a>\n      </div>\n        \n          <div class=\"swiper-slide\">\n        <a href=\"/recruit/interview-tech/03.html\">\n          <img class=\"fluid-image\" src=\"/sites/default/files/2020-09/main_8.jpg\" alt=\"\">\n          <span>建設工事<small>本社　建設・緑化部　名古屋工事センター　工事第１グループ　2020年入社</small></span>\n        </a>\n      </div>\n        \n          <div class=\"swiper-slide\">\n        <a href=\"/recruit/interview-tech/04.html\">\n          <img class=\"fluid-image\" src=\"/sites/default/files/2020-09/main_7.jpg\