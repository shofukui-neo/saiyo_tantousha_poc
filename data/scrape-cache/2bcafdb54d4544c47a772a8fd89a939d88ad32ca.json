rc=\"../Scripts/jquery.inview.js\"></script>\n<script type=\"text/javascript\" src=\"../Scripts/common.js\"></script> \n<script src=\"https://unpkg.com/split-type\"></script>   \n\n    \n\n</head>\n\n\n\n<body id=\"p-inq\">\n<a id=\"top\"></a> \n<div id=\"outer\">\n<div id=\"wrap\">\n\n\n<header id=\"\" class=\"\">\n<h1 id=\"hd-logo\"><a href=\"/\"><img src=\"/img/hd-logo.svg\" alt=\"同仁社\"/></a></h1>\n\t  \n<div class=\"inner\">\n<ul  class=\"svs-nav\">\n<li class=\"current\"><a href=\"/hospital/\">ホスピタルリネン</a></li>\n<li><a href=\"/leasekin/\">リースキン</a></li>\n<li><a href=\"/linen/\">リネンサプライ</a></li>\n<li><a href=\"/health/\">ヘルスケア</a></li>\n<li><a href=\"/uniform/\">ユニフォーム</a></li>\n</ul>\n\n<ul  class=\"cmp-nav\">\n<li class=\"menu__single\">\n<!--<a href=\"/company/\">会社紹介<i class=\"las la-angle-down\"></i></a>-->\n会社紹介<i class=\"las la-angle-down\"></i>\n <ul class=\"menu__second-level\">\n<li><a href=\"/company/index.html\">私達の想い</a></li>\n<li><a href=\"/company/outline.html\">企業情報</a></li>\n<li><a href=\"/company/action.html\">取り組み</a></li>\n<li><a href=\"/company/quality.html\">品質方針</a></li>\n</ul>\n</li>\n<li><a href=\"/factory/\">工場について</a></li>\n</ul>\n       \n<ul class=\"bt-nav\">\n<li><a href=\"/recruit/\"><i class=\"las la-paste\"></i>採用情報</a></li>\n<li><a href=\"/contact/\"><i class=\"las la-envelope\"></i>お問合わせ</a></li>\n</ul>\n<!--inner--></div>\n</header>\n\n    \n<article id=\"content\">\t\n<a id=\"hd-fade\"></a>       \n    \n<div class=\"pg-tit\">\n<h2 class=\"fd\">\n<span class=\"en1 fadeIn2\"><span class=\"fdtex\">Contact</span></span><br class=\"pcno\">\n<span class=\"jp fadeIn2\"><span class=\"fdtex\">お問合わせ</span></span>\n</h2>\n<!--pg-tit--></div>\t  \n\n\n\n<section id=\"sec1\">\n<div class=\"cons w1000\">\n    \n    \n<p class=\"lead1\">同仁社へご質問等ある方は、<br>\nお気軽に下記送信フォームよりお問合わせ下さい。</p>    \n  \n<p class=\"lead2\">お問合わせの内容によっては、ご返事にお時間を頂く場合もございますので、<br>\n予めご了承くださいますようお願い致します。</p>\n\n\n<div class=\"colum\">\n\n  <h3 class=\"m40\"><span>送信フォーム</span></h3>  \n    \n    \n\t\n\n<form method=\"post\" action=\"mail.php\" id=\"formCheck\">\n    \n<div class=\"inner\">\n <p class=\"lead\">全ての入力欄をご入力の上、送信してください。</p>\n    \n<table class=\"formtab\" width=\"400\" border=\"0\" cellspacing=\"0\" cellpadding=\"0\">\n\n  <tr>\n    <th class=\"hissu\" scope=\"row\">お問合わせの種類</th>\n    <td>\n\t\t\n<select name=\"お問合わせの種類\" class=\"validate[required]\" id=\"kind\">\n<option value=\"\" selected>お選び下さい</option>\n<option value=\"採用に関するお問合わせ\">採用について</option>\n<option value=\"ホスピタルリネンについて\">ホスピタルリネンについて</option>\n<option value=\"リネンサプライについて\">リネンサプライについて</option>\n<option value=\"ユニフォームについて\">ユニフォームについて</option>\n<option value=\"リースキンについて\">リースキンについて</option>\n<option value=\"ヘルスケアについて\">ヘルスケアについて</option>\n<option value=\"その他のお問合わせ\">その他のお問合わせ</option>\n</select>\n\t</td>\n    </tr>\n\n\n\n\n  <tr>\n    <th class=\"hissu\" scope=\"row\">お名前</th>\n    <td><input name=\"お名前\" type=\"text\" class=\"texfld-nomal katakana validate[required]\" id=\"name\" size=\"50\"   placeholder=\"例）佐藤 太郎\"/></td>\n    </tr>\n    \n    \n  <tr>\n    <th class=\"hissu\" scope=\"row\">フリガナ</th>\n    <td><input name=\"フリガナ\" type=\"text\" class=\"texfld-nomal katakana validate[required]\" id=\"furigana\" size=\"50\"   placeholder=\"例）サトウ タロウ\"/></td>\n    </tr>\n\n\n    \n  <tr>\n    <th scope=\"row\">会社名</th>\n    <td><input name=\"会社名\" type=\"text\" class=\"texfld-nomal\" id=\"furigana\" size=\"50\"   placeholder=\"例）株式会社 同仁社\"/></td>\n    </tr>   \n    \n    \n     \n  <tr>\n    <th class=\"hissu\" scope=\"row\">電話番号</th>\n    <td><input name=\"電話番号\" type=\"text\" class=\"texfld-nomal ascii validate[required,custom[phone]]\"  size=\"50\" placeholder=\"例）024-987-3456\"/></td>\n    </tr>\n\n    \n\n  <tr>\n    <th class=\"hissu\" scope=\"row\">メールアドレス</th>\n    <td><input name=\"Email\" type=\"text\" class=\"texfld-nomal ascii validate[required,custom[email]]\" id=\"email\" size=\"50\" placeholder=\"例）sample@ginga110.com\"/>\n    </td>\n  </tr>\n  \n \n  \n  \n  <tr class=\"last\">\n    <th class=\"hissu\" scope=\"row\">内容</th>\n    <td>\n      <label for=\"naiyou\"></label>\n      <textarea name=\"内容\" cols=\"40\" rows=\"10\" id=\"naiyou\" class=\"validate[required]\"></textarea></td>\n  </tr>\n</table>   \n    \n    \n<p class=\"kojin\">※<a href=\"/privacy/\">個人情報保護方針はこちら</a>をご覧ください。</p> \n    \n    \n\t\n<!--<div id=\"submit-box\">\t\n\t<input id=\"submit_button\" type=\"submit\" name=\"submit\" value=\"入力内容を確認する\">\n</div>\t-->    \n    \n\t\n<div id=\"submit-box\">\t\n<input type=\"submit\" id=\"submit_button\"   value=\"確認画面へ\">    \n<!--submit-box--></div>\t\t\n\t\n\t\n\t\n<!--inner--></div>\n\n\n</form>\n    \n    \n<!--colum--></div>       \n    \n    \n<!--cons--></div>\n<!--sec1--></section>\n\n    \n\n</article><!-- fin_content -->\n\n\n\n\t\n    \n  \n<p id=\"up\">\n<a href=\"#top\"><svg id=\"up.svg\" xmlns=\"http://www.w3.org/2000/svg\" width=\"139\" height=\"49.469\" viewBox=\"0 0 139 49.469\">\n  <defs>\n    <style>\n      .cls-1 {\n        fill: #ccc;\n      }\n\n      .cls-1, .cls-2 {\n        fill-rule: evenodd;\n      }\n\n      .cls-2 {\n        fill: none;\n        stroke: #CCC;\n        stroke-width: 1px;\n      }\n    </style>\n  </defs>\n  <path id=\"text\" class=\"cls-1\" d=\"M661.979,141.382l0.252-1.422h-3.078l-2.61,14.832h3.078l1.1-6.192a2.706,2.706,0,0,0,1.062,1.116,3.372,3.372,0,0,0,1.764.432,4.674,4.674,0,0,0,2.358-.639,5.725,5.725,0,0,0,1.908-1.818,6.976,6.976,0,0,0,1.062-2.727,7.364,7.364,0,0,0,.108-1.206,4.034,4.034,0,0,0-1-2.88,3.429,3.429,0,0,0-2.619-1.062,4.337,4.337,0,0,0-3.384,1.566h0Zm3.78,3.582a3.116,3.116,0,0,1-.981,1.827,2.489,2.489,0,0,1-1.683.675,1.754,1.754,0,0,1-1.3-.5,1.873,1.873,0,0,1-.5-1.386,3.636,3.636,0,0,1,.054-0.594,3.1,3.1,0,0,1,.972-1.818A2.474,2.474,0,0,1,664,142.5a1.785,1.785,0,0,1,1.3.5,1.879,1.879,0,0,1,.513,1.4,3.234,3.234,0,0,1-.054.558h0Zm3.918,0a7.46,7.46,0,0,0-.108,1.224,4.6,4.6,0,0,0,.45,2.1,3.28,3.28,0,0,0,1.269,1.377,3.615,3.615,0,0,0,1.88