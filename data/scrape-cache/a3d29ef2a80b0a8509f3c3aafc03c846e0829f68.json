         <a href=\"https://hi-niyaku.co.jp/\">\n                                <div class=\"menuSectionItem_title\">トップ</div>\n                            </a>\n                        </div>\n                        <!-- /.menuSectionItem -->\n\n                        <div class=\"menuSectionItem\">\n                            <a href=\"https://hi-niyaku.co.jp/about/\">\n                                <div class=\"menuSectionItem_title\">会社概要</div>\n                            </a>\n                        </div>\n                        <!-- /.menuSectionItem -->\n\n                        <ul class=\"menuSectionList\">\n                            <li><a href=\"https://hi-niyaku.co.jp/about/history/\">沿革</a></li>\n                        </ul>\n                        <!-- /.menuSectionList -->\n\n                    </div>\n                    <div class=\"menuContainer_item menuContainer_item-02\">\n\n                        <div class=\"menuSectionItem\">\n                            <a href=\"https://hi-niyaku.co.jp/business/\">\n                                <div class=\"menuSectionItem_title\">事業案内</div>\n                            </a>\n                        </div>\n                        <!-- /.menuSectionItem -->\n\n                        <ul class=\"menuSectionList\">\n                            <li><a href=\"https://hi-niyaku.co.jp/business/lumber/\">木材物流</a></li>\n                            <li><a href=\"https://hi-niyaku.co.jp/business/container/\">コンテナ物流</a></li>\n                            <li><a href=\"https://hi-niyaku.co.jp/business/automobile/\">車輌物流</a></li>\n                            <li><a href=\"https://hi-niyaku.co.jp/business/general/\">その他物流</a></li>\n                        </ul>\n                        <!-- /.menuSectionList -->\n\n                    </div>\n                </div>\n                <div class=\"menuContainer_item menuContainer_item-03\">\n                    <div class=\"menuSectionItem\">\n                        <a href=\"https://hi-niyaku.co.jp/recruit/\">\n                            <div class=\"menuSectionItem_title\">採用情報</div>\n                        </a>\n                    </div>\n                    <!-- /.menuSectionItem -->\n                    <div class=\"menuSectionItem\">\n                        <a href=\"https://hi-niyaku.co.jp/sdgs/\">\n                            <div class=\"menuSectionItem_title\">SDGsの取組</div>\n                        </a>\n                    </div>\n                    <!-- /.menuSectionItem -->\n\n                    <div class=\"menuSectionItem\">\n                        <a href=\"https://hi-niyaku.co.jp/contact/\">\n                            <div class=\"menuSectionItem_title\">お問い合せ</div>\n                        </a>\n                    </div>\n                    <!-- /.menuSectionItem -->\n\n                    <div class=\"menuSectionItem\">\n                        <a href=\"https://hi-niyaku.co.jp/sitemap/\">\n                            <div class=\"menuSectionItem_title\">サイトマップ</div>\n                        </a>\n                    </div>\n                    <!-- /.menuSectionItem -->\n\n                </div>\n\n            </div>\n        </div>\n        <!-- /.menuContainer -->\n\n\n<div class=\"topMainMovie\">\n    <div class=\"topMainMovie_movie\">\n        <video src=\"https://hi-niyaku.co.jp/wp-content/themes/niyaku-theme/cmn/movie/movie_top.mp4?v=202601260546\" autoplay muted loop></video>\n    </div>\n    <!-- /.topMainMovie_movie -->\n\n    <div class=\"topMainMovie_inner\">\n        <div class=\"topMainMovie_inner-wrap\">\n            <div class=\"topMainMovie_text01\">運ぶのは、モノと信頼</div>\n            <div class=\"topMainMovie_text02\">Transporting goods and trust</div>\n        </div>\n    </div>\n\n    <div class=\"topMainMovie_scroll\"><img src=\"https://hi-niyaku.co.jp/wp-content/themes/niyaku-theme/cmn/img/top/icon_scroll.svg?v=202601260546\" alt=\"\"></div>\n    <div class=\"topMainMovie_recbtn\"><a href=\"https://hi-niyaku.co.jp/recruit/\"><img src=\"https://hi-niyaku.co.jp/wp-content/themes/niyaku-theme/cmn/img/top/pic_toprecbtn.png?v=202601260546\" alt=\"採用情報はこちら\"></a></div>\n</div>\n<!-- /.topMainMovie -->\n\n<div class=\"topSecAbout\">\n    <div class=\"topSecAbout_inner\">\n        <div class=\"topSecAbout\">\n            <div class=\"topSecAbout_data js-left-item\">\n\n                <div class=\"topSecAbout_title\">\n                    <div class=\"topSecAbout_title-01\">About</div>\n                    <div class=\"topSecAbout_title-02\"><span>広島荷役株式会社について</span></div>\n                </div>\n\n                <dl class=\"topSecAbout_list\">\n                    <dt>港湾を中心とした現代荷役物流から<br>一貫物流まで進化を遂げる</dt>\n                    <dd>私たちは、設立から50年以上にわたり港湾運送を担い、時代の変化に柔軟に対応してきました。最新設備の導入やノウハウの蓄積により最適な荷役システムを構築し、倉庫整備によって一貫物流体制も確立。常にお客様のニーズに応える物流企業を目指しています。</dd>\n                </dl>\n\n                <div class=\"topCommonBtn\"><a href=\"https://hi-niyaku.co.jp/about/\">私たちについて</a></div>\n\n            </div>\n            <div class=\"topSecAbout_pic js-right-item\">\n                <img src=\"https://hi-niyaku.co.jp/wp-content/themes/niyaku-theme/cmn/img/top/pic_topabout.jpg?v=202601260545\" alt=\"\">\n            </div>\n        </div>\n        <!-- /.topSecAbout -->\n    </div>\n</div>\n<!-- /.topSecAbout -->\n\n<div class=\"topMidScroll\">\n    <div class=\"topMidScroll_item\"><img src=\"https://hi-niyaku.co.jp/wp-content/themes/niyaku-theme/cmn/img/top/icon_topmid.svg?v=202601260545\" alt=\"\"></div>\n</div>\n\n\n\n\n<div class=\"topBusinessSec\">\n\n    <div class=\"topBusinessSecHead\">\n        <div class=\"topBusinessSecHead_title\">Business</div>\n        <div class=\"topBusinessSecHead_subtitle\">事業案内</div>\n        <div class=\"topBusinessSecHead_text\">私たちは、港を拠点に木材物流、コンテナ物流、車両物流を手がけています。<br>それぞれ異なる特性を持つ貨物に向き合い、安全性と確実性を最優先に、日々の物流を滞りなく支えています。</div>\n    </div>\n    <!-- /.topBusinessSecHead -->\n\n    <div class=\"topBusinessSecMain\">\n        <div class=\"topBusinessSecMain_item js-left-item\">\n            <a href=\"https://hi-niyaku.co.jp/business/lumber/\">\n                <div class=\"topBusinessSecMain_title\">\n                    <div class=\"topBusinessSecMain_title-01\">木材物流</div>\n                    <div class=\"topBusinessSecMain_title-02\">Lumber</div>\n                </div>\n                <div class=\"topBusinessSecMain_pic\"><img src=\"https://hi-niyaku.co.jp/wp-content/themes/niyaku-theme/cmn/img/top/pic_topbusiness_01.jpg?v=202601260545\" alt=\"\"></div>\n            </a>\n        </div>\n        <div class=\"topBusinessSecMain_item js-right-item\">\n            <a href=\"https://hi-niyaku.co.jp/business/container/\">\n                <div class=\"topBusinessSecMain_title\">\n                    <div class=\"topBusinessSecMain_title-01\">コンテナ物流</div>\n                    <div class=\"topBusinessSecMain_title-02\">Container</div>\n                </div>\n                <div class=\"topBusinessSecMain_pic\"><img src=\"https://hi-niyaku.co.jp/wp-content/themes/niyaku-theme/cmn/img/top/pic_topbusiness_02.jpg?v=202601260545\" alt=\"\"></div>\n            </a>\n        </div>\n        <div class=\"topBusinessSecMain_item js-left-item\">\n            <a href=\"https://hi-niyaku.co.jp/business/automobile/\">\n                <div class=\"topBusinessSecMain_title\">\n                    <div class=\"topBusinessSecMain_title-01\">車輌物流</div>\n                    <div class=\"topBusinessSecMain_title-02\">Automobile</div>\n                </div>\n                <div class=\"topBusinessSecMain_pic\"><img src=\"https://hi-niyaku.co.jp/wp-content/themes/niyaku-theme/cmn/img/top/pic_topbusiness_03.jpg?v=202601260545\" alt=\"\"></div>\n            </a>\n        </div>\n        <div class=\"topBusinessSecMain_item js-right-item\">\n            <a href=\"https://hi-niyaku.co.jp/business/general/\">\n                <div class=\"topBusinessSecMain_title\">\n                    <div cla