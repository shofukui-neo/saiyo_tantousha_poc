            <li><a href=\"/support/\">お客さまサポートトップ</a></li>\r\n              <li><a href=\"/support/faq/\">よくあるご質問</a></li>\r\n              <li>\r\n                <div>お問い合わせ・資料請求</div>\r\n                <ul class=\"c-header-nav-sp-list03\">\r\n                  <li><a href=\"https://qmnb.f.msgs.jp/webapp/form/26692_qmnb_1/index.do\" target=\"_blank\" rel=\"noopener\">ソリューション・製品に関するお問い合わせ</a></li>\r\n                  <li><a href=\"https://yagb.f.msgs.jp/webapp/form/21656_yagb_1/index.do\" target=\"_blank\" rel=\"noopener\">e-コレクト&reg;をご利用中の方のお問い合わせ</a></li>\r\n                  <li><a href=\"https://qmnb.f.msgs.jp/webapp/form/26692_qmnb_2/index.do\" target=\"_blank\" rel=\"noopener\">当社サービス以外のお問い合わせ</a></li>\r\n                  <li><a href=\"https://qmnb.f.msgs.jp/webapp/form/26692_qmnb_3/index.do\" target=\"_blank\" rel=\"noopener\">資料請求</a></li>\r\n                </ul>\r\n              </li>\r\n            </ul>\r\n          </li>\r\n          <li><a href=\"/strength/\">SGシステムの強み</a></li>\r\n          <li>\r\n            <button class=\"js-header-sp-item\" type=\"button\">採用情報</button>\r\n            <ul class=\"c-header-nav-sp-list02 js-header-sp-item__contents\">\r\n              <li><a href=\"/recruit/\">採用情報トップ</a></li>\r\n              <li><a href=\"/recruit/job/\">仕事を知る</a></li>\r\n              <li><a href=\"/recruit/people/\">人を知る</a></li>\r\n              <li><a href=\"/recruit/corporate/\">会社を知る</a></li>\r\n              <li><a href=\"/recruit/corporate/3min/\">数字で分かるSGシステム</a></li>\r\n              <li><a href=\"/recruit/guideline/\">募集要項</a></li>\r\n            </ul>\r\n          </li>\r\n          <li>\r\n            <button class=\"js-header-sp-item\" type=\"button\">企業情報</button>\r\n            <ul class=\"c-header-nav-sp-list02 js-header-sp-item__contents\">\r\n              <li><a href=\"/company/\">企業情報トップ</a></li>\r\n              <li><a href=\"/company/message/\">ごあいさつ</a></li>\r\n              <li><a href=\"/company/outline/\">会社概要</a></li>\r\n              <li><a href=\"/company/history/\">沿革</a></li>\r\n              <li><a href=\"/company/branch/\">事業所一覧</a></li>\r\n              <li><a href=\"/company/internal/\">内部統制基本方針</a></li>\r\n              <!--<li><a href=\"/company/faq/\">よくあるご質問</a></li>-->\r\n              <li><a href=\"https://www.sg-hldgs.co.jp/company/philosophy/\" target=\"_blank\" rel=\"noopener\">企業理念・行動憲章</a></li>\r\n            </ul>\r\n          </li>\r\n        </ul>\r\n      </div>\r\n      <div class=\"c-header-nav-sp__sub\">\r\n        <ul>\r\n          <li><a href=\"/service/e-collect/guide/\">e-コレクト&reg;のお申込</a></li>\r\n          <li><a href=\"https://www.e-service.sagawa-exp.co.jp/portal/do/login/show\" target=\"_blank\" rel=\"noopener\">スマートクラブログイン</a></li>\r\n        </ul>\r\n      </div>\r\n      <div class=\"c-header-nav-sp__contact\">\r\n        <a href=\"/support/#inquiry\">お問い合わせ</a>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</header>\r\n<div class=\"l-header__overlay\"></div>\n    <main class=\"l-main\">\n      <div class=\"recruit-header\">\r\n  <div class=\"recruit-header__inner\">\r\n    <div class=\"recruit-header__heading\">\r\n      <span>RECRUIT</span><span>SGシステムの採用情報</span>\r\n    </div>\r\n    <button class=\"recruit-header__menu\" type=\"button\"></button>\r\n    <div class=\"recruit-header__nav\">\r\n      <div>\r\n        <ul class=\"recruit-header__links\">\r\n          <li><a href=\"/recruit/\" class=\"recruit-header__item\" data-url=\"\"><span>トップ</span></a></li>\r\n          <li><a href=\"/recruit/corporate/\" class=\"recruit-header__item\" data-url=\"corporate\"><span>会社を知る</span></a></li>\r\n          <li><a href=\"/recruit/job/\" class=\"recruit-header__item\" data-url=\"job\"><span>仕事を知る</span></a></li>\r\n          <li><a href=\"/recruit/people/\" class=\"recruit-header__item\" data-url=\"people\"><span>人を知る</span></a></li>\r\n          <li><a href=\"/recruit/faq/\" class=\"recruit-header__item\" data-url=\"faq\"><span>よくあるご質問</span></a></li>\r\n        </ul>\r\n        <ul class=\"recruit-header__cta\">\r\n          <li><a href=\"https://job.mynavi.jp/27/pc/search/corp88148/outline.html\" target=\"_blank\" class=\"recruit-header__btn\"><span>新卒採用（マイナビ）</span></a></li>\r\n          <li><a href=\"https://jsd.jposting.net/sg-systems/\" target=\"_blank\" rel=\"noopener\" class=\"recruit-header__btn -career\"><span>中途採用</span></a></li>\r\n        </ul>\r\n      </div>\r\n    </div>\r\n  </div>\r\n  <div class=\"recruit-header__overlay\"></div>\r\n</div>\n            <div class=\"recruit-title\">\r\n        <h1>会社を知る</h1>\r\n        <div class=\"recruit-title__pagelink\">\r\n          <ul>\r\n            <li><a href=\"#a1\"><span>PHILOSOPHY</span><span>SGホールディングス<br class=\"sp:view pc:view\">グループ理念</span></a></li>\r\n            <li><a href=\"#a2\"><span>ABOUT</span><span>私たちについて</span></a></li>\r\n            <li><a href=\"#a3\"><span>DATA</span><span>数字で分かる<br class=\"pc:view\">SGシステム</span></a></li>\r\n            <li><a href=\"#a4\"><span>WELFARE</span><span>福利厚生</span></a></li>\r\n          </ul>\r\n        </div>\r\n      </div>\r\n      <div class=\"recruit-block\">\r\n        <div class=\"recruit-block__inner\">\r\n          <h2 class=\"recruit-heading u-mb-80 u-sp-mb-24\" id=\"a1\"><span>PHILOSOPHY</span><span>SGホールディングスグループ理念</span></h2>\r\n          <div class=\"recruit-corp-philosophy\">\r\n            <div class=\"recruit-corp-philosophy__heading\">\r\n              <span>“「飛脚の<ruby>精神<rt>こころ</rt></ruby>」を胸に、<br class=\"sp:view\">お客さまの期待に応え続ける”</span>\r\n              <span>信頼、創造、挑戦</span>\r\n            </div>\r\n            <div class=\"recruit-corp-philosophy__contents\">\r\n              <p>SGホールディングスグループは、</p>\r\n              <ul>\r\n                <li>お客さまと社会の信頼に応え共に成長します</li>\r\n                <li>新しい価値を創造し社会の発展に貢献します</li>\r\n                <li>常に挑戦を続けあらゆる可能性を追求します</li>\r\n              </ul>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n      <div class=\"recruit-block -bg-pale-blue\">\r\n        <div class=\"recruit-block__inner\">\r\n          <div class=\"l-section\">\r\n            <h2 class=\"recruit-heading u-mb-40 u-sp-mb-24\" id=\"a2\"><span>ABOUT</span><span>私たちについて</span></h2>\r\n            <h3 class=\"recruit-heading -medium u-mb-40 u-sp-mb-32\">SGホールディングスグループが<br class=\"sp:view\">展開する事業</h3>\r\n            <p class=\"u-font-l u-ta-c u-mb-56 u-sp-mb-24\">\r\n              SGホールディングスグループは、<br class=\"sp-tb:view\">佐川急便をはじめとする<br class=\"sp:view\">総合物流企業グループです。<br>\r\n              人々の生活に欠かせない社会インフラとして、<br class=\"sp:view\">豊かな暮らしを実現するため、<br>グループが持つ多様な機能を組み合わせ、<br class=\"sp:view\">社会の発展と安定に貢献します。\r\n            </p>\r\n            <div class=\"c-movie\">\r\n              <video src=\"/assets/mov/recruit/corporate/about.mp4\" controls playsinline controlsList=\"nodownload\"></video>\r\n            </div>\r\n            <div class=\"recruit-corp-about-arrow\"></div>\r\n            <h3 class=\"recruit-heading -medium u-mb-40 u-sp-mb-32\">物流×ITのリーディングカンパニーとして<br class=\"sp-tb:view\">お客さまの企業価値を高める<br>それが、私たちSGシステムの<br class=\"sp:view\">ミッションです</h3>\r\n            <p class=\"u-font-l u-ta-c u-mb-40\">\r\n              SGシステムは、IT・デジタルを通じて<br class=\"sp:view\">物流課題を解決することで、<br class=\"sp-tb:view\">お客さまの企業価値向上を目指します。<br>\r\n              お客さまの多様化・複雑化する課題に<br class=\"sp:view\">応えるため、幅広い知識と経験、<br class=\"sp-tb:view\">新しい技術への探求により進化し続けます。\r\n            </p>\r\n            <figure class=\"c-figure\"><img src=\"/assets/img/recruit/corporate/img_about01.jpg\" alt=\"SGシステムは世の中の物流をITで支えています\" loading=\"lazy\"></figure>\r\n          </div>\r\n          <div class=\"l-section\">\r\n            <h3 class=\"recruit-heading -medium u-mb-40 u-sp-mb-32\">SGシステムの事業</h3>\r\n            <p class=\"u-font-l u-ta-c u-mb-40\">SGシステムはロジスティクス、<br class=\"sp-tb:view\">バックオフィス、決済など<br class=\"sp:view\">多様な事業をITで解決します。</p>\r\n            <figure class=\"c-figure\"><img src=\"/recruit/assets/corporate_img_about02.png\" alt=\"SGシステムの事業を示した円グラフ\" loading=\"lazy\"></figure>\r\n            <div class=\"c-btn-wrap  u-mt-80 u-sp-mt-32\">\r\n              <a href=\"/recruit/job/\" class=\"recruit-btn\"><span>仕事を知る</span></a>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n      <div class=\"recruit-block\">\r\n        <div class=\"recruit-block__inner u-pb-0\">\r\n          <a href=\"/recruit/corporate/3min/\" id=\"a3\"><img src=\"/assets/img/recruit/corporate/img_3minutes.jpg\" alt=\"数字で分かるSGシステム\" loading=\"lazy\"></a>\r\n        </div>\r\n      </div>\r\n      <div class=\"recruit-block\">\r\n        <div class=\"recruit-block__inner\">\r\n          <h2 class=\"recruit-heading u-mb-40 u-sp-mb-24\" id=\"a4\"><span>WELFARE</span><span>福利厚生</span></h2>\r\n          <div class=\"recruit-corp-grid\">\r\n            <div class=\"recruit-corp-grid__item -col-3 -tb-col-12\">\r\n              <div class=\"recruit-corp-welfare-item\">\r\n                <div class=\"recruit-corp-welfare-item__ttl\">職場環境</div>\r\n                <div class=\"recruit-corp-welfare-item__img\"><img src=\"/assets/img/recruit/corporate/img_welfare01.png\" alt=\"\" loading=\"lazy\"></div>\r\n                <ul class=\"recruit-corp-welfare-item__list\">\r\n                  <li class=\"recruit-corp-welfare-item__list-item -col-12\">\r\n                    <div class=\"recruit-corp-welfare-item__list-ttl\">在宅勤務</div>\r\n                    <p class=\"recruit-corp-welfare-item__list-txt\">自宅での業務が可能です。</p>\r\n                    <small>※業務内容など条件あり</small>\r\n                  </li>\r\n                </ul>\r\n              </div>\r\n            </div>\r\n            <div class=\"recruit-corp-grid__item -col-9 -tb-col-12\">\r\n              <div class=\"recruit-corp-welfare-item\">\r\n                <div class=\"recruit-corp-welfare-item__ttl\">休暇関係</div>\r\n                <div class=\"recruit-corp-welfare-item__img\"><img src=\"/assets/img/recruit/corporate/img_welfare02.png\" alt=\"\" loading=\"lazy\"></div>\r\n                <ul class=\"recruit-corp-welfare-item__list\">\r\n                  <li class=\"recruit-corp-welfare-item__list-item -col-4\">\r\n                    <div class=\"recruit-corp-welfare-item__list-ttl\">年次有給休暇</div>\r\n                    <p class=\"recruit-corp-welfare-item__list-txt\">入社6カ月後に10日付与し、勤続6年6カ月以上で最大20日付与します。</p>\r\n                  </li>\r\n                  <li class=\"recruit-corp-welfare-item__list-item -col-4\">\r\n                    <div class=\"recruit-corp-welfare-item__list-ttl\">特別休暇<br class=\"pc:view\">（慶弔関係など）</div>\r\n                    <p class=\"recruit-corp-welfare-item__list-txt\">結婚、出産、忌引などで取得が可能です。</p>\r\n                  </li>\r\n                  <li class=\"recruit-corp-welfare-item__list-item -col-4\">\r\n                    <div class=\"recruit-corp-welfare-item__list-ttl\">時間単位有休</div>\r\n                    <p class=\"recruit-corp-welfare-item__list-txt\">時間単位で有給休暇の取得が可能です。</p>\r\n                  </li>\r\n                </ul>\r\n              </div>\r\n            </div>\r\n            <div class=\"recruit-corp-grid__item -col-6 -tb-col-12\">\r\n              <div class=\"recruit-corp-welfare-item\">\r\n                <div class=\"recruit-corp-welfare-item__ttl\">育児・介護関係</div>\r\n                <div class=\"recruit-corp-welfare-item__img\"><img src=\"/assets/img/recruit/corporate/img_welfare03.png\" alt=\"\" loading=\"lazy\"></div>\r\n                <ul class=\"recruit-corp-welfare-item__list\">\r\n                  <li class=\"recruit-corp-welfare-item__list-item -col-6\">\r\n                    <div class=\"recruit-corp-welfare-item__list-ttl\">産前産後休業</div>\r\n                    <p class=\"recruit-corp-welfare-item__list-txt\">産前6週間（多胎の場合は14週間）、産後は8週間の休暇となります。</p>\r\n                  </li>\r\n                  <li class=\"recruit-corp-welfare-item__list-item -col-6\">\r\n                    <div class=\"recruit-corp-welfare-item__list-ttl\">育児休業</div>\r\n                    <p class=\"recruit-corp-welfare-item__list-txt\">子どもが3歳になる前日まで取得が可能です。</p>\r\n                  </li>\r\n                  <li class=\"recruit-corp-welfare-item__list-item -col-6\">\r\n                    <div class=\"recruit-corp-welfare-item__list-ttl\">短時間勤務</div>\r\n                    <p class=\"recruit-corp-welfare-item__list-txt\">6時間以上8時間未満で短時間勤務が可能です。</p>\r\n                  </li>\r\n                  <li class=\"recruit-corp-welfare-item__list-item -col-6\">\r\n                    <div class=\"recruit-corp-welfare-item__list-ttl\">介護・看護休業</div>\r\n                    <p class=\"recruit-corp-welfare-item__list-txt\">介護や看護による休暇の取得が可能です。</p>\r\n                  </li>\r\n                </ul>\r\n              </div>\r\n            </div>\r\n            <div class=\"recruit-corp-grid__item -col-6 -tb-col-12\">\r\n              <div class=\"recruit-corp-welfare-item\">\r\n                <div class=\"recruit-corp-welfare-item__ttl\">表彰関係</div>\r\n                <div class=\"recruit-corp-welfare-item__img\"><img src=\"/assets/img/recruit/corporate/img_welfare04.png\" alt=\"\" loading=\"lazy\"></div>\r\n                <ul class=\"recruit-corp-welfare-item__list\">\r\n                  <li class=\"recruit-corp-welfare-item__list-item -col-12\">\r\n                    <div class=\"recruit-corp-welfare-item__list-ttl\">永年勤続表彰</div>\r\n                    <p class=\"recruit-corp-welfare-item__list-txt\">勤続年数20年を迎えた社員が表彰される制度です。</p>\r\n                  </li>\r\n                  <li class=\"recruit-corp-welfare-item__list-item -col-12\">\r\n                    <div class=\"recruit-corp-welfare-item__list-ttl\">優秀社員表彰</div>\r\n                    <p class=\"recruit-corp-welfare-item__list-txt\">1年を通して優秀な働きをした社員が表彰される制度です。</p>\r\n                  </li>\r\n                </ul>\r\n              </div>\r\n            </div>\r\n            <div class=\"recruit-corp-grid__item -col-6 -tb-col-12\">\r\n              <div class=\"recruit-corp-welfare-item\">\r\n                <div class=\"recruit-corp-welfare-item__ttl\">健康関係</div>\r\n                <div class=\"recruit-corp-welfare-item__img\"><img src=\"/assets/img/recruit/corporate/img_welfare05.png\" alt=\"\" loading=\"lazy\"></div>\r\n                <ul class=\"recruit-corp-welfare-item__list\">\r\n                  <li class=\"recruit-corp-welfare-item__list-item -col-12\">\r\n                    <div class=\"recruit-corp-welfare-item__list-ttl\">健康相談</div>\r\n                    <p class=\"recruit-corp-welfare-item__list-txt\">医療・介護・育児・メンタルヘルスなどを専門スタッフへ相談可能です。</p>\r\n                  </li>\r\n                  <li class=\"recruit-corp-welfare-item__list-item -col-12\">\r\n                    <div class=\"recruit-corp-welfare-item__list-ttl\">各種予防・検診補助</div>\r\n                    <p class=\"recruit-corp-welfare-item__list-txt\">人間ドックやインフルエンザなどの予防・検診を補助します。</p>\r\n                  </li>\r\n                </ul>\r\n              </div>\r\n            </div>\r\n            <div class=\"recruit-corp-grid__item -col-6 -tb-col-12\">\r\n              <div class=\"recruit-corp-welfare-item\">\r\n                <div class=\"recruit-corp-welfare-item__ttl\">共済関係</div>\r\n                <div class=\"recruit-corp-welfare-item__img\"><img src=\"/assets/img/recruit/corporate/img_welfare06.png\" alt=\"\" loading=\"lazy\"></div>\r\n                <ul class=\"recruit-corp-welfare-item__list\">\r\n                  <li class=\"recruit-corp-welfare-item__list-item -col-6\">\r\n                    <div class=\"recruit-corp-welfare-item__list-ttl\">ENJOY給付金</div>\r\n                    <p class=\"recruit-corp-welfare-item__list-txt\">「楽しい！」と感じた体験に対し費用を補助します（年1回）。</p>\r\n                  </li>\r\n                  <li class=\"recruit-corp-welfare-item__list-item -col-6\">\r\n                    <div class=\"recruit-corp-welfare-item__list-ttl\">スポーツ大会給付金</div>\r\n                    <p class=\"recruit-corp-welfare-item__list-txt\">スポーツ大会への参加費用を補助します。</p>\r\n                  </li>\r\n                  <li class=\"recruit-corp-welfare-item__list-item -col-6\">\r\n                    <div class=\"recruit-corp-welfare-item__list-ttl\">資格取得祝金</div>\r\n                    <p class=\"recruit-corp-welfare-item__list-txt\">資格取得者へ受験費用を一部補助する制度です。</p>\r\n                  </li>\r\n                  <li class=\"recruit-corp-welfare-item__list-item -col-6\">\r\n                    <div class=\"recruit-corp-welfare-item__list-ttl\">慶弔見舞金</div>\r\n                    <p class=\"recruit-corp-welfare-item__list-txt\">慶弔事に対し祝金・お見舞金が⽀給される制度です。</p>\r\n                  </li>\r\n                </ul>\r\n              </div>\r\n            </div>\r\n            <div class=\"recruit-corp-grid__item -col-12\">\r\n              <div class=\"recruit-corp-welfare-item\">\r\n                <div class=\"recruit-corp-welfare-item__ttl\">その他</div>\r\n                <div class=\"recruit-corp-welfare-item__img\"><img src=\"/assets/img/recruit/corporate/img_welfare07.png\" alt=\"\" loading=\"lazy\"></div>\r\n                <ul class=\"recruit-corp-welfare-item__list\">\r\n                  <li class=\"recruit-corp-welfare-item__list-item -col-4\">\r\n                    <div class=\"recruit-corp-welfare-item__list-ttl\">保養施設</div>\r\n                    <p class=\"recruit-corp-welfare-item__list-txt\">国内3カ所、国外1カ所の施設を利用できます。</p>\r\n                  </li>\r\n                  <li class=\"recruit-corp-welfare-item__list-item -col-4\">\r\n                    <div class=\"recruit-corp-welfare-item__list-ttl\">独身寮制度</div>\r\n                    <p class=\"recruit-corp-welfare-item__list-txt\">新卒・入社6年目まで会社が家賃の半額を負担する借り上げ独身寮制度があります。</p>\r\n                  </li>\r\n                  <li class=\"recruit-corp-welfare-item__list-item -col-4\">\r\n                    <div class=\"recruit-corp-welfare-item__list-ttl\">退職金制度</div>\r\n                    <p class=\"recruit-corp-welfare-item__list-txt\">確定拠出年金制度（DC）を導入しています。</p>\r\n                  </li>\r\n                </ul>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n      <div class=\"recruit-entry\">\r\n  <div class=\"recruit-entry__block\">\r\n    <h2 class=\"recruit-entry__heading\">ENTRY</h2>\r\n    <p class=\"recruit-entry__lead\">SGシステムで一緒に<br class=\"sp-tb:view\">未来を作りませんか</p>\r\n    <p class=\"recruit-entry__txt\">私たちとこれからの物流を変える一歩を<br class=\"sp:view\">踏み出しませんか？<br>\r\n      エントリーはこちらからお願いします。</p>\r\n    <div class=\"recruit-entry__btn\">\r\n      <a href=\"https://job.mynavi.jp/27/pc/search/corp88148/outline.html\" target=\"_blank\" rel=\"noopener\" class=\"recruit-btn\"><span>新卒採用（マイナビ）</span></a>\r\n      <a href=\"https://jsd.jposting.net/sg-systems/\" target=\"_blank\" rel=\"noopener\" class=\"recruit-btn\"><span>中途採用</span></a>\r\n    </div>\r\n    <a href=\"https://qmnb.f.msgs.jp/webapp/form/26692_qmnb_2/index.do\" target=\"_blank\" rel=\"noopener\" class=\"recruit-entry__link01\">\r\n      <div>採用に関するお問い合わせ</div>\r\n    </a>\r\n    <a href=\"https://www.sg-hldgs.co.jp/recruit/group-recruit/\" target=\"_blank\" rel=\"noopener\" class=\"recruit-entry__link02\">\r\n      <div>SGホールディングスグループ合同採用募集</div>\r\n    </a>\r\n  </div>\r\n</div>\r\n<div class=\"l-block\">\r\n  <div class=\"l-block__inner\">\r\n    <h3 class=\"recruit-heading -medium u-mb-40 u-sp-mb-32\">関連リンク</h3>\r\n    <div class=\"c-btn-wrap\">\r\n      <a href=\"/strength/\" class=\"recruit-btn\"><span>SGシステムの強み</span></a>\r\n    </div>\r\n  </div>\r\n</div>\r\n<div class=\"recruit-bottom\">\r\n  <button class=\"recruit-bottom__open\" type=\"button\">応募する</button>\r\n  <div class=\"recruit-bottom__modal\">\r\n    <div class=\"recruit-bottom__heading\">応募する</div>\r\n    <p class=\"recruit-bottom__txt\">物流×ITのリーディングカンパニーを目指し、<br>\r\n      活躍していただける人材を募集しています。</p>\r\n    <div class=\"recruit-bottom__cta\">\r\n      <a href=\"https://job.mynavi.jp/27/pc/search/corp88148/outline.html\" target=\"_blank\" rel=\"noopener\" class=\"recruit-bottom__btn\"><span>新卒採用（マイナビ）</span></a>\r\n      <!--<a href=\"\" target=\"_blank\" rel=\"noopener\" class=\"recruit-bottom__btn\"><span>新卒採用（リクナビ）</span></a>-->\r\n      <a href=\"https://jsd.jposting.net/sg-systems/\" target=\"_blank\" rel=\"noopener\" class=\"recruit-bottom__btn\"><span>中途採用</span></a>\r\n      <a href=\"https://qmnb.f.msgs.jp/webapp/form/26692_qmnb_2/index.do\" target=\"_blank\" rel=\"noopener\" class=\"recruit-bottom__btn -contact\"><span>お問い合わせ</span></a>\r\n    </div>\r\n    <button class=\"recruit-bottom__close\"></button>\r\n  </div>\r\n</div>\r\n      <div class=\"l-breadcrumb\">\r\n        <div class=\"l-breadcrumb__inner\">\r\n          <ol class=\"l-breadcrumb__list\">\r\n            <li class=\"l-breadcrumb__item\"><a href=\"/\">ホーム</a></li>\r\n            <li class=\"l-breadcrumb__item\"><a href=\"/recruit/\">採用情報</a></li>\r\n            <li class=\"l-breadcrumb__item\"><a href=\"/recruit/corporate/\">会社を知る</a></li>\r\n          </ol>\r\n        </div>\r\n      </div>\n    </main>\n    ﻿<footer class=\"l-footer\">\r\n  <div class=\"l-footer__pagetop\">\r\n    <a href=\"#\"></a>\r\n  </div>\r\n  <div class=\"l-footer__head\">\r\n    <div class=\"l-footer__logo\">\r\n      <div>\r\n        <span>物流×ITのリーディングカンパニー</span>\r\n        <div>\r\n          <a href=\"https://www.sg-hldgs.co.jp/\" target=\"_blank\" rel=\"noopener\"><img src=\"/assets/img/common/logo_sgh.svg\" alt=\"SGホールディングス\"></a>\r\n          <a href=\"/\"><img src=\"/assets/img/common/logo_sgsystem.svg\" alt=\"SGシステム株式会社\"></a>\r\n        </div>\r\n      </div>\r\n    </div>\r\n    <div class=\"l-footer__company\">\r\n      <dl>\r\n        <div>\r\n          <dt>本社</dt>\r\n          <dd>〒601-8104<br>\r\n            京都府京都市南区上鳥羽角田町25</dd>\r\n        </div>\r\n        <div>\r\n          <dt>東京本社</dt>\r\n          <dd>\r\n            〒136-0075<br>\r\n            東京都江東区新砂1-8-2 <br class=\"sp:view\">SGHビル新砂Ⅱ\r\n          </dd>\r\n        </div>\r\n      </dl>\r\n    </div>\r\n  </div>\r\n  <div class=\"l-footer__nav\">\r