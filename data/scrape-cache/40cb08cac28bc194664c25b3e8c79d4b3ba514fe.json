" href=\"/\"><span>KDDIホーム</span></a></li>\n<li><span class=\"main-breadcrumb__type--nolink\"><span>採用情報</span></span></li>\n</ol>\n<!--BreadcrumbAreaEnd--> <!--/Main__guide--></div>\n<div class=\"Main__head\">\n<div class=\"cmn-heading1\">\n<div class=\"cmn-heading1__inner\">\n<h1 class=\"cmn-heading1__title\">採用情報</h1>\n</div>\n</div>\n<!-- ln_20251003_01 -->\n<div class=\"cmn-lower-wrap\">\n<div class=\"cmn-lower-wrap__inner\"><nav class=\"cmn-lower-main-lnav--top js-lower-main-lnav\" aria-label=\"採用情報メニュー\">\n<ul class=\"cmn-lower-main-lnav__stage1 js-lower-main-lnav__stage1\">\n<li><a href=\"https://career.kddi.com/freshers/\" class=\"cmn-lower-main-lnav__stage1__type\" target=\"_blank\" rel=\"noopener\">新卒採用<img src=\"/extlib/common/img_new/cmn_ic02_02.svg\" alt=\"新規ウィンドウが開きます\" class=\"mls\" width=\"10\" height=\"10\"></a></li>\n<li><a href=\"https://career.kddi.com/career/recruit/\" class=\"cmn-lower-main-lnav__stage1__type\" target=\"_blank\" rel=\"noopener\">キャリア採用<img src=\"/extlib/common/img_new/cmn_ic02_02.svg\" alt=\"新規ウィンドウが開きます\" class=\"mls\" width=\"10\" height=\"10\"></a></li>\n<li><a href=\"/recruit/freshers/\" class=\"cmn-lower-main-lnav__stage1__type\">社員訪問ルール<br class=\"util-pc-hidden\">について</a></li>\n<li><a href=\"https://career.kddi.com/diversity/challenged/\" class=\"cmn-lower-main-lnav__stage1__type\" target=\"_blank\" rel=\"noopener\">障がい者採用<img src=\"/extlib/common/img_new/cmn_ic02_02.svg\" alt=\"新規ウィンドウが開きます\" class=\"mls\" width=\"10\" height=\"10\"></a></li>\n<li><a href=\"https://career.kddi.com/group/\" class=\"cmn-lower-main-lnav__stage1__type\" target=\"_blank\" rel=\"noopener\">グループ企業での採用<img src=\"/extlib/common/img_new/cmn_ic02_02.svg\" alt=\"新規ウィンドウが開きます\" class=\"mls\" width=\"10\" height=\"10\"></a></li>\n<li><a href=\"/recruit/rehirement/\" class=\"cmn-lower-main-lnav__stage1__type\">KDDI退職者向け情報</a></li>\n<li><a href=\"/recruit/detachment/\" class=\"cmn-lower-main-lnav__stage1__type\">KDDI退職者の派遣登録制度</a></li>\n<li><a href=\"/recruit/group/oversea/\" class=\"cmn-lower-main-lnav__stage1__type\">海外現地法人の採用</a></li>\n</ul>\n</nav></div>\n</div>\n<!-- ln_20251003_01 --> <!--/Main__head--></div>\n<div class=\"Main__body\">\n<div class=\"Main__content\">\n<section>\n<div class=\"cmn-heading2\">\n<div class=\"cmn-heading2__inner\">\n<h2 class=\"cmn-heading2__title\">KDDI採用ポータルサイト（新卒採用・インターンシップ・キャリア採用）</h2>\n</div>\n</div>\n<div class=\"cmn-card-v3-wrap\">\n<div class=\"cmn-card-v3\"><a href=\"https://career.kddi.com/\" class=\"cmn-card-v3__type\" target=\"_blank\" rel=\"noopener\">\n<div class=\"cmn-card-v3__head\">\n<div class=\"cmn-card-v3__image\"><img src=\"/extlib/corporate/recruit/index/top_img.jpg\" alt=\"KDDI RECRUITING 通信で、何する？詳しくはこちら\" width=\"1256\" height=\"440\"></div>\n</div>\n<span class=\"cmn-visually-hidden\">新規ウィンドウで開く</span> </a></div>\n</div>\n</section>\n<section>\n<div class=\"cmn-heading2\">\n<div class=\"cmn-heading2__inner\">\n<h2 class=\"cmn-heading2__title\">新卒採用活動における社員訪問ルールについて</h2>\n</div>\n</div>\n<div class=\"cmn-button-wrap\">\n<div class=\"cmn-button\"><a href=\"/corporate/recruit/freshers/\" class=\"cmn-button__type\"><span class=\"cmn-button__label\">詳細はこちらをご覧ください</span></a></div>\n</div>\n</section>\n<section>\n<div class=\"cmn-heading2\">\n<div class=\"cmn-heading2__inner\">\n<h2 class=\"cmn-heading2__title\">各種採用について</h2>\n</div>\n</div>\n<div class=\"cmn-card-v2-wrap\">\n<div class=\"cmn-card-v2\">\n<div class=\"cmn-card-v2__type\"><a href=\"https://career.kddi.com/diversity/challenged/\" class=\"cmn-card-v2__head\" target=\"_blank\" rel=\"noopener\">\n<div class=\"cmn-card__image\"><img src=\"/extlib/corporate/recruit/index/img_disabilities.jpg\" alt=\"\" width=\"476\" height=\"277\"></div>\n<span class=\"cmn-visually-hidden\">新規ウィンドウで開く</span> </a>\n<div class=\"cmn-card-v2__body\">\n<div class=\"cmn-card-v2__title\">障がい者採用</div>\n<p class=\"cmn-card-v2__description\">KDDIは障がいのある方の採用を積極的に進めています。<br>また、グループ企業であるKDDIチャレンジドにおいても、障がいのある方の採用を随時行っております。</p>\n<div class=\"cmn-card-v2__link\"><a href=\"https://www.kddichallenged.com/\" class=\"cmn-card-v2__link__type--blank\" target=\"_blank\" rel=\"noopener\">KDDIチャレンジド<span class=\"cmn-visually-hidden\">新規ウィンドウで開く</span></a></div>\n</div>\n</div>\n</div>\n<div class=\"cmn-card-v2\">\n<div class=\"cmn-card-v2__type\"><a href=\"https://career.kddi.com/group/\" target=\"_blank\" rel=\"noopener\" class=\"cmn-card-v2__head\">\n<div class=\"cmn-card__image\"><img src=\"/extlib/corporate/recruit/index/img_group.png\" alt=\"Spark Your Journey KDDI\" width=\"476\" height=\"277\"></div>\n</a>\n<div class=\"cmn-card-v2__body\">\n<div class=\"cmn-card-v2__title\">グループ企業での採用</div>\n<p class=\"cmn-card-v2__description\">グループ企業各社の採用情報はこちらからご覧いただけます。</p>\n<div class=\"cmn-card-v2__link-icon blank\"><span class=\"cmn-visually-hidden\">新規ウィンドウで開く</span></div>\n</div>\n</div>\n</div>\n</div>\n<div class=\"cmn-list-wrap\">\n<ul class=\"cmn-link-list-v2\">\n<li><a href=\"/corporate/recruit/rehirement/\" class=\"cmn-link-list-v2__type\"><span class=\"cmn-link-list-v2__label\">KDDI退職者向け情報</span></a></li>\n<li><a href=\"/corporate/recruit/detachment/\" class=\"cmn-link-list-v2__type\"><span class=\"cmn-link-list-v2__label\">KDDI退職者の派遣登録制度</span></a></li>\n<li><a href=\"/corporate/recruit/group/oversea/\" class=\"cmn-link-list-v2__type\"><span class=\"cmn-link-list-v2__label\">海外現地法人の採用</span></a></li>\n</ul>\n</div>\n</section>\n<section>\n<div class=\"cmn-heading2\">\n<div class=\"cmn-heading2__inner\">\n<h2 class=\"cmn-heading2__title\">KDDIを知る</h2>\n</div>\n</div>\n<div class=\"cmn-card-wrap\" data-card-col-pc=\"3\">\n<div class=\"cmn-card\"><a href=\"https://career.kddi.com/andkddi/\" class=\"cmn-card__type--blank\" target=\"_blank\" rel=\"noopener\">\n<div class=\"cmn-card__head\">\n<div class=\"cmn-card__image\"><img src=\"/extlib/corporate/recruit/index/img_andkddi.jpg\" alt=\"\" width=\"357\" height=\"153\"></div>\n</div>\n<div class=\"cmn-card__body\">\n<div class=\"cmn-card__title\">&amp;KDDI</div>\n<p class=\"cmn-card__description\">企業文化や働き方など、採用に関わるコンテンツをご覧いただけます。</p>\n</div>\n<span class=\"cmn-visually-hidden\">新規ウィンドウで開く</span> </a></div>\n<div class=\"cmn-card\"><a href=\"/corporate/kddi/\" class=\"cmn-card__type\">\n<div class=\"cmn-card__head\">\n<div class=\"cmn-card__image\"><img src=\"/extlib/corporate/recruit/index/img_about.jpg\" alt=\"\" width=\"357\" height=\"153\"></div>\n</div>\n<div class=\"cmn-card__body\">\n<div class=\"cmn-card__title\">KDDIについて</div>\n<p class=\"cmn-card__description\">企業情報、社長メッセージなどをご覧いただけます。</p>\n</div>\n</a></div>\n<div class=\"cmn-card\"><a href=\"https://kddi-volunteer.resv.jp/?medid=web&amp;serial=reserve&amp;srcid=260204_1\" class=\"cmn-card__type--blank\" target=\"_blank\" rel=\"noopener\">\n<div class=\"cmn-card__head\">\n<div class=\"cmn-card__image\"><img src=\"/extlib/corporate/recruit/index/img_volunteer.jpg\" alt=\"\" width=\"357\" height=\"153\"></div>\n</div>\n<div class=\"cmn-card__body\">\n<div class=\"cmn-card__title\">おもいでケータイ再起動<br>ボランティア募集</div>\n<p class=\"cmn-card__description\">おもいでケータイ再起動、学生ボランティア応募についてご覧いただけます。</p>\n<div class=\"cmn-list-wrap mt0\">\n<ul class=\"cmn-note-list\">\n<li><span class=\"cmn-note-list__mark\">※</span>本活動は、当社選考と一切関係ございません。</li>\n</ul>\n</div>\n</div>\n<span class=\"cmn-visually-hidden\">新規ウィンドウで開く</span> </a></div>\n</div>\n</section>\n</div>\n<!--/Main__body--></div>\n<!--/Main__inner--></div>\n<!--/Main--> </main> <!-- SYNCSEARCH13 -->\n<script type=\"text/javascript\" src=\"https://static.syncsearch.jp/common/js/sync_suggest.js\"></script>\n<script type=\"text/javascript\">\nSYNCSEARCH_SITE=\"2KZ9WLFD\";\nSYNCSEARCH_GROUP=13;\n</script>\n<!-- SYNCSEARCH13 --> <!--start footer--> <!-- footer -->\n<div id=\"pageTopBox\"><!-- 旧体裁のJS等から参照されるセレクタ --></div>\n<footer class=\"Footer is-renewal\">\n  <nav class=\"Footer__inner\" aria-label=\"フッターリンク\">\n    <div class=\"Footer__head\">\n      <div class=\"footer-brand-link\">\n        <div class=\"footer-brand-