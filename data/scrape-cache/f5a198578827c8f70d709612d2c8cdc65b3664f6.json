{"url":"https://www.sc-aero.co.jp/recruit/staff/member02.html","html":"\n<!DOCTYPE html>\n<html lang=\"ja\">\n    <head>\n        <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n        <meta charset=\"utf-8\">\n        <meta name=\"description\" content=\"住商エアロシステム株式会社 新卒採用情報の「社員を知る」ページです。\">\n        <meta name=\"keywords\" content=\"住商エアロシステム,防衛航空宇宙,社員\">\n        <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n        <meta name=\"format-detection\" content=\"telephone=no\">\n\n        <title>社員を知る｜住商エアロシステム株式会社 新卒採用情報</title>\n\n        <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n        <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n        <link rel=\"stylesheet\" href=\"https://fonts.googleapis.com/css2?family=Zen+Old+Mincho:wght@400;700&display=swap\">\n        <link rel=\"stylesheet\" href=\"https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&display=swap\">\n        \n        <link rel=\"stylesheet\" href=\"../assets/css/style.css\" media=\"all\">\n\n        <script src=\"../assets/js/vendor/script.js\"></script>\n        <script src=\"../assets/js/plugins.js\"></script>\n        \n        <script src=\"../assets/js/app.js\"></script>\n\n        <!-- Global site tag (gtag.js) - Google Analytics -->\n        <script async src=\"https://www.googletagmanager.com/gtag/js?id=G-K76JDYQNZS\"></script> <script>\n            window.dataLayer = window.dataLayer || []; function gtag(){dataLayer.push(arguments);} gtag('js', new Date());\n            gtag('config', 'G-K76JDYQNZS');\n            gtag('config', 'UA-226519009-1');\n        </script>\n    </head>\n    <body class=\"child staff p02\" data-key=\"00-04-02\" data-dir=\"1\">\n        <div id=\"wrapper\">\n            <header>\n                <div id=\"header\">\n                    <div class=\"float\">\n                        <div class=\"left\">\n                            <ul class=\"flex\">\n                                <li><a class=\"logo\" href=\"../\"><img src=\"../assets/img/common/header_logo.png\" alt=\"住商エアロシステム株式会社\"></a></li>\n                                <li><p>新卒採用サイト</p></li>\n                            </ul>\n                        </div>\n                        <div class=\"right\">\n                            <ul class=\"flex\">\n                                <li><a id=\"menu-entry\" href=\"../info/requirements.html#entry\"><p>ENTRY</p></a></li>\n                                <li><button id=\"menu-btn\"><span class=\"icon\"></span></button></li>\n                            </ul>\n                        </div>\n                    </div>\n                </div>\n            </header>\n\n\n\n            <div id=\"menu\">\n                <div id=\"menu-overlay\"></div>\n                <div id=\"menu-list\">\n                    <div class=\"inner900\">\n                        <div class=\"flex\">\n                            <div class=\"col\">\n                                <div class=\"box\">\n                                    <div class=\"parent\"><a href=\"../\"><p class=\"font--serif\">TOP</p></a></div>\n                                </div>\n\n                                <div class=\"box\">\n                                    <div class=\"parent\"><a href=\"../message/\"><p class=\"font--serif\">社長メッセージ</p></a></div>\n                                </div>\n\n                                <div class=\"box\">\n                                    <div class=\"parent\"><a class=\"accordion-btn--sp\"><p class=\"font--serif\">会社を知る</p></a></div>\n                                    <ul class=\" accordion-body--sp\">\n                                        <li class=\"child\"><a href=\"../company/\"><p>企業概要</p></a></li>\n                                        <li class=\"child\"><a href=\"../company/info.html\"><p>住商エアロシステムの機能</p></a></li>\n                                        <li class=\"child\"><a href=\"../company/movie.html\"><p>動画ギャラリー</p></a></li>\n                                    </ul>\n                                </div>\n\n                                <div class=\"box\">\n                                    <div class=\"parent\"><a class=\"accordion-btn--sp\"><p class=\"font--serif\">ビジネスを知る</p></a></div>\n                                    <ul class=\" accordion-body--sp\">\n                                        <li class=\"child\"><a href=\"../business/#business-pro\"><p>防衛・航空宇宙の専門商社</p></a></li>\n                                        <li class=\"child\"><a href=\"../business/#business-sas\"><p>SAS Business</p></a></li>\n                                    </ul>\n                                </div>\n                            </div>\n                            <div class=\"col\">\n                                <div class=\"box\">\n                                    <div class=\"parent\"><a class=\"accordion-btn--sp\"><p class=\"font--serif\">社員を知る</p></a></div>\n                                    <ul class=\" accordion-body--sp\">\n                                        <li class=\"child\"><a href=\"../staff/member04.html\"><p>総合職</p></a></li>\n                                        <li class=\"child\"><a href=\"../staff/member02.html\"><p>総合職</p></a></li>\n                                        <li class=\"child\"><a href=\"../staff/member03.html\"><p>管理職</p></a></li>\n                                    </ul>\n                                </div>\n                                <div class=\"box\">\n                                    <div class=\"parent\"><a class=\"accordion-btn--sp\"><p class=\"font--serif\">採用情報</p></a></div>\n                                    <ul class=\" accordion-body--sp\">\n                                        <li class=\"child\"><a href=\"../info/requirements.html\"><p>募集要項</p></a></li>\n                                        <li class=\"child\"><a href=\"../info/personality.html\"><p>求める人材像</p></a></li>\n                                        <li class=\"child\"><a href=\"../info/event.html\"><p>イベント情報</p></a></li>\n                                    </ul>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n\n            <div id=\"mv\" class=\"size--staff\">\n                <div class=\"bg\"></div>\n\n                <div class=\"inside\">\n                    <div class=\"inner1000\">\n                        <h1 class=\"font--serif\">社員紹介</h1>\n                        <div class=\"shoulder\">\n                            <p class=\"font--serif\">\n                                専門性を高めることで<br>\n                                自身の武器を増やしたい\n                            </p>\n                        </div>\n                        <div class=\"profile\">\n                            <div class=\"belongs\">\n                                <p>\n                                    経理部<br>\n                                    2015年入社\n                                </p>\n                            </div>\n                            <div class=\"name\"><p>M.K</p></div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n\n\n\n            <main>\n                <article>\n                    <section id=\"staff-prologue\">\n                        <div class=\"inner1000\">\n                            <div class=\"inside\">\n                                <p>\n                                    幼少期の家族旅行の経験から海外や航空業界に興味を持ち、大学では留学生と異文化交流の機会に加え多角的に国際社会や日本文化について学びました。<br>\n                                    航空関連を中心に就職活動を行い、住友商事グループ合同企業説明会で当社を知りました。若手女性総合職の先輩が活躍している姿や、若手のうちから積極的な業務への取り組みが求められる点、また国の安全保障に貢献できることに魅力を感じ入社を決めました。\n\n                                </p>\n                            </div>\n                        </div>\n                    </section>\n\n\n\n                    <section id=\"staff-q-list\">\n                        <div class=\"q-list--01\">\n                            <div class=\"inner1000\">\n                                <div class=\"inside\">\n                                    <div class=\"h2\">\n                                        <div class=\"en\"><p class=\"font--serif\">Q.1-Work and rewarding</p></div>\n                                        <div class=\"ja\"><h2 class=\"font--serif\">現在の仕事とやりがい</h2></div>\n                                    </div>\n                                    <div class=\"txt\">\n                                        <p>\n                                            会計、財務、主計・総括と多岐に亘り担当しており、最近では会社の予算管理や予算策定の業務に携わっています。例えば、経営戦略を立てた背景や将来的に達成すべき業績目標（会社の達成したい利益）など、経営層の考えをより近くで確認できる機会が増えました。加えて、経理部が提供する数字が経営判断を下す上で不可欠な要素でもあり、誤った内容は報告できないため良い緊張感を持って取り組んでいます。下調べや準備が甘いと痛感する場面も多々ありますが、成長の良い機会だと前向きに捉え、会社経営の根幹にも関われることにもやりがいを感じながら日々奮闘しています。\n                                        </p>\n                                    </div>\n                                </div>\n                                <div class=\"ph\"><img src=\"../assets/img/staff/p02_p_01.jpg\"></div>\n                            </div>\n                        </div>\n\n\n                        <div class=\"q-list--02\">\n                            <div class=\"inner1000\">\n                                <div class=\"inside\">\n                                    <div class=\"h2\">\n                                        <div class=\"en\"><p class=\"font--serif\">Q.2-Success stories and failure stories</p></div>\n                                        <div class=\"ja\"><h2 class=\"font--serif\">仕事での成功談や失敗談</h2></div>\n                                    </div>\n                                    <div class=\"txt\">\n                                        <p>\n                                            入社3年目に財務から会計へ担当替えとなった際に、従前の業務とはほぼ180度異なる業務で分からないことばかりで四苦八苦しました。営業担当者から質問や相談を受けても答えられず、迷惑を掛けたくない気持ちも相まって業務を抱え込んでしまい辛酸を嘗める時期が続きました。しかし親身になって相談に乗ってくれる先輩が多く、チームワークの大切さを感じながら課題に真摯に向き合うことで乗り越えることができました。その後、経費精算システムの切替えを担当した際には、膨大な量の検証作業と社内説明会資料作成などでパンク寸前になってしまったのですが、周囲へ積極的に働きかけることでノウハウなどを学び、無事遂行することができました。\n                                        </p>\n                                    </div>\n                                </div>\n                            </div>\n                        </div>\n\n\n                        <div class=\"q-list--03\">\n                            <div class=\"inner1000\">\n                                <div class=\"inside\">\n                                    <div class=\"h2\">\n                                        <div class=\"en\"><p class=\"font--serif\">Q.3-Dreams and goals</p></div>\n                                        <div class=\"ja\"><h2 class=\"font--serif\">これからの夢や目標</h2></div>\n                                    </div>\n                                    <div class=\"txt\">\n                                        <p>\n                                            日々模索中ですが、営業部署と比較すると経理部は対外的な顧客とやり取りする機会が少ないため、まずは社内から信頼されるよう、管理会計や税務会計などより専門性を高めることで自身の武器を増やしたいです。また前述の通り、会社の予算策定に携わることから予実（予算と実績）管理の精度も上げたいと考えており、自身だけでなくチーム員にも還元できるようにしたいです。その結果、相乗効果をもたらすことができたなら担当者冥利に尽きると思います。\n                                        </p>\n                                    </div>\n                                </div>\n                                <div class=\"ph\"><img src=\"../assets/img/staff/p02_p_02.jpg\"></div>\n                            </div>\n                        </div>\n                    </section>\n\n\n\n                    <section id=\"staff-links\">\n                        <div class=\"inner860\">\n                            <div class=\"h3\">\n                                <h3 class=\"font--serif\">他の社員のインタビューを読む</h3>\n                            </div>\n                            <ul class=\"flex\">\n                                <li><a href=\"../staff/member04.html\"><div class=\"bg\"><img src=\"../assets/img/staff/category_link_04.jpg\"></div><p class=\"font--serif\">総合職</p></a></li>\n                                <li><a href=\"../staff/member03.html\"><div class=\"bg\"><img src=\"../assets/img/staff/category_link_03.jpg\"></div><p class=\"font--serif\">管理職</p></a></li>\n                            </ul>\n                        </div>\n                    </section>\n                </article>\n            </main>\n\n            <div id=\"footer-message\">\n                <div class=\"inside\">\n                    <div class=\"ph\"><img src=\"../assets/img/common/footer_copy.png\" alt=\"あたりまえを衞り続ける\"></div>\n                </div>\n            </div>\n            <footer class=\"child staff p02\">\n                <div class=\"upper\">\n                    <div class=\"inner1000\">\n                        <ul class=\"flex\">\n                            <li>\n                                <ol>\n                                    <li class=\"parent\"><a href=\"../\"><p>TOP</p></a></li>\n                                    <li class=\"child\"><a href=\"../info/requirements.html#entry\"><p>エントリー</p></a></li>\n                                    <li class=\"child\"><a class=\"blank\" href=\"https://www.sc-aero.co.jp/index.html\" target=\"_blank\"><p>コーポレートサイト</p></a></li>\n                                </ol>\n                            </li>\n                            <li>\n                                <ol>\n                                    <li class=\"parent\"><a href=\"../message/\"><p>社長メッセージ</p></a></li>\n                                </ol>\n                            </li>\n                            <li>\n                                <ol>\n                                    <li class=\"parent\"><a class=\"none\"><p>会社を知る</p></a></li>\n                                    <li class=\"child\"><a href=\"../company/\"><p>企業概要</p></a></li>\n                                    <li class=\"child\"><a href=\"../company/info.html\"><p>住商エアロシステムの機能</p></a></li>\n                                    <li class=\"child\"><a href=\"../company/movie.html\"><p>動画ギャラリー</p></a></li>\n                                </ol>\n                            </li>\n                            <li>\n                                <ol>\n                                    <li class=\"parent\"><a class=\"none\"><p>ビジネスを知る</p></a></li>\n                                    <li class=\"child\"><a href=\"../business/#business-pro\"><p>防衛・航空宇宙の専門商社</p></a></li>\n                                    <li class=\"child\"><a href=\"../business/#business-sas\"><p>SAS Business</p></a></li>\n                                </ol>\n                            </li>\n                            <li>\n                                <ol>\n                                    <li class=\"parent\"><a class=\"none\"><p>社員を知る</p></a></li>\n                                    <li class=\"child\"><a href=\"../staff/member04.html\"><p>総合職</p></a></li>\n                                    <li class=\"child\"><a href=\"../staff/member02.html\"><p>総合職</p></a></li>\n                                    <li class=\"child\"><a href=\"../staff/member03.html\"><p>管理職</p></a></li>\n                                </ol>\n                            </li>\n                            <li>\n                                <ol>\n                                    <li class=\"parent\"><a class=\"none\"><p>採用情報</p></a></li>\n                                    <li class=\"child\"><a href=\"../info/requirements.html\"><p>募集要項</p></a></li>\n                                    <li class=\"child\"><a href=\"../info/personality.html\"><p>求める人材像</p></a></li>\n                                    <li class=\"child\"><a href=\"../info/event.html\"><p>イベント情報</p></a></li>\n                                </ol>\n                            </li>\n                        </ul>\n                    </div>\n                </div>\n\n\n                <div class=\"lower\">\n                    <div class=\"copyright\"><p>&copy; Sumisho Aero Systems Corporation</p></div>\n                </div>\n            </footer>\n        </div>\n    </body>\n</html>","finalUrl":"https://www.sc-aero.co.jp/recruit/staff/member02.html","rendered":false,"_cachedAt":"2026-06-22T18:24:41.027Z"}