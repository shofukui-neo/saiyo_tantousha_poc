\"l-gnav-sns__list\">\r\n\t\t\t\t\t\t\t<li class=\"l-gnav-sns__item\"><a class=\"l-gnav-sns__link\" href=\"https://www.facebook.com/ITEC.Community\" target=\"_blank\"><img src=\"/common/images/icon_facebook.svg\" alt=\"アイテック公式 Facebook\"></a></li>\r\n\t\t\t\t\t\t\t<li class=\"l-gnav-sns__item\"><a class=\"l-gnav-sns__link\" href=\"https://x.com/ITEC_shikaku\" target=\"_blank\"><img src=\"/common/images/icon_x.webp\" alt=\"アイテック公式 X\" width=\"36\"></a></li>\r\n\t\t\t\t\t\t</ul>\r\n\t\t\t\t\t</dd>\r\n\t\t\t\t</dl>\r\n\t\t\t</div>\r\n\t\t</nav>\r\n\t\t<!-- //nav -->\r\n\t</div>\r\n</header>\r\n<!-- //header -->\r\n<!-- topimg -->\r\n<div class=\"secondImg webform\">\r\n<div class=\"ttlPage\">お問い合わせ</div>\r\n</div>\r\n<!-- //topimg -->\r\n<div class=\"breadArea inner\">\r\n<ul>\r\n<li><a href=\"/\">アイテックTOP</a></li>\r\n<li>アイテック教育事業本部のお問い合わせ一覧</li>\r\n</ul>\r\n</div>\r\n<!-- main -->\r\n<main id=\"gMain\">\r\n<h1 class=\"ttlLv01 txtC\">アイテック教育事業本部のお問い合わせ一覧</h1>\r\n<div class=\"entryBody\">\r\n<p class=\"leadCat\">アイテック教育事業本部が提供する商品・サービスについて\r\nご不明な点がございましたらお気軽にお問い合わせください。<!--\r\n電話でのお問い合わせは Tel: 03-6824-9001（土日祝日を除く 10:00〜17:00） まで。--></p>\r\n\r\n<section class=\"secBasicL\">\r\n<ul class=\"listCatTop cf\">\r\n \t<li><a href=\"/contact/\">\r\n\r\n<div class=\"thumb icon-arrow\"><img src=\"/common/images/img_user.jpg\" alt=\"お問い合わせ（学習様用窓口）\" width=\"224\" height=\"130\" /></div>\r\n<h2 class=\"ttl\">お問い合わせ（学習様用窓口）</h2>\r\n学習中の疑問点や不明点、悩んでいる事や気になる事がございましたらお気軽にご相談ください。</a></li>\r\n \t<li><a href=\"/inquiry/\">\r\n\r\n<div class=\"thumb icon-arrow\"><img src=\"/common/images/img_business.jpg\" alt=\"お問い合わせ（法人企業様用窓口）\" width=\"224\" height=\"130\" /></div>\r\n<h2 class=\"ttl\">お問い合わせ（法人様用窓口）</h2>\r\nお見積もり・お問合せや、実施したい研修、取得させたいIT資格や向上させたいITスキルなど、お気軽にご相談ください。</a></li>\r\n \t<li><a href=\"/bookstore/\">\r\n\r\n<div class=\"thumb icon-arrow\"><img src=\"/common/images/img_book.jpg\" alt=\"書店・取次店様用窓口\" width=\"224\" height=\"130\" /></div>\r\n<h2 class=\"ttl\">書店・取次店様用窓口</h2>\r\nお電話、FAXにてご注文を受けつけております。ご不明な点がありましたら、お気軽にお問い合わせください。</a></li>\r\n \t<li><a href=\"/webform/mailmagazine/\">\r\n\r\n<div class=\"thumb icon-arrow\"><img src=\"/common/images/img_contactus.jpg\" alt=\"メルマガ登録\" width=\"224\" height=\"130\" /></div>\r\n<h2 class=\"ttl\">メルマガ登録</h2>\r\nメルマガ購読者限定のお得な情報や最新情報をお届けいたします。\r\n<span class=\"fs12\">登録の解除は受信メルマガの「配信停止」をクリックください\r\nメールマガジンの再講読は、<a class=\"normalLink\" href=\"https://ui.benchmarkemail.com/jp/help-email\"><b>こちら</b></a></span></a></li>\r\n</ul>\r\n<h2 class=\"ttlLv02 mt20\">■アカウントメールが届かない場合について</h2>\r\n自動的に「迷惑メールフォルダ」や「ゴミ箱」へ移動している可能性があります。お手数ですが、迷惑メールやゴミ箱をご確認ください。\r\nそれでも尚、メールの受信が確認できなかった場合は、「お問い合わせフォーム」よりお問い合わせくださいますようお願い致します。\r\n※フリーメール（gmailやYahoomailなど）、また、プロバイダのメールでも、設定によって、迷惑メールやゴミ箱に自動的に振り分けられることがあります。\r\nお問い合わせフォームへのご記入前に「<a class=\"normalLink\" href=\"/faq/\">よくあるご質問</a>」も併せてご覧ください。\r\n\r\n<!--\r\n<h2 class=\"ttlLv02 mt40\">■メールマガジンの再講読について</h2>\r\n再度配信を希望される場合は、サポートへのご連絡が必要となっております。\r\n\r\nサポートへの連絡はお問い合わせフォームのご利用または、直接メールをお送りいただく方法がございます。\r\nお問い合わせフォームは<a href=\"https://ui.benchmarkemail.com/jp/help-email\" class=\"normalLink\">こちら</a>\r\n↓メルマガ再講読依頼の記入例\r\n<img src=\"/common/images/img_re_mailmaga.png\" width=\"564\" height=\"417\" alt=\"メルマガ再講読用窓口\"/>\r\n\r\n直接メールを送信：support@benchmarkemail.com\r\n-->\r\n\r\n</section>\r\n<ul class=\"listBtns col3 cf btn-s left\">\r\n \t<li><a class=\"icon-arrow btnStyle01\" href=\"/about/\"><span>アイテックが選ばれる理由</span></a></li>\r\n \t<li><a class=\"icon-arrow btnStyle01\" href=\"/comment/\"><span>合格者の声</span></a></li>\r\n \t<li><a class=\"icon-arrow btnStyle01\" href=\"/topics/\"><span>トピック一覧</span></a></li>\r\n</ul>\r\n<ul class=\"listBtns col2 cf btn-s left\">\r\n \t<li><a class=\"icon-arrow btnStyle01\" href=\"/examination/\"><span>アイテックが提供する情報処理技術者試験とは</span></a></li>\r\n \t<li><a class=\"icon-arrow btnStyle01\" href=\"/howto/\"><span>アイテック情報処理技術者試験学習方法</span></a></li>\r\n</ul></div>\r\n</main>\r\n<!-- //main -->\r\n\r\n<!-- right side fix \r\n<div class=\"sideFix\">\r\n\t<ul