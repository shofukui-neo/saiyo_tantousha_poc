r-contact\">\n        <span class=\"icon-contact __ico\" aria-hidden=\"true\"></span>\n        <p>お問い合わせ</p>\n      </a>\n    </div>\n  </div>\n</header>\n\n\t\t\t<!--============================================== /header -->\n\t\t\t\n\t\t\t<div class=\"e-h1 _corporate_\">\n\t\t\t\t<div class=\"e-h1__inner\">\n\t\t\t\t\t<div class=\"e-h1__txt _ja_\">\n\t\t\t\t\t\t<span class=\"__small\">企業情報</span>\n\t\t\t\t\t\t<h1>トップメッセージ</h1>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t\t\n\t\t\t<!-- .c-breadcrumb -->\n\t\t\t<nav class=\"c-breadcrumb\">\n\t\t\t\t<ul class=\"c-breadcrumb__inner\">\n\t\t\t\t\t<li class=\"c-breadcrumb__item\"><a href=\"/\" class=\"c-breadcrumb__link\">TOP</a></li>\n\t\t\t\t\t<li class=\"c-breadcrumb__item\"><a href=\"/corporate/\" class=\"c-breadcrumb__link\">企業情報</a></li>\n\t\t\t\t\t<li class=\"c-breadcrumb__item\">トップメッセージ</li>\n\t\t\t\t</ul>\n\t\t\t</nav>\n\t\t\t<!-- /.c-breadcrumb -->\n\t\t\t\n\n\t\t\t<!-- .l-contents -->\n\t\t\t<div class=\"l-contents _col2_\">\n\t\t\t\t<div class=\"l-row\">\n\t\t\t\t\t\n\t\t\t\t\t<!-- .l-contents__inner -->\n\t\t\t\t\t<div class=\"l-contents__inner\">\n\n\t\t\t\t\t\t<!-- .l-contents__body -->\n\t\t\t\t\t\t<main class=\"l-contents__body\">\n\t\t\t\t\t\t\t<h2 class=\"e-catch01\"><span class=\"__accent\">&ldquo;</span>進化<span class=\"__accent\">&rdquo;</span></h2>\n\t\t\t\t\t\t\t<p class=\"e-h3\">社会の期待を先取りし応え続ける「開発機能会社」への進化</p>\n\t\t\t\t\t\t\t<img src=\"/common/img/corporate/message/pic_message_01.png\" alt=\"東北特殊鋼株式会社 代表取締役社長　成瀬 真司\" class=\"u-mw100p u-mb-xxs\">\n\t\t\t\t\t\t\t<div class=\"m-block\">\n\t\t\t\t\t\t\t\t<p class=\"e-text-mb _wide_\">東北特殊鋼は1937年の創業以来、日本の金属研究をリードする東北大学との産学共同による技術開発を礎に、宮城の地で発展してまいりました。その間、ステークホルダーの皆さまのご支援のもと、磁性材料をはじめとした高機能特殊鋼の分野で、自動車産業や半導体製造装置をはじめとした産業機械分野に、様々な機能的価値をチームで提供してまいりました。</p>\n\t\t\t\t\t\t\t\t<p class=\"e-text-mb _wide_\">そして今、私たちはチームとして築き上げてきた歴史を更に進化させるべく、新たな価値創造を目指したチャレンジに取り組んでいます。これまで続けてきたお客様との商品開発はもちろんのこと、技術・商品開発によるSDGsへの貢献や、これまでの歴史で貢献してきた産業にとらわれない新たな業界の研究機関とのコラボレーションを進めております。さらには、地域社会の豊かな生活に貢献すべく、地域住民の皆様と当社が一体となった「元気の出る取り組み」を推進しています。</p>\n\t\t\t\t\t\t\t\t<p>これからもますます多様化する社会の期待を先取りし応え続ける「開発機能会社」へ進化すべく、チーム一丸で取り組んでまいります。ステークホルダーの皆さまにおかれましては、引き続き変わらぬご支援、ご鞭撻を賜れますようお願い申し上げます。</p>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t<div class=\"u-al-r e-h7\">\n\t\t\t\t\t\t\t\t東北特殊鋼株式会社<br>代表取締役社長　<span class=\"e-h6\">成瀬 真司</span>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</main>\n\t\t\t\t\t\t<!-- .l-contents__body -->\n\n\t\t\t\t\t\t<!-- .l-contents__side -->\n\t\t\t\t\t\t<!--============================================== snav-corporate -->\n\t\t\t\t\t\t\t\t\t\t\t\t<aside class=\"l-contents__side\">\n\t\t\t\t\t\t\t<nav class=\"c-snav\">\n\t\t\t\t\t\t\t\t<h2 class=\"c-snav-head\">\n\t\t\t\t\t\t\t\t\t<a href=\"/corporate/\" class=\"__elem e-text-link\">企業情報</a>\n\t\t\t\t\t\t\t\t</h2>\n\t\t\t\t\t\t\t\t<div class=\"c-snav-body\">\n\t\t\t\t\t\t\t\t\t<ul class=\"c-snav-list\">\n\t\t\t\t\t\t\t\t\t\t<li class=\"c-snav-list__item\">\n\t\t\t\t\t\t\t\t\t\t\t<a href=\"/corporate/message/\" class=\"c-snav-list__link\">\n\t\t\t\t\t\t\t\t\t\t\t\t<span class=\"__txt\">トップメッセージ</span>\n\t\t\t\t\t\t\t\t\t\t\t\t<span class=\"__ico icon-angle-right\" aria-hidden=\"true\"></span>\n\t\t\t\t\t\t\t\t\t\t\t</a>\n\t\t\t\t\t\t\t\t\t\t</li>\n\t\t\t\t\t\t\t\t\t\t<li class=\"c-snav-list__item\">\n\t\t\t\t\t\t\t\t\t\t\t<a href=\"/corporate/philosophy/\" class=\"c-snav-list__link\">\n\t\t\t\t\t\t\t\t\t\t\t\t<span class=\"__txt\">経営理念</span>\n\t\t\t\t\t\t\t\t\t\t\t\t<span class=\"__ico icon-angle-right\" aria-hidden=\"true\"></span>\n\t\t\t\t\t\t\t\t\t\t\t</a>\n\t\t\t\t\t\t\t\t\t\t</li>\n\t\t\t\t\t\t\t\t\t\t<li class=\"c-snav-list__item\">\n\t\t\t\t\t\t\t\t\t\t\t<a href=\"/corporate/about/\" class=\"c-snav-list__link\">\n\t\t\t\t\t\t\t\t\t\t\t\t<span class=\"__txt\">会社概要</span>\n\t\t\t\t\t\t\t\t\t\t\t\t<span class=\"__ico icon-angle-right\" aria-hidden=\"true\"></span>\n\t\t\t\t\t\t\t\t\t\t\t</a>\n\t\t\t\t\t\t\t\t\t\t</li>\n\t\t\t\t\t\t\t\t\t\t<li class=\"c-snav-list__item\">\n\t\t\