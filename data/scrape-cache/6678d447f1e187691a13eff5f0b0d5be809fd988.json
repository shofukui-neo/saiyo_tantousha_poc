{"url":"https://www.yamazakipan.co.jp/recruit/diversity/index.html","html":"<!DOCTYPE html>\r\n<html lang=\"ja-JP\">\r\n    <head>\r\n        <meta charset=\"UTF-8\">\r\n        <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n        <meta name=\"description\" content=\"山崎製パン障がい者採用サイトです。ヤマザキでは、自分が過ごしてきた地域の中で、様々な人と一緒にはたらいていける会社作りを目指しています。\">\r\n        <meta name=\"keywords\" content=\"ヤマザキ,山崎,山崎製パン,製パン,食品業界,リクルート,工場,障がい者採用,ハンディキャップ採用\">\r\n        <title>山崎製パン　障がい者採用サイト</title>\r\n        <link rel=\"stylesheet\" href=\"./assets/css/main.css?20250725-1511\">\r\n        <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\r\n        <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\r\n        <link href=\"https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@100..900&display=swap\" rel=\"stylesheet\">\r\n        <!-- Google Analytics start -->\r\n        <script src=\"https://www.yamazakipan.co.jp/common/js/gaq.js\"></script>\r\n        <!-- //Google Analytics end -->\r\n    </head>\r\n    <body>\r\n        <div id=\"wrapper\" class=\"diversity\">\r\n            <header>\r\n                <div class=\"header_inner\">\r\n                    <h1>\r\n                        <picture>\r\n                            <source media=\"(max-width: 750px)\" srcset=\"./assets/img/logo_yamazaki_sp.png\">\r\n                            <img src=\"./assets/img/logo_yamazaki.png\" alt=\"障がい者採用\">\r\n                        </picture>\r\n                        <span class=\"title\">障がい者採用</span>\r\n                    </h1>\r\n                    <nav class=\"menu_apply-nav menu_pc\">\r\n                        <ul>\r\n                            <li class=\"link_text icon_blank\"><a href=\"https://www.yamazakipan.co.jp/recruit/career/index.html\" target=\"_blank\">中途（地域社員）採用</a></li>\r\n                            <!-- <li class=\"link_button_line icon_pin\"><a href=\"#\">勤務地から探す</a></li> -->\r\n                            <!-- <li class=\"link_button_fill icon_apply\"><a href=\"#\">応募する</a></li> -->\r\n                        </ul>\r\n                    </nav>\r\n                    <div class=\"menu_sp\" id=\"menu_sp\">\r\n                        <div class=\"menu_logo_sp\">\r\n                            <img src=\"./assets/img/logo_yamazaki_sp.png\" alt=\"障がい者採用\">\r\n                        </div>\r\n                        <div class=\"hamburger\" id=\"hamburger\">\r\n                            <div class=\"hamburger_open\">\r\n                                <div class=\"hamburger_open_inner\">\r\n                                    <span></span>\r\n                                    <span></span>\r\n                                    <span></span>\r\n                                </div>\r\n\r\n                            </div>\r\n                            <div class=\"hamburger_close\">\r\n                                <div class=\"hamburger_close_inner\">\r\n                                    <span></span>\r\n                                    <span></span>\r\n                                </div>\r\n                            </div>\r\n                        </div>\r\n                        <div class=\"menu_wrap\" id=\"menu_wrap\">\r\n                            <div class=\"menu_apply_wrap\">\r\n                                <h1>障がい者採用</h1>\r\n                                <nav class=\"menu_apply-nav\">\r\n                                    <ul>\r\n                                        <li class=\"link_text icon_blank\"><a class=\"menu_site-nav_link\" href=\"https://www.yamazakipan.co.jp/recruit/career/index.html\" target=\"_blank\">中途（地域社員）採用</a></li>\r\n                                        <!-- <li class=\"link_button_line icon_pin\"><a class=\"menu_site-nav_link\" href=\"#\">勤務地から探す</a></li> -->\r\n                                        <!-- <li class=\"link_button_fill icon_apply\"><a class=\"menu_site-nav_link\" href=\"#\">応募する</a></li> -->\r\n                                    </ul>\r\n                                </nav>\r\n                            </div>\r\n\r\n                            <nav class=\"menu_site-nav\">\r\n                                <ul>\r\n                                    <li><a class=\"menu_site-nav_link\" href=\"#job-point\">“ともにはたらく”を助けるヤマザキのポイント</a></li>\r\n                                    <li><a class=\"menu_site-nav_link\" href=\"#work-exsample\">主な仕事例</a></li>\r\n                                    <li><a class=\"menu_site-nav_link\" href=\"#faq\">よくあるご質問</a></li>\r\n                                    <li><a class=\"menu_site-nav_link\" href=\"#Job-description\">募集要項</a></li>\r\n                                    <li><a class=\"menu_site-nav_link\" href=\"#flow\">採用フロー</a></li>\r\n                                    <li><a class=\"menu_site-nav_link\" href=\"#contact\">障がい者採用に関するお問い合わせ窓口</a></li>\r\n                                </ul>\r\n                            </nav>\r\n                            <ul class=\"menu_yamazaki-nav\">\r\n                                <li><a target=\"_blank\" class=\"menu_site-nav_link\" href=\"https://www.yamazakipan.co.jp/\">山崎製パン企業サイト</a></li>\r\n                                <li><a target=\"_blank\" class=\"menu_site-nav_link\" href=\"https://www.yamazakipan.co.jp/company/company/\">会社概要</a></li>\r\n                                <li><a target=\"_blank\" class=\"menu_site-nav_link\" href=\"https://www.yamazakipan.co.jp/shakai/kankyou/\">環境への取り組み</a></li>\r\n                                <li><a target=\"_blank\" class=\"menu_site-nav_link\" href=\"https://www.yamazakipan.co.jp/shakai/safety/\">食の安全・安心</a></li>\r\n                            </ul>\r\n                        </div>\r\n\r\n                    </div>\r\n                </div>\r\n\r\n            </header>\r\n            <main>\r\n                <section class=\"diversity__main-visual\" id=\"main-visual\">\r\n                    <picture>\r\n                        <source media=\"(max-width: 750px)\" srcset=\"./assets/img/section_mainvisual_a_sp.jpg\">\r\n                        <img src=\"./assets/img/section_mainvisual_a.jpg\" alt=\"障がい者採用\">\r\n                    </picture>\r\n                </section>\r\n                <section class=\"diversity__message\" id=\"message\">\r\n                    <div class=\"round_box\">\r\n                        <svg viewBox=\"0 0 200 40\" xmlns=\"http://www.w3.org/2000/svg\">\r\n                            <ellipse cx=\"100\" cy=\"20\" rx=\"100\" ry=\"20\" />\r\n                        </svg>\r\n                    </div>\r\n                    <hgroup>\r\n                        <h2><span style=\"font-size: var(--font-size-xl);\">ともに</span><span>すごす、</span><span style=\"font-size: var(--font-size-xl);\">ともに</span><span>はたらく。</span></h2>\r\n                        <p>ヤマザキでは、自分が暮らしている地域で、<br>\r\n                            様々な人と共に働き、活躍できる職場環境を目指しています。<br>\r\n                            あなたの希望や配慮してほしいことを大切にしながら、<br>\r\n                            一緒に理想の“はたらき方”を実現していきましょう。\r\n                        </p>\r\n                    </hgroup>\r\n                </section>\r\n                <section class=\"diversity__job-point\" id=\"job-point\">\r\n                    <div class=\"round_box\">\r\n                        <svg viewBox=\"0 0 200 40\" xmlns=\"http://www.w3.org/2000/svg\">\r\n                            <ellipse cx=\"100\" cy=\"20\" rx=\"100\" ry=\"20\" />\r\n                        </svg>\r\n                    </div>\r\n                    <hgroup>\r\n                        <h2><span>“ともに はたらく”を助ける</span>　<span>ヤマザキのポイント</span></h2>\r\n                    </hgroup>\r\n                    <div class=\"diversity__job-point_inner\">\r\n                        <div class=\"job-point_wrap\">\r\n                            <div class=\"job-point\">\r\n                                <img src=\"./assets/img/section_job-point_03.svg\" alt=\"\">\r\n                                <hgroup>\r\n                                    <h3>一緒に働く、ともに学ぶ、<br><span class=\"job-point_important\">職場環境づくり</span></h3>\r\n                                    <p>ともに働く仲間が助け合いながら従業員の能力を最大限に発揮できる職場環境づくりを目指しています。</p>\r\n                                </hgroup>\r\n                            </div>\r\n                            <div class=\"job-point\">\r\n                                <img src=\"./assets/img/section_job-point_02.svg\" alt=\"\">\r\n                                <hgroup>\r\n                                    <h3><span class=\"job-point_important\">全事業所</span><br>で採用活動</h3>\r\n                                    <div class=\"job-point_link_wrap\">\r\n                                        <p>ヤマザキの事業所は全国に２８か所。その全ての事業所で採用活動を行っています。ご自身で選んだ地域で働けます。\r\n                                            <br class=\"sp_none\"><br class=\"sp_none\">\r\n                                        </p>\r\n                                        <!-- <div class=\"job-point_link\"><a href=\"#\">勤務地から探す</a></div> -->\r\n                                    </div>\r\n                                </hgroup>\r\n                            </div>\r\n                            <div class=\"job-point\">\r\n                                <img src=\"./assets/img/section_job-point_04.svg\" alt=\"\">\r\n                                <hgroup>\r\n                                    <h3><span class=\"job-point_important\">自立</span>、<span class=\"job-point_important\">雇用実現</span>に<br>貢献する</h3>\r\n                                    <p>障がいのある方が働く特定部署をつくるのではなく、一人ひとりの障がいの種類や程度に応じ、さまざまな部署で活躍しています。<br>\r\n                                    <span style=\"font-size: var(--font-size-ss);\">※特例子会社は設置していません。</span></p>\r\n                                </hgroup>\r\n                            </div>\r\n                            <!-- <div class=\"job-point\">\r\n                                <img src=\"./assets/img/section_job-point_01.svg\" alt=\"\">\r\n                                <hgroup>\r\n                                    <h3><span class=\"job-point_important\">地域とのつながり</span>を<br>重視する雇用</h3>\r\n                                    <p>人権啓発活動をベースに地域とのつながりを大切に、安心して働ける職場環境の実現を図っています。</p>\r\n                                </hgroup>\r\n                            </div> -->\r\n                            <div class=\"job-point\">\r\n                                <img src=\"./assets/img/section_job-point_05.svg\" alt=\"\">\r\n                                <hgroup>\r\n                                    <h3>豊富な<span class=\"job-point_important\">雇用実績</span></h3>\r\n                                    <p>「多様な人材が新たな価値を創造すること」が企業の持続的成長の源泉となると考え、障がいのある方の採用を積極的に行ってます。</p>\r\n                                </hgroup>\r\n                            </div>\r\n                            <div class=\"job-point\">\r\n                                <img src=\"./assets/img/section_job-point_06.svg\" alt=\"\">\r\n                                <hgroup>\r\n                                    <h3><span class=\"job-point_important\">多様な人材の<br>活躍</h3>\r\n                                    <p>当社で就労している障がいをお持ちの方は、身体障がい約3割、知的障がい約6割、精神障がい約1割の割合です。障がいの種類を問わず、それぞれの職場で活躍しています。</p>\r\n                                </hgroup>\r\n                            </div>\r\n                        </div>\r\n                    </div>\r\n                </section>\r\n                <section class=\"diversity__work-exsample\" id=\"work-exsample\">\r\n                    <hgroup>\r\n                        <h2>主な仕事例</h2>\r\n                    </hgroup>\r\n                    <div class=\"diversity__work-exsample_inner\">\r\n                        <div class=\"work-exsample_wrap\">\r\n                            <div class=\"work-exsample\">\r\n                                <picture>\r\n                                    <source media=\"(max-width: 750px)\" srcset=\"./assets/img/section_work-exsample_01_sp.png\">\r\n                                    <img src=\"./assets/img/section_work-exsample_01.png\" alt=\"生産職（製造）\">\r\n                                </picture>\r\n                                生産職（製造）\r\n                            </div>\r\n                            <div class=\"work-exsample\">\r\n                                <picture>\r\n                                    <source media=\"(max-width: 750px)\" srcset=\"./assets/img/section_work-exsample_02_sp.png\">\r\n                                    <img src=\"./assets/img/section_work-exsample_02.png\" alt=\"製品管理職（仕分け・配分）\">\r\n                                </picture>\r\n                                製品管理職（仕分け・配分）\r\n                            </div>\r\n                            <div class=\"work-exsample\">\r\n                                <picture>\r\n                                    <source media=\"(max-width: 750px)\" srcset=\"./assets/img/section_work-exsample_03_sp.png\">\r\n                                    <img src=\"./assets/img/section_work-exsample_03.png\" alt=\"資材職（原材料管理）\">\r\n                                </picture>\r\n                                資材職（原材料管理）\r\n                            </div>\r\n                            <div class=\"work-exsample\">\r\n                                <picture>\r\n                                    <source media=\"(max-width: 750px)\" srcset=\"./assets/img/section_work-exsample_04_sp.png\">\r\n                                    <img src=\"./assets/img/section_work-exsample_04.png\" alt=\"総務職（環境整備）\">\r\n                                </picture>\r\n                                総務職（環境整備）\r\n                            </div>\r\n                            <div class=\"work-exsample\">\r\n                                <picture>\r\n                                    <source media=\"(max-width: 750px)\" srcset=\"./assets/img/section_work-exsample_05_sp.png\">\r\n                                    <img src=\"./assets/img/section_work-exsample_05.png\" alt=\"デイリーヤマザキ店舗スタッフ職\">\r\n                                </picture>\r\n                                デイリーヤマザキ店舗スタッフ職\r\n                            </div>\r\n                        </div>\r\n                    </div>\r\n                </section>\r\n                <section class=\"diversity__faq\" id=\"faq\">\r\n                    <hgroup>\r\n                        <h2>よくあるご質問</h2>\r\n                    </hgroup>\r\n                    <div class=\"diversity__faq_inner\">\r\n                        <dl class=\"faq_list\">\r\n                            <dt class=\"faq_title\"><span>配属部署はどのように決まりますか？</span></dt>\r\n                            <dd><span>選考の中で、障がいの内容や程度をきめ細やかに確認していきます。本人の希望やそれぞれの状況を踏まえて、仕事内容や適性などを個別に相談しながら、決定します。</span></dd>\r\n                        </dl>\r\n                        <dl class=\"faq_list\">\r\n                            <dt class=\"faq_title\"><span>どのような障がいのある方が働いていますか？</span></dt>\r\n                            <dd><span>肢体不自由、視覚、聴覚、内部、知的、精神など様々な障がいをお持ちの方が働いています。</span></dd>\r\n                        </dl>\r\n                        <dl class=\"faq_list\">\r\n                            <dt class=\"faq_title\"><span>サポート体制を教えてください</span></dt>\r\n                            <dd><span>各個人の特性・個性にあった雇用管理や指導工夫等のサポート体制を取っています。働くうえで必要な配慮内容については、面談や面接時にご相談ください。</span></dd>\r\n                        </dl>\r\n                    </div>\r\n                </section>\r\n                <section class=\"diversity__Job-description\" id=\"Job-description\">\r\n                    <div class=\"diversity__Job-description_inner\">\r\n                        <hgroup>\r\n                            <h2>募集要項</h2>\r\n                        </hgroup>\r\n                        <div class=\"list_Job-description\">\r\n                            <dl>\r\n                                <dt>仕事内容（例）</dt>\r\n                                <dd>・生産職（製造）<br>\r\n                                    ・製品管理職（仕分け）<br>\r\n                                    ・資材職（原材料管理）<br>\r\n                                    ・総務職（環境整備）<br>\r\n                                    ・デイリー店舗スタッフ職<br>\r\n                                    事業所においての選考の中で、個々の障がいの内容や程度を確認していきます。<br>\r\n                                    それぞれの状況を踏まえて、勤務する上で必要な<br>\r\n                                    配慮、仕事内容や適性などを個別に相談しながら、決定します。\r\n                                </dd>\r\n                            </dl>\r\n                            <dl>\r\n                                <dt>待遇</dt>\r\n                                <dd>\r\n                                    <div class=\"sub_description_block\">\r\n                                        <span>【雇用形態】</span>\r\n                                        正社員（地域社員）、パートタイマー 等<br>\r\n                                        ※ご希望される働き方に応じて相談していきます。\r\n                                    </div>\r\n                                    <div class=\"sub_description_block\">\r\n                                        <span>【想定年収】</span>\r\n                                        雇用形態によって異なる\r\n                                    </div>\r\n                                    <div class=\"sub_description_block\">\r\n                                        <span>【各種手当等】</span>\r\n                                        通勤手当、時間外手当、各種社会保険 他\r\n                                    </div>\r\n                                </dd>\r\n                            </dl>\r\n                            <dl>\r\n                                <dt>勤務地</dt>\r\n                                <dd>全国各事業所または本社</dd>\r\n                            </dl>\r\n\r\n\r\n\r\n\r\n                            <dl>\r\n                                <dt>応募方法</dt>\r\n                                <dd>\r\n                                    <div class=\"sub_description_block\">\r\n                                        <span>正社員（地域社員）</span>\r\n                                        <a href=\"https://www.yamazakipan.co.jp/recruit/career/index.html\" target=\"_blank\">山崎製パン中途（地域社員）採用サイト</a>（ご応募はこちら）よりエントリーしてください。\r\n                                    </div>\r\n                                    <div class=\"sub_description_block\">\r\n                                        <span>パートタイマー</span>\r\n                                        <a href=\"https://www.yamazakipan.co.jp/company/zigyousho/index.html\" target=\"_blank\">山崎製パン | 企業情報 | 事業所一覧</a>よりご希望の事業所にご連絡ください。\r\n                                    </div>\r\n                                    または saiyo-s@yamazakipan.co.jp（障がい者採用窓口）に<br>メールにてお問い合わせください。\r\n\r\n                                </dd>\r\n                            </dl>\r\n                        </div>\r\n                    </div>\r\n\r\n                </section>\r\n                <section class=\"diversity__flow\" id=\"flow\">\r\n                    <hgroup>\r\n                        <h2>採用フロー</h2>\r\n                    </hgroup>\r\n                    <div class=\"diversity__flow-chart\">\r\n                        <ul>\r\n                            <li><span>エントリー</span></li>\r\n                            <li><span>会社説明会</span></li>\r\n                            <li><span>適性検査</li>\r\n                            <li><span>個人面接<br class=\"sp_none\">（数回）</span></li>\r\n                            <li><span>内々定</span></li>\r\n                        </ul>\r\n                    </div>\r\n                    <!-- <a class=\"button\" href=\"#\">応募する</a> -->\r\n                </section>\r\n                <section class=\"diversity__contact\" id=\"contact\">\r\n                    <!-- <picture>\r\n                        <source media=\"(max-width: 750px)\" srcset=\"./assets/img/section_contact_sp.jpg\">\r\n                        <img src=\"./assets/img/section_contact.jpg\" alt=\"障がい者採用\">\r\n                    </picture> -->\r\n                    <div class=\"round_box\">\r\n                        <svg viewBox=\"0 0 200 40\" xmlns=\"http://www.w3.org/2000/svg\">\r\n                            <ellipse cx=\"100\" cy=\"20\" rx=\"100\" ry=\"20\" />\r\n                        </svg>\r\n                    </div>\r\n                    <hgroup>\r\n                        <h2><span>障がい者採用に関する</span>お問い合わせ窓口</h2>\r\n                    </hgroup>\r\n                    <div class=\"diversity__contact_inner\">\r\n                        <p>山崎製パン㈱では、各事業所にて採用活動を行っています。<br>以下、事業所一覧よりご希望の勤務地にお問い合わせください。<br>\r\n                            <a href=\"https://www.yamazakipan.co.jp/company/zigyousho/index.html\" target=\"_blank\">事業所一覧</a>\r\n                        </p>\r\n                        <p>または、メールにてお問合せください。 <br>\r\n                            saiyo-s@yamazakipan.co.jp<br>\r\n                            （本社障がい者採用窓口）</p>\r\n                    </div>\r\n                    <!-- <div class=\"list_address\">\r\n                        <dl>\r\n                            <dt>関東以北・静岡・長野・富山担当</dt>\r\n                            <dd>〒101-8585<br>東京都千代田区岩本町3-10-1<br>電話 03-5821-2255（人事本部 採用課）</dd>\r\n                        </dl>\r\n                        <dl>\r\n                            <dt>中部・関西・中四国・福井・石川担当</dt>\r\n                            <dd>〒532-0003<br>大阪府大阪市淀川区宮原3-3-31上村ニッセイビル11階<br>電話 06-6350-0368（人事本部 関西分室）</dd>\r\n                        </dl>\r\n                        <dl>\r\n                            <dt>九州・山口担当</dt>\r\n                            <dd>〒811-3198<br>福岡県古賀市古賀69<br>電話 092-943-5162（福岡工場人事課）</dd>\r\n                        </dl>\r\n                    </div> -->\r\n\r\n                </section>\r\n            </main>\r\n            <footer>\r\n                <nav>\r\n                    <ul>\r\n                        <li><a target=\"_blank\" href=\"https://www.yamazakipan.co.jp/corporate/\">山崎製パン企業サイト</a></li>\r\n                        <li><a target=\"_blank\" href=\"https://www.yamazakipan.co.jp/company/company/\">会社概要</a></li>\r\n                        <li><a target=\"_blank\" href=\"https://www.yamazakipan.co.jp/shakai/kankyou/\">環境への取り組み</a></li>\r\n                        <li><a target=\"_blank\" href=\"https://www.yamazakipan.co.jp/shakai/safety/\">食の安全・安心</a></li>\r\n                    </ul>\r\n                </nav>\r\n                <div class=\"copylight\"><small>Copyright (C)Yamazaki Baking Co., Ltd. All rights reserved.</small></div>\r\n            </footer>\r\n        </div>\r\n        <script>\r\n\r\n            //ハンバーガー\r\n            const hamburger = document.getElementById('hamburger');\r\n            const navMenu = document.getElementById('menu_wrap');\r\n            const menu_sp = document.getElementById('menu_sp');\r\n            hamburger.addEventListener('click', () => {\r\n                hamburger.classList.toggle('open');\r\n                navMenu.classList.toggle('active');\r\n                menu_sp.classList.toggle('active');\r\n                if (navMenu.getElementsByClassName('active')) {\r\n                    document.body.classList.toggle('lock');\r\n                }\r\n            });\r\n\r\n            const menuSiteNavLink = document.getElementsByClassName('menu_site-nav_link');\r\n            console.log(menuSiteNavLink);\r\n            for (let k = 0; k < menuSiteNavLink.length; k++) {\r\n                menuSiteNavLink[k].addEventListener('click', () => {\r\n                    hamburger.classList.toggle('open');\r\n                    navMenu.classList.toggle('active');\r\n                    menu_sp.classList.toggle('active');\r\n                    if (navMenu.getElementsByClassName('active')) {\r\n                        document.body.classList.toggle('lock');\r\n                    }\r\n                })\r\n            }\r\n\r\n            //FAQ\r\n            const faqDom = document.getElementsByClassName('faq_list');\r\n            const faqTitle = document.getElementsByClassName('faq_title');\r\n            for (let i = 0; i < faqTitle.length; i++) {\r\n                faqTitle[i].addEventListener('click', () => {\r\n                    if (faqTitle[i].parentNode.classList.contains('active')) {\r\n                        faqTitle[i].parentNode.classList.remove('active');\r\n                    } else {\r\n                        for (let j = 0; j < faqDom.length; j++) {\r\n                            faqDom[j].classList.remove('active');\r\n                        }\r\n                        faqTitle[i].parentNode.classList.add('active');\r\n                    }\r\n                });\r\n            }\r\n\r\n        </script>\r\n    </body>\r\n</html>","finalUrl":"https://www.yamazakipan.co.jp/recruit/diversity/index.html","rendered":false,"_cachedAt":"2026-06-22T19:18:51.922Z"}