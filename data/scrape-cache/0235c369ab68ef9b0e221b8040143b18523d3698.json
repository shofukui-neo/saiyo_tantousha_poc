{"url":"https://www.k-yamasan.co.jp/recruit/info/guideline/","html":"<!DOCTYPE HTML>\n<html lang=\"ja\">\n\n<head>\n  <!-- Google Tag Manager -->\n  <script>\n    (function(w, d, s, l, i) {\n      w[l] = w[l] || [];\n      w[l].push({\n        'gtm.start': new Date().getTime(),\n        event: 'gtm.js'\n      });\n      var f = d.getElementsByTagName(s)[0],\n        j = d.createElement(s),\n        dl = l != 'dataLayer' ? '&l=' + l : '';\n      j.async = true;\n      j.src = 'https://www.googletagmanager.com/gtm.js?id=' + i + dl;\n      f.parentNode.insertBefore(j, f);\n    })(window, document, 'script', 'dataLayer', 'GTM-PJDQ96SJ');\n  </script>\n  <!-- End Google Tag Manager -->\n  <meta http-equiv=\"content-type\" content=\"text/html; charset=utf-8\">\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1.0,minimum-scale=1.0\">\n  <meta name=\"format-detection\" content=\"telephone=no\">\n  <title>募集要項・選考の流れ｜株式会社山産 採用サイト</title>\n  <script src=\"/recruit/inc/js/page/viewport-extra.min.js\"></script>\n  <script>\n    new ViewportExtra(375);\n  </script>\n  <link rel=\"icon\" href=\"/recruit/inc/image/favicon.ico\" type=\"image/x-icon\">\n  <link rel=\"apple-touch-icon\" href=\"/recruit/inc/image/apple-touch-icon.png\">\n  <link rel=\"icon\" href=\"/recruit/inc/image/android-chrome-192x192.png\" type=\"image/png\">\n  <meta name=\"description\" content=\"株式会社山産の募集要項・選考の流れをご覧いただけます。\">\n  <meta property=\"og:site_name\" content=\"株式会社山産 採用サイト\">\n  <meta property=\"og:title\" content=\"募集要項・選考の流れ｜株式会社山産 採用サイト\">\n  <meta property=\"og:description\" content=\"株式会社山産の募集要項・選考の流れをご覧いただけます。\">\n  <meta property=\"og:type\" content=\"article\">\n  <meta property=\"og:url\" content=\"https://www.k-yamasan.co.jp/recruit/info/training/\">\n  <meta property=\"og:image\" content=\"https://www.k-yamasan.co.jp/recruit/inc/image/common/img_ogp.jpg\">\n  <meta name=\"twitter:card\" content=\"summary_large_image\">\n  <meta name=\"twitter:site\" content=\"https://www.k-yamasan.co.jp/recruit/info/training/\">\n  <meta name=\"twitter:image\" content=\"https://www.k-yamasan.co.jp/recruit/inc/image/common/img_ogp.jpg\">\n  <link href=\"https://fonts.googleapis.com/css?family=Noto+Sans+JP:400,500,700&display=swap&subset=japanese\" rel=\"stylesheet\">\n  <link rel=\"stylesheet\" type=\"text/css\" href=\"/recruit/inc/css/style.css\">\n  <link rel=\"stylesheet\" type=\"text/css\" href=\"/recruit/inc/css/project/guideline.css\">\n</head>\n\n<body id=\"guideline\">\n  <!-- Google Tag Manager (noscript) -->\n  <noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-PJDQ96SJ\" height=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n  <!-- End Google Tag Manager (noscript) -->\n  <div id=\"container\">\n    <header class=\"l-header\">\n      <div class=\"l-header__inner\">\n        <div class=\"l-header__modules\">\n          <a href=\"/recruit\" class=\"logo\">\n            <span class=\"logo-main\"><img src=\"/recruit/inc/image/common/img_logo.svg\" alt=\"株式会社山産 採用サイト\"></span>\n            <span class=\"logo-sub\"><img src=\"/recruit/inc/image/common/img_headerLogocaption.svg\" alt=\"RECRUIT SITE\"></span>\n          </a>\n        </div>\n        <nav class=\"l-header__btnArea\">\n          <button class=\"l-header__btn js-naviBtn\" data-cat=\"gnavi\">\n            <span class=\"c-toggleBtn\" id=\"toggle\">\n              <span></span>\n              <span></span>\n              <span></span>\n            </span>\n          </button>\n        </nav>\n      </div>\n      <!-- グローバルナビゲーション -->\n      <div class=\"l-navigation__wrapper\" id=\"gnavi\">\n        <nav class=\"l-navigation\">\n          <!-- 1列目 -->\n          <ul class=\"l-navigation__list\">\n            <!-- トップ -->\n            <li class=\"l-navigation__item\">\n              <a class=\"current\" href=\"/recruit\">トップ</a>\n            </li>\n            <!-- トップ -->\n            <!-- 山産を知る -->\n            <li class=\"l-navigation__item\">\n              <button class=\"js-hasDropdown l-navigation__item\">山産を知る</button>\n              <ul class=\"l-navigation__list-sub\">\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/about/message/\">採用メッセージ</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/about/business/\">山産の事業について</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/about/data/\">数字で見る山産</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/about/case/\">こんなところに山産</a></li>\n              </ul>\n            </li>\n            <!-- 山産を知る -->\n          </ul>\n          <!-- 1列目 -->\n          <!-- 2列目 -->\n          <ul class=\"l-navigation__list\">\n            <!-- 仕事を知る -->\n            <li class=\"l-navigation__item\">\n              <a href=\"/recruit/about/work/\">仕事を知る</a>\n            </li>\n            <!-- 仕事を知る -->\n            <!-- 山産の人 -->\n            <li class=\"l-navigation__item\">\n              <button class=\"js-hasDropdown l-navigation__item\">人を知る</button>\n              <ul class=\"l-navigation__list-sub\">\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/member/\" class=\"js-naviAnchor\">人を知るTOP</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/member/interview01/\" class=\"js-naviAnchor\">環境事業グループ D.F.</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/member/interview06/\" class=\"js-naviAnchor\">環境事業グループ Y.O.</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/member/interview07/\" class=\"js-naviAnchor\">産機事業グループ S.K.</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/member/interview02/\" class=\"js-naviAnchor\">産機事業グループ Y.T.</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/member/interview03/\" class=\"js-naviAnchor\">総務部 K.I.</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/member/interview04/\" class=\"js-naviAnchor\">産機事業グループ S.I.</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/member/interview05/\" class=\"js-naviAnchor\">環境事業グループ H.M.</a></li>\n              </ul>\n            </li>\n            <!-- 山産の人 -->\n          </ul>\n          <!-- 2列目 -->\n          <!-- 3列目 -->\n          <ul class=\"l-navigation__list\">\n            <!-- 環境・制度を知る -->\n            <li class=\"l-navigation__item\">\n              <button class=\"js-hasDropdown l-navigation__item\">環境・制度を知る</button>\n              <ul class=\"l-navigation__list-sub\">\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/info/culture/\">文化・社風</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/info/benefits/\">福利厚生</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/info/training/\">教育制度・キャリアステップ</a></li>\n              </ul>\n            </li>\n            <!-- 働く人を知る -->\n          </ul>\n          <!-- 3列目 -->\n          <!-- 4列目 -->\n          <ul class=\"l-navigation__list\">\n            <!-- 採用情報 -->\n            <li class=\"l-navigation__item\">\n              <button class=\"js-hasDropdown l-navigation__item\">採用情報</button>\n              <ul class=\"l-navigation__list-sub\">\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/info/guideline/\">募集要項・選考の流れ</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/info/faq/\">よくあるご質問</a></li>\n              </ul>\n            </li>\n            <!-- 採用情報 -->\n            <!-- エントリー -->\n            <li class=\"l-navigation__item\">\n              <button class=\"js-hasDropdown l-navigation__item\">エントリー</button>\n              <ul class=\"l-navigation__list-sub\">\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/new-graduate-entry/\">新卒採用エントリー</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/entry/\">経験者採用エントリー</a></li>\n              </ul>\n            </li>\n            <!-- エントリー -->\n          </ul>\n          <!-- 4列目 -->\n        </nav>\n      </div>\n      <!-- グローバルナビゲーション -->\n    </header>\n    <!-- /header -->\n    <main id=\"main\">\n      <div class=\"l-lowerCaption\">\n        <div class=\"l-lowerCaption__inner\">\n          <h1 class=\"l-lowerCaption__title\">募集要項・<br class=\"u-only-xs\">選考の流れ</h1>\n          <ol class=\"c-topicspath\">\n            <li><a href=\"/recruit\">ホーム</a></li>\n            <li>採用情報</li>\n            <li>募集要項・選考の流れ</li>\n          </ol>\n        </div>\n      </div>\n      <div class=\"l-lowerCaption__bottom\">\n        <img src=\"/recruit/inc/image/common/lower/img_lowerCaption-bottom.svg\" alt=\"\">\n      </div>\n      <div id=\"contents\" class=\"l-lower\">\n        <div class=\"c-buttonArea\">\n          <div class=\"c-buttonArea__wrapper\">\n            <ol class=\"c-buttonArea__inner\">\n              <li class=\"c-buttonArea__item\">\n                <a href=\"#new-graduate\" class=\"c-anchorButton\">新卒採用</a>\n              </li>\n              <li class=\"c-buttonArea__item\">\n                <a href=\"#career\" class=\"c-anchorButton\">経験者採用</a>\n              </li>\n            </ol>\n          </div>\n        </div>\n        <div id=\"new-graduate\" class=\"p-guideline__section u-border-bottom u-border-bottom--gray\">\n          <h2 class=\"c-ttl-main c-ttl--center c-ttl--keycolor c-ttl--oblique p-guidelineTitle\"> 新卒採用 </h2>\n          <section class=\"l-section\">\n            <div class=\"l-section__inner\">\n              <div class=\"l-mw l-mw--800\">\n                <h3 class=\"c-ttl-middle c-ttl--center c-ttl--keycolor c-ttl--oblique c-tbl__title\">募集要項</h3>\n                <table class=\"c-tbl c-tbl--block\">\n                  <tbody>\n                    <tr>\n                      <th>募集職種</th>\n                      <td>セールスエンジニア（営業・施工管理）</td>\n                    </tr>\n                    <tr>\n                      <th>雇用形態</th>\n                      <td>正社員</td>\n                    </tr>\n                    <tr>\n                      <th>初任給</th>\n                      <td>\n                        <p>大学卒業・大学院修了　290,000円<br>（基本給270,000円 + 借上げ住宅手当20,000円）</p>\n                        <p>高専卒業　270,000円<br>（基本給250,000円 + 借上げ住宅手当20,000円）</p>\n                      </td>\n                    </tr>\n                    <tr>\n                      <th>募集人員</th>\n                      <td>5名～10名程度</td>\n                    </tr>\n                    <tr>\n                      <th>業務内容</th>\n                      <td>\n                        <p>【産機事業グループ】<br> 民間工業会社様を対象に様々な産業機械やプラントを販売します。総合的なサービスを提供する総合商事業です。</p>\n                        <p>【環境事業グループ】<br> 官公庁を対象に上下水道に関わるプラントの建設や機器の販売、施工、メンテナンスを行います。水に関するインフラ整備を行う機械・電気エンジニアリング業です。</p>\n                      </td>\n                    </tr>\n                    <tr>\n                      <th>必須スキル・経験</th>\n                      <td>普通自動車免許</td>\n                    </tr>\n                    <tr>\n                      <th>提出書類</th>\n                      <td>履歴書・卒業見込証明書・成績証明書</td>\n                    </tr>\n                    <tr>\n                      <th>待遇</th>\n                      <td>\n                        <p>【諸手当】<br> 時間外手当・通勤手当（全額支給）・地域手当・役職手当・資格手当・家族手当・帰省手当・家賃手当</p>\n                        <p>【賞与】<br> 年2回（6月・12月）＋特別賞与（業績による）</p>\n                        <p>【休日休暇】<br> 土曜・日曜・祝日・夏期休暇・年末年始休暇・年次有給休暇・慶弔休暇・永年勤続休暇<br> 社内カレンダーあり 年間所定休日127日</p>\n                        <p>【住居】<br> 借り上げ住宅制度あり<br> 家賃手当を含め家賃の実質80％～90％を会社が補助します。</p>\n                      </td>\n                    </tr>\n                    <tr>\n                      <th>お問い合わせ先</th>\n                      <td> &#12306;754-0002　山口県山口市小郡下郷2189<br> TEL：083-973-2133<br> 株式会社山産　総務部採用担当 </td>\n                    </tr>\n                  </tbody>\n                </table>\n              </div>\n            </div>\n          </section>\n          <section class=\"l-section\">\n            <h3 class=\"c-tbl__title c-ttl-middle c-ttl--center c-ttl--keycolor c-ttl--oblique\">選考の流れ</h3>\n            <div class=\"c-flow l-mw l-mw--800\">\n              <table class=\"c-flow__list\">\n                <tr class=\"c-flow__item\">\n                  <th class=\"c-flow__title c-ttl-small\"><span class=\"c-flow__title-number\">01</span><span class=\"c-flow__title-text\">会社説明会</span></th>\n                  <td class=\"c-flow__description\">\n                    <p>対面/WEBにて実施<br> 会社訪問も可能、随時受け付けておりますのでまずはご連絡ください。</p>\n                  </td>\n                </tr>\n                <tr class=\"c-flow__item\">\n                  <th class=\"c-flow__title c-ttl-small\"><span class=\"c-flow__title-number\">02</span><span class=\"c-flow__title-text\">書類選考</span></th>\n                  <td class=\"c-flow__description\">\n                    <p>受験を希望される方は応募書類一式（履歴書・卒業見込証明書・成績証明書）を下記住所へ郵送ください。書類審査後1次選考の日時・場所をご連絡致します。<br> &#12306;754-0002<br> 山口県山口市小郡下郷2189<br> 株式会社山産　総務部採用担当　宛 </p>\n                  </td>\n                </tr>\n                <tr class=\"c-flow__item\">\n                  <th class=\"c-flow__title c-ttl-small\"><span class=\"c-flow__title-number\">03</span><span class=\"c-flow__title-text\">1次選考試験</span></th>\n                  <td class=\"c-flow__description\">\n                    <p>1次面接＋適性検査<br> 受験当日持参するもの（筆記用具）<br> ご自宅からの交通費を全額支給します。</p>\n                  </td>\n                </tr>\n                <tr class=\"c-flow__item\">\n                  <th class=\"c-flow__title c-ttl-small\"><span class=\"c-flow__title-number\">04</span><span class=\"c-flow__title-text\">2次面接試験</span></th>\n                  <td class=\"c-flow__description\">\n                    <p>1次面接の合格者には、2次面接の日時・場所をご連絡致します。<br>ご自宅からの交通費を全額支給します。</p>\n                  </td>\n                </tr>\n                <tr class=\"c-flow__item\">\n                  <th class=\"c-flow__title c-ttl-small\"><span class=\"c-flow__title-number\">05</span><span class=\"c-flow__title-text\">最終面接試験</span></th>\n                  <td class=\"c-flow__description\">\n                    <p>2次面接の合格者には、最終面接の日時・場所をご連絡致します。<br>ご自宅からの交通費を全額支給します。</p>\n                  </td>\n                </tr>\n                <tr class=\"c-flow__item\">\n                  <th class=\"c-flow__title c-ttl-small\"><span class=\"c-flow__title-number\">06</span><span class=\"c-flow__title-text\">採用内定</span></th>\n                </tr>\n              </table>\n            </div>\n          </section>\n          <section class=\"l-section\">\n            <div class=\"l-mw l-mw--800\">\n              <h3 class=\"c-tbl__title c-ttl-middle c-ttl--center c-ttl--keycolor c-ttl--oblique\">エントリー</h3>\n              <p class=\"u-taC\">&#9660;新卒採用エントリーはこちらから&#9660;</p>\n              <div class=\"p-entry__buttonArea\">\n                <a href=\"/recruit/new-graduate-entry/\" class=\"p-entry__button\"> 新卒採用エントリー<span class=\"p-button__arrow p-button__arrow--white\"></span>\n                </a>\n              </div>\n            </div>\n          </section>\n        </div>\n        <div id=\"career\" class=\"p-guideline__section u-border-bottom\">\n          <h2 class=\"c-ttl-main c-ttl--center c-ttl--keycolor c-ttl--oblique p-guidelineTitle\"> 経験者採用 </h2>\n          <section class=\"l-section\">\n            <div class=\"l-section__inner\">\n              <div class=\"l-mw l-mw--800\">\n                <h3 class=\"c-ttl-middle c-ttl--center c-ttl--keycolor c-ttl--oblique c-tbl__title\">募集要項</h3>\n                <table class=\"c-tbl c-tbl--block\">\n                  <tbody>\n                    <tr>\n                      <th>募集職種</th>\n                      <td>セールスエンジニア（営業・施工管理）</td>\n                    </tr>\n                    <tr>\n                      <th>雇用形態</th>\n                      <td>正社員</td>\n                    </tr>\n                    <tr>\n                      <th>給与</th>\n                      <td>ご本人の前職、能力、年齢をバランス的に判断し決定</td>\n                    </tr>\n                    <tr>\n                      <th>募集人員</th>\n                      <td>若干名<br> （募集を中止している場合もございます）</td>\n                    </tr>\n                    <tr>\n                      <th>業務内容</th>\n                      <td>\n                        <p>【産機事業グループ】<br> 民間工業会社様を対象に様々な産業機械やプラントを販売します。総合的なサービスを提供する総合商事業です。</p>\n                        <p>【環境事業グループ】<br> 官公庁を対象に上下水道に関わるプラントの建設や機器の販売、施工、メンテナンスを行います。水に関するインフラ整備を行う機械・電気エンジニアリング業です。</p>\n                      </td>\n                    </tr>\n                    <tr>\n                      <th>必須スキル・経験</th>\n                      <td>\n                        <p>【必須】<br> 普通自動車免許</p>\n                        <p>【歓迎】<br> （電気・管・土木・電気通信）施工管理技士<br> （機械器具設置工事業）監理技術者</p>\n                      </td>\n                    </tr>\n                    <tr>\n                      <th>提出書類</th>\n                      <td>履歴書・経歴書</td>\n                    </tr>\n                    <tr>\n                      <th>待遇</th>\n                      <td>\n                        <p>【諸手当】<br> 時間外手当・通勤手当（全額支給）・地域手当・役職手当・資格手当・家族手当・帰省手当・家賃手当</p>\n                        <p>【賞与】<br> 年2回（6月・12月）+特別賞与（業績による）</p>\n                        <p>【休日休暇】<br> 土曜・日曜・祝日・夏期休暇・年末年始休暇・年次有給休暇・慶弔休暇・永年勤続休暇<br> 社内カレンダーあり 年間所定休日127日</p>\n                        <p>【住居】<br> 借り上げ住宅制度あり<br> 家賃手当を含め家賃の実質80％～90％を会社が補助します。</p>\n                      </td>\n                    </tr>\n                    <tr>\n                      <th>お問い合わせ先</th>\n                      <td> &#12306;754-0002　山口県山口市小郡下郷2189<br> TEL：083-973-2133<br> 株式会社山産　総務部採用担当 </td>\n                    </tr>\n                  </tbody>\n                </table>\n              </div>\n            </div>\n          </section>\n          <section class=\"l-section\">\n            <h3 class=\"c-tbl__title c-ttl-middle c-ttl--center c-ttl--keycolor c-ttl--oblique\">選考の流れ</h3>\n            <div class=\"c-flow l-mw l-mw--800\">\n              <table class=\"c-flow__list\">\n                <tr class=\"c-flow__item\">\n                  <th class=\"c-flow__title c-ttl-small\"><span class=\"c-flow__title-number\">01</span><span class=\"c-flow__title-text\">面談</span></th>\n                  <td class=\"c-flow__description\">\n                    <p>対面/WEBにて実施<br> カジュアルな面談にてお互いのミスマッチが起きないよう対話形式でお話をさせていただきます。</p>\n                  </td>\n                </tr>\n                <tr class=\"c-flow__item\">\n                  <th class=\"c-flow__title c-ttl-small\"><span class=\"c-flow__title-number\">02</span><span class=\"c-flow__title-text\">適性検査</span></th>\n                  <td class=\"c-flow__description\">\n                    <p>適性検査<br> 受験当日持参するもの（筆記用具）</p>\n                  </td>\n                </tr>\n                <tr class=\"c-flow__item\">\n                  <th class=\"c-flow__title c-ttl-small\"><span class=\"c-flow__title-number\">03</span><span class=\"c-flow__title-text\">1次選考試験</span></th>\n                  <td class=\"c-flow__description\">\n                    <p>合格者には、最終面接の日時・場所をご連絡致します。<br> ご自宅からの交通費を全額支給します。 </p>\n                  </td>\n                </tr>\n                <tr class=\"c-flow__item\">\n                  <th class=\"c-flow__title c-ttl-small\"><span class=\"c-flow__title-number\">04</span><span class=\"c-flow__title-text\">最終面接試験</span></th>\n                  <td class=\"c-flow__description\">\n                    <p>1次面接の合格者には、最終面接の日時・場所をご連絡致します。<br> ご自宅からの交通費を全額支給します。 </p>\n                  </td>\n                </tr>\n                <tr class=\"c-flow__item\">\n                  <th class=\"c-flow__title c-ttl-small\"><span class=\"c-flow__title-number\">05</span><span class=\"c-flow__title-text\">採用内定</span></th>\n                </tr>\n              </table>\n            </div>\n          </section>\n          <section class=\"l-section\">\n            <div class=\"l-mw l-mw--800\">\n              <h3 class=\"c-tbl__title c-ttl-middle c-ttl--center c-ttl--keycolor c-ttl--oblique\">エントリー</h3>\n              <p class=\"u-taC\">&#9660;経験者採用エントリーはこちらから&#9660;</p>\n              <div class=\"p-entry__buttonArea\">\n                <a href=\"/recruit/entry/\" class=\"p-entry__button\"> 経験者採用エントリー<span class=\"p-button__arrow p-button__arrow--white\"></span>\n                </a>\n              </div>\n            </div>\n          </section>\n        </div>\n        <section class=\"c-relatedContents\">\n          <div class=\"c-relatedContents__wrapper\">\n            <h2 class=\"c-ttl-main\"> 関連<span class=\"u-not-under-sm u-not-under-sm--inline\">する</span>コンテンツ </h2>\n            <ul class=\"c-cardWrapper c-cardWrapper--info\">\n              <li class=\"c-contentsCard c-contentsCard--info\">\n                <a href=\"/recruit/info/faq/\">\n                  <div class=\"c-contentsCard__textArea\">\n                    <span class=\"c-contentsCard__text c-contentsCard__text--info\">よくあるご質問</span><span class=\"c-contentsCard__arrow\"></span>\n                  </div>\n                </a>\n              </li>\n            </ul>\n          </div>\n        </section>\n      </div>\n    </main>\n    <!-- end of #main -->\n    <div class=\"c-cvArea\">\n      <div class=\"c-cvArea__inner \">\n        <div class=\"c-cvArea__inner__textArea\">\n          <h2 class=\"c-cvArea__title\"><span>グレートを創り出す山産に</span>エントリーする</h2>\n          <p class=\"c-cvArea__text u-taC\">「グレートを創り出す」ために、<br class=\"u-only-xs\">山産で一緒に働いてみませんか？</p>\n          <div class=\"c-cvArea__buttonArea\">\n            <ul class=\"c-cvArea__buttonList\">\n              <li class=\"c-cvArea__buttonItem\">\n                <a href=\"/recruit/new-graduate-entry/\" class=\"c-cvArea__button c-cvArea__button--white\">\n                  <span class=\"c-cvArea__buttonText\">新卒採用エントリー</span>\n                </a>\n              </li>\n              <li class=\"c-cvArea__buttonItem\">\n                <a href=\"/recruit/entry/\" class=\"c-cvArea__button c-cvArea__button--white\">\n                  <span class=\"c-cvArea__buttonText\">経験者採用エントリー</span>\n                </a>\n              </li>\n            </ul>\n          </div>\n        </div>\n      </div>\n    </div>\n    <footer class=\"l-f\">\n      <div class=\"l-f__inner\">\n        <div class=\"grid\">\n          <div class=\"col-4_sm-12\">\n            <div class=\"l-f__info\">\n              <a href=\"/recruit\" class=\"l-f__logo\">\n                <img src=\"/recruit/inc/image/common/img_logo.svg\" alt=\"株式会社山産 採用サイト\">\n              </a>\n              <p> &#12306;754-0002<br> 山口県山口市小郡下郷2189番地<br> TEL：<a href=\"tel:0839732133\" class=\"c-tel sampleClass\">083-973-2133</a><br> FAX：083-974-1070 </p>\n            </div>\n          </div>\n          <div class=\"col-8_sm-12\">\n            <nav class=\"l-f__nav\">\n              <ul class=\"l-f__links\">\n                <li class=\"l-f__linksItem\"><a href=\"/recruit\">トップ</a></li>\n                <li class=\"l-f__linksItem\">\n                  <p>山産を知る</p>\n                  <ul class=\"l-f__links-sub\">\n                    <li class=\"l-f__linksItem-sub\"><a href=\"/recruit/about/message/\">採用メッセージ</a></li>\n                    <li class=\"l-f__linksItem-sub\"><a href=\"/recruit/about/business/\">山産の事業について</a></li>\n                    <li class=\"l-f__linksItem-sub\"><a href=\"/recruit/about/data/\">数字で見る山産</a></li>\n                    <li class=\"l-f__linksItem-sub\"><a href=\"/recruit/about/case/\">こんなところに山産</a></li>\n                  </ul>\n                </li>\n              </ul>\n              <ul class=\"l-f__links\">\n                <li class=\"l-f__linksItem\"><a href=\"/recruit/about/work/\">仕事を知る</a></li>\n                <li class=\"l-f__linksItem\">\n                  <p>人を知る</p>\n                  <ul class=\"l-f__links-sub\">\n                    <li class=\"l-f__linksItem-sub\"><a href=\"/recruit/member/\">人を知るTOP</a></li>\n                    <li