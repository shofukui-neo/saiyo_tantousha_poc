"_webfonts.css?1777211630096\" id=\"webfont-css\"> \n  <link rel=\"stylesheet\" type=\"text/css\" href=\"_csslinkbtn/btn-import.css?1767874585473\" id=\"linkbtn-css\"> \n </head> \n <body id=\"l-2\" class=\"l-2 l-fixed-side -dress_pp013recruit bd-webp\" data-type=\"responsive\" data-layout-type=\"sidefixed\" data-view-pc-button=\"true\" data-view-pc-position=\"bottom\" data-page-animation=\"none\"> \n  <div id=\"page\" class=\"bg-window \"> \n   <div class=\"bg-document\"> \n    <noscript> \n     <div id=\"js-off\"> \n      <img src=\"_module/images/noscript.gif\" alt=\"Enable JavaScript in your browser. このウェブサイトはJavaScriptをオンにしてご覧下さい。\"> \n     </div> \n    </noscript> \n    <div id=\"a-header\" data-float=\"false\" class=\"a-header   cssskin-_area_header\"> \n     <header> \n      <div class=\"site_frame\"> \n       <section> \n        <div id=\"bk1351\" class=\"b-plain c-space_normal c-sp-space_normal c-padding_narrow c-sp-padding_normal cssskin-_block_header\" data-bk-id=\"bk1351\" data-shared=\"true\" data-sharedname=\"HEADER2\"> \n         <div class=\" column -column1\"> \n          <div class=\" c-body\"> \n           <div class=\"c-img   \"> \n            <a href=\"index.html\" data-pid=\"70\"> \n             <picture> \n              <source type=\"image/webp\" srcset=\"_src/960/logo-credit-500.webp?v=1767874585473\"> \n              <img src=\"_src/960/logo-credit-500.png?v=1767874585473\" width=\"2085\" height=\"327\" alt=\"\" id=\"imgsrc960_1\" class=\" c-no_adjust\" loading=\"lazy\"> \n             </picture></a> \n           </div> \n          </div> \n         </div> \n        </div> \n        <div id=\"bk1576\" class=\"b-plain -blog-article c-space_narrow c-sp-space_normal c-sp-padding_normal bd-webp -dress_white cssskin-_block_header\" data-bk-id=\"bk1576\" data-shared=\"true\" data-sharedname=\"HEADER\"> \n         <div class=\" column -column1\"> \n          <nav> \n           <div id=\"js-globalNavigation\" data-slide-type=\"rightSlide\" data-btn-position=\"rightTop\"> \n            <div class=\" js-motion\"> \n             <ul class=\"m-motion menu-parts -f\"> \n              <li class=\" c-left\"><a href=\"company_profile/index.html\" data-pid=\"77\">ご挨拶</a></li> \n              <li class=\" c-left\"><a href=\"company_profile/index1.html\" data-pid=\"78\">企業概要</a> \n               <ul> \n                <li class=\" c-left\"><a href=\"company_profile/index1.html#profile\" data-pid=\"78\">会社概要</a></li> \n                <li class=\" c-left\"><a href=\"company_profile/index1.html#history\" data-pid=\"78\">沿革</a></li> \n                <li class=\" c-left\"><a href=\"company_profile/index1.html#maker\" data-pid=\"78\">取り扱いメーカー</a></li> \n               </ul></li> \n              <li class=\" c-left\"><a href=\"Activities/index.html\" data-pid=\"123\">事業案内</a></li> \n              <li class=\" c-left\"><a href=\"base/location.html\" data-pid=\"103\">事業所一覧</a></li> \n              <li class=\" c-left\"><a href=\"Product_guide/product01.html\" data-pid=\"90\">取扱商品</a></li> \n              <li class=\" c-left\"><a href=\"festa2022/index.html\" data-pid=\"79\">ツールdeフェスタ</a></li> \n              <li class=\" c-left\"><a href=\"https://job-gear.net/sankotech/\">採用情報</a></li> \n              <li class=\" c-left\"><a href=\"Information/index.html\" data-pid=\"122\">お問い合わせ</a></li> \n              <li class=\" c-current c-left\"><a href=\"info.html\" data-mypid=\"72\">Information</a> \n               <ul> \n                <li class=\" c-current c-left\"><a href=\"info.html\" data-mypid=\"72\">新着情報</a></li> \n                <li class=\" c-left\"><a href=\"stj.html\" data-pid=\"73\">STジャーナル</a></li> \n               </ul></li> \n             </ul> \n            </div> \n           </div> \n           <div id=\"spNavigationTrigger\" class=\" c-sp_navigation_btn\"></div> \n          </nav> \n         </div> \n        </div> \n       </section> \n      </div> \n     </header> \n    </div> \n    <div id=\"a-billboard\" class=\"a-billboard    cssskin-_area_billboard\"> \n     <div class=\"site_frame\"> \n      <section> \n       <div id=\"bk1352\" class=\"b-plain c-space_normal c-sp-space_normal c-sp-padding_init cssskin-_block_billboard\" data-bk-id=\"bk1352\"> \n        <div class=\" column -column1\"> \n         <div class=\" c-body\"> \n          <div class=\"c-img   \"> \n           <picture> \n            <source type=\"image/webp\" srcset=\"_src/994/information_banner_20190526095941163.webp?v=1767874585473\"> \n            <img src=\"_src/994/information_banner_20190526095941163.jpg?v=1767874585473\" width=\"1000\" height=\"300\" alt=\"\" id=\"imgsrc994_1\" loading=\"lazy\"> \n           </picture> \n          </div> \n         </div> \n        </div> \n       </div> \n       <div id=\"bk1771\" class=\"b-plain c-space_normal c-sp-space_normal c-sp-padding_normal cssskin-h2_midashi2\" data-bk-id=\"bk1771\"> \n        <div class=\" column -column1\" id=\"top\"> \n         <h4 class=\" c-small_headline\">&nbsp; <span style=\"color:#ffffff;\">&nbsp;&nbsp;新着情報</span></h4> \n        </div> \n       </div> \n      </section> \n     </div> \n    </div> \n    <main> \n     <div id=\"a-site_contents\" class=\"a-site_contents  noskin\"> \n      <article> \n       <div class=\"site_frame\"> \n        <div class=\"g-column\"> \n         <div id=\"a-main\" class=\"a-main column -col8 \"> \n          <section> \n           <div id=\"bk5462\" class=\"b-plain c-space_normal c-sp-space_normal c-padding_normal c-sp-padding_normal cssskin-_block_main\" data-bk-id=\"bk5462\"> \n            <div class=\" column -column1\" id=\"260109\"> \n             <p class=\" c-body\"><span class=\" d-large_font\"><span class=\" d-bold\"><span style=\"color:#073763;\">当社名および当社代表者名を騙った迷惑メールにご注意ください</span></span></span></p> \n             <div class=\" c-body c-right\"> \n              <hr class=\"c-hr\"> 2026.1.9 \n             </div> \n             <p class=\" c-body\">現在、当社名および当社代表者名を騙り、<br><span>LINE</span>グループの作成を求める不審なメール（なりすましメール）が送信されている事案を確認しております。<br><span>&nbsp;</span><br>これらは当社とは一切関係のない第三者によるものであり、場合によってはウィルス感染やフィッシングサイトへの誘導、不正アクセス等の危険がございます。<br><span>&nbsp;</span><br>万一、同様の連絡を受信されたとしても、以下の行為は行わないようお願い致します。<br><span>&nbsp;</span><br>・<span>LINE</span>グループを作成しない、参加しない<br>・記載された<span>URL</span>はクリックしない<br>・メールの返信や個人情報を入力しない<br>・添付ファイルを開かない<br><span>&nbsp;</span><br>何卒ご注意くださいますようお願い申し上げます。</p> \n             <div class=\" c-body c-left\">\n               &nbsp; \n             </div> \n            </div> \n           </div> \n           <div id=\"bk5564\" class=\"b-plain c-space_normal c-sp-space_normal c-padding_normal c-sp-padding_normal cssskin-_block_main\" data-bk-id=\"bk5564\"> \n            <div class=\" column -column1\" id=\"251110\"> \n             <p class=\" c-body\"><span class=\" d-large_font\"><span class=\" d-bold\"><span style=\"color:#073763;\">冬季休暇の御案内</span></span></span></p> \n             <div class=\" c-body c-right\"> \n              <hr class=\"c-hr\"> 2025.11.10 \n             </div> \n             <div class=\" c-body c-left\">\n               平素は格別のご高配を賜り、厚く御礼を申し上げます \n             </div> \n             <div class=\" c-body c-left\">\n               &nbsp; \n             </div> \n             <div class=\" c-body c-left\"> \n              <span style=\"color:#434343;\" data-sitecolor-text=\"\">弊社では下記の期間を冬季休暇とさせて頂きます</span> \n              <br> \n              <span style=\"color:#434343;\">期間中は何かとご不便をお掛けいたしますが、宜しくお願い申し上げます　</span> \n              <br> \n              <br> \n              <span class=\" d-bold\"><span style=\"color:#a61c00;\" data-sitecolor-text=\"\">2025年12月27日(土曜日)〜2026年1月4日(日曜日</span></span> \n              <span class=\" d-bold\"><span style=\"color:#a61c00;\" data-sitecolor-text=\"\">)</span></span> \n              <br> \n              <br> \n              <span style=\"color:#434343;\" data-sitecolor-text=\"\">レンタル商品の納品・引取は、お早めに御連絡くださいますようお願い申し上げます</span> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk5409\" class=\"b-plain c-space_normal c-sp-space_normal c-padding_normal c-sp-padding_normal cssskin-_block_main\" data-bk-id=\"bk5409\"> \n            <div class=\" column -column1\" id=\"250924\"> \n             <p class=\" c-body\"><span class=\" d-large_font\"><span class=\" d-bold\"><span style=\"color:#073763;\">京浜営業所 紹介動画公開しました</span></span></span></p> \n             <div class=\" c-body c-right\"> \n              <hr class=\"c-hr\"> 2025.9.24 \n             </div> \n             <div class=\" c-body c-left\"> \n              <span style=\"color:#000000;\">京浜営業所</span> \n              <span style=\"color:#000000;\">の紹介動画を公開しましたのでぜひご覧ください！</span> \n             </div> \n             <div class=\" c-body c-left\">\n               &nbsp; \n             </div> \n             <div class=\" c-body c-left\"> \n              <span class=\"js-sync -video\" style=\"display:none;\">,http://gdata.youtube.com/feeds/api/videos/dHUG-UmupmU,,{\"playerWidth\":\"425\",\"useCustom\":false,\"autoPlay\":false,\"autoLoop\":false,\"autoNext\":false,\"quality\":\"default\",\"qualityName\":\"自動\",\"coverImage\":\"\"}</span> \n             </div> \n             <div class=\" c-body c-left\">\n               &nbsp; \n             </div> \n             <div class=\" c-body c-left\"> \n              <span style=\"color:#434343;\" data-sitecolor-text=\"\">動画は<a href=\"base/keihin.html\" data-pid=\"115\">事業所一覧</a> からもご視聴頂けます</span> \n              <br> \n              <br> \n              <span style=\"color:#000000;\">これから紹介動画を増やしていけるよう、撮影頑張っておりますので、どうぞご期待ください</span> \n              <span style=\"color:#434343;\" data-sitecolor-text=\"\"></span> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk5417\" class=\"b-plain c-space_normal c-sp-space_normal c-padding_normal c-sp-padding_normal cssskin-_block_main\" data-bk-id=\"bk5417\"> \n            <div class=\" column -column1\" id=\"250720\"> \n             <p class=\" c-body\"><span class=\" d-large_font\"><span class=\" d-bold\"><span style=\"color:#073763;\">いわき営業所 紹介動画公開しました</span></span></span></p> \n             <div class=\" c-body c-right\"> \n              <hr class=\"c-hr\"> 2025.7.20 \n             </div> \n             <div class=\" c-body c-left\"> \n              <span style=\"color:#000000;\">いわき営業所</span> \n              <span style=\"color:#000000;\">の紹介動画を公開しましたのでぜひご覧ください！</span> \n             </div> \n             <div class=\" c-body c-left\">\n               &nbsp; \n             </div> \n             <div class=\" c-body c-left\"> \n              <span class=\"js-sync -video\" style=\"display:none;\">,http://gdata.youtube.com/feeds/api/videos/GT4WCbCZZkc,,{\"playerWidth\":\"425\",\"useCustom\":false,\"autoPlay\":false,\"autoLoop\":false,\"autoNext\":false,\"quality\":\"default\",\"qualityName\":\"自動\",\"coverImage\":\"\"}</span> \n             </div> \n             <div class=\" c-body c-left\">\n               &nbsp; \n             </div> \n             <div class=\" c-body c-left\"> \n              <span style=\"color:#434343;\" data-sitecolor-text=\"\">動画は<a href=\"base/iwaki.html\" data-pid=\"108\">事業所一覧</a> からもご視聴頂けます</span> \n              <br> \n              <br> \n              <span style=\"color:#000000;\">これから紹介動画を増やしていけるよう、撮影頑張っておりますので、どうぞご期待ください</span> \n              <span style=\"color:#434343;\" data-sitecolor-text=\"\"></span> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk5408\" class=\"b-plain c-space_normal c-sp-space_normal c-padding_normal c-sp-padding_normal cssskin-_block_main\" data-bk-id=\"bk5408\"> \n            <div class=\" column -column1\" id=\"250717\"> \n             <p class=\" c-body\"><span class=\" d-large_font\"><span class=\" d-bold\"><span style=\"color:#073763;\">夏季休暇の御案内</span></span></span></p> \n             <div class=\" c-body c-right\"> \n              <hr class=\"c-hr\"> 2025.7.17 \n             </div> \n             <div class=\" c-body c-left\">\n               平素は格別のご高配を賜り、厚く御礼を申し上げます \n             </div> \n             <div class=\" c-body c-left\">\n               &nbsp; \n             </div> \n             <div class=\" c-body c-left\"> \n              <span style=\"color:#434343;\" data-sitecolor-text=\"\">弊社では下記の期間を夏季休暇とさせて頂きます</span> \n              <br> \n              <span style=\"color:#434343;\">期間中は何かとご不便をお掛けいたしますが、宜しくお願い申し上げます　</span> \n              <br> \n              <br> \n              <span class=\" d-bold\"><span style=\"color:#a61c00;\" data-sitecolor-text=\"\">2025年8月13日(水曜日)〜2025年8月17日(日曜日</span></span> \n              <span class=\" d-bold\"><span style=\"color:#a61c00;\" data-sitecolor-text=\"\">)</span></span> \n              <br> \n              <br> \n              <span style=\"color:#434343;\" data-sitecolor-text=\"\">レンタル商品の納品・引取は、お早めに御連絡くださいますようお願い申し上げます</span> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk5407\" class=\"b-plain c-space_normal c-sp-space_normal c-padding_normal c-sp-padding_normal cssskin-_block_main\" data-bk-id=\"bk5407\"> \n            <div class=\" column -column1\" id=\"250525\"> \n             <p class=\" c-body\"><span class=\" d-large_font\"><span class=\" d-bold\"><span style=\"color:#073763;\">鹿島工場 紹介動画公開しました</span></span></span></p> \n             <div class=\" c-body c-right\"> \n              <hr class=\"c-hr\"> 2025.5.25 \n             </div> \n             <div class=\" c-body c-left\"> \n              <span style=\"color:#000000;\">鹿島工場</span> \n              <span style=\"color:#000000;\">の紹介動画を公開しましたのでぜひご覧ください！</span> \n             </div> \n             <div class=\" c-body c-left\">\n               &nbsp; \n             </div> \n             <div class=\" c-body c-left\"> \n              <span class=\"js-sync -video\" style=\"display:none;\">,http://gdata.youtube.com/feeds/api/videos/ZVi_YhYixHk,,{\"playerWidth\":\"425\",\"useCustom\":false,\"autoPlay\":false,\"autoLoop\":false,\"autoNext\":false,\"quality\":\"default\",\"qualityName\":\"自動\",\"coverImage\":\"\"}</span> \n             </div> \n             <div class=\" c-body c-left\">\n               &nbsp; \n             </div> \n             <div class=\" c-body c-left\"> \n              <span style=\"color:#434343;\" data-sitecolor-text=\"\">動画は<a href=\"base/kasfactory.html\" data-pid=\"120\">事業所一覧</a> からもご視聴頂けます</span> \n              <br> \n              <br> \n              <span style=\"color:#000000;\">これから紹介動画を増やしていけるよう、撮影頑張っておりますので、どうぞご期待ください</span> \n              <span style=\"color:#434343;\" data-sitecolor-text=\"\"></span> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk5391\" class=\"b-plain c-space_normal c-sp-space_normal c-sp-padding_normal cssskin-_block_main\" data-bk-id=\"bk5391\"> \n            <div class=\" column -column1\" id=\"250519\"> \n             <p class=\" c-body\"><span style=\"color:#073763;\" class=\" d-large_font\"><span class=\" d-bold\">レンタル新商品のご案内</span></span></p> \n             <div class=\" c-body c-right\"> \n              <hr class=\"c-hr\"> \n              <span style=\"color:#434343;\" data-sitecolor-text=\"\">2025.5.19&nbsp;</span> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk5392\" class=\"b-plain c-space_normal c-sp-space_normal c-padding_narrow c-sp-padding_normal cssskin-_block_main -js-bindZoom\" data-bk-id=\"bk5392\"> \n            <div class=\" column -column1\"> \n             <div class=\" c-body\"> \n              <div class=\"c-img   \"> \n               <a href=\"_src/6974/img20250524212325937773.jpg?v=1767874585473\" class=\"js-zoomImage\" rel=\"width=2476,height=2504\"> \n                <picture> \n                 <source type=\"image/webp\" srcset=\"_src/6973/img20250524212325937773.webp?v=1767874585473\"> \n                 <img src=\"_src/6973/img20250524212325937773.jpg?v=1767874585473\" width=\"2476\" height=\"2504\" alt=\"\" id=\"imgsrc6973_1\" loading=\"lazy\"> \n                </picture></a> \n              </div> \n              <br> \n              <span class=\" d-small_font\">画像クリックで拡大表示します</span> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk5354\" class=\"b-plain c-space_normal c-sp-space_normal c-sp-padding_normal cssskin-_block_main\" data-bk-id=\"bk5354\"> \n            <div class=\" column -column1\" id=\"250425\"> \n             <p class=\" c-body\"><span style=\"color:#073763;\" class=\" d-large_font\"><span class=\" d-bold\">期間限定！ケルヒャー特別価格のご案内</span></span></p> \n             <div class=\" c-body c-right\"> \n              <hr class=\"c-hr\"> \n              <span style=\"color:#434343;\" data-sitecolor-text=\"\">2025.4.25&nbsp;</span> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk5353\" class=\"b-plain c-space_normal c-sp-space_normal c-padding_narrow c-sp-padding_normal cssskin-_block_main -js-bindZoom\" data-bk-id=\"bk5353\"> \n            <div class=\" g-column -col2 -sp-col1\" id=\"230105\"> \n             <div class=\" column -column1\"> \n              <p class=\" c-body\">高圧洗浄機にて有名な「ケルヒャージャパン㈱」さんとのコラボ企画が実現しました。<br>&nbsp;<br>2025年4月1日～5月31日の期間限定で<br>業務用乾湿両用クリーナーを特別価格でご提供中です。<br>&nbsp;<br>当社のリース商品としても取扱いがあり、好評の声が多く<br>今回の企画が実現いたしました。<br>&nbsp;<br>是非ともこの機会を逃さずにお買い求めいただければと思います。<br>&nbsp;<br>製品内容および価格も含めまして、詳しくは最寄りの営業所へお気軽に<br>お問い合わせください。<br>&nbsp;</p> \n             </div> \n             <div class=\" column -column2 -column-lasts\"> \n              <div class=\" c-body\"> \n               <div class=\"c-img   \"> \n                <a href=\"_src/6870/img20250427214854523370.jpg?v=1767874585473\" class=\"js-zoomImage\" rel=\"width=2480,height=3507\"> \n                 <picture> \n                  <source type=\"image/webp\" srcset=\"_src/6869/img20250427214854523370.webp?v=1767874585473\"> \n                  <img src=\"_src/6869/img20250427214854523370.jpg?v=1767874585473\" width=\"2480\" height=\"3507\" alt=\"\" id=\"imgsrc6869_1\" loading=\"lazy\"> \n                 </picture></a> \n               </div> \n              </div> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk5352\" class=\"b-plain c-space_normal c-sp-space_normal c-padding_normal c-sp-padding_normal cssskin-_block_main\" data-bk-id=\"bk5352\"> \n            <div class=\" column -column1\" id=\"250420\"> \n             <p class=\" c-body\"><span class=\" d-large_font\"><span class=\" d-bold\"><span style=\"color:#073763;\">ひたちなか営業所 紹介動画公開しました</span></span></span></p> \n             <div class=\" c-body c-right\"> \n              <hr class=\"c-hr\"> 2025.4.20 \n             </div> \n             <div class=\" c-body c-left\"> \n              <span style=\"color:#000000;\">ひたちなか</span> \n              <span style=\"color:#000000;\">営業所の紹介動画を公開しましたのでぜひご覧ください！</span> \n             </div> \n             <div class=\" c-body c-left\">\n               &nbsp; \n             </div> \n             <div class=\" c-body c-left\"> \n              <span class=\"js-sync -video\" style=\"display:none;\">,http://gdata.youtube.com/feeds/api/videos/Cp0aev2qR5g,,{\"playerWidth\":\"425\",\"useCustom\":false,\"autoPlay\":false,\"autoLoop\":false,\"autoNext\":false,\"quality\":\"default\",\"qualityName\":\"自動\",\"coverImage\":\"\"}</span> \n             </div> \n             <div class=\" c-body c-left\">\n               &nbsp; \n             </div> \n             <div class=\" c-body c-left\"> \n              <span style=\"color:#434343;\" data-sitecolor-text=\"\">動画は<a href=\"base/hitachinaka.html\" data-pid=\"109\">事業所一覧</a> からもご視聴頂けます</span> \n              <br> \n              <br> \n              <span style=\"color:#000000;\">これから紹介動画を増やしていけるよう、撮影頑張っておりますので、どうぞご期待ください</span> \n              <span style=\"color:#434343;\" data-sitecolor-text=\"\"></span> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk5277\" class=\"b-plain c-space_normal c-sp-space_normal c-sp-padding_normal cssskin-_block_main\" data-bk-id=\"bk5277\"> \n            <div class=\" column -column1\" id=\"240101\"> \n             <p class=\" c-body\"><span style=\"color:#073763;\" class=\" d-large_font\"><span class=\" d-bold\">新年のご挨拶</span></span></p> \n             <div class=\" c-body c-right\"> \n              <hr class=\"c-hr\"> \n              <span style=\"color:#434343;\" data-sitecolor-text=\"\">2025.1.1&nbsp;</span> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk5278\" class=\"b-plain c-space_normal c-sp-space_normal c-sp-padding_normal cssskin-_block_main\" data-bk-id=\"bk5278\"> \n            <div class=\" column -column1\"> \n             <div class=\" c-body\"> \n              <div class=\"c-img   \"> \n               <picture> \n                <source type=\"image/webp\" srcset=\"_src/6768/img20241230125705758277.webp?v=1767874585473\"> \n                <img src=\"_src/6768/img20241230125705758277.jpg?v=1767874585473\" width=\"1000\" height=\"500\" alt=\"\" id=\"imgsrc6768_1\" loading=\"lazy\"> \n               </picture> \n              </div> \n              <br> \n              <span style=\"color:#555555;\" class=\" d-small_font\">SDGs推進の一環として、年賀状でのご挨拶を廃止いたしました</span> \n             </div> \n            </div> \n           </div> \n          </section> \n         </div> \n         <div id=\"a-side-a\" data-float=\"false\" class=\"a-side-a column -col4 \" data-fixed-size=\"200px\"> \n          <section> \n           <div id=\"bk1853\" class=\"b-plain c-space_normal c-sp-space_normal c-sp-padding_normal bd-webp -dress_navy cssskin-_block_side_a\" data-bk-id=\"bk1853\" data-shared=\"true\" data-sharedname=\"info_archive\" data-sticky=\"true\"> \n            <div class=\" column -column1\"> \n             <nav> \n              <div class=\" -menu_center\"> \n               <ul class=\"c-menu -menu_e menu-parts -v\"> \n                <li><span class=\" c-u