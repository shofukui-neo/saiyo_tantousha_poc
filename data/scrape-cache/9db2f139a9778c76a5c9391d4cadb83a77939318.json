{"url":"https://www.tepco-sa.co.jp/ssl/recruit/new_graduate/voice_05/","html":"<!DOCTYPE html>\r\n<html lang=\"ja\">\r\n\r\n<head>\r\n  <meta charset=\"UTF-8\">\r\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n  <meta name=\"description\" content=\"新卒入社した社員のリアルな声をご紹介します。就職活動の決め手や現在の業務、やりがいなどを語っています。\">\r\n  <meta name=\"keywords\" content=\"社員インタビュー, 新卒採用, 若手社員, 入社理由, テプコ・ソリューション・アドバンス\">\r\n  <meta name=\"author\" content=\"テプコ・ソリューション・アドバンス株式会社\">\r\n  <title>新卒社員インタビュー｜採用情報｜テプコ・ソリューション・アドバンス株式会社</title>\r\n\r\n  <!--favicon https://www.favicon-generator.org/-->\r\n  <link rel=\"apple-touch-icon\" sizes=\"57x57\" href=\"https://www.tepco-sa.co.jp/ssl/images/site-icon/apple-icon-57x57.png\">\r\n  <link rel=\"apple-touch-icon\" sizes=\"60x60\" href=\"https://www.tepco-sa.co.jp/ssl/images/site-icon/apple-icon-60x60.png\">\r\n  <link rel=\"apple-touch-icon\" sizes=\"72x72\" href=\"https://www.tepco-sa.co.jp/ssl/images/site-icon/apple-icon-72x72.png\">\r\n  <link rel=\"apple-touch-icon\" sizes=\"76x76\" href=\"https://www.tepco-sa.co.jp/ssl/images/site-icon/apple-icon-76x76.png\">\r\n  <link rel=\"apple-touch-icon\" sizes=\"114x114\" href=\"https://www.tepco-sa.co.jp/ssl/images/site-icon/apple-icon-114x114.png\">\r\n  <link rel=\"apple-touch-icon\" sizes=\"120x120\" href=\"https://www.tepco-sa.co.jp/ssl/images/site-icon/apple-icon-120x120.png\">\r\n  <link rel=\"apple-touch-icon\" sizes=\"144x144\" href=\"https://www.tepco-sa.co.jp/ssl/images/site-icon/apple-icon-144x144.png\">\r\n  <link rel=\"apple-touch-icon\" sizes=\"152x152\" href=\"https://www.tepco-sa.co.jp/ssl/images/site-icon/apple-icon-152x152.png\">\r\n  <link rel=\"apple-touch-icon\" sizes=\"180x180\" href=\"https://www.tepco-sa.co.jp/ssl/images/site-icon/apple-icon-180x180.png\">\r\n  <link rel=\"icon\" type=\"image/png\" sizes=\"192x192\" href=\"https://www.tepco-sa.co.jp/ssl/images/site-icon/android-icon-192x192.png\">\r\n  <link rel=\"icon\" type=\"image/png\" sizes=\"32x32\" href=\"https://www.tepco-sa.co.jp/ssl/images/site-icon/favicon-32x32.png\">\r\n  <link rel=\"icon\" type=\"image/png\" sizes=\"96x96\" href=\"https://www.tepco-sa.co.jp/ssl/images/site-icon/favicon-96x96.png\">\r\n  <link rel=\"icon\" type=\"image/png\" sizes=\"16x16\" href=\"https://www.tepco-sa.co.jp/ssl/images/site-icon/favicon-16x16.png\">\r\n  <link rel=\"manifest\" href=\"https://www.tepco-sa.co.jp/ssl/images/site-icon/manifest.json\">\r\n  <meta name=\"msapplication-TileColor\" content=\"#ffffff\">\r\n  <meta name=\"msapplication-TileImage\" content=\"https://www.tepco-sa.co.jp/ssl/images/site-icon/ms-icon-144x144.png\">\r\n  <meta name=\"theme-color\" content=\"#ffffff\">\r\n  <link rel=\"canonical\" href=\"https://www.tepco-sa.co.jp/ssl/recruit/new_graduate/voice_05/\">\r\n\r\n  <!--google fonts-->\r\n  <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\r\n  <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\r\n  <link href=\"https://fonts.googleapis.com/css2?family=Hina+Mincho&family=Zen+Maru+Gothic:wght@400;500;700;900&display=swap\" rel=\"stylesheet\">\r\n\r\n  <!--css-->\r\n  <link href=\"https://www.tepco-sa.co.jp/ssl/src/css/vendor.css\" rel=\"stylesheet\">\r\n  <link href=\"https://www.tepco-sa.co.jp/ssl/src/css/theme.css\" rel=\"stylesheet\">\r\n  <link href=\"https://www.tepco-sa.co.jp/ssl/src/css/themes/career-detail.css\" rel=\"stylesheet\">\r\n  <script src=\"https://www.tepco-sa.co.jp/ssl/src/js/jquery.min.js\"></script>\r\n\r\n  <!-- Google Tag Manager -->\r\n  <script>(function (w, d, s, l, i) {\r\n      w[l] = w[l] || []; w[l].push({\r\n        'gtm.start':\r\n          new Date().getTime(), event: 'gtm.js'\r\n      }); var f = d.getElementsByTagName(s)[0],\r\n        j = d.createElement(s), dl = l != 'dataLayer' ? '&l=' + l : ''; j.async = true; j.src =\r\n          'https://www.googletagmanager.com/gtm.js?id=' + i + dl; f.parentNode.insertBefore(j, f);\r\n    })(window, document, 'script', 'dataLayer', 'GTM-P8XXC67');</script>\r\n  <!-- End Google Tag Manager -->\r\n</head>\r\n\r\n<body>\r\n  <!-- Google Tag Manager (noscript) -->\r\n  <noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-P8XXC67\" height=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\r\n  <!-- End Google Tag Manager (noscript) -->\r\n\r\n  <div id=\"header\"></div>\r\n  <script>\r\n    $(function () {\r\n      $('#header').load('https://www.tepco-sa.co.jp/ssl/src/inc/header.html');\r\n    });\r\n  </script>\r\n\r\n  <div class=\"page-wrapper voice-newgrads1-page\">\r\n    <div class=\"main-container bg-transparent p-0 mb-5\">\r\n      <nav aria-label=\"breadcrumb\" class=\"page-breadcrumb\">\r\n        <ol class=\"breadcrumb mb-0\">\r\n          <li class=\"breadcrumb-item\"><a href=\"https://www.tepco-sa.co.jp/ssl/\">ホーム</a></li>\r\n          <li class=\"breadcrumb-item\"><a href=\"https://www.tepco-sa.co.jp/ssl/recruit/\">採用情報</a></li>\r\n          <li class=\"breadcrumb-item\"><a href=\"https://www.tepco-sa.co.jp/ssl/recruit/new_graduate/\">新卒採用</a></li>\r\n          <li class=\"breadcrumb-item active\" aria-current=\"page\">先輩社員の声 - ネットワークサービス本部　ネットワークサービス第二部　松戸ネットワーク受付センターH・A</li>\r\n        </ol>\r\n      </nav>\r\n    </div>\r\n    <div class=\"voice-main\">\r\n      <div class=\"voice-main__img\">\r\n        <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/interview/newgrads5-banner.png\" alt=\"hero-img\">\r\n      </div>\r\n      <div class=\"voice-main__ttl\">\r\n        休日もつい街中の<br>\r\n        電気設備に目が行くように。<br>\r\n        あたたかい職場環境で<br>\r\n        やりがいを持って働けています。\r\n      </div>\r\n      <div class=\"voice-main__block\">\r\n        <div>\r\n          <div class=\"depart\">ネットワークサービス本部　ネットワークサービス第二部<br>松戸ネットワーク受付センター</div>\r\n          <div class=\"name\">H・A</div>\r\n        </div>\r\n        <div class=\"info\">\r\n          2021年度 入社<br>\r\n          <small>部署名等は取材当初のものです</small>\r\n        </div>\r\n      </div>\r\n    </div>\r\n    <div class=\"sc-job-descp main-container d-flex flex-column flex-lg-row\">\r\n      <div class=\"img-wrapper\">\r\n        <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/interview/newgrads5-img-3.jpg\" alt=\"\" style=\"border-radius: 12px;\">\r\n      </div>\r\n      <div class=\"title-descp\">\r\n        <div class=\"fs-26 title-wrapper\">仕事内容</div>\r\n        <p class=\"descp para-text mb-0 text-white\">\r\n          ネットワーク受付センターでは、電気の新規契約や契約内容変更にともなう工事の受付をしています。私の仕事は、受付業務を担当しているスタッフの方々の業務が円滑に進むよう、全体の管理や運営を行うことです。例えば、マニュアルの変更があった際には、大勢のスタッフの前に立って説明をしないといけません。誰にでも伝わるように話すのは難しいですが、先輩方の姿を見ながら学んでいる最中です。<br>\r\n          事務職といっても毎日同じ仕事をするのではなく、申込内容は一つひとつ違うものなので、日々新しい仕事と向き合っているイメージです。\r\n        </p>\r\n      </div>\r\n    </div>\r\n    <div class=\"sc-wrapper main-container\">\r\n      <div class=\"decide-factor\">\r\n        <section class=\"p-schedule\">\r\n          <div class=\"p-content\">\r\n            <h2 class=\"p-schedule-mh\">一日のスケジュール</h2>\r\n            <div class=\"p-schedule-wrapper\">\r\n              <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/new_graduate/icn_schedule01.png\" alt=\"\" class=\"p-schedule-icn01\">\r\n              <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/new_graduate/icn_schedule02.png\" alt=\"\" class=\"p-schedule-icn02\">\r\n              <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/new_graduate/icn_schedule03.png\" alt=\"\" class=\"p-schedule-icn03\">\r\n              <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/new_graduate/icn_schedule04.png\" alt=\"\" class=\"p-schedule-icn04\">\r\n              <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/new_graduate/icn_schedule05.png\" alt=\"\" class=\"p-schedule-icn05 sp\">\r\n              <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/new_graduate/icn_schedule06.png\" alt=\"\" class=\"p-schedule-icn06 sp\">\r\n              <ul class=\"p-schedule-list\">\r\n                <li class=\"p-schedule-list-item\">\r\n                  <p class=\"p-schedule-time\">8:25</p>\r\n                  <p class=\"p-schedule-desc\">出社</p>\r\n                </li>\r\n                <li class=\"p-schedule-list-item\">\r\n                  <p class=\"p-schedule-time\">8:40</p>\r\n                  <p class=\"p-schedule-desc\">始業・朝礼</p>\r\n                </li>\r\n                <li class=\"p-schedule-list-item\">\r\n                  <p class=\"p-schedule-time\">9:00</p>\r\n                  <p class=\"p-schedule-desc\">社員ミーティング</p>\r\n                </li>\r\n                <li class=\"p-schedule-list-item\">\r\n                  <p class=\"p-schedule-time\">9:30</p>\r\n                  <p class=\"p-schedule-desc\">オペレーターのサポート、問い合わせ対応</p>\r\n                </li>\r\n                <li class=\"p-schedule-list-item\">\r\n                  <p class=\"p-schedule-time\">12:00</p>\r\n                  <p class=\"p-schedule-desc\">昼食</p>\r\n                </li>\r\n                <li class=\"p-schedule-list-item\">\r\n                  <p class=\"p-schedule-time\">13:00</p>\r\n                  <p class=\"p-schedule-desc\">オペレーターのサポート、作業結果チェック</p>\r\n                </li>\r\n                <li class=\"p-schedule-list-item\">\r\n                  <p class=\"p-schedule-time\">15:00</p>\r\n                  <p class=\"p-schedule-desc\">ミーティング</p>\r\n                </li>\r\n                <li class=\"p-schedule-list-item\">\r\n                  <p class=\"p-schedule-time\">17:00</p>\r\n                  <p class=\"p-schedule-desc\">日常業務のとりまとめ、報告</p>\r\n                </li>\r\n                <li class=\"p-schedule-list-item\">\r\n                  <p class=\"p-schedule-time\">17:20</p>\r\n                  <p class=\"p-schedule-desc\">終業・退社</p>\r\n                </li>\r\n              </ul>\r\n            </div>\r\n          </div>\r\n        </section>\r\n        <div class=\"bottom-banner d-flex align-items-center\">\r\n          <div class=\"title-d escp d-flex flex-column flex-lg-row\">\r\n            <div class=\"title-box d-flex justify-content-center\">\r\n              <div class=\"title-wrapper d-flex justify-content-center flex-column mb-0\">\r\n                <div>TSA</div>\r\n                <div class=\"bottom-text\">の魅力</div>\r\n              </div>\r\n            </div>\r\n            <div class=\"descp para-text\">\r\n              <div class=\"second-title\">安定性のある職場で日々、変化・成長していける</div>\r\n              TSAは社会のインフラをささえる企業なので、安定性が高いというのが魅力だと思います。ですが、経営理念に「変化を楽しむ」とあるように、日々の業務は安定よりもカイゼン改革の意識を大切にしています。<br>\r\n              「プチカイゼン」の案を常に募集していて、提出した内容が少しでも業務効率化や作業時間削減に繋がれば報酬に反映してくれるのもうれしいです。新人の何気ない意見も尊重してくださるので、やりがいに繋がっています。<br>\r\n              あとは、なんといっても充実した福利厚生と、職場の明るい雰囲気が大好きです。\r\n            </div>\r\n          </div>\r\n        </div>\r\n        <div class=\"custom-row d-flex align-items-center flex-column flex-lg-row\">\r\n          <div class=\"img-wrapper\">\r\n            <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/interview/newgrads5-img-1.png\" alt=\"decide-factor\" style=\"border-radius: 12px;\">\r\n          </div>\r\n          <div class=\"title-descp\">\r\n            <div class=\"fs-26 title-wrapper\">入社の決め手は</div>\r\n            <p class=\"descp para-text mb-0\">\r\n              もともとはアミューズメント業界を中心に就活をしていました。でも私の就活時代はほとんどアミューズメント系の募集がなくて、志望先を一から見直すことにしたんです。すると、私のやりたいことは「人」に関わることや、世の中のためになる仕事だと再認識でき、視野が広がりました。<br>\r\n              そこからインフラ業界なども探すようになり、<br>\r\n              TSAを知りました。実際に働いてみて思うのは、社会貢献度の高い仕事に携われる喜びです。大勢のセンターのメンバーと協力し合って、誰かのために働けている実感があります。\r\n            </p>\r\n          </div>\r\n        </div>\r\n        <div class=\"custom-row d-flex align-items-center flex-column-reverse flex-lg-row\">\r\n          <div class=\"title-descp\">\r\n            <div class=\"fs-26 title-wrapper\">仕事の大変なところ</div>\r\n            <p class=\"descp para-text mb-0\">\r\n              受付スタッフの方からの質問に答える時、自分では理解しているつもりのことでも、筋道立てて説明するのが難しいです。まずは相手がどこまで理解できているか、どういう考えを持って質問しているのかを確認することも大事ですし、その上で論理的に説明するよう意識しています。しっかり伝わった時はうれしいですし、少しずつ成長できているのかなと実感します。<br>\r\n              常に電気設備の資料ばかり見て考えているので、最近は街を歩いていてもつい電線に目が行ってしまいます。不思議な電線の引き方をしているなとか、なんでこういう設置方法になっているんだろうとか……。職業病ですね(笑)。\r\n            </p>\r\n          </div>\r\n          <div class=\"img-wrapper\">\r\n            <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/interview/newgrads5-img-2.png\" alt=\"decide-factor\" style=\"border-radius: 12px;\">\r\n          </div>\r\n        </div>\r\n        <div class=\"custom-row d-flex align-items-center\">\r\n          <div class=\"title-descp\">\r\n            <div class=\"fs-26 title-wrapper\">職場の雰囲気</div>\r\n            <p class=\"descp para-text mb-0\">\r\n              受付センターの雰囲気はとても明るくて、和気あいあいとしています。そして日頃から業務についてのカイゼン点を検討し合うような風土もあり、メリハリがあるなと感じます。年齢の離れた先輩ばかりですが、皆さん新人の私たちをとても気遣ってくださるので、困った時にはいつでも相談しやすい雰囲気です。<br>\r\n              有給も積極的に活用するよう気にかけてくださいますし、体調が良くない時は「健康が第一だからね」と無理せず休暇申請するよう声をかけてくださいます。本当に、あたたかい職場だなと感じます。\r\n            </p>\r\n          </div>\r\n        </div>\r\n        <div class=\"future-goals d-flex align-items-center\">\r\n          <div class=\"title-descp d-flex align-items-center flex-column flex-lg-row\">\r\n            <div class=\"title-box d-flex align-items-center justify-content-center\">\r\n              <div class=\"fs-26 title-wrapper\">今後の目標</div>\r\n            </div>\r\n            <p class=\"descp para-text mb-0\">\r\n              先日、「ロジカルシンキング」の研修を受けたのですが、論理的な考え方や伝え方を学ぶ良い機会になりました。難しいことも多いですが、研修で学んだことや日々の実践を通して伝える力を磨き、センターの運営により貢献していくことが今の目標です。<br>\r\n              そして、常に「人の立場に立って考える」ことを忘れずに、仕事でかかわる人やお客さまの立場に立って行動していきたいです。\r\n            </p>\r\n          </div>\r\n        </div>\r\n        <div class=\"future-goals\">\r\n          <div class=\"title-descp d-flex flex-column flex-lg-row\">\r\n            <div class=\"img-wrapper position-relative\">\r\n              <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/new_graduate/img_voice05_message.png\" alt=\"applicant-img\">\r\n            </div>\r\n            <div class=\"right-sec\">\r\n              <div class=\"fs-26 title-wrapper\">応募者へのメッセージ</div>\r\n              <div class=\"descp para-text mb-0\">\r\n                就活は思うように進まないことも多いと思いますが、自分なりに納得いくまで頑張ってほしいなと思います。最初から業種を絞りこみすぎず、広く探してみると意外と自分に合う仕事が見えてくるかもしれません。<br>\r\n                TSAは、2021年度から15年ぶりに新卒採用を再開しました。私たちはその1期社員になります。会社全体として、カイゼン改革やデジタル化を進めているので、まだまだ若い力が必要です。少しでも興味があれば、応募してくださるとうれしいです。\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n        <div class=\"entry-banner\">\r\n          <div class=\"title text-center\">\r\n            <div class=\"bg-text\">ENTRY</div>\r\n          </div>\r\n          <a href=\"https://job.mynavi.jp/27/pc/search/corp249116/outline.html\" class=\"img-wrapper d-block mx-auto\" target=\"_blank\">\r\n            <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/new_graduate/survey/entry-banner-img.png\" alt=\"banner-img\">\r\n          </a>\r\n        </div>\r\n        <div class=\"graduate-title text-center fw-bold text-orange\">先輩社員の声</div>\r\n        <div class=\"new-graduate-list\">\r\n          <a href=\"https://www.tepco-sa.co.jp/ssl/recruit/new_graduate/voice_01/\" class=\"graduate\">\r\n            <div class=\"graduate-image\">\r\n              <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/career/graduate-1.png\" alt=\"graduate-img\">\r\n            </div>\r\n            <div class=\"info-box\">\r\n              <div class=\"title fw-bold\">\r\n                エネルギーサービス本部<br>\r\n                法人サポートセンター\r\n              </div>\r\n              <div class=\"d-flex flex-column flex-xl-row justify-content-between align-items-end\">\r\n                <div class=\"date\">2021年度 入社</div>\r\n              </div>\r\n            </div>\r\n          </a>\r\n          <a href=\"https://www.tepco-sa.co.jp/ssl/recruit/new_graduate/voice_03/\" class=\"graduate d-inline-block\">\r\n            <div class=\"graduate-image\">\r\n              <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/career/graduate-3.png\" alt=\"graduate-img\">\r\n            </div>\r\n            <div class=\"info-box\">\r\n              <div class=\"title fw-bold\">\r\n                フィールドサービス本部<br>\r\n                技術サービス部\r\n              </div>\r\n              <div class=\"d-flex flex-column flex-xl-row justify-content-between align-items-end\">\r\n                <div class=\"date\">2022年度 入社</div>\r\n              </div>\r\n            </div>\r\n          </a>\r\n          <a href=\"https://www.tepco-sa.co.jp/ssl/recruit/new_graduate/voice_04/\" class=\"graduate d-inline-block\">\r\n            <div class=\"graduate-image\">\r\n              <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/career/graduate-4.png\" alt=\"graduate-img\">\r\n            </div>\r\n            <div class=\"info-box\">\r\n              <div class=\"title fw-bold\">\r\n                フィールドサービス本部<br>\r\n                屋内配線調査部\r\n              </div>\r\n              <div class=\"d-flex flex-column flex-xl-row justify-content-between align-items-end\">\r\n                <div class=\"date\">2022年度 入社</div>\r\n              </div>\r\n            </div>\r\n          </a>\r\n        </div>\r\n        <a href=\"https://www.tepco-sa.co.jp/ssl/recruit/new_graduate/survey/\" class=\"graduate-banner img-wrapper mt-5 d-none d-md-block\">\r\n          <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/career/graduate-banner_off.png\" alt=\"先輩社員アンケート\" onmouseover=\"this.src='/ssl/images/recruit/career/graduate-banner.png'\" onmouseout=\"this.src='/ssl/images/recruit/career/graduate-banner_off.png'\">\r\n        </a>\r\n        <a href=\"https://www.tepco-sa.co.jp/ssl/recruit/new_graduate/survey/\" class=\"graduate-banner img-wrapper mt-5 d-md-none\">\r\n          <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/career/graduate-banner.png\" alt=\"先輩社員アンケート\">\r\n        </a>\r\n      </div>\r\n    </div>\r\n    <!-- main content -->\r\n\r\n    <div id=\"f