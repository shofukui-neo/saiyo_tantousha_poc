{"url":"https://www.oh-tomi.co.jp/contact/","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n<head>\n<meta http-equiv=\"content-language\" content=\"ja\"> \n<meta charset=\"UTF-8\" />\n<title>お問い合わせ｜株式会社 大富</title>\n\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1,minimum-scale=1,maximum-scale=1,user-scalable=no\">\n<meta name=\"Keywords\" content=\"大富,株式会社,福岡,古賀,配送,九州,大分,佐賀,長崎,北九州,荷物,輸送\">\n<meta name=\"Description\" content=\"株式会社 大富は、福岡の古賀を拠点に九州北部にて６つの営業所と連携し、日本全国にスムーズかつ安全な貨物輸送を行っております。お客様の大切なお荷物の運搬は私たち大富にお任せ下さい。\">\n<meta name=\"format-detection\" content=\"telephone=no\">\n\n<link rel=\"stylesheet\" href=\"../css/reset.css\" />\n<link rel=\"stylesheet\" href=\"../css/import.css\" />\n<link rel=\"stylesheet\" href=\"../css/mailform.css\" type=\"text/css\">\n\n<script src=\"https://code.jquery.com/jquery-1.12.4.min.js\"></script>\n<script src=\"../js/common.js\"></script>\n<script src=\"../js/image-switch.js\"></script>\n<script>\n\tif (window.matchMedia('screen and (max-width:480px)').matches) {\n\t\t//メニュー\n\t\t$(function() {\n\t\t    $(\"#hNavi\").css(\"display\",\"none\");\n\t\t\t$(\".menu_button\").on(\"click\", function() {\n\t\t\t\t$(\"#hNavi\").slideToggle();\n\t\t\t\t$(\".menu_button\").toggleClass(\"menu_close\");\n\t\t\t});\n\t\t});\n\t}\n</script>\n\n<script>\n// 変換前\nvar beforeStr = new Array('ｧ','ｨ','ｩ','ｪ','ｫ','ｬ','ｭ','ｮ','ｯ','ｰ','ｳﾞ','ｶﾞ','ｷﾞ','ｸﾞ','ｹﾞ','ｺﾞ','ｻﾞ','ｼﾞ','ｽﾞ','ｾﾞ','ｿﾞ','ﾀﾞ','ﾁﾞ','ﾂﾞ','ﾃﾞ','ﾄﾞ','ﾊﾞ','ﾋﾞ','ﾌﾞ','ﾍﾞ','ﾎﾞ','ﾊﾟ','ﾋﾟ','ﾌﾟ','ﾍﾟ','ﾎﾟ','ｱ','ｲ','ｳ','ｴ','ｵ','ｶ','ｷ','ｸ','ｹ','ｺ','ｻ','ｼ','ｽ','ｾ','ｿ','ﾀ','ﾁ','ﾂ','ﾃ','ﾄ','ﾅ','ﾆ','ﾇ','ﾈ','ﾉ','ﾊ','ﾋ','ﾌ','ﾍ','ﾎ','ﾏ','ﾐ','ﾑ','ﾒ','ﾓ','ﾔ','ﾕ','ﾖ','ﾗ','ﾘ','ﾙ','ﾚ','ﾛ','ﾜ','ｦ','ﾝ');\n// 変換後\nvar afterStr = new Array('ァ','ィ','ゥ','ェ','ォ','ャ','ュ','ョ','ッ','ー','ヴ','ガ','ギ','グ','ゲ','ゴ','ザ','ジ','ズ','ゼ','ゾ','ダ','ヂ','ヅ','デ','ド','バ','ビ','ブ','ベ','ボ','パ','ピ','プ','ペ','ポ','ア','イ','ウ','エ','オ','カ','キ','ク','ケ','コ','サ','シ','ス','セ','ソ','タ','チ','ツ','テ','ト','ナ','ニ','ヌ','ネ','ノ','ハ','ヒ','フ','ヘ','ホ','マ','ミ','ム','メ','モ','ヤ','ユ','ヨ','ラ','リ','ル','レ','ロ','ワ','ヲ','ン');\n\nfunction convertStr(str) {\n\tvar fullStr = str;\n\tfor(var i = 0; i < beforeStr.length; i++) {\n\t    fullStr = fullStr.replace(new RegExp(beforeStr[i], 'g'), afterStr[i]);\n\t}\n\treturn fullStr;\n}\n$(function() {\n\t$('.sample').on('blur', function() {\n\t\tvar str = $(this).val();\n\t\t$(this).val(convertStr(str));\n\t});\n\n});\n</script>\n\n</head>\n<body id=\"contact_n\">\n<div id=\"wrapper\">\n\n<header>\n<div id=\"header_inner\">\n<h1 class=\"header_logo\"><a href=\"../index.html\"><img src=\"../img/common/header_logo_pc.png\" width=\"226\" alt=\"株式会社 大富\" class=\"js-image-switch\" /></a></h1>\n\n<div id=\"gnavi_bg\">\n<div id=\"gnavi\">\n<ul class=\"clearfix\">\n<li><a href=\"../\">ホーム</a></li>\n<li><a href=\"../works.html\">業務内容</a></li>\n<li><a href=\"../education.html\">社員教育</a></li>\n<li><a href=\"../outline.html\">会社案内</a></li>\n<li><a href=\"../base.html\">営業所</a></li>\n<li><a href=\"../recruit/\">採用情報</a></li>\n<li class=\"current\"><a href=\"../contact/\">お問い合わせ</a></li>\n</ul>\n</div>\n</div>\n\n<div class=\"sp\">\n<div class=\"menu_button\"><span></span><span></span><span></span></div>\n<ul id=\"hNavi\">\n<li><a href=\"../\">ホーム</a></li>\n<li><a href=\"../works.html\">業務内容</a></li>\n<li><a href=\"../education.html\">社員教育</a></li>\n<li><a href=\"../outline.html\">会社案内</a></li>\n<li><a href=\"../base.html\">営業所</a></li>\n<li><a href=\"../recruit/\">採用情報</a></li>\n<li><a href=\"../contact/\">お問い合わせ</a></li>\n<li><a href=\"../privacy.html\">プライバシーポリシー</a></li>\n<li><a href=\"../privacy.html#sitemap\">サイトマップ</a></li>\n<li><a href=\"tel:0929413311\" class=\"telhref\"><span><img src=\"../img/common/hNavi_inquiry.png\" alt=\"24時間対応 お問い合せは...092-941-3311\" /></span></a></li>\n</ul>\n</div>\n\n<p class=\"white_mask_top\"><img src=\"../img/common/white_mask_page_top.png\" width=\"683\" height=\"1159\" alt=\"\" /></p>\n</div><!--#header_inner // -->\n</header><!-- #header // -->\n\n\n<div id=\"main_cont\">\n<div class=\"inner\">\n\n<div class=\"main_visual_in\">\n<h2>お問い合わせ<span>CONTACT</span></h2>\n<img src=\"../img/contact/main_visual.jpg\" width=\"950\" height=\"235\" alt=\"お問い合わせ イメージ画像\" />\n</div><!--.main_visual_in // -->\n\n\n\n<article class=\"w920\">\n<h3 class=\"h3_icon\">お問い合わせフォーム<span>Contact Form</span></h3>\n<p>株式会社大富では、皆さまからいただきましたご意見・ご要望・ご質問を今後のサービスの充実に活かしてまいります。<br>\nお気軽にお問い合わせください。 <br>\n<span class=\"must\">※</span>は必須項目です。 半角カナ、特殊文字は文字化けの原因となりますのでご使用にならないようお願い申し上げます。 \n</p>\n\n\n\n\n\n\n\n<!--メールフォーム-->\n<form method=\"post\" action=\"index.php\" enctype=\"multipart/form-data\">\n<dl class=\"mailform\">\n\n\n\n\n<dt class=\"mfp\"><span class=\"must\">※必須</span>お名前</dt>\n<dd class=\"mfp\">\n<input type=\"text\" name=\"お名前\" value=\"\" size=\"15\" placeholder=\"例）山田　太郎\"> \n<input type=\"hidden\" name=\"required[]\" value=\"お名前\">\n\n</dd>\n\n<dt class=\"mfp\"><span class=\"must\">※必須</span>ふりがな</dt>\n<dd class=\"mfp\">\n<input type=\"text\" name=\"ふりがな\" value=\"\" size=\"15\" placeholder=\"例）やまだ　たろう\"> \n<input type=\"hidden\" name=\"required[]\" value=\"ふりがな\">\n\n</dd>\n\n<dt class=\"mfp\">企業名</dt>\n<dd class=\"mfp\"><input type=\"text\" name=\"企業名\" size=\"50\"></dd>\n\n<dt class=\"mfp\">所属部署</dt>\n<dd class=\"mfp\"><input type=\"text\" name=\"所属部署\" size=\"50\"></dd>\n\n<dt class=\"mfp\">役職</dt>\n<dd class=\"mfp\"><input type=\"text\" name=\"役職\" size=\"50\"></dd>\n\n<dt class=\"mfp\"><span class=\"must\">※必須</span>郵便番号</dt>\n<dd class=\"mfp\">\n<input type=\"text\" name=\"郵便番号\" value=\"\" size=\"30\" >\n<input type=\"hidden\" name=\"required[]\" value=\"郵便番号\">\n\n</dd>\n\n<dt class=\"mfp\"><span class=\"must\">※必須</span>ご住所</dt>\n<dd class=\"mfp\"><input type=\"text\" name=\"ご住所\" value=\"\" size=\"50\">\n<input type=\"hidden\" name=\"required[]\" value=\"ご住所\">\n\n</dd>\n\n<dt class=\"mfp\"><span class=\"must\">※必須</span>メールアドレス</dt>\n<dd class=\"mfp\"><input type=\"text\" name=\"メールアドレス\" value=\"\" class=\"middle\">\n<input type=\"hidden\" name=\"email[]\" value=\"メールアドレス\">\n\n<input type=\"hidden\" name=\"required[]\" value=\"メールアドレス\">\n</dd>\n\n<dt class=\"mfp\"><span class=\"must\">※必須</span>電話番号</dt>\n<dd class=\"mfp\"><input type=\"text\" name=\"電話番号\" value=\"\" size=\"16\" data-min=\"9\"placeholder=\"例）000-000-0000\">\n<input type=\"hidden\" name=\"required[]\" value=\"電話番号\">\n\n</dd>\n<dt class=\"mfp\">FAX番号</dt>\n<dd class=\"mfp\"><input type=\"text\" name=\"FAX番号\" value=\"\" size=\"16\" data-min=\"9\">\n</dd>\n\n<dt class=\"mfp\"><span class=\"must\">※必須</span>お問い合わせ内容</dt>\n<dd class=\"mfp\"><textarea name=\"お問い合わせ内容\"></textarea>\n<input type=\"hidden\" name=\"required[]\" value=\"お問い合わせ内容\">\n\n</dd>\n\n\n</dl>\n<div class=\"mfp_buttons\">\n<button type=\"reset\" class=\"button01\">リセット</button><button type=\"submit\" class=\"button01\">入力内容確認</button>\n</div>\n</form>\n<!--/メールフォーム-->\n</article>\n\n\n\n</div><!-- .inner // -->\n</div><!-- #main_cont // -->\n\n<div class=\"sp_bottom_banner\">\n<div class=\"inner\">\n<ul class=\"clearfix\">\n<li><a href=\"../contact/\"><img src=\"../img/top/banner01.png\" alt=\"ご相談・ご質問はお気軽にご連絡ください。24時間対応　092-941-3311\" /></a></li>\n<li><a href=\"../works.html#vehicle\"><img src=\"../img/top/banner02.jpg\" alt=\"車両設備\" /></a></li>\n<li><a href=\"../workflow.html\"><img src=\"../img/top/banner08.jpg\" alt=\"一日の流れ\" /></a></li>\n<li><a href=\"../recruit/\"><img src=\"../img/top/banner07.jpg\" alt=\"\" /></a></li>\n<li><a href=\"/recruit/voice.html\"><img src=\"../img/top/banner15.jpg\" alt=\"\" /></a></li>\n<li><a href=\"../nursery.html\"><img src=\"../img/top/banner03-2.jpg\" alt=\"事業所内保育所　大富保育園\" /></a></li>\n<li><a href=\"../welfare.html\"><img src=\"../img/top/banner09.jpg\" alt=\"福利厚生\" /></a></li>\n<li><a href=\"../sanatorium.html\"><img src=\"../img/top/banner04.jpg\" alt=\"福利厚生施設　湯布院　大富荘\" /></a></li>\n<li><a href=\"information.html#yuryo\"><img src=\"../img/top/banner06.png\" alt=\"優良申告法人\" /></a></li>\n</ul>\n</div><!-- 