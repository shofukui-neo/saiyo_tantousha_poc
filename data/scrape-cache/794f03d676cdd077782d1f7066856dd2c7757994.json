type=\"text\" name=\"kana\" maxlength=\"100\" class=\"contact-input is-size01 js-form-hiragana-check\">\n                    <div class=\"contact-err-view js-err-view\">\n                      \n                    </div>\n                  <!-- /contact-control --></div>\n                </td>\n              </tr>\n              <tr class=\"js-form-group\">\n                <th>\n                  <div class=\"contact-table-header\">\n                    <div class=\"contact-table-header__label js-form-label\">会社名または学校名・団体名</div>\n                  </div>\n                </th>\n                <td>\n                  <div class=\"contact-control\">\n                    <p class=\"contact-control__example\">例 : 石福金属興業株式会社</p>\n                    <input type=\"text\" name=\"company_name\" maxlength=\"100\" class=\"contact-input is-size01\">\n                    <div class=\"contact-err-view js-err-view\">\n                      \n                    </div>\n                  <!-- /contact-control --></div>\n                </td>\n              </tr>\n              <tr>\n                <th>\n                  <div class=\"contact-table-header\">\n                    <div class=\"contact-table-header__label js-form-label\">ご住所</div>\n                  </div>\n                </th>\n                <td>\n                  <div class=\"contact-control js-form-group\">\n                    <p class=\"contact-control__label\"><span class=\"js-form-label\">郵便番号</span></p>\n                    <p class=\"contact-control__example\">例 : 101-0047</p>\n                    <div class=\"contact-layout-row\">\n                      <div class=\"contact-layout__item contact-layout__item--input\">\n                        <input type=\"text\" name=\"post\" maxlength=\"8\" class=\"contact-input is-size01 js-form-postalcode-check js-form-search-address\">\n                      </div>\n                      <div class=\"contact-layout__item contact-layout__item--button\">\n         