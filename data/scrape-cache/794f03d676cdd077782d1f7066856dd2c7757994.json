/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n})(window,document,'script','dataLayer','GTM-MSTL8JM');</script>\n<!-- End Google Tag Manager -->\n</head>\n<body>\n<!-- Google Tag Manager (noscript) -->\r\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-MSTL8JM\"\r\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\r\n<!-- End Google Tag Manager (noscript) -->\n <header id=\"header\" class=\"Header--form\">\r\n  <div class=\"Header__inner\">\r\n    <div class=\"Header__head\">\r\n      <h1 class=\"header-logo\"><img src=\"/app-files/img/cmn_logo01.png\" alt=\"ISHIFUKU\" width=\"196\" height=\"27\"></h1>\r\n    </div>\r\n  </div>\r\n</header> \n<main id=\"main\" class=\"Main\">\n  <div class=\"Main__inner\">\n    <div class=\"Main__head\">\n      <div class=\"heading1\">\n        <div class=\"heading1__inner\">\n          <h1 class=\"heading1__title\">原材料調達ホットライン</h1>\n        </div>\n      </div>\n      <!--/Main__head-->\n    </div>\n    <div class=\"Main__body\">\n      <div class=\"Main__content\">\n        <div class=\"contact-chart\">\n          <div class=\"contact-chart-state--sp\"><img src=\"/contact/img/cmn_ic03_01.png\" alt=\"STEP1\"></div>\n          <ol class=\"contact-chart-list is-bg01\">\n            <li class=\"is-current\">\n              <dl class=\"contact-chart__step\"><dt>STEP1</dt><dd>内容のご入力</dd></dl>\n            </li>\n            <li>\n              <dl class=\"contact-chart__step\"><dt>STEP2</dt><dd>入力内容のご確認</dd></dl>\n            </li>\n            <li>\n              <dl class=\"contact-chart__step\"><dt>STEP3</dt><dd>送信完了</dd></dl>\n            </li>\n          </ol>\n        <!-- /contact-chart -->\n        <div class=\"list-wrap--right\">\n          <ul class=\"link-list\" data-col-pc=\"1\" data-col-sp=\"1\">\n            <li><a href=\"/english/contact/hotline/input\" class=\"link-list__type\">Inquiry Form</a></li>\n          </ul>\n        </div>\n        <p class=\"text\">当社「<a href=\"/sustainability/conflict-minerals/\" target=\"_blank\" rel=\"noopener\" class=\"util-link--blank\">原材料の調達についての方針</a>」に反する行為（内部通報含む）があった場合、以下のフォームより具体的な情報をご連絡ください。</p>\n        <div class=\"list-wrap\">\n          <dl class=\"description-list\">\n            <dt>留意事項</dt>\n            <dd>\n              <div class=\"list-wrap\">\n                <ul class=\"note-list-v2\" data-col-pc=\"1\" data-col-sp=\"1\">                \n                  <li><span class=\"note-list-v2__mark\">※</span>頂いた情報については遅滞なく内容を確認し、当社方針に反する行為と確認できた場合に調査を実施させて頂きます。</li>\n                  <li><span class=\"note-list-v2__mark\">※</span>事実を確認させていただくため、可能な限り詳細を記入欄にご記入ください。</li>\n                  <li><span class=\"note-list-v2__mark\">※</span>お送りいただいた情報は当社総務部、管理部にて取り扱い、必要に応じて関連部署と共有し対応いたします。</li>\n                  <li><span class=\"note-list-v2__mark\">※</span>通報者保護のため、お名前の記入は任意であり、必須ではございません。匿名でのお問い合わせおよびご通報が可能です。</li>\n                  <li><span class=\"note-list-v2__mark\">※</span>当社は、ご通報いただいた方やその組織に対し、ご通報自体を理由とする不利益な取り扱いはいたしません。ただし、不正な目的による通報の場合はこの限りではありません。</li>\n                  <li><span class=\"note-list-v2__mark\">※</span>調査の結果、当社による違法行為、不正行為などが明らかになった場合は是正処置及び再発防止措置を開始します。</li>\n                  <li><span class=\"note-list-v2__mark\">※</span>調査結果、是正処置、再発防止措置についてはご通報頂いた方に共有します。</li>\n                </ul>\n              </div>\n            </dd>\n          </dl>\n        </div>\n        <p class=\"contact-rule\"><span class=\"contact-icon-req is-inline\">必須</span>は必須項目です。必ずご記入ください。</p>\n        <form method=\"post\" accept-charset=\"utf-8\" novalidate=\"novalidate\" class=\"contact-form js-input-form\" action=\"/contact/hotline/input\"><div style=\"display:none;\"><input type=\"hidden\" name=\"_csrfToken\" autocomplete=\"off\" value=\"yca96dWnnPkV+MePXRDuuz45xvO4KoHc0tMiuS8CM8qcchfPL8WsR006vCIQ+1MydaHN+CvpK2lS+8CspMrF6A==\"></div>\n          <section class=\"contact-section\">\n            <div class=\"heading2\">\n              <div class=\"heading2__inner\">\n                <h2 class=\"heading2__title\">通報内容</h2>\n              </div>\n            </div>\n            <table class=\"contact-table\">\n              <colgroup>\n\n                <col style=\"width: 25%;\">\n                <col style=\"width: 75%;\">\n              </colgroup>\n              <tr class=\"js-form-group\">\n                <th>\n                  <div class=\"contact-table-header\">\n                    <div class=\"contact-table-header__label js-form-label\">対象となる行為者の氏名</div>\n                    <div class=\"contact-icon-req\">必須</div>\n                  </div>\n                </th>\n                <td>\n                  <div class=\"contact-control\">\n                    <p class=\"contact-control__example\">例 : 石福　太郎</p>\n                    <input type=\"text\" name=\"target_name\" maxlength=\"100\" class=\"contact-input is-size01 js-form-required-check\">\n                    <div class=\"contact-err-view js-err-view\">\n                      \n                    </div>\n                  <!-- /contact-control --></div>\n                </td>\n              </tr>\n              <tr class=\"js-form-group\">\n                <th>\n                  <div class=\"contact-table-header\">\n                    <div class=\"contact-table-header__label js-form-label\">行為者の所属会社・部署名</div>\n                    <div class=\"contact-icon-req\">必須</div>\n                  </div>\n                </th>\n                <td>\n                  <div class=\"contact-control\">\n                    <p class=\"contact-control__example\">例 : 石福金属興業株式会社</p>\n                    <input type=\"text\" name=\"target_company\" maxlength=\"100\" class=\"contact-input is-size01 js-form-required-check\">\n                    <div class=\"contact-err-view js-err-view\">\n                      \n                    </div>\n                  <!-- /contact-control --></div>\n                </td>\n              </tr>\n              <tr class=\"js-form-group\">\n                <th>\n                  <div class=\"contact-table-header\">\n                    <div class=\"contact-table-header__label js-form-label\">対象となる行為が行われた日時</div>\n                    <div class=\"contact-icon-req\">必須</div>\n                  </div>\n                </th>\n                <td>\n                  <div class=\"contact-control\">\n                    <p class=\"contact-control__example\">例 : 0000年00月00日</p>\n                    <input type=\"text\" name=\"target_date\" maxlength=\"100\" class=\"contact-input is-size01 js-form-required-check\">\n                    <div class=\"contact-err-view js-err-view\">\n                      \n                    </div>\n                  <!-- /contact-control --></div>\n                </td>\n              </tr>\n              <tr class=\"js-form-group\">\n                <th>\n                  <div class=\"contact-table-header\">\n                    <div class=\"contact-table-header__label js-form-label\">対象となる行為が行われた場所</div>\n                    <div class=\"contact-icon-req\">必須</div>\n                  </div>\n                </th>\n                <td>\n                  <div class=\"contact-control\">\n                    <p class=\"contact-control__example\">例 : 東京都千代田区内神田3-20-7　本社ビル</p>\n                    <input type=\"text\" name=\"target_place\" maxlength=\"100\" class=\"contact-input is-size01 js-form-required-check\">\n                    <div class=\"contact-err-view js-err-view\">\n                      \n                    </div>\n                  <!-- /contact-control --></div>\n                </td>\n              </tr>\n              <tr class=\"js-form-group\">\n                <th>\n                  <div class=\"contact-table-header\">\n                    <div class=\"contact-table-header__label js-form-label\">詳細</div>\n                    <div class=\"contact-icon-req\">必須</div>\n                  </div>\n                </th>\n                <td>\n                  <div cla