ry-3.6.0.min.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/simple-parallax-js@5.6.2/dist/simpleParallax.min.js\"></script>\n    <script src=\"/assets/js/common.js\"></script>\n    <script>\n  document.addEventListener(\"DOMContentLoaded\", function () {\n  const links = document.querySelectorAll(\".js-link\");\n\n  links.forEach(link => {\n    let tapped = false;\n\n    link.addEventListener(\"click\", function (e) {\n      // スマホだけ適用したい場合は window.innerWidth で判定\n      if (window.innerWidth <= 768) {\n        if (!tapped) {\n          e.preventDefault(); // 1回目はリンク飛ばない\n          link.classList.add(\"active\"); // hover風のアクション\n          tapped = true;\n\n          // 数秒後にリセット（任意）\n          setTimeout(() => {\n            tapped = false;\n            link.classList.remove(\"active\");\n          }, 1500);\n\n        } else {\n          // 2回目はそのままリンク遷移\n          tapped = false;\n        }\n      }\n    });\n  });\n});\n</script>\n  </div>\n\n</body>\n\n</html>\n\n","finalUrl":"http://www.r-ehm.co.jp/recruit/interview/","rendered":false,"_cachedAt":"2026-06-23T16:27:29.839Z"}