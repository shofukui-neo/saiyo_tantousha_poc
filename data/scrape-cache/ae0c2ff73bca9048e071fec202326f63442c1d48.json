{"url":"https://www.asahitatemonokanri.co.jp/recruit/","html":"<!doctype html>\n<html>\n<head prefix=\"og: http://ogp.me/ns# fb: http://ogp.me/ns/fb# article: http://ogp.me/ns/article#\">\n<meta charset=\"utf-8\">\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n<title>求人案内 | 朝日建物管理株式会社</title>\n<meta name=\"keywords\" content=\"朝日,管理,不動産,清掃,ビルメン,警備,設備,技術,総合管理,貸しビル,大阪,東京,名古屋,ビル管理,ビル設備\">\n<meta name=\"description\" content=\"朝日建物管理株式会社ウェブサイト\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<meta name=\"format-detection\" content=\"telephone=no\">\n<meta http-equiv=\"content-language\" content=\"ja\">\n\n<link rel=\"stylesheet\" href=\"/common/css/reset.css\">\n<link rel=\"stylesheet\" href=\"/common/css/print.css\" media=\"print\">\n<link rel=\"stylesheet\" href=\"/common/css/common.css\">\n<link rel=\"stylesheet\" href=\"/common/css/common_sp.css\">\n\n<link rel=\"stylesheet\" href=\"/recruit/css/recruit.css\">\n<link rel=\"stylesheet\" href=\"/recruit/css/recruit_sp.css\">\n<script src=\"/common/js/jquery.js\"></script>\n<script src=\"/common/js/jquery.easing.js\"></script>\n<script src=\"/common/js/common.js?ver=1\"></script>\n\n<script src=\"/recruit/js/recruit.js\"></script>\n<!-- Google Tag Manager -->\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n})(window,document,'script','dataLayer','GTM-KM9NWHL');</script>\n<!-- End Google Tag Manager -->\n<!-- Global site tag (gtag.js) - Google Analytics -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=UA-38894027-1\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n  gtag('config', 'UA-38894027-1');\n</script>\n\n</head>\n<body id=\"recruit\" class=\"idxPage\">\n<!-- Google Tag Manager (noscript) -->\r\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-KM9NWHL\"\r\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\r\n<!-- End Google Tag Manager (noscript) -->\r\n\n<div id=\"container\">\n  <p class=\"skip-link\"><a href=\"#contentsWrap\">メインコンテンツへ移動</a></p>\n<header id=\"siteHeader\">\n  <div id=\"headerWrap\" class=\"cf\">\n    <h1>\n      <a href=\"/\"><img src=\"/common/images/header_img_logo.gif\" alt=\"朝日建物管理株式会社\" /></a>\n    </h1>\n    <div id=\"gNaviSection\">\n      <nav aria-label=\"グローバルナビゲーション\">\n        <ul>\n          <li><a href=\"/\">ホーム</a></li>\n          <li><a href=\"/business/\">業務案内</a></li>\n          <li><a href=\"/recruit/\">求人案内</a></li>\n          <li><a href=\"/company/\">会社案内</a></li>\n          <li><a href=\"/inquiry/\">お問い合わせ</a></li>\n        </ul>\n      </nav>\n    </div>\n    <p id=\"spMenuBtn\">\n      <button type=\"button\" aria-label=\"メニューを開く\" aria-controls=\"gNaviSection\" aria-expanded=\"false\">\n        <img src=\"/common/images/header_btn_menu_open.gif\" alt=\"\" />\n      </button>\n    </p>\n  </div>\n</header>\n\n\n  <main>\n    <div id=\"mvWrap\">\n      <div id=\"mvSection\">\n        <h2>求人案内</h2>\n        <p class=\"txtMincho\">私たちが守るビルには、特別な思いがあります。<br>\n        一緒に働いてみませんか？</p>\n      </div>\n    </div>\n    <div id=\"breadCrumbWrap\">\n      <ul id=\"breadCrumbList\">\n        <li><a href=\"/\">ホーム</a></li>\n        <li>求人案内</li>\n      </ul>\n    </div>\n    <div id=\"contentsWrap\">\n      <div class=\"contentsSection\">\n        <ul class=\"ancLinkList\">\n          <li><a href=\"#recruit01Area\">新卒採用</a></li>\n          <li class=\"spRLine\"><a href=\"#recruit02Area\">中途、パート・アルバイト（西日本・関東）</a></li>\n          <!--\n          <li><a href=\"#recruitEtcSection\">中途、パート・アルバイト（九州・名古屋）</a></li>\n          -->\n        </ul>\n        <div id=\"recruit01Area\" class=\"contentsArea\">\n          <p><img src=\"/recruit/images/recruit_top_img_new_graduate.jpg\" alt=\"\"></p>\n          <div class=\"contentsInner\">\n            <h3>新卒採用</h3>\n            <p>総合職（ビルメンテナンス営業・不動産）、<br>技術職（設備管理）の募集です。<br>\n            求める人材は、当社の将来を一緒に担う仲間。<br>\n            やりがいのある仕事と充実した福利厚生が魅力。<br>\n            上司や先輩と話しやすい社風が自慢です！！</p>\n            <p class=\"spTxtCenter\"><a class=\"txtBtn02w btnEffect02\" href=\"https://job.mynavi.jp/27/pc/search/corp52897/outline.html\" target=\"_blank\">マイナビ</a></p>\n          </div>\n        </div>\n        <div id=\"recruit02Area\" class=\"contentsArea\">\n          <p><img src=\"/recruit/images/recruit_top_img_career.jpg\" alt=\"\"></p>\n          <div class=\"contentsInner\">\n            <h3>中途採用、パート・アルバイト募集</h3>\n            <dl class=\"type01List\">\n              <dt>■中途採用</dt>\n              <dd>ビルメンテナンスは現場がメーンの仕事。<br>\n              あなたの能力・経験をすぐに活かせます!!</dd>\n              <dt>■パート、アルバイト</dt>\n              <dd>パート、フルタイム勤務のアルバイトを募集しています。<br>\n              未経験者大歓迎!!<br>\n              親切丁寧に教えます。</dd>\n            </dl>\n            <ul class=\"col01List spTxtCenter\">\n              <li><a class=\"txtBtn02w btnEffect02\" href=\"https://job-gear.jp/tatekan/index.htm\" target=\"_blank\">西日本の方はこちら</a></li>\n              <li><a class=\"txtBtn02w btnEffect02\" href=\"https://arwrk.net/recruit/utdcmathj9k3bb4\" target=\"_blank\">関東の方はこちら</a></li>\n            </ul>\n          </div>\n        </div>\n      </div>\n      <!--\n      <div id=\"recruitEtcSection\" class=\"contentsSection\">\n        <div class=\"contentsArea\">\n          <h3>九州・名古屋でも募集しています!!</h3>\n          <div class=\"contentsInner\">\n            <p class=\"txtRight\">更新日：2019年10月1日</p>\n            <h4><span>九州</span><span>病院清掃スタッフ募集</span></h4>\n            <table class=\"type01Table bdTopNone\">\n              <tr>\n                <th>職種</th>\n                <td>病院清掃スタッフ</td>\n              </tr>\n              <tr>\n                <th>仕事内容</th>\n                <td>総合病院内の清掃、点検チェックetcをお願いします。<br>\n                外来フロア・病室の清掃です<br>\n                研修もありますので、未経験の方でも安心して働けます。<br>\n                綺麗な総合病院内での清掃<br>\n                環境衛生を通じて医療を支えられるお仕事をしてみませんか？</td>\n              </tr>\n              <tr>\n                <th>給与</th>\n                <td>時給845円+交通費支給</td>\n              </tr>\n              <tr>\n                <th>勤務地</th>\n                <td>北九州市小倉北区浅野（小倉駅北口より徒歩5分）</td>\n              </tr>\n              <tr>\n                <th>勤務時間</th>\n                <td>\n                  <ul class=\"atComment\">\n                    <li>①7：00～12：00</li>\n                    <li>②7：00～16：00</li>\n                    <li>③7：30～12：30</li>\n                    <li>④7：30～16：30</li>\n                  </ul>\n                </td>\n              </tr>\n              <tr>\n                <th>応募資格</th>\n                <td>未経験者大歓迎</td>\n              </tr>\n              <tr>\n                <th>待遇</th>\n                <td>\n                <dl class=\"type01List mt0\">\n                  <dt>■待遇</dt>\n                  <dd>\n                    <ul class=\"txtPlaneList mt0\">\n                      <li>制服貸与・賞与あり・有給休暇有</li>\n                      <li>継続勤務で報奨金あり（入社半年後、1年後に5,000円ずつ支給）</li>\n                      <li>交通費規定支給　・正社員登用制度あり</li>\n                      <li>①、③　雇用保険有/②、④　社会保険完備</li>\n                    </ul>\n                  </dd>\n                  <dt>■休日</dt>\n                  <dd>\n                    <ul class=\"txtPlaneList mt0\">\n                      <li>①、③　４週６休　②、④　週休２日</li>\n                    </ul>\n                  </dd>\n                </dl>\n                </td>\n              </tr>\n              <tr>\n                <th>応募方法</th>\n                <td>お電話でのご応募をお待ちしております。<br>\n                面接日時を調整させて頂きます。<br>\n                （応募受付電話番号093-512-1730／採用担当）</td>\n              </tr>\n            </table>\n          </div>\n\t\t\t\t\t\n          <div class=\"contentsInner\">\n            <p class=\"txtRight\">更新日：2019年10月1日</p>\n            <h4><span>名古屋</span><span>清掃スタッフ募集!（名古屋（伏見））充実と安心の環境で始めてみませんか？</span></h4>\n\t\t\t\t\t\t <p class=\"txtCenter mt25\"><img src=\"/recruit/images/nagoya01.jpg\" alt=\"\"></p>\n            <table class=\"type01Table mt30\">\n              <tr>\n                <th>職種</th>\n                <td>清掃スタッフ（フルタイム、パートタイム）同時募集<br>\n                ①フルタイム（7時間）<br>\n                ②パートタイム（3時間）</td>\n              </tr>\n              <tr>\n                <th>仕事内容</th>\n                <td>ビル内のテナントフロアや共用部（トイレや通路）などの簡単な清掃業務。<br>\n\t\t\t\t\t\t\t\t\t2人チームまたは1人作業なので自分のペースで働けます。<br>\n\t\t\t\t\t\t\t\t\tご本人に無理のないよう業務分担やマニュアルや業務チェック表などを使うので未経験の方も安心して活躍できるようにしています。\n\t\t\t\t\t\t\t\t</td>\n              </tr>\n              <tr>\n                <th>給与</th>\n                <td>①②ともに　930円以上</td>\n              </tr>\n              <tr>\n                <th>勤務地</th>\n                <td>名古屋市中区栄1-3-3　朝日会館（朝日新聞名古屋本社他）<br>\n\t\t\t\t\t\t\t\t最寄駅：地下鉄東山線・鶴舞線　伏見駅から徒歩5分\n\t\t\t\t\t\t\t\t</td>\n              </tr>\n              <tr>\n                <th>勤務時間</th>\n                <td>\n                  <ul class=\"atComment\">\n                    <li>①6：30～14：30</li>\n                    <li>②6：30～9：30</li>\n                  </ul>\n                  <p>土日出勤できる方歓迎。勤務日数や勤務曜日など相談できます。 <br>\n\t\t\t\t\t\t\t\t\t\tまずはお気軽にお問合せ下さい（メールでのお問い合わせ歓迎です）</p>\n                </td>\n              </tr>\n              <tr>\n                <th>応募資格</th>\n                <td>学歴、年齢、資格一切不問、未経験大歓迎、定年退職された方歓迎、Wワーク歓迎です。</td>\n              </tr>\n              <tr>\n                <th>待遇</th>\n                <td>\n                    <ul class=\"txtPlaneList mt0\">\n                      <li>全額支給、保養所有、勤続奨励金有</li>\n                      <li>健康診断年1回(会社負担)</li>\n                      <li>社員食堂（展望レストラン）利用できます</li>\n                      <li>プチボーナスあり（入社半年後、1年後に5,000円ずつ支給）</li>\n\t\t\t\t\t\t\t\t\t\t\t<li>社員昇格制度あり</li>\n                    </ul>\n                    <p>&lt;20代～60代のスタッフ活躍中！&gt;<br>\n                    定期健康診断やご本人に合わせた無理のない作業分担により、<br>より長く活躍してもらえる環境作りに力を入れており安心して働くことができます。</p>\n                    <p>&lt;研修充実で、未経験でも安心です&gt;<br>\n                    入社時の導入研修、実技研修、現場責任者によるフォロー体制等、未経験からでも安心です。</p>\n                    <p>いつも笑顔の絶えない職場です。充実と安心の職場で、清掃の仕事を始めてみませんか？</p>\n                </td>\n              </tr>\n              <tr>\n                <th>応募方法</th>\n                <td>\n                  <p>まずはお気軽にお電話、メールにてお問い合わせください。</p>\n                  <ul>\n                    <li>※面接予約の電話後、履歴書をご持参ください（写真は入社時でもOKです）</li>\n                    <li>※応募書類の返却は致しません。</li>\n                  </ul>\n                  <p>（電話）052-221-8030<br>\n                  （携帯電話）080-2458-9987<br>\n                  （e-mail) okubo@asahitatemonokanri.com</p>\n                  <p>担当：名古屋支店　大久保まで</p>\n                </td>\n              </tr>\n            </table>\n          </div>\n\t\t\t\t\t\n\t\t\t\t\t<div class=\"contentsInner\">\n            <p class=\"txtRight\">更新日：2019年10月1日</p>\n            <h4><span>名古屋</span><span>急募!　清掃スタッフ　☆西春営業所（北名古屋市）</span></h4>\n\t\t\t\t\t\t<p class=\"txtCenter mt25\"><img src=\"/recruit/images/nagoya02.jpg\" alt=\"\"></p>\n            <table class=\"type01Table mt30\">\n              <tr>\n                <th>職種</th>\n                <td>清掃スタッフ<br>\n                ①フルタイム（7時間）<br>\n                ②パートタイム（3.5時間／2時間）</td>\n              </tr>\n              <tr>\n                <th>仕事内容</th>\n                <td>☆朝日新聞グループ工場内の簡単な清掃業務☆<br>\n\t\t\t\t\t\t\t\t\t2人チームか1人での作業なので自分のペースで働けます。<br>\n\t\t\t\t\t\t\t\t\t体力的にきつい仕事もありませんのでご安心下さい。<br>\n\t\t\t\t\t\t\t\t\t<br>\n\t\t\t\t\t\t\t\t\t&lt;研修もしっかりやります&gt;<br>\n\t\t\t\t\t\t\t\t\t入社時の導入研修、実技研修、現場責任者によるフォロー体制等、未経験からでも安心して始められる体制です。\n\t\t\t\t\t\t\t\t</td>\n              </tr>\n              <tr>\n                <th>給与</th>\n                <td>時給930円以上</td>\n              </tr>\n              <tr>\n                <th>勤務地</th>\n                <td>愛知県北名古屋市中之郷池田6-1　朝日プリンテック（朝日新聞名古屋工場）内<br>\n\t\t\t\t\t\t\t\t\t最寄駅：名鉄西春駅から車10分、JR稲沢駅・清洲駅から車で10分\n\n\t\t\t\t\t\t\t\t</td>\n              </tr>\n              <tr>\n                <th>勤務時間</th>\n                <td>\n                  <ul class=\"atComment\">\n                    <li>①7：30～15：30</li>\n                    <li>②7：30～11：00</li>\n\t\t\t\t\t\t\t\t\t\t<li>③10：00～12：00</li>\n                  </ul>\n                  <p>土日出勤できる方歓迎。勤務日数や勤務曜日など相談できます。<br>\n\t\t\t\t\t\t\t\t\t\tまずはお気軽にお問合せ下さい（メールでのお問い合わせ歓迎です）</p>\n                </td>\n              </tr>\n              <tr>\n                <th>応募資格</th>\n                <td>学歴、年齢、資格一切不問、未経験大歓迎、定年退職された方歓迎</td>\n              </tr>\n              <tr>\n                <th>待遇</th>\n                <td>\n                    <ul class=\"txtPlaneList mt0\">\n                      <li>交通費規定支給、車通勤可（バイク通勤は不可）</li>\n                      <li>労災保険、有給休暇（半年勤務後　12日間付与）</li>\n                      <li>健康診断年1回(会社負担)</li>\n                      <li>プチボーナスあり（入社半年後、1年後に5,000円づつ支給）</li>\n\t\t\t\t\t\t\t\t\t\t\t<li>社員昇格制度あり</li>\n                    </ul>\n                    <p>&lt;中高年主婦の方が活躍中&gt;<br>\n                    定期健康診断やご本人に合わせた無理のない業務分担により、長く活躍してもらえる環境作りに力を入れています</p>\n                    <p>&lt;研修充実で、未経験でも安心です&gt;<br>\n                    入社時の導入研修、実技研修、現場責任者によるフォロー体制等、未経験からでも安心です。</p>\n                    <p>いつも笑顔の絶えない職場です。充実と安心の職場で、清掃の仕事を始めてみませんか？</p>\n                </td>\n              </tr>\n              <tr>\n                <th>応募方法</th>\n                <td>\n                  <p>まずはお気軽にお電話、メールにてお問い合わせください。</p>\n                  <ul>\n                    <li>※面接予約の電話後、履歴書をご持参ください（写真は入社時でOKです）</li>\n                    <li>※応募書類の返却は致しません。</li>\n                  </ul>\n                  <p>（電話）0568-22-0360<br>\n                  （携帯電話）080-8469-2180<br>\n\t\t\t\t\t\t\t\t\t\t※応募受付／平日：9:00～17:00<br>\n                  （e-mail)j.aoki@asahitatemonokanri.com</p>\n                  <p>担当：西春営業所　青木まで</p>\n                </td>\n              </tr>\n            </table>\n          </div>\n       </div>\n      </div>\n      -->\n    </div>\n  </main>\n\n    <footer>\n    <div id=\"footerWrap\">\n      <p id=\"pageTopBtn\"><a href=\"#container\"><img src=\"/common/images/footer_btn_pagetop.gif\" alt=\"ページトップ\"></a></p>\n      <div id=\"footerTopSection\" class=\"cf\">\n        <ul>\n          <li><a href=\"/privacy/\">プライバシーポリシー</a></li>\n          <li><a href=\"/sitemap/\">サイトマップ</a></li>\n        </ul>\n      </div>\n      <div id=\"footerBottomSection\" class=\"cf\">\n        <p>Copyright(C) 2004-2026 朝日建物管理株式会社</p>\n      </div>\n    </div>\n  </footer>\n\n</div>\n\n</body>\n</html>\n","finalUrl":"https://www.asahitatemonokanri.co.jp/recruit/","rendered":false,"_cachedAt":"2026-06-22T22:15:29.254Z"}