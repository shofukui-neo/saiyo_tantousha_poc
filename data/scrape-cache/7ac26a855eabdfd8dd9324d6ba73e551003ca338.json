                  <!-- /.interview_box -->\n                </div>\n                <div class=\"interview_box\">\n                  <a href=\"interview/interview11/\">\n                    <figure>\n                      <img src=\"interview/img/interview_pic11.jpg\"\n                        srcset=\"interview/img/interview_pic11.jpg 1x, interview/img/interview_pic11@2x.jpg 2x\" alt=\"\" />\n                      <figcaption>\n                        <div class=\"txtarea\">\n                          <strong class=\"belong\">金型事業本部 浜松営業所</strong> <span class=\"year hidden-xs\">2016年入社</span>\n                          <strong class=\"ttl\">渡邊 亮<span class=\"en hidden-xs\">Ryo Watanabe</span></strong>\n                        </div>\n                      </figcaption>\n                    </figure>\n                  </a>\n                  <!-- /.interview_box -->\n                </div>\n                <div class=\"interview_box\">\n                  <a href=\"interview/interview02/\">\n                    <figure>\n                      <img src=\"interview/img/interview_pic02.jpg\"\n                        srcset=\"interview/img/interview_pic02.jpg 1x, interview/img/interview_pic02@2x.jpg 2x\" alt=\"\" />\n                      <figcaption>\n                        <div class=\"txtarea\">\n                          <strong class=\"belong\">金型事業本部 熊谷営業所</strong> <span class=\"year hidden-xs\">2017年入社</span>\n                          <strong class=\"ttl\">石井 隆史<span class=\"en hidden-xs\">Takashi Ishii</span></strong>\n                        </div>\n                      </figcaption>\n                    </figure>\n                  </a>\n                  <!-- /.interview_box -->\n                </div>\n                <div class=\"interview_box\">\n                  <a href=\"interview/interview05/\">\n                    <figure>\n                      <img src=\"interview/img/interview_pic05.jpg\"\n                        srcset=\"interview/img/interview