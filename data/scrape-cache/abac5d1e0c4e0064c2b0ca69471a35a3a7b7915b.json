s/asupia/common/js/config.js\"></script>\n<script src=\"https://asupia.co.jp/cms/wp-content/themes/asupia/common/js/jquery.easing.1.3.js\"></script>\n<script src=\"https://asupia.co.jp/cms/wp-content/themes/asupia/common/js/animation.gsap.min.js\"></script>\n<script src=\"https://asupia.co.jp/cms/wp-content/themes/asupia/common/js/TweenMax.min.js\"></script>\n<!-- Instagram Feed JS -->\r\n<script type=\"text/javascript\">\r\nvar sbiajaxurl = \"https://asupia.co.jp/cms/wp-admin/admin-ajax.php\";\r\n</script>\r\n    <script>\n    document.addEventListener('DOMContentLoaded', function() {\n        console.log('DOM loaded, initializing debug...');\n        \n        // フォーム送信のデバッグ\n        const form = document.querySelector('.wpcf7-form');\n        const submitBtn = document.querySelector('.wpcf7-form input[type=\"submit\"]');\n        \n        if (form) {\n            console.log('Contact Form 7 found:', form);\n            console.log('Submit button found:', submitBtn);\n            \n            // 送信ボタンのクリックイベント（複数の方法で検知）\n            if (submitBtn) {\n                // click イベント\n                submitBtn.addEventListener('click', function(e) {\n                    console.log('=== SUBMIT BUTTON CLICKED ===');\n                    console.log('Event target:', e.target);\n                    console.log('Button disabled?', submitBtn.disabled);\n                    console.log('Form action:', form.action);\n                    console.log('Default prevented?', e.defaultPrevented);\n                    \n                    // Turnstileトークンの確認\n                    const turnstileResponse = form.querySelector('[name=\"cf-turnstile-response\"]');\n                    if (turnstileResponse) {\n                        console.log('Turnstile token exists:', !!turnstileResponse.value);\n                        if (turnstileResponse.value) {\n                            console.log('Token length:', turnstileResponse.value.length);\n                        }\n                    } else {\n                        console.log('ERROR: Turnstile response field not found!');\n                    }\n                });\n                \n                // mousedown イベント\n                submitBtn.addEventListener('mousedown', function(e) {\n                    console.log('Submit button mousedown detected');\n                });\n                \n                // pointerdown イベント\n                submitBtn.addEventListener('pointerdown', function(e) {\n                    console.log('Submit button pointerdown detected');\n                });\n            }\n            \n            // フォーム送信イベント（複数の方法でキャッチ）\n            form.addEventListener('submit', function(e) {\n                console.log('Form submit event triggered!');\n                console.log('Event prevented?', e.defaultPrevented);\n                \n                // 全フィールドの確認\n                const formData = new FormData(form);\n                console.log('Form data entries:');\n                for (let [key, value] of formData.entries()) {\n                    if (key === 'cf-turnstile-response') {\n                        console.log(key + ': [TOKEN PRESENT]');\n                    } else {\n                        console.log(key + ': ' + value);\n                    }\n                }\n            });\n            \n            // Contact Form 7の全イベント\n            form.addEventListener('wpcf7submit', function(e) {\n                console.log('wpcf7submit event:', e.detail);\n            });\n            \n            form.addEventListener('wpcf7invalid', function(e) {\n                console.log('wpcf7invalid event:', e.detail);\n            });\n            \n            form.addEventListener('wpcf7spam', function(e) {\n                console.log('wpcf7spam event:', e.detail);\n            });\n            \n            form.addEventListener('wpcf7mailsent', function(e) {\n                console.log('wpcf7mailsent event:', e.detail);\n            });\n            \n            form.addEventListener('wpcf7mailfailed', function(e) {\n                console.log('wpcf7mailfailed event:', e.detail);\n            });\n            \n        } else {\n            console.log('ERROR: Contact Form 7 not found!');\n        }\n        \n        // すべての送信ボタンをチェック\n        const allSubmits = document.querySelectorAll('input[type=\"submit\"], button[type=\"submit\"]');\n        console.log('All submit buttons found:', allSubmits.length);\n        allSubmits.forEach((btn, i) => {\n            console.log(`Submit button ${i}:`, btn);\n            btn.addEventListener('click', function(e) {\n                console.log(`Submit button ${i} clicked!`);\n            });\n        });\n        \n        // Turnstile初期化関数\n        function initializeTurnstile() {\n            if (typeof turnstile !== 'undefined') {\n                const turnstileElements = document.querySelectorAll('.cf-turnstile');\n                console.log('Turnstile elements found:', turnstileElements.length);\n                \n                turnstileElements.forEach(function(element, index) {\n                    // 既にiframeが存在する場合はスキップ\n                    if (element.querySelector('iframe')) {\n                        console.log(`Turnstile ${index} already has iframe`);\n                        return;\n                    }\n                    \n                    try {\n                        // Turnstileウィジェットをレンダリング\n                        const widgetId = turnstile.render(element, {\n                            sitekey: element.getAttribute('data-sitekey') || '',\n                            callback: function(token) {\n                                console.log('Turnstile verified:', token.substring(0, 50) + '...');\n                            },\n                            'error-callback': function(error) {\n                                console.warn('Turnstile error:', error);\n                            },\n                            'expired-callback': function() {\n                                console.warn('Turnstile expired, refreshing...');\n                                turnstile.reset(widgetId);\n                            }\n                        });\n                        \n                        console.log('Turnstile initialized for element', index);\n                        \n                    } catch (error) {\n                        console.warn('Turnstile render failed:', error);\n                    }\n                });\n            } else {\n                console.warn('Turnstile API not loaded');\n            }\n        }\n        \n        // 初期化実行\n        initializeTurnstile();\n        \n        // Contact Form 7のフォーム再読み込み時にも対応\n        document.addEventListener('wpcf7mailsent', function() {\n            setTimeout(initializeTurnstile, 1000);\n        });\n        \n        document.addEventListener('wpcf7invalid', function() {\n            setTimeout(initializeTurnstile, 500);\n        });\n        \n        document.addEventListener('wpcf7spam', function() {\n            setTimeout(initializeTurnstile, 500);\n        });\n        \n    });\n    \n    // Cloudflare Turnstile API読み込み完了時の処理\n    window.onCloudflareLoad = function() {\n        console.log('Cloudflare Turnstile API loaded');\n    };\n    </script>\n    <script type='text/javascript' src='https://asupia.co.jp/cms/wp-includes/js/imagesloaded.min.js?ver=4.1.4' id='imagesloaded-js'></script>\n<script type='text/javascript' src='https://asupia.co.jp/cms/wp-includes/js/masonry.min.js?ver=4.2.2' id='masonry-js'></script>\n<script type='text/javascript' src='https://asupia.co.jp/cms/wp-includes/js/jquery/jquery.masonry.min.js?ver=3.1.2b' id='jquery-masonry-js'></script>\n<script type='text/javascript' id='wpcf7cf-scripts-js-extra'>\n/* <![CDATA[ */\nvar wpcf7cf_global_settings = {\"ajaxurl\":\"https:\\/\\/asupia.co.jp\\/cms\\/wp-admin\\/admin-ajax.php\"};\n/* ]]> */\n</script>\n<script type='text/javascr