{"url":"https://www.sanyodenken.co.jp","html":"<!DOCTYPE html PUBLIC \"-//W3C//DTD XHTML 1.0 Transitional//EN\" \"http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd\">\n<html xmlns=\"http://www.w3.org/1999/xhtml\">\n\n<head>\n<meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\" />\n<meta name=\"description\" content=\"私たちは、お客様に「山陽電研に仕事をしてもらってよかった。」と言われる信頼される企業を目指します。\"/>\n<meta name=\"keywords\" content=\"山陽電研,受配電盤,マンホールポンプ制御盤,ポンプ制御盤,コンテナークレーン制御装置,半導体生産検査設備,舶用ディーゼルエンジン遠隔操縦装置,環境向け製品，融雪器\" />\n<meta name=\"viewport\" content=\"width=1012\">\n<meta http-equiv=\"Content-Style-Type\" content=\"text/css\" />\n<meta name=\"GENERATOR\" content=\"JustSystems Homepage Builder Version 17.0.1.0 for Windows\" />\n<link rel=\"stylesheet\" href=\"common/css/import.css\" />\n<link rel=\"stylesheet\" href=\"common/css/top.css\" />\n<title>山陽電研株式会社　オフィシャルサイト</title>\n\n  <link rel=\"stylesheet\" type=\"text/css\" href=\"slick/slick.css\"/>\n    <script type=\"text/javascript\" src=\"slick/slick.min.js\"></script>\n\t<script type=\"text/javascript\" src=\"common/js/jquery-1.11.0.min.js\"></script>\n<script type=\"text/javascript\" src=\"slick/slick.js\"></script>\n\n<!-- Global site tag (gtag.js) - Google Analytics -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-1HGTENGETE\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'G-1HGTENGETE');\n</script>   \n</head>\n\n<body>\n\n\n<!--ヘッダー-->\n<div id=\"wrapper01\">\n<div class=\"headder\">\n<img src=\"top_img/logo.png\" width=\"253\" height=\"57\" alt=\"山陽電研ロゴマーク\" /></div>\n<div class=\"srider\">\n\n    <!-- カルーセル -->\n    <div class=\"single-item\">\n      <div> <img src=\"top_img/slide_72.png\" width=\"980\" alt=\"世界に1つだけを創り続けて72年\" /></div>\n      <div><a href=\"aboutus/index.html\"><img src=\"top_img/slide2.jpg\" width=\"100%\" alt=\"会社紹介\" /></a></div>\n      <div><a href=\"recruit/senior/index.html\" target=\"_blank\"><img src=\"top_img/slide3.jpg\" width=\"100%\" alt=\"社員紹介\" /></a></div>\n\t  <div><a href=\"products/index.html\"><img src=\"top_img/slide4.jpg\" width=\"100%\" alt=\"事業紹介\" /></a></div>\n\t  <div><a href=\"corpdata/index.html#map\"><img src=\"top_img/slide5.jpg\" width=\"100%\" alt=\"メカトロニクスセンター稼働\" /></a></div>\n    </div>\n    <script>\n      $(document).ready(function(){\n        $('.single-item').slick();\n      });\n    </script>\n      <!-- end カルーセル -->\n      </div>\n</div>\n<!-- end wrapper01 -->\n      \n\n\n<!--メニューボタン-->\n<div id=\"navi01_bg\">\n<div id=\"navi01\">\n\n <ul>\n  <li id=\"denryoku\"><a href=\"products/index.html\">電力向け製品</a></li>\n    <li id=\"sangyo\"><a href=\"products/industrial.html\">産業向け製品</a></li>\n    <li id=\"kankyo\"><a href=\"products/environment.html\">環境向け製品</a></li>\n    <li id=\"mecha\"><a href=\"products/mechatronics.html\">メカトロ製品</a></li>  \n</ul>\n    <div class=\"clear\">\n      <hr />\n    </div>\n</div>\n</div>\n\n<div id=\"navi02_bg\">\n<div class=\"navi02\">\n<nav class=\"naver\">\n  <a href=\"index.html\">HOME</a>\n  <a href=\"aboutus/index.html\">山陽電研について</a>\n  <a href=\"corpdata/index.html\">会社概要</a>\n  <a href=\"products/index.html\">事業紹介</a>\n  <a href=\"recruit/index.html\" target=\"_blank\" class=\"img\">\n  <img src=\"common/gmenu_recruitdate.gif\" width=\"187\" height=\"48\" alt=\"採用情報\" /></a>\n</nav>\n\n    <div class=\"clear\">\n      <hr />\n    </div>\n</div>\n</div>\n<!-- end メニューボタン -->\n\n<!--コンテンツ-->\n<div id=\"wrapper02\">\n<div class=\"contents\">\n<div class=\"contents__\">\n<a href=\"recruit/video/tv_cm_2025_01.html\" target=\"_blank\"><img src=\"common/cm_202412new.png\" width=\"220\" height=\"112\" alt=\"\"/></a>\n　<a href=\"recruit/video/tv_cm_2024_12.html\" target=\"_blank\"><img src=\"common/cm_202412old.png\" width=\"220\" height=\"112\" alt=\"\"/></a>\n　 <a href=\"https://www.sanyodenken.biz/\" target=\"_blank\"><img src=\"top_img/site_bnr.gif\" alt=\"\" width=\"500\" height=\"112\" border=\"0\"/></a>\n<br>\n<!---\t<div class=\"t_c\"> <h2><a href=\"top_img/202201.pdf\" target=\"_blank\">新型コロナウイルスに関するお知らせ</a></h2></div> --->\n\n\n<p><img src=\"top_img/title01.gif\" width=\"196\" height=\"69\" alt=\"山陽電研の特長\" /></p>\n\n<div class=\"menu_a\"><p class=\"p01\">設計から板金・塗装、組立まで全てを自社で行うことで、あらゆるニーズに対応します。同時に、隅々まで行き届いた品質管理を実現しご期待に応える製品を提供します。</p>\n  <h3><a href=\"products/strongpoint.html#point01\"><img class=\"topmargin_10\" src=\"top_img/kuwashiku.png\" width=\"99\" height=\"25\" alt=\"詳しくはこちら\" /></a></h3>\n</div>\n  \n  \n<div class=\"menu_b\"><p class=\"p01\">1948年の創業より工場・生産設備、大規模プラントなど地域発展の中核となる製品の提供に数多く携わってきました。重ねてきた実績はそのまま当社の技術力に繋がっております。</p>\n  <h3><a href=\"products/strongpoint.html#point02\"><img class=\"topmargin_10\" src=\"top_img/kuwashiku.png\" width=\"99\" height=\"25\" alt=\"詳しくはこちら\" /></a></h3>\n</div>\n  \n  \n<div class=\"menu_c\"><p class=\"p01\">技術、知識、ノウハウを若手技術者へ引き継ぐことはもちろん、創業者のモノづくりへの情熱も同時に伝え続けています。<br />60余年変わらない社訓がその証です。</p>\n  <a href=\"products/strongpoint.html#point03\"><img class=\"topmargin_10\" src=\"top_img/kuwashiku.png\" width=\"99\" height=\"25\" alt=\"詳しくはこちら\" /></a></div>\n\n    <div class=\"clear\">\n      <hr />\n    </div>\n</div>\n</div>\n\n</div>\n\n<!-- end wrapper02 -->\n<!--フッター-->\n<div id=\"wrapper03\">\n<div id=\"footer\">\n\n<div class=\"menu\">\n     <strong> 製品のご紹介</strong>\n  <ul>\n \n    <li><a href=\"products/index.html\">電力向け製品</a></li>\n    <li><a href=\"products/industrial.html\">産業向け製品</a></li>\n    <li><a href=\"products/environment.html\">環境向け製品 </a></li>\n    <li><a href=\"products/mechatronics.html\">メカトロ製品 </a></li>\n    <li><a href=\"products/strongpoint.html\">山陽電研の特長\n    </a></li>\n  </ul>\n</div>\n  \n  \n<div class=\"menu\">\n<strong>会社のご紹介</strong>\n  <ul>\n    <li><a href=\"aboutus/index.html\">ごあいさつ</a><br />\n      </li>\n    <li><a href=\"aboutus/index.html#story\">社訓の由来</a><br />\n      </li>\n    <li><a href=\"corpdata/index.html\">会社概要</a><br />\n      </li>\n    <li><a href=\"corpdata/index.html#history\">沿革</a><br />\n      </li>\n    <li><a href=\"corpdata/index.html#organization\">組織図</a><br />\n      </li>\n    <li><a href=\"corpdata/index.html#map\">アクセス・地図</a></li>\n      </li>\n    <li><a href=\"privacy-policy/index.html\">プライバシーポリシー</a></li>\n  </ul>\n</div>\n  \n  \n<div class=\"menu\">\n<strong>お問い合わせ</strong><img src=\"common/footer_mail.gif\" width=\"20\" height=\"13\" /><br />\n<a href=\"mailto:soumuka@sanyodenken.co.jp\">【採用窓口】soumuka@sanyodenken.co.jp</a><br />\n<a href=\"mailto:sales@sanyodenken.co.jp\">【営業窓口】sales@sanyodenken.co.jp</a><br />\n<a href=\"recruit/index.html\"><img src=\"common/link_saiyo.jpg\" width=\"171\" height=\"62\" /></a><br /><br />\n<a href=\"recruit/entrydata/index.html\"><img src=\"common/link_saiyo_cyuto.png\" width=\"170\" height=\"61\" alt=\"中途採用・パート採用はこちらへ\" /></a></div>\n  \n  \n  \n<div class=\"fprofile\">\n \n<img src=\"common/footer_com.gif\" width=\"314\" height=\"99\" /><br />\n本社・工場　<br />\n岡山県岡山市中区乙多見449　〒703-8228<br />\nTEL086-279-0591 FAX086-279-4560<hr />\n<img src=\"common/iso.jpg\" width=\"106\" align=\"left\" hspace=\"5\" />ISO9001　認証取得　2001年8月   <br />\nISO14001 認証取得　2003年6月\n    <div class=\"clear\">\n      <hr />\n    </div>\n    </div>\n  \n    <div class=\"clear\">\n      <hr />\n    </div>\n</div>\n</div></body>\n</html>\n","finalUrl":"https://www.sanyodenken.co.jp/","rendered":false,"_cachedAt":"2026-06-14T18:51:37.589Z"}