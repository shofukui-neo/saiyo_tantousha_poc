ax-width: 640px)\" href=\"https://www.tohogas.co.jp/nw/designing-company-recruit/sp/honshikan/\" />\n<!-- inc_GTM_head -->\n<!-- inc_GTM_head -->\n</head>\n<body>\n<!-- Google Tag Manager (noscript)  --> \n<!-- End Google Tag Manager (noscript) --> \n\n<!-- header --> \n<script src=\"https://ajax.googleapis.com/ajax/libs/jquery/2.1.4/jquery.min.js\"></script> \n<script>\nfunction init() {\n    var px_change   = 0;\n    window.addEventListener('scroll', function(e){\n        if ( $(window).scrollTop() > px_change ) {\n            $(\"header\").addClass(\"smaller\");\n        } else if ( $(\"header\").hasClass(\"smaller\") ) {\n            $(\"header\").removeClass(\"smaller\");\n        }\n    });\n}\nwindow.onload = init();\n</script> \n<!-- header --> \n\n<!-- fade --> \n<script>\n$(function(){\n    $(window).scroll(function (){\n        $('.parallaxin,.doukan p, .constructiontop,.cooperationmore,.more,.cooperationmore02,.honshikannaikan02,.title01,.title02').each(function(){\n            var elemPos = $(this).offset().top;\n            var scroll = $(window).scrollTop();\n            var windowHeight = $(window).height();\n            if (scroll > elemPos - windowHeight + 200){\n                $(this).addClass('scrollin');\n            }\n        });\n    });\n});\n</script> \n<!-- fade --> \n\n<!-- slide --> \n<script type=\"text/javascript\">\nwindow.addEventListener('DOMContentLoaded', function() {\n  var swiper03 = new Swiper('.topinterviewin .swiper-container', {\n    pagination: '.swiper-pagination',\n    paginationClickable: true,\n    nextButton: '.swiper-button-next',\n    prevButton: '.swiper-button-prev',\n    loop: true,\n    slidesPerView: 3,\n    loopedSlides: 9,\n\t      loopFillGroupWithBlank: true,\n    centeredSlides: true,\n    slideToClickedSlide: true,\n    spaceBetween: 170,\n\tspeed: 600,\n\teffect: 'slide',\n    direction: 'horizontal',\n\tautoplay: 8000,\n\tsimulateTouch: true,\n\tautoplayDisableOnInteraction:false,\n\n\n\n   // レスポンシブ化条件f\n    breakpoints: {\n\t\t      // 1365ピクセル幅以下になったら\n      1365: {\n        slidesPerView: 3,\n        spaceBetween:120\n      },\n    },\n  });\n}, false);\n</script> \n<!-- slide -->\n\n<div id=\"wrapper\"> \n  \n  <!-- header -->\n  <div id=\"l-document\"></div>\n  <div id=\"header\" class=\"pc_box\">\n  <div class=\"inner\">\n    <div id=\"sitelogo\"><a href=\"/index.html\" class=\"rollover\"><img src=\"../img/logo.gif\" width=\"172\" height=\"38\" alt=\"東邦ガスネットワーク\" /></a></div>\n  </div>\n  \n  <!-- nav -->\n  <header>\n    <nav id=\"nav\">\n      <ul>\n        <li><a href=\"../index.html\">TOP</a></li>\n        <li><a href=\"../honshikan/index.html\">本支管工事</a></li>\n        <li><a href=\"../naikan/index.html\">内管工事</a></li>\n        <li><a href=\"../interview/index.html\">インタビュー</a></li>\n        <li><a href=\"../support/index.html\">研修サポート</a></li>\n        <li><a href=\"../kyujin/index.html\">求人工事会社一覧</a></li>\n        <li><a href=\"../faq/index.html\">よくある質問</a></li>\n      </ul>\n    </nav>\n    </div>\n    <!-- //nav --> \n    \n  </header>\n  <!-- //header --> \n  \n  <!-- parallax -->\n  <div id=\"sec01\">\n    <div class=\"parallax02\"> <img src=\"../img/honshikan_title.png\" alt=\"本支管工事\"> </div>\n  </div>\n  <!-- // parallax --> \n  \n  <!-- team -->\n  <div id=\"sec02\">\n    <div class=\"honshikannaikan\"> <img src=\"../img/honshikan002.jpg\" > </div>\n    <div class=\"honshikannaikan02\">\n      <p><b>ガス製造所からスタートし、道路部分とお客さまの敷地に引き込む「ガス導管」を施工します。</b></p>\n      <img src=\"../img/honshikan_sozai.jpg\"> </div>\n    <div class=\"team\">\n      <div class=\"title01\">\n        <p><span><b>こんなチームでシゴトします！</b></span><br />\n          The team of work</p>\n        <img src=\"../img/title01.jpg\"></div>\n      <ul>\n        <li><img src=\"../img/icon01.png\">\n          <p><span class=\"hnfont01\">現場の守護神</span><br />\n            <span class=\"hnfont02\"><b>監理士</b></span><br />\n            <span class=\"hnfont03\">■</span>工事全体の工程管理<br />\n            <span class=\"hnfont03\">■</span>必要書類の作成<br />\n            <span class=\"hnfont03\">■</span>現場での他設備業者との<br />\n            &emsp;打ち合わせや調整業務<br />\n            <span class=\"hnfont03\">■</span>工事現場の全体指揮</p>\n        </li>\n        <li><img src=\"../img/icon02.png\" alt=\"\">\n          <p><span class=\"hnfont01\">ガス工事の最前線</span><br />\n            <span class=\"hnfont02\"><b>工事士</b></span><br />\n            <span class=\"hnfont03\">■</span>工事当日の進捗管理<br />\n            <span class=\"hnfont03\">■</span>導管の加工・接続<br />\n            <span class=\"hnfont03\">■</span>道路への導管の埋設</p>\n        </li>\n      </ul>\n    </div>\n  </div>\n  \n  <!-- // team --> \n  \n  <!-- nagare -->\n  <div id=\"sec03\">\n    <div class=\"title02\">\n      <p><span><b>1日の流れ</b></span></p>\n      <img src=\"../img/title02.jpg\"></div>\n    <div class=\"honshikannagare\"><img src=\"../img/hn_sozai01.png\">\n      <p><b>本支管監理士<br/>\n        本支管工事士</b></p>\n    </div>\n    <div class=\"honshikantime\"><img src=\"../img/time_001.png\" alt=\"8:30\"><br />\n      <p><b>朝礼</b><br />\n      </p>\n      現場の監理士や工事士が集まり、その日の工事内容や安全確保の注意点、使用機材などを確認します。<br />\n    </div>\n    <div class=\"honshikannagare02\"><img src=\"../img/hn_sozai02.png\">\n      <p><b>本支管<br />\n        監理士</b></p>\n    </div>\n    <div class=\"honshikantime02\"><img src=\"../img/time_002.png\" alt=\"9:30\"><br />\n      <p><b>施工監理業務 </b><br />\n      </p>\n      現場の安全を確保するため、カラーコーンなどの設置状況や重機周囲の安全確認などを行います。 <br />\n    </div>\n    <div class=\"honshikannagare03\"><img src=\"../img/hn_sozai01.png\">\n      <p><b>本支管<br />\n        工事士</b> \n    </div>\n    <div class=\"honshikantime05\"><img src=\"../img/time_003.png\" alt=\"10:00\"><br />\n      <p><b>本支管埋設作業</b><br />\n      </p>\n      道路を掘削し、ガス導管を埋設する作業を行います。 <br />\n    </div>\n    <div class=\"honshikannagare04\"><img src=\"../img/hn_sozai02.png\">\n      <p><b>本支管<br />\n        監理士</b> \n    </div>\n    <div class=\"honshikantime02\"><img src=\"../img/time_004.png\" alt=\"10:30\"><br />\n      <p><b>本支管埋設業務</b><br />\n      </p>\n      道路にガス導管を埋設する工事で、工程通りに正しく行われているか確認します。 <br />\n    </div>\n    <div class=\"honshikantime03\"><img src=\"../img/time_007.png\" alt=\"12：00\"><br />\n      <b>休憩</b>\n      <p>食事をとるだけでなく、チーム内でコミュニケーションをとって風通しの良い関係を築く大切な時間です。</p>\n    </div>\n    <div class=\"honshikannagare05\"><img src=\"../img/hn_sozai01.png\">\n      <p><b>本支管<br />\n        工事士</b> \n    </div>\n    <div class=\"honshikantime\"><img src=\"../img/time_005.png\" alt=\"12:30\"><br />\n      <p><b>配管・融着・<br />\n        溶接作業</b><br />\n      </p>\n      ガス導管を接続する作業を行います。 <br />\n    </div>\n    <div class=\"honshikannagare06\"><img src=\"../img/hn_sozai02.png\" >\n      <p><b>本支管<br />\n        工事士</b> \n    </div>\n    <div class=\"honshikantime02\"><img src=\"../img/time_006.png\" alt=\"14:30\"><br />\n      <p><b>埋戻し作業</b><br />\n      </p>\n      配管が終わったら土を埋め戻します。土を入れた後は機械で地面を固めます。 <br />\n    </div>\n    <div class=\"honshikantime04\"><img src=\"../img/time_008.png\" alt=\"夕方\"><br />\n      <b>退社</b>\n      <p>当日の報告書作成や翌日以降の準備をしてから退社します。</p>\n    </div>\n  </div>\n  \n  <!-- // nagare --> \n  \n  <!-- interview -->\n  <div class=\"topinterview\"><img src=\"../img/interview_bg.png\" alt=\"先輩に聞いてみました！！\">\n    <p><b>｢ガス工事｣の現場で働く先輩たちのホンネをご紹介。</b></p>\n  </div>\n  <div class=\"topinterviewin\">\n    <div class=\"swiper-container\">\n      <div class=\"swiper-wrapper\">\n        <div class=\"swiper-slide\"><a href=\"../interview/index.html#interview01\"><img src=\"../img/interview_01.jpg\"></a>\n          <p class=\"swiper-slide01\">本支管監理士<br />\n            <span><b>田中 将浩</b></span></p>\n        </div>\n        <div class=\"swiper-slide\"><a href=\"../interview/index.html#interview02\"><img src=\"../img/interview_02.jpg\" alt=\"樋田 泰裕\"></a>\n          <p class=\"swiper-slide01\">本支管監理士<br />\n            <span><b></b></span></p>\n        </div>\n        <div class=\"swiper-slide\"><a href=\"../interview/index.html#interview03\"><img src=\"../img/interview_03.jpg\"></a>\n          <p class=\"swiper-slide01\">本支管工事士<br />\n            <span><b>庄司 昌弘</b></span></p>\n        </div>\n        <div class=\"swiper-slide\"><a href=\"../interview/index.html#interview04\"><img src=\"../img/interview_04.jpg\"></a>\n          <p class=\"swiper-slide01\">本支管工事士<br />\n            <span><b>村川 弘信</b></span></p>\n        </div>\n        <div class=\"swiper-slide\"><a href=\"../interview/index.html#interview05\"><img src=\"../img/interview_05.jpg\"></a>\n          <p class=\"swiper-slide01\">本支管工事士<br />\n            <span><b>藤井 康博</b></span></p>\n        </div>\n        <div class=\"swiper-slide\"><a href=\"../interview/index.html#interview06\"><img src=\"../img/interview_06.jpg\"></a>\n          <p class=\"swiper-slide02\">内管監理士<br />\n            <span><b>丹羽 真里奈</b></span></p>\n        </div>\n        <div class=\"swiper-slide\"><a href=\"../interview/index.html#interview07\"><img src=\"../img/interview_07.jpg\"></a>\n          <p class=\"swiper-slide01\">内管工事士<br />\n            <span><b>田中 廣幸</b></span></p>\n        </div>\n        <div class=\"swiper-slide\"><a href=\"../interview/index.html#interview08\"><img src=\"../img/interview_08.jpg\"></a>\n          <p class=\"swiper-slide01\">内管工事士<br />\n            <span><b>谷上 友浩</b></span></p>\n        </div>\n        <div class=\"swiper-slide\"><a href=\"../interview/index.html#interview09\"><img src=\"../img/interview_09.jpg\"></a>\n          <p class=\"swiper-slide01\">内管設計士<br />\n            <span><b>二村 一輝</b></span></p>\n        </div>\n      </div>\n      <div class=\"swiper-pagination\"></div>\n      <div class=\"swiper-button-prev\"></div>\n      <div class=\"swiper-button-next\"></div>\n    </div>\n  </div>\n  <div class=\"interviewbutton\"><a href=\"../interview/index.html\"><img src=\"../img/button_interview.png\" alt=\"他の社員を見る\"></a> </div>\n  \n  <!-- //interview --> \n  \n  <!-- kyujin -->\n  <div class=\"topcooperation02\"> <img src=\"../img/cooperation_bg02.png\" alt=\"求人工事会社一覧\">\n    <p class=\"cooperationfont02\"><b>あなたが輝く場所が、きっとあります。<br />\n      一緒に働く仲間を募集中の会社はこちら！</b></p>\n    <p class=\"cooperationmore02\"><a href=\"../kyujin/index.html\"><img src=\"../img/button_more.png\" alt=\"詳しく見る\"></a></p>\n    <p class=\"cooperatioimage02\"><img src=\"../img/woman.png\" alt=\"\"></p>\n    \n    <!-- topbutton -->\n    <div class=\"gotop\"> <a href=\"#header\"><img src=\"../img/button.png\" alt=\"top\"></a> </div>\n    <!-- //topbutton --> \n  </div>\n  <!-- //kyujin --> \n  \n  <!-- footer -->\n  <footer id=\"footer\">\n    <ul>\n      <li><a href=\"../index.html\">TOP</a></li>\n      <li>|</li>\n      <li><a href=\"../honshikan/index.html\">本支管工事</a></li>\n      <li>|</li>\n      <li><a href=\"../naikan/index.html\">内管工事</a></li>\n      <li>|</li>\n      <li><a href=\"../interview/index.html\">インタビュー</a></li>\n      <li>|</li>\n      <li><a href=\"../support/index.html\">研修サポート</a></li>\n      <li>|</li>\n      <li><a href=\"../kyujin/index.html\">求人工事会社一覧</a></li>\n      <li>|</li>\n      <li><a href=\"../faq/index.html\">よくある質問</a></li>\n    </ul>\n  </footer>\n  <div id=\"footer02\">\n    <div class=\"inner\">\n      <div class=\"fnavi\">\n        <ul>\n          <li><a href=\"/siteinfo/site-use/\"><img src=\"../img/fnavi_site-use.gif\" height=\"19\" width=\"140\" alt=\"サイトのご利用にあたって\" /></a></li>\n          <li><a href=\"/siteinfo/privacypolicy/\"><img src=\"../img/fnavi_privacypolicy.gif\" height=\"19\" width=\"143\" alt=\"個人情報の取扱いについて\" /></a></li>\n        </ul>\n      </div>\n      <div class=\"copyright\">\n        <p><img src=\"../img/copyright.gif\" alt=\"東邦ガスネットワーク株式会社 Copyright &#169; TOHO GAS NETWORK Co., Ltd. All Rights Reserved.\" width=\"297\" height=\"39\" />\n      </div>\n\n    </div>\n  </div>\n</div>\n\n<!-- //footer -->\n</div>\n\n<!-- /wrap --> \n<script type=\"text/javascript\">\n\tif (location .protocol == \"https:\") {\n\tdocument.write(unescape('%3Cscript src=\"https://ssl.syncsearch.jp/common