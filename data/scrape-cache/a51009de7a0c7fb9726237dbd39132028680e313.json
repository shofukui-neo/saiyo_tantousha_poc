s=\"navlist\">\n \t\t\t\t\t\t<a href=\"https://www.mizuho.co.jp/recruit/faq/\" class=' link-gnav'>\n \t\t\t\t\t\t\t<span class=\"en\">FAQ</span>\n \t\t\t\t\t\t\t<span class=\"ja\">よくある質問</span>\n \t\t\t\t\t\t</a>\n \t\t\t\t\t</li>\n \t\t\t\t\t<li class=\"navlist\">\n            <a href=\"https://job.mynavi.jp/27/pc/search/corp227148/outline.html\" class=\"img-btn link-gnav mynavi\" target=\"_blank\">\n              <img src=\"https://job.mynavi.jp/conts/kigyo/2027/logo/banner_logo_195_60.gif\" alt=\"マイナビ2027\" border=\"0\" style=\"max-width: 190px;\">\n            </a>\n \t\t\t\t\t</li>\n \t\t\t\t\t<li class=\"navlist\">\n \t\t\t\t\t\t<a href=\"https://www.mizuho.co.jp/recruit/entry/\" class='entry link-gnav'>\n \t\t\t\t\t\t\t<span class=\"en\">ENTRY</span>\n \t\t\t\t\t\t\t<span class=\"ja\">エントリー</span>\n \t\t\t\t\t\t</a>\n \t\t\t\t\t</li>\n\n \t\t\t\t</ul>\n \t\t\t</nav>\n \t\t</div>\n \t</div>\n\n </header>\n\n\n <main role=\"main\" class=\"main \">\n<div class=\"pgttl\">\n\t<div class=\"inner-pgttl\">\n\t\t<div class=\"txt\">\n\t\t\t<div class=\"wrapper-en\"><p class=\"en\">Training</p></div>\n\t\t\t<div><h1 class=\"ja\">人材育成</h1></div>\n\t\t</div>\n\t\t<div class=\"bg photo-ofi\">\n\t\t\t<img src=\"https://www.mizuho.co.jp/recruit/wp-content/themes/mizuho1.2.7/img/common/bg-pgttl-training.jpg\" alt=\"人材育成\">\n\t\t</div>\n\t</div>\n</div>\n\n<div class=\"breadcrumbs\">\n\t<ul class=\"list-inline\" itemscope itemtype=\"http://schema.org/BreadcrumbList\"><li itemprop=\"itemListElement\" itemscope itemtype=\"http://schema.org/ListItem\"><a href=\"https://www.mizuho.co.jp/recruit/\" class=\"home\" itemprop=\"item\" ><span itemprop=\"name\">TOP</span></a><meta itemprop=\"position\" content=\"1\" /></li><li itemprop=\"itemListElement\" itemscope itemtype=\"http://schema.org/ListItem\"><span itemprop=\"name\">人材育成</span><meta itemprop=\"position\" content=\"2\" /></li></ul></div>\n\n<div class=\"section-lg\">\n\t<div class=\"container-fluid container-lg\">\n\t\t<div class=\"wrapper-txt-lined mb-40\">\n\t\t\t<p class=\"txt-lined txt-training txt-main txt-bold txt-mincho ls-md\">\n\t\t\t\t自分で考えて、学んで、行動する<br>\n\t\t\t\tグローバルに活躍できる人材へ\n\t\t\t</p>\n\t\t</div>\n\t\t<div class=\"row mb-60\">\n\t\t\t<div class=\"col-lg-10 col-lg-offset-1\">\n\t\t\t\t<p class=\"txt-18 txt-mincho\">\n\t\t\t\t\t個々の個性を活かし活躍していく時代になり、自分のキャリアや能力は、自分で高めていく必要があります。その中で、ミズホが目指すのは<span class=\"txt-20 txt-bold txt-mincho\">“自分で考えて、学んで、行動する”</span>ことができる人材づくりです。\n\t\t\t\t\tそれが、どのような環境でも自身を高め、グローバルに活躍できる人材につながると考えています。\n\t\t\t\t\tそのために、意欲のある社員を全面的にバックアップする制度を整えています。\n\t\t\t\t</p>\n\t\t\t</div>\n\t\t</div>\n\t\t<p class=\"arrow-training\">\n\t\t\tミズホではキャリアに応じたテーマで<br class=\"visible-xs\">育成プログラムを用意しています。\n\t\t</p>\n\t</div>\n</div>\n<div class=\"section-lg bg-light\">\n\t<div class=\"container-fluid container-lg\">\n\t\t<p>\n\t\t\t<img alt=\"研修制度・育成プログラム\" class=\"img-responsive center-block\" src=\"https://www.mizuho.co.jp/recruit/wp-content/themes/mizuho1.2.7/img/common/table-training.png\">\n\t\t</p>\n\t</div>\n</div>\n</main>\n\t<section class=\"section-requirements section-lg\">\n\t\t<div class=\"container-lg container-fluid\">\n\t\t\t<div class=\"txt-center txt-main mb-40\">\n\t\t\t\t<h2 class=\"txt-40 txt-eng ls-md mb-10\">Requirements</h2>\n\t\t\t\t<p class=\"txt-18 txt-mincho txt-bold ls-md lh-1\">募集要項</p>\n\t\t\t</div>\n\t\t\t<div class=\"row row-min\">\n\t\t\t\t<div class=\"col-xs-6\">\n\t\t\t\t\t<a href=\"https://www.mizuho.co.jp/recruit/requirements-01/\" class=\"btn-requirements\">\n\t\t\t\t\t\t<span class=\"inner\">新卒募集要項</span>\n\t\t\t\t\t</a>\n\t\t\t\t</div>\n\t\t\t\t<div class=\"col-xs-6\">\n\t\t\t\t\t<a href=\"https://www.mizuho.co.jp/recruit/requirements-02/\" class=\"btn-requirements\">\n\t\t\t\t\t\t<span class=\"inner\">中途募集要項</span>\n\t\t\t\t\t</a>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\t</section>\n\n<footer class=\"footer\">\n\t\t\t<p>\n\t\t\t<a href=\"https://www.mizuho.co.jp/recruit/entry/\" class=\"btn-entry-footer\">\n\t\t\t\tENTRY\n\t\t\t</a>\n\t\t</p>\n\t\t<div class=\"footer-top\">\n\t\t<div class=\"container-lg container-fluid mb-20\">\n\t\t\t<div class=\"row\">\n\t\t\t\t<div class=\"col-sm-4 left mb-20-xs\">\n\t\t\t\t\t<h2 class=\"ttl-footer mb-20\">\n\t\t\t\t\t\t<img src=\"https://www.mizuho.co.jp/recruit/wp-content/themes/mizuho1.2.7/img/common/logo.png\" alt=\"採用情報 &#8211; ミズホ株式会社\" class=\"img-responsive\">\n\t\t\t\t\t</h2>\n\t\t\t\t\t<div class=\"detail mb-20\">\n\t\t\t\t\t\t<p class=\"txt-14 txt-bold mb-5 txt-center-xs\">ミズホ株式会社</p>\n\t\t\t\t\t\t<p class=\"txt-13 txt-center-xs\">\n\t\t\t\t\t\t\t〒113-0033 <br>東京都文京区本郷3丁目30番13号\n\t\t\t\t\t\t</p>\n\t\t\t\t\t</div>\n\t\t\t\t\t<p class=\"txt-center-xs\">\n\t\t\t\t\t\t<a href=\"https://www.mizuho.co.jp\" class=\"btn-base btn-lined txt-15 txt-mincho\" target=\"_blank\">企業公式HP</a>\n\t\t\t\t\t</p>\n\t\t\t\t</div>\n\t\t\t\t<div class=\"col-sm-8 right\">\n\t\t\t\t\t<div class=\"tb\">\n\t\t\t\t\t\t<ul class=\"list-footer\">\n\t\t\t\t\t\t\t<li><a href=\"https://www.mizuho.co.jp/recruit\">リクルートサイトトップ</a></li>\n\t\t\t\t\t\t\t<li><a href=\"https://www.mizuho.co.jp/recruit/training/\">人材育成</a></li>\n\t\t\t\t\t\t\t<li><a href=\"https://www.mizuho.co.jp/recruit/environment/\">働く環境</a></li>\n\t\t\t\t\t\t</ul>\n\t\t\t\t\t\t<ul class=\"list-footer\">\n\t\t\t\t\t\t\t<li><a href=\"https://www.mizuho.co.jp/recruit/infographics/\">数字で見るミズホ</a></li>\n\t\t\t\t\t\t\t<li><a href=\"https://www.mizuho.co.jp/recruit/systems/\">各種制度</a></li>\n\t\t\t\t\t\t\t<li><a href=\"https://www.mizuho.co.jp/recruit/interview/\">先輩インタビュー</a></li>\n\t\t\t\t\t\t</ul>\n\t\t\t\t\t\t<ul class=\"list-footer\">\n\t\t\t\t\t\t\t<li><a href=\"https://www.mizuho.co.jp/recruit/requirements-01/\">新卒募集要項</a></li>\n\t\t\t\t\t\t\t<li><a href=\"https://www.mizuho.co.jp/recruit/requirements-02/\">中途募集要項</a></li>\n\t\t\t\t\t\t\t<li><a href=\"https://www.mizuho.co.jp/recruit/faq/\">よくある質問</a></li>\n\t\t\t\t\t\t\t<li><a class=\"target_b\" href=\"https://www.mizuho.co.jp/media/\" onclick=\"gtag('event', 