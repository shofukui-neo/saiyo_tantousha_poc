" />\n</head>\n\n<body class=\"home wp-singular page-template-default page page-id-30 wp-theme-nanboku-bs\">\n        <!-- ======== ヘッダー ======== -->\n    <header class=\"header\" id=\"header\">\n        <div class=\"header__inner base-inner\">\n                        <h1 class=\"header__logo\">\n                <a href=\"https://nanboku-bs.co.jp/\">\n                    <img src=\"https://nanboku-bs.co.jp/cms/wp-content/themes/nanboku-bs/img/logo.png\" alt=\"南北ビルセイビ株式会社\">\n                </a>\n            </h1>\n            \n            <nav class=\"header__nav nav\">\n                <ul class=\"nav__list\">\n                    <li class=\"nav__item is-active\">\n                        <a href=\"https://nanboku-bs.co.jp/\">ホーム</a>\n                    </li>\n                    <li class=\"nav__item \">\n                        <a href=\"https://nanboku-bs.co.jp/about\">私たちについて</a>\n                    </li>\n                    <li class=\"nav__item \">\n                        <a href=\"https://nanboku-bs.co.jp/company\">会社情報</a>\n                    </li>\n                    <li class=\"nav__item \">\n                        <a href=\"https://nanboku-bs.co.jp/work\">事業紹介</a>\n                    </li>\n                </ul>\n                <div class=\"header__actions\">\n                    <a href=\"https://nanboku-bs.co.jp/recruit\"\n                        class=\"btn btn--recruit \">\n                        <span class=\"icon-user\"><i class=\"fa-solid fa-user\"></i></span>採用情報\n                    </a>\n                    <a href=\"https://nanboku-bs.co.jp/contact\"\n                        class=\"btn btn--contact \">\n                        <span class=\"icon-mail\"><i class=\"fa-solid fa-envelope\"></i></span>お問い合わせ\n                    </a>\n                </div>\n                <!-- /.header__actions -->\n            </nav>\n\n            <button class=\"header__hamburger hamburger\" id=\"js-hamburger\" aria-label=\"メニューを開く\" aria-expanded=\"false\"\n                aria-controls=\"js-nav\">\n                <span class=\"hamburger__line\"></span>\n                <span class=\"hamburger__line\"></span>\n                <span class=\"hamburger__line\"></span>\n            </button>\n\n            <nav class=\"header__sp-nav sp-nav\" id=\"js-nav\">\n                <ul class=\"sp-nav__list\">\n                    <li class=\"sp-nav__item\"><a href=\"https://nanboku-bs.co.jp/\">ホーム</a></li>\n                    <li class=\"sp-nav__item\"><a href=\"https://nanboku-bs.co.jp/about\">私たちについて</a></li>\n                    <li class=\"sp-nav__item\"><a href=\"https://nanboku-bs.co.jp/company\">会社情報</a></li>\n                    <li class=\"sp-nav__item\"><a href=\"https://nanboku-bs.co.jp/work\">事業紹介</a></li>\n                    <li class=\"sp-nav__item\"><a href=\"https://nanboku-bs.co.jp/news\">新着情報</a></li>\n                    <li class=\"sp-nav__item\"><a href=\"https://nanboku-bs.co.jp/csr-policy\">CSRポリシー</a></li>\n                    <li class=\"sp-nav__item\"><a\n                            href=\"https://nanboku-bs.co.jp/privacy-policy\">プライバシーポリシー</a></li>\n                </ul>\n                <div class=\"header__actions\">\n                    <a href=\"https://nanboku-bs.co.jp/recruit\" class=\"btn btn--recruit\"><span\n                            class=\"icon-user\"><i class=\"fa-solid fa-user\"></i></span>採用情報</a>\n                    <a href=\"https://nanboku-bs.co.jp/contact\" class=\"btn btn--contact\"><span\n                            class=\"icon-mail\"><i class=\"fa-solid fa-envelope\"></i></span>お問い合わせ</a>\n                </div>\n                <!-- /.header__actions -->\n            </nav>\n        </div>\n        <!-- /.header__inner base-inner -->\n    </header>\n\n    <div class=\"overlay\" id=\"js-overlay\"></div>\n\n    <div id=\"wrapper\"><main class=\"main\">\n    <section class=\"mv\">\n        <video src=\"https://nanboku-bs.co.jp/cms/wp-content/themes/nanboku-bs/img/mv.mp4\" autoplay muted playsinline id=\"bg-video\"\n            class=\"mv__video except-sp\"></video>\n        <img src=\"https://nanboku-bs.co.jp/cms/wp-content/themes/nanboku-bs/img/mv.webp\" alt=\"\" class=\"mv__img only-sp\">\n        <div class=\"mv__inner base-inner\">\n            <h2 class=\"mv__title\">\n                誠実に、実直に。<br>\n                その空間に、心地よい品質を。\n            </h2>\n            <h3 class=\"mv__company\">南北ビルセイビ株式会社</h3>\n            <div class=\"mv__recruit-cta\">\n                <p class=\"mv__text\">私たちと一緒に、<br>心地よい未来をつくりませんか。</p>\n                <a href=\"https://nanboku-bs.co.jp/recruit\" class=\"btn btn--mv-cta\">採用情報をみる<span\n                        class=\"arrow-wrap\"><span class=\"arrow\"></span></span></a>\n            </div>\n            <!-- /.mv__recruit-cta -->\n        </div>\n        <!-- /.mv__inner .base-inner -->\n\n        <!-- ======== スクロールインジケーター ======== -->\n        <div class=\"scroll-indicator\">\n            <div class=\"chevron-container\">\n                <div class=\"chevron\"></div>\n                <div class=\"chevron\"></div>\n                <div class=\"chevron\"></div>\n            </div>\n            <span class=\"scroll-text\">Scroll</span>\n        </div>\n        <!-- /.scroll-indicator -->\n    </section>\n\n    <!-- ======== パンくずリスト ======== -->\n    \n    <!-- ======== 信頼の実績と安定基盤 ======== -->\n    <section class=\"achieve bg-color\">\n        <div class=\"achieve__inner base-inner\">\n            <div class=\"section-header fadeUp\">\n                <span class=\"section-header__en\" aria-hidden=\"true\">OUR ACHIEVEMENTS</span>\n                <h2 class=\"section-header__jp\">信頼の実績と安定基盤</h2>\n            </div>\n            <!-- /.section-header -->\n            <div class=\"achieve__lead narrow-inner fadeUp\">\n                <p>\n                    昭和32年の創業以来、半世紀以上にわたり地域社会とともに歩み、誠実に積み重ねてきた信頼の証。平成27年に竣工した難波の自社ビルを拠点に、現在、私たちが管理をお任せいただいている物件数は約400件にのぼり、その実績は多岐にわたります。\n                </p>\n                <p>\n                    長い歴史の中で培ったノウハウは、確かな公的認定によって裏付けられています。「建築物環境衛生総合管理業」としての総合的なビルマネジメント能力に加え、特に厳格な衛生基準が求められる「医療関連サービスマーク」の認定も取得。\n                </p>\n                <p>オフィスビルからマンション、商業・医療施設まで、あらゆる空間に「安心」と「快適」を提供できるプロフェッショナルとして、お客様の大切な資産価値を守り抜きます。</p>\n            </div>\n            <!-- /.achieve__lead -->\n            <div class=\"achieve__cards\">\n                <div class=\"achieve__card achieve-card fadeUp\">\n                    <h3 class=\"achieve-card__title\">管理物件数</h3>\n                    <div class=\"achieve-card__text\">\n                        <p><span class=\"achieve-card__about\">約</span><span class=\"achieve-card__num\">400</span><span\n                                class=\" achieve-card__unit\">件<sup class=\" achieve-card__sup\">※</sup></span>\n                        </p>\n                    </div>\n                    <!-- /.achieve-card__text -->\n                </div>\n                <!-- /.achieve__card -->\n                <div class=\"achieve__card achieve-card fadeUp\">\n                    <h3 class=\"achieve-card__title\">創業</h3>\n                    <div class=\"achieve-card__text\">\n                        <p><span class=\"achieve-card__num\" id=\"u_years\"></span><span\n                                class=\" achieve-card__unit\">年</span></p>\n                    </div>\n                    <!-- /.achieve-card__text -->\n                </div>\n                <!-- /.achieve__card -->\n                <div class=\"achieve__card achieve-card fadeUp\">\n                    <h3 class=\"achieve-card__title\">登録・認定</h3>\n                    <div class=\"achieve-card__text achieve-card__text--license\">\n                        <p><span class=\"achieve-card__license\">建築物環境衛生総合管理業<br>医療関連サービスマーク認定</span></p>\n                    </div>\n                    <!-- /.achieve-card__text -->\n                </div>\n                <!-- /.achieve__card -->\n            </div>\n            <!-- /.achieve__cards -->\n            <div class=\"achieve__note fadeUp\">※令和8年5月現在</div>\n        </div>\n        <!-- /.achieve__inner .base-inner -->\n    </section>\n\n    <!-- ======== 南北ビルセイビの「強み」 ======== -->\n    <section class=\"front-strengths\">\n        <div class=\"front-strengths__inner base-inner\">\n            <div class=\"section-header fadeUp\">\n                <span class=\"section-header__en\" aria-hidden=\"true\">OUR STRENGTHS</span>\n                <h2 class=\"section-header__jp\">南北ビルセイビの「強み」</h2>\n            </div>\n            <!-- /.section-header -->\n            <div class=\"front-strengths__grid\">\n                <div class=\"strength-card fadeUp\">\n                    <span class=\"strength-card__num\">01</span>\n                    <div class=\"strength-card__icon\">\n                        <img src=\"https://nanboku-bs.co.jp/cms/wp-content/themes/nanboku-bs/img/icon-strength-01.webp\" alt=\"\">\n                    </div>\n                    <!-- /.strength-card__icon -->\n                    <p class=\"strength-card__text\">「ひと」を大切にする企業風土</p>\n                </div>\n                <!-- /.strength-card -->\n                <div class=\"strength-card fadeUp\">\n                    <span class=\"strength-card__num\">02</span>\n                    <div class=\"strength-card__icon\">\n                        <img src=\"https://nanboku-bs.co.jp/cms/wp-content/themes/nanboku-bs/img/icon-strength-02.webp\" alt=\"\">\n                    </div>\n                    <!-- /.strength-card__icon -->\n                    <p class=\"strength-card__text\">高い技術力と専門性</p>\n                </div>\n                <!-- /.strength-card -->\n                <div class=\"strength-card fadeUp\">\n                    <span class=\"strength-card__num\">03</span>\n                    <div class=\"strength-card__icon strength-card__icon--3\">\n                        <img src=\"https://nanboku-bs.co.jp/cms/wp-content/themes/nanboku-bs/img/icon-strength-03.webp\" alt=\"\">\n                    </div>\n                    <!-- /.strength-card__icon -->\n                    <p class=\"strength-card__text\">機動力と柔軟な対応</p>\n                </div>\n                <!-- /.strength-card -->\n                <div class=\"strength-card fadeUp\">\n                    <span class=\"strength-card__num\">04</span>\n                    <div class=\"strength-card__icon\">\n                        <img src=\"https://nanboku-bs.co.jp/cms/wp-content/themes/nanboku-bs/img/icon-strength-04.webp\" alt=\"\">\n                    </div>\n                    <!-- /.strength-card__icon -->\n                    <p class=\"strength-card__text\">現場との温度感を大切にする経営</p>\n                </div>\n                <!-- /.strength-card -->\n                <div class=\"strength-card fadeUp\">\n                    <span class=\"strength-card__num\">05</span>\n                    <div class=\"strength-card__icon\">\n                        <img src=\"https://nanboku-bs.co.jp/cms/wp-content/themes/nanboku-bs/img/icon-strength-05.webp\" alt=\"\">\n                    </div>\n                    <!-- /.strength-card__icon -->\n                    <p class=\"strength-card__text\">現場との距離感が近い組織</p>\n                </div>\n                <!-- /.strength-card -->\n                <div class=\"strength-card fadeUp\">\n                    <span class=\"strength-card__num\">06</span>\n                    <div class=\"strength-card__icon\">\n                        <img src=\"https://nanboku-bs.co.jp/cms/wp-content/themes/nanboku-bs/img/icon-strength-06.webp\" alt=\"\">\n                    </div>\n                    <!-- /.strength-card__icon -->\n                    <p class=\"strength-card__text\">働きやすい職場環境</p>\n                </div>\n                <!-- /.strength-card -->\n            </div>\n            <!-- /.front-strengths__grid -->\n            <div class=\"front-strengths__btn fadeUp\">\n                <a href=\"https://nanboku-bs.co.jp/about#strengths\" class=\"btn\"><span\n                        class=\"except-sp\">南北ビルセイビの</span>強みを詳しくみる<span class=\"arrow-wrap\"><span\n                            class=\"arrow\"></span></span></a>\n            </div>\n            <!-- /.front-strengths__btn -->\n        </div>\n        <!-- /.front-strengths__inner. base-inner -->\n    </section>\n\n    <!-- ======== 事業紹介 ======== -->\n    <section class=\"front-work bg-color\">\n        <div class=\"front-work__inner\">\n            <div class=\"front-work__img-box front-work-block1 fadeUp\">\n                <p class=\"vertical-text\">ビルメンテナンス事業</p>\n                <img src=\"https://nanboku-bs.co.jp/cms/wp-content/themes/nanboku-bs/img/regular-cleaning-03.webp\" alt=\"\">\n            </div>\n            <!-- /.front-work__img-box -->\n            <div class=\"front-work__img-box front-work-block2 fadeUp\">\n                <p class=\"vertical-text\">商環境事業</p>\n                <img src=\"https://nanboku-bs.co.jp/cms/wp-content/themes/nanboku-bs/img/work-commercial.webp\" alt=\"\">\n            </div>\n            <!-- /.front-work__img-box -->\n            <div class=\"front-work__content front-work-block3 fadeUp\">\n                <div class=\"section-header\">\n                    <span class=\"section-header__en\" aria-hidden=\"true\">OUR SERVICE</span>\n                    <h2 class=\"section-header__jp\">事業紹介</h2>\n                </div>\n                <!-- /.section-header -->\n                <div class=\"front-work__text\">\n                    <p>訪れる人に「心地よさ」を、オーナー様に「安心」を。\n                        日々のメンテナンスによる環境維持から、ビジネスを活性化させる店舗・空間デザインまで。お客様の大切な資産価値を高める、最適なソリューションをご提案します。\n                    </p>\n                </div>\n                <!-- /.front-work__text -->\n                <div class=\"front-work__btn only-pc\">\n                    <a href=\"https://nanboku-bs.co.jp/work\" class=\"btn\">事業紹介を詳しくみる<span\n                            class=\"arrow-wrap\"><span class=\"arrow\"></span></span></a>\n                </div>\n                <!-- /.front-work__btn -->\n            </div>\n            <!-- /.front-work__content -->\n            <div class=\"front-work__btn except-pc front-work-block4 fadeUp\">\n                <a href=\"https://nanboku-bs.co.jp/work\" class=\"btn\">事業紹介を詳しくみる<span class=\"arrow-wrap\"><span\n                            class=\"arrow\"></span></span></a>\n            </div>\n            <!-- /.front-work__btn -->\n        </div>\n        <!-- /.front-work__inner -->\n    </section>\n\n    <!-- ======== 新着情報 ======== -->\n    <section class=\"front-news\">\n        <div class=\"front-news__inner base-inner\">\n            <div class=\"front-news__header\">\n                <div class=\"section-header fadeUp\">\n                    <span class=\"section-header__en\" aria-hidden=\"true\">NEWS</span>\n                    <h2 class=\"section-header__jp\">新着情報</h2>\n                </div>\n                <!-- /.section-header -->\n                <div class=\"front-news__btn only-pc fadeUp\">\n                    <a href=\"https://nanboku-bs.co.jp/news\" class=\"btn\">新着情報一覧<span class=\"arrow-wrap\"><span\n                                class=\"arrow\"></span></span></a>\n                </div>\n                <!-- /.front-news__btn -->\n            </div>\n            <!-- /.front-news__header -->\n                                    <ul class=\"front-news__list fadeUp\">\n                                <li class=\"front-news__item\">\n                    <a href=\"https://nanboku-bs.co.jp/website-renewal/\">\n                        <span class=\"front-news__meta\">\n                            <time datetime=\"2025-12-25\">2026.06.02</time>\n                            <span class=\"front-news__tag\">\n                                <span class=\"category-label\">お知らせ</span></span>\n                        </span>\n                        <p class=\"front-news__title\">ホームページをリニューアルしました</p>\n                    </a>\n                </li>\n                <!-- /.front-news__item -->\n                                <li class=\"front-news__item\">\n                    <a href=\"https://nanboku-bs.co.jp/bcp-certification/\">\n                        <span class=\"front-news__meta\">\n                            <time datetime=\"2025-12-25\">2026.03.26</time>\n                            <span class=\"front-news__tag\">\n                                <span class=\"category-label\">お知らせ</span></span>\n                        </span>\n                        <p class=\"front-news__title\">経済産業省の「事業継続力強化計画」の認定を取得しました</p>\n                    </a>\n                </li>\n                <!-- /.front-news__item -->\n                                <li class=\"front-news__item\">\n                    <a href=\"https://nanboku-bs.co.jp/building-environment-2026/\">\n                        <span class=\"front-news__meta\">\n                            <time datetime=\"2025-12-25\">2026.02.27</time>\n                            <span class=\"front-news__tag\">\n                                <span class=\"category-label\">お知らせ</span></span>\n                        </span>\n                        <p class=\"front-news__title\">「建築物環境衛生総合管理業」の登録を更新しました</p>\n                    </a>\n                </li>\n                <!-- /.front-news__item -->\n                            </ul>\n            <!-- /.front-news__list -->\n            \n            <div class=\"front-news__btn except-pc fadeUp\">\n                <a href=\"https://nanboku-bs.co.jp/news\" class=\"btn\">新着情報一覧<span class=\"arrow-wrap\"><span\n                            class=\"arrow\"></span></span></a>\n            </div>\n            <!-- /.front-news__btn -->\n        </div>\n        <!-- /.front-news__inner -->\n    </section>\n\n    <!-- ======== 採用情報 ======== -->\n    <section class=\"front-recruit bg-color\">\n        <div class=\"front-recruit__inner\">\n            <div class=\"front-recruit__img recruit-block-full fadeUp\">\n                <img src=\"https://nanboku-bs.co.jp/cms/wp-content/themes/nanboku-bs/img/recruit-full.webp\" alt=\"\">\n                <div class=\"front-recruit__textBox\">\n                    <h3>正社員採用</h3>\n                    <p>安定した環境でキャリアを築きたい方へ</p>\n                </div>\n                <!-- /.front-recruit__textBox -->\n            </div>\n            <!-- /.front-recruit__img -->\n            <div class=\"front-recruit__message recruit-block-message fadeUp\">\n                <div class=\"section-header\">\n                    <span class=\"section-header__en\" aria-hidden=\"true\">RECRUIT</span>\n                    <h2 class=\"section-header__jp\">採用情報</h2>\n                </div>\n                <!-- /.section-header -->\n                <div class=\"front-recruit__text\">\n                    <p>\n                        街の「快適」を支える、<br class=\"except-tab\">やりがいのある仕事です。\n                    </p>\n                    <p>\n                        私たちと一緒に、<br class=\"except-tab\">心地よい空間をつくりませんか？\n                    </p>\n                </div>\n                <!-- /.front-recruit__text -->\n                <div class=\"front-recruit__btn only-pc\">\n                    <a href=\"https://nanboku-bs.co.jp/recruit\" class=\"btn\">採用情報を詳しくみる<span\n                            class=\"arrow-wrap\"><span class=\"arrow\"></span></span></a>\n                </div>\n                <!-- /.front-recruit__btn -->\n            </div>\n            <!-- /.front-recruit__message -->\n            <div class=\"front-recruit__img recruit-block-part fadeUp\">\n                <img src=\"https://nanboku-bs.co.jp/cms/wp-content/themes/nanboku-bs/img/recruit-part.webp\" alt=\"\">\n                <div class=\"front-recruit__textBox\">\n                    <h3>パート社員採用</h3>\n                    <p>ライフスタイルに合わせて働きたい方へ</p>\n                </div>\n                <!-- /.front-recruit__textBox -->\n            </div>\n            <!-- /.front-recruit__img -->\n            <div class=\"front-recruit__btn except-pc recruit-block-btn fadeUp\">\n                <a href=\"https://nanboku-bs.co.jp/recruit\" class=\"btn\">採用情報を詳しくみる<span\n                        class=\"arrow-wrap\"><span class=\"arrow\"></span></span></a>\n            </div>\n            <!-- /.front-recruit__btn -->\n        </div>\n        <!-- /.front-recruit__inner -->\n    </section>\n\n    <!-- ======== 採用情報CTA ======== -->\n        <!-- 採用に関するお問い合わせ -->\n    <section class=\"recruit-cta fadeUp\">\n        <div class=\"recruit-cta__inner\">\n            <h2 class=\"recruit-cta__title\">採用に関するお問い合わせ</h2>\n            <div class=\"recruit-cta__btns\">\n                <a href=\"tel:0800-200-6441\" class=\"recruit-cta__btn\"><span>専用フリーダイヤル</span><span><i\n                            class=\"fa-solid fa-phone\"></i><span class=\"tel\">0800-200-6441</span></span></a>\n                <a href=\"https://nanboku-bs.co.jp/contact\" class=\"recruit-cta__btn\"><i\n                        class=\"fa-solid fa-envelope\"></i>お問い合わせフォーム</a>\n                <a href=\"https://arwrk.net/recruit/f9tkh3sisgwpg9g/\" class=\"recruit-cta__btn\">採用サイトへ移動する<i\n                        class=\"fa-solid fa-arrow-up-right-from-square\"></i></a>\n            </div>\n            <!-- /.recruit-cta__btns -->\n        </div>\n        <!-- /.recruit-cta__inner -->\n    </section>\n</main>\n    </div>\n    <!-- /.wrapper -->\n\n    <div id=\"go-top\"></div>\n\n    <!-- ======== フッター ======== -->\n    <footer class=\"footer base-inner fadeUp\">\n        <div class=\"footer__inner narrow-inner\">\n            <div class=\"footer__info\">\n                <h2 class=\"footer__company\">南北ビルセイビ株式会社</h2>\n                <div class=\"footer__address\">\n                    <p>〒556-0011<br>\n                        大阪市浪速区難波中2丁目7番10号\n                    </p>\n                </div>\n                <!-- /.footer__address -->\n                <div class=\"footer__tel\">\n                    <p>TEL 06-6631-1441（代表）<br>\n             