l\" target=\"_blank\"><img class=\"hoverimg\" src=\"/images/dt_banner.png\" width=\"205\" alt=\"塩竈の味をお届け！仙台伊達さつま揚げ詰合せセット\" /></a></div>\n  <div style=\"margin-top:5px;\"><a href=\"https://www.abezen-online.com/shiogama_odenkan_lp.html\" target=\"_blank\"><img class=\"hoverimg\" src=\"/images/od_banner.png\" width=\"205\" alt=\"かきの旨味だし塩竈おでん缶6缶セット 非常食に最適！\" /></a></div>\n  <!--\n  <div style=\"margin-top:5px;\"><a href=\"https://www.abezen-online.com/shiogama_beer_lp.html\" target=\"_blank\"><img class=\"hoverimg\" src=\"/images/beer_banner.jpg\" width=\"205\" alt=\"塩竈の海に乾杯！海の幸によく合う塩竈ビール\" /></a></div>\n-->\n </div><!--/#contents_left-->\n\n <div id=\"ll_contents_right\">\n \n\t\t<h1>お問い合わせ</h1>\r\n<div class=\"aim_box\"><form id=\"mailform\" action=\"/cgi/mailform/send.cgi\" method=\"post\" name=\"mailform\"><input type=\"hidden\" />\r\n<table class=\"contact_table\">\r\n<tbody>\r\n<tr>\r\n<th>お名前<span class=\"text_red bold\">※</span></th>\r\n<td><input class=\"textbox\" name=\"お名前(必須)\" size=\"30\" type=\"text\" />\r\n例：山田 太郎</td>\r\n</tr>\r\n<tr>\r\n<th>郵便番号<span class=\"text_red bold\">※</span></th>\r\n<td><input class=\"textbox\" name=\"郵便番号(必須)\" size=\"15\" type=\"text\" />\r\n例：1231234</td>\r\n</tr>\r\n<tr>\r\n<th>ご住所</th>\r\n<td><input class=\"textbox\" name=\"ご住所\" size=\"70\" type=\"text\" />\r\n例：宮城県塩釜市中の島1-11</td>\r\n</tr>\r\n<tr>\r\n<th>電話番号</th>\r\n<td><input class=\"textbox\" name=\"電話番号\" size=\"30\" type=\"text\" />\r\n例：0223642155</td>\r\n</tr>\r\n<tr>\r\n<th>メールアドレス<span class=\"text_red bold\">※</span></th>\r\n<td><input class=\"textbox\" name=\"email(必須)\" size=\"30\" type=\"text\" />\r\n例：aaa@sample.com</td>\r\n</tr>\r\n<tr>\r\n<th>お問い合わせ種別<span class=\"text_red bold\">※</span>\r\n<span style=\"font-size: 12px; font-weight: normal;\">（いずれかを選択）</span></th>\r\n<td><input name=\"お問い合わせ種別(必須)\" type=\"radio\" value=\"お問い合わせ\" />お問い合わせ\r\n\r\n<input name=\"お問い合わせ種別(必須)\" type=\"radio\" value=\"弊社製品への感想・ご要望\" />弊社製品への感想・ご要望\r\n\r\n<span style=\"font-size: 12px;\">※感想・ご要望は、<a style=\"font-size: 12px;\" href=\"https://abezen.co.jp/voice-index/\">お客様の声</a><img src=\"/images/windows_icon.jpg\" alt=\"お客様の声\" width=\"12\" height=\"11\" />に掲載させて頂く場合がございます。</span></td>\r\n</tr>\r\n<tr>\r\n<th>お問い合わせ内容<span class=\"text_red bold\">※</span></th>\r\n<td><textarea cols=\"55\" name=\"お問い合わせ内容(必須)\" rows=\"5\"></textarea></td>\r\n</tr>\r\n</tbody>\r\n</table>\r\n<p style=\"text-align: center;\"><button>送信内容確認</button></p>\r\n&nbsp;\r\n\r\n</form>&nbsp;\r\n\r\n</div>\r\n<!--/.aim_box-->    \n </div><!--/#contents_right-->\n <div class=\"clear\"></div>\n \n <p class=\"to_pagetop\"><img src=\"/images/to_pagetop.jpg\" width=\"140\" height=\"23\" alt=\"ページの上部に戻る\" /></p>\n\n</div><!--/#ll_in_contents-->\n</div><!--contents-->\n\n\t<div id=\"footer_link\">\r\n\r\n <ul style=\"width:470px; margin:0 auto;\">\r\n  <!--<li><a href=\"\"><img class=\"hoverimg\" src=\"/images/footer_link_privacy.jpg\" width=\"148\" height=\"15\" alt=\"プライバシーポリシー\" /></a></li>-->\r\n  <!--<li><a href=\"\"><img class=\"hoverimg\" src=\"/images/footer_link_law.jpg\" width=\"176\" height=\"15\" alt=\"特定商取引法に関する表示\" /></a></li>-->\r\n  <!--<li><a href=\"\"><img class=\"hoverimg\" src=\"/images/footer_link_onlineshop.jpg\" width=\"133\" height=\"15\" alt=\"オンラインショップ\" /></a></li>-->\r\n  <li><a href=\"/blog-index/\"><img class=\"hoverimg\" src=\"/images/footer_link_zenlog.jpg\" width=\"178\" height=\"15\" alt=\"阿部善商店ブログ ZENLOG\" /></a></li>\r\n  <li><a href=\"/sitemap-index/\"><img class=\"hoverimg\" src=\"/images/footer_link_sitemap.jpg\" width=\"92\" height=\"15\" alt=\"サイトマップ\" /></a></li>\r\n  <li><a href=\"/five-articles/\"><img class=\"hoverimg\" src=\"/images/footer_link_lce.jpg\" width=\"121\" height=\"15\" alt=\"塩竈おでんとは\" /></a></li>\r\n  <div class=\"clear\"></div>\r\n </ul>\r\n\r\n</div><!--/.footer_link-->\r\n\r\n<div id=\"footer\">\r\n <div id=\"in_footer\">\r\n \r\n  <p class=\"footer_logo\"><img src=\"/images/footer_logo.jpg\" width=\"39\" height