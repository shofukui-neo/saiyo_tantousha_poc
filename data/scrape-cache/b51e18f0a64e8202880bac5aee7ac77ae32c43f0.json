{"url":"https://www.asahi.co.jp/saiyo/career/","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n\n<head>\n    <meta charset=\"utf-8\" />\n    <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\" />\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1, minimum-scale=1, maximum-scale=1, user-scalable=no\" />\n    <meta name=\"content-language\" content=\"ja\" />\n    <meta name=\"description\" content=\"朝日放送グループホールディングス、朝日放送テレビ キャリア採用情報のページです。\">\n    <meta name=\"google-site-verification\" content=\"4_zPsQJM-Wo6Z259HK0zrrLYlaSTG_0siVsrbnT8h0A\">\n    <meta property=\"og:title\" content=\"朝日放送グループホールディングス、朝日放送テレビ キャリア採用情報\">\n    <meta property=\"og:type\" content=\"article\">\n    <meta property=\"og:url\" content=\"https://www.asahi.co.jp/saiyo/career/index.html\">\n    <meta property=\"og:image\" content=\"https://www.asahi.co.jp/saiyo/career/img/ogp.png\">\n    <meta property=\"og:description\" content=\"朝日放送グループホールディングス、朝日放送テレビ キャリア採用情報のページです。\">\n    <meta name=\"twitter:card\" content=\"summary_large_image\">\n    <meta name=\"twitter:image\" content=\"https://www.asahi.co.jp/saiyo/career/img/ogp.png\">\n\n    <!-- <script type=\"text/javascript\" src=\"/common/js/analytics.min.js\" charset=\"UTF-8\"></script> -->\n    <!-- css -->\n    <link rel=\"stylesheet\" href=\"https://use.typekit.net/leh0dok.css\">\n    <link href=\"https://use.fontawesome.com/releases/v5.6.1/css/all.css\" rel=\"stylesheet\">\n    <script type=\"text/javascript\" src=\"//typesquare.com/3/tsst/script/ja/typesquare.js?61652f0c3dfc40d294791813ac1e02d5\" charset=\"utf-8\"></script>\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"./css/drawer.min.css\" />\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"./css/style.min.css?202401\" />\n\n    <title>キャリア採用情報 | 朝日放送グループホールディングス</title>\n    <!-- Google Tag Manager -->\n    <script>\n        (function (w, d, s, l, i) {\n            w[l] = w[l] || [];\n            w[l].push({\n                'gtm.start': new Date().getTime(),\n                event: 'gtm.js'\n            });\n            var f = d.getElementsByTagName(s)[0],\n                j = d.createElement(s),\n                dl = l != 'dataLayer' ? '&l=' + l : '';\n            j.async = true;\n            j.src =\n                'https://www.googletagmanager.com/gtm.js?id=' + i + dl;\n            f.parentNode.insertBefore(j, f);\n        })(window, document, 'script', 'dataLayer', 'GTM-WPBZTT4');\n    </script>\n    <!-- End Google Tag Manager -->\n</head>\n\n<body class=\"drawer drawer--right\">\n    <!-- Google Tag Manager (noscript) -->\n    <noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-WPBZTT4\" height=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n    <!-- End Google Tag Manager (noscript) -->\n\n    <header id=\"top\" class=\"position-now\">\n        <section>\n            <!-- head navi -->\n            <!-- ハンバーガーメニュー -->\n            <div class=\"navi\">\n                <p class=\"navi-logo\"><a href=\"/saiyo/career/\">朝日放送テレビ キャリア採用情報</a></p>\n\n                <!-- hamburger-button -->\n                <button type=\"button\" class=\"drawer-toggle drawer-hamburger\">\n                    <span class=\"sr-only\">toggle navigation</span>\n                    <span class=\"drawer-hamburger-icon\"></span>\n                </button>\n                <nav class=\"drawer-nav\" role=\"navigation\">\n                    <ul class=\"drawer-menu\">\n                        <li><a href=\"#top\" id=\"top_link_js\">トップ</a></li>\n                        <li><a href=\"#jobs\" id=\"jobs_link_js\">私たちの仕事</a></li>\n                        <li><a href=\"#limited\" id=\"limited_link_js\">限定募集</a></li>\n                        <li><a href=\"#usually\" id=\"usually_link_js\">随時募集</a></li>\n                        <!-- <p class=\"bt_application\"><a href=\"#application\" id=\"application_link_js\">応募宛先</a></p> -->\n                        <li class=\"drawer-menu_li_app\"><a href=\"#application\" id=\"application_link_js\" class=\"bt_application\">応募する</a></li>\n\n                        <li class=\"sp-only drawer-nav_link\"><a href=\"https://corp.asahi.co.jp/ja/index.html\" target=\"_blank\">会社情報</a></li>\n                        <li class=\"sp-only drawer-nav_link\"><a href=\"https://www.asahi.co.jp/regulation/\" target=\"_blank\">サイトの<br>ご利用にあたって</a></li>\n                        <li class=\"sp-only drawer-nav_link\"><a href=\"https://www.asahi.co.jp/personal/\" target=\"_blank\">個人情報の<br>取り扱い方針</a></li>\n                    </ul>\n                </nav>\n\n            </div>\n            <!-- /ハンバーガーメニュー -->\n            </div>\n            <!-- /head navi -->\n            <div class=\"wrap-out\">\n                <h1><span>朝日放送グループホールディングス<br>朝日放送テレビ</span>キャリア採用情報</h1>\n                <div class=\"news\">\n                    <p class=\"news-icon\">NEWS</p>\n                    <p class=\"news-content\">営業局・技術局は 2026年1⽉30⽇まで︕</p>\n                </div>\n            </div>\n        </section>\n    </header>\n\n    <main>\n        <!-- 私たちの仕事 -->\n        <section id=\"jobs\" class=\"wrapper position-now\">\n            <div class=\"wrap-out\">\n                <h1>私たちの仕事</h1>\n                <div class=\"wrap-inn\">\n                    <h2>ABCの新しい未来を<br>共に創造しませんか?</h2>\n                    <div class=\"main_copy\">\n                        <p>朝日放送グループホールディングスでは、テレビを取り巻く事業環境の変化、多様化を、<br class=\"pc-min-only\">またとない「進化のチャンス」として捉え、テレビの枠を飛び越え、メディアの殻を打ち破り、<br class=\"pc-min-only\">人々の心や社会を動かす「ムーブメントカンパニー」に生まれ変わろうとしています。</p>\n                        <p>我々が創り出すコンテンツの価値を最大化できる方、<br class=\"pc-min-only\">既存の枠に捉われずに柔軟で独創的なアイデアで新たなコンテンツを創り出せる方、<br class=\"pc-min-only\">我々と共に新しいABCの未来を創っていきませんか?</p>\n                    </div>\n                </div>\n            </div>\n        </section>\n        <!-- /私たちの仕事 -->\n\n        <!-- 募集 -->\n        <section id=\"occupation\" class=\"wrapper position-now22\">\n            \n            <!-- 限定募集 -->\n            <div id=\"limited\" class=\"wrap-inner position-now\">\n                <h1 class=\"h1-title limited-title\">限定募集</h1>\n                <p class=\"limited-txt\">2025年12⽉1⽇〜2026年1⽉30⽇まで、「営業局」「技術局」のキャリア採⽤を募集いたします。</p>\n                <ul class=\"limited-links\">\n                    <li><a href=\"#process\">選考プロセス<i class=\"fas fa-chevron-down\"></i></a></li>\n                    <li><a href=\"#occupation-sales\">営業局・募集要項<i class=\"fas fa-chevron-down\"></i></a></li>\n                    <li><a href=\"#occupation-tech\">技術局・募集要項<i class=\"fas fa-chevron-down\"></i></a></li>\n                </ul>\n\n                <p class=\"limited-h2\">選考プロセス</p>\n                <p class=\"limited-note\">※ 本スケジュールは想定であり、応募状況や選考の進捗により、⽇程が変更となる可能性がございます。あらかじめご了承ください。</p>\n\n                <ul id=\"process\" class=\"limited-process\">\n                    <li>\n                        <div class=\"limited-process_period\">2026年<br class=\"pc-min-only\">1月30日締切</div>\n                        <p class=\"limited-process_detail\"><span>＜STEP 1＞ご応募</span>応募の際、<strong>「写真付き履歴書」「略歴書」「志望理由」の3点</strong>\n                            をご提出いただきます。</p>\n                    </li>\n                    <li>\n                        <div class=\"limited-process_period\">2026年<br class=\"pc-min-only\">2⽉上旬結果発表</div>\n                        <p class=\"limited-process_detail\"><span>＜STEP 2＞書類選考</span>ご提出いただいた<strong>書類に基づき選考</strong>を⾏います。</p>\n                    </li>\n                    <li>\n                        <div class=\"limited-process_period\">2026年<br class=\"pc-min-only\">2⽉上旬〜3⽉中旬</div>\n                        <p class=\"limited-process_detail\"><span>＜STEP 3＞⾯接（複数回）</span><strong>⼀次⾯接はオンライン、⼆次⾯接以降は対⾯</strong>を予定しています。</p>\n                    </li>\n                    <li>\n                        <div class=\"limited-process_period\">2026年<br class=\"pc-min-only\">3⽉下旬〜</div>\n                        <p class=\"limited-process_detail\"><span>＜STEP 4＞内定</span>⾯接を通過された⽅に内定のご連絡をいたします。</p>\n                    </li>\n                </ul>\n\n                <!-- 営業局 -->\n                <div id=\"occupation-sales\" class=\"wrap-inn\">\n                    <h2 class=\"h2-long\">\n                        <p class=\"occupation-title-p\">営業局　東京セールスソリューション部　<br class=\"tab-only\">プレーヤークラス</p><span class=\"icon-txt\"><em class=\"icon-txt_end\">募集終了</em></span>\n                        <!-- <p class=\"occupation-title-p\">営業局　東京セールスソリューション部　<br class=\"tab-only\">プレーヤークラス</p><span class=\"icon-txt\"><em>2026年1⽉30⽇まで</em></span> -->\n                    </h2>\n                    <ul class=\"occupation-detail\">\n                        <li>\n                            <p>仕事の内容</p>\n                            <div>\n                                <ul class=\"list-marker\">\n                                    <li>地上波テレビおよびデジタル領域（TVer等）におけるセールス企画の開発・販促支援</li>\n                                    <li>放送局の新規マネタイズ領域における企画戦略の立案・推進支援</li>\n                                </ul>\n                            </div>\n                        </li>\n                        <li>\n                            <p>雇用形態</p>\n                            <div>契約社員（正社員登用の場合あり ※詳細面談にて）</div>\n                        </li>\n                        <li>\n                            <p>必要な経験・<br class=\"tab-only\">能力など</p>\n                            <div>\n                                <ol class=\"list-marker\">\n                                    <li><span>・</span>地上波テレビ営業の実務経験を有する方<br>\n                                        （例：スポット・タイムセールスの基礎理解、番組企画立案、渉外対応 等）</li>\n                                    <li><span>・</span>デジタル広告のセールスまたは運用経験をお持ちの方</li>\n                                    <li><span>・</span>将来的には営業局以外の部署や関係会社、また大阪本社含めて活躍していただく可能性があります</li>\n                                </ol>\n                            </div>\n                        </li>\n                        <li>\n                            <p>勤務地</p>\n                            <div>東京オフィス</div>\n                        </li>\n                        <li>\n                            <p>勤務時間</p>\n                            <div>10:00～18:00</div>\n                        </li>\n                        <li>\n                            <p>待遇</p>\n                            <div>詳細面談にて</div>\n                        </li>\n                    </ul>\n                    <!-- <div class=\"occupation-app_bt\"><a href=\"#application\"><i class=\"fas fa-chevron-down\"></i>応募する</a></div> -->\n                </div>\n\n                <!-- 技術局 -->\n                <div id=\"occupation-tech\" class=\"wrap-inn\">\n                    <h2 class=\"h2-long\">\n                        <p class=\"occupation-title-p\">技術局　プレーヤークラス</p><span class=\"icon-txt\"><em class=\"icon-txt_end\">募集終了</em></span>\n                        <!-- <p class=\"occupation-title-p\">技術局　プレーヤークラス</p><span class=\"icon-txt\"><em>2026年1⽉30⽇まで</em></span> -->\n                    </h2>\n                    <ul class=\"occupation-detail\">\n                        <li>\n                            <p>仕事の内容</p>\n                            <div>\n                                <ul class=\"list-marker\">\n                                    <li>放送コンテンツ制作技術全般、送出・送信技術全般</li>\n                                    <li>コンテンツ制作でのAI技術の利活用、コンテンツ配信・リアルタイム配信、IPマスターなどの次期新放送設備構築</li>\n                                    <li>ICT分野の高い知見をもっての業務改善や効率化につながるシステム開発</li>\n                                </ul>\n                            </div>\n                        </li>\n                        <li>\n                            <p>雇用形態</p>\n                            <div>契約社員（正社員登用の場合あり ※詳細面談にて）</div>\n                        </li>\n                        <li>\n                            <p>応募資格</p>\n                            <div>以下のいずれかにあてはまる方\n                                <ul class=\"list-marker\">\n                                    <li>放送局や放送メディアに関連する企業での勤務経験があり、放送技術スキルや放送システムの運用・構築経験がある方</li>\n                                    <li>ネットワーク・クラウド・AI技術などを利用したシステム構築や運用及びプログラミングの実務経験がある方</li>\n                                </ul>\n                            </div>\n                        </li>\n                        <li>\n                            <p>必要な経験・<br class=\"tab-only\">能力など</p>\n                            <div>\n                                <ol class=\"list-marker\">\n                                    <li><span>・</span>最新IT技術の知識と経験</li>\n                                    <li><span>・</span>高い専門性と新規分野への挑戦意欲、柔軟な思考と創造力</li>\n                                    <li><span>・</span>将来、チームをけん引できる強いリーダーシップ、協調性、コミュニケーション能力</li>\n                                    <li><span>・</span>広範囲なタスクに対する責任感と完遂への意欲</li>\n                                    <li><span>・</span>将来的には技術職以外の部署や関係会社、また東京オフィス含めて活躍していただく可能性があります</li>\n                                </ol>\n                            </div>\n                        </li>\n                        <li>\n                            <p>勤務地</p>\n                            <div>大阪本社</div>\n                        </li>\n                        <li>\n                            <p>勤務時間</p>\n                            <div>10:00～18:00</div>\n                        </li>\n                        <li>\n                            <p>待遇</p>\n                            <div>詳細面談にて</div>\n                        </li>\n                    </ul>\n                    <!-- <div class=\"occupation-app_bt\"><a href=\"#application\"><i class=\"fas fa-chevron-down\"></i>応募する</a></div> -->\n                </div>\n\n            </div>\n            <!-- 限定募集 -->\n\n            <!-- 随時募集 -->\n            <div id=\"usually\" class=\"wrap-out position-now\">\n                <div class=\"occupation-title_link\">\n                    <h1>\n                        <p class=\"h1-title\">随時募集<span>OCCUPATION</span></p>\n                    </h1>\n                    <ul class=\"occupation-links\"><!-- txt長い場合：<a>に class=\"occupation-links_long\" -->\n                        <li><a href=\"#occupation-12\">総合編成局　ライツマネジメント部　<br>プレーヤークラス<i class=\"fas fa-chevron-down\"></i></a></li>\n                        <li><a href=\"#occupation-11\" class=\"occupation-links_long\">東京マーケティング・PR部　プレーヤークラス<i class=\"fas fa-chevron-down\"></i></a></li>\n                        <li><a href=\"#occupation-02\" class=\"occupation-links_long\">マーケティング戦略部　プレーヤークラス<i class=\"fas fa-chevron-down\"></i></a></li>\n                    </ul>\n                </div>\n\n                <!-- 総合編成局　ライツマネジメント部　プレーヤークラス -->\n                <div id=\"occupation-12\" class=\"wrap-inn\">\n                    <h2 class=\"h2-long\">\n                        <!-- <p class=\"occupation-title-p\">人事局　プレーヤークラス</p><span class=\"icon-txt\"><em class=\"icon-txt_end\">募集終了</em></span> -->\n                        <p class=\"occupation-title-p\">総合編成局　ライツマネジメント部　<br class=\"sp-only\">プレーヤークラス</p><span class=\"icon-txt\"><em>募集中</em></span>\n                    </h2>\n                    <ul class=\"occupation-detail\">\n                        <li>\n                            <p>仕事の内容</p>\n                            <div>\n                                <ul class=\"list-marker\">\n                                    <li>コンテンツビジネスに関する契約書作成及び審査</li>\n                                    <li>著作権に関する相談への対応</li>\n                                    <li>権利処理に関する業務</li>\n                                    <li>権利者団体の窓口及び交渉業務</li>\n                                </ul>\n                            </div>\n                        </li>\n                        <li>\n                            <p>雇用形態</p>\n                            <div>契約社員（正社員登用の場合あり※詳細面談にて）</div>\n                        </li>\n                        <li>\n                            <p>応募資格</p>\n                            <div>以下のいずれかにあてはまる方\n                                <ul class=\"list-marker\">\n                                    <li>ロースクール卒業など法律の知識を有する方</li>\n                                    <li>著作権または契約実務経験のある方</li>\n                                </ul>\n                            </div>\n                        </li>\n                        <li>\n                            <p>必要な経験・<br class=\"tab-only\">能力など</p>\n                            <div>【必須】\n                                <ul class=\"list-marker\" style=\"margin-bottom: 20px;\">\n                                    <li>ドラマ、バラエティなどのコンテンツビジネスを著作権・契約の面から積極的に支援できる方</li>\n                                    <li>従来にないコンテンツビジネスのスキーム構築を著作権・契約の面からリードする意欲のある方</li>\n                                    <li>ビジネス著作権検定上級程度以上の著作権の知識のある方</li>\n                                </ul>\n                                【歓迎】\n                                <ul class=\"list-marker\" style=\"margin-bottom: 20px;\">\n                                    <li>弁護士資格を有するなど法律の知識が豊富な方</li>\n                                    <li>企業内の法務部門等で契約書作成・審査の実務経験のある方</li>\n                                    <li>エンターテーメント業界や著作権管理団体等で著作権関連業務の経験のある方</li>\n                                </ul>\n                                【その他】\n                                <ul class=\"list-marker\" style=\"margin-bottom: 20px;\">\n                                    <li>将来的にはライツマネジメント業務以外の部署や関係会社、また東京オフィス含めて活躍していただく可能性があります</li>\n                                </ul>\n                            </div>\n                        </li>\n                        <li>\n                            <p>勤務地</p>\n                            <div>大阪本社</div>\n                        </li>\n                        <li>\n                            <p>勤務時間</p>\n                            <div>10:00～18:00</div>\n                        </li>\n                        <li>\n                            <p>待遇</p>\n                            <div>詳細面談にて</div>\n                        </li>\n                    </ul>\n                    <div class=\"occupation-app_bt\"><a href=\"#application\"><i class=\"fas fa-chevron-down\"></i>応募する</a></div>\n                </div>\n\n                <!-- 東京マーケティング・PR部　プレーヤークラス -->\n                <div id=\"occupation-11\" class=\"wrap-inn\">\n                    <h2 class=\"h2-long\">\n                        <!-- <p class=\"occupation-title-p\">人事局　プレーヤークラス</p><span class=\"icon-txt\"><em class=\"icon-txt_end\">募集終了</em></span> -->\n                        <p class=\"occupation-title-p\">東京マーケティング・PR部　<br class=\"sp-only\">プレーヤークラス</p><span class=\"icon-txt\"><em>募集中</em></span>\n                    </h2>\n                    <ul class=\"occupation-detail\">\n                        <li>\n                            <p>仕事の内容</p>\n                            <div>番組含むコンテンツの宣伝業務全般<br>\n                                （戦略立案から実施・分析・評価・改善や、代理店・各部署との調整など）</div>\n                        </li>\n                        <li>\n                            <p>雇用形態</p>\n                            <div>契約社員（正社員登用の場合あり※詳細面談にて）</div>\n                        </li>\n                        <li>\n                            <p>応募資格</p>\n                            <div>\n                                <ul class=\"list-marker\">\n                                    <li>宣伝業務全般の実務経験者、特にSNS、WEBを使った宣伝の実務経験がある方</li>\n                                    <li>ドラマをはじめとしたテレビコンテンツに興味がある方</li>\n                                </ul>\n                            </div>\n                        </li>\n                        <li>\n                            <p>必要な経験・<br class=\"tab-only\">能力など</p>\n                            <div>\n                                <ul class=\"list-marker\">\n                                    <li>高いコミュニケーション力、また、リーダーシップを発揮し、チームメンバーを巻き込み、自らプロジェクトを推進できる方</li>\n                                    <li>一般的なPCスキルと資料作成スキル(企画書、実施報告書等)のある方</li>\n                                    <li>SNSリテラシーの高い方</li>\n                                    <li>事業会社や広告会社等で、各種データを用いた宣伝プランの分析・提案の経験がある方</li>\n                                    <li>将来的には宣伝業務以外の部署や関係会社にて活躍していただく可能性があります</li>\n                                </ul>\n                            </div>\n                        </li>\n                        <li>\n                            <p>勤務地</p>\n                            <div>東京オフィス、または大阪本社</div>\n                        </li>\n                        <li>\n                            <p>勤務時間</p>\n                            <div>10:00～18:00</div>\n                        </li>\n                        <li>\n                            <p>待遇</p>\n                            <div>詳細面談にて</div>\n                        </li>\n                    </ul>\n                    <div class=\"occupation-app_bt\"><a href=\"#application\"><i class=\"fas fa-chevron-down\"></i>応募する</a></div>\n                </div>\n\n                <!-- マーケティング戦略部　プレーヤークラス -->\n                <div id=\"occupation-02\" class=\"wrap-inn\">\n                    <h2>\n                        <!-- <p class=\"occupation-title-p\">マーケティング戦略部　<br class=\"sp-only\">プレーヤークラス</p><span class=\"icon-txt\"><em class=\"icon-txt_end\">募集終了</em></span> -->\n                        <p class=\"occupation-title-p\">マーケティング戦略部　<br class=\"sp-only\">プレーヤークラス</p><span class=\"icon-txt\"><em>募集中</em></span>\n                    </h2>\n                    <ul class=\"occupation-detail\">\n                        <li>\n                            <p>仕事の内容</p>\n                            <div>\n                                <ul class=\"list-marker\">\n                                    <li>視聴者ニーズを基に提案を行い、より良い番組＝コンテンツを世に出していく仕事</li>\n                                    <li>視聴者の満足度を高める施策を提案し、ABCファンを増やしていく仕事</li>\n                                    <li>テレビ番組やデジタルコンテンツにおける顧客ニーズを分析し、セールスに役立てる仕事</li>\n                                </ul>\n                            </div>\n                        </li>\n                        <li>\n                            <p>雇用形態</p>\n                            <div>契約社員（正社員登用の場合あり ※詳細面談にて）</div>\n                        </li>\n                        <li>\n                            <p>応募資格</p>\n                            <div>\n                                <!-- 20歳後半～40歳代前半 ※ -->マーケティング実務経験者に限ります</div>\n                        </li>\n                        <li>\n                            <p>必要な経験・<br class=\"tab-only\">能力など</p>\n                            <div>\n                                <ol class=\"list-marker\">\n                                    <li><span>&#9312;</span>事業会社や広告会社において、家庭用製品やサービスに関連するマーケティング業務を経験している方</li>\n                                    <li><span>&#9313;</span>調査会社や広告会社において、テレビやデジタルに関連するプランニングや、各種データを用いた分析・提案を経験している方</li>\n                                </ol>\n                                <span class=\"occupation-ul_note\">※①、②いずれかの条件に適合する方</span>\n                            </div>\n                        </li>\n                        <li>\n                            <p>勤務地</p>\n                            <div>大阪本社、または東京オフィス</div>\n                        </li>\n                        <li>\n                            <p>勤務時間</p>\n                            <div>10:00～18:00</div>\n                        </li>\n                        <li>\n                            <p>待遇</p>\n                            <div>詳細面談にて</div>\n                        </li>\n                    </ul>\n                    <div class=\"occupation-app_bt\"><a href=\"#application\"><i class=\"fas fa-chevron-down\"></i>応募する</a></div>\n                </div>\n            </div>\n            <!-- /随時募集 -->\n\n        </section>\n        <!-- /募集 -->\n\n        <!-- 応募宛先 -->\n        <section id=\"application\" class=\"wrapper position-now\">\n            <div class=\"wrap-out\">\n                <h1 class=\"h1-title\">応募宛先<span>APPLICATION ADDRESS</span></h1>\n                <div class=\"wrap-inn\">\n                    <p class=\"application-txt\">希望される職種を明記の上、メール、または郵送で「写真付き履歴書」「略歴書」「志望理由」の3点をお送りください。<br>\n                        書類審査の結果、面接させて頂く場合はこちらから連絡させて頂きます。<br>\n                        ※応募書類の返却はできません。予めご了承ください。</p>\n                    <ul class=\"occupation-detail\">\n                        <li>\n                            <p>メールアドレス</p>\n                            <div>朝日放送テレビ キャリア採用担当　<a href=\"mailto:asahi_career.gp@asahi.co.jp\" class=\"link-mail\">asahi_career.gp@asahi.co.jp</a></div>\n                        </li>\n                        <li>\n                            <p>郵送先</p>\n                            <div>〒553-8503　大阪市福島区福島1-1-30<br>\n                                朝日放送テレビ株式会社　人事局　キャリア採用担当宛</div>\n                        </li>\n                    </ul>\n                </div>\n            </div>\n        </section>\n        <!-- /応募宛先 -->\n\n    </main>\n\n    <footer>\n        <p id=\"pagetop\" style=\"display: block;\">\n            <a href=\"#top\"><i class=\"fas fa-chevron-up\"></i></a>\n        </p>\n        <div class=\"link-saiyo\">\n            <p><a href=\"../index.html\">採用総合サイト<i class=\"fas fa-chevron-right\"></i></a></p>\n            <p><a href=\"../newgrad/\">新卒採用サイト<i class=\"fas fa-chevron-right\"></i></a></p>\n        </div>\n        <ul>\n            <li><a href=\"https://corp.asahi.co.jp/ja/index.html\" target=\"_blank\">会社情報<i class=\"far fa-window-restore\"></i></a></li>\n            <li><a href=\"https://www.asahi.co.jp/regulation/\" target=\"_blank\">サイトのご利用にあたって<i class=\"far fa-window-restore\"></i></a></li>\n            <li><a href=\"https://www.asahi.co.jp/personal/\" target=\"_blank\">個人情報の取り扱い方針<i class=\"far fa-window-restore\"></i></a></li>\n        </ul>\n        <p>©ABC TV All rights reserved.</p>\n    </footer>\n\n    <!-- js -->\n    <script src=\"./js/lib/jquery.min.js\" type=\"text/javascript\"></script>\n    <script src=\"./js/lib/iscroll.min.js\" type=\"text/javascript\"></script>\n    <script src=\"./js/lib/drawer.min.js\" type=\"text/javascript\"></script>\n    <script src=\"./js/common.min.js\" type=\"text/javascript\"></script>\n</body>\n\n</html>\n","finalUrl":"https://www.asahi.co.jp/saiyo/career/","rendered":false,"_cachedAt":"2026-06-23T17:08:54.423Z"}