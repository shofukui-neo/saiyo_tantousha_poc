r>\r\n\t\t\t■<a href=\"./company.php?name=takeoff\"><span class=\"underline\">テイクオフ</span></a><br>\r\n\t\t\t■<a href=\"./company.php?name=tohokuasahi\"><span class=\"underline\">東北旭段ボール</span></a><br>\r\n\t\t\t■<a href=\"./company.php?name=toyotacorolla\"><span class=\"underline\">トヨタカローラ山形</span></a><br>\r\n\t\t\t■<a href=\"./company.php?name=netztoyota\"><span class=\"underline\">ネッツトヨタ山形</span></a><br>\r\n\t\t\t■<a href=\"./company.php?name=nogawa\"><span class=\"underline\">野川商事グループ</span></a><br>\r\n\t\t\t■<a href=\"./company.php?name=yab\"><span class=\"underline\">山形アドビューロ</span></a><br>\r\n\t\t\t■<a href=\"./company.php?name=yamagin\"><span class=\"underline\">山形銀行</span></a><br>\r\n\t\t\t■<a href=\"./company.php?name=sunene\"><span class=\"underline\">山形酸素</span></a><br>\r\n\t\t\t■<a href=\"./company.php?name=yamashin\"><span class=\"underline\">山形新聞社</span></a><br>\r\n\t\t\t■<a href=\"./company.php?name=daihatsu\"><span class=\"underline\">山形ダイハツ販売</span></a><br>\r\n\t\t\t■<a href=\"./company.php?name=ybc\"><span class=\"underline\">山形放送</span></a><br>\r\n\t\t\t■<a href=\"./company.php?name=travelysk\"><span class=\"underline\">山新観光</span></a><br>\r\n\t\t\t■<a href=\"./company.php?name=yamashinkenso\"><span class=\"underline\">山新建装</span></a><br>\r\n\t\t\t■<a href=\"./company.php?name=ycc\"><span class=\"underline\">ＹＣＣ情報システム</span></a><br>\r\n\t\t\t（五十音順）\r\n\t\t</td>\r\n\t</tr>\r\n</table>\r\n\t\r\n\t<!-- やまがた就活ナビとは -->\r\n\t<div id=\"about_navi\">\r\n\t    <h4>\r\n\t    \t<img src=\"./img/about_navi.svg\" alt=\"やまがた就活ナビとは\" class=\"banner_img\">\r\n\t    </h4>\r\n\t    \r\n\t\t<div class=\"three_col\">\r\n\t\t\t<div class=\"three_contenner\"> \r\n    \t\t\t<div>\r\n    \t\t\t\t<img src=\"./img/point-1.svg\" alt=\"会員登録なし\">\r\n      \t \t\t\t<p>参加登録しなくても、本サイトで企業情報をチェックすることができます。</p>\r\n    \t\t\t</div>\r\n\r\n    \t\t\t<div>\r\n    \t\t\t\t<img src=\"./img/point-2.svg\" alt=\"「働く」をイメージできる\">\r\n        \t\t\t<p>サイト内の企業紹介ページに参加企業の様子を詳しく紹介。実際に働く姿をイメージして就活を進めることができます。</p>\r\n    \t\t\t</div>\r\n\r\n\t\t\t\t<div>\r\n\t\t\t        <img src=\"./img/point-3.svg\" alt=\"新聞で情報ゲット\">\r\n\t\t\t        <p>\r\n\t\t\t        \t山形で働くには、山形の情報を知っておかなければなりません。山形新聞は、学生の皆さんに「お試し読み」を行っています。\r\n\t\t\t        \t<a href=\"https://www.yamagata-np.jp/koudoku/\" target=\"_blank\">詳しくはコチラ</a>\r\n\t\t\t        </p>\r\n\t\t\t    </div>\r\n\t\t\t</div>\r\n\t\t</div>\r\n\t</div><!-- about_navi -->\r\n\r\n    <h2><img src=\"./img/yamagata_work.svg\" alt=\"山形で働きたい\"></h2>\r\n    \t\r\n\t<!-- 山形は暮らしやすい -->\r\n\t<div id=\"yamagata_pref\">\r\n\t    <h2>\r\n\t    \t<img src=\"./img/rank_3reason.svg\" alt=\"山形が全国3位の3つの理由\" class=\"banner_img\">\r\n\t    </h2>\r\n\t    \r\n\t\t<div class=\"three_col\">\r\n\t\t\t<div class=\"three_contenner\"> \r\n\t    \t\t<div><img src=\"./img/employ_2.svg\" alt=\"全国２位\"></div>\r\n\t    \t\t<div><img src=\"./img/household_imcome3.svg\" alt=\"全国３位\"></div>\r\n\t     \t\t<div><img src=\"./img/commute_3_new.svg\" alt=\"全国６位\"></div>\r\n\t\t\t</div>\r\n\t\t</div><!-- three_col --> \r\n\r\n\t\t<div class=\"rank_caution\">\r\n\t\t\t<ul>\r\n\t\t\t    <li>※1 平成29年就業構造基本調査より</li>\r\n\t\t\t    <li>※2 令和3年国土交通省「企業等の東京一極集中に関する懇談会」資料より</li>\r\n\t\t\t    <li>※3 令和3年社会生活基本調査より</li>\r\n\t\t\t</ul>\r\n\t\t</div>\r\n\t</div><!-- yamagata_pref -->\r\n\r\n\t<!-- 就活情報は山形新聞で -->\r\n\t<div id=\"yamashin_area\">\r\n\t\t<h2>\r\n\t\t\t<img\r\n\t\t\t\tsrc=\"./img/yamashin_info.svg\"\r\n\t\t\t\talt=\"就活に役立つ情報は山形新聞で\"\r\n\t\t\t\tclass=\"banner_img\"\r\n\t\t\t>\r\n\t\t</h2>\r\n\r\n\t\t<div class=\"join_yamashin\">\r\n\t\t\t<a\r\n\t\t\t\thref=\"./yamashin_hambai.php\"\r\n\t\t\t\ttarget=\"_blank\"\r\n\t\t\t\tclass=\"btn-top btn_yamashin\"\r\n\t\t\t>\r\n\t\t\t山形新聞の購読はこちらから\r\n\t\t\t<img\r\n\t\t\t\tsrc=\"./img/yajirushi-white.svg\"\r\n\t\t\t\tclass=\"yajirushi\"\r\n\t\t\t\talt=\"新聞を購読する矢印ボタン\"\r\n\t\t\t>\r\n\t\t\t</a>\r\n\t\t</div><!-- join_yamashin -->\r\n\r\n\t\t<div class=\"about_nib\">\r\n\t\t    <h4>NIBフロントライン</h4>\r\n\t\t        <a\r\n\t\t    \t\t