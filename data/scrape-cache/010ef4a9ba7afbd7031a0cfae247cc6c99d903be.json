ttps://www.pasconet.co.jp/recruit/wp-content/themes/pasco/assets/js/jquery.min.js?ver=3.7.1\" id=\"jquery-js\"></script>\n<link rel=\"icon\" href=\"https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/01/cropped-favicon-32x32.png\" sizes=\"32x32\" />\n<link rel=\"icon\" href=\"https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/01/cropped-favicon-192x192.png\" sizes=\"192x192\" />\n<link rel=\"apple-touch-icon\" href=\"https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/01/cropped-favicon-180x180.png\" />\n<meta name=\"msapplication-TileImage\" content=\"https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/01/cropped-favicon-270x270.png\" />\n</script>\r\n</head>\r\n<body>\r\n\t<header id=\"header\" class=\"p-header\">\r\n    <div class=\"p-header__wrap\">\r\n        <a href=\"https://www.pasconet.co.jp/recruit/\" class=\"p-header__logo hover\">\r\n            <span class=\"p-header__logo-img\">\r\n                <img src=\"https://www.pasconet.co.jp/recruit/wp-content/themes/pasco/assets/images/common/pasco_logo.svg\" alt=\"Pasco\">\r\n            </span>\r\n            <span class=\"p-header__logo-txt\">新卒<br class=\"sp\">採用サイト</span>\r\n        </a>\r\n        <div class=\"p-header__right\">\r\n            <h1 class=\"p-header__ttl\">敷島製パン株式会社 Pascoの大学生向けの新卒採用サイト「失敗したらアドバイス、成功したら称賛。協力しあえる環境。」ページ</h1>\r\n            <div class=\"p-header__main\">\r\n                <nav class=\"p-header__nav\">\r\n                    <a href=\"https://www.pasconet.co.jp/recruit/details/\" class=\"p-header__btn btn-hover\">募集要項<span class=\"icon icon-info\"></span></a>\r\n                    <a href=\"https://job.axol.jp/bx/s/pasco_27/entry\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"p-header__btn p-header__btn--info btn-hover\">27年卒 ENTRY<span class=\"icon icon-entry\"></span></a>\r\n                    <a href=\"https://axol.jp/zw/s/pasco_28/entry/agreement\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"p-header__btn p-header__btn--