{"url":"https://www.alco-ex.jp/","html":"<!DOCTYPE html>\r\n<html dir=\"ltr\" lang=\"ja\">\r\n\r\n<head>\r\n  <meta charset=\"UTF-8\">\r\n  <meta name=\"viewport\" content=\"width=device-width, user-scalable=yes, maximum-scale=1.0, minimum-scale=1.0\">\r\n  <meta name=\"keywords\" content=\"介護見守りカメラ,介護施設来訪者受付システム,企業受付システム,ソフトウェア設計・開発,ＩＴソリューションの提供\">\r\n  <meta name=\"description\" content=\"介護見守りカメラ,介護施設来訪者受付システムなどで社会に貢献するソリューションを生み出す株式会社アルコ・イーエックス\">\r\n\r\n  <title>介護見守りカメラ|ソフトウェア設計・開発　ＩＴソリューションの提供　茨城県ひたちなか市の株式会社アルコ・イーエックス</title>\r\n\r\n  <link rel=\"stylesheet\" href=\"css/style.css\" type=\"text/css\" media=\"screen\">\r\n  <link rel=\"stylesheet\" href=\"css/style_plus.css\" type=\"text/css\" media=\"screen\">\r\n  <link rel=\"stylesheet\" type=\"text/css\" href=\"css/slick.css\" />\r\n  <link rel=\"stylesheet\" type=\"text/css\" href=\"css/slick-theme.css\" />\r\n  <link rel=\"stylesheet\" href=\"css/lightbox.min.css\" type=\"text/css\" />\r\n  <link rel=\"stylesheet\" href=\"css/colorbox.css\" />\r\n  <link rel=\"stylesheet\" href=\"css/styles_35th_anniversary.css\" type=\"text/css\" />\r\n  <link href=\"https://fonts.googleapis.com/css?family=Noto+Sans+JP:100,300,400,500&amp;subset=japanese\"\r\n    rel=\"stylesheet\">\r\n  <link href=\"images/favicon.ico\" rel=\"Shortcut Icon\" type=\"../image/x-icon\">\r\n\r\n  <style>\r\n    @media screen and (max-width: 960px) {\r\n      #url-txt1 {\r\n        position: absolute;\r\n        top: 267px;\r\n        left: 42px;\r\n        width: 200px;\r\n        text-align: left;\r\n        color: darkcyan;\r\n      }\r\n\r\n      .date {\r\n        position: absolute;\r\n        top: 50px;\r\n        left: 30px;\r\n        padding-right: 30px;\r\n        text-align: left;\r\n      }\r\n\r\n      .content {\r\n        position: absolute;\r\n        top: 75px;\r\n        left: 30px;\r\n        padding-right: 30px;\r\n        text-align: left;\r\n      }\r\n\r\n      .product_area {\r\n        margin-top: 30px;\r\n      }\r\n\r\n      .kh_pw {\r\n        position: absolute;\r\n        top: 80%;\r\n        right: 32%;\r\n      }\r\n\r\n      #top_content {\r\n        position: absolute;\r\n        top: 16%;\r\n        margin-left: 4.25%;\r\n        width: 340px;\r\n        font-size: 15px;\r\n        text-align: left;\r\n      }\r\n\r\n      .topnews_content{\r\n        text-align: left;\r\n        position: absolute;\r\n        top: 15%;\r\n        left: 5%;\r\n        padding-right: 20px;\r\n        font-size: 13px;\r\n      }\r\n    }\r\n\r\n    @media screen and (min-width: 960px) {\r\n      #url-txt1 {\r\n        position: absolute;\r\n        top: 192px;\r\n        left: 60px;\r\n        width: 500px;\r\n        text-align: left;\r\n        color: darkcyan;\r\n      }\r\n\r\n      .date {\r\n        position: absolute;\r\n        top: 50px;\r\n        left: 55px;\r\n        padding-right: 40px;\r\n        text-align: left;\r\n      }\r\n\r\n      .content {\r\n        position: absolute;\r\n        top: 75px;\r\n        left: 55px;\r\n        padding-right: 40px;\r\n        text-align: left;\r\n      }\r\n\r\n      .product_area {\r\n        margin-top: 30px !important;\r\n      }\r\n\r\n      .kh_pw {\r\n        position: absolute;\r\n        top: 75%;\r\n        right: 38%;\r\n      }\r\n\r\n      #top_content {\r\n        position: absolute;\r\n        top: 17%;\r\n        width: 1035px;\r\n        margin-left: 3.5%;\r\n        text-align: left;\r\n      }\r\n\r\n      .topnews_content{\r\n        text-align: left;\r\n        position: absolute;\r\n        top: 20%;\r\n        left: 6%;\r\n        padding-right: 50px;\r\n      }\r\n    }\r\n\r\n    /* @media screen and (-webkit-min-device-pixel-ratio: 0) {\r\n        _::-webkit-full-page-media, _:future, :root #nw_img{\r\n          left: 30% !important;\r\n        }\r\n      } */\r\n  </style>\r\n\r\n  <script src=\"js/html5.js\"></script>\r\n  <script src=\"js/css3-mediaqueries.js\"></script>\r\n  <script src=\"https://ajax.googleapis.com/ajax/libs/jquery/2.2.0/jquery.min.js\"></script>\r\n  <script src=\"js/script.js\"></script>\r\n  <script src=\"js/jquery.colorbox-min.js\"></script>\r\n  <script type=\"text/javascript\" src=\"js/slick.min.js\"></script>\r\n  <script type=\"text/javascript\" src=\"js/common.js\"></script>\r\n  <script type=\"text/javascript\" src=\"js/picturefill.js\"></script>\r\n  <script type='text/javascript' src=\"js/lightbox.min.js\"></script>\r\n\r\n  <script>\r\n    $(function () {\r\n      $(\".iframe\").colorbox({\r\n        iframe: true,\r\n        width: \"80%\",\r\n        height: \"80%\",\r\n        opacity: 0.7\r\n      });\r\n    });\r\n  </script>\r\n\r\n  <script>\r\n    $(document).ready(function () {\r\n      $('.slider').slick({\r\n        // アクセシビリティ。左右ボタンで画像の切り替えをできるかどうか\r\n        accessibility: true,\r\n        // 自動再生。trueで自動再生される。\r\n        autoplay: true,\r\n        // 自動再生で切り替えをする時間\r\n        autoplaySpeed: 6000,\r\n        // 自動再生や左右の矢印でスライドするスピード\r\n        speed: 1500,\r\n        // 自動再生時にスライドのエリアにマウスオンで一時停止するかどうか\r\n        pauseOnHover: true,\r\n        // 自動再生時にドットにマウスオンで一時停止するかどうか\r\n        pauseOnDotsHover: true,\r\n        // 切り替えのアニメーション。ease,linear,ease-in,ease-out,ease-in-out\r\n        cssEase: 'ease',\r\n        // 画像下のドット（ページ送り）を表示\r\n        // dots: true,\r\n        // ドットのclass名をつける\r\n        // dotsClass: 'slick-dots',\r\n        // ドラッグができるかどうか\r\n        draggable: true,\r\n        // 切り替え時のフェードイン設定。trueでon\r\n        fade: true,\r\n        // 左右の次へ、前へボタンを表示するかどうか\r\n        arrows: true,\r\n        // 無限スクロールにするかどうか。最後の画像の次は最初の画像が表示される。\r\n        infinite: true,\r\n        // 最初のスライダーの位置\r\n        initialSlide: 0,\r\n        // 画像の遅延表示。‘ondemand’or'progressive'\r\n        lazyLoad: 'ondemand',\r\n        // スライドのエリアにマウスオーバーしている間、自動再生を止めるかどうか。\r\n        pauseOnHover: true,\r\n        // スライドのエリアに画像がいくつ表示されるかを指定\r\n        slidesToShow: 1,\r\n        // 一度にスライドする数\r\n        slidesToScroll: 1,\r\n        // タッチスワイプに対応するかどうか\r\n        swipe: true,\r\n        // 縦方向へのスライド\r\n        vertical: false,\r\n        // 表示中の画像を中央へ\r\n        centerMode: true,\r\n        // 中央のpadding\r\n        centerPadding: '0px'\r\n      });\r\n    });\r\n  </script>\r\n</head>\r\n\r\n<body>\r\n  <!-- ヘッダ -->\r\n  <header id=\"header\" role=\"banner\">\r\n    <script type=\"text/javascript\">header();</script>\r\n\r\n    <!-- スライダー画像 -->\r\n    <div class=\"top_slider_pc\">\r\n      <ul class=\"slider\">\r\n        <!--classは任意の名前でOK-->\r\n        <li><a href=\"product_patientwatcher.html\"><img src=\"images/index_topscreen/top screen_img_pw.png\" alt=\"介護の質を高める新しい見守りのかたち ペイシェントウォッチャープラス\"></a></li>\r\n        <li><a href=\"product_patientwatcher_homecare.html\"><img src=\"images/index_topscreen/top screen_img_homecare.png\" alt=\"ペイシェントウォッチャープラスは住宅介護にも最適！\"></a></li>\r\n        <li><a href=\"product_patientwatcher.html#pw03\"><img src=\"images/index_topscreen/top screen_img_vital-rader-sensor.png\" alt=\"ペイシェントウォッチャープラスのバイタルレーダーで呼吸・脈拍の異常を検知\"></a></li>\r\n      </ul>\r\n    </div>\r\n\r\n    <div class=\"top_slider_mob\">\r\n      <ul class=\"slider\">\r\n        <!--classは任意の名前でOK-->\r\n        <li><a href=\"product_patientwatcher.html\"><img src=\"images/index_topscreen/top screen_img_pw_mob.png\" alt=\"介護の質を高める新しい見守りのかたち ペイシェントウォッチャープラス\"></a></li>\r\n        <li><a href=\"product_patientwatcher_homecare.html\"><img src=\"images/index_topscreen/top screen_img_homecare_mob.png\" alt=\"ペイシェントウォッチャープラスは住宅介護にも最適！\"></a></li>\r\n        <li><a href=\"product_patientwatcher.html#pw03\"><img src=\"images/index_topscreen/top screen_img_vital-rader-sensor_mob.png\" alt=\"ペイシェントウォッチャープラスのバイタルレーダーで呼吸・脈拍の異常を検知\"></a></li>\r\n      </ul>\r\n    </div>\r\n  </header>\r\n\r\n  <div id=\"main_content\" style=\"text-align: center;\">\r\n    <section class=\"news_area\">\r\n      <div class=\"container\">\r\n        <table class=\"newsWrap\">\r\n          <tr>\r\n            <th class=\"mob_title\"><img src=\"images/new_news_title.png\" alt=\"最新情報\"></th>\r\n          </tr>\r\n\r\n          <tr>\r\n            <th rowspan=\"3\" class=\"pc_title\">\r\n              <img src=\"images/new_news_title.png\" alt=\"最新情報\">\r\n            </th>\r\n            <td>\r\n              <span class=\"fb\">2026/04/15</span>\r\n              <span class=\"event\">お知らせ</span>\r\n              <span class=\"mob_blank\"><br></span>ISO9001認証取得をいたしました\r\n            </td>\r\n          </tr>\r\n\r\n          <tr>\r\n            <td>\r\n              <span class=\"fb\">2026/03/10</span>\r\n              <span class=\"event\">お知らせ</span>\r\n              <span class=\"mob_blank\"><br></span>CareTEX東京2026に出展しました\r\n            </td>\r\n          </tr>\r\n\r\n          <tr>\r\n            <td>\r\n              <span class=\"fb\">2026/02/05</span>\r\n              <span class=\"event\">お知らせ</span>\r\n              <span class=\"mob_blank\"><br></span>CareTEX東京2026に出展します\r\n            </td>\r\n          </tr>\r\n        </table>\r\n        <div class=\"center_btn news_btn\">\r\n          <a href=\"news.html\" class=\"btn-animation-01\">\r\n            <span>詳しく見る</span>\r\n          </a>\r\n        </div>\r\n      </div>\r\n    </section>\r\n\r\n    <!-- トップニュース -->\r\n\r\n    <div class=\"topnews-area\">\r\n\r\n      <div class=\"topnews-titlearea\">\r\n\r\n        <div class=\"title-position\">\r\n          <h4 class=\"topnews-title\">TOP<br>NEWS</h4>\r\n          <img class=\"title-yajirushi\" src=\"images/index_topnews/topnews-yajirushi.png\">\r\n          <img class=\"title-triangle\" src=\"images/index_topnews/topnews-triangle.png\">\r\n          <div class=\"topnews-date\">2026/04/15</div>\r\n          <img class=\"title-background\" src=\"images/index_topnews/topnews-back-ground-image.png\">\r\n        </div>\r\n        \r\n      </div>\r\n\r\n      <div class=\"topnews-mainarea\">\r\n        \r\n        <div class=\"text-title-area\">\r\n          <h5 class=\"text-title\">ISO9001認証取得をいたしました</h5>\r\n        </div>\r\n        <div class=\"text-area\">\r\n          \r\n          <p class=\"text\">\r\n            自社製品開発部門において、新たに品質マネジメントシステムに関する国際規格「ISO9001」の認証を、\r\n            2026年2月24日に取得いたしましたので、下記のとおりお知らせいたします。<br>\r\n            <br>\r\n            ■基本方針<br>\r\n            顧客満足の向上に、全従業員が一丸となって取り組みます。<br>\r\n            品質方針を具体的に実行するため、品質目標を設定し、その達成のための活動を行い、検証を行います。<br>\r\n            関連する法規制要求事項を順守します。<br>\r\n            全従業員が、教育・訓練を受講し、一人ひとりが力量を備えていることを確実にします。<br>\r\n            本「品質方針」および関連する諸規則、管理体制の評価、見直しを定期的に行うことで、品質マネジメントシステムの継続的な改善を図ります。<br>\r\n          </p>\r\n          \r\n          <div class=\"image-area\">\r\n            <img class src=\"images/index_topnews/20260415/ISO 9001_2015 UKAS_purple.jpg\" alt=\"ISO9001\">\r\n          </div>\r\n        \r\n        </div>\r\n        \r\n      </div>\r\n\r\n    </div>\r\n\r\n\r\n    <!--拡大画像使う用 \r\n          <a href=\"images/news/kh_pw_bannar.png\" data-lightbox=\"kh_pw_bannar\" class=\"kh_pw\">\r\n            <img id=\"bannar\" src=\"images/news/kh_pw_thumbnail.jpg\">\r\n          </a>\r\n          <img class=\"topnews-img\" src=\"images/index_topnews/20230209/news_caretex-tokyo2023_image.png\" alt=\"トップニュース画像\">\r\n\r\n          <a href=\"images/news/20230328_news/news_caretex-tokyo2023_after04.png\" data-lightbox=\"ts_pw_bannar\">\r\n              <img id=\"bannar\" src=\"images/index_topnews/20230328/news_caretex-tokyo2023_after04_thumbnail.png\" style=\"margin-top:10px;\">\r\n          </a>\r\n\r\n          HCRバナー\r\n          <div class=\"image-area\">\r\n            <img class src=\"images/index_topnews/20240909/hcr2024_banner_728.png\" alt=\"国際福祉機器展バナー\">\r\n          </div>\r\n          <div class=\"image-area-responsive\">\r\n            <img class src=\"images/index_topnews/20240909/hcr2024_banner_300.png\" alt=\"国際福祉機器展バナー\">\r\n          </div>\r\n\r\n          HCR出展しました用\r\n          <div class=\"image-area\">\r\n            <a href=\"images/index_topnews/20241010/news_hcr2024_close01.png\" data-lightbox=\"ts_pw_bannar\">\r\n              <img class=\"topnews-img\" src=\"images/index_topnews/20241010/news_hcr2024_close01_thumbnail.png\" style=\"margin-top:10px;\">\r\n            </a>\r\n            <a href=\"images/index_topnews/20241010/news_hcr2024_close02.png\" data-lightbox=\"ts_pw_bannar\">\r\n              <img class=\"topnews-img\" src=\"images/index_topnews/20241010/news_hcr2024_close02_thumbnail.png\" style=\"margin-top:10px;\">\r\n            </a>\r\n            <a href=\"images/index_topnews/20241010/news_hcr2024_close03.png\" data-lightbox=\"ts_pw_bannar\">\r\n              <img class=\"topnews-img\" src=\"images/index_topnews/20241010/news_hcr2024_close03_thumbnail.png\" style=\"margin-top:10px;\">\r\n            </a>\r\n            <a href=\"images/index_topnews/20241010/news_hcr2024_close04.png\" data-lightbox=\"ts_pw_bannar\">\r\n              <img class=\"topnews-img\" src=\"images/index_topnews/20241010/news_hcr2024_close04_thumbnail.png\" style=\"margin-top:10px;\">\r\n            </a>\r\n          </div>\r\n\r\n      -->\r\n\r\n    <section class=\"product_area\">\r\n      <div class=\"container\">\r\n        <h3 class=\"b_title\">PRODUCT</h3>\r\n        <h4 class=\"b_title_2\">製品紹介</h4>\r\n        <div class=\"product-item\">\r\n          <div class=\"itemWrap\">\r\n            <ul>\r\n              <li class=\"item_img\"><a href=\"product_soft.html\"><img src=\"images/product_img01.jpg\" alt=\"ソフトウェア\"></a>\r\n              </li>\r\n              <li class=\"item_name\">ソフトウェア</li>\r\n              <li class=\"more_btn\"><a href=\"product_soft.html\" class=\"btn-animation-02\"><span>詳しく見る</span></a></li>\r\n            </ul>\r\n          </div><!-- itemWrap -->\r\n          <div class=\"itemWrap\">\r\n            <ul>\r\n              <li class=\"item_img\"><a href=\"product_patientwatcher.html\"><img src=\"images/product_img02.jpg\"\r\n                    alt=\"ソフトウェア＆ハードウェア\"></a></li>\r\n              <li class=\"item_name\">ソフトウェア＆ハードウェア</li>\r\n              <li class=\"more_btn\"><a href=\"product_patientwatcher.html\" class=\"btn-animation-02\"><span>詳しく見る</span></a>\r\n              </li>\r\n            </ul>\r\n          </div><!-- itemWrap -->\r\n          <div class=\"itemWrap\">\r\n            <ul>\r\n              <li class=\"item_img\"><a href=\"product_hard.html\"><img src=\"images/product_img03.jpg\" alt=\"ハードウェア\"></a>\r\n              </li>\r\n              <li class=\"item_name\">ハードウェア</li>\r\n              <li class=\"more_btn\"><a href=\"product_hard.html\" class=\"btn-animation-02\"><span>詳しく見る</span></a></li>\r\n            </ul>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </section>\r\n\r\n    <section class=\"concept_area\">\r\n      <div class=\"container\">\r\n        <h3 class=\"b_title\">CONCEPT</h3>\r\n        <h4 class=\"b_title_2\">コンセプト</h4>\r\n        <p class=\"font-now\">\r\n          シンプルで使いやすく、あたらしいセンスに満ち、<br>すべての人がなんのストレスもなく暮らせること。<br>そのための製品を、サービスを、<br>今までにない発想と先進的な技術で\r\n          <span class=\"mob_blank\"><br></span>つくっていきます。\r\n        </p>\r\n      </div>\r\n    </section>\r\n\r\n    <section class=\"company_recruit\">\r\n      <div class=\"container\">\r\n        <div class=\"company_area col-md-6\">\r\n          <ul>\r\n            <li class=\"title_img\"><h3 class=\"b_title\">COMPANY</h3>\r\n              <h4 class=\"b_title_2\">企業概要</h4></li>\r\n            <li class=\"link_img\"><a href=\"company.html\"><img src=\"images/company_img.jpg\" alt=\"企業イメージ\"></a></li>\r\n            <li class=\"desc\">私たちの会社は社会に貢献することを目指しています。雇用も製品づくりもCSRも、社会に貢献し誰もが幸せになることを願って取り組んでいます。</li>\r\n          </ul>\r\n        </div><!-- /company_area -->\r\n        <div class=\"recruit_area col-md-6\">\r\n          <ul>\r\n            <li class=\"title_img\"><h3 class=\"b_title\">RECRUIT</h3>\r\n              <h4 class=\"b_title_2\">採用情報</h4></li>\r\n            <li class=\"link_img\"><a href=\"recruit.html\"><img src=\"images/recruit_img.jpg\" alt=\"採用情報イメージ\"></a></li>\r\n            <li class=\"desc\">私たちが手がけるサービス、それは社会に貢献するソリューションを創り広めていくこと。より高品質なサービス提供へ向けて、さまざまな経験・知識・個性を持った方々を広く求めています。\r\n            </li>\r\n          </ul>\r\n        </div><!-- /recruit_area -->\r\n      </div><!-- /container -->\r\n    </section><!-- /company_recruit -->\r\n\r\n    <section class=\"contact_area\">\r\n      <div class=\"container\">\r\n        <h3 class=\"b_title\">CONTACT</h3>\r\n        <h4 class=\"b_title_2\">お問い合わせ</h4>\r\n        <p>サービスや製品に関するご質問・資料請求は、<span class=\"mob_blank\"><br></span>以下よりご連絡ください。</p>\r\n        <a href=\"contact.html\" class=\"btn-animation-04\"><span>お問い合わせフォーム</span></a>\r\n      </div><!-- /container -->\r\n    </section><!-- /contact_area -->\r\n  </div><!-- /main_content -->\r\n\r\n  <!-- フッタ -->\r\n  <script type=\"text/javascript\">footer();</script>\r\n\r\n  <!-- ページの先頭へ戻るボタン -->\r\n  <p id=\"pageTop\"><a href=\"#\"><img src=\"images/page_top.png\"></a></p>\r\n</body>\r\n\r\n</html>","finalUrl":"https://www.alco-ex.jp/","rendered":false,"_cachedAt":"2026-06-17T22:59:34.794Z"}