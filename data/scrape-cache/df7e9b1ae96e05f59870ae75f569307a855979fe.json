{"url":"https://www.acsc.co.jp/recruit/new_graduate.html","html":"<!DOCTYPE html>\r\n<html lang=\"ja\">\r\n<head>\r\n<meta charset=\"UTF-8\">\r\n<title>採用情報｜ACS 株式会社 青森電子計算センター</title>\r\n<meta name=\"description\" content=\"\">\r\n<meta name=\"keywords\" content=\"\">\r\n\r\n<!--Require Mobile-->\r\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n<meta name=\"apple-mobile-web-app-capable\" content=\"yes\">\r\n\r\n<!--Require Stylesheet-->\r\n<link rel=\"stylesheet\" href=\"../css/base.css\">\r\n<link rel=\"stylesheet\" href=\"../css/acs.css\">\r\n<link rel=\"shortcut icon\" href=\"../images/favicon.ico\">\r\n<link rel=\"apple-touch-icon\" href=\"../images/apple-touch-icon.png\"/>\r\n\r\n\r\n<script src=\"../js/jquery-1.11.1.min.js\"></script>\r\n<script>\r\nwindow.jQuery || document.write('<script type=\"text/javascript\" src=\"jquery-1.11.1.min.js\"><\\/script>');\r\n</script>\r\n\r\n<script>\r\n  (function(i,s,o,g,r,a,m){i['GoogleAnalyticsObject']=r;i[r]=i[r]||function(){\r\n  (i[r].q=i[r].q||[]).push(arguments)},i[r].l=1*new Date();a=s.createElement(o),\r\n  m=s.getElementsByTagName(o)[0];a.async=1;a.src=g;m.parentNode.insertBefore(a,m)\r\n  })(window,document,'script','//www.google-analytics.com/analytics.js','ga');\r\n\r\n  ga('create', 'UA-64157168-1', 'auto');\r\n  ga('send', 'pageview');\r\n\r\n</script>\r\n\r\n<script>\r\n// 印刷倍率を80%にする(edge、chromはOK、filefoxは効かない)\r\nfunction addPrintCSS() {\r\n    // 新しいスタイル要素を作成\r\n    var style = document.createElement('style');\r\n    style.type = 'text/css';\r\n    style.media = 'print';\r\n\r\n    // CSSルールを追加\r\n    var cssText = 'body { zoom: 0.8; }';\r\n    if (style.styleSheet) {\r\n        // IEの場合\r\n        style.styleSheet.cssText = cssText;\r\n    } else {\r\n        // それ以外のブラウザの場合\r\n        style.appendChild(document.createTextNode(cssText));\r\n    }\r\n\r\n    // スタイル要素を<head>に追加\r\n    document.getElementsByTagName('head')[0].appendChild(style);\r\n}\r\n\r\n// 引数のclass(printableArea)で囲まれたエリアのみ印刷する\r\nfunction printDiv(className) {\r\n  var elements = document.getElementsByClassName(className);\r\n  \r\n  // 印刷しない要素(お問い合わせ)を一時的に非表示にする\r\n  var noPrintElements = document.getElementsByClassName('inq');\r\n  for (var i = 0; i < noPrintElements.length; i++) {\r\n    noPrintElements[i].style.display = 'none';\r\n  }\r\n  \r\n  var printContents = \"\";\r\n  for (var i = 0; i < elements.length; i++) {\r\n    printContents += elements[i].innerHTML;\r\n  }\r\n  var originalContents = document.body.innerHTML;\r\n\r\n  document.body.innerHTML = printContents;\r\n  \r\n  // 印刷倍率を80%にする\r\n  addPrintCSS();\r\n\r\n  window.print();\r\n\r\n  document.body.innerHTML = originalContents;\r\n\r\n  // 印刷しない要素を再表示する\r\n  for (var i = 0; i < noPrintElements.length; i++) {\r\n    noPrintElements[i].style.display = '';\r\n  }\r\n}\r\n</script>\r\n</head>\r\n\r\n<body>\r\n<div id=\"wrapper\">\r\n  <div class=\"printableArea\">\r\n    <header role=\"banner\" id=\"header\">\r\n        <h1 class=\"logo\"><a href=\"../index.html\">ACS 株式会社 青森電子計算センター</a></h1>\r\n        <span class=\"button menu-button-right\"></span>\r\n        <p class=\"inq\"><a href=\"../contact.html\">ご質問・お問い合わせ</a></p>\r\n    </header>\r\n  </div><!-- / .printableArea -->\r\n\r\n    <nav id=\"headnav\" role=\"navigation\">\r\n        <ul>\r\n            <li class=\"n00\"><a href=\"../index.html\">ホーム<span>HOME</span></a></li><li class=\"n01\"><a href=\"../information.html\">お知らせ<span>INFORMATION</span></a></li><li class=\"n02\"><a href=\"../service.html\">事業内容<span>SERVICE</span></a></li><li class=\"n03\"><a href=\"../recruit.html\">採用情報<span>RECRUIT</span></a></li><li class=\"n04\"><a href=\"../company.html\">会社案内<span>COMPANY PROFILE</span></a></li>\r\n        </ul>\r\n    </nav>\r\n\r\n<main role=\"main\" id=\"main\">\r\n\r\n<div class=\"main-right\">\r\n\r\n    <div class=\"breadcrumbs\">\r\n        <ul>\r\n            <li><a href=\"../index.html\">トップページ</a></li>\r\n            <li><a href=\"../recruit.html\">採用情報</a></li>\r\n            <li><a href=\"../recruit.html\">募集内容</a></li>\r\n            <li>新卒採用</li>\r\n        </ul>\r\n    </div><!--/.breadcrumbs-->\r\n    \r\n    <span class=\"print-text\" onclick=\"printDiv('printableArea')\">印刷する</span>\r\n    <img src=\"../images/printer.png\" alt=\"印刷する\" onclick=\"printDiv('printableArea')\" class=\"print-icon\">\r\n    \r\n    <div class=\"printableArea\">\r\n    <h1 class=\"title\">新卒採用</h1>\r\n    </div><!-- / .printableArea -->\r\n    <article>\r\n        <div>\r\n            <img src=\"../images/recruit.jpg\" alt=\"採用情報\" style=\"margin-bottom:1em\">\r\n            <h2 id=\"recruit\">地域に根差し、地域と共に発展する、地域ナンバーワンの企業を目指して<br>『ITで青森県を盛り上げていく、地域に貢献できる仲間を探しています』</h2>\r\n        </div>\r\n        <div class=\"bn\">\r\n            <a href=\"../anniversary.html\"><img src=\"../images/l_LOVE_ACS.jpg\" alt=\"I LOVE ACS\"></a>\r\n<!--            <a href=\"../anniversary.html\"><img src=\"../images/anniversary.jpg\" alt=\"おかげさまで55周年\"></a> -->\r\n        </div>\r\n\r\n        <div class=\"printableArea\">\r\n        <table>\r\n            <tr><th>募集職種</th>\r\n                <td>総合職<br>\r\n                    <ol style=\"list-style-type: decimal\">\r\n                        <li>コンピュータ技術職<br>（システムエンジニア、プログラマー他）<br>※<a href=\"regulation.html\">就業内容</a>へ記載有り</li>\r\n                        <li>営業職</li>\r\n                        <li>総務職</li>\r\n                    </ol>\r\n                </td>\r\n            </tr>\r\n            <tr><th>募集人数</th>\r\n                <td>2027年3月迄に大学、大学院、高専、短大、各種学校を卒業（修了）見込の方（既卒可）<br>学校・学部・学科不問　………　約5名</td>\r\n            </tr>\r\n            <tr><th>応募書類</th>\r\n                <td><ol style=\"list-style-type: decimal\">\r\n                        <li>履歴書</li>\r\n                        <li>卒業見込証明書</li>\r\n                        <li>成績証明書</li>\r\n                        <li>個人情報の取扱いに関する同意書（署名捺印したもの）\r\n                            <p class=\"down\"><a href=\"../files/個人情報の取扱いに関する同意書.pdf\" target=\"_blank\">個人情報の取扱いに関する同意書(採用応募者用)</a></p>\r\n                        </li>\r\n                    </ol>\r\n                    <p>※専門学校卒業見込みの方は、情報処理技術者資格の取得を希望します。</p>\r\n                </td>\r\n            </tr>\r\n            <tr><th>応募書類<br/>提出期間</th>\r\n               <td><strong style=\"color:red;\">随時対応いたしますので、お問い合わせください。</strong></td>\r\n            </tr>\r\n            <tr><th>提出先</th>\r\n                <td><p>上記応募書類を本社　経営管理本部　総務部宛に郵送してください。</p>\r\n                    <div style=\"font-weight:bold\">〒038-0031　青森市大字三内字丸山393番地270<br>株式会社　青森電子計算センター　経営管理本部　総務部　採用担当者</div>\r\n                </td>\r\n            </tr>\r\n            <tr><th>選考内容</th>\r\n                <td><dl><dt>1.書類選考</dt>\r\n                        <dd>応募書類にて実施（筆記試験前に応募者全員に選考結果をお知らせ致します）</dd>\r\n                        <dt>2.筆記試験・面接<small>（一般常識、適正・性格検査、自己紹介カード）</small></dt>\r\n                        <dd>会場等詳細は書類選考通過者に別途連絡致します。</dd>                      \r\n                    </dl>\r\n                </td>\r\n            </tr>\r\n            <tr><th>お問い合わせ<br/>連絡担当</th>\r\n                <td><p>経営管理本部　総務部　採用担当：工藤</p>\r\n                    <p>&#9742;017-761-5300　FAX：017-761-5310</p>\r\n                    <p>&#9993;&nbsp;<img class=\"mail\" src=\"../images/mail_soumu.png\" alt=\"経営管理本部　総務部\"></p>\r\n                </td>\r\n            </tr>\r\n        </table>\r\n        </div><!-- / .printableArea -->\r\n    </article>\r\n    <div class=\"printableArea\">\r\n    <article>\r\n        <h2>応募に際しての留意事項</h2>\r\n        <ul>\r\n            <li>応募に関する応募者の情報、及び秘密は厳守します。</li>\r\n            <li>応募書類は、弊社規定に沿って細心の注意を払って適切に管理致します。なお、応募書類の返却はいたしません。（弊社規定により適切に破棄致します。）</li>\r\n            <li>ご応募頂いた個人情報は、採用業務以外の目的で利用することはありません。</li>\r\n            <li>応募者ご本人様は、ご応募頂いた個人情報の内容確認や訂正又は削除を要求する権利を有します。当該権利を行使される場合は、本人確認の為の身分証明書等を持参し弊社経営管理本部までご来社ください。なお、電話や電子メール等では受付を致しかねますのでご了承ください。</li>\r\n        </ul>\r\n    </article>\r\n    </div><!-- / .printableArea -->\r\n\r\n</div><!-- / .right -->\r\n\r\n    <div class=\"main-left\">\r\n        <div class=\"submenu\">\r\n            <h2>採用情報</h2>\r\n            <ul>\r\n                <li><a href=\"../recruit.html\">募集内容</a>\r\n                    <ul>\r\n                        <li><a href=\"new_graduate.html\">新卒採用</a></li>\r\n                        <li><a href=\"mid-career.html\">中途採用</a></li>\r\n                    </ul>\r\n                </li>\r\n                <li><a href=\"regulation.html\">就業内容</a></li>\r\n            </ul>\r\n        </div>\r\n        <div class=\"add box\">\r\n            <h2>お問い合わせ</h2>\r\n            <p>本社事務所<br>青森市大字三内字丸山393番地270</p>\r\n            <p class=\"tel\">&#9742;<span class=\"tel-link\">017-761-5300</span></p>\r\n            <p>（平日9:00~17:00）</p>\r\n        </div>\r\n        <div class=\"bn\">\r\n            <a href=\"../package/macs_office.html\"><img src=\"../images/bn_macs_office.png\" alt=\"mACS Office\"></a>\r\n            <a href=\"../package/macs_hanbai.html\"><img src=\"../images/bn_macs_hanbai.png\" alt=\"mACS 販売\"></a>\r\n        </div>\r\n    </div><!--/.left-->\r\n\r\n</main>\r\n\r\n\r\n<footer role=\"contentinfo\" id=\"footer\">\r\n\r\n<div class=\"footnav\">\r\n    <div class=\"inner\">\r\n        <p class=\"sitemap\"><a href=\"../certification/pmark.html#privacy_policy\">個人情報保護方針</a>　 | 　<a href=\"../certification/privacy.html\">個人情報の取扱いについて</a>　 | 　<a href=\"../about.html\">当サイトについて</a>　｜　<a href=\"../sitemap.html\">サイトマップ</a>　｜　<a href=\"../link.html\">リンク</a></p>\r\n        <p class=\"page-top\" id=\"page-top\"><a href=\"#\">PAGE TOP</a></p>\r\n    </div>\r\n</div>\r\n\r\n<div class=\"inner\">\r\n        <h2 class=\"logo\"><a href=\"../index.html\">ACS 株式会社 青森電子計算センター</a></h2>\r\n    <div class=\"col_4\">\r\n        <dl class=\"address\">\r\n            <dt>本社事務所</dt><dd>&#9742;017-761-5300　〒038-0031　青森市三内丸山393-270</dd>\r\n            <dt>本社分室</dt><dd>&#9742;017-735-1440　〒030-0801　青森市新町二丁目5番1号　角弘ビル</dd>\r\n            <dt>八戸支店</dt><dd>&#974