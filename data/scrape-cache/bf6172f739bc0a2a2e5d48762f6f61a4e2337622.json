"./service.html\">サービス</a></li>\n              <li><a href=\"./company.html\">企業情報</a></li>\n              <li><a href=\"./recruit/\">採用情報</a></li>\n              <li><a href=\"./contact/\">お問い合わせ</a></li>\n            </ul>\n            <ul class=\"sub\">\n              <li><a href=\"./privacy-policy.html\">プライバシーポリシー</a></li>\n              <li><a href=\"./security.html\">情報セキュリティーポリシー</a></li>\n            </ul>\n            <!-- <ul class=\"sns\">\n              <li><a href=\"https://www.facebook.com/Def-tribe-group%E6%A0%AA%E5%BC%8F%E4%BC%9A%E7%A4%BEDef-tribe-195375853971980/?ref=bookmarks\" target=\"_blank\"><img class=\"svg\" src=\"./assets/img/common/icon_fb.svg\" alt=\"\"></a></li>\n              <li><a href=\"https://twitter.com/def_tribe\" target=\"_blank\"><img class=\"svg\" src=\"./assets/img/common/icon_tw.svg\" alt=\"\"></a></li>\n              <li><a href=\"https://www.instagram.com/def_tribe/\" target=\"_blank\"><img class=\"svg\" src=\"./assets/img/common/icon_insta.svg\" alt=\"\"></a></li>\n            </ul> -->\n          </nav>\n        </div>\n      </div>\n      <div class=\"swiper\" id=\"panelWrap\">\n        <div class=\"swiper-wrapper\">\n          <section\n            class=\"panel swiper-slide\"\n            id=\"secAbout\"\n            data-section-name=\"about\"\n          >\n            <div class=\"inner\">\n              <div class=\"typo\">\n                <img\n                  src=\"./assets/img/top/zokuzoku01.png\"\n                  srcset=\"\n                    ./assets/img/top/zokuzoku01.png    1x,\n                    ./assets/img/top/zokuzoku01@2x.png 2x\n                  \"\n                  alt=\"族族\"\n                />\n              </div>\n              <div class=\"text\">\n                <div class=\"copy\">\n                  <p class=\"row\"><span>ゾクゾク</span></p>\n                  <p class=\"row\"><span>な</span></p>\n                  <p class=\"row\"><span>感動を</span></p>\n                </div>\n                <div class=\"btnArea\">\n                  <a class=\"btnStyle03\" href=\"./about.html\"\n                    >Def tribeについて</a\n                  >\n                </div>\n              </div>\n            </div>\n            <div class=\"bg_color bg_about\">\n              <div class=\"square01\"></div>\n              <div class=\"square02\"></div>\n              <div class=\"square03\">\n                <img src=\"./assets/img/top/img01.png\" /><img\n                  class=\"tab\"\n                  src=\"./assets/img/top/img01_v.png\"\n                />\n              </div>\n            </div>\n            <div class=\"btnScroll\">\n              <button type=\"button\">\n                <div class=\"en _cormorant\">SCROLL</div>\n                <div class=\"line\"><span></span></div>\n              </button>\n            </div>\n          </section>\n          <section\n            class=\"panel swiper-slide\"\n            id=\"secService\"\n            data-section-name=\"service\"\n          >\n            <div class=\"inner\">\n              <div class=\"typo\">\n                <img\n                  src=\"./assets/img/top/zokuzoku02.png\"\n                  srcset=\"\n                    ./assets/img/top/zokuzoku02.png    1x,\n                    ./assets/img/top/zokuzoku02@2x.png 2x\n                  \"\n                  alt=\"続続\"\n                />\n              </div>\n              <div class=\"textbox\">\n                <p class=\"en _cormorant\">SERVICE</p>\n                <h2 class=\"ttl\">\n                  変わり続ける時代に<br />最新で最高のシステムを\n                </h2>\n                <p>\n                  モバイルアプリ開発からIoT開発・AI開発・インフラ構築など、今後も発展し続ける「IT社会」。優れたセンス、無限に広がる発想力、幅広い企画力を駆使したシステム開発で、“ZOKUZOKU”する感動をお届けします。\n                </p>\n                <div class=\"btnArea\">\n                  <a class=\"btnStyle03\" href=\"./service.html\">サービス</a>\n                </div>\n              </div>\n              <div class=\"bg_color bg_service\">\n                <div class=\"square01\"></div>\n                <div class=\"square02 sp_size\">\n                  <img src=\"./assets/img/top/img02.png\" /><img\n                    class=\"tab\"\n                    src=\"./assets/img/top/img02_v.png\"\n                  />\n                </div>\n              </div>\n            </div>\n          </section>\n          <section\n            class=\"panel swiper-slide\"\n            id=\"secCompany\"\n            data-section-name=\"company\"\n          >\n            <div class=\"inner\">\n              <div class=\"typo\">\n                <img\n                  src=\"./assets/img/top/zokuzoku03.png\"\n                  srcset=\"\n                    ./assets/img/top/zokuzoku03.png    1x,\n                    ./assets/img/top/zokuzoku03@2x.png 2x\n                  \"\n                  alt=\"束束\"\n                />\n              </div>\n              <div class=\"textbox\">\n                <p class=\"en _cormorant\">COMPANY</p>\n                <h2 class=\"ttl\">高い結束力が<br />高いクオリティを生む</h2>\n                <p>\n                  Def\n                  tribeは、幅広いご依頼に高品質なサービスと技術で応えるプロエンジニア部族。仲間との高い結束力があるからこそ、どんな要望も形にすることができます。そんな集団だからこその“ZOKUZOKU”する企画とアイデアをご提供します。\n                </p>\n                <div class=\"btnArea\">\n                  <a class=\"btnStyle03\" href=\"./company.html\">企業情報</a>\n                </div>\n              </div>\n              <div class=\"bg_color bg_company\">\n                <div class=\"square01\"></div>\n                <div class=\"square02\"></div>\n                <div class=\"square03\">\n                  <img src=\"./assets/img/top/img03.png\" /><img\n                    class=\"tab\"\n                    src=\"./assets/img/top/img03_v.png\"\n                  />\n                </div>\n              </div>\n            </div>\n          </section>\n          <section\n            class=\"panel swiper-slide\"\n            id=\"secRecruit\"\n            data-section-name=\"recruit\"\n          >\n            <div class=\"inner\">\n              <div class=\"typo\">\n                <img\n                  src=\"./assets/img/top/zokuzoku04.png\"\n                  srcset=\"\n                    ./assets/img/top/zokuzoku04.png    1x,\n                    ./assets/img/top/zokuzoku04@2x.png 2x\n                  \"\n                  alt=\"属属\"\n                />\n              </div>\n              <div class=\"textbox\">\n                <p class=\"en _cormorant\">RECRUIT</p>\n                <h2 class=\"ttl\">属して属さない<br />働き方を一緒に</h2>\n                <p>\n                  チャレンジ精神を武器に、今後もスタッフ全員で「新しいなにか」を作り出す企業。一人ひとりの能力が伸びる「枠にとらわれないスタイル」だから、自分にマッチした“ZOKUZOKU”できる働き方を見つけることができます。\n                </p>\n                <div class=\"btnArea\">\n                  <a class=\"btnStyle03\" href=\"./recruit/\">採用情報</a>\n                </div>\n              </div>\n              <div class=\"bg_color bg_recruit\">\n                <div class=\"square01\"></div>\n                <div class=\"square02\"></div>\n                <div class=\"square03\">\n                  <img src=\"./assets/img/top/img04.png\" /><img\n                    class=\"tab\"\n                    src=\"./assets/img/top/img04_v.png\"\n                  />\n                </div>\n              </div>\n            </div>\n          </section>\n        </div>\n        <div class=\"swiper-pagination\"></div>\n      </div>\n      <footer id=\"footer\">\n        <div class=\"inner\">\n          <div class=\"cta\">\n            <p class=\"ttl _cormorant\">CONTACT</p>\n            <p>\n              お仕事のご相談や、採用に関するご質問などお気軽にこちらからお問い合わせください。\n            </p>\n            <div class=\"btnArea\">\n              <a class=\"btnStyle01\" href=\"./contact/\">お問い合わせフォーム</a>\n            </div>\n          </div>\n          <div class=\"ftlink\">\n            <ul class=\"page\">\n              <li><a href=\"./about.html\">Def tribeについて</a></li>\n              <li><a href=\"