ervice/envelope/memoldar.html\" onclick=\"ga('send','event','slide','click','file_a', 1);\" target=\"_blank\" rel=\"noopener noreferrer\"><img class=\"sp-image\" src=\"images_n/slider-new/blank.gif\" data-src=\"images_n/slider-new/slide2_pc.png\" data-small=\"images_n/slider-new/slide2_sp.png\" data-large=\"images_n/slider-new/slide2_pc.png\" alt=\"メモルダー\"></a></div>\n\n        <div class=\"sp-slide\"><img class=\"sp-image\" src=\"images_n/slider-new/blank.gif\" data-src=\"images_n/slider-new/slide3_pc.png\" data-small=\"images_n/slider-new/slide3_sp.png\" data-large=\"images_n/slider-new/slide3_pc.png\" alt=\"包材集合\">\n          <!--<span class=\"sp-layer spno\" data-show-transition=\"up\" style=\"margin-left:10%;\">\n<img src=\"images_n/slider-new/slide_give_b_pc.png\">\n</span>\n<!--<span class=\"sp-layer spno\" data-show-transition=\"up\" style=\"margin-top:20%;margin-left:10%;color:white;\">\n私たちは次の100年もコミュニケーション分野において最高の付加価値を提供します。<br>そしてすべての人の笑顔に貢献します。\n</span>-->\n        </div>\n\n        <div class=\"sp-slide\"><img class=\"sp-image\" src=\"images_n/slider-new/blank.gif\" data-src=\"images_n/slider-new/slide4_pc.png\" data-small=\"images_n/slider-new/slide4_sp.png\" data-large=\"images_n/slider-new/slide4_pc.png\" alt=\"紙ロール\">\n          <!--<span class=\"sp-layer spno\" data-show-transition=\"up\" style=\"margin-left:10%;\">\n<img src=\"images_n/slider-new/slide_give_b_pc.png\">\n</span>\n<!--<span class=\"sp-layer spno\" data-show-transition=\"up\" style=\"margin-top:20%;margin-left:10%;color:white;\">\n私たちは次の100年もコミュニケーション分野において最高の付加価値を提供します。<br>そしてすべての人の笑顔に貢献します。\n</span>-->\n        </div>\n\n        <div class=\"sp-slide\"><img class=\"sp-image\" src=\"images_n/slider-new/blank.gif\" data-src=\"images_n/slider-new/slide5_pc.png\" data-small=\"images_n/slider-new/slide5_sp.png\" data-large=\"images_n/slider-new/slide5_pc.png\" alt=\"Give&Give&Give\">\n          <!--<span class=\"sp-layer spno\" data-show-transition=\"up\" style=\"margin-left:10%;\">\n<img src=\"images_n/slider-new/slide_give_b_pc.png\">\n</span>\n<!--<span class=\"sp-layer spno\" data-show-transition=\"up\" style=\"margin-top:30%;margin-left:10%;color:white;\">\n私たちは次の100年もコミュニケーション分野において最高の付加価値を提供します。<br>そしてすべての人の笑顔に貢献します。\n</span>-->\n        </div>\n\n        <div class=\"sp-slide\"><img class=\"sp-image\" src=\"images_n/slider-new/blank.gif\" data-src=\"images_n/slider-new/slide6_pc.png\" data-small=\"images_n/slider-new/slide6_sp.png\" data-large=\"images_n/slider-new/slide6_pc.png\" alt=\"大阪本社ビル\">>\n          <!--<span class=\"sp-layer spno\" data-show-transition=\"up\" style=\"margin-left:10%;\">\n<img src=\"images_n/slider-new/slide_give_w_pc.png\">\n</span>\n<!--<span class=\"sp-layer spno\" data-show-transition=\"up\" style=\"margin-top:20%;margin-left:10%;color:white;\">\n私たちは次の100年もコミュニケーション分野において最高の付加価値を提供します。<br>そしてすべての人の笑顔に貢献します。\n</span>-->\n        </div>\n      </div>\n    </div>\n    <!-- スライダ -->\n\n    <!-- ABOUT -->\n    <section class=\"index-about-section\" id=\"about\">\n      <header class=\"index-about-lead-wrapper\">\n        <h2>\n          <small>イムラの仕事</small>\n          <span>ABOUT IMURA</span>\n          <a href=\"/about/index.html\">事業紹介を見る</a>\n        </h2>\n        <p>封筒メーカーとして培ってきたさまざまなノウハウで、<br class=\"hidden-xs\">\n          <span>パッケージソリューション</span>、<span>メーリング&amp;デジタルソリューション</span>を軸に、<br class=\"hidden-xs\">\n          長年の実績から業界をリードしています。</p>\n      </header><!-- /lead -->\n\n      <!-- main -->\n      <article class=\"index-about-main\">\n        <!-- primary -->\n        <div class=\"index-about-primary\">\n          <div class=\"about-inner\">\n            <h3><span>パッケージソリューション事業</span><small>PACKAGE SOLUTIONS</small></h3>\n            <p>当社が主力としているのが、オーダーメイドの封筒です。一社一社と話し合いの上で作られている封筒ですので同じ物はひとつとしてありません。<br>\n              ビジネス封筒からDM封筒、商品発送用袋までお客様が求めるあらゆるものをカタチにします。</p>\n            <div class=\"display-sp\">\n              <img src=\"images_n/index/about01-sp.jpg\" class=\"style-round\">\n            </div>\n\n            <a href=\"/about/index.html#envelope\" class=\"page_anchor\"></a>\n          </div>\n        </div><!-- /primary -->\n\n        <!-- secondary -->\n        <div class=\"index-about-secondary\">\n          <h3><span>メーリング&amp;デジタルソリューション事業</span><small>Mailing&amp;Digital Solutions</small></h3>\n\n          <div class=\"about-secondary-wrapper\">\n            <div class=\"about-secondary-thumb\">\n              <img src=\"images_n/index/about-thumb01.jpg\">\n            </div><!-- /inner-left -->\n\n            <div class=\"about-inner-wrapper\">\n\n              <div class=\"about-inner\">\n                <div class=\"about-thumb\"><img src=\"images_n/index/about-thumb-sp01.jpg\"></div>\n                <div class=\"about-body\">\n                  <h4>メーリングサービス</h4>\n                  <p>マーケティング、DMの企画から始まり、封筒製造、顧客リスト管理、内容物の手配、封入、発送、レスポンスデータの分析、ロジスティックサービスなど\n                    発送に関する全ての作業を一手に引き受けています。</p>\n                </div>\n                <a href=\"/about/index.html#mailing\" class=\"thumb-loader\"></a>\n              </div><!-- /メーリングサービス -->\n\n              <!--<div class=\"about-inner\">\n              <div class=\"about-thumb\"><img src=\"images_n/index/about-thumb-sp02.jpg\"></div>\n              <div class=\"about-body\">\n              <h4>ロジスティックサービス</h4>\n              <p>お客様からお預かりした大切な商品を、<br class=\"hidden-xs\">\n                真心込めて梱包し、お届けすることをモットーに。</p>\n              </div>\n              <a href=\"/about/index.html#logistic\" class=\"thumb-loader\"></a>\n            </div> /ロジスティックサービス -->\n\n              <div class=\"about-inner\">\n                <div class=\"about-thumb\"><img src=\"images_n/index/about-thumb-sp03.jpg\"></div>\n                <div class=\"about-body\">\n                  <h4>情報システム</h4>\n                  <p>今の時代に欠かせない情報インフラの整備、ノウハウ提供まで、<br class=\"hidden-xs\">\n                    トータルにサポートしています。</p>\n                </div>\n                <a href=\"/about/index.html#information\" class=\"thumb-loader\"></a>\n              </div><!-- /情報システム -->\n\n            </div><!-- /inner-wrapper -->\n          </div><!-- /inner-right -->\n        </div><!-- /secondary -->\n\n      </article><!-- /main -->\n\n    </section>\n    <!-- /ABOUT -->\n\n    <section class=\"index-rmitp\">\n      <div class=\"index-rmitp__leadblock\">\n        <p class=\"index-rmitp__heading\">\n          <small>イムラのサービス、全部見るなら</small>\n        </p>\n        <p>珍しい封筒のギミックや、コスト削減の方法まで。<br>イムラのサービスサイト「リミップ」で、イムラができること、全部お見せします。</p>\n      </div>\n      <div class=\"index-rmitp__inner\">\n\n        <div class=\"index-rmitp__firstblock\">\n          <div class=\"index-rmitp__imageblock\">\n            <img src=\"/images_n/index/img_rimitp_v2.png\" alt=\"\">\n            <div class=\"index-rmitp__imageblock-lead\">\n              <ul class=\"index-rmitp__keyword-list\">\n                <li>事例</li>\n                <li>サービス</li>\n                <li>知識</li>\n              </ul>\n              <p class=\"index-rmitp__heading\">\n                <span><img src=\"/images_n/index/logo_rimitp_v2.png\"></span>\n              </p>\n            </div>\n          </div>\n          <div class=\"index-rmitp__button\"><a href=\"https://service.imura.co.jp/\" target=\"_blank\"><span>イムラのサービス一覧へ</span></a></div>\n        </div>\n        <div class=\"index-rmitp__secondblock\">\n          <div class=\"index-rmitp__imageblock\">\n            <img src=\"/images_n/index/img_rimitp_v3.jpg\" alt=\"\">\n          </div>\n          <div class=\"index-rmitp__button\"><a href=\"https://service.imura.co.jp/service/envelope/kami-net.html\" target=\"_blank\"><span>紙Net封筒の詳細はこちら</span></a></div>\n\n        </div>\n        <!--\n          <div class=\"index-rmitp__contents\">\n            <div class=\"index-rmitp__db\"><img src=\"./images_n/index/icon-db.svg\" width=\"57\" height=\"72\">\n              <p>顧客DB</p>\n            </div>\n            <div class=\"index-rmitp__list\">\n              <div class=\"index-rmi