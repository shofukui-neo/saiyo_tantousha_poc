{"url":"http://www.imura.co.jp/index.html","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n\n<head prefix=\"og: http://ogp.me/ns# fb: http://ogp.me/ns/fb# website: http://ogp.me/ns/website#\">\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width\" />\n  <title>株式会社イムラ</title>\n  <meta name=\"Keywords\" content=\"イムラ,imura,封筒,封入,メーリング,発送代行\" />\n\n  <meta name=\"Description\" content=\"株式会社イムラは、「Give＆Give＆Give（全ての人に最高の付加価値を届け続ける）」を掲げ、時代のニーズの変化を確実にキャッチし、私どもにしか提案できない商品・技術・サービスを提供します。\" />\n\n  <meta name=\"format-detection\" content=\"telephone=no\" />\n  <meta property=\"og:type\" content=\"website\" />\n  <meta property=\"og:title\" content=\"株式会社イムラ\" />\n  <meta property=\"og:site_name\" content=\"株式会社イムラ\" />\n  <meta property=\"og:description\" content=\"株式会社イムラは、「Give＆Give＆Give（全ての人に最高の付加価値を届け続ける）」を掲げ、時代のニーズの変化を確実にキャッチし、私どもにしか提案できない商品・技術・サービスを提供します。\" />\n\n  <meta property=\"og:image\" content=\"/images_n/shared/og_image.png\" />\n<link rel=\"shortcut icon\" type=\"image/x-icon\" href=\"/favicon.ico\" />\n<link rel=\"apple-touch-icon\" href=\"/images_n/shared/apple_touch_icon.png\" />\n<link href=\"//fonts.googleapis.com/icon?family=Material+Icons\" rel=\"stylesheet\" />\n<link rel=\"stylesheet\" href=\"//fonts.googleapis.com/earlyaccess/notosansjapanese.css\" />\n<link rel=\"stylesheet\" href=\"/common_n/css/style.css?20200221\" />\n<script src=\"//code.jquery.com/jquery-2.2.4.min.js\"></script>\n<script src=\"/common_n/js/jquery.inview.min.js\"></script>\n<script src=\"/common_n/js/jquery-ui.min.js\"></script>\n<script src=\"/common_n/js/slick.min.js\"></script>\n<script src=\"/common_n/js/script.js\"></script>\n<script>\n    if ((navigator.userAgent.indexOf('iPhone') > 0) || navigator.userAgent.indexOf('iPod') > 0 || navigator.userAgent.indexOf('Android') > 0) {\n        document.write('<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">');\n    } else {\n        document.write('<meta name=\"viewport\" conte