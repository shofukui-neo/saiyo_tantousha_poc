{"url":"https://www.ooc.co.jp/recruit/mind/interview/01","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n<head>\n  <!-- Global site tag (gtag.js) - Google Analytics -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=UA-6049077-1\"></script>\n<script>\n    window.dataLayer = window.dataLayer || [];\n\n    function gtag() {\n        dataLayer.push(arguments);\n    }\n    gtag('js', new Date());\n\n    gtag('config', 'UA-6049077-1');\n</script>\n<!-- Google Analytics end -->\n<meta charset=\"UTF-8\">\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<meta name=\"format-detection\" content=\"email=no,telephone=no,address=no\">\n<link rel=\"icon\" type=\"image/png\" href=\"\">\n<link rel=\"apple-touch-icon\" href=\"\" sizes=\"180x180\">\n<link rel=\"shortcut icon\" href=\"\" type=\"image/x-icon\">\n<meta name=\"robots\" content=\"noindex,nofollow\" />\n\n  <title>社員インタビュー｜採用情報｜大阪有機化学工業株式会社</title>\n  <link rel=\"shortcut icon\" href=\"/common/img/favicon.ico\" />\n  <meta name=\"description\" content=\"大阪有機化学工業株式会社は塗料・インキ・粘接着剤・電子材料部材等の樹脂原料として幅広い産業分野で使用されるアクリル酸エステルを研究開発しています。\" />\n  <meta name=\"keywords\" content=\"新卒採用,就職,求人\" />\n  <meta name=\"format-detection\" content=\"telephone=no\">\n\n  <!-- OGP -->\n  <meta property=\"og:title\" content=\"大阪有機化学工業株式会社 : アクリル酸エステルの総合メーカー\" />\n  <meta property=\"og:type\" content=\"company\" />\n  <meta property=\"og:url\" content=\"https://www.ooc.co.jp\" />\n  <meta property=\"og:image\" content=\"/common/img/thumb_fb.gif\" />\n  <meta property=\"og:site_name\" content=\"大阪有機化学工業株式会社\" />\n  <meta property=\"og:description\" content=\"大阪有機化学工業株式会社は塗料・インキ・粘接着剤・電子材料部材等の樹脂原料として幅広い産業分野で使用されるアクリル酸エステルを研究開発しています。\" />\n\n  <!-- Twitter OGP -->\n  <meta name=\"twitter:card\" content=\"summary_large_image\" />\n\n  <!-- css,js -->\n  <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n<link href=\"https://fonts.googleapis.com/css2?family=Barlow:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&family=Noto+Sans+JP:wght@100..900&family=Zen+Old+Mincho:wght@400;500;600;700;900&display=swap\" rel=\"stylesheet\">\n<link rel=\"stylesheet\" href=\"../../../css/style.css\">\n<script src=\"../../../js/common.js\"></script>\n<link rel=\"stylesheet\" href=\"../../../css/swiper-bundle.css\">\n<link rel=\"stylesheet\" href=\"../../../css/aos.css\">\n<script src=\"../../../js/swiper-bundle.min.js\"></script>\n<script src=\"../../../js/aos.js\"></script>\n  <link rel=\"stylesheet\" href=\"../../../css/swiper-bundle.css\">\n  <script src=\"../../../js/swiper-bundle.min.js\"></script>\n</head>\n<body>\n  \n<header class=\"l-header p-header\">\n  <div class=\"p-header_logo\"><a href=\"../../../\"><img src=\"../../../img/logo.png\" alt=\"「特殊アクリル酸エステル」のリーディングカンパニー 大阪有機化学工業株式会社\"></a></div>\n  <nav id=\"nav\" class=\"p-nav\">\n    <ul class=\"p-nav_list\">\n      <li class=\"p-nav_item\"><a href=\"../../../\">採用トップ</a></li>\n      <li class=\"p-nav_item\">\n        <a class=\"arrow\" href=\"../../../mind\">想いを知る</a>\n        <ul class=\"p-dropdown-content\">\n          <li><a href=\"../../../mind/\">コーナートップ</a></li>\n          <li><a href=\"../../../mind/ooc_way\">プロジェクトストーリー</a></li>\n          <li><a href=\"../../../mind/interview/01\">社員インタビュー</a></li>\n        </ul>\n      </li>\n      <li class=\"p-nav_item\">\n        <a class=\"arrow\" href=\"../../../job\">仕事を知る</a>\n        <ul class=\"p-dropdown-content\">\n          <li><a href=\"../../../job/\">コーナートップ</a></li>\n          <li><a href=\"../../../job/welfare\">福利厚生・教育制度</a></li>\n          <li><a href=\"../../../job/challenge\">挑戦しやすい風土</a></li>\n          <li><a href=\"../../../job/role_model\">キャリアロールモデル</a></li>\n        </ul>\n      </li>\n      <li class=\"p-nav_item\"><a href=\"../../../about\">OOCを知る</a></li>\n      <li class=\"p-nav_item\">\n        <a class=\"arrow\" href=\"../../../employment\">採用情報</a>\n        <ul class=\"p-dropdown-content\">\n          <li><a href=\"../../../employment/\">コーナートップ</a></li>\n          <li><a href=\"../../../employment/new/01/\">新卒採用</a></li>\n          <li><a href=\"../../../employment/career/01/\">キャリア採用</a></li>\n        </ul>\n      </li>\n    </ul>\n    <div class=\"p-nav_entry\"><a href=\"../../../entry\">ENTRY</a></div>\n    <div class=\"p-nav_sub_link\">\n      <ul>\n        <li><a href=\"/\" target=\"_blank\">コーポレートサイト</a></li>\n        <li><a href=\"/privacy\">個人情報保護方針</a></li>\n      </ul>\n    </div>\n  </nav>\n  <div class=\"p-hamburger\" id=\"hamburger\">\n    <div class=\"p-hamburger__line\"></div>\n    <div class=\"p-hamburger__line\"></div>\n    <div class=\"p-hamburger__line\"></div>\n  </div>\n</header>\n  <main>\n    <div class=\"p-bread_crumbs\">\n      <div class=\"l-container01\">\n        <div class=\"p-bread_crumbs_inner\">\n          <span class=\"p-bread_crumbs_sub\">想いを知る</span>\n          <span class=\"p-bread_crumbs_main\">社員インタビュー</span>\n        </div>\n      </div>\n    </div>\n    <div class=\"l-container01\">\n      <div class=\"p-single_top\">\n        <div class=\"p-row01\">\n          <div class=\"p-row01_col\" data-aos=\"fade-up\">\n            <div class=\"p-single_top_name\">\n              <p>\n                <span class=\"department\">金沢研究所 研究三課</span><br>\n                <span class=\"name\">D.S.</span>さん / 2016年入社\n              </p>\n            </div>\n            <h1 class=\"p-single_top_ttl\"><span>お題が難しければ<br>難しいほど、<br>プレッシャーがある。<br>ワクワクもある。</span></h1>\n          </div>\n          <div class=\"p-row01_col\" data-aos=\"fade-up\">\n            <div class=\"p-single_top_img\"><img src=\"img/top_img.png\" alt=\"D.S.さん / 2016年入社\"></div>\n          </div>\n        </div>\n      </div>\n      <div class=\"l-container02\">\n        <div class=\"p-single_question\">\n          <div class=\"p-single_question_item\" data-aos=\"fade-up\">\n            <p class=\"p-single_question_ttl\">-入社のきっかけは？</p>\n            <div class=\"p-text01\">\n              <p>もともと好奇心旺盛で、試行錯誤を繰り返すプロセスが好きなこともあり、理系の道に。大学では高分子化学を専攻し、ポリマーの立体規則性の制御について研究していました。就職活動では、自分の専門知識を活かせる仕事をしたいと考えており、大阪有機の事業内容が大学での研究と近かったため、入社を決めました。会社の規模がちょうどよく、個人のアイデアが研究に反映されやすく、ラボスケールからパイロットスケールまで一貫して担当できる環境があることも魅力的でした。</p>\n            </div>\n          </div>\n          <div class=\"p-single_question_item\" data-aos=\"fade-up\">\n            <p class=\"p-single_question_ttl\">-現在の仕事内容は？ やりがいは？</p>\n            <div class=\"p-text01\">\n              <p>半導体製造に使用されるフォトレジストの原料開発を担当しています。その中でも、お客様から依頼された原料をどのように合成し、スケールアップしていくかを検討・実行することが主な業務です。お客様からの要望も多種多様なため、これといった正解がある訳ではなく、様々な知識が必要になります。プレッシャーもありますが、難しいお題に向き合っている時間は正直楽しいですし、結果的に提案が採用され、生産立ち上げまで進んだときにはとても達成感があります。</p>\n            </div>\n          </div>\n          <div class=\"p-single_question_item\" data-aos=\"fade-up\">\n            <p class=\"p-single_question_ttl\">-仕事で大切にしていることは？</p>\n            <div class=\"p-text01\">\n              <p>他部署とのコミュニケーションを大切にしています。ラボスケールでの検討段階では、基本的に自部署内で完結することが多いのですが、開発ステージが進み、パイロットスケールや量産に移行する段階では、製造部や品質管理室など、他部署との連携が不可欠になります。様々な観点から問題がないか考える必要があるため、技術的な知識はもちろん、現場でしか得られない知見や自分ひとりでは対応できないこともあり、日々のコミュニケーションの重要性を強く感じています。今では、自らプラントに出向いて現場の状況を見たり聞いたりすることもあります。おしゃべりが好きな人も多く、研究部門に来て、雑談をしてお菓子を食べて帰る製造部の人もいます（笑）そんな時間も、意外と有意義だったりします。</p>\n            </div>\n          </div>\n          <div class=\"p-single_question_item\" data-aos=\"fade-up\">\n            <p class=\"p-single_question_ttl\">-こんなことに挑戦した！ 挑戦したい！ 私の「ゆうき」エピソード</p>\n            <div class=\"p-text01\">\n              <p>これまでの挑戦の一つとして、技術部門全員が参加する研究発表会でMVPを獲得したことがあります。発表したテーマの製品は惜しくもお客様の採用には至りませんでしたが、その過程で得た知見やアイデアが社内で高く評価されたことは、自分にとって大きな励みになりました。発表会では自らテーマを選定する必要があるため、日頃から「何を発表できるか？」という視点で業務に取り組むようになり、研究への向き合い方にも良い影響を与えてくれました。</p>\n            </div>\n          </div>\n          <div class=\"p-single_question_item\" data-aos=\"fade-up\">\n            <p class=\"p-single_question_ttl\">-OOCの強みは？ らしさは？</p>\n            <div class=\"p-text01\">\n              <p>若手であっても「やってみたい」という気持ちがあれば、周囲が積極的に後押ししてくれる社風だと思います。もちろん、挑戦には失敗もつきものですが、その経験を将来の糧として捉える文化があるので、安心してチャレンジできます。さらに、年々品質要求が高まる半導体材料においては、積極的な設備投資も行っており、前向きな社風と相まってか、お客様の要望に応える品質管理力もより一層向上しているように感じます。</p>\n            </div>\n          </div>\n        </div>\n        <div class=\"p-single_images\" data-aos=\"fade-up\">\n          <img src=\"img/img01.jpg\" alt=\"\">\n        </div>\n      </div>\n    </div>\n    <div class=\"p-single_schedule\">\n      <div class=\"l-container01\">\n        <h2 class=\"p-single_schedule_ttl\" data-aos=\"fade-up\">SCHEDULE</h2>\n        <div class=\"p-single_schedule_txt\" data-aos=\"fade-up\">\n          <span class=\"day\">ある1日の</span>\n          <span class=\"schedule\">スケジュール</span>\n          <!--<span class=\"aside\">※1直8:00‐15:00の場合</span>-->\n        </div>\n        <div class=\"p-row01\">\n          <div class=\"p-row01_col\" data-aos=\"fade-up\">\n            <div class=\"p-schedule_table\">\n              <dl>\n                <dt>9:00</dt>\n                <dd>出社、メールチェック</dd>\n              </dl>\n              <dl>\n                <dt>9:30</dt>\n                <dd>前日に測定した分析データの確認</dd>\n              </dl>\n              <dl>\n                <dt>10:00</dt>\n                <dd>サンプル合成のための反応仕込み</dd>\n              </dl>\n              <dl>\n                <dt>12:00</dt>\n                <dd>昼食</dd>\n              </dl>\n              <dl>\n                <dt>13:00</dt>\n                <dd>反応が完了したサンプルの後処理と精製</dd>\n              </dl>\n              <dl>\n                <dt>16:00</dt>\n                <dd>チームメンバーと各テーマの進捗状況の確認</dd>\n              </dl>\n              <dl>\n                <dt>17:00</dt>\n                <dd>合成したサンプルの分析（測定予約して夜間に測定）</dd>\n              </dl>\n              <dl>\n                <dt>18:00</dt>\n                <dd>次の日に使用する実験器具の準備・組み立て</dd>\n              </dl>\n              <dl>\n                <dt>19:00</dt>\n                <dd>退社</dd>\n              </dl>\n            </div>\n          </div>\n          <div class=\"p-row01_col\" data-aos=\"fade-up\">\n            <div class=\"p-single_schedule_img\">\n              <figure><img src=\"img/schedule_img.png\" alt=\"\"></figure>\n              <p>オフショット<br>「同僚と金沢城リレーマラソン」</p>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n    <div class=\"p-single_other\">\n  <div class=\"l-container01\">\n    <div class=\"c-ttl02 --center\" data-aos=\"fade-up\">\n      <span class=\"c-ttl02_main\">OTHER INTERVIEW</span>\n      <h2 class=\"c-ttl02_sub\">他社員のインタビュー</h2>\n    </div>\n  </div>\n  <div class=\"p-slider01\" data-aos=\"fade-up\">\n    <div class=\"l-container01\">\n      <div class=\"swiper\">\n        <div class=\"p-card01 swiper-wrapper\">\n          <div class=\"p-card01_item swiper-slide\">\n            <a href=\"../../../mind/interview/01\">\n              <div class=\"p-card01_item_img\">\n                <img src=\"../../../img/interview_img01.png\" alt=\"D.S.さん\">\n                <p>金沢研究所 研究三課<br>D.S.さん</p>\n              </div>\n              <div class=\"p-card01_item_cont\">\n                <h3 class=\"p-card01_item_ttl\">お題が難しければ難しいほど、プレッシャーがある。ワクワクもある。</h3>\n                <div class=\"p-card01_item_detail\">\n                  <span class=\"p-card01_item_cat\">研究部門</span>\n                  <ul class=\"p-card01_item_tags\">\n                    <li>#研究開発職</li>\n                    <li>#金沢研究所</li>\n                  </ul>\n                </div>\n              </div>\n            </a>\n          </div>\n          <div class=\"p-card01_item swiper-slide\">\n            <a href=\"../../../mind/interview/02\">\n              <div class=\"p-card01_item_img\">\n                <img src=\"../../../img/interview_img02.png\" alt=\"N.S.さん\">\n                <p>金沢研究所 研究二課<br>N.S.さん</p>\n              </div>\n              <div class=\"p-card01_item_cont\">\n                <h3 class=\"p-card01_item_ttl\">答えはすぐ言わない。目先の早さよりも、その先の成長に期待しているから。</h3>\n                <div class=\"p-card01_item_detail\">\n                  <span class=\"p-card01_item_cat\">研究部門</span>\n                  <ul class=\"p-card01_item_tags\">\n                    <li>#研究開発職</li>\n                    <li>#金沢研究所</li>\n                  </ul>\n                </div>\n              </div>\n            </a>\n          </div>\n          <div class=\"p-card01_item swiper-slide\">\n            <a href=\"../../../mind/interview/03\">\n              <div class=\"p-card01_item_img\">\n                <img src=\"../../../img/interview_img03.png\" alt=\"O.S.さん\">\n                <p>大阪研究所 研究一課<br>O.S.さん</p>\n              </div>\n              <div class=\"p-card01_item_cont\">\n                <h3 class=\"p-card01_item_ttl\">日々、向き合ってるのは、実験室の机ではなく、人です。</h3>\n                <div class=\"p-card01_item_detail\">\n                  <span class=\"p-card01_item_cat\">研究部門</span>\n                  <ul class=\"p-card01_item_tags\">\n                    <li>#研究開発職</li>\n                    <li>#大阪研究所</li>\n                  </ul>\n                </div>\n              </div>\n            </a>\n          </div>\n          <div class=\"p-card01_item swiper-slide\">\n            <a href=\"../../../mind/interview/04\">\n              <div class=\"p-card01_item_img\">\n                <img src=\"../../../img/interview_img04.png\" alt=\"T.Y.さん\">\n                <p>大阪研究所 研究一課<br>T.Y.さん</p>\n              </div>\n              <div class=\"p-card01_item_cont\">\n                <h3 class=\"p-card01_item_ttl\">挑戦することに、大きいも小さいも関係ない。</h3>\n                <div class=\"p-card01_item_detail\">\n                  <span class=\"p-card01_item_cat\">研究部門</span>\n                  <ul class=\"p-card01_item_tags\">\n                    <li>#研究開発職</li>\n                    <li>#大阪研究所</li>\n                  </ul>\n                </div>\n              </div>\n            </a>\n          </div>\n          <div class=\"p-card01_item swiper-slide\">\n            <a href=\"../../../mind/interview/05\">\n              <div class=\"p-card01_item_img\">\n                <img src=\"../../../img/interview_img05.png\" alt=\"I.T.さん\">\n                <p>金沢工場 製造三課<br>I.T.さん</p>\n              </div>\n              <div class=\"p-card01_item_cont\">\n                <h3 class=\"p-card01_item_ttl\">作業も考える時間も、なんでもかんでも早くするだけが、作業効率化ではない。</h3>\n                <div class=\"p-card01_item_detail\">\n                  <span class=\"p-card01_item_cat\">製造部門</span>\n                  <ul class=\"p-card01_item_tags\">\n                    <li>#プラントオペレーター職</li>\n                    <li>#金沢工場</li>\n                  </ul>\n                </div>\n              </div>\n            </a>\n          </div>\n          <div class=\"p-card01_item swiper-slide\">\n            <a href=\"../../../mind/interview/06\">\n              <div class=\"p-card01_item_img\">\n                <img src=\"../../../img/interview_img06.png\" alt=\"K.S.さん\">\n                <p>金沢工場 製造五課<br>K.S.さん</p>\n              </div>\n              <div class=\"p-card01_item_cont\">\n                <h3 class=\"p-card01_item_ttl\">学びって、勉強することと実践することで生まれる。</h3>\n                <div class=\"p-card01_item_detail\">\n                  <span class=\"p-card01_item_cat\">製造部門</span>\n                  <ul class=\"p-card01_item_tags\">\n                    <li>#プラントオペレーター職</li>\n                    <li>#金沢工場</li>\n                  </ul>\n                </div>\n              </div>\n            </a>\n          </div>\n          <div class=\"p-card01_item swiper-slide\">\n            <a href=\"../../../mind/interview/07\">\n              <div class=\"p-card01_item_img\">\n                <img src=\"../../../img/interview_img07.png\" alt=\"M.K.さん\">\n                <p>金沢工場 製造二課<br>M.K.さん</p>\n              </div>\n              <div class=\"p-card01_item_cont\">\n                <h3 class=\"p-card01_item_ttl\">ちょっとした機会にも成長の種はたくさんある。</h3>\n                <div class=\"p-card01_item_detail\">\n                  <span class=\"p-card01_item_cat\">製造部門</span>\n                  <ul class=\"p-card01_item_tags\">\n                    <li>#プラントオペレーター職</li>\n                    <li>#金沢工場</li>\n                  </ul>\n                </div>\n              </div>\n            </a>\n          </div>\n          <div class=\"p-card01_item swiper-slide\">\n            <a href=\"../../../mind/interview/08\">\n              <div class=\"p-card01_item_img\">\n                <img src=\"../../../img/interview_img08.png\" alt=\"N.T.さん\">\n                <p>金沢工場 製造二課<br>N.T.さん</p>\n              </div>\n              <div class=\"p-card01_item_cont\">\n                <h3 class=\"p-card01_item_ttl\">役に立てているという実感が、前へ前へと走らせてくれる。</h3>\n                <div class=\"p-card01_item_detail\">\n                  <span class=\"p-card01_item_cat\">製造部門</span>\n                  <ul class=\"p-card01_item_tags\">\n                    <li>#プラントオペレーター職</li>\n                    <li>#金沢工場</li>\n                  </ul>\n                </div>\n              </div>\n            </a>\n          </div>\n        </div>\n      </div>\n      <div class=\"swiper-button-prev\"></div>\n      <div class=\"swiper-button-next\"></div>\n    </div>\n  </div>\n</div>    <div class=\"p-information\" data-aos=\"fade-up\">\n      <div class=\"l-container01\">\n        <div class=\"p-btn p-information_entry\">\n          <div class=\"c-btn01\"><a href=\"../../../entry\">エントリーはこちら</a></div>\n        </div>\n        <div class=\"p-mynavi\">\n  <a href=\"https://job.mynavi.jp/27/pc/search/corp58074/outline.html\" target=\"_blank\">\n    <img src=\"../../../img/mynavi_2027.svg\" alt=\"マイナビ\">\n  </a>\n</div>      </div>\n    </div>\n  </main>\n  <div class=\"p-page_top js-page_top\"><span>PAGE TOP</span></div>\n<footer class=\"p-footer\">\n  <div class=\"p-footer_row\">\n    <div class=\"p-footer_col\">\n      <p class=\"p-footer_name\">大阪有機化学工業株式会社</p>\n      <ul>\n        <li><a href=\"/\" target=\"_blank\">コーポレートサイト</a></li>\n        <li><a href=\"/privacy\">個人情報保護方針</a></li>\n      </ul>\n    </div>\n    <div class=\"p-footer_col\">\n      <p class=\"p-footer_c_right\">© OSAKA ORGANIC CHEMICAL INDUSTRY</p>\n    </div>\n  </div>\n</footer>\n<script>\n  window.onload = function () {\n      AOS.init({\n          duration: 800,\n          once: true,\n      })\n  }\n</script>\n  <script src=\"../js/interview.js\"></script>\n</body>\n</html>\n","finalUrl":"https://www.ooc.co.jp/recruit/mind/interview/01/","rendered":false,"_cachedAt":"2026-06-22T17:25:59.857Z"}