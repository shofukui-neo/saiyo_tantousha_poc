{"url":"https://www.kinon.co.jp/recruit/interview-01.shtml","html":"<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\">\n<meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width\" />\n<meta name=\"format-detection\" content=\"telephone=no\">\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/common.css\" />\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/zone.css\" />\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/bpts.css\" />\n<!-- Basic parts -->\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/unit.css\" />\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/col.css\" />\n<!-- 本文領域レイアウタ -->\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/other.css\" />\n<!-- インタビュー用CSS -->\n<link rel=\"stylesheet\" type=\"text/css\" href=\"css/interview.css\" />\n<title>営業│社員の声│Recruit│キノンビクス株式会社</title>\n<style>\n.interview_fv {\n\tbackground-image: url(\"image/interview-01-00.jpg\");\n\tcolor: #fff;\n}\n#zone_substage h1 {\n\tfont-size: clamp(2.563rem, 0.767rem + 8.98vw, 7.5rem);\n\theight: auto;\n\tdisplay: block;\n\tpadding: 0;\n\tline-height: 1.5;\n\tfont-weight: normal;\n\tmargin: 1em 0 0 .5em;\n}\n@media screen and (max-width : 768px) {\n.interview_fv {\n\tbackground-position: center right;\n}\n\t}\n/*　PC表示時任意の場所で改行　*/\n.bpts_br_450::before {\n\tcontent: \"\\A\";\n\twhite-space: pre;\n}\n@media (max-width: 450px) {\n  /*　PC表示時任意の場所で改行をレスポンシブ時解除　*/\n  .bpts_br_450::before {\ndisplay: none;\n}\n}\n</style>\n<!-- スクリプトのインクルード（事前呼び出し） --> \n<meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\" />\n<link rel=\"icon\" href=\"../favicon.ico\">\n\n<!-- fontawesome -->\n<link href=\"https://use.fontawesome.com/releases/v5.6.1/css/all.css\" rel=\"stylesheet\">\n\n\n</head>\n<body>\n<div id=\"zone_sheet\"> \n  <!-- ヘッダーのインクルード --> \n  <meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\" />\n<!--\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/css/other.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/css/bpts.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/css/common.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/css/zone.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/css/unit.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/css/col.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/css/other.css\"/>\n -->\n<div class=\"header_bg\">\n<div class=\"header_logo\"><a href=\"../../\"><img src=\"../image/common/logo.svg\"></a></div>\n<nav class=\"pc_menu\">\n  <div class=\"o_mainmenu\">\n    <ul>\n      <li><a href=\"../about/\">About us</a>\n        <ul>\n          <li><a href=\"/about/index.shtml\">代表挨拶</a></li>\n          <li><a href=\"/about/overview.shtml\">会社概要</a></li>\n          <li><a href=\"/about/philosophy.shtml\">経営理念</a></li>\n          <li><a href=\"/about/promises.shtml\">7つのお約束</a></li>\n          <li><a href=\"/about/history.shtml\">沿革</a></li>\n          <li><a href=\"/about/employee.shtml\">社員保有資格一覧</a></li>\n          <li><a href=\"/about/certifications.shtml\">各種認定と宣言</a></li>\n        </ul>\n      </li>\n      <li><a href=\"../culture/\">Culture</a></li>\n      <li><a href=\"../solution/\">Solution</a>\n        <ul>\n          <li><a href=\"../solution/index.shtml#jump_01\">システムソリューション</a></li>\n          <li><a href=\"../solution/index.shtml#s_index_section02\">場所から探す</a></a></li>\n          <li><a href=\"../solution/index.shtml#s_index_section03\">納入事例</a></a></li>\n        </ul>\n      </li>\n      <li><a href=\"../recruit/\">Recruit</a>\n        <ul>\n          <li><a href=\"/recruit/\">採用情報</a></li>\n          <li><a href=\"/recruit/job.shtml\">職種紹介</a></li>\n          <li><a href=\"/recruit/interview.shtml\">社員インタビュー</a></li>\n          <li><a href=\"/recruit/requirements.shtml\">募集要項</a></li>\n        </ul>\n      </li>\n      <li><a href=\"../misc/contact.shtml\">Contact</a></li>\n    </ul>\n  </div>\n</nav>\n</div>\n<!-- レスポンシブメニュー　 -->\n<header>\n<div class=\"header-logo-menu\">\n<div id=\"nav-drawer\">\n<input id=\"nav-input\" type=\"checkbox\" class=\"nav-unshown\">\n<label id=\"nav-open\" for=\"nav-input\">\n<span></span>\n<p class=\"label_txt_menu\">MENU</p>\n</label>\n<label class=\"nav-unshown\" id=\"nav-close\" for=\"nav-input\"></label>\n<div id=\"nav-content\">\n<!--  ----------------- -->\n<div class=\"accordion\"> \n  <!-- menu1 -->\n  <div class=\"option\">\n    <input type=\"checkbox\" id=\"toggle1\" class=\"toggle\">\n    <label class=\"title item10\" for=\"toggle1\">About us</label>\n    <div class=\"content\">\n      <ul>\n        <li class=\"f_m10_10\"><a href=\"/about/index.shtml\">代表挨拶</a></li>\n        <li class=\"f_m10_20\"><a href=\"/about/overview.shtml\">会社概要</a></li>\n        <li class=\"f_m10_30\"><a href=\"/about/philosophy.shtml\">経営理念</a></li>\n        <li class=\"f_m10_40\"><a href=\"/about/promises.shtml\">7つのお約束</a></li>\n        <li class=\"f_m10_50\"><a href=\"/about/history.shtml\">沿革</a></li>\n        <li class=\"f_m10_60\"><a href=\"/about/employee.shtml\">社員保有資格一覧</a></li>\n        <li class=\"f_m10_70\"><a href=\"/about/certifications.shtml\">各種認定と宣言</a></li>\n      </ul>\n    </div>\n  </div>\n  <!-- menu2 -->\n  <div class=\"option\">\n    <div class=\"one_link\"><a href=\"../culture/\">Culture</a></div>\n  </div>\n  <!-- menu3 -->\n  <div class=\"option\">\n    <input type=\"checkbox\" id=\"toggle3\" class=\"toggle\">\n    <label class=\"title item50\" for=\"toggle3\">Solution</label>\n    <div class=\"content\">\n      <ul>\n        <li class=\"f_m30_10\"><a href=\"../solution/index.shtml#sp_jump_01\">システムソリューション</a></li>\n        <li class=\"f_m30_20\"><a href=\"../solution/index.shtml#jump_15\">場所から探す</a></a></li>\n        <li class=\"f_m30_30\"><a href=\"../solution/index.shtml#jump_02\">納入事例</a></a></li>\n      </ul>\n    </div>\n  </div>\n  <!-- menu4 -->\n  <div class=\"option\">\n    <input type=\"checkbox\" id=\"toggle4\" class=\"toggle\">\n    <label class=\"title item60\" for=\"toggle4\">Recruit</label>\n    <div class=\"content\">\n      <ul>\n        <li class=\"f_m40_10\"><a href=\"/recruit/\">採用情報</a></li>\n        <li class=\"f_m40_20\"><a href=\"/recruit/job.shtml\">職種紹介</a></li>\n        <li class=\"f_m40_30\"><a href=\"/recruit/interview.shtml\">社員インタビュー</a></li>\n        <li class=\"f_m40_40\"><a href=\"/recruit/requirements.shtml\">募集要項</a></li>\n      </ul>\n    </div>\n  </div>\n  <!-- menu5 -->\n  <div class=\"option\">\n    <div class=\"one_link\"><a href=\"../misc/contact.shtml\">Contact</a></div>\n  </div>\n<!-- menu6 -->\n  <div class=\"option\">\n    <div class=\"one_link\"><a href=\"../\">Home</a></div>\n  </div>\n</div alt=\"eod:accordion\">\n</header>\n<!-- --------------------------------------------------- --> \n\n \n  <!-- ヘッダーのインクルード 終わり　--> \n  \n  <!-- ステージ-->\n  <div id=\"zone_substage\">\n    <div>\n      <h1>Interview</h1>\n    </div>\n    <!--- パンくず -->\n    <ol class=\"zone_pankuzu\">\n      <li><a href=\"../\">HOME</a></li>\n      <li><a href=\"/recruit/\">Recruit</a></li>\n      <li><a href=\"/recruit/interview.shtml\">社員の声</a></li>\n      <li>営業</li>\n    </ol>\n    <!-- パンくず --> \n  </div alt=\"eod:zone_substage\">\n  <!-- ステージ　終わり --> \n  <!-- 第2層 -->\n  <div id=\"zone_middle_floor\"> \n    <!--　ボディ領域　-->\n    <div id=\"zone_body\"> \n      <!--　メインエリア　-->\n      <div id=\"zone_mainarea_1col\">\n        <div class=\"sp_padding\"> \n          \n          <!--　▼▼▼　本文領域　▼▼▼　-->\n          <div class=\"col_textarea_full\">\n            <div class=\"interview_fv\">\n              <div class=\"interview_fv-box\">\n                <h2>「本当に納得できる選択をしていただくために、<span class=\"bpts_br_450\"></span> 伝えるべきことを、誠実に伝える」</h2>\n                <p>京都支店　営業<span class=\"bpts_br\"></span>（教育ソリューションチーム）<br>\n                  30代　在職歴：8年</p>\n              </div>\n            </div>\n            <section id=\"interview_section01\">\n              <div class=\"l_overview_box\">\n                <p>お客様にとって、最良の選択とは何か。私は、メリットだけではなくデメリットも正直にお伝えすることを大切にしています。もちろん良い点もしっかりとご説明しますが、それだけではなく「予算を削ることで生じるリスク」や「この部分は含まれません」といった注意点も丁寧にお伝えするようにしています。人はネガティブな情報の方が記憶に残りやすく、案内不足は後々のトラブルにつながることもあります。「聞いていなかった」とか「もっと説明や説得をしてほしかった」と言われることが、営業にとって一番の失敗だと思いますし、最も避けたいことです。</p>\n                <p>お客様には、時に何百万、何千万という大きな金額を投資していただくことになるからこそ、後悔の無いご判断をしていただくことが何より重要です。リスクも含めて誠実に向き合うことで、信頼関係を築き、その後の良好なお付き合いにつなげていけると信じています。</p>\n              </div>\n              \n              <!-- 大見出し -->\n              <h2 class=\"col_midashi_pagetop\" data-en=\"About the Job\"> <span>業務について</span> </h2 alt=\"eod:col_midashi_pagetop\">\n              <ul>\n                <li>\n                  <h3><span><img src=\"image/no-01.svg\"></span>どのような業務を担当していますか？</h3>\n                  <p class=\"pad-left\">当社の営業は大きく『教育市場（学校）』と『民間企業（工場や法人など）』の2つの分野に分かれていて、私は教育市場のチームに所属しています。基本的には1人で複数のお客様を担当し、必要に応じて事務所から訪問に出向きます。<br>\n                    お客様にお困りごとがあって訪問する際は、基本的には提案をしつつ、雑談を交えながら時事ネタや冗談話をすることも多いです。ご予算や金額の話が関わってくることもあり、お客様からは切り出しにくい場合もあるので、こちらからさまざまなご提案をして、具体的なイメージを持っていただけるように導く。最終的な決定権はお客様にあるので、選択肢を多く提供することが大事かなと思います。<br>\n                    また、弊社では細かく分業をしており、技術チームやサービスチームと連携し、プロジェクトによっては4～5名で動くこともあります。工事が進行中のお客様とのやり取りは現場の担当者が行い、重要事項や書類対応は営業が引継ぎます。工事後も、不具合確認や次のご提案など、継続的なフォローを大切にしています。</p>\n                </li>\n                <li>\n                  <h3><span><img src=\"image/no-02.svg\"></span>やりがいを感じる瞬間や、印象に残っている出来事を教えてください</h3>\n                  <div class=\"bpts_flexbox_onoff justify flexbox\">\n                    <div>\n                      <p>お客様から「すごく良くなった」「先生も喜んでいたよ」といったお言葉をいただけたときが、やっぱり一番嬉しいです。</p>\n                      <p>当社の施工は専門性が高く、費用が膨大になることも少なくありません。だからこそ、現状よりもさらに良い状態に仕上げるのは当然の責任だと考えています。</p>\n                      <p>その中で、率直な感想を直接伝えていただけると強く心に残りますし、「この方のためにもっと頑張りたい」と自然に思えるのです。</p>\n                      <p>利益度外視で動きたくなるような、そんな信頼関係を築ける瞬間にこの仕事のやりがいを深く感じますし、今後もそうした関係をたくさん構築出来たら良いなと思います。</p>\n                    </div>\n                    <img src=\"image/interview-01-02.jpg\" alt=\"\"> </div>\n                </li>\n                <li>\n                  <h3><span><img src=\"image/no-03.svg\"></span>分業体制の中で意識していることや、難しさを感じる場面がありますか？</h3>\n                  <p class=\"pad-left\">社内の連携には難しさもあります。当社は分業体制をとっている分、境界線が曖昧になることも多く、担当業務の範囲に対する意識のズレが生まれやすいと感じています。そのため、社内でのコミュニケーションに苦労する場面も多いです。</p>\n                  <p class=\"pad-left\">社内連携がうまくいっていないと、結果的にお客様にご迷惑をおかけすることにもなりかねません。だからこそ、「まあ大丈夫だろう」と流さずに、気づいたことはすぐに伝えるようにしています。聞きたいこと、伝えたいことはその場でパッと共有する。そうすることで、後々のトラブルを未然に防げると常々実感しています。</p>\n                  <p class=\"pad-left\">もちろん、自分も含めて、皆が複数の案件を同時に進めている中で、指示や記憶が抜けてしまうこともありますし、采配の難しさを感じる場面もあります。それでも、そうした苦労を乗り越えて無事に完工できたときの達成感は格別です。内容が難しければ難しいほど、最後までやり遂げたときの喜びは大きいですね。 </p>\n                </li>\n                <li>\n                  <div class=\"bpts_flexbox_onoff justify flexbox rev\">\n                    <div class=\"wrap\">\n                      <h3><span><img src=\"image/no-04.svg\"></span><span>営業職として入社後、どのように業務を覚え、独り立ちしていくのでしょうか</span></h3>\n                      <p>入社後は、新規開拓を含めて他の業務にも取り組みながら、上司や先輩が担当していた既存のお客様を徐々に引き継いでいくのがスタンダードな流れです。まずはお客様に担当変更のご連絡を行い、メールや電話の主な連絡先を切り替えていただきます。</p>\n                      <p>その後はこれまで担当していた上司や先輩が横につき、お客様ごとの対応方法や書類作成の手順など、実務面でのレクチャーを受けます。ある程度業務に慣れてきた段階で、徐々に先輩方のフォローが減っていき、最終的には一人でお客様対応を任されるようになります。お客様にご迷惑はおかけできないので、1年ほどかけて丁寧な引継ぎが行われます。</p>\n                      <p>引き継ぎ後は、基本的に前任者のやり方を踏襲しつつ、過去の施工内容を踏まえて新たなご提案をしたり、お客様のご要望に応じてより良い方向へ導いたりします。この段階から個人の判断が求められますが、自発的に提案していくことが重要ですね。自分の個性や特色も活かして、お客様とどのように信頼関係も築いていくかは、それぞれの人のキャラクターに委ねられていると思います。 </p>\n                    </div>\n                    <img src=\"image/interview-01-01.jpg\" alt=\"\"> </div>\n                </li>\n              </ul>\n              \n              <!-- 大見出し -->\n              <h2 class=\"col_midashi_pagetop\" data-en=\"About KINONVICS\"> <span>キノンビクスについて</span> </h2 alt=\"eod:col_midashi_pagetop\">\n              <ul>\n                <li>\n                  <h3><span><img src=\"image/no-01.svg\"></span>社内の雰囲気や、周囲の人たちとの関係性について教えてください</h3>\n                  <div class=\"bpts_flexbox_onoff justify flexbox\">\n                    <p>明るく真面目、前向きな雰囲気です。いわゆる”職人肌”というか、その道を長年極めてきた、経験豊富なプロフェッショナルがたくさんいます。誰に聞いても自分が求めている答えが返ってくることが多いので、非常に心強いです。後輩の皆さんにも、ぜひ積極的に質問してほしいと思います。<br>\n                      また、違うチームの人でも、何か相談したからといって無下にされるようなことはありません。「こういうことをお願いしたい」「〇〇に困っている」といったことを相談すると、周囲が耳を傾けて手を差し伸べてくれます。学ぶ環境は十分に整っているので、意欲さえあればどんどん成長していける職場です。</p>\n                    <img src=\"image/interview-01-03.jpg\" alt=\"\"> </div>\n                </li>\n                <li>\n                  <h3><span><img src=\"image/no-02.svg\"></span>入社後に感じたギャップや”想定外”はありますか？</h3>\n                  <p class=\"pad-left\">入社してみて、思っていた以上に専門的な知識が必要だと感じました。普段の生活ではなかなか見えない部分が多く、私も映像や音響に関する知識が無かったので、目にするものすべてが新しいことでした。特に意外だったのは、理数系の要素が多いことです。私自身、これまでの人生であまり触れてこなかった分野だったので、いい意味でギャップを感じました。実際に、昔理科で習ったような電気の仕組みや、数学の公式のような「何×何＝こうなる」といった計算も出てきます。私もまだまだ勉強中ではありますが、入社してから少しずつ学びながら、身につけてきています。</p>\n                </li>\n                <li>\n                  <h3><span><img src=\"image/no-03.svg\"></span>福利厚生・社内制度について教えてください</h3>\n                  <p class=\"pad-left\">若手を中心に勉強会が開催されています。メーカーさんにも来ていただけるのですが、社内にもその道30年、40年、50年やってきた超ベテランの方がたくさんいますので、これまで培った経験や知識を活かして、下の子たちに自分で伝えるという場が不定期に開催されています。私も参加しているのですが、なかなか貴重な場だなと思いますね。 </p>\n                  <p class=\"pad-left\">毎年開催される社員旅行には、ほぼ毎回参加しています。最近では社員旅行を実施している会社も少なくなってきているかと思いますが、当社では城崎温泉など、さまざまな場所に出かけるので、なかなか珍しいのではないでしょうか。 </p>\n                  <p class=\"pad-left\">また、社員の家族も参加できる日帰り旅行もあります。慰労会や忘年会なども含めると、年間で4〜5回ほど社内イベントがありますので、社員同士の親睦を深める良い機会になっています。こうしたイベントでは、普段の仕事中とはまた違った一面が見られることもあり、チームの結束力が高まるように感じています。 </p>\n                </li>\n              </ul>\n              \n              <!-- 大見出し -->\n              <h2 class=\"col_midashi_pagetop\" data-en=\"Message\"> <span>入社・応募を考えている方へのメッセージ</span> </h2 alt=\"eod:col_midashi_pagetop\">\n              <ul>\n                <li>\n                  <div class=\"bpts_flexbox_onoff justify flexbox rev\">\n                    <div class=\"wrap\">\n                      <p>私自身、業界に関してまったくの素人状態で入社して先輩や上司の方々に育てていただきました。そのため、「未経験だから無理かもしれない」と心配する必要はありません。誰でも最初は初心者なので、やる気さえあればぜひチャレンジしてほしいです。</p>\n                      <p>当社では分業体制をとっているため、営業一人で完結する仕事はほとんどありません。特に営業チームは、他のチームに依頼をする場面が圧倒的に多く、チーム間の連携やコミュニケーション能力がとても重要です。</p>\n                      <p> 社内には経験豊富な先輩方や上司が多くいらっしゃいますが、そういった方々に対して、しっかりと礼儀や敬意を持って接する姿勢も大切です。自分本位な考え方では、業務を円滑に回すことはできません。</p>\n                      <p> 逆に言えば、社会人としての基本的なマナーや協調性を持ち、チームの一員として働く気持ちがあれば、未経験でもまったく問題ないのです。私も、そんな方にぜひ仲間になっていただきたいと思っています。</p>\n                    </div>\n                    <img src=\"image/interview-01-04.jpg\" alt=\"\" class=\"in01_img\"> </div>\n                </li>\n              </ul>\n            </section>\n            <section id=\"interview_section02\">\n              <h2>1日のスケジュール</h2>\n              <ul>\n                <li>\n                  <h3>8：30</h3>\n                  <div class=\"txt\">\n                    <p>出社<br>\n                      本日の行動予定やメールの確認、対応 </p>\n                  </div>\n                </li>\n                <li>\n                  <h3>9:00</h3>\n                  <div class=\"txt\">\n                    <p>外出<br>\n                      お客様との約束があれば事務所から出発 </p>\n                  </div>\n                </li>\n                <li>\n                  <h3>12:00</h3>\n                  <div class=\"txt\">\n                    <p>昼食</p>\n                  </div>\n                </li>\n                <li>\n                  <h3>15:00</h3>\n                  <div class=\"txt\">\n                    <p>帰社<br>\n                      提案準備、付随資料・見積書作成など事務処理</p>\n                  </div>\n                </li>\n                <li>\n                  <h3>17:30</h3>\n                  <div class=\"txt\">\n                    <p>退社</p>\n                  </div>\n                </li>\n              </ul>\n            </section>\n            <section id=\"interview_section03\">\n              <h2>その他INTERVIEW</h2>\n              <ul class=\"l_grid_interview_list\">\n                <!--  -->\n                <li class=\"support\"> <a href=\"interview-02.shtml\">\n                  <div>\n                    <p>京都支店　保守・サポート<span class=\"pre\">（京都サービスチーム）</span></p>\n                    <h5>“この先もずっと続けられる仕事を。”<br>\n                      夢を追いかけた先に見つけた、新しい働き方のかたち。</h5>\n                    <span> 20代　在職歴：半年</span> </div>\n                  </a> </li>\n                <!--  -->\n                <li class=\"se\"> <a href=\"interview-03.shtml\">\n                  <div>\n                    <p>本社　システムエンジニア<span class=\"pre\">（システムデザインチーム）</span></p>\n                    <h5>向いている、向いていないよりも、まずはやってみる。<em class=\"bpts_br_pc\"></em>迷いながらの一歩が自分を変えました。</h5>\n                    <span>40代　在職歴：2年半</span> </div>\n                  </a> </li>\n                <!--  -->\n                <li class=\"engineer\"> <a href=\"interview-04.shtml\">\n                  <div>\n                    <p>本社　施工管理<span class=\"pre\">（滋賀システム技術チーム）</span></p>\n                    <h5>現場ごとに違う景色が、今の自分にちょうどいい。</h5>\n                    <span>30代　在職歴：1年</span> </div>\n                  </a> </li>\n              </ul>\n            </section>\n          </div alt=\"col_textarea_full\">\n          <!--　▲▲▲　本文領域　終わり　▲▲▲　--> \n        </div>\n        <!-- eod:sp_padding --> \n      </div alt=\"eod:zone_mainarea\">\n      <!--　メインエリア　終わり　--> \n    </div alt=\"eod:zone_body\">\n    <!--　ボディ領域　終わり　--> \n  </div alt=\"eod:zone_middle\">\n  <!--　第2層　終わり　--> \n  <!-- リクルート用　お問い合わせフッターのインクルード --> \n  <meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\" />\n<meta name=\"format-detection\" content=\"telephone=no\">\n<!-- \n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/common.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/zone.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/bpts.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/unit.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/col.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/other.css\"/>\n-->\n<!-- リクルートフッターここから -->\n<div class=\"bpts_footer_recruit\"> \n  <!-- ▼ 左ボックス -->\n  <div>\n    <h4>採用に関するお問い合わせ</h4>\n    <table>\n      <tr>\n        <th>担当</th>\n        <td><span>管理グループ</span><br>\n          西村 伸宏</td>\n      </tr>\n      <tr>\n        <th>TEL</th>\n        <td>077-552-1144</td>\n      </tr>\n<!--      <tr>\n        <th>Mail　</th>\n        <td><a href=\"mailto:\"></a></td>\n      </tr>-->\n    </table>\n  </div>\n  <!-- ▲ 左ボックス --> \n  <!-- ▼ 右ボックス -->\n  <div> <a href=\"requirements.shtml\">\n    <h6>募集要項</h6></a> </div>\n  <!-- ▲ 右ボックス --> \n</div>\n<!-- ▲リクルートフッターここまで --> \n\n<!-- お問い合わせfooterここから -->\n<div class=\"bpts_footer_contact_area recruit_wrap\">\n  <h6 class=\"recruit_fotter\">ご相談等ありましたら<span>お気軽にお問い合わせください</span></h6>\n  <div class=\"center\"> <a href=\"/recruit/saiyou-contact.shtml\" class=\"bpts_btn_squarered\"><span>お問い合わせフォームを開く</span></a> </div>\n</div>\n<!-- お問い合わせfooterここまで --> \n \n  <!--　第3層　-->\n  <div id=\"zone_bottom_floor\"> \n    <!--　フッター　-->\n    <div id=\"zone_footer\"> \n      <!-- フッターのインクルード --> \n      <meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\" />\n<meta name=\"format-detection\" content=\"telephone=no\">\n<!-- \n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/common.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/zone.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/bpts.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/unit.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/col.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/other.css\"/>\n -->\n<div id=\"pagetop\"><a href=\"#top\">Page Top</a></div>\n<!--　フッター　-->\n<footer id=\"footer\">\n<div class=\"bpts_footer_wrapper\"> \n  \n  <!-- -------------------- ▼　画像とロゴ -------------------