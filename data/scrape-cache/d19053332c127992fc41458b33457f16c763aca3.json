t.com/\">採用情報</a>\n        </li>\n\n        <li>\n          <a href=\"https://www.eigetsu.co.jp/neo/news\"><span>お知らせ</span></a>\n        </li>\n\n        <li class=\"btInq\">\n          <a href=\"https://www.eigetsu.co.jp/neo/contact\"><span>お問合せ</span></a>\n        </li>\n      </ul>\n    </nav>\n  </div>\n</header>\n<!-- ▲ HEADER -->\n\n<!-- ▼ CONTENTS -->\n<main>\n  <!-- ↓パン屑 -->\n  <div id=\"breadcrumbs\">\n    <ul class=\"row\">\n      <li><a href=\"https://www.eigetsu.co.jp/neo\">TOP</a></li>\n      <li><a href=\"https://www.eigetsu.co.jp/neo/business\">事業案内</a></li>\n            <li>情報システム事業 - 地域を支える事業</li>\n          </ul>\n  </div>\n  <!-- ↑パン屑 -->\n\n  <article id=\"infosystem\">\n    <!-- ▽ タイトル -->\n    <div id=\"pageTitle\">\n      <div class=\"row\">\n        <h2>情報システム事業</h2>\n                <p class=\"h2sup\">地域を支える事業 / 事業案内</p>\n              </div>\n    </div>\n    <!-- △ タイトル -->\n\n        <p id=\"mainImg\"><img src=\"https://www.eigetsu.co.jp/neo/wp-content/uploads/2019/12/mainImg-21.jpg\" alt=\"情報システム事業\"/></p>    \n    <div id=\"container\">\n      <div class=\"intro\">\n        <div class=\"catch\">情報システムをサポートします</div>\n        <p class=\"catchSup\">INFORMATION SYSTEM</p>\n        <p>OA機器の設置からサーバーネットワークの設計・構築・運用まで、情報インフラ整備をお手伝いします。</p>\n              </div>\n                  \n<div class=\"inNav\">\n        <div class=\"row\">\n          <ul class=\"pageNav\">\n            <li><a href=\"#cnt01\">OA機器・消耗品等の販売</a></li>\n            <li><a href=\"#cnt02\">技術サービス</a></li>\n          </ul>\n        </div>\n      </div>\n      <div class=\"contents\">\n        <section id=\"cnt01\">\n          <h3>OA機器・消耗品等の販売</h3>\n          <div class=\"jobDesc\">\n            <div class=\"flex\">\n              <p class=\"photo\"><img src=\"https://www.eigetsu.co.jp/neo/images/business/region/infoSystem/img01.jpg\" alt=\"\"></p>\n              <p class=\"txt\">富士通をメインとしたパソコン・ワークステーション・サーバの取扱いをはじめ、\nディスプレイ・プリンタなどのパソコン周辺機器の他、レーザープリンターや\n消耗品トナー・インクなどオフィス用品の販売も行っております。</p>\n            </div>\n          </div>\n          <div class=\"handling\">\n            <p class=\"ttl\">取扱メーカー</p>\n            <table>\n              <tbody>\n                <tr>\n                  <th scope=\"row\"><p class=\"square\">パソコン</p></th>\n                  <td>富士通、NEC、DELL、HP、東芝、Acer、パナソニック、Lenovo</td>\n                </tr>\n                <tr>\n                  <th scope=\"row\"><p class=\"square\">プリンター</p></th>\n                  <td>リコー、エプソン、キヤノン、ブラザー</td>\n                </tr>\n\t\t\t\t\t\t\t\t<tr>\n                  <th scope=\"row\"><p class=\"square\">周辺機器</p></th>\n                  <td>バッファロー、IOデータ、サンワサプライ、エレコム</td>\n                </tr>\n\t\t\t\t\t\t\t\t<tr>\n                  <th scope=\"row\"><p class=\"square\">ソフト</p></th>\n                  <td>トレンドマイクロ、マイクロソフト、OBC、オーケン</td>\n                </tr>\n              </tbody>\n            </table>\n          </div>\n        </section>\n        <section id=\"cnt02\"> \n          <h3>技術サービス</h3>\n          <div class=\"jobDesc\">\n            <h4>システムインテグレーション・ネットワーク構築</h4>\n            <div class=\"flex\">\n              <p class=\"photo\"><img src=\"https://www.eigetsu.co.jp/neo/images/business/region/infoSystem/img02.jpg\" alt=\"\"></p>\n              <p class=\"txt\">お客様の業務形態・ご要望に合わせて、サーバ機器の設置・システム構築・ネットワーク設定など対応いたします。</p>\n            </div>\n          </div>\n          <div class=\"jobDesc\">\n            <h4>サーバーシステム・ソフトウェア開発</h4>\n            <div class=\"flex\">\n              <p class=\"photo\"><img src=\"https://www.eigetsu.co.jp/neo/images/business/region/infoSystem/img03.jpg\" alt=\"\"></p>\n              <p class=\"txt\">高校向けの成績処理システムを主とし、帳票出力系のソフトウェア開発をいたします。</p>\n            </div>\n          </div>\n          </div>\n        </section>\n      </div>\n          </div>\n\n    <div class=\"inqArea\">\n      <div class=\"contents\">\n      <p class=\"mainTtl\">お問い合わせ</p>\n        <!--エネルギーサービス-->\n          <!--p>プロパンガス・住宅設備に関するお困りごとなど、まずはお気軽にお問合せください。</p-->\n     