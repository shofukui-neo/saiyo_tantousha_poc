s://www.nova-system.com/recruitment/xmlrpc.php?rsd\" />\n<meta name=\"generator\" content=\"WordPress 6.3.8\" />\n<link rel=\"canonical\" href=\"https://www.nova-system.com/recruitment/recruitmentregistration/\" />\n<link rel='shortlink' href='https://www.nova-system.com/recruitment/?p=136' />\n<link rel=\"alternate\" type=\"application/json+oembed\" href=\"https://www.nova-system.com/recruitment/wp-json/oembed/1.0/embed?url=https%3A%2F%2Fwww.nova-system.com%2Frecruitment%2Frecruitmentregistration%2F\" />\n<link rel=\"alternate\" type=\"text/xml+oembed\" href=\"https://www.nova-system.com/recruitment/wp-json/oembed/1.0/embed?url=https%3A%2F%2Fwww.nova-system.com%2Frecruitment%2Frecruitmentregistration%2F&#038;format=xml\" />\n\t\t        \n<section id=\"recruitment-infomation\">\n\t<h1 class=\"main-title\">\n\t\t<p class=\"main-title-en\">\n\t\t\tRecruitment\n\t\t</p>\n\t\t<br>\n\t\t<p class=\"main-title-jp\">\n\t\t\t情報配信登録\n\t\t</p>\n\t</h1>\n\n\n\t<h2 class=\"philosophy\">\n\t\t<span class=\"main-philosophy01\">\n\t\t\t『スマートに働き、<br>\n\t\t</span>\n\t\t<span class=\"main-philosophy02\">\n\t\t\tよく学び、よく遊び、<br>\n\t\t</span>\n\t\t<span class=\"main-philosophy03\">\n\t\t\t夢や理想に近づく』<br>\n\t\t</span>\n\t\tノバシステムでは<br>\n\t\tあなたの市場価値を着実に高められるステージを用意しております。\n\t</h2>\n\n\n\t<p class=\"wp-admin-body01\">\n\t\tノバシステムに興味をお持ちいただきまして誠にありがとうございます。<br>\n\t\t「\n\t\t<span class=\"font-change01\">\n\t\t\t登録フォームへ進む\n\t\t</span>\n\t\t」というボタンより<br>「\n\t\t<span class=\"font-change01\">\n\t\t\t情報配信登録\n\t\t</span>\n\t\t」をお願いいたします。\n\t</p>\n\n\n\t<div class=\"cr-box\">\n\t\t<p class=\"cr-text-title\">\n\t\t\t情報配信登録とは<br>\n\t\t</p>\n\t\t<p class=\"cr-text-body\">\n\t\t\t<br>\n\t\t\tご自身のメールアドレスをご登録いただくことで、当社より各種情報を配信させていただきます。<br>\n\t\t\t登録時に「履歴書」や「職務経歴書」のご提出は不要です。<br>\n\t\t\tこのご登録をもって選考のエントリーとはなりません。<br>\n\t\t\tぜひ、お気軽にご登録ください。<br>\n\t\t</p>\n\t</div>\n\n\n\t<p class=\"worries-title\">\n\t\tこんな方におすすめ\n\t</p>\n\n\n\t<div class=\"worries-list\">\n\t\t<div class=\"worries-box\">\n\t\t\tどの職種に応募すれば良いか分からない\n\t\t</div>\n\t\t<div class=\"worries-box\">\n\t\t\t今すぐ転職するわけではないが、ノバシステムに興味を持った\n\t\t</div>\n\t\t<div class=\"worries-box\">\n\t\t\t今後新たにマッチするポジションが募集開始となったら紹介してほしい\n\t\t</div>\n\t\t<div class=\"worries-box\">\n\t\t\tまずはイベント／面談に参加してノバシステムのことを知りたい\n\t\t</div>\n\t</div>\n\n\n\t<div class=\"worries-bottom-text\">\n\t\tなど、エントリーでお困りの方は、まずはこちらの情報配信登録をご利用ください\n\t</div>\n\n\n\t<div class=\"cr-box-bottom-text\">\n\t\tまずは情報収集からはじめませんか。<br>\n\t\tキャリアチャンスを広げるきっかけとして、ぜひご登録ください。\n\t</div>\n\n\n\n\n\t<div class=\"submit-button\">\n\t\t<a href=\"https://app.crm.i-myrefer.jp/entry/novasystem/QI4osVxIsdYo85ZewhSC\" class=\"form-button\" target=\"_blank\" rel=\"noopener\">\n\t\t\t<div class=\"button-maintext\">\n\t\t\t\t登録フォームへ進む\n\t\t\t</div>\n\t\t\t<div class=\"button-subtext\">\n\t\t\t\t※登録フォームは株式会社TalentXが運営する「MyTalent」を使用しております。\n\t\t\t</div>\n\t\t</a>\n\t</div>\n\n\n\n\t<div class=\"bottom-text\">\n\t\t※すべての方にイベントのご案内や面談、選考の機会をお約束するものではございません。<br>\n\t\t既にエントリーしたい職種が決まっている場合は、\n\t\t<a href=\"https://www.nova-system.com/recruitment/entry/\" target=\"_blank\" class=\"entry\" rel=\"noopener\">\n\t\t\tエントリーフォーム\n\t\t</a>\n\t\tからエントリーをお願いいたします。\n\t</div>\n\n</section>\n\t\t<script type='text/javascript' src='https://www.nova-system.com/recruitment/wp-content/plugins/contact-form-7/includes/swv/js/index.js?ver=5.8' id='swv-js'></script>\n<script type='text/javascript' id='contact-form-7-js-extra'>\n/* <![CDATA[ */\nvar wpcf7 = {\"api\":{\"root\":\"https:\\/\\/www.nova-system.com\\/recruitment\\/wp-json\\/\",\"namespace\":\"contact-form-7\\/v1\"}};\n/* ]]> */\n</script>\n<script type='text/javascript' src='https://www.nova-system.com/recruitment/wp-content/plugins/contact-form-7/includes/js/index.js?ver=5.8' id='contact-form-7-js'></script>\n \n  <footer id=\"footer\">\n    <div id=\"fv\" class=\"yu_mincho\">\n      <div class=\"inner\"> <span class=\"catch\">明日をINNOVATION</span> \n        <!-- .inner --> \n      </div>\n    </div>\n    <div id=\"footer_entry\">\n      <div clas