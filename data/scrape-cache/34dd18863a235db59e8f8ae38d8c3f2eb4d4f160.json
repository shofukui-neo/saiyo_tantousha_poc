          <span class=\"graph\"><span>2019</span></span>\r\n          </li>\r\n          <li>\r\n            <span class=\"value\">10,147<span>億円</span></span>\r\n            <span class=\"graph\"><span>2020</span></span>\r\n          </li>\r\n          <li>\r\n            <span class=\"value\">10,529<span>億円</span></span>\r\n            <span class=\"graph\"><span>2021</span></span>\r\n          </li>\r\n          <li>\r\n            <span class=\"value\">10,770<span>億円</span></span>\r\n            <span class=\"graph\"><span>2022</span></span>\r\n          </li>\r\n          <li>\r\n            <span class=\"value\">11,755<span>億円</span></span>\r\n            <span class=\"graph\"><span>2023</span></span>\r\n          </li>\r\n          <li>\r\n            <span class=\"value\">12,444<span>億円</span></span>\r\n            <span class=\"graph\"><span>2024</span></span>\r\n          </li>\r\n        </ul>\r\n\r\n        <p class=\"data-sales2-text\">安定した経営を<br>続けています！</p>\r\n\r\n        <p class=\"data-heading data-sales-caption\">製パン業界<br><span class=\"crown\"><img src=\"../assets/images/number/icon_01.svg\" alt=\"\"></span>売上高<strong>第1位</strong><br>※2024年度</p>\r\n\r\n        <!-- <ol class=\"data-sales\">\r\n          <li>\r\n            <div class=\"text\">\r\n              <span class=\"label turn-white\">山崎製パン</span>\r\n              <span class=\"value turn-white\">10,529<span>億円</span></span>\r\n            </div>\r\n            <span class=\"graph\"></span>\r\n          </li>\r\n          <li>\r\n            <div class=\"text\">\r\n              <span class=\"label turn-white\">A社</span>\r\n              <span class=\"value\">2,651<span>億円</span></span>\r\n            </div>\r\n            <span class=\"graph\"></span>\r\n          </li>\r\n          <li>\r\n            <div class=\"text\">\r\n              <span class=\"label turn-white\">B社</span>\r\n              <span class=\"value\">1,543<span>億円</span></span>\r\n            </div>\r\n            <span class=\"graph\"></span>\r\n          </li>\r\n          <li>\r\n            <div class=\"text\">\r\n              <span class=\"label\">C社</span>\r\n              <span class=\"value\">433<span>億円</span></span>\r\n            </div>\r\n            <span class=\"graph\"></span>\r\n          </li>\r\n          <li>\r\n            <div class=\"text\">\r\n              <span class=\"label\">D社</span>\r\n              <span class=\"value\">238<span>億円</span></span>\r\n            </div>\r\n            <span class=\"graph\"></span>\r\n          </li>\r\n        </ol> -->\r\n\r\n        <p class=\"data-heading\">食品業界では<br>売上高<strong>第7位</strong><br>※2024年度</p>\r\n\r\n\r\n      </div><!-- .detail-section-inner + white-area\" -->\r\n    </section><!-- .detail-section -->\r\n\r\n    <section class=\"detail-section\">\r\n      <div class=\"detail-section-inner white-area\">\r\n        <h2><span>2024年度の採用実績</span></h2>\r\n\r\n        <p class=\"data-heading-text\">性別</p>\r\n        <div class=\"circle-graph\">\r\n          <svg class=\"graph\" viewBox=\"0 0 63.6619772368 63.6619772368\">\r\n            <circle class=\"graph-male\" cx=\"31.8309886184\" cy=\"31.8309886184\" r=\"15.9154943092\" stroke-width=\"31.8309886184\" />\r\n            <circle class=\"graph-female\" cx=\"31.8309886184\" cy=\"31.8309886184\" r=\"15.9154943092\" stroke-width=\"31.8309886184\" />\r\n          </svg>\r\n          <div class=\"value\">\r\n            <img src=\"../assets/images/number/circle_graph_value.png\" alt=\"女性47% 男性53%\">\r\n          </div>\r\n          <figure class=\"image\">\r\n            <img src=\"../assets/images/number/circle_graph_image.png\" alt=\"\">\r\n          </figure>\r\n        </div>\r\n\r\n        <!-- <p class=\"data-heading-text\">職種</p>\r\n\r\n        <ul class=\"horizontal-graph type-01\">\r\n          <li>\r\n            <span class=\"value\">91<span>%</span></span>\r\n            <span class=\"block\">\r\n              <span class=\"label\">生産職</span>\r\n       