          \r\n             </h2>\r\n        </div>\r\n    </div>\r\n</section>\r\n<!--top-->\r\n\r\n<!--pageback-->\r\n<section>\r\n    <div class=\"container align-right\">\r\n        <p class=\"mar-top10\">\r\n            <a href=\"javascript:history.back()\" class=\"btn btn-default\">\r\n                前のページへ戻る\r\n                \r\n            </a>\r\n        </p>\r\n    </div>\r\n</section>\r\n<!--pageback-->\r\n\r\n\r\n<section id=\"\" class=\"section-under\">\r\n    <div class=\"container\">\r\n        <p>\r\n            ご意見・ご質問・弊社へのご相談などございましたら以下のフォームより、必要事項をご記入の上、お問い合わせ下さいますようお願い申し上げます。<br>\r\nまた、お電話でのお問い合わせは、各担当部門まで直接ご連絡頂きますようお願い申し上げます。\r\n            \r\n        </p>\r\n        <p>\r\n            個人情報保護については、個人情報保護法方針をご覧ください。\r\n            \r\n        </p>\r\n        <p class=\"mar-top10\">\r\n            <a href=\"https://www.umc.co.jp/modules/contents/pp.html\" class=\"btn btn-default\" target=\"_blank\">\r\n                個人情報保護法方針\r\n                \r\n            </a>\r\n        </p>\r\n        <p>\r\n            採用については、こちらから採用情報をご覧ください。\r\n        </p>\r\n        <p class=\"mar-top10\">\r\n            <a href=\"https://www.umc.co.jp/modules/contents/recruit.html\" class=\"btn btn-default\" target=\"_blank\">\r\n                採用情報を見る\r\n            </a>\r\n        </p>\r\n\r\n        <!---->\r\n        <style>\r\n            .contact-attention {\r\n                margin-top: 30px;\r\n            }\r\n            .contact-attention .attention-headline {\r\n                font-weight: 600;\r\n            }\r\n            .contact-attention .attention-desc {\r\n                padding-left: 1rem;\r\n            }\r\n        </style>\r\n        \r\n        <div class=\"contact-attention\">\r\n            <p class=\"attention-headline\">【お問い合わせ時のご注意】</p>\r\n            <p class=\"attention-desc\">\r\n                下記に該当するご質問には回答いたしかねますので、予めご了承ください。<br>\r\n                ・弊社の業務に関係の無い内容<br>\r\n                ・非公開情報に関するご質問<br>\r\n                ・誹謗中傷に該当する内容<br>\r\n                ・匿名でのお問い合わせ<br><br>\r\n                当社からお客様に差し上げた回答はお客様個人に宛てたものです。<br>\r\n                内容の一部または全てを転用したり二次利用したりすることは厳にご遠慮ください。\r\n            </p>\r\n        </div>\r\n        \r\n        \r\n\r\n                \r\n        <!---->\r\n\r\n        <link rel=\"stylesheet\" type=\"text/css\" media=\"all\" href=\"https://www.umc.co.jp/modules/liaise/css/validate.css\" />\r\n\r\n        <form name=\"liaise_1\" id=\"liaise_1\" action=\"https://www.umc.co.jp/modules/liaise/index.php\" method=\"post\" class=\"liaise\">\r\n\r\n        <!--page-->\r\n        <table class=\"table mar-top20 border_under_table\">\r\n            <!--table class=\"table mar-top20\"-->\r\n            <tr>\r\n                <td class=\"bg_grayyellow\">\r\n                    カテゴリ\r\n                    \r\n                    <span class=\"small color-red\">（必須）</span>\r\n                    \r\n                </td>\r\n                <td>\r\n                    <select size='1' name='ele_16' id='ele_16' >\r\n                      <option id='ele_16_1' value=''  selected='selected'>\r\n                          カテゴリを選択して下さい\r\n                          \r\n                      </option>\r\n                      <option id='ele_16_2' value='2' >\r\n                          弊社営業部へのお問い合わせ\r\n                          \r\n                      </option>\r\n                      <!---->\r\n                      <option id='ele_16_4' value='4' >\r\n                          弊社購買部へのお問い合わせ\r\n                          \r\n                      </option>\r\n                      <option id='ele_16_7' value='7' >\r\n                          IRに関するお問い合わせ\r\n                          \r\n                      </option>\r\n                      <option id='ele_16_5' value='5' >\r\n                          採用に関するお問い合わせ\r\n                          \r\n                      </option>\r\n                      <option id='ele_16_6' value='6' >\r\n                     