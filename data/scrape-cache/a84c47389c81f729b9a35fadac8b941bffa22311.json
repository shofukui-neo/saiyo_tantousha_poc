lt page page-id-37\">\n\n<!-- Google Tag Manager (noscript) -->\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-P3BQK43\"\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n<!-- End Google Tag Manager (noscript) -->\n\n<div id=\"container\">\n<header id=\"globalheader\">\n<div class=\"siteLogo\"><a href=\"/\" class=\"on\"><img src=\"https://gyosei.jp/wp/wp-content/themes/gyosei_co/images/global/logo_gyousei.png\" alt=\"ぎょうせい\" width=\"185\" height=\"42\"></a></div>\n</header>\n\n<nav id=\"globalnavi\">\n<div class=\"btnMenu\"><span>menu</span></div>\n<div class=\"menuBody\">\n<ul class=\"mainMenu\">\n\n<li class=\"gnHome\"><a href=\"/\">Home</a></li>\n\n<li class=\"gnCompany\">\n<a href=\"/company/\">企業情報</a>\n<div class=\"lowerMenu\">\n<dl class=\"clearfix\">\n<dt><a href=\"/company/\">企業情報</a></dt>\n<dd>\n<ul>\n<li><a href=\"/company/message/\">ごあいさつ</a></li>\n<li><a href=\"/company/outline/\">会社概要</a></li>\n<li><a href=\"/company/statement/\">ぎょうせいについて</a></li>\n<li><a href=\"/company/history/\">会社沿革</a></li>\n<li><a href=\"/mediaclip/\">メディアクリップ</a></li>\n<li><a href=\"/company/organization/\">組織体制</a></li>\n<li><a href=\"/company/group/\">グループ企業</a></li>\n<li><a href=\"/company/office/\">事業所・担当地域一覧</a></li>\n<li><a href=\"/company/compliance/\">コンプライアンス</a></li>\n<li><a href=\"/company/security/\">情報セキュリティ</a></li>\n<li><a href=\"/company/privacypolicy/\">個人情報保護基本方針</a></li>\n<li class=\"spDoubleLine pcLongLine\"><a href=\"/company/socialmedia/\">ソーシャルメディア<br class=\"only-sp\">公式アカウント一覧</a></li>\n</ul>\n</dd>\n</dl>\n<div class=\"linkList\"><a href=\"/company/\">企業情報一覧へ</a></div>\n</div>\n</li>\n\n<li class=\"gnBusiness\">\n<a href=\"/business/\">事業分野</a>\n<div class=\"lowerMenu\">\n<dl class=\"clearfix\">\n<dt><a href=\"/business/\">事業分野</a></dt>\n<dd>\n<ul>\n<li><a href=\"/business/publishing/\">総合出版</a></li>\n<li><a href=\"/business/dcs/\">デジタルコンテンツサービス</a></li>\n<li class=\"spDoubleLine\"><a href=\"/business/law/\">法令・例規・<br class=\"only-sp\">企業法務サービス</a></li>\n<li><a href=\"/business/system/\">地方公共団体情報システム</a></li>\n<li><a href=\"/business/event/\">地域創生・地域活性化</a></li>\n</ul>\n</dd>\n</dl>\n<div class=\"linkList\"><a href=\"/business/\">事業分野一覧へ</a></div>\n</div>\n</li>\n\n<li class=\"gnRecruit\"><a href=\"/recruit/\">採用情報</a></li>\n\n<li class=\"gnInquiry current\"><a href=\"/inquiry/\">お問い合わせ</a></li>\n\n<li class=\"gnInquiry\"><a href=\"/collabo_inquiry/\">協業に関するお問い合わせ</a></li>\n\n</ul>\n\n<ul class=\"subMenu\">\n<li><a href=\"/news/\">お知らせ</a></li>\n<li><a href=\"/faq/\">よくあるご質問</a></li>\n</ul>\n\n<div class=\"siteSearch\">\n<script>\n  (function() {\n  \tvar cx = '001811576467755339547:phksktl1kaw';\n  \tvar gcse = document.createElement('script');\n  \tgcse.type = 'text/javascript';\n  \tgcse.async = true;\n  \tgcse.src = 'https://cse.google.com/cse.js?cx=' + cx;\n  \tvar s = document.getElementsByTagName('script')[0];\n  \ts.parentNode.insertBefore(gcse, s);\n  })();\n</script>\n<gcse:searchbox-only></gcse:searchbox-only>\n</div>\n\n<ul class=\"socialLinks\">\n<li><a href=\"#\" class=\"on\"><img src=\"https://gyosei.jp/wp/wp-content/themes/gyosei_co/images/global/icon_facebook.png\" alt=\"facebook\"></a></li>\n<li><a href=\"#\" class=\"on\"><img src=\"https://gyosei.jp/wp/wp-content/themes/gyosei_co/images/global/icon_twitter.png\" alt=\"twitter\"></a></li>\n<li><a href=\"#\" class=\"on\"><img src=\"https://gyosei.jp/wp/wp-content/themes/gyosei_co/images/global/icon_gplus.png\" alt=\"Google +\"></a></li>\n</ul>\n\n<div class=\"linkOnlineshop\"><a href=\"http://shop.gyosei.jp/\" class=\"on\" target=\"_blank\"><span>オンラインショップ</span></a></div>\n</div>\n</nav>\n\n<div class=\"cookie\" id=\"cookie\">\n  <div class=\"cookie_block\">\n    <div class=\"cookie_box\">\n      <div class=\"cookie_text\">\n        <p>当ウェブサイトでは、お客様のサービス向上のためCookie (クッキー)を使用しています。ブラウザの設定よりCookieの機能を変更することができます。Cookieの利用に同意していただける場合は、同意ボタンをクリックしてください。</p>\n        <div class=\"cookie_text_link_container\">→ <a href=\"/about/privacy/\" class=\"cookie_text_link\">個人情報の取扱いについて</a></div>\n      </div>\n      <div class=\"cookie_button_container\">\n        <button type=\"button\" class=\"cookie_button on\" id=\"cookie_button\">同意</button>\n      </div>\n    </div>\n  </div>\n</div>\n\r\n<div id=\"topicPath\">\r\n<ul>\r\n<li><a href=\"https://gyosei.jp\">Home</a></li>\r\n<li>お問い合わせ</li>\r\n</ul>\r\n</div>\r\n\r\n<div id=\"mainArea\" class=\"col3 clearfix\">\r\n\r\n<div id=\"content\">\r\n\r\n<section id=\"mainContents\" class=\"cat-inquiry page-index\">\r\n\r\n<h1 class=\"pageTitle\">お問い合わせ</h1>\r\n\r\n<article class=\"articleBox\">\r\n<p>ご依頼・ご質問につきましては、各種お問い合わせフォームをご利用ください。<br>\r\nお電話・FAXでのお問い合わせも受け付けております。<br>\r\n<br>\r\nよくいただくお問い合わせにつきましては、「よくあるご質問」にてご案内しております。<br>\r\nお問い合わせ前にぜひご確認ください。<BR>\r\n<BR>\r\n「協業に関するお問い合わせ」は、専用ページがございますので、そちらをご確認ください。\r\n</p>\r\n<div class=\"btnPanel\">\r\n<ul>\r\n<li>\r\n<div class=\"btnFormal\"><a href=\"/faq/\" class=\"on\">よくあるご質問</a></div>\r\n</li>\r\n<li>\r\n<div class=\"btnFormal\"><a href=\"/collabo_inquiry/\" class=\"on\">協業に関するお問い合わせ</a></div>\r\n</li>\r\n</ul>\r\n\r\n</div>\r\n</article>\r\n\r\n<article class=\"articleBox\">\r\n<h2 class=\"bdrTitleB\">各種入力フォームでのお問い合わせ</h2>\r\n\r\n<table class=\"borderTable\">\r\n<tbody>\r\n<tr>\r\n<th class=\"lv00\">お問い合わせ内容</th>\r\n<th class=\"lv00\">お問い合わせフォーム</th>\r\n</tr>\r\n<tr>\r\n<th class=\"lv01\">「自治体実務解説サービス GovGuide」に関するご照会</th>\r\n<td class=\"lv04\"><a href=\"https://krs.bz/gyosei/m/govguide_input\" rel=\"noopener\" target=\"_blank\">こちら</a></td>\r\n</tr>\r\n<tr>\r\n<th class=\"lv01\">商品の在庫確認・ご注文に関するご照会</th>\r\n<td class=\"lv04\"><a href=\"https://krs.bz/gyosei/m/order_input/\" rel=\"noopener\" target=\"_blank\">こちら</a></td>\r\n</tr>\r\n<tr>\r\n<th class=\"lv01\">新規図書購入のための見積に関するご照会</th>\r\n<td class=\"lv04\"><a href=\"https://krs.bz/gyosei/m/book_estimate\" target=\"_blank\" rel=\"noopener\">こちら</a></td>\r\n</tr>\r\n<tr>\r\n<th class=\"lv01\">追録・雑誌代金の見積に関するご照会</th>\r\n<td class=\"lv04\"><a href=\"https://krs.bz/gyosei/m/estimate_input/\" rel=\"noopener\" target=\"_blank\">こちら</a></td>\r\n</tr>\r\n<tr>\r\n<th class=\"lv01\">定期購読のお届け先・名義変更に関するご照会</th>\r\n<td class=\"lv04\"><a href=\"https://krs.bz/gyosei/m/customer_info_input/\" rel=\"noopener\" target=\"_blank\">こちら</a></td>\r\n</tr>\r\n<tr>\r\n<th class=\"lv01\">請求書が届かない等、発行時期に関するご照会</th>\r\n<td class=\"lv04\"><a href=\"https://krs.bz/gyosei/m/invoice_status\" target=\"_blank\" rel=\"noopener\">こちら</a></td>\r\n</tr>\r\n<tr>\r\n<th class=\"lv01\">請求書の紛失、あて名変更等、再発行に関するご照会</th>\r\n<td class=\"lv04\"><a href=\"https://krs.bz/gyosei/m/invoice_input/\" rel=\"noopener\" target=\"_blank\">こちら</a></td>\r\n</tr>\r\n<tr>\r\n<th class=\"lv01\">追録の加除（差し替え）に関するご照会</th>\r\n<td class=\"lv04\"><a href=\"https://krs.bz/gyosei/m/addition_input/\" rel=\"noopener\" target=\"_blank\">こちら</a></td>\r\n</tr>\r\n<tr>\r\n<th class=\"lv01\">領収証の発行に関するご照会</th>\r\n<td class=\"lv04\"><a href=\"https://krs.bz/gyosei/m/receipt_input/\" rel=\"noopener\" target=\"_blank\">こちら</a></td>\r\n</tr>\r\n<!--<tr>\r\n<th class=\"lv01\">書籍の内容に関するご照会</th>\r\n<td class=\"lv04\"><a href=\"https://krs.bz/gyosei/m/book_inquiry\" rel=\"noopener\" target=\"_blank\">こちら</a></td>\r\n</tr>--!>\r\n<tr>\r\n<th class=\"lv01\">資料のご請求</th>\r\n<td class=\"lv04\"><a href=\"https://krs.bz/gyosei/m/inventory_input/\" rel=\"noopener\" target=\"_blank\">こちら</a></td>\r\n</tr>\r\n<tr>\r\n<th class=\"lv01\">当社雑誌への広告掲載に関するご照会</th>\r\n<td class=\"lv04\"><a href=\"https://krs.bz/gyosei/m/ad\" rel=\"noopener\" target=\"_blank\">こちら</a></td>\r\n</tr>\r\n<tr>\r\n<th class=\"lv01\">その他のお問い合わせ</th>\r\n<td class=\"lv04\"><a href=\"https://krs.bz/gyosei/m/contact_input/\" rel=\"noopener\" target=\"_blank\">こちら</a></td>\r\n</tr>\r\n</tbody>\r\n</table>\r\n<BR>\r\n<BR>\r\n<p>\r\n※お問い合わせ内容によっては、ご返答にお時間をいただく場合もございますので、あらかじめご了承ください。\r\n</p>\r\n\r\n</article>\r\n\r\n<!--2025/4/24 スマホで見ると体裁が崩れるためコメントアウト　ここから\r\n<article class=\"articleBox\">\r\n<h2 class=\"bdrTitleB\">各種入力フォームでのお問い合わせ</h2>\r\n\r\n<table class=\"borderTable\"> \r\n<tbody>\r\n<tr>\r\n</tr>\r\n\r\n<tr>\r\n<td class=\"lv01\"><center><a href=\"https://krs.bz/gyosei/m/customer_info_input/\" rel=\"noopener\" target=\"_blank\"><img loading=\"lazy\" src=\"/wp/wp-content/uploads/2024/11/mail.png\" alt=\"\" width=\"60\" height=\"45\" class=\"alignleft size-full wp-image-2336\" /></a><BR><BR>【定期購読】<BR>お届け先／名義変更</center></td>\r\n<td class=\"lv01\"><center><a href=\"https://krs.bz/gyosei/m/addition_input/\" rel=\"noopener\" target=\"_blank\"><img loading=\"lazy\" src=\"/wp/wp-content/uploads/2024/11/mail.png\" alt=\"\" width=\"60\" height=\"45\" class=\"alignleft size-full wp-image-2336\" /></a><BR><BR>追録の差し替え<BR>（加除）</center></td>\r\n<td class=\"lv01\"><center><a href=\"https://krs.bz/gyosei/m/string_input/\" rel=\"noopener\" target=\"_blank\"><img loading=\"lazy\" src=\"/wp/wp-content/uploads/2024/11/mail.png\" alt=\"\" width=\"60\" height=\"45\" class=\"alignleft size-full wp-image-2336\" /></a><BR><BR>加除式図書の付属品<br>（表紙・バインダー<br>・とじ紐)交換</center></td></td>\r\n</tr>\r\n\r\n<tr>\r\n<td class=\"lv01\"><center><a href=\"https://krs.bz/gyosei/m/estimate_input/\" rel=\"noopener\" target=\"_blank\"><img loading=\"lazy\" src=\"/wp/wp-content/uploads/2024/11/mail.png\" alt=\"\" width=\"60\" height=\"45\" class=\"alignleft size-full wp-image-2336\" /></a><BR>追録・雑誌代金の当年度・<BR>次年度概算見積書／<BR>各種図書購入のための見積書</center></td>\r\n<td class=\"lv01\"><center><a href=\"https://krs.bz/gyosei/m/invoice_input/\" rel=\"noopener\" target=\"_blank\"><img loading=\"lazy\" src=\"/wp/wp-content/uploads/2024/11/mail.png\" alt=\"\" width=\"60\" height=\"45\" class=\"alignleft size-full wp-image-2336\" /></a><BR><BR>請求書の再発行</center></td>\r\n<td class=\"lv01\"><center><a href=\"https://krs.bz/gyosei/m/receipt_input/\" rel=\"noopener\" target=\"_blank\"><img loading=\"lazy\" src=\"/wp/wp-content/uploads/2024/11/mail.png\" alt=\"\" width=\"60\" height=\"45\" class=\"alignleft size-full wp-image-2336\" /></a><BR><BR>領収証の発行</center></td>\r\n</tr>\r\n\r\n<tr>\r\n<td class=\"lv01\"><center><a href=\"https://krs.bz/gyosei/m/inventory_input/\" rel=\"noopener\" target=\"_blank\"><img loading=\"lazy\" src=\"/wp/wp-content/uploads/2024/11/mail.png\" alt=\"\" width=\"60\" height=\"45\" class=\"alignleft size-full wp-image-2336\" /></a><BR><BR>資料のご請求</center></td>\r\n<td class=\"lv01\"><center><a href=\"https://krs.bz/gyosei/m/order_input/\" rel=\"noopener\" target=\"_blank\"><img loading=\"lazy\" src=\"/wp/wp-content/uploads/2024/11/mail.png\" alt=\"\" width=\"60\" height=\"45\" class=\"alignleft size-full wp-image-2336\" /></a><BR><BR>商品の在庫確認、ご注文</center></td>\r\n<td class=\"lv01\"><center><a href=\"https://krs.bz/gyosei/m/contact_input/\" rel=\"noopener\" target=\"_blank\"><img loading=\"lazy\" src=\"/wp/wp-content/uploads/2024/11/mail.png\" alt=\"\" width=\"60\" height=\"45\" class=\"alignleft size-full wp-image-2336\" /></a><BR><BR>その他のお問い合わせ</center></td>\r\n</tr>\r\n\r\n</tbody>\r\n</table>\r\n<BR>\r\n<BR>\r\n<p>\r\n※お問い合わせ内容によっては、ご返答にお時間をいただく場合もございますので、あらかじめご了承ください。\r\n</p>\r\n\r\n</article>\r\n2025/4/24 コメントアウト　ここまで--!>\r\n\r\n<article class=\"articleBox\">\r\n<h2 class=\"bdrTitleB\">FAXでのお問い合わせ</h2>\r\n\r\n<table class=\"borderTable\">\r\n<tbody>\r\n<tr>\r\n<th class=\"lv00\">商品・サービス・お問い合わせ内容</th>\r\n<th class=\"lv00\">FAX<span class=\"sub\">〔受付時間：毎日24時間〕</span></th>\r\n</tr>\r\n<tr>\r\n<th class=\"lv01\">書籍のご注文<br>書籍の掲載内容に関するご質問<br>発行時期等に関するご照会</th>\r\n<td class=\"lv04\">0120-953-495</td>\r\n</tr>\r\n<tr>\r\n<th class=\"lv01\">加除式図書の追録差替えのご依頼<br>最寄の支社・事務所へのご連絡</th>\r\n<td class=\"lv04\"><a href=\"/company/office/\">こちら</a>をご覧ください。</td>\r\n</tr>\r\n<tr>\r\n<th class=\"lv01\">当社雑誌への広告掲載について</th>\r\n<td class=\"lv04\">03-6892-6925</td>\r\n</tr>\r\n<tr>\r\n<th class=\"lv01\">当社出版物の権利・流用・貸出等について</th>\r\n<td class=\"lv04\">0120-953-495</td>\r\n</tr>\r\n<tr>\r\n<th class=\"lv01\">ご請求内容、お支払い、住所変更について</th>\r\n<td class=\"lv04\">0120-953-497</td>\r\n</tr>\r\n<tr>\r\n<th class=\"lv01\">SUPER REIKI-BASE関連について</th>\r\n<td class=\"lv04\">0120-953-498</td>\r\n</tr>\r\n<tr>\r\n<th class=\"lv01\">総合出版（自費・請負出版）</th>\r\n<td class=\"lv04\">0120-953-495</td>\r\n</tr>\r\n<tr>\r\n<th class=\"lv01\">法令・例規・企業法務サービス</th>\r\n<td class=\"lv04\">03-6892-6929</td>\r\n</tr>\r\n<tr>\r\n<th class=\"lv01\">地方公共団体情報システム</th>\r\n<td class=\"lv04\">03-6892-6930</td>\r\n</tr>\r\n<tr>\r\n<th class=\"lv01\">地方創生・地域活性化</th>\r\n<td class=\"lv04\">03-6892-6931</td>\r\n</tr>\r\n<tr>\r\n<th class=\"lv01\">企業情報について</th>\r\n<td class=\"lv04\">03-6892-6933</td>\r\n</tr>\r\n<tr>\r\n<th class=\"lv01\">採用情報について</th>\r\n<td class=\"lv04\">03-6892-6934</td>\r\n</tr>\r\n<tr>\r\n<th class=\"lv01\">サイトのご利用について</th>\r\n<td class=\"lv04\">0120-953-495\r\n</tr>\r\n</tbody>\r\n</table>\r\n\r\n</article>\r\n\r\n<article class=\"articleBox\">\r\n<h2 class=\"bdrTitleB\">お電話でのお問い合わせ</h2>\r\n<article class=\"articleBox\" id=\"inquiryGroup01\">\r\n<h4 class=\"bdrTitleL\">1. 出版物関連</h4>\r\n\r\n<div class=\"contactPhoneColumn\">\r\n<div class=\"columnBlock\">\r\n\r\n<div class=\"bnrPhone\"><a href=\"tel:0120-953-431\" class=\"phonenumber\"><span class=\"number\">0120-953-431</span><span class=\"time\">受付時間 平日9時～17時</span></a></div>\r\n\r\n<p class=\"notice\">音声ガイダンスにしたがって、<br class=\"only-sp\">次の番号を押してください。</p>\r\n\r\n<div class=\"guidanceColumn clearfix\">\r\n<dl class=\"guidanceItem\">\r\n<dt><img src=\"/wp/wp-content/themes/gyosei_co/images/v/inquiry/images/img_inquiry_04.png\" alt=\"*1\"></dt>\r\n<dd>書籍のご注文／書籍の掲載内容に関するご質問／<br>発行時期等に関するご照会</dd>\r\n</dl>\r\n<dl class=\"guidanceItem\">\r\n<dt><img src=\"/wp/wp-content/themes/gyosei_co/images/v/inquiry/images/img_inquiry_05.png\" alt=\"*2\"></dt>\r\n<dd>自治体史・周年記念誌・自費出版に関するご照会</dd>\r\n</dl>\r\n<dl class=\"guidanceItem\">\r\n<dt><img src=\"/wp/wp-content/themes/gyosei_co/images/v/inquiry/images/img_inquiry_06.png\" alt=\"*3\"></dt>\r\n<dd>加除式図書の追録の差し替えのご依頼／最寄の支社・事務所へのご連絡</dd>\r\n</dl>\r\n<dl class=\"guidanceItem\">\r\n<dt><img src=\"/wp/wp-conten