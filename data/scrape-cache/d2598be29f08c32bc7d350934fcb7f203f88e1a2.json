n            </div>\r\n\t\t</section>\r\n\t\t\r\n    </section>\r\n\r\n\t\t\t\r\n</main>\r\n<!--//main-->\r\n<footer id=\"footer\">\n\t\t<div id=\"footBreadcrumb\" class=\"breadcrumbs\" typeof=\"BreadcrumbList\" vocab=\"https://schema.org/\">\n\t\t<ol><!-- Breadcrumb NavXT 6.5.0 -->\n<li><span property=\"itemListElement\" typeof=\"ListItem\"><a property=\"item\" typeof=\"WebPage\" title=\"Go to キャリアプランニング.\" href=\"https://www.capla.co.jp\" class=\"home\" ><span property=\"name\">キャリアプランニング</span></a><meta property=\"position\" content=\"1\"></span></li><li><span property=\"itemListElement\" typeof=\"ListItem\"><a property=\"item\" typeof=\"WebPage\" title=\"Go to 採用情報.\" href=\"https://www.capla.co.jp/recruit/\" class=\"post post-page\" ><span property=\"name\">採用情報</span></a><meta property=\"position\" content=\"2\"></span></li><li><span property=\"itemListElement\" typeof=\"ListItem\"><span property=\"name\" class=\"post post-page current-item\">人材ビジネスとは</span><meta property=\"url\" content=\"https://www.capla.co.jp/recruit/industry/\"><meta property=\"position\" content=\"3\"></span></li></ol>\t</div>\n    <div class=\"serchSection\">\n        <div class=\"searchKeyWord serchBox\">\n            <dl>\n                <dt>キーワードで探す</dt>\n                <dd>\n                    <ul>\n                        <li><a href=\"/forcompany/haken/\">岡山　派遣</a></li>\n                        <li><a href=\"/forcompany/tensyoku/\">中途採用</a></li>\n                        <li><a href=\"/forcompany/shinsotsu/\">新卒採用</a></li>\n                        <li><a href=\"/forcompany/tensyoku/\">介護　採用</a></li>\n                        <li><a href=\"https://capla-kensyu.jp/\" class=\"blank\"rel=\"noopener noreferrer\" target=\"_blank\">社員研修</a></li>\n                        <li><a href=\"/forcompany/bposervice/\">BPOサービス</a></li>\n                        <li><a href=\"https://www.capla-haken.jp/\" class=\"blank\"rel=\"noopener noreferrer\" target=\"_blank\">派遣　求人</a></li>\n                 