/a>\n</li>\n\t\n\t\n<li data-hash=\"c5\" id=\"hlt\">\n<a href=\"/health/\">\n<p class=\"photo\"><img src=\"/health/img/vis.webp\" srcset=\"/health/img/vis.webp 1x, /health/img/vis@2x.webp 2x\" alt=\"\"></p>\n<h3>ヘルスケア</h3>\n<p class=\"tex\">福祉用具のレンタル・販売・住宅改修</p>\n</a>\n</li>\n\n</ul>\n\t    \n    \n<!--<i class=\"arrow-icon g-bot3\" id=\"top-arw\"></i>-->\n    \n    \n<!--sec1--></section>\n    \n    \n    \n    \n   \n    \n<section id=\"sec2\" class=\"halfbox-pl\">\n<div class=\"cons\">\n    \n    \n<div class=\"lbox\">\n    \n<div id=\"photo1\" class=\"photo-wp g-plx\">\n<p class=\"photo g-plx\"><img  src=\"/img/top/sec2a.webp\" srcset=\"/img/top/sec2a.webp 1x, /img/top/sec2a@2x.webp 2x\" alt=\"\"></p>\n</div>\n    \n   \n<div id=\"photo2\" class=\"photo-wp g-plx\">\n<p class=\"photo g-plx2\"><img  src=\"/img/top/sec2b.webp\" srcset=\"/img/top/sec2b.webp 1x, /img/top/sec2b@2x.webp 2x\" alt=\"\"></p>\n</div>\n    \n    \n    \n<!--lbox--></div>\n    \n    \n<div class=\"rbox\">\n    \n<div id=\"dec-en\" class=\"fd\">\n<p class=\"en1 fd\">\n<span class=\"fadeIn2\"><span class=\"fdtex\">Create</span></span><br>\n<span class=\"fadeIn2\"><span class=\"fdtex\">cleanliness</span></span><br>\n<span class=\"fadeIn2\"><span class=\"fdtex\">and comfort</span></span></p>\n</div>\n    \n<div class=\"top-tit\">\n<h2 class=\"fd\"><span class=\"jp fadeIn2\"><span class=\"fdtex\">会社紹介</span></span></h2>\n<p class=\"en1\"><span class=\"fadeIn2\"><span class=\"fdtex\">About Us</span></span></p>\n<!--top-tit--></div>\t    \n    \n    \n\n<h3 class=\"mds\">\n<span class=\"fadeIn2\"><span class=\"fdtex\">清潔と快適を</span></span><br>\n<span class=\"fadeIn2\"><span class=\"fdtex\">クリエイトするために</span></span>   \n</h3>\n    \n<div class=\"honbun g-fd4\">\n私達はお客様へよりよい「清潔」と「快適」をお届けするために、社員一人ひとりが安心して働け、能力を最大限に発揮できる職場環境づくりに積極的に取り組み、業務の更なる精度向上と効率化に努めてまいります。\n</div>\n<p class=\"more-bt g-fd4\"><a href=\"/company/\">View more</a></p>\n    \n<!--rbox--></div>\n    \n    \n\n    \n<!--cons--></div>   \n