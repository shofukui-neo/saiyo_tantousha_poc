{"url":"https://www.nds-infos.co.jp/recruit/works/discussion/","html":"\n<!doctype html>\n<html lang=\"ja\">\n\n<head>\n    <!--メタ情報 -->\n    <meta charset=\"UTF-8\">\n\n    <meta http-equiv=\"X-UA-Compatible\" content=\"IE=Edge\">\n    <meta name=\"viewport\" content=\"width=device-width\">\n    <meta name=\"format-detection\" content=\"telephone=no\">\n\n    <!-- slick -->\n    <link rel=\"stylesheet\" href=\"https://www.nds-infos.co.jp/recruit/assets/js/slick/slick.css\">\n    <link rel=\"stylesheet\" href=\"https://www.nds-infos.co.jp/recruit/assets/js/slick/slick-theme.css\">\n\n    <!-- css -->\n    <link rel=\"stylesheet\" href=\"https://www.nds-infos.co.jp/recruit/assets/css/style.css\">\n    <link href=\"https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700&family=Work+Sans:wght@700&display=swap\" rel=\"stylesheet\">\n\n    <link rel=\"shortcut icon\" href=\"/recruit/favicon.ico\">\n\n    <title>女性座談会 | 職場を知る | NDSインフォス 採用サイト</title>\n\n    <!-- og -->\n    <meta property=\"og:site_name\" content=\"NDSインフォス 採用サイト\">\n    <meta property=\"og:image\" content=\"https://www.nds-infos.co.jp/recruit/assets/img/common/ogp.jpg\">\n    <meta property=\"og:type\" content=\"website\">\n    <meta name=\"description\" content=\"NDSインフォスの女性座談会をご紹介します。\">\n    <meta property=\"og:url\" content=\"https://www.nds-infos.co.jp/recruit/works/discussion/\">\n    <meta property=\"og:title\" content=\"女性座談会 | 職場を知る | NDSインフォス 採用サイト\">\n    <meta property=\"og:description\" content=\"NDSインフォスの女性座談会をご紹介します。\">\n\n    <!-- TwitterCard -->\n    <meta name=\"twitter:card\" content=\"summary_large_image\">\n    <meta name=\"twitter:image\" content=\"https://www.nds-infos.co.jp/recruit/assets/img/common/ogp.jpg\">\n    <meta name=\"twitter:url\" content=\"https://www.nds-infos.co.jp/recruit/works/discussion/\">\n    <meta name=\"twitter:title\" content=\"女性座談会 | 職場を知る | NDSインフォス 採用サイト\">\n    <meta name=\"twitter:description\" content=\"NDSインフォスの女性座談会をご紹介します。\">\n\n</head>\n\n<body>\n<!-- Sibulla tracking code start -->\n<script type=\"text/javascript\"><!--\n(function(){ var b = document.getElementsByTagName('script')[0],sib = document.createElement('script');\nsib.type = 'text/javascript';sib.async = true;\nsib.src = ('https:' == document.location.protocol ? 'https://' : 'http://') + 'wv004.sibulla.com/dekatag/access?id=Mz0aXmbZ';\nb.parentNode.insertBefore(sib,b);}());\n//--></script>\n<!-- /Sibulla tracking code end -->\n    <!--ヘッダー-->\n    <header class=\"header\">\n        <div class=\"header-layout\">\n            <div class=\"header-inner\">\n                <div class=\"header-logo logo\">\n                    <a href=\"/recruit/\" class=\"logo-link\">\n                        <img src=\"https://www.nds-infos.co.jp/recruit/assets/img/common/logo-site.png\" alt=\"NDSインフォス 採用サイト\" width=\"118\" class=\"logo-img\">\n                    </a>\n                </div>\n                <div class=\"header-nav\">\n                    <nav class=\"nav\">\n                        <ul class=\"nav-list\">\n                            <li class=\"nav-item\">\n                                <a href=\"/recruit/company/\" class=\"nav-link nav-sp-none \">会社を知る</a>\n                                <div class=\"nav-link nav-pc-none\">会社を知る</div>\n                                <div class=\"megamenu\">\n                                    <ul class=\"megamenu-list\">\n                                        <li class=\"megamenu-item\">\n                                            <a href=\"/recruit/company/ict_se/\" class=\"megamenu-link\">ICT業界の魅力</a>\n                                        </li>\n                                        <li class=\"megamenu-item\">\n                                            <a href=\"/recruit/company/strong-points/\" class=\"megamenu-link\">NDSインフォスの強み</a>\n                                        </li>\n                                        <li class=\"megamenu-item\">\n                                            <a href=\"/recruit/company/se/\" class=\"megamenu-link\">SEの仕事</a>\n                                        </li>\n                                    </ul>\n                                </div>\n                            </li>\n                            <li class=\"nav-item\">\n                                <a href=\"/recruit/job/\" class=\"nav-link \">仕事を知る</a>\n                            </li>\n                            <li class=\"nav-item\">\n                                <a href=\"/recruit/member/\" class=\"nav-link \">社員を知る</a>\n                            </li>\n                            <li class=\"nav-item\">\n                                <a href=\"/recruit/works/\" class=\"nav-link nav-sp-none nav-link-current\">職場を知る</a>\n                                <div class=\"nav-link nav-pc-none\">職場を知る</div>\n                                <div class=\"megamenu\">\n                                    <ul class=\"megamenu-list\">\n                                        <li class=\"megamenu-item\">\n                                            <a href=\"/recruit/works/welfare/\" class=\"megamenu-link\">福利厚生</a>\n                                        </li>\n                                        <li class=\"megamenu-item\">\n                                            <a href=\"/recruit/works/education/\" class=\"megamenu-link\">教育体制</a>\n                                        </li>\n                                        <li class=\"megamenu-item\">\n                                            <a href=\"/recruit/works/work-style-reform/\" class=\"megamenu-link\">働き方改善</a>\n                                        </li>\n                                        <li class=\"megamenu-item\">\n                                            <a href=\"/recruit/works/care/\" class=\"megamenu-link\">育児・介護支援</a>\n                                        </li>\n                                        <li class=\"megamenu-item\">\n                                            <a href=\"/recruit/works/discussion/\" class=\"megamenu-link\">女性座談会</a>\n                                        </li>\n                                        <li class=\"megamenu-item\">\n                                            <a href=\"/recruit/works/question/\" class=\"megamenu-link\">Q&A</a>\n                                        </li>\n                                    </ul>\n                                </div>\n                            </li>\n                            <li class=\"nav-item\">\n                                <a href=\"/recruit/information/\" class=\"nav-link nav-sp-none \">採用情報</a>\n                                <div class=\"nav-link nav-pc-none\">採用情報</div>\n                                <div class=\"megamenu\">\n                                    <ul class=\"megamenu-list\">\n                                        <li class=\"megamenu-item\">\n                                            <a href=\"/recruit/information/\" class=\"megamenu-link\">採用情報</a>\n                                        </li>\n                                        <li class=\"megamenu-item\">\n                                            <a href=\"/recruit/information/new-graduates/\" class=\"megamenu-link\">新卒採用情報</a>\n                                        </li>\n                                    </ul>\n                                </div>\n                            </li>\n                        </ul>\n                    </nav>\n                </div>\n                <div class=\"header-btn\">\n                    <button class=\"headerBtn\">\n                        <span class=\"headerBtn-icon headerBtn-top\"></span>\n                        <span class=\"headerBtn-icon headerBtn-middle\"></span>\n                        <span class=\"headerBtn-icon headerBtn-bottom\"></span>\n                    </button>\n                </div>\n                <div class=\"header-entryBtn\">\n                    <a class=\"header-entryBtn-link\" href=\"https://job.mynavi.jp/27/pc/search/corp73705/outline.html\" target=\"_blank\"><span class=\"header-entryBtn-sp-none\">新卒採用</span>ENTRY</a>\n                </div>\n            </div>\n        </div>\n    </header>\n                        <div class=\"pageHeader\">\n                <div class=\"pageHeader-bg\">\n                    <img class=\"pageHeader-img display-sp-none\" src=\"https://www.nds-infos.co.jp/recruit/ndsinfos-sys/wp-content/uploads/2022/09/main-18.jpg\" alt=\"\">\n                    <img class=\"pageHeader-img display-pc-none\" src=\"https://www.nds-infos.co.jp/recruit/ndsinfos-sys/wp-content/uploads/2022/09/main-sp-19.jpg\" alt=\"\">\n                </div>\n                <div class=\"pageHeader-inner\">\n                    <div class=\"pageHeader-wrap\">\n                        <div class=\"pageHeader-heading\">\n                            <h1 class=\"pageHeader-ttl\">女性座談会</h1>\n                            <p class=\"pageHeader-ttl-en\">Discussion</p>\n                        </div>\n                        <div class=\"pageHeader-tag\">\n\n                                                    </div>\n                    </div>\n                </div>\n            </div>\n        \n        <div class=\"pankuzu\">\n            <div class=\"container\">\n                <ul class=\"pankuzu-list\">\n                    <li class=\"pankuzu-item\">\n                        <a href=\"https://www.nds-infos.co.jp/recruit/\" class=\"pankuzu-link\">TOP</a>\n                    </li>\n                                            <li class=\"pankuzu-item\">\n                            <a href=\"https://www.nds-infos.co.jp/recruit/works/\" class=\"pankuzu-link\">職場を知る</a>\n                        </li>\n                                        <li class=\"pankuzu-item\">女性座談会</li>\n                </ul>\n            </div>\n        </div>\n\n        <main ><div class=\"discussion\">\r\n    <div class=\"container\">\r\n        <div class=\"discussion-member\">\r\n            <div class=\"discussion-member-figure\">\r\n                <img class=\"discussion-member-img\" src=\"../../assets/img/pages/works/discussion/img-member.jpg\" alt=\"\">\r\n            </div>\r\n            <div class=\"discussion-member-plofile\">\r\n                <div class=\"plofile\">\r\n                    <div class=\"plofile-card\">\r\n                        <div class=\"plofile-figure\">\r\n                            <img src=\"../../assets/img/pages/works/discussion/img-human01.png\" alt=\"\">\r\n                        </div>\r\n                        <div class=\"plofile-name\">山本 えりか</div>\r\n                        <p class=\"plofile-text2\">2009年入社</p>\r\n                    </div>\r\n                    <div class=\"plofile-card\">\r\n                        <div class=\"plofile-figure\">\r\n                            <img src=\"../../assets/img/pages/works/discussion/img-human02.png\" alt=\"\">\r\n                        </div>\r\n                        <div class=\"plofile-name\">東瀬 香織</div>\r\n                        <p class=\"plofile-text2\">2006年入社</p>\r\n                    </div>\r\n                    <div class=\"plofile-card\">\r\n                        <div class=\"plofile-figure\">\r\n                            <img src=\"../../assets/img/pages/works/discussion/img-human04.png\" alt=\"\">\r\n                        </div>\r\n                        <div class=\"plofile-name\">杉原 安耶香</div>\r\n                        <p class=\"plofile-text2\">2008年入社</p>\r\n                    </div>\r\n                    <div class=\"plofile-card\">\r\n                        <div class=\"plofile-figure\">\r\n                            <img src=\"../../assets/img/pages/works/discussion/img-human03.png\" alt=\"\">\r\n                        </div>\r\n                        <div class=\"plofile-name\">石原 愛理</div>\r\n                        <p class=\"plofile-text2\">2016年入社</p>\r\n                    </div>\r\n                    <div class=\"plofile-card\">\r\n                        <div class=\"plofile-figure\">\r\n                            <img src=\"../../assets/img/pages/works/discussion/img-human05.png\" alt=\"\">\r\n                        </div>\r\n                        <div class=\"plofile-name\">田貫 美也子</div>\r\n                        <p class=\"plofile-text2\">1998年入社</p>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n        </div>\r\n\r\n        <section class=\"discussion-section\">\r\n            <div class=\"discussion-heading discussion-heading-row discussion-heading-deco discussion-heading-deco-1\">\r\n                <div class=\"heading heading-l\">結婚や子育てを経験しながら<br>仕事のキャリアを<br>積んでいます。</div>\r\n                <div class=\"media\">\r\n                    <figure class=\"media-figure\">\r\n                        <img class=\"media-img\" src=\"../../assets/img/pages/works/discussion/img-01.jpg\" alt=\"\">\r\n                    </figure>\r\n                </div>\r\n            </div>\r\n            <div class=\"talk\">\r\n                <div class=\"talk-media\">\r\n                    <figure class=\"talk-figure\">\r\n                        <img class=\"talk-img\" src=\"../../assets/img/pages/works/discussion/img-human05.png\" alt=\"\">\r\n                    </figure>\r\n                    <p class=\"talk-name\">田貫</p>\r\n                </div>\r\n                <div class=\"talk-content\">\r\n                    <p class=\"talk-text\">\r\n                        私は1998年、NDSインフォスに分社化する前の日本電話施設時代に入社しました。SEや営業事務を経験して、育児休業の間に社名が変わって…。育休から戻ってきた時はNDSインフォスになっていました。今は経営企画部にて研修や社内イベントの企画を担当して、新入社員の研修も担当しています。\r\n                    </p>\r\n                </div>\r\n            </div>\r\n            <div class=\"talk talk-reverse\">\r\n                <div class=\"talk-media\">\r\n                    <figure class=\"talk-figure\">\r\n                        <img class=\"talk-img\" src=\"../../assets/img/pages/works/discussion/img-human02.png\" alt=\"\">\r\n                    </figure>\r\n                    <p class=\"talk-name\">東瀬</p>\r\n                </div>\r\n                <div class=\"talk-content\">\r\n                    <p class=\"talk-text\">\r\n                        私は2006年入社でNDSインフォスの1期生です。日本電話施設時代に入社試験を受けて、NDSインフォスで採用をいただきました。そういう意味では会社の大きな変化を見てきたと言えるかもしれません。現在は本社で一般企業や公共事業のシステム開発を担当しています。具体的には自治体のコールセンターの開発を担当し、お客様の要望を聞いて実現に向けて管理していく立場です。\r\n                    </p>\r\n                </div>\r\n            </div>\r\n            <div class=\"talk\">\r\n                <div class=\"talk-media\">\r\n                    <figure class=\"talk-figure\">\r\n                        <img class=\"talk-img\" src=\"../../assets/img/pages/works/discussion/img-human04.png\" alt=\"\">\r\n                    </figure>\r\n                    <p class=\"talk-name\">杉原</p>\r\n                </div>\r\n                <div class=\"talk-content\">\r\n                    <p class=\"talk-text\">\r\n                        私は2008年入社で、現在はブレーキの制御システムなど自動車関連の仕事に関わっています。その前は通信関連で医療系システムのメンテナンスや保守に関わっていました。\r\n                    </p>\r\n                </div>\r\n            </div>\r\n            <div class=\"talk talk-reverse\">\r\n                <div class=\"talk-media\">\r\n                    <figure class=\"talk-figure\">\r\n                        <img class=\"talk-img\" src=\"../../assets/img/pages/works/discussion/img-human01.png\" alt=\"\">\r\n                    </figure>\r\n                    <p class=\"talk-name\">山本</p>\r\n                </div>\r\n                <div class=\"talk-content\">\r\n                    <p class=\"talk-text\">\r\n                        私も杉原さんと同じ仕事で自動車のブレーキ制御システムに関わっています。私が所属するチームは20名ほど。その中でチームメンバーの管理を担当しています。ブレーキと言っても自動車メーカーごとに仕様が異なるので、それぞれの要望を反映させるのが重要な仕事です。\r\n                    </p>\r\n                </div>\r\n            </div>\r\n            <div class=\"talk\">\r\n                <div class=\"talk-media\">\r\n                    <figure class=\"talk-figure\">\r\n                        <img class=\"talk-img\" src=\"../../assets/img/pages/works/discussion/img-human03.png\" alt=\"\">\r\n                    </figure>\r\n                    <p class=\"talk-name\">石原</p>\r\n                </div>\r\n                <div class=\"talk-content\">\r\n                    <p class=\"talk-text\">\r\n                        私は2016年にSEとして入社しました。今は電話回線を接続する交換機のシステム開発に関わっています。\r\n                    </p>\r\n                </div>\r\n            </div>\r\n            <div class=\"talk-row\">\r\n                <div class=\"talk-sub\">\r\n                    <img class=\"talk-img\" src=\"../../assets/img/pages/works/discussion/img-02.jpg\" alt=\"\">\r\n                </div>\r\n                <div class=\"talk-main\">\r\n                    <div class=\"talk talk-reverse\">\r\n                        <div class=\"talk-media\">\r\n                            <figure class=\"talk-figure\">\r\n                                <img class=\"talk-img\" src=\"../../assets/img/pages/works/discussion/img-human01.png\" alt=\"\">\r\n                            </figure>\r\n                            <p class=\"talk-name\">山本</p>\r\n                        </div>\r\n                        <div class=\"talk-content\">\r\n                            <p class=\"talk-text\">\r\n                                私はコロナ禍になってから基本テレワークです。みなさんはどうですか？\r\n                            </p>\r\n                        </div>\r\n                    </div>\r\n                    <div class=\"talk\">\r\n                        <div class=\"talk-media\">\r\n                            <figure class=\"talk-figure\">\r\n                                <img class=\"talk-img\" src=\"../../assets/img/pages/works/discussion/img-human05.png\" alt=\"\">\r\n                            </figure>\r\n                            <p class=\"talk-name\">田貫</p>\r\n                        </div>\r\n                        <div class=\"talk-content\">\r\n                            <p class=\"talk-text\">\r\n                                私は通常勤務で9時出社して17時30分に退社しています。残業はほとんどなくて、あっても1日１時間程度です。コロナが落ち着いている今はテレワークではありませんが、家族が感染した場合など、すぐにテレワークに切り替える環境は整えていますよ。\r\n                            </p>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n        </section>\r\n\r\n        <section class=\"discussion-section\">\r\n            <div class=\"discussion-heading discussion-heading-row discussion-heading-deco discussion-heading-deco-2\">\r\n                <div class=\"heading heading-l\">仕事と育児が両立できるのは<br>会社のサポートや仲間の<br>理解があるから！</div>\r\n                <div class=\"media\">\r\n                    <figure class=\"media-figure\">\r\n                        <img class=\"media-img\" src=\"../../assets/img/pages/works/discussion/img-03.jpg\" alt=\"\">\r\n                    </figure>\r\n                </div>\r\n            </div>\r\n            <div class=\"talk\">\r\n                <div class=\"talk-media\">\r\n                    <figure class=\"talk-figure\">\r\n                        <img class=\"talk-img\" src=\"../../assets/img/pages/works/discussion/img-human02.png\" alt=\"\">\r\n                    </figure>\r\n                    <p class=\"talk-name\">東瀬</p>\r\n                </div>\r\n                <div class=\"talk-content\">\r\n                    <p class=\"talk-text\">\r\n                        田貫さんは育児と仕事の両立はどうしていますか？\r\n                    </p>\r\n                </div>\r\n            </div>\r\n            <div class=\"talk talk-reverse\">\r\n                <div class=\"talk-media\">\r\n                    <figure class=\"talk-figure\">\r\n                        <img class=\"talk-img\" src=\"../../assets/img/pages/works/discussion/img-human05.png\" alt=\"\">\r\n                    </figure>\r\n                    <p class=\"talk-name\">田貫</p>\r\n                </div>\r\n                <div class=\"talk-content\">\r\n                    <p class=\"talk-text\">\r\n                        私は子どもが３人いて、上の２人は高校生で、３人目が小学生になりますが、3人ともすべて育児休業を取得しています。1人目の育児休業中にＮＤＳインフォスが設立されたので、おそらく初めて育児休業を取得したのが私だったと思います。今でも、子供が発熱したらテレワークにしてもらったり、学校行事の際は、時間年休を使って１時間単位で休みを取ったりするなど、制度をフレキシブルに活用しています。例えば、授業参観の時は、その時間だけ年休を取って、自宅に帰ってからテレワークで仕事しています。\r\n                    </p>\r\n                </div>\r\n            </div>\r\n            <div class=\"talk\">\r\n                <div class=\"talk-media\">\r\n                    <figure class=\"talk-figure\">\r\n                        <img class=\"talk-img\" src=\"../../assets/img/pages/works/discussion/img-human02.png\" alt=\"\">\r\n                    </figure>\r\n                    <p class=\"talk-name\">東瀬</p>\r\n                </div>\r\n                <div class=\"talk-content\">\r\n                    <p class=\"talk-text\">\r\n                        働く女性に対して理解ある会社だと思います。女性社員が増えて、さらに小さな子どもがいる男性社員も多いので、みんな子育てしながら働く女性の大変さを理解してくれます。私も３人の子どもがいて、上が小学3年生で、下は３歳と１歳。上２人まではフルタイム勤務でしたが、３人目の復帰からは時短勤務にしています。\r\n                    </p>\r\n                </div>\r\n            </div>\r\n            <div class=\"talk talk-reverse\">\r\n                <div class=\"talk-media\">\r\n                    <figure class=\"talk-figure\">\r\n                        <img class=\"talk-img\" src=\"../../assets/img/pages/works/discussion/img-human01.png\" alt=\"\">\r\n                    </figure>\r\n                    <p class=\"talk-name\">山本</p>\r\n                </div>\r\n                <div class=\"talk-content\">\r\n                    <p class=\"talk-text\">\r\n                        私はテレワークになるまでは子どもを保育園に預けている間しか働けませんでした。でも今はテレワークで通勤時間がなくなり、昼の休憩時間に家事ができて、家庭との両立がしやすくなりました。精神的な余裕も出てきたと思います。\r\n                    </p>\r\n                </div>\r\n            </div>\r\n            <div class=\"talk-row\">\r\n                <div class=\"talk-sub\">\r\n                    <img class=\"talk-img\" src=\"../../assets/img/pages/works/discussion/img-04.jpg\" alt=\"\">\r\n                </div>\r\n                <div class=\"talk-main\">\r\n                    <div class=\"talk talk-reverse\">\r\n                        <div class=\"talk-media\">\r\n                            <figure class=\"talk-figure\">\r\n                                <img class=\"talk-img\" src=\"../../assets/img/pages/works/discussion/img-human03.png\" alt=\"\">\r\n                            </figure>\r\n                            <p class=\"talk-name\">石原</p>\r\n                        </div>\r\n                        <div class=\"talk-content\">\r\n                            <p class=\"talk-text\">\r\n                                私は通常出社ですが、時差出勤を活用していますよ。時差出勤は常駐先の会社によって制度が異なりますね。\r\n                            </p>\r\n                        </div>\r\n                    </div>\r\n                    <div class=\"talk\">\r\n                        <div class=\"talk-media\">\r\n                            <figure class=\"talk-figure\">\r\n                                <img class=\"talk-img\" src=\"../../assets/img/pages/works/discussion/img-human02.png\" alt=\"\">\r\n                            </figure>\r\n                            <p class=\"talk-name\">東瀬</p>\r\n                        </div>\r\n                        <div class=\"talk-content\">\r\n                            <p class=\"talk-text\">\r\n                                常駐先の働き方に合わせる必要はありますが、テレワークや時短・時差勤務など働き方を選べるのはいいですね。基本的に育休後は所属していた部署に復帰できるので、仕事再開もスムーズでした。\r\n                            </p>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n            <div class=\"talk talk-reverse\">\r\n                <div class=\"talk-media\">\r\n                    <figure class=\"talk-figure\">\r\n                        <img class=\"talk-img\" src=\"../../assets/img/pages/works/discussion/img-human01.png\" alt=\"\">\r\n                    </figure>\r\n                    <p class=\"talk-name\">山本</p>\r\n                </div>\r\n                <div class=\"talk-content\">\r\n                    <p class=\"talk-text\">\r\n                        私も同じ職場に復帰したんですが、同じ仕事でもやり方やスタッフが変わっていたのでしばらくは慣れるのに大変でした。しかし、復帰当初は休むことが多かった私を誰も嫌な顔ひとつしないでフォローしてくれたので本当にありがたかったですね。\r\n                    </p>\r\n                </div>\r\n            </div>\r\n            <div class=\"talk\">\r\n                <div class=\"talk-media\">\r\n                    <figure class=\"talk-figure\">\r\n                        <img class=\"talk-img\" src=\"../../assets/img/pages/works/discussion/img-human05.png\" alt=\"\">\r\n                    </figure>\r\n                    <p class=\"talk-name\">田貫</p>\r\n                </div>\r\n                <div class=\"talk-content\">\r\n                    <p class=\"talk-text\">\r\n                        男性だから女性だからという差を感じることもほとんどありません。\r\n                    </p>\r\n                </div>\r\n            </div>\r\n            <div class=\"talk talk-reverse\">\r\n                <div class=\"talk-media\">\r\n                    <figure class=\"talk-figure\">\r\n                        <img class=\"talk-img\" src=\"../../assets/img/pages/works/discussion/img-human02.png\" alt=\"\">\r\n                    </figure>\r\n                    <p class=\"talk-name\">東瀬</p>\r\n                </div>\r\n                <div class=\"talk-content\">\r\n                    <p class=\"talk-text\">\r\n                        そうですね。女性が少ない職場ですが、だからといって肩身の狭い想いをしたこともないですし。\r\n                    </p>\r\n                </div>\r\n            </div>\r\n        </section>\r\n        <section class=\"discussion-section\">\r\n            <div class=\"discussion-heading\">\r\n                <div class=\"media\">\r\n                    <figure class=\"media-figure\">\r\n                        <img class=\"media-img\" src=\"../../assets/img/pages/works/discussion/img-05.jpg\" alt=\"\">\r\n                    </figure>\r\n                </div>\r\n                <div class=\"heading heading-l align-center\">これからの目標は<br>仕事をがんばりながら、家庭や自分の時間も守ること！</div>\r\n            </div>\r\n            <div class=\"talk\">\r\n                <div class=\"talk-media\">\r\n                    <figure class=\"talk-figure\">\r\n                        <img class=\"talk-img\" src=\"../../assets/img/pages/works/discussion/img-human05.png\" alt=\"\">\r\n                    </figure>\r\n                    <p class=\"talk-name\">田貫</p>\r\n                </div>\r\n                <div class=\"talk-content\">\r\n                    <p class=\"talk-text\">\r\n                        私の家庭では夫にたくさん協力をしてもらっているので、これからも上手にバランスをとって仕事と家庭を両立させたいと思っています。<br>それと子育てと仕事を両立してきた経験者として、社員の皆さんから相談ごとがあれば、アドバイスもしていきたいと思っています。\r\n                    </p>\r\n                </div>\r\n            </div>\r\n            <div class=\"talk talk-reverse\">\r\n                <div class=\"talk-media\">\r\n                    <figure class=\"talk-figure\">\r\n                        <img class=\"talk-img\" src=\"../../assets/img/pages/works/discussion/img-human04.png\" alt=\"\">\r\n                    </figure>\r\n                    <p class=\"talk-name\">杉原</p>\r\n                </div>\r\n                <div class=\"talk-content\">\r\n                    <p class=\"talk-text\">\r\n                        私も家庭とのバランスが取れるようになりたいと思っています。今は慣れない職場で少し残業が増えているので、少しでも早く仕事に慣れて上手に業務をこなせるようになりたいです。\r\n                    </p>\r\n                </div>\r\n            </div>\r\n            <div class=\"talk\">\r\n                <div class=\"talk-media\">\r\n                    <figure class=\"talk-figure\">\r\n                        <img class=\"talk-img\" src=\"../../assets/img/pages/works/discussion/img-human02.png\" alt=\"\">\r\n                    </figure>\r\n                    <p class=\"talk-name\">東瀬</p>\r\n                </div>\r\n                <div class=\"talk-content\">\r\n                    <p class=\"talk-text\">\r\n                        うちの場合、家事は夫と分担しています。今後は仕事面での活躍を目指したいです。ゆくゆくはチームを統括できるプロジェクトマネージャーになって、さまざまなお客様の案件に関わっていきたいです。\r\n                    </p>\r\n                </div>\r\n            </div>\r\n            <div class=\"talk talk-reverse\">\r\n                <div class=\"talk-media\">\r\n                    <figure class=\"talk-figure\">\r\n                        <img class=\"talk-img\" src=\"../../assets/img/pages/works/discussion/img-human01.png\" alt=\"\">\r\n                    </figure>\r\n                    <p class=\"talk-name\">山本</p>\r\n                </div>\r\n                <div class=\"talk-content\">\r\n                    <p class=\"talk-text\">\r\n                        私は現在チームリーダーとして勤務していますが、スケジュール管理やメンバーのフォローなど、まだまだ力不足を感じます。リーダーとしてのスキルを高めて、プライベートでは自分の時間が取れるようにしたいです。私の夫も家事分担に協力的なんですが、いつも慌ただしいので・・・。\r\n                    </p>\r\n                </div>\r\n            </div>\r\n            <div class=\"talk\">\r\n                <div class=\"talk-media\">\r\n                    <figure class=\"talk-figure\">\r\n                        <img class=\"talk-img\" src=\"../../assets/img/pages/works/discussion/img-human03.png\" alt=\"\">\r\n                    </figure>\r\n                    <p class=\"talk-name\">石原</p>\r\n                </div>\r\n                <div class=\"talk-content\">\r\n                    <p class=\"talk-text\">\r\n                        そうですね！私も家庭での時間を作りたいと思っています。プロジェクトリーダーを任されたのですが、まだ周りのメンバーに助けられてばかり。うまく回せるようになって、自分の時間も大切にできるようになりたいです。\r\n                    </p>\r\n                </div>\r\n            </div>\r\n        </section>\r\n    </div>\r\n</div>                <div class=\"container\">\n                    <section class=\"cards-section\">\n                        <h3 class=\"heading heading-xl heading-border2\">職場を知る</h3>\n                        <div class=\"cards\">\n                            <div class=\"cards-list cards-list-3\">\n                                                                <div class=\"cards-item\">\n                                    <div class=\"card\">\n                                        <a class=\"card-link\" href=\"https://www.nds-infos.co.jp/recruit/works/welfare/\">\n                                            <div class=\"card-thumbnail\">\n                                                <img src=\"https://www.nds-infos.co.jp/recruit/ndsinfos-sys/wp-content/uploads/2022/09/img-thumbnail-welfare.jpg\" alt=\"\"\n                                                    class=\"card-image\">\n                                            </div>\n                                            <h4 class=\"card-title\">福利厚生</h4>\n                                        </a>\n                                    </div>\n                                </div><!-- cards-item -->\n                                                                <div class=\"cards-item\">\n                                    <div class=\"card\">\n                                        <a class=\"card-link\" href=\"https://www.nds-infos.co.jp/recruit/works/education/\">\n                                            <div class=\"card-thumbnail\">\n                                                <img src=\"https://www.nds-infos.co.jp/recruit/ndsinfos-sys/wp-content/uploads/2022/09/img-thumbnail-education.jpg\" alt=\"\"\n                                                    class=\"card-image\">\n                                            </div>\n                                            <h4 class=\"card-title\">教育体制</h4>\n                                        </a>\n                                    </div>\n                                </div><!-- cards-item -->\n                                                                <div class=\"cards-item\">\n                                    <div class=\"card\">\n                                        <a class=\"card-link\" href=\"https://www.nds-infos.co.jp/recruit/works/work-style-reform/\">\n                                            <div class=\"card-thumbnail\">\n                                                <img src=\"https://www.nds-infos.co.jp/recruit/ndsinfos-sys/wp-content/uploads/2022/09/img-thumbnail-wsr.jpg\" alt=\"\"\n                                                    class=\"card-image\">\n                                            </div>\n                                            <h4 class=\"card-title\">働き方改革</h4>\n                                        </a>\n                                    </div>\n                                </div><!-- cards-item -->\n                                                                <div class=\"cards-item\">\n                                    <div class=\"card\">\n                                        <a class=\"card-link\" href=\"https://www.nds-infos.co.jp/recruit/works/care/\">\n                                            <div class=\"card-thumbnail\">\n                                                <img src=\"https://www.nds-infos.co.jp/recruit/ndsinfos-sys/wp-content/uploads/2022/09/img-thumbnail-04-1.jpg\" alt=\"\"\n                                                    class=\"card-image\">\n                                            </div>\n                                            <h4 class=\"card-title\">育児・介護支援</h4>\n                                        </a>\n                                    </div>\n                                </div><!-- cards-item -->\n                                                                <div class=\"cards-item\">\n                                    <div class=\"card\">\n                                        <a class=\"card-link\" href=\"https://www.nds-infos.co.jp/recruit/works/discussion/\">\n                                            <div class=\"card-thumbnail\">\n                                                <img src=\"https://www.nds-infos.co.jp/recruit/ndsinfos-sys/wp-content/uploads/2022/09/img-thumbnail-05.jpg\" alt=\"\"\n                                                    class=\"card-image\">\n                                            </div>\n                                            <h4 class=\"card-title\">女性座談会</h4>\n                                        </a>\n                                    </div>\n                                </div><!-- cards-item -->\n                                                                <div class=\"cards-item\">\n                                    <div class=\"card\">\n                                        <a class=\"card-link\" href=\"https://www.nds-infos.co.jp/recruit/works/question/\">\n                                            <div class=\"card-thumbnail\">\n                                                <img src=\"https://www.nds-infos.co.jp/recruit/ndsinfos-sys/wp-content/uploads/2022/09/img-thumbnail-qa-1.jpg\" alt=\"\"\n                                                    class=\"card-image\">\n                                            </div>\n                                            <h4 class=\"card-title\">Q&amp;A</h4>\n                                        </a>\n                                    </div>\n                                </div><!-- cards-item -->\n                                                            </div><!-- cards-list -->\n                        </div><!-- cards -->\n                    </section>\n                </div>\n            </main>\n\n<!--フッター-->\n<footer class=\"footer\">\n    <div class=\"footer-entry\">\n        <p class=\"footer-entry-text\">\n            NDSインフォス株式会社では<br>\n            新たな「チーム」のメンバーを求めています。\n        </p>\n        <a class=\"footer-entry-btn\" href=\"https://job.mynavi.jp/27/pc/search/corp73705/outline.html\" target=\"_blank\" rel=\"noopener\">新卒採用ENTRY</a>\n\n　　<div class=\"footer-youtube\">\n        <iframe src=\"https://www.youtube-nocookie.com/embed/IX7CyQNXgP0\"\n            title=\"【NDSインフォス株式会社】私たちの会社、紹介します！\"\n            frameborder=\"0\"\n            allow=\"accelerometer; encrypted-media; gyroscope; picture-in-picture\"\n            allowfullscreen>\n      