       <p><a href=\"/sitemap/\">サイトマップ</a></p>\r\n          <div id=\"fontSize\">\r\n            <noscript><p>JavaScriptを使用しています。</p></noscript>\r\n            文字サイズ\r\n            <ul>\r\n              <li class=\"changeBtn\">小</li>\r\n              <li class=\"changeBtn\">中</li>\r\n              <li class=\"changeBtn\">大</li>\r\n            </ul>\r\n          </div>\r\n        </div>\r\n      </div><!-- //header -->\r\n\r\n      <nav id=\"nav\">\r\n        <ul>\r\n          <li class=\"nav01\"><a href=\"/\">トップページ<span>TOP PAGE</span></a></li>\r\n          <li class=\"nav02\"><a href=\"/corp_info/\">会社情報<span>CORPORATE INFORMATION</span></a></li>\r\n          <li class=\"nav03\"><a href=\"/corp_outline/\">会社概要<span>COMPANY PROFILE</span></a></li>\r\n          <li class=\"nav04\"><a href=\"/business/\">事業内容<span>BUSINESS CONTENTS</span></a></li>\r\n          <li class=\"nav05\">\r\n            <a href=\"javascript:void(0);\">採用情報<span>CAREER</span></a>\r\n            <ul class=\"nav--sub\">\r\n              <li><a href=\"/business_2/\">料金所スタッフ採用情報</a></li>\r\n              <li>\r\n                <a href=\"https://tenshoku.mynavi.jp/jobinfo-426307-3-6-1/?msockid=3d319ca12add6b111ec189be2b0f6a58\" target=\"_blank\" title=\"新しいウインドウが開きます。\" rel=\"noopener noreferrer\">\r\n                  本社採用情報\r\n                  <img src=\"/common/img/blank_icon--white.svg\" width=\"11\" height=\"10\" alt=\"\" class=\"blank\">\r\n                  <span class=\"note\">（マイナビ転職に移動します）</span>\r\n                </a>\r\n              </li>\r\n            </ul>\r\n          </li>\r\n        </ul>\r\n      </nav>\r\n\r\n    </header>\r\n\r\n\r\n\r\n\r\n<div id=\"changeArea\">\r\n<div id=\"main\">\r\n<!-- InstanceBeginEditable name=\"EditRegion3\" -->\r\n<h2><img src=\"img/corpinfo_h2.jpg\" width=\"950\" height=\"123\" alt=\"会社情報\" /></h2>\r\n<div class=\"clearfix mt25\">\r\n\t<div class=\"content\">\r\n\t\t<h3><img src=\"img/index03_tit01.jpg\" width=\"680\" height=\"41\" alt=\"人材育成\" /></h3>\r\n\t\t<p class=\"mt20\"><img src=\"img/index03_img01.jpg\" width=\"680\" height=\"30\" alt=\"お客さまへのサービス向上のために、人材育成に力を入れています。\" /></p>\r\n\r\n\t\t<div class=\"corp_info_box01 mt25\">\r\n\t\t\t<p class=\"mt25\"><img src=\"img/index03_img02.jpg\" width=\"235\" height=\"20\" alt=\"新人研修など\" /></p>\r\n\t\t\t<p class=\"mt15 l160\">入社後、収受業務に必要な知識やスキルを身につけるために、新人研修、OJT研修を実施しています。<br />また、料金所スタッフとして必要な知識や技能のレベルアップを目的とした、階層別研修等も実施しています。</p>\r\n\t\t</div>\r\n\r\n\t\t<p class=\"mt25\"><img src=\"img/index03_img06.jpg\" width=\"235\" height=\"20\" alt=\"接客状況調査\" /></p>\r\n\t\t<p class=\"mt15 l160\">料金所スタッフのお客さま対応スキルをレベルアップさせるため、専門業者もしくは自社社員が料金所を巡り調査する「接客状況調査」を毎月実施し、接客技術の向上を目指しています。<br />また年に2回程度、外部講師による接客技術の向上を図る研修を行っています。</p>\r\n\t\t\r\n\t\t<div class=\"clearfix mt30\">\r\n\t\t\t<img src=\"img/index03_img03_v2.jpg\" width=\"210\" height=\"142\" alt=\"\" class=\"f_left\" />\r\n\t\t\t<img src=\"img/index03_img04_v2.jpg\" width=\"210\" height=\"142\" alt=\"\" class=\"f_left ml25\" />\r\n\t\t\t<img src=\"img/index03_img05_v2.jpg\" width=\"210\" height=\"142\" alt=\"\" class=\"f_left ml25\" />\r\n\t\t</div>\r\n\r\n\t</div><!-- //content -->\r\n\r\n  <div id=\"side\" class=\"menu1-3\">\r\n      <p class=\"side--title\">\r\n        会社情報\r\n        <span>CORPORATE INFORMATION</span>\r\n      </p>\r\n      <ul>\r\n        <li class=\"menu1-1\"><a href=\"/corp_info/\">会社情報</a></li>\r\n        <li class=\"menu1-2\"><a href=\"/corp_info/index02.html\">社会貢献活動</a></li>\r\n        <li class=\"menu1-3\"><a href=\"/corp_info/index03.html\">人材育成</a></li>\r\n        <li class=\"menu1-4\">\r\n          <a href=\"/corp_info/pdf/career.pdf?v=202507\" target=\"_blank\" title=\"PDFファイルが開きます。\" rel=\"noopener noreferrer\">\r\n          労働施策総合推進法に基づく<br />中途採用比率の公表\r\n          <img src=\"/common/img/icon_pdf.gif\" width=\"16\" height=\"16\" alt=\"\"/>\r\n          </a>\r\n        </li>\r\n      </ul>\r\n\r\n  </div><!-- //side -->\r\n\r\n</div>\r\n<!-- InstanceEndEditable -->\r\n</div><!-- //main -->\r\n</div><!-- //changeArea -->\r\n\r\n<div id=\"pagetop\"><p><a href=\"#top\"><img src=\"/common/img/pagetop.jpg\" width=\"170\" height=\"26\" alt=\"ページトップへ戻る\" class=\"rollover\" /></a></p></div>\r\n<div id=\"footer\">\r\n\t<p><a href=\"/\">トップページ</a>　｜　\r\n    <a href=\"/corp_info/\">会社情報</a>　｜　\r\n    <a href=\"/corp_outline/\">会社概要</a>　｜　\r\n    <a href=\"/business/\">事業内容</a>　｜　\r\n    <a href=\"/news\">お知らせ</a>　｜　\r\n    <a href=\"/link/\">お役立ちリンク集</a>　｜　\r\n    <a href=\"/sitemap/\">サイトマップ</a>　｜　\r\n    <a href=\"/security/\">セキュリティポリシー</a>　｜　\r\n    <a href=\"/privacy/\">個人情報保護方針</a></p>\r\n</div><!-- //footer -->\r\n<div id=\"copyright\"><p>Copyright(c) Hanshin Expressway Toll KOBE Co., Ltd. All rights reserved.</p></div>\r\n\r\n<script type=\"text/javascript\" src=\"../common/js/jquery/jquery.min.js\"></script>\r\n<script type=\"text/javascript\" src=\"../common/js/fontsizechange.js\"></script>\r\n<script type=\"text/javascript\" src=\"../common/js/jquery.cookie.js\"></script>\r\n<script type=\"text/javascript\" src=\"../common/js/jquery.rollover.js\"></script>\r\n<script type=\"text/javascript\" src=\"../common/js/common.js\"></script>\r\n<!-- InstanceBeginEditable name=\"js\" -->\r\n<!-- InstanceEndEditable -->\r\n<script type=\"text/javascript\" src=\"/_Incapsula_Resource?SWJIYLWA=719d34d31c8e3a6e6fffd425f7e032f3&ns=8&cb=975276414\" async></script></body>\r\n<!-- InstanceEnd --></html>\r\n","finalUrl":"https://www.hanshin-tollkobe.co.jp/corp_info/index03.html","rendered":false,"_cachedAt":"2026-06-22T17:43:18.595Z"}