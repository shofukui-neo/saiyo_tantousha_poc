letagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\r\n})(window,document,'script','dataLayer','GTM-TLWT6JLC');</script>\r\n<!-- End Google Tag Manager --><link href=\"../css/service.css\" rel=\"stylesheet\" type=\"text/css\">\r\n</head>\r\n\r\n<body>\r\n<section class=\"bg_imgbox\">\r\n<div class=\"title_box\">\r\n<h2 class=\"page_title\">Services</h2>\r\n<p class=\"page_sub_title\">仕事を知る</p>\r\n</div>\r\n\r\n<div class=\"scroll_bar\">\r\n<a href=\"#\"></a>\r\n</div>\r\n<!--end bg_imgbox -->\r\n</section>\r\n\r\n<header id=\"header\">\r\n<h1 class=\"header_logo\"><a href=\"../index.php\"><img src=\"../img/common/head_logo.svg\" alt=\"ネクスト・ワン株式会社 採用特設サイト\"/></a></h1>\r\n\r\n<nav class=\"g_navi\">\r\n<ul>\r\n<li><a href=\"../message/\"><span class=\"roll_txt\"><span class=\"en\">MESSAGE</span><span class=\"ja\">メッセージ</span></span></a></li>\r\n<li><a href=\"../company/\"><span class=\"roll_txt\"><span class=\"en\">COMPANY</span><span class=\"ja\">会社を知る</span></span></a></li>\r\n<li><a href=\"../service/\"><span class=\"roll_txt\"><span class=\"en\">SERVICE</span><span class=\"ja\">仕事を知る</span></span></a></li>\r\n<li><a href=\"../interview/\"><span class=\"roll_txt\"><span class=\"en\">INTERVIEW</span><span class=\"ja\">人を知る</span></span></a></li>\r\n<li><a href=\"../culture/\"><span class=\"roll_txt\"><span class=\"en\">CULTURE</span><span class=\"ja\">環境・制度</span></span></a></li>\r\n<li><a href=\"../faq/\"><span class=\"roll_txt\"><span class=\"en\">FAQ</span><span class=\"ja\">質問</span></span></a></li>\r\n<li><a href=\"../contact/\"><span class=\"roll_txt\"><span class=\"en\">CONTACT</span><span class=\"ja navi_contact\">お問い合わせ</span></span></a></li>\r\n</ul>\r\n\r\n<div class=\"entry_box\">\r\n<a href=\"../entry/\">\r\n<span class=\"roll_txt\">\r\n<span class=\"en\">ENTRY</span>\r\n<span class=\"ja\">エントリー</span>\r\n</span>\r\n</a>\r\n</div>\r\n</nav>\r\n</header>\r\n\r\n\r\n<div class=\"openbtn\"><span></span><span></span><span></span></div>\r\n<nav id=\"open_navi\">\r\n<div class=\"open_navi_list\">\r\n<p class=\"ham_logo\"><img src=\"../img/common/ham_logo.svg\" alt=\"\"/></p>\r\n<ul>\r\n<li><a href=\"../\">TOP<span class=\"ham_menu_ja\">トップ</span></a></li> \r\n<li><a href=\"../message/\">MESSAGE<span class=\"ham_menu_ja\">メッセージ</span></a></li>\r\n<li><a href=\"../company/\">COMPANY<span class=\"ham_menu_ja\">会社を知る</span></a></li> \r\n<li><a href=\"../service/\">SERVICE<span class=\"ham_menu_ja\">仕事を知る</span></a></li> \r\n<li><a href=\"../interview/\">INTERVIEW<span class=\"ham_menu_ja\">人を知る</span></a></li>\r\n<li><a href=\"../culture/\">CULTURE<span class=\"ham_menu_ja\">環境・制度</span></a></li> \r\n<li><a href=\"../faq/\">FAQ<span class=\"ham_menu_ja\">よくあるご質問</span></a></li> \r\n<li><a href=\"../contact/\">CONTACT<span class=\"ham_menu_ja\">お問い合わせ</span></a></li> \r\n<li><a href=\"../entry/\">ENTRY<span class=\"ham_menu_ja\">エントリー</span></a></li> \r\n</ul>\r\n</div>\r\n</nav>\r\n<main>\r\n<div class=\"content page_service\">\r\n<section class=\"box box_m\">\r\n<h3 class=\"intro_title\">部署間の連携が育むプロフェッショナルの仕事</h3>\r\n\r\n<p class=\"page_dis_txt\">私たちネクスト・ワンは、各部署が誇る高い専門性・技術・知識を縦横に連携して力強くきめ細やかなサービス&amp;フォローを創出。<br>\r\n地域の暮らしと産業に貢献し、エネルギーと人と社会の未来を拓きます。\r\n</p>\r\n\r\n<div class=\"anchor_btn_wrap\">\r\n<div class=\"anchor_btn\">\r\n<a href=\"#sec01\" data-scroll=\"\">\r\n<span class=\"anchor_txt\">ガス溶材部</span>\r\n</a>\r\n</div>\r\n\r\n<div class=\"anchor_btn\">\r\n<a href=\"#sec02\" data-scroll=\"\">\r\n<span class=\"anchor_txt\">LP住設部</span>\r\n</a>\r\n</div>\r\n\r\n<div class=\"anchor_btn\">\r\n<a href=\"#sec03\" data-scroll=\"\">\r\n<span class=\"anchor_txt\">空調冷熱部</span>\r\n</a>\r\n</div>\r\n\r\n<div class=\"anchor_btn\">\r\n<a href=\"#sec04\" data-scroll=\"\">\r\n<span class=\"anchor_txt\">レンタル部</span>\r\n</a>\r\n</div>\r\n\r\n<div class=\"anchor_btn\">\r\n<a href=\"#sec05\" data-scroll=\"\">\r\n<span class=\"anchor_txt\">一般事務</span>\r\n</a>\r\n</div>\r\n<!--end div.anchor_btn_wrap-->\r\n</div>\r\n\r\n\r\n<div class=\"box_s\" id=\"sec01\">\r\n<dl class=\"division_tittle_wrap\">\r\n<dt class=\"division_title_jp\">ガス溶材部</dt>\r\n<dd class=\"division_title_en\">High-Pressure Gas</dd>\r\n</dl>\r\n\r\n<figure class=\"division_img\"><img src=\"../img/service/img01.jpg\" alt=\"ガス溶材部\"/></figure>\r\n<!--end div.box_s -->\r\n</div>\r\n\r\n<div class=\"detail_box\">\r\n<div class=\"box_s\">\r\n<p class=\"box_subtitle\">FEATURES</p>\r\n<h4 class=\"box_title\">工業・医療の現場で必要不可欠なガスと設備を供給。</h4>\r\n<p class=\"box_dis_txt\">工場の生産ラインを支える工業ガスをはじめ、材料や工具、研磨・切断・溶接・レーザーなどの各種加工機、産業用ロボットの供給から作業効率アップや省エネルギーを実現するご提案まで、ものづくりに関わる事業所のサポートを通じて産業の発展と環境の保全に努めます。また医療の現場においては、医療活動に必要不可欠な各種医療用ガスの供給と設備を提供。地域で暮らす人々のライフクオリティの向上に貢献するべく安心・安全を徹底した運用体制をもって業務を推進しています。</p>\r\n\r\n<p class=\"box_subtitle\">INTERVIEW &amp; MOVIE</p>\r\n<ul class=\"interview_list\">\r\n<li><a href=\"../interview/kamei/\"><img src=\"../img/service/interview01.jpg\" alt=\"\"/></a></li>\r\n<li><a href=\"../interview/#movie\"><img src=\"../img/service/interview04.jpg\" alt=\"\"/></a></li>\r\n<li><a href=\"../interview/#movie\"><img src=\"../img/service/interview05.jpg\" alt=\"\"/></a></li>\r\n</ul>\r\n\r\n\r\n<!--end div.box_s -->\r\n</div>\r\n<!--end div.detail_box -->\r\n</div>\r\n\r\n\r\n<div class=\"box_s\" id=\"sec02\">\r\n<dl class=\"division_tittle_wrap\">\r\n<dt class=\"division_title_jp\">LP住設部</dt>\r\n<dd class=\"division_title_en\">LP Housing Equipment</dd>\r\n</dl>\r\n\r\n<figure class=\"division_img\"><img src=\"../img/service/img02.jpg\" alt=\"LP住設部\"/></figure>\r\n<!--end div.box_s -->\r\n</div>\r\n\r\n<div class=\"detail_box\">\r\n<div class=\"box_s\">\r\n<p class=\"box_subtitle\">FEATURES</p>\r\n<h4 class=\"box_title\">エネルギーと暮らしを結ぶ、住まいと設備のプロフェッショナル。</h4>\r\n<p class=\"box_dis_txt\">LPガス販売（直売・卸、使用用途：家庭用・業務用・工業用）、ガス機器販売（家庭用・業務用・工業用）、リフォーム。<br>\r\n私たちは、ご相談いただけるお客さまの要望に応え、課題の解決を行い、エネルギーと暮らしを結ぶ住まいと設備のプロフェッショナルとして、地域と社会の豊かな暮らしづくりに貢献することを目指しています。</p>\r\n\r\n<!--<p class=\"box_subtitle\">INTERVIEW</p>\r\n<ul class=\"interview_list\">\r\n<li><a href=\"../interview/haraguchi/\"><img src=\"../img/service/interview03.jpg\" alt=\"\"/></a></li>\r\n</ul>-->\r\n<!--end div.box_s -->\r\n</div>\r\n<!--end div.detail_box -->\r\n</div>\r\n\r\n\r\n<div class=\"box_s\" id=\"sec03\">\r\n<dl class=\"division_tittle_wrap\">\r\n<dt class=\"division_title_jp\">空調冷熱部</dt>\r\n<dd class=\"division_title_en\">Air Conditioning</dd>\r\n</dl>\r\n\r\n<figure class=\"division_img\"><img src=\"../img/service/img03.jpg\" alt=\"空調冷熱部\"/></figure>\r\n<!--end div.box_s -->\r\n</div>\r\n\r\n<div class=\"detail_box\">\r\n<div class=\"box_s\">\r\n<p class=\"box_subtitle\">FEATURES</p>\r\n<h4 class=\"box_title\">空調冷熱設備で豊かな食生活と快適な環境づくりに貢献。</h4>\r\n<p class=\"box_dis_txt\">私たちの業務は既成の商品を商うことではなく、顧客の満足を得るという事を本来の目的としています。それは要望を導き出すヒアリングから始まり、設計・施工を経て納品となるまでの第一幕。運用からフィードバックを得て情報を蓄積しながら確実にメンテナンスを行う第二幕。そして、役割を全うして次の段階に共に進む第三幕。私たちの願いは、お客さまと長い時間をかけた物語をご一緒して、安心と信頼によってのみ得られるビジネスサイクルの輪を堅牢に形作ること、お客さまの課題を解決し続けることにあります。</p>\r\n\r\n<p class=\"box_subtitle\">MOVIE</p>\r\n<ul class=\"interview_list\">\r\n<li><a href=\"../interview/#movie\"><img src=\"../img/service/interview06.jpg\" alt=\"\"/></a></li>\r\n</ul>\r\n<!--end div.box_s -->\r\n</div>\r\n<!--end div.detail_box -->\r\n</div>\r\n\r\n\r\n<div class=\"box_s\" id=\"sec04\">\r\n<dl class=\"division_tittle_wrap\">\r\n<dt class=\"division_title_jp\">レンタル部</dt>\r\n<dd class=\"division_title_en\">Rental Service</dd>\r\n</dl>\r\n\r\n<figure class=\"division_img\"><img src=\"../img/service/img04.jpg\" alt=\"レンタル部\"/></figure>\r\n<!--end div.box_s -->\r\n</div>\r\n\r\n<div class=\"detail_box\">\r\n<div class=\"box_s\">\r\n<p class=\"box_subtitle\">FEATURES</p>\r\n<h4 class=\"box_title\">厨房機器・備品を窓口ひとつでトータルサポート。</h4>\r\n<p class=\"box_dis_txt\">展示会・催事の現場に、冷凍・冷蔵ショーケースを始めとする厨房機器、備品を必要に応じて短期・中長期にレンタル。関西エリア随一の豊富な在庫でサイズ・種類も思いのまま。業界のトレンドを熟知したスタッフがイベントでのブース演出から、省力化・省エネルギー化に至るまで窓口ひとつで安心対応。お客様のご要望に沿った、快適かつ効果的な空間づくりをトータルサポートいたします。</p>\r\n\r\n<p class=\"box_subtitle\">INTERVIEW</p>\r\n<ul class=\"interview_list\">\r\n<li><a href=\"../interview/kohyama/\"><img src=\"../img/service/interview02.jpg\" alt=\"\"/></a></li>\r\n</ul>\r\n<!--end div.box_s -->\r\n</div>\r\n<!--end div.detail_box -->\r\n</div>\r\n\r\n\r\n<div class=\"box_s\" id=\"sec05\">\r\n<dl class=\"division_tittle_wrap\">\r\n<dt class=\"division_title_jp\">一般事務</dt>\r\n<dd class=\"division_title_en\">General Secretary</dd>\r\n</dl>\r\n\r\n<figure class=\"division_img\"><img src=\"../img/service/img05.jpg\" alt=\"一般事務\"/></figure>\r\n<!--end div.box_s -->\r\n</div>\r\n\r\n<div class=\"detail_box\">\r\n<div class=\"box_s\">\r\n<p class=\"box_subtitle\">FEATURES</p>\r\n<h4 class=\"box_title\">経理に人事、庶務も総務も安心・安全に、気持ちよく働ける環境づくり。</h4>\r\n<p class=\"box_dis_txt\">人事・採用、労務管理、給与計算。福利厚生の企画・立案・運用。経理など、一般事務は会社の根幹となる「働く人」と「働く環境」に関わる大切な仕事です。社員ひとりひとりが安心・安全に気持ちよく働ける環境づくりを実現するべく、「残業時間の縮小」「負担の集中改善」「労働時間管理」に取り組み、会社として全体的な成果を発揮するための縁の下の力持ち的に組織の基礎となる部分を担います。</p>\r\n\r\n<p class=\"box_subtitle\">INTERVIEW</p>\r\n<ul class=\"interview_list\">\r\n<li><a href=\"../interview/haraguchi/\"><img src=\"../img/service/interview03.jpg\" alt=\"\"/></a></li>\r\n</ul>\r\n<!--end div.box_s -->\r\n</div>\r\n<!--end div.detail_box -->\r\n</div>\r\n\r\n<!--end box -->\r\n</section>\r\n</div>\r\n</main>\r\n<footer>\r\n<section class=\"sec_movie\">\r\n<div class=\"entry_pv_wrap\">\r\n<video class=\"entry_pvbox\" muted autoplay loop playsinline>\r\n<source src=\"../img/common/entry_pv.mp4\" type=\"video/mp4\" class=\"entry_pv\">\r\n</video>\r\n\r\n<div class=\"entry_title_wrap\">\r\n<figure class=\"entry_copy\"><img src=\"../img/common/foot_copy.svg\" alt=\"\"/></figure>\r\n<div class=\"circle_btn\"><a href=\"../entry/\" class=\"btn-txt\">More Info</a></div>\r\n<!--end div.movie_title_wrap -->\r\n</div>\r\n\r\n<!--end div.recruit_pv_wrap -->\r\n</div>\r\n</section>\r\n\r\n<section class=\"footer_inner\">\r\n<div class=\"box_m\">\r\n<p class=\"foot_logo\"><img src=\"../img/common/foot_logo.svg\" alt=\"\"/></p>\r\n<p class=\"foot_office_txt\">【KAKOGAWA HEAD OFFICE 】 </p>\r\n<p class=\"foot_addless\">〒 675-0039<br class=\"sp-hidden\">\r\n兵庫県加古川市加古川町粟津805-3　<br class=\"pc-hidden\">\r\nTEL：079-421-1111  FAX：079-425-8981</p>\r\n<p class=\"foot_link_txt\"><a href=\"../privacy/\">プライバシー・ポリシー</a> /  <a class=\"blk_icon\" href=\"https://www.next-1.co.jp/\" target=\"_blank\">コーポレートサイト</a></p>\r\n<small class=\"copyright\">COPYRIGHT &copy;  NEXT ONE CO., LTD. ALL RIGHT RESERVED.</small>\r\n<!--end div.box_m -->\r\n</div>\r\n\r\n<!--end div.footer_inner -->\r\n</section>\r\n</footer>\r\n\r\n<div class=\"page_top\"><a href=\"#\"></a></div><!--jQuery-->\r\n<script src=\"https://ajax.googleapis.com/ajax/libs/jquery/3.6.1/jquery.min.js\"></script>\r\n<!-- ハンバーガーメニュー-->\r\n<script src=\"../js/hamburgermenu.js\"></script>\r\n<!--Page top-->\r\n<script src=\"../js/pagetop.js\"></script><!--ページスクロール-->\r\n<script>\r\n$(function() {\r\nvar headerHeight = 0;\r\n$('[href^=\"#\"]').click(function(){\r\nvar href= $(this).attr(\"href\");\r\nvar target = $(href == \"#\" || href == \"\" ? 'html' : href);\r\nvar position = target.offset().top-headerHeight; \r\n$(\"html, body\").animate({scrollTop:position}, 200, \"swing\");\r\nreturn false;\r\n});\r\n});\r\n</script>\r\n</body>\r\n</html>","finalUrl":"https://www.next-1.co.jp/recruit/service/","rendered":false,"_cachedAt":"2026-06-22T22:31:31.135Z"}