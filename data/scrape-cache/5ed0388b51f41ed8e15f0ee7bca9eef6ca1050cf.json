link rel=\"apple-touch-icon\" sizes=\"120x120\" href=\"../apple-touch-icon-120x120.png\" />\n<link rel=\"apple-touch-icon\" sizes=\"144x144\" href=\"../apple-touch-icon-144x144.png\" />\n<link rel=\"apple-touch-icon\" sizes=\"152x152\" href=\"../apple-touch-icon-152x152.png\" />\n<link rel=\"apple-touch-icon\" sizes=\"180x180\" href=\"../apple-touch-icon-180x180.png\" />\n\n<!-- Document Title\n\t============================================= -->\n<title>藤村薬品株式会社｜会社案内｜ごあいさつ</title>\n</head>\n\n<body class=\"stretched\">\n\n<!-- Document Wrapper\n\t============================================= -->\n<div id=\"wrapper\" class=\"clearfix\"> \n  \n  <!-- Header\n\t\t============================================= -->\n  <header id=\"header\" class=\"header-size-sm border-bottom-0\" data-sticky-shrink=\"false\">\n    <div id=\"header-wrap\">\n      <div class=\"container\">\n        <div class=\"header-row justify-content-lg-between\"> \n          \n          <!-- Logo\n\t\t\t\t\t\t============================================= -->\n          <div id=\"logo\"> <a href=\"../index.html\" class=\"standard-logo\" data-dark-logo=\"images/logo.png\"><img src=\"../images/logo.png\" alt=\"Canvas Logo\"></a> <a href=\"../index.html\" class=\"retina-logo\" data-dark-logo=\"images/logo@2x.png\"><img src=\"../images/logo@2x.png\" alt=\"Canvas\"></a> </div>\n          <!-- #logo end -->\n          \n          <div id=\"primary-menu-trigger\">\n            <svg class=\"svg-trigger\" viewBox=\"0 0 100 100\">\n              <path d=\"m 30,33 h 40 c 3.722839,0 7.5,3.126468 7.5,8.578427 0,5.451959 -2.727029,8.421573 -7.5,8.421573 h -20\"></path>\n              <path d=\"m 30,50 h 40\"></path>\n              <path d=\"m 70,67 h -40 c 0,0 -7.5,-0.802118 -7.5,-8.365747 0,-7.563629 7.5,-8.634253 7.5,-8.634253 h 20\"></path>\n            </svg>\n          </div>\n          \n          <!-- Primary Navigation\n\t\t\t\t\t\t============================================= -->\n          <nav class=\"primary-menu with-arrows mr-lg-auto\">\n            <ul class=\"menu-container align-self-start\">\n              <li class=\"menu-item\"><span class=\"menu-bg col-auto align-self-start d-flex\"></span></li>\n              <li class=\"menu-item\"><a class=\"menu-link\" href=\"../index.html\">\n                <div>HOME</div>\n                </a></li>\n              <li class=\"menu-item current\"><a class=\"menu-link\" href=\"#\">\n                <div>会社案内</div>\n                </a>\n                <ul class=\"sub-menu-container\">\n                  <li class=\"menu-item\"><a class=\"menu-link\" href=\"01_message.html\">\n                    <div>ごあいさつ</div>\n                    </a></li>\n                  <li class=\"menu-item\"><a class=\"menu-link\" href=\"01_company.html\">\n                    <div>会社概要</div>\n                    </a></li>\n                  <li class=\"menu-item\"><a class=\"menu-link\" href=\"01_office.html\">\n                    <div>事業所一覧</div>\n                    </a></li>\n                  <li class=\"menu-item\"><a class=\"menu-link\" href=\"01_history.html\">\n                    <div>沿 革</div>\n                    </a></li>\n                </ul>\n              </li>\n              <li class=\"menu-item\"><a class=\"menu-link\" href=\"#\">\n                <div>事業案内</div>\n                </a>\n                <ul class=\"sub-menu-container\">\n                  <li class=\"menu-item\"><a class=\"menu-link\" href=\"02_sales.html\">\n                    <div>営業機能</div>\n                    </a></li>\n                  <li class=\"menu-item\"><a class=\"menu-link\" href=\"02_logistics.html\">\n                    <div>物流機能</div>\n                    </a></li>\n                  <li class=\"menu-item\"><a class=\"menu-link\" href=\"02_support.html\">\n                    <div>お得意先支援</div>\n                    </a></li>\n                  <li class=\"menu-item\"><a class=\"menu-link\" href=\"02_solution.html\">\n                    <div>ソリューション</div>\n                    </a></li>\n                </ul>\n              </li>\n              <li class=\"menu-item\"><a class=\"menu-link btn-contact\" href=\"03_csr.html\">\n                <div>CSR</div>\n                </a></li>\n              <li class=\"menu-item\"><a class=\"menu-link btn-contact\" href=\"../topics/\">\n                <div>NEWS</div>\n                </a></li>\n              <li class=\"menu-item\"><a class=\"menu-link\" href=\"#\">\n                <div>採用情報</div>\n                </a>\n                <ul class=\"sub-menu-container\">\n                  <li class=\"menu-item\"><a class=\"menu-link\" href=\"04_info.html\">\n                    <div>採用案内</div>\n                    </a></li>\n                  <li class=\"menu-item\"><a class=\"menu-link\" href=\"04_welfare.html\">\n                    <div>研修制度・福利厚生</div>\n                    </a></li>\n                  <li class=\"menu-item\"><a class=\"menu-link\" href=\"04_voice.html\">\n                    <div>先輩社員の声</div>\n                    </a></li>\n                  <li class=\"menu-item\"><a class=\"menu-link\" href=\"04_faq.html\">\n                    <div>よくある質問</div>\n                    </a></li>\n                </ul>\n              </li>\n              <li class=\"menu-item\"><a class=\"menu-link btn-contact\" href=\"05_forest.html\">\n                <div>フォレストグループ</div>\n                </a></li>\n            </ul>\n          </nav>\n          <!-- #primary-menu end --> \n          \n        </div>\n      </div>\n    </div>\n    <div class=\"header-wrap-clone\"></div>\n  </header>\n  <!-- #header end --> \n  \n  <!-- Page Title\n\t\t============================================= -->\n  <section id=\"page-title\">\n    <div class=\"container\">\n      <h1>ごあいさつ</h1>\n      <ol class=\"breadcrumb\">\n        <li class=\"breadcrumb-item\"><a href=\"../index.html\">Home</a></li>\n        <li class=\"breadcrumb-item active\" aria-current=\"page\">会社案内</li>\n      </ol>\n    </div>\n  </section>\n  <!-- #page-title end --> \n  \n  <!-- Content\n\t\t============================================= -->\n  <section id=\"content\">\n   \n   <div>\n       <img src=\"president_large_photo.jpg\" style=\"width: 100%;\">\n   </div>\n    <div class=\"container clearfix pt-5 pb-5\">\n        <div>\n            <p>　当社は1894年（明治27年）に藤村萬盛堂として発足し、令和６年に創業130周年を迎えることができました。<br>　私たちは、高品質で安全な「医薬品の供給」を通じて地域医療の発展に貢献することを目的に、長崎の地に根ざし、常に医療機関や地域の皆さまの支えとなる存在であり続けるよう、下記に掲げた「吾々の信条」を考動指針に、地域の医療課題解決に向けた取り組みを続けています。</p>\n\n            <p>　また、当社が参画するフォレストグループでは、「人々の健康に関わる＜不＞の打開」を基本理念に掲げ、人々が病気やケガをしたときに感じる健康への不安、不快、不足、不便を取り除いていくことを社員一人ひとりの使命としております。</p>\n\n            <p>　さらに、当グループは「卸こそ人がすべて」という考えのもと、人材育成にも力を注いでいます。企業の成長は社員一人ひとりの成長に深く結びついています。当社は、今後も共に働く仲間を大切にし、社員がやりがいを実感し誇りを持てる会社づくりを目指してまいります。</p>\n\n            <p>　これからも地域の皆さまに信頼され、選ばれる企業であり続けるために、誠実な事業活動を通じてご期待以上の価値を提供してまいります。引き続き、ご指導とご支援を賜りますようお願い申しあげます。</p>\n            \n            <p class=\"presidentname\";>代表取締役社長<br><strong>谷口　理一郎</strong></p>\n        </div>\n        <div>\n            <h3 class=\"center-with-lines\">フォレストグループ基本理念</h3>\n          <h4 class=\"font-weight-normal\" style=\"line-height: 1.8;\"> われわれは<br>\n              自らの人格、志気、能力を育み、<br>\n              たゆまぬ創造と革新のもと事業を進化させ、<br>\n              人々の健康に関わる＜不＞の打開と<br>\n              健全社会への貢献に真の喜びを求める\n          </h4>\n            <h3 class=\"center-with-lines\">藤村薬品 吾々の信条</h3>\n          <h4 class=\"font-weight-normal\" style=\"line-height: 1.8;\"> 一．喜ばれ信頼される商品の供給<br>\n              一．正しい人間の完成と常に正道に立った社業の運営<br>\n              一．顧客とメーカーと本社との共存共栄<br>\n              一．吾々の働きで吾々の生活を向上し、よりよい会社にいたしましょう</h4>\n        </div>\n    </div>\n  </section>\n  <!-- #content end --> \n  \n  <style>\n      .center-with-lines {\n          display: flex;\n          align-items: center;\n          justify-content: center;\n      }\n\n      .center-with-lines::before,\n      .center-with-lines::after {\n          content: \"\";\n          flex-grow: 1;\n          height: 1px; /* 線の太さ */\n          background-color: #77C345; /* 線の色 */\n          margin: 0 10px; /* 文字と線の間隔 */\n      }\n      .presidentname{\n          text-align: right!important;\n          margin: 0 0 0 auto!important;\n      }\n    </style>\n  \n  <!-- Footer\n\t\t============================================= -->\n    <footer id=\"footer\" class=\"bg_lgreen border-0 pt-5\">\n        <div class=\"container clearfix\">\n            <div class=\"mb-3 text-center\"> <img src=\"../images/logo_w.png\" srcset=\"../images/logo_w.png 1x, ../images/logo_w@2x.png 2x\" alt=\"Canvas\"> </div>\n            <div class=\"col-12 text-center\"> <a href=\"06_contact.html\">お問い合わせ</a> ｜         <a href=\"../data/file.php?sitepolicy\" target=\"_blank\">サイトポリシー</a> ｜ \n                <a href=\"../data/file.php?privacypolicy\" target=\"_blank\">個人情報保護方針</a> ｜ \n                <a href=\"../data/file.php?securitypolicy\" target=\"_blank\">情報セキュリティ基本方針</a>  </div>\n        </div>\n    \n    <!-- Copyrights\n\t\t\t============================================= -->\n    <div id=\"copyrights\" style=\"background-color: #77C345;\">\n      <div class=\"container clearfix\">\n        <div class=\"row justify-content-between align-items-center\">\n          <div class=\"col-md-12 text-center\"> &copy; 藤村薬品株式会社 </div>\n        </div>\n      </div>\n    </div>\n    <!-- #copyrights end --> \n    \n  </footer>\n  <!-- #footer end --> \n  \n</div>\n<!-- #wrapper end --> \n\n<!-- Go To Top\n\t============================================= -->\n<div id=\"gotoTop\" class=\"icon-angle-up\"></div>\n\n<!-- JavaScripts\n\t============================================= --> \n<script src=\"../js/jquery.js\"></script> \n<script src=\"../js/plugins.min.js\"></script> \n<script src=\"../js/jquery.calendario.js\"></script> \n\n<!-- Footer Scripts\n\t============================================= --> \n<script src=\"../js/functions.js\"></script>\n</body>\n</html>","finalUrl":"https://www.fujimurayakuhin.jp/contents/01_message.html","rendered":false,"_cachedAt":"2026-06-23T22:20:10.042Z"}