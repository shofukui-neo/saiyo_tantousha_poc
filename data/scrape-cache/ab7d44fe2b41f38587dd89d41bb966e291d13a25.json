pplication/rsd+xml\" title=\"RSD\" href=\"https://www.gd-inc.co.jp/xmlrpc.php?rsd\" />\n<link rel=\"wlwmanifest\" type=\"application/wlwmanifest+xml\" href=\"https://www.gd-inc.co.jp/wp-includes/wlwmanifest.xml\" /> \n<meta name=\"generator\" content=\"WordPress 5.5.18\" />\n<link rel=\"canonical\" href=\"https://www.gd-inc.co.jp/recruit/\" />\n<link rel='shortlink' href='https://www.gd-inc.co.jp/?p=18' />\n<link rel=\"alternate\" type=\"application/json+oembed\" href=\"https://www.gd-inc.co.jp/wp-json/oembed/1.0/embed?url=https%3A%2F%2Fwww.gd-inc.co.jp%2Frecruit%2F\" />\n<link rel=\"alternate\" type=\"text/xml+oembed\" href=\"https://www.gd-inc.co.jp/wp-json/oembed/1.0/embed?url=https%3A%2F%2Fwww.gd-inc.co.jp%2Frecruit%2F&#038;format=xml\" />\n  <script src=\"https://ajax.googleapis.com/ajax/libs/jquery/3.6.0/jquery.min.js\"></script>\n  <script src=\"https://www.gd-inc.co.jp/wp-content/themes/gdinc/assets/js/jquery.mb.YTPlayer.min.js\"></script>\n  <script src=\"https://www.gd-inc.co.jp/wp-content/themes/gdinc/assets/js/common.js\"></script>\n</head>\n<body class=\"page-template-default page page-id-18\">\n\n<header class=\"globalHeader\">\n  <div class='globalHeader__inner'>\n    <div class=\"globalHeader__ci\">\n      <a href=\"/\">\n        <svg width=\"258\" height=\"23\" viewBox=\"0 0 258 23\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" xmlns:xlink=\"http://www.w3.org/1999/xlink\">\n          <rect width=\"258\" height=\"23\" fill=\"url(#pattern0_1_1128)\"/>\n          <defs>\n            <pattern id=\"pattern0_1_1128\" patternContentUnits=\"objectBoundingBox\" width=\"1\" height=\"1\">\n              <use xlink:href=\"#image0_1_1128\" transform=\"scale(0.00387597 0.0434783)\"/>\n            </pattern>\n            <image id=\"image0_1_1128\" width=\"258\" height=\"23\" preserveAspectRatio=\"none\" xlink:href=\"data:image/png;base64,\"/>\n          </defs>\n        </svg>\n      </a>\n    </div>\n\n    <div id=\"navBtn\"><a class=\"menu-trigger\" href=\"#\"><span></span><span></span><span></span></a></div>\n\n    <nav class=\"globalNavigation\">\n      <ul class='globalNavigation__items'>\n        <li class='globalNavigation__item'><a href=\"/outline/\">企業情報</a></li>\n        <li class='globalNavigation__item -hover'>\n          <span>製品</span>\n          <ul class='globalNavigation__hoverItems'>\n            <li class='globalNavigation__hoverItem'>\n              <a href='https://graphitedesign.gd-inc.co.jp/' target='_blank'>\n                ゴルフシャフト\n                <i class=\"fas fa-external-link-alt\"></i>\n              </a>\n            </li>\n            <li class='globalNavigation__hoverItem'>\n              <a href='/composites/'>コンポジット</a></li>\n          </ul>\n        </li>\n        <li class='globalNavigation__item'><a href=\"/ir/\">投資家情報</a></li>\n        <li class='globalNavigation__item'><a href=\"/recruit/\">採用情報</a></li>\n      </ul>\n    </nav>\n  </div>\n  <nav id='globalNavigationSp' class=\"globalNavigationSp\">\n    <ul class='globalNavigationSp__items'>\n      <li class='globalNavigationSp__item'><a href=\"/outline/\">企業情報</a></li>\n      <li class='globalNavigationSp__item'><a href=\"/president/\">社長あいさつ</a></li>\n      <li class='globalNavigationSp__item'><a href=\"/access/\">アクセスマップ</a></li>\n      <li class='globalNavigationSp__item'><a href='https://graphitedesign.gd-inc.co.jp/' target='_blank'>\n          ゴルフシャフト\n          <i class=\"fas fa-external-link-alt\"></i>\n        </a>\n      </li>\n      <li class='globalNavigationSp__item'><a href='/composites/'>コンポジット</a></li>\n      <li class='globalNavigationSp__item'><a href=\"/ir/\">投資家情報</a></li>\n      <li class='globalNavigationSp__item'><a href=\"/recruit/\">採用情報</a></li>\n    </ul>\n  </nav>\n</header>\n\n<div class=\"contentsArea\">\n\n<style>\n@media screen and (max-width: 768px) {\n  .recruitInformation__inquiry dl {\n    display: block !important;\n    flex-wrap: unset !important;\n    flex-direction: unset !important;\n    align-items: unset !important;\n  }\n  .recruitInformation__inquiry dt,\n  .recruitInformation__inquiry dd {\n    display: block !important;\n    width: 100% !important;\n    min-width: unset !important;\n    max-width: unset !important;\n    flex: unset !important;\n    padding-left: 0 !important;\n    margin-left: 0 !important;\n    box-sizing: border-box !important;\n  }\n  .recruitInformation__inquiry dt:empty {\n    display: none !important;\n  }\n  .recruitInformation__inquiry dd::before {\n    content: \" ：\" !important;\n    letter-spacing: 0 !important;\n    margin-right: 0 !important;\n    padding-right: 0 !important;\n  }\n}\n</style>\n\n<script>\nif (window.innerWidth <= 768) {\n  document.querySelectorAll('.recruitInformation__inquiry dd').forEach(function(dd) {\n    if (dd.textContent.trimStart().charAt(0) === '：') {\n      dd.textContent = dd.textContent.trimStart().replace('：', ' ：');\n    }\n  });\n}\n</script>\n\n<div class=\"contentsArea__inner\" style=\"max-width: 1240px;\">\n  <article class='articleRecruit'>\n    <h2 class='articleRecruit__heading'>採用情報</h2>\n    <div class='recruitInformation'>\n      <div class='recruitInformation__body'>\n      </div>\n      <div class='recruitInformation__inquiry'>\n        <dl>\n          <dt>採用種別</dt>\n          <dd>新卒採用</dd>\n        </dl>\n        <dl>\n          <dt>雇用形態</dt>\n          <dd>正社員（試用期間3か月　※労働条件変更なし）</dd>\n        </dl>\n        <dl>\n          <dt>勤務地</dt>\n          <dd>本社（埼玉県秩父市太田2474-1）</dd>\n        </dl>\n        <dl>\n          <dt></dt>\n          <dd>転勤の可能性：なし</dd>\n        </dl>\n        <br>\n        <dl>\n          <dt>職種</dt>\n          <dd>営業職</dd>\n        </dl>\n        <dl>\n          <dt>仕事内容</dt>\n          <dd>ゴルフシャフトの営業全般</dd>\n        </dl>\n        <dl>\n          <dt></dt>\n          <dd>【業務内容】</dd>\n        </dl>\n        <dl>\n          <dt></dt>\n          <dd>・ゴルフクラブメーカー、ゴルフ用品販売店、工房等への営業活動</dd>\n        </dl>\n        <dl>\n          <dt></dt>\n          <dd>・試打会等のイベント対応</dd>\n        </dl>\n        <dl>\n          <dt></dt>\n          <dd>・顧客対応（電話、メール等の対応）</dd>\n        </dl>\n        <dl>\n          <dt></dt>\n          <dd>・一部海外顧客対応（ビジネスレベルの英語ができれば尚可）</dd>\n        </dl>\n        <dl>\n          <dt></dt>\n          <dd>・業務の変更範囲：変更なし</dd>\n        </dl>\n        <br>\n        <dl>\n          <dt>応募資格</dt>\n          <dd>大学および大学院を2027年3月までに卒業見込みの方</dd>\n        </dl>\n        <dl>\n          <dt>応募要件</dt>\n          <dd>普通自動車運転免許をお持ちの方（AT限定可）</dd>\n        </dl>\n        <dl>\n          <dt></dt>\n          <dd>英語力（ビジネスレベル）があれば尚可</dd>\n        </dl>\n        <br>\n        <dl>\n          <dt>募集人数</dt>\n          <dd>若干名</dd>\n        </dl>\n        <br>\n        <dl>\n          <dt>初任給</dt>\n          <dd>【院卒】268,000円</dd>\n        </dl>\n        <dl>\n          <dt></dt>\n          <dd>【大卒】248,000円</dd>\n        </dl>\n        <dl>\n          <dt>賞与</dt>\n          <dd>年2回</dd>\n        </dl>\n        <br>\n        <dl>\n          <dt>勤務時間</dt>\n          <dd>9:00～18:00</dd>\n        </dl>\n        <dl>\n          <dt>休日</dt>\n          <dd>年間休日125日</dd>\n        </dl>\n        <dl>\n          <dt></dt>\n          <dd>週休2日、祝日、GW、夏季休暇、年末年始休暇、その他当社営業カレンダーによる</dd>\n        </dl>\n        <dl>\n          <dt>休暇</dt>\n          <dd>年次有給休暇、慶弔休暇（結婚、配偶者の出産、忌引など）、子の看護休暇、介護休暇、地域行事休暇など</dd>\n        </dl>\n        <br>\n        <dl>\n          <dt>選考方法</dt>\n          <dd>一次：履歴書にて書類選考</dd>\n        </dl>\n        <dl>\n          <dt></dt>\n          <dd>二次：適性検査及び面接</dd>\n        </dl>\n        <br>\n        <dl>\n          <dt>福利厚生</dt>\n          <dd>社会保険完備・独身寮・財形貯蓄・社員持株制度など　※社内規定あり</dd>\n        </dl>\n        <br>\n        <dl>\n          <dt>問合せ</dt>\n        </dl>\n        <dl>\n          <dt>担当</dt>\n          <dd>管理部　管理課　採用担当者</dd>\n        </dl>\n        <dl>\n          <dt>TEL</dt>\n          <dd>0494-62-2800</dd>\n        </dl>\n        <dl>\n          <dt>E-Mail</dt>\n          <dd>kanri@gd-inc.co.jp</dd>\n        </dl>\n      </div>\n    </div>\n  </article>\n\n</div>\n\n<!-- /#contentsArea --></div>\n\n<footer class=\"globalFooter\">\n  <div class='globalFooter__inner'>\n    <div class='globalFooterNav'>\n      <ul class='globalFooterNav__items'>\n        <li class='globalFooterNav__item'><a href='/outline/'>企業情報</a></li>\n        <li class='globalFooterNav__item'><a href='/ir/'>投資家情報</a></li>\n        <li class='globalFooterNav__item'><a href='/recruit/'>採用情報</a></li>\n        <li class='globalFooterNav__item'><a href='/contact/'>お問い合わせ</a></li>\n        <li class='globalFooterNav__item'><a href='/privacy/'>個人情報保護方針</a></li>\n      </ul>\n    </div>\n    <div class=\"globalFooter__copyright\">&copy; 1989 - 2026 GRAPHITE DESIGN</div>\n  </div>\n</footer>\n\n<script type='text/javascript' src='https://www.gd-inc.co.jp/wp-includes/js/wp-embed.min.js?ver=5.5.18' id='wp-embed-js'></script>\n</body>\n</html>\n","finalUrl":"https://www.gd-inc.co.jp/recruit/","rendered":false,"_cachedAt":"2026-06-14T16:20:01.684Z"}