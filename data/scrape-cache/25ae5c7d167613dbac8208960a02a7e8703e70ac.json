t>\n<script src=\"/js/common.js\"></script>\n<script>\n  $(window).on(\"load\", function() {\n    let scroll = new SmoothScroll('a[href*=\"#\"]', {\n      header: \"header\",\n      speedAsDuration: true,\n      speed: 650,\n      easing: 'easeInOutQuint',\n    });\n  });\n\n  $('.fot_top nav li').matchHeight();\n</script>\n\t<script src=\"https://ajaxzip3.github.io/ajaxzip3.js\"></script>\n\t<script src=\"/js/jquery.validate.min.js\"></script>\n\t<script>\n\t\t// 同意ボタンのチェックがされているか\n\t\tconst checkbox = document.querySelector('#checkAgree');\n\t\tconst submitButton = document.querySelector('#checkSubmit');\n\t\tconst arrowButton = document.querySelector('.arrow');\n\n\t\tlet changeDisabled = function() {\n\t\t\tif (checkbox.checked) {\n\t\t\t\tsubmitButton.disabled = \"\";\n\t\t\t\tsubmitButton.style.opacity = 1;\n\t\t\t\tarrowButton.style.opacity = 1;\n\t\t\t\tsubmitButton.parentNode.style.pointerEvents = \"auto\";\n\t\t\t} else {\n\t\t\t\tsubmitButton.disabled = \"disabled\";\n\t\t\t\tsubmitButton.style.opacity = 0.4;\n\t\t\t\tarrowButton.style.opacity = 0.4;\n\t\t\t\tsubmitButton.parentNode.style.pointerEvents = \"none\";\n\t\t\t}\n\t\t}\n\t\tcheckbox.addEventListener(\"change\", changeDisabled);\n\t\twindow.onload = changeDisabled;\n\t\t//\n\n\t\t(function() {\n\t\t\t//標準エラーメッセージの変更\n\t\t\t$.extend($.validator.messages, {\n\t\t\t\temail_s: '*正しいメールアドレスの形式で入力して下さい',\n\t\t\t\trequired: '*必須項目です',\n\t\t\t\tmaxlength: jQuery.validator.format(\"\")\n\t\t\t});\n\n\t\t\t//追加ルールの定義\n\t\t\tvar methods = {\n\t\t\t\temail: function(value, element) {//メールチェック\n\t\t\t\t\treturn this.optional(element) || /^[A-Za-z0-9]{1}[A-Za-z0-9_.-]*@{1}[A-Za-z0-9_.-]{1,}\\.[A-Za-z0-9]{1,}$/.test(value);\n\t\t\t\t},\n\t\t\t\temail_re: function(value, element) {//確認用メールチェック\n\t\t\t\t\treturn this.optional(element) || (value == $('input[name=\"email_s\"]').val());\n\t\t\t\t},\n\t\t\t\tkana_rule: function(value, element) {//カタカナ\n\t\t\t\t\treturn this.optional(element) || /^[ァ-ヶー　]+$/.test(value);\n\t\t\t\t},\n\t\t\t\tmoji_rule: function(value, element) {//機種依存文字をはじく\n\t\t\t\t\treturn this.optional(element) || /[^(?!.*①②③④⑤⑥⑦⑧⑨⑩⑪⑫⑬⑭⑮⑯⑰⑱⑲⑳ⅠⅡⅢⅣⅤⅥⅦⅧⅨⅩ㍉㌔㌢㍍㌘㌧㌃㌶㍑㍗㌍㌦㌣㌫㍊㌻㎜㎝㎞㎎㎏㏄㎡㍻〝〟№㏍℡㊤㊥㊦㊧㊨㈱㈲㈹㍾㍽㍼).]+$/.test(value);\n\t\t\t\t},\n\t\t\t\tzenkaku_rule: function(value, element) {//全角文字がない場合にはじく\n\t\t\t\t\treturn this.optional(element) || /.*[^\\x01-\\x7E]+.*$/.test(value);\n\t\t\t\t},\n\t\t\t\ttel_rule: function(value, element) {//ハイフンつき電話番号\n\t\t\t\t\treturn this.optional(element) || /^[0-9-]{10,13}$/.test(value);\n\t\t\t\t},\n\t\t\t\tzip_rule: function(value, element) {//郵便番号\n\t\t\t\t\treturn this.optional(element) || /^[0-9-]{7,8}$/.test(value);\n\t\t\t\t},\n\t\t\t};\n\n\t\t\t//メソッドの追加\n\t\t\t$.each(methods, function(key) {\n\t\t\t\t$.validator.addMethod(key, this);\n\t\t\t});\n\n\t\t\t//入力項目の検証ルール定義\n\t\t\tvar rules = {\n\t\t\t\tname_s: {\n\t\t\t\t\trequired: true\n\t\t\t\t},\n\t\t\t\temail_s: {\n\t\t\t\t\temail: true,\n\t\t\t\t\trequired: true,\n\t\t\t\t},\n\t\t\t\t'check_s[]': {\n\t\t\t\t\trequired: true,\n\t\t\t\t},\n\t\t\t\t'radio_s[]': {\n\t\t\t\t\trequired: true,\n\t\t\t\t},\n\t\t\t\tzip: {\n\t\t\t\t\tzip_rule: true\n\t\t\t\t},\n\t\t\t\tselect_s: {\n\t\t\t\t\trequired: true\n\t\t\t\t},\n\t\t\t\taddress: {},\n\t\t\t\tmessage_s: {\n\t\t\t\t\trequired: true,\n\t\t\t\t},\n\t\t\t\ttel: {\n\t\t\t\t\ttel_rule: false\n\t\t\t\t}\n\t\t\t};\n\n\t\t\t//入力項目ごとのエラーメッセージ定義\n\t\t\tvar messages = {\n\t\t\t\temail_s: {\n\t\t\t\t\temail: \"正しいメールアドレスを入力してください\"\n\t\t\t\t},\n\t\t\t\ttel: {\n\t\t\t\t\ttel_rule: \"正しい電話番号を入力してください\"\n\t\t\t\t},\n\t\t\t\tzip: {\n\t\t\t\t\tzip_rule: \"正しい郵便番号を入力してください\"\n\t\t\t\t}\n\t\t\t};\n\n\t\t\t$(function() {\n\t\t\t\t$('#sfm-form').validate({\n\t\t\t\t\terrorElement: \"span\",\n\n\t\t\t\t\trules: rules,\n\t\t\t\t\tmessages: messages,\n\n\t\t\t\t\t//エラーメッセージ出力箇所調整\n\t\t\t\t\terrorPlacement: function(error, element) {\n\t\t\t\t\t\tif (element.is(':radio')) {\n\t\t\t\t\t\t\terror.insertAfter(\".check-list\");\n\t\t\t\t\t\t} else if (element.attr(\"name\") == \"zip\") {\n\t\t\t\t\t\t\terror.insertAfter(\".ad_btn\");\n\t\t\t\t\t\t} else if (element.attr(\"name\") == \"select_s\") {\n\t\t\t\t\t\t\terror.insertAfter(\".select-box\");\n\t\t\t\t\t\t} else if (element.attr(\"name\") == \"check_s[]\") {\n\t\t\t\t\t\t\terror.insertAfter(\".checkbox\");\n\t\t\t\t\t\t} else {\n\t\t\t\t\t\t\terror.insertAfter(element);\n\t\t\t\t\t\t}\n\t\t\t\t\t},\n\t\t\t\t\tfocusInvalid: false,\n\t\t\t\t\tinvalidHandler: function(form, validator) {\n\t\t\t\t\t\tif (!validator.numberOfInvalids())\n\t\t\t\t\t\t\treturn;\n\n\t\t\t\t\t\t//　エラーのある箇所へのスクロール\n\t\t\t\t\t\t$('html, body').animate({\n\t\t\t\t\t\t\tscrollTop: $(validator.errorList[0].element).offset().top - 100\n\t\t\t\t\t\t}, 300);\n\t\t\t\t\t}\n\n\t\t\t\t});\n\t\t\t});\n\n\t\t})();\n\n\t\t$(function() {\n\t\t\t$('.ad_btn').click(function() {\n\t\t\t\tAjaxZip3.zip2addr('zip', '', 'address', 'address');\n\t\t\t});\n\t\t});\n\t</script>\n</body>\n\n</html>\n","finalUrl":"https://www.unagifujita.com/contact/","rendered":false,"_cachedAt":"2026-06-22T19:52:53.050Z"}