{"url":"https://www.imaokakogyo.com/recruit/message_03.html","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n\n<head>\n  <meta charset=\"UTF-8\">\n  <title>吉井 甫｜先輩メッセージ｜今岡工業株式会社 RECRUIT</title>\n  <meta name=\"description\" content=\"吉井 甫｜先輩メッセージ｜今岡工業株式会社のリクルートサイト。島根県内での総合建設・土木請負。\">\n  <meta name=\"keywords\" content=\"先輩メッセージ,島根県,出雲市,建設,住宅\">\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1.0,minimum-scale=1.0\">\n  <meta name=\"format-detection\" content=\"telephone=no\">\n  <link rel=\"shortcut icon\" href=\"favicon.ico\">\n  <!-- css -->\n  <link rel=\"stylesheet\" href=\"js/drawer/drawer.min.css\">\n  <link rel=\"stylesheet\" href=\"js/slick/slick.css\" media=\"screen\">\n  <link rel=\"stylesheet\" href=\"js/slick/slick-theme.css\" media=\"screen\">\n  <link rel=\"stylesheet\" href=\"css/common.css\">\n  <link rel=\"stylesheet\" href=\"css/import.css\">\n  <link rel=\"stylesheet\" href=\"css/font_style.css\">\n  <link href=\"https://fonts.googleapis.com/css?family=Roboto:500i,700i\" rel=\"stylesheet\">\n  <!-- js -->\n  <script src=\"js/lib/jquery-1.11.2.min.js\"></script>\n  <script src=\"js/jquery.matchHeight.js\"></script>\n  <script src=\"js/drawer/drawer.min.js\"></script>\n  <script src=\"js/drawer/iscroll.js\"></script>\n  <script src=\"js/slick/slick.min.js\"></script>\n  <script src=\"js/common.js\"></script>\n  <!--[if lt IE 9]>\n  <script src=\"http://html5shiv.googlecode.com/svn/trunk/html5.js\" type=\"text/javascript\"></script>\n  <![endif]-->\n</head>\n\n<body class=\"drawer drawer--right\">\n\n  <!-- header -->\n  <header role=\"banner\" class=\"headerArea\" id=\"is-headerFixed\">\n    <div class=\"l-container clearfix\">\n      <!-- logo -->\n      <div class=\"headerArea__logo\">\n        <a href=\"index.html\">\n          <img src=\"img/common/logo_header_01.png\" alt=\"今岡工業株式会社\" class=\"imgFit\">\n          <h1 class=\"dn\">今岡工業株式会社</h1>\n          <span class=\"subTitle\">RECRUIT</span>\n        </a>\n      </div>\n      <!-- /logo -->\n      <!-- global navi -->\n      <nav role=\"navigation\" class=\"gNav gNav-accordion drawer-nav\">\n        <ol class=\"clearfix drawer-menu\">\n          <li class=\"gNav__item gNav__item--normal gNav__item--message\">\n            <a href=\"message_index.html\" class=\"hoverNot\">\n              <span class=\"en\">MESSAGE</span>先輩メッセージ\n            </a>\n          </li>\n          <li class=\"gNav__item gNav__item--normal gNav__item--crosstalk\">\n            <a href=\"crosstalk.html\" class=\"hoverNot\">\n              <span class=\"en\">CROSSTALK</span>新人座談会\n            </a>\n          </li>\n          <li class=\"gNav__item gNav__item--normal gNav__item--work\">\n            <a href=\"work.html\" class=\"hoverNot\">\n              <span class=\"en\">WORK</span>今岡工業の仕事\n            </a>\n          </li>\n          <li class=\"gNav__item gNav__item--guide accordion close\">\n            <a href=\"guide_new_grad.html\" class=\"trigger hoverNot\">\n              <span class=\"en\">GUIDE</span>募集要項\n            </a>\n            <ul class=\"accordionMenu--mobile accordionMenu--pc\">\n              <li><a href=\"guide_new_grad.html\"><span>新卒の方</span></a></li>\n              <li><a href=\"guide_kisotsu_kentiku.html\"><span>既卒 建築技術</span></a></li>\n              <li><a href=\"guide_kisotsu_doboku.html\"><span>既卒 土木技術</span></a></li>\n              <li><a href=\"guide_kisotsu_eigyou.html\"><span>既卒 営業職</span></a></li>\n            </ul>\n          </li>\n          <li class=\"gNav__item gNav__item--normal gNav__item--faq\">\n            <a href=\"faq.html\" class=\"hoverNot\">\n              <span class=\"en\">FAQ</span>よくある質問\n            </a>\n          </li>\n          <li class=\"gNav__item gNav__item--normal gNav__item--entry\">\n            <a href=\"/recruite_form/index\" class=\"hoverNot\">\n              <span class=\"en\">ENTRY</span>エントリー\n            </a>\n          </li>\n          <li class=\"gNav__item gNav__item--close dn-pc\">\n            <a class=\"drawer-toggle\">\n              閉じる\n            </a>\n          </li>\n        </ol>\n      </nav>\n      <!-- /global navi -->\n      <!-- mobile menu -->\n      <div id=\"close\" class=\"headerArea__menuBtn dn-pc drawer-toggle\">\n        <span class=\"dn\">MENU</span>\n      </div>\n      <!-- /mobile menu -->\n    </div>\n  </header>\n  <!-- /header -->\n\n  <!-- main container -->\n  <main>\n    <div role=\"main\">\n      <!-- h1 -->\n      <h1 class=\"sub-category sub-category--massage\">\n        <span class=\"sub-category__inner\">\n          <span class=\"catNameEn\">MESSAGE</span>\n          <span class=\"catName\">先輩メッセージ</span>\n        </span>\n      </h1>\n      <!-- /h1 -->\n\n      <!-- breadcrumbs -->\n      <div class=\"sub-breadcrumbs dn-mobile\">\n        <ol class=\"l-container-sub clearfix\">\n          <li><a href=\"index.html\">トップページ</a></li>\n          <li><a href=\"message_index.html\">先輩メッセージ</a></li>\n          <li>吉井 甫</li>\n        </ol>\n      </div>\n      <!-- /breadcrumbs -->\n\n      <!-- l-container-sub -->\n      <div class=\"l-container-sub sub-container\">\n        <section>\n          <!-- h2 -->\n          <h2 class=\"mod-hl-01 mod-hl-01--catTag\">\n            <span class=\"icon-training icon\">&thinsp;</span>\n            吉井 甫\n            <span class=\"en\">Yoshii Hajime</span>\n            <span class=\"small\">2013年に入社</span>\n            <span class=\"catTag\">営業</span>\n          </h2>\n          <!-- /h2 -->\n          <!-- articleBox-01 -->\n          <div class=\"column-articleBox-subLeft--w300 l-innerBox clearfix\">\n            <div class=\"mod-column-sub\">\n              <img src=\"img/massage/bnr_03.jpg\" alt=\"スタッフ写真\" class=\"imgFit\">\n            </div>\n            <div class=\"mod-column-main\">\n              <div class=\"mod-column-main__inner\">\n                <section>\n                  <h3 class=\"mod-hl-02\">\n                    <span class=\"icon\">Q</span>この仕事を選んだきっかけは何ですか？\n                  </h3>\n                  <p>\n                    現在は今岡工業の住宅事業部で営業の仕事をさせてもらっていますが、元々は東京で別の仕事をしていました。 地元である島根に戻ってくる際に今岡工業と出会い、そのまま就職しました。\n                  </p>\n                  <p class=\"marginTop10\">\n                    初めはグループ内の飲食関連事業で、企画・マーケティング関連の業務を担当していましたが、 住宅事業部が「桧家住宅」を展開するにあたって席を移しました。\n                    当時「桧家住宅」というブランドは、山陰初上陸ということで知名度が低く、色々と大変な部分もありましたが、 それまでに培った企画・マーケティングの知識を活かしつつ、スタッフ全員で乗り越えました。\n                    そのことは、私自身にとっても貴重な体験だったと思っています。\n                  </p>\n                </section>\n                <section class=\"marginTop30\">\n                  <h3 class=\"mod-hl-02\">\n                    <span class=\"icon\">Q</span>この仕事のやり甲斐を感じるのは、どんな時ですか？\n                  </h3>\n                  <p>\n                    お客様に完成間際の家をご案内している時でしょうか。出来上がった家に問題がないかどうか一緒にチェックしてまわるのですが、家の中を歩いている時のお客様の嬉しそうな顔を見ると、こちらまで嬉しくなってきます。\n                  </p>\n                  <p class=\"marginTop10\">\n                    また、最近「桧家住宅さんが良いという話を聞いた」というお客様が増えてきたことも嬉しいことです。知名度のないところからのスタートだったので、こうしたお客様に接すると感慨深いものがあります。\n                  </p>\n                </section>\n              </div>\n            </div>\n          </div>\n          <!-- /articleBox-01 -->\n          <!-- articleBox-02 -->\n          <div class=\"column-articleBox-subRight--w300 l-innerBox marginTop60 clearfix\">\n            <div class=\"mod-column-sub\">\n              <img src=\"img/massage/pic_face03.jpg\" alt=\"スタッフ写真\" class=\"imgFit\">\n            </div>\n            <div class=\"mod-column-main\">\n              <div class=\"mod-column-main__inner\">\n                <section>\n                  <h3 class=\"mod-hl-02\">\n                    <span class=\"icon\">Q</span>そうしたお仕事をする中で、心がけていることがありますか？\n                  </h3>\n                  <p>\n                    住宅購入は高い買い物で、お客様も色々な要望もってお越しになりますので、私たちとしても出来るだけお客様の希望を叶えたいと思っています。\n                    そこで、打ち合わせの際にはお客様に「夢を語ってもらう」ことを心がけています。 その「夢」から私たちが具体的なプランを作り、ご提案すればお客様にご満足いただけるのではないかと思うからです。\n                  </p>\n                </section>\n                <section class=\"marginTop30\">\n                  <h3 class=\"mod-hl-02\">\n                    <span class=\"icon\">Q</span>目標や課題がありますか？\n                  </h3>\n                  <p>\n                    山陰で１番になりたいと思っています。もともと桧家住宅ブランドの住宅は、性能が高くて品質もよいため、その良さをお客様に伝えていければきっと達成できると思っています。\n                    また、松江展示場の店長として他のスタッフが働きやすい環境をつくり、みなで目標に向けて頑張っていければと思っています\n                  </p>\n                </section>\n              </div>\n            </div>\n          </div>\n          <!-- /articleBox-02 -->\n          <!-- articleBox-03 -->\n          <!-- a<div class=\"column-articleBox-subLeft--w300 l-innerBox marginTop60 clearfix\">\n            <div class=\"mod-column-sub\">\n              <img src=\"img/massage/pic_sample.jpg\" alt=\"スタッフ写真\" class=\"imgFit\">\n            </div>\n            <div class=\"mod-column-main\">\n              <div class=\"mod-column-main__inner\">\n                <h3 class=\"mod-hl-02\">\n                  <span class=\"icon\">Q</span>プライベートは何をしていますか？\n                </h3>\n                <p>\n                  この文章はダミーです。文字の大きさ、量、字間、行間等を確認するために入れています。この文章はダミーです。文字の大きさ、量、字間、行間等を確認するために入れています。この文章はダミーです。文字の大きさ、量、字間、行間等を確認するために入れています。\n                  この文章はダミーです。文字の大きさ、量、字間、行間等を確認するために入れています。この文章はダミーです。文字の大きさ、量、字間、行間等を確認するために入れています。この文章はダミーです。文字の大きさ、量、字間、行間等を確認するために入れています。\n                </p>\n              </div>\n            </div>\n          </div> -->\n          <!-- /articleBox-03 -->\n          <!-- btn -->\n          <div class=\"marginTop60 textCenter\">\n            <a href=\"message_index.html\" class=\"mod-btn-02 mod-btn-w300\">\n              <span class=\"icon-menu\">&thinsp;</span> 一覧に戻る\n            </a>\n          </div>\n          <!-- /btn -->\n        </section>\n      </div>\n      <!-- /l-container-sub -->\n    </div>\n  </main>\n  <!-- /main container -->\n\n  <!-- footer -->\n  <footer role=\"contentinfo\" class=\"mod-bg-cSub\">\n    <!-- footer -->\n    <div class=\"footer clearfix\">\n      <!-- main -->\n      <div class=\"footer__main\">\n        <a href=\"index.html\">\n          <img src=\"img/common/logo_footer_02.png\" alt=\"今岡工業株式会社\" class=\"imgFit footer__main__logo\">\n        </a>\n        <p class=\"footer__main__address\">\n          〒693-0024 島根県出雲市塩冶神前 2-8-16<br>\n          TEL <a href=\"tel:0853237778\">0853-23-7778</a> / FAX 0853-22-5959\n        </p>\n        <div class=\"footer__main__siteBtn\">\n          <a href=\"#\" class=\"hoverNot\"><span class=\"icon icon-arrow_right_02\">&thinsp;</span> 企業サイトへ</a>\n        </div>\n      </div>\n      <!-- /main -->\n      <!-- sub -->\n      <div class=\"footer__sub dn-mobile\">\n        <h6 class=\"footer__sub__hed\">MENU</h6>\n        <div class=\"clearfix footer__sub__menu\">\n          <ul>\n            <li><a href=\"index.html\" class=\"hoverNot\">トップページ</a></li>\n            <li><a href=\"message_index.html\" class=\"hoverNot\">先輩メッセージ</a></li>\n            <li><a href=\"crosstalk.html\" class=\"hoverNot\">新人座談会</a></li>\n          </ul>\n          <ul>\n            <li><a href=\"work.html\" class=\"hoverNot\">今岡工業の仕事</a></li>\n            <li><a href=\"guide_new_grad.html\" class=\"hoverNot\">募集要項</a></li>\n            <li><a href=\"faq.html\" class=\"hoverNot\">よくある質問</a></li>\n          </ul>\n          <ul>\n            <li><a href=\"/recruite_form/index\" class=\"hoverNot\">エントリーフォーム</a></li>\n          </ul>\n        </div>\n      </div>\n      <!-- /sub -->\n    </div>\n    <!-- /footer -->\n    <!-- copyright -->\n    <div class=\"mod-bg-cMain copyright\">\n      (C)Copyright 2019 imaokakogyo Corporation. All rights reserved.\n    </div>\n    <!-- /copyright -->\n  </footer>\n  <!-- /footer -->\n\n  <!-- pageTop -->\n  <div class=\"pageTop-box\">\n    <div id=\"pageTop\" class=\"pageTop\">\n      <img src=\"img/common/btn_pg_top.png\" alt=\"トップに戻る\" class=\"imgFit\">\n    </div>\n  </div>\n  <!-- /pageTop -->\n\n</body>\n\n</