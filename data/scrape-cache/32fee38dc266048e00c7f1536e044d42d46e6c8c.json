">About us</label>\n    <div class=\"content\">\n      <ul>\n        <li class=\"f_m10_10\"><a href=\"/about/index.shtml\">代表挨拶</a></li>\n        <li class=\"f_m10_20\"><a href=\"/about/overview.shtml\">会社概要</a></li>\n        <li class=\"f_m10_30\"><a href=\"/about/philosophy.shtml\">経営理念</a></li>\n        <li class=\"f_m10_40\"><a href=\"/about/promises.shtml\">7つのお約束</a></li>\n        <li class=\"f_m10_50\"><a href=\"/about/history.shtml\">沿革</a></li>\n        <li class=\"f_m10_60\"><a href=\"/about/employee.shtml\">社員保有資格一覧</a></li>\n        <li class=\"f_m10_70\"><a href=\"/about/certifications.shtml\">各種認定と宣言</a></li>\n      </ul>\n    </div>\n  </div>\n  <!-- menu2 -->\n  <div class=\"option\">\n    <div class=\"one_link\"><a href=\"../culture/\">Culture</a></div>\n  </div>\n  <!-- menu3 -->\n  <div class=\"option\">\n    <input type=\"checkbox\" id=\"toggle3\" class=\"toggle\">\n    <label class=\"title item50\" for=\"toggle3\">Solution</label>\n    <div class=\"content\">\n      <ul>\n        <li class=\"f_m30_10\"><a href=\"../solution/index.shtml#sp_jump_01\">システムソリューション</a></li>\n        <li class=\"f_m30_20\"><a href=\"../solution/index.shtml#jump_15\">場所から探す</a></a></li>\n        <li class=\"f_m30_30\"><a href=\"../solution/index.shtml#jump_02\">納入事例</a></a></li>\n      </ul>\n    </div>\n  </div>\n  <!-- menu4 -->\n  <div class=\"option\">\n    <input type=\"checkbox\" id=\"toggle4\" class=\"toggle\">\n    <label class=\"title item60\" for=\"toggle4\">Recruit</label>\n    <div class=\"content\">\n      <ul>\n        <li class=\"f_m40_10\"><a href=\"/recruit/\">採用情報</a></li>\n        <li class=\"f_m40_20\"><a href=\"/recruit/job.shtml\">職種紹介</a></li>\n        <li class=\"f_m40_30\"><a href=\"/recruit/interview.shtml\">社員インタビュー</a></li>\n        <li class=\"f_m40_40\"><a href=\"/recruit/requirements.shtml\">募集要項</a></li>\n      </ul>\n    </div>\n  </div>\n  <!-- menu5 -->\n  <div class=\"option\">\n    <div class=\"one_link\"><a href=\"../misc/contact.shtml\">Contact</a></div>\n  </div>\n<!-- menu6 -->\n  <div class=\"option\">\n    <div class=\"one_link\"><a href=\"../\">Home</a></div>\n  </div>\n</div alt=\"eod:accordion\">\n</header>\n<!-- --------------------------------------------------- --> \n\n \n  <!-- ヘッダーのインクルード 終わり　--> \n  \n  <!-- ステージ-->\n  <div id=\"zone_substage\">\n    <div>\n      <h1>About us</h1>\n    </div>\n    <!--- パンくず -->\n    <ol class=\"zone_pankuzu\">\n      <li><a href=\"../\">HOME</a></li>\n      <li>About us</li>\n    </ol>\n    <!-- パンくず -->\n  </div alt=\"eod:zone_substage\">\n  <!-- ステージ　終わり --> \n  <!-- 第2層 -->\n  <div id=\"zone_middle_floor\"> \n    <!--　ボディ領域　-->\n    <div id=\"zone_body\"> \n      <!--　メインエリア　-->\n      <div id=\"zone_mainarea_1col\">\n        <div class=\"sp_padding\"> \n          \n          <!--　▼▼▼　本文領域　▼▼▼　-->\n          <div class=\"col_textarea_full\">\n            <div class=\"fv\">\n              <div class=\"wrap\">\n                <h3>技術と人の力で、<br>\n                  豊かな未来を<br>\n                  実現する </h3>\n                <h2><small>キノンビクス株式会社<br>\n                  代表取締役</small>\n\t\t\t\t  <div class=\"name\"><img src=\"image/name.svg\"></div></h2>\n              </div>\n              <div class=\"img\"><img src=\"image/greeting.jpg\" alt=\"代表取締役 福永 悟\"></div>\n            </div>\n            <div class=\"flexbox greeting\">\n              <div>\n                <p>キノンビクスは、お客様にご満足いただくことを何よりの使命と考えています。その実現のために、確かな技術力、誠実な姿勢、そして人と人との信頼関係を大切にしながら歩んでまいりました。</p>\n                <p>当社は、放送・電話設備を手がける工事会社として1970年に創業し、現場の安全・安心と品質を提供することを使命としてきました。現在では、映像、音響、ICT、サービス、ソフトウェアなど、幅広い分野でソリューションを展開するマルチベンダーへと成長しています。その背景には、時代や市場の変化に応じて柔軟に対応してきた姿勢があります。私たちは、お客様のあらゆるニーズに応えるべく、変化を受け入れ、自らを進化させていく「カメレオン経営」を実践しています。</p>\n                <p>私たちの強みは、お客様に少しでも近い立場で物事を捉え、対話を重ねながら本質的な課題を見つけ出し、先回りしてご提案できることです。各部門が密に連携し、一体となって最適な解決策を考え、お客様の期待を超える価値を届けられるよう努めています。お客様のその先にいる人々まで見据えた視点で、より良い提案をし、より安心できる環境を共に築く。それが、私たちが社会の中で果たすべき役割であると考えています。</p>\n                <p>また、私たちは社員一人ひとりのやりがいや成長が、会社の力そのものであると信じており、社員が前向きにチャレンジできる環境づくりと、人材育成・働きがいのある評価制度・充実した福利厚生の整備に力を入れています。個人や家庭の満足が仕事のやりがいにつながり、それがお客様の満足や社会の発展へとつながっていく。そんな好循環を生み出す企業でありたいと願っています。</p>\n                <p>キノンビクスはこれからも、関西に根差した企業として、地域のお客様に寄り添いながら、技術と人の力で期待を超える価値を提供し続けていきます。そして、すべての出会いを「一期一会」として大切にし、豊かな未来の実現に貢献してまいります。</p>\n              </div>\n            </div>\n            \n            <ul class=\"l_list_link\">\n\t\t\t  <li> <a class=\"l_btn_line\" href=\"overview.shtml\"> <span class=\"top-key\"></span> <span class=\"text\"><em>Company Profile</em>\n\t\t\t\t<h4>会社概要</h4>\n\t\t\t\t</span> <span class=\"bottom-key-1\"></span> </a> </li>\n\t\t\t  <li> <a class=\"l_btn_line\" href=\"philosophy.shtml\"> <span class=\"top-key\"></span> <span class=\"text\"><em>Corporate Philosophy</em>\n\t\t\t\t<h4>経営理念</h4>\n\t\t\t\t</span> <span class=\"bottom-key-1\"></span> </a> </li>\n\t\t\t  <li> <a class=\"l_btn_line\" href=\"promises.shtml\"> <span class=\"top-key\"></span> <span class=\"text\"><em>Our 7 Promises</em>\n\t\t\t\t<h4>7つのお約束</h4>\n\t\t\t\t</span> <span class=\"bottom-key-1\"></span> </a> </li>\n\t\t\t  <li> <a class=\"l_btn_line\" href=\"history.shtml\"> <span class=\"top-key\"></span> <span class=\"text\"><em>Company History</em>\n\t\t\t\t<h4>沿革</h4>\n\t\t\t\t</span> <span class=\"bottom-key-1\"></span> </a> </li>\n\t\t\t  <li> <a class=\"l_btn_line\" href=\"employee.shtml\"> <span class=\"top-key\"></span> <span class=\"text\"><em>Employee Certifications</em>\n\t\t\t\t<h4>社員保有資格一覧</h4>\n\t\t\t\t</span> <span class=\"bottom-key-1\"></span> </a> </li>\n\t\t\t  <li> <a class=\"l_btn_line\" href=\"certifications.shtml\"> <span class=\"top-key\"></span> <span class=\"text\"><em>Certifications &amp; Declarations</em>\n\t\t\t\t<h4>各種認定と宣言</h4>\n\t\t\t\t</span> <span class=\"bottom-key-1\"></span> </a> </li>\n\t\t\t</ul>\n            \n          </div alt=\"col_textarea_full\">\n          <!--　▲▲▲　本文領域　終わり　▲▲▲　--> \n        </div>\n        <!-- eod:sp_padding --> \n      </div alt=\"eod