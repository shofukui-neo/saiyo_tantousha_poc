).clone(true);\n\t\t\t\t\t$picker__footer.addClass('tmp__header');\n\t\t\t\t\t$('.picker__box').prepend($picker__footer);\n\t\t\t\t}\t\n\t\t\t});\n\t\t});\t\n\t});\n\n\tvar _ua = (function(u){\n\t  return {\n\t    Tablet:(u.indexOf(\"windows\") != -1 && u.indexOf(\"touch\") != -1 && u.indexOf(\"tablet pc\") == -1) \n\t      || u.indexOf(\"ipad\") != -1\n\t      || (u.indexOf(\"android\") != -1 && u.indexOf(\"mobile\") == -1)\n\t      || (u.indexOf(\"firefox\") != -1 && u.indexOf(\"tablet\") != -1)\n\t      || u.indexOf(\"kindle\") != -1\n\t      || u.indexOf(\"silk\") != -1\n\t      || u.indexOf(\"playbook\") != -1,\n\t    Mobile:(u.indexOf(\"windows\") != -1 && u.indexOf(\"phone\") != -1)\n\t      || u.indexOf(\"iphone\") != -1\n\t      || u.indexOf(\"ipod\") != -1\n\t      || (u.indexOf(\"android\") != -1 && u.indexOf(\"mobile\") != -1)\n\t      || (u.indexOf(\"firefox\") != -1 && u.indexOf(\"mobile\") != -1)\n\t      || u.indexOf(\"blackberry\") != -1\n\t  }\n\t})(window.navigator.userAgent.toLowerCase());\n</script>\n\n<script src=\"/php/js/inquiry_table.js\"></script>\n\n</head>\n\n<body>\n<!-- Google Tag Manager (noscript) -->\r\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-NN3KNF\"\r\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\r\n<!-- End Google Tag Manager (noscript) -->\r\n\r\n<ul class=\"skipLinks\">\r\n\t<li><a href=\"#mainContents\">このページの本文へ</a></li>\r\n</ul>\r\n\r\n<header class=\"header\" id=\"pageTop\">\r\n\t<div class=\"headerLogo\"><a href=\"/\"><img src=\"/assets/img/logo_tis.svg\" alt=\"TIS株式会社\"></a></div>\r\n</header>\n<nav class=\"breadcrumb\">\n\t<ol itemscope itemtype=\"http://schema.org/BreadcrumbList\">\n\t\t<li itemscope itemprop=\"itemListElement\" itemtype=\"http://schema.org/ListItem\">\n\t\t\t<a itemprop=\"item\" href=\"/\"><span itemprop=\"name\">HOME</span></a>\n\t\t\t<meta itemprop=\"position\" content=\"1\" />\n\t\t</li>\n\t\t<li itemscope itemprop=\"itemListElement\" itemtype=\"http://schema.org/ListItem\">\n\t\t\t<span itemprop=\"name\">IRに関するお問い合わせ</span>\n\t\t\t<meta itemprop=\"position\" content=\"2\" />\n\t\t</li>\n\t</ol>\n</nav>\n\n<div class=\"container wideStyle\">\n\t<main id=\"mainContents\"  >\n\t\t<article>\n\t\t\t<h1>IRに関するお問い合わせ</h1>\n\t\t\t<nav id=\"stepFlow\">\n\t\t\t\t<ol>\n\t\t\t\t\t<li class=\"cur\"><span>step1:</span><span>入力</span></li>\n\t\t\t\t\t<li><span>step2:</span><span>確認</span></li>\n\t\t\t\t\t<li><span>step3:</span><span>完了</span></li>\n\t\t\t\t</ol>\n\t\t\t</nav>\n\t\t\t<p>\n\t\t\t\t<small class=\"indChrSp1\"><span class=\"mark\">※</span>入力していただいた情報は、SSLによる暗号化通信により安全に送受信されます。<br />\n\t\t\t\t<span style=\"color: rgb(255, 0, 0);\">[必須]</span>の付いている項目は必ずご記入ください。</small>\n\t\t\t</p>\n\n<form action=\"/contact/confirm.php\" method=\"post\" id=\"form\">\n<input type=\"hidden\" name=\"inq_token\" value=\"279c023fdfbc7c6e918c2aff7093295b1e397c71\">\n<input type=\"hidden\" name=\"form_code\" value=\"ir\">\n<input type=\"hidden\" name=\"form_referer\" value=\"\">\n<h2>お客様情報</h2><table class=\"tableTypeF\"><tbody><tr><th id=\"TH2\">お名前</th><td><div class=\"name_wrapper\"><label for=\"Q2_2\">姓</label> <input type=\"text\" id=\"Q2_2\" name=\"Q2_2\" value=\"\" placeholder=\"例) 山田\" class=\"inquiry_text_medium\"> <span id=\"Q2_2-error\" class=\"rightSideErrorMsg errorMsgY\"></span></div><div class=\"name_wrapper\"><label for=\"Q2_3\">名</label> <input type=\"text\" id=\"Q2_3\" name=\"Q2_3\" value=\"\" placeholder=\"例) 太郎\" class=\"inquiry_text_medium\"> <span id=\"Q2_3-error\" class=\"rightSideErrorMsg errorMsgY\"></span></div></td></tr><tr><th id=\"TH3\">お名前（フリガナ）</th><td><div class=\"name_wrapper\"><label for=\"Q3_4\">セイ</label> <input type=\"text\" id=\"Q3_4\" name=\"Q3_4\" value=\"\" placeholder=\"例) ヤマダ\" class=\"inquiry_text_medium\"> <span id=\"Q3_4-error\" class=\"rightSideErrorMsg errorMsgY\"></span></div><div class=\"name_wrapper\"><label for=\"Q3_5\">メイ</label> <input type=\"text\" id=\"Q3_5\" name=\"Q3_5\" value=\"\" placeholder=\"例) タロウ\" class=\"inquiry_text_medium\"> <span id=\"Q3_5-error\" class=\"rightSideErrorMsg errorMsgY\"></span></div></td></tr><tr><th id=\"TH326\">年齢</th><td> <input type=\"text\" id=\"Q326_585\" name=\"Q326_585\" value=\"\" title=\"年齢\"  class=\"inquiry_text_small\"> <span id=\"Q326_585-error\" class=\"rightSideErrorMsg errorMsgY\"></span>歳<p>※半角数字入力</p></td></tr><tr><th id=\"TH1\">Email アドレス</th><td> <input type=\"text\" id=\"Q1_1\" name=\"Q1_1\" value=\"\" placeholder=\"例) taro@xxx.xx.jp\" title=\"Email アドレス\"  class=\"inquiry_text_large\"> <span id=\"Q1_1-error\" class=\"rightSideErrorMsg errorMsgY\"></span><p>※返信メールの送付先になります。</p></td></tr><tr><th id=\"TH327\">ご職業</th><td class=\"inquiry_column_3\"><fieldset><legend>ご職業</legend><label>\r\n\t<input type=\"radio\"  name=\"Q327\" value=\"586\"  >\r\n\t個人投資家</label>\r\n<label>\r\n\t<input type=\"radio\"  name=\"Q327\" value=\"587\"  >\r\n\t機関投資家</label>\r\n<label>\r\n\t<input type=\"radio\"  name=\"Q327\" value=\"588\"  >\r\n\t証券会社</label>\r\n<div class=\"inquiry_column_item\">\r\n<label>\r\n\t<input type=\"radio\" id=\"Q327_589P\" name=\"Q327\" value=\"589\"  >\r\n\tその他</label>\r\n\t<input type=\"text\" id=\"Q327_589\" name=\"Q327_589\" value=\"\" title=\"その他\">&nbsp;<span id=\"Q327_589-error\" class=\"rightSideErrorMsg errorMsgY\"></span></div>\r\n</fieldset><input type=\"hidden\" id=\"Q327\" class=\"T4\" /><span id=\"Q327-error\" class=\"rightSideErrorMsg errorMsgY\"></span></td></tr></tbody></table><table class=\"tableTypeF\"><tbody><tr><th id=\"TH367\">お問い合わせ内容</th><td><textarea id=\"Q367_633\" name=\"Q367_633\" title=\"お問い合わせ内容\"  class=\"inquiry_textarea_large\" rows=\"6\"></textarea><span id=\"Q367_633-error\" class=\"rightSideErrorMsg errorMsgY\"></span><br>※お問い合わせ内容を1000文字以内で入力ください。</td></tr></tbody></table><h2>資料送付先ご住所</h2><div>\r\n<p>※資料をご請求される方は必ずご記入ください。</p></div>\r\n<table class=\"tableTypeF\"><tbody><tr><th id=\"TH322\">住所</th><td class=\"inquiry_column_1\"><labe