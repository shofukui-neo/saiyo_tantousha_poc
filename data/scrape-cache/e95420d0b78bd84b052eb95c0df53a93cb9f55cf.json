 <link rel=\"stylesheet\" type=\"text/css\" href=\"../_webfonts.css?1777211641616\" id=\"webfont-css\"> \n  <link rel=\"stylesheet\" type=\"text/css\" href=\"../_csslinkbtn/btn-import.css?1767099951882\" id=\"linkbtn-css\"> \n </head> \n <body id=\"l-2\" class=\"l-2 l-fixed-side -dress_pp013recruit bd-webp\" data-type=\"responsive\" data-layout-type=\"sidefixed\" data-view-pc-button=\"true\" data-view-pc-position=\"bottom\" data-page-animation=\"none\"> \n  <div id=\"page\" class=\"bg-window \"> \n   <div class=\"bg-document\"> \n    <noscript> \n     <div id=\"js-off\"> \n      <img src=\"../_module/images/noscript.gif\" alt=\"Enable JavaScript in your browser. このウェブサイトはJavaScriptをオンにしてご覧下さい。\"> \n     </div> \n    </noscript> \n    <div id=\"a-header\" data-float=\"false\" class=\"a-header   cssskin-_area_header\"> \n     <header> \n      <div class=\"site_frame\"> \n       <section> \n        <div id=\"bk5279\" class=\"b-plain c-space_normal c-sp-space_normal c-padding_narrow c-sp-padding_normal cssskin-_block_header\" data-bk-id=\"bk5279\" data-shared=\"true\" data-sharedname=\"HEADER2\"> \n         <div class=\" column -column1\"> \n          <div class=\" c-body\"> \n           <div class=\"c-img   \"> \n            <a href=\"../index.html\" data-pid=\"70\"> \n             <picture> \n              <source type=\"image/webp\" srcset=\"../_src/960/logo-credit-500.webp?v=1767099951882\"> \n              <img src=\"../_src/960/logo-credit-500.png?v=1767099951882\" width=\"2085\" height=\"327\" alt=\"\" id=\"imgsrc960_1\" class=\" c-no_adjust\" loading=\"lazy\"> \n             </picture></a> \n           </div> \n          </div> \n         </div> \n        </div> \n        <div id=\"bk5280\" class=\"b-plain -blog-article c-space_narrow c-sp-space_normal c-sp-padding_normal bd-webp -dress_white cssskin-_block_header\" data-bk-id=\"bk5280\" data-shared=\"true\" data-sharedname=\"HEADER\"> \n         <div class=\" column -column1\"> \n          <nav> \n           <div id=\"js-globalNavigation\" data-slide-type=\"rightSlide\" data-btn-position=\"rightTop\"> \n            <div class=\" js-motion\"> \n             <ul class=\"m-motion menu-parts -f\"> \n              <li class=\" c-left\"><a href=\"../company_profile/index.html\" data-pid=\"77\">ご挨拶</a></li> \n              <li class=\" c-left\"><a href=\"../company_profile/index1.html\" data-pid=\"78\">企業概要</a> \n               <ul> \n                <li class=\" c-left\"><a href=\"../company_profile/index1.html#profile\" data-pid=\"78\">会社概要</a></li> \n                <li class=\" c-left\"><a href=\"../company_profile/index1.html#history\" data-pid=\"78\">沿革</a></li> \n                <li class=\" c-left\"><a href=\"../company_profile/index1.html#maker\" data-pid=\"78\">取り扱いメーカー</a></li> \n               </ul></li> \n              <li class=\" c-left\"><a href=\"../Activities/index.html\" data-pid=\"123\">事業案内</a></li> \n              <li class=\" c-left\"><a href=\"../base/location.html\" data-pid=\"103\">事業所一覧</a></li> \n              <li class=\" c-left\"><a href=\"../Product_guide/product01.html\" data-pid=\"90\">取扱商品</a></li> \n              <li class=\" c-left\"><a href=\"../festa2022/index.html\" data-pid=\"79\">ツールdeフェスタ</a></li> \n              <li class=\" c-left\"><a href=\"https://job-gear.net/sankotech/\">採用情報</a></li> \n              <li class=\" c-left\"><a href=\"../Information/index.html\" data-pid=\"122\">お問い合わせ</a></li> \n              <li class=\" c-left\"><a href=\"../info.html\" data-pid=\"72\">Information</a> \n               <ul> \n                <li class=\" c-left\"><a href=\"../info.html\" data-pid=\"72\">新着情報</a></li> \n                <li class=\" c-left\"><a href=\"../stj.html\" data-pid=\"73\">STジャーナル</a></li> \n               </ul></li> \n             </ul> \n            </div> \n           </div> \n           <div id=\"spNavigationTrigger\" class=\" c-sp_navigation_btn\"></div> \n          </nav> \n         </div> \n        </div> \n       </section> \n      </div> \n     </header> \n    </div> \n    <div id=\"a-billboard\" class=\"a-billboard    cssskin-_area_billboard\"> \n     <div class=\"site_frame\"> \n      <section> \n       <div id=\"bk5281\" class=\"b-plain c-space_normal c-sp-space_normal c-sp-padding_init cssskin-_block_billboard\" data-bk-id=\"bk5281\"> \n        <div class=\" column -column1\"> \n         <div class=\" c-body\"> \n          <div class=\"c-img   \"> \n           <picture> \n            <source type=\"image/webp\" srcset=\"../_src/6770/information_banner_20190526095941163.webp?v=1767099951882\"> \n            <img src=\"../_src/6770/information_banner_20190526095941163.jpg?v=1767099951882\" width=\"1000\" height=\"300\" alt=\"\" id=\"imgsrc6770_1\" loading=\"lazy\"> \n           </picture> \n          </div> \n         </div> \n        </div> \n       </div> \n       <div id=\"bk5282\" class=\"b-plain c-space_normal c-sp-space_normal c-sp-padding_normal cssskin-h2_midashi2\" data-bk-id=\"bk5282\"> \n        <div class=\" column -column1\" id=\"top\"> \n         <h4 class=\" c-small_headline\">&nbsp; <span style=\"color:#ffffff;\">&nbsp;&nbsp;新着情報</span></h4> \n        </div> \n       </div> \n      </section> \n     </div> \n    </div> \n    <main> \n     <div id=\"a-site_contents\" class=\"a-site_contents  noskin\"> \n      <article> \n       <div class=\"site_frame\"> \n        <div class=\"g-column\"> \n         <div id=\"a-main\" class=\"a-main column -col8 \"> \n          <section> \n           <div id=\"bk5298\" class=\"b-plain c-space_normal c-sp-space_normal c-padding_normal c-sp-padding_normal cssskin-_block_main\" data-bk-id=\"bk5298\"> \n            <div class=\" column -column1\" id=\"231220\"> \n             <p class=\" c-body\"><span class=\" d-large_font\"><span class=\" d-bold\"><span style=\"color:#073763;\">仙台営業所本社 紹介動画公開しました</span></span></span></p> \n             <div class=\" c-body c-right\"> \n              <hr class=\"c-hr\"> 2023.12.20 \n             </div> \n             <div class=\" c-body c-left\"> \n              <span style=\"color:#000000;\">今夏よりお届けしております営業所紹介動画、</span> \n             </div> \n             <div class=\" c-body c-left\"> \n              <span style=\"color:#000000;\">今回は仙台営業所の紹介動画を公開しましたのでぜひご覧ください！</span> \n             </div> \n             <div class=\" c-body c-left\">\n               &nbsp; \n             </div> \n             <div class=\" c-body c-left\"> \n              <span style=\"color:#000000;\"><span class=\"js-sync -video\" style=\"display:none;\">,http://gdata.youtube.com/feeds/api/videos/sX7hvwcglbk,,{\"playerWidth\":\"425\",\"useCustom\":false,\"autoPlay\":false,\"autoLoop\":false,\"autoNext\":false,\"quality\":\"default\",\"qualityName\":\"自動\",\"coverImage\":\"\"}</span></span> \n             </div> \n             <div class=\" c-body c-left\">\n               &nbsp; \n             </div> \n             <div class=\" c-body c-left\"> \n              <span style=\"color:#434343;\" data-sitecolor-text=\"\">動画は<a href=\"../base/sendai.html\" data-pid=\"107\">事業所一覧</a> からもご視聴頂けます</span> \n              <br> \n              <br> \n              <span style=\"color:#000000;\">これから紹介動画を増やしていけるよう、撮影頑張っておりますので、どうぞご期待ください</span> \n              <span style=\"color:#434343;\" data-sitecolor-text=\"\"></span> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk5299\" class=\"b-plain c-space_normal c-sp-space_normal c-padding_normal c-sp-padding_normal cssskin-_block_main\" data-bk-id=\"bk5299\"> \n            <div class=\" column -column1\" id=\"231125\"> \n             <p class=\" c-body\"><span class=\" d-large_font\"><span class=\" d-bold\"><span style=\"color:#073763;\">冬季休暇の御案内</span></span></span></p> \n             <div class=\" c-body c-right\"> \n              <hr class=\"c-hr\"> 2023.11.25 \n             </div> \n             <div class=\" c-body c-left\">\n               平素は格別のご高配を賜り、厚く御礼を申し上げます \n             </div> \n             <div class=\" c-body c-left\">\n               &nbsp; \n             </div> \n             <div class=\" c-body c-left\"> \n              <span style=\"color:#434343;\" data-sitecolor-text=\"\">弊社では下記の期間を冬季休暇とさせて頂きます</span> \n              <br> \n              <span style=\"color:#434343;\">期間中は何かとご不便をお掛けいたしますが、宜しくお願い申し上げます　</span> \n              <br> \n              <br> \n              <span class=\" d-bold\"><span style=\"color:#a61c00;\" data-sitecolor-text=\"\">2023年12月28日(木曜日)〜2024年1月4日(木曜日)</span></span> \n              <br> \n              <br> \n              <span style=\"color:#434343;\" data-sitecolor-text=\"\">レンタル商品の納品・引取は、お早めに御連絡くださいますようお願い申し上げます</span> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk5300\" class=\"b-plain c-space_normal c-sp-space_normal c-padding_normal c-sp-padding_normal cssskin-_block_main\" data-bk-id=\"bk5300\"> \n            <div class=\" column -column1\" id=\"231122\"> \n             <p class=\" c-body\"><span class=\" d-large_font\"><span class=\" d-bold\"><span style=\"color:#073763;\">東京本社 紹介動画公開しました</span></span></span></p> \n             <div class=\" c-body c-right\"> \n              <hr class=\"c-hr\"> 2023.11.22 \n             </div> \n             <div class=\" c-body c-left\"> \n              <span style=\"color:#000000;\">今夏よりお届けしております営業所紹介動画、</span> \n             </div> \n             <div class=\" c-body c-left\"> \n              <span style=\"color:#000000;\">今回は東京本社の紹介動画を公開しましたのでぜひご覧ください</span> \n             </div> \n             <div class=\" c-body c-left\">\n               &nbsp; \n             </div> \n             <div class=\" c-body c-left\"> \n              <span class=\"js-sync -video\" style=\"display:none;\">,http://gdata.youtube.com/feeds/api/videos/dsnxzc9nSps,,{\"playerWidth\":\"425\",\"useCustom\":false,\"autoPlay\":false,\"autoLoop\":false,\"autoNext\":false,\"quality\":\"default\",\"qualityName\":\"自動\",\"coverImage\":\"\"}</span> \n             </div> \n             <div class=\" c-body c-left\">\n               &nbsp; \n             </div> \n             <div class=\" c-body c-left\"> \n              <span style=\"color:#434343;\" data-sitecolor-text=\"\">動画は<a href=\"../base/tokyo.html\" data-pid=\"104\">事業所一覧</a> からもご視聴頂けます</span> \n              <br> \n              <br> \n              <span style=\"color:#000000;\">これから紹介動画を増やしていけるよう、撮影頑張っておりますので、どうぞご期待ください</span> \n              <span style=\"color:#434343;\" data-sitecolor-text=\"\"></span> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk5301\" class=\"b-plain c-space_normal c-sp-space_normal c-sp-padding_normal cssskin-_block_main\" data-bk-id=\"bk5301\"> \n            <div class=\" column -column1\" id=\"231030\"> \n             <p class=\" c-body\"><span style=\"color:#073763;\" class=\" d-large_font\"><span class=\" d-bold\">第72回 リーダー会議実施</span></span></p> \n             <div class=\" c-body c-right\"> \n              <hr class=\"c-hr\"> \n              <span style=\"color:#434343;\" data-sitecolor-text=\"\">2023.10.30&nbsp;</span> \n             </div> \n             <div class=\" c-body c-left\">\n               &nbsp; \n             </div> \n             <div class=\" c-body c-left\"> \n              <span style=\"color:#434343;\" data-sitecolor-text=\"\">9月22日・23日の2日間に渡って当社大阪営業所にてリーダー会議を実施しました</span> \n             </div> \n             <div class=\" c-body c-left\"> \n              <span style=\"color:#434343;\" data-sitecolor-text=\"\"><br>当会議自体も既に72回目となり、今回は「組織力の再構築」というテーマを軸に討議を行い、</span> \n             </div> \n             <div class=\" c-body c-left\"> \n              <span style=\"color:#434343;\" data-sitecolor-text=\"\">会社として目指すべきものという共通認識をまずは参加者メンバーで再確認しました<br>対面でのやり取りにて、リモートにはない臨場感と雰囲気にて実のある場となりました</span> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk5302\" class=\"b-plain c-space_narrow c-sp-space_normal c-padding_narrow c-sp-padding_normal cssskin-_block_main\" data-bk-id=\"bk5302\"> \n            <div class=\" g-column -col2 -sp-col1\"> \n             <div class=\" column -column1\"> \n              <div class=\" c-body\"> \n               <div class=\"c-img   \"> \n                <picture> \n                 <source type=\"image/webp\" srcset=\"../_src/6793/1_img_0776.webp?v=1767099951882\"> \n                 <img src=\"../_src/6793/1_img_0776.jpg?v=1767099951882\" width=\"2048\" height=\"1536\" alt=\"\" id=\"imgsrc6793_1\" loading=\"lazy\"> \n                </picture> \n               </div> \n              </div> \n             </div> \n             <div class=\" column -column2 -column-lasts\"> \n              <div class=\" c-body\"> \n               <div class=\"c-img   \"> \n                <picture> \n                 <source type=\"image/webp\" srcset=\"../_src/6795/1_img_0775.webp?v=1767099951882\"> \n                 <img src=\"../_src/6795/1_img_0775.jpg?v=1767099951882\" width=\"2048\" height=\"1536\" alt=\"\" id=\"imgsrc6795_1\" loading=\"lazy\"> \n                </picture> \n               </div> \n              </div> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk5303\" class=\"b-plain c-space_normal c-sp-space_normal c-padding_normal c-sp-padding_normal cssskin-_block_main\" data-bk-id=\"bk5303\"> \n            <div class=\" column -column1\" id=\"230822\"> \n             <p class=\" c-body\"><span class=\" d-large_font\"><span class=\" d-bold\"><span style=\"color:#073763;\">四日市営業所 紹介動画公開しました</span></span></span></p> \n             <div class=\" c-body c-right\"> \n              <hr class=\"c-hr\"> 2023.08.22 \n             </div> \n             <div class=\" c-body c-left\"> \n              <span style=\"color:#000000;\">先月よりお届けしております営業所紹介動画、</span> \n             </div> \n             <div class=\" c-body c-left\"> \n              <span style=\"color:#000000;\">今回は四日市営業所の紹介動画を公開しました！</span> \n             </div> \n             <div class=\" c-body c-left\">\n               &nbsp; \n             </div> \n             <div class=\" c-body c-left\">\n               ぜひご覧ください！ \n             </div> \n             <div class=\" c-body c-left\">\n               &nbsp; \n             </div> \n             <div class=\" c-body c-left\"> \n              <span class=\"js-sync -video\" style=\"display:none;\">,http://gdata.youtube.com/feeds/api/videos/_K9ZEc-TRzU,,{\"playerWidth\":\"425\",\"useCustom\":false,\"autoPlay\":false,\"autoLoop\":false,\"autoNext\":false,\"quality\":\"default\",\"qualityName\":\"自動\",\"coverImage\":\"\"}</span> \n             </div> \n             <div class=\" c-body c-left\">\n               &nbsp; \n             </div> \n             <div class=\" c-body c-left\">\n               動画は \n              <a href=\"../base/location.html\" data-pid=\"103\">事業所一覧</a> からもご視聴頂けます \n              <br> \n              <br> \n              <span style=\"color:#000000;\">引き続きこれから増やしていけるよう、撮影頑張りますのでご期待ください！</span> \n              <span style=\"color:#434343;\" data-sitecolor-text=\"\"></span> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk5304\" class=\"b-plain c-space_normal c-sp-space_normal c-padding_normal c-sp-padding_normal cssskin-_block_main\" data-bk-id=\"bk5304\"> \n            <div class=\" column -column1\" id=\"230711\"> \n             <p class=\" c-body\"><span class=\" d-large_font\"><span class=\" d-bold\"><span style=\"color:#073763;\">営業所紹介動画 掲載のお知らせ</span></span></span></p> \n             <div class=\" c-body c-right\"> \n              <hr class=\"c-hr\"> 2023.07.11 \n             </div> \n             <div class=\" c-body c-left\"> \n              <span style=\"color:#000000;\">この度、もっと弊社を知って頂きたく事業所毎の動画掲載を始めました！</span> \n              <br> \n              <span style=\"color:#000000;\">　</span> \n              <br> \n              <span style=\"color:#000000;\">「どんな場所に営業所が建っているのかな…」</span> \n             </div> \n             <div class=\" c-body c-left\"> \n              <span style=\"color:#000000;\">「どんな環境で仕事をしているのかな…」</span> \n             </div> \n             <div class=\" c-body c-left\"> \n              <br> \n              <span style=\"color:#000000;\">第一弾は熊谷営業所・八戸営業所です</span> \n             </div> \n             <div class=\" c-body c-left\">\n               &nbsp; \n             </div> \n             <div class=\" c-body c-left\"> \n              <span class=\"js-sync -video\" style=\"display:none;\">,http://gdata.youtube.com/feeds/api/videos/dUF2oqGWEhE,,{\"playerWidth\":\"425\",\"useCustom\":false,\"autoPlay\":false,\"autoLoop\":false,\"autoNext\":false,\"quality\":\"default\",\"qualityName\":\"自動\",\"coverImage\":\"\"}</span>　 \n             </div> \n             <div class=\" c-body c-left\">\n               熊谷営業所&nbsp; \n             </div> \n             <div class=\" c-body c-left\"> \n              <span class=\"js-sync -video\" style=\"display:none;\">,http://gdata.youtube.com/feeds/api/videos/oLdcSx8-uWY,,{\"playerWidth\":\"425\",\"useCustom\":false,\"autoPlay\":false,\"autoLoop\":false,\"autoNext\":false,\"quality\":\"default\",\"qualityName\":\"自動\",\"coverImage\":\"\"}</span> \n             </div> \n             <div class=\" c-body c-left\">\n               八戸営業所 \n             </div> \n             <div class=\" c-body c-left\">\n               &nbsp; \n             </div> \n             <div class=\" c-body c-left\">\n               &nbsp; \n             </div> \n             <div class=\" c-body c-left\">\n               動画は \n              <a href=\"../base/location.html\" data-pid=\"103\">事業所一覧</a> からもご視聴頂けます \n              <br> \n              <br> \n              <span style=\"color:#000000;\">これからもっと増やしていけるよう、撮影頑張りますのでご期待ください！</span> \n              <span style=\"color:#434343;\" data-sitecolor-text=\"\"></span> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk5305\" class=\"b-plain c-space_normal c-sp-space_normal c-padding_normal c-sp-padding_normal cssskin-_block_main\" data-bk-id=\"bk5305\"> \n            <div class=\" column -column1\" id=\"230710\"> \n             <p class=\" c-body\"><span class=\" d-large_font\"><span class=\" d-bold\"><span style=\"color:#073763;\">夏季休暇の御案内</span></span></span></p> \n             <div class=\" c-body c-right\"> \n              <hr class=\"c-hr\"> 2023.07.10 \n             </div> \n             <div class=\" c-body c-left\">\n               平素は格別のご高配を賜り、厚く御礼を申し上げます \n             </div> \n             <div class=\" c-body c-left\">\n               &nbsp; \n             </div> \n             <div class=\" c-body c-left\"> \n              <span style=\"color:#434343;\" data-sitecolor-text=\"\">弊社では下記の期間を夏期休暇とさせて頂きます</span> \n              <br> \n              <span style=\"color:#434343;\">期間中は何かとご不便をお掛けいたしますが、宜しくお願い申し上げます　</span> \n              <br> \n              <br> \n              <span class=\" d-bold\"><span style=\"color:#a61c00;\" data-sitecolor-text=\"\">8月11日(金曜日)〜16日(水曜日)</span></span> \n              <br> \n              <br> \n              <span style=\"color:#434343;\" data-sitecolor-text=\"\">レンタル商品の納品・引取は、お早めに御連絡くださいますようお願い申し上げます</span> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk5306\" class=\"b-plain c-space_normal c-sp-space_normal c-padding_normal c-sp-padding_normal cssskin-_block_main\" data-bk-id=\"bk5306\"> \n            <div class=\" column -column1\" id=\"230425\"> \n             <p class=\" c-body\"><span class=\" d-large_font\"><span class=\" d-bold\"><span style=\"color:#073763;\">ゴールデンウィーク休業のご案内</span></span></span></p> \n             <div class=\" c-body c-right\"> \n              <hr class=\"c-hr\"> 2023.04.25 \n             </div> \n             <div class=\" c-body c-left\">\n               平素は格別のご高配を賜り、厚く御礼を申し上げます \n             </div> \n             <div class=\" c-body c-left\">\n               &nbsp; \n             </div> \n             <div class=\" c-body c-left\">\n               誠に勝手ながら&nbsp; \n              <span style=\"color:#1c4587;\"><span class=\" d-bold\">2023年5月3日(水)〜5月7日(日)</span></span>の期間を \n              <span style=\"color:#1c4587;\"><span class=\" d-bold\">休業</span></span>とさせて頂きます \n             </div> \n             <p class=\" c-body\"><span class=\" d-bold\"><span style=\"color:#a61c00;\">5月8日(月)より通常通り営業</span></span>致します<br>&nbsp;<br>お客様にはご不便をお掛けいたしますが、ご理解とご協力のほど宜しくお願い致します</p> \n            </div> \n           </div> \n           <div id=\"bk5307\" class=\"b-plain c-space_normal c-sp-space_normal c-sp-padding_normal cssskin-_block_main\" data-bk-id=\"bk5307\"> \n            <div class=\" column -column1\" id=\"230310\"> \n             <p class=\" c-body\"><span style=\"color:#073763;\" class=\" d-large_font\"><span class=\" d-bold\">創立45周年記念として社員旅行へ行きました</span></span></p> \n             <div class=\" c-body c-right\"> \n              <hr class=\"c-hr\"> \n              <span style=\"color:#434343;\" data-sitecolor-text=\"\">2023.3.10&nbsp;</span> \n             </div> \n             <div class=\" c-body c-left\">\n               &nbsp; \n             </div> \n             <div class=\" c-body c-left\"> \n              <span style=\"color:#434343;\" data-sitecolor-text=\"\">おかげさまで弊社は創立45周年を迎えることができました</span> \n             </div> \n             <div class=\" c-body c-left\">\n               &nbsp; \n             </div> \n             <div class=\" c-body c-left\"> \n              <span style=\"color:#434343;\">その記念として2023年2月に社員旅行（ハワイ）へ行きました</span> \n             </div> \n             <div class=\" c-body c-left\"> \n              <span style=\"color:#434343;\">今回は遊ぶだけでなく、SDGsへの取組みの一環として、</span> \n             </div> \n             <div class=\" c-body c-left\"> \n              <span style=\"color:#434343;\">海に流れ込むプラスチックごみ問題に対するセミナーも全員で拝聴しました</span> \n             </div> \n             <div class=\" c-body c-left\"> \n              <span style=\"color:#434343;\" data-sitecolor-text=\"\">現地は非常に風の強い日が続きましたが、日頃の喧騒を忘れ、楽しい時間を皆で過ごすことが出来ました</span> \n             </div> \n             <div class=\" c-body c-left\">\n               &nbsp; \n             </div> \n            </div> \n           </div> \n           <div id=\"bk5308\" class=\"b-plain c-space_narrow c-sp-space_normal c-padding_narrow c-sp-padding_normal cssskin-_block_main -js-bindZoom\" data-bk-id=\"bk5308\"> \n            <div class=\" g-column -col2 -sp-col1\"> \n             <div class=\" column -column1\"> \n              <div class=\" c-body\"> \n               <div class=\"c-img   \"> \n                <a href=\"../_src/6798/45th_hawaii_2.jpg?v=1767099951882\" class=\"js-zoomImage\" rel=\"width=1000,height=667\"> \n                 <picture> \n                  <source type=\"image/webp\" srcset=\"../_src/6797/45th_hawaii_2.webp?v=1767099951882\"> \n                  <img src=\"../_src/6797/45th_hawaii_2.jpg?v=1767099951882\" width=\"1000\" height=\"667\" alt=\"\" id=\"imgsrc6797_1\" loading=\"lazy\"> \n                 </picture></a> \n               </div> \n              </div> \n             </div> \n             <div class=\" column -column2 -column-lasts\"> \n              <div class=\" c-body\"> \n               <div class=\"c-img   \"> \n                <a href=\"../_src/6800/img_2783.jpg?v=1767099951882\" class=\"js-zoomImage\" rel=\"width=1706,height=960\"> \n                 <picture> \n                  <source type=\"image/webp\" srcset=\"../_src/6799/img_2783.webp?v=1767099951882\"> \n                  <img src=\"../_src/6799/img_2783.jpg?v=1767099951882\" width=\"1706\" height=\"960\" alt=\"\" id=\"imgsrc6799_1\" loading=\"lazy\"> \n                 </picture></a> \n               </div> \n              </div> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk5309\" class=\"b-plain c-space_normal c-sp-space_normal c-sp-padding_normal cssskin-_block_main\" data-bk-id=\"bk5309\"> \n            <div class=\" column -column1\" id=\"230101\"> \n             <p class=\" c-body\"><span style=\"color:#073763;\" class=\" d-large_font\"><span class=\" d-bold\">新年のご挨拶</span></span></p> \n             <div class=\" c-body c-right\"> \n              <hr class=\"c-hr\"> \n              <span style=\"color:#434343;\" data-sitecolor-text=\"\">2023.1.1&nbsp;</span> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk5310\" class=\"b-plain c-space_normal c-sp-space_normal c-padding_narrow c-sp-padding_normal cssskin-_block_main\" data-bk-id=\"bk5310\"> \n            <div class=\" column -column1\"> \n             <div class=\" c-body\"> \n              <div class=\"c-img   \"> \n               <picture> \n                <source type=\"image/webp\" srcset=\"../_src/6801/top_2023.webp?v=1767099951882\"> \n                <img src=\"../_src/6801/top_2023.jpg?v=1767099951882\" width=\"1000\" height=\"500\" alt=\"\" id=\"imgsrc6801_1\" loading=\"lazy\"> \n               </picture> \n              </div> \n              <br>本年よりSDGs推進の一環として、年賀状でのご挨拶を廃止いたしました \n             </div> \n            </div> \n           </div> \n          </section> \n         </div> \n         <div id=\"a-side-a\" data-float=\"false\" class=\"a-side-a column -col4 \" data-fixed-size=\"200px\"> \n          <section> \n           <div id=\"bk5311\" class=\"b-plain c-space_normal c-sp-space_normal c-sp-padding_normal bd-webp -dress_navy cssskin-_block_side_a\" data-bk-id=\"bk5311\" data-shared=\"true\" data-sharedname=\"info_archive\" data-sticky=\"true\"> \n            <div class=\" column -column1\"> \n             <nav> \n              <div class=\" -menu_center\"> \n               <ul class=\"c-menu -menu_e menu-parts -v\"> \n                <li><span class=\" c-unlink\"><span class=\" d-bold\">Back Number</span></span></li> \n               </ul> \n              </div> \n             </nav> \n             <div class=\" c-body\"> \n              <span class=\"bindicon-angle-right-circle\"></span> \n              <a href=\"../info_arch/pg271.html\" target=\"_blank\" rel=\"noopener noreferrer\" data-pid=\"271\">2024年</a> \n              <br> \n              <span class=\"bindicon-angle-right-circle\"></span> \n              <a href=\"pg265.html\" target=\"_blank\" rel=\"noopener noreferrer\" data-mypid=\"265\">2023年</a> \n              <br> \n              <span class=\"bindicon-angle-right-circle\"></span> \n              <a href=\"../info_arch/pg261.html\" target=\"_blank\" rel=\"noopener noreferrer\" data-pid=\"261\">2022年</a> \n              <br> \n              <span class=\"bindicon-angle-right-circle\"></span> \n              <a href=\"../info_arch/info2021.html\" target=\"_blank\" rel=\"noopener noreferrer\" data-pid=\"173\">2021年</a> \n              <br> \n              <span class=\"bindicon-angle-right-circle\"></span> \n              <a href=\"../info_arch/info2020.html\" target=\"_blank\" rel=\"noopener noreferrer\" data-pid=\"133\">2020年</a> \n              <br>&nbsp; \n              <br> \n              <div class=\"c-img   \"> \n               <a href=\"../stj.html\" data-pid=\"73\"> \n                <picture> \n                 <source type=\"image/webp\" srcset=\"../_src/3484/test_small2.webp?v=1767099951882\"> \n                 <img src=\"../_src/3484/test_small2.jpg?v=1767099951882\" width=\"200\" height=\"100\" alt=\"\" id=\"imgsrc3484_1\" loading=\"lazy\"> \n                </picture></a> \n              </div> \n             </div> \n             <div class=\" c-body c-right\"> \n              <span class=\" d-small_font\"> <a href=\"../info_arch/info2021.html\" data-pid=\"173\">STジャーナルへ</a></span> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk5312\" class=\"b-plain cssskin-_block_side_a\" data-bk-id=\"bk5312\"> \n            <div class=\" column -column1\"> \n            </div> \n           </div> \n          </section> \n         </div> \n        </div> \n       </div> \n      </article> \n     </div> \n    </main> \n    <div id=\"