=\"flex\">\n                                <li><a class=\"logo\" href=\"../\"><img src=\"../assets/img/common/header_logo.png\" alt=\"住商エアロシステム株式会社\"></a></li>\n                                <li><p>新卒採用サイト</p></li>\n                            </ul>\n                        </div>\n                        <div class=\"right\">\n                            <ul class=\"flex\">\n                                <li><a id=\"menu-entry\" href=\"../info/requirements.html#entry\"><p>ENTRY</p></a></li>\n                                <li><button id=\"menu-btn\"><span class=\"icon\"></span></button></li>\n                            </ul>\n                        </div>\n                    </div>\n                </div>\n            </header>\n\n\n\n            <div id=\"menu\">\n                <div id=\"menu-overlay\"></div>\n                <div id=\"menu-list\">\n                    <div class=\"inner900\">\n                        <div class=\"flex\">\n                            <div class=\"col\">\n                                <div class=\"box\">\n                                    <div class=\"parent\"><a href=\"../\"><p class=\"font--serif\">TOP</p></a></div>\n                                </div>\n\n                                <div class=\"box\">\n                                    <div class=\"parent\"><a href=\"../message/\"><p class=\"font--serif\">社長メッセージ</p></a></div>\n                                </div>\n\n                                <div class=\"box\">\n                                    <div class=\"parent\"><a class=\"accordion-btn--sp\"><p class=\"font--serif\">会社を知る</p></a></div>\n                                    <ul class=\" accordion-body--sp\">\n                                        <li class=\"child\"><a href=\"../company/\"><p>企業概要</p></a></li>\n                                        <li class=\"child\"><a href=\"../company/info.html\"><p>住商エアロシステムの機能</p></a></li>\n                                        <li class=\"child\"><a href=\"../company/movie.html\"><p>動画ギャラリー</p></a></li>\n                                    </ul>\n                                </div>\n\n                                <div class=\"box\">\n                                    <div class=\"parent\"><a class=\"accordion-btn--sp\"><p class=\"font--serif\">ビジネスを知る</p></a></div>\n                                    <ul class=\" accordion-body--sp\">\n                                        <li class=\"child\"><a href=\"../business/#business-pro\"><p>防衛・航空宇宙の専門商社</p></a></li>\n                                        <li class=\"child\"><a href=\"../business/#business-sas\"><p>SAS Business</p></a></li>\n                                    </ul>\n                                </div>\n                            </div>\n                            <div class=\"col\">\n                                <div class=\"box\">\n                                    <div class=\"parent\"><a class=\"accordion-btn--sp\"><p class=\"font--serif\">社員を知る</p></a></div>\n                                    <ul class=\" accordion-body--sp\">\n                                        <li class=\"child\"><a href=\"../staff/member04.html\"><p>総合職</p></a></li>\n                                        <li class=\"child\"><a href=\"../staff/member02.html\"><p>総合職</p></a></li>\n                                        <li class=\"child\"><a href=\"../staff/member03.html\"><p>管理職</p></a></li>\n                                    </ul>\n                                </div>\n                                <div class=\"box\">\n                                    <div class=\"parent\"><a class=\"accordion-btn--sp\"><p class=\"font--serif\">採用情報</p></a></div>\n                                    <ul class=\" accordion-body--sp\">\n                                        <li class=\"child\"><a href=\"../info/requirements.html\"><p>募集要項</p></a></li>\n                                        <li class=\"child\"><a href=\"../info/personality.html\"><p>求める人材像</p></a></li>\n                                        <li class=\"child\"><a href=\"../info/event.html\"><p>イベント情報</p></a></li>\n                                    </ul>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n\n            <div id=\"mv\" class=\"size--default\">\n                <div class=\"bg\"></div>\n\n                <div class=\"inside\">\n                    <h1>求める人材像</h1>\n                </div>\n            </div>\n\n\n\n            <main>\n                <article>\n                    <section id=\"info-personality-body\">\n                        <div class=\"inner900\">\n                            <div class=\"upper\"><p>当社では下記のような人材を求めています。</p></div>\n                            <div class=\"list--basic\">\n                                <ul>\n                                    <li>\n                                        <div class=\"dt\"><p class=\"font--serif\">自負</p></div>\n                                        <div class=\"dd\">\n                                            <p>\n                                                自らの仕事が国家の安全・安心に繋がることを認識し、情熱を持って行動できる方\n                                            </p>\n                                        </div>\n                                    </li>\n                                    <li>\n                                        <div class=\"dt\"><p class=\"font--serif\">誠実</p></div>\n                                        <div class=\"dd\">\n                                            <p>\n                                                全てのステークホルダーに対して常に誠実であることを誓える方\n                                            </p>\n                                        </div>\n                                    </li>\n                                    <li>\n                                        <div class=\"dt\"><p class=\"font--serif\">自律</p></div>\n                                        <div class=\"dd\">\n                                            <p>\n                                                常に自ら考え、能動的に行動できる方\n                                            </p>\n                                        </div>\n                                    </li>\n                                    <li>\n                                        <div class=\"dt\"><p class=\"font--serif\">コミットメント</p></div>\n                                        <div class=\"dd\">\n                                            <p>\n                                                ステークホルダーが抱える課題に真摯に向き合い、解決に向けて粘り強く取り組める方\n                                            </p>\n                                        </div>\n                                    </li>\n                                    <li>\n                                        <div class=\"dt\"><p class=\"font--serif\">挑戦</p></div>\n                                        <div class=\"dd\">\n                                            <p>\n                                                成⾧や変革に対して現状に甘んじることなく挑戦し続けられる方\n                                            </p>\n                                        </div>\n                                    </li>\n                                    <li>\n                                        <div class=\"dt\"><p class=\"font--serif\">プロフェッショナル</p></div>\n                                        <div class=\"dd\">\n                                            <p>\n                                                プロフェッショナルとしての自覚と責任を持ち、常に期待を超える価値提供を行える方\n                                            </p>\n                                        </div>\n                                    </li>\n                                    <li>\n                                        <div class=\"dt\"><p class=\"font--serif\">コミュニケーション</p></div>\n                                        <div class=\"dd\">\n                                            <p>\n                                                多様な価値観・意見を尊重し、情報発信・意思疎通を図ることで信頼関係を築ける方\n                                            </p>\n                                        </div>\n                                    </li>\n                                    <li>\n                                        <div class=\"dt\"><p class=\"font--serif\">チームマインド</p></div>\n                                        <div class=\"dd\">\n                                            <p>\n                                                何事も個人で閉じず、メンバーの成⾧を支援しつつ、チームで成果発揮に取り組める方\n                                            </p>\n                                        </div>\n                                    </li>\n                                    <li>\n                                        <div class=\"dt\"><p class=\"font--serif\">コンプライアンス</p></div>\n                                        <div class=\"dd\">\n                                            <p>\n                                                日々の仕事や行動に係る法令を理解し、順守できる方\n                                            </p>\n                                        </div>\n                                    </li>\n                                </ul>\n                            </div>\n                        </div>\n                    </section>\n                </article>\n            </main>\n\n            <div id=\"footer-message\">\n                <div class=\"inside\">\n                    <div class=\"ph\"><img src=\"../assets/img/common/footer_copy.png\" alt=\"あたりまえを衞り続ける\"></div>\n                </div>\n            </div>\n            <footer class=\"child info personality\">\n                <div class=\"upper\">\n                    <div class=\"inner1000\">\n                        <ul class=\"flex\">\n                            <li>\n                                <ol>\n                                    <li class=\"parent\"><a href=\"../\"><p>TOP</p></a></li>\n                     