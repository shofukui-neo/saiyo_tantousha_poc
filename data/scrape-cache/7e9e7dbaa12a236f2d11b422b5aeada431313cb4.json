       <li><a href=\"/ytc/en/\" lang=\"en\">EN</a></li>\r\n        <li><a href=\"/ytc/scn/\" lang=\"zh-cn\">CN</a></li>\r\n      </ul>\r\n    </div>\r\n    <!--/Header__head-->\r\n  </div>\r\n  <div class=\"Header__inner\">\r\n    <div class=\"Header__guide\">\r\n      <p class=\"header-logo--guide\"><a href=\"/ytc/customer/\"><img src=\"/app-files/img/com_logo01.png\" alt=\"ヤマト運輸 次の運び方をつくる。\"></a></p>\r\n      <!--/Header__guide-->\r\n    </div>\r\n    <div class=\"Header__body\">\r\n      <button class=\"header-gnav__button js-nav-menu_trigger\" aria-expanded=\"false\" aria-label=\"メニューボタン\"><span></span><span></span><span></span></button>\r\n      <nav class=\"header-gnav js-gNav\">\r\n        <ul class=\"header-gnav__list js-gNav_stage1\">\r\n          <li><a href=\"/ytc/customer/send/\" id=\"GN_3\">送る</a></li>\r\n          <li><a href=\"/ytc/customer/redelivery/\" id=\"GN_2\">受け取る</a></li>\r\n          <li><a href=\"/ytc/customer/service/\" id=\"GN_4\">サービス</a></li>\r\n          <li><a href=\"https://faq.kuronekoyamato.co.jp/\" id=\"GN_5\" target=\"_blank\" rel=\"noopener\" class=\"header-gnav__link--blank\"><img src=\"/app-files/img/sprite/icon.svg#blank-usage\" class=\"header-gnav__link--icon\" alt=\"新しいウィンドウを開きます\">よくあるご質問</a></li>\r\n          <li><a href=\"/ytc/contact/\" id=\"GN_6\">お問い合わせ</a></li>\r\n          <li class=\"header-gnav__members\"><a href=\"https://member.kms.kuronekoyamato.co.jp/member?id=kojintop\">クロネコメンバーズ</a></li>\r\n        </ul>\r\n      </nav>\r\n      <div class=\"header-utility\">\r\n        <div class=\"header-search\">\r\n          <button type=\"button\" class=\"header-search__button js-nav-search_trigger\" aria-expanded=\"false\">サイト内検索</button>\r\n          <div class=\"header-search__body\">\r\n            <div class=\"header-search__form\">\r\n              <form id=\"ss-form1\" name=\"search_form\" action=\"/ytc/searchresult/jp/\" method=\"GET\" accept-charset=\"UTF-8\">\r\n                <input type=\"hidden\" name=\"site\" value=\"YGOX6KBD\">\r\n                <input type=\"hidden\" name=\"charset\" value=\"UTF-8\">\r\n                <input type=\"hidden\" name=\"design\" value=\"2\">\r\n                <input type=\"hidden\" name=\"group\" value=\"1\">\r\n                <label for=\"ss-query1\" class=\"search_label\">サイト内検索</label>\r\n                <input type=\"text\" id=\"ss-query1\" name=\"query\" autocomplete=\"off\" aria-autocomplete=\"none\" value=\"\" placeholder=\"サイト内検索\"  class=\"search_input\">\r\n                <input type=\"submit\" value=\"検索\" class=\"search_submit\" onclick=\"document.charset='UTF-8';\">\r\n              </form>\r\n              <button type=\"button\" class=\"search_close js-nav-search_close\">閉じる</button>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n      <!--/Header__body-->\r\n    </div>\r\n    <!--/Header__inner-->\r\n  </div>\r\n  <!--/Header-->\r\n</header>\n<main id=\"main\" class=\"Main\">\n<div class=\"Main__inner\"><noscript>\r\n  <div class=\"noscript-alert\">\r\n    <div class=\"noscript-alert__inner\">\r\n      <i class=\"noscript-alert__icon\"><img src=\"/app-files/img/sprite/icon.svg#alert2-usage\" alt=\"\"></i>\r\n      <p class=\"noscript-alert__text\">このページは、JavaScriptという技術を使用しています。<br class=\"util-sp-hidden\">JavaScriptの設定がオンにされていない場合、適切な表示・操作を行えないことがありますのでご了承ください。</p>\r\n    </div>\r\n  </div>\r\n</noscript>\n<div class=\"Main__guide\">\n<ol class=\"main-breadcrumb\" itemscope=\"\" itemtype=\"http://schema.org/BreadcrumbList\">\n<li itemprop=\"itemListElement\" itemscope=\"\" itemtype=\"http://schema.org/ListItem\"><a class=\"main-breadcrumb__type\" itemprop=\"item\" href=\"/ytc/customer/\"><span itemprop=\"name\">個人のお客さま トップ</span></a> <meta itemprop=\"position\" content=\"1\"></li>\n<li itemprop=\"itemListElement\" itemscope=\"\" itemtype=\"http://schema.org/ListItem\"><a class=\"main-breadcrumb__type\" itemprop=\"item\" href=\"/ytc/customer/send/\"><span itemprop=\"name\">送る</span></a> <meta itemprop=\"position\" content=\"2\"></li>\n<li itemprop=\"itemListElement\" itemscope=\"\" itemtype=\"http://schema.org/ListItem\"><a class=\"main-breadcrumb__type\" itemprop=\"item\" href=\"/ytc/customer/send/members/\"><span itemprop=\"name\">「送る」を便利にするサービス</span></a> <meta itemprop=\"position\" content=\"3\"></li>\n<li itemprop=\"itemListElement\" itemscope=\"\" itemtype=\"http://schema.org/ListItem\"><span class=\"main-breadcrumb__type--nolink\"><span itemprop=\"name\">webで集荷申し込み　自宅から送る</span></span> <meta itemprop=\"position\" content=\"4\"></li>\n</ol>\n<!--/Main__guide--></div>\n<div class=\"Main__body\">\n<div class=\"Main__content\">\n<div class=\"hdg-services-02\">\n<div class=\"hdg-services-02__inner\">\n<div class=\"hdg-services-02__title-wrap\">\n<h1 class=\"hdg-services-02__title\">webで集荷申し込み</h1>\n<div class=\"hdg-services-02__image\"><img src=\"/ytc/customer/send/members/shuka/img/index_h1_im01.png\" alt=\"\"></div>\n<div class=\"button-wrap hdg-services-02__btn\" data-col-pc=\"1\" data-col-sp=\"1\">\n<div class=\"button-v2\"><a href=\"https://shuka.kuronekoyamato.co.jp/\" target=\"_blank\" rel=\"noopener\" class=\"button-v2__type button-v2__type--blank button-v2__type--small\"><img src=\"/app-files/img/sprite/icon.svg#blank2-usage\" class=\"button-v2__icon\" alt=\"新しいウィンドウを開きます\"><span class=\"button-v2__label\">いますぐ利用する</span></a></div>\n</div>\n</div>\n</div>\n<div class=\"hdg-services-02__detail\">\n<div class=\"hdg-services-02__detail__inner\">\n<div class=\"hdg-services-02__info\">\n<p class=\"hdg-services-02__text\">登録情報やアドレス帳、履歴を使って、<br>簡単に集荷を申し込みできます。<br>webから集荷をお申し込みいただくと、送り状なしで、<br>しかも60円おトクに荷物を送ることができます。<br><span class=\"off-app__phone__note\" style=\"margin-left: 0;\">※こねこ便420は、送り状の入力や60円の割引は対象外です。</span></p>\n</div>\n<ul class=\"hdg-services-02__list\">\n<li class=\"hdg-services-02__icon hdg-services-02__icon--01\">Web</li>\n<li class=\"hdg-services-02__icon hdg-services-02__icon--02\">アプリ</li>\n<li class=\"hdg-services-02__icon hdg-services-02__icon--03\">LINE</li>\n</ul>\n</div>\n</div>\n</div>\n<p class=\"text\" style=\"margin-top: 50px;\">「webで集荷申し込み」において、営業所止めをご指定いただく際、よりスムーズにお手続きいただけるようになりました。<br>詳細は<a class=\"util-link--blank\" href=\"/ytc/customer/send/members/shuka/shukapdf/web_shuka.pdf\" target=\"_blank\" rel=\"noopener\"><img src=\"/app-files/img/sprite/icon.svg#blank-usage\" alt=\"新しいウィンドウを開きます\" class=\"util-link--icon\">こちら</a>をご覧ください。</p>\n<div class=\"anchor-navi\">\n<ul class=\"anchor-navi__list\" data-col-pc=\"5\" data-col-sp=\"1\">\n<li><a href=\"#anc-01\" class=\"anchor-navi__link\"><span class=\"anchor-navi__label\">ご利用方法</span></a></li>\n<li><a href=\"#anc-02\" class=\"anchor-navi__link\"><span class=\"anchor-navi__label\">集荷可能な時間帯と<br class=\"util-sp-hidden\">受付締切時間</span></a></li>\n<li><a href=\"#anc-03\" class=\"anchor-navi__link\"><span class=\"anchor-navi__label\">対象サービス</span></a></li>\n<li><a href=\"#anc-04\" class=\"anchor-navi__link\"><span class=\"anchor-navi__label\">よくあるご質問（FAQ）</span></a></li>\n<li><a href=\"#anc-05\" class=\"anchor-navi__link\"><span class=\"anchor-navi__label\">ご注意事項</span></a></li>\n</ul>\n</div>\n<section>\n<div id=\"anc-01\" class=\"hdg-level2-01\">\n<div class=\"hdg-level2-01__inner\">\n<h2 class=\"hdg-level2-01__title\">ご利用方法</h2>\n</div>\n</div>\n<section>\n<div class=\"hdg-level3-01\">\n<div class=\"hdg-level3-01__inner\">\n<h3 class=\"hdg-level3-01__title\">お手元に送り状がない場合</h3>\n</div>\n</div>\n<div class=\"send-media\">\n<div class=\"send-media__head\">\n<figure class=\"send-media__image util-sp-hidden\"><img src=\"/ytc/customer/send/members/shuka/img/index_use_im01.png\" alt=\"お手元に送り状がない場合の画面操作\"></figure>\n<figure class=\"send-media__image util-pc-hidden\"><img src=\"/ytc/customer/send/members/shuka/img/index_use_im01-r2x.png\" alt=\"\"></figure>\n</div>\n<div class=\"send-media__body\">\n<p class=\"text\">webから集荷を申し込む際に、発送方法で「送り状のご用意がまだの方」を選択します。お届け先や、ご依頼主、荷物の内容を設定すると、手書きの送り状などを用意せずに、しかも60円おトクに荷物を送ることができます。</p>\n<p>※こねこ便420は、送り状の入力や60円の割引は対象外です。<br>※集荷依頼は<a href=\"https://shuka.kuronekoyamato.co.jp/shuka_req/TopAction_doInit.action\" class=\"util-link\" target=\"&rdquo;_blank&rdquo;\">こちら</a></p>\n</div>\n</div>\n</section>\n<section>\n<div class=\"hdg-level3-01\">\n<div class=\"hdg-level3-01__inner\">\n<h3 class=\"hdg-level3-01__title\">送り状をお持ちの場合</h3>\n</div>\n</div>\n<div class=\"send-media\">\n<div class=\"send-media__head\">\n<figure class=\"send-media__image util-sp-hidden\"><img src=\"/ytc/customer/send/members/shuka/img/index_use_im02.png\" alt=\"送り状をお持ちの場合の画面操作\"></figure>\n<figure class=\"send-media__image util-pc-hidden\"><img src=\"/ytc/customer/send/members/shuka/img/index_use_im02-r2x.png\" alt=\"\"></figure>\n</div>\n<div class=\"send-media__body\">\n<p class=\"text\">手書きの送り状や、すでに発行済みの送り状をお持ちの場合は、webから集荷を申し込む際に、発送方法で「送り状をご用意済みの方」を選択します。</p>\n<p>※集荷依頼は<a href=\"https://shuka.kuronekoyamato.co.jp/shuka_req/TopAction_doInit.action\" class=\"util-link\" target=\"&rdquo;_blank&rdquo;\">こちら</a></p>\n</div>\n</div>\n</section>\n</section>\n<section>\n<div id=\"anc-02\" class=\"hdg-level2-01\">\n<div class=\"hdg-level2-01__inner\">\n<h2 class=\"hdg-level2-01__title\">集荷可能な時間帯と受付締切時間</h2>\n</div>\n</div>\n<div class=\"table\" data-table-sp=\"scroll\">\n<div class=\"table__body\">\n<table class=\"table__matrix\"><caption class=\"util-pc-hidden\">\n<div class=\"table__caption\">※この表はスクロールすることができます。</div>\n</caption><colgroup> <col class=\"table__w--20per\" span=\"5\"> </colgroup>\n<thead>\n<tr>\n<th class=\"table__cell--lv1--left-middle table__cell--lv1--sp--center-top\" scope=\"row\">ご指定可能な時間帯</th>\n<td class=\"table__cell--lv7--left-middle table__cell--lv7--sp--center-top\">13:00まで</td>\n<td class=\"table__cell--lv7--left-middle table__cell--lv7--sp--center-top\">14:00<br class=\"util-pc-hidden\">～<br class=\"util-pc-hidden\">16:00</td>\n<td class=\"table__cell--lv7--left-middle table__cell--lv7--sp--center-top\">16:00<br class=\"util-pc-hidden\">～<br class=\"util-pc-hidden\">18:00</td>\n<td class=\"table__cell--lv7--left-middle table__cell--lv7--sp--center-top\">17:00<br class=\"util-pc-hidden\">～<br class=\"util-pc-hidden\">18:30</td>\n</tr>\n</thead>\n<tbody>\n<tr>\n<th class=\"table__cell--lv1--left-middle table__cell--lv1--sp--center-top\" scope=\"row\">受付締切時間</th>\n<td class=\"table__cell--left-middle table__cell--sp--center-top\">当日10:00まで受付</td>\n<td class=\"table__cell--left-middle table__cell--sp--center-top\">当日14:00まで受付</td>\n<td class=\"table__cell--left-middle table__cell--sp--center-top\">当日16:00まで受付</td>\n<td class=\"table__cell--left-middle table__cell--sp--center-top\">当日17:00まで受付</td>\n</tr>\n</tbody>\n</table>\n</div>\n</div>\n<div class=\"hdg-level4-02\" style=\"margin-top: 2.5em;\">\n<div class=\"hdg-level4-02__inner\">\n<h3 class=\"hdg-level4-02__title\">パソコン宅急便の場合</h3>\n</div>\n</div>\n<p>パソコン宅急便は専用資材のご準備がありますので、お時間を頂戴しております。</p>\n<div class=\"table\" data-table-sp=\"scroll\">\n<div class=\"table__body\">\n<table class=\"table__matrix\"><caption class=\"util-pc-hidden\">\n<div class=\"table__caption\">※この表はスクロールすることができます。</div>\n</caption><colgroup> <col class=\"table__w--33per\" span=\"3\"> </colgroup>\n<thead>\n<tr>\n<th class=\"table__cell--lv1--left-middle table__cell--lv1--sp--center-top\" scope=\"row\">ご指定可能な時間帯</th>\n<td class=\"table__cell--lv7--left-middle table__cell--lv7--sp--center-top\">14:00以降</td>\n<td class=\"table__cell--lv7--left-middle table__cell--lv7--sp--center-top\">翌日以降</td>\n</tr>\n</thead>\n<tbody>\n<tr>\n<th class=\"table__cell--lv1--left-middle table__cell--lv1--sp--center-top\" scope=\"row\">受付締切時間</th>\n<td class=\"table__cell--left-middle table__cell--sp--center-top\">当日12:00までの受付</td>\n<td class=\"table__cell--left-middle table__cell--sp--center-top\">当日12:00以降の受付</td>\n</tr>\n</tbody>\n</table>\n</div>\n</div>\n<p>集荷受付時間は地域により異なる場合があります。詳しくは<a href=\"/ytc/contact/\" class=\"util-link\">サービスセンター</a>へお問い合わせください。</p>\n</section>\n<section>\n<div id=\"anc-03\" class=\"hdg-level2-01\">\n<div class=\"hdg-level2-01__inner\">\n<h2 class=\"hdg-level2-01__title\">対象サービス</h2>\n</div>\n</div>\n<div class=\"table\" data-table-sp=\"shrink\">\n<div class=\"table__body\">\n<table class=\"table__matrix\"><colgroup> <col class=\"table__w--33per\" span=\"1\"> <col class=\"table__w--33per\" span=\"1\"> <col class=\"table__w--34per\" span=\"1\"> </colgroup>\n<thead>\n<tr>\n<th class=\"table__cell--lv1--left-middle table__cell--lv1--sp--center-middle\" scope=\"col\">サービス</th>\n<th class=\"table__cell--lv1--left-middle table__cell--lv1--sp--center-middle\" scope=\"col\">ご利用可能なお荷物</th>\n<th class=\"table__cell--lv1--left-middle table__cell--lv1--sp--center-middle\" scope=\"col\">備考</th>\n</tr>\n</thead>\n<tbody>\n<tr>\n<th class=\"table__cell--left-middle table__cell--sp--left-top\" scope=\"row\"><a href=\"/ytc/customer/send/services/takkyubin/\" class=\"util-link\">宅急便</a></th>\n<td class=\"table__cell--left-middle table__cell--sp--left-top\">発払い・着払い・複数口</td>\n<td class=\"table__cell--left-middle table__cell--sp--left-top\">複数口をご利用の場合は、「国内に送る」の荷物の内容設定個数を選択します。</td>\n</tr>\n<tr>\n<th class=\"table__cell--left-middle table__cell--sp--left-top\" scope=\"row\"><a href=\"/ytc/customer/send/services/compact/\" class=\"util-link\">宅急便コンパクト</a></th>\n<td class=\"table__cell--left-middle table__cell--sp--left-top\">発払い・着払い</td>\n<td class=\"table__cell--left-middle table__cell--sp--left-top\">「国内に送る」のご利用サービス選択で「宅急便コンパクト」を指定します。</td>\n</tr>\n<tr>\n<th class=\"table__cell--left-middle table__cell--sp--left-top\" scope=\"row\"><a href=\"/ytc/customer/send/services/cool/\" class=\"util-link\">クール宅急便</a></th>\n<td class=\"table__cell--left-middle table__cell--sp--left-top\">発払い・着払い</td>\n<td class=\"table__cell--left-middle table__cell--sp--left-top\">「国内に送る」のご利用サービス選択で「クール宅急便」を指定します。</td>\n</tr>\n<tr>\n<th class=\"table__cell--left-middle table__cell--sp--left-top\" scope=\"row\"><a href=\"/ytc/customer/send/services/golf/\" class=\"util-link\">ゴルフ宅急便</a></th>\n<td class=\"table__cell--left-middle table__cell--sp--left-top\">片道・往復</td>\n<td class=\"table__cell--left-middle table__cell--sp--left-top\">「ゴルフ場に送る」を選択します。</td>\n</tr>\n<tr>\n<th class=\"table__cell--left-middle table__cell--sp--left-top\" scope=\"row\"><a href=\"/ytc/customer/send/services/ski/\" class=\"util-link\">スキー宅急便</a></th>\n<td class=\"table__cell--left-middle table__cell--sp--left-top\">片道・往復</td>\n<td class=\"table__cell--left-middle table__cell--sp--left-top\">「スキー場に送る」を選択します。</td>\n</tr>\n<tr>\n<th class=\"table__cell--left-middle table__cell--sp--left-top\" scope=\"row\"><a href=\"/ytc/customer/send/services/airport/\" class=\"util-link\">空港宅急便</a></th>\n<td class=\"table__cell--left-middle table__cell--sp--left-top\">片道・往復</td>\n<td class=\"table__cell--left-middle table__cell--sp--left-top\">「空港に送る」を選択します。</td>\n</tr>\n<tr>\n<th class=\"table__cell--left-middle table__cell--sp--left-top\" scope=\"row\"><a href=\"/ytc/customer/send/services/bothways/\" class=\"util-link\">往復宅急便</a></th>\n<td class=\"table__cell--left-middle table__cell--sp--left-top\">発払い</td>\n<td class=\"table__cell--left-middle table__cell--sp--left-top\">宿泊施設との往復配送に利用できます。「宿泊施設に送る」を選択します。</td>\n</tr>\n<tr>\n<th class=\"table__cell--left-middle table__cell--sp--left-top\" scope=\"row\"><a href=\"/ytc/customer/send/services/pasotaku/\" class=\"link-list__type\">パソコン宅急便</a></th>\n<td class=\"table__cell--left-middle table__cell--sp--left-top\">発払い・着払い<br>\n<div class=\"list-wrap\">\n<ul class=\"note-list\" data-col-sp=\"1\" data-col-pc=\"1\">\n<li><span class=\"note-list__mark\">※</span>「パソコン宅急便」からは複数口の申し込みはできません。複数口をご利用の場合は、「パソコン宅急便」で集荷依頼後続けて「宅急便」で複数口集荷依頼をお願いいたします。</li>\n</ul>\n</div>\n</td>\n<td class=\"table__cell--left-middle table__cell--sp--left-top\">「国内に送る」のご利用サービス選択で「パソコン宅急便」を指定します。</td>\n</tr>\n<tr>\n<th class=\"table__cell--left-middle table__cell--sp--left-top\" scope=\"row\"><a href=\"/ytc/customer/send/services/konekobin420/\" class=\"util-link\">こねこ便420</a></th>\n<td class=\"table__cell--left-middle table__cell--sp--left-top\">ー</td>\n<td class=\"table__cell--left-middle table__cell--sp--left-top\">「国内に送る」のご利用サービス選択で「こねこ便420」を指定します。</td>\n</tr>\n</tbody>\n</table>\n</div>\n</div>\n</section>\n<section>\n<div class=\"hdg-level3-01\">\n<div class=\"hdg-level3-01__inner\">\n<h3 class=\"hdg-level3-01__title\">ご利用いただけないサービス</h3>\n</div>\n</div>\n<p class=\"text\">以下のサービスはご利用いただけません。</p>\n<div class=\"table disabled\" data-table-sp=\"vertical\">\n<div class=\"table__body\">\n<table class=\"table__matrix\">\n<tbody>\n<tr>\n<td class=\"table__cell--center-middle table__cell--disabled\">ネコポス</td>\n<td class=\"table__cell--center-middle table__cell--disabled\">宅急便タイム<!--<br class=\"util-sp-hidden\">-->サービス</td>\n<td class=\"table__cell--center-middle table__cell--disabled\">国際宅急便</td>\n<td class=\"table__cell--center-middle table__cell--disabled\">クロネコゆうパケット</td>\n<td class=\"table__cell--center-middle table__cell--disabled\">クロネコゆうメール</td>\n</tr>\n</tbody>\n</table>\n</div>\n</div>\n</section>\n<section>\n<div class=\"hdg-level3-01\">\n<div class=\"hdg-level3-01__inner\">\n<h3 class=\"hdg-level3-01__title\">梱包の方法・送り方</h3>\n</div>\n</div>\n<div class=\"column\" data-col-pc=\"3\" data-col-sp=\"1\">\n<div class=\"column__item\">\n<div class=\"heading4\">\n<div class=\"heading4__inner\">\n<h4 class=\"heading4__title\">荷造りの方法がわからない</h4>\n</div>\n</div>\n<div class=\"card-wrap\" data-col-pc=\"1\" data-col-sp=\"1\">\n<div class=\"card img-center\" data-card-sp=\"row\"><a href=\"/ytc/customer/send/preparations/packing/\" class=\"card__type\">\n<div class=\"card__head\">\n<div class=\"card__image\"><img src=\"/ytc/customer/send/services/ski/img/index_im13.png\" alt=\"\"></div>\n</div>\n<div class=\"card__body\">\n<div class=\"card__title\">荷物の梱包方法</div>\n<p class=\"card__description\">送る品物別に、上手な梱包方法をご紹介します。</p>\n</div>\n</a></div>\n</div>\n</div>\n<div class=\"column__item\">\n<div class=\"heading4\">\n<div class=\"heading4__inner\">\n<h4 class=\"heading4__title\">最適な包装資材を知りたい</h4>\n</div>\n</div>\n<div class=\"card-wrap\" data-col-pc=\"1\" data-col-sp=\"1\">\n<div class=\"card img-center\" data-card-sp=\"row\"><a href=\"https://market.kuronekoyamato.co.jp/market/MarketTopAction_doInit.action\" class=\"card__type\">\n<div class=\"card__head\">\n<div class=\"card__image\"><img src=\"/ytc/customer/send/services/ski/img/index_im14.png\" alt=\"\"></div>\n</div>\n<div class=\"card__body\">\n<div class=\"card__title\">便利な包装資材</div>\n<p class=\"card__description\">長年の宅配ノウハウが活かされた便利な包装資材をご紹介します。</p>\n</div>\n</a></div>\n</div>\n</div>\n<div class=\"column__item\">\n<div class=\"heading4\">\n<div class=\"heading4__inner\">\n<h4 class=\"heading4__title\">送り方、支払い方を知りたい</h4>\n</div>\n</div>\n<div class=\"card-wrap\" data-col-pc=\"1\" data-col-sp=\"1\">\n<div class=\"card img-center\" data-card-sp=\"row\"><a href=\"/ytc/customer/send/preparations/payoff/\" class=\"card__type\">\n<div class=\"card__head\">\n<div class=\"card__image\"><img src=\"/ytc/customer/send/services/ski/img/index_im15.png\" alt=\"\"></div>\n</div>\n<div class=\"card__body\">\n<div class=\"card__title\">発送方法・お支払い方法</div>\n<p class=\"card__description\">お荷物の取り扱い窓口や、ご利用可能な精算方法をご紹介します。</p>\n</div>\n</a></div>\n</div>\n</div>\n</div>\n</section>\n<section>\n<div id=\"anc-04\" class=\"hdg-level2-01\">\n<div class=\"hdg-level2-01__inner\">\n<h2 class=\"hdg-level2-01__title\">よくあるご質問（FAQ）</h2>\n</div>\n</div>\n<div id=\"faq\"></div>\n<div class=\"list-wrap\">\n<ul class=\"link-list\" data-col-pc=\"1\" data-col-sp=\"1\">\n<li><a href=\"https://faq.kuronekoyamato.co.jp/app/answers/list/p/223\" target=\"_blank\" rel=\"noopener\" class=\"link-list__type--blank\"><img src=\"/app-files/img/sprite/icon.svg#blank-usage\" class=\"link-list__type--blank__icon\" alt=\"新しいウィンドウを開きます\">「集荷申し込み」のFAQ一覧はこちら</a></li>\n</ul>\n</div>\n</section>\n<section>\n<div id=\"anc-05\" class=\"hdg-level2-01\">\n<div class=\"hdg-level2-01__inner\">\n<h2 class=\"hdg-level2-01__title\">ご注意事項</h2>\n</div>\n</div>\n<div class=\"list-wrap\">\n<ul class=\"unorder-list\" data-col-pc=\"1\" data-col-sp=\"1\">\n<li>ゴルフ宅急便・スキー宅急便・空港宅急便・宿泊施設向け往復宅急便は、一般の宅急便より1日多く日数がかかります。</li>\n<li>ご使用日の前日迄にお荷物が到着するようご依頼ください。</li>\n<li>お急ぎの場合は、お電話で<a href=\"/ytc/files/redirect/search_driver.html\" class=\"util-link--blank\" target=\"_blank\" rel=\"noopener\"><img src=\"/app-files/img/sprite/icon.svg#blank-usage\" alt=\"新しいウィンドウを開きます\" class=\"util-link--icon\">担当セールスドライバー</a>に直接ご依頼ください。</li>\n<li>災害や交通事情などにより、ご指定いただいた集荷日時もしくは配達日時のお伺いができない場合があります。</li>\n<li>web上から集荷日時の変更・キャンセルが可能です。日時変更の場合は<a href=\"https://faq.kuronekoyamato.co.jp/app/answers/detail/a_id/3957\" target=\"_blank\" rel=\"noopener\" class=\"util-link\"><img src=\"/app-files/img/sprite/icon.svg#blank-usage\" alt=\"新しいウィンドウを開きます\" class=\"util-link--icon\">こちら</a>、キャンセルの場合は<a href=\"https://faq.kuronekoyamato.co.jp/app/answers/detail/a_id/2800\" target=\"_blank\" rel=\"noopener\" class=\"util-link\"><img src=\"/app-files/img/sprite/icon.svg#blank-usage\" alt=\"新しいウィンドウを開きます\" class=\"util-link--icon\">こちら</a>をご確認ください。</li>\n</ul>\n</div>\n</section>\n<div class=\"send-conversion\">\n<div class=\"send-conversion__inner\">\n<section>\n<div class=\"hdg-level2-03--center\">\n<div class=\"hdg-level2-03__inner\">\n<h2 class=\"hdg-level2-03__title\">「webで集荷申し込み」のご利用はこちら</h2>\n</div>\n</div>\n<ul class=\"send-conversion__link\">\n<li><a href=\"https://shuka.kuronekoyamato.co.jp/shuka_req/TopAction_doInit.action\" target=\"_blank\" rel=\"noopener\" class=\"send-conversion__button send-conversion__button--blank send-conversion__button--white\"><img src=\"/app-files/img/sprite/icon.svg#blank-usage\" alt=\"新しいウィンドウを開きます\"><span>ログインして利用する</span></a></li>\n<li><a href=\"/ytc/files/redirect/members_register.html\" class=\"send-conversion__button send-conversion__button--black\"><span>クロネコメンバーズに新規登録する</span></a></li>\n</ul>\n</section>\n</div>\n</div>\n<section>\n<div class=\"hdg-level2-03--center\">\n<div class=\"hdg-level2-03__inner\">\n<h2 class=\"hdg-level2-03__title\">「送る」を便利にするサービス</h2>\n</div>\n</div>\n<div class=\"card-wrap\" data-col-pc=\"3\" data-col-sp=\"1\">\n<div class=\"card img-center\" data-card-sp=\"row\"><a href=\"/ytc/customer/send/sp/\" class=\"card__type\">\n<div class=\"card__head\">\n<div class=\"card__image\"><img src=\"/ytc/customer/send/img/send_service_im01.png\" alt=\"\"></div>\n</div>\n<div class=\"card__body\">\n<div class=\"card__title\">宅急便をスマホで送る</div>\n</div>\n</a></div>\n<div class=\"card img-center\" data-card-sp=\"row\">\n<div class=\"card__type--nolink is-current\">\n<div class=\"card__head\">\n<div class=\"card__image\"><img src=\"/ytc/customer/send/img/send_service_im02.png\" alt=\"\"></div>\n</div>\n<div class=\"card__body\">\n<div class=\"card__title\">webで集荷申し込み</div>\n</div>\n</div>\n</div>\n<div class=\"card img-center\" data-card-sp=\"row\"><a href=\"/ytc/customer/send/members/locker/\" class=\"card__type\">\n<div class=\"card__head\">\n<div class=\"card__image\"><img src=\"/ytc/customer/send/img/send_service_im03.png\" alt=\"\"></div>\n</div>\n<div class=\"card__body\">\n<div class=\"card__title\">宅配ロッカー発送サービス</div>\n</div>\n</a></div>\n<div class=\"card img-center\" data-card-sp=\"row\"><a href=\"/ytc/customer/send/members/c2/\" class=\"card__type\">\n<div class=\"card__head\">\n<div class=\"card__image\"><img src=\"/ytc/customer/send/img/send_service_im04.png\" alt=\"\"></div>\n</div>\n<div class=\"card__body\">\n<div class=\"card__title\">自宅で送り状発行</div>\n</div>\n</a></div>\n<div class=\"card img-center\" data-card-sp=\"row\"><a href=\"/ytc/customer/send/members/rakuraku/\" class=\"card__type\">\n<div class=\"card__head\">\n<div class=\"card__image\"><img src=\"/ytc/customer/send/img/send_service_im05.png\" alt=\"\"></div>\n</div>\n<div class=\"card__body\">\n<div class=\"card__title\">らくらく送り状発行サービス</div>\n</div>\n</a></div>\n<div class=\"card img-center\" data-card-sp=\"row\"><a href=\"/ytc/customer/send/members/schedule_notice/\" class=\"card__type\">\n<div 