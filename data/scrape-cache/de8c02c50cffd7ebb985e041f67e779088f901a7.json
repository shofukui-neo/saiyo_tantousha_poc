{"url":"https://www.sc-aero.co.jp/recruit/career.html","html":"\n<!DOCTYPE html>\n<html lang=\"ja\">\n    <head>\n        <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n        <meta charset=\"utf-8\">\n        <meta name=\"description\" content=\"住商エアロシステム株式会社の「キャリア採用」ページです。\">\n        <meta name=\"keywords\" content=\"住商エアロシステム,SAS,キャリア採用\">\n        <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n        <meta name=\"format-detection\" content=\"telephone=no\">\n\n        <title>キャリア採用｜住商エアロシステム株式会社</title>\n\n        <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n        <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n        <link rel=\"stylesheet\" href=\"https://fonts.googleapis.com/css2?family=Oswald:wght@700&display=swap\">\n        <link rel=\"stylesheet\" href=\"https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&display=swap\">\n        \n        <link rel=\"stylesheet\" href=\"../assets/css/style.css\" media=\"all\">\n\n        <script src=\"../assets/js/vendor/script.js\"></script>\n        <script src=\"../assets/js/plugins.js\"></script>\n        \n        <script src=\"../assets/js/app.js\"></script>\n\n        <!-- Global site tag (gtag.js) - Google Analytics -->\n        <script async src=\"https://www.googletagmanager.com/gtag/js?id=G-K76JDYQNZS\"></script> <script>\n            window.dataLayer = window.dataLayer || []; function gtag(){dataLayer.push(arguments);} gtag('js', new Date());\n            gtag('config', 'G-K76JDYQNZS');\n            gtag('config', 'UA-226519009-1');\n        </script>\n    </head>\n    <body class=\"lang-jp child recruit career\" data-key=\"01-05-01\" data-dir=\"1\">\n        <div id=\"wrapper\">\n            <header>\n                \n                <div id=\"header\">\n                    <div class=\"float\">\n                        <div class=\"left\">\n                            <div class=\"logo\">\n  