{"url":"https://www.neco-net.co.jp/","html":"<!doctype html>\n<html lang=\"ja\">\n<head>\n<title>原子力エンジニアリング株式会社｜豊かな社会と原子力技術発展の共栄を目指して。</title>\n<meta name=\"description\" content=\"原子力関連施設において、試験研究炉、核燃料取扱施設、核融合装置など、施設の運転保守管理業務、それら施設に設置される、さまざまな実験・試験装置を使用した研究開発の支援業務や廃棄物管理業務などを通じて、原子力の研究開発の土台を支える業務を行っています。\">\n<meta name=\"keywords\" content=\"原子力,エネルギー,環境,研究,開発,原子力発電所,エネルギー環境,実験,試験,放射性,廃棄物,点検,検査,原子力エンジニアリング\">\n\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<meta name=\"format-detection\" content=\"telephone=no\">\n\n<meta property=\"og:type\" content=\"website\">\n<meta property=\"og:title\" content=\"原子力エンジニアリング株式会社｜豊かな社会と原子力技術発展の共栄を目指して。\">\n<meta property=\"og:description\" content=\"原子力関連施設において、試験研究炉、核燃料取扱施設、核融合装置など、施設の運転保守管理業務、それら施設に設置される、さまざまな実験・試験装置を使用した研究開発の支援業務や廃棄物管理業務などを通じて、原子力の研究開発の土台を支える業務を行っています。\">\n<meta property=\"og:site_name\" content=\"原子力エンジニアリング株式会社\">\n<meta property=\"og:url\" content=\"https://www.neco-net.co.jp\">\n<meta property=\"og:image\" content=\"https://www.neco-net.co.jp/ogp.jpg\">\n<link rel=\"stylesheet\" href=\"css/top.css\">\n<link rel=\"stylesheet\" href=\"css/import.css\">\n<link rel=\"icon\" type=\"image/svg+xml\" href=\"favicon.svg\" />\n<link rel=\"icon\" type=\"image/vnd.microsoft.icon\" href=\"favicon.png\" />\n<link rel=\"apple-touch-icon\" href=\"apple-touch-icon.png\">\n\n<script src=\"js/jquery-1.7.2.min.js\" type=\"text/javascript\"></script>\n<script src=\"js/viewport.js\" type=\"text/javascript\"></script>\n<script src=\"js/hover.js\" type=\"text/javascript\"></script>\n<script src=\"js/menu.js\" type=\"text/javascript\"></script>\n<script src=\"js/inview.js\" type=\"text/javascript\"></script>\n<script src=\"js/inview_op.js\" type=\"text/javascript\"></script>\n<script src=\"js/slick.min.js\" type=\"text/javascript\"></script>\n<script src=\"js/slick_op.js\" type=\"text/javascript\"></script>\n<script src=\"js/smaller.js\" type=\"text/javascript\"></script>\n<script src=\"js/scroll.js\" type=\"text/javascript\"></script>\n<script src=\"js/scrolltopcontrol.js\" type=\"text/javascript\"></script>\n<script src=\"js/ScrollTrigger.min.js\" type=\"text/javascript\"></script>\n<script src=\"js/jquery.easing.1.3.js\" type=\"text/javascript\"></script>\n<script src=\"js/fancybox/jquery.fancybox-1.3.4.pack.js\" type=\"text/javascript\"></script>\n<script src=\"js/fancybox_set.js\"></script>\n\n<!-- Googleアナリティクス開始【原子力エンジニアリング株式会社】 -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-CW27MV4TRW\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'G-CW27MV4TRW');\n</script>\n<!-- Googleアナリティクス終了【原子力エンジニアリング株式会社】 -->\n\n<!-- ブログ読み込み用 -->\n<link href=\"information/pickup/pickup.css?20210423\" rel=\"stylesheet\" />\n<script type=\"text/javascript\" charset=\"utf-8\" src=\"information/pickup/pickup.js?20210423\"></script>\n<!--/ ブログ読み込み用 -->\n</head>\n\n<body id=\"top\">\n<header>\n<div id=\"menu\">\n<div class=\"header_nav\">\n    <div class=\"flex\">\n        <a href=\"index.html\" class=\"logo\"><img src=\"images/logo.svg\" alt=\"原子力エンジニアリング株式会社\" width=\"379\" height=\"48\"></a>\n        <a href=\"index.html\" class=\"logo_short\"><img src=\"images/logo_short.svg\" alt=\"原子力エンジニアリング株式会社\" width=\"266\" height=\"48\"></a>\n        <a href=\"index.html\" class=\"logo_icon\"><img src=\"images/logo_icon.svg\" alt=\"原子力エンジニアリング株式会社\" width=\"60\" height=\"48\"></a>\n        <div>\n            <nav class=\"global_nav\">\n                <ul>\n                    <li><a href=\"about/index.html\">NECOについて</a></li>\n                    <li><a href=\"works/index.html\">私たちの仕事</a></li>\n                    <li><a href=\"people/index.html\">NECOの仲間</a></li>\n                    <li><a href=\"career_formation/index.html\">キャリア形成</a></li>\n                    <li><a href=\"benefit/index.html\">環境と制度</a></li>\n                    <li><a href=\"recruit/index.html\">採用情報</a></li>\n                    <li class=\"contact\"><a href=\"contact/index.html\"><span>お問い合わせ</span></a></li>\n                </ul>\n            </nav>\n            <!-- /global_nav -->\n        </div>\n    </div>\n    <!-- /flex -->\n</div>\n<!-- /header_nav -->\n</div>\n<!-- /menu -->\n\t\n<nav class=\"floating_contact\">\n<ul class=\"flex\">\n<li><a href=\"recruit/index.html#entry\">採用エントリー</a></li>\n<li><a href=\"recruit/index.html#requirements\">募集要項</a></li>\n</ul>\n</nav>\n<!-- /floating_contact -->\n\n<div class=\"global_nav_sp\">\n<div class=\"menu\">\n    <a href=\"index.html\" class=\"logo_sp\"><img src=\"images/logo.svg\" alt=\"原子力エンジニアリング株式会社\"></a>\n    <div class=\"toggle\">\n        <div class=\"bar top\"></div>\n        <div class=\"bar middle\"></div>\n        <div class=\"bar bottom\"></div>\n    </div>\n    <!-- /toggle -->\n    <nav class=\"menu_sp\">\n        <ul>\n            <li><a href=\"about/index.html\">NECOについて</a></li>\n            <li><a href=\"works/index.html\">私たちの仕事</a></li>\n            <li><a href=\"people/index.html\">NECOの仲間</a></li>\n            <li><a href=\"career_formation/index.html\">キャリア形成</a></li>\n            <li><a href=\"benefit/index.html\">環境と制度</a></li>\n            <li><a href=\"recruit/index.html\">採用情報</a></li>\n            <li class=\"contact\"><a href=\"contact/index.html\">お問い合わせ</a></li>\n        </ul>\n    </nav>\n</div>\n<!-- /menu -->\n</div>\n<!-- /global_nav_sp -->\n</header>\n\n\n<div class=\"mainvisual\">\n<div class=\"inner\">\n<div class=\"fr\">\n    <picture>\n    <source media=\"(max-width:767px)\" srcset=\"images/mainvisual_fr_sp.png\">\n    <img src=\"images/mainvisual_fr.png\" alt=\"\">\n    </picture>\n</div>\n<!-- /fr -->\n<ul id=\"main_slide\" class=\"slider\">\n    <li>\n        <picture>\n        <source media=\"(max-width:767px)\" srcset=\"images/mainvisual01_sp.png\">\n        <img src=\"images/mainvisual01.jpg\" alt=\"\" width=\"1680\" height=\"750\">\n        </picture>\n    </li>\n    <li>\n        <picture>\n        <source media=\"(max-width:767px)\" srcset=\"images/mainvisual02_sp.png\">\n        <img src=\"images/mainvisual02.jpg\" alt=\"\" width=\"1680\" height=\"750\">\n        </picture>\n    </li>\n    <li>\n        <picture>\n        <source media=\"(max-width:767px)\" srcset=\"images/mainvisual03_sp.png\">\n        <img src=\"images/mainvisual03.jpg\" alt=\"\" width=\"1680\" height=\"750\">\n        </picture>\n    </li>\n    <li>\n        <picture>\n        <source media=\"(max-width:767px)\" srcset=\"images/mainvisual04_sp.png\">\n        <img src=\"images/mainvisual04.jpg\" alt=\"\" width=\"1680\" height=\"750\">\n        </picture>\n    </li>\n</ul>\n</div>\n<!-- /inner -->\n<div class=\"wrap\">\n    <h1>豊かな社会と原子力技術発展の<br>共栄を目指して。</h1>\n    <div class=\"flex\">\n        <p>EVOLUTION</p>\n        <div class=\"image_wrap\"><img src=\"images/mainvisual_deco.png\" alt=\"\" width=\"320\" height=\"290\"></div>\n    </div>\n</div>\n</div>\n<!-- /mainvisual -->\n\n<main>\n\n<section id=\"info\">\n<div class=\"inner\">\n<h2><a href=\"info/index.html\">INFORMATION<span>お知らせ</span></a></h2>\n\n<!-- ブログ最新記事表示 始まり -->\n<ul id=\"blog_all\" class=\"flex\"></ul><!-- 最新記事表示 DOM要素。id は任意。 -->\n<script type=\"text/javascript\">\nnecoBlogPickupDataFile('information/pickup/all/data.php','blog_all',4,'news',null);//読み込み先カテゴリーごとに blog/pickup/ の下に別々のフォルダとファイルを用意して、1つ目の引数にそのファイルを指定。2つ目の引数には、表示する DOM 要素の id を指定。\n</script>\n<!-- ブログ最新記事表示 終わり -->\n\n<div class=\"btn_more\">\n    <a href=\"information/\">MORE</a>\n</div>\n\t\n<div class=\"imgC\"><a href=\"recruit/index.html#entry\"><figure><img src=\"images/bnr_entry.jpg\" alt=\"\" width=\"600\" height=\"150\"></figure></a></div>\n</div>\n<!-- /inner -->\n</section>\n<!-- /info -->\n\n\n<section id=\"about\" class=\"transMv01\">\n<div class=\"inner\">\n<h2><a href=\"about/index.html\"><span class=\"en\">ABOUT</span><span>原子力エンジニアリング（NECO）について</span></a></h2>\n<div class=\"text_wrap\">\n    <p class=\"catch\">私たちの活動が最先端の<br class=\"pc\">研究を支えています。</p>\n    <div class=\"imgC sp mb_normal\">\n        <img src=\"images/about_sp.png\" alt=\"\" width=\"356\" height=\"251\">\n    </div>\n    <div class=\"btn\">\n        <a href=\"about/index.html\">NECOを知る</a>\n    </div>\n</div>\n\n</div>\n<!-- /inner -->\n</section>\n<!-- /about -->\n\n\n<section id=\"works\" class=\"transMv01\">\n<div class=\"inner\">\n<div class=\"text_wrap\">\n    <h2><a href=\"works/index.html\">WORKS<span>私たちの仕事</span></a></h2>\n    <p class=\"catch txtL\">技術力と豊富な経験を活かし、<br class=\"pc\">信頼される質の高いサービスを提供しています。</p>\n    <p>私たちは原子力の下で、高度な技術と多岐にわたる知識を身につけ、福島復興支援に尽力すると共に、原子力の研究開発にも引き続き寄与していきます。</p>\n</div>\n<ul class=\"flex\">\n    <li><a href=\"works/support/index.html\">研究支援業務</a></li>\n    <li><a href=\"works/operate/index.html\">施設の運転保守</a></li>\n    <li><a href=\"works/control/index.html\">実験・試験装置の運転管理</a></li>\n\t<li><a href=\"works/radiation_control/index.html\">放射線管理業務</a></li>\n\t<li><a href=\"works/radioactive_waste/index.html\">放射性廃棄物管理業務</a></li>\n    <li><a href=\"works/sell/index.html\">鋼製角型容器販売</a></li>\n    <li><a href=\"works/relocation/index.html\">建屋等の建設・移設・解体撤去作業</a></li>\n    <li><a href=\"works/plan/index.html\">各種設備・関連機器の設計・製作・点検検査作業</a></li>\n    <li><a href=\"works/demonstration_project/index.html\">除去土壌の埋立処分に係る実証事業の技術協力</a></li>\n</ul>\n</div>\n<!-- /inner -->\n</section>\n<!-- /works -->\n\n\n<section id=\"people\" class=\"transMv06\">\n<div class=\"inner\">\n<div class=\"ttl flex\">\n    <h2 class=\"second\"><a href=\"people/index.html\">PEOPLE<span>NECOの仲間</span></a></h2>\n    <img src=\"images/people_deco.png\" alt=\"\" width=\"147\" height=\"230\" class=\"pc\">\n    <img src=\"images/people_deco_sp.png\" alt=\"\" width=\"500\" height=\"270\" class=\"sp\">\n    <div>\n        <p class=\"catch\"><span>NECOをささえる社員を紹介します。</span><br><span>等身大の声から見えてくる、</span><br><span>私たちの仕事とこれから。</span></p>\n        <p>全国の事業所で毎日いきいきと働く社員が、様々な業務、人の生活、私たちの夢をささえています。</p>\n    </div>\n</div>\n<ul class=\"flex\">\n    <li>\n        <a href=\"people/interview01/index.html\">\n            <div class=\"image_wrap\">\n                <img src=\"images/people01.jpg\" alt=\"\" width=\"300\" height=\"320\">\n            </div>\n            <div class=\"text_wrap\">\n                <p class=\"type\">東海事業所<br>事業管理部 事業管理第3課</p>\n                <p class=\"name\"></p>\n            </div>\n        </a>\n    </li>\n    <li>\n        <a href=\"people/interview02/index.html\">\n            <div class=\"image_wrap\">\n                <img src=\"images/people02.jpg\" alt=\"\" width=\"300\" height=\"320\">\n            </div>\n            <div class=\"text_wrap\">\n                <p class=\"type\">東海事業所<br>トリチウム研グループ</p>\n                <p class=\"name\"></p>\n            </div>\n        </a>\n    </li>\n    <li>\n        <a href=\"people/interview03/index.html\">\n            <div class=\"image_wrap\">\n                <img src=\"images/people03.jpg\" alt=\"\" width=\"300\" height=\"320\">\n            </div>\n            <div class=\"text_wrap\">\n                <p class=\"type\">東海事業所<br>焼却処理グループ</p>\n                <p class=\"name\"></p>\n            </div>\n        </a>\n    </li>\n    <li>\n        <a href=\"people/interview04/index.html\">\n            <div class=\"image_wrap\">\n                <img src=\"images/people04.jpg\" alt=\"\" width=\"300\" height=\"320\">\n            </div>\n            <div class=\"text_wrap\">\n                <p class=\"type\">技術営業部<br>営業課</p>\n                <p class=\"name\"></p>\n            </div>\n        </a>\n    </li>\n</ul>\n</div>\n<!-- /inner -->\n</section>\n<!-- /people -->\n\n\n<section id=\"career_formation\" class=\"transMv06\">\n<div class=\"inner\">\n<h2><a href=\"career_formation/index.html\">CAREER <br class=\"sp\">FORMATION<span>キャリア形成</span></a></h2>\n\n<div class=\"wrap flex\">\n    <div class=\"image_wrap\">\n        <img src=\"images/career_formation_deco.png\" alt=\"\" width=\"270\" height=\"186\">\n    </div>\n    <div class=\"text_wrap\">\n        <p class=\"catch\">NECOはあなたがプロフェッショナルになれる会社。<br class=\"pc\">私たちは<span>「人」</span>の教育に力を入れています。</p>\n        <p>私たちはどんな先端技術も支えているのは人であると考えています。<br>何かを成し遂げようという「人」の強い意志が起点であり、それを前進するための「人」の恒常的な修練・努力こそが技術の向上に繋がり終着点はありません。</p>\n    </div>\n</div>\n<ul class=\"flex\">\n    <li>\n        <a href=\"career_formation/index.html\">\n            <img src=\"images/career_formation01.jpg\" alt=\"\" width=\"560\" height=\"440\">\n            <div class=\"text_wrap\">\n                <h3>NECOで叶えるキャリアパス</h3>\n                <p>あなたがNECOに入社したら、<!--どんな働き方ができるのか、-->どんな風にキャリアアップを図っていくことができるのかを紹介します。</p>\n            </div>\n            <div class=\"btn\"></div>\n        </a>\n    </li>\n    <li>\n        <a href=\"career_formation/index.html#route\">\n            <img src=\"images/career_formation02.jpg\" alt=\"\" width=\"560\" height=\"440\">\n            <div class=\"text_wrap\">\n                <h3>教育・研修制度</h3>\n                <p>「NECOテクニカルスクール」や「独り立ちプログラム」、各種資格の取得サポートなどの教育・研修制度が充実しているので、社会人として、技術者として、ひとりの人としてスキルアップを続けていくことができます。</p>\n            </div>\n            <div class=\"btn\"></div>\n        </a>\n    </li>\n</ul>\n</div>\n<!-- /inner -->\n</section>\n<!-- /career_formation -->\n\n\n<section id=\"benefit\" class=\"transMv01\">\n<div class=\"inner\">\n<h2><a href=\"benefit/index.html\">BENEFIT<span>環境と制度</span></a></h2>\n<div class=\"text_wrap\">\n    <p class=\"catch\">仕事も余暇も充実した<br class=\"pc\">バランス良いワークライフを。</p>\n    <p>「楽しく働こう。Have Fun！」が私たちのモットーです。<br class=\"pc\">職場でも、私人としても、豊かで充実した生活を過ごせるように、社員の処遇改善と福利厚生に取り組んでいます。</p>\n    <div class=\"btn\">\n        <a href=\"benefit/index.html\">NECOの多彩な福利厚生</a>\n    </div>\n</div>\n</div>\n<!-- /inner -->\n<div class=\"image_wrap\">\n    <img src=\"images/benefit_deco_sp.png\" alt=\"\" width=\"350\" height=\"294\" class=\"sp\">\n</div>\n</section>\n<!-- /benefit -->\n\n\n<section id=\"recruit\" class=\"transMv01\">\n<div class=\"inner\">\n<h2><a href=\"recruit/index.html\"><span class=\"en\">RECRUIT</span><span>採用情報</span></a></h2>\n<p>新入社員のためのプログラムやスクールなどで分野別の基礎知識を習得できるので、やる気さえあればそれで充分。<br>ぜひ、私たちと一緒に、未来のエネルギー環境を開拓しましょう！</p>\n<p class=\"catch\">夢のある仕事をする。<br class=\"sp\">毎日をささえる人になる。</p>\n<ul class=\"flex\">\n    <li><a href=\"recruit/index.html#message\">メッセージ・求める人物<span class=\"en\">MESSAGE</span></a></li>\n    <li><a href=\"recruit/graduate/index.html\"><span class=\"type\">新卒採用</span>募集要項<span class=\"en\">GRADUATE</span></a></li>\n    <li><a href=\"recruit/career/index.html\"><span class=\"type\">キャリア採用</span>募集要項<span class=\"en\">CAREER</span></a></li>\n</ul>\n</div>\n<!-- /inner -->\n</section>\n<!-- /recruit -->\n</main>\n\n\n<footer>\n<div class=\"inner\">\n<nav class=\"footer_area_nav sp\">\n<ul>\n<li><a href=\"about/index.html\">NECOについて</a></li>\n<li><a href=\"works/index.html\">私たちの仕事</a></li>\n<li><a href=\"people/index.html\">NECOの仲間</a></li>\n<li><a href=\"career_formation/index.html\">キャリア形成</a></li>\n<li><a href=\"benefit/index.html\">環境と制度</a></li>\n<li><a href=\"recruit/index.html\">採用情報</a></li>\n<li><a href=\"privacy/index.html\">プライバシーポリシー</a></li>\n<li><a href=\"contact/index.html\">お問い合わせ</a></li>\n<li><a href=\"sitemap/index.html\">サイトマップ</a></li>\n</ul>\n</nav>\n<!-- /footer_area_nav -->\n<div class=\"vcard_area\">\n    <div class=\"fn org\"><a href=\"index.html\"><img src=\"images/logo.svg\" alt=\"原子力エンジニアリング株式会社\" class=\"footer_logo\"></a></div>\n    <dl class=\"flex\">\n        <dt>本社</dt>\n        <dd class=\"adr\">\n            <span class=\"postal-code\">〒319-1112</span><span class=\"region\">茨城県</span><span class=\"locality\">那珂郡東海村</span><span class=\"street-address\">村松字平原3129-29</span>\n            <br>\n            <span class=\"tel\"><span class=\"type\">TEL：</span><span class=\"value\">029-287-2828</span></span>/\n            <span class=\"fax\">\n                <span class=\"type\">FAX：</span><span class=\"value\">029-287-3399</span>\n            </span>\n        </dd>\n    </dl>\n</div>\n<!-- /vcard_area -->\n</div>\n<!-- /inner -->\n\n<div class=\"footer_area_nav pc\">\n<div class=\"inner\">\n<ul class=\"flex\">\n<li><a href=\"privacy/index.html\">プライバシーポリシー</a></li>\n<li><a href=\"contact/index.html\">お問い合わせ</a></li>\n<li><a href=\"sitemap/index.html\">サイトマップ</a></li>\n</ul>\n<div class=\"copyright\">\n<small >Copyright Nuclear Engineering Co.,Ltd. All Rights Reserved.</small>\n</div>\n</div>\n<!-- /inner -->\n</div>\n<!-- /footer_area_nav -->\n\n<div class=\"copyright sp\">\n    <small >Copyright Nuclear Engineering Co.,Ltd. All Rights Reserved.</small>\n</div>\n</footer>\n\n\n<nav class=\"floating_menu sp\">\n<ul>\n<!--<li class=\"contact full\"><a href=\"contact/index.html\">お問い合わせ</a></li>-->\n<li class=\"entry\"><a href=\"recruit/index.html#entry\">採用エントリー</a></li>\n<li class=\"requirements\"><a href=\"recruit/index.html#requirements\">募集要項</a></li>\n</ul>\n</nav>\n\n\n</body>\n</html>\n","finalUrl":"https://www.neco-net.co.jp/","rendered":false,"_cachedAt":"2026-06-22T15:04:53.629Z"}