crumbsLine\">\n    <ol class=\"sub-breadcrumbs clearfix\">\n      <li><a href=\"/\">HOME</a></li>\n      <li>新着情報</li>\n    </ol>\n  </div>\n  <!-- /breadcrumbs -->\n  <!-- main-body -->\n  <section class=\"l-container\">\n    <h1 class=\"mod-hl-01\">\n      新着情報一覧\n      <span class=\"en\">information index</span>\n    </h1>\n    <!-- l-container-w900 -->\n    <div class=\"l-container-w900\">\n\n\n                        <!-- article -->\n          <article class=\"info-infoArticle\">\n            <a href=\"/news/archives/116\" class=\"info-infoArticle__inner\">\n              <time class=\"info-infoArticle__date\" datetime=\"2026-06-23\">2026.06.23</time>\n              <span class=\"info-infoArticle__cat\">\n                                トピックス              </span>\n              <h2 class=\"info-infoArticle__title\">2026年度 安全衛生大会開催</h2>\n              <p class=\"info-infoArticle__text\">\n                令和8年6月22日、出雲労働基準監督署 小田署長様及び出雲警察署 安田交通総務課長様を来賓に迎え20...\n              </p>\n            </a>\n          </article>\n          <!-- /article -->\n                  <!-- article -->\n          <article class=\"info-infoArticle\">\n            <a href=\"/news/archives/115\" class=\"info-infoArticle__inner\">\n              <time class=\"info-infoArticle__date\" datetime=\"2026-04-02\">2026.04.02</time>\n              <span class=\"info-infoArticle__cat\">\n                                トピックス              </span>\n              <h2 class=\"info-infoArticle__title\">令和８年度　今岡グループ入社式</h2>\n              <p class=\"info-infoArticle__text\">\n                令和８年４月１日、本社３階大会議室にて今岡グループ入社式を行いました。会長からの祝辞のあと、各社社長...\n              </p>\n            </a>\n          </article>\n          <!-- /article -->\n                  <!-- article -->\n          <article class=\"info-infoArticle\">\n            <a href=\"/news/archives/114\" class=\"info-infoArticle__inner\">\n              <time class=\"info-infoArticle__date\" datetime=\"2026-03-30\">2026.03.30</time>\n              <span class=\"info-infoArticle__cat\">\n                                トピックス              </span>\n              <h2 class=\"info-infoArticle__title\">「健康経営優良法人2026」に認定されました</h2>\n              <p class=\"info-infoArticle__text\">\n                経済産業省の「健康経営優良法人2026」に、3月9日付で認定されましたので、お知らせします。↓経済産...\n              </p>\n            </a>\n          </article>\n          <!-- /article -->\n                  <!-- article -->\n          <article class=\"info-infoArticle\">\n            <a href=\"/news/archives/113\" class=\"info-infoArticle__inner\">\n              <time class=\"info-infoArticle__date\" datetime=\"2026-01-09\">2026.01.09</time>\n              <span class=\"info-infoArticle__cat\">\n                                表彰              </span>\n              <h2 class=\"info-infoArticle__title\">国土交通省中国地方整備局長より感謝状をいただきました</h2>\n              <p class=\"info-infoArticle__text\">\n                令和７年８月・９月豪雨に際し、松江国道事務所管内において山陰道で事前通行規制を実施し二次災害の防止に...\n              </p>\n            </a>\n          </article>\n          <!-- /article -->\n                  <!-- article -->\n          <article class=\"info-infoArticle\">\n            <a href=\"/news/archives/112\" class=\"info-infoArticle__inner\">\n              <time class=\"info-infoArticle__date\" datetime=\"2025-11-21\">2025.11.21</time>\n              <span class=\"info-infoArticle__cat\">\n                                トピックス              </span>\n              <h2 class=\"info-infoArticle__title\">創業８０周年記念事業寄付</h2>\n              <p class=\"info-infoArticle__text\">\n                  令和７年１１月１８日、創業８０周年記念の一環として本社を構える出雲市に文化スポーツ事業の一助とし...\n              </p>\n            </a>\n          </article>\n          <!-- /article -->\n                  <!-- article -->\n          <article class=\"info-infoArticle\">\n            <a href=\"/news/archives/111\" class=\"info-infoArticle__inner\">\n              <time class=\"info-infoArticle__date\" datetime=\"2025-09-22\">2025.09.22</time>\n              <span class=\"info-infoArticle__cat\">\n                                トピックス              </span>\n              <h2 class=\"info-infoArticle__title\">今岡工業創業80周年記念祝賀会</h2>\n              <p class=\"info-infoArticle__text\">\n                当社は創業80周年を迎え、記念祝賀会を執り行いました。当日は、多くの来賓の皆様にご臨席賜り、4名の方...\n              </p>\n            </a>\n          </article>\n          <!-- /article -->\n                  <!-- article -->\n          <article class=\"info-infoArticle\">\n            <a href=\"/news/archives/110\" class=\"info-infoArticle__inner\">\n              <time class=\"info-infoArticle__date\" datetime=\"2025-09-09\">2025.09.09</time>\n              <span class=\"info-infoArticle__cat\">\n                                トピックス              </span>\n              <h2 class=\"info-infoArticle__title\">社員旅行に行きました</h2>\n              <p class=\"info-infoArticle__text\">\n                二班に分けて沖縄に社員旅行に行きました。1班は8月28日～30日、2班は9月4日～6日にかけて沖縄を...\n              </p>\n            </a>\n          </article>\n          <!-- /article -->\n                  <!-- article -->\n          <article class=\"info-infoArticle\">\n            <a href=\"/news/archives/109\" class=\"info-infoArticle__inner\">\n              <time class=\"info-infoArticle__date\" datetime=\"2025-08-22\">2025.08.22</time>\n              <span class=\"info-infoArticle__cat\">\n                                表彰              </span>\n              <h2 class=\"info-infoArticle__title\">ヘルス・マネジメント認定事業所表彰をいただきました</h2>\n              <p class=\"info-infoArticle__text\">\n                令和７年８月２０日、ヘルス・マネジメント認定事業所表彰を頂きました。今後も健康経営の推進に努めてまい...\n              </p>\n            </a>\n          </article>\n          <!-- /article -->\n                  <!-- article -->\n          <article class=\"info-infoArticle\">\n            <a href=\"/news/archives/108\" class=\"info-infoArticle__inner\">\n              <time class=\"info-infoArticle__date\" datetime=\"2025-08-04\">2025.08.04</time>\n              <span class=\"info-infoArticle__cat\">\n                                表彰              </span>\n              <h2 class=\"info-infoArticle__title\">令和７年度島根県優良工事等所長表彰をいただきました。</h2>\n              <p class=\"info-infoArticle__text\">\n                令和7年7月31日、島根県優良工事等所長表彰を受賞しました。・出雲県土整備事務所長表彰工事名：三刀屋...\n              </p>\n            </a>\n          </article>\n          <!-- /article -->\n                  <!-- article -->\n          <article class=\"info-infoArticle\">\n            <a href=\"/news/archives/107\" class=\"info-infoArticle__inner\">\n              <time class=\"info-infoArticle__date\" datetime=\"2025-07-29\">2025.07.29</time>\n              <span class=\"info-infoArticle__cat\">\n                                トピックス              </span>\n              <h2 class=\"info-infoArticle__title\">令和７年度 工事成績優秀企業に認定されました</h2>\n              <p class=\"info-infoArticle__text\">\n                7月16日、国土交通省　中国地方整備局長より令和7年度 工事成績優秀企業に認定されました。...\n              </p>\n            </a>\n          </article>\n          <!-- /article -->\n                    <!-- pagination -->\n      \n\n\n<div class=\"mod-pagination-01 textCenter marginTop35\">\n  <span class=\"dn\">＜</span>  <span class=\"current number page-numbers\">1</span><span class=\"number page-numbers\"><a href=\"/news/index/page:2\">2</a></span><span class=\"number page-numbers\"><a href=\"/news/index/page:3\">3</a></span><span class=\"number page-numbers\"><a href=\"/news/index/page:4\">4</a></span><span class=\"number page-numbers\"><a href=\"/news/index/page:5\">5</a></span><span class=\"number page-numbers\"><a href=\"/news/index/page:6\">6</a></span><span class=\"number page-numbers\"><a href=\"/news/index/page:7\">7</a></span>  <span class=\"next page-numbers\"><a href=\"/news/index/page:2\" rel=\"next\">＞</a></span></div>\n      <!-- /pagination -->\n    </div>\n    <!-- /l-container-w900 -->\n  </section>\n  <!-- /main-body -->\n</div>      </main>\n  <!-- /main container -->\n\n  <!-- footer -->\n  <footer role=\"contentinfo\" 