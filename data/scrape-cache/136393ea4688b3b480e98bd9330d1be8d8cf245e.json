=\"header-list__item\">\n                  <a href=\"/saiyou/new/business/\">仕事・人を知る</a>\n                </li>\n                <li class=\"header-list__item\">\n                  <a href=\"/saiyou/new/workstyle/\">働き方を知る</a>\n                </li>\n                <li class=\"header-list__item\">\n                  <a href=\"/saiyou/new/information/\">採用情報</a>\n                </li>\n                <li class=\"header-list__item\">\n                  <a href=\"https://www.ags.co.jp/corporate/outline/index.html\" target=\"_blank\">会社情報</a>\n                </li>\n              </ul>\n              <ul class=\"header-buttons hover-outline\">\n                <li class=\"header-buttons__item\">\n                  <a href=\"/saiyou/new/information/entry/\">\n                    <span>募集要項</span>\n                  </a>\n                </li>\n                <li class=\"header-buttons__item\">\n                  <a href=\"https://ags.snar.jp/entry.aspx?entryid=190d4991-7f97-42c8-b72f-0496d241e802\">\n                    <span>ENTRY</span>\n                  </a>\n                </li>\n              </ul>\n            </div>\n          </nav>\n        </div>\n      </div>\n    </header>\n  <main class=\"layout-content\">\n\n  <section class=\"section component-hero js-inview\">\n    <div class=\"component-hero__inner\">\n      <figure class=\"component-hero__image\">\n        <picture>\n          <source srcset=\"/saiyou/assets/img/new/home/img_hero.jpg\" media=\"(max-width: 768px)\">\n          <img src=\"/saiyou/assets/img/new/home/img_hero.jpg\" alt=\"新卒採用\" width=\"1248\" height=\"945\">\n        </picture>\n      </figure>\n      <h2 class=\"component-hero__heading\">\n        <span>挑戦と成長。その先をともに。</span>\n        <span>新たな一歩を、自分らしく。</span>\n      </h2>\n    </div>\n    \n    <div class=\"component-hero-news\">\n        <h3 class=\"component-hero-news__heading\">NEWS</h3>\n        <ul class=\"component-hero-news-list hover-color\">\n            <li class=\"component-hero-news-list__item\">\n                <div><date class=\"component-hero-news-list__date\">2026.04.01</date><span class=\"component-hero-news-list__text\"><p><a href=\"/saiyou/new/open-company/\">2026年度開催オープン・カンパニーの受付を開始いたしました。</a></p></span></div>\n            </li>\n        \n    \n    \n            <li class=\"component-hero-news-list__item\">\n                <div><date class=\"component-hero-news-list__date\">2026.02.02</date><span class=\"component-hero-news-list__text\"><p><a href=\"/saiyou/new/information/entry/\">2027年卒業予定学生の新卒エントリーの受付を開始いたしました。</a></p></span></div>\n            </li>\n        </ul>\n    </div>\n    \n\n    <!-- オープン・カンパニー フローティングバナー-->\n    <div class=\"floating-banner hover-color\">\n      <a href=\"/saiyou/new/open-company/\">\n        <div class=\"floating-banner__content\">\n          <h3 class=\"floating-banner__heading\">\n            OPEN<br class=\"only-pc\">\n            COMPANY\n          </h3>\n          <h4 class=\"floating-banner__subheading\">オープン・カンパニー</h4>\n        </div>\n        <figure class=\"floating-banner__illust\">\n          <img src=\"/saiyou/assets/img/new/home/illst_work.svg\" alt=\"ＡＧＳの仕事を知る\" loading=\"lazy\" decoding=\"async\" fetchpriority=\"auto\" width=\"144\" height=\"149\">\n        </figure>\n        <span class=\"component-arrow component-arrow--white\"></span>\n      </a>\n    </div>\n\n\n  </section>\n\n  <div class=\"component-background only-sp\" style=\"z-index: -1;\">\n                <svg viewBox=\"0 0 2423 1518\" preserveAspectRatio=\"xMidYMid slice\">\n                    <defs>\n                        <linearGradient id=\"gradient-stroke01\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"0%\">\n                            <stop offset=\"0%\" stop-color=\"#10d994\"></stop>\n                            <stop offset=\"43%\" stop-color=\"#4285f4\"></stop>\n                            <stop offset=\"73%\" stop-color=\"#69d314\"></stop>\n                            <stop offset=\"100%\" stop-color=\"#0