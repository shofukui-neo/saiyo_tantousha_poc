0\" height=\"600\">\n        </figure>\n        <ul class=\"new-about-list hover-color\">\n          <li class=\"new-about-list__item\">\n            <a href=\"/saiyou/new/about/reason/\"><span class=\"component-arrow component-arrow--large component-arrow--outline\"></span>ＡＧＳってどんな会社？</a>\n          </li>\n          <li class=\"new-about-list__item\">\n            <a href=\"/saiyou/new/numbers/\"><span class=\"component-arrow component-arrow--large component-arrow--outline\"></span>数字で見るＡＧＳ</a>\n          </li>\n        <li class=\"new-about-list__item\">\n            <a href=\"/saiyou/new/about/history/\"><span class=\"component-arrow component-arrow--large component-arrow--outline\"></span>ＡＧＳの歴史・取り組み</a>\n          </li>\n          <li class=\"new-about-list__item\">\n            <a href=\"/saiyou/new/hr-message/\"><span class=\"component-arrow component-arrow--large component-arrow--outline\"></span>採用責任者メッセージ</a>\n          </li>\n          <li class=\"new-about-list__item\">\n            <a href=\"/saiyou/new/r-message/\"><span class=\"component-arrow component-arrow--large component-arrow--outline\"></span>採用担当者メッセージ</a>\n          </li>\n        </ul>\n      </div>\n      <p class=\"component-button component-button--more\">\n        <a href=\"/saiyou/new/about/\">More</a>\n      </p>\n    </div>\n  </section>\n\n  <div class=\"component-background only-pc\">\n    <svg viewBox=\"0 0 2423 1518\" preserveAspectRatio=\"xMidYMid slice\">\n      <defs>\n        <linearGradient id=\"gradient-stroke\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"0%\">\n          <stop offset=\"0%\" stop-color=\"#10d994\"></stop>\n          <stop offset=\"43%\" stop-color=\"#4285f4\"></stop>\n          <stop offset=\"73%\" stop-color=\"#69d314\"></stop>\n          <stop offset=\"100%\" stop-color=\"#004098\"></stop>\n        </linearGradient>\n      </defs>\n      <path fill=\"none\" stroke=\"url(#gradient-stroke)\" stroke-linecap=\"round\" d=\"M69.999,593.999 C69.999,593.999 298.561,951.387 969.834,1076.048 C1349.225,1146.505 1806.166,1017.950 2049.070,812.382 C2266.344,606.597 2316.852,418.343 2296.857,293.851 C2282.391,203.788 2216.549,120.999 2133.444,89.105 C2050.340,57.209 1947.838,60.909 1853.363,133.783 C1758.887,206.658 1594.407,474.022 1643.491,789.205 C1695.895,1125.714 2013.850,1520.775 2385.694,1673.212\"></path>\n    </svg>\n  </div>\n\n  <section class=\"section home-section home-work\">\n    <div class=\"section__inner\">\n      <h2 class=\"section__heading\">\n        <span class=\"section__heading-en js-inview slide-up\">WORK&PERSON</span>\n        <span class=\"section__heading-ja\">仕事・人を知る</span>\n      </h2>\n      <p class=\"section__text\">ＡＧＳの職種をご紹介。仕事の内容はもちろん、それぞれの仕事で感じられる魅力もご紹介します。</p>\n      <div class=\"splide js-slider-sp\">\n        <div class=\"splide__track\">\n          <ul class=\"splide__list home-work-list hover-color\">\n            <li class=\"splide__slide home-work-list__item\">\n              <a href=\"/saiyou/new/business/infrastructure-engineer/\">\n                <figure class=\"home-work-list__image\">\n                  <picture>\n                    <source srcset=\"/saiyou/assets/img/new/home/img_work01@sp.jpg\" media=\"(max-width: 768px)\">\n                    <img src=\"/saiyou/assets/img/new/home/img_work01.jpg\" alt=\"インフラエンジニアの仕事\" loading=\"lazy\" decoding=\"async\" fetchpriority=\"auto\" width=\"400\" height=\"260\">\n                  </picture>\n                </figure>\n                <div class=\"home-work-list__content\">\n                  <h3 class=\"home-work-list__heading hover-color__text\">インフラエンジニアの仕事<span class=\"component-arrow\"></span></h3>\n                </div>\n              </a>\n            </li>\n            <li class=\"splide__slide home-work-list__item\">\n              <a href=\"/saiyou/new/business/system-engineer/\">\n                <figure class=\"home-work-list__image\">\n                  <img src=\"/saiyou/assets/img/new/home/img_work02.jpg\" alt=\"システムエンジニアの仕事\" loading=\"lazy\" decoding=\"async\" fetchpriority=\"auto\" width=\"400\" height=\"260\">\n                </figure>\n                <div class=\"home-work-list__content\">\n                  <h3 class=\"home-work-list__heading hover-color__text\">システムエンジニアの仕事<span class=\"component-arrow\"></span></h3>\n                </div>\n              </a>\n            </li>\n            <li class=\"splide__slide home-work-list__item\">\n              <a href=\"/saiyou/new/business/sales/\">\n                <figure class=\"home-work-list__image\">\n                  <img src=\"/saiyou/assets/img/new/home/img_work03.jpg\" alt=\"営業の仕事\" loading=\"lazy\" decoding=\"async\" fetchpriority=\"auto\" width=\"400\" height=\"260\">\n                </figure>\n                <div class=\"home-work-list__content\">\n                  <h3 class=\"home-work-list__heading hover-color__text\">営業の仕事<span class=\"component-arrow\"></span></h3>\n                </div>\n              </a>\n            </li>\n          </ul>\n        </div>\n      </div>\n      <p class=\"component-button component-button--more\">\n        <a href=\"/saiyou/new/business/\">More</a>\n      </p>\n\n      <!--  オープン・カンパニー バナー-->\n      <div class=\"home-work-banner hover-color\">\n        <a href=\"/saiyou/new/open-company/\">\n          <h3 class=\"home-work-banner__heading hover-color__text\">\n            OPEN<br class=\"only-pc\">\n            COMPANY\n          </h3>\n          <div class=\"home-work-banner__content\">\n            <h4 class=\"home-work-banner__subheading\">オープン・カンパニー</h4>\n            <p class=\"home-work-banner__text\">ＡＧＳの仕事・働き方を<br>見て感じてみませんか？</p>\n          </div>\n          <figure class=\"home-work-banner__illust\">\n            <img src=\"/saiyou/assets/img/new/home/illst_work.svg\" alt=\"ＡＧＳの仕事を知る\" loading=\"lazy\" decoding=\"async\" fetchpriority=\"auto\" width=\"144\" height=\"149\">\n          </figure>\n          <span class=\"component-arrow component-arrow--white\"></span>\n        </a>\n      </div>\n\n    </div>\n  </section>\n\n  <section class=\"section home-section home-interview\">\n    <figure class=\"home-interview__image\">\n      <picture>\n        <source srcset=\"/saiyou/assets/img/new/home/img_interview@sp.jpg\" media=\"(max-width: 768px)\">\n        <img src=\"/saiyou/assets/img/new/home/img_interview.jpg\" alt=\"オフィスの風景\" loading=\"lazy\" decoding=\"async\" fetchpriority=\"auto\" width=\"1920\" height=\"500\">\n      </picture>\n    </figure>\n    <div class=\"home-interview__inner\">\n      <div class=\"section__inner\">\n        <h2 class=\"section__heading\">\n          <span class=\"section__heading-en js-inview slide-up\">INTERVIEW</span>\n          <span class=\"section__heading-ja\">社員インタビュー</span>\n        </h2>\n        <p class=\"section__text\">先輩社員が語る「本当のＡＧＳ」をご紹介します。</p>\n        <div class=\"splide js-slider-sp\">\n          <div class=\"splide__track\">\n            <ul class=\"splide__list home-interview-list hover-color\">\n            \n                <li class=\"splide__slide home-interview-list__item\" data-join=\"new\">\n                    <a href=\"/saiyou/new/interview/detail15/\">\n                        <figure class=\"home-interview-list__image\">\n                            <picture>\n                              \n                                <source srcset=\"/saiyou/assets/img/interview15_thum.png\" media=\"(max-width: 768px)\">\n                                <img src=\"/saiyou/assets/img/interview15_thum.png\" alt=\"\" loading=\"lazy\" decoding=\"async\" fetchpriority=\"auto\" width=\"380\" height=\"460\">\n                              \n                            </picture>\n                            <figcaption>インフラエンジニア</figcaption>\n                        </figure>\n                        <div class=\"home-interview-list__content\">\n                            <h3 class=\"home-interview-list__heading hover-color__text\">特殊な環境でのインフラ構築。試行錯誤の先に見えた、壁を突破する確かな手ごたえ</h3>\n     