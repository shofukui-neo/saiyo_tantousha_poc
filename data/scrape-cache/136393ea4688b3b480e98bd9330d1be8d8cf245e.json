"460\">\n                              \n                            </picture>\n                            <figcaption>営業</figcaption>\n                        </figure>\n                        <div class=\"home-interview-list__content\">\n                            <h3 class=\"home-interview-list__heading hover-color__text\">“自分らしさ”を引き出す面接から始まった──風通し抜群のＡＧＳで挑む法人営業の第一歩</h3>\n                            <p class=\"home-interview-list__text hover-color__text\">2023年 新卒入社</p>\n                        </div>\n\n                    </a>\n                </li>\n              \n            </ul>\n          </div>\n        </div>\n        <p class=\"component-button component-button--more\">\n          <a href=\"/saiyou/new/interview/\">More</a>\n        </p>\n        <div class=\"home-interview-talk hover-color\">\n          <a href=\"/saiyou/new/business/discussion/\">\n            <figure class=\"home-interview-talk__image\">\n              <img src=\"/saiyou/assets/img/new/home/img_interview_talk.jpg\" alt=\"ＡＧＳの仕事を知る\" loading=\"lazy\" decoding=\"async\" fetchpriority=\"auto\" width=\"570\" height=\"292\">\n            </figure>\n            <div class=\"home-interview-talk__content\">\n              <h3 class=\"home-interview-talk__heading\">CROSS TALK</h3>\n              <h4 class=\"home-interview-talk__subheading hover-color__text\">\n                <small>ＡＧＳで働く人のホンネ</small><br>\n                若手×中堅社員の座談会\n              </h4>\n              <p class=\"home-interview-talk__text\">入社の決め手や仕事のやりがい、働き方などを、今後のＡＧＳを担うメンバーが本音で語ります。</p>\n            </div>\n          </a>\n        </div>\n      </div>\n      <div class=\"home-interview-wave\">\n        <svg class=\"wave-animation\" viewBox=\"0 0 1920 699\" preserveAspectRatio=\"xMidYMid slice\">\n          <defs>\n            <linearGradient id=\"wave-gradient\" x1=\"100%\" x2=\"0%\" y1=\"0%\" y2=\"0%\">\n              <stop offset=\"0%\" stop-color=\"#d98b10\"></stop>\n              <stop offset=\"50%\" stop-color=\"#