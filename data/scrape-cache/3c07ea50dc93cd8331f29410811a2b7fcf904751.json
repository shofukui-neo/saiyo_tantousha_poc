nt/themes/pasco/assets/js/jquery.min.js?ver=3.7.1\" id=\"jquery-js\"></script>\n<link rel=\"icon\" href=\"https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/01/cropped-favicon-32x32.png\" sizes=\"32x32\" />\n<link rel=\"icon\" href=\"https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/01/cropped-favicon-192x192.png\" sizes=\"192x192\" />\n<link rel=\"apple-touch-icon\" href=\"https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/01/cropped-favicon-180x180.png\" />\n<meta name=\"msapplication-TileImage\" content=\"https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/01/cropped-favicon-270x270.png\" />\n</script>\r\n</head>\r\n<body>\r\n\t<header id=\"header\" class=\"p-header\">\r\n    <div class=\"p-header__wrap\">\r\n        <a href=\"https://www.pasconet.co.jp/recruit/\" class=\"p-header__logo hover\">\r\n            <span class=\"p-header__logo-img\">\r\n                <img src=\"https://www.pasconet.co.jp/recruit/wp-content/themes/pasco/assets/images/common/pasco_logo.svg\" alt=\"Pasco\">\r\n            </span>\r\n            <span class=\"p-header__logo-txt\">新卒<br class=\"sp\">採用サイト</span>\r\n        </a>\r\n        <div class=\"p-header__right\">\r\n            <h1 class=\"p-header__ttl\">敷島製パン株式会社 Pascoの大学生向けの新卒採用サイト「若いうちから自分主導でさまざまなことに挑戦できる環境。」ページ</h1>\r\n            <div class=\"p-header__main\">\r\n                <nav class=\"p-header__nav\">\r\n                    <a href=\"https://www.pasconet.co.jp/recruit/details/\" class=\"p-header__btn btn-hover\">募集要項<span class=\"icon icon-info\"></span></a>\r\n                    <a href=\"https://job.axol.jp/bx/s/pasco_27/entry\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"p-header__btn p-header__btn--info btn-hover\">27年卒 ENTRY<span class=\"icon icon-entry\"></span></a>\r\n                    <a href=\"https://axol.jp/zw/s/pasco_28/entry/agreement\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"p-header__btn p-header__btn--info btn-hover\">28年卒 ENTRY<span class=\"icon icon-entry\"></span></a>\r\n                </nav>\r\n                <a href=\"https://www.instagram.com/pasco_saiyo/\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"p-header__ins\"><img src=\"https://www.pasconet.co.jp/recruit/wp-content/themes/pasco/assets/images/common/icn_ins.svg\" alt=\"instagram\"></a>\r\n                <div class=\"hamburger-box js-show-menu\" role=\"button\" aria-label=\"Menu\" aria-expanded=\"false\"><span class=\"hamburger-inner\"></span></div>\r\n            </div>\r\n        </div>\r\n    </div>\r\n\r\n    <div class=\"p-header__wrap p-header__wrap--fixed\">\r\n        <a href=\"https://www.pasconet.co.jp/recruit/\" class=\"p-header__logo hover\">\r\n            <span class=\"p-header__logo-img\">\r\n                <img src=\"https://www.pasconet.co.jp/recruit/wp-content/themes/pasco/assets/images/common/pasco_logo.svg\" alt=\"Pasco\">\r\n            </span>\r\n            <span class=\"p-header__logo-txt\">新卒<br>採用サイト</span>\r\n        </a>\r\n        <div class=\"p-header__right\">\r\n            <div class=\"p-header__main\">\r\n                <nav class=\"p-header__nav\">\r\n                    <a href=\"https://www.pasconet.co.jp/recruit/details/\" class=\"p-header__btn btn-hover\">募集要項<span class=\"icon icon-info\"></span></a>\r\n                    <a href=\"https://job.axol.jp/bx/s/pasco_27/entry\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"p-header__btn p-header__btn--info btn-hover\">27年卒 ENTRY<span class=\"icon icon-entry\"></span></a>\r\n                    <a href=\"https://axol.jp/zw/s/pasco_28/entry/agreement\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"p-header__btn p-header__btn--info btn-hover\">28年卒 ENTRY<span class=\"icon icon-entry\"></span></a>\r\n                </nav>\r\n                <a href=\"https://www.instagram.com/pasco_saiyo/\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"p-header__ins\"><img src=\"https://www.pasconet.co.jp/recruit/wp-content/themes/pasco/assets/images/common/icn_ins.svg\" alt=\"instagram\"></a>\r\n            </div>\r\n        </div>\r\n    </div>\r\n    <div class=\"hamburger-box hamburger-box--single js-show-menu\" role=\"button\" aria-label=\"Menu\" aria-expanded=\"false\"><span class=\"hamburger-inner\"></span></div>\r\n\r\n    <div class=\"global-nav\">\r\n    <div class=\"global-nav__wrap\">\r\n        <nav class=\"global-nav__group\">\r\n            <ul class=\"nav-list\">\r\n                <li class=\"nav-item\">\r\n                    <a href=\"https://www.pasconet.co.jp/recruit/\" class=\"nav-link\">\r\n                        <span class=\"nav-link__ttl\">Top</span>\r\n                        <span class=\"nav-link__sub\">採用ページトップ</span>\r\n                    </a>\r\n                </li>\r\n                <li class=\"nav-item\">\r\n                    <a href=\"https://www.pasconet.co.jp/recruit/news/\" class=\"nav-link\">\r\n                        <span class=\"nav-link__ttl\">News</span>\r\n                        <span class=\"nav-link__sub\">お知らせ</span>\r\n                    </a>\r\n                </li>\r\n                <li class=\"nav-item\">\r\n                    <a href=\"https://www.pasconet.co.jp/recruit/company/\" class=\"nav-link\">\r\n                        <span class=\"nav-link__ttl\">Company</span>\r\n                        <span class=\"nav-link__sub\">会社概要&<br class=\"sp\">社長メッセージ</span>\r\n                    </a>\r\n                </li>\r\n                <li class=\"nav-item\">\r\n                    <a href=\"https://www.pasconet.co.jp/recruit/data/\" class=\"nav-link\">\r\n                        <span class=\"nav-link__ttl\">Data</span>\r\n                        <span class=\"nav-link__sub\">数字で見るPasco</span>\r\n                    </a>\r\n                </li>\r\n                <li class=\"nav-item\">\r\n                    <a href=\"https://www.pasconet.co.jp/recruit/interview/\" class=\"nav-link\">\r\n                        <span class=\"nav-link__ttl\">Interview</span>\r\n                        <span class=\"nav-link__sub\">社員インタビュー</span>\r\n                    </a>\r\n                </li>\r\n            </ul>\r\n            <ul class=\"nav-list\">\r\n                <li class=\"nav-item\">\r\n                    <a href=\"https://www.pasconet.co.jp/recruit/discussion/\" class=\"nav-link\">\r\n                        <span class=\"nav-link__ttl\">Discussion</span>\r\n                        <span class=\"nav-link__sub\">社員対談</span>\r\n                    </a>\r\n                </li>\r\n                <li class=\"nav-item\">\r\n                    <a href=\"https://www.pasconet.co.jp/recruit/culture/\" class=\"nav-link\">\r\n                        <span class=\"nav-link__ttl\">Culture</span>\r\n                        <span class=\"nav-link__sub\">企業文化＆働く環境</span>\r\n                    </a>\r\n                </li>\r\n                <li class=\"nav-item\">\r\n                    <a href=\"https://www.pasconet.co.jp/recruit/career/\" class=\"nav-link\">\r\n                        <span class=\"nav-link__ttl\">Career</span>\r\n                        <span class=\"nav-link__sub\">教育・研修制度＆<br class=\"sp\">キャリアパス</span>\r\n                    </a>\r\n                </li>\r\n                <li class=\"nav-item\">\r\n                    <a href=\"https://www.pasconet.co.jp/recruit/business/\" class=\"nav-link\">\r\n                        <span class=\"nav-link__ttl\">Business</span>\r\n                        <span class=\"nav-link__sub\">事業内容</span>\r\n                    </a>\r\n                </li>\r\n                <li class=\"nav-item\">\r\n                    <a href=\"https://www.pasconet.co.jp/recruit/qa/\" class=\"nav-link\">\r\n                        <span class=\"nav-link__ttl\">Q&A</span>\r\n                        <span class=\"nav-link__sub\">よくある質問</span>\r\n                    </a>\r\n                </li>\r\n            </ul>\r\n        </nav>\r\n        <nav class=\"global-nav__other\">\r\n            <a href=\"https://www.pasconet.co.jp/recruit/details/\" class=\"btn btn-sub btn-hover\">募集要項・<br class=\"pc\">採用スケジュール<span class=\"icon icon-info\"></span></a>\r\n            <a href=\"https://job.axol.jp/bx/s/pasco_27/entry/\" class=\"btn btn-primary-reverse btn-hover\" target=\"_blank\">27年卒 ENTRY<span class=\"icon icon-entry\"></span></a>\r\n            <a href=\"https://axol.jp/zw/s/pasco_28/entry/agreement\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"btn btn-primary-reverse btn-hover\">28年卒 ENTRY<span class=\"icon icon-entry\"></span></a>\r\n        </nav>\r\n    </div>\r\n</div></header>\r\n\r\n<ul class=\"nav-fixed sp\">\r\n    <li><a href=\"https://www.pasconet.co.jp/recruit/details/\" class=\"btn btn-sub btn-hover\">募集要項<span class=\"icon icon-info\"></span></a></li>\r\n    <li><a href=\"https://job.axol.jp/bx/s/pasco_27/entry\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"btn btn-primary btn-hover\">27年卒 ENTRY<span class=\"icon icon-entry\"></span></a></li>\r\n    <li><a href=\"https://axol.jp/zw/s/pasco_28/entry/agreement\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"btn btn-primary btn-hover\">28年卒 ENTRY<span class=\"icon icon-entry\"></span></a></li>\r\n</ul><div class=\"c-mv\">\r\n    <div class=\"c-mv__wrap\">\r\n        <div class=\"c-mv__content\">\r\n            <h2 class=\"c-mv__page\">Interview</h2>\r\n            <p class=\"c-mv__sub\">社員インタビュー</p>\r\n        </div>\r\n        <div class=\"c-breadcrumb\">\r\n            <ul class=\"c-breadcrumb__list\">\r\n                <li class=\"c-breadcrumb__item hover\"><a href=\"https://www.pasconet.co.jp/recruit/\">ホーム</a></li>\r\n                <li class=\"c-breadcrumb__item hover\"><a href=\"https://www.pasconet.co.jp/recruit/interview/\">社員インタビュー</a></li>\r\n                <li class=\"c-breadcrumb__item\">若いうちから自分主導でさまざまなことに挑戦できる環境。</li>\r\n            </ul>\r\n        </div>\r\n    </div>\r\n</div>\r\n<div class=\"inner\">\r\n    <div class=\"c-single\">\r\n        <div class=\"c-single__media\">\r\n                        <div class=\"c-single__media-img\">\r\n                                    <p class=\"c-single__media-cate\">営業</p>\r\n                                \r\n                <img width=\"1008\" height=\"1024\" src=\"https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A8023-scaled-e1772094113520-1008x1024.jpg\" class=\"attachment-large size-large wp-post-image\" alt=\"\" decoding=\"async\" fetchpriority=\"high\" srcset=\"https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A8023-scaled-e1772094113520-1008x1024.jpg 1008w, https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A8023-scaled-e1772094113520-295x300.jpg 295w, https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A8023-scaled-e1772094113520-768x780.jpg 768w, https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A8023-scaled-e1772094113520-1512x1536.jpg 1512w, https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A8023-scaled-e1772094113520.jpg 1707w\" sizes=\"(max-width: 1008px) 100vw, 1008px\" />            </div>\r\n                        \r\n            <div class=\"c-single__media-body\">\r\n                                <p class=\"btn-basic\">2022年入社 / 冷食営業</p>\r\n                \r\n                <p class=\"c-single__media-ttl\">若いうちから自分主導でさまざまなことに挑戦できる環境。</p>\r\n                <p class=\"c-single__media-name\">岩井</p>\r\n            </div>\r\n        </div>\r\n\r\n        \r\n                \r\n        <div class=\"detail-body c-txt\"><div class=\"box\">\n<p>【略歴】</p>\n<p>2022年4月：営業職入社</p>\n<p>&nbsp;</p>\n<p>【好きな商品】</p>\n<p>1位：国産小麦と米粉のロール</p>\n<p>2位：なごにゃんクロ</p>\n<p>3位：国産小麦 塩バターパン　</p>\n</div>\n<h3>Q：入社の理由は？<br />\nA：冒険しながら食と関わることができるところに魅力を感じて入社を決意。</h3>\n<p>実家の両親が飲食店を経営しており、学生時代は、学校から帰って毎日お店のカレーを食べていました。ただ、毎日同じカレーでは飽きるため、父がいろんなアレンジを加えた「パパスペシャル」をつくってくれ、同じ食べ物でも飽きないようさまざまな工夫ができるのだと知りました。その後、自分でも家族の食事やお弁当を進んでつくるようになり、食を通じて人を笑顔にする仕事、自分自身も楽しんで冒険できる仕事を志すようになりました。</p>\n<p>その点、Pascoはパンの冷凍生地を提供しており、冷凍生地をベースに食事にもおやつにもアレンジできるレシピ提案の仕事内容が自分にぴったりだと感じました。</p>\n<p>また、パンメーカーの中でも健康志向商品が強いところに惹かれました。私は食べることが好きですが、過去には体質に合わないものを食べて肌荒れしたり、太ってしまった時期があり、なるべく負担のないものを身体に取り入れたいと考えていました。Pascoは国産小麦や低糖質のパンにも注力しており、材料に制限がある中でも風味や食感などの工夫を感じる商品が多いため、「働くならPascoしかない」と思っていました。</p>\n<h3>Q：仕事の内容は？<br />\nA：外食チェーンへの商品の提案。</h3>\n<div class=\"img-with-txt\">\n<div class=\"img-with-txt__content\">\n<div><img decoding=\"async\" class=\"alignnone size-full wp-image-249\" src=\"https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A8242.jpg\" alt=\"\" width=\"2322\" height=\"1600\" srcset=\"https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A8242.jpg 2322w, https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A8242-300x207.jpg 300w, https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A8242-1024x706.jpg 1024w, https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A8242-768x529.jpg 768w, https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A8242-1536x1058.jpg 1536w, https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A8242-2048x1411.jpg 2048w\" sizes=\"(max-width: 2322px) 100vw, 2322px\" /></div>\n<div>　</div>\n<p>主な仕事内容は、パンの冷凍生地を活用してお取引先様へ提案を行い、採用販売に向けてアプローチとフォローを行うことです。業務を細分化すると、商品の試食提案会の実施、PB*¹商品開発のフォロー、在庫管理等の社内調整があります。</p>\n<p>&nbsp;</p>\n<p>冷食営業では、毎月の新商品や既存の冷凍生地を加工し、お取引先様にあわせて提案することが一般的ですが、私が担当するお取引先様はさまざまな外食チェーンを展開されており、レストラン、カフェ、テイクアウト専門店など業態が異なります。そのため、それぞれに合った商品をゼロから企画・開発・提案することが求められます。PB*¹商品の提案にあたっては、既存販売品についてのお困りごとや、描いている販売商品の方針についてヒアリングを行います。例えば、「季節によってラインアップを変えたい」「評判に合わせてリニューアルしたい」といった要望があれば、当社でその要望に合致した商品を提案すべく、開発部門と協力して進めていきます。『提案→フィードバック→改良』を繰り返して理想に近づけていく地道な仕事です。</p>\n<p>&nbsp;</p>\n<p>冷凍生地の提案では、実際の作業手順も重視されます。パン生地を触ったことのない人でも『簡単に・素早く・きれいに』おいしいパンが焼ける手順になっているかどうか、何度もテストしてレシピをつくり込んで提案に望むようにしています。</p>\n<p>&nbsp;</p>\n<p>また、在庫調整も大切な業務の一つです。年間通して使っていただいている商品もあれば、季節ごとに入れ替わる商品もあるため、常に注文数量の確認を徹底しています。さまざまな業態に複数の商品が販売開始したり終売したりと目まぐるしいため、スケジュール帳にしっかり書き込み肌身離さず持ち歩いています。</p>\n<p>※1・・・小売店などが自社ブランドでつくって販売するオリジナル商品です。</p>\n<h3>Q：冷食営業で大切なことは？<br />\nA：深堀りしてすり合わせることと、スケジュール管理。</h3>\n<p>お取引先様へのヒアリングの際は、「ポイントかもしれない」と思うことはすべて聞き取り、商品の設計に盛り込むようにしています。例えば、「やわらかいパン」を希望されていても、ふんわり感を重視しているのか、しっとり感が感じられる方が良いのか分かりません。お取引先様が話していないことでも、詳細が定まっていないと開発部門に混乱を招く恐れがあるため、お話を深掘りして認識をすり合わせてから進めることを徹底しています。</p>\n<p>&nbsp;</p>\n<p>また、商品の発売には、商品提案だけではなく、納品スケジュールの調整などやることが盛りだくさんです。優先順位をつけながら、頭をフル回転し発売に向けて取り組んでいます。</p>\n<p>&nbsp;</p>\n<p>こう伝えると大変そうに見えると思いますが、商品の開発のために市場調査を行ったり、自由な発想でアイデアをどんどん取り入れられることはとても楽しいです。まるで料理している感覚で商品提案に取り組めるだけでなく、自分のアイデアが採用されて反響があったときは、この上ないやりがいを感じます。</p>\n<p>食にこだわりを持って、楽しみながら挑戦できる人に向いている仕事だと思います。トレンドを掴むために雑誌やSNSをチェックしたり、実際の店舗を巡って今まで見たことのないパンを知れるのも楽しいですね。</p>\n<h3>Q：どんな会社？<br />\nA：若いうちから自分主導でさまざまなことに挑戦できる環境。</h3>\n<div>\n<div class=\"img-with-txt\">\n<div class=\"img-with-txt__content\">\n<div><img decoding=\"async\" class=\"alignnone size-full wp-image-248\" src=\"https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A8051-scaled.jpg\" alt=\"\" width=\"2560\" height=\"1707\" srcset=\"https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A8051-scaled.jpg 2560w, https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A8051-300x200.jpg 300w, https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A8051-1024x683.jpg 1024w, https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A8051-768x512.jpg 768w, https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A8051-1536x1024.jpg 1536w, https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A8051-2048x1365.jpg 2048w\" sizes=\"(max-width: 2560px) 100vw, 2560px\" /></div>\n<div>　</div>\n<p>若いうちから自分主導で企画し、挑戦できるところはPascoの良いところだと思います。新入社員のとき、先輩の商談に同行した際には、「1年目だから見るだけ」ではなく、先輩と一緒に企画・提案する機会をいただきました。そのとき、上司や先輩方は『完璧じゃなくて大丈夫、難しかったらすぐ助けるから！』という雰囲気で見守ってくれたため、自分のやりたいことに挑戦しやすく、心強かったです。</p>\n<p>&nbsp;</p>\n<p>また、さまざまなお取引先様があり、興味がある分野であれば担当外でも提案の機会をいただけます。お取引先様の要望に沿っていれば、企画を自由に設計しても問題ありません。社内でのコンテストもあり、さまざまな形で挑戦の機会が設けられています。</p>\n<p>&nbsp;</p>\n<p>こんなに幅広く挑戦できるのは、誰かのために一肌脱げる、面倒見の良い人がPascoに多いからかもしれません。わからないことを正直に「わからない！」と言える空気で、自分が悩んでいると上司や先輩がちゃんと助けてくれるため、安心して働けます。</p>\n<h3>A：今後の目標は？<br />\nQ：製パンの知識を深めて、早く思いどおりに解決したい。</h3>\n<p>製パンの専門知識を身につけ、パンについて今よりもっと詳しくなりたいです。</p>\n<p>商品提案では、求めている食感や味にうまくたどり着けないこともあります。私は大学で栄養学や食品の酵素の働きについて専攻していないため、開発部門のメンバーよりも知識不足で、「もっとパンについて詳しい知識を身につけておけば…」と悔しい思いをする場面があります。</p>\n<p>幸い、Pascoは製パン研修や検定試験などサポート体制が豊富に揃っているので、それらを有効活用して思いどおりの食感や味を反映させられるような学びと経験を積みたいと考えています。次のステップを目指して、成長できるチャレンジを続けていきたいと思います。</p>\n</div>\n</div>\n</div>\n</div>\n</div>\n</div>\r\n    </div>\r\n</div>\r\n<div class=\"container\">\r\n        <nav class=\"c-back-nav\">\r\n                    <a href=\"https://www.pasconet.co.jp/recruit/production/p201/\" class=\"c-back-nav__arrow c-back-nav__arrow--prev\"></a>\r\n        \r\n        <a href=\"https://www.pasconet.co.jp/recruit/interview/\" class=\"btn btn-sub c-back-nav__button\">一覧へ戻る</a>\r\n\r\n                    <a href=\"https://www.pasconet.co.jp/recruit/sales/p198/\" class=\"c-back-nav__arrow c-back-nav__arrow--next\"></a>\r\n            </nav>\r\n\r\n        <nav class=\"c-category-filter\">\r\n        <ul class=\"c-category-filter__list\">\r\n            <li><a href=\"https://www.pasconet.co.jp/recruit/interview/\" class=\"btn-basic\">すべて</a></li>\r\n                        <li><a href=\"https://www.pasconet.co.jp/recruit/interview/engineer/\" class=\"btn-basic\">エンジニア</a></li>\r\n                        <li><a href=\"https://www.pasconet.co.jp/recruit/interview/sales/\" class=\"btn-basic\">営業</a></li>\r\n                        <li><a href=\"https://www.pasconet.co.jp/recruit/interview/production/\" class=\"btn-basic\">生産</a></li>\r\n                    </ul>\r\n    </nav>\r\n    </div>\r\n\r\n<footer class=\"p-footer\">\r\n    <div class=\"inner\">\r\n        <div class=\"footer-entry\">\r\n            <h3 class=\"footer-entry__ttl font-en\">Entry!</h3>\r\n            <p class=\"footer-entry__txt\">Pascoでは、<br class=\"sp\">一緒に働く社員を募集しています。<br>\r\n            まだ夢がはっきりしていなくて