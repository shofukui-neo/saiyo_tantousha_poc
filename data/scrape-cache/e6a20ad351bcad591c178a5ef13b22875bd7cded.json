                       </dd>\n                  </div>\n                                    \n                                </dl>\n              <div class=\"t-r\"><a href=\"https://www.chikuma.co.jp/news/\" class=\"btn-s arrow\">ALL</a></div>\n          </div>\n          \n          \n                    \n      </div>\n  </div>\n</div><!-- /fadeIn -->\n\n<!-- footer -->\n<footer class=\"footer\">\n  <div class=\"footer__contact\">\n    <a href=\"/inquiry/form.html\" class=\"btn btn-grade\"><b>お問い合わせ</b><small>CONTACT</small></a>\n  </div>\n  <div class=\"footer__area\">\n    <div class=\"footer__inner\">\n      <h2 class=\"company\">株式会社チクマ</h2>\n      <nav class=\"footer-nav\">\n        <ul class=\"footer-nav__items\">\n          <li class=\"footer-nav__item\"><a href=\"/\">TOP</a></li>\n          <li class=\"footer-nav__item\">\n            <span>企業情報</span>\n            <nav class=\"\">\n              <ul class=\"\">\n                <li class=\"\"><a href=\"/company/index.html\">ご挨拶</a></li>\n                <li class=\"\"><a href=\"/company/outline.html\">企業概要</a></li>\n                <li class=\"\"><a href=\"/company/history.html\">チクマの歴史</a></li>\n                <li class=\"\"><a href=\"/company/certification.html\">各種認証取得</a></li>\n              </ul>\n            </nav>\n          </li>\n          <li class=\"footer-nav__item\">\n            <span>事業内容</span>\n            <nav class=\"\">\n              <ul class=\"\">\n                <li class=\"\"><a href=\"/uniform/\" target=\"_blank\">オリジナルユニフォーム<i class=\"fas fa-external-link-alt\"></i></a></li>\n                <li class=\"\"><a href=\"/business/campus.html\">学生服</a></li>\n                <li class=\"\"><a href=\"/business/alphapier.html\">既製ユニフォーム</a></li>\n                <li class=\"\"><a href=\"https://chikuma-no-smafa.com/st/unikanri/\" target=\"_blank\">チクマノH.U.B<i class=\"fas fa-external-link-alt\"></i></a></li>\n                <li class=\"\"><a href=\"https://chikuma-no-loop.com/\" tar