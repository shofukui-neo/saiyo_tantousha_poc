tant;}\n.wp-block-navigation a:where(:not(.wp-element-button)){color: inherit;}\n:where(.wp-block-post-template.is-layout-flex){gap: 1.25em;}:where(.wp-block-post-template.is-layout-grid){gap: 1.25em;}\n:where(.wp-block-columns.is-layout-flex){gap: 2em;}:where(.wp-block-columns.is-layout-grid){gap: 2em;}\n.wp-block-pullquote{font-size: 1.5em;line-height: 1.6;}\n</style>\n</head>\n<body class=\"top\">\n\n<div id=\"main-contents\">\n\n<!-- header -->\n<header>\n  <h1 class=\"logo\">\n    <a href=\"/\">\n      <picture class=\"p-main-visual__img\">\n        <source srcset=\"/common/img/logo_sp.svg\" media=\"(max-width: 1023px)\">\n        <img src=\"/common/img/logo.svg\" alt=\"株式会社チクマ\">\n      </picture>\n    </a>\n  </h1>\n  <div class=\"lang-sp\">\n      <a href=\"/ch/\">中文</a>\n      <a href=\"/en/\">EN</a>\n  </div>\n  <div id=\"nav-btn\" class=\"nav-btn\">\n      <span></span>\n      <span></span>\n      <span></span>\n  </div>\n  <nav class=\"nav parents-nav\">\n      <ul class=\"nav__parents\">\n        <li class=\"nav__parent\"><a href=\"/\">TOP</a></li>\n        <li class=\"nav__parent\">\n          <a href=\"/company/outline.html\">企業情報</a>\n          <nav class=\"nav children-nav\">\n            <ul class=\"nav__children\">\n              <li class=\"nav__child\"><a href=\"/company/index.html\">ご挨拶</a></li>\n              <li class=\"nav__child\"><a href=\"/company/outline.html\">企業概要</a></li>\n              <li class=\"nav__child\"><a href=\"/company/history.html\">チクマの歴史</a></li>\n              <li class=\"nav__child\"><a href=\"/company/certification.html\">各種認証取得</a></li>\n            </ul>\n          </nav>\n        </li>\n        <li class=\"nav__parent\">\n          <a href=\"#\">事業内容</a>\n          <nav class=\"children-nav\">\n            <ul class=\"nav nav__children\">\n              <li class=\"nav__child\"><a href=\"/uniform/\" target=\"_blank\">オリジナルユニフォーム<i class=\"fas fa-external-link-alt\"></i></a></li>\n              <li class=\"nav__child\"><a href=\"/business/campus.html\">学生服</a></li>\n              <li class=\"nav__child\"><a href=\"/business/alphapier.html\">既製ユニフォーム</a></li>\n              <li class=\"nav__child nav__child--hidden\"><a href=\"#\"></a></li>\n              <li class=\"nav__child\"><a href=\"https://chikuma-no-smafa.com/st/unikanri/\" target=\"_blank\">チクマノH.U.B<i class=\"fas fa-external-link-alt\"></i></a></li>\n              <li class=\"nav__child\"><a href=\"https://chikuma-no-loop.com/\" target=\"_blank\">チクマノループ<i class=\"fas fa-external-link-alt\"></i><br>（リサイクル）</a></li>\n              <li class=\"nav__child\"><a href=\"https://chikuma-no-smafa.com/\" target=\"_blank\">チクマノスマファ<i class=\"fas fa-external-link-alt\"></i><br>（電動ファン付きウェア）</a></li>\n              <li class=\"nav__child\"><a href=\"/business/overseas.html\">グローバルビジネス</a></li>\n              </ul>\n          </nav>\n        </li>\n        <li class=\"nav__parent\">\n          <a href=\"/csr/index.html\">サステナビリティ</a>\n          <nav class=\"nav children-nav\">\n            <ul class=\"nav__children\">\n              <li class=\"nav__child\"><a href=\"/csr/index.html\">CSRとSDGs</a></li>\n              <li class=\"nav__child\"><a href=\"https://saas.actibookone.com/content/detail?param=eyJjb250ZW50TnVtIjo0ODA1Mn0=&detailFlg=0&pNo=1\" target=\"_blank\">チクマとSDGs<i class=\"fas fa-external-link-alt\"></i></a></li>\n              <li class=\"nav__child\"><a href=\"/csr/basic-policy.html\">CSRガイドライン</a></li>\n              <li class=\"nav__child nav__child--hidden\"><a href=\"#\"></a></li>\n              <li class=\"nav__child\"><a href=\"/csr/environmental-office.html\">環境推進室</a></li>\n              <li class=\"nav__child\"><a href=\"/csr/environmental-policy.html\">環境方針</a></li>\n            </ul>\n          </nav>\n        </li>\n        <li class=\"nav__parent\">\n          <a href=\"/business/fukuiku.html\">服育とは</a>\n          <!-- <nav class=\"nav children-nav\">\n            <ul class=\"nav__children\">\n              <li class=\"nav__child\"><a href=\"/business/fukuiku.html\">服育とは</a></li>\n              <li class=\"nav__child\"><a href=\"/business/fukuiku.html#a\">健康・安全</a></li>\n              <li class=\"nav__child\"><a href=\"/business/fukuiku.html#b\">社会性</a></li>\n              <li class=\"nav__child\"><a href=\"/business/fukuiku.html#c\">国際性</a></li>\n            </ul>\n          </nav> -->\n        </li>\n        <li class=\"nav__parent\"><a href=\"/recruit/recruit.html\">採用情報</a></li>\n        <li class=\"nav__parent nav__parent--contact\"><a href=\"/inquiry/form.html\">お問い合わせ</a></li>\n        <li class=\"nav__parent sp-link\"><a href=\"/privacy/index.html\">プライバシーポリシー</a></li>\n        <li class=\"nav__parent sp-link\"><a href=\"/policy/index.html\">個人情報保護方針</a></li>\n        <li class=\"nav__parent nav__parent--end sp-link\">\n          <a href=\"/privacy/index.html#cookie\">クッキーポリシー</a>\n          <div class=\"nav__children lang\">\n            <a href=\"/ch/\">中文</a>\n            <a href=\"/en/\">EN</a>\n          </div>\n        </li>\n      </ul>\n      <div class=\"lang pc-only\">\n        <a href=\"/ch/\">中文</a>\n        <a href=\"/en/\">EN</a>\n      </div>\n  </nav>\n</header><!-- /header -->\n\n<div class=\"top-slide\">\n  <div class=\"slide\">\n    <img src=\"/img/kv7.jpg\" alt=\"\">\n  </div>\n  <div class=\"slide\">\n    <img src=\"/img/kv1.jpg\" alt=\"\">\n  </div>\n  <div class=\"slide\">\n    <img src=\"/img/kv2.jpg\" alt=\"\">\n  </div>\n  <div class=\"slide\">\n    <img src=\"/img/kv3.jpg\" alt=\"\">\n  </div>\n  <div class=\"slide\">\n    <img src=\"/img/kv4.jpg\" alt=\"\">\n  </div>\n  <div class=\"slide\">\n    <img src=\"/img/kv5.jpg\" alt=\"\">\n  </div>\n</div>\n\n<div class=\"fadeIn\">\n  <div class=\"bg-wrap business-wrap anniversary-wrap\">\n    <div class=\"anniversary-btn\"><a href=\"https://youtu.be/EkA6ppFS--U\" target=\"_blank\"><img src=\"/img/corporatemv_btn.jpg\" alt=\"\"></a></div>\n    <div class=\"inner inner--lg\">\n      <div class=\"block\">\n        <h2 class=\"title-kakko title-kakko--first\"><span><span><b>事業内容</b><small>BUSINESS</small></span></span></h2>\n        <ul class=\"c-card-list\">\n          <li class=\"c-card-list__item p-card\">\n            <a href=\"/uniform/\" target=\"_blank\">\n                <div class=\"p-card__img\"><img src=\"/img/business_01.jpg\" alt=\"オリジナルユニフォーム\"></div>\n                <div class=\"p-card__title\"><span>オリジナルユニフォーム<i class=\"fas fa-external-link-alt\"></i></span></div>\n                <p class=\"p-card__text\">ブランディング分析やマーケティングリサーチを実施し、企業理念を反映したオーダーメイドユニフォームを提案。企画、生産、納品、管理、リサイクルまで承ります。​</p>\n            </a>\n          </li>\n          <li class=\"c-card-list__item p-card\">\n            <a href=\"/business/campus.html\">\n                <div class=\"p-card__img\"><img src=\"/img/business_02.jpg\" alt=\"学生服\"></div>\n                <div class=\"p-card__title\"><span>学生服</span></div>\n                <p class=\"p-card__text\">学校のニーズを反映した新制服のデザイン提案から素材企画・製品販売まで、学生服に関わる様々な事業を展開。全国の販売店、学生服アパレルとのネットワークを生かした情報量と提案力が強みです。​</p>\n            </a>\n          </li>\n          <li class=\"c-card-list__item p-card\">\n            <a href=\"/business/alphapier.html\">\n                <div class=\"p-card__img\"><img src=\"/img/business_03.jpg\" alt=\"\"></div>\n                <div class=\"p-card__title\"><span>既製ユニフォーム</span></div>\n                <p class=\"p-card__text\">女性事務服『ALPHA PIER』『MARY QUANT』、イベント・インフォメーション系『U-FACTORY』、男女ペアウェア『The FELLOWS』などを全国へ販売。また、多様なシーンで活躍する働く人たちのためのユニフォームカタログをジャンル別に2種類発行しています。（年2回刷新）​</p>\n            </a>\n          </li>\n\n          <li class=\"c-card-list__item p-card\">\n            <a href=\"https://chikuma-no-smafa.com/st/unikanri/\" target=\"_blank\">\n                <div class=\"p-card__img\"><img src=\"/img/business_07.jpg\" alt=\"チクマノH.U.B\"></div>\n                <div class=\"p-card__title\"><span>チクマノH.U.B<i class=\"fas fa-external-link-alt\"></i></span></div>\n                <p class=\"p-card__text\">2008年以来、着実に進化してきたチクマの制服管理システム。WEB受発注システムとICタグ等の管理識別コードを組み合わせ、保管から出荷、リユース、リサイクルまで企業の制服管理の大幅な効率化を実現した【H.U.B】へとさらに進化しました。\n</p>\n            </a>\n          </li>\n\n          <li class=\"c-card-list__item p-card\">\n            <a href=\"https://chikuma-no-loop.com/\" target=\"_blank\">\n                <div class=\"p-card__img\"><img src=\"/img/business_04.jpg\" alt=\"チクマノループ（リサイクル）\"></div>\n                <div class=\"p-card__title\"><span>チクマノループ<i class=\"fas fa-external-link-alt\"></i><br><small>（リサイクル）</small></span></div>\n                <p class=\"p-card__text\">チクマでは「私達が携わった服を着る人達とのコミュニケーション」と「廃棄物のリサイクル」を大事な価値と捉えて、独自のバリューチェーンを構築。新しいステージでの服づくりを目指します。​</p>\n            </a>\n          </li>\n          <li class=\"c-card-list__item p-card\">\n            <a href=\"https://chikuma-no-smafa.com/\" target=\"_blank\">\n                <div class=\"p-card__img\"><img src=\"/img/business_06.jpg\" alt=\"チクマノスマファ（電動ファン付きウェア）\"></div>\n                <div class=\"p-card__title\"><span>チクマノスマファ<i class=\"fas fa-external-link-alt\"></i><br><small>（電動ファン付きウェア）</small></span></div>\n                <p class=\"p-card__text\">電動工具メーカー（株）マキタのファン&バッテリーと素材メーカー帝人フロンティア（株）の機能性素材を使用。二層内圧式構造（特許取得済み）で膨らみを抑えた動きやすくスマートな充電式ファン付ウエアです。​</p>\n            </a>\n          </li>\n          <li class=\"c-card-list__item p-card\">\n            <a href=\"/business/overseas.html\">\n                <div class=\"p-card__img\"><img src=\"/img/business_05.jpg\" alt=\"\"></div>\n                <div class=\"p-card__title\"><span>グローバルビジネス</span></div>\n                <p class=\"p-card__text\">海外取引はチクマの祖業です。国内生地メーカーと共同開発した新素材などを海外のアパレルに提供し、各国の素材を輸入。日本と世界のファッションをつなぎ、新たなトレンドを生むお手伝いをしていきます。​</p>\n            </a>\n          </li>\n        </ul>\n      </div>\n      <div class=\"block\">\n        <h2 class=\"title-kakko title-kakko--second\"><span><span><b>社会への取り組み</b><small>SOCIAL</small></span></span></h2>\n        <ul class=\"c-card-list\">\n          <li class=\"c-card-list__item p-card p-card--reverse\">\n            <a href=\"/business/fukuiku.html\">\n                <div class=\"p-card__img\"><img src=\"/img/social_01.jpg\" alt=\"服育\"></div>\n                <div class=\"p-card__title\"><span>服育</span></div>\n                <p class=\"p-card__text\">服には人を育てる力があるとチクマは考えます。環境問題、健康・安全、TPOやコミュニケーションなど、衣服は人の成長や生活と深い関わりがあります。2004年、衣服を通して心を育む『服育』を提唱しました。​</p>\n            </a>\n          </li>\n          <li class=\"c-card-list__item p-card p-card--reverse\">\n            <a href=\"https://saas.actibookone.com/content/detail?param=eyJjb250ZW50TnVtIjo0ODA1Mn0=&detailFlg=0&pNo=1\" target=\"_blank\">\n                <div class=\"p-card__img\"><img src=\"/img/social_02.jpg\" alt=\"SDGs\"></div>\n                <div class=\"p-card__title\"><span>チクマとSDGs<i class=\"fas fa-external-link-alt\"></i></span></div>\n                <p class=\"p-card__text\">衣服は誰にとっても身近で個人的なものであり、世界中の人や環境とつながるグローバルなものでもあります。地球環境や地球上で共に生きる私たちのことを考え、チクマが衣服でできることを進めていきます。​</p>\n            </a>\n          </li>\n        </ul>\n      </div>\n    </div>\n  </div>\n\n  <div class=\"section-news\">\n    <h2 class=\"title-kakko\"><span><span>NEWS &amp; TOPICS</span></span></h2>\n      <div class=\"inner news-wrap\">\n          <div class=\"news-area\">\n              <dl>\n                                    \n                                    <div>\n                      <dt>2026/06/19</dt>\n                      <dd>\n                                                    <a href=\"https://www.chikuma.co.jp/_wp/wp-content/uploads/2026/06/itentokyo202607.pdf\" class=\"a\" target=\"_blank\">東京支店移転のお知らせ（2026年7月21日より移転いたします）<i class=\"fas fa-external-link-alt\"></i></a>\n                                                    <span class=\"new\">New</span>\n                                                        \n                                                </dd>\n                  </div>\n                                    <div>\n                      <dt>2026/06/18</dt>\n                     