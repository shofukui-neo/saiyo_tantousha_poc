    <ul class=\"c-header-nav-sp-list02 js-header-sp-item__contents\">\r\n              <li><a href=\"/support/\">お客さまサポートトップ</a></li>\r\n              <li><a href=\"/support/faq/\">よくあるご質問</a></li>\r\n              <li>\r\n                <div>お問い合わせ・資料請求</div>\r\n                <ul class=\"c-header-nav-sp-list03\">\r\n                  <li><a href=\"https://qmnb.f.msgs.jp/webapp/form/26692_qmnb_1/index.do\" target=\"_blank\" rel=\"noopener\">ソリューション・製品に関するお問い合わせ</a></li>\r\n                  <li><a href=\"https://yagb.f.msgs.jp/webapp/form/21656_yagb_1/index.do\" target=\"_blank\" rel=\"noopener\">e-コレクト&reg;をご利用中の方のお問い合わせ</a></li>\r\n                  <li><a href=\"https://qmnb.f.msgs.jp/webapp/form/26692_qmnb_2/index.do\" target=\"_blank\" rel=\"noopener\">当社サービス以外のお問い合わせ</a></li>\r\n                  <li><a href=\"https://qmnb.f.msgs.jp/webapp/form/26692_qmnb_3/index.do\" target=\"_blank\" rel=\"noopener\">資料請求</a></li>\r\n                </ul>\r\n              </li>\r\n            </ul>\r\n          </li>\r\n          <li><a href=\"/strength/\">SGシステムの強み</a></li>\r\n          <li>\r\n            <button class=\"js-header-sp-item\" type=\"button\">採用情報</button>\r\n            <ul class=\"c-header-nav-sp-list02 js-header-sp-item__contents\">\r\n              <li><a href=\"/recruit/\">採用情報トップ</a></li>\r\n              <li><a href=\"/recruit/job/\">仕事を知る</a></li>\r\n              <li><a href=\"/recruit/people/\">人を知る</a></li>\r\n              <li><a href=\"/recruit/corporate/\">会社を知る</a></li>\r\n              <li><a href=\"/recruit/corporate/3min/\">数字で分かるSGシステム</a></li>\r\n              <li><a href=\"/recruit/guideline/\">募集要項</a></li>\r\n            </ul>\r\n          </li>\r\n          <li>\r\n            <button class=\"js-header-sp-item\" type=\"button\">企業情報</button>\r\n            <ul class=\"c-header-nav-sp-list02 js-header-sp-item__contents\">\r\n              <li><a href=\"/company/\">企業情報トップ</a></li>\r\n              <li><a href=\"/company/message/\">ごあいさつ</a></li>\r\n              <li><a href=\"/company/outline/\">会社概要</a></li>\r\n              <li><a href=\"/company/history/\">沿革</a></li>\r\n              <li><a href=\"/company/branch/\">事業所一覧</a></li>\r\n              <li><a href=\"/company/internal/\">内部統制基本方針</a></li>\r\n              <!--<li><a href=\"/company/faq/\">よくあるご質問</a></li>-->\r\n              <li><a href=\"https://www.sg-hldgs.co.jp/company/philosophy/\" target=\"_blank\" rel=\"noopener\">企業理念・行動憲章</a></li>\r\n            </ul>\r\n          </li>\r\n        </ul>\r\n      </div>\r\n      <div class=\"c-header-nav-sp__sub\">\r\n        <ul>\r\n          <li><a href=\"/service/e-collect/guide/\">e-コレクト&reg;のお申込</a></li>\r\n          <li><a href=\"https://www.e-service.sagawa-exp.co.jp/portal/do/login/show\" target=\"_blank\" rel=\"noopener\">スマートクラブログイン</a></li>\r\n        </ul>\r\n      </div>\r\n      <div class=\"c-header-nav-sp__contact\">\r\n        <a href=\"/support/#inquiry\">お問い合わせ</a>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</header>\r\n<div class=\"l-header__overlay\"></div>\n    <main class=\"l-main\">\n      <div class=\"recruit-header\">\r\n  <div class=\"recruit-header__inner\">\r\n    <div class=\"recruit-header__heading\">\r\n      <span>RECRUIT</span><span>SGシステムの採用情報</span>\r\n    </div>\r\n    <button class=\"recruit-header__menu\" type=\"button\"></button>\r\n    <div class=\"recruit-header__nav\">\r\n      <div>\r\n        <ul class=\"recruit-header__links\">\r\n          <li><a href=\"/recruit/\" class=\"recruit-header__item\" data-url=\"\"><span>トップ</span></a></li>\r\n          <li><a href=\"/recruit/corporate/\" class=\"recruit-header__item\" data-url=\"corporate\"><span>会社を知る</span></a></li>\r\n          <li><a href=\"/recruit/job/\" class=\"recruit-header__item\" data-url=\"job\"><span>仕事を知る</span></a></li>\r\n          <li><a href=\"/recruit/people/\" class=\"recruit-header__item\" data-url=\"people\"><span>人を知る</span></a></li>\r\n          <li><a href=\"/recruit/faq/\" class=\"recruit-header__item\" data-url=\"faq\"><span>よくあるご質問</span></a></li>\r\n        </ul>\r\n        <ul class=\"recruit-header__cta\">\r\n          <li><a href=\"https://job.mynavi.jp/27/pc/search/corp88148/outline.html\" target=\"_blank\" class=\"recruit-header__btn\"><span>新卒採用（マイナビ）</span></a></li>\r\n          <li><a href=\"https://jsd.jposting.net/sg-systems/\" target=\"_blank\" rel=\"noopener\" class=\"recruit-header__btn -career\"><span>中途採用</span></a></li>\r\n        </ul>\r\n      </div>\r\n    </div>\r\n  </div>\r\n  <div class=\"recruit-header__overlay\"></div>\r\n</div>\n            <div class=\"recruit-people-title\">\r\n        <div class=\"recruit-people-title__img\">\r\n          <img src=\"/assets/img/recruit/people/14/img_mv-pc.jpg\" alt=\"\" class=\"tb-pc:view\">\r\n          <img src=\"/assets/img/recruit/people/14/img_mv-sp.jpg\" alt=\"\" class=\"sp:view\">\r\n        </div>\r\n        <div class=\"recruit-people-title__contents\">\r\n          <div class=\"recruit-people-title__category\"><span>人を知る</span><span>エンジニア</span></div>\r\n          <h1 class=\"recruit-people-title__ttl\"><span>文系出身の私が、今では上流工程を担うSEに。</span><br><span>手厚い研修と温かい仲間が育ててくれました</span></h1>\r\n          <div class=\"recruit-people-title__person\">2019年入社・新卒（文系）　SI第1事業部 勘定系U</div>\r\n        </div>\r\n      </div>\r\n      <div class=\"recruit-block\">\r\n        <div class=\"recruit-block__inner u-pt-80 u-sp-pt-40\">\r\n          <div class=\"l-section\">\r\n            <div class=\"recruit-people-profile\">\r\n              <div class=\"recruit-people-profile__mv\">\r\n                <img src=\"/assets/img/recruit/people/14/img_01.jpg\" alt=\"\" loading=\"lazy\">\r\n              </div>\r\n              <div class=\"recruit-people-profile__contents\">\r\n                <div class=\"recruit-people-profile__category\">エンジニア</div>\r\n                <div class=\"recruit-people-profile__name\">宇山 ひな</div>\r\n                <div class=\"recruit-people-profile__person\">2019年入社・新卒（文系）　SI第1事業部 勘定系U</div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n          <section class=\"l-section\">\r\n            <div class=\"recruit-media\">\r\n              <div class=\"recruit-media__img -right\">\r\n                <figure class=\"c-figure\"><img src=\"/assets/img/recruit/people/14/img_02.jpg\" alt=\"\" loading=\"lazy\"></figure>\r\n              </div>\r\n              <div class=\"recruit-media__txt\">\r\n                <h2 class=\"recruit-heading -small u-ta-l u-mb-32 u-sp-mb-24\">学生時代は、Excelの使い方すら知らなかった</h2>\r\n                <p>文学部で国語国文学を学んでいた、いわゆる文系出身の私。大学を卒業するまではExcelの操作すらままならない状態でした。しかし就職活動を進めていく中で、「SEは、1人でコツコツ進めながらも、最終的には仲間と力を合わせて大きなことを成し遂げる仕事」だと知りました。部活を頑張ってきた過去とも重なって、自分に向いているかもしれないと思うようになり、IT業界への志望度が急速に高まっていきました。</p>\r\n                <p>当社に入社するきっかけとなったのは、1day仕事体験です。仕事体験の内容が面白かっただけでなく、人事担当者の人柄に魅力を感じました。「SGシステムを選んでくれたらうれしいけど、もし合わないと感じるなら他社に行くべきだよ」と、学生の私に本音で話してくれたのを今でも覚えています。その裏表なく接してくれる雰囲気が心地よく、入社を決意しました。</p>\r\n                <p>実際に入社してみて驚いたのは、同期の4割程度が文系出身者だったことです。そこで一気に不安が和らぎました（笑）。入社後の研修も、まず3カ月は開発演習で、グループで1つのシステムを完成させるというものでした。その後も、私が配属された部署では実務研修が2〜3カ月、OJT研修が半年ほど続きました。つまり丸1年間も教育期間が設けられており、じっくり経験を積むことができたのです。</p>\r\n                <p>さらに当社には「先輩社員は積極的に若手をサポートする」という風土が根付いており、1年目の頃はほとんど付きっきりで仕事を教えてもらいました。現在はリモートワークが中心ですが、チャットや電話で気兼ねなく質問ができる雰囲気があります。どんな質問にも本当に丁寧に答えてくれるので、文系出身の方でも安心だと思います。</p>\r\n              </div>\r\n            </div>\r\n          </section>\r\n          <section class=\"l-section\">\r\n            <h2 class=\"recruit-heading -small u-ta-l u-mb-32 u-sp-mb-24\">入社5年目で、大規模プロジェクトの管理を経験</h2>\r\n            <p>現在はSEとして、佐川急便の請求システムの保守を担当しています。入社2年目までは経験値を高めるために開発を行っていましたが、その後はキャリアの希望を聞き入れてもらい、3年目からはプロジェクトの進捗や工程を管理する立場となりました。</p>\r\n            <p>そして入社5年目では、担当するシステムのリプレース案件（サーバ入れ替え）のプロジェクトに参画することに。私は、担当システムのPM補佐として任命されました。進捗管理をはじめ、各開発リーダーや実際にシステムを使うユーザーとのスケジュール調整、顧客に向けた資料作成や説明……など、とても重要な業務を担いました。</p>\r\n            <p>文系出身でPC操作にすら慣れていなかった私が、4〜5年で大規模プロジェクトの管理業務を担うなんて、驚きですよね。ここまで成長できたのは、間違いなくSGシステムの手厚い教育体制や、周囲へのサポートを惜しまない先輩や仲間がいてくれたおかげです。</p>\r\n          </section>\r\n          <section class=\"l-section\">\r\n            <div class=\"recruit-media\">\r\n              <div class=\"recruit-media__img -left\">\r\n                <figure class=\"c-figure\"><img src=\"/assets/img/recruit/people/14/img_03.jpg\" alt=\"\" loading=\"lazy\"></figure>\r\n              </div>\r\n              <div class=\"recruit-media__txt\">\r\n                <h2 class=\"recruit-heading -small u-ta-l u-mb-32 u-sp-mb-24\">初めての大規模プロジェクト。完遂の達成感は、より一層高いものに</h2>\r\n                <p>これまでの仕事で最も思い出に残っているのは、やはり前述の大規模プロジェクトです。新サーバが問題なく動作するかを検証するため、請求システムのすべての処理をテストする必要がありました。</p>\r\n                <p>連携しているシステムやアプリケーションが多いため、各チームとのスケジュールを合わせるのは至難の業。さらにテストを行っている間も請求システム自体は稼働しているため、「そのテストを行うことで、どの部署のどんな人に影響があるか」を考えて段取りを組まなければいけません。また途中、頼りにしていた先輩が育児休業取得となり、作業を期日までに漏れなく行えるのか、不安を感じた場面もありました （余談ですが、当社には男女ともに育児休業を取りやすい環境や雰囲気があります）。</p>\r\n                <p>しかし最終的に、プロジェクトは無事予定どおり完了。プロジェクト全体を統括している先輩社員が相談に乗ってくれて、タスク整理や進捗の遅れを取り戻す方法の検討ができました。プロジェクト完了後も特に問題なくシステムが稼働しているのを確認できたときは、安堵と言葉にならないほどの達成感を得られました。</p>\r\n              </div>\r\n            </div>\r\n          </section>\r\n          <section class=\"l-section\">\r\n            <h2 class=\"recruit-heading -small u-ta-l u-mb-32 u-sp-mb-24\">休日は、社内メンバーと遊ぶことも。温かい社風だから、仕事でも頼りやすい</h2>\r\n            <p>SGシステムは、社内の雰囲気の良さも魅力のひとつです。同期や先輩社員とは仕事だけでなく、プライベートの時間を一緒に過ごすことも多いですね。フェスに行ったり、グループ全体で行われる運動会に運営スタッフとして同期メンバーで参加したり、家を行き来したり……と、かなり頻繁に遊んでいます。入社当時は覚えることが多く悩んだこともありましたが、その気持ちを素直に伝えられる仕事仲間がいたから、乗り越えられたのだと思います。</p>\r\n            <p>「SEはあまりコミュニケーションを取りたがらない人が多そう」と考えている方も多いかもしれませんが、当社は真逆かもしれません。むしろこまめにコミュニケーションを取らないと、業務でも認識の齟齬が起きてしまうこともありますよね。そういう意味では、どんな人とも分け隔てなく話せる方や、会話のキャッチボールを楽しめる方が、当社には向いていると思います。</p>\r\n            <p>もし「IT業界に興味はあるけど、文系だからな…」と考えている方がいたら、ぜひ一度当社に来ていただきたいです。知識がない方を置いてけぼりにしない教育体制と、後輩思いなメンバー達があなたをお待ちしています。</p>\r\n          </section>\r\n          <section class=\"l-section\">\r\n            <h2 class=\"recruit-heading -medium u-mb-40 u-sp-mb-24\">1日の仕事の流れ</h2>\r\n            <div class=\"recruit-people-routine\">\r\n              <div class=\"recruit-people-routine__list\">\r\n                <dl>\r\n                  <div>\r\n                    <dt>09:00</dt>\r\n                    <dd>勤務開始</dd>\r\n                  </div>\r\n                  <div>\r\n                    <dt>09:30</dt>\r\n                    <dd>メールチェック</dd>\r\n                  </div>\r\n                  <div>\r\n                    <dt>10:00</dt>\r\n                    <dd>顧客向け資料作成</dd>\r\n                  </div>\r\n                  <div>\r\n                    <dt>12:00</dt>\r\n                    <dd>お昼休憩</dd>\r\n                  </div>\r\n                  <div>\r\n                    <dt>13:00</dt>\r\n                    <dd>チームミーティング</dd>\r\n                  </div>\r\n                  <div>\r\n                    <dt>14:00</dt>\r\n                    <dd>担当案件のテスト実施結果確認 </dd>\r\n                  </div>\r\n                  <div>\r\n                    <dt>15:00</dt>\r\n                    <dd>顧客向けレビュー</dd>\r\n                  </div>\r\n                  <div>\r\n                    <dt>16:00</dt>\r\n                    <dd>要望内容の取りまとめと検討</dd>\r\n                  </div>\r\n                  <div>\r\n                    <dt>17:00</dt>\r\n                    <dd>開発担当者への連携</dd>\r\n                  </div>\r\n                  <div>\r\n                    <dt>18:00</dt>\r\n                    <dd>退社</dd>\r\n                  </div>\r\n                  <small>※業務内容・所属部署は取材当時のものです</small>\r\n                </dl>\r\n              </div>\r\n              <div class=\"recruit-people-routine__img\">\r\n                <img src=\"/assets/img/recruit/people/14/img_04.jpg\" alt=\"\" loading=\"lazy\">\r\n              </div>\r\n            </div>\r\n          </section>\r\n        </div>\r\n      </div>\r\n      <div class=\"l-block -bg-pale-blue\">\r\n        <div class=\"l-block__inner\">\r\n          <div class=\"c-slider -panel js-slider\" data-show=\"3\">\r\n            <div class=\"c-slider__inner js-slider__inner\">\r\n              <a href=\"/recruit/people/15/\" class=\"recruit-panel\">\r\n                <div class=\"recruit-panel__img\"><img src=\"/assets/img/recruit/people/15/img_thumb.jpg\" alt=\"\" loading=\"lazy\"></div>\r\n                <div class=\"recruit-panel__category\">エンジニア</div>\r\n                <div class=\"recruit-panel__ttl\">論理的思考で挑む、物流のDX。チーフスペシャリストが語る、SGシステムのAIソリューション</div>\r\n                <div class=\"recruit-panel__person\">2016年入社・新卒（理系）<br>SI第2事業部 AIソリューションU</div>\r\n              </a>\r\n              <a href=\"/recruit/people/16/\" class=\"recruit-panel\">\r\n                <div class=\"recruit-panel__img\"><img src=\"/assets/img/recruit/people/16/img_thumb.jpg\" alt=\"\" loading=\"lazy\"></div>\r\n                <div class=\"recruit-panel__category\">エンジニア</div>\r\n                <div class=\"recruit-panel__ttl\">システム利用者と直接やり取りして、新機能を提案。エンジニアとして、仕事の領域を広げられる</div>\r\n                <div class=\"recruit-panel__person\">2023年入社・中途（理系）<br>SI第1事業部 勘定系U</div>\r\n              </a>\r\n              <a href=\"/recruit/people/17/\" class=\"recruit-panel\">\r\n                <div class=\"recruit-panel__img\"><img src=\"/assets/img/recruit/people/17/img_thumb.jpg\" alt=\"\" loading=\"lazy\"></div>\r\n                <div class=\"recruit-panel__category\">エンジニア</div>\r\n                <div class=\"recruit-panel__ttl\">佐川急便が保有するビッグデータをどう活用するかは、あなた次第。SGシステムが、物流を未来へ導く</div>\r\n                <div class=\"recruit-panel__person\">2022年入社・中途（理系）<br>SI第1事業部 IT業務改革U</div>\r\n              </a>\r\n            </div>\r\n            <div class=\"c-slider__nav\">\r\n              <div class=\"c-slider__pause\"></div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n      <div class=\"recruit-entry\">\r\n  <div class=\"recruit-entry__block\">\r\n    <h2 class=\"recruit-entry__heading\">ENTRY</h2>\r\n    <p class=\"recruit-entry__lead\">SGシステムで一緒に<br class=\"sp-tb:view\">未来を作りませんか</p>\r\n    <p class=\"recruit-entry__txt\">私たちとこれからの物流を変える一歩を<br class=\"sp:view\">踏み出しませんか？<br>\r\n      エントリーはこちらからお願いします。</p>\r\n    <div class=\"recruit-entry__btn\">\r\n      <a href=\"https://job.mynavi.jp/27/pc/search/corp88148/outline.html\" target=\"_blank\" rel=\"noopener\" class=\"recruit-btn\"><span>新卒採用（マイナビ）</span></a>\r\n      <a href=\"https://jsd.jposting.net/sg-systems/\" target=\"_blank\" rel=\"noopener\" class=\"recruit-btn\"><span>中途採用</span></a>\r\n    </div>\r\n    <a href=\"https://qmnb.f.msgs.jp/webapp/form/26692_qmnb_2/index.do\" target=\"_blank\" rel=\"noopener\" class=\"recruit-entry__link01\">\r\n      <div>採用に関するお問い合わせ</div>\r\n    </a>\r\n    <a href=\"https://www.sg-hldgs.co.jp/recruit/group-recruit/\" target=\"_blank\" rel=\"noopener\" class=\"recruit-entry__link02\">\r\n      <div>SGホールディングスグループ合同採用募集</div>\r\n    </a>\r\n  </div>\r\n</div>\r\n<div class=\"l-block\">\r\n  <div class=\"l-block__inner\">\r\n    <h3 class=\"recruit-heading -medium u-mb-40 u-sp-mb-32\">関連リンク</h3>\r\n    <div class=\"c-btn-wrap\">\r\n      <a href=\"/strength/\" class=\"recruit-btn\"><span>SGシステムの強み</span></a>\r\n    </div>\r\n  </div>\r\n</div>\r\n<div class=\"recruit-bottom\">\r\n  <button class=\"recruit-bottom__open\" type=\"button\">応募する</button>\r\n  <div class=\"recruit-bottom__modal\">\r\n    <div class=\"recruit-bottom__heading\">応募する</div>\r\n    <p class=\"recruit-bottom__txt\">物流×ITのリーディングカンパニーを目指し、<br>\r\n      活躍していただける人材を募集しています。</p>\r\n    <div class=\"recruit-bottom__cta\">\r\n      <a href=\"https://job.mynavi.jp/27/pc/search/corp88148/outline.html\" target=\"_blank\" rel=\"noopener\" class=\"recruit-bottom__btn\"><span>新卒採用（マイナビ）</span></a>\r\n      <!--<a href=\"\" target=\"_blank\" rel=\"noopener\" class=\"recruit-bottom__btn\"><span>新卒採用（リクナビ）</span></a>-->\r\n      <a href=\"https://jsd.jposting.net/sg-systems/\" target=\"_blank\" rel=\"noopener\" class=\"recruit-bottom__btn\"><span>中途採用</span></a>\r\n      <a href=\"https://qmnb.f.msgs.jp/webapp/form/26692_qmnb_2/index.do\" target=\"_blank\" rel=\"noopener\" class=\"recruit-bottom__btn -contact\"><span>お問い合わせ</span></a>\r\n    </div>\r\n    <button class=\"recruit-bottom__close\"></button>\r\n  </div>\r\n</div>\r\n      <div class=\"l-breadcrumb\">\r\n        <div class=\"l-breadcrumb__inner\">\r\n          <ol class=\"l-breadcrumb__list\">\r\n            <li class=\"l-breadcrumb__item\"><a href=\"/\">ホーム</a></li>\r\n            <li class=\"l-breadcrumb__item\"><a href=\"/recruit/\">採用情報</a></li>\r\n            <li class=\"l-breadcrumb__item\"><a href=\"/recruit/people/\">人を知る</a></li>\r\n            <li class=\"l-breadcrumb__item\"><a href=\"/recruit/people/14/\">エンジニア・2019年入社・新卒（文系）</a></li>\r\n          </ol>\r\n        </div>\r\n      </div>\n    </main>\n    ﻿<footer class=\"l-footer\">\r\n  <div class=\"l-footer__pagetop\">\r\n    <a href=\"#\"></a>\r\n  </div>\r\n  <div class=\"l-footer__head\">\r\n    <div class=\"l-footer__logo\">\r\n      <div>\r\n        <span>物流×ITのリーディングカンパニー</span>\r\n        <div>\r\n          <a href=\"https://www.sg-hldgs.co.jp/\" target=\"_blank\" rel=\"noopener\"><img src=\"/assets/img/common/logo_sgh.svg\" alt=\"SGホールディングス\"></a>\r\n          <a href=\"/\"><img src=\"/assets/img/common/logo_sgsystem.svg\" alt=\"SGシステム株式会社\"></a>\r\n        </div>\r\n      </div>\r\n    </div>\r\n    <div class=\"l-footer__company\">\r\n      <dl>\r\n        <div>\r\n          <dt>本社</dt>\r\n          <dd>〒601-8104<br>\r\n            京都府京都市南区上鳥羽角田町25</dd>\r\n        </div>\r\n        <div>\r\n          <dt>東京本社</dt>\r\n          <dd>\r\n            〒136-0075<br>\r\n            東京都江東区新砂1-8-2 <br class=\"sp:view\">SGHビル新砂Ⅱ\r\n          </dd>\r\n        </div>\r\n      </dl>\r\n    </div>\r\n  </div>\r\n  <div class=\"l-footer__nav\">\r\n    <div class=\"l-footer__nav-inner\">\r\n      <ul class=\"l-footer__nav01\">\r\n        <li><a href=\"/sitemap/\">サイトマップ</a></li>\r\n        <li><a href=\"/help/\">ウェブサイトのご利用について</a></li>\r\n        <li><a href=\"/personal-data/\">個人情報保護方針</a></li>\r\n        <li><a href=\"/info-security/\">情報セキュリティ基本方針</a></li>\r\n        <li><a href=\"/contract/\">各種約款</a></li>\r\n        <li><a href=\"/multi-stakeholder/\">マルチステークホルダー方針</a></li>\r\n      </ul>\r\n      <ul class=\"l-footer__nav02\">\r\n        <li><a href=\"/service/\"><span>ソリューション・製品</span></a></li>\r\n        <li><a href=\"/casestudy/\"><span>導入事例</span></a></li>\r\n        <li><a href=\"/support/\"><span>お客さまサポート</span></a></li>\r\n        <li><a href=\"/strength/\"><span>SGシステムの強み</span></a></li>\r\n        <li><a href=\"/recruit/\"><span>採用情報</span></a></li>\r\n        <li><a href=\"/company/\">企業情報</a></li>\r\n      </ul>\r\n      <ul class=\"l-footer__nav03\">\r\n        <li><a href=\"/service/e-collect/guide/\">e-コレクト&reg;のお申込</a></li>\r\n        <li><a href=\"https://www.e-service.sagawa-exp.co.jp/portal/do/login/show\" target=\"_blank\" rel=\"noopener\">スマートクラブログイン</a></li>\r\n        <li><a href=\"https://www.sg-hldgs.co.jp/\" target=\"_blank\" rel=\"noopener\">SGホールディングス公式サイト</a></li>\r\n      </ul>\r\n    </div>\r\n  </div>\r\n  <div class=\"l-footer__copyright\">\r\n    <ul class=\"l-footer__marks\">\r\n      <li><img src=\"/assets/img/common/img_footer_logo-p.png\" alt=\"\" onclick=\"window.open('https://privacymark.jp/');\" class=\"link-pointer\" loading=\"lazy\"></li>\r\n      <li><img src=\"/assets/img/common/img_footer_logo-iso9001.png\" alt=\"\" loading=\"lazy\"></li>\r\n      <li><img src=\"/assets/img/common/img_footer_logo-isos.png\" alt=\"\" loading=\"lazy\"></li>\r\n      <li><img src=\"/assets/img/common/img_footer_logo-kurumin.png\" alt=\"\" loading=\"lazy\"></li>\r\n      <li><img src=\"/assets/img/common/img_footer_logo-elbosi.png\" alt=\"\" loading=\"lazy\"></li>\r\n    </ul>\r\n    <p>&copy; 2024 SG SYSTEMS Co.,Ltd.</p>\r\n  </div>\r\n</footer>\r\n\n  </div>\n</body>\n</html>\n","finalUrl":"https://www.sg-systems.co.jp/recruit/people/14/","rendered":false,"_cachedAt":"2026-06-14T19:35:14.456Z"}