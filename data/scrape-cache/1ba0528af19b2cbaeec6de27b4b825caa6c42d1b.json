<a href=\"/corp/csr/\" class=\"sp_menu_link\">CSR情報</a>\r\n\t\t</li>\r\n\t\t<li class=\"sp_menu_item\">\r\n\t\t\t<a href=\"/update/\" class=\"sp_menu_link\">ニュース</a>\r\n\t\t</li>\r\n\t\t<li class=\"sp_menu_item\">\r\n\t\t\t<a href=\"/recruit/\" class=\"sp_menu_link\">採用情報</a>\r\n\t\t</li>\r\n\t</ul>\r\n</div>\r\n<!-- header END -->\r\n  <!-- bottomここから -->\r\n  <div id=\"bottom\"> \r\n    <!-- bottom_mainここから -->\r\n    <div id=\"bottom_main\"> \r\n      <!-- siterouteここから -->\r\n      <div id=\"breadcrumb\">\r\n        <div class=\"contents\">\r\n          <ul>\r\n            <li><a href=\"/\">トップページ</a></li>\r\n            <li>特定個人情報の適切な取扱いに関する基本方針</li>\r\n          </ul>\r\n        </div>\r\n      </div>\r\n      <!-- siterouteここまで --> \r\n      <!-- main入力ここから -->\r\n      <div id=\"main\">\r\n        <h1>特定個人情報の適切な取扱いに関する基本方針</h1>\r\n        <p>弊社では、特定個人情報等の適切な取扱いの確保についての基本方針を以下の通り定めます。</p>\r\n        <ol class=\"privacy_list\">\r\n          <li>\r\n            <dl>\r\n              <dt>1.&nbsp;関係法令・ガイドライン等の遵守</dt>\r\n              <dd>弊社は、個人番号及び特定個人情報の取扱いに関し、「行政手続における特定の個人を識別するための番号の利用等に関する法律」及び「特定個人情報の適正な取扱いに関するガイドライン（事業者編）」、並びに「個人情報の保護に関する法律」及び各省庁のガイドラインを遵守します。</dd>\r\n            </dl>\r\n          </li>\r\n          <li>\r\n            <dl>\r\n              <dt>2.&nbsp;特定個人情報の安全管理措置</dt>\r\n              <dd>弊社は、特定個人情報の取扱いに関して「特定個人情報取扱規程」を定め、個人番号関係事務の処理を行なうにあたり、特定個人情報の安全な管理に努めます。</dd>\r\n            </dl>\r\n          </li>\r\n          <li>\r\n            <dl>\r\n              <dt>3.&nbsp;苦情・ご質問の窓口</dt>\r\n              <dd>弊社の特定個人情報の取扱いに関する苦情・ご質問等につきましては以下の窓口にご連絡頂きますようお願い致します。</dd>\r\n            </dl>\r\n          </li>\r\n        </ol>\r\n        <table class=\"toi\" border=\"0\" cellspacing=\"0\" cellpadding=\"0\" summary=\"特定個人情報の適切な取扱いに関する基本方針に関するお問合せ\">\r\n          <caption>\r\n          ■ 東建コーポレーション株式会社　個人情報保護委員会事務局\r\n          </caption>\r\n          <tr>\r\n            <th>受付時間</th>\r\n            <td>平日は9～12時・13～17時<br>\r\n              土日祝及び夏期・年末年始休暇中は除く</td>\r\n          </tr>\r\n          <tr>\r\n            <th>Email</th>\r\n            <td>privacy@token.co.jp</td>\r\n          </tr>\r\n          <tr>\r\n            <td class=\"t_center\" colspan=\"2\">個人情報保護に関するお問合せは<a href=\"https://www.token.co.jp/inquiry/input.asp?id=005\" target=\"_blank\">こちら</a></td>\r\n          </tr>\r\n        </table>\r\n      </div>\r\n      <!-- main入力ここまで --> \r\n    </div>\r\n    <!-- bottom_main入力ここまで --> \r\n  </div>\r\n  <!-- bottomここまで --> \r\n  \r\n</div>\r\n<!-- footer -->\r\n<footer class=\"footer\">\r\n\t<div class=\"footer_inner\">\r\n\t\t<div class=\"footer_nav_wrap\">\r\n\t\t\t<p class=\"footer_nav_ttl js-toggle_activeClass\">土地活用・賃貸経営<span class=\"footer_accordion_btn\"></span></p>\r\n\t\t\t<div class=\"footer_nav_accordion\">\r\n\t\t\t\t<ul class=\"footer_nav\">\r\n\t\t\t\t\t<li class=\"footer_nav_item\"><a href=\"/estate/\">土地活用・賃貸経営トップ</a></li>\r\n\t\t\t\t\t<li class=\"footer_nav_item\"><a href=\"/estate/consulting/\">土地活用コンサルティング</a></li>\r\n\t\t\t\t\t<li class=\"footer_nav_item\"><a href=\"/estate/seven_strengths/\">東建7つの強み</a></li>\r\n\t\t\t\t\t<li class=\"footer_nav_item\"><a href=\"/apartment/\">商品ラインナップ</a></li>\r\n\t\t\t\t\t<li class=\"footer_nav_item\"><a href=\"/estate/construction_work/\">土地活用事例</a></li>\r\n\t\t\t\t\t<li class=\"footer_nav_item\"><a href=\"/estate/estate_guide/\">土地活用ガイド</a></li>\r\n\t\t\t\t\t<li class=\"footer_nav_item\"><a href=\"/apartment/zeh-m/\">東建コーポレーションのZEH</a></li>\r\n\t\t\t\t\t<li class=\"footer_nav_item\"><a href=\"https://investment.homemate.co.jp/\" target=\"_blank\">ホームメイトの収益物件</a></li>\r\n\t\t\t\t\t<li class=\"footer_nav_item\"><a href=\"/inquiry/estate_request/\">資料請求</a></li>\r\n\t\t\t\t</ul>\r\n\t\t\t</div>\r\n\t\t\t<p class=\"footer_nav_ttl js-toggle_activeClass\">お部屋探し・入居者様<span class=\"footer_accordion_btn\"></span></p>\r\n\t\t\t<div class=\"footer_nav_accordion\">\r\n\t\t\t\t<ul class=\"footer_nav\">\r\n\t\t\t\t\t<li class=\"footer_nav_item -homemate\"><