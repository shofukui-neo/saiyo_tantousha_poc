ader class=\"page-header page-header--recruit\">\n      <div class=\"container\">\n        <div class=\"page-header__inner\">\n          <div>\n            <header class=\"heading\">\n              <h1 class=\"heading__subtext\">採用情報</h1>\n              <p class=\"heading__text u-fonten\">RECRUIT</p>\n            </header>\n          </div>\n                  </div>\n      </div>\n    </header>\n      <nav class=\"l-breadcrumbs\" id=\"anc\">\n    <div class=\"container\">\n      \n  <ol itemscope itemtype=\"http://schema.org/BreadcrumbList\" class=\"l-breadcrumbs-list\">\n    <li itemprop=\"itemListElement\" itemscope itemtype=\"http://schema.org/ListItem\" class=\"l-breadcrumbs-list__item l-breadcrumbs-list__item--home\">\n      <a itemprop=\"item\" href=\"https://www.magokorosapporo.com/\">\n        <span itemprop=\"name\">\n          トップページ\n        </span>\n      </a>\n      <meta itemprop=\"position\" content=\"1\" />\n    </li>\n  \n      <li itemprop=\"itemListElement\" itemscope itemtype=\"http://schema.org/ListItem\" class=\"l-breadcrumbs-list__item l-breadcrumbs-list__item--current\">\n        <a itemprop=\"item\" href=\"https://www.magokorosapporo.com/recruit/\">\n          <span itemprop=\"name\">\n            採用情報\n          </span>\n        </a>\n        <meta itemprop=\"position\" content=\"2\" />\n      </li>\n      \n    <li itemprop=\"itemListElement\" itemscope itemtype=\"http://schema.org/ListItem\" class=\"l-breadcrumbs-list__item l-breadcrumbs-list__item--current\">\n        <span itemprop=\"name\">\n          職種紹介\n        </span>\n        <meta itemprop=\"position\" content=\"3\" />\n    </li>\n    </ol>    </div>\n  </nav>\n    <div class=\"l-contents\">\n      <div class=\"page-content\">\n        <div class=\"container\">\n          <div class=\"page-sections\">\n            <section class=\"page-section\">\n              <div class=\"page-section__content\">\n                <header class=\"heading01\">\n                  <h2 class=\"heading01__text\">職種紹介</h2>\n                  <div class=\"heading01__dot\">\n                    <span></span>\n                    <span></span>\n                    <span></span>\n                  </div>\n                </header>\n                <p class=\"u-center u-mb01\">\n                  まごころでは、デイサービスから訪問看護まで他職種の社員が助け合いながら活躍しています。<br>\n                  各職種について、どのような働き方をしているかご紹介致します。\n                </p>\n                <ul class=\"cards02\">\n                                      <li class=\"card02\">\n                      <div class=\"card02__img recruit_profession_img\">\n                        <a href=\"https://www.magokorosapporo.com/recruit_profession/transportation-staff/#anchor\">\n                                                      <img src=\"https://placehold.jp/520x300.png\" alt=\"\">\n                                                  </a>\n                      </div>\n                      <div class=\"card02__content\">\n                        <h3>介護・送迎職員</h3>\n                        <p>安心してリハビリに通っていただけるよう、安全な送迎を担当します。</p>\n                        <div class=\"btn btn--left\">\n                          <a href=\"https://www.magokorosapporo.com/recruit_profession/transportation-staff/#anchor\" class=\"btn__link\">\n                            <span class=\"btn__text\">VIEW MORE</span>\n                            <span class=\"btn__line\"></span>\n                          </a>\n                        </div>\n                      </div>\n                    </li>\n                                      <li class=\"card02\">\n                      <div class=\"card02__img recruit_profession_img\">\n                        <a href=\"https://www.magokorosapporo.com/recruit_profession/day_nurse/#anchor\">\n                                                      <img width=\"2560\" height=\"1920\" src=\"https://www.magokorosapporo.com/wp-content/uploads/2025/07/看護師_デイサービス01-scaled.jpeg\" class=\"attachment-full size-full wp-post-image\" alt=\"\" loading=\"lazy\" srcset=\"https://www.magokorosapporo.com/wp-content/uploads/2025/07/看護師_デイサービス01-scaled.jpeg 2560w, https://www.magokorosapporo.com/wp-content/uploads/2025/07/看護師_デイサービス01-300x225.jpeg 300w, https://www.magokorosapporo.com/wp-content/uploads/2025/07/看護師_デイサービス01-1024x768.jpeg 1024w, https://www.magokorosapporo.com/wp-content/uploads/2025/07/看護師_デイサービス01-768x576.jpeg 768w, https://www.magokorosapporo.com/wp-content/uploads/2025/07/看護師_デイサービス01-1536x1152.jpeg 1536w, https://www.magokorosapporo.com/wp-content/uploads/2025/07/看護師_デイサービス01-2048x1536.jpeg 2048w\" sizes=\"(max-width: 2560px) 100vw, 2560px\" />                                                  </a>\n                      </div>\n                      <div class=\"card02__content\">\n                        <h3>デイサービスの看護師</h3>\n                        <p>リハビリに専念できるよう、日々の体調管理と安全面を看護の視点でサポートします。</p>\n                        <div class=\"btn btn--left\">\n                          <a href=\"https://www.magokorosapporo.com/recruit_profession/day_nurse/#anchor\" class=\"btn__link\">\n                            <span class=\"btn__text\">VIEW MORE</span>\n                            <span class=\"btn__line\"></span>\n                          </a>\n                        </div>\n                      </div>\n                    </li>\n                                      <li class=\"card02\">\n                      <div class=\"card02__img recruit_profession_img\">\n                        <a href=\"https://www.magokorosapporo.com/recruit_profession/life-counselor/#anchor\">\n                                                      <img width=\"2560\" height=\"2172\" src=\"https://www.magokorosapporo.com/wp-content/uploads/2020/02/石山_前田さん07-1-scaled.jpg\" class=\"attachment-full size-full wp-post-image\" alt=\"\" loading=\"lazy\" srcset=\"https://www.magokorosapporo.com/wp-content/uploads/2020/02/石山_前田さん07-1-scaled.jpg 2560w, https://www.magokorosapporo.com/wp-content/uploads/2020/02/石山_前田さん07-1-300x255.jpg 300w, https://www.magokorosapporo.com/wp-content/uploads/2020/02/石山_前田さん07-1-1024x869.jpg 1024w, https://www.magokorosapporo.com/wp-content/uploads/2020/02/石山_前田さん07-1-768x652.jpg 768w, https://www.magokorosapporo.com/wp-content/uploads/2020/02/石山_前田さん07-1-1536x1303.jpg 1536w, https://www.magokorosapporo.com/wp-content/uploads/2020/02/石山_前田さん07-1-2048x1738.jpg 2048w\" sizes=\"(max-width: 2560px) 100vw, 2560px\" />                                                  </a>\n                      </div>\n                      <div class=\"card02__content\">\n                        <h3>生活相談員</h3>\n                        <p>施設の相談窓口としての業務や調整役を行い、実際に運動に携わることもあります。</p>\n                        <div class=\"btn btn--left\">\n                          <a href=\"https://www.magokorosapporo.com/recruit_profession/life-counselor/#anchor\" class=\"btn__link\">\n                            <span class=\"btn__text\">VIEW MORE</span>\n                            <span class=\"btn__line\"></span>\n                          </a>\n                        </div>\n                      </div>\n                    </li>\n                                      <li class=\"card02\">\n                      <div class=\"card02__img recruit_profession_img\">\n                        <a href=\"https://www.magokorosapporo.com/recruit_profession/functional-training-instructor/#anchor\">\n                                                      <img width=\"1435\" height=\"992\" src=\"https://www.magokorosapporo.com/wp-content/uploads/2025/01/FT_スタッフ集合.jpg\" class=\"attachment-full size-full wp-post-image\" alt=\"\" loading=\"lazy\" srcset=\"https://www.magokorosapporo.com/wp-content/uploads/2025/01/FT_スタッフ集合.jpg 1435w, https://www.magokorosapporo.com/wp-content/uploads/2025/01/FT_スタッフ集合-300x207.jpg 300w, https://www.magokorosapporo.com/wp-content/uploads/2025/01/FT_スタッフ集合-1024x708.jpg 1024w, https://www.magokorosapporo.com/wp-content/uploads/2025/01/FT_スタッフ集合-768x531.jpg 768w\" sizes=\"(max-width: 1435px) 100vw, 1435px\" />                                                  </a>\n                      </div>\n                      <div class=\"card02__content\">\n                        <h3>理学療法士・柔道整復師・鍼灸師</h3>\n                        <p>リハビリに加え、当施設ならではのマッサージ・ストレッチを組み合わせて機能改善を目指します。</p>\n                        <div class=\"btn btn--left\">\n                          <a href=\"https://www.magokorosapporo.com/recruit_profession/functional-training-instructor/#anchor\" class=\"btn__link\">\n                            <span class=\"btn__text\">VIEW MORE</span>\n                            <span class=\"btn__line\"></span>\n                          </a>\n                        </div>\n                      </div>\n                    </li>\n                                      <li class=\"card02\">\n                      <div class=\"card02__img recruit_profession_img\">\n                        <a href=\"https://www.magokorosapporo.com/recruit_profession/visiting-nurse/#anchor\">\n                                                      <img width=\"1000\" height=\"680\" src=\"https://www.magokorosapporo.com/wp-content/uploads/2020/02/59272917_edited.png\" class=\"attachment-full size-full wp-post-image\" alt=\"訪問看護師のイメージ\" loading=\"lazy\" srcset=\"https://www.magokorosapporo.com/wp-content/uploads/2020/02/59272917_edited.png 1000w, https://www.magokorosapporo.com/wp-content/uploads/2020/02/59272917_edited-300x204.png 300w, https://www.magokorosapporo.com/wp-content/uploads/2020/02/59272917_edited-768x522.png 768w\" sizes=\"(max-width: 1000px) 100vw, 1000px\" />                                                  </a>\n                      </div>\n                      <div class=\"card02__content\">\n                        <h3>訪問看護師</h3>\n                        <p>体調や状態観察、服薬管理の支援をしながら、ご自宅で待っているご利用者様に明るさを届けます。</p>\n                        <div class=\"btn btn--left\">\n                          <a href=\"https://www.magokorosapporo.com/recruit_profession/visiting-nurse/#anchor\" class=\"btn__link\">\n                            <span class=\"btn__text\">VIEW MORE</span>\n                            <span class=\"btn__line\"></span>\n                          </a>\n                        </div>\n                      </div>\n                    </li>\n                                      <li class=\"card02\">\n                      <div class=\"card02__img recruit_profession_img\">\n                        <a href=\"https://www.magokorosapporo.com/recruit_profession/care-manager/#anchor\">\n                                                      <img width=\"520\" height=\"360\" src=\"https://www.magokorosapporo.com/wp-content/uploads/2020/02/pixta_58179031_M.png\" class=\"attachment-full size-full wp-post-image\" alt=\"\" loading=\"lazy\" srcset=\"https://www.magokorosapporo.com/wp-content/uploads/2020/02/pixta_58179031_M.png 520w, https://www.magokorosapporo.com/wp-content/uploads/2020/02/pixta_58179031_M-300x208.png 300w\" sizes=\"(max-width: 520px) 100vw, 520px\" />                                                  </a>\n                      </div>\n                      <div class=\"card02__content\">\n                        <h3>ケアマネージャー</h3>\n                        <p>ご本人やご家族のお話を丁寧に伺い、必要な介護サービスを一緒に考え、調整します。</p>\n                        <div class=\"btn btn--left\">\n                          <a href=\"https://www.magokorosapporo.com/recruit_profession/care-manager/#anchor\" class=\"btn__link\">\n                            <span class=\"btn__text\">VIEW MORE</span>\n                            <span class=\"btn__line\"></span>\n                          </a>\n                        </div>\n                      </div>\n                    </li>\n                                  </ul>\n              </div>\n            </section>\n            <div id=\"entry\" class=\"anchor-target\">\n  <div  class=\"entry-box\">\n    <!-- <img src=\"https://www.magokorosapporo.com/wp-content/themes/magokoro-theme/image