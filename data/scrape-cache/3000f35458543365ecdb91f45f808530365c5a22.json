\"50\" order=\"1\" issupportfloat=\"true\"   level=\"2\" compId='fde24486-04db-40f3-8af4-5238ec82c232' id=\"f75369a0-b239-4e14-9ea5-5acbf55f7c7d\" class=\"container9998 nec_series_product_footer_link_line min_height\"  componentRender=\"slides\">\r\n    \r\n  \r\n  <meta http-equiv=\"Content-Type\" content=\"text/html; charset=utf-8\"> \r\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0, maximum-scale=1.0, minimum-scale=1.0\"> \r\n  <meta name=\"keywords\" content=\"NEC, LAVIE,公式サイト,チャット,サービス\"> \r\n  <meta name=\"description\" content=\"こちらはNEC DirectはNEC LAVIE公式サイトショッピングのチャットサービスに関してのページです。\"> \r\n  <title>NEC Directチャットサービスに関して NEC Direct｜NEC LAVIE公式サイト</title> \r\n  <link rel=\"stylesheet\" href=\"//c1-nec.static.pub/version/css/5bf76cafda2a1745d98f8e74340d36b5.css\"> \r\n  \r\n  \r\n  <!-- link rel=\"stylesheet\" href=\"https://maxcdn.bootstrapcdn.com/font-awesome/4.7.0/css/font-awesome.min.css\" --> \r\n  <!-- DTMコード --> \r\n  <!-- Adobe Analytics DTMコード 170418 --> \r\n  <script src=\"//assets.adobedtm.com/9f0b01d01b963414024fff848ca9d3750437e1fa/satelliteLib-ce06f339e854781efdf01c8236d72d007c870956.js\"></script> \r\n  <!-- import JS --> \r\n  <!-- <script type=\"text/javascript\" src=\"//j1-nec.static.pub/resource/NEC_Public_Resource/shop/tmd/js/jquery-1.5.2.min.js\"></script> --> \r\n  <script src=\"//j1-nec.static.pub/resource/NEC_Public_Resource/navigate/common/js/jquery-1.11.2.min.js\" type=\"text/javascript\"></script> \r\n  <script type=\"text/javascript\" src=\"//j1-nec.static.pub/resource/NEC_Public_Resource/shop/js/import.js\"></script> \r\n  <!-- Adobe Analytics DTMコード 170418 --> \r\n  <script type=\"text/javascript\">\r\r\n    if (!window.lmd) {\r\r\n        window.lmd = {}; try { window.lmd.bu = \"NEC Direct\"; window.lmd.cc = \"JP\"; window.lmd.country = \"Japan\"; window.lmd.currency = \"JPY\"; window.lmd.currencycode = \"JPY\"; window.lmd.language = \"Ja\"; window.lmd.pageName = document.title; window.lmd.pagePath = location.href; window.lmd.PageTitle = document.title; window.lmd.storeID = \"nec/web\"; window.lmd.storeType = \"NEC Direct\"; window.lmd.title = document.title; } catch (lmderror) { console.warn(lmderror); } }\r\r\n    </script> \r\n  <script src=\"//j1-nec.static.pub/resource/NEC_Public_Resource/shop/js/gtm.js\" type=\"text/javascript\"></script> \r\n  <div class=\"wrapper\"> \r\n   <h1><img src=\"//p2-nec.static.pub/fes/cms/2026/04/08/k3epr2hg3szzq6qypjsmg6ig3o3yla015561.png\" width=\"2400\" alt=\"チャットで24時間問い合わせOK\" class=\"kv_01\"></h1> \r\n   <div id=\"popup_all_cont\" class=\"sec_01\"> \r\n    <div class=\"msg--agree\" align=\"center\" style=\"display:none;\"> \r\n     <input type=\"checkbox\" id=\"check\"> \r\n     <label for=\"check\">利用規約に同意します</label> \r\n    </div> \r\n    <p class=\"title\" style=\"display:none;\"> <a name=\"form\" id=\"form\"></a>チャット事前ご入力情報に関して</p> \r\n    <div class=\"flxWrap\"> \r\n     <div class=\"block--form\"> \r\n      <h2><span style=\"font-size:32px; font-weight: bold; background: linear-gradient(transparent 80%, yellow 0%); display: inline-block; padding-bottom: 0.8em;line-height: 1.2em;\">NEC Direct ご購入相談チャット</span></h2> \r\n      <div class=\"notes\">\r\n       必須項目を入力し利用規約に同意して送信ボタンを押すとNEC Direct担当者とチャット開始できます。\r\n       <br>製品の技術的なご相談、故障診断は、\r\n       <a href=\"https://support.nec-lavie.jp/chat\">*こちらのチャット*</a>&nbsp;からご相談ください。\r\n      </div> \r\n      <div> \r\n       <button class=\"btn--blue\" id=\"openChatButton\" onclick=\"openChatButtonClick()\">購入相談を開始する</button> \r\n      </div> \r\n     </div> \r\n     <img class=\"img_01\" src=\"//p1-nec.static.pub/fes/cms/2023/07/11/fg6t3d2ftp8x91ozyjxwnwo7zkfu2z443118.png\" width=\"300\" height=\"300\" alt=\"img\"> \r\n    </div> \r\n    <div class=\"clear\"> \r\n     <dl> \r\n      <dt>\r\n       ■対応時間\r\n      </dt> \r\n      <dd>\r\n       ・平日：9:00～21:00、週末・祝日：9:00～18:00\r\n      </dd> \r\n      <dd>\r\n       ・混み合っている場合には対応までにお時間を要する場合がございます\r\n      </dd> \r\n      <dd>\r\n       ・営業時間外は受付しておりません\r\n      </dd> \r\n     </dl> \r\n     <dl> \r\n      <dt>\r\n       ■注意事項\r\n      </dt> \r\n      <dd>\r\n       ・ご質問内容によりましては回答までにお時間を要する場合がございます。\r\n      </dd> \r\n      <dd>\r\n       ・必要に応じてお電話にて折り返しご連絡させていただく場合がございます。\r\n      </dd> \r\n      <dd>\r\n       ・日本語サポートのみでございます。※Japanese only\r\n      </dd> \r\n      <dd>\r\n       ・チャット中に一定時間以上応答が無い場合は、チャットを終了させていただく場合がございます。\r\n      </dd> \r\n      <dd>\r\n       ・ご注文に必要な情報(お客様名/住所/電話番号/Eメールなど)をお伺いすることがございます。\r\n      </dd> \r\n      <dd>\r\n       ・チャット中は、クレジットカード情報を入力しないよう、ご注意ください。\r\n      </dd> \r\n      <dd>\r\n       ・チャット中に何らかの障害で切断してしまった場合、恐れ入りますが、再度お問い合わせをお願いします。\r\n      </dd> \r\n     </dl> \r\n     <p> ■個人情報について <br> NEC Directでは、<a href=\"/privacy/index.html\" target=\"_blank\">『NEC LAVIE公式サイト（サポートサービスおよびNEC Direct）における個人情報の取り扱い』</a>に基づき、お客さまの個人情報の適切な管理に努めます。お客さまは、当社がお客さまの個人情報を、<a href=\"/privacy/index.html\" target=\"_blank\">当規約</a>に基づき利用することをあらかじめ了承願います。 </p> \r\n    </div> \r\n   </div> \r\n   <div class=\"sec_03\"> \r\n    <h2><span style=\"font-size: 32px; background: linear-gradient(transparent 80%, yellow 0%); display: inline-block; padding-bottom: 0.5em;\">ご注文後の確認</span></h2> \r\n    <p>納期確認・領収書発行</p> \r\n    <a class=\"btn--blue\" href=\"https://support.nec-lavie.jp/my/\">マイページへ</a> \r\n   </div> \r\n   <div class=\"sec_02\"> \r\n    <h2><span style=\"font-size: 32px; background: linear-gradient(transparent 80%, yellow 0%); display: inline-block; padding-bottom: 0.5em;\">ご購入後の使い方・故障診断のご相談はこちら</span></h2> \r\n    <p>パソコン・タブレットの使い方と故障診断のご相談はこちらからお願いします</p> \r\n    <a class=\"btn--blue\" href=\"https://support.nec-lavie.jp/navigate/support/webchat_sp/index.html\">Webチャット</a> \r\n    <a class=\"btn--blue\" href=\"https://support.nec-lavie.jp/navigate/support/linechat/index.html\">LINEチャット</a> \r\n   </div> \r\n  </div> \r\n  <!-- DTMコード --> \r\n  <script type=\"text/javascript\">\r\r\n    if (typeof _satellite !== \"undefined\")\r\r\n    _satellite.pageBottom();\r\r