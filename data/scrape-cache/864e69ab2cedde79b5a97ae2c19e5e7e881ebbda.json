                     <li class=\"subLink\">\n                                <a href=\"../organization/#sec2\" class=\"js-anchor\">福利厚生</a>\n                            </li>\n                        </ul>\n                    </li>\n                    <li class=\"link\">\n                        <a href=\"../infomation\">\n                            <span class=\"title f-en\">Infomation</span>\n                            <span class=\"subTitle f-jp\">採用情報</span>\n                        </a>\n                        <ul class=\"subNavList f-jp\">\n                            <li class=\"subLink\">\n                                <a href=\"../infomation/#sec1\" class=\"js-anchor\">募集要項</a>\n                            </li>\n                            <li class=\"subLink\">\n                                <a href=\"../infomation/#sec2\" class=\"js-anchor\">選考フロー</a>\n                            </li>\n                            <li class=\"subLink\">\n                                <a href=\"../infomation/#sec3\" class=\"js-anchor\">Q&A</a>\n                            </li>\n                        </ul>\n                    </li>\n                    <li class=\"link\">\n                        <a href=\"../contact\">\n                            <span class=\"title f-en\">Contact</span>\n                            <span class=\"subTitle f-jp\">お問合せ</span>\n                        </a>\n                    </li>\n                </ul>\n            </div>\n            <div class=\"right\">\n                <a href=\"https://job.mynavi.jp/27/pc/search/corp2703/outline.html?msockid=3d1f8b56624f6c6a10ff9dda63d26d78\" class=\"ngLinkBtn\" target=\"_blank\">\n                    <span class=\"title f-en\">New-<br>-Graduate</span>\n                    <span class=\"subTitle f-jp\">新卒採用</span>\n                    <img src=\"../assets/images/common_header_arrow_icon.png\" class=\"arrow\" alt=\"\">\n                </a>\n                <a href=\"../contact\" class=\"mdLinkBtn\">\n                    <span class=\"title f-en\">Mid<br>-Career</span>\n                    <span class=\"subTitle f-jp\">中途採用</span>\n                    <img src=\"../assets/images/common_header_mail_icon.png\" class=\"arrow\" alt=\"\">\n                </a>\n            </div>\n        </div>\n        <div class=\"lower\">\n            <ul class=\"linkList f-jp\">\n                <li class=\"link\">\n                    <a href=\"https://www.ik-felt.co.jp/\" target=\"_blank\">コーポレートサイト</a>\n                </li>\n                <li class=\"link\">\n                    <a href=\"https://www.ik-felt.co.jp/terms/\" target=\"_blank\">サイトポリシー</a>\n                </li>\n                <li class=\"link\">\n                    <a href=\"https://www.ik-felt.co.jp/privacypolicy/\" target=\"_blank\">個人情報保護方針</a>\n                </li>\n            </ul>\n            <span class=\"copyright f-en\">©Copyright 2020.ICHIKAWA CO.,LTD.</span>\n        </div>\n    </div>\n</nav>\n\t\t\n<main id=\"js-bg-parallax-flag\">\n    <section class=\"mainVisualArea --child\">\n        <div class=\"breadcrumb f-en\">\n            <span class=\"text --left js-init-position\">Ichikawa Recruiting</span>\n            <span class=\"text --right js-init-position\">Organization</span>\n        </div>\n        <div class=\"innerBlock\">\n            <div class=\"left js-cue --a1\">\n                <span class=\"num f-en\">03</span>\n                <h1 class=\"title f-en\">Organization</h1>\n                <span class=\"sub f-jp\">あなたを支える会社の制度</span>\n            </div>\n            <div class=\"right js-cue --a1 --format\">\n                <img src=\"../assets/images/organization_main_visual.jpg\" alt=\"\">\n            </div>\n        </div>\n        <div class=\"scrollAttention\">\n            <img src=\"../assets/images/common_scroll_down_icon.png\" width=\"128\" height=\"127\" alt=\"Scroll Down\">\n        </div>\n    </section>\n    <div class=\"contentsArea\">\n        <div class=\"innerBlock\">\n            <div class=\"left --parent js-toggle-menu-sp\">\n                <button class=\"toggleBtn js-toggle-slide\">\n                    <span class=\"text f-jp\">あなたを支える会社の制度</span>\n                </button>\n                <div class=\"sideMenu\">\n                    <a href=\"#sec1\" class=\"link f-jp js-anchor is-current\" data-current-num=\"1\">人材育成</a>\n                    <a href=\"#sec2\" class=\"link f-jp js-anchor\" data-current-num=\"2\">福利厚生</a>\n                </div>\n            </div>\n            <div class=\"right --parent\">\n                <section class=\"trainingContents js-side-menu\" data-current-num=\"1\" id=\"sec1\">\n                    <div class=\"inner\">\n                        <div class=\"titleHead astro-ZFUFVVIG\">\n    <h2 class=\"text f-jp astro-ZFUFVVIG\">人材育成</h2>\n</div>\n                        <span class=\"caption f-jp\">一人ひとりの希望や適性に合わせたスキルアップおよびキャリアアップをサポートしています。</span>\n                        <ul class=\"itelList\">\n                            <li class=\"item js-cue --a1\">\n                                <div class=\"left\">\n                                    <img src=\"../assets/images/organization_training_img_01.png\" alt=\"\">\n                                </div>\n                                <div class=\"right\">\n                                    <h3 class=\"title f-jp\">海外研修制度</h3>\n                                    <span class=\"detail f-jp\">国際色豊かな人材を育成するために、若手社員を積極的に海外に留学させています。</span>\n                                </div>\n                            </li>\n                            <li class=\"item js-cue --a1\">\n                                <div class=\"left\">\n                                    <img src=\"../assets/images/organization_training_img_02.png\" alt=\"\">\n                                </div>\n                                <div class=\"right\">\n                                    <h3 class=\"title f-jp\">国内留学制度</h3>\n                                    <span class=\"detail f-jp\">専門性を高めて働いていくために、勤務をしながら国内の大学へ留学する制度です。電気・機械関連の大学や、IT・プログラミング関係の大学への派遣実績があります。</span>\n                                </div>\n                            </li>\n                            <li class=\"item js-cue --a1\">\n                                <div class=\"left\">\n                                    <img src=\"../assets/images/organization_training_img_03.png\" alt=\"\">\n                                </div>\n                                <div class=\"right\">\n                                    <h3 class=\"title f-jp\">多様性のある働き方</h3>\n                                    <span class=\"detail f-jp\">フレックス勤務制度、テレワーク勤務制度があります。業務の繁閑に合わせて就業時間を調整したり、テレワークが可能な部署についてはご自宅での勤務が可能です。育児休職制度と介護休職制度を完備しており、育児・介護のための短時間勤務をすることも可能です。</span>\n                                </div>\n                            </li>\n                            <li class=\"item js-cue --a1\">\n                                <div class=\"left\">\n                                    <img src=\"../assets/images/organization_training_img_04.png\" alt=\"\">\n                                </div>\n                                <div class=\"right\">\n                                    <h3 class=\"title f-jp\">自己啓発・資格検定取得支援制度</h3>\n                                    <span class=\"detail f-jp\">業務に必要な資格取得の補助に加え、自己啓発に関する費用補助や、資格・検定取得時の奨励金支給などがあります。</span>\n                                </div>\n                            </li>\n                        </ul>\n                    </div>\n                </section>\n                <section class=\"welfareContents js-side-menu\" data-current-num=\"2\" id=\"sec2\">\n                    <div class=\"inner\">\n                        <div class=\"titleHead astro-ZFUFVVIG\">\n    <h2 class=\"text f-jp astro-ZFUFVVIG\">福利厚生</h2>\n</div>\n                        <span class=\"caption f-jp\">社員一人ひとりの生活をサポートする、各種制度をご紹介します。</span>\n                        <div class=\"toggleBtnList\">\n                            <div class=\"toggleItem\">\n                                <button class=\"toggleProfileBtn js-toggle-slide\">\n                                    <h3 class=\"title f-jp\">休日・休暇・休職</h3>\n                                    <div class=\"btnBox\">\n                                        <div class=\"moreBtn\">\n                                            <div class=\"item\">\n                                                <div class=\"circle\"></div>\n                                                <div class=\"arrow\">       \n                                                    <svg width=\"25\" height=\"24\" viewBox=\"0 0 25 24\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n                                                        <path fill-rule=\"evenodd\" clip-rule=\"evenodd\" d=\"M11.4305 23.9992H12.5734L12.3164 2.98028C12.3066 2.18037 13.3009 1.8043 13.823 2.41045L22.5734 12.5706H24.002L12.5734 -0.000793934H12.2877H11.7162H11.4305L0.00195312 12.5706H1.43052L10.1809 2.41045C10.703 1.8043 11.6973 2.18037 11.6875 2.98028L11.4305 23.9992Z\" fill=\"#231815\"></path>\n                                                    </svg>                                                                         \n                                                </div>\n                                            </div>\n                                        </div>\n                                    </div>\n                                </button>\n                                <div class=\"detailList\">\n                                    <div class=\"wrap\">\n                                        <span class=\"detail f-jp\">有給休暇、慶弔休暇、リフレッシュ休暇などがあります。また、制度として育児休職、介護休職などがあります。</span>\n                                    </div>\n                                </div>\n                            </div>\n                            <div class=\"toggleItem\">\n                                <button class=\"toggleProfileBtn js-toggle-slide\">\n                                    <h3 class=\"title f-jp\">イベント</h3>\n                                    <div class=\"btnBox\">\n                                        <div class=\"moreBtn\">\n                                            <div class=\"item\">\n                                                <div class=\"circle\"></div>\n                                                <div class=\"arrow\">       \n                                                    <svg width=\"25\" height=\"24\" viewBox=\"0 0 25 24\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n                                                        <path fill-rule=\"evenodd\" clip-rule=\"evenodd\" d=\"M11.4305 23.9992H12.5734L12.3164 2.98028C12.3066 2.18037 13.3009 1.8043 13.823 2.41045L22.5734 12.5706H24.002L12.5734 -0.000793934H12.2877H11.7162H11.4305L0.00195312 12.5706H1.43052L10.1809 2.41045C10.703 1.8043 11.6973 2.18037 11.6875 2.98028L11.4305 23.9992Z\" fill=\"#231815\"></path>\n                                                    </svg>                                                                         \n                                                </div>\n                                            </div>\n                                        </div>\n                                    </div>\n                                </button>\n                                <div class=\"detailList\">\n                                    <div class=\"wrap\">\n                                        <span class=\"detail f-jp\">創立記念式典、秋祭り、家族工場見学会などがあります。</span>\n                                    </div>\n                                </div>\n                            </div>\n                            <div class=\"toggleItem\">\n                                <button class=\"toggleProfileBtn js-toggle-slide\">\n                                    <h3 class=\"title f-jp\">財産形成</h3>\n                                    <div class=\"btnBox\">\n                                        <div class=\"moreBtn\">\n                                            <div class=\"item\">\n                                                <div class=\"circle\"></div>\n                                                <div class=\"arrow\">       \n                                                    <svg width=\"25\" height=\"24\" viewBox=\"0 0 25 24\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n                                                        <path fill-rule=\"evenodd\" clip-rule=\"evenodd\" d=\"M11.4305 23.9992H12.5734L12.3164 2.98028C12.3066 2.18037 13.3009 1.8043 13.823 2.41045L22.5734 12.5706H24.002L12.5734 -0.000793934H12.2877H11.7162H11.4305L0.00195312 12.5706H1.43052L10.1809 2.41045C10.703 1.8043 11.6973 2.18037 11.6875 2.98028L11.4305 23.9992Z\" fill=\"#231815\"></path>\n                                                    </svg>                                                                         \n                                                </div>\n                                            </div>\n                                        </div>\n                                    </div>\n                                </button>\n                                <div class=\"detailList\">\n                                    <div class=\"wrap\">\n                                        <span class=\"detail f-jp\">財形貯蓄、持株会、確定拠出年金、共済会などがあります。</span>\n                                    </div>\n                                </div>\n                            </div>\n                            <div class=\"toggleItem\">\n                                <button class=\"toggleProfileBtn js-toggle-slide\">\n                                    <h3 class=\"title f-jp\">社宅・寮</h3>\n                                    <div class=\"btnBox\">\n                                        <div class=\"moreBtn\">\n                                            <div class=\"item\">\n                                                <div class=\"circle\"></div>\n                                                <div class=\"arrow\">       \n                                                    <svg width=\"25\" height=\"24\" viewBox=\"0 0 25 24\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n                                                        <path fill-rule=\"evenodd\" clip-rule=\"evenodd\" d=\"M11.4305 23.9992H12.5734L12.3164 2.98028C12.3066 2.18037 13.3009 1.8043 13.823 2.41045L22.5734 12.5706H24.002L12.5734 -0.000793934H12.2877H11.7162H11.4305L0.00195312 12.5706H1.43052L10.1809 2.41045C10.703 1.8043 11.6973 2.18037 11.6875 2.98028L11.4305 23.9992Z\" fill=\"#231815\"></path>\n                                                    </svg>                                                                         \n                                                </div>\n                                            </div>\n                                        </div>\n                                    </div>\n                                </button>\n                                <div class=\"detailList\">\n                                    <div class=\"wrap\">\n                                        <span class=\"detail f-jp\">工場周辺に借上げ社宅・寮を用意しています。（入居条件有り）</span>\n                                    </div>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                </section>\n            </div>\n        </div>\n    </div>\n    <div class=\"loadingArea js-loading-top-animation is-visited\">\n    <div class=\"innerBlock f-en\">\n        <div class=\"num\">000</div>\n        <div class=\"card\">\n            <div class=\"item\" data-num=\"1\"></div>\n            <div class=\"item\" data-num=\"2\"></div>\n            <div class=\"item\" data-num=\"3\"></div>\n            <div class=\"item\" data-num=\"4\"></div>\n            <div class=\"item\" data-num=\"5\"></div>\n            <div class=\"item\" data-num=\"6\"></div>