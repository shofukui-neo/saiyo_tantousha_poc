../../../../../contact/index.html\">お問い合わせ</a></li>\r\n     </ul>\r\n \t  </div>\r\n  </nav>\r\n<!-- ----- nav End ----- -->\r\n\r\n\r\n \t\t</div>\r\n\t\r\n\t\t</header>\r\n \r\n<!-- ----- Header End ----- -->\t\t\r\n\r\n<!-- InstanceBeginEditable name=\"Main\" -->\r\n\t\t\r\n<!-- ----- Main ----- -->\r\n\t\t\r\n<div id=\"page\">\r\n\t\r\n\t\r\n  <!-- ----- PageImage ----- -->\r\n  <div class=\"List_bg\">\r\n    <div class=\"List\">\r\n      <p><a href=\"../index.html\">HOME</a>　/　企業情報　/　代表挨拶</p>\r\n    </div>\r\n  </div>\r\n  <div class=\"pageimage_wrp pi_com\">\r\n    <div class=\"pi_stit\">Corporate Information</div>\r\n    <h2>企業情報</h2>\r\n  </div>\r\n  <!-- ----- PageImage End ----- -->\r\n\t\r\n\t\r\n  <!-- ----- Content ----- -->\r\n  <div class=\"sec01\">\r\n   <div class=\"greeting_wrp\">\r\n\t\t\t\t<section class=\"title w01\">\r\n    \t<h2><div class=\"stit left\">Greetings</div>代表挨拶</h2>\r\n\t\t\t\t</section>\r\n\t\t\t\t\r\n\t\t\t\t<div class=\"cp\">もっと　ときめく明日へ</div>\r\n\t\t\t\t<section class=\"content02\">\r\n\t\t\t\t\t\t<div class=\"leftbox_text\">\r\n\t\t\t\t\t\t\t<p>　弊社ホームページにお越し頂きありがとうございます。</p>\r\n\t\t\t\t\t\t\t\r\n\t\t\t\t\t\t\t<p>　弊社は、昭和50年創業以来「社会のために存在し、社会と共に繫栄する」を経営信条として社業に取り組んでまいりました。<br>　おかげさまで、令和7年11月25日に創立50周年を迎えることができました。この50年間、まるなか建設と共に歩み続けて頂いたすべての皆様に改めて感謝申し上げます。</p>\r\n\t\t\t\t\t\t\t\r\n\t\t\t\t\t\t\t<p>　我々建設業者の使命は、近年多発するインフラ老朽化による災害や激甚化する自然災害などから人・地域を守ることであると考えています。これから先、50年後の未来でも、人・地域を守り、安心と安全を届けられる企業であり続けるために、役職員一丸となって日々邁進してまいります。</p>\r\n\t\t\t\t\t\t\t\r\n\t\t\t\t\t\t\t<p>　今後とも、一層のご愛顧と格別のお引き立てを賜りますようお願い申し上げます。</p>\r\n\t\t\t\t\t\t\t<p class=\"name_right\"><img src=\"images/com_president_t.png\" alt=\"代表取締役社長　大筒晃一\"/></p>\t\t\t\t\t\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t<div class=\"rightbox_photo\">\r\n\t\t\t\t\t\t\t<img src=\"images/com_p_president_t.jpg\" alt=\"代表取締役社長　大筒晃一\"/>\t\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t</section><!-- /.content02 -->\r\n\t\t\t</div><!-- /.greeting_wrp -->\r\n  </div><!-- /.sec01 -->\r\n\t\r\n\t\r\n\t\r\n  <di