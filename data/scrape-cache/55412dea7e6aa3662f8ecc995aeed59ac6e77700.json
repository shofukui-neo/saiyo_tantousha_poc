iv class=\"p-kv__slider-item slide-move\">\n                    <picture class=\"p-kv__slider-img\">\n                      <source srcset=\"/recruit/inc/image/top/pic_kv06.jpg.webp 1x, /recruit/inc/image/top/pic_kv06@2x.jpg.webp 2x\" type=\"image/webp\">\n                      <img src=\"/recruit/inc/image/top/pic_kv06.jpg\" alt=\"K.I.\">\n                    </picture>\n                  </div>\n                  <div class=\"p-kv__slider-item slide-move\">\n                    <picture class=\"p-kv__slider-img\">\n                      <source srcset=\"/recruit/inc/image/top/pic_kv07.jpg.webp 1x, /recruit/inc/image/top/pic_kv07@2x.jpg.webp 2x\" type=\"image/webp\">\n                      <img src=\"/recruit/inc/image/top/pic_kv07.jpg\" alt=\"K.I.\">\n                    </picture>\n                  </div>\n                </div>\n                <div class=\"p-kv__slider\">\n                  <div class=\"p-kv__slider-item slide-move\">\n                    <picture class=\"p-kv__slider-img\">\n                      <source srcset=\"/recruit/inc/image/top/pic_kv01.jpg.webp 1x, /recruit/inc/image/top/pic_kv01@2x.jpg.webp 2x\" type=\"image/webp\">\n                      <img src=\"/recruit/inc/image/top/pic_kv01.jpg\" alt=\"H.M.\">\n                    </picture>\n                  </div>\n                  <div class=\"p-kv__slider-item slide-move\">\n                    <picture class=\"p-kv__slider-img\">\n                      <source srcset=\"/recruit/inc/image/top/pic_kv02.jpg.webp 1x, /recruit/inc/image/top/pic_kv02@2x.jpg.webp 2x\" type=\"image/webp\">\n                      <img src=\"/recruit/inc/image/top/pic_kv02.jpg\" alt=\"S.I.\">\n                    </picture>\n                  </div>\n                  <div class=\"p-kv__slider-item slide-move\">\n                    <picture class=\"p-kv__slider-img\">\n                      <source srcset=\"/recruit/inc/image/top/pic_kv03.jpg.webp 1x, /recruit/inc/image/top/pic_kv03@2x.jpg.webp 2x\" type=\"image/webp\">\n                      <img src=\"/recruit/inc/image/top/pic_kv03.jpg\" alt=\"D.F.\">\n                    </picture>\n                  </div>\n                  <div class=\"p-kv__slider-item slide-move\">\n                    <picture class=\"p-kv__slider-img\">\n                      <source srcset=\"/recruit/inc/image/top/pic_kv04.jpg.webp 1x, /recruit/inc/image/top/pic_kv04@2x.jpg.webp 2x\" type=\"image/webp\">\n                      <img src=\"/recruit/inc/image/top/pic_kv04.jpg\" alt=\"Y.T.\">\n                    </picture>\n                  </div>\n                  <div class=\"p-kv__slider-item slide-move\">\n                    <picture class=\"p-kv__slider-img\">\n                      <source srcset=\"/recruit/inc/image/top/pic_kv05.jpg.webp 1x, /recruit/inc/image/top/pic_kv05@2x.jpg.webp 2x\" type=\"image/webp\">\n                      <img src=\"/recruit/inc/image/top/pic_kv05.jpg\" alt=\"K.I.\">\n                    </picture>\n                  </div>\n                  <div class=\"p-kv__slider-item slide-move\">\n                    <picture class=\"p-kv__slider-img\">\n                      <source srcset=\"/recruit/inc/image/top/pic_kv06.jpg.webp 1x, /recruit/inc/image/top/pic_kv06@2x.jpg.webp 2x\" type=\"image/webp\">\n                      <img src=\"/recruit/inc/image/top/pic_kv06.jpg\" alt=\"K.I.\">\n                    </picture>\n                  </div>\n                  <div class=\"p-kv__slider-item slide-move\">\n                    <picture class=\"p-kv__slider-img\">\n                      <source srcset=\"/recruit/inc/image/top/pic_kv07.jpg.webp 1x, /recruit/inc/image/top/pic_kv07@2x.jpg.webp 2x\" type=\"image/webp\">\n                      <img src=\"/recruit/inc/image/top/pic_kv07.jpg\" alt=\"K.I.\">\n                    </picture>\n                  </div>\n                </div>\n              </div>\n            </div>\n            <div class=\"p-kv__sliderText__wrapper\">\n              <picture class=\"p-kv__sliderText\">\n                <source srcset=\"/recruit/inc/image/top/img_kvSlide-textPc.svg\" media=\"(min-width: 569px)\">\n                <source srcset=\"/recruit/inc/image/top/img_kvSlide-textSp.svg\" media=\"(max-width: 568px)\">\n                <img src=\"/recruit/inc/image/top/img_kvSlide-textPc.svg\" alt=\"グレートを創り出せ\">\n              </picture>\n            </div>\n          </div>\n          <div class=\"p-kv__textWrapper l-mw l-mw--1000\">\n            <div class=\"p-kv__text\">\n              <h2 class=\"c-ttl-main c-ttl-main c-ttl--white c-ttl--oblique p-kv__title\"> あなたのグレートを考え、<br>主体性を持って挑戦していく。 </h2>\n              <p class=\"p-kv__description\"> 「グレートを創りだせ」と言われても、最初は驚くかもしれません。山産はハイレベルな営業力と知識、技術力をあわせもつ「産業機械商社」「機械電気設備エンジニアリング会社」として、日々、お客様の課題解決を行なっています。それらは、民間の工場内や上下水道施設で使用されることが多く、普段私たちが目にする機会はほとんどありません。 でもご安心ください。必要となる知識や技術は入社後に十分に習得できます。面倒見の良い先輩たちが熱心に指導し、サポートしてくれるので、不安に感じることはありません。 しかし、仕事をする中ではもちろん多くの苦労も伴います。それでも先輩たちが頑張れているのは、お客様からの喜びの声の為に、自ら仕事を楽しんでいるからです。当社には、「楽しむ力（リョク）」を持った社員が多数在籍しています。 山産の「財産」とも言える、積極的かつ献身的な社員一人ひとりの行いが、グレート山産を創り出す原動力となっています。もしあなたが「人を喜ばせることをしたい」あるいは「インフラを通じて人々の暮らしを支えたい」と思っているのであれば、是非、私たちと次の「グレート」を創り出していきましょう。 </p>\n              <div class=\"p-kv__link\">\n                <a href=\"/recruit/about/message/\" class=\"p-linkText p-linkText--kv\">採用メッセージを詳しく見る<span class=\"p-linkText__arrow p-linkText__arrow--white\"></span></a>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n      <section class=\"l-section\">\n        <h2 class=\"c-ttl-main c-ttl-main c-ttl--center c-ttl--keycolor c-ttl--oblique\">\n          <span class=\"c-ttl-main__sub\">グレートを創り出す</span> 山産を知る\n        </h2>\n        <div class=\"grid-equalHeight\">\n          <div class=\"col-6_sm-12\">\n            <div class=\"p-top-cardAreaL\">\n              <a href=\"/recruit/about/business/\" class=\"p-top-contentsCardL\">\n                <picture class=\"p-top-contentsCardL__image\">\n                  <source srcset=\"/recruit/inc/image/top/img_cardBusiness.png.webp 1x, /recruit/inc/image/top/img_cardBusiness@2x.png.webp 2x\" type=\"image/webp\">\n                  <img src=\"/recruit/inc/image/top/img_cardBusiness.png\" alt=\"山産の事業について\">\n                </picture>\n                <div class=\"p-top-contentsCardL__textarea\">\n                  <h3 class=\"p-top-contentsCardL__title c-ttl-small\">山産の事業について<span class=\"p-top-contentsCardL__arrow\"></span></h3>\n                  <p class=\"p-top-contentsCardL__description\">山産は環境事業と産機事業の両分野において、未来に繋がるビジネスを展開しています。 </p>\n                </div>\n              </a>\n            </div>\n          </div>\n          <div class=\"col-6_sm-12\">\n            <div class=\"p-top-cardAreaR\">\n              <a href=\"/recruit/about/data/\" class=\"p-top-contentsCardR\">\n                <div class=\"p-top-contentsCardR__inner\">\n                  <picture class=\"p-top-contentsCardR__image p-top-contentsCardR__image--data\">\n                    <source srcset=\"/recruit/inc/image/top/img_cardData.png.webp 1x, /recruit/inc/image/top/img_cardData@2x.png.webp 2x\" type=\"image/webp\">\n                    <img src=\"/recruit/inc/image/top/img_cardData.png\" alt=\"数字で見る山産\">\n                  </picture>\n                  <div class=\"p-top-contentsCardR__textarea\">\n                    <h3 class=\"p-top-contentsCardR__title c-ttl-small\">数字で見る山産<span class=\"p-top-contentsCardR__arrow\"></span></h3>\n                    <p class=\"p-top-contentsCardR__description\">山産をより理解していただくために、数字を通して山産の特徴をご紹介します。</p>\n                  </div>\n                </div>\n              </a>\n              <a href=\"/recruit/about/case/\" class=\"p-top-contentsCardR\">\n                <div class=\"p-top-contentsCardR__inner\">\n                  <picture class=\"p-top-contentsCardR__image\">\n                    <source srcset=\"/recruit/inc/image/top/img_cardCase.png.webp 1x, /recruit/inc/image/top/img_cardCase@2x.png.webp 2x\" type=\"image/webp\">\n                    <img src=\"/recruit/inc/image/top/img_cardCase.png\" alt=\"こんなところに山産\">\n                  </picture>\n                  <div class=\"p-top-contentsCardR__textarea\">\n                    <h3 class=\"p-top-contentsCardR__title c-ttl-small\">こんなところに<br class=\"u-only-md\">山産<span class=\"p-top-contentsCardR__arrow\"></span></h3>\n                    <p class=\"p-top-contentsCardR__description\">山産の仕事がどんな所に繋がっているかを、イラストを通じてわかりやすくご紹介します。</p>\n                  </div>\n                </div>\n              </a>\n            </div>\n          </div>\n        </div>\n      </section>\n      <section class=\"p-top-parallelogram js-blueArea-2 p-work\">\n        <div class=\"c-parallelogram-top c-parallelogram-top--hasDecoration\">\n          <img src=\"/recruit/inc/image/top/img_parallelogram-top.svg\" alt=\"\">\n        </div>\n        <div class=\"p-top-parallelogram__container\">\n          <div class=\"p-top-parallelogram__inner\">\n            <a href=\"/recruit/about/work/\" class=\"c-layeredCard\">\n              <div class=\"c-layeredCard__imageArea\">\n                <picture class=\"c-layeredCard__image\">\n                  <source srcset=\"/recruit/inc/image/top/img_layeredCard01.jpg.webp 1x, /recruit/inc/image/top/img_layeredCard01@2x.jpg.webp 2x\" type=\"image/webp\">\n                  <img src=\"/recruit/inc/image/top/img_layeredCard01.jpg\" alt=\"産機事業\">\n                </picture>\n                <picture class=\"c-layeredCard__image\">\n                  <source srcset=\"/recruit/inc/image/top/img_layeredCard02.jpg.webp 1x, /recruit/inc/image/top/img_layeredCard02@2x.jpg.webp 2x\" type=\"image/webp\">\n                  <img src=\"/recruit/inc/image/top/img_layeredCard02.jpg\" alt=\"環境事業\">\n                </picture>\n              </div>\n              <div class=\"c-layeredCard__infoArea\">\n                <div class=\"c-layeredCard__infoArea-inner\">\n                  <h2 class=\"c-ttl-main c-ttl-main c-ttl--center c-ttl--keycolor c-ttl--oblique c-layeredCard__title\">\n                    <span class=\"c-ttl-main__sub\">グレートを創り出す</span> 仕事を知る\n                  </h2>\n                  <div class=\"c-layeredCard__text\">\n                    <p class=\"c-layeredCard__description\">一体、山産ではどんな仕事を行なっているのでしょうか？産業機械事業と環境事業の大きな仕事の流れや大切にしていることをご紹介します。</p>\n                    <div class=\"c-layeredCard__lnik\">\n                      <span class=\"c-layeredCard__linkText\">詳細を見る<span class=\"c-layeredCard__arrow\"></span></span>\n                    </div>\n                  </div>\n                </div>\n              </div>\n            </a>\n          </div>\n        </div>\n        <div class=\"c-parallelogram-bottom c-parallelogram-bottom--hasDecoration\">\n          <img src=\"/recruit/inc/image/top/img_parallelogram-bottom.svg\" alt=\"\">\n        </div>\n      </section>\n      <section class=\"l-section l-section--full p-topInterview\">\n        <h2 class=\"c-ttl-main c-ttl-main c-ttl--center c-ttl--keycolor c-ttl--oblique\">\n          <span class=\"c-ttl-main__sub\">グレートを創り出す</span> 先輩社員の声\n        </h2>\n        <div class=\"swiper-button-prev\"></div>\n        <div class=\"swiper-button-next\"></div>\n        <div class=\"intervewSwiper js-swiper\">\n          <ul class=\"swiper-wrapper\">\n            <li class=\"swiper-slide\">\n              <div class=\"p-topInterview__card\">\n                <a href=\"/recruit/member/interview01\" class=\"c-hasImageCard\">\n                  <picture class=\"c-hasImageCard__image\">\n                    <source srcset=\"/recruit/inc/image/member/pic_interviewCard01.jpg.webp 1x, /recruit/inc/image/member/pic_interviewCard01@2x.jpg.webp 2x\" type=\"image/webp\">\n                    <img src=\"/recruit/inc/image/member/pic_interviewCard01.jpg\" alt=\"D.F.\">\n                  </picture>\n                  <div class=\"c-hasImageCard__text\">\n                    <h4 class=\"c-hasImageCard__title\"><span>自由な裁量で</span><span>自分の仕事に責任を持つ</span></h4>\n                    <div class=\"c-hasImageCardInfo\">\n                      <div class=\"c-hasImageCardInfo__main\">\n                        <span class=\"c-hasImageCard__affiliation\">2021年度入社<br>環境事業グループ 施工管理</span>\n                        <span class=\"c-hasImageCard__name\">D.F.</span>\n                      </div>\n                      <span class=\"c-hasImageCard__arrow c-hasImageCardInfo__arrow\"></span>\n                    </div>\n                  </div>\n                </a>\n              </div>\n            </li>\n            <li class=\"swiper-slide\">\n              <div class=\"p-topInterview__card\">\n                <a href=\"/recruit/member/interview06\" class=\"c-hasImageCard\">\n                  <picture class=\"c-hasImageCard__image\">\n                    <source srcset=\"/recruit/inc/image/member/pic_interviewCard06.jpg.webp 1x, /recruit/inc/image/member/pic_interviewCard06@2x.jpg.webp 2x\" type=\"image/webp\">\n                    <img src=\"/recruit/inc/image/member/pic_interviewCard06.jpg\" alt=\"Y.O.\">\n                  </picture>\n                  <div class=\"c-hasImageCard__text\">\n                    <h4 class=\"c-hasImageCard__title\"><span>提案から完成まで</span><span>独自のスタイルを築く</span></h4>\n                    <div class=\"c-hasImageCardInfo\">\n                      <div class=\"c-hasImageCardInfo__main\">\n                        <span class=\"c-hasImageCard__affiliation\">2021年度入社<br>環境事業グループ 施工管理</span>\n                        <span class=\"c-hasImageCard__name\">Y.O.</span>\n                      </div>\n                      <span class=\"c-hasImageCard__arrow c-hasImageCardInfo__arrow\"></span>\n                    </div>\n                  </div>\n                </a>\n              </div>\n            </li>\n            <li class=\"swiper-slide\">\n              <div class=\"p-topInterview__card\">\n                <a href=\"/recruit/member/interview07\" class=\"c-hasImageCard\">\n                  <picture class=\"c-hasImageCard__image\">\n                    <source srcset=\"/recruit/inc/image/member/pic_interviewCard07.jpg.webp 1x, /recruit/inc/image/member/pic_interviewCard07@2x.jpg.webp 2x\" type=\"image/webp\">\n                    <img src=\"/recruit/inc/image/member/pic_interviewCard07.jpg\" alt=\"S.K.\">\n                  </picture>\n                  <div class=\"c-hasImageCard__text\">\n                    <h4 class=\"c-hasImageCard__title\"><span>関係構築と挑戦</span><span>自分らしく成長する</span></h4>\n                    <div class=\"c-hasImageCardInfo\">\n                      <div class=\"c-hasImageCardInfo__main\">\n                        <span class=\"c-hasImageCard__affiliation\">2020年度入社<br>産機事業グループ 営業</span>\n                        <span class=\"c-hasImageCard__name\">S.K.</span>\n                      </div>\n                      <span class=\"c-hasImageCard__arrow c-hasImageCardInfo__arrow\"></span>\n                    </div>\n                  </div>\n                </a>\n              </div>\n            </li>\n            <li class=\"swiper-slide\">\n              <div class=\"p-topInterview__card\">\n                <a href=\"/recruit/member/interview02\" class=\"c-hasImageCard\">\n                  <picture class=\"c-hasImageCard__image\">\n                    <source srcset=\"/recruit/inc/image/member/pic_interviewCard02.jpg.webp 1x, /recruit/inc/image/member/pic_interviewCard02@2x.jpg.webp 2x\" type=\"image/webp\">\n                    <img src=\"/recruit/inc/image/member/pic_interviewCard02.jpg\" alt=\"Y.T.\">\n                  </picture>\n                  <div class=\"c-hasImageCard__text\">\n                    <h4 class=\"c-hasImageCard__title\"><span>お客様とメーカーの</span><span>架け橋になる </span></h4>\n                    <div class=\"c-hasImageCardInfo\">\n                      <div class=\"c-hasImageCardInfo__main\">\n                        <span class=\"c-hasImageCard__affiliation\">2017年度入社<br>産機事業グループ 営業</span>\n                        <span class=\"c-hasImageCard__name\">Y.T.</span>\n                      </div>\n                      <span class=\"c-hasImageCard__arrow c-hasImageCardInfo__arrow\"></span>\n                    </div>\n                  </div>\n                </a>\n              </div>\n            </li>\n            <li class=\"swiper-slide\">\n              <div class=\"p-topInterview__card\">\n                <a href=\"/recruit/member/interview03\" class=\"c-hasImageCard\">\n                  <picture class=\"c-hasImageCard__image\">\n                    <source srcset=\"/recruit/inc/image/member/pic_interviewCard03.jpg.webp 1x, /recruit/inc/image/member/pic_interviewCard03@2x.jpg.webp 2x\" type=\"image/webp\">\n                    <img src=\"/recruit/inc/image/member/pic_interviewCard03.jpg\" alt=\"K.I.\">\n                  </picture>\n                  <div class=\"c-hasImageCard__text\">\n                    <h4 class=\"c-hasImageCard__title\"><span>人に優しく</span><span>役に立つ仕事を目指す</span></h4>\n                    <div class=\"c-hasImageCardInfo\">\n                      <div class=\"c-hasImageCardInfo__main\">\n                        <span class=\"c-hasImageCard__affiliation\">2017年度入社<br>総務部</span>\n                        <span class=\"c-hasImageCard__name\">K.I.</span>\n                      </div>\n                      <span class=\"c-hasImageCard__arrow c-hasImageCardInfo__arrow\"></span>\n                    </div>\n                  </div>\n                </a>\n              </div>\n            </li>\n            <li class=\"swiper-slide\">\n              <div class=\"p-topInterview__card\">\n                <a href=\"/recruit/member/interview04\" class=\"c-hasImageCard\">\n                  <picture class=\"c-hasImageCard__image\">\n                    <source srcset=\"/recruit/inc/image/member/pic_interviewCard04.jpg.webp 1x, /recruit/inc/image/member/pic_interviewCard04@2x.jpg.webp 2x\" type=\"image/webp\">\n                    <img src=\"/recruit/inc/image/member/pic_interviewCard04.jpg\" alt=\"S.I.\">\n                  </picture>\n                  <div class=\"c-hasImageCard__text\">\n                    <h4 class=\"c-hasImageCard__title\"><span>協力と柔軟性</span><span>山産流仕事の進め方</span></h4>\n                    <div class=\"c-hasImageCardInfo\">\n                      <div class=\"c-hasImageCardInfo__main\">\n                        <span class=\"c-hasImageCard__affiliation\">2011年度入社<br>産機事業グループ 営業</span>\n                        <span class=\"c-hasImageCard__name\">S.I.</span>\n                      </div>\n                      <span class=\"c-hasImageCard__arrow c-hasImageCardInfo__arrow\"></span>\n                    </div>\n                  </div>\n                </a>\n              </div>\n            </li>\n            <li class=\"swiper-slide\">\n              <div class=\"p-topInterview__card\">\n                <a href=\"/recruit/member/interview05\" class=\"c-hasImageCard\">\n                  <picture class=\"c-hasImageCard__image\">\n                    <source srcset=\"/recruit/inc/image/member/pic_interviewCard05.jpg.webp 1x, /recruit/inc/image/member/pic_interviewCard05@2x.jpg.webp 2x\" type=\"image/webp\">\n                    <img src=\"/recruit/inc/image/member/pic_interviewCard05.jpg\" alt=\"H.M.\">\n                  </picture>\n                  <div class=\"c-hasImageCard__text\">\n                    <h4 class=\"c-hasImageCard__title\"><span>インフラを支える</span><span>縁の下の力持ち</span></h4>\n                    <div class=\"c-hasImageCardInfo\">\n                      <div class=\"c-hasImageCardInfo__main\">\n                        <span class=\"c-hasImageCard__affiliation\">2002年度入社<br>環境事業グループ 営業</span>\n                        <span class=\"c-hasImageCard__name\">H.M.</span>\n                      </div>\n                      <span class=\"c-hasImageCard__arrow c-hasImageCardInfo__arrow\"></span>\n                    </div>\n                  </div>\n                </a>\n              </div>\n            </li>\n          </ul>\n