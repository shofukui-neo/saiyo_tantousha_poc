option value=\"沖縄県\"\n>\n\n                                沖縄県</option>\n                            \n                        </select>\n                    </td>\n                </tr>\n                <tr>\n                    <th>\n                        <div class=\"op\">&nbsp;</div>\n                        <div class=\"label\"><label for=\"mail_address\">&nbsp;</label></div>\n                    </th>\n                    <td class=\"pt0\">\n                        <input id=\"mail_address\" class=\"inputText\" name=\"mail_address\" type=\"text\" value=\"\">\n                    </td>\n                </tr>\n            <tr>\n                    <th>\n                        <div class=\"op\">&nbsp;</div>\n                        <div class=\"label\"><label for=\"mail_contact\">お問い合わせ先</label></div>\n                    </th>\n                    <td>\n                    \t\n                        \n                            <div class=\"cellRow\">\n                            \n                                <label id=\"mail_contact_zyutaku\">\n                                    <input type=\"radio\" name=\"mail_contact\" id=\"mail_contact_zyutaku\" class=\"text\" value=\"受託試験\"\n>\n\n                                    受託試験 \n                                <p class=\"fukidashi\">説明文が表示されます</p>\n                                </label>\n                            \n                                <label id=\"mail_contact_voc\">\n                                    <input type=\"radio\" name=\"mail_contact\" id=\"mail_contact_voc\" class=\"text\" value=\"ＶＯＣ\"\n>\n\n                                    ＶＯＣ \n                                <p class=\"fukidashi\">説明文が表示されます</p>\n                                </label>\n                            \n                                <label id=\"mail_contact_zairyou\">\n                                    <input type=\"radio\" name=\"mail_contact\" id=\"mail_contact_zairyou\" class=\"text\" value=\"材料分析\"