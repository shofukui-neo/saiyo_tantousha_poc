.kayama-sakaki.co.jp/img/arrow_mark_gray.gif\" alt=\"\" width=\"9\" height=\"9\" />沿革</a></li>\n<li><a href=\"http://www.kayama-sakaki.co.jp/outline/access.php\"><img class=\"arrow_mark\" src=\"http://www.kayama-sakaki.co.jp/img/arrow_mark_gray.gif\" alt=\"\" width=\"9\" height=\"9\" />アクセス</a></li>\n</ul>\n</li>\n<li id=\"gn-products\"><a href=\"http://www.kayama-sakaki.co.jp/products/\">加工製品</a></li>\n<li id=\"gn-equipment\"><a href=\"http://www.kayama-sakaki.co.jp/equipment/\">設備情報</a>\n<ul class=\"drop\">\n<li><a href=\"http://www.kayama-sakaki.co.jp/equipment/\"><img class=\"arrow_mark\" src=\"http://www.kayama-sakaki.co.jp/img/arrow_mark_gray.gif\" alt=\"\" width=\"9\" height=\"9\" />設備情報</a></li>\n<li><a href=\"http://www.kayama-sakaki.co.jp/equipment/list.php\"><img class=\"arrow_mark\" src=\"http://www.kayama-sakaki.co.jp/img/arrow_mark_gray.gif\" alt=\"\" width=\"9\" height=\"9\" />導入設備</a></li>\n</ul>\n</li>\n<li id=\"gn-associated\"><a href=\"http://www.kayama-sakaki.co.jp/associated/esprit.php\">関連会社</a>\n<ul class=\"drop\">\n<li><a href=\"http://www.kayama-sakaki.co.jp/associated/esprit.php\"><img class=\"arrow_mark\" src=\"http://www.kayama-sakaki.co.jp/img/arrow_mark_gray.gif\" alt=\"\" width=\"9\" height=\"9\" />株式会社エスプリ</a></li>\n<li><a href=\"http://www.kayama-sakaki.co.jp/associated/ket.php\"><img class=\"arrow_mark\" src=\"http://www.kayama-sakaki.co.jp/img/arrow_mark_gray.gif\" alt=\"\" width=\"9\" height=\"9\" />KET</a></li>\n<li><a href=\"http://www.kayama-sakaki.co.jp/associated/thai-akiba.php\"><img class=\"arrow_mark\" src=\"http://www.kayama-sakaki.co.jp/img/arrow_mark_gray.gif\" alt=\"\" width=\"9\" height=\"9\" />THAI AKIBA</a></li>\n</ul>\n</li>\n<li id=\"gn-recruit\"><a href=\"http://www.kayama-sakaki.co.jp/recruit/\">採用情報</a>\n<ul class=\"drop\">\n<li><a href=\"http://www.kayama-sakaki.co.jp/recruit/\"><img class=\"arrow_mark\" src=\"http://www.kayama-sakaki.co.jp/img/arrow_mark_gray.gif\" alt=\"\" width=\"9\" height=\"9\" />採用情報</a></li>\n<li><a href=\"http://www.kayama-sakaki.co.jp/recruit/selection.php\"><img class=\"arrow_mark\" src=\"http://www.kayama-sakaki.co.jp/img/arrow_mark_gray.gif\" alt=\"\" width=\"9\" height=\"9\" />選考方法</a></li>\n<li><a href=\"http://www.kayama-sakaki.co.jp/recruit/guide.php\"><img class=\"arrow_mark\" src=\"http://www.kayama-sakaki.co.jp/img/arrow_mark_gray.gif\" alt=\"\" width=\"9\" height=\"9\" />募集要項</a></li>\n</ul>\n</li>\n<li id=\"gn-contact\"><a href=\"https://kayama-sakaki-cojp.ssl-xserver.jp/contact/\">お問い合わせ</a></li>\n</ul>\n</div>\n</div>\n<!-- end [header] -->\n\n<!-- start [container] -->\n<div id=\"container\">\n\n<!-- start [contents] -->\n<div id=\"contents\" class=\"clearfix\">\n\n<!-- start [topicpath] -->\n<div id=\"topicpath\">\n<div id=\"topicpathInner\">\n<!--メインインデックス部分-->\n<ul>\n<li><a href=\"http://www.kayama-sakaki.co.jp/\">HOME</a> &nbsp;&gt;&nbsp;</li>\n<li><a href=\"http://www.kayama-sakaki.co.jp/recruit/\">採用情報</a> &nbsp;&gt;&nbsp;</li>\n<li>選考方法</li>\n<!--ブログ記事部分-->\n</ul>\n</div>\n</div>\n<!-- end [topicpath] -->\n\n<div id=\"main\">\n<h2 id=\"selection\">採用選考フロー</h2>\n<dl class=\"arrowLine-blue\">\n<dt><img src=\"img/step1.gif\" alt=\"1.お問い合わせ\" width=\"148\" height=\"18\" /></dt>\n<dd><span class=\"emphasis\">募集職務状況については <a href=\"guide.php\">募集要項</a>をご確認の上、お問い合わせ下さい。</span><br />（担当\n総務部長：坂口）</dd>\n</dl>\n<dl class=\"arrowLine-green\">\n<dt><img src=\"img/step2.gif\" alt=\"2.受付\" width=\"148\" height=\"18\" /></dt>\n<dd>お問い合わせののち、履歴書・職務経歴書をご郵送下さい。</dd>\n</dl>\n<dl class=\"arrowLine-Ygreen\">\n<dt><img src=\"img/step3.gif\" alt=\"3.工場見学・面接\" width=\"148\" height=\"18\" /></dt>\n<dd>日程をお知らせいたしますので、指定日時にお越し頂き、実際に働く職場を見たうえで面接を実施します。選考は面接重視ですので、入社を希望される方のことを出来るだけ詳しくお聞きします。志望動機や、今までの職歴・経験・保有資格などもぜひPRしてください。工場見学から面接まで概ね2～3時間程度です。簡単な筆記試験もあります。</dd>\n</dl>\n<dl class=\"arrowLine-blue\">\n<dt><img src=\"img/step4.gif\" alt=\"4.採用\" width=\"148\" height=\"18\" /></dt>\n<dd>採否は採用担当者からお電話でご連絡します。<br />\n採用の場合、次の事前教育日程も合わせてご連絡します。</dd>\n</dl>\n<dl class=\"arrowLine-green\">\n<dt><img src=\"img/step5.gif\" alt=\"5.事前教育\" width=\"148\" height=\"18\" /></dt>\n<dd>就業規則やISO、実務で必要な基礎検具や帳票類の教育、提出書類、制服あわせ、出勤日の説明を行います。</dd>\n</dl>\n<dl class=\"arrowLine-Ygreen\">\n<dt><img src=\"img/step6.gif\" alt=\"6.出勤初日\" width=\"148\" height=\"18\" /></dt>\n<dd>8:15に配属先部門の朝礼で、部門課長から職場の仲間に紹介、いよいよ配属です。<br />\n当日は職場リーダーや先輩社員がOJT指導をします。</dd>\n</dl>\n<dl class=\"dottedLine\">\n<dt><img src=\"img/step7.gif\" alt=\"7.登用ステップ\" width=\"148\" height=\"18\" /></dt>\n<dd><ol>\n<li>&#9312;&nbsp;配属から14日以内に適正（本人自らと会社からの双方）を見極めます。</li>\n<li>&#9313;&nbsp;1ヶ月単位でスキルアップ評価、勤怠評価を部門課長・総務で行います。</li>\n<li>&#9314;&nbsp;試用期間3ヶ月を経て、正社員登用となります。</li>\n</ol></dd>\n</dl>\n\n<div class=\"contactus\">\n<h4 id=\"contact\">採用に関するお問い合わせ</h4>\n<ul>\n<li><img src=\"http://www.kayama-sakaki.co.jp/recruit/tel3.gif\" alt=\"お電話の場合、0268-82-2439 総務部長 坂口まで\" width=\"760\" height=\"75\" /></li>\n<li class=\"formbtn\"><a href=\"https://kayama-sakaki-cojp.ssl-xserver.jp/contact/\"><img src=\"img/btn_contact.png\" alt=\"お問い合わせフォームご利用の場合はこちらから\" width=\"370\" height=\"42\" /></a></li>\n</ul>\n</div>\n</div>\n<div id=\"sub\">\n<h5>採用情報メニュー</h5>\n<ul class=\"menu\">\n<li><a href=\"http://www.kayama-sakaki.co.jp/recruit/\">採用情報</a></li>\n<li class=\"pagehere\"><a href=\"http://www.kayama-sakaki.co.jp/recruit/selection.php\">選考方法</a></li>\n<li class=\"endlist\"><a href=\"http://www.kayama-sakaki.co.jp/recruit/guide.php\">募集要項</a></li>\n</ul>\n<ul class=\"banner\">\n<li><a href=\"http://www.kayama-sakaki.co.jp/associated/esprit.php\"><img src=\"http://www.kayama-sakaki.co.jp/img/sub_banner_esprit.png\" alt=\"株式会社エスプリ\" width=\"190\" height=\"53\" /></a></li>\n<li><a href=\"http://www.kayama-sakaki.co.jp/associated/ket.php\"><img src=\"http://www.kayama-sakaki.co.jp/img/sub_banner_kayamaengine.png\" alt=\"kayama engineering co.,ltd\" width=\"190\" height=\"53\" /></a></li>\n<li><a href=\"http://www.kayama-sakaki.co.jp/associated/thai-akiba.php\"><img src=\"http://www.kayama-sakaki.co.jp/img/sub_banner_taiakiba.png\" alt=\"tai akiba co.,ltd\" width=\"190\" height=\"53\" /></a></li>\n</ul>\n</div>\n</div>\n<!-- end [contents] -->\n\n</div>\n<!-- end [container] -->\n\n<!-- start [footer] --> \n<div id=\"footer\">\n<div id=\"footerInner\" class=\"clearfix\">\n<dl id=\"address\">\n<dt>株式会社カヤマ</dt>\n<dd>〒389-0601 長野県埴科郡坂城町大字坂城4487-1</dd>\n<dd>TEL.0268-82-2439（代） FAX.0268-82-2904</dd>\n<!--dd>E-mail : info@kayama-sakaki.co.jp</dd -->\n<dd>株式会社カヤマはIATF16949, ISO14001認証取得事業所です</dd>\n</dl>\n<div id=\"footernavi\">\n<ul>\n<li><a href=\"http://www.kayama-sakaki.co.jp/\">HOME</a></li>\n<li><a href=\"http://www.kayama-sakaki.co.jp/information/\">お知らせ</a></li>\n<li><a href=\"http://www.kayama-sakaki.co.jp/outline/\">会社情報</a></li>\n<li><a href=\"http://www.kayama-sakaki.co.jp/products/\">加工製品</a></li>\n</ul>\n<ul>\n<li><a href=\"http://www.kayama-sakaki.co.jp/equipment/\">設備情報</a></li>\n<li><a href=\"http://www.kayama-sakaki.co.jp/associated/esprit.php\">関連会社</a></li>\n<li><a href=\"http://www.kayama-sakaki.co.jp/recruit/\">採用情報</a></li>\n<li><a href=\"http://www.kayama-sakaki.co.jp/contact/\">お問い合わせ</a></li>\n</ul>\n<ul class=\"listend\">\n<li><a href=\"http://www.kayama-sakaki.co.jp/outline/access.php\">アクセス</a></li>\n<!-- <li><a href=\"\">ENGLISH</a></li> -->\n<li><a href=\"http://www.kayama-sakaki.co.jp/policy/\">個人情報保護方針</a></li>\n<li><a href=\"http://www.kayama-sakaki.co.jp/sitemap/\">サイトマップ</a></li>\n</ul>\n</div>\n<div class=\"pagetop fr\">\n<p id=\"toTop\"><a href=\"#wrapper\"><img src=\"http://www.kayama-sakaki.co.jp/img/pagetop.png\" alt=\"ページの先頭へ\" width=\"92\" height=\"13\" /></a></p>\n</div>\n</div>\n<div id=\"footerUnder\">\n<div id=\"underInner\">\n<p class=\"copyright\">Copyright&nbsp;&copy; 2026 KAYAMA. Co.,Ltd. All Rights Reserved.</p>\n</div>\n</div>\n</div>\n<!-- end [footer] -->\n\n</div>\n<!-- end [wrapper] -->\n</body>\n</html>","finalUrl":"http://www.kayama-sakaki.co.jp/recruit/selection.php","rendered":false,"_cachedAt":"2026-06-