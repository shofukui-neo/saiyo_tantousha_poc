     var elemPos = $(this).offset().top;\n            var scroll = $(window).scrollTop();\n            var windowHeight = $(window).height();\n            if (scroll > elemPos - windowHeight + 200){\n                $(this).addClass('scrollin');\n            }\n        });\n    });\n});\n</script>\n<script src=\"https://ajax.googleapis.com/ajax/libs/jquery/3.3.1/jquery.min.js\"></script>\n<script>$(function () {\n    var target1 = $(\"#parallax-01\");\n    var targetPosOT1 = target1.offset().top;\n    var targetFactor = 0.5;\n    var windowH = $(window).height();\n    var scrollYStart1 = targetPosOT1 - windowH;\n    $(window).on('scroll', function () {\n        var scrollY = $(this).scrollTop();\n        if (scrollY > scrollYStart1) {\n            target1.css('background-position-y', (scrollY - targetPosOT1) * targetFactor + 'px');\n        } \n    });\n});\t\n</script>\n\t\n<body>\n\t\n\n<!-----ここからヘッダー-----> \n\n<div class=\"header\">\n<div class=\"container\">\n\t<div class=\"header-left\">\n\t<h1>\n      <a href=\"index.html\"><img class=\"logo\" src=\"img/logo_yamasaki.svg\" alt=\"yamasaki_logo\"></a>\n    </h1>\n\t</div>\n    <nav>\n\t<div class=\"header-right\">\n<header class=\"top_menu\">\t\n    <ul class=\"top-menu-list\">\n\t\t<li><a href=\"index.html\">トップページ</a></li>\n\t\t<li><a href=\"company.html\">会社案内</a></li>\n        <li><a href=\"#\">業務案内</a>\n            <ul>\n \t    <li><a href=\"business01.html\">清掃管理業務</a></li>\n\t\t<li><a href=\"business02.html\">環境衛生管理業務</a></li>\n\t\t<li><a href=\"business03.html\">設備管理業務</a></li>\n\t\t<li><a href=\"business04.html\">産業廃棄物収集運搬管理業務</a></li>\t\t\n            </ul>\n        </li>\n        <li><a href=\"recruit.html\">求人情報</a></li>\n\t\t<li><a href=\"contact.html\">お問い合わせ</a></li>\n    </ul>\n\t</header>\n\t</div>\n\t</nav>\n\t    <!-----スマホメニューバー----->\n    <div class=\"hamburger-menu\">\n        <input type=\"checkbox\" id=\"menu-btn-check\">\n        <label for=\"menu-btn-check\" class=\"menu-btn\"><span></span></label>\n\t\t<!--ここからメニュー-->\n        <div class=\"menu-content\">\n            <ul>\n                <li>\n                    <a href=\"index.html\">トップページ</a>\n                </li>\n                <li>\n                    <a href=\"company.html\">会社案内</a>\n                </li>\n                <li>\n                    <a href=\"business01.html\">清掃管理業務</a>\n                </li>\n                <li>\n                    <a href=\"business02.html\">環境衛生管理業務</a>\n                </li>\n\t\t\t    <li>\n                    <a href=\"business03.html\">設備管理業務</a>\n                </li>\n                <li>\n                    <a href=\"business04.html\">産業廃棄物収集運搬業務</a>\n                </li>\n\t\t\t\t <li>\n                    <a href=\"recruit.html\">求人情報</a>\n                </li>\n\t\t\t\t<li>\n                    <a href=\"contact.html\">お問い合わせ</a>\n                </li>\n\t\t\t</ul>\n        </div>\n</div>\t\t\n <!--ここまでスマホメニュー-->  \n\t</div>\n</div>\n\n\t\n\n\n\t\n\n<!------トップ画像------>\n\t\n<div class=\"top_page_visual\">\n  <div class=\"top_page_title_wrap\">\n    <div class=\"top_page_visual_title\">株式会社山﨑ビル環境サービス</div>\t\n  </div>\t\n</div> \n  \n<div class=\"top_page_wrap\">\n<div class=\"top_page_title_wrap\">\n\t<div class=\"top-title\"><img class=\"slogan01\" src=\"img/slogan01.svg\" alt=\"slogan\"></div>\n\t<p class=\"messege_coments\">私たちはさまざまな環境をよくするために努力します。\n\t  より良い働く環境の基、最高水準のメンテナンス技術を十二分に生かし建物利用者が快適に過ごしていただけるような環境を創造します。\n\t  また、地域の環境美化、自然環境の保全・保護にも取り組んで参ります。</p>\n<a href=\"company.html\"><div class=\"company_info_top_page\">会社案内</div></a></div>\n<div class=\"mission-box\">\n\n<div class=\"mission-box\">\n<div class=\"top_img\"><img class=\"top_img\" src=\"img/top_img_02.jpg\" alt=\"top_img_02\"></div>\t\n</div>\n<div class=\"business_illsut_info\">\n  <p>わたしたちのお仕事</p>\n</div>\n<div class=\"business_illust_wrap\"><div class=\"business_illust\"><img class=\"business_illust_img\" src=\"img/business_illust02.jpg\" alt=\"top_img_02\"></div></div>\t\n<!-----清掃管理について----->\t\n<div class=\"business_list_back\">\n\t\n\t\n<div class=\"business01_top_page_wrap\">\n\t\n<div class=\"business01_title_top_page_box\"><h2 class=\"business01_title_top_page\">清掃管理業務</h2></div>\n\t\n\t\n<div class=\"category\">\n  <div class=\"box_category\">\t\n\t<div class=\"box_category_left\">\n    <div><h3 class=\"title_03\">大型商業施設からオフィスビル一般家庭まで様々な清掃業務を行っております。</h3></div>\t\n\t\t<ul class=\"business_list\">\n\t\t\t<li>日常清掃</li>\n\t\t\t<li>定期清掃</li>\n\t\t    <li>特別清掃</li>\n\t\t    <li>客室清掃</li>\n\t\t\t<li>エアコンクリーニング</li>\n\t\t\t<li>ガラス清掃</li>\n\t\t    <li>外壁面清掃</li>\n\t\t    <li>ハウスクリーニング</li>\n\t\t\t<li>新築建物の施工清掃</li>\n\t\t    <li>除草・剪定業務</li>\n\t\t    <li>特殊清掃</li>\n\t\t</ul>\n\t</div>\n\t\n\t<div class=\"box_category_right01\"><img src=\"img/category01_img_top-page.jpg\" alt=\"category01\" width=\"414\" class=\"box_category_right01_img\">\n\t</div>\n　</div>\n</div>\n<a href=\"business01.html\"><div class=\"business01_info_top_page\">清掃管理業務について</div></a>\n\n</div>\t\n\t\n\t\n<!-----環境衛生管理について----->\n\n<div class=\"business02_top_page_wrap\">\t\n\t\n<div class=\"business02_title_top_page_box\"><h2 class=\"business02_title_top_page\">環境衛生管理業務</h2></div>\n\t\n<div class=\"category\">\n  <div class=\"box_category\">\t\n\t<div class=\"box_category_left\">\n    <div><h3 class=\"title_03\">専門の技術者により測定を定期的に行い\n法令を遵守した衛生管理を行います。</h3></div>\t\n\t\t<ul class=\"business_list\">\n\t\t\t<li>貯水槽清掃</li>\n\t\t\t<li>排水管清掃</li>\n\t\t    <li>空気環境測定</li>\n\t\t\t<li>照度測定</li>\n\t\t    <li>消毒業務</li>\n\t\t\t<li>害虫防除業務</li>\n\t\t</ul>\n\t</div>\n\t\n\t<div class=\"box_category_right\"><img class=\"box_category_right_img\" src=\"img/category02_img_top-page.jpg\" alt=\"category01\">\n\t</div>\n　</div>\n</div>\n<a href=\"business02.html\"><div class=\"business02_info_top_page\">環境衛生管理業務について</div></a>\n</div>\t\n<!-----設備管理について----->\n\n<div class=\"business03_top_page_wrap\">\n\t\n<div class=\"business03_title_top_page_box\"><h2 class=\"business03_title_top_page\">設備管理業務</h2></div>\n\t\n<div class=\"category\">\n  <div class=\"box_category\">\t\n\n\t\t<div class=\"box_category_left\">\n    <div><h3 class=\"title_03\">建物を安全で心地よい場所にするため、設備が正常に稼働しているか管理します</h3></div>\t\n\t\t<ul class=\"business_list\">\n\t\t\t<li>建物設備定期点検</li>\n\t\t\t<li>特定建設物定期調査</li>\n\t\t    <li>巡回設備点検</li>\n\t\t    <li>消防設備点検</li>\n\t\t\t<li>空調機保守点検</li>\n\t\t</ul>\n\t</div>\n\t<div class=\"box_category_right03\"><img class=\"box_category_right03_img\" src=\"img/category03_img_top-page.jpg\" alt=\"category01\"></div>\n　</div>\n</div>\n<a href=\"business03.html\"><div class=\"business03_info_top_page\">設備管理業務について</div></a>\n</div>\t\n<!----産業廃棄物収集運搬業務について----->\n\n<div class=\"business04_top_page_wrap\">\t\n\t\n<div class=\"business04_title_top_page_box\"><h2 class=\"business04_title_top_page\">産業廃棄物収集運搬業務</h2></div>\n\t\n<div class=\"category\">\n  <div class=\"box_category\">\t\n\t<div class=\"box_category_left\">\n    <div><h3 class=\"title_03\">強力吸引車(ダンパー車)で汚泥を回し、処分場まで安全に運搬します。</h3></div>\t\n\t\t<ul class=\"business_list\">\n\t\t\t<li>グリストラップ清掃</li>\n\t\t\t<li>側溝清掃</li>\n\t\t\t<li>雑排水槽清掃</li>\n\t\t\t<li>清掃時剥離廃液収集運搬</li>\n\t\t    <li>＊汚泥・廃アルカリ収集運搬許可</li>\n\t\t</ul>\n\t</div>\n\t\n\t<div class=\"box_category_right04\"><img class=\"box_category_right04_img\" src=\"img/category04_img_top-page.jpg\" alt=\"category01\">\n\t</div>\n　</div>\n</div>\n<a href=\"business04.html\"><div class=\"business04_info_top_page\">産業廃棄物収集運搬業務について</div></a>\n</div>\t\n</div> <!-----ビジネスバックグラウンド----->\n<!-----求人情報について----->\n\t\n\t\n<div class=\"business05_title_top_page_box\"><h2 class=\"business05_title_top_page\">自分にあった働き方、<br>見つけませんか？</h2></div>\n\t\n<div class=\"mission-box_02\">\t\t\n<div class=\"first-v2\" id=\"parallax-01\">\n\t<p class=\"coments\">求人募集中！<p class=\"coments02\">弊社は働きやすい環境作りを目指しています。</p></p>\n</div>\n</div>\n\t\t\n<div class=\"rec_top_page\">\n<div><h3 class=\"title_02\">時間、場所、期間等ご要望を教えてください！</h3></div>\n\t<p class=\"description_merit\">弊社では、常時一緒に働いてくれる従業員を募集しております。\n清掃業務といっても仕事は様々。病院やデパート、ビルやマンション等、場所も時間帯も様々。\nあなたの働きやすい場所で時間帯でご相談いただければ、ぴったりのお仕事が見つかるかも。\n是非一度ご相談ください。\nまた、弊社ではより良い働く環境づくりを目指しています。\n短期間の体験就業も可能ですので、お気軽にお問い合わせください。</p>\t\n <div class=\"box_rec\">\t\n\t<div class=\"box_rec_left\">\n    <img class=\"box_rec_left\" src=\"img/rec01_img.jpg\" alt=\"oruso\">\n\t</div>\n\t<div class=\"box_rec_right\"><img class=\"box_rec_right\" src=\"img/rec02_img.jpg\" alt=\"oruso\">\n\t</div>\n\t<div class=\"box_rec_left\"><img class=\"box_rec_left\" src=\"img/rec03_img.jpg\" alt=\"oruso\">\n\t</div>\n\t<div class=\"box_rec_right\"><img class=\"box_rec_right\" src=\"img/rec04_img.jpg\" alt=\"oruso\">\n\t</div>\n</div>\n<a href=\"recruit.html\"><div class=\"rec_info_top_page\">求人情報</div></a>\t\n</div>\n\n</div>\t<!-----top_page_wrap----->\n\t\n</div>\t\n<footer>\t\t\n<div class=\"wrapper-fotter\">\n\n <div class=\"fotter-size\">\t\n\t<div class=\"toiawase-fotter\">\n\t  <p>&nbsp;</p>\n\t  <p>お問い合わせ先</p>\n\t</div>\n\t\n <div class=\"boxA-honten\">\n    <ul class=\"miseinfo-miyazaki-f\">\n\t\t\n\t <li>株式会社山﨑ビル環境サービス</li>\n\t <li>住所&emsp;880-0844</li>\n\t <li>宮崎県宮崎市柳丸町32番地</li>\n\t <li>電話番号&emsp;0985-22-9551</li>\n\t <li>FAX番号&emsp;0985-22-9552</li>\n\t <li>https://www.ybks.co.jp</li>\n\t <li>支店&emsp;延岡営業所・都城営業所・福岡営業所・鹿児島営業所</li>\n\t</ul> \n </div>\n \n <div class=\"boxC-menu\">\n  <ul class=\"toriatukai\">\n\t<li class=\"box_top\">事業概要</li>\n\t<a href=\"company.html\"><li>会社案内</li></a>\n\t<a href=\"recruit.html\"><li>求人情報</li> </a>\n\t<a href=\"contact.html\"><li>お問い合わせ</li></a>\n\t<a href=\"privacypolicy.html\"><li>個人情報取扱について</li></a>  \n   </ul>\n  </div>   \n\t<div class=\"boxC-menu\">\n  <ul class=\"toriatukai\"> \n\t<li class=\"box_top\">事業内容</li>  \n\t<a href=\"business01.html\"><li>清掃管理業務</li></a>\n\t<a href=\"business02.html\"><li>環境衛生管理業務</li></a>\n\t<a href=\"business03.html\"><li>設備管理業務</li></a>  \n\t<a href=\"business04.html\"><li>産業廃棄物収集運搬業務</li></a>     \n\t\n   </ul>\n  </div>  \n\t</div>\t \n\n\t\n\