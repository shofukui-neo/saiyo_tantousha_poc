)')\n      .replace('{', '\\\\{')\n      .replace('}', '\\\\}')\n      .replace('[', '\\\\[')\n      .replace(']', '\\\\]')\n      .replace('$', '\\\\$')\n     ;\n     if (external_url.match(new RegExp('^' + url))) {\n      url_exists = true;\n      break;\n     }\n    }\n    $('[data-external-url]').text(external_url).show();\n    $('[data-external-close]').show();\n    if (!url_exists) {\n     $('[data-external-message]').html('このホームページへの移動は許可されていません。').show();\n     $('[data-external-button]').hide().off('click');\n    } else {\n     $('[data-external-message]').html('10秒後に自動的にページへ移動します。<br>画面を自動的に読み込まない場合は、下のリンクボタンをクリックしてください。').show();\n     $('[data-external-button]').show();\n     setTimeout(function() {\n      if ($('[data-external-button]:visible').length) window.location.href = external_url;\n     }, 10000);\n    }\n    $(document).on('click', '[data-external-button]', function() {\n     window.location.href = external_url;\n    });\n    $(document).on('click', '[data-external-close]', function() {\n     window.close();\n    });\n   });\n  });\n  $(window).trigger('document_ready');\n\n </script>\n <!-- Google Tag Manager --><noscript><iframe src=\"//www.googletagmanager.com/ns.html?id=GTM-PWPG4R\" height=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript><script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src='//www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);})(window,document,'script','dataLayer','GTM-PWPG4R');</script><!-- End Google Tag Manager -->\n</body>\n\n</html>\n","finalUrl":"https://www.chugin.co.jp/link_page.html?","rendered":false,"_cachedAt":"2026-06-23T16:24:48.864Z"}