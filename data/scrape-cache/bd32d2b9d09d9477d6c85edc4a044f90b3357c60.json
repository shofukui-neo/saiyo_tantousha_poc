{"url":"https://rococoweb.co.jp/entry/","html":"<!DOCTYPE html>\n<html class=\"no-js\" lang=\"ja\">\n  <head>\n    <meta charset=\"UTF-8\" />\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n    <link rel=\"profile\" href=\"https://gmpg.org/xfn/11\" />\n    <title>エントリーフォーム | ロココ</title>\n    <link rel=\"canonical\" href=\"https://rococoweb.co.jp/entry/\" />\n    <script type=\"text/javascript\">\n      window.ga =\n        window.ga ||\n        function () {\n          (ga.q = ga.q || []).push(arguments);\n        };\n      ga.l = +new Date();\n      ga(\"create\", \"UA-164909322-1\", \"auto\");\n      // Plugins\n      ga(\"require\", \"outboundLinkTracker\");\n      ga(\"send\", \"pageview\");\n    </script>\n    <script async src=\"https://www.google-analytics.com/analytics.js\"></script>\n    <link rel=\"stylesheet\" href=\"../css/contact.css\" media=\"all\" />\n    <link\n      rel=\"stylesheet\"\n      id=\"parent-style-css\"\n      href=\"../css/style.css\"\n      media=\"all\"\n    />\n    <link\n      rel=\"stylesheet\"\n      id=\"twentytwenty-style-css\"\n      href=\"../css/child-style.css\"\n      media=\"all\"\n    />\n    <style id=\"custom-background-css\">\n      body.custom-background {\n        background-color: #ffffff;\n      }\n    </style>\n    <script src=\"../js/jquery-3.7.0.min.js\"></script>\n    <script\n      src=\"https://www.googletagmanager.com/gtag/js?id=UA-164909322-1\"\n      async\n    ></script>\n    <script>\n      window.dataLayer = window.dataLayer || [];\n      function gtag() {\n        dataLayer.push(arguments);\n      }\n      gtag(\"js\", new Date());\n      gtag(\"config\", \"UA-164909322-1\", { anonymize_ip: true });\n    </script>\n    <link\n      rel=\"icon\"\n      href=\"../img/uploads/2020/04/cropped-icon-32x32.png\"\n      sizes=\"32x32\"\n    />\n    <link\n      rel=\"icon\"\n      href=\"../img/uploads/2020/04/cropped-icon-192x192.png\"\n      sizes=\"192x192\"\n    />\n    <link\n      rel=\"apple-touch-icon\"\n      href=\"../img/uploads/2020/04/cropped-icon-180x180.png\"\n    />\n    <link\n      rel=\"stylesheet\"\n      href=\"https://use.fontawesome.com/releases/v5.15.4/css/all.css\"\n    />\n    <link href=\"../js/slick-theme.css\" rel=\"stylesheet\" type=\"text/css\" />\n    <link href=\"../js/slick.css\" rel=\"stylesheet\" type=\"text/css\" />\n    <script src=\"../js/slick.min.js\" type=\"text/javascript\"></script>\n    <script>\n      $(function () {\n        $(\"#job_wrap dt\").on(\"click\", function () {\n          $(this).next().slideToggle();\n          //$(\".fa-chevron-down\").rotate({ angle: 0,animateTo: 180,easing: $.easing.easeInOutExpo });\n        });\n      });\n    </script>\n  </head>\n\n  <body\n    data-rsssl=\"1\"\n    class=\"page-template page-template-recruit page-template-entry page-template-recruitentry-php page page-id-69 custom-background wp-custom-logo wp-embed-responsive singular missing-post-thumbnail has-no-pagination not-showing-comments show-avatars entry footer-top-visible reduced-spacing\"\n  >\n    <a class=\"skip-link screen-reader-text\" href=\"#site-content\"\n      >コンテンツへスキップ</a\n    >\n    <header id=\"site-header\" class=\"header-footer-group\" role=\"banner\">\n      <div class=\"header-inner section-inner\">\n        <div class=\"header-navi_top\">\n          <div class=\"header-titles-wrapper\">\n            <div class=\"header-titles\">\n              <div class=\"site-logo faux-heading\">\n                <a href=\"../\" class=\"custom-logo-link\" rel=\"home\"\n                  ><img\n                    width=\"213\"\n                    height=\"42\"\n                    style=\"height: 42px\"\n                    src=\"../img/uploads/2020/04/logo.png\"\n                    class=\"custom-logo\"\n                    alt=\"株式会社ロココ\"\n                    srcset=\"\n                      ../img/uploads/2020/04/logo.png        426w,\n                      ../img/uploads/2020/04/logo-300x59.png 300w\n                    \"\n                    sizes=\"(max-width: 426px) 100vw, 426px\" /></a\n                ><span class=\"screen-reader-text\">ロココ</span>\n              </div>\n            </div>\n            <!-- .header-titles -->\n            <!--　モバイル用ハンバーガー　-->\n            <!--\n\t\t\t\t\t\t<button class=\"toggle nav-toggle mobile-nav-toggle\" data-toggle-target=\".menu-modal\"  data-toggle-body-class=\"showing-menu-modal\" aria-expanded=\"false\" data-set-focus=\".close-nav-toggle\">\n\t\t\t\t\t\t\t<span class=\"toggle-inner\">\n\t\t\t\t\t\t\t\t<span class=\"toggle-icon\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t</span>\n\t\t\t\t\t\t\t\t<span class=\"toggle-text\"></span>\n\t\t\t\t\t\t\t</span>\n\t\t\t\t\t\t</button>\n-->\n            <!-- .nav-toggle -->\n          </div>\n          <!-- .header-titles-wrapper -->\n\n          <div class=\"header_recruite_navi\">\n            <nav>\n              <ul>\n                <li\n                  id=\"menu-item-63\"\n                  class=\"menu-item menu-item-type-custom menu-item-object-custom menu-item-63\"\n                >\n                  <a href=\"../recruit/#contact\"\n                    ><i class=\"far fa-envelope\"></i\n                  ></a>\n                </li>\n                <li\n                  id=\"menu-item-62\"\n                  class=\"menu-item menu-item-type-custom menu-item-object-custom menu-item-62\"\n                >\n                  <a href=\"../recruit/\"\n                    ><p class=\"header_square_recruit\">採用情報</p></a\n                  >\n                </li>\n              </ul>\n            </nav>\n          </div>\n        </div>\n      </div>\n      <!-- .header-inner -->\n    </header>\n    <!-- #site-header -->\n\n    <div\n      class=\"menu-modal cover-modal header-footer-group\"\n      data-modal-target-string=\".menu-modal\"\n    >\n      <div class=\"menu-modal-inner modal-inner\">\n        <div class=\"menu-wrapper section-inner\">\n          <div class=\"menu-top\">\n            <button\n              class=\"toggle close-nav-toggle fill-children-current-color\"\n              data-toggle-target=\".menu-modal\"\n              data-toggle-body-class=\"showing-menu-modal\"\n              aria-expanded=\"false\"\n              data-set-focus=\".menu-modal\"\n            >\n              <span class=\"toggle-text\">メニューを閉じる</span>\n              <svg\n                class=\"svg-icon\"\n                aria-hidden=\"true\"\n                role=\"img\"\n                focusable=\"false\"\n                xmlns=\"http://www.w3.org/2000/svg\"\n                width=\"16\"\n                height=\"16\"\n                viewBox=\"0 0 16 16\"\n              >\n                <polygon\n                  fill=\"\"\n                  fill-rule=\"evenodd\"\n                  points=\"6.852 7.649 .399 1.195 1.445 .149 7.899 6.602 14.352 .149 15.399 1.195 8.945 7.649 15.399 14.102 14.352 15.149 7.899 8.695 1.445 15.149 .399 14.102\"\n                />\n              </svg></button\n            ><!-- .nav-toggle -->\n\n            <nav class=\"mobile-menu\" aria-label=\"モバイル\" role=\"navigation\">\n              <ul class=\"modal-menu reset-list-style\">\n                <li\n                  id=\"menu-item-73\"\n                  class=\"menu-item menu-item-type-custom menu-item-object-custom menu-item-73\"\n                >\n                  <div class=\"ancestor-wrapper\">\n                    <a href=\"../#about\">私たちについて</a>\n                  </div>\n                  <!-- .ancestor-wrapper -->\n                </li>\n                <li\n                  id=\"menu-item-74\"\n                  class=\"menu-item menu-item-type-custom menu-item-object-custom menu-item-74\"\n                >\n                  <div class=\"ancestor-wrapper\">\n                    <a href=\"../#message\">ヒストリー</a>\n                  </div>\n                  <!-- .ancestor-wrapper -->\n                </li>\n                <li\n                  id=\"menu-item-75\"\n                  class=\"menu-item menu-item-type-custom menu-item-object-custom menu-item-75\"\n                >\n                  <div class=\"ancestor-wrapper\">\n                    <a href=\"../#company_overview\">会社概要</a>\n                  </div>\n                  <!-- .ancestor-wrapper -->\n                </li>\n                <li\n                  id=\"menu-item-76\"\n                  class=\"menu-item menu-item-type-custom menu-item-object-custom menu-item-76\"\n                >\n                  <div class=\"ancestor-wrapper\">\n                    <a href=\"../#access\">アクセス</a>\n                  </div>\n                  <!-- .ancestor-wrapper -->\n                </li>\n              </ul>\n            </nav>\n          </div>\n          <!-- .menu-top -->\n\n          <div class=\"menu-bottom\"></div>\n          <!-- .menu-bottom -->\n        </div>\n        <!-- .menu-wrapper -->\n      </div>\n      <!-- .menu-modal-inner -->\n    </div>\n    <!-- .menu-modal -->\n\n    <main id=\"site-content\" role=\"main\">\n      <section id=\"job_description\">\n        <div class=\"title\">\n          <div class=\"red_box\"><div class=\"white_box\"></div></div>\n          <p>Application information</p>\n          <h2>募集要項</h2>\n        </div>\n        <table>\n          <tr>\n            <th>雇用形態</th>\n            <td>\n              正社員・契約社員<br />\n              <span\n                >※入社から半年間は契約社員になります。期間中の待遇に違いはありません。</span\n              >\n            </td>\n          </tr>\n          <tr>\n            <th>勤務地・交通</th>\n            <td>\n              大阪府大阪市中央区博労町1-8-8 ピカソ堺筋本町ビル5階<br />\n              ※転勤はありません。<br />\n              <p>\n                <span>大阪メトロ各線「堺筋本町駅」7号出入口より徒歩5分</span\n                ><br />\n                <span>大阪メトロ各線「長堀橋駅」1号出入口より徒歩5分</span>\n              </p>\n            </td>\n          </tr>\n          <tr>\n            <th>勤務時間</th>\n            <td>9：00～18：00（実働8時間）</td>\n          </tr>\n          <tr>\n            <th>給与</th>\n            <td>\n              月給25万円～30万円<br />\n              <span>※能力・年齢等を考慮の上で決定します。</span><br />\n              <span\n                >※上記には固定残業代\n                月40時間分5万6100円を含みます。時間超過分は追加支給いたします。</span\n              >\n            </td>\n          </tr>\n          <tr>\n            <th>休日休暇</th>\n            <td>\n              完全週休2日制（シフト制）<br />\n              年末年始休暇（5日）<br />\n              有給休暇（100％取得を推奨）<br />\n              慶弔休暇\n            </td>\n          </tr>\n          <tr>\n            <th>福利厚生・待遇</th>\n            <td>\n              昇給年2回（3月、9月）<br />\n              賞与年2回<br />\n              交通費支給（月1万5000円まで）<br />\n              社会保険完備（雇用・労災・健康・厚生年金）<br />\n              時間外手当<br />\n              服装・髪型自由<br />\n              社員割引制度<br />\n              飲み物補助（コーヒー1杯20円）\n            </td>\n          </tr>\n        </table>\n      </section>\n\n      <div class=\"arrow\"><i class=\"fas fa-chevron-down\"></i></div>\n\n      <section id=\"entry\">\n        <div class=\"title\">\n          <div class=\"red_box\"><div class=\"white_box\"></div></div>\n          <p>Entry form</p>\n        </div>\n        <h2>エントリーする</h2>\n        <p class=\"entry_txt\">\n          弊社にご興味をお持ち頂いた方は、下記のエントリーフォームよりご応募いただき、履歴書・職務経歴書をメールにてお送りください。\n        </p>\n        <div class=\"entry_form\">\n          <div role=\"form\" class=\"wpcf7\" id=\"entry_form\" lang=\"ja\" dir=\"ltr\">\n            <div class=\"screen-reader-response\"></div>\n            <form\n              action=\"#\"\n              method=\"post\"\n              class=\"wpcf7-form\"\n              novalidate=\"novalidate\"\n            >\n              <input type=\"hidden\" name=\"mail_sent\" value=\"\" />\n              <input type=\"hidden\" name=\"mailform_token\" value=\"\" />\n              <p>\n                <label>\n                  お名前 <span class=\"cation\">(必須)</span><br />\n                  <span class=\"wpcf7-form-control-wrap your-name\"\n                    ><input\n                      type=\"text\"\n                      name=\"your-name\"\n                      value=\"\"\n                      size=\"40\"\n                      class=\"wpcf7-form-control wpcf7-text wpcf7-validates-as-required\"\n                      aria-required=\"true\"\n                      aria-invalid=\"false\"\n                  /></span>\n                </label>\n              </p>\n              <p>\n                <label>\n                  性別 <span class=\"cation\">(必須)</span><br />\n                  <span class=\"wpcf7-form-control-wrap radio-229\"\n                    ><span class=\"wpcf7-form-control wpcf7-radio\"\n                      ><span class=\"wpcf7-list-item first\"\n                        ><input\n                          type=\"radio\"\n                          name=\"radio-229\"\n                          value=\"男性\"\n                          checked=\"checked\"\n                        /><span class=\"wpcf7-list-item-label\">男性</span></span\n                      ><span class=\"wpcf7-list-item last\"\n                        ><input\n                          type=\"radio\"\n                          name=\"radio-229\"\n                          value=\"女性\"\n                        /><span class=\"wpcf7-list-item-label\">女性</span></span\n                      ></span\n                    ></span\n                  ></label\n                >\n              </p>\n              <p>\n                <label>\n                  年齢 <span class=\"cation\">(必須)</span><br />\n                  <span class=\"wpcf7-form-control-wrap number-393\"\n                    ><input\n                      type=\"number\"\n                      name=\"number-393\"\n                      value=\"\"\n                      class=\"wpcf7-form-control wpcf7-number wpcf7-validates-as-required wpcf7-validates-as-number\"\n                      min=\"18\"\n                      max=\"65\"\n                      aria-required=\"true\"\n                      aria-invalid=\"false\" /></span\n                ></label>\n              </p>\n              <p>\n                <label>\n                  ご住所 <span class=\"cation\">(必須)</span><br />\n                  <span class=\"wpcf7-form-control-wrap textarea-71\">\n                    <textarea\n                      name=\"textarea-71\"\n                      cols=\"40\"\n                      rows=\"10\"\n                      class=\"wpcf7-form-control wpcf7-textarea wpcf7-validates-as-required\"\n                      aria-required=\"true\"\n                      aria-invalid=\"false\"\n                    ></textarea></span\n                ></label>\n              </p>\n              <p>\n                <label>\n                  メールアドレス <span class=\"cation\">(必須)</span><br />\n                  <span class=\"wpcf7-form-control-wrap your-email\"\n                    ><input\n                      type=\"email\"\n                      name=\"your-email\"\n                      value=\"\"\n                      size=\"40\"\n                      class=\"wpcf7-form-control wpcf7-text wpcf7-email wpcf7-validates-as-required wpcf7-validates-as-email\"\n                      aria-required=\"true\"\n                      aria-invalid=\"false\"\n                  /></span>\n                </label>\n              </p>\n              <p>\n                <label>\n                  電話番号 <span class=\"cation\">(必須)</span><br />\n                  <span class=\"wpcf7-form-control-wrap tel-435\"\n                    ><input\n                      type=\"tel\"\n                      name=\"tel-435\"\n                      value=\"\"\n                      size=\"40\"\n                      class=\"wpcf7-form-control wpcf7-text wpcf7-tel wpcf7-validates-as-required wpcf7-validates-as-tel\"\n                      aria-required=\"true\"\n                      aria-invalid=\"false\"\n                  /></span>\n                </label>\n              </p>\n              <p>\n                <label>\n                  希望職種 <span class=\"cation\">(必須)</span><br />\n                  <span class=\"wpcf7-form-control-wrap menu-973\"\n                    ><select\n                      name=\"menu-973\"\n                      class=\"wpcf7-form-control wpcf7-select wpcf7-validates-as-required\"\n                      aria-required=\"true\"\n                      aria-invalid=\"false\"\n                    >\n                      <option value=\"\">---</option>\n                      <!--<option value=\"MD部\">MD部</option>-->\n                      <option value=\"CR部\">CR部</option>\n                      <option value=\"WEB事業部\">WEB事業部</option>\n                      <option value=\"撮影部（女性モデル兼任）\">\n                        撮影部（女性モデル兼任）\n                      </option>\n                    </select></span\n                  ></label\n                >\n              </p>\n              <p>\n                <label>\n                  備考<br />\n                  <span class=\"wpcf7-form-control-wrap your-message\">\n                    <textarea\n                      name=\"your-message\"\n                      cols=\"40\"\n                      rows=\"10\"\n                      class=\"wpcf7-form-control wpcf7-textarea\"\n                      aria-invalid=\"false\"\n                    ></textarea>\n                  </span>\n                </label>\n              </p>\n              <p>\n                <input\n                  type=\"submit\"\n                  value=\"送信\"\n                  class=\"wpcf7-form-control wpcf7-submit\"\n                  id=\"submit_sent\"\n                /><input\n                  type=\"submit\"\n                  value=\"確認する\"\n                  class=\"wpcf7-form-control wpcf7-confirm wpcf7c-elm-step1 wpcf7c-btn-confirm wpcf7c-force-hide\"\n                  id=\"confirm\"\n                /><input\n                  type=\"button\"\n                  value=\"戻る\"\n                  class=\"wpcf7-form-control wpcf7-back wpcf7c-elm-step2 wpcf7c-btn-back wpcf7c-force-hide\"\n                  id=\"confirm_back\"\n                />\n              </p>\n              <div class=\"wpcf7-response-output wpcf7-display-none\"></div>\n            </form>\n          </div>\n        </div>\n      </section>\n\n      <section id=\"company_overview\">\n        <div class=\"title\">\n          <div class=\"red_box\"><div class=\"white_box\"></div></div>\n          <p>Company overview</p>\n        </div>\n        <h2>会社概要</h2>\n        <table>\n          <tr>\n            <th>会社名</th>\n            <td>株式会社ロココ</td>\n          </tr>\n          <tr>\n            <th>本社</th>\n            <td>大阪府大阪市中央区博労町1-8-8<br />ピカソ堺筋本町ビル501</td>\n          </tr>\n          <tr>\n            <th>代表取締役社長</th>\n            <td>阿部 慎太郎</td>\n          </tr>\n          <tr>\n            <th>設立</th>\n            <td>2011 年 12 月</td>\n          </tr>\n          <tr>\n            <th>資本金</th>\n            <td>800万円</td>\n          </tr>\n          <tr>\n            <th>従業員数</th>\n            <td>26名</td>\n          </tr>\n          <tr>\n            <th>主な事業内容</th>\n            <td>アパレル小売業/ECサイトによる通信販売</td>\n          </tr>\n        </table>\n        <p class=\"attention\">※2020年3月現在</p>\n      </section>\n      <section id=\"access\">\n        <div class=\"title\">\n          <div class=\"red_box\"><div class=\"white_box\"></div></div>\n          <p>Access</p>\n        </div>\n        <h2>アクセス</h2>\n        <iframe\n          src=\"https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2320.034296839742!2d135.50782229601793!3d34.67934455531442!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f100!3m3!1m2!1s0x0%3A0x23fe61c24df3c808!2z5qCq5byP5Lya56S-44Ot44Kz44Kz77yIUk9DT0NPKQ!5e0!3m2!1sja!2sjp!4v1588242465354!5m2!1sja!2sjp\"\n          width=\"780\"\n          height=\"540\"\n          frameborder=\"0\"\n          style=\"border: 0\"\n          allowfullscreen=\"\"\n          aria-hidden=\"false\"\n          tabindex=\"0\"\n        ></iframe>\n        <table>\n          <tr>\n            <th>所在地</th>\n            <td>\n              〒541-0059<br />大阪府大阪市中央区博労町1-8-8　ピカソ堺筋本町ビル5階\n            </td>\n          </tr>\n          <tr>\n            <th>TEL・FAX</th>\n            <td>06-4708-6316</td>\n          </tr>\n        </table>\n        <hr />\n        <p id=\"contact\" class=\"sub_title\">お問い合わせ</p>\n        <p class=\"contactform_txt\">\n          弊社にご連絡いただく際は以下のフォームよりお問い合わせください。<br />\n          商品・ECサイトに関しては各サイトからお願い申し上げます。\n        </p>\n        <div class=\"company_form\">\n          <div role=\"form\" class=\"wpcf7\" id=\"company_form\" lang=\"ja\" dir=\"ltr\">\n            <div class=\"screen-reader-response\"></div>\n            <form\n              action=\"#\"\n              method=\"post\"\n              class=\"wpcf7-form\"\n              novalidate=\"novalidate\"\n            >\n              <input type=\"hidden\" name=\"mail_sent\" value=\"\" />\n              <input type=\"hidden\" name=\"mailform_token\" value=\"\" />\n              <p>\n                <label>\n                  お名前 <span class=\"cation\">(必須)</span><br />\n                  <span class=\"wpcf7-form-control-wrap your-name\"\n                    ><input\n                      type=\"text\"\n                      name=\"your-name\"\n                      value=\"\"\n                      size=\"40\"\n                      class=\"wpcf7-form-control wpcf7-text wpcf7-validates-as-required\"\n                      aria-required=\"true\"\n                      aria-invalid=\"false\"\n                  /></span>\n                </label>\n              </p>\n              <p>\n                <label>\n                  メールアドレス <span class=\"cation\">(必須)</span><br />\n                  <span class=\"wpcf7-form-control-wrap your-email\"\n                    ><input\n                      type=\"email\"\n                      name=\"your-email\"\n                      value=\"\"\n                      size=\"40\"\n                      class=\"wpcf7-form-control wpcf7-text wpcf7-email wpcf7-validates-as-required wpcf7-validates-as-email\"\n                      aria-required=\"true\"\n                      aria-invalid=\"false\"\n                  /></span>\n                </label>\n              </p>\n              <p>\n                <label>\n                  カテゴリ <span class=\"cation\">(必須)</span><br />\n                  <span class=\"wpcf7-form-control-wrap menu-973\"\n                    ><select\n                      name=\"menu-973\"\n                      class=\"wpcf7-form-control wpcf7-select wpcf7-validates-as-required\"\n                      aria-required=\"true\"\n                      aria-invalid=\"false\"\n                    >\n                      <option value=\"\">---</option>\n                      <option value=\"会社について\">会社について</option>\n                      <option value=\"商品について\">商品について</option>\n                      <option value=\"採用について\">採用について</option>\n                      <option value=\"その他\">その他</option>\n                    </select></span\n                  ></label\n                >\n              </p>\n              <p>\n                <label>\n                  メッセージ本文<br />\n                  <span class=\"wpcf7-form-control-wrap your-message\">\n                    <textarea\n                      name=\"your-message\"\n                      cols=\"40\"\n                      rows=\"10\"\n                      class=\"wpcf7-form-control wpcf7-textarea\"\n                      aria-invalid=\"false\"\n                    ></textarea>\n                  </span>\n                </label>\n              </p>\n              <p>\n                <input\n                  type=\"submit\"\n                  value=\"送信\"\n                  class=\"wpcf7-form-control wpcf7-submit\"\n                  id=\"submit_sent\"\n                /><input\n            