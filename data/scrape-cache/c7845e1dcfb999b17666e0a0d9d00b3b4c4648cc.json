  <div :class=\"['event_calender', loading && 'loading']\">\n        <div class=\"side\">\n            <form class=\"search\" v-on:submit.prevent=\"handleSubmit\">\n                <div class=\"calendar\">\n                    <h3>日付で絞り込む（複数選択可）</h3>\n\n                    <div class=\"calendar-table\">\n                        <div class=\"table_header\">\n                            <button name=\"prev_month\" :disabled=\"isDisabledPrev\" v-on:click.prevent=\"handlePrev\">前月</button>\n                            <button name=\"curr_month\">{{ yearMonth }}</button>\n                            <button name=\"next_month\" :disabled=\"isDisabledNext\" v-on:click.prevent=\"handleNext\">次月</button>\n                        </div>\n                        <div class=\"dates\">\n                            <div :class=\"calendarDate.styles\"\n                                 v-for=\"calendarDate in calendarDates\"\n                                 v-on:click=\"handleDate(calendarDate.date)\">{{ calendarDate.date.date() }}\n                            </div>\n                        </div>\n                        <div class=\"table_footer\">\n                            <div class=\"table_footer_left\">\n                                <label class=\"weekend\">\n                                    <input type=\"checkbox\" name=\"weekend\" :checked=\"calendar.checkedWeekend\" v-on:change=\"handleWeekend\"/>\n                                    土日のみ\n                                </label>\n                                <label class=\"weekday\">\n                                    <input type=\"checkbox\" name=\"weekday\" :checked=\"calendar.checkedWeekday\" v-on:change=\"handleWeekday\"/>\n                                    土日以外\n                                </label>\n                            </div>\n                            <div class=\"table_footer_right\">\n                                <button name=\"clear\" v-on:click.prevent=\"handleClearDates\">選択日付をクリア</button>\n                            </div>\n                        </div>\n                        <div class=\"selected_dates\" v-if=\"selectedDates.length > 0\">\n                            選択中の日付：{{ selectedDates.join(' | ') }}\n                        </div>\n                    </div>\n                </div>\n\n                <div class=\"anytime_event\">\n                    <button\n                            type=\"button\"\n                            :class=\"['anytime_toggle_btn', anytimeFlag ? 'is-active' : '']\"\n                            v-on:click.prevent=\"handleAnytimeFlag\"\n                    >\n                        随時開催イベントも表示する\n                    </button>\n                </div>\n\n                <div class=\"show_closed_event\">\n                    <label><input type=\"checkbox\" :checked=\"showClosedEvent\" v-on:change=\"handleShowClosedEvent\"/> 満員・受付終了イベントも表示する</label>\n                </div>\n\n                <div v-for=\"condition in useConditions\" :class=\"[condition.class, 'foldable']\">\n                    <h3 v-on:click=\"toggle[condition.key] = !toggle[condition.key]\">{{ condition.title }}で絞り込む <span><i\n                            :class=\"['fa', toggle[condition.key] ? 'fa-chevron-down' : 'fa-chevron-up']\"></i></span></h3>\n                    <transition name=\"condition-slide\"\n                                v-on:before-enter=\"toggleSlideBeforeEnter\"\n                                v-on:enter=\"toggleSlideEnter\"\n                                v-on:before-leave=\"toggleSlideBeforeLeave\"\n                                v-on:leave=\"toggleSlideLeave\">\n                        <div class=\"conditions\" v-show=\"!toggle[condition.key]\">\n                            <template v-for=\"group in master[condition.key]\">\n                                <div class=\"bt-group\">{{ group.title }}</div>\n                                <div>\n                                    <label v-for=\"item in group.items\">\n                                        <input type=\"checkbox\"\n                                               v-model=\"filter[condition.name]\"\n                                               :value=\"item.id\"\n                                               @change=\"handleSubmit\"/>\n                                        {{ item.name }}\n                                    </label>\n                                </div>\n                            </template>\n                        </div>\n                    </transition>\n                </div>\n\n            </form>\n        </div>\n\n        <div class=\"main\">\n            <h3 class=\"result-title\">{{ resultTitle }}</h3>\n            <template v-if=\"!this.errorMessage\">\n                <div class=\"total\"><span>{{ total }}</span>件の{{ title }}が登録されています</div>\n                <div class=\"result\">\n                    <ol>\n                        <li :id=\"`event-${event.id}`\" class=\"event\" v-for=\"event in results\">\n                            <div class=\"opening_term\">{{ event.opening_term }}</div>\n                            <div class=\"event_information\">\n                                <div class=\"company\">\n                                    <p class=\"event_name\">\n                                        <a :href=\"event.detail_page\">{{ event.name }}</a>\n                                        <span :class=\"`block status_${event.reserve_status}`\"></span>\n                                    </p>\n                                    <p :class=\"`company_name cmp-${event.company.id}`\">\n                                        <a :href=\"`c/company.html?cmp_id=${event.company.id}`\" class=\"go_company_detail\">\n                                            {{ event.company.name }}\n                                        </a>\n                                    </p>\n                                    <p class=\"event_hall\">会場：{{ event.hall }}\n                                        <template v-if=\"!!event.map_url\">\n                                            <a :href=\"decodeURI(event.map_url)\" class=\"map\" v-on:click.prevent=\"openMap(event.map_url)\">【MAP】</a>\n                                            <span class=\"block hall_address\">{{ event.hall_address }}</span>\n                                        </template>\n                                    </p>\n                                </div>\n                                <div class=\"detail\"><a :href=\"event.detail_page\">詳細へ</a></div>\n                            </div>\n                        </li>\n                    </ol>\n                </div>\n            </template>\n            <div class=\"error_message\" v-else>\n                {{ this.errorMessage }}\n            </div>\n        </div>\n    </div>\n</div>\n<script>vueApp.mount('#calendar-search')</script>\n</div>\n\n\n        \n\n\n        <!--　ページTOPタブ　-->\n<!--　▼　ページトップ　タブ　▼　-->\n<div id=\"pagetop\">\n\t<div class=\"gotop\">\n\t\t<a href=\"#\"><i class=\"fa-solid fa-circle-chevron-up\"></i></a>\n\t</div>\n</div>\n<!--　▲　ページトップ　タブ　▲　-->\n\n        <!--　▼検索ページバナー　▼　--> \n<div id=\"bottom_bannerxb2\">\n    <ul id=\"imgbanner\" v-if=\"total > 0\" :class=\"[loading && 'loading']\">\n  <li v-for=\"visual in visuals\" :class=\"[visual.type]\">\n    <a :href=\"visual.url\" :target=\"visual.target\" v-on:click=\"handleClick(visual.banner_id)\">\n      <img :src=\"visual.src\" :alt=\"visual.alt\"/>\n    </a>\n  </li>\n    </ul>\n</div>\n<script>\n    ;(function() {\n    \tconst BANNER_LIST = [{\n\"type\": \"cgbl\",\n\"id\": \"1063\",\n\"src\": \"https:\\/\\/s3-ap-northeast-1.amazonaws.com\\/4en\\/niigata-job.ne.jp\\/banners\\/1093\\/2028\\/7c45bf23-238a-4cfd-a916-7aa9df1e1ffd.jpg\",\n\"alt\": \"緑水工業株式会社\",\n\"alt2\": \"\",\n\"url\": \"https:\\/\\/www.niigata-job.ne.jp\\/2028\\/c\\/company.html?cmp_id=1093\",\n\"target\": \"_blank\"\n},{\n\"type\": \"cgbl\",\n\"id\": \"1080\",\n\"src\": \"https:\\/\\/s3-ap-northeast-1.amazonaws.com\\/4en\\/niigata-job.ne.jp\\/banners\\/1172\\/2028\\/89b0a555-94cb-41e6-8144-976bf23338b5.jpg\",\n\"alt\": \"株式会社野島角清製作所\",\n\"alt2\": \"\",\n\"url\": \"https:\\/\\/www.niigata-job.ne.jp\\/2028\\/c\\/company.html?cmp_id=1172\",\n\"target\": \"_blank\"\n},null].filter(v => v);\n\t\tinitBannerApp('#imgbanner', '35', BANNER_LIST, '/ajax/2028/banner_click/',2,false)        \n    })()\n</script>\n        \n\n        <!-- 全ページ共通 body内設置タグ -->\n<!-- Google Tag Manager (noscript) -->\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-5T9FCTQD\"\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n<!-- End Google Tag Manager (noscript) -->\n        \n        <!--access  2028-->\n<script>\n    (function(w,d,l,i,e,p){\n        i.src=(l.origin === undefined?l.origin = l.protocol+\"//\"+l.hostname:l.origin)+p+\"?dt=\"+w[e](d.title)+\"&url=\"+w[e](l.href);\n    })(window,document,location,new Image,\"encodeURIComponent\",\"/ajax/2028/al\");\n</script>\n<!--/access-->\n        <!-- ドロワーメニューの利用宣言 -->\n        <script>\n            $(document).ready(function() {\n                $('.drawer').drawer();\n            });\n        </script>\n    </body>\n</html>","finalUrl":"https://www.niigata-job.ne.jp/2028/intern/search_calender.html","rendered":false,"_cachedAt":"2026-06-23T16:08:24.428Z"}