"c-header-nav-sp-list02 js-header-sp-item__contents\">\r\n              <li><a href=\"/support/\">お客さまサポートトップ</a></li>\r\n              <li><a href=\"/support/faq/\">よくあるご質問</a></li>\r\n              <li>\r\n                <div>お問い合わせ・資料請求</div>\r\n                <ul class=\"c-header-nav-sp-list03\">\r\n                  <li><a href=\"https://qmnb.f.msgs.jp/webapp/form/26692_qmnb_1/index.do\" target=\"_blank\" rel=\"noopener\">ソリューション・製品に関するお問い合わせ</a></li>\r\n                  <li><a href=\"https://yagb.f.msgs.jp/webapp/form/21656_yagb_1/index.do\" target=\"_blank\" rel=\"noopener\">e-コレクト&reg;をご利用中の方のお問い合わせ</a></li>\r\n                  <li><a href=\"https://qmnb.f.msgs.jp/webapp/form/26692_qmnb_2/index.do\" target=\"_blank\" rel=\"noopener\">当社サービス以外のお問い合わせ</a></li>\r\n                  <li><a href=\"https://qmnb.f.msgs.jp/webapp/form/26692_qmnb_3/index.do\" target=\"_blank\" rel=\"noopener\">資料請求</a></li>\r\n                </ul>\r\n              </li>\r\n            </ul>\r\n          </li>\r\n          <li><a href=\"/strength/\">SGシステムの強み</a></li>\r\n          <li>\r\n            <button class=\"js-header-sp-item\" type=\"button\">採用情報</button>\r\n            <ul class=\"c-header-nav-sp-list02 js-header-sp-item__contents\">\r\n              <li><a href=\"/recruit/\">採用情報トップ</a></li>\r\n              <li><a href=\"/recruit/job/\">仕事を知る</a></li>\r\n              <li><a href=\"/recruit/people/\">人を知る</a></li>\r\n              <li><a href=\"/recruit/corporate/\">会社を知る</a></li>\r\n              <li><a href=\"/recruit/corporate/3min/\">数字で分かるSGシステム</a></li>\r\n              <li><a href=\"/recruit/guideline/\">募集要項</a></li>\r\n            </ul>\r\n          </li>\r\n          <li>\r\n            <button class=\"js-header-sp-item\" type=\"button\">企業情報</button>\r\n            <ul class=\"c-header-nav-sp-list02 js-header-sp-item__contents\">\r\n              <li><a href=\"/company/\">企業情報トップ</a></li>\r\n              <li><a href=\"/company/message/\">ごあいさつ</a></li>\r\n              <li><a href=\"/company/outline/\">会社概要</a></li>\r\n              <li><a href=\"/company/history/\">沿革</a></li>\r\n              <li><a href=\"/company/branch/\">事業所一覧</a></li>\r\n              <li><a href=\"/company/internal/\">内部統制基本方針</a></li>\r\n              <!--<li><a href=\"/company/faq/\">よくあるご質問</a></li>-->\r\n              <li><a href=\"https://www.sg-hldgs.co.jp/company/philosophy/\" target=\"_blank\" rel=\"noopener\">企業理念・行動憲章</a></li>\r\n            </ul>\r\n          </li>\r\n        </ul>\r\n      </div>\r\n      <div class=\"c-header-nav-sp__sub\">\r\n        <ul>\r\n          <li><a href=\"/service/e-collect/guide/\">e-コレクト&reg;のお申込</a></li>\r\n          <li><a href=\"https://www.e-service.sagawa-exp.co.jp/portal/do/login/show\" target=\"_blank\" rel=\"noopener\">スマートクラブログイン</a></li>\r\n        </ul>\r\n      </div>\r\n      <div class=\"c-header-nav-sp__contact\">\r\n        <a href=\"/support/#inquiry\">お問い合わせ</a>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</header>\r\n<div class=\"l-header__overlay\"></div>\n    <main class=\"l-main\">\n      <div class=\"recruit-header\">\r\n  <div class=\"recruit-header__inner\">\r\n    <div class=\"recruit-header__heading\">\r\n      <span>RECRUIT</span><span>SGシステムの採用情報</span>\r\n    </div>\r\n    <button class=\"recruit-header__menu\" type=\"button\"></button>\r\n    <div class=\"recruit-header__nav\">\r\n      <div>\r\n        <ul class=\"recruit-header__links\">\r\n          <li><a href=\"/recruit/\" class=\"recruit-header__item\" data-url=\"\"><span>トップ</span></a></li>\r\n          <li><a href=\"/recruit/corporate/\" class=\"recruit-header__item\" data-url=\"corporate\"><span>会社を知る</span></a></li>\r\n          <li><a href=\"/recruit/job/\" class=\"recruit-header__item\" data-url=\"job\"><span>仕事を知る</span></a></li>\r\n          <li><a href=\"/recruit/people/\" class=\"recruit-header__item\" data-url=\"people\"><span>人を知る</span></a></li>\r\n          <li><a href=\"/recruit/faq/\" class=\"recruit-header__item\" data-url=\"faq\"><span>よくあるご質問</span></a></li>\r\n        </ul>\r\n        <ul class=\"recruit-header__cta\">\r\n          <li><a href=\"https://job.mynavi.jp/27/pc/search/corp88148/outline.html\" target=\"_blank\" class=\"recruit-header__btn\"><span>新卒採用（マイナビ）</span></a></li>\r\n          <li><a href=\"https://jsd.jposting.net/sg-systems/\" target=\"_blank\" rel=\"noopener\" class=\"recruit-header__btn -career\"><span>中途採用</span></a></li>\r\n        </ul>\r\n      </div>\r\n    </div>\r\n  </div>\r\n  <div class=\"recruit-header__overlay\"></div>\r\n</div>\n            <div class=\"recruit-people-title\">\r\n        <div class=\"recruit-people-title__img\">\r\n          <img src=\"/assets/img/recruit/people/18/img_mv-pc.jpg\" alt=\"\" class=\"tb-pc:view\">\r\n          <img src=\"/assets/img/recruit/people/18/img_mv-sp.jpg\" alt=\"\" class=\"sp:view\">\r\n        </div>\r\n        <div class=\"recruit-people-title__contents\">\r\n          <div class=\"recruit-people-title__category\"><span>人を知る</span><span>営業</span></div>\r\n          <h1 class=\"recruit-people-title__ttl\"><span>安定性と革新性の両立。</span><br><span>未来を支える物流ITで、多様な業界の<br class=\"sp:view\">課題に挑む</span></h1>\r\n          <div class=\"recruit-people-title__person\">2019年入社・新卒（理系）　営業開発部 営業開発U</div>\r\n        </div>\r\n      </div>\r\n      <div class=\"recruit-block\">\r\n        <div class=\"recruit-block__inner u-pt-80 u-sp-pt-40\">\r\n          <div class=\"l-section\">\r\n            <div class=\"recruit-people-profile\">\r\n              <div class=\"recruit-people-profile__mv\">\r\n                <video src=\"/assets/mov/recruit/people/18/mov_01.mp4\" controls controlsList=\"nodownload\"></video>\r\n              </div>\r\n              <div class=\"recruit-people-profile__contents\">\r\n                <div class=\"recruit-people-profile__category\">営業</div>\r\n                <div class=\"recruit-people-profile__name\">上野 大氣</div>\r\n                <div class=\"recruit-people-profile__person\">2019年入社・新卒（理系）　営業開発部 営業開発U</div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n          <section class=\"l-section\">\r\n            <div class=\"recruit-media\">\r\n              <div class=\"recruit-media__img -right\">\r\n                <figure class=\"c-figure\"><img src=\"/assets/img/recruit/people/18/img_01.jpg\" alt=\"\" loading=\"lazy\"></figure>\r\n              </div>\r\n              <div class=\"recruit-media__txt\">\r\n                <h2 class=\"recruit-heading -small u-ta-l u-mb-32 u-sp-mb-24\">簡単に潰れない会社に入りたかった</h2>\r\n                <p>就職活動時は「潰れない会社であるか」「IT業界」の2軸で会社探しをしていました。就職は一生物なので、「入社してすぐ倒産しない会社がいい」と考えていたのです。その中で、物流大手の佐川急便を有するSGホールディングスグループに属するSGシステムは、安定性という面で魅力的でした。今後の日本にとってITが重要になることは確実でしたし、物流はこれからもなくなることはないことも大きなポイントでした。</p>\r\n                <p>さらに、就職活動をしていた当時、自動運転技術が注目を集め始めていたこともあり、「もしかしたら最先端の領域に関われるかもしれない」と期待を抱いたこともSGシステムを選んだ理由の一つ。実は、学生時代の専攻は工学系であったもののITに直結するものではありませんでしたが、それでもSGシステムの営業分野に応募したのは、事務系の仕事は自分には合わないと思っていたからです。</p>\r\n                <p>最終的に入社を決めたのは、佐川急便という大黒柱があったから。他のIT企業と比較した際、この点が大きな差別化要因となりました。入社前は佐川と言うと体育会系というイメージが強く、SGシステムもそんな社風なのかと思っていました。しかし、実際に入社してみると、わきあいあいとしていて、上下関係も厳しくありませんでした。いい意味でギャップがありましたね。</p>\r\n              </div>\r\n            </div>\r\n          </section>\r\n          <section class=\"l-section\">\r\n            <h2 class=\"recruit-heading -small u-ta-l u-mb-32 u-sp-mb-24\">物流の最適解を一気通貫で。SGホールディングスグループ横断の「ＧＯＡＬ&reg;」チーム</h2>\r\n            <p>現在、営業開発部営業開発ユニットに所属し、Xフロンティアに常駐するメンバーとして活動しています。具体的にはSGホールディングスグループ横断の先進的ロジスティクスプロジェクトチーム「ＧＯＡＬ&reg;」のメンバーとして、お客さまの物流課題の改善・解決に向けたソリューションを提案しています。お客さまの物流に関する隠れた課題を見つけ出し、物流の最適解を一気通貫で提供することが主な役割です。</p>\r\n            <p>時には物流業界特有の課題にも直面します。例えば、危険物や医薬品など運搬に関する法的規制や、各業界特有のルールなどです。法律が絡んでくる物流に関わる仕事を何も知らずに進めて、もし何かあっても「知りませんでした」では通用しません。そのため、新しい業界の仕事にチャレンジする際は、入念に関連する知識をインプットするよう心がけています。</p>\r\n            <p>私が携わった案件の一例として、全国に販売店を持つ企業の自社システムの統一化プロジェクトがあります。700〜800ほどある全国の拠点で、本来各拠点が個別に利用している送り状発行の仕組みを本社の基幹システムに組み込むことで、統一的な管理を可能にしました。このプロジェクトにより、各拠点の送り状発行状況を本社で把握でき、統計も取れるようになりました。</p>\r\n          </section>\r\n          <section class=\"l-section\">\r\n            <div class=\"recruit-media\">\r\n              <div class=\"recruit-media__img -left\">\r\n                <figure class=\"c-figure\"><img src=\"/assets/img/recruit/people/18/img_02.jpg\" alt=\"\" loading=\"lazy\"></figure>\r\n              </div>\r\n              <div class=\"recruit-media__txt\">\r\n                <h2 class=\"recruit-heading -small u-ta-l u-mb-32 u-sp-mb-24\">2024年問題に直面する物流業界を、ITで変革できる</h2>\r\n                <p>仕事でやりがいを感じる瞬間は、大きく2つあります。1つ目は、お客さまから感謝の声をいただいたとき。私たちにお声がかかるときは、運用面での困りごとがあるときがほとんどで、それをシステム導入によって改善し、「現場が楽になった」と言っていただけた時はやはりうれしいですね。</p>\r\n                <p>2つ目は、大手企業との仕事ができること。取引先の多くが名だたる企業で、「あれは自分が手がけた仕組みで動いている」と誇らしい気持ちになることが多々あります。物流はさまざまな業界で必要とされているため、佐川急便だけでなくさまざまなお客さまと相対する機会があるので、さまざまな業種業態を学び、成長できます。</p>\r\n                <p>さらに、物流業界全体の変革に関われることもこの仕事の魅力の1つ。2024年問題で今、物流業界は佳境を迎えています。ITでいろんなことを変えたい人にはピンポイントでいい環境だと思います。</p>\r\n              </div>\r\n            </div>\r\n          </section>\r\n          <section class=\"l-section\">\r\n            <h2 class=\"recruit-heading -small u-ta-l u-mb-32 u-sp-mb-24\">SGシステムで挑む業界変革と未来創造</h2>\r\n            <p>私が所属する部署の雰囲気は和やかでありながら、仕事に対しては真剣に取り組む環境です。各事業会社が集まるXフロンティアのオフィスに常駐し、日頃から顔を合わせる機会が多いこともあり、休日明けにはお土産を交換したり、互いの趣味の話や他愛のない話をしたり、時には案件の対応を助け合ったり、上司を含め周囲と気楽にコミュニケーションができる雰囲気です。</p>\r\n            <p>SGシステムで働く魅力としては、ITで物流業界の人手不足などの課題を解消できること。当社は今後も独自のポジションで、物流のIT化を加速させていきます。私たちは佐川急便と共に動くことで、いろんな業種・業態のお客さまと関わることができる点もやりがいにつながります。</p>\r\n            <p>最後に今後の目標として、お客さまから「システムや物流改善といえば上野さん」と言われるようになりたいですね。営業という立場上、信頼はかなり重要なポイントだと思っています。今もお声がけいただく機会は多くなってますが、内部だけでなくお客さまからもそう言われるような存在になりたいです。</p>\r\n            <p>SGシステムは物流とITの融合によって、多様な業界の課題解決に挑戦し続ける企業です。ここで働く私の経験からも、安定性と将来性、そして個人の成長機会が豊富にある魅力的な職場環境だと実感しています。</p>\r\n          </section>\r\n          <section class=\"l-section\">\r\n            <h2 class=\"recruit-heading -medium u-mb-40 u-sp-mb-24\">1日の仕事の流れ</h2>\r\n            <div class=\"recruit-people-routine\">\r\n              <div class=\"recruit-people-routine__list\">\r\n                <dl>\r\n                  <div>\r\n                    <dt>09:00</dt>\r\n                    <dd>出社・メールチェック</dd>\r\n                  </div>\r\n                  <div>\r\n                    <dt>10:00</dt>\r\n                    <dd>資料準備・最終確認</dd>\r\n                  </div>\r\n                  <div>\r\n                    <dt>11:00</dt>\r\n                    <dd>佐川急便・佐川グローバルロジスティクスとの事前MTG</dd>\r\n                  </div>\r\n                  <div>\r\n                    <dt>12:00</dt>\r\n                    <dd>お昼休憩（Xフロンティア食堂）</dd>\r\n                  </div>\r\n                  <div>\r\n                    <dt>13:00</dt>\r\n                    <dd>お客さま来社・Xフロンティア施設見学・商談</dd>\r\n                  </div>\r\n                  <div>\r\n                    <dt>16:00</dt>\r\n                    <dd>商談内容整理</dd>\r\n                  </div>\r\n                  <div>\r\n                    <dt>17:00</dt>\r\n                    <dd>翌日の商談準備</dd>\r\n                  </div>\r\n                  <div>\r\n                    <dt>18:00</dt>\r\n                    <dd>定時退社</dd>\r\n                  </div>\r\n                  <small>※業務内容・所属部署は取材当時のものです</small>\r\n                </dl>\r\n              </div>\r\n              <div class=\"recruit-people-routine__img\">\r\n                <img src=\"/assets/img/recruit/people/18/img_03.jpg\" alt=\"\" loading=\"lazy\">\r\n              </div>\r\n            </div>\r\n          </section>\r\n        </div>\r\n      </div>\r\n      <div class=\"l-block -bg-pale-blue\">\r\n        <div class=\"l-block__inner\">\r\n          <div class=\"c-slider -panel js-slider\" data-show=\"3\">\r\n            <div class=\"c-slider__inner js-slider__inner\">\r\n              <a href=\"/recruit/people/14/\" class=\"recruit-panel\">\r\n                <div class=\"recruit-panel__img\"><img src=\"/assets/img/recruit/people/14/img_thumb.jpg\" alt=\"\" loading=\"lazy\"></div>\r\n                <div class=\"recruit-panel__category\">エンジニア</div>\r\n                <div class=\"recruit-panel__ttl\">文系出身の私が、今では上流工程を担うSEに。手厚い研修と温かい仲間が育ててくれました</div>\r\n                <div class=\"recruit-panel__person\">2019年入社・新卒（文系）<br>SI第1事業部 勘定系U</div>\r\n              </a>\r\n              <a href=\"/recruit/people/15/\" class=\"recruit-panel\">\r\n                <div class=\"recruit-panel__img\"><img src=\"/assets/img/recruit/people/15/img_thumb.jpg\" alt=\"\" loading=\"lazy\"></div>\r\n                <div class=\"recruit-panel__category\">エンジニア</div>\r\n                <div class=\"recruit-panel__ttl\">論理的思考で挑む、物流のDX。チーフスペシャリストが語る、SGシステムのAIソリューション</div>\r\n                <div class=\"recruit-panel__person\">2016年入社・新卒（理系）<br>SI第2事業部 AIソリューションU</div>\r\n              </a>\r\n              <a href=\"/recruit/people/16/\" class=\"recruit-panel\">\r\n                <div class=\"recruit-panel__img\"><img src=\"/assets/img/recruit/people/16/img_thumb.jpg\" alt=\"\" loading=\"lazy\"></div>\r\n                <div class=\"recruit-panel__category\">エンジニア</div>\r\n                <div class=\"recruit-panel__ttl\">システム利用者と直接やり取りして、新機能を提案。エンジニアとして、仕事の領域を広げられる</div>\r\n                <div class=\"recruit-panel__person\">2023年入社・中途（理系）<br>SI第1事業部 勘定系U</div>\r\n              </a>\r\n            </div>\r\n            <div class=\"c-slider__nav\">\r\n              <div class=\"c-slider__pause\"></div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n      <div class=\"recruit-entry\">\r\n  <div class=\"recruit-entry__block\">\r\n    <h2 class=\"recruit-entry__heading\">ENTRY</h2>\r\n    <p class=\"recruit-entry__lead\">SGシステムで一緒に<br class=\"sp-tb:view\">未来を作りませんか</p>\r\n    <p class=\"recruit-entry__txt\">私たちとこれからの物流を変える一歩を<br class=\"sp:view\">踏み出しませんか？<br>\r\n      エントリーはこちらからお願いします。</p>\r\n    <div class=\"recruit-entry__btn\">\r\n      <a href=\"https://job.mynavi.jp/27/pc/search/corp88148/outline.html\" target=\"_blank\" rel=\"noopener\" class=\"recruit-btn\"><span>新卒採用（マイナビ）</span></a>\r\n      <a href=\"https://jsd.jposting.net/sg-systems/\" target=\"_blank\" rel=\"noopener\" class=\"recruit-btn\"><span>中途採用</span></a>\r\n    </div>\r\n    <a href=\"https://qmnb.f.msgs.jp/webapp/form/26692_qmnb_2/index.do\" target=\"_blank\" rel=\"noopener\" class=\"recruit-entry__link01\">\r\n      <div>採用に関するお問い合わせ</div>\r\n    </a>\r\n    <a href=\"https://www.sg-hldgs.co.jp/recruit/group-recruit/\" target=\"_blank\" rel=\"noopener\" class=\"recruit-entry__link02\">\r\n      <div>SGホールディングスグループ合同採用募集</div>\r\n    </a>\r\n  </div>\r\n</div>\r\n<div class=\"l-block\">\r\n  <div class=\"l-block__inner\">\r\n    <h3 class=\"recruit-heading -medium u-mb-40 u-sp-mb-32\">関連リンク</h3>\r\n    <div class=\"c-btn-wrap\">\r\n      <a href=\"/strength/\" class=\"recruit-btn\"><span>SGシステムの強み</span></a>\r\n    </div>\r\n  </div>\r\n</div>\r\n<div class=\"recruit-bottom\">\r\n  <button class=\"recruit-bottom__open\" type=\"button\">応募する</button>\r\n  <div class=\"recruit-bottom__modal\">\r\n    <div class=\"recruit-bottom__heading\">応募する</div>\r\n    <p class=\"recruit-bottom__txt\">物流×ITのリーディングカンパニーを目指し、<br>\r\n      活躍していただける人材を募集しています。</p>\r\n    <div class=\"recruit-bottom__cta\">\r\n      <a href=\"https://job.mynavi.jp/27/pc/search/corp88148/outline.html\" target=\"_blank\" rel=\"noopener\" class=\"recruit-bottom__btn\"><span>新卒採用（マイナビ）</span></a>\r\n      <!--<a href=\"\" target=\"_blank\" rel=\"noopener\" class=\"recruit-bottom__btn\"><span>新卒採用（リクナビ）</span></a>-->\r\n      <a href=\"https://jsd.jposting.net/sg-systems/\" target=\"_blank\" rel=\"noopener\" class=\"recruit-bottom__btn\"><span>中途採用</span></a>\r\n      <a href=\"https://qmnb.f.msgs.jp/webapp/form/26692_qmnb_2/index.do\" target=\"_blank\" rel=\"noopener\" class=\"recruit-bottom__btn -contact\"><span>お問い合わせ</span></a>\r\n    </div>\r\n    <button class=\"recruit-bottom__close\"></button>\r\n  </div>\r\n</div>\r\n      <div class=\"l-breadcrumb\">\r\n        <div class=\"l-breadcrumb__inner\">\r\n          <ol class=\"l-breadcrumb__list\">\r\n            <li class=\"l-breadcrumb__item\"><a href=\"/\">ホーム</a></li>\r\n            <li class=\"l-breadcrumb__item\"><a href=\"/recruit/\">採用情報</a></li>\r\n            <li class=\"l-breadcrumb__item\"><a href=\"/recruit/people/\">人を知る</a></li>\r\n            <li class=\"l-breadcrumb__item\"><a href=\"/recruit/people/18/\">営業：2019年入社・新卒（理系）</a></li>\r\n          </ol>\r\n        </div>\r\n      </div>\n    </main>\n    ﻿<footer class=\"l-footer\">\r\n  <div class=\"l-footer__pagetop\">\r\n    <a href=\"#\"></a>\r\n  </div>\r\n  <div class=\"l-footer__head\">\r\n    <div class=\"l-footer__logo\">\r\n      <div>\r\n        <span>物流×ITのリーディングカンパニー</span>\r\n        <div>\r\n          <a href=\"https://www.sg-hldgs.co.jp/\" target=\"_blank\" rel=\"noopener\"><img src=\"/assets/img/common/logo_sgh.svg\" alt=\"SGホールディングス\"></a>\r\n          <a href=\"/\"><img src=\"/assets/img/common/logo_sgsystem.svg\" alt=\"SGシステム株式会社\"></a>\r\n        </div>\r\n      </div>\r\n    </div>\r\n    <div class=\"l-footer__company\">\r\n      <dl>\r\n        <div>\r\n          <dt>本社</dt>\r\n          <dd>〒601-8104<br>\r\n            京都府京都市南区上鳥羽角田町25</dd>\r\n        </div>\r\n        <div>\r\n          <dt>東京本社</dt>\r\n          <dd>\r\n            〒136-0075<br>\r\n            東京都江東区新砂1-8-2 <br class=\"sp:view\">SGHビル新砂Ⅱ\r\n          </dd>\r\n        </div>\r\n      </dl>\r\n    </div>\r\n  </div>\r\n  <div class=\"l-footer__nav\">\r\n    <div class=\"l-footer__nav-inner\">\r\n      <ul class=\"l-footer__nav01\">\r\n        <li><a href=\"/sitemap/\">サイトマップ</a></li>\r\n        <li><a href=\"/help/\">ウェブサイトのご利用について</a></li>\r\n        <li><a href=\"/personal-data/\">個人情報保護方針</a></li>\r\n        <li><a href=\"/info-security/\">情報セキュリティ基本方針</a></li>\r\n        <li><a href=\"/contract/\">各種約款</a></li>\r\n        <li><a href=\"/multi-stakeholder/\">マル