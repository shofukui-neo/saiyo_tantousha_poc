{"url":"https://www.sunmec.jp/recruit.html","html":"<!doctype html>\n<html lang=\"ja\">\n  <!-- InstanceBegin template=\"/Templates/sunmec_n.dwt\" codeOutsideHTMLIsLocked=\"false\" -->\n  <head>\n    <meta charset=\"UTF-8\" />\n    <!-- <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"> -->\n    <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\" />\n    <meta name=\"format-detection\" content=\"telephone=no\" />\n    <!-- InstanceBeginEditable name=\"doctitle\" -->\n    <title>【採用情報 茨城県 製造業】株式会社サンメックの採用情報</title>\n    <!-- InstanceEndEditable -->\n    <!-- InstanceBeginEditable name=\"EditRegion4\" -->\n    <meta name=\"keywords\" content=\"採用情報,茨城県,製造業,サンメック\" />\n    <meta\n      name=\"description\"\n      content=\"【募集要項】募集職種 営業１名、設計１名、製造（随時）勤務地：茨城県日立市勤務時間：当社規定による 給与：当社規定による 福利厚生:家族手当、住宅手当、皆勤手当て　他 株式会社サンメック 〒319-1416 日立市田尻町3丁目28番地1号TEL 0294-42-3077（代）\"\n    />\n    <!-- InstanceEndEditable -->\n    <link rel=\"shortcut icon\" href=\"img/common/favicon.png\" />\n    <link\n      rel=\"stylesheet\"\n      href=\"https://fonts.googleapis.com/css?family=Noto+Sans+JP\"\n    />\n    <link\n      rel=\"stylesheet\"\n      href=\"https://use.fontawesome.com/releases/v5.5.0/css/all.css\"\n      integrity=\"sha384-B4dIYHKNBt8Bc12p+WXckhzcICo0wtJAoU8YZTY5qE0Id1GSseTk6S+L3BlXeVIU\"\n      crossorigin=\"anonymous\"\n    />\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"cssn/style.css\" />\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"cssn/style-s.css\" />\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"cssn/table-wrap.css\" />\n    <script rel=\"preload\" src=\"js/jquery.js\"></script>\n    <!--[if lt IE 9]>\n      <script src=\"//cdn.jsdelivr.net/html5shiv/3.7.2/html5shiv.min.js\"></script>\n      <script src=\"//cdnjs.cloudflare.com/ajax/libs/respond.js/1.4.2/respond.min.js\"></script>\n    <![endif]-->\n    <!-- InstanceBeginEditable name=\"head\" -->\n    <!-- InstanceEndEditable -->\n  </head>\n  <body>\n    <div id=\"