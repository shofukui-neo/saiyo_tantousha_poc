iv>\n        <div class=\"head_sp sp-only\">\n          <div class=\"logo_head\">\n            <a href=\"https://www.sunmec.jp/\"\n              ><img src=\"img/%40sp/common/head_logo.png\" alt=\"\"\n            /></a>\n          </div>\n          <div class=\"icn_tel\">\n            <a href=\"tel:0294423077\"\n              ><img src=\"img/%40sp/common/head_tel.png\" alt=\"tel 0294-42-3077\"\n            /></a>\n          </div>\n          <div class=\"icn_contact\">\n            <a href=\"ask.html\"\n              ><img src=\"img/%40sp/common/head_mail.png\" alt=\"contact\"\n            /></a>\n          </div>\n          <div class=\"icn_menu\">\n            <div><span></span><span></span><span></span></div>\n          </div>\n        </div>\n        <div class=\"gnav_wrap inner\">\n          <nav class=\"gnav\">\n            <ul class=\"flexbox\">\n              <li>\n                <a href=\"https://www.sunmec.jp/\">\n                  <p>HOME</p>\n                </a>\n              </li>\n\n              <li class=\"trigger01 pc-only\">\n                <a href=\"/contents/products\">\n                  <p>製作事例</p>\n                </a>\n                <div class=\"sub_menu\">\n                  <ul class=\"sub01 flexbox\">\n                    <li>\n                      <a href=\"/p_ex_gai.html\"\n                        ><p>放射線遮蔽容器＆パック（自社開発）</p></a\n                      >\n                    </li>\n                    <li>\n                      <a href=\"p_ind.html\"><p>再生可能エネルギー関連事例</p></a>\n                    </li>\n                  </ul>\n                </div>\n              </li>\n\n              <li>\n                <a href=\"industrial.html\">\n                  <p>産業用装置の設計・製造</p>\n                </a>\n              </li>\n\n              <li class=\"trigger01 pc-only\">\n                <a href=\"strength.html\">\n                  <p>サンメックの強み</p>\n                </a>\n                <div class=\"sub_menu\">\n                  <ul class=\"sub01 flexbox\">\n                    <li>\n                      <a href=\"t_welding.html\">\n                        <p>製缶加工</p>\n                      </a>\n                    </li>\n                    <li>\n                      <a href=\"t_machining.html\">\n                        <p>一貫生産対応</p>\n                      </a>\n                    </li>\n                  </ul>\n                </div>\n              </li>\n\n              <li>\n                <a href=\"equipment.html\">\n                  <p>工場・設備</p>\n                </a>\n              </li>\n              <li>\n                <a href=\"qc.html\">\n                  <p>品質管理</p>\n                </a>\n              </li>\n              <li>\n                <a href=\"company.html\">\n                  <p>会社概要</p>\n                </a>\n              </li>\n              <li class=\"sp-only\">\n                <a href=\"recruit.html\"><p>採用情報</p></a>\n              </li>\n              <li class=\"sp-only\">\n                <a href=\"faq.html\"><p>よくある質問</p></a>\n              </li>\n              <li class=\"sp-only\">\n                <a href=\"news/\"><p>トピックス</p></a>\n              </li>\n              <li class=\"sp-only\">\n                <a href=\"sitemap.html\"><p>サイトマップ</p></a>\n              </li>\n              <li class=\"sp-only\">\n                <a href=\"priv.html\"><p>プライバシーポリシー</p></a>\n              </li>\n            </ul>\n          </nav>\n        </div>\n      </header>\n      <!-- InstanceBeginEditable name=\"EditRegion3\" -->\n      <div class=\"main_page\">\n        <div class=\"bg01\">\n          <div class=\"obi inner\">\n            <h1 class=\"wow fadeIn\">\n              <small>Recruit</small> <strong>採用情報</strong>\n            </h1>\n          </div>\n        </div>\n        <div class=\"bg02\">\n          <ul class=\"breadcrumb inner\">\n            <li><a href=\"./\">HOME</a></li>\n            <li>採用情報</li>\n          </ul>\n        </div>\n      </div>\n      <div id=\"content\">\n        <article>\n          <section>\n            <div class=\"inner\">\n              <h2 class=\"center mincho fs26\">\n                プロフェッショナルエンジニアリング企業を目指す私たちと、<br />\n                共に歩む仲間を募集します。\n              </h2>\n              <p class=\"center\">\n                私たちは約50名程のプロフェッショナルなエンジニア集団です。\n              </p>\n              <p class=\"center\">\n                技術力を結集し、お客様、そして社会が求める構想をカタチにします。<br />\n                私たちの想いに共感し、切磋琢磨しながらともに仕事をする新たな仲間を募集しています。\n              </p>\n              <figure class=\"full mt25\">\n                <span><img src=\"img/recruit/re01.png\" /></span>\n                <figcaption></figcaption>\n              </figure>\n\n              <div class=\"visit-cta-wrap\">\n                <p class=\"visit-cta-lead fadeIn\">高校生の方はこちら</p>\n                <div class=\"visit-cta-bubble\">職場見学受付中！</div>\n              </div>\n              <div class=\"jobdraft-wrap\">\n                <a href=\"https://job-draft.com/jobs/7944\" class=\"jobdraft-link\">\n                  <img\n                    src=\"img/recruit/jobdraft2.jpg\"\n                    alt=\"ジョブドラフト\"\n                  />\n                </a>\n              </div>\n            </div>\n          </section>\n          <section>\n            <h2 class=\"wow fadeIn\">\n              <div class=\"inner\"><span>募集要項</span></div>\n            </h2>\n            <!-- 資材調達業務 -->\n\n            <div class=\"inner\">\n              <h3 class=\"wow fadeIn\">\n                <div class=\"inner\"><span>資材調達業務</span></div>\n              </h3>\n              <table class=\"table spCol1\">\n                <tbody>\n                  <tr>\n                    <td valign=\"top\" bgcolor=\"#E6FBF2\" width=\"100\">募集職種</td>\n                    <td>資材調達業務（最大2名）</td>\n                  </tr>\n                  <tr>\n                    <td valign=\"top\" bgcolor=\"#E6FBF2\" width=\"100\">雇用形態</td>\n                    <td>正社員</td>\n                  </tr>\n                  <tr>\n                    <td valign=\"top\" bgcolor=\"#E6FBF2\" width=\"100\">勤務地</td>\n                    <td>\n                      茨城県日立市田尻町3-28-1<br />\n                      ※必要に応じて当社第二工場（日立市砂沢町）での業務を行う場合があります。（移動は公用車）\n                    </td>\n                  </tr>\n                  <tr>\n                    <td valign=\"top\" bgcolor=\"#E6FBF2\" width=\"100\">勤務時間</td>\n                    <td>8:00～16:45</td>\n                  </tr>\n                  <tr>\n                    <td valign=\"top\" bgcolor=\"#E6FBF2\" width=\"100\">休日</td>\n                    <td>\n                      週休二日制　会社カレンダーによる。<br />\n                      長期休暇：年末年始、GW、夏季休暇等　6カ月経過後の年次有給休暇日数\n                      10日\n                    </td>\n                  </tr>\n                  <tr>\n                    <td valign=\"top\" bgcolor=\"#E6FBF2\" width=\"100\">給与</td>\n                    <td>\n                      220,000円～300,000円<br />\n                      昇給有、賞与有（年二回、前年度実績50,000円～500,000円）\n                    </td>\n                  </tr>\n                  <tr>\n                    <td valign=\"top\" bgcolor=\"#E6FBF2\" width=\"100\">福利厚生</td>\n                    <td>\n                      健康診断、特別休暇、育児休業、皆勤手当、家族手当、住宅手当、ほか\n                    </td>\n                  </tr>\n                  <tr>\n                    <td valign=\"top\" bgcolor=\"#E6FBF2\" width=\"100\">職務内容</td>\n                    <td>\n                      製作図面に基づいた材料手配を行っていただきます。<br />\n                      お客様からのお問合せや材料メーカーとの電話でのやり取りが主な業務です。<br />\n                      （エクセル・AUTOCADを仕様）<br />\n                      未経験者歓迎です。ベテラン社員が丁寧に指導いたします。<br />\n                    </td>\n                  </tr>\n                  <tr>\n                    <td valign=\"top\" bgcolor=\"#E6FBF2\" width=\"100\">\n                      条件・備考\n                    </td>\n                    <td>\n                      ・職務経歴は不問となります。<br />\n                      ・コミュニケーションが取れる方、お取引先様、社内関連部署との調整が出来る方を募集いたします。<br />\n                      ・時間外労働有り　月平均 25時間<br />\n                    </td>\n                  </tr>\n                </tbody>\n              </table>\n              <!-- 資材調達業務 -->\n\n              <!-- 製缶・溶接員 -->\n              <div class=\"mt60\"></div>\n              <h3 class=\"wow fadeIn\">\n                <div class=\"inner\">\n                  <span>製造（製缶/溶接）業務</span>\n                </div>\n              </h3>\n              <table class=\"table spCol1\">\n                <tbody>\n                  <tr>\n                    <td valign=\"top\" bgcolor=\"#E6FBF2\" width=\"100\">募集職種</td>\n                    <td>製造（製缶/溶接）業務（最大1名）</td>\n                  </tr>\n                  <tr>\n                    <td valign=\"top\" bgcolor=\"#E6FBF2\" width=\"100\">雇用形態</td>\n                    <td>正社員</td>\n                  </tr>\n                  <tr>\n                    <td valign=\"top\" bgcolor=\"#E6FBF2\" width=\"100\">勤務地</td>\n                    <td>\n                      本社：茨城県日立市田尻町3-28-1<br />\n                      ※必要に応じて当社第二工場（日立市砂沢町）での業務を行う場合があります。（移動は公用車）\n                    </td>\n                  </tr>\n                  <tr>\n                    <td valign=\"top\" bgcolor=\"#E6FBF2\" width=\"100\">勤務時間</td>\n                    <td>8:00～16:45</td>\n                  </tr>\n                  <tr>\n                    <td valign=\"top\" bgcolor=\"#E6FBF2\" width=\"100\">休日</td>\n                    <td>\n                      週休二日制　会社カレンダーによる。<br />\n                      長期休暇：年末年始、GW、夏季休暇等　6カ月経過後の年次有給休暇日数\n                      10日\n                    </td>\n                  </tr>\n                  <tr>\n                    <td valign=\"top\" bgcolor=\"#E6FBF2\" width=\"100\">給与</td>\n                    <td>\n                      200,000円～300,000円<br />\n                      昇給有、賞与有（年二回、前年度実績50,000円～500,000円）\n                    </td>\n                  </tr>\n                  <tr>\n                    <td valign=\"top\" bgcolor=\"#E6FBF2\" width=\"100\">福利厚生</td>\n                    <td>\n                      健康診断、特別休暇、育児休業、皆勤手当、家族手当、住宅手当、ほか\n                    </td>\n                  </tr>\n                </tbody>\n                <tr>\n                  <td valign=\"top\" bgcolor=\"#E6FBF2\" width=\"100\">職務内容</td>\n                  <td>\n                    金属製品の溶接・製缶作業となります。<br />\n                    製品サイズは大小様々で、小さいものからトレーラーで運ぶ大きさまであります。<br />\n                    必要に応じて、重量物を取り扱うこともございます。<br />\n                    手先の器用な方、大歓迎です。<br />\n                    未経験者の応募も可能です。ベテラン社員が丁寧に指導いたします。<br />\n                  </td>\n                </tr>\n                <tr>\n                  <td valign=\"top\" bgcolor=\"#E6FBF2\" width=\"100\">条件・備考</td>\n                  <td>\n                    ・職務経歴は不問となります。<br />\n                    ・業務に必要・有利に働く資格（JIS溶接免許、フォークリフト、クレーン・玉掛け等）を取得頂ける場合には、費用は会社負担にて受検頂けます。<br />\n                    ・時間外労働有り　月平均 25時間<br />\n                  </td>\n                </tr>\n              </table>\n              <!-- 製缶・溶接員 -->\n\n              <!-- 塗装業務 -->\n              <div class=\"mt60\"></div>\n              <h3 class=\"wow fadeIn\">\n                <div class=\"inner\">\n                  <span>塗装業務</span>\n                </div>\n              </h3>\n              <table class=\"table spCol1\">\n                <tbody>\n                  <tr>\n                    <td valign=\"top\" bgcolor=\"#E6FBF2\" width=\"100\">募集職種</td>\n                    <td>製缶品の塗装業務（最大1名）</td>\n                  </tr>\n                  <tr>\n                    <td valign=\"top\" bgcolor=\"#E6FBF2\" width=\"100\">雇用形態</td>\n                    <td>正社員</td>\n                  </tr>\n                  <tr>\n                    <td valign=\"top\" bgcolor=\"#E6FBF2\" width=\"100\">勤務地</td>\n                    <td>\n                      本社：茨城県日立市田尻町3-28-1<br />\n                      ※必要に応じて当社第二工場（日立市砂沢町）での業務を行う場合があります。（移動は公用車）\n                    </td>\n                  </tr>\n                  <tr>\n                    <td valign=\"top\" bgcolor=\"#E6FBF2\" width=\"100\">勤務時間</td>\n                    <td>8:00～16:45</td>\n                  </tr>\n                  <tr>\n                    <td valign=\"top\" bgcolor=\"#E6FBF2\" width=\"100\">休日</td>\n                    <td>\n                      週休二日制　会社カレンダーによる。<br />\n                      長期休暇：年末年始、GW、夏季休暇等　6カ月経過後の年次有給休暇日数\n                      10日\n                    </td>\n                  </tr>\n                  <tr>\n                    <td valign=\"top\" bgcolor=\"#E6FBF2\" width=\"100\">給与</td>\n                    <td>\n                      200,000円～300,000円<br />\n                      昇給有、賞与有（年二回、前年度実績50,000円～500,000円）\n                    </td>\n                  </tr>\n                  <tr>\n                    <td valign=\"top\" bgcolor=\"#E6FBF2\" width=\"100\">福利厚生</td>\n                    <td>\n                      健康診断、特別休暇、育児休業、皆勤手当、家族手当、住宅手当ほか\n                    </td>\n                  </tr>\n                </tbody>\n                <tr>\n                  <td valign=\"top\" bgcolor=\"#E6FBF2\" width=\"100\">職務内容</td>\n                  <td>\n                    弊社で製作した鉄の製品の洗浄および塗装を行っていただきます。<br />\n                    主な塗装の種類は、ハケ塗り及び吹付塗装です。<br />\n                    増員に向けた募集でありベテラン社員による丁寧な指導を行えますので、未経験の方の応募も可能です。<br />\n                    業務に必要な資格（JIS溶接免許、フォークリフト、クレーン玉掛け等）を取得する際は、必要費用は会社が全額負担いたします。<br />\n                  </td>\n                </tr>\n                <tr>\n                  <td valign=\"top\" bgcolor=\"#E6FBF2\" width=\"100\">条件・備考</td>\n                  <td>\n                    ・職務経歴は不問となります。<br />\n                    ・時間外労働有り　月平均 25時間<br />\n                  </td>\n                </tr>\n              </table>\n              <!--  塗装業務 -->\n\n              <!-- 検査業務 -->\n              <div class=\"mt60\"></div>\n              <h3 class=\"wow fadeIn\">\n                <div class=\"inner\">\n                  <span>検査業務</span>\n                </div>\n              </h3>\n              <table class=\"table spCol1\">\n                <tbody>\n                  <tr>\n                    <td valign=\"top\" bgcolor=\"#E6FBF2\" width=\"100\">募集職種</td>\n                    <td>\n                      製品（機械加工品・製缶・溶接品等）の検査業務（最大1名）\n                    </td>\n                  </tr>\n                  <tr>\n                    <td valign=\"top\" bgcolor=\"#E6FBF2\" width=\"100\">雇用形態</td>\n                    <td>正社員</td>\n                  </tr>\n                  <tr>\n                    <td valign=\"top\" bgcolor=\"#E6FBF2\" width=\"100\">勤務地</td>\n                    <td>\n                      本社：茨城県日立市田尻町3-28-1<br />\n                      ※必要に応じて当社第二工場（日立市砂沢町）での業務を行う場合があります。（移動は公用車）\n                    </td>\n                  </tr>\n                  <tr>\n                    <td valign=\"top\" bgcolor=\"#E6FBF2\" width=\"100\">勤務時間</td>\n                    <td>8:00～16:45</td>\n                  </tr>\n                  <tr>\n                    <td valign=\"top\" bgcolor=\"#E6FBF2\" width=\"100\">休日</td>\n                    <td>\n                      週休二日制　会社カレンダーによる。<br />\n                      長期休暇：年末年始、GW、夏季休暇等　6カ月経過後の年次有給休暇日数\n                      10日\n                    </td>\n                  </tr>\n                  <tr>\n                    <td valign=\"top\" bgcolor=\"#E6FBF2\" width=\"100\">給与</td>\n                    <td>\n                      210,000円～300,000円<br />\n                      昇給有、賞与有（年二回、前年度実績50,000円～500,000円）\n                    </td>\n                  </tr>\n                  <tr>\n                    <td valign=\"top\" bgcolor=\"#E6FBF2\" width=\"100\">福利厚生</td>\n                    <td>\n                      健康診断、特別休暇、育児休業、皆勤手当、家族手当、住宅手当ほか\n                    </td>\n                  </tr>\n                </tbody>\n                <tr>\n                  <td valign=\"top\" bgcolor=\"#E6FBF2\" width=\"100\">職務内容</td>\n                  <td>\n                    弊社で製作した機械加工品、製缶品、溶接品等の検査を行って頂きます。<br />\n                    基本的な業務内容は、弊社で製造した製品の出荷準備（社内検査、受入製品検査）となり、成績表の作成を行って頂きます。<br />\n                    検査内容は、大小様々な製品の寸法検査、耐圧試験（水圧等）から始まり、将来的には資格を要する非破壊検査の実施もご担当頂くことを想定しております。<br />\n                    日立製作所をはじめとする大手電機メーカーの電力事業部様向けの金属製品の検査がメインとなります。<br />\n                    未経験の方の応募も可能です。弊社のベテラン社員が丁寧に指導をいたします。<br />\n                    また、もちろん各種非破壊検査等、業務に必要となる資格の取得、研修費用等は会社が全額負担いたします。<br />\n                  </td>\n                </tr>\n                <tr>\n                  <td valign=\"top\" bgcolor=\"#E6FBF2\" width=\"100\">条件・備考</td>\n                  <td>\n                    ・職務経歴は不問となります。<br />\n                    ・時間外労働有り　月平均 25時間<br />\n                  </td>\n                </tr>\n              </table>\n              <!--  検査業務 -->\n\n              <a class=\"cpr-a-gr\" href=\"https://www.sunmec.jp/entry/\">\n                <div class=\"btn_cpr-green\">\n                  <span>エントリーフォームへ</span>\n                </div></a\n              >\n            </div>\n          </section>\n          <section>\n            <div class=\"visit-cta-wrap\">\n                <p class=\"visit-cta-lead fadeIn\">高校生向け採用ページはこちら</p>\n                <div class=\"visit-cta-bubble2\">実際の仕事や職場の雰囲気が分かる！</div>\n              </div>\n              <div class=\"jobdraft-wrap\">\n                <a href=\"https://job-draft.com/jobs/7944\" class=\"jobdraft-link\">\n                  <img\n                    src=\"img/recruit/jobdraft2.jpg\"\n                    alt=\"ジョブドラフト\"\n                  />\n                </a>\n              </div>\n            <h2 class=\"wow fadeIn\">\n              <div class=\"inner\"><span>求める人物像</span></div>\n            </h2>\n            <div class=\"inner\">\n              <p>\n                明るく活発な方で、向上心を持って仕事の出来る人材。やる気があれば経験は問いません。\n              </p>\n            </div>\n          </section>\n          <section>\n            <h2 class=\"wow fadeIn\">\n              <div class=\"inner\"><span>サンメックで働く社員の声</span></div>\n            </h2>\n            <div class=\"inner\">\n              <h3 class=\"wow fadeInUp\">\n                <span>サンメックのいいところ！</span>\n              </h3>\n              <p>\n                ・初心者での入社でも、各作業のマニュアルがあるので安心できます。<br />\n                ・先輩社員が丁寧に教えてくれるところ！<br />\n                ・会社が資格取得に力を入れており、支援もしてくれる。<br />\n                ・各部署（設計、業務、製造、品証）の連携が取れているので仕事の流れがスムーズです。\n              </p>\n              <div class=\"mt60\">\n                <h3 class=\"wow fadeInUp\"><span>仕事のやりがい</span></h3>\n                <p>\n                  ・製作品が量産品よりも一品一様なものが多く、大小さまざまなものを取り扱うので常に新鮮な気持ちで仕事に取り組むことができます。<br />\n                  ・一品一様品が多いので、技術や知識、考える力が身に付き、それが評価に結び付くことが仕事の醍醐味でもあります！\n                </p>\n              </div>\n              <div class=\"mt60\">\n                <h3 class=\"wow fadeInUp\"><span>挑戦したいこと</span></h3>\n                <p>\n                  ・今後はJIS溶接資格の各種類取得を目指し、どんなものが受注されても製作できるエンジニアになりたいです！<br />\n                  ・将来の夢は、製造部の技術指導員としてのキャリアアップも目指していきたいです。\n                </p>\n              </div>\n              <figure class=\"full mt25\">\n                <span><img src=\"img/recruit/re02.png\" /></span>\n                <figcaption></figcaption>\n              </figure>\n\n              <a class=\"cpr-a-gr\" href=\"https://www.sunmec.jp/entry/\">\n                <div class=\"btn_cpr-green\">\n                  <span>エントリーフォームへ</span>\n                </div></a\n              >\n            </div>\n          </section>\n        </article>\n      </div>\n      <!-- InstanceEndEditable -->\n      <footer>\n        <div class=\"foot_main\">\n          <div class=\"inner flexbox\">\n            <div class=\"col_c\">\n              <p class=\"text-center\">\n                構想段階からのご相談・技術的なご相談・御見積など<br />\n                お気軽にお問い合わせください。\n              </p>\n              <ul class=\"flexbox nowrap stretch mt10\">\n                <li class=\"flexbox\">\n