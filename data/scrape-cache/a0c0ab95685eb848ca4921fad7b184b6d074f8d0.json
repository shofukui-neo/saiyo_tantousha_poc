   <a class=\"nav__txt\" href=\"why.html\">Vision</a>\n        <ul class=\"child-nav\">\n          <li><a href=\"why.html#next\" class=\"anchor-link child-nav__txt\">Next Future</a></li>\n          <!--  <li><a href=\"why.html#message\" class=\"anchor-link child-nav__txt\">代表Message</a></li>  -->\n          <li><a href=\"why.html#strategy\" class=\"anchor-link child-nav__txt\">成長戦略</a></li>\n        </ul>\n      </li>\n      <li>\n        <a class=\"nav__txt\" href=\"how.html\">Education</a>\n        <ul class=\"child-nav\">\n          <li><a href=\"how.html#education\" class=\"anchor-link child-nav__txt\">教育制度</a></li>\n          <li><a href=\"how.html#welfare\" class=\"anchor-link child-nav__txt\">福利厚生</a></li>\n        </ul>\n      </li>\n      <li>\n        <a class=\"nav__txt\" href=\"recruit.html\">Recruit</a>\n        <ul class=\"child-nav\">\n          <li><a href=\"recruit.html#recruit\" class=\"anchor-link child-nav__txt\">募集要項</a></li>\n        </ul>\n      </li>\n      <li>\n        <a class=\"nav__txt\" href=\"data.html\">Data</a>\n        <ul class=\"child-nav\">\n          <li><a href=\"data.html#data\" class=\"anchor-link child-nav__txt\">数字で見る島忠</a></li>\n        </ul>\n      </li>\n    </ul>\n\n    <div class=\"hamburger-nav__btns\">\n      <div class=\"entry-btns\">\n        <div class=\"nav-entry-btn\">Entry</div>\n        <a href=\"https://job.axol.jp/bx/s/nitorihd_27/entry_2515020041\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"nav-entry-btn\">27年卒</a>\n        <a href=\"https://axol.jp/zw/s/nitorihd_28/entry/agreement\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"nav-entry-btn\">28年卒</a>\n      </div>\n      <a href=\"https://www.shimachu.co.jp\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"nav-corporate-btn\">Corporate site</a>\n    </div>\n\n    <div class=\"hamburger-nav__loop-msg\">\n      <div class=\"hamburger-nav__loop-msg__item\">The Revolution Starts With You. The Revolution Starts With You.</div>\n      <div class=\"hamburger-nav__loop-msg__item\">The Revolution Starts With You. The Revolution Starts With You.</div>\n    </div>\n  </div>\n\n  <div id=\"headerSpace\" class=\"headerSpace\"></div>\n  <header id=\"header\" class=\"header\">\n    <div class=\"header__inner\">\n      <div class=\"header__logo\">\n        <a href=\"index.html\"><img src=\"assets/imgs/common/site-logo.png\" alt=\"家具・ホームセンター HOME&apos;S 島忠\"></a><span>『革命』は、君から始まる。</span>\n      </div>\n      <div class=\"header__btns\">\n        <a href=\"fair_recruitment_declaration.html\" class=\"header-btn --orange\">公平・公正な採用活動について</a>\n        <a href=\"what.html\" class=\"header-btn --orange\">個々の革命</a>\n        <div class=\"entry-btns\">\n          <div class=\"header-btn --gray\">Entry</div>\n          <a href=\"https://job.axol.jp/bx/s/nitorihd_27/entry_2515020041\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"header-btn --gray\">27年卒</a>\n          <a href=\"https://axol.jp/zw/s/nitorihd_28/entry/agreement\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"header-btn --gray\">28年卒</a>\n        </div>\n      </div>\n    </div>\n  </header>\n\n  <!--  main ////////////////////////////////////////////////////////////////////////////////////////////////////  -->\n  <main class=\"main\">\n    <section class=\"sec-page-head page-head bg-beige\">\n      <div class=\"sec-page-head__inner\">\n        <div class=\"page-head__body\">\n          <div class=\"vertical-line\"></div>\n          <h2 class=\"page-head__ttl\"><span class=\"en\">When</span><span class=\"jp\">島忠のキャリアステップ</span></h2>\n          <div class=\"page-head__copy\">日々チャレンジを積み重ね<br>新たな革命を<br>生み出していく</div>\n          <p class=\"page-head__txt\">\n            実績を積み重ねることでキャリアの幅は広がり、<br>\n            一人ひとりが思い描く革命の形が実現されるでしょう。<br>\n            島忠で経験を重ね、自分を磨き、スペシャリストを目指しませんか？\n          </p>\n        </div>\n        <div class=\"page-head__img\">\n          <div class=\"page-head__img__accent-wrapper\">\n            <div class=\"page-head__img__accent\">When</div>\n          </div>\n          <div class=\"page-head__img__photo-wrapper\">\n            <img class=\"page-head__img__photo\" src=\"assets/imgs/when/page-head_when.webp\" srcset=\"assets/imgs/when/page-head_when.webp 1x, assets/imgs/when/page-head_when@2x.webp 2x\" alt=\"\">\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <section id=\"career\" class=\"sec-career-step career-step bg-beige\">\n      <div class=\"sec-career-step__inner\">\n        <div class=\"career-step__overview\">\n          <div class=\"career-step__overview__body\">\n            <div class=\"ttl-style-2-wrapper\">\n              <h2 class=\"career-step__ttl ttl-style-2 js-title\">Career Step</h2>\n            </div>\n            <div class=\"career-step__overview__img --sp fadein\">\n              <img src=\"assets/imgs/when/career_illust.webp\" srcset=\"assets/imgs/when/career_illust.webp 1x, assets/imgs/when/career_illust@2x.webp 2x\" alt=\"\">\n            </div>\n            <p class=\"career-step__txt fadein\">社員一人ひとりが年次やスキルに応じて、確実にキャリアアップをはかれるよう、入社後からさまざまな研修を用意しています。“自身の成長が実感できる”教育の機会を提供することで、社員一人ひとりのキャリアアップへの意欲に応えています。配転を実施し、さまざまな仕事を経験することでキャリア形成に繋げていきます。</p>\n          </div>\n          <div class=\"career-step__overview__img --pc fadein\">\n            <img src=\"assets/imgs/when/career_illust.webp\" srcset=\"assets/imgs/when/career_illust.webp 1x, assets/imgs/when/career_illust@2x.webp 2x\" alt=\"\">\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <section id=\"system\" class=\"sec-system system  bg-beige\">\n      <div class=\"sec-system__inner\">\n        <div class=\"system__overview\">\n          <div class=\"system__overview__img --pc fadein\">\n            <img src=\"assets/imgs/when/system_illust.webp\" srcset=\"assets/imgs/when/system_illust.webp 1x, assets/imgs/when/system_illust@2x.webp 2x\" alt=\"\">\n          </div>\n          <div class=\"system__overview__body\">\n            <div class=\"ttl-style-2-wrapper\">\n              <h2 class=\"system__ttl ttl-style-2 js-title\">New System</h2>\n              <div class=\"system__subttl ttl-style-2-subttl js-title\">配転教育で</div>\n              <div class=\"system__subttl ttl-style-2-subttl js-title\">真の「スペシャリスト」へ</div>\n            </div>\n            <div class=\"system__overview__img --sp fadein\">\n              <img src=\"assets/imgs/when/system_illust.webp\" srcset=\"assets/imgs/when/system_illust.webp 1x, assets/imgs/when/system_illust@2x.webp 2x\" alt=\"\">\n            </div>\n            <p class=\"system__txt fadein\">これから求められるのは、一つの専門分野だけに特化した人材ではなく、幅広い経験と豊富な知識をもち、様々な分野で活躍できる人材。そしてそれこそが、真の「スペシャリスト」だと考えています。<br>そうした人材育成のために、ニトリグループ独自で行われているのが「配転教育」です。2～3年の短いスパンで、様々な店舗、部署、職位を経験する制度です。幅広い業務を経験することで、広い視野と論理的な思考が養われていきます。店舗での経験を原点に、様々な経験とそこで得たスキルを掛け合わせ、スペシャリストへと成長していきます。島忠に革命を起こし、そして一人ひとりが生き生きと働くための制度、それが配転教育です。</p>\n          </div>\n        </div>\n        <div class=\"system__img fadein fadein\">\n          <img src=\"assets/imgs/when/system_image.webp\" srcset=\"assets/imgs/when/system_image.webp 1x, assets/imgs/when/system_image@2x.webp 2x\" alt=\"\">\n        </div>\n      </div>\n    </section>\n\n    <section id=\"careerUp\" class=\"sec-career-up career-up  bg-beige\">\n      <div class=\"sec-career-up__inner\">\n        <div class=\"ttl-style-2-wrapper\">\n          <h2 class=\"career-up__ttl ttl-style-2 js-title\">Career Up</h2>\n          <div class=\"career-up__subttl ttl-style-2-subttl js-title\">店舗でのキャリアアップ例</div>\n        </div>\n\n        <div id=\"splide1\" class=\"splide splide-1\" role=\"group\" aria-label=\"career-up\">\n          <div class=\"splide__track\">\n\n            <div class=\"splide__list career-up__contents\">\n\n              <div class=\"splide__slide career-up-card-wrap\">\n                <div class=\"career-up-card career-up-card--1 scroll-illust-wrapper\">\n                  <div class=\"scroll-illust\">\n                    <img src=\"assets/imgs/common/scroll-illust.png\" srcset=\"assets/imgs/common/scroll-illust.png 1x, assets/imgs/common/scroll-illust@2x.png 2x\" alt=\"\">\n                  </div>\n                  <div class=\"career-up-card__num\">01</div>\n                  <div class=\"career-up-card__ttl\"><span>担当</span></div>\n                  <div class=\"career-up-card__label\"><span>入社1〜3年目</span></div>\n                  <div class=\"career-up-card__content\">\n                    <p class=\"career-up-card__content__txt\">\n                      <span>ー</span>チェーンストア理論研修<br>\n                      <span>ー</span>入社前研修<br>\n                      <span>ー</span>新入社員研修<br>\n                      <span>ー</span>1年目、2年目、3年目期別研修<br>\n                      <span>ー</span>指導員コーチング研修<br>\n                      <span>ー</span>技術習得研修<br>\n                      <span>ー</span>本部ジョブシャドウイング研修<br>　（3年目）<br>\n                    </p>\n                    <div class=\"career-up-card__content__img\">\n                      <img src=\"assets/imgs/when/career-up01.webp\" srcset=\"assets/imgs/when/career-up01.webp 1x, assets/imgs/when/career-up01@2x.webp 2x\" alt=\"\">\n                    </div>\n                  </div>\n                </div>\n              </div>\n\n              <div class=\"splide__slide career-up-card-wrap\">\n                <div class=\"career-up-card career-up-card--2 fadein2 _right\">\n                  <div class=\"career-up-card__num\">02</div>\n                  <div class=\"career-up-card__ttl\"><span><img src=\"assets/imgs/when/career-up-arrow01.svg\" alt=\"\">フロアマネジャー</span></div>\n                  <div class=\"career-up-card__label\"><span>入社4〜6年目</span></div>\n                  <div class=\"career-up-card__content\">\n                    <p class=\"career-up-card__content__txt\">\n                      <span>ー</span>チェーンストア理論研修<br>\n                      <span>ー</span>コンプライアンス研修<br>\n                      <span>ー</span>新任役職者研修<br>\n                      <span>ー</span>ビジョナリーリーダー研修<br>\n                      <span>ー</span>競合店調査研修<br>\n                    </p>\n                    <div class=\"career-up-card__content__img\">\n                      <img src=\"assets/imgs/when/career-up02.webp\" srcset=\"assets/imgs/when/career-up02.webp 1x, assets/imgs/when/career-up02@2x.webp 2x\" alt=\"\">\n                    </div>\n                  </div>\n                </div>\n              </div>\n\n              <div class=\"splide__slide career-up-card-wrap\">\n                <div class=\"career-up-card career-up-card--3 fadein3 _right\">\n                  <div class=\"career-up-card__num\">03</div>\n                  <div class=\"career-up-card__ttl\"><span><img src=\"assets/imgs/when/career-up-arrow02.svg\" alt=\"\">店長</span></div>\n                  <div class=\"career-up-card__label\"><span>入社7年目〜</span></div>\n                  <div class=\"career-up-card__content\">\n                    <p class=\"career-up-card__content__txt\">\n                      <span>ー</span>チェーンストア理論研修<br>\n                      <span>ー</span>コンプライアンス研修<br>\n                      <span>ー</span>新任役職者研修<br>\n                      <span>ー</span>ビジョナリーリーダー研修<br>\n                      <span>ー</span>競合店調査研修<br>\n                    </p>\n                    <div class=\"career-up-card__content__img\">\n                      <img src=\"assets/imgs/when/career-up03.webp\" srcset=\"assets/imgs/when/career-up03.webp 1x, assets/imgs/when/career-up03@2x.webp 2x\" alt=\"\">\n                    </div>\n                  </div>\n                </div>\n              </div>\n\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"sec-loop-5w1h bg-beige\">\n      <div id=\"mySplideLoop5w1h\" class=\"splide loop-5w1h\">\n        <div class=\"splide__track\">\n          <ul class=\"splide__list\">\n            <li class=\"splide__slide\"><a class=\"loop-5w1h__item\" href=\"when.html\"><div class=\"ttl\">When</div><div class=\"txt\">島忠のCareer Step →</div></