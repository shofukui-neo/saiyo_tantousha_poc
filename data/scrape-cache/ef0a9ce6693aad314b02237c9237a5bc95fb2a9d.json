{"url":"https://www.cat-kyushu.co.jp/lp/recruit/","html":"<html lang=\"ja\">\n\n<head>\n  <title>キャタピラー九州|採用情報</title>\n  <meta charset=\"utf-8\">\n  <meta name=\"description\" content=\"\" />\n  <meta name=\"keywords\" content=\"\" />\n  <meta name=\"viewport\" content=\"width=device-width\">\n  <meta name=\"author\" content=\"キャタピラー九州株式会社\">\n  <meta name=\"copyright\" content=\"(c) 2026 キャタピラー九州株式会社\" />\n  <meta property=\"og:title\" content=\"キャタピラー九州|採用情報\">\n  <meta property=\"og:description\" content=\"\">\n  <meta property=\"og:url\" content=\"https://www.cat-kyushu.co.jp/\">\n  <meta property=\"og:site_name\" content=\"キャタピラー九州株式会社\">\n  <meta property=\"og:type\" content=\"website\">\n  <meta property=\"og:image\" content=\"./img/common/img-social.jpg\">\n  <meta property=\"og:locale\" content=\"ja_JP\">\n  <meta http-equiv=\"imagetoolbar\" content=\"no\">\n  <link rel=\"index\" href=\"https://www.cat-kyushu.co.jp/\" />\n  <link rel=\"shortcut icon\" href=\"./img/favicon.ico\">\n  <link rel=\"stylesheet\" href=\"https://stackpath.bootstrapcdn.com/bootstrap/4.5.0/css/bootstrap.min.css\"\n    integrity=\"sha384-9aIt2nRpC12Uk9gS9baDl411NQApFmC26EwAOH8WgZl5MYYxFfc+NcPb1dKGj7Sk\" crossorigin=\"anonymous\">\n  <link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/swiper@8/swiper-bundle.min.css\">\n  <!-- <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/lightbox2/2.11.4/css/lightbox.css\"> -->\n  <link rel=\"stylesheet\" href=\"./css/style.css?2026011902000\">\n  <link rel=\"stylesheet\" href=\"./css/light-box.css?2023060051629\">\n  <script src=\"https://code.jquery.com/jquery-3.6.0.min.js\"\n    integrity=\"sha256-/xUj+3OJU5yExlq6GSYGSHk7tPXikynS7ogEvDej/m4=\" crossorigin=\"anonymous\"></script>\n  <script src=\"https://cdn.jsdelivr.net/npm/popper.js@1.16.0/dist/umd/popper.min.js\"\n    integrity=\"sha384-Q6E9RHvbIyZFJoft+2mJbHaEWldlvI9IOYy5n3zV9zzTtmI3UksdQRVvoxMfooAo\"\n    crossorigin=\"anonymous\"></script>\n  <script src=\"https://stackpath.bootstrapcdn.com/bootstrap/4.5.0/js/bootstrap.min.js\"\n    integrity=\"sha384-OgVRvuATP1z7JjHLkuOU7Xw704+h835Lr+6QL9UvYjZE3Ipu6Tp75j7Bh/kR0JKI\"\n    crossorigin=\"anonymous\"></script>\n  <script src=\"https://cdnjs.cloudflare.com/ajax/libs/smooth-scroll/16.1.3/smooth-scroll.min.js\"\n    integrity=\"sha512-HYG9E+RmbXS7oy529Nk8byKFw5jqM3R1zzvoV2JnltsIGkK/AhZSzciYCNxDMOXEbYO9w6MJ6SpuYgm5PJPpeQ==\"\n    crossorigin=\"anonymous\" referrerpolicy=\"no-referrer\"></script>\n  <script src=\"https://cdn.jsdelivr.net/npm/swiper@9/swiper-bundle.min.js\"></script>\n  <script src=\"https://cdnjs.cloudflare.com/ajax/libs/jquery/3.2.1/jquery.min.js\"></script>\n  <script src=\"https://cdnjs.cloudflare.com/ajax/libs/lightbox2/2.11.4/js/lightbox.min.js\"></script>\n  <script src=\"https://unpkg.com/scrollreveal\"></script>\n</head>\n\n<body>\n  <header>\n    <div class=\"title-all\">\n      <a href=\"https://www.cat-kyushu.co.jp/\" class=\"navbar-brand\"><img\n          src=\"https://www.cat-kyushu.co.jp/kc/static/img/logo.png\" class=\"img-fluid full\">\n      </a>\n      <span class=\"company-title\">建設機械の専門商社<br>キャタピラー九州株式会社 </span>\n    </div>\n    <span class=\"Recruiting-Site\">Recruiting Site</span>\n  </header>\n  <main>\n    <article>\n      <section class=\"bg-common fv-area\">\n        <div class=\"swiper\">\n          <div class=\"swiper-wrapper\">\n            <div class=\"swiper-slide d-none d-md-block\"><img src=\"./img/main-img.png\" class=\"img-fluid full\"></div>\n            <div class=\"swiper-slide d-block d-md-none\"><img src=\"./img/main-img-sp.jpg\" class=\"img-fluid full\"></div>\n            <div class=\"swiper-slide d-none d-md-block\"><img src=\"./img/cat-lp-slide2.jpg\" class=\"img-fluid full\"></div>\n            <div class=\"swiper-slide d-block d-md-none\"><img src=\"./img/cat-lp-slide2-sp.jpg\" class=\"img-fluid full\">\n            </div>\n            <div class=\"swiper-slide d-none d-md-block\"><img src=\"./img/cat-lp-slide3.jpg\" class=\"img-fluid full\"></div>\n            <div class=\"swiper-slide d-block d-md-none\"><img src=\"./img/cat-lp-slide3-sp.jpg\" class=\"img-fluid full\">\n            </div>\n          </div>\n          <div class=\"text-area\">\n            <div class=\"ttl-area\">\n              <h1 class=\"title invert\"><span class=\"ttl center\">不確かな未来に<br>確かな技術を。</span></h1>\n            </div>\n          </div>\n      </section>\n      <section class=\"bg-common intro\">\n        <div class=\"container-fluid inner\">\n          <div class=\"cont\">\n            <div class=\"cont-main\">\n              <div class=\"block_5 cont-item\">\n                <div class=\"row row-intro row-stretch\">\n                  <div class=\"col-12 col-md-6 item item-text\">\n                    <div class=\"cont v-middle\">\n                      <div class=\"box\">\n                        <div class=\"metabox\">\n                          <p>\n                            キャタピラー九州は、世界トップシェアの建設機械を扱う専門商社。あらゆる機械を修理できる高度な整備技術と、建設業の経営支援まで行う営業スキルを身に付け、九州の街づくりを一緒に支えませんか？チームワークが好きな方、毎日新しい発見をしたい方、一生モノのスキルを手にしたい方、大歓迎です。\n                          </p>\n                        </div>\n                      </div>\n                    </div>\n                  </div>\n                  <div class=\"col-12 col-md-6 item item-image\">\n                    <div class=\"cont v-middle\">\n                      <div class=\"box\">\n                        <div class=\"image-area\">\n                          <div class=\"image\"><img src=\"./img/intro.jpg\" class=\"img-fluid full\"></div>\n                        </div>\n                      </div>\n                    </div>\n                  </div>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </section>\n      <h2 class=\"h-big\">身につけた技術は、未来を生きる武器になる。</h2>\n      </section>\n      <section class=\"bg-common our-work bg-blue\">\n        <div class=\"container-fluid inner\">\n          <div class=\"block_3\">\n            <div class=\"cont\">\n              <div class=\"cont-main\">\n                <div class=\"block_5 cont-item\">\n                  <div class=\"ttl-area\">\n                    <h2 class=\"title black\"><span class=\"ttl ttl-01\"><span class=\"ttl-eng\">OUR WORK</span>\n                        <div class=\"yellow-bottom\">\n                          <img src=\"./img/yellow-bottom.png\" class=\"img-fluid full\">\n                        </div>\n                        <span class=\"ttl-jpn\">キャタピラー九州の仕事</span>\n                      </span>\n                    </h2>\n                  </div>\n                  <div class=\"catch-area\">\n                    <div class=\"text-area\">\n                      <h3 class=\"title center\"><span class=\"ttl ttl-02 center\"><span>メインサポートカンパニー</span></span></h3>\n                      <h4 class=\"center\"><span>お客様が困ったときに<br class=\"sp\">一番頼れるパートナー</span></h4>\n                      <div class=\"metabox main\">\n                        <p>\n                          私たちは建設機械の専門商社として、販売から修理・メンテナンスなどのアフターサポートまで行っています。メーカー系列でない独立商社だからこそ、知恵と技術で多様なサービスを展開し、お客様の課題解決に柔軟に対応しています。\n                        </p>\n                      </div>\n                    </div>\n                  </div>\n                </div>\n                <div class=\"block_5 cont-item\">\n                  <div class=\"row row-our-work row-stretch row-styleB\">\n                    <div class=\"col-12 col-md-4 item\">\n                      <div class=\"cont\">\n                        <div class=\"box\">\n                          <div class=\"image-area\">\n                            <div class=\"image\"><img src=\"./img/our-work-list-1.jpg\" class=\"img-fluid full\"></div>\n                          </div>\n                          <div class=\"ttl-area\">\n                            <h4 class=\"title\"><span class=\"ttl ttl-03 center\"><span>営業・販売</span></span></h4>\n                          </div>\n                          <div class=\"img-1 center\">\n                            <img src=\"./img/img-1.png\" class=\"img-fluid full\">\n                          </div>\n                          <div class=\"metabox\">\n                            <p>キャタピラー社の正規ディーラーとして新車・中古車の販売を行っております。</p>\n                          </div>\n                        </div>\n                      </div>\n                    </div>\n                    <div class=\"col-12 col-md-4 item\">\n                      <div class=\"cont\">\n                        <div class=\"box\">\n                          <div class=\"image-area\">\n                            <div class=\"image\"><img src=\"./img/our-work-list-2.jpg\" class=\"img-fluid full\"></div>\n                          </div>\n                          <div class=\"ttl-area\">\n                            <h4 class=\"title\"><span class=\"ttl ttl-03 center\"><span>修理・メンテナンス</span></span></h4>\n                          </div>\n                          <div class=\"img-1 center\">\n                            <img src=\"./img/img-1.png\" class=\"img-fluid full\">\n                          </div>\n                          <div class=\"metabox\">\n                            <p>建設機械をお届けした後も、長期的に使用していただくため、修理やメンテナンスを行っています。</p>\n                          </div>\n                        </div>\n                      </div>\n                    </div>\n                    <div class=\"col-12 col-md-4 item\">\n                      <div class=\"cont\">\n                        <div class=\"box\">\n                          <div class=\"image-area\">\n                            <div class=\"image\"><img src=\"./img/our-work-list-3.jpg\" class=\"img-fluid full\"></div>\n                          </div>\n                          <div class=\"ttl-area\">\n                            <h4 class=\"title\"><span class=\"ttl ttl-03 center\"><span>部品交換等のご提案</span></span></h4>\n                          </div>\n                          <div class=\"img-1 center\">\n                            <img src=\"./img/img-1.png\" class=\"img-fluid full\">\n                          </div>\n                          <div class=\"metabox\">\n                            <p>長く・安全に建設機械を使用していただくため、部品の交換やコスト削減のサポートをしています。</p>\n                          </div>\n                        </div>\n                      </div>\n                    </div>\n                  </div>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </section>\n      <section class=\"bg-common collaborate\">\n        <div class=\"container-fluid inner\">\n          <div class=\"block_1\">\n            <div class=\"cont\">\n              <div class=\"cont-main\">\n                <div class=\"block_5 cont-item\">\n                  <div class=\"ttl-area\">\n                    <h4 class=\"center title-1\">世界一の安心と、<br class=\"sp\">九州を支える誇り</h4>\n                    <div class=\"metabox main\">\n                      <p> 建設機械は、建築・災害復興・インフラなど、社会のあらゆる場面で活躍しています。創業から60年以上に亘り、社会を創る建設機械をお届けすることで、街づくりの基盤を支えています。 </p>\n                      <div class=\"img-collaborate\">\n                        <img src=\"./img/img-collaborate.png\" class=\"img-fluid full\">\n                      </div>\n                      <div class=\"metabox main\">\n                        <p>\n                          当社は『100年間世界シェア不動の1位』『世界で最も賞賛される企業※』である米キャタピラー社の正規ディーラーです。2017年からは、九州の街づくりを第一線で行っているJR九州グループに参画し、都市開発に大きく貢献しています。\n                        </p>\n                        <p class=\"small-p\"> ※フォーチュン誌 </p>\n                      </div>\n                    </div>\n                  </div>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </section>\n      <section class=\"bg-common our-job\">\n        <div class=\"block_3\">\n          <div class=\"cont\">\n            <div class=\"cont-main\">\n              <div class=\"ttl-area\">\n                <h2 class=\"title black\"><span class=\"ttl ttl-01\"><span class=\"ttl-eng\">OUR JOB</span>\n                    <div class=\"yellow-bottom\">\n                      <img src=\"./img/yellow-bottom.png\" class=\"img-fluid full\">\n                    </div>\n                    <span class=\"ttl-jpn\">キャタピラー九州の職種</span>\n                  </span></h2>\n              </div>\n              <div class=\"cont-item\">\n                <div class=\"container-fluid inner\">\n                  <div class=\"block_10 pc\"></div>\n                  <!-- <div class=\"metabox sp\">\n\n                      <p>横にスクロールしてご覧ください。</p> -->\n                  <div class=\"image-area scroll\">\n                    <div class=\"bg-job\">\n                      <div class=\"image d-none d-md-block\"><img src=\"./img/bg-job.png?202601190\" class=\"img-fluid full\">\n                      </div>\n                      <div class=\"image d-block d-md-none\"><img src=\"./img/bg-job-sp.png?202601190\"\n                          class=\"img-fluid full\"></div>\n                    </div>\n                  </div>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n        </div>\n        </div>\n      </section>\n      <section class=\"bg-common meet-our-team\">\n        <div class=\"container-fluid inner\">\n          <div class=\"block_3\">\n            <div class=\"cont\">\n              <div class=\"cont-main\">\n                <div class=\"block_5 cont-item\">\n                  <div class=\"ttl-area\">\n                    <!-- <h2 class=\"title\"><span class=\"ttl ttl-01\"><span class=\"ttl-jpn\">キャタピラー九州の社員紹介</span><span class=\"ttl-eng\">MEET OUR TEAM</span></span></h2> -->\n                    <h2 class=\"title black\"><span class=\"ttl ttl-01\"><span class=\"ttl-eng\">MEET OUR TEAM</span>\n                        <div class=\"yellow-bottom\">\n                          <img src=\"./img/yellow-bottom.png\" class=\"img-fluid full\">\n                        </div>\n                        <span class=\"ttl-jpn\">キャタピラー九州の社員紹介</span>\n                      </span>\n                    </h2>\n                  </div>\n                  <div class=\"cont-main meet-our-team-list\">\n                    <div class=\"block_5 cont-item\">\n                      <div class=\"ttl-area profile\">\n                        <h3 class=\"title\">\n                          <div class=\"yellow-block\">\n                          </div><span class=\"ttl ttl-04\"><span class=\"text\">メカニック4年目</span></span>\n                        </h3>\n                      </div>\n                      <div class=\"row row-meet-our-team row-stretch row-cross\">\n                        <div class=\"col-12 col-md-3 item item-image\">\n                          <div class=\"cont\">\n                            <div class=\"box\">\n                              <div class=\"image\"><img src=\"./img/meet-our-team-1-1.jpg\" class=\"img-fluid full\"></div>\n                              <!-- <div class=\"block_10\"></div> -->\n                            </div>\n                          </div>\n                        </div>\n                        <div class=\"col-12 col-md-9 item item-text\">\n                          <div class=\"cont\">\n                            <div class=\"box\">\n                              <div class=\"block_10\">\n                                <div class=\"ttl-area\">\n                                  <h4 class=\"title\"><span class=\"ttl ttl-05\"><span>地元で安定して働く</span></span></h4>\n                                </div>\n                                <div class=\"metabox\">\n                                  <p>企業を探していく中で建機業界のことを知り、<span\n                                      class=\"bg-yellow-1\">先々の経済状況に寄らず残り続けていく産業・業界であり、安定した需要がある</span>ところに魅力を感じました。\n                                    <br>また、私は高校・大学が県外だったので、<span\n                                      class=\"bg-yellow-1\">就職するときは地元に就職したいと思っていた</span>ことも理由の一つです。\n                                  </p>\n                                </div>\n                              </div>\n                              <div class=\"block_5\">\n                                <div class=\"ttl-area\">\n                                  <h4 class=\"title\"><span class=\"ttl ttl-05\"><span>未経験からのスタート</span></span></h4>\n                                </div>\n                                <div class=\"metabox\">\n                                  <p>私は経済系の学部出身であり、全くの未経験でしたが、不安はありませんでした。 <br><span\n                                      class=\"bg-yellow-1\">キャタピラー九州では資格取得のための研修や基礎知識をインプットする場が整えられている</span>ので未経験者でも十分に巻き返すことができると感じました。\n                                  </p>\n                                </div>\n                              </div>\n                            </div>\n                          </div>\n                        </div>\n                      </div>\n                      <div class=\"row row-meet-our-team row-stretch row-cross\">\n                        <div class=\"col-12 col-md-3 item item-image\">\n                          <div class=\"cont\">\n                            <div class=\"box\">\n                              <div class=\"block_10\"></div>\n                              <div class=\"image\"><img src=\"./img/meet-our-team-1-2.jpg\" class=\"img-fluid full\"></div>\n                              <!-- <div class=\"block_10\"></div> -->\n                            </div>\n                          </div>\n                        </div>\n                        <div class=\"col-12 col-md-9 item item-text\">\n                          <div class=\"cont\">\n                            <div class=\"box\">\n                              <div class=\"block_10\">\n                                <div class=\"ttl-area\">\n                                  <br>\n                                  <h4 class=\"title\"><span class=\"ttl ttl-05\"><span>毎日、新しい問題解決にチャレンジする爽快さ</span></span>\n                                  </h4>\n                                </div>\n                                <div class=\"metabox\">\n                                  <p>建機は一般的な車と使用している環境が違うため、壊れ方も全く違います。 <br>そのため、現場に行ってみないとトラブルの原因が分からないことが多いです。\n                                    <br><span\n                                      class=\"bg-yellow-1\">難解な修理を完了したときにはやり切った達成感・爽快感を感じます。</span>また、例えば「マシンのある部位が動かない」という問題が起こっていたとしても、機械の種類や仕様・用途・年式の違いなどによって、その理由はさまざまです。加えて、現場の状況や環境等も毎回異なるため、同じシチュエーションでの整備（解決方法）はありません。<span\n                                      class=\"bg-yellow-1\">毎日違う修理に対応していく中で、成長をすごく感じています。</span>\n                                  </p>\n                                  <!-- <p></p> -->\n                                </div>\n                              </div>\n                            </div>\n                          </div>\n                        </div>\n                      </div>\n                    </div>\n                    <!-- 第二个人 -->\n                    <div class=\"block_5 cont-item\">\n                      <div class=\"ttl-area profile-2\">\n                        <h3 class=\"title\">\n                          <div class=\"yellow-block-right\">\n                          </div><span class=\"ttl ttl-04\"><span class=\"text\">パーツセールス5年目</span></span>\n                        </h3>\n                      </div>\n                      <div class=\"row row-meet-our-team row-stretch row-cross\">\n                        <div class=\"col-12 col-md-3 item item-image\">\n                          <div class=\"cont\">\n                            <div class=\"box\">\n                              <div class=\"image\"><img src=\"./img/meet-our-team-2-1.jpg?202306141000\"\n                                  class=\"img-fluid full\"></div>\n                              <!-- <div class=\"block_10\"></div> -->\n                            </div>\n                          </div>\n                        </div>\n                        <div class=\"col-12 col-md-9 item item-text\">\n                          <div class=\"cont\">\n                            <div class=\"box\">\n                              <div class=\"block_10\">\n                                <div class=\"ttl-area\">\n                                  <h4 class=\"title\"><span class=\"ttl ttl-05\"><span>未経験の仕事をして刺激を受けたい</span></span></h4>\n                                </div>\n                                <div class=\"metabox\">\n                                  <p>大学は文系学部であり、建機とはかけ離れたことを専攻していました。<br>\n                                    <span\n                                      class=\"bg-yellow-1\">「自分が全く経験していないところで刺激を受けたい」</span>と思っていたときに建機業界を知り、キャタピラー九州を見つけました。キャタピラー建機のデザインに惹かれたことや、<span\n                                      class=\"bg-yellow-1\">福利厚生・入社からのフォローアップ体制が整っていたこともあり、</span>入社を決めました。\n                                  </p>\n                                </div>\n                              </div>\n                              <div class=\"block_5\">\n                                <div class=\"ttl-area\">\n                                  <h4 class=\"title\"><span class=\"ttl ttl-05\"><span>何でも相談できる人間関係</span></span></h4>\n                                </div>\n                                <div class=\"metabox\">\n                                  <p>私は今まで、3つの拠点に配属されたことがありますが、どの拠点においても<span\n                                      class=\"bg-yellow-1\">人間関係に恵まれていると感じます。</span>先輩上司・後輩も含めすごくいい人が多くて、<span\n                                      class=\"bg-yellow-1\">仕事でもプライベートでも、何かあったときに相談できます。</span><br>\n                                    そうした安心感があるので、これを言ったら怒られるんじゃないかということもしっかり共有することができます。</p>\n                                </div>\n                              </div>\n                            </div>\n                          </div>\n                        </div>\n                      </div>\n                      <div class=\"row row-meet-our-team row-stretch row-cross\">\n                        <div class=\"col-12 col-md-3 item item-image\">\n                          <div class=\"cont\">\n                            <div class=\"box\">\n                              <div class=\"image\"><img src=\"./img/meet-our-team-2-2.jpg\" class=\"img-fluid full\"></div>\n                              <!-- <div class=\"block_10\"></div> -->\n                            </div>\n                          </div>\n                        </div>\n                        <div class=\"col-12 col-md-9 item item-text\">\n                          <div class=\"cont\">\n                            <div class=\"box\">\n                              <div class=\"block_10\">\n                                <div class=\"ttl-area\">\n                                  <br>\n                                  <h4 class=\"title\"><span class=\"ttl ttl-05\"><span>試行錯誤して、お客様に感謝していただく喜び</span></span>\n                                  </h4>\n                                </div>\n                                <div class=\"metabox\">\n                                  <p><span class=\"bg-yellow-1\">今まで、ミスをして苦労をすることもありました。</span><br>\n                                    その中でも、修理を完了したり修理を提案してそれが上手く成功してお客様に納得していただいたとき、<span\n                                      class=\"bg-yellow-1\">感謝・お礼を頂いたときやっててよかったと思います。</span>\n                                    <br>また、自分で考えた提案をお客様に納得していただいて修理を行うというプロセスにおいて同じ内容はなく、<span\n                                      class=\"bg-yellow-1\">常に新しいことにチャレンジしながら成長していくことが楽しく感じます。</span>\n                                  </p>\n                                </div>\n                              </div>\n                            </div>\n                          </div>\n                        </div>\n                      </div>\n                    </div>\n                  </div>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </section>\n      <section class=\"bg-common work-joy\">\n        <div class=\"block_3\">\n          <div class=\"cont\">\n            <div class=\"cont-main\">\n              <div class=\"block_5 cont-item\">\n                <div class=\"container-fluid inner\">\n                  <div class=\"ttl-area\">\n                    <h2 class=\"title black\"><span class=\"ttl ttl-01\"><span class=\"ttl-eng\">WORK JOY</span>\n                        <div class=\"yellow-bottom\">\n                          <img src=\"./img/yellow-bottom.png\" class=\"img-fluid full\">\n                        </div>\n                        <span class=\"ttl-jpn\">キャタピラー九州で働く魅力</span>\n                      </span>\n                    </h2>\n                  </div>\n                </div>\n              </div>\n            </div>\n            <div class=\"block_5\"></div>\n            <div class=\"container-fluid inner\">\n              <div class=\"cont betsu\">\n                <div class=\"cont-box bg-cont\">\n                  <div class=\"box\">\n                    <div class=\"ttl-area toku\">\n                      <h2 class=\"title\"><span class=\"ttl ttl-09\"><span>お客様からの「ありがとう」</span></span></h2>\n                      <div class=\"metabox\">\n                        <p>私たちのお客様は、建設機械が必要不可欠な企業様ばかりです。そんな企業様の命綱としての役割を私たちは担っています。その分、責任も重大ですが、お客様からの感謝を肌に感じることができます。\n                        </p>\n                      </div>\n                    </div>\n                  </div>\n                  <div class=\"cont\">\n                    <div class=\"box\">\n                      <!-- <div class=\"block_3 sp\"></div> -->\n                      <div class=\"image end\"><img src=\"./img/joy-1.jpg\" class=\"img-fluid\"></div>\n                    </div>\n                  </div>\n                </div>\n              </div>\n            </div>\n            <div class=\"block_3\"></div>\n            <!-- 第二个 -->\n            <div class=\"container-fluid inner\">\n              <div class=\"cont betsu-2\">\n                <div class=\"cont-box bg-cont\">\n                  <div class=\"box\">\n                    <div class=\"ttl-area toku-2\">\n                      <h2 class=\"title\"><span class=\"ttl ttl-09\"><span>「自分にしかできない」問題を解決</span></span></h2>\n                      <div class=\"metabox\">\n                        <p>\n                          「なせ壊れているのか。どうしたら直るのか。」単一的な作業ではなく、問題を解いていくように試行錯誤します。自身の成長を感じながら、自分の手で、大型精密機械を復活させる。爽快感を感じられる仕事です。\n                        </p>\n                      </div>\n                    </div>\n                  </div>\n                  <div class=\"cont\">\n                    <div class=\"box\">\n                      <div class=\"block_3 sp\"></div>\n                      <div class=\"image\"><img src=\"./img/joy-2.jpg\" class=\"img-fluid\"></div>\n                    </div>\n                  </div>\n                </div>\n              </div>\n            </div>\n            <div class=\"block_3\"></div>\n            <!-- 第三个 -->\n            <div class=\"container-fluid inner\">\n              <div class=\"cont betsu\">\n                <div class=\"cont-box bg-cont\">\n                  <div class=\"box\">\n                    <div class=\"ttl-area toku\">\n                      <h2 class=\"title\"><span class=\"ttl ttl-09\"><span>「自分」を選んでいただく喜び</span></span></h2>\n                      <div class=\"metabox\">\n                        <p>\n                          建設機械は一台数億円するものもある高額な精密機械。ファイナンスなど企業経営入り込み。お客様をサポートします。「〇〇さんだから安心して頼れる」と言っていただけたとき、大きな喜びを感じることができます。\n                        </p>\n                      </div>\n                    </div>\n                  </div>\n                  <div class=\"cont\">\n                    <div class=\"box\">\n                      <div class=\"block_3 sp\"></div>\n                      <div class=\"image end\"><img src=\"./img/joy-3.jpg\" class=\"img-fluid\"></div>\n                    </div>\n                  </div>\n                </div>\n              </div>\n            </div>\n            <div class=\"block_3\"></div>\n            <!-- 第四个 -->\n            <div class=\"container-fluid inner\">\n              <div class=\"cont betsu-2\">\n                <div class=\"cont-box bg-cont\">\n                  <div class=\"box\">\n                    <div class=\"ttl-area toku-2\">\n                      <h2 class=\"title\"><span class=\"ttl ttl-09\"><span>風通しの良い風土</span></span></h2>\n                      <div class=\"metabox\">\n                        <p>\n                          幅広い年代の社員が所属していますが、同僚や先輩後輩の仲が良く、風通しの良さが当社の特長の一つです。仕事をする上でも、チームで連携することが重要なので、何でも話せる関係性をとても大切にしています。\n                        </p>\n                      </div>\n                    </div>\n                  </div>\n                  <div class=\"cont\">\n                    <div class=\"box\">\n                      <div class=\"block_3 sp\"></div>\n                      <div class=\"image\"><img src=\"./img/joy-4.jpg\" class=\"img-fluid\"></div>\n                    </div>\n                  </div>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n        </div>\n        </div>\n        </div>\n        <section class=\"bg-common training-program bg-blue\">\n          <div class=\"block_2\">\n            <div class=\"cont\">\n              <div class=\"cont-main\">\n                <div class=\"block_5 cont-item\">\n                  <div class=\"container-fluid inner\">\n                    <div class=\"ttl-area\">\n                      <h2 class=\"title black\"><span class=\"ttl ttl-01\"><span class=\"ttl-eng\">TRAINING PROGRAM</span>\n                          <div class=\"yellow-bottom\">\n                            <img src=\"./img/yellow-bottom.png\" class=\"img-fluid full\">\n                          </div>\n                          <span class=\"ttl-jpn\">キャタピラー九州の教育体制</span>\n                        </span>\n                      </h2>\n                    </div>\n                    <div class=\"catch-area\">\n                      <h3 class=\"title center\"><span class=\"ttl ttl-02\"><span>未経験から5年で<br\n                              class=\"sp\">プロフェッショナルへ</span></span></h3>\n                      <div class=\"metabox main\">\n                        <p>\n                          キャタピラー九州では、経験ゼロからでも建設機械のプロとして活躍できるようになるための教育体制を整えております。建設機械業界は、人手不足や需要の拡大から今後も必要とされ続ける業界であり、営業や機械整備で身につけたスキルは一生通用する武器になります。\n                        </p>\n                      </div>\n                    </div>\n                    <div class=\"block_7\"></div>\n                    <!-- <div class=\"metabox sp\">\n\n                      <p>横にスクロールしてご覧ください。</p>\n\n                    </div> -->\n                    <div class=\"image-area scroll\">\n                      <div class=\"image pl-pr d-none d-md-block\"><img src=\"./img/training-program.png\"\n                          class=\"img-fluid full\"></div>\n                      <div class=\"image pl-pr d-block d-md-none\"><img src=\"./img/training-program-sp.png\"\n                          class=\"img-fluid full\"></div>\n                    </div>\n                  </div>\n                </div>\n              </div>\n            </div>\n          </div>\n        </section>\n        <section class=\"bg-common career-development\">\n          <div class=\"bg-carrer\">\n            <img src=\"./img/bg-carrer.png?20260116\" class=\"img-fluid full\">\n          </div>\n          <div class=\"block_3 m-t\">\n            <div class=\"cont\">\n              <div class=\"cont-main\">\n                <div class=\"block_5 cont-item\">\n                  <div class=\"container-fluid inner\">\n                    <div class=\"ttl-area\">\n                      <h2 class=\"title black\"><span class=\"ttl ttl-01\"><span class=\"ttl-eng\">CAREER DEVELOPMENT</span>\n                          <div class=\"yellow-bottom\">\n                            <img src=\"./img/yellow-bottom.png?20260116\" class=\"img-fluid full\">\n                          </div>\n                          <span class=\"ttl-jpn\">キャタピラー九州でのキャリア</span>\n                        </span>\n                      </h2>\n                    </div>\n                    <div class=\"catch-area\">\n                      <div class=\"metabox main center\">\n                        <p>研修生として入社した後、メカニックで建設機械の技術力向上や資格取得などをしていきます。その後、本人の希望や適性を鑑みて、個人に合ったキャリアを形成していくことができます。</p>\n                      </div>\n                    </div>\n                    <div class=\"block_3 pc\"></div>\n                    <div class=\"block_10 sp\"></div>\n                  </div>\n                  <div class=\"image-area\">\n                    <div class=\"container-fluid inner\">\n                      <div class=\"image\"><img src=\"./img/career-development.png?2026011902\" class=\"img-fluid full\">\n                      </div>\n                    </div>\n                  </div>\n                </div>\n              </div>\n            </div>\n          </div>\n        </section>\n        <section class=\"bg-common information bg-blue\">\n          <div class=\"block_3\">\n            <div class=\"cont\">\n              <div class=\"cont-main\">\n                <div class=\"block_5 cont-item\">\n                  <div class=\"container-fluid inner\">\n                    <div class=\"ttl-area\">\n                      <h2 class=\"title black\"><span class=\"ttl ttl-01\"><span class=\"ttl-eng\">RECRUIT</span>\n                          <div class=\"yellow-bottom\">\n                            <img src=\"./img/yellow-bottom.png\" class=\"img-fluid full\">\n                          </div>\n                          <span class=\"ttl-jpn\">採用情報</span>\n                        </span>\n                      </h2>\n                    </div>\n                  </div>\n                  <div class=\"image-area image-list\">\n                    <div class=\"block_3\">\n                      <div class=\"container-fluid inner\">\n                        <div class=\"ttl-area\">\n                          <h3 class=\"title\"><span class=\"ttl ttl-06\"><span class=\"pore-z-5\">募集職種</span>\n                              <div class=\"yellow-block-2\"></div>\n                            </span></h3>\n                        </div>\n                        <div class=\"image-information light-box\">\n                          <a href=\"./img/recruit-big-2.png\" data-lightbox=\"img02\" class=\"image-information-item pc\">\n                            <div class=\"img-a imageHeight\">\n                              <img src=\"./img/recruit-2.png\" class=\"img-fluid full\">\n                            </div>\n                            <div class=\"metabox invert center matchHeight\">\n                              <p>マシンセールス<br>（営業）</p>\n                            </div>\n                          </a>\n                          <a href=\"./img/recruit-big-2-sp.png\" data-lightbox=\"img02\" class=\"image-information-item sp\">\n                            <div class=\"img-a imageHeight\">\n                              <img src=\"./img/recruit-2.png\" class=\"img-fluid full\">\n                            </div>\n                            <div class=\"metabox invert center matchHeight\">\n                              <p>マシンセールス<br>（営業）</p>\n                            </div>\n                          </a>\n                          <a href=\"./img/recruit-big-1.png?2026011902\" data-lightbox=\"img01\"\n                            class=\"image-information-item pc\">\n                            <div class=\"img-a imageHeight\">\n                              <img src=\"./img/recruit-1.jpg?2026011902\" class=\"img-fluid full\">\n                            </div>\n                            <div class=\"metabox invert center\">\n                              <p>パーツセールス<br>（技術営業）</p>\n                            </div>\n                          </a>\n                          <a href=\"./img/recruit-big-1-sp.png?2026011902\" data-lightbox=\"img01\"\n                            class=\"image-information-item sp\">\n                            <div class=\"img-a imageHeight\">\n                              <img src=\"./img/recruit-1.jpg?2026011902\" class=\"img-fluid full\">\n                            </div>\n                            <div class=\"metabox invert center\">\n                              <p>パーツセールス<br>（技術営業）</p>\n                            </div>\n                          </a>\n                          <a href=\"./img/recruit-big-3.png?202306051636\" data-lightbox=\"img03\"\n                            class=\"image-information-item pc\">\n                            <div class=\"img-a imageHeight\">\n                              <img src=\"./img/recruit-3.png?202306051636\" class=\"img-fluid full t-2\">\n                            </div>\n                            <div class=\"metabox invert center matchHeight\">\n                              <p>メカニック<br>（整備士）</p>\n                            </div>\n                          </a>\n                          <a href=\"./img/recruit-big-3-sp.png?202306051636\" data-lightbox=\"img03\"\n                            class=\"image-information-item sp\">\n                            <div class=\"img-a imageHeight\">\n                              <img src=\"./img/recruit-3.png?202306051636\" class=\"img-fluid full t-2\">\n                            </div>\n                            <div class=\"metabox invert center matchHeight\">\n                              <p>メカニック<br>（整備士）</p>\n                            </div>\n                          </a>\n                          <!-- <a href=\"./img/recruit-big-4.jpg\" data-lightbox=\"img04\" class=\"image-information-item pc\">\n                            <div class=\"img-a imageHeight\">\n                              <img src=\"./img/recruit-4.jpg\" class=\"img-fluid full\">\n                            </div>\n                            <div class=\"metabox invert center matchHeight\">\n                              <p>インストラクター<br>（教習講師）</p>\n                            </div>\n                          </a>\n                          <a href=\"./img/recruit-big-4-sp.jpg\" data-lightbox=\"img04\" class=\"image-information-item sp\">\n                            <div class=\"img-a imageHeight\">\n                              <img src=\"./img/recruit-4.jpg\" class=\"img-fluid full\">\n                            </div>\n                            <div class=\"metabox invert center\">\n                              <p>インストラクター<br>（教習講師）</p>\n                            </div>\n                          </a>\n                          <a href=\"./img/recruit-big-5.jpg\" data-lightbox=\"img05\" class=\"image-information-item pc\">\n                            <div class=\"img-a imageHeight\">\n                              <img src=\"./img/recruit-5.jpg\" class=\"img-fluid full\">\n                            </div>\n                            <div class=\"metabox invert center\">\n                              <p>システムエンジニア<br>（社内SE）</p>\n                            </div>\n                          </a>\n                          <a href=\"./img/recruit-big-5-sp.jpg\" data-lightbox=\"img05\" class=\"image-information-item sp\">\n                            <div class=\"img-a imageHeight\">\n                              <img src=\"./img/recruit-5.jpg\" class=\"img-fluid full\">\n                            </div>\n                            <div class=\"metabox invert center\">\n                              <p>システムエンジニア<br>（社内SE）</p>\n                            </div>\n                          </a> -->\n                        </div>\n                      </div>\n                    </div>\n                  </div>\n                </div>\n                <div class=\"block_5 cont-item\">\n                  <div class=\"container-fluid inner\">\n                    <div class=\"ttl-area\">\n                      <h3 class=\"title\"><span class=\"ttl ttl-06\"><span class=\"pore-z-5\">勤務地</span>\n                          <div class=\"yellow-block-2\"></div>\n                        </span></h3>\n                    </div>\n                    <div class=\"metabox\">\n                      <p class=\"main-text\">九州全域※（福岡・佐賀・長崎・熊本・大分・宮崎・鹿児島）</p>\n                      <p class=\"small-text\">※本人の居住地等を鑑みて決定いたします。</p>\n                    </div>\n                    <h4 class=\"center\">頑張りが報酬につながる<br class=\"sp\">人事制度</h4>\n                    <div class=\"metabox fw\">\n                      <p>\n                        当社では年3回の賞与・一時金制度があります。成果が報酬に反映されるので、自分の頑張りによって、収入を上げることが可能です。また、土日祝日が休みであり、年間休日も126日と働きやすい環境を整えています。\n                      </p>\n                    </div>\n                  </div>\n                </div>\n                <div class=\"block_5 cont-item\">\n                  <div class=\"container-fluid inner\">\n                    <div class=\"ttl-area\">\n                      <h3 class=\"title\"><span class=\"ttl ttl-06\"><span class=\"pore-z-5\">給与・待遇</span>\n                          <div class=\"yellow-block-2\"></div>\n                        </span></h3>\n                    </div>\n                    <!-- <div class=\"metabox sp\">\n\n                      <p>横にスクロールしてご覧ください。</p>\n\n                    </div> -->\n                  </div>\n                  <div class=\"image-area scroll\">\n                    <div class=\"block_5\">\n                      <div class=\"container-fluid inner\">\n                        <div class=\"image d-none d-md-block\"><img src=\"./img/recruit-info-1.png?20260116\"\n                            class=\"img-fluid full\">\n                        </div>\n                        <div class=\"image d-block d-md-none\"><img src=\"./img/recruit-info-1-sp.png?20260116\"\n                            class=\"img-fluid full\"></div>\n                        <div class=\"block_3 pc\"></div>\n                        <div class=\"metabox\">\n                          <p class=\"p-2\">\n                            また、自宅からの通勤が困難な場合でも、住宅補助制度によって家賃・水道光熱費・駐車場代が支給されるため、実質無料で生活することができます。他にも、福利厚生を数多く設けています。 </p>\n                        </div>\n                      </div>\n                    </div>\n                  </div>\n                </div>\n                <div class=\"block_5 cont-item\">\n                  <div class=\"container-fluid inner\">\n                    <div class=\"ttl-area\">\n                      <h3 class=\"title\"><span class=\"ttl ttl-06\"><span class=\"pore-z-5\">福利厚生</span>\n                          <div class=\"yellow-block-2\"></div>\n                        </span></h3>\n                    </div>\n                    <!-- <div class=\"metabox sp\">\n\n                      <p>横にスクロールしてご覧ください。</p>\n\n                    </div> -->\n                  </div>\n                  <div class=\"image-area scroll\">\n                    <div class=\"container-fluid inner\">\n                      <div class=\"image d-none d-md-block\"><img src=\"./img/recruit-info-2.png\" class=\"img-fluid full\">\n                      </div>\n                      <div class=\"image d-block d-md-none\"><img src=\"./img/recruit-info-2-sp.png\"\n                          class=\"img-fluid full\"></div>\n                    </div>\n                  </div>\n                </div>\n              </div>\n            </div>\n          </div>\n        </section>\n        <section class=\"bg-common entry\">\n          <div class=\"block_3\">\n            <div class=\"cont\">\n              <div class=\"cont-main\">\n                <div class=\"block_5 cont-item\">\n                  <div class=\"container-fluid inner\">\n                    <div class=\"ttl-area\">\n                      <h2 class=\"title black\"><span class=\"ttl ttl-01\"><span class=\"ttl-eng\">ENTRY</span>\n                          <div class=\"yellow-bottom\">\n                            <img src=\"./img/yellow-bottom.png\" class=\"img-fluid full\">\n                          </div>\n                          <span class=\"ttl-jpn\">エントリー</span>\n                        </span>\n                      </h2>\n                      <div class=\"metabox center\">\n                        <p>皆様からのエントリーをお待ちしております。</p>\n                      </div>\n                    </div>\n                  </div>\n                  <div class=\"image-area\">\n                    <div class=\"block_3\">\n                      <div class=\"container-fluid inner\">\n                        <div class=\"row row-entry row-stretch\">\n                          <div class=\"col-12 col-md-6 item\">\n                            <div class=\"cont\">\n                              <div class=\"box\">\n                                <a href=\"https://job.mynavi.jp/27/pc/search/corp75525/outline.html\" class=\"block-area\"\n                                  target=\"_blank\" rel=\"noopener\">\n                                  <div class=\"image\"><img src=\"./img/recruit-link-1.png?20260121\"\n                                      class=\"img-fluid full\"></div>\n                                </a>\n                              </div>\n                            </div>\n                          </div>\n                          <div class=\"col-12 col-md-6 item\">\n                            <div class=\"cont\">\n                              <div class=\"box\">\n                                <a href=\"https://job.axol.jp/jn/c/catkyushu/public/job/search\" class=\"block-area\"\n                                  target=\"_blank\" rel=\"noopener\">\n                                  <div class=\"image\"><img src=\"./img/recruit-link-2.jpg?20260116\"\n                                      class=\"img-fluid full\"></div>\n                                </a>\n                              </div>\n                            </div>\n                          </div>\n                        </div>\n                        <div class=\"bu