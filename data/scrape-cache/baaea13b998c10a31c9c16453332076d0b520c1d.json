{"url":"https://asahi-ad.co.jp/recruiting/welfare/","html":"<!DOCTYPE html>\r\n<html lang=\"ja\">\r\n\r\n<head>\r\n<!-- Google Tag Manager -->\r\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\r\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\r\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\r\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\r\n})(window,document,'script','dataLayer','GTM-53RNMQF');</script>\r\n<!-- End Google Tag Manager -->\r\n    \r\n    <meta charset=\"UTF-8\">\r\n    <title>福利厚生 | 株式会社旭広告社 採用情報</title>\r\n    <meta name=\"description\" content=\"株式会社旭広告社の採用情報サイト、福利厚生ページです。働く社員の豊かな生活を支援するため、さまざまな福利厚生制度を用意しており、安心して働くことができます。\" />\r\n    <meta name=\"keywords\" content=\"2026,採用,新卒,中途,エントリー,広告,代理店,横浜,地域貢献\" />\r\n    <meta property=\"og:title\" content=\"株式会社旭広告社 採用情報\" />\r\n    <meta property=\"og:type\" content=\"website\" />\r\n    <meta property=\"og:url\" content=\"https://www.asahi-ad.co.jp/recruiting/\" />\r\n    <meta property=\"og:image\" content=\"https://www.asahi-ad.co.jp/recruiting/images/asahi_og.png\" />\r\n    <meta property=\"og:site_name\" content=\"株式会社旭広告社 採用情報\" />\r\n    <meta property=\"og:description\" content=\"横浜の総合広告代理店、株式会社旭広告社の採用情報サイトです。仕事内容・社員インタビュー・福利厚生など、採用に関する情報をご紹介します。\" />\r\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\">\r\n    <link href=\"https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500&family=Roboto&display=swap\" rel=\"stylesheet\">\r\n    <link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/yakuhanjp@3.4.1/dist/css/yakuhanjp-noto.min.css\">\r\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"../js/drawer/drawer.css\">\r\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"../css/base.css\">\r\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"../css/welfare.css\">\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no\" />\r\n\t\r\n<link rel=\"shortcut icon\" href=\"../favicon.ico\">\r\n<link rel=\"apple-touch-icon\" href=\"../apple-touch-icon.png\">\r\n<link rel=\"icon\" type=\"image/png\" href=\"../android-chrome-192x192.png\">\r\n</head>\r\n\r\n<body class=\"drawer drawer--right\">\r\n<!-- Google Tag Manager (noscript) -->\r\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-53RNMQF\"\r\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\r\n<!-- End Google Tag Manager (noscript) -->    \r\n    <div class=\"drawer_container\">\r\n        <button type=\"button\" class=\"drawer-toggle drawer-hamburger\">\r\n            <span class=\"sr-only\">toggle navigation</span>\r\n            <span class=\"drawer-hamburger-icon\"></span>\r\n        </button>\r\n        <nav class=\"drawer-nav\" role=\"navigation\">\r\n            <ul class=\"drawer-menu\">\r\n                <li class=\"drawer_logo\"><a href=\"../\"><img src=\"../images/footer_logo.png\" alt=\"株式会社旭広告社\"></a></li>\r\n                <li><a href=\"../\" class=\"drawer-menu-item\">HOME</a></li>\r\n                <li><a href=\"../message/\" class=\"drawer-menu-item\">社長メッセージ</a></li>\r\n                <li><a href=\"../interview/\" class=\"drawer-menu-item\">社員インタビュー</a></li>\r\n                <li><a href=\"../job/\" class=\"drawer-menu-item\">旭広告社の仕事を知る</a></li>\r\n                <li><a href=\"../data/\" class=\"drawer-menu-item\">DATAで見る旭広告社</a></li>\r\n                <li><a href=\"../welfare/\" class=\"drawer-menu-item\">福利厚生</a></li>\r\n                <li><a href=\"../environment/\" class=\"drawer-menu-item\">職場環境</a></li>\r\n                <li><a href=\"../recruit/\" class=\"drawer-menu-item\">採用情報</a></li>\r\n                <li class=\"st\">エントリー</li>\r\n                <li><a href=\"https://job.rikunabi.com/n/selection/job_descriptions/0fd0d43359bd8a60/?from=job_search\" class=\"drawer-menu-item\" target=\"new\" rel=\"nofollow\">新卒採用</a></li>\r\n                <li><a href=\"../recruit/#tab2\" class=\"drawer-menu-item\">中途採用</a></li>\r\n                <li class=\"st\">企業情報</li>\r\n                <li><a href=\"https://asahi-ad.co.jp/\" class=\"drawer-menu-item drawer-menu-item2\" target=\"_blank\">コーポレートサイト</a></li>\r\n                <li><a href=\"https://asahi-ad.co.jp/about/privacy-policy/\" class=\"drawer-menu-item drawer-menu-item2\" target=\"_blank\">プライバシーポリシー</a></li>\r\n            </ul>\r\n        </nav>\r\n    </div>\r\n\r\n    <header id=\"header\" class=\"cf\">\r\n        <p class=\"header_logo\"><a href=\"../\"><img src=\"../images/logo.png\" alt=\"株式会社旭広告社\"></a><span>RECRUIT</span></p>\r\n        <nav id=\"gnavi\">\r\n            <ul class=\"menu cf\">\r\n                <li><a href=\"../message/\">社長メッセージ</a></li>\r\n                <li><a href=\"../interview/\">社員インタビュー</a></li>\r\n                <li><a href=\"../job/\">旭広告社の仕事を知る</a></li>\r\n                <li><a href=\"../data/\">DATAで見る旭広告社</a></li>\r\n                <li><a href=\"../welfare/\" class=\"on\">福利厚生</a></li>\r\n                <li><a href=\"../environment/\">職場環境</a></li>\r\n                <li><a href=\"../recruit/\">採用情報</a></li>\r\n            </ul>\r\n            <ul class=\"entry\">\r\n                <li class=\"item\"><span>&gt; ENTRY</span>\r\n                    <ul class=\"child\">\r\n                        <!--<li><a href=\"../news/\">&gt; 新卒採用</a></li>-->\r\n                        <li><a href=\"https://job.rikunabi.com/n/selection/job_descriptions/0fd0d43359bd8a60/?from=job_search\" target=\"new\" rel=\"nofollow\">&gt; 新卒採用</a></li>\r\n                        <li><a href=\"../recruit/#tab2\">&gt; 中途採用</a></li>\r\n                    </ul>\r\n                </li>\r\n            </ul>\r\n        </nav>\r\n    </header>\r\n\r\n    <div id=\"page_title\">\r\n        <div class=\"inner1\">\r\n            <p>Welfare</p>\r\n            <h1>福利厚生</h1>\r\n        </div>\r\n    </div>\r\n\r\n    <div id=\"breadcrumb\">\r\n        <div class=\"inner1\">\r\n            <ul class=\"cf\">\r\n                <li><a href=\"../\">ホーム</a></li>\r\n                <li>福利厚生</li>\r\n            </ul>\r\n        </div>\r\n    </div>\r\n\r\n    <section id=\"welfare1\">\r\n        <div class=\"inner1\">\r\n            <div class=\"welfare_intro\">\r\n                <h2>旭広告社の福利厚生制度</h2>\r\n                <p>働く社員の豊かな生活を支援するため、さまざまな福利厚生制度を用意しており、<br class=\"br_768_none\">安心して働くことができます。</p>\r\n            </div>\r\n            <h3>法定福利</h3>\r\n            <ul class=\"ul1 cf\">\r\n                <li>厚生年金保険</li>\r\n                <li>健康保険</li>\r\n                <li>介護保険</li>\r\n                <li>雇用保険</li>\r\n                <li>労災保険</li>\r\n                <li>児童手当拠出金</li>\r\n            </ul>\r\n\r\n            <h3>法定外福利</h3>\r\n            <ul class=\"ul2 cf\">\r\n                <li><a href=\"#a01\">通勤<img src=\"../images/ar3.png\" alt=\"\"></a></li>\r\n                <li><a href=\"#a02\">財産形成<img src=\"../images/ar3.png\" alt=\"\"></a></li>\r\n                <li><a href=\"#a03\">慶弔・災害・お祝<img src=\"../images/ar3.png\" alt=\"\"></a></li>\r\n                <li><a href=\"#a04\">育児・介護<img src=\"../images/ar3.png\" alt=\"\"></a></li>\r\n                <li><a href=\"#a05\">健診・医療<img src=\"../images/ar3.png\" alt=\"\"></a></li>\r\n                <li><a href=\"#a06\">レクリエーション<img src=\"../images/ar3.png\" alt=\"\"></a></li>\r\n                <li><a href=\"#a07\">休暇<img src=\"../images/ar3.png\" alt=\"\"></a></li>\r\n                <li><a href=\"#a08\">アサヒ会<img src=\"../images/ar3.png\" alt=\"\"></a></li>\r\n            </ul>\r\n        </div>\r\n    </section>\r\n\r\n    <section id=\"welfare2\">\r\n        <div class=\"inner1\">\r\n            <ul class=\"welfare2_ul1 cf\">\r\n                <li>\r\n                    <p id=\"a01\" class=\"st1\">通勤</p>\r\n                    <div>\r\n                        <figure><img src=\"images/welfare01.jpg\" alt=\"通勤手当\"></figure>\r\n                        <dl>\r\n                            <dt>通勤手当</dt>\r\n                            <dd>全額支給されます。</dd>\r\n                        </dl>\r\n                    </div>\r\n                </li>\r\n                <li>\r\n                    <p id=\"a02\" class=\"st1\">財産形成</p>\r\n                    <div>\r\n                        <figure><img src=\"images/welfare02.jpg\" alt=\"年金制度\"></figure>\r\n                        <dl>\r\n                            <dt>年金制度</dt>\r\n                            <dd>確定給付企業年金、確定拠出年金制度があります。</dd>\r\n                        </dl>\r\n                    </div>\r\n                </li>\r\n            </ul>\r\n\r\n            <p id=\"a03\" class=\"st1\">慶弔・災害・お祝</p>\r\n            <ul class=\"welfare2_ul1 cf\">\r\n                <li>\r\n                    <div class=\"p_2line\">\r\n                        <figure><img src=\"images/welfare03.jpg\" alt=\"結婚祝金\"></figure>\r\n                        <dl>\r\n                            <dt>結婚祝金</dt>\r\n                            <dd>勤続年数によりお祝金があります。</dd>\r\n                        </dl>\r\n                    </div>\r\n                </li>\r\n                <li>\r\n                    <div class=\"p_2line\">\r\n                        <figure><img src=\"images/welfare04.jpg\" alt=\"出産祝金\"></figure>\r\n                        <dl>\r\n                            <dt>出産祝金</dt>\r\n                            <dd>社員または配偶者が出産の時は年数によりお祝金があります。</dd>\r\n                        </dl>\r\n                    </div>\r\n                </li>\r\n                <li>\r\n                    <div>\r\n                        <figure><img src=\"images/welfare05.jpg\" alt=\"お誕生日祝\"></figure>\r\n                        <dl>\r\n                            <dt>お誕生日祝</dt>\r\n                            <dd>お誕生祝として、１万円分の食事に使えるグルメ券とベネフィットポイント2000ポイント進呈！</dd>\r\n                        </dl>\r\n                    </div>\r\n                </li>\r\n                <li>\r\n                    <div>\r\n                        <figure><img src=\"images/welfare06.jpg\" alt=\"新築祝金\"></figure>\r\n                        <dl>\r\n                            <dt>新築祝金</dt>\r\n                            <dd>社員が家を新築した際やマンションを購入した際にお祝金があります。</dd>\r\n                        </dl>\r\n                    </div>\r\n                </li>\r\n                <li>\r\n                    <div>\r\n                        <dl>\r\n                            <dt>災害見舞金</dt>\r\n                            <dd>災害の程度によりお見舞金があります。</dd>\r\n                        </dl>\r\n                    </div>\r\n                </li>\r\n                <li>\r\n                    <div>\r\n                        <dl>\r\n                            <dt>傷病見舞金</dt>\r\n                            <dd>条件を満たす入院の際にお見舞金があります。</dd>\r\n                        </dl>\r\n                    </div>\r\n                </li>\r\n                <li>\r\n                    <div class=\"t_3line\">\r\n                        <dl>\r\n                            <dt>死亡弔慰金</dt>\r\n                            <dd>親族が亡くなられた際には、条件により弔慰金があります。</dd>\r\n                        </dl>\r\n                    </div>\r\n                </li>\r\n                <li>\r\n                    <div class=\"t_3line\">\r\n                        <dl>\r\n                            <dt>サンクスポイント</dt>\r\n                            <dd>他の社員の日報にコメントを入れることができ、”ありがとう”のコメントの授受でベネフィットポイントがもらえます。</dd>\r\n                        </dl>\r\n                    </div>\r\n                </li>\r\n                <li>\r\n                    <div>\r\n                        <dl>\r\n                            <dt>永年勤続表彰祝</dt>\r\n                            <dd>勤続15年以上、5年おきに表彰と共に祝金と記念品の贈呈があります。</dd>\r\n                        </dl>\r\n                    </div>\r\n                </li>\r\n                <li>\r\n                    <div>\r\n                        <dl>\r\n                            <dt>創立記念祝金</dt>\r\n                            <dd>創立記念日に、通常5,000円、10周年ごとに10,000円の祝金があります。</dd>\r\n                        </dl>\r\n                    </div>\r\n                </li>\r\n            </ul>\r\n\r\n            <p id=\"a04\" class=\"st1\">育児・介護</p>\r\n            <ul class=\"welfare2_ul1 cf\">\r\n                <li>\r\n                    <div class=\"t_2line\">\r\n                        <dl>\r\n                            <dt>産前産後休暇</dt>\r\n                            <dd>出産予定日前6週間（多胎妊娠の場合14週間）産後8週間の休暇を取得できます。</dd>\r\n                        </dl>\r\n                    </div>\r\n                </li>\r\n                <li>\r\n                    <div class=\"t_2line\">\r\n                        <dl>\r\n                            <dt>育児・介護休業制度</dt>\r\n                            <dd>当社規定により育児・介護休業をすることができます。</dd>\r\n                        </dl>\r\n                    </div>\r\n                </li>\r\n                <li>\r\n                    <div>\r\n                        <dl>\r\n                            <dt>育児・介護休業時短勤務制度</dt>\r\n                            <dd>当社規定により育児・介護のための短時間勤務ができます。</dd>\r\n                        </dl>\r\n                    </div>\r\n                </li>\r\n            </ul>\r\n\r\n            <p id=\"a05\" class=\"st1\">健診・医療</p>\r\n            <ul class=\"welfare2_ul1 cf\">\r\n                <li>\r\n                    <div class=\"t_2line\">\r\n                        <dl>\r\n                            <dt>定期健康診断</dt>\r\n                            <dd>生活習慣病健診受診者以外の社員を対象。</dd>\r\n                        </dl>\r\n                    </div>\r\n                </li>\r\n                <li>\r\n                    <div class=\"t_2line\">\r\n                        <dl>\r\n                            <dt>生活習慣病健診</dt>\r\n                            <dd>35歳以上の社員全員が対象で、協会けんぽからの補助を超える分の費用も会社が負担。</dd>\r\n                        </dl>\r\n                    </div>\r\n                </li>\r\n            </ul>\r\n\r\n            <p id=\"a06\" class=\"st1\">レクリエーション</p>\r\n            <ul class=\"welfare2_ul1 welfare2_ul2 cf\">\r\n                <li>\r\n                    <div>\r\n                        <div class=\"cf\">\r\n                            <figure class=\"figure1\"><img src=\"images/welfare07.jpg\" alt=\"\"></figure>\r\n                            <figure class=\"figure2\"><img src=\"images/welfare08.jpg\" alt=\"\"></figure>\r\n                            <figure class=\"figure3\"><img src=\"images/welfare09.jpg\" alt=\"\"></figure>\r\n                        </div>\r\n                        <dl>\r\n                            <dt>社員旅行</dt>\r\n                            <dd>毎年全社員で国内、5年ごとに海外へ会社全額費用負担の旅行があります。</dd>\r\n                        </dl>\r\n                    </div>\r\n                </li>\r\n                <li>\r\n                    <div class=\"t_3line\">\r\n                        <dl>\r\n                            <dt>アサヒ会（社員親睦会）会社からの補助金有</dt>\r\n                            <dd>活動を円滑で有意義なものにするために、会社からの補助金を利用しています。</dd>\r\n                        </dl>\r\n                    </div>\r\n                </li>\r\n                <li>\r\n                    <div class=\"t_3line\">\r\n                        <dl>\r\n                            <dt>忘新年会会費補助金制度</dt>\r\n                            <dd>会社とアサヒ会より計7,000円の補助金があり、忘年会と新年会を別々に行う部やまとめて1回で使用する部などさまざま！</dd>\r\n                        </dl>\r\n                    </div>\r\n                </li>\r\n                <li>\r\n                    <div class=\"t_4line\">\r\n                        <dl>\r\n                            <dt>ハマふれんど加入</dt>\r\n                            <dd>横浜市の勤労者福祉共済で各種給付や健康維持増進、主催イベントなどの独自サービスの提供など、余暇をより充実するための様々なメニューのあるハマふれんどに会社が加入しています。</dd>\r\n                        </dl>\r\n                    </div>\r\n                </li>\r\n                <li>\r\n                    <div class=\"t_4line\">\r\n                        <dl>\r\n                            <dt>展示会補助金制度</dt>\r\n                            <dd>幅広く展示会や鑑賞を通じて　“一流に触れる”　ことで、知識と感性を磨き、お客様に対して多彩で価値ある提案をするために、利用していただきます。</dd>\r\n                        </dl>\r\n                    </div>\r\n                </li>\r\n            </ul>\r\n\r\n            <p id=\"a07\" class=\"st1\">休暇</p>\r\n            <ul class=\"welfare2_ul1 cf\">\r\n                <li>\r\n                    <div class=\"p_2line\">\r\n                        <figure><img src=\"images/welfare10.jpg\" alt=\"リフレッシュ休暇制度\"></figure>\r\n                        <dl>\r\n                            <dt>リフレッシュ休暇制度</dt>\r\n                            <dd>勤続15年より5年ごとに、10日のリフレッシュ休暇を取得できます。</dd>\r\n                        </dl>\r\n                    </div>\r\n                </li>\r\n                <li>\r\n                    <div class=\"p_2line\">\r\n                        <figure><img src=\"images/welfare11.jpg\" alt=\"年末年始休暇\"></figure>\r\n                        <dl>\r\n                            <dt>年末年始休暇</dt>\r\n                            <dd>12月30日～1月3日はお休みです。</dd>\r\n                        </dl>\r\n                    </div>\r\n                </li>\r\n                <li>\r\n                    <div>\r\n                        <dl>\r\n                            <dt>創立記念日休日</dt>\r\n                            <dd>9月13日が平日であれば休日となります。</dd>\r\n                        </dl>\r\n                    </div>\r\n                </li>\r\n                <li>\r\n                    <div>\r\n                        <dl>\r\n                            <dt>半日・時間有給休暇取得制度</dt>\r\n                            <dd>ライフワークに合わせた有給休暇が取得できます。</dd>\r\n                        </dl>\r\n                    </div>\r\n                </li>\r\n            </ul>\r\n\r\n            <p id=\"a08\" class=\"st1\">アサヒ会（サークル活動）</p>\r\n            <ul class=\"welfare2_ul1 cf\">\r\n                <li>\r\n                    <div class=\"p_3line\">\r\n                        <figure><img src=\"images/welfare19.jpg\" alt=\"バンド部\"></figure>\r\n                        <dl>\r\n                            <dt>バンド部</dt>\r\n                            <dd>好みやジャンルが違っても、音楽を通じて交流できる場として楽しんで活動しています。仕事の喧騒から離れて、音楽の力で心が軽くなり、新たなエネルギーを得ることはとても素敵なことです。</dd>\r\n                        </dl>\r\n                    </div>\r\n                </li>\r\n                <li>\r\n                    <div class=\"p_3line\">\r\n                        <figure><img src=\"images/welfare13.jpg\" alt=\"野球部\"></figure>\r\n                        <dl>\r\n                            <dt>野球部</dt>\r\n                            <dd>全盛期は中区の大会で3位になりました。和気あいあいと楽しく練習しています。</dd>\r\n                        </dl>\r\n                    </div>\r\n                </li>\r\n                <li>\r\n                    <div>\r\n                        <figure><img src=\"images/welfare17.jpg\" alt=\"フットサル部\"></figure>\r\n                        <dl>\r\n                            <dt>フットサル部</dt>\r\n                            <dd>参加メンバーの多い部で、普段の仕事姿からは想像できないハッスルプレーや足元のテクニックなどの披露で盛り上がります。</dd>\r\n                        </dl>\r\n                    </div>\r\n                </li>\r\n                <li>\r\n                    <div>\r\n                        <figure><img src=\"images/welfare18.jpg\" alt=\"釣り部\"></figure>\r\n                        <dl>\r\n                            <dt>釣り部</dt>\r\n                            <dd>釣りに興味のある人や趣味を広げたい人が初心者でも参加しやすい岸釣り、時には船釣りなど、楽しい雰囲気で活動しています。</dd>\r\n                        </dl>\r\n                    </div>\r\n                </li>\r\n                <li>\r\n                    <div>\r\n                        <dl>\r\n                            <dt>ゴルフ部</dt>\r\n                            <dd>年に数回のゴルフ部主催コンペとそれに伴う練習会をメインに活動しています。<br>初心者の方も楽しんで参加しています。</dd>\r\n                        </dl>\r\n                    </div>\r\n                </li>\r\n                <li>\r\n                    <div class=\"t_3line\">\r\n                        <dl>\r\n                            <dt>囲碁部</dt>\r\n                            <dd>囲碁は脳トレに最高！ということで初心者の方も若い方も気軽に参加しています。</dd>\r\n                        </dl>\r\n                    </div>\r\n                </li>\r\n                <li>\r\n                    <div class=\"t_3line\">\r\n                        <dl>\r\n                            <dt>沼津支部</dt>\r\n                            <dd>営業所が本社と離れており本社の活動に参加しにくいため、沼津営業所のみで活動できるよう別途設けているもので、旅行や食べ歩きなどを行っています。</dd>\r\n                        </dl>\r\n                    </div>\r\n                </li>\r\n                <li>\r\n                    <div class=\"t_3line\">\r\n                        <dl>\r\n                            <dt>e-スポーツ部</dt>\r\n                            <dd>e-スポーツは、実際にスポーツするよりも気楽にできる上、しっかり体の運動にもなるので仕事終わりに楽しみながらリフレッシュしています。</dd>\r\n                        </dl>\r\n                    </div>\r\n                </li>\r\n                <li>\r\n                    <div class=\"t_3line\">\r\n                        <dl>\r\n                            <dt>ボーリング部</dt>\r\n                            <dd>老若男女が出来るスポーツとして、健康維持に役立っています。全社から参加を募って開催することもあります。</dd>\r\n                        </dl>\r\n                    </div>\r\n                </li>\r\n                <li>\r\n                    <div class=\"t_3line\">\r\n                        <dl>\r\n                            <dt>テニス部</dt>\r\n                            <dd>長い歴史の中で、伝統のある部で、常に一定数の愛好者がいます。気軽に楽しめるスポーツとしてこれからも活動していきます。</dd>\r\n                        </dl>\r\n                    </div>\r\n                </li>\r\n                <li>\r\n                    <div class=\"t_3line\">\r\n                        <dl>\r\n                            <dt>アスリート部</dt>\r\n                            <dd>遠泳大会やマラソン大会への参加をしています。ストイックに取り組む人、ひたすら完走（泳）を目指す人など、自分のペースで気軽に参加できます。</dd>\r\n                        </dl>\r\n                    </div>\r\n                </li>\r\n            </ul>\r\n\r\n        </div>\r\n    </section>\r\n\r\n    <section id=\"foot_recruit\">\r\n        <div class=\"inner1 cf\">\r\n            <h2>採用情報</h2>\r\n            <ul class=\"cf\">\r\n                <li><a href=\"../recruit/#tab1\">\r\n                        <figure><img src=\"../images/foot_recruit2.png\" alt=\"新卒採用情報\"></figure>\r\n                        <p>新卒採用情報</p>\r\n                    </a></li>\r\n                <li><a href=\"../recruit/#tab2\">\r\n                        <figure><img src=\"../images/foot_recruit3.png\" alt=\"中途採用情報\"></figure>\r\n                        <p>中途採用情報</p>\r\n                    </a></li>\r\n            </ul>\r\n        </div>\r\n    </section>\r\n\r\n    <footer id=\"footer\">\r\n        <div class=\"inner1 cf\">\r\n            <div class=\"footer_txt\">\r\n                <p><a href=\"../\"><img src=\"../images/footer_logo.png\" alt=\"株式会社旭広告社\"></a></p>\r\n                <p class=\"p1\">〒231-0014　神奈川県横浜市中区常盤町2-19<br>TEL: 045-681-2831</p>\r\n            </div>\r\n            <ul class=\"ul1\">\r\n                <li><a href=\"../message/\">社長メッセージ</a></li>\r\n                <li><a href=\"../interview/\">社員インタビュー</a></li>\r\n                <li><a href=\"../job/\">旭広告社の仕事を知る</a></li>\r\n                <li><a href=\"../data/\">DATAで見る</a></li>\r\n            </ul>\r\n\r\n            <ul class=\"ul1\">\r\n                <li><a href=\"../welfare/\">福利厚生</a></li>\r\n                <li><a href=\"../environment/\">職場環境</a></li>\r\n                <li><a href=\"../recruit/#tab1\">新卒採用情報</a></li>\r\n                <li><a href=\"../recruit/#tab1\">中途採用情報</a></li>\r\n            </ul>\r\n\r\n            <ul class=\"ul2\">\r\n                <li><a href=\"https://asahi-ad.co.jp/\" target=\"_blank\"><img src=\"../images/icon1.png\" alt=\"\">コーポレートサイト</a></li>\r\n                <li><a href=\"https://asahi-ad.co.jp/about/privacy-policy/\" target=\"_blank\"><img src=\"../images/icon1.png\" alt=\"\">プライバシーポリシー</a></li>\r\n            </ul>\r\n        </div>\r\n        <div id=\"copyright\">\r\n            <div class=\"inner1\">\r\n                <p>&copy; ASAHI ADVERTISING, INC.</p>\r\n            </div>\r\n   