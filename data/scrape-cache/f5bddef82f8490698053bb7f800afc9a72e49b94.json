 rel=\"stylesheet\" href=\"https://www.kyowa-corp.co.jp/wp/wp-content/themes/kyowa-corp/js/scroll-hint/scroll-hint.css\">\n<link rel=\"stylesheet\" href=\"https://www.kyowa-corp.co.jp/wp/wp-content/themes/kyowa-corp/css/common.css?20260414-01\">\n<link rel=\"stylesheet\" href=\"https://www.kyowa-corp.co.jp/wp/wp-content/themes/kyowa-corp/css/contents.css\">\n\n<!-- js -->\n<script src=\"https://ajax.googleapis.com/ajax/libs/jquery/2.2.0/jquery.min.js\"></script>\n\n<!-- og meta -->\n<meta property=\"og:type\" content=\"article\">\n<meta property=\"og:title\" content=\"地域清掃活動　～未来のためにできること～\">\n<meta property=\"og:image\" content=\"https://www.kyowa-corp.co.jp/wp/wp-content/themes/kyowa-corp/img/ogp.jpg\">\n\n<script type=\"text/javascript\" src=\"https://www.kyowa-corp.co.jp/wp/wp-content/themes/kyowa-corp/js/gtag.js\"></script>\n</head>\n<body>\n<!-- ////////// PageHeader ////////// -->\n<header class=\"header\">\n\t<div class=\"header_inner\">\n\t\t<div class=\"header_logo\">\n                        <div class=\"logo\"><a href=\"https://www.kyowa-corp.co.jp\"><img src=\"https://www.kyowa-corp.co.jp/wp/wp-content/themes/kyowa-corp/img/common/header_logo.png\" alt=\"株式会社 共和コーポレーション\"></a></div>\n            \t\t</div>\n\t\t<div class=\"header_menu\">\n\t\t\t<div class=\"header_menu_first\">\n\t\t\t\t<nav>\n\t\t\t\t\t<ul class=\"header_menu_pc\">\n\t\t\t\t\t\t<li><a href=\"https://kyowa-corp.saiyo-job.jp/tpkj/recruit/\" target=\"_blank\">採用情報</a></li>\n\t\t\t\t\t\t<li><a href=\"https://www.kyowa-corp.co.jp/contact/\">お問い合わせ</a></li>\n\t\t\t\t\t\t<li class=\"font_size\">\n\t\t\t\t\t\t\t<span>文字サイズ</span>\n\t\t\t\t\t\t\t<button id=\"font_m\" class=\"font_size_btn font_m\">中</button>\n\t\t\t\t\t\t\t<button id=\"font_l\" class=\"font_size_btn font_l\">大</button>\n\t\t\t\t\t\t</li>\n\t\t\t\t\t</ul>\n\t\t\t\t\t<ul class=\"header_menu_sp\">\n\t\t\t\t\t\t<li><a href=\"#\" class=\"header_menu_btn_menu\"></a></li>\n\t\t\t\t\t</ul>\n\t\t\t\t</nav>\n\t\t\t</div><!-- /.header_menu_first -->\n\t\t\t<div class=\"header_menu_second\">\n\t\t\t\t<nav>\n\t\t\t\t\t<ul>\n\t\t\t\t\t\t<li><a href=\"https://www.kyowa-corp.co.jp/company/\" class=\"company\"><span>企業情報</span></a></li>\n\t\t\t\t\t\t<li><a href=\"https://www.kyowa-corp.co.jp/business/\" class=\"business\"><span>事業内容</span></a></li>\n\t\t\t\t\t\t<li><a href=\"http://www.kyowa-corp.co.jp/ir/\" class=\"ir\"><span>株主・投資家の皆様へ</span></a></li>\n\t\t\t\t\t\t<li><a href=\"https://www.kyowa-corp.co.jp/sustainability/\" class=\"csr\"><span>サスティナビリティ</span></a></li>\n\t\t\t\t\t</ul>\n\t\t\t\t</nav>\n\t\t\t</div><!-- /.header_menu_second -->\n\t\t</div>\n\t</div>\n</header>\n\n<!-- ////////// PageContents ////////// -->\n\n<section class=\"page_content_single news\">\n    <div class=\"page_main_title\">\n        <div class=\"contents_inner\">\n            <div class=\"title\">\n                <strong class=\"font_robot\">NEWS RELEASE</strong>\n                <span>ニュースリリース</span>\n            </div>\n        </div><!-- /.contents_inner -->\n    </div><!-- /.page_main_title -->\n    <div class=\"contents_inner\">\n        <div class=\"page_contents_body\">\n                        <div class=\"news_head\">\n                <div class=\"colm1_short\">\n                    <h1>地域清掃活動　～未来のためにできること～</h1>\n                    <div class=\"data\">\n                        <span class=\"time\">2026年4月17日</span>\n                        <span class=\"tag tag_blue\">お知らせ</span>\n                    </div>\n                </div>\n            </div>\n            <div class=\"news_body\">\n                <div class=\"paragraph\">\n                    <div class=\"colm1_short pattern_left\">\n                        <p>当社はサステナビリティ推進の一環として、長野市内の河川敷<span>(</span>裾花川<span>)</span>清掃活動を実施しました。昨年に続き、<span>20</span>名の社員が一丸となって地域の環境美化に取り組みました。２班に分かれて<span>1</span>時間の清掃を行い、軽トラック<span>2</span>台分のゴミを回収しました。社員同士の協力や地域への思いが、活動を通じてより強く感じられる一日となりました。</p>\r\n<p>今後も当社は、持続可能な社会の実現に向けて、地域とともに歩み続けます。</p>\r\n<p><img fetchpriority=\"high\" decoding=\"async\" src=\"http://www.kyowa-corp.co.jp/wp/wp-content/uploads/2026/04/1000000824-300x222.jpg\" alt=\"\" width=\"300\" height=\"222\" class=\"size-medium wp-image-1608\" srcset=\"https://www.kyowa-corp.co.jp/wp/wp-content/uploads/2026/04/1000000824-300x222.jpg 300w, https://www.kyowa-corp.co.jp/wp/wp-content/uploads/2026/04/1000000824-1024x759.jpg 1024w, https://www.kyowa-corp.co.jp/wp/wp-content/uploads/2026/04/1000000824-768x569.jpg 768w, https://www.kyowa-corp.co.jp/wp/wp-content/uploads/2026/04/1000000824-1536x1139.jpg 1536w, https://www.kyowa-corp.co.jp/wp/wp-content/uploads/2026/04/1000000824-2048x1518.jpg 2048w\" sizes=\"(max-width: 300px) 100vw, 300px\" /></p>\r\n<p>出発前の宮本社長からの激励のお言葉</p>\r\n<p><img decoding=\"async\" src=\"http://www.kyowa-corp.co.jp/wp/wp-content/uploads/2026/04/1000000828-300x222.jpg\" alt=\"\" width=\"300\" height=\"222\" class=\"size-medium wp-image-1609\" srcset=\"https://www.kyowa-corp.co.jp/wp/wp-content/uploads/2026/04/1000000828-300x222.jpg 300w, https://www.kyowa-corp.co.jp/wp/wp-content/uploads/2026/04/1000000828-1024x759.jpg 1024w, https://www.kyowa-corp.co.jp/wp/wp-content/uploads/2026/04/1000000828-768x569.jpg 768w, https://www.kyowa-corp.co.jp/wp/wp-content/uploads/2026/04/1000000828-1536x1139.jpg 1536w, https://www.kyowa-corp.co.jp/wp/wp-content/uploads/2026/04/1000000828-2048x1518.jpg 2048w\" sizes=\"(max-width: 300px) 100vw, 300px\" /></p>\r\n<p>出発前の集合写真</p>\r\n<p><img decoding=\"async\" src=\"http://www.kyowa-corp.co.jp/wp/wp-content/uploads/2026/04/1000000834-300x222.jpg\" alt=\"\" width=\"300\" height=\"222\" class=\"size-medium wp-image-1610\" srcset=\"https://www.kyowa-corp.co.jp/wp/wp-content/uploads/2026/04/1000000834-300x222.jpg 300w, https://www.kyowa-corp.co.jp/wp/wp-content/uploads/2026/04/1000000834-1024x759.jpg 1024w, https://www.kyowa-corp.co.jp/wp/wp-content/uploads/2026/04/1000000834-768x569.jpg 768w, https://www.kyowa-corp.co.jp/wp/wp-content/uploads/2026/04/1000000834-1536x1139.jpg 1536w, https://www.kyowa-corp.co.jp/wp/wp-content/uploads/2026/04/1000000834-2048x1518.jpg 2048w\" sizes=\"(max-width: 300px) 100vw, 300px\" /></p>\r\n<p>河川敷での作業の様子</p>\r\n<p><img loading=\"lazy\" decoding=\"async\" src=\"http://www.kyowa-corp.co.jp/wp/wp-content/uploads/2026/04/DSC_0503-300x225.jpg\" alt=\"\" width=\"300\" height=\"225\" class=\"alignnone size-medium wp-image-1611\" srcset=\"https://www.kyowa-corp.co.jp/wp/wp-content/uploads/2026/04/DSC_0503-300x225.jpg 300w, https://www.kyowa-corp.co.jp/wp/wp-content/uploads/2026/04/DSC_0503-768x576.jpg 768w, https://www.kyowa-corp.co.jp/wp/wp-content/uploads/2026/04/DSC_0503.jpg 1008w\" sizes=\"auto, (max-width: 300px) 100vw, 300px\" /></p>\r\n<p>回収したごみの山</p>                    </div>\n                </div>\n            </div>\n                    </div><!-- /.page_contents_body -->\n    </div><!-- /.contents_inner -->\n</section><!-- /.page_content_single -->\n\n\n<div class=\"page_layer_nav\">\n    <div class=\"contents_inner\">\n        <div class=\"second_layer_nav\">\n            <a href=\"https://www.kyowa-corp.co.jp/news\">ニュースリリース</a>\n        </div><!-- /.second_layer_nav -->\n    </div><!-- /.contents_inner -->\n</div><!-- /.page_layer_nav -->\n<div class=\"page_pan_list\">\n    <div class=\"contents_inner\">\n        <ul itemscope itemtype=\"http://schema.org/BreadcrumbList\">\n            <li class=\"home\" itemprop=\"itemListElement\" itemscope itemtype=\"http://schema.org/ListItem\">\n                <a itemprop=\"item\" href=\"https://www.kyowa-corp.co.jp/\">\n                    <span itemprop=\"name\">HOME</span>\n                </a>\n                <meta itemprop=\"position\" content=\"1\" />\n            </li>\n            <li itemprop=\"itemListElement\" itemscope itemtype=\"http://schema.org/ListItem\">\n                <a itemprop=\"item\" href=\"https://www.kyowa-corp.co.jp/news/\">\n                    <span itemprop=\"name\">ニュースリリース</span>\n                </a>\n                <meta ite