{"url":"http://www.ktec-akashi.co.jp/","html":"<!DOCTYPE html>\r\n<html lang=\"ja\">\r\n\r\n<head prefix=\"og: https://ogp.me/ns#\">\r\n    <meta charset=\"UTF-8\">\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n    <meta name=\"description\" content=\"カワサキモータースの関連会社、ケイテックの公式サイトです。川崎重工グループを中心に事業展開するデジタル・ソリューション・カンパニーです。\">\r\n\r\n    <title>K-TEC 株式会社ケイテック</title>\r\n\r\n    <!-- ファビコン -->\r\n    <link rel=\"icon\" type=\"image/x-icon\" href=\"assets/img/favicon_16x16px.png\">\r\n    <link rel=\"apple-touch-icon\" href=\"assets/img/favicon_180x180px.png\">\r\n\r\n    <!-- ogp -->\r\n    <meta property=\"og:locale\" content=\"ja_JP\">\r\n    <meta property=\"og:site_name\" content=\"K-TEC 株式会社ケイテック\">\r\n    <meta property=\"og:url\" content=\"https://www.ktec-akashi.co.jp/\">\r\n    <meta property=\"og:type\" content=\"website\">\r\n    <meta property=\"og:title\" content=\"K-TEC 株式会社ケイテック\">\r\n    <meta property=\"og:description\" content=\"カワサキモータースの関連会社、ケイテックの公式サイトです。川崎重工グループを中心に事業展開するデジタル・ソリューション・カンパニーです。\">\r\n    <meta property=\"og:image\" content=\"https://www.ktec-akashi.co.jp/assets/img/OGP_1200x630px.png\">\r\n\r\n    <!-- font -->\r\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\r\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\r\n    <link\r\n        href=\"https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@100..900&family=Noto+Sans:ital,wght@0,100..900;1,100..900&family=Roboto:ital,wght@0,100..900;1,100..900&family=Zen+Kaku+Gothic+New&display=swap\"\r\n        rel=\"stylesheet\">\r\n\r\n    <!-- css -->\r\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"assets/css/reset.css\">\r\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"assets/css/style.css\">\r\n\r\n    <!-- Google tag (gtag.js) -->\r\n    <script async src=\"https://www.googletagmanager.com/gtag/js?id=G-XHJS5KLZ2J\"></script>\r\n    <script>\r\n        window.dataLayer = window.dataLayer || [];\r\n        function gtag() { dataLayer.push(arguments); }\r\n        gtag('js', new Date());\r\n\r\n        gtag('config', 'G-XHJS5KLZ2J');\r\n    </script>\r\n    \r\n</head>\r\n\r\n<body class=\"bg-color_lblue\">\r\n    <!-- 共通のヘッダーを使用 -->\r\n    <div id=\"header\"></div>\r\n\r\n    <main>\r\n        <!-- トップ -->\r\n        <section class=\"corp-top_sec\">\r\n            <div class=\"corp-top_txt\">\r\n                <div class=\"corp-top_txt_box\">\r\n                    <img src=\"assets/img/index/top-ktec-txt.svg\">\r\n                </div>\r\n            </div>\r\n            <div class=\"corp-top_video\">\r\n                <video loop muted autoplay playsinline class=\"corp-top_video-pc\">\r\n                    <source src=\"assets/video/index/corp-top_animation.mp4\" type=\"video/mp4\">\r\n                </video>\r\n                <video loop muted autoplay playsinline class=\"corp-top_video-sp\">\r\n                    <source src=\"assets/video/index/corp-top_animation-sp.mp4\" type=\"video/mp4\">\r\n                </video>\r\n            </div>\r\n        </section>\r\n\r\n        <!-- 企業メッセージ -->\r\n        <section class=\"corp-message_sec\">\r\n            <!-- <div class=\"chain_txt_frame01\">\r\n                <img src=\"assets/img/index/chain-reaction_img.png\">\r\n            </div>\r\n            <div class=\"chain_txt_frame02\">\r\n                <img src=\"assets/img/index/chain-reaction_img.png\">\r\n            </div> -->\r\n            <div class=\"chain_txt_frame03\">\r\n                <img src=\"assets/img/index/chain-reaction_img02.svg\">\r\n            </div>\r\n            <div class=\"corp-message_box fadeUpTrigger\">\r\n                <div class=\"chain_img\">\r\n                    <img src=\"assets/gif/subpage/icon_animation03.gif\">\r\n                </div>\r\n                <div class=\"chain_txt\">\r\n                    <p class=\"chain_txt_main fadeUpTrigger\">いける、<br>\r\n                        もう一歩先へ</p>\r\n                    <p class=\"chain_txt_sub fadeUpTrigger\">課題を共に見つめ、考え、探す。<br>\r\n                        そのプロセスの中で生まれる、ひとつの気づきが新たな可能性を呼び起こし、<br>\r\n                        共感が広がっていく。<br>\r\n                        “連鎖反応” —Chain reaction— が、未来を動かす。<br>\r\n                        技術とアイデアを積み重ね、その可能性を、もう一歩先へ。<br>\r\n                        「ケイテックとなら、いけるかもしれない。」<br>\r\n                        その一歩が、まだ見ぬステージへとつながる。<br>\r\n                        積み重ねたその歩みで、限界を超えていく。<br>\r\n                        私たちは、そう信じています。</p>\r\n                </div>\r\n            </div>\r\n            <div class=\"message_viewmore_btn\">\r\n                <a href=\"about-us/index.html\"><img src=\"assets/img/index/viewmore_btn_white.png\"></a>\r\n            </div>\r\n            <!-- <div class=\"corp-messege_backvideo\">\r\n                <video src=\"assets/video/index/fractalnoise_1920x1920.mp4\" autoplay loop muted playsinlin></video>\r\n            </div> -->\r\n        </section>\r\n\r\n        <!-- ニュース -->\r\n        <!-- <section class=\"news_sec\">\r\n            <div class=\"news_inn fadeUpTrigger\">\r\n                <div class=\"news_ttl\">\r\n                    <p>ニュース</p>\r\n                    <div class=\"news_ttl_img\">\r\n                        <img src=\"assets/img/index/news_outline_txt.png\">\r\n                    </div>\r\n                </div>\r\n                <ul class=\"news_box\">\r\n                    <li>\r\n                        <div class=\"news_t\">\r\n                            <time>2025.XX.XX</time>\r\n                            <p class=\"news_theme\">お知らせ</p>\r\n                        </div>\r\n                        <p class=\"overflow-ellipsis\">XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX</p>\r\n                    </li>\r\n                    <li>\r\n                        <div class=\"news_t\">\r\n                            <time>2025.XX.XX</time>\r\n                            <p class=\"news_theme\">お知らせ</p>\r\n                        </div>\r\n                        <p class=\"overflow-ellipsis\">XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX</p>\r\n                    </li>\r\n                </ul>\r\n                <div class=\"news_viewmore_btn\">\r\n                    <a href=\"#\"><img src=\"assets/img/index/viewmore_btn_gray.png\"></a>\r\n                </div>\r\n            </div>\r\n        </section> -->\r\n\r\n        <!-- 事業内容 -->\r\n        <article class=\"service_article\">\r\n            <div class=\"service_icon_animation01\">\r\n                <img src=\"assets/gif/subpage/icon_animation01_green.gif\" alt=\"イメージ\">\r\n            </div>\r\n            <div class=\"service_icon_animation02\">\r\n                <img src=\"assets/gif/subpage/icon_animation05_green.gif\" alt=\"イメージ\">\r\n            </div>\r\n            <section class=\"service_sec\">\r\n                <div class=\"service_ttl fadeUpTrigger\">\r\n                    <p>事業内容</p>\r\n                    <div class=\"service_ttl_img\">\r\n                        <img src=\"assets/img/index/service_outline_txt.png\">\r\n                    </div>\r\n                </div>\r\n                <div class=\"service_txt fadeUpTrigger\">\r\n                    <p>私たちケイテックは、社是の「夢と革新 愛と歓び」を理念とした<br>\r\n                        カワサキグループを中心に事業展開するデジタルソリューション企業です。</p>\r\n                </div>\r\n                <!-- PCのとき -->\r\n                <div class=\"service_menu_pc\">\r\n                    <div class=\"big-circle fadeUpTrigger\">\r\n                        <div class=\"circle_center_img\">\r\n                            <img src=\"assets/img/index/circle_center_img.png\">\r\n                        </div>\r\n                        <a href=\"/service/index.html#service_sec_box01\" class=\"small-circle\">デジタル技術開発</a>\r\n                        <a href=\"/service/index.html#service_sec_box02\" class=\"small-circle\">航空ジェット<br>エンジン設計</a>\r\n                        <a href=\"/service/index.html#ser