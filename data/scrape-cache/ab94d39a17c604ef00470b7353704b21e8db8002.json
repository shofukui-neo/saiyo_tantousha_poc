n                    <img class=\"pc-only\" src=\"assets/gif/index/vision_circle_animation.gif\">\r\n                    <img class=\"sp-only\" src=\"assets/gif/index/vision_circle_animation_sp.gif\">\r\n                </div>\r\n                <div class=\"to-vision_ttl\">\r\n                    <p>ケイテックのビジョン</p>\r\n                    <!-- <img src=\"assets/img/index/ktec-vision_txt.png\"> -->\r\n                </div>\r\n                <div class=\"to-vision_txt\">\r\n                    <p>多様な仲間と挑戦し続ける、<br>\r\n                        ケイテックが描く<br class=\"sp-only\">4つのビジョンを紹介する<br>\r\n                        スペシャルコンテンツです。</p>\r\n                </div>\r\n                <div class=\"to-vision_viewmore_btn\">\r\n                    <img src=\"assets/img/index/viewmore_btn_white02.png\">\r\n                </div>\r\n                <div class=\"to-vision_viewmore_btn_sp\">\r\n                    <img src=\"assets/img/index/viewmore_btn_sp_white02.png\">\r\n                </div>\r\n            </section>\r\n        </a>\r\n\r\n        <!-- 採用情報 -->\r\n\r\n        <section class=\"recruit_sec fadeUpTrigger\">\r\n            <a href=\"recruit/index.html\">\r\n                <div class=\"recruit_inn\">\r\n                    <div class=\"recruit_ttl\">\r\n                        <p>採用情報</p>\r\n                        <img src=\"assets/img/index/recruit_txt.png\">\r\n                    </div>\r\n                    <div class=\"recruit_txt\">\r\n                        <p>様々な分野のプロフェッショナルが集まる<br>ケイテック。<br>\r\n                            私たちの仕事を詳しくご紹介します。</p>\r\n                    </div>\r\n                    <div class=\"recruit_viewmore_btn\">\r\n                        <img src=\"assets/img/index/viewmore_btn_gray.png\">\r\n                    </div>\r\n                    <div class=\"recruit_viewmore_btn_sp\">\r\n                        <img src=\"assets/img/index/viewmore_btn_sp_gray.png\">\r\n                    </div>\r\n                </div>\r\n            </a>\r\n        </section>\r\n\r\n        <!-- インターシップ -->\r\n        <section class=\"internship_sec fadeUpTrigger\">\r\n            <a href=\"https://ktec-recruit.snar.jp/\">\r\n                <div class=\"intership_inn\">\r\n                    <div class=\"intership_ttl\">\r\n                        <img src=\"assets/img/index/intership_txt.png\">\r\n                    </div>\r\n                    <div class=\"intership_viewmore_btn\">\r\n                        <img src=\"assets/img/index/viewmore_btn_gray.png\">\r\n                    </div>\r\n                    <div class=\"intership_viewmore_btn_sp\">\r\n                        <img src=\"assets/img/index/viewmore_btn_sp_green.png\">\r\n                    </div>\r\n                </div>\r\n            </a>\r\n        </section>\r\n\r\n        <article class=\"info_article fadeUpTrigger\">\r\n            <!-- アクセス -->\r\n            <a href=\"access/index.html\" class=\"to-access_btn\">\r\n                <section class=\"to-access_sec\">\r\n                    <div class=\"to-access_ttl\">\r\n                        <p>アクセス</p>\r\n                        <img src=\"assets/img/index/access_outline_txt.png\">\r\n                    </div>\r\n                    <div class=\"viewmore_info_btn\">\r\n                        <img src=\"assets/img/index/viewmore_info_btnwaku.png\">\r\n                    </div>\r\n                </section>\r\n            </a>\r\n            <!-- お問い合わせ -->\r\n            <a href=\"company/index.html\" class=\"to-contact_btn\">\r\n                <section class=\"to-contact_sec\">\r\n                    <div class=\"to-contact_ttl\">\r\n                        <p>お問い合わせ</p>\r\n                        <img src=\"assets/img/index/contact_outline_txt.png\">\r\n                    </div>\r\n                    <div class=\"viewmore_info_btn\">\r\n                        <img src=\"assets/img/index/viewmore_info_btnwaku.png\">\r\n                    </div>\r\n                </section>\r\n            </a>\r\n        </article>\r\n\r\n        <!-- リンク集 -->\r\n        <section class=\"links_sec fadeUpTrigger\">\r\n            <div class=\"links_ttl\">\r\n                <p>リンク集</p>\r\n                <img src=\"assets/img/index/links_outline_txt.png\">\r\n            </div>\r\n            <div class=\"links_box\">\r\n                <figure>\r\n                    <a href=\"https://www.khi.co.jp/\" target=\"_blank\" rel=\"noopener noreferrer\">\r\n                        <img src=\"assets/img/index/khi_link_logo.svg\" alt=\"KHIリンクバナー\" />\r\n                        <figcaption>川崎重工業株式会社</figcaption>\r\n                    </a>\r\n                </figure>\r\n                <figure>\r\n                    <a href=\"https://www.global-kawasaki-motors.com/\" target=\"_blank\" rel=\"noopener noreferrer\">\r\n                        <img src=\"assets/img/index/kmc_link_logo.svg\" alt=\"KMCリンクバナー\" />\r\n                        <figcaption>カワサキモータース株式会社</figcaption>\r\n                    </a>\r\n                </figure>\r\n            </div>\r\n        </section>\r\n    </main>\r\n\r\n    <div id=\"to-top_btn\" class=\"to-top_btn\">\r\n        <a href=\"#\">\r\n            <img src=\"assets/img/index/to-top-btn.png\">\r\n        </a>\r\n    </div>\r\n\r\n    <!-- 共通のフッターを使用 -->\r\n    <div id=\"footer\"></div>\r\n\r\n    <!-- js -->\r\n    <!-- jquery -->\r\n    <script src=\"https://code.jquery.com/jquery-3.7.1.min.js\"\r\n        integrity=\"sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo=\" crossorigin=\"anonymous\"></script>\r\n\r\n    <!-- オリジナルjs -->\r\n    <script src=\"assets/js/script.js\"></script>\r\n    <script src=\"assets/js/top.js\"></script>\r\n\r\n    <!-- 共通のヘッダーフッターを使用 -->\r\n    <script>\r\n        $(function () {\r\n            $(\"#header\").load(\"include/header.html\");\r\n            $(\"#footer\").load(\"include/footer.html\");\r\n        });\r\n    </script>\r\n\r\n</body>\r\n\r\n</html>","finalUrl":"https://www.ktec-akashi.co.jp/","rendered":false,"_cachedAt":"2026-06-14T16:12:42.076Z"}