 async src=\"https://www.googletagmanager.com/gtag/js?id=UA-152929986-1\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'UA-152929986-1');\n  gtag('config', 'AW-693389117');\n</script>\n<script async src=\"https://s.yimg.jp/images/listing/tool/cv/ytag.js\"></script>\n<script>\nwindow.yjDataLayer = window.yjDataLayer || [];\nfunction ytag() { yjDataLayer.push(arguments); }\nytag({\"type\":\"ycl_cookie\", \"config\":{\"ycl_use_non_cookie_storage\":true}});\n</script>\n<script async src=\"https://s.yimg.jp/images/listing/tool/cv/ytag.js\"></script>\n<script>\nwindow.yjDataLayer = window.yjDataLayer || [];\nfunction ytag() { yjDataLayer.push(arguments); }\nytag({\n  \"type\":\"yjad_retargeting\",\n  \"config\":{\n    \"yahoo_retargeting_id\": \"3VY030UDKM\",\n    \"yahoo_retargeting_label\": \"\"\n    /*,\n    \"yahoo_retargeting_page_type\": \"\",\n    \"yahoo_retargeting_items\":[\n      {item_id: '', category_id: '', price: '', quantity: ''}\n    ]*/\n  }\n});\n</script>\n  </head>\n\n  <body>\n    <!-- Google Tag Manager (noscript) -->\n    <noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-KG4D784\"\n    height=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n    <!-- End Google Tag Manager (noscript) -->\n    <div class=\"l-container\">\n\n      <noscript>\n  <div class=\"c-box -danger u-ta-c\">\n    <p class=\"u-font-red\">当サイトはJavaScriptを使用しています。<br>JavaScriptが無効になっている場合は、有効にしてください。</p>\n  </div>\n</noscript>\n<header class=\"l-header\">\n  <div class=\"l-header__inner\">\n    <div class=\"l-header__logo\">\n      <a href=\"/\">\n        <img src=\"/common/img/common/logo_main.svg\" alt=\"株式会社データプラス\">\n      </a>\n    </div>\n    <a class=\"l-header-menu-btn\">\n      <span></span>\n      <span></span>\n      <span></span>\n    </a>\n    <div class=\"l-header__nav\">\n      <nav class=\"l-gnav\">\n        <ul class=\"l-gnav__list\">\n          <li class=\"l-gnav__item\">\n            <a href=\"/\" class=\"l-gnav__link\" data-text=\"HOME\">ホーム</a>\n          </li>\n          <li class=\"l-gnav__item\">\n            <a href=\"/works/\" class=\"l-gnav__link\" data-text=\"WORKS\">事業案内</a>\n          </li>\n          <li class=\"l-gnav__item\">\n            <a href=\"/company/\" class=\"l-gnav__link\" data-text=\"COMPANY\">会社案内</a>\n          </li>\n          <li class=\"l-gnav__item\">\n            <a href=\"/news/\" class=\"l-gnav__link\" data-text=\"NEWS\">お知らせ</a>\n          </li>\n        </ul>\n      </nav>\n      <div class=\"l-header-text-size\">\n        <span class=\"l-header-text-size__title\">文字サイズ</span>\n        <button class=\"l-header-text-size__small\">小</button>\n        <button class=\"l-header-text-size__medium -current\">中</button>\n        <button class=\"l-header-text-size__large\">大</button>\n      </div>\n      <div class=\"l-header__contact\">\n        <a href=\"/contact/\" class=\"l-header__contact-btn\">お問い合わせ</a>\n      </div>\n    </div>\n  </div>\n</header>\n\n      <main class=\"l-main\">\n\n        <div class=\"l-title -works\">\n          <div class=\"l-title__text\">\n            <span class=\"l-title__sub\">アウトソーシング事業</span>\n            <h1 class=\"l-title__main\">データエントリー</h1>\n          </div>\n        </div>\n\n        <div class=\"l-breadcrumb\">\n          <div class=\"l-breadcrumb__inner\">\n            <ol class=\"c-breadcrumb\">\n              <li><a href=\"/\">ホーム</a></li>\n              <li><a href=\"/works\">事業案内</a></li>\n              <li><span>データエントリー</span></li>\n            </ol>\n          </div>\n        </div>\n\n        <div class=\"c-content-block\">\n          <div class=\"c-content-block__inner\">\n            <div class=\"c-section -large\">\n              <p class=\"c-sentence\">長年の実績と経験を活かし、安心で精度の高いサービスをご提供。<br>\n                アンケートや名簿など素早く確実にデータ化いたします。<br>\n                プライバシーマークも取得しており、セキュリティにも万全の体制を確立しています。</p>\n            </div>\n\n            <section class=\"c-section -large\">\n              <h2 class=\"c-heading-main -large\">特徴<span class=\"c-heading-main__subtext -blue\">FEATURE</span></h2>\n              <div class=\"works-explain\">\n                <h3 class=\"works-explain__title\" tabindex=\"0\"><span class=\"works-explain__number -blue\">01.</span>実績と信頼<span class=\"works-explain__icon -active\"><img src=\"/common/img/common/ico_plus_gray.svg\" alt=\"開く\"></span>\n                </h3>\n                <div class=\"works-explain__content\">\n                  <div class=\"works-explain__body\">\n                    <div class=\"works-explain__image\">\n                      <img src=\"/common/img/works/data_entry/img_data_entry_01.jpg\" alt=\"\">\n                    </div>\n                    <div class=\"works-explain__text\">\n                      <ul class=\"works-explain__list -blue\">\n                        <li>設立以来40年以上の実績があります。</li>\n                        <li>金融機関様や大手企業様の入力実績も多数あります。</li>\n                      </ul>\n                    </div>\n                  </div>\n                </div>\n              </div>\n\n              <div class=\"works-explain\">\n                <h3 class=\"works-explain__title\" tabindex=\"0\"><span class=\"works-explain__number -blue\">02.</span>万全なセキュリティ対策<span class=\"works-explain__icon -active\"><img src=\"/common/img/common/ico_plus_gray.svg\" alt=\"開く\"></span>\n                </h3>\n                <div class=\"works-explain__content\">\n                  <div class=\"works-explain__body -reverse\">\n                    <div class=\"works-explain__image\">\n                      <img src=\"/common/img/works/data_entry/img_data_entry_02.jpg\" alt=\"\">\n                    </div>\n                    <div class=\"works-explain__text\">\n                      <ul class=\"works-explain__list -blue\">\n                        <li>プライバシーマーク、ISO27001も取得し、個人情報も徹底管理しています。</li>\n                        <li>国内のみの入力作業を実施しています。</li>\n                      </ul>\n                    </div>\n                  </div>\n                </div>\n              </div>\n\n              <div class=\"works-explain\">\n                <h3 class=\"works-explain__title\" tabindex=\"0\"><span class=\"works-explain__number -blue\">03.</span>高品質なデータ提供<span class=\"works-explain__icon -active\"><img src=\"/common/img/common/ico_plus_gray.svg\" alt=\"開く\"></span>\n                </h3>\n                <div class=\"works-explain__content\">\n                  <div class=\"works-explain__body\">\n                    <div class=\"works-explain__image\">\n                      <img src=\"/common/img/works/data_entry/img_data_entry_03.jpg\" alt=\"\">\n                    </div>\n                    <div class=\"works-explain__text\">\n                      <ul class=\"works-explain__list -blue\">\n                        <li>専用のシステムで入力専門スタッフがデータ入力をしています。</li>\n                        <li>ベリファイ入力により精度の高いデータを作成いたします。</li>\n                      </ul>\n                    </div>\n                  </div>\n                </div>\n              </div>\n            </section>\n\n            <section class=\"c-section -large\">\n              <h2 class=\"c-heading-main -large\">メリット<span class=\"c-heading-main__subtext -blue\">MERIT</span></h2>\n              <ul class=\"works-merit\">\n                <li class=\"works-merit__item\">\n                  <div class=\"works-merit__image\"><img src=\"/common/img/works/ico_lock.svg\" alt=\"\"></div>\n                  <h3 class=\"works-merit__title\">セキュリティが万全</h3>\n                  <p>セキュリティ万全の環境で入力作業を実施していますので、個人情報入力の委託も安心してお任せください。</p>\n                </li>\n                <li class=\"works-merit__item\">\n                  <div class=\"works-merit__image\"><img src=\"/common/img/works/ico_check.svg\" alt=\"\"></div>\n                  <h3 class=\"works-merit__title\">安全かつスピーディー</h3>\n                  <p>国内で入力専門スタッフが安全、かつスピーディーにデータ化いたします。</p>\n                </li>\n                <li class=\"works-merit__item\">\n                  <div class=\"works-merit__image\"><img src=\"/common/img/works/ico_shine.svg\" alt=\"\"></div>\n                  <h3 class=\"works-merit__title\">二度入力で高品質</h3>\n                  <p>二度（エントリー・ベリファイ）入力を基本としていますので、高品質なデータを納品させていただきます。</p>\n                </li>\n                <li class=\"works-merit__item\">\n                  <div class=\"works-merit__image\"><img src=\"/common/img/works/ico_list.svg\" alt=\"\"></div>\n                  <h3 class=\"works-merit__title\">柔軟な対応</h3>\n                  <p>お客様の要望に応じた納品方法で、素早く確実に納品いたしております。</p>\n                </li>\n                <li class=\"works-merit__item\">\n                  <div class=\"works-merit__image\"><img src=\"/common/img/works/ico_print.svg\" alt=\"\"></div>\n                  <h3 class=\"works-merit__title\">報告書の作成も</h3>\n                  <p>入力業務のみでなく、集計作業や報告書の作成まで対応可能です。</p>\n                </li>\n              </ul>\n            </section>\n\n            <section class=\"c-section -large\">\n              <h2 class=\"c-heading -medium -center\">データエントリーに関するよくあるご質問</h2>\n              <div class=\"u-ta-c\">\n                <a href=\"/qa/#data_entry\" class=\"c-btn -blue\">よくあるご質問</a>\n              </div>\n            </section>\n\n            <section class=\"c-local-nav\">\n              <h2 class=\"c-heading -medium -center\">クラウドシステム開発</h2>\n              <div class=\"c-local-nav__list\">\n                <ul class=\"c-grid\" style=\"justify-content: center;\">\n                  <li class=\"c-grid__col -col-3 -col-sp-6\">\n                    <a href=\"/works/truck/\" class=\"c-local-nav__btn\">指示らくネット for トラック</a>\n                  </li>\n                  <li class=\"c-grid__col -col-3 -col-sp-6\">\n                    <a href=\"/works/bus/\" class=\"c-local-nav__btn\">指示らくネット for バス</a>\n                  </li>\n                  <li class=\"c-grid__col -col-3 -col-sp-6\">\n                    <a href=\"/works/other/\" class=\"c-local-nav__btn\">その他システム開発</a>\n                  </li>\n                </ul>\n              </div>\n\n              <div class=\"c-local-nav__list\">\n                <h2 class=\"c-heading -medium -center\">アウトソーシング事業</h2>\n                <ul class=\"c-grid\">\n                  <li class=\"c-grid__col -col-3 -col-sp-12\">\n                    <a href=\"/works/logistics/\" class=\"c-local-nav__btn\">ロジスティクス</a>\n                  </li>\n                  <li class=\"c-grid__col -col-3 -col-sp-12\">\n                    <a href=\"/works/printing/\" class=\"c-local-nav__btn\">プリンティング</a>\n                  </li>\n                  <li class=\"c-grid__col -col-3 -col-sp-12\">\n                    <a href=\"/works/mailing/\" class=\"c-local-nav__btn\">メーリング</a>\n                  </li>\n                  <li class=\"c-grid__col -col-3 -col-sp-12\">\n                    <a href=\"/works/data_entry/\" class=\"c-local-nav__btn -current\">データエントリー</a>\n                  </li>\n                </ul>\n              </div>\n            </section>\n\n\n          </div>\n        </div>\n\n        <div class=\"l-contact\">\n  <div class=\"l-contact__inner\">\n    <h2 class=\"l-contact__title\">サービスについての資料請求・お問い合わせはこちら</h2>\n    <a href=\"/contact/\" class=\"l-contact__btn\">お問い合わせ</a>\n    \n    <h2 class=\"l-contact__title-02\">お電話でのお問い合わせはこちら</h2>\n    <div class=\"l-contact__tel-wrap\">\n      <p class=\"l-contact__tel\"><span class=\"l-contact__tel-title\">クラウドシステムに関するご相談</span><br><span class=\"l-contact__tel-number js-tel-link\">0942-87-3114</span></p>\n      <p class=\"l-contact__tel\"><span class=\"l-contact__tel-title\">アウトソーシングに関するご相談</span><br><span class=\"l-contact__tel-number js-tel-link\">092-588-9380</span></p>\n    </div>\n  </div>\n</div>\n\n      </main>\n\n      <footer class=\"l-footer\">\n  <a href=\"#\" class=\"l-footer__pagetop\"><span>ページ上部へ戻る</span></a>\n\n  <div class=\"l-footer__info\">\n    <div class=\"l-