{"url":"https://www.fujimurayakuhin.jp/recruit/voice/customer_sm.html","html":"<!DOCTYPE html>\n<html dir=\"ltr\" lang=\"ja\">\n<head>\n<meta http-equiv=\"content-type\" content=\"text/html; charset=utf-8\" />\n\n<!-- Stylesheets\n\t============================================= -->\n<link rel=\"stylesheet\" href=\"../../css/bootstrap.css\" type=\"text/css\" />\n<link rel=\"stylesheet\" href=\"../../css/style.css\" type=\"text/css\" />\n<link rel=\"stylesheet\" href=\"../../css/swiper.css\" type=\"text/css\" />\n<link rel=\"stylesheet\" href=\"../../css/dark.css\" type=\"text/css\" />\n<link rel=\"stylesheet\" href=\"../../css/font-icons.css\" type=\"text/css\" />\n<link rel=\"stylesheet\" href=\"../../css/animate.css\" type=\"text/css\" />\n<link rel=\"stylesheet\" href=\"../../css/magnific-popup.css\" type=\"text/css\" />\n<link rel=\"stylesheet\" href=\"../../css/custom.css\" type=\"text/css\" />\n<link rel=\"stylesheet\" href=\"../../css/calendar.css\" type=\"text/css\" />\n\n<!-- NonProfit Demo Specific Stylesheet -->\n<link rel=\"stylesheet\" href=\"../../css/colors.php?color=77C345\" type=\"text/css\" />\n<!-- Theme Color -->\n<link rel=\"stylesheet\" href=\"../../css/nonprofit.css\" type=\"text/css\" />\n<!-- / --> \n\n<!--font -->\n<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\">\n<link href=\"https://fonts.googleapis.com/css2?family=M+PLUS+1p:wght@300;400;500&display=swap\" rel=\"stylesheet\">\n<meta name='viewport' content='initial-scale=1, viewport-fit=cover'>\n\n<!--favicon -->\n<link rel=\"shortcut icon\" href=\"../../favicon.ico\" type=\"image/x-icon\" />\n<link rel=\"apple-touch-icon\" href=\"../../apple-touch-icon.png\" />\n<link rel=\"apple-touch-icon\" sizes=\"57x57\" href=\"../../apple-touch-icon-57x57.png\" />\n<link rel=\"apple-touch-icon\" sizes=\"72x72\" href=\"../../apple-touch-icon-72x72.png\" />\n<link rel=\"apple-touch-icon\" sizes=\"76x76\" href=\"../../apple-touch-icon-76x76.png\" />\n<link rel=\"apple-touch-icon\" sizes=\"114x114\" href=\"../../apple-touch-icon-114x114.png\" />\n<link rel=\"apple-touch-icon\" sizes=\"120x120\" href=\"../../apple-touch-icon-120x120.png\" />\n<link rel=\"apple-touch-icon\" sizes=\"144x144\" href=\"../../apple-touch-icon-144x144.png\" />\n<link rel=\"apple-touch-icon\" sizes=\"152x152\" href=\"../../apple-touch-icon-152x152.png\" />\n<link rel=\"apple-touch-icon\" sizes=\"180x180\" href=\"../../apple-touch-icon-180x180.png\" />\n\n<!-- Document Title\n\t============================================= -->\n<title>藤村薬品株式会社｜採用情報｜先輩社員の声</title>\n</head>\n\n<body class=\"stretched\">\n\n<!-- Document Wrapper\n\t============================================= -->\n<div id=\"wrapper\" class=\"clearfix\">\n\n<!-- Header\n\t\t============================================= -->\n<header id=\"header\" class=\"header-size-sm border-bottom-0\" data-sticky-shrink=\"false\">\n  <div id=\"header-wrap\">\n    <div class=\"container\">\n      <div class=\"header-row justify-content-lg-between\"> \n        \n        <!-- Logo\n\t\t\t\t\t\t============================================= -->\n        <div id=\"logo\"> <a href=\"../../index.html\" class=\"standard-logo\" data-dark-logo=\"images/logo.png\"><img src=\"../../images/logo.png\" alt=\"Canvas Logo\"></a> <a href=\"../../index.html\" class=\"retina-logo\" data-dark-logo=\"images/logo@2x.png\"><img src=\"../../images/logo@2x.png\" alt=\"Canvas\"></a> </div>\n        <!-- #logo end -->\n        \n        <div id=\"primary-menu-trigger\">\n          <svg class=\"svg-trigger\" viewBox=\"0 0 100 100\">\n            <path d=\"m 30,33 h 40 c 3.722839,0 7.5,3.126468 7.5,8.578427 0,5.451959 -2.727029,8.421573 -7.5,8.421573 h -20\"></path>\n            <path d=\"m 30,50 h 40\"></path>\n            <path d=\"m 70,67 h -40 c 0,0 -7.5,-0.802118 -7.5,-8.365747 0,-7.563629 7.5,-8.634253 7.5,-8.634253 h 20\"></path>\n          </svg>\n        </div>\n        \n        <!-- Primary Navigation\n\t\t\t\t\t\t============================================= -->\n        <nav class=\"primary-menu with-arrows mr-lg-auto\">\n          <ul class=\"menu-container align-self-start\">\n            <li class=\"menu-item\"><span class=\"menu-bg col-auto align-self-start d-flex\"></span></li>\n            <li class=\"menu-item\"><a class=\"menu-link\" href=\"../../index.html\">\n              <div>HOME</div>\n              </a></li>\n            <li class=\"menu-item\"><a class=\"menu-link\" href=\"#\">\n              <div>会社案内</div>\n              </a>\n              <ul class=\"sub-menu-container\">\n                <li class=\"menu-item\"><a class=\"menu-link\" href=\"../../contents/01_message.html\">\n                  <div>ごあいさつ</div>\n                  </a></li>\n                <li class=\"menu-item\"><a class=\"menu-link\" href=\"../../contents/01_company.html\">\n                  <div>会社概要</div>\n                  </a></li>\n                <li class=\"menu-item\"><a class=\"menu-link\" href=\"../../contents/01_office.html\">\n                  <div>事業所一覧</div>\n                  </a></li>\n                <li class=\"menu-item\"><a class=\"menu-link\" href=\"../../contents/01_history.html\">\n                  <div>沿 革</div>\n                  </a></li>\n              </ul>\n            </li>\n            <li class=\"menu-item\"><a class=\"menu-link\" href=\"#\">\n              <div>事業案内</div>\n              </a>\n              <ul class=\"sub-menu-container\">\n                <li class=\"menu-item\"><a class=\"menu-link\" href=\"../../contents/02_sales.html\">\n                  <div>営業機能</div>\n                  </a></li>\n                <li class=\"menu-item\"><a class=\"menu-link\" href=\"../../contents/02_logistics.html\">\n                  <div>物流機能</div>\n                  </a></li>\n                <li class=\"menu-item\"><a class=\"menu-link\" href=\"../../contents/02_support.html\">\n                  <div>お得意先支援</div>\n                  </a></li>\n                <li class=\"menu-item\"><a class=\"menu-link\" href=\"../../contents/02_solution.html\">\n                  <div>ソリューション</div>\n                  </a></li>\n              </ul>\n            </li>\n            <li class=\"menu-item\"><a class=\"menu-link btn-contact\" href=\"../../contents/03_csr.html\">\n              <div>CSR</div>\n              </a></li>\n            <li class=\"menu-item\"><a class=\"menu-link btn-contact\" href=\"../../topics/\">\n                <div>NEWS</div>\n                </a></li>\n            <li class=\"menu-item current\"><a class=\"menu-link\" href=\"#\">\n              <div>採用情報</div>\n              </a>\n              <ul class=\"sub-menu-container\">\n                <li class=\"menu-item\"><a class=\"menu-link\" href=\"../../contents/04_info.html\">\n                  <div>採用案内</div>\n                  </a></li>\n                <li class=\"menu-item\"><a class=\"menu-link\" href=\"../../contents/04_welfare.html\">\n                  <div>研修制度・福利厚生</div>\n                  </a></li>\n                <li class=\"menu-item\"><a class=\"menu-link\" href=\"../../contents/04_voice.html\">\n                  <div>先輩社員の声</div>\n                  </a></li>\n                <li class=\"menu-item\"><a class=\"menu-link\" href=\"../../contents/04_faq.html\">\n                  <div>よくある質問</div>\n                  </a></li>\n              </ul>\n            </li>\n            <li class=\"menu-item\"><a class=\"menu-link btn-contact\" href=\"../../contents/05_forest.html\">\n              <div>フォレストグループ</div>\n              </a></li>\n          </ul>\n        </nav>\n        <!-- #primary-menu end --> \n        \n      </div>\n    </div>\n  </div>\n  <div class=\"header-wrap-clone\"></div>\n</header>\n<!-- #header end --> \n\n<!-- Page Title\n\t\t============================================= -->\n<section id=\"page-title\">\n  <div class=\"container\">\n    <h1>先輩社員の声</h1>\n    <ol class=\"breadcrumb\">\n      <li class=\"breadcrumb-item\"><a href=\"../../index.html\">Home</a></li>\n      <li class=\"breadcrumb-item active\" aria-current=\"page\">採用情報</li>\n    </ol>\n  </div>\n</section>\n<!-- #page-title end --> \n\n<!-- 2025.12.09 h.tabi ここから-->\n\n    <!-- ▼▼▼ ここから貼り付け ▼▼▼ -->\n    <style>\n        /* -------------------------------------------\n        詳細ページ用スタイル（修正版）\n        ------------------------------------------- */\n\n        /* ▼ ヘッダー画像エリア設定 */\n        .voice-detail-header {\n            position: relative;\n            width: 100%;\n            /* 高さ指定(vh)を削除し、padding-topで比率を作ります */\n            background-size: cover;\n            background-position: center;\n            background-repeat: no-repeat;\n            /* 背景画像設定 */\n            background-image: url('img/customer_sm_prv.jpg'); \n        }\n\n        /* 比率を維持するための疑似要素 (PC用デフォルト: 2.5対1) */\n        .voice-detail-header::before {\n            content: '';\n            display: block;\n            /*padding-top: 40%; /* 高さを横幅の40%に設定 */\n            padding-top: 100%; /* 正方形に変更 */\n        }\n\n        /* 画像に重ねるグラデーション */\n        .voice-detail-header::after {\n            content: '';\n            position: absolute;\n            top: 0; left: 0; right: 0; bottom: 0;\n            background: linear-gradient(to bottom, rgba(0,0,0,0) 60%, rgba(0,0,0,0.7) 100%);\n            z-index: 1;\n        }\n\n        /* ヘッダー内のコンテンツ配置用ラッパー */\n        .voice-header-inner {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            z-index: 2; /* グラデーションより上に表示 */\n        }\n\n        /* テキストの位置調整 */\n        .voice-header-content {\n            position: absolute;\n            bottom: 40px;\n            left: 0;\n            width: 100%;\n            color: #fff;\n            text-shadow: 0 2px 5px rgba(0,0,0,0.3);\n        }\n\n        .v-d-role {\n            background: #77C345;\n            padding: 5px 15px;\n            border-radius: 4px;\n            font-size: 0.9rem;\n            display: inline-block;\n            margin-bottom: 10px;\n        }\n\n        .v-d-name {\n            font-size: 2.5rem;\n            font-weight: 700;\n            margin-bottom: 5px;\n            letter-spacing: 0.1em;\n            color: white;\n        }\n\n        .v-d-name small {\n            font-size: 1.2rem;\n            margin-left: 15px;\n            font-weight: 400;\n        }\n\n        .v-d-meta {\n            font-size: 1.1rem;\n            opacity: 0.9;\n        }\n\n        /* ▼ プロフィールエリア */\n        .voice-profile-section {\n            background: #fff;\n            padding: 60px 0;\n            border-bottom: 1px solid #eee;\n        }\n\n        /* プロフィール画像比率固定用クラス (3:2) */\n        .profile-img-wrap {\n            position: relative;\n            width: 100%;\n            padding-top: 66.66%; /* 3:2の比率 (2÷3=0.666...) */\n            overflow: hidden;\n            border-radius: 0.25rem; /* Bootstrapのrounded相当 */\n        }\n\n        .profile-img-wrap img {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            object-fit: cover; /* 枠に合わせてトリミング */\n        }\n\n        .profile-box {\n            background: #f9f9f9;\n            padding: 30px;\n            border-radius: 8px;\n            border-left: 5px solid #77C345;\n        }\n\n        .profile-list dl {\n            display: flex;\n            flex-wrap: wrap;\n            margin-bottom: 10px;\n            border-bottom: 1px dotted #ccc;\n            padding-bottom: 10px;\n        }\n        .profile-list dl:last-child {\n            border-bottom: none;\n            margin-bottom: 0;\n        }\n        .profile-list dt {\n            width: 30%;\n            font-weight: bold;\n            color: #77C345;\n        }\n        .profile-list dd {\n            width: 70%;\n            margin-bottom: 0;\n        }\n\n        /* ▼ Q&Aエリア */\n        .voice-qa-section {\n            padding: 60px 0;\n            background: #fff;\n        }\n\n        .qa-item {\n            margin-bottom: 50px;\n        }\n\n        .qa-q {\n            display: flex;\n            align-items: flex-start;\n            margin-bottom: 15px;\n        }\n\n        .q-icon {\n            background: #77C345;\n            color: #fff;\n            width: 50px;\n            height: 50px;\n            border-radius: 50%;\n            text-align: center;\n            line-height: 50px;\n            font-size: 1.2rem;\n            font-weight: bold;\n            flex-shrink: 0;\n            margin-right: 20px;\n            margin-top: -5px;\n        }\n\n        .q-text {\n            font-size: 1.3rem;\n            font-weight: 700;\n            color: #333;\n            line-height: 1.4;\n            padding-top: 5px;\n            border-bottom: 2px solid #77C345;\n            padding-bottom: 10px;\n            width: 100%;\n        }\n\n        .qa-a {\n            padding-left: 70px;\n            font-size: 1rem;\n            line-height: 1.9;\n            color: #555;\n        }\n\n        /* ▼ スマホ対応調整 */\n        @media (max-width: 767px) {\n            /* スマホ時はヘッダー画像を少し縦長(3:2)にして人物を見やすくする */\n            .voice-detail-header::before {\n                /*padding-top: 66.66%; */\n                padding-top: 100%; /* 正方形に変更 */\n            }\n\n            .v-d-name { font-size: 1.8rem; }\n            .v-d-name small { display: block; margin-left: 0; font-size: 1rem; margin-top: 5px; }\n            .profile-list dt, .profile-list dd { width: 100%; }\n            .qa-a { padding-left: 0; margin-top: 15px; }\n            .q-text { font-size: 1.1rem; }\n        }\n    </style>\n\n    <!-- ヘッダービジュアル -->\n    <section class=\"voice-detail-header\">\n        <div class=\"voice-header-inner\">\n        <div class=\"container h-100 position-relative\">\n            <div class=\"voice-header-content\">\n                <span class=\"v-d-role\">営業本部</span>\n                <h2 class=\"v-d-name\">M.S<small></small></h2>\n                <div class=\"v-d-meta\">2023年 入社</div>\n            </div>\n        </div>\n        </div>\n    </section>\n\n    <!-- プロフィール -->\n    <section class=\"voice-profile-section\">\n        <div class=\"container\">\n            <div class=\"row align-items-center\">\n                <div class=\"col-lg-5 mb-4 mb-lg-0\">\n                    <!-- プロフィール横の顔写真など（あれば） -->\n                    <div class=\"profile-img-wrap\"><img src=\"img/customer_sm_image.jpg\" alt=\"Profile\" class=\"img-fluid rounded\" style=\"width:100%;\"></div>\n                </div>\n                <div class=\"col-lg-7\">\n                    <div class=\"profile-box\">\n                        <h4 class=\"mb-4\">PROFILE</h4>\n                        <div class=\"profile-list\">\n                            <dl>\n                                <dt>どんな会社？</dt>\n                                <dd>個性全開！カルフルな会社！</dd>\n                            </dl>\n                            <dl>\n                                <dt>入社</dt>\n                                <dd>2023年</dd>\n                            </dl>\n                            <dl>\n                                <dt>趣味</dt>\n                                <dd>スポーツ観戦、ゲーム</dd>\n                            </dl>\n                            <dl>\n                                <dt>好きな言葉</dt>\n                                <dd>3連休</dd>\n                            </dl>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <!-- インタビュー本文 -->\n    <section class=\"voice-qa-section\">\n        <div class=\"container\">\n\n            <div class=\"qa-item\">\n                <div class=\"qa-q\">\n                    <div class=\"q-icon\">Q1</div>\n                    <div class=\"q-text\">就職活動の軸は？</div>\n                </div>\n                <div class=\"qa-a\">\n                地元長崎で地域に貢献しながら働ける会社を探していました。 </div>\n            </div>\n\n            <div class=\"qa-item\">\n                <div class=\"qa-q\">\n                    <div class=\"q-icon\">Q2</div>\n                    <div class=\"q-text\">就職活動の失敗談</div>\n                </div>\n                <div class=\"qa-a\">\n                    スケジュールの確認不足です。メールで確認した日付をアプリのカレンダーに登録し、その後はアプリだけを確認していました。 明日面接緊張するな～と思いながらバイトに向かっていると人事の方から連絡が、、、 なんと登録していた日付が1日ずれていたのです。今思い出しても心臓が痛くなります。 </div>\n            </div>\n\n            <div class=\"qa-item\">\n                <div class=\"qa-q\">\n                    <div class=\"q-icon\">Q3</div>\n                    <div class=\"q-text\">入社の決め手</div>\n                </div>\n                <div class=\"qa-a\">\n                安心感です。歴史も長く、ずっと長崎の医療を支えてきたことと面接、懇談会を重ねていく中で会社の雰囲気や先輩社員の明るい対応などを受け、この会社に入れば長く楽しく働いていけると確信しました！ </div>\n            </div>\n\n            <div class=\"qa-item\">\n                <div class=\"qa-q\">\n                    <div class=\"q-icon\">Q4</div>\n                    <div class=\"q-text\">会社自慢をお願いします！</div>\n                </div>\n                <div class=\"qa-a\">\n                人の良さですね！最高です！分からないことがあれば誰にでも聞ける環境はとても大切だと思います。 お互いが分からないことを共有し、コミュニケーションをとることで社員全員が同じ方向を向いて業務に取り組めている1番のポイントだと思います！ </div>\n            </div>\n\n            <div class=\"qa-item\">\n                <div class=\"qa-q\">\n                    <div class=\"q-icon\">Q5</div>\n                    <div class=\"q-text\">入社後のギャップを教えてください。</div>\n                </div>\n                <div class=\"qa-a\">\n                    入社前はとにかく不安でたまりませんでした。薬剤の知識、病気の知識、営業スキル、仕事とプライベートの両立たくさんありましたが、 いざ入社してみれば何も心配いりませんでした。薬剤、病気の知識に関しては手厚いフォローがあり、営業に出てからも分からない事があれば先輩社員、誰に聞いても優しくアドバイスしてくれます！\n              </div>\n            </div>\n\t\t\t\n            <div class=\"qa-item\">\n                <div class=\"qa-q\">\n                    <div class=\"q-icon\">Q6</div>\n                    <div class=\"q-text\">どんな後輩が欲しいですか？</div>\n                </div>\n                <div class=\"qa-a\">\n                  「成長したい」という気持ちがある人がいいですね！全力で応援したくなるので！\n              </div>\n            </div>\n\t\t\t\n            <div class=\"qa-item\">\n                <div class=\"qa-q\">\n                    <div class=\"q-icon\">Q7</div>\n                    <div class=\"q-text\">仕事をする上での座右の銘・モットーを教えて下さい。</div>\n                </div>\n                <div class=\"qa-a\">\n                  「為せば成る」\n              </div>\n            </div>\n\t\t\t\n            <div class=\"qa-item\">\n                <div class=\"qa-q\">\n                    <div class=\"q-icon\">Q8</div>\n                    <div class=\"q-text\">休日の過ごし方を教えて下さい。</div>\n                </div>\n                <div class=\"qa-a\">\n                  基本、家で過ごすことが多いです。ゲームをしたりネットフリックスを見ながら家事をしています。\n              </div>\n            </div>\n\t\t\t\n            <div class=\"qa-item\">\n                <div class=\"qa-q\">\n                    <div class=\"q-icon\">Q9</div>\n                    <div class=\"q-text\">就職活動生へメッセージをお願いします！</div>\n                </div>\n                <div class=\"qa-a\">\n                  頑張った分だけ自分に返ってきます。未来の自分に最高の環境をプレゼントできるように、今を大事にしてください！ あと、思い出も同じくらい大事です！学生時代の思い出や友人は社会に出てからもたくさんのエネルギーをくれるので多くの友人と思い出を作ってください！ みんな頑張れ！！！応援しています！！！\n              </div>\n            </div>\t\t\t\n\n            <!-- 一覧に戻るボタン -->\n            <div class=\"text-center mt-5\">\n                <a href=\"index.html\" class=\"button button-large button-rounded\" style=\"background-color: #77C345;\">一覧に戻る</a>\n            </div>\n\n        </div>\n    </section>\n    <!-- ▲▲▲ ここまで ▲▲▲ -->\n<!-- 2025.12.09 h.tabi ここまで-->\n\n  \n  <!-- Footer\n\t\t============================================= -->\n    <footer id=\"footer\" class=\"bg_lgreen border-0 pt-5\">\n        <div class=\"container clearfix\">\n            <div class=\"mb-3 text-center\"> <img src=\"../../images/logo_w.png\" srcset=\"../../images/logo_w.png 1x, ../images/logo_w@2x.png 2x\" alt=\"Canvas\"> </div>\n            <div class=\"col-12 text-center\"> <a href=\"../../contents/06_contact.html\">お問い合わせ</a> ｜         <a href=\"../../data/file.php?sitepolicy\" target=\"_blank\">サイトポリシー</a> ｜ \n                <a href=\"../../data/file.php?privacypolicy\" target=\"_blank\">個人情報保護方針</a> ｜ \n                <a href=\"../../data/file.php?securitypolicy\" target=\"_blank\">情報セキュリティ基本方針</a>  </div>\n        </div>\n    \n    <!-- Copyrights\n\t\t\t============================================= -->\n    <div id=\"copyrights\" style=\"background-color: #77C345;\">\n      <div class=\"container clearfix\">\n        <div class=\"row justify-content-between align-items-center\">\n          <div class=\"col-md-12 text-center\"> &copy; 藤村薬品株式会社 </div>\n        </div>\n      </div>\n    </div>\n    <!-- #copyrights end --> \n    \n  </footer>\n  <!-- #footer end --> \n  \n</div>\n<!-- #wrapper end --> \n\n<!-- Go To Top\n\t============================================= -->\n<div id=\"gotoTop\" class=\"icon-angle-up\"></div>\n\n<!-- JavaScripts\n\t============================================= --> \n<script src=\"../../js/jquery.js\"></script> \n<script src=\"../../js/plugins.min.js\"></script> \n<script src=\"../../js/jquery.calendario.js\"></script> \n\n<!-- Footer Scripts\n\t============================================= --> \n<script src=\"../../js/functions.js\"></script>\n</body>\n</html>","finalUrl":"https://www.fujimurayakuhin.jp/recruit/voice/customer_sm.html","rendered":false,"_cachedAt":"2026-06-23T22:20:16.387Z"}