{"url":"https://www.tis-web.co.jp/recruit/bs_eco.html","html":"<!DOCTYPE html>\n<html lang=\"ja\" prefix=\"og: http://ogp.me/ns#\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta content=\"IE=edge\" http-equiv=\"X-UA-Compatible\">\n    <meta content=\"initial-scale=1,width=device-width\" name=\"viewport\">\n    <title>株式会社ティ・アイ・エス新卒採用</title>\n    <link href=\"#\" rel=\"canonical\">\n    <meta content=\"株式会社ティ・アイ・エスの採用特設サイトです。福岡・佐賀を拠点に産業機械製作のFA事業、太陽光発電システム販売・メンテナンスの太陽光事業、機器の導入支援・メンテナンスのサービス事業を行っている企業です。\" name=\"description\">\n    <meta content=\"ja_JP\" property=\"og:locale\">\n    <meta content=\"株式会社ティ・アイ・エス新卒採用\" property=\"og:site_name\">\n    <meta content=\"株式会社ティ・アイ・エス新卒採用\" property=\"og:title\">\n    <meta content=\"website\" property=\"og:type\">\n    <meta content=\"#\" property=\"og:url\">\n    <meta content=\"assets/images/ogimage.jpg\" property=\"og:image\">\n    <meta content=\"株式会社ティ・アイ・エスの採用特設サイトです。福岡・佐賀を拠点に産業機械製作のFA事業、太陽光発電システム販売・メンテナンスの太陽光事業、機器の導入支援・メンテナンスのサービス事業を行っている企業です。\" property=\"og:description\">\n    <meta content=\"summary_large_image\" name=\"twitter:card\">\n    <meta content=\"株式会社ティ・アイ・エス新卒採用\" name=\"twitter:title\">\n    <meta content=\"株式会社ティ・アイ・エスの採用特設サイトです。福岡・佐賀を拠点に産業機械製作のFA事業、太陽光発電システム販売・メンテナンスの太陽光事業、機器の導入支援・メンテナンスのサービス事業を行っている企業です。\" name=\"twitter:description\">\n    <meta content=\"assets/images/ogimage.jpg\" name=\"twitter:image\">\n    <link href=\"assets/css/style.css\" rel=\"stylesheet\">\n    <script src=\"https://ajax.googleapis.com/ajax/libs/jquery/2.2.4/jquery.min.js\"></script>\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n    <link href=\"https://fonts.googleapis.com/css2?family=Azeret+Mono:wght@700&family=Rubik+Mono+One&display=swap\" rel=\"stylesheet\">\n    <link rel=\"apple-touch-icon\" sizes=\"180x180\" href=\"assets/images/icon/apple-touch-icon.png\">\n    <link rel=\"icon\" type=\"image/png\" sizes=\"32x32\" href=\"assets/images/icon/favicon-32x32.png\">\n    <link rel=\"icon\" type=\"image/png\" sizes=\"16x16\" href=\"assets/images/icon/favicon-16x16.png\">\n    <link rel=\"manifest\" href=\"assets/images/icon/site.webmanifest.txt\">\n    <link rel=\"mask-icon\" href=\"assets/images/icon/safari-pinned-tab.svg\" color=\"#615ea8\">\n    <meta name=\"msapplication-TileColor\" content=\"#615ea8\">\n    <meta name=\"theme-color\" content=\"#ffffff\">\n</head>\n<body id=\"top\">\n\n<div class=\"bs_eco page-bs\">\n\n  <header class=\"header add-scrolled add-reverse\" id=\"header\">\n    <div class=\"header-inner\">\n\n        <div class=\"header-ttl\">\n            <a class=\"header-ttlLink\" href=\"index.html\"><img src=\"assets/images/tis_logo.png\"><span>Recruit Site</span></a>\n        </div>\n\n        <nav class=\"header-nav\">\n            <button class=\"header-closeButton\" id=\"js-header_closeBtn\" type=\"button\">\n                <span></span>\n                <span></span>\n            </button>\n            <ul class=\"header-list\">\n                <li class=\"header-item\">\n                    <div class=\"header-item_ttl\"><a class=\"header-itemLink-top js-unlink\" href=\"index.html#mission\">ビジョン</a></div>\n                </li>\n                <li class=\"header-item\">\n                    <div class=\"header-item_ttl\"><a class=\"header-itemLink-top js-unlink\" href=\"index.html#message\">メッセージ</a></div>\n                </li>\n                <li class=\"header-item\">\n                    <div class=\"header-item_ttl\"><a class=\"header-itemLink-top js-unlink\" href=\"index.html#business\">事業内容</a></div>\n                </li>\n                <li class=\"header-item\">\n                    <div class=\"header-item_ttl\"><a class=\"header-itemLink-top js-unlink\" href=\"index.html#interview\">社員インタビュー</a></div>\n                </li>\n                <li class=\"header-item\">\n                    <div class=\"header-item_ttl\"><a class=\"header-itemLink-top js-unlink\" href=\"index.html#culture\">TISの文化</a></div>\n                </li>\n                <li class=\"header-item\">\n                    <div class=\"header-item_ttl\"><a class=\"header-itemLink-top js-unlink\" href=\"index.html#company\">会社概要</a></div>\n                </li>\n                <li class=\"header-item\">\n                    <div class=\"header-item_ttl\"><a class=\"header-itemLink-top js-unlink\" href=\"recruit.html\">採用情報</a></div>\n                </li>\n                <li class=\"header-btnarea\">\n                    <a class=\"header-entry\" href=\"entry.html\" ><img src=\"assets/images/entry.svg\" alt=\"\"><tspan>エントリー</tspan>\n                    </a>\n                </li>\n            </ul>\n        </nav>\n    </div>\n    <button class=\"header-navButton\" id=\"js-header_toggleBtn\" type=\"button\">\n        <span class=\"header-toggleBtn\">\n            <span></span>\n            <span></span>\n            <span></span>\n        </span>\n        <span class=\"header-toggleBtn-txt\">メニュー</span>\n    </button>\n    <a class=\"header-entryButton\" href=\"entry.html\" >\n        <img src=\"assets/images/entry.svg\"><tspan>エントリー</tspan></a>\n    <div class=\"header-bg js-headerBg\" id=\"js-headerBg\"></div>\n  </header>\t\n  <main class=\"project-container mod-crosstalk\">\n        <div class=\"project-boxKv js-kvImage\">\n          <div class=\"project-boxKvInner\">\n            <h1 class=\"project-boxKvTtl js-inView rise add-inView\">\n              <span class=\"project-boxKvTtl-tag\">Eco System</span>\n              <span class=\"project-boxKvTtl-ttl\">エコシステム事業部</span>\n            </h1>\n          </div>\n        </div>\n        <section class=\"project\">\n          <div class=\"project-index-wrap js-inView rise add-inView\">\n            <div class=\"project-index-wrap__inner\">\n              <p class=\"project-flow-case\">仕事の内容 </p>\n              <p class=\"team-feature__desc\">九州北部（福岡・佐賀・長崎（一部）・熊本（一部））を中心に<br class=\"sp-hidden\">地場のハウスメーカー様と連携して住宅用太陽光発電システム及び<br class=\"sp-hidden\">蓄電システムの提案から施工までを一貫して行っております。</p>\n              <p class=\"team-feature__desc\">2002年より動き始めた事業ですが、施工実績は2021年度時点で3000件を超えました。</p>\n              <p class=\"team-feature__desc\">国内外の様々なメーカーの製品を取り扱っており<br class=\"sp-hidden\">近年多様化しているお客様それぞれの希望に沿ったシステムを<br class=\"sp-hidden\">ご提案できるよう日々取り組んでいます。</p><p class=\"team-feature__desc mb60\">部署は、新規取引先開拓やお客様への提案や見積作成、お引き渡し時の説明等を行う営業課、<br class=\"sp-hidden\">現地の調査や実際の施工を担う工事課、電力会社や経産省への申請、<br class=\"sp-hidden\">部材等の手配・受入を行う業務課で構成されています。</p>\n              <p class=\"project-flow-case\">仕事の流れ </p>\n              <ul class=\"project-flow-wrapper clearfix\">\n                <li class=\"project-flow-wrapper__item\">\n                  <span class=\"project-flow-wrapper__item__time project-flow-wrapper__item__time--blue\">営業活動</span>\n                  <h3 class=\"project-flow-wrapper__item__title\"> 営業</h3>\n                  <p class=\"project-flow-wrapper__item__text\"> 新たに取引先候補となる工務店様への提案を行います。太陽光や蓄電システム導入のメリットやティ・アイ・エスの強みを説明しながら営業活動を行います。</p>\n                </li>\n                <li class=\"project-flow-wrapper__item project-flow-wrapper__item--mt01\"> <span class=\"project-flow-wrapper__item__time\">提案活動</span>\n                  <h3 class=\"project-flow-wrapper__item__title\"> 見積作成、営業 </h3>\n                  <p class=\"project-flow-wrapper__item__text\"> 取引先の工務店様で家を建てる方を対象に太陽光の提案を行います。昨今は蓄電池やV2Hといった発電した電気を利用する商材の需要も高まっています。</p>\n                </li>\n                <li class=\"project-flow-wrapper__item \"> <span class=\"project-flow-wrapper__item__time\">受注</span>\n                  <h3 class=\"project-flow-wrapper__item__title\"> 機器位置確認 </h3>\n                  <p class=\"project-flow-wrapper__item__text\"> 住宅の図面を基に太陽光設置機器を打ち合わせします。お客様の希望や立地、住宅機器の位置などを考慮します。</p>\n                </li>\n                <li class=\"project-flow-wrapper__item project-flow-wrapper__item--mt02\"> <span class=\"project-flow-wrapper__item__time\">現場調査</span>\n                  <h3 class=\"project-flow-wrapper__item__title\"> 現場調査、部材発注 </h3>\n                  <p class=\"project-flow-wrapper__item__text\"> 新築の現場や屋根の確認を行います。お見積時点の条件と相違なければ部材の発注を行います。</p>\n                </li>\n                <li class=\"project-flow-wrapper__item project-flow-wrapper__item--mt02\"> <span class=\"project-flow-wrapper__item__time\">電力会社申請</span>\n                  <h3 class=\"project-flow-wrapper__item__title\"> 太陽光電力申請 </h3>\n                  <p class=\"project-flow-wrapper__item__text\"> 家の電気の申込書をもとに管轄の電力会社へ太陽光設置の申込を行います。申請は専用サイトから行います。</p>\n                </li>\n                <li class=\"project-flow-wrapper__item\"> <span class=\"project-flow-wrapper__item__time\">配線工事</span>\n                  <h3 class=\"project-flow-wrapper__item__title\"> 太陽光配線工事 </h3>\n                  <p class=\"project-flow-wrapper__item__text\"> 太陽光用のケーブルを屋根裏に隠れる位置に通します。まだ住宅の壁や天井がないタイミングで行います。</p>\n                </li>\n                <li class=\"project-flow-wrapper__item\"> <span class=\"project-flow-wrapper__item__time\">パネル工事</span>\n                  <h3 class=\"project-flow-wrapper__item__title\"> パネル設置工事 </h3>\n                  <p class=\"project-flow-wrapper__item__text\"> 住宅の外から見える部分（壁・屋根など）の工事終盤に太陽光パネルを屋根に設置します。作業は安全のため必ず足場を設置して行います。 </p>\n                </li>\n                <li class=\"project-flow-wrapper__item\"> <span class=\"project-flow-wrapper__item__time\">経産省事業申請</span>\n                  <h3 class=\"project-flow-wrapper__item__title\"> 経産省事業申請 </h3>\n                  <p class=\"project-flow-wrapper__item__text\"> 電力会社へ申請した内容が承諾され次第、経済産業省への申込を行います。申請は専用サイトから行います。 </p>\n                </li>\n                <li class=\"project-flow-wrapper__item\"> <span class=\"project-flow-wrapper__item__time\">仕上工事</span>\n                  <h3 class=\"project-flow-wrapper__item__title\"> 太陽光仕上工事 </h3>\n                  <p class=\"project-flow-wrapper__item__text\"> 住宅の内装が完成、家の分電盤が設置されたタイミングで太陽光機器の取付を行います。</p>\n                </li>\n                <li class=\"project-flow-wrapper__item\"> <span class=\"project-flow-wrapper__item__time\">試運転</span>\n                  <h3 class=\"project-flow-wrapper__item__title\"> 試運転 </h3>\n                  <p class=\"project-flow-wrapper__item__text\"> 工事完了後、太陽光機器の試運転・設定作業を行います。</p>\n                </li>\n                <li class=\"project-flow-wrapper__item\"> <span class=\"project-flow-wrapper__item__time project-flow-wrapper__item__time--blue\">取扱説明</span>\n                  <h3 class=\"project-flow-wrapper__item__title\"> 太陽光連系開始 </h3>\n                  <p class=\"project-flow-wrapper__item__text\"> 住宅の引き渡しに合わせて訪問し、太陽光機器の使用方法を説明します。取扱説明完了後、電力会社へ連系（余った電気を売る状態）開始の連絡、メーカーへの保証申請を行います。</p>\n                </li>\n              </ul>\n            </div>\n          </div>\n        </section>\n      \n    <section class=\"entryBtn\">\n      <div class=\"personal-carousel-boxBtn\">\n      <a class=\"common-btn\" href=\"recruit.html\"><span>採用情報を見る</span></a>\n      </div>    \n    </section>\n  </main>\n</div>\n<footer class=\"footer\" id=\"js-footer\">\n  <div class=\"pagetop\">\n      <a href=\"#top\"><span><small>PAGE TOP</small></span></a>\n  </div>\n<div class=\"footer-inner\">\n  <ul class=\"footer-list\">\n    <li class=\"footer-item\">\n      <dl class=\"footer-boxList\">\n        <dt class=\"footer-boxItem_ttl\"><a class=\"footer-itemLink\" href=\"index.html#mission\">ビジョン</a></dt>\n      </dl>\n    </li>\n    <li class=\"footer-item\">\n      <dl class=\"footer-boxList\">\n        <dt class=\"footer-boxItem_ttl\"><a class=\"footer-itemLink\" href=\"index.html#message\">メッセージ</a></dt>\n      </dl>\n    </li>\n    <li class=\"footer-item\">\n      <dl class=\"footer-boxList\">\n        <dt class=\"footer-boxItem_ttl\"><a class=\"footer-itemLink\" href=\"index.html#business\">事業内容</a>\n        </dt>\n        <dd class=\"footer-boxItem\">\n          <a class=\"footer-boxItemLink\" href=\"bs_fa.html\">FA事業の仕事</a>\n        </dd>\n        <dd class=\"footer-boxItem\">\n          <a class=\"footer-boxItemLink\" href=\"bs_ser.html\">サービス事業の仕事</a>\n        </dd>\n        <dd class=\"footer-boxItem\">\n          <a class=\"footer-boxItemLink\" href=\"bs_eco.html\">エコシステム事業の仕事</a>\n        </dd>\n      </dl>\n    </li>\n    <li class=\"footer-item\">\n      <dl class=\"footer-boxList\">\n        <dt class=\"footer-boxItem_ttl\"><a class=\"footer-itemLink\" href=\"index.html#interview\">社員インタビュー</a></dt>\n        <dd class=\"footer-boxItem\">\n          <a class=\"footer-boxItemLink\" href=\"crosstalk.html\">若手クロストーク</a>\n        </dd>\n      </dl>\n    </li>\n    <li class=\"footer-item\">\n      <dl class=\"footer-boxList\">\n        <dt class=\"footer-boxItem_ttl\"><a class=\"footer-itemLink\" href=\"index.html#culture\">TISの文化</a></dt>\n      </dl>\n    </li>\n    <li class=\"footer-item\">\n      <dl class=\"footer-boxList\">\n        <dt class=\"footer-boxItem_ttl\"><a class=\"footer-itemLink\" href=\"index.html#company\">会社概要</a></dt>\n      </dl>\n    </li>\n          <li class=\"footer-item\">\n      <div class=\"footer-boxList\">\n        <div class=\"footer-boxItem_ttl\"><a class=\"footer-itemLink\" href=\"recruit.html\">採用情報</a></div>\n      </div>\n      <div class=\"footer-boxList\">\n        <div class=\"footer-boxItem_ttl\"><a class=\"footer-itemLink\" href=\"https://www.tis-web.co.jp/\" target=\"_blank\">コーポレートサイト</a></div>\n      </div>\n    </li>\n  </ul>\n  <div class=\"footer_logo\">\n    <a class=\"footer_logoLink\" href=\"https://www.tis-web.co.jp/\" target=\"_blank\">\n      <img alt=\"株式会社ティ・アイ・エス\" src=\"assets/images/tis_logo.png\" class=\"footer_logoImg\">\n    </a>\n  </div>\n  <p class=\"footer_copyright\">Copyright © Technical Information Service Co.,LTD</p>\n</div>\n</footer>\n<script src=\"assets/js/common.js\"></script>\n</body>\n</html>","finalUrl":"https://www.tis-web.co.jp/recruit/bs_eco.html","rendered":false,"_cachedAt":"2026-06-22T18:56:01.735Z"}