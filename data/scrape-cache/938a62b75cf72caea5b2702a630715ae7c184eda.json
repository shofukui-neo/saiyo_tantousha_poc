#000080;\r\n}\r\n.arrow_link::after{\r\n    left: 6px;\r\n    width: 8px;\r\n    height: 8px;\r\n    border-top: 3px solid #fff;\r\n    border-right: 3px solid #fff;\r\n    -webkit-transform: rotate(45deg);\r\n    transform: rotate(45deg);\r\n}\r\n</style>\r\n<div class=\"article-header\">\r\n<div class=\"article-header__summary\">\r\n<p>「岐阜新聞デジタルに過去に掲載された記事を読みたい」そんなあなたに。<br />\r\n無料で簡単会員登録！過去１年間に岐阜新聞デジタルで掲載された記事を閲覧できるようになります。<br />\r\n岐阜新聞読者の方は追加料金なしで、岐阜新聞デジタル上で朝刊記事を読むことができます。<br />\r\n岐阜新聞デジタルをもっと便利に！快適に！</p>\r\n</div>\r\n</div>\r\n\r\n<div class=\"member-course l-inner\">\r\n<table class=\"member-course__table\">\r\n\t<tbody>\r\n\t\t<tr>\r\n\t\t\t<th>　</th>\r\n\t\t\t<th><span style=\"font-size:16px;\">デジタルプラン<br />\r\n\t\t\t月額1,980円（税込）</span><br />\r\n\t\t\t<span class=\"cta-wrapper\"><a class=\"c-btn --registration-cta\" href=\"/auth/preregistration\">お申し込み</a> </span></th>\r\n\t\t\t<th><span style=\"font-size:16px;\">宅配＋デジタルプラン<br />\r\n\t\t\t（新聞購読料のみで追加料金なし）</span><br />\r\n\t\t\t<span class=\"cta-wrapper\"><a class=\"c-btn --registration-cta\" href=\"/auth/preregistration\">お申し込み</a> </span></th>\r\n\t\t\t<th><span style=\"font-size:16px;\">無料会員</span><br />\r\n\t\t\t<br />\r\n\t\t\t<span class=\"cta-wrapper\"><a class=\"c-btn --registration-cta\" href=\"/auth/preregistration\">お申し込み</a> </span></th>\r\n\t\t</tr>\r\n\t\t<tr>\r\n\t\t\t<td><a href=\"https://www.gifu-np.co.jp/\" target=\"_blank\"><strong>①速報・ピックアップ記事<br />\r\n\t\t\t（非会員は7日間）</strong></a><span class=\"arrow arrow_link\">&nbsp;</span></td>\r\n\t\t\t<td><span style=\"font-size:20px;\"><strong>無期限</strong></span></td>\r\n\t\t\t<td><span style=\"font-size:20px;\"><strong>無期限</strong></span></td>\r\n\t\t\t<td><span style=\"font-size:20px;\"><strong>一定の期間（365日）</strong></span></td>\r\n\t\t</tr>\r\n\t\t<tr>\r\n\t\t\t<td><a href=\"https://www.gifu-np.co.jp/list/show-paper\" target=\"_blank\"><strong>②岐阜新聞朝刊掲載の記事全量</strong></a><span class=\"arrow arrow_link\">&nbsp;</span></td>\r\n\t\t\t<td><span style=\