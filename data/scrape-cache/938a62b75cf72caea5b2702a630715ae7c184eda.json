-np.co.jp/subcategory/訃報\" target=\"_blank\"><strong>⑦訃報・おくやみ</strong></a><span class=\"arrow arrow_link\">&nbsp;</span></td>\r\n\t\t\t<td><span style=\"font-size:20px;\"><strong>○</strong></span></td>\r\n\t\t\t<td><span style=\"font-size:20px;\"><strong>○</strong></span></td>\r\n\t\t\t<td><span style=\"font-size:20px;\"><strong>&times;</strong></span></td>\r\n\t\t</tr>\r\n\t\t<tr>\r\n\t\t\t<td><strong>⑧ニュースレター</strong><span class=\"arrow arrow_link\">&nbsp;</span></td>\r\n\t\t\t<td><span style=\"font-size:20px;\"><strong>○</strong></span></td>\r\n\t\t\t<td><span style=\"font-size:20px;\"><strong>○</strong></span></td>\r\n\t\t\t<td><span style=\"font-size:20px;\"><strong>○</strong></span></td>\r\n\t\t</tr>\r\n\t\t<tr>\r\n\t\t\t<td><a href=\"https://www.gifu-np.co.jp/list/company/koudoku\" target=\"_blank\"><strong>⑨岐阜新聞朝刊</strong></a><span class=\"arrow arrow_link\">&nbsp;</span></td>\r\n\t\t\t<td><span style=\"font-size:20px;\"><strong>&times;</strong></span></td>\r\n\t\t\t<td><span style=\"font-size:20px;\"><strong>○</strong></span></td>\r\n\t\t\t<td><span style=\"font-size:20px;\"><strong>&times;</strong></span></td>\r\n\t\t</tr>\r\n\t</tbody>\r\n</table>\r\n\r\n<ul>\r\n\t<li>※表示価格は税込</li>\r\n\t<li>※「宅配＋デジタルプラン」は岐阜新聞朝刊を購読されている方が対象</li>\r\n\t<li>※会員登録をしなくても岐阜新聞デジタルの一部コンテンツを閲覧できます</li>\r\n\t<li>※お支払い方法はクレジットカード、各キャリア決済（d払い、auかんたん決済、ソフトバンクまとめて支払い）が利用できます</li>\r\n\t<li><span style=\"color:#FF0000;\">※「宅配＋デジタルプラン」からデジタルプランへの切り替えを希望される場合は、まず新聞をお配りしている販売店にご相談ください</span></li>\r\n</ul>\r\n</div>\r\n\r\n<div class=\"member-regist\"><a class=\"member-regist__link\" href=\"/list/denshi/top\"><b>紙面ビューアの紹介はこちら</b></a></div>\r\n\r\n<div class=\"member-service\">\r\n<h2 class=\"article-header__heading\">サービス紹介</h2>\r\n\r\n<div class=\"l-inner\">\r\n<div class=\"member-service__detail\">\r\n<div class=\"member-service__title\"><span class=\"num\">1</span><a href=\"https://www.gifu-np.co.jp/\"><span style=\"color:#FFFFFF;\">速報・ピックアップ記事</span></a></div>\r\n\r\n<div class=\"member-service__text\">\r\n<p>毎日更新する岐阜のニュースや一部特集コーナーの記事です。※岐阜のニュース「事件・事故」カテゴリは30日間</p>\r\n\r\n<center>\r\n<figure class=\"image-area figure-center\" style=\"width:200px;\"><img alt=\"\" class=\"main-image\" src=\"/mwimgs/0/4/-/img_04de6622fb96b8ffdd3faba209295f8c169094.png\" /></figure>\r\n</center>\r\n</div>\r\n</div>\r\n\r\n<div class=\"member-service__detail\">\r\n<div class=\"member-service__title\"><span class=\"num\">2</span><a href=\"https://www.gifu-np.co.jp/list/show-paper\"><span style=\"color:#FFFFFF;\">岐阜新聞朝刊掲載の記事全量</span></a></div>\r\n\r\n<div class=\"member-service__text\">\r\n<p>岐阜新聞朝刊に掲載された記事を岐阜新聞デジタル内で読むことができます。</p>\r\n\r\n<center>\r\n<figure class=\"image-area figure-center\" style=\"width:200px;\"><img alt=\"\" class=\"main-image\" src=\"/mwimgs/0/4/-/img_0427383c494999ab8807de043c4264e5409782.png\" /></figure>\r\n</center>\r\n</div>\r\n</div>\r\n\r\n<div class=\"member-service__detail\">\r\n<div class=\"member-service__title\"><span class=\"num\">3</span><a href=\"https://www.gifu-np.co.jp/list/premium\"><span style=\"color:#FFFFFF;\">岐阜新聞デジタルオリジナル記事（デジオリ！）</span></a></div>\r\n\r\n<div class=\"member-service__text\">\r\n<p>デジオリ！（デジタルオンリー）は岐阜新聞デジタルオリジナルの会員限定コンテンツです。</p>\r\n\r\n<center>\r\n<figure class=\"image-area figure-center\" style=\"width:200px;\"><img alt=\"\" class=\"main-image\" src=\"/mwimgs/c/3/-/img_c3dbd289cb972d9a817a124debcb1f0a410691.png\" /></figure>\r\n</center>\r\n</div>\r\n</div>\r\n\r\n<div class=\"member-service__detail\">\r\n<div class=\"member-service__title\"><span class=\"num\">4</span><a href=\"https://viewer2.gifu-np.co.jp/NAViH_S/\"><span style=\"color:#FFFFFF;\">紙面ビューア</span></a></div>\r\n\r\n<div class=\"member-service__text\">\r\n<p>岐阜新聞朝刊の紙面イメージを見ることができます。</p>\r\n\r\n<center>\r\n<figure class=\"image-area figure-center\" style=\"width:200px;\"><img alt=\"\" class=\"main-image\" src=\"/mwimgs/9/f/-/img_9ff25ba3b0fa159b614d73e3b4897522514182.png\" /></figure>\r\n</center>\r\n</div>\r\n</div>\r\n\r\n<div class=\"member-service__detail\">\r\n<div class=\"member-service__title\"><span class=\"num\">5</span><a href=\"https://www.gifu-np.co.jp/articles/-/611846\"><span style=\"color:#FFFFFF;\">チケットの先行販売</span></a></div>\r\n\r\n<div class=\"member-service__text\">\r\n<p>岐阜新聞社が主催するコンサート等のチケットを一般発売に先駆けて購入できるサービスです。</p>\r\n\r\n<center>\r\n<figure class=\"image-area figure-center\" style=\"width:200px;\"><img alt=\"\" class=\"main-image\" src=\"/mwimgs/d/5/-/img_d54a7859e89b612f17f07ca379612d74501022.png\" /></figure>\r\n</center>\r\n</div>\r\n</div>\r\n\r\n<div class=\"member-service__detail\">\r\n<div class=\"member-service__title\"><span class=\"num\">6</span><a href=\"https://www.gifu-np.co.jp/list/coupon\"><span style=\"color:#FFFFFF;\">お得なクーポン</span></a></div>\r\n\r\n<div class=\"member-service__text\">\r\n<p>「宅配＋デジタルプラン」「デジタルプラン」の会員が利用できるお得なクーポンです。100店舗以上掲載。</p>\r\n\r\n<center>\r\n<figure class=\"image-area figure-center\" style=\"width:200px;\"><img alt=\"\" class=\"main-image\" src=\"/mwimgs/8/a/-/img_8a2d8b272b5aa18b1a915b29d0db77cc507283.png\" /></figure>\r\n</center>\r\n</div>\r\n</div>\r\n\r\n<div class=\"member-service__detail\">\r\n<div class=\"member-service__title\"><span class=\"num\">7</span><a href=\"https://www.gifu-np.co.jp/subcategory/%E8%A8%83%E5%A0%B1\"><span style=\"color:#FFFFFF;\">訃報・おくやみ</span></a></div>\r\n\r\n<div class=\"member-service__text\">\r\n<p>岐阜県内のおくやみ情報を掲載しています。</p>\r\n\r\n<center>\r\n<figure class=\"image-area figure-center\" style=\"width:200px;\"><img alt=\"\" class=\"main-image\" src=\"/mwimgs/2/b/-/img_2bb2b2ec0a9dd69f82eebd29e04dc728622927.png\" /></figure>\r\n</center>\r\n</div>\r\n</div>\r\n\r\n<div class=\"member-service__detail\">\r\n<div class=\"member-service__title\"><span class=\"num\">8</span>ニュースレター</div>\r\n\r\n<div class=\"member-service__text\">\r\n<p>岐阜に関する知っておきたい新着情報を月～金曜日（平日）の正午をめどに１回メールで配信します。</p>\r\n\r\n<center>\r\n<figure class=\"image-area figure-center\" style=\"width:200px;\"><img alt=\"\" class=\"main-image\" src=\"/mwimgs/7/9/-/img_79544da41fe908316b2aa722f4cff7b3531057.png\" /></figure>\r\n</center>\r\n</div>\r\n</div>\r\n\r\n<div class=\"member-service__detail\">\r\n<div class=\"member-service__title\"><span class=\"num\">9</span><a href=\"https://www.gifu-np.co.jp/list/company/koudoku\"><span style=\"color:#FFFFFF;\">岐阜新聞朝刊</span></a></div>\r\n\r\n<div class=\"member-service__text\">\r\n<p>紙の岐阜新聞朝刊をご購読いただけます。</p>\r\n\r\n<center>\r\n<figure class=\"image-area figure-center\" style=\"width:200px;\"><img alt=\"\" class=\"main-image\" src=\"/mwimgs/0/2/-/img_022cbb947a3aecf5404e0b850845583f491167.png\" /></figure>\r\n</center>\r\n</div>\r\n</div>\r\n</div>\r\n\r\n<h2 class=\"article-header__heading\">プラン紹介</h2>\r\n\r\n<div class=\"member-information__lead\">こんな人におすすめです！</div>\r\n\r\n<div class=\"member-information__list\">\r\n<div class=\"member-information__item\">\r\n<div class=\"member-information__title\">無料会員</div>\r\n\r\n<div class=\"member-information__text\">・料金：無料<br />\r\n記事の閲覧期間が7日では少なすぎる！１年前の記事も読みたい。</div>\r\n</div>\r\n\r\n<div class=\"member-information__item\">\r\n<div class=\"member-information__title\">デジタルプラン</div>\r\n\r\n<div class=\"member-information__text\">・月額1,980円（税込）<br />\r\n紙もいいけど古新聞の処分が大変！&hellip;でも外出先で手軽に岐阜新聞が読みたい！</div>\r\n</div>\r\n\r\n<div class=\"member-information__item\">\r\n<div class=\"member-information__title\">宅配＋デジタルプラン</div>\r\n\r\n<div class=\"member-information__text\">・新聞購読料のみで追加料金なし<br />\r\n紙の新聞も岐阜新聞デジタルも紙面ビューアも全部使いたい！</div>\r\n</div>\r\n</div>\r\n</div>\r\n\r\n<div class=\"member-regist\"><a class=\"member-regist__link\" href=\"/auth/preregistration\">まずは無料登録！</a></div>\r\n\n</div>    </main>\n  </div>\n<footer class=\"m-footer overlay-none\">\n  <div class=\"m-footer-bottom\">\n    <div class=\"l-inner m-footer-bottom__wrap\">\n      <div class=\"m-footer-bottom__logo\"><img src=\"https://gifu-np.ismcdn.jp/common/images/site/footer-logo_2022.png\" alt=\"岐阜新聞社\"></div>\n      <div class=\"m-footer-bottom__text\">\n        <div class=\"m-foo