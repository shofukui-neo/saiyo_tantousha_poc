{"url":"http://www.ise-ics.co.jp/recruit","html":"<!DOCTYPE html>\r\n<html lang=\"ja\">\r\n<head prefix=og: http://ogp.me/ns# fb: http://ogp.me/ns/fb# article: http://ogp.me/ns/article#>\r\n    <meta charset=\"UTF-8\"/>\r\n  <meta property=\"og:type\" content=\"article\"/>\r\n  <meta property=\"og:title\" content=\"採用情報 - システムエンジニア・プログラマー募集（三重県伊勢市）｜株式会社アイ・シー・エス\"/>\r\n  <meta property=\"og:url\" content=\"http://www.ise-ics.co.jp/recruit/\"/>\r\n  <meta property=\"og:description\" content=\"三重県伊勢市に本社を構える、製造業の現場を支えるシステム開発会社・株式会社アイ・シー・エスの採用情報。組込・制御システム開発に携わるシステムエンジニア(プログラマー)や営業職を募集しています。新卒・中途採用の募集要項や仕事内容、働く環境、社員インタビューをご紹介します。\"/>\r\n  <meta property=\"og:site_name\" content=\"採用情報 - システムエンジニア・プログラマー募集（三重県伊勢市）｜株式会社アイ・シー・エス\"/>\r\n  <meta property=\"og:image\" content=\"https://www.ise-ics.co.jp/img/common/screenshot.jpg\"/>\r\n  <meta property=\"og:locale\" content=\"ja_JP\">\r\n  <meta name=\"twitter:card\" content=\"summary_large_image\"/>\r\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1, shrink-to-fit=no\"/>\r\n  <meta name=\"format-detection\" content=\"telephone=no\">\r\n  <meta name=\"description\" content=\"三重県伊勢市に本社を構える、製造業の現場を支えるシステム開発会社・株式会社アイ・シー・エスの採用情報。組込・制御システム開発に携わるシステムエンジニア(プログラマー)や営業職を募集しています。新卒・中途採用の募集要項や仕事内容、働く環境、社員インタビューをご紹介します。\"/>\r\n  <meta name=\"robots\" content=\"noindex\">  <link rel=\"icon\" href=\"../img/favicon.ico\">\r\n  <title>採用情報 - システムエンジニア・プログラマー募集（三重県伊勢市）｜株式会社アイ・シー・エス</title>\r\n\r\n  <link href=\"./assets/css/default.css\" rel=\"stylesheet\" type=\"text/css\"/><link href=\"./assets/css/home.css\" rel=\"stylesheet\" type=\"text/css\"/><link href=\"./assets/top_interview-slider/style.css\" rel=\"stylesheet\" type=\"text/css\"/><link href=\"https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700&display=swap\" rel=\"preload\" as=\"style\"/><link href=\"https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700&display=swap\" rel=\"stylesheet\" media=\"print\" onload=\"this.media='all'\"/><script type=\"text/javascript\" src=\"https://code.jquery.com/jquery-3.4.1.min.js\"></script><script type=\"text/javascript\" src=\"./assets/js/default.js\"></script><script type=\"text/javascript\" src=\"./assets/js/slider.js\"></script><script type=\"text/javascript\" src=\"./assets/js/slick.min.js\"></script><script type=\"text/javascript\" src=\"./assets/top_interview-slider/script.js\"></script>  <script>console.log(\"ICS Web Site Loaded.\");</script>\r\n</head>\r\n\r\n<body>\r\n    \r\n<div class=\"c-header__msg\">製造業の現場課題を、システムで解決する会社です。</div>\r\n<header class=\"c-header js-header\">\r\n  <div class=\"c-header__inner\">\r\n\r\n        <a class=\"c-header__logo\" href=\"./\"><img src=\"./img/logo.svg\" alt=\"株式会社アイ・シー・エス\"/></a>\r\n    \r\n            <nav class=\"c-header__nav _pc\">\r\n      <ul class=\"c-header__nav--list\">\r\n        <li class=\"c-header__nav--item\"><a href=\"./company\">会社を知る</a></li><li class=\"c-header__nav--item\"><a href=\"./work\">仕事を知る</a></li><li class=\"c-header__nav--item\"><a href=\"./people\">人を知る</a></li><li class=\"c-header__nav--item\"><a href=\"./environment\">働く環境を知る</a></li><li class=\"c-header__nav--item\"><a href=\"./positions\">募集要項</a></li>      </ul>\r\n    </nav>\r\n    \r\n        <div class=\"js-mobile-nav\">\r\n      <div class=\"c-header__drawer-btn js-drawer-btn\">\r\n        <input type=\"checkbox\" id=\"drawer-btn\" class=\"c-header__drawer-btn--input\"/>\r\n        <label class=\"c-header__drawer-btn--link\" for=\"drawer-btn\"><span class=\"c-header__drawer-btn--icon\"><span></span></span></label>\r\n      </div>\r\n      <nav class=\"c-header__nav _mobile\">\r\n        <div class=\"c-header__nav--headline\">\r\n          <a class=\"c-header__logo\" href=\"./\"><img src=\"./img/logo.svg\" alt=\"株式会社アイ・シー・エス\"/></a>\r\n        </div>\r\n                <ul class=\"c-header__nav--list\">\r\n          <li class=\"c-header__nav--item\"><a href=\"./company\">会社を知る</a></li><li class=\"c-header__nav--item\"><a href=\"./work\">仕事を知る</a></li><li class=\"c-header__nav--item\"><a href=\"./people\">人を知る</a></li><li class=\"c-header__nav--item\"><a href=\"./environment\">働く環境を知る</a></li><li class=\"c-header__nav--item\"><a href=\"./positions\">募集要項</a></li><li class=\"c-header__nav--item\"><a href=\"./news\">お知らせ</a></li><li class=\"c-header__nav--item\"><a href=\"./faq\">よくあるご質問</a></li>        </ul>\r\n              </nav>\r\n    </div>\r\n\r\n  </div>\r\n</header>\r\n\r\n<div class=\"b-wrap s-home-view\">\r\n<ul id=\"js-slider_home-view\" class=\"s-home-view__list\"><li class=\"s-home-view__item js-slider_item_0\"><img src=\"./img/home-slider/img_01.jpg\"/></li><li class=\"s-home-view__item js-slider_item_1 _hidden\"><img src=\"./img/home-slider/img_02.jpg\"/></li><li class=\"s-home-view__item js-slider_item_2 _hidden\"><img src=\"./img/home-slider/img_03.jpg\"/></li><li class=\"s-home-view__item js-slider_item_3 _hidden\"><img src=\"./img/home-slider/img_04.jpg\"/></li><li class=\"s-home-view__item js-slider_item_4 _hidden\"><img src=\"./img/home-slider/img_05.jpg\"/></li><li class=\"s-home-view__item js-slider_item_5 _hidden\"><img src=\"./img/home-slider/img_06.jpg\"/></li><li class=\"s-home-view__item js-slider_item_6 _hidden\"><img src=\"./img/home-slider/img_07.jpg\"/></li><li class=\"s-home-view__item js-slider_item_7 _hidden\"><img src=\"./img/home-slider/img_08.jpg\"/></li></ul>  <div class=\"s-home-view__catch\">\r\n    <div class=\"s-home-view__msg\">\r\n      <div class=\"s-home-view__msg-logo\"><img src=\"./img/home/catch.svg\" alt=\"日本のものづくりをITで支える\" loading=\"lazy\"/></div>\r\n      <!-- <div class=\"s-home-view__msg-main\">日本のものづくりを<br><strong>ITで支える</strong></div> -->\r\n      <div class=\"s-home-view__msg-sub\">製造現場の課題を、システムで解決する会社です。</div>\r\n    </div>\r\n  </div>\r\n</div>\r\n\r\n<div id=\"entry-sub\" class=\"b-wrap bg-theme\">\r\n  <div class=\"line-msg\">現在、システムエンジニア・営業職を募集しています</div>\r\n  <div class=\"b-inner\">\r\n    <ul class=\"cta-entry-btn__list\">\r\n      <li class=\"cta-entry-btn__item btn _arrow\"><a href=\"https://job.mynavi.jp/27/pc/search/corp60360/outline.html\" target=\"_blank\">27卒 新卒採用</a></li><li class=\"cta-entry-btn__item btn _arrow\"><a href=\"https://job.mynavi.jp/28/pc/search/corp60360/outline.html\" target=\"_blank\">28卒 インターン情報</a></li><li class=\"cta-entry-btn__item btn _arrow\"><a href=\"https://en-gage.net/ise-ics_saiyo1/\" target=\"_blank\">キャリア採用</a></li>    </ul>\r\n  </div>\r\n</div>\r\n\r\n<div id=\"msg\" class=\"b-wrap bg-white\">\r\n  <div class=\"b-inner b-container\">\r\n    <div class=\"top-msg__content\">\r\n      <div class=\"top-msg__headline\">\r\n        <div class=\"top-msg__label\">採用メッセージ</div>\r\n        <div class=\"top-msg__catch\"><img src=\"./img/home/message.svg\" loading=\"lazy\" alt=\"「できる」が増える、ひとつずつ。\"/></div>\r\n        <div class=\"top-msg__image\"><img src=\"./img/home/message.jpg\" loading=\"lazy\"/></div>\r\n      </div>\r\n      <div class=\"top-msg__dsc\">\r\n        私たちは、ITの力で日本のものづくりを支える<br>\r\n        システムを開発・提案しています。<br>\r\n        <br>\r\n        ふだんの生活では触れることのない技術や分野も多く、<br>\r\n        初めは「難しい」と感じるかもしれません。<br>\r\n        <br>\r\n        でも、最初は分からなくて当たり前です。<br>\r\n        <br>\r\n        アイ・シー・エスには<br>\r\n        現場での経験を積みながら、少しずつ「できる」を増やし、<br>\r\n        ひとりひとりのペースで成長していける環境があります。<br>\r\n        <br>\r\n        また、日々進化するIT技術にも触れながら<br>\r\n        現場で活かせる技術を身につけていきます。<br>\r\n        <br>\r\n        そうした積み重ねが、将来の力につながっていきます。\r\n      </div>\r\n    </div>\r\n  </div>\r\n</div>\r\n\r\n<div id=\"news\" class=\"b-wrap bg-pale _hr\">\r\n  <div class=\"b-inner\">\r\n    <div class=\"top-news__content\">\r\n      <div class=\"top-news__headline\"><span class=\"top-news__headline--icon\"><img src=\"./img/icon/menu_news.png\" loading=\"lazy\"/></span>お知らせ</div>\r\n      <ul class=\"top-news__list\">\r\n        \r\n              <li class=\"top-news__item\">\r\n                <a href=\"./news/?id=20260422_ 【会社説明会情報】姫路情報システム専門学校 学内企業説明会に出展します。\">\r\n                  <div class=\"top-news__date\">2026年4月22日</div>\r\n                  <div class=\"top-news__title\"> 【会社説明会情報】姫路情報システム専門学校 学内企業説明会に出展します。</div>\r\n                </a>\r\n              </li>\r\n            \r\n              <li class=\"top-news__item\">\r\n                <a href=\"./news/?id=20260420_初任給を改定しました。\">\r\n                  <div class=\"top-news__date\">2026年4月20日</div>\r\n                  <div class=\"top-news__title\">初任給を改定しました。</div>\r\n                </a>\r\n              </li>\r\n            \r\n              <li class=\"top-news__item\">\r\n                <a href=\"./news/?id=20260311_ 【会社説明会情報】名古屋情報メディア専門学校 学内企業説明会に出展します。\">\r\n                  <div class=\"top-news__date\">2026年3月11日</div>\r\n                  <div class=\"top-news__title\"> 【会社説明会情報】名古屋情報メディア専門学校 学内企業説明会に出展します。</div>\r\n                </a>\r\n              </li>\r\n            \r\n              <li class=\"top-news__item\">\r\n                <a href=\"./news/?id=20260305_ 【会社説明会情報】合説愛知2027に出展します。\">\r\n                  <div class=\"top-news__date\">2026年3月5日</div>\r\n                  <div class=\"top-news__title\"> 【会社説明会情報】合説愛知2027に出展します。</div>\r\n                </a>\r\n              </li>\r\n            \r\n              <li class=\"top-news__item\">\r\n                <a href=\"./news/?id=20260301_2027年度新卒採用のエントリーを開始しました！\">\r\n                  <div class=\"top-news__date\">2026年3月1日</div>\r\n                  <div class=\"top-news__title\">2027年度新卒採用のエントリーを開始しました！</div>\r\n                </a>\r\n              </li>\r\n                  </ul>\r\n    </div>\r\n  </div>\r\n</div>\r\n\r\n<div id=\"solution\" class=\"b-wrap bg-white _hr\">\r\n  <div class=\"b-inner b-container\">\r\n        <div class=\"top-headline__content\">\r\n      <div class=\"top-headline__icon\"><img src=\"./img/icon/menu_company.png\" loading=\"lazy\"/></div>\r\n      <div class=\"top-headline__main\">会社を知る</div>\r\n      <p class=\"top-headline__dsc\">\r\n        ものづくり現場を、ITで支えるソリューションを提供しています。<br>\r\n        設計・製造・検査・搬送など、ものづくりのさまざまな工程に対して<br>\r\n        システム開発や制御技術を通じて課題解決に取り組んでいます。\r\n      </p>\r\n    </div>\r\n        <ul class=\"col-img\">\r\n      <li><span><img src=\"./company/solution/img/img_1.jpg\" loading=\"lazy\"/></span></li>\r\n      <li><span><img src=\"./company/solution/img/img_2.jpg\" loading=\"lazy\"/></span></li>\r\n      <li><span><img src=\"./company/solution/img/img_3.jpg\" loading=\"lazy\"/></span></li>\r\n      <li><span><img src=\"./company/solution/img/img_4.jpg\" loading=\"lazy\"/></span></li>\r\n      <li><span><img src=\"./company/solution/img/img_5.jpg\" loading=\"lazy\"/></span></li>\r\n    </ul>\r\n    <div class=\"btn-more _wrap\"><a href=\"./company/solution\">事業紹介を見る</a></div>\r\n  </div>\r\n</div>\r\n\r\n<div id=\"work\" class=\"b-wrap bg-pale _hr\">\r\n  <div class=\"b-inner b-container\">\r\n        <div class=\"top-headline__content\">\r\n      <div class=\"top-headline__icon\"><img src=\"./img/icon/menu_work.png\" loading=\"lazy\"/></div>\r\n      <div class=\"top-headline__main\">仕事を知る</div>\r\n      <p class=\"top-headline__dsc\">\r\n        私たちは、製造業のお客様を中心に、現場の課題を解決するシステムの開発・提案を行っています。<br>\r\n        設計・製造・検査・搬送など、ものづくりのさまざまな工程に関わる仕事です。\r\n      </p>\r\n    </div>\r\n        <ul class=\"li-work__list\">\r\n      <li class=\"li-work__item\">\r\n        <a href=\"./work/engineer\">\r\n          <div class=\"li-work__thumb\"><img src=\"./work/engineer/img/screenshot.jpg\" loading=\"lazy\"/></div>\r\n          <div class=\"li-work__text\">\r\n            <div class=\"li-work__title\">技術職</div>\r\n            <p class=\"li-work__dsc\">システムの設計・開発を担当するSE・プログラマーの仕事です。<br>要件定義から開発・保守まで一貫して関わり、現場に直結するシステムづくりができるのが特徴です。</p>\r\n          </div>\r\n          <div class=\"li-work__btn\">仕事の詳細を見る</div>\r\n        </a>\r\n      </li>\r\n      <li class=\"li-work__item\">\r\n        <a href=\"./work/sales\">\r\n          <div class=\"li-work__thumb\"><img src=\"./work/sales/img/screenshot.jpg\" loading=\"lazy\"/></div>\r\n          <div class=\"li-work__text\">\r\n            <div class=\"li-work__title\">営業職</div>\r\n            <p class=\"li-work__dsc\">お客様の課題に最適なシステムやソリューションを提案します。<br>展示会などを通じて新たな出会いを創出し、ビジネスの機会を広げていく役割も担います。</p>\r\n          </div>\r\n          <div class=\"li-work__btn\">仕事の詳細を見る</div>\r\n        </a>\r\n      </li>\r\n      <li class=\"li-work__item\">\r\n        <a href=\"./work/admin\">\r\n          <div class=\"li-work__thumb\"><img src=\"./work/admin/img/screenshot.jpg\" loading=\"lazy\"/></div>\r\n          <div class=\"li-work__text\">\r\n            <div class=\"li-work__title\">事務職</div>\r\n            <p class=\"li-work__dsc\">人事・総務・購買などの社内業務や管理業務を通じて、会社の運営を支える仕事です。<br>社内の業務効率化や環境づくりにも関わることができるのが特徴です。</p>\r\n          </div>\r\n          <div class=\"li-work__btn\">仕事の詳細を見る</div>\r\n        </a>\r\n      </li>\r\n    </ul>\r\n    <div class=\"btn-more _wrap\"><a href=\"./work\">すべての職種を見る</a></div>\r\n  </div>\r\n</div>\r\n\r\n<div id=\"interview\" class=\"b-wrap _hr\">\r\n  <div class=\"b-inner b-container__top\">\r\n        <div class=\"top-headline__content\">\r\n      <div class=\"top-headline__icon\"><img src=\"./img/icon/menu_people.png\" loading=\"lazy\"/></div>\r\n      <div class=\"top-headline__main\">人を知る</div>\r\n      <p class=\"top-headline__dsc\">\r\n        アイ・シー・エスで働く人たちは、どうして入社を決めたのでしょうか？<br>\r\n        社員インタビューを通して、入社のきっかけや現在の仕事内容をご紹介します。\r\n      </p>\r\n    </div>\r\n  </div>\r\n</div>\r\n<div class=\"b-wrap\">\r\n  <div class=\"sd-menu\">\r\n    <ul id=\"js-slider_interview\" class=\"sd-menu__slider\">\r\n      <li class=\"sd-menu__list\">\r\n        <a class=\"sd-menu__list--link\" href=\"./people/interview/engineer_23kt\"></a>\r\n        <div class=\"sd-menu__list--img\">\r\n          <img src=\"./people/interview/engineer_23kt/img/screenshot.jpg?20260409\" loading=\"lazy\"/>\r\n          <span class=\"sd-menu__list--label\">技術職・2023年入社</span>\r\n        </div>\r\n        <div class=\"sd-menu__list--text\">\r\n          <div class=\"sd-menu__list--main\">“作る”だけじゃない。<br>現場まで関わるシステム開発</div>\r\n          <p class=\"sd-menu__list--dsc\">実際に現場を見ながら、使いやすいシステムを考えて開発する。お客様と直接関わりながらエンジニアとして成長してきた社員にインタビューしました。</p>\r\n        </div>\r\n      </li>\r\n      <li class=\"sd-menu__list\">\r\n        <a class=\"sd-menu__list--link\" href=\"./people/interview/sales_22kb\"></a>\r\n        <div class=\"sd-menu__list--img\">\r\n          <img src=\"./people/interview/sales_22kb/img/screenshot.jpg?20260409\" loading=\"lazy\"/>\r\n          <span class=\"sd-menu__list--label\">営業職・2022年入社</span>\r\n        </div>\r\n        <div class=\"sd-menu__list--text\">\r\n          <div class=\"sd-menu__list--main\">“この人に相談したい”と<br>思われる営業へ</div>\r\n          <p class=\"sd-menu__list--dsc\">文系・未経験からIT営業に挑戦。お客様との信頼関係を大切にしながら、「人で選ばれる営業」を目指す営業職社員に仕事への思いをインタビューしました。</p>\r\n        </div>\r\n      </li>\r\n      <li class=\"sd-menu__list\">\r\n        <a class=\"sd-menu__list--link\" href=\"./people/interview/sales_22mr\"></a>\r\n        <div class=\"sd-menu__list--img\">\r\n          <img src=\"./people/interview/sales_22mr/img/screenshot.jpg?20260409\" loading=\"lazy\"/>\r\n          <span class=\"sd-menu__list--label\">営業職・2022年入社</span>\r\n        </div>\r\n        <div class=\"sd-menu__list--text\">\r\n          <div class=\"sd-menu__list--main\">一つひとつ丁寧に、<br>信頼される営業へ</div>\r\n          <p class=\"sd-menu__list--dsc\">パソコンもあまり触ったことがなかったところから、IT企業の営業職へ。お客様・メーカー・社内をつなぐ丁寧なコミュニケーションで、信頼を積み重ねている社員にインタビューしました。</p>\r\n        </div>\r\n      </li>\r\n      <li class=\"sd-menu__list\">\r\n        <a class=\"sd-menu__list--link\" href=\"./people/interview/engineer_25kw\"></a>\r\n        <div class=\"sd-menu__list--img\">\r\n          <img src=\"./people/interview/engineer_25kw/img/screenshot.jpg?20260409\" loading=\"lazy\"/>\r\n          <span class=\"sd-menu__list--label\">技術職・2025年入社</span>\r\n        </div>\r\n        <div class=\"sd-menu__list--text\">\r\n          <div class=\"sd-menu__list--main\">少しずつ、<br>“できる”が増えていく</div>\r\n          <p class=\"sd-menu__list--dsc\">入社1年目で在庫管理システムの開発、上流工程にもチャレンジ。分からないことを一つひとつ乗り越え、少しずつ成長を重ねている若手社員へインタビューしました。</p>\r\n        </div>\r\n      </li>\r\n      <li class=\"sd-menu__list\">\r\n        <a class=\"sd-menu__list--link\" href=\"./people/interview/sales_24hy\"></a>\r\n        <div class=\"sd-menu__list--img\">\r\n          <img src=\"./people/interview/sales_24hy/img/screenshot.jpg?20260409\" loading=\"lazy\"/>\r\n          <span class=\"sd-menu__list--label\">営業職・2024年入社</span>\r\n        </div>\r\n        <div class=\"sd-menu__list--text\">\r\n          <div class=\"sd-menu__list--main\">試行錯誤しながら、<br>“伝わる”をつくる仕事</div>\r\n          <p class=\"sd-menu__list--dsc\">ITもマーケティングも未経験。展示会やPR資料制作、セミナー配信などを通して、“どうすれば伝わるか”を試行錯誤しながら挑戦し続けている社員にインタビューしました。</p>\r\n        </div>\r\n      </li>\r\n      <li class=\"sd-menu__list\">\r\n        <a class=\"sd-menu__list--link\" href=\"./people/interview/engineer_25mc\"></a>\r\n        <div class=\"sd-menu__list--img\">\r\n          <img src=\"./people/interview/engineer_25mc/img/screenshot.jpg?20260409\" loading=\"lazy\"/>\r\n          <span class=\"sd-menu__list--label\">技術職・2025年入社</span>\r\n        </div>\r\n        <div class=\"sd-menu__list--text\">\r\n          <div class=\"sd-menu__list--main\">動いて当たり前を、<br>支える仕事</div>\r\n          <p class=\"sd-menu__list--dsc\">地元でエンジニアとして働く。保守・運用業務を通して、実際に使われているシステムを支える若手エンジニアに現場で感じたやりがいをインタビューしました。</p>\r\n        </div>\r\n      </li>\r\n      <li class=\"sd-menu__list\">\r\n        <a class=\"sd-menu__list--link\" href=\"./people/interview/sales_21ym\"></a>\r\n        <div class=\"sd-menu__list--img\">\r\n          <img src=\"./people/interview/sales_21ym/img/screenshot.jpg?20260409\" loading=\"lazy\"/>\r\n          <span class=\"sd-menu__list--label\">営業職・2021年入社</span>\r\n        </div>\r\n        <div class=\"sd-menu__list--text\">\r\n          <div class=\"sd-menu__list--main\">未経験から挑戦した、<br>マーケティングの仕事</div>\r\n          <p class=\"sd-menu__list--dsc\">正解のないマーケティングに挑戦。メルマガ配信やセミナー企画・登壇など、さまざまな方法でお客様の “知りたい” 情報を届け続けている社員のインタビューです。</p>\r\n        </div>\r\n      </li>\r\n      <li class=\"sd-menu__list\">\r\n        <a class=\"sd-menu__list--link\" href=\"./people/interview/sales_24bp\"></a>\r\n        <div class=\"sd-menu__list--img\">\r\n          <img src=\"./people/interview/sales_24bp/img/screenshot.jpg?20260409\" loading=\"lazy\"/>\r\n          <span class=\"sd-menu__list--label\">営業職・2024年入社</span>\r\n        </div>\r\n        <div class=\"sd-menu__list--text\">\r\n          <div class=\"sd-menu__list--main\">製造現場を知るほど、<br>営業が面白くなる</div>\r\n          <p class=\"sd-menu__list--dsc\">美術系出身から新規顧客開拓のセールスへ。工場見学やお客様との会話を通じて、現場理解が深まっていく面白さを感じながら提案営業に取り組む社員へインタビューしました。</p>\r\n        </div>\r\n      </li>\r\n      <li class=\"sd-menu__list\">\r\n        <a class=\"sd-menu__list--link\" href=\"./people/interview/engineer_22mr\"></a>\r\n        <div class=\"sd-menu__list--img\">\r\n          <img src=\"./people/interview/engineer_22mr/img/screenshot.jpg?20260409\" loading=\"lazy\"/>\r\n          <span class=\"sd-menu__list--label\">技術職・2022年入社</span>\r\n        </div>\r\n        <div class=\"sd-menu__list--text\">\r\n          <div class=\"sd-menu__list--main\">“わからない”を聞けるから、<br>成長できた</div>\r\n          <p class=\"sd-menu__list--dsc\">文系・未経験からIT業界へ。“わからない”をすぐに相談できる環境の中で、自分のペースで一歩ずつ成長してきた社員にインタビューしました。</p>\r\n        </div>\r\n      </li>\r\n      <li class=\"sd-menu__list\">\r\n        <a class=\"sd-menu__list--link\" href=\"./people/interview/engineer_24ik\"></a>\r\n        <div class=\"sd-menu__list--img\">\r\n          <img src=\"./people/interview/engineer_24ik/img/screenshot.jpg?20260409\" loading=\"lazy\"/>\r\n          <span class=\"sd-menu__list--label\">技術職・2024年入社</span>\r\n        </div>\r\n        <div class=\"sd-menu__list--text\">\r\n          <div class=\"sd-menu__list--main\">面白そうから始まった、<br>システム開発の仕事</div>\r\n          <p class=\"sd-menu__list--dsc\">「なんかかっこいい！」と思ったことが、IT業界へ進むきっかけに。設計・開発・検査まで幅広く関わりながら、新しい技術に挑戦し続けるエンジニアにインタビューしました。</p>\r\n        </div>\r\n      </li>\r\n    </ul>\r\n    <div class=\"slick-dots-area\"></div>\r\n  </div>\r\n<div class=\"b-wrap\">\r\n  <div class=\"b-inner b-container__bottom\">\r\n    <div class=\"btn-more _wrap\"><a href=\"./people/interview/\">すべてのインタビューを見る</a></div>\r\n    <div class=\"btn-more__message\">※ 他のインタビューも順次公開予定です</div>\r\n  </div>  \r\n</div>\r\n\r\n\r\n<div id=\"evironment\" class=\"b-wrap bg-white _hr\">\r\n  <div class=\"b-inner b-container__top\">\r\n    <div class=\"col-half__content\">\r\n      <div class=\"col-half__item\">\r\n                <div class=\"top-headline__content _left\">\r\n          <div class=\"top-headline__icon\"><img src=\"./img/icon/menu_environment.png\" loading=\"lazy\"/></div>\r\n          <div class=\"top-headline__main\">働く環境を知る</div>\r\n          <p class=\"top-headline__dsc\">\r\n            アイ・シー・エスは全国６拠点に事務所があります。<br>\r\n            各拠点で、現場に寄り添った開発・提案を行っています。<br>\r\n            <br>\r\n            地元で働きたい方はもちろん、<br>\r\n            地域に根ざした働き方を希望する方にも適した環境です。\r\n          </p>\r\n        </div>\r\n      </div>\r\n      <div class=\"col-half__item\">\r\n        <div class=\"img-base__map\">\r\n          <img src=\"./img/home/location.png\" loading=\"lazy\"/>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n  <div class=\"b-inner b-container__bottom\">   \r\n        <ul class=\"col-img _3\">\r\n      <li><span class=\"_16-9\"><img src=\"./img/home/base_1.jpg\" loading=\"lazy\"/></span></li>\r\n      <li><span class=\"_16-9\"><img src=\"./img/home/base_2.jpg\" loading=\"lazy\"/></span></li>\r\n      <li><span class=\"_16-9\"><img src=\"./img/home/base_3.jpg\" loading=\"lazy\"/></span></li>\r\n      <li><span class=\"_16-9\"><img src=\"./img/home/base_4.jpg\" loading=\"lazy\"/></span></li>\r\n      <li><span class=\"_16-9\"><img src=\"./img/home/base_5.jpg\" loading=\"lazy\"/></span></li>\r\n      <li><span class=\"_16-9\"><img src=\"./img/home/base_6.jpg\" loading=\"lazy\"/></span></li>\r\n    </ul>\r\n    <div class=\"btn-more _wrap\"><a href=\"./environment/office\">働く環境をもっと見る</a></div>\r\n  </div>\r\n</div>\r\n\r\n<div id=\"company\" class=\"b-wrap bg-white _hr\">\r\n  <div class=\"b-inner b-container\">\r\n    <div class=\"col-half__content\">\r\n      <div class=\"col-half__item _order2\">\r\n        <div class=\"col-half__img\"><img src=\"./img/home/company.jpg\" loading=\"lazy\"/></div>\r\n      </div>\r\n      <div class=\"col-half__item _order1\">\r\n                <div class=\"top-menu__content\">\r\n          <div class=\"top-headline__content _left\">\r\n            <div class=\"top-headline__icon\"><img src=\"./img/icon/menu_company.png\" loading=\"lazy\"/></div>\r\n            <div class=\"top-headline__main\">会社情報</div>\r\n            <p class=\"top-headline__dsc\">\r\n              48年にわたり、製造業の現場課題に向き合い続けてきた<br>\r\n              アイ・シー・エスの会社概要や事業などをご紹介します。\r\n            </p>\r\n          </div>\r\n          <ul class=\"top-menu__list\">\r\n            <li class=\"top-menu__item\"><a href=\"./company/about\">会社概要</a></li>\r\n            <li class=\"top-menu__item\"><a href=\"./company/solution\">５つの事業</a></li>\r\n            <li class=\"top-menu__item\"><a href=\"./company/philosophy\">企業理念</a></li>\r\n            <li class=\"top-menu__item\"><a href=\"./company/history\">歴史</a></li>\r\n            <li class=\"top-menu__item\"><a href=\"./company/access\">拠点とアクセス</a></li>\r\n            <li class=\"top-menu__item\"><a href=\"./company/data\">数字で分かる</a></li>\r\n          </ul>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</div>\r\n\r\n<div id=\"entry\" class=\"b-wrap cta-entry-card__bg\">\r\n  <div class=\"b-inner\">\r\n    <div class=\"cta-entry-card__headline--content _color-white\">\r\n      <div class=\"cta-entry-card__headline--main\">エントリー</div>\r\n      <p class=\"cta-entry-card__headline--dsc\">\r\n        アイ・シー・エスで働いてみたいという方は、エントリーください。<br>\r\n        「まずは、話を聞いてみたい」という方も、歓迎しています。\r\n      </p>\r\n    </div>\r\n    <ul class=\"cta-entry-card__list\">\r\n      \r\n            <li class=\"cta-entry-card__item\">\r\n              <div class=\"cta-entry-card__title\">27卒 新卒採用</div>\r\n              <p class=\"cta-entry-card__dsc\">これから社会人として<br>成長していきたい方へ</p>\r\n              <div class=\"cta-entry-card__btn\"><a href=\"https://job.mynavi.jp/27/pc/search/corp60360/outline.html\" target=\"_blank\">エントリーする</a></div>\r\n              <div class=\"cta-entry-card__link\"><a href=\"./positions/newgraduate\" target=\"_blank\">募集要項を見る</a></div>\r\n            </li>\r\n            <li class=\"cta-entry-card__item\">\r\n              <div class=\"cta-entry-card__title\">28卒 インターン情報</div>\r\n              <p class=\"cta-entry-card__dsc\">まずは、インターンシップで<br>仕事を経験したい方へ</p>\r\n              <div class=\"cta-entry-card__btn\"><a href=\"https://job.mynavi.jp/28/pc/search/corp60360/outline.html\" target=\"_blank\">エントリーする</a></div>\r\n              <div class=\"cta-entry-card__link\"><a href=\"./positions/internship\" target=\"_blank\">募集要項を見る</a></div>\r\n            </li>\r\n            <li class=\"cta-entry-card__item\">\r\n              <div class=\"cta-entry-card__title\">キャリア採用</div>\r\n              <p class=\"cta-entry-card__dsc\">これまでの経験を活かし、<br>新たな環境で挑戦したい方へ</p>\r\n              <div class=\"cta-entry-card__btn\"><a href=\"https://en-gage.net/ise-ics_saiyo1/\" target=\"_blank\">エントリーする</a></div>\r\n              <div class=\"cta-entry-card__link\"><a href=\"./positions/career\" target=\"_blank\">募集要項を見る</a></div>\r\n            </li>    </ul>\r\n  </div>\r\n</div>\r\n<div class=\"line-msg\">みなさまのご応募を社員一同、心よりお待ちしております！</div>\r\n\r\n<div class=\"b-wrap cta-corporate__wrap\">\r\n  <div class=\"b-inner b-container\">\r\n    <div class=\"cta-corporate__content\">\r\n      <div class=\"cta-corporate__logo\"><img src=\"./img/logo-white.svg\" alt=\"株式会社アイ・シー・エス\" loading=\"lazy\"/></div>\r\n      <div class=\"cta-corporate__catch\">製造業の現場課題を、<br>システムで解決する会社です。</div>\r\n      <p class=\"cta-corporate__dsc\">1978年創立以来、工場の設備や機械を制御するソフトウェアを開発してきました。<br>製造業のお客様を中心に、現場の課題を解決するシステムを開発・提案しています。</p>\r\n      <div class=\"cta-corporate__btn btn _arrow\"><a href=\"../\" target=\"_blank\">コーポレートサイトを見る</a></div>\r\n    </div>\r\n  </div>\r\n</div>\r\n\r\n<footer class=\"c-footer\">\r\n  <div class=\"b-inner b-container\">\r\n    <div class=\"c-footer__headline\">\r\n      <a class=\"c-footer__logo\" href=\"./\"><img src=\"./img/logo.svg\" alt=\"株式会社アイ・シー・エス\" loading=\"lazy\"/></a>\r\n      <div class=\"c-footer__site-name\">採用サイト</div>\r\n    </div>\r\n        <nav class=\"c-footer__nav\">\r\n      <ul class=\"c-footer__nav--list\">\r\n        <li class=\"c-footer__nav--item\"><a href=\"./company\">会社を知る</a></li><li class=\"c-footer__nav--item\"><a href=\"./work\">仕事を知る</a></li><li class=\"c-footer__nav--item\"><a href=\"./people\">人を知る</a></li><li class=\"c-footer__nav--item\"><a href=\"./environment\">働く環境を知る</a></li><li class=\"c-footer__nav--item\"><a href=\"./positions\">募集要項</a></li><li class=\"c-footer__nav--item\"><a href=\"./news\">お知らせ</a></li><li class=\"c-footer__nav--item\"><a href=\"./faq\">よくあるご質問</a></li>      </ul>\r\n    </nav>\r\n      </div>\r\n  <div class=\"c-footer__bottom\">Copyright ICS CO., LTD. All Rights Reserved.</div>\r\n</footer>\r\n</body>\r\n</html>\r\n","finalUrl":"http://www.ise-ics.co.jp/recruit/","rendered":false,"_cachedAt":"2026-06-14T16:37:50.560Z"}