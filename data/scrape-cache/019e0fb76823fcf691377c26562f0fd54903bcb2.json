https://www.instagram.com/zynas_corp\" target=\"_blank\" rel=\"noopener noreferrer\" aria-label=\"Instagramのリンク\"></a></li>\n                <li class=\"nav--sns__list__item\"><a class=\"nav--sns__list__item__link facebook\" href=\"https://www.facebook.com/zynas.inc\" target=\"_blank\" rel=\"noopener noreferrer\" aria-label=\"Facebookのリンク\"></a></li>\n            </ul>\n        </nav>\n    </div>\n</header>\n\n<div id=\"childNavBg-white\" :class=\"{ 'js-on':childNavActive }\"></div>\n<div id=\"childNavBg-black\" :class=\"{ 'js-on':childNavActive }\" v-on:click=\"toggleChildNav\"></div>        <!--------------- / HEADER AREA --------------->\n\n        <!--------------- MAIN AREA --------------->\n        <main>\n\n<!--------------- Template - PageHeader --------------->\n<section id=\"template-pageHeader\">\n    <hgroup class=\"page-title\">\n        <h1 class=\"page-title--ja js-fade-up\">私たちの想い</h1>\n        <p class=\"page-title--en js-fade-up\">Our Message</p>\n    </hgroup>\n</section><!--------------- / Template - PageHeader --------------->\n\n\n<section id=\"mission\" class=\"cm-inner--fluid js-fade-up\">\n    <h2 class=\"mission__head\">Mission</h2>\n\n    <p class=\"mission__catchcopy\">\n        <span class=\"inB\">もっといいシステムで、</span><span class=\"inB\">もっといい明日を</span>\n    </p>\n\n    <p class=\"mission__text\">\n        テクノロジーは、“人”がどう駆使していくかによって、形が大きく変わります。<br>\n        <br>\n        ザイナスはお客様に寄り添いともに考え、テクノロジーを利活用するまでの過程を<br class=\"none--sp\">\n        とても大切にしています。そして、それは決してゴールではありません。<br>\n        <br>\n        日々、変化する環境や使いやすさにこだわりながら、<br class=\"none--sp\">\n        より良いものを創り続けることが、私たちの使命です。<br>\n        <br>\n        そんな毎日の積み重ねがきっと、人々のより良い明日に繋がっていくのだと信じています。\n    </p>\n</section>\n\n\n<section id=\"zynasStandard\" class=\"cm-inner--fluid js-fade-up\">\n    <h2 class=\"zynasStandard__head\">Zynas Standard</h2>\n\n    <p class=\"zynasStandard__text\">\n        ザイナスの軸であり、わたしたちの行動指針です。<br>\n        社員全員がZynas Standardを体現することで、もっといい明日を目指します。\n    </p>\n\n    <div class=\"zynasStandard__content\">\n        <div class=\"zynasStandard__item\">\n            <h3 class=\"item__head\">技術は深く広く、志は高く</h3>\n            <p class=\"item__text\">世界の技術は日々、進歩しています。常に様々なことに目を配り学び、そして、自分のものにできるようにしよう。</p>\n        </div>\n        <!-- / item -->\n        <div class=\"zynasStandard__item\">\n            <h3 class=\"item__head\">ニーズの一歩先を創造する、真摯に応える</h3>\n            <p class=\"item__text\">相手の “本当の” ニーズは何なのか、コミュニケーションを図って、とことん探求しよう。</p>\n        </div>\n        <!-- / item -->\n        <div class=\"zynasStandard__item\">\n            <h3 class=\"item__head\">自分と相手の本音を大切にし、認め合う</h3>\n            <p class=\"item__text\">一人ひとりの豊かさが、会社や社会の成長、成熟に繋がります。<br>相手はもちろん、自分も大切な一人として尊重しよう。</p>\n        </div>\n        <!-- / item -->\n    </div>\n</section>\n\n\n<section id=\"representative\" class=\"cm-inner--fluid js-fade-up\">\n    <!-- .cm-head--c -->\n    <h2 class=\"cm-head--c--center\">代表メッセージ</h2>\n    <!-- / .cm-head--c -->\n\n    <div class=\"representative__content\">\n        <p class=\"representative__text\">\n            私たちザイナスは、システムを駆使し、お客様、地域社会、ひいてはそこに暮らす人々の明日をより良くすることを信念としています。<br>\n            ITは今や社会に浸透し、一瞬にして問題を解決できる魔法のように思われているかもしれませんが、その裏側では、私たちのような作り手がいて、どうやったら使いやすく効果的か、どうやったら満足いただけるかを日々考え続けています。システムの利用者やその先にいる人たちの顔を思い浮かべて、仕事をしています。<br>\n            “システム”という言葉には“仕組み”という意味があります。私たちザイナスは、お客様と一緒に仕事や地域社会の仕組みづくりから行い、より良い未来を作ることに貢献していきます。\n            <span class=\"author__name\">代表取締役社長　　江藤 彰悟</span>\n        </p>\n        <img class=\"representative__img lazyload\" src=\"data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAsoAAANOAQAAAAAguxeXAAAAAnRSTlMAAHaTzTgAAABhSURBVHja7cExAQAAAMKg9U9tCy+gAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAADgYSzJAAH5vhbOAAAAAElFTkSuQmCC\" alt=\"代表取締役社長 江藤彰悟の写真\" loading=\"lazy\" data-src=\"https://zynas.co.jp/wp-content/themes/zynas/img/message/img-message-representative-vice-president.png\" decoding=\"async\" data-eio-rwidth=\"714\" data-eio-rheight=\"846\"><noscript><img class=\"representative__img\" src=\"https://zynas.co.jp/wp-content/themes/zynas/img/message/img-message-representative-vice-president.png\" alt=\"代表取締役社長 江藤彰悟の写真\" loading=\"lazy\" data-eio=\"l\"></noscript>\n    </div>\n</section>\n\n\n<section id=\"solicitation\" class=\"cm-inner--fluid js-fade-up\">\n    <picture class=\"solicitation__header\">\n        <source  media=\"(max-width: 750px)\" data-srcset=\"https://zynas.co.jp/wp-content/themes/zynas/img/message/bg-message-solicitation-header-sp.png\">\n        <img src=\"data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAB4AAAAH+AQAAAABVIS7gAAAAAnRSTlMAAHaTzTgAAACOSURBVHja7cExAQAAAMKg9U9tCy+gAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAeBuAtAAELXm80AAAAAElFTkSuQmCC\" alt=\"\" loading=\"lazy\" data-src=\"https://zynas.co.jp/wp-content/themes/zynas/img/message/bg-message-solicitation-header-pc.png\" decoding=\"async\" class=\"lazyload\" data-eio-rwidth=\"2560\" data-eio-rheight=\"680\">\n    </picture><noscript><img src=\"https://zynas.co.jp/wp-content/themes/zynas/img/message/bg-message-solicitation-header-pc.png\" alt=\"\" loading=\"lazy\" data-eio=\"l\"></noscript>\n\n    <div class=\"solicitation__content\">\n        <div class=\"content--left\">\n            <!-- .cm-head--c -->\n            <h2 class=\"cm-head--c\">もっといい明日へ、ともに歩む</h2>\n            <!-- / .cm-head--c -->\n            <p class=\"content__text\">ザイナスのミッションや価値観に共感し、ともに働くメンバーを探しています。<br>わたしたちと一緒に、より良い明日を創造するための挑戦を始めませんか？</p>\n        </div>\n\n        <div class=\"content--right\">\n            <!-- .cm-link--button -->\n            <a class=\"cm-link--button content__permalink\" href=\"https://recruit.zynas.co.jp\" target=\"_blank\" rel=\"noopener noreferrer\">採用情報</a> \n            <!-- / .cm-link--button  -->\n        </div>\n    </div>\n</section>\n\n\n<section id=\"magazine\" class=\"cm-inner--fluid js-fade-up\">\n    <!-- .cm-head--b--center -->\n    <hgroup class=\"cm-head--b--center\">\n        <h2 class=\"head--ja\">ザイナスをもっと知る</h2>\n        <p class=\"head--en\">Zynas Magazine</p>\n    </hgroup>\n    <!-- / .cm-head--b--center -->\n\n    <p class=\"magazine__text\">ザイナス公式noteでは、社員アンケートやインタビューなど様々な記事を配信しています。よりリアルなザイナスの雰囲気を感じていただけます。</p>\n\n    <!-- .cm-note-slider -->\n    <div id=\"note-rss\" class=\"cm-note-slider magazine__slider\">\n        <!--------------- Template - note RSS --------------->\n        <article class=\"note\"><a class=\"note__link\" href=\"https://note.com/zynas/n/n562be71eed88\" target=\"_blank\"></a><div class=\"note__thumbnail\"><img class=\"note__thumbnail__img lazyload\" src=\"data:image/gif;base64,R0lGODlhAQABAAAAACH5BAEKAAEALAAAAAABAAEAAAICTAEAOw==\" alt=\"\" loading=\"lazy\" data-src=\"https://assets.st-note.com/production/uploads/images/278138367/rectangle_large_type_2_0f3eaf354a2c9ea5ce585e5eed8b9877.png?width=800\" decoding=\"async\"><noscript><img class=\"note__thumbnail__img\" src=\"https://assets.st-note.com/production/uploads/images/278138367/rectangle_large_type_2_0f3eaf354a2c9ea5ce585e5eed8b9877.png?width=800\" alt=\"\" loading=\"lazy\" data-eio=\"l\"></noscript></div><div class=\"note__content\"><time class=\"note__date\">2026年05月22日</time><h1 class=\"note__title\">【STech I x ザイナス対談】長谷川AP事業本部長と江藤社長が語るグループ会社化の理由</h1></div></article><article class=\"note\"><a class=\"note__link\" href=\"https://note.com/zynas/n/nbd80fdf9de34\" target=\"_blank\"></a><div class=\"note__thumbnail\"><img class=\"note__thumbnail__img lazyload\" src=\"data:image/gif;base64,R0lGODlhAQABAAAAACH5BAEKAAEALAAAAAABAAEAAAICTAEAOw==\" alt=\"\" loading=\"lazy\" data-src=\"https://assets.st-note.com/production/uploads/images/235084145/rectangle_large_type_2_e9c86a406dc5a8753b1b845431ad8299.png?width=800\" decoding=\"async\"><noscript><img class=\"note__thumbnail__img\" src=\"https://assets.st-note.com/production/uploads/images/235084145/rectangle_large_type_2_e9c86a406