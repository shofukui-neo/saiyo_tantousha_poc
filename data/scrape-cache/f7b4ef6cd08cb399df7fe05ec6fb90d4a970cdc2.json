{"url":"https://corp.jac-recruitment.jp/recruit/workplace/training/","html":"<!doctype html>\r\n<html lang=\"ja\">\r\n<head>\r\n<meta charset=\"utf-8\">\r\n  <meta name=\"robots\" content=\"noindex\" />\r\n  <script>\r\n    location.replace(\"https://recruit.jacgroup.com/workplace/training/\");\r\n  </script>\r\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\r\n<title>スキルアップ支援・研修｜採用情報｜転職・人材紹介のJAC Recruitment</title>\r\n<meta name=\"description\" content=\"JAC Recruitmentの採用情報、教育・成長支援を紹介しています。\">\r\n<analyticsOUT></analyticsOUT>\r\n\r\n<link rel=\"shortcut icon\" href=\"/recruit/common/images/favicon.ico\" />\r\n\r\n<link rel=\"stylesheet\" href=\"/recruit/common/css/master.css\">\r\n<script src=\"/recruit/common/js/init.js\"></script>\r\n\t\r\n</head>\r\n\r\n<body>\r\n<!-- Google Tag Manager (noscript) -->\r\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-NMMNH8P3\"\r\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\r\n<!-- End Google Tag Manager (noscript) -->\r\n<header-underlayerOUT></header-underlayerOUT>\r\n\r\n<hr>\r\n\r\n<div class=\"site-heading\">\r\n<div class=\"outer\">\r\n<nav class=\"nav-breadcrumb\" aria-label=\"Breadcrumb\">\r\n<ul>\r\n<li><a href=\"/recruit/\">採用トップ</a></li>\r\n<li><a href=\"/recruit/workplace/\">制度・支援</a></li>\r\n<li><a aria-current=\"true\">スキルアップ支援・研修</a></li>\r\n</ul>\r\n</nav>\r\n\r\n<h1 class=\"heading-01\">スキルアップ支援・研修</h1>\r\n</div><!-- /.str-outer -->\r\n</div><!-- /.site-heading -->\r\n\r\n\r\n\r\n<!--main-content-->\r\n<main>\r\n\r\n\r\n\r\n<section>\r\n<div class=\"str-outer\">\r\n<div class=\"str-inner\">\r\n\r\n<img src=\"/recruit/workplace/training/images/index_img_02.jpg\"  alt=\"\">\r\n<br>\r\n\t\r\n</div><!-- /.str-inner -->\r\n</div><!-- /.str-outer -->\r\n\r\n\r\n\r\n<div class=\"str-outer\">\r\n<div class=\"str-inner\">\r\n\r\n\r\n\r\n<div class=\"mod-heading-02\">\r\n<h2 class=\"title\">スキルアップ支援・研修</h2>\r\n</div><!-- /.mod-heading-02 -->\r\n\t\r\n<div class=\"mod-text\">\r\n<p class=\"text\">50年以上にわたる業界での実績をもとに、新しく仲間に加わるすべての方に、業界をリードするためのトレーニングを提供しています。キャリアパスに沿った教育体制を整え、プロフェッショナルなコンサルタントの育成を目指します。</p><br>\r\n\t\r\n</div><!-- /.mod-text -->\r\n\r\n<div class=\"mod-heading-04\">\r\n<h3 class=\"title\">オンボーディング研修</h3>\r\n</div><!-- /.mod-heading-03 -->\r\n\r\n\r\n<div class=\"mod-box-text of-col3\">\r\n<div class=\"box\">\r\n<h3 class=\"head\">オンボーディングトレーニング</h3>\r\n<div class=\"content\">\r\n<p class=\"text\">コンサルタントとして早期に成果を上げるための土台を構築し、安定的な成果を維持するための意識、考え方、行動を習得する1年間の研修制度です。</p>\r\n</div><!-- /.content -->\r\n</div><!-- /.box -->\r\n\r\n<div class=\"box\">\r\n<h3 class=\"head\">バディ制度</h3>\r\n<div class=\"content\">\r\n<p class=\"text\">同じ部署の先輩社員が、新入社員に対して会社の風土や仕事の進め方を指導し、業務や社会生活における不安や悩みに寄り添います。</p>\r\n</div><!-- /.content -->\r\n</div><!-- /.box -->\r\n\r\n</div><!-- /.mod-box-text col3 -->\r\n\r\n\r\n<div class=\"mod-heading-04\">\r\n<h3 class=\"title\">継続的な研修</h3>\r\n</div><!-- /.mod-heading-03 -->\r\n\r\n\r\n<div class=\"mod-box-text of-col3\">\r\n<div class=\"box\">\r\n<h3 class=\"head\">Portable Skill 研修</h3>\r\n<div class=\"content\">\r\n<p class=\"text\">社外でも通用する汎用的ななスキルや知識を身につけることで、コンサルタントとしてビジネスパーソンとしてのステップアップを目指す研修です。</p>\r\n</div><!-- /.content -->\r\n</div><!-- /.box -->\r\n\r\n<div class=\"box\">\r\n<h3 class=\"head\">コンプライアンス研修</h3>\r\n<div class=\"content\">\r\n<p class=\"text\">法令遵守の観点から、企業や登録者に適切なアドバイスができるプロフェッショナルを育成します。</p>\r\n</div><!-- /.content -->\r\n</div><!-- /.box -->\r\n\r\n<div class=\"box\">\r\n<h3 class=\"head\">e-learning</h3>\r\n<div class=\"content\">\r\n<p class=\"text\">社内向けのオンライン学習プログラムで、自分のペースで学習を進めることができます。</p>\r\n</div><!-- /.content -->\r\n</div><!-- /.box -->\r\n</div><!-- /.mod-box-text col3 -->\r\n\r\n\r\n<div class=\"mod-heading-04\">\r\n<h3 class=\"title\">マネジメント・リーダーシップ研修</h3>\r\n</div><!-- /.mod-heading-03 -->\r\n\r\n\r\n<div class=\"mod-box-text of-col3\">\r\n<div class=\"box\">\r\n<h3 class=\"head\">新任管理職研修</h3>\r\n<div class=\"content\">\r\n<p class=\"text\">マネジメントに求められる役割や行動を理解し、実践力を高めます。</p>\r\n</div><!-- /.content -->\r\n</div><!-- /.box -->\r\n\r\n<div class=\"box\">\r\n<h3 class=\"head\">部支店長、マネージャー向け研修</h3>\r\n<div class=\"content\">\r\n<p class=\"text\">部支店長、マネージャーに求められるミッション・役割に必要とされるスキルや知識を習得するための研修です。</p>\r\n</div><!-- /.content -->\r\n</div><!-- /.box -->\r\n</div><!-- /.mod-box-text col3 -->\r\n\r\n\r\n<div class=\"mod-heading-04\">\r\n<h3 class=\"title\">海外研修</h3>\r\n</div><!-- /.mod-heading-03 -->\r\n\r\n<div class=\"mod-box-text of-col3\">\r\n<div class=\"box\">\r\n<h3 class=\"head\">海外派遣制度</h3>\r\n<div class=\"content\">\r\n<p class=\"text\">海外グループ会社を訪問し、現地社員との交流や海外マーケットの理解を深めることで、国際的な視野を広げます。</p>\r\n</div><!-- /.content -->\r\n</div><!-- /.box -->\r\n\r\n<div class=\"box\">\r\n<h3 class=\"head\">植樹ツアーへの参加</h3>\r\n<div class=\"content\">\r\n<p class=\"text\">サステナビリティ活動の一環として、インドネシア、マレーシア、宮古島の植樹地を訪れ、植樹を体験します。</p>\r\n</div><!-- /.content -->\r\n</div><!-- /.box -->\r\n</div><!-- /.mod-box-text col3 -->\r\n\r\n<br><br>\r\n\r\n<div class=\"mod-heading-02\">\r\n<h2 class=\"title\" style=\"font-size: 2rem;text-align: center;\">\r\nJAC Groupでは、すべての社員にキャリア形成の機会を提供しています。<br>\r\n個人の適性に合わせた研修やスキルアップ支援を通じて、会社と社員が一体となって成長を目指していきます。\r\n</h2>\r\n</div>\t\r\n\r\n<div class=\"mod-text\">\r\n<div class=\"col\"><center><a href=\"/recruit/works/careerpath/\" class=\"mod-btn-style of-target of-wide\" > キャリア形成支援 </a>\r\n</center></div>\r\n</div>\r\n\r\n<br><br>\r\n\r\n\r\n</div><!-- /.str-inner -->\r\n</div><!-- /.str-outer -->\r\n</section>\r\n\r\n</main>\r\n<!--/.main-content-->\r\n\r\n\r\n\r\n<section class=\"sct-recruit of-mt\">\r\n<div class=\"site-recruit\">\r\n<div class=\"outer\">\r\n<div class=\"inner\">\r\n\r\n\r\n<h2 class=\"title\"><font size=\"7\">JAC Group 採用情報</font></h2>\r\n<ul class=\"mod-index-box\">\r\n<li><font size=\"6\">新卒採用</font><a href=\"/recruit/entry/new-graduate.html\">詳しく見る</a></li>\r\n<li><font size=\"6\">キャリア/中途採用</font><a href=\"/recruit/entry/career.html\">詳しく見る</a></li>\r\n<li><font size=\"6\">海外採用</font><a href=\"/recruit/entry/overseas1.html\">詳しく見る</a></li>\r\n</ul>\r\n\r\n\r\n</div><!-- /.inner -->\r\n</div><!-- /.outer -->\r\n</div><!-- /.site-recruit -->\r\n</section>\r\n\r\n\r\n\r\n<footerOUT></footerOUT>\r\n\r\n\r\n\r\n<script src=\"/recruit/common/js/jquery.js\"></script>\r\n<script src=\"/recruit/common/js/run.js\"></script>\r\n\r\n<script>\r\n    $(function(){\r\n        $.ajaxSetup({cache:false});\r\n        $(\"analyticsOUT\").load(\"/recruit/common/inc/analytics.html\");\r\n    }); \r\n    </script>\r\n    <script>\r\n    $(function(){\r\n        $.ajaxSetup({cache:false});\r\n        $(\"headerOUT\").load(\"/recruit/common/inc/header.html\");\r\n    }); \r\n    </script>\r\n<script>\r\n    $(function(){\r\n        $.ajaxSetup({cache:false});\r\n        $(\"header-underlayerOUT\").load(\"/recruit/common/inc/header-underlayer.html\");\r\n    }); \r\n    </script>\r\n    <script>\r\n    $(function(){\r\n        $.ajaxSetup({cache:false});\r\n        $(\"footerOUT\").load(\"/recruit/common/inc/footer.html\");\r\n    }); \r\n    </script>\r\n</body>\r\n</html>\r\n","finalUrl":"https://corp.jac-recruitment.jp/recruit/workplace/training/","rendered":false,"_cachedAt":"2026-06-22T21:37:31.296Z"}