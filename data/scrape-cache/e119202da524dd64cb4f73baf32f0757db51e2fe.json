{"url":"https://www.meisei-kogyo.co.jp/recruit/staff/","html":"<!DOCTYPE html>\r\n<html>\r\n\r\n<head>\r\n  <meta charset=\"utf-8\">\r\n  <meta http-equiv=\"X-UA-Compatible\" content=\"IE=Edge\">\r\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n  <meta name=\"format-detection\" content=\"telephone=no\">\r\n\r\n  <title>先輩社員紹介｜採用情報｜明星工業株式会社</title>\r\n  <meta name=\"description\" content=\"大阪府大阪市。化学プラントなどの熱絶縁工事業。会社組織・IR情報、工事実績と製品案内。\">\r\n  <meta name=\"keywords\" content=\"断熱,断熱材,熱絶縁,化学プラント,保温,保冷,LNG,LPG,液化天然ガス,耐火被覆,築炉,環境エネルギー,焼却炉,煙突ライニング,防音,アスベスト対策,スターベローズ,非金属製伸縮継手\">\r\n  <link rel=\"canonical\" href=\"https://www.meisei-kogyo.co.jp/recruit/\">\r\n  <link rel=\"icon\" href=\"/icon/favicon.ico\">\r\n\r\n  <link href=\"https://fonts.googleapis.com/css?family=Noto+Serif+JP:400,500,600,700,900&display=swap&subset=japanese\" rel=\"stylesheet\">\r\n  <link href=\"https://fonts.googleapis.com/css?family=Arvo:700&display=swap\" rel=\"stylesheet\">\r\n  <link rel=\"stylesheet\" href=\"/css/all.css\">\r\n  <link rel=\"stylesheet\" type=\"text/css\" href=\"/css/reset.css\">\r\n  <link rel=\"stylesheet\" type=\"text/css\" href=\"/css/common.css\">\r\n  <link rel=\"stylesheet\" type=\"text/css\" href=\"/css/style.css\">\r\n  <link rel=\"stylesheet\" type=\"text/css\" href=\"/css/recruit/common.css\">\r\n  <link rel=\"stylesheet\" type=\"text/css\" href=\"/css/recruit/staff.css\">\r\n\r\n  <script src=\"https://code.jquery.com/jquery-3.3.1.min.js\"></script>\r\n  <script src=\"/js/common.js\"></script>\r\n</head>\r\n\r\n<body>\r\n  <div id=\"wrapper\">\r\n\r\n    \n<header class=\"header\">\n  <h1 class=\"header_logo\">\n    <a href=\"/\"><img src=\"/img/common/logo.png\"></a>\n  </h1>\n    <div class=\"Toggle\" id=\"js_sideMenuBtn\">\n      <span></span><span></span><span></span>\n    </div>\n    <div class=\"NavMenu\">\n    <div class=\"menu\">\n      <div class=\"nav\">\n        <div class=\"language\">\n          <p><span class=\"current\">JP</span>｜<a href=\"/en/\">EN</a></p>\n        </div>\n        <ul>\n          <li><a href=\"/about/\">明星工業とは</a></li>\n          <li><a class=\"hasChild\">事業紹介<i class=\"fas fa-chevron-down\"></i></a>\n            <div class=\"nav_child\">\n              <p class=\"title\">事業紹介</p>\n              <ul>\n                <li><a href=\"/dannetsu/\"><img src=\"/img/common/nav/business_01.png\"><p class=\"name\">断熱分野</p></a></li>\n                <li><a href=\"/kankyou/\"><img src=\"/img/common/nav/business_02.png\"><p class=\"name\">環境分野</p></a></li>\n                <li><a href=\"/kaigai/\"><img src=\"/img/common/nav/business_03.png\"><p class=\"name\">海外分野</p></a></li>\n                <li><a href=\"/seisan/\"><img src=\"/img/common/nav/business_04.png\"><p class=\"name\">生産分野</p></a></li>\n              </ul>\n            </div>\n            <div class=\"nav_child_sp\">\n              <!-- <a><p class=\"title\">事業紹介</p></a> -->\n              <ul>\n                <li><a href=\"/dannetsu/\">断熱分野</a></li>\n                <li><a href=\"/kankyou/\">環境分野</a></li>\n                <li><a href=\"/kaigai/\">海外分野</a></li>\n                <li><a href=\"/seisan/\">生産分野</a></li>\n              </ul>\n            </div>\n          </li>\n          <li><a href=\"/seihin/\">製品紹介</a></li>\n          <li><a class=\"hasChild\" href=\"/corporate/\">会社情報<i class=\"fas fa-chevron-down\"></i></a>\n            <div class=\"nav_child\">\n              <p class=\"title\">会社情報</p>\n              <ul>\n                <li><a href=\"/corporate/\"><img src=\"/img/common/nav/company_01.jpg\"><p class=\"name\">会社概要</p></a></li>\n                <li><a href=\"/corporate/activity/\"><img src=\"/img/common/nav/company_02.jpg\"><p class=\"name\">事業概要</p></a></li>\n                <li><a href=\"/corporate/officer/\"><img src=\"/img/common/nav/company_06.jpg\"><p class=\"name\">役員紹介</p></a></li>\n                <li><a href=\"/corporate/transition/\"><img src=\"/img/common/nav/company_03.jpg\"><p class=\"name\">沿革</p></a></li>\n                <li><a href=\"/corporate/list/\"><img src=\"/img/common/nav/company_04.jpg\"><p class=\"name\">事業所紹介</p></a></li>\n                <li><a href=\"/corporate/group/\"><img src=\"/img/common/nav/company_05.jpg\"><p class=\"name\">関連会社紹介</p></a></li>\n                <li></li> <!-- dummy -->\n                <li></li> <!-- dummy -->\n              </ul>\n            </div>\n            <div class=\"nav_child_sp\">\n              <!-- <a><p class=\"title\">会社情報</p></a> -->\n              <ul>\n                <li><a href=\"/corporate/\">会社概要</a></li>\n                <li><a href=\"/corporate/activity/\">事業概要</a></li>\n                <li><a href=\"/corporate/officer/\">役員紹介</a></li>\n                <li><a href=\"/corporate/transition/\">沿革</a></li>\n                <li><a href=\"/corporate/list/\">事業所紹介</a></li>\n                <li><a href=\"/corporate/group/\">関連会社紹介</a></li>\n              </ul>\n            </div>\n          </li>\n          <li><a class=\"hasChild\" href=\"/sustainability/\">サステナビリティ<i class=\"fas fa-chevron-down\"></i></a>\n            <div class=\"nav_child\">\n              <p class=\"title\">サステナビリティ</p>\n              <div class=\"nav_subList\">\n                <div class=\"nav_subItem\">\n                  <div class=\"nav_subItem-img\">\n                    <a href=\"/about/\"><img src=\"/img/common/nav/sus_01.jpg?2025070801\" alt=\"トップメッセージ イメージ\"></a>\n                  </div>\n                  <div class=\"nav_subItem-txt\">\n                    <p><a href=\"/about/\">トップメッセージ</a></p>\n                  </div>\n                </div>\n                <div class=\"nav_subItem\">\n                  <div class=\"nav_subItem-img\">\n                    <a href=\"/sustainability/concept/\"><img src=\"/img/common/nav/sus_02.jpg\" alt=\"サステナビリティ方針/推進体制 イメージ\"></a>\n                  </div>\n                  <div class=\"nav_subItem-txt\">\n                    <p><a href=\"/sustainability/concept/\">サステナビリティ方針/推進体制</a></p>\n                  </div>\n                </div>\n                <div class=\"nav_subItem\">\n                  <div class=\"nav_subItem-img\">\n                    <a href=\"/sustainability/environment/\"><img src=\"/img/common/nav/sus_03.jpg\" alt=\"環境 イメージ\"></a>\n                  </div>\n                  <div class=\"nav_subItem-txt\">\n                    <p><a href=\"/sustainability/environment/\">環境</a></p>\n                    <ul>\n                      <li><a href=\"/sustainability/environment/tcfd.html\">・TCFDに基づく情報開示</a></li>\n                      <li><a href=\"/sustainability/environment/zeb.html\">・ZEBへの取組み目標</a></li>\n                      <li><a href=\"/sustainability/environment/procurement.html\">・持続可能な調達方針</a></li>\n                    </ul>\n                  </div>\n                </div>\n                <div class=\"nav_subItem\">\n                  <div class=\"nav_subItem-img\">\n                    <a href=\"/sustainability/social/\"><img src=\"/img/common/nav/sus_04.jpg\" alt=\"社会 イメージ\"></a>\n                  </div>\n                  <div class=\"nav_subItem-txt\">\n                    <p><a href=\"/sustainability/social/\">社会</a></p>\n                    <ul>\n                      <li><a href=\"/sustainability/social/humanrights_policy.html\">・明星グループ人権方針</a></li>\n                      <li><a href=\"/sustainability/social/health.html\">・健康経営の推進</a></li>\n                      <li><a href=\"/sustainability/social/partnership.html\">・パートナーシップ構築宣言</a></li>\n                    </ul>\n                  </div>\n                </div>\n                <div class=\"nav_subItem\">\n                  <div class=\"nav_subItem-img\">\n                    <a href=\"/sustainability/governance/\"><img src=\"/img/common/nav/sus_05.jpg\" alt=\"ガバナンス イメージ\"></a>\n                  </div>\n                  <div class=\"nav_subItem-txt\">\n                    <p><a href=\"/sustainability/governance/\">ガバナンス</a></p>\n                    <ul>\n                      <li><a href=\"/sustainability/governance/#anc02\">・コーポレート・ガバナンス</a></li>\n                      <li><a href=\"/sustainability/governance/#anc03\">・コンプライアンス</a></li>\n                      <li><a href=\"/sustainability/governance/#anc04\">・リスクマネジメント</a></li>\n                      <li><a href=\"/corporate/officer/\">・役員紹介</a></li>\n                    </ul>\n                  </div>\n                </div>\n              </div><!--/nav_subList-->\n            </div>\n            <div class=\"nav_child_sp\">\n              <!-- <a><p class=\"title\">サステナビリティ</p></a> -->\n              <ul>\n                <li><a href=\"/sustainability/\">サステナビリティ</a></li>\n                <li><a href=\"/about/\">トップメッセージ</a></li>\n                <li><a href=\"/sustainability/concept/\">サステナビリティ方針／推進体制</a></li>\n                <li><a href=\"/sustainability/environment/\">環境</a></li>\n                <li><a href=\"/sustainability/social/\">社会</a></li>\n                <li><a href=\"/sustainability/governance/\">ガバナンス</a></li>\n              </ul>\n            </div>\n          </li>\n          <li><a class=\"hasChild\" href=\"/ir/\">IR情報<i class=\"fas fa-chevron-down\"></i></a>\n            <div class=\"nav_child\">\n              <p class=\"title\">IR情報</p>\n              <ul>\n                <li><a href=\"/ir/management/message/\"><img src=\"/img/common/nav/ir_01.jpg?2025070801\"><p class=\"name\">株主の皆さまへ</p></a></li>\n                <li><a href=\"/ir/library/\"><img src=\"/img/common/nav/ir_02.jpg\"><p class=\"name\">IRライブラリー</p></a></li>\n                <li><a href=\"/ir/management/\"><img src=\"/img/common/nav/ir_03.jpg\"><p class=\"name\">経営情報</p></a></li>\n                <li><a href=\"/ir/stock/\"><img src=\"/img/common/nav/ir_04.jpg\"><p class=\"name\">株式について</p></a></li>\n                <li><a href=\"/ir/finance/\"><img src=\"/img/common/nav/ir_05.jpg\"><p class=\"name\">財務ハイライト</p></a></li>\n                <li><a href=\"/ir/calender/\"><img src=\"/img/common/nav/ir_06.jpg\"><p class=\"name\">IRカレンダー</p></a></li>\n                <li><a href=\"/ir/faq/\"><img src=\"/img/common/nav/ir_07.jpg\"><p class=\"name\">よくあるご質問</p></a></li>\n                <li></li> <!-- dummy -->\n              </ul>\n              <ul class=\"nav_list--btn\">\n                <li><a href=\"/inquiry/\">IRお問い合わせ</a></li>\n                <li><a href=\"/ir/kokoku/\">電子広告</a></li>\n                <li><a href=\"/ir/immunity/\">免責事項</a></li>\n              </ul>\n            </div>\n            <div class=\"nav_child_sp\">\n              <!-- <a><p class=\"title\">IR情報</p></a> -->\n              <ul>\n                <li><a href=\"/ir/\">IR情報</a></li>\n                <li><a href=\"/ir/management/message/\">株主の皆さまへ</a></li>\n                <li><a href=\"/ir/library/\">IRライブラリー</a></li>\n                <li><a href=\"/ir/management/\">経営情報</a></li>\n                <li><a href=\"/ir/stock/\">株式について</a></li>\n                <li><a href=\"/ir/finance/\">財務ハイライト</a></li>\n                <li><a href=\"/ir/calender/\">IRカレンダー</a></li>\n                <li><a href=\"/ir/faq/\">よくあるご質問</a></li>\n                <li><a href=\"/inquiry/\">IRお問い合わせ</a></li>\n                <li><a href=\"/ir/kokoku/\">電子広告</a></li>\n                <li><a href=\"/ir/immunity/\">免責事項</a></li>\n              </ul>\n            </div>\n          </li>\n          <li><a class=\"hasChild\" href=\"/recruit/\">採用情報<i class=\"fas fa-chevron-down\"></i></a>\n            <div class=\"nav_child\">\n              <p class=\"title\">採用情報</p>\n              <ul>\n                <li><a href=\"/recruit/graduates/\"><img src=\"/img/common/nav/recruit_01.png\"><p class=\"name\">仕事内容を知る</p></a></li>\n                <li><a href=\"/recruit/talent/\"><img src=\"/img/common/nav/recruit_02.png\"><p class=\"name\">求める人材像</p></a></li>\n                <li><a href=\"/recruit/staff/\"><img src=\"/img/common/nav/recruit_03.png\"><p class=\"name\">スタッフ紹介</p></a></li>\n                <li><a href=\"/recruit/carrier/\"><img src=\"/img/common/nav/recruit_04.png\"><p class=\"name\">キャリアアップ</p></a></li>\n                <li><a href=\"/recruit/welfare/\"><img src=\"/img/common/nav/recruit_05.png\"><p class=\"name\">福利厚生</p></a></li>\n                <li><a href=\"/recruit/contacts/\"><img src=\"/img/common/nav/recruit_06.png\"><p class=\"name\">募集要項</p></a></li>\n                <li></li> <!-- dummy -->\n                <li></li> <!-- dummy -->\n              </ul>\n            </div>\n            <div class=\"nav_child_sp\">\n              <!-- <a href=\"/recruit/\"><p class=\"title\">採用情報</p></a> -->\n              <ul>\n                <li><a href=\"/recruit/\">採用情報</a></li>\n                <li><a href=\"/recruit/graduates/\">仕事内容を知る</a></li>\n                <li><a href=\"/recruit/talent/\">求める人材像</a></li>\n                <li><a href=\"/recruit/staff/\">スタッフ紹介</a></li>\n                <li><a href=\"/recruit/carrier/\">キャリアアップ</a></li>\n                <li><a href=\"/recruit/welfare/\">福利厚生</a></li>\n                <li><a href=\"/recruit/contacts/\">募集要項</a></li>\n              </ul>\n            </div>\n          </li>\n          <li class=\"tabsp\"><a href=\"/inquiry/\">お問い合わせ</a></li>\n          <li class=\"tabsp\"><a class=\"hasChild\">JP｜EN<i class=\"fas fa-chevron-down\"></i></a>\n            <div class=\"nav_child_sp\">\n              <ul>\n                <li class=\"tabsp\"><a class=\"disabled\" href=\"javascript:void(0);\"><span class=\"current\">JP</span></a></li>\n                <li class=\"tabsp\"><a href=\"/en/\">EN</a></li>\n              </ul>\n            </div>\n          </li>\n        </ul>\n      </div>\n      <div class=\"header_contact\">\n        <a href=\"/inquiry/\">お問い合わせ</a>\n      </div>\n    </div>\n    </div>\n  </header>\n  \r\n\r\n    <main>\r\n\r\n      <div class=\"mv\">\r\n        <div class=\"mv_img\"></div>\r\n        <div class=\"mv_wrapper\">\r\n          <div class=\"mv_text_wrapper\">\r\n            <h2 class=\"mv_text\">Staff Interview</h2>\r\n            <h3 class=\"mv_text\">先輩社員紹介</h3>\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n      <div class=\"sec_wrapper\">\r\n          <section class=\"sec sales\" id=\"sales\">\r\n            <div class=\"cont\">\r\n              <h3 class=\"recruit_title title_color_1\">Sales</h3>\r\n                <div class=\"recruit_subtitle\">営業の仕事</div>\r\n                <div class=\"text\">\r\n                  お客様の会社を訪問し、建設工事の情報入手あるいは断熱工事の提案、コンサルティングを行います。\r\n                  その情報を元に積算、見積を行いお客様との交渉を経て、受注に結び付けます。\r\n                  お客様の大部分は、プラント・化学・石油・食品等メーカー、電力・ガス会社など大手企業です。工事完了後、工事代金を回収するまでが営業の仕事です。\r\n                </div>\r\n                <div class=\"staff_block\">\r\n                  <div class=\"staff_bg_block\">\r\n                    <img class=\"sec_bg\" src=\"/img/recruit/staff/sales_bg.png\" alt=\"営業_背景\">\r\n                  </div>\r\n                  <!--\r\n                  <div class=\"staff\">\r\n                    <div class=\"img_block\">\r\n                      <img src=\"/img/recruit/staff/sales_img01.png\" alt=\"津田 昂亮\">\r\n                      <div class=\"voice\">Voice 01</div>\r\n                    </div>\r\n                    <div class=\"staff_message\">\r\n                      「次も一緒に仕事がしたい」<br>\r\n                      そう言っていただけることがとても嬉しい\r\n                    </div>\r\n                    <div class=\"staff_name\">2013年入社</div>\r\n                    <div class=\"staff_detail\">\r\n                      経営情報学部　経営情報学科卒業<br>\r\n                      所属部署：近畿・中部支店　四日市営業所\r\n                    </div>\r\n                    <div class=\"more\"><a href=\"/recruit/staff/sales.html#staff_01\">MORE<i class=\"fas fa-caret-right\"></i></a></div>\r\n                  </div>\r\n                  -->\r\n                  <div class=\"staff\">\r\n                    <div class=\"img_block\">\r\n                      <img src=\"/img/recruit/staff/sales_img02.png\" alt=\"生島 大地\">\r\n                      <div class=\"voice\">Voice 01</div>\r\n                    </div>\r\n                    <div class=\"staff_message\">\r\n                      営業から施工管理まで自分自身で一貫してやり遂げてみたい\r\n                    </div>\r\n                    <div class=\"staff_name\">2018年入社</div>\r\n                    <div class=\"staff_detail\">\r\n                      経済学部　経済学科卒業<br>\r\n                      所属部署：西部支店　水島営業所\r\n                    </div>\r\n                    <div class=\"more\"><a href=\"/recruit/staff/sales.html#staff_02\">MORE<i class=\"fas fa-caret-right\"></i></a></div>\r\n                  </div>\r\n                  <div class=\"staff\">\r\n                    <div class=\"img_block\">\r\n                      <img src=\"/img/recruit/staff/sales_img03.png\" alt=\"岩上 弘明\">\r\n                      <div class=\"voice\">Voice 02</div>\r\n                    </div>\r\n                    <div class=\"staff_message\">\r\n                      自分で仕事をこなしていく楽しみを感じる\r\n                    </div>\r\n                    <div class=\"staff_name\">2014年入社</div>\r\n                    <div class=\"staff_detail\">\r\n                      法学部　国際企業関係法学科卒業<br>\r\n                      所属部署：東京営業部　営業2課\r\n                    </div>\r\n                    <div class=\"more\"><a href=\"/recruit/staff/sales.html#staff_03\">MORE<i class=\"fas fa-caret-right\"></i></a></div>\r\n                  </div>\r\n                </div>\r\n              </div>\r\n          </section>\r\n\r\n          <section class=\"sec construction\" id=\"construction\">\r\n            <div class=\"cont\">\r\n              <h3 class=\"recruit_title title_color_2\">Construction</h3>\r\n                <div class=\"recruit_subtitle\">工事の仕事</div>\r\n                <div class=\"text\">\r\n                  工事の仕様書や計画に基づいて使用する資材と作業員の手配を行います。\r\n                  工事が始まると、安全、品質、工程、原価管理といった施工全般のマネジメントを行います。\r\n                  お客様や協力会社としっかりコミュニケーションをとり、作業をしやすい環境を作る事が重要です。\r\n                  仕様書通りに工事が終わるように細心の注意を払い管理し、工事終了後、お客様の検収を受けるまでが仕事です。\r\n                </div>\r\n                <div class=\"staff_block\">\r\n                  <div class=\"staff_bg_block\">\r\n                    <img class=\"sec_bg\" src=\"/img/recruit/staff/construction_bg.png\" alt=\"工事_背景\">\r\n                  </div>\r\n\r\n                  <div class=\"staff\">\r\n                    <div class=\"img_block\">\r\n                      <img src=\"/img/recruit/staff/construction_img01.png\" alt=\"阪田 紘貴\">\r\n                      <div class=\"voice\">Voice 01</div>\r\n                    </div>\r\n                    <div class=\"staff_message\">\r\n                      地球環境の保全にも大きく貢献\r\n                    </div>\r\n                    <div class=\"staff_name\">2014年入社</div>\r\n                    <div class=\"staff_detail\">\r\n                      経済学部　経済システム学科卒業<br>\r\n                      所属部署：工事部\r\n                    </div>\r\n                    <div class=\"more\"><a href=\"/recruit/staff/construction.html#staff_01\">MORE<i class=\"fas fa-caret-right\"></i></a></div>\r\n                  </div>\r\n\r\n                  <div class=\"staff\">\r\n                    <div class=\"img_block\">\r\n                      <img src=\"/img/recruit/staff/construction_img02.png\" alt=\"片岡 大\">\r\n                      <div class=\"voice\">Voice 02</div>\r\n                    </div>\r\n                    <div class=\"staff_message\">\r\n                      工事を最後までやり遂げた時の達成感\r\n                    </div>\r\n                    <div class=\"staff_name\">2017年入社</div>\r\n                    <div class=\"staff_detail\">\r\n                      工学部　機械工学科卒業<br>\r\n                      所属部署：工事部\r\n                    </div>\r\n                    <div class=\"more\"><a href=\"/recruit/staff/construction.html#staff_02\">MORE<i class=\"fas fa-caret-right\"></i></a></div>\r\n                  </div>\r\n                  <!--\r\n                  <div class=\"staff\">\r\n                    <div class=\"img_block\">\r\n                      <img src=\"/img/recruit/staff/construction_img03.png\" alt=\"名前名前\">\r\n                      <div class=\"voice\">Voice 03</div>\r\n                    </div>\r\n                    <div class=\"staff_message\">\r\n                      ダミーテキストダミーテキストダミーテキストダミーテキスト\r\n                    </div>\r\n                    <div class=\"staff_name\">名前名前</div>\r\n                    <div class=\"staff_detail\">\r\n                      ダミーテキストダミーテキストダミーテキスト<br>\r\n                      ダミーテキストダミーテキスト\r\n                    </div>\r\n                    <div class=\"more\"><a href=\"/recruit/staff/construction.html#staff_03\">MORE<i class=\"fas fa-caret-right\"></i></a></div>\r\n                  </div>\r\n                  -->\r\n                </div>\r\n              </div>\r\n          </section>\r\n\r\n          <section class=\"sec technical\" id=\"technical\">\r\n            <div class=\"cont\">\r\n              <h3 class=\"recruit_title title_color_3\">Technical</h3>\r\n                <div class=\"recruit_subtitle\">技術の仕事</div>\r\n                <div class=\"text\">\r\n                  断熱工事の施工方法や使用材料を検討し、熱計算や施工要領図・仕様書の作成を行います。\r\n                  また、お客様への説明や技術提案、現場への技術指導、材料の開発や性能試験なども行います。\r\n                  当社の根幹である断熱をはじめとする技術水準を日々高め、お客様の信頼を得るための礎となる仕事です。\r\n                </div>\r\n                <div class=\"staff_block\">\r\n                  <div class=\"staff_bg_block\">\r\n                    <img class=\"sec_bg\" src=\"/img/recruit/staff/technical_bg.png\" alt=\"技術_背景\">\r\n                  </div>\r\n                  <div class=\"staff\">\r\n                    <div class=\"img_block\">\r\n                      <img src=\"/img/recruit/staff/technical_img01.png\" alt=\"能冨 雄介\">\r\n                      <div class=\"voice\">Voice 01</div>\r\n                    </div>\r\n                    <div class=\"staff_message\">\r\n                      自ら学んだことを後輩たちに伝えていく\r\n                    </div>\r\n                    <div class=\"staff_name\">2010年入社</div>\r\n                    <div class=\"staff_detail\">\r\n                      工学部　化学工学科卒業<br>\r\n                      所属部署：技術統括部　東京技術課\r\n                    </div>\r\n                    <div class=\"more\"><a href=\"/recruit/staff/technical.html#staff_01\">MORE<i class=\"fas fa-caret-right\"></i></a></div>\r\n                  </div>\r\n                  <div class=\"staff\">\r\n                    <div class=\"img_block\">\r\n                      <img src=\"/img/recruit/staff/technical_img02.png\" alt=\"向井 真\">\r\n                      <div class=\"voice\">Voice 02</div>\r\n                    </div>\r\n                    <div class=\"staff_message\">\r\n                      高い技術力と多くの実績<br>\r\n                      それらを吸収して信頼される技術者に\r\n                    </div>\r\n                    <div class=\"staff_name\">2017年入社</div>\r\n                    <div class=\"staff_detail\">\r\n                      工学部　応用理工学科卒業<br>\r\n                      所属部署：技術統括部　大阪技術課\r\n                    </div>\r\n                    <div class=\"more\"><a href=\"/recruit/staff/technical.html#staff_02\">MORE<i class=\"fas fa-caret-right\"></i></a></div>\r\n                  </div>\r\n                  <div class=\"staff\">\r\n                    <div class=\"img_block\">\r\n                      <img src=\"/img/recruit/staff/technical_img03.png\" alt=\"高橋 一弘\">\r\n                      <div class=\"voice\">Voice 03</div>\r\n                    </div>\r\n                    <div class=\"staff_message\">\r\n                      自ら提案したテーマで仕事ができることが<br>\r\n                      大きなやりがい\r\n                    </div>\r\n                    <div class=\"staff_name\">2006年入社</div>\r\n                    <div class=\"staff_detail\">\r\n                      総合理工学研究科　物質系工学専攻博士課程修了<br>\r\n                      所属部署：技術統括部　中央研究所\r\n                    </div>\r\n                    <div class=\"more\"><a href=\"/recruit/staff/technical.html#staff_03\">MORE<i class=\"fas fa-caret-right\"></i></a></div>\r\n                  </div>\r\n                </div>\r\n              </div>\r\n          </section>\r\n      </div>\r\n\r\n      <div class=\"pageTop\"><a href=\"#wrapper\"><img src=\"/img/common/pagetop.png\" alt=\"pagetop\"></a></div>\n\n<footer class=\"footer\">\n\t<div class=\"footer_nav\">\n\t\t<ul>\n\t\t\t<li><a href=\"/\">TOP</a></li>\n\t\t\t<li class=\"pc\"><a href=\"/about/\">明星工業とは</a></li>\n\t\t</ul>\n\t\t<ul class=\"pc\">\n\t\t\t<li>事業紹介</li>\n\t\t\t<li class=\"sub\"><a href=\"/dannetsu/\">断熱分野</a></li>\n\t\t\t<li class=\"sub\"><a href=\"/kankyou/\">環境分野</a></li>\n\t\t\t<li class=\"sub\"><a href=\"/kaigai/\">海外分野</a></li>\n\t\t\t<li class=\"sub\"><a href=\"/seisan/\">生産分野</a></li>\n\t\t</ul>\n\t\t<ul class=\"pc\">\n\t\t\t<li><a href=\"/seihin/\">製品紹介</a></li>\n\t\t\t<li><a href=\"/corporate/\">会社情報</a></li>\n      <li><a href=\"/sustainability/\">サステナビリティ</a></li>\n\t\t\t<li><a href=\"/ir/\">IR情報</a></li>\n\t\t\t<li><a href=\"/recruit/\">採用情報</a></li>\n\t\t</ul>\n\t\t<ul>\n\t\t<li><a href=\"/sitemap/\">サイトマップ</a></li>\n\t\t\t<li class=\"pc\"><a href=\"/inquiry/\">お問い合わせ</a></li>\n\t\t<li><a href=\"/use/\">サイトのご利用について</a></li>\n\t\t<li><a href=\"/dataprotect/\">個人情報保護方針</a></li>\n\t\t</ul>\n\t</div>\n\n\t<div class=\"copyright\">\n\t\t<div class=\"copyright_wrapper\">\n\t\t\t<div class=\"footer_logo\"><img src=\"/img/common/footer_logo.png\"></div>\n\t\t\t<div class=\"footer_text\">© MEISEI INDUSTRIAL CO., LTD. All Right Reserved</div>\n\t\t</div>\n\t</div>\n\n</footer>\n\r\n\r\n    </main>\r\n\r\n  </div> <!--/wrapper-->\r\n\r\n</body>\r\n</html>\r\n","finalUrl":"https://www.meisei-kogyo.co.jp/recruit/staff/","rendered":false,"_cachedAt":"2026-06-22T17:25:33.341Z"}