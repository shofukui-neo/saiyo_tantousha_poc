{"url":"https://www.joyobank.co.jp/recruit/","html":"<!DOCTYPE html>\r\n<html lang=\"ja\" prefix=\"og: https://ogp.me/ns#\">\r\n<head>\r\n<!-- Google Tag Manager -->\r\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\r\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\r\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\r\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\r\n})(window,document,'script','dataLayer','GTM-N5L6XJP');</script>\r\n<!-- End Google Tag Manager -->\r\n<meta charset=\"utf-8\">\r\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=Edge\">\r\n<title>常陽銀行｜新卒採用情報</title>\r\n<meta name=\"description\" content=\"茨城県を地盤とする常陽銀行の新卒採用サイトです。茨城のメインバンクとして地域に貢献するプロジェクトストーリーやさまざまな業務に就く行員の仕事紹介、働く環境、採用情報などを掲載しています。\">\r\n<meta name=\"keywords\" content=\"常陽銀行,採用情報,新卒採用,新卒,インターンシップ,オープン・カンパニー,茨城,地方銀行,地銀,金融,メインバンク,トップバンク,Uターン,Iターン\">\r\n<meta name=\"author\" content=\"JOYO BANK,Ltd.\">\r\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\r\n<meta name=\"format-detection\" content=\"telephone=no, date=no, address=no\">\r\n<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\r\n<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\r\n<link href=\"/recruit/common/css/slick.css\" rel=\"stylesheet\">\r\n<link href=\"/recruit/common/css/slick-theme.css\" rel=\"stylesheet\">\r\n<link href=\"/recruit/common/css/aos.css\" rel=\"stylesheet\">\r\n<link href=\"/recruit/common/css/style.css\" rel=\"stylesheet\">\r\n<script src=\"/recruit/common/js/jquery-3.6.1.min.js\"></script>\r\n<script src=\"/recruit/common/js/jquery.easing.1.3.js\"></script>\r\n<script src=\"/recruit/common/js/scrollsmoothly.js\"></script>\r\n<script src=\"/recruit/common/js/slick.js\"></script>\r\n<script src=\"/recruit/common/js/jquery.cookie.js\"></script>\r\n<script src=\"/recruit/common/js/top.js\"></script>\r\n<script src=\"/recruit/common/js/basic.js\"></script>\r\n<link rel=\"shortcut icon\" href=\"/favicon.ico\" type=\"image/vnd.microsoft.icon\">\r\n<meta property=\"og:title\" content=\"常陽銀行｜新卒採用情報\">\r\n<meta property=\"og:url\" content=\"https://www.joyobank.co.jp/recruit/\">\r\n<meta property=\"og:image\" content=\"https://www.joyobank.co.jp/recruit/common/images/ogp.png\">\r\n<meta property=\"og:type\" content=\"article\">\r\n<meta property=\"og:locale\" content=\"ja_JP\">\r\n<meta name=\"twitter:card\" content=\"summary_large_image\">\r\n<meta name=\"twitter:title\" content=\"常陽銀行｜新卒採用情報\">\r\n<meta name=\"twitter:image\" content=\"https://www.joyobank.co.jp/recruit/common/images/ogp.png\">\r\n</head>\r\n\r\n<body id=\"top\" class=\"top\">\r\n<!-- Google Tag Manager (noscript) -->\r\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-N5L6XJP\" height=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\r\n<!-- End Google Tag Manager (noscript) -->\r\n\r\n<script src=\"/recruit/common/js/aos.js\"></script>\r\n<script>\r\n  if (window.AOS) { AOS.init({ duration: 1500, once: true, anchorPlacement: 'top-bottom' });\r\n  window.addEventListener('load', function () { AOS.refreshHard(); }); }\r\n</script>\r\n\r\n  <div id=\"assist\">\r\n    <p>ページの先頭です。</p>\r\n    <p><a href=\"#content\">本文へ移動する。</a></p>\r\n  <!-- /assist --></div>\r\n\r\n  <div id=\"headfix\">\r\n    <noscript><p>JavaScriptをONにしてください</p></noscript>\r\n    <header id=\"header\" aria-label=\"サイト内メニュー\" class=\"closed\">\r\n      <script src=\"/recruit/common/js/gnav.js\"></script>\r\n    </header>\r\n  <!-- /headfix --></div>\r\n\r\n  <div id=\"topmv_wrapeer\">\r\n    <div class=\"top_mv_cnt sc_animation\">\r\n      <div class=\"mv_cloud_s\"><img src=\"common/images/pic_top_mv_cloud_s.png\" alt=\"\"><img src=\"common/images/pic_top_mv_cloud_s.png\" alt=\"\"></div>\r\n      <div class=\"mv_cloud_l\"><img src=\"common/images/pic_top_mv_cloud_l.png\" alt=\"\"><img src=\"common/images/pic_top_mv_cloud_l.png\" alt=\"\"></div>\r\n      <div class=\"mv_sun\"><img src=\"common/images/pic_top_mv_sun.png\" alt=\"\"></div>\r\n      <div class=\"mv_build\">\r\n        <img src=\"common/images/pic_top_mv_build.png\" alt=\"\">\r\n        <div class=\"mv_tree\"><img src=\"common/images/pic_top_mv_tree.png\" alt=\"\"></div>\r\n        <ul class=\"mv_people\">\r\n          <li><img src=\"common/images/pic_top_mv_people1.png\" alt=\"\"></li>\r\n          <li><img src=\"common/images/pic_top_mv_people2.png\" alt=\"\"></li>\r\n          <li><img src=\"common/images/pic_top_mv_people3.png\" alt=\"\"></li>\r\n          <li><img src=\"common/images/pic_top_mv_people4.png\" alt=\"\"></li>\r\n          <li><img src=\"common/images/pic_top_mv_people5.png\" alt=\"\"></li>\r\n          <li><img src=\"common/images/pic_top_mv_people6.png\" alt=\"\"></li>\r\n          <li><img src=\"common/images/pic_top_mv_people7.png\" alt=\"\"></li>\r\n          <li><img src=\"common/images/pic_top_mv_people8.png\" alt=\"\"></li>\r\n        </ul>\r\n      </div>\r\n      <ul class=\"mv_cars\">\r\n        <li><img src=\"common/images/pic_top_mv_car1.png\" alt=\"\"></li>\r\n        <li><img src=\"common/images/pic_top_mv_car2.png\" alt=\"\"></li>\r\n        <li><img src=\"common/images/pic_top_mv_car3.png\" alt=\"\"></li>\r\n      </ul>\r\n      <div class=\"mv_copy_en\" lang=\"en\"><img src=\"common/images/idx_top_mv_title.png\" alt=\"\"></div>\r\n      <div class=\"mv_copy_jp\">\r\n        <img src=\"common/images/idx_top_mv_copy1.png\" alt=\"常に陽をあてる。いばらきの未来へ。\">\r\n        <img src=\"common/images/idx_top_mv_copy2.png\" alt=\"\">\r\n        <img src=\"common/images/idx_top_mv_copy3.png\" alt=\"\">\r\n        <img src=\"common/images/idx_top_mv_copy4.png\" alt=\"\">\r\n      </div>\r\n    </div>\r\n  <!-- /topmv_wrapeer --></div>\r\n\r\n  <div class=\"top_mv_space gnav_hide\" id=\"content\"></div>\r\n  <div class=\"top_lead_bg js-fadeby\" data-fadeby-base=\".top_lead\"></div>\r\n\r\n  <section class=\"top_lead gnav_hide\">\r\n    <p class=\"top_lead_txt\">かつて常陸の国と呼ばれたこの地で、太陽のように明るく、前向きに進みゆく存在に——。<br>\r\n常陽銀行は、そうした想いのもと設立されました。<br>\r\nそれから約90年、私たちは茨城県のトップバンクとしてこの地域の発展に貢献し、陽をあて続けてきました。<br>\r\n<br>\r\n茨城県は、首都圏に近く、交通インフラが充実し、人口増加が見込まれ、工場等の進出も活発な国内有数のポテンシャルの高い地域です。<br>\r\n私たちが果たすべき使命は、この地域が持つ可能性や力をもっともっと引き出し、この地域に常に陽をあて続けること。<br>\r\nそして、希望にあふれるいばらきの未来をつくりだしていくことです。<br>\r\n<br>\r\n少子高齢化、事業承継、SDGs、エネルギー…お客さまを取り巻く環境や社会構造が大きく変わる中、私たちにできることは、まだまだあります。<br>\r\n大切なのは、いばらきを愛し、ともにあゆむこと。そのために、どんなことにも前向きにチャレンジすること。<br>\r\n<br>\r\nあなたも、この地に陽をあてる存在となりませんか？いばらきの未来のために。</p>\r\n  <!-- /top_lead --></section>\r\n\r\n  <section class=\"top_cnt\">\r\n    <div class=\"bg_sky js-fadeby\" data-fadeby-base=\".top_for_title\"></div>\r\n    <div class=\"top_cnt_inner content_r\">\r\n      <h3 class=\"top_for_title\" data-aos=\"fade-up\" data-aos-delay=\"100\" lang=\"en\"><img src=\"common/images/idx_for_ibaraki.svg\" alt=\"For Ibaraki\"></h3>\r\n      <div class=\"for_slider_wrapper\">\r\n        <div class=\"for_slider common_slick\">\r\n          <a href=\"/recruit/for_ibaraki/\">\r\n            <div class=\"for_ph\" data-aos=\"fade-up\" data-aos-delay=\"100\">\r\n              <div class=\"for_ph_img\"><img src=\"for_ibaraki/images/mv_for01_01.png\" alt=\"\"></div>\r\n              <div class=\"for_ph_num\"><img src=\"for_ibaraki/images/idx_mv_prj_01.png\" alt=\"プロジェクト1\"></div>\r\n              <div class=\"for_ph_copy\"><img src=\"common/images/idx_top_prj_shoulder.png\" alt=\"\"></div>\r\n              <div class=\"btn_arrow_cir\"></div>\r\n            </div>\r\n            <p class=\"for_copy\" data-aos=\"fade-up\" data-aos-delay=\"100\">企業のDNAを可視化せよ。<br>地域に根付く２社だから編み出せた物語。</p>\r\n            <p class=\"for_title\" data-aos=\"fade-up\" data-aos-delay=\"100\"><img src=\"for_ibaraki/images/idx_for_prj_name01.png\" alt=\"ジョイフル本田さまの対外発信(IR)支援プロジェクト\"></p>\r\n          </a>\r\n          <a href=\"/recruit/for_ibaraki/project2.html\">\r\n            <div class=\"for_ph\" data-aos=\"fade-up\" data-aos-delay=\"100\">\r\n              <div class=\"for_ph_img\"><img src=\"for_ibaraki/images/mv_for02_01.png\" alt=\"\"></div>\r\n              <div class=\"for_ph_num\"><img src=\"for_ibaraki/images/idx_mv_prj_02.png\" alt=\"プロジェクト2\"></div>\r\n              <div class=\"for_ph_copy\"><img src=\"common/images/idx_top_prj_shoulder.png\" alt=\"\"></div>\r\n              <div class=\"btn_arrow_cir\"></div>\r\n            </div>\r\n            <p class=\"for_copy\" data-aos=\"fade-up\" data-aos-delay=\"100\">「働く人」を元気に。<br>それが、地域の未来を元気にする。</p>\r\n            <p class=\"for_title\" data-aos=\"fade-up\" data-aos-delay=\"100\"><img src=\"for_ibaraki/images/idx_for_prj_name02.png\" alt=\"福利厚生サービス「ベネサポ」アプリ開発プロジェクト\"></p>\r\n          </a>\r\n        </div>\r\n        <p class=\"for_slider_cloud1\"><img src=\"common/images/pic_top_01_02_1.png\" alt=\"\"></p>\r\n        <p class=\"for_slider_cloud2\"><img src=\"common/images/pic_top_01_02_2.png\" alt=\"\"></p>\r\n        <p class=\"for_slider_cloud3\"><img src=\"common/images/pic_top_01_02_3.png\" alt=\"\"></p>\r\n      </div>\r\n      <h3 class=\"top_joyolife_career_title\" data-aos=\"fade-up\" data-aos-delay=\"100\" lang=\"en\">\r\n        <span>SPECIAL MOVIE</span>\r\n        <img src=\"common/images/idx_movie.svg\" alt=\"Work at Joyo, Life in Ibaraki\">\r\n      </h3>\r\n      <div class=\"top_joblife_movie_wrapper_w100\" data-aos=\"fade-up\" data-aos-delay=\"100\">\r\n        <div class=\"top_joblife_marquee\" lang=\"en\"><span><img src=\"common/images/idx_joyolife_career_wh.svg\" alt=\"\"> </span><span><img src=\"common/images/idx_joyolife_career_wh.svg\" alt=\"\"> </span><span><img src=\"common/images/idx_joyolife_career_wh.svg\" alt=\"\"> </span></div>\r\n        <div class=\"top_joblife_movie_wrapper\">\r\n          <iframe width=\"560\" height=\"315\" src=\"https://www.youtube.com/embed/BN7N92_IFl8?si=MCx5SsNfaIJx2CGZ\" title=\"YouTube video player\" frameborder=\"0\" allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share\" referrerpolicy=\"strict-origin-when-cross-origin\" allowfullscreen></iframe>\r\n        </div>\r\n      </div>\r\n      <h3 class=\"top_reasons_title\" data-aos=\"fade-up\" data-aos-delay=\"100\" lang=\"en\">\r\n        <img src=\"common/images/idx_reasons.svg\" alt=\"Reasons\" class=\"comingsoon\">\r\n      </h3>\r\n      <p data-aos=\"fade-up\" data-aos-delay=\"200\"><span class=\"comingsoon\">常陽銀行を選んだ先輩たちの<br class=\"cnt_pc\">さまざまなホンネを聞いてみました！</span></p>\r\n      <div class=\"top_reasons_wrapper sc_animation popin comingsoon\">\r\n        <ul class=\"top_reasons_slider common_slick\">\r\n          <li><img src=\"common/images/pic_top_02_03.png\" alt=\"\"></li>\r\n          <li><img src=\"common/images/pic_top_02_04.png\" alt=\"\"></li>\r\n          <li><img src=\"common/images/pic_top_02_05.png\" alt=\"\"></li>\r\n          <li><img src=\"common/images/pic_top_02_06.png\" alt=\"\"></li>\r\n        </ul>\r\n        <div class=\"top_reasons_shoulder comingsoon\" data-aos=\"fade-up\" data-aos-delay=\"400\"><img src=\"common/images/pic_top_02_01.png\" alt=\"\"></div>\r\n        <div class=\"top_reasons_balloon sc_animation popin comingsoon\"><img src=\"common/images/pic_top_02_02.png\" alt=\"\"></div>\r\n        <div class=\"btn_reasons_more comingsoon\" data-aos=\"fade-up\" data-aos-delay=\"600\"><a href=\"/recruit/for_ibaraki/reasons.html\" class=\"comingsoon\">VIEW MORE</a></div>\r\n      </div>\r\n      <ul class=\"top_photo_slider\">\r\n        <li><img src=\"common/images/pic_topslide01.jpg\" alt=\"\"></li>\r\n        <li><img src=\"common/images/pic_topslide02.jpg\" alt=\"\"></li>\r\n        <li><img src=\"common/images/pic_topslide03.jpg\" alt=\"\"></li>\r\n        <li><img src=\"common/images/pic_topslide04.jpg\" alt=\"\"></li>\r\n        <li><img src=\"common/images/pic_topslide05.jpg\" alt=\"\"></li>\r\n        <li><img src=\"common/images/pic_topslide06.jpg\" alt=\"\"></li>\r\n        <li><img src=\"common/images/pic_topslide07.jpg\" alt=\"\"></li>\r\n      </ul>\r\n    <!-- /top_cnt_inner --></div>\r\n  <!-- /top_cnt --></section>\r\n\r\n  <section class=\"top_cnt\">\r\n    <div class=\"bg_gry js-fadeby\" data-fadeby-base=\".top_about_title\"></div>\r\n    <div class=\"top_cnt_inner content_r\">\r\n      <h3 class=\"top_about_title\" data-aos=\"fade-up\" data-aos-delay=\"100\" lang=\"en\">\r\n        <img src=\"common/images/idx_about.svg\" alt=\"For Ibaraki\" class=\"comingsoon\">\r\n        <span data-aos=\"fade-up\" data-aos-delay=\"100\"><span class=\"comingsoon\">いばらきの<br>トップバンクである<br>常陽銀行について紹介します。</span></span>\r\n      </h3>\r\n      <p data-aos=\"fade-up\" data-aos-delay=\"100\"><span class=\"comingsoon\">常陽銀行を知る</span></p>\r\n      <div class=\"top_about_column comingsoon\">\r\n        <div class=\"top_about_l\" data-aos=\"fade-up\" data-aos-delay=\"100\">\r\n          <div class=\"top_about_l_ph1\"><img src=\"common/images/pic_top_03_01.png\" alt=\"\"></div>\r\n          <div class=\"top_about_l_ph2 sc_animation popin\"><img src=\"common/images/pic_top_03_06.png\" alt=\"\"></div>\r\n        </div>\r\n        <div class=\"top_about_r\" data-aos=\"fade-up\" data-aos-delay=\"100\">\r\n          <div class=\"top_about_movie_wrapper\">\r\n            <video class=\"top_about_movie\" src=\"common/movie/225252_small.mp4\" autoplay muted playsinline loop></video>\r\n          </div>\r\n          <div class=\"top_about_btn_star\"><img src=\"common/images/pic_top_03_04.png\" alt=\"\"></div>\r\n          <ul class=\"top_about_btn\">\r\n            <li><a href=\"/recruit/about/\">はじめに</a></li>\r\n            <li><a href=\"/recruit/about/future.html\">私たちが陽をあてる未来</a></li>\r\n            <li><a href=\"/recruit/about/business.html\">教えて！銀行ビジネスの魅力とは？</a></li>\r\n          </ul>\r\n        </div>\r\n      </div>\r\n      <div class=\"top_about_b comingsoon\">\r\n        <div class=\"top_about_b_ph1\" data-aos=\"fade-up\" data-aos-delay=\"100\"><img src=\"common/images/pic_top_03_02.png\" alt=\"\"></div>\r\n        <div class=\"top_about_b_ph2\" data-aos=\"fade-up\" data-aos-delay=\"100\"><img src=\"common/images/pic_top_03_05.png\" alt=\"\"></div>\r\n      </div>\r\n      <h3 class=\"top_work_people_title\" lang=\"en\">\r\n        <img src=\"common/images/idx_work_people_2l.svg\" alt=\"Work and People\">\r\n        <span class=\"sc_animation popin\"><img src=\"common/images/pic_top_04_02.png\" alt=\"それぞれの場からいばらきに陽をあてる仕事を紹介します！\"></span>\r\n      </h3>\r\n      <p data-aos=\"fade-up\" data-aos-delay=\"100\">常陽銀行の人と仕事</p>\r\n      <div class=\"top_work\" data-aos=\"fade-up\" data-aos-delay=\"100\">\r\n        <img src=\"common/images/pic_top_04_01.png\" alt=\"\">\r\n        <div class=\"btn_work_more\" data-aos=\"fade-up\" data-aos-delay=\"600\"><a href=\"/recruit/work_people/\">業務・コース紹介</a></div>\r\n      </div>\r\n      <div class=\"top_people\" data-aos=\"fade-up\" data-aos-delay=\"100\">\r\n        <div class=\"top_people_slider common_slick\">\r\n          <div>\r\n            <div class=\"top_people_column\">\r\n              <div class=\"top_people_l\">\r\n                <img src=\"common/images/pic_top_04_pp01.png\" alt=\"\">\r\n              </div>\r\n              <div class=\"top_people_r\">\r\n                <p class=\"top_people_copy\">東京で大企業と向き合い<br>ダイナミックな支援へと<br>漕ぎ出す。</p>\r\n                <p class=\"top_people_name\">広瀬 竜兵</p>\r\n                <p class=\"top_people_prof\">東京営業部  営業第一部  営業第一課  課長代理<br>\r\n2013年入行 工学部卒</p>\r\n              </div>\r\n              <div class=\"btn_people_more \"><a href=\"/recruit/work_people/banker_sr.html\">VIEW MORE</a></div>\r\n            </div>\r\n          <!-- /slick-slide --></div>\r\n          <div>\r\n            <div class=\"top_people_column\">\r\n              <div class=\"top_people_l\">\r\n                <img src=\"common/images/pic_top_04_pp02.png\" alt=\"\">\r\n              </div>\r\n              <div class=\"top_people_r\">\r\n                <p class=\"top_people_copy\">お金を超えて、<br>暮らしを支え、<br>笑顔を増やしていく。</p>\r\n                <p class=\"top_people_name\">益子 美玲</p>\r\n                <p class=\"top_people_prof\">日高支店  係長<br>\r\n2017年入行 経済学部卒</p>\r\n              </div>\r\n              <div class=\"btn_people_more \"><a href=\"/recruit/work_people/banker_mm.html\">VIEW MORE</a></div>\r\n            </div>\r\n          <!-- /slick-slide --></div>\r\n          <div>\r\n            <div class=\"top_people_column\">\r\n              <div class=\"top_people_l\">\r\n                <img src=\"common/images/pic_top_04_pp03.png\" alt=\"\">\r\n              </div>\r\n              <div class=\"top_people_r\">\r\n                <p class=\"top_people_copy\">スペシャリストとして<br>培った専門スキルを、<br>店舗運営に昇華させていく。</p>\r\n                <p class=\"top_people_name\">山﨑 美帆</p>\r\n                <p class=\"top_people_prof\">高津リテールステーション  支店長<br>\r\n2003年入行 外国語学部卒</p>\r\n              </div>\r\n              <div class=\"btn_people_more \"><a href=\"/recruit/work_people/banker_ym.html\">VIEW MORE</a></div>\r\n            </div>\r\n          <!-- /slick-slide --></div>\r\n          <div>\r\n            <div class=\"top_people_column\">\r\n              <div class=\"top_people_l\">\r\n                <img src=\"common/images/pic_top_04_pp04.png\" alt=\"\">\r\n              </div>\r\n              <div class=\"top_people_r\">\r\n                <p class=\"top_people_copy\">自らチャンスを掴みにいき、<br>身につけた専門性で<br>企業の成長を支援。</p>\r\n                <p class=\"top_people_name\">宮澤 恵太</p>\r\n                <p class=\"top_people_prof\">コンサルティング営業部  調査役<br>\r\n2011年入行 法学部卒</p>\r\n              </div>\r\n              <div class=\"btn_people_more \"><a href=\"/recruit/work_people/banker_mk.html\">VIEW MORE</a></div>\r\n            </div>\r\n          <!-- /slick-slide --></div>\r\n          <div>\r\n            <div class=\"top_people_column\">\r\n              <div class=\"top_people_l\">\r\n                <img src=\"common/images/pic_top_04_pp05.png\" alt=\"\">\r\n              </div>\r\n              <div class=\"top_people_r\">\r\n                <p class=\"top_people_copy\">日本中の<br>大規模プロジェクトに貢献。<br>その専門性と経験を、<br>いばらきの未来に還す。</p>\r\n                <p class=\"top_people_name\">鈴木 康太</p>\r\n                <p class=\"top_people_prof\">ストラクチャードファイナンス部  調査役<br>\r\n2010年入行 第一文学部卒</p>\r\n              </div>\r\n              <div class=\"btn_people_more \"><a href=\"/recruit/work_people/banker_sk.html\">VIEW MORE</a></div>\r\n            </div>\r\n          <!-- /slick-slide --></div>\r\n          <div>\r\n            <div class=\"top_people_column\">\r\n              <div class=\"top_people_l\">\r\n                <img src=\"common/images/pic_top_04_pp06.png\" alt=\"\">\r\n              </div>\r\n              <div class=\"top_people_r\">\r\n                <p class=\"top_people_copy\">「自分を変えたい」。<br>その想いで挑み、<br>生きがいと呼べる仕事に<br>巡り合えた。</p>\r\n                <p class=\"top_people_name\">久松 加奈</p>\r\n                <p class=\"top_people_prof\">融資審査部  指導グループ 係長<br>\r\n2015年入行 経営学部卒</p>\r\n              </div>\r\n              <div class=\"btn_people_more \"><a href=\"/recruit/work_people/banker_hk.html\">VIEW MORE</a></div>\r\n            </div>\r\n          <!-- /slick-slide --></div>\r\n          <div>\r\n            <div class=\"top_people_column\">\r\n              <div class=\"top_people_l\">\r\n                <img src=\"common/images/pic_top_04_pp07.png\" alt=\"\">\r\n              </div>\r\n              <div class=\"top_people_r\">\r\n                <p class=\"top_people_copy\">茨城と海外をつなぎ、<br>「グローカル」な支援で<br>未来を拓く。</p>\r\n                <p class=\"top_people_name\">淺野 功貴</p>\r\n                <p class=\"top_people_prof\">市場国際部  係長<br>\r\n2017年入行 社会学部卒</p>\r\n              </div>\r\n              <div class=\"btn_people_more \"><a href=\"/recruit/work_people/banker_ak.html\">VIEW MORE</a></div>\r\n            </div>\r\n          <!-- /slick-slide --></div>\r\n        <!-- /top_people_slider --></div>\r\n        <div class=\"top_people_btn\"><a href=\"/recruit/work_people/banker.html\"><img src=\"common/images/pic_top_04_04.png\" alt=\"\"></a></div>\r\n      </div>\r\n      <h3 class=\"top_life_career_title\" lang=\"en\">\r\n        <img src=\"common/images/idx_life_career_2l.svg\" alt=\"Career and Life\">\r\n        <span class=\"top_life_career_ill2 sc_animation popin\"><img src=\"common/images/pic_top_05_04.png\" alt=\"\"></span>\r\n        <span class=\"top_life_career_ill1 sc_animation popin\"><img src=\"common/images/pic_top_05_03.png\" alt=\"\"></span>\r\n      </h3>\r\n      <p class=\"cnt_sp\" data-aos=\"fade-up\" data-aos-delay=\"100\">いばらきで働くということ</p>\r\n      <div class=\"top_life_career_column\">\r\n        <div class=\"top_life_career_l\">\r\n          <p class=\"cnt_pc\" data-aos=\"fade-up\" data-aos-delay=\"100\">いばらきで働くということ</p>\r\n          <ul class=\"top_life_career_btn\">\r\n            <li><a href=\"/recruit/life_career/\" class=\"comingsoon\">研修・キャリア</a></li>\r\n            <li><a href=\"/recruit/life_career/map.html\">キャリア&amp;ライフMAP</a></li>\r\n            <li><a href=\"/recruit/life_career/welfare.html\" class=\"comingsoon\">福利厚生</a></li>\r\n            <li><a href=\"/recruit/life_career/life.html\" class=\"comingsoon\">いばらきLIFEのススメ</a></li>\r\n          </ul>\r\n        </div>\r\n        <div class=\"top_life_career_r\">\r\n          <img src=\"common/images/pic_top_05_01.png\" alt=\"\">\r\n          <div class=\"top_life_career_r_ill sc_animation popin\"><img src=\"common/images/pic_top_05_02.png\" alt=\"\"></div>\r\n        </div>\r\n      </div>\r\n      <h3 class=\"top_recruit_title\" data-aos=\"fade-up\" data-aos-delay=\"100\" lang=\"en\">\r\n        <div>\r\n          <img src=\"common/images/idx_recruit.svg\" alt=\"Recruit\" class=\"comingsoon\">\r\n          <p data-aos=\"fade-up\" data-aos-delay=\"100\"><span class=\"comingsoon\">採用情報</span></p>\r\n        </div>\r\n        <ul class=\"top_recruit_btn comingsoon\">\r\n          <li><a hre