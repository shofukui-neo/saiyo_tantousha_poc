{"url":"https://www.sg-ud.co.jp/company/topmessage.php","html":"<!DOCTYPE HTML>\n<html class=\"no-js\" lang=\"ja\">\n\n<head>\n  <meta charset=\"utf-8\">\n  <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge,chrome=1\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n  <meta name=\"description\" content=\"西部ガス都市開発株式会社サイトのトップメッセージを掲載しています。\">\n  <meta name=\"author\" content=\"西部ガス都市開発株式会社\">\n  <meta name=\"copyright\" content=\"西部ガス都市開発株式会社\" />\n  <meta property=\"og:site_name\" content=\"西部ガス都市開発株式会社\">\n  <meta property=\"og:title\" content=\"企業情報 | トップメッセージ | 西部ガス都市開発株式会社\">\n  <meta property=\"og:description\" content=\"西部ガス都市開発株式会社サイトのトップメッセージを掲載しています。\">\n  <meta property=\"og:type\" content=\"website\">\n  <meta property=\"og:url\" content=\"https://www.sg-ud.co.jp/company/topmessage.php\">\n  <meta http-equiv=\"Pragma\" content=\"no-cache\" />\n  <meta http-equiv=\"Cache-Control\" content=\"no-cache\" />\n  <meta http-equiv=\"expires\" content=\"0\" />\n  <meta http-equiv=\"Imagetoolbar\" content=\"no\" />\n\n  <link rel=\"canonical\" href=\"https://www.sg-ud.co.jp/company/topmessage.php\">\n\n  <title>企業情報 | トップメッセージ | 西部ガス都市開発株式会社</title>\n\n  <!--================== read include ==================-->\n  <!-- set -->\n<link rel=\"home\" href=\"https://www.sg-ud.co.jp/\">\n<link rel=\"icon\" type=\"image/x-icon\" href=\"../images/common/fav.ico\">\n<link rel=\"shortcut icon\" type=\"image/x-icon\" sizes=\"32x32\" href=\"../images/common/fav.ico\">\n\n<!-- css -->\n<link rel=\"stylesheet\" href=\"../css/common.css\">\n<link rel=\"stylesheet\" href=\"../css/h_f2.css\">\n<link rel=\"stylesheet\" href=\"../css/top.css\">\n<link rel=\"stylesheet\" href=\"../css/content.css\">\n<link rel=\"stylesheet\" href=\"../css/content_new.css\">\n<link rel=\"stylesheet\" href=\"../css/drawer.css\">\n\n<link rel=\"stylesheet\" href=\"../css/custom.css\">\n\n<!--jQueryを読み込み-->\n<script src=\"https://ajax.googleapis.com/ajax/libs/jquery/3.7.0/jquery.min.js\"></script>\n\n<!-- animate -->\n<link href=\"https://unpkg.com/aos@2.3.1/dist/aos.css\" rel=\"stylesheet\">\n\n<!-- analytics -->\n<!-- Google tag (gtag.js) -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-W22JH7B309\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n\n  function gtag() {\n    dataLayer.push(arguments);\n  }\n  gtag('js', new Date());\n\n  gtag('config', 'G-W22JH7B309');\n</script>\n</head>\n\n<body class=\"company fadeout\">\n  <div class=\"blue-area\">\n    <a class=\"skip-link\" href=\"#main\">本文へスキップ</a>\n    <!--================== Header include ==================-->\n    <header class=\"header_n -custom\">\n  <div class=\"header-logo\">\n    <a href=\"../\"><img src=\"../images/new/header_logo.png\" alt=\"西部ガス都市開発株式会社\"></a>\n  </div>\n  <nav id=\"gnav\" aria-label=\"グローバルナビゲーション\">\n    <ul id=\"gnav-list\">\n      <li class=\"has-child\">\n        <a href=\"../company/\" class=\"gnav-link\">\n          <span>企業情報</span>\n        </a>\n        <button type=\"button\"\n          class=\"gnav-toggle\"\n          aria-expanded=\"false\"\n          aria-controls=\"gnav-company\" tabindex=\"-1\">\n          <span class=\"visually-hidden\">企業情報メニューを開く</span>\n        </button>\n        <ul id=\"gnav-company\" hidden>\n          <li><a href=\"../company/topmessage.php\">トップメッセージ</a></li>\n          <li><a href=\"../company/profile.php\">会社概要</a></li>\n          <li><a href=\"../company/history.php\">会社沿革</a></li>\n          <li><a href=\"../company/compliance.php\">経営理念</a></li>\n          <li><a href=\"../company/office_list.php\">事業所一覧</a></li>\n          <li><a href=\"../group/\">グループ企業</a></li>\n          <li><a href=\"../company/sustainability.php\">サステナビリティ</a></li>\n        </ul>\n      </li>\n      <li class=\"has-child\">\n        <button type=\"button\"\n          class=\"gnav-toggle\"\n          aria-expanded=\"false\"\n          aria-controls=\"gnav-business\">\n          <span>事業分野</span>\n        </button>\n        <ul id=\"gnav-business\" hidden>\n          <li><a href=\"../business/estate.php\">不動産事業</a></li>\n          <li><a href=\"../business/logistics.php\">物流事業</a></li>\n          <li><a href=\"../business/commercial_business.php\">商事事業</a></li>\n          <li><a href=\"../business/sports_business.php\">スポーツ・健康・店舗事業</a></li>\n        </ul>\n      </li>\n      <li><a href=\"../access/\"><span>アクセス</span></a></li>\n      <li><a href=\"https://www.sg-ud.co.jp/jobs/\"><span>採用情報</span></a></li>\n      <li class=\"contact\"><a href=\"../inquiry/\"><span>お問い合わせ</span></a></li>\n    </ul>\n  </nav>\n</header>\n\n\n<!--==================[ Header ]==================-->\n\n<div class=\"sp\">\n  <!-- ハンバーガーボタン -->\n  <button type=\"button\"\n    id=\"spMenuBtn\"\n    class=\"hamburger\"\n    aria-expanded=\"false\"\n    aria-controls=\"sp-drawer\"\n    aria-label=\"メニューを開く\">\n    <span class=\"hamburger-icon\" aria-hidden=\"true\"></span>\n  </button>\n  <!-- ドロワーメニュー -->\n  <nav id=\"sp-drawer\" class=\"drawer-list\" aria-label=\"スマートフォンメニュー\" hidden>\n    <ul id=\"accordion\" class=\"accordion-container\">\n      <li>\n        <a href=\"../\">\n          <img class=\"splogo\" src=\"../images/logo_square.png\" alt=\"TOPページ\">\n        </a>\n      </li>\n      <!-- 企業情報 -->\n      <li class=\"accordion-item\">\n        <div class=\"accordion-head\">\n          <a href=\"../company/\" class=\"accordion-link\">\n            企業情報\n          </a>\n          <button type=\"button\"\n            class=\"accordion-toggle\"\n            aria-expanded=\"false\"\n            aria-controls=\"sp-company\"\n            aria-label=\"企業情報メニューを開く\"\n            data-label-open=\"企業情報メニューを開く\"\n            data-label-close=\"企業情報メニューを閉じる\">\n          </button>\n        </div>\n        <div id=\"sp-company\" class=\"accordion-content\" hidden>\n          <p><a href=\"../company/topmessage.php\">トップメッセージ</a></p>\n          <p><a href=\"../company/profile.php\">会社概要</a></p>\n          <p><a href=\"../company/history.php\">会社沿革</a></p>\n          <p><a href=\"../company/compliance.php\">企業理念</a></p>\n          <p><a href=\"../company/office_list.php\">事業所一覧</a></p>\n          <p><a href=\"../group/\">グループ企業</a></p>\n          <p><a href=\"../company/sustainability.php\">サステナビリティ</a></p>\n        </div>\n      </li>\n      <!-- 事業案内 -->\n      <li class=\"accordion-item\">\n        <button type=\"button\"\n          class=\"accordion-toggle\"\n          aria-expanded=\"false\"\n          aria-controls=\"sp-business\"\n          aria-label=\"事業分野メニューを開く\"\n          data-label-open=\"事業分野メニューを開く\"\n          data-label-close=\"事業分野メニューを閉じる\">\n          事業分野\n        </button>\n        <div id=\"sp-business\" class=\"accordion-content\" hidden>\n          <p><a href=\"../business/estate.php\">不動産事業</a></p>\n          <p><a href=\"../business/sports_business.php\">スポーツ・健康・店舗事業</a></p>\n          <p><a href=\"../business/logistics.php\">物流事業</a></p>\n          <p><a href=\"../business/commercial_business.php\">商事事業</a></p>\n        </div>\n      </li>\n      <li><a href=\"../access/\">アクセス</a></li>\n      <li><a href=\"../jobs/\">採用情報</a></li>\n      <li><a href=\"../inquiry/\">お問い合わせ</a></li>\n      <li><a href=\"../privacy_policy.php\">プライバシーポリシー</a></li>\n      <li><a href=\"../customer_harassment.php\">カスタマーハラスメントに対する<br>基本方針</a></li>\n      <li class=\"bnr\">\n        <a href=\"https://sg-ud.meclib.jp/corpolateprofile/book/index.html\"\n          target=\"_blank\"\n          rel=\"noopener\"\n          aria-label=\"西部ガス都市開発デジタル会社案内（別ウィンドウで開きます）\">\n          <img src=\"../images/index/top_bnr_corporate-profile.jpg\" alt=\"\">\n        </a>\n      </li>\n    </ul>\n  </nav>\n</div>\n    <main id=\"main\" tabindex=\"-1\">\n\n      <div class=\"str-pageTitle\">\n        <div class=\"inner\">\n          <h1 class=\"hdg\">トップメッセージ\n            <!--<img src=\"../images/com_topmesse_h1.png\" alt=\"企業情報\">-->\n          </h1>\n          <p>TOP MESSAGE</p>\n        </div>\n      </div>\n      <nav aria-label=\"企業情報ページ内ナビゲーション\">\n        <ul>\n          <li class=\"ac\"><a href=\"./topmessage.php\" class=\"navigate-anchor\" aria-current=\"page\">トップメッセージ</a></li>\n          <li><a href=\"./profile.php\" class=\"navigate-anchor\">会社概要</a></li>\n          <li><a href=\"./history.php\" class=\"navigate-anchor\">会社沿革</a></li>\n          <li><a href=\"./compliance.php\" class=\"navigate-anchor\">経営理念</a></li>\n          <li><a href=\"./office_list.php\" class=\"navigate-anchor\">事業所一覧</a></li>\n        </ul>\n      </nav>\n\n      <section class=\"box \">\n\n        <div class=\"top_m_pc\">\n\n          <div class=\"w100\">\n            <img class=\"f_item\" src=\"../images/top_message_bg.jpg\" alt=\"\">\n            <div class=\"top_m_text text_waku\">\n              <h2>ごあいさつ</h2>\n              <p>平素より格別のご高配を賜り、厚く御礼申し上げます。</p>\n              <p>私たちは、西部ガスグループにおいて、ガスエネルギー事業に次ぐ収益の柱として一層の成長が期待されている「不動産」に加え、「物流」、「商事」、「スポーツ・健康・店舗事業」という非ガスエネルギーの4つの分野で幅広く事業を展開しています。</p>\n              <p>現在、事業環境は人口減少や少子高齢化、デジタル技術の進展、2050年のカーボンニュートラルに向けた潮流により持続可能な社会を目指すなど、大きく変化しています。</p>\n              <p>このような中、当社は「街づくりと暮らしの創造企業」として、社員一同「お客さま価値」を創造し続けられる企業になるべく、挑戦と進化を続けながら、地域社会の発展に貢献してまいります。</p>\n              <p>今後とも引き続きご支援とご愛顧を賜りますよう、心よりお願い申し上げます。</p>\n              <p class=\"ceo\">代表取締役社長<img src=\"../images/matsuda.png\" alt=\"代表取締役社長 松田和久\"></p>\n            </div>\n\n          </div>\n        </div>\n\n        <div class=\"top_m_sp\">\n\n          <div class=\"w40\">\n            <img class=\"f_item\" src=\"../images/top_message_bg_sp.jpg\" alt=\"\">\n          </div>\n          <div class=\"w60\">\n            <h2>ごあいさつ</h2>\n            <p>平素より格別のご高配を賜り、厚く御礼申し上げます。</p>\n            <p>私たちは、西部ガスグループにおいて、ガスエネルギー事業に次ぐ収益の柱として一層の成長が期待されている「不動産」に加え、「物流」、「商事」、「スポーツ健康」という非ガスエネルギーの4つの分野で幅広く事業を展開しています。</p>\n            <p>現在、事業環境は人口減少や少子高齢化、デジタル技術の進展、2050年のカーボンニュートラルに向けた潮流により持続可能な社会を目指すなど、大きく変化しています。</p>\n            <p>このような中、当社は「街づくりと暮らしの創造企業」として、社員一同「お客さま価値」を創造し続けられる企業になるべく、挑戦と進化を続けながら、地域社会の発展に貢献してまいります。</p>\n            <p>今後とも引き続きご支援とご愛顧を賜りますよう、心よりお願い申し上げます。</p>\n            <p><span>代表取締役社長<img src=\"../images/matsuda.png\" alt=\"代表取締役社長 松田和久\"></span></p>\n          </div>\n\n        </div>\n\n\n      </section>\n      <!--=====[ box ]=====-->\n\n    </main>\n    <!--==================[ main ]==================-->\n\n  </div>\n\n  <!--================== Footer include ==================-->\n  <footer class=\"\">\n  <div class=\"footer_inner\">\n    <div class=\"container-h_f\">\n      <div class=\"flex_n justify-be\">\n        <div class=\"f_logo_area\">\n          <img src=\"../images/new/footer_logo.png\" alt=\"西部ガス都市開発株式会社\">\n        </div>\n        <div class=\"f_nav_area flex_n justify-be\">\n          <ul class=\"f_nav01\">\n            <li class=\"tit\"><a href=\"../company/\">企業情報</a></li>\n            <li><a href=\"../company/topmessage.php\">トップメッセージ</a></li>\n            <li><a href=\"../company/profile.php\">会社概要</a></li>\n            <li><a href=\"../company/history.php\">会社沿革</a></li>\n            <li><a href=\"../company/compliance.php\">経営理念</a></li>\n            <li><a href=\"../company/office_list.php\">事業所一覧</a></li>\n            <li><a href=\"../group/\">グループ企業</a></li>\n            <li><a href=\"../company/sustainability.php\">サステナビリティ</a></li>\n          </ul>\n          <ul class=\"f_nav02\">\n            <li class=\"tit\"><span class=\"disabled\" aria-disabled=\"true\">事業分野</span></li>\n            <li><a href=\"../business/estate.php\">不動産事業</a></li>\n            <li><a href=\"../business/logistics.php\">物流事業</a></li>\n            <li><a href=\"../business/commercial_business.php\">商事事業</a></li>\n            <li><a href=\"../business/sports_business.php\">スポーツ・健康・店舗事業</a></li>\n          </ul>\n          <ul class=\"f_nav03\">\n            <li class=\"tit\"><a href=\"../access/\">アクセス</a></li>\n            <li class=\"tit\"><a href=\"../privacy_policy.php\">プライバシーポリシー</a></li>\n            <li class=\"tit\"><a href=\"../customer_harassment.php\">カスタマーハラスメントに対する<br>基本方針</a></li>\n            <li class=\"tit\"><a href=\"../accessibility/\">ウェブアクセシビリティ方針</a></li>\n            <li class=\"tit\"><a href=\"../sitemap.php\">サイトマップ</a></li>\n            <li class=\"tit\"><a href=\"../inquiry/\">お問い合わせ</a></li>\n          </ul>\n        </div>\n      </div>\n\n    </div>\n  </div>\n  <div id=\"goTop\">\n    <a href=\"#\">\n      <img src=\"../images/common/go-top.png\" alt=\"TOPに戻る\" loading=\"lazy\">\n    </a>\n  </div>\n  <div class=\"copyright\">\n    <div class=\"container-h_f\">\n      <small>Copyright © All Rights Reserved. 西部ガス都市開発株式会社</small>\n    </div>\n  </div>\n</footer>\n\n\n<!--========================================【 js 】========================================-->\n<!-- animate -->\n<script src=\"https://unpkg.com/aos@2.3.1/dist/aos.js\"></script>\n<script>\n  AOS.init();\n</script>\n\n<!--=======[ Custom ]=======-->\n<script src=\"../js/index.js\"></script>\n\n<!--=======[ Fade animate ]=======-->\n<script src=\"../js/jquery.inview.js\"></script>\n<script>\n  $(function() {\n    $('.v1 h1').on('inview', function(event, isInView) {\n      if (isInView) {\n        $(this).addClass('fadeInRight');\n      }\n    });\n  });\n</script>\n\n<!--=======[ Masonry ]=======-->\n<script src=\"../js/masonry.pkgd.min.js\"></script>\n<script src=\"../js/imagesloaded.pkgd.min.js\"></script>\n<script>\n  window.addEventListener('DOMContentLoaded', function() {\n    document.querySelectorAll('.box ul').forEach(function(box) {\n\n      if (box.classList.contains('nomasonry')) return;\n\n      imagesLoaded(box, function() {\n        new Masonry(box, {\n          itemSelector: '.panel',\n          percentPosition: true,\n          isAnimated: true\n        });\n      });\n\n    });\n  });\n</script>\n\n\n<!--=======[ Fade Masonry ]=======-->\n<script>\n  $(function() {\n    $(window).scroll(function() {\n      $('.fadein').each(function() {\n        var elemPos = $(this).offset().top;\n        var scroll = $(window).scrollTop();\n        var windowHeight = $(window).height();\n        if (scroll > elemPos - windowHeight - 200) {\n          $(this).addClass('scrollin');\n        }\n      });\n    });\n  });\n</script>\n\n\n\n<script>\n  document.addEventListener('DOMContentLoaded', () => {\n    document.querySelectorAll('#gnav .has-child').forEach((li) => {\n      const btn = li.querySelector('.gnav-toggle, .gnav-parent');\n      if (!btn) return;\n\n      const id = btn.getAttribute('aria-controls');\n      const panel = id ? document.getElementById(id) : null;\n      if (!panel) return;\n\n      // 初期は閉じる\n      btn.setAttribute('aria-expanded', 'false');\n      panel.hidden = true;\n\n      const openMenu = () => {\n        btn.setAttribute('aria-expanded', 'true');\n        panel.hidden = false;\n      };\n\n      const closeMenu = () => {\n        btn.setAttribute('aria-expanded', 'false');\n        panel.hidden = true;\n      };\n\n      // マウス\n      li.addEventListener('mouseenter', openMenu);\n      li.addEventListener('mouseleave', closeMenu);\n\n      // キーボードフォーカス\n      li.addEventListener('focusin', openMenu);\n      li.addEventListener('focusout', (e) => {\n        if (!li.contains(e.relatedTarget)) {\n          closeMenu();\n        }\n      });\n    });\n  });\n</script>\n\n\n\n<script>\n  document.addEventListener('DOMContentLoaded', () => {\n    const menuBtn = document.getElementById('spMenuBtn') || document.querySelector('.sp .hamburger');\n    const drawer = document.getElementById('sp-drawer') || document.getElementById('spMenuPanel');\n\n    if (!menuBtn || !drawer) return;\n\n    const TRANSITION_MS = 450; // drawer.cssに合わせて調整\n    const focusableSelector = [\n      'a[href]',\n      'button:not([disabled])',\n      'input:not([disabled])',\n      'select:not([disabled])',\n      'textarea:not([disabled])',\n      '[tabindex]:not([tabindex=\"-1\"])'\n    ].join(',');\n\n    let lastActiveEl = null;\n    let scrollY = 0;\n\n    const getFocusable = () =>\n      Array.from(drawer.querySelectorAll(focusableSelector))\n      .filter(el => !el.hasAttribute('disabled') && el.offsetParent !== null);\n\n    const main = document.getElementById('main'); // ← 追加（main要素）\n\n    const openMenu = () => {\n      lastActiveEl = document.activeElement;\n\n      drawer.hidden = false;\n\n      // 🔧 これを追加（アニメ保証トリガー）\n      drawer.offsetHeight;\n\n      // 背景スクロール位置を保存し、固定\n      scrollY = window.scrollY || window.pageYOffset || 0;\n      document.body.classList.add('is-menu-open');\n      document.body.style.position = 'fixed';\n      document.body.style.top = `-${scrollY}px`;\n      document.body.style.left = '0';\n      document.body.style.right = '0';\n      document.body.style.width = '100%';\n\n      requestAnimationFrame(() => {\n        drawer.classList.add('is-open');\n      });\n\n      menuBtn.setAttribute('aria-expanded', 'true');\n      menuBtn.setAttribute('aria-label', 'メニューを閉じる');\n\n      // フォーカスをトリガーに戻す（OK）\n      menuBtn.focus();\n\n      if (main) main.setAttribute('aria-hidden', 'true');\n    };\n\n\n\n    const closeMenu = () => {\n      drawer.classList.remove('is-open');\n      menuBtn.setAttribute('aria-expanded', 'false');\n      menuBtn.setAttribute('aria-label', 'メニューを開く');\n\n      // アニメ後にhidden\n      window.setTimeout(() => {\n        drawer.hidden = true;\n\n        // ✅ 追加：本文の aria-hidden を戻す\n        if (main) main.removeAttribute('aria-hidden');\n\n        // 背景固定解除して元の位置に戻す\n        document.body.classList.remove('is-menu-open');\n        const top = document.body.style.top;\n        document.body.style.position = '';\n        document.body.style.top = '';\n        document.body.style.left = '';\n        document.body.style.right = '';\n        document.body.style.width = '';\n        window.scrollTo(0, parseInt(top || '0', 10) * -1);\n\n        // フォーカス戻し\n        (lastActiveEl || menuBtn).focus();\n      }, TRANSITION_MS);\n    };\n\n\n    const isOpen = () => menuBtn.getAttribute('aria-expanded') === 'true';\n\n    menuBtn.addEventListener('click', () => {\n      isOpen() ? closeMenu() : openMenu();\n    });\n\n    // ESCで閉じる\n    document.addEventListener('keydown', (e) => {\n      if (!isOpen()) return;\n\n      if (e.key === 'Escape') {\n        e.preventDefault();\n        closeMenu();\n        return;\n      }\n\n      // Spaceで背景が動くのを防ぐ（フォーカスがメニュー内にある前提）\n      if (e.key === ' ' || e.code === 'Space') {\n        // フォーカスがリンク/ボタン等にある場合は本来の操作を邪魔しない\n        const t = e.target;\n        const isInteractive =\n          t && (t.tagName === 'BUTTON' || t.tagName === 'A' || t.tagName === 'INPUT' || t.tagName === 'TEXTAREA' || t.tagName === 'SELECT');\n        if (!isInteractive) e.preventDefault();\n      }\n\n      // フォーカストラップ（Tabで外に出ない）\n      if (e.key === 'Tab') {\n        // 「閉じるボタン + メニュー内」のフォーカス可能要素をまとめる\n        const focusables = [menuBtn, ...getFocusable()].filter(Boolean);\n\n        if (focusables.length === 0) {\n          e.preventDefault();\n          return;\n        }\n\n        const first = focusables[0]; // menuBtn\n        const last = focusables[focusables.length - 1];\n\n        // 現在がどこか\n        const current = document.activeElement;\n\n        // Shift+Tabで先頭（menuBtn）から戻る→最後へ\n        if (e.shiftKey && current === first) {\n          e.preventDefault();\n          last.focus();\n          return;\n        }\n\n        // Tabで最後から進む→先頭（menuBtn）へ\n        if (!e.shiftKey && current === last) {\n          e.preventDefault();\n          first.focus();\n          return;\n        }\n      }\n    });\n\n    // クリック外で閉じる（必要なら）\n    document.addEventListener('click', (e) => {\n      if (!isOpen()) return;\n      if (e.target.closest('#sp-drawer') || e.target.closest('.sp .hamburger')) return;\n\n      closeMenu();\n    });\n\n    // アコーディオン\n    // アコーディオン（アニメ対応）\n    document.querySelectorAll('.accordion-toggle').forEach((btn) => {\n\n      const id = btn.getAttribute('aria-controls');\n      const panel = id ? document.getElementById(id) : null;\n      if (!panel) return;\n\n      // 初期状態\n      btn.setAttribute('aria-expanded', 'false');\n      panel.hidden = true;\n      panel.style.maxHeight = '0px';\n      panel.classList.remove('is-expanded');\n\n      const openPanel = () => {\n        btn.setAttribute('aria-expanded', 'true');\n        btn.setAttribute('aria-label', btn.dataset.labelClose || 'メニューを閉じる');\n\n        panel.hidden = false;\n        panel.style.maxHeight = '0px';\n        panel.classList.add('is-expanded');\n\n        requestAnimationFrame(() => {\n          panel.style.maxHeight = panel.scrollHeight + 'px';\n        });\n      };\n\n      const closePanel = () => {\n        btn.setAttribute('aria-expanded', 'false');\n        btn.setAttribute('aria-label', btn.dataset.labelOpen || 'メニューを開く');\n\n        panel.style.maxHeight = panel.scrollHeight + 'px';\n        requestAnimationFrame(() => {\n          panel.style.maxHeight = '0px';\n          panel.classList.remove('is-expanded');\n        });\n\n        const onEnd = (e) => {\n          if (e.propertyName !== 'max-height') return;\n          panel.hidden = true;\n          panel.removeEventListener('transitionend', onEnd);\n        };\n        panel.addEventListener('transitionend', onEnd);\n      };\n\n      btn.addEventListener('click', () => {\n        const expanded = btn.getAttribute('aria-expanded') === 'true';\n        expanded ? closePanel() : openPanel();\n      });\n\n      // 画面回転・リサイズ時：開いているパネルの高さを再計算\n      window.addEventListener('resize', () => {\n        if (btn.getAttribute('aria-expanded') === 'true') {\n          panel.style.maxHeight = panel.scrollHeight + 'px';\n        }\n      });\n    });\n\n  });\n</script>\n\n<script>\n  document.addEventListener('DOMContentLoaded', () => {\n    const triggers = document.querySelectorAll('.office-acc-trigger');\n    if (!triggers.length) return;\n\n    const DURATION = 350; // CSSのmax-height transition と合わせる\n\n    triggers.forEach((btn) => {\n      const id = btn.getAttribute('aria-controls');\n      const panel = id ? document.getElementById(id) : null;\n      if (!panel) return;\n\n      // 初期状態を必ず閉じる\n      btn.setAttribute('aria-expanded', 'false');\n      panel.classList.remove('is-open');\n      panel.hidden = true;\n      panel.style.maxHeight = '0px';\n\n      const open = () => {\n        btn.setAttribute('aria-expanded', 'true');\n        panel.hidden = false;\n        panel.classList.add('is-open');\n\n        // 1) 念のため初期化\n        panel.style.maxHeight = '0px';\n\n        // 2) 強制リフロー\n        panel.offsetHeight;\n\n        // 3) 実サイズまで展開\n        panel.style.maxHeight = panel.scrollHeight + 'px';\n\n        // 4) 開き切ったら制限解除（高さ変動に強くする）\n        window.setTimeout(() => {\n          if (btn.getAttribute('aria-expanded') === 'true') {\n            panel.style.maxHeight = 'none';\n          }\n        }, DURATION + 50);\n      };\n\n      const close = () => {\n        btn.setAttribute('aria-expanded', 'false');\n        panel.classList.remove('is-open');\n\n        // 1) いったん現在高さを固定\n        panel.style.maxHeight = panel.scrollHeight + 'px';\n\n        // 2) 強制リフロー（これが重要）\n        panel.offsetHeight; // eslint-disable-line no-unused-expressions\n\n        // 3) 0へ（transition確実に走る）\n        panel.style.maxHeight = '0px';\n\n        // 4) transitionendに頼らず確実にhiddenへ\n        window.setTimeout(() => {\n          // 閉じたままなら隠す\n          if (btn.getAttribute('aria-expanded') === 'false') {\n            panel.hidden = true;\n          }\n        }, DURATION + 50);\n      };\n\n\n\n\n\n      btn.addEventListener('click', () => {\n        const expanded = btn.getAttribute('aria-expanded') === 'true';\n        expanded ? close() : open();\n      });\n\n      // 開いている時だけリサイズ再計算\n      window.addEventListener('resize', () => {\n        if (btn.getAttribute('aria-expanded') === 'true') {\n          panel.style.maxHeight = panel.scrollHeight + 'px';\n        }\n      });\n    });\n  });\n</script>\n\n<script>\n  document.addEventListener('DOMContentLoaded', () => {\n    const triggers = document.querySelectorAll('.group-acc-trigger');\n    if (!triggers.length) return;\n\n    const DURATION = 350; // CSSのtransition時間に合わせる（未設定ならこのままでもOK）\n\n    triggers.forEach((btn) => {\n      const id = btn.getAttribute('aria-controls');\n      const panel = id ? document.getElementById(id) : null;\n      if (!panel) return;\n\n      // 初期は閉じる\n      btn.setAttribute('aria-expanded', 'false');\n      panel.hidden = true;\n      panel.style.maxHeight = '0px';\n\n      const open = () => {\n        btn.setAttribute('aria-expanded', 'true');\n        panel.hidden = false;\n\n        panel.style.maxHeight = '0px';\n        panel.offsetHeight; // reflow\n        panel.style.maxHeight = panel.scrollHeight + 'px';\n\n        window.setTimeout(() => {\n          if (btn.getAttribute('aria-expanded') === 'true') {\n            panel.style.maxHeight = 'none';\n          }\n        }, DURATION + 50);\n      };\n\n      const close = () => {\n        btn.setAttribute('aria-expanded', 'false');\n\n        // none対策：数値に戻してから閉じる\n        panel.style.maxHeight = panel.scrollHeight + 'px';\n        panel.offsetHeight;\n        panel.style.maxHeight = '0px';\n\n        window.setTimeout(() => {\n          if (btn.getAttribute('aria-expanded') === 'false') {\n            panel.hidden = true;\n          }\n        }, DURATION + 50);\n      };\n\n      btn.addEventListener('click', () => {\n        const expanded = btn.getAttribute('aria-expanded') === 'true';\n        expanded ? close() : open();\n      });\n\n      window.addEventListener('resize', () => {\n        if (btn.getAttribute('aria-expanded') === 'true' && panel.style.maxHeight !== 'none') {\n          panel.style.maxHeight = panel.scrollHeight + 'px';\n        }\n      });\n    });\n  });\n</script>\n\n<script>\n  document.addEventListener('DOMContentLoaded', () => {\n    const skip = document.querySelector('.skip-link');\n    const main = document.getElementById('main');\n\n    if (!skip || !main) return;\n\n    skip.addEventListener('click', () => {\n      main.setAttribute('tabindex', '-1');\n      main.focus({\n        preventScroll: true\n      });\n    });\n  });\n</script>\n\n\n\n\n\n<!--=======[ go top]======= -->\n<script src=\"../js/base.js\"></script>\n\n</body>\n\n</html>","finalUrl":"https://www.sg-ud.co.jp/company/topmessage.php","rendered":false,"_cachedAt":"2026-06-22T19:45:37.327Z"}