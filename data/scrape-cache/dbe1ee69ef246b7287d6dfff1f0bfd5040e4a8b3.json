_st__ls__bd\">\r\n                    <ul class=\"footer__t__st__ls__bd__ls\">\r\n                      <li><a href=\"culture.html\"><span>企業文化</span></a></li>\r\n                      <li><a href=\"illword.html\"><span>アイル語</span></a></li>\r\n                    </ul>\r\n                  </div>\r\n                </li>\r\n              </ul>\r\n            </div>\r\n            <div class=\"footer__t__st\">\r\n              <ul class=\"footer__t__st__ls\">\r\n                <li>\r\n                  <div class=\"footer__t__st__ls__hd\"><a href=\"business.html\"><span class=\"c-navText\"><span class=\"__en\">BUSINESS</span><span class=\"__ja\">仕事を知る</span></span></a></div>\r\n                  <div class=\"footer__t__st__ls__bd\">\r\n                    <ul class=\"footer__t__st__ls__bd__ls\">\r\n                      <li><a href=\"business.html\"><span>ビジネスモデル</span></a></li>\r\n                      <li><a href=\"job.html\"><span>職種紹介</span></a></li>\r\n                    </ul>\r\n                  </div>\r\n                </li>\r\n              </ul>\r\n            </div>\r\n            <div class=\"footer__t__st\">\r\n              <ul class=\"footer__t__st__ls\">\r\n                <li>\r\n                  <div class=\"footer__t__st__ls__hd\"><a href=\"member.html\"><span class=\"c-navText\"><span class=\"__en\">MEMBER</span><span class=\"__ja\">人を知る</span></span></a></div>\r\n                  <div class=\"footer__t__st__ls__bd\">\r\n                    <ul class=\"footer__t__st__ls__bd__ls\">\r\n                      <li><a href=\"member.html\"><span>社員紹介</span></a></li>\r\n                      <li><a href=\"interview/index.html\"><span>若手社員の声</span></a></li>\r\n                    </ul>\r\n                  </div>\r\n                </li>\r\n              </ul>\r\n            </div>\r\n            <div class=\"footer__t__st\">\r\n              <ul class=\"footer__t__st__ls\">\r\n                <li>\r\n                  <div class=\"footer__t__st__ls__hd\"><a href=\"requirements.html\"><span class=\"c-navText\"><span class=\"__en\">RECRUIT</span><span class=\"__ja\">採用情報</span></span></a></div>\r\n                  <div class=\"footer__t__st__ls__bd\">\r\n                    <ul class=\"footer__t__st__ls__bd__ls\">\r\n                      <li><a href=\"requirements.html\"><span>募集要項</span></a></li>\r\n                      <li><a href=\"education.html\"><span>教育・評価制度</span></a></li>\r\n                      <li><a href=\"welfare.html\"><span>福利厚生</span></a></li>\r\n                      <li><a href=\"faq.html\"><span>採用FAQ</span></a></li>\r\n                    </ul>\r\n                  </div>\r\n                </li>\r\n              </ul>\r\n            </div>\r\n            <div class=\"footer__t__st\">\r\n              <ul class=\"footer__t__st__ls\">\r\n                <li>\r\n                  <div class=\"footer__t__st__ls__hd\"><a href=\"company.html\"><span class=\"c-navText\"><span class=\"__en\">COMPANY</span><span class=\"__ja\">会社概要</span></span></a></div>\r\n                </li>\r\n              </ul>\r\n            </div>\r\n            <div class=\"footer__t__st\">\r\n              <ul class=\"footer__t__st__ls\">\r\n                <li>\r\n                  <div class=\"footer__t__st__ls__hd\"><a href=\"https://www.ill.co.jp/recruit/entry_select.html\"><span class=\"c-navText\"><span class=\"__en\">ENTRY</span><span class=\"__ja\">エントリー</span></span></a></div>\r\n                </li>\r\n              </ul>\r\n            </div>\r\n          </nav>\r\n          <a href=\"https://www.ill.co.jp/\" class=\"page-link\"><img src=\"images/corporate.png\" alt=\"株式会社アイルコーポレートサイト\"></a>\r\n\t\t\t          <a href=\"https://www.ill.co.jp/recruit/internship/\" class=\"page-link\"><img src=\"images/intern.png\" alt=\"株式会社アイルインターン情報サイト\"></a>\r\n\t\t  </div>\r\n      </div>\r\n    </nav>\r\n    <div class=\"g-nav-bg\"></div>\r\n  </div>\r\n  <!--スマホヘッダー終了--> \r\n</header>\r\n<section class=\"top\">\r\n  <button class=\"entry_btn\">\r\n  <div class=\"entry_btn_in\">\r\n  <span class=\"h__en\"><a href=\"\" class=\"in-the-page\">ENTRY</a></span><span class=\"subtitle\">エントリー</span>\r\n  </div>\r\n  </button>\r\n</section>\r\n<div id=\"job\">\r\n\t<section class=\"key_visual bg__gradation\">\r\n\t\t<div class=\"page_title bg_in\">\r\n\t\t\t<div class=\"title_area\">\r\n\t\t\t\t<span class=\"subtitle__en\">BUSINESS</span>\r\n\t\t\t\t<span class=\"subtitle\">仕事を知る</span>\r\n\t\t\t</div>\r\n\t\t\t<h2>職種紹介</h2>\r\n\t\t</div>\r\n\t</section>\r\n  <section class=\"main main_top bg__b solution\">\r\n\t\t<div class=\"main_cont\">\r\n\t\t\t<h3 class=\"cont_title\"><span class=\"h__en\">SOLUTION＆PRODUCT</span>システムを知る</h3>\r\n      <h4>－リアルとWebの両システムを独自で開発・提供できるのは「アイルだけ」</h4>\r\n      <p>実店舗（=リアル）でもネットショップ（=Web）でも買物ができて当たり前だと思っていませんか？<br></p>\r\n      <p class=\"Lead_text\">売手側は、販売窓口が増えると、モノ（在庫）やお金（売上・決済・ポイント等）の管理が煩雑になります。<br>経営において、モノやお金の状況・動きをいかに統合的に管理できるかがとても重要で、その実現のためにシステムの活用が大きな鍵となっています。<br><br>アイルではリアルとWeb、さらには両システムを一元管理するシステムまでを自社開発しているため、お客様の業務効率化と企業力強化に大きく貢献しています。<br>ほかにも、企業間取引ではまだ電話やFAXでのアナログ注文が主流ですが、ネットショップのようにデジタル注文を可能にするシステムや、ホームページ制作等のブランディング領域まで、幅広く経営のお手伝いをしています。<br><br>\r\n        <a href=\"#product\" class=\"btn a__m_top modal-open modalLink\">\r\n          <span class=\"round_arrow\">もっと詳しく知る</span>\r\n        </a>\r\n      </p>\r\n\t\t</div>\r\n\t</section>\r\n\t<section class=\"main bg__w workflow\">\r\n\t\t<div class=\"main_cont\">\r\n      <h3 class=\"cont_title\"><span class=\"h__en\">WORKFLOW</span>流れを知る</h3>\r\n      <p>主な業務内容と職種の紹介です。<br>IT企業と言っても、社員全員がパソコンに向かってプログラミングをしているわけではありません。<br>どの職種も文理不問で、研修制度が充実しているため、未経験からのスタートで活躍している社員も多くいます。</p>\r\n    </div>\r\n    <div class=\"scroll-box\">\r\n      <img class=\"workflow_img\" src=\"images/job/workflow.png\" alt=\"業務内容\">\r\n      <img class=\"jobflow_img\" src=\"images/job/jobflow.png\" alt=\"職種を知る\">\r\n    </div>\r\n    <div class=\"main_cont\">\r\n      <p>アイルでは「製販一体」という考えのもと、実際はさまざまな職種間で協力して取り組んでいます。<br>それは、アイルの提供するサービスがお客様の根本的な課題解決に貢献し、その後もスムーズにサポートできているのか、全社員が責任感を持って真剣に向き合っているからです。<br>システムをただ売って終わりにするのではなく、お客様と一緒に向き合う「フィフティ・フィフティ」の姿勢を大切にしています。</p><p>品質を高く保つシステムエンジニア・プログラマーの他にも、お客様が気づかない領域まで課題を発掘・提案する営業や、安心してシステムをお使いいただく手助けをするサポート、全社的に支える経営管理・企画部門などさまざまな職種があり、皆で協力しあって最高のパフォーマンスを発揮します。</p>\r\n    </div>\r\n  </section>\r\n  <section class=\"main bg__b job_intr cont_bottom o_hidden\">\r\n    <div class=\"main_cont\">\r\n      <h3 class=\"cont_title\"><span class=\"h__en\">JOB INTRODUCTION</span>職種を知る</h3>\r\n    <p>職種名をクリックすると詳細を見ることができます。</p>\r\n      <div class=\"column4\">\r\n        <div class=\"col cont__white\">\r\n          <img src=\"images/job/job_icon01.png\" alt=\"営業職\">\r\n          <h4 class=\"box_title box_title_c\">営業職</h4>\r\n          <ul>\r\n            <li class=\"color__ss\"><a href=\"#con1\" class=\"modal-open modalLink\">ITソリューション営業</a></li>\r\n            <li class=\"color__ss\"><a href=\"#con1\" class=\"modal-open modalLink\">パートナー営業</a></li>\r\n            <li class=\"color__web\"><a href=\"#con1\" class=\"modal-open modalLink\">カスタマーサクセス</a></li>\r\n          </ul><a href=\"#con1\" class=\"job_arrow modal-open modalLink\"></a>\r\n        </div>\r\n        <div class=\"col cont__white\">\r\n          <img src=\"images/job/job_icon02.png\" alt=\"技術サポート職\">\r\n          <h4 class=\"box_title box_title_c\">技術サポート職</h4>\r\n          <ul>\r\n            <li class=\"color__se\"><a href=\"#con2\" class=\"modal-open modalLink\">システムエンジニア</a></li>\r\n            <li class=\"color__se\"><a href=\"#con2\" class=\"modal-open modalLink\">ネットワーク<br>エンジニア</a></li>\r\n            <li class=\"color__web\"><a href=\"#con2\" class=\"modal-open modalLink\">カスタマーサクセス</a></li>\r\n          </ul><a href=\"#con2\" class=\"job_arrow modal-open modalLink\"></a>\r\n        </div>\r\n        <div class=\"col cont__white\">\r\n          <img src=\"images/job/job_icon03.png\" alt=\"技術職\">\r\n          <h4 class=\"box_title box_title_c\">技術職</h4>\r\n          <ul>\r\n            <li class=\"color__pg\"><a href=\"#con3\" class=\"modal-open modalLink\">プログラマー・<br>製品開発</a></li>\r\n            <li class=\"color__pg\"><a href=\"#con3\" class=\"modal-open modalLink\">WEBシステム開発</a></li>\r\n          </ul><a href=\"#con3\" class=\"job_arrow modal-open modalLink\"></a>\r\n        </div>\r\n        <div class=\"col cont__white\">\r\n          <img src=\"images/job/job_icon04.png\" alt=\"ユーザーサポート職\">\r\n          <h4 class=\"box_title box_title_c\">ユーザー<br class=\"no_sp\">サポート職</h4>\r\n          <ul>\r\n            <li class=\"color__cs\"><a href=\"#con4\" class=\"modal-open modalLink\">カスタマーサポート</a></li>\r\n            <li class=\"color__web\"><a href=\"#con4\" class=\"modal-open modalLink\">カスタマーサクセス</a></li>\r\n          </ul>\r\n\t\t<a href=\"#con4\" class=\"job_arrow modal-open modalLink\"></a>\r\n        </div>\r\n      </div>\r\n      <div class=\"column4\">\r\n        <div class=\"col cont__white\">\r\n          <img src=\"images/job/job_icon05.png\" alt=\"WEB職\">\r\n          <h4 class=\"box_title box_title_c\">WEB職</h4>\r\n          <ul>\r\n            <li class=\"color__web\"><a href=\"#con5\" class=\"modal-open modalLink\">WEBディレクター</a></li>\r\n            <li class=\"color__web\"><a href=\"#con5\" class=\"modal-open modalLink\">WEBデザイナー</a></li>\r\n            <li class=\"color__pg\"><a href=\"#con5\" class=\"modal-open modalLink\">WEBシステム開発</a></li>\r\n            <li class=\"color__web\"><a href=\"#con5\" class=\"modal-open modalLink\">カスタマーサクセス</a></li>\r\n          </ul><a href=\"#con5\" class=\"job_arrow modal-open modalLink\"></a>\r\n        </div>\r\n        <div class=\"col cont__white\">\r\n          <img src=\"images/job/job_icon06.png\" alt=\"企画職\">\r\n          <h4 class=\"box_title box_title_c\">企画職</h4>\r\n          <ul>\r\n            <li class=\"color__office\"><a href=\"#con6\" class=\"modal-open modalLink\">マーケティング企画</a></li>\r\n            <li class=\"color__office\"><a href=\"#con6\" class=\"modal-open modalLink\">広報</a></li>\r\n            <li class=\"color__office\"><a href=\"#con6\" class=\"modal-open modalLink\">インハウスデザイナー</a></li>\r\n\t\t\t              <li class=\"color__office\"><a href=\"#con6\" class=\"modal-open modalLink\">人事</a></li>\r\n            <li class=\"color__office\"><a href=\"#con6\" class=\"modal-open modalLink\">IR</a></li>\r\n          </ul><a href=\"#con6\" class=\"job_arrow modal-open modalLink\"></a>\r\n        </div>\r\n        <div class=\"col cont__white\">\r\n          <img src=\"images/job/job_icon07.png\" alt=\"コーポレート職\">\r\n          <h4 class=\"box_title box_title_c\">コーポレート職</h4>\r\n          <ul>\r\n            <li class=\"color__office\"><a href=\"#con7\" class=\"modal-open modalLink\">経理</a></li>\r\n\t\t\t              <li class=\"color__office\"><a href=\"#con7\" class=\"modal-open modalLink\">業務</a></li>\r\n            <li class=\"color__office\"><a href=\"#con7\" class=\"modal-open modalLink\">総務</a></li>\r\n\t\t\t              <li class=\"color__office\"><a href=\"#con7\" class=\"modal-open modalLink\">人事</a></li>\r\n            <li class=\"color__office\"><a href=\"#con7\" class=\"modal-open modalLink\">法務</a></li>\r\n            <li class=\"color__office\"><a href=\"#con7\" class=\"modal-open modalLink\">情報管理</a></li>\r\n          </ul><a href=\"#con7\" class=\"job_arrow modal-open modalLink\"></a>\r\n        </div>\r\n      </div>\r\n    </div>\r\n    <article class=\"right_outside__white\">\r\n      <div class=\"main_cont\">\r\n        <h3 class=\"cont_title\"><span class=\"h__en\">MOVIE</span>全職種紹介動画</h3>\r\n        <div class=\"column2\">\r\n          <div class=\"col\">\r\n            <iframe src=\"https://www.youtube.com/embed/jGt37nhwCO4?si=JE0IGra9JNxJ3JDa\" title=\"YouTube video player\" frameborder=\"0\" allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share\" referrerpolicy=\"strict-origin-when-cross-origin\" allowfullscreen></iframe>\r\n          </div>\r\n          <div class=\"col no_sp\">\r\n            <img src=\"images/job/movie_bg.png\" alt=\"アイルのメンバー\">\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </article>\r\n    \r\n    <!-- ウィンドウ表示 -->\r\n    <section id=\"product\" class=\"modal-content\">\r\n      <div class=\"product-cont\">\r\n        <h4>システム紹介</h4>\r\n        <div class=\"job\">\r\n          <div class=\"column2\">\r\n            <div class=\"col\">\r\n              <a href=\"https://aladdin-office.com/\" target=\"_blank\"><img src=\"images/job/ao.png\" alt=\"ALADDIN OFFICE\"></a>\r\n            </div>\r\n            <div class=\"col\">\r\n              <p>在庫管理・販売管理・生産管理システム</p>\r\n              <h5>ALADDIN OFFICE</h5>\r\n            </div>\r\n          </div>\r\n          <p>販売・在庫・生産・購買管理といった、企業がビジネスを遂行するために必要である基本的な業務を効率化するためのシステムを自社開発しています。これを一般的に「基幹システム」と言い、効率化の他にも、業務の標準化や経営状況を可視化することで人為的ミスや業務負荷の軽減を実現しています。アラジンオフィスは、あらゆる業種・業態に対応しており、お客様の業務フローや課題感を理解しています。そのため、本当に必要な業務のデジタル化がどこにあるのかを見極めることができ、日々のバックオフィス業務に変革を起こすことで新たな価値や時間の創出の実現を目的としています。</p>\r\n        </div>\r\n        <div class=\"job\">\r\n          <div class=\"column2\">\r\n            <div class=\"col\">\r\n              <a href=\"https://aladdin-ec.jp/\" target=\"_blank\"><img src=\"images/job/aec.png\" alt=\"ALADDIN EC\"></a>\r\n            </div>\r\n            <div class=\"col\">\r\n              <p>BtoB向けWeb受発注システム</p>\r\n              <h5>ALADDIN EC</h5>\r\n            </div>\r\n          </div>\r\n          <p>受発注業務とは、取引先から商品の注文を受ける（受注）と、仕入先に注文をする（発注）業務のことです。<br>例えば、一般的な受注業務では、「見積もり→問合せ→注文→納品→請求」の流れで行われますが、見積書や納品書など書類の作成・確認などさまざまな業務があり、電話やFAXを使用し注文を受け、手作業で入力作業を行うアナログな対応をとっている企業も少なくありません。アイルでは、そのような企業間取引に欠かせない受発注業務をデジタル化したWeb受発注システム「アラジンEC」を自社開発しています。企業間の受発注取引に特化した専用のBtoB ECサイトを構築し、売り手・買い手ともに利便性の向上を支援しています。</p>\r\n        </div>\r\n        <div class=\"job\">\r\n          <div class=\"column2\">\r\n            <div class=\"col\">\r\n              <a href=\"https://cross-mall.jp/\" target=\"_blank\"><img src=\"images/job/cm.png\" alt=\"CROSS MALL\"></a>\r\n            </div>\r\n            <div class=\"col\">\r\n              <p>複数ネットショップ一元管理クラウドサービス</p>\r\n              <h5>CROSS MALL</h5>\r\n            </div>\r\n          </div>\r\n          <p>楽天市場やYahoo!ショッピングなど複数ネットショップを展開している企業による商品一括登録、在庫管理、受注管理、発注・仕入れまでをワンストップで行うことができるクラウドサービスです。複数店舗間にまたがる在庫数などの情報を適正に保つことができ、出店者側の負荷や人為的ミスを軽減することができます。また、注文分析を活用することで、売り上げの向上にもご活用いただいています。</p>\r\n        </div>\r\n        <div class=\"job\">\r\n          <div class=\"column2\">\r\n            <div class=\"col\">\r\n              <a href=\"https://cross-point-system.jp/\" target=\"_blank\"><img src=\"images/job/cp.png\" alt=\"CROSS POINT\"></a>\r\n            </div>\r\n            <div class=\"col\">\r\n              <p>ネットショップとリアルの店舗のポイント・<br>顧客一元管理クラウドサービス</p>\r\n              <h5>CROSS POINT</h5>\r\n            </div>\r\n          </div>\r\n          <p>実店舗とECサイトのポイントや購買履歴、顧客情報を一元管理できるクラウドサービスです。現在、人はさまざまな経路で買い物をします。実店舗で商品を下見し、サイズ等の確認をした後にECサイトで購入することなど、企業にとって顧客との接点は多様化しています。そこで、顧客とのあらゆる接点において買い物に限らずその前後も豊かな体験を提供し、「ショップやブランドのファンを作る」ためのツールとして自社開発しています。実店舗とECサイト間の連動分析により、より効果的な販売促進が可能になっています。</p>\r\n        </div>\r\n        <div class=\"job\">\r\n          <div class=\"column2\">\r\n            <div class=\"col\">\r\n              <a href=\"https://cross-staff.net/\" target=\"_blank\"><img src=\"images/job/cs.png\" alt=\"CROSS STAFF\"></a>\r\n            </div>\r\n            <div class=\"col\">\r\n              <p>スタッフ管理クラウドサービス</p>\r\n              <h5>CROSS STAFF</h5>\r\n            </div>\r\n          </div>\r\n          <p>人材サービス企業・派遣会社向けのクラウド型スタッフ管理・スタッフマイページ構築システムです。急ぎの求人募集の際にその派遣先に合ったスタッフに素早く連絡ができることや、給与明細・源泉徴収票や契約書などの書類をWeb化することで効率化とコスト削減も実現可能です。また、個々のスタッフごとにマイページを発行することで、一斉・個別のお知らせ配信が可能で、迷惑メール扱いになることを防ぎ確実に連絡を届けることができます。</p>\r\n        </div>\r\n      </div>\r\n    </section>\r\n    \r\n    <section id=\"con1\" class=\"modal-content\">\r\n      <img src=\"images/job/job_icon01.png\" alt=\"営業職\">\r\n      <h4>営業職</h4>\r\n      <div class=\"job\">\r\n        <h5>ITソリューション営業</h5>\r\n        <p>基幹業務システムの企画・提案営業を行います。基幹業務システムとは、どの企業でも必ず管理している「モノ」と「お金」を管理するシステムです。新人の内は経験として飛び込みや電話営業も行っています。お客様の困ったの声に耳を傾けて、最適な提案をし、ITの力を駆使して企業をコンサルティングするお仕事です。お客様との最初の接点であり、直接的に会社の受注を生み出す職種のため、よく花形の職種と言われています。数多くのお客様と関わることができます。</p>\r\n        <p class=\"member_list\">先輩社員の1日を見る</p>\r\n        <ul>\r\n          <li><a href=\"member_01.html\"><img src=\"images/member/member01_04.png\" alt=\"先輩社員の1日を見る\"></a></li>\r\n          <li><a href=\"member_02.html\"><img src=\"images/member/member02_04.jpg\" alt=\"先輩社員の1日を見る\"></a></li>\r\n        </ul>\r\n      </div>\r\n      <div class=\"job\">\r\n        <h5>パートナー営業</h5>\r\n        <p>主にパートナー企業（金融機関、コンサルタント、OA販社、SIerなど）に訪問し、自社製品である「アラジンオフィス」「アラジンEC」「CROSSシリーズ」などの紹介や営業支援を行います。パートナー企業と取引のあるお客様のご紹介をいただき、「ITソリューション営業」へのトスアップを行います。また、ウェビナーや展示会などの販促用施策の企画・運営も行います。「ITソリューション営業」は直接販売ですが、「パートナー営業」は主に支援を目的とした間接販売になります。</p>\r\n      </div>\r\n      <div class=\"job\">\r\n        <h5>カスタマーサクセス</h5>\r\n        <p>自社開発のWEBサービス（サブスク、クラウド）を利用したお客様の業務の改善提案から、利用開始までの支援、運用中のフォローなどを行います。例えば自社製品のCROSSMALL（クロスモール）ではネットショップ運営で必要な商品の登録や、出荷業務を効率化する機能を提供しており、どのようにサービスを利用すれば効率的になるか相談に乗りながら、サポートを行います。お客様からの機能改善要望などもヒアリングし、機能開発チームへ共有して、より良いサービスへ成長させるための窓口の役割も果たします。</p>\r\n        <p class=\"member_list\">先輩社員の1日を見る</p>\r\n        <ul>\r\n          <li><a href=\"member_14.html\"><img src=\"images/member/member14_04.jpg\" alt=\"先輩社員の1日を見る\"></a></li>\r\n        </ul>\r\n      </div>\r\n      <div class=\"job\">\r\n        <h5>営業職紹介動画</h5>\r\n        <iframe src=\"https://www.youtube.com/embed/w5zfELb9VYU?si=aOo33T8dW1fdWxbz\" title=\"YouTube video player\" frameborder=\"0\" allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share\" referrerpolicy=\"strict-origin-when-cross-origin\" allowfullscreen></iframe>\r\n      </div>\r\n    </section>\r\n    \r\n    <section id=\"con2\" class=\"modal-content\">\r\n      <img src=\"images/job/job_icon02.png\" alt=\"技術サポート職\">\r\n      <h4>技術サポート職</h4>\r\n      <div class=\"job\">\r\n        <h5>システムエンジニア</h5>\r\n        <p>お客様に提供する基幹業務システムの設計、運用、保守などを行います。お客様と直接打合せをして業務内容をより詳しくヒアリングし、システムのパッケージソフトにどのようなカスタマイズを加えたらお客様の業務効率化のお手伝いができるかを考え、お客様専用のシステムを構築するための設計書を作成します。そのため、専門知識よりもコミュニケーション能力が大切な職種になります。またシステム完成後に使い方を説明したり、使用中に不明点やトラブルが起きた際に助けてあげることもお仕事のひとつです。担当したお客様と長く深く関わることができます。</p>\r\n        <p class=\"member_list\">先輩社員の1日を見る</p>\r\n        <ul>\r\n          <li><a href=\"member_04.html\"><img src=\"images/member/member04_04.jpg\" alt=\"先輩社員の1日を見る\"></a></li>\r\n          <li><a href=\"member_05.html\"><img src=\"images/member/member05_04.jpg\" alt=\"先輩社員の1日を見る\"></a></li>\r\n          <li><a href=\"member_09.html\"><img src=\"images/member/member09_04.jpg\" alt=\"先輩社員の1日を見る\"></a></li>\r\n          <li><a href=\"member_12.html\"><img src=\"images/member/member12_04.jpg\" alt=\"先輩社員の1日を見る\"></a></li>\r\n        </ul>\r\n      </div>\r\n      <div class=\"job\">\r\n        <h5>ネットワークエンジニア</h5>\r\n        <p>基幹業務システムを使用するための、ネットワークやサーバーの設計、構築、保守管理を行います。またエンジニアの立場からセールスサポートも行います。お客様のデジタル化を促進するために「クラウド化」「セキュリティ対策」「テレワーク支援」「災害対策」などを行い、幅広い知識を習得することができます。安全かつ適切なインフラを提供することでトラブルを未然に防ぎ、障害発生時は問題点を的確に捉えて、お客様の立場に立って保守対応を行います。お客様に安定と安心を届ける重要なお仕事です。</p>\r\n        <p class=\"member_list\">先輩社員の1日を見る</p>\r\n        <ul>\r\n          <li><a href=\"member_08.html\"><img src=\"images/member/member08_04.jpg\" alt=\"先輩社員の1日を見る\"></a></li>\r\n        </ul>\r\n      </div>\r\n      <div class=\"job\">\r\n        <h5>カスタマーサクセス</h5>\r\n        <p>自社開発のWEBサービス（サブスク、クラウド）を利用したお客様の業務の改善提案から、利用開始までの支援、運用中のフォローなどを行います。例えば自社製品のCROSSMALL（クロスモール）ではネットショップ運営で必要な商品の登録や、出荷業務を効率化する機能を提供しており、どのようにサービスを利用すれば効率的になるか相談に乗りながら、サポートを行います。お客様からの機能改善要望などもヒアリングし、機能開発チームへ共有して、より良いサービスへ成長させるための窓口の役割も果たします。</p>\r\n        <p class=\"member_list\">先輩社員の1日を見る</p>\r\n        <ul>\r\n          <li><a href=\"member_14.html\"><img src=\"images/member/member14_04.jpg\" alt=\"先輩社員の1日を見る\"></a></li>\r\n        </ul>\r\n      </div>\r\n      <div class=\"job\">\r\n        <h5>技術サポート職紹介動画</h5>\r\n        <iframe src=\"https://www.youtube.com/embed/RB5suWTPBw0?si=h625LtPWBHXhDnS4\" title=\"YouTube video player\" frameborder=\"0\" allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share\" referrerpolicy=\"strict-origin-when-cross-origin\" allowfullscreen></iframe>\r\n      </div>\r\n    </section>\r\n    \r\n    <section id=\"con3\" class=\"modal-content\">\r\n      <img src=\"images/job/job_icon03.png\" alt=\"技術職\">\r\n      <h4>技術職</h4>\r\n      <div class=\"job\">\r\n        <h5>プログラマー・製品開発</h5>\r\n        <p>システムを構築するためのプログラミングや、パッケージソフトの開発を行います。システムエンジニアが作成した設計書を基に、プログラミング言語を用いて実際にシステムを構築します。思い描いているシステムを自分の手で現物化することのできる職種になります。また、さまざまなお客様から多くのご要望をいただくので、そのお声を基に、パッケージソフトをよりフィット感のあるモノへと改修し、より専門性の高いパッケージソフトへとアップデートさせたりしています。常駐は一切なく、全て自社でプログラミング・開発を行なっています。</p>\r\n        <p class=\"member_list\">先輩社員の1日を見る</p>\r\n        <ul>\r\n          <li><a href=\"member_07.html\"><img src=\"images/member/member07_04.jpg\" alt=\"先輩社員の1日を見る\"></a></li>\r\n        </ul>\r\n      </div>\r\n      <div class=\"job\">\r\n        <h5>WEBシステム開発</h5>\r\n        <p>自社開発のクラウドサービス「CROSSMALL」「CROSSPOINT」等の機能開発及び強化、加えて、これらに続くアイルの次世代製品のクラウドサービス開発を行っています。アイルの頭脳集団として、知識や技術の習得しながら、システムの利用者やニーズをイメージして開発を行います。また、サービスを通してお客様の利益・喜びを支援できる仕事です。</p>\r\n      </div>\r\n      <div class=\"job\">\r\n        <h5>技術職紹介動画</h5>\r\n        <iframe src=\"https://www.youtube.com/embed/0TkvxcGuF8k?si=5hPjsfODlQArZKkB\" title=\"YouTube video player\" frameborder=\"0\" allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share\" referrerpolicy=\"strict-origin-when-cross-origin\" allowfullscreen></iframe>\r\n      </div>\r\n    </section>\r\n    \r\n    <section id=\"con4\" class=\"modal-content\">\r\n      <img src=\"images/job/job_icon04.png\" alt=\"ユーザーサポート職\">\r\n      <h4>ユーザーサポート職</h4>\r\n      <div class=\"job\">\r\n        <h5>カスタマーサポート</h5>\r\n        <p>自社製品である基幹業務システムを導入していただいたお客様へ、電話を通してシステムの操作指導・問題解決などのサポートを行います。企業にとって重要な業務システムを止めないことを使命とし、スピード感もって状況把握に努め、最良の回答を導き出します。時には、社内外関係者との調整を行いながら円滑にお客様対応をしていくため、高いコミュニケーション能力が求められます。継続したスキルアップの必要性も高く、自部署内に留まらず、社内の教育ツールの拡充にも力を注いでいます。</p>\r\n        <p class=\"member_list\">先輩社員の1日を見る</p>\r\n        <ul>\r\n          <li><a href=\"member_13.html\"><img src=\"images/member/member13_04.jpg\" alt=\"先輩社員の1日を見る\"></a></li>\r\n        </ul>\r\n      </div>\r\n      <div class=\"job\">\r\n        <h5>カスタマーサクセス</h5>\r\n        <p>自社開発のWEBサービス（サブスク、クラウド）を利用したお客様の業務の改善提案から、利用開始までの支援、運用中のフォローなどを行います。例えば自社製品のCROSSMALL（クロスモール）ではネットショップ運営で必要な商品の登録や、出荷業務を効率化する機能を提供しており、どのようにサービスを利用すれば効率的になるか相談に乗りながら、サポートを行います。お客様からの機能改善要望などもヒアリングし、機能開発チームへ共有して、より良いサービスへ成長させるための窓口の役割も果たします。</p>\r\n        <p class=\"member_list\">先輩社員の1日を見る</p>\r\n        <ul>\r\n          <li><a href=\"member_14.html\"><img src=\"images/member/member14_04.jpg\" alt=\"先輩社員の1日を見る\"></a></li>\r\n        </ul>\r\n      </div>\r\n      <div class=\"job\">\r\n        <h5>ユーザーサポート職紹介動画</h5>\r\n        <iframe src=\"https://www.youtube.com/embed/2SRx7ecXCi0?si=75PXQsICojuFCwaY\" title=\"YouTube video player\" frameborder=\"0\" allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share\" referrerpolicy=\"strict-origin-when-cross-origin\" allowfullscreen></iframe>\r\n      </div>\r\n    </section>\r\n    \r\n    <section id=\"con5\" class=\"modal-content\">\r\n      <img src=\"images/job/job_icon05.png\" alt=\"WEB職\">\r\n      <h4>WEB職</h4>\r\n      <div class=\"job\">\r\n        <h5>WEBディレクター</h5>\r\n        <p>お客様のコーポレートサイトやネットショップ（ECサイト）の構築・運用を行います。具体的には、プロジェクト全体の管理やコンセプト立案、課題解決のための企画提案、スケジュール管理などを担当します。近年ではWEBサイトだけでなく、企業ブランディングの一環として、名刺やカタログといった紙媒体のデザイン企画も手掛けるケースが増えています。また、蓄積された購買データや顧客データを分析し、マーケティング施策に落とし込む支援も行っています。</p>\r\n        <p class=\"member_list\">先輩社員の1日を見る</p>\r\n        <ul>\r\n          <li><a href=\"member_11.html\"><img src=\"images/member/member11_04.jpg\" alt=\"先輩社員の1日を見る\"></a></li>\r\n        </ul>\r\n      </div>\r\n      <div class=\"job\">\r\n        <h5>WEBデザイナー</h5>\r\n        <p>お客様のターゲットや目的に合わせ、魅力的で使いやすいWEBサイトのデザイン・構築を行います。単なる見た目だけでなく、ユーザーインターフェース（UI）の設計を通じて、ユーザー体験全体を最適化する重要な役割を担います。中には、自らデザイン制作を手掛けながら、お客様と共にプロジェクトを推進する「クリエイティブディレクター」として活躍するデザイナーもいます。企画段階からお客様と深く関わり、アイデアを形にしていくやりがいのある職種です。</p>\r\n        <p class=\"member_list\">先輩社員の1日を見る</p>\r\n        <ul>\r\n          <li><a href=\"member_10.html\"><img src=\"images/member/member10_04.jpg\" alt=\"先輩社員の1日を見る\"></a></li>\r\n        </ul>\r\n      </div>\r\n      <div class=\"job\">\r\n        <h5>WEBシステム開発</h5>\r\n        <p>自社開発のクラウドサービス「CROSSMALL」「CROSSPOINT」等の機能開発及び強化、加えて、これらに続くアイルの次世代製品のクラウドサービス開発を行っています。アイルの頭脳集団として、知識や技術の習得しながら、システムの利用者やニーズをイメージして開発を行います。また、サービスを通してお客様の利益・喜びを支援できる仕事です。</p>\r\n      </div>\r\n      <div class=\"job\">\r\n        <h5>カスタマーサクセス</h5>\r\n        <p>自社開発のWEBサービス（サブスク、クラウド）を利用したお客様の業務の改善提案から、利用開始までの支援、運用中のフォローなどを行います。例えば自社製品のCROSSMALL（クロスモール）ではネットショップ運営で必要な商品の登録や、出荷業務を効率化する機能を提供しており、どのようにサービスを利用すれば効率的になるか相談に乗りながら、サポートを行います。お客様からの機能改善要望などもヒアリングし、機能開発チームへ共有して、より良いサービスへ成長させるための窓口の役割も果たします。</p>\r\n        <p class=\"member_list\">先輩社員の1日を見る</p>\r\n        <ul>\r\n          <li><a href=\"member_14.html\"><img src=\"images/member/member14_04.jpg\" alt=\"先輩社員の1日を見る\"></a></li>\r\n        </ul>\r\n      </div>\r\n      <div class=\"job\">\r\n        <h5>WEB職紹介動画</h5>\r\n        <iframe src=\"https://www.youtube.com/embed/BrizYcnGP5E?si=Bs-JGC736TKxM9A-\" title=\"YouTube video player\" frameborder=\"0\" allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share\" referrerpolicy=\"strict-origin-when-cross-origin\" allowfullscreen></iframe>\r\n      </div>\r\n    </section>\r\n    \r\n    <section id=\"con6\" class=\"modal-content\">\r\n      <img src=\"images/job/job_icon06.png\" alt=\"企画職\">\r\n      <h4>企画職</h4>\r\n      <div class=\"job\">\r\n        <h5>マーケティング企画</h5>\r\n        <p>システムソリューション事業部の新規受注拡大のためのマーケティング活動を行います。業務管理システムを探している人に対して、自社製品の特徴や強みを、WEBサイト・広告・展示会などを通じてPR・訴求し、商談に繋がるお問合せを獲得するための企画を考案・実施しています。WEBサイト運営をはじめ、SEO対策やコンテンツマーケティング、SNS活用といったWEBマーケティングと、TVCMやタクシー・エレベーター広告、雑誌・新聞広告などのプロモーション企画、チラシ・カタログ製作、ノベルティなどの販促企画などを行っています。</p>\r\n        <p class=\"member_list\">先輩社員の1日を見る</p>\r\n        <ul>\r\n          <li><a href=\"member_16.html\"><img src=\"images/member/member16_04.jpg\" alt=\"先輩社員の1日を見る\"></a></li>\r\n        </ul>\r\n      </div>\r\n      <div class=\"job\">\r\n        <h5>広報</h5>\r\n        <p>アイルのことをもっと多くの人々に知ってもらい、そして理解してもらうための情報発信活動を行います。会社の事業や新たな取り組みなどをはじめ、アイルの強みである企業文化や風土についてなども広く社会に発信していくことで、認知度拡大と企業価値向上を目指しています。具体的には、プレスリリースの作成・配信、メディア取材対応、導入事例取材、新たな取り組みの企画などといった社外広報と、社内報や社内向けイベント企画を通して、社内に対しても、自社への理解促進やコミュニケーションの醸成を図っています。</p>\r\n      </div>\r\n      <div class=\"job\">\r\n        <h5>インハウスデザイナー</h5>\r\n        <p>自社製品の販売促進や広告デザイン、自社サイトのWEBデザインなどの制作を行います。社内で発生した要望に沿って情報整理をし、多岐に渡るデザインを行っていきます。そういった意味では社員がクライアントとなるため、意見を直接聞いて上流から制作に深く関わることができるのが大きなメリットです。作って終わりではなく、継続して同じ事業のデザインに携わり、ブラッシュアップを続けて育てていけるのもこのお仕事の魅力の一つです。WEBや紙だけでなく、動画や空間デザインなど多岐に渡るデザインに携われる職種です。</p>\r\n      </div>\r\n\t\t<div class=\"job\">\r\n        <h5>人事</h5>\r\n        <p>採用活動のイメージが強いと思いますが、その他にも社内研修の企画や人事考課、社内制度設計、労務管理などと幅広く、社員が力を発揮できる環境を整えるための業務を行います。そのため、時にはアイルを伝える会社の顔的存在になったり、採用広報などを考える企画職になったり、賃金制度の設計や法改正対応を行う専門職になったりと、その時々で役割も様々です。会社に直接的に利益を生み出すことはできませんが、社員が力を発揮できる環境を整えることで会社の成長や発展に貢献できていると感じられるお仕事です。</p>\r\n      </div>\r\n      <div class=\"job\">\r\n        <h5>IR</h5>\r\n        <p>自社の株式価値向上を目的とし、投資家に対して業績状況や成長性の説明、会社の取り組みや企業価値などを伝える活動を行います。四半期ごとの決算発表の開示資料作成や投資家対応をはじめ、東証プライム上場企業に求められる各種情報開示の対応も行っています。</p>\r\n      </div>\r\n\t\t<div class=\"job\">\r\n        <h5>企画職紹介動画</h5>\r\n        <iframe src=\"https://www.youtube.com/embed/moN_f6eOBC8?si=KVSsI_NZ3IEe62e1\" title=\"YouTube video player\" frameborder=\"0\" allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share\" referrerpolicy=\"strict-origin-when-cross-origin\" allowfullscreen></iframe>\r\n      </div>\r\n    </section>\r\n    \r\n    <section id=\"con7\" class=\"modal-content\">\r\n      <img src=\"images/job/job_icon07.png\" alt=\"コーポレート職\">\r\n      <h4>コーポレート職</h4>\r\n      <div class=\"job\">\r\n        <h5>経理</h5>\r\n        <p>数字の面からアイルを支援する業務を行います。お客様へのご請求・回収や取引先への支払いを行うことをはじめ、会社の活動から生まれる売上などの成果を、ルールに沿って集計のうえ、投資家・株主に公開することや、社内で各部署の指針となるような数値情報を提供することが、主な役割です。社内外の関係者とのコミュニケーションから情報を収集し、会計、税務などの専門的なスキルを活用することで、上場企業としての信用を支えています。</p>\r\n      </div>\r\n\t\t<div class=\"job\">\r\n        <h5>業務</h5>\r\n        <p>上場企業に求められるルールに従い、受注・売上・仕入といった数字の集計を正しく正確に行います。また、営業や社内処理などに関する社内ルールの見直しや、新たな商材・サービスの販売開始時に、関係部署と一緒に販売フローを構築するなど、様々なことを行っています。状況に応じて適切な判断をするため、会計や法律の基本的な知識の習得はもちろん、業界トレンドや法改正への動き、営業方針などにも素早く反応ができるよう、日々アンテナを張っています。「守り」の要として企業活動全体を支えつつ、「攻め」の要素も備えたやりがいのある職種です。</p>\r\n      </div>\r\n\t\t<div class=\"job\">\r\n        <h5>総務</h5>\r\n        <p>労務管理・給与処理・各種手配・社内申請受付・株主総会運営・庶務業務など、幅広い業務を行います。事務・管理業務が多いですが、業務知識だけでなく、関連法務などの専門知識や上場企業が守るべき内容に関する知識も必要になるため、「事務職」ではなく「専門職」という意識で業務に取り組んでいます。基本的には社内業務がほとんどですが、人を相手にする職種ではありますので、コミュニケーション力も大切になります。会社全体や社員の生活に関わる業務が多いため、社内からの感謝の声を聞けることが多い職種です。</p>\r\n        <p class=\"member_list\">先輩社員の1日を見る</p>\r\n        <ul>\r\n          <li><a href=\"member_15.html\"><img src=\"images/member/member15_04.jpg\" alt=\"先輩社員の1日を見る\"></a></li>\r\n        </ul>\r\n      </div>\r\n\t\t<div class=\"job\">\r\n        <h5>人事</h5>\r\n        <p>採用活動のイメージが強いと思いますが、その他にも社内研修の企画や人事考課、社内制度設計、労務管理などと幅広く、社員が力を発揮できる環境を整えるための業務を行います。そのため、時にはアイルを伝える会社の顔的存在になったり、採用広報などを考える企画職になったり、賃金制度の設計や法改正対応を行う専門職になったりと、その時々で役割も様々です。会社に直接的に利益を生み出すことはできませんが、社員が力を発揮できる環境を整えることで会社の成長や発展に貢献できていると感じられるお仕事です。</p>\r\n      </div>\r\n      <div class=\"job\">\r\n        <h5>法務</h5>\r\n        <p>お客様をはじめとした取引先との契約に関する相談・トラブル相談・契約管理・法的措置手続き・訴訟対応・顧問弁護士との窓口・社内の知的財産権などの管理・社内法務研修などを行います。会社の守りの要として、法的な知識以上に、事業内容や取引内容に関する理解が求められます。</p>\r\n      </div>\r\n      <div class=\"job\">\r\n        <h5>情報管理</h5>\r\n        <p>社内システム及びインフラの開発・構築・運用保守、ITセキュリティ対策の実施、IT化推進の計画や導入などを行います。社内のITに関わるすべての役割を担っており、アイル全社の事業活動と社員の業務を、IT面から支えています。</p>\r\n      </div>\r\n\t\t<div class=\"job\">\r\n        <h5>コーポレート職紹介動画</h5>\r\n        <iframe src=\"https://www.youtube.com/embed/Avrc8osmIaI?si=XtB1G01yY-qa0Y40\" title=\"YouTube video player\" frameborder=\"0\" allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share\" referrerpolicy=\"strict-origin-when-cross-origin\" allowfullscreen></iframe>\r\n      </div>\r\n    </section>\r\n    \r\n\t</section>\r\n</div>\r\n<section class=\"cv\">\r\n    <div class=\"cv_bg\">\r\n      <div class=\"cv_bg_in\">\r\n        <h3>あなたも一緒に、思い切りバットを振っていこう。</h3>\r\n        <div class=\"cv_in_box\">\r\n          <div class=\"cv_in\">\r\n            <p class=\"cv_e_p\">新卒採用</p>\r\n            <a href=\"https://ill-recruit.snar.jp/index.aspx\" class=\"cv_btn\">\r\n            <div class=\"cv_box\">\r\n              <div class=\"cv_btn_in\"> <span class=\"h__en\">ENTRY</span><span class=\"subtitle\">新卒採用</span></div>\r\n              <p>新卒採用向け<br>\r\n                エントリーはこちら</p>\r\n              <span class=\"cv_arrow\"></span> </div>\r\n            </a> </div>\r\n          <div class=\"cv_in\">\r\n            <p class=\"cv_c_p\">キャリア採用</p>\r\n            <a href=\"entry_career.html\" class=\"cv_btn btn_gr\">\r\n            <div class=\"cv_box\">\r\n              <div class=\"cv_btn_in\"> <span class=\"h__en\">CAREER</span><span class=\"subtitle\">キャリア採用</span></div>\r\n              <p>キャリア採用向け<br>\r\n                募集要項はこちら</p>\r\n              <span class=\"cv_arrow\"></span> </div>\r\n            </a> </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </section>\r\n<footer class=\"footer\">\r\n  <div class=\"footer_all\"> <a href=\"#\" class=\"page-top\"><img src=\"images/airu_small.png\" alt=\"PAGE TOP\">PAGE TOP</a>\r\n    <div class=\"footer__t\">\r\n      <nav class=\"footer__t__in\">\r\n        <div class=\"footer__t__st\">\r\n          <ul class=\"footer__t__st__ls\">\r\n            <li>\r\n              <div class=\"footer__t__st__ls__hd\"><a href=\"message.html\"><span class=\"c-navText\"><span class=\"__en\">MESSAGE</span><span class=\"__ja\">アイルの想い</span></span></a></div>\r\n              <div class=\"footer__t__st__ls__bd\">\r\n                <ul class=\"footer__t__st__ls__bd__ls\">\r\n                  <li><a href=\"message.html#message_or\"><span>アイルの役割</span></a></li>\r\n                  <li><a href=\"message.html#message_cp\"><span>企業ポリシー</span></a></li>\r\n                  <li><a href=\"message.html#message_ic\"><span>求める人物像</span></a></li>\r\n                </ul>\r\n              </div>\r\n            </li>\r\n          </ul>\r\n        </div>\r\n        <div class=\"footer__t__st\">\r\n          <ul class=\"footer__t__st__ls\">\r\n            <li>\r\n              <div class=\"footer__t__st__ls__hd\"><a href=\"culture.html\"><span class=\"c-navText\"><span class=\"__en\">CULTURE</span><span class=\"__ja\">文化を知る</span></span></a></div>\r\n              <div class=\"footer__t__st__ls__bd\">\r\n                <ul class=\"footer__t__st__ls__bd__ls\">\r\n                  <li><a href=\"culture.html\"><span>企業文化</span></a></li>\r\n                  <li><a href=\"illword.html\"><span>アイル語</span></a></li>\r\n                </ul>\r\n              </div>\r\n            </li>\r\n          </ul>\r\n        </div>\r\n        <div class=\"footer__t__st\">\r\n          <ul class=\"footer__t__st__ls\">\r\n            <li>\r\n              <div class=\"footer__t__st__ls__hd\"><a href=\"business.html\"><span class=\"c-navText\"><span class=\"__en\">BUSINESS</span><span class=\"__ja\">仕事を知る</span></span></a></div>\r\n              <div class=\"footer__t__st__ls__bd\">\r\n                <ul class=\"footer__t__st__ls__bd__ls\">\r\n                  <li><a href=\"business.html\"><span>ビジネスモデル</span></a></li>\r\n                  <li><a href=\"job.html\"><span>職種紹介</span></a></li>\r\n                </ul>\r\n              </div>\r\n            </li>\r\n          </ul>\r\n        </div>\r\n        <div class=\"footer__t__st\">\r\n          <ul class=\"footer__t__st__ls\">\r\n            <li>\r\n              <div class=\"footer__t__st__ls__hd\"><a href=\"member.html\"><span class=\"c-navText\"><span class=\"__en\">MEMBER</span><span class=\"__ja\">人を知る</span></span></a></div>\r\n              <div class=\"footer__t__st__ls__bd\">\r\n                <ul class=\"footer__t__st__ls__bd__ls\">\r\n                  <li><a href=\"member.html\"><span>社員紹介</span></a></li>\r\n                      <li><a href=\"interview/index.html\"><span>若手社員の声</span></a></li>\r\n                </ul>\r\n              </div>\r\n            </li>\r\n          </ul>\r\n        </div>\r\n        <div class=\"footer__t__st\">\r\n          <ul class=\"footer__t__st__ls\">\r\n            <li>\r\n              <div class=\"footer__t__st__ls__hd\"><a href=\"requirements.html\"><span class=\"c-navText\"><span class=\"__en\">RECRUIT</span><span class=\"__ja\">採用情報</span></span></a></div>\r\n              <div class=\"footer__t__st__ls__bd\">\r\n                <ul class=\"footer__t__st__ls__bd__ls\">\r\n                  <li><a href=\"requirements.html\"><span>募集要項</span></a></li>\r\n                  <li><a href=\"education.html\"><span>教育・評価制度</span></a></li>\r\n                  <li><a href=\"welfare.html\"><span>福利厚生</span></a></li>\r\n                  <li><a href=\"faq.html\"><span>採用FAQ</span></a></li>\r\n                </ul>\r\n              </div>\r\n            </li>\r\n          </ul>\r\n        </div>\r\n        <div class=\"footer__t__st\">\r\n          <ul class=\"footer__t__st__ls\">\r\n            <li>\r\n              <div class=\"footer__t__st__ls__hd\"><a href=\"company.html\"><span class=\"c-navText\"><span class=\"__en\">COMPANY</span><span class=\"__ja\">会社概要</span></span></a></div>\r\n\t\t\t\t<div class=\"footer__t__st__ls__bd\">\r\n                <ul class=\"footer__t__st__ls__bd__ls\">\r\n                  <li><a href=\"compliance.html\"><span>就活ハラスメント防止方針</span></a></li>\r\n                </ul>\r\n              </div>\r\n            </li>\r\n          </ul>\r\n        </div>\r\n        <div class=\"footer__t__st\">\r\n          <ul class=\"footer__t__st__ls\">\r\n            <li>\r\n              <div class=\"footer__t__st__ls__hd\"><a href=\"entry_select.html\"><span class=\"c-navText\"><span class=\"__en\">ENTRY</span><span class=\"__ja\">エントリー</span></span></a></div>\r\n            </li>\r\n          </ul>\r\n        </div>\r\n      </nav>\r\n      <div class=\"footer_link\">\r\n      <a href=\"https://www.ill.co.jp/\" target=\"_blank\" class=\"page-link\"><img src=\"images/corporate.png\" alt=\"株式会社アイルコーポレートサイト\"></a>\r\n\t  <a href=\"https://www.ill.co.jp/recruit/internship/\" target=\"_blank\" class=\"page-link\"><img src=\"images/intern.png\" alt=\"株式会社アイルインターン情報サイト\"></a></div> </div>\r\n    <div class=\"footer__b\">\r\n      <p class=\"footer__b__cr\"><span>Copyright &copy; I'LL inc. All Rights Reserved.</span></p>\r\n    </div>\r\n  </div>\r\n</footer>\r\n  <script type=\"text/javascript\" src=\"js/modaal.min.js\"></script>\r\n  <script src=\"https://cdnjs.cloudflare.com/ajax/libs/jquery-cookie/1.4.1/jquery.cookie.js\"></script>\r\n  <script type=\"text/javascript\" src=\"js/illword.js\"></script>\r\n<script src=\"js/common.js\"></script></body>\r\n</html>\r\n","finalUrl":"https://www.ill.co.jp/recruit/job.html","rendered":false,"_cachedAt":"2026-06-23T17:20:23.495Z"}