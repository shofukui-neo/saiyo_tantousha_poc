{"url":"https://www.pref.miyagi.jp/site/saiyou/r8-navigator.html","html":"<!doctype html>\n<html lang=\"ja\" xmlns:og=\"http://ogp.me/ns#\" xmlns:fb=\"http://www.facebook.com/2008/fbml\">\n<head>\n<meta charset=\"UTF-8\">\n\n<title>宮城県庁ナビゲーターオンライン相談会 - 宮城県公式ウェブサイト</title>\n\n<meta property=\"og:title\" content=\"宮城県庁ナビゲーターオンライン相談会\">\n<meta property=\"og:type\" content=\"article\">\n<meta property=\"og:description\" content=\"\">\n<meta property=\"og:url\" content=\"https://www.pref.miyagi.jp/site/saiyou/r8-navigator.html\">\n<meta property=\"og:image\" content=\"https://www.pref.miyagi.jp/shared/images/sns/logo.jpg\">\n<meta property=\"og:site_name\" content=\"宮城県\">\n<meta property=\"og:locale\" content=\"ja_JP\">\n<meta name=\"author\" content=\"宮城県\">\n<meta name=\"viewport\" content=\"width=device-width, maximum-scale=3.0\">\n<meta name=\"format-detection\" content=\"telephone=no\">\n<meta name=\"page_id\" content=\"65129\">\n<link href=\"/shared/style/default.css\" rel=\"stylesheet\" type=\"text/css\" media=\"all\">\n<link href=\"/shared/style/layout.css\" rel=\"stylesheet\" type=\"text/css\" media=\"all\">\n<link href=\"/shared/templates/free/style/edit.css\" rel=\"stylesheet\" type=\"text/css\" media=\"all\">\n<link href=\"/shared/style/tablet.css\" rel=\"stylesheet\" media=\"only screen and (min-width : 641px) and (max-width : 980px)\" type=\"text/css\" id=\"tmp_tablet_css\" class=\"mc_css\">\n<link href=\"/shared/style/smartphone.css\" rel=\"stylesheet\" media=\"only screen and (max-width : 640px)\" type=\"text/css\" class=\"mc_css\">\n<link href=\"/shared/templates/free/style/edit_sp.css\" rel=\"stylesheet\" media=\"only screen and (max-width : 640px)\" type=\"text/css\" class=\"mc_css\">\n<link href=\"/shared/images/favicon/favicon.ico\" rel=\"shortcut icon\" type=\"image/vnd.microsoft.icon\">\n<link href=\"/shared/images/favicon/apple-touch-icon-precomposed.png\" rel=\"apple-touch-icon-precomposed\">\n<script src=\"/shared/js/jquery.js\"></script>\n<script src=\"/shared/js/setting.js\"></script>\n<script src=\"/shared/js/page_print.js\"></script>\n<script src=\"/shared/js/readspeaker.js\"></script>\n<script src=\"/shared/js/gtag.js\"></script>\n\n\n\n\n</head>\n<body class=\"format_free no_javascript\">\n\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-PS9C6B9\" height=\"0\" width=\"0\" style=\"display:none;visibility:hidden\" title=\"Google Tag Manager\"></iframe></noscript>\n\n<div id=\"fb-root\"></div>\n<script async defer crossorigin=\"anonymous\" src=\"https://connect.facebook.net/ja_JP/sdk.js#xfbml=1&version=v12.0\"></script>\n<script src=\"/shared/js/init.js\"></script>\n<div id=\"tmp_wrapper\">\n<noscript>\n<p>このサイトではJavaScriptを使用したコンテンツ・機能を提供しています。JavaScriptを有効にするとご利用いただけます。</p>\n</noscript>\n<p><a href=\"#tmp_honbun\" class=\"skip\">本文へスキップします。</a></p>\n\n<header id=\"tmp_header\">\n<div class=\"container\">\n<div id=\"tmp_hlogo\">\n<p><a href=\"/index.html\"><span>宮城県 Miyagi Prefectural Government</span></a></p>\n</div>\n<ul id=\"tmp_hnavi_s\">\n\t<li id=\"tmp_hnavi_lmenu\"><a href=\"https://miyagi-bousai.my.salesforce-sites.com/\">災害・気象情報</a></li>\n\t<li id=\"tmp_hnavi_mmenu\"><a href=\"javascript:void(0);\">閲覧支援</a></li>\n\t<li id=\"tmp_hnavi_rmenu\"><a href=\"javascript:void(0);\">検索メニュー</a></li>\n</ul>\n<div id=\"tmp_means\">\n<div id=\"tmp_setting\">\n<ul>\n\t<li class=\"func_language\"><a href=\"/soshiki/kohou/foreign.html\" lang=\"en\">Foreign Language</a></li>\n\t<li class=\"func_browser\"><a href=\"javascript:void(0);\">閲覧支援メニュー</a>\n\t<div class=\"support_dropdown\">\n\t<ul>\n\t\t<li id=\"readspeaker_button1\" class=\"func_read rs_skip\"><a accesskey=\"L\" href=\"//app-eas.readspeaker.com/cgi-bin/rsent?customerid=9180&amp;lang=ja_jp&amp;readid=tmp_main,tmp_update&amp;url=\" onclick=\"readpage(this.href, 'tmp_readspeaker'); return false;\" rel=\"nofollow\" class=\"rs_href\">音声読み上げ</a></li>\n\t\t<li class=\"func_fsize\"><a href=\"/moji.html\">文字サイズ・色合い変更</a></li>\n\t\t<l