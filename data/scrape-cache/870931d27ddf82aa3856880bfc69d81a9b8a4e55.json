class=\"flex\">\n                                <div class=\"left\">\n                                    <a href=\"products/\"><img class=\"fit\" src=\"assets/img/common/jp/submenu_btn_03.jpg\"></a>\n                                </div>\n                                <div class=\"right\">\n                                    <div class=\"flex col2\">\n                                        <div class=\"col\">\n                                            <ul>\n                                                <li><a class=\"hover--underline type--black anchor-link\" href=\"products/#anchor01\">機体プラットフォーム</a></li>\n                                                <li><a class=\"hover--underline type--black anchor-link\" href=\"products/#anchor02\">アビオニクス機器</a></li>\n                                                <li><a class=\"hover--underline type--black anchor-link\" href=\"products/#anchor03\">エンジン</a></li>\n                                            </ul>\n                                        </div>\n                                        <div class=\"col\">\n                                            <ul>\n                                                <li><a class=\"hover--underline type--black anchor-link\" href=\"products/#anchor04\">メカニカル機器</a></li>\n                                                <li><a class=\"hover--underline type--black anchor-link\" href=\"products/#anchor05\">宇宙・サイバー・電磁波</a></li>\n                                                <li><a class=\"hover--underline type--black anchor-link\" href=\"products/#anchor06\">その他</a></li>\n                                            </ul>\n                                        </div>\n                                    </div>\n                                </div>\n                            </div>\n                        </div>\n                        <div id=\"nav04\" class=\"submenu\" data-nav=\"04\">\n                            <div class=\"flex\">\n                                <div class=\"left\">\n                                    <a href=\"recruit/index_top.html\"><img class=\"fit\" src=\"assets/img/common/jp/submenu_btn_04.jpg\"></a>\n                                </div>\n                                <div class=\"right\">\n                                    <div class=\"flex col1\">\n                                        <div class=\"col\">\n                                            <ul>\n                                                <li><a class=\"hover--underline type--black blank\" href=\"https://www.sc-aero.co.jp/recruit/\" target=\"_blank\">新卒採用</a></li>\n                                                <li><a class=\"hover--underline type--black\" href=\"recruit/career.html\">キャリア採用</a></li>\n                                            </ul>\n                                        </div>\n                                    </div>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </nav>\n\n            <div id=\"menu\">\n                <a id=\"menu-btn--close\"><span class=\"icon\"></span></a>\n                <div id=\"menu-list\">\n                    <nav>\n                        <ul>\n                            <li><a href=\"\">TOP<div class=\"icon--arrow black\"></div></a></li>\n                            <li><a href=\"message/\">ごあいさつ<div class=\"icon--arrow black\"></div></a></li>\n                            <li><a href=\"company/\">企業情報<div class=\"icon--arrow black\"></div></a></li>\n                            <li><a href=\"business/\">事業紹介<div class=\"icon--arrow black\"></div></a></li>\n                            <li><a href=\"products/\">取扱商品<div class=\"icon--arrow black\"></div></a></li>\n                            <li><a href=\"recruit/index_top.html\">採用情報<div class=\"icon--arrow black\"></div></a></li>\n                        </ul>\n                    </nav>\n                </div>\n            </div>\n            \n\n            <div id=\"top-bg\">\n                <video webkit-playsinline playsinline muted autoplay loop oncontextmenu=\"return false;\"></video>\n            </div>\n\n            <main>\n                <article>\n                    <section id=\"mv\">\n                        <div class=\"h1\"><h1><img class=\"js-switching\" data-src=\"assets/img/home/jp/top_h1_pc.png\"></h1></div>\n                        <div class=\"spshow contact-btn\"><a href=\"contact/\"><img src=\"assets/img/home/top_contact_icon.png\"></a></div>\n                    </section>\n\n\n                    <section id=\"prologue\">\n                        <div class=\"upper\">\n                            <p>住商エアロシステムのスローガン 「Sky’s the Limit」 は、私たちの発想及び活動には限界がないということを表現しています。</p>\n                        </div>\n                        <div class=\"lower\">\n                            <div class=\"inside\">\n                                <ul class=\"flex\">\n                                    <li><a href=\"business/\"><img class=\"fit\" src=\"assets/img/home/jp/top_banner_01.png\"></a></li>\n                                    <li><a href=\"business/about.html#anchor03\"><img class=\"fit\" src=\"assets/img/home/jp/top_banner_02.png\"></a></li>\n                                    <li><a href=\"recruit/index_top.html\"><img class=\"fit\" src=\"assets/img/home/jp/top_banner_03.png\"></a></li>\n                                </ul>\n                            </div>\n                        </div>\n                    </section>\n\n\n\n                    <section id=\"top-message\" class=\"section\">\n                        <div class=\"inner1000\">\n                            <div class=\"inside\">\n                                <div class=\"h3\">\n                                    <h3>\n                                        住商エアロシステム株式会社は、<br>\n                                        住友商事グループにおける<br>\n                                        防衛・航空宇宙分野の専門商社です。\n                                    </h3>\n                                </div>\n                                <div class=\"txt\">\n                                    <p>\n                                        住商エアロシステムは、人と人、企業と企業、さらには国と国をつなぎ、平和と豊かな社会の実現に貢献してきました。<br>\n                                        <br>\n                                        私たちは、これまで築きあげてきた磐石なるグループ力と柔軟な発想で、<br>\n                                        防衛・航空宇宙の技術革新及び安全保障分野において広く社会に貢献し、また、新たな価値を創造するグローバルな企業を目指します。\n                                    </p>\n                                </div>\n                                <div class=\"btn type--small\">\n                                    <div class=\"related--links col1\">\n                                        <div class=\"inside\">\n                                            <ul class=\"flex\">\n                                                <li><a class=\"btn--arrow\" href=\"message/\"><p>ごあいさつ</p><div class=\"icon--arrow\"></div></a></li>\n                                            </ul>\n                                        </div>\n                                    </div>\n                                </div>\n                            </div>\n                        </div>\n                    </section>\n\n\n\n                    <section class=\"hr\"></section>\n\n\n\n\n                    <section id=\"top-strengths\" class=\"section\">\n                        <div class=\"inner1000\">\n                            <div class=\"inside\">\n                                <div class=\"h2\"><h2>すべてのお客様へ</h2></div>\n                                <div class=\"list\">\n                                    <ul class=\"flex\">\n                                        <li>\n                                            <div class=\"sttl\"><p>ビジネス体制</p></div>\n                                            <div class=\"txt\">\n                                                <p>\n                                                    住商エアロシステムは、住友商事グループの防衛・航空宇宙事業の中核を担い、我が国の安全保障に大きく寄与しています。\n                                                </p>\n                                            </div>\n                                        </li>\n                                        <li>\n                                            <div class=\"sttl\"><p>商社機能</p></div>\n                                            <div class=\"txt\">\n                                                <p>\n                                                    マーケティングと販売、アフターサービスといったこれまでの商社機能だけではなく、バリューチェーンの各フェーズで新しい価値を創造します。\n                                                </p>\n                                            </div>\n                                        </li>\n                                        <li>\n                                            <div class=\"sttl\"><p>主要取引先</p></div>\n                                            <div class=\"txt\">\n                                                <p>\n                                                    国内外の仕入先メーカーと多くのお取引様を結び、築いてきた強固な繋がりが当社の強みです。<br>\n                                                    創業以来積み重ねてきた信用を旨とし、これからも多角的な視点から、より豊かなサービスを提供できるよう邁進してまいります。\n                                                </p>\n                                            </div>\n                                        </li>\n                                        <li>\n                                            <div class=\"sttl\"><p>実績</p></div>\n                                            <div class=\"txt\">\n                                                <p>\n                                                    最先端の技術・性能・信頼性が求められる防衛・航空宇宙分野において、ニーズにあった確かな商品を数多く提供してきました。現在は装備品のみならず、プラットフォーム（完成機）を手掛けるまでになりました。\n                                                </p>\n                                            </div>\n                                        </li>\n                                    </ul>\n                                </div>\n                                <div class=\"btn type--small\">\n                                    <div class=\"related--links col1\">\n                                        <div class=\"inside\">\n                                            <ul class=\"flex\">\n                                                <li><a class=\"btn--arrow\" href=\"business/strengths.html\"><p>住商エアロシステムの強み</p><div class=\"icon--arrow\"></div></a></li>\n                                            </ul>\n                                        </div>\n                                    </div>\n                                </div>\n                            </div>\n                        </div>\n                    </section>\n\n\n\n                    <section class=\"hr\"></section>\n\n\n\n\n                    <section id=\"top-business\" class=\"section\">\n                        <div class=\"inside\">\n                            <div class=\"h2\"><h2>事業紹介</h2></div>\n                            <div class=\"list\">\n                                <ul class=\"flex\">\n                                    <li>\n                                        <a href=\"business/about.html#anchor01\">\n                                            <div class=\"txt-set\">\n                                                <div class=\"ttl\"><p>機体・装備品・技術</p></div>\n                                                <div class=\"txt\">\n                                                    <p>\n                                                        陸上自衛隊、海上自衛隊、航空自衛隊向けに多様な装備品や機体・技術を提供しています。<br>\n                                                        国防の整備計画に基づいた適切な提案を行い、日本の安全保障の一翼を担っています。\n                                                    </p>\n                                                </div>\n                                            </div>\n                                            <div class=\"icon\"><p class=\"font--oswald bold\">READ MORE</p><div class=\"arrow\"></div></div>\n                                        </a>\n                                    </li>\n                                    <li>\n                                        <a href=\"business/about.html#anchor02\">\n                                            <div class=\"txt-set\">\n                                                <div class=\"ttl\"><p>宇宙・サイバー・電磁波領域</p></div>\n                                                <div class=\"txt\">\n                                                    <p>\n                                                        いま注目が高まっている宇宙・サイバー・電磁波領域といった新たな領域において、お取引様の課題解決に向けたサービスを提案しています。未知な部分も多く壮大なスケールの中で、私たちも確かな存在感を発揮できるよう、挑戦し続けます。\n                                                    </p>\n                                                </div>\n                                            </div>\n                                            <div class=\"icon\"><p class=\"font--oswald bold\">READ MORE</p><div class=\"arrow\"></div></div>\n                                        </a>\n                                    </li>\n                                    <li>\n                                        <a href=\"business/about.html#anchor03\">\n                                            <div class=\"txt-set\">\n                                                <div class=\"ttl\"><p>革新技術</p></div>\n                                                <div class=\"txt\">\n                                                    <p>\n                                                        技術開発は日進月歩の世界。中でも、防衛技術という最先端の分野を主戦場に、日本の安全保障に資する技術を開拓しています。<br>\n                                                        優れた新技術や新たなサービスにいち早く着目し、実用化に向けビジネスパートナーとしてサポートします。\n                                                    </p>\n                                                </div>\n                                            </div>\n                                            <div class=\"icon\"><p class=\"font--oswald bold\">READ MORE</p><div class=\"arrow\"></div></div>\n                                        </a>\n                                    </li>\n                                    <li>\n                                        <a href=\"business/about.html#anchor04\">\n                                            <div class=\"txt-set\">\n                                                <div class=\"ttl\"><p>サービス機能</p></div>\n                                                <div class=\"txt\">\n                                                    <p>\n                                                        防衛専門商社として長年培ってきた代理店・トレード機能だけでなく、変わりゆくお客様のニーズに応え、新たな価値を提供していきます。\n                                                    </p>\n                                                </div>\n                                            </div>\n                                            <div class=\"icon\"><p class=\"font--oswald bold\">READ MORE</p><div class=\"arrow\"></div></div>\n                                        </a>\n                                    </li>\n                                </ul>\n                            </div>\n                        </div>\n                    </section>\n\n\n\n                    <section class=\"hr\"></section>\n\n\n\n\n                    <section id=\"top-news\" class=\"section\">\n                        <div class=\"inner750\">\n                            <div class=\"inside\">\n                                <div class=\"h2\"><h2>NEWS</h2></div>\n                                <div class=\"list\">\n                                    <div id=\"js--inc-news\"></div>\n                                </div>\n                                <div class=\"btn\">\n                                    <div class=\"related--links col1\">\n                                        <div class=\"inside\">\n                                            <ul class=\"flex\">\n                                                <li><a class=\"btn--arrow btn--contact\" href=\"contact/\"><p>お問い合わせはこちら</p><div class=\"icon--arrow\"></div></a></li>\n                                            </ul>\n                                        </div>\n                                    </div>\n                                </div>\n                            </div>\n                        </div>\n                    </section>\n                </article>\n            </main>\n\n\n            <footer class=\"lang-jp home\">\n                <div class=\"inner1200\">\n                    <a id=\"pagetop\" class=\"hover--alpha\" href=\"#wrapper\" data-fade=\"0\"><img class=\"js-switching\" data-src=\"assets/img/common/btn_pagetop.png\" alt=\"PAGE TOP\"></a>\n                </div>\n                <a class=\"accordion-btn spshow\"><p>Site map</p></a>\n                <div class=\"upper accordion-body\">\n                    <div class=\"inner1000\">\n                        <div class=\"flex\">\n                            \n                            <div class=\"col\">\n                                <div class=\"parent\"><a href=\"\">TOP</a></div>\n                                <ul>\n                                    <li><a class=\"hover--underline type--black\" href=\"en/\">ENGLISH</a></li>\n                                    <li><a class=\"hover--underline type--black\" href=\"contact/\">お問い合わせ</a></li>\n                                    <li><a class=\"hover--underline type--black blank\" href=\"https://www.sumitomocorp.com/ja/jp\" target=\"_blank\">住友商事</a></li>\n                                </ul>\n                            </div>\n                            <div class=\"col\">\n                                <div class=\"parent\"><a href=\"message/\">ごあいさつ</a></div>\n                            </div>\n                            <div class=\"col\">\n                                <div class=\"parent\"><a href=\"company/\">企業情報</a></div>\n                                <ul>\n                               