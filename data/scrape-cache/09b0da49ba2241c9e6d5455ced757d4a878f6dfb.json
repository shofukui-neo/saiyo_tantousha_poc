{"url":"https://www.dynapac-gr.co.jp/csr/employees/index.html","html":"<!DOCTYPE html>\n<html lang=\"ja\" class=\"csr\"><!-- InstanceBegin template=\"/Templates/normal_page.dwt\" codeOutsideHTMLIsLocked=\"false\" -->\n<head>\n<meta charset=\"UTF-8\">\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n<!-- Google Tag Manager -->\r\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\r\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\r\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\r\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\r\n})(window,document,'script','dataLayer','GTM-K7N4KJ9');</script>\r\n<!-- End Google Tag Manager -->\n\n<title>従業員と共に｜サステナビリティ｜ダイナパック株式会社</title>\n\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<!-- InstanceBeginEditable name=\"meta\" -->\n<meta name=\"Description\" content=\"ダイナパック株式会社・サステナビリティの従業員と共にのご紹介です。\">\n<meta name=\"Keywords\" content=\"従業員,段ボール,ダンボール,パレット,緩衝材,梱包材,化粧箱,軟包装材,パルプモールド\">\n<!-- InstanceEndEditable -->\n<meta name=\"format-detection\" content=\"telephone=no\">\n<link rel=\"shortcut icon\" href=\"/common/images/favicon.ico\">\n<link href=\"/common/css/html5reset.css\" rel=\"stylesheet\" type=\"text/css\">\n<link href=\"/common/css/screen.css\" rel=\"stylesheet\">\n<link href=\"/common/css/clearfix.css\" rel=\"stylesheet\">\n<script src=\"/common/js/g_analytics.js\"></script>\n\n<!-- InstanceBeginEditable name=\"head\" -->\n<style type=\"text/css\">\n.link-kanren .csr_employees{\n\tdisplay:none;\n\t}\n</style>\n<!-- InstanceEndEditable -->\n<!-- InstanceParam name=\"ページタイトル\" type=\"text\" value=\"従業員と共に\" -->\n<!-- InstanceParam name=\"ページタイトル2\" type=\"text\" value=\"｜サステナビリティ\" -->\n\n<!-- InstanceParam name=\"PageClass\" type=\"text\" value=\"csr\" -->\n<!-- InstanceParam name=\"ローカルナビエリア\" type=\"boolean\" value=\"true\" -->\n<!-- InstanceParam name=\"ローカルナビ01_企業情報\" type=\"boole