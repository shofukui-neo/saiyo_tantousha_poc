' />\n<link rel='stylesheet' id='veu-cta-css' href='https://www.kokudoec.co.jp/wp-content/plugins/vk-all-in-one-expansion-unit/inc/call-to-action/package/assets/css/style.css?ver=9.109.0.1' media='all' />\n<link rel=\"https://api.w.org/\" href=\"https://www.kokudoec.co.jp/wp-json/\" /><link rel=\"alternate\" title=\"JSON\" type=\"application/json\" href=\"https://www.kokudoec.co.jp/wp-json/wp/v2/pages/183\" /><link rel=\"EditURI\" type=\"application/rsd+xml\" title=\"RSD\" href=\"https://www.kokudoec.co.jp/xmlrpc.php?rsd\" />\n<meta name=\"generator\" content=\"WordPress 7.0\" />\n<link rel=\"canonical\" href=\"https://www.kokudoec.co.jp/recruit/special/\" />\n<link rel='shortlink' href='https://www.kokudoec.co.jp/?p=183' />\n<!-- [ VK All in One Expansion Unit OGP ] -->\n<meta property=\"og:site_name\" content=\"株式会社国土技術コンサルタンツ\" />\n<meta property=\"og:url\" content=\"https://www.kokudoec.co.jp/recruit/special/\" />\n<meta property=\"og:title\" content=\"KAGOSHIMA | 株式会社国土技術コンサルタンツ\" />\n<meta property=\"og:description\" content=\"                                  KAGOSHIMA        ようこそ！魅力あふれる鹿児島県へ！                              \\ これぞ鹿児島メシ！ 極上のグルメ体験 /                        01          黒豚の極上の味わい          とろけるような脂の甘みと上質な肉質が特徴の鹿児島黒豚。とんかつやしゃぶしゃぶで堪能すると、\" />\n<meta property=\"og:type\" content=\"article\" />\n<!-- [ / VK All in One Expansion Unit OGP ] -->\n<!-- [ VK All in One Expansion Unit twitter card ] -->\n<meta name=\"twitter:card\" content=\"summary_large_image\">\n<meta name=\"twitter:description\" content=\"                                  KAGOSHIMA        ようこそ！魅力あふれる鹿児島県へ！                              \\ これぞ鹿児島メシ！ 極上のグルメ体験 /                        01          黒豚の極上の味わい          とろけるような脂の甘みと上質な肉質が特徴の鹿児島黒豚。とんかつやしゃぶしゃぶで堪能すると、\">\n<meta name=\"twitter:title\" content=\"KAGOSHIMA | 株式会社国土技術コンサルタンツ\">\n<meta name=\"twitter:url\" content=\"https://www.kokudoec.co.jp/recruit/special/\">\n\t<meta name=\"twitter:domain\" content=\"www.kokudoec.co.jp\">\n\t<!-- [ / VK All in One Expansion Unit twitter card ] -->\n\t<link rel=\"icon\" href=\"https://www.kokudoec.co.jp/wp-content/uploads/2025/07/cropped-favicon-32x32.png\" sizes=\"32x32\" />\n<link rel=\"icon\" href=\"https://www.kokudoec.co.jp/wp-content/uploads/2025/07/cropped-favicon-192x192.png\" sizes=\"192x192\" />\n<link rel=\"apple-touch-icon\" href=\"https://www.kokudoec.co.jp/wp-content/uploads/2025/07/cropped-favicon-180x180.png\" />\n<meta name=\"msapplication-TileImage\" content=\"https://www.kokudoec.co.jp/wp-content/uploads/2025/07/cropped-favicon-270x270.png\" />\n  </head>\n\n  <body class=\"wp-singular page-template page-template-page-recruit page-template-page-recruit-php page page-id-183 page-child parent-pageid-157 wp-theme-kokudo post-name-special post-type-page\">\n    <header class=\"l-header\">\n      <div class=\"l-header__logo\">\n        <a href=\"/recruit\">\n          <img src=\"/wp-content/themes/kokudo/recruit/assets/img/common/h-logo.webp\">\n          <p>\n            <span>国土技術コンサルタンツ</span>\n            <u></u>\n            <span>RECRUIT</span>\n          </p>\n        </a>\n      </div>\n      <div class=\"c-hamburger\">\n        <input type=\"checkbox\" id=\"menu-btn-check\">\n        <label for=\"menu-btn-check\" class=\"c-hamburger__btn\"><span></span></label>\n        <!--ここからメニュー-->\n        <div class=\"c-hamburger__menu\">\n          <ul class=\"l-header__nav\">\n            <li>\n              <a href=\"/recruit\">TOP</a>\n            </li>\n            <li>\n              <a href=\"/recruit/message\">メッセージ</a>\n            </li>\n            <li>\n              <a href=\"/recruit/company\">会社を知る</a>\n            </li>\n            <li>\n              <a href=\"/recruit/member\">働く人を知る</a>\n            </li>\n            <li>\n              <a href=\"/recruit/business\">仕事を知る</a>\n            </li>\n            <li>\n              <a href=\"/recruit/#ENVIRONMENT\">働く環境を知る</a>\n              <ul class=\"is-sp\">\n                <li>\n                  <a href=\"/recruit/data\">⚫︎数字で見る</a>\n                </li>\n                <li><a href=\"/recruit/service\">⚫︎福利厚生 / キャリア形成</a></li>\n                <li>\n                  <a href=\"/recruit/special\">⚫︎鹿児島スペシャルページ</a>\n                </li>\n              </ul>\n            </li>\n            <li>\n              <a href=\"/recruit/information\">採用情報</a>\n            </li>\n            <li>\n              <a href=\"/contact\">お問い合わせ</a>\n            </li><li class=\"is-sp\"><a href=\"/\">コーポレートサイトへ</a></li>\n          </ul>\n          <!--ここまでメニュー-->\n        </div>\n      </div>\n\n    </header>\n\n  <main class=\"p-special\">\n    <section class=\"p-special__fv\">\n      <img decoding=\"async\" src=\"/wp-content/themes/kokudo/recruit/assets/img/special/image01.webp\" alt=\"\">\n    </section>\n\n    <section class=\"p-special__kagooshima\">\n      <h2>\n        <span>KAGOSHIMA</span>\n        ようこそ！<br class=\"is-sp\">魅力あふれる鹿児島県へ！\n      </h2>\n      <img decoding=\"async\" src=\"/wp-content/themes/kokudo/recruit/assets/img/special/image02.webp\" alt=\"\">\n    </section>\n    \n    <section class=\"p-special__gourmet\">\n      <h2>\\ これぞ鹿児島メシ！ 極上のグルメ体験 /</h2>\n      <ul>\n        <li>\n          <span>01</span>\n          <h3>黒豚の極上の味わい</h3>\n          <p>とろけるような脂の甘みと上質な肉質が特徴の鹿児島黒豚。とんかつやしゃぶしゃぶで堪能すると、その違いを実感できます。全国生産量の約8割を占める鹿児島の黒豚は、まさに日本を代表する豚肉です。</p>\n          <img decoding=\"async\" src=\"/wp-content/themes/kokudo/recruit/assets/img/special/image03.webp\" alt=\"\">\n        </li>\n        <li>\n          <span>02</span>\n          <h3>黒牛の贅沢な霜降り</h3>\n          <p>きめ細かい霜降りと深い旨味が特徴の鹿児島黒牛。ステーキやすき焼きなど、様々な料理で堪能できます。全国和牛能力共進会で数々の賞を受賞する品質の高さを誇ります。</p>\n          <img decoding=\"async\" src=\"/wp-content/themes/kokudo/recruit/assets/img/special/image04.webp\" alt=\"\">\n        </li>\n        <li>\n          <span>03</span>\n          <h3>さつま地鶏の力強い味</h3>\n          <p>引き締まった肉質としっかりとした旨みが特徴のさつま地鶏。炭火焼きや鶏飯など、地元ならではの調理法で楽しめます。日本の地鶏の中でも特に人気が高い品種です。</p>\n          <img decoding=\"async\" src=\"/wp-content/themes/kokudo/recruit/assets/img/special/image05.webp\" alt=\"\">\n        </li>\n        <li>\n          <span>04</span>\n          <h3>さつまいもの多彩な活用</h3>\n          <p>鹿児島の代表的な農産物であるさつまいも。スイートポテトや焼酎など様々な形で楽しめます。特に芋焼酎の原料として、鹿児島の食文化に欠かせない存在です。</p>\n          <img decoding=\"async\" src=\"/wp-content/themes/kokudo/recruit/assets/img/special/image06.webp\" alt=\"\">\n        </li>\n      </ul>\n\n      <h2>「鹿児島の海の幸」 〜新鮮な恵みを堪能〜</h2>\n      <img decoding=\"async\" src=\"/wp-content/themes/kokudo/recruit/assets/img/special/image07.webp\" alt=\"\">\n\n      <h2>「鹿児島温泉天国」〜 癒しの湯めぐり 〜</h2>\n      <img decoding=\"async\" src=\"/wp-content/themes/kokudo/recruit/assets/img/special/image08.webp\" alt=\"\">\n\n      <h2>交通のアクセスに最適な本社</h2>\n      <img decoding=\"async\" src=\"/wp-content/themes/kokudo/recruit/assets/img/special/image09.webp\" alt=\"\">\n    </section>\n\n    <section class=\"p-special__spot\">\n      <h2>世界遺産として有数な観光地</h2>\n      <img decoding=\"async\" src=\"/wp-content/themes/kokudo/recruit/assets/img/special/image10.webp\" alt=\"\">\n\n      <h2>革新の町として歴史的な場所</h2>\n      <img decoding=\"async\" src=\"/wp-content/themes/kokudo/recruit/assets/img/special/image11.webp\" alt=\"\">\n\n      <h2>宇宙開発の中心地</h2>\n      <img decoding=\"async\" src=\"/wp-content/themes/kokudo/recruit/assets/img/special/image12.webp\" alt=\"\">\n\n      <h2>鹿児島県観光サイト</h2>\n      <img decoding=\"async\" src=\"/wp-content/themes/kokudo/recruit/assets/img/special/image13.webp\" alt=\"\">\n\n      <a href=\"https://www.kagoshima-kankou.com/\" target=\"_blank\">鹿児島県観光サイトを見る<i class=\"fa-solid fa-arrow-right\" aria-hidden=\"true\"></i></a>\n    </section>\n\n  </main>\n\n<section class=\"l-entry\">\n      <!-- 画像エリア -->\n      <div class=\"l-entry-bg\">\n        <strong>あなたの夢を、街に刻もう！</strong>\n        <p>わたしたちと一緒に未来を作っていきませんか？</p>\n\n        <div class=\"l-entry__btn\">\n          <a href=\"https://rqt2iij1f.jbplt.jp/\" target=\"_blank\">キャリア採用<i class=\"fa-solid fa-square-caret-right\"></i></a>\n          <a href=\"/recruit/information/\">新卒採用<i class=\"fa-solid fa-square-caret-right\"></i></a>\n        </div>\n      </div>\n\n      <!-- 追従ボタン -->\n      <a class=\"l-entry__fixed-btn is-new\" href=\"/recruit/information/\">\n        <div>\n          <img src=\"/wp-content/themes/kokudo/recruit/assets/img/common/entry-icon2.webp\" alt=\"\">\n        </div>\n        <span>新卒採用</span>\n        ENTRY\n      </a>\n\n      <a class=\"l-entry__fixed-btn is-mid\" href=\"https://rqt2iij1f.jbplt.jp/\" target=\"_blank\">\n        <div>\n          <img src=\"/wp-content/themes/kokudo/recruit/assets/img/common/entry-icon1.webp\" alt=\"\">\n        </div>\n        <span>キャリア採用</span>\n        ENTRY\n      </a>\n\n      <div class=\"l-entry__spbtn is-sp\" style=\"bottom: 0px;\">\n        <div class=\"l-entry__spbtn-flex\">\n          <a class=\"l-entry__spbtn-recruit\" href=\"/recruit/information/\">新卒採用</a>\n          <a class=\"l-entry__spbtn-graduate\" href=\"https://rqt2iij1f.jbplt.jp/\" target=\"_blank\">キャリア採用</a>\n        </div>\n      </div>\n\n    </section>\n\n    <footer class=\"l-footer\">\n      <!-- 画像下リンク集 -->\n      <div class=\"l-footer__links-list\">\n        <div class=\"l-footer__textlink\">\n          <a href=\"https://rqt2iij1f.jbplt.jp/\" target=\"_blank\">キャリア<br class=\"is-sp\">採用\n            <span><i class=\"icon fa-solid fa-arrow-right-long\"></i></span>\n            <u></u>\n          </a>\n          <a href=\"/recruit/information\">新卒<br class=\"is-sp\">採用情報\n            <span><i class=\"icon fa-solid fa-arrow-right-long\"></i></span>\n            <u></u>\n          </a>\n        </div>\n  \n        <div class=\"l-footer__btnlink\">\n          <span></span>\n          <a href=\"https://job.mynavi.jp/27/pc/search/corp272088/outline.html\" target=\"_blank\">インターンシップ</a>\n          <a href=\"contact\">CONTACT</a>\n        </div>\n        \n      </div>\n\n      <div class=\"l-footer__flex\">\n 