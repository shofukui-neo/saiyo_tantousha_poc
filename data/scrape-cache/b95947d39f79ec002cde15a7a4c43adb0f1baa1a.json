{"url":"https://www.takizumi.com/recruit/workflow/","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n<head prefix=\"og: http://ogp.me/ns#\">\n\t<!-- Google tag (gtag.js) -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-23HKB9BP8V\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'G-23HKB9BP8V');\n</script>\t<meta charset=\"UTF-8\">\n\t<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n\t<title>1日の仕事の流れ｜タキズミ採用サイト</title>\n  <meta name=\"description\" content=\"タキズミの社員の1日の仕事の流れを紹介します。タキズミを代表する職種の社員がどんな日常を送っているのか密着しました。\">\n  <meta name=\"keywords\" content=\"\">\n\n  <meta property=\"fb:app_id\" content=\"\">\n  <meta property=\"og:title\" content=\"1日の仕事の流れ｜タキズミ採用サイト\">\n  <meta property=\"og:description\" content=\"タキズミの社員の1日の仕事の流れを紹介します。タキズミを代表する職種の社員がどんな日常を送っているのか密着しました。\">\n  <meta property=\"og:type\" content=\"website\">\n  <meta property=\"og:image\" content=\"https://www.takizumi.com/recruit/images/ogp.jpg\">\n  <meta property=\"og:url\" content=\"https://www.takizumi.com/recruit/workflow/\">\n  <meta property=\"og:site_name\" content=\"株式会社タキズミ\">\n  <meta property=\"og:locale\" content=\"ja_JP\">\n  <meta name=\"twitter:title\" content=\"1日の仕事の流れ｜タキズミ採用サイト\">\n  <meta name=\"twitter:description\" content=\"タキズミの社員の1日の仕事の流れを紹介します。タキズミを代表する職種の社員がどんな日常を送っているのか密着しました。\">\n  <meta name=\"twitter:image\" content=\"https://www.takizumi.com/recruit/images/ogp.jpg\">\n  <meta name=\"twitter:url\" content=\"https://www.takizumi.com/recruit/workflow/\">\n  <meta name=\"twitter:card\" content=\"summary_large_image\">\n\t<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<link rel=\"icon\" href=\"/recruit/images/apple-touch-icon.png\">\n<link rel=\"shortcut icon\" href=\"/recruit/images/apple-touch-icon.png\">\n<link rel=\"shortcut icon\" type=\"image/x-icon\" href=\"/recruit/favicon.ico\">\n<link rel=\"apple-touch-icon\" href=\"/recruit/images/apple-touch-icon.png\">\n<link rel=\"apple-touch-icon-precomposed\" href=\"/recruit/images/apple-touch-icon-precomposed.png\">\n\n\t<link rel=\"stylesheet\" href=\"../css/reset.css\">\n  <link rel=\"stylesheet\" href=\"../css/style.css\">\n</head>\n<body>\n\t\n  <div id=\"wrapper\" class=\"workflow\">\n  <div id=\"Loader\"><span class=\"base\"></span><span class=\"progress\"></span></div>\n\t\t<div id=\"page\">\n\t\t\t<header id=\"header\" class=\"header\">\n  <div class=\"header_logo_area\"><a href=\"/recruit/\">\n    <p class=\"header_logo\"><img src=\"/recruit/images/all_logo.jpg\" alt=\"株式会社タキズミ\"></p>\n    <p class=\"header_logo_recruit\">RECRUIT SITE</p>\n  </a></div>\n\t<div class=\"header_menubtn\">\n\t\t<div class=\"header_menubtn_lines\">\n\t\t\t<span></span>\n\t\t\t<span></span>\n\t\t</div>\n\t</div>\n\t<div class=\"header_wrap\">\n\t\t<div class=\"header_wrap_inner\">\n\t\t\t<nav class=\"header_gnav\">\n\t\t\t\t<ul class=\"header_gnav_nav\">\n\t\t\t\t\t<li class=\"header_gnav_item header_gnav_item_01 header_gnav_item_solo\"><a href=\"/recruit/business/\">事業紹介</a></li>\n\t\t\t\t\t<li class=\"header_gnav_item header_gnav_item_02 header_gnav_item_mega\"><span>仕事を知る</span>\n\t\t\t\t\t\t<div class=\"header_gnav_mega\">\n\t\t\t\t\t\t\t<ul class=\"header_megamenu\">\n\t\t\t\t\t\t\t\t<li class=\"header_megamenu_item\"><a href=\"/recruit/crosstalk/\">社員クロストーク</a></li>\n\t\t\t\t\t\t\t\t<li class=\"header_megamenu_item\"><a href=\"/recruit/workflow/\">1日の仕事の流れ</a></li>\n\t\t\t\t\t\t\t</ul>\n\t\t\t\t\t\t</div>\n          </li>\n\t\t\t\t\t<li class=\"header_gnav_item header_gnav_item_03 header_gnav_item_mega\"><span>働く環境を知る</span>\n\t\t\t\t\t\t<div class=\"header_gnav_mega\">\n\t\t\t\t\t\t\t<ul class=\"header_megamenu\">\n\t\t\t\t\t\t\t\t<li class=\"header_megamenu_item\"><a href=\"/recruit/training/\">キャリア・研修制度</a></li>\n\t\t\t\t\t\t\t\t<li class=\"header_megamenu_item\"><a href=\"/recruit/welfare/\">福利厚生</a></li>\n\t\t\t\t\t\t\t</ul>\n\t\t\t\t\t\t</div>\n          </li>\n\t\t\t\t\t<li class=\"header_gnav_item header_gnav_item_04 header_gnav_item_mega\"><span>人を知る</span>\n\t\t\t\t\t\t<div class=\"header_gnav_mega\">\n\t\t\t\t\t\t\t<ul class=\"header_megamenu\">\n\t\t\t\t\t\t\t\t<li class=\"header_megamenu_item\"><a href=\"/recruit/Interview01/\">社員インタビュー01</a></li>\n\t\t\t\t\t\t\t\t<li class=\"header_megamenu_item\"><a href=\"/recruit/Interview02/\">社員インタビュー02</a></li>\n\t\t\t\t\t\t\t\t<!-- <li class=\"header_megamenu_item\"><a href=\"/recruit/Interview03/\">社員インタビュー03</a></li>  -->\n\t\t\t\t\t\t\t\t<!-- <li class=\"header_megamenu_item\"><a href=\"/recruit/Interview04/\">社員インタビュー04</a></li> -->\n\t\t\t\t\t\t\t</ul>\n\t\t\t\t\t\t</div>\n          </li>\n\t\t\t\t\t<li class=\"header_gnav_item header_gnav_item_05 header_gnav_item_solo\"><a href=\"/recruit/detail/\">募集要項</a></li>\n\t\t\t\t</ul>\n\t\t\t</nav>\n      <p class=\"header_corporate\"><a href=\"http://www.takizumi.com/\" target=\"_blank\">コーポレートサイトはこちら</a></p>\n\t\t\t<div class=\"header_entry\">\n\t\t\t\t<p class=\"header_entry_btn\"><a href=\"/recruit/detail/#message\">エントリー</a></p>\n\t\t\t</div>\n      <p class=\"header_copy\">&copy; 2022 TAKIZUMI All Right Reserved.</p>\n\t\t</div><!-- /.header_wrap_inner -->\n\t</div><!-- /.header_wrap -->\n</header>\n\n\t\t\t<main id=\"main\">\n\t\t\t\t<div class=\"all_m_mv\"><div class=\"all_m_mv_wrap\">\n          <div class=\"all_m_mv_title\">\n\t\t\t\t\t\t<h1 class=\"all_m_mv_title_text\">1日の仕事の流れ</h1>\n            <span class=\"all_m_mv_title_obj\"><img src=\"../images/workflow_txt_obj.svg\" alt=\"Work flow\"></span>\n\t\t\t\t\t</div>\n          <figure class=\"all_m_mv_img\"><img src=\"../images/workflow_img_mv.jpg\" width=\"2800\" height=\"1400\" alt=\"1日の仕事の流れ画像\"></figure>\n          <div class=\"all_m_mv_scroll\">\n            <p class=\"all_m_mv_scroll_img\"><img src=\"../images/all_img_mv_scroll.svg\" alt=\"SCROLL\"></p>\n          </div>\n\t\t\t\t</div></div><!-- /.all_m_mv -->\n\n        <div class=\"all_m_intro\">\n          <div class=\"all_l_wrap\">\n            <h2 class=\"all_m_intro_title all_c_title_en\" data-anim=\"fadeup\">・Workflow</h2>\n            <p class=\"all_m_intro_catch\" data-anim=\"fadeup\">タキズミ社員の1日を<br class=\"all_mi_sp\">ご紹介します</p>\n            <p class=\"all_m_intro_text\" data-anim=\"fadeup\">タキズミを代表する職種の社員がどんな日常を送っているのか密着しました。入社してからの日々をイメージしてみてください。</p>\n          </div>\n        </div><!-- /.all_m_intro -->\n\n        <div class=\"workflow_contents js-target-tab\" data-anim=\"fadeup\">\n          <div class=\"workflow_contents_nav all_l_wrap\">\n            <ul class=\"workflow_tabnav\" style=\"justify-content: center;\">\n              <!-- <li class=\"workflow_tabnav_btn js-trigger-tab\"><a href=\"#sales\"><h3 class=\"workflow_contents_title\">営業職の1日</h3></a></li> -->\n              <li class=\"workflow_tabnav_btn js-trigger-tab\"><a href=\"#construction\"><h3 class=\"workflow_contents_title\">施工管理職の1日</h3></a></li>\n            </ul>\n          </div>\n          <div class=\"all_l_wrap_l\">\n            <div class=\"workflow_contents_body\">\n              <!-- <div id=\"sales\" class=\"workflow_oneday js-content-tab\">\n                <div class=\"workflow_oneday_profile\">\n                  <div class=\"workflow_oneday_profile_label\">\n                    <h4 class=\"workflow_oneday_profile_title all_c_title_en\">・Profile</h4>\n                    <p class=\"workflow_oneday_profile_name\">H.M.</p>\n                  </div>\n                  <p class=\"workflow_oneday_profile_text\">管理ソリューション部　入社6年目</p>\n                  <figure class=\"workflow_oneday_profile_img\"><img src=\"../images/workflow_img_sales_hm.png\" width=\"214\" height=\"239\" alt=\"H.M.\"></figure>\n                </div>\n                <div class=\"workflow_oneday_flow\">\n                  <div class=\"workflow_oneday_flow_body\">\n                    <ol class=\"workflow_oneday_flow_list\">\n                      <li class=\"workflow_oneday_flow_item\">\n                        <h5 class=\"workflow_oneday_flow_title\">\n                          <span class=\"workflow_oneday_flow_title_time\">09:00</span>\n                          <span class=\"workflow_oneday_flow_title_text\">出勤・朝礼参加</span>\n                        </h5>\n                        <p class=\"workflow_oneday_flow_text\">朝いちばんに行うのはパソコンでのメール確認。必要に応じて返信した後は、朝礼に参加。身が引き締まります。</p>\n                        <figure class=\"workflow_oneday_flow_img\">\n                          <img src=\"../images/workflow_img_sales_flow01.jpg\" width=\"400\" height=\"300\" alt=\"出勤画像\">\n                        </figure>\n                      </li>\n                      <li class=\"workflow_oneday_flow_item\">\n                        <h5 class=\"workflow_oneday_flow_title\">\n                          <span class=\"workflow_oneday_flow_title_time\">11:00</span>\n                          <span class=\"workflow_oneday_flow_title_text\">退去立会</span>\n                        </h5>\n                        <p class=\"workflow_oneday_flow_text\">引っ越しを終えたお客様の部屋へ向かい、鍵の返却と室内の確認を行います。壁紙・クロスの傷や汚れ、水まわりのカビや水垢など定められたポイントを点検。</p>\n                      </li>\n                      <li class=\"workflow_oneday_flow_item\">\n                        <h5 class=\"workflow_oneday_flow_title\">\n                          <span class=\"workflow_oneday_flow_title_time\">13:00</span>\n                          <span class=\"workflow_oneday_flow_title_text\">内勤</span>\n                        </h5>\n                        <p class=\"workflow_oneday_flow_text\">得意先に提出する見積や資料の作成。6年目になって最近は慣れてきたため、短時間で作成できるようになりました。</p>\n                      </li>\n                      <li class=\"workflow_oneday_flow_item\">\n                        <h5 class=\"workflow_oneday_flow_title\">\n                          <span class=\"workflow_oneday_flow_title_time\">15:00</span>\n                          <span class=\"workflow_oneday_flow_title_text\">会議orミーティング</span>\n                        </h5>\n                        <p class=\"workflow_oneday_flow_text\">社内での新しい取り組みや仕組みについてディスカッションを行います。チームメンバーを集め、直近の売上とトピックスの確認をします。</p>\n                        <figure class=\"workflow_oneday_flow_img\">\n                          <img src=\"../images/workflow_img_sales_flow02.jpg\" width=\"400\" height=\"300\" alt=\"会議orミーティング画像\">\n                        </figure>\n                      </li>\n                      <li class=\"workflow_oneday_flow_item\">\n                        <h5 class=\"workflow_oneday_flow_title\">\n                          <span class=\"workflow_oneday_flow_title_time\">18:00</span>\n                          <span class=\"workflow_oneday_flow_title_text\">退社</span>\n                        </h5>\n                        <p class=\"workflow_oneday_flow_text\">今日1日の仕事を振り返り、明日以降に持ち越す案件についてはとりまとめ、整理をしてから退社します。</p>\n                        <figure class=\"workflow_oneday_flow_img\">\n                          <img src=\"../images/workflow_img_sales_flow03.jpg\" width=\"400\" height=\"300\" alt=\"内勤画像\">\n                        </figure>\n                      </li>\n                    </ol>\n                    <ol class=\"workflow_oneday_flow_imglist\">\n                      <li class=\"workflow_oneday_flow_imgitem\">\n                        <figure class=\"workflow_oneday_flow_imgitem_img\">\n                          <img src=\"../images/workflow_img_sales_flow01.jpg\" width=\"400\" height=\"300\" alt=\"出勤画像\">\n                        </figure>\n                      </li>\n                      <li class=\"workflow_oneday_flow_imgitem\">\n                        <figure class=\"workflow_oneday_flow_imgitem_img\">\n                          <img src=\"../images/workflow_img_sales_flow03.jpg\" width=\"400\" height=\"300\" alt=\"内勤画像\">\n                        </figure>\n                      </li>\n                      <li class=\"workflow_oneday_flow_imgitem\">\n                        <figure class=\"workflow_oneday_flow_imgitem_img\">\n                          <img src=\"../images/workflow_img_sales_flow02.jpg\" width=\"400\" height=\"300\" alt=\"会議orミーティング画像\">\n                        </figure>\n                      </li>\n                    </ol>\n                  </div>\n\n                  <div class=\"workflow_oneday_dayoff\">\n                    <figure class=\"workflow_oneday_dayoff_img\"><img src=\"../images/workflow_img_sales_off.jpg\" width=\"200\" height=\"200\" alt=\"休みの日の過ごし方イメージ画像\"></figure>\n                    <div class=\"workflow_oneday_dayoff_body\">\n                      <h5 class=\"workflow_oneday_dayoff_title\">\n                        <span class=\"workflow_oneday_dayoff_title_en all_c_title_en\">・Day Off</span>\n                        <span class=\"workflow_oneday_dayoff_title_text\">休みの日の過ごし方</span>\n                      </h5>\n                      <p class=\"workflow_oneday_dayoff_text\">休日は家族でショッピングに出かけたり、ドライブで遠出をしたり。それ以外は自分の趣味に時間を使うことが多いです。</p>\n                    </div>\n                  </div>\n                </div>\n              </div> -->\n              <div id=\"construction\" class=\"workflow_oneday js-content-tab\">\n                <div class=\"workflow_oneday_profile\">\n                  <div class=\"workflow_oneday_profile_label\">\n                    <h4 class=\"workflow_oneday_profile_title all_c_title_en\">・Profile</h4>\n                    <p class=\"workflow_oneday_profile_name\">S.N.</p>\n                  </div>\n                  <p class=\"workflow_oneday_profile_text\">PMソリューション部　施工管理課　入社6年目</p>\n                  <figure class=\"workflow_oneday_profile_img\"><img src=\"../images/workflow_img_construction_sh.png\" width=\"214\" height=\"239\" alt=\"S.N.\"></figure>\n                </div>\n                <div class=\"workflow_oneday_flow\">\n                  <div class=\"workflow_oneday_flow_body\">\n                    <ol class=\"workflow_oneday_flow_list\">\n                      <li class=\"workflow_oneday_flow_item\">\n                        <h5 class=\"workflow_oneday_flow_title\">\n                          <span class=\"workflow_oneday_flow_title_time\">09:00</span>\n                          <span class=\"workflow_oneday_flow_title_text\">出勤・朝礼参加</span>\n                        </h5>\n                        <p class=\"workflow_oneday_flow_text\">オフィスまでは約30分、施工現場に直行する時は1時間程度かかる場合もあります。通勤時は音楽を聴きながら、オフィスに着いたらメールやLINE WORKSをチェックします。</p>\n                        <figure class=\"workflow_oneday_flow_img\">\n                          <img src=\"../images/workflow_img_construction_flow01.jpg\" width=\"400\" height=\"300\" alt=\"出勤画像\">\n                        </figure>\n                      </li>\n                      <li class=\"workflow_oneday_flow_item\">\n                        <h5 class=\"workflow_oneday_flow_title\">\n                          <span class=\"workflow_oneday_flow_title_time\">10:00</span>\n                          <span class=\"workflow_oneday_flow_title_text\">施工現場でのミーティング</span>\n                        </h5>\n                        <p class=\"workflow_oneday_flow_text\">その日1日の仕事内容をミーティングで確認。自社の上司、営業、デザイン課のスタッフ、施工会社の職人さんなど、メンバーは案件や施工内容によって様々です。</p>\n                      </li>\n                      <li class=\"workflow_oneday_flow_item\">\n                        <h5 class=\"workflow_oneday_flow_title\">\n                          <span class=\"workflow_oneday_flow_title_time\">11:00</span>\n                          <span class=\"workflow_oneday_flow_title_text\">現場指示</span>\n                        </h5>\n                        <p class=\"workflow_oneday_flow_text\">私が担当しているのはオフィスビルの原状回復や水廻りのリニューアルが中心。塗装業者、内装業者などの職人さんに指示するときは、できるだけわかりやすく具体的に、を心がけています。</p>\n                        <figure class=\"workflow_oneday_flow_img\">\n                          <img src=\"../images/workflow_img_construction_flow02.jpg\" width=\"400\" height=\"300\" alt=\"現場指示画像\">\n                        </figure>\n                      </li>\n                      <li class=\"workflow_oneday_flow_item\">\n                        <h5 class=\"workflow_oneday_flow_title\">\n                          <span class=\"workflow_oneday_flow_title_time\">15:00</span>\n                          <span class=\"workflow_oneday_flow_title_text\">パソコンによる図面作成</span>\n                        </h5>\n                        <p class=\"workflow_oneday_flow_text\">図面作成は入社後に学びました。最初は先輩社員に随分助けてもらいましたね。PDFデータを編集して、現場の職人さんに理解してもらえる内容に仕上げます。</p>\n                      </li>\n                      <li class=\"workflow_oneday_flow_item\">\n                        <h5 class=\"workflow_oneday_flow_title\">\n                          <span class=\"workflow_oneday_flow_title_time\">18:00</span>\n                          <span class=\"workflow_oneday_flow_title_text\">退社</span>\n                        </h5>\n                        <p class=\"workflow_oneday_flow_text\">退社前には、必ずLINE WORKSで施工現場に関する報告を送り、メンバーに進行状況を周知してもらいます。また、明日の予定を確認して資料の準備などを行います。</p>\n                        <figure class=\"workflow_oneday_flow_img\">\n                          <img src=\"../images/workflow_img_construction_flow03.jpg\" width=\"400\" height=\"300\" alt=\"退社画像\">\n                        </figure>\n                      </li>\n                    </ol>\n                    <ol class=\"workflow_oneday_flow_imglist\">\n                      <li class=\"workflow_oneday_flow_imgitem\">\n                        <figure class=\"workflow_oneday_flow_imgitem_img\">\n                          <img src=\"../images/workflow_img_construction_flow01.jpg\" width=\"400\" height=\"300\" alt=\"出勤画像\">\n                        </figure>\n                      </li>\n                      <li class=\"workflow_oneday_flow_imgitem\">\n                        <figure class=\"workflow_oneday_flow_imgitem_img\">\n                          <img src=\"../images/workflow_img_construction_flow02.jpg\" width=\"400\" height=\"300\" alt=\"現場指示画像\">\n                        </figure>\n                      </li>\n                      <li class=\"workflow_oneday_flow_imgitem\">\n                        <figure class=\"workflow_oneday_flow_imgitem_img\">\n                          <img src=\"../images/workflow_img_construction_flow03.jpg\" width=\"400\" height=\"300\" alt=\"退社画像\">\n                        </figure>\n                      </li>\n                    </ol>\n                  </div>\n\n                  <div class=\"workflow_oneday_dayoff\">\n                    <figure class=\"workflow_oneday_dayoff_img\"><img src=\"../images/workflow_img_construction_off.jpg\" width=\"200\" height=\"200\" alt=\"休みの日の過ごし方イメージ画像\"></figure>\n                    <div class=\"workflow_oneday_dayoff_body\">\n                      <h5 class=\"workflow_oneday_dayoff_title\">\n                        <span class=\"workflow_oneday_dayoff_title_en all_c_title_en\">・Day Off</span>\n                        <span class=\"workflow_oneday_dayoff_title_text\">休みの日の過ごし方</span>\n                      </h5>\n                      <p class=\"workflow_oneday_dayoff_text\">ドライブをしたり、友達と温泉に行ったりしています。伊豆や熱海など有名な温泉地へ行くと、心身共にリフレッシュして、明日から頑張ろうと思えるんです。</p>\n                    </div>\n                  </div>\n                </div><!-- /.workflow_oneday_flow -->\n              </div><!-- /.workflow_oneday -->\n            </div><!-- /.workflow_contents_body -->\n          </div>\n        </div><!-- /.workflow_contents -->\n\n        <div class=\"all_m_breadcrumb\">\n          <div class=\"all_l_wrap\">\n            <ul class=\"all_m_breadcrumb_list\">\n              <li class=\"all_m_breadcrumb_item\"><a href=\"../\">トップ</a></li>\n              <li class=\"all_m_breadcrumb_item _current\">1日の仕事の流れ</li>\n            </ul>\n          </div>\n        </div><!-- /.all_m_breadcrumb -->\n\t\t\t</main><!-- /#main -->\n\n\t\t\t<div class=\"all_m_entry\">\n  <div class=\"all_m_entry_boxes\">\n    <div class=\"all_m_entry_box all_m_entry_recruitment\"><a href=\"/recruit/detail/\">\n      <span class=\"all_m_entry_box