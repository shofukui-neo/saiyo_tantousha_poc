letagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\r\n})(window,document,'script','dataLayer','GTM-TLWT6JLC');</script>\r\n<!-- End Google Tag Manager --><link href=\"../css/privacy.css\" rel=\"stylesheet\" type=\"text/css\">\r\n</head>\r\n\r\n<body>\r\n<section class=\"bg_imgbox\">\r\n<div class=\"title_box\">\r\n<h2 class=\"page_title\">Privacy Policy</h2>\r\n<p class=\"page_sub_title\">プライバシー・ポリシー</p>\r\n</div>\r\n\r\n<div class=\"scroll_bar\">\r\n<a href=\"#\"></a>\r\n</div>\r\n<!--end bg_imgbox -->\r\n</section>\r\n\r\n<header id=\"header\">\r\n<h1 class=\"header_logo\"><a href=\"../index.php\"><img src=\"../img/common/head_logo.svg\" alt=\"ネクスト・ワン株式会社 採用特設サイト\"/></a></h1>\r\n\r\n<nav class=\"g_navi\">\r\n<ul>\r\n<li><a href=\"../message/\"><span class=\"roll_txt\"><span class=\"en\">MESSAGE</span><span class=\"ja\">メッセージ</span></span></a></li>\r\n<li><a href=\"../company/\"><span class=\"roll_txt\"><span class=\"en\">COMPANY</span><span class=\"ja\">会社を知る</span></span></a></li>\r\n<li><a href=\"../service/\"><span class=\"roll_txt\"><span class=\"en\">SERVICE</span><span class=\"ja\">仕事を知る</span></span></a></li>\r\n<li><a href=\"../interview/\"><span class=\"roll_txt\"><span class=\"en\">INTERVIEW</span><span class=\"ja\">人を知る</span></span></a></li>\r\n<li><a href=\"../culture/\"><span class=\"roll_txt\"><span class=\"en\">CULTURE</span><span class=\"ja\">環境・制度</span></span></a></li>\r\n<li><a href=\"../faq/\"><span class=\"roll_txt\"><span class=\"en\">FAQ</span><span class=\"ja\">質問</span></span></a></li>\r\n<li><a href=\"../contact/\"><span class=\"roll_txt\"><span class=\"en\">CONTACT</span><span class=\"ja navi_contact\">お問い合わせ</span></span></a></li>\r\n</ul>\r\n\r\n<div class=\"entry_box\">\r\n<a href=\"../entry/\">\r\n<span class=\"roll_txt\">\r\n<span class=\"en\">ENTRY</span>\r\n<span class=\"ja\">エントリー</span>\r\n</span>\r\n</a>\r\n</div>\r\n</nav>\r\n</header>\r\n\r\n\r\n<div class=\"openbtn\"><span></span><span></span><span></span></div>\r\n<nav id=\"open_navi\">\r\n<div class=\"open_navi_list\">\r\n<p class=\"ham_logo\"><img src=\"../img/common/ham_logo.svg\" alt=\"\"/></p>\r\n<ul>\r\n<li><a href=\"../\">TOP<span class=\"ham_menu_ja\">トップ</span></a></li> \r\n<li><a href=\"../message/\">MESSAGE<span class=\"ham_menu_ja\">メッセージ</span></a></li>\r\n<li><a href=\"../company/\">COMPANY<span class=\"ham_menu_ja\">会社を知る</span></a></li> \r\n<li><a href=\"../service/\">SERVICE<span class=\"ham_menu_ja\">仕事を知る</span></a></li> \r\n<li><a href=\"../interview/\">INTERVIEW<span class=\"ham_menu_ja\">人を知る</span></a></li>\r\n<li><a href=\"../culture/\">CULTURE<span class=\"ham_menu_ja\">環境・制度</span></a></li> \r\n<li><a href=\"../faq/\">FAQ<span class=\"ham_menu_ja\">よくあるご質問</span></a></li> \r\n<li><a href=\"../contact/\">CONTACT<span class=\"ham_menu_ja\">お問い合わせ</span></a></li> \r\n<li><a href=\"../entry/\">ENTRY<span class=\"ham_menu_ja\">エントリー</span></a></li> \r\n</ul>\r\n</div>\r\n</nav>\r\n<main>\r\n<div class=\"content page_privacy\">\r\n<section class=\"box box_s\">\r\n<p class=\"txt00\">ネクスト・ワン株式会社は、個人情報の保護の重要性を認識し、個人情報の取扱いに伴う個人の権利利益の侵害を防止するために、\r\n以下の個人情報に関する基本方針（プライバシー）を定め、適正な取り扱いに努めます。</p> \r\n\r\n<h3>個人情報取得の目的</h3>\r\n\r\n<p class=\"txt01\">ネクスト・ワン株式会社（以下「ネクスト・ワン」といいます）は応募時及び選考時において、下記の目的で必要な範囲において個人情報を取得いたします。</p>\r\n<ol class=\"purpose\">\r\n<li>ネクスト・ワンに勤務する従業員の採用</li>\r\n<li>採用が決定した場合は、当社人事業務における利用</li>\r\n</ol>\r\n\r\n<p class=\"txt02\">取得した個人情報は、人材採用以外の目的には一切使用いたしません。</p>\r\n\r\n<h3>個人情報の第三者への提供</h3>\r\n\r\n<p class=\"txt01\">採用が決定した場合は、以下の内容で第三者への提供を行います。</p>\r\n<ol class=\"purpose\">\r\n<li>第三者に提供する目的：当社人事業務</li>\r\n<li>提供する個人情報の項目：氏名、年齢、性別、住所、電話番号、生年月日</li>\r\n<li>提供する手段または方法：宅配、郵送、手渡し</li>\r\n</ol>\r\n<p class=\"txt02\">個人情報を利用する際は、利用目的の範囲内で適切に行い、法令で認められている場合を除いて、お客様等のご承諾なく第三者には開示いたしません。</p>\r\n\r\n\r\n<h3>個人情報の利用</h3>\r\n<p class=\"txt01\">個人情報を利用する際は、利用目的の範囲内で適切に行い、法令で認められている場合を除いて、お客様等のご承諾なく第三者には開示いたしません。</p>\r\n<ol class=\"purpose mb-20\">\r\n<li> 弊社の採用活動にかかわる、各種情報（セミナー・企業説明会やホームページの案内等）のご案内ならびにお申込受付を行うため。</li>\r\n<li>当行が採用選考を行うため。</li>\r\n<li>採用選考に関するご連絡等の事務処理のため。</li>\r\n<li>雇入時健康診断、入社手続き等の案内のため。</li>\r\n<li>就業後の雇用管理のため。\r\n</li>\r\n</ol>\r\n\r\n\r\n\r\n<h3>個人情報の開示等について</h3>\r\n\r\n<p class=\"txt01\">応募者が、提供した個人情報の開示等（利用目的の通知、開示・訂正・追加または削除、利用停止・消去および第三者への提供の停止）を 希望する場合は、下記のお問い合わせ窓口で受け付けいたします。</p>\r\n\r\n\r\n<h3 class=\"mt-20\">個人情報についてのお問い合わせ先</h3>\r\n\r\n<p class=\"txt01\">開示等のご請求、またはご意見・ご要望につきましては、下記の窓口までお申し出ください。</p>\r\n\r\n<h4>ネクスト・ワン株式会社</h4>\r\n\r\n<p class=\"txt02\">〒 653-0012 兵庫県加古川市加古川町粟津805-3<br>\r\n電話番号：079-421-1111<br>\r\n受付時間：9:00～17:00<br>\r\nお問い合わせEメールアドレス：<a href=\"mailto:  info@next-1.jp\" class=\"line_effect\"><span class=\"u_line_blk\">  info@next-1.jp</span></a></p> \r\n\r\n<!--end box -->\r\n</section>\r\n</div>\r\n</main>\r\n<footer>\r\n<section class=\"sec_movie\">\r\n<div class=\"entry_pv_wrap\">\r\n<video class=\"entry_pvbox\" muted autoplay loop playsinline>\r\n<source src=\"../img/common/entry_pv.mp4\" type=\"video/mp4\" class=\"entry_pv\">\r\n</video>\r\n\r\n<div class=\"entry_title_wrap\">\r\n<figure class=\"entry_copy\"><img src=\"../img/common/foot_copy.svg\" alt=\"\"/></figure>\r\n<div class=\"circle_btn\"><a href=\"../entry/\" class=\"btn-txt\">More Info</a></div>\r\n<!--end div.movie_title_wrap -->\r\n</div>\r\n\r\n<!--end div.recruit_pv_wrap -->\r\n</div>\r\n</section>\r\n\r\n<section class=\"footer_inner\">\r\n<div class=\"box_m\">\r\n<p class=\"foot_logo\"><img src=\"../img/common/foot_logo.svg\" alt=\"\"/></p>\r\n<p class=\"foot_office_txt\">【KAKOGAWA HEAD OFFICE 】 </p>\r\n<p class=\"foot_addless\">〒 675-0039<br class=\"sp-hidden\">\r\n兵庫県加古川市加古川町粟津805-3　<br class=\"pc-hidden\">\r\nTEL：079-421-1111  FAX：079-425-8981</p>\r\n<p class=\"foot_link_txt\"><a href=\"../privacy/\">プライバシー・ポリシー</a> /  <a class=\"blk_icon\" href=\"https://www.next-1.co.jp/\" target=\"_blank\">コーポレートサイト</a></p>\r\n<small class=\"copyright\">COPYRIGHT &copy;  NEXT ONE CO., LTD. ALL RIGHT RESERVED.</small>\r\n<!--end div.box_m -->\r\n</div