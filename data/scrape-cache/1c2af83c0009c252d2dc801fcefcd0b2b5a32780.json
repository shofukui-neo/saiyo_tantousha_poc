{"url":"https://www.sankotech.co.jp/info_arch/info2021.html","html":"<!DOCTYPE html>\n<html lang=\"ja-JP\">\n <head> \n  <meta charset=\"UTF-8\"> \n  <meta http-equiv=\"content-type\" content=\"text/html; charset=UTF-8\"> \n  <meta name=\"robots\" content=\"index\"> \n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" id=\"a-viewport\"> \n  <meta name=\"description\" content=\"サンコーテック株式会社ホームページについて\"> \n  <meta property=\"og:title\" content=\"サンコーテック／インフォメーション\"> \n  <meta property=\"og:type\" content=\"website\"> \n  <meta property=\"og:image\" content=\"https://www.sankotech.co.jp/bdflashinfo/thumbnail.png\"> \n  <meta property=\"og:url\" content=\"https://www.sankotech.co.jp/info_arch/info2021.html\"> \n  <meta property=\"og:site_name\" content=\"NEW S-Techサイト\"> \n  <meta property=\"og:description\" content=\"サンコーテック株式会社ホームページについて\"> \n  <meta name=\"twitter:card\" content=\"summary_large_image\"> \n  <meta name=\"twitter:image\" content=\"https://www.sankotech.co.jp/bdflashinfo/thumbnail.png\"> \n  <meta name=\"note:card\" content=\"summary_large_image\"> \n  <link rel=\"canonical\" href=\"https://www.sankotech.co.jp/info_arch/info2021.html\"> \n  <title>サンコーテック／インフォメーション</title> \n  <link rel=\"stylesheet\" type=\"text/css\" href=\"../_module/styles/bind.css?v=17.0.7\" id=\"bind-css\"> \n  <link rel=\"stylesheet\" type=\"text/css\" href=\"../_dress/pp013recruit/base.css?1777211640326\"> \n  <link rel=\"stylesheet\" type=\"text/css\" href=\"../_dress/white/base.css?1777211640326\"> \n  <link rel=\"stylesheet\" type=\"text/css\" href=\"../_dress/navy/base.css?1777211640326\"> \n  <link rel=\"stylesheet\" type=\"text/css\" href=\"info2021.css?1777211640328c0100\" id=\"page-css\"> \n  <link rel=\"stylesheet\" type=\"text/css\" href=\"https://fonts.googleapis.com/css2?family=Delius:wght@400&amp;display=swap\"> \n  <link rel=\"stylesheet\" type=\"text/css\" href=\"../_webfonts.css?1777211640331\" id=\"webfont-css\"> \n  <link rel=\"stylesheet\" type=\"text/css\" href=\"../_csslinkbtn/btn-import.css?1767099951882\" id=\"linkbtn-css\"> \n </head> \n <body id=\"l-2\" class=\"l-2 l-fixed-side -dress_pp013recruit bd-webp\" data-type=\"responsive\" data-layout-type=\"sidefixed\" data-view-pc-button=\"true\" data-view-pc-position=\"bottom\" data-page-animation=\"none\"> \n  <div id=\"page\" class=\"bg-window \"> \n   <div class=\"bg-document\"> \n    <noscript> \n     <div id=\"js-off\"> \n      <img src=\"../_module/images/noscript.gif\" alt=\"Enable JavaScript in your browser. このウェブサイトはJavaScriptをオンにしてご覧下さい。\"> \n     </div> \n    </noscript> \n    <div id=\"a-header\" data-float=\"false\" class=\"a-header   cssskin-_area_header\"> \n     <header> \n      <div class=\"site_frame\"> \n       <section> \n        <div id=\"bk3332\" class=\"b-plain c-space_normal c-sp-space_normal c-padding_narrow c-sp-padding_normal cssskin-_block_header\" data-bk-id=\"bk3332\" data-shared=\"true\" data-sharedname=\"HEADER2\"> \n         <div class=\" column -column1\"> \n          <div class=\" c-body\"> \n           <div class=\"c-img   \"> \n            <a href=\"../index.html\" data-pid=\"70\"> \n             <picture> \n              <source type=\"image/webp\" srcset=\"../_src/960/logo-credit-500.webp?v=1767099951882\"> \n              <img src=\"../_src/960/logo-credit-500.png?v=1767099951882\" width=\"2085\" height=\"327\" alt=\"\" id=\"imgsrc960_1\" class=\" c-no_adjust\" loading=\"lazy\"> \n             </picture></a> \n           </div> \n          </div> \n         </div> \n        </div> \n        <div id=\"bk3333\" class=\"b-plain -blog-article c-space_narrow c-sp-space_normal c-sp-padding_normal bd-webp -dress_white cssskin-_block_header\" data-bk-id=\"bk3333\" data-shared=\"true\" data-sharedname=\"HEADER\"> \n         <div class=\" column -column1\"> \n          <nav> \n           <div id=\"js-globalNavigation\" data-slide-type=\"rightSlide\" data-btn-position=\"rightTop\"> \n            <div class=\" js-motion\"> \n             <ul class=\"m-motion menu-parts -f\"> \n              <li class=\" c-left\"><a href=\"../company_profile/index.html\" data-pid=\"77\">ご挨拶</a></li> \n              <li class=\" c-left\"><a href=\"../company_profile/index1.html\" data-pid=\"78\">企業概要</a> \n               <ul> \n                <li class=\" c-left\"><a href=\"../company_profile/index1.html#profile\" data-pid=\"78\">会社概要</a></li> \n                <li class=\" c-left\"><a href=\"../company_profile/index1.html#history\" data-pid=\"78\">沿革</a></li> \n                <li class=\" c-left\"><a href=\"../company_profile/index1.html#maker\" data-pid=\"78\">取り扱いメーカー</a></li> \n               </ul></li> \n              <li class=\" c-left\"><a href=\"../Activities/index.html\" data-pid=\"123\">事業案内</a></li> \n              <li class=\" c-left\"><a href=\"../base/location.html\" data-pid=\"103\">事業所一覧</a></li> \n              <li class=\" c-left\"><a href=\"../Product_guide/product01.html\" data-pid=\"90\">取扱商品</a></li> \n              <li class=\" c-left\"><a href=\"../festa2022/index.html\" data-pid=\"79\">ツールdeフェスタ</a></li> \n              <li class=\" c-left\"><a href=\"https://job-gear.net/sankotech/\">採用情報</a></li> \n              <li class=\" c-left\"><a href=\"../Information/index.html\" data-pid=\"122\">お問い合わせ</a></li> \n              <li class=\" c-left\"><a href=\"../info.html\" data-pid=\"72\">Information</a> \n               <ul> \n                <li class=\" c-left\"><a href=\"../info.html\" data-pid=\"72\">新着情報</a></li> \n                <li class=\" c-left\"><a href=\"../stj.html\" data-pid=\"73\">STジャーナル</a></li> \n               </ul></li> \n             </ul> \n            </div> \n           </div> \n           <div id=\"spNavigationTrigger\" class=\" c-sp_navigation_btn\"></div> \n          </nav> \n         </div> \n        </div> \n       </section> \n      </div> \n     </header> \n    </div> \n    <div id=\"a-billboard\" class=\"a-billboard    cssskin-_area_billboard\"> \n     <div class=\"site_frame\"> \n      <section> \n       <div id=\"bk3334\" class=\"b-plain c-space_normal c-sp-space_normal c-sp-padding_init cssskin-_block_billboard\" data-bk-id=\"bk3334\"> \n        <div class=\" column -column1\"> \n         <div class=\" c-body\"> \n          <div class=\"c-img   \"> \n           <picture> \n            <source type=\"image/webp\" srcset=\"../_src/3449/information_banner_20190526095941163.webp?v=1767099951882\"> \n            <img src=\"../_src/3449/information_banner_20190526095941163.jpg?v=1767099951882\" width=\"1000\" height=\"300\" alt=\"\" id=\"imgsrc3449_1\" loading=\"lazy\"> \n           </picture> \n          </div> \n         </div> \n        </div> \n       </div> \n       <div id=\"bk3335\" class=\"b-plain c-space_normal c-sp-space_normal c-sp-padding_normal cssskin-h2_midashi2\" data-bk-id=\"bk3335\"> \n        <div class=\" column -column1\" id=\"top\"> \n         <h4 class=\" c-small_headline\">&nbsp; <span style=\"color:#ffffff;\">&nbsp;&nbsp;新着情報</span></h4> \n        </div> \n       </div> \n      </section> \n     </div> \n    </div> \n    <main> \n     <div id=\"a-site_contents\" class=\"a-site_contents  noskin\"> \n      <article> \n       <div class=\"site_frame\"> \n        <div class=\"g-column\"> \n         <div id=\"a-main\" class=\"a-main column -col8 \"> \n          <section> \n           <div id=\"bk3346\" class=\"b-plain c-space_normal c-sp-space_normal c-sp-padding_normal cssskin-_block_main\" data-bk-id=\"bk3346\"> \n            <div class=\" column -column1\" id=\"211224\"> \n             <p class=\" c-body\"><span style=\"color:#073763;\" class=\" d-large_font\"><span class=\" d-bold\">仙台営業所 ホイストクレーン 能力増強工事</span></span></p> \n             <div class=\" c-body c-right\"> \n              <hr class=\"c-hr\"> \n              <span style=\"color:#434343;\" data-sitecolor-text=\"\">2021.12.24&nbsp;</span> \n             </div> \n             <div class=\" c-body c-left\"> \n              <span style=\"color:#000000;\">仙台営業所にて、機材ストックヤードで使用しているホイストクレーンの能力増強工事を行いました</span> \n             </div> \n             <div class=\" c-body c-left\"> \n              <br> \n              <span style=\"color:#000000;\">これにより機動力が向上、より大型な機材の積み下ろしが可能となります</span> \n              <br> \n              <span style=\"color:#000000;\">2022年1月より運用を開始となります</span> \n             </div> \n             <div class=\" c-body c-left\"> \n              <span style=\"color:#000000;\">ご期待ください！</span> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk3347\" class=\"b-plain c-space_normal c-sp-space_normal c-padding_normal c-sp-padding_normal cssskin-_block_main -js-bindZoom\" data-bk-id=\"bk3347\"> \n            <div class=\" column -column1\"> \n             <div class=\" c-body\"> \n              <div class=\"c-img   \"> \n               <a href=\"../_src/3469/dsc_0290.jpg?v=1767099951882\" class=\"js-zoomImage\" rel=\"width=1000,height=750\"> \n                <picture> \n                 <source type=\"image/webp\" srcset=\"../_src/3468/dsc_0290.webp?v=1767099951882\"> \n                 <img src=\"../_src/3468/dsc_0290.jpg?v=1767099951882\" width=\"1000\" height=\"750\" alt=\"\" id=\"imgsrc3468_1\" loading=\"lazy\"> \n                </picture></a> \n              </div> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk3348\" class=\"b-plain c-space_normal c-sp-space_normal c-sp-padding_normal cssskin-_block_main\" data-bk-id=\"bk3348\"> \n            <div class=\" column -column1\" id=\"211223\"> \n             <p class=\" c-body\"><span style=\"color:#073763;\" class=\" d-large_font\"><span class=\" d-bold\">ツールdeフェスタ 2022 開催決定！</span></span></p> \n             <div class=\" c-body c-right\"> \n              <hr class=\"c-hr\"> 2021.12.23&nbsp; \n             </div> \n            </div> \n           </div> \n           <div id=\"bk3349\" class=\"b-both_diff -left_large -sp-single_column c-space_narrow c-sp-space_normal c-sp-padding_normal cssskin-_block_main\" data-bk-id=\"bk3349\"> \n            <div class=\" g-column\"> \n             <div class=\" column -col8 -col_main\"> \n              <p class=\" c-body\"><span style=\"color:#434343;\" data-sitecolor-text=\"\">ツールdeフェスタ2022の開催が決定しました</span><br><span style=\"color:#434343;\">&nbsp;</span><br><span style=\"color:#434343;\">今回のタイトルは「さあスキップ！新しい時を見つけ出す２日間」<br></span><br><span style=\"color:#434343;\">withコロナ時代のあり方を探る機会の提供を目指します</span><br><span style=\"color:#434343;\"><br><span style=\"color:#000000;\" class=\" d-small_font\">(万一、感染症が拡大した際には、延期または中止する可能性がございます)</span></span><br><span style=\"color:#000000;\">&nbsp;</span>&nbsp;</p> \n             </div> \n             <div class=\" column -col4 -col_sub\"> \n              <div class=\" c-body\">\n                &nbsp; \n               <div class=\"c-img   \"> \n                <a href=\"../festa2022/index.html\" data-pid=\"79\"> \n                 <picture> \n                  <source type=\"image/webp\" srcset=\"../_src/3470/tdf2022_300.webp?v=1767099951882\"> \n                  <img src=\"../_src/3470/tdf2022_300.jpg?v=1767099951882\" width=\"300\" height=\"400\" alt=\"\" id=\"imgsrc3470_1\" loading=\"lazy\"> \n                 </picture></a> \n               </div> \n              </div> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk3350\" class=\"b-plain c-space_normal c-sp-space_normal c-sp-padding_normal cssskin-_block_main\" data-bk-id=\"bk3350\"> \n            <div class=\" column -column1\" id=\"211116\"> \n             <p class=\" c-body\"><span style=\"color:#073763;\" class=\" d-large_font\"><span class=\" d-bold\">株式会社テザック ブルースリング +1 キャンペーン</span></span></p> \n             <div class=\" c-body c-right\"> \n              <hr class=\"c-hr\"> \n              <span style=\"color:#434343;\" data-sitecolor-text=\"\">2021.11.16&nbsp;</span> \n             </div> \n             <div class=\" c-body c-left\">\n               当社主催展示会『ツールdeフェスタ』にも毎年参加頂いております株式会社テザック様のブルースリングが、 \n             </div> \n             <div class=\" c-body c-left\">\n               JIS最高グレードである4等級にグレードアップしました \n             </div> \n             <div class=\" c-body c-left\">\n               &nbsp; \n             </div> \n             <div class=\" c-body c-left\">\n               商品リニューアルを記念し、ブルースリング4等級を10点（組み合わせ自由）をお買い上げ頂きますと、 \n             </div> \n             <div class=\" c-body c-left\">\n               お好きな寸法のブルースリングを1本プレゼントするキャンペーンを行なっております \n             </div> \n             <div class=\" c-body c-left\">\n               &nbsp; \n             </div> \n             <div class=\" c-body c-left\">\n               キャンペーン期間は2022年3月末までとなります \n             </div> \n             <div class=\" c-body c-left\">\n               この機会に是非ともご検討ください！ \n             </div> \n             <div class=\" c-body c-left\">\n               詳細・ご不明点等は弊社担当までお問い合わせください \n             </div> \n            </div> \n           </div> \n           <div id=\"bk3351\" class=\"b-plain c-space_normal c-sp-space_normal c-padding_normal c-sp-padding_normal cssskin-_block_main -js-bindZoom\" data-bk-id=\"bk3351\"> \n            <div class=\" g-column -col2 -sp-col1\"> \n             <div class=\" column -column1\"> \n              <div class=\" c-body\"> \n               <div class=\"c-img   \"> \n                <a href=\"../_src/3473/img20211119072841651673.jpg?v=1767099951882\" class=\"js-zoomImage\" rel=\"width=2480,height=3507\"> \n                 <picture> \n                  <source type=\"image/webp\" srcset=\"../_src/3472/img20211119072841651673.webp?v=1767099951882\"> \n                  <img src=\"../_src/3472/img20211119072841651673.jpg?v=1767099951882\" width=\"2480\" height=\"3507\" alt=\"\" id=\"imgsrc3472_1\" loading=\"lazy\"> \n                 </picture></a> \n               </div> \n              </div> \n             </div> \n             <div class=\" column -column2 -column-lasts\"> \n              <div class=\" c-body\"> \n               <div class=\"c-img   \"> \n                <a href=\"../_src/3475/img20211119072841647705.jpg?v=1767099951882\" class=\"js-zoomImage\" rel=\"width=2480,height=3507\"> \n                 <picture> \n                  <source type=\"image/webp\" srcset=\"../_src/3474/img20211119072841647705.webp?v=1767099951882\"> \n                  <img src=\"../_src/3474/img20211119072841647705.jpg?v=1767099951882\" width=\"2480\" height=\"3507\" alt=\"\" id=\"imgsrc3474_1\" loading=\"lazy\"> \n                 </picture></a> \n               </div> \n              </div> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk3352\" class=\"b-plain c-space_normal c-sp-space_normal c-padding_normal c-sp-padding_normal cssskin-_block_main\" data-bk-id=\"bk3352\"> \n            <div class=\" column -column1\" id=\"211115\"> \n             <p class=\" c-body\"><span class=\" d-large_font\"><span class=\" d-bold\"><span style=\"color:#073763;\">冬季休業のご案内</span></span></span></p> \n             <div class=\" c-body c-right\"> \n              <hr class=\"c-hr\"> 2021.11.15 \n             </div> \n             <div class=\" c-body c-left\">\n               平素は格別のご高配を賜り、厚く御礼を申し上げます \n             </div> \n             <div class=\" c-body c-left\">\n               &nbsp; \n             </div> \n             <div class=\" c-body c-left\">\n               誠に勝手ながら&nbsp; \n              <span style=\"color:#1c4587;\"><span class=\" d-bold\">2021年12月29日(水)〜2022年1月4日(火)</span></span>の期間を \n              <span style=\"color:#1c4587;\"><span class=\" d-bold\">冬季休業</span></span>とさせて頂きます \n             </div> \n             <p class=\" c-body\">新年は<span style=\"color:#a61c00;\">&nbsp;<span class=\" d-bold\">2022年1月5日(水)より通常通り営業</span>&nbsp;</span>致します<br>&nbsp;<br>お客様にはご不便をお掛けいたしますが、ご理解とご協力のほど宜しくお願い致します</p> \n            </div> \n           </div> \n           <div id=\"bk3353\" class=\"b-plain c-space_normal c-sp-space_normal c-sp-padding_normal cssskin-_block_main\" data-bk-id=\"bk3353\"> \n            <div class=\" column -column1\" id=\"211001\"> \n             <p class=\" c-body\"><span style=\"color:#073763;\" class=\" d-large_font\"><span class=\" d-bold\">東北支店営業会議を行いました</span></span></p> \n             <div class=\" c-body c-right\"> \n              <hr class=\"c-hr\"> \n              <span style=\"color:#434343;\" data-sitecolor-text=\"\">2021.10.01&nbsp;</span> \n             </div> \n             <div class=\" c-body c-left\">\n               9月24日、東北支店営業会議を行いました \n             </div> \n             <p class=\" c-body\">コロナ禍、久しぶりに東北支店の営業メンバーが仙台営業所に集合しました</p> \n             <div class=\" c-body c-left\">\n               会議では互いに近況を報告し合っていましたが、 \n             </div> \n             <div class=\" c-body c-left\">\n               もちろんメインテーマは最終業績 \n             </div> \n             <div class=\" c-body c-left\">\n               和やかな中にも厳しい質疑応答があり、期末に向けた取り組みが発表されました \n             </div> \n             <div class=\" c-body c-left\">\n               &nbsp; \n             </div> \n            </div> \n           </div> \n           <div id=\"bk3354\" class=\"b-plain c-space_normal c-sp-space_normal c-padding_normal c-sp-padding_normal cssskin-_block_main\" data-bk-id=\"bk3354\"> \n            <div class=\" column -column1\"> \n             <div class=\" c-body\"> \n              <div class=\"c-img   \"> \n               <picture> \n                <source type=\"image/webp\" srcset=\"../_src/3476/dsc_0250_1.webp?v=1767099951882\"> \n                <img src=\"../_src/3476/dsc_0250_1.jpg?v=1767099951882\" width=\"4000\" height=\"3000\" alt=\"\" id=\"imgsrc3476_1\" loading=\"lazy\"> \n               </picture> \n              </div> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk3355\" class=\"b-plain c-space_normal c-sp-space_normal c-sp-padding_normal cssskin-_block_main\" data-bk-id=\"bk3355\"> \n            <div class=\" column -column1\" id=\"210930\"> \n             <p class=\" c-body\"><span style=\"color:#073763;\" class=\" d-large_font\"><span class=\" d-bold\">コンプレッサー講習会を行いました</span></span></p> \n             <div class=\" c-body c-right\"> \n              <hr class=\"c-hr\"> \n              <span style=\"color:#434343;\" data-sitecolor-text=\"\">2021.09.30&nbsp;</span> \n             </div> \n             <div class=\" c-body c-right\"> \n              <span style=\"color:#434343;\">&nbsp;</span> \n             </div> \n             <div class=\" c-body c-left\"> \n              <span style=\"color:#434343;\">先日、弊社仙台営業所（宮城）にて、コンプレッサーの講習会を行いました</span> \n              <br>今回の講習では、北越工業様主催の認定試験「PC（ポータブルコンプレッサー）レベル1」の取得に必要な基礎知識を再確認しました \n             </div> \n             <div class=\" c-body c-left\">\n               弊社には現在、約7名の認定取得者が在籍していますが今後も更なる品質向上と、設備技術の向上を目的に、資格習得にも力を入れて参ります \n             </div> \n            </div> \n           </div> \n           <div id=\"bk3356\" class=\"b-plain c-space_normal c-sp-space_normal c-padding_normal c-sp-padding_normal cssskin-_block_main\" data-bk-id=\"bk3356\"> \n            <div class=\" column -column1\"> \n             <div class=\" c-body\"> \n              <div class=\"c-img   \"> \n               <picture> \n                <source type=\"image/webp\" srcset=\"../_src/3478/dsc_0244_1.webp?v=1767099951882\"> \n                <img src=\"../_src/3478/dsc_0244_1.jpg?v=1767099951882\" width=\"4000\" height=\"3000\" alt=\"\" id=\"imgsrc3478_1\" loading=\"lazy\"> \n               </picture> \n              </div> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk3357\" class=\"b-plain c-space_normal c-sp-space_normal c-padding_normal c-sp-padding_normal cssskin-_block_main\" data-bk-id=\"bk3357\"> \n            <div class=\" column -column1\" id=\"210722\"> \n             <p class=\" c-body\"><span class=\" d-large_font\"><span class=\" d-bold\"><span style=\"color:#073763;\">夏季休業のご案内</span></span></span></p> \n             <div class=\" c-body c-right\"> \n              <hr class=\"c-hr\"> 2021.7.22 \n             </div> \n             <div class=\" c-body c-left\">\n               平素は格別のご高配を賜り、厚く御礼を申し上げます \n             </div> \n             <div class=\" c-body c-left\">\n               &nbsp; \n             </div> \n             <div class=\" c-body c-left\">\n               誠に勝手ながら&nbsp; \n              <span style=\"color:#1c4587;\"><span class=\" d-bold\">2021年8月13日(金)〜2021年8月16日(月)</span></span>の期間を \n              <span style=\"color:#1c4587;\"><span class=\" d-bold\">夏季休業</span></span>とさせて頂きます \n             </div> \n             <p class=\" c-body\">&nbsp;<br>お客様にはご不便をお掛けいたしますが、ご理解とご協力のほど宜しくお願い致します<br>&nbsp;<br>&nbsp;<br>&nbsp;</p> \n            </div> \n           </div> \n           <div id=\"bk3358\" class=\"b-plain c-space_normal c-sp-space_normal c-sp-padding_normal cssskin-_block_main\" data-bk-id=\"bk3358\"> \n            <div class=\" column -column1\" id=\"210416\"> \n             <p class=\" c-body\"><span style=\"color:#073763;\" class=\" d-large_font\"><span class=\" d-bold\">新型コロナウイルス感染者発生に関するお知らせ</span></span></p> \n             <div class=\" c-body c-right\"> \n              <hr class=\"c-hr\"> 2021.04.16&nbsp; \n             </div> \n            </div> \n           </div> \n           <div id=\"bk3359\" class=\"b-plain c-space_normal c-sp-space_normal c-padding_narrow c-sp-padding_normal cssskin-_block_main -js-bindZoom\" data-bk-id=\"bk3359\"> \n            <div class=\" column -column1\"> \n             <div class=\" c-body\"> \n              <div class=\"c-img   \"> \n               <a href=\"../_src/3481/info_20210416.jpg?v=1767099951882\" class=\"js-zoomImage\" rel=\"width=2480,height=2870\"> \n                <picture> \n                 <source type=\"image/webp\" srcset=\"../_src/3480/info_20210416.webp?v=1767099951882\"> \n                 <img src=\"../_src/3480/info_20210416.jpg?v=1767099951882\" width=\"2480\" height=\"2870\" alt=\"\" id=\"imgsrc3480_1\" loading=\"lazy\"> \n                </picture></a> \n              </div> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk3360\" class=\"b-plain c-space_normal c-sp-space_normal c-sp-padding_normal cssskin-_block_main\" data-bk-id=\"bk3360\"> \n            <div class=\" column -column1\" id=\"20210410\"> \n             <p class=\" c-body\"><span style=\"color:#073763;\" class=\" d-large_font\"><span class=\" d-bold\">【重要】東京本社 代表電話番号変更のお知らせ</span></span></p> \n             <div class=\" c-body c-right\"> \n              <hr class=\"c-hr\"> 2021.04.10&nbsp; \n             </div> \n            </div> \n           </div> \n           <div id=\"bk3361\" class=\"b-plain c-space_normal c-sp-space_normal c-padding_normal c-sp-padding_normal cssskin-_block_main\" data-bk-id=\"bk3361\"> \n            <div class=\" column -column1\" id=\"200729\"> \n             <p class=\" c-body\">平素は格別のご高配を賜り、厚く御礼を申し上げます</p> \n             <div class=\" c-body c-left\">\n               &nbsp; \n             </div> \n             <div class=\" c-body c-left\">\n               この度、サンコーテック東京本社の代表電話番号が下記の通り変更になりました \n             </div> \n             <div class=\" c-body c-left\">\n               &nbsp; \n             </div> \n             <div class=\" c-body c-left\"> \n              <span class=\" d-bold\"><span style=\"color:#a61c00;\">サンコーテック東京本社 新電話番号：03-5610-1600（代表）</span></span> \n             </div> \n             <div class=\" c-body c-left\">\n               &nbsp; \n             </div> \n             <div class=\" c-body c-left\">\n               FAX番号は変更ございません \n             </div> \n             <div class=\" c-body c-left\">\n               &nbsp; \n             </div> \n             <p class=\" c-body\">お客様にはご不便をお掛けいたしますが、ご理解とご協力のほど宜しくお願い致します</p> \n            </div> \n           </div> \n           <div id=\"bk3362\" class=\"b-plain c-space_normal c-sp-space_normal c-sp-padding_normal cssskin-_block_main\" data-bk-id=\"bk3362\"> \n            <div class=\" column -column1\" id=\"20210220\"> \n             <p class=\" c-body\"><span style=\"color:#073763;\" class=\" d-large_font\"><span class=\" d-bold\">【重要】ツールdeフェスタ2021 開催延期について</span></span></p> \n             <div class=\" c-body c-right\"> \n              <hr class=\"c-hr\"> 2021.02.20&nbsp; \n             </div> \n            </div> \n           </div> \n           <div id=\"bk3363\" class=\"b-plain c-space_normal c-sp-space_normal c-padding_narrow c-sp-padding_normal cssskin-_block_main -js-bindZoom\" data-bk-id=\"bk3363\"> \n            <div class=\" column -column1\"> \n             <div class=\" c-body\"> \n              <div class=\"c-img   \"> \n               <a href=\"../_src/3483/img20210220211035686501.jpg?v=1767099951882\" class=\"js-zoomImage\" rel=\"width=2480,height=3507\"> \n                <picture> \n                 <source type=\"image/webp\" srcset=\"../_src/3482/img20210220211035686501.webp?v=1767099951882\"> \n                 <img src=\"../_src/3482/img20210220211035686501.jpg?v=1767099951882\" width=\"2480\" height=\"3507\" alt=\"\" id=\"imgsrc3482_1\" loading=\"lazy\"> \n                </picture></a> \n              </div> \n             </div> \n            </div> \n           </div> \n          </section> \n         </div> \n         <div id=\"a-side-a\" data-float=\"false\" class=\"a-side-a column -col4 \" data-fixed-size=\"200px\"> \n          <section> \n           <div id=\"bk3364\" class=\"b-plain c-space_normal c-sp-space_normal c-sp-padding_normal bd-webp -dress_navy cssskin-_block_side_a\" data-bk-id=\"bk3364\" data-shared=\"true\" data-sharedname=\"info_archive\" data-sticky=\"true\"> \n            <div class=\" column -column1\"> \n             <nav> \n              <div class=\" -menu_center\"> \n               <ul class=\"c-menu -menu_e menu-parts -v\"> \n                <li><span class=\" c-unlink\"><span class=\" d-bold\">Back Number</span></span></li> \n               </ul> \n              </div> \n             </nav> \n             <div class=\" c-body\"> \n              <span class=\"bindicon-angle-right-circle\"></span> \n              <a href=\"../info_arch/pg271.html\" target=\"_blank\" rel=\"noopener noreferrer\" data-pid=\"271\">2024年</a> \n              <br> \n              <span class=\"bindicon-angle-right-circle\"></span> \n              <a href=\"../info_arch/pg265.html\" target=\"_blank\" rel=\"noopener noreferrer\" data-pid=\"265\">2023年</a> \n              <br> \n              <span class=\"bindicon-angle-right-circle\"></span> \n              <a href=\"../info_arch/pg261.html\" target=\"_blank\" rel=\"noopener noreferrer\" data-pid=\"261\">2022年</a> \n              <br> \n              <span class=\"bindicon-angle-right-circle\"></span> \n              <a href=\"info2021.html\" target=\"_blank\" rel=\"noopener noreferrer\" data-mypid=\"173\">2021年</a> \n              <br> \n              <span class=\"bindicon-angle-right-circle\"></span> \n              <a href=\"../info_arch/info2020.html\" target=\"_blank\" rel=\"noopener noreferrer\" data-pid=\"133\">2020年</a> \n              <br>&nbsp; \n              <br> \n              <div class=\"c-img   \"> \n               <a href=\"../stj.html\" data-pid=\"73\"> \n                <picture> \n                 <source type=\"image/webp\" srcset=\"../_src/3484/test_small2.webp?v=1767099951882\"> \n                 <img src=\"../_src/3484/test_small2.jpg?v=1767099951882\" width=\"200\" height=\"100\" alt=\"\" id=\"imgsrc3484_1\" loading=\"lazy\"> \n                </picture></a> \n              </div> \n             </div> \n             <div class=\" c-body c-right\"> \n              <span class=\" d-small_font\"> <a href=\"info2021.html\" data-mypid=\"173\">STジャーナルへ</a></span> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk3365\" class=\"b-plain cssskin-_block_side_a\" data-bk-id=\"bk3365\"> \n            <div class=\" column -column1\"> \n            </div> \n           </div> \n          </section> \n         </div> \n        </div> \n       </div> \n      </article> \n     </div> \n    </main> \n    <div id=\"a-footer\" data-float=\"false\" class=\"a-footer   cssskin-_area_footer\"> \n     <footer> \n      <div class=\"site_frame\"> \n       <div id=\"bk5115\" class=\"b-plain c-space_normal c-sp-space_normal c-sp-padding_normal cssskin-_block_footer\" data-bk-id=\"bk5115\"> \n        <div class=\" column -column1\"> \n         <div class=\" c-body c-center\">\n           &nbsp; \n         </div> \n         <div class=\" c-body c-right\"> \n          <span class=\"bindicon-arrow-up2\"></span> \n          <a href=\"info2021.html\" data-mypid=\"173\">ページトップへ</a> \n         </div> \n        </div> \n       </div> \n       <div id=\"bk3367\" class=\"b-plain c-space_normal c-sp-space_normal c-sp-padding_normal cssskin-_block_footer\" data-bk-id=\"bk3367\" data-shared=\"true\" data-sharedname=\"フッター\"> \n        <div class=\" column -column1\"> \n         <div class=\" c-body c-right\"> \n          <hr class=\"c-hr\"> \n         </div> \n         <div class=\" c-body c-center\"> \n          <div class=\"c-img   \"> \n           <picture> \n            <source type=\"image/webp\" srcset=\"../_src/6484/logo-credit-500.webp?v=1767099951882\"> \n            <img src=\"../_src/6484/logo-credit-500.png?v=1767099951882\" width=\"2085\" height=\"327\" alt=\"\" id=\"imgsrc6484_1\" class=\" c-no_adjust\" loading=\"lazy\"> \n           </picture> \n          </div> \n         </div> \n         <div class=\" c-body c-center\"> \n          <span>&nbsp; 〒130-0011 東京都墨田区石原4丁目12番地10号 (Zrビル) TEL <span style=\"color:#666666;\">03-5610-1600</span>（代表）</span> \n         </div> \n         <div class=\" c-body c-center\">\n           Copyright Sanko Tech Corporation. All Rights Reserved. \n         </div> \n         <div class=\" c-body c-center\"> \n          <span><span class=\"bindicon-angle-right-circle\"></span></span> \n          <span style=\