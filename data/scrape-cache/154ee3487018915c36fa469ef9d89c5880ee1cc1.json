{"url":"https://www.jobkita.jp/shukatsu/","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n\n<head>\n\n  <!-- Google Tag Manager -->\n  <script>(function (w, d, s, l, i) {\n          w[l] = w[l] || [];\n          w[l].push({\n              'gtm.start': new Date().getTime(), event: 'gtm.js'\n          });\n          var f = d.getElementsByTagName(s)[0],\n              j = d.createElement(s), dl = l != 'dataLayer' ? '&l=' + l : '';\n          j.async = true;\n          j.src =\n              'https://www.googletagmanager.com/gtm.js?id=' + i + dl;\n          f.parentNode.insertBefore(j, f);\n      })(window, document, 'script', 'dataLayer', 'GTM-MLJ53XS');</script>\n  <!-- End Google Tag Manager -->\n  \n      <meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\" />\n    <title>ジョブキタ就活｜学生向け北海道の就職活動・採用情報サイト</title>\n    <meta name=\"description\" content=\"ジョブキタ就活は「アルキタ」「シゴトガイド」でおなじみ、北海道アルバイト情報社が運営する就活準備・スケジュール対策サイト。自己分析に役立つコンテンツや北海道が地元のメディアならではの企業・業界研究、インターンシップ・仕事体験だけじゃない就活スケジュール対策など就活準備に役立つ情報が満載です。\" />\n    <meta name=\"keywords\" content=\"就職,就職活動,就活,新卒,自己分析,インターンシップ,仕事体験,スケジュール,採用情報,中小企業,ジョブキタ就活\" />\n  \n    \n            <!--OGP-->\n      <meta property=\"og:title\" content=\"ジョブキタ就活｜学生向け北海道の就職活動・採用情報サイト\" />\n      <meta property=\"og:type\" content=\"article\" />\n      <meta property=\"og:url\" content=\"https://www.jobkita.jp/shukatsu/\" />\n      <meta property=\"og:image\" content=\"https://image.haj.co.jp/jobkita/shukatsu/root/ogp.png\" />\n      <meta property=\"og:description\" content=\"ジョブキタ就活は「アルキタ」「シゴトガイド」でおなじみ、北海道アルバイト情報社が運営する就活準備・スケジュール対策サイト。自己分析に役立つコンテンツや北海道が地元のメディアならではの企業・業界研究、インターンシップ・仕事体験だけじゃない就活スケジュール対策など就活準備に役立つ情報が満載です。\" />\n      <meta property=\"og:site_name\" content=\"ジョブキタ就活\" />\n      \n  <!-- icon image -->\n  <link rel=\"shortcut icon\" href=\"https://image.haj.co.jp/jobkita/shukatsu/favicon.ico?update=202303311300\" />\n  <link rel=\"apple-touch-icon-precomposed\" href=\"https://image.haj.co.jp/jobkita/shukatsu/apple-touch-icon-precomposed.png?update=202303311300\" />\n\n    <!--viewport-->\n  <meta name=\"viewport\" content=\"width=1200\" />\n  \n      <!--css-->\n    <link rel=\"stylesheet\" href=\"/shukatsu/resource/css/style_branch_pc.css?update=202505231300\" type=\"text/css\" media=\"all\"/>\n  \n      <!--js-->\n    <script src=\"/shukatsu/resource/js/jquery.min.js?update=202303311300\" type=\"text/javascript\"></script>\n    <script src=\"/shukatsu/resource/js/jquery.mobile.min.js?update=202303311300\" type=\"text/javascript\"></script>\n    <script src=\"/shukatsu/resource/js/base.js?update=202303311300\" type=\"text/javascript\"></script>\n    <script src=\"/shukatsu/resource/js/site_pc.js?update=202303311300\" type=\"text/javascript\"></script>\n  \n    \n    \n          \n</head>\n<body id=\"top\" class=\"yearAround\">\n      <!-- Google Tag Manager (noscript) -->\n    <noscript>\n      <iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-MLJ53XS\"\n              height=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe>\n    </noscript>\n    <!-- End Google Tag Manager (noscript) -->\n  \n      <div id=\"header\" class=\"header\">\n        <div class=\"header_inner\">\n\n            <h1 class=\"siteTitle\"><span>大好きな北海道で就職したい。<br/>新卒・第二新卒の学生の皆さんを応援する就職情報サイト</span><strong>ジョブキタ就活</strong>\n            </h1>\n\n        </div>\n    </div><!-- .header -->\n\n  \n  \n    <div id=\"contents\" class=\"contents\">\n        <div class=\"contents_inner\">\n\n                        <div class=\"serviceGuide serviceGuide_current-shift\" data-ana-area=\"serviceGuide\">\n\n                <div class=\"serviceGuide_set serviceGuide_set-upcoming\">\n                                            <h2 class=\"serviceGuide_title\"><a href=\"/shukatsu/2028/\" data-ana-event=\"link-logo-2028\"><img src=\"https://image.haj.co.jp/jobkita/shukatsu/branch/logo_2028.png\" alt=\"ジョブキタ就活 2028\"></a></h2>\n                        <p class=\"serviceGuide_lead\">2028年卒業予定の大学・大学院・短大・高専・専門学校の学生の方および既卒の方の就職活動</p>\n                        <ul class=\"serviceGuide_link\">\n                            <li class=\"serviceGuide_linkItem serviceGuide_linkItem-site\"><a href=\"/shukatsu/2028/\" data-ana-event=\"link-top-2028\">ジョブキタ就活 2028へ</a></li>\n                            <li class=\"serviceGuide_linkItem serviceGuide_linkItem-register\"><a href=\"/shukatsu/2028/signup/mail/input/\" data-ana-event=\"link-register-2028\">会員登録<span class=\"free\">（無料）</span></a></li>\n                            <li class=\"serviceGuide_linkItem serviceGuide_linkItem-login\"><a href=\"/shukatsu/2028/login/\" data-ana-event=\"link-login-2028\">ログイン</a></li>\n                        </ul>\n                                    </div>\n\n                <div class=\"serviceGuide_set serviceGuide_set-current\">\n\n                    <h2 class=\"serviceGuide_title\">\n                        <a href=\"/shukatsu/2027/\" data-ana-event=\"link-logo-2027\">\n                            <img src=\"https://image.haj.co.jp/jobkita/shukatsu/branch/logo_2027.png?update=202303311300\"\n                                 alt=\"ジョブキタ就活 2027\"/>\n                        </a>\n                    </h2>\n\n                    <p class=\"serviceGuide_lead\">\n                        2027年卒業予定の大学・大学院・短大・高専・専門学校の学生の方および既卒の方の就職活動\n                    </p>\n\n                    <ul class=\"serviceGuide_link\">\n                        <li class=\"serviceGuide_linkItem serviceGuide_linkItem-site\">\n                            <a href=\"/shukatsu/2027/\" data-ana-event=\"link-top-2027\">ジョブキタ就活 2027へ</a>\n                        </li>\n                        <li class=\"serviceGuide_linkItem serviceGuide_linkItem-register\">\n                            <a href=\"/shukatsu/2027/signup/mail/input/\" data-ana-event=\"link-register-2027\">会員登録<span class=\"free\">（無料）</span></a>\n                        </li>\n                        <li class=\"serviceGuide_linkItem serviceGuide_linkItem-login\">\n                            <a href=\"/shukatsu/2027/login/\" data-ana-event=\"link-login-2027\">ログイン</a>\n                        </li>\n                    </ul>\n\n                </div><!-- .serviceGuide_set -->\n\n            </div><!-- .serviceGuide -->\n\n                            <div class=\"topArticle\"><div class=\"topArticle_inner\">\n        <h3 class=\"topArticle_title\">就活ガイド</h3>\n        <div class=\"topArticle_body\">\n\n                            <div class=\"topArticleUnit\">\n                    <h4 class=\"topArticleUnit_headline\">北海道就活トーク・就活ノウハウ編</h4>\n                    <div class=\"topArticleUnit_linkSet\">\n                                                    <a class=\"topArticleUnit_item\" href=\"https://www.jobkita.jp/shukatsu/shukatsu-guide/how-to/24581/\">\n                                                                    <span class=\"topArticleUnit_thumbnail\"><img src=\"https://image.haj.co.jp/article/images/678deabdcdd7f001979104.png\" alt=\"\"></span>\n                                                                <span class=\"topArticleUnit_lead\">ちゃんと考えよう、北海道で「働き、暮らすこと」</span>\n                            </a>\n                                                <div class=\"topArticleUnit_links\">\n                            <a class=\"topArticleUnitBtn\" href=\"/shukatsu/shukatsu-guide/how-to/\">記事一覧へ</a>\n                        </div>\n                    </div>\n                </div>\n                            <div class=\"topArticleUnit\">\n                    <h4 class=\"topArticleUnit_headline\">北海道就活トーク・自己理解編</h4>\n                    <div class=\"topArticleUnit_linkSet\">\n                                                    <a class=\"topArticleUnit_item\" href=\"https://www.jobkita.jp/shukatsu/shukatsu-guide/selfanalysis/25181/\">\n                                                                    <span class=\"topArticleUnit_thumbnail\"><img src=\"https://image.haj.co.jp/article/images/678decf71fe04522851379.png\" alt=\"\"></span>\n                                                                <span class=\"topArticleUnit_lead\">自己分析って何のためにするの？</span>\n                            </a>\n                                                <div class=\"topArticleUnit_links\">\n                            <a class=\"topArticleUnitBtn\" href=\"/shukatsu/shukatsu-guide/selfanalysis/\">記事一覧へ</a>\n                        </div>\n                    </div>\n                </div>\n                            <div class=\"topArticleUnit\">\n                    <h4 class=\"topArticleUnit_headline\">北海道就活トーク・仕事理解編</h4>\n                    <div class=\"topArticleUnit_linkSet\">\n                                                    <a class=\"topArticleUnit_item\" href=\"https://www.jobkita.jp/shukatsu/shukatsu-guide/workstudy/25801/\">\n                                                                    <span class=\"topArticleUnit_thumbnail\"><img src=\"https://image.haj.co.jp/article/images/67970cfcc7b28561037559.png\" alt=\"\"></span>\n                                                                <span class=\"topArticleUnit_lead\">知ることから始める、職種研究と分析。</span>\n                            </a>\n                                                <div class=\"topArticleUnit_links\">\n                            <a class=\"topArticleUnitBtn\" href=\"/shukatsu/shukatsu-guide/workstudy/\">記事一覧へ</a>\n                        </div>\n                    </div>\n                </div>\n                            <div class=\"topArticleUnit\">\n                    <h4 class=\"topArticleUnit_headline\">北海道就活トーク・選考対策編</h4>\n                    <div class=\"topArticleUnit_linkSet\">\n                                                    <a class=\"topArticleUnit_item\" href=\"https://www.jobkita.jp/shukatsu/shukatsu-guide/measures/25601/\">\n                                                                    <span class=\"topArticleUnit_thumbnail\"><img src=\"https://image.haj.co.jp/article/images/678deecde584f001827039.png\" alt=\"\"></span>\n                                                                <span class=\"topArticleUnit_lead\">北海道就活生必見！エントリーシートの基本と書き方。</span>\n                            </a>\n                                                <div class=\"topArticleUnit_links\">\n                            <a class=\"topArticleUnitBtn\" href=\"/shukatsu/shukatsu-guide/measures/\">記事一覧へ</a>\n                        </div>\n                    </div>\n                </div>\n            \n        </div>\n    </div></div><!-- .topArticle -->                                        <div class=\"siteMapCategory\"><div class=\"siteMapCategory_inner\">\n        <h2 class=\"siteMapCategory_title siteMapCategory_title-primary\"><a href=\"https://www.jobkita.jp/shukatsu/column/\">編集記事</a></h2>\n        <ul class=\"siteMapList\">\n                            <li class=\"siteMapList_item\"><a href=\"/shukatsu/column/manner/\">知っておくと安心。基本の就活マナー＆北海道就活あるある</a></li>\n                            <li class=\"siteMapList_item\"><a href=\"/shukatsu/column/industryResearch/\">就活準備は知ることから。北海道視点の業界研究</a></li>\n                    </ul>\n    </div></div>                    </div>\n    </div><!-- .contents -->\n\n\n      <div id=\"footer\">\n      <div class=\"footer_inner\">\n        <b class=\"footer_pageTop ui-scroll\" data-top=\"0\" role=\"button\"><img src=\"https://image.haj.co.jp/jobkita/shukatsu/root/common/ft_pagetop.png?update=202303311300\" alt=\"ページの先頭へ\"></b>\n\n        <div class=\"footer_outline\">\n          <div class=\"footerDescription\">\n            <h3 class=\"footerDescription_title\">『ジョブキタ就活』とは？</h3>\n            <p class=\"footerDescription_text\">ジョブキタ就活は「地元・北海道で就職したい」学生のための就職情報サイト。約50年に渡り北海道の求人事業に取り組んできた北海道アルバイト情報社ならではのノウハウと情報網、徹底した取材で北海道内企業の新卒採用情報を掲載しています。</p>\n            <p class=\"footerDescription_text\">また、ジョブキタ就活主催の合同企業説明会、キャリアアドバイザーによる就活個別相談や就活講座・セミナー、新卒学生向けの無料就職エージェントサービス（新卒紹介）など、就職活動を頑張る、北海道で働きたい学生に役立つ就職情報・イベントを提供します。</p>\n          </div><!-- .footerDescription -->\n\n          \t\t<div class=\"footerOfficialBadges\">\n        <div class=\"footerCertifiedJobMedia\">\n            <a href=\"https://yuryonintei.com/\" target=\"_blank\">\n              <img loading=\"lazy\" src=\"https://www.haj.co.jp/certified-job-media/certification-mark.png\" alt=\"優良募集情報等提供事業者\" width=\"275px\" height=\"80px\">\n            </a>\n            <p class=\"footerSummaryCertifiedJobMedia_text\">\n              弊社は、優良募集情報等提供事業者認定制度の基準を満たしている事業者です。制度の詳細についてはリンク先をご覧ください。\n            </p>\n        </div>\n        <div class=\"footerPmark\"><a href=\"http://privacymark.jp/\" target=\"_blank\"><img\n                        src=\"https://image.haj.co.jp/hajsite_common/pmark/pmark_75.gif\" alt=\"プライバシーマーク\"/></a></div>\n    </div>\n\n        </div><!-- .footer_outline -->\n\n          <div class=\"footer_links\">\n    \n    <div class=\"footerHajLinks\">\n      <h3 class=\"footerHajLinks_title\">HAJの求人情報サイト</h3>\n      <ul class=\"footerHajLinks_list\"><li class=\"footerHajLinks_item\"><a href=\"https://job.haj.co.jp\" target=\"_blank\"><span>JOB-NET HOKKAIDO</span>HAJの各求人情報サイトを一覧できるポータルサイト</a></li><li class=\"footerHajLinks_item\"><a href=\"https://www.arukita.com/\" target=\"_blank\"><span>アルキタ</span>札幌市内・周辺の求人情報を中心に配信する総合求人情報サイト</a></li><li class=\"footerHajLinks_item\"><a href=\"https://www.jobkita.jp\" target=\"_blank\"><span>ジョブキタ</span>正社員志向の高い、北海道で働きたい人のための転職・就職求人サイト</a></li><li class=\"footerHajLinks_item\"><a href=\"https://www.shufukita.jp\" target=\"_blank\"><span>しゅふきた</span>主婦の「働く」を応援する北海道の求人情報サイト</a></li><li class=\"footerHajLinks_item\"><a href=\"https://www.sgnavi.com\" target=\"_blank\"><span>シゴトガイド</span>道内各エリアをカバーする、地域に根ざした総合求人情報サイト</a></li><li class=\"footerHajLinks_item\"><a href=\"https://www.jobkita.jp/hrs/\" target=\"_blank\"><span>ジョブキタ紹介</span>キャリア・資格・人柄、「あなたの強み」を札幌・北海道の企業へ繋ぐ転職エージェント</a></li></ul>    </div><!-- .footerHajLinks -->\n    <div class=\"footerHajLinks\">\n      <h3 class=\"footerHajLinks_title\">その他の関連サイト</h3>\n      <ul class=\"footerHajLinks_list\"><li class=\"footerHajLinks_item\"><a href=\"https://kurashigoto.hokkaido.jp\" target=\"_blank\"><span>くらしごと</span>北海道での暮らしや仕事をテーマに、その土地で働く人や生活スタイルを紹介するWebサイト</a></li><li class=\"footerHajLinks_item\"><a href=\"https://sankousho.haj.co.jp\" target=\"_blank\"><span>北海道 未来のしごとの参考書</span>北海道の仕事に出会えるキャリア探求サイト</a></li><li class=\"footerHajLinks_item\"><a href=\"https://sapporo-mirai-base.jp/\" target=\"_blank\"><span>札幌未来ベース</span>札幌の未来を創る暮らしや仕事。そこにある「人」の想いを届けるWebサイト</a></li><li class=\"footerHajLinks_item\"><a href=\"https://www.haj.co.jp/holive/\" target=\"_blank\"><span>歩らいぶ</span>マチ歩きBOOK</a></li><li class=\"footerHajLinks_item\"><a href=\"https://official.haj.co.jp/\" target=\"_blank\"><span>HAJオフィシャルサイト</span>株式会社 北海道アルバイト情報社の各種サービス、リリース情報、会社の取り組みなどをご案内</a></li><li class=\"footerHajLinks_item\"><a href=\"https://www.haj.co.jp/recruit/\" target=\"_blank\"><span>HAJ新卒採用サイト</span>株式会社 北海道アルバイト情報社の採用に関する情報を公開しています</a></li><li class=\"footerHajLinks_item\"><a href=\"https://hitokita.haj.co.jp/\" target=\"_blank\"><span>ヒトキタ</span>人事担当者のブックマークサイト</a></li></ul>    </div><!-- .footerHajLinks -->\n\n  </div><!-- .footer_links -->\n\n        <div class=\"footerSignature\"><div class=\"footerSignature_inner\">\n            <a class=\"footerSignature_company\" href=\"https://official.haj.co.jp/\" target=\"_blank\">HAJ 株式会社 北海道アルバイト情報社</a>\n            <p class=\"footerSignature_copyright\">(c) Hokkaido Arbeit Johosha co.,ltd. All Rights Reserved.</p>\n          </div></div><!-- .footer_signature -->\n\n\n      </div>\n    </div><!-- [/#footer] -->\n    \n  \n  \n</body>\n</html>","finalUrl":"https://www.jobkita.jp/shukatsu/","rendered":false,"_cachedAt":"2026-06-22T14:39:37.040Z"}