//hi-niyaku.co.jp/about/\">\n                                <div class=\"menuSectionItem_title\">会社概要</div>\n                            </a>\n                        </div>\n                        <!-- /.menuSectionItem -->\n\n                        <ul class=\"menuSectionList\">\n                            <li><a href=\"https://hi-niyaku.co.jp/about/history/\">沿革</a></li>\n                        </ul>\n                        <!-- /.menuSectionList -->\n\n                    </div>\n                    <div class=\"menuContainer_item menuContainer_item-02\">\n\n                        <div class=\"menuSectionItem\">\n                            <a href=\"https://hi-niyaku.co.jp/business/\">\n                                <div class=\"menuSectionItem_title\">事業案内</div>\n                            </a>\n                        </div>\n                        <!-- /.menuSectionItem -->\n\n                        <ul class=\"menuSectionList\">\n                            <li><a href=\"https://hi-niyaku.co.jp/business/lumber/\">木材物流</a></li>\n                            <li><a href=\"https://hi-niyaku.co.jp/business/container/\">コンテナ物流</a></li>\n                            <li><a href=\"https://hi-niyaku.co.jp/business/automobile/\">車輌物流</a></li>\n                            <li><a href=\"https://hi-niyaku.co.jp/business/general/\">その他物流</a></li>\n                        </ul>\n                        <!-- /.menuSectionList -->\n\n                    </div>\n                </div>\n                <div class=\"menuContainer_item menuContainer_item-03\">\n                    <div class=\"menuSectionItem\">\n                        <a href=\"https://hi-niyaku.co.jp/recruit/\">\n                            <div class=\"menuSectionItem_title\">採用情報</div>\n                        </a>\n                    </div>\n                    <!-- /.menuSectionItem -->\n                    <div class=\"menuSectionItem\">\n                        <a href=\"https://hi-niyaku.co.jp/sdgs/\">\n                            <div class=\"menuSectionItem_title\">SDGsの取組</div>\n                        </a>\n                    </div>\n                    <!-- /.menuSectionItem -->\n\n                    <div class=\"menuSectionItem\">\n                        <a href=\"https://hi-niyaku.co.jp/contact/\">\n                            <div class=\"menuSectionItem_title\">お問い合せ</div>\n                        </a>\n                    </div>\n                    <!-- /.menuSectionItem -->\n\n                    <div class=\"menuSectionItem\">\n                        <a href=\"https://hi-niyaku.co.jp/sitemap/\">\n                            <div class=\"menuSectionItem_title\">サイトマップ</div>\n                        </a>\n                    </div>\n                    <!-- /.menuSectionItem -->\n\n                </div>\n\n            </div>\n        </div>\n        <!-- /.menuContainer -->\n\n<div class=\"commonTitle\">\n    <div class=\"container\">\n        <h1 class=\"commonTitle_title commonTitle_title-03\"><img src=\"https://hi-niyaku.co.jp/wp-content/themes/niyaku-theme/cmn/img/recruit/pic_titlte.png?v=202601260546\" alt=\"\"></h1>\n        <div class=\"commonTitle_info\">先輩の声</div>\n    </div>\n</div>\n<!-- /.commonTitle -->\n\n<div class=\"pnkz\">\n    <div class=\"container\">\n        <ul class=\"pnkz_list\">\n            <li><a href=\"https://hi-niyaku.co.jp/\">トップ</a></li>\n            <li><a href=\"https://hi-niyaku.co.jp/recruit/\">採用情報</a></li>\n            <li class=\"active\">先輩の声</li>\n        </ul>\n    </div>\n</div>\n<!-- /.pnkz -->\n\n\n<div class=\"recruitDetailSec01\">\n    <div class=\"container\">\n        <h2 class=\"recruitDetailSec01_title\">先輩の声</h2>\n\n        <div class=\"recruitDetailSec01Head\">\n            <div class=\"recruitDetailSec01Head_pic\">\n                <img src=\"https://hi-niyaku.co.jp/wp-content/themes/niyaku-theme/cmn/img/recruit/03/pic_head.jpg?v=202601260546\" alt=\"\">\n            </div>\n            <div class=\"recruitDetailSec01Head_data\">\n                <div class=\"recruitDetailSec01Head_catch\">先回りして対応できるよう、<br>日々段取りよく！</div>\n                <div class=\"recruitDetailSec01Head_label\"><span>営業部 営業グループ</span></div>\n                <!-- <div class=\"recruitDetailSec01Head_pos\">所属<br>2018年入社</div> -->\n                <div class=\"recruitDetailSec01Head_pos\">所属</div>\n                <div class=\"recruitDetailSec01Head_message\">お客様やドライバーとの信頼関係を常に意識して、効率のよい業務を目指しています。</div>\n            </div>\n        </div>\n        <!-- /.recruitDetailSec01Head -->\n    </div>\n</div>\n<!-- /.recruitDetailSec01 -->\n\n\n<div class=\"recruitDetailMainSec\">\n    <div class=\"container\">\n        <div class=\"recruitDetailSubBox\">\n\n            <div class=\"recruitDetailSubBox_item\">\n                <div class=\"recruitDetailSubBox_title\">事務系総合職を求めている方に<span class=\"spBr\"></span>最適な職場</div>\n                <div class=\"recruitDetailSubBox_text\">私の業務は主に車輌の運行記録集計や請求書の作成を担当しています。総合物流会社である当社は日々、トレーラーや大型車が各所へ運送しており、私は運行管理者と意思疎通を図りながら円滑に運送業務が行えるように数々の仕事を引き受けます。<br>\n                    入社間もない頃は業務量の多さに取りまとめが大変と感じたのですが、事務仕事の軽減のために当社独自のシステムを導入して頂いたり、先輩や上司のサポートもありましたので、今では自信を持って対応できるようになりました。<br>\n                    当社は各々のスキルやレベルに応じて仕事の調整をしてくれる事が大きな魅力です。私が事務仕事だけでなく、配車業務（各所へトラックの手配・調整業務）をできるだけ挑戦してみたいと思い切って先輩にお願いしたところ、快く承諾してくれました。それから少しずつ、丁寧に指導をして頂き、いまでは大型トラックの配車手配を全て任されています。</div>\n                <div class=\"recruitDetailSubBox_pic\"><img src=\"https://hi-niyaku.co.jp/wp-content/themes/niyaku-theme/cmn/img/recruit/03/pic_01.jpg?v=202601260546\" alt=\"\"></div>\n            </div>\n\n            <div class=\"recruitDetailSubBox_item\">\n                <div class=\"recruitDetailSubBox_title\">向上心があれば<span class=\"spBr\"></span>色々な選択肢があります</div>\n                <div class=\"recruitDetailSubBox_text\">配車業務は指定された場所に荷物を届けるだけではありません。”指定場所の独自ルール””建物に接触しそうな箇所””指定時間””交通状況”など様々な事に注意しなければなりません。それと併せて翌日・翌々日の手配を同時にこなすチカラが必要となってきます。大変な日もありますが、手配すべてが完了し、漏れがないシフトが組めていると自信に繋がります。先回りして物事を考え、効率や段取りを常に意識するようにしています。<br>\n                    また当社は向上心があれば選択肢はたくさんあります。私のように配車業務に挑戦する事も可能ですし、営業や通関・貿易実務など、志があれば参加することも可能です。<br>\n                    そして休日と有給休暇がしっかり取れるところも魅力です。平日もほとんど残業がないので、余裕を持ってプライベートの時間を計画的に楽しむことができます。<br>\n                    しっかりと仕事をがんばり、しっかりとプライベートも充実させたい、という方にぴったりの職場環境です。</div>\n                <div class=\"recruitDetailSubBox_pic\"><img src=\"https://hi-niyaku.co.jp/wp-content/themes/niyaku-theme/cmn/img/recruit/03/pic_02.jpg?v=202601260546\" alt=\"\"></div>\n            </div>\n\n\n\n        </div>\n        <!-- /.recruitDetailSubBox -->\n    </div>\n</div>\n<!-- /.recruitDetailMainSec -->\n\n\n\n<div class=\"recNaviBox\">\n    <div class=\"container\">\n        <div class=\"recNaviBoxMain\">\n            <a href=\"/recruit/rec02/\" class=\"recNaviBoxMain_item\">\n                <div class=\"recNaviBoxMain_pic\">\n                    <img src=\"https://hi-niyaku.co.jp/wp-content/themes/niyaku-theme/cmn/img/recruit/pic_staff_02.jpg?v=202601260546\" alt=\"\">\n                </div>\n                <div class=\"recNaviBoxMain_data\">\n                    <div class=\"recNaviBoxMain_pos\">廿日市営業所<br>所属</div>\n                </div>\n            </a>\n            <a href=\"/recruit/rec04/\" class=\"recNaviBoxMain_item02\">\n                <div class=\"recNaviBoxMain_pic\">\n                    <img src=\"https://hi-niyaku.co.jp/wp-content/themes/niyaku-theme/cmn/img/recruit/pic_staff_04.jpg?v=202601260546\" alt=\"\">\n                </div>\n                <div class=\"recNaviBoxMain_data\">\n                    <div class=\"recNaviBoxMain_pos\">通関部<br>所属</div>\n                </div>\n            </a>\n        </div>\n        <!-- /.recNaviBoxMain -->\n\n    </div>\n</div>\n<!-- /.recNaviBox -->\n\n\n\n\n\n<section class=\"aboutBtmNavi\">\n    <div class=\"container\">\n        <div class=\"aboutBtmNaviMain\">\n            <div class=\"aboutBtmNaviMain_item aboutBtmNaviMain_item-01\">\n                <a href=\"https://hi-niyaku.co.jp/recruit/\">\n                    <div class=\"aboutBtmNaviMain_item-inner\"><span>採用情報</span></div>\n                </a>\n            </div>\n            <div class=\"aboutBtmNaviMain_item aboutBtmNaviMain_item-02\">\n                <a href=\"https://hi-niyaku.co.jp/contact/\">\n                    <div class=\"aboutBtmNaviMain_item-inner\"><span>お問い合せ</span></div>\n                </a>\n            </div>\n\n        </div>\n        <!-- /.aboutBtmNaviMain -->\n\n    </div>\n</section>\n<!-- /.aboutBtmNavi -->\n\n\n\n<div class=\"footer\">\n    <div class=\"footerTop\">\n        <div class=\"container\">\n            <div class=\"footerTopMain\">\n                <div class=\"footerTopMain_data\">\n                    <div class=\"footerTopMain_logo\"><a href=\"https://hi-niyaku.co.jp/\"><img src=\"https://hi-niyaku.co.jp/wp-content/themes/niyaku-theme/cmn/img/common/pic_logo.png?v=202601260546\" width=\"532\" height=\"80\" alt=\"広島荷役株式会社\"></a></div>\n\n                    <div class=\"footerTopMain_address\">\n                        <p>本社　広島市南区宇品海岸二丁目23番27号</p>\n                        <p>総務部／TEL.<span class=\"js-tel\">082-254-8889</span>　FAX.082-254-5681<br>\n                            営業部／TEL.<span class=\"js-tel\">082-254-0289</span>　FAX.082-251-6388<br>\n                            通関部／TEL.<span class=\"js-tel\">082-254-0289</span>　FAX.082-254-8893<br>\n                            港運部／TEL.<span class=\"js-tel\">082-254-8888</span>　FAX.082-254-8891</p>\n                        <p>廿日市営業所　広島県廿日市市木材港南9番11号</p>\n                        <p>TEL.<span class=\"js-tel\">0829-32-8831</span>　FAX.0829-32-7667</p>\n                    </div>\n                </div>\n\n                <div class=\"footerTopMain_navi\">\n                    <dl class=\"footerTopMain_list\">\n                        <dt><a href=\"https://hi-niyaku.co.jp/about/\">会社概要</a></dt>\n                        <dd>\n                            <ul>\n                                <li><a