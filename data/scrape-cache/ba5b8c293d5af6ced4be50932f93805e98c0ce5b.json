 </dt>\r\n            <dd>\r\n              <ul>\r\n                <li><a href=\"../recruit/index.html\">募集要項／<br>採用担当者メッセージ</a></li>\r\n                <li><a href=\"../recruit/faq.html\">よくあるご質問</a></li>\r\n              </ul>\r\n            </dd>\r\n          </dl>\r\n\r\n        </div>\r\n        <div class=\"menu-harassment\">\r\n          <ul>\r\n            <li><a href=\"../harassment-policy/index.html\">就活ハラスメント防止方針</a></li>\r\n          </ul>\r\n        </div>\r\n      \r\n        <div class=\"menuFoot\">\r\n          <ul class=\"c-flex__sb\">\r\n            <li class=\"entry\"><a href=\"https://mypage.3070.i-webs.jp/rec_ct2027/\" target=\"_blank\">新卒ENTRY／MY PAGE</a></li>\r\n            <li><a href=\"https://landing.lineml.jp/r/1599619341-oVQDY4wO?lp=jM9O73\" target=\"_blank\"><img src=\"../assets/img/line.png\" alt=\"LILNE 友だち追加\"></a></li>\r\n          </ul>\r\n        </div>\r\n      </div>\r\n      <script type=\"text/javascript\" src=\"../assets/js/jquery.inview.min.js\"></script>\r\n      <script>\r\n        $(\"section\").on(\"inview\", function () {\r\n          $(this).addClass(\"is-inview\");\r\n        });\r\n      </script>\r\n\r\n\r\n</body>\t\r\n</html>\r\n","finalUrl":"https://recruit.career-tasu.co.jp/newgraduate/recruit/index.html","rendered":false,"_cachedAt":"2026-06-24T00:22:05.169Z"}