th=\"2\" onClick=\"calStay.write();\" onChange=\"calStay.getFormValue(); calStay.hide();\">\n\t\t<br />\n\t</div>\n\n\t<div class=\"option\">\n\t\t<div class=\"days\">\n\t\t\t<label for=\"hidSELECTHAKSU\">宿泊数</label>\n\t\t\t<select name=\"hidSELECTHAKSU\">\n\t\t\t\t<option value=\"1\" selected>1</option>\n\t\t\t\t<option value=\"2\">2</option>\n\t\t\t\t<option value=\"3\">3</option>\n\t\t\t\t<option value=\"4\">4</option>\n\t\t\t\t<option value=\"5\">5</option>\n\t\t\t\t<option value=\"6\">6</option>\n\t\t\t\t<option value=\"7\">7</option>\n\t\t\t</select>泊\n\t\t</div>\n\t\t<div class=\"number\">\n\t\t\t<label for=\"cmbADULT\">人数</label>\n\t\t\t<select name=\"cmbADULT\">\n\t\t\t\t<option value=\"1\">1</option>\n\t\t\t\t<option value=\"2\" selected>2</option>\n\t\t\t\t<option value=\"3\">3</option>\n\t\t\t\t<option value=\"4\">4</option>\n\t\t\t\t<option value=\"5\">5</option>\n\t\t\t\t<option value=\"6\">6</option>\n\t\t\t\t<option value=\"7\">7</option>\n\t\t\t</select>名\n\t\t</div>\n\t\t<div class=\"btn-submit\">\n\t\t\t<input type=\"button\" name=\"seek\" class=\"btn-search\" value=\"検 索\">\n\t\t</div>\n\t</div><!-- end option -->\n\n\t\t<!-- 部屋数を1に設定 -->\n\t\t<input type=\"hidden\" name=\"hidROOM\" value=\"1\">\n\n\t\t<!-- 日程未定非表示 -->\n\t\t<input type=\"checkbox\" name=\"chkymd\" id=\"chkymd\" value=\"0\" style=\"display:none;\">\n\n\t\t<!-- 人数未定非表示 -->\n\t\t<input type=\"checkbox\" name=\"chkpsn\" id=\"chkpsn\" value=\"0\" style=\"display:none;\">\n\n\t\t<!-- 子どもA~D非表示-->\n\t\t<input type=\"hidden\" name=\"cmbCHILDa\" value=\"0\">\n\t\t<input type=\"hidden\" name=\"cmbCHILDb\" value=\"0\">\n\t\t<input type=\"hidden\" name=\"cmbCHILDc\" value=\"0\">\n\t\t<input type=\"hidden\" name=\"cmbCHILDd\" value=\"0\">\n\n\t\t<!-- 最低最高料金非表示 -->\n\t\t<input type=\"hidden\" name=\"minPrice\" value=\"0\">\n\t\t<input type=\"hidden\" name=\"maxPrice\" value=\"9999999\">\n\n\t\t<!-- Dispunit / プランを表示 -->\n\t\t<input type=\"hidden\" name=\"hiddispunit\" id=\"selectplan\" value=\"\"\tchecked\t>\n\n\t\t\t\n\t\t\n\t\t<input type=\"hidden\" name=\"hidSELECTARRYMD\" value=\"\">\n\t\t<input type=\"hidden\" name=\"hidchkymd\" value=\"\">\n\t\t<input type=\"hidden\" name=\"hidchkpsn\" value=\"\">\n\t\t<input type=\"hidden\" name=\"Dispunit\" value=\"\">\n\n\t</div>\n</form>\n</div>\n\n<script>\n//カレンダー設定\nvar calStay = new JKL.Calendar(\"cal-stay-id\",\"frm-stay-id\",\"hidSELECTARRYMD\");\n//カレンダー初期設定\ninitJsCal(calStay);\n//日付初期値\ninitRsvDate('frm-stay-id');\n</script>\n\t\t\t\t\t<div class=\"stay-PUP\">\n<h3 class=\"titleA\">Pick Up Plan</h3>\n<p class=\"sub\">おすすめプラン</p>\n<div class=\"inner\">\n<ul class=\"res-PUP-Slider\">\n<li>\n<div class=\"thumb\"><a href=\"https://asp.hotel-story.ne.jp/ver3d/ASPP0200.asp?hidSELECTCOD1=61550&hidSELECTCOD2=001&hidSELECTPLAN=A0GWB&pac=P01&hidSELECTARRYMD=2022/12/07&hidSELECTHAKSU=1&rooms=1&selectptyp=&selectppsn=00020&hidk=&reffrom=&LB01=server8\" target=\"_blank\"><img alt=\"【当館定番】★世界一の朝食付き★ステイ\" src=\"/upload/file/images/20180404_003ts.jpg\" style=\"width: 800px; height: 533px;\"></a></div>\n<div class=\"cont\">\n<h4><a href=\"https://asp.hotel-story.ne.jp/ver3d/ASPP0200.asp?hidSELECTCOD1=61550&hidSELECTCOD2=001&hidSELECTPLAN=A0GWB&pac=P01&hidSELECTARRYMD=2022/12/07&hidSELECTHAKSU=1&rooms=1&selectptyp=&selectppsn=00020&hidk=&reffrom=&LB01=server8\" target=\"_blank\">【当館定番】★世界一の朝食付き★ステイ </a></h4>\n</div>\n</li>\n<li>\n<div class=\"thumb\"><a href=\"https://asp.hotel-story.ne.jp/ver3d/ASPP0200.asp?hidSELECTCOD1=61550&hidSELECTCOD2=001&hidSELECTPLAN=A1TM9&pac=P02&hidSELECTARRYMD=2022/12/07&hidSELECTHAKSU=1&rooms=1&selectptyp=&selectppsn=00020&hidk=&reffrom=&LB01=server8\" target=\"_blank\"><img alt=\"【ディナー人気No１】兵庫の厳選食材！前菜+魚料理+神戸ビーフ★フレンチディナー＆世界一の朝食付き\" src=\"/upload/file/images/6155000100836.jpg\" style=\"width: 800px; height: 533px;\"></a></div>\n<div class=\"cont\">\n<h4><a href=\"https://asp.hotel-story.ne.jp/ver3d/ASPP0200.asp?hidSELECTCOD1=61550&hidSELECTCOD2=001&hidSELECTPLAN=A1TM9&pac=P02&hidSELECTARRYMD=2022/12/07&hidSELECTHAKSU=1&rooms=1&selectptyp=&selectppsn=00020&hidk=&reffrom=&LB01=server8\" target=\"_blank\">【ディナー人気No１】兵庫の厳選食材！前菜+魚料理+神戸ビーフ★フレンチディナー＆世界一の朝食付き</a></h4>\n</div>\n</li>\n<li>\n<div class=\"thumb\"><a href=\"https://asp.hotel-story.ne.jp/ver3d/ASPP0200.asp?hidSELECTCOD1=61550&hidSELECTCOD2=001&hidSELECTPLAN=A2HHB&pac=P02&hidSELECTARRYMD=2022/12/07&hidSELECTHAKSU=1&rooms=1&selectptyp=&selectppsn=00020&hidk=&reffrom=&LB01=server8\" target=\"_blank\"><img alt=\"【アニバーサリー】誕生日・記念日を大切な人と過ごすオーベルジュステイ★演出ケーキ付ディナー&世界一の朝食付き【1泊2食】 \" src=\"/upload/file/images/6155000100270.jpg\" style=\"width: 600px; height: 400px;\"></a></div>\n<div class=\"cont\">\n<h4><a href=\"https://asp.hotel-story.ne.jp/ver3d/ASPP0200.asp?hidSELECTCOD1=61550&hidSELECTCOD2=001&hidSELECTPLAN=A2HHB&pac=P02&hidSELECTARRYMD=2022/12/07&hidSELECTHAKSU=1&rooms=1&selectptyp=&selectppsn=00020&hidk=&reffrom=&LB01=server8\" target=\"_blank\">【アニバーサリー】誕生日・記念日を大切な人と過ごすオーベルジュステイ★演出ケーキ付ディナー&世界一の朝食付き【1泊2食】</a></h4>\n</div>\n</li>\n<li>\n<div class=\"thumb\"><a href=\"https://asp.hotel-story.ne.jp/ver3d/ASPP0200.asp?hidSELECTCOD1=61550&hidSELECTCOD2=001&hidSELECTPLAN=A1G9B&pac=P01&hidSELECTARRYMD=2022/12/07&hidSELECTHAKSU=1&rooms=1&selectptyp=&selectppsn=00030&hidk=&reffrom=&LB01=server8\" target=\"_blank\"><img alt=\"【3名だからお得】神戸北野ホテル自慢の焼菓子とお帰りのタクシー付き\" src=\"/upload/file/images/6155000100650.jpg\" style=\"width: 600px; height: 400px;\"></a></div>\n<div class=\"cont\">\n<h4><a href=\"https://asp.hotel-story.ne.jp/ver3d/ASPP0200.asp?hidSELECTCOD1=61550&hidSELECTCOD2=001&hidSELECTPLAN=A1G9B&pac=P01&hidSELECTARRYMD=2022/12/07&hidSELECTHAKSU=1&rooms=1&selectptyp=&selectppsn=00030&hidk=&reffrom=&LB01=server8\" target=\"_blank\">【3名だからお得】神戸北野ホテル自慢の焼菓子とお帰りのタクシー付き</a></h4>\n</div>\n</li>\n</ul>\n<p style=\"text-align: center;\"><a class=\"btn_plan\" href=\"https://asp.hotel-story.ne.jp/ver3d/planlist.asp?hcod1=61550&hcod2=001&mode=seek&clrmode=true&reffrom=\" target=\"_blank\">宿泊プラン一覧</a></p>\n</div>\n</div>\n<p> </p>\n\t\t\t\t</div>\n\t<main>\n\t\t\t\t\t\t\t\t\t<!-- 通常記事2 -->\n<div class=\"kiji2\" id=\"522\">\n<!-- -->\n\n<!-- 擬似area1 -->\r\n<div id=\"area1\"><!-- 通常記事2 -->\r\n<div class=\"kiji2\" id=\"137\"><!-- -->\r\n<p><img src=\"/upload/file/Image/Kanko/uroko.jpg\" alt=\"うろこの家\" width=\"900\" height=\"600\" /></p>\r\n<h4>うろこの家</h4>\r\n<p>外壁を飾る天然石のスレートが魚の鱗に見えることから「うろこの家」と呼ばれている神戸のシンボル的な異人館。展望室からは神戸の街と港が一望できます。</p>\r\n<p><strong>住所</strong><br />\r\n兵庫県神戸市中央区北野町２丁目２０&minus;４</p>\r\n<p><strong>神戸北野ホテルからのアクセス</strong><br />\r\n北東に徒歩およそ17分</p>\r\n<p><strong>公式サイト</strong><br />\r\n<a href=\"http://kobe-ijinkan.net/\" target=\"_blank\">http://kobe-ijinkan.net/</a></p>\r\n</div>\r\n<div class=\"kiji2\" id=\"138\"><!-- -->\r\n<p><img src=\"/upload/file/Image/Kanko/kazamidori.jpg\" alt=\"風見鶏の館\" width=\"900\" height=\"600\" /></p>\r\n<h4>風見鶏の館</h4>\r\n<p>明治時代にドイツ人貿易商ゴッドフリート・トーマス氏の自邸として建てられた、国の指定重要文化財。北野異人館のシンボルとして人々に愛されています。</p>\r\n<p><strong>住所</strong><br />\r\n兵庫県神戸市中央区北野町3丁目13-3</p>\r\n<p><strong>神戸北野ホテルからのアクセス</strong><br />\r\n北東に徒歩およそ10分</p>\r\n<p><strong>公式サイト</strong><br />\r\n<a href=\"https://www.kobe-kazamidori.com/kazamidori/\" target=\"_blank\">https://www.kobe-kazamidori.com/kazamidori/</a></p>\r\n</div>\r\n<div class=\"kiji2\" id=\"139\"><!-- -->\r\n<p><img src=\"/upload/file/Image/Kanko/moegi.jpg\" alt=\"萌黄の館\" width=\"900\" height=\"600\" /></p>\r\n<h4>萌黄の館</h4>\r\n<p>明治36年(1903)にアメリカ総領事の邸宅として建築された、木造2階建て、下見板張りの異人館。国の重要文化財に指定されています。</p>\r\n<p><strong>住所</strong><br />\r\n兵庫県神戸市中央区北野町３&minus;１０&minus;１１</p>\r\n<p><strong>神戸北野ホテルからのアクセス</strong><br />\r\n北東に徒歩およそ11分</p>\r\n<p><strong>公式サイト</strong><br />\r\n<a href=\"https://www.kobeijinkan.com/ijinkan_list/moegi\" target=\"_blank\">https://www.kobeijinkan.com/ijinkan_list/moegi</a></p>\r\n</div>\r\n<div class=\"kiji2\" id=\"140\"><!-- -->\r\n<p><img src=\"/upload/file/Image/Kanko/england.jpg\" alt=\"英国館\" width=\"900\" height=\"600\" /></p>\r\n<h4>英国館</h4>\r\n<p>英国人技師の設計による美しいバルコニーを持つコロニアル様式が、当時のまま保存されています。館内にあるホームズの衣装を身に着けて散策が可能です。</p>\r\n<p><strong>住所</strong><br />\r\n兵庫県神戸市中央区北野町２丁目３&minus;１６</p>\r\n<p><strong>神戸北野ホテルからのアクセス</strong><br />\r\n北東に徒歩およそ11分</p>\r\n<p><strong>公式サイト</strong><br />\r\n<a href=\"http://kobe-ijinkan.net/england/\" target=\"_blank\">http://kobe-ijinkan.net/england/</a></p>\r\n</div>\r\n<div class=\"kiji2\" id=\"141\"><!-- -->\r\n<p><img src=\"/upload/file/Image/Kanko/kitanokoubou.jpg\" alt=\"北野工房のまち\" width=\"900\" height=\"600\" /></p>\r\n<h4>北野工房のまち</h4>\r\n<p>トアロードに面して建つ「旧北野小学校」の校舎を活用した人気スポット。スイーツや神戸牛・コロッケ、日本酒などの購入やクラフト体験を楽しめます。</p>\r\n<p><strong>住所</strong><br />\r\n兵庫県神戸市中央区中山手通３丁目１７&minus;１</p>\r\n<p><strong>神戸北野ホテルからのアクセス</strong><br />\r\n南へ徒歩およそ3分</p>\r\n<p><strong>公式サイト</strong><br />\r\n<a href=\"http://kitanokoubou.jp/\" target=\"_blank\">http://kitanokoubou.jp/</a></p>\r\n</div>\r\n<div class=\"kiji2\" id=\"142\"><!-- -->\r\n<p><img src=\"/upload/file/Image/Kanko/kitano-tenmanshrine.jpg\" alt=\"北野天満神社\" width=\"900\" height=\"600\" /></p>\r\n<h4>北野天満神社</h4>\r\n<p>北野坂を登りきると見えてくる石造りの鳥居がシンボルの1180年に平清盛が設建し北野の地名の発祥となった神社です。</p>\r\n<p><strong>住所</strong><br />\r\n兵庫県神戸市中央区北野町３丁目１２&minus;１</p>\r\n<p><strong>神戸北野ホテルからのアクセス</strong><br />\r\n北東に徒歩およそ14分</p>\r\n<p><strong>公式サイト</strong><br />\r\n<a href=\"http://www.kobe-kitano.net/\" target=\"_blank\">http://www.kobe-kitano.net/</a><br />\r\n&nbsp;</p>\r\n</div>\r\n<div class=\"kiji2\" id=\"143\"><!-- -->\r\n<p><img src=\"/upload/file/Image/Kanko/nankinmachi.jpg\" alt=\"神戸南京町\" width=\"900\" height=\"600\" /></p>\r\n<h4>神戸南京町</h4>\r\n<p>日本三大チャイナタウンの一つに数えられる南京町。中華料理や雑貨などのお店が多数あり、観光や食べ歩きを楽しむことができます。</p>\r\n<p><strong>住所</strong><br />\r\n兵庫県神戸市中央区栄町通１丁目３&minus;１８</p>\r\n<p><strong>神戸北野ホテルからのアクセス</strong><br />\r\n南西に徒歩およそ15分</p>\r\n<p><strong>公式サイト</strong><br />\r\n<a href=\"http:// https://www.nankinmachi.or.jp/\" target=\"_blank\"> https://www.nankinmachi.or.jp/</a></p>\r\n</div>\r\n<div class=\"kiji2\" id=\"144\"><!-- -->\r\n<p><img src=\"/upload/file/Image/Kanko/meriken-park.jpg\" alt=\"メリケンパーク\" width=\"900\" height=\"600\" /></p>\r\n<h4>メリケンパーク</h4>\r\n<p>神戸ポートタワーや海洋博物館などの観光施設があり、爽やかな潮風を感じることが出来る広々とした海際公園です。</p>\r\n<p><strong>住所</strong><br />\r\n兵庫県神戸市中央区波止場町２&minus;２</p>\r\n<p><strong>神戸北野ホテルからのアクセス</strong><br />\r\n南西に徒歩およそ20分</p>\r\n<p><strong>公式サイト</strong><br />\r\n<a href=\"http://www.kobe-meriken.or.jp/\" target=\"_blank\">http://www.kobe-meriken.or.jp/</a></p>\r\n</div>\r\n<div class=\"kiji2\" id=\"145\"><!-- -->\r\n<p><img src=\"/upload/file/Image/Kanko/harborland.jpg\" alt=\"神戸ハーバーランド\" width=\"900\" height=\"600\" /></p>\r\n<h4>神戸ハーバーランド</h4>\r\n<p>グルメやショッピング、アミューズメントスペースなどの複合施設が充実しています。お子様から大人まで楽しめるスポットです。</p>\r\n<p><strong>住所</strong><br />\r\n兵庫県神戸市中央区東川崎町１丁目３</p>\r\n<p><strong>神戸北野ホテルからのアクセス</strong><br />\r\nJR（元町駅～神戸駅）を利用しおよそ25分</p>\r\n<p><strong>公式サイト</strong><br />\r\n<a href=\"http://www.harborland.co.jp/\" target=\"_blank\">http://www.harborland.co.jp/</a></p>\r\n</div>\r\n<div class=\"kiji2\" id=\"146\"><!-- -->\r\n<p><img src=\"/upload/file/Image/Kanko/kyoryuchi.jpg\" alt=\"旧居留地\" width=\"900\" height=\"600\" /></p>\r\n<h4>旧居留地</h4>\r\n<p>明治時代に外国人居留地として栄えた街並みを継承した異国情緒あふれる近代洋風建築が立ち並びます。</p>\r\n<p><strong>住所</strong><br />\r\n兵庫県神戸市中央区明石町４０</p>\r\n<p><strong>神戸北野ホテルからのアクセス</strong><br />\r\n南に徒歩およそ15分</p>\r\n<p><strong>公式サイト</strong><br />\r\n<a href=\"https://www.kobe-kyoryuchi.com/\" target=\"_blank\">https://www.kobe-kyoryuchi.com/</a></p>\r\n</div>\r\n<div class=\"kiji2\" id=\"147\"><!-- -->\r\n<p><img src=\"/upload/file/Image/Kanko/ikuta-shrine.jpg\" alt=\"生田神社\" width=\"900\" height=\"600\" /></p>\r\n<h4>生田神社</h4>\r\n<p>1800年以上の歴史を有し、神戸中心市街地に位置する古社。生田の神を守る家、神戸(かんべ)は神戸の地名由来となっています。</p>\r\n<p><strong>住所</strong><br />\r\n兵庫県神戸市中央区下山手通１丁目２&minus;１</p>\r\n<p><strong>神戸北野ホテルからのアクセス</strong><br />\r\n南東に徒歩およそ6分</p>\r\n<p><strong>公式サイト</strong><br />\r\n<a href=\"https://ikutajinja.or.jp/\" target=\"_blank\">https://ikutajinja.or.jp/</a></p>\r\n</div>\r\n<div class=\"kiji2\" id=\"148\"><!-- -->\r\n<p><img src=\"/upload/file/Image/Kanko/herb-park.jpg\" alt=\"神戸布引ハーブ園／ロープウェイ\" width=\"900\" height=\"600\" /></p>\r\n<h4>神戸布引ハーブ園／ロープウェイ</h4>\r\n<p>ロープウェイでハーブ園山頂まで約10分。全ゴンドラバリアフリー、広い窓からは神戸の街並みが一望できます。</p>\r\n<p><strong>住所</strong><br />\r\n兵庫県神戸市中央区北野町１&minus;４&minus;３</p>\r\n<p><strong>神戸北野ホテルからのアクセス</strong><br />\r\nハーブ園山麓駅まで北東に徒歩およそ20分、ハーブ園山麓駅よりロープウェイでおよそ10分</p>\r\n<p><strong>公式サイト</strong><br />\r\n<a href=\"http://www.kobeherb.com/\" target=\"_blank\">http://www.kobeherb.com/</a></p>\r\n</div>\r\n<div class=\"kiji2\" id=\"149\"><!-- -->\r\n<p><img src=\"/upload/file/Image/Kanko/nunobiki-falls.jpg\" alt=\"布引の滝\" width=\"900\" height=\"600\" /></p>\r\n<h4>布引の滝</h4>\r\n<p>「日本の滝百選」にも選ばれた滝です。「布引の滝」は雄滝・雌滝・夫婦滝・鼓ヶ滝の4つの滝の総称で、なかでも雄滝は高さ43mの名瀑です</p>\r\n<p><strong>住所</strong><br />\r\n兵庫県神戸市中央区葺合町布引遊園地４５</p>\r\n<p><strong>神戸北野ホテルからのアクセス</strong><br />\r\n新神戸駅まで北東に徒歩およそ20分、新神戸駅より北へ登り20分程度</p>\r\n</div>\r\n<div class=\"kiji2\" id=\"150\"><!-- -->\r\n<p><img src=\"/upload/file/Image/Kanko/kikuseidai.jpg\" alt=\"摩耶山掬星台\" width=\"900\" height=\"600\" /></p>\r\n<h4>摩耶山掬星台</h4>\r\n<p>掬星台からの夜景は日本三大夜景に選ばれるほど素晴らしい眺めです。日の出から日の入りまで見渡すことができる地形は日本においても有数のものです。</p>\r\n<p><strong>住所</strong><br />\r\n兵庫県神戸市灘区摩耶山町２&minus;２</p>\r\n<p><strong>神戸北野ホテルからのアクセス</strong><br />\r\nJR元町駅よりJR灘駅下車、坂バスを利用しおよそ15分で摩耶ケーブル下にて下車。ロープウェイを利用し掬星台へ。</p>\r\n<p><strong>公式サイト</strong><br />\r\n<a href=\"https://www.feel-kobe.jp/kobe-yakei/area/mountain/03/\" target=\"_blank\">https://www.feel-kobe.jp/kobe-yakei/area/mountain/03/</a></p>\r\n</div>\r\n<div class=\"kiji2\" id=\"151\"><!-- -->\r\n<p><img src=\"/upload/file/Image/Kanko/arima-onsen.jpg\" alt=\"有馬温泉\" width=\"900\" height=\"600\" /></p>\r\n<h4>有馬温泉</h4>\r\n<p>日帰り湯もあり、神社・仏閣や風情ある温泉街などの日本文化も満喫できます。太閤ゆかりの地や四季折々の景観、土地ならではの食物なども楽しめます。</p>\r\n<p><strong>住所</strong><br />\r\n兵庫県神戸市北区有馬町</p>\r\n<p><strong>神戸北野ホテルからのアクセス</strong><br />\r\n地下鉄三宮駅より谷上駅にて神戸電鉄有馬線に乗り換え、およそ1時間程度の道程。</p>\r\n<p><strong>公式サイト</strong><br />\r\n<a href=\"http://www.arima-onsen.com/\" target=\"_blank\">http://www.arima-onsen.com/</a></p>\r\n</div>\r\n<style type=\"text/css\">\r\n#mainTitle{\r\n  background-image: url(/images/main_stay_kanko.jpg);\r\n}\r\n#area1 {\r\n  display: flex;\r\n  max-width: 1100px;\r\n  padding: 50px 10px;\r\n  margin: auto;\r\n  flex-wrap: wrap;\r\n}\r\n#area1 .kiji2 {\r\n  font-size: 0.8rem;\r\n  line-height: 1.3rem;\r\n  width: 32%;\r\n  margin-right: 2%;\r\n  margin-bottom: 2%;\r\n  padding: 15px;\r\n  background-color: #efefef;\r\n}\r\n\r\n/*-----SP用------*/\r\n@media screen and (max-width: 428px) {\r\n#area1 {\r\n    display: flex;\r\n    padding: 15px !important;\r\n    margin: auto;\r\n    flex-wrap: wrap;\r\n    flex-direction: column;\r\n  }\r\n  #area1 .kiji2 {\r\n    font-size: 0.8rem;\r\n    line-height: 1.3rem;\r\n    width: 100% !important;\r\n    margin-right: 0 !important;\r\n    margin-bottom: 15px !important;\r\n    padding: 15px;\r\n    background-color: #efefef;\r\n  }\r\n}\r\n</style></div>\r\n<!-- end 擬似area1 -->\n\n</div>\n\n\t\t\t\t\n\t\t\t\t<div id=\"areaCenter\" class=\"clx\">\t\t\t\t\t\t\t<!--通常記事3-->\n\n<div class=\"kiji3\" id=\"\">\n\n\n</div>\n\n\t\t\t\t\t\t\t<div class=\"subMenu\">\n    <ul class=\"subMenuList\">\n        <li><a href=\"?men=4\" class=\"title\">宿泊</a></li>\n        <li><a  href=\"?men=4&cat=11\">世界一の朝食</a></li>\n        <li><a  href=\"?men=4&cat=9\">プラン</a></li>\n        <li><a  href=\"?men=4&cat=10\">過ごし方</a></li>\n        <li><a  href=\"?men=4&cat=8\">客室</a></li>\n        <li><a  href=\"?men=4&cat=12\">施設・サービス</a></li>\n        <li><a  id=\"submenuOn\"  href=\"?men=4&cat=13\">観光案内</a></li>\n    </ul>\n</div>\t\t\t\t\t\t</div>\n\t\t<!--中ここまで-->\n\t\t\t\t\t\t\t\t\t\t\t\t\t</main>\n\n\t\t<div id=\"areaFoot\" class=\"clx\">\t\t\t\t\t\n<div class=\"exLink-container\">\n<h3>山口シェフのエスプリ</h3>\n<div class=\"inner\">\n<ul class=\"exLink\">\n    <li><a href=\"?men=2&cat=1\">山口浩シェフの取組・活動</a></li>\n    <li><a href=\"?men=2&cat=2\">SDGs</a></li>\n    <li><a href=\"?men=2&cat=1#330\">リスペクトパーソン</a></li>\n    <li><a hre