anager -->\r\n\r\n</head>\r\n\r\n<body>\r\n    <!-- Google Tag Manager (noscript) -->\r\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-PZFRMBD\"\r\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\r\n<!-- End Google Tag Manager (noscript) -->\r\n\r\n    <!-- =================================================== -->\r\n\r\n    <div class=\"wrap\" id=\"pagetop\">\r\n        <header>\r\n            <div class=\"headLogo\">\r\n                <div class=\"logo\"><a href=\"../index.html\"><img src=\"../assets/img/common/logo.png\" alt=\"日本紙通商株式会社\"></a></div>\r\n                <p class=\"text\">RECRUIT</p>\r\n            </div>\r\n            <div class=\"humburgerBtn\">\r\n                <span class=\"top\"></span>\r\n                <span class=\"middle\"></span>\r\n                <span class=\"bottom\"></span>\r\n            </div>\r\n            <div class=\"headMenu\">\r\n                <nav>\r\n                    <ul class=\"navList\">\r\n                        <li class=\"item -parent\">\r\n                            <a href=\"../about\"><span>日本紙通商について</span></a>\r\n                            <span class=\"accordionBtn\"></span>\r\n                            <ul class=\"child\">\r\n                                <li class=\"item\"><a href=\"../about/message.html\">メッセージ</a></li>\r\n                                <li class=\"item\"><a href=\"../about/introduction.html\">事業紹介</a></li>\r\n                                <li class=\"item\"><a href=\"../about/company_profile.html\">会社概要</a></li>\r\n                            </ul>\r\n                        </li>\r\n                        <li class=\"item\">\r\n                            <a href=\"../interview\"><span>インタビュー</span></a>\r\n                        </li>\r\n                        <li class=\"item\"><a href=\"../career_plan\"><span>キャリアプラン</span></a></li>\r\n                        <li class=\"item -sp\"><a href=\"../access\"><span>アクセスマップ</span></a></li>\r\n                        <li class=\"item -sp\"><a href=\"../gallery\"><span>社内風景</span></a></li>\r\n                        <li class=\"item\"><a href=\"../faq\"><span>FAQ</span></a></li>\r\n                        <li class=\"item\"><a href=\"../guideline\"><span>募集要項</span></a></li>\r\n                        <li class=\"item -entry\"><a href=\"https://job.mynavi.jp/24/pc/search/corp235178/outline.html\" target=\"_blank\"><span>ENTRY</span></a></li>\r\n                    </ul>\r\n                </nav>\r\n            </div>\r\n        </header>\r\n\r\n        <div class=\"lContainer -sub\">\r\n            <!-- InstanceBeginEditable name=\"container\" -->\r\n            <div class=\"secContainer -faq -white\">\r\n                <div class=\"pageLabel\">\r\n                    <div class=\"inner\">\r\n                        <h1 class=\"labelMain\">\r\n                            <span class=\"main\"><img src=\"../assets/img/faq/ttl-faq.png\" alt=\"faq\"></span>\r\n                            <sub class=\"labelSub -white\">よくある質問</sub>\r\n                        </h1>\r\n                    </div>\r\n                </div>\r\n\r\n                <div class=\"mainWrap\">\r\n                    <div class=\"inner\">\r\n                        <div class=\"faq-inner\">\r\n                            <h2 class=\"faq-ttl\">採用選考について</h2>\r\n                            <dl>\r\n                                <dt>『応募するにはどのようにすればよいですか？』</dt>\r\n                                <dd>マイナビよりエントリーを受付けておりますので、まずはマイナビよりご応募いただけますようお願い申し上げます。</dd>\r\n                                <dt>『学部・学科の制限はありますか？』</dt>\r\n                                <dd>全学部・全学科対象です。文理不問です。</dd>\r\n                                <dt>『必要な資格はありますか？』</dt>\r\n                                <dd>特にありません。ご自身の興味のあるもの、スキルアップに必要だと感じるものがあれば、積極的に学んでいただきたいと思います。</dd>\r\n                                <dt>『語学力はどの程度必要ですか？』</dt>\r\n                                <dd>事業領域の国際化に伴い、語学力は身につけていただきたいスキルです。しかし言語はあくまでもコミュニケーションの「ツール」です。それ以前に高めるべき能力は基本的なコミュニケーションスキルだと考えます。語学力はひとつのアピールポイントになり得ます。入社後、社内の英語研修制度で語学力を高める社員も多くいます。</dd>\r\n                                <dt>『外国籍でも応募できますか？』</dt>\r\n                                <dd>国籍について制限は設けておりません。多様な国籍の方に活躍していただいていますが、原則としてビジネスレベルの日本語能力が必要です。</dd>\r\n                            </dl>\r\n                            <h2 class=\"faq-ttl\">入社後について</h2>\r\n                            <dl>\r\n                                <dt>『入社後の配属はどのように決まりますか？』</dt>\r\n                                <dd>人員計画や適性等を考慮し配属を決定します。<br>また、当社では自己申告制度を導入していますので、その後のローテーションについても、極力、本人の希望を取り入れる体制をとっています。</dd>\r\n                                <dt>『転勤はありますか？』</dt>\r\n                                <dd>東京本社以外にも国内支社、営業所、海外事務所での勤務の可能性がございます。</dd>\r\n                                <dt>『海外の研修制度はありますか？』</dt>\r\n                                <dd>当社では、中国語の習得と現地の習慣などの知見を深め国際的視野を持った人材育成のため、社内公募により、語学留学制度（中国語）を実施しています。</dd>\r\n                                <dt>『女性が働きやすい環境は整っていますか？』</dt>\r\n                                <dd>産前産後休暇、育児休暇、短時間勤務、時差勤務など、女性としてキャリアを重ねる上で必要な制度を整えています。</dd>\r\n                                <dt>『部活動やサークルはありますか？』</dt>\r\n                                <dd>野球、テニス、サッカー、釣り、華道があり、積極的に活動しています。テニス部は実業団テニス部もあり日本リーグに出場するなど活躍しています。</dd>\r\n                            </dl>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n\r\n            </div>\r\n            <!-- InstanceEndEditable -->\r\n        </div>\r\n\r\n        <div class=\"linkArea\">\r\n            <div class=\"inner\">\r\n                <div class=\"siteLink\">\r\n                    <ul class=\"linkList\">\r\n                        <li class=\"item\">\r\n                            <a href=\"../guideline\">\r\n                                <div class=\"thumb\"><img src=\"../assets/img/common/bottomMenu-guideline.jpg\" alt=\"募集要項\"></div>\r\n                                <div class=\"textarea\">\r\n                   