n        <img src=\"/dealer/dairi/assets/img/recruit/main_img.jpg\" alt=\"住み慣れた街で、ずっと暮らす。スズキで、ずっと働く。\" class=\"mv_mb\">\n        <ul class=\"menu_list\">\n          <li>\n            <a href=\"/dealer/sj-saitama/recruit/graduate-guideline/\" class=\"js_matchHeight\">\n              <span>\n                <i class=\"m_icon01\"></i>【新卒採用】<br>募集要項</span>\n            </a>\n          </li>\n          <li>\n            <a href=\"/dealer/sj-saitama/recruit/career-guideline/\" class=\"js_matchHeight\">\n              <span>\n                <i class=\"m_icon02\"></i>【中途採用】<br>募集要項</span>\n            </a>\n          </li>\n          <li>\n            <a href=\"/dealer/sj-saitama/recruit/workplace_information/\" class=\"js_matchHeight\">\n              <span>\n                <i class=\"m_icon08\"></i>職場情報</span>\n            </a>\n          </li>\n          <li>\n            <a href=\"/dealer/sj-saitama/recruit/briefing/\" class=\"js_matchHeight\">\n              <span>\n                <i class=\"m_icon03\"></i>説明会情報</span>\n            </a>\n          </li>\n          <li>\n            <a href=\"/dealer/sj-saitama/recruit/message/\" class=\"js_matchHeight\">\n              <span>\n                <i class=\"m_icon04\"></i>みなさんへの<br>メッセージ</span>\n            </a>\n          </li>\n          <li>\n            <a href=\"/dealer/sj-saitama/recruit/workplace/\" class=\"js_matchHeight\">\n              <span>\n                <i class=\"m_icon05\"></i>職場紹介</span>\n            </a>\n          </li>\n          <li>\n            <a href=\"/dealer/sj-saitama/recruit/shop/\" class=\"js_matchHeight\">\n              <span>\n                <i class=\"m_icon06\"></i>拠点紹介</span>\n            </a>\n          </li>\n          <li>\n            <a href=\"/dealer/sj-saitama/recruit/topic/\" class=\"js_matchHeight\">\n              <span>\n                <i class=\"m_icon07\"></i>採用トピックス</span>\n            </a>\n          </li>\n        </ul>\n      </div>\n\n      <div class=\"ly_body ly_body__mainContents ly_bgWhite hp_mb30 cf\">\n        <section class=\"bl_sect01\">\n          <h4 class=\"el_sectTtl el_sectTtl__lv4 bl_B08_block_title\">アクセス / お問い合わせ</h4>\n          <div class=\"ly_content_col6\">\n            <table class=\"bl_table__std\">\n              <tbody>\n                <tr>\n                  <th class=\"bl_table__std_hd__mid\">所在地</th>\n                  <td>〒331-0811　埼玉県さいたま市北区吉野町2-222-10\n                    <br />\n                     TEL / FAX：\n                    <span class=\"js_telNumber\">048-663-5911</span> / 048-651-6524                  </td>\n                </tr>\n                                    <tr>\n                        <th class=\"bl_table__std_hd__mid\">アクセス</th>\n                                                <td>【電車でご来社の方】<br />\r\n最寄り駅はJR高崎線宮原駅もしくは上尾駅です。<br />\r\n宮原駅東口より、東武バス　上尾駅東口行き<br />\r\nまたは<br />\r\n上尾駅東口より、東武バス　大宮駅東口行き<br />\r\n「馬喰新田」下車　700m　徒歩10分</td>\n                    </tr>\n                                              </tbody>\n            </table>\n          </div>\n          <div class=\"ly_content_col6 pc\">\n            <iframe src=\"https://www.google.com/maps?q=埼玉県さいたま市北区吉野町2-222-10&output=embed&language=jp\"\n              width=\"100%\" height=\"265\" frameborder=\"0\" style=\"border:0\" allowfullscreen></iframe>\n            <p class=\"bl_T04_right\">\n              <a href=\"https://www.google.co.jp/maps/search/?q=埼玉県さいたま市北区吉野町2-222-10\" target=\"_blank\" class=\"el_icon el_icon__blank hp_fzss hp_fwb hp_colorBlue\">大きな地図で見る</a>\n            </p>\n          </div>\n          <div class=\"sp hp_mt30\">\n            <ul class=\"bl_B03 cf\">\n              <li>\n                <a href=\"https://www.google.co.jp/maps/search/?api=1&query=埼玉県さいたま市北区吉野町2-222-10\" target=\"_blank\" class=\"el_btn el_btn__bw el_btn__l el_btn__arrow\">地図表示</a>\n              </li>\n            </ul>\n          </div>\n        </section>\n      </div>\n\n      <div class=\"ly_body ly_body__mainContents ly_bgWhite hp_mb30 cf\">\n        <section class=\"bl_sect02 bl_accessRanking bl_focalBlock\">\n          <h5 class=\"el_sectTtl el_sectTtl__lv5\">採用トピックス\n            <span class=\"more_link\">\n              <a href=\"/dealer/sj-saitama/recruit/topic/\" class=\"el_icon el_icon__arrow hp_fzss hp_fwb\">すべてを見る</a>\n            </span>\n          </h5>\n          <div class=\"cf\">\n            <ol class=\"bl_accessRanking_list cf\">\n                                        <li class=\"bl_focalBlock_list js_matchHeight recruit_topics hp_mr0\">\n                              <a href=\"/dealer/sj-saitama/recruit/topic/?id=46862\">\n                                  <figure class=\"bl_centerThumb jsArtImg\"><img src=\"/dealer/sj-admin/sharefiles/image4_4bd937ce-661c-11f1-b316-fa163e38a592_s.jpg\" alt=\"サービス新入社員入門研修\"></figure>\n                                  <div class=\"bl_focalBlock_list_info\">\n                    <p class=\"bl_focalBlock_list_meta\"><span class=\"el_label jsCatName\" style=background-color:#0099CA;>採用教育活動</span><span class=\"bl_focalBlock_list_meta_date\">2026.06.12</span></p>\n                    <p class=\"bl_focalBlock_list_shop jsRecTitle\">サービス新入社員入門研修</p>\n                    <p class=\"bl_focalBlock_list_title jsRecContent\"></p>\n                  </div>\n                </a>\n                <div class=\"jsTmpRecContent\" style='display:none'><p style=\"text-align: center;\">みなさんこんにちわ！<img src=\"/dealer/sj-admin/asset/js/tinymce/plugins/emoticons/img/128.png\" alt=\"128\" width=\"32\" height=\"32\" name=\"emoticons\" /></p>\r\n<p style=\"text-align: center;\">スズキ自販埼玉　採用担当です。</p>\r\n<p style=\"text-align: center;\">&nbsp;</p>\r\n<p style=\"text-align: center;\">先日、サービス職　<span style=\"color: #ff0000;\"><strong>新入社員入門研修</strong></span>を行いました！</p>\r\n<p style=\"text-align: center;\"><img src=\"/dealer/sj-admin/sharefiles/image4_4bd937ce-661c-11f1-b316-fa163e38a592.jpeg\" alt=\"\" width=\"400\" height=\"300\" /></p>\r\n<p style=\"text-align: center;\">整備業務の基礎の知識や安全作業の重要性について学びました。</p>\r\n<p style=\"text-align: center;\">講師は各拠点の工場長が担当し、それぞれの経験を交えながら</p>\r\n<p style=\"text-align: center;\">わかりやすく、説明してくださいました<img src=\"/dealer/sj-admin/asset/js/tinymce/plugins/emoticons/img/03.png\" alt=\"03\" width=\"32\" height=\"32\" name=\"emoticons\" /><img src=\"/dealer/sj-admin/asset/js/tinymce/plugins/emoticons/img/178.png\" alt=\"178\" width=\"32\" height=\"32\" name=\"emoticons\" /></p>\r\n<p style=\"text-align: center;\">&nbsp;</p>\r\n<p style=\"text-align: center;\"><img src=\"/dealer/sj-admin/sharefiles/image3_08864782-661c-11f1-bde7-fa163e38a592.jpeg\" alt=\"\" width=\"350\" height=\"467\" /><img src=\"/dealer/sj-admin/sharefiles/image1 (1)_e3bf7aa2-66bd-11f1-a0b7-fa163e38a592.jpeg\" alt=\"\" width=\"350\" height=\"467\" /></p>\r\n<p style=\"text-align: center;\">さまざまな拠点の工場長との交流を通じて</p>\r\n<p style=\"text-align: center;\">幅広い知識や考え方に触れる貴重な</p>\r\n<p style=\"text-align: center;\">機会になりました！！！<img src=\"/dealer/sj-admin/asset/js/tinymce/plugins/emoticons/img/29.png\" alt=\"29\" width=\"32\" height=\"32\" name=\"emoticons\" /></p>\r\n<p style=\"text-align: center;\">&nbsp;</p>\r\n<p style=\"text-align: center;\">スズキ自販埼玉では、入社後もしっかり研修を行いサポート</p>\r\n<p style=\"text-align: center;\">していきますのでご安心ください<img src=\"/dealer/sj-admin/asset/js/tinymce/plugins/emoticons/img/07.png\" alt=\"07\" width=\"32\" height=\"32\" name=\"emoticons\" /><img src=\"/dealer/sj-admin/asset/js/tinymce/plugins/emoticons/img/07.png\" alt=\"07\" width=\"32\" height=\"32\" name=\"emoticons\" /><img src=\"/dealer/sj-admin/asset/js/tinymce/plugins/emoticons/img/198.png\" alt=\"198\" width=\"32\" height=\"32\" name=\"emoticons\" /></p>\r\n<p style=\"text-align: center;\">&nbsp;</p>\r\n<p style=\"text-align: center;\">最後に、新入社員・工場長</p>\r\n<p style=\"text-align: center;\">１日お疲れ様でした！！</p>\r\n<p style=\"text-align: center;\">ありがとうございました<img src=\"/dealer/sj-admin/asset/js/tinymce/plugins/emoticons/img/96.png\" alt=\"96\" width=\"32\" height=\"32\" name=\"emoticons\" /></p>\r\n<p style=\"text-align: center;\"><img src=\"/dealer/sj-admin/sharefiles/IMG_0553_724ef9ea-661f-11f1-a89b-fa163e38a592.jpg\" alt=\"\" width=\"600\" height=\"450\" /></p>\r\n<p style=\"text-align: center;\">&nbsp;</p>\r\n<p style=\"text-align: center;\">&nbsp;</p>\r\n<p style=\"text-align: center;\">&nbsp;</p></div>\n              </li>\n                                        <li class=\"bl_focalBlock_list js_matchHeight recruit_topics hp_mr0\">\n                              <a href=\"/dealer/sj-saitama/recruit/topic/?id=46515\">\n                                  <figure class=\"bl_centerThumb jsArtImg\"><img src=\"/dealer/sj-admin/sharefiles/IMG_2577_db04b016-58cc-11f1-b0d7-fa163e794ba5_s.jpg\" alt=\"マイナビ【インターンシップ＆キャリア発見フェア】に参加してきました！\"></figure>\n                                  <div class=\"bl_focalBlock_list_info\">\n                    <p class=\"bl_focalBlock_list_meta\"><span class=\"el_label jsCatName\" style=background-color:#0099CA;>採用教育活動</span><span class=\"bl_focalBlock_list_meta_date\">2026.05.28</span></p>\n                    <p class=\"bl_focalBlock_list_shop jsRecTitle\">マイナビ【インターンシップ＆キャリア発見フェア】に参加してきました！</p>\n                    <p class=\"bl_focalBlock_list_title jsRecContent\"></p>\n                  </div>\n                </a>\n                <div class=\"jsTmpRecContent\" style='display:none'><p style=\"text-align: center;\">&nbsp;</p>\r\n<p style=\"text-align: center;\">こんにちわ<img src=\"/dealer/sj-admin/asset/js/tinymce/plugins/emoticons/img/198.png\" alt=\"198\" width=\"32\" height=\"32\" name=\"emoticons\" /></p>\r\n<p style=\"text-align: center;\">スズキ自販埼玉の採用担当です<img src=\"/dealer/sj-admin/asset/js/tinymce/plugins/emoticons/img/84.png\" alt=\"84\" width=\"32\" height=\"32\" name=\"emoticons\" /></p>\r\n<p style=\"text-align: center;\">&nbsp;</p>\r\n<p style=\"text-align: center;\"><strong><span style=\"font-size: 14pt;\">5月23日（土）</span></strong></p>\r\n<p style=\"text-align: center;\"><strong><span style=\"font-size: 14p