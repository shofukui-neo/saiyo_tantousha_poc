{"url":"https://suntaxi.com/","html":"<!DOCTYPE html>\n<html xml:lang=\"ja\" lang=\"ja\">\n<head>\n<!-- Google tag (gtag.js) -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-8L99XZ0PR6\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'G-8L99XZ0PR6');\n</script>\n<meta charset=\"utf-8\">\n<title>サンタクシー | 横浜市内の観光、子育てサポートはお任せください</title>\n<meta name=\"description\" content=\"横浜市のサンタクシーは、観光、子育てサポートサービスを充実させ、神奈川県横浜市の街とともに発展を続けるタクシー会社です。\" />\n<meta name=\"keywords\" content=\"横浜,タクシー,観光,子育て支援,神奈川県\" />\n<link rel=\"shortcut icon\" href=\"images/common/favicon.ico\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1, maximum-scale=1\" />\n<meta name=\"format-detection\" content=\"telephone=no\">\n<link href=\"./style/base.css\" rel=\"stylesheet\" type=\"text/css\" media=\"all\" />\n<link href=\"./style/gheader.css\" rel=\"stylesheet\" type=\"text/css\" media=\"all\" />\n<link href=\"./style/top.css\" rel=\"stylesheet\" type=\"text/css\" media=\"all\" />\n<link href=\"./style/lightbox.css\" rel=\"stylesheet\" type=\"text/css\" media=\"all\" />\n<link href=\"https://use.fontawesome.com/releases/v5.5.0/css/all.css\" rel=\"stylesheet\">\n<script src=\"https://ajax.googleapis.com/ajax/libs/jquery/3.3.1/jquery.min.js\"></script>\n<script src=\"./js/common.js\"></script>\n<script src=\"./js/gnavfunc.js\"></script>\n<script src=\"./js/tpfunc.js\"></script>\n</head>\n\n<body>\n    <div id=\"header\">\n        <div class=\"contaider\">\n            <div id=\"mobile-head\">\n                <h1 id=\"logo\"><a href=\"./index.html\" title=\"神奈川県横浜市のサンタクシー\"><img src=\"./images/common/logo.png\" alt=\"神奈川県横浜市のサンタクシー\" /></a></h1>\n            </div>\n            <nav class=\"gNav\" role=\"navigation\" aria-label=\"メインメニュー\">\n            <p class=\"gnavbtn\"><a href=\"javascript:void(0)\"><span>メニューを開く</span></a></p>\n            <u