</div>\n                            <div class=\"col\">\n                                <div class=\"box\">\n                                    <div class=\"parent\"><a href=\"../about/\"><p class=\"en\">ABOUT</p><p class=\"ja\">日本パーカライジングについて</p></a></div>\n                                    <ul>\n                                        <li class=\"child\"><a href=\"https://www.parker.co.jp/corporate/profile/outline\" target=\"_blank\">- 企業情報</a></li>\n                                        <li class=\"child\"><a href=\"../about/strategy.html\">- 特長と戦略</a></li>\n                                        <li class=\"child\"><a href=\"../about/future.html\">- 未来</a></li>\n                                        <li class=\"child\"><a href=\"../about/action.html\">- 取り組み</a></li>\n                                        <li class=\"child\"><a href=\"../about/number.html\">- 数字でわかる日本パーカライジング</a></li>\n                                    </ul>\n                                </div>\n                                <div class=\"box\">\n                                    <div class=\"parent\"><a href=\"../services/\"><p class=\"en\">SERVICES</p><p class=\"ja\">事業紹介</p></a></div>\n                                </div>\n                                <div class=\"box\">\n                                    <div class=\"parent\"><a href=\"../job/\"><p class=\"en\">JOB CATEGORY</p><p class=\"ja\">職種紹介</p></a></div>\n                                </div>\n                            </div>\n                            <div class=\"col\">\n                                <div class=\"box\">\n                                    <div class=\"parent\"><a href=\"../people/\"><p class=\"en\">PEOPLE</p><p class=\"ja\">社員紹介</p></a></div>\n                                </div>\n                                <div class=\"box\">\n                                    <div class=\"parent\"><a href=\"../culture/\"><p class=\"en\">CULTURE</p><p class=\"ja\">キャリアと制度</p></a></div>\n                                    <ul>\n                                        <li class=\"child\"><a href=\"../culture/training.html\">- 教育制度</a></li>\n                                        <li class=\"child\"><a href=\"../culture/welfare.html\">- 福利厚生</a></li>\n                                        <li class=\"child\"><a href=\"../culture/voice.html\">- 産休・育休取得社員の声</a></li>\n                                    </ul>\n                                </div>\n                                <div class=\"box\">\n                                    <div class=\"parent\"><a href=\"../recruitment/\"><p class=\"en\">RECRUITMENT</p><p class=\"ja\">採用情報</p></a></div>\n                                    <ul>\n                                        <li class=\"child\"><a class=\"anchor-link\" href=\"../recruitment/#anchor04\">- Q&A</a></li>\n                                    </ul>\n                                </div>\n                            </div>\n                        </div>\n                        \n                    </div>\n                </div>\n            </div>\n\n            <div id=\"mv\">\n                <div class=\"bg\"></div>\n                <div class=\"h1\">\n                    <div class=\"ja\"><h1>教育制度</h1></div>\n                </div>\n            </div>\n\n\n\n            <main>\n                <article class=\"inner900\">\n                    <section id=\"culture--blocks\">\n                        <div class=\"block\">\n                            <div class=\"h2\">\n                                <h2>一人ひとりを大切に</h2>\n                                <p>\n                                    当社では、「人材」こそが企業にとってあらゆる経営資源に優先する財産（＝人財）と考え、<br class=\"pcshow\">「一人ひとりを大切に！」の思想のもと、「積極的な行動力と創造性を有した企業人を育成する」ために<br class=\"pcshow\">社員の育成・教育訓練に取り組んでいます。\n                                </p>\n                            </div>\n\n                            <div class=\"graph\">\n                                <h3>能力開発教育体系図</h3>\n                                <div class=\"ph\"><img class=\"fit\" src=\"../assets/img/culture/training_g_01.svg\"></div>\n                            </div>\n                        </div>\n\n\n                        <div class=\"block\">\n                            <div class=\"h2\">\n                                <h2>社員研修について</h2>\n                            </div>\n\n                            <div class=\"boxes\">\n                                <div class=\"box\">\n                                    <div class=\"flex\">\n                                        <div class=\"col\"><div class=\"ph\"><img class=\"fit\" src=\"../assets/img/culture/training_ph_01.jpg\"></div></div>\n                                        <div class=\"col\">\n                                            <div class=\"h3\"><h3>入社前 内定者研修会</h3></div>\n                                            <div class=\"txt\">\n                                                <p>\n                                                    教育は入社の前から始まります。来年から一緒に働く仲間はどんな人なのかという不安を解消します。\n                                                </p>\n                                            </div>\n                                        </div>\n                                    </div>\n                                </div>\n\n\n                                <div class=\"box\">\n                                    <div class=\"flex\">\n                                        <div class=\"col\"><div class=\"ph\"><img class=\"fit\" src=\"../assets/img/culture/training_ph_02.jpg\"></div></div>\n                                        <div class=\"col\">\n                                            <div class=\"h3\"><h3>実務研修</h3></div>\n                                            <div class=\"txt\">\n                                                <p>\n                                                    総合技術研究所・薬品製造工場・加工工場・営業所での業務体験：約１カ月\n                                                </p>\n                                            </div>\n                                        </div>\n                                    </div>\n                                </div>\n\n\n                                <div class=\"box\">\n                                    <div class=\"flex\">\n                                        <div class=\"col\"><div class=\"ph\"><img class=\"fit\" src=\"../assets/img/culture/training_ph_03.jpg\"></div></div>\n                                        <div class=\"col\">\n                                            <div class=\"h3\"><h3>中堅社員研修</h3></div>\n                                            <div class=\"txt\">\n                                                <p>\n                                                    新入社員からチームの主力として活躍できる人材になるために、必要なマインド、ビジネス知識等を身に着ける講義やグループワーク等の研修をとおし、社員の成長をサポートしています。\n                                                </p>\n                                            </div>\n                                        </div>\n                                    </div>\n                                </div>\n\n\n                                <div class=\"box\">\n                                    <div class=\"flex\">\n                                        <div class=\"col\"><div class=\"ph\"><img class=\"fit\" src=\"../assets/img/culture/training_ph_04.jpg\"></div></div>\n                                        <div class=\"col\">\n                                            <div class=\"h3\"><h3>OJT研修と<br>コーチング研修</h3></div>\n                                            <div class=\"txt\">\n                                                <p>\n                                                    新入社員で配属されたとき、OJTで業務を覚えていただきます。OJTは配属された部署に年齢の近い先輩社員がコーチャーとして業務を教えたり、相談に乗ったりしてくれます。入社時は誰もが不安を抱えていると思いますが、コーチャーと二人三脚で業務を覚え、成長していただきます。また、後輩ができたときは、ご自身がコーチャーとして活躍していただくことになります。その場合は、コーチング研修で新人指導育成に必要な考え方やポイントを学び、職場全体で後輩指導を推進していく重要性とコーチャーとしての関わり方を理解する研修を実施しているので安心して後輩の指導に当たることができます。\n                                                </p>\n                                            </div>\n                                        </div>\n                                    </div>\n                                </div>\n                            </div>\n                        </div>\n                    </section>\n                </article>\n            </main>\n\n\n\n            <div id=\"big-banner\">\n                <a href=\"../culture/welfare.html\">\n                    <div class=\"bg\"></div>\n                    <div class=\"inner900\">\n                        <div class=\"inside type--02 flex\">\n                            <div class=\"col\">\n                                <div class=\"ttl-set\">\n                                    <div class=\"en\"><p>CULTURE</p></div>\n                                    <div class=\"ja\"><p>キャリアと制度</p></div>\n                                </div>\n                                <div class=\"ttl\">\n                                    <p>\n                                        福利厚生\n                                    </p>\n                                </div>\n                            </div>\n                            <div class=\"col\">\n                                <p><span>NEXT</span> CONTENTS</p>\n                            </div>\n                        </div>\n                    </div>\n                </a>\n            </div>\n\n\n            <footer class=\"child bottom-banner culture training\">\n                <div class=\"upper\">\n                    <div class=\"logo\"><img src=\"../assets/img/common/footer_logo.png\" alt=\"日本パーカライジング株式会社\"></div>\n                </div>\n\n\n                <div class=\"lower\">\n                    <div class=\"copyright\"><p>Copyright ©2022 <br class=\"spshow\">Nihon Parkerizing Co.,Ltd. All rights reserved.</p></div>\n                </div>\n\n                <a id=\"pagetop\" href=\"#wrapper\" data-fade=\"0\"><img src=\"../assets/img/common/pagetop.png\" alt=\"PAGE TOP\"></a>\n            </footer>\n        </div>\n    </body>\n</html>","finalUrl":"https://www.parker.co.jp/recruit/culture/training.html","rendered":false,"_cachedAt":"2026-06-22T21:16:55.272Z"}