       $('body > header + div').css('margin-top', headerHeight + 'px');\n\n        // デバッグログ\n        console.log('SUCCESS: Header height applied.');\n        console.log('Header Height:', headerHeight + 'px');\n        console.log('Target Element:', $('body > header + div')[0]);\n    }\n\n    // ページ読み込み完了時（load）とリサイズ時に実行\n    $(window).on('load resize', function() {\n        adjustContentPosition();\n    });\n    // DOM準備完了時にも実行\n    $(document).ready(function() {\n        adjustContentPosition();\n    });\n</script>\n</body>\n\n</html>","finalUrl":"https://www.ryukei.okinawa/recruit.php","rendered":false,"_cachedAt":"2026-06-17T23:17:22.483Z"}