{"url":"https://www.heiwa-net.co.jp/recruit/career/index.html","html":"<!DOCTYPE html>\r\n<html lang='ja'>\r\n\r\n<head>\r\n  <meta charset='UTF-8'>\r\n<meta http-equiv='X-UA-Compatible' content='IE=edge'>\r\n<meta name='viewport' content='width=device-width, initial-scale=1.0'>\r\n<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\r\n<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\r\n<link href=\"https://fonts.googleapis.com/css2?family=Abel&family=Crimson+Text:wght@400;600;700&family=Noto+Sans+JP:wght@100..900&family=Noto+Serif+JP:wght@400;500;600;700;900&family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Roboto+Mono:ital,wght@0,100..700;1,100..700&display=swap\" rel=\"stylesheet\">\r\n<link rel='stylesheet' href='assets/css/style.css'>\r\n<script src=\"https://code.jquery.com/jquery-3.7.1.min.js\"></script>\r\n<script src=\"assets/js/common.js\"></script>\r\n  <title>中途採用情報｜平和不動産株式会社</title>\r\n</head>\r\n\r\n<body>\r\n  <header class='l-header isReverse'>\r\n  \r\n  <h1 class=\"l-header_logo\">\r\n    <img src='assets/img/common/logo_w.png' alt='平和不動産　MID-CAREER RECRUITING' class=\"l-header_logo_w\">\r\n    <img src='assets/img/common/logo_color.png' alt='' class=\"l-header_logo_color\">\r\n  </h1>\r\n  \r\n  <a href='' class='l-header_menubar u-sp js-menubar'><span></span><span></span><span></span></a>\r\n  <nav class='l-header_links js-menu'>\r\n    <a href='index.html' class='l-header_links_link isCurrent'>TOP</a>\r\n    <a href='index.html#interview' class='l-header_links_link '>INTERVIEW</a>\r\n    <a href='index.html#business' class='l-header_links_link '>BUSINESS</a>\r\n    <a href='benefit.html' class='l-header_links_link '>ENVIRONMENT</a>\r\n    <a href='message.html' class='l-header_links_link '>MESSAGE</a>\r\n    <a href='requirement.html' class='l-header_links_rq'>募集要項</a>\r\n  </nav>\r\n</header>\r\n  <a href='#' class='l-anchor'>PAGE TOP</a>\r\n  <div class='p-topFv'>\r\n  <div class='p-topFv_catch'>\r\n    <div class=\"p-topFv_catch_intra\">\r\n      <p class='p-topFv_catch_title'>\r\n        <span>あなたの<em>経験</em>と</span>\r\n        <span><em>アイディア</em>を</span>\r\n      </p>\r\n      <p class='p-topFv_catch_en'>MID-CAREER RECRUITING</p>\r\n    </div>\r\n  </div>\r\n  <section class='p-topFv_info'>\r\n    <div class=\"p-topFv_info_intra\">\r\n      <h2 class='p-topFv_info_title'>INFORMATION</h2>\r\n      <ul class='p-topFv_info_lists'>\r\n        <li>\r\n          <time>2024.4.1</time>\r\n          <p>キャリア採用サイトをオープンしました。</p>\r\n        </li>\r\n      </ul>\r\n    </div>\r\n  </section>\r\n</div>\r\n  <section class='p-topIntro'>\r\n    <div class='p-topIntro_main'>\r\n      <h2 class='p-topIntro_main_title'>平和不動産は今、<br>変化の時を迎えている。</h2>\r\n      <p class='p-topIntro_main_text'>\r\n        金融の中心地として<br class=\"u-sp\">歴史を刻み続けてきた<br>\r\n        日本橋兜町・茅場町を起点に、<br>\r\n        私たちは様々な彩りの種を蒔いてきた。<br>\r\n        デベロッパーという枠に収まることなく、<br>\r\n        人々を惹きつける「場づくり」の連続によって、<br>\r\n        未来に豊かさをもたらす。<br>\r\n        平和不動産が挑戦する次の一歩に、<br>\r\n        あなたの経験とアイデアを。\r\n      </p>\r\n    </div>\r\n    <div class='p-topIntro_name'>\r\n      <div class=\"p-topIntro_fixed\">\r\n        <img src='assets/img/top/bg_intro.png' alt='' class=\"js-prxBg p-topIntro_name_bg\">\r\n      </div>\r\n      <span class=\"p-topIntro_name_text\">HEIWA REAL ESTATE</span>\r\n    </div>\r\n</section>\r\n  <section class='p-topItv' id=\"interview\">\r\n  <div class=\"p-topItv_intra\">\r\n    <div class='p-topItv_sum'>\r\n      <h2 class='p-topTitle'>\r\n        <span class='p-topTitle_en'>interview</span>\r\n        <span class='p-topTitle_ja'>街<small>をつくる</small>人</span>\r\n      </h2>\r\n      <p class='p-topText'>\r\n        あなたの経験が、街に深みを。<br>\r\n        あなたのアイデアが街に繋がりを。<br>\r\n        一人ひとりの思いから、街づくりは始まる。<br>\r\n        思いを形にする、それが私たちの仕事。\r\n      </p>\r\n    </div>\r\n    <ul class='p-topItv_people'>\r\n      <li>\r\n        <a href='people-01.html' class=\"p-topItv_people_list\">\r\n          <h3 class='p-topItv_people_title'>兜町の魅力を発信することで<br>この街が人を惹きつける次のフェーズへ</h3>\r\n          <p class='p-topItv_people_dept'>地域共創部</p>\r\n          <figure class='p-topItv_people_img'>\r\n            <img src='assets/img/itv/common/fig_itv01.png' alt=''>\r\n            <figcaption>Sato Miku</figcaption>\r\n          </figure>\r\n          <p class='p-topItv_people_meta'>\r\n            <span class=\"date\">２０２２年入社</span>\r\n            <span class=\"name\">佐藤&emsp;未来</span>\r\n          </p>\r\n        </a>\r\n        <a href='people-01.html' class=\"p-topBtn\">Read More</a>\r\n      </li>\r\n      <li>\r\n        <a href='people-02.html' class=\"p-topItv_people_list\">\r\n          <h3 class='p-topItv_people_title'>不動産デベロッパーの醍醐味として<br>プロジェクトの竣工まで携わりたい</h3>\r\n          <p class='p-topItv_people_dept -second'>開発推進部</p>\r\n          <figure class='p-topItv_people_img'>\r\n            <img src='assets/img/itv/common/fig_itv02.png' alt=''>\r\n            <figcaption>Kubota Toru</figcaption>\r\n          </figure>\r\n          <p class='p-topItv_people_meta'>\r\n            <span class=\"date\">２０２２年入社</span>\r\n            <span class=\"name\">久保田&emsp;亨</span>\r\n          </p>\r\n        </a>\r\n        <a href='people-02.html' class=\"p-topBtn\">Read More</a>\r\n      </li>\r\n      <li>\r\n        <a href='people-03.html' class=\"p-topItv_people_list\">\r\n          <h3 class='p-topItv_people_title'>平和不動産らしさを確立しつつ<br>多様性を受け入れるマネジメントを</h3>\r\n          <p class='p-topItv_people_dept -third'>不動産投資事業部</p>\r\n          <figure class='p-topItv_people_img'>\r\n            <img src='assets/img/itv/common/fig_itv03.png' alt=''>\r\n            <figcaption>Harasawa Ken</figcaption>\r\n          </figure>\r\n          <p class='p-topItv_people_meta'>\r\n            <span class=\"date\">２００４年入社</span>\r\n            <span class=\"name\">原澤&emsp;憲</span>\r\n          </p>\r\n        </a>\r\n        <a href='people-03.html' class=\"p-topBtn\">Read More</a>\r\n      </li>\r\n      <li>\r\n        <a href='people-04.html' class=\"p-topItv_people_list\">\r\n          <h3 class='p-topItv_people_title'>将来の子供たちのためになる仕事がしたい<br>不動産会社の可能性を拓く</h3>\r\n          <p class='p-topItv_people_dept -fourth'>ビルディング事業部</p>\r\n          <figure class='p-topItv_people_img'>\r\n            <img src='assets/img/itv/common/fig_itv04.png' alt=''>\r\n            <figcaption>Hompo Akika</figcaption>\r\n          </figure>\r\n          <p class='p-topItv_people_meta'>\r\n            <span class=\"date\">２０１６年入社</span>\r\n            <span class=\"name\">本保&emsp;明香</span>\r\n          </p>\r\n        </a>\r\n        <a href='people-04.html' class=\"p-topBtn\">Read More</a>\r\n      </li>\r\n    </ul>\r\n  </div>\r\n</section>\r\n  <section class='p-topBusi' id=\"business\">\r\n  <div class=\"p-topBusi_intra\">\r\n    <div class='p-topBusi_detail'>\r\n      <h2 class='p-topTitle'>\r\n        <span class='p-topTitle_en'>Business</span>\r\n        <span class='p-topTitle_ja'>事業</span>\r\n      </h2>\r\n      <p class='p-topText'>\r\n        私たちの事業はつづく、<br>\r\n        街の過去から現在、<br>\r\n        そして未来へ。<br>\r\n        人が集い、<br>\r\n        その街のストーリーは続いていく。\r\n      </p>\r\n    </div>\r\n    <div class='p-topBusi_nav'>\r\n      <a href='https://www.heiwa-net.co.jp/business/redevelopment/' target=\"_blank\" class='p-topBusi_nav_link'><span>再開発事業</span></a>\r\n      <a href='https://www.heiwa-net.co.jp/business/building/' target=\"_blank\" class='p-topBusi_nav_link -second'><span>ビルディング事業</span></a>\r\n      <a href='https://www.heiwa-net.co.jp/business/estate.html' target=\"_blank\" class='p-topBusi_nav_link -third'><span>アセットマネジメント事業</span></a>\r\n      <div class='p-topBusi_nav_other'>\r\n        <a href='https://www.heiwa-net.co.jp/corporate/about.html' target=\"_blank\">会社概要</a>\r\n        <a href='https://www.heiwa-net.co.jp/corporate/history.html' target=\"_blank\">沿革</a>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</section>\r\n  <section class='p-topBenefit' id=\"benefit\">\r\n  <div class=\"p-topBenefit_intra\">\r\n    <h2 class='p-topTitle'>\r\n      <span class='p-topTitle_en'>Benefit</span>\r\n      <span class='p-topTitle_ja'>職場環境<small>と</small>制度</span>\r\n    </h2>\r\n    <p class='p-topText'>\r\n      人生を豊かにする職場。<br>\r\n      私たちが目指すのは、<br>\r\n      社員も家族も皆が幸せになる企業の姿。<br>\r\n      お互いが認め合い、尊重し合う風土が、<br>\r\n      私たちの会社を形作っている。<br>\r\n      そして、社員が活躍する職場がある<br>\r\n      それぞれの仕事によって<br>つくられた場が繋がって、街になる。\r\n    </p>\r\n    <a href='benefit.html' class='p-topBtn'>Read More</a>\r\n  </div>\r\n</section>\r\n  <a href='https://www.heiwa-net.co.jp/ir/individual/at_a_glance.html' class='l-know' target=\"_blank\">\r\n  <p class='l-know_catch'>平和不動産ってどんな会社？</p>\r\n  <h3 class='l-know_title'>すぐわかる<br class=\"u-sp\">平和不動産</h3>\r\n  <p class='l-know_sum'><span>当社の特長や強み、<br class=\"u-sp\">成長戦略を早わかりで紹介します</span></p>\r\n</a>\r\n  <hgroup class='l-special'>\r\n  <h2 class='l-special_title'>Special</h2>\r\n  <a href='office-tour.html' class='l-special_link'><span>オフィスツアー</span></a>\r\n</hgroup>\r\n  <nav class='l-localnav'>\r\n  <a href='https://www.heiwa-net.co.jp/corporate/about.html' class='l-localnav_link -ext' target=\"_blank\">会社概要</a>\r\n  <a href='https://www.heiwa-net.co.jp/corporate/history.html' class='l-localnav_link -ext' target=\"_blank\">沿革</a>\r\n  <a href='message.html' class='l-localnav_link -int'>メッセージ</a>\r\n  <a href='requirement.html' class='l-localnav_link -int'>募集要項</a>\r\n</nav>\r\n  <footer class='l-footer'>\r\n  <address class='l-footer_meta'>\r\n    <a href='index.html' class='l-footer_meta_logo'><img src='assets/img/common/logo_w.png' alt='平和不動産 MID-CAREER RECRUITINNG'></a>\r\n    <small class='l-footer_meta_copyright'>Copyright &copy; HEIWA REAL ESTATE CO., LTD. All rights reserved.</small>\r\n  </address>\r\n  <nav class='l-footer_links'>\r\n    <a href='index.html' class='l-footer_links_link'>TOP</a>\r\n    <a href='index.html#interview' class='l-footer_links_link'>INTERVIEW</a>\r\n    <a href='index.html#business' class='l-footer_links_link'>BUSINESS</a>\r\n    <a href='benefit.html' class='l-footer_links_link'>ENVIRONMENT</a>\r\n    <a href='message.html' class='l-footer_links_link'>MESSAGE</a>\r\n    <a href='https://www.heiwa-net.co.jp/' class='l-footer_links_ext' target=\"_blank\">コーポレートサイト</a>\r\n  </nav>\r\n</footer>\r\n  <script src=\"https://cdn.jsdelivr.net/npm/simple-parallax-js@5.6.1/dist/simpleParallax.min.js\"></script>\r\n  <script>\r\n    const image = document.getElementsByClassName('js-prxBg');\r\n    new simpleParallax(image, {\r\n      scale: 1.5\r\n    });\r\n  </script>\r\n</body>\r\n\r\n</html>","finalUrl":"https://www.heiwa-net.co.jp/recruit/career/index.html","rendered":false,"_cachedAt":"2026-06-14T19:06:40.468Z"}