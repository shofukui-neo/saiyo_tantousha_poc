{"url":"https://www.sc-aero.co.jp/recruit/","html":"\n<!DOCTYPE html>\n<html lang=\"ja\">\n    <head>\n        <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n        <meta charset=\"utf-8\">\n        <meta name=\"description\" content=\"住商エアロシステム株式会社の新卒採用情報です。\">\n        <meta name=\"keywords\" content=\"住商エアロシステム,防衛航空宇宙,新卒採用\">\n        <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n        <meta name=\"format-detection\" content=\"telephone=no\">\n\n        <title>住商エアロシステム株式会社｜新卒採用情報</title>\n\n        <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n        <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n        <link rel=\"stylesheet\" href=\"https://fonts.googleapis.com/css2?family=Zen+Old+Mincho:wght@400;700&display=swap\">\n        <link rel=\"stylesheet\" href=\"https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&display=swap\">\n        \n        <link rel=\"stylesheet\" href=\"assets/css/style.css\" media=\"all\">\n\n        <script src=\"assets/js/vendor/script.js\"></script>\n        <script src=\"assets/js/plugins.js\"></script>\n        \n        <script src=\"assets/js/app.js\"></script>\n\n        <!-- Global site tag (gtag.js) - Google Analytics -->\n        <script async src=\"https://www.googletagmanager.com/gtag/js?id=G-K76JDYQNZS\"></script> <script>\n            window.dataLayer = window.dataLayer || []; function gtag(){dataLayer.push(arguments);} gtag('js', new Date());\n            gtag('config', 'G-K76JDYQNZS');\n            gtag('config', 'UA-226519009-1');\n        </script>\n    </head>\n    <body class=\"home\" data-key=\"00-00-00\" data-dir=\"0\">\n        <div id=\"wrapper\">\n            <header>\n                <div id=\"header\">\n                    <div class=\"float\">\n                        <div class=\"left\">\n                            <ul class=\"flex\">\n                                <li><a class=\"logo\" href=\"\"><img src=\"assets/img/common/header_logo.png\" alt=\"住商エアロシステム株式会社\"></a></li>\n                                <li><p>新卒採用サイト</p></li>\n                            </ul>\n                        </div>\n                        <div class=\"right\">\n                            <ul class=\"flex\">\n                                <li><a id=\"menu-entry\" href=\"info/requirements.html#entry\"><p>ENTRY</p></a></li>\n                                <li><button id=\"menu-btn\"><span class=\"icon\"></span></button></li>\n                            </ul>\n                        </div>\n                    </div>\n                </div>\n            </header>\n\n\n\n            <div id=\"menu\">\n                <div id=\"menu-overlay\"></div>\n                <div id=\"menu-list\">\n                    <div class=\"inner900\">\n                        <div class=\"flex\">\n                            <div class=\"col\">\n                                <div class=\"box\">\n                                    <div class=\"parent\"><a href=\"\"><p class=\"font--serif\">TOP</p></a></div>\n                                </div>\n\n                                <div class=\"box\">\n                                    <div class=\"parent\"><a href=\"message/\"><p class=\"font--serif\">社長メッセージ</p></a></div>\n                                </div>\n\n                                <div class=\"box\">\n                                    <div class=\"parent\"><a class=\"accordion-btn--sp\"><p class=\"font--serif\">会社を知る</p></a></div>\n                                    <ul class=\" accordion-body--sp\">\n                                        <li class=\"child\"><a href=\"company/\"><p>企業概要</p></a></li>\n                                        <li class=\"child\"><a href=\"company/info.html\"><p>住商エアロシステムの機能</p></a></li>\n                                        <li class=\"child\"><a href=\"company/movie.html\"><p>動画ギャラリー</p></a></li>\n                                    </ul>\n                                </div>\n\n                                <div class=\"box\">\n                                    <div class=\"parent\"><a class=\"accordion-btn--sp\"><p class=\"font--serif\">ビジネスを知る</p></a></div>\n                                    <ul class=\" accordion-body--sp\">\n                                        <li class=\"child\"><a href=\"business/#business-pro\"><p>防衛・航空宇宙の専門商社</p></a></li>\n                                        <li class=\"child\"><a href=\"business/#business-sas\"><p>SAS Business</p></a></li>\n                                    </ul>\n                                </div>\n                            </div>\n                            <div class=\"col\">\n                                <div class=\"box\">\n                                    <div class=\"parent\"><a class=\"accordion-btn--sp\"><p class=\"font--serif\">社員を知る</p></a></div>\n                                    <ul class=\" accordion-body--sp\">\n                                        <li class=\"child\"><a href=\"staff/member04.html\"><p>総合職</p></a></li>\n                                        <li class=\"child\"><a href=\"staff/member02.html\"><p>総合職</p></a></li>\n                                        <li class=\"child\"><a href=\"staff/member03.html\"><p>管理職</p></a></li>\n                                    </ul>\n                                </div>\n                                <div class=\"box\">\n                                    <div class=\"parent\"><a class=\"accordion-btn--sp\"><p class=\"font--serif\">採用情報</p></a></div>\n                                    <ul class=\" accordion-body--sp\">\n                                        <li class=\"child\"><a href=\"info/requirements.html\"><p>募集要項</p></a></li>\n                                        <li class=\"child\"><a href=\"info/personality.html\"><p>求める人材像</p></a></li>\n                                        <li class=\"child\"><a href=\"info/event.html\"><p>イベント情報</p></a></li>\n                                    </ul>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n\n            <div id=\"mv\">\n                <div class=\"bg\"></div>\n                <div class=\"inner1000\">\n                    <div class=\"inside\">\n                        <div class=\"onload-late-in-group\">\n                            <div class=\"shoulder\"><p class=\"font--serif\">あなたの“大切なもの”は何ですか？</p></div>\n                            <div class=\"txt\">\n                                <p class=\"font--serif\">\n                                    家族や友達、恋人ですか？<br>\n                                    それとも仕事や趣味ですか？<br>\n                                    <br>\n                                    それぞれが思う“大切なもの”を未来へ繋げたい。<br>\n                                    <br>\n                                    その思いは、日本の明日を支え、<br>\n                                    未来をつくっていく。<br>\n                                    <br>\n                                    “大切なもの”が溢れる日常をあたりまえに。\n                                </p>\n                            </div>\n                            <div class=\"h1\"><h1><img class=\"js-switching\" data-src=\"assets/img/home/home_h1_pc.png\" alt=\"私たちはあたりまえを衛り続けます。\"></h1></div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n\n\n\n            <main>\n                <article>\n                    <section id=\"top-message\" class=\"late-in\">\n                        <div class=\"inner1200\">\n                            <div class=\"bg\"></div>\n                            <div class=\"inside\">\n                                <div class=\"h2\">\n                                    <h2 class=\"font--serif\">\n                                        豊かであたりまえの日常を<br>\n                                        <span class=\"color--white\">衛</span>り続ける\n                                    </h2>\n                                </div>\n\n                                <div class=\"txt\">\n                                    <p>\n                                        防衛・航空宇宙の仕事を通じて、社会に貢献したいという強い熱意・情熱が、私たちの豊かであたりまえの日常を衛る原動力となります。\n                                    </p>\n                                </div>\n\n                                <div class=\"btn\">\n                                    <ul>\n                                        <li><a href=\"message/\"><p>社長メッセージ</p></a></li>\n                                    </ul>\n                                </div>\n                            </div>\n                        </div>\n                    </section>\n\n\n\n                    <section id=\"top-business\" class=\"late-in\">\n                        <div class=\"inner1000\">\n                            <div class=\"bg\"><span></span></div>\n                            <div class=\"inside\">\n                                <div class=\"h2\">\n                                    <h2 class=\"font--serif\">\n                                        日本の、そして世界の安全を<br>\n                                        <span class=\"color--main\">衛</span>る仕事\n                                    </h2>\n                                </div>\n\n                                <div class=\"txt\">\n                                    <p>\n                                        国の安全・安心は、国民の生活や経済の基盤。住商エアロシステムは日本の豊かな社会を衛り広く国民の生活に貢献するという意識でビジネスに取り組んでいます。\n                                    </p>\n                                </div>\n\n                                <div class=\"btn\">\n                                    <ul>\n                                        <li><a href=\"company/\"><p>会社を知る</p></a></li>\n                                        <li><a href=\"business/\"><p>ビジネスを知る</p></a></li>\n                                    </ul>\n                                </div>\n                            </div>\n                        </div>\n                    </section>\n\n\n\n                    <section id=\"top-people\" class=\"late-in\">\n                        <div class=\"inner1000\">\n                            <div class=\"bg\"></div>\n                            <div class=\"inside\">\n                                <div class=\"h2\"><h2 class=\"font--serif\">未来を<span class=\"color--main\">衛</span>り続ける人々</h2></div>\n\n                                <div class=\"txt\">\n                                    <p>\n                                        あたりまえの日常を未来へと繋げるために、懸命に働く人たちがいます。あたりまえを支え続け、大切なものを衛るために、日々働く社員を紹介します。\n                                    </p>\n                                </div>\n\n                                <div class=\"btn\">\n                                    <ul>\n                                        <li><a href=\"staff/member04.html\"><p>社員を知る</p></a></li>\n                                    </ul>\n                                </div>\n                            </div>\n                        </div>\n                    </section>\n\n\n\n                    <section id=\"top-recruit\" class=\"late-in\">\n                        <div class=\"inner830\">\n                            <div class=\"h2\"><h2 class=\"font--serif\">採用情報</h2></div>\n                            <div class=\"list\">\n                                <ul class=\"flex\">\n                                    <li><a href=\"info/requirements.html\"><p class=\"font--serif\">募集要項</p></a></li>\n                                    <li><a href=\"info/personality.html\"><p class=\"font--serif\">求める人材像</p></a></li>\n                                    <li><a href=\"info/event.html\"><p class=\"font--serif\">イベント情報</p></a></li>\n                                </ul>\n                            </div>\n\n                            <div class=\"txt-link\">\n                                <a href=\"https://www.sc-aero.co.jp/recruit/career.html\" target=\"_blank\">＜キャリア採用情報はこちら＞</a>\n                            </div>\n                        </div>\n                    </section>\n                </article>\n            </main>\n\n            <div id=\"footer-message\">\n                <div class=\"inside\">\n                    <div class=\"ph\"><img src=\"assets/img/common/footer_copy.png\" alt=\"あたりまえを衞り続ける\"></div>\n                </div>\n            </div>\n            <footer class=\"home\">\n                <div class=\"upper\">\n                    <div class=\"inner1000\">\n                        <ul class=\"flex\">\n                            <li>\n                                <ol>\n                                    <li class=\"parent\"><a href=\"\"><p>TOP</p></a></li>\n                                    <li class=\"child\"><a href=\"info/requirements.html#entry\"><p>エントリー</p></a></li>\n                                    <li class=\"child\"><a class=\"blank\" href=\"https://www.sc-aero.co.jp/index.html\" target=\"_blank\"><p>コーポレートサイト</p></a></li>\n                                </ol>\n                            </li>\n                            <li>\n                                <ol>\n                                    <li class=\"parent\"><a href=\"message/\"><p>社長メッセージ</p></a></li>\n                                </ol>\n                            </li>\n                            <li>\n                                <ol>\n                                    <li class=\"parent\"><a class=\"none\"><p>会社を知る</p></a></li>\n                                    <li class=\"child\"><a href=\"company/\"><p>企業概要</p></a></li>\n                                    <li class=\"child\"><a href=\"company/info.html\"><p>住商エアロシステムの機能</p></a></li>\n                                    <li class=\"child\"><a href=\"company/movie.html\"><p>動画ギャラリー</p></a></li>\n                                </ol>\n                            </li>\n                            <li>\n              