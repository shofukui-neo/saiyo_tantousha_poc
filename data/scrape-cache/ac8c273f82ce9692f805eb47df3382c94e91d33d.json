ink type=\"text/css\" href=\"../common/css/page_c.css\" rel=\"stylesheet\" media=\"all\">\n<link type=\"text/css\" href=\"../common/css/add_style_c.css\" rel=\"stylesheet\" media=\"all\">\n\n<!-- CSS -->\n<link rel=\"stylesheet\" href=\"../common/js/vendor/aos.css\" />\n\n<!-- Javascript -->\n<script type=\"text/javascript\" src=\"../common/js/vendor/jquery-3.4.1.min.js\" charset=\"UTF-8\"></script>\n<script type=\"text/javascript\" src=\"../common/js/vendor/smooth-scroll.min.js\" charset=\"UTF-8\"></script>\n<script type=\"text/javascript\" src=\"../common/js/slide_menu.js\" charset=\"UTF-8\"></script>\n<script type=\"text/javascript\" src=\"../common/js/function.js\" charset=\"UTF-8\"></script>\n\n</head>\n\n<body>\n<!-- Google Tag Manager (noscript) -->\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-KL36MS6F\"\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n<!-- End Google Tag Manager (noscript) -->\n<div id=\"wrapper\" class=\"message\">\n    <!-- header -->\n\t<header class=\"top\">\n\t\t<!-- inner -->\n\t\t<div id=\"header-inner\">\n\t\t\t<h1 id=\"header-logo\"><a href=\"../index.html\"><img src=\"../images/logo.png\" alt=\"デンソーワイズテック\" /></a></h1>\n\t\t\t<div class=\"header-spmenu\"><img src=\"../common/images/sp_menu_bar.png\" alt=\"spmenu\"></div>\n\t\t\t<!-- sp overlayer-->\n    \t\t<div class=\"layer\"></div>\n\t\t\t<!-- navi -->\n\t\t\t<nav>\n\t\t\t\t<ul id=\"navi-inner\">\n                    <li class=\"sp-only category\">\n                        <a href=\"../u_graduate/index.html\">大卒採用の方は<br>こちら</a>\n                        <a href=\"../h_graduate/index.html\">高卒採用の方は<br>こちら</a>\n                        <a href=\"../career/index.html\">キャリア採用の方は<br>こちら</a>\n                        <a href=\"https://arwrk.net/recruit/denso-wisetech/\" target=\"_blank\">パート採用の方は<br>こちら</a>\n                    </li>\n                    <li><a href=\"index.html\">キャリア採用トップページ</a></li>\n                    <li><a href=\"message.html\">先輩メッセージ</a>\n                        <ul>\n                            <li><a href=\"message.html\">製品設計部</a></li>\n                            <li><a href=\"message2.html\">品質保証部</a></li>\n                            <li><a href=\"message3.html\">経営企画部</a></li>\n                        </ul>\n                    </li>\n                    <li><a href=\"education.html\">教育システム</a></li>\n                    <li><a href=\"reason.html\">安心できる理由</a></li>\n                    <li><a href=\"c_data.html\">募集要項・エントリー</a>\n                        <ul>\n                            <li><a href=\"c_data.html\">募集要項</a></li>\n                            <li><a href=\"https://arwrk.net/recruit/denso-wisetech/\" target=\"_blank\">エントリー</a></li>\n                        </ul>\n                    </li>\n\t\t\t  \t  \t<li class=\"close-button sp-only\">CLOSE</li>\n\t\t  \t  \t</ul>\n\t\t\t</nav>\n\t\t</div>\n\t\t<!-- inner  end -->\n\t</header>\n    <div class=\"header-option\">\n        <ul class=\"gr\">\n            <li><a href=\"../u_graduate/index.html\">大卒採用の方は<br>こちら</a></li>\n            <li><a href=\"../h_graduate/index.html\">高卒採用の方は<br>こちら</a></li>\n            <li class=\"active\"><a href=\"../career/index.html\">キャリア採用の方は<br>こちら</a></li>\n            <li><a href=\"https://arwrk.net/recruit/denso-wisetech/\" target=\"_blank\">パート採用の方は<br>こちら</a></li>\n        </ul>\n    </div>\n    <div class=\"top-image-c\">\n        <div class=\"photo-m\" data-aos=\"fade-in\"><img src=\"images/interview1_top.jpg\" width=\"1400\" height=\"700\" alt=\"\"/></div>\n        <div class=\"txt-m\">\n            <p>先輩メッセージ</p>\n            <div class=\"inner\">\n                <h1 data-aos=\"fade-left\">やりたかった回路設計の仕事と、<br>プライベートの充実を手に入れた。</h1>\n                <p class=\"prof\" data-aos=\"fade-right\">\n                    製品設計部 設計課<br>\n                    2020年入社<br>\n                    理学部 物理情報科学科出身\n                </p>\n            </div>\n        </div>\n    </div>\n    <main id=\"contents\">\n        <section data-aos=\"fade-up\">\n            <div class=\"inner\">\n                <dl>\n                    <dt>もっと広い視野で考える<br>設計がしたかった。</dt>\n                    <dd>\n                        <p>\n                        新卒で就いた仕事は、自動車向けの抵抗器の設計でした。自動車が電動化されても間違いなく必要とされる製品ですが、もっとノイズ対策など多様な課題に応える「回路全体の設計」に挑戦したいと思うようになり、同じ自動車向けの回路設計ができるデンソーワイズテックへの転職を決意しました。入社後は、既存製品の改良や評価を先輩と一緒に経験した後、独り立ち。入社1年半で、農業機械のメータの設計を担当しました。従来品のメータに、フィルタ詰まりの検知信号を受けて警告灯を表示する機能を追加する仕事です。配線の幅や隙間の寸法・配置など、品質を確保するための細かいルールを理解しながら設計に臨みました。屋外で風雨にさらされ、海外の過酷な環境でも使われるため、腐食から保護し、万一ショートした場合の影響を最小限に食い止めることも、設計上の重要なポイントでした。\n                        </p>\n                    </dd>\n                </dl>\n                <ul>\n                    <li><img src=\"images/i1_p1.jpg\" width=\"600\" height=\"360\" alt=\"\"/></li>\n                    <li><img src=\"images/i1_p2.jpg\" width=\"600\" height=\"360\" alt=\"\"/></li>\n                </ul>\n            </div>\n        </section>\n        <section data-aos=\"fade-up\">\n            <div class=\"inner\">\n                <dl>\n                    <dt>達成感ある仕事と育児、<br>どちらも充実の環境。</dt>\n                    <dd>\n                        <p>\n                        前職で得た抵抗器の知識や、メッキ加工など工程の内容に関する基礎知識は、現在の仕事にも活かせています。図面を描くだけでなく、試作品を動作させて、回路変更による影響が考えられる全項目を評価するまでを自分で行い、やりきった感も味わえています。仕事の充実度に加えてもう一つ転職してよかったと思うのが、育児休暇を取れたこと。双子の育児に苦労していた妻から「とても助かった！」と喜ばれました。ちょうど仕事が多忙な時期でしたが、思い切って上司に相談すると快諾。3カ月の育休期間は、ミルクとおむつ交換の他、家事に追われ寝る暇もないほどでしたが、事前に仕事の引き継ぎができたおかげで、休暇中は問い合わせが来ることもなく家庭のことに専念できました。職場復帰後は慣らし運転的な業務からスタートして、無理なく少しずつ仕事の勘を取り戻せたのもありがたかったです。\n                        </p>\n                    </dd>\n                </dl>\n                <ul>\n                    <li><img src=\"images/i1_p3.jpg\" width=\"600\" height=\"360\" alt=\"\"/></li>\n                    <li><img src=\"images/i1_p4.jpg\" width=\"600\" height=\"360\" alt=\"\"/></li>\n                </ul>\n            </div>\n        </section>\n        <aside class=\"contents-menu\">\n            <ul>\n                <li>\n                    <a href=\"message.html\">\n                        <div class=\"photo\"><img src=\"images/imenu_1.jpg\" width=\"310\" height=\"277\" alt=\"\"/></div>\n                        <p>Message.1</p>\n                        <p class=\"title\">製品設計部</p>\n                        <div class=\"button rdw\">Read more</div>\n                    </a>\n                </li>\n                <li>\n                    <a href=\"message2.html\">\n                        <div class=\"photo\"><img src=\"images/imenu_2.jpg\" width=\"310\" height=\"277\" alt=\"\"/></div>\n                        <p>Message.2</p>\n                        <p class=\"title\">品質保証部</p>\n                        <div class=\"button rdw\">Read more</div>\n                    </a>\n                </li>\n                <li>\n                    <a href=\"message3.html\">\n                        <div class=\"photo\"><img src=\"images/imenu_3.jpg\" width=\"310\" height=\"277\" alt=\"\"/></div>\n                        <p>Message.3</p>\n                        <p class=\"title\">経営企画部</p>\n                        <div class=\"button rdw\">Read more</div>\n                    </a>\n                </li>\n            </ul>\n        </aside>\n    </main>\n    <!-- page top -->\n    <div class=\"pagetop\"><a href=\"#wrapper\"><img src=\"../common/images/pagetop.png\" width=\"150\" height=\"45\" alt=\"pagetop\"/></a></div>\n    <!-- footer -->\n  \t<footer>\n        <div class=\"footer-bottom\">\n            <div class=\"inner\">\n                <div class=\"footer-logo\">\n                    <h1><img src=\"../images/logo_footer.png\" alt=\"デンソーワイズテック\" width=\"280\" height=\"20\"/></h1>\n                    <p>〒509-0249　岐阜県可児市姫ケ丘3-1<br>TEL:0574-60-5220</p>\n                    <a href=\"https://www.denso-wisetech.co.jp/\" target=\"_blank\" class=\"link-b\">コーポレートサイト</a>\n                </div>\n                <div class=\"footer-menu\">\n      