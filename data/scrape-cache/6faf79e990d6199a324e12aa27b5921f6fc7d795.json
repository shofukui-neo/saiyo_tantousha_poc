2.6z\" />\n\t\t</symbol>\n\t\t<symbol viewbox=\"0 0 512 512\" id=\"icon-external-link\">\n\t\t\t<path d=\"m24 508c-11 0-20-9-20-20v-400c0-11 9-20 20-20h295l-47.3 49.7c-3.9 3.9-12.2 7.3-17.7 7.3h-193.5v328l326.6-1.4-.1-193.6c0-5.5 3.4-13.8 7.3-17.7 0 0 49.1-49 49.5-49.2.1.4.2 296.9.2 296.9 0 11-9 20-20 20zm157.9-136.6c-5.3 0-10.4-2.1-14.2-5.9l-21.2-21.2c-3.8-3.7-5.9-8.7-5.9-14 0-5.4 2.1-10.4 5.9-14.2l255.7-255.6-46.3-46.3c-3.6-3.6-.9-10.2 4.1-10.2h128c11 0 20 9 20 20v128c0 4.2-6.3 8-10.1 4.1l-46.3-46.2-255.6 255.6c-3.8 3.8-8.8 5.9-14.1 5.9z\"/>\n\t\t</symbol>\n\t</defs>\n</svg>\n\n<header id=\"header\" class=\"header-dark\">\n\t<div id=\"company\">\n\t\t<div class=\"logo\"><a href=\"\"><div class=\"img\"><img src=\"img/logo.png\" class=\"img-fluid\" alt=\"\"></div></a></div>\n\t\t<!--<div class=\"link-corpsite\"><a href=\"https://www.yonei.co.jp/\" target=\"_blank\">コーポレートサイト<svg class=\"icon-external-link\" aria-hidden=\"true\"><use xlink:href=\"#icon-external-link\"></use></svg></a></div>-->\n\t</div>\n\t<div id=\"hamburger\">\n\t\t<button id=\"nav-icon\" class=\"hamburger hamburger--spin\" type=\"button\" onfocus=\"this.blur();\" aria-label=\"メニュを開く\">\n\t\t\t<span class=\"hamburger-box\">\n\t\t\t\t<span class=\"hamburger-inner\"></span>\n\t\t\t</span>\n\t\t</button>\n\t</div>\n\t<nav id=\"nav\">\n\t\t<ul>\n\t\t\t<li><a href=\"#movie\"><p>会社説明動画</p></a></li>\n\t\t\t<li><a href=\"#message\"><p>代表メッセージ</p></a></li>\n\t\t\t<li><a href=\"#interview\"><p>先輩インタビュー</p></a></li>\n\t\t\t<li><a href=\"#service\"><p>事業紹介</p></a></li>\n\t\t\t<li><a href=\"#charm\"><p>ヨネイの魅力</p></a></li>\n\t\t\t<li><a href=\"#infographics\"><p>数字で見る</p></a></li>\n\t\t\t<li><a href=\"#photo\"><p>職場風景</p></a></li>\n\t\t\t<li><a href=\"#access\"><p>アクセス</p></a></li>\n\t\t\t<!--<li id=\"nav-main-corpsite\"><a href=\"https://www.yonei.co.jp/\" target=\"_blank\">コーポレートサイト<svg class=\"icon-external-link\" aria-hidden=\"true\"><use xlink:href=\"#icon-external-link\"></use></svg></a></li>-->\n\t\t\t<li id=\"nav-entry\">\n\t\t\t\t<a href=\"\" id=\"nav-entry-btn\"><p>エントリー <svg class=\"icon-circle-arrow-r\" aria-hidden=\"true\"><use xlink:href=\"#icon-circle-arrow-r\"></use></svg></p></a>\n\t\t\t\t<ul id=\"entry-subnav\" class=\"subnav\">\n\t\t\t\t\t<li><a href=\"https://job.rikunabi.com/selection/job_descriptions/3d99dd5dee15e6b2/?betk=SoDu6_I3jk56TvTIzx0IbzkdCdPP&jrtk=5-nrt1-1-1jp4ota7sgmdb800-3d99dd5dee15e6b2--SoAH6_M3jk56l_S5bx0LbzkdCdPP&seqNo=2&job_list_type=recruit-newgrad-feed-hp-selection\" target=\"_blank\">リクナビ2027</a></li>\n\t\t\t\t\t<li><a href=\"https://job.career-tasu.jp/corp/00013178/\" target=\"_blank\">キャリタス2028</a></li>\n\t\t\t\t<!-- END Footer Entry btn -->\n\t\t\t\t</ul>\n\t\t\t</li>\n\t\t</ul>\n\t</nav>\n</header>\n\n<!-- Footer Entry btn -->\n\t<div id=\"nav-main-entry\">\n\t\t<a href=\"\" id=\"footer-entry-btn\">エントリー <svg class=\"icon-circle-arrow-r\" aria-hidden=\"true\"><use xlink:href=\"#icon-circle-arrow-r\"></use></svg></a>\n\t\t<div class=\"subnav\">\n\t\t\t<ul>\n\t\t\t\t<li><a href=\"https://job.rikunabi.com/selection/job_descriptions/3d99dd5dee15e6b2/?betk=SoDu6_I3jk56TvTIzx0IbzkdCdPP&jrtk=5-nrt1-1-1jp4ota7sgmdb800-3d99dd5dee15e6b2--SoAH6_M3jk56l_S5bx0LbzkdCdPP&seqNo=2&job_list_type=recruit-newgrad-feed-hp-selection\" target=\"_blank\">リクナビ&nbsp;2027</a></li>\n\t\t\t\t<li><a href=\"https://job.career-tasu.jp/corp/00013178/\" target=\"_blank\">キャリタス&nbsp;2028</a></li>\n\t\t\t</ul>\n\t\t</div>\n\t</div>\n<!-- END Footer Entry btn -->\n\n\n\n\t<!-- Back to top btn -->\n\t<div id=\"backtotop\">\n\t\t<div class=\"arrow\"><span></span></div>\n\t</div><!-- END Back to top btn -->\n\n\t<section id=\"kv\" class=\"wow fadeIn\" data-wow-duration=\"1.2s\" data-wow-delay=\"0.3s\">\n\t\t<div class=\"catch-copy\">\n\t\t\t<h2 class=\"wow fadeIn\" data-wow-duration=\"1.2s\" data-wow-delay=\"0.24s\">人と技術と情報を繋ぐ「機能商社」として、<br>社会の発展と安全に貢献します。</h2>\n\t\t\t<!--<p class=\"wow fadeIn\" data-wow-duration=\"1.2s\" data-wow-delay=\"0.8s\">「アナタらしく」、120年の歴史が背中を押してくれる。</p>-->\n\t\t</div>\n\t\t<div class=\"img-wrapper\">\n\t\t\t<picture>\n\t\t\t\t<source media=\"(min-width: 1281px)\" srcset=\"img/kv.jpg\">\n\t\t\t\t<source media=\"(min-width: 961px)\" srcset=\"img/kv-1280.jpg 1x, img/kv.jpg 2x\">\n\t\t\t\t<source media=\"(min-width: 576px)\" srcset=\"img/kv-960.jpg 1x, img/kv.jpg 2x\">\n\t\t\t\t<img src=\"img/kv-sp.jpg\" alt=\"オープニングスタッフ募集\">\n\t\t\t</picture>\n\t\t</div>\n\t\t<div class=\"kv-bg\"></div>\n\t\t<div id=\"icon-scrolldown\"><div class=\"arrow anime\"><span></span></div></div>\n\t</section>\n\t\n\t<section id=\"movie\">\n\t\t<h3 class=\"wow fadeIn\" data-wow-duration=\"1.2s\" data-wow-delay=\"0.3s\">MOVIE<br><span>会社説明動画</span></h3>\n\t\t<div class=\"container\">\n\t\t\t<div class=\"row justify-content-center no-gutters\">\n\t\t\t\t<div class=\"fixed-width\">\n\t\t\t\t\t<video src=\"douga/information.mp4\" poster=\"img/movie.jpg\" controls></video>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\t</section>\n\n\t<section id=\"message\">\n\t\t<h3 class=\"wow fadeIn\" data-wow-duration=\"1.2s\" data-wow-delay=\"0.3s\">MESSAGE<br><span>代表メッセージ</span></h3>\n\t\t<div class=\"container\">\n\t\t\t<div class=\"row no-gutters\">\n\t\t\t\t<div class=\"col-md-6\">\n\t\t\t\t\t<div class=\"message-portrait wow fadeIn\" data-wow-duration=\"1.2s\" data-wow-delay=\"0.24s\">\n\t\t\t\t\t\t<div class=\"img\">\n\t\t\t\t\t\t\t<img class=\"img-fluid lazyload\" alt=\"\" data-sizes=\"(max-width: 768px) 100vw, 50vw\" data-src=\"img/about-768.jpg\" data-srcset=\"img/about-768.jpg 768w, img/about-380.jpg 380w\">\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t\t<div class=\"col-md-6\">\n\t\t\t\t\t<div class=\"box wow fadeIn\" data-wow-duration=\"1.2s\" data-wow-delay=\"0.24s\">\n\t\t\t\t\t\t<h5>社員の個性が会社の成長に繋がる。</h5>\n\t\t\t\t\t\t<div class=\"txt\">\n\t\t\t\t\t\t\t1897年の創業以来、ヨネイは社会環境の変化と共に改革を行ってきました。2020年には生活様式の変化をチャンスと捉え、働き方の改善を行いました。又、成果をより正しく評価する人事制度を整え、社員のモチベーションアップを図っています。歴史を重んじながら時代と共に柔軟に形を変えて120余年。「人と技術と情報を繋ぐ機能商社」を目指す姿として掲げ、これからも国・自治体・民間のお客様とメーカーを繋ぐ懸け橋となっていきます。\n\t\t\t\t\t\t\tそのために必要となるのが“人”の力です。様々な人脈や技術、情報を持っているプロの人材が介在することで、カスタマーサクセスを実現できます。社員には役職や社歴、新卒・中途入社にとらわれず、自分の個性や生まれ持ったものを活かしながら、できることを増やして欲しいと考えています。社員の個性は会社の財産です。あなたの個性を存分に活かし、一緒に新たな未来を創っていきませんか。\n\t\t\t\t\t\t</div>\n\t\t\t\t\t\t<div class=\"name\"><span>取締役社長</span>大田 健治</div>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\t</section>\n\t\n\t<section id=\"interview\">\n\t\t<h3 class=\"wow fadeIn\" data-wow-duration=\"1.2s\" data-wow-delay=\"0.3s\">INTERVIEW<br><span>先輩インタビュー</span></h3>\n\t\t<div class=\"container\">\n\t\t\t<div class=\"row no-gutters\">\t\t\n\t\t\t\t<div class=\"col-md-6\">\n\t\t\t\t\t<div class=\"box wow fadeIn\" data-wow-duration=\"1.2s\" data-wow-delay=\"0.3s\">\n\t\t\t\t\t\t<div class=\"img\">\n\t\t\t\t\t\t\t<img class=\"img-fluid lazyload\" alt=\"\" data-sizes=\"(max-width: 768px) 100vw, 50vw\" data-src=\"img/interview-1-768.jpg\" data-srcset=\"img/interview-1-768.jpg 768w, img/interview-1-380.jpg 380w\">\n\t\t\t\t\t\t</div>\n\t\t\t\t\t\t<div class=\"inner\">\n\t\t\t\t\t\t\t<h5>J．M</h5>\n\t\t\t\t\t\t\t<div class=\"position\">2020年新卒入社／建設機械事業部</div>\n\t\t\t\t\t\t\t<dvi class=\"title\">誠実さを武器に、お客様から愛される営業に。</dvi>\n\t\t\t\t\t\t\t<div class=\"txt\">\n\t\t\t\t\t\t\t\t建設業界のお客様にクレーン等の建設機械の販売やレンタルをしています。一番うれしいのはお客様に信頼して頂ける時。今でも心に残っているのは、市場にほとんど流通していない50トンのラフタークレーンが欲しいとご相談頂いたお客様から、初めてご注文を頂いた時の事。当時、経験もスキルも不十分な私にご相談して下さり、少しでも役に立ちたいと探し回ったことを覚えています。ある日、お客様が希望されている中古クレーンの売却を希望されているオーナー様を見つけることができ、仲介することができました。無事に納品できた時は、安堵と同時に言葉にできない達成感を感じましたね。\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t\t<div class=\"col-md-6\">\n\t\t\t\t\t<div class=\"box wow fadeIn\" data-wow-duration=\"1.2s\" data-wow-delay=\"0.3s\">\n\t\t\t\t\t\t<div class=\"img\">\n\t\t\t\t\t\t\t<img class=\"img-fluid lazyload\" alt=\"\" data-sizes=\"(max-width: 768px) 100vw, 50vw\" data-src=\"img/interview-2-768.jpg\" data-srcset=\"img/interview-2-768.jpg 768w, img/interview-2-380.jpg 380w\">\n\t\t\t\t\t\t</div>\n\t\t\t\t\t\t<div class=\"inner\">\n\t\t\t\t\t\t\t<h5>R．S</h5>\n\t\t\t\t\t\t\t<div class=\"position\">2016年新卒入社／産業機械事業部 主任</div>\n\t\t\t\t\t\t\t<dvi class=\"title\">日本の製品を世界に広げる。</dvi>\n\t\t\t\t\t\t\t<div class=\"txt\">\n\t\t\t\t\t\t\t\t自動車関連部品のホースや塗料等の輸出手配を行っています。この仕事で大切なのは、できる方法を考え、行動していくことです。橋を作る際に使用する塗料をスリランカに輸出した時のこと。本来は、近国のインドから輸出予定だったのですが、新型コロナウイルスの影響等を受け輸出ができない状況になりました。そこで当社が関わり日本製品を輸出することに。短納期でのご依頼でしたが、時間のロスや手配漏れがないよう細心の注意を払い迅速に対応すると共に、お客様、メーカー、輸送業者と小まめに連絡を取り合うなどして最短納期で輸送を完了しました。その後もお客様から「スムーズに進めるためには、ヨネイさんが必要」という言葉をいただいた時は、メーカーとお客様の間に立って中立な立場で仕事をする意味と、自分の介在価値を強く感じることができた経験でしたね。\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t\t<div class=\"col-md-6\">\n\t\t\t\t\t<div class=\"box wow fadeIn\" data-wow-duration=\"1.2s\" data-wow-delay=\"0.3s\">\n\t\t\t\t\t\t<div class=\"img\">\n\t\t\t\t\t\t\t<img class=\"img-fluid lazyload\" alt=\"\" data-sizes=\"(max-width: 768px) 100vw, 50vw\" data-src=\"img/interview-3-768.jpg\" data-srcset=\"img/interview-3-768.jpg 768w, img/interview-3-380.jpg 380w\">\n\t\t\t\t\t\t</div>\n\t\t\t\t\t\t<div class=\"inner\">\n\t\t\t\t\t\t\t<h5>T．Y</h5>\n\t\t\t\t\t\t\t<div class=\"position\">2021年新卒入社／産業機械事業部</div>\n\t\t\t\t\t\t\t<dvi class=\"title\">顧客の課題解決しながら、エコな状態を作っていく。</dvi>\n\t\t\t\t\t\t\t<div class=\"txt\">\n\t\t\t\t\t\t\t\t製紙会社や化学会社などへ新設備の導入や既存設備の保守をご提案し、お客様の事業を後押ししています。例えばコスト削減を考えている製紙会社の場合、オートストレーナーという全自動で水をろ過する装置の導入をご提案します。紙を抄くには大量の水が必要となるのですが、一度使われた水をそのまま捨てるのは非常にもったいない。オートストレーナーを導入することで水を再利用し、コスト削減と同時に環境への負荷を減らすこともできます。各社それぞれの課題を抱えているので、一社一社のお客様に合うご提案をしていくことが何よりも重要。これからもお客様に選ばれる為、どんな些細な悩みでも相談してもらえるよう足繁く通い、ご相談頂いた際にはスピーディーに対応していきます。\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t\t<div class=\"col-md-6\">\n\t\t\t\t\t<div class=\"box wow fadeIn\" data-wow-duration=\"1.2s\" data-wow-delay=\"0.3s\">\n\t\t\t\t\t\t<div class=\"img\">\n\t\t\t\t\t\t\t<img class=\"img-fluid lazyload\" alt=\"\" data-sizes=\"(max-width: 768px) 100vw, 50vw\" data-src=\"img/interview-4-768.jpg\" data-srcset=\"img/interview-4-768.jpg 768w, img/interview-4-380.jpg 380w\">\n\t\t\t\t\t\t</div>\n\t\t\t\t\t\t<div class=\"inner\">\n\t\t\t\t\t\t\t<h5>Y．W</h5>\n\t\t\t\t\t\t\t<div class=\"position\">2017年新卒入社／特機事業部 主任</div>\n\t\t\t\t\t\t\t<dvi class=\"title\">国防に携わるという誇りとやりがいを実感。</dvi>\n\t\t\t\t\t\t\t<div class=\"txt\">\n\t\t\t\t\t\t\t\tお客様である海上自衛隊と、メーカー（造船所）をつなぐ役割を担う特機事業部。海上自衛隊の保有する艦船や搭載機器の修理・点検や部品調達などを行う際に、メーカーの代理で契約し、スムーズな修理～納品につなげていくことが私たち営業のミッションです。重要なのは、海上自衛隊とメーカー双方の要望をまとめ上げていく調整力。国防に携わる仕事なだけに、時間的な制約をはじめクリアしなくてはならないハードルが沢山ありますが、だからこそ無事にプロジェクトを完了させたときの達成感は非常に大きいものがあります。入社後の数年間を過ごした呉営業所では、私が携わった艦船が出航していく姿を目にする機会も多々ありました。こんなにスケールの大きな仕事を手掛けられることを、誇らしく思っています。\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\t</section>\n\t\n\t<section id=\"service\">\n\t\t<h3 class=\"wow fadeIn\" data-wow-duration=\"1.2s\" data-wow-delay=\"0.3s\">SERVICE<br><span>事業紹介</span></h3>\n\t\t<div class=\"container\">\n            <div class=\"row\">\n\t\t\t\t<div class=\"col-md-6 wow fadeIn\" data-wow-duration=\"1.2s\" data-wow-delay=\"0.3s\">\n\t\t\t\t\t<div class=\"img\">\n\t\t\t\t\t\t<img class=\"img-fluid lazyload\" alt=\"\" data-sizes=\"(max-width: 768px) 100vw, 50vw\" data-src=\"img/service-5-768.jpg\" data-src=\"img/service-5-768.jpg\" data-srcset=\"img/service-5-768.jpg 768w, img/service-5-380.jpg 380w\" sizes=\"(max-width: 768px) 100vw, 50vw\" data-src=\"img/service-5-768.jpg\" srcset=\"img/service-5-768.jpg 768w, img/service-5-380.jpg 380w\" src=\"img/service-5-768.jpg\">\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t\t<div class=\"col-md-6 wow fadeIn\" data-wow-duration=\"1.2s\" data-wow-delay=\"0.3s\">\n\t\t\t\t\t<div class=\"inner\">\n\t\t\t\t\t\t<h5>建設機械事業部</h5>\n\t\t\t\t\t\t<div class=\"txt\">\n\t\t\t\t\t\t\tクレーンやショベル、基礎機械など、いわゆる工事現場ではたらく機械を取扱う部署です。販売だけでなくレンタルも行っています。お客様は、建築・土木工事を行う建設業界の企業が中心。お客様のニーズに合わせて柔軟な提案を行います。又、中古機械の売買も行っています。\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n            \n            <div class=\"row flex-md-row-reverse\">\n\t\t\t\t<div class=\"col-md-6 wow fadeIn\" data-wow-duration=\"1.2s\" data-wow-delay=\"0.3s\">\n\t\t\t\t\t<div class=\"img\">\n\t\t\t\t\t\t<img class=\"img-fluid lazyload\" alt=\"\" data-sizes=\"(max-width: 768px) 100vw, 50vw\" data-src=\"img/service-6-768.jpg\" data-src=\"img/service-6-768.jpg\" data-srcset=\"img/service-6-768.jpg 768w, img/service-6-380.jpg 380w\" sizes=\"(max-width: 768px) 100vw, 50vw\" data-src=\"img/service-6-768.jpg\" srcset=\"img/service-6-768.jpg 768w, img/service-6-380.jpg 380w\" src=\"img/service-6-768.jpg\">\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t\t<div class=\"col-md-6 wow fadeIn\" data-wow-duration=\"1.2s\" data-wow-delay=\"0.3s\">\n\t\t\t\t\t<div class=\"inner\">\n\t\t\t\t\t\t<h5>特機事業部</h5>\n\t\t\t\t\t\t<div class=\"txt\">\n\t\t\t\t\t\t\t海上自衛隊と関連メーカーをつなぐ役割を担う部署です。主に護衛艦やその搭載機器の点検・修理の契約業務を行います。国との契約が多く、各種書類を多数作成・確認します。100年以上にわたる取引の中で築いた信頼を大切に引継いでいます。\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n            \n\t\t\t<div class=\"row\">\n\t\t\t\t<div class=\"col-md-6 wow fadeIn\" data-wow-duration=\"1.2s\" data-wow-delay=\"0.3s\">\n\t\t\t\t\t<div class=\"img\">\n\t\t\t\t\t\t<img class=\"img-fluid lazyload\" alt=\"\" data-sizes=\"(max-width: 768px) 100vw, 50vw\" data-src=\"img/service-1-768.jpg\" data-src=\"img/service-1-768.jpg\" data-srcset=\"img/service-1-768.jpg 768w, img/service-1-380.jpg 380w\" sizes=\"(max-width: 768px) 100vw, 50vw\" data-src=\"img/service-1-768.jpg\" srcset=\"img/service-1-768.jpg 768w, img/service-1-380.jpg 380w\" src=\"img/service-1-768.jpg\">\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t\t<div class=\"col-md-6 wow fadeIn\" data-wow-duration=\"1.2s\" data-wow-delay=\"0.3s\">\n\t\t\t\t\t<div class=\"inner\">\n\t\t\t\t\t\t<h5>情報産業システム事業部</h5>\n\t\t\t\t\t\t<div class=\"txt\">\n\t\t\t\t\t\t\t３分野の商材を取扱う部署です。１つ目は大型映像表示システム。官公庁や鉄道系企業、インフラ企業などで活用され、営業～設計～施工～保守までを私たちが担っています。２つ目は監視カメラや、オフィスのセキュリティゲートなどのセキュリティ関連機器。３つ目は各種工場で使用される、圧力や流量を測定する機器などの計装システム機器や、総合生産制御システムです。\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n            \n            <div class=\"row flex-md-row-reverse\">\n\t\t\t\t<div class=\"col-md-6 wow fadeIn\" data-wow-duration=\"1.2s\" data-wow-delay=\"0.3s\">\n\t\t\t\t\t<div class=\"img\">\n\t\t\t\t\t\t<img class=\"img-fluid lazyload\" alt=\"\" data-sizes=\"(max-width: 768px) 100vw, 50vw\" data-src=\"img/service-3-768.jpg\" data-src=\"img/service-3-768.jpg\" data-srcset=\"img/service-3-768.jpg 768w, img/service-3-380.jpg 380w\" sizes=\"(max-width: 768px) 100vw, 50vw\" data-src=\"img/service-3-768.jpg\" srcset=\"img/service-3-768.jpg 768w, img/service-3-380.jpg 380w\" src=\"img/service-3-768.jpg\">\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t\t<div class=\"col-md-6 wow fadeIn\" data-wow-duration=\"1.2s\" data-wow-delay=\"0.3s\">\n\t\t\t\t\t<div class=\"inner\">\n\t\t\t\t\t\t<h5>産業機械事業部　工業資材グループ</h5>\n\t\t\t\t\t\t<div class=\"txt\">\n\t\t\t\t\t\t\t機械や装置の中に組み込まれる工業用ゴム・樹脂部品等を主に取扱う部署です。お客様は、造船会社や建設機械メーカー、エレベーターメーカー、産業ロボットメーカー等が中心。商品はお客様の要求仕様に合わせ、カスタマイズした製品が主ですので、一度ご採用いただくと継続的に受注・納品するものが多々あります。\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n            \n            <div class=\"row\">\n\t\t\t\t<div class=\"col-md-6 wow fadeIn\" data-wow-duration=\"1.2s\" data-wow-delay=\"0.3s\">\n\t\t\t\t\t<div class=\"img\">\n\t\t\t\t\t\t<img class=\"img-fluid lazyload\" alt=\"\" data-sizes=\"(max-width: 768px) 100vw, 50vw\" data-src=\"img/service-4-768.jpg\" data-src=\"img/service-4-768.jpg\" data-srcset=\"img/service-4-768.jpg 768w, img/service-4-380.jpg 380w\" sizes=\"(max-width: 768px) 100vw, 50vw\" data-src=\"img/service-4-768.jpg\" srcset=\"img/service-4-768.jpg 768w, img/service-4-380.jpg 380w\" src=\"img/service-4-768.jpg\">\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t\t<div class=\"col-md-6 wow fadeIn\" data-wow-duration=\"1.2s\" data-wow-delay=\"0.3s\">\n\t\t\t\t\t<div class=\"inner\">\n\t\t\t\t\t\t<h5>産業機械事業部　設備グループ</h5>\n\t\t\t\t\t\t<div class=\"txt\">\n\t\t\t\t\t\t\t製紙会社や製鉄会社、食品・飲料・化学メーカー向けの各種機械・部品を取扱う部署です。主要な商品は、紙を作るための機械に使われる「ゴム・ウレタンロール」。鉄ロール表面にゴム・ウレタンをライニングするもので、幅数メートルにも及ぶ大きなものです。消耗品ですので、メンテナンスのため工場への定期訪問も行います。昨今、製紙会社各社がケミカル関係の開発も進めていることに対応し、液体・粉体に関する機器も取扱っています。又、搬送機器、包装機器、検査機なども取り扱っています。\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t\t\n\t\t\t<div class=\"row flex-md-row-reverse\">\n\t\t\t\t<div class=\"col-md-6 wow fadeIn\" data-wow-duration=\"1.2s\" data-wow-delay=\"0.3s\">\n\t\t\t\t\t<div class=\"img\">\n\t\t\t\t\t\t<img class=\"img-fluid lazyload\" alt=\"\" data-sizes=\"(max-width: 768px) 100vw, 50vw\" data-src=\"img/service-2-768.jpg\" data-src=\"img/service-2-768.jpg\" data-srcset=\"img/service-2-768.jpg 768w, img/service-2-380.jpg 380w\" sizes=\"(max-width: 768px) 100vw, 50vw\" data-src=\"img/service-2-768.jpg\" srcset=\"img/service-2-768.jpg 768w, img/service-2-380.jpg 380w\" src=\"img/service-2-768.jpg\">\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t\t<div class=\"col-md-6 wow fadeIn\" data-wow-duration=\"1.2s\" data-wow-delay=\"0.3s\">\n\t\t\t\t\t<div class=\"inner\">\n\t\t\t\t\t\t<h5>産業機械事業部　海外グループ</h5>\n\t\t\t\t\t\t<div class=\"txt\">\n\t\t\t\t\t\t\t東南アジア向け自動車部品製造用金型設備、自動車ホース、塗料原料等の輸出業務を主体とした事業を行っています。また、東南アジア向け事業投資としてタイ及びインドネシアにて、INGRESSグループ、片山工業株式会社と共に自動車部品製造会社へ出資を行っています。タイでは株式会社明治ゴム化成と合弁で特殊ホース製造会社を設立し、現地法人であるTHAI YONEI Co., Ltd.社(右写真は同社スタッフ)が各国への販売を行っています。\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t\t\n\t\t</div>\n\t</section>\n\n\t<section id=\"charm\">\n\t\t<h3 class=\"wow fadeIn\" data-wow-duration=\"1.2s\" data-wow-delay=\"0.3s\">CHARM<br><span>ヨネイの魅力</span></h3>\n\t\t<div class=\"container\">\n\t\t\t<div class=\"row justify-content-center no-gutters\">\n\n\t\t\t\t<div class=\"col-md-4\">\n\t\t\t\t\t<div class=\"box wow fadeIn\" data-wow-duration=\"1.2s\" data-wow-delay=\"0.3s\">\n\t\t\t\t\t\t<div class=\"img\">\n\t\t\t\t\t\t\t<img class=\"img-fluid lazyload\" alt=\"\" data-sizes=\"(max-width: 768px) 100vw, 50vw\" data-src=\"img/charm-1-768.jpg\" data-srcset=\"img/charm-1-768.jpg 768w, img/charm-1-380.jpg 380w\" sizes=\"(max-width: 768px) 100vw, 50vw\" srcset=\"img/charm-1-768.jpg 768w, img/charm-1-380.jpg 380w\" src=\"img/charm-1-768.jpg\">\n\t\t\t\t\t\t</div>\n\t\t\t\t\t\t<div class=\"inner\">\n\t\t\t\t\t\t\t<h5>環境変化に即応した福利厚生</h5>\n\t\t\t\t\t\t\t<div class=\"txt\">\n\t\t\t\t\t\t\t\t自社ホームページにて健康宣言を行い、社内外にその取組の実績・計画を公表し、社員・家族の健康増進に積極的に取り組んでいます。コロナ対策として社員の時短勤務導入・ワクチン休暇の付与等、特別勤務体制を早期に実現しました。少ない自己負担で本人が希望する住居を貸与する借上社宅制度、各種有給休暇制度、スポーツ奨励金等の福利厚生により、今後も社員が安心して長く活躍できる環境づくりに取組み続けます。\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\n\t\t\t\t<div class=\"col-md-4\">\n\t\t\t\t\t<div class=\"box wow fadeIn\" data-wow-duration=\"1.2s\" data-wow-delay=\"0.3s\">\n\t\t\t\t\t\t<div class=\"img\">\n\t\t\t\t\t\t\t<img class=\"img-fluid lazyload\" alt=\"\" data-sizes=\"(max-width: 768px) 100vw, 50vw\" data-src=\"img/charm-2-768.jpg\" data-srcset=\"img/charm-2-768.jpg 768w, img/charm-2-380.jpg 380w\" sizes=\"(max-width: 768px) 100vw, 50vw\" srcset=\"img/charm-2-768.jpg 768w, img/charm-2-380.jpg 380w\" src=\"img/charm-2-768.jpg\">\n\t\t\t\t\t\t</div>\n\t\t\t\t\t\t<div class=\"inner\">\n\t\t\t\t\t\t\t<h5>充実した教育制度</h5>\n\t\t\t\t\t\t\t<div class=\"txt\">\n\t\t\t\t\t\t\t\t社会に役立つ人材育成の為、社員教育として各階層別に定期的な研修の実施や、簿記・ビジネス法務等の資格取得を進めています。又、語学学習等の費用補助やｅラーニングにより、社員の自己啓発をサポートしています。加えて、新卒社員の育成に力を入れており、入社後1年間は専任のOJT・メンター担当者を割り当て、2名体制で成長の後押し・ノウハウの継承を行っています。\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\n\t\t\t\t<div class=\"col-md-4\">\n\t\t\t\t\t<div class=\"box wow fadeIn\" data-wow-duration=\"1.2s\" data-wow-delay=\"0.3s\">\n\t\t\t\t\t\t<div class=\"img\">\n\t\t\t\t\t\t\t<img class=\"img-fluid lazyload\" alt=\"\" data-sizes=\"(max-width: 768px) 100vw, 50vw\" data-src=\"img/charm-3-768.jpg\" data-srcset=\"img/charm-3-768.jpg 768w, img/charm-3-380.jpg 380w\" sizes=\"(max-width: 768px) 100vw, 50vw\" srcset=\"img/charm-3-768.jpg 768w, img/charm-3-380.jpg 380w\" src=\"img/charm-3-768.jpg\">\n\t\t\t\t\t\t</div>\n\t\t\t\t\t\t<div class=\"inner\">\n\t\t\t\t\t\t\t<h5>堅実で発言しやすい社風</h5>\n\t\t\t\t\t\t\t<div class=\"txt\">\n\t\t\t\t\t\t\t\t120年を超す長年の取引で培った多くの取引先との信頼を重んじています。新入社員は先輩社員との取引先訪問の際、その重みを知り、それを守り、いずれ引き継ぐ事となります。社員数が約130名と少数精鋭ですので、若手でも責任のある仕事を担当します。又、役職や部署に関係なく意見を出しやすい環境で、会社の制度として年に一度自分の異動希望を直接会社に伝える機会を設けています。\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\n\t\t\t</div>\n\t\t</div>\n\t</section>\n\t\n\t<section id=\"infographics\">\n\t\t<h3 class=\"wow fadeInUp\" data-wow-duration=\"1.2s\" data-wow-delay=\"0s\" style=\"visibility: visible; animation-duration: 1.2s; animation-delay: 0s; animation-name: fadeInUp;\">INFOGRAPHICS<br><span>数字で見る</span></h3>\n\t\t<div class=\"container full-width\">\n\t\t\t<ul class=\"row\">\n\t\t\t\t<li class=\"col-lg-4 col-md-6 col-12\">\n\t\t\t\t\t<div class=\"img wow fadeInUp\" data-wow-duration=\"1.2s\" data-wow-delay=\"0.3s\">\n\t\t\t\t\t\t<img class=\"img-fluid lazyload\" alt=\"\" data-sizes=\"(max-width: 992px) 100vw, 33vw\" data-src=\"img/infographics-1-768.jpg\" data-srcset=\"img/infographics-1-768.jpg 768w, img/infographics-1-380.jpg 380w\" sizes=\"(max-width: 992px) 100vw, 33vw\" srcset=\"img/infographics-1-768.jpg 768w, img/infographics-1-380.jpg 380w\" src=\"img/infographics-1-768.jpg\" >\n\t\t\t\t\t</div>\n\t\t\t\t</li>\n\t\t\t\t<li class=\"col-lg-4 col-md-6 col-12\">\n\t\t\t\t\t<div class=\"img wow fadeInUp\" data-wow-duration=\"1.2s\" data-wow-delay=\"0.3s\">\n\t\t\t\t\t\t<img class=\"img-fluid lazyload\" alt=\"\" data-sizes=\"(max-width: 992px) 100vw, 33vw\" data-src=\"img/infographics-2-768.jpg\" data-srcset=\"img/infographics-2-768.jpg 768w, img/infographics-2-380.jpg 380w\" sizes=\"(max-width: 992px) 100vw, 33vw\" srcset=\"img/infographics-2-768.jpg 768w, img/infographics-2-380.jpg 380w\" src=\"img/img/infographics-2-768.jpg\">\n\t\t\t\t\t</div>\n\t\t\t\t</li>\n\t\t\t\t<li class=\"col-lg-4 col-md-6 col-12\">\n\t\t\t\t\t<div class=\"img wow fadeInUp\" data-wow-duration=\"1.2s\" data