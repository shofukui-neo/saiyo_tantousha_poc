\t<span itemprop=\"name\">募集要項</span>\r\n\t\t\t\t</a>    \r\n\t\t\t\t<meta itemprop=\"position\" content=\"3\" />\r\n\t\t\t</li>\r\n\t\t</ol>\r\n\t</div><!--breadcrumbs-->\r\n\r\n\t<div class=\"box_area\">\r\n\t<div class=\"info\">\r\n\t\t<h2>募集要項</h2>\r\n\t\t<div class=\"info_guidelinebox\">\r\n\t\t<table width=\"0\" border=\"1\" class=\"info_guideline\">\r\n          <tbody>\r\n            <tr>\r\n\t\t\t\t<th scope=\"row\">職種</th>\r\n\t\t\t\t<td>技術系正社員</td>\r\n\t\t\t  </tr>\r\n\t\t\t  <tr>\r\n\t\t\t\t  <th scope=\"row\" rowspan=\"3\">給与</th>\r\n\t\t\t\t  <td><table class=\"inner_table\">\r\n\t\t\t\t\t  <tbody>\r\n\t\t\t\t\t\t  <tr>\r\n\t\t\t\t\t\t\t  <th rowspan=\"4\" scope=\"row\">新卒<br class=\"sp-only\">採用</th>\r\n\t\t\t\t\t\t\t  <td>・大学院卒：235,100円</td>\r\n\t\t\t\t\t\t  </tr>\r\n\t\t\t\t\t\t  <tr><td>・大学卒　：225,900円</td></tr>\r\n\t\t\t\t\t\t  <tr><td>・高専卒　：206,000円</td></tr>\r\n\t\t\t\t\t\t  <tr><td>・高校卒　：186,000円</td></tr>\r\n\t\t\t\t\t  </tbody>\r\n\t\t\t\t\t  </table>\r\n\t\t\t\t  </td>\r\n\t\t\t  </tr>\r\n\t\t\t  <tr>\r\n\t\t\t\t  <td><table class=\"inner_table\">\r\n\t\t\t\t\t  <tbody>\r\n\t\t\t\t\t\t  <tr>\r\n\t\t\t\t\t\t\t  <th rowspan=\"2\" scope=\"row\">中途<br class=\"sp-only\">採用</th>\r\n\t\t\t\t\t\t\t  <td>186,000円程度（高卒）～400,000円</td>\r\n\t\t\t\t\t\t  </tr>\r\n\t\t\t\t\t\t  <tr><td>※経験・年齢・能力等を考慮し決定します。</td></tr>\r\n\t\t\t\t\t  </tbody>\r\n\t\t\t\t\t  </table>\r\n\t\t\t\t  </td>\r\n\t\t\t  </tr>\r\n\t\t\t  <tr>\r\n\t\t\t\t  <td>※採用時に試用期間3ヵ月あり。（条件面に変更なし）</td>\r\n\t\t\t  </tr>\r\n\t\t\t  <tr>\r\n\t\t\t\t  <th scope=\"row\">諸手当</th>\r\n\t\t\t\t  <td>時間外勤務手当、夜勤手当、役職手当<br>資格手当、扶養手当、住宅手当、通勤手当　等</td>\r\n\t\t\t  </tr>\r\n\t\t\t  <tr>\r\n\t\t\t\t  <th scope=\"row\" rowspan=\"2\">昇給 / 賞与</th>\r\n\t\t\t\t  <td>昇給：年1回（4月）</td>\r\n\t\t\t  </tr>\r\n\t\t\t  <tr>\r\n\t\t\t\t  <td>賞与：年2回（7月、12月）</td>\r\n\t\t\t  </tr>\r\n\t\t\t  <tr>\r\n\t\t\t\t  <th scope=\"row\">職務内容</th>\r\n\t\t\t\t  <td>・担当工事の安全管理、工程管理、予算管理<br>・発注者及び協力会社との各種調整、打合せ<br>・工事に伴う自治体・警察等への各種申請<br>・現場のチェック</td>\r\n\t\t\t  </tr>\r\n\t\t\t  <tr>\r\n\t\t\t\t  <th scope=\"row\">勤務地</th>\r\n\t\t\t\t  <td>香川県高松市西宝町の本社</td>\r\n\t\t\t  </tr>\r\n\t\t\t  <tr>\r\n\t\t\t\t  <th scope=\"row\">勤務時間</th>\r\n\t\t\t\t  <td>8：30～17：30（休憩60分）<br>※工事の内容により、夜間勤務（21:00～6:00）あり</td>\r\n\t\t\t  </tr>\r\n\t\t\t  <tr>\r\n\t\t\t\t  <th scope=\"row\">休日</th>\r\n\t\t\t\t  <td>土・日・祝日（完全週休2日制）<br>※業務の都合により、休日勤務あり（代休付与）</td>\r\n\t\t\t  </tr>\r\n\t\t\t  <tr>\r\n\t\t\t\t  <th scope=\"row\">休暇</th>\r\n\t\t\t\t  <td>年末年始休暇、年次有給休暇（半日休暇あり）、慶弔休暇<br>産前産後・育児休暇、配偶者産後休暇（産後育休）<br>介護休暇、看護休暇（子供の傷病看護） 等</td>\r\n\t\t\t  </tr>\r\n\t\t\t  <tr>\r\n\t\t\t\t  <th scope=\"row\">福利厚生</th>\r\n\t\t\t\t  <td>各種社会保険完備（雇用・労災・健康・厚生年金）<br>定期健康診断、人間ドック<br>退職金制度<br>資格取得支援制度（受検費用会社負担、取得時奨励金）　等</td>\r\n\t\t    </tr>\r\n          </tbody>\r\n        </table> <!--company_profile-->\r\n\t\t\t</div>\r\n\t\t</div><!--info-->\r\n\r\n\t\t<!-- 外部の採用サイトリンク用\r\n\t\t<div class=\"info_apply\">\r\n\t\t  <h3>応募方法</h3>\r\n\t\t\t<div class=\"info_apply-btn\">\r\n\t\t\t\t<div><a href=\"\" class=\"btn\">新卒/既卒の方はこちら</a></div>\r\n\t\t\t\t<div><a href=\"\" class=\"btn\">中途採用はこちら</a></div>\r\n\t\t\t</div>\r\n\t\t</div>-->\r\n \r\n      <div class=\"info_inquiry\">\r\n        <h3>お問合せ先</h3>\r\n\t\t  <p class=\"incname\">本四塗装工業株式会社　採用担当宛</p>\r\n\t\t  <p>&#12306;760-0004<br>香川県高松市西宝町三丁目５番２６号</p>\r\n\t\t  <p class=\"inquiry_tel\">TEL：<a href=\"tel:0878023525\">087-802-3525</a></p>\r\n\t\t  <div class=\"inquiry_mail\">\r\n\t\t\t  <a href=\"mailto:soumu-honshi@jr-shikoku.co.jp?subject=採用に関するお問い合わせ\">メールでのお問い合わせはこちら</a>\r\n\t\t  </div>\r\n\t\t</div><!--info_inquiry-->\t\r\n  </div>\r\n\t<button id=\"pagetop\" class=\"page-top\"><span class=\"page-top_icon\"></span></button>\r\n<!--inc footer-->\r\n<div class=\"footer\">\r\n\t<p class=\"policy\"><a href=\"/honshitoso/policy.html\">個人情報の取り扱いに関する基本方針</a></p>\r\n\t<p class=\"outside\"><span class=\"underline\">リンク</span><br><a href=\"https://www.jr-shikoku.co.jp/\" target=\"_blank\">四国旅客鉄道株式会社</a></p>\r\n\t<p class=\