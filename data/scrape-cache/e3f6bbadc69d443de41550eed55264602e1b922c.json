{"url":"https://www.takizumi.com/recruit/","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n<head prefix=\"og: http://ogp.me/ns#\">\n  <!-- Google tag (gtag.js) -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-23HKB9BP8V\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'G-23HKB9BP8V');\n</script>  <meta charset=\"UTF-8\">\n  <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n  <title>タキズミ採用サイト｜東京都内を中心としたオフィス・住空間のソリューションプロバイダー</title>\n  <meta name=\"description\" content=\"株式会社タキズミの採用情報サイトです。事業紹介、社員インタビュー、仕事の流れ、募集要項などを掲載しています。\">\n  <meta name=\"keywords\" content=\"\">\n\n  <meta property=\"fb:app_id\" content=\"\">\n  <meta property=\"og:title\" content=\"タキズミ採用サイト｜東京都内を中心としたオフィス・住空間のソリューションプロバイダー\">\n  <meta property=\"og:description\" content=\"株式会社タキズミの採用情報サイトです。事業紹介、社員インタビュー、仕事の流れ、募集要項などを掲載しています。\">\n  <meta property=\"og:type\" content=\"website\">\n  <meta property=\"og:image\" content=\"https://www.takizumi.com/recruit/images/ogp.jpg\">\n  <meta property=\"og:url\" content=\"https://www.takizumi.com/recruit/\">\n  <meta property=\"og:site_name\" content=\"株式会社タキズミ\">\n  <meta property=\"og:locale\" content=\"ja_JP\">\n  <meta name=\"twitter:title\" content=\"タキズミ採用サイト｜東京都内を中心としたオフィス・住空間のソリューションプロバイダー\">\n  <meta name=\"twitter:description\" content=\"株式会社タキズミの採用情報サイトです。事業紹介、社員インタビュー、仕事の流れ、募集要項などを掲載しています。\">\n  <meta name=\"twitter:image\" content=\"https://www.takizumi.com/recruit/images/ogp.jpg\">\n  <meta name=\"twitter:url\" content=\"https://www.takizumi.com/recruit/\">\n  <meta name=\"twitter:card\" content=\"summary_large_image\">\n\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<link rel=\"icon\" href=\"/recruit/images/apple-touch-icon.png\">\n<link rel=\"shortcut icon\" href=\"/recruit/images/apple-touch-icon.png\">\n<link rel=\"shortcut icon\" type=\"image/x-icon\" href=\"/recruit/f