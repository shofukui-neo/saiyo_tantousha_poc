</li>\n\t\t\t\t\t\t\t</ul>\n\t\t\t\t\t\t</div>\n          </li>\n\t\t\t\t\t<li class=\"header_gnav_item header_gnav_item_04 header_gnav_item_mega\"><span>人を知る</span>\n\t\t\t\t\t\t<div class=\"header_gnav_mega\">\n\t\t\t\t\t\t\t<ul class=\"header_megamenu\">\n\t\t\t\t\t\t\t\t<li class=\"header_megamenu_item\"><a href=\"/recruit/Interview01/\">社員インタビュー01</a></li>\n\t\t\t\t\t\t\t\t<li class=\"header_megamenu_item\"><a href=\"/recruit/Interview02/\">社員インタビュー02</a></li>\n\t\t\t\t\t\t\t\t<!-- <li class=\"header_megamenu_item\"><a href=\"/recruit/Interview03/\">社員インタビュー03</a></li>  -->\n\t\t\t\t\t\t\t\t<!-- <li class=\"header_megamenu_item\"><a href=\"/recruit/Interview04/\">社員インタビュー04</a></li> -->\n\t\t\t\t\t\t\t</ul>\n\t\t\t\t\t\t</div>\n          </li>\n\t\t\t\t\t<li class=\"header_gnav_item header_gnav_item_05 header_gnav_item_solo\"><a href=\"/recruit/detail/\">募集要項</a></li>\n\t\t\t\t</ul>\n\t\t\t</nav>\n      <p class=\"header_corporate\"><a href=\"http://www.takizumi.com/\" target=\"_blank\">コーポレートサイトはこちら</a></p>\n\t\t\t<div class=\"header_entry\">\n\t\t\t\t<p class=\"header_entry_btn\"><a href=\"/recruit/detail/#message\">エントリー</a></p>\n\t\t\t</div>\n      <p class=\"header_copy\">&copy; 2022 TAKIZUMI All Right Reserved.</p>\n\t\t</div><!-- /.header_wrap_inner -->\n\t</div><!-- /.header_wrap -->\n</header>\n\n\t\t\t<main id=\"main\">\n\t\t\t\t<div class=\"top_mv\" id=\"js-target-mvSlider\"><div class=\"top_mv_inline\">\n          <h1 class=\"top_mv_text_box\">\n\t\t\t\t\t\t<span class=\"top_mv_title\">向き合って、強くなる。</span>\n\t\t\t\t\t\t<span class=\"top_mv_text\">TAKIZUMI recruit</span>\n\t\t\t\t\t</h1>\n          <div class=\"swiper-container\">\n\t\t\t\t\t\t<div class=\"swiper-wrapper\">\n\t\t\t\t\t\t\t<div class=\"swiper-slide\">\n\t\t\t\t\t\t\t\t<div class=\"top_mv_slide\">\n                  <picture>\n                    <source media=\"(min-width:768px)\" srcset=\"images/slides/top_mv_slide01.jpg\">\n                    <source media=\"(max-width:767px)\" srcset=\"images/slides/top_mv_slide01_sp.jpg\">\n                    <img src=\"images/slides/top_mv_slide01.jpg\" width=\"1600\" height=\"900\" alt=\"イメージ画像\">\n                  </picture>\n                </div>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t<div class=\"swiper-slide\">\n\t\t\t\t\t\t\t\t<div class=\"top_mv_slide\">\n                  <picture>\n                    <source media=\"(min-width:768px)\" srcset=\"images/slides/top_mv_slide02.jpg\">\n                    <source media=\"(max-width:767px)\" srcset=\"images/slides/top_mv_slide02_sp.jpg\">\n                    <img src=\"images/slides/top_mv_slide02.jpg\" width=\"1600\" height=\"900\" alt=\"イメージ画像\">\n                  </picture>\n                </div>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t<div class=\"swiper-slide\">\n\t\t\t\t\t\t\t\t<div class=\"top_mv_slide\">\n                  <picture>\n                    <source media=\"(min-width:768px)\" srcset=\"images/slides/top_mv_slide03.jpg\">\n                    <source media=\"(max-width:767px)\" srcset=\"images/slides/top_mv_slide03_sp.jpg\">\n                    <img src=\"images/slides/top_mv_slide03.jpg\" width=\"1600\" height=\"900\" alt=\"イメージ画像\">\n                  </picture>\n                </div>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t<div class=\"swiper-slide\">\n\t\t\t\t\t\t\t\t<div class=\"top_mv_slide\">\n                  <picture>\n                    <source media=\"(min-width:768px)\" srcset=\"images/slides/top_mv_slide04.jpg\">\n                    <source media=\"(max-width:767px)\" srcset=\"images/slides/top_mv_slide04_sp.jpg\">\n                    <img src=\"images/slides/top_mv_slide04.jpg\" width=\"1600\" height=\"900\" alt=\"イメージ画像\">\n                  </picture>\n                </div>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t<div class=\"swiper-slide\">\n\t\t\t\t\t\t\t\t<div class=\"top_mv_slide\">\n                  <picture>\n                    <source media=\"(min-width:768px)\" srcset=\"images/slides/top_mv_slide05.jpg\">\n                    <source media=\"(max-width:767px)\" srcset=\"images/slides/top_mv_slide05_sp.jpg\">\n                    <img src=\"images/slides/top_mv_slide05.jpg\" width=\"1600\" height=\"900\" alt=\"イメージ画像\">\n                  </picture>\n                </div>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</div><!-- /.swiper-wrapper -->\n\t\t\t\t\t</div><!-- /.swiper-container -->\n          <div class=\"top_mv_scroll\">\n            <p class=\"top_mv_scroll_text\">\n              <span class=\"text\">Scroll down</span>\n              <span class=\"line\"></span>\n            </p>\n          </div>\n          <div class=\"top_mv_cover\"></div>\n\t\t\t\t</div></div><!-- /.top_mv -->\n\n        <div class=\"top_message\">\n          <div class=\"all_l_wrap\">\n            <h2 class=\"top_message_title\">・Message</h2>\n            <div class=\"top_message_body\">\n              <p class=\"top_message_catch\">お客様と、自分自身と。<br>向き合うことで、<br>私たちは成長できた。</p>\n              <p class=\"top_message_text\">私たちタキズミの仕事は、お客様の大切な建物・空間を<br class=\"all_mi_pc\">より快適に、より美しくコーディネートすること。<br>\n              そのためにお客様のご要望にとことん向き合い<br class=\"all_mi_pc\">プロとしてどんな提案ができるか、最善の方法を見つけます。<br>\n              それは、今の自分がどこまでできるか、自分と向き合うことにもなります。<br>\n              プレッシャーはいつも感じますが、そんな時は、風通しのよい環境の中で<br class=\"all_mi_pc\">心強い仲間や先輩が相談にのってくれ、支えてくれます。<br>\n              だから、楽しく乗り越えられる。<br>\n              そして、いい仕事の後は、お客様からのうれしい言葉が必ず待っています。<br>\n              ふと気づくと、自分が短い期間で成長していることに驚いた。<br>\n              タキズミでは、よく聞く話です。<br>\n              あなたも、私たちと一緒に、自分自身の成長を実感してみませんか。</p>\n            </div>\n          </div>\n          <span class=\"top_message_obj\"><img src=\"images/top_message_txt_obj.svg\" alt=\"Message\"></span>\n        </div><!-- /.top_message -->\n\n        <div class=\"top_contents\">\n          <div class=\"top_business\" data-anim=\"custom\">\n            <div class=\"all_l_wrap\">\n              <div class=\"top_business_body\">\n                <h2 class=\"top_business_title all_c_title_dot\"><span>事業紹介</span></h2>\n                <span class=\"top_business_obj\"><img src=\"images/top_business_txt_obj.svg\" alt=\"Business\"></span>\n                <p class=\"top_business_text\">私たちの仕事は、ビルのオーナー様や不動産会社様など、お客様のお困りごとを解決し、独自のご提案をプラスすることで、社会全体に快適な空間を増やすこと。設備リニューアルソリューション、デザイン改修ソリューション、管理ソリューションの3つの主要業務についてご紹介することで、詳しく知っていただけます。</p>\n                <div class=\"top_business_btn all_c_more\"><a href=\"business/\">\n                  <span class=\"all_c_more_text\">VIEW MORE</span>\n                  <span class=\"all_c_more_mark\"></span>\n                </a></div>\n              </div>\n              <div class=\"top_business_img_box\">\n                <div class=\"top_business_img_gallery\">\n                  <div class=\"top_business_img_gallery_left\">\n                    <img src=\"images/top_business_img_left.jpg\" width=\"400\" height=\"1400\" alt=\"事業紹介画像\">\n                    <img src=\"images/top_business_img_left.jpg\" width=\"400\" height=\"1400\" alt=\"事業紹介画像\">\n                  </div>\n                  <div class=\"top_business_img_gallery_right\">\n                    <img src=\"images/top_business_img_right.jpg\" width=\"400\" height=\"1400\" alt=\"事業紹介画像\">\n                    <img src=\"images/top_business_img_right.jpg\" width=\"400\" height=\"1400\" alt=\"事業紹介画像\">\n                  </div>\n                </div>\n                <div class=\"top_business_img_sp\">\n                  <div class=\"top_business_img_filter\"></div>\n                  <figure>\n                    <img src=\"images/top_business_img_sp.jpg\" width=\"2304\" height=\"216\" alt=\"事業紹介画像\">\n                    <img src=\"images/top_business_img_sp.jpg\" width=\"2304\" height=\"216\" alt=\"事業紹介画像\">\n                  </figure>\n                </div>\n              </div>\n            </div>\n          </div><!-- /.top_business -->\n\n          <div class=\"top_job\" data-anim=\"custom\">\n            <div class=\"top_job_header\">\n              <h2 class=\"top_job_title all_c_title_dot\"><span>仕事を知る</span></h2>\n              <span class=\"top_job_obj\"><img src=\"images/top_job_txt_obj.svg\" alt=\"Our Job\"></span>\n              <p class=\"top_job_lead\">社員同士の楽しい座談会や、1日の仕事の流れを追うことで、タキズミの仕事の内容をリアルに感じてください。</p>\n            </div>\n            <div class=\"top_job_body\">\n              <div class=\"top_job_content top_job_content_talk\"><a href=\"crosstalk/\">\n                <div class=\"top_job_content_img_box\">\n                  <span class=\"top_job_content_img_filter\"></span>\n                  <figure class=\"top_job_content_img\">\n                    <picture>\n                      <source media=\"(min-width:768px)\" srcset=\"images/top_job_img_crosstalk.jpg\">\n                      <source media=\"(max-width:767px)\" srcset=\"images/top_job_img_crosstalk_sp.jpg\">\n                      <img src=\"images/top_job_img_crosstalk.jpg\" width=\"700\" height=\"650\" alt=\"社員クロストーク\">\n                    </picture>\n                  </figure>\n                </div>\n                <div class=\"top_job_content_title_box\">\n                  <h3 class=\"top_job_content_title\">社員クロストーク</h3>\n                  <p class=\"top_job_content_text\">同期社員の4人組がホンネで語る座談会。<br class=\"all_mi_pc\">タキズミが、どんな会社かを知ってください。</p>\n                </div>\n                <p class=\"top_job_content_more\">VIEW MORE</p>\n              </a></div>\n              <div class=\"top_job_content top_job_content_flow\"><a href=\"workflow/\">\n                <div class=\"top_job_content_img_box\">\n                  <span class=\"top_job_content_img_filter\"></span>\n                  <figure class=\"top_job_content_img\">\n                    <picture>\n                      <source media=\"(min-width:768px)\" srcset=\"images/top_job_img_flow.jpg\">\n                      <source media=\"(max-width:767px)\" srcset=\"images/top_job_img_flow.jpg\">\n                      <img src=\"images/top_job_img_flow.jpg\" width=\"700\" height=\"650\" alt=\"1日の仕事の流れ\">\n                    </picture>\n                  </figure>\n                </div>\n                <div class=\"top_job_content_title_box\">\n                  <h3 class=\"top_job_content_title\">1日の仕事の流れ</h3>\n                  <p class=\"top_job_content_text\">タキズミを代表する職種の社員が過ごす１日を追っていきます。</p>\n                </div>\n                <p class=\"top_job_content_more\">VIEW MORE</p>\n              </a></div>\n            </div>\n          </div><!-- /.top_job -->\n\n          <div class=\"top_culture\" data-anim=\"custom\">\n            <div class=\"all_l_wrap\">\n              <div class=\"top_culture_header\">\n                <h2 class=\"top_culture_title all_c_title_dot\"><span>働く環境を知る</span></h2>\n                <span class=\"top_culture_obj\"><img src=\"images/top_culture_txt_obj.svg\" alt=\"Our Culture\"></span>\n                <p class=\"top_culture_lead\">会社の規模は決して大きくはありませんが、私たちは社員が仕事を通じて豊かな人生を送れるように、様々な制度や仕組みを設けています。</p>\n              </div>\n              <div class=\"top_culture_body\">\n                <div class=\"top_culture_content top_culture_content_training\"><a href=\"training/\">\n                  <div class=\"top_culture_content_visual\">\n                    <p class=\"top_culture_content_title_en\">Training system</p>\n                    <span class=\"top_culture_content_bg\"></span>\n                    <p class=\"top_culture_content_illust\"><img src=\"images/top_culture_img_training.svg\" width=\"266\" height=\"258\" alt=\"Training system\"></p>\n                    <p class=\"top_culture_content_btn\"></p>\n                  </div>\n                  <h3 class=\"top_culture_content_title_ja\">キャリア・研修制度</h3>\n                  <p class=\"top_culture_content_text\">未経験の方でも無理なく知識や技術を身につけられるように、また資格を取得したいというチャレンジ精神を応援するための制度があります。</p>\n                </a></div>\n                <div class=\"top_culture_content top_culture_content_welfare\"><a href=\"welfare\">\n                  <div class=\"top_culture_content_visual\">\n                    <p class=\"top_culture_content_title_en\">Welfare system</p>\n                    <span class=\"top_culture_content_bg\"></span>\n                    <p class=\"top_culture_content_illust\"><img src=\"images/top_culture_img_welfare.svg\" width=\"176\" height=\"273\" alt=\"Welfare system\"></p>\n                    <p class=\"top_culture_content_btn\"></p>\n                  </div>\n                  <h3 class=\"top_culture_content_title_ja\">福利厚生</h3>\n                  <p class=\"top_culture_content_text\">社員が快適な環境の中で、やりがいを持って働けるように、独自の福利制度を設け、生活全般を支援しています。</p>\n                </a></div>\n              </div>\n            </div>\n          </div><!-- /.top_culture -->\n\n          <div class=\"top_member all_m_member\" data-anim=\"custom\" data-no=\"0\">\n            <div class=\"all_m_member_header\">\n              <h2 class=\"all_m_member_title all_c_title_dot\"><span>人を知る</span></h2>\n              <span class=\"all_m_member_obj\"><img src=\"images/all_member_txt_obj.svg\" alt=\"Member\"></span>\n              <p class=\"all_m_member_lead\">職種も世代も様々な社員に、仕事の内容や会社の雰囲気など、普段感じていることを語っていただきました。</p>\n            </div>\n            <div class=\"all_m_member_body\">\n              <div class=\"swiper-container\">\n  <div class=\"swiper-wrapper\">\n    <div class=\"swiper-slide all_m_member_panel\">\n      <a href=\"/recruit/Interview01/\">\n        <div class=\"all_m_member_panel_img_box\">\n          <span class=\"all_m_member_panel_img_filter\"></span>\n          <span class=\"all_m_member_panel_img_bg\"></span>\n          <figure class=\"all_m_member_panel_img\"><img src=\"/recruit/images/all_member_img01.jpg\" width=\"350\" height=\"468\" alt=\"Interview01 K.K.さん\"></figure>\n        </div>\n        <p class=\"all_m_member_panel_label\">Interview 01</p>\n        <div class=\"all_m_member_panel_body\">\n          <p class=\"all_m_member_panel_title\">新しい部署、新しい仕事と共に一つずつ成長できた気がします。</p>\n          <p class=\"all_m_member_panel_info\">管理ソリューション部<br>2014年入社</p>\n          <p class=\"all_m_member_panel_name\">K.K.</p>\n        </div>\n      </a>\n    </div>\n    <div class=\"swiper-slide all_m_member_panel\">\n      <a href=\"/recruit/Interview02/\">\n        <div class=\"all_m_member_panel_img_box\">\n          <span class=\"all_m_member_panel_img_filter\"></span>\n          <span class=\"all_m_member_panel_img_bg\"></span>\n          <figure class=\"all_m_member_panel_img\"><img src=\"/recruit/images/all_member_img04.jpg\" width=\"350\" height=\"468\" alt=\"Interview02 T.W.さん\"></figure>\n        </div>\n        <p class=\"all_m_member_panel_label\">Interview 02</p>\n        <div class=\"all_m_member_panel_body\">\n          <p class=\"all_m_member_panel_title\">困難に向き合って得たスキルが、私を強くしてくれました。</p>\n          <p class=\"all_m_member_panel_info\">PMソリューション部<br>2017年入社</p>\n          <p class=\"all_m_member_panel_name\">T.W.</p>\n        </div>\n      </a>\n    </div>\n    <!-- Interview01とInterview02のclone(Interview数が増える場合はclone削除してください) -->\n    <div class=\"swiper-slide all_m_member_panel\">\n      <a href=\"/recruit/Interview01/\">\n        <div class=\"all_m_member_panel_img_box\">\n          <span class=\"all_m_member_panel_img_filter\"></span>\n          <span class=\"all_m_member_panel_img_bg\"></span>\n          <figure class=\"all_m_member_panel_img\"><img src=\"/recruit/images/all_member_img01.jpg\" width=\"350\" height=\"468\" alt=\"Interview01 K.K.さん\"></figure>\n        </div>\n        <p class=\"all_m_member_panel_label\">Interview 01</p>\n        <div class=\"all_m_member_panel_body\">\n          <p class=\"all_m_member_panel_title\">新しい部署、新しい仕事と共に一つずつ成長できた気がします。</p>\n          <p class=\"all_m_member_panel_info\">管理ソリューション部<br>2014年入社</p>\n          <p class=\"all_m_member_panel_name\">K.K.</p>\n        </div>\n      </a>\n    </div>\n     <div class=\"swiper-slide all_m_member_panel\">\n      <a href=\"/recruit/Interview02/\">\n        <div class=\"all_m_member_panel_img_box\">\n      