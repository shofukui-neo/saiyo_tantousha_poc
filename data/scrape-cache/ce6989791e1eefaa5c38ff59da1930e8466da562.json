{"url":"https://www.okinawa.ccbc.co.jp/recruite/carrier_plan/","html":"<!doctype html>\n<html lang=\"ja\">\n<head>\n<!-- Google Tag Manager --> \n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n})(window,document,'script','dataLayer','GTM-K49Q3QS');</script> \n<!-- End Google Tag Manager -->\n\n<meta charset=\"UTF-8\">\n<title>教育・キャリアプラン｜沖縄コカ･コーラボトリング採用情報</title>\n<meta name=\"description\" content=\"沖縄地域のコカ･コーラ採用情報サイト　リクルート情報　新規学卒　募集要項\">\n<meta name=\"keywords\" content=\"沖縄,コカ･コーラ,リクルート,大学卒,募集要項,募集要項\">\n<meta property=\"og:title\" content=\">教育・キャリアプラン｜沖縄コカ･コーラボトリング採用情報\">\n<meta property=\"og:type\" content=\"website\" />\n<meta property=\"og:url\" content=\"http://www.okinawa.ccbc.co.jp/recruite/carrier_plan/\">\n<meta property=\"og:image\" content=\"http://www.okinawa.ccbc.co.jp/cmn/img/logo.gif\">\n<meta property=\"og:description\" content=\"未来へ受け継いでいこうワシタチムグクルに\">\n<meta property=\"og:site_name\" content=\"沖縄コカ･コーラボトリング採用情報\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1, maximum-scale=1\">\n<meta name=\"format-detection\" content=\"telephone=no\">\n<link rel=\"shortcut icon\" href=\"/favicon.ico\"/>\n<meta name=\"apple-mobile-web-app-title\" content=\"沖縄コカコーラ\">\n<link rel=\"apple-touch-icon\" sizes=\"192x192\" href=\"/cmn/touch-icon.png\">\n<link href=\"/recruite/css/style.css\" rel=\"stylesheet\" type=\"text/css\">\n<link href=\"style.css\" rel=\"stylesheet\" type=\"text/css\">\n<script\nsrc=\"https://code.jquery.com/jquery-2.2.4.min.js\"\nintegrity=\"sha256-BbhdlvQf/xTY9gja0Dq3HiwQF8LaCRTXxZKRutelT44=\"\ncrossorigin=\"anonymous\"></script>\n<script type=\"text/javascript\" src=\"/recruite/js/script.js\"></script>\n</head>\n<body>\n<!-- Google Tag Manager (noscript) -->\n<noscript>\n<iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-K49Q3QS\"\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe>\n</noscript>\n<!-- End Google Tag Manager (noscript) --> \n<!--loding-->\n<div id=\"loader\">\n  <div class=\"spinner\">\n    <div class=\"rect1\"></div>\n    <div class=\"rect2\"></div>\n    <div class=\"rect3\"></div>\n    <div class=\"rect4\"></div>\n    <div class=\"rect5\"></div>\n  </div>\n</div>\n<!--/loding-->\n<div id=\"wrapper\"> \n  <!--header--> \n  <header>\n<div id=\"header\">\n<div class=\"sitename\">\n<h1><a href=\"/recruite/\"><img src=\"/recruite/img/logo.svg\" alt=\"沖縄コカ･コーラボトリング採用情報\" class=\"logo\"/><span class=\"siteH1\"><span class=\"corp\">沖縄コカ･コーラボトリング</span>RECRUIT SITE</span></a></h1>\n</div>\n<div class=\"contactmenu\"><a href=\"/recruite/form/\" target=\"_blank\" class=\"en\">CONTACT<span class=\"icon-forward\"></span></a></div>\n<nav>\n<ul id=\"jetmenu\" class=\"jetmenu\">\n<li><a href=\"/recruite/message/\">\n<p>社長メッセージ</p>\n</a></li>\n<li><a href=\"/recruite/vision/\">\n<p>企業ビジョン</p>\n</a></li>\n<li><a href=\"/recruite/culture/\">\n<p>企業文化</p>\n</a></li>\n<li><a href=\"/recruite/carrier_plan/\">\n<p>教育・キャリアプラン</p>\n</a></li>\n<li><a href=\"javascript:void();\">\n<p>社員インタビュー<span class=\"icon-arrow-down\"></span></p>\n</a><!--row-->\n<div class=\"megamenu full-width\">\n<div class=\"row\">\n<div class=\"memint\">\n<div class=\"title mh\">\n<h5><span class=\"en\">Interview</span>社員インタビュー</h5>\n</div>\n<ul>\n<li><a href=\"/recruite/interview/marketing.html\">\n<p><img src=\"/recruite/img/cmn/men06.jpg\" alt=\"\"/></p>\n<p class=\"text1\">トレードマーケティング部</p>\n<p class=\"text2\">新垣 凜／與久田 藍香</p>\n</a></li>\n<li><a href=\"/recruite/interview/akamine.html\">\n<p><img src=\"/recruite/img/cmn/men07.jpg\" alt=\"\"/></p>\n<p class=\"text1\">浦添工場 製造二課</p>\n<p class=\"text2\">赤嶺 孝太</p>\n</li>\n<li></li>\n</ul>\n</div>\n<a></a></div>\n</div>\n<!--/row--></li>\n<li><a href=\"/recruite/guideline/\">\n<p>募集要項</p>\n</a></li>\n</ul>\n</nav>\n</div>\n</header>\n \n  <!--/header-->\n  <main> \n    <!--　メイン画像　-->\n    <div class=\"secondtitle\">\n      <h2><span class=\"en\">Carrier Plan</span>教育・キャリアプラン</h2>\n    </div>\n    <!--　/ メイン画像　--> \n    \n    <!--　教育・キャリアプラン　-->\n    <section class=\"section1\">\n      <div class=\"trg\"></div>\n      <div class=\"sec1width\">\n        <div class=\"cariad\">\n          <div class=\"sec1t\">\n            <h2>キャリアデザイン</h2>\n          </div>\n          <p>当社は、製造から営業まで幅広い業務があり、多様なキャリアデザインが可能となっています。そのため組織の状況や社員本人の適性、自己申告制度などを基に、人事ローテーションを行っています。<br>\n            また半期に一度は必ず上長と面談する機会を設け、目標設定や自己成長、取り組みの振り返りなど、率直な意見交換を行います。<br>\n            できるだけ幅広く様々な部署の仕事を経験していただき、人としても成長し続けることを期待しています。</p>\n        </div>\n        <div class=\"cariaex\">\n          <p class=\"ext\">キャリアデザインの例（総合職・技術職共通）</p>\n          <ul class=\"eximg\">\n            <li class=\"lank1 fadein\">\n              <p class=\"position\">経営幹部</p>\n            </li>\n            <li class=\"lank2 fadein\">\n              <p class=\"position\">管理職（部長・課長）</p>\n            </li>\n            <li class=\"lank3 fadein\">\n              <p class=\"position\">監督職（マネージャー）</p>\n            </li>\n            <li class=\"fadein\">\n              <p class=\"position\">一般職</p>\n              <div class=\"occupation\">\n                <dl>\n                  <dt><span>営業職</span></dt>\n                  <dd>自販機・スーパー・市場開発など</dd>\n                </dl>\n                <dl>\n                  <dt><span>技術職</span></dt>\n                  <dd>製造・機器・SCM</dd>\n                </dl>\n                <dl>\n                  <dt><span>スタッフ職</span></dt>\n                  <dd>総務・経理など</dd>\n                </dl>\n              </div>\n            </li>\n          </ul>\n          <div class=\"female\">\n            <p class=\"fecatch\">女性が活躍できる環境も整っています</p>\n            <p>産前産後休暇、育児休暇を取得し、職場復帰した女性も活躍しています</p>\n          </div>\n        </div>\n      </div>\n    </section>\n    <!--　/ 教育・キャリアプラン　--> <!--　教育体系　-->\n    <section class=\"section2\">\n      <div class=\"sec2t\">\n        <h2>教育体系</h2>\n      </div>\n      <div class=\"read\">\n        <p>沖縄コカ･コーラボトリングでは多様な教育・研修制度を設けています。<br>\n          新入社員や中堅社員、管理職など組織における階層ごとに分けて実施する「階層別研修」、営業職や技術職など職種ごとに分けて実施する「職能別研修」、役職者から一般職まで特定の人を対象に実施する「選抜型研修」、自宅のパソコンやスマートフォンで学習するeラーニングの「自己啓発プログラム」など。</p>\n        <p>しかし、教育の目的は単なるスキルや知識の強化だけではありません。私たちが環境の変化に対応できる力量を身につけ、今後も継続して成長するために、すべての社員が常に学ぶ姿勢を持ち続ける組織を実現することが教育の真の狙いです。</p>\n      </div>\n      <div class=\"fadein taikeiimg\"><picture>\n<source media=\"(max-width: 767px)\" srcset=\"img/taikei2407_sp.png\">\n<img src=\"img/taikei2407.png\" alt=\"\">\n</picture></div>\n    </section>\n    <!--　/教育体系　--> \n  </main>\n  <!--　お問い合わせ　-->\n<aside class=\"infoLink\">\n<article class=\"contact\">\n<div class=\"basewidth\"><div class=\"all_contact\"><a href=\"tel:0988775257\" target=\"_blank\" class=\"inqtel\">\n      <p><span class=\"icon-phone\"></span><span class=\"phone\"><strong>098-877-5257</strong><i>平日9:00～17:00</i></span><span class=\"icospc\"></span></p>\n      </a><a href=\"/recruite/guideline/\"  class=\"guideline\"><p><span class=\"icon-file\"></span><span>募集要項</span><span class=\"icospc\"></span></p></a><a href=\"/recruite/form/\" target=\"_blank\"  class=\"inqmail\">\n      <p><span class=\"icon-envelope\"></span><span>採用に関するお問い合わせ</span></p>\n      </a></div>\n</div>\n</article>\n</aside>\n<!--　/ お問い合わせ　--> \n<!--footer-->\n<footer>\n<div id=\"footer\">\n<div class=\"logo\"><a href=\"/recruite/\"><img src=\"/recruite/img/logo.svg\" alt=\"沖縄コカ･コーラボトリング リクルート\"/><span class=\"siteH1\"><span class=\"corp\">沖縄コカ･コーラボトリング</span>RECRUIT SITE</span></a></div>\n<div class=\"footernav\">\n<nav>\n<dl class=\"line\">\n<dt>Contents</dt>\n<dd>\n<ul>\n<li><a href=\"/recruite/message/\">社長メッセージ</a></li>\n<li><a href=\"/recruite/vision/\">企業ビジョン</a></li>\n<li><a href=\"/recruite/culture/\">企業文化</a></li>\n<li><a href=\"/recruite/carrier_plan/\">教育・キャリアプラン</a> </li>\n<li><a href=\"/recruite/guideline/\">募集要項</a> </li>\n<li><a href=\"/recruite/form/\" target=\"_blank\">お問い合わせ</a> </li>\n</ul>\n</dd>\n</dl>\n<dl>\n<dt>Interview </dt>\n<dd>\n<ul>\n<li><a href=\"/recruite/interview/marketing.html\">新垣 凜／與久田 藍香</a></li>\n<li><a href=\"/recruite/interview/akamine.html\">赤嶺 孝太</a></li>\n</ul>\n</dd>\n</dl>\n</nav>\n</div>\n</div>\n<p class=\"copyright\">&copy; Okinawa Coca-Cola Bottling. All rigts reserved.</p>\n</footer>\n<!--/footer-->\n<p class=\"pagetop\"><a href=\"#wrapper\"><img src=\"/recruite/img/pagetop.png\" alt=\"このページのトップへ\"/></a></p>\n<!--SNSボタン-->\n<div id=\"sns\"><a href=\"https://youtube.com/channel/UChsB29BLuWGsuVKFCWQSERA?si=pPadrNdcxwR5iD5V\" target=\"_blank\"><span class=\"icon-youtube\"></span>Youtube</a><a href=\"https://www.instagram.com/okinawa_cocacola_recruit/\" target=\"_blank\"><span class=\"icon-instagram\"></span>Instagram</a></div> \n</div>\n<!--スクリプト--> \n<script type=\"text/javascript\" src=\"/recruite/js/jetmenu.js\"></script> \n<script type=\"text/javascript\" src=\"/recruite/js/common.js\"></script>\n</body>\n</html>\n","finalUrl":"https://www.okinawa.ccbc.co.jp/recruite/carrier_plan/","rendered":false,"_cachedAt":"2026-06-23T22:41:24.453Z"}