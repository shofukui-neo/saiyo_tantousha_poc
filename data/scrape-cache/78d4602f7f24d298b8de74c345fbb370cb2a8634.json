{"url":"https://www.shinko.co.jp/recruit/highschool/","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>高校生採用サイト | 新光電気工業株式会社</title>\n<meta name=\"keywords\" content=\"新光電気工業,高校生,採用情報,半導体業界,ものづくり\">\n<meta name=\"description\" content=\"新光電気工業の高校生採用ページです。半導体パッケージを主軸に世界中のお客様とビジネスを展開し、皆さんの生活の身近にあるスマートフォンやパソコンなどの&quot;便利&quot;を支えている会社です。共に未来につながる“ものづくり”をしてみませんか。\">\n<link rel=\"stylesheet\" href=\"/recruit/highschool/assets/css/style.css?v=1.04\">\n\n<script>\r\n// Do not delete this line. This is to prevent CSS transition in Chrome.\r\n</script>\r\n\r\n<!-- Global site tag (gtag.js) - Google Analytics -->\r\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=UA-113455841-1\"></script>\r\n<script>\r\n  window.dataLayer = window.dataLayer || [];\r\n  function gtag(){dataLayer.push(arguments);}\r\n  gtag('js', new Date());\r\n\r\n  gtag('config', 'UA-113455841-1');\r\n</script>\r\n\n</head>\n<body id=\"home\">\n\n<div id=\"page\">\n\n\n\n\n\n\n\n<div id=\"js-loader\" class=\"loader\"></div>\n\n<header class=\"l-header  l-header--2022\">\n\n  <h1 class=\"l-header-logo  l-header-logo--2022\">\n    <a href=\"/recruit/highschool/\" class=\"l-header-logo__link\">\n      <span class=\"l-header-logo__image\"><img src=\"/recruit/highschool/assets/img/common/logo.svg\" width=\"190\" height=\"47\" alt=\"新光電気工業株式会社\"></span>\n      <span class=\"l-header-logo__text\"><img src=\"/recruit/highschool/assets/img/common/logo_text.svg\" width=\"101\" height=\"27\" alt=\"新光電気 高校生採用サイト\"></span>\n    </a>\n  </h1>\n\n  <nav class=\"l-header-nav\">\n    <div class=\"l-header-nav__inner\">\n      <ul class=\"l-header-nav__list\">\n        <li class=\"l-header-nav__item\"><a href=\"/recruit/highschool/\" class=\"l-header-nav__link  js-home-anchor-target\">高校生採用トップ</a></li>\n        <li class=\"l-header-nav__item\"><a href=\"/recruit/highschool/#anchor05\" class=\"l-header-nav__link  js-home-anchor-target\">高校生・保護者・学校関係者の皆さまへ</a></li>\n        <li class=\"l-header-nav__item\"><a href=\"/recruit/highschool/#anchor01\" class=\"l-header-nav__link  js-home-anchor-target\">新光電気ってどんな会社？</a></li>\n        <li class=\"l-header-nav__item\"><a href=\"/recruit/highschool/#anchor02\" class=\"l-header-nav__link  js-home-anchor-target\">新光電気の仕事を知る</a></li>\n        <li class=\"l-header-nav__item\"><a href=\"/recruit/highschool/#anchor03\" class=\"l-header-nav__link  js-home-anchor-target\">先輩社員に聞いてみた！</a></li>\n        <li class=\"l-header-nav__item\"><a href=\"/recruit/highschool/#anchor04\" class=\"l-header-nav__link  js-home-anchor-target\">採用担当者の顔</a></li>\n        <li class=\"l-header-nav__item\"><a href=\"/recruit/highschool/guideline/#guideline02\" class=\"l-header-nav__link  js-guideline-anchor-target\">募集要項</a></li>\n        <li class=\"l-header-nav__item\"><a href=\"/recruit/highschool/guideline/#guideline01\" class=\"l-header-nav__link  js-guideline-anchor-target\">Q &amp; A</a></li>\n        <li class=\"l-header-nav__item\"><a href=\"/recruit/entry/\" target=\"_blank\" class=\"l-header-nav__link\">お問い合わせ</a></li>\n      </ul>\n\n    <!-- /.l-header-nav__inner --></div>\n  </nav>\n\n\n\n  <button class=\"l-header-button\" id=\"js-header-button\">\n    <span class=\"l-header-button__item\"></span>\n    <span class=\"l-header-button__item\"></span>\n    <span class=\"l-header-button__item\"></span>\n  </button>\n\n</header>\n\n\n<main>\n\n\n<div class=\"p-home-visual\">\n  <p class=\"p-home-visual__bg\"><img src=\"/recruit/highschool/assets/img/home/visual_bg.svg\" width=\"591\" height=\"990\" alt=\"\"></p>\n  <div class=\"p-home-visual-illust\">\n    <div class=\"p-home-visual-illust__item  p-home-visual-illust__item--01\"><img src=\"/recruit/highschool/assets/img/home/visual_illust01.svg\" width=\"246\" height=\"108\" alt=\"\"></div>\n    <div class=\"p-home-visual-illust__item  p-home-visual-illust__item--02\"><img src=\"/recruit/highschool/assets/img/home/visual_illust02.svg\" width=\"181\" height=\"141\" alt=\"\"></div>\n    <div class=\"p-home-visual-illust__item  p-home-visual-illust__item--03\"><img src=\"/recruit/highschool/assets/img/home/visual_illust03.svg\" width=\"141\" height=\"127\" alt=\"\"></div>\n    <div class=\"p-home-visual-illust__item  p-home-visual-illust__item--04\"><img src=\"/recruit/highschool/assets/img/home/visual_illust04.svg\" width=\"164\" height=\"94\" alt=\"\"></div>\n    <div class=\"p-home-visual-illust__item  p-home-visual-illust__item--05\"><img src=\"/recruit/highschool/assets/img/home/visual_illust05.svg\" width=\"106\" height=\"114\" alt=\"\"></div>\n    <div class=\"p-home-visual-illust__item  p-home-visual-illust__item--06\"><img src=\"/recruit/highschool/assets/img/home/visual_illust06.svg\" width=\"148\" height=\"130\" alt=\"\"></div>\n    <div class=\"p-home-visual-illust__item  p-home-visual-illust__item--07\"><img src=\"/recruit/highschool/assets/img/home/visual_illust07.svg\" width=\"110\" height=\"133\" alt=\"\"></div>\n    <div class=\"p-home-visual-illust__item  p-home-visual-illust__item--08\"><img src=\"/recruit/highschool/assets/img/home/visual_illust08.svg\" width=\"209\" height=\"120\" alt=\"\"></div>\n    <div class=\"p-home-visual-illust__item  p-home-visual-illust__item--09\"><img src=\"/recruit/highschool/assets/img/home/visual_illust09.svg\" width=\"138\" height=\"138\" alt=\"\"></div>\n    <div class=\"p-home-visual-illust__item  p-home-visual-illust__item--10\"><img src=\"/recruit/highschool/assets/img/home/visual_illust10.svg\" width=\"130\" height=\"140\" alt=\"\"></div>\n    <div class=\"p-home-visual-illust__item  p-home-visual-illust__item--11\"><img src=\"/recruit/highschool/assets/img/home/visual_illust11.svg\" width=\"110\" height=\"122\" alt=\"\"></div>\n    <div class=\"p-home-visual-illust__item  p-home-visual-illust__item--12\"><img src=\"/recruit/highschool/assets/img/home/visual_illust12.svg\" width=\"117\" height=\"142\" alt=\"\"></div>\n    <div class=\"p-home-visual-illust__item  p-home-visual-illust__item--13\"><img src=\"/recruit/highschool/assets/img/home/visual_illust13.svg\" width=\"169\" height=\"132\" alt=\"\"></div>\n    <div class=\"p-home-visual-illust__item  p-home-visual-illust__item--14\"><img src=\"/recruit/highschool/assets/img/home/visual_illust14.svg\" width=\"139\" height=\"143\" alt=\"\"></div>\n    <div class=\"p-home-visual-illust__item  p-home-visual-illust__item--15\"><img src=\"/recruit/highschool/assets/img/home/visual_illust15.svg\" width=\"152\" height=\"163\" alt=\"\"></div>\n  <!-- /.p-home-visual-illust --></div>\n  <div class=\"p-home-visual__inner\">\n\n    <div class=\"p-home-visual__item01\">\n      <div class=\"p-home-visual-tagline01\">\n        <p class=\"p-home-visual-tagline01__text\"><img src=\"/recruit/highschool/assets/img/home/tagline01_01.svg\" width=\"631\" height=\"97\" alt=\"君のチカラは、\"></p>\n        <p class=\"p-home-visual-tagline01__text\"><img src=\"/recruit/highschool/assets/img/home/tagline01_02.svg\" width=\"622\" height=\"97\" alt=\"世界のチカラ\"></p>\n      <!-- /.p-home-visual-tagline01 --></div>\n      <p class=\"p-home-visual-tagline02\"><img src=\"/recruit/highschool/assets/img/home/tagline02.svg\" width=\"680\" height=\"69\" alt=\"\" class=\"pc\"><img src=\"/recruit/highschool/assets/img/home/tagline02_sp.svg\" width=\"680\" height=\"69\" alt=\"\" class=\"sp\"></p>\n    <!-- /.p-home-visual__item01 --></div>\n\n    <div class=\"p-home-visual__item02\">\n      <div class=\"p-home-visual-character\">\n        <p class=\"p-home-visual-character__image01\"><img src=\"/recruit/highschool/assets/img/home/visual_main01.svg\" width=\"484\" height=\"678\" alt=\"\"></p>\n        <p class=\"p-home-visual-character__image02\"><img src=\"/recruit/highschool/assets/img/home/visual_main02.svg\" width=\"364\" height=\"627\" alt=\"\"></p>\n      <!-- /.p-home-visual-character --></div>\n    <!-- /.p-home-visual__item02 --></div>\n\n  <!-- /.p-home-visual__inner --></div>\n<!-- /.p-home-visual --></div>\n\n\n<div class=\"p-home-introduction\" id=\"anchor05\">\n  <div class=\"p-home-introduction__inner\">\n    <div class=\"p-home-introduction__content\">\n      <h3 class=\"p-home-introduction__title\" data-aos=\"fade-in\">高校生向け<br class=\"sp\">採用活動について</h3>\n      <p class=\"p-home-introduction__subtitle\" data-aos=\"fade-in\">高校生・保護者・学校関係者の<br class=\"sp\">皆さまへ</p>\n      <div class=\"p-home-introduction__body\" data-aos=\"fade-in\">\n        <p><span>当社は半導体パッケージを主軸に世界中のお客様とビジネスを展開し、皆さんの生活の身近にあるスマートフォンやパソコンなどの\"便利\"を支えている会社です。日々目まぐるしい進化を遂げる半導体業界で、創業以来培ってきた技術力をベースに、世の中になくてはならない製品を作っています。</span></p>\r\n<p><span>また、新光電気グループは、社会における我々の存在意義を表したミッションにおいて「最先端のテクノロジーとものづくりで、人々の暮らしを豊かに彩り、輝かしい未来の創造に貢献する」と定め、新たな価値を創造することにより社会の持続的成長に貢献することを目指しています。</span></p>\r\n<p><span>高校生の皆さん、新光電気の一員として、力を発揮してみませんか？</span></p>\r\n<p><span>皆さんと一緒に働けることを心より楽しみにしております。</span></p>\r\n<p style=\"text-align: right;\"><span>人材開発部長　前 　千尋</span></p>\n      <!-- /.p-home-introduction__content --></div>\n    <!-- /.p-home-introduction__content --></div>\n    <p class=\"p-home-introduction__image\"><img src=\"/recruit/highschool/assets/img/home/introduction_img.png\" width=\"522\" height=\"324\" alt=\"\"></p>\n  <!-- /.p-home-introduction__inner --></div>\n<!-- /.p-home-introduction --></div>\n\n\n\n\n<div class=\"p-home-contents\">\n\n<div class=\"p-home-nav\" data-aos=\"fade-in\">\n  <ul class=\"p-home-nav__list\">\n    <li class=\"p-home-nav__item\"><a href=\"#anchor01\" class=\"p-home-nav__link\">新光電気って<br>どんな会社？</a></li>\n    <li class=\"p-home-nav__item\"><a href=\"#anchor02\" class=\"p-home-nav__link\">新光電気の<br>仕事を知る</a></li>\n    <li class=\"p-home-nav__item\"><a href=\"#anchor03\" class=\"p-home-nav__link\">先輩社員に<br>聞いてみた！</a></li>\n    <li class=\"p-home-nav__item\"><a href=\"#anchor04\" class=\"p-home-nav__link\">採用担当者の顔</a></li>\n  </ul>\n<!-- /.p-home-nav --></div>\n\n\n<div class=\"p-home-about\" id=\"anchor01\">\n  <div class=\"p-home-about__inner\">\n    <h3 class=\"p-home-heading\" data-aos=\"fade-in\"><span class=\"p-home-pic__decoration\">新光電気</span>ってどんな会社？</h3>\n    <p class=\"p-home-about__text\" data-aos=\"fade-in\">新光電気は、半導体の小型化、高速化、高機能化に対応するさまざまな「半導体パッケージ」の開発・製造を行っています！</p>\n    <div class=\"p-home-about-data\">\n      <div class=\"p-home-about-data__item\" data-aos=\"fade-in\" data-aos-id=\"home-about\">\n        <h4 class=\"p-home-about-data__title\">創立</h4>\n        <p class=\"p-home-about-data__image\"><img src=\"/recruit/highschool/assets/img/home/about_graf01.svg\" width=\"200\" height=\"104\" alt=\"\"></p>\n        <p class=\"p-home-about-data__text01\"><span class=\"p-home-about-data__number  js-odometer\" data-countup-default=\"0000\">1946</span><span class=\"p-home-about-data__unit\">年</span></p>\n      <!-- /.p-home-about-data__item --></div>\n\n      <div class=\"p-home-about-data__item\" data-aos=\"fade-in\" data-aos-id=\"home-about\">\n        <h4 class=\"p-home-about-data__title\">海外売上比率</h4>\n        <p class=\"p-home-about-data__image\"><img src=\"/recruit/highschool/assets/img/home/about_graf02.svg?v=1\" width=\"200\" height=\"104\" alt=\"\"></p>\n        <p class=\"p-home-about-data__text01\"><span class=\"p-home-about-data__unit\">約</span><span class=\"p-home-about-data__number  js-odometer\" data-countup-default=\"00\">90</span><span class=\"p-home-about-data__unit\">%</span></p>\n      <!-- /.p-home-about-data__item --></div>\n\n      <div class=\"p-home-about-data__item\" data-aos=\"fade-in\" data-aos-id=\"home-about\">\n        <h4 class=\"p-home-about-data__title\">グループ連結売上</h4>\n        <p class=\"p-home-about-data__image\"><img src=\"/recruit/highschool/assets/img/home/about_graf03.svg\" width=\"200\" height=\"104\" alt=\"\"></p>\n        <p class=\"p-home-about-data__text01\"><span class=\"p-home-about-data__number  js-odometer\" data-countup-default=\"0,000\">2,150</span><span class=\"p-home-about-data__unit\">億円</span></p>\n        <p class=\"p-home-about-data__text02\">（2024年度連結）</p>\n      <!-- /.p-home-about-data__item --></div>\n\n      <div class=\"p-home-about-data__item\" data-aos=\"fade-in\" data-aos-id=\"home-about\">\n        <h4 class=\"p-home-about-data__title\">従業員数</h4>\n        <p class=\"p-home-about-data__image\"><img src=\"/recruit/highschool/assets/img/home/about_graf04.svg\" width=\"200\" height=\"104\" alt=\"\"></p>\n        <p class=\"p-home-about-data__text01\"><span class=\"p-home-about-data__number  js-odometer\" data-countup-default=\"0,000\">5,256</span><span class=\"p-home-about-data__unit\">人</span></p>\n        <p class=\"p-home-about-data__text02\">（2026年3月末）</p>\n      <!-- /.p-home-about-data__item --></div>\n\n      <div class=\"p-home-about-data__item\" data-aos=\"fade-in\" data-aos-id=\"home-about\">\n        <h4 class=\"p-home-about-data__title\">平均勤続年数</h4>\n        <p class=\"p-home-about-data__image\"><img src=\"/recruit/highschool/assets/img/home/about_graf05.svg\" width=\"200\" height=\"104\" alt=\"\"></p>\n        <p class=\"p-home-about-data__text01\"><span class=\"p-home-about-data__number  js-odometer\" data-countup-default=\"00.0\">18.2</span><span class=\"p-home-about-data__unit\">年</span></p>\n        <p class=\"p-home-about-data__text02\">（2024年度）</p>\n      <!-- /.p-home-about-data__item --></div>\n\n      <div class=\"p-home-about-data__item\" data-aos=\"fade-in\" data-aos-id=\"home-about\">\n        <h4 class=\"p-home-about-data__title\">年間休日</h4>\n        <p class=\"p-home-about-data__image\"><img src=\"/recruit/highschool/assets/img/home/about_graf06.svg\" width=\"200\" height=\"104\" alt=\"\"></p>\n        <p class=\"p-home-about-data__text01\"><span class=\"p-home-about-data__number  js-odometer\" data-countup-default=\"000\">126</span><span class=\"p-home-about-data__unit\">日</span></p>\n        <p class=\"p-home-about-data__text02\">（2025年度）</p>\n      <!-- /.p-home-about-data__item --></div>\n    <!-- /.p-home-about-data --></div>\n  <!-- /.p-home-about__inner --></div>\n<!-- /.p-home-about --></div>\n\n\n<div class=\"p-home-interview\" id=\"anchor02\">\n  <div class=\"p-home-interview__inner\">\n    <h3 class=\"p-home-heading\" data-aos=\"fade-in\"><span class=\"p-home-pic__decoration\">新光電気</span>の仕事を知る</h3>\n    <p class=\"p-home-interview__text\" data-aos=\"fade-in\">先輩社員が活躍する3職種について、各職種のインタビューとあわせてご紹介します！</p>\n\n    <div class=\"p-home-interview__item\">\n      <div class=\"p-home-interview-jobs\">\n\n        <div class=\"p-home-interview-jobs__header\">\n          <p class=\"p-home-interview-jobs__number\">01</p>\n          <h4 class=\"p-home-interview-jobs__title\">加工オペレーター職</h4>\n          <p class=\"p-home-interview-jobs__image\"><img src=\"/recruit/highschool/assets/img/home/jobs_img01.png\" width=\"270\" height=\"253\" alt=\"\"></p>\n          <div class=\"p-home-interview-jobs__text\">\n\n\n\n            <ul class=\"p-home-interview-jobs__list\">\n              <li>製品の製造装置操作</li><li>製造装置の異常チェック</li>\n            </ul>\n\n\n            <p>など</p>\n\n          <!-- /.p-home-interview-jobs__text --></div>\n        <!-- /.p-home-interview-jobs__header --></div>\n\n        <div class=\"p-home-interview-cards\" data-aos=\"fade-in\">\n\n<div class=\"p-home-interview-cards__item\">\n        <a href=\"https://www.shinko.co.jp/recruit/highschool/interview/interview02/\" class=\"c-interview-card\">\n          <div class=\"c-interview-card__col01\">\n            <p class=\"c-interview-card__image\" data-lead=\"多い仕事量をこなせた達成感将来は多能工な人材に\"><img src=\"https://www.shinko.co.jp/recruit/assets_c/2023/09/7482cabf979ca7cd5cdb4add81935964d94d4564-thumb-280xauto-4521.png\" width=\"280\" height=\"300\" alt=\"\"></p>\n            <p class=\"c-interview-card__lead\">多い仕事量をこなせた達成感将来は多能工な人材に</p>\n          <!-- /.c-interview-card__col01 --></div>\n          <div class=\"c-interview-card__col02\">\n            <p class=\"c-interview-card__title\">先輩インタビュー</p>\n            <p class=\"c-interview-card__department\">アセンブリ事業部門<br>加工オペレーター職</p>\n            <p class=\"c-interview-card__name\">T. SAKAI</p>\n            <p class=\"c-interview-card__joined\">2018年入社</p>\n          <!-- /.c-interview-card__col02 --></div>\n        </a>\n      <!-- /.p-home-interview-cards__item --></div>\n\n\n  \n      <div class=\"p-home-interview-cards__item\">\n        <a href=\"https://www.shinko.co.jp/recruit/highschool/interview/interview01/\" class=\"c-interview-card\">\n          <div class=\"c-interview-card__col01\">\n            <p class=\"c-interview-card__image\" data-lead=\"スピード感持って達成待遇の良さもやりがいに\"><img src=\"https://www.shinko.co.jp/recruit/assets_c/2022/06/interview01_1-thumb-280xauto-3515.png\" width=\"280\" height=\"300\" alt=\"\"></p>\n            <p class=\"c-interview-card__lead\">スピード感持って達成待遇の良さもやりがいに</p>\n          <!-- /.c-interview-card__col01 --></div>\n          <div class=\"c-interview-card__col02\">\n            <p class=\"c-interview-card__title\">先輩インタビュー</p>\n            <p class=\"c-interview-card__department\">リードフレーム事業部門<br>加工オペレーター職</p>\n            <p class=\"c-interview-card__name\">K.SHIONOIRI</p>\n            <p class=\"c-interview-card__joined\">2018年入社</p>\n          <!-- /.c-interview-card__col02 --></div>\n        </a>\n      <!-- /.p-home-interview-cards__item --></div>\n\n\n        <!-- /.p-home-interview-cards --></div>\n\n      <!-- /.p-home-interview-jobs --></div>\n    <!-- /.p-home-interview__item --></div>\n\n    <div class=\"p-home-interview__item\">\n      <div class=\"p-home-interview-jobs\">\n\n        <div class=\"p-home-interview-jobs__header\">\n          <p class=\"p-home-interview-jobs__number\">02</p>\n          <h4 class=\"p-home-interview-jobs__title\">検査オペレーター職</h4>\n          <p class=\"p-home-interview-jobs__image\"><img src=\"/recruit/highschool/assets/img/home/jobs_img02.png\" width=\"270\" height=\"253\" alt=\"\"></p>\n          <div class=\"p-home-interview-jobs__text\">\n\n\n\n            <ul class=\"p-home-interview-jobs__list\">\n              <li>製造中の製品検査</li><li>製品の歩留り改善（良い製品を作るための工夫）、効率化</li>\n            </ul>\n\n\n            <p>など</p>\n\n          <!-- /.p-home-interview-jobs__text --></div>\n        <!-- /.p-home-interview-jobs__header --></div>\n\n        <div class=\"p-home-interview-cards\" data-aos=\"fade-in\">\n\n<div class=\"p-home-interview-cards__item\">\n        <a href=\"https://www.shinko.co.jp/recruit/highschool/interview/interview04/\" class=\"c-interview-card\">\n          <div class=\"c-interview-card__col01\">\n            <p class=\"c-interview-card__image\" data-lead=\"生産性を高める効率化にも取り組みたい\"><img src=\"https://www.shinko.co.jp/recruit/assets_c/2023/04/8c09f0d5d1ce1aa3cafb80ea86ceb27bea99cc44-thumb-280xauto-4309.png\" width=\"280\" height=\"300\" alt=\"\"></p>\n            <p class=\"c-interview-card__lead\">生産性を高める効率化にも取り組みたい</p>\n          <!-- /.c-interview-card__col01 --></div>\n          <div class=\"c-interview-card__col02\">\n            <p class=\"c-interview-card__title\">先輩インタビュー</p>\n            <p class=\"c-interview-card__department\">コンポーネント事業部門<br>検査オペレーター職</p>\n            <p class=\"c-interview-card__name\">K. MURAYAMA</p>\n            <p class=\"c-interview-card__joined\">2019年入社</p>\n          <!-- /.c-interview-card__col02 --></div>\n        </a>\n      <!-- /.p-home-interview-cards__item --></div>\n\n\n  \n      <div class=\"p-home-interview-cards__item\">\n        <a href=\"https://www.shinko.co.jp/recruit/highschool/interview/interview03/\" class=\"c-interview-card\">\n          <div class=\"c-interview-card__col01\">\n            <p class=\"c-interview-card__image\" data-lead=\"人を大切にした風通しのいい環境が魅力\"><img src=\"https://www.shinko.co.jp/recruit/assets_c/2023/07/839d11e55072e8dd2521cb9737b2db0a0d5a2525-thumb-280xauto-4478.png\" width=\"280\" height=\"300\" alt=\"\"></p>\n            <p class=\"c-interview-card__lead\">人を大切にした風通しのいい環境が魅力</p>\n          <!-- /.c-interview-card__col01 --></div>\n          <div class=\"c-interview-card__col02\">\n            <p class=\"c-interview-card__title\">先輩インタビュー</p>\n            <p class=\"c-interview-card__department\">第二PLP事業部門<br>検査オペレーター職</p>\n            <p class=\"c-interview-card__name\">C. ISHIDA</p>\n            <p class=\"c-interview-card__joined\">2020年入社</p>\n          <!-- /.c-interview-card__col02 --></div>\n        </a>\n      <!-- /.p-home-interview-cards__item --></div>\n\n\n        <!-- /.p-home-interview-cards --></div>\n\n      <!-- /.p-home-interview-jobs --></div>\n    <!-- /.p-home-interview__item --></div>\n\n    <div class=\"p-home-interview__item\">\n      <div class=\"p-home-interview-jobs\">\n\n        <div class=\"p-home-interview-jobs__header\">\n          <p class=\"p-home-interview-jobs__number\">03</p>\n          <h4 class=\"p-home-interview-jobs__title\">設備保全職</h4>\n          <p class=\"p-home-interview-jobs__image\"><img src=\"/recruit/highschool/assets/img/home/jobs_img03.png\" width=\"270\" height=\"253\" alt=\"\"></p>\n          <div class=\"p-home-interview-jobs__text\">\n\n\n\n            <ul class=\"p-home-interview-jobs__list\">\n              <li>工場内の機械メンテナンス</li><li>故障の予防、故障後の修理作業</li>\n            </ul>\n\n\n            <p>など</p>\n\n          <!-- /.p-home-interview-jobs__text --></div>\n        <!-- /.p-home-interview-jobs__header --></div>\n\n        <div class=\"p-home-interview-cards\" data-aos=\"fade-in\">\n\n<div class=\"p-home-interview-cards__item\">\n        <a href=\"https://www.shinko.co.jp/recruit/highschool/interview/interview05/\" class=\"c-interview-card\">\n          <div class=\"c-interview-card__col01\">\n            <p class=\"c-interview-card__image\" data-lead=\"常に向上心を持ち続け、いずれはリーダーに\"><img src=\"https://www.shinko.co.jp/recruit/assets_c/2022/06/interview03_1-thumb-280xauto-3509.png\" width=\"280\" height=\"300\" alt=\"\"></p>\n            <p class=\"c-interview-card__lead\">常に向上心を持ち続け、いずれはリーダーに</p>\n          <!-- /.c-interview-card__col01 --></div>\n          <div class=\"c-interview-card__col02\">\n            <p class=\"c-interview-card__title\">先輩インタビュー</p>\n            <p class=\"c-interview-card__department\">第一PLP事業部門<br>設備保全職</p>\n            <p class=\"c-interview-card__name\">M. MIYAZAWA</p>\n            <p class=\"c-interview-card__joined\">2018年入社</p>\n          <!-- /.c-interview-card__col02 --></div>\n        </a>\n      <!-- /.p-home-interview-cards__item --></div>\n\n\n        <!-- /.p-home-interview-cards --></div>\n\n      <!-- /.p-home-interview-jobs --></div>\n    <!-- /.p-home-interview__item --></div>\n\n  <!-- /.p-home-interview__inner --></div>\n<!-- /.p-home-interview --></div>\n\n\n<div class=\"p-home-questionnaire01\" id=\"anchor03\">\n  <div class=\"p-home-questionnaire01__inner\">\n    <h3 class=\"p-home-heading\" data-aos=\"fade-in\"><span class=\"p-home-pic__decoration\">先輩社員</span>に聞いてみた！</h3>\n    <p class=\"p-home-questionnaire01__subtitle\" data-aos=\"fade-in\">（採用担当調べ）</p>\n    <p class=\"p-home-questionnaire01__text\" data-aos=\"fade-in\">先輩社員に就職活動中のことについて<br class=\"sp\">アンケートを実施しました！</p>\n\n    <div class=\"p-home-questions\">\n      <div class=\"p-home-questions__item\">\n        <h4 class=\"p-home-questions__title\" data-aos=\"fade-in\"><span class=\"p-home-questions__q\">Q1.</span>新光電気に入社しようと思ったキッカケはなんでしたか？</h4>\n        <div class=\"p-home-questions__content\" data-aos=\"fade-in\">\n          <p class=\"pc\"><img src=\"/recruit/highschool/assets/img/home/questionnaire01_img01.png\" width=\"1300\" height=\"760\" alt=\"\"></p>\n          <p class=\"sp\"><img src=\"/recruit/highschool/assets/img/home/questionnaire01_img01_sp.png\" width=\"1000\" height=\"960\" alt=\"\"></p>\n        <!-- /.p-home-questions__content --></div>\n      <!-- /.p-home-questions__item --></div>\n\n      <div class=\"p-home-questions__item\">\n        <h4 class=\"p-home-questions__title\" data-aos=\"fade-in\"><span class=\"p-home-questions__q\">Q2.</span>新光電気に入社して、どんな社会人になりたいですか？</h4>\n        <div class=\"p-home-questions__content\" data-aos=\"fade-in\">\n          <p class=\"pc\"><img src=\"/recruit/highschool/assets/img/home/questionnaire01_img02.png\" width=\"1300\" height=\"849\" alt=\"\"></p>\n          <p class=\"sp\"><img src=\"/recruit/highschool/assets/img/home/questionnaire01_img02_sp.png\" width=\"1000\" height=\"1307\" alt=\"\"></p>\n        <!-- /.p-home-questions__content --></div>\n      <!-- /.p-home-questions__item --></div>\n\n      <div class=\"p-home-questions__item\">\n        <h4 class=\"p-home-questions__title\" data-aos=\"fade-in\"><span class=\"p-home-questions__q\">Q3.</span>働くことを意識し、考え始めた時期を教えてください。</h4>\n        <div class=\"p-home-questions__content\" data-aos=\"fade-in\">\n          <p class=\"pc\"><img src=\"/recruit/highschool/assets/img/home/questionnaire01_img03.png\" width=\"1300\" height=\"600\" alt=\"\"></p>\n          <p class=\"sp\"><img src=\"/recruit/highschool/assets/img/home/questionnaire01_img03_sp.png\" width=\"1000\" height=\"677\" alt=\"\"></p>\n        <!-- /.p-home-questions__content --></div>\n      <!-- /.p-home-questions__item --></div>\n\n      <div class=\"p-home-questions__item\">\n        <h4 class=\"p-home-questions__title\" data-aos=\"fade-in\"><span class=\"p-home-questions__q\">Q4.</span>就職活動の中でどんな悩みを持っていましたか？</h4>\n        <div class=\"p-home-questions__content\" data-aos=\"fade-in\">\n          <p class=\"pc\"><img src=\"/recruit/highschool/assets/img/home/questionnaire01_img04.png\" width=\"1300\" height=\"790\" alt=\"\"></p>\n          <p class=\"sp\"><img src=\"/recruit/highschool/assets/img/home/questionnaire01_img04_sp.png\" width=\"1000\" height=\"987\" alt=\"\"></p>\n        <!-- /.p-home-questions__content --></div>\n      <!-- /.p-home-questions__item --></div>\n\n      <div class=\"p-home-questions__item\">\n        <h4 class=\"p-home-questions__title\" data-aos=\"fade-in\"><span class=\"p-home-questions__q\">Q5.</span>就職するにあたって悩みがあった際は誰に相談していましたか？</h4>\n        <div class=\"p-home-questions__content\" data-aos=\"fade-in\">\n          <p class=\"pc\"><img src=\"/recruit/highschool/assets/img/home/questionnaire01_img05.png\" width=\"1300\" height=\"720\" alt=\"\"></p>\n          <p class=\"sp\"><img src=\"/recruit/highschool/assets/img/home/questionnaire01_img05_sp.png\" width=\"1000\" height=\"853\" alt=\"\"></p>\n        <!-- /.p-home-questions__content --></div>\n      <!-- /.p-home-questions__item --></div>\n    <!-- /.p-home-questions --></div>\n\n  <!-- /.p-home-questionnaire01__inner --></div>\n<!-- /.p-home-questionnaire01 --></div>\n\n\n<div class=\"p-home-questionnaire02\">\n  <div class=\"p-home-questionnaire02__inner\">\n    <h3 class=\"p-home-questionnaire02__title\" data-aos=\"fade-in\">新光電気なら！<br>そんな悩みがあっても<br><span class=\"p-home-questionnaire02__mark\">大</span><span class=\"p-home-questionnaire02__mark\">丈</span><span class=\"p-home-questionnaire02__mark\">夫</span>です！</h3>\n    <div class=\"p-home-questionnaire02-list\">\n      <div class=\"p-home-questionnaire02-list__item\" data-aos=\"fade-in\">\n        <p class=\"p-home-questionnaire02-list__image\"><img src=\"https://www.shinko.co.jp/recruit/images/highschool_questionnaire02_img01_202308.png\" width=\"400\" height=\"280\" alt=\"\"></p>\n        <h4 class=\"p-home-questionnaire02-list__title\">職場では先輩社員が<br>サポートをしてくれます！</h4>\n        <div class=\"p-home-questionnaire02-list__text\">\n          <p>入社後は年齢や社歴の近い先輩社員が業務や社会人生活をサポートしてくれ、自分らしく成長・活躍できるよう後押しをしてくれます。入社後の様々な不安や悩みを相談できる、温かい環境です。</p>\n        </div>\n      <!-- /.p-home-questionnaire02-list__item --></div>\n\n      <div class=\"p-home-questionnaire02-list__item\" data-aos=\"fade-in\">\n        <p class=\"p-home-questionnaire02-list__image\"><img src=\"https://www.shinko.co.jp/recruit/images/highschool_questionnaire02_img02_202308.png\" width=\"400\" height=\"280\" alt=\"\"></p>\n        <h4 class=\"p-home-questionnaire02-list__title\">教育体制が充実！<br>新光テクノアカデミー</h4>\n        <div class=\"p-home-questionnaire02-list__text\">\n          <p>ものづくり現場で必要とされる知識を実習しながら体系的に学べる場として、社内教育機関「<a href=\"/rd/pe/academy.php\" target=\"_blank\" rel=\"noopener\">新光テクノアカデミー</a>」を開講し、教育プログラムの充実をはかっています。ここで学ぶことで高い技術力と知識を身につけることができます。</p>\n        </div>\n      <!-- /.p-home-questionnaire02-list__item --></div>\n\n      <div class=\"p-home-questionnaire02-list__item\" data-aos=\"fade-in\">\n        <p class=\"p-home-questionnaire02-list__image\"><img src=\"https://www.shinko.co.jp/recruit/images/highschool_questionnaire02_img03_202308.png\" width=\"400\" height=\"280\" alt=\"\"></p>\n        <h4 class=\"p-home-questionnaire02-list__title\">見て！聞いて！<br>楽しく学べる会社見学会</h4>\n        <div class=\"p-home-questionnaire02-list__text\">\n          <p>仕事内容・働き方がわかります。採用試験に関する疑問にも採用担当がお答えします！</p>\n        </div>\n      <!-- /.p-home-questionnaire02-list__item --></div>\n    <!-- /.p-home-questionnaire02-list --></div>\n  <!-- /.p-home-questionnaire02__inner --></div>\n<!-- /.p-home-questionnaire02 --></div>\n\n\n<div class=\"p-home-pic\" id=\"anchor04\">\n  <div class=\"p-home-pic__inner\">\n  <h3 class=\"p-home-heading\" data-aos=\"fade-in\"><span class=\"p-home-pic__decoration\">採用担当者</span>の顔</h3>\n    <div class=\"p-home-pic-content\" data-aos=\"fade-in\">\n      <div class=\"p-home-pic-content__item01\">\n        <picture class=\"p-home-pic-content__image\"></picture>\n      <!-- /.p-home-pic-content__item01 --></div>\n      <div class=\"p-home-pic-content__item02\">\n        <h4 class=\"p-home-pic-content__title\">私たちが新光電気の<br>採用を担当しています！</h4>\n        <div class=\"p-home-pic-content__text\">\n          <p><span>働くとはどういうことなのか、自分でも働けるのか、そんな皆さんの不安を解決させていただくため、私たちが全力でサポートいたします！皆さんと一緒に働けることを心より楽しみにしております！</span></p>\n        </div>\n      <!-- /.p-home-pic-content__item02 --></div>\n    <!-- /.p-home-pic-content --></div>\n\n    <ul class=\"p-home-pic-nav\">\n      <li class=\"p-home-pic-nav__item\"><a href=\"/recruit/highschool/guideline/#guideline02\" data-aos=\"fade-in\" class=\"p-home-pic-nav__link\">募集要項</a></li>\n      <li class=\"p-home-pic-nav__item\"><a href=\"/recruit/highschool/guideline/#guideline01\" data-aos=\"fade-in\" class=\"p-home-pic-nav__link\">Q＆A</a></li>\n    </ul>\n\n  <!-- /.p-home-pic__inner --></div>\n<!-- /.p-home-pic --></div>\n\n<!-- /.p-home-contents --></div>\n\n<p class=\"c-page-top\"><a href=\"#page\" class=\"c-page-top__link\"><img src=\"/recruit/highschool/assets/img/common/page_top.svg\" width=\"26\" height=\"42\" alt=\"\"></a></p>\n\n</main>\n\n\n\n<footer class=\"l-footer\">\r\n  <div class=\"l-footer__upper\">\r\n    <div class=\"l-footer__inner  l-footer__inner--01\">\r\n      <div class=\"l-footer-title\">\r\n        <div class=\"l-footer-title__logo\">\r\n          <a href=\"/recruit/highschool/\" class=\"l-footer-title__link\">\r\n            <p class=\"l-footer-title__logo01\"><img src=\"/recruit/highschool/assets/img/common/logo.svg\" width=\"190\" height=\"47\" alt=\"新光電気工業株式会社\"></p>\r\n            <p class=\"l-footer-title__logo02\"><img src=\"/recruit/highschool/assets/img/common/logo_text.svg\" width=\"101\" height=\"27\" alt=\"新光電気 高校生採用サイト\"></p>\r\n          </a>\r\n        <!-- /.l-footer-title__logo --></div>\r\n        <p class=\"l-footer-title__tagline01\"><img src=\"/recruit/highschool/assets/img/common/footer_tagline01.svg\" width=\"214\" height=\"81\" alt=\"君のチカラは、世界のチカラ\"></p>\r\n        <p class=\"l-footer-title__tagline02\"><img src=\"/recruit/highschool/assets/img/common/footer_tagline02.svg\" width=\"218\" height=\"18\" alt=\"未来につながる &quot;ものづくり&quot;\"></p>\r\n      <!-- /.l-footer-title --></div>\r\n\r\n      <ul class=\"l-fooer-nav01\">\r\n        <li class=\"l-fooer-nav01__item\"><a href=\"/recruit/highschool/\" class=\"l-fooer-nav01__link\">トップページ</a></li>\r\n        <li class=\"l-fooer-nav01__item\"><a href=\"/recruit/highschool/#anchor05\" class=\"l-fooer-nav01__link  js-home-anchor-target\">高校生・学校関係者者・保護者の皆さまへ</a></li>\r\n        <li class=\"l-fooer-nav01__item\"><a href=\"/recruit/highschool/#anchor01\" class=\"l-fooer-nav01__link  js-home-anchor-target\">新光電気ってどんな会社？</a></li>\r\n        <li class=\"l-fooer-nav01__item\"><a href=\"/recruit/highschool/#anchor02\" class=\"l-fooer-nav01__link  js-home-anchor-target\">新光電気の仕事を知る</a></li>\r\n        <li class=\"l-fooer-nav01__item\"><a href=\"/recruit/highschool/#anchor03\" class=\"l-fooer-nav01__link  js-home-anchor-target\">先輩社員に聞いてみた！</a></li>\r\n        <li class=\"l-fooer-nav01__item\"><a href=\"/recruit/highschool/#anchor04\" class=\"l-fooer-nav01__link  js-home-anchor-target\">採用担当者の顔</a></li>\r\n        <li class=\"l-fooer-nav01__item\"><a href=\"/recruit/highschool/guideline/#guideline02\" class=\"l-fooer-nav01__link  js-guideline-anchor-target\">募集要項</a></li>\r\n        <li class=\"l-fooer-nav01__item\"><a href=\"/recruit/highschool/guideline/#guideline01\" class=\"l-fooer-nav01__link  js-guideline-anchor-target\">Q&A</a></li>\r\n        <li class=\"l-fooer-nav01__item\"><a href=\"/recruit/entry/\" target=\"_blank\" class=\"l-fooer-nav01__link\">お問い合わせ</a></li>\r\n      </ul>\r\n    <!-- /.l-footer__inner --></div>\r\n  <!-- /.l-footer__upper --></div>\r\n\r\n  <div class=\"l-footer__lower\">\r\n    <div class=\"l-footer__inner  l-footer__inner--02\">\r\n      <ul class=\"l-fooer-nav02\">\r\n        <li class=\"l-fooer-nav02__item\"><a href=\"/\" target=\"_blank\" class=\"l-fooer-nav02__link\">新光電気サイトTOP</a></li>\r\n        <li class=\"l-fooer-nav02__item\"><a href=\"/recruit/\" target=\"_blank\" class=\"l-fooer-nav02__link\">採用情報サイトTOP</a></li>\r\n        <li class=\"l-fooer-nav02__item\"><a href=\"/privacy/\" target=\"_blank\" class=\"l-fooer-nav02__link\">個人情報保護ポリシー</a></li>\r\n        <li class=\"l-fooer-nav02__item\"><a href=\"/about_site/\" target=\"_blank\" class=\"l-fooer-nav02__link\">このサイトについて</a></li>\r\n        <li class=\"l-fooer-nav02__item\"><a href=\"/recruit/sitemap/\" target=\"_blank\" class=\"l-fooer-nav02__link\">サイトマップ</a></li>\r\n      </ul>\r\n      <p class=\"l-footer__copyright\">&copy; SHINKO ELECTRIC INDUSTRIES CO., LTD.</p>\r\n    <!-- /.l-footer__inner --></div>\r\n  <!-- /.l-footer__lower --></div>\r\n</footer>\r\n\n\n<!-- /#page --></div>\n\n\n<script src=\"/recruit/highschool/assets/js/libraries.js\"></script>\r\n<script src=\"/recruit/highschool/assets/js/main.js?v=1.01\"></script>\r\n\n\n<script>\n$('.js-odometer').each(function(){\n  let format;\n  const defaultNumber = $(this).attr('data-countup-default');\n  const targetNumber = $(this).html().replace(/,/, '');\n  if ($(this).html().indexOf(',') !== -1 || $(this).html().indexOf('.') !== -1) {\n    format = '(,ddd).dd';\n  } else {\n    format = 'd';\n  }\n  $(this).html(defaultNumber);\n  $(this).attr('data-countup-target', targetNumber);\n  const el = $(this)[0];\n  const od = new Odometer({\n    el: el,\n    format: format,\n    value: defaultNumber,\n  });\n});\ndocument.addEventListener('aos:in:home-about', ({ detail }) => {\n  const $target = $(detail).find('.js-odometer');\n  $target.html($target.attr('data-countup-target'));\n});\nAOS.init({\n  once: true\n});\n</script>\n\n</body>\n</html>","finalUrl":"https://www.shinko.co.jp/recruit/highschool/","rendered":false,"_cachedAt":"2026-06-23T23:09:35.470Z"}