ul class=\"menu\">\n\t\t\t\t\t\t<li class=\"title\">Recruiting Site</li>\n\t\t\t\t\t\t<li><a href=\"./index.html\">HOME</a></li>\n\t\t\t\t\t\t<li><a href=\"./message.html\">採用担当者メッセージ</a></li>\n\t\t\t\t\t\t<li><a href=\"./infographics.html\">数字で見るMBM</a></li>\n\t\t\t\t\t\t<li><a href=\"./interview/\">社員インタビュー</a></li>\n\t\t\t\t\t\t<li><a href=\"./worklife/\">働きやすい環境づくり</a></li>\n\t\t\t\t\t\t<li><a href=\"./worklife/welfare.html\">福利厚生</a></li>\n\t\t\t\t\t\t<li><a href=\"./conditions.html\">募集要項</a></li>\n\t\t\t\t\t\t<li><a href=\"./intern.html\">インターンシップ募集要項</a></li>\n\t\t\t\t\t\t<li><a href=\"./news/\">NEWS & TOPICS</a></li>\n\t\t\t\t\t\t<li><a target=\"_blank\" href=\"https://mypage.3030.i-webs.jp/olc2028/\">MY PAGE2028</a></li>\n\t\t\t\t\t\t<li><a target=\"_blank\" href=\"https://mypage.3030.i-webs.jp/olc2027/\">MY PAGE2027</a></li>\n\t\t\t\t\t\t<!-- <li><a target=\"_blank\" href=\"https://mypage.1050.i-web.jpn.com/mbm2021/\">MY PAGE2021</a></li> -->\n\t\t\t\t\t</ul>\n\t\t\t\t\t<ul class=\"menu corporate\">\n\t\t\t\t\t\t<li class=\"title\">Corporate Site</li>\n\t\t\t\t\t\t<li><a target=\"_blank\" href=\"http://www.mbm.olc.co.jp/company/index.html\">会社概要</a></li>\n\t\t\t\t\t\t<li><a target=\"_blank\" href=\"http://www.mbm.olc.co.jp/policy/index.html\">企業理念・行動指針</a></li>\n\t\t\t\t\t\t<li><a target=\"_blank\" href=\"http://www.mbm.olc.co.jp/use/index.html\">免責事項</a></li>\n\t\t\t\t\t\t<li><a target=\"_blank\" href=\"http://www.mbm.olc.co.jp/privacy/index.html\">プライバシーポリシー</a></li>\n\t\t\t\t\t</ul>\n\t\t\t\t</div>\n\t\t\t</nav>\n\t\t\t<!-- <a class=\"entry_btn\" href=\"https://mypage.1050.i-web.jpn.com/mbm2021/\" target=\"_blank\">\n\t\t\t\t\t<img src=\"./images/mypage-2021.png\" alt=\"MY PAGE2021\">\n\t\t\t\t</a> -->\n\t\t\t<a class=\"entry2022_btn\" href=\"https://mypage.3030.i-webs.jp/olc2028/\" target=\"_blank\">\n\t\t\t\t<img src=\"./images/mypage-2028b.png\" alt=\"MY PAGE2028\">\n\t\t\t</a>\n\t\t\t<a class=\"entry_btn\" href=\"https://mypage.3030.i-webs.jp/olc2027/\" target=\"_blank\">\n\t\t\t\t<img src=\"./images/mypage-2027a.png\" alt=\"MY PAGE2027\">\n\t\t\t</a>\n\t\t\t<div id=\"drawer_menu_btn\">\n\t\t\t\t<img src=\"./images/menu_btn.png\" class=\"menu\" alt=\"\">\n\t\t\t\t<img src=\"./images/menu_btn_close.png\" class=\"close\" alt=\"\">\n\t\t\t</div>\n\t\t</header>\n\t\t<main id=\"main\" class=\"subpage message\">\n\t\t\t<div id=\"key_area\" style=\"background-image: url(./images/message_key_bg.jpg);\">\n\t\t\t\t<div class=\"title common_title01\">\n\t\t\t\t\t<h1 class=\"main\">採用担当者メッセージ</h1>\n\t\t\t\t\t<span class=\"sub\">MESSAGE</span>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t\t<div id=\"pankuzu\">\n\t\t\t\t<div class=\"inner\">\n\t\t\t\t\t<ul class=\"list\">\n\t\t\t\t\t\t<li><a href=\"./index.html\">HOME</a></li>\n\t\t\t\t\t\t<li>採用担当者メッセージ</li>\n\t\t\t\t\t</ul>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t\t<section id=\"about_area\" class=\"inner\">\n\t\t\t\t<div class=\"txt_wrap\">\n\t\t\t\t\t<p>\n\t\t\t\t\t\t───── 東京ディズニーリゾート<span class=\"r_mark\">®</span><br />\n\t\t\t\t\t\tここには、気付かれないところ<br />\n\t\t\t\t\t\t見えないところで<br />\n\t\t\t\t\t\t人知れず働く者たちがいる。\n\t\t\t\t\t</p>\n\t\t\t\t\t<p>\n\t\t\t\t\t\t24時間、365日。<br>\n\t\t\t\t\t\t安心できる空間と時間を守る者。<br>\n\t\t\t\t\t\t最高のアトラクションやショーを支える者。<br>\n\t\t\t\t\t\t翌日もゲストを迎えるために美しいパークを保つ者。<br>\n\t\t\t\t\t\tカタチに残る思い出を届ける者。\n\t\t\t\t\t</p>\n\t\t\t\t\t<p>\n\t\t\t\t\t\t一人ひとりが最高のおもてなしの為に<br>\n\t\t\t\t\t\t自ら考え、細部にまで気を配り<br>\n\t\t\t\t\t\t夢の世界をつくりあげていく。\n\t\t\t\t\t</p>\n\t\t\t\t\t<p>\n\t\t\t\t\t\t今、時を告げる鐘が鳴る。<br>\n\t\t\t\t\t\t今日もまた、夢の守り人が、動き出す。\n\t\t\t\t\t</p>\n\t\t\t\t</div>\n\t\t\t</section>\n\t\t\t<section id=\"message_area\">\n\t\t\t\t<h2 class=\"sec_title common_title01\">\n\t\t\t\t\t<span class=\"eng_title\">MESSAGE</span>\n\t\t\t\t\t<span>「ＭＢＭってなにをやっている会社？」</span>\n\t\t\t\t</h2>\n\t\t\t\t<div class=\"box01 inner\">\n\t\t\t\t\t<div class=\"txt_wrap\">\n\t\t\t\t\t\t<p>\n\t\t\t\t\t\t\t初めて当社を目にしたとき<br class=\"pc\">\n\t\t\t\t\t\t\t多くの皆様が疑問に思ったのではないでしょうか？\n\t\t\t\t\t\t</p>\n\t\t\t\t\t\t<p>\n\t\t\t\t\t\t\t「永遠に完成しない場所」として進化を続けていく東京ディズニーリゾート<span class=\"r_mark\">®</span>にて安全・安心・快適な空間を提供する。<br\n\t\t\t\t\t\t\t\tclass=\"pc\">24時間365日　夢の守り人　として東京ディズニーリゾート<span class=\"r_mark\">®</span>の運営を支えるのが\n\t\t\t\t\t\t\t私たちＭＢＭの仕事です。\n\t\t\t\t\t\t</p>\n\t\t\t\t\t\t<p>\n\t\t\t\t\t\t\t清掃・警備・メンテナンス・工事管理・施設管理・ショップ運営・物品販売・保険代理販売・バスサービス\n\t\t\t\t\t\t</p>\n\t\t\t\t\t</div>\n\t\t\t\t\t<div class=\"img\"><img src=\"./images/message_sec02_img01.jpg\" alt=\"\"></div>\n\t\t\t\t</div>\n\t\t\t\t<div class=\"box02 inner\">\n\t\t\t\t\t<div class=\"img\"><img src=\"./images/message_sec02_img02.jpg\" alt=\"\"></div>\n\t\t\t\t\t<div class=\"txt_wrap\">\n\t\t\t\t\t\t<p>\n\t\t\t\t\t\t\t多岐に渡る事業を通じて提供しているもの。<br class=\"pc\">\n\t\t\t\t\t\t\tそれは東京ディズニーリゾート<span class=\"r_mark\">®</span>を訪れるゲストだけではなく<br class=\"pc\">\n\t\t\t\t\t\t\tゲストを笑顔にするために働くキャストも笑顔にすること。\n\t\t\t\t\t\t</p>\n\t\t\t\t\t\t<p>\n\t\t\t\t\t\t\t興味の持てない仕事かもしれない。<br class=\"pc\">\n\t\t\t\t\t\t\t何をやっている会社かわからないかもしれない。\n\t\t\t\t\t\t</p>\n\t\t\t\t\t\t<p>\n\t\t\t\t\t\t\tそんな人にこそ話しを聞いてほしい。<br class=\"pc\">\n\t\t\t\t\t\t\t「東京ディズニーリゾート<span class=\"r_mark\">®</span>を支える」とはどういうことか？\n\t\t\t\t\t\t</p>\n\t\t\t\t\t\t<p>\n\t\t\t\t\t\t\t皆さまにお会い出来る日を楽しみにしています。\n\t\t\t\t\t\t</p>\n\t\t\t\t\t\t<p class=\"ta_r\">新卒採用担当</p>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</section>\n\t\t</main>\n\t\t<footer id=\"footer\">\n\t\t\t<div class=\"job_description_link\">\n\t\t\t\t<div class=\"inner\">\n\t\t\t\t\t<div class=\"box\">\n\t\t\t\t\t\t<h4 class=\"title\">\n\t\t\t\t\t\t\t<img src=\"./images/title_job-description.png\" alt=\"JOB DESCRIPTION\">\n\t\t\t\t\t\t</h4>\n\t\t\t\t\t\t<div class=\"flex_wrap\">\n\t\t\t\t\t\t\t<a href=\"./conditions.html\" class=\"bnr\">\n\t\t\t\t\t\t\t\t<img class=\"pc\" src=\"./images/bnr_conditions.jpg\" alt=\"募集要項\">\n\t\t\t\t\t\t\t\t<img class=\"sp\" src=\"./images/bnr_conditions_sp.jpg\" alt=\"募集要項\">\n\t\t\t\t\t\t\t</a>\n\t\t\t\t\t\t\t<a href=\"./intern.html\" class=\"bnr\">\n\t\t\t\t\t\t\t\t<img class=\"pc\" src=\"./images/bnr_intern.jpg\" alt=\"インターシップ募集要項\">\n\t\t\t\t\t\t\t\t<img class=\"sp\" src=\"./images/bnr_intern_sp.jpg\" alt=\"インターシップ募集要項\">\n\t\t\t\t\t\t\t</a>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t\t<div class=\"company_link\">\n\t\t\t\t<h4 class=\"title common_title01\">\n\t\t\t\t\tCOMPANY\n\t\t\t\t</h4>\n\t\t\t\t<div class=\"box\">\n\t\t\t\t\t<div class=\"flex_wrap\">\n\t\t\t\t\t\t<a target=\"_blank\" href=\"http://www.mbm.olc.co.jp/company/index.html\" class=\"bnr\">\n\t\t\t\t\t\t\t<img class=\"pc\" src=\"./images/bnr_company.jpg\" alt=\"会社概要\">\n\t\t\t\t\t\t\t<img class=\"sp\" src=\"./images/bnr_company_sp.jpg\" alt=\"会社概要\">\n\t\t\t\t\t\t</a>\n\t\t\t\t\t\t<a target=\"_blank\" href=\"http://www.mbm.olc.co.jp/policy/index.html\" class=\"bnr\">\n\t\t\t\t\t\t\t<img class=\"pc\" src=\"./images/bnr_philosophy.jpg\" alt=\"企業理念 行動指針\">\n\t\t\t\t\t\t\t<img class=\"sp\" src=\"./images/bnr_philosophy_sp.jpg\" alt=\"企業理念 行動指針\">\n\t\t\t\t\t\t</a>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t\t<p class=\"caution ta_r\">\n\t\t\t\t\tコーポレートサイトへ移動します。\n\t\t\t\t</p>\n\t\t\t</div>\n\t\t\t<div class=\"footer_container inner\">\n\t\t\t\t<div class=\"info_area\">\n\t\t\t\t\t<div class=\"footer_logo\">\n\t\t\t\t\t\t<img class=\"pc\" src=\"./images/footer_logo.png\" alt=\"\">\n\t\t\t\t\t\t<img class=\"sp\" src=\"./images/footer_logo_sp.png\" alt=\"\">\n\t\t\t\t\t</div>\n\t\t\t\t\t<p class=\"copy\"><small>©MBM CO.,LTD. ALL rights reserved/© Disney</small></p>\n\t\t\t\t</div>\n\t\t\t\t<div class=\"footer_menu\">\n\t\t\t\t\t<ul class=\"menu\">\n\t\t\t\t\t\t<li class=\"title\">Recruiting Site</li>\n\t\t\t\t\t\t<li><a href=\"./index.html\">HOME</a></li>\n\t\t\t\t\t\t<li><a href=\"./message.html\">採用担当者メッセージ</a></li>\n\t\t\t\t\t\t<li><a href=\"./infographics.html\">数字で見るMBM</a></li>\n\t\t\t\t\t\t<li><a href=\"./interview/\">社員インタビュー</a></li>\n\t\t\t\t\t\t<li><a href=\"./worklife/\">働きやすい環境づくり</a></li>\n\t\t\t\t\t\t<li><a href=\"./conditions.html\">募集要項</a></li>\n\t\t\t\t\t\t<li><a href=\"./i