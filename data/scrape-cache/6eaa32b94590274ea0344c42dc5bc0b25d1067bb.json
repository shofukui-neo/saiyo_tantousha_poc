oveClass('is-active');\n    });\n  });\n</script>\n\n\n<!-- 同ページ内でアンカーリンククリック時に、ハンバーガーメニュー閉じないのに対応 -->\n<!-- <script>\n\t$(function(){\n\t\tvar state = false;\n\t\t$('.menu-wrapper a').click(function(e){\n\t\t\t$header.removeClass('is-active');\n\t\t});\n\t});\n</script> -->\n\n<!-- ギミックの兼ね合いで、/about/index.htmlでは読み込まない。 -->\n\n<script>\n  $(function () {\n    $('a[href^=\"#\"]').click(function (e) {\n      e.preventDefault();\n      var speed = 500;\n      var href = $(this).attr('href');\n      var target = $(href);\n      if (target.length) {\n        var position = target.offset().top;\n        $('html, body').animate({ scrollTop: position }, speed, 'swing');\n      }\n    });\n  });\n</script>\n\n\n\n<script>\n\t$(window).on('load scroll resize', function(){\n\t\tvar scroll = $(window).scrollTop();\n\t\tvar windowHeight = $(window).height();\n\t\t$('.trigger').each(function(){\n\t\t\tvar imgPos = $(this).offset().top;\n\t\t\tif (scroll > imgPos - windowHeight + windowHeight / 3){\n\t\t\t\t$(this).addClass('is-show');\n\t\t\t// } else {\n\t\t\t// \t$(this).removeClass('is-show');\n\t\t\t}\n\t\t});\n\t});\n</script>\n\n<script>\n  document.addEventListener('DOMContentLoaded', () => {\n    const items = document.querySelectorAll('.link-list li');\n\n    document.addEventListener('click', () => {\n      items.forEach(i => i.classList.remove('is-active'));\n    });\n\n    items.forEach(item => {\n      item.addEventListener('click', e => {\n        e.stopPropagation();\n        if (item.classList.contains('is-active')) {\n          item.classList.remove('is-active');\n        } else {\n          items.forEach(i => i.classList.remove('is-active'));\n          item.classList.add('is-active');\n        }\n      });\n    });\n  });\n</script>\n\n\n\n\n\t<script>\n\t$(function() {\n\t\tlet counted = false;\n\n\t\tfunction countUpIfVisible() {\n\t\t\tconst $target = $('.mab-column.trigger.is-show');\n\t\t\tif ($target.length && !counted) {\n\t\t\t\tcounted = true;\n\n\t\t\t\tconst $span = $target.find('.map-count-text span');\n\t\t\t\tconst countTo = parseInt($span.text(), 10);\n\n\t\t\t\t$span.text(0);\n\n\t\t\t\tsetTimeout(function() {\n\t\t\t\t\t$({ num: 0 }).animate({ num: countTo }, {\n\t\t\t\t\t\tduration: 1000,\n\t\t\t\t\t\teasing: 'swing',\n\t\t\t\t\t\tstep: function(now) {\n\t\t\t\t\t\t\t$span.text(Math.floor(now));\n\t\t\t\t\t\t},\n\t\t\t\t\t\tcomplete: function() {\n\t\t\t\t\t\t\t$span.text(countTo);\n\t\t\t\t\t\t}\n\t\t\t\t\t});\n\t\t\t\t}, 100);\n\t\t\t}\n\t\t}\n\n\t\t$(window).on('scroll', countUpIfVisible);\n\t\tcountUpIfVisible();\n\t});\n\t</script>\n\n\n\n\t<script>\n\t\t$(function(){\n\t\t\tvar slider = $('.top-data-slider').slick({\n\t\t\t\tinfinite: true,\n\t\t\t\tautoplay: true,\n\t\t\t\tdots: false,\n\t\t\t\tcssEase: 'linear',\n\t\t\t\tautoplaySpeed: 0,\n\t\t\t\tspeed: 6000,\n\t\t\t\tvariableWidth: true, \n\t\t\t\tslidesToShow: 4,\n\t\t\t\tslidesToScroll: 1,\n\t\t\t\tswipe: false,\n\t\t\t\tpauseOnFocus: false,\n\t\t\t\tpauseOnHover: false,\n\t\t\t\tarrows: false,\n\t\t\t\tfade: false,\n\t\t\t\tcenterMode:true,\n\t\t\t\tcenterPadding:\"0\",\n\t\t\t\tadaptiveHeight:true,\n\t\t\t\t// responsive: [\n\t\t\t\t// \t{\n\t\t\t\t// \t\tbreakpoint: 1025,\n\t\t\t\t// \t\tsettings: {\n\t\t\t\t// \t\t\tslidesToShow: 2,\n\t\t\t\t// \t\t\tcenterPadding:\"3%\",\n\t\t\t\t// \t\t}\n\t\t\t\t// \t},\n\t\t\t\t// ]\n\t\t\t});\n\t\t});\n\t</script>\n\n\n\t<script>\n\t\t$(function(){\n\t\tvar $slider = $('.top-people-slider');\n\t\tvar $counter = $('.interview-slider-counter span');\n\n\t\t// 初期化 & スライド切り替え時に発火\n\t\t$slider.on('init reInit afterChange', function(event, slick, currentSlide){\n\t\t\tvar i = (currentSlide ? currentSlide : 0) + 1; \n\t\t\t$counter.text(i + ' / ' + slick.slideCount);\n\t\t});\n\n\t\t$slider.slick({\n\t\t\tautoplay: true,\n\t\t\tdots: false,\n\t\t\tautoplaySpeed: 5000,\n\t\t\tspeed: 1000,\n\t\t\tvariableWidth: true, \n\t\t\tslidesToShow: 3,\n\t\t\tslidesToScroll: 1,\n\t\t\tswipe: false,\n\t\t\tpauseOnFocus: 