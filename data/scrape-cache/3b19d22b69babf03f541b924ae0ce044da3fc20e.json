{"url":"https://www.chu-bu.co.jp/recruit.html","html":"<!DOCTYPE html PUBLIC \"-//W3C//DTD XHTML 1.0 Strict//EN\" \"https://www.w3.org/TR/xhtml1/DTD/xhtml1-strict.dtd\">\n<html xmlns=\"https://www.w3.org/1999/xhtml\" lang=\"ja\" xml:lang=\"ja\">\n<head>\n<meta charset=\"utf-8\">\n<title>採用情報｜中部印刷株式会社</title><meta content=\"中部印刷株式会社\" name=\"Author\">\n<meta name=\"Keywords\" content=\"印刷,不織布,カタログ,チラシ,制作,PP,トムソン,ラミネート,オフィスデータ,ウィンドウズデータ,東京,大阪,名古屋,静岡,豊橋,浜松\"/>\n<meta name=\"Description\" content=\"お客様のビジネスに、効果をもたらす印刷物を作ります\"/>\n<meta content=\"index,follow\" name=\"robots\"/>\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes\">\n<link rel=\"stylesheet\" href=\"./css/_normalize.css\">\n<link rel=\"stylesheet\" href=\"./css/_defaults.css\">\n<link rel=\"stylesheet\" href=\"./css/style.css?0426-2\">\n<link rel=\"stylesheet\" media=\"Only screen and (max-width:768px)\" href=\"./css/sp.css\">\n<link rel=\"stylesheet\" href=\"https://use.fontawesome.com/releases/v5.4.1/css/all.css\" integrity=\"sha384-5sAR7xN1Nv6T6+dT2mhtzEpVJvfS3NScPQTrOxhwjIuvcA67KV2R5Jz6kr4abQsz\" crossorigin=\"anonymous\">\n<!-- Google Tag Manager -->\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n})(window,document,'script','dataLayer','GTM-PJS3FGW');</script>\n<!-- End Google Tag Manager -->\n</head>\n<body>\n<!-- Google Tag Manager (noscript) -->\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-PJS3FGW\"\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n<!-- End Google Tag Manager (noscript) -->\n\n<header>\n<div id=\"logo\"><a href=\"index.html\"><img src=\"img/common-logo.jpg\" alt=\"中部印刷株式会社\" /></a></div>\n<div id=\"header-right\"><img src=\"img/common-tel.jpg\" alt=\"お問い合わせ：053-441-2431\" /><br /><i class=\"fas fa-chevron-circle-right\"></i> <a href=\"recruit.html\">採用情報</a>　　<i class=\"fas fa-chevron-circle-right\"></i> <a href=\"contact.html\">お問い合わせ</a>　　<i class=\"fas fa-chevron-circle-right\"></i> <a href=\"privacy.html\">個人情報保護方針</a></div>\n</header>\n\n<div id=\"menu\">\n<div id=\"menu-inner\">\n<div id=\"btn-content\"><span id=\"menu-btn\"><i class=\"fas fa-align-left\"></i> MENU</span></div>\n<ul id=\"menu-content\">\n<li class=\"b\"><a href=\"chubu-definition.html\">中部印刷のイチ押し！ <i class=\"fas fa-angle-down\"></i></a>\n<ul class=\"second-content\">\n<li><span><i class=\"fas fa-chevron-circle-down\"></i> 印刷加工技術</span></li>\n<li class=\"sec\"><a href=\"chubu-iridesse.html\"><i class=\"fas fa-angle-right\"></i> IRIDESSE</a></li>\n<li class=\"sec\"><a href=\"chubu-nonwoven.html\"><i class=\"fas fa-angle-right\"></i> 不織布</a></li>\n<li class=\"sec\"><a href=\"chubu-inserting.html\"><i class=\"fas fa-angle-right\"></i> 封入封緘機</a></li>\n<li><span><i class=\"fas fa-chevron-circle-down\"></i> 表面加工</span></li>\n<li class=\"sec\"><a href=\"chubu-varnish.html\"><i class=\"fas fa-angle-right\"></i> ニス加工</a></li>\n<li class=\"sec\"><a href=\"chubu-cutting.html\"><i class=\"fas fa-angle-right\"></i> トムソン</a></li>\n<li class=\"sec\"><a href=\"chubu-varnish.html\"><i class=\"fas fa-angle-right\"></i> PP</a></li>\n<li class=\"sec\"><a href=\"chubu-varnish.html\"><i class=\"fas fa-angle-right\"></i> ラミネート</a></li>\n<li class=\"sec\"><a href=\"chubu-foil.html\"><i class=\"fas fa-angle-right\"></i> 箔押し（金銀黒）</a></li>\n</ul>\n</li>\n<li><a href=\"about-greeting.html\">会社案内 <i class=\"fas fa-angle-down\"></i></a>\n<ul class=\"second-content\">\n<li class=\"sec\"><a href=\"about-greeting.html\"><i class=\"fas fa-angle-right\"></i> 社長挨拶</a></li>\n<li class=\"sec\"><a href=\"about-overview.html\"><i class=\"fas fa-angle-right\"></i> 会社概要</a></li>\n<li class=\"sec\"><a href=\"about-history.html\"><i class=\"fas fa-angle-right\"></i> 沿革</a></li>\n<li class=\"sec\"><a href=\"about-group.html\"><i class=\"fas fa-angle-right\"></i> 支社/営業所/グループ</a></li>\n</ul>\n</li>\n<li><a href=\"facility.html\">設備紹介 <i class=\"fas fa-angle-down\"></i></a>\n<ul class=\"second-content\">\n<li class=\"sec\"><a href=\"facility.html#01\"><i class=\"fas fa-angle-right\"></i> プリプレス</a></li>\n<li class=\"sec\"><a href=\"facility.html#02\"><i class=\"fas fa-angle-right\"></i> 印刷</a></li>\n<li class=\"sec\"><a href=\"facility.html#03\"><i class=\"fas fa-angle-right\"></i> 製品</a></li>\n<li class=\"sec\"><a href=\"facility.html#04\"><i class=\"fas fa-angle-right\"></i> デジタル印刷</a></li>\n<li class=\"sec\"><a href=\"facility.html#05\"><i class=\"fas fa-angle-right\"></i> 竜洋工場</a></li>\n</ul>\n</li>\n<li><a href=\"category.html\">部門紹介 <i class=\"fas fa-angle-down\"></i></a>\n<ul class=\"second-content\">\n<li><a href=\"category.html#01\"><i class=\"fas fa-angle-right\"></i> 営業部</a></li>\n<li><a href=\"category.html#02\"><i class=\"fas fa-angle-right\"></i> プランニングセンター</a></li>\n<li><a href=\"category.html#11\"><i class=\"fas fa-angle-right\"></i> 製造部/生産管理課</a></li>\n<li><a href=\"category.html#03\"><i class=\"fas fa-angle-right\"></i> プリプレス課（検版・刷版）</a></li>\n<li><a href=\"category.html#04\"><i class=\"fas fa-angle-right\"></i> 製品課</a></li>\n<li><a href=\"category.html#05\"><i class=\"fas fa-angle-right\"></i> 印刷課</a></li>\n<li><a href=\"category.html#06\"><i class=\"fas fa-angle-right\"></i> デジタル印刷課</a></li>\n<li><a href=\"category.html#07\"><i class=\"fas fa-angle-right\"></i> 物流課/倉庫業</a></li>\n<li><a href=\"category.html#08\"><i class=\"fas fa-angle-right\"></i> 竜洋工場</a></li>\n<li><a href=\"category.html#09\"><i class=\"fas fa-angle-right\"></i> 西ヶ崎工場</a></li>\n<li><a href=\"category.html#10\"><i class=\"fas fa-angle-right\"></i> 管理部</a></li>\n</ul>\n</li>\n<li><a href=\"product-print.html\">製品案内 <i class=\"fas fa-angle-down\"></i></a>\n<ul class=\"second-content\">\n<li><a href=\"product-print.html\"><i class=\"fas fa-angle-right\"></i> 商業印刷全般</a></li>\n<li><a href=\"product-nonwoven.html\"><i class=\"fas fa-angle-right\"></i> 不織布</a></li>\n<li><a href=\"product-sp.html\"><i class=\"fas fa-angle-right\"></i> ノベルティ</a></li>\n</ul>\n</li>\n<li><a href=\"environment.html\">環境/品質 <i class=\"fas fa-angle-down\"></i></a>\n<ul class=\"second-content\">\n<li><a href=\"environment.html#iso\"><i class=\"fas fa-angle-right\"></i> ISO</a></li>\n<li><a href=\"environment.html#fsc\"><i class=\"fas fa-angle-right\"></i> FSC森林認証</a></li>\n<li><a href=\"environment.html#biomass\"><i class=\"fas fa-angle-right\"></i>バイオマスマーク</a></li>\n<li><a href=\"environment.html#report\"><i class=\"fas fa-angle-right\"></i> 環境報告書</a></li>\n</ul>\n</li>\n</ul>\n</div>\n</div><div style=\"clear:both\"></div>\n\n<script type=\"text/javascript\" src=\"https://code.jquery.com/jquery-1.9.1.min.js\"></script>\n<script>\n$(function(){\n    var menuBtn = $(\"#menu-btn\"),\n        menuContent = $(\"#menu-content\");\n    menuBtn.click(function(){\n        menuContent.slideToggle();\n    });\n    $(window).resize(function(){\n        var win = $(window).width(),\n            p = 768;//19\n        if(win > p){\n            menuContent.show();\n        }else{\n            menuContent.hide();\n        }\n    });\n});\n</script>\n\n<div id=\"breadcrumbs\">\n<div class=\"breadcrumbs\">\n<ul>\n<li><a href=\"index.html\">ホーム</a></li>\n<li>採用情報</li>\n</ul>\n</div>\n</div>\n\n<div class=\"content wrapper\">\n\n<div id=\"recruit-wrapper\">\n\n<p><img src=\"img/recruit-title.jpg\" alt=\"当社で活躍する若手社員から「一緒にやろうよ！」メッセージ\" /></p>\n\n<!--<div class=\"main-image\" style=\"background-image:url(./img/recruit-img-01.jpg)\">\n<div>学んだ知識を生かして<br />地元に貢献する</div>\n<p class=\"w\">\n<b>伊藤 綾</b><span>AYA ITO</span>\n営業部<br />\n2015年4月 入社</p>\n</div>\n<div class=\"recruit-w\">\n<img src=\"img/recruit-img-01-01.jpg\" class=\"right\" width=\"490\"><b>学生時代に学んだ事/現在の仕事を教えてください</b>\n<span>幼少期の頃から絵を描くことが好きで大学でもデザインを選考して学んできたため、その知識を生かせる職業に就きたいと思いました。<br />営業職はお客様とコミュニケーションを図りながら制作から印刷まで一貫して行うため、学んできたデザインの知識を生かしながらつくりあげられるのでとてもやりがいを感じます。</span>\n<b>中部印刷の良いトコロを教えてください</b>\n<span>社内の風通しがとても良く、みなさんとても優しく未経験でも先輩たちが印刷物の知識を一から丁寧に教えてくれます。<br />困ったことがあっても真摯に受け止め、解決への道を教えてくれます。</span>\n</div><br clear=\"all\" />\n<div class=\"recruit-w\">\n<img src=\"img/recruit-img-01-02.jpg\" class=\"left\" width=\"500\"><b>今後チャレンジしたい事/やりがいは？</b>\n<span>制作から印刷までトータルして携われることが魅力でありやりがいだと思います。個人的には紙媒体以外の特殊案件にも即時対応できるように、知識の幅を広げたいです。</span>\n</div>\n<div class=\"recruit-w\">\n<b>現在就職活動中の学生の皆さまへ</b>\n<span>心強い先輩方が困った時は支えになってくれますので、あせらずゆっくり一緒にがんばりましょう！</span>\n</div>\n\n<br clear=\"all\" /><br />-->\n<div class=\"main-image\" style=\"background-image:url(./img/recruit-img-02.jpg)\">\n<div>お客様の想いを<br />カタチで表現する</div>\n<p class=\"m\">\n<b>髙岡 祐也</b><span>YUUYA TAKAOKA</span>\n営業部<br />\n2017年4月 入社</p>\n</div>\n<div class=\"recruit-m\">\n<img src=\"img/recruit-img-02-01.jpg\" class=\"right\" width=\"490\"><b>学生時代に学んだ事/現在の仕事を教えてください</b>\n<span>学生時代は社会福祉を学んでおり、インターンシップでデイケアセンターに行き介護が必要な高齢者の方に付き添い実習を積んできました。<br />現在は印刷業の仕事をさせて頂き、お客様の思いを形にして社会に発信（アピール）していく営業の仕事をしています。</span>\n<b>中部印刷の良いトコロを教えてください</b>\n<span>一番は人がいいところです。会社にはしっかりとした仕組みやルールも必要ですが、一番大切なのは一緒に働く「人」です。中部印刷で働いている皆さんは1人1人がお客様を大切にし、共に働く人を尊重してくれています。</span>\n</div>\n<div class=\"recruit-m\">\n<b>今後チャレンジしたい事/やりがいは？</b>\n<span>企業・スポーツ・マスメディア等、幅広い職種の方とお仕事ができることが魅力であり、お客様と協力して一からモノを作っていくことができるという「やりがい」があります。<br />印刷会社にしかできない新しい試みにチャレンジしたいです。</span>\n</div>\n<div class=\"recruit-m\">\n<b>現在就職活動中の学生の皆さまへ</b>\n<span>独り立ちするまで先輩方が丁寧に教えてくれます。印刷に関しての知識が無くても安心してください！</span>\n</div>\n\n<br clear=\"all\" /><a href=\"recruit-form.html\" class=\"cp_btn\">採用応募フォームへ <i class=\"fas fa-angle-right cp_btn_right\"></i></a>\n\n\n<br clear=\"all\" /><br />\n<div class=\"main-image\" style=\"background-image:url(./img/recruit-img-07.jpg)\">\n<div>制作物を<br />作り上げていく楽しみ</div>\n<p class=\"m\">\n<b>松野 晃</b><span>AKIRA MATSUNO</span>\nプランニングセンター<br />\n2013年2月 入社</p>\n</div>\n<div class=\"recruit-m\">\n<img src=\"img/recruit-img-07-01.jpg\" class=\"right\" width=\"490\"><b>学生時代に学んだ事/現在の仕事を教えてください</b>\n<span>デザインの専門学校に通っていたときは学んだことを他の人に教える事が得意でした。今振り返ってみるとその時の行動が自分に少しだけ付加価値を与えてくれたと思います。<br />現在は一般的な編集とデザインを担当しています。</span>\n<b>中部印刷の良いトコロを教えてください</b>\n<span>静岡県内に大手製造業の顧客を持っているので、比較的大きな仕事があり安定していると思います。<br />不織布を使用した特殊印刷技術を持っており、独自の質感を持ちながら高品質な風合いがある製品を提供できるのでとてもユニークだと思いました。<br />印刷以外ではWEB関係の仕事など多角的に制作を請け負っています。</span>\n</div><br clear=\"all\" />\n<div class=\"recruit-m\">\n<img src=\"img/recruit-img-07-02.jpg\" class=\"left\" width=\"490\"><b>今後チャレンジしたい事/やりがいは？</b>\n<span>この仕事は残業があったり制作時間が限られたりと少しハードワークになると思いますが、様々な制作物を作り上げていく楽しみと困難を乗り越えるやりがいがあり、天職だと思っています。<br />クリエイティブな業界では常に先を思う感性が重要になってきます。最初はどうしても上手くいかない時間が長く、自分には向いていないと思いがちですが様々な制作物に携わっていく事でそれを克服し、いわゆる「手に職がある」事を目標にしています。今後はノベルティグッズの制作に関わりたいと思っています。</span>\n</div><br clear=\"all\" />\n<div class=\"recruit-m\">\n<b>現在就職活動中の学生の皆さまへ</b>\n<span>クリエイティブな業界は常に最新のソフトウェアとアーティスティックなセンスによって構築されていると思われがちですが、実際には「紙とペン」の世界です。どんなに技術が進歩しても、自分自身の感性の上達が最高の作品制作への近道になります。<br />新鮮な遊び心で周りを笑顔にするデザインに挑戦してみませんか？</span>\n</div>\n\n<br clear=\"all\" /><a href=\"recruit-form.html\" class=\"cp_btn\">採用応募フォームへ <i class=\"fas fa-angle-right cp_btn_right\"></i></a>\n\n\n<!--<br clear=\"all\" /><br />\n<div class=\"main-image\" style=\"background-image:url(./img/recruit-img-03.jpg)\">\n<div style=\"color:#fff;\">初心者でも先輩方が<br />丁寧に指導してくれる</div>\n<p class=\"m\">\n<b>内山 優也</b><span>YUUYA UCHIYAMA</span>\n印刷課<br />\n2018年4月 入社</p>\n</div>\n<div class=\"recruit-m\">\n<img src=\"img/recruit-img-03-01.jpg\" class=\"right\" width=\"490\"><b>学生時代に学んだ事/現在の仕事を教えてください</b>\n<span>主にDTP（デスクトップパブリシング）でパソコンを利用してデータを制作した印刷物の制作を学びました。<br />現在はデザイン特化ではなくオペレーターとして作業をしています。</span>\n<b>中部印刷の良いトコロを教えてください</b>\n<span>初心者でも先輩方が丁寧に教育を行ってくれるところだと思います。社長をはじめ先輩方との距離が近く、色々な仕事に取り組むことができます。</span>\n</div><br clear=\"all\" />\n<div class=\"recruit-m\">\n<img src=\"img/recruit-img-03-02.jpg\" class=\"left\" width=\"490\"><b>今後チャレンジしたい事/やりがいは？</b>\n<span>まだまだ覚えることが多く先輩の指示に頼ることが多いので、1つ1つ指示をされなくても仕事を進められる様にしたいです。</span>\n</div>\n<div class=\"recruit-m\">\n<b>現在就職活動中の学生の皆さまへ</b>\n<span>悔いのない就職活動にしてください。体が資本ですので体調管理には気をつけて頑張ってください！</span>\n</div>\n\n<br clear=\"all\" /><a href=\"recruit-form.html\" class=\"cp_btn\">採用応募フォームへ <i class=\"fas fa-angle-right cp_btn_right\"></i></a>-->\n\n\n\n<!--<br clear=\"all\" /><br />\n<div class=\"main-image\" style=\"background-image:url(./img/recruit-img-04.jpg)\">\n<div>高度な技術に挑戦！<br />毎日成長したい</div>\n<p class=\"m\">\n<b>永谷 賢</b><span>KEN NAGATANI</span>\n製品課<br />\n2017年4月 入社</p>\n</div>\n<div class=\"recruit-m\">\n<img src=\"img/recruit-img-04-01.jpg\" class=\"right\" width=\"490\"><b>学生時代に学んだ事/現在の仕事を教えてください</b>\n<span>学生時代は部活動に力を入れていて、コミュニケーションを高めるために人と積極的に関わる様に心がけました。<br />現在の業務内容は企業向けのカタログ/パンフレット/チラシ等といった印刷物を加工する業務をしています。</span>\n<b>中部印刷の良いトコロを教えてください</b>\n<span>上司や先輩方が同じ目線で物事を考えてくれるところです。何よりいい人が多いと思います。</span>\n</div><br clear=\"all\" />\n<div class=\"recruit-m\">\n<img src=\"img/recruit-img-04-02.jpg\" class=\"left\" width=\"490\"><b>今後チャレンジしたい事/やりがいは？</b>\n<span>高度な技術を必要とする作業に取り組んでいきたいです。<br />自分が作業に関わった印刷物を店頭等で見かけた時に「この印刷物に関わったんだ」という実感を得る事にやりがいを感じます。</span>\n</div>\n<div class=\"recruit-m\">\n<b>現在就職活動中の学生の皆さまへ</b>\n<span>どの会社に入社しても必ず自分のプラスになることはあります。がんばってください！</span>\n</div>\n\n<br clear=\"all\" /><a href=\"recruit-form.html\" class=\"cp_btn\">採用応募フォームへ <i class=\"fas fa-angle-right cp_btn_right\"></i></a>-->\n\n<br clear=\"all\" /><br />\n\n<!--<div class=\"main-image\" style=\"background-image:url(./img/recruit-img-05.jpg)\">\n<div>好きなイラストを<br />仕事に活かす</div>\n<p class=\"w\">\n<b>髙塚 千惠美</b><span>CHIEMI TAKATSUKA</span>\nプランニングセンター<br />\n2017年4月 入社</p>\n</div>\n<div class=\"recruit-w\">\n<img src=\"img/recruit-img-05-01.jpg\" class=\"right\" width=\"490\"><b>学生時代に学んだ事/現在の仕事を教えてください</b>\n<span>ポスターのデザインやイラスト、クレイアニメーションなど様々なことに広く力をいれ学びました。<br />現在ではチラシやポスター、広報誌などを制作しています。</span>\n<b>中部印刷の良いトコロを教えてください</b>\n<span>皆が優しく丁寧に指導してくれるところです。</span>\n<b>今後チャレンジしたい事/やりがいは？</b>\n<span>趣味でも好きで長く続けているイラストを描くことを活かして仕事ができることや、量の多い仕事などを終えた時はとてもやりがいを感じます。<br />今後はInDesignを勉強し一から頁ものを作れるようになりたいです。</span>\n</div>\n<div class=\"recruit-w\">\n<b>現在就職活動中の学生の皆さまへ</b>\n<span>私と一緒に働きましょう！</span>\n</div><br clear=\"all\" />-->\n\n<!--<div class=\"clearfix\"></div><br />\n<div class=\"main-image\" style=\"background-image:url(./img/recruit-img-06.jpg)\">\n<div>オリジナル商品を<br />制作できる会社</div>\n<p class=\"m\">\n<b>森田 靖隆</b><span>YASUTAKA MORITA</span>\n総務課<br />\n2014年4月 入社</p>\n</div>\n<div class=\"recruit-m\">\n<img src=\"img/recruit-img-06-01.jpg\" class=\"right\" width=\"490\"><b>学生時代に学んだ事/現在の仕事を教えてください</b>\n<span>学生時代はビジネス実務を学んでいました。現在は総務課にて従業員の勤怠管理や社会保険関連の書類提出等を行っています。<br />社会保険関係は個人の収入や家族状況によって違うので大変難しいのですが、従業員の相談にのって手助けができたときは大変やりがいを感じます。</span>\n<b>中部印刷の良いトコロを教えてください</b>\n<span>仕事上での自分の意見を言いやすく、またその意見が採用されることが多いです。上司との間にも大きな壁というものを感じることがなく、雰囲気がよいと思います。ベテラン社員が多い環境で、面倒見がよい方が多い印象です。</span>\n</div>\n<div class=\"recruit-m\">\n<b>今後チャレンジしたい事/やりがいは？</b>\n<span>従業員個人の相談に関わることが多いので、そのお手伝いが出来た時はとてもやりがいを感じます。</span>\n</div>\n<div class=\"recruit-m\">\n<b>現在就職活動中の学生の皆さまへ</b>\n<span>弊社は製造業の中でもひとつの商品を作り続けるのではなく、オリジナルの商品を作り上げる仕事です。印刷業はどのような業界にも必ず需要がある仕事です。<br />この世に一つだけのオリジナル商品を作ってみたい方、印刷を通じて様々な業界に飛び込んでみたい方、お待ちしています！</span>\n</div>\n\n<br clear=\"all\" /><a href=\"recruit-form.html\" class=\"cp_btn\">採用応募フォームへ <i class=\"fas fa-angle-right cp_btn_right\"></i></a>-->\n\n<br clear=\"all\" />\n\n<div class=\"title re\">募集内容</div>\n<table class=\"tbl\">\n<tr><th>募集している職種</th><td><span style=\"font-weight: bold; color: #0068b7;\">東京支社（営業）、大阪営業所（営業）、名古屋営業所（営業）、浜松本社（営業、制作）</span></td></tr>\n<tr><th>職種</th><td>各種印刷物の企画営業、<!--印刷オペレーター、-->グラフィックデザイナー、DTPオペレーター、WEBデザイナー、展示物の設計/デザイン/施工管理</td></tr>\n<tr><th>雇用形態</th><td>正社員</td></tr>\n<tr><th>応募資格</th><td>要自動車普通免許</td></tr>\n<tr><th>勤務予定地</th><td>浜松本社、東京支社、大阪営業所、<!--静岡営業所、-->名古屋営業所<!--、豊橋営業所--></td></tr>\n<tr><th>休日休暇</th><td>土曜・日曜・夏季・年末年始休暇　他　会社カレンダーによる（年間休日110日）</td></tr>\n<tr><th>待遇</th><td>昇給年1回、賞与年2回</td></tr>\n<tr><th>福利厚生</th><td>各種社会保険完備、退職金制度、財形貯蓄、社員親睦会制度、資格取得補助、産休・育休制度、その他特別休暇制度、社員持株制度</td></tr>\n</table>\n\n<br clear=\"all\" /><a href=\"recruit-form.html\" class=\"cp_btn\">採用応募フォームへ <i class=\"fas fa-angle-right cp_btn_right\"></i></a>\n\n<!--<div class=\"title re\">応募方法</div>\n<div class=\"about-iso\">\n電話連絡後、履歴書（写真貼）をご郵送ください。<br />\n書類選考の上、後日ご連絡致します。<br />\n受付時間　8：00～17：00（月～金）<br />\n</div>-->\n\n</div>\n\n</div>\n\n\n<footer id=\"footer\"><div class=\"content footer\">\n<div id=\"footer-logo\"><img src=\"img/common-footer-logo.png\" alt=\"中部印刷株式会社\" /><br /><strong>本社/本社工場</strong>〒432-8052　静岡県浜松市中央区東若林町1516-2<br>TEL 053-441-2431</div>\n<div id=\"group\">\n<strong>東京支社</strong>〒103-0001 東京都中央区日本橋小伝馬町4-9 小伝馬町新日本橋ビル9F　TEL：03-6661-6821<hr>\n<strong>大阪営業所</strong>〒541-0054 大阪市中央区南本町4-5-7 東亜ビル3F　TEL：06-6786-8797<hr>\n<strong>名古屋営業所</strong>〒460-0011 名古屋市中区大須4-13-46 ウィストリアビル803号　TEL：052-212-7793<hr>\n<strong>静岡営業所</strong>〒422-8037 静岡県静岡市駿河区下島426-1　TEL：054-237-9133<hr>\n<strong>豊橋営業所</strong>〒441-8113 愛知県豊橋市西幸町字浜池333-9 豊橋サイエンスコア 403-A<br />TEL：0532-39-5210<hr>\n</div>\n</div></footer>\n\n<small id=\"copyright\"><div class=\"content copyright\">\n© Chubu Printing Co.,Ltd\n</div></small>\n\n<!-- Global site tag (gtag.js) - Google Analytics -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=UA-200638481-1\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'UA-200638481-1');\n</script>\n\n<!-- Begin Mieruca Embed Code -->\n<script type=\"text/javascript\" id=\"mierucajs\">\nwindow.__fid = window.__fid || [];__fid.push([251206470]);\n(function() {\nfunction mieruca(){if(typeof window.__fjsld != \"undefined\") return; window.__fjsld = 1; var fjs = document.createElement('script'); fjs.type = 'text/javascript'; fjs.async = true; fjs.id = \"fjssync\"; var timestamp = new Date;fjs.src = ('https:' == document.location.protocol ? 'https' : 'http') + '://hm.mieru-ca.com/service/js/mieruca-hm.js?v='+ timestamp.getTime(); var x = document.getElementsByTagName('script')[0]; x.parentNode.insertBefore(fjs, x); };\nsetTimeout(mieruca, 500); document.readyState != \"complete\" ? (window.attachEvent ? window.attachEvent(\"onload\", mieruca) : window.addEventListener(\"load\", mieruca, false)) : mieruca();\n})();\n</script>\n<!-- End Mieruca Embed Code -->\n\n<script type=\"text/javascript\" src=\"js/modal.js\"></script>\n<!-- モーダルを開くボタン -->\n<button class=\"modal-open js-modal-open\"><img src=\"img/4-banner.png?0426\" alt=\"4コマ漫画始めました！\" style=\"width: 100%; max-width: 100%;\" /></button>\n\n<!-- モーダル本体 -->\n<div class=\"modal js-modal\">\n<div class=\"modal-container\">\n<!-- モーダルを閉じるボタン -->\n<div class=\"modal-close js-modal-close\">×</div>\n<!-- モーダル内部のコンテンツ -->\n<div class=\"modal-content\">\n<h2>第4話　校正してもらうってさ</h2>\n<p>～何事にも確認は必要だよね！～<img src=\"img/4-04.jpg?0426\" style=\"width: 100%; max-width: 100%;\" alt=\"\" /></p>\n<h2>第3話　ﾌﾟﾗﾝﾆﾝｸﾞｾﾝﾀｰって何？</h2>\n<p>～所属が“ﾌﾟﾗﾝﾆﾝｸﾞｾﾝﾀｰ”になったちゅうちゃん。運命はいかに～<img src=\"img/4-03.jpg?0426\" style=\"width: 100%; max-width: 100%;\" alt=\"\" /></p>\n<h2>第2話　会社の先輩</h2>\n<p>～初日の夜に早速やけ酒。会社の人とばったり！～<img src=\"img/4-02.jpg?0426\" style=\"width: 100%; max-width: 100%;\" alt=\"\" /></p>\n<h2>第1話　就職したってさ</h2>\n<p>～入社したちゅうちゃん。初日からそんなに飛ばして大丈夫…？～<img src=\"img/4-01.jpg?0426\" style=\"width: 100%; max-width: 100%;\" alt=\"\" /></p>\n</div>\n</div>\n</div>\n\n<script type=\"text/javascript\">\n//要素を取得\nconst modal = document.querySelector('.js-modal'),\n      open = document.querySelector('.js-modal-open'),\n      close = document.querySelector('.js-modal-close');\n\n//「開くボタン」をクリックしてモーダルを開く\nfunction modalOpen() {\n  modal.classList.add('is-active');\n}\nopen.addEventListener('click', modalOpen);\n\n//「閉じるボタン」をクリックしてモーダルを閉じる\nfunction modalClose() {\n  modal.classList.remove('is-active');\n}\nclose.addEventListener('click', modalClose);\n\n//「モーダルの外側」をクリックしてモーダルを閉じる\nfunction modalOut(e) {\n  if (e.target == modal) {\n    modal.classList.remove('is-active');\n  }\n}\naddEventListener('click', modalOut);\n</script>\n\n</body>\n</html>\n","finalUrl":"https://www.chu-bu.co.jp/recruit.html","rendered":false,"_cachedAt":"2026-06-17T23:17:38.440Z"}