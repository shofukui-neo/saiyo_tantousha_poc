 Tag Manager (noscript) -->\r\n<!-- skipLink -->\r\n<ul id=\"skipLink\">\r\n<li><a href=\"#globalNav\">グローバルナビへ移動する</a></li>\r\n<li><a href=\"#contents\">本文へ移動する</a></li>\r\n</ul>\r\n<!-- /skipLink -->\r\n\r\n<!-- ===== header ====== -->\r\n<header class=\"ly_header inc_header\"><!-- /shared/inc/inc_header --></header>\r\n<!-- ===== /header ====== -->\r\n\r\n<!-- ===== globalNav ====== -->\r\n<nav id=\"globalNav\" class=\"ly_globalNav inc_globalnav\"><!-- /shared/inc/inc_globalnav --></nav>\r\n<!-- ===== /globalNav ====== -->\r\n\r\n<!-- ===== contents ====== -->\r\n<main class=\"ly_mainContents\" id=\"contents\">\r\n\r\n<div class=\"ly_container\">\r\n  <div class=\"uq_topHero\">\r\n      <a class=\"hero\" href=\"/100th/\" target=\"_blank\">\r\n        <picture class=\"heroImg\">\r\n          <source media=\"(max-width: 767px)\" srcset=\"./images/index_kv100_jp_sp.webp\">\r\n          <source media=\"(min-width: 768px)\" srcset=\"./images/index_kv100_jp.webp\">\r\n          <img srcset=\"./images/index_kv100_jp.webp\" alt=\"\">\r\n        </picture>\r\n        <!--<h1 class=\"heroHeading\">\r\n          NHK 「魔改造の夜」に参戦！<br>\r\n          東レのエンジニアリングの挑戦をご紹介します。\r\n        </h1>-->\r\n      </a>\r\n      <!--<a class=\"hero\" href=\"/makaizo/\" target=\"_blank\">\r\n        <picture class=\"heroImg\">\r\n          <source media=\"(max-width: 767px)\" srcset=\"./images/index_hero_makaizo_sp.webp\">\r\n          <source media=\"(min-width: 768px)\" srcset=\"./images/index_hero_makaizo.webp\">\r\n          <img srcset=\"./images/index_hero_makaizo.webp\" alt=\"\">\r\n        </picture>\r\n        <h1 class=\"heroHeading\">\r\n          NHK 「魔改造の夜」に参戦！<br>\r\n          東レのエンジニアリングの挑戦をご紹介します。\r\n        </h1>\r\n      </a>-->\r\n      <!--<a class=\"hero\" href=\"/ir/integrated_report/\">\r\n        <picture class=\"heroImg\">\r\n          <source media=\"(max-width: 767px)\" srcset=\"./images/index_hero_report_2024_sp.webp\">\r\n          <source media=\"(min-width: 768px)\" srcset=\"./images/index_hero_report_2024.webp\">\r\n          <img srcset=\"./images/index_hero_report_2024.webp\" alt=\"\">\r\n        </picture>\r\n        <h1 class=\"heroHeading\">\r\n          統合報告書 「東レレポート2024」<br>\r\n          東レの価値創造ストーリーをご紹介します。\r\n        </h1>\r\n      </a>-->\r\n    <div class=\"swiper-container heroSlider\">\r\n      <ul class=\"swiper-wrapper\">\r\n        <li class=\"swiper-slide item\">\r\n          <a href=\"https://note.toray/n/n2990f129a409\" class=\"clip\" target=\"_blank\">\r\n            <picture class=\"clipImg\">\r\n              <img srcset=\"./images/index_slide_01.webp\" alt=\"\">\r\n            </picture>\r\n            <p class=\"clipHeading\">\r\n              <strong>【東レ公式note】遮る、守る、彩る。東レのサマーシールド<sup>&reg;</sup>が夏の景色になるまで</strong>\r\n             東レのサマーシールド<sup>&reg;</sup>生地を使った日傘は、テレビやSNSでも話題を呼び、今や夏に活躍する人気アイテムです。サマーシールド<sup>&reg;</sup>誕生から現在までのストーリーをぜひご一読ください。\r\n            </p>\r\n          </a>\r\n        </li>\r\n        <li class=\"swiper-slide item\">\r\n          <a href=\"https://youtu.be/fN6r0sB9qsE\" class=\"clip\" target=\"_blank\">\r\n            <picture class=\"clipImg\">\r\n              <img srcset=\"./images/index_slide_04.webp\" alt=\"\">\r\n            </picture>\r\n            <p class=\"clipHeading\">\r\n              <strong>東レ100周年記念作品</strong>\r\n            実話に基づく短編映画 <br>「A RAY OF LIGHT／一条の光」と「東レ100年の軌跡」\r\n            </p>\r\n          </a>\r\n        </li>\r\n        <li class=\"swiper-slide item\">\r\n          <a href=\"https://youtu.be/ncJPlpSRtnM\" class=\"clip\" target=\"_blank\">\r\n            <picture class=\"clipImg\">\r\n              <img srcset=\"./images/index_slide_08.webp\" alt=\"\">\r\n            </picture>\r\n            <p class=\"clipHeading\">\r\n              <strong>【YouTube東レチャンネル「東レポ」】</strong>\r\n            第２弾：女子バレーボールチーム「東レアローズ滋賀」の花岡選手と結束選手、OGの迫田さおりさんが登場！チームの本拠地・大津市 石山の魅力と、選手たちの強い“絆”をお届けします。トーク終盤にはスペシャルゲストも出演!?　ぜひご覧ください。\r\n            </p>\r\n          </a>\r\n        </li>\r\n        <li class=\"swiper-slide item\">\r\n          <a href=\"https://youtu.be/jCySIbyJ8mQ\" class=\"clip\" target=\"_blank\">\r\n            <picture class=\"clipImg\">\r\n              <img srcset=\"./images/index_slide_09.webp\" alt=\"\">\r\n            </picture>\r\n            <p class=\"clipHeading\">\r\n              <strong>【YouTube東レチャンネル「東レポ」】</strong>\r\n            第１弾：社長に直撃取材！「科学で社会の未来を紡ぐ」とは？素材に込めた願いと夢の続き\r\n            </p>\r\n          </a>\r\n        </li>\r\n        <li class=\"swiper-slide item\">\r\n          <a href=\"/news/article.html?contentId=6ov2xbsl\" class=\"clip\">\r\n            <picture class=\"clipImg\">\r\n              <img srcset=\"./images/index_slide_02.webp\" alt=\"\">\r\n            </picture>\r\n            <p class=\"clipHeading\">\r\n              <strong>長期経営方針、中期経営課題</strong>\r\n              長期経営方針“TORAY Challenges 2035”ならびに中期経営課題“IGNITION 2028”についてご説明します。\r\n            </p>\r\n          </a>\r\n        </li>\r\n        <li class=\"swiper-slide item\">\r\n          <a href=\"https://note.toray/n/n3f5475f04186\" class=\"clip\" target=\"_blank\">\r\n            <picture class=\"clipImg\">\r\n              <img srcset=\"./images/index_slide_03.webp\" alt=\"\">\r\n            </picture>\r\n            <p class=\"clipHeading\">\r\n              <strong>【東レ公式note】家庭に寄り添い40年。<br>「水は東レのトレビーノ<sup>&reg;</sup>」が選ばれ続けてきたわけ</strong>\r\n              「こんなところにも？」──実は、私たちの暮らしの様々な場面で使われている東レの素材。今回ご紹介するのは、東レ独自の強みである膜技術から生まれ、1986年の発売から40周年を迎えた家庭用浄水器「トレビーノ<sup>&reg;</sup>」です。\r\n            </p>\r\n          </a>\r\n        </li>\r\n        <li class=\"swiper-slide item\">\r\n          <a href=\"https://partners.wsj.com/toray/the-fabric-of-innovation/the-hidden-technology-transforming-americas-fastest-growing-sport-jp/\" class=\"clip\" target=\"_blank\">\r\n            <picture class=\"clipImg\">\r\n              <img srcset=\"./images/index_slide_05.webp\" alt=\"\">\r\n            </picture>\r\n            <p class=\"clipHeading\">\r\n              <strong>The Fabric of Innovation</strong>\r\n              全米で人気沸騰のスポーツ「ピックルボール」― その進化を陰で支える先端素材の力。\r\n            </p>\r\n          </a>\r\n        </li>\r\n        <li class=\"swiper-slide item\">\r\n          <a href=\"/100th/\" class=\"clip\" target=\"_blank\">\r\n            <picture class=\"clipImg\">\r\n              <img srcset=\"./images/index_slide_07.webp\" alt=\"\">\r\n            </picture>\r\n            <p class=\"clipHeading\">\r\n              <strong>創立100周年特設サイト</strong>\r\n              ここから先の百年。どんな仲間と、どんな素材で、どんな世界を描こうか。 ― 東レ創立100周年に関する情報をご紹介します。\r\n            </p>\r\n          </a>\r\n        </li>\r\n        <li class=\"swiper-slide item\">\r\n          <a href=\"https://partners.wsj.com/toray/the-fabric-of-innovation/rewriting-the-rules-of-fashion-discover-the-partnership-reshaping-modern-clothing-jp/\" class=\"clip\" target=\"_blank\">\r\n            <picture class=\"clipImg\">\r\n              <img srcset=\"./images/index_slide_06.webp\" alt=\"\">\r\n            </picture>\r\n            <p class=\"clipHeading\">\r\n              <strong>The Fabric of Innovation</strong>\r\n              ファッションの常識を塗り替える<br>東レ×ユニクロ トップが語るパートナーシップの力\r\n            </p>\r\n          </a>\r\n        </li>\r\n      </ul>\r\n      <div class=\"swiper-controls\">\r\n        <div class=\"swiper-button-prev\"></div>\r\n        <div class=\"swiper-pagination\"></div>\r\n        <div class=\"swiper-button-play\" tabindex=\"0\" role=\"button\" aria-label=\"Stop Play\" aria-disabled=\"false\"></div>\r\n        <div class=\"swiper-button-next\"></div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</div><!-- /ly_container-->\r\n\r\n<div class=\"ly_container uq_topImportantNotice\">\r\n  <div class=\"ly_inner\">\r\n    <div class=\"noticeWrap\">\r\n      <h2 class=\"noticeHeading\">重要なお知らせ</h2>\r\n      <ul class=\"noticeList\">\r\n        <!--<li><a href=\"/aboutus/information/inf220502.html\" target=\"_blank\">当社樹脂事業におけるUL認証登録に関する不適正行為への対応状況