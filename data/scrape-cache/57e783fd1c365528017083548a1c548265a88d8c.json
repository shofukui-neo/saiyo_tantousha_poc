{"url":"https://www.goko-net.jp/information/34","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n\n<head>\n  <!-- Global site tag (gtag.js) - Google Analytics -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=UA-47328307-1\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'UA-47328307-1');\n</script>\n  <meta charset=\"utf-8\">\n  <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n  <meta name=\"format-detection\" content=\"telephone=no\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <meta name=\"Description\" content=\"栃木県（宇都宮市）・群馬県（前橋市・高崎市）・茨城県（水戸市・つくば市）の北関東を中心に、東京から仙台を中心に東北までディスプレイやイベント、サインなどの企画・制作・運営までを一貫してご提供いたします。\">\n  <meta name=\"Keywords\" content=\"五光,栃木県,群馬県,茨城県,宇都宮市,前橋市,高崎市,水戸市,つくば市,宇都宮餃子,マロニエプラザ,オリオンスクエア,イベント,ディスプレイ,サイン,イルミネーション\">\n  <title>大谷コネクトHP　新設のご案内 | 五光[GOKO]:栃木(宇都宮)/群馬(前橋･高崎)/茨城(水戸･つくば)のイベント,ディスプレイ,サインなどSPの専門会社</title>\n\n  <meta property=\"og:title\" content=\"五光[GOKO]:栃木(宇都宮)/群馬(前橋･高崎)/茨城(水戸･つくば)のイベント,ディスプレイ,サインなどSPの専門会社\">\n  <meta property=\"og:url\" content=\"https://www.goko-net.jp/\">\n  <meta property=\"og:image\" content=\"https://www.goko-net.jp/common/images/ogp.jpg\">\n  <meta property=\"og:type\" content=\"article\">\n\n  <link rel=\"shortcut icon\" href=\"/favicon.ico?v=1d061ad2c11b8630c8c253e3678856a7\" type=\"image/x-icon\">\n  <link rel=\"icon\" href=\"/favicon.ico?v=1d061ad2c11b8630c8c253e3678856a7\" type=\"image/x-icon\">\n\n  <link href=\"https://fonts.googleapis.com/css?family=Exo+2:400,500,600,700&display=swap\" rel=\"stylesheet\">\n\n  <link rel=\"stylesheet\" href=\"/common/css/normalize.css?v=ccc10c60c0f52084eb4f60647bd2ad9e\">\n  <link rel=\"stylesheet\" href=\"/common/css/common.css\">\n  <link rel=\"stylesheet\" href=\"./css/style.css?\">\n</head>\n\n<body>\n  <div id=\"container\" class=\"container\">\n    <header class=\"header\" id=\"header\">\