</script>\n\n<!--=======[ Fade animate ]=======-->\n<script src=\"../js/jquery.inview.js\"></script>\n<script>\n  $(function() {\n    $('.v1 h1').on('inview', function(event, isInView) {\n      if (isInView) {\n        $(this).addClass('fadeInRight');\n      }\n    });\n  });\n</script>\n\n<!--=======[ Masonry ]=======-->\n<script src=\"../js/masonry.pkgd.min.js\"></script>\n<script src=\"../js/imagesloaded.pkgd.min.js\"></script>\n<script>\n  window.addEventListener('DOMContentLoaded', function() {\n    document.querySelectorAll('.box ul').forEach(function(box) {\n\n      if (box.classList.contains('nomasonry')) return;\n\n      imagesLoaded(box, function() {\n        new Masonry(box, {\n          itemSelector: '.panel',\n          percentPosition: true,\n          isAnimated: true\n        });\n      });\n\n    });\n  });\n</script>\n\n\n<!--=======[ Fade Masonry ]=======-->\n<script>\n  $(function() {\n    $(window).scroll(function() {\n      $('.fadein').each(function() {\n        var elemPos = $(this).offset().top;\n        var scroll = $(window).scrollTop();\n        var windowHeight = $(window).height();\n        if (scroll > elemPos - windowHeight - 200) {\n          $(this).addClass('scrollin');\n        }\n      });\n    });\n  });\n</script>\n\n\n\n<script>\n  document.addEventListener('DOMContentLoaded', () => {\n    document.querySelectorAll('#gnav .has-child').forEach((li) => {\n      const btn = li.querySelector('.gnav-toggle, .gnav-parent');\n      if (!btn) return;\n\n      const id = btn.getAttribute('aria-controls');\n      const panel = id ? document.getElementById(id) : null;\n      if (!panel) return;\n\n      // 初期は閉じる\n      btn.setAttribute('aria-expanded', 'false');\n      panel.hidden = true;\n\n      const openMenu = () => {\n        btn.setAttribute('aria-expanded', 'true');\n        panel.hidden = false;\n      };\n\n      const closeMenu = () => {\n        btn.setAttribute('aria-expanded', 'false');\n        panel.hidden = true;\n      };\n\n      // マウス\n      li.addEventListener('mouseenter', openMenu);\n      li.addEventListener('mouseleave', closeMenu);\n\n      // キーボードフォーカス\n      li.addEventListener('focusin', openMenu);\n      li.addEventListener('focusout', (e) => {\n        if (!li.contains(e.relatedTarget)) {\n          closeMenu();\n        }\n      });\n    });\n  });\n</script>\n\n\n\n<script>\n  document.addEventListener('DOMContentLoaded', () => {\n    const menuBtn = document.getElementById('spMenuBtn') || document.querySelector('.sp .hamburger');\n    const drawer = document.getElementById('sp-drawer') || document.getElementById('spMenuPanel');\n\n    if (!menuBtn || !drawer) return;\n\n    const TRANSITION_MS = 450; // drawer.cssに合わせて調整\n    const focusableSelector = [\n      'a[href]',\n      'button:not([disabled])',\n      'input:not([disabled])',\n      'select:not([disabled])',\n      'textarea:not([disabled])',\n      '[tabindex]:not([tabindex=\"-1\"])'\n    ].join(',');\n\n    let lastActiveEl = null;\n    let scrollY = 0;\n\n    const getFocusable = () =>\n      Array.from(drawer.querySelectorAll(focusableSelector))\n      .filter(el => !el.hasAttribute('disabled') && el.offsetParent !== null);\n\n    const main = document.getElementById('main'); // ← 追加（main要素）\n\n    const openMenu = () => {\n      lastActiveEl = document.activeElement;\n\n      drawer.hidden = false;\n\n      // 🔧 これを追加（アニメ保証トリガー）\n      drawer.offsetHeight;\n\n      // 背景スクロール位置を保存し、固定\n      scrollY = window.scrollY || window.pageYOffset || 0;\n      document.body.classList.add('is-menu-open');\n      document.body.style.position = 'fixed';\n      document.body.style.top = `-${scrollY}px`;\n      document.body.style.left = '0';\n      document.body.style.right = '0';\n      document.body.style.width = '100%';\n\n      requestAnimationFrame(() => {\n        drawer.classList.add('is-open');\n      });\n\n      menuBtn.setAttribute('aria-expanded', 'true');\n      menuBtn.setAttribute('aria-label', 'メニューを閉じる');\n\n      // フォーカスをトリガーに戻す（OK）\n      menuBtn.focus();\n\n      if (main) main.setAttribute('aria-hidden', 'true');\n    };\n\n\n\n    const closeMenu = () => {\n      drawer.classList.remove('is-open');\n      menuBtn.setAttribute('aria-expanded', 'false');\n      menuBtn.setAttribute('aria-label', 'メニューを開く');\n\n      // アニメ後にhidden\n      window.setTimeout(() => {\n        drawer.hidden = true;\n\n        // ✅ 追加：本文の aria-hidden を戻す\n        if (main) main.removeAttribute('aria-hidden');\n\n        // 背景固定解除して元の位置に戻す\n        document.body.classList.remove('is-menu-open');\n        const top = document.body.style.top;\n        document.body.style.position = '';\n        document.body.style.top = '';\n        document.body.style.left = '';\n        document.body.style.right = '';\n        document.body.style.width = '';\n        window.scrollTo(0, parseInt(top || '0', 10) * -1);\n\n        // フォーカス戻し\n        (lastActiveEl || menuBtn).focus();\n      }, TRANSITION_MS);\n    };\n\n\n    const isOpen = () => menuBtn.getAttribute('aria-expanded') === 'true';\n\n    menuBtn.addEventListener('click', () => {\n      isOpen() ? closeMenu() : openMenu();\n    });\n\n    // ESCで閉じる\n    document.addEventListener('keydown', (e) => {\n      if (!isOpen()) return;\n\n      if (e.key === 'Escape') {\n        e.preventDefault();\n        closeMenu();\n        return;\n      }\n\n      // Spaceで背景が動くのを防ぐ（フォーカスがメニュー内にある前提）\n      if (e.key === ' ' || e.code === 'Space') {\n        // フォーカスがリンク/ボタン等にある場合は本来の操作を邪魔しない\n        const t = e.target;\n        const isInteractive =\n          t && (t.tagName === 'BUTTON' || t.tagName === 'A' || t.tagName === 'INPUT' || t.tagName === 'TEXTAREA' || t.tagName === 'SELECT');\n        if (!isInteractive) e.preventDefault();\n      }\n\n      // フォーカストラップ（Tabで外に出ない）\n      if (e.key === 'Tab') {\n        // 「閉じるボタン + メニュー内」のフォーカス可能要素をまとめる\n        const focusables = [menuBtn, ...getFocusable()].filter(Boolean);\n\n        if (focusables.length === 0) {\n          e.preventDefault();\n          return;\n        }\n\n        const first = focusables[0]; // menuBtn\n        const last = focusables[focusables.length - 1];\n\n        // 現在がどこか\n        const current = document.activeElement;\n\n        // Shift+Tabで先頭（menuBtn）から戻る→最後へ\n        if (e.shiftKey && current === first) {\n          e.preventDefault();\n          last.focus();\n          return;\n        }\n\n        // Tabで最後から進む→先頭（menuBtn）へ\n        if (!e.shiftKey && current === last) {\n          e.preventDefault();\n          first.focus();\n          return;\n        }\n      }\n    });\n\n    // クリック外で閉じる（必要なら）\n    document.addEventListener('click', (e) => {\n      if (!isOpen()) return;\n      if (e.target.closest('#sp-drawer') || e.target.closest('.sp .hamburger')) return;\n\n      closeMenu();\n    });\n\n    // アコーディオン\n    // アコーディオン（アニメ対応）\n    document.querySelectorAll('.accordion-toggle').forEach((btn) => {\n\n      const id = btn.getAttribute('aria-controls');\n      const panel = id ? document.getElementById(id) : null;\n      if (!panel) return;\n\n      // 初期状態\n      btn.setAttribute('aria-expanded', 'false');\n      panel.hidden = true;\n      panel.style.maxHeight = '0px';\n      panel.classList.remove('is-expanded');\n\n      const openPanel = () => {\n        btn.setAttribute('aria-expanded', 'true');\n        btn.setAttribute('aria-label', btn.dataset.labelClose || 'メニューを閉じる');\n\n        panel.hidden = false;\n        panel.style.maxHeight = '0px';\n        panel.classList.add('is-expanded');\n\n        requestAnimationFrame(() => {\n          panel.style.maxHeight = panel.scrollHeight + 'px';\n        });\n      };\n\n      const closePanel = () => {\n        btn.setAttribute('aria-expanded', 'false');\n        btn.setAttribute('aria-label', btn.dataset.labelOpen || 'メニューを開く');\n\n        panel.style.maxHeight = panel.scrollHeight + 'px';\n        requestAnimationFrame(() => {\n          panel.style.maxHeight = '0px';\n          panel.classList.remove('is-expanded');\n        });\n\n        const onEnd = (e) => {\n          if (e.propertyName !== 'max-height') return;\n          panel.hidden = true;\n          panel.removeEventListener('transitionend', onEnd);\n        };\n        panel.addEventListener('transitionend', onEnd);\n      };\n\n      btn.addEventListener('click', () => {\n        const expanded = btn.getAttribute('aria-expanded') === 'true';\n        expanded ? closePanel() : openPanel();\n      });\n\n      // 画面回転・リサイズ時：開いているパネルの高さを再計算\n      window.addEventListener('resize', () => {\n        if (btn.getAttribute('aria-expanded') === 'true') {\n          panel.style.maxHeight = panel.scrollHeight + 'px';\n        }\n      });\n    });\n\n  });\n</script>\n\n<script>\n  document.addEventListener('DOMContentLoaded', () => {\n    const triggers = document.querySelectorAll('.office-acc-trigger');\n    if (!triggers.length) return;\n\n    const DURATION = 350; // CSSのmax-height transition と合わせる\n\n    triggers.forEach((btn) => {\n      const id = btn.getAttribute('aria-controls');\n      const panel = id ? document.getElementById(id) : null;\n      if (!panel) return;\n\n      // 初期状態を必ず閉じる\n      btn.setAttribute('aria-expanded', 'false');\n      panel.classList.remove('is-open');\n      panel.hidden = true;\n      panel.style.maxHeight = '0px';\n\n      const open = () => {\n        btn.setAttribute('aria-expanded', 'true');\n        panel.hidden = false;\n        panel.classList.add('is-open');\n\n        // 1) 念のため初期化\n        panel.style.maxHeight = '0px';\n\n        // 2) 強制リフロー\n        panel.offsetHeight;\n\n        // 3) 実サイズまで展開\n        panel.style.maxHeight = panel.scrollHeight + 'px';\n\n        // 4) 開き切ったら制限解除（高さ変動に強くする）\n        window.setTimeout(() => {\n          if (btn.getAttribute('aria-expanded') === 'true') {\n            panel.style.maxHeight = 'none';\n          }\n        }, DURATION + 50);\n      };\n\n      const close = () => {\n        btn.setAttribute('aria-expanded', 'false');\n        panel.classList.remove('is-open');\n\n        // 1) いったん現在高さを固定\n        panel.style.maxHeight = panel.scrollHeight + 'px';\n\n        // 2) 強制リフロー（これが重要）\n        panel.offsetHeight; // eslint-disable-line no-unused-expressions\n\n        // 3) 0へ（transition確実に走る）\n        panel.style.maxHeight = '0px';\n\n        // 4) transitionendに頼らず確実にhiddenへ\n        window.setTimeout(() => {\n          // 閉じたままなら隠す\n          if (btn.getAttribute('aria-expanded') === 'false') {\n            panel.hidden = true;\n          }\n        }, DURATION + 50);\n      };\n\n\n\n\n\n      btn.addEventListener('click', () => {\n        const expanded = btn.getAttribute('aria-expanded') === 'true';\n        expanded ? close() : open();\n      });\n\n      // 開いている時だけリサイズ再計算\n      window.addEventListener('resize', () => {\n        if (btn.getAttribute('aria-expanded') === 'true') {\n          panel.style.maxHeight = panel.scrollHeight + 'px';\n        }\n      });\n    });\n  });\n</script>\n\n<script>\n  document.addEventListener('DOMContentLoaded', () => {\n    const triggers = document.querySelectorAll('.group-acc-trigger');\n    if (!triggers.length) return;\n\n    const DURATION = 350; // CSSのtransition時間に合わせる（未設定ならこのままでもOK）\n\n    triggers.forEach((btn) => {\n      const id = btn.getAttribute('aria-controls');\n      const panel = id ? document.getElementById(id) : null;\n      if (!panel) return;\n\n      // 初期は閉じる\n      btn.setAttribute('aria-expanded', 'false');\n      panel.hidden = true;\n      panel.style.maxHeight = '0px';\n\n      const open = () => {\n        btn.setAttribute('aria-expanded', 'true');\n        panel.hidden = false;\n\n        panel.style.maxHeight = '0px';\n        panel.offsetHeight; // reflow\n        panel.style.maxHeight = panel.scrollHeight + 'px';\n\n        window.setTimeout(() => {\n          if (btn.getAttribute('aria-expanded') === 'true') {\n            panel.style.maxHeight = 'none';\n          }\n        }, DURATION + 50);\n      };\n\n      const close = () => {\n        btn.setAttribute('aria-expanded', 'false');\n\n        // none対策：数値に戻してから閉じる\n        panel.style.maxHeight = panel.scrollHeight + 'px';\n        panel.offsetHeight;\n        panel.style.maxHeight = '0px';\n\n        window.setTimeout(() => {\n          if (btn.getAttribute('aria-expanded') === 'false') {\n            panel.hidden = true;\n          }\n        }, DURATION + 50);\n      };\n\n      btn.addEventListener('click', () => {\n        const expanded = btn.getAttribute('aria-expanded') === 'true';\n        expanded ? close() : open();\n      });\n\n      window.addEventListener('resize', () => {\n        if (btn.getAttribute('aria-expanded') === 'true' && panel.style.maxHeight !== 'none') {\n          panel.style.maxHeight = panel.scrollHeight + 'px';\n        }\n      });\n    });\n  });\n</script>\n\n<script>\n  document.addEventListener('DOMContentLoaded', () => {\n    const skip = document.querySelector('.skip-link');\n    const main = document.getElementById('main');\n\n    if (!skip || !main) return;\n\n    skip.addEventListener('click', () => {\n      main.setAttribute('tabindex', '-1');\n      main.focus({\n        preventScroll: true\n      });\n    });\n  });\n</script>\n\n\n\n\n\n<!--=======[ go top]======= -->\n<script src=\"../js/base.js\"></script>\n\n</body>\n\n</html>\n","finalUrl":"https://www.sg-ud.co.jp/inquiry/","rendered":false,"_cachedAt":"2026-06-22T19:45:42.557Z"}