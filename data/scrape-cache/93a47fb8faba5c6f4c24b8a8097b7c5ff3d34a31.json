62-4335-a01c-de107b54d066{\r\n            height:100%\r\n        }\r\n    </style>\r\n    <div    level=\"1\"  width=\"100px\" height=\"100px\" _id=\"9f796140-f162-4335-a01c-de107b54d066\" style=\"width:100%;\" order='1' class=\"layoutBox-sm slot_cls9f796140-f162-4335-a01c-de107b54d066 cms_currency_layout  \" tplConfig dischargeComponent floorname=\"\"></div>\r\n    <div    level=\"1\"  width=\"100px\" height=\"100px\" _id=\"9f796140-f162-4335-a01c-de107b54d066\" style=\"width:100%;\" order='2' class=\"layoutBox-sm slot_cls9f796140-f162-4335-a01c-de107b54d066 cms_currency_layout  \" tplConfig dischargeComponent floorname=\"\"><div style=\"width:100%;height:100%\" width=\"1556.98\" height=\"50\" order=\"2\" issupportfloat=\"true\"   level=\"2\" compId='fde24486-04db-40f3-8af4-5238ec82c232' id=\"a0723160-4707-44ee-ac2e-56ebb2573057\" class=\"container9998 nec_series_product_footer_link_line min_height\"  componentRender=\"slides\">\r\n    \r\n \r\n  <title>ご利用ガイド ショッピング（NEC Direct）ご利用ガイドトップページ NEC Direct｜NEC LAVIE公式サイト</title> \r\n  <meta name=\"keywords\" content=\"NEC, LAVIE,公式サイト,利用,ガイド\"> \r\n  <meta name=\"description\" content=\"こちらはNEC LAVIE公式サイトショッピングの ご利用ガイド はじめにお読みくださいについてのページです。\"> \r\n  <link href=\"//c1-nec.static.pub/version/css/55e595bdc2e79e96b97208ed19350b13.css\" rel=\"stylesheet\"> \r\n  <script src=\"//j1-nec.static.pub/version/js/3ad39022467462941f4ee1d47afac8de.js\"></script> \r\n  <!-- コンテンツここから --> \r\n \r\n \r\n  <div id=\"necqa\" class=\"necqa\"> \r\n   <section class=\"necqa_supportLinks\" aria-labelledby=\"necqa-supportLinks-title\"> \r\n    <div class=\"necqa_supportLinks__inner\"> \r\n     <h2 id=\"necqa-supportLinks-title\" class=\"necqa_supportLinks__title\"> サポート関連リンク </h2> \r\n     <ul class=\"necqa_supportLinks__list\"> \r\n      <li class=\"necqa_supportLinks__item\"> <a class=\"necqa_supportLinks__link\" href=\"/navigate/direct/info/faq/\"> よくあるご質問 </a> </li> \r\n      <li class=\"necqa_supportLinks__item\"> <a class=\"necqa_supportLinks__link\" href=\"/shop/info/guide/inquiry/\"> ご購入相談・サポート </a> </li> \r\n     </ul> \r\n    </div> \r\n   </section> \r\n   <section class=\"necqa_supportNotice\" aria-labelledby=\"necqa-supportNotice-title\"> \r\n    <div class=\"necqa_supportNotice__inner\"> \r\n     <h2 id=\"necqa-supportNotice-title\" class=\"necqa_supportNotice__title\"> ショッピング（NEC Direct）&nbsp;ご利用ガイド </h2> \r\n     <p class=\"necqa_supportNotice__lead\"> NEC Directをより一層ご理解いただくために、ご購入、お支払い、ご配送をはじめとして、さまざまな情報をご用意しております。 ぜひご利用ください。 </p> \r\n     <div class=\"necqa_supportNotice__group\"> \r\n      <section class=\"necqa_noticeImportant\" aria-labelledby=\"necqa-noticeImportant-title\"> \r\n       <div class=\"necqa_noticeImportant__box\"> \r\n        <h3 id=\"necqa-noticeImportant-title\" class=\"necqa_noticeImportant__title\"> 重要なお知らせ </h3> \r\n        <div class=\"necqa_noticeImportant__body\"> \r\n         <p class=\"necqa_noticeImportant__linkWrap\"> <a class=\"necqa_noticeImportant__link js-necqa-modal-open\" href=\"#necqa-modal-login-id\" data-modal-id=\"necqa-modal-login-id\" aria-haspopup=\"dialog\" aria-controls=\"necqa-modal-login-id\"> 【古いログインID（2020年5月24日以前）をお持ちのお客様へ】 <span class=\"necqa_noticeImportant__linkIcon\" aria-hidden=\"true\"></span> </a> </p> \r\n         <p class=\"necqa_noticeImportant__text\"> ※お問い合わせ方法のご案内NEC Direct（購入前のご相談・ご注文に関するお問い合わせ）は電話では承っておりません。 </p> \r\n         <ul class=\"necqa_noticeImportant__guideList\"> \r\n          <li class=\"necqa_noticeImportant__guideItem\"> <span class=\"necqa_noticeImportant__guideLabel\">■購入前（製品選び・購入手続き）</span> <span class=\"necqa_noticeImportant__guideText\">→ FAQ / チャットをご利用ください。</span> </li> \r\n          <li class=\"necqa_noticeImportant__guideItem\"> <span class=\"necqa_noticeImportant__guideLabel\">■注文後（納期・注文内容・領収書など）</span> <span class=\"necqa_noticeImportant__guideText\">→ マイページをご確認ください。</span> </li> \r\n          <li class=\"necqa_noticeImportant__guideItem\"> <span class=\"necqa_noticeImportant__guideLabel\">■購入後（使い方・故障・修理）</span> <span class=\"necqa_noticeImportant__guideText\">→ サポートサイトの窓口をご利用ください。</span> </li> \r\n         </ul> \r\n        </div> \r\n       </div> \r\n       <dialog class=\"necqa_modal\" id=\"necqa-modal-login-id\" aria-labelledby=\"necqa-modal-login-id-title\" name=\"necqa_modal\"> \r\n        <button class=\"necqa_modal__close js-necqa-modal-close\" type=\"button\" aria-label=\"モーダルを閉じる\"> <span class=\"necqa_modal__closeLine\" aria-hidden=\"true\"></span> </button> \r\n        <div class=\"necqa_modal__inner\"> \r\n         <div class=\"necqa_modal__content\"> \r\n          <div class=\"necqa_modalNotice\"> \r\n           <div class=\"necqa_modalNotice__body\"> \r\n            <p> ログインにメールアドレスが必要となります。<br> 20年5月25日以降ログインIDを廃止し、メールアドレスでログインする方式に変更いたしました。<br>これに伴い、セキュリティ保護のため、パスワードの再設定（初期化）が必要となります。大変お手数ですが、まだ済みでないお客様は、&nbsp;<a class=\"necqa_modalNotice__link\" href=\"https://support.nec-lavie.jp/migration\" target=\"_blank\" rel=\"noopener noreferrer\">お客様登録更新のご案内</a>をご覧ください。 </p> \r\n           </div> \r\n           <div class=\"necqa_modalNotice__callcenter\"> \r\n            <p class=\"necqa_modalNotice__callcenterLead\"> 万一、パスワード再設定でお客様登録更新ができない場合は、サポートサイトの案内をご確認ください。 </p> \r\n            <div class=\"necqa_modalNotice__callcenterBody\"> \r\n             <p>※本ガイドに掲載している「購入前相談／ご注文に関するお問い合わせ」は電話受付を行っておりません。 お手続き・ご不明点はFAQ／チャット／お問い合わせフォームをご利用ください。</p> \r\n            </div> \r\n           </div> \r\n          </div> \r\n         </div> \r\n        </div> \r\n       </dialog> \r\n      </section> \r\n      <section class=\"necqa_notice\" aria-labelledby=\"necqa-notice-title\"> \r\n       <div class=\"necqa_notice__box\"> \r\n        <h3 id=\"necqa-notice-title\" class=\"necqa_notice__title\"> ご注意ください </h3> \r\n        <ul class=\"necqa_notice__list\"> \r\n         <li class=\"necqa_notice__item\"> \r\n          <details class=\"necqa_notice__details\"> \r\n           <summary class=\"necqa_notice__summary\"> <span class=\"necqa_notice__summaryMain\"> <span class=\"necqa_notice__summaryText\"> 悪天候での配送遅延について </span> <span class=\"necqa_notice__icon\" aria-hidden=\"true\"></span> </span> </summary> \r\n           <div class=\"necqa_notice__panel\"> \r\n            <div class=\"necqa_notice__panelInner\"> \r\n             <p class=\"necqa_notice__text\"> 悪天候や交通事情などの影響により、一部地域で配送に遅れが発生する場合があります。 最新の配送状況は各配送会社のお知らせをご確認ください。 </p> \r\n            </div> \r\n           </div> \r\n          </details> </li> \r\n        </ul> \r\n       </div> \r\n      </section> \r\n     </div> \r\n    </div> \r\n   </section> \r\n   <section class=\"necqa_flow\" aria-labelledby=\"necqa-flow-title\"> \r\n    <div class=\"necqa_flow__inner\"> \r\n     <h2 id=\"necqa-flow-title\" class=\"necqa_flow__title\"> お買い物の流れ </h2> \r\n     <ol class=\"necqa_flow__list\"> \r\n      <li class=\"necqa_flow__item\"> \r\n       <div class=\"necqa_flow__step\"> \r\n        <button class=\"necqa_flow__trigger\" type=\"button\" aria-expanded=\"false\" data-flow-panel=\"mypage\" data-flow-align=\"left\"> <span class=\"necqa_flow__triggerIcon necqa_flow__triggerIcon--mypage\" aria-hidden=\"true\"></span> <span class=\"necqa_flow__triggerLabel\"> マイページ・<br>お客様登録 </span> <span class=\"necqa_flow__triggerToggle\" aria-hidden=\"true\"></span> </button> \r\n        <div class=\"necqa_flow__panel necqa_flow__panel--sp\"> \r\n         <ul class=\"necqa_flow__subnav\"> \r\n          <li class=\"necqa_flow__subnavItem\"><a class=\"necqa_flow__subnavLink\" href=\"/shop/info/guide/mypage/\">マイページとは</a></li> \r\n          <li class=\"necqa_flow__subnavItem\"><a class=\"necqa_flow__subnavLink\" href=\"/shop/info/help/guide/#3abIdPt\">メルマガ会員の登録</a></li> \r\n          <li class=\"necqa_flow__subnavItem\"><a class=\"necqa_flow__subnavLink\" href=\"https://support.nec-lavie.jp/navigate/mypage/help/signup/\" target=\"_blank\">お客様登録手続き</a></li> \r\n          <li class=\"necqa_flow__subnavItem\"><a class=\"necqa_flow__subnavLink\" href=\"/shop/info/guide/points/\">ポイントの確認</a></li> \r\n          <li class=\"necqa_flow__subnavItem\"><a class=\"necqa_flow__subnavLink\" href=\"/shop/info/guide/mail/\">ポイントメール</a></li> \r\n          <li class=\"necqa_flow__subnavItem\"><a class=\"necqa_flow__subnavLink\" href=\"/shop/info/guide/keitaimail/\">携帯電話・E-mailアドレスの&nbsp;登録について</a></li> \r\n         </ul> \r\n        </div> \r\n       </div> </li> \r\n      <li class=\"necqa_flow__arrow\" aria-hidden=\"true\"></li> \r\n      <li class=\"necqa_flow__item\"> \r\n       <div class=\"necqa_flow__step\"> \r\n        <button class=\"necqa_flow__trigger\" type=\"button\" aria-expanded=\"false\" data-flow-panel=\"purchase\" data-flow-align=\"left\"> <span class=\"necqa_flow__triggerIcon necqa_flow__triggerIcon--cart\" aria-hidden=\"true\"></span> <span class=\"necqa_flow__triggerLabel\"> ご購入 </span> <span class=\"necqa_flow__triggerToggle\" aria-hidden=\"true\"></span> </button> \r\n        <div class=\"necqa_flow__panel necqa_flow__panel--sp\"> \r\n         <ul class=\"necqa_flow__subnav\"> \r\n          <li class=\"necqa_flow__subnavItem\"><a class=\"necqa_flow__subnavLink\" href=\"/shop/info/help/guide/guide3_1.html\">ご購入方法</a></li> \r\n          <li class=\"necqa_flow__subnavItem\"><a class=\"necqa_flow__subnavLink\" href=\"/shop/info/guide/buy/customize/\">PCのカスタマイズ方法</a></li> \r\n          <li class=\"necqa_flow__subnavItem\"><a class=\"necqa_flow__subnavLink\" href=\"/shop/info/help/guide/cartfunction.html\">カートの使い方</a></li> \r\n          <li class=\"necqa_flow__subnavItem\"><a class=\"necqa_flow__subnavLink\" href=\"/shop/info/guide/memo_use/\">メモの使い方</a></li> \r\n          <li class=\"necqa_flow__subnavItem\"><a class=\"necqa_flow__subnavLink\" href=\"/shop/info/guide/coupon_use/\">クーポンの使い方</a></li> \r\n          <li class=\"necqa_flow__subnavItem\"><a class=\"necqa_flow__subnavLink\" href=\"/shop/info/guide/point/\">ポイントサービス</a></li> \r\n          <li class=\"necqa_flow__subnavItem\"><a class=\"necqa_flow__subnavLink\" href=\"/shop/info/guide/friend/\">お友達紹介プログラム</a></li> \r\n         </ul> \r\n        </div> \r\n       </div> </li> \r\n      <li class=\"necqa_flow__arrow\" aria-hidden=\"true\"></li> \r\n      <li class=\"necqa_flow__item\"> \r\n       <div class=\"necqa_flow__step\"> \r\n        <button class=\"necqa_flow__trigger\" type=\"button\" aria-expanded=\"false\" data-flow-panel=\"cancel\" data-flow-align=\"center\"> <span class=\"necqa_flow__triggerIcon necqa_flow__triggerIcon--box\" aria-hidden=\"true\"></span> <span class=\"necqa_flow__triggerLabel\"> キャンセル・<br>返品・変更 </span> <span class=\"necqa_flow__triggerToggle\" aria-hidden=\"true\"></span> </button> \r\n        <div class=\"necqa_flow__panel necqa_flow__panel--sp\"> \r\n         <ul class=\"necqa_flow__subnav\"> \r\n          <li class=\"necqa_flow__subnavItem\"><a class=\"necqa_flow__subnavLink\" href=\"/shop/info/help/guide/guide4_1.html\">ご注文内容の変更・キャンセルについて</a></li> \r\n          <li class=\"necqa_flow__subnavItem\"><a class=\"necqa_flow__subnavLink\" href=\"/shop/info/guide/return/\">お客さま都合によるご返品について</a></li> \r\n         </ul> \r\n        </div> \r\n       </div> </li> \r\n      <li class=\"necqa_flow__arrow\" aria-hidden=\"true\"></li> \r\n      <li class=\"necqa_flow__item\"> \r\n       <div class=\"necqa_flow__step\"> \r\n        <button class=\"necqa_flow__trigger\" type=\"button\" aria-expanded=\"false\" data-flow-panel=\"payment\" data-flow-align=\"right\"> <span class=\"necqa_flow__triggerIcon necqa_flow__triggerIcon--payment\" aria-hidden=\"true\"></span> <span class=\"necqa_flow__triggerLabel\"> お支払い </span> <span class=\"necqa_flow__triggerToggle\" aria-hidden=\"true\"></span> </button> \r\n        <div class=\"necqa_flow__panel necqa_flow__panel--sp\"> \r\n         <ul class=\"necqa_flow__subnav\"> \r\n          <li class=\"necqa_flow__subnavItem\"><a class=\"necqa_flow__subnavLink\" href=\"/shop/info/help/guide/payment.html\">お支払方法について(個人)</a></li> \r\n          <li class=\"necqa_flow__subnavItem\"><a class=\"necqa_flow__subnavLink\" href=\"/shop/info/guide/friend/payment2.html\">お支払方法について(法人)</a></li> \r\n          <li class=\"necqa_flow__subnavItem\"><a class=\"necqa_flow__subnavLink\" href=\"/shop/info/help/guide/chargeinfo.html\">送料について</a></li> \r\n         </ul> \r\n        </div> \r\n       </div> </li> \r\n      <li class=\"necqa_flow__arrow\" aria-hidden=\"true\"></li> \r\n      <li class=\"necqa_flow__item\"> \r\n       <div class=\"necqa_flow__step\"> \r\n        <button class=\"necqa_flow__trigger\" type=\"button\" aria-expanded=\"false\" data-flow-panel=\"delivery\" data-flow-align=\"right\"> <span class=\"necqa_flow__triggerIcon necqa_flow__triggerIcon--delivery\" aria-hidden=\"true\"></span> <span class=\"necqa_flow__triggerLabel\"> 配送 </span> <span class=\"necqa_flow__triggerToggle\" aria-hidden=\"true\"></span> </button> \r\n        <div class=\"necqa_flow__panel necqa_flow__panel--sp\"> \r\n         <ul class=\"necqa_flow__subnav\"> \r\n          <li class=\"necqa_flow__subnavItem\"><a class=\"necqa_flow__subnavLink\" href=\"/shop/info/delivery/\">納期について</a></li> \r\n          <li class=\"necqa_flow__subnavItem\"><a class=\"necqa_flow__subnavLink\" href=\"/shop/info/help/guide/guide3_2.html\">商品の配送について</a></li> \r\n          <li class=\"necqa_flow__subnavItem\"><a class=\"necqa_flow__subnavLink\" href=\"/shop/info/guide/order/\">ご注文状況の確認</a></li> \r\n         </ul> \r\n        </div> \r\n       </div> </li> \r\n     </ol> \r\n     <div class=\"necqa_flow__panelArea\" data-flow-align=\"left\" hidden> \r\n      <div class=\"necqa_flow__panelAreaInner\"> \r\n       <div class=\"necqa_flow__panel necqa_flow__panel--pc\" data-flow-panel-id=\"mypage\"></div> \r\n       <div class=\"necqa_flow__panel necqa_flow__panel--pc\" data-flow-panel-id=\"purchase\"></div> \r\n       <div class=\"necqa_flow__panel necqa_flow__panel--pc\" data-flow-panel-id=\"cancel\"></div> \r\n       <div class=\"necqa_flow__panel necqa_flow__panel--pc\" data-flow-panel-id=\"payment\"></div> \r\n       <div class=\"necqa_flow__panel necqa_flow__panel--pc\" data-flow-panel-id=\"delivery\"></div> \r\n      </div> \r\n     </div> \r\n    </div> \r\n   </section> \r\n   <section class=\"necqa_helpGuide\" aria-labelledby=\"necqa-helpGuide-title\"> \r\n    <div class=\"necqa_helpGuide__inner\"> \r\n     <h2 id=\"necqa-helpGuide-title\" class=\"necqa_helpGuide__title\"> ご購入に役立つガイド </h2> \r\n     <ul class=\"necqa_helpGuide__list\"> \r\n      <li class=\"necqa_helpGuide__item\"> \r\n       <section class=\"necqa_helpGuideCard\" aria-labelledby=\"necqa-helpGuideCard-title-01\"> \r\n        <div class=\"necqa_helpGuideCard__head\"> \r\n         <div class=\"necqa_helpGuideCard__icon\" aria-hidden=\"true\"> \r\n          <img src=\"//p2-nec.static.pub/fes/cms/2026/03/30/oznmryfew5vgvun5x65604tg871f57667391.svg\" alt=\"\" width=\"133\" height=\"32\"> \r\n         </div> \r\n         <h3 id=\"necqa-helpGuideCard-title-01\" class=\"necqa_helpGuideCard__title\"> NEC Directとは？ </h3> \r\n        </div> \r\n        <div class=\"necqa_helpGuideCard__body\"> \r\n         <ul class=\"necqa_helpGuideCard__linkList\"> \r\n          <li class=\"necqa_helpGuideCard__linkItem\"> <a class=\"necqa_helpGuideCard__link\" href=\"/shop/info/help/guide/\"> <span class=\"necqa_helpGuideCard__linkText\">はじめにお読みください</span> <span class=\"necqa_helpGuideCard__linkIcon\" aria-hidden=\"true\"></span> </a> </li> \r\n          <li class=\"necqa_helpGuideCard__linkItem\"> <a class=\"necqa_helpGuideCard__link\" href=\"/shop/attractivepoint/?ipromoID=subbanner_attractive#block3\"> <span class=\"necqa_helpGuideCard__linkText\">NEC Directで購入するメリット 7つのこだわり</span> <span class=\"necqa_helpGuideCard__linkIcon\" aria-hidden=\"true\"></span> </a> </li> \r\n          <li class=\"necqa_helpGuideCard__linkItem\"> <a class=\"necqa_helpGuideCard__link\" href=\"/shop/info/help/guide/\"> <span class=\"necqa_helpGuideCard__linkText\">ログインIDとNEC Directポイントとは？</span> <span class=\"necqa_helpGuideCard__linkIcon\" aria-hidden=\"true\"></span> </a> </li> \r\n          <li class=\"necqa_helpGuideCard__linkItem\"> <a class=\"necqa_helpGuideCard__link\" href=\"/shop/info/guide/about/customize_catalog/\"> <span class=\"necqa_helpGuideCard__linkText\">カスタマイズモデルとカタログモデル</span> <span class=\"necqa_helpGuideCard__linkIcon\" aria-hidden=\"true\"></span> </a> </li> \r\n         </ul> \r\n        </div> \r\n       </section> </li> \r\n      <li class=\"necqa_helpGuide__item\"> \r\n       <section class=\"necqa_helpGuideCard\" aria-labelledby=\"necqa-helpGuideCard-title-02\"> \r\n        <div class=\"necqa_helpGuideCard__head\"> \r\n         <div class=\"necqa_helpGuideCard__icon\" aria-hidden=\"true\"> \r\n          <img src=\"//p1-nec.static.pub/fes/cms/2026/03/30/jpcc3k6agqwq7lrt046wchnx7sgmfs991133.svg\" alt=\"\" width=\"52\" height=\"48\"> \r\n         </div> \r\n         <h3 id=\"necqa-helpGuideCard-title-02\" class=\"necqa_helpGuideCard__title\"> 証書発行 </h3> \r\n        </div> \r\n        <div class=\"necqa_helpGuideCard__body\"> \r\n         <ul class=\"necqa_helpGuideCard__linkList\"> \r\n          <li class=\"necqa_helpGuideCard__linkItem\"> <a class=\"necqa_helpGuideCard__link\" href=\"/shop/info/guide/quotation/\"> <span class=\"necqa_helpGuideCard__linkText\">見積書について</span> <span class=\"necqa_helpGuideCard__linkIcon\" aria-hidden=\"true\"></span> </a> </li> \r\n          <li class=\"necqa_helpGuideCard__linkItem\"> <a class=\"necqa_helpGuideCard__link\" href=\"/shop/info/help/guide/receipt.html\"> <span class=\"necqa_helpGuideCard__linkText\">領収書発行</span> <span class=\"necqa_helpGuideCard__linkIcon\" aria-hidden=\"true\"></span> </a> </li> \r\n         </ul> \r\n        </div> \r\n       </section> </li> \r\n     </ul> \r\n    </div> \r\n   </section> \r\n   <section class=\"necqa_chatCta\" aria-labelledby=\"necqa-chatCta-title\"> \r\n    <div class=\"necqa_chatCta__inner\"> \r\n     <div class=\"necqa_chatCta__box\"> \r\n      <h2 id=\"necqa-chatCta-title\" class=\"necqa_chatCta__title\"> <sp