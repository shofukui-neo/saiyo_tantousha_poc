{"url":"https://www.nta.co.jp/recruit/person/people.html","html":"<!DOCTYPE html PUBLIC \"-//W3C//DTD XHTML 1.0 Transitional//EN\" \"http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd\">\n<html xmlns=\"http://www.w3.org/1999/xhtml\">\n<head>\n<meta http-equiv=\"Content-Type\" content=\"text/html; charset=utf-8\" />\n<title>日旅People | 日本旅行2012新卒採用情報サイト</title>\n<meta name=\"keywords\" content=\"旅行,旅,赤い風船,旅行情報,国内旅行,ホテル,旅館,パック,ツアー,航空券,チケット\">\n<meta name=\"description\" content=\"旅のプランは日本旅行ホームページ。宿泊やパッケージツアー、航空券の検索・予約から、観光情報などが満載な総合旅行情報サイトです。宿泊、航空券、パッケージツアーは午前9時から午前2時30分までオンラインで予約・決済ができます。\"> \n<link href=\"../common/css/import.css\" rel=\"stylesheet\" type=\"text/css\" media=\"all\" />\n<link rel=\"shortcut icon\" href=\"../common/images/favicon.ico\" type=\"image/x-icon\"> \n<script type=\"text/javascript\" src=\"../js/rollover.js\"></script>\n\n</head>\n\n<body id=\"person\">\n<!--Header -->\n<div id=\"header\"><img src=\"../common/images/header.jpg\" alt=\"日本旅行 2012新卒採用情報サイト\" width=\"890\" height=\"67\" border=\"0\" usemap=\"#Map\" /></div>\n\n<!--Global Navi -->\n<div id=\"globalnavi_wrap\">\n\t<ul>\n\t\t<li id=\"navi01\"><a href=\"../business/seminar.html\" title=\"ビジネスを感じるZONE\">ビジネスを感じるZONE</a></li>\n\t\t<li id=\"navi02\"><a title=\"社員に触れるZONE\">社員に触れるZONE</a></li>\n\t\t<li id=\"navi03\"><a href=\"../company/history.html\" title=\"制度と風土を知るZONE\">制度と風土を知るZONE</a></li>\n\t\t<li id=\"navi04\"><a href=\"../recruit/article.html\" title=\"採用情報ZONE\">採用情報ZONE</a></li>\n\t</ul>\n</div>\n\n<!--Page Titel -->\n<h1><img src=\"images/title_people.jpg\" alt=\"日旅People\" width=\"886\" height=\"180\" /></h1>\n\n<!--Breadlist -->\n<div class=\"breadlist_wrap\">\n<ul>\n\t<li><a title=\"日旅People\">日旅People</a></li>\n\t<li><a title=\"社員に触れる\">社員に触れる</a></li>\n\t<li><a href=\"../index.html\" title=\"採用トップ\">採用トップ</a></li>\n</ul>\n</div>\n\n<!--Contents -->\n<div id=\"contents_wrap\">\n\t<!--Contents Area -->\n\t<div id=\"people\" class=\"contents_area\">\n\t<p class=\"honbun\">　\n 様々な個性を持った社員が集う日本旅行。仕事・これまでの体験・プライベートな旅・そして夢 … 一人ひとりの声から、日本旅行社員が持つ自由さや活気を感じてください。 &#13;</p>\n\t<div class=\"step4\">\n\t<div><a href=\"people01.html\"><img src=\"images/person_img01.jpg\" alt=\"\" width=\"163\" height=\"150\" border=\"0\" /></a></div>\n\t<div><a href=\"people02.html\"><img src=\"images/person_img02.jpg\" alt=\"\" width=\"163\" height=\"150\" border=\"0\" /></a></div>\n\t<div><a href=\"people03.html\"><img src=\"images/person_img03.jpg\" alt=\"\" width=\"163\" height=\"150\" border=\"0\" /></a></div>\n\t<div><a href=\"people04.html\"><img src=\"images/person_img04.jpg\" alt=\"\" width=\"163\" height=\"150\" border=\"0\" /></a></div>\n\t<br class=\"blockend\" />\n\t<!-- /step4 --></div>\n\t\n\t<div class=\"step4\">\n\t<div><a href=\"people05.html\"><img src=\"images/person_img05.jpg\" alt=\"\" width=\"163\" height=\"150\" border=\"0\" /></a></div>\n\t<div><a href=\"people06.html\"><img src=\"images/person_img06.jpg\" alt=\"\" width=\"163\" height=\"150\" border=\"0\" /></a></div>\n\t<div><a href=\"people07.html\"><img src=\"images/person_img07.jpg\" alt=\"\" width=\"163\" height=\"150\" border=\"0\" /></a></div>\n\t<div><a href=\"people08.html\"><img src=\"images/person_img08.jpg\" alt=\"\" width=\"163\" height=\"150\" border=\"0\" /></a></div>\n\t<br class=\"blockend\" />\n\t<!-- /step4 --></div>\n\t\n\t<div class=\"step4\">\n\t<div><a href=\"people09.html\"><img src=\"images/person_img09.jpg\" alt=\"\" width=\"163\" height=\"150\" border=\"0\" /></a></div>\n\t<div><a href=\"people10.html\"><img src=\"images/person_img10.jpg\" alt=\"\" width=\"163\" height=\"150\" border=\"0\" /></a></div>\n\t<div><a href=\"people11.html\"><img src=\"images/person_img11.jpg\" alt=\"\" width=\"163\" height=\"150\" border=\"0\" /></a></div>\n\t<div><a href=\"people12.html\"><img src=\"images/person_img12.jpg\" alt=\"\" width=\"163\" height=\"150\" border=\"0\" /></a></div>\n\t<br class=\"blockend\" />\n\t<!-- /step4 --></div>\n\t\n\t<div class=\"step4\">\n\t<div>