ill-birds-view_plain.webp?v=1741944785037\"> \n             <img src=\"_src/88202037/s45-p_mill-birds-view_plain.jpg?v=1741944785037\" width=\"1920\" height=\"1080\" alt=\"s45-p_mill-birds-view_plain.jpg\" loading=\"lazy\"> \n            </picture><span class=\"slide-title\"></span><span class=\"slide-body\"></span> </span><span class=\"s-slide-img\"> \n            <picture> \n             <source type=\"image/webp\" srcset=\"_src/88202039/s4_s49_biwako_torii-min.webp?v=1741944785037\"> \n             <img src=\"_src/88202039/s4_s49_biwako_torii-min.jpg?v=1741944785037\" width=\"1920\" height=\"1080\" alt=\"s4_s49_biwako_torii-min.jpg\" loading=\"lazy\"> \n            </picture><span class=\"slide-title\"></span><span class=\"slide-body\"></span> </span><span class=\"s-slide-img\"> \n            <picture> \n             <source type=\"image/webp\" srcset=\"_src/88202040/s2_s9a_s46a_drain-min.webp?v=1741944785037\"> \n             <img src=\"_src/88202040/s2_s9a_s46a_drain-min.jpg?v=1741944785037\" width=\"1919\" height=\"1080\" alt=\"s2_s9a_s46a_drain-min.jpg\" loading=\"lazy\"> \n            </picture><span class=\"slide-title\"></span><span class=\"slide-body\"></span> </span><span class=\"s-slide-img\"> \n            <picture> \n             <source type=\"image/webp\" srcset=\"_src/88202041/s9b_s46b_lotus-min.webp?v=1741944785037\"> \n             <img src=\"_src/88202041/s9b_s46b_lotus-min.jpg?v=1741944785037\" width=\"1920\" height=\"1079\" alt=\"s9b_s46b_lotus-min.jpg\" loading=\"lazy\"> \n            </picture><span class=\"slide-title\"></span><span class=\"slide-body\"></span> </span><span class=\"s-slide-img\"> \n            <picture> \n             <source type=\"image/webp\" srcset=\"_src/88202042/comb1_20250314170616984.webp?v=1741944785037\"> \n             <img src=\"_src/88202042/comb1_20250314170616984.jpg?v=1741944785037\" width=\"2560\" height=\"1706\" alt=\"comb1_20250314170616984.jpg\" loading=\"lazy\"> \n            </picture><span class=\"slide-title\"></span><span class=\"slide-body\"></span> </span> </span> \n         </div> \n        </div> \n       </div> \n       <div id=\"bk90844467\" class=\"b-plain c-space_normal c-sp-space_normal bd-sm-smart cssskin-_block_billboard\" data-bk-id=\"bk90844467\"> \n        <div class=\" column -column1\"> \n         <div class=\"c-none c-center\"> \n          <a href=\"#\" class=\"arrow-big-bottom js-link_scroller\"></a> \n         </div> \n        </div> \n       </div> \n      </section> \n     </div> \n    </div> \n    <main> \n     <div id=\"a-site_contents\" class=\"a-site_contents  noskin\"> \n      <article> \n       <div class=\"site_frame\"> \n        <div class=\"g-column\"> \n         <div id=\"a-main\" class=\"a-main column -col12 \"> \n          <section> \n           <div id=\"bk90844416\" class=\"b-both_diff -right_large -sp-single_column c-space_normal c-sp-space_wide bd-webp -dress_b15003Concept cssskin-_block_main\" data-bk-id=\"bk90844416\"> \n            <div class=\" g-column\"> \n             <div class=\" column -col6 -col_sub\"> \n              <h2 class=\" c-title\">CONCEPT</h2> \n              <h3 class=\" c-large_headline\">開発・一貫製造・販売</h3> \n              <p class=\"c-lead\">必要とされる企業<br>誠実な企業<br>努力しがいのある企業</p> \n              <div class=\"c-none\"> \n               <a href=\"concept.html\" data-pid=\"5773229\" class=\"btn-default\">READ MORE</a> \n              </div> \n             </div> \n             <div class=\" column -col6 -col_main\"> \n              <p class=\" c-body\">伸和は、起毛加工を得意とし、面ファスナー「マジクロス」の他にも、合成皮革基布、衣料(インナー、スポーツ裏地等)、寝具、家具、インテリア等様々な用途展開をしています。<br>面ファスナー「マジクロス」の加工技術は、2005年カネボウ(株)からの同事業譲受により、一貫製造体制となり産業資材用面ファスナー(ハードタイプ)では日本国内のトップメーカーであり、世界各国への輸出を行っています。</p> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk90844468\" class=\"b-both_diff -right_large -sp-single_column c-space_normal c-sp-space_wide bd-webp -dress_b15003Service cssskin-_block_main\" data-bk-id=\"bk90844468\"> \n            <div class=\" g-column\"> \n             <div class=\" column -col5 -col_sub\"> \n              <h2 class=\" c-title\">SERVCE</h2> \n              <p class=\"c-lead\">サービス</p> \n              <p class=\" c-body\">化合繊編物の染色、起毛、仕上樹脂加工は、その用途によって様々な加工工程を経て「せんい」の機能性と快適性を生かし、各種素材の付加価値アップを実現します。</p> \n              <div class=\"c-none\"> \n               <a href=\"service.html\" data-pid=\"5773230\" class=\"btn-default\">READ MORE</a> \n              </div> \n             </div> \n             <div class=\" column -col7 -col_main\"> \n              <table class=\"c-list_table\"> \n               <tbody> \n                <tr> \n                 <th><span class=\"bindicon-loop\"></span></th> \n                 <td> <p>マジクロス</p><p class=\" c-affix\">マジクロスは、伸和株式会社がご提供するMade in Japanの高品質な面ファスナーです。<br>オス面とメス面の組合せで「くっつき」「はがれる」機能が多様な用途に活用いただける「可能性は無限大」の資材です。<br>一般によく見受けられるフックタイプと強力なマッシュルームタイプを取り揃えています。</p><p class=\" c-affix\"><a href=\"https://xn--pckre9l1c.jp/\" class=\"btn-default\">マジクロス.jp</a></p></td> \n                </tr> \n                <tr> \n                 <th><span class=\"bindicon-drop\"></span></th> \n                 <td> <p>染色</p><p class=\" c-affix\">染色専業企業である我が社では、長年積み重ねてきた技術力と熱意で、起毛商品及び伸縮性、機能性商品の開発、加工に注力しています。<br>お客様のニーズをいち早くキャッチし、品質、コスト、納期は自社100％一貫加工を行い顧客満足を高めることで行列のできる工場を目指しております。</p></td> \n                </tr> \n                <tr> \n                 <th><span class=\"bindicon-scissors\"></span></th> \n                 <td> <p>起毛</p><p class=\" c-affix\">生地の表面から針やサンドペーパーで毛を出し、保温性や面ファスナー機能、独特の風合いを実現する起毛。<br>生地の表面積を増やすことになり、他の素材との貼り合わせや樹脂塗布時の剥離強度UPなど多様な効果を提供します。<br>長年培った高度な起毛技術でハイタッチのせんい製品を生み出すことを実現します。</p></td> \n                </tr> \n                <tr> \n                 <th><span class=\"bindicon-science\"></span></th> \n                 <td> <p>仕上樹脂加工</p><p class=\" c-affix\">仕上樹脂加工では、生地に撥水、吸水、抗菌、消臭、防炎等の樹脂を含浸させ機能を出します。<br>様々な樹脂のほか、漆喰や珪藻土、遮熱塗料などをコーティングすることでご要望に応じた加工が可能です。</p></td> \n                </tr> \n               </tbody> \n         