/ListItem\" class=\"l-breadcrumbs-list__item l-breadcrumbs-list__item--current\">\n        <a itemprop=\"item\" href=\"https://www.magokorosapporo.com/recruit/\">\n          <span itemprop=\"name\">\n            採用情報\n          </span>\n        </a>\n        <meta itemprop=\"position\" content=\"2\" />\n      </li>\n      \n      <li itemprop=\"itemListElement\" itemscope itemtype=\"http://schema.org/ListItem\" class=\"l-breadcrumbs-list__item\">\n        <a itemprop=\"item\" href=\"https://www.magokorosapporo.com/recruit_profession/\">\n          <span itemprop=\"name\">\n            職種紹介\n          </span>\n        </a>\n        <meta itemprop=\"position\" content=\"3\" />\n      </li>\n      \n    <li itemprop=\"itemListElement\" itemscope itemtype=\"http://schema.org/ListItem\" class=\"l-breadcrumbs-list__item l-breadcrumbs-list__item--current\">\n      <span itemprop=\"name\">\n        理学療法士・柔道整復師・鍼灸師\n      </span>\n      <meta itemprop=\"position\" content=\"4\" />\n    </li>\n    </ol>    </div>\n  </nav>\n      <div class=\"l-contents\">\n        <div class=\"page-content\">\n          <div id=\"anchor\" class=\"anchor-target container\">\n            <header class=\"heading heading--type01 u-center\">\n              <p class=\"heading__subtext\">職種紹介</p>\n              <h2 class=\"heading__text\">理学療法士・柔道整復師・鍼灸師</h2>\n            </header>\n            <div class=\"page-sections\">\n\n              <section class=\"page-section\">\n                <header class=\"heading01\">\n                  <h2 class=\"heading01__text\">お仕事内容</h2>\n                  <div class=\"heading01__dot\">\n                    <span></span>\n                    <span></span>\n                    <span></span>\n                  </div>\n                </header>\n\n                                  <div class=\"movie_w100_area\">\n                    <iframe width=\"560\" height=\"315\" src=\"https://www.youtube.com/embed/rqTzwDwSW9c?si=Xhv4z54yYCocQI1v\" title=\"YouTube video player\" frameborder=\"0\" allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share\" referrerpolicy=\"strict-origin-when-cross-origin\" allowfullscreen></iframe>                  </div>\n\n                \n          <div class=\"page-section__content\">\n            <div class=\"row row--2\">\n              <div class=\"grid\">\n                <img width=\"1435\" height=\"992\" src=\"https://www.magokorosapporo.com/wp-content/uploads/2025/01/FT_スタッフ集合.jpg\" class=\"attachment-full size-full\" alt=\"\" loading=\"lazy\" srcset=\"https://www.magokorosapporo.com/wp-content/uploads/2025/01/FT_スタッフ集合.jpg 1435w, https://www.magokorosapporo.com/wp-content/uploads/2025/01/FT_スタッフ集合-300x207.jpg 300w, https://www.magokorosapporo.com/wp-content/uploads/2025/01/FT_スタッフ集合-1024x708.jpg 1024w, https://www.magokorosapporo.com/wp-content/uploads/2025/01/FT_スタッフ集合-768x531.jpg 768w\" sizes=\"(max-width: 1435px) 100vw, 1435px\" />              </div>\n              <div class=\"grid\">\n                <p>リハビリに特化したデイサービスで、機能訓練等を担当していただきます。<br />\r\n未経験・新社会人の方でも就業前研修が充実しているので安心してスタートできるほか、定期研修もあるのでスキルアップもスムーズです。<br />\r\n<br />\r\n1）休憩時間は、しっかり体が休まる1時間25分！<br />\r\n2）夜勤なし！生活のリズムが整います。<br />\r\n3）有給休暇取得がしやすい社風。<br />\r\n4）プライベートや家族との時間を大切に考えています。<br />\r\n5）独自のメソッド「トリガーポイントマッサージ」「IDストレッチ」が学べ、高い技術が身につきます！</p>\n                              </div>\n            </div>\n                                      <div>\n                                  <div class=\"row02\">\n                    <div class=\"grid\">\n                      <p>・健康維持支援制度が充実しています。<br />\r\n・入浴、食事介助なし<br />\r\n・実務指導2週～4週間後に配属先での引き継ぎをするので研修も充実<br />\r\n・日勤のみ<br />\r\n・土日休み<br />\r\n・先輩機能訓練指導員が丁寧に指導いたします。</p>\n                    </div>\n                    <div class=\"grid\">\n                      <img width=\"1758\" height=\"1325\" src=\"https://www.magokorosapporo.com/wp-content/uploads/2025/01/FT_傾聴.jpg\" class=\"attachment-full size-full\" alt=\"\" loading=\"lazy\" srcset=\"https://www.magokorosapporo.com/wp-content/uploads/2025/01/FT_傾聴.jpg 1758w, https://www.magokorosapporo.com/wp-content/uploads/2025/01/FT_傾聴-300x226.jpg 300w, https://www.magokorosapporo.com/wp-content/uploads/2025/01/FT_傾聴-1024x772.jpg 1024w, https://www.magokorosapporo.com/wp-content/uploads/2025/01/FT_傾聴-768x579.jpg 768w, https://www.magokorosapporo.com/wp-content/uploads/2025/01/FT_傾聴-1536x1158.jpg 1536w\" sizes=\"(max-width: 1758px) 100vw, 1758px\" />                    </div>\n                  </div>\n                              </div>\n                      </div>\n          </section>\n\n\n\n\n\n          \n\n\n\n\n                                          <section class=\"page-section\">\n              <header class=\"heading01\">\n                <h2 class=\"heading01__text\">充実の研修制度</h2>\n                <div class=\"heading01__dot\">\n                  <span></span>\n                  <span></span>\n                  <span></span>\n                </div>\n              </header>\n              <div class=\"page-section__content\">\n                                  <div class=\"row02\">\n                    <div class=\"grid\">\n                      <header class=\"heading02 heading02--type01 is-green\">\n                        <h3 class=\"heading02__text\">導入前研修から始まり、学習の機会が豊富</h3>\n                      </header>\n                      <p>入社前に行われる「導入前研修」は、まるで学校のよう。時間をかけて技術について学び、テストも行われます。最終2日は技術の実践！ まごころの技術の基礎をスムーズに吸収していくことが出来ます。<br />\r\n入社後も2ヶ月に1回は勉強会・講習会などが行われ、技術の向上に努めています。</p>\n                    </div>\n                    <div class=\"grid\">\n                      <img width=\"1370\" height=\"1028\" src=\"https://www.magokorosapporo.com/wp-content/uploads/2025/01/FT_施術（トレーニング風景03）.jpg\" class=\"attachment-full size-full\" alt=\"\" loading=\"lazy\" srcset=\"https://www.magokorosapporo.com/wp-content/uploads/2025/01/FT_施術（トレーニング風景03）.jpg 1370w, https://www.magokorosapporo.com/wp-content/uploads/2025/01/FT_施術（トレーニング風景03）-300x225.jpg 300w, https://www.magokorosapporo.com/wp-content/uploads/2025/01/FT_施術（トレーニング風景03）-1024x768.jpg 1024w, https://www.magokorosapporo.com/wp-content/uploads/2025/01/FT_施術（トレーニング風景03）-768x576.jpg 768w\" sizes=\"(max-width: 1370px) 100vw, 1370px\" />                    </div>\n                  </div>\n                                  <div class=\"row02\">\n                    <div class=\"grid\">\n                      <header class=\"heading02 heading02--type01 is-green\">\n                        <h3 class=\"heading02__text\">「まごころ」は日々向上する技術を積極的に取り入れています。</h3>\n                      </header>\n                      <p>医学の進歩とともに、各種施術内容も常に変化しています。よりよい施術が出来、ご利用者様に喜んでいただけるように、まごころでは日々の技術研鑽を怠りません。<br />\r\nより良い施術は確かな技術があってこそ。入社時の導入前講習研修から始まり、外部と連携しての研修の企画や研究など、理論から学び、スキルアップしていきたい方には最適な環境です。</p>\n                    </div>\n                    <div class=\"grid\">\n                      <img width=\"1639\" height=\"1237\" src=\"https://www.magokorosapporo.com/wp-content/uploads/2025/01/FT_施術（横並び_旭ヶ丘02）.jpg\" class=\"attachment-full size-full\" alt=\"\" loading=\"lazy\" srcset=\"https://www.magokorosapporo.com/wp-content/uploads/2025/01/FT_施術（横並び_旭ヶ丘02）.jpg 1639w, https://www.magokorosapporo.com/wp-content/uploads/2025/01/FT_施術（横並び_旭ヶ丘02）-300x226.jpg 300w, https://www.magokorosapporo.com/wp-content/uploads/2025/01/FT_施術（横並び_旭ヶ丘02）-1024x773.jpg 1024w, https://www.magokorosapporo.com/wp-content/uploads/2025/01/FT_施術（横並び_旭ヶ丘02）-768x580.jpg 768w, https://www.magokorosapporo.com/wp-content/uploads/2025/01/FT_施術（横並び_旭ヶ丘02）-1536x1159.jpg 1536w\" sizes=\"(max-width: 1639px) 100vw, 1639px\" />                    </div>\n                  </div>\n                              </div>\n            </section>\n                                <section class=\"page-section\">\n              <header class=\"heading01\">\n                <h2 class=\"heading01__text\">先輩社員にインタビュー</h2>\n                <div class=\"heading01__dot\">\n                  <span></span>\n                  <span></span>\n                  <span></span>\n                </div>\n              </header>\n              <div class=\"page-section__content\">\n                                  <div class=\"row02\">\n                    <div class=\"grid\">\n                      <header class=\"heading02 heading02--type01 is-green\">\n                        <h3 class=\"heading02__text\">理学療法士 (デイサービス) (入社・4年)</h3>\n                      </header>\n                      <p>以前に勤めていた職場で、訪問・デイケアなど介護保険に関するリハビリ経験がありました。<br />\r\nその経験から、リハビリに興味を持ち、まごころに入社いたしました。<br />\r\nまごころのデイサービスでは幅広い疾患の利用者さまがいらっしゃいます。<br />\r\n特定の疾患の利用者さまがいらっしゃる所と比較すると、総合力が試される職場だと思います。<br />\r\nそのため、難しいと思うことも多々ありますが、経験豊富な先輩方の丁寧な教育体制のおかげで、濃い知識・経験を得ることができます。<br />\r\n利用者さまに感謝され、喜びを感じることのできる「まごころ」で、日々成長を実感しながら、一緒に働きましょう。</p>\n                    </div>\n                    <div class=\"grid\">\n                      <img width=\"880\" height=\"660\" src=\"https://www.magokorosapporo.com/wp-content/uploads/2022/08/インタビュー.png\" class=\"attachment-full size-full\" alt=\"\" loading=\"lazy\" srcset=\"https://www.magokorosapporo.com/wp-content/uploads/2022/08/インタビュー.png 880w, https://www.magokorosapporo.com/wp-content/uploads/2022/08/インタビュー-300x225.png 300w, https://www.magokorosapporo.com/wp-content/uploads/2022/08/インタビュー-768x576.png 768w\" sizes=\"(max-width: 880px) 100vw, 880px\" />                    </div>\n                  </div>\n                                  <div class=\"row02\">\n                    <div class=\"grid\">\n                      <header class=\"heading02 heading02--type01 is-green\">\n                        <h3 class=\"heading02__text\">柔道整復師（入社・3年）</h3>\n                      </header>\n                      <p>トリガーポイント鍼治療・マッサージの技術を身につけたくて入社しました。<br />\r\n最初は不安もありましたが、2週間の技術研修のおかげで安心して現場に出ることができました。<br />\r\n今でも日々勉強ですが、様々な職種の方と働くことはとても刺激になり、自分の強みを活かしどこまでも成長できる職場です。<br />\r\n地域の方に貢献し、自らのスキルアップもできる「まごころ」で一緒に働きましょう。</p>\n                    </div>\n                    <div class=\"grid\">\n                      <img width=\"1920\" height=\"2560\" src=\"https://www.magokorosapporo.com/wp-content/uploads/2025/01/Ft_ina260205-scaled.jpg\" class=\"attachment-full size-full\" alt=\"\" loading=\"lazy\" srcset=\"https://www.magokorosapporo.com/wp-content/uploads/2025/01/Ft_ina260205-scaled.jpg 1920w, https://www.magokorosapporo.com/wp-content/uploads/2025/01/Ft_ina260205-225x300.jpg 225w, https://www.magokorosapporo.com/wp-content/uploads/2025/01/Ft_ina260205-768x1024.jpg 768w, https://www.magokorosapporo.com/wp-content/uploads/2025/01/Ft_ina260205-1152x1536.jpg 1152w, https://www.magokorosapporo.com/wp-content/uploads/2025/01/Ft_ina260205-1536x2048.jpg 1536w\" sizes=\"(max-width: 1920px) 100vw, 1920px\" />                    </div>\n                  </div>\n                                  <div class=\"row02\">\n                    <div class=\"grid\">\n                      <header class=\"heading02 heading02--type01 is-green\">\n                        <h3 class=\"heading02__text\">鍼灸師（入社・7年7ヶ月）</h3>\n                      </header>\n                      <p>以前は整骨院に勤務していましたが、家族との時間を両立できず転職を決意しました。まごころでは帰宅時間も以前ほど遅くならず、家族みんなで夕食を食べることができています。<br />\r\n「1ヶ月に1度は有給休暇を取得しよう」という風潮があり、職員一同積極的に有給消化に勤しんでいるため、<br />\r\n自然と家族と過ごす時間も増えて、とても嬉しいです。<br />\r\n<br />\r\n入社初日に鼻血を出してしまい、止まらなくて困ったことも今では懐かしい思い出です（皆さんに笑われてしまいかえって緊張が解けました）。職員・サポーターさんも優しく、すぐに職場に馴染むことができました。<br />\r\n鍼を通して、\"利用者様に喜んでいただき、利用者様の人生にも携わり、社会からも必要とされる鍼灸師\"を、まごころで一緒に目指しましょう！</p>\n                    </div>\n                    <div class=\"grid\">\n                      <img width=\"800\" height=\"665\" src=\"https://www.magokorosapporo.com/wp-content/uploads/2025/01/鍼灸師.png\" class=\"attachment-full size-full\" alt=\"\" loading=\"lazy\" srcset=\"https://www.magokorosapporo.com/wp-content/uploads/2025/01/鍼灸師.png 800w, https://www.magokorosapporo.com/wp-content/uploads/2025/01/鍼灸師-300x249.png 300w, https://www.magokorosapporo.com/wp-content/uploads/2025/01/鍼灸師-768x638.png 768w\" sizes=\"(max-width: 800px) 100vw, 800px\" />                    </div>\n                  </div>\n                              </div>\n            </section>\n\n            \n                    <section class=\"page-section\">\n            <header class=\"heading02 u-mb0\">\n              <h2 class=\"heading02__text\">理学療法士・柔道整復師・鍼灸師　<span class=\"is-black\">の求人</span></h2>\n            </header>\n            <div class=\"page-section__content\">\n                              <ul class=\"recinfos-list\">\n                                      <li class=\"recinfos-list__item\">\n                      <a href=\"https://www.magokorosapporo.com/recruitment_info/1347/\" class=\"recinfos-list__link\">\n                                                  <span class=\"recinfos-list__status\">\n                            正                          </span>\n                                                <div class=\"recinfos-list__block\">\n                                                    <span class=\"recinfos-list__title\">理学療法士</span>\n                        </div>\n                      </a>\n                    </li>\n                                      <li class=\"recinfos-list__item\">\n                      <a href=\"https://www.magokorosapporo.com/recruitment_info/1247/\" class=\"recinfos-list__link\">\n                                                  <span class=\"recinfos-list__status\">\n                            正                          </span>\n                                                <div class=\"recinfos-list__block\">\n                                                    <span class=\"recinfos-list__title\">柔道整復師</span>\n                        </div>\n                      </a>\n                    </li>\n                                  </ul>\n                          </div>\n          </section>\n          <div class=\"recruit-more container-out\">\n  <p class=\"recruit-more__head\">\n    採用について<br>\n    もっと見てみる\n  </p>\n  <div class=\"container\">\n    <div class=\"recruit-more__content\">\n      <div class=\"recruit-more__block jobs\">\n        <h3 class=\"recruit-more__heading\">職種紹介</h3>\n        <p>まごころでは、デイサービスや訪問看護など複数の業態があり、様々な職種の方が活躍しています。</p>\n        <ul class=\"recruit-more-list\">\n                      <li class=\"recruit-more-list__item\">\n              <a href=\"https://www.magokorosapporo.com/recruit_profession/transportation-staff/#anchor\" class=\"recruit-more-list__link\">介護・送迎職員</a>\n            </li>\n                      <li class=\"recruit-more-list__item\">\n              <a href=\"https://www.magokorosapporo.com/recruit_profession/day_nurse/#anchor\" class=\"recruit-more-list__link\">デイサービスの看護師</a>\n            </li>\n                      <li class=\"recruit-more-list__item\">\n              <a href=\"https://www.magokorosapporo.com/recruit_profession/life-counselor/#anchor\" class=\"recruit-more-list__link\">生活相談員</a>\n            </li>\n                      <li class=\"recruit-more-list__item\">\n              <a href=\"https://www.magokorosapporo.com/recruit_profession/functional-training-instructor/#anchor\" class=\"recruit-more-list__link\">理学療法士・柔道整復師・鍼灸師</a>\n            </li>\n                      <li class=\"recruit-more-list__item\">\n              <a href=\"https://www.magokorosapporo.com/recruit_profession/visiting-nurse/#anchor\" class=\"recruit-more-list__link\">訪問看護師</a>\n            </li>\n                      <li class=\"recruit-more-list__item\">\n              <a href=\"https://www.magokorosapporo.com/recruit_profession/care-manager/#anchor\" class=\"recruit-more-list__link\">ケアマネージャー</a>\n            </li>\n                  </ul>\n        <a href=\"https://www.magokorosapporo.com/recruit_profession/\" class=\"recruit-more__link u-fonten\">\n          VIEW ALL\n        </a>\n      </div>\n      <div class=\"recruit-more__block recruit\">\n        <h3 class=\"recruit-more__heading\">求人情報</h3>\n        <p>複数の職種と勤務地から選べます。ご不明点はお気軽にお問い合わせください。</p>\n        <ul class=\"recruit-mor