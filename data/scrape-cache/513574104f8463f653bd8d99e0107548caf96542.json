libs/Swiper/6.7.5/swiper-bundle.min.js\" integrity=\"sha512-jm5exnXjOC6mBpqBG81xU+GK4ybKq28mLihDCNj2E3RkzrfW/tSGt7Uy7wRSkedl95C4cH9+9lectBCGwEcD0g==\" crossorigin=\"anonymous\" referrerpolicy=\"no-referrer\"></script>\n<link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/Swiper/6.7.5/swiper-bundle.min.css\" integrity=\"sha512-IZyebVAIO5IWMM3Jcx/Z0awNNBq1YcqWW34QlhQy9fzM1XxzmX3gB/YmbPkVuH/EU8QvpeY92EGS45iW/YKt1g==\" crossorigin=\"anonymous\" referrerpolicy=\"no-referrer\" />\n<link rel='stylesheet'  href='/wp-content/themes/tayama/assets/css/index.css' />\n\n\n\n<div class=\"mv\">\n\n<!-- Swiper START -->\n  <div class=\"swiper-container\">\n    <!-- メイン表示部分 -->\n    <div class=\"swiper-wrapper\">\n      <!-- 各スライド -->\n      <a href=\"/service/semiorder/printingcans\" class=\"swiper-slide\"></a>\n      <a href=\"/service/semiorder/stickers\" class=\"swiper-slide\"></a>\n      <a href=\"/service/semiorder/irodori\" class=\"swiper-slide\"></a>\n    </div>\n  </div>\n  <div class=\"swiper-pagination\"></div>\n  <!-- Swiper END -->\n  \n</div>\n\n\n<section id=\"section01\" class=\"js-fadeIn\">\n  <div class=\"image-box\">\n    <div class=\"image\"><img src=\"/common/img/top/img04.png\" width=\"427\"></div>\n  </div>\n  <div class=\"text-box\">\n    <h2 class=\"h2catch\">タマヤはパッケージ製造・<br>企画デザイン会社です</h2>\n    <p class=\"text\">\n      パッケージデザインから製造・納品まで。<br>\n      長年の食品業界におけるパッケージのノウハウを活かした提案・企画・デザイン力でお客様の想いをカタチにします。\n    </p>\n    <div class=\"btn\"><a href=\"/point\">詳しく見る</a></div>\n  </div>\n</section>\n\n<section id=\"news\" class=\"js-fadeIn\">\n  \n  <!-- NEWS -->\n    <div class=\"news-box\">\n      <div class=\"news-inner\">\n      <h2 class=\"\">NEWS<span class=\"newslink\"><a href=\"/news\">一覧はこちら</a></span></h2>\n      <ul class=\"news-content\">\n          \n                      <li class=\"\">\n          <a href=\"https://www.tamaya-net.co.jp/news/2444\">\n            <dl>\n              <dt>\n              <span class=\"tag important\">重要なお知らせ</span>              <p class=\"date\">2026.06.10</p>\n              </dt>\n              <dd>\n              <p class=\"txt\">既製品袋商品 価格改定のお知らせ</p>\n              </dd>\n            </dl>\n          </a>\n        </li>\n                  <li class=\"\">\n          <a href=\"https://www.tamaya-net.co.jp/news/2428\">\n            <dl>\n              <dt>\n              <span class=\"tag important\">重要なお知らせ</span>              <p class=\"date\">2026.05.15</p>\n              </dt>\n              <dd>\n              <p class=\"txt\">価格改定のお知らせ</p>\n              </dd>\n            </dl>\n          </a>\n        </li>\n                  <li class=\"\">\n          <a href=\"https://www.tamaya-net.co.jp/news/2413\">\n            <dl>\n              <dt>\n              <span class=\"tag event\">イベント</span>              <p class=\"date\">2026.05.11</p>\n              </dt>\n              <dd>\n              <p class=\"txt\">第16回 タマヤ内覧会 &#8211; パッケージ企画展 &#8211; のお知らせ</p>\n              </dd>\n            </dl>\n          </a>\n        </li>\n                  <li class=\"\">\n          <a href=\"https://www.tamaya-net.co.jp/news/2376\">\n            <dl>\n              <dt>\n              <span class=\"tag event\">イベント</span>              <p class=\"date\">2026.04.23</p>\n              </dt>\n              <dd>\n              <p class=\"txt\">既製品特価セール開催のお知らせ</p>\n              </dd>\n            </dl>\n          </a>\n        </li>\n                  <li class=\"\">\n          <a href=\"https://www.tamaya-net.co.jp/news/2372\">\n            <dl>\n              <dt>\n              <span class=\"tag holiday\">休業日のお知らせ</span>              <p class=\"date\">2026.04.15</p>\n              </dt>\n              <dd>\n              <p class=\"txt\">ゴールデンウィーク休業のお知らせ</p>\n              </dd>\n            </dl>\n          </a>\n        </li>\n                      \n            </ul>\n      \n      </div>\n    </div>\n    <!-- /NEWS -->\n</section>\n\n\n<section id=\"section02\" >\n  <div class=\"text-box js-fadeIn\">\n    <h2 class=\"main\">サービス<span class=\"en\">SERVICE</span></h2>\n    <p class=\"catch\">一般ロットから小ロットまで</p>\n    <p class=\"text\">\n      パッケージはもちろん、販促品も多数ご用意しております。<br>お客様のニーズに合わせた理想の商品づくりをお手伝いします。\n    </p>\n  </div>\n  <div class=\"service_wrap js-fadeIn\">\n    <div class=\"service_wrap_title\">人気のサービス</div>\n    <div class=\"service_wrap_contet\">\n      <div class=\"service_wrap_item\">\n        <div class=\"service_wrap_item_title\">@彩</div>\n        <div class=\"service_wrap_img\">\n          <div class=\"image\"><img src=\"/common/img/top/service01.png\"></div>\n        </div>\n        <div class=\"service_wrap_point\">\n          <ul>\n            <li>小ロット<span class=\"color\">100枚</span>〜オリジナル印刷</li>\n            <li>独自の技術により<span class=\"color\">版代不要</span></li>\n            <li>グラビア印刷に比べ<span class=\"color\">短納期</span></li>\n          </ul>\n        </div>\n        <div class=\"btn\"><a href=\"/service/semiorder/irodori\">詳しく見る</a></div>\n      </div>\n      <div class=\"service_wrap_item\">\n        <div class=\"service_wrap_item_title\">オリジナル印刷缶</div>\n        <div class=\"service_wrap_img\">\n          <div class=\"image\"><img src=\"/common/img/top/service02.png\"></div>\n        </div>\n        <div class=\"service_wrap_point\">\n          <ul>\n            <li>ベース缶・印刷方法が<span class=\"color\">選べる</span></li>\n            <li>小ロット<span class=\"color\">100本</span>〜オリジナル印刷</li>\n            <li><span class=\"color\">オリジナルデザイン</span>を実現</li>\n          </ul>\n        </div>\n        <div class=\"btn\"><a href=\"/service/semiorder/printingcans\">詳しく見る</a></div>\n      </div>\n      <div class=\"service_wrap_item\">\n        <div class=\"service_wrap_item_title\">選べるシール</div>\n        <div class=\"service_wrap_img\">\n          <div class=\"image\"><img src=\"/common/img/top/service03.png\"></div>\n        </div>\n        <div class=\"service_wrap_point\">\n          <ul>\n            <li>材質・形状・サイズが<span class=\"color\">選べる</span></li>\n            <li>小ロット<span class=\"color\">100枚</span>〜オリジナル印刷</li>\n            <li>独自の技術により<span class=\"color\">版代不要</span></li>\n          </ul>\n        </div>\n        <div class=\"btn\"><a href=\"/service/semiorder/stickers\">詳しく見る</a></div>\n      </div>\n    </div>\n  </div>\n  <div class=\"service_wrap2 js-fadeIn\">\n    <div class=\"service_wrap2_item\">\n      <div class=\"service_wrap2_item_title\">フルオーダーパッケージ</div>\n      <div class=\"service_wrap2_img\">\n        <div class=\"image\"><img src=\"/common/img/top/service04.png\"></div>\n      </div>\n      <div class=\"service_wrap2_item_catch\">プランニングから製造まで、<br>トータルコーディネートの完全オリジナルパッケージ</div>\n      <div class=\"service_wrap2_item_text\">\n        オリジナルでクオリティが高いパッケージ商品や、既製品にはないサイズの商品、販売の企画など、あなただけのデザインをお引き受けします。小さなシールから大きな段ボールまで当社だけで用意できます。POPやチラシなど、目を引く販促品の制作もお手伝いします。全部まとめて対応するので、費用面でもよい提案ができます。\n      </div>\n      <div class=\"btn\"><a href=\"/service/fullorder\">詳しく見る</a></div>\n    </div>\n    <div class=\"service_wrap2_item\">\n      <div class=\"service_wrap2_item_title\">セミオーダーパッケージ</div>\n      <div class=\"service_wrap2_img\">\n        <div class=\"image\"><img src=\"/common/img/top/service05.png\"></div>\n      </div>\n      <div class=\"service_wrap2_item_catch\">既製品パッケージを利用するので、<br>手軽でスピーディーにオリジナルのパッケージが作れます！</div>\n      <div class=\"service_wrap2_item_text\">\n        自分だけの高品質なパッケージをかんたんに用意したいというお客様の声にこたえるのが「セミオーダー（後加工）パッケージ」です。当社では「@彩（あっといろどり）」をはじめ、「スタンパックシステム」、「印刷加工」、「箔押し加工」など、お客様の使い方に合わせたさまざまな加工方法をご用意しています。\n      </div>\n      <div class=\"btn\"><a href=\"/service/semiorder\">詳しく見る</a></div>\n    </div>    \n  </div>\n  <div class=\"service_wrap3 js-fadeIn\">\n    <div class=\"service_wrap3_catch\">その他にもスイーツや蕎麦などの販促商品企画も行っています</div>\n    <div class=\"service_wrap3_img\">\n      <div class=\"image\"><img src=\"/common/img/top/img05.png\"></div>\n    </div>\n    <div class=\"btn\"><a href=\"/service\">サービス一覧を見る</a></div>\n  </div>\n</section>\n\n<section id=\"banner\" class=\"js-fadeIn\">\n    <a href=\"https://gallery.tamaya-net.info/\">\n      <img src=\"/common/img/top/ban.png\" class=\"pc\">\n      <img src=\"/common/img/top/bansp.png\" class=\"sp\">\n    </a>\n    <div class=\"banner_comment\">「想いをカタチに」弊社包装資材とサービスを組み合わせた<br class=\"spd\">パッケージ使用イメージをご紹介しております</div>\n</section>\n\n\n<section id=\"section03\" class=\"js-fadeIn\">\n  <h2 class=\"main\">会社情報<span class=\"en\">Profile</span></h2>\n  <div class=\"profile_content\">\n    <div class=\"profile_item\">\n      <div class=\"profile_title\">会社概要</div>\n      <div class=\"profile_img\">\n        <div class=\"image\"><img src=\"/common/img/top/img06.png\"></div>        \n      </div>\n      <div class=\"profile_catch\">日本の食品パッケージの歴史と共に</div>\n      <div class=\"profile_text\">\n        時代の変化と共に成長し続けながら、京都本社・静岡・福岡の3箇所を起点に全国ネットワークでお客様をサポートします。\n      </div>\n      <div class=\"btn\"><a href=\"/company\">詳しく見る</a></div>\n    </div>\n    <div class=\"profile_item\">\n      <div class=\"profile_title\">企業理念</div>\n      <div class=\"profile_img\">\n        <div class=\"image\"><img src=\"/common/img/top/img07.png\"></div>        \n      </div>\n      <div class=\"profile_catch\">創業100年、変化を恐れない伝統企業を目指して</div>\n      <div class=\"profile_text\">\n        伝統ある京都ブランド会社としてパッケージ製造、企画・デザイン力でお客様に貢献し、 会社の体質を強化することで、社員とその家族の幸せを追求します。\n      </div>\n      <div class=\"btn\"><a href=\"/philosophy\">詳しく見る</a></div>\n    </div>\n  </div>\n</section>\n\n\n\n\n\n    \n    <script>\n      var mySwiper = new Swiper('.swiper-container', {\n        loop: true,\n        speed:1000,\n        autoplay: {\n          delay: 3500,\n          stopOnLastSlide: false,\n          disableOnInteraction: false,\n          reverseDirection: false\n    },\n    pagination: {\n      el: '.swiper-pagination', // ページネーション要素のクラス\n      clickable: true, // クリックによるスライド切り替えを有効にする\n      type: 'bullets' // 'bullets'（デフォルト） | 'fraction' | 'progressbar'\n    },\n    });\n    </script>\n\n\n\n<section id=\"btn-area\">\n\t\