).toggleClass('btn-open').toggleClass('btn-close');\n            });\n\n            $('.menu a').on('click', function () {\n                $(\".overlay\").fadeToggle(200);\n                $(\".menu-btn a\").toggleClass('btn-open').toggleClass('btn-close');\n            });\n\n        });\n\n        // ナビゲーション\n        let lastScrollTop = 0;\n        const navWrap = document.querySelector('.navWrap');\n\n        window.addEventListener('scroll', function() {\n          let scrollTop = window.pageYOffset || document.documentElement.scrollTop;\n          let windowHeight = window.innerHeight;\n          let documentHeight = document.documentElement.scrollHeight;\n\n          if (scrollTop <= 5) {\n            // 一番上にいる時 → くっきり表示\n            navWrap.classList.remove('hide', 'show', 'bottom');\n            navWrap.classList.add('top');\n          } else if (scrollTop + windowHeight >= documentHeight - 5) {\n            // 一番下にいる時 → ナビを消す\n            navWrap.classList.add('hide');\n            navWrap.classList.remove('top', 'show');\n          } else if (scrollTop > lastScrollTop) {\n            // スクロールダウン → ナビゲーションを非表示\n            navWrap.classList.add('hide');\n            navWrap.classList.remove('top', 'show');\n          } else {\n            // スクロールアップ → ナビゲーションを表示しつつ透明度を少し下げる\n            navWrap.classList.remove('hide', 'top', 'bottom');\n            navWrap.classList.add('show');\n          }\n\n          lastScrollTop = scrollTop;\n        });\n    </script>\n\n    <!-- imgタグで読み込んだsvgファイルをsvgタグに置換-->\n    <script src=\"https://cdn.jsdelivr.net/npm/desvg@1.0.2/desvg.min.js\"></script>    \n    <script>\n        deSVG('.svgIcon', true); /* SVGをリンクしたimgタグに付けたclass名 */\n    </script>\n</body>\n</html>","finalUrl":"https://www.snp.co.jp/recruit/","rendered":false,"_cachedAt":"2026-06-17T23:11:21.582Z"}