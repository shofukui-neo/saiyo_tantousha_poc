i-list-child\">\n              <li class=\"header_navi__sub-list\">\n                <p class=\"header_navi-list_txt btn btn-color06\"><a href=\"/recruit/message/index.html\"  target=\"_blank\">メッセージ</a></p>\n              </li>\n            </ul>\n          </li>\n          <li class=\"header_navi-list\">\n            <ul class=\"header_navi-list-child\">\n              <li class=\"header_navi__sub-list\">\n                <p class=\"header_navi-list_txt btn btn-color06\"><a href=\"/recruit/new_graduate/index.html\"  target=\"_blank\">新卒採用</a></p>\n              </li>\n            </ul>\n          </li>\n          <li class=\"header_navi-list\">\n            <ul class=\"header_navi-list-child\">\n              <li class=\"header_navi__sub-list\">\n                <p class=\"header_navi-list_txt btn btn-color06\"><a href=\"/recruit/project/index.html\"  target=\"_blank\">プロジェクト</a></p>\n              </li>\n            </ul>\n          </li>\n        </ul>\n      </li>\n      <li><a href=\"/html/company/index.html\">企業情報</a>\n        <ul class=\"header_navi-child\">\n          <li class=\"header_navi-child-ttl_wrap\">\n            <div class=\"header_navi-child-ttl_inner\">\n              <p class=\"header_navi-child-ttl_txt\">ENTERPRISE<br>INFORMATION</p>\n              <p class=\"header_navi-list_txt btn btn-color06\"><a href=\"/html/company/index.html\">企業情報</a></p>\n            </div>\n          </li>\n          <li class=\"header_navi-list\">\n            <ul class=\"header_navi-list-child\">\n              <li class=\"header_navi__sub-list\">\n                <p class=\"header_navi-list_txt btn btn-color06\"><a href=\"/html/company/system.html\">組織図</a></p>\n              </li>\n            </ul>\n          </li>\n          <li class=\"header_navi-list\">\n            <ul class=\"header_navi-list-child\">\n              <li class=\"header_navi__sub-list\">\n                <p class=\"header_navi-list_txt btn btn-color06\"><a href=\"/html/company/message.html\">社長メッセージ</a></p>\n              </li>\n            </ul>\n          </li>\n          <li class=\"header_navi-list\">\n            <ul class=\"header_navi-list-child\">\n              <li class=\"header_navi__sub-list\">\n                <p class=\"header_navi-list_txt btn btn-color06\"><a href=\"/html/company/enkaku.html\">沿革</a></p>\n              </li>\n            </ul>\n          </li>\n          <li class=\"header_navi-list\">\n            <ul class=\"header_navi-list-child\">\n              <li class=\"header_navi__sub-list\">\n                <p class=\"header_navi-list_txt btn btn-color06\"><a href=\"/html/report/prerelease.html\">プレスリリース</a></p>\n              </li>\n            </ul>\n          </li>\n        </ul>\n      </li>\n    </ul>\n  </nav></header><section class=\"mv mv_member\"> \r\n  <!--パンくずリスト-->\r\n  <div class=\"breadcrumb\">\r\n    <ul>\r\n      <li><a href=\"../../\">トップページ</a></li>\r\n      <li>会員メリット</li>\r\n    </ul>\r\n  </div>\r\n  <h1 class=\"mv__h1\">会員メリット</h1>\r\n</section>\r\n<section class=\"merit_contents\">\r\n  <div class=\"merit_inner\">\r\n    <h2 class=\"sub-ttl\">会員サービス紹介</h2>\r\n    <p class=\"member-main_txt\">浜銀総合研究所は、横浜銀行の関連会社として1988年に設立され、地域のシンクタンク・コンサルティングファームとして、地域の企業の皆さまへのご支援はもとより、国や地方公共団体に対する受託調査、金融機関へのコンサルティングなどに関する実績を重ねてきました。</p>\r\n  </div>\r\n  <div class=\"merit-system\">\r\n    <div class=\"merit-system_inner\">\r\n      <p class=\"merit-system_txt\">浜銀総合研究所では、これらの機能をご活用いただくため、企業の皆さまを対象とした会員制度を設けています。</p>\r\n      <ul class=\"merit-system_list\">\r\n        <li class=\"merit-system-item\">\r\n          <p class=\"merit-system_item_ttl\">年会費</p>\r\n          <p class=\"merit-system_item_txt\">66,000円（税込）</p>\r\n        </li>\r\n        <li class=\"merit-system-item\">\r\n          <p class=\"merit-system_item_ttl\">会員数</p>\r\n          <p class=\"merit-system_item_txt\">約4,500社</p>\r\n        </li>\r\n        <li class=\"merit-system-item\">\r\n          <p class=\"merit-system_item_txt\">各種会員サービスを<br>\r\n            無料または割引価格でご提供</p>\r\n        </li>\r\n      </ul>\r\n    </div>\r\n  </div>\r\n  <div class=\"merit_service\">\r\n    <div class=\"merit_service_wrap\"> <a href=\"../business/index.html\">\r\n      <div class=\"merit_service_ttl service01\"> 企業経営のための情報提供 </div>\r\n      </a> <a href=\"../skillup/index.html\">\r\n      <div class=\"merit_service_ttl service02\"> 社員教育のサポート </div>\r\n      </a> </div>\r\n    <div class=\"merit_service_main_ttl\">\r\n      <p>会員サービスの<br>\r\n        2本の大きな柱</p>\r\n    </div>\r\n  </div>\r\n  <div class=\"merit_rrivilege01\">\r\n    <h2 class=\"sub-ttl\">会員特典</h2>\r\n    <div class=\"merit_rrivilege_ttl_wrap\">\r\n      <div class=\"merit_rrivilege_img\"><img src=\"img/merit/merit_rrivilege_ttl01.png\" alt=\"会員特典1\"></div>\r\n      <p class=\"merit_rrivilege_ttl\">最新の情報を毎月お届け</p>\r\n    </div>\r\n    <p class=\"merit_rrivilege_txt\">浜銀総合研究所が毎月発行する各種刊行物、セミナー・講演会をはじめ、各種サービスのご案内をお届けいたします。</p>\r\n    <ul class=\"merit_rrivilege_list\">\r\n      <li class=\"merit_rrivilege_item\"> <a href=\"../publication/bestpartner/index.html\">\r\n        <dl class=\"merit_rrivilege_item_wrap\">\r\n          <dd class=\"merit_rrivilege_item_img\"><img src=\"img/merit/merit_rrivilege01_img01.jpg\" alt=\"機関誌「ベストパートナー」\"></dd>\r\n          <dt class=\"merit_rrivilege_item_ttl\">機関誌「ベストパートナー」</dt>\r\n          <dd class=\"merit_rrivilege_item_txt\">専門家・企業経営者等による「特集鼎談」、「挑戦する独創企業」などの記事を掲載</dd>\r\n        </dl>\r\n        </a> </li>\r\n      <li class=\"merit_rrivilege_item\"> <a href=\"../report/index.html?dt=629187988&th=2\">\r\n        <dl class=\"merit_rrivilege_item_wrap\">\r\n          <dd class=\"merit_rrivilege_item_img\"><img src=\"img/merit/merit_rrivilege01_img02.jpg\" alt=\"「かながわ経済情報」\"></dd>\r\n          <dt class=\"merit_rrivilege_item_ttl\">「かながわ経済情報」</dt>\r\n          <dd class=\"merit_rrivilege_item_txt\">当社研究員が地域の経済情報を発信</dd>\r\n        </dl>\r\n        </a> </li>\r\n      <li class=\"merit_rrivilege_item\"> <a href=\"../skillup/sashi.html\">\r\n        <dl class=\"merit_rrivilege_item_wrap\">\r\n          <dd class=\"merit_rrivilege_item_img\"><img src=\"img/merit/merit_rrivilege01_img03.jpg\" alt=\"小冊子「ビジネスハンドブック」\"></dd>\r\n          <dt class=\"merit_rrivilege_item_ttl\">小冊子「ビジネスハンドブック」</dt>\r\n          <dd class=\"merit_rrivilege_item_txt\">携帯に便利なサイズで、実務に直結するテーマを簡潔に解説</dd>\r\n        </dl>\r\n        </a> </li>\r\n    </ul>\r\n  </div>\r\n  <div class=\"merit_rrivilege02\">\r\n    <div class=\"merit_rrivilege_ttl_wrap\">\r\n      <div class=\"merit_rrivilege_img\"><img src=\"img/merit/merit_rrivilege_ttl02.png\" alt=\"会員特典2\"></div>\r\n      <p class=\"merit_rrivilege_ttl\">会員限定の情報・サービス</p>\r\n    </div>\r\n    <p class=\"merit_rrivilege_txt\">当社ホームページから、会員限定でご利用いただける各種サービスをご提供いたします。<br>会員ID・パスワードにより「会員ログイン」のうえ、ご利用ください。</p>\r\n    <ul class=\"merit_rrivilege_list\">\r\n      <li class=\"merit_rrivilege_item\">\r\n        <dl class=\"merit_rrivilege_item_wrap\">\r\n          <a href=\"../skillup/netseminar.html\"><dd class=\"merit_rrivilege_item_img\"><img src=\"img/merit/merit_rrivilege02_img01.jpg\" alt=\"「インターネット・セミナー」\"><!-- <p class=\"sample-icn\">無料サンプル</p>--></dd>\r\n          <dt class=\"merit_rrivilege_item_ttl\">「インターネット・セミナー」</dt></a>\r\n          <dd class=\"merit_rrivilege_item_txt\">3,000本以上のセミナー動画を、いつでも何度でも無料で視聴可能\r\n           <div class=\"merit_rrivilege_item_btn\"> <a href=\"http://www.esod-neo.com/client_certify.php?id=22iAYMrjBD.hU&amp;sample_page=1\" target=\"_blank\" id=\"ebrain_sample_btn\"><img src=\"../member/img/bt_41.png\" alt=\"サンプルサイトへ\"></a>\r\n              <p class=\"merit_rrivilege_item_btn_txt\"> どなたでも各セミナー1分程度のサンプルムービーを視聴できます。<br>\r\n                (株)イー・ブレーン提供のサイトに進みます。</p>\r\n\t\t\t\t\t\t </div>\r\n          </dd>\r\n        </dl>\r\n        </li>\r\n      <li class=\"merit_rrivilege_item\"> <a href=\"../business/botw.html\">\r\n        <dl class=\"merit_rrivilege_item_wrap\">\r\n          <dd class=\"merit_rrivilege_item_img\"><img src=\"img/merit/merit_rrivilege02_img02.jpg\" alt=\"「ビジネスサポートon the Web」\"></dd>\r\n          <dt class=\"merit_rrivilege_item_ttl\">「ビジネスサポートon the Web」</dt>\r\n          <dd class=\"merit_rrivilege_item_txt\">全国の地方銀行が共同で運営している法人・事業者を対象とした情報Webサイト。業種別レポート、ビジネス文例集など役立つコンテンツを多数ご用意</dd>\r\n        </dl>\r\n        </a> </li>\r\n      <li class=\"merit_rrivilege_item\"> <a href=\"../publication/bestpartner/bp_digitalbook.html\">\r\n        <dl class=\"merit_rrivilege_item_wrap\">\r\n          <dd class=\"merit_rrivilege_item_img\"><img src=\"img/merit/merit_rrivilege02_img03.jpg\" alt=\"機関誌「ベストパートナー」PDF版\"></dd>\r\n          <dt class=\"merit_rrivilege_item_ttl\">機関誌「ベストパートナー」<br>PDF版</dt>\r\n          <dd class=\"merit_rrivilege_item_txt\">毎月1冊のお届けに加えて、「PDF版」形式で閲覧が可能</dd>\r\n        </dl>\r\n        </a> </li>\r\n    </ul>\r\n  </div>\r\n  <div class=\"merit_rrivilege03\">\r\n    <div class=\"merit_rrivilege_ttl_wrap\">\r\n      <div class=\"merit_rrivilege_img\"><img src=\"img/merit/merit_rrivilege_ttl03.png\" alt=\"会員特典3\"></div>\r\n      <p class=\"merit_rrivilege_ttl\">会員無料・会員割引サービス</p>\r\n    </div>\r\n    <p class=\"merit_rrivilege_txt\">会員無料・会員割引価格で利用できるサービスを多数ご用意しております。</p>\r\n    <ul class=\"merit_rrivilege_list\">\r\n      <li class=\"merit_rrivilege_item\"> <a href=\"../seminar/kouen_list.html\">\r\n        <dl class=\"merit_rrivilege_item_wrap\">\r\n          <dd class=\"merit_rrivilege_item_img\"><img src=\"../seminar/img/top_seminar_img02.jpg\" alt=\"講演会\"></dd>\r\n          <dt class=\"merit_rrivilege_item_ttl\">講演会</dt>\r\n          <dd class=\"merit_rrivilege_item_txt\">会員は1社何名でも無料</dd>\r\n        </dl>\r\n        </a> </li>\r\n      <li class=\"merit_rrivilege_item\"> <a href=\"../seminar/seminar_list.html\">\r\n        <dl class=\"merit_rrivilege_item_wrap\">\r\n          <dd class=\"merit_rrivilege_item_img\"><img src=\"../seminar/img/top_seminar_img01.jpg\" alt=\"ビジネスセミナー\"></dd>\r\n          <dt class=\"merit_rrivilege_item_ttl\">ビジネスセミナー</dt>\r\n          <dd class=\"merit_rrivilege_item_txt\">一部は会員無料、有料分も会員割引価格でご案内</dd>\r\n        </dl>\r\n        </a> </li>\r\n      <li class=\"merit_rrivilege_item\"> <a href=\"../skillup/sinnjin.html\">\r\n        <dl class=\"merit_rrivilege_item_wrap\">\r\n          <dd class=\"merit_rrivilege_item_img\"><img src=\"../skillup/img/top_skillup_img06.jpg\" alt=\"新入社員合同研修会\"></dd>\r\n          <dt class=\"merit_rrivilege_item_ttl\">新入社員合同研修会</dt>\r\n          <dd class=\"merit_rrivilege_item_txt\">会員は1社5名まで無料</dd>\r\n        </dl>\r\n        </a> </li>\r\n    </ul>\r\n    <ul class=\"merit_rrivilege_list\">\r\n      <li class=\"merit_rrivilege_item\"> <a href=\"../skillup/video_select.html\">\r\n        <dl class=\"merit_rrivilege_item_wrap\">\r\n          <dd class=\"merit_rrivilege_item_img\"><img src=\"../skillup/img/top_skillup_img01.jpg\" alt=\"研修用DVD貸出\">\r\n           <!-- <p class=\"sample-icn\">無料サンプル</p>-->\r\n          </dd>\r\n          <dt class=\"merit_rrivilege_item_ttl\">研修用DVD貸出</dt>\r\n          <dd class=\"merit_rrivilege_item_txt\">会員限定・無料</dd>\r\n        </dl>\r\n        </a> </li>\r\n      <li class=\"merit_rrivilege_item\"> <a href=\"../skillup/tushin.html\">\r\n        <dl class=\"merit_rrivilege_item_wrap\">\r\n          <dd class=\"merit_rrivilege_item_img \"><img  src=\"../skillup/img/top_skillup_img04.jpg\" alt=\"通信教育講座・ITサービス（パソコン教室等）\">\r\n           <!-- <p class=\"sample-icn\">無料サンプル</p>-->\r\n          </dd>\r\n          <dt class=\"merit_rrivilege_item_ttl\">通信教育講座</dt>\r\n          <dd class=\"merit_rrivilege_item_txt\">会員割引価格</dd>\r\n        </dl>\r\n        </a> </li>\r\n      <li class=\"merit_rrivilege_item\"> <a href=\"../business/kigyou.html\">\r\n        <dl class=\"merit_rrivilege_item_wrap\">\r\n          <dd class=\"merit_rrivilege_item_img\"><img src=\"../business/img/top_business_img03.jpg\" alt=\"企業情報サービス\"></dd>\r\n          <dt class=\"merit_rrivilege_item_ttl\">企業情報サービス</dt>\r\n          <dd class=\"merit_rrivilege_item_txt\">会員割引価格</dd>\r\n        </dl>\r\n        </a> </li>\r\n    </ul>\r\n  </div>\r\n  <div class=\"entry_procedure\">\r\n    <div class=\"merit_inner\">\r\n      <h2 class=\"sub-ttl\">入会手続き </h2>\r\n      <div class=\"entry_procedure_wrap\">\r\n        <dl>\r\n          <dt class=\"entry_procedure_ttl\">入会対象者</dt>\r\n          <dd class=\"entry_procedure_txt\">事業を営む法人、団体、個人事業主の方</dd>\r\n        </dl>\r\n        <dl>\r\n          <dt class=\"entry_procedure_ttl\">入会手続き</dt>\r\n          <dd class=\"entry_procedure_txt\">横浜銀行とのお取引がございましたら、取引店のご担当者にお申し出ください。もしくは、浜銀総合研究所会員サービス部（TEL 045-225-2376）までお電話にてお問い合わせください。</dd>\r\n        </dl>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</section>\r\n<div class=\"footer_contact-wrap\">\r\n  <div class=\"footer_contact-inner\">\r\n    <p class=\"footer_contact btn btn-color01\"><a href=\"../inquiry/inquiry.html?nno=3\">お問い合わせはこちら</a></p>\r\n    <p class=\"footer_contact-txt\">株式会社浜銀総合研究所　会員サービス部　TEL 045-225-2376</p>\r\n  </div>\r\n</div>\r\n<div class=\"page-top_btn\"> <a href=\"#page-top\">&nbsp;</a> </div>\r\n<footer>\r\n  <nav class=\"top__footer-navi\">\r\n    <ul>\r\n      <li><a href=\"/html/site_map/\">サイトマップ</a></li>\r\n      <li><a href=\"/html/regulation/index.html\">免責・利用規定</a></li>\r\n      <li><a href=\"/html/security_policy/index.html\">情報セキュリティ基本方針</a></li>\r\n      <li><a href=\"/html/regulation/person.html\">個人情報保護について</a></li>\r\n      <li><a href=\"/html/regulation/shareduse.html\">法人等のお客さまの情報の共同利用について</a></li>\r\n    </ul>\r\n  </nav>\r\n  <p class=\"footer__txt\"> 【浜銀総合研究所は、横浜銀行グループのシンクタンク・コンサルティング会社。地元神奈川、横浜、川崎、東京に密着した調査から全国規模および海外にいたるまでの専門的研究を手がけています。】<br>\r\n    このホームページに関するご意見、お問合せは、<a href=\"/html/inquiry/inquiry.html\">こちら</a>までお願いします。このホームページの内容を、許可無く転載・複製することを禁止します。 </p>\r\n  <small>Copyright 2019 (C) Hamagin Research Institute,Ltd.All rights reserved.</small> </footer>\r\n<script>\r\n\t// Fix link value (as dev)\r\n\tlet $prd_domain = 'www.yokohama-ri.co.jp';\r\n\tlet $this_domain = window.location.hostname;\r\n\tlet $env