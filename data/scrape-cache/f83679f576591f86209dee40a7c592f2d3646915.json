              'memberid': $('input[name=\"memberid\"]').val(),\r\n                'passwd': $('input[name=\"passwd\"]').val(),\r\n                'logintokens': \"5481450ade6aeb12699cf84d036791cc\"\r\n            }/*,\r\n            dataType:'json'*/\r\n        }).done(function(data, textStatus, jqXHR) {\r\n            if (data != null && data != \"\") {\r\n                $(\"#account_lock_message\").hide();\r\n                $(\"#login_error_message\").hide();\r\n                // 認証失敗\r\n                if (data == \"failed\") {\r\n                    //alert(\"failed\");\r\n                    $(\"#login_error_message\").show();\r\n                } else if (data == \"locked\") {\r\n                    //alert(\"locked\");\r\n                    $(\"#account_lock_message\").show();\r\n                } else {\r\n                    location.href = data;\r\n                    setTimeout(function(){\r\n                         $('.site_login_wrap').css({display: 'none'});\r\n                    },2000);\r\n                }\r\n            }\r\n        }).fail(function(jqXHR, textStatus, errorThrown) {\r\n            //alert(\"fail\");\r\n        });\r\n    });\r\n});\r\n</script>\r\n</body>\r\n</html>","finalUrl":"https://www.yokohama-ri.co.jp/html/member/merit.html","rendered":false,"_cachedAt":"2026-06-22T21:47:05.714Z"}