{"url":"https://www.hanshin-tollkobe.co.jp/business_2/","html":"<!doctype html>\r\n<html lang=\"ja\"><!-- InstanceBegin template=\"/Templates/base.dwt\" codeOutsideHTMLIsLocked=\"false\" -->\r\n<head>\r\n<!-- Google tag (gtag.js) -->\r\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-D46ENBW51P\"></script>\r\n<script>\r\n  window.dataLayer = window.dataLayer || [];\r\n  function gtag(){dataLayer.push(arguments);}\r\n  gtag('js', new Date());\r\n\r\n  gtag('config', 'G-D46ENBW51P');\r\n  gtag('config', 'UA-87337378-1');\r\n</script>\r\n\r\n<meta charset=\"utf-8\">\r\n<!-- InstanceBeginEditable name=\"doctitle\" -->\r\n<title>料金所スタッフ採用情報｜阪神高速トール神戸</title>\r\n<meta name=\"description\" content=\"阪神高速トール神戸株式会社の採用情報のご案内です。\">\r\n<!-- InstanceEndEditable -->\r\n<meta http-equiv=\"Pragma\" content=\"no-cache\">\r\n<meta http-equiv=\"Cache-Control\" content=\"no-cache\">\r\n<meta name=\"author\" content=\"阪神高速トール神戸\" />\r\n<meta name=\"copyright\" content=\"阪神高速トール神戸\" />\r\n<meta name=\"robots\" content=\"all\" />\r\n<link href=\"../common/css/import.css?20260525121533\" rel=\"stylesheet\" type=\"text/css\" media=\"all\" />\r\n<!-- InstanceBeginEditable name=\"head\" -->\r\n<!-- InstanceEndEditable -->\r\n<!-- InstanceParam name=\"bodyID\" type=\"text\" value=\"\" -->\r\n<!-- InstanceParam name=\"g_menu\" type=\"text\" value=\"g_menu04\" -->\r\n<!-- InstanceParam name=\"contents\" type=\"text\" value=\"business_2\" -->\r\n<!-- InstanceParam name=\"filename\" type=\"text\" value=\"index\" -->\r\n</head>\r\n\r\n<body id=\"business_2\" class=\"index\">\r\n    <a name=\"top\" id=\"top\"></a>\r\n    <header id=\"header-frame\">\r\n\r\n      <div id=\"header\">\r\n        <h1>\r\n          <a href=\"/\">\r\n            <img src=\"/common/img/header01.png\" width=\"276\" height=\"38\" alt=\"阪神高速トール神戸株式会社\" />\r\n            <span>お客さまから愛される料金所を目指します</span>\r\n          </a>\r\n        </h1>\r\n        <div id=\"header_right\">\r\n          <p><a href=\"/sitemap/\">サイトマップ</a></p>\r\n          <div id=\"fontSize\">\r\n            <noscript><p>JavaScriptを使用しています。</p></noscript>\r\n            文字サイズ\r\n            <ul>\r\n              <li class=\"changeBtn\">小</li>\r\n              <li class=\"changeBtn\">中</li>\r\n              <li class=\"changeBtn\">大</li>\r\n            </ul>\r\n          </div>\r\n        </div>\r\n      </div><!-- //header -->\r\n\r\n      <nav id=\"nav\">\r\n        <ul>\r\n          <li class=\"nav01\"><a href=\"/\">トップページ<span>TOP PAGE</span></a></li>\r\n          <li class=\"nav02\"><a href=\"/corp_info/\">会社情報<span>CORPORATE INFORMATION</span></a></li>\r\n          <li class=\"nav03\"><a href=\"/corp_outline/\">会社概要<span>COMPANY PROFILE</span></a></li>\r\n          <li class=\"nav04\"><a href=\"/business/\">事業内容<span>BUSINESS CONTENTS</span></a></li>\r\n          <li class=\"nav05\">\r\n            <a href=\"javascript:void(0);\">採用情報<span>CAREER</span></a>\r\n            <ul class=\"nav--sub\">\r\n              <li><a href=\"/business_2/\">料金所スタッフ採用情報</a></li>\r\n              <li>\r\n                <a href=\"https://tenshoku.mynavi.jp/jobinfo-426307-3-6-1/?msockid=3d319ca12add6b111ec189be2b0f6a58\" target=\"_blank\" title=\"新しいウインドウが開きます。\" rel=\"noopener noreferrer\">\r\n                  本社採用情報\r\n                  <img src=\"/common/img/blank_icon--white.svg\" width=\"11\" height=\"10\" alt=\"\" class=\"blank\">\r\n                  <span class=\"note\">（マイナビ転職に移動します）</span>\r\n                </a>\r\n              </li>\r\n            </ul>\r\n          </li>\r\n        </ul>\r\n      </nav>\r\n\r\n    </header>\r\n\r\n\r\n\r\n\r\n<div id=\"changeArea\">\r\n<div id=\"main\">\r\n<!-- InstanceBeginEditable name=\"EditRegion3\" -->\r\n<div class=\"main-img\">\r\n\t<img src=\"img/img02.png\" width=\"635\" height=\"314\" alt=\"\"/>\r\n\t<img src=\"img/img01.png\" width=\"635\" height=\"314\" alt=\"\"/>\r\n</div>\r\n\r\n<div class=\"main-title\">\r\n\t<h1><img src=\"img/title.png\" width=\"902\" height=\"161\" alt=\"阪神高速料金所スタッフ募集中　未経験者大歓迎！正社員登用制度有！\"/></h1>\r\n</div>\r\n\r\n<div id=\"requirements\">\r\n\t\r\n\t<table class=\"table-type01\">\r\n    \r\n    <tr>\r\n      <th class=\"w20\">職種</th>\r\n      <td>阪神高速道路 料金所スタッフ<br />阪神高速道路 サポートセンタースタッフ</td>\r\n    </tr>\r\n    \r\n\t\t<tr>\r\n\t\t\t<th>仕事内容</th>\r\n\t\t\t<td>\r\n        <p class=\"bold\">料金所スタッフ</p>\r\n        <p class=\"space05b\">阪神高速道路（兵庫地区）の各料金所において料金収受とこれに付随する業務</p>\r\n        \r\n        <p class=\"bold\">サポートセンタースタッフ業務</p>\r\n        <p class=\"space10b\">阪神高速道路（兵庫地区）の各無人料金所での料金収受業務等における遠隔でのお客さま対応業務</p>\r\n        \r\n        <p class=\"color-orange space15b indent\">※ 3日に1回の1昼夜勤務で25時間の拘束仮眠4時間、休憩5時間<br />（遠隔サポートセンターは24時間の拘束仮眠時間4時間、休憩時間4時間）【実働16時間】</p>\r\n        <div class=\"link-type01\"><a href=\"../business/index02.html\">料金所スタッフの仕事とは？</a></div>\r\n\t\t\t</td>\r\n\t\t</tr>\r\n    \r\n\t\t<tr>\r\n\t\t\t<th>雇用形態</th>\r\n\t\t\t<td>契約社員（1年毎の更新）<span class=\"color-orange\">※正社員登用制度あり</span></td>\r\n\t\t</tr>\r\n    \r\n\t\t<tr>\r\n\t\t\t<th>勤務地</th>\r\n\t\t\t<td>\r\n\t\t\t\t<ul class=\"l180\">\r\n\t\t\t\t\t<li><span class=\"bold\">&#9312;【深江浜営業所】</span><span class=\"font13\">神戸市東灘区深江浜町</span></li>\r\n\t\t\t\t\t<li><span class=\"bold\">&#9313;【若宮営業所】</span><span class=\"font13\">神戸市須磨区鷹取町</span></li>\r\n\t\t\t\t\t<li><span class=\"bold\">&#9314;【藍那営業所】</span><span class=\"font13\">神戸市北区山田町</span></li>\r\n          <li><span class=\"bold\">&#9315;【兵庫地区遠隔サポートセンター】</span><span class=\"font13\">神戸市中央区</span></li>\r\n\t\t\t\t</ul>\r\n        <p class=\"color-orange\">※2020年4月1日の「改正健康増進法」の施行に伴う「受動喫煙防止対策」として<br>全ての料金所において「禁煙」を実施しています。</p>\r\n\t\t\t</td>\r\n\t\t</tr>\r\n    \r\n\t\t<tr>\r\n\t\t\t<th>給与</th>\r\n\t\t\t<td>\r\n\t\t\t\t<p class=\"l150\">月給<span class=\"font22 bold color-red\">213,000</span>円+寸志年2回</p>\r\n\t\t\t</td>\r\n\t\t</tr>\r\n    \r\n\t\t<tr>\r\n\t\t\t<th>勤務時間と<br />休日・休暇</th>\r\n\t\t\t<td>\r\n        \r\n\t\t\t\t<p class=\"space10b\"><span class=\"bold\">●勤務時間</span></p>\r\n        <dl class=\"space10b flex flex-wrap\">\r\n          <dt class=\"right space15r w4em\">&#9312;&#9313;&#9314;</dt>\r\n          <dd>昼夜勤務（8:15～翌朝10:15 みなし残業時間1時間を含む）<br />※変形労働時間制（仮眠4時間・休憩5時間有）</dd>\r\n        </dl>\r\n        <dl class=\"space15b flex flex-wrap\">\r\n          <dt class=\"right space15r w4em\">&#9315;</dt>\r\n          <dd>昼夜勤務（8:30～翌朝9:30　みなし残業時間1時間を含む）<br />※変形労働時間制（仮眠4時間・休憩4時間有）<br />1ヶ月10回の勤務</dd>\r\n        </dl>\r\n        \r\n\t\t\t\t<p class=\"space00b\"><span class=\"bold\">●休日・休暇</span></p>\r\n\t\t\t\t<p class=\"space15b space1eml\">1昼夜勤務1休のローテーションで月10日の休日<br />年次有給休暇（規定により付与）</p>\r\n        \r\n\t\t\t\t<p class=\"bold space05b\">●シフト表</p>\r\n\t\t\t\t<div class=\"box-white space10b space1eml\">\r\n\t\t\t\t\t<img src=\"img/img_shift_v2.png\" width=\"332\" height=\"332\" alt=\"\"/>\r\n\t\t\t\t\t<div class=\"txt\">\r\n\t\t\t\t\t\t<p class=\"bold\">シフト例：</p>\r\n\t\t\t\t\t\t<ul class=\"font13\">\r\n\t\t\t\t\t\t\t<li>★3日に1回休み。余裕を持って働けます。</li>\r\n\t\t\t\t\t\t\t<li>★1勤務有給を取ると4連休になります。<br />（入社6ヵ月以降）</li>\r\n\t\t\t\t\t\t</ul>\r\n\t\t\t\t\t</div><!-- //.txt -->\r\n\t\t\t\t</div><!-- //.box-white -->\r\n\t\t\t</td>\r\n\t\t</tr>\r\n\t\t\r\n\t\t<tr>\r\n\t\t\t<th>福利厚生</th>\r\n\t\t\t<td>各種社会保険完備、制服貸与、交通費実費支給</td>\r\n\t\t</tr>\r\n    \r\n\t\t<tr>\r\n\t\t\t<th>応募資格</th>\r\n\t\t\t<td>高卒程度の学力を有する者、要普通自動車運転免許（AT限定可）</td>\r\n\t\t</tr>\r\n    \r\n\t\t<tr>\r\n\t\t\t<th>応募方法</th>\r\n\t\t\t<td>まずは、下記問い合わせ先まで履歴書（写真貼付）をお送りください。<br>締切後、書類選考の上ご連絡いたします。</td>\r\n\t\t</tr>\r\n    \r\n\t\t<tr>\r\n\t\t\t<th>選考方法</th>\r\n\t\t\t<td>\r\n\t\t\t\t<p class=\"font15 color-red bold\">\r\n\t\t\t\t\t書類選考通過者のみ面接を行います。\r\n\t\t\t\t</p>\r\n\t\t\t\t<ul class=\"color-orange\">\r\n\t\t\t\t\t<li>※計算テスト有り</li>\r\n\t\t\t\t\t<li>※履歴書は採用の資料と採用後は人事管理に使用しそれ以外での使用は致しません</li>\r\n\t\t\t\t\t<li>※履歴書は返却致しませんのでご了承ください</li>\r\n\t\t\t\t</ul>\r\n\t\t\t</td>\r\n\t\t</tr>\r\n    \r\n\t</table>\r\n\t\r\n\t<table class=\"table-type02\">\r\n\t\t<tr>\r\n\t\t\t<th>応募締切日</th>\r\n\t\t\t<td>随時募集中<br />\r\n      <span class=\"font13 color-red bold\">※履歴書到着後、2週間程度で書類選考結果を送付させていただきます。</span></td>\r\n\t\t</tr>\r\n\t\t<tr>\r\n\t\t\t<th>面接日</th>\r\n\t\t\t<td>書類選考通過者のみご連絡させていただきます。<br />\r\n      <span class=\"font13 color-red bold\">※計算テストも同時に行います。</span></td>\r\n\t\t</tr>\r\n\t\t<tr>\r\n\t\t\t<th>採用日</th>\r\n\t\t\t<td>毎月1日付採用<br />\r\n      <span class=\"font13 color-red bold\">※希望採用月があれば履歴書等に記載してください。</span></td>\r\n\t\t</tr>\r\n\r\n  </table>\r\n\r\n\r\n  <div class=\"entry\">\r\n    <div class=\"entry-btn\">\r\n      <a href=\"https://arwrk.net/recruit/hanshin-tollkobe\" target=\"_blank\" title=\"新しいウインドウが開きます。\" rel=\"noopener noreferrer\">\r\n        <span>ご応募はこちらから</span>\r\n      </a>\r\n    </div>\r\n      <p>（阪神高速トール神戸株式会社の採用サイトに移動します。）</p>  \r\n  </div>\r\n\r\n\r\n\r\n\t<div class=\"contacts\">\r\n\t\t<h2>料金所スタッフ募集に関するお問い合わせはこちら</h2>\r\n\t\t<div>\r\n\t\t\t<h3>阪神高速トール神戸株式会社　採用担当</h3>\r\n\t\t\t<p class=\"space30b\">〒651-0096　神戸市中央区雲井通4丁目2番2号（マークラー神戸ビル9階）</p>\r\n\t\t\t<p class=\"tel\"><span class=\"number\">078-252-7755</span></p>\r\n\t\t\t<p>平日9時30分～17時</p>\r\n\t\t</div>\r\n\t</div><!-- //.contacts -->\r\n\r\n\r\n</div><!-- //#requirements -->\r\n\r\n<!-- InstanceEndEditable -->\r\n</div><!-- //main -->\r\n</div><!-- //changeArea -->\r\n\r\n<div id=\"pagetop\"><p><a href=\"#top\"><img src=\"/common/img/pagetop.jpg\" width=\"170\" height=\"26\" alt=\"ページトップへ戻る\" class=\"rollover\" /></a></p></div>\r\n<div id=\"footer\">\r\n\t<p><a href=\"/\">トップページ</a>　｜　\r\n    <a href=\"/corp_info/\">会社情報</a>　｜　\r\n    <a href=\"/corp_outline/\">会社概要</a>　｜　\r\n    <a href=\"/business/\">事業内容</a>　｜　\r\n    <a href=\"/news\">お知らせ</a>　｜　\r\n    <a href=\"/link/\">お役立ちリンク集</a>　｜　\r\n    <a href=\"/sitemap/\">サイトマップ</a>　｜　\r\n    <a href=\"/security/\">セキュリティポリシー</a>　｜　\r\n    <a href=\"/privacy/\">個人情報保護方針</a></p>\r\n</div><!-- //footer -->\r\n<div id=\"copyright\"><p>Copyright(c) Hanshin Expressway Toll KOBE Co., Ltd. All rights reserved.</p></div>\r\n\r\n<script type=\"text/javascript\" src=\"../common/js/jquery/jquery.min.js\"></script>\r\n<script type=\"text/javascript\" src=\"../common/js/fontsizechange.js\"></script>\r\n<script type=\"text/javascript\" src=\"../common/js/jquery.cookie.js\"></script>\r\n<script type=\"text/javascript\" src=\"../common/js/jquery.rollover.js\"></script>\r\n<script type=\"text/javascript\" src=\"../common/js/common.js\"></script>\r\n<!-- InstanceBeginEditable name=\"js\" -->\r\n<!-- InstanceEndEditable -->\r\n<script type=\"text/javascript\" src=\"/_Incapsula_Resource?SWJIYLWA=719d34d31c8e3a6e6fffd425f7e032f3&ns=6&cb=1276788776\" async></script></body>\r\n<!-- InstanceEnd --></html>\r\n","finalUrl":"https://www.hanshin-tollkobe.co.jp/business_2/","rendered":false,"_cachedAt":"2026-06-22T17:43:16.505Z"}