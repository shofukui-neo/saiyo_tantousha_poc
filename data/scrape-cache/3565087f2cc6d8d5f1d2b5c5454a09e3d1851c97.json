ss=\"ttl_page land-and-building-information\">\n    <span class=\"inner\">\n        <span class=\"en\">Land & building information</span>\n        <span class=\"ja\">土地建物情報</span>\n    </span>\n\n</h1>\n\n\n    \n    \t<ul id=\"breads\">\n\t\t<li class=\"top\"><a href=\"https://www.p-kikuya.co.jp/\">トップ</a></li>\n\t\t<li class=\"bread\"><span class=\"current\">土地建物情報</span></li>\n\t</ul>\n\n\n<div id=\"main\" class=\"post-18 page type-page status-publish hentry\" role=\"main\">\n\n\t\t\n<div class=\"wrapper\" id=\"page_land-and-building-information\">\n\t<div class=\"inner\">\n\t\t<div class=\"sec-head\">\n\t\t\t<h2 class=\"ttl\"><img src=\"https://www.p-kikuya.co.jp/wp_7e34/wp-content/themes/kikuya/images/land-and-building-information/ttl-estate.png\" width=\"444\" height=\"64\" alt=\"土地活用をお考えの方へ\"></h2>\n\t\t\t<p class=\"txt\">下記の条件に合うような土地建物を<br class=\"sp-inline\">お持ちの方がいらっしゃいましたら、<br>ぜひお問い合わせください。</p>\n\t\t</div><!-- /sec-head -->\n\n\t\t<div class=\"sec-cont\">\n\t\t\t<div class=\"cont cont-01\">\n\t\t\t\t<h3 class=\"ttl\">\n\t\t\t\t\t<span class=\"wrap\">\n\t\t\t\t\t\t<span class=\"en\"><img src=\"https://www.p-kikuya.co.jp/wp_7e34/wp-content/themes/kikuya/images/land-and-building-information/ttl-01.png\" width=\"265\" height=\"24\" alt=\"Recruitment area\"></span>\n\t\t\t\t\t\t<span class=\"ja\">募集エリア</span>\n\t\t\t\t\t</span>\n\t\t\t\t</h3>\n\t\t\t\t<div class=\"txtbox\">\n\t\t\t\t\t<figure>\n\t\t\t\t\t\t<img class=\"image\" src=\"https://www.p-kikuya.co.jp/wp_7e34/wp-content/themes/kikuya/images/land-and-building-information/map.png\" width=\"659\" height=\"474\" alt=\"東京都・神奈川県・千葉県・埼玉県・岐阜県・愛知県 ・静岡県・大阪府・兵庫県・京都府\">\n\t\t\t\t\t\t<img class=\"image_s\" src=\"https://www.p-kikuya.co.jp/wp_7e34/wp-content/themes/kikuya/images/land-and-building-information/map_sp.png\" width=\"664\" height=\"727\" alt=\"東京都・神奈川県・千葉県・埼玉県・岐阜県・愛知県 ・静岡県・大阪府・兵庫県・京都府\">\n\t\t\t\t\t</figure>\n\t\t\t\t</div>\n\t\t\t</div><!-- /cont-01 -->\n\n\t\t\t<div class=\"cont cont-02\">\n\t\t\t\t<h3 class=\"ttl\">\n\t\t\t\t\t<span class=\"wrap\">\n\t\t\t\t\t\t<span class=\"en\"><img src=\"https://www.p-kikuya.co.jp/wp_7e34/wp-content/themes/kikuya/images/land-and-building-information/ttl-02.png\" width=\"233\" height=\"25\" alt=\"Area / use area\"></span>\n\t\t\t\t\t\t<span class=\"ja\">面積・用途地域</span>\n\t\t\t\t\t</span>\n\t\t\t\t</h3>\n\t\t\t\t<div class=\"txtbox\">\n\t\t\t\t\t<p class=\"txt txt-01\">［ 面積 ］<br>・郊外、ロードサイド立地　3000坪以上 </p>\n\t\t\t\t\t<p class=\"txt txt-02\">［ 用途地域 ］<br>準工業地域 ／ 工業地域 ／ 商業地域 ／ 近隣商業地域 ／ 無指定地域</p>\n\t\t\t\t</div>\n\t\t\t</div><!-- /cont-02 -->\n\n\t\t\t<div class=\"cont cont-03\">\n\t\t\t\t<h3 class=\"ttl\">\n\t\t\t\t\t<span class=\"wrap\">\n\t\t\t\t\t\t<span class=\"en\"><img src=\"https://www.p-kikuya.co.jp/wp_7e34/wp-content/themes/kikuya/images/land-and-building-information/ttl-03.png\" width=\"192\" height=\"23\" alt=\"Intended use\"></span>\n\t\t\t\t\t\t<span class=\"ja\">使用目的</span>\n\t\t\t\t\t</span>\n\t\t\t\t</h3>\n\t\t\t\t<div class=\"txtbox\">\n\t\t\t\t\t<p class=\"txt\">パチンコ店【 遊技場営業(4号営業) 】 及びそれに付随する施設運営</p>\n\t\t\t\t</div>\n\t\t\t</div><!-- /cont-03 -->\n\n\t\t\t<div class=\"cont cont-04\">\n\t\t\t\t<h3 class=\"ttl\">\n\t\t\t\t\t<span class=\"wrap\">\n\t\t\t\t\t\t<span class=\"en\"><img src=\"https://www.p-kikuya.co.jp/wp_7e34/wp-content/themes/kikuya/images/land-and-building-information/ttl-04.png\" width=\"285\" height=\"24\" alt=\"Protected facilities\"></span>\n\t\t\t\t\t\t<span class=\"ja\">保護対象施設</span>\n\t\t\t\t\t</span>\n\t\t\t\t</h3>\n\t\t\t\t<div class=\"txtbox\">\n\t\t\t\t\t<p class=\"txt\">下記施設から 100m 以上離れていること。 (各都道府県によって例外あり)<br>学校 ／ 幼稚園 ／ 保育園 ／ 児童福祉施設 ／ その他福祉施設 ／ 図書館 ／ 病院(医院を除く)</p>\n\t\t\t\t</div>\n\t\t\t</div><!-- /cont-04 -->\n\n\t\t\t<div class=\"cont cont-05\">\n\t\t\t\t<h3 class=\"ttl\">\n\t\t\t\t\t<span class=\"wrap\">\n\t\t\t\t\t\t<span class=\"en\"><img src=\"https://www.p-kikuya.co.jp/wp_7e34/wp-content/themes/kikuya/images/land-and-building-information/ttl-05.png\" width=\"138\" height=\"29\" alt=\"Roadway\"></span>\n\t\t\t\t\t\t<span class=\"ja\">接道</span>\n\t\t\t\t\t</span>\n\t\t\t\t</h3>\n\t\t\t\t<div class=\"txtbox\">\n\t\t\t\t\t<p class=\"txt\">・主要道路(国道・県道など)に面する土地<br>・道路幅6m以上の道路に接続する土地</p>\n\t\t\t\t</div>\n\t\t\t</div><!-- /cont-05 -->\n\t\t\t\n\t\t</div><!-- /sec-cont -->\n\t\t\n\t\t<div class=\"sec-btn\">\n\t\t\t<a href=\"https://www.p-kikuya.co.jp/contact-us\"><img src=\"https://www.p-kikuya.co.jp/wp_7e34/wp-content/themes/kikuya/images/land-and-building-information/btn-contact.png\" width=\"470\" height=\"183\" alt=\"土地の有効活用をお考えの方はお気軽にご相談ください!お問い合わせはこちら\"></a>\n\t\t</div>\n\t\t\n\t</div><!-- /inner -->\n\t\n</div><!-- /wrapper -->\n\t\n\t\t\t\t\t\t\n\t\t\n</div>\n<!-- /#main -->\n\n<!-- <aside class=\"information_links\">\n    <a target=\"_blank\" href=\"//www.youtube.com/channel/UC1Qhnplct5D4YoAKDJR4rRA\"><img src=\"https://www.p-kikuya.co.jp/wp_7e34/wp-content/themes/kikuya/images/links/l_5.jpg\" alt=\"キクPチャンネル\"></a>\n\n    <a target=\"_blank\" href=\"https://twitter.com/sayaka_kikuya\"><img src=\"https://www.p-kikuya.co.jp/wp_7e34/wp-content/themes/kikuya/images/links/l_4.jpg\" alt=\"キクヤ広報担当ツィッター\"></a>\n\n    <a target=\"_blank\" href=\"https://www.youtube.com/channel/UCGT4fnK7lm2ftlgs-iDhZnw\"><img src=\"https://www.p-kikuya.co.jp/wp_7e34/wp-content/themes/kikuya/images/links/l_2.jpg\" alt=\"キクチャン\"></a>\n</aside> -->\n<!-- /.information_links -->\n\n<footer>\n    <div id=\"global_foot\">\n        <div class=\"box\">\n            <a href=\"https://www.p-kikuya.co.jp/\">トップ</a>\n\n        </div>\n        <!-- /.box -->\n\n        <div class=\"box\">\n            <a href=\"https://www.p-kikuya.co.jp/company-information\">企業情報</a>\n            <a href=\"https://www.p-kikuya.co.jp/management-philosophy-and-our-thoughts\">経営理念・私たちの想い</a>\n            <a href=\"https://www.p-kikuya.co.jp/history\">沿革</a>\n            <a href=\"https://www.p-kikuya.co.jp/profile-ranking\">会社概要</a>\n        </div>\n        <!-- /.box -->\n\n        <div class=\"box\