r(--wp--preset--font-size--medium) !important;}.has-large-font-size{font-size: var(--wp--preset--font-size--large) !important;}.has-x-large-font-size{font-size: var(--wp--preset--font-size--x-large) !important;}\n/*# sourceURL=global-styles-inline-css */\n</style>\n\n<style id='classic-theme-styles-inline-css' type='text/css'>\n/*! This file is auto-generated */\n.wp-block-button__link{color:#fff;background-color:#32373c;border-radius:9999px;box-shadow:none;text-decoration:none;padding:calc(.667em + 2px) calc(1.333em + 2px);font-size:1.125em}.wp-block-file__button{background:#32373c;color:#fff;text-decoration:none}\n/*# sourceURL=/wp-includes/css/classic-themes.min.css */\n</style>\n<link rel='stylesheet' id='contact-form-7-css' href='https://www.ibcsoft.ne.jp/wordpress/wp-content/plugins/contact-form-7/includes/css/styles.css?ver=6.1.4' type='text/css' media='all' />\n<link rel=\"canonical\" href=\"https://www.ibcsoft.ne.jp/recruit_haken/\" />\n</head>\n\n<body> \n\n<!-- Google Tag Manager (noscript) -->\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-MK83ZDT\"\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n<!-- End Google Tag Manager (noscript) -->\n  \n<!-- ヘッダ -->\n<div id=\"header_wrap\">\n\t<div id=\"header_wrap_innner\" class=\"crearfix\">\n\t\t<p class=\"headtitle\">ソフトウェア開発・Web制作および人材派遣に関するコンサルティング</p>\n\t\t\t   \n\t\t<p class=\"telephone\">019-653-0118</p>\n\t</div>\n</div>\n  \n<div id=\"page_pertile_wrap\">\n\t<div id=\"page_pertile_area\" class=\"crearfix\">\n\t\t<div id=\"page_logo\"><a href=\"https://www.ibcsoft.ne.jp\">\n\t\t\t<img src=\"https://www.ibcsoft.ne.jp/wordpress/wp-content/themes/softalpha/img/logo_page.png\" alt=\"株式会社IBCソフトアルファ\"></a>\n\t\t</div>\n\t\t<div id=\"page_glb_menu\">\n        \t<ul>\n\t\t\t\t<li><a href=\"/company/\">会社案内</a></li>\n\t\t\t\t<li><a href=\"/mission/\" >経営理念</a></li>\n\t\t\t\t<li><a href=\"/system/\">システム開発</a></li>\n\t\t\t\t<li><a href=\"/haken/\">人材派遣</a></li>\n\t\t\t\t<li class=\"last\"><a href=\"kikaku/\">広告・事業</a></li>\n\t\t\t</ul>\n\t\t</div>\n\t</div>\n</div><!-- コンテンツ左 -->\n\n<div id=\"cont_wrap\" >\n  <div id=\"cont_wrap_inner\" class=\"clearfix\">\n    <div id=\"cont_left\">\n      <div class=\"cont_page\">\n\t\t\n\t\t\n\t\t\n\t\t<h2>派遣社員求人情報</h2>\n\t\t\n\t\t\n\t\t\t\t\r\n<h3><span data-mce-type=\"bookmark\" style=\"display: inline-block; width: 0px; overflow: hidden; line-height: 0;\" class=\"mce_SELRES_start\"></span>有期雇用派遣労働者募集要項</h3>\r\n\r\n\r\n\r\n\r\n\r\n<div style=\"height: 20px;\"></div>\r\n\r\n<!-- システム運用・インフラスタッフ（盛岡市） -->\r\n<h4>システム運用・インフラスタッフ（盛岡市）</h4>\r\n\r\n<div class=\"scroll\">\r\n  <table>\r\n    <tbody>\r\n\r\n <!-- 仕事内容 -->\r\n      <tr>\r\n        <th rowspan=\"9\">仕事内容</th>\r\n        <th>職種</th>\r\n        <td>システム運用・インフラスタッフ（盛岡市）</td>\r\n      </tr>\r\n      <tr>\r\n        <th>仕事の内容</th>\r\n        <td><p>サーバーの運用管理（Ｗｉｎｄｏｗｓ、Ｌｉｎｕｘ他）<br>\r\n               運用監視（エラーの確認、プログラムの実行確認他）<br>\r\n               バックアップ媒体の交換<br>\r\n               バッチ処理等の実行確認<br>\r\n               オペレーション作業<br>\r\n               その他、付随する業務</p>\r\n        </td>\r\n      </tr>\r\n      <tr>\r\n        <th>雇用形態</th>\r\n        <td>有期雇用派遣労働者</td>\r\n      </tr>\r\n      <tr>\r\n        <th>雇用期間</th>\r\n        <td>期間の定めあり（4ヶ月未満）令和6年9月1日～令和6年11月30日<br>\r\n            契約更新の可能性：あり（条件付きで更新あり）<br>\r\n            契約更新の条件：原則更新（3ヶ月毎の更新）、更新は最長3年まで<br>\r\n            勤務成績良好の場合、無期転換の可能性あり</td>\r\n      </tr>\r\n      <tr>\r\n        <th>就業場所</th>\r\n        <td>岩手県盛岡市</td>\r\n      </tr>\r\n      <tr>\r\n        <th>マイカー通勤</th>\r\n        <td>可（駐車場なし）</td>\r\n      </tr>\r\n      <tr>\r\n        <th>年齢</th>\r\n        <td>不問</td>\r\n      </tr>\r\n      <tr>\r\n        <th>学歴</th>\r\n        <td>不問</td>\r\n      </tr>\r\n      <tr>\r\n        <th>必要な経験等</th>\r\n        <td>必須　インフラ設定経験またはシステム運用経験<br>\r\n        ＰＣスキル：ＰＣ設定経験 </td>\r\n      </tr>\r\n\r\n <!-- 賃金・手当 -->\r\n      <tr>\r\n        <th rowspan=\"2\">賃金・手当</th>\r\n        <th>賃金</th>\r\n        <td>月額　220,000円～260,000円</td>\r\n      </tr>\r\n      <tr>\r\n        <th>通勤手当</th>\r\n        <td>通勤手当は距離に応じて、社内規定にて支給します。　（上限17,000円）</td>\r\n      </tr>\r\n\r\n <!-- 労働時間 -->\r\n      <tr>\r\n        <th rowspan=\"5\">労働時間</th>\r\n        <th>就業時間</th>\r\n        <td>交替制（シフト制）<br>\r\n            （1）8時30分～17時00分<br>\r\n            （2）8時00分～16時30分<br>\r\n            （3）7時30分～16時00分</td>\r\n      </tr>\r\n      <tr>\r\n        <th>時間外労働時間</th>\r\n        <td>時間外労働なし</td>\r\n      </tr>\r\n      <tr>\r\n        <th>休憩時間</th>\r\n        <td>60分</td>\r\n      </tr>\r\n      <tr>\r\n        <th>年間休日数</th>\r\n        <td>125日</td>\r\n      </tr>\r\n      <tr>\r\n        <th>休日等</th>\r\n        <td>土日祝日<br>\r\n            完全週休2日制　毎週</td>\r\n      </tr>\r\n\r\n <!-- その他労働条件等 -->\r\n      <tr>\r\n        <th rowspan=\"1\">労働条件等</th>\r\n        <th>加入保険</th>\r\n        <td>雇用　労災　健康　厚生</td>\r\n      </tr>\r\n\r\n <!-- 選考等 -->\r\n      <tr>\r\n        <th rowspan=\"4\">選考・応募</th>\r\n        <th>採用人数</th>\r\n        <td>1人</td>\r\n      </tr>\r\n      <tr>\r\n        <th>応募書類</th>\r\n        <td>・履歴書（写真貼付）<br>\r\n            ・職務経歴書<br>\r\n            応募書類を下記の郵送先住所まで郵送してください。<br>\r\n            書類選考後（到着から５日以内）、追って連絡いたします。</td>\r\n      </tr>\r\n      <tr>\r\n        <th>郵送先住所</th>\r\n        <td>〒020-8566<br>\r\n            岩手県盛岡市志家町6番1号　IBC放送会館</td>\r\n      </tr>\r\n      <tr>\r\n        <th>担当者</th>\r\n        <td>事業本部　古谷（フルヤ）　019-653-0118<br>受付時間：9:00 &#8211; 17:30</td>\r\n      </tr>\r\n    </tbody>\r\n  </table>\r\n</div>\r\n\r\n<div style=\"height: 40px;\"></div>\r\n\r\n<!-- アカウントマネージメント（盛岡市） -->\r\n<h4>アカウントマネージメント（盛岡市）</h4>\r\n<div class=\"scroll\">\r\n  <table>\r\n    <tbody>\r\n\r\n <!-- 仕事内容 -->\r\n      <tr>\r\n        <th rowspan=\"9\">仕事内容</th>\r\n        <th>職種</th>\r\n        <td>アカウントマネージメント（盛岡市）</td>\r\n      </tr>\r\n      <tr>\r\n        <th>仕事の内容</th>\r\n        <td><p>派遣先事業所にて下記の業務を担当していただきます<br>\r\n            ビデオ広告、テレビコマーシャル、ラジオ広告、<br>\r\n            新聞広告、印刷物（チラシ、ポスター）、<br>\r\n            デジタルコンテンツ<br>\r\n            （ウェブサイト、バナー、ソーシャルメディア広告）、<br>\r\n            交通広告、イベントなどの企画を立案しクライアントへ提案<br>\r\n            新規クライアントを獲得し新しいビジネス機会を広げる業務<br>\r\n            ・社用車あり</p></td>\r\n      </tr>\r\n      <tr>\r\n        <th>雇用形態</th>\r\n        <td>有期雇用派遣労働者</td>\r\n      </tr>\r\n      <tr>\r\n        <th>雇用期間</th>\r\n        <td>期間の定めあり（4ヶ月以上）～令和6年12月31日<br>\r\n            契約更新の条件：1年間派遣ののち、派遣先への正社員雇用の可能性あり</td>\r\n      </tr>\r\n      <tr>\r\n        <th>就業場所</th>\r\n        <td>岩手県盛岡市</td>\r\n      </tr>\r\n      <tr>\r\n        <th>マイカー通勤</th>\r\n        <td>可（駐車場なし）</td>\r\n      </tr>\r\n      <tr>\r\n        <th>年齢</th>\r\n        <td>不問</td>\r\n      </tr>\r\n      <tr>\r\n        <th>学歴</th>\r\n        <td>大学以上</td>\r\n      </tr>\r\n      <tr>\r\n        <th>必要な免許・資格</th>\r\n        <td>普通自動車免許　必須</td>\r\n      </tr>\r\n\r\n <!-- 賃金・手当 -->\r\n      <tr>\r\n        <th rowspan=\"2\">賃金・手当</th>\r\n        <th>賃金</th>\r\n        <td>210,000円～300,000円<br>\r\n        月額21万円以上（年齢・社会経験により異なります）<br>\r\n        残業代・交通費別途支給<br>\r\n        ※車通勤の場合、駐車場は自己確保自己負担</td>\r\n      </tr>\r\n      <tr>\r\n        <th>通勤手当</th>\r\n        <td>実費支給（上限あり）　日額850円</td>\r\n      </tr>\r\n\r\n <!-- 労働時間 -->\r\n      <tr>\r\n        <th rowspan=\"5\">労働時間</th>\r\n        <th>就業時間</th>\r\n        <td>9時30分～18時00分</td>\r\n      </tr>\r\n      <tr>\r\n        <th>時間外労働時間</th>\r\n        <td>時間外労働あり<br>\r\n        月平均10時間</td>\r\n      </tr>\r\n      <tr>\r\n        <th>休憩時間</th>\r\n        <td>60分</td>\r\n      </tr>\r\n      <tr>\r\n        <th>年間休日</th>\r\n        <td>125日</td>\r\n      </tr>      <tr>\r\n        <th>休日等</th>\r\n        <td>土日祝日　その他<br>\r\n            完全週休二日制　毎週<br>\r\n            その他、会社指定日</td>\r\n      </tr>\r\n\r\n <!-- その他労働条件等 -->\r\n      <tr>\r\n        <th rowspan=\"1\">労働条件等</th>\r\n        <th>加入保険</th>\r\n        <td>雇用　労災　健康　厚生</td>\r\n      </tr>\r\n\r\n <!-- 求人に関する特記事項 -->\r\n      <tr>\r\n        <th colspan=\"2\">特記事項</th>\r\n        <td>派遣先にて直接雇用の可能性あり</td>\r\n      </tr>\r\n\r\n <!-- 選考等 -->\r\n      <tr>\r\n        <th rowspan=\"4\">選考・応募</th>\r\n        <th>採用人数</th>\r\n        <td>1人</td>\r\n      </tr>\r\n      <tr>\r\n        <th>応募書類</th>\r\n        <td>・履歴書（写真貼付）<br>\r\n            ・職務経歴書<br>\r\n            応募書類を下記の郵送先住所まで郵送してください。<br>\r\n            書類選考後（到着から５日以内）、追って連絡いたします。</td>\r\n      </tr>\r\n      <tr>\r\n        <th>郵送先住所</th>\r\n        <td>〒020-8566<br>\r\n            岩手県盛岡市志家町6番1号　IBC放送会館</td>\r\n      </tr>\r\n      <tr>\r\n        <th>担当者</th>\r\n        <td>事業本部　古谷（フルヤ）　019-653-0118<br>受付時間：9:00 &#8211; 17:30</td>\r\n      </tr>\r\n    </tbody>\r\n  </table>\r\n</div> \r\n\r\n\r\n<div style=\"height: 40px;\"></div>\r\n\r\n<!-- 総務事務スタッフ（盛岡市）【紹介予定派遣】 -->\r\n<h4>総務事務スタッフ（盛岡市）【紹介予定派遣】</h4>\r\n\r\n<div class=\"scroll\">\r\n  <table>\r\n    <tbody>\r\n\r\n <!-- 仕事内容 -->\r\n      <tr>\r\n        <th rowspan=\"9\">仕事内容</th>\r\n        <th>職種</th>\r\n        <td>総務事務スタッフ（盛岡市）【紹介予定派遣】</td>\r\n      </tr>\r\n      <tr>\r\n        <th>仕事の内容</th>\r\n        <td><p>\r\n        総務業務全般<br>\r\n        日常の電話応対、来客対応、書類作成などの事務<br>\r\n        新卒採用業務<br>\r\n        社内イベントの企画運営<br>\r\n        建築業法に関わる業務</p>\r\n        </td>\r\n      </tr>\r\n      <tr>\r\n        <th>雇用形態</th>\r\n        <td>有期雇用派遣労働者</td>\r\n      </tr>\r\n      <tr>\r\n        <th>雇用期間</th>\r\n        <td>期間の定めあり（4ヶ月以上）6ヶ月<br>\r\n            契約更新の可能性：なし</td>\r\n      </tr>\r\n      <tr>\r\n        <th>就業場所</th>\r\n        <td>岩手県盛岡市</td>\r\n      </tr>\r\n      <tr>\r\n        <th>マイカー通勤</th>\r\n        <td>可（駐車場あり）</td>\r\n      </tr>\r\n      <tr>\r\n        <th>年齢</th>\r\n        <td>不問</td>\r\n      </tr>\r\n      <tr>\r\n        <th>学歴</th>\r\n        <td>大学以上</td>\r\n      </tr>\r\n      <tr>\r\n        <th>必要な経験等</th>\r\n        <td>日商簿記2級　あれば尚可<br>\r\n        建設業経理士2級　あれば尚可<br>\r\n        普通自動車免許　必須</td>\r\n      </tr>\r\n\r\n <!-- 賃金・手当 -->\r\n      <tr>\r\n        <th rowspan=\"2\">賃金・手当</th>\r\n        <th>賃金</th>\r\n        <td>月額　201,600円～201,600円</td>\r\n      </tr>\r\n      <tr>\r\n        <th>通勤手当</th>\r\n        <td>実費支給（上限あり）　日額850円</td>\r\n      </tr>\r\n\r\n <!-- 労働時間 -->\r\n      <tr>\r\n        <th rowspan=\"5\">労働時間</th>\r\n        <th>就業時間</th>\r\n        <td>8時00分～17時00分</td>\r\n      </tr>\r\n      <tr>\r\n        <th>時間外労働時間</th>\r\n        <td>時間外労働あり<br>\r\n            月平均　10時間</td>\r\n      </tr>\r\n      <tr>\r\n        <th>休憩時間</th>\r\n        <td>60分</td>\r\n      </tr>\r\n      <tr>\r\n        <th>年間休日数</th>\r\n        <td>109日</td>\r\n      </tr>\r\n      <tr>\r\n        <th>休日等</th>\r\n        <td>日祝日<br>\r\n            週休二日制<br>\r\n            第3土曜日のみ出社</td>\r\n      </tr>\r\n\r\n <!-- その他労働条件等 -->\r\n      <tr>\r\n        <th rowspan=\"1\">労働条件等</th>\r\n        <th>加入保険</th>\r\n        <td>雇用　労災　健康　厚生</td>\r\n      </tr>\r\n\r\n <!-- 求人に関する特記事項 --> \r\n      <tr>\r\n        <th colspan=\"2\">特記事項</th>\r\n        <td>紹介予定派遣です。半年間派遣社員として勤務し、双方同意のもと派遣先へ直接雇用（正社員）を予定しています。</td>\r\n      </tr>\r\n\r\n <!-- 選考等 -->\r\n      <tr>\r\n        <th rowspan=\"5\">選考・応募</th>\r\n        <th>採用人数</th>\r\n        <td>1人</td>\r\n      </tr>\r\n      <tr>\r\n        <th>応募書類</th>\r\n        <td>・履歴書（写真貼付）<br>\r\n            ・職務経歴書<br>\r\n            応募書類を下記の郵送先住所まで郵送してください。<br>\r\n            書類選考後（到着から５日以内）、追って連絡いたします。</td>\r\n      </tr>\r\n      <tr>\r\n        <th>郵送先住所</th>\r\n        <td>〒020-8566<br>\r\n            岩手県盛岡市志家町6番1号　IBC放送会館</td>\r\n      </tr>\r\n      <tr>\r\n        <th>担当者</th>\r\n        <td>事業本部　古谷（フルヤ）　019-653-0118<br>受付時間：9:00 &#8211; 17:30</td>\r\n      </tr>\r\n    </tbody>\r\n  </table>\r\n</div>\r\n\n\t\t\t\t\t\t\n\t\t\n        \n      </div>\n      <!-- /notice -->\n    </div>\n    <!-- /cont_left -->\n    <!-- コンテンツ右 -->\n    <div id=\"cont_right\">\n      <a href=\"/recruit/\" onclick=\"ga('send','event','内部リンク','クリック','採用情報',{'nonInteraction':1});\"><img src=\"/wordpress/wp-conten