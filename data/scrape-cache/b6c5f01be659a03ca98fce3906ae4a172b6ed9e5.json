\n\t\t\t\t\t<a href=\"https://benesse-scg.co.jp/\" target=\"_blank\"><img src=\"/assets_ren/images/banner/bnr_benesse_stylecare2.png\" alt=\"ベネッセスタイルケア\"></a>\r\n\t\t\t\t</div>\r\n\t\t\t</div>\r\n\t\t</div>\r\n\t\t<!-- / l-footer-upperGroup -->\r\n\t\t\r\n\t\t<div class=\"l-footer-lowerGroup\">\r\n\t\t\t<ul class=\"l-footer-lowerLink__items\">\r\n\t\t\t\t<li class=\"l-footer-lowerLink__item\"><a href=\"/about/utility/term.html\">サイトのご利用にあたって</a></li>\r\n\t\t\t\t<li class=\"l-footer-lowerLink__item\"><a href=\"/privacy/\">情報セキュリティ・個人情報</a></li>\r\n\t\t\t\t<li class=\"l-footer-lowerLink__item\"><a href=\"/zemi/privacy/zemi.html\">利用者情報の取り扱い</a></li>\r\n\t\t\t\t<li class=\"l-footer-lowerLink__item\"><a href=\"/about/management/antisocial.html\">反社会的勢力排除に関する基本方針</a></li>\r\n\t\t\t\t<!-- <li class=\"l-footer-lowerLink__item\"><a href=\"/about/utility/hotline.html\">ベネッセコーポレーショングループとのお取り引きに関する通報窓口</a></li> -->\r\n\t\t\t\t<li class=\"l-footer-lowerLink__item\"><a href=\"/about/management/taxpolicy.html\">ベネッセコーポレーショングループ税務基本方針</a></li>\r\n\t\t\t\t<li class=\"l-footer-lowerLink__item\"><a href=\"/benesseinfo/data.html#notice\">電子公告</a></li>\r\n\t\t\t</ul>\r\n\t\t\t<div class=\"l-copyright\">\r\n\t\t\t\t<p class=\"l-footer__logo\"><a href=\"/\"><img src=\"/assets_ren/images/benesse-logo3.svg\" alt=\"Benesse\"></a></p>\r\n\t\t\t\t<small>Copyright &copy;Benesse Corporation. All rights reserved.</small>\r\n\t\t\t</div>\r\n\t\t</div>\r\n\t\t<!-- / l-footer-lowerGroup -->\r\n\t</div>\r\n</footer>\r\n<!-- / l-footer -->\r\n\n<script>\nasync function initMember() {\n\ttry {\n\t\t// const res = await fetch(\"https://company.benesse.co.jp/benesseinfo/data/yakuin.json\", {\n\t\tconst res = await fetch(\"https://company.benesse.co.jp/benesseinfo/data/yakuin2.json\", {\n\t\t\tcache: \"no-cache\"\n\t\t});\n\n\t\tif (!res.ok) throw new Error(\"HTTPエラー\");\n\n\t\tconst data = await res.json();\n\n\t\tif (!data || !data.entries) {\n\t\t\tconsole.error(\"JSON構造不正\", data);\n\t\t\treturn;\n\t\t}\n\n\t\tconst container = document.getElementById(\"list_container\");\n\t\tif (!container) {\n\t\t\tconsole.error(\"containerが無い\");\n\t\t\treturn;\n\t\t}\n\n\t\tconst grouped = {};\n\t\tdata.entries.forEach(entry => {\n\t\t\tif (!entry.categories) return;\n\n\t\t\tentry.categories.forEach(cat => {\n\t\t\t\tif (!grouped[cat]) grouped[cat] = [];\n\t\t\t\tgrouped[cat].push(entry);\n\t\t\t});\n\t\t});\n\n\t\tObject.keys(grouped).forEach(category => {\n\t\t\tconst safeCat = category.replace(/[^\\w\\-]/g, \"_\");\n\n\t\t\tconst section = document.createElement(\"div\");\n\t\t\tsection.innerHTML = `\n\t\t\t\t<h3 class=\"c-tertiaryHeading\">${category}</h3>\n\t\t\t\t<div id=\"cat-${category}\" class=\"p-memberList__items\"></div>\n\t\t\t`;\n\n\t\t\tcontainer.appendChild(section);\n\n\t\t\tconst div = section.querySelector(\".p-memberList__items\");\n\n\t\t\tgrouped[category].forEach(entry => {\n\t\t\t\tconst hasUrl = entry.url && entry.url.trim() !== \"\";\n\n\t\t\t\tdiv.insertAdjacentHTML(\"beforeend\", `\n\t\t\t\t\t<div class=\"p-memberList__item\">\n\t\t\t\t\t\t<div class=\"p-memberList__post\">${entry.yaku || \"\"}</div>\n\t\t\t\t\t\t<div class=\"p-memberList__name\">${entry.title || \"\"}</div>\n\t\t\t\t\t\t${hasUrl ? `\n\t\t\t\t\t\t\t<div class=\"p-memberList__biography\">\n\t\t\t\t\t\t\t\t<p class=\"c-textlink arw_ani\">\n\t\t\t\t\t\t\t\t\t<a class=\"c-arw_r03\" href=\"${entry.url}\" target=\"${entry.target || '_self'}\">略歴</a>\n\t\t\t\t\t\t\t\t</p>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t` : ``}\n\t\t\t\t\t</div>\n\t\t\t\t`);\n\t\t\t});\n\t\t});\n\n\t\t// 更新日\n\t\tconst update = document.getElementById(\"update\");\n\t\tif (update && data.entrydata) {\n\t\t\tupdate.innerText = \"\";\n\t\t\tdata.entrydata.forEach(item => {\n\t\t\t\tupdate.innerText += `${item.date} 更新`;\n\t\t\t});\n\t\t}\n\n\t\t// 取締役の後にテキスト\n\t\tconst textNotes = document.querySelector('#cat-取締役');\n\t\tif (textNotes) {\n\t\t\ttextNotes.insertAdjacentHTML('afterend', '<p class=\"c-note\">非業務執行取締役</p>');\n\t\t}\n\n\t} catch (err) {\n\t\tconsole.error(\"致命エラー\", err);\n\t}\n}\n\ndocument.addEventListener(\"DOMContentLoaded\", () => {\n\tinitMember();\n});\n\n</script>\n<script type=\"text/javascript\" src=\"/_Incapsula_Resource?SWJIYLWA=719d34d31c8e3a6e6fffd425f7e032f3&ns=6&cb=1509024525\" async></script></body>\n</html>\n","finalUrl":"https://www.benesse.co.jp/benesseinfo/executive_member.html","rendered":false,"_cachedAt":"2026-06-23T16:25:06.889Z"}