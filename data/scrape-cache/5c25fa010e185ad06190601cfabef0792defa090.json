{"url":"https://www.k-yamasan.co.jp/recruit/member/interview07/","html":"<!DOCTYPE HTML>\n<html lang=\"ja\">\n\n<head>\n  <!-- Google Tag Manager -->\n  <script>\n    (function(w, d, s, l, i) {\n      w[l] = w[l] || [];\n      w[l].push({\n        'gtm.start': new Date().getTime(),\n        event: 'gtm.js'\n      });\n      var f = d.getElementsByTagName(s)[0],\n        j = d.createElement(s),\n        dl = l != 'dataLayer' ? '&l=' + l : '';\n      j.async = true;\n      j.src = 'https://www.googletagmanager.com/gtm.js?id=' + i + dl;\n      f.parentNode.insertBefore(j, f);\n    })(window, document, 'script', 'dataLayer', 'GTM-PJDQ96SJ');\n  </script>\n  <!-- End Google Tag Manager -->\n  <meta http-equiv=\"content-type\" content=\"text/html; charset=utf-8\">\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1.0,minimum-scale=1.0\">\n  <meta name=\"format-detection\" content=\"telephone=no\">\n  <title>S.K.｜株式会社山産 採用サイト</title>\n  <script src=\"/recruit/inc/js/page/viewport-extra.min.js\"></script>\n  <script>\n    new ViewportExtra(375);\n  </script>\n  <link rel=\"icon\" href=\"/recruit/inc/image/favicon.ico\" type=\"image/x-icon\">\n  <link rel=\"apple-touch-icon\" href=\"/recruit/inc/image/apple-touch-icon.png\">\n  <link rel=\"icon\" href=\"/recruit/inc/image/android-chrome-192x192.png\" type=\"image/png\">\n  <meta name=\"description\" content=\"株式会社山産で働く先輩社員たちの、入社の動機や仕事に対する思い、みなさんへのメッセージなどをご紹介しています。\">\n  <meta property=\"og:site_name\" content=\"株式会社山産 採用サイト\">\n  <meta property=\"og:title\" content=\"S.K.｜株式会社山産 採用サイト\">\n  <meta property=\"og:description\" content=\"株式会社山産で働く先輩社員たちの、入社の動機や仕事に対する思い、みなさんへのメッセージなどをご紹介しています。\">\n  <meta property=\"og:type\" content=\"article\">\n  <meta property=\"og:url\" content=\"https://www.k-yamasan.co.jp/recruit/member/interview07/\">\n  <meta property=\"og:image\" content=\"https://www.k-yamasan.co.jp/recruit/inc/image/common/img_ogp.jpg\">\n  <meta name=\"twitter:card\" content=\"summary_large_image\">\n  <meta name=\"twitter:site\" content=\"https://www.k-yamasan.co.jp/recruit/member/interview07/\">\n  <meta name=\"twitter:image\" content=\"https://www.k-yamasan.co.jp/recruit/inc/image/common/img_ogp.jpg\">\n  <link href=\"https://fonts.googleapis.com/css?family=Noto+Sans+JP:400,500,700&display=swap&subset=japanese\" rel=\"stylesheet\">\n  <link rel=\"stylesheet\" type=\"text/css\" href=\"/recruit/inc/css/style.css\">\n  <link rel=\"stylesheet\" type=\"text/css\" href=\"/recruit/inc/css/project/interview.css\">\n</head>\n\n<body id=\"interview07\">\n  <!-- Google Tag Manager (noscript) -->\n  <noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-PJDQ96SJ\" height=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n  <!-- End Google Tag Manager (noscript) -->\n  <div id=\"container\">\n    <header class=\"l-header\">\n      <div class=\"l-header__inner\">\n        <div class=\"l-header__modules\">\n          <a href=\"/recruit\" class=\"logo\">\n            <span class=\"logo-main\"><img src=\"/recruit/inc/image/common/img_logo.svg\" alt=\"株式会社山産 採用サイト\"></span>\n            <span class=\"logo-sub\"><img src=\"/recruit/inc/image/common/img_headerLogocaption.svg\" alt=\"RECRUIT SITE\"></span>\n          </a>\n        </div>\n        <nav class=\"l-header__btnArea\">\n          <button class=\"l-header__btn js-naviBtn\" data-cat=\"gnavi\">\n            <span class=\"c-toggleBtn\" id=\"toggle\">\n              <span></span>\n              <span></span>\n              <span></span>\n            </span>\n          </button>\n        </nav>\n      </div>\n      <!-- グローバルナビゲーション -->\n      <div class=\"l-navigation__wrapper\" id=\"gnavi\">\n        <nav class=\"l-navigation\">\n          <!-- 1列目 -->\n          <ul class=\"l-navigation__list\">\n            <!-- トップ -->\n            <li class=\"l-navigation__item\">\n              <a class=\"current\" href=\"/recruit\">トップ</a>\n            </li>\n            <!-- トップ -->\n            <!-- 山産を知る -->\n            <li class=\"l-navigation__item\">\n              <button class=\"js-hasDropdown l-navigation__item\">山産を知る</button>\n              <ul class=\"l-navigation__list-sub\">\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/about/message/\">採用メッセージ</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/about/business/\">山産の事業について</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/about/data/\">数字で見る山産</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/about/case/\">こんなところに山産</a></li>\n              </ul>\n            </li>\n            <!-- 山産を知る -->\n          </ul>\n          <!-- 1列目 -->\n          <!-- 2列目 -->\n          <ul class=\"l-navigation__list\">\n            <!-- 仕事を知る -->\n            <li class=\"l-navigation__item\">\n              <a href=\"/recruit/about/work/\">仕事を知る</a>\n            </li>\n            <!-- 仕事を知る -->\n            <!-- 山産の人 -->\n            <li class=\"l-navigation__item\">\n              <button class=\"js-hasDropdown l-navigation__item\">人を知る</button>\n              <ul class=\"l-navigation__list-sub\">\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/member/\" class=\"js-naviAnchor\">人を知るTOP</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/member/interview01/\" class=\"js-naviAnchor\">環境事業グループ D.F.</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/member/interview06/\" class=\"js-naviAnchor\">環境事業グループ Y.O.</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/member/interview07/\" class=\"js-naviAnchor\">産機事業グループ S.K.</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/member/interview02/\" class=\"js-naviAnchor\">産機事業グループ Y.T.</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/member/interview03/\" class=\"js-naviAnchor\">総務部 K.I.</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/member/interview04/\" class=\"js-naviAnchor\">産機事業グループ S.I.</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/member/interview05/\" class=\"js-naviAnchor\">環境事業グループ H.M.</a></li>\n              </ul>\n            </li>\n            <!-- 山産の人 -->\n          </ul>\n          <!-- 2列目 -->\n          <!-- 3列目 -->\n          <ul class=\"l-navigation__list\">\n            <!-- 環境・制度を知る -->\n            <li class=\"l-navigation__item\">\n              <button class=\"js-hasDropdown l-navigation__item\">環境・制度を知る</button>\n              <ul class=\"l-navigation__list-sub\">\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/info/culture/\">文化・社風</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/info/benefits/\">福利厚生</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/info/training/\">教育制度・キャリアステップ</a></li>\n              </ul>\n            </li>\n            <!-- 働く人を知る -->\n          </ul>\n          <!-- 3列目 -->\n          <!-- 4列目 -->\n          <ul class=\"l-navigation__list\">\n            <!-- 採用情報 -->\n            <li class=\"l-navigation__item\">\n              <button class=\"js-hasDropdown l-navigation__item\">採用情報</button>\n              <ul class=\"l-navigation__list-sub\">\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/info/guideline/\">募集要項・選考の流れ</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/info/faq/\">よくあるご質問</a></li>\n              </ul>\n            </li>\n            <!-- 採用情報 -->\n            <!-- エントリー -->\n            <li class=\"l-navigation__item\">\n              <button class=\"js-hasDropdown l-navigation__item\">エントリー</button>\n              <ul class=\"l-navigation__list-sub\">\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/new-graduate-entry/\">新卒採用エントリー</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/entry/\">経験者採用エントリー</a></li>\n              </ul>\n            </li>\n            <!-- エントリー -->\n          </ul>\n          <!-- 4列目 -->\n        </nav>\n      </div>\n      <!-- グローバルナビゲーション -->\n    </header>\n    <!-- /header -->\n    <main id=\"main\">\n      <div class=\"l-lowerCaption\">\n        <div class=\"l-lowerCaption__inner\">\n          <h1 class=\"l-lowerCaption__title\">S.K.</h1>\n          <ol class=\"c-topicspath\">\n            <li><a href=\"/recruit\">ホーム</a></li>\n            <li><a href=\"/recruit/member/\">人を知る</a></li>\n            <li>S.K.</li>\n          </ol>\n        </div>\n      </div>\n      <div class=\"l-lowerCaption__bottom\">\n        <img src=\"/recruit/inc/image/common/lower/img_lowerCaption-bottom.svg\" alt=\"\">\n      </div>\n      <div id=\"contents\" class=\"l-lower\">\n        <section class=\"l-section\">\n          <div class=\"l-section__inner\">\n            <div class=\"l-mw p-interviewHero\">\n              <picture class=\"p-interviewHero__image\">\n                <source srcset=\"/recruit/inc/image/member/interview07/pic_interview-main.jpg.webp 1x, /recruit/inc/image/member/interview07/pic_interview-main@2x.jpg.webp 2x\" type=\"image/webp\">\n                <img src=\"/recruit/inc/image/member/interview07/pic_interview-main.jpg\" alt=\"S.K.\">\n              </picture>\n              <div class=\"p-interviewHero__text\">\n                <h2 class=\"p-interviewHero__title\"><span>関係構築と挑戦</span><span>自分らしく成長する</span></h2>\n                <p class=\"p-interviewHero__affiliation\"><span>2020年度入社 産機事業グループ 営業</span></p>\n                <p class=\"p-interviewHero__name\"><span>S.K.</span></p>\n              </div>\n            </div>\n          </div>\n          <!-- 本文 -->\n          <div class=\"l-section__inner l-section__inner--pbSmall-sm\">\n            <div class=\"l-mw l-mw--800\">\n              <p class=\"p-interview__question\">山産で働きたいと思うようになった理由、きっかけは？</p>\n              <h3 class=\"c-ttl-small\">先輩社員の紹介と、アットホームな社風が入社の決め手に</h3>\n              <p>同じ出身地の先輩社員から紹介していただいたことがきっかけです。給料や福利厚生などの待遇に興味を持ち、会社説明会に参加しました。そこで出会った採用担当者の親切な対応と、会社全体のアットホームな雰囲気に魅力を感じました。<br> 専門知識がない状態からのスタートでしたが、「営業という職種は、コミュニケーション能力や愛嬌があればやっていける」という話を聞き、自分にも活躍のチャンスがあると感じたことが、入社の大きな決め手になりました。</p>\n            </div>\n          </div>\n          <div class=\"l-section__inner l-section__inner--pbSmall-sm\">\n            <div class=\"l-mw l-mw--800\">\n              <p class=\"p-interview__question\">どんな仕事をしていますか？</p>\n              <h3 class=\"c-ttl-small\">お客様の課題に向き合う提案型営業</h3>\n              <p>主に民間工場のお客様のニーズに合わせて、製品の紹介や提案、発注を行っています。お客様とメーカーをつなぐ架け橋として、日々の営業活動に取り組んでいます。まずはお客様の工場を訪問し、お困りごとやご要望を伺いながら、課題をしっかりと把握します。そして、メーカーや協力会社と連携しながら、最適な製品を選定してご提案します。<br> また、大阪・兵庫エリアの営業を担当しており、エリアが広く頻繫に訪問することは難しいので、 一件一件丁寧に対応することを心がけています。 このエリアは小規模なお客様も多く、新しいお取引のチャンスも多いのが特徴です。</p>\n            </div>\n          </div>\n          <div class=\"l-section__inner l-section__inner--pbSmall-sm\">\n            <div class=\"l-mw l-mw--800\">\n              <p class=\"p-interview__question\">山産の良い部分は？また、やりがいを教えてください。</p>\n              <h3 class=\"c-ttl-small\">支え合う環境と、お客様との信頼関係づくり</h3>\n              <p>社内には経験豊富で面倒見の良い社員が多く、分からないことがあればすぐに相談できる環境です。2年に1回の社員旅行もあり、社員同士の距離が近く、営業所を超えた横のつながりも大切にしています。<br> やりがいを感じるのは、お客様との距離が縮まったときです。初めての訪問では仕事の話が中心ですが、通い続けるうちに少しずつプライベートな話題を引き出せるようになってきます。仕事とプライベートが半々くらいの割合で話せるようになると、お客様との信頼関係が深まったことを実感でき、この仕事の喜びを感じます。</p>\n            </div>\n          </div>\n          <div class=\"l-section__inner l-section__inner--pbSmall-sm\">\n            <div class=\"l-mw l-mw--800\">\n              <picture class=\"c-imageWrapper\">\n                <source srcset=\"/recruit/inc/image/member/interview07/pic_interviewBody01.jpg.webp 1x, /recruit/inc/image/member/interview07/pic_interviewBody01@2x.jpg.webp 2x\" type=\"image/webp\">\n                <img src=\"/recruit/inc/image/member/interview07/pic_interviewBody01.jpg\" alt=\"業務風景\">\n              </picture>\n            </div>\n          </div>\n          <div class=\"l-section__inner l-section__inner--pbSmall-sm\">\n            <div class=\"l-mw l-mw--800\">\n              <p class=\"p-interview__question\">仕事をしていて大変なことは？どうやって乗り越えてますか？</p>\n              <h3 class=\"c-ttl-small\">トラブル対応で日々成長。人との関わりが支えに</h3>\n              <p>特に大変なのはトラブル対応の場面です。迅速な対応が求められるため、常に気を引き締めて行動しています。お客様とメーカーの間で調整が必要になることも多いですが、お互いが納得できる形を模索しながら話を進めるよう心がけています。<br> 私なりのリセット方法は、しっかり休むことです。しっかり寝ると、翌日にはリセットできます。私が担当している関西エリアはフランクなお客様が多く、人見知りだった学生時代から大きく変わることができました。オンとオフの切り替えを大切にしながら、日々前向きに仕事に取り組んでいます。</p>\n            </div>\n          </div>\n          <div class=\"l-section__inner l-section__inner--pbSmall-sm\">\n            <div class=\"l-mw l-mw--800\">\n              <p class=\"p-interview__question\">グレートを創り出す為に心がけていることや、これから挑戦したいことがあれば教えてください</p>\n              <h3 class=\"c-ttl-small\">頼られる存在になるために、新しい環境への挑戦を続ける</h3>\n              <p>お客様にも社内の仲間にも頼られる社員になることが、私にとっての「グレート」です。<br> 知識が豊富で、社内外から頼られている上司を、心から尊敬しています。先輩の良いところを見習いながら、自分の強みや興味を活かして成長していけるよう心がけています。一方で、同じお客様を長く担当していると、新しい知識を得る機会が少なくなりがちです。そのため、異なる業種での新規営業などにも挑戦し、意識的に新しい環境に身を置くようにしています。</p>\n            </div>\n          </div>\n          <div class=\"l-section__inner l-section__inner--pbSmall-sm\">\n            <div class=\"l-mw l-mw--800\">\n              <picture class=\"c-imageWrapper\">\n                <source srcset=\"/recruit/inc/image/member/interview07/pic_interviewBody02.jpg.webp 1x, /recruit/inc/image/member/interview07/pic_interviewBody02@2x.jpg.webp 2x\" type=\"image/webp\">\n                <img src=\"/recruit/inc/image/member/interview07/pic_interviewBody02.jpg\" alt=\"業務風景\">\n              </picture>\n            </div>\n          </div>\n          <!-- 一日の流れ -->\n          <div class=\"l-section__inner l-section__inner--pbSmall-sm\">\n            <div class=\"l-mw l-mw--800\">\n              <h3 class=\"c-ttl-small c-ttl-middle--mbLarge\">1日の流れ</h3>\n              <div class=\"c-timeline\">\n                <ol class=\"c-timeline__list\">\n                  <li class=\"c-timeline__itemWrapper\">\n                    <dl class=\"c-timeline__item\">\n                      <dt class=\"c-timeline__time\"><span><span>8:00</span></span></dt>\n                      <dd class=\"c-timeline__content\">\n                        <h4 class=\"c-timeline__heading\">出社 or お客様の元へ直行</h4>\n                        <p></p>\n                      </dd>\n                    </dl>\n                  </li>\n                  <li class=\"c-timeline__itemWrapper\">\n                    <dl class=\"c-timeline__item\">\n                      <dt class=\"c-timeline__time\"><span><span>9:00</span></span></dt>\n                      <dd class=\"c-timeline__content\">\n                        <h4 class=\"c-timeline__heading\">お客様訪問・ヒアリング</h4>\n                        <p></p>\n                      </dd>\n                    </dl>\n                  </li>\n                  <li class=\"c-timeline__itemWrapper\">\n                    <dl class=\"c-timeline__item\">\n                      <dt class=\"c-timeline__time\"><span><span>12:00</span></span></dt>\n                      <dd class=\"c-timeline__content\">\n                        <h4 class=\"c-timeline__heading\">昼休み</h4>\n                        <p></p>\n                      </dd>\n                    </dl>\n                  </li>\n                  <li class=\"c-timeline__itemWrapper\">\n                    <dl class=\"c-timeline__item\">\n                      <dt class=\"c-timeline__time\"><span><span>13:00</span></span></dt>\n                      <dd class=\"c-timeline__content\">\n                        <h4 class=\"c-timeline__heading\">午後の営業活動</h4>\n                        <p></p>\n                      </dd>\n                    </dl>\n                  </li>\n                  <li class=\"c-timeline__itemWrapper\">\n                    <dl class=\"c-timeline__item\">\n                      <dt class=\"c-timeline__time\"><span><span>16:00</span></span></dt>\n                      <dd class=\"c-timeline__content\">\n                        <h4 class=\"c-timeline__heading\">帰社</h4>\n                        <p>見積もり作成・発注・打合せなど</p>\n                      </dd>\n                    </dl>\n                  </li>\n                  <li class=\"c-timeline__itemWrapper\">\n                    <dl class=\"c-timeline__item\">\n                      <dt class=\"c-timeline__time\"><span><span>19:00</span></span></dt>\n                      <dd class=\"c-timeline__content\">\n                        <h4 class=\"c-timeline__heading\">退勤</h4>\n                        <p></p>\n                      </dd>\n                    </dl>\n                  </li>\n                </ol>\n              </div>\n            </div>\n          </div>\n          <!-- 一日の流れ -->\n          <div class=\"l-section__inner l-section__inner--pbSmall-sm\">\n            <div class=\"l-mw l-mw--800\">\n              <picture class=\"c-imageWrapper\">\n                <source srcset=\"/recruit/inc/image/member/interview07/pic_interviewBody03.jpg.webp 1x, /recruit/inc/image/member/interview07/pic_interviewBody03@2x.jpg.webp 2x\" type=\"image/webp\">\n                <img src=\"/recruit/inc/image/member/interview07/pic_interviewBody03.jpg\" alt=\"業務風景\">\n              </picture>\n            </div>\n          </div>\n          <div class=\"l-section__inner l-section__inner--pbSmall-sm\">\n            <div class=\"l-mw l-mw--800\">\n              <h3 class=\"c-ttl-small\">応募を考えている人へメッセージをお願いします!!</h3>\n              <p>知識がなくても、やる気があれば先輩が丁寧に教えてくれます。周囲の人がフォローやアドバイスをしてくれる環境が整っているので、安心して飛び込んできてほしいです。どこの営業所にも頼れる先輩がいて、優しい方ばかりなので安心して働けます。<br>山産は、一人ひとりの個性や強みを尊重し、自分らしく働ける環境が整っています。ぜひ一緒に、お客様や仲間から頼られる存在を目指していきましょう。皆さんと一緒に働けることを楽しみにしています。</p>\n            </div>\n          </div>\n          <!-- 本文 -->\n        </section>\n        <!-- 他インタビューへのリンク-->\n        <div class=\"l-bg l-bg--bgColor\">\n          <div class=\"l-section l-section--pb2x u-border-top\">\n            <h2 class=\"c-ttl-main c-ttl-main c-ttl--center c-ttl--keycolor c-ttl--oblique\"> 他のメンバーのインタビューを見る </h2>\n            <div class=\"l-Grid--18\">\n              <!-- 他ページへのリンク -->\n              <ul class=\"grid\">\n                <li class=\"col-4_md-6_sm-12\">\n                  <a href=\"/recruit/member/interview01\" class=\"c-hasImageCard\">\n                    <picture class=\"c-hasImageCard__image\">\n                      <source srcset=\"/recruit/inc/image/member/pic_interviewCard01.jpg.webp 1x, /recruit/inc/image/member/pic_interviewCard01@2x.jpg.webp 2x\" type=\"image/webp\">\n                      <img src=\"/recruit/inc/image/member/pic_interviewCard01.jpg\" alt=\"D.F.\">\n                    </picture>\n                    <div class=\"c-hasImageCard__text\">\n                      <h4 class=\"c-hasImageCard__title\"><span>自由な裁量で</span><span>自分の仕事に責任を持つ</span></h4>\n                      <div class=\"c-hasImageCardInfo\">\n                        <div class=\"c-hasImageCardInfo__main\">\n                          <span class=\"c-hasImageCard__affiliation\">2021年度入社<br>環境事業グループ 施工管理</span>\n                          <span class=\"c-hasImageCard__name\">D.F.</span>\n                        </div>\n                        <span class=\"c-hasImageCard__arrow c-hasImageCardInfo__arrow\"></span>\n                      </div>\n                    </div>\n                  </a>\n                </li>\n                <li class=\"col-4_md-6_sm-12\">\n                  <a href=\"/recruit/member/interview06\" class=\"c-hasImageCard\">\n                    <picture class=\"c-hasImageCard__image\">\n                      <source srcset=\"/recruit/inc/image/member/pic_interviewCard06.jpg.webp 1x, /recruit/inc/image/member/pic_interviewCard06@2x.jpg.webp 2x\" type=\"image/webp\">\n                      <img src=\"/recruit/inc/image/member/pic_interviewCard06.jpg\" alt=\"H.M.\">\n                    </picture>\n 