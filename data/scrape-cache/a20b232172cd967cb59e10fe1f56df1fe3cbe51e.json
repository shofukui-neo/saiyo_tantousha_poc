{"url":"https://www.yoshida-p.co.jp/about/","html":"<!DOCTYPE HTML>\n<html lang=\"ja\">\n<head>\n<meta charset=\"utf-8\">\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n<meta name=\"format-detection\" content=\"telephone=no\">\n\n\n\n\n<meta name=\"description\" content=\"ヨシダ印刷株式会社｜金沢・東京を拠点に活動する印刷会社。印刷物、デジタルコンテンツ、販促ツール、Web入稿システム構築等、企画からデザイン制作・発送までワンストップで幅広くご提供しています。\">\n\n<meta name=\"keywords\" content=\"水なし印刷,印刷会社,ISMS,FSC,Web入稿システム,ドキュメント管理,展示会運営,販促ツール,企画提案,金沢,東京\">\n\n\n\n<link rel=\"icon\" href=\"/favicon.ico\">\n<!-- common -->\n<link rel=\"stylesheet\" href=\"/common/css/bootstrap.css\">\n<link rel=\"stylesheet\" href=\"/common/css/default.css\">\n<link rel=\"stylesheet\" href=\"/common/css/font-awesome.min.css\">\n<link rel=\"stylesheet\" href=\"/common/css/style.css?date=20250618094031\">\n<script src=\"https://www.ypg.jp/common/js/jquery-2.1.4.min.js\"></script>\n<script src=\"https://www.ypg.jp/common/js/jquery.msbxlib.js\"></script>\n<script src=\"https://www.ypg.jp/common/js/common.js\"></script>\n<link href=\"https://www.ypg.jp/common/css/jquery.bxslider.css\" rel=\"stylesheet\">\n\n<!-- Google Tag Manager -->\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n})(window,document,'script','dataLayer','GTM-NZG7SXG5');</script>\n<!-- End Google Tag Manager -->\n\n\n\n<title>ヨシダ印刷とは | ヨシダ印刷株式会社</title>\n\n</head>\n<body>\n<!-- Google Tag Manager (noscript) -->\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-NZG7SXG5\"\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n<!-- End Google Tag Manager (noscript) -->\n\n<div id=\"page\">\n<!-- header ==================================================================== -->\n  <header>\n    <div id=\"header\">\n      <p class=\"logo\">\n        <a href=\"/index.html\">\n          <img src=\"/images/logo_pc_yoshida.svg\" alt=\"YPG\" class=\"pc_only_767\">\n          <img src=\"https://www.ypg.jp/images/ypg_fotter.svg\" alt=\"YPG\" class=\"sp_only_767\">\n        </a>\n      </p>\n      <nav id=\"gnavi\">\n        <ul class=\"gNaviPc gNaviSp_renewal\">\n          <li><a class=\"sp_dropdown\" href=\"https://www.ypg.jp/#ypg_service\"><span class=\"gNaviPc_maintxt\">製品・サービス</span></a>\n          </li>\n          <li><a href=\"https://www.yoshida-p.co.jp/about/index.html\"><span class=\"gNaviPc_maintxt\">ヨシダ印刷とは</span></a></li>\n          <li><a href=\"https://www.yoshida-p.co.jp/company/index.html\"><span class=\"gNaviPc_maintxt\">企業情報</span></a></li>\n          <li><a href=\"https://www.ypg.jp/recruit/index.html\"><span class=\"gNaviPc_maintxt\">採用情報</span></a></li>\n          <li><a href=\"https://www.yoshida-p.co.jp/inquiry/\"><span class=\"gNaviPc_maintxt\">お問い合わせ</span></a></li>\n        </ul>\n      </nav>\n      <div class=\"sp_contact_btn\"><a href=\"https://www.yoshida-p.co.jp/inquiry/\"><img src=\"https://www.ypg.jp/images/btn_contact_sp.svg\" alt=\"お問合せ\"></a></div>\n      <div class=\"header_hum_btn\"><a href=\"javascript:void(0)\" id=\"hum_menu\"><span></span></a></div>\n    </div><!-- / #header .clearfix -->\n  </header>\n  <style>\n    @media print,\n    screen and (min-width: 768px) {\n      .gNaviPc {\n        margin-top: 30px;\n      }\n    }\n\n    @media print,\n    screen and (max-width: 767px) {\n      .gNaviSp_renewal .sp_dropdown::after {\n        content: none;\n      }\n    }\n  </style>\n<!-- /header ==================================================================== -->\n<!-- contents ==================================================================== -->\n\n\n<div class=\"contents_page page-about\">\n<!-- フォント読み込み -->\n  <style>\n    @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@600;700;800&family=Noto+Sans+JP:wght@400;500;700&family=EB+Garamond:wght@600&display=swap');\n  </style>\n\n  <!-- パンくずリスト_bgcolor有 -->\n  <nav class=\"nav_bg\">\n    <ol class=\"breadcrumb\">\n      <li><a href=\"/\">TOP</a></li>\n      <li>ヨシダ印刷とは</li>\n    </ol>\n    <div class=\"top_title_txt_container\">\n      <p class=\"top_title_txt\">About us</p>\n    </div>\n  </nav>\n  <style>\n    .nav_bg {\n      background-color: #f0f8ff;\n      padding: 1em 1em 2em 1em;\n    }\n\n    .top_title_txt_container {\n      max-width: 1110px;\n      margin: 0 auto;\n      padding: 0 1em;\n    }\n\n    .top_title_txt {\n      font-family: 'EB Garamond', serif;\n      font-size: 7rem;\n      letter-spacing: 3px;\n      color: #0069C7;\n      font-weight: 600;\n    }\n\n    .breadcrumb {\n      display: flex;\n      flex-wrap: wrap;\n      list-style: none;\n      max-width: 1110px;\n      margin: 30px auto 30px auto;\n      padding: 0 1em;\n    }\n\n    .breadcrumb li {\n      font-family: 'Noto Sans JP', sans-serif;\n      font-size: 1.2rem;\n      font-weight: 400;\n      color: #222;\n    }\n\n    .breadcrumb a {\n      text-decoration: underline;\n    }\n\n    .breadcrumb a:hover {\n      font-weight: 700;\n    }\n\n    .breadcrumb li:not(:last-of-type)::after {\n      content: \"＞\";\n      margin: 0 1.3em;\n      color: #222;\n    }\n\n    .breadcrumb li:last-child {\n      font-weight: 700;\n    }\n\n    @media print,\n    screen and (max-width: 750px) {\n      .breadcrumb {\n        margin-bottom: clamp(20px, 10vw, 70px);\n      }\n\n      .breadcrumb li:not(:last-of-type)::after {\n        margin: 0 0.5em;\n      }\n    }\n\n    @media print,\n    screen and (max-width: 470px) {\n      .top_title_txt {\n        font-size: clamp(4.7rem, 14.9vw, 7rem)\n      }\n    }\n  </style>\n\n  <!-- メッセージ -->\n  <div class=\"message_container\">\n    <!-- <div class=\"box_title\">\n      メッセージ\n    </div> -->\n    <div class=\"box_title_txt\">\n      <p class=\"box_title_txt_1\">\n        社会にとって\n        <br>\n        <span style=\"color: #0069C7;\">「なくてはならない」</span>印刷会社を目指して\n      </p>\n      <p class=\"box_title_txt_2\">私たちヨシダ印刷は、「印刷の本質は情報伝達である」と捉えています。</p>\n      <p class=\"box_title_txt_3 txt14\">\n        媒体のジャンルにとらわれず、お客様の伝えたい情報を、最も効果的なカタチにすること。\n        <br>\n        それが、私たちの使命です。ヨシダ印刷は、一人でも多くのお客様にとって「なくてはならない印刷会社」となることを目指し、これからも邁進いたします。\n      </p>\n    </div>\n  </div>\n  <style>\n    .message_container {\n      display: flex;\n      justify-content: center;\n      margin: 0 auto;\n      max-width: 1110px;\n      padding: 7em 1em;\n      position: relative;\n    }\n\n    .message_container::after {\n      position: absolute;\n      top: 99.5%;\n      left: 50%;\n      border: solid transparent;\n      content: \" \";\n      border-top-color: #FFF;\n      border-width: 32px 42px 0 42px;\n      margin-left: -42px;\n    }\n\n    .box_title {\n      width: 30%;\n      font-family: 'Noto Sans JP', sans-serif;\n      font-size: 4rem;\n      font-weight: 700;\n      color: #222;\n      letter-spacing: 1.5px;\n      margin-bottom: 30px;\n      padding-left: 0.8em;\n      text-indent: -0.8em;\n    }\n\n    .box_title::before {\n      content: \"\";\n      height: 13px;\n      width: 13px;\n      background: #0069C7;\n      display: inline-block;\n      margin-right: 0.2em;\n      vertical-align: middle;\n    }\n\n    .box_title_txt {\n      width: 70%;\n    }\n\n    .box_title_txt_1,\n    .box_title_txt_2,\n    .box_title_txt_3 {\n      font-family: 'Noto Sans JP', sans-serif;\n      color: #222;\n      letter-spacing: 1.5px;\n    }\n\n    .box_title_txt_1 {\n      font-size: 3rem;\n      font-weight: 700;\n      line-height: 1.2;\n    }\n\n    .box_title_txt_2 {\n      font-size: 2rem;\n      font-weight: 700;\n      margin-top: 20px;\n      margin-bottom: 30px;\n      line-height: 1.2;\n    }\n\n    .box_title_txt_3 {\n      font-weight: 400;\n      line-height: 1.8;\n    }\n\n    @media print,\n    screen and (max-width: 881px) {\n      .message_container {\n        display: block;\n      }\n\n      .box_title,\n      .box_title_txt {\n        width: 100%;\n      }\n\n      .box_title_txt_1,\n      .box_title_txt_2,\n      .box_title_txt_3 {\n        text-align: justify;\n        letter-spacing: 1px;\n      }\n    }\n\n    @media print,\n    screen and (max-width: 470px) {\n      .box_title {\n        font-size: clamp(3rem, 8.6vw, 4rem);\n      }\n\n      .box_title_txt_1 {\n        font-size: clamp(2rem, 6.4vw, 3rem);\n      }\n\n      .box_title_txt_2 {\n        font-size: clamp(1.6rem, 4.3vw, 2rem);\n      }\n\n      .box_title_txt_3 {\n        line-height: 1.5;\n      }\n    }\n  </style>\n\n  <!-- Point -->\n  <div class=\"gray_bg\">\n    <div class=\"about_point_container\">\n      <div style=\"text-align: center;\">\n        <img src=\"/images/about_yoshida_01-1.jpg\" alt=\"\">\n      </div>\n      <div class=\"about_point_item\">\n        <div class=\"point_img_box\">\n          <img src=\"/images/about_yoshida_01-2.png\" alt=\"\">\n        </div>\n        <div class=\"point_txt_box\">\n          <p class=\"txt14 point_item_1\"><span style=\"color: #0069C7;\">Point</span></p>\n          <p class=\"txt20 point_item_2\">紙媒体からデジタルまでトータルサポート</p>\n          <p class=\"txt14 point_item_3\">\n            紙媒体からデジタルまで、印刷会社ならではのノウハウと多彩な実績を活かし、媒体を問わずお客様にとって最適な情報伝達ツールをご提案します。\n            <br>\n            より良いものを目指す向上心と発想力でお客様の要望を超えた新しい価値を創造します。\n            <br>\n            お客様にとって最適な情報発信の在り方やカタチを<span\n              style=\"color: #0069C7; font-weight: 700;\">二つのソウゾウリョク（想像力／創造力）</span>でご提案し、運営・進行管理まで、お客様の業務をYPGの<span\n              style=\"color: #0069C7; font-weight: 700;\">総合力</span>でトータルサポートします。\n          </p>\n        </div>\n      </div>\n      <div class=\"col3_box\">\n        <div class=\"col3_box_item\">\n          <p class=\"gradation_circle\">創造力</p>\n          <p class=\"col3_box_item_txt txt14\">多彩なデザインと精度の高い校正によりお客様のご要望に対応します。</p>\n        </div>\n        <div class=\"col3_box_item\">\n          <p class=\"gradation_circle\">想像力</p>\n          <p class=\"col3_box_item_txt txt14\">お客様の要望を伺い、印刷の枠に捉われず、 最適な情報伝達方法を具体化します。</p>\n        </div>\n        <div class=\"col3_box_item\">\n          <p class=\"gradation_circle\">総合力</p>\n          <p class=\"col3_box_item_txt txt14\">2023年9月より、グループ4社体制を始動。それぞれの特長を生かし、多様化するお客様のニーズに対応いたします。</p>\n        </div>\n      </div>\n    </div>\n  </div>\n  <div class=\"gray_bg\">\n    <div class=\"about_point_container\">\n      <div style=\"text-align: center;\">\n        <img src=\"/images/about_yoshida_02-1.jpg\" alt=\"\">\n      </div>\n      <div class=\"about_point_item\">\n        <div class=\"point_img_box\">\n          <img src=\"/images/about_yoshida_02-2.png\" alt=\"\">\n        </div>\n        <div class=\"point_txt_box\">\n          <p class=\"txt14 point_item_1\"><span style=\"color: #0069C7;\">Point</span></p>\n          <p class=\"txt20 point_item_2\">徹底した品質管理</p>\n          <p class=\"txt14 point_item_3\">\n            「最高の印刷物」とは、品質・コスト・パフォーマンス、すべての面でお客様にご満足いただける印刷物のことであると捉えています。ヨシダ印刷では、高品質を実現するため、社員ひとりひとりが日々研鑽を積むとともに、印刷設備の整備、徹底した管理体制の構築を行っています。また、機動力を高めることで、迅速かつ柔軟な対応ができる社内体制を確立しています。具体的には、ヨシダ印刷独自の品質マネジメントシステムの構築、情報セキュリティマネジメントシステムISO27001の認証取得、環境対応として水なし印刷の導入、カーボンオフセットの取り組み、ノンVOCインキの使用、FSC認証の取得などを実現しています。\n          </p>\n        </div>\n      </div>\n      <div class=\"col3_box\">\n        <div class=\"col3_box_item\">\n          <div style=\"margin: 0 auto;\">\n            <p class=\"col3_box_item_txt txt14 icon_circle\">QMS（品質マネジメントシステム）</p>\n            <p class=\"col3_box_item_txt txt14 icon_circle\">Japan Color標準印刷認証取得）</p>\n            <img src=\"/images/about_yoshida_logo_japancolor.svg\" alt=\"JapanColor標準印刷認証\">\n          </div>\n          <div class=\"col1_box\">\n            <a href=\"https://www.ypg.jp/effort/quality_management.html\">詳細はこちら</a>\n          </div>\n        </div>\n        <div class=\"col3_box_item\">\n          <div style=\"margin: 0 auto;\">\n            <p class=\"col3_box_item_txt txt14 icon_circle\">ISO27001:2013認証取得<br>（情報セキュリティマネジメントシステム）</p>\n            <img src=\"../images/quality_logo_ISO27001_2x.png\" alt=\"ISO27001\" style=\"border:solid 1px #ddd;\">\n          </div>\n          <div class=\"col1_box\">\n            <a href=\"https://www.ypg.jp/effort/information_security.html\">詳細はこちら</a>\n          </div>\n        </div>\n        <div class=\"col3_box_item\">\n          <div style=\"margin: 0 auto;\">\n            <p class=\"col3_box_item_txt txt14 icon_circle\">グリーンプリンティング認証工場</p>\n            <p class=\"col3_box_item_txt txt14 icon_circle\">水なしECO－UV印刷</p>\n            <p class=\"col3_box_item_txt txt14 icon_circle\">カーボンオフセット印刷</p>\n            <p class=\"col3_box_item_txt txt14 icon_circle\">ベジタブルインキ</p>\n            <p class=\"col3_box_item_txt txt14 icon_circle\">ノンＶＯＣインキ</p>\n            <p class=\"col3_box_item_txt txt14 icon_circle\">FSC/CoC認証</p>\n          </div>\n          <div class=\"col1_box\">\n            <a href=\"https://www.ypg.jp/effort/environmental_protection.html\">詳細はこちら</a>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n  <style>\n    .gray_bg {\n      background-color: #F2F2F2;\n      padding: 8em 1em;\n    }\n\n    @media print,\n    screen and (max-width: 750px) {\n      .gray_bg {\n        padding: 6em 1em;\n      }\n    }\n\n    .about_point_item,\n    .col3_box {\n      display: flex;\n      max-width: 1110px;\n      margin: 0 auto;\n      gap: 6%;\n    }\n\n    .col3_box {\n      background: #FFF;\n      padding: 3em 5em;\n    }\n\n    .about_point_item {\n      padding-top: 50px;\n      padding-bottom: 25px;\n      gap: 85px;\n      align-items: center;\n    }\n\n    .col3_box_item {\n      width: 33.3%;\n      display: flex;\n      flex-direction: column;\n      justify-content: space-between;\n    }\n\n    .gradation_circle {\n      text-align: center;\n      border-radius: 50%;\n      height: 100px;\n      width: 1