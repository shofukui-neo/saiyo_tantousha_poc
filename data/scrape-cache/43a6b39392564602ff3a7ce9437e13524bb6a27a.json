/button>\r\n</div><!-- child-button -->\r\n</div><!-- child-grid -->\r\n</div><!-- inner -->\r\n</div><!-- header-globalLink-child -->\r\n\r\n</li>\r\n\r\n</ul>\r\n</div><!-- header-links-bottom -->\r\n<div class=\"header-links-close\">\r\n<button class=\"header-links-close-buttton\">閉じる<span></span></button>\r\n</div>\r\n</div><!-- header-links -->\r\n</div><!-- toggle-menu -->\r\n</div><!-- header-main -->\r\n</div><!-- header-inner -->\r\n<span id=\"header-bg\"></span>\r\n</header>\r\n  <section class=\"section template-area breadcrumb-section\">\r\n    <div class=\"section-inner\">\r\n\r\n<ol class=\"breadcrumb-list\">\r\n\r\n<li><a href=\"/jp/\">HOME</a></li>\r\n\r\n<li><a href=\"/jp/corporation/index.html\">私たちについて</a></li>\r\n\r\n<li>社長挨拶</li>\r\n\r\n</ol>\r\n\r\n    </div>\r\n  </section>\r\n  <section class=\"section template-area\">\r\n    <div class=\"page-heading-block \">\r\n\r\n<div class=\"image\">\r\n<picture>\r\n<source media=\"(max-width: 767px)\" srcset=\"/jp/corporation/uoavdk0000000917-img/uoavdk000000092r.jpg\">\r\n<img src=\"/jp/corporation/uoavdk0000000917-img/uoavdk000000092q.jpg\" alt=\"\">\r\n</picture>\r\n\r\n</div>\r\n\r\n\r\n      <div class=\"heading\">\r\n        \r\n        <h1>\r\n          社長挨拶\r\n        </h1>\r\n\r\n     </div>\r\n\r\n    </div>\r\n  </section>\r\n  <div id=\"contents\">\r\n    <main id=\"main\" role=\"main\">\r\n      <section class=\"section component-area\">\r\n        <div class=\"section-inner\">\r\n            <div class=\"column-box-wrapper\">\r\n<div class=\"column-box col2-ratio2to1 \">\r\n\r\n<div>\r\n\r\n<p class=\"fz-l  mb-middle\">　当社は“人々の安心・安全を支え、平和で豊かな社会づくりに貢献する”ことを経営理念に掲げ、『お客様の測りたい』を実現する技術集団であり続けることを目指しております。<br>\nそれら実現のために、気象・水文、航海、航空・燃焼、防衛の各事業において、当社がこれまで培ってきた技術をベースに創意工夫を重ね、企業の枠を越えた共創による新たな価値を提供させて頂きます。<br>\nこのことは、将来予測が困難だと言われる今の時代にあっても、決して揺るぐことのない確かな軸でありお客様への約束です。<br>\nこれからも、高い品質と高い信頼性をもった製品・サービス、そしてソリューションを提供し続けるために、私たちYDKテクノロジーズは日々前へ前へと邁進してまいります。<br>\n今後ともご支援賜りますよう何卒よろしくお願い申し上げます。</p>\r\n\r\n