>募集</th>\r\n<td>募集中</td>\r\n</tr>\r\n\r\n<!--\r\n-->\r\n\r\n<tr>\r\n<span class=\"font-bold\"><td colspan=\"6\">お問合せ先は、下記までどうぞ</td></span></tr><tr>\r\n<span class=\"font-bold\"><td colspan=\"6\"><span class=\"font-bold\"></span>TEL.0973-23-5930 (平日10:00~17:00) 明林堂書店城町店　担当：店長</span></td></tr></span>\r\n</tr>\r\n</table>\n\n\n\n\n\n\n<!-- End of include : source=themes/system/include/column.html -->\n\n                        \n                        \n                        \n                        \n                        <!-- Start of include : source=themes/system/admin/entry/action.html -->\n\n\n<!-- End of include : source=themes/system/admin/entry/action.html -->\n\n                    </div>\n                    <!-- /entry -->\n                </div>\n                <!-- /entryWrapper -->\n                \n                <!-- 1記事▲▲ -->\n                \n                \n            </div>\n\t\t<!-- InstanceEndEditable -->\n        </div>\n        <!--　right_content --->\n    \n    </div>\n    <!--　content --->\n\n\t<!--　footer --->\n\t<!-- Start of include : source=themes/main/include/footer.html -->\n<div id=\"footer\" class=\"clearfix\">\n    <div class=\"footerWrap\">\n        <div class=\"profile\">\n            <h2>株式会社 明林堂書店</h2>\n            <p>〒760-0064<br>香川県高松市朝日新町2番19号<br>宮脇書店内<br>TEL / 087-851-3736</p>\n        </div>\n        <div class=\"site_map\">\n        \t<ul>\n            \t<li><a href=\"http://www.meirindo.co.jp//\">トップページ</a></li>\n                <li><a href=\"http://www.meirindo.co.jp/bestseller/\">ベストセラー</a></li>\n                <li><a href=\"http://www.meirindo.co.jp/channel/\">チャンネル</a></li>\n                <li><a href=\"http://www.meirindo.co.jp/company/\">会社概要</a></li>\n                <li><a href=\"http://www.meirindo.co.jp/recruit/\">採用情報</a></li>\n            </ul>\n          \t<ul class=\"store\">\n               \t<li><a href=\"http://www.meirindo.co.jp/store/\">店舗一覧</a>\n                <ul>\n                \t<li