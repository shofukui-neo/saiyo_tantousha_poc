enu\" data-nav=\"04\">\n                            <div class=\"flex\">\n                                <div class=\"left\">\n                                    <a href=\"../recruit/index_top.html\"><img class=\"fit\" src=\"../assets/img/common/jp/submenu_btn_04.jpg\"></a>\n                                </div>\n                                <div class=\"right\">\n                                    <div class=\"flex col1\">\n                                        <div class=\"col\">\n                                            <ul>\n                                                <li><a class=\"hover--underline type--black blank\" href=\"https://www.sc-aero.co.jp/recruit/\" target=\"_blank\">新卒採用</a></li>\n                                                <li><a class=\"hover--underline type--black\" href=\"../recruit/career.html\">キャリア採用</a></li>\n                                            </ul>\n                                        </div>\n                                    </div>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </nav>\n\n            <div id=\"menu\">\n                <a id=\"menu-btn--close\"><span class=\"icon\"></span></a>\n                <div id=\"menu-list\">\n                    <nav>\n                        <ul>\n                            <li><a href=\"../\">TOP<div class=\"icon--arrow black\"></div></a></li>\n                            <li><a href=\"../message/\">ごあいさつ<div class=\"icon--arrow black\"></div></a></li>\n                            <li><a href=\"../company/\">企業情報<div class=\"icon--arrow black\"></div></a></li>\n                            <li><a href=\"../business/\">事業紹介<div class=\"icon--arrow black\"></div></a></li>\n                            <li><a href=\"../products/\">取扱商品<div class=\"icon--arrow black\"></div></a></li>\n                            <li><a href=\"../recruit/index_top.html\">採用情報<div class=\"icon--arrow black\"></div></a></li>\n                        </ul>\n                    </nav>\n                </div>\n            </div>\n            \n\n            <div id=\"mv\">\n                <div id=\"h1\"><h1>ごあいさつ</h1></div>\n            </div>\n\n\n\n            <main>\n                <article id=\"main-body\">\n                    <section>\n                        <div class=\"inner1000\">\n                            <div class=\"ttl\">\n                                <p>\n                                    革新と改革を生み出す企業として、<br>\n                                    より豊かな社会の実現を目指していきます\n                                </p>\n                            </div>\n\n                            <div class=\"flex\">\n                                <div class=\"col\">\n                                    <p>\n                                        当社は、1982年に航空宇宙・防衛事業に精通した専門家集団として設立されました。以来、変化を先取りして新たな価値を提供することをモットーに、お客様やパートナーの皆様とのビジネス活動を通じて、国の安全と平和への貢献、さらには豊かな社会の実現を目指して邁進してまいりました。<br>\n                                        国内外における環境の変化はスピードを増しており、これまでにない対応が求められています。かかる環境下において、住友商事グループのもつ総合力を生かし、最先進技術の導入や、安定したサプライチェーンの確保など多岐にわたる機能を発揮して、社会の一員としての役割を果たしてまいります。<br>\n                                        健全な事業活動を通じて、ステークホルダーの皆様の経済的、精神的な豊かさと夢を実現することは当社経営のミッションです。「住友の事業精神」の真髄である「信用を重んじ確実を旨とする」ことを貫き、主体性と創造性を持って、改革と革新を不断に生み出す企業を目指してまいります。\n                                    </p>\n\n                                    <div class=\"sign\">\n                                        <p>代表取締役社長　上野 智規</p>\n                                    </div>\n                                </div>\n                                <div class=\"col\">\n                                    <div class=\"ph\"><img class=\"fit\" src=\"../assets/img/message/top_p_01.jpg\"></div>\n                                </div>\n                            </div>\n                        </div>\n                    </section>\n                </article>\n            