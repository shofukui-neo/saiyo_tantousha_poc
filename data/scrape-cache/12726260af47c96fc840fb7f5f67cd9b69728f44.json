'https://shibundo.jp/wp-content/plugins/contact-form-7/includes/css/styles.css?ver=5.5.1' type='text/css' media='all' />\n<script type='text/javascript' src='https://shibundo.jp/wp-includes/js/jquery/jquery.min.js?ver=3.6.1' id='jquery-core-js'></script>\n<script type='text/javascript' src='https://shibundo.jp/wp-includes/js/jquery/jquery-migrate.min.js?ver=3.3.2' id='jquery-migrate-js'></script>\n<link rel=\"https://api.w.org/\" href=\"https://shibundo.jp/wp-json/\" /><meta name=\"generator\" content=\"WordPress 6.1.10\" />\n<link rel='shortlink' href='https://shibundo.jp/?p=1535' />\n<link rel=\"alternate\" type=\"application/json+oembed\" href=\"https://shibundo.jp/wp-json/oembed/1.0/embed?url=https%3A%2F%2Fshibundo.jp%2Frecruit%2Fkeibiin%2F\" />\n<link rel=\"alternate\" type=\"text/xml+oembed\" href=\"https://shibundo.jp/wp-json/oembed/1.0/embed?url=https%3A%2F%2Fshibundo.jp%2Frecruit%2Fkeibiin%2F&#038;format=xml\" />\n<meta name=\"og:title\" property=\"og:title\" content=\"交通誘導員【アルバイト・パート】\" />\n<meta name=\"og:description\" property=\"og:description\" content=\"\" />\n<meta name=\"og:type\" property=\"og:type\" content=\"article\" />\n<meta name=\"og:url\" property=\"og:url\" content=\"https://shibundo.jp/recruit/keibiin/\" />\n<meta name=\"og:image\" property=\"og:image\" content=\"https://shibundo.jp/wp-content/uploads/2023/09/keibi08.jpg\" />\n<meta name=\"og:image:secure_url\" property=\"og:image:secure_url\" content=\"https://shibundo.jp/wp-content/uploads/2023/09/keibi08.jpg\" />\n<meta name=\"og:image:width\" property=\"og:image:width\" content=\"640\" /> \n<meta name=\"og:image:height\" property=\"og:image:height\" content=\"427\" /> \n<meta name=\"og:site_name\" property=\"og:site_name\" content=\"斯文堂株式会社｜鹿児島の印刷会社・TJカゴシマ\" />\n<meta name=\"twitter:card\" content=\"summary_large_image\" />\n<meta name=\"twitter:site\" content=\"\" />\n<meta name=\"og:locale\" property=\"og:locale\" content=\"ja_JP\" />\n</head>\n<body>\n    <header>\n        <div>\n   