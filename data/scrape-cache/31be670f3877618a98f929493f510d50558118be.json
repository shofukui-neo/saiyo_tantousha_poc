graduate/img/common/Instagram_color.svg\" alt=\"Instagram\" width=\"44\" height=\"44\" />\n              <p class=\"instagram_title_top\">新卒採用<br>アカウント</p>\n              </div></a>\n            </li>\n          </ul>\n          <div class=\"recruit_menu\">\n            <span>RECRUIT</span>\n            <ul class=\"recruit_links\">\n                <li><a href=\"https://job.mynavi.jp/27/pc/search/corp69194/outline.html\" target=\"_blank\">マイナビ2027</a></li>\n                <li><a href=\"https://job.mynavi.jp/28/pc/search/corp69194/outline.html\" target=\"_blank\">マイナビ2028</a></li>\n                <li><a href=\"https://www.onecareer.jp/companies/4098\" target=\"_blank\">ONE CAREER</a></li>\n            </ul>\n          </div>\n          <div class=\"fullnavi_btn\" id=\"menu_btn\"><span></span><span></span><span></span></div>\n        </div>\n\n        <div class=\"fullnavi headernav\">\n          <div class=\"fullnavi_scroll\">\n            <ul class=\"fullnavi_inner\">\n              <li><a href=\"/saiyo/newgraduate/\">トップページ</a></li>\n              <li><a href=\"/saiyo/newgraduate/message/\">あなたへのメッセージ</a></li>\n              <li><a href=\"/saiyo/newgraduate/about/\">イオンリテールとは</a></li>\n              <li><a href=\"/saiyo/newgraduate/dna/\">イオンリテールのDNA</a></li>\n              <li><a href=\"/saiyo/newgraduate/challenge/\">イオンリテールの挑戦</a></li>\n              <li><a href=\"/saiyo/newgraduate/people/\">社員紹介</a></li>\n              <li><a href=\"/saiyo/newgraduate/job/\">職種紹介</a></li>\n              <li><a href=\"/saiyo/newgraduate/specialmovie/\">スペシャルムービー</a></li>\n              <li><a href=\"/saiyo/newgraduate/recruit/\">採用情報</a></li>\n            </ul>\n            <div class=\"sp_d recruit_section\">\n              <!-- <div class=\"recruit_block lastyear\">\n                <div>\n                  <a href=\"https://aeonretail.snar.jp/login.aspx\" target=\"_blank\"><img src=\"/saiyo/newgraduate/img/common/2025mypage.png\" alt=\"MY PAGE 2025\" width=\"636\" height=\"126\" /></a>\n                </div>\n              </div> -->\n              <div class=\"recruit_block\">\n                <div>\n                  <a href=\"https://job.axol.jp/bx/s/aeonretail_27/mypage/login\" target=\"_blank\"><img src=\"/saiyo/newgraduate/img/common/2027mypage.png\" alt=\"MY PAGE 2027\" width=\"636\" height=\"126\" /></a>\n                </div>\n                <div>\n                  <a href=\"https://job.axol.jp/bx/s/aeonretail_27/entry/\" target=\"_blank\"><img src=\"/saiyo/newgraduate/img/common/2027entry.png\" alt=\"2027 ENTRY\" width=\"636\" height=\"126\"/></a>\n                </div>\n                <div>\n                  <a href=\"https://axol.jp/zw/s/aeonretail_28/mypage/login\" target=\"_blank\"><img src=\"/saiyo/newgraduate/img/common/2028mypage.png\" alt=\"MY PAGE 2028\" width=\"636\" height=\"126\" /></a>\n                </div>\n                <div>\n                  <a href=\"https://axol.jp/zw/s/aeonretail_28/entry/\" target=\"_blank\"><img src=\"/saiyo/newgraduate/img/common/2028entry.png\" alt=\"2028 ENTRY\" width=\"636\" height=\"126\"/></a>\n                </div>\n              </div>\n              <div class=\"recruit2025\">\n                <div>\n                  <span>RECRUIT</span>\n                  <p>\n                    <a href=\"https://job.mynavi.jp/27/pc/search/corp69194/outline.html\" target=\"_blank\">マイナビ2027<i></i></a>\n                  </p>\n                  <p>\n                    <a href=\"https://www.onecareer.jp/companies/4098\" target=\"_blank\">ONE CAREER<i></i></a>\n                  </p>\n                  <p>\n                    <a href=\"https://job.mynavi.jp/28/pc/search/corp69194/outline.html\" target=\"_blank\">マイナビ2028<i></i></a>\n                  </p>\n                </div>\n              </div>\n              <div class=\"recruit_sns\">\n                <a href=\"https://www.instagram.com/aeonretail_recruit/\" target=\"_blank\">\n                <div class=\"instagram_wrap bottom\">\n                  <img src=\"/saiyo/newgraduate/img/common/Instagram_color.svg\" alt=\"Instagram\" width=\"44\" height=\"44\" />\n                  <p class=\"instagram_title\">新卒採用アカウント</p>\n                </div></a>\n              </div>\n            </div>\n          </div>\n        </div>\n      </section>\n    </header>\n    <div class=\"main_contents\">\n      <div class=\"main_contents_inner\">\n        <section class=\"section top_kv\">\n          <h2 class=\"move_elm elm_tit js-action slideup\">未来の「お買物」は、あなたがつくる。</h2>\n\n          <picture class=\"move_elm elm_basket js-action slideup\">\n            <source media=\"(max-width: 768px)\" srcset=\"/saiyo/newgraduate/img/message/sp/img-basket.png\"\n              width=\"368\" height=\"412\">\n            <img src=\"/saiyo/newgraduate/img/message/img-basket.png\" alt=\"\" width=\"427\" height=\"958\">\n          </picture>\n\n          <picture class=\"move_elm elm_people_1 js-action slideup\">\n            <source media=\"(max-width: 768px)\" srcset=\"/saiyo/newgraduate/img/message/sp/img-people_1.png\"\n              width=\"175\" height=\"179\">\n            <img src=\"/saiyo/newgraduate/img/message/img-people_1.png\" alt=\"\" width=\"193\" height=\"207\">\n          </picture>\n\n          <div>\n            <span class=\"move_elm elm_cloud_1 js-action slideup\"></span>\n          </div>\n        </section>\n\n        <div class=\"page_contents\">\n          <div class=\"section section_1\">\n            <div class=\"js-action slideup message-text message1\">\n              <p class=\"lead_txt\">日本で初めて24色展開をした、<br>\n                カラーランドセルをはじめとする<br>\n                プライベートブランドの開発。<br>\n                AIの導入による接客管理や、割引率の決定。<br>\n                電子マネー「WAON」や、<br>\n                待たないレジ「レジゴー」の導入など、<br>\n                イオンリテールは時代に先駆けて、<br>\n                日本の新しいお買物体験を<br class=\"smt\">生み出してきました。</p>\n            </div>\n            <div>\n              <picture class=\"move_elm elm_cardreader js-action slideup\">\n                <source media=\"(max-width: 768px)\" srcset=\"/saiyo/newgraduate/img/message/sp/img-cardreader.png\"\n                  width=\"256\" height=\"194\">\n                <img src=\"/saiyo/newgraduate/img/message/img-cardreader.png\" alt=\"\" width=\"284\" height=\"215\"\n                  loading=\"lazy\">\n              </picture>\n              <picture class=\"move_elm elm_waoncard js-action slideup\">\n                <source media=\"(max-width: 768px)\" srcset=\"/saiyo/newgraduate/img/message/sp/img-waoncard.png\"\n                  width=\"190\" height=\"235\">\n                <img src=\"/saiyo/newgraduate/img/message/img-waoncard.png\" alt=\"\" width=\"215\" height=\"266\"\n                  loading=\"lazy\">\n              </picture>\n              <picture class=\"move_elm elm_randsel js-action slideup\">\n                <source media=\"(max-width: 768px)\" srcset=\"/saiyo/newgraduate/img/message/sp/img-randsel.png\"\n                  width=\"291\" height=\"307\">\n                <img src=\"/saiyo/newgraduate/img/message/img-randsel.png\" alt=\"\" width=\"324\" height=\"343\"\n                  loading=\"lazy\">\n              </picture>\n              <picture class=\"move_elm elm_people_2 js-action slideup\">\n                <source media=\"(max-width: 768px)\" srcset=\"/saiyo/newgraduate/img/message/sp/img-people_2.png\"\n                  width=\"81\" height=\"117\">\n                <img src=\"/saiyo/newgraduate/img/message/img-people_2.png\" alt=\"\" width=\"90\" height=\"130\"\n                  loading=\"lazy\">\n              </picture>\n              <picture class=\"move_elm elm_people_3 js-action slideup\">\n                <source media=\"(max-width: 768px)\" srcset=\"/saiyo/newgraduate/img/message/sp/img-people_3.png\"\n                  width=\"67\" height=\"108\">\n                <img src=\"/saiyo/newgraduate/img/message/img-people_3.png\" alt=\"\" width=\"75\" height=\"121\"\n                  loading=\"lazy\">\n              </picture>\n            </div>\n            <div>\n              <span class=\"move_elm elm_cloud_2 js-action slideup\"></span>\n            </div>\n          </div>\n\n          <div class=\"section section_2\">\n            <div class=\"js-action slideup message-text message2\">\n              <p class=\"lead_txt\">どんなにすごいアイデアも、<br>\n                はじまりは、個人の想いです。<br>\n                だからこそ、イオンリテールは<br>\n                新しい挑戦を応援する風土を<br class=\"smt\">大切にしてきました。<br>\n                店舗の運営だけではなく、<br class=\"smt\">商品開発や店舗開発、<br>\n                マーケティング、<br class=\"smt\">デジタルプロモーションまで。<br>\n                手を挙げれば、幅広いフィールドで<br>\n                自分のキャリアを切り拓くことができます。</p>\n            </div>\n            <div>\n              <picture class=\"move_elm elm_dog js-action slideup\">\n                <source media=\"(max-width: 768px)\" srcset=\"/saiyo/newgraduate/img/message/sp/img-dog.png\"\n                  width=\"270\" height=\"252\">\n                <img src=\"/saiyo/newgraduate/img/message/img-dog.png\" alt=\"\" width=\"318\" height=\"297\" loading=\"lazy\">\n              </picture>\n              <picture class=\"move_elm elm_monitor js-action slideup\">\n                <source media=\"(max-width: 768px)\" srcset=\"/saiyo/newgraduate/img/message/sp/img-monitor.png\"\n                  width=\"357\" height=\"532\">\n                <img src=\"/saiyo/newgraduate/img/message/img-monitor.png\" alt=\"\" width=\"360\" height=\"537\"\n                  loading=\"lazy\">\n              </picture>\n              <picture class=\"move_elm elm_spray js-action slideup\">\n                <source media=\"(max-width: 768px)\" srcset=\"/saiyo/newgraduate/img/message/sp/img-spray.png\"\n                  width=\"162\" height=\"209\">\n                <img src=\"/saiyo/newgraduate/img/message/img-spray.png\" alt=\"\" width=\"208\" height=\"268\" loading=\"lazy\">\n              </picture>\n              <picture class=\"move_elm elm_people_4 js-action slideup\">\n                <source media=\"(max-width: 768px)\" srcset=\"/saiyo/newgraduate/img/message/sp/img-people_4.png\"\n                  width=\"104\" height=\"126\">\n                <img src=\"/saiyo/newgraduate/img/message/img-people_4.png\" alt=\"\" width=\"116\" height=\"140\"\n                  loading=\"lazy\">\n              </picture>\n              <picture class=\"move_elm elm_people_5 js-action slideup\">\n                <source media=\"(max-width: 768px)\" srcset=\"/saiyo/newgraduate/img/message/sp/img-people_5.png\"\n                  width=\"75\" height=\"115\">\n                <img src=\"/saiyo/newgraduate/img/message/img-people_5.png\" alt=\"\" width=\"83\" height=\"128\"\n                  loading=\"lazy\">\n              </picture>\n              <picture class=\"move_elm elm_coffeecup js-action slideup\">\n                <source media=\"(max-width: 768px)\" srcset=\"/saiyo/newgraduate/img/message/sp/img-coffeecup.png\"\n                  width=\"177\" height=\"176\">\n                <img src=\"/saiyo/newgraduate/img/message/img-coffeecup.png\" alt=\"\" width=\"202\" height=\"201\"\n                  loading=\"lazy\">\n              </picture>\n              <picture class=\"move_elm elm_block js-action slideup\">\n                <source media=\"(max-width: 768px)\" srcset=\"/saiyo/newgraduate/img/message/sp/img-block.png\"\n                  width=\"150\" height=\"164\">\n                <img src=\"/saiyo/newgraduate/img/message/img-block.png\" alt=\"\" width=\"202\" height=\"201\" loading=\"lazy\">\n              </picture>\n              <picture class=\"move_elm elm_pot js-action slideup\">\n                <source media=\"(max-width: 768px)\" srcset=\"/saiyo/newgraduate/img/message/sp/img-pot.png\"\n                  width=\"344\" height=\"344\">\n                <img src=\"/saiyo/newgraduate/img/message/img-pot.png\" alt=\"\" width=\"409\" height=\"409\" loading=\"lazy\">\n              </picture>\n            </div>\n            <div>\n              <span class=\"move_elm elm_cloud_3 js-action slideup\"></span>\n              <span class=\"move_elm elm_cloud_5 js-action slideup\"></span>\n            </div>\n          </div>\n\n          <div class=\"section section_3\">\n            <div class=\"js-action slideup message-text message3\">\n              <p class=\"lead_txt\">どんな品揃えにすると、<br class=\"smt\">うれしいだろう。<br>\n                こんな商品があったら、<br class=\"smt\">喜んでくれるかな。<br>\n                街の人びとが喜ぶ顔を想像し、<br class=\"smt\">その街の笑顔をふやしていく。 <br>\n                お客さまのたくさんの声が、<br class=\"smt\">いつもそばにある。<br>\n                それこそが、私たちのアドバンテージ。<br><br>\n                小売業のリーディングカンパニーだからこそ、<br>\n                新しいお買物体験を<br class=\"smt\">生み出す挑戦ができるのです。<br>\n                さあ、想像するだけでワクワクするような、<br>\n                笑顔あふれる未来のお買物体験をつくりましょう。</p>\n            </div>\n            <div>\n              <picture class=\"move_elm elm_cart js-action slideup\">\n                <source media=\"(max-width: 768px)\" srcset=\"/saiyo/newgraduate/img/message/sp/img-cart.png\"\n                  width=\"524\" height=\"428\">\n                <img src=\"/saiyo/newgraduate/img/message/img-cart.png\" alt=\"\" width=\"486\" height=\"397\" loading=\"lazy\">\n              </picture>\n              <picture class=\"move_elm elm_carrot js-action slideup\">\n                <source media=\"(max-width: 768px)\" srcset=\"/saiyo/newgraduate/img/message/sp/img-carrot.png\"\n                  width=\"180\" height=\"128\">\n                <img src=\"/saiyo/newgraduate/img/message/img-carrot.png\" alt=\"\" width=\"200\" height=\"142\" loading=\"lazy\">\n              </picture>\n              <picture class=\"move_elm elm_cauliflower js-action slideup\">\n                <source media=\"(max-width: 768px)\" srcset=\"/saiyo/newgraduate/img/message/sp/img-cauliflower.png\"\n                  width=\"224\" height=\"179\">\n                <img src=\"/saiyo/newgraduate/img/message/img-cauliflower.png\" alt=\"\" width=\"294\" heig