{"url":"https://www.hitachi-hpm.co.jp/recruit/newgraduate/job/index.html","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n<head>\n<!-- Google Tag Manager -->\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n})(window,document,'script','dataLayer','GTM-M9FCJQP');</script>\n<!-- End Google Tag Manager -->\n<meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0, user-scalable=no, minimum-scale=1.0, maximum-scale=1.0\">\n<meta name=\"format-detection\" content=\"telephone=no\">\n<meta name=\"author\" content=\"Hitachi Plant Mechanics Co., Ltd.\">\n<meta name=\"robots\" content=\"index, follow\">\n<meta name=\"keywords\" content=\"日立プラントメカニクス,日立グループ,採用,採用情報,クレーン,産業用クレーン\">\n<meta name=\"description\" content=\"クレーンの製作から保守・メンテナンスまで一貫したビジネスを展開する株式会社 日立プラントメカニクスの仕事風景です。\">\n<title>仕事風景：株式会社 日立プラントメカニクス</title>\n<link rel=\"index\" href=\"http://www.hitachi-hpm.co.jp/\" title=\"ホーム\">\n<link rel=\"stylesheet\" type=\"text/css\" media=\"screen,print\" href=\"/css/jp/r1/common.css\">\n<link rel=\"stylesheet\" type=\"text/css\" media=\"screen,print\" href=\"/css/jp/r1/responsive.css\">\n<link rel=\"stylesheet\" type=\"text/css\" media=\"screen,print\" href=\"/css/jp/r1/wide.css\">\n<link rel=\"stylesheet\" type=\"text/css\" media=\"screen,print\" href=\"/css/jp/r1/common2.css\">\n<link rel=\"stylesheet\" type=\"text/css\" media=\"print\" href=\"/css/jp/r1/print.css\">\n<link rel=\"stylesheet\" type=\"text/css\" media=\"screen,print\" href=\"/recruit/css/magnific-popup.css\">\n<link rel=\"stylesheet\" type=\"text/css\" media=\"screen,print\" href=\"/recruit/css/recruit.css\">\n<link rel=\"stylesheet\" type=\"text/css\" media=\"print\" href=\"/recruit/css/recruit_print.css\">\n<script type=\"text/javascript\" src=\"/js/lib/jquery.js\"></script>\n<script type=\"text/javascript\" charset=\"Shift_JIS\" src=\"/js/jp/r1/common.js\"></script>\n<script type=\"text/javascript\" charset=\"Shift_JIS\" src=\"/js/jp/r1/responsive.js\"></script>\n<script type=\"text/javascript\" charset=\"Shift_JIS\" src=\"/js/jp/r1/wide.js\"></script>\n<script type=\"text/javascript\" charset=\"Shift_JIS\" src=\"/js/jp/r1/common2.js\"></script>\n<script type=\"text/javascript\" src=\"https://module.hitachi.com/search/js/sug.js#sv=//mf2aps06.marsflag.com/hitachi__RGN_JAPAN__result_00\"></script>\n<script type=\"text/javascript\" src=\"/recruit/js/jquery.rwdImageMaps.min.js\"></script>\n<script type=\"text/javascript\" src=\"/recruit/js/jquery.magnific-popup.min.js\"></script>\n<script type=\"text/javascript\" src=\"/recruit/js/jquery.matchHeight-min.js\"></script>\n<script type=\"text/javascript\" src=\"/recruit/js/recruit.js\"></script>\n<script>\n/* image click responsive\n----------------------------------------------------- */\n$(function(){\n    $('img[usemap]').rwdImageMaps();\n});\n</script>\n</head>\n<body>\n<!-- Google Tag Manager (noscript) -->\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-M9FCJQP\"\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n<!-- End Google Tag Manager (noscript) -->\n\n<p id=\"top\"><a href=\"#body\">ページの本文へ</a></p>\n\n<div id=\"HeaderArea1\">\n\t<div class=\"Container Wide\">\n\n\t\t<div id=\"Statement\"><a href=\"https://www.hitachi.co.jp/\"><img src=\"/image/jp/r1/common2/corp_id.png\" alt=\"Hitachi\"></a></div>\n\n\t\t<div id=\"SupportNavi\" class=\"SupportNaviIconText\">\n\n\t\t\t<a href=\"https://www8.hitachi.co.jp/inquiry/hitachi-hpm/general/form.jsp\" target=\"_blank\"><img src=\"/image/jp/r1/common2/icon_mail.png\" alt=\"お問い合わせ\"><span>お問い合わせ</span></a>\n\n\t\t\t<button type=\"button\" id=\"SupportNaviSearch\" aria-expanded=\"false\" aria-controls=\"SearchFormArea\"><span><img src=\"/image/jp/r1/common2/icon_search.png\" alt=\"検索\"><span>検索</span></span></button>\n\t\t\t<div id=\"SearchFormArea\">\n\t\t\t\t<div>\n\t\t\t\t\t<button class=\"BtnClose\" aria-label=\"閉じる\"></button>\n\t\t\t\t\t<form action=\"https://module.hitachi.com/search/RGN_JAPAN.html\" method=\"get\" accept-charset=\"UTF-8\">\n\t\t\t\t\t\t<input type=\"hidden\" name=\"imgsize\" value=\"3\">\n\t\t\t\t\t\t<input type=\"hidden\" name=\"pagemax\" value=\"10\">\n\t\t\t\t\t\t<div class=\"SearchGroup\">\n\t\t\t\t\t\t\t<input type=\"text\" name=\"q\" size=\"20\" maxlength=\"40\" accesskey=\"s\" title=\"検索キーワード\" placeholder=\"日立グループ全体から検索\" autocomplete=\"off\" class=\"SearchPhrease\" id=\"MF_form_phrase\">\n\t\t\t\t\t\t\t<button class=\"SearchBtn\" type=\"submit\">検索</button>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</form>\n\t\t\t\t</div>\n\t\t\t</div><!--/#SearchFormArea-->\n\t\t</div><!--/#SupportNavi-->\n\n\t\t<button id=\"SpMenuBtn\" aria-label=\"メニュー\">\n\t\t\t<span></span>\n\t\t\t<span></span>\n\t\t\t<span></span>\n\t\t</button>\n\n\t</div><!--/.Container-->\n</div><!--/#HeaderArea1-->\n\n<div id=\"HeaderArea2\">\n\t<div class=\"Container Wide\">\n\t\t<div id=\"SiteID\">\n\t\t\t<a href=\"/index.html\"><span>株式会社 日立プラントメカニクス</span></a>\n\t\t\t<a href=\"/recruit/index.html\"><span>採用情報</span></a>\n\t\t</div>\n\t\t<ul id=\"GlobalNaviMenu\">\n\t\t\t<li><a href=\"/recruit/newgraduate/about.html\">会社概要</a></li>\n\t\t\t<li><a href=\"/recruit/newgraduate/info.html\">福利厚生</a></li>\n\t\t\t<li><a href=\"/recruit/office.html\">事業所紹介</a></li>\n\t\t\t<li class=\"Current\"><a href=\"/recruit/newgraduate/job/index.html\" aria-crrent=\"true\"><strong>仕事風景</strong></a></li>\n\t\t\t<li><a href=\"/recruit/newgraduate/index.html\">新卒採用</a></li>\n\t\t\t<li><a href=\"https://en-gage.net/hpm_careersaiyo/\" target=\"_blank\">経験者採用</a></li>\n\t\t\t<li><a href=\"/recruit/disability/index.html\">障がい者採用</a></li>\n\t\t</ul>\n\t</div><!--/.Container-->\n</div><!--/#HeaderArea2-->\n\n<div id=\"Contents\" class=\"sub-page\">\n\n\t<div class=\"breadcrumb-list\">\n\t\t<div class=\"GridSet\">\n\t\t\t<div class=\"Grid4\">\n\t\t\t\t<ul>\n\t\t\t\t\t<li><a href=\"/recruit/index.html\">採用情報トップページ</a></li>\n\t\t\t\t\t<li><strong>仕事風景</strong></li>\n\t\t\t\t</ul>\n\t\t\t</div>\n\t\t</div>\n\t</div><!-- /.breadcrumb-list -->\n\n\n\t<div class=\"GridSet\">\n\t\t<div class=\"Grid4\">\n\n            <div class=\"contents-width\">\n\n                <div class=\"section-recruit sub-page-layout\" id=\"section-interview-top\">\n\n                    <div class=\"recruit-title-en is-vertical job-vertical\">WORK</div>\n\n                    <div class=\"message-title\">\n                        <h1>WORK<br>SCENE<span>仕事風景</span></h1>\n                    </div><!-- /title-message -->\n\n                </div><!-- /#section-interview-top -->\n\n\t\t\t</div><!-- /.contents-width -->\n\n\n            <div class=\"contents-width contents-section\">\n\n                <div class=\"message-section\">\n                    <h2 class=\"title-second\">事業スキーム</h2>\n                    <p class=\"text-second\">日立プラントメカニクスは、受注、製品開発・設計からアフターサービスまで、製造、販売、サービスが一体となった事業体制。さまざまな部門、職種のプロフェッショナルが連携して一気通貫に製品・サービスを提供できることが大きな強みです。</p>\n                    <div class=\"sp-scroll-box02\">\n                        <p class=\"image-second mt-adjust02 taC\"><img src=\"/recruit/newgraduate/job/image/img_job01.png\" alt=\"図：事業スキーム\" width=\"772\" height=\"653\" usemap=\"#Map\">\n                            <map name=\"Map\">\n                                <area shape=\"rect\" coords=\"167,11,360,90\" href=\"#anc-job01\" class=\"smooth-scroll\" alt=\"営業\">\n                                <area shape=\"rect\" coords=\"366,11,559,90\" href=\"#anc-job02\" class=\"smooth-scroll\" alt=\"フロントエンジニア（営業技術）\">\n                                <area shape=\"rect\" coords=\"167,103,559,183\" href=\"#anc-job03\" class=\"smooth-scroll\" alt=\"設計・開発\">\n                                <area shape=\"rect\" coords=\"167,192,360,229\" href=\"#anc-job04\" class=\"smooth-scroll\" alt=\"資材調達\">\n                                <area shape=\"rect\" coords=\"167,233,360,270\" href=\"#anc-job05\" class=\"smooth-scroll\" alt=\"生産管理\">\n                                <area shape=\"rect\" coords=\"366,192,559,271\" href=\"#anc-job06\" class=\"smooth-scroll\" alt=\"生産技術\">\n                                <area shape=\"rect\" coords=\"167,277,559,329\" href=\"#anc-job07\" class=\"smooth-scroll\" alt=\"品質保証\">\n                                <area shape=\"rect\" coords=\"167,340,559,419\" href=\"#anc-job08\" class=\"smooth-scroll\" alt=\"施工管理\">\n                                <area shape=\"rect\" coords=\"167,482,362,561\" href=\"#anc-job09\" class=\"smooth-scroll\" alt=\"サービス設計\">\n                                <area shape=\"rect\" coords=\"365,482,560,561\" href=\"#anc-job10\" class=\"smooth-scroll\" alt=\"アフターサービス\">\n                                <area shape=\"rect\" coords=\"569,11,767,561\" href=\"#anc-job11\" class=\"smooth-scroll\" alt=\"人事総務/経理財務/社内情報システム/法務/企画\">\n                            </map>\n                        </p>\n                    </div><!-- /.sp-scroll-box02 -->\n                </div><!-- /.message-section -->\n\n                <div class=\"message-section\">\n                    <h2 class=\"title-second\">職種について</h2>\n                    <h3 class=\"title-second04\"><span>営業</span></h3>\n                    <div id=\"anc-job01\" class=\"drop-down-list\"><span class=\"bg-white\">&nbsp;</span>\n                        <div class=\"drop-down-title\">\n                            『営業』\n                            <span class=\"drop-down-category\">技術系・事務系共通</span>\n                        </div><!-- /drop-down-title -->\n                        <div class=\"drop-down-body\">\n                            当社の製品であるクレーンの総合窓口です。お客様の工場などに納めるクレーンの新設販売や、既設の製品のアフターサービスや修理・工事の提案を行います。\n                            <a href=\"/recruit/newgraduate/interview/05.html\" class=\"job-link job-link-blue\"><div class=\"more-general-blue\">この職種の<br class=\"br-adjust01\">先輩インタビューを見る<span></span></div></a>\n                        </div><!-- /drop-down-body -->\n                    </div><!-- /drop-down-list -->\n\n                    <div id=\"anc-job02\" class=\"drop-down-list drop-down-red\"><span class=\"bg-white\">&nbsp;</span>\n                        <div class=\"drop-down-title\">\n                            『フロントエンジニア（営業技術）』\n                            <span class=\"drop-down-category\">技術系</span>\n                        </div><!-- /drop-down-title -->\n                        <div class=\"drop-down-body\">\n                            当社の製品であるクレーンの技術窓口として、販売から製品の納入まで、営業や設計、施工部門と密に連携をとりながら、技術的な問題解決や設計仕様の決定、施工管理などを行います。\n                        </div><!-- /drop-down-body -->\n                    </div><!-- /drop-down-list -->\n                    <p class=\"smooth-page-top\"><a href=\"#top\" class=\"smooth-scroll\">ページTOPへ戻る</a></p>\n                </div><!-- /.message-section -->\n\n                <div class=\"message-section next-block\">\n                    <h3 class=\"title-second04\"><span>設計</span></h3>\n                    <div id=\"anc-job03\" class=\"drop-down-list drop-down-red\"><span class=\"bg-white\">&nbsp;</span>\n                        <div class=\"drop-down-title\">\n                            『設計・開発』\n                            <span class=\"drop-down-category\">技術系</span>\n                        </div><!-- /drop-down-title -->\n                        <div class=\"drop-down-body\">\n                            お客様のニーズを踏まえ製品を企画し、価値を提供していくことが設計・開発を担当するエンジニアの業務です。機械・電気の機器、自動クレーンのソフトウェアの開発から製品化までを担います。\n                            <a href=\"/recruit/newgraduate/interview/01.html\" class=\"job-link\"><div class=\"more-general-pink\">この職種の<br class=\"br-adjust01\">先輩インタビューを見る<span></span></div></a>\n                        </div><!-- /drop-down-body -->\n                    </div><!-- /drop-down-list -->\n                    <p class=\"smooth-page-top\"><a href=\"#top\" class=\"smooth-scroll\">ページTOPへ戻る</a></p>\n                </div><!-- /.message-section -->\n\n                <div class=\"message-section next-block\">\n                    <h3 class=\"title-second04\"><span>生産</span></h3>\n                    <div id=\"anc-job04\" class=\"drop-down-list\"><span class=\"bg-white\">&nbsp;</span>\n                        <div class=\"drop-down-title\">\n                            『資材調達』\n                            <span class=\"drop-down-category\">技術系・事務系共通</span>\n                        </div><!-- /drop-down-title -->\n                        <div class=\"drop-down-body\">\n                            お客様へ提供する製品やサービスに必要な部材を、外部から良いものを早く調達（購入する）することが主な業務であり、その為に、取引先との交渉や社内関連部署との調整などを行う業務です。\n                        </div><!-- /drop-down-body -->\n                    </div><!-- /drop-down-list -->\n\n                    <div id=\"anc-job05\" class=\"drop-down-list\"><span class=\"bg-white\">&nbsp;</span>\n                        <div class=\"drop-down-title\">\n                            『生産管理』\n                            <span class=\"drop-down-category\">技術系・事務系共通</span>\n                        </div><!-- /drop-down-title -->\n                        <div class=\"drop-down-body\">\n                            生産現場における、製造プロセス全体の効率化と最適化の実現をめざし、生産に関わる全ての工程を統括、管理を行う業務です。\n                        </div><!-- /drop-down-body -->\n                    </div><!-- /drop-down-list -->\n\n                    <div id=\"anc-job06\" class=\"drop-down-list drop-down-red\"><span class=\"bg-white\">&nbsp;</span>\n                        <div class=\"drop-down-title\">\n                            『生産技術』\n                            <span class=\"drop-down-category\">技術系</span>\n                        </div><!-- /drop-down-title -->\n                        <div class=\"drop-down-body\">\n                            生産現場において、製品や部品を効率よく生産するための体制を構築する業務です。高度なモノづくり技術と経験をいかし、生産効率の向上、生産設備の維持・最適化を実現します。\n                            <a href=\"/recruit/newgraduate/interview/04.html\" class=\"job-link\"><div class=\"more-general-pink\">この職種の<br class=\"br-adjust01\">先輩インタビューを見る<span></span></div></a>\n                        </div><!-- /drop-down-body -->\n                    </div><!-- /drop-down-list -->\n\n                    <div id=\"anc-job07\" class=\"drop-down-list drop-down-red\"><span class=\"bg-white\">&nbsp;</span>\n                        <div class=\"drop-down-title\">\n                            『品質保証』\n                            <span class=\"drop-down-category\">技術系</span>\n                        </div><!-- /drop-down-title -->\n                        <div class=\"drop-down-body\">\n                            製品の品質・機能・性能を計測機器や各種試験装置を用いて検査する業務です。製作品の検査や試運転調整等を通じ、お客様が安心してお使い頂ける品質を確保し、ご提供します。\n                            <a href=\"/recruit/newgraduate/interview/02.html\" class=\"job-link\"><div class=\"more-general-pink\">この職種の<br class=\"br-adjust01\">先輩インタビューを見る<span></span></div></a>\n                        </div><!-- /drop-down-body -->\n                    </div><!-- /drop-down-list -->\n                    <p class=\"smooth-page-top\"><a href=\"#top\" class=\"smooth-scroll\">ページTOPへ戻る</a></p>\n                </div><!-- /.message-section -->\n\n                <div class=\"message-section next-block\">\n                    <h3 class=\"title-second04\"><span>施工</span></h3>\n                    <div id=\"anc-job08\" class=\"drop-down-list\"><span class=\"bg-white\">&nbsp;</span>\n                        <div class=\"drop-down-title\">\n                            『施工管理』\n                            <span class=\"drop-down-category\">技術系・事務系共通</span>\n                        </div><!-- /drop-down-title -->\n                        <div class=\"drop-down-body\">\n                            製品であるクレーンをお客様の工場などに納めるための、安全管理、品質管理、工程管理、搬入計画などを担当しています。社内の関係部署の他、建設会社や職人さんなど、多くの方と関わりながら業務を行います。\n                        </div><!-- /drop-down-body -->\n                    </div><!-- /drop-down-list -->\n                    <p class=\"smooth-page-top\"><a href=\"#top\" class=\"smooth-scroll\">ページTOPへ戻る</a></p>\n                </div><!-- /.message-section -->\n\n                <div class=\"message-section next-block\">\n                    <h3 class=\"title-second04\"><span>サービス</span></h3>\n                    <div id=\"anc-job09\" class=\"drop-down-list drop-down-red\"><span class=\"bg-white\">&nbsp;</span>\n                        <div class=\"drop-down-title\">\n                            『サービス設計』\n                            <span class=\"drop-down-category\">技術系</span>\n                        </div><!-- /drop-down-title -->\n                        <div class=\"drop-down-body\">\n                            お客様に納入した天井クレーンの安定稼働や機能向上を目的に、安全化・省エネ・生産性向上などの改修を行うための設計業務です。既設図面に基づく設計だけでなく、実際に現地出張し、現物を確認してから設計を行うことも多くあります。\n                            <a href=\"/recruit/newgraduate/interview/03.html\" class=\"job-link\"><div class=\"more-general-pink\">この職種の<br class=\"br-adjust01\">先輩インタビューを見る<span></span></div></a>\n                        </div><!-- /drop-down-body -->\n                    </div><!-- /drop-down-list -->\n\n                    <div id=\"anc-job10\" class=\"drop-down-list drop-down-red\"><span class=\"bg-white\">&nbsp;</span>\n                        <div class=\"drop-down-title\">\n                            『アフターサービス』\n                            <span class=\"drop-down-category\">技術系</span>\n                        </div><!-- /drop-down-title -->\n                        <div class=\"drop-down-body\">\n                            工場の天井などに据え付けられたクレーンのメンテナンスを行う業務です。<br>具体的には、お客さまの工場などを訪問し、クレーンの保守サービス、修理、改造などを行う業務です。\n                            <a href=\"/recruit/newgraduate/interview/06.html\" class=\"job-link\"><div class=\"more-general-pink\">この職種の<br class=\"br-adjust01\">先輩インタビューを見る<span></span></div></a>\n                        </div><!-- /drop-down-body -->\n                    </div><!-- /drop-down-list -->\n                    <p class=\"smooth-page-top\"><a href=\"#top\" class=\"smooth-scroll\">ページTOPへ戻る</a></p>\n                </div><!-- /.message-section -->\n\n                <div class=\"message-section\">\n                    <h3 class=\"title-second04\"><span>管理部門</span></h3>\n                    <div id=\"anc-job11\" class=\"drop-down-list drop-down-ivory\"><span class=\"bg-white\">&nbsp;</span>\n                        <div class=\"drop-down-title\">\n                            『経理財務』\n                            <span class=\"drop-down-category\">事務系</span>\n                        </div><!-- /drop-down-title -->\n                        <div class=\"drop-down-body\">\n                            業績の管理や自社が持つ資産の管理、投資計画の取り纏め、支払・請求処理といった入出金の処理などを行います。経済的な視点を踏まえ、会社の方向性を提案する、経営の要となる部門です。\n                        </div><!-- /drop-down-body -->\n                    </div><!-- /drop-down-list -->\n\n                    <div id=\"anc-job12\" class=\"drop-down-list drop-down-ivory\"><span class=\"bg-white\">&nbsp;</span>\n                        <div class=\"drop-down-title\">\n                            『人事総務』\n                            <span class=\"drop-down-category\">事務系</span>\n                        </div><!-- /drop-down-title -->\n                        <div class=\"drop-down-body\">\n                            「人」は、企業にとって最も大切な財産。人事総務の仕事は、その「人財」をいかすこと。「働きやすい職場づくり」や「募集・採用、育成から退職に至る」まで、「人財」に関するすべての業務を幅広く行っています。\n                            <!--a href=\"/recruit/newgraduate/interview/01.html\" class=\"job-link job-link-ivory\"><div class=\"more-general-ivory\">この職種の<br class=\"br-adjust01\">先輩インタビューを見る<span></span></div></a-->\n                        </div><!-- /drop-down-body -->\n                    </div><!-- /drop-down-list -->\n                    <p class=\"smooth-page-top\"><a href=\"#top\" class=\"smooth-scroll\">ページTOPへ戻る</a></p>\n                </div><!-- /.message-section -->\n\t\t\t</div><!-- /.contents-width -->\n\n<div class=\"contents-width\">\n\n<div class=\"section-recruit multiple\" id=\"section-entry\">\n<img src=\"/recruit/newgraduate/image/back_entry.jpg\" alt=\"\">\n<div class=\"entry-inner\">\n<div>\n<p>ENTRY</p>\n<p>エントリーはこちらから</p>\n</div>\n<div class=\"entry-link\">\n<p><a href=\"https://job.mynavi.jp/26/pc/search/corp113326/outline.html\" target=\"_blank\">2026卒エントリー<span class=\"entry-arrow\"></span></a></p>\n<p>2027卒エントリー（準備中）</p>\n</div>\n</div>\n</div>\n\n</div><!-- /.contents-width -->\n\n\n\t\t\t<div class=\"accessory-6\">\n\t\t\t\t<span></span>\n\t\t\t\t<span></span>\n\t\t\t\t<span></span>\n\t\t\t\t<span></span>\n\t\t\t\t<span></span>\n\t\t\t\t<span></span>\n\t\t\t\t<span></span>\n\t\t\t</div>\n\n\n\n\t\t</div><!--/Grid4-->\n\t</div><!--/GridSet-->\n</div><!--/Contents-->\n\n\n\n<div id=\"FooterArea\">\n\t<div class=\"Container Wide\">\n\n\t\t<a href=\"#top\" id=\"FooterPageTop\" aria-label=\"ページの先頭へ\"></a>\n\n\t\t<div id=\"Footer1\">\n\n\t\t\t<div id=\"HitachiTop\">\n\t\t\t\t<a href=\"https://www.hitachi.co.jp/\">日立グループTOP</a>\n\t\t\t</div>\n\n\t\t\t<div id=\"Footer1Menu\">\n\t\t\t\t<a href=\"/utility/termofuse/index.html\">サイトの利用条件</a>\n\t\t\t\t<a href=\"/utility/privacy/index.html\">個人情報保護に関して</a>\n\t\t\t</div>\n\n\t\t\t<div id=\"Copyright\">&copy; Hitachi Plant Mechanics Co., Ltd.<span>2007</span>. All rights reserved.</div>\n\n\t\t</div><!--/#Footer1-->\n\n\t</div><!--/.Container-->\n</div><!--/#FooterArea-->\n\n<script>\n(function (i, s, o, g, r, a, m) {(i[r] = i[r] || function () { (i[r].q = i[r].q || []).push(arguments) }),(a = s.createElement(o)), (m = s.getElementsByTagName(o)[0]);a.async = 1;a.src = g;m.parentNode.insertBefore(a, m);})(window, document, \"script\", \"//ar.mrc-s.com/web/ar.js\", \"mrc\");\nmrc(\"id\", \"mgr8af\");\nmrc(\"autolink\", [\"*.hitachi-hpm.co.jp\", \"hitachi-hpm.mrc-lp.com\"]);\nmrc(\"send\");\n</script>\n\n</body>\n</html>","finalUrl":"https://www.hitachi-hpm.co.jp/recruit/newgrad