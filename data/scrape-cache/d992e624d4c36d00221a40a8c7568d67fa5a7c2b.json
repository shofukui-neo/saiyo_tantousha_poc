{"url":"https://www.dmre.daikin.co.jp/message/","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width,initial-scale=1.0\">\n    <meta name=\"description\" content=\"ダイキンMRエンジニアリング代表取締役社長 鶴田幸大からのメッセージ。「海の空気をつくる会社」として、船舶空調を通じた社会的使命と今後のビジョンをお伝えします。\">\n    <title>トップメッセージ | ダイキンMRエンジニアリング株式会社</title>\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n    <link href=\"https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Noto+Sans+JP:wght@100..900&family=Roboto+Condensed:wght@100..900&display=swap\" rel=\"stylesheet\">\n    <link href=\"/common/css/common.css\" rel=\"stylesheet\">\n      <link rel=\"stylesheet\" href=\"css/index.css\">\n\n    <script src=\"//ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js\"></script>\n    <script>window.jQuery || document.write('<script src=\"/common/js/libs/jquery-3.7.1.min.js\"><\\/script>')</script>\n    <script src=\"/common/js/plugins.js\"></script>\n    <script src=\"/common/js/common.min.js\"></script>\n    \n    <meta property=\"og:type\" content=\"article\">\n    <meta property=\"og:title\" content=\"トップメッセージ | ダイキンMRエンジニアリング株式会社\">\n    <meta property=\"og:url\" content=\"https://www.dmre.daikin.co.jp/message/\">\n    <meta property=\"og:image\" content=\"https://www.dmre.daikin.co.jp/common/img/ogp.png\">\n    <meta property=\"og:description\" content=\"ダイキンMRエンジニアリング代表取締役社長 鶴田幸大からのメッセージ。「海の空気をつくる会社」として、船舶空調を通じた社会的使命と今後のビジョンをお伝えします。\">\n    <meta property=\"og:site_name\" content=\"ダイキンMRエンジニアリング株式会社\">\n    <meta property=\"og:locale\" content=\"ja_JP\">\n    <link rel=\"canonical\" href=\"https://www.dmre.daikin.co.jp/message/\">\n    <script async=\"\" src=\"https://www.googletagmanager.com/gtag/js?id=G-M2C3PBSPC7\"></script>\n    <script>\n      window.dataLayer = window.dataLayer || [];\n      function gtag() { dataLayer.push(arguments); }\n      gtag('js', new Date());\n\n      gtag('config', 'G-M2C3PBSPC7');\n    </script>\n    <script type=\"application/ld+json\">\n  {\n\t\t\"@context\": \"http://schema.org\",\n\t\t\"@type\" : \"BreadcrumbList\",\n\t\t\"itemListElement\":[\n    \t\t                    {\n            \"@type\"   : \"ListItem\",\n            \"position\": \"1\",\n            \"item\"    : {\n                \"@id\" : \"https://www.dmre.daikin.co.jp/\",\n                \"name\": \"ダイキンMRエンジニアリング株式会社\"\n            }\n          },\n                    {\n            \"@type\"   : \"ListItem\",\n            \"position\": \"2\",\n          \"item\"    : {\n              \"@id\" : \"https://www.dmre.daikin.co.jp/message/\",\n              \"name\": \"トップメッセージ\"\n          }\n        }\n\t\t]\n\t}\n\n</script>\n</head>\n<body>\n<div class=\"wrap\"><header class=\"header\">\n    <div class=\"header__main\">\n                    <a href=\"/\">\n                <p class=\"header__logo\"><img src=\"/common/img/logo.svg\" alt=\"ダイキンMRエンジニアリング株式会社\" width=\"307\" height=\"73\"></p>\n            </a>\n                <div class=\"header__list\">\n            <ul class=\"header__nav\">\n                <li><a href=\"/contact/\" class=\"header__contact\"><span>FAQ｜お問い合わせ</span></a></li>\n                <li>\n                    <a href=\"/recruit/\" class=\"header__recruit\">\n                        <span class=\"header__recruit-en\">RECRUIT</span>\n                        <span class=\"header__recruit-ja\">採用情報はこちら</span>\n                    </a>\n                </li>\n                <li class=\"header__lang\">\n                    <div class=\"header__lang-main\">\n                        <span class=\"header__lang-ja\">JP</span>\n                        <a href=\"/english/\" class=\"header__lang-en\">EN</a>\n                    </div>\n                </li>\n                <li>\n                    <button class=\"header__menu js-menu-show\">MENU</button>\n                </li>\n            </ul>\n        </div>\n    </div>\n</header>\n\n<div class=\"fixed-menu\">\n    <ul class=\"fixed-menu__list\">\n        <li>\n            <button class=\"fixed-menu__menu js-menu-show\">MENU</button>\n        </li>\n        <li><a href=\"/contact/\" class=\"fixed-menu__contact\"><span>FAQ｜お問い合わせ</span></a></li>\n        <li>\n            <a href=\"/recruit/\" class=\"fixed-menu__recruit\">\n                <span class=\"fixed-menu__recruit-en\">RECRUIT</span>\n                <span class=\"fixed-menu__recruit-ja\">採用情報はこちら</span>\n            </a>\n        </li>\n\n    </ul>\n</div>\n\n\n<div class=\"sp-menu\"><button class=\"js-menu-show\"><span>menu</span></button></div>\n\n\n<main class=\"main message\">\n    <div class=\"main__head\">\n        <picture class=\"\">\n    <source srcset=\"img/head_img.avif\" type=\"image/avif\">\n    <img src=\"img/head_img.jpg\" alt=\"\" width=\"1400\" height=\"464\"  loading=\"lazy\">\n  </picture>\n        <hgroup class=\"main__head-group\">\n            <p class=\"main__head-sub\" lang=\"en\">TOP MESSAGE</p>\n            <h1 class=\"main__head-title\">トップメッセージ</h1>\n        </hgroup>\n        <div class=\"message__head\">\n            <p class=\"message__head-comapny\">ダイキンMRエンジニアリング株式会社</p>\n            <p class=\"message__head-name\">代表取締役社長 <span>鶴田幸大</span></p>\n        </div>\n        <div class=\"message__head-title\">\n            <p class=\"message__head-title-lead\">DRE<span>@</span>M 夢を語ろう</p>\n            <p class=\"message__head-title-en\">Let's talk about dreams</p>\n        </div>\n    </div>\n    <section class=\"message-lead contents\">\n        <h2 class=\"message-lead__title\">顧客から最高の信用を得る、品質で選ばれるエンジニアリング会社の実現</h2>\n        <ol class=\"message-lead__list\">\n            <li>舶用空調エンジニアリングのプロとして最高レベルをめざします。</li>\n            <li>省エネルギー・地球環境保護に貢献する舶用空調冷凍システムを開発・提供します。</li>\n            <li>風通しの良い社風、お客様や現場の声にタイムリーに応えられる会社をめざします。</li>\n        </ol>\n    </section>\n    <section class=\"message-contents\">\n        <div class=\"contents\">\n            <div class=\"message-contents__head\">\n                <p class=\"message-contents__number\">01</p>\n                <h3 class=\"message-contents__title\">社会的使命</h3>\n                <p class=\"message-contents__title-en\">Social Mission</p>\n            </div>\n            <div class=\"message-01\">\n                <div class=\"message-contents__main\">\n                    <p>地球は海の星です。<br>\n                        太古の昔から、船は人や物、文化の往来を支えてきました。そしていまも、船は欠くことができない輸送手段です。</p>\n                    <p>当社はダイキン工業の100％出資子会社として、同社の空調技術を船舶分野へと展開しています。</p>\n                    <p>\n                        また、私たちは機器の販売だけではなく空調・冷凍システムの設計から施工までをワンストップで提供しています。「こんな空調を備えたい」というニーズを的確に汲み取り、船の仕様に合わせた空調システムを形にします。</p>\n                    <p>私たちは日本のみならず、シンガポールや中国の拠点をはじめとした、グローバルネットワークで世界中で活躍されるお客様のビジネスを力強く支えます。</p>\n                    <p>お客様と共に歩み、成長するエンジニアリング会社として、「ダイキンMRエンジニアリングに任せてよかった」と感じていただける確かな技術とサービスをお約束します。</p>\n                </div>\n                <div class=\"message-01__img\"><picture class=\"\">\n    <source srcset=\"img/01_img01.avif\" type=\"image/avif\">\n    <img src=\"img/01_img01.jpg\" alt=\"\" width=\"420\" height=\"280\"  loading=\"lazy\">\n  </picture></div>\n            </div>\n        </div>\n    </section>\n    <div class=\"message-02-03\">\n        <section class=\"message-contents\">\n            <div class=\"contents\">\n                <div class=\"message-contents__head\">\n                    <p class=\"message-contents__number\">02</p>\n                    <h3 class=\"message-contents__title\">エンジニアリング企業としての誇り</h3>\n                    <p class=\"message-contents__title-en\">Pride as an Engineering Company</p>\n                </div>\n                <div class=\"message-02\">\n                    <div class=\"message-contents__main message-02__main\">\n                        <p>お客様からの「信用」を第一に、私たちは日々の研鑽を惜しまず、空調・冷凍技術のアップデートを図っています。</p>\n\n                        <p>当社の高い技術力で、タンカーからLNG船、官公庁船、客船まで多岐にわたる船に最適な環境をご提案いたします。</p>\n\n                        <p>世界各地での豊富な納品・施工実績を礎に、新規建造時の空調システム導入から就航後の保守・メンテナンス、将来の機器換装までを網羅しています。\n                            「空気で答えを出す会社」として船の生涯に伴走し、お客様のビジネスを力強く支え続けます。</p>\n                    </div>\n                    <div class=\"message-02__img\">\n                        <div><picture class=\"\">\n    <source srcset=\"img/02_img01.avif\" type=\"image/avif\">\n    <img src=\"img/02_img01.jpg\" alt=\"\" width=\"278\" height=\"182\"  loading=\"lazy\">\n  </picture></div>\n                        <div class=\"message-02__img-02\"><picture class=\"\">\n    <source srcset=\"img/02_img02.avif\" type=\"image/avif\">\n    <img src=\"img/02_img02.jpg\" alt=\"\" width=\"278\" height=\"182\"  loading=\"lazy\">\n  </picture></div>\n                    </div>\n                </div>\n            </div>\n        </section>\n        <section class=\"message-contents\">\n            <div class=\"contents\">\n                <div class=\"message-contents__head\">\n                    <p class=\"message-contents__number\">03</p>\n                    <h3 class=\"message-contents__title\">グローバルカンパニー・ダイキンの研究・開発力を活かす</h3>\n                    <p class=\"message-contents__title-en\">Utilizing the Research and Development Capabilities of Global Corporation Daikin</p>\n                </div>\n                <div class=\"message-03\">\n                    <div class=\"message-contents__main\">\n                        <p>ダイキンMRエンジニアリングの大きな強みは、ダイキングループの一員として、グローバルカンパニー、ダイキン工業の研究力や製品開発力を存分に活かすことができることにあります。</p>\n                        <p>ダイキンが持つ空調・冷蔵・冷凍に関するさまざまな研究や高度な知見、最適な空気づくりを実現するための製品開発力と技術力。私たちの提案力・設計力・施工力には、これらの研究開発資産が活かされています。</p>\n                    </div>\n                    <div class=\"message-03__img\"><picture class=\"\">\n    <source srcset=\"img/03_img01.avif\" type=\"image/avif\">\n    <img src=\"img/03_img01.jpg\" alt=\"\" width=\"420\" height=\"290\"  loading=\"lazy\">\n  </picture></div>\n                </div>\n            </div>\n        </section>\n    </div>\n    <section class=\"message-contents message-04\">\n        <div class=\"contents\">\n            <div class=\"message-contents__head\">\n                <p class=\"message-contents__number\">04</p>\n                <h3 class=\"message-contents__title\">行動指針 </h3>\n                <p class=\"message-contents__title-en\">Guiding Principles</p>\n            </div>\n            <div class=\"message-04__contents\">\n                <div class=\"message-contents__main\">\n                    <h4 class=\"message-04__lead\">人に基軸をおく経営<br>\n                        ＜People Centered Management＞</h4>\n                    <p>人を基軸におく経営。<br>\n                        人は無限の可能性をひめたかけがえのない存在である。 一人ひとりの成長の総和が、企業の発展の基盤である。</p>\n                    <p>これは、ダイキングループが創業より実践してきた人材育成に関する考え方です。</p>\n                    <p>エンジニアリング力とは、提案力・設計力・施工力の総合力です。その提案力・設計力・施工力は、商品や製品ではありません。形にならない付加価値であり、すべては人が生み出すものです。</p>\n                    <p>だからこそ私たちは、ダイキングループのなかでもとりわけ、この行動指針にこだわります。</p>\n                    <p>「船の空調・冷凍システムのプロ」と呼ばれるにふさわしい知識と技術を持って、お客様のご要望やご期待を越えてお応えする。そんなプロフェッショナルであり、挑戦者であり続けたいと考えます。</p>\n                </div>\n                <div class=\"message-04__img\">\n                    <div><picture class=\"\">\n    <source srcset=\"img/04_img01.avif\" type=\"image/avif\">\n    <img src=\"img/04_img01.jpg\" alt=\"\" width=\"420\" height=\"280\"  loading=\"lazy\">\n  </picture></div>\n                    <div class=\"message-04__img02\"><picture class=\"\">\n    <source srcset=\"img/04_img02.avif\" type=\"image/avif\">\n    <img src=\"img/04_img02.jpg\" alt=\"\" width=\"278\" height=\"182\"  loading=\"lazy\">\n  </picture></div>\n                    <div class=\"message-04__img03\"><picture class=\"\">\n    <source srcset=\"img/04_img03.avif\" type=\"image/avif\">\n    <img src=\"img/04_img03.jpg\" alt=\"\" width=\"278\" height=\"182\"  loading=\"lazy\">\n  </picture></div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n</main>\n<footer class=\"footer\">\n    <div class=\"footer__wrap\">\n        <div class=\"footer__contents\">\n            <div class=\"footer__main\">\n                <div class=\"footer__logo\"><a href=\"/\"><img src=\"/common/img/logo.svg\" alt=\"ダイキンMRエンジニアリング株式会社\" width=\"308\" height=\"73\"></a></div>\n                <div class=\"footer__nav\">\n                    <ul class=\"footer__nav-list\">\n                        <li><a href=\"/message/\">トップメッセージ</a></li>\n                        <li><a href=\"/outline/\">企業情報</a></li>\n                        <li><a href=\"/business/\">事業概要</a></li>\n                    </ul>\n                </div>\n                <div class=\"footer__nav\">\n                    <ul class=\"footer__nav-list\">\n                        <li><a href=\"/engineer/\">エンジニアリング力</a></li>\n                        <li><a href=\"/results/\">納入・サービス実績</a></li>\n                        <li><a href=\"/catalog/\">商品・サービス</a></li>\n                    </ul>\n                </div>\n                <div class=\"footer__other\">\n                    <ul class=\"footer-other-list\">\n                        <li><a href=\"/contact/\" class=\"footer__contact\"><span>FAQ｜お問い合わせ</span></a></li>\n                        <li>\n                            <a href=\"/recruit/\" class=\"footer__recruit\">\n                                <span class=\"footer__recruit-en\">RECRUIT</span>\n                                <span class=\"footer__recruit-ja\">採用情報はこちら</span>\n                            </a>\n                        </li>\n                    </ul>\n                    <div class=\"footer__lang\">\n                        <span class=\"footer__lang-ja\">JP</span>\n                        <a href=\"/english/\" class=\"footer__lang-en\">EN</a>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n    <div class=\"footer__bottom\">\n        <ul class=\"footer__bottom-list\">\n            <li><a href=\"/terms/