d><a href=\"/adbanner/\">広告について</a></dd>\n                    <dd><a href=\"/pressreleases/\">プレスリリース</a></dd>\n                    <dd><a href=\"/sitemap/\">サイトマップ</a></dd>\n                    <dd><a href=\"/contacts/\">お問合せ</a></dd>\n                    <dd><a href=\"/privacy/\">プライバシーポリシー</a></dd>\n                    <dd><a href=\"/sitepolicy/\">サイトポリシー</a></dd>\n                </dl>\n                <dl>\n                    <dt>学校・旅行会社向け</dt>\n                    <dd><a href=\"/shugaku/\" target=\"_blank\">教育旅行サイト</a></dd>\n                    <dd><a href=\"/movies/\">動画ギャラリー</a></dd>\n                    <dd><a href=\"/photos/\">フォトギャラリー</a></dd>\n                    <dd><a href=\"/fc/\" target=\"_blank\">くまもとフィルムコミッション</a></dd>\n                </dl>\n                <dl>\n                    <dt>その他</dt>\n                    <dd><a href=\"/document/\">観光連盟情報公開資料</a></dd>\n                    <dd><a href=\"/statistics/\">熊本県観光統計</a></dd>\n                    <dd><a href=\"/renmei/\">連盟会員名簿</a></dd>\n                    <dd class=\"btn\"><a href=\"/members/\" target=\"_blank\">会員専用サイト</a></dd>\n                </dl>\n            </div>\n\n            <div class=\"new-copy\">\n                <p>©2010 kumamoto pref.kumamon</p>\n                <p>CopyRight © Kumamoto Prefecture Tourist Federation. All Rights Reserved.</p>\n            </div>\n\n        </footer>\n        <!-- footer -->\n\n                <script src=\"https://ajax.googleapis.com/ajax/libs/jquery/3.3.1/jquery.min.js\"></script>\n        <script src=\"/js/modernizr-custom.js?1669639515\" timestamp=\"force\"></script>        <script src=\"/js/cookies.js?1669639515\" timestamp=\"force\"></script>        <script src=\"/js/common.js?1680177997\" timestamp=\"force\"></script>        <script>$(function() {\n   //postal code search\n  $('#button-postal-code-search').click(function() {\n     var code = $('input[name=postal_code]').val();\n\n     $.ajax('/postal-code/postal-codes/query', {\n         'data': {\n             'q': code\n         },\n         'dataType': 'json'\n     })\n     .then(function(data) {\n        if (\n            typeof data.postalCodes !== 'undefined' &&\n            typeof data.postalCodes[0] !== 'undefined'\n        ) {\n            $('input[name=address_pref]').val(data.postalCodes[0].prefecture);\n            $('input[name=address1]').val(data.postalCodes[0].city + data.postalCodes[0].sublocality1);\n\n            if (data.postalCodes[0].sublocality2) {\n                $('input[name=address2]').val(data.postalCodes[0].sublocality2);\n            }\n        }\n     })\n  });\n});</script>        <script src=\"https://cdnjs.cloudflare.com/ajax/libs/js-cookie/2.1.3/js.cookie.min.js\"></script><script>window._favoriteManage = {};\nwindow._favoriteManage.localStorageKey = 'favorites';\nwindow._favoriteManage.fetchFavorites = function () {\n    window.favorites = [];   \n    if (Cookies.get(window._favoriteManage.localStorageKey)) {\n        var favorites = JSON.parse(Cookies.get(window._favoriteManage.localStorageKey));\n        if (typeof favorites === 'object' && favorites !== null) {\n            window.favorites = favorites;\n        }\n    }\n};\n        \nwindow._favoriteManage.saveFavorites = function () {\n    Cookies.set(window._favoriteManage.localStorageKey, JSON.stringify(window.favorites));\n};\n\njQuery(function() {\n    jQuery('span.ico-add-fav,p.btn-add-fav').each(function() {\n\n\n        \n        var itemId;\n        var itemType;\n        var isFavored = false;\n        \n        var getStatus = function() {\n            if (typeof window.favorites === 'undefined') {\n                  window.favorites = [];\n              }\n            for (var i = 0; i < window.favorites.length; i++) {\n                var item = window.favorites[i];\n                if (item !== null && typeof item !== 'undefined') {\n                    if (item.id == itemId && item.itemType == itemType) {\n                        return true;\n                    }\n                }\n            }\n            return false;\n        };\n        var setStatus = function(status) {\n          if (typeof window.favorites === 'undefined') {\n              window.favorites = [];\n          }\n          for (var i = 0; i < window.favorites.length; i++) {\n            var item = window.favorites[i];\n            if (item !== null && typeof item !== 'undefined') {\n                if (item.id === itemId && item.itemType === itemType) {\n                    window.favorites.splice(i, 1);\n                }\n            }\n          }\n          if (!!status) {  \n            window.favorites.push({id: itemId, itemType: itemType});  \n          }\n          isFavored = status;\n          window._favoriteManage.saveFavorites();\n        };\n        var syncVisibility = function(parent) {\n            var addBtn = $(parent).find('span.ico-add-fav,p.btn-add-fav');\n            var removeBtn = $(parent).find('span.ico-remove-fav,p.btn-remove-fav');\n            \n            if (isFavored) {\n                addBtn.hide();\n                removeBtn.show();\n            } else {\n                addBtn.show();\n                removeBtn.hide();\n            }\n        };\n        \n      window.favorites = [];\n        window._favoriteManage.fetchFavorites();\n        if ($(this).attr('data-item-id')&&$(this).attr('data-item-type')) {\n            itemId = $(this).attr('data-item-id');\n            itemType = $(this).attr('data-item-type');\n            isFavored = getStatus();\n            syncVisibility($(this).parent());\n        }\n        \n        $(this).parent().find('span.ico-add-fav,span.ico-remove-fav,p.btn-add-fav,p.btn-remove-fav').click(function(e) {\n            setStatus(!getStatus());\n            syncVisibility($(this).parent());\n            e.stopPropagation();\n            e.preventDefault();\n        });\n        syncVisibility($(this).parent());\n    });\n});</script>    </body>\n</html>\n","finalUrl":"https://kumamoto.guide/contacts/","rendered":false,"_cachedAt":"2026-06-22T19:17:24.088Z"}