{"url":"https://www.sc-aero.co.jp/recruit/business/","html":"\n<!DOCTYPE html>\n<html lang=\"ja\">\n    <head>\n        <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n        <meta charset=\"utf-8\">\n        <meta name=\"description\" content=\"住商エアロシステム株式会社 新卒採用情報の「ビジネスを知る」ページです。\">\n        <meta name=\"keywords\" content=\"住商エアロシステム,防衛航空宇宙,専門商社\">\n        <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n        <meta name=\"format-detection\" content=\"telephone=no\">\n\n        <title>ビジネスを知る｜住商エアロシステム株式会社 新卒採用情報</title>\n\n        <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n        <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n        <link rel=\"stylesheet\" href=\"https://fonts.googleapis.com/css2?family=Zen+Old+Mincho:wght@400;700&display=swap\">\n        <link rel=\"stylesheet\" href=\"https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&display=swap\">\n        \n        <link rel=\"stylesheet\" href=\"../assets/css/style.css\" media=\"all\">\n\n        <script src=\"../assets/js/vendor/script.js\"></script>\n        <script src=\"../assets/js/plugins.js\"></script>\n        \n        <script src=\"../assets/js/app.js\"></script>\n\n        <!-- Global site tag (gtag.js) - Google Analytics -->\n        <script async src=\"https://www.googletagmanager.com/gtag/js?id=G-K76JDYQNZS\"></script> <script>\n            window.dataLayer = window.dataLayer || []; function gtag(){dataLayer.push(arguments);} gtag('js', new Date());\n            gtag('config', 'G-K76JDYQNZS');\n            gtag('config', 'UA-226519009-1');\n        </script>\n    </head>\n    <body class=\"child business top\" data-key=\"00-03-00\" data-dir=\"1\">\n        <div id=\"wrapper\">\n            <header>\n                <div id=\"header\">\n                    <div class=\"float\">\n                        <div class=\"left\">\n                            <ul class=\"flex\">\n                                <li><a class=\"logo\" href=\"../\"><img src=\"../assets/img/common/header_logo.png\" alt=\"住商エアロシステム株式会社\"></a></li>\n                                <li><p>新卒採用サイト</p></li>\n                            </ul>\n                        </div>\n                        <div class=\"right\">\n                            <ul class=\"flex\">\n                                <li><a id=\"menu-entry\" href=\"../info/requirements.html#entry\"><p>ENTRY</p></a></li>\n                                <li><button id=\"menu-btn\"><span class=\"icon\"></span></button></li>\n                            </ul>\n                        </div>\n                    </div>\n                </div>\n            </header>\n\n\n\n            <div id=\"menu\">\n                <div id=\"menu-overlay\"></div>\n                <div id=\"menu-list\">\n                    <div class=\"inner900\">\n                        <div class=\"flex\">\n                            <div class=\"col\">\n                                <div class=\"box\">\n                                    <div class=\"parent\"><a href=\"../\"><p class=\"font--serif\">TOP</p></a></div>\n                                </div>\n\n                                <div class=\"box\">\n                                    <div class=\"parent\"><a href=\"../message/\"><p class=\"font--serif\">社長メッセージ</p></a></div>\n                                </div>\n\n                                <div class=\"box\">\n                                    <div class=\"parent\"><a class=\"accordion-btn--sp\"><p class=\"font--serif\">会社を知る</p></a></div>\n                                    <ul class=\" accordion-body--sp\">\n                                        <li class=\"child\"><a href=\"../company/\"><p>企業概要</p></a></li>\n                                        <li class=\"child\"><a href=\"../company/info.html\"><p>住商エアロシステムの機能</p></a></li>\n                                        <li class=\"child\"><a href=\"../company/movie.html\"><p>動画ギャラリー</p></a></li>\n                                    </ul>\n                                </div>\n\n                                <div class=\"box\">\n                                    <div class=\"parent\"><a class=\"accordion-btn--sp\"><p class=\"font--serif\">ビジネスを知る</p></a></div>\n                                    <ul class=\" accordion-body--sp\">\n                                        <li class=\"child\"><a href=\"../business/#business-pro\"><p>防衛・航空宇宙の専門商社</p></a></li>\n                                        <li class=\"child\"><a href=\"../business/#business-sas\"><p>SAS Business</p></a></li>\n                                    </ul>\n                                </div>\n                            </div>\n                            <div class=\"col\">\n                                <div class=\"box\">\n                                    <div class=\"parent\"><a class=\"accordion-btn--sp\"><p class=\"font--serif\">社員を知る</p></a></div>\n                                    <ul class=\" accordion-body--sp\">\n                                        <li class=\"child\"><a href=\"../staff/member04.html\"><p>総合職</p></a></li>\n                                        <li class=\"child\"><a href=\"../staff/member02.html\"><p>総合職</p></a></li>\n                                        <li class=\"child\"><a href=\"../staff/member03.html\"><p>管理職</p></a></li>\n                                    </ul>\n                                </div>\n                                <div class=\"box\">\n                                    <div class=\"parent\"><a class=\"accordion-btn--sp\"><p class=\"font--serif\">採用情報</p></a></div>\n                                    <ul class=\" accordion-body--sp\">\n                                        <li class=\"child\"><a href=\"../info/requirements.html\"><p>募集要項</p></a></li>\n                                        <li class=\"child\"><a href=\"../info/personality.html\"><p>求める人材像</p></a></li>\n                                        <li class=\"child\"><a href=\"../info/event.html\"><p>イベント情報</p></a></li>\n                                    </ul>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n\n            <div id=\"mv\" class=\"size--default\">\n                <div class=\"bg\"></div>\n\n                <div class=\"inside\">\n                    <h1>ビジネスを知る</h1>\n                </div>\n            </div>\n\n\n\n            <main>\n                <article>\n                    <section id=\"anchors\">\n                        <div class=\"inner630\">\n                            <div class=\"inside\">\n                                <ul class=\"flex\">\n                                    <li><a href=\"#business-pro\"><p>防衛・航空宇宙の専門商社</p></a></li>\n                                    <li><a href=\"#business-sas\"><p>SAS Business</p></a></li>\n                                </ul>\n                            </div>\n                        </div>\n                    </section>\n\n\n\n                    <section id=\"business-pro\">\n                        <div class=\"prologue inner690\">\n                            <div class=\"h2\"><h2>防衛・航空宇宙の専門商社</h2></div>\n                            <div class=\"txt\">\n                                <p>\n                                    総合商社が幅広い事業分野でビジネスを展開するのに対し、当社は防衛・航空宇宙分野の専門商社として、様々な機体や装備品などをお客様に提供してきました。加えて、宇宙領域や電磁波領域といった新しい領域でのサービス提供や、優れた革新技術の発掘と実用化に向けた協業など、新たな取り組みにも挑戦しています。\n                                </p>\n                            </div>\n                        </div>\n\n                        <div class=\"blocks\">\n                            <div class=\"block\">\n                                <div class=\"inside\">\n                                    <div class=\"flex\">\n                                        <div class=\"col\">\n                                            <div class=\"h3\"><h3 class=\"font--serif\">機体・装備品</h3></div>\n                                            <div class=\"txt\">\n                                                <p>\n                                                    防衛省・陸上自衛隊・海上自衛隊・航空自衛隊向けに、国内外メーカーの代理店として機体・装備品を提供しています。<br>\n                                                    <br>\n                                                    ・航空機（固定翼機・回転翼機）<br>\n                                                    ・無人航空機<br>\n                                                    ・水陸両用車両<br>\n                                                    ・各種装備品<br>\n                                                    （メカニカル機器・電子機器・通信器材など）\n                                                </p>\n                                            </div>\n                                        </div>\n                                        <div class=\"col\">\n                                            <div class=\"ph\"><img class=\"fit\" src=\"../assets/img/business/top_p_01.jpg\"></div>\n                                        </div>\n                                    </div>\n                                </div>\n                            </div>\n\n                            <div class=\"block\">\n                                <div class=\"inside\">\n                                    <div class=\"flex\">\n                                        <div class=\"col\">\n                                            <div class=\"ph\"><img class=\"fit\" src=\"../assets/img/business/top_p_02.jpg\"></div>\n                                        </div>\n                                        <div class=\"col\">\n                                            <div class=\"h3\"><h3 class=\"font--serif\">宇宙・サイバー・電磁波領域</h3></div>\n                                            <div class=\"txt\">\n                                                <p>\n                                                    従来の陸・海・空だけでなく、宇宙・サイバー・電磁波領域においても、新たな製品やサービスを提供していきます。<br>\n                                                    <br>\n                                                    ・宇宙状況監視システム<br>\n                                                    ・情報処理・分析システム<br>\n                                                    ・電磁波関連システム\n                                                </p>\n                                            </div>\n                                        </div>\n                                    </div>\n                                </div>\n                            </div>\n\n                            <div class=\"block\">\n                                <div class=\"inside\">\n                                    <div class=\"flex\">\n                                        <div class=\"col\">\n                                            <div class=\"h3\"><h3 class=\"font--serif\">革新技術</h3></div>\n                                            <div class=\"txt\">\n                                                <p>\n                                                    国内外の優れた革新技術を発掘し、実用化に向けたサポートを提供すると共に、お客様の抱える課題やニーズへの新たなソリューションとして提案していきます。<br>\n                                                    <br>\n                                                    ・スタートアップ企業との協業実績<br>\n                                                    （電波収集衛星サービス・衛星量子暗号など）\n                                                </p>\n                                            </div>\n                                        </div>\n                                        <div class=\"col\">\n                                            <div class=\"ph\"><img class=\"fit\" src=\"../assets/img/business/top_p_03.jpg\"></div>\n                                        </div>\n                                    </div>\n                                </div>\n                            </div>\n\n                            <div class=\"block\">\n                                <div class=\"inside\">\n                                    <div class=\"flex\">\n                                        <div class=\"col\">\n                                            <div class=\"ph\"><img class=\"fit\" src=\"../assets/img/business/top_p_04.jpg\"></div>\n                                        </div>\n                                        <div class=\"col\">\n                                            <div class=\"h3\"><h3 class=\"font--serif\">サービス機能</h3></div>\n                                            <div class=\"txt\">\n                                                <p>\n                                                    代理店としてトレード機能を提供するだけでなく、需要予測や包括的な維持整備支援など、様々なお客様のニーズに応える新たな価値を提供していきます。<br>\n                                                    <br>\n                                                    ・部品在庫・需要予測機能を活用したサービス\n                                                </p>\n                                            </div>\n                                        </div>\n                                    </div>\n                                </div>\n                            </div>\n                        </div>\n                    </section>\n\n\n\n                    <section id=\"business-sas\">\n                        <div class=\"inner510\">\n                            <div class=\"h2\"><h2>SAS Business</h2></div>\n                            <div class=\"h3\">\n                                <h3 class=\"font--serif\">\n                                    “現在と未来の安心・安全を守ること。”<br>\n                                    それを支える当社ビジネスの面白さを感じてください\n                                </h3>\n                            </div>\n\n                            <div class=\"sttl\"><p>SAS Business Short Movie</p></div>\n                            <div class=\"video\">\n                                <video src=\"../assets/video/recruiting.mp4\" playsinline controls oncontextmenu=\"return false;\" poster=\"../assets/img/business/top_video_poster.jpg\"></video>\n                            </div>\n                        </div>\n                    </section>\n                </article>\n            </main>\n\n            <div id=\"footer-message\">\n                <div class=\"inside\">\n                    <div class=\"ph\"><img src=\"../assets/img/common/footer_copy.png\" alt=\"あたりまえを衞り続ける\"></div>\n                </div>\n            </div>\n            <footer class=\"child business top\">\n                <div class=\"upper\">\n                    <div class=\"inner1000\">\n                        <ul class=\"flex\">\n                            <li>\n                                <ol>\n                                    <li class=\"parent\"><a href=\"../\"><p>TOP</p></a></li>\n                                    <li class=\"child\"><a href=\"../info/requirements.html#entry\"><p>エントリー</p></a></li>\n                                    <li class=\"child\"><a class=\"blank\" href=\"https://www.sc-aero.co.jp/index.html\" target=\"_blank\"><p>コーポレートサイト</p></a></li>\n                                </ol>\n                            </li>\n                            <li>\n                                <ol>\n                                    <li class=\"parent\"><a href=\"../message/\"><p>社長メッセージ</p></a></li>\n                                </ol>\n                            </li>\n                            <li>\n                                <ol>\n                                    <li class=\"parent\"><a class=\"none\"><p>会社を知る</p></a></li>\n                                    <li class=\"child\"><a href=\"../company/\"><p>企業概要</p></a></li>\n                                    <li class=\"child\"><a href=\"../company/info.html\"><p>住商エアロシステムの機能</p></a></li>\n                                    <li class=\"child\"><a href=\"../company/movie.html\"><p>動画ギャラリー</p></a></li>\n                                </ol>\n                            </li>\n                            <li>\n                                <ol>\n                                    <li class=\"parent\"><a class=\"none\"><p>ビジネスを知る</p></a></li>\n                                    <li class=\"child\"><a href=\"../business/#business-pro\"><p>防衛・航空宇宙の専門商社</p></a></li>\n                                    <li class=\"child\"><a href=\"../business/#business-sas\"><p>SAS Business</p></a></li>\n                                </ol>\n                            </li>\n                            <li>\n                                <ol>\n                                    <li class=\"parent\"><a class=\"none\"><p>社員を知る</p></a></li>\n                                    <li class=\"child\"><a href=\"../staff/member04.html\"><p>総合職</p></a></li>\n                                    <li class=\"child\"><a href=\"../staff/member02.html\"><p>総合職</p></a></li>\n                                    <li class=\"child\"><a href=\"../staff/member03.html\"><p>管理職</p></a></li>\n                                </ol>\n                            </li>\n                            <li>\n                                <ol>\n                                    <li class=\"parent\"><a class=\"none\"><p>採用情報</p></a></li>\n                                    <li class=\"child\"><a href=\"../info/requirements.html\"><p>募集要項</p></a></li>\n                                    <li class=\"child\"><a href=\"../info/personality.html\"><p>求める人材像</p></a></li>\n                                    <li class=\"child\"><a href=\"../info/event.html\"><p>イベント情報</p></a></li>\n                                </ol>\n                            </li>\n                        </ul>\n                    </div>\n                </div>\n\n\n                <div class=\"lower\">\n                    <div class=\"copyright\"><p>&copy; Sumisho Aero Systems Corporation</p></div>\n                </div>\n            </footer>\n        </div>\n    </body>\n</html>","finalUrl":"https://www.sc-aero.co.jp/recruit/business/","rendered":false,"_