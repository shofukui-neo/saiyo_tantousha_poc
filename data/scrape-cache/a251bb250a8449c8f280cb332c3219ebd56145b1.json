orms/d/e/1FAIpQLSe71MoUz5KKrxVmKL2YxPpdVgZh-he3FJeq7o2cSaqzSHgvVg/viewform\" target=\"_blank\"><img src=\"https://www.kantokoshin-kubota.co.jp/shared_new/imgs/page-top/header/bg_information.gif\" alt=\"お問い合わせ\" width=\"96\" height=\"22\"></a>\n</div>\n</div><!-- /.utility-inner -->\n</div><!-- /.utility -->\n<hr>\n</header>\n<!-- ========== End Header ========== -->\n</div><!--/header-->\n<!-- ========== Begin Global Navigation ========== -->\n<div class=\"contentsWidth2\">\n<nav id=\"menu\">\n<ul id=\"menubar\" class=\"clearfix\">\n<li><a href=\"https://www.kantokoshin-kubota.co.jp/news/index.html\" title=\"新着情報\">新着情報</a></li>\n<li><a href=\"https://www.kantokoshin-kubota.co.jp/outline/index.html\" title=\"会社案内\">会社案内</a></li>\n<li><a href=\"https://www.kantokoshin-kubota.co.jp/office/index.html\" title=\"営業所案内\">営業所案内</a></li>\n<li><a href=\"https://www.kantokoshin-kubota.co.jp/products/index.html\" title=\"製品情報\">製品情報</a></li>\n<li><a href=\"https://www.kantokoshin-kubota.co.jp/recruitment/index.html\" title=\"採用情報\">採用情報</a></li>\n<li><a href=\"https://www.kantokoshin-kubota.co.jp/sengen/index.html\" title=\"健康経営宣言\">健康経営宣言</a></li></ul></nav>\n</div>\n</div>\n<!-- ========== End Global Navigation ========== -->\n<article>\n<!-- ********************** Begin Promotion ********************** -->\n<div class=\"clearfix\" id=\"main_in\">\n<div class=\"contentsWidth\">\n<!--topicPath-->\n<div id=\"topicPath\">\n<ul>  \n<li class=\"home\"><a href=\"https://www.kantokoshin-kubota.co.jp/index.html\">ホーム</a> &gt; </li>\n\n\n\n\n\n\n<li><a href=\"https://www.kantokoshin-kubota.co.jp/recruitment/index.html\">採用情報</a> &gt; </li>\n<li>募集要項</li>\n\n\n\n\n\n\n\n\n\n\n\n\n</ul> \n</div>\n<!--topicPath-->\n</div>\n</div>\n<!-- ********************** End Promotion ********************** -->\n<!-- ********************** Begin Promotion ********************** -->\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n<!-- ********************** End Promotion ********************** -->\n\n\n<div class=\"contentsWidth clearfix\">\n\t<h3 class=\"margin_bottom_40 margin_top_20\">\n\t\t<img alt=\"募集要項\" class=\"per100\" src=\"images/title_01.jpg\" /></h3>\n\t<div class=\"position_r\" id=\"right\">\n\t\t<a id=\"index01\" name=\"index01\"></a>\n\t\t<div class=\"newsbox mb1em entry entry_blog\">\n\t\t\t<div class=\"rec01\">\n\t\t\t\t<div class=\"top\">\n\t\t\t\t\t<h4>\n\t\t\t\t\t\t募集職種（新規卒業・中途採用）</h4>\n\t\t\t\t\t<p>\n\t\t\t\t\t\t・セールスエンジニア（営業職）<br />\n\t\t\t\t\t\t・サービスエンジニア（技術職）<br />\n\t\t\t\t\t\t・事務職員（総合職・営業事務）<br />\n\t\t\t\t\t\t※但しセールスエンジニア、サービスエンジニア経験後の配属</p>\n\t\t\t\t</div>\n\t\t\t\t<script src='http://code.jquery.com/jquery.min.js'></script><script src='jquery.tabs.js'></script><script>\n$(document).ready( function() {\n  tabify( '#tabs' );\n});\n</script>\n\t\t\t\t<div id=\"tabs\">\n\t\t\t\t\t<ul>\n\t\t\t\t\t\t<li>\n\t\t\t\t\t\t\t新規卒業</li>\n\t\t\t\t\t\t<li>\n\t\t\t\t\t\t\t中途採用</li>\n\t\t\t\t\t</ul>\n\t\t\t\t\t<div>\n\t\t\t\t\t\t<h4>\n\t\t\t\t\t\t\t新規卒業</h4>\n\t\t\t\t\t\t<table class=\"seminar3\">\n\t\t\t\t\t\t\t<colgroup>\n\t\t\t\t\t\t\t\t<col width=\"15%\" />\n\t\t\t\t\t\t\t\t<col width=\"85%\" />\n\t\t\t\t\t\t\t</colgroup>\n\t\t\t\t\t\t\t<tbody>\n\t\t\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t\t\t<th class=\"nowrap\" scope=\"row\">\n\t\t\t\t\t\t\t\t\t\t業務内容</th>\n\t\t\t\t\t\t\t\t\t<td>\n\t\t\t\t\t\t\t\t\t\t多種多様な機械を扱うので、一人前になるためにしっかり学んでいきましょう。\n\n\n<br />\n\t\t\t\t\t\t\t\t\t\tまずは「正確に」というところから徐々にスピードアップしていってください。\n\n<br />\n\t\t\t\t\t\t\t\t\t\t<strong class=\"rpoint\">・セールスエンジニア（営業職）</strong><br />\n\t\t\t\t\t\t\t\t\t\t　クボタ農業機械の販売、その他農業機械の販売、営農活動訪問。\n\n<br />\n\t\t\t\t\t\t\t\t\t\t<strong class=\"rpoint\">・サービスエンジニア（技術職）</strong><br />\n\t\t\t\t\t\t\t\t\t\t　営業所またはサービスセンター内で農業機械の修理及びメンテナンス、<br />\n\t\t\t\t\t\t\t\t\t\t　お客様宅への出張修理。\n\n<br />\n\t\t\t\t\t\t\t\t\t\t<strong class=\"rpoint\">・事務職員（総合職・営業事務）</strong><br />\n\t\t\t\t\t\t\t\t\t\t　◇総合職（配属先：本社または事務所）<br />\n\t\t\t\t\t\t\t\t\t\t　　営業部・業務部・管理部の総合職として管轄内の事務、<br />\n\t\t\t\t\t\t\t\t\t\t　　展示会及び実演会で営業活動の支援。\n\n<br />\n\t\t\t\t\t\t\t\t\t\t　◇営業事務（配属先：営業所、流通センター）<br />\n\t\t\t\t\t\t\t\t\t\t　　営業所内の事務処理、展示会及び実演会等の活動支援。\n\n</td>\n\t\t\t\t\t\t\t\t</tr>\n\t\t\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t\t\t<th class=\"bg_beige\" scope=\"row\">\n\t\t\t\t\t\t\t\t\t\t募集人員</th>\n\t\t\t\t\t\t\t\t\t<td>\n\t\t\t\t\t\t\t\t\t\t<strong>若干名</strong><br />\n\t\t\t\t\t\t\t\t\t\t◆下記の方大歓迎◆<br />\n\t\t\t\t\t\t\t\t\t\t<span class=\"rpoint\">◎農業に興味がある方<br />\n\t\t\t\t\t\t\t\t\t\t◎明るく元気なあいさつができる方<br />\n\t\t\t\t\t\t\t\t\t\t◎人と話すことが好きな方<br />\n\t\t\t\t\t\t\t\t\t\t◎「やる気」「意欲」のある方</span></td>\n\t\t\t\t\t\t\t\t</tr>\n\t\t\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t\t\t<th class=\"bg_beige\" scope=\"row\">\n\t\t\t\t\t\t\t\t\t\t採用試験</th>\n\t\t\t\t\t\t\t\t\t<td>\n\t\t\t\t\t\t\t\t\t\t・採用方法　（書類選考・筆記・面接）<br />\n\t\t\t\t\t\t\t\t\t\t・随時（要相談）</td>\n\t\t\t\t\t\t\t\t</tr>\n\t\t\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t\t\t<th class=\"nowrap\" scope=\"row\">\n\t\t\t\t\t\t\t\t\t\t応募資格</th>\n\t\t\t\t\t\t\t\t\t<td>\n\t\t\t\t\t\t\t\t\t\t2027年3月卒業見込者</td>\n\t\t\t\t\t\t\t\t</tr>\n\t\t\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t\t\t<th class=\"nowrap\" scope=\"row\">\n\t\t\t\t\t\t\t\t\t\t雇用形態</th>\n\t\t\t\t\t\t\t\t\t<td>\n\t\t\t\t\t\t\t\t\t\t正社員（試用期間3ヶ月）</td>\n\t\t\t\t\t\t\t\t</tr>\n\t\t\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t\t\t<th class=\"bg_beige\" scope=\"row\">\n\t\t\t\t\t\t\t\t\t\t給与</th>\n\t\t\t\t\t\t\t\t\t<td>\n\t\t\t\t\t\t\t\t\t\t<table>\n\t\t\t\t\t\t\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t\t\t\t\t\t\t<td>\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t・大卒</td>\n\t\t\t\t\t\t\t\t\t\t\t\t\t<td>\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t　238,500円</td>\n\t\t\t\t\t\t\t\t\t\t\t\t</tr>\n\t\t\t\t\t\t\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t\t\t\t\t\t\t<td>\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t・短大・専門卒　　</td>\n\t\t\t\t\t\t\t\t\t\t\t\t\t<td>\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t　221,500円</td>\n\t\t\t\t\t\t\t\t\t\t\t\t</tr>\n\t\t\t\t\t\t\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t\t\t\t\t\t\t<td>\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t・高卒</td>\n\t\t\t\t\t\t\t\t\t\t\t\t\t<td>\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t　205,500円</td>\n\t\t\t\t\t\t\t\t\t\t\t\t</tr>\n\t\t\t\t\t\t\t\t\t\t</table