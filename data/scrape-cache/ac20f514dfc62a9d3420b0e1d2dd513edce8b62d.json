=\"all\">\n<link type=\"text/css\" href=\"../common/css/page.css\" rel=\"stylesheet\" media=\"all\">\n<link type=\"text/css\" href=\"../common/css/add_style.css\" rel=\"stylesheet\" media=\"all\">\n<link type=\"text/css\" href=\"../common/css/contact.css\" rel=\"stylesheet\" media=\"all\">\n\n<!-- CSS -->\n<link rel=\"stylesheet\" href=\"../common/js/vendor/aos.css\" />\n\n<!-- Javascript -->\n<script type=\"text/javascript\" src=\"../common/js/vendor/jquery-3.4.1.min.js\" charset=\"UTF-8\"></script>\n<script type=\"text/javascript\" src=\"../common/js/vendor/smooth-scroll.min.js\" charset=\"UTF-8\"></script>\n<script type=\"text/javascript\" src=\"../common/js/slide_menu.js\" charset=\"UTF-8\"></script>\n<script type=\"text/javascript\" src=\"../common/js/function.js\" charset=\"UTF-8\"></script>\n<script type=\"text/javascript\" src=\"../common/js/contact.js\" charset=\"UTF-8\"></script>\n\n</head>\n\n<body>\n<!-- Google Tag Manager (noscript) -->\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-KL36MS6F\"\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n<!-- End Google Tag Manager (noscript) -->\n<div id=\"wrapper\" class=\"contact\">\n    <!-- header -->\n\t<header class=\"top\">\n\t\t<!-- inner -->\n\t\t<div id=\"header-inner\">\n\t\t\t<h1 id=\"header-logo\"><a href=\"../index.html\"><img src=\"../images/logo.png\" alt=\"デンソーワイズテック\" /></a></h1>\n\t\t\t<div class=\"header-spmenu\"><img src=\"../common/images/sp_menu_bar.png\" alt=\"spmenu\"></div>\n\t\t\t<!-- sp overlayer-->\n    \t\t<div class=\"layer\"></div>\n\t\t\t<!-- navi -->\n\t\t\t<nav>\n\t\t\t\t<ul id=\"navi-inner\">\n                    <li class=\"sp-only category\">\n                        <a href=\"../u_graduate/index.html\">大卒採用の方は<br>こちら</a>\n                        <a href=\"../h_graduate/index.html\">高卒採用の方は<br>こちら</a>\n                        <a href=\"../career/index.html\">キャリア採用の方は<br>こちら</a>\n                        <a href=\