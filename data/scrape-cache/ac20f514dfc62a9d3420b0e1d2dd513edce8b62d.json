                   <dl class=\"helf\">\n                        <dt>お名前<span>必須</span></dt>\n                        <dd>\n                            <input type=\"text\" id=\"name\" name=\"お名前\" class=\"formwidth-l\" value=\"\" />\n                        </dd>\n                    </dl>\n                    <dl class=\"helf\">\n                        <dt>ふりがな<span>必須</span></dt>\n                        <dd>\n                            <input type=\"text\" id=\"namek\" name=\"ふりがな\" class=\"formwidth-l\" value=\"\" />\n                        </dd>\n                    </dl>\n                </div>\n                <div class=\"contact-item fl-box\">\n                    <dl class=\"helf\">\n                        <dt>お電話番号<span>必須</span></dt>\n                        <dd>\n                            <input type=\"text\" id=\"tel\" name=\"お電話番号\" class=\"formwidth-l\" value=\"\" />\n                        </dd>\n                    </dl>\n                    <dl class=\"helf\">\n                        <dt>メールアドレス<span>必須</span></dt>\n                        <dd>\n                            <input type=\"text\" id=\"email\" name=\"Email\" class=\"formwidth-l\" value=\"\" />\n                        </dd>\n                    </dl>\n                </div>\n                <div class=\"contact-item\">\n                    <dl>\n                        <dt>応募区分<span>必須</span></dt>\n                        <dd>\n                            <ul class=\"row-list\">\n                                <li><label><input name=\"応募区分[]\" type=\"radio\" value=\"新卒\" checked=\"checked\">新卒</label></li>\n                                <li><label><input name=\"応募区分[]\" type=\"radio\" value=\"第二新卒\">第二新卒</label></li>\n                                <li><label><input name=\"応募区分[]\" type=\"radio\" value=\"キャリア\">キャリア</label></li>\n                                <li><label><input name=\"応募区分[]\" type=\"radio\" value=\"パート\">パート</label></li>\n                            </ul>\n                        </dd>\n                    </dl>\n                </div>\n                <div class=\"contact-item\">\n                    <dl>\n                        <dt>お問い合わせ詳細<span>必須</span></dt>\n                        <dd>\n                            <textarea id=\"about\" name=\"お問い合わせ詳細\" rows=\"6\" class=\"formwidth-l\"></textarea>\n                        </dd>\n                    </dl>\n                </div>\n                <div class=\"check\">\n                    <div>\n                        <p>個人情報に関する方針につきましては、<br class=\"sp-only\">「<a href=\"privacy.html\">こちら</a>」をご確認ください。</p>\n                        <label><dl><dt><input type=\"checkbox\" id=\"check\"></dt><dd>プライバシーポリシーに同意する</dd></dl></label>\n                    </div>\n                </div>\n                <div class=\"entry-area\">\n                    <input type=\"submit\" value=\"確認画面へ進む\" id=\"submit\" class=\"button-rd\"><input type=\"reset\" value=\"リセット\" class=\"button-gr\">\n                </div>\n            </form>\n        </section>\n        \n    </main>\n    <!-- page top -->\n    <div class=\"pagetop\"><a href=\"#wrapper\"><img src=\"../common/images/pagetop.png\" width=\"150\" height=\"45\" alt=\"pagetop\"/></a></div>\n    <!-- footer -->\n  \t<footer>\n        <div class=\"footer-bottom\">\n            <div class=\"inner\">\n                <div class=\"footer-logo\">\n                    <h1><img src=\"../images/logo_footer.png\" alt=\"デンソーワイズテック\" width=\"280\" height=\"20\"/></h1>\n                    <p>〒509-0249　岐阜県可児市姫ケ丘3-1<br>TEL:0574-60-5220</p>\n                    <a href=\"https://www.denso-wisetech.co.jp/\" target=\"_blank\" class=\"link-b\">コーポレートサイト</a>\n                </div>\n                <div class=\"footer-menu\">\n                    <ul class=\"category\">\n                        <li><a href=\"../u_graduate/index.html\">大卒採用の方は<br>こちら</a></li>\n                        <li><a href=\"../h_graduate/index.html\">高卒採用の方は<br>こちら</a><