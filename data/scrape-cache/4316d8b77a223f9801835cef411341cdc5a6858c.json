ipt>\n\n\n\n<script src=\"https://www.skdy.co.jp/prd/wp/wp-content/themes/skdy/assets/recruit/js/bundle.js\"></script>\n<!-- 既存のheader.jsを読み込んだ後に、この追加スクリプトを読み込む -->\n<script>\n  document.addEventListener('DOMContentLoaded', function() {\n    var menuBtn = document.querySelector('.js-menuBtn');\n    var headerLine = document.querySelector('.l-headerLine');\n\n    // 万一要素が取得できなかった場合のガード\n    if (!menuBtn || !headerLine) return;\n\n    // メニュークリック時に .l-headerLine にも is-open を付与/解除\n    menuBtn.addEventListener('click', function() {\n      headerLine.classList.toggle('is-open');\n    });\n  });\n</script>\n\n<script>\n    // ポップアップ関連要素を取得\n    const popupBackground = document.getElementById('popupBackground');\n    const videoIframe = document.getElementById('videoIframe');\n    const closeBtn = document.getElementById('closeBtn');\n    const videoLinks = document.querySelectorAll('.video-link');\n\n    // ポップアップを開く（サムネイルクリック）\n    videoLinks.forEach(link => {\n      link.addEventListener('click', (e) => {\n        e.preventDefault();\n        const videoUrl = link.getAttribute('data-video');\n        videoIframe.src = videoUrl;              // iframeにURLをセット\n        popupBackground.style.display = 'flex';  // 表示\n      });\n    });\n\n    // ポップアップを閉じる（×ボタンクリック）\n    closeBtn.addEventListener('click', () => {\n      videoIframe.src = '';                     // 動画を停止する\n      popupBackground.style.display = 'none';   // 非表示\n    });\n\n    // 背景クリックでも閉じる\n    popupBackground.addEventListener('click', (e) => {\n      if (e.target === popupBackground) {\n        videoIframe.src = '';\n        popupBackground.style.display = 'none';\n      }\n    });\n  </script>\n\n</body>\n</html>","finalUrl":"https://www.skdy.co.jp/recruit/products/","rendered":false,"_cachedAt":"2026-06-22T17:39:14.721Z"}