t\t</ul>\n\t\t\t</li>\n\t\t</ul>\n\t</div>\n</nav>\n<!-- /#globalnav -->    </header>\n\n    <div id=\"contentsSection\">\n      <div id=\"contentsSectionInner\">\n        <div class=\"guide\">ここからメインコンテンツ</div>\n        <div id=\"breadcrumb\">\n          <ul>\n            <li><a href=\"/\">HOME</a></li>\n            <li><a href=\"/recruit/\">採用情報</a></li>\n          </ul>\n        </div>\n\n        <div id=\"mainTtlWrapper\">\n          <h1 id=\"mainTtl\">中途採用</h1>\n          <div id=\"lead\">アペックスの中途採用情報をご案内します。</div>\n        </div>\n        <!-- /#mainTtlWrapper -->\n\n        <div id=\"mainContents\">\n          <div class=\"mainContents_l\">\n            <section>\n              <div id=\"mv\">\n                <img src=\"/resources/images/recruit/midcareer_mv.png\" alt=\"\" />\n                <div id=\"mv_lead\">あなたの<br />「おもてなしの心」を<br />待っています。</div>\n              </div>\n              <!-- /#mv -->\n              <div class=\"mb40\">\n                <div class=\"titleWrapper\">\n                  <h2 class=\"contentsTitle\">中途採用について</h2>\n                </div>\n                <p class=\"ml20\">事業拡大により、ルートセールス職を多くの地域で募集しています。<br />下記フォームよりご応募やお問い合わせをお待ちしております。</p>\n              </div>\n              <div class=\"titleWrapper\">\n                <h2 class=\"contentsTitle\">募集要項</h2>\n              </div>\n              <table>\n                <tbody>\n                  <tr>\n                    <th>募集職種</th>\n                    <td>ルートセールス</td>\n                  </tr>\n                  <tr>\n                    <th>主な仕事内容</th>\n                    <td>\n                      企業の休憩スペースなどに設置した当社の自動販売機をまわり、原料の補充・清掃点検・売上管理・集金などの基本業務を行います。\n                      <br />\n                      そのほか、利用するお客様に応じた商品構成を考えたり、新商品の販売促進のためのPOP作りをするなど、自分なりの工夫を加えていきます。\n                    </td>\n                  </tr>\n                  <tr>\n                    <th>応募資格</th>\n                    <td>\n                      高卒以上 40歳まで（キャリア形成のため）<br />\n                      〜未経験者・第二新卒者 応募歓迎〜<br />\n                      普通自動車免許取得者（AT限定可）\n                    </td>\n                  </tr>\n                  <tr>\n                    <th>給与</th>\n                    <td>\n                      月給 180,000円以上＋各種手当<br />\n                      &#9733;あなたの年齢・経験・能力を考慮の上、決定します。<br />\n                      <span class=\"mt10\">【月収例】</span>\n                      261,123円 / 25歳<br />286,545円 / 30歳<br />295,686円 / 35歳\n                    </td>\n                  </tr>\n                  <tr>\n                    <th>勤務地</th>\n                    <td>全国の営業所（詳細は弊社HPにてご確認ください）</td>\n                  </tr>\n                  <tr>\n                    <th>勤務時間</th>\n                    <td>8:30〜17:15<br />※残業あり（約10h〜40h/月）。勤務地により若干異なります。</td>\n                  </tr>\n                  <tr>\n                    <th>休日休暇</th>\n                    <td>\n                      週休2日制（年間休日110日）<br />\n                      有給休暇10日〜40日<br />休暇制度：夏季休暇、年末年始休暇、慶弔休暇、産前・産後休暇、育児休暇、介護休暇 等\n                    </td>\n                  </tr>\n                  <tr>\n                    <th>昇給</th>\n                    <td>年1回</td>\n                  </tr>\n                  <tr>\n                    <th>賞与</th>\n                    <td>年2回<br />備考：夏・冬（業績に応じて支給）</td>\n                  </tr>\n                  <tr>\n                    <th>各種保険</th>\n                    <td>社会保険完備（健康保険、厚生年金、雇用保険、労働災害補償保険（労災））</td>\n                  </tr>\n                  <tr>\n                    <th>諸手当</th>\n                    <td>時間外勤務手当、休日勤務手当、ジョブランク（資格）手当、住宅手当、家族手当、通勤手当　等</td>\n                  </tr>\n                </tbody>\n              </table>\n              <!--div id=\"mynavi2015\" class=\"entry\">\n\t\t\t\t\t\t<h3><img src=\"/resources/images/recruit/ttl_midcareer_mynavi.png\" alt=\"マイナビ転職でエントリー受付中\"></h3>\n\t\t\t\t\t\t<div class=\"entry_wrapper\">\n\t\t\t\t\t\t\t<div class=\"logo\"><img src=\"/resources/images/recruit/midcareer_mynavi.png\" alt=\"マイナビ