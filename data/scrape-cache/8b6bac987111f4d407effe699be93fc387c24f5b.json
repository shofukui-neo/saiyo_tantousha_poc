_header.png\" alt=\"社員の1日を見てみよう\">\n\t\t</div>\n\n\t\t<!-- トップ画像 -->\n\t\t<div class=\"recruit_schedule_topimg_block\">\n\t\t\t<!-- 左上画像 -->\n\t\t\t<div class=\"recruit_schedule_topimg_in\">\n\t\t\t\t<a href=\"#sales\"><img src=\"/images/recruit/pic_schedule_topimg01.png\" alt=\"営業編\" width=\"368\" height=\"112\"></a>\n\t\t\t</div>\n\t\t\t<!-- 右上画像 -->\n\t\t\t<div class=\"recruit_schedule_topimg_in\">\n\t\t\t\t<a href=\"#radioD\"><img src=\"/images/recruit/pic_schedule_topimg02.png\" alt=\"ディレクター編\" width=\"368\" height=\"112\"></a>\n\t\t\t</div>\n\t\t\t<!-- 左下画像 -->\n\t\t\t<div class=\"recruit_schedule_topimg_in\">\n\t\t\t\t<a href=\"#organization\"><img src=\"/images/recruit/pic_schedule_topimg03.png?date=202203\" alt=\"編成編\" width=\"368\" height=\"112\"></a>\n\t\t\t</div>\n\t\t\t<div class=\"fclear\"></div>\n\t\t</div>\n\n\t\t<!-- 営業編 -->\n\t\t<div id=\"sales\" class=\"recruit_schedule_content_area1\">\n\n\t\t\t<div class=\"recruit_schedule_img_block\">\n\t\t\t\t<img src=\"/images/recruit/pic_schedule_titleimg01.png\" alt=\"営業編\" width=\"960\" height=\"437\">\n\t\t\t</div>\n\n\t\t\t<!-- スケジュール -->\n\t\t\t<!-- 09:00-->\n\t\t\t<table class=\"recruit_schedule_area\">\n\t\t\t\t<tbody>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item1_img\"><img src=\"/images/recruit/pic_schedule_clock_0900.png\" alt=\"09:00\" width=\"79\" height=\"77\"></td>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item1_time\">09:00</td>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item2\"><p>営業部ミーティング</p></td>\n\t\t\t\t\t\t<td rowspan=\"2\" class=\"recruit_schedule_area_item3\"><img src=\"/images/recruit/pic_schedule_eigyo_A.png\" alt=\"営業A\" width=\"268\" height=\"179\"></td>\n\t\t\t\t\t</tr>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<td></td>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item1_bar\"></td>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item4\">\n\t\t\t\t\t\t\t<div class=\"recruit_schedule_text\">\n\t\t\t\t\t\t\t\t当日訪ねるスポンサーや、前日にどのような動きがあったのかを部署の中で共有。<br>\n\t\t\t\t\t\t\t\t困っていること、迷っていることなどがあれば先輩からアドバイスをもらいます。\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</td>\n\t\t\t\t\t</tr>\n\t\t\t\t</tbody>\n\t\t\t</table>\n\n\t\t\t<!-- 10:30-->\n\t\t\t<table class=\"recruit_schedule_area\">\n\t\t\t\t<tbody>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item1_img\"><img src=\"/images/recruit/pic_schedule_clock_1030.png\" alt=\"10:30\" width=\"79\" height=\"77\"></td>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item1_time\">10:30</td>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item2\"><p>スポンサーとの打ち合わせ</p></td>\n\t\t\t\t\t\t<td rowspan=\"2\" class=\"recruit_schedule_area_item3\"><img src=\"/images/recruit/pic_schedule_eigyo_B.png\" alt=\"営業B\" width=\"268\" height=\"179\"></td>\n\t\t\t\t\t</tr>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<td></td>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item1_bar\"></td>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item4\">\n\t\t\t\t\t\t\t<div class=\"recruit_schedule_text\">\n\t\t\t\t\t\t\t\tスポンサーを直接訪ねて、テレビCM・ラジオCMの提案をします。\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</td>\n\t\t\t\t\t</tr>\n\t\t\t\t</tbody>\n\t\t\t</table>\n\n\t\t\t<!-- 12:00-->\n\t\t\t<table class=\"recruit_schedule_area\">\n\t\t\t\t<tbody>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item1_img\"><img src=\"/images/recruit/pic_schedule_clock_1200.png\" alt=\"12:00\" width=\"79\" height=\"77\"></td>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item1_time\">12:00</td>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item2\"><p>昼食</p></td>\n\t\t\t\t\t\t<td rowspan=\"2\" class=\"recruit_schedule_area_item3\"><img src=\"/images/recruit/pic_schedule_eigyo_C.png\" alt=\"営業C\" width=\"268\" height=\"179\"></td>\n\t\t\t\t\t</tr>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<td></td>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item1_bar\"></td>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item4\">\n\t\t\t\t\t\t\t<div class=\"recruit_schedule_text\">\n\t\t\t\t\t\t\t\t会社の中にある社員食堂で昼食。<br>\n\t\t\t\t\t\t\t\t値段も安く、ボリュームもあります。午後の仕事に向けて英気を養います。\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</td>\n\t\t\t\t\t</tr>\n\t\t\t\t</tbody>\n\t\t\t</table>\n\n\t\t\t<!-- 14:00-->\n\t\t\t<table class=\"recruit_schedule_area\">\n\t\t\t\t<tbody>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item1_img\"><img src=\"/images/recruit/pic_schedule_clock_1400.png\" alt=\"14:00\" width=\"79\" height=\"77\"></td>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item1_time\">14:00</td>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item2\"><p>番組収録の立ち合い</p></td>\n\t\t\t\t\t\t<td rowspan=\"2\" class=\"recruit_schedule_area_item3\"><img src=\"/images/recruit/pic_schedule_eigyo_D.png\" alt=\"営業D\" width=\"268\" height=\"179\"></td>\n\t\t\t\t\t</tr>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<td></td>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item1_bar\"></td>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item4\">\n\t\t\t\t\t\t\t<div class=\"recruit_schedule_text\">\n\t\t\t\t\t\t\t\t担当するスポンサーが出演する番組に立ち合います。<br>\n\t\t\t\t\t\t\t\tスポンサーの伝えたいことがラジオ・テレビを通してしっかり伝わるようにサポートします。\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</td>\n\t\t\t\t\t</tr>\n\t\t\t\t</tbody>\n\t\t\t</table>\n\n\t\t\t<!-- 16:00-->\n\t\t\t<table class=\"recruit_schedule_area\">\n\t\t\t\t<tbody>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item1_img\"><img src=\"/images/recruit/pic_schedule_clock_1600.png\" alt=\"16:00\" width=\"79\" height=\"77\"></td>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item1_time\">16:00</td>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item2\"><p>CM原稿・絵コンテ作成</p></td>\n\t\t\t\t\t\t<td rowspan=\"2\" class=\"recruit_schedule_area_item3\"><img src=\"/images/recruit/pic_schedule_eigyo_E.png\" alt=\"営業E\" width=\"268\" height=\"179\"></td>\n\t\t\t\t\t</tr>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<td></td>\n\t\t\t\t\t\t<td></td>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item4\">\n\t\t\t\t\t\t\t<div class=\"recruit_schedule_text\">\n\t\t\t\t\t\t\t\t放送されているラジオの原稿や、テレビの画面構成を考えるのも営業の仕事。スポンサーや広告代理店と何度も話し合い、より効果的な広告の方法を考えます。\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</td>\n\t\t\t\t\t</tr>\n\t\t\t\t</tbody>\n\t\t\t</table>\n\n\n\t\t\t<div class=\"recruit_schedule_comment_area\">\n\t\t\t\t<div class=\"recruit_schedule_comment_img\">\n\t\t\t\t\t<img src=\"/images/recruit/pic_schedule_eigyo_m.png\" alt=\"\" width=\"125\" height=\"125\">\n\t\t\t\t</div>\n\t\t\t\t<div class=\"recruit_schedule_comment_text\">\n\t\t\t\t\t営業は各スポンサーをまわり広告の提案をするのが主な仕事です。<br />\n\t\t\t\t\tRABは県内唯一のラジオ・テレビ兼営局であるため、スポンサーに提案できることがたくさんあります。<br />\n\t\t\t\t\t自分の提案内容とスポンサーの求めていることが合致し、契約に至ったときにやりがいを感じます。もちろん大変なこともありますが、そんなときには親身になって相談に乗ってくれる先輩や同僚に助けられています。青森放送でぜひ一緒に仕事をしましょう！\n\t\t\t\t</div>\n\t\t\t\t<div class=\"fclear\"></div>\n\t\t\t</div>\n\n\t\t</div>\n\n\t\t<!-- ディレクター編 -->\n\t\t<div id=\"radioD\" class=\"recruit_schedule_content_area1\">\n\n\t\t\t<div class=\"recruit_schedule_img_block\">\n\t\t\t\t<img src=\"/images/recruit/pic_schedule_titleimg02.png\" alt=\"ディレクター編\" width=\"960\" height=\"437\">\n\t\t\t</div>\n\n\t\t\t<!-- スケジュール -->\n\t\t\t<!-- 10:00-->\n\t\t\t<table class=\"recruit_schedule_area\">\n\t\t\t\t<tbody>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item1_img\"><img src=\"/images/recruit/pic_schedule_clock_1000.png\" alt=\"10:00\" width=\"79\" height=\"77\"></td>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item1_time\">10:00</td>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item2\"><p>番組演出の検討</p></td>\n\t\t\t\t\t\t<td rowspan=\"2\" class=\"recruit_schedule_area_item3\"><img src=\"/images/recruit/pic_schedule_radioD_A.png\" alt=\"ディレクターA\" width=\"268\" height=\"179\"></td>\n\t\t\t\t\t</tr>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<td></td>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item1_bar\"></td>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item4\">\n\t\t\t\t\t\t\t<div class=\"recruit_schedule_text\">\n\t\t\t\t\t\t\t\tその日の生ワイド番組の進め方について、カメラ割りや演出方法を検討します。\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</td>\n\t\t\t\t\t</tr>\n\t\t\t\t</tbody>\n\t\t\t</table>\n\n\t\t\t<!-- 12:00-->\n\t\t\t<table class=\"recruit_schedule_area\">\n\t\t\t\t<tbody>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item1_img\"><img src=\"/images/recruit/pic_schedule_clock_1200.png\" alt=\"12:00\" width=\"79\" height=\"77\"></td>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item1_time\">12:00</td>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item2\"><p>昼食</p></td>\n\t\t\t\t\t\t<td rowspan=\"2\" class=\"recruit_schedule_area_item3\"><img src=\"/images/recruit/pic_schedule_radioD_B.png\" alt=\"ディレクターB\" width=\"268\" height=\"179\"></td>\n\t\t\t\t\t</tr>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<td></td>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item1_bar\"></td>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item4\">\n\t\t\t\t\t\t\t<div class=\"recruit_schedule_text\">\n\t\t\t\t\t\t\t\t社員食堂でランチ。ボリュームもあってリーズナブル。<br />\n\t\t\t\t\t\t\t\t取材や編集のタイミングによって時間をずらすこともあります。\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</td>\n\t\t\t\t\t</tr>\n\t\t\t\t</tbody>\n\t\t\t</table>\n\n\t\t\t<!-- 13:00-->\n\t\t\t<table class=\"recruit_schedule_area\">\n\t\t\t\t<tbody>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item1_img\"><img src=\"/images/recruit/pic_schedule_clock_1300.png\" alt=\"13:00\" width=\"79\" height=\"77\"></td>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item1_time\">13:00</td>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item2\"><p>番組打ち合わせ</p></td>\n\t\t\t\t\t\t<td rowspan=\"2\" class=\"recruit_schedule_area_item3\"><img src=\"/images/recruit/pic_schedule_radioD_C.jpg\" alt=\"ディレクターC\" width=\"268\" height=\"268\"></td>\n\t\t\t\t\t</tr>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<td></td>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item1_bar\"></td>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item4\">\n\t\t\t\t\t\t\t<div class=\"recruit_schedule_text\">\n\t\t\t\t\t\t\t\tアナウンサー、スイッチャー、カメラマン、<br>音声ミキサー、フロアディレクター、ADなどと<br>番組進行の全体打ち合わせ。<br>\n\t\t\t\t\t\t\t\tその日のニュースや天気をチェックしながら、生放送に盛り込むこともあります。\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</td>\n\t\t\t\t\t</tr>\n\t\t\t\t</tbody>\n\t\t\t</table>\n\n\t\t\t<!-- 15:50-->\n\t\t\t<table class=\"recruit_schedule_area\">\n\t\t\t\t<tbody>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item1_img\"><img src=\"/images/recruit/pic_schedule_clock_1550.png\" alt=\"15:50\" width=\"79\" height=\"77\"></td>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item1_time\">15:50</td>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item2\"><p>本番</p></td>\n\t\t\t\t\t\t<td rowspan=\"2\" class=\"recruit_schedule_area_item3\"><img src=\"/images/recruit/pic_schedule_radioD_D.png\" alt=\"ディレクターD\" width=\"268\" height=\"179\"></td>\n\t\t\t\t\t</tr>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<td></td>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item1_bar\"></td>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item4\">\n\t\t\t\t\t\t\t<div class=\"recruit_schedule_text\">\n\t\t\t\t\t\t\t\t生放送のPD（プログラムディレクター）。スタジオカメラ、VTR、中継などを繋ぎ、番組を進めていきます。<br>\n\t\t\t\t\t\t\t\tアナウンサーの話やVTRの内容に対応し、カメラマンに指示をします。\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</td>\n\t\t\t\t\t</tr>\n\t\t\t\t</tbody>\n\t\t\t</table>\n\n\t\t\t<!-- 17:00-->\n\t\t\t<table class=\"recruit_schedule_area\">\n\t\t\t\t<tbody>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item1_img\"><img src=\"/images/recruit/pic_schedule_clock_1700.png\" alt=\"17:00\" width=\"79\" height=\"77\"></td>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item1_time\">17:00</td>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item2\"><p>編集</p></td>\n\t\t\t\t\t\t<td rowspan=\"2\" class=\"recruit_schedule_area_item3\"><img src=\"/images/recruit/pic_schedule_radioD_E.png\" alt=\"ディレクターE\" width=\"268\" height=\"179\"></td>\n\t\t\t\t\t</tr>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<td></td>\n\t\t\t\t\t\t<td></td>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item4\">\n\t\t\t\t\t\t\t<div class=\"recruit_schedule_text\">\n\t\t\t\t\t\t\t\t次の日の放送に使用するVTRを編集。映像音声の編集のほか、ナレーション原稿作成・BGM選曲・テロップの発注を行います。テロップや内容に間違いがないか複数人でチェックをしています。\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</td>\n\t\t\t\t\t</tr>\n\t\t\t\t</tbody>\n\t\t\t</table>\n\n\t\t\t<div class=\"recruit_schedule_comment_area\">\n\t\t\t\t<div class=\"recruit_schedule_comment_img\">\n\t\t\t\t\t<img src=\"/images/recruit/pic_schedule_radioD_m.png\" alt=\"\" width=\"125\" height=\"125\">\n\t\t\t\t</div>\n\t\t\t\t<div class=\"recruit_schedule_comment_text\">\n\t\t\t\t\t毎日生放送をしていく中で、「視聴者は何を観たいのか」「何を知りたいのか」「青森でいま何が起きているのか」を常に考えながら番組を制作しています。ときには苦労して作ったVTRをカットし、最新の情報を入れることもあります。それでも観ている人のためになったと思えるような番組が放送できれば疲れも吹き飛びます。また、畑や工場、海や山とさまざまなところに取材に行き、普通に生活していたら話をすることができない方とお話したり、見ることができない景色を見られるのもテレビディレクターの醍醐味です。\n\t\t\t\t</div>\n\t\t\t\t<div class=\"fclear\"></div>\n\t\t\t</div>\n\n\t\t</div>\n\n\t\t<!-- 編成編 -->\n\t\t<div id=\"organization\" class=\"recruit_schedule_content_area1\">\n\n\t\t\t<div class=\"recruit_schedule_img_block\">\n\t\t\t\t<img src=\"/images/recruit/pic_schedule_titleimg03.png\" alt=\"編成編\" width=\"960\" height=\"437\">\n\t\t\t</div>\n\n\t\t\t<!-- スケジュール -->\n\t\t\t<!-- 09:00-->\n\t\t\t<table class=\"recruit_schedule_area\">\n\t\t\t\t<tbody>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item1_img\"><img src=\"/images/recruit/pic_schedule_clock_0900.png\" alt=\"09:00\" width=\"79\" height=\"77\"></td>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item1_time\">09:00</td>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item2\"><p>放送済みの結果取り込み</p></td>\n\t\t\t\t\t\t<td rowspan=\"2\" class=\"recruit_schedule_area_item3\"><img src=\"/images/recruit/pic_schedule_organization_A.png\" alt=\"編成A\" width=\"268\" height=\"179\"></td>\n\t\t\t\t\t</tr>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<td></td>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item1_bar\"></td>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item4\">\n\t\t\t\t\t\t\t<div class=\"recruit_schedule_text\">\n\t\t\t\t\t\t\t\t放送されたデータに問題がなかったか確認をします。<br>\n\t\t\t\t\t\t\t\t異常があったら即対応をします。\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</td>\n\t\t\t\t\t</tr>\n\t\t\t\t</tbody>\n\t\t\t</table>\n\n\t\t\t<!-- 10:00-->\n\t\t\t<table class=\"recruit_schedule_area\">\n\t\t\t\t<tbody>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item1_img\"><img src=\"/images/recruit/pic_schedule_clock_1000.png\" alt=\"10:00\" width=\"79\" height=\"77\"></td>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item1_time\">10:00</td>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item2\"><p>放送データ作成</p></td>\n\t\t\t\t\t\t<td rowspan=\"2\" class=\"recruit_schedule_area_item3\"><img src=\"/images/recruit/pic_schedule_organization_B.png\" alt=\"編成B\" width=\"268\" height=\"179\"></td>\n\t\t\t\t\t</tr>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<td></td>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item1_bar\"></td>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item4\">\n\t\t\t\t\t\t\t<div class=\"recruit_schedule_text\">\n\t\t\t\t\t\t\t\tこれから放送される番組などのデータを放送に関する資料を見ながらパソコンで作成していきます。\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</td>\n\t\t\t\t\t</tr>\n\t\t\t\t</tbody>\n\t\t\t</table>\n\n\t\t\t<!-- 12:00-->\n\t\t\t<table class=\"recruit_schedule_area\">\n\t\t\t\t<tbody>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item1_img\"><img src=\"/images/recruit/pic_schedule_clock_1200.png\" alt=\"12:00\" width=\"79\" height=\"77\"></td>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item1_time\">12:00</td>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item2\"><p>昼食</p></td>\n\t\t\t\t\t\t<td rowspan=\"2\" class=\"recruit_schedule_area_item3\"><img src=\"/images/recruit/pic_schedule_organization_C.png\" alt=\"編成C\" width=\"268\" height=\"179\"></td>\n\t\t\t\t\t</tr>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<td></td>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item1_bar\"></td>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item4\">\n\t\t\t\t\t\t\t<div class=\"recruit_schedule_text\">\n\t\t\t\t\t\t\t\t売店で日替わりランチを頼みます。<br>\n\t\t\t\t\t\t\t\t何が出てくるかは、毎日の楽しみ♪\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</td>\n\t\t\t\t\t</tr>\n\t\t\t\t</tbody>\n\t\t\t</table>\n\n\t\t\t<!-- 13:00-->\n\t\t\t<table class=\"recruit_schedule_area\">\n\t\t\t\t<tbody>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item1_img\"><img src=\"/images/recruit/pic_schedule_clock_1300.png\" alt=\"13:00\" width=\"79\" height=\"77\"></td>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item1_time\">13:00</td>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item2\"><p>放送データをチェック</p></td>\n\t\t\t\t\t\t<td rowspan=\"2\" class=\"recruit_schedule_area_item3\"><img src=\"/images/recruit/pic_schedule_organization_D.png\" alt=\"編成D\" width=\"268\" height=\"179\"></td>\n\t\t\t\t\t</tr>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<td></td>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item1_bar\"></td>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item4\">\n\t\t\t\t\t\t\t<div class=\"recruit_schedule_text\">\n\t\t\t\t\t\t\t\t午前中は、パソコンでデータを作成しましたが<br>\n\t\t\t\t\t\t\t\tそのあと、作成されたデータに間違いがないかプリントアウトをして入念にチェックをします。<br>\n\t\t\t\t\t\t\t\t一字一句、間違いないかチェックしないと放送事故に直結してしまいます。\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</td>\n\t\t\t\t\t</tr>\n\t\t\t\t</tbody>\n\t\t\t</table>\n\n\t\t\t<!-- 16:00-->\n\t\t\t<table class=\"recruit_schedule_area\">\n\t\t\t\t<tbody>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item1_img\"><img src=\"/images/recruit/pic_schedule_clock_1600.png\" alt=\"16:00\" width=\"79\" height=\"77\"></td>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item1_time\">16:00</td>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item2\"><p>最終チェックをして<br>関連部署に運行表を渡す</p></td>\n\t\t\t\t\t\t<td rowspan=\"2\" class=\"recruit_schedule_area_item3\"><img src=\"/images/recruit/pic_schedule_organization_E.png\" alt=\"編成E\" width=\"268\" height=\"179\"></td>\n\t\t\t\t\t</tr>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<td></td>\n\t\t\t\t\t\t<td></td>\n\t\t\t\t\t\t<td class=\"recruit_schedule_area_item4\">\n\t\t\t\t\t\t\t<div class=\"recruit_schedule_text\">\n\t\t\t\t\t\t\t\t放送がない日はありません。放送するには運行表が必要になります。<br>\n\t\t\t\t\t\t\t\t運行表で放送をリアルタイムで確認している部署、また生放送を運行しているディレクターさんたちに放送運行表を渡します。\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</td>\n\t\t\t\t\t</tr>\n\t\t\t\t</tbody>\n\t\t\t</table>\n\n\t\t\t<div class=\"recruit_schedule_comment_area\">\n\t\t\t\t<div class=\"recruit_schedule_comment_img\">\n\t\t\t\t\t<img src=\"/images/recruit/pic_schedule_organization_m.png\" alt=\"\" width=\"125\" height=\"125\">\n\t\t\t\t</div>\n\t\t\t\t<div class=\"recruit_schedule_comment_text\">\n\t\t\t\t\tテレビ編成部の中でも私の仕事は一部に過ぎません。<br>\n\t\t\t\t\t放送を出すまでには様々な仕事があります。どの仕事も「チェック」が欠かせません。<br>\n\t\t\t\t\t一つでも抜けると放送事故につながります。<br>\n\t\t\t\t\t無事放送を送り出すことで、少しでも県民の皆さんの役に立てればと考えながら仕事をしています。\n\t\t\t\t</div>\n\t\t\t\t<div class=\"fclear\"></div>\n\t\t\t</div>\n\n\t\t</div>\n\n\n\t</div>\n</div>\n\n\t<div class=\"recruit_footer_menu\">\n\t\t<div class=\"recruit_footer_line1\">\n\t\t\t<div class=\"recruit_footer_box1 mr20\">\n\t\t\t\t<a href=\"/recruit/introduction.html\"><img src=\"/images/recruit/pic_footer_01.png?date=20260624055040\" width=\"250\" alt=\"青森放送とは\"></a>\n\t\t\t</div>\n\t\t\t<div class=\"recruit_footer_box1 mr20\">\n\t\t\t\t<a href=\"/recruit/job.html\"><img src=\"/images/recruit/pic_footer_02.png?date=20260624055040\" width=\"250\" alt=\"仕事紹介\"></a>\n\t\t\t</div>\n\t\t\t<div class=\"recruit_footer_box1\">\n\t\t\t\t<a href=\"/recruit/schedule.html\"><img src=\"/images/recruit/pic_footer_03_2024.png\" width=\"250\" alt=\"働く1日\"></a>\n\t\t\t</div>\n\t\t\t<div style=\"clear:both\"></div>\n\t\t</div>\n\n\t\t<div style=\"padding-bottom:40px;\"><a href=\"create.html\"><img src=\"/images/recruit/pic_top_link_tsukuru.png?date=20260624055040\" width=\"870\" alt=\"アオモリを創る\"></a></div>\n\n\t\t<div class=\"recruit_footer_line2\">\n\t\t\t<div class=\"recruit_footer_box2 mr20\">\n\t\t\t\t<a href=\"/recruit/question.html\"><img src=\"/images/recruit/pic_footer_04.png?date=20260624055040\" width=\"250\" alt=\"Ｑ＆Ａ\"></a>\n\t\t\t</div>\n\t\t\t<div class=\"recruit_footer_box2 mr20\">\n\t\t\t\t<a href=\"/recruit/requirement.html\"><img src=\"/images/recruit/pic_footer_05.png?date=20260624055040\" width=\"250\" alt=\"募集要項\"></a>\n\t\t\t</div>\n\t\t\t<div class=\"recruit_footer_box2\">\n\t\t\t\t<img src=\"/images/recruit/pic_footer_06.png?date=20260624055040\" width=\"250\" alt=\"お問い合わせ\">\n\t\t\t</div>\n\t\t\t<div style=\"clear:both\"></div>\n\t\t</div>\n\t</div>\n\n\t<!-- フッター -->\n\t<div id=\"footer\">\n\t\t<div class=\"footer-top\"></div>\n\t\t<div id=\"footer-area1\">\n\t\t\t<div id=\"footer-area-m\">\n\t\t\t\t<div class=\"footer-block footer-block-space\">\n\t\t\t\t\t<ul class=\"footer-menu\">\n\t\t\t\t\t\t<li><p><a href=\"/aboutus/\">会社概要</a></p></li>\n\t\t\t\t\t\t<li><p><a href=\"/compliance/\">コンプライアンス憲章</a></p></li>\n\t\t\t\t\t\t<li><p><a href=\"/rights/\">青森放送人権方針</a></p></li>\n\t\t\t\t\t\t<li><p><a href=\"/s-policy/\">利用規約</a></p></li>\n\t\t\t\t\t\t<li><p><a href=\"/privacy/\">個人情報/プライバシー<br>ポリシーについて</a></p></li>\n\t\t\t\t\t\t<li><p><a href=\"/protection/\">青森放送国民保護業務計画</a></p></li>\n\t\t\t\t\t\t<li><p><a href=\"/partnership/\">パートナーシップ構築宣言</a></p></li>\n\t\t\t\t\t\t<li><p><a href=\"/classification/\">放送番組の種別</a></p></li>\n\t\t\t\t\t\t<li><p><a href=\"/standard/\">番組基準</a></p></li>\n\t\t\t\t\t\t<li><p><a href=\"/deliberation/\">番組審議会</a></p></li>\n\t\t\t\t\t\t<li><p><a href=\"/link/\">リンク</a></p></li>\n\t\t\t\t\t\t<li><p><a href=\"/recruit/\">採用情報</a></p></li>\n\t\t\t\t\t\t<li><p><a href=\"/opinion/\">ご意見・ご感想</a></p></li>\n\t\t\t\t\t</ul>\n\t\t\t\t</div>\n\t\t\t\t<div class=\"footer-block footer-block-space\">\n\t\t\t\t\t<ul class=\"footer-menu\">\n\t\t\t\t\t\t<li><p><a href=\"/tv/\">テレビ</a></p></li>\n\t\t\t\t\t\t<li><p><a href=\"/tv/t-bangumi\">テレビ番組表</a></p></li>\n\t\t\t\t\t\t<li><p><a href=\"http://www.minkyo.or.jp/01/nipponnochikara/\" target=\"_blank\">日本のチカラ</a></p></li>\n\t\t\t\t\t\t<li><p><a href=\"/tv/sunday\">サンデー流暮らしの知恵袋</a></p></li>\n\t\t\t\t\t\t<li><p><a href=\"http://www.ntv.co.jp/24h/index.html\" target=\"_blank\">24時間テレビ</a></p></li>\n\n\t\t\t\t\t</ul>\n\t\t\t\t</div>\n\t\t\t\t<div class=\"footer-block footer-block-space\">\n\t\t\t\t\t<ul class=\"footer-menu\">\n\t\t\t\t\t\t<li><p><a href=\"/radio/\">ラジオ</a></p></li>\n\t\t\t\t\t\t<li><p><a href=\"/radio/r-bangumi\">ラジオ番組表</a></p></li>\n\t\t\t\t\t</ul>\n\t\t\t\t</div>\n\t\t\t\t<div class=\"footer-block\">\n\t\t\t\t\t<ul class=\"footer-menu\">\n\t\t\t\t\t\t<li><p><a href=\"/announcer/\">アナウンサー</a></p></li>\n\t\t\t\t\t</ul>\n\t\t\t\t</div>\n\n\n\t\t\t\t<div style=\"clear:both;\"></div>\n\t\t\t</div>\n\t\t</div>\n\t\t<div id=\"footer-area2\">\n\t\t\t<div class=\"footer-area2-in\">\n\t\t\t\t<div class=\"footer-logo\"><img src=\"/images/pic_footer_rablogo.png\" width=\"212\" height=\"33\" alt=\"青森放送\"></div>\n\t\t\t\t<p>030-0965 青森県青森市松森1-8-1</p>\n\t\t\t</div>\n\t\t</div>\n\t\t<div id=\"footer-area3\">\n\t\t\t<div class=\"footer-area3-in\">\n\t\t\t青森放送のホームページの著作権は青森放送および情報提供者に帰属します。<br>\n\t\t\t青森放送のホームページの記事・画像等を無断で転載、または私的範囲を超えて利用することはできません。\n\t\t\t</div>\n\t\t</div>\n\t\t\n\t\t<div id=\"copyright-area\"><div id=\"copyright-area-in\"><div class=\"copyright-text\">&copy; Aomori Broadcasting Corporation</div></div></div>\n\t\t\n\t</div>\n\n</div>\n\n<div id=\"page-top\"><img src=\"/images/icon/page-top.png\" width=\"100%\" /></div>\n\n\n\n\n\n</body>\n</html>","finalUrl":"https://www.rab.co.jp/recruit/schedule.html","rendered":false,"_cachedAt":"2026-06-23T20:50:42.324Z"}