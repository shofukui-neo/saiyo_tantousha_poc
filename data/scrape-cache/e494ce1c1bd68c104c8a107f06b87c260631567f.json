ient--pale-ocean) !important;}.has-electric-grass-gradient-background{background: var(--wp--preset--gradient--electric-grass) !important;}.has-midnight-gradient-background{background: var(--wp--preset--gradient--midnight) !important;}.has-small-font-size{font-size: var(--wp--preset--font-size--small) !important;}.has-medium-font-size{font-size: var(--wp--preset--font-size--medium) !important;}.has-large-font-size{font-size: var(--wp--preset--font-size--large) !important;}.has-x-large-font-size{font-size: var(--wp--preset--font-size--x-large) !important;}\n:where(.wp-block-post-template.is-layout-flex){gap: 1.25em;}:where(.wp-block-post-template.is-layout-grid){gap: 1.25em;}\n:where(.wp-block-columns.is-layout-flex){gap: 2em;}:where(.wp-block-columns.is-layout-grid){gap: 2em;}\n:root :where(.wp-block-pullquote){font-size: 1.5em;line-height: 1.6;}\n</style>\n<script type=\"text/javascript\" src=\"https://www.meikokensetsu.co.jp/common/js/jquery-3.6.4.min.js\" id=\"jquery-js\"></script>\n<script type=\"text/javascript\" src=\"https://www.meikokensetsu.co.jp/common/js/common.js\" id=\"commons-js\"></script>\n<link href='/common/css/base_pc.css' rel='stylesheet' type='text/css' />\n<link href='/common/css/top_pc.css' rel='stylesheet' type='text/css' />\n</head>\n\n<body>\n<div id=\"wrap\">\n<div id=\"header\"></div>\n\n<div id=\"blr\">\n<div id=\"contents\">\n\n<div class=\"main\">\n<div class=\"visualArea\">\n <div id=\"pcMovie\" class=\"spn\">\n\n   <video autoplay loop muted playsinline width=\"100%\" id=\"mvideo\" poster=\"v.jpg\">\n   <source src=\"common/v.mp4\">\n  </video>\n  <p class=\"slideCopy\"><img src=\"image/main_text.png\" width=\"462\" height=\"282\" alt=\"ACT TO BUILD THE FUTURE 未来を築く。\"></p>\n  <p class=\"scroll\"><img src=\"image/main_scroll.png\" width=\"12\" height=\"146\" alt=\"\"></p>\n </div>\n <!--スライドSP版-->\n <div id=\"slideBox\">\n  <div id=\"topslideSp\" class=\"swiper-container\">\n   <div class=\"swiper-wrapper\">\n    <div class=\"swiper-slide\"><img src=\"image/main01_sp.jpg\"></div>\n    <div class=\"swiper-slide\"><img src=\"image/main02_sp.jpg\"></div>\n    <div class=\"swiper-slide\"><img src=\"image/main03_sp.jpg\"></div>\n   </div>\n   <div class=\"swiper-pagination\"></div>\n  </div><!--//ここまで-->\n  <p class=\"slideCopy\"><img src=\"image/main_text.png\" width=\"462\" height=\"282\" alt=\"ACT TO BUILD THE FUTURE 未来を築く。\"></p>\n </div>\n\n\n <div id=\"newsBox\">\n \t  <div class=\"news spn\"><h3>NEWS</h3><div class=\"day\">2026.06.05</div><div class=\"text\"><a href=\"https://www.meikokensetsu.co.jp/data/c0386200d61eecfbb71224ad5a7e8323-1.pdf\" class=\"pdf\" target=\"_blank\">ホームページのお問い合わせ機能一時停止について（PDF：284.2 KB）</a></div><div class=\"more\"><a href=\"/news/\" class=\"ovr\"><img src=\"image/btn_nows_more_w.png\" width=\"90\" height=\"30\" alt=\"MORE\"></a></div>\n   </div>\t</div>\n\n</div><!--//visualArea-->\n\n\n\n<div class=\"linkBox\">\n<h2 class=\"spn\"><img src=\"image/ttl_sol.png\" width=\"650\" height=\"46\" alt=\"SOLUTION\"></h2>\n<div class=\"groupNavi\">\n <a href=\"/company/business/engineering/\" class=\"bg1 ovr\"><p class=\"ttl\">土木部門</p><p>より快適で環境負荷の少ない<br>社会基盤の創造をめざして</p></a>\n <a href=\"/company/business/architect/\" class=\"bg2 ovr\"><p class=\"ttl\">建築部門</p><p>設計・施工からリニューアルまで<br>トータルにサポート</p></a>\n <a href=\"/company/business/railway/\" class=\"bg3 ovr\"><p class=\"ttl\">軌道部門</p><p>安全で快適な輸送を支えつづける<br>という大きな誇りを胸に</p></a>\n <a href=\"http://www.jp-re.japanpost.jp/properties/jptower-nagoya.html\" target=\"_blank\" class=\"bg4 ovr\"><p class=\"ttl\">不動産ビル事業</p><p>日本郵便株式会社と共同で建設。<br>JPタワー名古屋についてはこちら<br><span>※外部サイトへ移動</span></p></a>\n</div>\n\n<!--実績SP版-->\n<div id=\"topPerformanceSP\"><a href=\"/performance/\"><img src=\"image/perf_sp.png\" alt=\"名工建設の実績\"></a></div>\n\n<div class=\"linkArea\">\n <h2 class=\"spn\"><img src=\"image/ttl_about.png\" width=\"276\" height=\"30\" alt=\"ABOUT\"></h2>\n <div class=\"inner\">\n  <div class=\"link-ir\">\n   <img src=\"image/link_img1.jpg\" width=\"600\" height=\"550\" alt=\"\">\n   <div class=\"linkbox ir\">\n    <a href=\"/ir/\" class=\"ovr\">\n    <p class=\"ttl\">I R</p>\n    <p>株主・投資家のみなさまへ、<br>名工建設の経営に関する<br>情報をお届けします。</p>\n    <div class=\"btn\">MORE</div>\n    </a>\n   </div>\n  </div>\n  <div class=\"link-csr\">\n   <img src=\"image/link_img2.jpg\" width=\"350\" height=\"420\" alt=\"\">\n   <div class=\"linkbox csr\">\n    <a href=\"/csr/\" class=\"ovr\">\n    <p class=\"ttl\">ESG/CSR/SDGs</p>\n    <p>地球をフィールドとして<br>事業展開をする企業としての<br>責任を果たすために。</p>\n    <div class=\"btn\">MORE</div>\n    </a>\n   </div>\n  </div>\n  <div class=\"link-recruit\">\n   <img src=\"image/link_img3.jpg\" width=\"460\" height=\"444\" alt=\"\">\n   <div class=\"linkbox rec\">\n    <a href=\"https://meikokensetsu-recruit.com/\" target=\"_blank\" class=\"ovr\">\n    <p class=\"ttl\">RECRUIT</p>\n    <p>建設を通して「モノづくり」や<br>「社会貢献」に関わりたい方を<br>広く求めています。</p>\n    <div class=\"btn\">MORE</div>\n   </a>\n   </div>\n  </div>\n </div>\n</div>\n</div><!--//linkBox-->\n\n<div class=\"pickupArea\">\n <h3 class=\"pick-t\"><img src=\"image/ttl_pickup.png\" width=\"345\" height=\"30\" alt=\"ピックアップ\"></h3>\n <div class=\"pick-list\">\n <a href=\"/learning-center/\" class=\"pick-banner learning ovr\">\n  <div class=\"btn\">総合技術研修センター</div>\n </a>\n <a href=\"/kids/\" target=\"_blank\" class=\"pick-item ovr\">\n  <div class=\"bnr\"><img src=\"image/btn_pickup_kids.png\" width=\"182\" height=\"82\" alt=\"めいこうキッズ　建設ものしり百科\"></div>\n  <div class=\"text\">\n   <p>お子様に遊びながら名工建設を知っていただけるページです。</p>\n   <div class=\"btn\">MORE</div>\n  </div>\n </a>\n <a href=\"/movie/\" class=\"pick-item ovr\">\n  <div class=\"bnr\"><img src=\"image/btn_pickup_movie.png\" width=\"182\" height=\"82\" alt=\"動画で見る名工建設\"></div>\n  <div class=\"text\">\n   <p>名工建設の事業を動画でよりわかりやすくお伝えします。</p>\n   <div class=\"btn\">MORE</div>\n  </div>\n </a>\n </div>\n</div>\n</div><!--//main-->\n\n<div id=\"footer\"></div>\n</div><!--//contents-->\n</div><!--//blr-->\n</div><!--//wrap-->\n<script type=\"text/javascript\" src=\"https://www.meikokensetsu.co.jp/common/js/jquery.easing.min.js\" id=\"ease-js\"></script>\n<script src='/common/js/velocity2.0.min.js'></script>\n<script src='/common/js/top_pc.js'></script>\n</body>\n</html>","finalUrl":"https://www.meikokensetsu.co.jp/","rendered":false,"_cachedAt":"2026-06-22T21:17:01.014Z"}