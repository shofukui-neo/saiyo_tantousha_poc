itle=\"お問い合わせへ移動\" href=\"https://www.hikarimiso.co.jp/inquiry/\" class=\"post post-page\"><span property=\"name\">お問い合わせ</span></a><meta property=\"position\" content=\"2\"></li><li><span property=\"name\">業務用みそ汁サーバーに関するお問い合わせ</span><meta property=\"position\" content=\"3\"></li></ul>\n</nav>\n</div>\n<!-- /crumb -->\n\r\n\t\t\t<!-- contents_all -->\r\n\t\t\t<article id=\"contents_all\">\r\n    <!-- contents_title_sp -->\r\n    <div id=\"contents_title_sp\">\r\n      <header>\r\n        <h1>業務用みそ汁サーバーに関するお問い合わせ</h1>\r\n      </header>\r\n    </div>\r\n    <!-- /contents_title_sp -->\r\n\r\n    <!-- contents -->\r\n    <div id=\"contents\" class=\"p-opinion__cont\">\r\n      <div id=\"contents_wrap\" class=\"faq_area\">\r\n        <div id=\"contents_main\">\r\n          <div class=\"contents_main_inr\">\r\n            <div class=\"c-btn-block\">\r\n              <div class=\"btnArea\">\r\n                <p class=\"cmn_btn\">\r\n                  <a href=\"/misoserver/\" class=\"btn-yellow\">業務用みそ汁サーバー サイト</a>\r\n                </p>\r\n              </div>\r\n              <p class=\"lineM t-center\">業務用みそ汁サーバーの特長・種類・導入の流れなどをご紹介します。</p>\r\n            </div>\r\n            <form method=\"post\" action=\"\" class=\"h-adr\">\r\n              <span class=\"p-country-name\" style=\"display:none;\">Japan</span>\r\n              <input type=\"text\" class=\"auto-region p-region\" style=\"display:none;\" />\r\n              <input type=\"text\" class=\"auto-city p-locality p-street-address\" style=\"display:none;\" />\r\n              <input type=\"text\" class=\"auto-address p-extended-address\" style=\"display:none;\" />\r\n\r\n              <section class=\"cmn_form\">\r\n                <h2>フォームでのお問い合わせ</h2>\r\n                <p class=\"lineM\">お問い合わせにつきましては土、日、祝祭日<!--、GW期間-->を除く営業時間内で対応させていただきます。<br>\r\n                  いただきましたメールすべてにお返事ができない場合がございますが、ご了承ください。また、お問い合わせの内容によりましては、お返事を差し上げるまでにお時間がかかる場合や、お電話等にてご連絡させていただく場合がございます。<br>\r\n                  弊社から送信させていただきますお客様へのメールは、お客様個人宛てにお答えするものです。<br>\r\n                  弊社の許可なく一部または全部を転用、二次利用することはご遠慮ください。<br>\r\n                  お客様の個人情報は、お客様へのお問い合わせの対応のために利用します。また、お客様の性別および年代に関する情報については、個人を識別・特定できない形で統計的に処理して、マーケティングの検討の参考として利用する場合がございます。</p>\r\n\r\n                <div class=\"form_area\">\r\n                  <div>\r\n                    <section class=\"policy_link\">\r\n                      <a href=\"/privacy/\" target=\"_blank\">ひかり味噌󠄀株式会社のプライバシーポリシー</a>\r\n                    </section>\r\n                    <section class=\"privacy_check\">\r\n                      <span>「お問合せにおける個人情報の取扱いについて」に同意してフォームを入力する</span>\r\n                    </section>\r\n                  </div>\r\n\r\n                  <section id=\"form_aco\" class=\"\">\r\n                    <dl>\r\n                      <dt>お名前<em>必須</em></dt>\r\n                      <dd class=\"\">\r\n                        <p class=\"txt_name\"><input name=\"sei\" type=\"text\" placeholder=\"姓\" value=\"\"><input name=\"mei\" type=\"text\" placeholder=\"名\" value=\"\">\r\n                        </p>                      </dd>\r\n\r\n                      <dt>フリガナ<em>必須</em></dt>\r\n                      <dd class=\"\">\r\n                        <p class=\"txt_name\"><input name=\"sei_kana\" type=\"text\" placeholder=\"セイ\" value=\"\"><input name=\"mei_kana\" type=\"text\" placeholder=\"メイ\" value=\"\"></p>\r\n                                              </dd>\r\n\r\n\r\n                      <dt>会社名・店名</dt>\r\n                      <dd class=\"\">\r\n                        <p class=\"txt_name\"><input name=\"company\" type=\"text\" placeholder=\"会社名・店名\" value=\"\"></p>\r\n                                              </dd>\r\n\r\n                      <dt>フリガナ</dt>\r\n                      <dd class=\"\">\r\n                        <p class=\"txt_name\"><input name=\"company_kana\" type=\"text\" placeholder=\"カイシャメイ・テンメイ\" value=\"\"></p>\r\n                                              </dd>\r\n\r\n      