{"url":"https://www.tis-web.co.jp/recruit/inv05.html","html":"<!DOCTYPE html>\n<html lang=\"ja\" prefix=\"og: http://ogp.me/ns#\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta content=\"IE=edge\" http-equiv=\"X-UA-Compatible\">\n    <meta content=\"initial-scale=1,width=device-width\" name=\"viewport\">\n    <title>株式会社ティ・アイ・エス新卒採用</title>\n    <link href=\"#\" rel=\"canonical\">\n    <meta content=\"株式会社ティ・アイ・エスの採用特設サイトです。福岡・佐賀を拠点に産業機械製作のFA事業、太陽光発電システム販売・メンテナンスの太陽光事業、機器の導入支援・メンテナンスのサービス事業を行っている企業です。\" name=\"description\">\n    <meta content=\"ja_JP\" property=\"og:locale\">\n    <meta content=\"株式会社ティ・アイ・エス新卒採用\" property=\"og:site_name\">\n    <meta content=\"株式会社ティ・アイ・エス新卒採用\" property=\"og:title\">\n    <meta content=\"website\" property=\"og:type\">\n    <meta content=\"#\" property=\"og:url\">\n    <meta content=\"assets/images/ogimage.jpg\" property=\"og:image\">\n    <meta content=\"株式会社ティ・アイ・エスの採用特設サイトです。福岡・佐賀を拠点に産業機械製作のFA事業、太陽光発電システム販売・メンテナンスの太陽光事業、機器の導入支援・メンテナンスのサービス事業を行っている企業です。\" property=\"og:description\">\n    <meta content=\"summary_large_image\" name=\"twitter:card\">\n    <meta content=\"株式会社ティ・アイ・エス新卒採用\" name=\"twitter:title\">\n    <meta content=\"株式会社ティ・アイ・エスの採用特設サイトです。福岡・佐賀を拠点に産業機械製作のFA事業、太陽光発電システム販売・メンテナンスの太陽光事業、機器の導入支援・メンテナンスのサービス事業を行っている企業です。\" name=\"twitter:description\">\n    <meta content=\"assets/images/ogimage.jpg\" name=\"twitter:image\">\n    <link href=\"assets/css/style.css\" rel=\"stylesheet\">\n    <script src=\"https://ajax.googleapis.com/ajax/libs/jquery/2.2.4/jquery.min.js\"></script>\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n    <link href=\"https://fonts.googleapis.com/css2?family=Azeret+Mono:wght@700&family=Rubik+Mono+One&display=swap\" rel=\"stylesheet\">\n    <link rel=\"apple-touch-icon\" sizes=\"180x180\" href=\"assets/images/icon/apple-touch-icon.png\">\n    <link rel=\"icon\" type=\"image/png\" sizes=\"32x32\" href=\"assets/images/icon/favicon-32x32.png\">\n    <link rel=\"icon\" type=\"image/png\" sizes=\"16x16\" href=\"assets/images/icon/favicon-16x16.png\">\n    <link rel=\"manifest\" href=\"assets/images/icon/site.webmanifest.txt\">\n    <link rel=\"mask-icon\" href=\"assets/images/icon/safari-pinned-tab.svg\" color=\"#615ea8\">\n    <meta name=\"msapplication-TileColor\" content=\"#615ea8\">\n    <meta name=\"theme-color\" content=\"#ffffff\">\n</head>\n<body id=\"top\">\n\n  <div class=\"inv05 page-inv\">\n\n    <header class=\"header add-scrolled add-reverse\" id=\"header\">\n      <div class=\"header-inner\">\n  \n          <div class=\"header-ttl\">\n              <a class=\"header-ttlLink\" href=\"index.html\"><img src=\"assets/images/tis_logo.png\"><span>Recruit Site</span></a>\n          </div>\n  \n          <nav class=\"header-nav\">\n              <button class=\"header-closeButton\" id=\"js-header_closeBtn\" type=\"button\">\n                  <span></span>\n                  <span></span>\n              </button>\n              <ul class=\"header-list\">\n                  <li class=\"header-item\">\n                      <div class=\"header-item_ttl\"><a class=\"header-itemLink-top js-unlink\" href=\"index.html#mission\">ビジョン</a></div>\n                  </li>\n                  <li class=\"header-item\">\n                      <div class=\"header-item_ttl\"><a class=\"header-itemLink-top js-unlink\" href=\"index.html#message\">メッセージ</a></div>\n                  </li>\n                  <li class=\"header-item\">\n                      <div class=\"header-item_ttl\"><a class=\"header-itemLink-top js-unlink\" href=\"index.html#business\">事業内容</a></div>\n                  </li>\n                  <li class=\"header-item\">\n                      <div class=\"header-item_ttl\"><a class=\"header-itemLink-top js-unlink\" href=\"index.html#interview\">社員インタビュー</a></div>\n                  </li>\n                  <li class=\"header-item\">\n                      <div class=\"header-item_ttl\"><a class=\"header-itemLink-top js-unlink\" href=\"index.html#culture\">TISの文化</a></div>\n                  </li>\n                  <li class=\"header-item\">\n                      <div class=\"header-item_ttl\"><a class=\"header-itemLink-top js-unlink\" href=\"index.html#company\">会社概要</a></div>\n                  </li>\n                  <li class=\"header-item\">\n                      <div class=\"header-item_ttl\"><a class=\"header-itemLink-top js-unlink\" href=\"recruit.html\">採用情報</a></div>\n                  </li>\n                  <li class=\"header-btnarea\">\n                      <a class=\"header-entry\" href=\"entry.html\" ><img src=\"assets/images/entry.svg\" alt=\"\"><tspan>エントリー</tspan>\n                      </a>\n                  </li>\n              </ul>\n          </nav>\n      </div>\n      <button class=\"header-navButton\" id=\"js-header_toggleBtn\" type=\"button\">\n          <span class=\"header-toggleBtn\">\n              <span></span>\n              <span></span>\n              <span></span>\n          </span>\n          <span class=\"header-toggleBtn-txt\">メニュー</span>\n      </button>\n      <a class=\"header-entryButton\" href=\"entry.html\" >\n          <img src=\"assets/images/entry.svg\"><tspan>エントリー</tspan></a>\n      <div class=\"header-bg js-headerBg\" id=\"js-headerBg\"></div>\n    </header>\t\n  \n    <main class=\"project-container mod-crosstalk\">\n        <div class=\"project-boxKv js-kvImage\">\n    <div class=\"project-boxKvInner\">\n      <h1 class=\"project-boxKvTtl js-inView rise add-inView\">\n        <span class=\"project-boxKvTtl-tag\">InterView</span>\n        <span class=\"project-boxKvTtl-ttl\">成長を実感でき<br>やりがいにつながる</span>\n        <span class=\"project-boxKvTtl-ttl-name\">サービス事業部 西村さん</span>\n      </h1>\n    </div>\n  </div>\n  <div class=\"personal\">\n\n    <div class=\"personal-textSide js-inView rise add-inView\">\n      <div class=\"personal-textSide-boxImage\">\n        <img src=\"assets/images/inv05_01.jpg\" class=\"personal-textSide-boxImage_img\" alt=\"\">\n      </div>\n      <div class=\"personal-textSide-boxText\">\n        <h2 class=\"personal-textSide-boxText_ttl\">仕事内容について教えてください。</h2>\n        <p class=\"personal-textSide-boxText_txt\">大手電機メーカーの協力会社として、高密度・高加工率・高品質の電子部品実装ライン全体を管理するシステムの開発評価、導入支援を行っています。</p>\n        <p class=\"personal-textSide-boxText_txt\">例えば、お客様の求めるシステム実現に向けて検討したり、確認テストを行い、不具合・懸念点があれば報告書を作成したりします。</p>\n        <p class=\"personal-textSide-boxText_txt\">海外とのやり取りもあるので、英語で資料を作ることもあります。私自身は、新入社員のトレーニング計画の作成・サポートなど、幅広い業務に携わっています。</p>\n      </div>\n    </div>\n    \n    <div class=\"personal-textTop js-inView rise add-inView\">\n      <div class=\"personal-textTop-boxText\">\n        <h2 class=\"personal-textTop-boxText_ttl team-feature__desc\">入社後のギャップを教えてください。</h2>\n        <p class=\"personal-textSide-boxText_txt\">いい意味でギャップがありました。もともとソフトウェアやシステムの開発がしたいと思い入社し、現在、希望通りの3グループに所属しています。ソフトウェアやシステムの開発はプログラミングばかりだと思っていましたが、プログラミングだけでなく、要求の検討やテストといった工程の大切さを学ぶことができ、興味の幅が非常に広がりました。</p>\n        <h2 class=\"personal-textTop-boxText_ttl team-feature__desc\">入社の決め手は？</h2>\n        <p class=\"personal-textSide-boxText_txt\">高専時代は、ハードやメカを学び、大学ではまちづくりやエネルギーを勉強していたので、エネルギーや環境の分野、ソフト・ハードやメカなど、幅広く興味がありました。</p>\n        <p class=\"personal-textSide-boxText_txt\">FA事業ではゼロからものづくりを行い、サービス事業ではハード、ソフト、メカ全てに対応できるものづくり支援を行っています。エコシステム事業では、太陽光関連の事業も行っており、自分の興味にぴったりの会社だと思い入社を決めました。</p>\n        <p class=\"personal-textSide-boxText_txt\">面接の中で、「他のことに挑戦したくなったら、他のグループや部署に異動もできるのでいつでも相談してください」と言われ、社員の成長を大切にする会社だと感じたことも入社の決め手です。</p>\n        <h2 class=\"personal-textTop-boxText_ttl team-feature__desc\">会社の魅力を教えてください。</h2>\n        <p class=\"personal-textSide-boxText_txt\">思いやりの心、気遣いの心を大切にしていて、その想いを持った社員が多いことです。相談がある時にいやな顔をせず、むしろ積極的に教えてくれて、一緒に考えてくれます。困っている時にすぐに声をかけてくれて、働きやすい会社です。</p>\n        <p class=\"personal-textSide-boxText_txt\">また、社員1人1人の成長を大切にしてくれている環境です。自分のキャリアについて面談で話す機会があり、目指したい姿を伝えるとキャリア形成につながる仕事をまかせてもらえます。以前、マネジメントをしてみたいと話をしたところ、新入社員のトレーニング計画の作成、サポートを任せてもらいました。</p>\n        <h2 class=\"personal-textTop-boxText_ttl team-feature__desc\">仕事の大変さとやりがいについて教えてください。</h2>\n        <p class=\"personal-textSide-boxText_txt\">1人1人に求められるスキルが多く、いろんなことを学ばないといけないので大変ですが、そこが楽しい部分です。</p>\n        <p class=\"personal-textSide-boxText_txt\">私は、工場全体を最適化するシステムに関わっていますが、様々なシステムや工場内の設備との連携もあるため、幅広い知識が必要です。知識を身に付けるために、勉強し続けないといけないですが、その分、成長を実感でき、やりがいにつながっています。</p>\n        <p class=\"personal-textSide-boxText_txt\">いろんなことに興味があり、勉強することが嫌いじゃない人が向いていると思います。</p>\n      </div>\n    </div>\n  \n    <div class=\"personal-textSide-left js-inView rise add-inView\">\n      <div class=\"personal-textSide-boxText mod-left\">\n        <h2 class=\"personal-textSide-boxText_ttl\">今後のキャリアについて</h2>\n        <p class=\"personal-textSide-boxText_txt\">技術力を極めていきたいです。今は、先輩に助けられることが多いので、先輩の技術をたくさん盗んで、早く一人前のエンジニアになりたいと考えています。</p>\n        <p class=\"personal-textSide-boxText_txt\">仕事終わりは勉強・スキルアップの時間にあてていて、少しでも早く1人前の技術者になりたいです。数年後には、マネジメント能力を身につけ、組織全体を引っ張れる存在になっていきたいです。</p>\n      </div>\n      <div class=\"personal-textSide-boxImage mod-right\">\n        <img src=\"assets/images/inv05_02.jpg\" class=\"personal-textSide-boxImage_img\" alt=\"\">\n      </div>\n    </div>\n  </div>\n<section class=\"entryBtn\">\n  <div class=\"l-actions\">\n      <a class=\"common-btn\" href=\"index.html#interview\"><span>社員インタビューに戻る</span></a>\n  </div>    \n</section>  \n</main>\n    </div>\n    <footer class=\"footer\" id=\"js-footer\">\n      <div class=\"pagetop\">\n          <a href=\"#top\"><span><small>PAGE TOP</small></span></a>\n      </div>\n    <div class=\"footer-inner\">\n      <ul class=\"footer-list\">\n        <li class=\"footer-item\">\n          <dl class=\"footer-boxList\">\n            <dt class=\"footer-boxItem_ttl\"><a class=\"footer-itemLink\" href=\"index.html#mission\">ビジョン</a></dt>\n          </dl>\n        </li>\n        <li class=\"footer-item\">\n          <dl class=\"footer-boxList\">\n            <dt class=\"footer-boxItem_ttl\"><a class=\"footer-itemLink\" href=\"index.html#message\">メッセージ</a></dt>\n          </dl>\n        </li>\n        <li class=\"footer-item\">\n          <dl class=\"footer-boxList\">\n            <dt class=\"footer-boxItem_ttl\"><a class=\"footer-itemLink\" href=\"index.html#business\">事業内容</a>\n            </dt>\n            <dd class=\"footer-boxItem\">\n              <a class=\"footer-boxItemLink\" href=\"bs_fa.html\">FA事業の仕事</a>\n            </dd>\n            <dd class=\"footer-boxItem\">\n              <a class=\"footer-boxItemLink\" href=\"bs_ser.html\">サービス事業の仕事</a>\n            </dd>\n            <dd class=\"footer-boxItem\">\n              <a class=\"footer-boxItemLink\" href=\"bs_eco.html\">エコシステム事業の仕事</a>\n            </dd>\n          </dl>\n        </li>\n        <li class=\"footer-item\">\n          <dl class=\"footer-boxList\">\n            <dt class=\"footer-boxItem_ttl\"><a class=\"footer-itemLink\" href=\"index.html#interview\">社員インタビュー</a></dt>\n            <dd class=\"footer-boxItem\">\n              <a class=\"footer-boxItemLink\" href=\"crosstalk.html\">若手クロストーク</a>\n            </dd>\n          </dl>\n        </li>\n        <li class=\"footer-item\">\n          <dl class=\"footer-boxList\">\n            <dt class=\"footer-boxItem_ttl\"><a class=\"footer-itemLink\" href=\"index.html#culture\">TISの文化</a></dt>\n          </dl>\n        </li>\n        <li class=\"footer-item\">\n          <dl class=\"footer-boxList\">\n            <dt class=\"footer-boxItem_ttl\"><a class=\"footer-itemLink\" href=\"index.html#company\">会社概要</a></dt>\n          </dl>\n        </li>\n              <li class=\"footer-item\">\n          <div class=\"footer-boxList\">\n            <div class=\"footer-boxItem_ttl\"><a class=\"footer-itemLink\" href=\"recruit.html\">採用情報</a></div>\n          </div>\n          <div class=\"footer-boxList\">\n            <div class=\"footer-boxItem_ttl\"><a class=\"footer-itemLink\" href=\"https://www.tis-web.co.jp/\" target=\"_blank\">コーポレートサイト</a></div>\n          </div>\n        </li>\n      </ul>\n      <div class=\"footer_logo\">\n        <a class=\"footer_logoLink\" href=\"https://www.tis-web.co.jp/\" target=\"_blank\">\n          <img alt=\"株式会社ティ・アイ・エス\" src=\"assets/images/tis_logo.png\" class=\"footer_logoImg\">\n        </a>\n      </div>\n      <p class=\"footer_copyright\">Copyright © Technical Information Service Co.,LTD</p>\n    </div>\n    </footer>\n    <script src=\"assets/js/common.js\"></script>\n</body>\n</html>","finalUrl":"https://www.tis-web.co.jp/recruit/inv05.html","rendered":false,"_cachedAt":"2026-06-22T18:56:06.921Z"}