nglish/\">ENGLISH</a></li>\n        <li><a href=\"/cp/site_map.html\">サイトマップ</a></li>\n      </ul>\n    </div>\n<!-- end of id(spnav) -->\n</div>\n<div id=\"cover\"></div>\n\t\t\r\n\t<nav id=\"nav\">\r\n\t\t<ul>\r\n\t\t\t<li id=\"nav1\"><a href=\"/\">HOME</a></li>\r\n\t\t\t<li id=\"nav2\"><a href=\"/automobile/\">自動車部品</a></li>\r\n\t\t\t<li id=\"nav3\"><a href=\"/lock/\">住宅・産業用ロック</a></li>\r\n\t\t\t<li id=\"nav4\"><a href=\"/locker/\">ロッカー</a></li>\r\n\t\t\t<li id=\"nav5\"><a href=\"/cp/kurashino.html\">暮らしのそばに…アルファ</a></li>\r\n\t\t</ul>\r\n\t<!-- end of id(nav) -->\r\n\t</nav>\n\n\t\n\t<div id=\"pankuzu\">\n\t\t<ul>\n\t\t\t<li><a href=\"/\">HOME</a></li>\n\t\t\t<li><a href=\"/cp/\">企業情報</a></li>\n\t\t\t\n\t\t\t\n\t\t\t<li>ごあいさつ</li>\n\t\t</ul>\n\t\n\t\t<div id=\"btnprint\"><a href=\"javascript:window.print();\">印刷をする</a></div>\n\t<!-- end of id(pankuzu) -->\n\t</div>\n\t<div id=\"mainArea\">\n\t\t<div id=\"contents\">\n\t\t\t<div id=\"incontents\">\n\t\t\t\t<div id=\"ttl\">\n\t\t\t\t\t\n\t\t\t\t\t\n\t\t\t\t\t\t\n\t\t\t\t\t\t<h1>企業情報</h1>\n\t\t\t\t\t\t\n\t\t\t\t\t\n\t\t\t\t<!-- end of id(ttl) -->\n\t\t\t\t</div>\n\t\t\t\t<div class=\"txtbox\">\n\t\t\t\t\t\n\t\t\t\t\t\t\n\t\t\t\t\t\t\n\t\t\t\t\t\t<h2>ごあいさつ</h2>\n\t\t\t\t\t\t\n\t\t\t\t\t\n\t\t\t\t<!-- InstanceBeginEditable name=\"maincontents\" -->\n\t\t\t\t<div><img src=\"img/img_message01.png\" width=\"715\" height=\"450\" alt=\"\" class=\"imgper100\"></div>\n\t\t\t\t<h3>目指すものがあるからひとは集い、ひとは挑戦することが可能になる。</h3>\n\t\t\t\t<p>2023年4月に発表した100年宣言　<span class=\"blue\">“世界の巡りを良くしよう”</span>　に基づき、その先の未来に寄せてALPHA VISION2030をより具体的に、そして成長を果たすために、我々Team ALPHA全従業員は挑戦し続けて参ります。</p>\n                <p>変動性が激しく、不確実性が高まり、より複雑性が増し、多くの選択肢が出てくる曖昧な時代を如何に乗り越え、<br>その先の未来に挑戦できる環境にするか我々の底力が試される時代になっております。</p>\n\t\t\t\t<p>\n\t\t\t\t\tはじまりは1本の鍵でした。その技術が・・・培ってきた品質が住宅事業、自動車事業、ロッカー事業に活かされ、生体認証・タッチ式・非接触認証へと、常に人々が最初に触れるドアハンドル・取手と共に進化を遂げて参りました。<br>\n\t\t\t\t\tこれが人々の暮らしの支えとなり、安心して移動できる社会の醸成に貢献する我々の使命だと受け止めております。\n\t\t\t\t</p>\n\t\t\t\t<p>\n\t\t\t\t\tこの変動性が激しい時代だからこそ「将来を見据え、中期を捉え、足元の結果を残すこと。」これが、目指すものを具現化し、挑戦することが可能になる環境を築くことに繋がります。<br>\n\t\t\t\t\tその上で、“視座を高く持ち、広い視野でものごとを捉え、柔らかい視点で考える”ということを常に心がけ、先見性をさらに磨きをかけTeam ALPHA全員で力を合わせ、この時代を乗り越えて参ります。\n\t\t\t\t</p>\n\t\t\t\t<p>皆さまには、今後ともより一層のご指導ご鞭撻を賜りますようお願い申し上げ、次の100 年も、皆さまに選ばれ続けられるよう精進して参ります。</p>\n\t\t\t\t<p style=\"text-align: right;\">代表取締役社長執行役員 塚野 哲幸<br><img src=\"img/img_message_sign.png\" width=\"95\" height=\"95\" alt=\"\"></p>\n\n\t\t\t\t<h3>関連リンク</h3>\n\t\t\t\t<ul class=\"list2\">\n\t\t\t\t\t<li><a href=\"/ir/greeting.html\">株主・投資家の皆様へ</a></li>\n\t\t\t\t</ul>\n\t\t\t\t<!-- InstanceEndEditable -->\n\t\t\t\t\t\t\t\n\t\t\t\t<!-- end of class(txtbox) -->\n\t\t\t\t</div>\n\t\t\t<!-- end of id(incontents) -->\n\t\t\t</div>\n\t\t\t<div id=\"side\">\n\t\t\t\t\n\t\t\t\t\t\n\t\t\t\t\t\t\t\t\t\t<div id=\"sidettl\">\n\t\t\t\t\t<a href=\"/cp/\">企業情報</a>\n\t\t\t\t<!-- end of id(sidettl) -->\n\t\t\t\t</div>\n\t\t\t\t<div id=\"bgside\">\n\t\t\t\t\t<ul>\n          \n\t\t\t\t\t\t<li><a href=\"/cp/message.html\">ごあいさつ</a></li>\n\t\t\t\t\t\t\n            <li><a href=\"/cp/philosophy.html\">企業理念</a></li>\n            \n\t\t\t\t\t\t<li><a href=\"/cp/about/\">会社概要</a>\n\t\t\t\t\t\t<ul>\n\t\t\t\t\t\t\t<li><a href=\"/cp/about/office.html\">事業所紹介</a></li>\n\t\t\t\t\t\t</ul></li>\n            \n            \n\t\t\t\t\t\t<li><a href=\"/cp/group/global.html\">グローバルネットワーク</a>\n              <ul>\n                <li><a href=\"/cp/group/global.html\">海外</a></li>\n                <li><a href=\"/cp/group/\">国内</a></li>\n              </ul></li>\n              \n\t\t\t\t\t\t<li><a href=\"/cp/officer.html\">役員一覧</a></li>\n\t\t\t\t\t\t\n\t\t\t\t\t\t\n\t\t\t\t\t\t<li><a href=\"/cp/history.html\">沿革</a></li>\n            \n\t\t\t\t\t\t<li><a href=\"/cp/technology/\">アルファの技術</a>\n              <ul>\n                <li><a href=\"/cp/technology/\">開発技術</a></li>\n                <li><a href=\"/cp/technology/production.html\">生産技術</a></li>\n              </ul></li>\n              \n\t\t\t\t\t\t<li><a href