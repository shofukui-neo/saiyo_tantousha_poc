{"url":"https://www.nippon-shinyaku.co.jp/recruit/disabilities/","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n  <head><script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);})(window,document,'script','dataLayer','GTM-NBTS97L');</script>\n\n    <meta charset=\"UTF-8\">\n    <title>障がい者採用｜日本新薬株式会社 | 新卒採用サイト</title>\n    <meta name=\"description\" content=\"日本新薬株式会社 | 新卒採用サイトの障がい者採用のページです｡京都発のグローバルヘルスケアカンパニー、日本新薬の新卒採用サイトです｡患者さんのために挑戦し続ける社員の想いや企業理念、各職種の仕事内容・福利厚生・研修制度にいたるまで、詳しくご紹介しております｡\">\n    <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n    <meta name=\"format-detection\" content=\"telephone=no\">\n    <meta property=\"og:locale\" content=\"ja_JP\">\n    <meta property=\"og:type\" content=\"website\">\n    <meta property=\"og:title\" content=\"障がい者採用｜日本新薬株式会社 | 新卒採用サイト\">\n    <meta property=\"og:site_name\" content=\"障がい者採用｜日本新薬株式会社 | 新卒採用サイト\">\n    <meta property=\"og:description\" content=\"日本新薬株式会社 | 新卒採用サイトの障がい者採用のページです｡京都発のグローバルヘルスケアカンパニー、日本新薬の新卒採用サイトです｡患者さんのために挑戦し続ける社員の想いや企業理念、各職種の仕事内容・福利厚生・研修制度にいたるまで、詳しくご紹介しております｡\">\n    <meta property=\"og:url\" content=\"https://www.nippon-shinyaku.co.jp/recruit/disabilities/\">\n    <meta property=\"og:image\" content=\"https://www.nippon-shinyaku.co.jp/recruit/assets/images/ogp.png\">\n    <link href=\"../assets/images/favicon.ico\" rel=\"icon\"/>\n    <link href=\"../assets/images/web-clipicon.png\" rel=\"apple-touch-icon\"/>\n    <link href=\"../assets/css/app.css\" rel=\"preload\" as=\"style\" onload=\"this.onload=null;this.rel='stylesheet'\"/>\n    <link href=\"../assets/css/fonts.css\" rel=\"stylesheet\" media=\"print\" onload=\"this.media='all'\"/>\n    <link href=\"../assets/css/style.css\" rel=\"stylesheet\"/>\n    <link href=\"../assets/css/print.css\" rel=\"stylesheet\" media=\"print\"/><script src=\"https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js\"></script>\n  </head>\n  <body class=\"disabilities\"><noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-NBTS97L\" height=\"0\" width=\"0\" style=\"display:none;visibility:hidden\" title=\"GTM\"></iframe></noscript>\r\n    <button class=\"c-slidebar-button  js-slidebar-button\" type=\"button\">\n      <span class=\"c-slidebar-button__inner\">\n        <span class=\"c-slidebar-button__line\">\n        </span>\n      </span>\n    </button>\n    <div class=\"c-slidebar-menu  js-slidebar-menu\" inert=\"inert\" data-lenis-prevent=\"data-lenis-prevent\">\n      <div class=\"c-slidebar-menu__inner\">\n        <ul class=\"c-slidebar-menu__list\">\n          <li class=\"c-slidebar-menu__parent\"><a class=\"c-slidebar-menu__parent-link\" href=\"#section01\">働く環境</a>\n          </li>\n          <li class=\"c-slidebar-menu__parent\"><a class=\"c-slidebar-menu__parent-link\" href=\"../message/\">採用メッセージ</a>\n          </li>\n        </ul>\n        <div class=\"c-slidebar-menu__buttons\">\n          <div class=\"c-slidebar-menu__button\"><a class=\"is-button\" href=\"#section02\">募集要項</a>\n          </div>\n        </div>\n      </div>\n    </div>\n    <div class=\"l-root-container\">\n      <header class=\"l-header js-fixedheader is-enter-ready is-enter-hidden\">\n        <div class=\"l-header__content is-lp\">\n          <div class=\"l-header__logo-wrapper\">\n            <div class=\"l-header__logo is-lg\"><a class=\"js-anchor\" href=\"#top\" data-anchor-target=\"html\" aria-label=\"ページ上部に戻る\"><img src=\"../assets/images/logo-disabilities.svg\" alt=\"日本新薬株式会社\" width=\"171\" height=\"56\"/></a>\n            </div>\n            <div class=\"l-header__logo-text\">障がい者採用</div>\n          </div>\n          <nav class=\"l-header__nav\">\n            <div class=\"l-header__nav-inner\">\n              <ul class=\"l-header__mainmenu\">\n                <li class=\"l-header__mainmenu-item\"><a class=\"js-anchor\" href=\"#section01\">働く環境</a>\n                </li>\n                <li class=\"l-header__mainmenu-item\"><a href=\"../message/\">採用メッセージ</a>\n                </li>\n              </ul>\n            </div><a class=\"js-anchor l-header__button\" href=\"#section02\">募集要項</a>\n          </nav>\n        </div>\n      </header>\n      <main>\n        <div class=\"l-page-header\">\n          <div class=\"l-page-header__container\">\n            <div class=\"l-container\">\n              <div class=\"l-page-header__inner js-animation-head\">\n                <div class=\"l-page-header__eng-title js-animation-head-eng\">Disability-Inclusive Recruitment</div>\n                <h1 class=\"l-page-header__jp-title js-animation-head-ja\">障がい者採用</h1>\n              </div>\n            </div>\n            <div class=\"l-page-header__breadcrumb is-enter-ready is-enter-hidden\">\n              <div class=\"c-breadcrumb\">\n                <div class=\"c-breadcrumb__inner\"><span><span><a href=\"../\">新卒採用TOP</a></span><span class=\"is-arrow\"></span><span>障がい者採用</span></span></div>\n              </div>\n            </div>\n          </div>\n          <div class=\"l-page-header__image is-enter-ready is-enter-hidden\"><img src=\"../assets/images/img-page-header-disabilities.jpg\" alt=\"\"/>\n          </div>\n        </div>\n        <div class=\"l-main\">\n          <section class=\"l-section is-lg\" id=\"section01\">\n            <div class=\"l-container\">\n              <h2 class=\"c-heading is-xlg is-mg-level-4\"><strong class=\"is-ja\">安心して､成長できる場所</strong></h2>\n              <div class=\"u-mbs is-md is-bottom\">\n                <div class=\"u-text-md\">日本新薬は､一人ひとりの｢個性｣と｢成長意欲｣を尊重します｡<br>障がいの有無は関係ありません｡あなたが一人のプロフェッショナルとして輝けるよう､<br>私たちは寄り添い､全力でサポートします｡</div>\n              </div>\n              <div class=\"c-card\">\n                <div class=\"c-card__list\">\n                  <div class=\"c-card__card\">\n                    <div class=\"c-card__number\">01</div>\n                    <div class=\"c-card__head c-heading is-sm is-mg-level-5\">インターンシップ制度</div>\n                    <div class=\"c-card__text is-md\">\n                      <p>短期間と長期間のインターンシップを行っています｡インターンシップ時には､生活リズムの確認や､障がい特性・配慮事項に応じた業務内容や業務時間を確認し､あなたに合った仕事を一緒に探します｡</p>\n                    </div>\n                  </div>\n                  <div class=\"c-card__card\">\n                    <div class=\"c-card__number\">02</div>\n                    <div class=\"c-card__head c-heading is-sm is-mg-level-5\">定着支援</div>\n                    <div class=\"c-card__text is-md\">\n                      <p>専門的な研修を受けた社内障がい者職業生活相談員が職場適応に向けたきめ細やかな支援を行っています｡仕事のことはもちろん､気持ちの悩みなども気軽に相談できるような環境を作っています｡</p>\n                    </div>\n                  </div>\n                  <div class=\"c-card__card\">\n                    <div class=\"c-card__number\">03</div>\n                    <div class=\"c-card__head c-heading is-sm is-mg-level-5\">合理的配慮の提供</div>\n                    <div class=\"c-card__text is-md\">\n                      <p>障がい者手帳の取得及び更新のための離席､通院のための時間単位年休の取得制度を導入しています｡その他､当人が直面している困難や周囲の環境に応じて必要な合理的配慮は異なりますので､申し出があれば人事部にて対応する仕組みを整備しています｡</p>\n                    </div>\n                  </div>\n                </div>\n              </div>\n            </div>\n          </section>\n          <section class=\"l-section is-lg is-bottom\" id=\"section02\">\n            <div class=\"l-container\">\n              <h2 class=\"c-heading is-xlg is-mg-level-4\"><span class=\"is-eng\">Requirements</span><strong class=\"is-ja\">募集要項</strong></h2>\n              <div class=\"u-mbs is-md is-top\">\n                <div class=\"c-accordion\">\n                  <details class=\"c-accordion__block js-accordion\" data-open=\"true\">\n                    <summary class=\"c-accordion__title\" data-accordion-title=\"title\">障がい者専用求人</summary>\n                    <div class=\"c-accordion__content-wrapper\" data-accordion-content=\"content\">\n                      <div class=\"c-accordion__content\">\n                        <div class=\"c-accordion__content-inner\">\n                          <table class=\"c-table\">\n                            <tbody>\n                              <tr>\n                                <th>職務内容</th>\n                                <td>事務補助<br>\n                                  <ul class=\"c-list is-icon\">\n                                    <li>データ入力</li>\n                                    <li>社内資料の電子化業務</li>\n                                    <li>資料作成</li>\n                                    <li>経費精算業務</li>\n                                    <li>メール／チャット対応</li>\n                                    <li>事務作業の自動化シナリオの作成</li>\n                                  </ul><br>軽作業<br>\n                                  <ul class=\"c-list is-icon\">\n                                    <li>清掃業務</li>\n                                    <li>洗濯業務</li>\n                                    <li>仕分け作業</li>\n                                    <li>社内郵便の集配</li>\n                                  </ul>\n                                </td>\n                              </tr>\n                              <tr>\n                                <th>雇用形態</th>\n                                <td>嘱託(有期契約従業員)<br>試用期間3ヵ月</td>\n                              </tr>\n                              <tr>\n                                <th>給与</th>\n                                <td>経験・能力を考慮し､当社規定により算出します。</td>\n                              </tr>\n                              <tr>\n                                <th>勤務地</th>\n                                <td>日本新薬株式会社 京都本社<br>※他エリアは要相談</td>\n                              </tr>\n                              <tr>\n                                <th>勤務形態</th>\n                                <td>9:00〜17:30<br>※フレックスタイム制への移行も可能です｡<br>※時短勤務も可能です｡</td>\n                              </tr>\n                              <tr>\n                                <th>休日休暇</th>\n                                <td>土日、祝日、その他<br>週休二日制(毎週)<br>※年末年始・夏季休暇あり<br>※その他会社が必要と認めた日</td>\n                              </tr>\n                            </tbody>\n                          </table>\n                          <div class=\"u-mbs is-md is-top is-center\"><a class=\"c-button is-xlg is-secondary\" href=\"https://forms.office.com/r/SSHj4rr8u3\" target=\"_blank\">エントリーする<span class=\"is-icon\"></span></a>\n                          </div>\n                        </div>\n                      </div>\n                    </div>\n                  </details>\n                </div>\n              </div>\n            </div>\n          </section>\n        </div>\n        <div class=\"l-offer\">\n          <div class=\"l-container\">\n            <div class=\"l-offer__inner\">\n              <div class=\"l-offer__head\"><img src=\"../assets/images/img-offet-text.svg\" alt=\"\"/>\n              </div>\n              <div class=\"l-offer__content\">\n                <div class=\"l-offer__text\">あなたの一歩が、ひとりの希望になる。<br/>ともに、“新しい生きる”を創ろう。</div>\n                <div class=\"l-offer__content-button\"><a class=\"c-button is-reverse is-lg\" href=\"../requirements/\">募集要項<span class=\"is-icon\"></span></a>\n                </div>\n              </div>\n              <div class=\"l-offer__buttons\">\n                <div class=\"l-offer__button\"><a class=\"c-button\" href=\"../career/\" target=\"_blank\">キャリア採用<span class=\"is-icon\"></span></a>\n                </div>\n                <div class=\"l-offer__button\"><a class=\"c-button\" href=\"../disabilities/\" target=\"_blank\">障がい者採用<span class=\"is-icon\"></span></a>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n        <div class=\"c-breadcrumb is-bottom is-bottom\">\n          <div class=\"l-container\">\n            <div class=\"c-breadcrumb__inner\"><span><span><a href=\"../\">新卒採用TOP</a></span><span class=\"is-arrow\"></span><span>障がい者採用</span></span></div>\n          </div>\n        </div>\n      </main>\n      <footer class=\"l-footer is-lp\">\n        <div class=\"l-footer__inner\">\n          <div class=\"l-container\">\n            <div class=\"l-footer__content\">\n              <div class=\"l-footer__right\">\n                <div class=\"l-footer__links\"><a class=\"l-footer__link\" href=\"../career/\" target=\"_blank\">キャリア採用</a><a class=\"l-footer__link\" href=\"../disabilities/\" target=\"_blank\">障がい者採用</a><a class=\"l-footer__link is-blank\" href=\"https://www.nippon-shinyaku.co.jp/\" target=\"_blank\">コーポレートサイト</a>\n                </div>\n                <div class=\"l-footer__bottom\"><a class=\"l-footer__link\" href=\"../fair-recruitment/\">日本新薬 公正採用方針</a><small class=\"l-footer__copyright\">© NIPPON SHINYAKU CO., LTD.</small>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </footer>\n    </div>\n    <script src=\"../assets/js/app.js\"></script>\n  </body>\n</html>","finalUrl":"https://www.nippon-shinyaku.co.jp/recruit/disabilities/","rendered":false,"_cachedAt":"2026-06-22T22:33:38.419Z"}