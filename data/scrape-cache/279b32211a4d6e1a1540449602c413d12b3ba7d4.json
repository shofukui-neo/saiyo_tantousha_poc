bs-list -->\n    </section>\n\n    <section class=\"parts-section-info\">\n      <div class=\"com-section-inner\">\n        <div class=\"info-detail-wrap\">\n\n                                                <div class=\"info-category-wrap\">\n                <ul class=\"mod-panel-layout info-category-item\">\n                  <li>\n                    <span style=\"color:#023455;background-color:#edf1f2\">\n                      健康経営                    </span>\n                  </li>\n                </ul>\n              </div>\n\n                      \n          <div class=\"info-title\">\n            <h1 class=\"title\">社員の健康状態をチェックするイベントを開催しました！</h1>\n            <p class=\"day\">2026.04.07</p>\n          </div>\n\n          <div class=\"info-body\">\n            <div class=\"def-editor-style-wrap\">\n            <!-- ▼ editor area ▼ -->\n\n                                                                                  <div class=\"mod-clearfix edt-L-img-R-text\">\n                      <div class=\"img-block\">\n                                                                          <img src=\"/upload/save/info/layout/9732ac42969f0c8003c3a376f798240b.jpg\" alt=\"健康チェックイベント02\">\n                                              </div>\n                      <div class=\"text-block\">\n                                                <p class=\"text\">4月7日(火)　広島本社にて社員の健康状態をチェックする社内イベントを行いました。<br>\n今回の社内イベントは、自身の身体の状態を知ることで更なる健康増進につなげようと、住友生命 様ご協力のもと開催。</p>\n                      </div>\n                    </div>\n                    <!-- End .edt-L-img-R-text -->\n\n                                                                        <div class=\"mod-clearfix edt-L-img-R-text\">\n                      <div class=\"img-block\">\n                                                                          <img src=\"/upload/save/info/layout/893d506754960056f7568bb14fa71a93.jpg\" alt=\"健康チェックイベント01\">\n                                              </div>\n                      <div class=\"text-block\">\n                                                <p class=\"text\">広島本社の社員 約40人が参加して ・InBody測定（体組成分析） ・血管年齢測定 ・ベジチェック（推定野菜摂取量測定） ・握力測定の4種類の健康チェックを実施しました。</p>\n                      </div>\n                    </div>\n                    <!-- End .edt-L-img-R-text -->\n\n                                                                        <div class=\"mod-clearfix edt-L-img-R-text\">\n                      <div class=\"img-block\">\n                                                                          <img src=\"/upload/save/info/layout/83b349da684e3e855f0fdbab349068e9.jpg\" alt=\"健康チェックイベント03\">\n                                              </div>\n                      <div class=\"text-block\">\n                                                <p class=\"text\">今回の測定を通じて、自身のからだの状態を多角的に把握することができ、日頃の生活習慣や運動、食事について改めて考えるきっかけとなりました。弊社では、今後も社員の健康増進に向けた取り組みを日々、実践・継続していきます。</p>\n                      </div>\n                    </div>\n                    <!-- End .edt-L-img-R-text -->\n\n                                                \n            <!-- ▲ editor area ▲ -->\n            </div>\n            <!-- End .def-editor-style-wrap -->\n          </div>\n\n        </div>\n        <!-- End .info-body-block -->\n        <div class=\"btn-block back-arrow-style\">\n          <a href=\"/infos/\">\n            <span>一覧へ戻る</span>\n          </a>\n        </div>\n      </div>\n    </section>\n\n  </article>\n  <!-- End #lay-article -->\n</main>\n<!-- End #lay-main -->\n\n    <!-- Start footer -->\n    <div class=\"lay-page-top-wrap\">\n  <a href=\"#\" class=\"lay-page-top\">\n      PAGE<br>TOP\n    <!-- <img src=\"/assets/img/common/page-top.png\" alt=\"PAGE TOP\" class=\"over\"> -->\n  </a>\n</div>\n<!-- End .lay-page-top-wrap -->\n\n<section class=\"footer-contact\">\n  <div class=\"footer-contact-wrap\">\n    <div class=\"footer-contact-inner\">\n      <div class=\"footer-contact-inner-title\">\n        <span class=\"ttl