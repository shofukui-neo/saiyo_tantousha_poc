 <ul class=\"sub-menu\">\r\n              <li class=\"sub-menu-item p-1-3\">\r\n                <a href=\"./about/aboutus.html\"><span>会社情報</span></a>\r\n              </li>\r\n              <li class=\"sub-menu-item p-2-3\">\r\n                <a href=\"./about/number.html\"><span>数字で知るヤマザキ</span></a>\r\n              </li>\r\n              <li class=\"sub-menu-item p-1-3\">\r\n                <a href=\"./about/csr.html\"><span>CSR</span></a>\r\n              </li>\r\n              <li class=\"sub-menu-item\">\r\n                <a href=\"./about/technology.html\"><span>ヤマザキの「技術力」</span></a>\r\n              </li>\r\n            </ul><!-- /.sub-menu -->\r\n          </li>\r\n\r\n          <li class=\"list-item\">\r\n            <div class=\"menu-heading\">\r\n              <a href=\"./recruit/index.html\"><span>ヤマザキの「採用」</span></a>\r\n            </div>\r\n\r\n            <ul class=\"sub-menu\">\r\n              <li class=\"sub-menu-item p-45\">\r\n                <a href=\"./recruit/message.html\"><span>人事メッセージ</span></a>\r\n              </li>\r\n              <li class=\"sub-menu-item p-55\">\r\n                <a href=\"./recruit/bosyu.html\"><span>募集要項（選考の流れ）</span></a>\r\n              </li>\r\n              <li class=\"sub-menu-item\">\r\n                <a href=\"./recruit/faq.html\"><span>Q &amp; A</span></a>\r\n              </li>\r\n            </ul><!-- /.sub-menu -->\r\n          </li>\r\n        </ul>\r\n\r\n        <a class=\"menu-trigger js-main-menu-trigger\"></a>\r\n      </div><!-- /.menu-body -->\r\n    </div><!-- /.main-menu -->\r\n  </nav>\r\n</header>\r\n\r\n<main>\r\n  <div class=\"main-visual\">\r\n    <div class=\"main-visual-image\">\r\n      <img src=\"./assets/images/top/kv_01.jpg\" alt=\"｢新しい価値｣を創造し、食文化を支える誇りはあるか？\" class=\"pc-view\">\r\n      <img src=\"./assets/images/top/kv_01_sp.jpg\" alt=\"｢新しい価値｣を創造し、食文化を支える誇りはあるか？\" class=\"sp-view\">\r\n    </div><!-- /.main-visual-image -->\r\n\r\n    <div class=\"main-visual-content\">\r\n      <p class=\"text\">｢新しい価値｣を<br class=\"sp-view\">創造し、<br>食文化を支える<br class=\"sp-view\">誇りはあるか？</p>\r\n    </div><!-- /.main-visual-content -->\r\n\r\n    <div class=\"main-visual-btn\">\r\n      <a data-path=\"./assets/movie/top_movie.mp4\" class=\"js-movie-modal\">\r\n        <span>ヤマザキの「紹介動画」</span>\r\n      </a>\r\n    </div><!-- /.main-visual-btn -->\r\n  </div><!-- /.main-visual -->\r\n\r\n  <div class=\"m-top-bar\">\r\n    <div class=\"m-top-bar-body\">\r\n      <div class=\"m-top-bar-title\">\r\n        <h1 class=\"title-heading\">高専卒採用情報</h1>\r\n        <p class=\"title-sub\"><span>Technical College</span> Recruitment Information</p>\r\n      </div><!-- /.m-top-bar-title -->\r\n\r\n      <div class=\"m-top-bar-info\">\r\n        <h2 class=\"info-heading\">Information</h2>\r\n        <div class=\"info-list js-info-list\"></div>\r\n      </div><!-- /.m-top-bar-info -->\r\n    </div><!-- /.m-top-bar-body -->\r\n  </div><!-- /.m-top-bar -->\r\n\r\n  <section class=\"m-top-message\">\r\n    <h2 class=\"c-accent-heading\">\r\n      <span class=\"sub\"><span>Yamazaki's</span>MESSAGE</span>\r\n      <span class=\"main\">ヤマザキの「メッセージ」</span>\r\n    </h2>\r\n\r\n    <div class=\"m-top-message-content\">\r\n      <p class=\"text\">\r\n        ヤマザキは創業以来、<br class=\"sp-view\"><b>｢良品廉価｣</b><b>｢顧客本位｣</b>という<br class=\"sp-view\">企業理念を掲げ、<br>\r\n        主食を通じて、食文化を支えています。\r\n      </p>\r\n\r\n      <p class=\"text\">変わりゆく時代の中で、<br class=\"sp-view\">常にお客様の期待に応えたい。</p>\r\n\r\n      <p class=\"text\">\r\n        「常に<b>最高の品質の製品</b>を提供する」<br>\r\n        「前例のない新しい製品を開発し、<br class=\"sp-view\">お客様の<b>新しい需要を創造する</b>」<br>\r\n        「どんな困難があろうとも、<br class=\"sp-view\">製品の供給を<b>決して止めない</b>」<br>\r\n        こうした想いを積み重ね、<b>業界 No.1</b> へと<br class=\"sp-view\">成長を遂げてきました。\r\n      </p>\r\n\r\n      <p class=\"text\">\r\n        なぜ、これが実現できるのか・・・<br>\r\n        それは、生産・物流・販売を一貫して手掛け、<br>\r\n        生産と販売が一体となって仕事に取り組む<br><b>オンリーワンのビジネスモデル</b>があるからです。<br>\r\n      </p>\r\n\r\n      <p class=\"text\">\r\n        いつの時代でもお客様の<br class=\"sp-view\">生活や心に寄り添える存在でありたい。<br>\r\n        私たちは、食が生み出す力を信じて<br class=\"sp-view\">これからも挑戦し続けます。\r\n      </p>\r\n    </div><!-- /.m-top-message-content -->\r\n  </section><!-- /.m-top-message -->\r\n\r\n  <section class=\"m-three-column\">\r\n    <h2 class=\"c-accent-heading\">\r\n      <span class=\"sub\"><span>Yamazaki's</span>WORK</span>\r\n      <a href=\"./work/index.html\" class=\"main link\">ヤマザキの「仕事」</a>\r\n    </h2>\r\n\r\n    <div class=\"m-three-column-content\">\r\n      <div class=\"content-list\">\r\n        <a href=\"./work/index.html#work01\" class=\"content-list-item\">\r\n          <div class=\"image\"><img src=\"./assets/images/top/img_work_01.jpg\" alt=\"生産技術職\"></div>\r\n          <div class=\"content\">\r\n            <h3>生産技術職</h3>\r\n            <p>食パン・菓子パン・<br>和菓子・洋菓子</p>\r\n          </div>\r\n        </a>\r\n\r\n        <a href=\"./work/index.html#work02\" class=\"content-list-item\">\r\n          <div class=\"image\"><img src=\"./assets/images/top/img_work_02.jpg\" alt=\"店舗運営職\"></div>\r\n          <div class=\"content\">\r\n            <h3>エンジニア<br>リング職</h3>\r\n            <p>保全・動力・企画</p>\r\n          </div>\r\n        </a>\r\n\r\n        <a href=\"./work/index.html#work03\" class=\"content-list-item\">\r\n          <div class=\"image\"><img src=\"./assets/images/top/img_work_03.jpg\" alt=\"専門職\"></div>\r\n          <div class=\"content\">\r\n            <h3>社内SE職</h3>\r\n            <p>運用・開発保守・企画</p>\r\n          </div>\r\n        </a>\r\n      </div><!-- /.content-list -->\r\n    </div><!-- /.m-three-column-content -->\r\n\r\n    <aside class=\"m-three-column-aside\">\r\n      <!-- <p><span class=\"yamazaki\">Yamazaki's</span><span class=\"title\">WORK</span></p> -->\r\n    </aside><!-- /.m-three-column-aside -->\r\n  </section><!-- /.m-three-column -->\r\n\r\n  <section class=\"m-top-person\">\r\n    <h2 class=\"c-accent-heading\">\r\n      <span class=\"sub\"><span>Yamazaki's</span>PERSON</span