{"url":"https://www.ktec-akashi.co.jp/company/","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n\n<head>\n  <meta http-equiv=\"X-UA-Compatible\" content=\"ie=edge\">\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <meta name=\"format-detection\" content=\"telephone=no\">\n\n  <link rel=\"icon\" type=\"image/x-icon\" href=\"../assets/img/favicon_16x16px.png\">\n  <link rel=\"apple-touch-icon\" href=\"../assets/img/favicon_180x180px.png\">\n\n  <title>コンタクトフォーム｜KTECリクルートサイト</title>\n  <meta name=\"description\" content=\"株式会社ケイテックのリクルートサイトです。コンタクトフォームです。こちらのフォームより各職種の求人にご応募いただけます。\">\n  <meta name=\"keyword\"\n    content=\"ケイテック,川崎重工,recruit,リクルート,採用,新卒,中途,応募フォーム,デザイン,デザイン開発,3D開発,テクニカルドキュメント,コミュニケーションデザイン,CIコンサルティング,プロモーション企画,環境デザイン\">\n\n  <meta property=\"og:title\" content=\"\">\n  <meta property=\"og:type\" content=\"website\">\n  <meta property=\"og:description\" content=\"\">\n  <meta property=\"og:image\" content=\"https://www.ktec-akashi.co.jp/assets/img/OGP_1200x630px.png\">\n\n  <link rel=\"stylesheet\" type=\"text/css\" href=\"./inquiry/css/style_old.css\">\n  <link rel=\"stylesheet\" type=\"text/css\" href=\"./inquiry/css/contact_pc.css\">\n  <link rel=\"stylesheet\" type=\"text/css\" href=\"./inquiry/css/contact_sp.css\">\n\n  <link rel=\"stylesheet\" type=\"text/css\" href=\"../assets/css/reset.css\">\n  <link rel=\"stylesheet\" type=\"text/css\" href=\"../assets/css/style.css\">\n  <link rel=\"stylesheet\" type=\"text/css\" href=\"../assets/css/contact.css\">\n\n  <!-- webフォントタイムラグを解消 -->\n  <script type='text/javascript' src='../assets/js/webfont.js'></script>\n\n  <!-- Google tag (gtag.js) -->\n  <script async src=\"https://www.googletagmanager.com/gtag/js?id=G-XHJS5KLZ2J\"></script>\n  <script>\n    window.dataLayer = window.dataLayer || [];\n    function gtag() { dataLayer.push(arguments); }\n    gtag('js', new Date());\n\n    gtag('config', 'G-XHJS5KLZ2J');\n  </script>\n\n</head>\n\n<body 