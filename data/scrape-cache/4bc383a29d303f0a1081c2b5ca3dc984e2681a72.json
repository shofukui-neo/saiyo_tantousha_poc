f 2px 1px 5px, #fff -2px 1px 5px,\n    #fff 2px -1px 5px, #fff -2px -1px 5px,\n    #fff 1px 1px 5px, #fff -1px 1px 5px,\n    #fff 1px -1px 5px, #fff -1px -1px 5px;\n}\n\n.link_talent:hover {\n   color:#cc0033;\n   text-decoration:none;\n}\n\n.link_talent:visited {\n   color:#cc0033;\n   text-decoration:none;\n}\n\n.tri::before{\n\tcontent: \"\";\n    padding-left:25px;\nbackground: url(https://www.kbs-web.com/docomo/recruit/wp-content/uploads/sites/2/2017/10/img_tri_red.png\n) no-repeat 0px center;\n}\n\n#content input[type=\"submit\"]:hover {\n\tbackground-color: #ccc;\n}\n\n\n\n\n\t\t</style>\n\t\t\n</head>\n\n<body id=\"\" class=\"page-template page-template-page_full page-template-page_full-php page page-id-142\">\n<div id=\"\">\n\n\n<div class=\"header_wrap\">\n<div id=\"header\">\n<div class=\"logo\">\n<a href=\"https://www.kbs-web.com/docomo/recruit/\"><img src=\"https://www.kbs-web.com/docomo/recruit/wp-content/themes/original2/contents_images/logo.png\" width=\"332px\" height=\"70px\" alt=\"KBSドコモ求人サイト｜株式会社ビジネスサービス\"/></a>\n</div>\n\n<div class=\"navi\">\n\t\t\t<div class=\"textwidget\"><p><a class=\"link_talent tri\" href=\"https://www.kbs-web.com/docomo/recruit/message/matters/\">募集要項・ご応募</a>　　<a href=\"https://www.kbs-web.com/\"><img class=\"image wp-image-41 attachment-full size-full\" style=\"max-width: 100%; height: auto;\" src=\"https://www.kbs-web.com/docomo/recruit/wp-content/uploads/sites/2/2017/09/logo_company.png\" alt=\"\" width=\"242\" height=\"38\" /></a></p>\n</div>\n\t\t</div>\n<div style=\"clear: both;\"></div>\n</div>\n</div>\n\n\n<div id=\"menu\">\n\t<div class=\"menu-main-menu-container\"><ul id=\"menu-main-menu\" class=\"menu\"><li id=\"menu-item-141\" class=\"menu-item menu-item-type-custom menu-item-object-custom menu-item-141\"><a href=\"https://www.kbs-web.com/docomo/recruit/message/\">私たちの想い</a></li>\n<li id=\"menu-item-144\" class=\"menu-item menu-item-type-post_type menu-item-object-page current-menu-item page_item page-item-142 current_page_item menu-item-144\"><a href=\"https://www.kbs-web.com/docomo/recruit/favorite/\" aria-current=\"page\">ココが好き！</a></li>\n<li id=\"menu-item-146\" class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-146\"><a href=\"https://www.kbs-web.com/docomo/recruit/shop/\">ショップ紹介</a></li>\n<li id=\"menu-item-150\" class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-150\"><a href=\"https://www.kbs-web.com/docomo/recruit/company/\">企業情報</a></li>\n</ul></div><div style=\"clear: both;\"></div>\n</div>\n\n<div id=\"wrap\">\n<div id=\"content\" class=\"full\">\n\n\n<h1>ココが好き！</h1>\n\n<div class=\"post\">\n\n<h2>楽しく働ける理由、包み隠さず大公開！</h2>\n<p><img class=\"alignnone size-full wp-image-1225\" src=\"https://www.kbs-web.com/docomo/recruit/wp-content/uploads/sites/2/2025/08/7b2179eb-0463-4577-b768-8caf4153034d.jpg\" alt=\"\" width=\"1472\" height=\"704\" srcset=\"https://www.kbs-web.com/docomo/recruit/wp-content/uploads/sites/2/2025/08/7b2179eb-0463-4577-b768-8caf4153034d.jpg 1472w, https://www.kbs-web.com/docomo/recruit/wp-content/uploads/sites/2/2025/08/7b2179eb-0463-4577-b768-8caf4153034d-300x143.jpg 300w, https://www.kbs-web.com/docomo/recruit/wp-content/uploads/sites/2/2025/08/7b2179eb-0463-4577-b768-8caf4153034d-1024x490.jpg 1024w, https://www.kbs-web.com/docomo/recruit/wp-content/uploads/sites/2/2025/08/7b2179eb-0463-4577-b768-8caf4153034d-768x367.jpg 768w\" sizes=\"(max-width: 1472px) 100vw, 1472px\" /></p>\n<h3>転勤なし！転職理由「青森で働きたい」など大歓迎です！</h3>\n<table cellspacing=\"10\">\n<tbody>\n<tr>\n<td style=\"vertical-align: top\">\n<p>当社運営のドコモショップは青森県にしか無く、特定のエリアを超えた転勤がありません。数多くの未経験者をプロに育てた研修があるため、未経験者も安心して仕事をスタートしています。</p>\n</p>\n</td>\n<td style=\"width: 300px\"><img class=\"alignnone size-full wp-image-1062\" src=\"https://www.kbs-web.com/docomo/recruit/wp-content/uploads/sites/2/2021/08/shinmachi_staff003.png\" alt=\"\" width=\"1500\" height=\"844\" srcset=\"https://www.kbs-web.com/docomo/recruit/wp-content/uploads/sites/2/2021/08/shinmachi_staff003.png 1500w, https://www.kbs-web.com/docomo/recruit/wp-content/uploads/sites/2/2021/08/shinmachi_staff003-300x169.png 300w, https://www.kbs-web.com/docomo/recruit/wp-content/uploads/sites/2/2021/08/shinmachi_staff003-1024x576.png 1024w, https://www.kbs-web.com/docomo/recruit/wp-content/uploads/sites/2/2021/08/shinmachi_staff003-768x432.png 768w\" sizes=\"(max-width: 1500px) 100vw, 1500px\" /></td>\n<td style=\"width: 300px\"><img class=\"alignnone size-full wp-image-1121\" src=\"https://www.kbs-web.com/docomo/recruit/wp-content/uploads/sites/2/2022/01/kokogasuki03.jpg\" alt=\"\" width=\"300\" height=\"225\" /></td>\n</tr>\n</tbody>\n</table>\n<h3>社員旅行は国内・海外選べます！</h3>\n<table cellspacing=\"10\">\n<tbody>\n<tr>\n<td style=\"vertical-align: top\">\n<p>２～３年に1度の社員旅行はスタッフの楽しみの一つ。海外ならハワイ・オーストラリア・ラスベガスなど、国内なら沖縄・大阪などから選択できます。仲の良いスタッフと一緒に、一生の思い出をつくれます！</p>\n</td>\n<td style=\"width: 300px\"><img class=\"alignnone size-full wp-image-1216\" src=\"https://www.kbs-web.com/docomo/recruit/wp-content/uploads/sites/2/2025/08/87E65104-69A0-4496-8906-174715E293D1.jpeg\" alt=\"\" width=\"1280\" height=\"853\" srcset=\"https://www.kbs-web.com/docomo/recruit/wp-content/uploads/sites/2/2025/08/87E65104-69A0-4496-8906-174715E293D1.jpeg 1280w, https://www.kbs-web.com/docomo/recruit/wp-content/uploads/sites/2/2025/08/87E65104-69A0-4496-8906-174715E293D1-300x200.jpeg 300w, https://www.kbs-web.com/docomo/recruit/wp-content/uploads/sites/2/2025/08/87E65104-69A0-4496-8906-174715E293D1-1024x682.jpeg 1024w, https://www.kbs-web.com/docomo/recruit/wp-content/uploads/sites/2/2025/08/87E65104-69A0-4496-8906-174715E293D1-768x512.jpeg 768w\" sizes=\"(max-width: 1280px) 100vw, 1280px\" /></td>\n<td style=\"width: 300px\"><img class=\"alignnone size-full wp-image-1217\" src=\"https://www.kbs-web.com/docomo/recruit/wp-content/uploads/sites/2/2025/08/5E7BF65A-CAB9-466A-8840-A15DCDFAEC73.jpeg\" alt=\"\" width=\"1280\" height=\"853\" srcset=\"https://www.kbs-web.com/docomo/recruit/wp-content/uploads/sites/2/2025/08/5E7BF65A-CAB9-466A-8840-A15DCDFAEC73.jpeg 1280w, https://www.kbs-web.com/docomo/recruit/wp-content/uploads/sites/2/2025/08/5E7BF65A-CAB9-466A-8840-A15DCDFAEC73-300x200.jpeg 300w, https://www.kbs-web.com/docomo/recruit/wp-content/uploads/sites/2/2025/08/5E7BF65A-CAB9-466A-8840-A15DCDFAEC73-1024x682.jpeg 1024w, https://www.kbs-web.com/docomo/recruit/wp-content/uploads/sites/2/2025/08/5E7BF65A-CAB9-466A-8840-A15DCDFAEC73-768x512.jpeg 768w\" sizes=\"(max-width: 1280px) 100vw, 1280px\" /></td>\n</tr>\n</tbody>\n</table>\n<h3>生活に密着した商品なので、やりがいがたくさん！</h3>\n<table cellspacing=\"10\">\n<tbody>\n<tr>\n<td style=\"vertical-align: top\">TVで話題になるトレンド商品の知識を得られることは家族や友達に自慢できるポイントです。そして、お客様から「ありがとう！」をたくさん言われる仕事だからやりがいや達成感を普段から感じられます！</td>\n<td style=\"width: 300px\"><img class=\"alignnone size-full wp-image-1167\" src=\"https://www.kbs-web.com/docomo/recruit/wp-content/uploads/sites/2/2023/12/shinmachi_shoukai_2023icon.png\" alt=\"\" width=\"300\" height=\"225\" /></td>\n<td style=\"width: 300px\"><img class=\"alignnone size-full wp-image-1066\" src=\"https://www.kbs-web.com/docomo/recruit/wp-content/uploads/sites/2/2021/08/shinmachi_staff007.png\" alt=\"\" width=\"1500\" height=\"844\" srcset=\"https://www.kbs-web.com/docomo/recruit/wp-content/uploads/sites/2/2021/08/shinmachi_staff007.png 1500w, https://www.kbs-web.com/docomo/recruit/wp-content/uploads/sites/2/2021/08/shinmachi_staff007-300x169.png 300w, https://www.kbs-web.com/docomo/recruit/wp-content/uploads/sites/2/2021/08/shinmachi_staff007-1024x576.png 1024w, https://www.kbs-web.com/docomo/recruit/wp-content/uploads/sites/2/2021/08/shinmachi_staff007-768x432.png 768w\" sizes=\"(max-width: 1500px) 100vw, 1500px\" /></td>\n</tr>\n</tbody>\n</table>\n<h2>まだまだあります！ココが好き！</h2>\n<table>\n<tbody>\n<tr>\n<td style=\"width: 300px\"><img class=\"alignnone size-full wp-image-777\" src=\"https://www.kbs-web.com/docomo/recruit/wp-content/uploads/sites/2/2017/09/300_08.jpg\" alt=\"\" width=\"300\" height=\"225\" /></td>\n<td>\n<p><span style=\"font-size: 120%\"><strong>◆国内シェアNo.1で永く安定したお仕事ができます◆</strong></span></p>\n</p>\n<p>携帯電話会社の中でも国内シェアが一番多いドコモ！</p>\n<p>約半分の国内シェアで長くNo.1を維持。だからこそ永く安定したお仕事ができます。</p>\n<p>万が一、家庭の都合で引っ越すことになっても大丈夫！ドコモショップは全国にあります。 全国共通のお仕事だから、これから磨いていくスキルは、どこのドコモショップでも通用する一生モノのスキルとなっていくでしょう。</p>\n</td>\n</tr>\n</tbody>\n</table>\n<table>\n<tbody>\n<tr>\n<td style=\"width: 300px\"><img class=\"alignnone size-full wp-image-1112\" src=\"https://www.kbs-web.com/docomo/recruit/wp-content/uploads/sites/2/2022/01/kokogasuki09.jpg\" alt=\"\" width=\"300\" height=\"225\" /></td>\n<td>\n<p><span style=\"font-size: 120%\"><strong>◆働きやすい環境づくりに注力しています◆</strong></span></p>\n</p>\n<p>フレンドリーで親しみやすい雰囲気がある当社。社風だけではなく、制度面からも安心して働けるようにしています。<br />\n例えばスキル形成では、入社後のスキル習得をサポートする研修や資格取得支援の制度があり、未経験から入社してドコモの接客コンテストで青森県No.1となった社員も在籍中です！知識ゼロから業界のプロを目指せます！</p>\n</td>\n</tr>\n</tbody>\n</table>\n<table>\n<tbody>\n<tr>\n<td style=\"width: 300px\"><img class=\"alignnone size-full wp-image-1155\" src=\"https://www.kbs-web.com/docomo/recruit/wp-content/uploads/sites/2/2023/07/fuukei3.png\" alt=\"\" width=\"300\" height=\"225\" /></td>\n<td>\n<p><span style=\"font-size: 120%\"><strong>◆性別を問わず、長く活躍できる会社です◆</strong></span></p>\n</p>\n<p>産休・育休の取得推奨など長期でキャリア形成できるようにしています。</p>\n<p>短時間勤務制度で終業を早めてお子さまの保育園に間に合うように対応しているケースもあり、スタッフ一人ひとりの働き方に会社として支援しています！</p>\n</td>\n</tr>\n</tbody>\n</table>\n<table>\n<tbody>\n<tr>\n<td style=\"width: 300px\"><img class=\"alignnone wp-image-1080 size-full\" src=\"https://www.kbs-web.com/docomo/recruit/wp-content/uploads/sites/2/2021/08/kokoga_suki_02-04.png\" alt=\"\" width=\"300\" height=\"225\" /></td>\n<td>\n<p><span style=\"font-size: 120%\"><strong>◆接客や仕事を通してスキルアップしたい方にはピッタリ◆</strong></span></p>\n</p>\n<p>未経験でも大丈夫。様々な研修が充実しています！学んだ内容はすぐにお店で実践することができ自身のステップアップを実感！みなさんのスキルアップへの想いを力強く後押しします。自分の実績とお客様からの感謝をたくさん集めて更にステップアップを重ねてください。<br />\nまた、自身の経験や、先輩スタッフの指導で社会に必要なビジネスマナーが身につくのもうれしいポイントです。</p>\n</td>\n</tr>\n</tbody>\n</table>\n<table style=\"width: 100%\">\n<tbody>\n<tr>\n<td style=\"width: 51.7241%\"></td>\n<td style=\"width: 47.2414%\"></td>\n</tr>\n</tbody>\n</table>\n\n\n</div>\n \n\t\n</div>\n\n<div style=\"clear: both;\"></div>\n\n</div>\n\n\n\n<div class=\"footer_banner\">\n<div class=\"wrap\">\n    \t\t\t<div class=\"block banner\">\n\t\t\t\t\t<p><a href=\"https://www.kbs-web.com/docomo/recruit/message/matters/\"></a><a href=\"https://www.kbs-web.com/docomo/recruit/message/matters/\"><img class=\"alignnone size-full wp-image-368\" src=\"https://www.kbs-web.com/docomo/recruit/wp-content/uploads/sites/2/2017/10/img_otoiawase.jpg\" alt=\"\" width=\"487\" height=\"123\" srcset=\"https://www.kbs-web.com/docomo/recruit/wp-content/uploads/sites/2/2017/10/img_otoiawase.jpg 487w, https://www.kbs-web.com/docomo/recruit/wp-content/uploads/sites/2/2017/10/img_otoiawase-300x76.jpg 300w\" sizes=\"(max-width: 487px) 100vw, 487px\" /></a><a href=\"https://www.kbs-web.com/docomo/recruit/message/faq/\"><img class=\"alignnone size-full wp-image-367\" src=\"https://www.kbs-web.com/docomo/recruit/wp-content/uploads/sites/2/2017/10/img_faq.jpg\" alt=\"\" width=\"487\" height=\"123\" srcset=\"https://www.kbs-web.com/docomo/recruit/wp-content/uploads/sites/2/2017/10/img_faq.jpg 487w, https://www.kbs-web.com/docomo/recruit/wp-content/uploads/sites/2/2017/10/img_faq-300x76.jpg 300w\" sizes=\"(max-width: 487px) 100vw, 487px\" /></a></p>\n\t\t\t\t\t\t\t\t\t</div>\n\t\t\t</div>\n</div>\n\n<div id=\"footerwrap\">\n\n<div class=\"ga_about\" ><span style=\"font-size: 80%;\"></span><span style=\"font-size: 80%;\">\nGoogle Analyticsについて<br />\n当サイトでは、Google Analytics（Google アナリティクス）を利用したアクセス解析を行っています。<br />\nGoogle Analytics は、サイトへのアクセス解析データを収集しますが、取得される情報は匿名のものであり、アクセス情報と閲覧者の個人情報を関連づけるものではありません。解析結果は、当サイトの質の向上、より良いコンテンツの提供を目的として利用するものです。<br />\n</span></div> \n    \n<div id=\"footer\">\n<a href=\"http://www.kbs-web.com/\" target=\"_blank\"><img src=\"https://www.kbs-web.com/docomo/recruit/wp-content/themes/original2/contents_images/footerlogo.png\" wid