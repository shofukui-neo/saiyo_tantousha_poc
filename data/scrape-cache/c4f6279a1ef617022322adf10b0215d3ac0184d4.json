{"url":"https://www.doggyman.com/recruit/people/boss-subordinate/","html":"<!doctype html>\r\n<html lang=\"ja\">\r\n\r\n<head>\r\n  <!-- Google Tag Manager -->\r\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\r\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\r\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\r\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\r\n})(window,document,'script','dataLayer','GTM-KPBT95R');</script>\r\n<!-- End Google Tag Manager -->\r\n<meta charset=\"UTF-8\">\r\n<meta name=\"viewport\" content=\"initial-scale=1.0\">\r\n<meta http-equiv=\"x-ua-compatible\" content=\"IE=edge\">\r\n<meta name=\"format-detection\" content=\"telephone=no\">\r\n<link rel=\"shortcut icon\" href=\"../../favicon.ico\">\r\n<link rel=\"stylesheet\" href=\"../../assets/css/style.css\" media=\"all\">\r\n<script src=\"https://code.jquery.com/jquery-3.7.1.min.js\" integrity=\"sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo=\" crossorigin=\"anonymous\"></script>\r\n<script src=\"../../assets/js/common.js\"></script>\r\n<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\r\n<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\r\n<link href=\"https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800;900&family=Noto+Sans+JP:wght@400;500;700&display=swap\" rel=\"stylesheet\">\r\n<script src=\"https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.3/gsap.min.js\" integrity=\"sha512-7Au1ULjlT8PP1Ygs6mDZh9NuQD0A5prSrAUiPHMXpU6g3UMd8qesVnhug5X4RoDr35x5upNpx0A6Sisz1LSTXA==\" crossorigin=\"anonymous\" referrerpolicy=\"no-referrer\"></script>\r\n<script src=\"https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.3/ScrollTrigger.min.js\" integrity=\"sha512-LQQDtPAueBcmGXKdOBcMkrhrtqM7xR2bVrnMtYZ8ImAZhFlIb5xrMqQ6uZviyeSB+4mYj89ta8niiCIQM1Gj0w==\" crossorigin=\"anonymous\" referrerpolicy=\"no-referrer\"></script>\r\n<meta name=\"keywords\" content=\"ドギーマン,DoggyMan,犬,猫,ペット,ペットフード,動物,ペットライフ,採用,新卒採用\">  <title>トークセッション／上司×部下｜新卒採用｜ドギーマンハヤシ株式会社</title>\r\n  <meta name=\"description\" content=\"総合ペットメーカーのドギーマンハヤシの新卒採用ホームページです。社長メッセージや社員メッセージ、当社の仕事内容など、採用に関する情報をお伝えします。トークセッション／上司×部下　社員インタビューや対談を通じて、実際に働いている社員の思いや当社の魅力をお伝えします。\">\r\n  <!-- OGP -->\r\n  <meta property=\"og:site_name\" content=\"新卒採用｜ドギーマンハヤシ株式会社\">\r\n  <meta property=\"og:title\" content=\"トークセッション／上司×部下｜新卒採用｜ドギーマンハヤシ株式会社\">\r\n  <meta property=\"og:type\" content=\"article\">\r\n  <meta property=\"og:url\" content=\"https://www.doggyman.com/recruit/people/boss-subordinate/\">\r\n  <meta property=\"og:description\" content=\"総合ペットメーカーのドギーマンハヤシの新卒採用ホームページです。社長メッセージや社員メッセージ、当社の仕事内容など、採用に関する情報をお伝えします。トークセッション／上司×部下　社員インタビューや対談を通じて、実際に働いている社員の思いや当社の魅力をお伝えします。\">\r\n  <meta property=\"og:image\" content=\"\">\r\n  <link rel=\"canonical\" href=\"https://www.doggyman.com/recruit/people/boss-subordinate/\">\r\n</head>\r\n\r\n\r\n\r\n<body id=\"talk_session\">\r\n\r\n\r\n\r\n  <div class=\"wrapper\">\r\n\r\n\r\n\r\n    <header>\r\n  <div class=\"inner\">\r\n    <div class=\"header-menu-area\">\r\n      <figure class=\"header-logo\">\r\n        <a href=\"../../\">\r\n          <img src=\"../../assets/img/logo.png\" alt=\"ドギーマンハヤシ株式会社\">\r\n          <p>採用サイト</p>\r\n        </a>\r\n      </figure>\r\n      <div class=\"header-menu\">\r\n        <ul class=\"header-menu-bottom\">\r\n          <li><a href=\"../../\">HOME</a></li>\r\n          <li><a href=\"../../message/\">社長メッセージ</a></li>\r\n          <li class=\"drop-menu\">\r\n            <a style=\"pointer-events: none;\">ドギーマンを知る</a>\r\n            <ul class=\"drop-menu-list\">\r\n              <li class=\"drop-menu-item\"><a href=\"../../pet_market/\">ペット市場の今</a></li>\r\n              <li class=\"drop-menu-item\"><a href=\"../../about-doggyman/\">キーワードで知る<br>ドギーマン</a></li>\r\n            </ul>\r\n          </li>\r\n          <li class=\"drop-menu\">\r\n            <a href=\"../../business/\">ドギーマンの仕事</a>\r\n            <ul class=\"drop-menu-list\">\r\n              <li class=\"drop-menu-item\"><a href=\"../../business#proposal\">「提案型営業」とは</a></li>\r\n              <li class=\"drop-menu-item\"><a href=\"../../business#group\">部門紹介</a></li>\r\n            </ul>\r\n          </li>\r\n          <li class=\"drop-menu\">\r\n            <a href=\"../../job/\">ドギーマンの人</a>\r\n            <ul class=\"drop-menu-list\">\r\n              <li class=\"drop-menu-item\"><a href=\"../../job/#interview_main\">社員メッセージ</a></li>\r\n              <li class=\"drop-menu-item\"><a href=\"../../job/#top-talk-session\">トークセッション</a></li>\r\n              <li class=\"drop-menu-item\"><a href=\"../../people/boss-subordinate/\">　上司×部下</a></li>\r\n              <li class=\"drop-menu-item\"><a href=\"../../people/development/\">　食品開発×用品開発</a></li>\r\n              <li class=\"drop-menu-item\"><a href=\"../../people/symposium\">　入社3〜4年目社員 座談会</a></li>\r\n            </ul>\r\n          </li>\r\n          <li class=\"drop-menu\">\r\n            <a style=\"pointer-events: none;\">採用情報</a>\r\n            <ul class=\"drop-menu-list\">\r\n              <li class=\"drop-menu-item\"><a href=\"../../welfare/\">各種制度・福利厚生</a></li>\r\n              <li class=\"drop-menu-item\"><a href=\"../../personnel/\">人事部メッセージ</a></li>\r\n              <li class=\"drop-menu-item\"><a href=\"../../recruit-info/\">採用情報</a></li>\r\n              <li class=\"drop-menu-item\"><a href=\"../../faq/\">よくある質問</a></li>\r\n            </ul>\r\n          </li>\r\n          <li class=\"drop-menu\">\r\n                <a style=\"pointer-events: none;\">ENTRY<br>MY PAGE</a>\r\n                <ul class=\"drop-menu-list entry\">\r\n                  <li class=\"drop-menu-item\">\r\n                  <a href=\"https://doggyman-recruit.snar.jp/index.aspx\" target=\"_blank\" rel=\"noopener noreferrer\">ENTRY</a>\r\n                  </li>\r\n                  <li class=\"drop-menu-item\">\r\n                  <a href=\"https://doggyman-recruit.snar.jp/login.aspx\" target=\"_blank\" rel=\"noopener noreferrer\">MY PAGE</a>\r\n                  </li>\r\n                </ul>\r\n              </li>\r\n\r\n\r\n\r\n        </ul>\r\n      </div>\r\n    </div>\r\n\r\n    <div class=\"menu\">\r\n      <nav>\r\n        <p class=\"navToggle\">\r\n          <span></span><span></span><span></span>\r\n        </p>\r\n        <div id=\"smt_menu_wrapper\" class=\"\">\r\n        <ul class=\"link\">\r\n            <li class=\"link-entry\">\r\n              <a href=\"https://doggyman-recruit.snar.jp/index.aspx\" target=\"_blank\" rel=\"noopener noreferrer\">新卒ENTRY</a>\r\n              <a href=\"https://doggyman-recruit.snar.jp/login.aspx\" target=\"_blank\" rel=\"noopener noreferrer\">MY PAGE</a>\r\n            </li>\r\n            <li class=\"full\">\r\n              <h3><a href=\"../../\">HOME</a></h3>\r\n            </li>\r\n            <li>\r\n              <h4><a>COMPANY</a></h4>\r\n              <a href=\"../../message/\">社長メッセージ</a>\r\n              <a href=\"../../pet_market/\">ペット市場の今</a>\r\n              <a href=\"../../about-doggyman/\">キーワードで知るドギーマン</a>\r\n              <a href=\"../../business/\">「提案型営業」と部門紹介</a>\r\n              <a href=\"../../#understands\">ドギーマンは分かってくれる</a>\r\n            </li>\r\n            <li>\r\n              <h4><a>PEOPLE</a></h4>\r\n              <a href=\"../../job/#interview_main\">社員インタビュー</a>\r\n              <a class=\"none\" href=\"../../job/#top-talk-session\">トークセッション</a>\r\n              <a class=\"under\" href=\"../../people/boss-subordinate/\">上司×部下</a>\r\n              <a class=\"under\" href=\"../../people/development/\">食品開発×用品開発</a>\r\n              <a class=\"under\" href=\"../../people/symposium\">入社3〜4年目社員 座談会</a>\r\n            </li>\r\n            <li>\r\n              <h4><a>RECRUIT</a></h4>\r\n              <a href=\"../../welfare/\">各種制度・福利厚生</a>\r\n              <a href=\"../../personnel/\">人事部メッセージ</a>\r\n              <a href=\"../../recruit-info/\">採用情報</a>\r\n              <a href=\"../../faq/\">よくある質問</a>\r\n            </li>\r\n          </ul>\r\n        </div>\r\n      </nav>\r\n    </div>\r\n  </div>\r\n  <div class=\"to_top_btn\">\r\n    <a href=\"#\"><img src=\"../../assets/img/top_allow.png\" alt=\"トップに戻る\"></a>\r\n  </div>\r\n  </header>\r\n\r\n\r\n    <main>\r\n\r\n\r\n\r\n      <section class=\"talk_session_main\">\r\n        <h2><span>T</span>ALK <span>S</span>ESSION</h2>\r\n        <p>トークセッション</p>\r\n        <div class=\"talk_head_title\">\r\n          <figure class=\"talk_post left\">\r\n            <img src=\"../../assets/img/interview/talk_title_jyoushi.png\" alt=\"上司\">\r\n          </figure>\r\n          <figure class=\"talk_post right\">\r\n            <img src=\"../../assets/img/interview/talk_title_buka.png\" alt=\"部下\">\r\n          </figure>\r\n        </div>\r\n        <dl class=\"talk_head_profile\">\r\n          <dt>\r\n            <div class=\"talk_head_profile_text\">\r\n              <h3>PROFILE</h3>\r\n              <div class=\"talk_head_profile_line\"></div>\r\n              <h4>大阪営業部 大阪第二営業所<br>\r\n                2008年度入社</h4>\r\n              <p>入社してからずっと大阪で営業を担当。2021年に所長代理に。痩せようと始めたマラソンと車の洗車が趣味。3児のパパでもある。大学では水産学を学び、生物に興味がある。</p>\r\n              <h5><span>S</span><span>さん</span></h5>\r\n            </div>\r\n          </dt>\r\n          <dd>\r\n            <div class=\"talk_head_profile_text\">\r\n              <h3>PROFILE</h3>\r\n              <div class=\"talk_head_profile_line\"></div>\r\n              <h4>大阪営業部 大阪第二営業所<br>\r\n                2018年度入社</h4>\r\n              <p>入社後ずっと営業を担当。中高生時代は陸上部に所属して長距離を走っていたこともあり、今は営業所のマラソンメンバーの中心に。大学では動物生命科学について学んでいた。</p>\r\n              <h5><span>K</span><span>さん</span></h5>\r\n            </div>\r\n          </dd>\r\n        </dl>\r\n      </section>\r\n\r\n\r\n\r\n      <section class=\"talk_session_dis fade\">\r\n        <dl>\r\n          <dt>\r\n            <figure>\r\n              <img src=\"../../assets/img/interview/talk_dis_01.jpg\" alt=\"トークセッション\">\r\n            </figure>\r\n          </dt>\r\n          <dd>\r\n            <figure class=\"rotate\"><img src=\"../../assets/img/interview/talk_session_rotate.png\" alt=\"トークセッション\"></figure>\r\n            <h2>\r\n              <p class=\"leftin part1\"><span>困った時</span>に相談すれば</p>\r\n              <p class=\"leftin part2\"><span>手を止めて</span>聞いてくれる。</p>\r\n            </h2>\r\n\r\n            <ul class=\"talk_session_dis_text\">\r\n              <li>\r\n                <figure>\r\n                  <img src=\"../../assets/img/interview/talk_face_s.jpg\" alt=\"sさん\">\r\n                  <figcaption>S</figcaption>\r\n                </figure>\r\n                <p>Kさんの第一印象は、入社後、最初に営業同行した時に車の運転があまり上手じゃなくて困っていたことかな（笑）。</p>\r\n              </li>\r\n              <li>\r\n                <figure><img src=\"../../assets/img/interview/talk_face_k.jpg\" alt=\"kさん\">\r\n                  <figcaption>K</figcaption>\r\n                </figure>\r\n                <p>\r\n                  そうでしたね（笑）。営業には運転免許が必要だということで免許を取ったのですが、あまりにも運転が上手くできなくて…。そこで、Sさんには何度も助けていただいた思い出があります。あの時はありがとうございました！\r\n                </p>\r\n              </li>\r\n              <li>\r\n                <figure><img src=\"../../assets/img/interview/talk_face_s.jpg\" alt=\"sさん\">\r\n                  <figcaption>S</figcaption>\r\n                </figure>\r\n                <p>いえいえ。でもその後、Ｋさんが得意先のことで悩んでいて話を聞いた時に、私も知らない専門用語や横文字の用語集を作っているのを見て、知らないことを学ぶ意欲のある人だな、と感心したのはよく覚えているよ。\r\n                </p>\r\n              </li>\r\n              <li>\r\n                <figure><img src=\"../../assets/img/interview/talk_face_k.jpg\" alt=\"kさん\">\r\n                  <figcaption>K</figcaption>\r\n                </figure>\r\n                <p>\r\n                  そんなこともありましたね。今はSさんと異なるチームにいるので、仕事で関わる機会は少ないですが、ドギーマンハヤシの先輩方は本当に良い人ばかりで、困ったことがあって相談するとすぐに手を止めて話を聞いてくださるので、とても助かっています。\r\n                </p>\r\n              </li>\r\n            </ul>\r\n          </dd>\r\n        </dl>\r\n      </section>\r\n\r\n      <section class=\"talk_session_dis re fade\">\r\n        <dl>\r\n          <dt>\r\n            <figure>\r\n              <img src=\"../../assets/img/interview/talk_dis_02.jpg\" alt=\"トークセッション\">\r\n            </figure>\r\n          </dt>\r\n          <dd>\r\n            <figure class=\"rotate2\"><img src=\"../../assets/img/interview/talk_session_rotate.png\" alt=\"トークセッション\"></figure>\r\n            <h2>\r\n              <p class=\"leftin2 part3\"><span>マラソン大会</span>に</p>\r\n              <p class=\"leftin2 part4\">出場する<span>仲間</span>としても。</p>\r\n            </h2>\r\n\r\n            <ul class=\"talk_session_dis_text\">\r\n              <li>\r\n                <figure><img src=\"../../assets/img/interview/talk_face_s.jpg\" alt=\"sさん\">\r\n                  <figcaption>S</figcaption>\r\n                </figure>\r\n                <p>\r\n                  会社はコミュニケーションやチームワークをとても大事にしているよね。私も部下から呼びかけがあれば、できるだけ耳を傾けるようにしています。部下の意見を聞いて取り入れることもあるし、仕事の話はもちろん、仕事以外の話も結構するよね。\r\n                </p>\r\n              </li>\r\n              <li>\r\n                <figure><img src=\"../../assets/img/interview/talk_face_k.jpg\" alt=\"kさん\">\r\n                  <figcaption>K</figcaption>\r\n                </figure>\r\n                <p>\r\n                  そういえばＳさんがマラソンをしているという噂を聞いて、「マラソン大会に出ませんか？」と声をかけさせてもらったんですよね。それも快く聞いてくださったので嬉しかったです。\r\n                </p>\r\n              </li>\r\n              <li>\r\n                <figure><img src=\"../../assets/img/interview/talk_face_s.jpg\" alt=\"sさん\">\r\n                  <figcaption>S</figcaption>\r\n                </figure>\r\n                <p>そうだった（笑）。確かリレーマラソンから始まったよね。そして、今度の奈良のマラソン大会に向けて練習を頑張らないと。いつもマラソンメンバーを仕切ってもらって助かっています。\r\n                </p>\r\n              </li>\r\n              <li>\r\n                <figure><img src=\"../../assets/img/interview/talk_face_k.jpg\" alt=\"kさん\">\r\n                  <figcaption>K</figcaption>\r\n                </figure>\r\n                <p>\r\n                  これからも仕事だけじゃなく、マラソンも頑張っていきます！\r\n                </p>\r\n              </li>\r\n            </ul>\r\n          </dd>\r\n        </dl>\r\n      </section>\r\n\r\n\r\n      <section class=\"talk_session_dis fade\">\r\n        <dl>\r\n          <dt>\r\n            <figure>\r\n              <img src=\"../../assets/img/interview/talk_dis_03.jpg\" alt=\"トークセッション\">\r\n            </figure>\r\n          </dt>\r\n          <dd>\r\n            <figure class=\"rotate3\"><img src=\"../../assets/img/interview/talk_session_rotate.png\" alt=\"トークセッション\"></figure>\r\n            <h2>\r\n              <p class=\"leftin3 part5\"><span>誰かの目標</span>になる\r\n              </p>\r\n              <p class=\"leftin3 part6\">存在を目指して。</p>\r\n            </h2>\r\n\r\n            <ul class=\"talk_session_dis_text\">\r\n              <li>\r\n                <figure><img src=\"../../assets/img/interview/talk_face_s.jpg\" alt=\"sさん\">\r\n                  <figcaption>S</figcaption>\r\n                </figure>\r\n                <p>\r\n                  Ｋさんが営業所を代表して社内の勉強会に参加した後、営業所のメンバーに共有してもらった時、みんなにとてもわかりやすく伝えてくれたのが印象的で、成長したなぁと思ったよ。所長にもはっきり意見を言えるのも良いところだと。\r\n                </p>\r\n              </li>\r\n              <li>\r\n                <figure><img src=\"../../assets/img/interview/talk_face_k.jpg\" alt=\"kさん\">\r\n                  <figcaption>K</figcaption>\r\n                </figure>\r\n                <p>\r\n                  ありがとうございます。会社は個性をとても尊重してくれますし、若手から色々なチャンスを与えてくださるので、成長の機会がたくさんあると思っています。<br>\r\n                  あとは、自分できちんと考えたうえで発言や相談をするように心がけています。\r\n                </p>\r\n              </li>\r\n              <li>\r\n                <figure><img src=\"../../assets/img/interview/talk_face_s.jpg\" alt=\"sさん\">\r\n                  <figcaption>S</figcaption>\r\n                </figure>\r\n                <p>\r\n                  Kさんにこれから期待することは、女性営業マンを代表するドギーマンの顔になってほしいということ。普段の雰囲気はふわっとしているのに、商談や発表になるととてもキビキビしているし、そのメリハリが良いと思います。<br>\r\n                  「ドギーマンの営業と言えばＫさん」と言ってもらえるように名前を売ってほしい。\r\n                </p>\r\n              </li>\r\n              <li>\r\n                <figure><img src=\"../../assets/img/interview/talk_face_k.jpg\" alt=\"kさん\">\r\n                  <figcaption>K</figcaption>\r\n                </figure>\r\n                <p>\r\n                  頑張ります！誰かの目標にしてもらえるような存在になりたいですね。また、この会社の良い雰囲気はそのままに、後輩も発言しやすい営業チームにしていきたい。みんなが楽しく働けるようにも努力していきたいと思っています。\r\n                </p>\r\n              </li>\r\n            </ul>\r\n          </dd>\r\n        </dl>\r\n      </section>\r\n\r\n\r\n\r\n      <figure class=\"fade last_photo\">\r\n        <picture>\r\n          <source media=\"(max-width:769px)\" srcset=\"../../assets/img/interview/talk_dis_04_sp.jpg 769w\" sizes=\"100vw\">\r\n          <img src=\"../../assets/img/interview/talk_dis_04.jpg\" alt=\"トークセッション\">\r\n        </picture>\r\n      </figure>\r\n\r\n\r\n\r\n\r\n      <section class=\"talk_session_end fade\">\r\n        <div class=\"inner\">\r\n          <figure class=\"minasama_title\"><img src=\"../../assets/img/interview/talk_minasama.png\" alt=\"就活生のみなさんへ\"></figure>\r\n          <ul class=\"minasama_pop_unit\">\r\n            <li class=\"pop part1\">\r\n              <figure><img src=\"../../assets/img/interview/talk_face_k.jpg\" alt=\"kさん\">\r\n                <figcaption>K</figcaption>\r\n              </figure>\r\n              <div class=\"minasama\">\r\n                <p>私の就職活動の軸は「ペットに関する仕事に就きたい！」ということでした。自分の好きなこと、やってみたいことをしっかり考えて、やり切ったと思える就活にしてください。応援しています。頑張ってください！</p>\r\n              </div>\r\n            </li>\r\n            <li class=\"pop part2\">\r\n              <figure><img src=\"../../assets/img/interview/talk_face_s.jpg\" alt=\"sさん\">\r\n                <figcaption>S</figcaption>\r\n              </figure>\r\n              <div class=\"minasama\">\r\n                <p>情報が溢れるなかでの企業選びは非常に難しいと思います。でも、くじけず頑張ればきっと最適な会社が見つかるはず。もし一緒に働くことになれば、ともに頑張っていきましょう。明るく元気な方をお待ちしています。\r\n                </p>\r\n              </div>\r\n            </li>\r\n          </ul>\r\n        </div>\r\n      </section>\r\n\r\n\r\n\r\n      <a class=\"back_link\" href=\"../../job/#top-talk-session\"><span>T</span>ALK\r\n        <span>S</span>ESSION一覧に戻る<span>▶︎</span></a>\r\n\r\n\r\n\r\n    </main>\r\n\r\n\r\n\r\n    <footer>\r\n  <div class=\"inner\">\r\n    <dl class=\"short_btn_unit_sp\">\r\n          <dt>\r\n            <a href=\"https://doggyman-recruit.snar.jp/index.aspx\" target=\"_blank\" rel=\"noopener noreferrer\">ENTRY</a>\r\n          </dt>\r\n          <dd>\r\n            <a href=\"https://doggyman-recruit.snar.jp/login.aspx\" target=\"_blank\" rel=\"noopener noreferrer\">MY PAGE</a>\r\n          </dd>\r\n        </dl>\r\n        <dl class=\"short_btn_unit\">\r\n          <dt>\r\n            <a href=\"https://doggyman-recruit.snar.jp/index.aspx\" target=\"_blank\" rel=\"noopener noreferrer\">\r\n              <span>ENTRY</span>\r\n            </a>\r\n          </dt>\r\n          <dd>\r\n            <a href=\"https://doggyman-recruit.snar.jp/login.aspx\" target=\"_blank\" rel=\"noopener noreferrer\">\r\n              <span>MY PAGE</span>\r\n            </a>\r\n          </dd>\r\n        </dl>\r\n\r\n    <ul class=\"link\">\r\n      <li>\r\n        <h3><a href=\"../../\">HOME</a></h3>\r\n      </li>\r\n      <li>\r\n        <h4><a>COMPANY</a></h4>\r\n        <a href=\"../../message/\">社長メッセージ</a>\r\n        <a href=\"../../pet_market/\">ペット市場の今</a>\r\n        <a href=\"../../about-doggyman/\">キーワードで知るドギーマン</a>\r\n        <a href=\"../../business/\">「提案型営業」と部門紹介</a>\r\n        <a href=\"../../#understands\">ドギーマンは分かってくれる</a>\r\n      </li>\r\n      <li>\r\n        <h4><a>PEOPLE</a></h4>\r\n        <a href=\"../../job/#interview_main\">社員インタビュー</a>\r\n        <a class=\"none\" href=\"../../job/#top-talk-session\">トークセッション</a>\r\n        <a class=\"under\" href=\"../../people/boss-subordinate/\">上司×部下</a>\r\n        <a class=\"under\" href=\"../../people/development/\">食品開発×用品開発</a>\r\n        <a class=\"