ary_language js-naviLanguage\">\n              <li>\n                  <a href=\"/\">JP</a>\n        \n              </li>\n          <li>\n                  <a href=\"/en/company\" data-drupal-link-system-path=\"node/555\">EN</a>\n        \n              </li>\n        </ul>\n  \n              </li>\n        </ul>\n  \n\n\n</nav>\n\n</div>\n\n    </div>\n  </header>\n  <div class=\"l-megamenu\" style=\"display: none;\">\n    <div class=\"megamenu\">\n          </div>\n  </div>\n\n  <main role=\"main\" class=\"l-mainContents\">\n    <div data-drupal-messages-fallback class=\"hidden\"></div>\n\n    \n          <div class=\"region region-content\">\n    <div id=\"block-princeton-content\" class=\"block block-system block-system-main-block\">\n  \n    \n      \n<article class=\"node node--type-page node--view-mode-full\">\n\n  <div class=\"l-container\">\n    \n        \n  </div>\n\n  \n  <div class=\"node__content\">\n      <div class=\"layout layout--onecol\">\n    <div  class=\"layout__region layout__region--content\">\n      <div class=\"block block-layout-builder block-field-blocknodepagebody\">\n  \n    \n      \n            <div class=\"clearfix text-formatted field field--name-body field--type-text-with-summary field--label-hidden field__item\"><div class=\"page-contacts\">\n  <div class=\"l-breadcrumbs is-first\">\n    <ol>\n      <li> <a href=\"/\">HOME</a> </li>\n      <li> <a href=\"/support/\">サポート</a> </li>\n      <li> <span>お問い合わせ</span> </li>\n    </ol>\n  </div>\n  <header class=\"l-pageTitle-text\">\n    <div class=\"l-container\">\n      <div class=\"heading-en\">\n        <div class=\"l-container\">\n          <h1 class=\"heading\">CONTACT</h1>\n          <p>お問い合わせ</p>\n        </div>\n      </div>\n      <p class=\"fz-copy2 text-center\">プリンストン製品、法人向け製品に関するお問い合わせ窓口をご案内します。<br>\n        お問い合わせの内容により受付窓口が異なりますのでご注意ください。</p>\n      <!--<section class=\"closed_attention\">\n        <h3>年末年始休業のお知らせ</h3>\n        <p>誠に勝手ながら、年末年始休業のためお問い合わせ窓口をお休みさせていただきます。</p>\n        <ul class=\"txt_cre\">\n          <li>2025年12月27日(土)～2026年1月4日(日)</li>\n        </ul>\n        <ul class=\"kome txt_cre\">\n          <li>12月26日(金)、1月5日(月)は一部窓口の営業時間を短縮させていただきます。</li>\n        </ul>\n        <p>休業期間中のお問い合わせ等につきましては、年始開始受付日より順次対応させていただきます。<br >\n        なお、年末年始は窓口が混み合うため、通常よりもお受付ならびに回答までにお時間をいただく場合がございます。<br>\n        ご不便をおかけしますが、ご理解とご協力のほど何卒よろしくお願い申し上げます。 </p>\n      </section>\n      <section class=\"closed_attention\">\n        <h3>弊社取扱一部製品の電話窓口休業のご案内 </h3>\n        <p>平素は、弊社製品をご愛顧頂き厚く御礼申し上げます。弊社受付システムのメンテナンスのため電話での受付業務をお休みさせていただきます。</p>\n        <dl  class=\"colonlist\">\n          <dt>電話番号</dt>\n          <dd>03-6670-6848</dd>\n          <dt>休業日</dt>\n          <dd>2021年5月6日（木）～2021年5月9日（日）</dd>\n        </dl>\n        <ul class=\"kome\">\n          <li>土日の休業日を含みます。</li>\n        </ul>\n        <p>お問い合わせフォーム・メールによるお問い合わせ等につきましては、順次対応させていただきます。<br />\n          なお、ゴールデンウイーク明けは窓口が混み合い通常よりもお受付ならびにご回答にお時間がかかる場合がございますので予めご了承ください。 </p>\n        <p>ご不便をおかけしますが、何卒ご理解とご協力のほどよろしくお願い申し上げます。</p>\n      </section>-->\n    </div>\n  </header>\n  <section class=\"page-contacts-first\" class=\"js-contacts-first\">\n  <div class=\"l-container\">\n    <header class=\"page-contacts-first_header\">\n      <h2 class=\"page-contacts-first_heading\">お問い合わせの前にご確認ください。</h2>\n      <p class=\"page-contacts-first_headerText\">お問い合わせいただく前に、以下の項目をご確認・ご活用ください。</p>\n    </header>\n    <div class=\"page-contacts-first_card\">\n      <div class=\"card-narrow\">\n        <ul class=\"card-narrow_list\">\n          <li class=\"card-narrow_item\"> <a href=\"https://faq.princeton.co.jp/\">\n            <p class=\"card-narrow_icon\">\n              <svg viewBox=\"0 0 64 64\" width=\"64\" height=\"64\" class=\"icon\">\n                <use xlink:href=\"#icon-help-circle\"></use>\n              </svg>\n            </p>\n            <h2 class=\"card-narrow_heading\">よくあるご質問（FAQ）</h2>\n            <p class=\"card-narrow_text\">プリンストン製品について、よくお問い合わせいただく疑問・質問等への回答を掲載しています。</p>\n            <p class=\"card-narrow_button\"> <span class=\"arrowLink-border\">View More</span> </p>\n            </a> </li>\n          <li class=\"card-narrow_item\"> <a href=\"/support/list\">\n            <p class=\"card-narrow_icon\">\n              <svg viewBox=\"0 0 64 64\" width=\"64\" height=\"64\" class=\"icon\">\n                <use xlink:href=\"#icon-device-desktop-filled\"></use>\n              </svg>\n            </p>\n            <h2 class=\"card-narrow_heading\">OS・デバイス<span class=\"text-inlineBlock\">対応情報</span></h2>\n            <p class=\"card-narrow_text\">最新OSや最新タブレット、iPhoneや携帯電話など、プリンストン製品の対応表はこちらからご確認ください。</p>\n            <p class=\"card-narrow_button\"> <span class=\"arrowLink-border\">View More</span> </p>\n            </a> </li>\n          <li class=\"card-narrow_item\"> <a href=\"/support/download.html\">\n            <p class=\"card-narrow_icon\">\n              <svg viewBox=\"0 0 64 64\" width=\"64\" height=\"64\" class=\"icon\">\n                <use xlink:href=\"#icon-download\"></use>\n              </svg>\n            </p>\n            <h2 class=\"card-narrow_heading\">ダウンロード</h2>\n            <p class=\"card-narrow_text\">各種ドライバー/ソフトウェア/ファームウェア/アップデートファイルの他、カタログや製品画像のダウンロードはこちらから。</p>\n            <p class=\"card-narrow_button\"> <span class=\"arrowLink-border\">View More</span> </p>\n            </a> </li>\n          <li class=\"card-narrow_item\"> <a href=\"/support/manual\">\n            <p class=\"card-narrow_icon\">\n              <svg viewBox=\"0 0 64 64\" width=\"64\" height=\"64\" class=\"icon\">\n                <use xlink:href=\"#icon-help-note\"></use>\n              </svg>\n            </p>\n            <h2 class=\"card-narrow_heading\">製品マニュアル</h2>\n            <p class=\"card-narrow_text\">各種製品マニュアルはこちらからご確認ください。</p>\n            <p class=\"card-narrow_button\"> <span class=\"arrowLink-border\">View More</span> </p>\n            </a> </li>\n        </ul>\n      </div>\n    </div>\n  </div>\n  </section>\n  <div cla