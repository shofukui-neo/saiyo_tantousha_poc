in\" -->\r\n\t<div id=\"subject\">\r\n\t\t<p>企業概要</p>\r\n\t\t<img class=\"thumb\" src=\"images/subject.jpg\">\r\n\t</div>\r\n\t<div id=\"overview\" class=\"wrap\">\r\n\t\t<article id=\"information\">\r\n\t\t\t<h2 class=\"title\">企業概要</h2>\r\n\t\t\t<div>\r\n\t\t\t\t<dl class=\"list line\">\r\n\t\t\t\t\t<dt>社名</dt>\r\n\t\t\t\t\t<dd>株式会社 市川工務店</dd>\r\n\t\t\t\t\t<dt>英文社名</dt>\r\n\t\t\t\t\t<dd>ICHIKAWA KOUMUTEN CO., LTD</dd>\r\n\t\t\t\t\t<dt>設立</dt>\r\n\t\t\t\t\t<dd>1950年（昭和25年）8月　<a class=\"linkText\" href=\"../history.html\"><i><svg><use xlink:href=\"#iconChevronRight\"></use></svg></i>沿革を見る</a></dd>\r\n\t\t\t\t\t<dt>資本金</dt>\r\n\t\t\t\t\t<dd>2億370万円</dd>\r\n\t\t\t\t</dl>\r\n\t\t\t\t<figure><img src=\"images/overview_informationPhoto.jpg\" alt=\"外観写真\"></figure>\r\n\t\t\t</div>\r\n\t\t</article>\r\n\t\t<hr>\r\n\t\t<article id=\"business\">\r\n\t\t\t<h2 class=\"title\">事業内容</h2>\r\n\t\t\t<div class=\"flex\">\r\n\t\t\t\t<div>\r\n\t\t\t\t\t<h4 class=\"subTitle\">主な営業品目</h4>\r\n\t\t\t\t\t<ul class=\"list point\">\r\n\t\t\t\t\t\t<li>土木建築の請負</li>\r\n\t\t\t\t\t\t<li>建設業の工事測量及び製図</li>\r\n\t\t\t\t\t\t<li>不動産の売買・仲介・賃貸・管理及び運営</li>\r\n\t\t\t\t\t\t<li>土木建築工事の資材の製造販売</li>\r\n\t\t\t\t\t\t<li>地質調査及びボーリング工事請負</li>\r\n\t\t\t\t\t\t<li>造園及び造園工事業</li>\r\n\t\t\t\t\t</ul>\r\n\t\t\t\t</div>\r\n\t\t\t\t<div>\r\n\t\t\t\t\t<h4 class=\"subTitle\">各種許可番号</h4>\r\n\t\t\t\t\t<dl class=\"list line\">\r\n\t\t\t\t\t\t<dt>建設業許可番号</dt>\r\n\t\t\t\t\t\t<dd>国土交通大臣許可（特−4）第1313号</dd>\r\n\t\t\t\t\t\t<dt>地質調査業者登録</dt>\r\n\t\t\t\t\t\t<dd>質5第879号</dd>\r\n\t\t\t\t\t\t<dt>一級建築士事務所登録</dt>\r\n\t\t\t\t\t\t<dd>岐阜県知事登録第6293号</dd>\r\n\t\t\t\t\t\t<dt>宅地建物取引業者免許証番号</dt>\r\n\t\t\t\t\t\t<dd>国土交通大臣（9）第3935号</dd>\r\n\t\t\t\t\t\t<dt>土壌汚染対策法に基づく指定調査機関指定番号</dt>\r\n\t\t\t\t\t\t<dd>2003-4-2020</dd>\r\n\t\t\t\t\t</dl>\r\n\t\t\t\t</div>\r\n\t\t\t</div>\r\n\t\t</article>\r\n\t\t<hr>\r\n\t\t<article id=\"story\">\r\n\t\t\t<h2 class=\"title\">社訓</h2>\r\n\t\t\t<div>\r\n\t\t\t\t<p><img src=\"images/overview_storyPict.jpg\" alt=\"汗出せ・知恵出せ・ま