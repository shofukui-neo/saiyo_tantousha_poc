if (scroll > imgPos - windowHeight + windowHeight / 3){\n\t\t\t\t$(this).addClass('is-show');\n\t\t\t}\n\t\t});\n\t});\n\t$(window).on('load scroll resize', function(){\n\t\tvar scroll = $(window).scrollTop();\n\t\tvar windowHeight = $(window).height();\n\t\t$('.trigger-fv').each(function(){\n\t\t\tvar imgPos = $(this).offset().top;\n\t\t\tif (scroll > imgPos - windowHeight + windowHeight / 8){\n\t\t\t\t$(this).addClass('is-show');\n\t\t\t} else {\n\t\t\t\t$(this).removeClass('is-show');\n\t\t\t}\n\t\t});\n\t});\n</script>\n\n<!-- タブ -->\n<script>\n\t$(\".tab-list li\").on(\"click\",function(){\n\t\tvar $th = $(this).index();\n\t\t$(\".tab-list li\").removeClass(\"active\");\n\t\t$(\".tab-panel\").removeClass(\"active\");\n\t\t$(this).addClass(\"active\");\n\t\t$(\".tab-panel\").eq($th).addClass(\"active\");\n\t});\n</script>\n\n<!-- 共通アコーディオン -->\n<script>\n\tjQuery(function($) {\n\t\t$(\".acc-box dt\").on('click', function() {\n\t\t\tconst $dt = $(this);\n\t\t\tconst $content = $dt.next();\n\n\t\t\t$dt.toggleClass(\"active\");\n\n\t\t\t$content.slideToggle(300, function() {\n\t\t\t\tif ($content.is(\":visible\")) {\n\t\t\t\t\t$content.addClass(\"active\");\n\t\t\t\t} else {\n\t\t\t\t\t$content.removeClass(\"active\");\n\t\t\t\t}\n\t\t\t});\n\t\t});\n\t});\n</script>\n\n\n\n\n\t<script>\n\t\tvar mySvg = new Vivus('move', {\n\t\t  type: 'oneByOne',\n\t\t  duration: 45,\n\t\t  forceRender: false,\n\t\t  start: 'manual',\n\t\t  animTimingFunction: Vivus.EASE_IN_OUT,\n\t\t});\n\t  \n\t\tconst observer = new IntersectionObserver((entries, observer) => {\n\t\t  entries.forEach(entry => {\n\t\t\tif (entry.isIntersecting) {\n\t\t\t  mySvg.play();\n\t\t\t  observer.unobserve(entry.target);\n\t\t\t}\n\t\t  });\n\t\t}, {\n\t\t  threshold: 0.25, // 25%が表示されたときに発火\n\t\t  rootMargin: \"0px 0px -40% 0px\" // 視覚的に中央に来た時点で発火\n\t\t});\n\t  \n\t\tconst svgEl = document.getElementById('move');\n\t\tif (svgEl) {\n\t\t  observer.observe(svgEl);\n\t\t}\n\t  </script>\n\t  \n\n\t<script>\n\t\tdocument.addEventListener('DOMContentLoaded', () => {\n\t\t\tconst border = document.querySelector('.bg-border');\n\t\t\tconst marker = document.querySelector('.scroll-end-marker');\n\t\t\tconst area02 = document.querySelector('#area02');\n\t\n\t\t\tconst observer = new IntersectionObserver(\n\t\t\t\t([entry]) => {\n\t\t\t\t\tif (entry.target === marker) {\n\t\t\t\t\t\tif (entry.isIntersecting) {\n\t\t\t\t\t\t\tborder.classList.add('stuck');\n\t\t\t\t\t\t} else {\n\t\t\t\t\t\t\tborder.classList.remove('stuck');\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t\telse if (entry.target === area02) {\n\t\t\t\t\t\tif (entry.isIntersecting) {\n\t\t\t\t\t\t\tborder.classList.remove('start');\n\t\t\t\t\t\t} else {\n\t\t\t\t\t\t\tborder.classList.add('start');\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\troot: null,\n\t\t\t\t\tthreshold: 0.3,\n\t\t\t\t}\n\t\t\t);\n\t\n\t\t\tif (border) {\n\t\t\t\tif (marker) observer.observe(marker);\n\t\t\t\tif (area02) observer.observe(area02);\n\t\t\t}\n\t\t});\n\t</script>\n\t\n\n</body>\n</html>","finalUrl":"https://field.ne.jp/recruit/about/","rendered":false,"_cachedAt":"2026-06-22T22:06:41.895Z"}