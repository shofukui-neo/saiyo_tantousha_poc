{"url":"https://www.tepco-sa.co.jp/ssl/recruit/new_graduate/survey/","html":"<!DOCTYPE html>\r\n<html lang=\"ja\">\r\n\r\n<head>\r\n  <meta charset=\"UTF-8\">\r\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n  <meta name=\"description\" content=\"テプコ・ソリューション・アドバンスの新卒採用情報ページです。会社の魅力や先輩社員の声、採用スケジュールなどをご紹介します。\">\r\n  <meta name=\"keywords\" content=\"新卒採用, 採用スケジュール, 企業研究, 就職活動, テプコ・ソリューション・アドバンス\">\r\n  <meta name=\"author\" content=\"テプコ・ソリューション・アドバンス株式会社\">\r\n  <title>先輩社員アンケート｜採用情報｜テプコ・ソリューション・アドバンス株式会社</title>\r\n\r\n  <!--favicon https://www.favicon-generator.org/-->\r\n  <link rel=\"apple-touch-icon\" sizes=\"57x57\" href=\"https://www.tepco-sa.co.jp/ssl/images/site-icon/apple-icon-57x57.png\">\r\n  <link rel=\"apple-touch-icon\" sizes=\"60x60\" href=\"https://www.tepco-sa.co.jp/ssl/images/site-icon/apple-icon-60x60.png\">\r\n  <link rel=\"apple-touch-icon\" sizes=\"72x72\" href=\"https://www.tepco-sa.co.jp/ssl/images/site-icon/apple-icon-72x72.png\">\r\n  <link rel=\"apple-touch-icon\" sizes=\"76x76\" href=\"https://www.tepco-sa.co.jp/ssl/images/site-icon/apple-icon-76x76.png\">\r\n  <link rel=\"apple-touch-icon\" sizes=\"114x114\" href=\"https://www.tepco-sa.co.jp/ssl/images/site-icon/apple-icon-114x114.png\">\r\n  <link rel=\"apple-touch-icon\" sizes=\"120x120\" href=\"https://www.tepco-sa.co.jp/ssl/images/site-icon/apple-icon-120x120.png\">\r\n  <link rel=\"apple-touch-icon\" sizes=\"144x144\" href=\"https://www.tepco-sa.co.jp/ssl/images/site-icon/apple-icon-144x144.png\">\r\n  <link rel=\"apple-touch-icon\" sizes=\"152x152\" href=\"https://www.tepco-sa.co.jp/ssl/images/site-icon/apple-icon-152x152.png\">\r\n  <link rel=\"apple-touch-icon\" sizes=\"180x180\" href=\"https://www.tepco-sa.co.jp/ssl/images/site-icon/apple-icon-180x180.png\">\r\n  <link rel=\"icon\" type=\"image/png\" sizes=\"192x192\" href=\"https://www.tepco-sa.co.jp/ssl/images/site-icon/android-icon-192x192.png\">\r\n  <link rel=\"icon\" type=\"image/png\" sizes=\"32x32\" href=\"https://www.tepco-sa.co.jp/ssl/images/site-icon/favicon-32x32.png\">\r\n  <link rel=\"icon\" type=\"image/png\" sizes=\"96x96\" href=\"https://www.tepco-sa.co.jp/ssl/images/site-icon/favicon-96x96.png\">\r\n  <link rel=\"icon\" type=\"image/png\" sizes=\"16x16\" href=\"https://www.tepco-sa.co.jp/ssl/images/site-icon/favicon-16x16.png\">\r\n  <link rel=\"manifest\" href=\"https://www.tepco-sa.co.jp/ssl/images/site-icon/manifest.json\">\r\n  <meta name=\"msapplication-TileColor\" content=\"#ffffff\">\r\n  <meta name=\"msapplication-TileImage\" content=\"https://www.tepco-sa.co.jp/ssl/images/site-icon/ms-icon-144x144.png\">\r\n  <meta name=\"theme-color\" content=\"#ffffff\">\r\n  <link rel=\"canonical\" href=\"https://www.tepco-sa.co.jp/ssl/recruit/new_graduate/survey/\">\r\n\r\n  <!--google fonts-->\r\n  <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\r\n  <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\r\n  <link href=\"https://fonts.googleapis.com/css2?family=Hina+Mincho&family=Zen+Maru+Gothic:wght@400;500;700;900&display=swap\" rel=\"stylesheet\">\r\n\r\n  <!--css-->\r\n  <link href=\"https://www.tepco-sa.co.jp/ssl/src/css/vendor.css\" rel=\"stylesheet\">\r\n  <link href=\"https://www.tepco-sa.co.jp/ssl/src/css/theme.css\" rel=\"stylesheet\">\r\n  <link href=\"https://www.tepco-sa.co.jp/ssl/src/css/themes/career-new-graduate.css\" rel=\"stylesheet\">\r\n  <script src=\"https://www.tepco-sa.co.jp/ssl/src/js/jquery.min.js\"></script>\r\n\r\n  <!-- Google Tag Manager -->\r\n  <script>(function (w, d, s, l, i) {\r\n      w[l] = w[l] || []; w[l].push({\r\n        'gtm.start':\r\n          new Date().getTime(), event: 'gtm.js'\r\n      }); var f = d.getElementsByTagName(s)[0],\r\n        j = d.createElement(s), dl = l != 'dataLayer' ? '&l=' + l : ''; j.async = true; j.src =\r\n          'https://www.googletagmanager.com/gtm.js?id=' + i + dl; f.parentNode.insertBefore(j, f);\r\n    })(window, document, 'script', 'dataLayer', 'GTM-P8XXC67');</script>\r\n  <!-- End Google Tag Manager -->\r\n</head>\r\n\r\n<body>\r\n  <!-- Google Tag Manager (noscript) -->\r\n  <noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-P8XXC67\" height=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\r\n  <!-- End Google Tag Manager (noscript) -->\r\n\r\n  <div id=\"header\"></div>\r\n  <script>\r\n    $(function () {\r\n      $('#header').load('https://www.tepco-sa.co.jp/ssl/src/inc/header.html');\r\n    });\r\n  </script>\r\n\r\n  <div class=\"page-wrapper new-graduate-survey-page\">\r\n    <div class=\"main-container bg-transparent p-0 mb-5\">\r\n      <nav aria-label=\"breadcrumb\" class=\"page-breadcrumb\">\r\n        <ol class=\"breadcrumb mb-0\">\r\n          <li class=\"breadcrumb-item\"><a href=\"https://www.tepco-sa.co.jp/ssl/\">ホーム</a></li>\r\n          <li class=\"breadcrumb-item\"><a href=\"https://www.tepco-sa.co.jp/ssl/recruit/\">採用情報</a></li>\r\n          <li class=\"breadcrumb-item\"><a href=\"https://www.tepco-sa.co.jp/ssl/recruit/new_graduate/\">新卒採用</a></li>\r\n          <li class=\"breadcrumb-item active\" aria-current=\"page\">先輩社員アンケート</li>\r\n        </ol>\r\n      </nav>\r\n    </div>\r\n    <div class=\"main-container sc-hero position-relative\">\r\n      <div class=\"hero-text-wrapper position-absolute text-center\">\r\n        <div class=\"text-tag position-relative\">新入社員の私たちが聞きました！\r\n          <div class=\"triangle-down position-absolute\"></div>\r\n        </div>\r\n        <div class=\"big-text text-orange mx-auto position-relative\">先輩社員<br>\r\n          アンケート</div>\r\n        <div class=\"btm-text text-dark\">\r\n          <div>入社1~3年目の皆さんに<br>\r\n            アンケートを取りました。</div>\r\n          <div><span class=\"text-orange\">働き方</span>や<span class=\"text-orange\">福利厚生</span>、<span class=\"text-orange\">休暇の過ごし方</span>など、<br>\r\n            リアルな声をお届けします！</div>\r\n        </div>\r\n      </div>\r\n      <div class=\"img-wrapper\">\r\n        <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/new_graduate/survey/hero-img.png\" class=\"d-none d-md-block\" alt=\"hero-img\">\r\n        <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/new_graduate/survey/hero-img-mobile.png\" class=\"d-md-none\" alt=\"hero-img\">\r\n      </div>\r\n    </div>\r\n    <div class=\"main-container wrapper-container\">\r\n      <div class=\"sc-main-wrapper\">\r\n        <div class=\"question-wrapper position-relative q1\">\r\n          <div class=\"q-num position-absolute d-flex align-items-center justify-content-center text-center\">Q1\r\n          </div>\r\n          <div class=\"question text-dark text-center\">入社前に<span class=\"text-orange position-relative\">電気の知識</span>はありましたか？</div>\r\n          <div class=\"main-content-wrapper d-flex align-items-center flex-column flex-lg-row gap-5 gap-lg-0\">\r\n            <div class=\"image-wrapper pie-chart\">\r\n              <div class=\"p-colum-chart js-fadeIn\">\r\n                <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/new_graduate/survey/q1-pie-chart.png\" alt=\"NO 100%\">\r\n                <p class=\"p-colum-chart-txt\">NO<span class=\"fzlarge\">100</span><span class=\"fzSmall\">%</span></p>\r\n              </div>\r\n            </div>\r\n            <div class=\"qa-box\">\r\n              <div class=\"qa-title text-dark text-center\">入社前、電気の知識は<span class=\"text-orange fw-bold\">全員がなし！</span><br>\r\n                どのように知識を身に付けたのでしょうか？</div>\r\n              <div class=\"chat-content\">\r\n                <div class=\"chat d-flex\">\r\n                  <div class=\"img-wrapper user-img\">\r\n                    <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/new_graduate/survey/chat-user-1.png\" alt=\"chat-user\">\r\n                  </div>\r\n                  <div class=\"message-box position-relative text-dark\">入社時の<span class=\"text-orange\">研修で基礎</span>を学び、配属後にわからないことを<span class=\"text-orange\">勉強会でサポート</span>してもらいました。\r\n                    <div class=\"img-wrapper pointed-icon position-absolute\">\r\n                      <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/new_graduate/survey/chat-point-icon.png\" alt=\"chat-point\">\r\n                    </div>\r\n                  </div>\r\n                </div>\r\n                <div class=\"chat d-flex\">\r\n                  <div class=\"message-box position-relative text-dark\"><span class=\"text-orange\">第二種電気工事士の資格取得</span>に向けた勉強を通して身に付けました。\r\n                    <div class=\"img-wrapper pointed-icon position-absolute\">\r\n                      <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/new_graduate/survey/chat-point-icon.png\" alt=\"chat-point\">\r\n                    </div>\r\n                  </div>\r\n                  <div class=\"img-wrapper user-img\">\r\n                    <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/new_graduate/survey/chat-user-2.png\" alt=\"chat-user\">\r\n                  </div>\r\n                </div>\r\n                <div class=\"chat d-flex\">\r\n                  <div class=\"img-wrapper user-img\">\r\n                    <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/new_graduate/survey/chat-user-3.png\" alt=\"chat-user\">\r\n                  </div>\r\n                  <div class=\"message-box position-relative text-dark\">周りの人に教えてもらいながら、仕事をしていく中で<span class=\"text-orange\">自然と</span>身に付けることができました。\r\n                    <div class=\"img-wrapper pointed-icon position-absolute\">\r\n                      <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/new_graduate/survey/chat-point-icon.png\" alt=\"chat-point\">\r\n                    </div>\r\n                  </div>\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n          <div class=\"addition-text-wrapper\">\r\n            <div class=\"btm-text text-dark\">研修や職場のサポートを通して業務知識を身に付けられるので、<br class=\"d-none d-md-block\"><span class=\"text-orange\">入社前に知識がなくても大丈夫</span>です！\r\n            </div>\r\n            <div class=\"img-wrapper\">\r\n              <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/new_graduate/survey/btm-img-1.png\" alt=\"btm-img\">\r\n            </div>\r\n          </div>\r\n        </div>\r\n        <div class=\"question-wrapper position-relative q2\">\r\n          <div class=\"q-num position-absolute d-flex align-items-center justify-content-center text-center\">Q2\r\n          </div>\r\n          <div class=\"question text-dark text-center\"><span class=\"text-orange position-relative\">休暇</span>は取得しやすいですか？</div>\r\n          <div class=\"main-content-wrapper d-flex align-items-center flex-column flex-lg-row gap-5 gap-lg-0\">\r\n            <div class=\"image-wrapper pie-chart\">\r\n              <div class=\"p-colum-chart js-fadeIn\">\r\n                <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/new_graduate/survey/q2-pie-chart.png\" alt=\"YES 98%\">\r\n                <p class=\"p-colum-chart-txt\">YES<span class=\"fzlarge\">98</span><span class=\"fzSmall\">%</span></p>\r\n              </div>\r\n            </div>\r\n            <div class=\"qa-box\">\r\n              <div class=\"qa-title text-dark text-center\">休みを<span class=\"text-orange fw-bold\">取りやすい環境</span>のようですね。<br>\r\n                どのような過ごし方をしているのでしょうか？\r\n              </div>\r\n              <div class=\"row activity-wrapper text-dark text-center\">\r\n                <div class=\"col-6\">\r\n                  <div class=\"activity\">友人と遊ぶ</div>\r\n                </div>\r\n                <div class=\"col-6\">\r\n                  <div class=\"activity\">旅行</div>\r\n                </div>\r\n                <div class=\"col-6\">\r\n                  <div class=\"activity\">ライブ</div>\r\n                </div>\r\n                <div class=\"col-6\">\r\n                  <div class=\"activity\">飲み会</div>\r\n                </div>\r\n                <div class=\"col-6\">\r\n                  <div class=\"activity\">お家でのんびり</div>\r\n                </div>\r\n                <div class=\"col-6\">\r\n                  <div class=\"activity\">映画鑑賞</div>\r\n                </div>\r\n                <div class=\"col-6\">\r\n                  <div class=\"activity\">ショッピング</div>\r\n                </div>\r\n                <div class=\"col-6\">\r\n                  <div class=\"activity\">ドライブ</div>\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n          <div class=\"addition-text-wrapper\">\r\n            <div class=\"btm-text text-dark\">さまざまなリフレッシュ方法で、休暇を満喫していますね。<br>\r\n              TSAは<span class=\"text-orange\">私生活も大事にしながら働ける環境</span>です！\r\n            </div>\r\n            <div class=\"img-wrapper\">\r\n              <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/new_graduate/survey/btm-img-2.png\" alt=\"btm-img\">\r\n            </div>\r\n          </div>\r\n        </div>\r\n        <div class=\"question-wrapper position-relative q3\">\r\n          <div class=\"q-num position-absolute d-flex align-items-center justify-content-center text-center\">Q3\r\n          </div>\r\n          <div class=\"question text-dark text-center\"><span class=\"text-orange position-relative\">カフェテリアプラン</span><sup>※</sup>には満足していますか？</div>\r\n          <div class=\"q-descp text-center text-dark\">※ 付与されたポイント内で旅行や日用品などを購入できます。 </div>\r\n          <div class=\"main-content-wrapper d-flex align-items-center flex-column flex-lg-row gap-5 gap-lg-0\">\r\n            <div class=\"image-wrapper pie-chart\">\r\n              <div class=\"p-colum-chart js-fadeIn\">\r\n                <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/new_graduate/survey/q3-pie-chart.png\" alt=\"YES 100%\">\r\n                <p class=\"p-colum-chart-txt\">YES<span class=\"fzlarge\">100</span><span class=\"fzSmall\">%</span></p>\r\n              </div>\r\n            </div>\r\n            <div class=\"qa-box\">\r\n              <div class=\"qa-title text-dark text-center\">なんと<span class=\"text-orange fw-bold\">満足率は100％！<br></span>どんなことにカフェテリアプランを<br>\r\n                利用しているのでしょうか？\r\n              </div>\r\n              <div class=\"row activity-wrapper text-dark text-center\">\r\n                <div class=\"col-6\">\r\n                  <div class=\"activity\">映画のチケット</div>\r\n                </div>\r\n                <div class=\"col-6\">\r\n                  <div class=\"activity\">ホテルの予約</div>\r\n                </div>\r\n                <div class=\"col-6\">\r\n                  <div class=\"activity\">スマホの機種変更</div>\r\n                </div>\r\n                <div class=\"col-6\">\r\n                  <div class=\"activity\">ブランド品</div>\r\n                </div>\r\n                <div class=\"col-6\">\r\n                  <div class=\"activity\">家電</div>\r\n                </div>\r\n                <div class=\"col-6\">\r\n                  <div class=\"activity\">コスメ</div>\r\n                </div>\r\n                <div class=\"col-6\">\r\n                  <div class=\"activity\">お米</div>\r\n                </div>\r\n                <div class=\"col-6\">\r\n                  <div class=\"activity\">福島の特産物</div>\r\n                </div>\r\n              </div>\r\n              <div class=\"etc text-end text-dark mt-2\">etc...</div>\r\n            </div>\r\n          </div>\r\n          <div class=\"addition-text-wrapper\">\r\n            <div class=\"btm-text text-dark\">日用品から旅行まで、様々な用途で利用していますね。<br>\r\n              TSAは<span class=\"text-orange\">生活に役立つ福利厚生が充実</span>しています！\r\n            </div>\r\n            <div class=\"img-wrapper\">\r\n              <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/new_graduate/survey/btm-img-3.png\" alt=\"btm-img\">\r\n            </div>\r\n          </div>\r\n        </div>\r\n        <div class=\"question-wrapper position-relative q4\">\r\n          <div class=\"q-num position-absolute d-flex align-items-center justify-content-center text-center\">Q4\r\n          </div>\r\n          <div class=\"question text-dark text-center\"><span class=\"text-orange position-relative\">通勤時間</span>はどのくらいですか？</div>\r\n          <div class=\"main-content-wrapper d-flex align-items-center justify-content-center flex-column flex-lg-row gap-5 gap-lg-0\">\r\n            <div class=\"image-wrapper left-img js-fadeIn\">\r\n              <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/new_graduate/survey/left-img-q4.png\" alt=\"pie-chart\">\r\n            </div>\r\n            <div class=\"image-wrapper right-img\">\r\n              <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/new_graduate/survey/right-img-q4.png\" alt=\"pie-chart\">\r\n            </div>\r\n          </div>\r\n          <div class=\"addition-text-wrapper\">\r\n            <div class=\"btm-text text-dark\">若手社員の<span class=\"text-orange\">半数以上が60分以内</span>で通勤できています！<br>\r\n              入社前に遠方に住んでいた方も、<span class=\"text-orange\">社宅</span>を利用して<span class=\"text-orange\">職住接近</span>を実現しています。\r\n            </div>\r\n          </div>\r\n        </div>\r\n        <div class=\"question-wrapper position-relative\">\r\n          <div class=\"q-num position-absolute d-flex align-items-center justify-content-center text-center\">Q5\r\n          </div>\r\n          <div class=\"question text-dark text-center\">職場の<span class=\"text-orange position-relative\">ファッションの自由度</span>は高いですか？</div>\r\n          <div class=\"main-content-wrapper d-flex align-items-center flex-column flex-lg-row gap-5 gap-lg-0\">\r\n            <div class=\"image-wrapper pie-chart\">\r\n              <div class=\"p-colum-chart js-fadeIn\">\r\n                <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/new_graduate/survey/q3-pie-chart.png\" alt=\"YES 100%\">\r\n                <p class=\"p-colum-chart-txt\">YES<span class=\"fzlarge\">100</span><span class=\"fzSmall\">%</span></p>\r\n              </div>\r\n            </div>\r\n            <div class=\"qa-box\">\r\n              <div class=\"qa-title text-dark text-center\"><span class=\"text-orange fw-bold\">オフィスカジュアル</span>を導入しているようですが、<br>\r\n                実際にどのような格好で勤務しているのでしょうか？</div>\r\n              <div class=\"chat-content\">\r\n                <div class=\"chat d-flex\">\r\n                  <div class=\"img-wrapper user-img\">\r\n                    <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/new_graduate/survey/q5-chat-user-1.png\" alt=\"chat-user\">\r\n                  </div>\r\n                  <div class=\"message-box position-relative text-dark\"><span class=\"text-orange\">ジーンズ</span>や<span class=\"text-orange\">パーカー、Tシャツ</span>など、カジュアルな服装で勤務しています。\r\n                    <div class=\"img-wrapper pointed-icon position-absolute\">\r\n                      <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/new_graduate/survey/chat-point-icon.png\" alt=\"chat-point\">\r\n                    </div>\r\n                  </div>\r\n                </div>\r\n                <div class=\"chat d-flex\">\r\n                  <div class=\"message-box position-relative text-dark\"><span class=\"text-orange\">インナーカラー</span>をいれるなど、<span class=\"text-orange\">自分の好きな髪色</span>を楽しんでいます。\r\n                    <div class=\"img-wrapper pointed-icon position-absolute\">\r\n                      <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/new_graduate/survey/chat-point-icon.png\" alt=\"chat-point\">\r\n                    </div>\r\n                  </div>\r\n                  <div class=\"img-wrapper user-img\">\r\n                    <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/new_graduate/survey/q5-chat-user-2.png\" alt=\"chat-user\">\r\n                  </div>\r\n                </div>\r\n                <div class=\"chat d-flex\">\r\n                  <div class=\"img-wrapper user-img\">\r\n                    <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/new_graduate/survey/q5-chat-user-3.png\" alt=\"chat-user\">\r\n                  </div>\r\n                  <div class=\"message-box position-relative text-dark\">忙しいときほど<span class=\"text-orange\">お気に入りのネイル</span>をして、気分を上げています。\r\n                    <div class=\"img-wrapper pointed-icon position-absolute\">\r\n                      <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/new_graduate/survey/chat-point-icon.png\" alt=\"chat-point\">\r\n                    </div>\r\n                  </div>\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n          <div class=\"addition-text-wrapper\">\r\n            <div class=\"btm-text text-dark\">自由なファッションで働ける環境のようですね。<br>\r\n              TSAは好きな服装や髪型・ネイルで、<br class=\"d-none d-md-block\"><span class=\"text-orange\">自分らしく</span>仕事ができます！\r\n            </div>\r\n            <div class=\"img-wrapper\">\r\n              <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/new_graduate/survey/btm-img-5.png\" alt=\"btm-img\">\r\n            </div>\r\n          </div>\r\n        </div>\r\n        <div class=\"question-wrapper position-relative q6\">\r\n          <div class=\"q-num position-absolute d-flex align-items-center justify-content-center text-center\">Q6\r\n          </div>\r\n          <div class=\"question text-dark text-center\">あなたの職場は<span class=\"text-orange position-relative\">相談しやすい</span>環境ですか？</div>\r\n          <div class=\"main-content-wrapper d-flex align-items-center flex-column flex-lg-row gap-5 gap-lg-0\">\r\n            <div class=\"qa-box\">\r\n              <div class=\"chat-content row\">\r\n                <div class=\"col-12 col-lg-6\">\r\n                  <div class=\"chat d-flex align-items-end\">\r\n                    <div class=\"img-wrapper user-img\">\r\n                      <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/new_graduate/survey/q6-chat-user-1.png\" alt=\"chat-user\">\r\n                    </div>\r\n                    <div class=\"message-box position-relative text-dark\">入社1年目は<span class=\"text-orange\">メンター制度</span>があるため、困ったときは、メンターへ相談しています。\r\n                      <div class=\"img-wrapper pointed-icon position-absolute\">\r\n                        <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/new_graduate/survey/chat-point-icon.png\" alt=\"chat-point\">\r\n                      </div>\r\n                    </div>\r\n                  </div>\r\n                </div>\r\n                <div class=\"col-12 col-lg-6\">\r\n                  <div class=\"chat d-flex align-items-end\">\r\n                    <div class=\"message-box position-relative text-dark\">仕事で困った際、<br><span class=\"text-orange\">先輩</span>や<span class=\"text-orange\">上司</span>が解決策を<br>\r\n                      <span class=\"text-orange\">一緒に考えてくれます。</span>\r\n                      <div class=\"img-wrapper pointed-icon position-absolute\">\r\n                        <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/new_graduate/survey/chat-point-icon.png\" alt=\"chat-point\">\r\n                      </div>\r\n                    </div>\r\n                    <div class=\"img-wrapper user-img\">\r\n                      <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/new_graduate/survey/q6-chat-user-2.png\" alt=\"chat-user\">\r\n                    </div>\r\n                  </div>\r\n\r\n                </div>\r\n                <div class=\"col-12 col-lg-6\">\r\n                  <div class=\"chat d-flex align-items-end\">\r\n                    <div class=\"img-wrapper user-img\">\r\n                      <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/new_graduate/survey/q6-chat-user-3.png\" alt=\"chat-user\">\r\n                    </div>\r\n                    <div class=\"message-box position-relative text-dark\">何でも気軽に話せる職場環境で、<span class=\"text-orange\">小さなこと</span>でも相談しやすいです。\r\n                      <div class=\"img-wrapper pointed-icon position-absolute\">\r\n                        <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/new_graduate/survey/chat-point-icon.png\" alt=\"chat-point\">\r\n                      </div>\r\n                    </div>\r\n                  </div>\r\n                </div>\r\n                <div class=\"col-12 col-lg-6\">\r\n                  <div class=\"chat d-flex align-items-end\">\r\n                    <div class=\"message-box position-relative text-dark\">「わからないことは<span class=\"text-orange\">何回でも聞いてね！</span>」と声をかけてもらえるので、安心して相談できます。\r\n                      <div class=\"img-wrapper pointed-icon position-absolute\">\r\n                        <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/new_graduate/survey/chat-point-icon.png\" alt=\"chat-point\">\r\n                      </div>\r\n                    </div>\r\n                    <div class=\"img-wrapper user-img\">\r\n                      <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/new_graduate/survey/q6-chat-user-4.png\" alt=\"chat-user\">\r\n                    </div>\r\n                  </div>\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n          <div class=\"addition-text-wrapper\">\r\n            <div class=\"btm-text text-dark\">周りの人に気兼ねなく相談できているようですね。<br>\r\n              わからないことがあっても<span class=\"text-orange\">安心して働ける</span>環境です！\r\n            </div>\r\n            <div class=\"img-wrapper\">\r\n              <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/new_graduate/survey/btm-img-6.png\" alt=\"btm-img\">\r\n            </div>\r\n          </div>\r\n        </div>\r\n        <div class=\"question-wrapper position-relative q6 q7\">\r\n          <div class=\"q-num position-absolute d-flex align-items-center justify-content-center text-center\">Q7\r\n          </div>\r\n          <div class=\"question text-dark text-center\">みんなの<span class=\"text-orange position-relative\">仲良しエピソード</span>を教えてください！</div>\r\n          <div class=\"main-content-wrapper d-flex align-items-center flex-column flex-lg-row gap-5 gap-lg-0\">\r\n            <div class=\"qa-box\">\r\n              <div class=\"chat-content row\">\r\n                <div class=\"col-12 col-lg-6\">\r\n                  <div class=\"chat d-flex align-items-end\">\r\n                    <div class=\"img-wrapper user-img\">\r\n                      <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/new_graduate/survey/q7-chat-user-1.png\" alt=\"chat-user\">\r\n                    </div>\r\n                    <div class=\"message-box position-relative text-dark\"><span class=\"text-orange\">先輩とランチ</span>が平日の楽しみです。今度休日に <span class=\"text-orange\">アフタヌーンティー</span>に行く約束もしています。\r\n                      <div class=\"img-wrapper pointed-icon position-absolute\">\r\n                        <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/new_graduate/survey/chat-point-icon.png\" alt=\"chat-point\">\r\n                      </div>\r\n                    </div>\r\n                  </div>\r\n                </div>\r\n                <div class=\"col-12 col-lg-6\">\r\n                  <div class=\"chat d-flex align-items-end\">\r\n                    <div class=\"message-box position-relative text-dark\">入社してから<span class=\"text-orange\">毎月同期会</span>は欠かさず開催しています。\r\n                      <div class=\"img-wrapper pointed-icon position-absolute\">\r\n                        <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/new_graduate/survey/chat-point-icon.png\" alt=\"chat-point\">\r\n                      </div>\r\n                    </div>\r\n                    <div class=\"img-wrapper user-img\">\r\n                      <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/new_graduate/survey/q7-chat-user-2.png\" alt=\"chat-user\">\r\n                    </div>\r\n                  </div>\r\n\r\n                </div>\r\n                <div class=\"col-12 col-lg-6\">\r\n                  <div class=\"chat d-flex align-items-end\">\r\n                    <div class=\"img-wrapper user-img\">\r\n                      <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/new_graduate/survey/q7-chat-user-3.png\" alt=\"chat-user\">\r\n                    </div>\r\n                    <div class=\"message-box position-relative text-dark\">休日は一緒に<span class=\"text-orange\">テーマパーク</span>に出かけるほど仲がいいです。\r\n                      <div class=\"img-wrapper pointed-icon position-absolute\">\r\n                        <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/new_graduate/survey/chat-point-icon.png\" alt=\"chat-point\">\r\n                      </div>\r\n                    </div>\r\n                  </div>\r\n                </div>\r\n                <div class=\"col-12 col-lg-6\">\r\n                  <div class=\"chat d-flex align-items-end\">\r\n                    <div class=\"message-box position-relative text-dark\">仕事や私生活問わず相談ができる<span class=\"text-orange\">大切な存在</span>です。\r\n                      <div class=\"img-wrapper pointed-icon position-absolute\">\r\n                        <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/new_graduate/survey/chat-point-icon.png\" alt=\"chat-point\">\r\n                      </div>\r\n                    </div>\r\n                    <div class=\"img-wrapper user-img\">\r\n                      <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/new_graduate/survey/q7-chat-user-4.png\" alt=\"chat-user\">\r\n                    </div>\r\n                  </div>\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n          <div class=\"addition-text-wrapper\">\r\n            <div class=\"btm-text text-dark\">若手社員同士、<span class=\"text-orange\">良好な関係性</span>を構築できているようですね。<br>\r\n              オンオフメリハリをつけて、楽しく過ごしています！\r\n            </div>\r\n            <div class=\"img-wrapper\">\r\n              <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/new_graduate/survey/btm-img-7.png\" alt=\"btm-img\">\r\n            </div>\r\n          </div>\r\n        </div>\r\n        <div class=\"question-wrapper position-relative q6 q8\">\r\n          <div class=\"q-num position-absolute d-flex align-items-center justify-content-center text-center\">Q8\r\n          </div>\r\n          <div class=\"question text-dark text-center\">業務の<span class=\"text-orange position-relative\">やりがい</span>を教えてください！</div>\r\n          <div class=\"main-content-wrapper d-flex align-items-center flex-column flex-lg-row gap-5 gap-lg-0\">\r\n            <div class=\"qa-box\">\r\n              <div class=\"chat-content row\">\r\n                <div class=\"col-12 col-lg-6\">\r\n                  <div class=\"chat d-flex align-items-end\">\r\n                    <div class=\"img-wrapper user-img\">\r\n                      <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/new_graduate/survey/q8-chat-user-1.png\" alt=\"chat-user\">\r\n                    </div>\r\n                    <div class=\"message-box position-relative text-dark\">自分のアイデアで業務を<span class=\"text-orange\">カイゼン</span>できることです。\r\n                      <div class=\"img-wrapper pointed-icon position-absolute\">\r\n                        <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/new_graduate/survey/chat-point-icon.png\" alt=\"chat-point\">\r\n                      </div>\r\n                    </div>\r\n                  </div>\r\n                </div>\r\n                <div class=\"col-12 col-lg-6\">\r\n                  <div class=\"chat d-flex align-items-end\">\r\n                    <div class=\"message-box position-relative text-dark\">お客さまからの<span class=\"text-orange\">感謝の言葉</span>が一番のやりがいです。\r\n                      <div class=\"img-wrapper pointed-icon position-absolute\">\r\n                        <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/new_graduate/survey/chat-point-icon.png\" alt=\"chat-point\">\r\n                      </div>\r\n                    </div>\r\n                    <div class=\"img-wrapper user-img\">\r\n                      <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/new_graduate/survey/q8-chat-user-2.png\" alt=\"chat-user\">\r\n                    </div>\r\n                  </div>\r\n\r\n                </div>\r\n                <div class=\"col-12 col-lg-6\">\r\n                  <div class=\"chat d-flex align-items-end\">\r\n                    <div class=\"img-wrapper user-img\">\r\n                      <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/new_graduate/survey/q8-chat-user-3.png\" alt=\"chat-user\">\r\n                    </div>\r\n                    <div class=\"message-box position-relative text-dark\">習得した業務知識を活かして<span class=\"text-orange\">新しいことに挑戦</span>させてもらえるとき。\r\n                      <div class=\"img-wrapper pointed-icon position-absolute\">\r\n                        <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/new_graduate/survey/chat-point-icon.png\" alt=\"chat-point\">\r\n                      </div>\r\n                    </div>\r\n                  </div>\r\n                </div>\r\n                <div class=\"col-12 col-lg-6\">\r\n                  <div class=\"chat d-flex align-items-end\">\r\n                    <div class=\"message-box position-relative text-dark\">自分の<span class=\"text-orange\">成長を実感</span>できた時にやりがいを感じます。\r\n                      <div class=\"img-wrapper pointed-icon position-absolute\">\r\n                        <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/new_graduate/survey/chat-point-icon.png\" alt=\"chat-point\">\r\n                      </div>\r\n                    </div>\r\n                    <div class=\"img-wrapper user-img\">\r\n                      <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/new_graduate/survey/q8-chat-user-4.png\" alt=\"chat-user\">\r\n                    </div>\r\n                  </div>\r\n\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n          <div class=\"addition-text-wrapper\">\r\n            <div class=\"btm-text text-dark\">一人ひとりが<span class=\"text-orange\">変化を楽しみ</span>、何事にも<span class=\"text-orange\">挑戦し続ける</span>ことで、<br class=\"d-none d-md-block\">やりがいをもって仕事をしているようですね。\r\n            </div>\r\n            <div class=\"img-wrapper\">\r\n              <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/new_graduate/survey/btm-img-8.png\" alt=\"btm-img\">\r\n            </div>\r\n          </div>\r\n        </div>\r\n        <div class=\"question-wrapper position-relative q6 q9\">\r\n          <div class=\"q-num position-absolute d-flex align-items-center justify-content-center text-center\">Q9\r\n          </div>\r\n          <div class=\"question text-dark text-center\">TSAの<span class=\"text-orange position-relative\">魅力</span>を教えてください！</div>\r\n          <div class=\"main-content-wrapper d-flex align-items-center flex-column flex-lg-row gap-5 gap-lg-0\">\r\n            <div class=\"qa-box\">\r\n              <div class=\"chat-content row\">\r\n                <div class=\"col-12 col-lg-6\">\r\n                  <div class=\"chat d-flex align-items-end\">\r\n                    <div class=\"img-wrapper user-img\">\r\n                      <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/new_graduate/survey/q9-chat-user-1.png\" alt=\"chat-user\">\r\n                    </div>\r\n                    <div class=\"message-box position-relative text-dark text-center\"><span class=\"text-orange\">福利厚生</span>が充実している\r\n                      <div class=\"img-wrapper pointed-icon position-absolute\">\r\n                        <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/new_graduate/survey/chat-point-icon.png\" alt=\"chat-point\">\r\n                      </div>\r\n                    </div>\r\n                  </div>\r\n                </div>\r\n                <div class=\"col-12 col-lg-6\">\r\n                  <div class=\"chat d-flex align-items-end\">\r\n                    <div class=\"message-box position-relative text-dark\"><span class=\"text-orange\">新入社員</span>のうちから<span class=\"text-orange\">プロジェクト</span>に参加できる\r\n                      <div class=\"img-wrapper pointed-icon position-absolute\">\r\n                        <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/new_graduate/survey/chat-point-icon.png\" alt=\"chat-point\">\r\n                      </div>\r\n                    </div>\r\n                    <div class=\"img-wrapper user-img\">\r\n                      <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/new_graduate/survey/q9-chat-user-2.png\" alt=\"chat-user\">\r\n                    </div>\r\n                  </div>\r\n\r\n                </div>\r\n                <div class=\"col-12 col-lg-6\">\r\n                  <div class=\"chat d-flex align-items-end\">\r\n                    <div class=\"img-wrapper user-img\">\r\n                      <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/new_graduate/survey/q9-chat-user-3.png\" alt=\"chat-user\">\r\n                    </div>\r\n                    <div class=\"message-box position-relative text-dark text-start text-md-center\"><span class=\"text-orange\">新たなこと</span>にチャレンジできる\r\n                      <div class=\"img-wrapper pointed-icon position-absolute\">\r\n                        <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/new_graduate/survey/chat-point-icon.png\" alt=\"chat-point\">\r\n                      </div>\r\n                    </div>\r\n                  </div>\r\n                </div>\r\n                <div class=\"col-12 col-lg-6\">\r\n                  <div class=\"chat d-flex align-items-end\">\r\n                    <div class=\"message-box position-relative text-dark text-center\"><span class=\"text-orange\">相談しやすい</span>職場環境\r\n                      <div class=\"img-wrapper pointed-icon position-absolute\">\r\n                        <img