{"url":"http://www.r-ehm.co.jp/recruit/description/","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n\n<head>\n  <meta charset=\"utf-8\">\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n  <title>募集要項-トヨタレンタリース西四国</title>\n  <meta name=\"description\" content=\"よいクルマ、よいサービス。愛媛県と高知県のレンタカー予約はトヨタレンタリース西四国へ！\">\n  <meta name=\"title\" content=\"募集要項-トヨタレンタリース西四国\">\n  <meta content=\"IE=edge\" http-equiv=\"X-UA-Compatible\">\n  <meta name=\"format-detection\" content=\"telephone=no,address=no,email=no\">\n  <!-- seo -->\n  <meta property=\"og:title\" content=\"募集要項-トヨタレンタリース西四国\" />\n  <meta property=\"og:type\" content=\"website\" />\n  <meta property=\"og:url\" content=\"https://www.r-ehm.co.jp/recruit/description/\" />\n  <meta property=\"og:image\" content=\"https://www.r-ehm.co.jp/assets/img/ogp.jpg\" />\n  <meta property=\"og:site_name\" content=\"募集要項-トヨタレンタリース西四国\" />\n  <meta property=\"og:description\" content=\"よいクルマ、よいサービス。愛媛県と高知県のレンタカー予約はトヨタレンタリース西四国へ！\" />\n  <meta name=\"twitter:card\" content=\"summary\" />\n  <meta name=\"twitter:title\" content=\"募集要項-トヨタレンタリース西四国\" />\n  <meta name=\"twitter:description\" content=\"よいクルマ、よいサービス。愛媛県と高知県のレンタカー予約はトヨタレンタリース西四国へ！\" />\n  <meta name=\"twitter:image\" content=\"https://www.r-ehm.co.jp/assets/img/ogp.jpg\" />\n\n  <!-- faviconの指定 -->\n  <link rel=\"icon\" type=\"img/x-icon\" href=\"/assets/img/favicon.ico\">\n  <link rel=\"icon\" href=\"/assets/img/favicon.ico\">\n  <link rel=\"shortcut icon\" type=\"img/vnd.microsoft.icon\" href=\"/assets/img/favicon.ico\">\n  <link rel=\"icon\" type=\"img/vnd.microsoft.icon\" href=\"/assets/img/favicon.ico\">\n  <link rel=\"apple-touch-icon\" href=\"/apple-touch-icon.png\" sizes=\"180x180\">\n  <link rel=\"apple-touch-icon-precomposed\" href=\"/apple-touch-icon.png\" sizes=\"180x180\">\n  <link rel=\"stylesheet\" href=\"https://unpkg.com/swiper/swiper-bundle.min.css\">\n  <link rel=\"stylesheet\" href=\"/assets/css/scss/pages/common.css\">\n  <link rel=\"stylesheet\" href=\"/assets/css/scss/pages/description.css\">\n</head>\n\n<body>\n  <div class=\"wrap\">\n    <div class=\"l-content\">\n      <!-- l-header -->\n      <header class=\"l-header js-header\">\n        <div class=\"l-header-logo\">\n          <h1 class=\"l-header-logo__ttl\">\n            <a class=\"-link\" href=\"/\">\n              <img src=\"/assets/img/common/logo.svg\" alt=\"TOYOTA Rent a Car\">\n            </a>\n          </h1>\n        </div>\n        <div id=\"js-drawermenu\" class=\"l-header-area\">\n          <ul class=\"l-header-area__list\">\n            <li class=\"l-header-area__list-item\"><a class=\"-link\" href=\"/\">ホーム</a></li>\n            <li class=\"l-header-area__list-item\"><a class=\"-link\" href=\"/company/\">会社概要</a></li>\n            <div class=\"l-header-area__list-item l-header-area__list-item--linkaccd\">\n              <a class=\"-link\" href=\"/recruit/\">採用情報</a>\n              <span class=\"l-header-area__list-item--linkaccd-btn js-accd\"></span>\n              <ul class=\"l-header-area__list-ul\" style=\"display:none;\">\n                <li class=\"l-header-area__list-section l-header-area__list-section--mt\"><a href=\"/recruit/interview/\">-\n                    社員インタビュー</a></li>\n                <li class=\"l-header-area__list-section\"><a href=\"/recruit/data/\">- 数字で見る</a></li>\n                <li class=\"l-header-area__list-section\"><a href=\"/recruit/training/\">- 研修制度</a></li>\n                <li class=\"l-header-area__list-section\"><a href=\"/recruit/faq/\">- よくあるご質問</a></li>\n                <li class=\"l-header-area__list-section\"><a href=\"/recruit/description/\">- 募集要項</a></li>\n              </ul>\n            </div>\n          </ul>\n          <div class=\"l-header-area__targetbox\">\n            <div class=\"l-header-area__shop\">\n              <a href=\"/shop/\"><span class=\"-icon\">店舗を探す</span></a>\n            </div>\n            <div class=\"l-header-area__info\">\n              <a href=\"https://rent.toyota.co.jp/static/guide/\" target=\"_blank\"><span class=\"-icon\">ご利用案内</span></a>\n            </div>\n            <div class=\"l-header-area__reservation\">\n              <a href=\"https://rent.toyota.co.jp/\" target=\"_blank\"><span class=\"-icon\">インターネット予約</span></a>\n            </div>\n          </div>\n        </div>\n        <div id=\"js-btnTrigger\" class=\"js-navbtn l-header-humbtn\">\n          <span class=\"l-header-humbtn__line\">\n            <!--btn-->\n          </span>\n          <span class=\"l-header-humbtn__line\">\n            <!--btn-->\n          </span>\n        </div>\n      </header>\n      <!-- l-snsbox -->\n      <div class=\"l-snsbox\">\n        <div class=\"l-snsbox-block l-snsbox-block--01\">\n          <a href=\"/recruit/\">\n            <p class=\"-txt\">採用情報</p>\n          </a>\n        </div>\n        <div class=\"l-snsbox-block l-snsbox-block--02\">\n          <a href=\"https://www.instagram.com/toyota_nishishikoku/\" target=\"_blank\">\n            <p class=\"-txt\">インスタグラム</p>\n          </a>\n        </div>\n      </div>\n      <div class=\"l-content-main\">\n        <section class=\"c-submv\">\n          <div class=\"c-submv-bg\"></div>\n          <div class=\"inner c-submv--inner\">\n            <div class=\"c-submv-img c-submv-img--description\"></div>\n            <div class=\"c-submv-area flex is-between\">\n              <h1 class=\"-ttl\">募集要項</h1>\n              <div class=\"-breadcrumbs\">\n                <ul class=\"flex\">\n                  <li><a href=\"/\">トップ</a></li>\n                  <li><a href=\"/recruit/\">採用情報</a></li>\n                  <li>募集要項</li>\n                </ul>\n              </div>\n            </div>\n          </div>\n        </section>\n\n<!-- p-description-area -->\n  <section class=\"p-description-area\">\n      <!-- p-description-area__tab -->\n      <ul class=\"p-description-area__tab flex\">\n        <li class=\"js-tab active\">レンタカーコンシェルジュ</li>\n      </ul>\n      <!-- p-description-area__cont -->\n      <div class=\"p-description-area__cont\">\n        <!-- p-description-area__cont-block -->\n        <div class=\"p-description-area__cont-block js-content show\">\n          <div class=\"-message\">\n            <div class=\"inner -message--inner flex\">\n              <div class=\"-message-left\">\n              <p class=\"-message-left-ttl\">先輩スタッフからのメッセージ</p>\n              <p class=\"-message-left-txt\">この会社は、スタッフ一人ひとりの意見を大切にしてくれる環境があります。入社してすぐでも、自分のアイデアを発信でき、挑戦できる自由さがあるのが魅力です。<br>お客様に安心して楽しんでもらえるよう、チーム全体で明るい雰囲気を作ることも大切にしています。私も日々、スタッフやお客様から信頼される存在を目指して働いています。笑顔で元気に働きたい方には、やりがいを感じられる職場だと思います。</p>\n            </div>\n            <div class=\"-message-right\">\n              <img src=\"/assets/img/description/img01.jpg\" alt=\"\">\n            </div>\n            </div>\n          </div>\n          <div class=\"-outer\">\n            <div class=\"-outer-in inner -outer--inner\">\n              <div class=\"-item\">\n                <p class=\"-item-ttl\">●募集職種</p>\n                <p class=\"-item-txt\">レンタカーコンシェルジュ</p>\n              </div>\n              <div class=\"-item\">\n                <p class=\"-item-ttl\">●応募資格</p>\n                <p class=\"-item-txt\">普通免許以上(入社後準中型、M/T免許取得が望ましい、取得補助制度有り)<br>※取得期限は令和8年入社日まで</p>\n              </div>\n              <div class=\"-item\">\n                <p class=\"-item-ttl\">●応募条件/人数</p>\n                <p class=\"-item-txt\">大学・短大・専門学校　2～3名（学部等不問）<br>既卒可（卒業後概ね3年）</p>\n              </div>\n              <div class=\"-item\">\n                <p class=\"-item-ttl\">●勤務予定地</p>\n                <p class=\"-item-txt\">レンタカーコンシェルジュ：松山地区・高知地区</p>\n              </div>\n              <div class=\"-item\">\n                <p class=\"-item-ttl\">●業務内容</p>\n                <p class=\"-item-txt\">レンタカーコンシェルジュ業務<br>\nご利用されるお客様は多岐にわたります。<br>\nご旅行で四国に来られる方、お仕事で来られる方、外国人の方々です。<br>\n私たちは、ご来店される様々なお客様に対して、車両の案内、安全装備の説明から利用用途に応じたアドバイス、旅行のプランニング等々、お客様の様々なリクエストにお応えすることを目指しています。</p>\n              </div>\n              <div class=\"-item\">\n                <p class=\"-item-ttl\">●勤務時間</p>\n                <p class=\"-item-txt\">◆空港店・駅前店　営業時間： 8:00～20:00<br><br>◆勤務時間：レンタカーコンシェルジュ(交代制)<br>①8：00～16：30　　②11：30～20：00<br><br>※1ヶ月単位の変形労働時間制</p>\n              </div>\n              <div class=\"-item\">\n                <p class=\"-item-ttl\">●休日等</p>\n                <p class=\"-item-txt\">年間112日　　会社指定有給休暇　5日</p>\n              </div>\n              <div class=\"-item\">\n                <p class=\"-item-ttl\">●有給休暇</p>\n                <p class=\"-item-txt\">入社後すぐに5日付与され、6ヶ月カ月後5日付与（初年度10日間）。<br>翌年度以降の有給休暇日数は就業規則に定められています。</p>\n              </div>\n              <div class=\"-item\">\n                <p class=\"-item-ttl\">●給与</p>\n                <p class=\"-item-txt\">入社時　基本給　197,000円+諸手当(通勤・業績・皆勤・超過勤務)<br>\n翌年度以降、様々な資格取得や職能資格制度等により以下の手当が付与<br>\n資格手当・諸手当(役職・役割・家族・住宅・各種資格・技能等)</p>\n              </div>\n              <div class=\"-item\">\n                <p class=\"-item-ttl\">●賞与</p>\n                <p class=\"-item-txt\">年2回（6月・12月）</p>\n              </div>\n              <div class=\"-item\">\n                <p class=\"-item-ttl\">●試用採用</p>\n                <p class=\"-item-txt\">試用採用期間は3ヶ月<br>就業規則に定められた内容</p>\n              </div>\n              <div class=\"-item\">\n                <p class=\"-item-ttl\">●休業・休暇体制</p>\n                <p class=\"-item-txt\">育児（実績あり）・介護休業（実績あり）　介護休暇　看護休暇</p>\n              </div>\n              <div class=\"-item\">\n                <p class=\"-item-ttl\">●各種制度</p>\n                <p class=\"-item-txt\">各種保険・財形・確定拠出年金 退職金制度（入社3年以上） 資格奨励金制度・研修制度（社内・外）</p>\n              </div>\n              <div class=\"-item\">\n                <p class=\"-item-ttl\">●組合</p>\n                <p class=\"-item-txt\">労働組合なし・社員会あり</p>\n              </div>\n              <div class=\"-item\">\n                <p class=\"-item-ttl\">●定年</p>\n                <p class=\"-item-txt\">60歳の誕生日を迎えた月の末日</p>\n              </div>\n              <div class=\"-item\">\n                <p class=\"-item-ttl\">●再雇用</p>\n                <p class=\"-item-txt\">定年後再雇用規定あり</p>\n              </div>\n              <p class=\"-outer-icon\">\n                <img src=\"/assets/img/description/icon01.png\" alt=\"\">\n              </p>\n            </div>\n          </div>\n        </div>\n      </div>\n  </section>\n\n\n\n\n<!-- c-recruit-layout -->\n        <section class=\"c-recruit-layout\">\n          <div class=\"inner c-recruit-layout--inner\">\n            <div class=\"c-recruit-layout__area flex\">\n              <div class=\"c-recruit-layout__area-left\">\n                <div class=\"c-ttl02box c-recruit-layout__area-left--ttl\">\n                  <h2 class=\"c-ttl02 js-anime\">recruit<span class=\"-jp\">採用情報</span></h2>\n                </div>\n                <p class=\"-catch\">地域と共に、人も育つ。<br>トヨタレンタリース西四国の<br><span class=\"-color\">未来</sapn>を一緒に。</p>\n                <p class=\"c-recruit-layout-txt\">\n                  愛媛・高知のあたたかさそのままに、職場も明るく居心地の良い環境が自慢です。役職や年齢に関係なく、意見を出し合い、助け合える関係性が根づいています。<br>地域の方々に寄り添いながら、自分らしくのびのびと働ける職場で、一緒に成長していきませんか？\n                </p>\n                <div class=\"c-btn01 c-recruit-layout--btn\">\n                  <a href=\"/recruit/\">\n                    <p class=\"-txt\">採用情報を見る</p>\n                  </a>\n                </div>\n              </div>\n              <div class=\"c-recruit-layout__area-right\">\n                <div class=\"-bgicon\">\n                  <img src=\"/assets/img/top/recruit-bg.png\">\n                </div>\n                <div class=\"-imgbox01 js-anime\">\n                  <div class=\"-in js-pararax\">\n                    <img src=\"/assets/img/top/recruit-img01.jpg\">\n                  </div>\n                </div>\n                <div class=\"-imgbox02 js-anime\">\n                  <div class=\"-in js-pararax\">\n                    <img src=\"/assets/img/top/recruit-img02.jpg\">\n                  </div>\n                </div>\n                <div class=\"-imgbox03 js-anime\">\n                  <div class=\"-in js-pararax\">\n                    <img src=\"/assets/img/top/recruit-img03.jpg\">\n                  </div>\n                </div>\n              </div>\n            </div>\n          </div>\n          <p class=\"c-recruit-layout__icon js-anime\">\n            <img src=\"/assets/img/top/recruitsec-icon.png\">\n          </p>\n        </section>\n        <div class=\"c-link-area\">\n          <div class=\"inner c-link-area--inner\">\n            <div class=\"c-link-area__block flex\">\n              <!-- c-link-area__block-item -->\n              <div class=\"c-link-area__block-item\">\n                <a class=\"-link\" href=\"/company/\">\n                  <div class=\"-img -img01\"></div>\n                  <div class=\"-txtbox\">\n                    <h3 class=\"-ttl\"><span class=\"-en\">Company</span>会社概要</h3>\n                  </div>\n                  <div class=\"-arrow\"></div>\n                </a>\n              </div>\n              <!-- c-link-area__block-item -->\n              <div class=\"c-link-area__block-item\">\n                <a class=\"-link\" href=\"/recruit/\">\n                  <div class=\"-img -img02\"></div>\n                  <div class=\"-txtbox\">\n                    <h3 class=\"-ttl\"><span class=\"-en\">Recruit</span>採用情報</h3>\n                  </div>\n                  <div class=\"-arrow\"></div>\n                </a>\n              </div>\n              <!-- c-link-area__block-item -->\n              <div class=\"c-link-area__block-item\">\n                <a class=\"-link\" href=\"/recruit/data/\">\n                  <div class=\"-img -img03\"></div>\n                  <div class=\"-txtbox\">\n                    <h3 class=\"-ttl\"><span class=\"-en\">Date</span>数字で見る</h3>\n                  </div>\n                  <div class=\"-arrow\"></div>\n                </a>\n              </div>\n              <!-- c-link-area__block-item -->\n              <div class=\"c-link-area__block-item\">\n                <a class=\"-link\" href=\"/recruit/interview/\">\n                  <div class=\"-img -img04\"></div>\n                  <div class=\"-txtbox\">\n                    <h3 class=\"-ttl\"><span class=\"-en\">Interview</span>社員インタビュー一覧</h3>\n                  </div>\n                  <div class=\"-arrow\"></div>\n                </a>\n              </div>\n              <!-- c-link-area__block-item -->\n              <div class=\"c-link-area__block-item\">\n                <a class=\"-link\" href=\"/recruit/training/\">\n                  <div class=\"-img -img05\"></div>\n                  <div class=\"-txtbox\">\n                    <h3 class=\"-ttl\"><span class=\"-en\">Training</span>研修制度</h3>\n                  </div>\n                  <div class=\"-arrow\"></div>\n                </a>\n              </div>\n\n            </div>\n          </div>\n        </div>\n        <!-- l-footer -->\n        <footer class=\"l-footer\">\n          <div class=\"l-footer-area\">\n            <div class=\"l-footer-area__pagetop\">\n              <a href=\"#\">\n                <p class=\"l-footer-area__pagetop-txt\">page top</p>\n              </a>\n            </div>\n            <div class=\"l-footer-area__block inner\">\n              <div class=\"l-footer-area__block-top flex is-between\">\n                <div class=\"-left flex\">\n                  <div class=\"-logo\">\n                    <a href=\"/\">\n                      <img src=\"/assets/img/common/f-logo.svg\">\n                    </a>\n                  </div>\n                  <p class=\"-access\">株式会社トヨタレンタリース西四国<br>〒791-8042 松山市南吉田町2750-12</p>\n                </div>\n                <div class=\"-insta\">\n                  <a href=\"https://www.instagram.com/toyota_nishishikoku/\" target=\"_blank\"><img\n                      src=\"/assets/img/common/insta-icon-wh.svg\"></a>\n                </div>\n              </div>\n              <div class=\"l-footer-area__block-list\">\n                <ul class=\"flex\">\n                  <li><a href=\"/csr/\">CSR基本方針</a></li>\n                  <li><a href=\"/pp/\">プライバシーポリシー</a></li>\n                  <li><a href=\"/solicitation/\">勧誘方針</a></li>\n                  <li><a href=\"/antisocial/\">暴力団等反社会的勢力排除宣言</a></li>\n                  <li><a href=\"/company/\">会社概要</a></li>\n                </ul>\n              </div>\n              <div class=\"l-footer-area__block-shop flex\">\n                <p class=\"-ttl\">店舗を探す</p>\n                <ul class=\"flex\">\n                  <li><a href=\"/shop/matsuyama.html\">松山店</a></li>\n                  <li><a href=\"/shop/matsuyama-port.html\">松山観光港店</a></li>\n                  <li><a href=\"/shop/matsuyama-ap.html\">松山空港店</a></li>\n                  <li><a href=\"/shop/imabari.html\">今治店</a></li>\n                  <li><a href=\"/shop/saijo-st.html\">JR伊予西条駅店</a></li>\n                  <li><a href=\"/shop/niihama-st.html\">新居浜駅前店</a></li>\n                  <li><a href=\"/shop/iyomishima-st.html\">JR伊予三島駅店</a></li>\n                  <li><a href=\"/shop/yawatahama-st.html\">JR八幡浜駅店</a></li>\n                  <li><a href=\"/shop/uwajima-st.html\">JR宇和島駅店</a></li>\n                  <li><a href=\"/shop/kochi-st.html\">高知駅前店</a></li>\n                  <li><a href=\"/shop/kochi-ap.html\">高知空港店</a></li>\n                  <li><a href=\"/shop/nakamura.html\">中村店</a></li>\n                </ul>\n              </div>\n              <div class=\"l-footer-area__block-recruit flex\">\n                <p class=\"-ttl\">採用情報</p>\n                <ul class=\"flex\">\n                  <li><a href=\"/recruit/interview/\">社員インタビュー</a></li>\n                  <li><a href=\"/recruit/data/\">数字で見る</a></li>\n                  <li><a href=\"/recruit/training/\">研修制度</a></li>\n                  <li><a href=\"/recruit/faq/\">よくあるご質問</a></li>\n                  <li><a href=\"/recruit/description/\">募集要項</a></li>\n                </ul>\n              </div>\n            </div>\n          </div>\n          <p class=\"l-footer-area__copy\">&copy; 2025, 株式会社トヨタレンタリース西四国</p>\n        </footer>\n      </div>\n    </div>\n    <script src=\"/assets/js/jquery-3.6.0.min.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/simple-parallax-js@5.6.2/dist/simpleParallax.min.js\"></script>\n    <script src=\"/assets/js/common.js\"></script>\n  </div>\n\n</body>\n\n</html>","finalUrl":"http://www.r-ehm.co.jp/recruit/description/","rendered":false,"_cachedAt":"2026-06-23T16:27:20.504Z"}