SD\" href=\"https://www.kk-tosan.co.jp/wp/xmlrpc.php?rsd\" />\n<link rel=\"wlwmanifest\" type=\"application/wlwmanifest+xml\" href=\"https://www.kk-tosan.co.jp/wp/wp-includes/wlwmanifest.xml\" /> \n<link rel=\"canonical\" href=\"https://www.kk-tosan.co.jp/\" />\n<link rel='shortlink' href='https://www.kk-tosan.co.jp/' />\n<link rel=\"alternate\" type=\"application/json+oembed\" href=\"https://www.kk-tosan.co.jp/wp-json/oembed/1.0/embed?url=https%3A%2F%2Fwww.kk-tosan.co.jp%2F\" />\n<link rel=\"alternate\" type=\"text/xml+oembed\" href=\"https://www.kk-tosan.co.jp/wp-json/oembed/1.0/embed?url=https%3A%2F%2Fwww.kk-tosan.co.jp%2F&#038;format=xml\" />\n<!-- customizer CSS -->\n<style>\nhtml {\nfont-size: 62.5%;\n}\n\nbody {\nbackground-color: #fff;\n}\n\na {\n}\n\na:focus,\na:hover {\n}\n\n/* .footCopy {\n} */\n</style>\n\t\t<style type=\"text/css\" id=\"wp-custom-css\">\n\t\t\t/*\nここに独自の CSS を追加することができます。\n\n詳しくは上のヘルプアイコンをクリックしてください。\n*/\n\n.tablestyletype001 {\n}\n.tablestyletype001 th{\nwidth:50%;\n}\n.tablestyletype001 td{\nwidth:50%;\n}\t\t</style>\n\t<link rel=\"alternate\" type=\"application/rss+xml\" title=\"RSS\" href=\"https://www.kk-tosan.co.jp/feed/\" />\r\n<link rel=\"alternate\" type=\"application/atom+xml\" title=\"Atom\" href=\"https://www.kk-tosan.co.jp/feed/atom/\" />\r\n\r\n</head>\r\n\r\n\r\n\r\n\r\n\r\n<body class=\"home page-template page-template-page_front page-template-page_front-php page page-id-6 front\">\r\n<a id=\"top\"></a>\r\n<!-- Facebook JavaScript SDK -->\r\n<div id=\"fb-root\"></div>\r\n<script>(function(d, s, id) {\r\n  var js, fjs = d.getElementsByTagName(s)[0];\r\n  if (d.getElementById(id)) return;\r\n  js = d.createElement(s); js.id = id;\r\n  js.src = \"//connect.facebook.net/ja_JP/sdk.js#xfbml=1&version=v2.9\";\r\n  fjs.parentNode.insertBefore(js, fjs);\r\n}(document, 'script', 'facebook-jssdk'));</script>\r\n<!-- Facebook JavaScript SDK -->\r\n\r\n\r\n<header id=\"top\">\r\n<div class=\"container-fluid headOuterContainer\">\r\n<div class=\"container headContainer\">\r\n\r\n\r\n<div class=\"siteTitleContainer\">\r\n<h1 class=\"siteTitle h1\"><a href=\"https://www.kk-tosan.co.jp/\" rel=\"home\"><img src=\"https://www.kk-tosan.co.jp/wp/wp-content/themes/kktosan/img/common/logo.jpg\" alt=\"株式会社 東酸\" /></a></h1></div><!-- / .siteTitleContainer -->\r\n\r\n\r\n<div class=\"globalNaviContainer\">\r\n\r\n\r\n<div class=\"headerButton\">\r\n<ul class=\"headerButtonList\">\r\n<li><a \r\n\thref=\"tel:0177362125\"><img src=\"https://www.kk-tosan.co.jp/wp/wp-content/themes/kktosan/img/common/headbanner1_tel.gif\" alt=\"電話でのお問い合わせは 017-736-2125（代表）\" /></a></li><li><a \r\n\thref=\"/kk-tosan/contact\"><img src=\"https://www.kk-tosan.co.jp/wp/wp-content/themes/kktosan/img/common/headbanner1_mail.gif\" alt=\"メールでお問い合わせ\" /></a></li>\r\n</ul><!-- / .headerButtonList -->\r\n</div><!-- / .headerButton -->\r\n\r\n\r\n<div id=\"openNavi\" class=\"openNavi\"><a><span><img src=\"https://www.kk-tosan.co.jp/wp/wp-content/themes/kktosan/img/common/menuopen_icon.png\" alt=\"MENU\" /></span></a></div>\r\n<div id=\"globalNavi\" class=\"globalNavi clearfix\">\r\n<ul id=\"globalMainNavi\" class=\"globalMainNavi\"><li class=\"current-menu-item current_page_item\"><a href=\"https://www.kk-tosan.co.jp/\">HOME</a></li><!-- \n --><li><a href=\"https://www.kk-tosan.co.jp/company/\">会社案内</a></li><!-- \n --><li><a href=\"https://www.kk-tosan.co.jp/catalog/\">取扱品目</a></li><!-- \n --><li><a href=\"https://www.kk-tosan.co.jp/office/\">営業所案内</a></li><!-- \n --><li><a href=\"https://www.kk-tosan.co.jp/news/\">新着情報</a></li><!-- \n --></ul>\r\n</div><!-- / #globalNavi .globalNavi .clearfix -->\r\n\r\n\r\n</div><!-- / .globalNaviContainer -->\r\n\r\n\r\n<div class=\"frontSlider1Container\">\n<ul id=\"frontSlider1\" class=\"frontSlider1\">\n<!-- slider0 -->\n<li id=\"frontSlider1item0\" data-logo=\"logo1\">\n<div class=\"sliderInner\">\n<div class=\"slide-title1\">一般高圧ガス</div>\n<div class=\"slide-title2\">株式会社東酸では酸素ガス、窒素ガス、炭酸ガス、アルゴン等々、地域産業を支える一般高圧ガスを取り扱っております。</div>\n</div><!-- / .sliderInner -->\n<div class=\"slide-bg\" style=\"background-image:url(https://www.kk-tosan.co.jp/wp/wp-content/uploads/2017/06/slider_gus-1200x630.jpg);\"></div>\n</li>\n<!-- slider1 -->\n<li id=\"frontSlider1item1\" data-logo=\"logo1\">\n<div class=\"sliderInner\">\n<div class=\"slide-title1\">LP ガス・灯油</div>\n<div class=\"slide-title2\">一般のお客様向けにＬＰガス、灯油の供給、機器・設備販売など、幅広いサービスを提供しております。</div>\n</div><!-- / .sliderInner -->\n<div class=\"slide-bg\" style=\"background-image:url(https://www.kk-tosan.co.jp/wp/wp-content/uploads/2017/06/slider_lpg-1200x630.jpg);\"></div>\n</li>\n<!-- slider2 -->\n<li id=\"frontSlider1item2\" data-logo=\"logo1\">\n<div class=\"sliderInner\">\n<div class=\"slide-title1\">化学薬品</div>\n<div class=\"slide-title2\">株式会社東酸では企業様向けに、減菌剤、凝集剤、中和剤、防錆剤、洗浄剤、スケール除去剤、また、防塵・融雪、ボイラー関連水処理を目的とした薬品を提供しております。</div>\n</div><!-- / .sliderInner -->\n<div class=\"slide-bg\" style=\"background-image:url(https://www.kk-tosan.co.jp/wp/wp-content/uploads/2017/06/slider_yakuhin-1200x630.jpg);\"></div>\n</li>\n<!-- slider3 -->\n<li id=\"frontSlider1item3\" data-logo=\"logo1\">\n<div class=\"sliderInner\">\n<div class=\"slide-title1\">産業機械</div>\n<div class=\"slide-title2\">溶接機、電動工具、作業工具、油圧・空圧機器、工作機械、建設荷役器具、安全保護器具。ガスに関わる機器を提供しております。</div>\n</div><!-- / .sliderInner -->\n<div class=\"slide-bg\" style=\"background-image:url(https://www.kk-tosan.co.jp/wp/wp-content/uploads/2017/06/slider_robo-1200x630.jpg);\"></div>\n</li>\n<!-- slider4 -->\n<li id=\"frontSlider1item4\" data-logo=\"logo1\">\n<div class=\"sliderInner\">\n<div class=\"slide-title1\">配管設備・技術サービス</div>\n<div class=\"slide-title2\">病院・工場・試験室・ホテル・ビル等のガス配管供給装置～容器再検査、高圧ガス設備保安検査、高圧ガスプラントの設計施工、コンサルティングをとりおこなっております。</div>\n</div><!-- / .sliderInner -->\n<div class=\"slide-bg\" style=\"background-image:url(https://www.kk-tosan.co.jp/wp/wp-content/uploads/2017/06/slider_system-1024x630.jpg);\"></div>\n</li>\n</ul><!-- / #frontSlider1 .frontSlider1 -->\n\n<ul id=\"frontSlider1pager\" class=\"frontSlider1pager bx-pager-custom\">\n<li class=\"bx-pager-item\"><a href=\"\" data-slide-index=\"0\" class=\"bx-pager-link\">1</a></li>\n<li class=\"bx-pager-item\"><a href=\"\" data-slide-index=\"1\" class=\"bx-pager-link\">2</a></li>\n<li class=\"bx-pager-item\"><a href=\"\" data-slide-index=\"2\" class=\"bx-pager-link\">3</a></li>\n<li class=\"bx-pager-item\"><a href=\"\" data-slide-index=\"3\" class=\"bx-pager-link\">4</a></li>\n<li class=\"bx-pager-item\"><a href=\"\" data-slide-index=\"4\" class=\"bx-pager-link\">5</a></li>\n</ul><!-- / #frontSlider1pager .bx-pager-custom -->\n\n</div><!-- / .frontSlider1Container -->\n\r\n\r\n</div><!-- / .container .headContainer -->\r\n\r\n\r\n</div><!-- / .container-fluid .headOuterContainer -->\r\n</header><!-- / -->\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n<div class=\"container\">\r\n\r\n\r\n<div class=\"row row-sm84pad80\">\r\n\n\n<div class=\"col-sm-12 mainColumn\">\n<div class=\"mainArticleCol1\">\n\n\n\n\n<div class=\"row row-sm84pad80 frontColumn frontNews\">\n\n<div class=\"col-sm-8\">\n<div class=\"frontNewsColumn\">\n\n<div class=\"frontNewsHead\">\n<h2>お知らせ・新着情報</h2>\n<p class=\"frontNewsHeadButton fs12\"><a href=\"https://www.kk-tosan.co.jp/news\">一覧へ</a></p>\n</div><!-- / .frontNewsHead -->\n\n\n<ul class=\"frontNewsList clearfix\">\n<!-- news 1 -->\n<li class=\"entryItem\">\n<article id=\"post-768\" class=\"row post-768 post type-post status-publish format-standard has-post-thumbnail hentry category-info\">\n\n<div class=\"col-xs-3 col-sm-3 col-md-2\">\n<div class=\"entryEyecatch\"><a href=\"https://www.kk-tosan.co.jp/2026/03/22/%ef%bc%92%ef%bc%90%ef%bc%92%ef%bc%96%e5%b9%b4%e5%ba%a6%e3%80%80%e5%96%b6%e6%a5%ad%e3%82%ab%e3%83%ac%e3%83%b3%e3%83%80%e3%83%bc/\">\n<figure style=\"background-image:url(https://www.kk-tosan.co.jp/wp/wp-content/uploads/2020/04/yjimage.jpg);\"></figure>\n</a></div><!-- / .entryEyecatch -->\n</div><!-- / .col-xs-3 .col-sm-3 .col-md-2 -->\n\n<div class=\"col-xs-9 col-