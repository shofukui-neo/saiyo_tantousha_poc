16\"> <a href=\"mailto:nishii@hiroshima-nishii.co.jp\"> <img\n              src=\"img/common/mail-icon-side.png\" alt=\"お問合せ\">　お問い合わせ</a> </div>\n        <!-- <div class=\"pagetop\">\n              <a href=\"#\"><img src=\"img/common/pagetop.png\" alt=\"PAGETOP\"></a>\n            </div> -->\n      </div>\n    </header>\n    <div class=\"top_slide\">\n      <!-- Slider main container -->\n      <div class=\"swiper-container container_m\">\n        <!-- Additional required wrapper -->\n        <div class=\"swiper-wrapper\">\n          <!-- Slides -->\n          <div class=\"swiper-slide\">\n            <picture>\n              <!-- <source media=\"(min-width: 700px)\" type=\"image/jpeg\" srcset=\"img/top/main_1.jpg\">\n            <source media=\"(min-width: 511px)\" type=\"image/jpeg\" srcset=\"img/top/main_1@2×.jpg\"> -->\n              <source media=\"(min-width: 511px)\" type=\"image/jpeg\" srcset=\"img/top/main_1.jpg\">\n              <img src=\"img/top/main_1_1@2×.jpg\" alt=\"スライダー\">\n            </picture>\n          </div>\n          <div class=\"swiper-slide\">\n            <picture>\n              <source media=\"(min-width: 511px)\" type=\"image/jpeg\" srcset=\"img/top/main_2.jpg\">\n              <img src=\"img/top/main_2_2@2×.jpg\" alt=\"スライダー\">\n            </picture>\n          </div>\n          <div class=\"swiper-slide\">\n            <picture>\n              <source media=\"(min-width: 511px)\" type=\"image/jpeg\" srcset=\"img/top/main_3.jpg\">\n              <img src=\"img/top/main_3_3@2×.jpg\" alt=\"スライダー\">\n            </picture>\n          </div>\n          <div class=\"swiper-slide if\">\n            <picture>\n              <source media=\"(min-width: 511px)\" type=\"image/jpeg\" srcset=\"img/top/main_4.jpg\">\n              <img src=\"img/top/main_4_4@2×.jpg\" alt=\"スライダー\">\n          </div>\n          </picture>\n        </div>\n        <!-- swiper-wrapper -->\n        <!-- ページネーション -->\n        <div class=\"swiper-pagination\"></div>\n      </div>\n      <!-- swiper-container -->\n      <p class=\"feauter copy container_m\">\n        西井製作所は100年以上の<br class=\"sp\">歴史のある企業です</p>\n\n      <ul class=\"certified_company_box\">\n        <li><a href=\"certification/#youthyell\"><img src=\"img/top/01_youthyell.jpg\"><span\n              class=\"name\">ユースエール<br>認定企業</span></a></li>\n        <li><a href=\"certification/#hiroshimawork\"><img src=\"img/top/02_hiroshimawork.jpg\"><span\n              class=\"name\">広島県働き方改革<br>実践企業 認定</span></a></li>\n        <li><a href=\"certification/#team-gantaisaku\"><img src=\"img/top/03_team-gantaisaku.jpg\"><span class=\"name\">Team\n              がん対策<br>ひろしま 企業登録</span></a></li>\n        <li><a href=\"certification/#kenkou\"><img src=\"img/top/04_kenkou.jpg\"><span class=\"name\">ひろしま企業<br>健康宣言\n              認定</span></a></li>\n      </ul>\n\n      <div class=\"number_box\">\n        <ul class=\"number_flex_list\">\n          <li>\n            <p><span class=\"band\">平均残業時間</span>7<span class=\"sub_txt\">時間/月</span></p><img class=\"icon\"\n              src=\"img/top/number_icon01.png\">\n          </li>\n          <li>\n            <p><span class=\"band\">有給休暇の平均取得日数</span>19<span class=\"sub_txt\">日/年</span></p><img class=\"icon\"\n              src=\"img/top/number_icon02.png\">\n          </li>\n          <li class=\"item_l\">\n            <p><span class=\"band\">働きやすい環境づくり</span><span class=\"num_txt\">通常の有給休暇に加えて、<br><span\n                  class=\"strong_txt\">自己成長有給休暇</span>を取得可能</span><span class=\"middle_txt\">最大</span>12<span\n                class=\"sub_txt\">日/年</span></p><img class=\"icon\" src=\"img/top/number_icon03.png\">\n          </li>\n        </ul>\n      </div>\n\n    </div>\n    <!-- top_slide -->\n\n\n\n\n\n  </div>\n  <!-- content_box -->\n\n  </div>\n  <!-- header_area -->\n\n  <div class=\"nx-independent-slider-section\">\n    <div class=\"swiper-container nx-independent-swiper container_m\">\n      <div class=\"swiper-wrapper\">\n        <div class=\"swiper-slide\">\n          <img src=\"img/top/slide01.jpg\" alt=\"スライド01\" width=\"800\" height=\"600\" decoding=\"async\">\n        </div>\n        <div class=\"swiper-slide\">\n          <img src=\"img/top/slide02.jpg\" alt=\"スライド02\" width=\"800\" height=\"600\" decoding=\"async\">\n        </div>\n        <div class=\"swiper-slide\">\n          <img src=\"img/top/slide03.jpg\" alt=\"スライド03\" width=\"800\" height=\"600\" decoding=\"async\">\n        </div>\n        <div class=\"swiper-slide\">\n          <img src=\"img/top/slide04.jpg\" alt=\"スライド04\" width=\"800\" height=\"600\" decoding=\"async\">\n        </div>\n        <div class=\"swiper-slide\">\n          <img src=\"img/top/slide05.jpg\" alt=\"スライド05\" width=\"800\" height=\"600\" decoding=\"async\">\n        </div>\n      </div>\n      <!-- ページネーション -->\n      <div class=\"swiper-pagination\"></div>\n    </div>\n  </div>\n  <main class=\"main\">\n    <section class=\"top01 top_wide_wrap\">\n      <div class=\"cont_area\">\n        <h2>西井のこだわり<span class=\"arial\">人づくり・環境づくりのための取り組み</span></h2>\n        <ul class=\"point_list_box\">\n          <li><img src=\"img/top/point_list01.jpg\">\n            <p class=\"title\"><span class=\"ini_txt\">1.</span>朝礼</p>\n            <p class=\"n_txt\">社員同士の人生に対する考え方や理想の会社像を共有することを目的に、毎朝30分間実施しています。</p>\n          </li>\n          <li><img src=\"img/top/point_list02.jpg\">\n            <p class=\"title\"><span class=\"ini_txt\">2.</span>朝の掃除</p>\n            <p class=\"n_txt\">毎朝20 分、社内や工場近隣の清掃を行います。綺麗で安全な会社・地域づくりのため、掃除手順や掃除方法を社員自らが考え実践しています。</p>\n          </li>\n          <li><img src=\"img/top/point_list03.jpg\">\n            <p class=\"title\"><span class=\"ini_txt\">3.</span>社内技能大会</p>\n            <p class=\"n_txt\">年2 回、作業についての実技テストや学科テストを行ない、その後上司や先輩社員からフィードバックを行ないます。技術力の向上や作業の課題解決を目的としています。</p>\n          </li>\n          <li><img src=\"img/top/point_list04.jpg\">\n            <p class=\"title\"><span class=\"ini_txt\">4.</span>家族会</p>\n            <p class=\"n_txt\">社員の家族の方も含めて幸せであることが、良い会社を作る上で大切なことだと考えており、家族の方をお招きして社員と一緒に楽しめるイベントを企画しています。</p>\n          </li>\n          <li><img src=\"img/top/point_list05.jpg\">\n            <p class=\"title\"><span class=\"ini_txt\">5.</span>部門別アセスメント</p>\n            <p class=\"n_txt\">当社では各部署がより良い会社づくりのための取組みを考え、実行しています。その取組み内容や成果を2\n              ヶ月に一度役員へ説明します。説明することで自らの活動を振り返り、より成果を高める取組みを実行することができます。</p>\n          </li>\n          <li class=\"hidden_item\"></li>\n        </ul>\n\n      </div>\n    </section>\n    <section class=\"top02 new_box cm_box\">\n      <h2>CMギャラリー<br>\n        <span class=\"ft-14\">CM GALLERY</span>\n      </h2>\n      <div class=\"flex\">\n\n        <div class=\"video_item\">\n          <button class=\"js-modal-btn\" data-video-url=\"img/top/recruit_cm2025_03.mp4\"><img\n              src=\"img/top/recruit_cm2025_01.jpg\"></button>\n          <span class=\"cm_time\">15秒</span><span class=\"cm_title\">「いつだって夢中」篇</span>\n        </div>\n        <div class=\"video_item\">\n          <button class=\"js-modal-btn\" data-video-url=\"img/top/recruit_cm2025_01.mp4\"><img\n              src=\"img/top/recruit_cm2025_02.jpg\"></button>\n          <span class=\"cm_time\">45秒</span><span class=\"cm_title\">「いつだって夢中」女性篇</span>\n        </div>\n        <div class=\"video_item\">\n          <button class=\"js-modal-btn\" data-video-url=\"img/top/recruit_cm2025_02.mp4\"><img\n              src=\"img/top/recruit_cm2025_03.jpg\"></button>\n          <span class=\"cm_time\">45秒</span><span class=\"cm_title\">「いつだって夢中」男性篇</span>\n        </div>\n    </section>\n\n    <section class=\"top03 new_box\">\n      <h2>採用情報<br>\n        <span class=\"ft-14\">RECRUIT</span>\n      </h2>\n      <div class=\"box\">\n        <div class=\"flexbox\">\n          <p class=\"top_btn\"><a href=\"recruit/index.html\">仕事紹介</a></p>\n          <p class=\"top_btn\"><a href=\"recruit/index.html\">募集要項</a></p>\n        </div>\n      </div>\n    </section>\n\n\n    <section class=\"