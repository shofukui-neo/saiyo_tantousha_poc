mv__box fade-bottom\">\n        <div class=\"page-mv__content\">\n          <h1 class=\"page-mv__title\">\n            <span class=\"page-mv__title--en\">Form</span>\n            <span class=\"page-mv__title--jp\">応募フォーム</span>\n          </h1>\n        </div>\n        <div class=\"page-mv__img\">\n          <picture>\n            <source  type=\"image/webp\" data-srcset=\"https://hokudo-kaihatsu.co.jp/recruit/wp-content/themes/hokudo-kaihatsu-recruit/assets/img/form/mv-img.webp\">\n            <img src=\"data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAABEwAAALcAQAAAADVzBhuAAAAAnRSTlMAAHaTzTgAAAB5SURBVHja7cExAQAAAMKg9U9tCj+gAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAADga42DAAETLtg9AAAAAElFTkSuQmCC\" alt=\"\" decoding=\"async\"\n              loading=\"eager\" width=\"550\" height=\"366\" data-src=\"https://hokudo-kaihatsu.co.jp/recruit/wp-content/themes/hokudo-kaihatsu-recruit/assets/img/form/mv-img.jpg\" class=\"lazyload\" data-eio-rwidth=\"1100\" data-eio-rheight=\"732\">\n          </picture><noscript><img src=\"https://hokudo-kaihatsu.co.jp/recruit/wp-content/themes/hokudo-kaihatsu-recruit/assets/img/form/mv-img.jpg\" alt=\"\" decoding=\"async\"\n              loading=\"eager\" width=\"550\" height=\"366\" data-eio=\"l\"></noscript>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"form__wrapper\">\n      <div class=\"inner\">\n        <div class=\"work-style__tab-list\">\n          <p class=\"work-style__tab-item active\">応募フォーム</p>\n          <a href=\"https://hokudo-kaihatsu.co.jp/recruit/form-visit\" class=\"work-style__tab-item\">見学フォーム</a>\n        </div>\n\n        <div class=\"contact__content\">\n          \n<div class=\"wpcf7 no-js\" id=\"wpcf7-f23-o1\" lang=\"en-US\" dir=\"ltr\" data-wpcf7-id=\"23\">\n<div class=\"screen-reader-response\"><p role=\"status\" aria-live=\"polite\" aria-atomic=\"true\"></p> <ul></ul></div>\n<form action=\"/recruit/form/#wpcf7-f23-o1\" method=\"post\" class=\"wpcf7-form init\" aria-label=\"Contact form\" novalidate=\"novalidate\" data-status=\"init\">\n<fieldset class=\"hidden-fields-container\"><input type=\"hidden\" name=\"_wpcf7\" value=\"23\" /><input type=\"hidden\" name=\"_wpcf7_version\" value=\"6.1.5\" /><input type=\"hidden\" name=\"_wpcf7_locale\" value=\"en_US\" /><input type=\"hidden\" name=\"_wpcf7_unit_tag\" value=\"wpcf7-f23-o1\" /><input type=\"hidden\" name=\"_wpcf7_container_post\" value=\"0\" /><input type=\"hidden\" name=\"_wpcf7_posted_data_hash\" value=\"\" /><input type=\"hidden\" name=\"_wpcf7_recaptcha_response\" value=\"\" />\n</fieldset>\n<div id=\"form__area\" class=\"form__area\">\n  <div class=\"contact__item\">\n    <p class=\"contact__label contact__label--required\">名前</p>\n    <div class=\"contact__input\">\n      <label for=\"contact-name\"><span class=\"wpcf7-form-control-wrap\" data-name=\"contact-name\"><input size=\"40\" maxlength=\"400\" class=\"wpcf7-form-control wpcf7-text wpcf7-validates-as-required\" id=\"contact-name\" aria-required=\"true\" aria-invalid=\"false\" placeholder=\"山田　太郎\" value=\"\" type=\"text\" name=\"contact-name\" /></span></label>\n    </div>\n  </div>\n  <div class=\"contact__item\">\n    <p class=\"contact__label contact__label--required\">フリガナ</p>\n    <div class=\"contact__input\">\n      <label for=\"contact-kana\"><span class=\"wpcf7-form-control-wrap\" data-name=\"contact-kana\"><input size=\"40\" maxlength=\"400\" class=\"wpcf7-form-control wpcf7-text wpcf7-validates-as-required\" id=\"contact-kana\" aria-required=\"true\" aria-invalid=\"false\" placeholder=\"ヤマダ　タロウ\" value=\"\" type=\"text\" name=\"contact-kana\" /></span></label>\n    </div>\n  </div>\n  <div class=\"contact__item\">\n    <p class=\"contact__label contact__label--required\">メールアドレス</p>\n    <div class=\"contact__input\">\n      <label for=\"contact-email\"><span class=\"wpcf7-form-control-wrap\" data-name=\"contact-email\"><input size=\"40\" maxlength=\"400\" class=\"wpcf7-form-control wpcf7-email wpcf7-validates-as-required wpcf7-text wpcf7-validates-as-email\" id=\"contact-email\" aria-required=\"true\" aria-invalid=\"false\" placeholder=\"info@abc.com\" value=\"\" type=\"email\" name=\"contact-email\" /></span></label>\n    </div>\n  </div>\n  \n  <div class=\"contact__item\">\n    <p class=\"contact__label contact__label--required\">電話番号</p>\n    <div class=\"contact__input\">\n      <label for=\"contact-tel\"><span class=\"wpcf7-form-control-wrap\" data-name=\"contact-tel\"><input size=\"40\" maxlength=\"400\" class=\"wpcf7-form-control wpcf7-tel wpcf7-validates-as-required wpcf7-text wpcf7-validates-as-tel\" id=\"contact-tel\" aria-required=\"true\" aria-invalid=\"false\" placeholder=\"000-0000-0000\" value=\"\" type=\"tel\" name=\"contact-tel\" /></span></label>\n    </div>\n  </div>\n  \n <div class=\"contact__item\">\n    <p class=\"contact__label contact__label--required\">応募職種</p>\n    <div class=\"contact__select\">\n      <label for=\"contact-select\"><span class=\"wpcf7-form-control-wrap\" data-name=\"contact-select\"><select class=\"wpcf7-form-control wpcf7-select wpcf7-validates-as-required\" aria-required=\"true\" aria-invalid=\"false\" name=\"contact-select\"><option value=\"【中途】技術職員（土木・建築）本社\">【中途】技術職員（土木・建築）本社</option><option value=\"【中途】技術職員（土木・建築）札幌支店\">【中途】技術職員（土木・建築）札幌支店</option><option value=\"【新卒】技術職員（土木・建築）本社\">【新卒】技術職員（土木・建築）本社</option><option value=\"【新卒】技術職員（土木・建築）札幌支店\">【新卒】技術職員（土木・建築）札幌支店</option></select></span></label>\n    </div>\n  </div>\n  \n  <div class=\"contact__item\">\n    <p class=\"contact__label contact__label--required\">性別</p>\n    <div class=\"contact__input contact__radio\"><span class=\"wpcf7-form-control-wrap\" data-name=\"contact-radio\"><span class=\"wpcf7-form-control wpcf7-radio\"><span class=\"wpcf7-list-item first\"><label><input type=\"radio\" name=\"contact-radio\" value=\"男性\" /><span class=\"wpcf7-list-item-label\">男性</span></label></span><span class=\"wpcf7-list-item last\"><label><input type=\"radio\" name=\"contact-radio\" value=\"女性\" /><span class=\"wpcf7-list-item-label\">女性</span></label></span></span></span></div>\n  </div>\n  <div class=\"contact__item contact__item--textarea\">\n    <p class=\"contact__label contact__label--required contact__label--multiple\">PR/その他</p>\n    <div class=\"contact__input\">\n      <label for=\"contact-contents\"><span class=\"wpcf7-form-control-wrap\" data-name=\"contact-contents\"><textarea cols=\"40\" rows=\"10\" maxlength=\"2000\" class=\"wpcf7-form-control wpcf7-textarea\" id=\"contact-contents\" aria-invalid=\"false\" placeholder=\"\" name=\"contact-contents\"></textarea></span></label>\n    </div>\n  </div>\n <div class=\"policy\">\n    <div class=\"policy__inner\" data-simplebar>\n      <h2 class=\"policy__title\">プライバシーポリシー</h2>\n      <div class=\"policy__content\">\n        <ol class=\"policy__list\">\n          <li class=\"policy__item\">\n            <p class=\"policy__text\">個人情報の管理当社は、お客様の個人情報について、管理責任者を任命するとともに、当社の個人情報保護に関する規定に従って適切に管理します</p>\n          </li>\n          <li class=\"policy__item\">\n            <p class=\"policy__text\">利用目的と収集範囲当社は、お客様からお名前・ご住所・電話番号・Ｅメールアドレスなどの個人情報をご提供いただく場合は、あらかじめ利用目的やお問い合わせの窓口などをお知らせし、適切な範囲内でお客様の個人情報を収集させていただきます</p>\n          </li>\n        </ol>\n      </div>\n    </div>\n  </div>\n <div class=\"contact__privacy-check\">\n    <label for=\"privacy-agree\"><span class=\"wpcf7-form-control-wrap\" data-name=\"privacy-agree\"><span class=\"wpcf7-form-control wpcf7-checkbox wpcf7-validates-as-required\"><span class=\"wpcf7-list-item first last\"><label><input type=\"checkbox\" name=\"privacy-agree[]\" value=\"プライバシーポリシーに同意する\" /><span class=\"wpcf7-list-item-label\">プライバシーポリシーに同意する</span></label></span></span></span></label>\n  </div>\n  <div class=\"contact__btn\">\n    <input class=\"wpcf7-form-control wpcf7-submit has-spinner btn\" type=\"submit\" value=\"送信する\" />\n  </div>\n</div><div class=\"wpcf7-response-output\" ar