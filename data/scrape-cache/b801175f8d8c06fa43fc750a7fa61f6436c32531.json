 -->\n</div>\n<!-- /menu -->\n\t\n<nav class=\"floating_contact\">\n<ul class=\"flex\">\n<li><a href=\"../../recruit/index.html#entry\">採用エントリー</a></li>\n<li><a href=\"../../recruit/index.html#requirements\">募集要項</a></li>\n</ul>\n</nav>\n<!-- /floating_contact -->\n\n<div class=\"global_nav_sp\">\n<div class=\"menu\">\n<a href=\"../../index.html\" class=\"logo_sp\"><img src=\"../../images/logo.svg\" alt=\"原子力エンジニアリング株式会社\"></a>\n<div class=\"toggle\">\n<div class=\"bar top\"></div>\n<div class=\"bar middle\"></div>\n<div class=\"bar bottom\"></div>\n</div>\n<!-- /toggle -->\n<nav class=\"menu_sp\">\n<ul>\n<li><a href=\"../../about/index.html\">NECOについて</a></li>\n<li><a href=\"../../works/index.html\">私たちの仕事</a></li>\n<li><a href=\"../../people/index.html\">NECOの仲間</a></li>\n<li><a href=\"../../career_formation/index.html\">キャリア形成</a></li>\n<li><a href=\"../../benefit/index.html\">環境と制度</a></li>\n<li><a href=\"../../recruit/index.html\">採用情報</a></li>\n<li class=\"contact\"><a href=\"../../contact/index.html\">お問い合わせ</a></li>\n</ul>\n</nav>\n</div>\n<!-- /menu -->\n</div>\n<!-- /global_nav_sp -->\n</header>\n\n\n<div class=\"mainvisual\">\n<div class=\"inner\">\n<ul>\n    <li>\n        <picture>\n        <img src=\"../../images/entry_title/bg_title_recruit.jpg\" alt=\"\" width=\"1680\" height=\"750\">\n        </picture>\n    </li>\n</ul>\n</div>\n<!-- /inner -->\n<div class=\"wrap\">\n    <h1><a href=\"../index.html\"><span>採用情報</span>RECRUIT</a></h1>\n    <img src=\"../../images/entry_title/deco/recruit.png\" alt=\"\" width=\"260\" height=\"186\">\n</div>\n<nav class=\"bread clearfix\">\n<ol>\n  <li><a href=\"../../index.html\">HOME</a></li>\n\t<li><a href=\"../index.html\">採用情報</a></li>\n\t<li>募集要項（キャリア採用）</li>\n</ol>\n</nav>\n<!-- /bread -->\n</div>\n<!-- /mainvisual -->\n\n\n<main>\t\n<div id=\"contents\">\n<section class=\"adjust_group\">\n<div class=\"inner\">\n<h2>募集要項（キャリア採用）</h2>\n<p class=\"mb_row\">原子力エンジニアリング株式会社のキャリア採用情報です。現在、以下の職種で募集を行っています。ご希望の方はエントリーフォームよりお申込みください。</p>\n<div itemscope itemtype = \"http://schema.org/JobPosting\" >\n<meta itemprop = \"specialCommitments\" content = \"VeteranCommit\" />\n<h3><span itemprop = \"title\">技術職｜施工・電気・機械設備工事等における管理業務 運転・保守業務 分析業務 放射線管理業務</span></h3>\n<p class=\"txtR\"><span itemprop = \"datePosted\" >2025-8-18</span></p>\n<table class=\"mb_normal\">\n<thead>\n    <tr>\n    \t<th colspan=\"2\" scope=\"col\">募集要項</th>\n    </tr>\n</thead>\n<tbody>\n    <tr>\n    \t<th scope=\"row\">仕事の概要</th>\n    \t<td>原子力施設内における施工・電気・機械設備工事等における管理業務、運転・保守業務、分析業務、放射線管理業務</td>\n    </tr>\n    <tr>\n    \t<th scope=\"row\">募集対象</th>\n    \t<td>\n    \t<span itemprop = \"description\" >・高校卒以上<br>\n    \t     【尚可】<br>\n    \t     ・建築・土木等の施工管理業務経験者(施工管理業務)<br>\n    \t     ・2級建築士、1級土木施工管理技士、1級建築施工管理技士いずれかの資格をお持ちの方<br>\n    \t     ・電気工事の施工管理経験、電気工事に関する知識及び経験、CADを利用した製図・設計経験<br>\n    \t\t ・2級電気工事施工管理技士、第二種電気工事士、第三種電気主任技術者のいずれかをお持ちの方<br>\n    \t\t ・Word、Excelによる文書/書類作成<br>\n    \t\t ・機械系・電気系の経験<br>\n    \t </span>\n    \t</td>\n    </tr>\n    <tr>\n    \t<th scope=\"row\">募集人数</th>\n    \t<td>若干名</td>\n    </tr>\n    <tr>\n    \t<th scope=\"row\">雇用形態</th>\n    \t<td>正社員（6ヶ月間の試用期間あり）</td>\n    </tr>\n</tbody>\n</table>\n\t\n<table class=\"mb_normal\">\n<thead>\n    <tr>\n    \t<th colspan=\"2\" scope=\"col\">勤務条件・待遇</th>\n    \t</tr>\n\t</thead>\n\t\t  <tbody>\n    <tr>\n    \t<th scope=\"row\">給与（初任給）</th>\n    \t<td>月給180,000円～300,000円 ※施工管理業務は350,000円～<br>\n    \t※給与は学歴・職歴（経験）・所持資格等を考慮し、決定されます。\n    \t</td>\n    </tr>\n    <tr>\n    \t<th scope=\"row\">諸手当</th>\n    \t<td>家族手当、住宅手当、通勤手当、技術手当等</td>\n    </tr>\n    <tr>\n    \t<th scope=\"row\">賞与</th>\n    \t<td>年2回</td>\n    </tr>\n    <tr>\n    \t<th scope=\"row\">勤務地</th>\n    \t<td>\n    \t<span itemprop = \"jobLocation\" itemscope itemtype = \"http://schema.org/Place\" > <span itemprop = \"address\" itemscope itemtype = \"http://schema.org/PostalAddress \" >\n    \t<span itemprop=\"addressRegion\"><span itemprop=\"addressLocality\">茨城県（東海村・那珂市・大洗町）、福島県（浜通り）、青森県（六ヶ所、むつ市）<span itemprop=\"addressCountry\">JP</span></span></span></td>\n    </tr>\n    <tr>\n    \t<th scope=\"row\">勤務時間</th>\n    \t<td>9時00分～17時30分（休憩1時間）<br>交替勤務あり</td>\n    </tr>\n    <tr>\n    \t<th scope=\"row\">休日・休暇等</th>\n    \t<td>週休2日制（土・日、ただし、会社が指定する1回／年の土曜日は除く）、祝日、夏期休暇、年末年始休暇</td>\n    </tr>\n\t<tr>\n    \t<th scope=\"row\">加入保険制度</th>\n    \t<td>健康保険、厚生年金、雇用保険、労災保険</td>\n    </tr>\n    <tr>\n    \t<th scope=\"row\">その他</th>\n    \t<td>社員寮完備（福島県双葉郡富岡町）賄付、福利厚生倶楽部、資格取得支援制度有</td>\n    </tr>\n</tbody>\n</table>\n\n<!--\n<div class=\"btn_area mb_high\">\n<ul>\n<li><a href=\"https://forms.gle/7sPWYET6j62tBbH57\" target=\"_blank\">エントリーフォームから応募する</a></li>\n</ul>\n</div>\n-->\n\t\n<div class=\"btn_area mb_high\">\n<ul>\n<li><a href=\"https://forms.gle/7sPWYET6j62tBbH57\" target=\"_blank\">エントリーフォームから応募する</a></li>\n</ul>\n</div>\n\n<h3>技術員（限定社員）</h3>\n<p class=\"txtR\">更新日：2021年4月1日</p>\n<table class=\"mb_normal\">\n<thead>\n    <tr>\n    \t<th colspan=\"2\" scope=\"col\">募集要項</th>\n    </tr>\n</thead>\n<tbody>\n    <tr>\n    \t<th scope=\"row\">仕事の概要</th>\n    \t<td>原子力施設内における電気・機械設備の運転及び保守業務</td>\n    </tr>\n    <tr>\n    \t<th scope=\"row\">募集対象</th>\n    \t<td>60歳～69歳<br>\n\t\t1級施工監理技士（建設、電気工事、管工事）、2級施工監理技士（建設、電気工事、管工事）、1級建築士、2級建築士、第2種電気主任技術者、第3種電気主任技術者、1級ボイラー技士、応用情報処理技術者、基本情報処理技術者・ITパスポートのいずれかをお持ちの方<br>\n\t\t2年以上の資格経験尚可</td>\n    </tr>\n    <tr>\n    \t<th scope=\"row\">募集人数</th>\n    \t<td>若干名</td>\n    </tr>\n    <tr>\n    \t<th scope=\"row\">雇用形態</th>\n    \t<td>正社員（6ヶ月間の試用期間あり）</td>\n    </tr>\n</tbody>\n</table>\n\n<table class=\"mb_normal\">\n<thead>\n    <tr>\n    \t<th colspan=\"2\" scope=\"col\">勤務条件・待遇</th>\n    \t</tr>\n</thead>\n<tbody>\n    <tr>\n    \t<th scope=\"row\">給与（初任給）</th>\n    \t<td>175,000円～</td>\n    </tr>\n    <tr>\n    \t<th scope=\"row\">諸手当</th>\n    \t<td>家族手当、住宅手当、通勤手当、技術手当等</td>\n    </tr>\n    <tr>\n    \t<th scope=\"row\">賞与</th>\n    \t<td>年2回</td>\n    </tr>\n    <tr>\n    \t<th scope=\"row\">勤務地</th>\n    \t<td>茨城県（東海村・那珂市・大洗町）、福島県（浜通り）</td>\n    </tr>\n    <tr>\n    \t<th scope=\"row\">勤務時間</th>\n    \t<td>9時00分～17時30分（休憩1時間）<br>交替勤務あり</td>\n    </tr>\n    <tr>\n    \t<th scope=\"row\">休日・休暇等</th>\n    \t<td>週休2日制（土・日、ただし、会社が指定する1回／年の土曜日は除く）、祝日、夏期休暇、年末年始休暇</td>\n    </tr>\n\t<tr>\n    \t<th scope=\"row\">加入保険制度</th>\n    \t<td>健康保険、厚生年金、雇用保険、労災保険</td>\n    </tr>\n    <tr>\n    \t<th scope=\"row\">その他</th>\n    \t<td>社員寮完備（福島県双葉郡富岡町）賄付、福利厚生倶楽部、資格取得支援制度有</td>\n    </tr>\n</tbody>\n</table>\n\n\t\n<div class=\"btn_area mb_high\">\n<ul>\n<li><a href=\"https://forms.gle/7sPWYET6j62tBbH57\" target=\"_blank\">エントリーフォームから応募する</a></li>\n</ul>\n</div>\n\n<h3>求人に関するお問い合わせ</h3>\n<div class=\"area01\">\n<div class=\"inner\">\n<h4><span itemprop=\"hiringOrganization\" itemscope itemtype = \"http://schema.org/Organization\"><span itemprop = \"name\" ><span itemprop=\"sameAs\">原子力エンジニアリング株式会社</span></span></span></h4>\n<p>〒319-1112　茨城県那珂郡東海村村松字平原3129-29<br>\n<span class=\"bld\">TEL：029-287-2828（代）<br>\nFAX：029-287-3399</span></p>\n<div class=\"btn02\">\n    <a href=\"https://forms.gle/zbkWBxVViE6ps3tR8\" target=\"_blank\">メールでのお問い合わせ</a>\n</div>\n</div>\n<!-- /inner -->\n</div>\n<!-- /area01 -->\n\n</div>\n<!-- /inner -->\n</section>\n<!-- /adjust_group -->\n\n</div>\n<!-- contents -->\n</main>\n\n\n<footer>\n<div class=\"inner\">\n<nav class=\"footer_area_nav sp\">\n<ul>\n<li><a href=\"../../about/index.html\">NECOについて</a></li>\n<li><a href=\"../../works/index.html\">私たちの仕事</a></li>\n<li><a href=\"../../people/index.html\">NECOの仲間</a></li>\n<li><a href=\"../../career_formation/index.html\">キャリア形成</a></li>\n<li><a href=\"../../benefit/index.html\">環境と制度</a></li>\n<li><a href=\"../../recruit/index.html\">採用情報</a></li>\n<li><a href=\"../../privacy/index.html\">プライバシーポリシー</a></li>\n<li><a href=\"../../contact/index.html\">お問い合わせ</a></li>\n<li><a href=\"../../sitemap/index.html\">サイトマップ</a></li>\n</ul>\n</nav>\n<!-- /footer_area_nav -->\n<div class=\"vcard_area\">\n<div class=\