{"url":"http://www.r-ehm.co.jp/recruit/","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n\n<head>\n  <meta charset=\"utf-8\">\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n  <title>採用情報-トヨタレンタリース西四国</title>\n  <meta name=\"description\" content=\"よいクルマ、よいサービス。愛媛県と高知県のレンタカー予約はトヨタレンタリース西四国へ！\">\n  <meta name=\"title\" content=\"採用情報-トヨタレンタリース西四国\">\n  <meta content=\"IE=edge\" http-equiv=\"X-UA-Compatible\">\n  <meta name=\"format-detection\" content=\"telephone=no,address=no,email=no\">\n  <!-- seo -->\n  <meta property=\"og:title\" content=\"採用情報-トヨタレンタリース西四国\" />\n  <meta property=\"og:type\" content=\"website\" />\n  <meta property=\"og:url\" content=\"https://www.r-ehm.co.jp/recruit/\" />\n  <meta property=\"og:image\" content=\"https://www.r-ehm.co.jp/assets/img/ogp.jpg\" />\n  <meta property=\"og:site_name\" content=\"採用情報-トヨタレンタリース西四国\" />\n  <meta property=\"og:description\" content=\"よいクルマ、よいサービス。愛媛県と高知県のレンタカー予約はトヨタレンタリース西四国へ！\" />\n  <meta name=\"twitter:card\" content=\"summary\" />\n  <meta name=\"twitter:title\" content=\"採用情報-トヨタレンタリース西四国\" />\n  <meta name=\"twitter:description\" content=\"よいクルマ、よいサービス。愛媛県と高知県のレンタカー予約はトヨタレンタリース西四国へ！\" />\n  <meta name=\"twitter:image\" content=\"https://www.r-ehm.co.jp/assets/img/ogp.jpg\" />\n\n  <!-- faviconの指定 -->\n  <link rel=\"icon\" type=\"img/x-icon\" href=\"/assets/img/favicon.ico\">\n  <link rel=\"icon\" href=\"/assets/img/favicon.ico\">\n  <link rel=\"shortcut icon\" type=\"img/vnd.microsoft.icon\" href=\"/assets/img/favicon.ico\">\n  <link rel=\"icon\" type=\"img/vnd.microsoft.icon\" href=\"/assets/img/favicon.ico\">\n  <link rel=\"apple-touch-icon\" href=\"/apple-touch-icon.png\" sizes=\"180x180\">\n  <link rel=\"apple-touch-icon-precomposed\" href=\"/apple-touch-icon.png\" sizes=\"180x180\">\n  <link rel=\"stylesheet\" href=\"https://unpkg.com/swiper/swiper-bundle.min.css\">\n  <link rel=\"stylesheet\" href=\"/assets/css/scss/pages/common.css\">\n  <link rel=\"stylesheet\" href=\"/assets/css/scss/pages/recruit.css\">\n</head>\n\n<body>\n  <div class=\"wrap\">\n    <div class=\"l-content\">\n      <!-- l-header -->\n      <header class=\"l-header js-header\">\n        <div class=\"l-header-logo\">\n          <h1 class=\"l-header-logo__ttl\">\n            <a class=\"-link\" href=\"/\">\n              <img src=\"/assets/img/common/logo.svg\" alt=\"TOYOTA Rent a Car\">\n            </a>\n          </h1>\n        </div>\n        <div id=\"js-drawermenu\" class=\"l-header-area\">\n          <ul class=\"l-header-area__list\">\n            <li class=\"l-header-area__list-item\"><a class=\"-link\" href=\"/\">ホーム</a></li>\n            <li class=\"l-header-area__list-item\"><a class=\"-link\" href=\"/company/\">会社概要</a></li>\n            <div class=\"l-header-area__list-item l-header-area__list-item--linkaccd\">\n              <a class=\"-link\" href=\"/recruit/\">採用情報</a>\n              <span class=\"l-header-area__list-item--linkaccd-btn js-accd\"></span>\n              <ul class=\"l-header-area__list-ul\" style=\"display:none;\">\n                <li class=\"l-header-area__list-section l-header-area__list-section--mt\"><a href=\"/recruit/interview/\">-\n                    社員インタビュー</a></li>\n                <li class=\"l-header-area__list-section\"><a href=\"/recruit/data/\">- 数字で見る</a></li>\n                <li class=\"l-header-area__list-section\"><a href=\"/recruit/training/\">- 研修制度</a></li>\n                <li class=\"l-header-area__list-section\"><a href=\"/recruit/faq/\">- よくあるご質問</a></li>\n                <li class=\"l-header-area__list-section\"><a href=\"/recruit/description/\">- 募集要項</a></li>\n              </ul>\n            </div>\n          </ul>\n          <div class=\"l-header-area__targetbox\">\n            <div class=\"l-header-area__shop\">\n              <a href=\"/shop/\"><span class=\"-icon\">店舗を探す</span></a>\n            </div>\n            <div class=\"l-header-area__info\">\n              <a href=\"https://rent.toyota.co.jp/static/guide/\" target=\"_blank\"><span class=\"-icon\">ご利用案内</span></a>\n            </div>\n            <div class=\"l-header-area__reservation\">\n              <a href=\"https://rent.toyota.co.jp/\" target=\"_blank\"><span class=\"-icon\">インターネット予約</span></a>\n            </div>\n          </div>\n        </div>\n        <div id=\"js-btnTrigger\" class=\"js-navbtn l-header-humbtn\">\n          <span class=\"l-header-humbtn__line\">\n            <!--btn-->\n          </span>\n          <span class=\"l-header-humbtn__line\">\n            <!--btn-->\n          </span>\n        </div>\n      </header>\n      <!-- l-snsbox -->\n      <div class=\"l-snsbox\">\n        <div class=\"l-snsbox-block l-snsbox-block--01\">\n          <a href=\"/recruit/\">\n            <p class=\"-txt\">採用情報</p>\n          </a>\n        </div>\n        <div class=\"l-snsbox-block l-snsbox-block--02\">\n          <a href=\"https://www.instagram.com/toyota_nishishikoku/\" target=\"_blank\">\n            <p class=\"-txt\">インスタグラム</p>\n          </a>\n        </div>\n      </div>\n      <div class=\"l-content-main\">\n\n\n<div class=\"p-recruit-bg\">\n  <section class=\"p-recruit-mv\">\n    <div class=\"p-recruit-mv__colud\"></div>\n    <p class=\"p-recruit-mv__icon01\"></p>\n    <p class=\"p-recruit-mv__icon02\"></p>\n    <p class=\"p-recruit-mv__wave\"></p>\n    <div class=\"p-recruit-mv__ttlbox\">\n      <h2 class=\"p-recruit-mv__ttlbox-ttl\">recruit</h2>\n      <div id=\"js-target\" class=\"p-recruit-mv__ttlbox-txt\">\n        <p class=\"-subtxt -subtxt01\">地域と共に、人も育つ。</p>\n        <p class=\"-subtxt -subtxt02\">トヨタレンタリース西四国の</p>\n        <p class=\"-subtxt -subtxt03\">未来を一緒に。</p>\n      </div>\n      <p class=\"p-recruit-mv__ttlbox-en\">People grow alongside their communities.<br>Let’s build the future of <br class=\"sp\">Toyota Rent-A-Lease Nishi Shikoku <br class=\"sp\">Co., Ltd. <br class=\"pc\">together.</p>\n    </div>\n    <div class=\"p-recruit-mv__loarding\"></div>\n    <div class=\"p-recruit-mv__breadcrumbs\">\n      <ul class=\"flex\">\n        <li><a href=\"/\">トップ</a></li>\n        <li>採用情報</li>\n      </ul>\n    </div>\n  </section>\n  <section class=\"p-recruit-message\">\n    <div class=\"inner p-recruit-message--inner\">\n      <div class=\"p-recruit-message__area flex\">\n        <div class=\"p-recruit-message__area-left\">\n          <div class=\"c-ttl02box\">\n            <h2 class=\"c-ttl02 js-anime\">Message<span class=\"-jp\">代表挨拶</span></h2>\n          </div>\n          <p class=\"-catch\"><span class=\"-color\">挑戦</span>する気持ちが、<br>あなたの<span class=\"-color\">未来</span>を動かす。</p>\n          <p class=\"p-recruit-message-txt\">私たちトヨタレンタリース西四国は、ただクルマを「貸す」だけの会社ではありません。お客様の目的や想いに寄り添い、最適な移動手段と安心を提供する“モビリティのパートナー”です。<br>\n地域に根ざした店舗展開と、トヨタグループの信頼を強みに、観光・ビジネス・生活のさまざまな場面で活躍しています。<br>\nお客様に「また利用したい」と思っていただける体験をつくるのは、あなたの人柄と挑戦する心。<br>\n私たちは、人と人とのつながりを大切にしながら、共に成長できる仲間を求めています。</p>\n        </div>\n        <div class=\"p-recruit-message__area-imgbox01 js-anime\">\n          <div class=\"-in js-pararax\">\n            <img src=\"/assets/img/top/recruit-img01.jpg\">\n          </div>\n        </div>\n        <div class=\"p-recruit-message__area-imgbox02 js-anime\">\n          <div class=\"-in js-pararax\">\n            <img src=\"/assets/img/top/recruit-img02.jpg\">\n          </div>\n        </div>\n        <div class=\"p-recruit-message__area-imgbox03 js-anime\">\n          <div class=\"-in js-pararax\">\n            <img src=\"/assets/img/top/recruit-img03.jpg\">\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n</div>\n\n<!-- p-recruit-interview -->\n<section class=\"p-recruit-interview\">\n  <div class=\"inner p-recruit-interview--inner\">\n    <div class=\"p-recruit-interview__area\">\n      <div class=\"c-ttl02box\">\n        <h2 class=\"c-ttl02 js-anime\">interview<span class=\"-jp\">社員インタビュー</span></h2>\n      </div>\n      <!-- p-recruit-interview__area-imgbox -->\n      <div class=\"p-recruit-interview__area-imgbox\">\n        <div class=\"-item\">\n          <a href=\"/recruit/interview/interview01/\">\n            <div class=\"-img\">\n              <img src=\"/assets/img/recruit/interview01.jpg\">\n            </div>\n            <div class=\"-info -info--01\">\n              <div class=\"-info-com\">\n                <p class=\"-info-com-txt\"><span>「笑顔」でつなぐ</span></p>\n                <p class=\"-info-com-txt\"><span>安心の時間</span></p>\n              </div>\n              <div class=\"-info-txtbox\">\n                <p class=\"-info-txtbox-year\">2024年 入社<br>レンタル部</p>\n                <p class=\"-info-txtbox-posi\">熊谷 奈桜</p>\n                <p class=\"-info-txtbox-en\">NAO KUMAGAI</p>\n              </div>\n              <p class=\"-info-arrow\"></p>\n            </div>\n          </a>\n        </div>\n        <div class=\"-item\">\n          <a href=\"/recruit/interview/interview02/\">\n            <div class=\"-img\">\n              <img src=\"/assets/img/recruit/interview02.jpg\">\n            </div>\n            <div class=\"-info -info--02\">\n              <div class=\"-info-com\">\n                <p class=\"-info-com-txt\"><span>車好きが導いた</span></p>\n                <p class=\"-info-com-txt\"><span>この会社との縁</span></p>\n              </div>\n              <div class=\"-info-txtbox\">\n                <p class=\"-info-txtbox-year\">2008年  入社<br>管理部</p>\n                <p class=\"-info-txtbox-posi\">田中 延明</p>\n                <p class=\"-info-txtbox-en\">NOBUAKI TANAKA</p>\n              </div>\n              <p class=\"-info-arrow\"></p>\n            </div>\n          </a>\n        </div>\n        <div class=\"-item\">\n          <a href=\"/recruit/interview/interview03/\">\n            <div class=\"-img\">\n              <img src=\"/assets/img/recruit/interview03.jpg\">\n            </div>\n            <div class=\"-info -info--03\">\n              <div class=\"-info-com\">\n                <p class=\"-info-com-txt\"><span>小さな気配りを大切に</span></p>\n                <p class=\"-info-com-txt\"><span>チームでお客様をお迎えする</span></p>\n              </div>\n              <div class=\"-info-txtbox\">\n                <p class=\"-info-txtbox-year\">2015年  入社<br>レンタル部</p>\n                <p class=\"-info-txtbox-posi\">竹内 くるみ</p>\n                <p class=\"-info-txtbox-en\">KURUMI  TAKEUCHI</p>\n              </div>\n              <p class=\"-info-arrow\"></p>\n            </div>\n          </a>\n        </div>\n        <div class=\"-item\">\n          <a href=\"/recruit/interview/interview04/\">\n            <div class=\"-img\">\n              <img src=\"/assets/img/recruit/interview04.jpg\">\n            </div>\n            <div class=\"-info -info--04\">\n              <div class=\"-info-com\">\n                <p class=\"-info-com-txt\"><span>縁とタイミングで決めた</span></p>\n                <p class=\"-info-com-txt\"><span>新たな挑戦</span></p>\n              </div>\n              <div class=\"-info-txtbox\">\n                <p class=\"-info-txtbox-year\">2024年  入社<br>リース部</p>\n                <p class=\"-info-txtbox-posi\">大城戸浩之</p>\n                <p class=\"-info-txtbox-en\">HIROYUKI OKIDO</p>\n              </div>\n              <p class=\"-info-arrow\"></p>\n            </div>\n          </a>\n        </div>\n        <div class=\"-item\">\n          <a href=\"/recruit/interview/interview05/\">\n            <div class=\"-img\">\n              <img src=\"/assets/img/recruit/interview05.jpg\">\n            </div>\n            <div class=\"-info -info--05\">\n              <div class=\"-info-com\">\n                <p class=\"-info-com-txt\"><span>車好きと人好きが導いた</span></p>\n                <p class=\"-info-com-txt\"><span>挑戦</span></p>\n              </div>\n              <div class=\"-info-txtbox\">\n                <p class=\"-info-txtbox-year\">2012年  入社<br>レンタル部</p>\n                <p class=\"-info-txtbox-posi\">佐々木 雅男</p>\n                <p class=\"-info-txtbox-en\">MASAO SASAKI</p>\n              </div>\n              <p class=\"-info-arrow\"></p>\n            </div>\n          </a>\n        </div>\n      </div>\n      <!-- p-recruit-interview__area-slider -->\n      <div class=\"p-recruit-interview__area-slider sp\">\n        <div class=\"js-swiper-interview\">\n          <div class=\"swiper-wrapper\">\n            <!-- swiper-slide -->\n            <div class=\"swiper-slide\">\n              <div class=\"-item\">\n                <a class=\"-link\" href=\"/recruit/interview/interview01/\">\n                  <div class=\"-img\">\n                    <img src=\"/assets/img/recruit/interview01-sp.jpg\">\n                  </div>\n                  <div class=\"-txtbox\">\n                    <span class=\"-year\">2024年入社</span>\n                    <p class=\"-posi\">レンタル部</p>\n                    <p class=\"-name\">熊谷 奈桜</p>\n                  </div>\n                </a>\n              </div>\n            </div>\n            <!-- swiper-slide -->\n            <div class=\"swiper-slide\">\n              <div class=\"-item\">\n                <a class=\"-link\" href=\"/recruit/interview/interview02/\">\n                  <div class=\"-img\">\n                    <img src=\"/assets/img/recruit/interview02-sp.jpg\">\n                  </div>\n                  <div class=\"-txtbox\">\n                    <span class=\"-year\">2008年入社</span>\n                    <p class=\"-posi\">管理部</p>\n                    <p class=\"-name\">田中 延明</p>\n                  </div>\n                </a>\n              </div>\n            </div>\n            <!-- swiper-slide -->\n            <div class=\"swiper-slide\">\n              <div class=\"-item\">\n                <a class=\"-link\" href=\"/recruit/interview/interview03/\">\n                  <div class=\"-img\">\n                    <img src=\"/assets/img/recruit/interview03-sp.jpg\">\n                  </div>\n                  <div class=\"-txtbox\">\n                    <span class=\"-year\">2015年入社</span>\n                    <p class=\"-posi\">レンタル部</p>\n                    <p class=\"-name\">竹内 くるみ</p>\n                  </div>\n                </a>\n              </div>\n            </div>\n            <!-- swiper-slide -->\n            <div class=\"swiper-slide\">\n              <div class=\"-item\">\n                <a class=\"-link\" href=\"/recruit/interview/interview04/\">\n                  <div class=\"-img\">\n                    <img src=\"/assets/img/recruit/interview04-sp.jpg\">\n                  </div>\n                  <div class=\"-txtbox\">\n                    <span class=\"-year\">2024年入社</span>\n                    <p class=\"-posi\">リース部</p>\n                    <p class=\"-name\">大城戸 浩之</p>\n                  </div>\n                </a>\n              </div>\n            </div>\n            <!-- swiper-slide -->\n            <div class=\"swiper-slide\">\n              <div class=\"-item\">\n                <a class=\"-link\" href=\"/recruit/interview/interview05/\">\n                  <div class=\"-img\">\n                    <img src=\"/assets/img/recruit/interview05-sp.jpg\">\n                  </div>\n                  <div class=\"-txtbox\">\n                    <span class=\"-year\">2012年入社</span>\n                    <p class=\"-posi\">レンタル部</p>\n                    <p class=\"-name\">佐々木 雅男</p>\n                  </div>\n                </a>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n      <p class=\"p-recruit-interview__area-txt\">\n        トヨタレンタリース西四国では、さまざまな部署・立場のスタッフが、それぞれのフィールドでやりがいを持って働いています。<br>このページでは、実際に働く社員の声をご紹介。入社のきっかけや仕事の魅力、成長を感じる瞬間など、リアルな言葉を通して、職場の雰囲気や価値観を感じてみてください。\n      </p>\n      <div class=\"c-btn01 p-recruit-interview__area-btn\">\n        <a href=\"/recruit/interview/\">\n          <p class=\"-txt\">社員インタビュー一覧</p>\n        </a>\n      </div>\n      <p class=\"p-recruit-interview__area-icon\">\n        <img src=\"/assets/img/recruit/interview-icon.png\">\n      </p>\n    </div>\n  </div>\n</section>\n\n<!-- p-recruit-training -->\n<section class=\"p-recruit-training\">\n  <div class=\"p-recruit-training__icon js-anime\">\n    <img src=\"/assets/img/recruit/training-icon.png\">\n  </div>\n  <div class=\"c-ttl02box p-recruit-training--ttobox\">\n    <h2 class=\"c-ttl02 js-anime\">Training<span class=\"-jp\">研修制度</span></h2>\n  </div>\n  <p class=\"p-recruit-training__txt\">トヨタレンタリース西四国では、社員一人ひとりの成長を支えるために、<br>充実した研修制度を整えています。</p>\n  <div class=\"c-btn01 p-recruit-training--btn\">\n    <a href=\"/recruit/training/\">\n      <p class=\"-txt\">研修制度について</p>\n    </a>\n  </div>\n  <p class=\"p-recruit-training__bg\"></p>\n  <div class=\"p-recruit-training__slidebox\">\n    <div class=\"swiper js-swiper01\">\n      <div class=\"swiper-wrapper\">\n        <div class=\"swiper-slide\">\n          <picture>\n            <source srcset=\"/assets/img/recruit/training-slide01-sp.jpg\" media=\"(max-width: 768px)\">\n            <img src=\"/assets/img/recruit/training-slide01.jpg\">\n          </picture>\n        </div>\n        <div class=\"swiper-slide\">\n          <picture>\n            <source srcset=\"/assets/img/recruit/training-slide02-sp.jpg\" media=\"(max-width: 768px)\">\n            <img src=\"/assets/img/recruit/training-slide02.jpg\">\n          </picture>\n        </div>\n        <div class=\"swiper-slide\">\n          <picture>\n            <source srcset=\"/assets/img/recruit/training-slide03-sp.jpg\" media=\"(max-width: 768px)\">\n            <img src=\"/assets/img/recruit/training-slide03.jpg\">\n          </picture>\n        </div>\n      </div>\n    </div>\n    <div class=\"swiper-pagination\"></div>\n    <div class=\"swiper-button-prev\"></div>\n    <div class=\"swiper-button-next\"></div>\n  </div>\n</section>\n\n<!-- p-recruit-other -->\n<section class=\"p-recruit-other\">\n  <div class=\"p-recruit-other__icon js-anime\">\n    <img src=\"/assets/img/recruit/link-icon.png\">\n  </div>\n  <div class=\"inner\">\n    <!-- p-recruit-other__area -->\n    <div class=\"p-recruit-ot