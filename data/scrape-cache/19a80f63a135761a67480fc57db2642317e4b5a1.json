alt=\"jump to a section icon\"\n                  />\n                  <span\n                    class=\"lb-font-eyebrow lb-font--no-crop yth-jumplinks__heading lb-font-weight-600\"\n                    >jump to a section</span\n                  >\n                  <span\n                    class=\"lb-font-subhead-1 lb-font-weight-700 lb-font--no-crop yth-jumplinks__heading--fixed\"\n                    >Our Policies</span\n                  >\n                </div>\n                <div class=\"yth-jumplinks__items-container\">\n                  <svg\n                    class=\"yth-jumplinks__arrow yth-jumplinks__arrow--left\"\n                    xmlns=\"http://www.w3.org/2000/svg\"\n                    width=\"24\"\n                    height=\"24\"\n                    viewBox=\"0 0 24 24\"\n                    fill=\"none\"\n                    stroke=\"#606060\"\n                    stroke-width=\"2.5\"\n                    stroke-linecap=\"square\"\n                    stroke-linejoin=\"arcs\"\n                  >\n                    <path d=\"M15 18l-6-6 6-6\" />\n                  </svg>\n                  <div class=\"yth-jumplinks__scroll-wrapper\">\n                    <div class=\"yth-jumplinks__items\">\n                      <button\n                        class=\"yth-jumplinks__items-label lb-font-weight-700\"\n                        data-id=\"how-our-guidelines-work\"\n                      >\n                        How our guidelines work\n                      </button>\n\n                      <button\n                        class=\"yth-jumplinks__items-label lb-font-weight-700\"\n                        data-id=\"how-we-support-creators\"\n                      >\n                        How we support creators\n                      </button>\n\n                      <button\n                        class=\"yth-jumplinks__items-label lb-font-weight-700\"\n                        data-id=\"combating-abuse\"\n                      >\n                        Combating abuse\n                      </button>\n                    </div>\n                  </div>\n                  <svg\n                    class=\"yth-jumplinks__arrow yth-jumplinks__arrow--right\"\n                    xmlns=\"http://www.w3.org/2000/svg\"\n                    width=\"24\"\n                    height=\"24\"\n                    viewBox=\"0 0 24 24\"\n                    fill=\"none\"\n                    stroke=\"#606060\"\n                    stroke-width=\"2.5\"\n                    stroke-linecap=\"square\"\n                    stroke-linejoin=\"arcs\"\n                  >\n                    <path d=\"M9 18l6-6-6-6\" />\n                  </svg>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </section>\n\n      <section\n        class=\"yth-section yth-section--small yth-guidelines\"\n        id=\"how-our-guidelines-work\"\n      >\n        <div class=\"yth-rail lb-margin-bottom-xs\"></div>\n\n        <h2\n          class=\"yth-guidelines__heading lb-font-headline-2 lb-font--no-crop lb-font-weight-700 lb-margin-bottom-s\"\n        >\n          How Community &amp; Ad-Friendly Guidelines work\n        </h2>\n\n        <div class=\"lb-grid yth-guidelines__grid\">\n          <div class=\"lb-grid__cell lb-grid__cell--span-7\">\n            <div class=\"yth-font-body-2\">\n              <div class=\"yth-md\">\n                <p>\n                  Our policies help us maintain a responsible business that\n                  viewers, creators, and advertisers can rely on in order to\n                  continue to thrive on YouTube.\n                </p>\n              </div>\n            </div>\n\n            <div class=\"yth-guidelines__sub-description yth-font-body-2\">\n              <div class=\"yth-md\">\n                <p>\n                  As with any system, we sometimes make mistakes. That’s why\n                  <a\n                    href=\"https://support.google.com/youtube/answer/185111?co=GENIE.Platform%3DDesktop&amp;sjid=9395522532112275037-NC\"\n                    target=\"_blank\"\n                    aria-label=\"appeals link opens in new tab\"\n                    rel=\"noopener noreferrer\"\n                    >appeals</a\n                  >\n                  are an important part of our processes. Creators are notified\n                  when their videos are removed due to policy violations or when\n                  they may be suspended from YPP, and can appeal if they\n                  disagree with our decision.\n                </p>\n                <p>\n                  Our\n                  <a\n                    href=\"https://support.google.com/youtube/answer/9288567\"\n                    target=\"_blank\"\n                    aria-label=\"Community Guidelines link opens in new tab\"\n                    rel=\"noopener noreferrer\"\n                    >Community Guidelines</a\n                  >\n                  and\n                  <a\n                    href=\"https://support.google.com/youtube/answer/6162278\"\n                    target=\"_blank\"\n                    aria-label=\"Advertiser-Friendly Content Guidelines link opens in new tab\"\n                    rel=\"noopener noreferrer\"\n                    >Advertiser-Friendly Content Guidelines</a\n                  >\n                  are what enable us to strike this balance.\n                </p>\n              </div>\n            </div>\n          </div>\n          <div class=\"lb-grid__cell lb-grid__cell--span-5\">\n            <a\n              class=\"yth-black-arrow lb-font-weight-700 lb-font-subhead-2\"\n              href=\"https://support.google.com/youtube/answer/9288567\"\n              aria-label=\"Community Guidelines link opens in new tab\"\n              target=\"_blank\"\n            >\n              Community Guidelines\n            </a>\n            <div class=\"yth-font-body-2 lb-margin-top-xs\">\n              <div class=\"yth-md\">\n                <p>\n                  Content that violates our community guidelines is flagged by a\n                  mix of\n                  <strong>automated detection and human reporting</strong> —\n                  most is automatically detected — and we go to great lengths to\n                  make sure violative content isn’t widely viewed, or even\n                  viewed at all, before it’s taken down.\n                </p>\n                <p>\n                  Exceptions can be made when content has a clear educational,\n                  documentary, scientific, or artistic\n                  <a\n                    href=\"https://support.google.com/youtube/answer/6345162?ref_topic=9282435&amp;sjid=277005303270439027-NA\"\n                    target=\"_blank\"\n                    aria-label=\"(EDSA) link opens in new tab\"\n                    rel=\"noopener noreferrer\"\n                    >(EDSA)</a\n                  >\n                  context, including content that is in the public’s interest.\n                </p>\n              </div>\n            </div>\n            <hr />\n\n            <a\n              class=\"yth-black-arrow lb-font-weight-700 lb-font-subhead-2\"\n              href=\"https://support.google.com/youtube/answer/6162278\"\n              aria-label=\"Advertiser-Friendly Content Guidelines link opens in new tab\"\n              target=\"_blank\"\n            >\n              Advertiser-Friendly Content Guidelines\n            </a>\n            <div class=\"yth-font-body-2 lb-margin-top-xs\">\n              <div class=\"yth-md\">\n                <p>\n                  Brands rely on us to protect their business interests when\n                  they’re advertising on YouTube.\n                </p>\n                <p>\n                  To help support this, we have a set of Ad-Friendly guidelines\n                  creators in the\n                  <a\n                    href=\"https://support.google.com/youtube/answer/72851?hl=en\"\n                    target=\"_blank\"\n                    aria-label=\"YouTube Partner Program (YPP) link opens in new tab\"\n                    rel=\"noopener noreferrer\"\n                    >YouTube Partner Program (YPP)</a\n                  >\n                  need to follow in order to have Ads served on their channel\n                  content and earn a share of the revenue.\n                </p>\n              </div>\n            </div>\n            <hr />\n          </div>\n        </div>\n      </section>\n\n      <section class=\"yth-highlight-lockup\" id=\"how-we-support-creators\">\n        <div class=\"yth-section yth-section--small\">\n          <div class=\"lb-grid yth-highlight-lockup__grid\">\n            <div class=\"lb-grid__cell lb-grid__cell--span-6\">\n              <div class=\"yth-rail lb-margin-bottom-xs\"></div>\n\n              <h2\n                class=\"yth-highlight-lockup__heading lb-font-headline-2 lb-font--no-crop lb-font-weight-700 lb-margin-bottom-s\"\n              >\n                How we support creators\n              </h2>\n\n              <div class=\"hyth-highlight-lockup__description yth-font-body-2\">\n                <div class=\"yth-md\">\n                  <p>\n                    Since 2007, we’ve been paying eligible creators every month\n                    through our revenue-sharing model, the\n                    <a\n                      href=\"https://support.google.com/youtube/answer/72851\"\n                      target=\"_blank\"\n                      aria-label=\"YouTube Partner Program link opens in new tab\"\n                      rel=\"noopener noreferrer\"\n                      >YouTube Partner Program</a\n                    >.\n                  </p>\n                </div>\n              </div>\n\n              <div\n                class=\"yth-highlight-lockup__sub-description yth-font-body-2\"\n              >\n                <div class=\"yth-md\">\n                  <p>\n                    For a creator to be eligible for YPP, they must meet a\n                    higher bar for what they share on YouTube. Creators have to\n                    follow\n                    <a\n                      href=\"https://support.google.com/youtube/answer/1311392\"\n                      target=\"_blank\"\n                      aria-label=\"YouTube monetization policies link opens in new tab\"\n                      rel=\"noopener noreferrer\"\n                      >YouTube monetization policies</a\n                    >\n                    and we review each applicant’s channel before admitting them\n                    to YPP. We also demonetize videos that violate our\n                    Advertiser Friendly Guidelines, and suspend creators from\n                    YPP for repeat offenses. With this model, creators have a\n                    long-term incentive to reinforce YouTube’s safety and follow\n                    our policies.\n                  </p>\n                </div>\n              </div>\n            </div>\n\n            <div class=\"lb-grid__cell lb-grid__cell--offset-7-span-5\">\n              <div class=\"yth-img-wrapper yth-img-wrapper--landscaped\">\n                <img\n                  class=\"yth-image\"\n                  lb-auto-init=\"LBImageLoader\"\n                  lb-options=\"{\n        '_1x': 'https://kstatic.googleusercontent.com/files/37b9adb9bb91ae0b3757172116146e1850ab24391746f2c8fb0455d6ba267434dde18c7e960071d98e864467122eff4ba221c69f5cc499ffe6dd5051a008b014 1x'\n      }\"\n                  src=\"https://kstatic.googleusercontent.com/files/37b9adb9bb91ae0b3757172116146e1850ab24391746f2c8fb0455d6ba267434dde18c7e960071d98e864467122eff4ba221c69f5cc499ffe6dd5051a008b014=w1080\"\n                  alt=\"How we support creators image\"\n                />\n              </div>\n            </div>\n          </div>\n\n          <div\n            class=\"yth-highlight-lockup__title lb-font--no-crop lb-font-subhead-2 lb-font-weight-700\"\n          >\n            We also provide Creators with an array of tools to manage their\n            content &amp; communities:\n          </div>\n\n          <div class=\"lb-grid\">\n            <div\n              class=\"lb-grid__cell lb-grid__cell--sm-span-12 lb-grid__cell--md-span-12 lb-grid__cell--span-4 yth-highlight-lockup__card-wrapper\"\n            >\n              <div class=\"yth-highlight-lockup__card-content-wrapper\">\n                <div\n                  class=\"lb-font-subhead-2 lb-font--no-crop lb-font-weight-600 lb-margin-bottom-xs\"\n                >\n                  Manage Experiences\n                </div>\n                <div class=\"yth-font-body-2 lb-color-grey-5\">\n                  <div class=\"yth-md\">\n                    <p>\n                      Channel Guidelines help creators set what kind of\n                      conversations they want to have on their channel.\n                    </p>\n                    <p>\n                      Creators can hold potentially inappropriate comments for\n                      review, hide certain individuals, block words, assign\n                      moderation privileges, and more.\n                    </p>\n                  </div>\n                </div>\n              </div>\n              <hr />\n              <a\n                class=\"yth-blue-arrow yth-highlight-lockup__manage-link\"\n                href=\"https://support.google.com/youtube/answer/11895180?sjid=16252001751925794258-NC\"\n                aria-label=\"How to set channel guidelines link opens in new tab\"\n                target=\"_blank\"\n              >\n                How to set channel guidelines\n              </a>\n            </div>\n\n            <div\n              class=\"lb-grid__cell lb-grid__cell--sm-span-12 lb-grid__cell--md-span-12 lb-grid__cell--span-4 yth-highlight-lockup__card-wrapper\"\n            >\n              <div class=\"yth-highlight-lockup__card-content-wrapper\">\n                <div\n                  class=\"lb-font-subhead-2 lb-font--no-crop lb-font-weight-600 lb-margin-bottom-xs\"\n                >\n                  Channel Management\n                </div>\n                <div class=\"yth-font-body-2 lb-color-grey-5\">\n                  <div class=\"yth-md\">\n                    <p>\n                      We provide creators with an array of products that help\n                      them decide how to manage their channels.\n                    </p>\n                  </div>\n                </div>\n              </div>\n              <hr />\n              <a\n                class=\"yth-blue-arrow yth-highlight-lockup__manage-link\"\n                href=\"https://support.google.com/youtube/topic/9257889?ref_topic=9257610&amp;sjid=17973076408754828508-NC\"\n                aria-label=\"How to manage posts and comments link opens in new tab\"\n                target=\"_blank\"\n              >\n                How to manage posts and comments\n              </a>\n            </div>\n\n            <div\n              class=\"lb-grid__cell lb-grid__cell--sm-span-12 lb-grid__cell--md-span-12 lb-grid__cell--span-4 yth-highlight-lockup__card-wrapper\"\n            >\n              <div class=\"yth-highlight-lockup__card-content-wrapper\">\n                <div\n                  class=\"lb-font-subhead-2 lb-font--no-crop lb-font-weight-600 lb-margin-bottom-xs\"\n                >\n                  Privacy &amp; Safety Resources\n                </div>\n                <div class=\"yth-font-body-2 lb-color-grey-5\">\n                  <div class=\"yth-md\">\n                    <p>\n                      The privacy and safety of creators on YouTube is important\n                      to us, and we provide a range of tools &amp; resources to\n                      support them.\n                    </p>\n                  </div>\n                </div>\n              </div>\n              <hr />\n              <a\n                class=\"yth-blue-arrow yth-highlight-lockup__manage-link\"\n                href=\"https://support.google.com/youtube/topic/2803240?ref_topic=6151248&amp;sjid=16252001751925794258-NC\"\n                aria-label=\"How to use privacy and safety tools link opens in new tab\"\n                target=\"_blank\"\n              >\n                How to use privacy and safety tools\n              </a>\n            </div>\n          </div>\n        </div>\n      </section>\n\n      <section class=\"yth-highlight-lockup\" id=\"combating-abuse\">\n        <div class=\"yth-section yth-section--small\">\n          <div class=\"lb-grid yth-highlight-lockup__grid\">\n            <div class=\"lb-grid__cell lb-grid__cell--span-12\">\n              <div class=\"yth-rail lb-margin-bottom-xs\"></div>\n\n              <h2\n                class=\"yth-highlight-lockup__heading lb-font-headline-2 lb-font--no-crop lb-font-weight-700 lb-margin-bottom-s\"\n              >\n                How YouTube Partners with Industry Experts to Combat Abuse\n              </h2>\n\n              <div class=\"hyth-highlight-lockup__description yth-font-body-2\">\n                <div class=\"yth-md\">\n                  <p>\n                    Content that’s meant to praise, promote, or aid violent\n                    extremist or criminal organizations is not allowed on\n                    YouTube. We rely on many factors — like certain government\n                    and international organization designations — to determine\n                    what constitutes criminal or terrorist organizations.\n                  </p>\n                </div>\n              </div>\n\n              <div\n                class=\"yth-highlight-lockup__sub-description yth-font-body-2\"\n              >\n                <div class=\"yth-md\">\n                  <p>\n                    We’re also a founding member of the Global Internet Forum to\n                    Counter Terrorism\n                    <a\n                      href=\"https://gifct.org/\"\n                      target=\"_blank\"\n                      aria-label=\"(GIFCT) link opens in new tab\"\n                      rel=\"noopener noreferrer\"\n                      >(GIFCT)</a\n                    >, where we work with other tech companies to keep terrorist\n                    content off the web — and provide training and other\n                    resources to smaller companies facing similar challenges.\n                  </p>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </section>\n\n      <section class=\"yth-explore-more\" id=\"our-policies-explore-more\">\n        <div class=\"yth-section\">\n          <h3\n            class=\"yth-explore-more__heading lb-font-headline-2 lb-font--no-crop lb-font-weight-700\"\n          >\n            Explore more\n          </h3>\n          <div class=\"lb-grid\">\n            <div\n              class=\"lb-grid__cell lb-grid__cell--sm-span-12 lb-grid__cell--md-span-12 lb-grid__cell--lg-span-4 yth-explore-more__content-wrapper\"\n            >\n              <div\n                class=\"yth-explore-more__label lb-font-subhead-1 lb-font--no-crop lb-font-weight-700\"\n              >\n                Expanding likeness detection to civic leaders and journalists\n              </div>\n              <a\n                class=\"yth-arrow-link\"\n                href=\"https://blog.youtube/news-and-events/expanding-likeness-detection-civic-leaders-journalists/\"\n                target=\"_blank\"\n                rel=\"noopener noreferrer\"\n                aria-label=\"Expanding likeness detection to civic Leaders and journalists link opens in new tab\"\n              >\n              </a>\n            </div>\n\n            <div\n              class=\"lb-grid__cell lb-grid__cell--sm-span-12 lb-grid__cell--md-span-12 lb-grid__cell--lg-span-4 yth-explore-more__content-wrapper\"\n            >\n              <div\n                class=\"yth-explore-more__label lb-font-subhead-1 lb-font--no-crop lb-font-weight-700\"\n              >\n                New tools to protect creators and artists\n              </div>\n              <a\n                class=\"yth-arrow-link\"\n                href=\"https://blog.youtube/news-and-events/responsible-ai-tools/\"\n                target=\"_blank\"\n                rel=\"noopener noreferrer\"\n                aria-label=\"New tools to protect creators and artists link opens in new tab\"\n              >\n              </a>\n            </div>\n\n            <div\n              class=\"lb-grid__cell lb-grid__cell--sm-span-12 lb-grid__cell--md-span-12 lb-grid__cell--lg-span-4 yth-explore-more__content-wrapper\"\n            >\n              <div\n                class=\"yth-explore-more__label lb-font-subhead-1 lb-font--no-crop lb-font-weight-700\"\n              >\n                How we&#x27;re helping creators disclose altered or synthetic\n                content\n              </div>\n              <a\n                class=\"yth-arrow-link\"\n                href=\"https://blog.youtube/news-and-events/disclosing-ai-generated-content/\"\n                target=\"_blank\"\n                rel=\"noopener noreferrer\"\n                aria-label=\"How we&#x27;re helping creators disclose altered or synthetic content link opens in new tab\"\n              >\n              </a>\n            </div>\n          </div>\n        </div>\n      </section>\n    </main>\n\n    <footer\n      class=\"lb-footer\"\n      role=\"contentinfo\"\n      lb-auto-init=\"LBCustomFooter\"\n      lb-options=\"{\n            'bareUrl': '/howyoutubeworks/our-policies/',\n            'locales': 'en_us,ALL_au,en_be,ALL_ca,ALL_in,ALL_uk,en_mt,ALL_ie,ALL_kr,ALL_it,ALL_ee,ALL_fi,fr_ca,ALL_nl,ALL_be,ALL_hu,ALL_lv,ALL_cz,ALL_id,fr_be,ALL_fr,fr_lu,ALL_bg,sw_ALL,ALL_se,ALL_ro,ALL_sk,ALL_es,ALL_vn,es_us,mt_ALL,ALL_pl,ALL_lt,ALL_dk,ALL_hr,ALL_si,ALL_gr,el_cy,ALL_pt,ALL_ru,ar_ALL,ALL_de,ALL_at,de_be,ALL_lu,ALL_tr,tr_cy,ALL_br,ga_ALL,zh-TW_ALL,hi_in,iw_ALL,ALL_jp'\n          }\"\n    ></footer>\n\n    <script type=\"application/ld+json\" nonce=\"Ou09kSPGijM44ioK8761eQ\">\n      {\n        \"@context\": \"https://schema.org\",\n        \"@type\": \"Organization\",\n        \"name\": \"How Youtube Works\",\n        \"alternateName\": [\"How Youtube Works\"],\n        \"url\": \"https://www.youtube.com/howyoutubeworks/\",\n        \"logo\": \"https://lh3.googleusercontent.com/u7efPJhM1pB1PAIAO5PotDW-Qkkpnde_2MPx2P8pWFua7ZfgMowbhNbklswuAbT9RpzabRA3TEhZd00LJQwbX71Z3PZKBhR87P71I21cS4FkiUXfTa0\",\n        \"description\": \"YouTube's policies ensure that our platform allows viewers, creators, and advertisers to thrive. Review our guidelines on how we maintain a balance.\"\n      }\n    </script>\n\n    <script type=\"application/ld+json\" nonce=\"Ou09kSPGijM44ioK8761eQ\">\n      {\n        \"@context\": \"https://schema.org\",\n        \"@type\": \"WebPage\",\n        \"name\": \"YouTube Policies Crafted for Openness - How YouTube Works\",\n        \"image\": \"https://lh3.googleusercontent.com/se048cFLsr5cNioO9UrA_9YotuuWOob9q-4whdB6LkTMLHzVGtUI4wvdhVDdagxFQkFbi91Zph9y3Xu7C_q-krcTKbrSyejqsafYqF2BhlD9zUyxjg\",\n        \"url\": \"https://www.youtube.com/howyoutubeworks/our-policies/\",\n        \"description\": \"YouTube's policies ensure that our platform allows viewers, creators, and advertisers to thrive. Review our guidelines on how we maintain a balance.\",\n        \"publisher\": { \"@type\": \"WebPageElement\", \"name\": \"How Youtube Works\" }\n      }\n    </script>\n\n    <script type=\"application/ld+json\" nonce=\"Ou09kSPGijM44ioK8761eQ\">\n      {\n        \"@context\": \"https://schema.org\",\n        \"@type\": \"WebSite\",\n        \"url\": \"https://www.youtube.com/howyoutubeworks/our-policies/\",\n        \"name\": \"YouTube Policies Crafted for Openness - How YouTube Works\",\n        \"potentialAction\": {\n          \"@type\": \"SearchAction\",\n          \"target\": \"https://www.youtube.com/howyoutubeworks/our-policies/\",\n          \"query-input\": \"required name=query\"\n        }\n      }\n    </script>\n\n    <script\n      src=\"https://www.gstatic.com/glue/cookienotificationbar/cookienotificationbar.min.js\"\n      data-glue-cookie-notification-bar-category=\"2A\"\n      data-glue-cookie-notification-bar-language=\"en\"\n      data-glue-cookie-notification-bar-site-id=\"youtube.com/howyoutubeworks\"\n    nonce=\"Ou09kSPGijM44ioK8761eQ\"></script>\n  </body>\n</html>\n","finalUrl":"https://www.youtube.com/intl/ja/howyoutubeworks/our-policies/","rendered":false,"_cachedAt":"2026-06-23T16:50:56.534Z"}