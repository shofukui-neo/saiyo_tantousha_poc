css'  href='https://lifecare-mayu.com/wp/wp-content/plugins/contact-form-7-add-confirm/includes/css/styles.css?ver=5.1' type='text/css' media='all' />\n<script type='text/javascript' src='https://lifecare-mayu.com/wp/wp-includes/js/jquery/jquery.js?ver=1.12.4'></script>\n<script type='text/javascript' src='https://lifecare-mayu.com/wp/wp-includes/js/jquery/jquery-migrate.min.js?ver=1.4.1'></script>\n<link rel='https://api.w.org/' href='https://lifecare-mayu.com/wp-json/' />\n<link rel=\"EditURI\" type=\"application/rsd+xml\" title=\"RSD\" href=\"https://lifecare-mayu.com/wp/xmlrpc.php?rsd\" />\n<link rel=\"wlwmanifest\" type=\"application/wlwmanifest+xml\" href=\"https://lifecare-mayu.com/wp/wp-includes/wlwmanifest.xml\" /> \n<meta name=\"generator\" content=\"WordPress 4.9.29\" />\n<link rel=\"canonical\" href=\"https://lifecare-mayu.com/recruit/recruit1\" />\n<link rel='shortlink' href='https://lifecare-mayu.com/?p=1986' />\n<link rel=\"alternate\" type=\"application/json+oembed\" href=\"https://lifecare-mayu.com/wp-json/oembed/1.0/embed?url=https%3A%2F%2Flifecare-mayu.com%2Frecruit%2Frecruit1\" />\n<link rel=\"alternate\" type=\"text/xml+oembed\" href=\"https://lifecare-mayu.com/wp-json/oembed/1.0/embed?url=https%3A%2F%2Flifecare-mayu.com%2Frecruit%2Frecruit1&#038;format=xml\" />\n    <link rel=\"stylesheet\" href=\"https://lifecare-mayu.com/wp/wp-content/themes/world/css/vendor.css\">\n    <link rel=\"stylesheet\" href=\"https://lifecare-mayu.com/wp/wp-content/themes/world/css/main.css\">\n    <link rel=\"stylesheet\" href=\"https://lifecare-mayu.com/wp/wp-content/themes/world/css/page.css?=201906>\">\n  </head>\n  <body class=\"page-template page-template-page-recruit1 page-template-page-recruit1-php page page-id-1986 page-child parent-pageid-1985\">\n\n\t\t\t\t\t\t\t\n<!-- コンテンツスタート -->\n<div id=\"recruit1\" class=\"page recruit_page\">\n  <header>\n  \n\n    <div  class=\"recruit_header_inner\">\n      <div  class=\"recruit_page_content\">\n        <p class=\"recruit1_logo\"><a href=\"https://lifecare-mayu.com\"><img src=\"https://lifecare-mayu.com/wp/wp-content/themes/world/images/common/logo.png\" alt=\"株式会社ライフケア\"></a></p>\n        <p class=\"recruit_linkbutton\"><a href=\"https://lifecare-mayu.com\"><span>ライフケアのサイトはこちら</span></a></p>\n      </div>\n    <!-- /recruit_header_inner--></div>\n    \n    <div  class=\"recruit_page_content recruit_page_headerimage\">\n      <div class=\"recruit1_headertitle\">\n        <h1><span class=\"recruit1_title1\"><img src=\"https://lifecare-mayu.com/wp/wp-content/themes/world/images/recruit/kango_title1.png\" alt=\"ケアーズ訪問看護ステーション\"></span> <span class=\"recruit1_title2\"><img src=\"https://lifecare-mayu.com/wp/wp-content/themes/world/images/recruit/kango_title2.png\"  alt=\"ながのの看護\"></span><span class=\"recruit1_title3\"><img src=\"https://lifecare-mayu.com/wp/wp-content/themes/world/images/recruit/kango_title3.png\" alt=\"訪問看護師募集\"></span></h1>\n        <p class=\"recruit1_title4\"><img src=\"https://lifecare-mayu.com/wp/wp-content/themes/world/images/recruit/kango_title4.png\" alt=\"地域での在宅生活に欠かせない訪問看護。長野の地で一緒に活躍しましょう!\"></p>\n        <!-- /recruit1_headertitle --></div>\n\n      <!-- /recruit_page_content --></div>\n  </header>\n  <div id=\"page__header__navi__trigger\">\n    <nav id=\"page__header__navi\" class=\"page__header__navi__wrap\">\n      <ul class=\"page__header__navi\">\n        <li class=\"page__header__navi__item\"><a href=\"#section1\">訪問看護</a></li>\n        <li class=\"page__header__navi__item\"><a href=\"#section2\">働きやすい環境</a></li>\n        <li class=\"page__header__navi__item\"><a href=\"#section3\">訪問看護師の1日</a></li>\n        <li class=\"page__header__navi__item\"><a href=\"#section4\">先輩からのメッセージ</a></li>\n        <li class=\"page__header__navi__item\"><a href=\"#section5\">よくある質問</a></li>\n        <li class=\"page__header__navi__item\"><a href=\"#section6\">募集要項</a></li>\n      </ul>\n    </nav>\n  </div>\n  <section id=\"section1\">\n            <div class=\"recruit_page_apply\">\n        <p class=\"recruit_page_apply_button\"><a href=\"https://lifecare-mayu.com/recruitform/#recruitformbox\">ご応募はこちら</a></p>\n        <p class=\"recruit_page_apply_txt\">お電話でもお気軽にご応募ください</p>\n        <p class=\"recruit_page_apply_tel\">フリーダイヤル <a href=\"tel:0120622515\"><span class=\"recruit_page_pink\">0120-622-515</span></a></p>\n        <!-- /recruit_page_apply --></div>\n    <div  class=\"recruit_page_content\">\n      <h1 class=\"recruit_page_title_l1\"><span class=\"recruit_page_green\">在宅生活を支える</span>訪問看護</h1>\n      <p class=\"page__header__text\">超高齢化社会に突入していく日本で、重度な要介護状態となっても、住み慣れた地域で自分らしい暮らしを、人生の最期まで続けることができるように…。医療・介護・リハビリ・生活支援の中心で自立支援、在宅療養を支援したいと、2016年1月「ケアーズ訪問看護ステーションながのの看護」をオープンいたしました。<br>\n        在宅での療養生活を送る方の自立した生活をともに目指し、最期の時まで住み慣れたご自宅で幸せに過ごしていただけるようサポートする…本当に大切な役割を担わせていただいている私たちと、一緒に働きませんか？</p>\n      <!--/recruit_page_content--> </div>\n  </section>\n  <section id=\"section2\">\n    <div  class=\"recruit_page_content\">\n      <h1 class=\"recruit_page_title_l1\"><span class=\"recruit_page_pink\">あなたを支える</span>働きやすい環境</h1>\n      <div  class=\"recruit_page_wrapper\">\n        <div class=\"recruit_page_circle\">\n          <p><img src=\"https://lifecare-mayu.com/wp/wp-content/themes/world/images/recruit/kango_circle1.png\" alt=\"しっかり同行して自立を目指す\"></p>\n          <p><img src=\"https://lifecare-mayu.com/wp/wp-content/themes/world/images/recruit/kango_circle2.png\" alt=\"自分に合った働き方を選択できる\"></p>\n        </div>\n        <div class=\"recruit_page_circle\">\n          <p><img src=\"https://lifecare-mayu.com/wp/wp-content/themes/world/images/recruit/kango_circle3.png\" alt=\"未経験者・ブランクがある方も安心の研修体制\"></p>\n          <p><img src=\"https://lifecare-mayu.com/wp/wp-content/themes/world/images/recruit/kango_circle4.png\" alt=\"働き方に合った給与体系\"></p>\n        </div>\n        <!--/recruit_page_circle--></div>\n      <div  class=\"recruit_page_wrapper pdgb40\">\n        <div class=\"recruit_page_2col_1 recruit_page_2col_fl\">\n          <h2 class=\"recruit_page_title_s1\">あなたのライフスタイルに合わせて</h2>\n          <p>〈短時間〉〈短期間だけ〉〈WワークOK〉〈できる時に少しずつ〉働く人の分だけ、働き方がある、そんな皆さんを応援する会社です。</p>\n          <p>Wワークや週1日の短時間からOK。普段は他の病院施設で働いている方、出産・子育てなどでしばらくお休みされ、復職先をお探しの方、子育て中やご家族の介護をされている方、みなさま大歓迎です。まずはパートから始めて状況が変わったら正社員でなど、それぞれのライフスタイルに合わせて働き方をご相談させてください。</p>\n        </div>\n        <div class=\"recruit_page_2col_2 recruit_page_2col_fr\">\n          <p><img src=\"https://lifecare-mayu.com/wp/wp-content/themes/world/images/recruit/kango_ph1.jpg\" alt=\"\"></p>\n        </div>\n        <!--/recruit_page_wrapper--></div>\n      <div  class=\"recruit_page_wrapper pdgb40\">\n        <div class=\"recruit_page_2col_1 recruit_page_2col_fr\">\n          <h2 class=\"recruit_page_title_s1\">訪問未経験者、ブランクがある方も<br>\n            \u0003安心の支援体制</h2>\n          <ul class=\"recruit_page_list\">\n            <li>まずはしっかりと同行訪問。ご自身の経験に合わせて訪問先を増やしていきます。</li>\n            <li>全国約400事業所を展開する“ケアーズパートナー”の一員として、サポートを受けられます（他事業所研修・いつでも受講できる動画研修など）。</li>\n          </ul>\n        </div>\n        <div class=\"recruit_page_2col_2 recruit_page_2col_fl\">\n          <p><img src=\"https://lifecare-mayu.com/wp/wp-content/themes/world/images/recruit/kango_ph2.jpg\" alt=\"\"></p>\n        </div>\n        <!--/recruit_page_wrapper--></div>\n      <div  class=\"recruit_page_wrapper pdgb40\">\n        <div class=\"recruit_page_2col_1 recruit_page_2col_fl\">\n          <h2 class=\"recruit_page_title_s1\">それぞれの働き方にあった給与体系</h2>\n          <p>正社員でしっかり働きたい方は、訪問手当として300円×訪問時間が別途つきます。パートの方は、週1日、1時間から勤務が可能です。時給は訪問時間中2,200円となります。</p>\n        </div>\n        <div class=\"recruit_page_2col_2 recruit_page_2col_fr\">\n          <p><img src=\"https://lifecare-mayu.com/wp/wp-content/themes/world/images/recruit/kango_ph4.jpg\" alt=\"\"></p>\n        </div>\n        <!--/recruit_page_wrapper--></div>\n      <div  class=\"recruit_page_wrapper\">\n        <div class=\"recruit_page_2col_1 recruit_page_2col_fr\">\n          <h2 class=\"recruit_page_title_s1\">スタッフ同士も連携を密に</h2>\n          <ul class=\"recruit_page_list\">\n            <li>朝のカンファレンスや、訪問後ステーションに戻り、相談をし合って情報を共有、アドバイスを受けることができます。</li>\n            <li>必ず複数人で1人の利用者さまに関わっていきます。 </li>\n            <li>常勤のセラピストがおり、看護と連携したリハビリを提供できます。</li>\n          </ul>\n        </div>\n        <div class=\"recruit_page_2col_2 recruit_page_2col_fl\">\n          <p><img src=\"https://lifecare-mayu.com/wp/wp-content/themes/world/images/recruit/kango_ph3.jpg\" alt=\"\"></p>\n          <!--/recruit_page_content--></div>\n      </div>\n      <!--/recruit_page_wrapper--></div>\n  </section>\n  <section id=\"section3\">\n    <h1 class=\"recruit_page_title_s2\">訪問看護師の1日</h1>\n    <div  class=\"recruit_page_content recruit1_schedule\">\n      <table>\n        <tbody>\n          <tr>\n            <th>9:00</th>\n            <td><h2 class=\"recruit_page_green\">全体朝礼</h2>\n              <p>社員が集まり、朝礼を行います。会社の行動規範を唱和し、連絡や研修報告などを行います。</p></td>\n          </tr>\n          <tr>\n            <th>9:15</th>\n            <td><div class=\"recruit_page_2col_1 recruit_page_2col_fl\">\n                <h2>ミーティング</h2>\n                <p class=\"mgnb10\">スケジュールの確認、利用者さまの状態の共有を行い、訪問に備えます。少しの時間も活用し、カンファレンスをするなど、より良いケアを目指しています。</p>\n                <h2>午前の訪問へ</h2>\n                <p>訪問カバンを持ち、準備万端！！社有車や自転車で出発します。 まずは、血圧・体温などのバイタルチェックを行い、体調のアセスメントをし、それぞれの方に必要な処置等を行います。（午前は2〜3件訪問）</p>\n              </div>\n              <div class=\"recruit_page_2col_2 recruit_page_2col_fr\">\n                <p class=\"mgnb10\"><img src=\"https://lifecare-mayu.com/wp/wp-content/themes/world/images/recruit/kango_day1.jpg\" alt=\"\"></p>\n                <p><img src=\"https://lifecare-mayu.com/wp/wp-content/themes/world/images/recruit/kango_day2.jpg\" alt=\"\"></p>\n              </div></td>\n          </tr>\n          <tr>\n            <th>12:00</th>\n            <td><div class=\"recruit_page_2col_1 recruit_page_2col_fl\">\n                <h2>お昼休憩</h2>\n                <p>ステーションに戻り、ほっとひと息。みんなで同じテーブルでわいわい食事♪仕事のこと、家庭のこと、なんでも相談できる楽しい職場です。</p>\n              </div>\n              <div class=\"recruit_page_2col_2 recruit_page_2col_fr\">\n                <p><img src=\"https://lifecare-mayu.com/wp/wp-content/themes/world/images/recruit/kango_day3.jpg\" alt=\"\"></p>\n              </div></td>\n          </tr>\n          <tr>\n            <th>13:00</th>\n            <td><div class=\"recruit_page_2col_1 recruit_page_2col_fl\">\n                <h2>午後の訪問へ</h2>\n                <p>はじめはお宅にたどり着くまで不安でしたが、慣れてくると、道にも詳しくなり、楽しい道中です。 訪問では、身体に変化がないか、気になることは小さなことでも、主治医や他職種との連携をしっかり行います。（午後は3〜4件訪問）</p>\n              </div>\n              <div class=\"recruit_page_2col_2 recruit_page_2col_fr\">\n                <p><img src=\"https://lifecare-mayu.com/wp/wp-content/themes/world/images/recruit/kango_day4.jpg\" alt=\"\"></p>\n              </div></td>\n          </tr>\n          <tr>\n            <th>17:30</th>\n            <td><h2>訪問終了</h2>\n              <p>ステーションへ戻り、スタッフ同士で情報共有！ここでしっかり相談し、ひとりで悩まないでください。 全員で関わりを持っていきます。一日お疲れ様でした。</p></td>\n          </tr>\n        </tbody>\n      </table>\n      <!--/recruit_page_content--></div>\n  </section>\n  <section id=\"section4\">\n    <div  class=\"recruit_page_content\">\n      <div class=\"recruit_page_memo  mgnb30\">\n        <h1 class=\"recruit_page_title_s2\">先輩看護師からのメッセージ</h1>\n        <div  class=\"recruit_page_wrapper\">\n<div  class=\"recruit2_career_box1\">\n<p class=\"recruit2_career_img\"><img src=\"https://lifecare-mayu.com/wp/wp-content/themes/world/images/recruit/kango_message.jpg\" alt=\"スタッフ写真\"></p>\n<p class=\"recruit2_career_name\">Ｔ・Ｊ<br>訪問看護師</p>\n</div>\n<div  class=\"recruit2_career_box2\">\n<p class=\"recruit_page_title_s4\">ブランクもあり、正直とても不安でした</p>\n<p>以前は、総合病院と小規模デイサービスで勤務をしていました。ブランクもあり、訪問看護で働くことにとても不安がありました。そんな時に説明会に行き、不安な間は一緒に訪問に行くから大丈夫！と丁寧に話してくださり、頑張ってみようと思いました。<br>お一人お一人のお客様とじっくり関わることのできる訪問看護はとても楽しいです。足りない知識や不安もたくさんありますが、相談できる方々がたくさんいるのは心強いです。 　<br>さまざまな疾患をもつ方々と関わるのが訪問看護です。自分の足りない知識や技術をより深め、お客様の気持ちに寄り添った看護師になりたいと思います。</p>\n<dl><dt>私のシフト予定</dt>\n<dd>\n<p>［月］お休み</p>\n<p>［火］9：00～17：30</p>\n<p>［水］お休み</p>\n<p>［木］9：00～17：30</p>\n<p>［金］9：00～17：30</p>\n<p>［土］お休み</p>\n<p>［日］お休み</p></dd>\n</dl>\n</div>\n<!--/recruit_page_wrapper--></div>\n      </div>\n      <div class=\"recruit_page_apply\">\n        <p class=\"recruit_page_apply_button\"><a href=\"https://lifecare-mayu.com/recruitform/#recruitformbox\">ご応募はこちら</a></p>\n        <p class=\"recruit_page_apply_txt\">お電話でもお気軽にご応募ください</p>\n        <p class=\"recruit_page_apply_tel\">フリーダイヤル <a href=\"tel:0120622515\"><span class=\"recruit_page_pink\">0120-622-515</span></a></p>\n        <!-- /recruit_page_apply --></div>\n      <!--/recruit_page_content--></div>\n  </section>\n  <section id=\"section5\">\n    <div  class=\"recruit_page_content\">\n      <h1 class=\"recruit_page_title_s2\">よくある質問</h1>\n      <dl class=\"recruit_page_faq\">\n        <dt>勤務時間ですが、“短時間からOK”とはどのくらいの時間OKですか？</dt>\n        <dd>1日1時間〜ＯＫです。ご自身の都合で、午前中1訪問だけ、という形で働いているスタッフもおります。</dd>\n        <dt>ブランクがあり、ひとりでの訪問も不安です。</dt>\n        <dd>管理者はもちろん、職員同士でお互いをカバーし、レクチャーしていきます。研修会や勉強会にも参加していただけます。</dd>\n        <dt>オンコール対応はありますか？</dt>\n        <dd>はい、24時間対応のステーションでオンコール対応があります。平日（18時〜翌9時）や、土日・祝日に、電話相談や、必要に応じて緊急訪問を行うこともあります。社用の携帯電話は、主に常勤看護師が対応し、交代で持ち帰っています。（緊急訪問の頻度は、非常に少ないです。</dd>\n        <dt>どんな疾患の方が多いですか？</dt>\n        <dd>お客様の8〜9割は65歳以上の高齢者の方です。がん末期の方や、留置カテーテルの必要な方、退院後リハビリが必要な方など、様々な方がいらっしゃいます。経験やスキルに応じて先輩看護師、セラピストが丁寧に指導いたしますので、ご安心ください。</dd>\n      </dl>\n      <!--/recruit_page_content--></div>\n  </section>\n  <section id=\"section6\">\n    <div  class=\"recruit_page_content\">\n      <h1 class=\"recruit_page_title_s3\">募集要項</h1>\n      <div class=\"block__section\">\n\t\t\t<p>◆訪問看護ステーションの管理者候補（正社員）</p>\n<p>&nbsp;</p>\n<p>訪問看護ステーションにて、ご利用者様のお宅を訪問し<br />\n療養のお世話や医療処置等のほか、管理者業務・マネジメントをしていただきます。</p>\n<p>またケアマネージャーとの連携、事業所の広報活動や、<br />\n事例報告会、報告書の作成、スタッフ管理やドクターとの連携等をしていただきます。</p>\n<p>訪問未経験・管理職業務未経験の方も歓迎です！<br />\nはじめは同行訪問でフローを覚えていただきます。<br />\nまた、外部研修へも積極的にご参加いただけ<br />\n（費用補助も一部あり）、スキルアップが望める環境です。</p>\n<p>&nbsp;</p>\n<p>■月給　365,000円〜415,000円</p>\n<p>＜内訳＞<br />\n基本給：250,000円〜300,000円<br />\n役職手当：100,000円<br />\n※訪問手当：300円／時間<br />\n※オンコール手当：1,500円／日（上記はオンコール手当10日分を含みます）</p>\n<p>■勤務時間　9：00〜18：00（祝日を含む月〜金曜日・週休2日）<br />\n※ 訪問は1件あたり60〜90分</p>\n<p>■待遇・福利厚生　各種保険完備 、昇給賞与（7・12月）あり、退職金あり、<br />\nマイカー通勤可、通勤手当あり（月20,000円まで）、ユニフォーム支給</p>\n<p>■正看護師、普通自動車免許（AT限定可）</p>\n<p>＜備考＞管理者のご経験、訪問看護のご経験は不問です。</p>\n<p>ご安心くださいね。会社もバックアップいたします。</p>\n<p>&nbsp;</p>\n<p>◆看護師（正社員）</p>\n<p>&nbsp;</p>\n<p>・健康状態のチェックと助言・食生活、排せつ、<br />\n寝たきり予防のためのケア<br />\n・服薬管理・床ずれ、褥瘡の処置・介護者の相談などを<br />\nお手伝いして頂きます。</p>\n<p>&nbsp;</p>\n<p>■月給　283,000円〜333,000円</p>\n<p>＜内訳＞<br />\n基本給　250,000円〜300,000円<br />\n※訪問手当：300円／時間（上記は月60時間分を含みます・300円×60時間＝18,000円）<br />\n※オンコール手当：1,500円／日（上記はオンコール手当10日分を含みます）</p>\n<p>■勤務時間　9：00〜18：00（祝日を含む月〜金曜日・週休2日）<br />\n※ 訪問は1件あたり60〜90分</p>\n<p>■待遇・福利厚生　各種保険完備 、昇給あり（役職昇給）、賞与（7・12月）あり、退職金あり、<br />\nマイカー通勤可、通勤手当あり（月20,000円まで）、ユニフォーム支給</p>\n<p>■正看護師、普通自動車免許（AT限定可）</p>\n<p>＜備考＞20代～50代のスタッフが活躍中！活気あるステーションです。<br />\n訪問未経験スタートの方も多数活躍中です。<br />\n看護師6名、理学療法士、作業療法士が在籍しています。</p>\n<p>訪問未経験の方も、はじめに同行訪問でフォローをしますので、</p>\n<p>ご安心くださいね。</p>\n<p>&nbsp;</p>\n<p>※※おしごと相談随時開催中※※</p>\n<p>訪問看護ってどんな仕事なんだろう・・・？</p>\n<p>興味があるけれど、まずは話だけ聞いてみたい・・・</p>\n<p>履歴書不要で、お気軽にお越しいただける、相談会を開催しています。</p>\n<p>事前にご連絡頂きましたら、ご都合のいいお時間に個別に対応致します。</p>\n<p>ぜひ、お気軽にお問い合わせください。</p>\n<p>&nbsp;</p>\n<p>こちらもご覧ください。</p>\n<p><a href=\"http://lifecare-recruit.com/\">http://lifecare-recruit.com/</a></p>\n<p>&nbsp;</p>\n<p>問合せ先：0120-622-515　（採用担当まで）</p>\n<p>&nbsp;</p>\n<p>&nbsp;</p>\n      </div>\n      \n            <!--/recruit_page_content--></div>\n  </section>\n  <footer class=\"recruit_page_footer\">\n    <div  class=\"recruit_page_content\">\n      <p class=\"recruit_page_footer_logo pdgb10\"><img src=\"https://lifecare-mayu.com/wp/wp-content/themes/world/images/common/logo.png\" alt=\"株式会社ライフケア\"></p>\n      <p>ケアーズ訪問看護ステーションながのの看護</p>\n      <p class=\"pdgb20\">長野市大字栗田857番地1 BBBビル 302号室</p>\n      <div class=\"recruit_page_apply\">\n        <p class=\"recruit_page_apply_button\"><a href=\"https://lifecare-mayu.com/recruitform/#recruitformbox\">ご応募はこちら</a></p>\n        <p class=\"recruit_page_apply_txt\">お電話でもお気軽にご応募ください</p>\n        <p class=\"recruit_page_apply_tel\">フリーダイヤル <a href=\"tel:0120622515\"><span class=\"recruit_page_pink\">0120-622-515</span></a></p>\n        <!-- /recruit_page_apply --></div>\n    </div>\n  </footer>\n  <p class=\"copyright\">Copyright &#169; Copyright(C) LIFE CARE CO.LTD. ALL RIGHTS RESERVED.</p>\n</div>\n<!-- コンテンツエンド -->\n\n    <script src=\"https://lifecare-mayu.com/wp/wp-content/themes/world/js/vendor.min.js\"></script>\n    <script src=\"https://lifecare-mayu.com/wp/wp-content/themes/world/js/main.js\"></script>\n\t\t\t\t \n\t\t\t\t\t\t\t\t\n\n\n    <p id=\"pagetop\"><a href=\"#\"><i class=\"fa fa-caret-up\" aria-hidden=\"true\"></i></a></p>\n\n\n\n<!-- Instagram Feed JS -->\r\n<script type=\"text/javascript\">\r\nvar sbiajaxurl = \"https://lifecare-mayu.com/wp/wp-admin/admin-ajax.php\";\r\n</script>\r\n<script type='text/javascript'>\n/* <![CDATA[ */\nvar wpcf7 = {\"apiSettings\":{\"root\":\"https:\\/\\/lifecare-mayu.com\\/wp-json\\/contact-form-7\\/v1\",\"namespace\":\"contact-form-7\\/v1\"}};\n/* ]]> */\n</script>\n<script type='text/javascript' src='https://lifecare-mayu.com/wp/wp-content/plugins/contact-form-7/includes/js/scripts.js?ver=5.1.1'></script>\n<script type='text/javascript' src='https://lifecare-mayu.com/wp/wp-includes/js/jquery/jquery.form.min.js?ver=4.2.1'></script>\n<script type='text/javascript' src='https://lifecare-mayu.com/wp/wp-content/plugins/contact-form-7-add-confirm/includes/js/scripts.js?ver=5.1'></script>\n<script type='text/javascript' src='https://lifecare-mayu.com/wp/wp-includes/js/wp-embed.min.js?ver=4.9.29'></script>\n  </body>\n</html>\n\n","finalUrl":"https://lifecare-mayu.com/recruit/recruit1","rendered":false,"_cachedAt":"2026-06-22T20:45:23.482Z"}