\"></use>\n                  </svg>\n                </a>\n                <a href=\"/\" class=\"link link__blank\">-コーポレートサイトトップへ</a>\n              </div>\n            </nav>\n          </div>\n\n          <div class=\"pick-wrap\">\n            <a href=\"/recruit/application/\" class=\"btn btn__type01\">\n              <div class=\"c-title01 c-title01__left c-title01__revers\">\n                <span class=\"en\">Application</span>\n                <span class=\"ja\">募集要項</span>\n              </div>\n              <div class=\"c-btn_arrow02\">\n                <svg class=\"arrow\">\n                  <use xlink:href=\"/recruit/img/svg/sprite-symbol.svg#icon-arrow\"></use>\n                </svg>\n              </div>\n            </a>\n            <a href=\"/recruit/entry/\" class=\"btn btn__type01\">\n              <div class=\"c-title01 c-title01__left c-title01__revers\">\n                <span class=\"en\">Entry</span>\n                <span class=\"ja\">エントリー</span>\n              </div>\n              <div class=\"c-btn_arrow02\">\n                <svg class=\"arrow\">\n                  <use xlink:href=\"/recruit/img/svg/sprite-symbol.svg#icon-arrow\"></use>\n                </svg>\n              </div>\n            </a>\n            <a href=\"/recruit/movie/\" class=\"btn btn__type02 movie\">\n              <div class=\"c-title01 c-title01__revers\">\n                <span class=\"en\">Special Movie</span>\n                <span class=\"ja\">スペシャルムービー</span>\n              </div>\n            </a>\n            <a href=\"/recruit/product/\" class=\"btn btn__type02 scene\">\n              <div class=\"c-title01 c-title01__revers\">\n                <span class=\"en\">Scene of Use</span>\n                <span class=\"ja\">暮らしの中の大鐵</span>\n              </div>\n            </a>\n          </div>\n        </div>\n      </header>\n<main class=\"page_electricfurnace\">\n  <section class=\"c-underMv\">\n    <div class=\"inner\">\n      <div class=\"txt-wrap\">\n        <ul class=\"c-breadcrumbs\">\n          <li class=\"breadcrumbs-item\"><a href=\"/\">TOP</a></li>\n          <li class=\"breadcrumbs-item\"><a href=\"/recruit/\">採用トップ</a></li>\n          <li class=\"breadcrumbs-item\">電気炉について</li>\n        </ul>\n        <h1 class=\"c-title01 c-title01__left\">\n          <span class=\"en\">Electric Furnace</span>\n          <span class=\"ja\">電気炉について</span>\n        </h1>\n      </div>\n      <ul class=\"page-link-list\">\n        <li class=\"page-link-item\">\n          <a href=\"#how\">\n            <span class=\"num\">01</span>鉄の作り方\n            <svg class=\"arrow\">\n              <use xlink:href=\"/recruit/img/svg/sprite-symbol.svg#icon-arrow\"></use>\n            </svg>\n          </a>\n        </li>\n        <li class=\"page-link-item\">\n          <a href=\"#structure\">\n            <span class=\"num\">02</span>電気炉の仕組み\n            <svg class=\"arrow\">\n              <use xlink:href=\"/recruit/img/svg/sprite-symbol.svg#icon-arrow\"></use>\n            </svg>\n          </a>\n        </li>\n      </ul>\n    </div>\n  </section>\n\n  <div class=\"c-side-wrapper\">\n    <aside class=\"sidebar\">\n      <div class=\"dot-wrapper sp\">\n        <span><a href=\"#how\" class=\"dot active\"></a></span>\n        <span><a href=\"#structure\" class=\"dot\"></a></span>\n      </div>\n      <ul data-index=\"0\">\n        <li><a href=\"#how\" class=\"sidebar__item active\">How to Made</a></li>\n        <li><a href=\"#structure\" class=\"sidebar__item\">Structure</a></li>\n      </ul>\n    </aside>\n    <div class=\"main-contents-wrapper\">\n      <section class=\"how\" id=\"how\">\n        <div class=\"inner\">\n          <h2 class=\"c-title02 c-title02__small\">\n            <span class=\"en\">How to Made</span>\n            <span class=\"ja\">電気炉製鋼法による<span class=\"ib\">鉄のつくり方</span></span>\n          </h2>\n          <div class=\"how__img\">\n            <img src=\"/recruit/img/electricfurnace/img-how.webp?20240321\" alt=\"図:電気炉製鋼法による鉄のつくり方\" class=\"pc\">\n            <img src=\"/recruit/img/electricfurnace/sp/img-how.webp?20240321\" alt=\"図:電気炉製鋼法による鉄のつくり方\" class=\"sp\">\n          </div>\n        </div>\n      </section>\n\n      <section class=\"structure\" id=\"structure\">\n        <div class=\"inner\">\n          <h2 class=\"c-title02 c-title02__small\">\n            <span class=\"en\">Structure</span>\n            <span class=\"ja\">電気炉について</span>\n          </h2>\n          <p class=\"txt\">電気炉内に投入したスクラップ（鉄くず）と電気炉上部から差し込まれた黒鉛電極との間に電流を流しアーク（人工的な雷のようなもの）を発生させます。アークは非常に高温のため、その熱と補助燃料（LNG等）のバーナーの熱、酸素を炉内にパイプなどで吹き込み発生する酸化反応熱等を用いてスクラップを溶解し溶鋼を作ります。目的成分になるよう、溶鋼に副原料（炭粉や石灰等）を炉内に加えます。溶鋼上に浮く比重が低い不純物（スラグ等）を除去しつつ精錬を行います。目的成分、温度に到達すると電気炉を傾け耐火物を内側に施工した鉄製の鍋に溶鋼を流し次工程に運搬します。</p>\n          <div class=\"structure__img\">\n            <img src=\"/recruit/img/electricfurnace/img-structure.webp\" alt=\"図:電気炉の図解\" class=\"pc\">\n            <img src=\"/recruit/img/electricfurnace/sp/img-structure.webp\" alt=\"図:電気炉の図解\" class=\"sp\">\n          </div>\n        </div>\n      </section>\n    </div>\n  </div>\n\n  <section class=\"footer-entry\">\n  <div class=\"gsap_target\">\n    <div class=\"gsap_target_wrap en\">OPEN UP THE FUTURE OPEN UP THE FUTURE&nbsp;</div>\n  </div>\n\n  <div class=\"inner\">\n    <div class=\"contents\">\n      <a href=\"/recruit/application/\">\n        <h2 class=\"c-title01 c-title01__left c-title01__revers\">\n          <span class=\"en\">Application</span>\n          <span class=\"ja\">募集要項</span>\n        </h2>\n        <div class=\"c-btn_arrow02\">\n          <svg class=\"arrow\">\n            <use xlink:href=\"/recruit/img/svg/sprite-symbol.svg#icon-arrow\"></use>\n          </svg>\n        </div>\n      </a>\n      <a href=\"/recruit/entry/\">\n        <h2 class=\"c-title01 c-title01__left c-title01__revers\">\n          <span class=\"en\">Entry</span>\n          <span class=\"ja\">エントリー</span>\n        </h2>\n        <div class=\"c-btn_arrow02\">\n          <svg class