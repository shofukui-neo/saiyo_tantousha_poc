 class=\"header-nav__menu-head-en\">RECRUIT</span>\n                            <span class=\"header-nav__menu-head-state\" aria-hidden=\"true\"></span>\n                        </button>\n                        <div id=\"nav-menu-recruit\" class=\"header-nav__menu__collapse accordion-collapse collapse\">\n                            <ul class=\"header-nav__menu__list reset-list reset-parts\">\n                                <li class=\"header-nav__menu__list-item\">\n                                    <a href=\"https://www.kitacom.co.jp/recruit-info\" class=\"header-nav-item\">お知らせ</a>\n                                </li>\n                                <li class=\"header-nav__menu__list-item\">\n                                    <a href=\"https://www.kitacom.co.jp/recruit-info/5874\" class=\"header-nav-item\">合同説明会</a>\n                                </li>\n                                <li class=\"header-nav__menu__list-item\">\n                                    <a href=\"https://www.kitacom.co.jp/recruit-info/5880\" class=\"header-nav-item\">インターンシップ＆キャリア</a>\n                                </li>\n                                <li class=\"header-nav__menu__list-item\">\n                                    <a href=\"https://www.kitacom.co.jp/recruit-info/5826\" class=\"header-nav-item\">採用選考会</a>\n                                </li>\n                                <li class=\"header-nav__menu__list-item\">\n                                    <a href=\"https://www.kitacom.co.jp/recruit-info/6159\" class=\"header-nav-item\">障がいのある方へ</a>\n                                </li>\n                                <li class=\"header-nav__menu__list-item\">\n                                    <a href=\"https://www.kitacom.co.jp/recruit/information/question\" class=\"header-nav-item\">よくある質問</a>\n                                </li>\n                                <li class=\"header-nav__menu__list-item\">\n                                    <a href=\"https://www.kitacom.co.jp/kc_cms/panf2025\" class=\"header-nav-item\" target=\"_blank\">採用パンフレット</a>\n                                </li>\n                            </ul>\n                        </div>\n                    </div>\n                </div>\n              </div>\n              <div class=\"header-nav__sub\">\n                <div class=\"header-nav__requirements\">\n                  <p class=\"header-nav__requirements-head\">募集要項</p>\n                  <ul class=\"header-nav__requirements__menu reset-list reset-parts\">\n                    <li class=\"header-nav__requirements__menu-item\">\n                        <a href=\"https://www.kitacom.co.jp/recruit/information/requirements#recruit1\" class=\"requirements-button\">\n                            <span class=\"requirements-button__image\">\n                                <img src=\"https://www.kitacom.co.jp/kc_cms/wp-content/themes/custom/assets/img/recruit/image_new.jpg\" alt=\"\">\n                            </span>\n                            <span class=\"requirements-button__text\">\n                                <span class=\"requirements-button__text-en\">NEW GRADUATE</span>\n                                <span class=\"requirements-button__text-jp\">新卒採用</span>\n                            </span>\n                        </a>\n                    </li>\n                    <li class=\"header-nav__requirements__menu-item\">\n                        <a href=\"https://www.kitacom.co.jp/recruit/information/requirements#recruit2\" class=\"requirements-button\">\n                            <span class=\"requirements-button__image\">\n                                <img src=\"https://www.kitacom.co.jp/kc_cms/wp-content/themes/custom/assets/img/recruit/image_career.jpg\" alt=\"\">\n                            </span>\n                            <span class=\"requirements-button__text\">\n                                <span class=\"requirements-button__text-en\">MID-CAREER</span>\n                                <span class=\"requirements-button__text-jp\">キャリア採用</span>\n                            </span>\n                        </a>\n                    </li>\n                    <li class=\"header-nav__requirements__menu-item\">\n                        <a href=\"https://www.kitacom.co.jp/recruit/information/requirements#recruit3\" class=\"requirements-button\">\n                            <span class=\"requirements-button__image\">\n                                <img src=\"https://www.kitacom.co.jp/kc_cms/wp-content/themes/custom/assets/img/recruit/image_disabled.jpg\" alt=\"\">\n                            </span>\n                            <span class=\"requirements-button__text\">\n                                <span class=\"requirements-button__text-en\">DISABLED PERSON</span>\n                                <span class=\"requirements-button__text-jp\">障がい者採用</span>\n                            </span>\n                        </a>\n                    </li>\n                  </ul>\n                </div>\n                <div class=\"header-nav__sub-other\">\n                  <a href=\"https://www.kitacom.co.jp/recruit/obog_policy\" class=\"link-button\">\n                      <span class=\"link-button-dot-text\">先輩社員面談</span>\n                      <span class=\"link-button-arrow\"></span>\n                  </a>\n                  <a href=\"https://www.kitacom.co.jp/recruit/entry_policy\" class=\"header-nav-entry\">ENTRY</a>\n                </div>\n              </div>\n              \n            </div>\n\n          </div>\n        </nav>\n\n      </div>\n    </header>\n        <main class=\"main\">\n<article class=\"page-contents\">\n    <header id=\"header-sentinel\" class=\"page-header\">\n        <div class=\"container\">\n            <div class=\"page-header__inner\">\n                <hgroup class=\"page-header__title\">\n                    <p class=\"page-header__title-sub\">RECRUIT INFO</p>\n                    <h1 class=\"page-header__title-main\">障がいのある方へ</h1>\n                </hgroup>\n            </div>\n        </div>\n    </header>\n\n\n    <div class=\"page-body\">\n        <div class=\"container\">\n            <div class=\"c-grid\">\n<div class=\"c-grid__cell c-grid__cell--3\"><img decoding=\"async\" src=\"https://www.kitacom.co.jp/kc_cms/wp-content/uploads/2021/11/staff12-on-235x300.jpg\" alt=\"\"  /></div>\n<div class=\"c-grid__cell c-grid__cell--9\">\n<p>北日本コンピューターサービスを支えているのは、一人ひとりの社員の力です。人物本位の採用を行い、人材をじっくり育て、活躍できる人財に育てたいというのが、当社の人財育成の考え方です。そこに、障がいの有無は関係ありません。<br />\n挑戦と成長の扉は、障がいの有無にかかわらず、すべての社員に等しく開かれています。<br />\n変化を恐れず、笑顔で何事にも積極的に挑戦できる方であれば、当社で必ず力を発揮できますので、あなたの新しい可能性を見つけてみませんか。</p>\n</div>\n</div>\n<h2>◇応募対象者</h2>\n<p>・現在、専門学校、短期大学、大学、大学院に通われている方、もしくは卒業後一年以内の方 ・障がい者手帳をお持ちの方、または申請中の方</p>\n<h2>◇募集職種</h2>\n<p>原則として、総合職としますが、配慮すべき事項により個別判断することがあります。</p>\n<h2>◇勤務条件</h2>\n<p>　原則として、正社員と同じ勤務条件としますが、配慮すべき事項により個別判断することがあります。</p>\n<h2>◇障がいへの配慮</h2>\n<p>　配慮すべき事項は、求職者から個別事情を伺い、当社の対応可否をお互いに確認することとします。実例として、上肢にハンデがある方に対して電話を使いやすくするため、ヘッドセットを購入したことがあります。これが今では“両手が使えて便利”と言うことでコールセンターの必須アイテムとなっています。 選考過程において会社訪問の機会を設け、会社生活を送ることができそうかを確認していただきます。必要に応じて専門家の意見を聞き、改善可否を判断することもあります。</p>\n<h2>◇応募方法</h2>\n<p>　一般公募との違いはありませんが、①障がいの概要、②配慮してほしい内容を当社の採用ページにエントリーする際に「ご要望･ご質問等」欄に記載のうえ応募の手続きを行ってください。</p>\n        </div>\n    </div>\n</article>\n<div class=\"page-breadcrumb\">\n    <div class=\"container\">\n        <nav aria-label=\"現在位置\" role=\"navigation\" class=\"breadcrumb-nav\">\n<ol itemscope=\"itemscope\" itemtype=\"http://schema.org/BreadcrumbList\" class=\"breadcrumb reset-list reset-parts\">\n<li itemprop=\"itemListElement\" itemscope=\"itemscope\" itemtype=\"http://schema.org/ListItem\" class=\"breadcrumb-item\"><a href=\"https://www.kitacom.co.jp/recruit\" itemprop=\"item\"><span itemprop=\"name\">ホーム</span></a></li>\n<li itemprop=\"itemListElement\" itemscope=\"itemscope\" itemtype=\"http://schema.org/ListItem\" class=\"breadcrumb-item\"><a href=\"https://www.kitacom.co.jp/recruit-info\">リクルート</a></li>\n<li itemprop=\"itemListElement\" itemscope=\"itemscope\" itemtype=\"http://schema.org/ListItem\" class=\"breadcrumb-item\">障がいのある方へ</li></ol>\n</nav>\n    </div>\n</div>\n          </main>\n    <footer class=\"footer\">\n      <div class=\"container\">\n        <div class=\"footer-top\">\n            <nav class=\"footer-nav\">\n                <div class=\"footer-nav-col \">\n                    <a href=\"https://www.kitacom.co.jp/recruit\" class=\"footer-nav-item\">トップページ</a>\n                </div>\n                <div class=\"footer-nav-col\">\n                    <p class=\"footer-nav__head\">\n                        <span class=\"footer-nav__head-jp\">会社を知る</span>\n                        <span class=\"footer-nav__head-en\">ABOUT US</span>\n                    </p>\n                    <ul class=\"footer-nav__list reset-list reset-parts\">\n                        <li class=\"footer-nav__list-item\">\n                            <a href=\"https://www.kitacom.co.jp/recruit/about/message\" class=\"footer-nav-item\">代表メッセージ</a>\n                        </li>\n                        <li class=\"footer-nav__list-item\">\n                            <a href=\"https://www.kitacom.co.jp/recruit/about/value\" class=\"footer-nav-item\">経営理念</a>\n                        </li>\n                        <li class=\"footer-nav__list-item\">\n                            <a href=\"https://www.kitacom.co.jp/recruit/about/company\" class=\"footer-nav-item\">会社概要</a>\n                        </li>\n                                                <li class=\"footer-nav__list-item\">\n                            <a href=\"https://www.kitacom.co.jp/software\" class=\"footer-nav-item\" target=\"_blank\">事業概要</a>\n                        </li>\n                        <li class=\"footer-nav__list-item\">\n                            <a href=\"https://www.kitacom.co.jp/recruit/about/office\" class=\"footer-nav-item\">主な営業拠点</a>\n                  