p\"></div>\n    <div class=\"lowerPage recruit\"><!-- topPage or lowerPage begin -->\n                <div class=\"lower__headArea\">\n        \n            \n<header>\n    <div class=\"hamburgerBtn\">\n        <div class=\"humburgerLine\">\n            <span class=\"top\"></span>\n            <span class=\"middle\"></span>\n            <span class=\"bottom\"></span>\n        </div>\n    </div>\n    <h1 class=\"headLogo\">\n        <a href=\"/\"><img src=\"https://www.unitec.jp/cms/wp-content/themes/unitec/assets/img/common/logo_unitec_wh.svg\" alt=\"株式会社ユニテック\"></a>\n    </h1>\n    <div class=\"headMenu\">\n        <nav>\n            <ul class=\"navList\">\n                <li class=\"navList__item \">\n                    <a href=\"/\">TOP</a>\n                </li>\n                <li class=\"navList__item \">\n                    <a href=\"/service/\">私たちの強み</a>\n                </li>\n                <li class=\"navList__item parentLink \">\n                    <span>サービス内容</span>\n                    <button class=\"navList__toggle\"></button>\n                    <ul class=\"childList\">\n                        <li class=\"\"><a href=\"/service/solution/\">システムインテグレーション</a></li>\n                        <li class=\"\"><a href=\"/service/ses-haken/\">SES・技術者派遣</a></li>\n                        <li class=\"\"><a href=\"/service/package/\">パッケージ販売・クラウドサービス</a></li>\n                    </ul>\n                </li>\n                <li class=\"navList__item parentLink \">\n                    <span>会社案内</span>\n                    <button class=\"navList__toggle\"></button>\n                    <ul class=\"childList\">\n                        <li class=\"\"><a href=\"/company/\">会社案内TOP</a></li>\n                        <li class=\"\"><a href=\"/company/company_profile/\">会社概要</a></li>\n                        <li class=\"\"><a href=\"/company/corporate_philosophy/\">経営理念・企業理念</a></li>\n                        <li class=\"\"><a href=\"/company/aisatsu/\">社長あいさつ</a></li>\n                        <li class=\"\"><a href=\"/company/certification/\">認証取得</a></li>\n                        <li class=\"\"><a href=\"/company/affiliate/\">加盟団体</a></li>\n                        <li class=\"\"><a href=\"/company/company_profile/#accessmap\">アクセスマップ</a></li>\n                    </ul>\n                </li>\n                <li class=\"navList__item parentLink current\">\n                    <span>リクルート</span>\n                    <button class=\"navList__toggle\"></button>\n                    <ul class=\"childList\">\n                        <li class=\"current\"><a href=\"/recruit/\">リクルートTOP</a></li>\n                        <li class=\"\"><a href=\"/recruit/company/\">会社を知る</a></li>\n                        <li class=\"\"><a href=\"/recruit/work/\">仕事を知る</a></li>\n                        <li class=\"\"><a href=\"/recruit/interview/\">人を知る</a></li>\n                        <li class=\"\"><a href=\"/recruit/job-description/\">募集要項</a></li>\n                        <li class=\"\"><a href=\"/recruit/aisatsu/\">社長あいさつ</a></li>\n                    </ul>\n                </li>\n                <li class=\"basicBtn -icon mb0\">\n                    <a href=\"/contact/\">\n                        <img src=\"https://www.unitec.jp/cms/wp-content/themes/unitec/assets/img/common/icon_mail.svg\" alt=\"お問い合わせ\"><span>お問い合わせ</span>\n                    </a>\n                </li>\n            </ul>\n        </nav>\n    </div>\n</header>\n                        <div class=\"pageHead\">\n                                    <h1>Recruit</h1>\n                                                    <p class=\"pageSubTtl\">リクルート</p>\n                            </div>\n            \n                </div>\n        \n<main>\n    <div class=\"lowerCont recruitCont\">\n        <section id=\"recruit\">\n            <div class=\"sContainer\">\n                <div class=\"inner\">\n                    <div class=\"aisatsuTtl\">\n                        <h2 class=\"-center\">未来をつくる側、<br class=\"nopc\">そろそろ行こう。</h2>\n                    </div>\n                    <p class=\"-center\">テクノロジーの進化が<br class=\"nopc\">加速する今、私たちは常に<br class=\"nopc\">“次の可能性”を追いかけています。<br>\n                        その中心にあるのは、最新の技術ではなく、<br class=\"nopc\">一人ひとりの「人」。<br>\n                        社員の発想や行動こそが、新しい価値を<br class=\"nopc\">生み出す原動力だと信じています。<br>\n                        変化を恐れず、挑戦を楽しみながら、<br class=\"nopc\">より良い未来を自らの手で形にしていく。<br>\n                        そして「ITで世界を前に進める」という<br class=\"nopc\">想いをお伝えします。<br>\n                        あなたの可能性も、<br class=\"nopc\">ここから大きく広がっていく——<br>\n                        自分らしく働きながら、<br class=\"nopc\">その一歩を踏み出せる出会いになることを、<br class=\"nopc\">私たちは本気で願っています。</p>\n                    <div class=\"stagger-fade linkArea\">\n                        <div class=\"item\">\n                            <a href=\"/recruit/company/\" class=\"recruitLink\">\n                                <h3 class=\"linkTtl -linkTtl01\">会社を知る</h3>\n                                <span class=\"circleArrow\"></span>\n                            </a>\n                        </div>\n                        <div class=\"item\">\n                            <a href=\"/recruit/work/\" class=\"recruitLink\">\n                                <h3 class=\"linkTtl -linkTtl02\">仕事を知る</h3>\n                                <span class=\"circleArrow\"></span>\n                            </a>\n                        </div>\n                        <div class=\"item\">\n                            <a href=\"/recruit/interview/\" class=\"recruitLink\">\n                                <h3 class=\"linkTtl -linkTtl03\">人を知る</h3>\n                                <span class=\"circleArrow\"></span>\n                            </a>\n                        </div>\n                        <div class=\"item\">\n                            <a href=\"/recruit/aisatsu/\" class=\"recruitLink\">\n                                <h3 class=\"linkTtl -linkTtl04\">社長あいさつ</h3>\n                                <span class=\"circleArrow\"></span>\n                            </a>\n                        </div>\n                        <div class=\"item -wide\">\n                            <a href=\"/recruit/job-description/\" class=\"recruitLink\">\n                                <h3 class=\"linkTtl -linkTtl05\">募集要項</h3>\n                                <span class=\"circleArrow\"></span>\n                            </a>\n                        </div>\n                    </div>\n\n                    <div class=\"stagger-fade pointArea\">\n                        <h2 class=\"headLv2_01 mt0\"><span class=\"en\">POINT</span><br>\\ 仕事の魅力・成長ポイント /</h2>\n                        <div class=\"item\">\n                            <div class=\"imageArea\">\n                                <img src=\"https://www.unitec.jp/cms/wp-content/themes/unitec/assets/img/recruit/top/point_img01.png?20260302\" alt=\"\">\n                            </div>\n                            <div class=\"textArea\">\n                                <h3 class=\"headLv3_01 -recruitTop\">ITで、課題を\"成果\"に<br class=\"tablet\">変える仕事</h3>\n                                <p>自分の仕事が誰かの役に立ち、社会を少し前に進めている――そんな実感を、日々の仕事の中で感じることができます。</p>\n                            </div>\n                        </div>\n                        <div class=\"item\">\n                            <div class=\"imageArea\">\n                                <img src=\"https://www.unitec.jp/cms/wp-content/themes/unitec/assets/img/recruit/top/point_img02.png\" alt=\"\">\n                            </div>\n                            <div class=\"textArea\">\n                                <h3 class=\"headLv3_01 -recruitTop\">挑戦できる環境が、<br class=\"tablet\">成長を加速させる</h3>\n                                <p>決まった仕事だけをこなすのではなく、「やってみたい」という気持ちを後押しする環境があります。<br>挑戦するたびに、視野もスキルも広がっていきます。</p>\n                            </div>\n                        </div>\n                        <div class=\"item\">\n                            <div class=\"imageArea\">\n                                <img src=\"https://www.unitec.jp/cms/wp-content/themes/unitec/assets/img/recruit/top/point_img03.png\" alt=\"\">\n                            </div>\n                            <div class=\"textArea\">\n                                <h3 class=\"headLv3_01 -recruitTop\">仲間と一緒だから<br class=\"tablet\">乗り越えられる</h3>\n                                <p>一人で完結する仕事はありません。<br>先輩や仲間と意見を出し合い、難しい課題を乗り越えたときの達成感は格別です。チームで成長する面白さを実感できます。</p>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </section>\n    </div>\n    <section id=\"contact\" class=\"mt0 stagger-fade\">\n    <div class=\"mContainer\">\n        <div class=\"inner\">\n            <div class=\"top_contactBox\">\n                <h2 class=\"bigTtl\">Entry</h2>\n                <div class=\"flexBox rv mb0\">\n                    <div class=\"txtArea\">\n                        <h3>「今、できるか」より<br>「学び続けられるか」を大切にしています</h3>\n                        <p>これからのキャリアを築く第一歩を、当社で踏み出してみませんか。<br>学びと挑戦の機会を通じて、ともに成長していける方のエントリーをお待ちしています。</p>\n                        <div class=\"contactBtn -sp\">\n                            <a href=\"/recruit/entry/\">\n                                <img src=\"https://www.unitec.jp/cms/wp-content/themes/unitec/assets/img/common/icon_mail.svg\" alt=\"エントリーフォーム\">\n                                <span>エントリーフォーム</span>\n                            </a>\n                        </div>\n                    </div>\n                    <div class=\"imgArea\">\n                        <img src=\"https://www.unitec.jp/cms/wp-content/themes/unitec/assets/img/common/img_entry.png\" width=\"171\" height=\"221\" alt=\"「今、できるか」より「学び続けられるか」を大切にしています\">\n                    </div>\n                </div>\n                <div class=\"contactBtn\">\n                    <a href=\"/recruit/entry/\">\n                        <img src=\"https://www.unitec.jp/cms/wp-content/themes/unitec/assets/img/common/icon_mail.svg\" alt=\"エントリーフォーム\">\n                        <span>エントリーフォーム</span>\n                    </a>\n                </div>\n            </div>\n        </div>\n    </div>\n</section></main>\n\n\n</div><!-- topPage or lowerPage end -->\n\n<footer>\n    <div class=\"scrollBtn\">\n        <a href=\"#top\"><img src=\"https://www.unitec.jp/cms/wp-content/themes/unitec/assets/img/common/btn_top.png\" alt=\"\"></a>\n    </div>\n    \n    <div class=\"footTop\">\n        <div class=\"inner\">\n            <div class=\"footCompany\">\n                <div class=\"logo\">\n                    <a href=\"/\"><img src=\"https://www.unitec.jp/cms/wp-content/themes/unitec/assets/img/common/logo_unitec_wh.svg\" alt=\"株式会社ユニテック\"></a>\n                </div>\n                <div class=\"footCompany__address\">\n                    <div class=\"textArea\">\n                        <h5>株式会社ユニテック</h5>\n                        <p>〒420-0911 静岡県静岡市葵区瀬名1丁目18番33号</p>\n                    </div>\n                </div>\n            </div>\n            <div class=\"flexBox\">\n                <div class=\"ftSitemap\">\n                    <ul class=\"ftSitemap__item nosp\">\n                        <li class=\"parentLink\"><a href=\"/\">TOP</a></li>\n                        <li class=\"parentLink\">\n                            <a href=\"/service/\">私たちの強み</a>\n                            <ul class=\"childList\" style=\"margin-top: 4rem;\">\n                                <li class=\"noLink\"><p>サービス内容</p></li>\n                                <li><a href=\"/service/solution/\">システムインテグレーション</a></li>\n                                <li><a href=\"/service/ses-haken/\">SES・技術者派遣</a></li>\n                                <li><a href=\"/service/package/\">パッケージ販売・クラウドサービス</a></li>\n                            </ul>\n                        </li>\n                    </ul>\n                    <ul class=\"ftSitemap