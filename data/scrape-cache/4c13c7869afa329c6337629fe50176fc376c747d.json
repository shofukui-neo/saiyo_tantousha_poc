body>\n<div id=\"wrapper\"><!-- wrapper START -->\n<!-- ///////// HEADER START //////////////////////////////////////////////////////////////////// -->\n<header id=\"h_area\"><!-- ヘッダ枠100%▼ -->\n  <div class=\"h_nav_wrapper\">\n    <div class=\"pc\">\n      <h1><a href=\"/\"><img src=\"https://sb-watanabe.jp/wp/wp-content/themes/sb-watanabe/images/logo.png\" alt=\"総合美装ワタナベ\"></a></h1>\n      <div class=\"contact_button\"><a href=\"https://sb-watanabe.jp/contact\" title=\"お問い合わせ\"><img src=\"https://sb-watanabe.jp/wp/wp-content/themes/sb-watanabe/images/button_contact.png\" alt=\"お問い合わせ\"></a></div>\n      <div class=\"nav_wrapper\">\n      <nav class=\"gnav pc\">\n        <ul>\n          <li><a href=\"https://sb-watanabe.jp/\" title=\"HOME\">HOME</a></li>\n          <li><a href=\"https://sb-watanabe.jp/industrialwaste\" title=\"産業廃棄物・一般廃棄物\">産業廃棄物・一般廃棄物</a></li>\n          <li><a href=\"https://sb-watanabe.jp/building\" title=\"清掃\">清掃</a>\n          </li>\n          <li><a href=\"https://sb-watanabe.jp/reform\" title=\"リフォーム・解体\">リフォーム・解体</a></li>\n          <li><a href=\"https://sb-watanabe.jp/company\" title=\"企業情報\">企業情報</a></li>\n          <li><a href=\"https://sb-watanabe.jp/recruit\" title=\"採用情報\">採用情報</a></li>\n        </ul>\n      </nav>\n    </div>\n    </div>\n    <div class=\"inner clearfix mb mbmenu\">\n      <h1><a href=\"/\"><img src=\"https://sb-watanabe.jp/wp/wp-content/themes/sb-watanabe/images/logo.png\" alt=\"総合美装ワタナベ\"></a></h1>\n      <script>\n        $(function(){\n        \t$('#nav_toggle').click(function(){\n        \t$(\"header\").toggleClass('open');\n        \t$(\".mbnav\").slideToggle(500);\n        \t});\n        \t});\n      </script>\n        <div id=\"nav_toggle\">\n          <div>\n          <span></span>\n          <span></span>\n          <span></span>\n          </div>\n        </div>\n        <nav class=\"mbnav\">\n          <ul>\n            <li><a href=\"https://sb-watanabe.jp/\" title=\"HOME\">HOME</a></li>\n          <li><a href=\"https://sb-watanabe.jp/industrialwaste\" title=\"産業廃棄物・一般廃棄物\">産業廃棄物・一般廃棄物</a></li>\n          <li><a href=\"https://sb-watanabe.jp/building\" title=\"清掃\">清掃</a>\n          </li>\n          <li><a href=\"https://sb-watanabe.jp/reform\" title=\"リフォーム・解体\">リフォーム・解体</a></li>\n          <li><a href=\"https://sb-watanabe.jp/company\" title=\"企業情報\">企業情報</a></li>\n          <li><a href=\"https://sb-watanabe.jp/recruit\" title=\"採用情報\">採用情報</a></li>\n          <li><a href=\"https://sb-watanabe.jp/news\" title=\"お問い合わせ\">お知らせ</a></li>\n          <li><a href=\"https://sb-watanabe.jp/contact\" title=\"お問い合わせ\">お問い合わせ</a></li>\n          </ul>\n        </nav>\n    </div>\n  </div>\n\n      <div class=\"headbg02\">\n      <h2 class=\"title_style01\">採用情報</h2>\n    </div>\n    <p class=\"breadcrumb\"><a href=\"https://sb-watanabe.jp\" title=\"TOP\" class=\"breadcrumb01\">TOP</a>&nbsp;<span class=\"breadcrumb02\">></span>&nbsp;<span class=\"breadcrumb03\">採用情報</span></p>\n\n  </header>\n\n<div class=\"cnt_wp\"><!-- コンテンツ枠100%▼ -->\n  <article>        <div class=\"wrap04\">\n      \t<div class=\"lead_box03_1\">\n<p class=\"font_style01\">ビル清掃スタッフ大募集！！</p>\n</div>\n<div class=\"txt_box\">\n<h2 class=\"title_style02 alignC\">募集要項</h2>\n<p>当社の求人に興味を持っていただき誠にありがとうございます。<br />\n現在、「建築クリーニング」「クリーンスタッフ」「特別清掃スタッフ」を募集しております。<br />\n募集要項に関するご質問、ご応募は電話 054-346-3103（平日8:00～17:00）　採用担当：原（ハラ）までお気軽にお問い合わせください。</p>\n<div class=\"mt50\">\n<p class=\"title_style05\">① 日常クリーンスタッフ</p>\n<table class=\"table_style03\">\n<tbody>\n<tr>\n<th>勤務地</th>\n<td>県内各地(お問合せください ）</td>\n</tr>\n<tr>\n<th>時間</th>\n<td>勤務地による（お問合せください）</td>\n</tr>\n<tr>\n<th>給与</th>\n<td>時給1,100円～1,200円</td>\n</tr>\n<tr>\n<th>仕事内容</th>\n<td>日常清掃</td>\n</tr>\n<tr>\n<th>休日</th>\n<td>勤務地による</td>\n</tr>\n</tbody>\n</table>\n</div>\n<div class=\"mt50\">\n<p class=\"title_style05\">② 運転手</p>\n<table class=\"table_style03\">\n<tbody>\n<tr>\n<th>勤務地</th>\n<td>清水区長崎</td>\n</tr>\n<tr>\n<th>時間</th>\n<td>8:00～17:00 （時間外労働あり)</td>\n</tr>\n<tr>\n<th>給与</th>\n<td>日給9,000円～11,000円</td>\n</tr>\n<tr>\n<th>仕事内容</th>\n<td>産業廃棄物の収集運搬</td>\n</tr>\n<tr>\n<th>休日</th>\n<td>113日　※当社暦による</td>\n</tr>\n</tbody>\n</table>\n</div>\n<div class=\"mt50\">\n<p class=\"title_style05\">③ 重機オペレーター</p>\n<table class=\"table_style03\">\n<tbody>\n<tr>\n<th>勤務地</th>\n<td>清水区長崎</td>\n</tr>\n<tr>\n<th>時間</th>\n<td>8:00～17:00（時間外労働あり）</td>\n</tr>\n<tr>\n<th>給与</th>\n<td>日給9,000円～12,000円</td>\n</tr>\n<tr>\n<th>仕事内容</th>\n<td>重機等による収集物の破砕、選別、仕分け等　時間外労働あり</td>\n</tr>\n<tr>\n<th>休日</th>\n<td>113日　※当社暦による</td>\n</tr>\n</tbody>\n</table>\n</div>\n<div class=\"mt50\">\n<p class=\"title_style05\">全職種共通項目</p>\n<table class=\"table_style01\">\n<tbody>\n<tr>\n<th>資格</th>\n<td>18～55歳まで　経験者優遇</td>\n</tr>\n<tr>\n<th>待遇</th>\n<td>社会保険完備・昇給年1回・賞与年2回・有給休暇･制服貸与･交通費支給・残業手当</td>\n</tr>\n</tbody>\n</table>\n</div>\n</div>\n      </div>\n  </article>\n  <script>\n        $(function(){\n          // #で始まるリンクをクリックしたら実行されます\n          $('a[href^=\"#\"]').click(function() {\n            // スクロールの速度\n            var speed = 800; // ミリ秒で記述\n            var href= $(this).attr(\"href\");\n            var target = $(href == \"#\" || href == \"\" ? 'html' : href);\n            var position = target.offset().top;\n            $('body,html').animate({scrollTop:position}, speed, 'swing');\n            return false;\n          });\n        });\n  </script>\n  <p id=\"p_top_area\"><a href=\"#h_area\"><img src=\"https://sb-watanabe.jp/wp/wp-content/themes/sb-watanabe/images/top_btn.png\" alt=\"ページトップ\"/></a></p>\n  <p id=\"phone_button\" class=\"mb\">\n    <a href=\"tel:+81-54-346-3103\">\n      <img src=\"https://sb-watanabe.jp/wp/wp-content/themes/sb-watanabe/images/phone_button.png\" alt=\"054-346-3103\"/>\n    </a>\n  </p>\n</div>\n<!-- コンテンツ枠100%▲ -->\n<!-- ///////// CONTENTS END //////////////////////////////////////////////////////////////////// -->\n\n\n<!-- ///////// FOOTER START //////////////////////////////////////////////////////////////////// -->\n<div 