s);}\n  gtag('js', new Date());\n  gtag('config', 'UA-2097811-1');\n  gtag('config', 'G-0BNP76Q4Q7');\n</script>\n</head>\n\n<body>\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=AW-734422123\"></script> \n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n  gtag('config', 'AW-734422123');\n</script>\n<div class=\"openbtn\"><span></span><span></span><span></span></div>\n<nav id=\"g-nav\">\n        <div id=\"g-nav-list\">\n                <ul>\n                        <li><a href=\"../index.html#01_business\" title=\"事業を知る\">事業を知る</a></li>\n                        <li><a href=\"../index.html#02_member\" title=\"職種と人を知る\">職種と人を知る</a></li>\n                        <li><a href=\"../index.html#03_workspace\" title=\"環境・待遇を知る\">環境・待遇を知る</a></li>\n                        <li><a href=\"../index.html#04_information\" title=\"新卒採用\">新卒採用</a></li>\n                        <li><a href=\"../index.html#04_information\" title=\"キャリア採用\">キャリア採用</a></li>\n                </ul>\n        </div>\n</nav>\n<nav class=\"pc\">\n        <div class=\"inner\">\n                <div class=\"logo\"><a href=\"../index.html\"><img src=\"../images/index/logo.svg\" alt=\"ソリマチ株式会社採用情報\"></a></div>\n                <div class=\"area\">\n                        <ul>\n                                <li><a href=\"service.html\" title=\"事業を知る\" class=\"select\">事業を知る</a></li>\n                                <li><a href=\"../member/movie.html\" title=\"職種と人を知る\">職種と人を知る</a></li>\n                                <li><a href=\"../workspace/office.html\" title=\"環境・待遇を知る\">環境・待遇を知る</a></li>\n                                <li><a href=\"../recruit/newgraduate.html\" title=\"新卒採用\">新卒採用</a></li>\n                                <li><a href=\"../recruit/career.html\" title=\"キャリア採用\">キャリア採用</a></li>\n                        </ul>\n                </div>\n        </div>\n</nav>\n<div id=\"contents\">\n        <div class=\"inner\">\n                <div class=\"side side--sticky\">\n                        <h1>事業を知る</h1>\n                        <ul>\n                                <li><a href=\"service.html\" title=\"01 ソリマチ製品の紹介\">01 ソリマチ製品の紹介</a></li>\n                                <li><a href=\"industry.html\" title=\"02 会計ソフト業界を知る\">02 会計ソフト業界を知る</a></li>\n                                <li><a href=\"message.html\" title=\"03 社長からメッセージ\">03 社長からメッセージ</a></li>\n                                <li><a href=\"sorimachi_group.html\" title=\"04 ソリマチテックグループの紹介\" class=\"select\">04 ソリマチテックグループの紹介</a></li>\n                                <li><a href=\"family.html\" title=\"05 ご家族の皆様へ\">05 ご家族の皆様へ</a></li>\n                        </ul>\n                </div>\n                <div class=\"area\">\n                        <h1>Sorimachi group</h1>\n                        <h2><span>04</span>ソリマチテックグループの紹介</h2>\n                        <img src=\"../images/business/img_08.jpg\" width=\"700\"alt=\"\" class=\"img_kadoR marT30 marB30\"/>\n                        <p>1972年10月に設立したソリマチ株式会社は「会計ソフトメーカー」で、会計王をはじめとした王シリーズから農家さん向けに特化した農業簿記まで幅広い事業を展開しています。</p>\n                        <p>もともと、長岡花火で有名な新潟県長岡市にあった反町会計事務所が母体となったグループで、創業は70年以上を迎え、現在18社の会社が所属しています。自社製品を扱うため、作り手のエンジニアはプライドと責任を持って業務にあたります。お客様からヒアリングを行い、親身になって相談にのる営業担当は会社とお客様を繋ぐ架け橋です。誰かの仕事を誰かが支え合いながらここまで続けてくることができました。</p>\n                        <h3 class=\"heading04\">最新テクノロジーを使って産業応援をするテーマ別部門</h3>\n                        <img src=\"../images/business/img_24.png\" width=\"700\"alt=\"\" class=\"img_kadoR marT30 marB30\"/>\n                        <div class=\"interview_wrap marB30\">\n                                <div class=\"interview\">\n                                        <div class=\"balloon-interview\">アカウンテック</div>\n                                        <p>信念と最新テクノロジーをもって会計に新たな価値を吹き込み産業応援する会社</p>\n                                </div>\n                                <div class=\"interview\">\n                                        <div class=\"balloon-interview\">アグリテック</div>\n                                        <p>最新テクノロジーを使って農家を中心とするサステナブルな農業を応援する会社</p>\n                                </div>\n                                <div class=\"interview\">\n                                        <div class=\"balloon-interview\">エリアテック</div>\n                                        <p>最新テクノロジーと持てる強みを駆使して地域の人を幸せにする会社</p>\n                                </div>\n                                <div class=\"interview\">\n                                        <div class=\"balloon-interview\">フィンテック</div>\n                                        <p>最新テクノロジーですべてのスモールビジネスに新しい出会いを創造する産業別社会基盤を提供する会社</p>\n                                </div>\n                                <div class=\"interview\">\n                                        <div class=\"balloon-interview\">ヒューマンテック</div>\n                                        <p>最新テクノロジーを使って流通小売り業に関わるすべての人を幸せにする会社</p>\n                                </div>\n                        </div>\n                        <h3 class=\"heading04\">イメージキャラクターは松岡修造さん！ </h3>\n                        <img src=\"../images/business/img_09.jpg\" width=\"700\" class=\"img_kadoR marT30 marB30\"/>\n                        <p>2007年からずっと松岡修造さんにイメージキャラクターを務めていただいております。パッケージやHPなどに登場いただいていて、お客様一人一人に熱く親身になって応援していく我々のイメージにぴったりだと感じております。</p>\n                        <p>テレビCMにも登場いただき、長くソリマチを支えていただいております。</p>\n                        <div class=\"flow_wrap\">\n                                <div class=\"flow\">\n                                        <h4>社長と熱血対談</h4>\n                                        <a href=\"https://www.youtube.com/watch?v=01SfPSBMLlE\" target=\"_blank\"><img src=\"../images/business/img_15.jpg\" width=\"180\" alt=\"\"/></a> </div>\n                                <div class=\"flow\">\n                                        <h4>テレビCM2017</h4>\n                                        <a href=\"https://www.youtube.com/watch?v=7skm4PcsoH8\" target=\"_blank\"><img src=\"../images/business/img_17.jpg\" width=\"180\" alt=\"\"/></a> </div>\n                                <div class=\"flow\">\n                                        <h4>テレビCM2023</h4>\n                                        <a href=\"https://www.youtube.com/watch?v=dGihEiMJ9K0\" target=\"_blank\"><img src=\"../images/business/img_16.jpg\" width=\"180\" alt=\"\"/></a> </div>\n                        </div>\n                        <ol class=\"pagination\">\n                                <li><a href=\"service.html\">1</a></li>\n                                <li><a href=\"industry.html\">2</a></li>\n                                <li><a href=\"message.html\">3</a></li>\n                                <li class=\"current\"><a href=\"sorimachi_group.html\">4</a></li>\n                                <li><a href=\"family.html\">5</a></li>\n                                <li class=\"next\"><a href=\"../member/movie.html\">></a></li>\n                        </ol>\n                </div>\n        </div>\n</div>\n<footer>\n        <div class=\"inner\"> &copy; Copyright Sorimachi Co.,Ltd. All rights reserved. </div>\n</footer>\n<div class=\"pagetop\"><a href=\"#\">▲</a></div>\n</body>\n</html>","finalUrl":"https://sorimachi.co.jp/about/recruit/business/sorimachi_group.html","rendered":false,"_cachedAt":"2026-06-23T23:07:07.741Z"}