</div>\n                  <dl class=\"shareLink\">\n                    <dt class=\"shareLinkHead\">SHARE:</dt>\n                    <dd class=\"shareLinkContent\">\n                      \n                      <a href=\"https://www.linkedin.com/shareArticle?mini=true&url=https%3A%2F%2Fwww.junkosha.com%2Fjp%2Fnews%2F70&title=%E3%82%AD%E3%83%A3%E3%83%AA%E3%82%A2%E6%8E%A1%E7%94%A8%E3%81%AF%E9%9A%8F%E6%99%82%E8%A1%8C%E3%81%A3%E3%81%A6%E3%81%8A%E3%82%8A%E3%81%BE%E3%81%99%E3%80%82%E3%82%A8%E3%83%BC%E3%82%B8%E3%82%A7%E3%83%B3%E3%83%88%E7%B5%8C%E7%94%B1%E3%81%A7%E3%81%94%E5%BF%9C%E5%8B%9F%E3%81%8F%E3%81%A0%E3%81%95%E3%81%84%E3%80%82\"\n                        target=\"_blank\" rel=\"noopener noreferrer\" data-effect=\"fade\">\n                        <img src=\"/assets/img/defaults/pc/news/btn_Linkedin.png\" width=\"32\" height=\"32\"\n                          alt=\"LinkedIn\">\n                      </a>\n                      \n                      <a href=\"http://twitter.com/share?url=https%3A%2F%2Fwww.junkosha.com%2Fjp%2Fnews%2F70&text=%E3%82%AD%E3%83%A3%E3%83%AA%E3%82%A2%E6%8E%A1%E7%94%A8%E3%81%AF%E9%9A%8F%E6%99%82%E8%A1%8C%E3%81%A3%E3%81%A6%E3%81%8A%E3%82%8A%E3%81%BE%E3%81%99%E3%80%82%E3%82%A8%E3%83%BC%E3%82%B8%E3%82%A7%E3%83%B3%E3%83%88%E7%B5%8C%E7%94%B1%E3%81%A7%E3%81%94%E5%BF%9C%E5%8B%9F%E3%81%8F%E3%81%A0%E3%81%95%E3%81%84%E3%80%82\"\n                        target=\"_blank\" rel=\"noopener noreferrer\" data-effect=\"fade\">\n                        <img src=\"/assets/img/defaults/pc/news/btn_X.png\" width=\"32\" height=\"32\" alt=\"X\">\n                      </a>\n                    </dd>\n                  </dl>\n                </div>\n\n                <section class=\"articleNewsDatailContent\">\n\n                  \n                  <h3 class=\"articleNewsDatailContentTitle titleSectionPrimary\">キャリア採用は随時行っております。エージェント経由でご応募ください。</h3>\n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n  \n    \n    \n    \n          <p class=\"boxNewsDetailText\">\n        高い専門性・経験やマネジメント力を有する仲間を中心に、募集しています。<br />\n<br />\n職種を問わず、アイデアを発信しながら様々な業務にチャレンジしたい、キャリアの職域を広げながら成長を続けたい、<br />\nグローバルに活躍したい等、会社と共に成長していける方を歓迎します。\n      </p>\n    \n    \n    \n    \n    \n    \n    \n    \n    \n  \n                </section><!-- End [section class=\"articleNewsDatailContent\"] -->\n\n                \n              </article><!-- End [section class=\"articleNewsDatail\"] -->\n\n            </div><!-- End [div class=\"blockNewsDetailContent\"] -->\n\n\n            \n            <div class=\"blockNewsDetailSub\">\n  \n  <news-latest-list url-json=\"/jp/news/json/recruit\"\n    block-title=\"採用\" more-text=\"More\">\n  </news-latest-list>\n</div><!-- End [div class=\"blockNewsDetailSub\"] -->\n\n          </div><!-- End [div class=\"blockNewsDetailInner\"] -->\n        </div><!-- End [div class=\"l-inner\"] -->\n      </div><!-- End [div class=\"blockNewsDetail\"] -->\n\n    </div><!-- End [div id=\"main\" class=\"l-main\"] -->\n  </div><!-- End [div id=\"contents\" class=\"l-contents\"] -->\n\n\n    \n    <div class=\"pagetop\" id=\"js-pagetop\">\n  <a href=\"#top\" class=\"btn ghost circle onlyIcon\" data-scroll>\n    <icon :path=\"svgIcon\" type=\"arrow\" option=\"colorMain arrowUp\"></icon><span class=\"text\">Page top</span>\n  </a>\n</div>\n\n<footer id=\"footer\" class=\"l-footer\">\n\n  <div class=\"blockFooter01\">\n    <div class=\"l-inner\">\n      <div class=\"boxInquiryFooter\">\n        <div class=\"boxInquiryFooterItem\">\n          <p class=\"textMain sansEn\">Become our partner.</p>\n          <p class=\"textSub\">潤工社の製品やソリューションについてお気軽にご相談ください。</p>\n        </div>\n        <p class=\"boxInquiryFooterItem\"><a href=\"https://market.junkosha.com/jp/contact\"\n            target=\"_blank\" class=\"btn colorSub round hasIcon\">お問い合わせ<icon :path=\"svgIcon\" type=\"mail\"\n              option=\"white posRight\"></icon></a></p>\n      </div><!-- End [div class=\"boxInquiryFooter\"] -->\n    </div><!-- End [div class