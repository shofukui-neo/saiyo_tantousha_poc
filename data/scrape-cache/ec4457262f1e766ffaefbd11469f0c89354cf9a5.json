{"url":"http://www.r-ehm.co.jp/","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n\n<head>\n  <meta charset=\"utf-8\">\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n  <title>トヨタレンタリース西四国</title>\n  <meta name=\"description\" content=\"よいクルマ、よいサービス。愛媛県と高知県のレンタカー予約はトヨタレンタリース西四国へ！\">\n  <meta name=\"title\" content=\"トヨタレンタリース西四国\">\n  <meta content=\"IE=edge\" http-equiv=\"X-UA-Compatible\">\n  <meta name=\"format-detection\" content=\"telephone=no,address=no,email=no\">\n  <!-- seo -->\n  <meta property=\"og:title\" content=\"トヨタレンタリース西四国\" />\n  <meta property=\"og:type\" content=\"website\" />\n  <meta property=\"og:url\" content=\"https://www.r-ehm.co.jp/\" />\n  <meta property=\"og:image\" content=\"https://www.r-ehm.co.jp/assets/img/ogp.jpg\" />\n  <meta property=\"og:site_name\" content=\"トヨタレンタリース西四国\" />\n  <meta property=\"og:description\" content=\"よいクルマ、よいサービス。愛媛県と高知県のレンタカー予約はトヨタレンタリース西四国へ！\" />\n  <meta name=\"twitter:card\" content=\"summary\" />\n  <meta name=\"twitter:title\" content=\"トヨタレンタリース西四国\" />\n  <meta name=\"twitter:description\" content=\"よいクルマ、よいサービス。愛媛県と高知県のレンタカー予約はトヨタレンタリース西四国へ！\" />\n  <meta name=\"twitter:image\" content=\"https://www.r-ehm.co.jp/assets/img/ogp.jpg\" />\n\n  <!-- faviconの指定 -->\n  <link rel=\"icon\" type=\"img/x-icon\" href=\"/assets/img/favicon.ico\">\n  <link rel=\"icon\" href=\"/assets/img/favicon.ico\">\n  <link rel=\"shortcut icon\" type=\"img/vnd.microsoft.icon\" href=\"/assets/img/favicon.ico\">\n  <link rel=\"icon\" type=\"img/vnd.microsoft.icon\" href=\"/assets/img/favicon.ico\">\n  <link rel=\"apple-touch-icon\" href=\"/apple-touch-icon.png\" sizes=\"180x180\">\n  <link rel=\"apple-touch-icon-precomposed\" href=\"/apple-touch-icon.png\" sizes=\"180x180\">\n  <link rel=\"stylesheet\" href=\"https://unpkg.com/swiper/swiper-bundle.min.css\">\n  <link rel=\"stylesheet\" href=\"/assets/css/scss/pages/common.css\">\n  <link rel=\"stylesheet\" href=\"/assets/css/scss/pages/index.css\">\n</head>\n\n<body>\n  <div class=\"wrap\">\n    <div class=\"l-content\">\n      <!-- l-header -->\n      <header class=\"l-header js-header\">\n        <div class=\"l-header-logo\">\n          <h1 class=\"l-header-logo__ttl\">\n            <a class=\"-link\" href=\"/\">\n              <img src=\"/assets/img/common/logo.svg\" alt=\"TOYOTA Rent a Car\">\n            </a>\n          </h1>\n        </div>\n        <div id=\"js-drawermenu\" class=\"l-header-area\">\n          <ul class=\"l-header-area__list\">\n            <li class=\"l-header-area__list-item\"><a class=\"-link\" href=\"/\">ホーム</a></li>\n            <li class=\"l-header-area__list-item\"><a class=\"-link\" href=\"/company/\">会社概要</a></li>\n            <div class=\"l-header-area__list-item l-header-area__list-item--linkaccd\">\n              <a class=\"-link\" href=\"/recruit/\">採用情報</a>\n              <span class=\"l-header-area__list-item--linkaccd-btn js-accd\"></span>\n              <ul class=\"l-header-area__list-ul\" style=\"display:none;\">\n                <li class=\"l-header-area__list-section l-header-area__list-section--mt\"><a href=\"/recruit/interview/\">-\n                    社員インタビュー</a></li>\n                <li class=\"l-header-area__list-section\"><a href=\"/recruit/data/\">- 数字で見る</a></li>\n                <li class=\"l-header-area__list-section\"><a href=\"/recruit/training/\">- 研修制度</a></li>\n                <li class=\"l-header-area__list-section\"><a href=\"/recruit/faq/\">- よくあるご質問</a></li>\n                <li class=\"l-header-area__list-section\"><a href=\"/recruit/description/\">- 募集要項</a></li>\n              </ul>\n            </div>\n          </ul>\n          <div class=\"l-header-area__targetbox\">\n            <div class=\"l-header-area__shop\">\n              <a href=\"/shop/\"><span class=\"-icon\">店舗を探す</span></a>\n            </div>\n            <div class=\"l-header-area__info\">\n              <a href=\"https://rent.toyota.co.jp/static/guide/\" target=\"_blank\"><span class=\"-icon\">ご利用案内</span></a>\n            </div>\n            <div class=\"l-header-area__reservation\">\n              <a href=\"https://rent.toyota.co.jp/\" target=\"_blank\"><span class=\"-icon\">インターネット予約</span></a>\n            </div>\n          </div>\n        </div>\n        <div id=\"js-btnTrigger\" class=\"js-navbtn l-header-humbtn\">\n          <span class=\"l-header-humbtn__line\">\n            <!--btn-->\n          </span>\n          <span class=\"l-header-humbtn__line\">\n            <!--btn-->\n          </span>\n        </div>\n      </header>\n      <!-- l-snsbox -->\n      <div class=\"l-snsbox\">\n        <div class=\"l-snsbox-block l-snsbox-block--01\">\n          <a href=\"/recruit/\">\n            <p class=\"-txt\">採用情報</p>\n          </a>\n        </div>\n        <div class=\"l-snsbox-block l-snsbox-block--02\">\n          <a href=\"https://www.instagram.com/toyota_nishishikoku/\" target=\"_blank\">\n            <p class=\"-txt\">インスタグラム</p>\n          </a>\n        </div>\n      </div>\n      <div class=\"l-content-main\">\n\n\n        <div id=\"loading\">\n          <div class=\"loading-block\">\n            <div id=\"loading_text\"></div>\n          </div>\n        </div>\n        <div class=\"p-top-mv\">\n          <div class=\"p-top-mv__area\">\n            <p class=\"p-top-mv__area-bg\"></p>\n            <p class=\"p-top-mv__area-cloud\"></p>\n            <div class=\"p-top-mv__area-ttlbox js-anime\">\n              <p class=\"-ttl\">このドライブ、<ruby>きっと好き<rt>・・・・・</rt></ruby>になる。</p>\n            </div>\n            <div class=\"p-top-mv__area-img\">\n              <div class=\"-img01 js-anime\">\n                <picture>\n                  <source srcset=\"/assets/img/top/mv-shop-sp.png\" media=\"(max-width: 768px)\">\n                  <img src=\"/assets/img/top/mv-shop.png\">\n                </picture>\n              </div>\n              <div class=\"-img02 js-anime\">\n                <img src=\"/assets/img/top/mv-people.png\">\n              </div>\n              <div class=\"-img03 js-anime\">\n                <img src=\"/assets/img/top/mv-car.png\">\n              </div>\n            </div>\n          </div>\n        </div>\n\n        <!-- p-top-shop -->\n        <section class=\"p-top-shop\">\n          <p class=\"p-top-shop__bg\"></p>\n          <div class=\"p-top-shop__bgbox\">\n            <div class=\"p-top-shop__bgbox-cicle\"></div>\n          </div>\n          <div class=\"p-top-shop__imgbox01 js-anime\">\n            <div class=\"-in js-pararax\">\n              <img src=\"/assets/img/top/top-img01.jpg\">\n            </div>\n          </div>\n          <div class=\"p-top-shop__imgbox02 js-anime\">\n            <div class=\"-in js-pararax\">\n              <img src=\"/assets/img/top/top-img02.jpg\">\n            </div>\n          </div>\n          <div class=\"p-top-shop__imgbox03 js-anime\">\n            <div class=\"-in js-pararax\">\n              <img src=\"/assets/img/top/top-img03.jpg\">\n            </div>\n          </div>\n          <div class=\"p-top-shop__imgbox04 js-anime\">\n            <div class=\"-in js-pararax\">\n              <img src=\"/assets/img/top/top-img04.jpg\">\n            </div>\n          </div>\n          <p class=\"p-top-shop__icon js-anime\">\n            <img src=\"/assets/img/top/top-about-icon.png\">\n          </p>\n          <div class=\"inner\">\n            <div class=\"p-top-shop__area flex\">\n              <div class=\"p-top-shop__area-txtbox\">\n                <h2 class=\"c-ttl01\">愛媛・高知の旅をもっと<span class=\"-color\">楽しく</span>、<br>もっと<span class=\"-color\">快適</span>に。\n                </h2>\n                <p class=\"-txt\">愛媛の穏やかな海、高知の豊かな自然や歴史ある街並み。<br>\n                  そんな四国の魅力を、もっと自由に楽しんでいただくために。<br>\n                  トヨタレンタリース西四国は、信頼の品質と地域に根ざしたサービスで、<br class=\"pc\">\n                  あなたの旅をサポートします。<br>\n                  観光にもビジネスにも、快適な移動を。<br>\n                  レンタカーだからこそ味わえる、四国の新しい発見がきっと待っています。</p>\n              </div>\n              <div class=\"p-top-shop__area-block\">\n                <div class=\"c-btn01\">\n                  <a href=\"/shop/\">\n                    <p class=\"-txt\">店舗一覧を見る</p>\n                  </a>\n                </div>\n              </div>\n            </div>\n          </div>\n        </section>\n\n        <!-- p-top-promise -->\n        <section class=\"p-top-promise\">\n          <p class=\"p-top-promise__bgtxt c-word-anime js-anime js-word\">our promise</p>\n          <div class=\"inner p-top-promise--inner\">\n            <div class=\"p-top-promise__ttlbox\">\n              <div class=\"c-ttl02box\">\n                <h2 class=\"c-ttl02 js-anime\">our promise<span class=\"-jp\">私たちが心がけていること</span></h2>\n              </div>\n              <p class=\"-txt\">お客様一人ひとりにとって、<br>快適で安心なレンタカー体験を<br>ご提供するために。</p>\n            </div>\n            <div class=\"p-top-promise__slide\">\n              <div class=\"swiper\">\n                <div class=\"swiper-wrapper\">\n                  <div class=\"swiper-slide\">\n                    <img src=\"/assets/img/top/top-our01.png\">\n                  </div>\n                  <div class=\"swiper-slide\">\n                    <img src=\"/assets/img/top/top-our02.png\">\n                  </div>\n                  <div class=\"swiper-slide\">\n                    <img src=\"/assets/img/top/top-our03.png\">\n                  </div>\n                  <div class=\"swiper-slide\">\n                    <img src=\"/assets/img/top/top-our04.png\">\n                  </div>\n                </div>\n              </div>\n              <div class=\"swiper-button-prev\"></div>\n              <div class=\"swiper-button-next\"></div>\n            </div>\n            <!-- p-top-promise__txtbox -->\n            <div class=\"p-top-promise__txtbox\">\n              <div class=\"p-top-promise__txtbox-item p-top-promise__txtbox-item--01 -show\">\n                <h3 class=\"-ttl\"><span class=\"-num\">Promise 01</span>笑顔とまごころの接客</h3>\n                <p class=\"-txt\">お忙しいお客様にもご満足いただけるよう、スピーディかつ丁寧な対応を心がけています。</p>\n              </div>\n              <div class=\"p-top-promise__txtbox-item p-top-promise__txtbox-item--02\">\n                <h3 class=\"-ttl\"><span class=\"-num\">Promise 02</span>安心・安全な車両管理</h3>\n                <p class=\"-txt\">トヨタの基準に基づいた点検・整備を徹底し、いつでも快適にお使いいただける車両をご用意しています。</p>\n              </div>\n              <div class=\"p-top-promise__txtbox-item p-top-promise__txtbox-item--03\">\n                <h3 class=\"-ttl\"><span class=\"-num\">Promise 03</span>地域に寄り添うサービス</h3>\n                <p class=\"-txt\">愛媛・高知に根ざした店舗展開と情報提供で、お客様の旅やビジネスを丁寧にサポートします。</p>\n              </div>\n              <div class=\"p-top-promise__txtbox-item p-top-promise__txtbox-item--04\">\n                <h3 class=\"-ttl\"><span class=\"-num\">Promise 04</span>スムーズなご出発・ご返却</h3>\n                <p class=\"-txt\">お忙しいお客様にもご満足いただけるよう、スピーディかつ丁寧な対応を心がけています。</p>\n              </div>\n            </div>\n            <!-- p-top-promise__pointbox -->\n            <div class=\"p-top-promise__pointbox\">\n              <div class=\"p-top-promise__pointbox-in\">\n                <p class=\"-txt -active\"><span class=\"-num\">01</span><span class=\"-word\">笑顔とまごころの接客</span></p>\n                <p class=\"-txt\"><span class=\"-num\">02</span><span class=\"-word\">安心・安全な車両管理</span></p>\n                <p class=\"-txt\"><span class=\"-num\">03</span><span class=\"-word\">地域に寄り添うサービス</span></p>\n                <p class=\"-txt\"><span class=\"-num\">04</span><span class=\"-word\">スムーズなご出発・ご返却</span></p>\n              </div>\n            </div>\n          </div>\n        </section>\n\n\n        <!-- p-top-insta -->\n        <section class=\"p-top-insta\">\n          <div class=\"p-top-insta__area\">\n            <div class=\"p-top-insta__area-bg\"></div>\n            <div class=\"p-top-insta__area-block\">\n              <div class=\"c-ttl02box\">\n                <h2 class=\"c-ttl02 c-ttl02-wh js-anime\">instagram<span class=\"-jp -jp-wh\">公式インスタグラム</span></h2>\n              </div>\n              <p class=\"p-top-insta__txt\">会社の取り組み、スタッフの素敵な一面など、<br>私たちの全力を発信しています！</p>\n              <div class=\"p-top-insta__area-iphone\">\n                <div class=\"-img\">\n                  <img src=\"/assets/img/top/insta-item.png\">\n                </div>\n                <div class=\"-scrollbox\">\n                  <div class=\"-scrollbox-img\">\n                    <img src=\"/assets/img/top/insta-scroll.png\">\n                  </div>\n                </div>\n                <p class=\"-com\">\n                  <img src=\"/assets/img/top/insta-com.png\">\n                </p>\n              </div>\n              <div class=\"c-btn01 p-top-insta--btn\">\n                <a href=\"https://www.instagram.com/toyota_nishishikoku/\" target=\"_blank\">\n                  <p class=\"-txt\">公式インスタグラムを見る</p>\n                </a>\n              </div>\n              <p class=\"p-top-insta__area-icon js-anime\">\n                <img src=\"/assets/img/top/instasec-icon.svg\">\n              </p>\n            </div>\n          </div>\n        </section>\n\n\n        <!-- c-recruit-layout -->\n        <section class=\"c-recruit-layout c-recruit-layout--top\">\n          <div class=\"inner c-recruit-layout--inner\">\n            <div class=\"c-recruit-layout__area flex\">\n              <div class=\"c-recruit-layout__area-left\">\n                <div class=\"c-ttl02box c-recruit-layout__area-left--ttl\">\n                  <h2 class=\"c-ttl02 js-anime\">recruit<span class=\"-jp\">採用情報</span></h2>\n                </div>\n                <p class=\"-catch\">\n                  地域と共に、人も育つ。<br>トヨタレンタリース西四国の<br><span class=\"-color\">未来</sapn>を一緒に。\n                </p>\n                <p class=\"c-recruit-layout-txt\">\n                  愛媛・高知のあたたかさそのままに、職場も明るく居心地の良い環境が自慢です。役職や年齢に関係なく、意見を出し合い、助け合える関係性が根づいています。<br>地域の方々に寄り添いながら、自分らしくのびのびと働ける職場で、一緒に成長していきませんか？\n                </p>\n                <div class=\"c-btn01 c-recruit-layout--btn\">\n                  <a href=\"/recruit/\">\n                    <p class=\"-txt\">採用情報を見る</p>\n                  </a>\n                </div>\n              </div>\n              <div class=\"c-recruit-layout__area-right\">\n                <div class=\"-bgicon\">\n                  <img src=\"/assets/img/top/recruit-bg.png\">\n                </div>\n                <div class=\"-imgbox01 js-anime\">\n                  <div class=\"-in js-pararax\">\n                    <img src=\"/assets/img/top/recruit-img01.jpg\">\n                  </div>\n                </div>\n                <div class=\"-imgbox02 js-anime\">\n                  <div class=\"-in js-pararax\">\n                    <img src=\"/assets/img/top/recruit-img02.jpg\">\n                  </div>\n                </div>\n                <div class=\"-imgbox03 js-anime\">\n                  <div class=\"-in js-pararax\">\n                    <img src=\"/assets/img/top/recruit-img03.jpg\">\n                  </div>\n                </div>\n              </div>\n            </div>\n          </div>\n          <p class=\"c-recruit-layout__icon js-anime\">\n            <img src=\"/assets/img/top/recruitsec-icon.png\">\n          </p>\n        </section>\n\n\n        <!-- l-footer -->\n        <footer class=\"l-footer l-footer--top\">\n          <div class=\"l-footer-area\">\n            <div class=\"l-footer-area__pagetop\">\n              <a href=\"#\">\n                <p class=\"l-footer-area__pagetop-txt\">page top</p>\n              </a>\n            </div>\n            <div class=\"l-footer-area__block inner\">\n              <div class=\"l-footer-area__block-top flex is-between\">\n                <div class=\"-left flex\">\n                  <div class=\"-logo\">\n                    <a href=\"/\">\n                      <img src=\"/assets/img/common/f-logo.svg\">\n                    </a>\n                  </div>\n                  <p class=\"-access\">株式会社トヨタレンタリース西四国<br>〒791-8042 松山市南吉田町2750-12</p>\n                </div>\n                <div class=\"-insta\">\n                  <a href=\"https://www.instagram.com/toyota_nishishikoku/\" target=\"_blank\"><img\n                      src=\"/assets/img/common/insta-icon-wh.svg\"></a>\n                </div>\n              </div>\n              <div class=\"l-footer-area__block-list\">\n                <ul class=\"flex\">\n                  <li><a href=\"/csr/\">CSR基本方針</a></li>\n                  <li><a href=\"/pp/\">プライバシーポリシー</a></li>\n                  <li><a href=\"/solicitation/\">勧誘方針</a></li>\n                  <li><a href=\"/antisocial/\">暴力団等反社会的勢力排除宣言</a></li>\n                  <li><a href=\"/company/\">会社概要</a></li>\n                </ul>\n              </div>\n              <div class=\"l-footer-area__block-shop flex\">\n                <p class=\"-ttl\">店舗を探す</p>\n                <ul class=\"flex\">\n                  <li><a href=\"/shop/matsuyama.html\">松山店</a></li>\n                  <li><a href=\"/shop/matsuyama-port.html\">松山観光港店</a></li>\n                  <li><a href=\"/shop/matsuyama-ap.html\">松山空港店</a></li>\n                  <li><a href=\"/shop/imabari.html\">今治店</a></li>\n                  <li><a href=\"/shop/saijo-st.html\">JR伊予西条駅店</a></li>\n                  <li><a href=\"/shop/niihama-st.html\">新居浜駅前店</a></li>\n                  <li><a href=\"/shop/iyomishima-st.html\">JR伊予三島駅店</a></li>\n                  <li><a href=\"/shop/yawatahama-st.html\">JR八幡浜駅店</a></li>\n                  <li><a href=\"/shop/uwajima-st.html\">JR宇和島駅店</a></li>\n                  <li><a href=\"/shop/kochi-st.html\">高知駅前店</a></li>\n                  <li><a href=\"/shop/kochi-ap.html\">高知空港店</a></li>\n                  <li><a href=\"/shop/nakamura.html\">中村店</a></li>\n                </ul>\n              </div>\n              <div class=\"l-footer-area__block-recruit flex\">\n                <p class=\"-ttl\">採用情報</p>\n                <ul class=\"flex\">\n                  <li><a href=\"/recruit/interview/\">社員インタビュー</a></li>\n                  <li><a href=\"/recruit/data/\">数字で見る</a></li>\n                  <li><a href=\"/recruit/training/\">研修制度</a></li>\n                  <li><a href=\"/recruit/faq/\">よくあるご質問</a></li>\n                  <li><a href=\"/recruit/description/\">募集要項</a></li>\n                </ul>\n              </div>\n            </div>\n          </div>\n          <p class=\"l-footer-area__copy\">&copy; 2025, 株式会社トヨタレンタリース西四国</p>\n        </footer>\n      </div>\n    </div>\n    <script src=\"/assets/js/jquery-3.6.0.min.js\"></script>\n    <script src=\"https://unpkg.com/swiper/swiper-bundle.min.js\"></script>\n    <script type=\"text/javascript\" src=\"https://cdnjs.cloudflare.com/ajax/libs/progressbar.js/1.1.0/progressbar.min.js\">\n    </script>\n    <script src=\"https://cdn.jsdelivr.net/npm/simple-parallax-js@5.6.2/dist/simpleParallax.min.js\"></script>\n    <script src=\"/assets/js/common.js\"></script>\n    <script src=\"/assets/js/index.js\"></script>\n  </div>\n\n</body>\n</html>","finalUrl":"http://www.r-ehm.co.jp/","rendered":false,"_cachedAt":"2026-06-23T16:27:19.424Z"}