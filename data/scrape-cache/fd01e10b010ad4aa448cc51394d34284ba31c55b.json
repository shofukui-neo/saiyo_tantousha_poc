      <td>年2回</td>\n          </tr>\n          <tr>\n            <th class=\"arrow_box\">各種保険 </th>\n            <td>健康保険、厚生年金保険、雇用保険、労災保険　他</td>\n          </tr>\n          <tr>\n            <th class=\"arrow_box\">交通費 </th>\n            <td>全額負担　（月10万円を限度とする）</td>\n          </tr>\n          <tr>\n            <th class=\"arrow_box\">選考方法 </th>\n            <td>書類選考 → 一次面接 → 最終面接</td>\n          </tr>\n          <tr>\n            <th class=\"arrow_box\">応募書類 </th>\n            <td>履歴書、職務経歴書</td>\n          </tr>\n          <tr>\n            <th class=\"arrow_box\">応募方法 </th>\n            <td>エントリーシートにご入力の上、送信してください。<br>\n            後日、面談日程をご連絡いたします。</td>\n          </tr>\n          <tr>\n            <th class=\"arrow_box\">お問い合わせ先 </th>\n            <td>管理本部総務部　木村<br>\n            TEL　048-650-7770　FAX　048-650-5533</td>\n          </tr>\n        </table>\n    \n<b></b>\n      </article><div class=\"entry_btn\"><a href=\"entry_halfway.html\"><img src=\"images/common/entry_bnr02.jpg\" width=\"460\" height=\"80\" alt=\"中途エントリーフォーム\"/></a></div>\n    </div>\n  </div>\n    <!--contants--> \n  </div>\n  <!--contants_warp-->\n  <footer id=\"footer\" class=\"footer\">\n    <div class=\"footer_navi\">\n      <ul>\n        <li><a href=\"index.html\">採用TOP</a></li>\n        <li><a href=\"voice.html\">新入社員の声</a></li>\n        <li><a href=\"entry_new_graduate.html\">新卒エントリーフォーム</a></li>\n        <li><a href=\"entry_halfway.html\">中途エントリーフォーム</a></li>\n      </ul>\n      \n    </div>\n    <p class=\"footer_copy\">(C) Apec engineering Co., Ltd. All Rights Reserved.</p>\n  </footer>\n  <!--footer--><!--wrapper-->\n<div id=\"page-top\"></div>\n</body>\n</html>\n","finalUrl":"https://www.apeceng.co.jp/recruit/halfway.html","rendered":false,"_cachedAt":"2026-06-22T20:25:59.899Z"}