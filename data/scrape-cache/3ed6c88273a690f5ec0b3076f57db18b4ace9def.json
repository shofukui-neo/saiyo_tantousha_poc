All in One SEO -->\n\n<link rel='dns-prefetch' href='//ajax.googleapis.com' />\n<link rel=\"alternate\" type=\"application/rss+xml\" title=\"ホシザキ京阪株式会社 &raquo; フィード\" href=\"https://hoshizaki-keihan.co.jp/feed/\" />\n<link rel=\"alternate\" type=\"application/rss+xml\" title=\"ホシザキ京阪株式会社 &raquo; コメントフィード\" href=\"https://hoshizaki-keihan.co.jp/comments/feed/\" />\n<link rel=\"alternate\" title=\"oEmbed (JSON)\" type=\"application/json+oembed\" href=\"https://hoshizaki-keihan.co.jp/wp-json/oembed/1.0/embed?url=https%3A%2F%2Fhoshizaki-keihan.co.jp%2Frecruite%2Frequirments%2F\" />\n<link rel=\"alternate\" title=\"oEmbed (XML)\" type=\"text/xml+oembed\" href=\"https://hoshizaki-keihan.co.jp/wp-json/oembed/1.0/embed?url=https%3A%2F%2Fhoshizaki-keihan.co.jp%2Frecruite%2Frequirments%2F&#038;format=xml\" />\n<style id='wp-img-auto-sizes-contain-inline-css' type='text/css'>\nimg:is([sizes=auto i],[sizes^=\"auto,\" i]){contain-intrinsic-size:3000px 1500px}\n/*# sourceURL=wp-img-auto-sizes-contain-inline-css */\n</style>\n<link rel='stylesheet' id='me-spr-block-styles-css' href='https://hoshizaki-keihan.co.jp/wp/wp-content/plugins/simple-post-redirect/css/block-styles.min.css?ver=6.9.4' type='text/css' media='all' />\n<link rel='stylesheet' id='contact-form-7-css' href='https://hoshizaki-keihan.co.jp/wp/wp-content/plugins/contact-form-7/includes/css/styles.css?ver=6.1.6' type='text/css' media='all' />\n<script type=\"text/javascript\" src=\"https://ajax.googleapis.com/ajax/libs/jquery/3.3.1/jquery.min.js?ver=3.3.1\" id=\"jquery-js\"></script>\n<link rel=\"https://api.w.org/\" href=\"https://hoshizaki-keihan.co.jp/wp-json/\" /><link rel=\"alternate\" title=\"JSON\" type=\"application/json\" href=\"https://hoshizaki-keihan.co.jp/wp-json/wp/v2/pages/334\" /><link rel='shortlink' href='https://hoshizaki-keihan.co.jp/?p=334' />\n<!-- Analytics by WP Statistics - https://wp-statistics.com -->\n\n<link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/Swiper/7.3.3/swiper-bundle.min.css\" />\n\t\n</head>\n<body class=\"wp-singular page-template-default page page-id-334 page-child parent-pageid-25 wp-theme-whitestudio requirments\">\n    <!-- ヘッダー -->\n\t<header class=\"top-head-ex\">\n\t\t<!-- ヘッダー中身 -->\n\t\t<div class=\"top-head-ex-gird\">\n\t\t\t<a href=\"https://hoshizaki-keihan.co.jp/\">\n\t\t\t\t<img src=\"https://hoshizaki-keihan.co.jp/wp/wp-content/themes/whitestudio/images/common/img-logo.png\" alt=\"京阪ロゴ\">\n\t\t\t</a>\n\t\t\t<div class=\"header-menu-pc-grid-2\">\n\t\t\t\t<a href=\"#footer\" class=\"map\">サイトマップ</a>\n\t\t\t\t<a href=\"https://hoshizaki-keihan.co.jp/company\">企業情報</a>\n\t\t\t\t<a href=\"https://hoshizaki-keihan.co.jp/location\">営業所一覧</a>\n\t\t\t\t<a href=\"https://hoshizaki-keihan.co.jp/toiawase\">お問い合わせ</a>\n\t\t\t\t<a href=\"https://hoshizaki-keihan.co.jp/recruite\" class=\"saiyo\">採用情報</a>\n\t\t\t\t\t\t\t\t\t\t\t<a href=\"https://job.mynavi.jp/27/pc/search/corp40189/outline.html\" target=\"_blank\" class=\"saiyo\">マイナビ2027</a>\n\t\t\t\t\t\t\t\t\t\t</div>\n\t\t\t<a href=\"#footer\" class=\"nav-bottom-link\">\n\t\t\t\t<div class=\"nav-bottom\"></div>\n\t\t\t\t<div class=\"nav-bottom\"></div>\n\t\t\t\t<div class=\"nav-bottom\"></div>\n\t\t\t\t<p>Menu</p>\n\t\t\t</a>\n\t\t</div>\n\t\t<!-- / ヘッダー中身 -->\n\t</header>\n\t<!-- / ヘッダー -->\n    <div id=\"p_top\"></div>\n\t<main>\n<div class=\"sub-page-line\"></div>\n<div class=\"inner2\">\n\t<div class=\"sub-title-grid\">\n\t\t<div class=\"sub-title-grid-left\">\n\t\t\t<h1 class=\"sub-title\">募集要項 - 新卒<span>\n\t\t\t\tRequirments</span>\n\t\t\t</h1>\n\t\t</div>\n\t</div>\n</div>\n\n<div class=\"inner3 contena-tbl\">\n\t<section class=\"mb30 rec-new\">\n\t\t<h3 class=\"midashi-6 midashi-6-blue\">[ 新卒採用向け ]</h3>\n\t\t<div class=\"mb30 pd20\">\n\t\t\t<a href=\"https://job.mynavi.jp/27/pc/search/corp40189/outline.html\" target=\"_blank\">\n\t\t\t\t<img src=\"https://job.mynavi.jp/conts/kigyo/2027/logo/banner_logo_195_60.gif\" alt=\"マイナビ2027\" border=\"0\" class=\"mynaviBnr\">\n\t\t\t\t<br>エントリー受付中\n\t\t\t</a>\n\t\t</div>\n\n\t\t<dl class=\"flextable-2\">\n\t\t\t<dt>募集人数</dt>\n\t\t\t<dd>20名程度</dd>\n\t\t</dl>\n\t\t<section>\n\t\t\t<h4>[ 勤務 ]</h4>\n\t\t\t<dl class=\"flextable-2\">\n\t\t\t\t<dt>勤務地</dt><dd>大阪・京都・滋賀・奈良・和歌山</dd>\n\t\t\t\t<dt>勤務時間</dt><dd>9：00～17：50</dd>\n\t\t\t\t<dt>休日休暇</dt><dd>年間122日（2026年実績）<br>\n\t\t\t\t完全週休二日制（土日）・夏季休暇・年末年始休暇<br>\n\t\t\t\t有給休暇制度（半日・時間単位取得可）・産前産後休暇・介護休暇・特別有給<br>\n\t\t\t\t※年5日程度祝日出勤が発生します</dd>\n\t\t\t</dl>\n\t\t</section>\n\t\t<section>\n\t\t\t<h4>[ 待遇 ]</h4>\n\t\t\t<dl class=\"flextable-2\">\n\t\t\t\t<dt>初任給</dt><dd>2026年4月実績<br>\n\t\t\t\t<span class=\"bold\">【営業・セールスエンジニア】大卒・本社地区勤務の場合</span><br>\n\t\t\t\t月給　292,884円<br>\n\t\t\t\t月給には以下が含まれます。<br>\n\t\t\t\t・本給、職能給、地域手当、その他特別手当、運転手当<br>\n\t\t\t\t・営業、技術手当※　58,984円<br>\n\t\t\t\t※時間外労働の有無に関わらず、32時間分の時間外手当として支給いたします<br>32時間を超える時間外労働分についての割増賃金は別途支給いたします。<br><br>\n\n\t\t\t\t<span class=\"bold\">【管理業務】大卒・本社地区勤務の場合</span><br>\n\t\t\t\t月給　214,150円<br>\n\t\t\t\t月給には以下が含まれます<br>\n\t\t\t\t・本給、職能給、地域手当</dd>\n\t\t\t\t<dt>諸手当</dt><dd>通勤手当（上限なし）、役付手当、家族手当、住宅手当、時間外手当、運転手当（車両運転者のみ）、資格手当</dd>\n\t\t\t\t<dt>賃金改定</dt><dd>年1回（4月）　5.0％（2026年実績）</dd>\n\t\t\t\t<dt>賞与</dt><dd>年2回（7月、12月）　7.1ヶ月（2025年実績）</dd>\n\n\t\t\t</dl>\n\t\t</section>\n\t\t<section>\n\t\t\t<h4>[ 応募資格 ]</h4>\n\t\t\t<dl class=\"flextable-2\">\n\t\t\t\t<dt>応募資格</dt><dd>2027年3月に四年制大学・大学院修士・博士課程を卒業・修了見込みの方</dd>\n\t\t\t\t<dt>採用実績</dt><dd>16名　男性14名　女性2名（2026年4月入社）</dd>\n\t\t\t\t<dt>採用実績</dt><dd>近畿大学、関西大学、京都産業大学、追手門学院大学、大阪学院大学\n\t\t\t\t龍谷大学、立命館大学、大阪産業大学、大阪商業大学、桃山学院大学\n\t\t\t\t帝塚山大学、大阪経済大学、摂南大学、阪南大学、京都学園大学</dd>\n\t\t\t\t<dt>募集学部・学科\t</dt><dd>>全学部、全学科対象</dd>\n\t\t\t\t<dt>応募方法</dt><dd>マイナビ2027</dd>\n\t\t\t\t<dt>提出書類</dt><dd>エントリーシート</dd>\n\t\t\t\t<dt>選考方法</dt><dd>まずは、弊社開催の会社説明会　または　学内セミナーへご参加ください（詳細はマイナビ2027にて）<br>\n\t\t\t\t書類選考　→　(1次)　WEB適正検査＋グループ面接　→　（最終）グループまたは個人面接</dd>\n\t\t\t</dl>\n\t\t</section>\n\t\t<section>\n\t\t\t<h4>[ 採用受付 ]</h4>\n\t\t\t<dl class=\"flextable-2\">\n\n\t\t\t\t<dt>お問い合わせ先</dt><dd>管理部　管理課　採用担当者<br>\n\t\t\t\t06-6762-5351（平日9：00-17：50）</dd>\n\n\t\t\t</dl>\n\t\t</section>\n\t\t<section>\n\t\t\t<h4>[ 福利厚生 ]</h4>\n\t\t\t<dl class=\"flextable-2\">\n\t\t\t\t<dt>福利厚生</dt><dd>退職金制度、慶弔見舞金制度、財形貯蓄制度、社員持株会制度、定期健康診断、保養所　他</dd>\n\t\t\t\t<dt>保険</dt><dd>健康保険、厚生年金保険、雇用保険、労災保険、ホシザキグループ保険</dd>\n\t\t\t</dl>\n\t\t</section>\n\t</section>\n\t<div class=\"inner2\">\n\t\t<section class=\"faq-box\">\n\t\t\t<h3 class=\"midashi-6 midashi-6-blue\">[ 新卒採用向けＱ＆Ａ ]</h3>\n\t\t\t<dl class=\"faq-list\">\n\t\t\t\t<dt>既卒者の応募は可能ですか</dt>\n\t\t\t\t<dd>弊社では、ご就業経験のない既卒者の方はすべて<a href=\"https://hoshizaki-keihan.co.jp/requirments-career\">キャリア採用</a>の対象となります。<br>\n\t\t\t\t\tキャリア採用ページに随時募集情報を掲載しますので、ご覧ください。\n\t\t\t\t</dd>\n\t\t\t\t<dt>会社説明会に参加していないが選考に進めますか</dt>\n\t\t\t\t<dd>弊社では、会社説明会　または　学内セミナーへご参加の方のみ。<br>\n\t\t\t\t\t選考へお進みいただいております。会社説明会はマイナビ2025よりご予約ください。\n\t\t\t\t</dd>\n\t\t\t\t<dt>配属までの研修内容を教えてほしい</dt>\n\t\t\t\t<dd>研修に関しては<a href=\"https://hoshizaki-keihan.co.jp/education\">こちら</a>へ公開しております。</dd>\n\t\t\t\t<dt>配属先はどのように決定されるのでしょうか</dt>\n\t\t\t\t<dd>本人と面談を重ね、ご自宅から原則90分以内で通える範囲で決定いたします</dd>\n\t\t\t\t<dt>転勤はありますか。</dt>\n\t\t\t\t<dd>原則、転居を伴う転勤はございません（一部例外有）</dd>\n\t\t\t\t<dt>資格は必要ですか。</dt>\n\t\t\t\t<dd>営業職　または　技術サービス職志望の場合はご入社までに、普通自動車免許（AT限定可）が必須です。</dd>\n\t\t\t\t<dt>インターンシップは大学4回生も参加できますか</dt>\n\t\t\t\t<dd>弊社インターンシップは3回生対象となっておりますので、ご参加いただけません。</dd>\n\t\t\t</dl>\n\t\t</section>\n\t</div>\n</div>\n\n\t</main>\n\t\t<footer id=\"footer\">\n\t  <!-- フッターコンテンツ -->\n\t\t<div class=\"footer-inner\">\n\t\t\t\t\t\t\t<div class=\"footer-menu-box\">\n\t\t\t\t\t<ul class=\"footer-menu-rec\">\n\t\t\t\t\t\t<li> <a href=\"https://hoshizaki-keihan.co.jp/privac\">個人情報保護方針</a> </li>\n\t\t\t\t\t</ul>\n\t\t\t\t</div>\n\t\t\t\t\t\t\t\t\t\t\t\t<div class=\"footer-menu-grid-2nd\">\n\t\t\t\t<ul>\n\t\t\t\t\t<li class=\"no-icon mb20\"><a href=\"https://hoshizaki-keihan.co.jp/company/\">企業情報</a></li>\n\t\t\t\t\t<li class=\"no-icon\"><a href=\"https://hoshizaki-keihan.co.jp/location/\">所在一覧</a></li>\n\t\t\t\t\t<li class=\"m