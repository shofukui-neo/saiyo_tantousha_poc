{"url":"https://www.dai-ichi.com/recruit/","html":"<!DOCTYPE html>\n<html lang=\"ja\" id=\"recruit\" class=\"lower\">\n    <head>\n        <meta charset=\"UTF-8\">\n        <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n        <meta name=\"keywords\" content=\"採用情報,求人,私たちの仕事,働く環境,福利厚生,研修,リクルート,第一商事株式会社,ビルメンテナンス,指定管理者事業,介護福祉\"/>\n        <meta name=\"description\" content=\"第一商事株式会社では、社員が安心して働くことが出来る環境を整えております。当社の仕事に関する様々な情報をご紹介する、採用情報ページです。\" />\n        <title>私たちの仕事｜リクルート｜第一商事株式会社</title>\n        <meta name=\"format-detection\" content=\"telephone=no\">\n        <!-- ogp start -->\n        <meta property=\"og:url\" content=\"https://dai-ichi.com/\"/>\n        <meta property=\"og:type\" content=\"article\">\n        <meta property=\"og:title\" content=\"私たちの仕事｜リクルート｜第一商事株式会社\" />\n        <meta property=\"og:description\" content=\"第一商事株式会社では、社員が安心して働くことが出来る環境を整えております。当社の仕事に関する様々な情報をご紹介する、採用情報ページです。\" />\n        <meta property=\"og:site_name\" content=\"第一商事株式会社\"/>\n        <meta property=\"og:image\" content=\"https://dai-ichi.com/images/common/ogp.png\"/>\n        <meta name=\"twitter:card\" content=\"summary_large_image\"/>\n        <!-- //ogp end -->\n        <link rel=\"shortcut icon\" href=\"../images/common/favicon.ico\">\n        <link rel=\"apple-touch-icon\" href=\"../images/common/apple-touch-icon.png\">\n        <link rel=\"icon\" type=\"../image/png\" href=\"images/common/android-chrome-192x192.png\">\n        <link rel=\"stylesheet\" href=\"../css/style.css\"/>\n        <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/Swiper/11.0.5/swiper-bundle.min.css\" integrity=\"sha512-rd0qOHVMOcez6pLWPVFIv7EfSdGKLt+eafXh4RO/12Fgr41hDQxfGvoi1Vy55QIVcQEujUE1LQrATCLl2Fs+ag==\" crossorigin=\"anonymous\" referrerpolicy=\"no-referrer\" />\n        <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n        <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n        <link href=\"https://fonts.googleapis.com/css2?family=Rubik:ital,wght@0,300..900;1,300..900&family=Zen+Kaku+Gothic+New:wght@300;400;500;700;900&family=Zen+Maru+Gothic:wght@300;400;500;700;900&display=swap\" rel=\"stylesheet\">\n<!-- Google tag (gtag.js) -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-LN8DMNBM3Z\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'G-LN8DMNBM3Z');\n</script>\n    </head>\n    <body>\n        <div class=\"body-wrap\">\n            <header id=\"header\">\n                <div class=\"header-wrapper flex-container\">\n                    <h1 class=\"header-logo\">\n                       <a href=\"../\"><img src=\"../images/common/logo.png\" alt=\"第一商事株式会社\"></a> \n                    </h1>\n                    <div class=\"box-nav flex-container\">\n                        <div class=\"main-nav-wrapper pc-on\">\n                            <nav id=\"main-nav\" class=\"flex-container\">\n                                <ul class=\"flex-container\">\n                                    <li class=\"nav-title has-child-top\"><a tabindex=\"-1\">会社案内</a>\n                                        <ul>\n                                            <li><a href=\"../message/\">社長ご挨拶</a></li>\n                                            <li><a href=\"../company/\">企業情報</a></li>\n                                            <li><a href=\"../access/\">本社・事業所・関連会社</a></li>\n                                            <li><a href=\"../permit/\">許認可</a></li>\n                                            <li><a href=\"../company/#company-movie\">会社紹介MOVIE</a></li>\n                                        </ul>    \n                                    </li>\n                                    <li class=\"nav-title has-child-top\"><a tabindex=\"-1\">サービス</a>\n                                        <ul>\n                                        