</a>\n                    <a href=\"http://www.enadan.co.jp/recruit\" class=\"blue_btn\" title=\"採用情報\">採用情報</a>\n                </nav>\n\n            </nav>\n            <div id=\"nav_icon\"><a href=\"javascript:void(0);\" id=\"panel-btn\"><span id=\"panel-btn-icon\"></span></a></div>\n        </div>\n    </header>\n\n   \n   \n    <!-- /　HEADER ================================================= -->\n\n<!-- MAIN VISUAL  ================================================= -->\n    <section id=\"main_ttl\" style=\"background:url(http://www.enadan.co.jp/wp/wp-content/uploads/2020/06/contact_k_n.png) no-repeat left center ; background-size: cover;\">\n        <h1><span class=\"en-txt\">CONTACT</span>お問い合わせ・サンプル作成依頼</h1>\n    </section>\n<!-- / MAIN VISUAL  ================================================= --> \n<!-- パンくず ================================================= -->\n<div id=\"pankuzu_box\"><ul class=\"pankuzu_list\"><li><a href=\"http://www.enadan.co.jp\"><span>HOME</span></a></li><li><span>お問い合わせ・サンプル作成依頼</span></li></ul></div><!-- / パンくず ================================================= -->\n   \n<!--  CONTENTS ================================================= -->\n<main id=\"main_container\">\n<div class=\"page_contents\">\n<div id=\"contact_contents\" class=\"contents_box\">\n<h2>お問い合わせ・サンプル作成フォーム</h2>\r\n<h3 style=\"text-align: center;\">お電話でのお問い合わせ</h3>\r\n<p class=\"lead_txt\">TEL：<span class=\"js-tel\">0573-25-3105</span></p>\r\n<p class=\"txt_center\">ダンボール・梱包資材に関することはお問い合わせください</p>\r\n<div class=\"flex_box_ct btn_list\"><a href=\"/product/10692\" class=\"more_blue_btn\" title=\"印刷について\">印刷について</a><a href=\"/product/10687\" class=\"more_blue_btn\" title=\"木型について\">木型について</a></div>\r\n<h3 style=\"text-align: center;\">メールでのお問い合わせ</h3>\r\n<p style=\"text-align: center;\">必要事項をご入力の上、確認ボタンを押してください。</p><form action=\"/mail/mail.php\" method=\"POST\" id=\"form1\" name=\"form1\">\n<table>\n\t<tr>\n\t  <th>お名前<span>必須</span></th>\n\t  <td><input type=\"text\" name=\"お名前\" value=\"\" class=\"validate[required]\"></td>\n    </tr>\n\t<tr>\n\t  <th>メールアドレス<span>必須</span></th>\n\t  <td>\n    <input type=\"email\" name=\"メールアドレス\" value=\"\" class=\"validate[required]\">\n\t    <p>確認のため、もう一度ご入力ください。</p>\n\t    <input type=\"email\" name=\"確認メールアドレス\" value=\"\" class=\"validate[required]\">\n\t  </td>\n\t</tr>\n\t<tr>\n\t  <th>御社名<span>必須</span></th>\n\t  <td><input type=\"text\" name=\"御社名\" value=\"\" class=\"validate[required]\"></td>\n    </tr>\n\t<tr>\n\t  <th>ご住所<span>必須</span></th>\n\t  <td><input type=\"text\" name=\"ご住所\" value=\"\" class=\"validate[required]\"></td>\n    </tr>\n\t<tr>\n\t  <th>お電話番号<span>必須</span></th>\n\t  <td><input type=\"text\" name=\"お電話番号\" value=\"\" class=\"validate[required]\"></td>\n    </tr>\n\t<tr>\n\t  <th>お問合せ内容</th>\n\t  <td><textarea name=\"お問合せ内容\" rows=\"10\"></textarea></td>\n    </tr>\n\t<tr>\n\t  <th>アンケート</th>\n\t  <td>\n        <p>弊社をお知りになったきっかけ媒体を教えてください。</p>\n        <label for=\"query01\"><input id=\"query01\" type=\"radio\" name=\"アンケート\" value=\"検索エンジン\"><span>1. 検索エンジン</span></label>\n        <label for=\"query02\"><input id=\"query02\" type=\"radio\" name=\"アンケート\" value=\"知人からの紹介\"><span>2. 知人からの紹介</span></label>\n        <label for=\"query03\"><input id=\"query03\" type=\"radio\" name=\"アンケート\" value=\"検索エンジン\"><span>3. その他</span></label>\n      </td>\n    </tr>\n</table>\n<div class=\"flex_box_ct btn_list mb00 form_btn\">\n<button type=\"reset\" class=\"more_btn\">リセット</button>\n<button type=\"submit\" class=\"more_blue_btn\">確認する</button>\n</div>\n</form>\n    </div>\n</div>\n\n</main>\n<!-- / CONTENTS  ================================================= -->   \n\n\n    <!-- <div id=\"pagetop_box\">\n        <a id=\"pageTop\" href=\"#header\" title=\"ページの先頭へ\">\n<object type=\"image/svg+xml\" data=\"/assets/images/common/page-top.svg\" width=\"96\"></object>\n        </a>\n    </div>   -->\n    <!--  FOOTER ================================================= -->\n    <foo