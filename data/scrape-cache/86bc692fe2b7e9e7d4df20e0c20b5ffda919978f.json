{"url":"https://www.okb-kcs.co.jp/recruit/office/index.html","html":"<!doctype html>\n<html lang=\"ja\"><!-- InstanceBegin template=\"/Templates/recruit02.dwt\" codeOutsideHTMLIsLocked=\"false\" --><head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<link rel=\"icon\" sizes=\"16x16 32x32 48x48\" href=\"/favicon.ico\">\n<link rel=\"apple-touch-icon\" href=\"/apple-touch-icon.png\">\n<!-- InstanceBeginEditable name=\"doctitle\" -->\n<title>KCSを知る - 採用情報サイト - 共立コンピューターサービス株式会社（KCS）</title>\n<meta name=\"keywords\" content=\"会社説明会,概要,エントリー\">\n<meta name=\"description\" content=\"福利厚生、研修制度、アドバイザー制度、新入社員の研修内容など。\">\n<meta property=\"og:url\" content=\"https://www.okb-kcs.co.jp/recruit/office/index.html\">\n<meta property=\"og:type\" content=\"website\">\n<meta property=\"og:title\" content=\"共立コンピューターサービス株式会社（KCS）\">\n<meta property=\"og:description\" content=\"福利厚生、研修制度、アドバイザー制度、新入社員の研修内容など。\">\n<meta property=\"og:site_name\" content=\"KCSを知る - 採用情報サイト - 共立コンピューターサービス株式会社（KCS）\">\n<meta property=\"og:image\" content=\"https://www.okb-kcs.co.jp/recruit/office/images/bg_office.jpg\">\n<!-- InstanceEndEditable -->\n<link href=\"https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css\" rel=\"stylesheet\" integrity=\"sha384-9ndCyUaIbzAi2FUVXJi0CjmCapSmO7SnpJef0486qhLnuZ2cdeRhO02iuK6FUUVM\" crossorigin=\"anonymous\">\n<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n<link href=\"https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;700&display=swap\" rel=\"stylesheet\">\n<!-- Google Tag Manager -->\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n})(window,document,'script','dataLayer','GTM-5MB5TN');</script>\n<!-- End Google Tag Manager -->\n<!-- InstanceBeginEditable name=\"head\" -->\n<link href=\"../css/default02.css\" rel=\"stylesheet\">\n<style type=\"text/css\">\n#header{\nbackground:linear-gradient(0deg, rgba(240, 247 , 253, 1.0), rgba(255, 255, 255, 0)),url(\"images/bg_office.jpg\") no-repeat center bottom / cover;\nanimation: none;\n}\n</style>\n<script src=\"https://cdn.jsdelivr.net/npm/chart.js\"></script>\n<!-- InstanceEndEditable -->\n</head>\n<body>\n<!-- Google Tag Manager (noscript) -->\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-5MB5TN\"\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n<!-- End Google Tag Manager (noscript) -->\n<!-- InstanceBeginEditable name=\"header\" -->\n<div id=\"header\">\n<header>\n<nav class=\"navbar navbar-expand-lg navbar-light  fw-bold p-4 shadow\">\n<div class=\"container-fluid\" id=\"navigation\"></div>\n</nav>\n</header>\n\n<div class=\"container-fluid\">\n<div class=\"row\">\n<div class=\"col-md-9\">\n<h1 class=\"display-3 fw-bold pb-4 mt-5\"><span class=\"bg-white lh-sm px-lg-3\">KCSを知る</span></h1>\n<ul class=\"list-inline ms-4\">\n<li class=\"list-inline-item pb-3\"><a class=\"btn btn-info btn-lg shadow-sm\" href=\"../entry/internship.html\" role=\"button\" target=\"_blank\"><i class=\"bi bi-arrow-right-short\"></i>マイナビでもっと知る</a></li>\n</ul>\n</div>\n<div class=\"col-md-3\">\n<ul class=\"nav flex-column bg-light shadow mb-5 p-3\">\n<li class=\"nav-item border-bottom\"><a class=\"nav-link\" href=\"#benefits\"><i class=\"bi bi-arrow-right-short\"></i>福利厚生</a></li>\n<li class=\"nav-item border-bottom\"><a class=\"nav-link\" href=\"#training\"><i class=\"bi bi-arrow-right-short\"></i>研修制度</a></li>\n<li class=\"nav-item border-bottom\"><a class=\"nav-link\" href=\"#new_employee\"><i class=\"bi bi-arrow-right-short\"></i>新入社員の研修内容</a></li>\n<li class=\"nav-item\"><a class=\"nav-link\" href=\"#best\"><i class=\"bi bi-arrow-right-short\"></i>入社後の研修スケジュール</a></li>\n</ul>\n</div>\n</div><!-- /.row -->\n</div><!-- /.container-fluid -->\n\n<div class=\"container mb-4\">\n<div class=\"mx-md-5 p-5 rounded shadow text-center\" id=\"feature\">\n<p><span class=\"display-5 fw-bold\">30秒で分かるKCS</span></p>\n<div class=\"row align-items-center pt-4\">\n<div class=\"col-lg-4 p-md-3\">\n<div class=\"ratio\" style=\"--bs-aspect-ratio: 150%;\">\n<iframe width=\"597\" height=\"1061\" src=\"https://www.youtube.com/embed/4jzOGiWlFj0?cc_load_policy=1&mute=1&loop=1&rel=0\" title=\"30秒で分かるKCS（2024）\" frameborder=\"0\" allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share\" allowfullscreen></iframe>\n</div><!-- /.ratio -->\n</div>\n<div class=\"col-lg-8 pt-2\">\n<canvas id=\"Chart03\"></canvas>\n<script>\n  const ctx2 = document.getElementById('Chart03');\n  new Chart(ctx2, {\n    type: 'bar',\n//    data: {\n//      labels: ['2020年度', '2021年度', '2022年度'],\n//      datasets: [{\n//        label: '人数',\n//        data: [10, 13,13],\n//        borderWidth: 1\n//      }],\n//      datasets: [{\n//        label: 'test',\n//        data: [10, 13,13],\n//        borderWidth: 1\n//      }]\n//    },\n\ndata: {\n  labels: [ '2023年','2024年','2025年'],\n  datasets: [{\n    label: \"男性（理系）\",\n    data: [5 ,6 ,6],\n    backgroundColor: ['#3da3e8']\n  },{\n    label: \"男性（文系）\",\n    data: [3 ,2 ,2],\n    backgroundColor: ['#8cd1ff']\n  },{\n    label: \"女性（理系）\",\n    data: [0, 2 ,3],\n    backgroundColor: ['#fc6585']\n  },{\n    label: \"女性（文系）\",\n    data: [4 ,5 ,5],\n    backgroundColor: ['#ffc7d3']\n  }],\n},\n  options: {\n  scales: {\n    x: {\n      stacked: true,\n    },\n    y: {\n      stacked: true\n    }\n  },\n  responsive: false\n}\n  });\n</script>\n<p class=\"fw-bold pt-3 pb-2\">過去3年間の新卒採用者数</p>\n</div>\n</div><!-- /.row -->\n\n<p class=\"pt-2\"><a class=\"btn btn-lg btn-outline-info shadow-sm\" data-bs-toggle=\"collapse\" href=\"#collapseMore\" role=\"button\" aria-expanded=\"false\" aria-controls=\"collapseMore\"><i class=\"bi bi-arrow-down-short\"></i>数字で見るKCS</a></p>\n<div class=\"collapse\" id=\"collapseMore\">\n\n<div class=\"row justify-content-md-center pt-4\">\n<div class=\"col-md-4 pt-2\">\n<canvas id=\"Chart01\"></canvas>\n<script>\n  const ctx = document.getElementById('Chart01');\n  new Chart(ctx, {\n    type: 'doughnut',\n    data: {\n      labels: ['理系', '文系'],\n      datasets: [{\n      backgroundColor: [\"#51c0bf\", \"#ffb97c\"],\n        label: '割合',\n        data: [52, 48],\n        borderWidth: 1,\n      }]\n    },\n  });\n</script>\n<p class=\"fw-bold pt-3 pb-2\">文系：理系＝ほぼ1：1</p>\n</div>\n<div class=\"col-md-4 pt-2\">\n<canvas id=\"Chart02\"></canvas>\n<script>\n  const ctx1 = document.getElementById('Chart02');\n  new Chart(ctx1, {\n    type: 'doughnut',\n    data: {\n      labels: ['男性', '女性'],\n      datasets: [{\n        backgroundColor: [\"#3da3e8\", \"#fe8aa3\"],\n        label: '人数',\n        data: [211, 101],\n        borderWidth: 1,\n      }]\n    },\n  });\n</script>\n<p class=\"fw-bold pt-3 pb-2\">女性：男性＝1：2</p>\n</div>\n</div><!-- /.row -->\n\n<div class=\"row align-items-center pt-4\">\n<div class=\"col-md-4 pt-2\">\n<h3 class=\"h5\">月平均所定外労働時間</h3>\n<p><span class=\"display-1 fw-bold\">20.2</span>時間<br>\n<span class=\"small text-secondary\">（2024年度実績）</span></p>\n</div>\n<div class=\"col-md-4 pt-2\">\n<h3 class=\"h5\">有給休暇の平均取得日数</h3>\n<p><span class=\"display-1 fw-bold\">14.0</span>日<br>\n<span class=\"small text-secondary\">（2024年度実績）</span></p>\n</div>\n<div class=\"col-md-4 pt-2\">\n<h3 class=\"h5\">平均勤続年数</h3>\n<p><span class=\"display-1 fw-bold\">20.4</span>年<br>\n<span class=\"small text-secondary\">（2025年4月時点）</span></p>\n</div>\n</div><!-- /.row -->\n</div><!-- /.collapse -->\n\n</div><!-- /.bg -->\n</div><!-- /.container -->\n</div><!-- /#header -->\n<!-- InstanceEndEditable -->\n<!-- InstanceBeginEditable name=\"content\" -->\n<div class=\"bg-slant bg-info py-5\">\n<div class=\"display-1 text-end text-white d-none d-sm-block title\">//<span class=\"fw-bold\">Benefits</span></div>\n<div class=\"container py-5 text-center\" id=\"benefits\">\n<h2 class=\"mb-5 h1 text-white\">福利厚生</h2>\n<div class=\"row text-white\">\n<div class=\"col-lg-3 px-4\">\n<i class=\"bi bi-journal-check display-1\"></i>\n<h3 class=\"fw-bold pt-3 pb-1\">社会保険完備</h3>\n<p class=\"text-start lh-lg\">健康保険、厚生年金、雇用保険、労働災害補償保険（労災）</p>\n</div>\n<div class=\"col-lg-3 px-4\">\n<i class=\"bi bi-balloon-heart display-1\"></i>\n<h3 class=\"fw-bold pt-3 pb-1\">育児支援</h3>\n<p class=\"text-start lh-lg\">育児休業、短時間勤務、時間外労働の免除および制限、子の看護休暇、子育て休暇</p>\n</div>\n<div class=\"col-lg-3 px-4\">\n<i class=\"bi bi-heart-pulse display-1\"></i>\n<h3 class=\"fw-bold pt-3 pb-1\">介護支援</h3>\n<p class=\"text-start lh-lg\">介護休業、短時間勤務、時間外労働の免除および制限、介護休暇</p>\n</div>\n<div class=\"col-lg-3 px-4\">\n<i class=\"bi bi-piggy-bank display-1\"></i>\n<h3 class=\"fw-bold pt-3 pb-1\">その他各種</h3>\n<p class=\"text-start lh-lg\">団体生命保険、財形貯蓄、住宅融資、大垣共立銀行健康保険組合、OKBの契約リゾートヴィラ多数</p>\n</div>\n</div><!-- /.row -->\n<p class=\"pt-4\"><a class=\"btn btn-outline-light shadow-sm\" href=\"../entry/internship.html\" target=\"_blank\" role=\"button\"><i class=\"bi bi-arrow-right-short\"></i>マイナビで詳しく見る</a></p>\n</div><!-- /.container -->\n</div><!-- /.gb-slant -->\n\n<div class=\"display-1 text-end text-info d-none d-sm-block title\">//<span class=\"fw-bold\">Training</span></div>\n<div class=\"container py-5 text-center\" id=\"training\">\n<h2 class=\"mb-5 h1\">研修制度</h2>\n<p class=\"lh-lg pb-5\">私たちは「人」が財産であり、社員の成長が企業の将来性を左右すると考えております。<br>\n総合的に優れた人材を育成するために<br>\n各種階層別研修のみならずライフプランにいたるまで充実した制度プログラムを設けています。</p>\n<div class=\"row text-white\">\n<div class=\"col-lg-3 mb-4\">\n<div class=\"bg-info rounded p-2 h-100\">\n<h3 class=\"fw-bold pt-3 pb-2\">内定〜入社</h3>\n<ul class=\"text-start\">\n<li>通信教育<small>（情報処理試験対策）</small></li>\n<li>ビジネスマナー</li>\n</ul>\n</div>\n</div>\n<div class=\"col-lg-3 mb-4\">\n<div class=\"bg-info rounded p-2 h-100\">\n<h3 class=\"fw-bold pt-3 pb-2\">新入社員</h3>\n<ul class=\"text-start\">\n<li>集合研修<small>（就業規則、コンプライアンス、各部の業務内容、ビジネスマナー、パソコン研修等）</small></li>\n<li>正社員研修</li>\n</ul>\n</div>\n</div>\n<div class=\"col-lg-3 mb-4\">\n<div class=\"bg-info rounded p-2 h-100\">\n<h3 class=\"fw-bold pt-3 pb-2\">入社3〜6年目</h3>\n<ul class=\"text-start\">\n<li>若手社員研修</li>\n<li>中堅社員研修</li>\n</ul>\n</div>\n</div>\n<div class=\"col-lg-3 mb-4\">\n<div class=\"bg-info rounded p-2 h-100\">\n<h3 class=\"fw-bold pt-3 pb-2\">入社8年目〜</h3>\n<ul class=\"text-start\">\n<li>キャリアアップ研修</li>\n<li>初級管理者研修</li>\n<li>中級管理者研修</li>\n<li>キャリア・ライフプラン研修</li>\n</ul>\n</div>\n</div>\n</div><!-- /.row -->\n<div class=\"row pt-3\">\n<div class=\"col-lg-6 text-info\">\n<h3 class=\"fw-bold py-3\">職業別研修</h3>\n<ul class=\"text-start\">\n<li>業務上必要な知識・技術習得のための外部研修<br>\n<small>（ITコンサルティング、プロジェクト管理、システム開発、プログラミング、ITリテラシー、OS、システム基盤、ネットワーク、セキュリティ、DB等他）</small></li>\n</ul>\n</div>\n<div class=\"col-lg-6 text-info\">\n<h3 class=\"fw-bold py-3\">自己啓発</h3>\n<ul class=\"text-start\">\n<li>資格取得支援<small>（通信教育、情報処理資格、ベンダー資格、簿記、ビジネスマナー等）</small></li>\n<li>報奨金制度<small>（推奨資格の合格者に対して報奨金を支給）</small></li>\n</ul>\n</div>\n</div><!-- /.row -->\n</div><!-- /.container -->\n\n<div class=\"bg-slant bg-info py-5\">\n<div class=\"display-1 text-end text-white d-none d-sm-block title\">//<span class=\"fw-bold\">New employee</span></div>\n<div class=\"container py-5 text-center\" id=\"new_employee\">\n<h2 class=\"mb-5 h1 text-white\">新入社員の研修内容</h2>\n<div class=\"row text-white\">\n<div class=\"col-lg-3 px-4\">\n<i class=\"bi bi-laptop display-1\"></i>\n<h3 class=\"fw-bold pt-3 pb-1\">業務研修</h3>\n<p>ロジック研修、プログラミング基礎</p>\n</div>\n<div class=\"col-lg-3 px-4\">\n<i class=\"bi bi-book display-1\"></i>\n<h3 class=\"fw-bold pt-3 pb-1\">コンプライアンス研修</h3>\n<p>就業規則や各種業務ルールについて</p>\n</div>\n<div class=\"col-lg-3 px-4\">\n<i class=\"bi bi-chat-square-heart display-1\"></i>\n<h3 class=\"fw-bold pt-3 pb-1\">QC・CS向上活動</h3>\n<p>品質、お客様満足活動</p>\n</div>\n<div class=\"col-lg-3 px-4\">\n<i class=\"bi bi-people display-1\"></i>\n<h3 class=\"fw-bold pt-3 pb-1\">アドバイザー制度</h3>\n<p>先輩社員が1年間マンツーマン教育</p>\n</div>\n</div><!-- /.row -->\n<div class=\"row pt-5\">\n<div class=\"col-md-4\">\n<p><img src=\"images/p04.jpg\" class=\"img-fluid rounded\" alt=\"研修\"></p>\n</div>\n<div class=\"col-md-4\">\n<p><img src=\"images/p03.jpg\" class=\"img-fluid rounded\" alt=\"研修\"></p>\n</div>\n<div class=\"col-md-4\">\n<p><img src=\"images/p05.jpg\" class=\"img-fluid rounded\" alt=\"アドバイザー制度\"></p>\n</div>\n</div><!-- /.row -->\n<div class=\"row align-items-center mt-5\">\n<div class=\"col-md-3\">\n<p class=\"mb-0 text-white\">\\ 何でも先輩に相談 /</p>\n<p><img src=\"../images/index_p03.png\" class=\"img-fluid\" alt=\"いち\"></p>\n</div>\n<div class=\"col-md-9 text-white lh-lg\">\n<p><span class=\"badge rounded-pill bg-light text-dark\">PickUp</span><span  class=\"fw-bold ms-2 h3 align-bottom\">アドバイザー制度とは？</span></p>\n<p class=\"text-start pt-2\">入社3年目以上の先輩社員が新入社員を指導する仕組みです。<br>\n開発・製造に関する知識や技術はもちろん、電話応対での言葉づかいをはじめ、社会人として大切なことについてマンツーマンで先輩社員がサポートします。</p>\n<p class=\"text-start\">新入社員の成長を支援するこの制度は、20年以上継続。<br>\n先輩から後輩へと引き継がれています。</p>\n<p class=\"text-center\"><a class=\"btn btn-outline-light shadow-sm\" href=\"../../journal/2022/10_adviser_note.html\" role=\"button\"><i class=\"bi bi-arrow-right-short\"></i>アドバイザー制度について詳しく知る</a></p>\n</div>\n</div><!-- /.row -->\n</div><!-- /.container -->\n</div><!-- /.gb-slant -->\n\n<div class=\"display-1 text-end text-info d-none d-sm-block title\">//<span class=\"fw-bold\">Schedule</span></div>\n<div class=\"container py-5 text-center\" id=\"best\">\n<h2 class=\"mb-5 h1\">入社後の研修スケジュール</h2>\n<p>2022年度は、以下のような日程で研修を行いました。</p>\n<div class=\"row pb-5 pt-4\">\n<div class=\"col-md-6\"><p><img src=\"images/p01.png\" class=\"img-fluid rounded\" alt=\"4月の研修\"></p></div>\n<div class=\"col-md-6\"><p><img src=\"images/p02.png\" class=\"img-fluid rounded\" alt=\"5月の研修\"></p></div>\n</div><!-- /.row -->\n<p>2022年度新入社員が選ぶ<br><span class=\"h1\">ベスト研修は...</span></p>\n<h3 class=\"display-1 pb-5 pt-3\">&#x1f947;<span class=\"fw-bold\">ロジック研修</span>&#x1f947;</h3>\n<div class=\"row pt-5\">\n<div class=\"col-md-4 mb-5\">\n<p class=\"mb-0\">\\ ソースコードの内容を理解できるようになった /</p>\n<p><img src=\"../images/index_p01.png\" class=\"img-fluid rounded-circle\" alt=\"てつ\"></p>\n<p>てつ<small>（2022年入社）</small></p>\n</div>\n<div class=\"col-md-4 mb-5\">\n<p class=\"mb-0\">\\ 社会人としてのマナーも学べた /</p>\n<p><img src=\"../images/index_p02.png\" class=\"img-fluid rounded-circle\" alt=\"なな\"></p>\n<p>なな<small>（2022年入社）</small></p>\n</div>\n<div class=\"col-md-4 mb-5\">\n<p class=\"mb-0\">\\ クラス図を描けるようになった /</p>\n<p><img src=\"../images/index_p03.png\" class=\"img-fluid rounded-circle\" alt=\"いち\"></p>\n<p>いち<small>（2023年入社）</small></p>\n</div>\n</div><!-- /.row -->\n</div><!-- /.container -->\n\n<div id=\"contact\">\n<div class=\"container py-5 text-center \">\n<h2 class=\"text-white fw-bold\">マイナビで情報公開中</h2>\n<p class=\"text-white pt-5\">会社概要・先輩情報・イベント情報の詳細をご覧いただけます。</p>\n<ul class=\"list-inline pt-4\">\n<li class=\"list-inline-item pb-3\"><a class=\"btn btn-info btn-lg shadow-sm\" href=\"../entry/internship.html\" role=\"button\" target=\"_blank\"><i class=\"bi bi-arrow-right-short\"></i>マイナビへのリンクはこちら</a></li>\n</ul><!-- /.list-inline -->\n</div><!-- /.container -->\n</div><!-- /.contact -->\n<!-- InstanceEndEditable -->\n<footer class=\"bg-info\">\n<div id=\"footer\"></div>\n</footer>\n<script src=\"https://code.jquery.com/jquery-3.7.1.min.js\" integrity=\"sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo=\" crossorigin=\"anonymous\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js\" integrity=\"sha384-geWF76RCwLtnZ8qwWowPQNguL3RmwHVBC9FhGdlKrxdiJJigb/j/68SIy3Te4Bkz\" crossorigin=\"anonymous\"></script>\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css\">\n<script src=\"https://cdnjs.cloudflare.com/ajax/libs/protonet-jquery.inview/1.1.2/jquery.inview.min.js\" integrity=\"sha512-D68mBFX2aQwVh2wV6uCDLmabIveaSQL3uVUo2Ze7VwxIeOcAd4C1/JagkVoObb/NLkYDrdvY3JHK1KOfenHVcA==\" crossorigin=\"anonymous\" referrerpolicy=\"no-referrer\"></script>\n<!-- InstanceBeginEditable name=\"added_js\" -->\n<script src=\"../js/default.js\"></script> \n<!-- InstanceEndEditable -->\n</body>\n<!-- InstanceEnd --></html>","finalUrl":"https://www.okb-kcs.co.jp/recruit/office/index.html","rendered":false,"_cachedAt":"2026-06-23T23:11:15.550Z"}