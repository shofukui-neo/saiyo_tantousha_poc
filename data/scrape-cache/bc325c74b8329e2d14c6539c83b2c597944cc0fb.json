w.miyazaki-group.com%2Frecruit%2F\" />\n<link rel=\"alternate\" type=\"text/xml+oembed\" href=\"http://www.miyazaki-group.com/wp-json/oembed/1.0/embed?url=http%3A%2F%2Fwww.miyazaki-group.com%2Frecruit%2F&#038;format=xml\" />\n</head>\n\n<body class=\"l-recruit\">\n  <div class=\"l-wrapper l-header__overlay\">\n    <header class=\"l-header\">\n      <div class=\"l-header__inner\">\n        <div class=\"l-header__head\">\n          <p class=\"l-header__logo\">\n            <a href=\"/\">\n              <img src=\"/assets/images/common/logo_corp_header.png\" alt=\"宮崎商店\">\n            </a>\n          </p>\n          <div class=\"l-header__nav-icon js-gnav-toggle\">\n            <span></span>\n          </div>\n        </div>\n\n        <nav class=\"l-header__body js-gnav-list\">\n          <ul class=\"l-header__list\">\n            <li class=\"l-header__item\">\n              <a class=\"l-header__link l-header__link--01\" href=\"/recruiting/\">リクルーティング</a>\n            </li>\n            <li class=\"l-header__item\">\n              <a class=\"l-header__link l-header__link--02\" href=\"/business/\">事業案内</a>\n            </li>\n            <li class=\"l-header__item\">\n              <a class=\"l-header__link l-header__link--03\" href=\"/company/\">会社案内</a>\n            </li>\n            <li class=\"l-header__item\">\n              <a class=\"l-header__link l-header__link--04\" href=\"https://www.talent-clip.jp/miyazaki-group/\" target=\"_blank\">採用情報</a>\n            </li>\n            <li class=\"l-header__item\">\n              <a class=\"l-header__link l-header__link--05\" href=\"/contact/\">お問い合わせ</a>\n            </li>\n            <li class=\"l-header__item l-header-sub\">\n              <span class=\"l-header__link l-header__link--fb js-fb-toggle\">Facebook</span>\n              <ul class=\"l-header-sub__list\">\n                <li class=\"l-header-sub__item\">\n                  <a class=\"l-header-sub__link\" href=\"https://www.facebook.com/%E5%AE%AE%E5%B4%8E%E5%95%86%E5%BA%97-2062845797276368/\" target=\"_blank\">Facebook 宮崎商店</a>\n                </li>\n                <li class=\"l-header-sub__item\">\n                  <a class=\"l-header-sub__link\" href=\"https://www.facebook.com/spasentoyukkomorioka/\" target=\"_blank\">Facebook ゆっこ盛岡</a>\n                </li>\n                <li class=\"l-header-sub__item is-no-link\">\n                  <a class=\"l-header-sub__link\">COMING SOON !</a>\n                </li>\n              </ul>\n            </li>\n          </ul>\n        </nav>\n      </div>\n    </header>\n\n    <section class=\"l-main\">\n\n      <div class=\"c-breadcrumb\">\n        <div class=\"c-inner\">\n          <ul class=\"c-breadcrumb__list\">\n            <li class=\"c-breadcrumb__item\"><a href=\"/\">HOME</a></li>\n            <li class=\"c-breadcrumb__item\">採用情報</li>\n          </ul>\n        </div>\n      </div>\n\n      <div class=\"l-contents\">\n        <section class=\"l-contents__box\">\n          <div class=\"l-contents__head\">\n            <div class=\"c-page-category\">\n              <p class=\"c-page-category__icon\">\n                <img src=\"/assets/images/common/icon_page_recruit.png\" alt=\"\">\n              </p>\n              <p class=\"c-page-category__txt\">RECRUIT</p>\n            </div>\n            <div class=\"c-hdg-lv1\">\n              <h1 class=\"c-hdg-lv1__txt\">採用情報</h1>\n            </div>\n          </div>\n\n          <div class=\"l-contents__body p-recruit\">\n            <div class=\"l-contents__inner\">\n\n              <section class=\"c-section\">\n                <div class=\"c-hdg-lv2\">\n                  <h2 class=\"c-hdg-lv2__txt\">新卒社員の募集について</h2>\n                </div>\n                                                                  \n\n                                              </section>\n\n              <section class=\"c-section\">\n                <div class=\"c-hdg-lv2\">\n                  <h2 class=\"c-hdg-lv2__txt\">中途採用の社員募集について</h2>\n                </div>\n                                                                  \n                    <p class=\"u-fs-small\">現在募集は行っておりません。</p>\n                  \n\n                                              </section>\n\n              <section class=\"c-section\">\n                <div class=\"c-hdg-lv2\">\n                  <h2 class=\"c-hdg-lv2__txt\">パートタイマーの募集について</h2>\n                </div>\n                                                                  \n                    <p class=\"u-fs-small\">フルサービススタンドで働きませんか</p>\n<p class=\"u-fs-small\">年齢・性別関係なく働けます！！</p>\n<p class=\"u-fs-small\">勤務時間・休日はお気軽にご相談ください。</p>\n                                                      <br>\n                  <p class=\"u-fs-small\">\n                  <strong>【時給】</strong>：850円～950円<br><strong>【資格】</strong>：高卒以上<br><strong>【仕事内容】</strong>：・給油作業（車の誘導・接客）　・洗車＆整備　・スタンド内の清掃など<br><strong>【待遇】</strong>：各種社保完備、制服貸与、車通勤可、正社員登用制度有、資格取得制度有<br><strong></strong>：<br><strong>【勤務地】</strong>：一方井ＳＳ（岩手町大字一方井14-168）<br><strong>【勤務時間】</strong>：7：00～19：00の間で応相談<br><strong></strong>：<br><strong>【勤務地】</strong>：岩手町ＳＳ（岩手町大字子抱6-35-1）<br><strong>【勤務時間】</strong>：7：00～20：00の間で応相談<br><strong></strong>：<br><strong>【応募・お問い合わせ】</strong>：℡019-613-7707　宮崎商店　総務部　高橋<br>                  </p>\n                  \n                                                                </section>\n\n            </div><!-- /.l-contents__inner -->\n\n          </div>\n        </section>\n\n\n      </div><!-- /.l-contents -->\n\n    </section><!-- /.l-main -->\n\n\n    <footer class=\"l-footer\">\n      <div class=\"l-footer__links\">\n        <p class=\"l-footer-links__corporate-logo\">\n          <a href=\"/\">\n            <img src=\"/assets/images/common/logo_corp_footer.png\" alt=\"宮崎商店 Miyazaki Syoten Ltd.\">\n          </a>\n        </p>\n        <nav class=\"l-footer-links__nav\">\n          <ul class=\"l-footer-links__list\">\n            <li class=\"l-footer-links__item\">\n              <a href=\"/privacy/\">個人情報保護方針</a>\n            </li>\n            <li class=\"l-footer-links__item\">\n              <a href=\"/sitemap.html\">サイトマップ</a>\n            </li>\n          </ul>\n        </nav>\n      </div>\n\n      <div class=\"l-footer__copyright\">\n        <p>\n          Copyright 2017(c) Miyazaki Syoten Co.,Ltd. All Rights Reserved.\n        </p>\n      </div>\n    </footer>\n  </div>\n\n  <script src=\"/assets/js/jquery-3.1.1.min.js\"></script>\n  <script src=\"/assets/js/jquery.easing.1.3.js\"></script>\n  <script src=\"/assets/js/slick.min.js\"></script>\n  <script src=\"/assets/js/jquery.fadethis.min.js\"></script>\n  <script src=\"/assets/js/common.js\"></script>\n\n<script type='text/javascript' src='http://www.miyazaki-group.com/wp-includes/js/wp-embed.min.js?ver=4.9.18'></script>\n\n</body>\n</html>\n","finalUrl":"http://www.miyazaki-group.com/recruit/","rendered":false,"_cachedAt":"2026-06-24T00:01:35.953Z"}