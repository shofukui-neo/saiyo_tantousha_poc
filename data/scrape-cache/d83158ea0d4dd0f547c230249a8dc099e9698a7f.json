</li>\r\n       <li><a href=\"../../../../../contact/index.html\">お問い合わせ</a></li>\r\n     </ul>\r\n \t  </div>\r\n  </nav>\r\n<!-- ----- nav End ----- -->\r\n\r\n\r\n \t\t</div>\r\n\t\r\n\t\t</header>\r\n \r\n<!-- ----- Header End ----- --> \r\n<!-- ----- Header End ----- -->\r\n\t\t\r\n\r\n<!-- InstanceBeginEditable name=\"Main\" -->\r\n\t\t\r\n<!-- ----- Main ----- -->\r\n\t\t\r\n<div id=\"page\">\r\n\t\r\n  <!-- ----- page_recruit ----- -->\r\n  <div class=\"List_bg\">\r\n    <div class=\"List List__recruit\">\r\n      <p><a href=\"../index.html\">HOME</a>　/　<a href=\"index.html\">採用情報TOP</a>　/　中途採用情報</p>\r\n    </div>\r\n  </div>\r\n  <div class=\"page_recruit_wrp pi_rec\">\r\n    <h2><span>まるなか建設株式会社</span><br>中途採用情報</h2>\r\n    <div class=\"rec_stit\">Mid Career</div>\r\n  </div>\r\n  <!-- ----- page_recruit End ----- -->\r\n\t\r\n\t\r\n\t\r\n\t\r\n  <!-- ----- Content ----- -->\r\n  <!-- ----- 中途 ----- -->\r\n\t\t<div class=\"np_wrp\">\r\n\t\t\t\t\r\n<!--中途採用情報へ切り替え-->\r\n\r\n\r\n<!--上記で指定した記事の件数を取得-->\r\n\r\n\t                    \r\n\t<!--アイキャッチ画像からURL取得-->\r\n\t\t\t\r\n\t<!--0詰めの日付表示用-->\r\n            \r\n    <!--現在の記事のカテゴリー情報を取得-->\r\n        \r\n\t<p>まるなか建設㈱では中途採用者の募集を行っています。<br />入社を希望される方は、電話またはメールにてまずはご連絡下さい。<br />面接等の日時を調整させていただきます。</p>\r\n\r\n<!-- 忘れずにリセットする必要がある -->\r\n   \t<div class=\"np_inner\">\r\n\r\n\t\t\t\t<h3>募集要項</h3>\r\n\t\t\t\t\r\n<!--中途採用情報へ切り替え-->\r\n\r\n\r\n<!--上記で指定した記事の件数を取得-->\r\n\r\n\t                    \r\n\t<!--アイキャッチ画像からURL取得-->\r\n\t\t\t\r\n\t<!--0詰めの日付表示用-->\r\n            \r\n    <!--現在の記事のカテゴリー情報を取得-->\r\n    \t\r\n      <section>\r\n      \t\t<h4>募集職種・募集人数</h4>\r\n        <dl class=\"list01\">\r\n\t\t\t<dt>土木技術職（施工管理）</dt>\r\n          \t<dd>若干名</dd>\r\n    \t\t<dt>建築技術職（施工管理）</dt>\r\n          \t<dd>若干名</dd>\r\n    \t\t<dt>建築技術職（設計）</dt>\r\n          \t<dd>若干名</dd>\r\n      \t\t<dt></dt>\r\n          \t<dd></dd>\r\n        </dl>\r\n      </section>\r\n      \t  \r\n\t\t<section>\r\n\t\t\t<h4>勤務地</h4>\r\n\t\t\t<p>松江市</p>\t\t</section>\r\n\r\n      <section>\r\n\t\t<h4>必要な資格</h4>\r\n\t\t<div class=\"np_license\">\r\n      \t\t<p>全職種（必須）</p><p>普通自動車運転免許 （技術職はAT限定不可・準中型自動車運転免許）<br />土木技術職 （施工管理）→ 1、2級土木施工管理技士</p><p>建築技術職 （施工管理・設計）<br />1、2級建築施工管理技士及び1、2級建築士<br />※資格が無い方でも、入社後に資格取得支援制度により取得可能</p>       \t</div>\r\n      </section>\r\n\r\n\t\t<section>\r\n  \t\t\t<h4>勤務条件・処遇</h4>\r\n\t\t\t<section>\r\n\t      \t\t<h5>給与</h5>\r\n\t\t\t\t<p>当社給与規程による（資格・経験により決定）</p>\t      \t</section>\r\n\r\n\t\t\t<section>\r\n\t      \t\t<h5>諸手当</h5>\r\n\t        <p>通勤、家族、資格、役職、職務、作業、現場手当 等</p>\t      </section>\r\n\r\n\t\t<section>\r\n\t      \t\t<h5>昇給</h5>\r\n\t        <p>年１回（４月）</p>\t      </section>\r\n\r\n\t\t<section>\r\n\t      \t\t<h5>賞与</h5>\r\n\t        <p>年２回（６月､１２月）</p>\t      </section>\r\n\r\n\r\n\r\n\t\t<section>\r\n\t      \t\t<h5>勤務時間</h5>\r\n\t        <p>8時00分～17時00分<br />※休憩12時00～13時00分</p>\t      </section>\r\n\r\n\t\t<section>\r\n\t      \t\t<h5>休日・休暇</h5>\r\n\t        <p>土日（完全週休二日制）<br />盆､年末年始（年間休日：124日）<br />有給休暇<br />特別休暇（結婚休暇、服喪休暇、裁判員休暇、ボランティア休暇、業務上傷病・通勤傷病待機休暇、産前産後休暇、生理休暇、子の看護休暇、出産補助休暇、母性健康管理休暇、傷病休暇、育児休業、介護休業）</p>\t      </section>\r\n\r\n\t\t<section>\r\n\t      \t\t<h5>定年</h5>\r\n\t        <p>60歳（65歳まで継続雇用制度あり）</p>\t      </section>\r\n\r\n\t\t<section>\r\n\t      \t\t<h5>退職金</h5>\r\n\t        <p>建設業退職金共済､中小企業退職金共済､確定拠出年金</p>\t      </section>\r\n\r\n\t\t<section>\r\n\t      \t\t<h5>研修制度</h5>\r\n\t        <p>新入社員研修､部門別研修､メンタルヘルス研修、ハラスメント研修 等</p>\t      </section>\r\n\r\n\t\t<section>\r\n\t      \t\t<h5>福利厚生</h5>\r\n\t        <p>国内外研修旅行､インフルエンザ予防接種費用負担､福利厚生倶楽部利用サービス､ノー残業デー、クラブ活動（軟式野球部･剣道部）、特別支給（クリスマスケーキ代、正月お菓子代、お年始料、お花見料）</p>\t      </section>\r\n\r\n\t\t<section>\r\n\t      \t\t<h5>働き方改革</h5>\r\n\t        <p>ノー残業デー（毎週水曜日、給料日）<br />年休取得年間計画事前申請制度<br />入社時年休５日付与</p>\t      </section>\r\n\r\n\t\t<section>\r\n\t      \t\t<h5>借上げ社宅制度</h5>\r\n\t        <p>有　　※支給条件あり</p>\t      </section>\r\n  \t</section>\r\n\r\n\r\n<!-- 忘れずにリセットする必要がある -->\r\n    </div>\r\n\r\n  </div>\r\n\t\r\n\