ist -->\n    </section>\n\n    <section class=\"parts-section-info\">\n      <div class=\"com-section-inner\">\n        <div class=\"info-detail-wrap\">\n\n                                                <div class=\"info-category-wrap\">\n                <ul class=\"mod-panel-layout info-category-item\">\n                  <li>\n                    <span style=\"color:#023455;background-color:#edf1f2\">\n                      イベント                    </span>\n                  </li>\n                </ul>\n              </div>\n\n                      \n          <div class=\"info-title\">\n            <h1 class=\"title\">山陽測器フェア2026in山口を開催しました</h1>\n            <p class=\"day\">2026.06.15</p>\n          </div>\n\n          <div class=\"info-body\">\n            <div class=\"def-editor-style-wrap\">\n            <!-- ▼ editor area ▼ -->\n\n                                                                                  <div class=\"mod-clearfix edt-L-img-R-text\">\n                      <div class=\"img-block\">\n                                                                          <img src=\"/upload/save/info/layout/5a5829c4b963c7336654841bbd5ac03d.jpg\" alt=\"001\">\n                                              </div>\n                      <div class=\"text-block\">\n                                                <p class=\"text\">6月10日　山陽測器フェア2026in山口を周南市地場産業振興センターで開催いたしました。<br>\n<br>\n屋内では業務効率改善に役立つCPDSセミナーと最新のソリューションの展示や体験会。<br>\n屋外では快測ナビ＋やFIELD-TERRACEとの連携で簡易3DマシンガイダンスシステムとなるHolfee3Dの実機展示を行いました。</p>\n                      </div>\n                    </div>\n                    <!-- End .edt-L-img-R-text -->\n\n                                                                        <div class=\"mod-clearfix edt-C-img\">\n                      <div class=\"img-block\">\n                                                                          <img src=\"/upload/save/info/layout/a581b30dd26a4015dc52253ca3b870f5.jpg\" alt=\"002\">\n                                              </div>\n                    </div>\n                    <!-- End .edt-C-img -->\n\n                                                                        <div class=\"mod-clearfix edt-C-img\">\n                      <div class=\"img-block\">\n                                                                          <img src=\"/upload/save/info/layout/fac923352ea5d91c89a3f1a6f01cb2ba.jpg\" alt=\"003\">\n                                              </div>\n                    </div>\n                    <!-- End .edt-C-img -->\n\n                                                                        <div class=\"mod-clearfix edt-C-img\">\n                      <div class=\"img-block\">\n                                                                          <img src=\"/upload/save/info/layout/c057a051622c30ba3c296ea1ac947d16.jpg\" alt=\"004\">\n                                              </div>\n                    </div>\n                    <!-- End .edt-C-img -->\n\n                                                                        <div class=\"mod-clearfix edt-C-img\">\n                      <div class=\"img-block\">\n                                                                          <img src=\"/upload/save/info/layout/0fe150baaaa9f7641cac118ae436b8a0.jpg\" alt=\"005\">\n                                              </div>\n                    </div>\n                    <!-- End .edt-C-img -->\n\n                                                                        <div class=\"mod-clearfix edt-C-img\">\n                      <div class=\"img-block\">\n                                                                          <img src=\"/upload/save/info/layout/191fa7a0e88da9dbd594d45113ec98b1.jpg\" alt=\"006\">\n                                              </div>\n                    </div>\n                    <!-- End .edt-C-img -->\n\n                                                                        <div class=\"mod-clearfix edt-C-img\">\n                      <div class=\"img-block\">\n                                                                          <img src=\"/upload/save/info/layout/cdf3b7351a7804e192ff5c2bb70f0b83.jpg\" alt=\"007\">\n                                              </div>\n                    </div>\n                    <!-- End .edt-C-img -->\n\n                                                                        <div class=\"mod-clearfix edt-C-img\">\n                      <div class=\"img-block\">\n                                                                          <img src=\"/upload/save/info/layout/190b15883125f590c64ac529601164de.jpg\" alt=\"008\">\n                                              </div>\n                    </div>\n                    <!-- End .edt-C-img -->\n\n                                                                        <div class=\"mod-clearfix edt-L-img-R-text\">\n                      <div class=\"img-block\">\n                                                                          <img src=\"/upload/save/info/layout/ad6ea94e77424f8be1e6859d0377279a.jpg\" alt=\"009\">\n                                              </div>\n                      <div class=\"text-block\">\n                                                <p class=\"text\">多数のお客様にご来場いただき、山陽測器フェアin山口を終える事ができました。<br>\n<br>\nご来場いただきました皆さま、前日の広島会場より引き続きご協力頂きましたメーカー様には心より御礼申し上げます。</p>\n                      </div>\n                    </div>\n                    <!-- End .edt-L-img-R-text -->\n\n                                                \n            <!-- ▲ editor area ▲ -->\n            </div>\n            <!-- End .def-editor-style-wrap -->\n          </div>\n\n        </div>\n        <!-- End .info-body-block -->\n        <div class=\"btn-block back-arrow-style\">\n          <a href=\"/infos/\">\n            <span>一覧へ戻る</span>\n          </a>\n        </div>\n      </div>\n    </section>\n\n  </article>\n  <!-- End #lay-article -->\