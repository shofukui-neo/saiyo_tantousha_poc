up-image\" media=\"(device-width: 768px) and (device-heig) 1024px) and (orientation: portrait) and (-webkit-device-pixel-ratio: 2)\" href=\"../profiles/shimadzu/themes/shimadzu/favicons/apple-touch-startup-image-1536x2008.png\">\r\n<title>会社案内 | 島津産機システムズ株式会社</title>\r\n<meta name=\"description\" content=\"島津産機システムズ、会社案内のページです。\" />\r\n<meta name=\"keywords\" content=\"島津産機システムズ,島津,会社案内,概要,沿革,アクセス\" />\r\n\r\n<style type=\"text/css\" media=\"all\">\r\n@import url(\"../profiles/shimadzu/themes/shimadzu/css/style.css?oru9ct\");\r\n</style>\r\n<style type=\"text/css\" media=\"all\">\r\n@import url(\"../css/reset.css\");\r\n@import url(\"../css/layout.css\");\r\n@import url(\"../css/module.css\");\r\n@import url(\"../css/local.css\");\r\n@import url(\"../css/responsive.css\");\r\n</style>\r\n<script type=\"text/javascript\" src=\"../misc/jquery.js?v=1.4.4\"></script>\r\n</head>\r\n\r\n<body id=\"pagetop\" class=\"page--top\">\r\n<div id=\"wrapper\" data-hierarchy=\"1\">\r\n<header id=\"gHeader\"> \r\n\t<!-- Page Header Region START-->\r\n\t<section id=\"head\">\r\n\t\t<div class=\"container\">\r\n\t\t\t<h1 id=\"logo\"><a href=\"../index.html\">SHIMADZU</a></h1>\r\n\t\t\t<a id=\"js-header-menu-trigger\" class=\"header-menu\" href=\"javascript:void(0)\" onclick=\"toggleClass(this, &#039;is_active&#039;); toggleClass(document.getElementById(&#039;js-globalNav_mobile&#039;), &#039;is_active&#039;)\">\r\n\t\t\t\t<span class=\"header-menu-item\"></span>\r\n\t\t\t\t<span class=\"header-menu-item\"></span>\r\n\t\t\t\t<span class=\"header-menu-item\"></span>\r\n\t\t\t</a>\r\n\t\t\t<div class=\"companyName\"><img src=\"../images/common/company_logo.png\" alt=\"島津産機システムズ株式会社\"></div>\r\n\t\t\t<div class=\"util--pc\">\r\n\t\t\t\t<ul class=\"utilNav utilNav-inner-col-02\">\r\n\t\t\t\t\t<li class=\"utilNav-top-adjust-item utilNav-top-adjust-item-03\"><a href=\"../english/index.html\">ENGLISH</a></li>\r\n\t\t\t\t\t<li><a href=\"https://www.shimadzu.co.jp/aboutus/company/sub.html\" target=\"_blank\"><i class=\"custom-icon icon-shimadzu-logo\"></i>島津製作所グループ</a></li>\r\n\t\t\t\t</ul>\r\n\t\t\t\t<ul class=\"fixNav\">\r\n\t\t\t\t\t<li><a href=\"../english/index.html\">ENGLISH</a></li>\r\n\t\t\t\t</ul>\r\n\t\t\t</div>\r\n\t\t</div>\r\n\t</section>\r\n\t<!-- Page Header Region END--> \r\n\t<!-- Global Nav Region START-->\r\n\t<div>\r\n\t\t<nav id=\"gnav\"></nav>\r\n\t\t<script type=\"text/javascript\" src=\"../js/global_nav.js\"></script>\r\n\t</div>\r\n\t<!-- Global Nav Region START-->\r\n\t<div class=\"util\">\r\n\t\t<ul class=\"utilNav utilNav-inner-col-02\">\r\n\t\t\t<li class=\"utilNav-top-adjust-item utilNav-top-adjust-item-03\"><a href=\"../english/index.html\">ENGLISH</a></li>\r\n\t\t\t<li><a href=\"https://www.shimadzu.co.jp/aboutus/company/sub.html\" target=\"_blank\"><i class=\"custom-icon icon-shimadzu-logo\"></i>島津製作所グループ</a></li>\r\n\t\t</ul>\r\n\t</div>\r\n</header>\r\n<!-- /Header -->\r\n\r\n<div class=\"blockSankiContents\">\r\n\t<div class=\"blockPageTitle\">\r\n\t\t<div class=\"titleTxtBox\">\r\n\t\t\t<p class=\"titleTxtBox__txt\">会社案内</p>\r\n\t\t</div>\r\n\t</div>\r\n\r\n\t<div class=\"pan_naviBox\">\r\n\t\t<div class=\"pan_navi\">\r\n\t\t\t<ul>\r\n\t\t\t\t<li><a href=\"../\" class=\"form\">ホーム</a>&nbsp;</li>\r\n\t\t\t\t<li>&gt;&nbsp;会社案内</li>\r\n\t\t\t</ul>\r\n\t\t</div>\r\n\t</div>\r\n\r\n\t<div class=\"blockContentsWrap\">\r\n\r\n\t\t<div class=\"contentsBox\">\r\n\t\t\t<div class=\"section__inner\">\r\n\t\t\t\t<h2 class=\"modHlLv2\">社長メッセージ</h2>\r\n\t\t\t\t<h3 class=\"modHlLv3\">めざすは顧客のベストパートナーへ</h3>\r\n\t\t\t\t<div class=\"narrowBox\">\r\n\t\t\t\t\r\n\t\t\t\t    <div style=\"text-align: center; margin: 20px 0 30px 0;\"><img src=\"../images/company/img_president.jpg\" alt=\"社長あいさつ\" /></div>\r\n\t\t\t\t\t<p class=\"modTxt01\">　島津産機システムズは、2018年4月に株式会社島津製作所100%出資会社である島津エミットと島津メクテムが両社の持つ産業インフラ機器事業を統合し誕生いたしました。我々は、1962年の創業以来、常に高度な技術と熟練の技を駆使し、豊かな暮らしや社会の発展に貢献するべく研鑽を重ねてまいりました。長年蓄積された技術から、現在では真空／熱処理技術、真空検査技術、動釣合試験技術、高粘度/高圧液送技術、高速回転制御技術、電動バルブ制御技術、潤滑油圧送技術など、多数のコア技術を保有しています。</p>\r\n\t\t\t\t\t<p class=\"modTxt01\" style=\"text-align: right;\"><strong>代表取締役社長　小西 昭士</strong></p>\r\n\t\t\t\t</div>\r\n\t\t\t</div>\r\n\r\n\t\t\t<div class=\"section__inner\" id=\"outline\">\r\n\t\t\t\t<h2 class=\"modHlLv2\">概要</h2>\r\n\t\t\t\t<div class=\"modTbl01Wrap\">\r\n\t\t\t\t\t<table class=\"modTbl01\">\r\n\t\t\t\t\t\t<tbody>\r\n\t\t\t\t\t\t\t<tr>\r\n\t\t\t\t\t\t\t\t<th>商　　　号</th>\r\n\t\t\t\t\t\t\t\t<td>島津産機システムズ株式会社</td>\r\n\t\t\t\t\t\t\t</tr>\r\n\t\t\t\t\t\t\t<tr>\r\n\t\t\t\t\t\t\t\t<th>社　　　是</th>\r\n\t\t\t\t\t\t\t\t<td>常に新しい価値を創造して、社会に貢献する</td>\r\n\t\t\t\t\t\t\t</tr>\r\n\t\t\t\t\t\t\t<tr>\r\n\t\t\t\t\t\t\t\t<th>設　　　立</th>\r\n\t\t\t\t\t\t\t\t<td>1962年</td>\r\n\t\t\t\t\t\t\t</tr>\r\n\t\t\t\t\t\t\t<tr>\r\n\t\t\t\t\t\t\t\t<th>資　本　金</th>\r\n\t\t\t\t\t\t\t\t<td>1億円（島津製作所 100%出資）</td>\r\n\t\t\t\t\t\t\t</tr>\r\n\t\t\t\t\t\t\t<tr>\r\n\t\t\t\t\t\t\t\t<th>従　業　員</th>\r\n\t\t\t\t\t\t\t\t<td>277名</td>\r\n\t\t\t\t\t\t\t</tr>\r\n\t\t\t\t\t\t\t<tr>\r\n\t\t\t\t\t\t\t\t<th>本社所在地</th>\r\n\t\t\t\t\t\t\t\t<td>520-2152　滋賀県大津市月輪一丁目8番1号<br>\r\n\t\t\t\t\t\t\t\tTEL：077-545-3250(代表)　FAX：077-545-8275\r\n</td>\r\n\t\t\t\t\t\t\t</tr>\r\n\t\t\t\t\t\t\t<tr>\r\n\t\t\t\t\t\t\t\t<th>支店・工場</th>\r\n\t\t\t\t\t\t\t\t<td>\r\n\t\t\t\t\t\t\t\t<p class=\"mt20\" style=\"margin-bottom: 20px;\"><a href=\"../contact/\">製品別お問い合わせ先TEL・FAXはこちら</a></p>\r\n\t\t\t\t\t\t\t\t■ 東京支店<br />\r\n                                101-0042　東京都千代田区神田東松下町47番地1（Daiwa神田イーストビル9階）<br /><br />\r\n                                ■ 大阪支店<br />\r\n                                532-0003　大阪市淀川区宮原三丁目5番24号（新大阪第一生命ビル8階）<br />\r\n                                TEL：06-6393-0110(代表)<br /><br />\r\n\r\n\r\n                                ■ 熊本営業所<br />\r\n                                熊本県菊池郡菊陽町光の森5丁目9-18<br />\r\n                                クリアモンテビル １階A号室<br />\r\n                                TEL：096-243-1332　FAX：096-243-1333<br /><br />\r\n\r\n\r\n                                ■ 本社工場<br />\r\n                                520-2152　滋賀県大津市月輪一丁目8番1号<br />\r\n                                ・工業炉・工機　TEL：077-545-3250　FAX：077-545-8275<br />\r\n                                ・バランサー　TEL：077-545-2073　FAX：077-545-2074<br />\r\n                                ・草津分工場<br />\r\n                                525-0071　滋賀県草津市南笠東一丁目3番43号<br />\r\n                                TEL：077-561-5504　FAX：077-561-5506<br /><br />\r\n\r\n                                ■ 秦野工場<br />\r\n                                259-1304　神奈川県秦野市堀山下380番1号<br />\r\n                                TEL：0463-88-8588　FAX：0463-88-8528<br /><br />\r\n\r\n                                ■ 寧波島津真空技術開発有限公司<br />\r\n                                315336　中華人民共和国浙江省慈渓経済開発区（杭州湾新区）濱海三路規劃支路<br />\r\n                                TEL：+86-574-2371-1337　FAX：+86-574-2371-1339\r\n\t\t\t\t\t\t\t\t</td>\r\n\t\t\t\t\t\t\t</tr>\r\n\t\t\t\t\t\t\t<tr>\r\n\t\t\t\t\t\t\t\t<th>役　　　員</th>\r\n\t\t\t\t\t\t\t\t<td>\r\n\t\t\t\t\t\t\t\t\t<ul class=\"officerWrap\">\r\n\t\t\t\t\t\t\t\t\t\t<li class=\"officer__item\">代表取締役社長　小西　昭士</li>\r\n\t\t\t\t\t\t\t\t\t\t<li class=\"officer__item\">取　締　役　山本　喜代之</li>\r\n\t\t\t\t\t\t\t\t\t\t<li class=\"officer__item\">取締役<span class=\"officer__item__fss\">（非常勤）</span>　濱田　隆雄</li>\r\n\t\t\t\t\t\t\t\t\t\t<li class=\"officer__item\">取締役<span class=\"officer__item__fss\">（非常勤）</span>　河村　真一</li>\r\n\t\t\t\t\t\t\t\t\t\t<li class=\"officer__item\">監査役<span class=\"officer__item__fss\">（非常勤）</span>　塩谷　暢教</li>\r\n\t\t\t\t\t\t\t\t\t</ul>\r\n\t\t\t\t\t\t\t\t\t<ul class=\"officerWrap\">\r\n\t\t\t\t\t\t\t\t\t\t<li class=\"officer__item\">執行役員　高橋　伯征</li>\r\n\t\t\t\t\t\t\t\t\t\t<li class=\"officer__item\">執行役員　河西　敬祐</li>\r\n\t\t\t\t\t\t\t\t\t\t<li class=\"officer__item\">執行役員　岡田　元博</li>\r\n\t\t\t\t\t\t\t\t\t</ul>\r\n\t\t\t\t\t\t\t\t</td>\r\n\t\t\t\t\t\t\t</tr>\r\n\t\t\t\t\t\t</tbody>\r\n\t\t\t\t\t</table>\r\n\t\t\t\t</div>\r\n\t\t\t</div>\r\n\r\n\t\t\t<div class=\"section__inner\">\r\n\t\t\t\t<h2 class=\"modHlLv2\">沿革</h2>\r\n\t\t\t\t<table class=\"modTbl02\">\r\n\t\t\t\t\t<tbody>\r\n\t\t\t\t\t\t<!--<tr>\r\n\t\t\t\t\t\t\t<th>&nbsp;</th>\r\n\t\t\t\t\t\t\t<th class=\"companyCell\">メクテムカンパニーエミットカンパニー</th>\r\n\t\t\t\t\t\t</tr>-->\r\n\t\t\t\t\t\t<tr>\r\n\t\t\t\t\t\t\t<th>1962年 1月</th>\r\n\t\t\t\t\t\t\t<td>（株）島津製作所から鋳造事業を分離し、現在地に島津金属工業（株）を設立、各種鋳造製品の製造を開始。</td>\r\n\t\t\t\t\t\t</tr>\r\n\t\t\t\t\t\t<tr>\r\n\t\t\t\t\t\t\t<th>1965年 4月</th>\r\n\t\t\t\t\t\t\t<td>機械加工部門を併設し、工業用X線検査装置の製造を開始。</td>\r\n\t\t\t\t\t\t</tr>\r\n\t\t\t\t\t\t<tr>\r\n\t\t\t\t\t\t\t<th>1973年 3月</th>\r\n\t\t\t\t\t\t\t<td>（株）島津製作所 機械事業部製品の紡績用ワインダと液送機器の販売・サービス会社として、資本金5百万円をもって島製機械（株）設立。</td>\r\n\t\t\t\t\t\t</tr>\r\n\t\t\t\t\t\t<tr>\r\n\t\t\t\t\t\t\t<th>1977年 3月</th>\r\n\t\t\t\t\t\t\t<td>（株）島津製作所から動力伝導装置（歯車機器）の製造部門を分離し、現在地内に（株）湖南製作所が移転され、動力伝導装置の製造を開始。</td>\r\n\t\t\t\t\t\t</tr>\r\n\t\t\t\t\t\t<tr>\r\n\t\t\t\t\t\t\t<th>1984年 4月</th>\r\n\t\t\t\t\t\t\t<td>社名を島津金属精工（株）と改称し、（株）湖南製作所の全事業を併合。</td>\r\n\t\t\t\t\t\t</tr>\r\n\t\t\t\t\t\t<tr>\r\n\t\t\t\t\t\t\t<th>1987年 4月</th>\r\n\t\t\t\t\t\t\t<td>（株）島津製作所から非破壊検査装置の製造権の移管を受け、各種産業用非破壊検査装置の製造を開始。</td>\r\n\t\t\t\t\t\t</tr>\r\n\t\t\t\t\t\t<tr>\r\n\t\t\t\t\t\t\t<th>1988年 3月</th>\r\n\t\t\t\t\t\t\t<td>鋳造事業から撤退。</td>\r\n\t\t\t\t\t\t</tr>\r\n\t\t\t\t\t\t<tr>\r\n\t\t\t\t\t\t\t<th>1992年 4月</th>\r\n\t\t\t\t\t\t\t<td>島製機械（株）のサービス部門と島津計装（株）（現島津システムソリューションズ（株））の一部門が統合し、資本金2千万円をもって島津産機サービス（株）創業。</td>\r\n\t\t\t\t\t\t</tr>\r\n\t\t\t\t\t\t<tr>\r\n\t\t\t\t\t\t\t<th>1993年 5月</th>\r\n\t\t\t\t\t\t\t<td>（株）島津製作所から工業炉の事業譲渡を受け、各種真空脱脂焼結・焼成炉等の製造を開始。</td>\r\n\t\t\t\t\t\t</tr>\r\n\t\t\t\t\t\t<tr>\r\n\t\t\t\t\t\t\t<th>1994年 4月</th>\r\n\t\t\t\t\t\t\t<td>社名を島津メクテム（株）と改称。</td>\r\n\t\t\t\t\t\t</tr>\r\n\t\t\t\t\t\t<tr>\r\n\t\t\t\t\t\t\t<th>1994年10月</th>\r\n\t\t\t\t\t\t\t<td>島津産機サービス（株）を存続会社、島製機械（株）を消滅会社として統合合併し、資本金4千万円をもって島津エミット（株）設立。</td>\r\n\t\t\t\t\t\t</tr>\r\n\t\t\t\t\t\t<tr>\r\n\t\t\t\t\t\t\t<th>1997年 7月</th>\r\n\t\t\t\t\t\t\t<td>神奈川県秦野市内秦野工場を開設し、操業を開始。</td>\r\n\t\t\t\t\t\t</tr>\r\n\t\t\t\t\t\t<tr>\r\n\t\t\t\t\t\t\t<th>1998年10月</th>\r\n\t\t\t\t\t\t\t<td>（株）島津製作所から歯車液送機器、ガラスワインダー等、産業機械業種の製造を受託。</td>\r\n\t\t\t\t\t\t</tr>\r\n\t\t\t\t\t\t<tr>\r\n\t\t\t\t\t\t\t<th>1999年 2月</th>\r\n\t\t\t\t\t\t\t<td>島津メクテムISO9001の認証取得。</td>\r\n\t\t\t\t\t\t</tr>\r\n\t\t\t\t\t\t<tr>\r\n\t\t\t\t\t\t\t<th>2001年 2月</th>\r\n\t\t\t\t\t\t\t<td>島津エミットISO9001の認証取得。</td>\r\n\t\t\t\t\t\t</tr>\r\n\t\t\t\t\t\t<tr>\r\n\t\t\t\t\t\t\t<th>2001年 3月</th>\r\n\t\t\t\t\t\t\t<td>動力伝導装置事業から撤退。</td>\r\n\t\t\t\t\t\t</tr>\r\n\t\t\t\t\t\t<tr>\r\n\t\t\t\t\t\t\t<th>2001年 4月</th>\r\n\t\t\t\t\t\t\t<td>広島市内に広島営業所、名古屋市内に名古屋営業所を開設し、全機種取扱の営業を開始。</td>\r\n\t\t\t\t\t\t</tr>\r\n\t\t\t\t\t\t<tr>\r\n\t\t\t\t\t\t\t<th>2001年 7月</th>\r\n\t\t\t\t\t\t\t<td>ISO14001の認証取得。</td>\r\n\t\t\t\t\t\t</tr>\r\n\t\t\t\t\t\t<tr>\r\n\t\t\t\t\t\t\t<th>2005年12月</th>\r\n\t\t\t\t\t\t\t<td>中国浙江省に真空工業炉製造の合弁会社を設立。</td>\r\n\t\t\t\t\t\t</tr>\r\n\t\t\t\t\t\t<tr>\r\n\t\t\t\t\t\t\t<th>2006年12月</th>\r\n\t\t\t\t\t\t\t<td>合弁を解消し寧波島津真空技術開発有限公司として発足。</td>\r\n\t\t\t\t\t\t</tr>\r\n\t\t\t\t\t\t<tr>\r\n\t\t\t\t\t\t\t<th>2007年 4月</th>\r\n\t\t\t\t\t\t\t<td>（株）島津製作所から産業機械業種の事業譲渡を受ける。</td>\r\n\t\t\t\t\t\t</tr>\r\n\t\t\t\t\t\t<tr>\r\n\t\t\t\t\t\t\t<th>2010年 3月</th>\r\n\t\t\t\t\t\t\t<td>寧波島津真空技術開発有限公司の新工場竣工。</td>\r\n\t\t\t\t\t\t</tr>\r\n\t\t\t\t\t\t<tr>\r\n\t\t\t\t\t\t\t<th>2012年 5月</th>\r\n\t\t\t\t\t\t\t<td>（株）島津製作所から非破壊検査装置の一部機種移管を受ける。</td>\r\n\t\t\t\t\t\t</tr>\r\n\t\t\t\t\t\t<tr>\r\n\t\t\t\t\t\t\t<th>2013年 3月</th>\r\n\t\t\t\t\t\t\t<td>寧波島津真空技術開発有限公司の事務棟竣工。</td>\r\n\t\t\t\t\t\t</tr>\r\n\t\t\t\t\t\t<tr>\r\n\t\t\t\t\t\t\t<th>2013年 4月</th>\r\n\t\t\t\t\t\t\t<td>（株）島津製作所 半導体装置、ヘリウムリークディテクタ機種の移管を受ける。</td>\r\n\t\t\t\t\t\t</tr>\r\n\t\t\t\t\t\t<tr>\r\n\t\t\t\t\t\t\t<th>2013年12月</th>\r\n\t\t\t\t\t\t\t<td>本社新社屋竣工。</td>\r\n\t\t\t\t\t\t</tr>\r\n\t\t\t\t\t\t<tr>\r\n\t\t\t\t\t\t\t<th>2014年 4月</th>\r\n\t\t\t\t\t\t\t<td>島津エミット本店・京都工場を（株）島津製作所 紫野工場内より、（株）島津製作所 瀬田工場内に移転し、本店 瀬田工場とした。</td>\r\n\t\t\t\t\t\t</tr>\r\n\t\t\t\t\t\t<tr>\r\n\t\t\t\t\t\t\t<th>2017年 7月</th>\r\n\t\t\t\t\t\t\t<td>湘南島津（株）から事業移管を受け、動釣合試験機（バランシングマシン）の開発・製造・販売の事業を開始。それに伴い、紫野工場、京都営業所、秦野営業所、韓国支店を開設。</td>\r\n\t\t\t\t\t\t</tr>\r\n\t\t\t\t\t\t<tr>\r\n\t\t\t\t\t\t\t<td colspan=\"2\" class=\"tac\">2018年 4月　島津メクテム（株）・島津エミット（株）が統合合併、<strong>島津産機システムズ株式会社</strong> 発足</td>\r\n\t\t\t\t\t\t</tr>\r\n\t\t\t\t\t\t<tr>\r\n\t\t\t\t\t\t\t<th>2021年 5月</th>\r\n\t\t\t\t\t\t\t<td>動釣合試験機（バランシングマシン）の開発・製造機能を紫野工場から移転し、本社工場に集約</td>\r\n\t\t\t\t\t\t</tr>\r\n\t\t\t\t\t\t<tr>\r\n\t\t\t\t\t\t\t<th>2023年 5月</th>\r\n\t\t\t\t\t\t\t<td>制御生産機能を本社工場から、本社工場（草津分工場）へ移転</td>\r\n\t\t\t\t\t\t</tr>\r\n\t\t\t\t\t\t<tr>\r\n\t\t\t\t\t\t\t<th>2024年 4月</th>\r\n\t\t\t\t\t\t\t<td>非破壊検査装置の製造を（株）島津製作所へ移管</td>\r\n\t\t\t\t\t\t</tr>\r\n\t\t\t\t\t</tbody>\r\n\t\t\t\t</table>\r\n\t\t\t</div>\r\n\r\n\t\t\t<div class=\"section__inner section__inner--spwid100\" id=\"access\">\r\n\t\t\t\t<h2 class=\"modHlLv2\">アクセス</h2>\r\n\t\t\t\t<div class=\"accessBox\">\r\n\t\t\t\t\t<h3 class=\"accessBox__ttl\">本社・工場</h3>\r\n\t\t\t\t\t<p class=\"modTxt01\">〒520-2152　<br class=\"spOnly\">滋賀県大津市月輪一丁目8番1号<br>\r\n\t\t\t\t\tTEL 077-545-3250（代表） / <br class=\"spOnly\">FAX 077-545-8275<br>\r\n\t\t\t\t\t大津市・JR瀬田駅から草津方面行バス3分</p>\r\n\t\t\t\t\t<div class=\"accessBox__btnBox\">\r\n\t\t\t\t\t\t<a href=\"https://goo.gl/maps/FmXXhMt2MtS2\" target=\"_blank\" class=\"modBtn01\">地図を表示</a>\r\n\t\t\t\t\t</div>\r\n\t\t\t\t</div>\r\n\t\t\t</div>\r\n\r\n\t\t</div>\r\n\t</div>\r\n</div>\r\n<footer> \r\n\t<!-- Page Footer Region START-->\r\n\t<div class=\"container\">\r\n\t\t<ul class=\"links\">\r\n\t\t\t<li><a href=\"../privacy.html\">プライバシーポリシー</a></li>\r\n\t\t\t<li><a href=\"../attention.html\">ご利用上の注意</a></li>\r\n\t\t\t<li><a href=\"../sitemap.html\">サイトマップ</a></li>\r\n\t\t</ul>\r\n\t\t<p class=\"copyright\"><img class=\"spOnly\" src=\"../images/common/copyright_sp.png\" alt=\"Copyright(C) Shimadzu Industrial Systems Co., Ltd. All Rights Reserved.\"><img class=\"pcOnly\" src=\"../images/common/copyright_pc.png\" alt=\"Copyright(C) Shimadzu Industrial Systems Co., Ltd. All Rig