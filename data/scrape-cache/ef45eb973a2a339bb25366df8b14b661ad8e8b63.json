!-- Google tag (gtag.js) --> \r\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-J62DFM87XB\"></script>\r\n<script> window.dataLayer = window.dataLayer || []; function gtag(){dataLayer.push(arguments);} gtag('js', new Date()); gtag('config', 'G-J62DFM87XB'); </script>\r\n\r\n<!-- Global site tag (gtag.js) - Google Analytics -->\r\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=UA-88655810-4\"></script>\r\n<script>\r\n  window.dataLayer = window.dataLayer || [];\r\n  function gtag(){dataLayer.push(arguments);}\r\n  gtag('js', new Date());\r\n\r\n  gtag('config', 'UA-88655810-4');\r\n</script>\r\n\r\n\r\n</head>\r\n<body class=\"page-template-default page page-id-9417 page-child parent-pageid-12\">\r\n\r\n<header id=\"header\" class=\"header\">\r\n\t<div class=\"container\">\r\n\r\n\t\t\t\t\t<a class=\"header__logo\" href=\"https://ryu-tsu.jp/\"><img src=\"https://ryu-tsu.jp/wp-content/themes/ryu-tsu/img/common/logo.png\" alt=\"鳥取県倉吉市 運送・観光・イベント 流通株式会社\">\r\n\t\t\t</a>\r\n\t\t\t\t<nav id=\"gnav\" class=\"gnav\" role=\"navigation\">\r\n\t\t\t<ul id=\"menu-%e3%82%b0%e3%83%ad%e3%83%bc%e3%83%90%e3%83%ab%e3%83%a1%e3%83%8b%e3%83%a5%e3%83%bc\" class=\"gnav__list\"><li id=\"menu-item-30\" class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-home menu-item-30\"><a href=\"https://ryu-tsu.jp/\">TOP</a></li>\n<li id=\"menu-item-31\" class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-31\"><a href=\"https://ryu-tsu.jp/about/\">流通について</a></li>\n<li id=\"menu-item-32\" class=\"menu-item menu-item-type-post_type menu-item-object-page current-page-ancestor menu-item-32\"><a href=\"https://ryu-tsu.jp/service/\">サービス</a></li>\n<li id=\"menu-item-41\" class=\"menu-item menu-item-type-custom menu-item-object-custom menu-item-41\"><a href=\"http://ryu-tsu.jp/news\">NEWS</a></li>\n<li id=\"menu-item-131\" class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-131\"><a href=\"https://ryu-tsu.jp/voices/\">お客様の声</a></li>\n<li id=\"menu-item-43\" class=\"menu-item menu-item-type-custom menu-item-object-custom menu-item-43\"><a href=\"http://ryu-tsu.jp/blog\">ブログ</a></li>\n<li id=\"menu-item-40\" class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-40\"><a href=\"https://ryu-tsu.jp/recruit/\">リクルート</a></li>\n</ul>\t\t\t<div class=\"gnav__search\">\r\n\t\t\t\t<form class=\"searchform\" method=\"GET\" action=\"/\"  role=\"search\">\r\n  <input type=\"text\" name=\"s\" value=\"\" id=\"search_text\" placeholder=\"\">\r\n  <button type=\"submit\">検索</button>\r\n</form>\r\n\t\t\t</div>\r\n\t\t\t<a class=\"gnav__tel\" href=\"tel:0120221211\">0120-22-1211</a>\r\n\t\t\t<a class=\"gnav__contact\" href=\"https://ryu-tsu.jp/contact/\"><span>お問い合わせ</span></a>\r\n\t\t</nav>\r\n\t\t<div class=\"gnav__search d--sp d--tab\">\r\n\t\t\t\t<form class=\"searchform\" method=\"GET\" action=\"/\"  role=\"search\">\r\n  <input type=\"text\" name=\"s\" value=\"\" id=\"search_text\" placeholder=\"\">\r\n  <button type=\"submit\">検索</button>\r\n</form>\r\n\t\t\t</div>\r\n\t\t<button id=\"header__hm\" class=\"header__hm\"><span></span><span></span><span></span></button>\r\n\t</div>\r\n</header>\r\n\r\n\r\n\t<div class=\"page-title\">\r\n\t\t<h1>採用支援サービス</h1>\t</div>\r\n\r\n<div class=\"contents clearfix\">\r\n\t<main class=\"main\" role=\"main\">\r\n\n<article class=\"staffing2 post-9417 page type-page status-publish hentry\">\n\t<style>\r\n/* 2025/11/25 追加 */\r\n\r\n.flow-container {\r\n    max-width: 1000px;\r\n    margin: 40px auto;\r\n    padding: 0;\r\n    background-color: transparent;\r\n    border-radius: 0; \r\n}\r\n\r\n.flow_fix {\r\n    list-style: none;\r\n    margin: 0;\r\n    padding: 0;\r\n    counter-reset: flow-step-counter;\r\n    border-radius: 0px;\r\n    overflow: visible; \r\n}\r\n\r\n.flow_fix > li {\r\n    position: relative;\r\n    display: flex;\r\n    align-items: center;\r\n    gap: 24px;\r\n    background-color: #F3F3EB;\r\n    /* 修正点: 枠線を透明にし、デフォルトでは非表示にする */\r\n    border: 1px solid transparent; \r\n    padding: 32px;\r\n    margin-top: 30px; \r\n    border-radius: 8px;\r\n\tbox-shadow: 0 2px 4px rgba(6, 0, 1, 0.1);\r\n    \r\n    /* マウスオーバー時の切り替えを滑らかにする */\r\n    transition: border-color 0.3s ease;\r\n\t/* 修正点: カウンタの増分をリストアイテム(li)自体に移動 */\r\n\tcounter-increment: flow-step-counter;\r\n\tmargin-bottom:0!important;\r\n}\r\n\r\n/* マウスオーバー設定用\r\n.flow_fix > li:hover {\r\n    border-color: #e8340c;\r\n}\r\n*/\r\n\r\n.flow_fix > li:first-child {\r\n    margin-top: 0;\r\n\tmargin-bottom:0!important;\r\n}\r\n\r\n.flow_fix > li .step-marker {\r\n    display: none;\r\n}\r\n\r\n.flow_fix > li:not(:last-child)::after {\r\n    content: \"\";\r\n    position: absolute;\r\n    bottom: -20px;\r\n    left: 50%;\r\n    transform: translate(-50%, 0);\r\n    width: 0;\r\n    height: 0;\r\n    border-style: solid;\r\n    border-width: 10px 8px 0 8px;\r\n    border-color: #e8340c transparent transparent transparent;\r\n    z-index: 20;\r\n}\r\n\r\n.flow_fix figure {\r\n    order: 1;\r\n    flex-shrink: 0; \r\n    width: 250px; \r\n    margin: 0;\r\n    border-radius: 8px;\r\n    overflow: hidden;\r\n}\r\n\r\n.flow_fix figure img {\r\n    width: 100%;\r\n    height: auto;\r\n    display: block;\r\n    object-fit: cover;\r\n}\r\n\r\n.flow_fix dl {\r\n    order: 2;\r\n    flex-grow: 1; \r\n    margin: 0;\r\n    padding: 0 10px;\r\n    position: relative; \r\n}\r\n\r\n.flow_fix dl::before {\r\n    content: \"Step \" counter(flow-step-counter);\r\n    color: #e8340c;\r\n    font-size: 20px;\r\n    font-weight: 700;\r\n    display: block;\r\n    margin-bottom: 8px;\r\n}\r\n\r\n.flow_fix dt {\r\n    font-size: 24px;\r\n    font-weight: 700;\r\n    color: #333;\r\n    line-height: 1.3;\r\n    margin-bottom: 5px;\r\n}\r\n\r\n.flow_fix dd p {\r\n    font-size: 16px;\r\n    line-height: 1.6;\r\n    color: #555;\r\n    margin: 0;\r\n}\r\n\r\n/* レスポンシブ対応 */\r\n@media (max-width: 768px) {\r\n    .flow-container {\r\n        margin: 20px 10px;\r\n    }\r\n    \r\n    .flow_fix > li {\r\n        flex-direction: column;\r\n        align-items: flex-start;\r\n        padding: 20px;\r\n        margin-top: 25px;\r\n    }\r\n    \r\n    .flow_fix > li:first-child {\r\n        margin-top: 0;\r\n    }\r\n\r\n    .flow_fix > li figure {\r\n        order: 1;\r\n        width: 100%; \r\n        margin-bottom: 15px;\r\n    }\r\n\r\n    .flow_fix > li dl {\r\n        order: 2;\r\n        width: 100%;\r\n        padding: 0;\r\n    }\r\n    \r\n    .flow_fix dl::before {\r\n        font-size: 22px;\r\n        margin-bottom: 10px;\r\n    }\r\n\r\n    .flow_fix > li:not(:last-child)::after {\r\n        left: 50%;\r\n        bottom: -15px; \r\n        transform: translateX(-50%);\r\n    }\r\n}\r\n    </style>\r\n<style>\r\n        /* オプションセクション全体 */\r\n        .option-section {\r\n            max-width: 100%; /* 親要素の幅に合わせるか、適宜調整 */\r\n            margin: auto; /* 上下の余白と中央寄せ */\r\n            /* 修正: 背景色を #F3F3EB に変更 */\r\n            background-color: #F3F3EB; \r\n            padding: 30px; /* 内側の余白 */\r\n            text-align: center; /* タイトルを中央寄せにするため */\r\n            /* 修正: 角丸を追加 */\r\n            border-radius: 8px; \r\n            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.05); /* 軽い影を追加 (デザインをより良くするため) */\r\n        }\r\n\r\n        /* セクションタイトル */\r\n        .option-title {\r\n            font-size: 28px;\r\n            font-weight: bold;\r\n            color: #333;\r\n            margin-bottom: 30px;\r\n            display: inline-block; /* 背景色の線を文字幅に合わせるため */\r\n            padding: 0 15px; /* タイトルと線の間の余白 */\r\n            /* 修正: タイトル背景色をセクション背景色に合わせる */\r\n            background-color: #F3F3EB; \r\n            position: relative;\r\n            z-index: 1; /* 線の上に表示 */\r\n        }\r\n\r\n        /* オプションコンテンツのレイアウト */\r\n        .option-content {\r\n            display: flex;\r\n            justify-content: center; /* 中央寄せ */\r\n            align-items: flex-start; /* 上揃え */\r\n            gap: 60px; /* 概要とリストの間のスペース */\r\n            margin-top: 30px; /* タイトルとの距離 */\r\n        }\r\n\r\n        /* オプション概要 (CHECK POINT) */\r\n        .option-summary {\r\n            text-align: left; /* テキスト左寄せ */\r\n            min-width: 180px; /* 幅の確保 */\r\n        }\r\n\r\n        /* 赤いチェックマーク */\r\n        .checkmark {\r\n            display: inline-block;\r\n            width: 20px;\r\n            height: 20px;\r\n            background-color: #e8340c; /* 赤い背景 */\r\n            clip-path: polygon(14% 44%, 0 65%, 50% 100%, 100% 16%, 80% 0%, 43% 60%); /* チェックマークの形 */\r\n            vertical-align: middle; /* テキストと高さを揃える */\r\n            margin-right: 8px; /* テキストとの間隔 */\r\n        }\r\n\r\n        /* 概要の見出し (CHECK POINT) */\r\n        .summary-heading {\r\n            font-size: 18px;\r\n            font-weight: bold;\r\n            color: #e8340c; /* 赤色 */\r\n            display: inline-block; /* チェックマークと同じ行に表示 */\r\n            vertical-align: middle;\r\n            margin: 0; /* デフォルトマージンをリセット */\r\n        }\r\n\r\n        /* 概要の詳細 (別途お見積り) */\r\n        .summary-detail {\r\n            font-size: 16px;\r\n            color: #333;\r\n            margin-top: 5px;\r\n            margin-left: 28px; /* チェックマークと合わせてインデント */\r\n        }\r\n\r\n  /* オプションリスト */\r\n        .option-list {\r\n            list-style: none; /* デフォルトのリストスタイルを削除 */\r\n            padding: 0;\r\n            margin: 0;\r\n            text-align: left; /* テキスト左寄せ */\r\n        }\r\n        \r\n        /* 追加: リストのタイトル (オプション例) */\r\n        .option-list-heading {\r\n            /* CHECK POINT と同じスタイル */\r\n            font-size: 18px;\r\n            font-weight: bold;\r\n            color: #333; /* 黒に変更 */\r\n            margin-bottom: 10px; /* リスト本体との間隔 */\r\n            margin-top: 0;\r\n        }\r\n\r\n        .option-list .list-item {\r\n            font-size: 16px;\r\n            color: #555;\r\n            margin-bottom: 0px!important; /* 各項目の間隔 */\r\n            position: relative;\r\n            padding-left: 15px; /* リストマークのスペース */\r\n        }\r\n\r\n        /* カスタムのリストマーク (点) */\r\n        .option-list .list-item::before {\r\n            content: \"・\"; /* 点の文字 */\r\n            color: #555;\r\n            position: absolute;\r\n            left: 0;\r\n            top: 0;\r\n        }\r\n\r\n        /* レスポンシブ対応 */\r\n        @media (max-width: 768px) {\r\n            .option-section {\r\n                margin: 40px 0; /* スマホ時のマージン */\r\n                padding: 20px;\r\n            }\r\n\r\n            .option-title {\r\n                font-size: 24px;\r\n                margin-bottom: 20px;\r\n            }\r\n\r\n            .option-content {\r\n                flex-direction: column; /* 縦積みに変更 */\r\n                gap: 30px;\r\n                align-items: center; /* 中央寄せ */\r\n            }\r\n\r\n            .option-summary {\r\n                text-align: center; /* スマホでは中央寄せ */\r\n                min-width: auto;\r\n            }\r\n\r\n            .summary-detail {\r\n                margin-left: 0; /* インデント解除 */\r\n            }\r\n            \r\n            .option-list {\r\n                width: 100%; /* 幅をいっぱいに */\r\n            }\r\n        }\r\n    </style>\r\n\t\r\n\t\r\n\t<div class=\"container\">\r\n\t<div class=\"staffing-recruit\">\r\n\t\t<h2 id=\"rec1\" class=\"heading2\">地域密着採用代行</h2>\r\n\t\t<p>「採用担当者がいない」を、月7万円でまるっと代行！山陰の企業に頼れる“人事のパートナー”と採用の代行サービスを。<br>この度、流通は地域密着型の採用代行サービスを立ち上げました！業界最安値水準で御社の採用活動をサポートします。今までのスポット的なサポートだけでなく、継続的な伴奏支援を行います。</p>\r\n\t\t<figure class=\"ta-c\"><img decoding=\"async\" src=\"https://ryu-tsu.jp/wp-content/uploads/2025/11/img01ca.png\" alt=\"地域密着採用代行\"></figure>\r\n\r\n\t</div>\r\n\r\n\t\r\n<div class=\"container\">\r\n\t<div class=\"staffing-strength\"><h2 id=\"rec1\" class=\"heading2\">採用支援サービスの3つの料金プラン</h2>\r\n\r\n\t<h2 class=\"heading1\"><span>稼働時間とニーズに合わせて選べる3段階の料金体系で、<br>採用活動を効率的にサポートします</span></h2>\r\n\t\r\n\t<ul class=\"grid grid--col3\">\r\n\t\t<li>\r\n\t\t\t\t<figure>\r\n\t\t\t\t\t<img decoding=\"async\" src=\"https://ryu-tsu.jp/wp-content/uploads/2026/02/img01da.png\" alt=\"お手軽プラン\">\r\n\t\t\t\t</figure>\r\n\t\t</li>\r\n\t\t<li>\r\n\t\t\t\t<figure>\r\n\t\t\t\t\t<img decoding=\"async\" src=\"https://ryu-tsu.jp/wp-content/uploads/2026/05/img01db-1.jpg\" alt=\"しっかりプラン\">\r\n\t\t\t\t</figure>\r\n\t\t</li>\t\t\r\n\t\t<li>\r\n\t\t\t\t<figure>\r\n\t\t\t\t\t<img decoding=\"async\" src=\"https://ryu-tsu.jp/wp-content/uploads/2026/02/img01dc.png\" alt=\"大満足プラン\">\r\n\t\t\t\t</figure>\r\n\t\t</li>\r\n\t</ul>\r\n\r\n\t<div class=\"option-section\">\r\n        <h2 class=\"option-title\">オプション</h2>\r\n        <div class=\"option-content\">\r\n            <div class=\"option-summary\">\r\n                <span class=\"checkmark\"></span>\r\n                <p class=\"summary-heading\">CHECK POINT</p>\r\n                <p class=\"summary-detail\">別途お見積り</p>\r\n            </div>\r\n        \t  <div class=\"option-list-wrapper\">\r\n                <p class=\"option-list-heading\">オプション例</p>\r\n                <ul class=\"option-list\">\r\n                    <li class=\"list-item\">会社説明会資料作成</li>\r\n                    <li class=\"list-item\">月の稼働時間を増やす</li>\r\n                    <li class=\"list-item\">採用 HP 作成 等</li>\r\n                </ul>\r\n            </div>\r\n        </div>\r\n    </div>\r\n\r\n\t<div class=\"staffing-recruit\">\r\n\t\t<h2 id=\"rec1\" class=\"heading2\">お支援体制とスケジュール</h2>\r\n\t\t<p>導入から運用までの流れとフィードバック体制を整え、貴社を全力でサポートいたします。</p>\r\n\t</div>\r\n    \r\n    <ol class=\"flow_fix\">\r\n        <!-- Step 1: 貴社の課題の整理 -->\r\n        <li>\r\n            <!-- .step-marker はCSSで非表示/位置調整されますが、HTMLの構造を維持 -->\r\n            <div class=\"step-marker\"></div> \r\n            \r\n            <figure>\r\n                <!-- 画像URLを元のコンテンツに戻す（URLは推測） -->\r\n                <img decoding=\"async\" src=\"https://ryu-tsu.jp/wp-content/uploads/2025/11/flow_reception-a.png\" alt=\"貴社の課題の整理\">\r\n            </figure>\r\n            <dl>\r\n                <dt>貴社の課題の整理</dt>\r\n                <dd>\r\n                    <p>貴社の課題を整理させていただき具体的な支援内容を提示します。</p>\r\n                </dd>\r\n            </dl>\r\n        </li>\r\n\r\n        <!-- Step 2: ご契約 -->\r\n        <li>\r\n            <div class=\"step-marker\"></div>\r\n            <figure>\r\n                <img decoding=\"async\" src=\"https://ryu-tsu.jp/wp-content/uploads/2025/11/flow_reception-b.png\" alt=\"ご契約\">\r\n            </figure>\r\n            <dl>\r\n                <dt>ご契約</dt>\r\n                <dd>\r\n                    <p>ご支援内容とお見積りをご確認の上、契約締結</p>\r\n                </dd>\r\n            </dl>\r\n        </li>\r\n\r\n        <!-- Step 3: プロジェクト KICKOFF ミーティング -->\r\n        <li>\r\n            <div class=\"step-marker\"></div>\r\n            <figure>\r\n                <img decoding=\"async\" src=\"https://ryu-tsu.jp/wp-content/uploads/2025/11/flow_reception-c.png\" alt=\"キックオフミーティング\">\r\n            </figure>\r\n            <dl>\r\n                <dt>プロジェクトKICKOFF ミーティング</dt>\r\n                <dd>\r\n                    <p>課題の支援内容の再確認と、ご支援にあたって必要な情報やタスクを整理します。</p>\r\n                </dd>\r\n            </dl>\r\n        </li>\r\n\r\n        <!-- Step 4: 月次フィードバック -->\r\n        <li>\r\n            <div class=\"step-marker\"></div>\r\n            <figure>\r\n                <img decoding=\"async\" src=\"https://ryu-tsu.jp/wp-content/uploads/2025/11/flow_reception-d.png\" alt=\"月次フィードバック\">\r\n            </figure>\r\n            <dl>\r\n                <dt>月次フィードバック</dt>\r\n                <dd>\r\n                    <p>定期的なフィードバックを通じて業務の質を高め、継続的な改善を行います。</p>\r\n                </dd>\r\n            </dl>\r\n        </li>\r\n    </ol>\r\n</div>\r\n\r\n</div>\r\n</div>\r\n\r\n\r\n<div class=\"cta\">\r\n\t<div class=\"cta__content\">\r\n\t\t<div class=\"container\">\r\n\t\t\t<div class=\"cta__inner cta__inner--wide\">\r\n\t\t\t\t<h2 class=\"cta__title\">お問い合わせ・ご相談はこちら<span>お問い合わせ・ご相談はこちら</span></h2>\r\n\t\t\t\t<ul class=\"cta__store\">\r\n\t\t\t\t\t<li><a