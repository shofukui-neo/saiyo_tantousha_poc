d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n})(window,document,'script','dataLayer','GTM-W7PTBMH');</script>\n<!-- End Google Tag Manager -->\n</head>\n\n<body data-rsssl=1 class=\"home blog wp-theme-xeory_extension wp-child-theme-okayama_landry_tm \" itemschope=\"itemscope\" itemtype=\"http://schema.org/WebPage\">\n<!-- Google Tag Manager (noscript) -->\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-W7PTBMH\"\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n<!-- End Google Tag Manager (noscript) -->\n<header id=\"header\">\n    <div class=\"header-logo\">\n        <h1>\n            <a href=\"https://okayamalaundry.co.jp/recruit/\"><img src=\"https://okayamalaundry.co.jp/recruit/wp-content/themes/okayama_landry_tm/img/common/header-logo.svg\" alt=\"OKAYAMA LANDRY\"/></a>\n        </h1>\n    </div>\n    <div class=\"header-menu\">\n        <nav>\n            <ul>\n                <li><a href=\"https://okayamalaundry.co.jp/recruit/\">TOP</a></li>\n                <li><a href=\"https://okayamalaundry.co.jp/recruit/concept/\">CONCEPT</a></li>\n                <li><a href=\"https://okayamalaundry.co.jp/recruit/data/\">DATA</a></li>\n                <li><a href=\"https://okayamalaundry.co.jp/recruit/works/\">WORKS</a></li>\n                <li><a href=\"https://okayamalaundry.co.jp/recruit/interview/\">INTERVIEW</a></li>\n                <li><a href=\"https://okayamalaundry.co.jp/recruit/welfare/\">WELFARE</a></li>\n                <li><a href=\"https://okayamalaundry.co.jp/recruit/topics/\">TOPICS</a></li>\n                <li><a href=\"https://okayamalaundry.co.jp/recruit/company/\">COMPANY</a></li>\n                <li><a href=\"https://okayamalaundry.co.jp/recruit/job-info/\" class=\"adjust\">JOB INFO</a></li>\n            </ul>\n        </nav>\n    </div>\n    <div class=\"nav-toggle-wrap\">\n        <div class=\"nav-toggle\">\n            <span></span>\n            <span></span>\n            <span></span>\n        </div>\n    </div>\n    <div id=\"drawer\">\n        <nav>\n            <ul>\n                <li><a href=\"https://okayamalaundry.co.jp/recruit/\">TOP</a></li>\n                <li><a href=\"https://okayamalaundry.co.jp/recruit/concept/\">CONCEPT</a></li>\n                <li><a href=\"https://okayamalaundry.co.jp/recruit/data/\">DATA</a></li>\n                <li><a href=\"https://okayamalaundry.co.jp/recruit/works/\">WORKS</a></li>\n                <li><a href=\"https://okayamalaundry.co.jp/recruit/interview/\">INTERVIEW</a></li>\n                <li><a href=\"https://okayamalaundry.co.jp/recruit/welfare/\">WELFARE</a></li>\n                <li><a href=\"https://okayamalaundry.co.jp/recruit/topics/\">TOPICS</a></li>\n                <li><a href=\"https://okayamalaundry.co.jp/recruit/company/\">COMPANY</a></li>\n                <li><a href=\"https://okayamalaundry.co.jp/recruit/job-info/\" class=\"adjust\">JOB INFO</a></li>\n                <li><a href=\"https://okayamalaundry.co.jp/recruit/entry/\" class=\"adjust orange\">ENTRY</a></li>\n            </ul>\n        </nav>\n    </div>\n</header>\n\n<aside id=\"aside\">\n    <a href=\"https://okayamalaundry.co.jp/recruit/entry/\"><img src=\"https://okayamalaundry.co.jp/recruit/wp-content/themes/okayama_landry_tm/img/common/sidebar-link.svg\" alt=\"ENTRY NOW\"/></a>\n</aside>    <div id=\"loading\">\n        <div class=\"loading-content\">\n            <div class=\"dot-pulse\"></div>\n        </div>\n    </div>\n    <main>\n        <div class=\"mv\">\n            <div class=\"mv-slider-wrap\">\n                <video src=\"https://okayamalaundry.co.jp/recruit/wp-content/themes/okayama_landry_tm/img/frontpage/mv.mp4\" muted playsinline loop autoplay poster=\"https://okayamalaundry.co.jp/recruit/wp-content/themes/okayama_landry_tm/img/frontpage/mv_poster.jpg\"></video>\n            </div>\n            <div class=\"mv-text-box\">\n                <h2 class=\"text-img\"><img src=\"https://okayamalaundry.co.jp/recruit/wp-content/themes/okayama_landry_tm/img/frontpage/mv-text01.svg\" alt=\"綺麗を、もっと。お気に入りを、ずっと。\"/></h2>\n                <div class=\"item\">\n                    <p class=\"en\"><img src=\"https://okayamalaundry.co.jp/recruit/wp-content/themes/okayama_landry_tm/img/frontpage/mv-text02.svg\" alt=\"Overcome what you were yesterday.\"/></p>\n                    <p class=\"text\"><img src=\"https://okayamalaundry.co.jp/recruit/wp-content/themes/okayama_landry_tm/img/frontpage/mv-text03.svg\" alt=\"常識なんて、洗ってしまおう。昨日の自分を超える。小さなことから変えていく。自分色に染まろう。\"/></p>\n                </div>\n            </div>\n        </div>\n\n        <div class=\"home-sec01 ps-re\">\n            <div class=\"blue-bg sc\">\n                <img src=\"https://okayamalaundry.co.jp/recruit/wp-content/themes/okayama_landry_tm/img/frontpage/concept-bg.jpg\" alt=\"CONCEPT\"/>\n            </div>\n            <h4 class=\"text-img\"><img src=\"https://okayamalaundry.co.jp/recruit/wp-content/themes/okayama_landry_tm/img/frontpage/text01.svg\" alt=\"常識なんて、洗ってしまえ。\"/></h4>\n            <div class=\"wrap ps-re\">\n                <div class=\"title title-flex white sc\">\n                    <img src=\"https://okayamalaundry.co.jp/recruit/wp-content/themes/okayama_landry_tm/img/title/concept.svg\" alt=\"CONCEPT\" class=\"ps-ab\"/>\n                    <h2 class=\"title-en fadein ts1\">01.CONCEPT</h2>\n                    <h3 class=\"title-text fadein ts1\">岡山ランドリーで働く</h3>\n                </div>\n                <div class=\"text-box\">\n                    <h4 class=\"text top fadein ts1\">常識なんて、<br />洗ってしまえ。</h4>\n                    <p class=\"text fadein ts1\">\n                        岡山市内を中心にクリーニング店を展開している<br />\n                        株式会社岡山ランドリー。<br />\n                        1931年創業以来、約90年お客様の「綺麗」「お気に入り」を守り、<br />\n                        挑戦を続けてきました。<br /><br />\n    \n                        クリーニングには世界を大きく変える力はないかもしれません。<br />\n                        でも、クリーニングを通してお客様に<br />\n                        幸せな気分になってもらうことはできるはず。<br /><br />\n    \n                        常識にとらわれない挑戦で<br />\n                        クリーニングの枠に縛られない事業と人をつくっていきたい。<br /><br />\n    \n                        不安や迷いも、期待も野望も、<br />\n                        その全部がココロを動かすエネルギーになる。<br /><br />\n    \n                        新しい挑戦をあなたと一緒に楽しみたい。\n                    </p>\n                    <div class=\"read-more white fadein ts1\">\n                        <a href=\"https://okayamalaundry.co.jp/recruit/concept/\">MORE</a>\n                    </div>\n                </div>\n            </div>\n        </div>\n        <div class=\"home-sec02 ps-re\">\n            <div class=\"gray-bg sc\"></div>\n            <div class=\"wrap ps-re\">\n                <div class=\"img-box sc\">\n                    <div class=\"img n1 fadein ts2\"><img src=\"https://okayamalaundry.co.jp/recruit/wp-content/themes/okayama_landry_tm/img/frontpage/img02.png\" alt=\"INFOGRAPHICS\"/></div>\n                    <div class=\"img n2 fadein ts2\"><img src=\"https://okayamalaundry.co.jp/recruit/wp-content/themes/okayama_landry_tm/img/frontpage/img03.png\" alt=\"INFOGRAPHICS\"/></div>\n                </div>\n                <div class=\"text-box\">\n                    <div class=\"title height-adjust sc\">\n                        <img src=\"https://okayamalaundry.co.jp/recruit/wp-content/themes/okayama_landry_tm/img/title/infographics.svg\" alt=\"INFOGRAPHICS\" class=\"ps-ab\"/>\n                        <h2 class=\"title-en fadein ts1\">02.DATA</h2>\n                        <h3 class=\"title-text fadein ts1\">岡山ランドリーのいま</h3>\n                    </div>\n                    <p class=\"text fadein ts1\">\n                        岡山ランドリーのいまを数字でご紹介します。<br />\n                        私たちはまだまだ発展途上。<br />\n                        だからこれからもっと強くなる。\n                    </p>\n                    <div class=\"read-more fadein ts1\">\n                        <a href=\"https://okayamalaundry.co.jp/recruit/data/\">MORE</a>\n                    </div>\n                </div>\n            </div>\n        </div>\n        <div class=\"home-sec03 ps-re\">\n            <div class=\"gray-bg sc\"></div>\n            <div class=\"blue-bg sc\"></div>\n            <div class=\"wrap ps-re\">\n                <div class=\"text-box\">\n                    <div class=\"title height-adjust white sc\">\n                        <img src=\"https://okayamalaundry.co.jp/recruit/wp-content/themes/okayama_landry_tm/img/title/our-work.svg\" alt=\"OUR WORK\" class=\"ps-ab\"/>\n                        <h2 class=\"title-en fadein ts1\">03.WORKS</h2>\n                        <h3 class=\"title-text fadein ts1\">私たちの仕事</h3>\n                    </div>\n                    <p class=\"text fadein ts1\">\n                        服には人それぞれ思い出が詰まっています。<br />\n                        私たちはお客様の“想いを預かる”仕事です。<br />\n                        店舗スタッフなどお客様と直接関わるスタッフだけでなく、<br />\n                        技術スタッフもチーム一丸となって<br />\n                        美しいサービスを心がけています。\n                    </p>\n                    <div class=\"read-more white fadein ts1\">\n                        <a href=\"https://okayamalaundry.co.jp/recruit/works/\">MORE</a>\n                    </div>\n                </div>\n                <div class=\"img fadein ts2\"><img src=\"https://okayamalaundry.co.jp/recruit/wp-content/themes/okayama_landry_tm/img/frontpage/img04.png\" alt=\"OUR WORK\"/></div>\n            </div>\n        </div>\n        <div class=\"home-sec04 ps-re\">\n            <div class=\"blue-bg sc\"></div>\n            <div class=\"wrap\">\n                <div class=\"title sc\">\n                    <img src=\"https://okayamalaundry.co.jp/recruit/wp-content/themes/okayama_landry_tm/img/title/interview.svg\" alt=\"INTERVIEW\" class=\"ps-ab\"/>\n                    <h2 class=\"title-en fadein ts1\">04.INTERVIEW</h2>\n                    <h3 class=\"title-text fadein ts1\">社員インタビュー</h3>\n                </div>\n                <p class=\"text fadein ts1\">\n                    ここまで挑戦してきた仲間たちのインタビューです。<br />\n                    ここにいるのは、未来のあなたかもしれません。\n                </p>\n            </div>\n            <div class=\"interview-slider-wrap fadein ts1\">\n                <div class=\"interview-slider-nav\">\n                    <ul>\n                        <li class=\"interview-slider-prev\"><img src=\"https://okayamalaundry.co.jp/recruit/wp-content/themes/okayama_landry_tm/img/frontpage/slider-prev.svg\" alt=\"前へ\"/></li>\n                        <li class=\"interview-slider-next\"><img src=\"https://okayamalaundry.co.jp/recruit/wp-content/themes/okayama_landry_tm/img/frontpage/slider-next.svg\" alt=\"次へ\"/></li>\n                    </ul>\n                </div>\n                <div class=\"interview-slider\">\n                    <div class=\"box\">\n                        <a href=\"https://okayamalaundry.co.jp/recruit/interview/interview01/\">\n                            <div class=\"img o-fit\"><img src=\"https://okayamalaundry.co.jp/recruit/wp-content/themes/okayama_landry_tm/img/frontpage/interview-img01.jpg\" alt=\"インタビュー画像\"/></div>\n                            <div class=\"name-box\">\n                                <p class=\"name\">佐々木 信<span>SHIN SASAKI</span></p>\n                                <p class=\"job\">営業スタッフ</p>\n                            </div>\n                        </a>\n                    </div>\n                    <div class=\"box\">\n                        <a href=\"https://okayamalaundry.co.jp/recruit/interview/interview02/\">\n                            <div class=\"img o-fit\"><img src=\"https://okayamalaundry.co.jp/recruit/wp-content/themes/okayama_landry_tm/img/frontpage/interview-img02.jpg\" alt=\"インタビュー画像\"/></div>\n                            <div class=\"name-box\">\n                                <p class=\"name\">佐々木 謙<span>KEN SASAKI</span></p>\n                                <p class=\"job\">事務スタッフ</p>\n                            </div>\n                        </a>\n                    </div>\n                    <div class=\"box\">\n                        <a href=\"https://okayamalaundry.co.jp/recruit/interview/interview03/\">\n                            <div class=\"img o-fit\"><img src=\"https://okayamalaundry.co.jp/recruit/wp-content/themes/okayama_landry_tm/img/frontpage/interview-img03.jpg\" alt=\"インタビュー画像\"/></div>\n                            <div class=\"name-box\">\n                                <p class=\"name\">大木 誠司<span>SEIJI OKI</span></p>\n                                <p class=\"job\">工場スタッフ</p>\n                            </div>\n                        </a>\n                    </div>\n                    <div class=\"box\">\n                        <a href=\"https://okayamalaundry.co.jp/recruit/interview/interview04/\">\n                            <div class=\"img o-fit\"><img src=\"https://okayamalaundry.co.jp/recruit/wp-content/themes/okayama_landry_tm/img/frontpage/interview-img04.jpg\" alt=\"インタビュー画像\"/></div>\n                            <div class=\"name-box\">\n                                <p class=\"name\">大月 公絵<span>KIMIE OTSUKI</span></p>\n                                <p class=\"job\">店舗スタッフ</p>\n                            </div>\n                        </a>\n                    </div>\n                    <div class=\"box\">\n                        <a href=\"https://okayamalaundry.co.jp/recruit/interview/interview05/\">\n                            <div class=\"img o-fit\"><img src=\"https://okayamalaundry.co.jp/recruit/wp-content/themes/okayama_landry_tm/img/frontpage/interview-img05.jpg\" alt=\"インタビュー画像\"/></div>\n                            <div class=\"name-box\">\n                                <p class=\"name\">平田 千裕<span>CHIHIRO HIRATA</span></p>\n                                <p class=\"job\">工場スタッフ</p>\n                            </div>\n                        </a>\n                    </div>\n                </div>\n            </div>\n        </div>\n        <div class=\"home-sec05 ps-re\">\n            <div class=\"home-sec05-bg n1 sc\"></div>\n            <div class=\"home-sec05-bg n2 sc\"></div>\n            <div class=\"wrap\">\n                <div class=\"text-box\">\n                    <div class=\"title white sc\">\n                        <img src=\"https://okayamalaundry.co.jp/recruit/wp-content/themes/okayama_landry_tm/img/title/werlfare.svg\" alt=\"WELFARE\" class=\"ps-ab\"/>\n                        <h2 class=\"title-en fadein ts1\">05.WELFARE</h2>\n                        <h3 class=\"title-text fadein ts1\">福利厚生／制度</h3>\n                    </div>\n                    <p class=\"text fadein ts1\">\n                        自ら学ぼうとする社員の成長につながる研修制度、<br />\n                        気持ちよく働ける福利厚生など、<br />\n                        仲間とともに学び刺激しあえる環境を整えています。\n                    </p>\n                    <div class=\"read-more white fadein ts1\">\n                        <a href=\"https://okayamalaundry.co.jp/recruit/welfare/\">MORE</a>\n                    </div>\n                </div>\n            </div>\n        </div>\n        <div class=\"home-sec06\">\n            <div class=\"wrap\">\n                <div class=\"title sc\">\n                    <img src=\"https://okayamalaundry.co.jp/recruit/wp-content/themes/okayama_landry_tm/img/title/topics.svg\" alt=\"TOPICS\" class=\"ps-ab\"/>\n                    <h2 class=\"title-en fadein ts1\">06.TOPICS</h2>\n                </div>\n                                    <div class=\"read-more fadein\">\n                        <a href=\"https://okayamalaundry.co.jp/recruit/topics/\">MORE</a>\n                    </div>\n                    <div class=\"topics-content\">\n                                                    <div class=\"topics-box fadein\">\n                                <a href=\"https://okayamalaundry.co.jp/recruit/news/42/\">\n                                    <div class=\"topics-meta\">\n                                        <p class=\"cat\">NEWS</p>\n                                        <p class=\"date\">2022.07.23</p>\n                                    </div>\n                                    <p class=\"text\">採用サイトをオープンいたしました。</p>\n                                </a>\n                            </div>\n                                            </div>\n                            </div>\n        </div>\n        <div class=\"home-sec07 fadein\"></div>\n    </main>\n    <script>\n        (function($){\n            $(function(){\n                setTimeout(function(){\n                    $('.mv-slider').slick({\n                        autoplay: true,\n                        autoplaySpeed: 5000,\n                        speed: 500,\n                        cssEase: 'ease-in',\n                        fade: true,\n                        dots: false,\n                        arrows: false,\n                        pauseOnHover: false,\n                        pauseOnFocus: false,\n                    });\n                    $('.slick-slide').removeClass('slick-current');\n                    setTimeout(function(){\n                        $('.mv-slider li img').css('transition','.5s');\n                        $('.slick-slide').eq(0).addClass('slick-current');\n                    }, 500);\n                }, 500);\n\n                setTimeout(function(){\n                    $('#loading').fadeOut();\n                }, 1000);\n            });\n            $(function(){\n                $('.interview-slider').slick({\n                    dots: false,\n                    arrows: false,\n                    variableWidth: true,\n                    responsive: [{\n                        breakpoint: 481,\n                        settings: {\n             