reetings.html\"><img src=\"images/pho_about01.png\" width=\"290\" height=\"150\" alt=\"代表あいさつ\"/><span>代表あいさつ</span></a></li>\r\n  <li><a href=\"/profile/outline.html\"><img src=\"images/pho_about02.png\" width=\"290\" height=\"150\" alt=\"会社概要\"/><span>会社概要</span></a></li>\r\n  <li><a href=\"/profile/outline.html\"><img src=\"images/pho_about03.png\" width=\"290\" height=\"150\" alt=\"沿革\"/><span>沿革</span></a></li>\r\n</ul>\r\n</section>\r\n\r\n<section id=\"section04\">\r\n    <div class=\"innerBlock\">\r\n    <h2>部署紹介<span>Offices Information</span></h2>\r\n    <ul class=\"clearfix col2\">\r\n      <li><a href=\"/profile/office.html#matsuyamahonsya\">松山本社</a></li>\r\n      <li><a href=\"/profile/office.html#hiroshima\">広島本社</a></li>\r\n      <li><a href=\"/profile/office.html#osaka\">大阪支店</a></li>\r\n      <li><a href=\"/profile/office.html#takamatsu\">香川事業所</a></li>\r\n      <li><a href=\"/profile/office.html#matsuyamait\">システム開発部</a></li>\r\n      <li><a href=\"/profile/office.html#matsuyamahonsya\">派遣事業部</a></li>\r\n    </ul>\r\n    </div>\r\n</section>\r\n\r\n<section id=\"section05\">\r\n\t<div class=\"innerBlock\">\r\n\t<h2>現在募集中の求人<span>Jobs currently in recruitment</span></h2>\r\n  <ul class=\"clearfix\">\r\n  \t<li><a href=\"/recruit/entry/#section01\"><img src=\"images/btn_new.png\" width=\"447\" height=\"150\" alt=\"新卒採用\"/></a></li>\r\n    <li><a href=\"/recruit/entry/#section02\"><img src=\"images/btn_carrier.png\" width=\"447\" height=\"150\" alt=\"キャリア採用\"/></a></li>\r\n  </ul>\r\n  </div>\r\n</section>\r\n<!-- // Contents END // -->\r\n\r\n\r\n<!-- // Footer START // -->\r\n<footer>\r\n\r\n<div id=\"gotop\"><a href=\"#page_top\"><img class=\"imgover\" src=\"common/images/btn_pagetop.png\" width=\"70\" height=\"70\" alt=\"このページの一番上へ\" /></a></div> \r\n\r\n<p id=\"skip_footer\" class=\"skip\">フッターです。</p>\r\n</footer>\r\n<!-- // Footer END // -->\r\n\r\n</body>\r\n</html>\r\n","finalUrl":"https://www.pro-win.co.jp/recruit/","rendered":false,"_cachedA