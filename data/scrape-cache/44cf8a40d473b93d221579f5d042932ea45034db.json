ection id=\"slider\" class=\"slider-element dark swiper_wrapper slider-parallax min-vh-60\" data-autoplay=\"5000\" data-speed=\"650\" data-loop=\"true\">\n    <div class=\"slider-inner\">\n      <div class=\"swiper-container swiper-parent\">\n        <div class=\"swiper-wrapper\">\n          <div class=\"swiper-slide dark\">\n            <div class=\"container\">\n              <div class=\"slider-caption\">\n                <div>\n                  <h2 class=\"nott\" data-animate=\"fadeInUp\">地域の皆様と<br>\n                    共に歩んで百有余年</h2>\n                </div>\n              </div>\n            </div>\n            <div class=\"swiper-slide-bg\" style=\"background: url('images/slide_01.jpg') no-repeat center center; background-size: cover;\"></div>\n          </div>\n          <div class=\"swiper-slide dark\">\n            <div class=\"container\">\n              <div class=\"slider-caption\">\n                <div>\n                  <h2 class=\"nott\" data-animate=\"fadeInUp\">皆様に健康と信頼を<br>\n                    お届けします</h2>\n                </div>\n              </div>\n            </div>\n            <div class=\"swiper-slide-bg\" style=\"background: url('images/slide_04.jpg') no-repeat center center; background-size: cover;\"></div>\n          </div>\n          <div class=\"swiper-slide dark\">\n            <div class=\"container\">\n              <div class=\"slider-caption\">\n                <div>\n                  <h2 class=\"nott\" data-animate=\"fadeInUp\">皆様の健康と安⼼が<br>\n                    わたしたちの願いです</h2>\n                </div>\n              </div>\n            </div>\n            <div class=\"swiper-slide-bg\" style=\"background: url('images/slide_03.jpg') no-repeat bottom center; background-size: cover;\"></div>\n          </div>\n        </div>\n        <div class=\"slider-arrow-left\"><i class=\"icon-angle-left\"></i></div>\n        <div class=\"slider-arrow-right\"><i class=\"icon-angle-right\"></i></div>\n      </div>\n    </div>\n  </section>\n  \n  <!-- Content\n\t\t============================================= -->\n  <section id=\"content\">\n    <div class=\"content-wrap py-0\" style=\"overflow: visible\">\n      <svg viewBox=\"0 0 1382 58\" width=\"100%\" height=\"60\" preserveAspectRatio=\"none\" style=\"position: absolute; top: -58px; left:0; z-index: 1\">\n        <path style=\"fill:#FFF;\" d=\"M1.52.62s802.13,127,1380,0v56H.51Z\"/>\n      </svg>\n      <div class=\"container\">\n        <div class=\"slider-feature w-100\">\n          <div class=\"row justify-content-center\">\n            <div class=\"col-9 col-md-8 col-lg-4 col-xl-3 px-1\"> <a href=\"contents/01_company.html\" class=\"card center border-left-0 border-right-0 border-top-0 border-bottom border-bottom shadow py-2 rounded-0 text-uppercase ls1\">\n              <div class=\"card-body\"> <i class=\"icon-building lgreen text-larger\"></i>会社概要 </div>\n              </a> </div>\n            <div class=\"col-9 col-md-8 col-lg-4 col-xl-3 px-1\"> <a href=\"contents/05_forest.html\" class=\"card center border-left-0 border-right-0 border-top-0 border-bottom border-bottom shadow py-2 rounded-0 text-uppercase\">\n              <div class=\"card-body\"> <i class=\"icon-leaf lgreen text-larger\"></i>フォレストグループ </div>\n              </a> </div>\n            <div class=\"col-9 col-md-8 col-lg-4 col-xl-3 px-1\"> <a href=\"contents/04_info.html\" class=\"card center border-left-0 border-right-0 border-top-0 border-bottom border-bottom shadow py-2 rounded-0 text-uppercase ls1\">\n              <div class=\"card-body\"> <i class=\"icon-clipboard1 lgreen text-larger\"></i>採用案内 </div>\n              </a> </div>\n          </div>\n        </div>\n      </div>\n      <div class=\"section mt-3 bg_news mb-0\">\n        <div class=\"container\">\n          <div class=\"row justify-content-center\">\n            <div class=\"col-md-12 center\">\n              <div class=\"heading-block border-bottom-0\">\n                <h2 class=\"text-white nott\">NEWS</h2>\n              </div>\n            </div>\n          </div>\n          <div id=\"information\"></div>\n          <div class=\"row\">\n            <div class=\"col-12 text-center\"> <a href=\"topics/\" class=\"button button-border button-border-thin button-white text-right\">View more<i class=\"icon-line-chevron-right\"></i></a> </div>\n          </div>\n        </div>\n      </div>\n      <div class=\"section bg-transparent mt-0 mb-0\" style=\"background: url('images/top_back01.jpg') no-repeat center center/ cover\">\n        <div class=\"container clearfix mt-5\">\n          <div class=\"row justify-content-center\">\n            <div class=\"col-md-12 center\">\n              <div class=\"heading-block border-bottom-0 mb-4\">\n                <h2 class=\"mb-4 nott\">ABOUT US</h2>\n              </div>\n              <div class=\"svg-line bottommargin-sm clearfix\"> <img src=\"images/divider-1.svg\" alt=\"svg divider\" height=\"20\"> </div>\n              <p style=\"font-weight: 400;\">地域の皆様に寄り添いながら、私たちにできることを。<br>\n                藤村薬品株式会社では、さまざまな事業に取り組んでいます。</p>\n            </div>\n          </div>\n          <div class=\"row align-items-stretch m-0 w-100 clearfix gutter-30\">\n            <div class=\"col-lg-4 col-sm-12 center mt-5\">\n              <div class=\"bg-white-08 p-4\"> <i class=\"icon-building2 lgreen\" style=\"font-size:60px;\"></i>\n                <h4 class=\"ls0 mt-0 font-weight-normal\">会社概要</h4>\n                <p class=\"text-left\">藤村薬品の歴史は、明治27年から。地域社会の皆様の健康に貢献・奉仕するという原点を忘れることなく、尚一層の努力を続けてまいります。</p>\n                <a href=\"contents/01_company.html\" class=\"button button-border button-border-thin button-black text-right\">View more<i class=\"icon-line-chevron-right\"></i></a> </div>\n            </div>\n            <div class=\"col-lg-4 col-sm-12 center mt-5\">\n              <div class=\"bg-white-08 p-4\"> <i class=\"icon-heartbeat lgreen\" style=\"font-size:60px;\"></i>\n                <h4 class=\"ls0 mt-0 font-weight-normal\">事業案内</h4>\n                <p class=\"text-left\">藤村薬品では、医療事業をはじめとした、さまざまな事業に取り組んでいます。徹底した品質管理と安定供給で、安全と安心をお届けします。</p>\n                <a href=\"contents/02_business.html\" class=\"button button-border button-border-thin button-black text-right\">View more<i class=\"icon-line-chevron-right\"></i></a> </div>\n            </div>\n            <div class=\"col-lg-4 col-sm-12 center mt-5\">\n              <div class=\"bg-white-08 p-4\"> <i class=\"icon-hand-holding-medical lgreen\" style=\"font-size:60px;\"></i>\n                <h4 class=\"ls0 mt-0 font-weight-normal\">CSR</h4>\n                <p class=\"text-left\">藤村薬品では、フォレストグループ企業の一員として、CSR活動「FSR（Forest Social Responsibility）」に取り組んでいます。</p>\n                <a href=\"contents/03_csr.html\" class=\"button button-border button-border-thin button-black text-right\">View more<i class=\"icon-line-chevron-right\"></i></a> </div>\n            </div>\n          </div>\n        </div>\n      </div>\n      <div class=\"clear\"></div>\n      <div class=\"section mt-0\" style=\"background-color: #EAE5CC;\">\n        <div class=\"container clearfix\">\n          <div class=\"row align-items-stretch m-0 w-100 clearfix gutter-50 justify-content-center\">\n            <div class=\"col-lg-8 col-sm-12 mt-5\">\n              <h3>藤村薬品はフォレストグループの一員です。</h3>\n              <p>フォレストグループは基本理念「健康にかかわる＜不＞の打開」を定款に掲げ、人々の健やかな生活実現のための環境づくり、健全社会の実現を目指しています。<br>\n                その強い意志と、次代を担う子どもたちまで健康を届けたいという願いを、『健康を未来につなぐ』というコーポレートメッセージに込めています。</p>\n              <div class=\"text-right mt-4\"> <a href=\"contents/05_forest.html\" class=\"button button-border button-border-thin button-black text-right\">フォレストグループについて<i class=\"icon-line-chevron-right\"></i></a> </div>\n            </div>\n            <div class=\"col-lg-4 col-sm-8\"> <img src=\"images/img_tree.png\" alt=\"\"/> </div>\n          </div>\n        </div>\n      </div>\n      <div class=\"clear\"></div>\n      <div class=\"section bg-transparent\">\n        <div class=\"container clearfix\">\n          <div class=\"col-md-12 center\">\n            <div class=\"heading-block border-bottom-0 mb-4\">\n              <h2 class=\"mb-4 nott\">RECRUIT</h2>\n            </div>\n            <div class=\"svg-line bottommargin-sm clearfix\"> <img src=\"images/divider-1.svg\" alt=\"svg divider\" height=\"20\"> </div>\n            <h3 class=\"mb-3\">私たちと一緒に、働きませんか？</h3>\n            <p>藤村薬品では、いろんな“やりがい”が待っています。<br>\n              私たちは“健康に奉仕する藤村薬品”をモットーに、地域に密着した企業をめざし、ともに繁栄し貢献することを念願しています。</p>\n          </div>\n          <div class=\"row gutter-50 mt-5 col-mb-50 justify-content-center\">\n            <div class=\"col-sm-8 col-lg-6 col-xl-5\">\n              <div class=\"p-3\"> <a href=\"contents/04_info.html\"><img src=\"images/rec_01.png\" alt=\"採用案内\"/></a> </div>\n            </div>\n            <div class=\"col-sm-8 col-lg-6 col-xl-5\">\n              <div class=\"p-3\"> <a href=\"contents/04_welfare.html\"><img src=\"images/rec_02.png\" alt=\"研修制度・福利厚生\"/></a> </div>\n            </div>\n            <div class=\"col-sm-8 col-lg-6 col-xl-5\">\n              <div class=\"p-3\"> <a href=\"contents/04_voice.html\"><img src=\"images/rec_03.png\" alt=\"先輩社員の声\"/></a> </div>\n            </div>\n            <div class=\"col-sm-8 col-lg-6 col-xl-5\">\n              <div class=\"p-3\"> <a href=\"contents/04_faq.html\"><img src=\"images/rec_04.png\" alt=\"よくある質問\"/></a> </div>\n            </div>\n          </div>\n        </div>\n      </div>\n      <div class=\"section bg-black pt-3 pb-3 mb-0\">\n        <div class=\"container clearfix\">\n          <div class=\"row justify-content-center\">\n            <div class=\"col-md-12\">\n              <ul class=\"clients-grid grid-2 grid-md-5 mb-0\">\n                <li class=\"grid-item\"><a href=\"https://www.f-hd.jp\" target=\"_blank\"><img src=\"images/btn_01.png\" alt=\"株式会社フォレストホールディングス\"></a></li>\n                <li class=\"grid-item\"><a href=\"https://forestpedia.jp\" target=\"_blank\"><img src=\"images/btn_02.png\" alt=\"みらい創生史\"></a></li>\n                <li class=\"grid-item\"><a href=\"https://www.astemf.jp/magazine/\" target=\"_blank\"><img src=\"images/btn_03.png\" alt=\"情報誌 Poti\"></a></li>\n                <li class=\"grid-item\"><a href=\"http://ashinokai.com/index.html\" target=\"_blank\"><img src=\"images/btn_04.png\" alt=\"株式会社葦の会\"></a></li>\n                  <li class=\"grid-item\"><a href=\"https://dlink.astemf.jp/\" target=\"_blank\"><img src=\"images/btn_05.png\" alt=\"Drink\"></a></li>\n              </ul>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n  <!-- #content end --> \n  \n  <!-- Footer\n\t\t============================================= -->\n  <footer id=\"footer\" class=\"bg_lgreen border-0 pt-5\">\n    <div class=\"container clearfix\">\n      <div class=\"mb-3 text-center\"> <img src=\"images/logo_w.png\" srcset=\"images/logo_w.png 1x, images/logo_w@2x.png 2x\" alt=\"Canvas\"> </div>\n      <div class=\"col-12 text-center\"> <a href=\"contents/06_contact.html\">お問い合わせ</a> ｜ \n        <a href=\"data/file.php?sitepolicy\" target=\"_blank\">サイトポリシー</a> ｜ \n        <a href=\"data/file.php?privacypolicy\" target=\"_blank\">個人情報保護方針</a> ｜ \n        <a href=\"data/file.php?securitypolicy\" target=\"_blank\">情報セキュリティ基本方針</a> \n      </div>\n    </div>\n    \n    <!-- Copyrights\n\t\t\t============================================= -->\n    <div id=\"copyrights\" style=\"background-color: #77C345;\">\n      <div class=\"container clearfix\">\n        <div class=\"row justify-content-between align-items-center\">\n          <div class=\"col-md-12 text-center\"> &copy; 藤村薬品株式会社 </div>\n        </div>\n      </div>\n    </div>\n    <!-- #copyrights end --> \n    \n  </footer>\n  <!-- #footer end --> \n  \n</div>\n<!-- #wrapper end --> \n\n<!-- Go To Top\n\t============================================= -->\n<div id=\"gotoTop\" class=\"icon-angle-up\"></div>\n\n<!-- JavaScripts\n\t============================================= --> \n<script src=\"js/jquery.js\"></script> \n<script src=\"js/plugins.min.js\"></script> \n<script src=\"js/jquery.calendario.js\"></script> \n\n<!-- Footer Scripts\n\t============================================= --> \n<script src=\"js/functions.js\"></script> \n<!-- news\n\t============================================= --> \n<script src=\"/topics/test.js\"></script> \n<script src=\"./assets/plugins/plugins.js\"></script>\n</body>\n</html>","finalUrl":"https://www.fujimurayakuhin.jp/","rendered":false,"_cachedAt":"2026-06-17T23:13:55.966Z"}