{"url":"https://www.kinon.co.jp/recruit/saiyou-contact.shtml","html":"<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\">\n<meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width\" />\n<meta name=\"format-detection\" content=\"telephone=no\">\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/common.css\" />\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/zone.css\" />\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/bpts.css\" />\n<!-- Basic parts -->\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/unit.css\" />\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/col.css\" />\n<!-- 本文領域レイアウタ -->\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/other.css\" />\n<!--メールフォームプロ用CSS--> \n<link rel=\"stylesheet\" href=\"mfp.statics/mailformpro.css\" type=\"text/css\"> \n<!--/メールフォームプロ用CSS--> \n<!--<link rel=\"stylesheet\" href=\"mfp.statics/example.css\" type=\"text/css\">-->\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/local.css\" />\n<!--miscのcss-->\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../misc/css/local.css\" />\n<title>採用│お問い合わせ│Recruit│キノンビクス株式会社</title>\n\n<!-- スクリプトのインクルード（事前呼び出し） --> \n<meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\" />\n<link rel=\"icon\" href=\"../favicon.ico\">\n\n<!-- fontawesome -->\n<link href=\"https://use.fontawesome.com/releases/v5.6.1/css/all.css\" rel=\"stylesheet\">\n\n\n<style>\n\t#mfp_loading,\n\t#mfp_loading_screen,\n\t#mfp_overlay_background{\n\t\tdisplay: none;\n\t}\n\t#mfp_hidden input[type=\"submit\"] {\n\t\tdisplay: none;\n\t}\n</style>\n</head>\n<body>\n<div id=\"zone_sheet\"> \n  <!-- ヘッダーのインクルード --> \n  <meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\" />\n<!--\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/css/other.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/css/bpts.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/css/common.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/css/zone.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/css/unit.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/css/col.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/css/other.css\"/>\n -->\n<div class=\"header_bg\">\n<div class=\"header_logo\"><a href=\"../../\"><img src=\"../image/common/logo.svg\"></a></div>\n<nav class=\"pc_menu\">\n  <div class=\"o_mainmenu\">\n    <ul>\n      <li><a href=\"../about/\">About us</a>\n        <ul>\n          <li><a href=\"/about/index.shtml\">代表挨拶</a></li>\n          <li><a href=\"/about/overview.shtml\">会社概要</a></li>\n          <li><a href=\"/about/philosophy.shtml\">経営理念</a></li>\n          <li><a href=\"/about/promises.shtml\">7つのお約束</a></li>\n          <li><a href=\"/about/history.shtml\">沿革</a></li>\n          <li><a href=\"/about/employee.shtml\">社員保有資格一覧</a></li>\n          <li><a href=\"/about/certifications.shtml\">各種認定と宣言</a></li>\n        </ul>\n      </li>\n      <li><a href=\"../culture/\">Culture</a></li>\n      <li><a href=\"../solution/\">Solution</a>\n        <ul>\n          <li><a href=\"../solution/index.shtml#jump_01\">システムソリューション</a></li>\n          <li><a href=\"../solution/index.shtml#s_index_section02\">場所から探す</a></a></li>\n          <li><a href=\"../solution/index.shtml#s_index_section03\">納入事例</a></a></li>\n        </ul>\n      </li>\n      <li><a href=\"../recruit/\">Recruit</a>\n        <ul>\n          <li><a href=\"/recruit/\">採用情報</a></li>\n          <li><a href=\"/recruit/job.shtml\">職種紹介</a></li>\n          <li><a href=\"/recruit/interview.shtml\">社員インタビュー</a></li>\n          <li><a href=\"/recruit/requirements.shtml\">募集要項</a></li>\n        </ul>\n      </li>\n      <li><a href=\"../misc/contact.shtml\">Contact</a></li>\n    </ul>\n  </div>\n</nav>\n</div>\n<!-- レスポンシブメニュー　 -->\n<header>\n<div class=\"header-logo-menu\">\n<div id=\"nav-drawer\">\n<input id=\"nav-input\" type=\"checkbox\" class=\"nav-unshown\">\n<label id=\"nav-open\" for=\"nav-input\">\n<span></span>\n<p class=\"label_txt_menu\">MENU</p>\n</label>\n<label class=\"nav-unshown\" id=\"nav-close\" for=\"nav-input\"></label>\n<div id=\"nav-content\">\n<!--  ----------------- -->\n<div class=\"accordion\"> \n  <!-- menu1 -->\n  <div class=\"option\">\n    <input type=\"checkbox\" id=\"toggle1\" class=\"toggle\">\n    <label class=\"title item10\" for=\"toggle1\">About us</label>\n    <div class=\"content\">\n      <ul>\n        <li class=\"f_m10_10\"><a href=\"/about/index.shtml\">代表挨拶</a></li>\n        <li class=\"f_m10_20\"><a href=\"/about/overview.shtml\">会社概要</a></li>\n        <li class=\"f_m10_30\"><a href=\"/about/philosophy.shtml\">経営理念</a></li>\n        <li class=\"f_m10_40\"><a href=\"/about/promises.shtml\">7つのお約束</a></li>\n        <li class=\"f_m10_50\"><a href=\"/about/history.shtml\">沿革</a></li>\n        <li class=\"f_m10_60\"><a href=\"/about/employee.shtml\">社員保有資格一覧</a></li>\n        <li class=\"f_m10_70\"><a href=\"/about/certifications.shtml\">各種認定と宣言</a></li>\n      </ul>\n    </div>\n  </div>\n  <!-- menu2 -->\n  <div class=\"option\">\n    <div class=\"one_link\"><a href=\"../culture/\">Culture</a></div>\n  </div>\n  <!-- menu3 -->\n  <div class=\"option\">\n    <input type=\"checkbox\" id=\"toggle3\" class=\"toggle\">\n    <label class=\"title item50\" for=\"toggle3\">Solution</label>\n    <div class=\"content\">\n      <ul>\n        <li class=\"f_m30_10\"><a href=\"../solution/index.shtml#sp_jump_01\">システムソリューション</a></li>\n        <li class=\"f_m30_20\"><a href=\"../solution/index.shtml#jump_15\">場所から探す</a></a></li>\n        <li class=\"f_m30_30\"><a href=\"../solution/index.shtml#jump_02\">納入事例</a></a></li>\n      </ul>\n    </div>\n  </div>\n  <!-- menu4 -->\n  <div class=\"option\">\n    <input type=\"checkbox\" id=\"toggle4\" class=\"toggle\">\n    <label class=\"title item60\" for=\"toggle4\">Recruit</label>\n    <div class=\"content\">\n      <ul>\n        <li class=\"f_m40_10\"><a href=\"/recruit/\">採用情報</a></li>\n        <li class=\"f_m40_20\"><a href=\"/recruit/job.shtml\">職種紹介</a></li>\n        <li class=\"f_m40_30\"><a href=\"/recruit/interview.shtml\">社員インタビュー</a></li>\n        <li class=\"f_m40_40\"><a href=\"/recruit/requirements.shtml\">募集要項</a></li>\n      </ul>\n    </div>\n  </div>\n  <!-- menu5 -->\n  <div class=\"option\">\n    <div class=\"one_link\"><a href=\"../misc/contact.shtml\">Contact</a></div>\n  </div>\n<!-- menu6 -->\n  <div class=\"option\">\n    <div class=\"one_link\"><a href=\"../\">Home</a></div>\n  </div>\n</div alt=\"eod:accordion\">\n</header>\n<!-- --------------------------------------------------- --> \n\n \n  <!-- ヘッダーのインクルード 終わり　--> \n  \n  <!-- ステージ-->\n  <div id=\"zone_substage\">\n    <div>\n      <h1>Contact</h1>\n    </div>\n  <!--- パンくず -->\n  <ol class=\"zone_pankuzu\">\n    <li><a href=\"../\">HOME</a></li>\n    <li><a href=\"/recruit/\">Recruit</a></li>\n    <li>採用に関するお問い合わせ</li>\n  </ol>\n  <!-- パンくず --> \n  </div alt=\"eod:zone_substage\">\n  <!-- ステージ　終わり --> \n  <!-- 第2層 -->\n  <div id=\"zone_middle_floor\"> \n    <!--　ボディ領域　-->\n    <div id=\"zone_body\"> \n      <!--　メインエリア　-->\n      <div id=\"zone_mainarea_1col\">\n        <div class=\"sp_padding\"> \n          \n          <!--　▼▼▼　本文領域　▼▼▼　-->\n          <div class=\"col_textarea_full\">\n            <div class=\"width_content\"> \n              \n              <!--▽▽▽　ここからフォーム　▽▽▽-->\n              <div id=\"l_form_container\">\n                <form id=\"mailformpro\" action=\"mailformpro/mailformpro.cgi\" method=\"POST\">\n                  <dl class=\"mailform\">\n                    \n                    <!--お名前（必須）-->\n                    <input type=\"hidden\" name=\"お名前\" data-unjoin=\"姓+ +名+（+セイ+ +メイ+）\" value=\"\">\n                    <dt class=\"mfp\">お名前<span class=\"infomark_label oshirase\">必須</span></dt>\n                    <dd class=\"mfp\">\n                      <div class=\"mfp_rows\">\n                        <div class=\"mfp_col5 l_form_input_half\">\n                          <input type=\"text\" name=\"姓\" data-kana=\"セイ\" size=\"15\" required=\"required\" placeholder=\"山田\">\n                        </div>\n                        <div class=\"mfp_col5 l_form_input_half\">\n                          <input type=\"text\" name=\"名\" data-kana=\"メイ\" size=\"15\" required=\"required\" placeholder=\"太郎\">\n                        </div>\n                      </div>\n                    </dd>\n                    \n                    <!--フリガナ-->\n                    <dt class=\"mfp\">フリガナ</dt>\n                    <dd class=\"mfp\">\n                      <div class=\"mfp_rows\">\n                        <div class=\"mfp_col5 l_form_input_half\">\n                          <input type=\"text\" name=\"セイ\" size=\"15\" data-charcheck=\"zenkaku\" placeholder=\"ヤマダ\">\n                        </div>\n                        <div class=\"mfp_col5 l_form_input_half\">\n                          <input type=\"text\" name=\"メイ\" size=\"15\" data-charcheck=\"kana\"  placeholder=\"タロウ\">\n                        </div>\n                      </div>\n                    </dd>\n                    \n                    <!--会社名-->\n                    <dt class=\"mfp\">会社名</dt>\n                    <dd class=\"mfp\">\n                      <div class=\"mfp_rows\">\n                        <div class=\"mfp_col10 l_form_input_whole\">\n                          <input type=\"text\" name=\"会社名\" placeholder=\"キノンビクス株式会社\">\n                        </div>\n                      </div>\n                    </dd>\n                    \n                    <!--住所-->\n                    <dt class=\"mfp\">郵便番号</dt>\n                    <dd class=\"mfp\">\n                      <input type=\"hidden\" name=\"ご住所\" data-unjoin=\"〒+郵便番号+\\n+都道府県+市区町村+丁目番地\" value=\"\">\n                      <div class=\"mfp_rows\">\n                        <div class=\"mfp_col10 l_form_input_whole\">\n                          <input type=\"text\" name=\"郵便番号\" size=\"30\" data-address=\"都道府県,市区町村,市区町村\" autocomplete=\"off\" placeholder=\"5203045\">\n                        </div>\n                      </div>\n                    </dd>\n                    <dt class=\"mfp\">住所</dt>\n                    <dd class=\"mfp\">\n                      <div class=\"mfp_rows l_form_flex_column\">\n                        <div class=\"mfp_col10  l_form_input_whole\">\n                          <select name=\"都道府県\">\n                            <option value=\"\" selected=\"selected\">【選択して下さい】</option>\n                            <optgroup label=\"北海道・東北地方\">\n                            <option value=\"北海道\">北海道</option>\n                            <option value=\"青森県\">青森県</option>\n                            <option value=\"岩手県\">岩手県</option>\n                            <option value=\"秋田県\">秋田県</option>\n                            <option value=\"宮城県\">宮城県</option>\n                            <option value=\"山形県\">山形県</option>\n                            <option value=\"福島県\">福島県</option>\n                            </optgroup>\n                            <optgroup label=\"関東地方\">\n                            <option value=\"栃木県\">栃木県</option>\n                            <option value=\"群馬県\">群馬県</option>\n                            <option value=\"茨城県\">茨城県</option>\n                            <option value=\"埼玉県\">埼玉県</option>\n                            <option value=\"東京都\">東京都</option>\n                            <option value=\"千葉県\">千葉県</option>\n                            <option value=\"神奈川県\">神奈川県</option>\n                            </optgroup>\n                            <optgroup label=\"中部地方\">\n                            <option value=\"山梨県\">山梨県</option>\n                            <option value=\"長野県\">長野県</option>\n                            <option value=\"新潟県\">新潟県</option>\n                            <option value=\"富山県\">富山県</option>\n                            <option value=\"石川県\">石川県</option>\n                            <option value=\"福井県\">福井県</option>\n                            <option value=\"静岡県\">静岡県</option>\n                            <option value=\"岐阜県\">岐阜県</option>\n                            <option value=\"愛知県\">愛知県</option>\n                            </optgroup>\n                            <optgroup label=\"近畿地方\">\n                            <option value=\"三重県\">三重県</option>\n                            <option value=\"滋賀県\">滋賀県</option>\n                            <option value=\"京都府\">京都府</option>\n                            <option value=\"大阪府\">大阪府</option>\n                            <option value=\"兵庫県\">兵庫県</option>\n                            <option value=\"奈良県\">奈良県</option>\n                            <option value=\"和歌山県\">和歌山県</option>\n                            </optgroup>\n                            <optgroup label=\"四国地方\">\n                            <option value=\"徳島県\">徳島県</option>\n                            <option value=\"香川県\">香川県</option>\n                            <option value=\"愛媛県\">愛媛県</option>\n                            <option value=\"高知県\">高知県</option>\n                            </optgroup>\n                            <optgroup label=\"中国地方\">\n                            <option value=\"鳥取県\">鳥取県</option>\n                            <option value=\"島根県\">島根県</option>\n                            <option value=\"岡山県\">岡山県</option>\n                            <option value=\"広島県\">広島県</option>\n                            <option value=\"山口県\">山口県</option>\n                            </optgroup>\n                            <optgroup label=\"九州・沖縄地方\">\n                            <option value=\"福岡県\">福岡県</option>\n                            <option value=\"佐賀県\">佐賀県</option>\n                            <option value=\"長崎県\">長崎県</option>\n                            <option value=\"大分県\">大分県</option>\n                            <option value=\"熊本県\">熊本県</option>\n                            <option value=\"宮崎県\">宮崎県</option>\n                            <option value=\"鹿児島県\">鹿児島県</option>\n                            <option value=\"沖縄県\">沖縄県</option>\n                            </optgroup>\n                          </select>\n                        </div>\n                        <div class=\"mfp_col10  l_form_input_whole\">\n                          <input type=\"text\" name=\"市区町村\" placeholder=\"市区町村\" size=\"50\">\n                        </div>\n                        <div class=\"mfp_col10  l_form_input_whole\">\n                          <input type=\"text\" name=\"丁目番地\" placeholder=\"丁目番地\" size=\"50\">\n                        </div>\n                        <div class=\"mfp_col10  l_form_input_whole\">\n                          <input type=\"text\" name=\"建物名\" placeholder=\"建物名・号室\" size=\"50\">\n                        </div>\n                      </div>\n                    </dd>\n                    <dt class=\"mfp\">電話番号</dt>\n                    <dd class=\"mfp\">\n                      <div class=\"mfp_rows\">\n                        <div class=\"mfp_col10  l_form_input_whole\">\n                          <input type=\"tel\" data-type=\"tel\" name=\"電話番号\" size=\"16\" data-min=\"9\" placeholder=\"01234567890\">\n                        </div>\n                      </div>\n                    </dd>\n                    <dt class=\"mfp\">FAX番号</dt>\n                    <dd class=\"mfp\">\n                      <div class=\"mfp_rows\">\n                        <div class=\"mfp_col10  l_form_input_whole\">\n                          <input type=\"tel\" data-type=\"tel\" name=\"FAX番号\" size=\"16\" data-min=\"9\" placeholder=\"01234567890\">\n                        </div>\n                      </div>\n                    </dd>\n                    <dt class=\"mfp\">メールアドレス<span class=\"infomark_label oshirase\">必須</span></dt>\n                    <dd class=\"mfp\">\n                      <div class=\"mfp_rows\">\n                        <div class=\"mfp_col10  l_form_input_whole\">\n                          <input type=\"email\" data-type=\"email\" name=\"email\" size=\"40\" required=\"required\" placeholder=\"email@sample.co.jp\">\n                        </div>\n                      </div>\n                    </dd>\n                    <dt class=\"mfp\">確認のためもう一度<span class=\"infomark_label oshirase\">必須</span></dt>\n                    <dd class=\"mfp\">\n                      <div class=\"mfp_rows\">\n                        <div class=\"mfp_col10  l_form_input_whole\">\n                          <input type=\"email\" data-type=\"email\" name=\"confirm_email\" data-post-disable=\"1\" size=\"40\" required=\"required\" placeholder=\"email@sample.co.jp\">\n                        </div>\n                      </div>\n                    </dd>\n                    <dt class=\"mfp\">メッセージ本文</dt>\n                    <dd class=\"mfp\">\n                      <div class=\"mfp_rows\">\n                        <div class=\"mfp_col10  l_form_input_whole\">\n                          <textarea name=\"備考欄\" rows=\"10\" cols=\"60\" placeholder=\"ここにメッセージを入力してください\"></textarea>\n                        </div>\n                      </div>\n                    </dd>\n                    <dt class=\"mfp\">送信確認<span class=\"infomark_label oshirase\">必須</span></dt>\n                    <dd class=\"mfp\">\n                      <div class=\"mfp_rows\">\n                        <div class=\"mfp_col10\">\n                          <label>\n                            <input type=\"checkbox\" required=\"required\" data-exc=\"1\" name=\"送信確認\" value=\"送信チェック済み\">送信内容を確認しました</label>\n                        </div>\n                      </div>\n                    </dd>\n                    <dt class=\"mfp mfp_margin_top\">\n\t\t\t\t\t\t\t\t\t\t\t<dt class=\"mfp\">\n\t\t\t\t\t\t\t\t\t\t\t\t<a href=\"../misc/privacy-policy.shtml\" class=\"link_targetblank\" style=\"text-decoration: underline\" target=\"_blank\">プライバシーポリシー</a> の同意\n\t\t\t\t\t\t\t\t\t\t\t\t<span class=\"infomark_label oshirase\">必須</span>\n\t\t\t\t\t\t\t\t\t\t\t</dt>\n\t\t\t\t\t\t\t\t\t\t</dt>\n                    <dd class=\"mfp\">\n                      <div class=\"mfp_rows\">\n                        <div class=\"mfp_col10\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t<label>\n                            <input type=\"checkbox\" required=\"required\" data-exc=\"1\" name=\"プライバシーポリシーの同意\" value=\"同意済み\">\n                            プライバシーポリシーに同意します</label>\n                    </dd>\n                  </dl>\n                  <div class=\"mfp_buttons\">\n                    <button type=\"submit\" class=\"check_btn\">確認画面へ</button>\n                  </div>\n                </form>\n                <script type=\"text/javascript\" id=\"mfpjs\" src=\"mailformpro/mailformpro.cgi\" charset=\"UTF-8\"></script> \n              </div>\n              <!--△△△　ここまでフォーム　△△△--> \n            </div>\n          </div alt=\"col_textarea_full\">\n          <!--　▲▲▲　本文領域　終わり　▲▲▲　--> \n        </div>\n        <!-- eod:sp_padding --> \n      </div alt=\"eod:zone_mainarea\">\n      <!--　メインエリア　終わり　--> \n    </div alt=\"eod:zone_body\">\n    <!--　ボディ領域　終わり　--> \n  </div alt=\"eod:zone_middle\">\n  <!--　第2層　終わり　--> \n  <!--　第3層　-->\n  <div id=\"zone_bottom_floor\"> \n    <!--　フッター　-->\n    <div id=\"zone_footer\"> \n      <!-- フッターのインクルード --> \n      <meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\" />\n<meta name=\"format-detection\" content=\"telephone=no\">\n<!-- \n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/common.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/zone.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/bpts.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/unit.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"