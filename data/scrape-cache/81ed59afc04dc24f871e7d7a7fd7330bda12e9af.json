-- /.p-nav -->    </nav><!-- /.l-nav -->\n\n    <main class=\"l-main\">\n<div class=\"p-interview\">\n\n  <div class=\"p-interview-hero\">\n    <div class=\"p-interview-title u-sp-mb50 u-pc-mb50\">\n      <p class=\"p-interview-title__ja\">先輩インタビュー</p>\n      <div class=\"p-interview-title__main\">\n        <p class=\"p-interview-title__en\">INTERVIEW</p>\n        <span class=\"p-interview-title__category\">新卒採用</span>\n      </div>\n    </div><!-- /.p-interview-title -->\n    <div class=\"c-inner p-interview-hero__inner\">\n      <header class=\"p-interview-header  u-sp-mb170 u-pc-mb20\">\n        <p class=\"p-interview-header__ja\">「これから」を共に。</p>\n        <p class=\"p-interview-header__en\">CREATING TOGETHER</p>\n        <p class=\"p-interview-header__message\">Toward the next 100 years.</p>\n      </header><!-- /.p-interview-header -->\n      <div class=\"p-interview-visual\">\n        <div class=\"p-interview-visual__body\">\n          <p class=\"p-interview-visual__common\">私とISEKIの「これから」</p>\n          <p class=\"p-interview-visual__keyword\">PIONEER</p>\n          <p class=\"p-interview-visual__job\">移植技術部</p>\n          <p class=\"p-interview-visual__name\">K . Y</p>\n        </div>\n        <div class=\"p-interview-visual__number-wrapper\">\n          <span class=\"p-interview-visual__category\">新卒採用</span>\n          <span class=\"p-interview-visual__number\">02</span>\n        </div>\n        <figure class=\"p-interview-visual__img-wrapper\">\n          <img class=\"p-interview-visual__img\" src=\"/assets/images/interview/newgraduates02_mv.jpg\" alt=\"\">\n        </figure>\n      </div><!-- /.p-interview-visual -->\n      <div class=\"p-interview-profile\">\n        <h3 class=\"p-interview-profile__title\">Profile</h3>\n        <div class=\"p-interview-profile__body\">\n          <p class=\"p-interview-profile__name\">K . Y</p>\n          <p class=\"p-interview-profile__bio\">\n            移植技術部<br>\n            <span class=\"p-interview-profile__location\">勤務地：愛媛</span>入社年：2019年度<br>\n            出身学部：農学部　農業環境工学専攻<br>\n            担当業務：田植機の機能研究・開発設計\n          </p>\n        </div>\n      </div><!-- /.p-interview-profile -->\n    </div><!-- /.c-inner -->\n    <div class=\"p-interview-hero__message\">CREATING TOGETHER</div>\n  </div><!-- /.p-interview-hero -->\n\n  <section class=\"c-inner p-interview-item p-interview-item--intro\">\n    <p class=\"p-interview-item__lead\">「これから」を共に。</p>\n  </section><!-- /.p-interview-item -->\n\n  <section class=\"p-interview-keyword\">\n    <div class=\"c-inner p-interview-keyword__inner\">\n      <h4 class=\"p-interview-keyword__title\">KEY WORD</h4>\n      <h3 class=\"p-interview-keyword__lead\">PIONEER</h3>\n      <p class=\"p-interview-keyword__text\">\n        世界に誇れる農業機械をつくるため<br>\n        先駆けとなるような先進技術を取り入れています。\n      </p>\n    </div>\n  </section><!-- /.p-interview-keyword -->\n\n  <section class=\"c-inner p-interview-item p-interview-item--question1\">\n    <h3 class=\"p-interview-item-title u-sp-mb90 u-pc-mb60\">\n      <span class=\"p-interview-item-title__en\">\n        QUESTION<span class=\"p-interview-item-title__number\">1</span>\n      </span>\n      <span class=\"p-interview-item-title__ja\">井関農機を選んだ理由を教えてください。</span>\n    </h3><!-- /.p-interview-item-title -->\n    <div class=\"p-interview-item-answer\">\n      <h4 class=\"p-interview-item-answer__heading\">\n        <span class=\"p-interview-item-answer__heading-inner\">ANSWER</span>\n      </h4>\n      <div class=\"p-interview-item-answer__body\">\n        <p class=\"p-interview-item-answer__text\">\n          大学時代にさといも農家さんの畑で研究をさせてもらい、実際に収穫作業も体験して、農業の大変さを少しばかり体感しました。<br>\n          これまでの農業機械の発展により農作業の負担が大幅に軽減されてきたことは間違いありませんが、現在も農作業の端々に労力を要する場面があることも事実です。<br>\n          農家さんの作業負担を機械の力で少しでも助けたい、そんな思いで井関農機に入社しました。加えて、農機メーカーの中でも、井関農機は可変施肥田植機を業界に先駆けて製品化しており、先進的な技術も積極的に取り入れるような、挑戦しがいのある会社という印象を受け、井関農機を選びました。\n        </p>\n      </div>\n    </div><!-- /.p-interview-item-answer -->\n  </section><!-- /.p-interview-item -->\n\n  <section class=\"c-inner p-interview-item p-interview-item--question2\">\n    <h3 class=\"p-interview-item-title u-sp-mb90 u-pc-mb60\">\n      <span class=\"p-interview-item-title__en\">\n        QUESTION<span class=\"p-interview-item-title__number\">2</span>\n      </span>\n      <span class=\"p-interview-item-title__ja\">現在の仕事内容を教えてください。</span>\n    </h3><!-- /.p-interview-item-title -->\n    <div class=\"p-interview-item-answer\">\n      <h4 class=\"p-interview-item-answer__heading\">\n        <span class=\"p-interview-item-answer__heading-inner\">ANSWER</span>\n      </h4>\n      <div class=\"p-interview-item-answer__body\">\n        <p class=\"p-interview-item-answer__text\">\n          現在は乗用田植機の、先行的な機能研究および開発・設計に取り組んでいます。<br>\n          すでに製品として出荷されているロボット田植機の機能改良や、これまでになかった新たな機能を追加するべく、チーム単位で業務を進めています。\n        </p>\n      </div>\n    </div><!-- /.p-interview-item-answer -->\n  </section><!-- /.p-interview-item -->\n\n  <section class=\"c-inner p-interview-item p-interview-item--question3\">\n    <h3 class=\"p-interview-item-title u-sp-mb90 u-pc-mb60\">\n      <span class=\"p-interview-item-title__en\">\n        QUESTION<span class=\"p-interview-item-title__number\">3</span>\n      </span>\n      <span class=\"p-interview-item-title__ja\">これまでで一番やりがいを感じた<br class=\"u-sp-only\">エピソードを教えてください。</span>\n    </h3><!-- /.p-interview-item-title -->\n    <div class=\"p-interview-item-answer\">\n      <h4 class=\"p-interview-item-answer__heading\">\n        <span class=\"p-interview-item-answer__heading-inner\">ANSWER</span>\n      </h4>\n      <div class=\"p-interview-item-answer__body\">\n        <p class=\"p-interview-item-answer__text\">\n          砥部事業所の稲作一貫体系研修に参加したことです。<br>\n          播種、耕うん、田植え、刈取りなど稲作一連の過程を体験して、知識と気づきを得るための研修でした。<br>\n          研修内では、生育調査と収量調査も実施し、米の生育を継続的に観察しました。<br>\n          可変施肥作業と収量の結果を比較するなど、実体験として営農情報の活用を考えられ、難しさも感じました。<br>\n          急加速で進む営農情報の活用に、当社としても製品を揃えられるよう、今回の経験を生かしていきたいです。\n        </p>\n      </div>\n    </div><!-- /.p-interview-item-answer -->\n  </section><!-- /.p-interview-item -->\n\n  <div class=\"c-inner p-interview-item\">\n    <figure>\n      <img src=\"/assets/images/interview/newgraduates02_article.jpg\" alt=\"\">\n    </figure>\n  </div><!-- /.p-interview-item -->\n\n  <section class=\"c-inner p-interview-item p-interview-item--question4\">\n    <h3 class=\"p-interview-item-title u-sp-mb90 u-pc-mb60\">\n      <span class=\"p-interview-item-title__en\">\n        QUESTION<span class=\"p-interview-item-title__number\">4</span>\n      </span>\n      <span class=\"p-interview-item-title__ja\">これまでで一番苦労した<br class=\"u-sp-only\">仕事のエピソードは何ですか？</span>\n    </h3><!-- /.p-interview-item-title -->\n    <div class=\"p-interview-item-answer\">\n      <h4 class=\"p-interview-item-answer__heading\">\n        <span class=\"p-interview-item-answer__heading-inner\">ANSWER</span>\n      </h4>\n      <div class=\"p-interview-item-answer__body\">\n        <p class=\"p-interview-item-answer__text\">\n          私自身はじめてのソフトウェア仕様設計を担当することになりました。<br>\n          先輩やプログラマーの方々に助言をもらいながら、基本仕様を作成し、現在も開発・設計中です。<br>\n          苗の特性に関わる制御内容ですが、なかなか正解が見つからず苦労しました。<br>\n          これからも試験を重ねて、ユーザーの助けになるような機能にしていきたいです。\n        </p>\n      </div>\n    </div><!-- /.p-interview-item-answer -->\n  </section><!-- /.p-interview-item -->\n\n  <section class=\"c-inner p-interview-item p-interview-item--question5\">\n    <h3 class=\"p-interview-item-title u-sp-mb90 u-pc-mb60\">\n      <span class=\"p-interview-item-title__en\">\n        QUESTION<span class=\"p-interview-item-title__number\">5</span>\n      </span>\n      <span class=\"p-interview-item-title__ja\">今後の目標は何ですか？</span>\n    </h3><!-- /.p-interview-item-title -->\n    <div class=\"p-interview-item-answer\">\n      <h4 class=\"p-interview-item-answer__heading\">\n        <span class=\"p-interview-item-answer__heading-inner\">ANSWER</span>\n      </h4>\n      <div class=\"p-interview-item-answer__body\">\n        <p class=\"p-interview-item-answer__text\">\n          製品開発に先行した研究テーマを担当すると、自動操舵技術やマップデータ活用技術など先進技術を扱うことが多いです。<br>\n          先進技術を製品に取り入れていくためには、設計者としてメカとソフトの双方を理解する必要があると、仕事をしていく中で実感しています。<br>\n          実際にユーザーとして作業する立場で製品をつくることに重きを置き、メカ設計とソフトウェア仕様設計の２本立てを今後のスキルアップの目標に頑張っていきたいです。\n        </p>\n      </div>\n    </div><!-- /.p-interview-item-answer -->\n  </section><!-- /.p-interview-item -->\n\n  <section class=\"c-inner p-interview-item p-interview-item--schedule\">\n    <h3 class=\"p-interview-item__schedule-title\">ある1日のスケジュール</h3>\n    <div class=\"p-interview-schedule p-interview-schedule--02\">\n      <ul class=\"p-interview-schedule__items p-interview-schedule__items--left\">\n        <li class=\"p-interview-schedule__item\">\n          <time class=\"p-interview-schedule__time\">8：00</time>\n          <p class=\"p-interview-schedule__text\">始業</p>\n        </li>\n        <li class=\"p-interview-schedule__item\">\n          <time class=\"p-interview-schedule__time\">10：00</time>\n          <p class=\"p-interview-schedule__text\">設計業務</p>\n        </li>\n        <li class=\"p-interview-schedule__item\">\n          <time class=\"p-interview-schedule__time\">12：00</time>\n          <p class=\"p-interview-schedule__text\">昼休憩</p>\n        </li>\n        <li class=\"p-interview-schedule__item\">\n          <time class=\"p-interview-schedule__time\">13：00</time>\n          <p class=\"p-interview-schedule__text\">ほ場試験</p>\n        </li>\n        <li class=\"p-interview-schedule__item\">\n          <time class=\"p-interview-schedule__time\">16：00</time>\n          <p class=\"p-interview-schedule__text\">試験結果まとめ</p>\n        </li>\n        <li class=\"p-interview-schedule__item\">\n          <time class=\"p-interview-schedule__time\">16：50</time>\n          <p class=\"p-interview-schedule__text\">退勤</p>\n        </li>\n      </ul>\n      <p class=\"p-interview-schedule__comment\">\n        現在は先行的な研究テーマを担当しているため、試験も多いですが、基本的には設計の時間が主になります。<br>製品開発が進んでいくにつれて、数日単位で設計や試験、組立をすることもあります。\n      </p>\n    </div><!-- /.p-interview-schedule -->\n  </section><!-- /.p-interview-item -->\n\n  <section class=\"c-inner p-interview-item p-interview-item--question6\">\n    <h3 class=\"p-interview-item-title u-sp-mb90 u-pc-mb60\">\n      <span class=\"p-interview-item-title__en\">\n        QUESTION<span class=\"p-interview-item-title__number\">6</span>\n      </span>\n      <span class=\"p-interview-item-title__ja\">オフの日の過ごし方を聞かせてください。</span>\n    </h3><!-- /.p-interview-item-title -->\n    <div class=\"p-interview-item__private\">\n      <div class=\"p-interview-item-answer p-interview-item-answer--column\">\n        <h4 class=\"p-interview-item-answer__heading\">\n          <span class=\"p-interview-item-answer__heading-inner\">ANSWER</span>\n        </h4>\n        <div class=\"p-interview-item-answer__body\">\n          <p class=\"p-interview-item-answer__text\">\n            車で買い物へ出かけたり、家でお笑い番組やアニメを見たりしてくつろいでいます。<br>\n            学生時代にしていた趣味のバスケットボールを週１〜月１回行い、体を動かしてリフレッシュしています。\n          </p>\n        </div>\n      </div>\n      <figure class=\"p-interview-item__img-wrapper\">\n        <img src=\"/assets/images/interview/newgraduates02_private.jpg\" alt=\"\">\n      </figure>\n    </div><!-- /.p-interview-item-answer -->\n  </section><!-- /.p-interview-item -->\n\n  <section class=\"c-inner p-interview-item p-interview-item--message\">\n    <h3 class=\"p-interview-item-title u-sp-mb50 u-pc-mb40\">\n      <span class=\"p-interview-item-title__en\">MESSAGE</span>\n      <span class=\"p-interview-item-title__ja\">就活をしている学生の皆さんへ<br class=\"u-sp-only\">メッセージをお願いします。</span>\n    </h3><!-- /.p-interview-item-title -->\n    <div class=\"p-interview-item-answer\">\n      <p class=\"p-interview-item-answer__text p-interview-item-answer__text--center\">\n        就職活動を始めるにあたって、自分の性格や目標、軸など、自分自身と向き合う時間が増えていきます。<br>\n        私自身、慣れない就職活動には苦しみましたが、自分のことを理解する重要な期間でもあったと思います。<br>\n        自分の興味がどこを向いているかに着目することは、職を決める上では一つの手であり、要でもあると私は思っています。<br>\n        具体的に働いている自分を想像することが難しくても、興味のある対象と関われるためです。<br>\n        井関農機の開発は、設計・組立・試験など多様な業務に携われる楽しさとやりがいがあります。<br>\n        当社に入社していただけた際には、ともに世界に誇れる農業機械をつくっていきましょう。\n      </p>\n    </div>\n  </section><!-- /.p-interview-item -->\n\n  <section class=\"p-other-interview\">\n    <h3 class=\"p-other-interview__title\">\n      <span class=\"p-other-interview__title-en\">OTHER INTERVIEW</span>\n      <span class=\"p-other-interview__title-ja\">新卒採用</span>\n    </h3>\n    <div class=\"p-slider js-slider-interview\">\n      <div class=\"p-slider__inner swiper-wrapper\">\n  <div class=\"p-slider__item swiper-slide\">\n    <a class=\"p-slider__link\" href=\"/newgraduates/interview01/\">\n      <figure class=\"p-slider__img-wrapper\">\n        <div class=\"p-slider__img-mask\">\n          <img class=\"p-slider__img\" src=\"/assets/images/interview/newgraduates01_slider.jpg\" alt=\"\">\n        </div>\n        <div class=\"p-slider__number-wrapper\">\n          <span class=\"p-slider__category\">新卒採用</span>\n          <span class=\"p-slider__number\">01</span>\n        </div>\n      </figure>\n      <div class=\"p-slider__body\">\n        <p class=\"p-slider__job\">トラクタ技術部</p>\n        <p class=\"p-slider__name\">K . A</p>\n      </div>\n      <buttom class=\"c-button p-slider__button\">View more</buttom>\n    </a>\n  </div>\n  <div class=\"p-slider__item swiper-slide\">\n    <a class=\"p-slider__link\" href=\"/newgraduates/interview02/\">\n      <figure class=\"p-slider__img-wrapper\">\n        <div class=\"p-slider__img-mask\">\n          <img class=\"p-slider__img\" src=\"/assets/images/interview/newgraduates02_slider.jpg\" alt=\"\">\n        </div>\n        <div class=\"p-slider__number-wrapper\">\n          <span class=\"p-slider__category\">新卒採用</span>\n          <span class=\"p-slider__number\">02</span>\n        </div>\n      </figure>\n      <div class=\"p-slider__body\">\n        <p class=\"p-slider__job\">移植技術部</p>\n        <p class=\"p-slider__name\">K . Y</p>\n      </div>\n      <buttom class=\"c-button p-slider__button\">View more</buttom>\n    </a>\n  </div>\n  <div class=\"p-slider__item swiper-slide\">\n    <a class=\"p-slider__link\" href=\"/newgraduates/interview03/\">\n      <figure class=\"p-slider__img-wrapper\">\n        <div class=\"p-slider__img-mask\">\n          <img class=\"p-slider__img\" src=\"/assets/images/interview/newgraduates03_slider.jpg\" alt=\"\">\n        </div>\n        <div class=\"p-slider__number-wrapper\">\n          <span class=\"p-slider__category\">新卒採用</span>\n          <span class=\"p-slider__number\">03</span>\n        </div>\n      </figure>\n      <div class=\"p-slider__body\">\n        <p class=\"p-slider__job\">アグリクリエイト部</p>\n        <p class=\"p-slider__name\">Y . K</p>\n      </div>\n      <buttom class=\"c-button p-slider__button\">View more</buttom>\n    </a>\n  </div>\n  <div class=\"p-slider__item swiper-slide\">\n    <a class=\"p-slider__link\" href=\"/newgraduates/interview04/\">\n      <figure class=\"p-slider__img-wrapper\">\n        <div class=\"p-slider__img-mask\">\n          <img class=\"p-slider__img\" src=\"/assets/images/interview/newgraduates04_slider.jpg\" alt=\"\">\n        </div>\n        <div class=\"p-slider__number-wrapper\">\n          <span class=\"p-slider__category\">新卒採用</span>\n          <span class=\"p-slider__number\">04</span>\n        </div>\n      </figure>\n      <div class=\"p-slider__body\">\n        <p class=\"p-slider__job\">技術サービス部</p>\n        <p class=\"p-slider__name\">R . M</p>\n      </div>\n      <buttom class=\"c-button p-slider__button\">View more</buttom>\n    </a>\n  </div>\n  <div class=\"p-slider__item swiper-slide\">\n    <a class=\"p-slider__link\" href=\"/newgraduates/interview05/\">\n      <figure class=\"p-slider__img-wrapper\">\n        <div class=\"p-slider__img-mask\">\n          <img class=\"p-slider__img\" src=\"/assets/images/interview/newgraduates05_slider.jpg\" alt=\"\">\n        </div>\n        <div class=\"p-slider__number-wrapper\">\n          <span class=\"p-slider__category\">新卒採用</span>\n          <span class=\"p-slider__number\">05</span>\n        </div>\n      </figure>\n      <div class=\"p-slider__body\">\n        <p class=\"p-slider__job\">海外営業総括部</p>\n        <p class=\"p-slider__name\">S . M</p>\n      </div>\n      <buttom class=\"c-button p-slider__button\">View more</buttom>\n    </a>\n  </div>\n  <div class=\"p-slider__item swiper-slide\">\n    <a class=\"p-slider__link\" href=\"/newgraduates/interview06/\">\n      <figure class=\"p-slider__img-wrapper\">\n        <div class=\"p-slider__img-mask\">\n          <img class=\"p-slider__img\" src=\"/assets/images/interview/newgraduates06_slider.jpg\" alt=\"\">\n        </div>\n        <div class=\"p-slider__number-wrapper\">\n          <span class=\"p-slider__category\">新卒採用</span>\n          <span class=\"p-slider__number\">06</span>\n        </div>\n      </figure>\n      <div class=\"p-slider__body\">\n        <p class=\"p-slider__job\">北米駐在員事務所</p>\n        <p class=\"p-slider__name\">R . K</p>\n      </div>\n      <buttom class=\"c-button p-slider__button\">View more</buttom>\n    </a>\n  </div>\n  <div class=\"p-slider__item swiper-slide\">\n    <a class=\"p-slider__link\" href=\"/newgraduates/interview07/\">\n      <figure class=\"p-slider__img-wrapper\">\n        <div class=\"p-slider__img-mask\">\n          <img class=\"p-slider__img\" src=\"/assets/images/interview/newgraduates07_slider.jpg\" alt=\"\">\n        </div>\n        <div class=\"p-slider__number-wrapper\">\n          <span class=\"p-slider__category\">新卒採用</span>\n          <span class=\"p-slider__number\">07</span>\n        </div>\n      </figure>\n      <div class=\"p-slider__body\">\n        <p class=\"p-slider__job\">コンプライアンス・法務部</p>\n        <p class=\"p-slider__name\">R . S</p>\n      </div>\n      <buttom class=\"c-button p-slider__button\">View more</buttom>\n    </a>\n  </div>\n</div>\n<div class=\"swiper-pagination\"></div>\n<div class=\"swiper-button-prev\"></div>\n<div class=\"swiper-button-next\"></div>    </div><!-- /.p-slider -->\n  </section><!-- /.p-other-interview -->\n\n</div><!-- /.p-interview -->\n\n    </main><!-- /.l-main -->\n\n    <footer class=\"l-footer\">\n      <div class=\"p-footer\">\n  <div class=\"p-footer__inner\">\n    <ul class=\"p-footer__nav\">\n  <li class=\"p-footer__nav-item\">\n    <a class=\"c-link-blank p-footer__nav-link\" href=\"https://www.iseki.co.jp/\" target=\"_blank\">井関農機株式会社 企業サイト</a>\n  </li>\n  <li class=\"p-footer__nav-item\">\n    <a class=\"c-link-blank p-footer__nav-link\" href=\"https://www.iseki.co.jp/pp/\" target=\"_blank\">個人情報保護方針</a>\n  </li>\n  <li class=\"p-footer__nav-item\">\n    <a class=\"c-link-blank p-footer__nav-link\" href=\"https://www.iseki.co.jp/aboutsite/\" target=\"_blank\">サイトについて</a>\n  </li>\n  <li class=\"p-footer__nav-item\">\n    <a class=\"c-link-blank p-footer__nav-link\" href=\"https://www.iseki.co.jp/socialmedia-gl/\" target=\"_blank\">ソーシャルメディアガイドライン</a>\n  </li>\n</ul>    <p class=\"p-footer__copyright\">&copy;2024 ISEKI &amp; CO.,LTD.</p>\n  </div>\n</div><!-- /.p-footer -->    </footer><!-- /.l-footer -->\n\n  </div><!-- /.l-container -->\n</body>\n\n</html>","finalUrl":"https://recruit.iseki.co.jp/newgraduates/interview02/","rendered":false,"_cachedAt":"2026-06-23T16:29:34.076Z"}