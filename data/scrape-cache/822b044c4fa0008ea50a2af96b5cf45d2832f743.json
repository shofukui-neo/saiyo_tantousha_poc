menu\">\n\t<li id=\"menu-item-3184\" class=\"menu-item menu-item-type-custom menu-item-object-custom\"><a href=\"http:////www.letus.co.jp/company2/#company\">会社概要</a></li>\n\t<li id=\"menu-item-3181\" class=\"menu-item menu-item-type-custom menu-item-object-custom\"><a href=\"https://www.letus.co.jp/company2/#history\">沿革</a></li>\n\t<li id=\"menu-item-3182\" class=\"menu-item menu-item-type-custom menu-item-object-custom\"><a href=\"http:////www.letus.co.jp/company2/#info\">会社情報</a></li>\n\t<li id=\"menu-item-3183\" class=\"menu-item menu-item-type-custom menu-item-object-custom\"><a href=\"http:////www.letus.co.jp/company2/#board\">社内委員会活動</a></li>\n</ul>\n</li>\n<li id=\"menu-item-29\" class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-has-children\"><a title=\"service\" href=\"https://www.letus.co.jp/letus_work/\"><strong>サービス案内</strong></a>\n<ul class=\"sub-menu\">\n\t<li id=\"menu-item-2543\" class=\"menu-item menu-item-type-post_type menu-item-object-page\"><a href=\"https://www.letus.co.jp/smadeli/\">製品紹介</a></li>\n\t<li id=\"menu-item-1037\" class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-has-children\"><a href=\"https://www.letus.co.jp/letus_work/\">サービス案内</a>\n\t<ul class=\"sub-menu\">\n\t\t<li id=\"menu-item-1340\" class=\"menu-item menu-item-type-post_type menu-item-object-page\"><a href=\"https://www.letus.co.jp/letus_work/service01/\">業務システム開発サービス</a></li>\n\t\t<li id=\"menu-item-1376\" class=\"menu-item menu-item-type-post_type menu-item-object-page\"><a href=\"https://www.letus.co.jp/letus_work/service02/\">Webシステム開発サービス</a></li>\n\t\t<li id=\"menu-item-1588\" class=\"menu-item menu-item-type-post_type menu-item-object-page\"><a href=\"https://www.letus.co.jp/letus_work/service09/\">ECサイト構築サービス</a></li>\n\t\t<li id=\"menu-item-1391\" class=\"menu-item menu-item-type-post_type menu-item-object-page\"><a href=\"https://www.letus.co.jp/letus_work/service03/\">ECサイト運営支援サービス</a></li>\n\t\t<li id=\"menu-item-1579\" class=\"menu-item menu-item-type-post_type menu-item-object-page\"><a href=\"https://www.letus.co.jp/letus_work/service08/\">CRMシステム構築サービス</a></li>\n\t\t<li id=\"menu-item-1400\" class=\"menu-item menu-item-type-post_type menu-item-object-page\"><a href=\"https://www.letus.co.jp/letus_work/service04/\">CMS化サービス</a></li>\n\t\t<li id=\"menu-item-1418\" class=\"menu-item menu-item-type-post_type menu-item-object-page\"><a href=\"https://www.letus.co.jp/letus_work/service05/\">クラウド化サービス</a></li>\n\t\t<li id=\"menu-item-1542\" class=\"menu-item menu-item-type-post_type menu-item-object-page\"><a href=\"https://www.letus.co.jp/letus_work/service07/\">HOSTシステム開発サービス</a></li>\n\t\t<li id=\"menu-item-1423\" class=\"menu-item menu-item-type-post_type menu-item-object-page\"><a href=\"https://www.letus.co.jp/letus_work/service06/\">運用・保守サービス</a></li>\n\t</ul>\n</li>\n\t<li id=\"menu-item-352\" class=\"menu-item menu-item-type-post_type menu-item-object-page\"><a title=\"flow\" href=\"https://www.letus.co.jp/letus_work/service/\">サービスの流れ</a></li>\n\t<li id=\"menu-item-364\" class=\"menu-item menu-item-type-post_type menu-item-object-page\"><a title=\"faq\" href=\"https://www.letus.co.jp/letus_work/question/\">よくあるご質問</a></li>\n\t<li id=\"menu-item-1743\" class=\"menu-item menu-item-type-post_type menu-item-object-page\"><a href=\"https://www.letus.co.jp/letus_work/price/\">サービス料金</a></li>\n</ul>\n</li>\n<li id=\"menu-item-353\" class=\"menu-item menu-item-type-post_type menu-item-object-page\"><a title=\"contact\" href=\"https://www.letus.co.jp/contact/\"><strong>お問い合わせ</strong></a></li>\n<li id=\"menu-item-27\" class=\"menu-item menu-item-type-post_type menu-item-object-page\"><a title=\"access\" href=\"https://www.letus.co.jp/letus_map/\"><strong>アクセス</strong></a></li>\n<li id=\"menu-item-28\" class=\"menu-item menu-item-type-post_type menu-item-object-page\"><a title=\"recruit\" href=\"https://www.letus.co.jp/letus_recruit/\"><strong>採用情報</strong></a></li>\n<li id=\"menu-item-521\" class=\"menu-item menu-item-type-post_type menu-item-object-page\"><a href=\"https://www.letus.co.jp/event-album/\"><strong>Event Album</strong></a></li>\n<li id=\"menu-item-3101\" class=\"menu-item menu-item-type-post_type menu-item-object-page\"><a href=\"https://www.letus.co.jp/%e3%81%b6%e3%82%8d%e3%81%90/\"><strong>コラム</strong></a></li>\n</ul></div>\n</div><!-- [ /#gMenuInner ] -->\n</div>\n<!-- [ /#gMenu ] -->\n\n\n<div id=\"topMainBnr\">\n<div id=\"topMainBnrFrame\" class=\"flexslider\">\n\t<ul class=\"slides\">\n\t<li><a href=\"https://www.letus.co.jp/letus_work/\" class=\"slideFrame\"><img src=\"https://www.letus.co.jp/wp-content/uploads/2016/11/letUsBegin-min.jpg\" alt=\"北海道\" /></a></li>\n<li><a href=\"https://www.letus.co.jp/letus_work/\" class=\"slideFrame\"><img src=\"https://www.letus.co.jp/wp-content/uploads/2016/11/koinobori-min.jpg\" alt=\"鯉のぼり\" /></a></li>\n<li><a href=\"https://www.letus.co.jp/letus_work/\" class=\"slideFrame\"><img src=\"https://www.letus.co.jp/wp-content/uploads/2016/11/momiji-min.jpg\" alt=\"もみじ\" /></a></li>\n<li><a href=\"https://www.letus.co.jp/letus_work/\" class=\"slideFrame\"><img src=\"https://www.letus.co.jp/wp-content/uploads/2016/11/ume-min.jpg\" alt=\"うめ\" /></a></li>\n\t</ul>\n</div>\n</div>\n<div id=\"main\"><!-- [ #container ] -->\n<div id=\"container\" class=\"innerBox\">\n\t<!-- [ #content ] -->\n\t<div id=\"content\">\n        <h1 class=\"leadTxt\" style=\"font-size:21px;\">セミオーダーシステム開発なら、レタスのスマートコンパス</h1>\n\t\t<!-- [ #topPr ] -->\r\n\t<div id=\"topPr\" class=\"topPr\">\r\n\t<div id=\"topPrLeft\" class=\"topPrOuter\">\r\n\t<div class=\"topPrInner\">\r\n\t<h3 class=\"topPrTit\"><a href=\"https://www.letus.co.jp/?page_id=21\">サービス案内</a></h3>\r\n\t\t\t<div class=\"prImage\">\r\n\t\t<a href=\"https://www.letus.co.jp/?page_id=21\">\r\n\t\t<img src=\"https://www.letus.co.jp/wp-content/uploads/2016/10/meeting1.jpg\" alt=\"サービス案内のイメージ\" class=\"imageWide\" />\r\n\t\t<img src=\"https://www.letus.co.jp/wp-content/uploads/2016/10/meeting1_mini.jpg\" alt=\"\" class=\"imageSmall\" />\r\n\t\t</a>\r\n\t\t</div>\r\n\t\t<div class=\"topPrTxtBox\">\r\n\t\t<p class=\"topPrDescription\"><a href=\"https://www.letus.co.jp/?page_id=21\">お客様のご要望に応じて、システムの提案から開発まで、一貫したITサービスをご提供いたします。</a></p>\r\n\t\t<div class=\"moreLink\"><a href=\"https://www.letus.co.jp/?page_id=21\">詳しくはこちら</a></div>\r\n\t</div>\r\n\t</div>\r\n\t</div><!-- /#topPrLeft -->\r\n\r\n\t<div id=\"topPrCenter\" class=\"topPrOuter\">\r\n\t<div class=\"topPrInner\">\r\n\t<h3 class=\"topPrTit\"><a href=\"https://www.letus.co.jp/?page_id=14\">会社概要</a></h3>\r\n\t\t\t<div class=\"prImage\">\r\n\t\t<a href=\"https://www.letus.co.jp/?page_id=14\">\r\n\t\t<img src=\"https://www.letus.co.jp/wp-content/uploads/2016/10/graph1.jpg\" alt=\"会社概要のイメージ\" class=\"imageWide\" />\r\n\t\t<img src=\"https://www.letus.co.jp/wp-content/uploads/2016/10/graph_mini.jpg\" alt=\"\" class=\"imageSmall\" />\r\n\t\t</a>\r\n\t\t</div>\r\n\t\t<div class=\"topPrTxtBox\">\r\n\t\t<p class=\"topPrDescription\"><a href=\"https://www.letus.co.jp/?page_id=14\">1998年設立。大阪を拠点とするのシステム開発会社です。大型汎用機からクラウドのWebシステムまで幅広く対応します。</a></p>\r\n\t\t<div class=\"moreLink\"><a href=\"https://www.letus.co.jp/?page_id=14\">詳しくはこちら</a></div>\r\n\t</div>\r\n\t</div>\r\n\t</div><!-- /#topPrCenter -->\r\n\r\n\t<div id=\"topPrRight\" class=\"topPrOuter\">\r\n\t<div class=\"topPrInner\">\r\n\t<h3 class=\"topPrTit\"><a href=\"https://www.letus.co.jp/?page_id=12\">お問い合わせ</a></h3>\r\n\t\t\t<div class=\"prImage\">\r\n\t\t<a href=\"https://www.letus.co.jp/?page_id=12\">\r\n\t\t<img src=\"https://www.letus.co.jp/wp-content/uploads/2016/10/ask.jpg\" alt=\"お問い合わせのイメージ\" class=\"imageWide\" />\r\n\t\t<img src=\"https://www.letus.co.jp/wp-content/uploads/2016/10/ask_mini.jpg\" alt=\"\" class=\"imageSmall\" />\r\n\t\t</a>\r\n\t\t</div>\r\n\t\t<div class=\"topPrTxtBox\">\r\n\t\t<p class=\"topPrDescription\"><a href=\"https://www.letus.co.jp/?page_id=12\">DX推進、AWSクラウドを利用したWebシステム開発、ECサイト構築、現行システムでのお悩みなどを承ります。</a></p>\r\n\t\t<div class=\"moreLink\"><a href=\"https://www.letus.co.jp/?page_id=12\">詳しくはこちら</a></div>\r\n\t</div>\r\n\t</div>\r\n\t</div><!-- /#topPrRight -->\r\n\t</div>\r\n\t<!-- [ #topPr ] -->\r\n\r\n\n\t\t<div id=\"topFreeArea\">\n\t\t<h2>そのお悩みを解決して業務効率化しませんか？</h2>\n\t\t<h4>スマートコンパスなら、お客様の要望にセミオーダーで対応！</h4>\n<div class=\"moreLink\">\n<p>例えば、以下のようなニーズに対応します。</p>\n<ul>\n<li>EC多店舗販売<br>自社サイト、楽天、Amazonなど複数プラットフォームの受注管理を一元化</li>\n<li>単位売り<br>数量ではなく、重さ、長さ、面積などの単位で販売を実現</li>\n<li>カスタム注文<br>お客様が自分好みに仕様を変更して注文できる商品の販売をサポート</li>\n<li>ワークフロー<br>業務の流れ（一連の作業や手続き）をシステム化して効率化</li>\n<li>手書き申込書<br>手書き申込書の受付、電子データ化、受付をスムーズに</li>\n</ul>\n<p>これらのわがままにも柔軟に対応するセミオーダーシステムをスマートコンパス（Smart Compass）が提供します。お気軽にお問い合わせください！</p>\n</div>\n<p><a href=\"https://www.letus.co.jp/contact/\"><img class=\"size-full wp-image-1492 alignright\" src=\"https://www.letus.co.jp/wp-content/uploads/2015/04/お問合せ.jpg\" alt=\"%e3%81%8a%e5%95%8f%e5%90%88%e3%81%9b\" width=\"183\" height=\"30\"></a></p>\n<div>\n<h2 id=\"service_biz_sys\">Webシステム開発は大阪（北浜）の株式会社レタスまで</h2>\n<p>受注管理システムの導入なら大阪の株式会社レタスにお任せください。&lt;br&gt;<br>弊社ではWebシステム構築、通販・ECサイト構築を手がけております。他にも、訪問介護システムや介護記録のクラウド化なども行っております。<br>導入に関する質問や費用のことなどお気軽にお問い合わせください。</p>\n</div>\n<h4>システム開発の会社なのに…　社名は「レタス」！？</h4>\n<div class=\"moreLink\">社名のレタスは、“Let us begin.” の <strong>Let us</strong> 「みんなで◯◯しよう！」が語源です。みんなで考え、学び、成長する『ネットワーク型組織の愉快な会社をつくろう！』との設立時の思いを込めた名前です。また、野菜のレタスが持つ、みずみずしく、新鮮で、明るく健康的なイメージは、当社が目指す企業イメージです。</div>\n<h2 id=\"service_biz_sys\"><strong><span style=\"font-size: large;\">お困りではありませんか？</span></strong></h2>\n<div>\n<p><img class=\"wp-image-1471 alignright\" src=\"https://www.letus.co.jp/wp-content/uploads/2015/04/K02.jpg\" alt=\"お困り事は？\" width=\"200\" height=\"134\"></p>\n<ul>\n<li>独自ノウハウをWebサービス化したい。</li>\n<li>DX推進にあたりIT技術の支援がほしい。</li>\n<li>業務に合った市販ソフトが見つからない。</li>\n<li>ネットショップ運営を改善したい。</li>\n<li>ExcelやAccessでの管理から卒業したい。</li>\n<li>老朽化したハードがいつ故障するか心配。<br><a href=\"https://www.letus.co.jp/contact/\"><img class=\"size-full wp-image-1492 alignright\" src=\"https://www.letus.co.jp/wp-content/uploads/2015/04/お問合せ.jpg\" alt=\"%e3%81%8a%e5%95%8f%e5%90%88%e3%81%9b\" width=\"183\" height=\"30\"></a></li>\n</ul>\n</div>\n<p>ちょっとしたご要望にもお応えします。</p>\n<h2 id=\"service_biz_sys\"><strong><span style=\"font-size: large;\">システム開発でお困りごとを解決します</span></strong></h2>\n<h4>身近になったコンピュータ。誰もが利用できるようになりました。</h4>\n<div class=\"moreLink\"><img class=\"alignleft wp-image-1467\" src=\"https://www.letus.co.jp/wp-content/uploads/2015/04/child.jpg\" alt=\"お困りごとを解決\" width=\"200\" height=\"134\">クラウドの普及により、高度な分析や業務システムを設備投資することなく利用できるようになりました。また、コンピュータも「所有」から「利用」へのシフトが加速し、クラウドと独自のシステムを組み合わせた戦略的システムをすばやく手にすることが可能になりました。<a style=\"margin-top: 0; vertical-align: top;\" href=\"https://www.letus.co.jp/letus_work/\">サービス案内</a></div>\n<h4>色んなことができるコンピュータ。いまだに絶えないトラブル。</h4>\n<p><img class=\"alignright wp-image-1465\" src=\"https://www.letus.co.jp/wp-content/uploads/2015/04/str.jpg\" alt=\"なぜトラブルは発生するの？\" width=\"200\" height=\"143\"></p>\n<div class=\"moreLink\">建築物などと異なり、プログラムは見たり触ったりすることができません。画面に表示されるのはプログラムではなく、プログラムの実行結果です。システム開発は柔軟でつかみどころのない多数のプログラムを組み合わせ、一つの仕組みにする仕事です。SEの技術力はもちろん、お客様の理解と協力なしにプロジェクトの成功はありません。<a style=\"margin-top: 0; vertical-align: top;\" href=\"https://www.letus.co.jp/letus_work/\">サービス案内</a></div>\n<h4>コンピュータ活用。気軽にご相談ください。</h4>\n<p><img class=\"alignleft wp-image-1466\" src=\"https://www.letus.co.jp/wp-content/uploads/2015/04/biz.jpg\" alt=\"コンピュータのご相談\" width=\"200\" height=\"134\"></p>\n<div class=\"moreLink\">DXはビジネスプロセスの変革を伴います。戦略的であるほど新システムに対する現場担当者の理解と協力を必要とします。限りあるコストと時間をいかに有効活用するかがプロジェクト成功の鍵になります。私たちは、これまでの経験をフル活用してDXを推進します。<a style=\"margin-top: 0; vertical-align: top;\" href=\"https://www.letus.co.jp/letus_work/\">サービス案内</a></div>\n<p><a href=\"https://www.letus.co.jp/contact/\"><img class=\"size-full wp-image-1492 alignright\" src=\"https://www.letus.co.jp/wp-content/uploads/2015/04/お問合せ.jpg\" alt=\"%e3%81%8a%e5%95%8f%e5%90%88%e3%81%9b\" width=\"183\" height=\"30\"></a></p>\n<h4>日常になったネット通販。ネットショップの運営を支援します。</h4>\n<p><img class=\"alignright wp-image-1462\" src=\"https://www.letus.co.jp/wp-content/uploads/2015/04/sys.jpg\" alt=\"ネット通販もサポート\" width=\"200\" height=\"134\"></p>\n<div class=\"moreLink\">スマホでのネットショッピングは日常になりました。私たちは、ECサイトの構築や多店舗運営の支援システムも手掛けてきました。基幹システム連携、ネット店舗とリアル店舗の統合管理など、お困りごと解消のお手伝いをいたします。<a style=\"margin-top: 0; vertical-align: top;\" href=\"https://www.letus.co.jp/letus_work/\">サービス案内</a></div>\n<p><img class=\"size-full wp-image-1492 alignright\" src=\"https://www.letus.co.jp/wp-content/uploads/2015/04/お問合せ.jpg\" alt=\"%e3%81%8a%e5%95%8f%e5%90%88%e3%81%9b\" width=\"183\" height=\"30\"></p>\n<h4>大阪を拠点にIT活用による企業価値向上に貢献します。</h4>\n<p>私たちは、<strong>大阪</strong>はもとより<strong>京都</strong>や<strong>神戸</strong>といった関西地域全般の企業価値向上に貢献いたします。</p>\n<div class=\"moreLink\"><img class=\"alignnone size-full wp-image-1144\" src=\"https://www.letus.co.jp/wp-content/uploads/2015/04/serviceFlow2.png\" alt=\"サービス提供までの流れ\" width=\"978\" height=\"441\"><br><a href=\"https://www.letus.co.jp/service/\">サービスの流れの詳細</a>　<a href=\"https://www.letus.co.jp/letus_work/price/\">システム開発/構築サービス料金</a></div>\n<p><a href=\"https://www.letus.co.jp/contact/\"><img class=\"size-full wp-image-1068 aligncenter\" src=\"https://www.letus.co.jp/wp-content/uploads/2016/02/お問合せ.png\" alt=\"お問合せ\" width=\"401\" height=\"90\"></a></p>\n\n\n<div class=\"seotextarea\">\n<h2 class=\"seotext\">受注管理システムの開発・導入に関するご相談なら大阪の株式会社レタスへ</h2>\n  <p>\n    株式会社レタスは大阪を拠点に、受注管理システムなどの業務システム・Webシステムの開発を行っています。お客様のニーズに合わせたおすすめのカスタマイズに対応可能で、Excel連携などもスムーズに実現いたします。\n  </p>\n  <p>\n    IT活用により、ビジネスの効率化と成長をサポートさせていただきます。EC・通販サイトの構築や運営支援、CRMシステム構築、CMS化、クラウド化サービス、運用・保守サービスなどもお任せください。比較ポイントや費用などに関するご質問・ご相談もお待ちしています。\n  </p>\n\n<div class=\"c-btn\">\n  <a href=\"/%e3%81%b6%e3%82%8d%e3%81%90/\" class=\"c-btn-anchor\">コラム一覧</a>\n</div>\n\n<div class=\"c-nap\">\n<h2>大阪周辺で受注管理システムや訪問介護システムを導入したいとお考えの企業様は株式会社レタスへ</h2>\n<table class=\"c-table\">\n<tr>\n<th>会社名</th>\n<td>株式会社レタス　（Let Us Co. Ltd.）</td>\n</tr>\n<tr>\n<th>代表取締役</th>\n<td>松尾　哲郎</td>\n</tr>\n<tr>\n<th>住所</th>\n<td>〒541-0041 大阪府大阪市中央区北浜２丁目５−２３ 小寺プラザ３階</td>\n</tr>\n<tr>\n<th>TEL</th>\n<td><a href=\"tel:0662213250\">06-6221-3250</a></td>\n</tr>\n<tr>\n<th>設　　立</th>\n<td>1998年（平成10年）7月</td>\n</tr>\n<tr>\n<th>事業内容</th>\n<td>\n<ul>\n<li>情報システムのコンサルティング</li>\n<li>情報システムの企画・分析</li>\n<li>汎用アプリケーションソフトウェアの開発</li>\n<li>Webアプリケーションソフトウェアの開発</li>\n<li>労働者派遣事業（許可番号　派27-302480）</li>\n</ul>\n</td>\n</tr>\n<tr>\n<th>URL</th>\n<td><a href=\"/\">https://www.letus.co.jp/</a></td>\n</tr>\n</table>\n</div>\n<style type=\"text/css\">\n.seotextarea{margin: 60px auto;}\n.seotext {}\n.u-pb1em {padding-bottom: 1em !important;}\n.c-table {border-collapse: collapse;border: 1px solid #ddd;text-align: left;width: 100%;}\n.c-table th {background: #f7f7f7;border: 1px solid #ddd;text-align: left;vertical-align: middle;width: 25%;padding:15px}\n.c-table td {border: 1px solid #ddd;vertical-align: middle;padding:15px}\n/*ボタン 共通*/\n.c-btn {text-align: center;margin: 40px 0;}\n.c-btn-anchor {display: block;text-align: center;vertical-align: middle;text-decoration: none;position: relative;width: 80%;margin: auto;padding: 15px 20px;font-weight: bold;border-radius: 10px;color: #ff981a;border: 3px solid #ff981a;box-shadow: 5px 5px #ff981a;transition: 0.3s ease-in-out;}\n.c-btn-anchor:hover {box-shadow: none;transform: translate(5px, 5px);color: #ff981a;}\n@media (max-width: 768px) {\n.c-table th {padding:15px 5px}\n.c-table td {padding:15px 5px}\n}\n@media (min-width: 768px) {\n/*ボタン PCのみ*/\n.c-btn-anchor {width: 30%;}\n}\n</style>\n</div>\n<script type=\"application/ld+json\">\n{\n  \"@context\": \"http://schema.org\",\n  \"@type\": \"LocalBusiness\",\n  \"name\": \"株式会社レタス\",\n  \"logo\": \"https://www.letus.co.jp/wp-content/uploads/2016/10/LetusLogo03.png\",\n  \"telephone\": \"+81 6-6221-3250\",\n  \"address\": {\n    \"@type\": \"PostalAddress\",\n    \"streetAddress\": \"中央区北浜２丁目５−２３ 小寺プラザ３階\",\n    \"addressLocality\": \"大阪市\",\n    \"addressRegion\": \"大阪府\",\n    \