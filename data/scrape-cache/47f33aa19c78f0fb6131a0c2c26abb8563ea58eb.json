        </div>\n            </li>\n          </ul>\n        </nav>\n        <div class=\"h_entry\"><a href=\"https://www.nichidai.jp/recruit/fresh/entry/\">ENTRY</a>\n          <!--.h_entry-->\n        </div>\n        <div class=\"h_corp\"><a href=\"/\" target=\"_blank\">コーポレートサイトへ</a>\n          <!--.h_corp-->\n        </div>\n        <div class=\"h_corp -instagram\"><a href=\"https://www.instagram.com/nichidai.official/\" target=\"_blank\">公式採用Instagramへ</a>\n          <!--.h_corp-->\n        <!-- / .inner -->\n      </div>\n      <span class=\"h_menu\"></span>\n      <!-- / .l-header -->\n    </header>\n\n    <!--    コンテンツ\t-->\n    <div class=\"l-contents\">\n      <div class=\"l-main\" role=\"main\">\n        <div class=\"crumbs\">\n          <ul>\n            <li><a href=\"../../\">トップページ</a>&nbsp;&gt;&nbsp;</li>\n            <li>メッセージ&nbsp;&gt;&nbsp;</li>\n            <li>採用コンセプト</li>\n          </ul>\n          <!-- / .crumbs -->\n        </div>\n        <article class=\"m-message\">\n          <section class=\"message01_content\">\n            <h1 class=\"common_ttl01\"><span class=\"en\">CONCEPT</span><span class=\"ja\">採用コンセプト</span></h1>\n            <p class=\"message01_copy\"><img src=\"img/message01_copy.png\"\n                srcset=\"img/message01_copy.png 1x,img/message01_copy@2x.png 2x\" alt=\"究極のつくりたがりたち。\"></p>\n            <p class=\"message01_txt\">ものづくりは簡単にはうまくいかない。<br>\n              <br>\n              しかし、あらゆる難題を乗り越えたその先にあるのは、<br>\n              大きな達成感、そして社会の課題へも解決に近づいていけるチカラ。<br>\n              <br>\n              ものづくりの魅力に引き寄せられたものたちが集まる場所、それがニチダイ。<br>\n              <br>\n              さまざまな専門知識を持ったメンバーが、<br>\n              自らの意思で創造性を発揮し、お互いを助け合い、困難に立ち向かう。<br>\n              活気と情熱に溢れるその姿はまさに「究極のつくりたがりたち」<br>\n              <br>\n              創意工夫すること、自らの手を動かしモノを生み出すこと、<br>\n              世界で活躍を夢見ること・・・志を持つ先輩や仲間とともに<br>\n              ものづくりの世界で成長したい・・。<br>\n              <br>\n              そんな想いを持つ方は、ぜひニチダイに挑戦してください。\n            </p>\n\n            <!-- /.message01_content -->\n          </section>\n          <div class=\"common_btn03 -left\"><a href=\"../message02/\"><span class=\"en\">TOP MESSAGE</span><span\n                class=\"ja\">社長メッセージ</span></a></div>\n\n          <!-- / .m-message -->\n        </article>\n        <div class=\"entry_block\">\n          <div class=\"entry_content\"> <a href=\"https://www.nichidai.jp/recruit/fresh/entry/\">\n              <p class=\"common_ttl01\"><span class=\"en\">RECRUIT</span><span class=\"ja\">株式会社ニチダイ <br class=\"visible-xs\">\n                  新卒採用エントリーはこちら</span></p>\n            </a>\n            <!-- /.entry_content --></div>\n          <!-- /.entry_block -->\n        </div>\n\n        <!-- /.l-main -->\n      </div>\n\n      <!-- / .l-contents -->\n    </div>\n\n    <!--     フッター   -->\n\n    <footer class=\"l-footer\">\n      <div class=\"inner\">\n        <div class=\"f_logo\"> <img src=\"../../common/img/footer/ft_logo.png\"\n            srcset=\"../../common/img/footer/ft_logo.png 1x,../../common/img/footer/ft_logo@2x.png 2x\" alt=\"株式会社ニチダイ\">\n          <!-- /.f_logo --></div>\n        <!--<div class=\"f_right\">\n        <p class=\"copyright\">&copy; 2018 NICHIDAI Co.,Ltd</p>\n      </div>-->\n        <!-- / .inner -->\n      </div>\n      <!-- / #footer -->\n    </footer>\n\n    <!-- / #page -->\n  </div>\n  <script src=\"https://ajax.googleapis.com/ajax/libs/jquery/2.1.0/jquery.min.js\"></script>\n  <script src=\"../../common/js/min/scripts.js\" charset=\"utf-8\"></script>\n  <script type=\"text/javascript\" src=\"/lib/analytics.js\"></script>\n</body>\n\n</html>","finalUrl":"https://www.nichidai.jp/recruit/fresh/message/message01/","rendered":false,"_cachedAt":"2026-06-22T17:26:50.459Z"}