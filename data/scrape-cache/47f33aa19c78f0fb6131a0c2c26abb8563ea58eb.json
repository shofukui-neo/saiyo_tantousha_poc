{"url":"https://www.nichidai.jp/recruit/fresh/message/message01/","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n\n<head>\n  <meta charset=\"UTF-8\">\n  <title>採用コンセプト｜メッセージ｜ニチダイ新卒採用サイト</title>\n  <meta name=\"description\" content=\"株式会社ニチダイの新卒採用サイトです。創造と情熱に溢れたものづくりをする仲間を募集しています。\">\n  <meta name=\"keywords\" content=\"株式会社ニチダイ,新卒採用,求人\">\n  <meta name=\"robots\" content=\"index,follow\">\n  <meta name=\"SKYPE_TOOLBAR\" content=\"SKYPE_TOOLBAR_PARSER_COMPATIBLE\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n  <meta name=\"format-detection\" content=\"telephone=no\">\n  <link rel=\"shortcut icon\" href=\"../../common/img/ico/favicon.ico\">\n  <link rel=\"stylesheet\" href=\"../../common/css/theme.css\">\n  <link rel=\"stylesheet\" href=\"https://maxcdn.bootstrapcdn.com/font-awesome/4.6.1/css/font-awesome.min.css?ver=4.8.1\">\n</head>\n\n<body class=\"page-message page-message-child page-message01\">\n  <div id=\"page\">\n\n    <!--   ヘッダー   -->\n\n    <header class=\"l-header\">\n      <div class=\"inner\">\n        <div class=\"h_logo\"><a href=\"../../\"><img src=\"../../common/img/header/logo.png\"\n              srcset=\"../../common/img/header/logo.png 1x,../../common/img/header/logo@2x.png 2x\" alt=\"株式会社 ニチダイ\"></a>\n        </div>\n        <nav class=\"gnavi\">\n          <ul>\n            <li class=\"visible-xs visible-sm\"><a href=\"../../\"><span class=\"ja\">トップページ</span><span\n                  class=\"en\">TOP</span></a></li>\n            <li class=\"parent\"> <span class=\"a\"><span class=\"ja\">メッセージ</span><span class=\"en\">MESSAGE</span></span>\n              <div class=\"child\">\n                <ul>\n                  <li><a href=\"../message01/\">採用コンセプト<i class=\"fa fa-angle-right\"></i></a></li>\n                  <li><a href=\"../message02/\">トップメッセージ<i class=\"fa fa-angle-right\"></i></a></li>\n                </ul>\n                <!-- /.child -->\n              </div>\n            </li>\n            <li cla