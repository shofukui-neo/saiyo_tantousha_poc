{"url":"https://www.aeonretail.jp/saiyo/challenged/","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n\n<head>\n<!-- Google Tag Manager -->\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n})(window,document,'script','dataLayer','GTM-M38PPC');</script>\n<!-- End Google Tag Manager -->\n  <meta charset=\"utf-8\">\n  <meta name=\"format-detection\" content=\"telephone=no\">\n  <meta name=\"viewport\" content=\"width=device-width\">\n  <link rel=\"shortcut icon\" href=\"/saiyo/challenged/img/common/apple-touch-icon.ico\">\n  <link rel=\"apple-touch-icon\" href=\"/saiyo/challenged/img/common/aeon_appletouchicon.png.webp\">\n\n  <title>障がい者採用サイト｜イオンリテール株式会社</title>\n  <meta name=\"keywords\" content=\"\">\n  <meta name=\"description\" content=\"イオンリテール株式会社の障がい者採用に関する情報をご覧いただけます。\">\n\n  <meta property=\"og:title\" content=\"障がい者採用サイト｜イオンリテール株式会社\">\n  <meta property=\"og:description\" content=\"イオンリテール株式会社の障がい者採用に関する情報をご覧いただけます。\">\n  <meta property=\"og:url\" content=\"https://www.aeonretail.jp/saiyo/challenged/\">\n  <meta property=\"og:type\" content=\"website\">\n  <meta property=\"og:locale\" content=\"ja_JP\">\n  <meta property=\"og:image\" content=\"/saiyo/challenged/img/common/og-image.jpg.webp\">\n  <meta property=\"og:site_name\" content=\"障がい者採用サイト｜イオンリテール株式会社\">\n\n  <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n  <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n  <link href=\"https://fonts.googleapis.com/css2?family=Quicksand:wght@500;700&family=Zen+Maru+Gothic:wght@500;700&display=swap\" rel=\"stylesheet\">\n\n  <link rel=\"stylesheet\" type=\"text/css\" href=\"/saiyo/challenged/css/lib/splide-core.min.css\">\n  <link rel=\"stylesheet\" type=\"text/css\" href=\"/saiyo/challenged/css/style.css\">\n\n\n  <script src=\"/saiyo/challenged/js/lib/b_browser_switcher.js\"></script>\n  <script src=\"/saiyo/challenged/js/lib/jquery-3.6.3.min.js\"></script>\n</head>\n\n\n<body>\n  <!-- Google Tag Manager (noscript) -->\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-M38PPC\"\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n<!-- End Google Tag Manager (noscript) -->\n\n  <svg width=\"0\" height=\"0\" aria-hidden=\"true\" focusable=\"false\" style=\"position:absolute\">\n    <defs>\n      <clipPath id=\"clip01\">\n        <path d=\"M540 0C650.457 0 740 89.5431 740 200C740 310.457 650.457 400 540 400C468.225 400 405.284 362.19 370 305.403C334.716 362.19 271.775 400 200 400C89.5431 400 0 310.457 0 200C0 89.5431 89.5431 0 200 0C271.774 0 334.716 37.8091 370 94.5957C405.284 37.8091 468.226 0 540 0Z\" />\n      </clipPath>\n      <clipPath id=\"clip02\">\n        <path d=\"M540 0C650.457 0 740 89.5431 740 200C740 310.457 650.457 400 540 400C468.225 400 405.284 362.19 370 305.403C334.716 362.19 271.775 400 200 400C89.5431 400 0 310.457 0 200C0 89.5431 89.5431 0 200 0C271.774 0 334.716 37.8091 370 94.5957C405.284 37.8091 468.226 0 540 0Z\" />\n      </clipPath>\n      <clipPath id=\"clip03\">\n        <path d=\"M540 0C650.457 0 740 89.5431 740 200C740 310.457 650.457 400 540 400C468.225 400 405.284 362.19 370 305.403C334.716 362.19 271.775 400 200 400C89.5431 400 0 310.457 0 200C0 89.5431 89.5431 0 200 0C271.774 0 334.716 37.8091 370 94.5957C405.284 37.8091 468.226 0 540 0Z\" />\n      </clipPath>\n    </defs>\n  </svg>\n\n\n  <div class=\"\" id=\"loading\">\n    <div class=\"fade-content\">\n      <div class=\"logo-area\">\n        <img src=\"/saiyo/challenged/img/common/aeon_logo.svg\" alt=\"AEON\">\n        <span class=\"txt\">障がい者採用サイト</span>\n      </div>\n    </div>\n  </div>\n  <div id=\"wrapper\">\n\n<header></header>\n<script>\n  $('header').load('/saiyo/challenged/inc/c-header.html');\n</script>\n\n    <main class=\"home\" id=\"main\" tabindex=\"-1\">\n      <section class=\"mv-section\">\n        <div class=\"inner-block\">\n          <div class=\"circle circle01 blue\"></div>\n          <div class=\"circle circle02 red\"></div>\n          <div class=\"circle circle03 green\"></div>\n          <div class=\"circle circle04 orange\"></div>\n          <div class=\"circle circle05 red\"></div>\n          <div class=\"circle circle06 blue\"></div>\n          <div class=\"circle circle07 light-blue\"></div>\n          <div class=\"circle circle08 light-blue\"></div>\n          <div class=\"circle circle09 orange\"></div>\n          <div class=\"circle circle10 green\"></div>\n          <div class=\"circle circle11 green\"></div>\n          <div class=\"circle circle12 light-blue\"></div>\n          <div class=\"circle circle13 light-blue\"></div>\n          <div class=\"circle circle14 blue\"></div>\n          <div class=\"circle circle15 yellow\"></div>\n          <div class=\"circle circle16 yellow\"></div>\n          <div class=\"circle circle17 red\"></div>\n          <div class=\"circle circle18 green\"></div>\n          <section class=\"splide mv-splide\" aria-label=\"MVスライド\">\n            <div class=\"splide__track\">\n              <div class=\"splide__list\">\n                <div class=\"splide__slide\">\n                  <div class=\"mv-img mv-img01\"><img src=\"/saiyo/challenged/img/home/mv-img04.jpg.webp\" alt=\"\"></div>\n                  <div class=\"mv-img mv-img02\"><img src=\"/saiyo/challenged/img/home/mv-img13.jpg.webp\" alt=\"\"></div>\n                  <div class=\"mv-main-img\">\n                    <svg width=\"740\" height=\"400\" viewBox=\"0 0 740 400\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n                      <image xlink:href=\"/saiyo/challenged/img/home/mv-img01.jpg.webp\" width=\"100%\" height=\"100%\" preserveAspectRatio=\"xMidYMid slice\" clip-path=\"url(#clip01)\" />\n                    </svg>\n\n                  </div>\n                  <div class=\"mv-img mv-img03\"><img src=\"/saiyo/challenged/img/home/mv-img07.jpg.webp\" alt=\"\"></div>\n                  <div class=\"mv-img mv-img04\"><img src=\"/saiyo/challenged/img/home/mv-img10.jpg.webp\" alt=\"\"></div>\n                  <div class=\"mv-img mv-img05\"><img src=\"/saiyo/challenged/img/home/mv-img16.jpg.webp\" alt=\"\"></div>\n                </div>\n                <div class=\"splide__slide\">\n                  <div class=\"mv-img mv-img01\"><img src=\"/saiyo/challenged/img/home/mv-img05.jpg.webp\" alt=\"\"></div>\n                  <div class=\"mv-img mv-img02\"><img src=\"/saiyo/challenged/img/home/mv-img14.jpg.webp\" alt=\"\"></div>\n                  <div class=\"mv-main-img\">\n                    <svg width=\"740\" height=\"400\" viewBox=\"0 0 740 400\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n                      <image xlink:href=\"/saiyo/challenged/img/home/mv-img02.jpg.webp\" width=\"100%\" height=\"100%\" preserveAspectRatio=\"xMidYMid slice\" clip-path=\"url(#clip02)\" />\n                    </svg>\n\n                  </div>\n                  <div class=\"mv-img mv-img03\"><img src=\"/saiyo/challenged/img/home/mv-img08.jpg.webp\" alt=\"\"></div>\n                  <div class=\"mv-img mv-img04\"><img src=\"/saiyo/challenged/img/home/mv-img11.jpg.webp\" alt=\"\"></div>\n                  <div class=\"mv-img mv-img05\"><img src=\"/saiyo/challenged/img/home/mv-img17.jpg.webp\" alt=\"\"></div>\n                </div>\n                <div class=\"splide__slide\">\n                  <div class=\"mv-img mv-img01\"><img src=\"/saiyo/challenged/img/home/mv-img06.jpg.webp\" alt=\"\"></div>\n                  <div class=\"mv-img mv-img02\"><img src=\"/saiyo/challenged/img/home/mv-img15.jpg.webp\" alt=\"\"></div>\n                  <div class=\"mv-main-img\">\n                    <svg width=\"740\" height=\"400\" viewBox=\"0 0 740 400\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n                      <image xlink:href=\"/saiyo/challenged/img/home/mv-img03.jpg.webp\" width=\"100%\" height=\"100%\" preserveAspectRatio=\"xMidYMid slice\" clip-path=\"url(#clip03)\" />\n                    </svg>\n\n                  </div>\n                  <div class=\"mv-img mv-img03\"><img src=\"/saiyo/challenged/img/home/mv-img09.jpg.webp\" alt=\"\"></div>\n                  <div class=\"mv-img mv-img04\"><img src=\"/saiyo/challenged/img/home/mv-img12.jpg.webp\" alt=\"\"></div>\n                  <div class=\"mv-img mv-img05\"><img src=\"/saiyo/challenged/img/home/mv-img18.jpg.webp\" alt=\"\"></div>\n                </div>\n              </div>\n            </div>\n            <div class=\"splide-navi\">\n              <ul class=\"splide__pagination\"></ul>\n              <button class=\"splide-toggle\"><span class=\"txt\">停止</span></button>\n            </div>\n          </section>\n          <h2 class=\"mv-ttl\"><img src=\"/saiyo/challenged/img/home/mv-ttl.svg\" alt=\"ぴったりを見つけよう\"></h2>\n          <div class=\"desc-area\">\n            <p class=\"desc\">\n              働く場所、仕事内容や働きやすさ、<br class=\"sp\">一緒に働く仲間。\n            </p>\n            <p class=\"desc\">\n              自分らしく働くために<br class=\"sp\">どれもゆずれない大切な要素です。\n            </p>\n            <p class=\"desc\">\n              そのひとつひとつが<br class=\"sp\">あなたにちょうどよく<span class=\"ib\">フィットする。</span>\n            </p>\n            <p class=\"strong\">イオンリテールなら<br>そんな「ぴったり」が<br class=\"sp\">見つかります。</p>\n          </div>\n        </div>\n      </section>\n\n      <section class=\"message-section\">\n        <div class=\"circle circle01 red\"></div>\n        <div class=\"circle circle02 blue\"></div>\n        <div class=\"circle circle03 yellow\"></div>\n        <div class=\"circle circle04 orange\"></div>\n        <div class=\"circle circle05 blue\"></div>\n        <div class=\"inner-block\">\n          <h2 class=\"c-ttl01 yellow\">\n            <span class=\"ja\">私たちの想い</span>\n            <span class=\"en\">Message</span>\n          </h2>\n          <div class=\"flex-wrap\">\n            <div class=\"img-area\">\n              <div class=\"img-wrap\"><img src=\"/saiyo/challenged/img/home/message-img01.jpg.webp\" alt=\"\"></div>\n            </div>\n            <div class=\"txt-area\">\n              <p class=\"txt\">一人ひとりが今以上に輝ける場をさらに広げていきたい。それが私たちの心からの想いです。障がいの有無にかかわらず、笑顔で安心して働ける組織づくりをこれからも進めていきます。</p>\n              <div class=\"btn-wrap\"><a href=\"/saiyo/challenged/message/\" class=\"c-btn01\">私たちの想いを見る<span class=\"icon\"></span></a></div>\n            </div>\n          </div>\n        </div>\n      </section>\n\n      <section class=\"job-section c-bg-pink anim\">\n        <div class=\"inner-block\">\n          <h2 class=\"c-ttl01 l-blue\">\n            <span class=\"ja\">仕事図鑑</span>\n            <span class=\"en\">JobMap</span>\n          </h2>\n          <div class=\"c-tab-wrap\" role=\"tablist\">\n            <button class=\"tab is-show\" id=\"tab01-btn\" value=\"tab01\" role=\"tab\" aria-selected=\"true\" aria-controls=\"tab01\" tabindex=\"0\">店舗での業務</button>\n            <button class=\"tab\" id=\"tab02-btn\" value=\"tab02\" role=\"tab\" aria-controls=\"tab02\" tabindex=\"0\">本社での業務</button>\n          </div>\n          <div class=\"result-area tab01-result pc is-show\" role=\"tabpanel\" id=\"tab01\" aria-labelledby=\"tab01\">\n            <div class=\"c-job-box\">\n              <h3 class=\"box-ttl\">品質管理</h3>\n              <div class=\"white-area\">\n                <div class=\"balloon anim matchHeight\"><span class=\"inn-txt\">食品の安全を守るキーパー</span></div>\n                <img src=\"/saiyo/challenged/img/home/job-img01.png.webp\" alt=\"食品の品質を管理するスタッフのイラスト\">\n                <p class=\"txt matchHeight\">商品の品質を確認することが主な業務です。食品担当の場合は食品の鮮度が保たれているか、衣料品担当の場合は衣服がきれいに折りたたまれているかなどを確認。お客さまが安心して買い物いただける商品かどうかをチェックします。</p>\n              </div>\n            </div>\n            <div class=\"c-job-box\">\n              <h3 class=\"box-ttl\">衛生管理</h3>\n              <div class=\"white-area\">\n                <div class=\"balloon anim matchHeight\"><span class=\"inn-txt\">品質と衛生環境を維持する最後の砦</span></div>\n                <img src=\"/saiyo/challenged/img/home/job-img02.png.webp\" alt=\"品質チェックと衛生管理をするスタッフのイラスト\">\n                <p class=\"txt matchHeight\">消費期限がある商品に対して期限が近付いていないか、期限切れの商品がないかを確認します。さらに各作業場が清潔で整頓されているかなどの衛生管理も担当。各売場担当者が実施する品質管理のルールが守られているか、ダブルチェックする役割を担います。</p>\n              </div>\n            </div>\n            <div class=\"c-job-box\">\n              <h3 class=\"box-ttl\">後方事務</h3>\n              <div class=\"white-area matchHeight\">\n                <div class=\"balloon anim\"><span class=\"inn-txt\">スムーズな店舗運営を支える<span class=\"ib\">縁の下の力持ち</span></span></div>\n                <img src=\"/saiyo/challenged/img/home/job-img03.png.webp\" alt=\"パソコンでデスクワークするスタッフのイラスト\">\n                <p class=\"txt\">店舗の総務、人事教育、販売促進など、店舗運営をサポートするお仕事です。繁忙時は売場へのレジ応援や商品の品出し、抽選会など店頭イベントのサポートに入ることもあります。人事教育では採用選考会や新規入社者の受入準備などをお任せします。</p>\n              </div>\n            </div>\n            <div class=\"c-job-box\">\n              <h3 class=\"box-ttl\">接客</h3>\n              <div class=\"white-area matchHeight\">\n                <div class=\"balloon  anim\"><span class=\"inn-txt\">笑顔と気配りでご対応する<span class=\"ib\">売場の顔</span></span></div>\n                <img src=\"/saiyo/challenged/img/home/job-img04.png.webp\" alt=\"売場で接客をするスタッフのイラスト\">\n                <p class=\"txt\">食品売場や衣料品売場、家庭用品売場など各売場でのお客さま対応が主な業務です。お客さまからのご質問への応対や売場案内、商品をお勧めする場面もあります。売場や商品の特徴を知り、お客さま視点での接客、販売をします。</p>\n              </div>\n            </div>\n            <div class=\"c-job-box\">\n              <h3 class=\"box-ttl\">商品管理</h3>\n              <div class=\"white-area\">\n                <div class=\"balloon anim\"><span class=\"inn-txt\">商品の数や状態をチェックする<span class=\"ib\">コツコツ作業</span></span></div>\n                <img src=\"/saiyo/challenged/img/home/job-img05.png.webp\" alt=\"商品の数をチェックするスタッフのイラスト\">\n                <p class=\"txt matchHeight\">入荷商品の搬入口での受け取り、運搬、検品、在庫のチェック、パソコンでの伝票管理を担当します。食品、衣料品、家庭用品などすべての売場に共通するお仕事です。また、定期的に在庫の棚卸をしたり売場に直接商品を運ぶこともあります。</p>\n              </div>\n            </div>\n            <div class=\"c-job-box\">\n              <h3 class=\"box-ttl\">カート回収</h3>\n              <div class=\"white-area matchHeight\">\n                <div class=\"balloon anim\"><span class=\"inn-txt\">カートや買い物カゴの<span class=\"ib\">整理担当</span></span></div>\n                <img src=\"/saiyo/challenged/img/home/job-img06.png.webp\" alt=\"カートや買い物カゴを片付けるスタッフのイラスト\">\n                <p class=\"txt\">店舗の敷地内にあるカートや買い物カゴの回収、整理、入口や駐車場の清掃を担当します。店内や駐車場など店舗全体を見渡しながら、定位置に整列できているかを確認します。お客さまから売場の場所を質問されたときは応対します。</p>\n              </div>\n            </div>\n          </div>\n          <div class=\"result-area tab01-result job-splide splide sp job-splide01 is-show\" id=\"tab01-sp\" role=\"tabpanel\" aria-labelledby=\"tab01\">\n            <div class=\"splide__track\">\n              <div class=\"splide__list\">\n                <div class=\"c-job-box splide__slide\">\n                  <h3 class=\"box-ttl\">品質管理</h3>\n                  <div class=\"white-area  matchHeight\">\n                    <div class=\"balloon\">食品の安全を<br class=\"sp\">守るキーパー</div>\n                    <img src=\"/saiyo/challenged/img/home/job-img01.png.webp\" alt=\"食品の品質を管理するスタッフのイラスト\">\n                    <p class=\"txt\">商品の品質を確認することが主な業務です。食品担当の場合は食品の鮮度が保たれているか、衣料品担当の場合は衣服がきれいに折りたたまれているかなどを確認。お客さまが安心して買い物いただける商品かどうかをチェックします。</p>\n                  </div>\n                </div>\n                <div class=\"c-job-box splide__slide\">\n                  <h3 class=\"box-ttl\">衛生管理</h3>\n                  <div class=\"white-area  matchHeight\">\n                    <div class=\"balloon anim\"><span class=\"inn-txt\">品質と衛生環境を維持する最後の砦</span></div>\n                    <img src=\"/saiyo/challenged/img/home/job-img02.png.webp\" alt=\"品質チェックと衛生管理をするスタッフのイラスト\">\n                    <p class=\"txt\">消費期限がある商品に対して期限が近付いていないか、期限切れの商品がないかを確認します。さらに各作業場が清潔で整頓されているかなどの衛生管理も担当。各売場担当者が実施する品質管理のルールが守られているか、ダブルチェックする役割を担います。</p>\n                  </div>\n                </div>\n                <div class=\"c-job-box splide__slide\">\n                  <h3 class=\"box-ttl\">後方事務</h3>\n                  <div class=\"white-area  matchHeight\">\n                    <div class=\"balloon anim\"><span class=\"inn-txt\">スムーズな店舗運営を支える<span class=\"ib\">縁の下の力持ち</span></span></div>\n                    <img src=\"/saiyo/challenged/img/home/job-img03.png.webp\" alt=\"パソコンでデスクワークするスタッフのイラスト\">\n                    <p class=\"txt\">店舗の総務、人事教育、販売促進など、店舗運営をサポートするお仕事です。繁忙時は売場へのレジ応援や商品の品出し、抽選会など店頭イベントのサポートに入ることもあります。人事教育では採用選考会や新規入社者の受入準備などをお任せします。</p>\n                  </div>\n                </div>\n                <div class=\"c-job-box splide__slide\">\n                  <h3 class=\"box-ttl\">接客</h3>\n                  <div class=\"white-area  matchHeight\">\n                    <div class=\"balloon anim\"><span class=\"inn-txt\">笑顔と気配りでご対応する売場の顔</span></div>\n                    <img src=\"/saiyo/challenged/img/home/job-img04.png.webp\" alt=\"売場で接客をするスタッフのイラスト\">\n                    <p class=\"txt\">食品売場や衣料品売場、家庭用品売場など各売場でのお客さま対応が主な業務です。お客さまからのご質問への応対や売場案内、商品をお勧めする場面もあります。売場や商品の特徴を知り、お客さま視点での接客、販売をします。</p>\n                  </div>\n                </div>\n                <div class=\"c-job-box splide__slide\">\n                  <h3 class=\"box-ttl\">商品管理</h3>\n                  <div class=\"white-area matchHeight\">\n                    <div class=\"balloon anim\"><span class=\"inn-txt\">商品の数や状態をチェックする<span class=\"ib\">コツコツ作業</span></span></div>\n                    <img src=\"/saiyo/challenged/img/home/job-img05.png.webp\" alt=\"商品の数をチェックするスタッフのイラスト\">\n                    <p class=\"txt\">入荷商品の搬入口での受け取り、運搬、検品、在庫のチェック、パソコンでの伝票管理を担当します。食品、衣料品、家庭用品などすべての売場に共通するお仕事です。また、定期的に在庫の棚卸をしたり売場に直接商品を運ぶこともあります。</p>\n                  </div>\n                </div>\n                <div class=\"c-job-box splide__slide\">\n                  <h3 class=\"box-ttl\">カート回収</h3>\n                  <div class=\"white-area matchHeight\">\n                    <div class=\"balloon anim\"><span class=\"inn-txt\">カートや買い物カゴの<span class=\"ib\">整理担当</span></span></div>\n                    <img src=\"/saiyo/challenged/img/home/job-img06.png.webp\" alt=\"カートや買い物カゴを片付けるスタッフのイラスト\">\n                    <p class=\"txt\">店舗の敷地内にあるカートや買い物カゴの回収、整理、入口や駐車場の清掃を担当します。店内や駐車場など店舗全体を見渡しながら、定位置に整列できているかを確認します。お客さまから売場の場所を質問されたときは応対します。</p>\n                  </div>\n                </div>\n              </div>\n            </div>\n            <ul class=\"splide__pagination\"></ul>\n          </div>\n          <div class=\"result-area tab02-result pc\" role=\"tabpanel\" id=\"tab02\" aria-labelledby=\"tab02\">\n            <div class=\"c-job-box\">\n              <h3 class=\"box-ttl\">一般事務</h3>\n              <div class=\"white-area matchHeight\">\n                <div class=\"balloon anim\"><span class=\"inn-txt\">事務作業でチームを支える存在</span></div>\n                <img src=\"/saiyo/challenged/img/home/job-img07.png.webp\" alt=\"パソコンで事務作業をするスタッフのイラスト\">\n                <p class=\"txt\">データ入力、データ集計、書類作成、ファイリング、部署メンバーへの郵便物の仕分け、備品管理などが主な業務です。パソコンを使ったデスクワークが中心で、障がい特性に応じて電話対応もお願いします。今までの事務経験やExcelのスキルを活かせます。</p>\n              </div>\n            </div>\n            <div class=\"c-job-box\">\n              <h3 class=\"box-ttl\">ECサイト運営サポート</h3>\n              <div class=\"white-area matchHeight\">\n                <div class=\"balloon anim\"><span class=\"inn-txt\">画像を整え、言葉を添えて、<span class=\"ib\">サイトにアップ</span></span></div>\n                <img src=\"/saiyo/challenged/img/home/job-img08.png.webp\" alt=\"パソコンでECサイト運営サポートをするスタッフのイラスト\">\n                <p class=\"txt\">ネットスーパーなどのECサイト運営サポートのお仕事です。パソコンを使って商品画像データを加工し、タイトルや説明文をつけてサイトに商品を登録します。商品説明文は、取引先から共有を受けた情報をもとに、よりわかりやすい表現に修正します。</p>\n              </div>\n            </div>\n            <div class=\"c-job-box\">\n              <h3 class=\"box-ttl\">商品発注業務事務</h3>\n              <div class=\"white-area matchHeight\">\n                <div class=\"balloon anim\"><span class=\"inn-txt\">商品情報を正確に登録し、<span class=\"ib\">円滑な運用をサポート</span></span></div>\n                <img src=\"/saiyo/challenged/img/home/job-img09.png.webp\" alt=\"パソコンで商品の発注業務をするスタッフのイラスト\">\n                <p class=\"txt\">店舗の担当者が発注業務をできるように商品情報の登録を行います。また、独自の自動受発注システムを使った数量入力も行います。将来的には、店舗や売場ごとの販売データを分析して、会議資料を作成することもあります。</p>\n              </div>\n            </div>\n            <div class=\"c-job-box\">\n              <h3 class=\"box-ttl\">契約管理</h3>\n              <div class=\"white-area matchHeight\">\n                <div class=\"balloon anim\">安心と信頼をつくる書類のプロ</div>\n                <img src=\"/saiyo/challenged/img/home/job-img10.png.webp\" alt=\"パソコンで契約関連のサポートをするスタッフのイラスト\">\n                <p class=\"txt\">取引先と契約を交わす際に、契約書の作成や内容確認を行います。契約内容が法令や規定に沿っているかをチェックし、期限管理やリスク管理も担当します。また、契約に関する問い合わせ対応や調整業務を行い、契約が円滑に進むようサポートします。</p>\n              </div>\n            </div>\n            <div class=\"c-job-box\">\n              <h3 class=\"box-ttl\">経理事務</h3>\n              <div class=\"white-area matchHeight\">\n                <div class=\"balloon anim\">ミスなくコツコツお金の記録係</div>\n                <img src=\"/saiyo/challenged/img/home/job-img11.png.webp\" alt=\"パソコンで経理業務をするスタッフのイラスト\">\n                <p class=\"txt\">取引先からの請求書の確認や自社システムへのデータ入力、請求書や領収書の発行、管理、経費精算などが主な業務です。さらに、税金の申告書類や財務資料の作成補助も行います。正確さや細部への注意力が求められるお仕事です。</p>\n              </div>\n            </div>\n          </div>\n          <div class=\"result-area tab02-result job-splide splide sp job-splide02\" role=\"tabpanel\" id=\"tab02-sp\" aria-labelledby=\"tab02\">\n            <div class=\"splide__track\">\n              <div class=\"splide__list\">\n                <div class=\"c-job-box splide__slide\">\n                  <h3 class=\"box-ttl\">一般事務</h3>\n                  <div class=\"white-area matchHeight\">\n                    <div class=\"balloon anim\"><span class=\"inn-txt\">事務作業でチームを支える存在</span></div>\n                    <img src=\"/saiyo/challenged/img/home/job-img07.png.webp\" alt=\"パソコンで事務作業をするスタッフのイラスト\">\n                    <p class=\"txt\">データ入力、データ集計、書類作成、ファイリング、部署メンバーへの郵便物の仕分け、備品管理などが主な業務です。パソコンを使ったデスクワークが中心で、障がい特性に応じて電話対応もお願いします。今までの事務経験やExcelのスキルを活かせます。</p>\n                  </div>\n                </div>\n                <div class=\"c-job-box splide__slide\">\n                  <h3 class=\"box-ttl\">ECサイト運営サポート</h3>\n                  <div class=\"white-area matchHeight\">\n                    <div class=\"balloon anim\"><span class=\"inn-txt\">画像を整え、言葉を添えて、<span class=\"ib\">サイトにアップ</span></span></div>\n                    <img src=\"/saiyo/challenged/img/home/job-img08.png.webp\" alt=\"パソコンでECサイト運営サポートをするスタッフのイラスト\">\n                    <p class=\"txt\">ネットスーパーなどのECサイト運営サポートのお仕事です。パソコンを使って商品画像データを加工し、タイトルや説明文をつけてサイトに商品を登録します。商品説明文は、取引先から共有を受けた情報をもとに、よりわかりやすい表現に修正します。</p>\n                  </div>\n                </div>\n                <div class=\"c-job-box splide__slide\">\n                  <h3 class=\"box-ttl\">商品発注業務事務</h3>\n                  <div class=\"white-area matchHeight\">\n                    <div class=\"balloon anim\"><span class=\"inn-txt\">商品情報を正確に登録し、円滑な運用をサポート</span></div>\n                    <img src=\"/saiyo/challenged/img/home/job-img09.png.webp\" alt=\"パソコンで商品の発注業務をするスタッフのイラスト\">\n                    <p class=\"txt\">店舗の担当者が発注業務をできるように商品情報の登録を行います。また、独自の自動受発注システムを使った数量入力も行います。将来的には、店舗や売場ごとの販売データを分析して、会議資料を作成することもあります。</p>\n                  </div>\n                </div>\n                <div class=\"c-job-box splide__slide\">\n                  <h3 class=\"box-ttl\">契約管理</h3>\n                  <div class=\"white-area matchHeight\">\n                    <div class=\"balloon anim\"><span class=\"inn-txt\">安心と信頼をつくる書類のプロ</span></div>\n                    <img src=\"/saiyo/challenged/img/home/job-img10.png.webp\" alt=\"パソコンで契約関連のサポートをするスタッフのイラスト\">\n                    <p class=\"txt\">取引先と契約を交わす際に、契約書の作成や内容確認を行います。契約内容が法令や規定に沿っているかをチェックし、期限管理やリスク管理も担当します。また、契約に関する問い合わせ対応や調整業務を行い、契約が円滑に進むようサポートします。</p>\n                  </div>\n                </div>\n                <div class=\"c-job-box splide__slide\">\n                  <h3 class=\"box-ttl\">経理事務</h3>\n                  <div class=\"white-area matchHeight\">\n                    <div class=\"balloon anim\"><span class=\"inn-txt\">ミスなくコツコツお金の記録係</span></div>\n                    <img src=\"/saiyo/challenged/img/home/job-img11.png.webp\" alt=\"パソコンで経理業務をするスタッフのイラスト\">\n                    <p class=\"txt\">取引先からの請求書の確認や自社システムへのデータ入力、請求書や領収書の発行、管理、経費精算などが主な業務です。さらに、税金の申告書類や財務資料の作成補助も行います。正確さや細部への注意力が求められるお仕事です。</p>\n                  </div>\n                </div>\n              </div>\n            </div>\n            <ul class=\"splide__pagination\"></ul>\n          </div>\n\n          <div class=\"btn-wrap\">\n            <a href=\"/saiyo/challenged/work/\" class=\"c-btn01\">仕事図鑑を見る<span class=\"icon\"></span></a>\n          </div>\n        </div>\n      </section>\n\n      <section class=\"c-interview-section interview-splide splide anim\">\n        <div class=\"inner-block\">\n          <div class=\"top-area\">\n            <h2 class=\"c-ttl01 green\">\n              <span class=\"ja\">先輩社員の声</span>\n              <span class=\"en\">Interview</span>\n            </h2>\n            <div class=\"nav-area\">\n              <ul class=\"splide__pagination\"></ul>\n              <button class=\"splide-toggle\"><span class=\"txt\">停止</span></button>\n              <div class=\"splide__arrows\"></div>\n            </div>\n          </div>\n          <div class=\"splide__wrapper\">\n            <div class=\"splide__track\">\n              <ul class=\"splide__list\">\n\n                <li class=\"splide__slide\">\n                  <a href=\"/saiyo/challenged/interview/staff01/\">\n                    <div class=\"img-area\"><img src=\"/saiyo/challenged/img/home/interview-img01.jpg.webp\" alt=\"\"></div>\n                    <div class=\"tag-list\">\n                      <span class=\"tag\">上下肢障がい　1級</span>\n                    </div>\n                    <h3 class=\"ttl\">薬剤師のキャリアを続けるには最適な場所。売場をまとめるリーダーとして活躍</h3>\n                    <div class=\"profile-wrap\">\n                      <p class=\"p-item\">部署</p>\n                      <p class=\"p-txt\">ファーマシー売場</p>\n                    </div>\n                    <div class=\"profile-wrap\">\n                      <p class=\"p-item\">入社</p>\n                      <p class=\"p-txt\">2001年3月</p>\n                    </div>\n                    <p class=\"name\">K.K.さん</p>\n                    <p class=\"link\">K.K.さんのインタビューを見る</p>\n                  </a>\n                </li>\n\n                <li class=\"splide__slide\">\n                  <a href=\"/saiyo/challenged/interview/staff02/\">\n                    <div class=\"img-area\"><img src=\"/saiyo/challenged/img/home/interview-img02.jpg.webp\" alt=\"\"></div>\n                    <div class=\"tag-list\">\n                      <span class=\"tag\">上下肢障がい　1級</span>\n                    </div>\n                    <h3 class=\"ttl\">ここは、自分の持ち味を輝かせてくれる場所</h3>\n                    <div class=\"profile-wrap\">\n                      <p class=\"p-item\">部署</p>\n                      <p class=\"p-txt\">本社 人事総務本部</p>\n                    </div>\n                    <div class=\"profile-wrap\">\n                      <p class=\"p-item\">入社</p>\n                      <p class=\"p-txt\">2018年4月</p>\n                    </div>\n                    <p class=\"name\"><span class=\"en\">K.M.</span>さん</p>\n                    <p class=\"link\">K.M.さんのインタビューを見る</p>\n                  </a>\n                </li>\n\n                <li class=\"splide__slide\">\n                  <a href=\"/saiyo/challenged/interview/staff03/\">\n                    <div class=\"img-area\"><img src=\"/saiyo/challenged/img/home/interview-img03.jpg.webp\" alt=\"\"></div>\n                    <div class=\"tag-list\">\n                      <span class=\"tag\">知的障がい　C</span>\n                    </div>\n                    <h3 class=\"ttl\">新鮮でおいしい野菜をお客さまへ届けるために。チームの仲間と一緒に成長していく</h3>\n                    <div class=\"profile-wrap\">\n                      <p class=\"p-item\">部署</p>\n                      <p class=\"p-txt\">農産売場</p>\n                    </div>\n                    <div class=\"profile-wrap\">\n                      <p class=\"p-item\">入社</p>\n                      <p class=\"p-txt\">2009年3月</p>\n                    </div>\n                    <p class=\"name\"><span class=\"en\">R.M.</span>さん</p>\n                    <p class=\"link\">R.M.さんのインタビューを見る</p>\n                  </a>\n                </li>\n\n                <li class=\"splide__slide\">\n                  <a href=\"/saiyo/challenged/interview/staff04/\">\n                    <div class=\"img-area\"><img src=\"/saiyo/challenged/img/home/interview-img04.jpg.webp\" alt=\"\"></div>\n                    <div class=\"tag-list\">\n                      <span class=\"tag\">聴覚障がい　2級</span>\n                    </div>\n                    <h3 class=\"ttl\">頼られることがうれしくて、私にできることをもっと探したくなる</h3>\n                    <div class=\"profile-wrap\">\n                      <p class=\"p-item\">部署</p>\n                      <p class=\"p-txt\">インナー売場</p>\n                    </div>\n                    <div class=\"profile-wrap\">\n                      <p class=\"p-item\">入社</p>\n                      <p class=\"p-txt\">2008年11月</p>\n                    </div>\n                    <p class=\"name\"><span class=\"en\">J.O.</span>さん</p>\n                    <p class=\"link\">J.O.さんのインタビューを見る</p>\n                  </a>\n                </li>\n\n                <li class=\"splide__slide\">\n                  <a href=\"/saiyo/challenged/interview/staff05/\">\n                    <div class=\"img-area\"><img src=\"/saiyo/challenged/img/home/interview-img05.jpg.webp\" alt=\"\"></div>\n                    <div class=\"tag-list\">\n                      <span class=\"tag\">内臓機能障がい（心臓）　1級</span>\n                    </div>\n                    <h3 class=\"ttl\">細やかな視点と伝える力で、食の品質を守る</h3>\n                    <div class=\"profile-wrap\">\n                      <p class=\"p-item\">部署</p>\n                      <p class=\"p-txt\">クオリティキーパー</p>\n                    </div>\n                    <div class=\"profile-wrap\">\n                      <p class=\"p-item\">入社</p>\n                      <p class=\"p-txt\">2016年3月</p>\n                    </div>\n                    <p class=\"name\"><span class=\"en\">T.S.</span>さん</p>\n                    <p class=\"link\">T.S.さんのインタビューを見る</p>\n                  </a>\n                </li>\n\n                <li class=\"splide__slide\">\n                  <a href=\"/saiyo/challenged/interview/staff06/\">\n                    <div class=\"img-area\"><img src=\"/saiyo/challenged/img/home/interview-img06.jpg.webp\" alt=\"\"></div>\n                    <div class=\"tag-list\">\n                      <span class=\"tag\">精神疾患　3級</span>\n                    </div>\n                    <h3 class=\"ttl\">夢中になれるPOPづくりで、売場の皆さんを支える</h3>\n                    <div class=\"profile-wrap\">\n                      <p class=\"p-item\">部署</p>\n                      <p class=\"p-txt\">販売促進</p>\n                    </div>\n                    <div class=\"profile-wrap\">\n                      <p class=\"p-item\">入社</p>\n                      <p class=\"p-txt\">2020年10月</p>\n                    </div>\n                    <p class=\"name\"><span class=\"en\">S.T.</span>さん</p>\n                    <p class=\"link\">S.T.さんのインタビューを見る</p>\n                  </a>\n                </li>\n\n              </ul>\n            </div>\n          </div>\n          <div class=\"btn-wrap\"><a href=\"/saiyo/challenged/interview/\" class=\"c-btn01\">先輩社員の声を見る<span class=\"icon\"></span></a></div>\n        </div>\n      </section>\n\n      <section class=\"work-section c-bg-pink anim\">\n        <div class=\"inner-block\">\n          <h2 class=\"c-ttl01 blue\">\n            <span class=\"ja\">制度・<span class=\"ib\">働く環境</span></span>\n            <span class=\"en\">WorkStyle</span>\n          </h2>\n          <div class=\"flex-wrap\">\n            <a href=\"/saiyo/challenged/training-careersupport/\" class=\"box\">\n              <div class=\"img-area\"><img src=\"/saiyo/challenged/img/home/work-img01.jpg.webp\" alt=\"\"></div>\n              <div class=\"txt-area\">\n                <h3 class=\"box-ttl\">研修・<span class=\"ib\">キャリア支援制度</span></h3>\n                <p class=\"txt matchHeight\">未経験の方でも安心して業務を学べる研修や、わかりやすく写真や動画を使ったマニュアル、VRで体験しながら学ぶ環境もあります。また、全社員共通の公正な人事制度を設けており、障がいの有無にかかわらず、上位職へのキャリアアップが可能です。</p>\n                <span class=\"c-btn01\">研修・キャリア支援制度<br class=\"sp\">を見る<span class=\"icon\"></span></span>\n              </div>\n            </a>\n            <a href=\"/saiyo/challenged/environment/\" class=\"box\">\n              <div class=\"img-area\"><img src=\"/saiyo/challenged/img/home/work-img02.jpg.webp\" alt=\"\"></div>\n              <div class=\"txt-area\">\n                <h3 class=\"box-ttl\">働く環境</h3>\n                <p class=\"txt matchHeight\">無理なく働けるシフト、バリアフリー設備、筆談対応など、特性に合わせて安心して働ける環境を整えています。また、イオンでのお買い物がお得になる割引制度など、福利厚生も充実しています。</p>\n                <span class=\"c-btn01\">働く環境を見る<span class=\"icon\"></span></span>\n              </div>\n            </a>\n          </div>\n        </div>\n      </section>\n      <section class=\"faq-section anim\">\n        <div class=\"inner-block\">\n          <h2 class=\"c-ttl01 orange\">\n            <span class=\"ja\">よくある質問</span>\n            <span class=\"en\">FAQ</span>\n          </h2>\n          <div class=\"faq-area\">\n            <div class=\"c-faq-box is-active\">\n              <h3>\n                <button class=\"c-q-area\" aria-expanded=\"true\">\n                  <span class=\"en icon-q\">Q.</span>\n                  <span class=\"q-wrap\">\n                    <span class=\"txt\">障がいのある社員はどれくらい在籍していますか？</span>\n                    <span class=\"icon\"></span>\n                  </span>\n                </button>\n              </h3>\n              <div class=\"c-a-area\">\n                <div class=\"a-inn\">\n                  <span class=\"en icon-a\">A.</span>\n                  <p class=\"txt\">現在約2,000名以上の障がい者の方々が働いています。イオンリテールでは障がいのある方の採用を積極的に進めています。</p>\n                  <span class=\"icon\"></span>\n                </div>\n              </div>\n            </div>\n            <div class=\"c-faq-box\">\n              <h3>\n                <button class=\"c-q-area\" aria-expanded=\"false\">\n                  <span class=\"en icon-q\">Q.</span>\n                  <span class=\"q-wrap\">\n                    <span class=\"txt\">書類選考や面接で重視されるポイントを教えてください。</span>\n                    <span class=\"icon\"></span>\n                  </span>\n                </button>\n              </h3>\n              <div class=\"c-a-area\">\n                <div class=\"a-inn\">\n                  <span class=\"en icon-a\">A.</span>\n                  <p class=\"txt\">障がいの有無に関わらず、職務に対する意欲、ご経歴、適性などを重視しています。障がい特性や業務上配慮が必要な点についても確認します。</p>\n                  <span class=\"icon\"></span>\n                </div>\n\n              </div>\n            </div>\n            <div class=\"c-faq-box\">\n              <h3>\n                <button class=\"c-q-area\" aria-expanded=\"false\">\n                  <span class=\"en icon-q\">Q.</span>\n                  <span class=\"q-wrap\">\n                    <span class=\"txt\">障がいに合わせて働けますか？</span>\n                    <span class=\"icon\"></span>\n                  </span>\n                </button>\n              </h3>\n              <div class=\"c-a-area\">\n                <div class=\"a-inn\">\n                  <span class=\"en icon-a\">A.</span>\n                  <p class=\"txt\">\n                    イオンリテールでは、障がい特性に合わせたいろいろな仕事をご用意しています。詳しくは、当社ホームページ内にあります「仕事図鑑」をご覧ください。\n                    <a href=\"/saiyo/challenged/work/\" class=\"link ib\">仕事図鑑ページを見る</a>\n                  </p>\n                  <span class=\"icon\"></span>\n                </div>\n              </div>\n            </div>\n            <div class=\"c-faq-box\">\n              <h3>\n                <button class=\"c-q-area\" aria-expanded=\"false\">\n                  <span class=\"en icon-q\">Q.</span>\n                  <span class=\"q-wrap\">\n                    <span class=\"txt\">仕事を覚えるまでに研修やサポートはありますか？</span>\n                    <span class=\"icon\"></span>\n                  </span>\n                </button>\n              </h3>\n              <div class=\"c-a-area\">\n                <div class=\"a-inn\">\n                  <span class=\"en icon-a\">A.</span>\n                  <p class=\"txt\">\n                    入社後研修はもちろん、先輩からOJTで仕事を学べるフォローアップ研修、スキルアップ研修などをご用意しています。研修内容や仕事の手順を写真付きで細かくマニュアルにし、安心して仕事ができる体制を整えています。\n                  </p>\n                  <span class=\"icon\"></span>\n                </div>\n              </div>\n            </div>\n            <div class=\"c-faq-box\">\n              <h3>\n                <button class=\"c-q-area\" aria-expanded=\"false\">\n                  <span class=\"en icon-q\">Q.</span>\n                  <span class=\"q-wrap\">\n                    <span class=\"txt\">勤務地、配属はどのように決まりますか？</span>\n                    <span class=\"icon\"></span>\n                  </span>\n                </button>\n              </h3>\n              <div class=\"c-a-area\">\n                <div class=\"a-inn\">\n                  <span class=\"en icon-a\">A.</span>\n                  <p class=\"txt\">\n                    勤務地はご希望をふまえ検討します。時間給制社員（パートタイマー）は自宅から通える範囲で決定します。日給月給制社員（正社員）は選択した勤務エリア区分により、配属範囲が異なります。配属は会社の方針とご本人の希望、能力、適性を総合的に判断して決定します。\n                  </p>\n                  <span class=\"icon\"></span>\n                </div>\n\n              </div>\n            </div>\n            <div class=\"c-faq-box\">\n              <h3>\n                <button class=\"c-q-area\" aria-expanded=\"false\">\n                  <span class=\"en icon-q\">Q.</span>\n                  <span class=\"q-wrap\">\n                    <span class=\"txt\">職場のバリアフリー環境は整っていますか？</span>\n                    <span class=\"icon\"></span>\n                  </span>\n                </button>\n              </h3>\n              <div class=\"c-a-area\">\n                <div class=\"a-inn\">\n                  <span class=\"en icon-a\">A.</span>\n                  <p class=\"txt\">\n                    車いす利用者や視覚障がいのある方が安全に移動できるよう、エントランスや通路はバリアフリー設計になっていることが多いです。また、エレベーターや多目的トイレの設置も積極的に進めています。勤務場所によって異なりますので、詳しくは面接でお聞きください。\n                  </p>\n                  <span class=\"icon\"></span>\n                </div>\n              </div>\n            </div>\n\n          </div>\n          <div class=\"btn-wrap\"><a href=\"/saiyo/challenged/faq/\" class=\"c-btn01\">よくある質問を見る<span class=\"icon\"></span></a></div>\n        </div>\n      </section>\n    </main>\n\n    <footer></footer>\n    <script>\n      $('footer').load('/saiyo/challenged/inc/c-footer.html');\n    </script>\n\n  </div><!-- /wrapper -->\n\n  <script src=\"/saiyo/challenged/js/lib/splide.min.js\"></script>\n  <script src=\"/saiyo/challenged/js/lib/jquery.matchHeight-min.js\"></script>\n  <script src=\"/saiyo/challenged/js/common.js\"></script>\n</body>\n\n</html>","finalUrl":"https://www.aeonretail.jp/saiyo/challenged/","rendered":false,"_cachedAt":"2026-06-22T21:06:50.558Z"}