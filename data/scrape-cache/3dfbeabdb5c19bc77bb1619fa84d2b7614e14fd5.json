\t\t\tconst answer = $(this).next(\".data_list dd\");\r\n\t\t\t\tif (!answer.is(\":visible\")) {\r\n\t\t\t\t\tanswer.slideDown(\"fast\");\r\n\t\t\t\t} else {\r\n\t\t\t\t\tanswer.slideUp(\"fast\")\r\n\t\t\t\t}\r\n\t\t\t});\r\n\t\t});\r\n\t</script>\r\n\r\n\t<script>\r\n\t\tdocument.addEventListener(\"DOMContentLoaded\", function () {\r\n\t\t\tvar container = document.querySelector('.taisei');\r\n\t\t\tvar figure = container.querySelector('.taisei_figure');\r\n\t\t\tvar imageWidth = figure.scrollWidth;\r\n\t\t\tif (imageWidth <= container.clientWidth) {\r\n\t\t\t\treturn;\r\n\t\t\t}\r\n\t\t\tvar centerScroll = (imageWidth - container.clientWidth) / 2;\r\n\t\t\tcontainer.scrollLeft = centerScroll;\r\n\t\t});\r\n\t</script>\r\n\r\n</body>\r\n\r\n</html>","finalUrl":"https://www.doggyman.com/recruit/business/","rendered":false,"_cachedAt":"2026-06-22T20:53:20.161Z"}