'});var f=d.getElementsByTagName(s)[0],\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n})(window,document,'script','dataLayer','GTM-P8R6G6L');</script>\n<!-- End Google Tag Manager -->\n\n<div id=\"wrapper\">\n\n<header id=\"header\" class=\"header uk-container uk-flex uk-flex-middle\">\n  <div class=\"header-logo\"><a href=\"https://man-up.co.jp\"><img src=\"https://man-up.co.jp/wp-content/themes/manup/img/common/logo_01.png\" srcset=\"https://man-up.co.jp/wp-content/themes/manup/img/common/logo_01.svg\" alt=\"株式会社マンアップ\"></a></div>\n  <nav id=\"gnav\" class=\"gnav uk-flex uk-flex-middle\">\n    <ul class=\"uk-flex uk-flex-wrap gnav-section\">\n      <li class=\"gnav-list\"><a href=\"https://man-up.co.jp/sales/\" class=\"com-link-03\">販促支援</a></li>\n      <li class=\"gnav-list\"><a href=\"https://man-up.co.jp/dispatch/\" class=\"com-link-03\">人材派遣</a></li>\n      <li class=\"gnav-list\"><a href=\"https://man-up.co.jp/logistics/\" class=\"com-link-03\">ロジスティクス</a></li>\n      <li class=\"gnav-list\"><a href=\"https://man-up.co.jp/nursery/\" class=\"com-link-03\">知育・保育</a></li>\n      <li class=\"gnav-list\"><a href=\"https://man-up.co.jp/outline/\" class=\"com-link-03\">企業情報</a></li>\n      <li class=\"gnav-list gnav-btn\"><a href=\"https://man-up.co.jp/contact/\" class=\"com-link-03 blue\">お問合せ</a></li>\n    </ul>\n  </nav><!-- /#gnav -->\n  <a href=\"#offcanvas\" class=\"header-menu-btn uk-hidden-larges\" data-uk-offcanvas>\n    <img src=\"https://man-up.co.jp/wp-content/themes/manup/img/common/btn_menu.svg\" alt=\"メニュー\">\n  </a>\n</header><!-- /#header -->\n\n\n<main id=\"main\">\n\n<section id=\"information-01\" class=\"com-section bg-blue-l\">\n  <div class=\"com-layout-02\">\n    <div id=\"keyvisual\" class=\"img keyvisual tiny information\">\n      <div class=\"keyvisual-inner uk-container\">\n        <h2 class=\"keyvisual-title com-tit-01\" data-uk-scrollspy=\"{cls:'uk-animation-fade'}\">インフォメーション<small class=\"sub\">INFORMATION</small></h2>\n      </div><!-- /.keyvisual-inner -->\n\n    </div><!-- /#keyvisual -->\n    \n        <article class=\"uk-container uk-container-sp\">\n      <div class=\"panel com-panel-01 white\" data-uk-scrollspy=\"{cls:'uk-animation-fade'}\">\n        <div class=\"panel-head\">\n          <p class=\"panel-accent\">2023年03月28日</p>\n          <h1 class=\"panel-tit com-tit-01 small\">プライバシーマーク取得のお知らせ</h1>\n        </div><!-- /.head -->\n        \n        <div class=\"panel-text\">\n                    \n          <p><p style=\"text-align: right\">2023年3月28日</p>\n<p>日頃は格別のお引き立てをいただき、ありがたく御礼申し上げます。</p>\n<p>株式会社マンアップ（本社：滋賀県大津市、代表取締役：宇野 晴久 以下、マンアップ）は、<br />\nこのたび、一般財団法人日本情報経済社会推進協会（JIPDEC）より<br />\n「プライバシーマーク」の認定を受けたことをお知らせいたします。</p>\n<p>マンアップは、事業活動を通じて取得する個人情報を適正に取り扱うため、<br />\nセキュリティ対策および社員のセキュリティ意識の向上に努めてまいりました。</p>\n<p>今後も当社は、プライバシーマーク認定事業者として、<br />\n個人情報の厳正な取り扱い体制を維持・強化してまいります。</p>\n<p style=\"margin-top:30px;\">認定概要<br />\n・登録組織：株式会社マンアップ<br />\n・登録番号：第 20002847 (01)号<br />\n・認定取得日：2023年3月20日\n</p>\n<p style=\"margin-top:30px;\">〈プライバシーマーク制度について〉<br />\nプライバシーマーク制度は、日本産業規格「JIS Q 15001個人情報保護マネジメントシステム－要求事項」に準拠した<br />\n「プライバシーマークにおける個人情報保護マネジメントシステム構築・運用指針」に基づいて、<br />\n個人情報について適切な保護措置を講ずる体制を整備している事業者等を評価し、<br />\nその旨を示すプライバシーマークを付与し、事業活動に関してプライバシーマークの使用を認める制度です。<br />\n※一般財団法人日本情報経済社会推進協会（JIPDEC）より引用　<a href=\"https://privacymark.jp/\" title=\"https://privacymark.jp/\" style=\"border-bottom:solid 1px;\">https://privacymark.jp/</a></p>\n</p>\n        </div><!-- /.text -->\n      </div><!-- /.com-panel-01 -->\n    </article><!-- /.uk-container -->\n    </div><!-- /.com-layout-02 -->\n</section><!-- /#information-01 -->\n\n<section id=\"information-02\" class=\"com-section section-no-padding\">\n  <div class=\"uk-container uk-container-sp\" data-uk-scrollspy=\"{cls:'uk-animation-fade'}\">\n      <div class=\"information-link-01 uk-flex\">\n          <a href=\"https://man-up.co.jp/information/post439\" class=\"com-btn-01 arrow left\">前の記事</a>\n              <a href=\"https://man-up.co.jp/information/post444\" class=\"com-btn-01 arrow right\">次の記事</a>\n        </div>\n      </div>\n</section><!-- /#information-02 -->\n\n</main><!-- /#main -->\n\n\n<footer id=\"footer\" class=\"footer\">\n  <div class=\"footer-backtop uk-container\">\n    <a href=\"#wrapper\" class=\"footer-backtop-btn\" data-uk-smooth-scroll><img src=\"https://man-up.co.jp/wp-content/themes/manup/img/common/btn_backtop.svg\" alt=\"ページのトップへ戻る\"></a>\n  </div><!-- /.footer-backtop -->\n  <div class=\"uk-container\">\n    <strong class=\"footer-catch\">明日のビジネスを変える提案。<br> 人と社会、未来へつなぐ架け橋に。</strong>\n    <div class=\"footer-logo\"><img src=\"https://man-up.co.jp/wp-content/themes/manup/img/common/logo_01.png\" alt=\"株式会社マンアップ\"></div>\n    <div class=\"P-mark\"><img src=\"https://man-up.co.jp/wp-content/themes/manup/img/common/Pmark.png\" alt=\"Pマーク\"></div>\n    <dl class=\"footer-text\">\n      <dt>株式会社マンアップ</dt>\n      <dd>〒520-0044 滋賀県大津市京町4丁目5番23号 フォレスト京町ビル5F</dd>\n      <dd>／ TEL.077-524-9220 ／ FAX.077-525-2084</dd>\n    </dl>\n    <a href=\"./privacy/\">｜個人情報取保護方針｜</a></div>\n  <small class=\"footer-copyright\">Copyright  2018 Manupco.,Ltd All Rights Reserved.</small>\n</footer><!-- /#footer -->\n</div><!-- /#wrapper -->\n\n<div id=\"offcanvas\" class=\"uk-offcanvas\">\n  <div class=\"uk-offcanvas-bar uk-offcanvas-bar-flip\">\n    <p class=\"offcanvas-tit\">MENU</p>\n    <ul class=\"uk-nav uk-nav-offcanvas uk-nav-parent-icon\" data-uk-nav=\"{multiple:true}\">\n      <li><a href=\"https://man-up.co.jp/\"><i class=\"icon-file\"></i>ホーム</a></li>\n      <li><a href=\"https://man-up.co.jp/sales/\"><i class=\"icon-file\"></i>販促支援事業</a></li>\n      <li><a href=\"https://man-up.co.jp/dispatch/\"><i class=\"icon-file\"></i>人材派遣事業</a></li>\n      <li><a href=\"https://man-up.co.jp/logistics/\"><i class=\"icon-file\"></i>ロジスティクス事業</a></li>\n      <li><a href=\"https://man-up.co.jp/nursery/\"