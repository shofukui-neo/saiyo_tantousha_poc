{"url":"https://www.takizumi.com/recruit/welfare","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n<head prefix=\"og: http://ogp.me/ns#\">\n\t<!-- Google tag (gtag.js) -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-23HKB9BP8V\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'G-23HKB9BP8V');\n</script>\t<meta charset=\"UTF-8\">\n\t<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n\t<title>福利厚生｜タキズミ採用サイト</title>\n  <meta name=\"description\" content=\"タキズミの福利厚生を紹介します。年2回の賞与以外に業績賞与を設け、社員寮を完備し、家賃補助を手厚くするなど、独自の福利厚生制度を充実させています。社員が快適に、やりがいを持って働ける環境をつくることを大切にしています。\">\n  <meta name=\"keywords\" content=\"\">\n\n  <meta property=\"fb:app_id\" content=\"\">\n  <meta property=\"og:title\" content=\"福利厚生｜タキズミ採用サイト\">\n  <meta property=\"og:description\" content=\"タキズミの福利厚生を紹介します。年2回の賞与以外に業績賞与を設け、社員寮を完備し、家賃補助を手厚くするなど、独自の福利厚生制度を充実させています。社員が快適に、やりがいを持って働ける環境をつくることを大切にしています。\">\n  <meta property=\"og:type\" content=\"website\">\n  <meta property=\"og:image\" content=\"https://www.takizumi.com/recruit/images/ogp.jpg\">\n  <meta property=\"og:url\" content=\"https://www.takizumi.com/recruit/welfare/\">\n  <meta property=\"og:site_name\" content=\"株式会社タキズミ\">\n  <meta property=\"og:locale\" content=\"ja_JP\">\n  <meta name=\"twitter:title\" content=\"福利厚生｜タキズミ採用サイト\">\n  <meta name=\"twitter:description\" content=\"タキズミの福利厚生を紹介します。年2回の賞与以外に業績賞与を設け、社員寮を完備し、家賃補助を手厚くするなど、独自の福利厚生制度を充実させています。社員が快適に、やりがいを持って働ける環境をつくることを大切にしています。\">\n  <meta name=\"twitter:image\" content=\"https://www.takizumi.com/recruit/images/ogp.jpg\">\n  <meta name=\"twitter:url\" content=\"https://www.takizumi.com/recruit/welfare/\">\n  <meta name=\"twitter:card\" content=\"summary_large_image\">\n\t<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<link rel=\"icon\" href=\"/recruit/images/apple-touch-icon.png\">\n<link rel=\"shortcut icon\" href=\"/recruit/images/apple-touch-icon.png\">\n<link rel=\"shortcut icon\" type=\"image/x-icon\" href=\"/recruit/favicon.ico\">\n<link rel=\"apple-touch-icon\" href=\"/recruit/images/apple-touch-icon.png\">\n<link rel=\"apple-touch-icon-precomposed\" href=\"/recruit/images/apple-touch-icon-precomposed.png\">\n\n\t<link rel=\"stylesheet\" href=\"../css/reset.css\">\n  <link rel=\"stylesheet\" href=\"../css/style.css\">\n</head>\n<body>\n\t\n  <div id=\"wrapper\" class=\"welfare\">\n  <div id=\"Loader\"><span class=\"base\"></span><span class=\"progress\"></span></div>\n\n\t\t<div id=\"page\">\n\t\t\t<header id=\"header\" class=\"header\">\n  <div class=\"header_logo_area\"><a href=\"/recruit/\">\n    <p class=\"header_logo\"><img src=\"/recruit/images/all_logo.jpg\" alt=\"株式会社タキズミ\"></p>\n    <p class=\"header_logo_recruit\">RECRUIT SITE</p>\n  </a></div>\n\t<div class=\"header_menubtn\">\n\t\t<div class=\"header_menubtn_lines\">\n\t\t\t<span></span>\n\t\t\t<span></span>\n\t\t</div>\n\t</div>\n\t<div class=\"header_wrap\">\n\t\t<div class=\"header_wrap_inner\">\n\t\t\t<nav class=\"header_gnav\">\n\t\t\t\t<ul class=\"header_gnav_nav\">\n\t\t\t\t\t<li class=\"header_gnav_item header_gnav_item_01 header_gnav_item_solo\"><a href=\"/recruit/business/\">事業紹介</a></li>\n\t\t\t\t\t<li class=\"header_gnav_item header_gnav_item_02 header_gnav_item_mega\"><span>仕事を知る</span>\n\t\t\t\t\t\t<div class=\"header_gnav_mega\">\n\t\t\t\t\t\t\t<ul class=\"header_megamenu\">\n\t\t\t\t\t\t\t\t<li class=\"header_megamenu_item\"><a href=\"/recruit/crosstalk/\">社員クロストーク</a></li>\n\t\t\t\t\t\t\t\t<li class=\"header_megamenu_item\"><a href=\"/recruit/workflow/\">1日の仕事の流れ</a></li>\n\t\t\t\t\t\t\t</ul>\n\t\t\t\t\t\t</div>\n          </li>\n\t\t\t\t\t<li class=\"header_gnav_item header_gnav_item_03 header_gnav_item_mega\"><span>働く環境を知る</span>\n\t\t\t\t\t\t<div class=\"header_gnav_mega\">\n\t\t\t\t\t\t\t<ul class=\"header_megamenu\">\n\t\t\t\t\t\t\t\t<li class=\"header_megamenu_item\"><a href=\"/recruit/training/\">キャリア・研修制度</a></li>\n\t\t\t\t\t\t\t\t<li class=\"header_megamenu_item\"><a href=\"/recruit/welfare/\">福利厚生</a></li>\n\t\t\t\t\t\t\t</ul>\n\t\t\t\t\t\t</div>\n          </li>\n\t\t\t\t\t<li class=\"header_gnav_item header_gnav_item_04 header_gnav_item_mega\"><span>人を知る</span>\n\t\t\t\t\t\t<div class=\"header_gnav_mega\">\n\t\t\t\t\t\t\t<ul class=\"header_megamenu\">\n\t\t\t\t\t\t\t\t<li class=\"header_megamenu_item\"><a href=\"/recruit/Interview01/\">社員インタビュー01</a></li>\n\t\t\t\t\t\t\t\t<li class=\"header_megamenu_item\"><a href=\"/recruit/Interview02/\">社員インタビュー02</a></li>\n\t\t\t\t\t\t\t\t<!-- <li class=\"header_megamenu_item\"><a href=\"/recruit/Interview03/\">社員インタビュー03</a></li>  -->\n\t\t\t\t\t\t\t\t<!-- <li class=\"header_megamenu_item\"><a href=\"/recruit/Interview04/\">社員インタビュー04</a></li> -->\n\t\t\t\t\t\t\t</ul>\n\t\t\t\t\t\t</div>\n          </li>\n\t\t\t\t\t<li class=\"header_gnav_item header_gnav_item_05 header_gnav_item_solo\"><a href=\"/recruit/detail/\">募集要項</a></li>\n\t\t\t\t</ul>\n\t\t\t</nav>\n      <p class=\"header_corporate\"><a href=\"http://www.takizumi.com/\" target=\"_blank\">コーポレートサイトはこちら</a></p>\n\t\t\t<div class=\"header_entry\">\n\t\t\t\t<p class=\"header_entry_btn\"><a href=\"/recruit/detail/#message\">エントリー</a></p>\n\t\t\t</div>\n      <p class=\"header_copy\">&copy; 2022 TAKIZUMI All Right Reserved.</p>\n\t\t</div><!-- /.header_wrap_inner -->\n\t</div><!-- /.header_wrap -->\n</header>\n\n\t\t\t<main id=\"main\">\n\t\t\t\t<div class=\"all_m_mv\"><div class=\"all_m_mv_wrap\">\n          <div class=\"all_m_mv_title\">\n\t\t\t\t\t\t<h1 class=\"all_m_mv_title_text\">福利厚生</h1>\n            <span class=\"all_m_mv_title_obj\"><img src=\"../images/welfare_txt_obj.svg\" alt=\"Welfare\"></span>\n\t\t\t\t\t</div>\n          <figure class=\"all_m_mv_img\"><img src=\"../images/welfare_img_mv.jpg\" alt=\"福利厚生画像\"></figure>\n          <div class=\"all_m_mv_scroll\">\n            <p class=\"all_m_mv_scroll_img\"><img src=\"../images/all_img_mv_scroll.svg\" alt=\"SCROLL\"></p>\n          </div>\n\t\t\t\t</div></div><!-- /.all_m_mv -->\n\n        <div class=\"all_m_intro\">\n          <div class=\"all_l_wrap\">\n            <h2 class=\"all_m_intro_title all_c_title_en\" data-anim=\"fadeup\">・welfare</h2>\n            <p class=\"all_m_intro_catch\" data-anim=\"fadeup\">社員の快適な生活を<br class=\"all_mi_sp\">支えるために</p>\n            <p class=\"all_m_intro_text\" data-anim=\"fadeup\">タキズミでは、年2回の賞与以外に業績賞与を設け、社員寮を完備し、家賃補助を手厚くするなど、独自の福利厚生制度を充実させています。お客様のお困りごとを解決するためには、まず社員が快適に、やりがいを持って働ける環境をつくることが大切である、という理念に基づいています。</p>\n          </div>\n        </div><!-- /.all_m_intro -->\n\n        <div class=\"all_l_wrap_l\">\n          <div class=\"welfare_contents\">\n            <div class=\"all_l_wrap_s\">\n              <div class=\"welfare_example\">\n                <div class=\"welfare_contents_header\" data-anim=\"fadeup\">\n                  <h3 class=\"welfare_contents_title\">タキズミの福利厚生</h3>\n                  <span class=\"welfare_contents_obj\"><img src=\"../images/welfare_txt_obj.svg\" alt=\"Welfare\"></span>\n                </div>\n                <ul class=\"welfare_example_list\">\n                  <li class=\"welfare_example_item\" data-anim=\"fadeup\">\n                    <figure class=\"welfare_example_item_img\"><img src=\"../images/welfare_icon_welfare01.svg\" width=\"100\" height=\"100\" alt=\"昇給年1回（11月）\"></figure>\n                    <p class=\"welfare_example_item_title\">昇給年1回（11月）</p>\n                    <p class=\"welfare_example_item_text\">年に1度、面談を行い、社内等級制度の基準にもとづいて昇給の金額を決定します。</p>\n                  </li>\n                  <li class=\"welfare_example_item\" data-anim=\"fadeup\">\n                    <figure class=\"welfare_example_item_img\"><img src=\"../images/welfare_icon_welfare02.svg\" width=\"100\" height=\"100\" alt=\"賞与年2回（5月・11月）\"></figure>\n                    <p class=\"welfare_example_item_title\">賞与年2回（5月・11月）</p>\n                    <p class=\"welfare_example_item_text\">会社業績に応じて、夏・冬の賞与とは別に業績賞与を支給する場合があります。</p>\n                  </li>\n                  <li class=\"welfare_example_item\" data-anim=\"fadeup\">\n                    <figure class=\"welfare_example_item_img\"><img src=\"../images/welfare_icon_welfare03.svg\" width=\"100\" height=\"100\" alt=\"業績賞与\"></figure>\n                    <p class=\"welfare_example_item_title\">業績賞与</p>\n                    <p class=\"welfare_example_item_text\">年に２回の賞与とは別に、8月にその年の利益に応じた業績賞与があります。</p>\n                  </li>\n                  <li class=\"welfare_example_item\" data-anim=\"fadeup\">\n                    <figure class=\"welfare_example_item_img\"><img src=\"../images/welfare_icon_welfare04.svg\" width=\"100\" height=\"100\" alt=\"年間休日\"></figure>\n                    <p class=\"welfare_example_item_title\">年間休日</p>\n                    <p class=\"welfare_example_item_text\">115日（令和3年9月16日～令和4年9月15日）土曜、日曜、祝日、年末年始以外に毎年有休を付与します。</p>\n                  </li>\n                  <li class=\"welfare_example_item\" data-anim=\"fadeup\">\n                    <figure class=\"welfare_example_item_img\"><img src=\"../images/welfare_icon_welfare05.svg\" width=\"100\" height=\"100\" alt=\"加入保険\"></figure>\n                    <p class=\"welfare_example_item_title\">加入保険</p>\n                    <p class=\"welfare_example_item_text\">雇用保険・労災保険・健康保険・厚生年金保険完備</p>\n                  </li>\n                  <li class=\"welfare_example_item\" data-anim=\"fadeup\">\n                    <figure class=\"welfare_example_item_img\"><img src=\"../images/welfare_icon_welfare06.svg\" width=\"100\" height=\"100\" alt=\"定期健康診断実施\"></figure>\n                    <p class=\"welfare_example_item_title\">定期健康診断実施</p>\n                    <p class=\"welfare_example_item_text\">年に1度、健康診断を実施します。</p>\n                  </li>\n                  <li class=\"welfare_example_item\" data-anim=\"fadeup\">\n                    <figure class=\"welfare_example_item_img\"><img src=\"../images/welfare_icon_welfare07.svg\" width=\"100\" height=\"100\" alt=\"社員寮完備\"></figure>\n                    <p class=\"welfare_example_item_title\">社員寮完備 <span class=\"_sub\">※家賃補助</span></p>\n                    <p class=\"welfare_example_item_text\">JR山手線巣鴨駅から徒歩5分。タキズミ本社事務所から徒歩20分。<span class=\"caption\">※家賃の半額を会社が負担致します。</span></p>\n                  </li>\n                  <li class=\"welfare_example_item\" data-anim=\"fadeup\">\n                    <figure class=\"welfare_example_item_img\"><img src=\"../images/welfare_icon_welfare08.svg\" width=\"100\" height=\"100\" alt=\"退職金制度\"></figure>\n                    <p class=\"welfare_example_item_title\">退職金制度</p>\n                    <p class=\"welfare_example_item_text\">企業型確定拠出年金制度有<br>（正社員のみ・退職金制度は入社3年目以降）</p>\n                  </li>\n                  <li class=\"welfare_example_item\" data-anim=\"fadeup\">\n                    <figure class=\"welfare_example_item_img\"><img src=\"../images/welfare_icon_welfare09.svg\" width=\"100\" height=\"100\" alt=\"各種手当\"></figure>\n                    <p class=\"welfare_example_item_title\">各種手当</p>\n                    <p class=\"welfare_example_item_text\">通勤手当(通勤定期代を実費支給)・残業手当・深夜手当・家族手当・役職手当・資格手当支給。</p>\n                  </li>\n                  <li class=\"welfare_example_item\" data-anim=\"fadeup\">\n                    <figure class=\"welfare_example_item_img\"><img src=\"../images/welfare_icon_welfare10.svg\" width=\"100\" height=\"100\" alt=\"資格取得報奨金制度有\"></figure>\n                    <p class=\"welfare_example_item_title\">資格取得報奨金制度有</p>\n                    <p class=\"welfare_example_item_text\">業務に関連すると会社が認めた資格については、取得にあたり報奨金を支給します。</p>\n                  </li>\n                  <li class=\"welfare_example_item\" data-anim=\"fadeup\">\n                    <figure class=\"welfare_example_item_img\"><img src=\"../images/welfare_icon_welfare11.svg\" width=\"100\" height=\"100\" alt=\"社員旅行実施\"></figure>\n                    <p class=\"welfare_example_item_title\">社員旅行実施</p>\n                    <p class=\"welfare_example_item_text\">2019年：神戸<br>2018年：沖縄<br>2017年：伊勢</p>\n                  </li>\n                  <li class=\"welfare_example_item\" data-anim=\"fadeup\">\n                    <figure class=\"welfare_example_item_img\"><img src=\"../images/welfare_icon_welfare12.svg\" width=\"100\" height=\"100\" alt=\"産前・産後、介護・育児休暇制度有\"></figure>\n                    <p class=\"welfare_example_item_title\">産前・産後、介護・育児<br>休暇制度有</p>\n                    <p class=\"welfare_example_item_text\"><span class=\"narrow\">復帰後も短時間勤務など育児と仕事が両立できるよう配慮しています。</span></p>\n                  </li>\n                  <li class=\"welfare_example_item\" data-anim=\"fadeup\">\n                    <figure class=\"welfare_example_item_img\"><img src=\"../images/welfare_icon_welfare13.svg\" width=\"100\" height=\"100\" alt=\"慶弔見舞金支給制度有\"></figure>\n                    <p class=\"welfare_example_item_title\">慶弔見舞金支給制度有</p>\n                    <p class=\"welfare_example_item_text\">復帰後も短時間勤務など育児と仕事が両立できるよう配慮しています。</p>\n                  </li>\n                  <li class=\"welfare_example_item\" data-anim=\"fadeup\">\n                    <figure class=\"welfare_example_item_img\"><img src=\"../images/welfare_icon_welfare14.svg\" width=\"100\" height=\"100\" alt=\"永年勤続表彰（金一封）\"></figure>\n                    <p class=\"welfare_example_item_title\">永年勤続表彰（金一封）</p>\n                    <div class=\"welfare_example_item_body\">\n                      <dl class=\"welfare_example_item_table\">\n                        <dt class=\"welfare_example_item_table_title\">満5年</dt>\n                        <dt class=\"welfare_example_item_table_text\">25,000円</dt>\n                        <dt class=\"welfare_example_item_table_title\">満10年</dt>\n                        <dt class=\"welfare_example_item_table_text\">50,000円</dt>\n                        <dt class=\"welfare_example_item_table_title\">満15年</dt>\n                        <dt class=\"welfare_example_item_table_text\">75,000円</dt>\n                      </dl>\n                      <dl class=\"welfare_example_item_table\">\n                        <dt class=\"welfare_example_item_table_title\">満20年</dt>\n                        <dt class=\"welfare_example_item_table_text\">100,000円</dt>\n                        <dt class=\"welfare_example_item_table_title\">満25年</dt>\n                        <dt class=\"welfare_example_item_table_text\">125,000円</dt>\n                        <dt class=\"welfare_example_item_table_title\">満30年</dt>\n                        <dt class=\"welfare_example_item_table_text\">150,000円</dt>\n                      </dl>\n                    </div>\n                    <p class=\"welfare_example_item_table_caption\">（以後は無し）</p>\n                  </li>\n                </ul>\n              </div><!-- /.welfare_example -->\n              <div class=\"welfare_number\" data-anim=\"fadeup\">\n                <div class=\"welfare_contents_header\">\n                  <h3 class=\"welfare_contents_title\" data-anim=\"fadeup\">数字で見るタキズミ</h3>\n                  <p class=\"welfare_contents_lead\">タキズミに関する情報をまとめたインフォグラフィックを紹介いたします。</p>\n                  <span class=\"welfare_contents_obj\"><img src=\"../images/welfare_txt_obj_number.svg\" alt=\"Number\"></span>\n                </div>\n                <ul class=\"welfare_number_list\">\n                  <li class=\"welfare_number_item\" data-anim=\"fadeup\"><img src=\"../images/welfare_img_number01.svg\" width=\"480\" height=\"303\" alt=\"年度別売上高・売上伸び率\"></li>\n                  <li class=\"welfare_number_item\" data-anim=\"fadeup\"><img src=\"../images/welfare_img_number02.svg\" width=\"480\" height=\"303\" alt=\"男女比率\"></li>\n                  <li class=\"welfare_number_item\" data-anim=\"fadeup\"><img src=\"../images/welfare_img_number03.svg\" width=\"480\" height=\"303\" alt=\"社員比率\"></li>\n                  <li class=\"welfare_number_item\" data-anim=\"fadeup\"><img src=\"../images/welfare_img_number04.svg\" width=\"480\" height=\"303\" alt=\"職種比率\"></li>\n                  <li class=\"welfare_number_item\" data-anim=\"fadeup\"><img src=\"../images/welfare_img_number05.svg\" width=\"480\" height=\"303\" alt=\"入社3年後の正社員定着率\"></li>\n                  <li class=\"welfare_number_item\" data-anim=\"fadeup\"><img src=\"../images/welfare_img_number06.svg\" width=\"480\" height=\"303\" alt=\"平均年齢\"></li>\n                  <li class=\"welfare_number_item\" data-anim=\"fadeup\"><img src=\"../images/welfare_img_number07.svg\" width=\"480\" height=\"303\" alt=\"趣味について\"></li>\n                  <li class=\"welfare_number_item\" data-anim=\"fadeup\"><img src=\"../images/welfare_img_number08.svg\" width=\"480\" height=\"303\" alt=\"仕事時の服装\"></li>\n                  <li class=\"welfare_number_item\" data-anim=\"fadeup\"><img src=\"../images/welfare_img_number09.svg\" width=\"480\" height=\"303\" alt=\"仕事のやりがいを感じるのはどんな時？\"></li>\n                  <li class=\"welfare_number_item\" data-anim=\"fadeup\"><img src=\"../images/welfare_img_number10.svg\" width=\"480\" height=\"303\" alt=\"タキズミの自慢\"></li>\n                  <li class=\"welfare_number_item\" data-anim=\"fadeup\"><img src=\"../images/welfare_img_number11.svg\" width=\"480\" height=\"303\" alt=\"入社を決めた理由\"></li>\n                  <li class=\"welfare_number_item\" data-anim=\"fadeup\"><img src=\"../images/welfare_img_number12.svg\" width=\"480\" height=\"303\" alt=\"休日の過ごし方\"></li>\n                </ul>\n              </div><!-- /.training_box 01 -->\n            </div><!-- /.training_contents_body -->\n          </div>\n        </div><!-- /.training_contents -->\n\n        <div class=\"all_m_breadcrumb\">\n          <div class=\"all_l_wrap\">\n            <ul class=\"all_m_breadcrumb_list\">\n              <li class=\"all_m_breadcrumb_item\"><a href=\"../\">トップ</a></li>\n              <li class=\"all_m_breadcrumb_item _current\">福利厚生</li>\n            </ul>\n          </div>\n        </div><!-- /.all_m_breadcrumb -->\n\t\t\t</main><!-- /#main -->\n\n\t\t\t<div