/shimadzu/favicons/apple-touch-icon-114x114.png\">\r\n<link rel=\"apple-touch-icon\" sizes=\"120x120\" href=\"../profiles/shimadzu/themes/shimadzu/favicons/apple-touch-icon-120x120.png\">\r\n<link rel=\"apple-touch-icon\" sizes=\"144x144\" href=\"../profiles/shimadzu/themes/shimadzu/favicons/apple-touch-icon-144x144.png\">\r\n<link rel=\"apple-touch-icon\" sizes=\"152x152\" href=\"../profiles/shimadzu/themes/shimadzu/favicons/apple-touch-icon-152x152.png\">\r\n<link rel=\"apple-touch-icon\" sizes=\"180x180\" href=\"../profiles/shimadzu/themes/shimadzu/favicons/apple-touch-icon-180x180.png\">\r\n<meta name=\"apple-mobile-web-app-capable\" content=\"yes\">\r\n<meta name=\"apple-mobile-web-app-status-bar-style\" content=\"black-translucent\">\r\n<meta name=\"apple-mobile-web-app-title\">\r\n<link rel=\"icon\" type=\"image/png\" sizes=\"228x228\" href=\"../profiles/shimadzu/themes/shimadzu/favicons/coast-228x228.png\">\r\n<link rel=\"yandex-tableau-widget\" href=\"../profiles/shimadzu/themes/shimadzu/favicons/yandex-browser-manifest.json\">\r\n<meta name=\"msapplication-TileColor\" content=\"#ffffff\">\r\n<meta name=\"msapplication-TileImage\" content=\"../profiles/shimadzu/themes/shimadzu/favicons/mstile-144x144.png\">\r\n<meta name=\"msapplication-config\" content=\"../profiles/shimadzu/themes/shimadzu/favicons/browserconfig.xml\">\r\n<link rel=\"icon\" type=\"image/png\" sizes=\"32x32\" href=\"../profiles/shimadzu/themes/shimadzu/favicons/favicon-32x32.png\">\r\n<link rel=\"icon\" type=\"image/png\" sizes=\"192x192\" href=\"../profiles/shimadzu/themes/shimadzu/favicons/android-chrome-192x192.png\">\r\n<link rel=\"icon\" type=\"image/png\" sizes=\"16x16\" href=\"../profiles/shimadzu/themes/shimadzu/favicons/favicon-16x16.png\">\r\n<link rel=\"apple-touch-startup-image\" media=\"(device-width: 320px) and (device-heig) 480px) and (-webkit-device-pixel-ratio: 1)\" href=\"../profiles/shimadzu/themes/shimadzu/favicons/apple-touch-startup-image-320x460.png\">\r\n<link rel=\