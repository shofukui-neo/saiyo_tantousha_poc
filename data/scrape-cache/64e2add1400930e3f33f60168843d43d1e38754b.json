ut.html\" />\r\n<meta property=\"og:image\" content=\"\" />\r\n<meta property=\"og:site_name\" content=\"宇式エンジニアリング株式会社\" />\r\n\r\n<meta name=\"twitter:card\" content=\"summary\" />\r\n</head>\r\n\r\n<body id=\"c_6\" class=\"base\">\r\n<!-- Google Tag Manager (noscript) -->\r\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-WKDMRMZ\"\r\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\r\n<!-- End Google Tag Manager (noscript) -->\r\n<div id=\"wrp\">\r\n<div id=\"wrp_cate\">\r\n<div id=\"main\">\r\n<div id=\"wrp_hdr\">\r\n<header id=\"hdr\">\r\n<p class=\"logo\"><a href=\"../\"><span class=\"logo_img\"></span></a></p>\r\n<ul class=\"hdr_nav\">\r\n<li class=\"nav_list\"><a href=\"../news_topics\">ニュース</a></li>\r\n<li class=\"nav_list has-child\"><a href=\"../service\">事業案内</a>\r\n<div class=\"has-child-content\">\r\n<div class=\"ttl\">\r\n<p><span class=\"en\">SERVICE</span>事業案内</p>\r\n</div>\r\n<ul class=\"sub-nav\"></ul>\r\n</div></li>\r\n<li class=\"nav_list has-child\"><a href=\"../company\">会社案内</a>\r\n<div class=\"has-child-content\">\r\n<div class=\"ttl\">\r\n<p><span class=\"en\">COMPANY</span>会社案内</p>\r\n</div>\r\n<ul class=\"sub-nav\"><li><a href=\"../company/message.html\"><span>代表メッセージ</span></a></li>\n<li><a href=\"../company/philosophy.html\"><span>会社概要</span></a></li>\n<li><a href=\"../company/history.html\"><span>歩み</span></a></li>\n</ul>\r\n</div></li>\r\n<li class=\"nav_list\"><a href=\"../sustainability\">SDGsの取り組み</a></li>\r\n<li class=\"nav_list has-child\"><a href=\"../recruit\">採用情報</a>\r\n<div class=\"has-child-content\">\r\n<div class=\"ttl\">\r\n<p><span class=\"en\">RECRUIT</span>採用情報</p>\r\n</div>\r\n<ul class=\"sub-nav\"><li><a href=\"../recruit/about.html\"><span>働く環境を知る</span></a></li>\n<li><a href=\"../recruit/interview/\"><span>社員インタビュー</span></a></li>\n<li><a href=\"../recruit/Job/\"><span>募集要項</span></a></li>\n<li><a href=\"../recruit/entry/\"><span>採用エントリー</span></a></li>\n</ul>\r\n</div></li>\r\n<li class=\"contact\"><a href=\"../contact\"><img src=\"../_cmn/icon_mail.svg\" alt=\"\"/><span>お問い合わせ</span></a></li>\r\n</ul>\r\n<div id=\"btn_menu\" class=\"menu_trigger\">\r\n<a href=\"javascript:void(0);\">\r\n<span class=\"brdr\"></span>\r\n<span class=\"brdr\"></span>\r\n<span class=\"brdr\"></span>\r\n<span class=\"txt\">MENU</span>\r\n</a>\r\n</div><!-- /btn_menu -->\r\n</header>\r\n<nav id=\"sp_menu\">\r\n<div class=\"toggle_menu\">\r\n<div class=\"inr_toggle_menu\">\r\n<ul><li><a href=\"../\">トップページ</a></li>\n<li><a href=\"../company/\">会社案内</a><ul class=\"sub invisible sub_cat_level2\" id=\"menu_3\">\n<li><a href=\"../company/\">会社案内</a></li>\n<li><a href=\"../company/message.html\">代表メッセージ</a></li>\n<li><a href=\"../company/philosophy.html\">会社概要</a></li>\n<li><a href=\"../company/history.html\">歩み</a></li>\n</ul>\n</li>\n<li><a href=\"../service/\">事業案内</a></li>\n<li><a href=\"../sustainability/\">SDGsの取り組み</a></li>\n<li><a href=\"../recruit/\">採用情報</a><ul class=\"sub sub-selected-cat sub_cat_level2\" id=\"menu_6\">\n<li><a href=\"../recruit/\">採用情報</a></li>\n<li><a href=\"../recruit/about.html\">働く環境を知る</a></li>\n<li><a href=\"../recruit/interview/\">社員インタビュー</a><ul class=\"sub invisible sub_cat_level3 grand_sub\" id=\"menu_12\">\n<li><a href=\"../recruit/interview/\">社員インタビュー</a></li>\n<li><a href=\"../recruit/interview/sales.html\">インタビュー(営業)</a></li>\n<li><a href=\"../recruit/interview/customer.html\">インタビュー(CS）</a></li>\n<li><a href=\"../recruit/interview/system.html\">インタビュー(SE）</a></li>\n</ul>\n</li>\n<li><a href=\"../recruit/Job/\">募集要項</a><ul class=\"sub invisible sub_cat_level3 grand_sub\" id=\"menu_11\">\n<li><a href=\"../recruit/Job/\">募集要項(営業)</a></li>\n<li><a href=\"../recruit/Job/customer.html\">募集要項(CE)</a></li>\n<li><a href=\"../recruit/Job/system.html\">募集要項(SE)</a></li>\n</ul>\n</li>\n<li><a href=\"../recruit/entry/\">採用エントリー</a></li>\n</ul>\n</li>\n<li><a href=\"../contact/\">お問い合わせ</a></li>\n<li><a href=\"../privacypolicy/\">個人情報保護方針</a></li>\n<li><a href=\"../copyright/\">著作権とリンク</a></li>\n</ul>\r\n</div>\r\n</div>\r\n</nav><!-- /sp_menu -->\r\n</div><!-- /wrp_hdr -->\r\n\r\n<div class=\"cate-head\">\r\n<h1>採用情報</h1>\r\n<div id=\"path\"><a href=\"../\">トップページ</a> &gt; <a href=\"../recruit/\">採用情報</a> &gt; 働く環境を知る</div>\r\n</div>\r\n</div><!-- /main -->\r\n\r\n<div class=\"cate-img\"><a name=\"fctop\"></a></div>\r\n</div><!-- /wrp_cate -->\r\n\r\n<div id=\"wrp_cnt\">\r\n<div id=\"cnt\">\r\n\r\n<div id=\"wrp_maincnt\">\r\n<article id=\"maincontent\">\r\n<table class=\"ttl\" width=\"100%\" border=\"0\" summary=\"\"><tbody><tr><td><p class=\"lead en\"><span style=\"font-size: 4rem; font-family: &quot;Noto Sans JP&quot;, sans-serif;\">働く環境を知る</span></p><p><span style=\"color: #005ec8; font-family: Oswald, sans-serif; font-size: 20px; font-weight: 700;\">FEATURE</span></p></td></tr></tbody></table><br /><table class=\"cnt_block shadow\" style=\"width: 100%; background: #ffffff;\" summary=\"\" width=\"100%\" cellspacing=\"0\" border=\"0\"><tbody><tr><td><table class=\"col2\" summary=\"\"><tbody><tr><td class=\"col2_l\" style=\"width: 45%;\"><img src=\"../images/17.jpg\" alt=\"未経験からプロへ。安心の教育体制\" style=\"max-width: 100%; width: 100%; height: auto;\" width=\"0\" height=\"0\" /></td><td class=\"col2_r\"><table summary=\"テーブル\" cellpadding=\"0\" style=\"border-spacing: 0px; border-width: 0px; border-collapse: separate; width: 100%;\" width=\"100%\"><tbody><tr><td style=\"text-align: right; vertical-align: middle;\"><p class=\"lead en\"><span style=\"color: #005ec8;\">POINT&nbsp;&nbsp;</span></p></td><td style=\"width: 20%; text-align: right; vertical-align: middle;\"><span class=\"en\" style=\"color: #005ec8;font-size:8rem;line-height:1;\">01</span></td></tr></tbody></table><br /><h3 style=\"line-height: 1.3;\">未経験からプロへ。安心の教育体制</h3>「ITは初めて」という方もご安心ください。まずはeラーニングで基礎を学び、現場では先輩とOJTで着実にスキルを習得できます。社内は若手メンバーが多く、何でも相談できる活気のある雰囲気。チーム全体であなたの成長をバックアップします。</td></tr></tbody></table></td></tr></tbody></table><br /><br /><table class=\"cnt_block shadow\" style=\"width: 100%; background: #ffffff;\" summary=\"\" width=\"100%\" cellspacing=\"0\" border=\"0\"><tbody><tr><td><table class=\"col2\" summary=\"\"><tbody><tr><td class=\"col2_l\" style=\"width: 45%;\"><img src=\"../images/22.jpg\" alt=\"地元・静岡を支える、誇れる仕事\" style=\"max-width: 100%; width: 100%; height: auto;\" /></td><td class=\"col2_r\"><table summary=\"テーブル\" cellpadding=\"0\" style=\"border-spacing: 0px; border-width: 0px; border-collapse: separate; width: 100%;\" width=\"100%\"><tbody><tr><td style=\"text-align: right; vertical-align: middle;\"><p class=\"lead en\"><span style=\"color: #005ec8;\">POINT&nbsp;&nbsp;</span></p></td><td style=\"width: 20%; text-align: right; vertical-align: middle;\"><span class=\"en\" style=\"color: #005ec8;font-size:8rem;line-height:1;\">02</span></td></tr></tbody></table><br /><h3 style=\"line-height: 1.3;\">地元・静岡を支える、誇れる仕事</h3>金融、製造、建築といった県内を代表する大手企業のほか、NPO法人や福祉施設まで、地域に根ざした多様なプロジェクトがあなたの舞台です。地元の暮らしを裏側から支える、ITエンジニアならではのやりがいを実感できる環境です。</td></tr></tbody></table></td></tr></tbody></table><br /><br /><table class=\"cnt_block shadow\" style=\"width: 100%; background: #ffffff;\" summary=\"\" width=\"100%\" cellspacing=\"0\" border=\"0\"><tbody><tr><td><table class=\"col2\" summary=\"\"><tbody><tr><td class=\"col2_l\" style=\"width: 45%;\"><img src=\"../images/21.jpg\" alt=\"富士通パートナーとしての信頼\" style=\"max-width: 100%; width: 100%; height: auto;\" /></td><td class=\"col2_r\"><table summary=\"テーブル\" cellpadding=\"0\" style=\"border-spacing: 0px; border-width: 0px; border-collapse: separate; width: 100%;\" width=\"100%\"><tbody><tr><td style=\"text-align: right; vertical-align: middle;\"><p class=\"lead en\"><span style=\"color: #005ec8;\">POINT&nbsp;&nbsp;</span></p></td><td style=\"width: 20%; text-align: right; vertical-align: middle;\"><span class=\"en\" style=\"color: #005ec8;font-size:8rem;line-height:1;\">03</span></td></tr></tbody></table><br /><h3 style=\"line-height: 1.3;\">富士通パートナーとしての信頼</h3>当社は富士通の認定パートナー限定の高度な研修も受講可能。安定した経営基盤と最新の環境で、エンジニアとしての価値を確実に高めていけます。</td></tr></tbody></table></td></tr></tbody></table><br /><br /><table class=\"wideBg\" summary=\"\"><tbody><tr><td><div class=\"wide_wrap bg_l-gray\"><br /><table class=\"ttl\" width=\"100%\" border=\"0\" summary=\"\"><tbody><tr><td style=\"text-align: center;\"><p class=\"lead en\"><span style=\"font-size: 4rem; font-family: &quot;Noto Sans JP&quot;, sans-serif;\">福利厚生</span></p><p><span style=\"color: #005ec8; font-family: Oswald, sans-serif; font-size: 20px; font-weight: 700;\">WELFARE</span></p><br /><p>社員の方が働きやすいように、各種制度や様々な保障を用意しています。</p></td></tr></tbody></table><table class=\"col3\" summary=\"\"><tbody><tr><td class=\"col3_l\"><table summary=\"テーブル\" cellpadding=\"30\" style=\"border-spacing: 0px; border-width: 0px; border-collapse: separate; width: 100%; background-color: #ffffff;\" width=\"100%\"><tbody><tr><td><table summary=\"テーブル\" cellpadding=\"0\" style=\" border-spacing:0pt; border-width:0px; border-collapse:separate;  width:100%;\"><tbody><tr><td rowspan=\"1\" style=\"width: 25%;\">&nbsp;</td><td rowspan=\"1\"><table summary=\"テーブル\" cellpadding=\"0\" style=\"border-spacing: 0px; border-width: 0px; border-collapse: separate; width: 100%;\" class=\"trm_img_maru\" width=\"100%\"><tbody><tr><td><img src=\"../images/23.jpg\" alt=\"加入保険あり\" style=\"max-width: 100%; width: 100%; height: auto;\" width=\"0\" height=\"0\" /></td></tr></tbody></table></td><td style=\"width: 25%;\">&nbsp;</td></tr></tbody></table><br /><h5 align=\"center\">加入保険あり</h5><p>万一、病気・ケガ等にも安心して働けるようにする加入保険（雇用、労災、健康、厚生年金）を設けています。</p></td></tr></tbody></table></td><td class=\"col3_m\"><table summary=\"テーブル\" cellpadding=\"30\" style=\"border-spacing: 0px; border-width: 0px; border-collapse: separate; width: 100%; background-color: #ffffff;\" width=\"100%\"><tbody><tr><td><table summary=\"テーブル\" cellpadding=\"0\" style=\" border-spacing:0pt; border-width:0px; border-collapse:separate;  width:100%;\"><tbody><tr><td rowspan=\"1\" style=\"width: 25%;\">&nbsp;</td><td rowspan=\"1\"><table summary=\"テーブル\" cellpadding=\"0\" style=\"border-spacing: 0px; border-width: 0px; border-collapse: separate; width: 100%;\" class=\"trm_img_maru\" width=\"100%\"><tbody><tr><td><img src=\"../images/28.jpg\" alt=\"社員寮\" style=\"max-width: 100%; width: 100%; height: auto;\" /></td></tr></tbody></table></td><td style=\"width: 25%;\">&nbsp;</td></tr></tbody></table><br /><h5 align=\"center\">社員寮</h5><p>社員やその家族のために家賃の負担が軽減、住環境サポートして社員寮の制度があります。</p></td></tr></tbody></table></td><td class=\"col3_r\"><table summary=\"テーブル\" cellpadding=\"30\" style=\"border-spacing: 0px; border-width: 0px; border-collapse: separate; width: 100%; background-color: #ffffff;\" width=\"100%\"><tbody><tr><td><table summary=\"テーブル\" cellpadding=\"0\" style=\" border-spacing:0pt; border-width:0px; border-collapse:separate;  width:100%;\"><tbody><tr><td rowspan=\"1\" style=\"width: 25%;\">&nbsp;</td><td rowspan=\"1\"><table summary=\"テーブル\" cellpadding=\"0\" style=\"border-spacing: 0px; border-width: 0px; border-collapse: separate; width: 100%;\" class=\"trm_img_maru\" width=\"100%\"><tbody><tr><td><img src=\"../images/26.jpg\" alt=\"感染症等一部費用負担\" style=\"max-width: 100%; width: 100%; height: auto;\" /></td></tr></tbody></table></td><td style=\"width: 25%;\">&nbsp;</td></tr></tbody></table><br /><h5 align=\"center\">感染症等一部費用負担</h5><p>安心して働けるよう、インフルエンザ等の感染症対策として予防接種の費用の一部を負担します。</p><h5></h5></td></tr></tbody></table></td></tr></tbody></table><br /><table class=\"col3\" summary=\"\"><tbody><tr><td class=\"col3_l\"><table summary=\"テーブル\" cellpadding=\"30\" style=\"border-spacing: 0px; border-width: 0px; border-collapse: separate; width: 100%; background-color: #ffffff;\" width=\"100%\"><tbody><tr><td><table summary=\"テーブル\" cellpadding=\"0\" style=\" border-spacing:0pt; border-width:0px; border-collapse:separate;  width:100%;\"><tbody><tr><td rowspan=\"1\" style=\"width: 25%;\">&nbsp;</td><td rowspan=\"1\"><table summary=\"テーブル\" cellpadding=\"0\" style=\"border-spacing: 0px; border-width: 0px; border-collapse: separate; width: 100%;\" class=\"trm_img_maru\" width=\"100%\"><tbody><tr><td><img src=\"../images/24.jpg\" alt=\"ドリンクコーナー\" style=\"max-width: 100%; width: 100%; height: auto;\" /></td></tr></tbody></table></td><td style=\"width: 25%;\">&nbsp;</td></tr></tbody></table><br /><h5 align=\"center\">ドリンクコーナー</h5><p>社員のリフレッシュ、コミュニケーション活性化にウォーターサーバー、お茶、コーヒーを常備しています。</p><h5></h5></td></tr></tbody></table></td><td class=\"col3_m\"><table summary=\"テーブル\" cellpadding=\"30\" style=\"border-spacing: 0px; border-width: 0px; border-collapse: separate; width: 100%; background-color: #ffffff;\" width=\"100%\"><tbody><tr><td><table summary=\"テーブル\" cellpadding=\"0\" style=\" border-spacing:0pt; border-width:0px; border-collapse:separate;  width:100%;\"><tbody><tr><td rowspan=\"1\" style=\"width: 25%;\">&nbsp;</td><td rowspan=\"1\"><table summary=\"テーブル\" cellpadding=\"0\" style=\"border-spacing: 0px; border-width: 0px; border-collapse: separate; width: 100%;\" class=\"trm_img_maru\" width=\"100%\"><tbody><tr><td><img src=\"../images/25.jpg\" alt=\"健康診断\" style=\"max-width: 100%; width: 100%; height: auto;\" /></td></tr></tbody></table></td><td style=\"width: 25%;\">&nbsp;</td></tr></tbody></table><br /><h5 align=\"center\">健康診断</h5><p>安心して働ける環境づくりや健康リスクの早期発見、治療につなげられるよう、会社負担で健康診断を実施しています。</p><h5></h5></td></tr></tbody></table></td><td class=\"col3_r\"><table summary=\"テーブル\" cellpadding=\"30\" style=\"border-spacing: 0px; border-width: 0px; border-collapse: separate; width: 100%; background-color: #ffffff;\" width=\"100%\"><tbody><tr><td><table summary=\"テーブル\" cellpadding=\"0\" style=\" border-spacing:0pt; border-width:0px; border-collapse:separate;  width:100%;\"><tbody><tr><td rowspan=\"1\" style=\"width: 25%;\">&nbsp;</td><td rowspan=\"1\"><table summary=\"テーブル\" cellpadding=\"0\" style=\"border-spacing: 0px; border-width: 0px; border-collapse: separate; width: 100%;\" class=\"trm_img_maru\" width=\"100%\"><tbody><tr><td><img src=\"../images/29.jpg\" alt=\"新人でも有給休暇付与\" style=\"max-width: 100%; width: 100%; height: auto;\" /></td></tr></tbody></table></td><td style=\"width: 25%;\">&nbsp;</td></tr></tbody></table><br /><h5 align=\"center\">新人でも有給休暇付与</h5><p>一般的には入社日から6ヶ月後に初めて10日付与されますが、当社は入社後すぐに付与する制度を設けています。</p><h5></h5></td></tr></tbody></table></td></tr></tbody></table><br /></div></td></tr></tbody></table><br /><br /><br /><h3 class=\"underline\">その他の採用情報</h3><table class=\"col3 nav_block\" summary=\"\"><tbody><tr><td class=\"col3_l\"><a href=\"../recruit/#data\" target=\"_self\"><img src=\"../images/18.jpg\" alt=\"数字で見る\" style=\"max-width: 100%; width: 100%; height: auto;\" width=\"0\" height=\"0\" /><br /><p class=\"ttl\">数字で見る</p></a></td><td class=\"col3_m\"><a href=\"../recruit/interview/\" target=\"_self\"><img src=\"../images/16.jpg\" alt=\"社員インタビュー\" style=\"max-width: 100%; width: 100%; height: auto;\" width=\"0\" height=\"0\" /><br /><p class=\"ttl\">社員インタビュー</p></a></td><td class=\"col3_r\"><a href=\"../recruit/Job/\" target=\"_self\"><img src=\"../images/20.jpg\" alt=\"募集要項\" style=\"max-width: 100%; width: 100%; height: auto;\" width=\"0\" height=\"0\" /><br /><p class=\"ttl\">募集要項</p></a></td></tr></tbody></table><br /><p><br /></p><table class=\"cnt_block shadow\" style=\"width: 100%; background: #ffffff;\" summary=\"\" width=\"100%\" cellspacing=\"0\" border=\"0\"><tbody><tr><td><table class=\"col2\" summary=\"\"><tbody><tr><td class=\"col2_l\" style=\"width: 55%; vertical-align: middle;\"><h3 style=\"line-height: 1.3;\">採用エントリー・お問い合わせ</h3>まずは、お気軽にお問い合わせください。</td><td class=\"col2_r\" style=\"text-align: right;\"><br /><table class=\"btn light-blue\" style=\"width: 100%; border-width: 0px; border-spacing: 0px;\" width=\"100%\" cellspacing=\"0\" border=\"0\" summary=\"\"><tbody><tr><td><a href=\"../recruit/entry/\" target=\"_self\">採用エントリー</a></td></tr></tbody></table><br /></td></tr></tbody></table></td></tr></tbod