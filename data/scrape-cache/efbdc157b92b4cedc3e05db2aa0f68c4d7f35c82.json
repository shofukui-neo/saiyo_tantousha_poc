       <span class=\"total --w-86\">\n                                        <span class=\"num f-en\">1</span>\n                                        <span class=\"text f-jp\">社</span>\n                                    </span>\n                                </div>\n                            </li>\n                            <li class=\"item js-cue --a1\">\n                                <span class=\"title f-jp --line\">プレスパートの全用具を<br>製造できる同業他社</span>\n                                <div class=\"wrap\">\n                                    <span class=\"sub f-jp\">世界</span>\n                                    <span class=\"total --w-86\">\n                                        <span class=\"num f-en\">2</span>\n                                        <span class=\"text f-jp\">社</span>\n                                    </span>\n                                </div>\n                            </li>\n                            <li class=\"item js-cue --a1\">\n                                <span class=\"title f-jp --line\">売上高<span class=\"s\">（2025年3月期）</span></span>\n                                <div class=\"wrap\">\n                                    <span class=\"total --w-214\">\n                                        <span class=\"num f-en\">139</span>\n                                        <span class=\"text f-jp\">億円</span>\n                                    </span>\n                                </div>\n                            </li>\n                            <li class=\"item js-cue --a1\">\n                                <span class=\"title f-jp --line\">海外売上高比率<span class=\"s\">（2025年3月期）</span></span>\n                                <div class=\"wrap\">\n                                    <span class=\"total --w-214\">\n                                        <span class=\"num f-en\">60.5</span>\n                                        <span class=\"text f-jp\">%</span>\n                                    </span>