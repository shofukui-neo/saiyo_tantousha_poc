{"url":"https://www.inahara.co.jp/contact/","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n\n<head>\n  <meta http-equiv=\"X-UA-Compatible\" content=\"IE=Edge\">\n  <meta charset=\"utf-8\">\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n  <meta name=\"format-detection\" content=\"telephone=no\">\n  <!-- SEO対策 -->\n  <meta name=\"description\" content=\"株式会社イナハラのお問い合わせページです。100社以上の仕入先から、お客様に最適な機器を組み合わせてご提案いたします。お気軽にご相談ください。\">\n  <title>お問い合わせ｜オフィスのあらゆるお困りごとを解決し、働きやすいオフィス空間を創造するイナハラ</title>\n  <!-- OGP（SNS用）設定 -->\n  <meta property=\"og:title\" content=\"サイトタイトル\">\n  <meta property=\"og:type\" content=\"website\">\n  <meta property=\"og:description\" content=\"ここにディスクリプションを記述\">\n  <meta property=\"og:image\" content=\"画像のURL\">\n  <!-- ファビコン -->\n  <link rel=\"icon\" href=\"画像のURL\">\n  <!-- スマホ用ファビコン 180x180 -->\n  <link rel=\"apple-touch-icon\" sizes=\"180x180\" href=\"画像のURL\">\n  <!-- FontAwesome -->\n  <link href=\"https://use.fontawesome.com/releases/v5.6.1/css/all.css\" rel=\"stylesheet\">\n  <!-- スタイルシート -->\n  <link rel=\"stylesheet\" href=\"../assets/css/style.css\">\n</head>\n\n<body>\n  <div id=\"wrapper\">\n    <header role=\"banner\" class=\"l-flex-wrap l-flex-jc-sb l-flex-ai-center p30\">\n      <h1 class=\"header-logo\">\n        <a href=\"/index.html\">\n          <img src=\"../assets/img/common/logo.png\" alt=\"株式会社イナハラ\">\n        </a>\n      </h1>\n      <div class=\"nav-btn\">\n        <span></span>\n        <span></span>\n        <span></span>\n      </div>\n      <nav role=\"navigation\">\n        <!-- 中身はtemplate.js -->\n      </nav>\n    </header>\n\n    <main role=\"main\">\n      <div class=\"content-mainvisual\">\n        <div class=\"l-container-lg mt25\">\n          <ul class=\"pankuzu\">\n            <li>\n              <a href=\"/\">\n                HOME\n              </a>\n            </li>\n            <li>\n              CONTACT\n            </li>\n          </ul>\n          <!-- /.pankuzu -->\n          <h2 class=\"main-ttl l-section-mid\" data-text=\"お問い合わせ\">\n            CONTACT\n          </h2>\n        </div>\n        <!-- /.l-container-lg -->\n      </div>\n      <!-- /.mainvisual -->\n      <div class=\"l-container-lg\">\n        <p class=\"mb30\">\n          必要事項をご記入の上、「入力内容の確認」ボタンを押してください。\n          <br>\n          入力内容の確認画面の表示後、入力内容に間違いがなければ、「送信」ボタンを押してください。\n          <br>\n          後日、当社よりご連絡を差し上げます。\n          <br>\n          一週間たっても、当社からの連絡がない場合は、メールがこちらに届いていない場合が考えられますので、その場合は大変お手数ですが、電話／078-231-4088 までご連絡をいただきますよう、お願い申し上げます。\n        </p>\n        <p class=\"w-red\">\n          ＜入力いただく際の注意事項＞\n        </p>\n        <ul class=\"mb50\">\n          <li class=\"list-astarisk w-red\">\n            ●は必須入力です。\n          </li>\n          <li class=\"list-astarisk w-red\">\n            個人情報の取扱いについては<a class=\"red\" href=\"/privacy.html\">プライバシーポリシー</a>をご確認ください。\n          </li>\n        </ul>\n\n        <hr>\n\n        <div class=\"l-section-min\">\n          <div class=\"l-container-min margin-none\">\n            <form class=\"form-getModule(inquiry)\" action=\"./mail.php\" method=\"post\">\n              <div class=\"errors\"></div>\n              <table class=\"table-form mb80\">\n                <tr>\n                  <th class=\"required\">会社名</th>\n                  <td>\n                    <input type=\"text\" name=\"company\" class=\"inputs\" placeholder=\"例：株式会社イナハラ\">\n                  </td>\n                </tr>\n                <tr>\n                  <th class=\"required\">氏名</th>\n                  <td>\n                    <input type=\"text\" name=\"name\" class=\"inputs\" placeholder=\"例：イナハラ 太郎\">\n                  </td>\n                </tr>\n                <tr>\n                  <th class=\"required\">電話番号</th>\n                  <td>\n                    <input type=\"text\" name=\"tel\" class=\"inputs\" placeholder=\"例：0120-123-4567\">\n                  </td>\n                </tr>\n                <tr>\n                  <th>ご住所</th>\n                  <td>\n                    <input type=\"text\" name=\"address\" class=\"inputs\" placeholder=\"例：兵庫県神戸市中央区\">\n                  </td>\n                </tr>\n                <tr>\n                  <th class=\"required\">メールアドレス</th>\n                  <td>\n                    <input type=\"text\" name=\"email\" class=\"inputs\" placeholder=\"例：mail@inahara.co.jp\">\n                  </td>\n                </tr>\n                <tr>\n                  <th class=\"required\">お問い合わせ内容</th>\n                  <td>\n                    <textarea name=\"content\" cols=\"50\" rows=\"7\" class=\"inputs\"></textarea>\n                  </td>\n                </tr>\n              </table>\n              <div class=\"btn-submit mb100\">\n                <input type=\"submit\" name=\"confirm\" value=\"プライバシーポリシーに同意して確認\">\n              </div>\n            </form>\n          </div>\n          <!-- /.l-container-min -->\n        </div>\n        <!-- /.l-section-min -->\n      </div>\n      <!-- l-container-lg -->\n    </main>\n\n    <footer role=\"contentinfo\" class=\"pt80 pb20\">\n      <!-- 中身はtemplate.js -->\n    </footer>\n  </div>\n  <!-- /#wrapper -->\n  <script src=\"https://ajax.googleapis.com/ajax/libs/jquery/1.12.4/jquery.min.js\"></script>\n  <script src=\"../assets/js/template.js\"></script>\n  <script src=\"../assets/js/common.js\"></script>\n  <!-- アナリティクス　ここから -->\n  <!-- Global site tag (gtag.js) - Google Analytics -->\n  <script async src=\"https://www.googletagmanager.com/gtag/js?id=UA-149301540-1\"></script>\n  <script>\n    window.dataLayer = window.dataLayer || [];\n    function gtag(){dataLayer.push(arguments);}\n    gtag('js', new Date());\n\n    gtag('config', 'UA-149301540-1');\n  </script>\n  <!-- アナリティクス ここまで-->\n</body>\n\n</html>\n","finalUrl":"https://www.inahara.co.jp/contact/","rendered":false,"_cachedAt":"2026-06-22T18:08:59.600Z"}