{"url":"http://www.k-kaneko.com/contact/","html":"<!doctype html>\n<html lang=\"ja\">\n\n<head>\n  <meta charset=\"utf-8\">\n  <!-- Google tag (gtag.js) -->\n  <script async src=\"https://www.googletagmanager.com/gtag/js?id=G-YQW1MG8B7L\"></script>\n  <script>\n    window.dataLayer = window.dataLayer || [];\n    function gtag(){dataLayer.push(arguments);}\n    gtag('js', new Date());\n\n    gtag('config', 'G-YQW1MG8B7L');\n  </script>\n  <script src=\"https://www.google.com/recaptcha/enterprise.js?render=6Leu00IsAAAAAKyl0hSovvJX9s9zCXlKn9UQGcuI\"></script>\n  <meta name=\"viewport\" content=\"width=device-width\">\n  <title>お問い合わせ｜株式会社兼子</title>\n  <link href=\"../assets/js/slick/slick.css\" rel=\"stylesheet\">\n  <link href=\"../assets/js/slick/slick-theme.css\" rel=\"stylesheet\">\n  <link href=\"../assets/css/style.css\" rel=\"stylesheet\">\n  <link href=\"../assets/img/favicon.png\" rel=\"icon\">\n  <script>console.log('load');</script><!-- transition fix -->\n</head>\n\n<body class=\"page contact\">\n  <div class=\"wrapper\">\n\n    <div class=\"header\">\n      <div class=\"title fade\">\n        <a href=\"../\">\n          <img src=\"../assets/img/logo_kaneko.png\" alt=\"株式会社兼子\">\n        </a>\n      </div>\n  \n      <div class=\"gnavi\">\n        <ul>\n          <li><a href=\"../#services\">事業案内</a></li>\n          <li><a href=\"../company/strength/\">強み</a></li>\n          <li><a href=\"../cases/\">事例紹介</a></li>\n          <li><a href=\"../company/profile/\">会社案内</a></li>\n          <li><a href=\"../sustainability/\">サステナビリティ</a></li>\n          <li><a href=\"https://recruit.kaneko-hd.co.jp/\" target=\"_blank\">採用情報</a></li>\n          <li><a href=\"../contact/\" class=\"button\"><span class=\"contact\">お問い合わせ</span></a></li>\n        </ul>\n      </div>\n    </div>\n\n    <div class=\"gnavi-button\">\n      <span></span>\n    </div>\n\n    <div class=\"main\">\n      <h1 class=\"page-header fade\">\n        <span class=\"jp type\">お問い合わせ</span>\n        <span class=\"en type\">CONTACT</span>\n      </h1>\n\n      <section class=\"fade\">\n        <div class=\"whitebox\">\n          <div class=\"flex center content\">\n            <div class=\"w45\">\n              <p>\n                以下のフォームよりお問い合わせを承っています。<br class=\"pc\">お急ぎの方は、直接お電話くださいますようお願いします。\n              </p>\n            </div>\n            <div class=\"w50\">\n              <div class=\"tel-box\">\n                <span class=\"tel\">TEL：054-369-1178</span><br>\n                受付時間 /平日8:00〜17:00\n              </div>\n            </div>\n          </div>\n          <div class=\"content w90\">\n            <dl class=\"flex wrap table form\" id=\"contactForm\">\n              <dt class=\"w30\">名前<span class=\"required\">【必須】</span></dt>\n              <dd class=\"w70\">\n                <input type=\"text\" name=\"name\" placeholder=\"例）兼子　太郎\">\n                <p class=\"error-message\" data-error=\"name\"></p>\n              </dd>\n  \n              <dt class=\"w30\">ふりがな<span class=\"required\">【必須】</span></dt>\n              <dd class=\"w70\">\n                <input type=\"text\" name=\"kana\" placeholder=\"例）かねこ　たろう\">\n                <p class=\"error-message\" data-error=\"kana\"></p>\n              </dd>\n  \n              <dt class=\"w30\">会社・団体名</dt>\n              <dd class=\"w70\">\n                <input type=\"text\" name=\"company\" placeholder=\"例）株式会社兼子\">\n              </dd>\n  \n              <dt class=\"w30\">電話番号</dt>\n              <dd class=\"w70\">\n                <input type=\"text\" name=\"phone\" placeholder=\"例）0123456789\">\n              </dd>\n  \n              <dt class=\"w30\">メールアドレス<span class=\"required\">【必須】</span></dt>\n              <dd class=\"w70\">\n                <input type=\"text\" name=\"email\" placeholder=\"例）info@k-kaneko.com\">\n                <p class=\"error-message\" data-error=\"email\"></p>\n              </dd>\n  \n              <dt class=\"w30\">お問い合わせの種別<span class=\"required\">【必須】</span></dt>\n              <dd class=\"w70\">\n                <span class=\"select\">\n                  <select name=\"type\">\n                    <option value=\"\" selected>以下から選んでください</option>\n                    <option value=\"古紙回収について\">古紙回収について</option>\n                    <option value=\"機密書類回収について\">機密書類回収について</option>\n                    <option value=\"廃棄物中間処理について\">廃棄物中間処理について</option>\n                    <option value=\"リサイクルステーションについて\">リサイクルステーションについて</option>\n                    <option value=\"ロジスティクスについて\">ロジスティクスについて</option>\n                    <option value=\"コンサルティングについて\">コンサルティングについて</option>\n                    <option value=\"その他\">その他</option>\n                  </select>\n                </span>\n                <p class=\"error-message\" data-error=\"type\"></p>\n              </dd>\n  \n              <dt class=\"w30\">お問い合わせ内容<span class=\"required\">【必須】</span></dt>\n              <dd class=\"w70\">\n                <textarea name=\"message\" rows=\"6\" placeholder=\"具体的なお問い合わせ内容をこちらに記載してください。\"></textarea>\n                <p class=\"error-message\" data-error=\"message\"></p>\n              </dd>\n\n              <dt class=\"w30\">（株）兼子をどこで<br>お知りになりましたか？</dt>\n              <dd class=\"w70\">\n                <span class=\"checkbox\">\n                  <input type=\"checkbox\" id=\"how1\" name=\"how[]\" class=\"hide\" value=\"インターネット検索\"><label for=\"how1\">インターネット検索</label>\n                  <input type=\"checkbox\" id=\"how2\" name=\"how[]\" class=\"hide\" value=\"ニュース・新聞・雑誌等\"><label\n                    for=\"how2\">ニュース・新聞・雑誌等</label>\n                  <input type=\"checkbox\" id=\"how3\" name=\"how[]\" class=\"hide\" value=\"ご紹介\"><label for=\"how3\">ご紹介</label>\n                  <input type=\"checkbox\" id=\"how4\" name=\"how[]\" class=\"hide\" value=\"看板・トラック\"><label for=\"how4\">看板・トラック</label>\n                  <input type=\"checkbox\" id=\"how5\" name=\"how[]\" class=\"hide\" value=\"展示会\"><label for=\"how5\">展示会</label>\n                  <input type=\"checkbox\" id=\"how6\" name=\"how[]\" class=\"hide\" value=\"過去にお取引の経験がある\"><label\n                    for=\"how6\">過去にお取引の経験がある</label>\n                  <input type=\"checkbox\" id=\"how7\" name=\"how[]\" class=\"hide\" value=\"その他\"><label for=\"how7\">その他</label>\n                </span>\n              </dd>\n            </dl>\n            <p class=\"center mt50\">\n              <input type=\"checkbox\" name=\"agree\" value=\"同意する\" id=\"agree\" class=\"hide\">\n              <label for=\"agree\"><a href=\"https://kaneko-hd.co.jp/privacy/\" target=\"_blank\">プライバシーポリシー</a>に同意する</label>\n            </p>\n            <div class=\"flex mt50 buttons h-center\">\n              <button type=\"button\" class=\"w47 button\" id=\"submitButton\">送信する</button>\n            </div>\n          </div>\n        </div>\n      </section>\n    </div>\n\n<div class=\"footer fade\">\n\n    <div class=\"banners\">\n        <a href=\"https://www.instagram.com/kaneko.group/\" target=\"_blank\"><img src=\"https://www.k-kaneko.com/assets/img/banner-insta.png\" alt=\"Instagram\"></a>\n    </div>\n    \n    <div class=\"fnavi fade\">\n        <div class=\"col\">\n          <ul>\n            <li><a href=\"../\" class=\"parent\">TOP</a></li>\n          </ul>\n        </div>\n        <div class=\"col\">\n          <ul>\n            <li><span class=\"parent\">事業案内</span></li>\n            <li><a href=\"../services/recycle/\">資源リサイクル</a></li>\n            <li><a href=\"../services/disposal/\">廃棄物再資源化・処理</a></li>\n            <li><a href=\"../services/consulting/\">リサイクルコンサルティング</a></li>\n            <li><a href=\"../services/equipment/\">設備導入コンサルティング</a></li>\n          </ul>\n          <ul>\n            <li><a href=\"../company/strength/\" class=\"parent\">強み</a></li>\n          </ul>\n          <ul>\n            <li><a href=\"../cases/\" class=\"parent\">事例紹介</a></li>\n          </ul>\n        </div>\n        <div class=\"col\">\n          <ul>\n            <li><a href=\"../company/profile/\" class=\"parent\">会社案内</a></li>\n            <li><a href=\"https://kaneko-hd.co.jp/company/policy/\" target=\"_blank\"><span class=\"blank\">兼子グループ各方針</span></a></li><!-- 兼子グループのページへ -->\n\n            <li><a href=\"../company/license/\">許認可情報</a></li>\n            <li><a href=\"https://www2.sanpainet.or.jp/index_u2.php?UserID=008360\" target=\"_blank\"><span class=\"blank\">さんぱいくん</span></a></li>\n          </ul>\n          <ul>\n            <li><a href=\"../sustainability/\" class=\"parent\">サステナビリティ</a></li>\n          </ul>\n        </div>\n        <div class=\"col\">\n          <ul>\n            <li><span class=\"parent\">採用情報</span></li>\n            <li><a href=\"https://recruit.kaneko-hd.co.jp/\" target=\"_blank\"><span class=\"blank\">グループ採用</span></a></li>\n            <li><a href=\"https://recruit.kaneko-hd.co.jp/for-driver/recycle.html\" target=\"_blank\"><span class=\"blank\">ドライバー採用</span></a></li>\n          </ul>\n        </div>\n        <div class=\"col\">\n          <ul>\n            <li><a href=\"../contact/\" class=\"parent\">お問い合わせ</a></li>\n              <li><a href=\"https://kaneko-hd.co.jp/privacy/\" target=\"_blank\"><span class=\"blank\">プライバシーポリシー</span></a></li><!-- 兼子グループのページへ -->\n              <li><a href=\"https://kaneko-hd.co.jp/terms/\" target=\"_blank\"><span class=\"blank\">サイト利用規約</span></a></li><!-- 兼子グループのページへ -->\n          </ul>\n          <ul>\n            <li><span class=\"parent\">兼子グループ</span></li>\n            <li><a href=\"https://kaneko-hd.co.jp/\" target=\"_blank\"><span class=\"blank\">KGホールディングス</span></a></li>\n            <li><a href=\"https://k-kaneko.com/\">株式会社兼子</a></li>\n            <li><a href=\"https://tokusan-unyu.jp/\" target=\"_blank\"><span class=\"blank\">德三運輸倉庫株式会社</span></a></li>\n            <li><a href=\"https://ecokaneko.com/\" target=\"_blank\"><span class=\"blank\">株式会社ECO兼子</span></a></li>\n            <li><a href=\"https://reuse-sunko.co.jp/\" target=\"_blank\"><span class=\"blank\">駿興製紙株式会社</span></a></li>\n              <li><a href=\"https://www.kokko-eco.co.jp/\" target=\"_blank\"><span class=\"blank\">株式会社國光</span></a></li>\n<li><a href=\"https://www.kkwell.co.jp/\" target=\"_blank\"><span class=\"blank\">株式会社WELL</span></a></li>\n              \n          </ul>\n        </div>\n      </div>\n      <div class=\"copyright\">\n        <img src=\"../assets/img/kaneko-group-s.png\" alt=\"兼子グループ\">\n        <p>&copy; 2023 KANEKO CO.,LTD.</p>\n      </div>\n    </div>\n\n    <div class=\"wall\">\n      <svg class=\"symbol\" width=\"535\" height=\"754\" viewBox=\"0 0 535 754\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n        <g><path d=\"M535 754L267.5 643.608L0 754V376.988V0L267.5 110.368L535 0L378.358 376.988L535 754Z\" /></g>\n      </svg>\n      <svg class=\"symbol\" width=\"535\" height=\"754\" viewBox=\"0 0 535 754\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n        <g><path d=\"M535 754L267.5 643.608L0 754V376.988V0L267.5 110.368L535 0L378.358 376.988L535 754Z\" /></g>\n      </svg>\n      <svg class=\"symbol\" width=\"535\" height=\"754\" viewBox=\"0 0 535 754\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n        <g><path d=\"M535 754L267.5 643.608L0 754V376.988V0L267.5 110.368L535 0L378.358 376.988L535 754Z\" /></g>\n      </svg>\n      <svg class=\"symbol\" width=\"535\" height=\"754\" viewBox=\"0 0 535 754\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n        <g><path d=\"M535 754L267.5 643.608L0 754V376.988V0L267.5 110.368L535 0L378.358 376.988L535 754Z\" /></g>\n      </svg>\n      \n      <svg class=\"symbol\" width=\"535\" height=\"754\" viewBox=\"0 0 535 754\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n        <g><path d=\"M535 754L267.5 643.608L0 754V376.988V0L267.5 110.368L535 0L378.358 376.988L535 754Z\" /></g>\n      </svg>\n      <svg class=\"symbol\" width=\"535\" height=\"754\" viewBox=\"0 0 535 754\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n        <g><path d=\"M535 754L267.5 643.608L0 754V376.988V0L267.5 110.368L535 0L378.358 376.988L535 754Z\" /></g>\n      </svg>\n      <svg class=\"symbol\" width=\"535\" height=\"754\" viewBox=\"0 0 535 754\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n        <g><path d=\"M535 754L267.5 643.608L0 754V376.988V0L267.5 110.368L535 0L378.358 376.988L535 754Z\" /></g>\n      </svg>\n      <svg class=\"symbol\" width=\"535\" height=\"754\" viewBox=\"0 0 535 754\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n        <g><path d=\"M535 754L267.5 643.608L0 754V376.988V0L267.5 110.368L535 0L378.358 376.988L535 754Z\" /></g>\n      </svg>\n      \n      <svg class=\"symbol\" width=\"535\" height=\"754\" viewBox=\"0 0 535 754\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n        <g><path d=\"M535 754L267.5 643.608L0 754V376.988V0L267.5 110.368L535 0L378.358 376.988L535 754Z\" /></g>\n      </svg>\n      <svg class=\"symbol\" width=\"535\" height=\"754\" viewBox=\"0 0 535 754\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n        <g><path d=\"M535 754L267.5 643.608L0 754V376.988V0L267.5 110.368L535 0L378.358 376.988L535 754Z\" /></g>\n      </svg>\n      <svg class=\"symbol\" width=\"535\" height=\"754\" viewBox=\"0 0 535 754\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n        <g><path d=\"M535 754L267.5 643.608L0 754V376.988V0L267.5 110.368L535 0L378.358 376.988L535 754Z\" /></g>\n      </svg>\n      <svg class=\"symbol\" width=\"535\" height=\"754\" viewBox=\"0 0 535 754\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n        <g><path d=\"M535 754L267.5 643.608L0 754V376.988V0L267.5 110.368L535 0L378.358 376.988L535 754Z\" /></g>\n      </svg>\n    </div>\n  </div>\n  <script src=\"../assets/js/jquery.min.js\"></script>\n  <script src=\"../assets/js/jquery.bez.min.js\"></script>\n  <script src=\"../assets/js/jquery.count.js\"></script>\n  <script src=\"../assets/js/slick/slick.js\"></script>\n  <script src=\"../assets/js/script.js\"></script>\n  <style>\n  .error-message {\n    color: #ff0000;\n    font-size: 12px;\n    margin-top: 5px;\n    display: none;\n  }\n  </style>\n  <script>\n  document.getElementById('submitButton').addEventListener('click', async function(e) {\n    e.preventDefault();\n\n    // プライバシーポリシーの同意確認\n    if (!document.getElementById('agree').checked) {\n      alert('プライバシーポリシーへの同意が必要です。');\n      return;\n    }\n\n    // エラーメッセージをクリア\n    document.querySelectorAll('.error-message').forEach(el => el.style.display = 'none');\n\n    // フォームデータを収集\n    const formData = new FormData();\n    const form = document.getElementById('contactForm');\n    \n    const inputs = form.querySelectorAll('input[type=\"text\"], textarea, select');\n    inputs.forEach(input => {\n      if (input.name) {\n        formData.append(input.name, input.value);\n      }\n    });\n\n    // チェックボックスの値を配列として追加\n    const howCheckboxes = form.querySelectorAll('[name=\"how[]\"]:checked');\n    howCheckboxes.forEach(checkbox => {\n      formData.append('how[]', checkbox.value);\n    });\n\n    try {\n        const token = await new Promise((resolve, reject) => {\n            grecaptcha.enterprise.ready(() => {\n            grecaptcha.enterprise.execute(\n                '6Leu00IsAAAAAKyl0hSovvJX9s9zCXlKn9UQGcuI',\n                { action: 'contact' }\n            ).then(resolve).catch(reject);\n            });\n        });\n\n        formData.append('g-recaptcha-response', token);\n\n      const response = await fetch('send.php', {\n          method: 'POST',\n          body: formData\n      });\n\n      const result = await response.json();\n\n      if (result.success) {\n        alert('お問い合わせを受け付けました。');\n        // フォームのリセット\n        inputs.forEach(input => {\n          input.value = '';\n        });\n        howCheckboxes.forEach(checkbox => {\n          checkbox.checked = false;\n        });\n        document.getElementById('agree').checked = false;\n      } else {\n        result.errors.forEach(error => {\n          if (error.field) {\n            const errorElement = document.querySelector(`[data-error=\"${error.field}\"]`);\n            if (errorElement) {\n              errorElement.textContent = error.message;\n              errorElement.style.display = 'block';\n            }\n          } else {\n            alert(error.message);\n          }\n        });\n      }\n    } catch (error) {\n      console.error('Error:', error);\n      alert('エラーが発生しました。時間をおいて再度お試しください。');\n    }\n  });\n  </script>\n</body>\n\n</html>","finalUrl":"http://www.k-kaneko.com/contact/","rendered":false,"_cachedAt":"2026-06-23T22:49:54.079Z"}