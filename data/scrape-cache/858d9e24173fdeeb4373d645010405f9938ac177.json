{"url":"https://www.ksg.co.jp/inquiry/","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"description\" content=\"教育産業株式会社は、映像・音響・教育ICT機器の販売、設計、レンタルから映像制作を中心に、テレビ会議などのネットワーク配信システム、ディスプレイ、プロジェクター、防犯カメラなど、あらゆる映像ソリューションをサポートします。愛知・名古屋\">\n<meta name=\"format-detection\" content=\"telephone=no, address=no, email=no\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n<link rel=\"icon\" href=\"/favicon.ico\">\n<title>お問い合わせ | 教育産業株式会社</title>\n<link rel=\"stylesheet\" href=\"/assets/css/fontawesome-pro-5.5.0-web-all.css\" />\n<link rel=\"stylesheet\" href=\"//fonts.googleapis.com/css?family=Roboto:100,400,500,700&display=swap&subset=japanese\">\n<link rel=\"stylesheet\" href=\"/css/style.css\" media=\"all\">\n<link rel=\"stylesheet\" href=\"/assets/css/project.css\" media=\"all\">\n<link rel=\"stylesheet\" href=\"/assets/css/unique/inquiry.css\" media=\"all\">\n<script src=\"/assets/js/vendor/jquery.js\"></script>\n<script src=\"/assets/js/vendor/jquery.matchHeight.js\"></script>\n<script src=\"/assets/js/project.js\"></script>\n<!-- Global site tag (gtag.js) - Google Analytics -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=UA-54222644-1\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n  gtag('config', 'UA-54222644-1');\n</script>\n</head>\n\n<body id=\"inquiry\" class=\"pageInquiry\">\n<noscript>JavascriptがOFFのため正しく表示されない可能性があります。</noscript>\n  <div id=\"wrap\">\n    <!-- [ HEADER ] -->\n    <header>\n      \n  <div class=\"header-inner\">\n    <p class=\"logo\"><a href=\"/\"><img src=\"/assets/images/logo.svg\" alt=\"KSG教育産業\"></a></p>\n  </div>\n    <nav>\n      <input id=\"menu-cb\" name=\"headmenu\" type=\"checkbox\" value=\"menu\">\n      <label id=\"menu-icon\" for=\"menu-cb\"><span></span><span></span><span></span></label>\