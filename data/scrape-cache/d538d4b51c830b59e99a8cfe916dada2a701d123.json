) {\r\n\t\t\t\tdocument.querySelectorAll('.overseas-expatriate-map-popup li').forEach(function(li) {\r\n\t\t\t\t\tli.classList.remove('active');\r\n\t\t\t\t});\r\n\t\t\t}\r\n\t\t});\r\n\t</script>\r\n\r\n\t<script>\r\n\t\t$(document).ready(function(){\r\n\t\t\t$(\".menu-box\").each(function(index) {\r\n\t\t\t\t$(this).hover(\r\n\t\t\t\t\tfunction() {\r\n\t\t\t\t\t\t$(\".menu-container\").addClass(\"bg-\" + index);\r\n\t\t\t\t\t},\r\n\t\t\t\t\tfunction() {\r\n\t\t\t\t\t\t$(\".menu-container\").removeClass(\"bg-\" + index);\r\n\t\t\t\t\t}\r\n\t\t\t\t);\r\n\t\t\t});\r\n\t\t});\r\n\t</script>\r\n\r\n</body>\r\n</html>","finalUrl":"https://www.iwatani.co.jp/jpn/recruit/new-graduate/","rendered":false,"_cachedAt":"2026-06-23T18:01:11.917Z"}