radient-background{background: var(--wp--preset--gradient--luminous-dusk) !important;}.has-pale-ocean-gradient-background{background: var(--wp--preset--gradient--pale-ocean) !important;}.has-electric-grass-gradient-background{background: var(--wp--preset--gradient--electric-grass) !important;}.has-midnight-gradient-background{background: var(--wp--preset--gradient--midnight) !important;}.has-small-font-size{font-size: var(--wp--preset--font-size--small) !important;}.has-medium-font-size{font-size: var(--wp--preset--font-size--medium) !important;}.has-large-font-size{font-size: var(--wp--preset--font-size--large) !important;}.has-x-large-font-size{font-size: var(--wp--preset--font-size--x-large) !important;}\n/*# sourceURL=global-styles-inline-css */\n</style>\n\n<link rel='stylesheet' id='contact-form-7-css' href='https://shikokuiryoki.com/recruit/wp-content/plugins/contact-form-7/includes/css/styles.css' media='all' />\n<link rel=\"canonical\" href=\"https://shikokuiryoki.com/recruit/interview/person3/\" />\n<link rel=\"stylesheet\" href=\"https://shikokuiryoki.com/recruit/wp-content/themes/shikokuiryoki_recruit/assets/css/reset.css\">\n<link rel=\"stylesheet\" href=\"https://shikokuiryoki.com/recruit/wp-content/themes/shikokuiryoki_recruit/style.css\">\n<link rel=\"shortcut icon\" href=\"https://shikokuiryoki.com/recruit/wp-content/themes/shikokuiryoki_recruit/images/favicon.ico\">\n\n    <link rel=\"stylesheet\" href=\"https://shikokuiryoki.com/recruit/wp-content/themes/shikokuiryoki_recruit/assets/css/pages.css\">\n\n<!-- Global site tag (gtag.js) - Google Analytics -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-ZC06HNPL99\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'G-ZC06HNPL99');\n</script>\n</head>\n\n<header class=\"header_logo\">\n\t<h1 class=\"header_logo_\">\n\t\t<a href=\"https://shikokuiryoki.com/recruit/\">\n\t\t\t<div class=\"jr\">JR四国グループ</div>\n\t\t\t<div class=\"header_logo_content\">\n\t\t\t\t<img src=\"https://shikokuiryoki.com/recruit/wp-content/themes/shikokuiryoki_recruit/images/logo.svg\" alt=\"四国医療器 オフィシャルサイト\">\n\t\t\t\t<span class=\"recruit\">Recruit</span>\n\t\t\t</div>\n\t\t</a>\n\t</h1>\n\n\t<h2 class=\"recruit_types\">\n\t\t<span>新卒</span>\n\t\t<span>キャリア</span>\n\t\t<span>カムバック採用</span>\n\t</h2>\n</header>\n\n<header class=\"header\">\t\n\t<div id=\"header_nav_area\"><!--  #header_nav_area -->\n\t\t<nav>\n\t\t<div class=\"header_nav_area_inner\">\n\t\t\t<ul class=\"nav_list\">\n            <li><a href=\"https://shikokuiryoki.com/recruit/about/\">ABOUT US</a></li>\n\t\t\t<li><a href=\"https://shikokuiryoki.com/recruit/message/\">MESSAGE</a></li>\n\t\t\t<li><a href=\"https://shikokuiryoki.com/recruit/interview/person1/\">INTERVIEW</a></li>\n\t\t\t<li><a href=\"https://shikokuiryoki.com/recruit/requirements/\">募集要項</a></li>\n\t\t\t<li><a href=\"https://shikokuiryoki.com/recruit/qa/\">Q&A</a></li>\n\t\t\t<li><a href=\"https://shikokuiryoki.com/\" target=\"_blank\">コーポレートサイト</a></li>\n\t\t\t<li><a href=\"https://shikokuiryoki.com/recruit/contact/\">お問い合わせ</a></li>\n\t\t\t</ul>\n\t\t</div>\n\n\t\t<div class=\"btn_close\">\n\t\t\t<span></span>\n\t\t\t<span></span>\n\t\t</div>\n\t\t</nav>\n\n\t\t<div class=\"btn_open\">\n\t\t\t<span></span>\n\t\t\t<span></span>\n\t\t\t<span></span>\t\t\t\n\t\t</div>\n\t\t\n\t\t<div class=\"toggle_btn_bg\"></div>\n\n\t  <div id=\"mask\"></div>\n\n\t</div><!--  END #header_nav_area -->\t\n</header><body class=\"wp-singular page-template page-template-page-interview-person3 page-template-page-interview-person3-php page page-id-35 page-child parent-pageid-77 wp-theme-shikokuiryoki_recruit pages interview person person3\">\n<main>\n    <div class=\"page-ttl\">\n        <div>\n            <h1 class=\"ttl\">INTERVIEW 03</h1>\n            <h2 class=\"hl\">先輩インタビュー ｜ 先輩社員たちが思う四国医療器とは。</h2>\n        </div>\n    </div>\n\n    <div class=\"mv\">\n        <div>\n            <div class=\"profile\">\n                <h3 class=\"name\">03.KUROKAWA KAZUAKI</h3>\n                <p>\n                    <span>SPDセンター｜黒川 和昭</span>\n                    <span>2018年入社</span>\n                    <span>勤務地｜SPD業務委託病院様 院内事務所</span>\n                    <!--<span>最終学歴｜北里大学 海洋生命科学部 海洋生命学科</span>-->\n                </p>\n            </div>\n        </div>\n    </div><!-- .mv -->\n\n    <section class=\"qa sec\">\n        <div class=\"inner\">\n            <article>\n                <h4 class=\"catch\">医療という分野にもっと接したい</h4>\n                <h5 class=\"q\">なぜこの仕事を選んだのか教えてください。</h5>\n                <p>私は特別養護老人ホームで12年間調理師や介護職員として働いた後、転職して四国医療器株式会社に入社しました。<br><br>転職のきっかけは、介護に携わっている事で「より医療という分野にもっと接したい」と感じるようになり、様々な医療機器メーカーや同業者を検討した結果、地元に貢献できるところに魅力を感じて四国医療器株式会社に入社を決めました。</p>\n            </article>\n\n            <article>\n                <h4 class=\"catch\">医療業務・看護業務に専念出来る部署</h4>\n                <h5 class=\"q\">配属部著のSPDとはどういった部署ですか？</h5>\n                <p>SPDとは「Supply Processing and Distribution」の略称であり、病院が使用する医療消耗品等の供給・在庫・加工などの物流を一元管理する方法のことです。<br><br>私は院内に常駐し、SPD専用システムを利用して、医療消耗品等の調達・使用・消費・補充といった一連の物流を管理しています。私達が院内で現場をサポートする事により医療従事者の方達は物品管理業務から開放され、医療業務・看護業務に専念出来ると言う事です。\n\n</p>\n            </article>\n\n            <div class=\"img img1 person1_1\"></div>\n\n\n            <article>\n                <h4 class=\"catch\">医療の最前線を支える</h4>\n                <h5 class=\"q\">仕事の面白さは？</h5>\n                <p>ドクターや看護師さん等の医療の最前線の方達と直接お話出来る事ですね。<br><br>コロナ禍で安定供給が困難になった商品の代替商品を提案し採用して頂いたことがありました。その代替商品のおかげでその後不安なく供給でき、病院側にとってメリットになったと感じていただけた事が記憶に残っています。さらに、私が３日間ほど不在になり復帰した時に、現場の方から「黒川さんが早期に復帰して良かった。居ると居ないとでは自分たちの業務効率が全然違う」と言われた事は今でも励みになっています。\n\n</p>\n            </article>\n\n            <article>\n                <h4 class=\"catch\">和気あいあいとした雰囲気</h4>\n                <h5 class=\"q\">職場の雰囲気について教えてください。</h5>\n                <p>私が担当する病院にスタッフは女性２名・男性２名の計４名が院内事務所に常駐しています。何事にも相談しながら進めていき、また休息時間にはお子さんの話やプライベートな話もするなど和気あいあいとした雰囲気です。</p>\n            </article>\n\n\n\n            <div class=\"img img2 person1_2\"></div>            \n        </div>\n    </section><!-- .qa -->\n\n    <section class=\"schedule sec\">\n        <div class=\"inner\">\n            <h3 class=\"schedule_ttl\">1日の仕事の流れを教えてください。</h3>\n            <table class=\"table_style1\">\n                <tbody>\n                    <tr>\n                        <th>時間</th>\n                        <th>スケジュール</th>\n                        <th>業務内容</th>\n                    </tr>\n                    <tr>\n                        <th>8：50</th>\n                        <td>出　社</td>\n                        <td>荷降ろしと納品チェック、院内事務所でのデスクワーク</td>\n                    </tr>\n                    <tr>\n                        <th>9:30</th>\n                        <td>院内配送開始</td>\n                        <td>午前中は病棟を中心とした16部署に配送と現場要望のヒアリング</td>\n                    </tr>\n                    <tr>\n                        <th>12:00</th>\n                        <td>休　憩</td>\n                        <td>お昼休憩</td>\n                    </tr>\n                    <tr>\n                        <th>13:00</th>\n                        <td>業　務</td>\n                        <td>外来を中心とした約30部署への配送と現場要望のヒアリング。急ぎの問い合わせがあれば、配送途中でも一旦院内事務所へ戻って対応</td>\n                    </tr>\n                    <tr>\n                        <th>16:00</th>\n                        <td>業　務</td>\n                        <td>院内事務所にて要望の確認やメーカー問い合わせ、見積書作成等</td>\n                    </tr>\n                    <tr>\n                        <th>17:00</th>\n                        <td>業　務</td>\n                        <td>SPDセンターへ行き翌日納品の準備</td>\n                    </tr>\n                    <tr>\n                        <th>19:00</th>\n                        <td>退　社</td>\n                        <td>業務が終わり次第、順次退社</td>\n                    </tr>\n                </tbody>\n            </table>\n        </div>\n    </section><!-- .schedule -->\n\n    <section class=\"message sec\">\n        <div class=\"inner\">\n        <div class=\"message_ttl_box\">\n                <h3 class=\"message_ttl\"><span>先輩からの<br>メッセージ</span></h3>\n                <div class=\"tagline\">Message from Seniors</div>\n            </div>\n\n\n            <div class=\"message_content\">\n                <div class=\"txt\">\n                    <p>まずはお客様から信頼される事が重要なので、明るく正直な人を望みます。また自分で商品を調べて提案する事が多いので探究心の有る方は向いていると思います。</p>\n                </div>\n                <div class=\"img\">\n                    <img src=\"https://shikokuiryoki.com/recruit/wp-content/themes/shikokuiryoki_recruit/images/interview/3/item4.png\" alt=\"先輩の写真\">\n                </div>\n            </div>\n        </div>\n    </section><!-- .message -->\n\n    <section class=\"viewmore sec\">\n        <div class=\"inner\">\n            <h4 class=\"sec_ttl\">VIEW MORE</h4>\n            <h5 class=\"hl\">先輩インタビュー</h5>\n            \n<div class=\"interview_slide\">\n\t<div class=\"slick clearfix\">\n\t\t<a href=\"https://shikokuiryoki.com/recruit/interview/person1/\"><img class=\"toggleImg\" alt=\"インタビュー1 田所 真純\" src=\"https://shikokuiryoki.com/recruit/wp-content/themes/shikokuiryoki_recruit/images/interview/slide_1.jpg\" /></a>\n\t\t<a href=\"https://shikokuiryoki.com/recruit/interview/person2/\"><img class=\"toggleImg\" alt=\"インタビュー2 石川 廉\" src=\"https://shikokuiryoki.com/recruit/wp-content/themes/shikokuiryoki_recruit/images/interview/slide_2.jpg\" /></a>\n\t\t<a href=\"https://shikokuiryoki.com/recruit/interview/person3/\"><img class=\"toggleImg\" alt=\"インタビュー3 福井 雅也\" src=\"https://shikokuiryoki.com/recruit/wp-content/themes/shikokuiryoki_recruit/images/interview/slide_3.jpg\" /></a>\n\t\t<a href=\"https://shikokuiryoki.com/recruit/interview/person4/\"><img class=\"toggleImg\" alt=\"インタビュー4 青野 雄樹\" src=\"https://shikokuiryoki.com/recruit/wp-content/themes/shikokuiryoki_recruit/images/interview/slide_4.jpg\" /></a>\t\n\t\t<a href=\"https://shikokuiryoki.com/recruit/interview/person5/\"><img class=\