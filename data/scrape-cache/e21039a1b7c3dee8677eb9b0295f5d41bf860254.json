u30fc\\u30b7\\u30e7\\u30f3\\u4e8b\\u696d\\u90e8&quot;:&quot;\\u30b5\\u30fc\\u30d3\\u30b9\\u30b9\\u30c6\\u30fc\\u30b7\\u30e7\\u30f3\\u4e8b\\u696d\\u90e8&quot;,&quot;\\u30ab\\u30fc\\u30e9\\u30a4\\u30d5\\u4e8b\\u696d\\u90e8&quot;:&quot;\\u30ab\\u30fc\\u30e9\\u30a4\\u30d5\\u4e8b\\u696d\\u90e8&quot;,&quot;\\u305d\\u306e\\u4ed6&quot;:&quot;\\u305d\\u306e\\u4ed6&quot;}\" />\n</dd>\n<dt>お問い合わせ内容<!--span class=\"att\">必須</span--></dt>\n<dd>\n<textarea name=\"detail\" id=\"detail\" cols=\"50\" rows=\"5\" ></textarea>\n</dd>\n<dt>お名前<!--span class=\"att\">必須</span--></dt>\n<dd>\n<input type=\"text\" name=\"name\" id=\"name\" size=\"60\" value=\"\" placeholder=\"例）栄月　太郎\" />\n</dd>\n<dt>メールアドレス<!--span class=\"att\">必須</span--></dt>\n<dd>\n<input type=\"email\" name=\"mail\" id=\"mail\" size=\"60\" value=\"\" placeholder=\"例）abcdef@address.co.jp\" data-conv-half-alphanumeric=\"true\"/>\n<br class=\"mb_only\" /> <span class=\"sup\">半角英数字で入力してください</span></dd>\n<dt>TEL<!--span class=\"att\">必須</span--></dt>\n<dd>\n\n<input type=\"text\" name=\"tel\" id=\"tel\" size=\"60\" value=\"\" placeholder=\"例）0776-25-1511\" data-conv-half-alphanumeric=\"true\"/>\n<br class=\"mb_only\"> <span class=\"sup\">半角英数字で入力してください</span></dd>\n<dt>ご住所<!--span class=\"att\">必須</span--></dt>\n<dd>\n<p>〒 \n<input type=\"text\" name=\"zip_code\" id=\"zip_code\" class=\"zip\" size=\"60\" value=\"\" placeholder=\"例）910-0005\" />\n<br class=\"mb_only\" /> <span class=\"sup\">ハイフン\"-\"を含め、半角で入力してください。</span></p>\n<p>\n<input type=\"text\" name=\"address\" id=\"address\" size=\"60\" value=\"\" placeholder=\"例）福井県福井市大手2丁目11番12号 栄月ビル201\" />\n</p>\n</dd>\n</dl>\n<p class=\"agree\">\n\t<span class=\"mwform-checkbox-field horizontal-item\">\n\t\t<label for=\"agree-1\">\n\t\t\t<input type=\"checkbox\" name=\"agree[data][]\" value=\"個人情報保護方針に同意する\" id=\"agree-1\" />\n\t\t\t<span class=\"mwform-checkbox-field-text\">個人情報保護方針に同意する</span>\n\t\t</label>\n\t</span>\n\n<input type=\"hidden\" name=\"agree[separator]\" value