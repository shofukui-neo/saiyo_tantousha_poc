ment,'script','dataLayer','GTM-5MB5TN');</script>\n<!-- End Google Tag Manager -->\n<!-- InstanceBeginEditable name=\"head\" -->\n<link href=\"css/default02.css\" rel=\"stylesheet\">\n<!-- InstanceEndEditable -->\n</head>\n<body>\n<!-- Google Tag Manager (noscript) -->\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-5MB5TN\"\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n<!-- End Google Tag Manager (noscript) -->\n<!-- InstanceBeginEditable name=\"header\" -->\n<div id=\"header\" class=\"px-sm-4 py-4\">\n<header id=\"index\" class=\"mx-2\">\n<nav class=\"navbar navbar-expand-lg navbar-light rounded fw-bold p-4 shadow\">\n<div class=\"container-fluid\" id=\"navigation\"></div>\n</nav>\n</header>\n\n<div class=\"container-fluid\">\n<div class=\"row\">\n<div class=\"col-xl-7\">\n<h1 class=\"display-3 fw-bold pb-4 mt-5\"><span class=\"bg-white lh-sm px-lg-3\">安定基盤<small>&amp;</small>地域密着</span><br>\n<span class=\"bg-white lh-sm px-lg-3\">OKBグループIT企業</span></h1>\n<ul class=\"list-inline ms-4\">\n<li class=\"list-inline-item pb-3\"><a class=\"btn btn-info btn-lg shadow-sm\" href=\"entry/seminar.html\" role=\"button\" target=\"_blank\"><i class=\"bi bi-arrow-right-short\"></i>会社説明会お申し込み</a></li>\n</ul>\n<div id=\"carouselNews\" class=\"carousel slide bg-white p-3 rounded shadow mb-5\" data-bs-ride=\"carousel\">\n<div class=\"carousel-inner\">\n<div class=\"carousel-item active\"><span class=\"text-secondary small pe-3\">2026年3月1日</span>2027年新卒採用活動を開始致しました。</div>\n<!--<div class=\"carousel-item\"><span class=\"text-secondary small pe-3\"></span></div>-->\n</div><!-- /.carousel-inner -->\n</div><!-- /.carousel slide -->\n</div><!-- /.col -->\n</div><!-- /.row -->\n</div><!-- /.container-fluid -->\n\n<div class=\"container\">\n<div class=\"mx-md-5 p-4 rounded  shadow text-center\" id=\"feature\">\n<div class=\"row align-items-center\">\n<div class=\"col-lg-6 p-md-3\">\n<div class=\"ratio ratio-16x9\">\n<iframe width=\"560\" height=\"315\" src=\"https://www.youtube.com/embed/qEuvD_y1nig?mute=1&loop=1&rel=0\" title=\"YouTube video player\" frameborder=\"0\" allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture\" allowfullscreen></iframe>\n</div><!-- /.ratio -->\n</div>\n<div class=\"col-lg-6 pt-2\">\n<p><span class=\"display-4 fw-bold\">With&amp;More</span><br>\n<span class=\"display-6 fw-bold\">共に、より一層</span></p>\n<p class=\"lh-lg\">私たちは、情報分野のフロンティアとして<br>\n最先端の知識と確かな技術で<br>\nお客さまのニーズにお応えします。</p>\n<a class=\"btn btn-outline-info shadow-sm\" href=\"office/index.html\" role=\"button\"><i class=\"bi bi-arrow-right-short\"></i>KCSについてもっと知る</a>\n</div>\n</div><!-- /.row -->\n</div><!-- /.bg -->\n</div><!-- /.container -->\n</div><!-- /#header -->\n<!-- InstanceEndEditable -->\n<!-- InstanceBeginEditable name=\"content\" -->\n<div class=\"bg-slant bg-info py-5\">\n<div class=\"display-1 text-end text-white d-none d-sm-block title\">//<span class=\"fw-bold\">Events</span></div>\n<div class=\"container py-5 text-center\" id=\"events\">\n<h2 class=\"mb-5 h1 text-white\">就活お役立ち情報</h2>\n<p class=\"text-white\">イベント情報を随時追加いたします。<br>\n気になるイベントがありましたら、参加してみてくださいね。</p>\n<p><a class=\"btn btn-outline-light shadow-sm\" data-bs-toggle=\"collapse\" href=\"#collapseCal\" role=\"button\" aria-expanded=\"false\" aria-controls=\"collapseCal\"><i class=\"bi bi-arrow-down-short\"></i>イベントカレンダーを表示する</a></p>\n<div class=\"collapse\" id=\"collapseCal\">\n<div class=\"google-cal py-3\">\n<iframe src=\"https://calendar.google.com/calendar/embed?height=600&wkst=1&bgcolor=%23ffffff&ctz=Asia%2FTokyo&showTitle=0&showTz=0&showCalendars=0&showPrint=0&src=MGxiMHU2bzcwbnJnZDM0NTl2Yzk0NDIxZjBAZ3JvdXAuY2FsZW5kYXIuZ29vZ2xlLmNvbQ&src=amEuamFwYW5lc2UjaG9saWRheUBncm91cC52LmNhbGVuZGFyLmdvb2dsZS5jb20&color=%23009688&color=%23F6BF26\" style=\"border-width:0\" width=\"950\" height=\"600\" frameborder=\"0\" scrolling=\"no\"></iframe>\n</div><!-- /.google-cal -->\n</div><!-- /.collapse -->\n\n<div class=\"row row-cols-1 row-cols-md-3 text-start kcs_topics photos py-5 g-4\">\n\n<div class=\"col\">\n<a href=\"../journal/2025/10_recruit_contents.html\">\n<div class=\"card h-100 shadow\">\n<img src=\"../journal/2025/images/10_recruit_contents_p01.webp\" class=\"card-img-top\" alt=\"∞に広がる可能性～新入社員による学生向けコンテンツ制作～\">\n<div class=\"card-body\">\n<h3 class=\"card-title h5\">∞に広がる可能性<small>～新入社員による学生向けコンテンツ制作～</small></h3>\n<p class=\"card-text link-primary\">ITソリューション本部に配属された7名による、制作活動と発表の様子。</p>\n<small class=\"text-secondary\">2025年12月5日</small>\n</div>\n</div>\n</a>\n</div>\n\n<div class=\"col\">\n<a href=\"../journal/2025/09_internship_2days.html\">\n<div class=\"card h-100 shadow\">\n<img src=\"../journal/2025/images/09_internship_2days_p28.webp\" class=\"card-img-top\" alt=\"2025年夏、2daysインターンシップ開催\n（対面・オンライン・プラスワン）\">\n<div class=\"card-body\">\n<h3 class=\"card-title h5\">2025年夏、2daysインターンシップ開催<small>（対面・オンライン・プラスワン）</small></h3>\n<p class=\"card-text link-primary\">今年は新コース「バンキングシステム開発体験」が登場！</p>\n<small class=\"text-secondary\">2025年8月～9月</small>\n</div>\n</div>\n</a>\n</div>\n\n<div class=\"col\">\n<a href=\"../journal/2025/09_internship_1day.html\">\n<div class=\"card h-100 shadow\">\n<img src=\"../journal/2025/images/09_internship_1day_p06.webp\" class=\"card-img-top\" alt=\"2025年夏、1day仕事体験（IT業界の仕事を知ろう）開催（オンライン・対面）\">\n<div class=\"card-body\">\n<h3 class=\"card-title h5\">2025年夏、1day仕事体験（IT業界の仕事を知ろう）開催<small>（オンライン・対面）</small></h3>\n<p class=\"card-text link-primary\">今年も8月と9月に、大学生を対象とした夏季インターンシップを開催しました。</p>\n<small class=\"text-secondary\">2025年8月～9月</small>\n</div>\n</div>\n</a>\n</div>\n\n</div><!-- /.row -->\n</div><!-- /.container -->\n</div><!-- /.gb-slant -->\n\n<div class=\"display-1 text-end text-info d-none d-sm-block title\">//<span class=\"fw-bold\">IT's KCS</span></div>\n<div class=\"container py-5 text-center\">\n<h2 class=\"mb-5 h1\">私たちがKCSを紹介します</h2>\n<div class=\"row pt-5\">\n<div class=\"col-md-4 mb-5\">\n<p class=\"mb-0\">\\ まずは業界研究 /</p>\n<p><img src=\"images/index_p01.png\" class=\"img-fluid rounded-circle\" alt=\"てつ\"></p>\n<p>てつ<small>（2022年入社）</small></p>\n<div class=\"d-grid gap-2 pt-3\">\n<a class=\"btn btn-lg btn-outline-info shadow-sm\" href=\"voice/index.html#check\" role=\"button\"><i class=\"bi bi-arrow-right-short\"></i>マッチング10秒診断</a>\n<a class=\"btn btn-lg btn-outline-info shadow-sm\" href=\"internship/index.html#1day\" role=\"button\"><i class=\"bi bi-arrow-right-short\"></i>1day業界研究</a>\n<a class=\"btn btn-lg btn-outline-info shadow-sm\" href=\"internship/index.html#2days\" role=\"button\"><i class=\"bi bi-arrow-right-short\"></i>2daysインターンシップ</a>\n</div>\n</div>\n<div class=\"col-md-4 mb-5\">\n<p class=\"mb-0\">\\ 笑顔で就活 /</p>\n<p><img src=\"images/index_p02.png\" class=\"img-fluid rounded-circle\" alt=\"なな\"></p>\n<p>なな<small>（2022年入社）</small></p>\n<div class=\"d-grid gap-2 pt-3\">\n<a class=\"btn btn-lg btn-outline-info shadow-sm\" href=\"entry/index.html#flow\" role=\"button\"><i class=\"bi bi-arrow-right-short\"></i>採用までの流れ</a>\n<a class=\"btn btn-lg btn-outline-info shadow-sm\" href=\"entry/index.html#recruit\" role=\"button\"><i class=\"bi bi-arrow-right-short\"></i>募集内容</a>\n<a class=\"btn btn-lg btn-outline-info shadow-sm\" href=\"work/index.html#pg\" role=\"button\"><i class=\"bi bi-arrow-right-short\"></i>プログラマの仕事</a>\n</div>\n</div>\n<div class=\"col-md-4 mb-5\">\n<p class=\"mb-0\">\\ 不安を解消 /</p>\n<p><img src=\"images/index_p03.png\" class=\"img-fluid rounded-circle\" alt=\"いち\"></p>\n<p>いち<small>（2023年入社）</small></p>\n<div class=\"d-grid gap-2 pt-3\">\n<a class=\"btn btn-lg btn-outline-info shadow-sm\" href=\"work/index.html#se\" role=\"button\"><i class=\"bi bi-arrow-right-short\"></i>システムエンジニアの仕事</a>\n<a class=\"btn btn-lg btn-outline-info shadow-sm\" href=\"office/index.html#benefits\" role=\"button\"><i class=\"bi bi-arrow-right-short\"></i>福利厚生</a>\n<a class=\"btn btn-lg btn-outline-info shadow-sm\" href=\"office/index.html#new_employee\" role=\"button\"><i class=\"bi bi-arrow-right-short\"></i>新入社員の研修内容</a>\n</div>\n</div>\n</div><!-- /.row -->\n</div><!-- /.container -->\n\n<div id=\"contact\">\n<div class=\"container py-5 text-center \">\n<h2 class=\"text-white fw-bold\">マイナビで情報公開中</h2>\n<p class=\"text-white pt-5\">あなたのエントリーをお待ちしています。</p>\n<ul class=\"list-inline pt-4\">\n<li class=\"list-inline-item pb-3\"><a class=\"btn btn-info btn-lg shadow-sm\" href=\"entry/internship.html\" role=\"button\" target=\"_blank\"><i class=\"bi bi-arrow-right-short\"></i>マイナビで詳細を見る</a></li>\n</ul><!-- /.list-inline -->\n</div><!-- /.container -->\n</div><!-- /.contact -->\n<!-- InstanceEndEditable -->\n<footer class=\"bg-info\">\n<div id=\"footer\"></div>\n</footer>\n<script src=\"https://code.jquery.com/jquery-3.7.1.min.js\" integrity=\"sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo=\" crossorigin=\"anonymous\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js\" integrity=\"sha384-geWF76RCwLtnZ8qwWowPQNguL3RmwHVBC9FhGdlKrxdiJJigb/j/68SIy3Te4Bkz\" crossorigin=\"anonymous\"></script>\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css\">\n<script src=\"https://cdnjs.cloudflare.com/ajax/libs/protonet-jquery.inview/1.1.2/jquery.inview.min.js\" integrity=\"sha512-D68mBFX2aQwVh2wV6uCDLmabIveaSQL3uVUo2Ze7VwxIeOcAd4C1/JagkVoObb/NLkYDrdvY3JHK1KOfenHVcA==\" crossorigin=\"anonymous\" referrerpolicy=\"no-referrer\"></script>\n<!-- InstanceBeginEditable name=\"added_js\" -->\n<script src=\"js/default.js\"></script> \n<!-- InstanceEndEditable -->\n</body>\n<!-- InstanceEnd --></html>","finalUrl":"https://www.okb-kcs.co.jp/recruit/","rendered":false,"_cachedAt":"2026-06-23T23:11:26.090Z"}