dc.co.jp/wp-json/oembed/1.0/embed?url=http%3A%2F%2Fstdc.co.jp%2Frecruit%2F\" />\n<link rel=\"alternate\" type=\"text/xml+oembed\" href=\"http://stdc.co.jp/wp-json/oembed/1.0/embed?url=http%3A%2F%2Fstdc.co.jp%2Frecruit%2F&#038;format=xml\" />\n<link rel=\"icon\" href=\"http://stdc.co.jp/wp/wp-content/uploads/b2d950f98a3670b332b38a1ec319f988-300x170.png\" sizes=\"32x32\" />\n<link rel=\"icon\" href=\"http://stdc.co.jp/wp/wp-content/uploads/b2d950f98a3670b332b38a1ec319f988-300x170.png\" sizes=\"192x192\" />\n<link rel=\"apple-touch-icon-precomposed\" href=\"http://stdc.co.jp/wp/wp-content/uploads/b2d950f98a3670b332b38a1ec319f988-300x170.png\" />\n<meta name=\"msapplication-TileImage\" content=\"http://stdc.co.jp/wp/wp-content/uploads/b2d950f98a3670b332b38a1ec319f988-300x170.png\" />\n<!-- Global site tag (gtag.js) - Google Analytics -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=UA-2603307-12\"></script>\n<script>\nwindow.dataLayer = window.dataLayer || [];\nfunction gtag(){dataLayer.push(arguments);}\ngtag('js', new Date());\ngtag('config', 'UA-2603307-12');\n</script>\n</head>\n<body>\n<!--[if lt IE 9]>\n<div id=\"ie-notice\">※お使いのブラウザは古いバージョンのためこのホームページをきちんと表示できません。Google Chromeなど最新のブラウザをお使いください。</div>\n<![endif]-->\n<div id=\"wrapper\">\n<div id=\"sec-news\">\n<div class=\"inner\">\n<p><span class=\"date\">2021.07.19</span> <a href=\"http://stdc.co.jp/%e7%94%9f%e7%94%a3%e6%8a%80%e8%a1%93%e8%80%85%e6%ad%a3%e7%a4%be%e5%93%a1%e5%8b%9f%e9%9b%86%e3%81%ae%e3%81%8a%e7%9f%a5%e3%82%89%e3%81%9b/\" class=\"alpha\">生産技術者(正社員)募集のお知らせ</a></p>\n</div>\n</div>\n<header id=\"header\">\n<div class=\"inner cols-2 block-1\">\n<div class=\"col col-1\">\n<h1>ダイカスト(鋳造・鋳物・金型)のことは岐阜県関市の</h1>\n<img src=\"/images/common/logo-mark.png\" alt=\"新東海ダイカスト工業株式会社ロゴマーク\" class=\"retina logo-mark\">\n<h2 class=\"mincho logo\"><a href=\"http://stdc.co.jp/\" class=\"alpha\">新東海ダイカスト工業株式会社</a></h2>\n<p class=\"logo-en\">Shin Tokai Die Casting Industry Co., Ltd.</p>\n</div>\n<div class=\"col col-2\">\n<div class=\"wrap-phone\">\n<div class=\"item-1\"><i class=\"fa fa-phone\"></i> <a href=\"tel:0575-27-3066\">0575-27-3066</a></div>\n<div class=\"item-2\">受付時間 9:00 ~ 17:00 ( 土日を除く )</div>\n</div>\n</div>\n</div>\n<nav id=\"gnavi\">\n<ul class=\"inner transition-a\">\n<li><a href=\"http://stdc.co.jp/about/\">会社案内</a></li>\n<li><a href=\"http://stdc.co.jp/equipment/\">主要設備紹介</a></li>\n<li><a href=\"http://stdc.co.jp/process/\">生産プロセス</a></li>\n<li><a href=\"http://stdc.co.jp/products/\">製品紹介</a></li>\n<li><a href=\"http://stdc.co.jp/access/\">アクセス</a></li>\n<li><a href=\"http://stdc.co.jp/recruit/\">採用情報</a></li>\n<li><a href=\"http://stdc.co.jp/contact/\">お問い合わせ</a></li>\n</ul>\n</nav>\n</header>\n<main role=\"main\" id=\"page\">\n<article id=\"recruit\">\n<section id=\"title-area\" style=\"background-color: rgba(0,79,159,1.00);\">\n<div class=\"inner\">\n<h2 class=\"title mincho\">採用情報</h2>\n<ul class=\"bnavi no-list-style\">\n<li><a href=\"http://stdc.co.jp/\">ホーム</a></li>\n<li class=\"current-page\">採用情報</li>\n</ul>\n</div>\n</section>\n<section id=\"page-01\" class=\"sec-common\">\n<div class=\"inner\">\n<div class=\"left\">\n<div id=\"item-01\" class=\"item\">\n<div class=\"img-right trigger fromBottomOut\">\n<div class=\"wrap-txt\">\n<img src=\"http://stdc.co.jp/wp/wp-content/uploads/IoT.png\" alt=\" 画像\" class=\"wrap-img\">\n<p>生産技術のメンバーは現在4名体制。常務とキャリアのある50代のメンバー、それに30代のメンバーが2名。働きやすさと生産性向上の両立のため、工場の自動化、IOT化を進めています。</p>\n<p>この度、<strong>生産技術スタッフを増員募集</strong>し技術、知識を継承していこうと考えています。 同じ作業を続けるのではなく、新しいことにも積極的にチャレンジできる方を求めています。</p>\n<p>将来的には幹部やリーダー候補も任せていきたいので、経験も大切ですが、<strong>仲間から信頼されるような人柄</strong>を重視して採用を行います。</p>\n<p>次世代養育手当を始め、厚待遇であなたをお迎えしたいと考えています。転職が不利にならないように、収入面もしっかり考慮します。</p>\n</div>\n</div><!-- //Image right-->\n</div>\n<div id=\"item-02\" class=\"item\">\n<h3 class=\"title mincho trigger fromBottomOut\">募集要項</h3>\n<div class=\"cont trigger fromBottomOut\">\n<div class=\"wrap-table-02\">\n<table>\n<tbody>\n<tr>\n<th>仕事の内容</th>\n<td>\n<p>◎設計、機械整備・修理まで幅広い業務をお任せします(生産技術、制御設計)</p>\n<p>【具体的には】<br />\n■生産技術、制御設計の仕事をお任せします。 <br />\n　仕事は、マンツーマンでサポートしていきます。 <br />\n　人により、得手不得手がありますので <br />\n　弱点を強化しつつ、強みを伸ばしていきたいと考えています。 <br />\n　経験者募集ですが、一人前になるまでは3～5年を予定。 <br />\n　あせらず、1つ1つ当社の仕事を覚えていきましょう。 </p>\n<p>■経験やスキルを見ながら教えていきます。 <br />\n　10年後には人に教えられるように、 <br />\n　スキルを磨いて成長してほしいと期待しています。 <br />\n　 <br />\n■下記のような業務を少しずつ覚えて頂きます。 <br />\n・社内および協力工場の機械メンテナンス <br />\n・社内設備のロボット化推進 <br />\n・各種機械の設置工事と立ち上げ <br />\n・ダイカストマシンの周辺機器の設計（製作） <br />\n・ダイカスト品の加工専用機の設計（製作） <br />\n・電気回路設計（シーケンス）</p>\n</td>\n</tr>\n<tr>\n<th>求めている人材</th>\n<td>\n<p>◎生産技術や保守の実務経験がある方、大歓迎　<br />\n◎ダイカスト業界の経験は不問。経験者は優遇します。　</p>\n<p>【具体的には】<br />\n◎CADを使い、図面が書ける方 <br />\n◎制御設計の実務経験があり <br />\n　制御回路の図面が読める方 <br />\n◎分業制ではなく、一貫して業務に携わりたい方 <br />\n◎ＰＣスキルのある方 <br />\n　ワード、エクセルも使いますので <br />\n　知識のある方は役立ちます。 <br />\n◎知らないことや分からないことがあっても、自分で考えたり <br />\n　技術部の仲間に聞いて解決できる方</p>\n</td>\n</tr>\n<tr>\n<th>勤務地</th>\n<td>\n<p>岐阜県関市千疋1061番地1</p>\n<p>【交通手段】<br />\n※車通勤が便利です <br />\n関広見インターから車で約7分 <br />\n関インターより車で約10分</p>\n</td>\n</tr>\n<tr>\n<th>給与</th>\n<td>\n<p>月給25万円～ <br />\n※前職の給与を保証 </p>\n<p>【年収例】<br />\n600万円／入社8年目　月給32万円＋賞与＋各種手当</p>\n</td>\n</tr>\n<tr>\n<th>勤務時間</th>\n<td>\n<p>8:00～16:55</p>\n</td>\n</tr>\n<tr>\n<th>休日・休暇</th>\n<td>\n<p>土日(年間カレンダーによる) <br />\n年末年始 <br />\nGW <br />\n夏期 <br />\n有給休暇<br />\n慶弔 <br />\n※会社カレンダー内に指定有給休暇11日有</p>\n</td>\n</tr>\n<tr>\n<th>待遇・福利厚生</th>\n<td>\n<p>昇給有 <br />\n賞与有 <br />\n(2018度実績　年2回・計6.0ヶ月分　又は　150万円～180万円) <br />\n社会保険完備 　 <br />\n次世代養育手当  <br />\n食事手当 <br />\n車通勤可(無料駐車場有) <br />\n※要任意保険加入 <br />\n交通費規定支給 <br />\n退職金共済 <br />\n退職金制度(規定有) <br />\n勤務延長、再雇用有 <br />\n試用期間3ヶ月/給与変動なし</p>\n</td>\n</tr>\n</tbody>\n</table>\n</div>\n</div>\n</div>\n<div id=\"item-03\" class=\"item\">\n<h3 class=\"title mincho trigger fromBottomOut\">エントリーフォーム</h3>\n<div class=\"cont trigger fromBottomOut\">\n<p>下記フォームの必須項目にすべて入力してください。<br />\n後日担当者よりご連絡差し上げます。</p>\n<div role=\"form\" class=\"wpcf7\" id=\"wpcf7-f156-o1\" lang=\"ja\" dir=\"ltr\">\n<div class=\"screen-reader-response\"></div>\n<form action=\"/recruit/#wpcf7-f156-o1\" method=\"post\" class=\"wpcf7-form\" novalidate=\"novalidate\">\n<div style=\"display: none;\">\n<input type=\"hidden\" name=\"_wpcf7\" value=\"156\" />\n<input type=\"hidden\" name=\"_wpcf7_version\" value=\"5.1\" />\n<input type=\"hidden\" name=\"_wpcf7_locale\" value=\"ja\" />\n<input type=\"hidden\" name=\"_wpcf7_unit_tag\" value=\"wpcf7-f156-o1\" />\n<input type=\"hidden\" name=\"_wpcf7_container_post\" value=\"0\" />\n<input type=\"hidden\" name=\"g-recaptcha-response\" value=\"\" />\n</div>\n<div class=\"form-style-01\">\n<dl>\n<dt>お名前 <span class=\"req\">※必須</span></dt>\n<dd><span class=\"wpcf7-form-control-wrap your-name\"><input type=\"text\" name=\"your-name\" value=\"\" size=\"40\" class=\"wpcf7-form-control wpcf7-text wpcf7-validates-as-required\" aria-required=\"true\" aria-invalid=\"false\" /></span></dd>\n<dt>ふりがな <span class=\"req\">※必須</span></dt>\n<dd><span class=\"wpcf7-form-control-wrap your-furigana\"><input type=\"text\" name=\"your-furigana\" value=\"\" size=\"40\" class=\"wpcf7-form-control wpcf7-text wpcf7-validates-as-required\" aria-required=\"true\" aria-invalid=\"false\" /></span></dd>\n<dt>メールアドレス <span class=\"req\">※必須</span></dt>\n<dd><span class=\"wpcf7-form-control-wrap your-email\"><input type=\"email\" name=\"your-email\" value=\"\" size=\"40\" class=\"wpcf7-form-control wpcf7-text wpcf7-email wpcf7-validates-as-required wpcf7-validates-as-email\" aria-required=\"true\" aria-invalid=\"false\" /></span></dd>\n<dt>電話番号<span class=\"font12\">（携帯可）</span> <span class=\"req\">※必須</span></dt>\n<dd><span class=\"wpcf7-form-control-wrap your-tel\"><input type=\"text\" name=\"your-tel\" value=\"\" size=\"40\" class=\"wpcf7-form-control wpcf7-text wpcf7-validates-as-required\" aria-required=\"true\" aria-invalid=\"false\" /></span></dd>\n<dt>年齢 <span class=\"req\">※必須</span></dt>\n<dd><span class=\"wpcf7-form-control-wrap your-age\"><input type=\"tex