\n<!-- パンくずリスト -->\n<div class=\"c-bread\">\n    <ol itemscope itemtype=\"https://schema.org/BreadcrumbList\" class=\"c-bread__list l-inner\">\n<!-- Breadcrumb NavXT 6.6.0 -->\n\n    <li>\n\t<span itemprop=\"itemListElement\" itemscope itemtype=\"http://schema.org/ListItem\">\n\t\t<a itemprop=\"item\" href=\"https://m-survey.co.jp\"><span itemprop=\"name\">TOP</span></a>\n\t\t<meta itemprop=\"position\" content=\"1\">\n\t</span>\n    </li>\n    <li>\n\t<span itemprop=\"itemListElement\" itemscope itemtype=\"http://schema.org/ListItem\">\n\t\t<a itemprop=\"item\" href=\"https://m-survey.co.jp/news/\"><span itemprop=\"name\">お知らせ</span></a>\n\t\t<meta itemprop=\"position\" content=\"2\">\n\t</span>\n    </li>\n    <li>\n\t<span itemprop=\"itemListElement\" itemscope itemtype=\"http://schema.org/ListItem\">\n\t\t<a itemprop=\"item\" href=\"https://m-survey.co.jp/news/recruit/\"><span itemprop=\"name\">採用情報</span></a>\n\t\t<meta itemprop=\"position\" content=\"3\">\n\t</span>\n    </li>\n    <li>\n\t<span itemprop=\"itemListElement\" itemscope itemtype=\"http://schema.org/ListItem\">\n\t\t<link itemprop=\"item\" href=\"https://m-survey.co.jp/news/recruit/%e3%80%8egis-day-in-%e5%a5%88%e8%89%af2025%e3%80%8f%e3%81%ab%e5%87%ba%e5%b1%95%e3%81%97%e3%81%be%e3%81%97%e3%81%9f/\"><span itemprop=\"name\">『GIS Day in 奈良2025』に出展しました</span>\n\t\t<meta itemprop=\"position\" content=\"4\">\n\t</span>\n    </li>    </ol>\n</div>\n<!-- /パンくずリスト -->\n\n<div class=\"c-pagetitle _detail\">\n    <div class=\"c-pagetitle__inner l-inner\">\n        <h1 class=\"c-pagetitle__name\">『GIS Day in 奈良2025』に出展しました</h1>\n    </div>\n    <div class=\"c-pagetitle__bg\">\n        <picture>\n            <source media=\"(max-width: 768px)\" srcset=\"https://m-survey.co.jp/wp-content/themes/theme/img/cmn/bg_pagetitle_sp.jpg\">\n            <img src=\"https://m-survey.co.jp/wp-content/themes/theme/img/cmn/bg_pagetitle_pc.jpg\" width=\"277\" height=\"196\" decoding=\"async\" alt=\"\">\n        </picture>\n    </div>\n</div>\n\n\n<!-- g-main -->\n<div role=\"main\" class=\"g-main\">\n<!-- q-news-detail -->\r\n<div class=\"q-news-detail\">\r\n<div class=\"c-bg _color_bg\">\r\n<div class=\"padding\">\r\n<div class=\"l-inner\">\r\n\t<section class=\"container\">\r\n\t\t<div class=\"head\">\r\n\t\t\t<time class=\"date\" datetime=\"2025-07-27\">2025.07.27</time>\r\n\t\t\t<div class=\"categories\">\r\n\t\t\t\t<p class=\"c-category\">採用情報</p>\t\t\t</div>\r\n\t\t</div>\r\n\t\t<div class=\"body\">\r\n\t\t\t\t\t<div class=\"post_text\">\n\t\t\t\t\t\t<!-- editor -->\n<p style=\"text-align: left;\">2025年7月27日(日)に「社会基盤としての地図～地理学科での学びを活かして～」をテーマに奈良大学で開催された、「GIS Day in 奈良2025」に出展いたしました。<br />\n当社の出展ブースでは、自社開発GISシステムである「MSYS２」を用いた土地データの活用技術等の展示を行いました。<br />\n加えて、当社在籍の奈良大学卒業生より、ミニ講演を実施させていただきました。<br />\n当社ブースへ足を運んでいただいた皆様に感謝申し上げます。</p>\n<p>&nbsp;</p>\n<div class=\"p-templateB\">\n\t<div class=\"p-templateB__item\">\n\t\t<div class=\"p-templateB__image\">\n            <img src=\"https://m-survey.co.jp/wp-content/uploads/2025/08/IMG_6149-scaled-e1754037014700-300x198.jpg\" alt=\"\">\n\t\t</div>\n\t\t<div class=\"p-templateB__desc\">\n            <p>ブース出展</p>\n\t\t</div>\n\t</div> \t\t\t\t\t\n\t<div class=\"p-templateB__item\">\n\t\t<div class=\"p-templateB__image\">\n            <img src=\"https://m-survey.co.jp/wp-content/uploads/2025/08/IMG_6142-300x198.jpg\" alt=\"\">\n\t\t</div>\n\t\t<div class=\"p-templateB__desc\">\n\t\t\t<p>ミニ講演</p>\n\t\t</div>\n\t</div>\n</div>\n\t\t\t\t\t\t<!-- /editor -->\n                    </div>\n\t\t</div>\r\n\t</section>\r\n\r\n\t<div class=\"c-pager _margin-top\">\r\n\t\t<div class=\"c-pager__item _prev\">\r\n\t\t\t<a href=\"https://m-survey.co.jp/news/business-award/%e4%bb%a4%e5%92%8c%ef%bc%97%e5%b9%b4%e3%80%80%e5%85%ac%e5%85%b1%e6%b8%ac%e9%87%8f%e5%93%81%e8%b3%aa%e7%ae%a1%e7%90%86%e5%84%aa%e7%a7%80%e8%b3%9e%ef%bc%88%e5%9f%ba%e6%ba%96%e7%82%b9%ef%bc%89/\">\r\n\t\t\t\t<span class=\"c-pager__arrow\">\r\n\t\t\t\t\t<svg class=\"reset-svg\" width=\"16.727\" hei