{"url":"https://www.inahara.co.jp/recruit/","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n\n<head prefix=\"og: https://ogp.me/ns# fb: https://ogp.me/ns/fb# website: https://ogp.me/ns/website#\">\n\n<!-- Google tag (gtag.js) -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-1HPD70193M\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'G-1HPD70193M');\n</script>\n\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width,initial-scale=1.0,minimum-scale=1.0,maximum-scale=5.0,user-scalable=1\">\n    <meta name=\"format-detection\" content=\"telephone=no\">\n    \n    <title>株式会社イナハラ 採用案内｜誰かの“役に立つ”自分でいたい。</title>\n    <meta name=\"description\" content=\"株式会社イナハラの採用案内。ITを通じて企業の課題を解決し、働く人を支える仕事です。営業・技術が連携し、お客様に寄り添う環境で成長したい方を募集しています。\">\n    <link rel=\"canonical\" href=\"https://www.inahara.co.jp/recruit/\">\n    <meta property=\"og:type\" content=\"website\">\n    <meta property=\"og:title\" content=\"株式会社イナハラ 採用案内｜誰かの“役に立つ”自分でいたい。\">\n    <meta property=\"og:description\" content=\"株式会社イナハラの採用案内。ITを通じて企業の課題を解決し、働く人を支える仕事です。営業・技術が連携し、お客様に寄り添う環境で成長したい方を募集しています。\">\n    <meta property=\"og:url\" content=\"https://www.inahara.co.jp/recruit/\">\n    <meta property=\"og:image\" content=\"https://www.inahara.co.jp/recruit/img/common/ogp.png\">\n    <meta property=\"og:locale\" content=\"ja_JP\">\n\n    <meta name=\"twitter:card\" content=\"summary_large_image\">\n    <meta name=\"twitter:title\" content=\"株式会社イナハラ 採用案内｜誰かの“役に立つ”自分でいたい。\">\n    <meta name=\"twitter:description\" content=\"株式会社イナハラの採用案内。ITを通じて企業の課題を解決し、働く人を支える仕事です。営業・技術が連携し、お客様に寄り添う環境で成長したい方を募集しています。\">\n    <meta name=\"twitter:url\" content=\"https://www.inahara.co.jp/recruit/\">\n    <meta name=\"twitter:image\" content=\"https://www.inahara.co.jp/recruit/img/common/ogp.png\">\n\n    <link rel=\"icon\" type=\"image/png\" href=\"./img/favicon/favicon-96x96.png\" sizes=\"96x96\" />\n    <link rel=\"icon\" type=\"image/svg+xml\" href=\"./img/favicon/favicon.svg\" />\n    <link rel=\"shortcut icon\" href=\"./img/favicon/favicon.ico\" />\n    <link rel=\"apple-touch-icon\" sizes=\"180x180\" href=\"./img/favicon/apple-touch-icon.png\" />\n\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n    <link href=\"https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=Noto+Sans+JP:wght@100..900&family=Zen+Kaku+Gothic+New:wght@300;400;500;700;900&family=Zen+Maru+Gothic:wght@300;400;500;700;900&display=swap\" rel=\"stylesheet\">\n    <link rel=\"stylesheet\" href=\"./css/common.css\">\n    <link rel=\"stylesheet\" href=\"css/index.css\">\n</head>\n\n<body>\n    <div id=\"wrapper\">\n        <header id=\"header\" role=\"banner\">\n                            <h1 class=\"site-title\">\n                    <a class=\"logo\" href=\"./\">\n                        <img src=\"./img/common/logo.svg\" alt=\"株式会社イナハラ\">\n                        <p>採用案内</p>\n                    </a>\n                </h1>\n                        <nav class=\"nav\" role=\"navigation\">\n                <ul class=\"main-list\">\n                    <li class=\"has-dropdown\">\n                        <a class=\"hierarchy1\">新卒採用</a>\n                        <ul class=\"dropdown\">\n                            <li><a href=\"./graduate-advisor\">ITアドバイザー</a></li>\n                            <li><a href=\"./graduate-service\">ITサービス</a></li>\n                        </ul>\n                    </li>\n                    <li class=\"has-dropdown\">\n                        <a class=\"hierarchy1\">キャリア採用</a>\n                        <ul class=\"dropdown\">\n                            <li><a href=\"./career-advisor\">ITアドバイザー</a></li>\n                        </ul>\n                    </li>\n                    <li><a class=\"hierarchy1\" href=\"./faq\">よくある質問</a></li>\n                </ul>\n                <a class=\"entry-btn\" href=\"./form/entry\" target=\"_blank\">エントリー</a>\n            </nav>\n            <button type=\"button\" class=\"menu-btn\" aria-label=\"メニュー\"><span></span></button>\n        </header>\n        <main role=\"main\" id=\"container\">\n<div id=\"fv\">\n    <div class=\"texts\">\n        <p class=\"fv-title\">誰かの<br><span>“</span>役に立つ<span>”</span><br>自分でいたい</p>\n        <p class=\"slogan\">地域で働く人々を<br>助けることが仕事になる</p>\n    </div>\n    <div class=\"rotating-circle\">\n        <img src=\"./img/index/rotating_circle.png\" alt=\"\">\n    </div>\n    <div class=\"image-boxes\">\n        <div class=\"image-box image-box1\">\n            <img src=\"./img/index/fv11.svg\" alt=\"\">\n            <img src=\"./img/index/fv12.svg\" alt=\"\">\n        </div>\n        <div class=\"image-box image-box2\">\n            <img src=\"./img/index/fv21.svg\" alt=\"\">\n            <img src=\"./img/index/fv22.svg\" alt=\"\">\n        </div>\n        <div class=\"image-box image-box3\">\n            <img src=\"./img/index/fv31.svg\" alt=\"\">\n            <img src=\"./img/index/fv32.svg\" alt=\"\">\n        </div>\n        <div class=\"image-box image-box4\">\n            <img src=\"./img/index/fv41.svg\" alt=\"\">\n            <img src=\"./img/index/fv42.svg\" alt=\"\">\n        </div>\n        <div class=\"image-box image-box5\">\n            <img src=\"./img/index/fv51.svg\" alt=\"\">\n            <img src=\"./img/index/fv52.svg\" alt=\"\">\n        </div>\n        <div class=\"image-box image-box6\">\n            <img src=\"./img/index/fv61.svg\" alt=\"\">\n            <img src=\"./img/index/fv62.svg\" alt=\"\">\n        </div>\n    </div>\n</div>\n\n<div class=\"inner w1440\">\n    <div id=\"management\" class=\"common-section scroll-reveal\">\n        <div class=\"left-img sp-off\">\n            <img src=\"./img/index/illust01.svg\" alt=\"\">\n        </div>\n        <div class=\"right-txt\">\n            <h2 class=\"txt1\">経営スタイル</h2>\n            <p class=\"txt2\">急成長より、<br>確かな成長を</p>\n            <div class=\"sp-img pc-off\">\n                <img src=\"./img/index/illust01.svg\" alt=\"\">\n            </div>\n            <p class=\"txt3\">\n                急成長だけを追いかければ、見失ってしまうものがあります<br>\n\t\tだから私たちは、一歩ずつ着実に積み重ねる「確かな成長」<br class=\"sp-off\">\n\t\tを選びます<br>\n\t\t派手さよりも、本質<br>\n\t\t近道よりも、積み重ね<br>\n\t\t木の年輪のように、時間をかけて強くなる会社でありたいと<br class=\"sp-off\">\n\t\t考えています<br>\n\t\t<br>\n                創業以来、2万社を超えるお客様との対話を重ね、<br class=\"sp-off\">\n                その一つひとつが提案力への信頼を築いてきました<br>\n                目指すのは、働きやすいオフィス環境<br>\n                <br>\n                その先にある、働く人の笑顔や「ありがとう」を何よりの価値として、これからもお客様に寄り添います\n            </p>\n        </div>\n    </div>\n\n    <div id=\"strength\" class=\"common-section\">\n        <h2 class=\"section-title\">3つの強み</h2>\n        <p class=\"section-description\">お客様の課題に向き合う中で培ってきた、私たちの3つの強み<br>それぞれの力が組み合わさることで、質の高い働き方へ貢献しています</p>\n        <div class=\"format scroll-reveal\">\n            <div class=\"left-image\">\n                <img src=\"./img/index/illust_strength.svg\" alt=\"3つの強み\">\n            </div>\n            <div class=\"right-text\">\n                <div class=\"item\">\n                    <img src=\"./img/index/illust_strength1.svg\" alt=\"\">\n                    <div class=\"text\">\n                        <p class=\"text1\">チームで考える提案</p>\n                        <p class=\"text2\">営業・技術・支援の社員チームで<br>お客様の業務課題に向き合う</p>\n                    </div>\n                </div>\n                <div class=\"item\">\n                    <img src=\"./img/index/illust_strength2.svg\" alt=\"\">\n                    <div class=\"text\">\n                        <p class=\"text1\">国内100社以上メーカー商品</p>\n                        <p class=\"text2\">最適な商品で、<br>業務課題を解決</p>\n                    </div>\n                </div>\n                <div class=\"item\">\n                    <img src=\"./img/index/illust_strength3.svg\" alt=\"\">\n                    <div class=\"text\">\n                        <p class=\"text1\">迅速で丁寧なサポート</p>\n                        <p class=\"text2\">日常を止めない、<br>安心と安定を守る技術力</p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n\n    <div id=\"business\" class=\"common-section\">\n        <h2 class=\"section-title\">イナハラの事業</h2>\n        <div class=\"format scroll-reveal\">\n            <div class=\"absolute-txt\">\n                <p class=\"big\">複雑な経営課題を、<br>6つの事業で最適化</p>\n                <p class=\"small\">私たちは笑顔で働ける「ワークスタイル」を提案しています<br>オフィス内の事業領域をシンプルに6つに分け、<br class=\"sp-off\">企業の経営課題に合わせた<br class=\"sp-off\">最新のソリューションで働く人を応援します</p>\n            </div>\n            <div class=\"big-illust-container\">\n                <div class=\"big-illust\">\n                    <img class=\"big-illust-bg\" src=\"./img/index/big_illust_bg.svg\" alt=\"\">\n                    <button type=\"button\" class=\"business-spot\" data-modal=\"1\" aria-label=\"ドキュメントソリューション\"><img src=\"./img/index/btn1.svg\" alt=\"\"></button>\n                    <button type=\"button\" class=\"business-spot\" data-modal=\"2\" aria-label=\"サービス＆サポート保守\"><img src=\"./img/index/btn2.svg\" alt=\"\"></button>\n                    <button type=\"button\" class=\"business-spot\" data-modal=\"3\" aria-label=\"オフィスサプライ\"><img src=\"./img/index/btn3.svg\" alt=\"\"></button>\n                    <button type=\"button\" class=\"business-spot\" data-modal=\"4\" aria-label=\"オフィスデザイン\"><img src=\"./img/index/btn4.svg\" alt=\"\"></button>\n                    <button type=\"button\" class=\"business-spot\" data-modal=\"5\" aria-label=\"通信・コミュニケーション\"><img src=\"./img/index/btn5.svg\" alt=\"\"></button>\n                    <button type=\"button\" class=\"business-spot\" data-modal=\"6\" aria-label=\"システムソリューション\"><img src=\"./img/index/btn6.svg\" alt=\"\"></button>\n                </div>\n                <div class=\"icon-sp-scroll pc-off\">\n                    <img src=\"./img/index/icon_sp_scroll.svg\" alt=\"\">\n                </div>\n            </div>\n        </div>\n        <!-- 事業モーダル：6 つの内容を data-modal で切り替え -->\n        <div id=\"business-modal\" class=\"modal-overlay\" aria-hidden=\"true\">\n            <div class=\"modal-panel\" id=\"modal-panel1\">\n                <button type=\"button\" class=\"modal-close\" aria-label=\"閉じる\"></button>\n                <p class=\"modal-category\">ドキュメントソリューション</p>\n                <p class=\"modal-title\">\n                    デジタル化による<br>\n                    情報共有と活用に向けたご提案\n                </p>\n                <div class=\"modal-image\">\n                    <figure>\n                        <img src=\"./img/index/business11.png\" alt=\"\" />\n                        <figcaption>複合機</figcaption>\n                    </figure>\n                    <figure>\n                        <img src=\"./img/index/business13.png\" alt=\"\" />\n                        <figcaption>レーサープリンター</figcaption>\n                    </figure>\n                    <figure>\n                        <img src=\"./img/index/business12.png\" alt=\"\" />\n                        <figcaption>大判プリンター</figcaption>\n                    </figure>\n                    <figure>\n                        <img src=\"./img/index/business14.png\" alt=\"\" />\n                        <figcaption>電子文書管理ソフト</figcaption>\n                    </figure>\n                </div>\n            </div>\n            <div class=\"modal-panel\" id=\"modal-panel2\">\n                <button type=\"button\" class=\"modal-close\" aria-label=\"閉じる\"></button>\n                <p class=\"modal-category\">サービス＆サポート保守</p>\n                <p class=\"modal-title\">\n                    機器の導入・設定から<br>\n                    点検・修理・保守まで、迅速確実に対応\n                </p>\n                <div class=\"modal-image\">\n                    <figure>\n                        <img src=\"./img/index/business21.png\" alt=\"\" />\n                        <figcaption>ハード・ソフトウェア<br>設置設定</figcaption>\n                    </figure>\n                    <figure>\n                        <img src=\"./img/index/business22.png\" alt=\"\" />\n                        <figcaption>ネットワーク構築</figcaption>\n                    </figure>\n                    <figure>\n                        <img src=\"./img/index/business23.png\" alt=\"\" />\n                        <figcaption>出張・預り修理</figcaption>\n                    </figure>\n                    <figure>\n                        <img src=\"./img/index/business24.png\" alt=\"\" />\n                        <figcaption>データ復旧</figcaption>\n                    </figure>\n                </div>\n            </div>\n            <div class=\"modal-panel\" id=\"modal-panel3\">\n                <button type=\"button\" class=\"modal-close\" aria-label=\"閉じる\"></button>\n                <p class=\"modal-category\">オフィスサプライ</p>\n                <p class=\"modal-title\">\n                    各種メーカーの消耗品を一元的に集約することで<br>\n                    発注管理の手間を削減\n                </p>\n                <div class=\"modal-image\">\n                    <figure>\n                        <img src=\"./img/index/business31.png\" alt=\"\" />\n                        <figcaption>トナーカートリッジ</figcaption>\n                    </figure>\n                    <figure>\n                        <img src=\"./img/index/business32.png\" alt=\"\" />\n                        <figcaption>インク</figcaption>\n                    </figure>\n                    <figure>\n                        <img src=\"./img/index/business33.png\" alt=\"\" />\n                        <figcaption>アスクル</figcaption>\n                    </figure>\n                    <figure>\n                        <img src=\"./img/index/business34.png\" alt=\"\" />\n                        <figcaption>各種消耗品</figcaption>\n                    </figure>\n                </div>\n            </div>\n            <div class=\"modal-panel\" id=\"modal-panel4\">\n                <button type=\"button\" class=\"modal-close\" aria-label=\"閉じる\"></button>\n                <p class=\"modal-category\">オフィスデザイン</p>\n                <p class=\"modal-title\">\n                    オフィス家具から<br>\n                    先進的な空間デザインまで、ワンストップで実現\n                </p>\n                <div class=\"modal-image\">\n                    <figure>\n                        <img src=\"./img/index/business41.png\" alt=\"\" />\n                        <figcaption>オフィス空間<br>デザイン</figcaption>\n                    </figure>\n                    <figure>\n                        <img src=\"./img/index/business42.png\" alt=\"\" />\n                        <figcaption>フリーアドレス<br>システム</figcaption>\n                    </figure>\n                    <figure>\n                        <img src=\"./img/index/business43.png\" alt=\"\" />\n                        <figcaption>デジタルサイネージ</figcaption>\n                    </figure>\n                    <figure>\n                        <img src=\"./img/index/business44.png\" alt=\"\" />\n                        <figcaption>CAD図面作成</figcaption>\n                    </figure>\n                </div>\n            </div>\n            <div class=\"modal-panel\" id=\"modal-panel5\">\n                <button type=\"button\" class=\"modal-close\" aria-label=\"閉じる\"></button>\n                <p class=\"modal-category\">通信・コミュニケーション</p>\n                <p class=\"modal-title\">\n                    通信機器導入から<br>\n                    通信インフラの整備・運用まで幅広く対応\n                </p>\n                <div class=\"modal-image\">\n                    <figure>\n                        <img src=\"./img/index/business51.png\" alt=\"\" />\n                        <figcaption>ビジネスフォン</figcaption>\n                    </figure>\n                    <figure>\n                        <img src=\"./img/index/business52.png\" alt=\"\" />\n                        <figcaption>スマートフォン</figcaption>\n                    </figure>\n                    <figure>\n                        <img src=\"./img/index/business53.png\" alt=\"\" />\n                        <figcaption>ネットワークカメラ</figcaption>\n                    </figure>\n                    <figure>\n                        <img src=\"./img/index/business54.png\" alt=\"\" />\n                        <figcaption>WEB会議システム</figcaption>\n                    </figure>\n                </div>\n            </div>\n            <div class=\"modal-panel\" id=\"modal-panel6\">\n                <button type=\"button\" class=\"modal-close\" aria-label=\"閉じる\"></button>\n                <p class=\"modal-category\">システムソリューション</p>\n                <p class=\"modal-title\">\n                    ビジネスインフラである<br>\n                    ネットワークに関するハード&ソフトをご提案\n                </p>\n                <div class=\"modal-image\">\n                    <figure>\n                        <img src=\"./img/index/business61.png\" alt=\"\" />\n                        <figcaption>パソコン</figcaption>\n                    </figure>\n                    <figure>\n                        <img src=\"./img/index/business63.png\" alt=\"\" />\n                        <figcaption>サーバー</figcaption>\n                    </figure>\n                    <figure>\n                        <img src=\"./img/index/business62.png\" alt=\"\" />\n                        <figcaption>基幹ソフト</figcaption>\n                    </figure>\n                    <figure>\n                        <img src=\"./img/index/business64.png\" alt=\"\" />\n                        <figcaption>セキュリティ対策機器</figcaption>\n                    </figure>\n                </div>\n            </div>\n        </div>\n    </div>\n\n    <div id=\"work\" class=\"common-section\">\n        <h2 class=\"section-title\">イナハラの仕事</h2>\n        <div class=\"switch-block scroll-reveal\">\n            <div class=\"switch-titles\">\n                <p class=\"switch-title active\">\n                    <span>ITアドバイザー<br class=\"pc-off\">(営業職)</span>\n                    <img src=\"./img/index/arrow_switch.svg\" alt=\"\">\n                </p>\n                <p class=\"switch-title\">\n                    <span>ITサービス<br class=\"pc-off\">(技術職)</span>\n                    <img src=\"./img/index/arrow_switch.svg\" alt=\"\">\n                </p>\n            </div>\n            <div class=\"switch-contents\">\n                <div class=\"switch-content active\">\n                    <div class=\"box\">\n                        <div class=\"lefty\">\n                            <p class=\"title\">提案するのは、<br>オフィスの先にある働く人たちの未来</p>\n                            <p class=\"description\">\n                                担当エリアのお客様へ営業活動を行い、課題やお困りごとをお伺いし、幅広い商材を組み合わせてオフィス環境の解決提案を行います<br>\n                                単なる機器の提供にとどまらず、業務効率や働きやすさの向上に貢献し、お客様と並走するお仕事です\n                            </p>\n                        </div>\n                        <div class=\"righty\">\n                            <img src=\"./img/index/illust_work.svg\" alt=\"\">\n                        </div>\n                    </div>\n                    <div class=\"buttons\">\n                        <a class=\"button\" href=\"./graduate-advisor\">新卒採用</a>\n                        <a class=\"button\" href=\"./career-advisor\">キャリア採用</a>\n                    </div>\n                </div>\n                <div class=\"switch-content\">\n                    <div class=\"box\">\n                        <div class=\"lefty\">\n                            <p class=\"title\">一番近くで、<br>頼られる仕事</p>\n                            <p class=\"description\">\n                                複合機やパソコンなどIT機器の点検・メンテナンスを担当し、トラブル時には迅速に対応を行います<br>\n                                機器の復旧にとどまらず、お客様の不安を解消し、安心して働ける環境を支える、身近で頼られる存在です\n                            </p>\n                        </div>\n                        <div class=\"righty\">\n                            <img src=\"./img/index/illust_work2.svg\" alt=\"\">\n                        </div>\n                    </div>\n                    <div class=\"buttons\">\n                        <a class=\"button\" href=\"./graduate-service\">新卒採用</a>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n\n    <div id=\"data\" class=\"common-section\">\n        <h2 class=\"section-title\">数字で見るイナハラ</h2>\n        <div class=\"items scroll-reveal\">\n            <div class=\"item\">\n                <img class=\"icon\" src=\"./img/index/icon_data1.svg\" alt=\"\">\n                <p class=\"desc\">創業<br><span class=\"ascending-number\">99</span>年</p>\n            </div>\n            <div class=\"item\">\n                <img class=\"icon\" src=\"./img/index/icon_data2.svg\" alt=\"\">\n                <p class=\"desc\">年間休日日数<br><span class=\"ascending-number\">125</span>日以上</p>\n            </div>\n            <div class=\"item\">\n                <img class=\"icon\" src=\"./img/index/icon_data3.svg\" alt=\"\">\n                <p class=\"desc\">有給休暇平均取得率<br><span class=\"ascending-number\">65.7</span>%</p>\n            </div>\n            <div class=\"item\">\n                <img class=\"icon\" src=\"./img/index/icon_data4.svg\" alt=\"\">\n                <p class=\"desc\">月平均残業時間<br><span class=\"ascending-number\">20</span>時間</p>\n            </div>\n            <div class=\"item\">\n                <img class=\"icon\" src=\"./img/index/icon_data5.svg\" alt=\"\">\n                <p class=\"desc\">自己資本比率<br><span class=\"ascending-number\">53</span>%</p>\n            </div>\n            <div class=\"item\">\n                <img class=\"icon\" src=\"./img/index/icon_data6.svg\" alt=\"\">\n                <p class=\"desc\">平均勤続年数<br><span class=\"ascending-number\">19</span>年</p>\n            </div>\n        </div>\n    </div>\n\n    <div id=\"benefit\" class=\"common-section\">\n        <h2 class=\"section-title\">福利厚生</h2>\n        <p class=\"section-description\">社員がいきいきと活躍し安心して働けるための各種制度を設けています<br>休暇や社会保険はもちろん、<br class=\"sp-br\">学びの環境とワークライフバランスの環境を整えています</p>\n        <div class=\"items scroll-reveal\">\n            <div class=\"item\">\n                <img class=\"icon\" src=\"./img/index/icon_benefit03.svg\" alt=\"\">\n                <p class=\"desc\">完全週休2日制<br>（土・日・祝休み）</p>\n            </div>\n            <div class=\"item\">\n                <img class=\"icon\" src=\"./img/index/icon_benefit04.svg\" alt=\"\">\n                <p class=\"desc\">有給休暇<br>（入社時10日間付与）</p>\n            </div>\n            <div class=\"item\">\n                <img class=\"icon\" src=\"./img/index/icon_benefit01.svg\" alt=\"\">\n                <p class=\"desc\">通年ノーネクタイ</p>\n            </div>\n            <div class=\"item\">\n                <img class=\"icon\" src=\"./img/index/icon_benefit02.svg\" alt=\"\">\n                <p class=\"desc\">かばん購入補助1万円<br>（何回でもOK）</p>\n            </div>\n            <div class=\"item\">\n                <img class=\"icon\" src=\"./img/index/icon_benefit09.svg\" alt=\"\">\n                <p class=\"desc\">予算達成打上費用<br>（拠点全員に毎月支給）</p>\n            </div>\n            <div class=\"item\">\n                <img class=\"icon\" src=\"./img/index/icon_benefit06.svg\" alt=\"\">\n                <p class=\"desc\">若年層家賃補助<br>（30歳まで毎月支給）</p>\n            </div>\n            <div class=\"item\">\n                <img class=\"icon\" src=\"./img/index/icon_benefit05.svg\" alt=\"\">\n                <p class=\"desc\">通勤交通費全額支給<br>（上限なし）</p>\n            </div>\n            <div class=\"item\">\n                <img class=\"icon\" src=\"./img/index/icon_benefit08.svg\" alt=\"\">\n                <p class=\"desc\">資格取得支援<br>（試験料を毎回全額支給）</p>\n            </div>\n            <div class=\"item\">\n                <img class=\"icon\" src=\"./img/index/icon_benefit10.svg\" alt=\"\">\n                <p class=\"desc\">インフルエンザ予防接種<br>（毎年全額支給）</p>\n            </div>\n            <div class=\"item\">\n                <img class=\"icon\" src=\"./img/index/icon_benefit07.svg\" alt=\"\">\n                <p class=\"desc\">退職金制度<br>中小企業退職金共済<br><span>※65歳まで積立</span></p>\n            </div>\n            <div class=\"item\">\n                <img class=\"icon\" src=\"./img/index/icon_benefit11.svg\" alt=\"\">\n                <p class=\"desc\">永続勤続表彰<br>（10年・20年・30年・40年）</p>\n            </div>\n            <div class=\"item\">\n                <img class=\"icon\" src=\"./img/index/icon_benefit12.svg\" alt=\"\">\n                <p class=\"desc\">育児休業制度</p>\n            </div>\n        </div>\n    </div>\n\n    <div id=\"certification\" class=\"common-section\">\n        <h2 class=\"section-title\">各種認定・実績</h2>\n        <div class=\"cards scroll-reveal\">\n            <div class=\"card\">\n                <img src=\"./img/index/certification3.png\" alt=\"\">\n                <p class=\"big-text\">健康経営優良法人2026<br>（中小規模法人部門）</p>\n                <p class=\"small-text\">2026年3月9日</p>\n                <p class=\"small-text\">日本健康会議</p>\n            </div>\n            <div class=\"card\">\n                <img src=\"./img/index/certification2.png\" alt=\"\">\n                <p class=\"big-text\">「わが社の健康宣言」<br>登録認定</p>\n                <p class=\"small-text\">2017年10月2日</p>\n                <p class=\"small-text\">全国健康保険協会　兵庫支部</p>\n            </div>\n            <div class=\"card\">\n                <img src=\"./img/index/certification1.png\" alt=\"\">\n                <p class=\"big-text\">ひょうご仕事と生活の<br>調和推進企業宣言</p>\n                <p class=\"small-text\">2013年10月18日</p>\n                <p class=\"small-text\">公益財団法人兵庫県勤労福祉協会<br>ひょうご仕事と生活センター</p>\n            </div>\n        </div>\n    </div>\n\n    <div id=\"training\" class=\"common-section\">\n        <h2 class=\"section-title\">研修制度</h2>\n        <p class=\"section-description\">ITアドバイザーとして成長するための<br class=\"sp-br\">体系的研修制度</p>\n        <div class=\"items scroll-reveal\">\n            <div class=\"item\">\n                <img class=\"icon\" src=\"./img/index/icon_training1.svg\" alt=\"\">\n                <p class=\"desc\">社会人基礎・マナー研修</p>\n                <p class=\"supplement\">信頼される社会人としての<br>基本行動・ビジネスマナーを<br class=\"sp-br\">習得</p>\n            </div>\n            <div class=\"item\">\n                <img class=\"icon\" src=\"./img/index/icon_training2.svg\" alt=\"\">\n                <p class=\"desc\">会社理解・<br>社内システム理解</p>\n                <p class=\"supplement\">イナハラの<br class=\"sp-off\">理念・歴史・<br class=\"sp-br\">業務フローを理解</p>\n            </div>\n            <div class=\"item\">\n                <img class=\"icon\" src=\"./img/index/icon_training3.svg\" alt=\"\">\n                <p class=\"desc\">商品・ネットワーク知識</p>\n                <p class=\"supplement\">IT機器・ネットワークの<br>基礎から実践知識まで</p>\n            </div>\n            <div class=\"item\">\n                <img class=\"icon\" src=\"./img/index/icon_training4.svg\" alt=\"\">\n                <p class=\"desc\">営業プロセス理解</p>\n                <p class=\"supplement\">ヒアリングから提案・受注<br>までの再現性ある営業</p>\n            </div>\n            <div class=\"item\">\n                <img class=\"icon\" src=\"./img/index/icon_training5.svg\" alt=\"\">\n                <p class=\"desc\">セールススキル習得</p>\n                <p class=\"supplement\">課題発見力・提案力を磨く<br>実践型研修</p>\n            </div>\n            <div class=\"item\">\n                <img class=\"icon\" src=\"./img/index/icon_training6.svg\" alt=\"\">\n                <p class=\"desc\">提案書作成</p>\n                <p class=\"supplement\">お客様に伝わる<br>構成・資料作成スキル</p>\n            </div>\n            <div class=\"item\">\n                <img class=\"icon\" src=\"./img/index/icon_training7.svg\" alt=\"\">\n                <p class=\"desc\">6事業展開と<br>チームセリング</p>\n                <p class=\"supplement\">6つの事業を活かした<br>チーム営業を理解</p>\n            </div>\n            <div class=\"item\">\n                <img class=\"icon\" src=\"./img/index/icon_training8.svg\" alt=\"\">\n                <p class=\"desc\">目標・計画立案と効率活動</p>\n                <p class=\"supplement\">成果につながる目標設定と<br>営業行動管理</p>\n            </div>\n        </div>\n    </div>\n\n    <div id=\"career-up\" class=\"common-section\">\n        <h2 class=\"section-title\">キャリアアップ</h2>\n        <div class=\"switch-block scroll-reveal\">\n            <div class=\"switch-titles\">\n                <p class=\"switch-title active\">\n                    <span>管理職コース</span>\n                    <img src=\"./img/index/arrow_switch.svg\" alt=\"\">\n                </p>\n                <p class=\"switch-title\">\n                    <span>専任コース</span>\n                    <img src=\"./img/index/arrow_switch.svg\" alt=\"\">\n                </p>\n            </div>\n            <div class=\"switch-contents\">\n                <div class=\"switch-content active\">\n                    <div class=\"picture-box\">\n                        <img class=\"picture\" src=\"./img/index/illust_up.svg\" alt=\"\">\n                        <img class=\"running-people\" src=\"./img/index/illust_character.svg\" alt=\"\">\n                    </div>\n                    <div class=\"icon-sp-scroll pc-off\">\n                        <img src=\"./img/index/icon_sp_scroll.svg\" alt=\"\">\n                    </div>\n                </div>\n                <div class=\"switch-content\">\n                    <div class=\"picture-box\">\n                        <img class=\"picture\" src=\"./img/index/illust_up2.svg\" alt=\"\">\n                        <img class=\"running-people\" src=\"./img/index/illust_character2.svg\" alt=\"\">\n                    </div>\n                    <div class=\"icon-sp-scroll pc-off\">\n                        <img src=\"./img/index/icon_sp_scroll.svg\" alt=\"\">\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n\n    <div id=\"message\" class=\"common-section\">\n        <h2 class=\"section-title\">社長メッセージ</h2>\n        <div class=\"article scroll-reveal\">\n            <img class=\"left-image\" src=\"./img/index/illust_message.svg\" alt=\"\">\n            <p class=\"mid-text\">地域で働く人を<br>支えたい</p>\n            <div class=\"right-text\">\n                <p class=\"content\">\n                    効率的な働き方が求められている世の中ですが、実はITをうまく使えずに悩んでいる会社はたくさんあります<br>\n                    実際、従業員数100名未満の中小企業は、50％以上がIT担当者不在で相談相手がいないという問題を抱えています<br>\n                    <br>\n                    当社はそういう会社の<span class=\"underline\">『良き相談相手、よきパートナー』</span>として、IT機器の導入前相談から導入後のサポートまで、すべてを支えています<br>\n                    <br>\n                    そしてお客様に喜んでいただき、また次も頼みますとおっしゃっていただける関係を目指して取り組んでいます<br>\n                    <br>\n                    当社の理念に共感し、<span class=\"underline\">“地域で働く人を支えたい”</span>という方のご応募をお待ちしております\n                </p>\n                <p class=\"name\">\n                    <img src=\"./img/index/signature-pre.png\" alt=\"\">\n                    <img src=\"./img/index/signature.png\" alt=\"稲原 達郎\">\n                </p>\n            </div>\n        </div>\n    </div>\n\n    <div id=\"faq\" class=\"scroll-reveal\">\n        <a class=\"box\" href=\"./faq\">\n            <div class=\"left\">\n                <img src=\"./img/index/icon_faq.svg\" alt=\"\">\n            </div>\n            <div class=\"mid\">\n                <p class=\"huge-txt\">よくある質問</p>\n                <p class=\"tiny-txt\">応募者の方から、よくいただくご質問をご紹介します</p>\n            </div>\n            <div class=\"right\">\n                <img src=\"./img/index/arrow_orange.svg\" alt=\"\">\n            </div>\n        </a>\n    </div>\n</div>\n\n</main>\n<div class=\"common-entry\">\n    <div class=\"inner w1440\">\n        <h2 class=\"entry-title\">エントリーはこちらから</h2>\n        <div class=\"boxes\">\n            <div class=\"box\">\n                <h3 class=\"type\">新卒採用</h3>\n                <div class=\"buttons\">\n                    <a class=\"button\" href=\"./form/entry\" target=\"_blank\">エントリーする</a>\n                    <a class=\"button\" href=\"https://job.mynavi.jp/27/pc/search/corp272359/outline.html\" target=\"_blank\" rel=\"noopener\">マイナビ</a>\n                </div>\n            </div>\n            <div class=\"box\">\n                <h3 class=\"type\">キャリア採用</h3>\n                <div class=\"buttons\">\n                    <a class=\"button\" href=\"./form/entry\" target=\"_blank\">エントリーする</a>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n<footer id=\"footer\" role=\"contentinfo\">\n    <a class=\"to-top\" href=\"#wrapper\">\n        <img src=\"./img/common/to_top.svg\" alt=\"トップへ戻る\">\n    </a>\n    <div class=\"inner w1440\">\n        <div class=\"footer-main\">\n            <div class=\"left-profile\">\n                <img class=\"logo\" src=\"./img/common/logo.svg\" alt=\"株式会社イナハラ\">\n                <p class=\"company-name\">株式会社イナハラ</p>\n                <p class=\"address\">\n                    本社<br>\n                    〒651-0086　<br class=\"pc-off\">兵庫県神戸市中央区磯上通4-1-26<br>\n                    TEL: <a href=\"tel:078-231-4088\">078-231-4088</a>\n                </p>\n            </div>\n            <div class=\"right-links\">\n                <div class=\"column\">\n                    <p class=\"type\">新卒採用</p>\n                    <ul class=\"list\">\n                        <li><a href=\"./graduate-advisor\">ITアドバイザー</a></li>\n                        <li><a href=\"./graduate-service\">ITサービス</a></li>\n                    </ul>\n                </div>\n                <div class=\"column\">\n                    <p class=\"type\">キャリア採用</p>\n                    <ul class=\"list\">\n                        <li><a href=\"./career-advisor\">ITアドバイザー</a></li>\n                    </ul>\n                </div>\n                <div class=\"column\">\n                    <p class=\"type\">　</p>\n                    <ul class=\"list\">\n                        <li><a href=\"./faq\">よくある質問</a></li>\n                    </ul>\n                </div>\n            </div>\n        </div>\n        <div class=\"footer-bottom\">\n            <div class=\"external-links\">\n                <a href=\"https://www.inahara.co.jp/privacy.html\" target=\"_blank\" rel=\"noopener\">個人情報保護方針</a>\n                <a href=\"https://www.inahara.co.jp\" target=\"_blank\" rel=\"noopener\">コーポレートサイト</a>\n            </div>\n            <p class=\"copyright\"><small>Copyright&copy; Inahara Co., Ltd. All Rights Reserved.</small></p>\n        </div>\n    </div>\n</footer>\n</div>\n<!-- #wrapper -->\n\n<script src=\"js/common.js\"></script>\n<script src=\"js/index.js\"></script></body>\n\n</html>","finalUrl":"https://www.inahara.co.jp/recruit/","rendered":false,"_cachedAt":"2026-06-14T16:12:40.066Z"}