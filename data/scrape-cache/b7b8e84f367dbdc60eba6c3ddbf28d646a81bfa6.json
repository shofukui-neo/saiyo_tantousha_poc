t\t\t<a href=\"/corporateSustainability.php\">環境・CSR</a>\n\t\t\t<ul class=\"sub_menu\">\n\t\t\t\t<li><a href=\"/newsrelease.php#news\">お知らせ</a></li>\n\t\t\t\t<li><a href=\"/newsrelease.php#press\">プレスリリース</a></li>\n\t\t\t</ul>\n\t\t</div>\n\t\t<div>\n\t\t\t<a href=\"/movie.php\">動画で観る製鉄</a>\n\t\t\t<ul class=\"sub_menu\">\n\t\t\t\t<li><a href=\"/newsrelease.php#news\">お知らせ</a></li>\n\t\t\t\t<li><a href=\"/newsrelease.php#press\">プレスリリース</a></li>\n\t\t\t</ul>\n\t\t</div>\n\t\t<div>\n\t\t\t<a href=\"/recruit.php\">採用情報</a>\n\t\t\t<ul class=\"sub_menu\">\n\t\t\t\t<li><a href=\"/newsrelease.php#news\">お知らせ</a></li>\n\t\t\t\t<li><a href=\"/newsrelease.php#press\">プレスリリース</a></li>\n\t\t\t</ul>\n\t\t</div>\n\t</div>\n\t<div id=\"nav_SP\" style=\"display:none;\">\n\t\t<div id=\"menu_wrapper\">\n\t\t\t<p class=\"humberger\">\n\t\t\t\t<span></span>\n\t\t\t\t<span></span>\n\t\t\t\t<span></span>\n\t\t\t</p>\n\t\t\t<nav id=\"sp_menu\" style=\"display:none;\">\n\t\t\t\t<ul class=\"menu\">     \n\t\t\t\t\t<li><a href=\"/\">ホーム</a></li>\n\t\t\t\t\t<li><a href=\"/newsrelease.php\">ニュースリリース</a></li>\n\t\t\t\t\t<li><a href=\"/companyProfile.php\">会社概要</a></li>\n\t\t\t\t\t<li><a href=\"/businessSummary.php\">事業概要</a></li>\n\t\t\t\t\t<li><a href=\"/corporateSustainability.php\">環境・CSR</a></li>\n\t\t\t\t\t<li><a href=\"/movie.php\">動画で観る製鉄</a></li>\n\t\t\t\t\t<li><a href=\"/recruit.php\">採用情報</a></li>\n\t\t\t\t\t<li><a href=\"/companyProfile.php#map\">所在地マップ</a></li>\n\t\t\t\t\t<li><a href=\"/privacypolicy.php\">個人情報保護方針</a></li>\n\t\t\t\t\t<li><a href=\"/contact.php?token=f07b89ab6fc761397327ab5e51f9ab64aca475c5b28a6154c7f6327d1e8569d7\">採用情報へのお問合せ</a></li>\n\t\t\t\t</ul>\n\t\t\t</nav>\n\t\t</div>\n\t</div>\n\t<script>\n\t$(function(){\n\t\t$(\".humberger\").on(\"click\", function(){\n\t\t\tvar rightVal = 0;\n\t\t\tif($(this).hasClass(\"open\")) {\n\t\t\t\trightVal = '-100vw';\n\t\t\t\t$(this).removeClass(\"open\");\n\t\t\t} else {\n\t\t\t\t$(this).addClass(\"open\");\n\t\t\t\t$(\"#sp_menu\").css(\"display\",\"block\");\n\t\t\t}\n\t \n\t\t\t$(\"#sp_menu\").stop().animate({\n\t\t\t\t'right': rightVal\n\t\t\t}, 200);\n\t\t\tif(!$(this).hasClass(\"open\")) {\n\t\t\t\tsetTimeout(function() {\n\t\t\t\t\t$(\"#sp_menu\").css(\"display\",\"none\");\n\t\t\t\t}, 200)\n\t\t\t}\n\t\t});\n\t});\n\t</script>  </header>\n\n  <section id=\"page_head\">\n    <div class=\"bg_image bg_zoomin\" style=\"background-image:url(/images/job/highschool/mv.jpg)\"></div>\n    <div class=\"headtext \"></div>\n    <div class=\"scroll\"><span></span><span></span><span></span>Scroll</div>\n  </section>\n\n  <main class=\"wrapper p-0\">\n    <section id=\"message\">\n      <div class=\"container\">\n        <h1 style=\"color:#0135d9\" class=\"text-center my-5\">Declaration</h1>\n        <div class=\"row\">\n          <div class=\"col-12 col-md\">\n            <h3 class=\"fade slideUp\">志望される方・保護者・先生方へ<br>採用担当メッセージ</h3>\n          </div>\n          <div class=\"col-12 col-md\">\n            <p class=\"fade\">\n              『世の中に必要とされる事業を展開していく』という考えを大切にし、今後もお客様にとって信頼できるパートナーとして選ばれること。そして、『社員が生き生きと働ける会社』を目指しています。<br>\n              九州製鋼の仕事は規模も責任も大きいですが、その分、社員一人ひとりが成長しながら働くことができる環境があり、手厚い教育制度や福利厚生、住宅手当などの制度は、社員のみなさんが安心して長く働き続けられるように、しっかりと充実したものを整備しています。\n            </p>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <section id=\"about\" style=\"background-image:url(/images/job/about_back.jpg); background-size: contain;\">\n      <div class=\"container py-5\">\n        <div style=\"background-color:rgba(255, 255, 255, 0.8);padding:1rem\">\n          <h1 class=\"text-center\" style=\"color:#0135d9\">About Us</h1>\n          <h2 class=\"border-bottom border-black d-inline-block mb-3 p-0\">九州製鋼とは</h2>\n          <div class=\"fade\">\n            私たちは、鉄スクラップから主に鉄筋コンクリート用棒鋼を製造し、建築現場などに提供している会社です。<br>\n            鉄筋コンクリート用棒鋼は、コンクリート構造物の強度を保つためには欠かせない建設資材。確かな品質の鉄筋を製造し、地域のインフラ整備や都市開発に貢献しています。\n          </div>\n          <div class=\"row flex-wrap g-1\">\n            <div class=\"col-12 col-md fade\" style=\"transition-delay: 0s;\">\n              <img class=\"img-fluid\" src=\"/images/job/about01.jpg\" alt=\"工事向け機材\">\n            </div>\n            <div class=\"col-12 col-md fade\" style=\"transition-delay: .25s;\">\n              <img class=\"img-fluid\" src=\"/images/job/about02.jpg\" alt=\"産業・医療・家庭用ガス\">\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <section id=\"point\" style=\"background-image:url(/images/job/point_back.jpg);background-size: contain\">\n      <div style=\"background-color:rgba(255,255,255,.5)\">\n        <div class=\"container py-5\">\n          <div class=\"\">\n            <h1 style=\"color:#0135d9\">Strong Point</h1>\n            <h2 class=\"border-bottom border-black d-inline-block mb-3 p-0\">九州製鋼で働く魅力</h2>\n          </div>\n          <div class=\"row flex-wrap g-3\">\n            <div class=\"col-12 col-lg-10 fade slideUp\">\n              <div class=\"box\">\n                <div class=\"box-img\">\n                  <img class=\"w-100 img-fluid\" src=\"/images/job/point01.jpg\" alt=\"dummy\">\n                </div>\n                <div class=\"box-text\">\n                  <div class=\"d-flex p-1 pb-2 g-1\">\n                    <img src=\"/images/job/point_num01.png\" class=\"align-self-center me-2\">\n                    <div class=\"title d-flex align-items-center\">\n                      <h5 class=\"text-white m-0\">持続可能な環境への取り組み</h5>\n                    </div>\n                  </div>\n                  <div>\n                    鉄スクラップに生命を与え　大きな巨人に育てるプロセスこそが私たちの使命。<br>\n                    私たちは環境にやさしい、持続可能な環境への取り組みを積極的に推進しています。<br>\n                    役割を終えた鉄スクラップに新たな生命を与えるというプロセスが、私たちの仕事です。<br>\n                    「社会のニーズと環境バランス」に正面から向き合っています。\n                  </div>\n                </div>\n              </div>\n            </div>\n            <div class=\"col-12 col-lg-10 offset-lg-2 fade slideUp\" style=\"transition-delay: .2s\">\n              <div class=\"box\">\n                <div class=\"box-img\">\n                  <img class=\"w-100 img-fluid\" src=\"/images/job/point02.jpg\" alt=\"dummy\">\n                </div>\n                <div class=\"box-text\">\n                  <div class=\"d-flex p-1\">\n                    <img src=\"/images/job/point_num02.png\" class=\"align-self-center me-2\">\n                    <div class=\"title d-flex align-items-center\">\n                      <h5 class=\"text-white m-0\">ワークバランスを重視</h5>\n                    </div>\n                  </div>\n                  <div>\n                    当社では、社員やその家族を守るため、安心して働ける環境を整備しています。<br>\n                    通勤手当や時間外手当はもちろんのこと、職種によっては技能手当や交代勤務手当、サンデープレミアム手当（日曜や祝祭日に出勤した場合の手当）など、各種手当が充実。働きに適した手当を支給するほか、休みもたっぷり。<br>\n                    年間休日は125日以上で、基本的には土曜、日曜が休みです。<br>\n                    会社についてのことや仕事に関する基本的な知識は、研修で学んだあと、配属先で先輩社員が丁寧にレクチャーします。<br>\n                    気さくで話しやすい先輩が多く、面倒見もよいので何でも聞いてください。<br>\n                    資格取得については会社がサポートする制度もあるので、スキルアップにもチャレンジできますよ。\n                  </div>\n                </div>\n              </div>\n            </div>\n            <div class=\"col-12 col-md-10 fade slideUp\" style=\"transition-delay: .3s\">\n              <div class=\"box\">\n                <div class=\"box-img\">\n                  <img class=\"w-100 img-fluid\" src=\"/images/job/point03.jpg\" alt=\"dummy\">\n                </div>\n                <div class=\"box-text\">\n                  <div class=\"d-flex p-1\">\n                    <img src=\"/images/job/point_num03.png\" class=\"align-self-center me-2\">\n                    <div class=\"title d-flex align-items-center\">\n                      <h5 class=\"text-white m-0\">地域密着</h5>\n                    </div>\n                  </div>\n                  <div>\n                    地域社会に貢献できる会社<br />\n                    <br />\n                    私たちの会社は、佐賀県武雄市と福岡県糟屋郡久山町に拠点をおいています。<br>\n                    大都市に企業が集中する中、地方で事業を行うことは、新たな雇用を創出し、関連サービスが生まれるなど、地域活性化に繋がります。<br>\n                    また、自然環境豊かな場所で働けるため、ストレスも軽減でき、仕事に集中できることも大きなメリットです。\n                  </div>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n    <section id=\"advice\" style=\"background-color:#e0e8ff\">\n      <div class=\"container py-5\">\n        <h1 style=\"color:#0135d9\" class=\"text-center col-12 col-md\">Message</h1>\n        <div class=\"d-flex flex-md-row-reverse flex-wrap\">\n          <div class=\"col-12 col-md align-self-center \">\n            <h2 class=\"d-inline-block mb-3 p-0\">先輩からメッセージ</h2>\n          </div>\n        </div>\n        <div class=\"row flex-wrap g-3\">\n          <div class=\"col-12 col-md-6 fade d-flex flex-column justify-content-between\" style=\"transition-delay: 0s;\">\n            <div>\n              <div style=\"background-color:#0135d9\" class=\"text-white py-2 px-3 mb-3\">圧延部 技術課　I.Yさん（25歳）</div>\n              <img src=\"/images/job/highschool/advice01_1.jpg\" alt=\"製鋼課　工長　Y.Mさん\" class=\"w-100 img-fluid\">\n              <p>\n                私の仕事は、工場内の設備点検・メンテナンス・部品交換・設備制御の改造など、幅広い業務に携わっています。職場の雰囲気はとても良く、人間関係も良好です。<br />\n                にぎやかな方もいれば落ち着いた方もいて、様々ですが、基本的に穏やかで思いやりのある方が多く、ストレスを感じる場面はほとんどありません。業務にはゆとりがあり、残業も少ないため、仕事とプライベートのバランスも非常に良いと感じています。<br />\n                頼まれた仕事を無事にやり遂げたときには達成感があり、上司からも適切に評価していただけるため、日々の業務が励みになります。<br />\n                褒めるときはしっかり褒め、必要なときには的確にご指導いただける、メリハリのある指導体制も魅力の一つです。安心して働ける、とても働きやすい職場環境だと感じています。\n              </p>\n            </div>\n\n            <div class=\"bg-white p-3\">\n              <div class=\"fs-5 fw-bold d-flex justify-content-center gap-4 mb-2\">\n                <img src=\"/images/job/clock.png\" class=\"img-fluid\" style=\"height:2.5rem\">\n                <span>スケジュール紹介</span>\n              </div>\n              <div class=\"schedule py-4 px-3 px-lg-5 mx-0 row\">\n                <div class=\"schedule-list\">\n                  <div class=\"schedule-item\">\n                    <div class=\"schedule-time\">22:00</div>\n                    <div class=\"schedule-text\">ミーティング<br> 立上げ作業</div>\n                  </div>\n                  <div class=\"schedule-item\">\n                    <div class=\"schedule-time\">23:00</div>\n                    <div class=\"schedule-text\">工場内日常点検</div>\n                  </div>\n                  <div class=\"schedule-item\">\n                    <div class=\"schedule-time\">0:00</div>\n                    <div class=\"schedule-text\">設備修理</div>\n                  </div>\n                  <div class=\"schedule-item\">\n                    <div class=\"schedule-time\">3:00</div>\n                    <div class=\"schedule-text\">設備点検・整備</div>\n                  </div>\n                  <div class=\"schedule-item\">\n                    <div class=\"schedule-time\">4:00</div>\n                    <div class=\"schedule-text\">休憩</div>\n                  </div>\n                  <div class=\"schedule-item\">\n                    <div class=\"schedule-time\">5:00</div>\n                    <div class=\"schedule-text\">設備修理</div>\n                  </div>\n                  <div class=\"schedule-item\">\n                    <div class=\"schedule-time\">7:00</div>\n                    <div class=\"schedule-text\">立下げ作業</div>\n                  </div>\n                  <div class=\"schedule-item\">\n                    <div class=\"schedule-time\">8:00</div>\n                    <div class=\"schedule-text\">退社</div>\n                  </div>\n                </div>\n                <div></div>\n              </div>\n            </div>\n          </div>\n          <div class=\"col-12 col-md-6 fade d-flex flex-column justify-content-between\" style=\"transition-delay: 0.25s;\">\n            <div>\n              <div style=\"background-color:#0135d9\" class=\"text-white py-2 px-3 mb-3\">製鋼部 技術課　S.Nさん（26歳）</div>\n              <img class=\"w-100 img-fluid\" src=\"/images/job/highschool/advice02_1.jpg\" alt=\"技術課　工長　Y.Aさん\">\n              <p>\n                私の仕事は、クレーンを操作してスクラップやビレットの運搬を行うほか、成分分析業務にも携わっています。<br />\n                職場には、役職に関係なく誰とでも気軽に話せる雰囲気があり、フラットで風通しの良いコミュニケーションが根付いています。<br />\n                また、後輩が困っていると、先輩が自然と手を差し伸べるなど、助け合いの精神が浸透しており、安心して業務に取り組むことができています。<br />\n                当社には多様な部署があり、それぞれの専門性を活かして業務を進めることができます。そのため、自分の役割に対して大きな達成感を感じる場面も多くあります。特に、新しい技術や知識を学び、それを実務に活かせたときには、自身の成長を強く実感することができます。<br />\n                さらに、社員一人ひとりの意見や考え方が尊重される環境が整っており、自由に意見交換ができる風土があります。<br />\n                こういった職場環境のおかげで、仕事に対して過度なストレスを感じることなく、安心して長く働ける会社だと感じています。\n              </p>\n            </div>\n\n            <div class=\"bg-white p-3\">\n              <div class=\"fs-5 fw-bold d-flex justify-content-center gap-4 mb-2\">\n                <img src=\"/images/job/clock.png\" class=\"img-fluid\" style=\"height:2.5rem\">\n                <span>スケジュール紹介</span>\n              </div>\n              <div class=\"schedule py-4 px-3 px-lg-5 mx-0 row\">\n                <div class=\"schedule-list\">\n                  <div class=\"schedule-item\">\n                    <div class=\"schedule-time\">22:00</div>\n                    <div class=\"schedule-text\">KY（危険予知）活動<br>申し送り確認</div>\n                  </div>\n                  <div class=\"schedule-item\">\n                    <div class=\"schedule-time\">23:00</div>\n                    <div class=\"schedule-text\">操業準備</div>\n                  </div>\n                  <div class=\"schedule-item\">\n                    <div class=\"schedule-time\">0:00</div>\n                    <div class=\"schedule-text\">80tクレーン運転</div>\n                  </div>\n                  <div class=\"schedule-item\">\n                    <div class=\"schedule-time\">3:00</div>\n                    <div class=\"schedule-text\">休憩</div>\n                  </div>\n                  <div class=\"schedule-item\">\n                    <div class=\"schedule-time\">4:00</div>\n                    <div class=\"schedule-text\">60tクレーン運転</div>\n                  </div>\n                  <div class=\"schedule-item\">\n                    <div class=\"schedule-time\">6:00</div>\n                    <div class=\"schedule-text\">6号クレーン運転</div>\n                  </div>\n                  <div class=\"schedule-item\">\n                    <div class=\"schedule-time\">8:00</div>\n                    <div class=\"schedule-text\">退社</div>\n                  </div>\n                </div>\n                <div style=\"height: 2.5rem;\"></div>\n              </div>\n            </div>\n          </div>\n        </div>\n    </section>\n\n    <section id=\"flow\" style=\"background-image:url(/images/job/flow_back.jpg);background-size: contain\">\n      <div style=\"background-color:#0135d980\">\n        <div class=\"container py-5\">\n          <div class=\"d-flex flex-md-row-reverse flex-wrap\">\n            <h1 class=\"text-center col-12 col-md text-white\">Flow</h1>\n            <div class=\"col-12 col-md align-self-center \">\n              <h2 class=\"border-bottom border-white d-inline-block mb-3 text-white p-0\">入社までの流れ</h2>\n            </div>\n          </div>\n          <div>\n            <img alt=\"demo\" class=\"img-fluid w-100 fade slideUp\" src=\"/images/job/flowchart.png\">\n            <div class=\"text-white fade slideUp\">面接は計２回ですが、一次面接はWEB（Zoom等）で行うことも可能です。<br>最終選考のみ本社にお越しいただきます。<br>最終選考でかかった交通費は全額当社が負担いたします。<br><br>その他、面接に関しまして柔軟に対応致しますので、不安な点やご不明点がありましたらお気軽にご相談ください。</div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <section id=\"recruit\">\n      <div class=\"container py-5\">\n        <h1 style=\"color:#0135d9\" class=\"text-center col-12 col-md\">Recruit</h1>\n        <div class=\"d-flex flex-md-row-reverse flex-wrap\">\n          <div class=\"col-12 col-md align-self-center \">\n            <h2 class=\"border-bottom border-black d-inline-block mb-3 p-0\">求人情報</h2>\n          </div>\n        </div>\n        <table class=\"table table-bordered recruit-table my-3\">\n          <tbody>\n            <tr>\n              <th>【仕事の内容】 </th>\n              <td>\n                <div class=\"d-flex\">\n                  <div class=\"text-nowrap\">福岡：</div>\n                  <div>\n                    鉄筋コンクリート用異形棒鋼（製品）の生産プロセスにおける圧延工程<br>\n                    （鋼片を鉄筋の形状に熱間加工する工程）の全般業務\n                  </div>\n                </div>\n                <div class=\"d-flex\">\n                  <div class=\"text-nowrap\">佐賀：</div>\n                  <div>\n                    鉄筋コンクリート用棒鋼用の原料である鋼塊及び鋳鋼用溶鋼の製造及びメンテナンス<br>\n                    鉄屑から鋼片を製造する業務\n                  </div>\n                </div>\n                ※職種は勤務地によって異なります\n              </td>\n            </tr>\n            <tr>\n              <th>【労働条件等】 </th>\n              <td>\n                <table class=\"job\">\n                  <tbody>\n                    <tr>\n                      <th>基本給</th>\n                      <td>月額193,000円</td>\n                    </tr>\n                    <tr>\n                      <th>就業時間</th>\n                      <td>\n                        変形労働時間制（1ヶ月単位）<br>\n                        本社　　　08:30～17:30<br>\n                        福岡工場　07:45～16:45　13:15～22:15　22:00～08:00<br>\n                        佐賀工場　08:00～17:00　14:30～00:00　22:00～08:45<br>\n                        ※勤務地または所属先によって就業時間が異なる\n                      </td>\n                    </tr>\n                    <tr>\n                      <th>休日等</th>\n                      <td>\n                        年間127日～156日<br>\n                        ※勤務地または所属先によって休日が異なる\n                      </td>\n                    </tr>\n                    <tr>\n                      <th>手当等</th>\n                      <td>通勤手当、日祝手当、資格手当、その他各種手当あり </td>\n                    </tr>\n                    <tr>\n                      <th>賞与</th>\n                      <td>年2回（7月、12月）</td>\n                    </tr>\n                    <tr>\n                      <th>加入保険等&nbsp;&nbsp;</th>\n                      <td>雇用、労災、健康、厚生等あり</td>\n                    </tr>\n                  </tbody>\n                </table>\n              </td>\n            </tr>\n          </tbody>\n        </table>\n      </div>\n    </section>\n\n  </main>\n\n  <footer>\n    \t<div id=\"page_top\"><a href=\"#\"></a></div>\r\n\t<div class=\"f_logo\"><a href=\"/\"><img src=\"/images/header/logo.png\"></a></div>\r\n\t<div class=\"f_menu\">\r\n\t\t<div><a href=\"/companyProfile.php#map\">所在地マップ</a></div>\r\n\t\t<div><a href=\"/privacypolicy.php\">個人情報保護方針</a></div>\r\n\t\t<div><a href=\"/contact.php?token=f07b89ab6fc761397327ab5e51f9ab64aca475c5b28a6154c7f6327d1e8569d7\">採用情報へのお問合せ</a></div>\r\n\t</div>\r\n\t<div class=\"f_inner_menu\">\r\n\t\t<div><p class=\"head\"><a href=\"/newsrelease.php\">ニュースリリース</a></p>\r\n\t\t\t<ul>\r\n\t\t\t\t<li><a href=\"/newsrelease.php#news\">お知らせ</a></li>\r\n\t\t\t\t<li><a href=\"/newsrelease.php#press\">プレスリリース</a></li>\r\n\t\t\t</ul>\r\n\t\t</div>\r\n\t\t<div><p class=\"head\"><a href=\"/companyProfile.php\">会社概要</a></p>\r\n\t\t\t<ul>\r\n\t\t\t\t<li><a href=\"/companyProfile.php#greeting\">トップメッセージ</a></li>\r\n\t\t\t\t<li><a href=\"/companyProfile.php#profile\">概要</a></li>\r\n\t\t\t\t<li><a href=\"/companyProfile.php#history\">沿革</a></li>\r\n\t\t\t\t<li><a href=\"/companyProfile.php#organization\">組織</a></li>\r\n\t\t\t\t<li><a href=\"/companyProfile.php#officer\">役員</a></li>\r\n\t\t\t\t<li><a href=\"/companyProfile.php#group\">グループ会社</a></li>\r\n\t\t\t\t<li><a href=\"/companyProfile.php#map\">所在地マップ</a></li>\r\n\t\t\t</ul>\r\n\t\t</div>\r\n\t\t<div><p class=\"head\"><a href=\"/recruit.php\">採用情報</a></p>\r\n\t\t\t<ul>\r\n\t\t\t\t<li><a href=\"/recruit.php#graduates\">新卒採用</a></li>\r\n\t\t\t\t<li><a href=\"/recruit.php#carrier\">キャリア採用</a></li>\r\n\t\t\t</ul>\r\n\t\t</div>\r\n\t\t<div><p class=\"head\"><a href=\"/corporateSustainability.php\">環境・CSR</a></p>\r\n\t\t\t<ul>\r\n\t\t\t\t<li><a href=\"/corporateSustainabi