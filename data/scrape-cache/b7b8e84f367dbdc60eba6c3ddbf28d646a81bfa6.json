{"url":"https://www.kyushu-steel.com/recruit/hs.php","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n\n<head>\n  <link href=\"https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css\" rel=\"stylesheet\" integrity=\"sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN\" crossOrigin=\"anonymous\">\n  \n<!-- Google tag (gtag.js) -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-6L79LX5XTD\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'G-6L79LX5XTD');\n</script>\n\n<meta charset=\"utf-8\">\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<meta name=\"format-detection\" content=\"telephone=no\">\n<meta name=\"description\" content=\"鋼片から圧延製品までの一貫且つ徹底した品質管理の基にさらに改善改良を重ね今まで以上に需要家の皆様方のご要望に添い得る良質の製品の生産と、安定供給に努力を重ねる所存でございます。\">\n<meta name=\"keywords\" content=\"九州製鋼株式会社,九州製鋼,九州,鉄鋼,鉄,製鋼,鉄筋,コンクリート,鋼,製造,福岡県,佐賀県,棒鋼\">\n<title>九州製鋼株式会社</title> \n<link rel=\"stylesheet\" href=\"/css/destyle.css\">\n<link rel=\"stylesheet\" href=\"/css/common.css?v=0.79568000 1782160322\">\n<link rel=\"stylesheet\" href=\"https://use.fontawesome.com/releases/v5.7.2/css/all.css\">\n<link rel=\"stylesheet\" href=\"https://fonts.googleapis.com/css2?family=Noto+Sans+JP&display=swap\">\n<!--<link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/animate.css/3.5.1/animate.min.css\">-->\n<link rel=\"stylesheet\" href=\"/css/slick-theme.css\">\n<link rel=\"stylesheet\" href=\"/css/slick.css\">\n<script src=\"/script/jquery-1.12.4.min.js\"></script>\n<script src=\"/script/jquery.easing.1.3.js\"></script>\n<script src=\"/script/jquery.inview.min.js\"></script>\n<script src=\"/script/slick.min.js\"></script>\n<script src=\"/script/custom.js\"></script>\n<script src=\"https://cdnjs.cloudflare.com/ajax/libs/lightbox2/2.10.0/js/lightbox.min.js\"></