ractImage\">\n        </div>\n    </div>\n</div>\n            <div id=\"wrapper-2\">\n<div id=\"nav\">\n    <div id=\"promos1\">\n<div class=\"promos\">\n    </div><!-- end promos -->\n    </div>\n    <div id=\"nav-box\" role=\"navigation\">\n             <h6>サブ-ナビゲーション</h6>\n        <ul class=\"navLevel_1\">\n            <li class=\"liIndex_0\">\n                        <a href=\"/ja.html\">エア・ウォーター株式会社</a>\n            </li>\n            <li class=\"liIndex_1\">\n                        <a href=\"/ja/special.html\">Meet with AW!</a>\n            </li>\n            <li class=\"liIndex_2\">\n                        <a href=\"/ja/company.html\">会社情報</a>\n            </li>\n            <li class=\"liIndex_3\">\n                        <a href=\"/ja/athlete.html\">アスリート社員</a>\n            </li>\n            <li class=\"liIndex_4\">\n                        <a href=\"/ja/ad.html\">動画・広告ギャラリー</a>\n            </li>\n            <li class=\"liIndex_5\">\n                        <a href=\"/ja/business.html\">事業紹介</a>\n            </li>\n            <li class=\"liIndex_6\">\n                        <a href=\"/ja/carbon_neutrality.html\">エア・ウォーターのカーボンNEWトラル！</a>\n            </li>\n            <li class=\"liIndex_7\">\n                        <a href=\"/ja/product.html\">製品・サービス</a>\n            </li>\n            <li class=\"liIndex_8\">\n                        <a href=\"/ja/research.html\">研究開発</a>\n            </li>\n            <li class=\"liIndex_9\">\n                        <a href=\"/ja/sustainability.html\">サステナビリティ</a>\n            </li>\n            <li class=\"liIndex_10\">\n                        <a href=\"/ja/ir.html\">株主・投資家情報</a>\n            </li>\n            <li class=\"liIndex_11\">\n                        <a href=\"/ja/group.html\">グループ会社</a>\n            </li>\n            <li class=\"liIndex_12\">\n                        <a href=\"/ja/recruit.html\">採用情報</a>\n            </li>\n            <li class=\"open liIndex_13\">\n                        <a href=\"/ja/news.html\">最新情報</a>\n        <ul class=\"navLevel_2\">\n            <li class=\"liIndex_0\">\n                        <a href=\"/ja/news/release.html\">ニュースリリース</a>\n            </li>\n            <li class=\"open on liIndex_1\">\n                            <a href=\"/ja/news/info.html\">                        <span><em>現在位置:</em>お知らせ</span>\n</a>\n            </li>\n        </ul>\n            </li>\n            <li class=\"liIndex_14\">\n                        <a href=\"/ja/contact1.html\">お問い合わせ</a>\n            </li>\n            <li class=\"liIndex_15\">\n                        <a href=\"/ja/disclaimer.html\">サイトポリシー</a>\n            </li>\n            <li class=\"liIndex_16\">\n                        <a href=\"/ja/privacy.html\">プライバシーポリシー</a>\n            </li>\n        </ul>\n    </div><!-- end nav-box -->\n    <div id=\"promos2\">\n<div class=\"promos\">\n    </div><!-- end promos -->\n    </div>\n</div><!-- end nav -->\n            <div id=\"wrapper-3\">\n<div id=\"page-intro\">\n        <h1 style=\"\">\n            東京大学大学院農学生命科学研究科とエア・ウォーター　みかんの皮粉末投与における犬の安全性試験に関する共同研究成果を発表<br/>～ シニア犬の認知症症状の緩和を目的とした研究の一環として ～\n        </h1>\n        <div class=\"text-meta\" role=\"contentinfo\">\n                    <ul class=\"text-data\">\n                        <li class=\"date\">2026年04月28日</li>\n                    </ul>\n        </div><!-- end text-meta -->\n        <div class=\"abstractImage\">\n        </div>\n</div>\n<div id=\"sharewithmain\" role=\"main\">\n    <div class=\"multiColumn multiColumn1\" id=\"multiColumn1-1\" style=\"margin-bottom:-40px;\">\n        <div class=\"column columnLast column1\" style=\"\">\n<div class=\"text-section\"  id=\"text-section-1\">\n            <div class=\"rich-text\" style=\"\">\n                <p style=\"text-align:justify\">東京大学大学院農学生命科学研究科（以下、東京大学）の米澤智洋准教授の研究グループとエア・ウォーター株式会社（以下、エア・ウォーター）は、みかんの皮粉末を犬に投与した際の安全性に関する共同研究成果を得ましたので、お知らせいたします。</p>\n            </div>\n</div>\n<div class=\"text-section\" style=\"margin-top:40px;\" id=\"text-section-2\">\n    <h2>１．経緯・目的</h2>\n</div>\n<div class=\"text-section\" style=\"margin-top:-15px;margin-left:40px;\" id=\"text-section-3\">\n            <div class=\"rich-text\" style=\"\">\n                <p>エア・ウォーターは、みかんの皮粉末（加工品）がシニア犬の認知症症状の緩和に寄与する可能性を示唆する論文（北里大学との共同研究）を、2024年12月に国際科学雑誌に発表しました。当該研究では、健康な犬を対象に2週間の投与試験を行い、身体的異常や臨床病理学的異常は認められませんでした。一方で、この研究は主に腸内細菌叢*1および行動変化に焦点を当てたものであり、安全性に関わる指標全体の体系的な評価には十分ではありませんでした。<br />\nみかんの皮粉末を栄養補助食品として活用、あるいは製品化するにあたっては、より長期間の投与における包括的な安全性データの取得が不可欠です。<br />\nこのような背景から、東京大学とエア・ウォーターは、本共同研究を実施しました。</p>\n            </div>\n</div>\n<div class=\"text-section\" style=\"margin-top:40px;\" id=\"text-section-4\">\n    <h2>２．共同研究の内容</h2>\n</div>\n<div class=\"text-section\" style=\"margin-top:-15px;margin-bottom:-10px;margin-left:40px;\" id=\"text-section-5\">\n            <div class=\"rich-text\" style=\"\">\n                <p>本研究では、残留農薬分析を実施し、「愛がん動物用飼料の安全性の確保に関する法律（ペットフード安全法）」の成分規格に適合したみかん皮粉末を使用しました。体重約10kgの犬4頭を対象に1日あたり2g、6g、10gの各用量を3〜4週間にわたり段階的に投与しました。試験期間中は、体重、観察される症状（臨床徴候*2）、血液生化学検査等を継続的に評価しました。さらに、脳脊髄液を採取して代謝物分析を行い、その結果に基づき、腸と脳の相互作用（腸－脳相関）に関わる作用機序についても考察しました。これらの研究成果は、2026年3月23日にスイスの国際科学雑誌『Metabolites』オンライン版に掲載されました。<br />\nまた、現在、東京大学との共同研究として、認知症症状を有するシニア犬約十数頭を対象とした臨床試験を実施しています。解析完了後、あらためて公開する予定です。</p>\n            </div>\n</div>\n        </div>\n</div>\n    <div class=\"multiColumn multiColumn1\" id=\"multiColumn1-2\" style=\"margin-top:-40px;margin-bottom:-20px;\">\n        <div class=\"column columnLast column1\" style=\"\">\n<div class=\"text-section\" style=\"margin-top:40px;\" id=\"text-section-6\">\n    <h2>３．使用原料及び安全性に関する注意点</h2>\n</div>\n<div class=\"text-section\" style=\"margin-top:-20px;margin-left:40px;\" id=\"text-section-7\">\n            <div class=\"rich-text\" style=\"\">\n                <p>本研究では、みかんの皮を適切な方法で加工し、残留農薬検査や各種成分分析を行うことで安全性を確認した粉末を使用しています。ご家庭等で作製したみかん皮粉末や市販のその他製品を獣医師の判断を仰ぐことなく犬に与えることはお控えください。</p>\n            </div>\n</div>\n<div class=\"text-section\" style=\"margin-top:5px;margin-left:40px;\" id=\"text-section-8\">\n            <div class=\"rich-text\" style=\"\">\n                <p><span style=\"font-size:90%\">※１ 腸内細菌叢（ちょうないさいきんそう）</span></p>\n            </div>\n</div>\n<div class=\"text-section\" style=\"margin-top:-20px;margin-left:80px;\" id=\"text-section-9\">\n            <div class=\"rich-text\" style=\"\">\n                <p><span style=\"font-size:90%\">腸内に生息する細菌の集団全体を指します。近年では、腸と脳の相互作用に関する研究が進展しており、健康状態や行動との関連が注目されています。</span></p>\n            </div>\n</div>\n<div class=\"text-section\" style=\"margin-top:-20px;margin-left:40px;\" id=\"text-section-10\">\n            <div class=\"rich-text\" style=\"\">\n                <p><span style=\"font-size:90%\">※２ 臨床兆候（りんしょうちょうこう）</span></p>\n            </div>\n</div>\n<div class=\"text-section\" style=\"margin-top:-20px;margin-left:80px;\" id=\"text-section-11\">\n            <div class=\"rich-text\" style=\"\">\n                <p><span style=\"font-size:90%\">行動や外見などから確認できる体調の変化を指します。元気や食欲の低下、下痢、嘔吐など、日常的な観察によって把握可能な異変が含まれます。本試験では、安全性試験における評価の一環としてこれらの兆候を継続的に観察・記録しました。</span></p>\n            </div>\n</div>\n        </div>\n</div>\n    <div class=\"multiColumn multiColumn1\" id=\"multiColumn1-3\" style=\"margin-top:-10px;margin-bottom:-20px;\">\n        <div class=\"column columnLast column1\" style=\"\">\n<div class=\"text-section\"  id=\"text-section-12\">\n    <h2>４．本研究の概要図</h2>\n</div>\n<div class=\"text-section\" style=\"margin-top:-15px;margin-bottom:-20px;margin-left:40px;\" id=\"text-section-13\">\n            <img class=\"media photo large\" src=\"/ja/news/info/info-2026042801/main/01111119/teaserItems1/01/binaryNodeName/20260428.webp\" alt=\"\" style=\"max-width:56%\"/>\n</div>\n        </div>\n</div>\n    <div class=\"multiColumn multiColumn1 lx_cke_ol_paren1\" id=\"multiColumn1-4\" style=\"\">\n        <div class=\"column columnLast column1\" style=\"\">\n<div class=\"text-section\" style=\"margin-top:40px;\" id=\"text-section-14\">\n    <h2>５．\t掲載論文情報</h2>\n</div>\n<div class=\"text-section\" style=\"margin-top:-15px;margin-left:40px;\" id=\"text-section-15\">\n            <div class=\"rich-text\" style=\"\">\n                <ol>\n\t<li>雑誌：Metabolites (MDPI)&nbsp;</li>\n\t<li>題名：Preliminary Safety Assessment for Mandarin Orange Peel Administration to Dogs Based on Physical Conditions and Blood Examination Parameters</li>\n\t<li>著者：Tomohiro Yonezawa, Yixue Lei, Cris Ni&ntilde;o Bon B. Marasigan, Mao Komori, Nanasa Fujiwara, Jun Nakahigashi, and Eiji Kobayashi</li>\n\t<li>DOI：10.3390/metabo16030213</li>\n</ol>\n            </div>\n</div>\n<div class=\"text-section\" style=\"margin-left:40px;\" id=\"text-section-16\">\n            <div class=\"rich-text\" style=\"\">\n                <p>論文の詳細は下記よりご覧いただけます。<br />\n論文URL: <a href=\"https://www.mdpi.com/2218-1989/16/3/213\" target=\"_blank\">https://www.mdpi.com/2218-1989/16/3/213</a></p>\n            </div>\n</div>\n        </div>\n</div>\n    <div class=\"multiColumn multiColumn1\" id=\"multiColumn1-5\" style=\"\">\n        <div class=\"column columnLast column1\" style=\"\">\n<div class=\"text-section highlight\"  id=\"text-section-17\">\n            <div class=\"rich-text\" style=\"\">\n                <p style=\"text-align:right\"><span style=\"font-size:100%\">以上</span></p>\n<p>&nbsp;</p>\n<p><span style=\"font-size:100%\">【共同研究成果に関するお問い合わせ先】<br />\n東京大学大学院農学生命科学研究科 准教授<br />\n米澤 智洋（よねざわ　ともひろ）<br />\nE-mail：ayone@g.ecc.u-tokyo.ac.jp<br />\n<br />\nエア・ウォーター株式会社 ウェルネス開発センター<br />\n中東 淳（なかひがし　じゅん）<br />\nE-mail：nakahigashi-jun@awi.co.jp</span></p>\n            </div>\n</div>\n        </div>\n</div>    \n</div><!-- end main -->            </div><!-- end wrapper-3 -->\n            <div id=\"promos3\">\n<div class=\"promos\">\n<div class=\"html-paragraph\" id=\"html-paragraph-1\">\n        <div data-page-marker=\"news-folder\"></div>\n<div data-page-marker=\"no-snav\"></div>\n<div data-news-folder-title=\"最新情報\"></div>\n<div data-page-marker=\"show-category-icon\"></div>