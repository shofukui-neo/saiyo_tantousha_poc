{"url":"https://www.shikokupak.co.jp/","html":"<!doctype html>\r\n<html lang=\"ja\">\r\n<head>\r\n<!-- Google tag (gtag.js) -->\r\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-PS3X62D6XF\"></script>\r\n<script>\r\n  window.dataLayer = window.dataLayer || [];\r\n  function gtag(){dataLayer.push(arguments);}\r\n  gtag('js', new Date());\r\n\r\n  gtag('config', 'G-PS3X62D6XF');\r\n</script>\r\n\r\n<meta charset=\"UTF-8\">\r\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\r\n<title>四国パック株式会社</title>\r\n<meta name=\"description\" content=\"環境に優しいヨーグルト、カップ麺等の紙カップをはじめとする食品用 紙容器の製造メーカー 、四国化工機グループ 四国パック株式会社です。\">\r\n<meta name=\"keywords\" content=\"\">\r\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\r\n<meta name=\"format-detection\" content=\"telephone=no\">\r\n\r\n<meta property=\"og:url\" content=\"https://www.shikokupak.co.jp/\">\r\n<meta property=\"og:type\" content=\"website\">\r\n<meta property=\"og:title\" content=\"四国パック株式会社\">\r\n<meta property=\"og:description\" content=\" 環境に優しいヨーグルト、カップ麺等の紙カップをはじめとする食品用 紙容器の製造メーカー 、四国化工機グループ 四国パック株式会社です。\">\r\n<meta property=\"og:site_name\" content=\"四国パック株式会社\">\r\n<meta property=\"og:image\" content=\"https://www.shikokupak.co.jp/images/og.png\">\r\n\r\n<!-- サイト共通CSS読み込み -->\r\n<link rel=\"stylesheet\" href=\"/common/css/style.css\">\r\n<!-- サイト共通JS読み込み -->\r\n<script src=\"/common/js/jquery.min.js\"></script>\r\n<script src=\"/common/js/jquery.easing.js\"></script>\r\n<script src=\"/common/js/animation.min.js\"></script>\r\n<script src=\"/common/js/contents_common.js\"></script>\r\n<script src=\"/common/js/slick/slick.min.js\"></script>\r\n<script src=\"/common/js/common.js\"></script>\r\n\r\n\r\n<!-- ページ固有CSS読み込み -->\r\n<link rel=\"stylesheet\" href=\"/css/unique.css\">\r\n<!-- ページ固有JS読み込み -->\r\n<script src=\"/js/unique.js\"></script>\r\n</head>\r\n<body id=\"body\">\r\n  <div class=\"l-wrap\">\r\n    <header class=\"l-header\"><div class=\"l-header__inr\">\r\n  <h1 class=\"l-header__logo\"><a href=\"/\"><img src=\"/common/images/logo.svg\" alt=\"四国パック株式会社\"></a></h1>\r\n  <nav class=\"l-header__nav\" data-hd-cts>\r\n    <ul class=\"l-header__navList\">\r\n      <li class=\"l-header__navItem\"><a href=\"/about/\">私たちの強み</a></li>\r\n      <li class=\"l-header__navItem\"><a href=\"/product/\">製品情報</a></li>\r\n      <li class=\"l-header__navItem\"><a href=\"/company/\">企業情報</a></li>\r\n      <li class=\"l-header__navItem\"><a href=\"/recruit/\">採用情報</a></li>\r\n    </ul>\r\n    <div class=\"l-header__contact\"><a href=\"/contact/\">お問い合わせ</a></div>\r\n  </nav>\r\n  <div class=\"l-header__btn sp\" data-hd-btn>\r\n    <div class=\"l-header__btnBar\"></div>\r\n    <p class=\"l-header__btnTxt\">MENU</p>\r\n  </div>\r\n  <div class=\"l-header__ol sp\"></div>\r\n</div></header>\r\n\r\n    <!-- .--hd-wtをつけると白に -->\r\n    <main class=\"l-main\">\r\n\r\n\r\n      <div class=\"u-fv\">\r\n        <div class=\"u-fv__slide\" data-js-fv-slider>\r\n          <div class=\"u-fv__slideList slider\" data-js-slide>\r\n            <div class=\"u-fv__slideItem\" data-theme=\"light\"><div class=\"u-fv__slideItemInr\">\r\n              <picture>\r\n                <source srcset=\"/images/fv_img01.jpg\" media=\"(max-width: 768px)\">\r\n                <img src=\"/images/fv_img01.jpg\" alt=\"\">\r\n              </picture>\r\n            </div></div>\r\n            <div class=\"u-fv__slideItem\" data-theme=\"dark\"><div class=\"u-fv__slideItemInr\">\r\n              <picture>\r\n                <source srcset=\"/images/fv_img02.jpg\" media=\"(max-width: 768px)\">\r\n                <img src=\"/images/fv_img02.jpg\" alt=\"\">\r\n              </picture>\r\n            </div></div>\r\n            <div class=\"u-fv__slideItem\" data-theme=\"dark\"><div class=\"u-fv__slideItemInr\">\r\n              <picture>\r\n                <source srcset=\"/images/fv_img03.jpg\" media=\"(max-width: 768px)\">\r\n                <img src=\"/images/fv_img03.jpg\" alt=\"\">\r\n              </picture>\r\n            </div></div>\r\n            <div class=\"u-fv__slideItem\" data-theme=\"light\"><div class=\"u-fv__slideItemInr\">\r\n              <picture>\r\n                <source srcset=\"/images/fv_img04.jpg\" media=\"(max-width: 768px)\">\r\n                <img src=\"/images/fv_img04.jpg\" alt=\"\">\r\n              </picture>\r\n            </div></div>\r\n            <div class=\"u-fv__slideItem\" data-theme=\"dark\"><div class=\"u-fv__slideItemInr\">\r\n              <picture>\r\n                <source srcset=\"/images/fv_img05.jpg\" media=\"(max-width: 768px)\">\r\n                <img src=\"/images/fv_img05.jpg\" alt=\"\">\r\n              </picture>\r\n            </div></div>\r\n          </div>\r\n          <div class=\"u-fv__cts\">\r\n            <div class=\"u-fv__ttl js-fadeIn\">\r\n              <h1 class=\"jp\">安全<span>、</span>安心<span>、</span>品質<span>。</span></h1>\r\n              <p class=\"en\">Contributing to food culture through creativity and innovation.</p>\r\n            </div>\r\n            <div class=\"u-fv__scroll js-fadeIn\"></div>\r\n          </div>\r\n          <div class=\"u-fv__slideControls\">\r\n            <div class=\"u-fv__slideProgress\" data-js-slide-progress></div>\r\n            <div class=\"u-fv__slideBtns\">\r\n              <button class=\"u-fv__slideArw --prev\" type=\"button\" data-js-slide-prev>前のスライドへ</button>\r\n              <button class=\"u-fv__slideToggle\" type=\"button\" data-js-slide-toggle>停止する</button>\r\n              <button class=\"u-fv__slideArw --next\" type=\"button\" data-js-slide-next>次のスライドへ</button>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n      <section>\r\n        <div class=\"u-about l-idt\"><div class=\"l-wid\">\r\n          <div class=\"u-about__cts\">\r\n            <h2 class=\"u-about__ttl m-ttl01 js-fadeIn\"><span class=\"jp\">私たちの強み</span><span class=\"en\">Strength</span></h2>\r\n            <p class=\"u-about__lead js-fadeIn\">小さな容器に課せられた<br class=\"sp\">役目は<br class=\"pc\">非常に重要です。</p>\r\n            <p class=\"u-about__txt js-fadeIn\">私たち四国パック株式会社は、「安全・安心・品質」をものづくりの基本とし、日本の食品メーカーの歩みとともに培ってきた独創的な技術と、ISO認証基準に基づく徹底した品質管理体制をベースに、お客様に最適なパッケージをお届けしてまいります。</p>\r\n            <picture class=\"u-about__img js-fadeIn\">\r\n              <source srcset=\"/images/sp_about_img.png\" media=\"(max-width: 768px)\">\r\n              <img src=\"/images/about_img.png\" alt=\"\">\r\n            </picture>\r\n            <div class=\"u-about__btn js-fadeIn\"><a href=\"/about/\" class=\"m-btn\">私たちの強み</a></div>\r\n          </div>\r\n        </div></div>\r\n        <div class=\"u-features l-idt\"><div class=\"l-wid\">\r\n          <ul class=\"u-features__list\">\r\n            <li class=\"u-featuresItem js-fadeIn\">\r\n              <div class=\"u-featuresItem__head\">\r\n                <p class=\"u-featuresItem__label\"><span class=\"en\">Strength</span><span class=\"num\">01</span></p>\r\n                <picture class=\"u-featuresItem__img\">\r\n                  <source srcset=\"/images/features_img01.jpg\" media=\"(max-width: 768px)\">\r\n                  <img src=\"/images/features_img01.jpg\" alt=\"\">\r\n                </picture>\r\n              </div>\r\n              <div class=\"u-featuresItem__body\">\r\n                <p class=\"u-featuresItem__ttl\">安全・安心・品質のものづくり</p>\r\n                <p class=\"u-featuresItem__txt\">お客様のニーズに応えた新しい価値をご提案するため、品質にこだわった最適なパッケージをお届けします。</p>\r\n              </div>\r\n            </li>\r\n            <li class=\"u-featuresItem js-fadeIn\">\r\n              <div class=\"u-featuresItem__head\">\r\n                <p class=\"u-featuresItem__label\"><span class=\"en\">Strength</span><span class=\"num\">02</span></p>\r\n                <picture class=\"u-featuresItem__img\">\r\n                  <source srcset=\"/images/features_img02.jpg\" media=\"(max-width: 768px)\">\r\n                  <img src=\"/images/features_img02.jpg\" alt=\"\">\r\n                </picture>\r\n              </div>\r\n              <div class=\"u-featuresItem__body\">\r\n                <p class=\"u-featuresItem__ttl\">商品にあわせた独創的な技術</p>\r\n                <p class=\"u-featuresItem__txt\">優れた最先端技術を駆使した製品開発に取り組み、食文化の発展と皆さまの健康に貢献してまいります。</p>\r\n              </div>\r\n            </li>\r\n            <li class=\"u-featuresItem js-fadeIn\">\r\n              <div class=\"u-featuresItem__head\">\r\n                <p class=\"u-featuresItem__label\"><span class=\"en\">Strength</span><span class=\"num\">03</span></p>\r\n                <picture class=\"u-featuresItem__img\">\r\n                  <source srcset=\"/images/features_img03.jpg\" media=\"(max-width: 768px)\">\r\n                  <img src=\"/images/features_img03.jpg\" alt=\"\">\r\n                </picture>\r\n              </div>\r\n              <div class=\"u-featuresItem__body\">\r\n                <p class=\"u-featuresItem__ttl\">クリーン環境による確かな品質</p>\r\n                <p class=\"u-featuresItem__txt\">高いクリーン環境とISO9001マネジメントシステムに基づく品質管理体制を確立しており、HACCP管理手法の活用による安全性の向上、環境衛生の整備、技術の伝承にも積極的に取り組んでおります。</p>\r\n              </div>\r\n            </li>\r\n          </ul>\r\n          <div class=\"u-features__btn js-fadeIn\"><a href=\"/about/\" class=\"m-btn --bgc-wt\">私たちの強み</a></div>\r\n        </div></div>\r\n\r\n        <div class=\"u-aboutSlide js-fadeIn\" data-js-auto-slider>\r\n          <div class=\"u-autoSlide\" data-js-slide data-auto-speed-ratio=\"0.6\">\r\n            <div class=\"u-autoSlide__item\"><img src=\"/images/about_slider_img01.jpg\" alt=\"\"></div>\r\n            <div class=\"u-autoSlide__item --small\"><img src=\"/images/about_slider_img02.jpg\" alt=\"\"></div>\r\n            <div class=\"u-autoSlide__item\"><img src=\"/images/about_slider_img03.jpg\" alt=\"\"></div>\r\n            <div class=\"u-autoSlide__item --small\"><img src=\"/images/about_slider_img04.jpg\" alt=\"\"></div>\r\n            <div class=\"u-autoSlide__item\"><img src=\"/images/about_slider_img05.jpg\" alt=\"\"></div>\r\n          </div>\r\n        </div>\r\n      </section>\r\n\r\n      <section class=\"u-product l-idt\"><div class=\"l-wid\">\r\n        <h2 class=\"m-ttl01 js-fadeIn\"><span class=\"jp\">製品情報</span><span class=\"en\">Products</span></h2>\r\n        <picture class=\"u-product__kev\">\r\n          <source srcset=\"/images/sp_product_kv_img.jpg\" media=\"(max-width: 768px)\">\r\n          <img src=\"/images/product_kv_img.jpg\" alt=\"\">\r\n        </picture>\r\n        <div class=\"u-product__cts\">\r\n          <p class=\"u-product__lead js-fadeIn\">様々なニーズに合わせた<br>新しい紙容器の創造</p>\r\n          <p class=\"u-product__txt js-fadeIn\">当社独自の技術で、お客様のニーズにお応えできるオリジナルの新しい容器を創造しています。</p>\r\n          <ul class=\"u-product__list\">\r\n            <li class=\"u-productItem js-fadeIn\">\r\n              <div class=\"u-productItem__img\"><img src=\"/images/product_img01.jpg\" alt=\"\"></div>\r\n              <div class=\"u-productItem__body\">\r\n                <p class=\"u-productItem__ttl\">紙カップ</p>\r\n                <p class=\"u-productItem__cat\">小型</p>\r\n              </div>\r\n            </li>\r\n            <li class=\"u-productItem js-fadeIn\">\r\n              <div class=\"u-productItem__img\"><img src=\"/images/product_img02.jpg\" alt=\"\"></div>\r\n              <div class=\"u-productItem__body\">\r\n                <p class=\"u-productItem__ttl\">紙カップ</p>\r\n                <p class=\"u-productItem__cat\">中型・大型</p>\r\n              </div>\r\n            </li>\r\n            <li class=\"u-productItem js-fadeIn\">\r\n              <div class=\"u-productItem__img\"><img src=\"/images/product_img03.jpg\" alt=\"\"></div>\r\n              <div class=\"u-productItem__body\">\r\n                <p class=\"u-productItem__ttl\">インスタント食品用<br class=\"sp\">紙カップ</p>\r\n              </div>\r\n            </li>\r\n            <li class=\"u-productItem js-fadeIn\">\r\n              <div class=\"u-productItem__img\"><img src=\"/images/product_img04.jpg\" alt=\"\"></div>\r\n              <div class=\"u-productItem__body\">\r\n                <p class=\"u-productItem__ttl\">アイス用紙カップ＋紙蓋</p>\r\n              </div>\r\n            </li>\r\n          </ul>\r\n          <div class=\"u-product__btn js-fadeIn\"><a href=\"/product/\" class=\"m-btn\">製品情報</a></div>\r\n        </div>\r\n      </div></section>\r\n      \r\n      <section class=\"u-company l-idt\"><div class=\"l-wid\">\r\n        <div class=\"u-company__cts\">\r\n          <h2 class=\"u-company__ttl m-ttl01 js-fadeIn\"><span class=\"jp\">企業情報</span><span class=\"en\">Company</span></h2>\r\n          <picture class=\"u-company__img js-fadeIn\">\r\n            <source srcset=\"/images/sp_company_img.jpg\" media=\"(max-width: 768px)\">\r\n            <img src=\"/images/company_img.jpg\" alt=\"\">\r\n          </picture>\r\n          <p class=\"u-company__txt js-fadeIn\">ノウハウを活かした独自のシステムや高度な品質管理体制で機能性と品質に優れた紙容器を作っています。</p>\r\n          <div class=\"u-company__btn js-fadeIn\"><a href=\"/company/\" class=\"m-btn\">企業情報</a></div>\r\n        </div>\r\n      </div></section>\r\n\r\n      <section class=\"u-recruit l-idt\"><div class=\"l-wid\">\r\n        <div class=\"u-recruit__cts\">\r\n          <h2 class=\"u-recruit__ttl m-ttl01 js-fadeIn\"><span class=\"jp\">採用情報</span><span class=\"en\">Recruit</span></h2>\r\n          <p class=\"u-recruit__lead js-fadeIn\">紙容器で食生活を彩る</p>\r\n          <p class=\"u-recruit__txt js-fadeIn\">四国パックでは、新しい食品用包装資材の企画提案、開発、製造を行い、お客様のニーズにお応えできるオリジナルの新しい容器を創造しています。</p>\r\n          <div class=\"u-recruit__gallery js-fadeIn\">\r\n            <div class=\"u-gallery\">\r\n              <div class=\"u-gallery__col\">\r\n                <div class=\"u-gallery__img\"><img src=\"/images/recruit_img01.jpg\" alt=\"\"></div>\r\n                <div class=\"u-gallery__img\"><img src=\"/images/recruit_img02.jpg\" alt=\"\"></div>\r\n              </div>\r\n              <div class=\"u-gallery__col\">\r\n                <div class=\"u-gallery__img\"><img src=\"/images/recruit_img03.jpg\" alt=\"\"></div>\r\n                <div class=\"u-gallery__img\"><img src=\"/images/recruit_img04.jpg\" alt=\"\"></div>\r\n                <div class=\"u-gallery__img\"><img src=\"/images/recruit_img05.jpg\" alt=\"\"></div>\r\n              </div>\r\n              <div class=\"u-gallery__col\">\r\n                <div class=\"u-gallery__img\"><img src=\"/images/recruit_img06.jpg\" alt=\"\"></div>\r\n                <div class=\"u-gallery__img\"><img src=\"/images/recruit_img07.jpg\" alt=\"\"></div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n          <div class=\"u-recruit__btn js-fadeIn\"><a href=\"/recruit/\" class=\"m-btn\">採用情報</a></div>\r\n        </div>\r\n      </div></section>\r\n\r\n      <section class=\"u-group l-idt\"><div class=\"l-wid\">\r\n        <h2 class=\"m-ttl01 --pc-stacked js-fadeIn\"><span class=\"jp\">グループ企業</span><span class=\"en\">Shikoku Kakoki Group</span></h2>\r\n        <p class=\"u-group__txt js-fadeIn\">四国化工機グループは、「食」に密接にかかわる３つの事業分野で仕事を行っています。<br class=\"pc\">液体食品充填機の製造販売やプラントエンジニアリングを行う「機械事業」を中核に、<br class=\"pc\">カップやフィルムなど食品用パッケージを扱う「包装資材事業」、<br class=\"pc\">自社開発機を用いて豆腐等を生産する「食品事業」、これら三事業で運営されています。</p>\r\n        <div class=\"u-group__logo js-fadeIn\"><a href=\"http://www.shikoku-kakoki.co.jp/\" target=\"_blank\"><img src=\"/images/group_logo01.png\" alt=\"四国化工機株式会社\"></a></div>\r\n        <div class=\"u-group__logoList\">\r\n          <div class=\"u-group__logoRow --pc-col-3\">\r\n            <p class=\"u-group__logoItem js-fadeIn\"><a href=\"http://www.satonoyuki.co.jp/\" target=\"_blank\"><img src=\"/images/group_logo02.png\" alt=\"さとの雪食品株式会社\"></a></p>\r\n            <p class=\"u-group__logoItem js-fadeIn\"><a href=\"http://www.ueraku.co.jp/\" target=\"_blank\"><img src=\"/images/group_logo03.png\" alt=\"植田酪農機工業株式会社\"></a></p>\r\n            <p class=\"u-group__logoItem js-fadeIn\"><a href=\"https://www.central-mc.co.jp/\" target=\"_blank\"><img src=\"/images/group_logo04.png\" alt=\"セントラル機械商事株式会社\"></a></p>\r\n          </div>\r\n          <div class=\"u-group__logoRow\">\r\n            <p class=\"u-group__logoItem js-fadeIn\"><a href=\"https://www.toyo-science.co.jp/\" target=\"_blank\"><img src=\"/images/group_logo05.png\" alt=\"東洋科学株式会社\"></a></p>\r\n            <p class=\"u-group__logoItem js-fadeIn\"><a href=\"http://www.shikokusangyo.com/\" target=\"_blank\"><img src=\"/images/group_logo07.png\" alt=\"四国産業株式会社\"></a></p>\r\n            <p class=\"u-group__logoItem js-fadeIn\"><a href=\"http://www.shikoku.com.cn/\" target=\"_blank\"><img src=\"/images/group_logo08.png\" alt=\"上海四国食品包装机械有限公司\"></a></p>\r\n          </div>\r\n          <div class=\"u-group__logoRow\">\r\n            <p class=\"u-group__logoItem js-fadeIn\"><img src=\"/images/group_logo09.png\" width=\"296\" alt=\"Shikoku Kakoki Europe GmbH\"></p>\r\n            <p class=\"u-group__logoItem js-fadeIn\"><img src=\"/images/group_logo10.png\" alt=\"Shikoku Kakoki (Thailand) Co., Ltd.\"></p>\r\n            <p class=\"u-group__logoItem js-fadeIn\"><img src=\"/images/group_logo11.png\" alt=\"Shikoku Kakoki America, Inc.\"></p>\r\n          </div>\r\n\t\t\t\t</div>\r\n      </div></section>\r\n\r\n    </main>\r\n    <div class=\"l-footer__contact\"><div class=\"l-footer__contactInr\">\r\n  <div class=\"l-footer__body\">\r\n    <h2 class=\"l-footer__ttl\"><span class=\"en\">Contact Us</span><span class=\"jp\">お問い合わせ</span></h2>\r\n    <p class=\"l-footer__txt\">資料請求や会社案内、採用情報などのご質問やご相談など、お気軽にお問合せください。</p>\r\n  </div>\r\n  <div class=\"l-footer__btn\">\r\n    <a href=\"/contact/\" class=\"m-btn --bgc-wt\">お問い合わせ</a>\r\n  </div>\r\n</div></div>\r\n\r\n    <footer class=\"l-footer\"><div class=\"l-footer__inr\">\r\n  <div class=\"l-footer__nav\"><div class=\"l-footer__navInr\">\r\n    <div class=\"l-footer__navHead\">\r\n      <p class=\"l-footer__navLogo pc\"><a href=\"/\"><img src=\"/common/images/logo.svg\" alt=\"四国パック株式会社\"></a></p>\r\n      <ul class=\"l-footer__nav