          <div class=\"wrap\">\n                  <div class=\"c-title01 c-title01__left js-accordion\">\n                    <span class=\"en\">Career</span>\n                    <span class=\"ja\">キャリア形成</span>\n                  </div>\n                  <ul class=\"link-list-wrap js-accordion-wrap\">\n                    <li class=\"item\">\n                      <a href=\"/recruit/career/\">\n                        <span class=\"txt\">職種紹介/キャリア事例</span>\n                        <svg class=\"arrow\">\n                          <use xlink:href=\"/recruit/img/svg/sprite-symbol.svg#icon-arrow\"></use>\n                        </svg>\n                      </a>\n                    </li>\n                    <li class=\"item\">\n                      <a href=\"/recruit/interview/\">\n                        <span class=\"txt\">先輩社員紹介</span>\n                        <svg class=\"arrow\">\n                          <use xlink:href=\"/recruit/img/svg/sprite-symbol.svg#icon-arrow\"></use>\n                        </svg>\n                      </a>\n                    </li>\n                    <li class=\"item\">\n                      <a href=\"/recruit/education/\">\n                        <span class=\"txt\">人材教育・研修</span>\n                        <svg class=\"arrow\">\n                          <use xlink:href=\"/recruit/img/svg/sprite-symbol.svg#icon-arrow\"></use>\n                        </svg>\n                      </a>\n                    </li>\n                  </ul>\n                </div>\n                <!-- Welfare -->\n                <div class=\"wrap wide\">\n                  <div class=\"c-title01 c-title01__left js-accordion\">\n                    <span class=\"en\">Welfare</span>\n                    <span class=\"ja\">福利厚生</span>\n                  </div>\n                  <div class=\"list-wrap js-accordion-wrap\">\n                    <div class=\"link-inner-wrap\">\n                      <ul class=\"link-list-wrap\">\n                        <li class=\"item\">\n                          <a href=\"/recruit/welfare#room\">\n                            <span class=\"txt\">独身寮・社宅</span>\n                            <svg class=\"arrow\">\n                              <use xlink:href=\"/recruit/img/svg/sprite-symbol.svg#icon-arrow\"></use>\n                            </svg>\n                          </a>\n                        </li>\n                        <li class=\"item\">\n                          <a href=\"/recruit/welfare#pension\">\n                            <span class=\"txt\">確定拠出年金</span>\n                            <svg class=\"arrow\">\n                              <use xlink:href=\"/recruit/img/svg/sprite-symbol.svg#icon-arrow\"></use>\n                            </svg>\n                          </a>\n                        </li>\n                        <li class=\"item\">\n                          <a href=\"/recruit/welfare#club\">\n                            <span class=\"txt\">部活動</span>\n                            <svg class=\"arrow\">\n                              <use xlink:href=\"/recruit/img/svg/sprite-symbol.svg#icon-arrow\"></use>\n                            </svg>\n                          </a>\n                        </li>\n                        <li class=\"item\">\n                          <a href=\"/recruit/welfare#rest\">\n                            <span class=\"txt\">保養所</span>\n                            <svg class=\"arrow\">\n                              <use xlink:href=\"/recruit/img/svg/sprite-symbol.svg#icon-arrow\"></use>\n                            </svg>\n                          </a>\n                        </li>\n                      </ul>\n                      <ul class=\"link-list-wrap\">\n                        <li class=\"item\">\n                          <a href=\"/recruit/welfare#stock\">\n                            <span class=\"txt\">持ち株会</span>\n                            <svg class=\"arrow\">\n                              <use xlink:href=\"/recruit/img/svg/sprite-symbol.svg#icon-arrow\"></use>\n                            </svg>\n                          </a>\n                        </li>\n                        <li class=\"item\">\n                          <a href=\"/recruit/welfare#care\">\n                            <span class=\"txt\">育児・介護に関わる<span class=\"ib\">制度</span></span>\n                            <svg class=\"arrow\">\n                              <use xlink:href=\"/recruit/img/svg/sprite-symbol.svg#icon-arrow\"></use>\n                            </svg>\n                          </a>\n                        </li>\n                        <li class=\"item\">\n                          <a href=\"/recruit/welfare#relo\">\n                            <span class=\"txt\">リロクラブ</span>\n                            <svg class=\"arrow\">\n                              <use xlink:href=\"/recruit/img/svg/sprite-symbol.svg#icon-arrow\"></use>\n                            </svg>\n                          </a>\n                        </li>\n                      </ul>\n                    </div>\n                  </div>\n                </div>\n              </div>\n              <!-- Top, Faq, Corporate -->\n              <div class=\"wrap no-flex max-1399\">\n                <a href=\"/recruit/\" class=\"c-title01 c-title01__left pc\">\n                  <span class=\"en\">Top</span>\n                  <span class=\"ja\">採用トップ</span>\n                  <svg class=\"arrow sp\">\n                    <use xlink:href=\"/recruit/img/svg/sprite-symbol.svg#icon-arrow\"></use>\n                  </svg>\n                </a>\n                <a href=\"/recruit/faq/\" class=\"c-title01 c-title01__left\">\n                  <span class=\"en\">Faq</span>\n                  <span class=\"ja\">よくあるご質問</span>\n                  <svg class=\"arrow sp\">\n                    <use xlink:href=\"/recruit/img/svg/sprite-symbol.svg#icon-arrow\"></use>\n                  </svg>\n                </a>\n                <a href=\"/\" class=\"link link__blank\">-コーポレートサイトトップへ</a>\n              </div>\n            </nav>\n          </div>\n\n          <div class=\"pick-wrap\">\n            <a href=\"/recruit/application/\" class=\"btn btn__type01\">\n              <div class=\"c-title01 c-title01__left c-title01__revers\">\n                <span class=\"en\">Application</span>\n                <span class=\"ja\">募集要項</span>\n              </div>\n              <div class=\"c-btn_arrow02\">\n                <svg class=\"arrow\">\n                  <use xlink:href=\"/recruit/img/svg/sprite-symbol.svg#icon-arrow\"></use>\n                </svg>\n              </div>\n            </a>\n            <a href=\"/recruit/entry/\" class=\"btn btn__type01\">\n              <div class=\"c-title01 c-title01__left c-title01__revers\">\n                <span class=\"en\">Entry</span>\n                <span class=\"ja\">エントリー</span>\n              </div>\n              <div class=\"c-btn_arrow02\">\n                <svg class=\"arrow\">\n                  <use xlink:href=\"/recruit/img/svg/sprite-symbol.svg#icon-arrow\"></use>\n                </svg>\n              </div>\n            </a>\n            <a href=\"/recruit/movie/\" class=\"btn btn__type02 movie\">\n              <div class=\"c-title01 c-title01__revers\">\n                <span class=\"en\">Special Movie</span>\n                <span class=\"ja\">スペシャルムービー</span>\n              </div>\n            </a>\n            <a href=\"/recruit/product/\" class=\"btn btn__type02 scene\">\n              <div class=\"c-title01 c-title01__revers\">\n                <span class=\"en\">Scene of Use</span>\n                <span class=\"ja\">暮らしの中の大鐵</span>\n              </div>\n            </a>\n          </div>\n        </div>\n      </header>\n<main class=\"page_faq\">\n  <section class=\"c-underMv\">\n    <div class=\"inner\">\n      <div class=\"txt-wrap\">\n        <ul class=\"c-breadcrumbs\">\n          <li class=\"breadcrumbs-item\"><a href=\"/\">TOP</a></li>\n          <li class=\"breadcrumbs-item\"><a href=\"/recruit/\">採用トップ</a></li>\n          <li class=\"breadcrumbs-item\">よくあるご質問</li>\n        </ul>\n        <h1 class=\"c-title01 c-title01__left\">\n          <span class=\"en\">FAQ</span>\n          <span class=\"ja\">よくあるご質問</span>\n        </h1>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"faq\">\n    <div class=\"inner_under\">\n      <div class=\"c-tab\">\n        <div class=\"c-tab__wrap col-4\" role=\"tablist\">\n          <button id=\"tab__01\" class=\"c-tab__item\" role=\"tab\" aria-selected=\"true\" aria-controls=\"panel01\" tabindex=\"0\">応募・選考</button>\n          <button id=\"tab__02\" class=\"c-tab__item\" role=\"tab\" aria-selected=\"false\" aria-controls=\"panel02\" tabindex=\"-1\">キャリア</button>\n          <button id=\"tab__03\" class=\"c-tab__item\" role=\"tab\" aria-selected=\"false\" aria-controls=\"panel03\" tabindex=\"-1\">働き方</button>\n          <button id=\"tab__04\" class=\"c-tab__item\" role=\"tab\" aria-selected=\"false\" aria-controls=\"panel04\" tabindex=\"-1\">福利厚生</button>\n        </div>\n        <!-- 応募・選考 -->\n        <div id=\"panel01\" class=\"c-tab__contents\" role=\"tabpanel\" aria-labelledby=\"tab__01\">\n          <div class=\"faq__wrap\">\n            <button class=\"js-accordion\">どこからエントリーすればよいですか？</button>\n            <p class=\"js-accordion-wrap\">\n              下記バナーの「マイナビ」よりエントリーください。\n              <span class=\"banner-wrap\">\n                <a href=\"https://job.mynavi.jp/27/pc/search/corp100201/outline.html\" class=\"banner\" target=\"_blank\" role=\"noopener noreferrer\"><img src=\"/recruit/img/common/img-entry_mynabi2027.png\" alt=\"マイナビ2027エントリーはこちらから\"></a>\n                <a href=\"https://job.mynavi.jp/28/pc/search/corp100201/outline.html\" class=\"banner\" target=\"_blank\" role=\"noopener noreferrer\"><img src=\"/recruit/img/common/img-entry_mynabi2028.png\" alt=\"マイナビ2028エントリーはこちらから\"></a>\n              </span>\n            </p>\n          </div>\n          <div class=\"faq__wrap\">\n            <button class=\"js-accordion\">インターンシップは実施していますか？</button>\n            <p class=\"js-accordion-wrap\">夏（7～9月頃）および秋冬（10～12月頃）に実施しています。<br>実施要項および応募方法については、<a href=\"https://job.mynavi.jp/27/pc/search/corp100201/outline.html\" target=\"_blank\" role=\"noopener noreferrer\">マイナビの当社ページ</a>よりご覧ください。</p>\n          </div>\n          <div class=\"faq__wrap\">\n            <button class=\"js-accordion\">募集している学部、学科について教えてください。</button>\n            <p class=\"js-accordion-wrap\">理系職種は材料系、機械系、化学系、電気・電子系ご出身の学生を中心にご活躍されていますが、理系・文系ともに特に制約はございません。</p>\n          </div>\n          <div class=\"faq__wrap\">\n            <button class=\"js-accordion\">選考スケジュールを教えてください。</button>\n            <p class=\"js-accordion-wrap\">エントリーシートご提出後、3回の面接がございます（筆記試験や適性検査はございません）。多少の前後はありますが、エントリーシートご提出から内々定までは約1ヶ月となります。</p>\n          </div>\n          <div class=\"faq__wrap\">\n            <button class=\"js-accordion\">会社説明会は開催していますか？</button>\n            <p class=\"js-accordion-wrap\">\n              開催しています。日程詳細および予約については、下記バナーよりマイナビの当社ページをご確認ください。\n              <span class=\"banner-wrap\">\n                <a href=\"https://job.mynavi.jp/27/pc/search/corp100201/outline.html\" class=\"banner\" target=\"_blank\" role=\"noopener noreferrer\"><img src=\"/recruit/img/common/img-entry_mynabi2027.png\" alt=\"マイナビ2027エントリーはこちらから\"></a>\n                <a href=\"https://job.mynavi.jp/28/pc/search/corp100201/outline.html\" class=\"banner\" target=\"_blank\" role=\"noopener noreferrer\"><img src=\"/recruit/img/common/img-entry_mynabi2028.png\" alt=\"マイナビ2028エントリーはこちらから\"></a>\n              </span>\n            </p>\n          </div>\n          <div class=\"faq__wrap\">\n            <button class=\"js-accordion\">オンラインでの面談、面接は可能ですか？</button>\n            <p class=\"js-accordion-wrap\">会社説明会、1次面接、2次面接はオンラインでの参加が可能です。最終面接は大阪の本社で実施します。</p>\n          </div>\n          <div class=\"faq__wrap\">\n            <button class=\"js-accordion\">入社前に取得しておくべき資格はありますか？</button>\n            <p class=\"js-accordion-wrap\">特にございません。</p>\n          </div>\n        </div>\n        <!-- キャリア -->\n        <div id=\"panel02\" class=\"c-tab__contents\" role=\"tabpanel\" aria-labelledby=\"tab__02\" hidden>\n          <div class=\"faq__wrap\">\n            <button class=\"js-accordion\">入社後の配属先、勤務地はどのように決まりますか？</button>\n            <p class=\"js-accordion-wrap\">入社1年目の仮配属先は、入社後の4月末に通知いたします。選考時に希望配属先や勤務地について伺う場合がございますが、最終的には会社の要員バランスや適性などを鑑み、会社側で総合的に判断いたします。</p>\n          </div>\n          <div class=\"faq__wrap\">\n            <button class=\"js-accordion\">1年目の研修はどんなことをしますか？</button>\n            <p class=\"js-accordion-wrap\">入社式後の4月は、社会人マナーを学ぶ外部講習と職種別の業務説明を受講していただきます。ゴールデンウイーク明けの5月から翌年3月までは、仮配属先にて、インストラクター役の先輩社員と実務を通じて業務経験を積んでいただきます。また、入社半年後および翌年3月には、これまで学んできたことや業務における課題について発表いただく研修発表会があります。</p>\n          </div>\n        </div>\n        <!-- 働き方 -->\n        <div id=\"panel03\" class=\"c-tab__contents\" role=\"tabpanel\" aria-labelledby=\"tab__03\" hidden>\n          <div class=\"faq__wrap\">\n            <button class=\"js-accordion\">休日は週何日ありますか？休日出勤はありますか？</button>\n            <p class=\"js-accordion-wrap\">原則、土日祝日は休日となります。繁忙期や操業への立ち会いなどで休日出勤の可能性はございますが、代休や振替休日、フレックス制度（コアタイム10～15時）、有給休暇取得により柔軟な働き方をしていただけます。</p>\n          </div>\n          <div class=\"faq__wrap\">\n            <button class=\"js-accordion\">残業時間はどれくらいありますか？</button>\n            <p class=\"js-accordion-wrap\"><a href=\"/recruit/data/#culture\">こちら</a>よりご確認ください。</p>\n          </div>\n          <div class=\"faq__wrap\">\n            <button class=\"js-accordion\">在宅勤務はできますか？</button>\n            <p class=\"js-accordion-wrap\">在宅勤務制度がございます。</p>\n          </div>\n        </div>\n        <!-- 福利厚生 -->\n        <div id=\"panel04\" class=\"c-tab__contents\" role=\"tabpanel\" aria-labelledby=\"tab__04\" hidden>\n          <div class=\"faq__wrap\">\n            <button class=\"js-accordion\">独身寮や社宅は誰でも入れますか？</button>\n            <p class=\"js-accordion-wrap\">ご実家が近い方でも独身寮や社宅への入居は可能です。独身寮は35歳、社宅は50歳を迎えるまでご入居いただけます。</p>\n          </div>\n          <div class=\"faq__wrap\">\n            <button class=\"js-accordion\">クラブ活動など、社内での交流機会はありますか？</button>\n            <p class=\"js-accordion-wrap\"><a href=\"/recruit/welfare/#club\">こちら</a>よりご確認ください。</p>\n          </div>\n          <div class=\"faq__wrap\">\n            <button class=\"js-accordion\">財形貯蓄など、社員の生活を応援する制度はありますか？</button>\n            <p class=\"js-accordion-wrap\"><a href=\"/recruit/welfare/#stock\">こちら</a>よりご確認ください。</p>\n          </div>\n          <div class=\"faq__wrap\">\n            <button class=\"js-accordion\">介護をサポートする制度について教えてください。</button>\n            <p class=\"js-accordion-wrap\">\n              <a href=\"/recruit/welfare/#care\">こちら</a>よりご確認ください。\n            </p>\n          </div>\n          <div class=\"faq__wrap\">\n            <button class=\"js-accordion\">給与や賞与、その他手当について教えてください。</button>\n            <p class=\"js-accordion-wrap\"><a href=\"/recruit/application/\">こちら</a>よりご確認ください。</p>\n          </div>\n          <div class=\"faq__wrap\">\n            <button class=\"js-accordion\">利用できる保養所などはありますか？</button>\n            <p class=\"js-accordion-wrap\"><a href=\"/recruit/welfare/#relo\">こちら</a>よりご確認ください。</p>\n          </div>\n          <div class=\"faq__wrap\">\n            <button class=\"js-accordion\">出産、育児をサポートする制度について教えてください。</button>\n            <p class=\"js-accordion-wrap\">\n              <a href=\"/recruit/welfare/#care\">こちら</a>よりご確認ください。\n            </p>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"faq__bottom\">\n        <p class=\"txt\">その他、上記質問以外で気になる点があれば、<br class=\"sp\">下記連絡先（総務部人事労働グループ 採用担当）までご連絡ください。</p>\n        <div class=\"faq__bottom_wrap\">\n          <a href=\"tel:06-6204-0161\" class=\"btn tel\">\n            <svg class=\"icon\">\n              <use xlink:href=\"/recruit/img/svg/sprite-symbol.svg#icon-tel\"></use>\n            </svg>\n            06-6204-0161\n          </a>\n          <a href=\"mailto:saiyou@osaka-seitetu.co.jp\" class=\"btn mail\">\n            <svg class=\"icon\">\n              <use xlink:href=\"/recruit/img/svg/sprite-symbol.svg#icon-mail\"></use>\n            </svg>\n            メールでお問い合わせ\n          </a>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"footer-entry\">\n  <div class=\"gsap_target\">\n    <div class=\"gsap_target_wrap en\">OPEN UP THE FUTURE OPEN UP THE FUTURE&nbsp;</div>\n  </div>\n\n  <div class=\"inner\">\n    <div class=\"contents\">\n      <a href=\"/recruit/application/\">\n        <h2 class=\"c-title01 c-title01__left c-title01__revers\">\n          <span class=\"en\">Application</span>\n          <span class=\"ja\">募集要項</span>\n        </h2>\n        <div class=\"c-btn_arrow02\">\n          <svg class=\"arrow\">\n            <use xlink:href=\"/recruit/img/svg/sprite-symbol.svg#icon-arrow\"></use>\n          </svg>\n        </div>\n      </a>\n      <a href=\"/recruit/entry/\">\n        <h2 class=\"c-title01 c-title01__left c-title01__revers\">\n          <span class=\"en\">Entry</span>\n          <span class=\"ja\">エントリー</span>\n        </h2>\n        <div class=\"c-btn_arrow02\">\n          <svg class=\"arrow\">\n            <use xlink:href=\"/recruit/img/svg/sprite-symbol.svg#icon-arrow\"></use>\n          </svg>\n        </div>\n      </a>\n    </div>\n  </div>\n</section>\n</main>\n\n</div>\n\n<footer>\n  <div class=\"inner\">\n    <div class=\"wrap\">\n      <div class=\"c-logo-wrap\">\n        <a href=\"/recruit/\">\n          <img src=\"/recruit/img/common/logo.svg\" alt=\"OPEN UP THE FUTURE\">\n          <div class=\"txt\">大阪製鐵株式会社 総合職向けリクルートサイト</div>\n        </a>\n      </div>\n      <div class=\"entry-wrap\">\n        <a href=\"https://job.mynavi.jp/27/pc/search/corp100201/outline.html\" rel=\"noopener noreferrer\" target=\"_blank\"><img src=\"/recruit/img/common/img-entry_mynabi2027.png\" alt=\"マイナビ2027