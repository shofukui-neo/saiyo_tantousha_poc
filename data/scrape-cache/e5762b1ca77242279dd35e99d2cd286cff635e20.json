recruit/faq/\">\n            よくあるご質問\n            <svg class=\"arrow\">\n              <use xlink:href=\"/recruit/img/svg/sprite-symbol.svg#icon-arrow\"></use>\n            </svg>\n          </a>\n        </li>\n        <li>\n          <a href=\"/recruit/\">\n            採用トップ\n            <svg class=\"arrow\">\n              <use xlink:href=\"/recruit/img/svg/sprite-symbol.svg#icon-arrow\"></use>\n            </svg>\n          </a>\n        </li>\n      </ul>\n    </div>\n  </div>\n\n  <div class=\"copyright-wrap\">\n    <div class=\"inner\">\n      <p class=\"copyright\">© OSAKA STEEL CO.,LTD. All rights reserved.</p>\n      <div class=\"link-wrap\">\n        <a href=\"/\" class=\"link link__blank\" target=\"_blank\" rel=\"noopener\">コーポレートサイトトップへ</a>\n      </div>\n    </div>\n  </div>\n</footer>\n\n<script src=\"https://code.jquery.com/jquery-3.6.0.min.js\"></script>\n\n\n<script src=\"/recruit/js/lib/splide.min.js\"></script>\n<script src=\"/recruit/js/base.js\"></script>\n<script src=\"/recruit/js/contents.js?260416\"></script>\n</body>\n\n</html>","finalUrl":"https://www.osaka-seitetu.co.jp/recruit/faq/","rendered":false,"_cachedAt":"2026-06-22T21:41:12.437Z"}