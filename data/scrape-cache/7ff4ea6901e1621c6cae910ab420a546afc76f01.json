length)return;const c=new IntersectionObserver(s=>{s.forEach(r=>{r.isIntersecting&&(r.target.classList.add(t),c.unobserve(r.target))})},n);o.forEach(s=>c.observe(s))},g=({selector:e,inClass:t,resetOpacity:n=!1})=>{const o=document.querySelectorAll(e);if(!o.length)return;n&&o.forEach(s=>s.style.opacity=\"0\");const c=new IntersectionObserver(s=>{s.forEach(r=>{const p=r.target;r.isIntersecting?p.classList.add(t):(p.classList.remove(t),n&&(p.style.opacity=\"0\"))})},{threshold:0});o.forEach(s=>c.observe(s))};g({selector:\".animate01\",inClass:\"animate__fadeInUp\",resetOpacity:!0}),g({selector:\".animate03\",inClass:\"animate__fadeIn\"}),h({selector:\".js-fadeUp1, .js-fadeUp2, .js-fadeUp3, .js-fadeLeft1, .js-fadeLeft2, .js-fadeLeft3, ul.service_list li\",inClass:\"is-inview\"}),h({selector:\".block\",inClass:\"fadeIn\",options:{rootMargin:\"0px 0px -200px 0px\"}});const u=document.querySelector(\".headerflex\");if(u){const e=()=>{document.documentElement.style.setProperty(\"--header-height\",`${u.offsetHeight}px`)};e();const t=new ResizeObserver(e);t.observe(u),i.addEventListener(\"abort\",()=>t.disconnect())}});</script>  </body></html>  <script>(function(){const apiUrl = \"https://13u8wycfh3.execute-api.ap-northeast-1.amazonaws.com//contact\";\n\n  const REQUIRED_TEXT = ['myoji', 'namae', 'kana_myoji', 'kana_namae', 'mail', 'message'];\n  const LABELS = {\n    myoji: 'お名前（姓）', namae: 'お名前（名）',\n    kana_myoji: 'ふりがな（姓）', kana_namae: 'ふりがな（名）',\n    mail: 'メールアドレス', tel: '電話番号', address: '住所',\n    items: 'お問い合わせ項目', item_others: 'その他詳細',\n    message: 'お問い合わせ内容', privacy: 'プライバシーポリシー',\n  };\n\n  function getFormData() {\n    const form = document.getElementById('contact-form');\n    const data = {};\n    const fd = new FormData(form);\n    for (const [key, val] of fd.entries()) {\n      if (key === 'items') {\n        data.items = data.items ? [...data.items, val] : [val];\n      } else {\n        data[key] = val;\n      }\n    }\n    return data;\n  }\n\n  function validate(data) {\n    for (const key of REQUIRED_TEXT) {\n      if (!data[key]?.trim()) return `${LABELS[key]} を入力してください`;\n    }\n    if (!data.items?.length) return 'お問い合わせ項目を1つ以上選択してください';\n    if (!data.privacy) return 'プライバシーポリシーへの同意が必要です';\n    return null;\n  }\n\n  function esc(str) {\n    return String(str).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/\"/g, '&quot;');\n  }\n\n  function buildConfirmList(data) {\n    const rows = [\n      ['お名前', `${data.myoji} ${data.namae}`],\n      ['ふりがな', `${data.kana_myoji} ${data.kana_namae}`],\n      ['メールアドレス', data.mail],\n      ...(data.tel ? [['電話番号', data.tel]] : []),\n      ...(data.postal_code ? [['郵便番号', `〒${data.postal_code}`]] : []),\n      ...(data.address ? [['住所', data.address]] : []),\n      ['お問い合わせ項目', Array.isArray(data.items) ? data.items.join('、') : data.items],\n      ...(data.item_others ? [['その他詳細', data.item_others]] : []),\n      ['お問い合わせ内容', data.message],\n    ];\n    return rows.map(([dt, dd]) =>\n      `<div class=\"confirm-list__row\"><dt>${esc(dt)}</dt><dd>${esc(dd).replace(/\\n/g, '<br>')}</dd></div>`\n    ).join('');\n  }\n\n  let pendingData = null;\n\n  document.getElementById('btn-confirm').addEventListener('click', () => {\n    const data = getFormData();\n    const error = validate(data);\n    const errEl = document.getElementById('form-error');\n    if (error) {\n      errEl.textContent = error;\n      errEl.style.display = '';\n      return;\n    }\n    errEl.style.display = 'none';\n    pendingData = data;\n    document.getElementById('confirm-list').innerHTML = buildConfirmList(data);\n    document.getElementById('view-input').style.display = 'none';\n    document.getElementById('view-confirm').style.display = '';\n    window.scrollTo({ top: 0, behavior: 'smooth' });\n  });\n\n  document.getElementById('btn-back').addEventListener('click', () => {\n    document.getElementById('view-confirm').style.display = 'none';\n    document.getElementById('view-input').style.display = '';\n    window.scrollTo({ top: 0, behavior: 'smooth' });\n  });\n\n  document.getElementById('btn-submit').addEventListener('click', async () => {\n    const btn = document.getElementById('btn-submit');\n    const errEl = document.getElementById('submit-error');\n    btn.disabled = true;\n    btn.textContent = '送信中…';\n    errEl.style.display = 'none';\n\n    try {\n      const res = await fetch(apiUrl, {\n        method: 'POST',\n        headers: { 'Content-Type': 'application/json' },\n        body: JSON.stringify(pendingData),\n      });\n      if (!res.ok) {\n        const json = await res.json().catch(() => ({}));\n        throw new Error(json.error ?? `サーバーエラー (${res.status})`);\n      }\n      document.getElementById('view-confirm').style.display = 'none';\n      document.getElementById('view-complete').style.display = '';\n      window.scrollTo({ top: 0, behavior: 'smooth' });\n    } catch (e) {\n      errEl.textContent = `送信に失敗しました。しばらく経ってから再度お試しください。（${e.message}）`;\n      errEl.style.display = '';\n      btn.disabled = false;\n      btn.textContent = '送信する';\n    }\n  });\n})();</script>","finalUrl":"https://www.sanwa-consul.co.jp/contact/","rendered":false,"_cachedAt":"2026-06-23T21:10:36.089Z"}