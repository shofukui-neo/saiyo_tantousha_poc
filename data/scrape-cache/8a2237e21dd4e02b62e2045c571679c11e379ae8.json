{"url":"https://www.maihamaclub.co.jp/recruit/list/?ca=2","html":"<!DOCTYPE html>\r\n<html lang=\"ja\">\r\n<head>\r\n<meta charset=\"utf-8\">\r\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">   <!-- IEの互換表示無効 -->\r\n<meta name=\"format-detection\" content=\"telephone=no\">   <!-- 電話番号自動リンク無効 -->\r\n<meta name=\"SKYPE_TOOLBAR\" content=\"SKYPE_TOOLBAR_PARSER_COMPATIBLE\">   <!-- Skypeによる電話番号置換無効 -->\r\n<meta name=\"viewport\" content=\"width=device-width\">\r\n<meta name=\"description\" content=\"中途採用|舞浜倶楽部の募集要項ページです。採用日程や応募資格、給与などの情報を掲載いたします。当倶楽部では手厚い研修制度で社員をバックアップ。スウェーデンのケア理念やケア手法を学べる他、入社してからのスキルアップも支援します。舞浜倶楽部で夢をカタチにしませんか？\">\r\n<meta name=\"keywords\" content=\"中途採用,舞浜倶楽部,介護施設,老人ホーム,採用,募集要項\">\r\n<title>中途採用|【公式】募集要項｜株式会社舞浜倶楽部</title>\r\n<link href=\"https://fonts.googleapis.com/css2?family=Noto+Sans+JP&family=Noto+Serif+JP:wght@400;500;600&family=Simonetta&display=swap\" rel=\"stylesheet\">\r\n<link rel=\"stylesheet\" href=\"../css/reset.css\">\r\n<link rel=\"stylesheet\" href=\"../css/base.css\">\r\n<link rel=\"stylesheet\" href=\"../css/utility.css\">\r\n<link rel=\"stylesheet\" href=\"../css/content.css\">\r\n\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-WD77NXD93V\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'G-WD77NXD93V');\n  gtag('config', 'UA-38313556-1');\n</script>\n\t</head>\r\n\r\n<body id=\"pagetop\" class=\"list\">\r\n<div id=\"wrapper\">\r\n\r\n<!-- ▼ HEADER start\r\n################################################## -->\r\n<div class=\"header-mv\">\r\n\t<header id=\"header\" class=\"clearfix\">\n\n    <div class=\"logo\">\n        <a href=\"/recruit/\">\n            <img class=\"logo-mark mark-l\" src=\"/recruit/common_img/logo_cercle.png\">\n            <img class=\"logo-mark mark-m2\" src=\"/recruit/common_img/logo_cercle55px.png\">\n            <img class=\"logo-mark mark-m\" src=\"/recruit/common_img/logo_cercle2.png\">\n            <span class=\"logo-mark_text\"><img class=\"logo-mark_text\" src=\"/recruit/common_img/logo_text.png\" alt=\"舞浜倶楽部\"></span>\n        </a>\n    </div>\n    \n    <div class=\"header--r\">\n        <div class=\"header--r_link\">\n            <ul class=\"header--r_list\">\n                <li><a class=\"arrow\" href=\"/recruit/topics/\">TOPICS</a></li>\n                <li><a class=\"arrow\" href=\"/recruit/list/\">募集要項</a></li>\n            </ul>\n        </div>\n        <nav>\n            <p class=\"hum_menu\"><span></span><span></span><span></span></p>\n            <ul class=\"nav\">\n                <li class=\"rwd_disp_xo\"><a href=\"/recruit/topics/\">TOPICS</a></li>\n                <li class=\"rwd_disp_xo\"><a href=\"/recruit/list/\">募集要項</a></li>\n\n                <li><a href=\"/recruit/care/\">舞浜倶楽部のケア</a></li>\n                <li><a href=\"/recruit/works/\">舞浜倶楽部のお仕事</a></li>\n                <li><a href=\"/recruit/career/\">研修制度/キャリアアップ</a></li>\n                <li><a href=\"/recruit/benefits/\">福利厚生</a></li>\n                <li><a href=\"/recruit/interview/\">先輩社員インタビュー</a></li>\n                <li><a href=\"/recruit/data/\">舞浜倶楽部の数字いろいろ！</a></li>\n                <li><a href=\"/recruit/faq/\">よくある質問</a></li>\n                <li class=\"rwd_disp_xo\"><a href=\"/recruit/entry/\">エントリーフォーム</a></li>\n            </ul>\n        </nav>\n    </div>\n</header><!-- /#header -->\r\n\t<div class=\"mv\">\r\n\t\t<h1><span class=\"serif\">募集要項</span></h1>\r\n\t</div>\r\n</div>\r\n\r\n<div id=\"breadcrumb\">\r\n\t<ul class=\"site_wrap\">\r\n\t\t<li><a href=\"../\">HOME</a></li>\r\n\t\t<li>募集要項</li>\r\n\t</ul>\r\n</div><!-- /#breadcrumb -->\r\n\r\n<!-- ▼ PAGE CONTANTS start\r\n################################################## -->\r\n<div id=\"content_area\">\r\n\r\n\t<section class=\"sec list01 site_wrap\">\r\n\t\t<div class=\"list01_txt\">\r\n\t\t\t<h2 class=\"ttl\">舞浜倶楽部で夢をカタチに</h2>\r\n\t\t\t<p class=\"txt\">舞浜倶楽部で、あなたの夢をカタチにしませんか？<br>⼿厚い研修制度であなたの社会⼈としての第⼀歩をバックアップ。<br>福祉先進国スウェーデンのケア理念やケア⼿法を学べるほか、やる気に応じて⼊社してからのスキルアップも⽀援します。<br>会社訪問は随時お受けしていますので、ぜひ舞浜倶楽部をその⽬で⾒て確かめてください。</p>\r\n\t\t\t<a class=\"list01_btn arrow-tin-wh\" href=\"../topics/\">説明会情報はこちら</a>\r\n\t\t</div>\r\n\t\t<div class=\"list01_img\"><img class=\"img\" src=\"images/list-img.jpg\"></div>\r\n\t</section>\r\n\r\n\t<section class=\"list_entry site_wrap\">\r\n\t\t<h2>会社説明会にエントリー</h2>\r\n\t\t<div class=\"flex_wrap\">\r\n\t\t\t<p class=\"txt\">\r\n\t\t\t\t新卒学生向けに会社説明会を開催します。<br>皆様の参加申込をお待ちしています。</p>\r\n\t\t\t<a class=\"arrow-tin-wh\" href=\"../entry/\">エントリーフォーム</a>\r\n\t\t</div>\r\n\t</section>\r\n\r\n\t<section class=\"sec list02\">\r\n\t\t<h2 class=\"ttl_line\">募集要項</h2>\r\n\t\t<ul class=\"site_wrap page_link\">\r\n            <li><a class=\"btn\" href=\"./\">ALL</a></li>\r\n                            <li>\r\n                    <a class=\"btn\" href=\"./?ca=1\">新卒採用</a>\r\n                </li>\r\n                            <li>\r\n                    <a class=\"btn active\" href=\"./?ca=2\">中途採用</a>\r\n                </li>\r\n                            <li>\r\n                    <a class=\"btn\" href=\"./?ca=3\">パート採用</a>\r\n                </li>\r\n            \t\t</ul>\r\n\r\n                                    <div class=\"dl_table_style site_wrap\">\r\n                    <h3 class=\"list02_title\">介護職（正社員）</h3>\r\n                    <div class=\"list02_box\">\r\n                                                                                    <div class=\"list02_box--img\">\r\n                                    <img src=\"./up_img/1735871417-371222_1.jpg\" alt=\"介護職（正社員）\">\r\n                                </div>\r\n                                                                            <div class=\"list02_box--txt\">\r\n                            <p>【仕事内容】</p>\r\n<p>有料老人ホームまたは小規模多機能型施設での介護業務全般</p>\r\n<p>★ぜひ見学して仕事の様子をご覧ください！</p>\r\n<p>&nbsp;</p>\r\n<p>【求める人材】</p>\r\n<p>・目的が共有できてチームワーク作りができること</p>\r\n<p>・マナーを身につけていること</p>\r\n<p>・体調管理が出来ること</p>\r\n<p>&nbsp;</p>\r\n<p>【主な取り組み】</p>\r\n<p>・スウェーデンから取り入れたケア技術の実践</p>\r\n<p>・国内トップレベルの手厚い介護と美味しい食事</p>\r\n<p>・既存業務IT化の推進（インカム、電子カルテ、LINEWORKS等の導入）</p>\r\n<p>&nbsp;</p>                        </div>\r\n                    </div>\r\n                                                                        <dl>\r\n                                <dt>採用条件・資格・勤務地</dt>\r\n                                <dd><p>【採用条件】</p>\r\n<p>・面接と試験により選抜します</p>\r\n<p>・採用から3ヶ月の試用期間があります※条件の変更なし</p>\r\n<p>・人事異動による転勤・配置換えの可能性があります（浦安市内）</p>\r\n<p>&nbsp;</p>\r\n<p>【資格】</p>\r\n<p>資格取得見込または入社後に資格取得を目指す方</p>\r\n<p>&nbsp;</p>\r\n<p>【勤務地】（ご希望を考慮します）</p>\r\n<p>・有料老人ホーム「富士見サンヴァーロ」（浦安市富士見3-16-46）</p>\r\n<p>・有料老人ホーム「新浦安フォーラム」（浦安市高洲1-2-1）</p>\r\n<p>・小規模多機能型施設「きはち」（浦安市高洲1-2-1）</p></dd>\r\n                            </dl>\r\n                                                                                                <dl>\r\n                                <dt>給与・賞与・昇給</dt>\r\n                                <dd><p>【給与】（処遇改善手当、資格手当を含む）</p>\r\n<p>・介護職（一般）</p>\r\n<p>基本給：190,000円～</p>\r\n<p>・介護職（介護福祉士）</p>\r\n<p>基本給：200,000円～</p>\r\n<p>＊これまでのご経験を考慮します</p>\r\n<p>＊支給日：毎月末日締切・当月25日支給（25日が銀行休業日の場合繰り上がり）</p>\r\n<p>★夜勤、早番遅番などを含めた月給・・・22.7万円～</p>\r\n<p>&nbsp;</p>\r\n<p>【賞与】</p>\r\n<p>年2回（6月と12月）※昨年度実績で年間基本給の2.8ヶ月分（人事考課で増減あり）</p>\r\n<p>★例えば6月は・・・200,000&times;1.4＝280,000円！</p>\r\n<p>&nbsp;</p>\r\n<p>【昇給】</p>\r\n<p>年1回（4月）※人事評価、管理職任命等による</p></dd>\r\n                            </dl>\r\n                                                                                                <dl>\r\n                                <dt>各種手当</dt>\r\n                                <dd><p>【資格手当】</p>\r\n<p>1資格5,000円（介護福祉士・社会福祉士・精神保健福祉士・介護支援専門員</p>\r\n<p>認知症ケア専門士・タクティールケア認定者）</p>\r\n<p>　</p>\r\n<p>【早遅手当】</p>\r\n<p>1回500円（日勤時間より90分以上ずれて勤務する場合に支給）</p>\r\n<p>&nbsp;</p>\r\n<p>【夜勤手当】</p>\r\n<p>1回8,000円</p>\r\n<p>&nbsp;</p>\r\n<p>【年末年始手当】</p>\r\n<p>1日2,400円（12/29～1/3の期間）</p>\r\n<p>&nbsp;</p>\r\n<p>【勤続手当】</p>\r\n<p>・勤続10年以上の介護福祉士を有する介護職　月額32,000円</p>\r\n<p>・上記以外の勤続10年以上の正社員（部門問わず）　月額7,200円</p>\r\n<p>・勤続5年以上の介護福祉士を有する介護職　月額15,000円</p>\r\n<p>・上記外の勤続5年以上の正社員（部門問わず）　月額3,700円</p>\r\n<p>　＊勤続手当は介護職員等特定処遇改善加算に対する支給となります</p>\r\n<p>　＊介護保険制度の改定等で金額が変更となる場合があります。</p>\r\n<p>★10年目、20年目にも永年勤続表彰として金一封あり</p>\r\n<p>&nbsp;</p>\r\n<p>【通勤手当】</p>\r\n<p>1ヶ月最大50,000円まで</p></dd>\r\n                            </dl>\r\n                                                                                                <dl>\r\n                                <dt>勤務時間</dt>\r\n                                <dd><p>【シフト制】＊シフト時間は職場により若干の前後があります</p>\r\n<p>日勤：9:00～18:00（休憩1時間）</p>\r\n<p>早出：7:00～16:00（休憩1時間）</p>\r\n<p>遅出：10:30～19:30（休憩1時間）</p>\r\n<p>準夜：21:30～翌朝6:30（休憩1時間）</p>\r\n<p>夜勤：17:00～翌朝10:00（休憩１時間+仮眠２時間）</p></dd>\r\n                            </dl>\r\n                                                                                                <dl>\r\n                                <dt>休日・有給休暇</dt>\r\n                                <dd><p>【休日】</p>\r\n<p>年間115日（31日まである月は10日間、それ以外の月は9日間）</p>\r\n<p>★そのうち3日は希望休が出せます</p>\r\n<p>&nbsp;</p>\r\n<p>【有給休暇】</p>\r\n<p>採用時に就業規則に基づく規定日数付与。毎年4月1日に更新します</p>\r\n<p>　＊入社6ヶ月後から、有給休暇の計画的取得制度あり（年1回1週間程度の連続休暇制度）</p>\r\n<p>&nbsp;</p>\r\n<p>【その他休暇等】</p>\r\n<p>・慶弔休暇、産前産後休暇、育児休業、介護休業、裁判員制度休暇</p>\r\n<p>・永年勤続表彰による特別休暇（10年目、20年目、30年目）</p>\r\n<p>&nbsp;</p></dd>\r\n                            </dl>\r\n                                                                                                <dl>\r\n                                <dt>福利厚生・研修制度</dt>\r\n                                <dd><p>【福利厚生】</p>\r\n<p>・各種社会保険完備（厚生年金、健康保険、雇用保険、労災）</p>\r\n<p>・就業規則に基づく遠隔地からの採用者には、引越支度金10万円を初回給与時に支給</p>\r\n<p>・単身者用社宅（20㎡～、家賃18,000円～、契約更新費用等無し、５年目からは家賃UP）</p>\r\n<p>・退職金制度（入社3年目以降）</p>\r\n<p>・定年後再雇用制度（定年60歳・継続雇用65歳）</p>\r\n<p>・育児時短勤務（小学校就学の始期まで）</p>\r\n<p>・食事補助制度</p>\r\n<p>・タクティールケア研修費貸与制度</p>\r\n<p>・ユニフォーム貸与制度</p>\r\n<p>・初任者研修費用貸与制度（社宅入居予定の介護職）</p>\r\n<p>&nbsp;</p>\r\n<p>【研修制度】</p>\r\n<p>・中途採用社員対象研修とプリセプター制度</p>\r\n<p>・各種社内研修制度</p>\r\n<p>・各種社外研修制度</p>\r\n<p>&nbsp;</p></dd>\r\n                            </dl>\r\n                                                                                                <dl>\r\n                                <dt>選考フロー・その他</dt>\r\n                                <dd><p>【選考フロー】</p>\r\n<p>エントリーフォームor電話でのご応募　&rArr;　履歴書提出　&rArr;　面接日程決定　&rArr;　面接（1回もしくは2回）　&rArr;　内定</p>\r\n<p>・採用不採用については、最終面接後10日以内にメールor文書でお知らせします。</p>\r\n<p>・採用の場合は、入社承諾書の受理を持って内定を決定します。</p>\r\n<p>&nbsp;</p>\r\n<p>株式会社舞浜倶楽部 　採用担当</p>\r\n<p>【ＴＥＬ】047-304-2400</p>\r\n<p>【ＦＡＸ】047-352-7302</p>\r\n<p>【応募・問い合わせ】　<span style=\"font-size: 18px; text-decoration: underline;\"><strong><a href=\"https://www.maihamaclub.co.jp/recruit/entry/\">エントリーフォーム</a></strong></span></p>\r\n<p>お気軽にお問い合わせ下さい。施設見学も随時承っています。</p>\r\n<p>&nbsp;</p></dd>\r\n                            </dl>\r\n                                                                                                                                                    </div>\r\n                                        <ul class=\"pagenation site_wrap\">\r\n                                                            <li></li>\r\n                                                                <li><a class=\"btn\" href=\"./?ca=2&p=2\">次へ</a></li>\r\n                                                </ul>\r\n        \t</section>\r\n\r\n</div><!-- /#content_area -->\r\n\r\n\r\n<!-- ▼ FOOTER start\n################################################## -->\n<a class=\"side_cv\" href=\"/recruit/entry/\">\n\t<img src=\"/recruit/common_img/float_pc.png\" class=\"rwd_disp_ox\">\n\t<img src=\"/recruit/common_img/float_sp.png\" class=\"rwd_disp_xo\">\n</a>\n<div class=\"contact\">\n\t<p>エントリーをご希望の方は<br class=\"rwd_disp_xo\">こちらから</p>\n\t<a class=\"arrow-tin-wh\" href=\"/recruit/entry/\">エントリーフォーム</a>\n</div>\n\n<footer id=\"footer\">\n\t<div class=\"footer--top\">\n\t\t<div class=\"site_wrap\">\n\t\t\t<a class=\"footer--top_logo\">\n\t\t\t    <img class=\"img\" src=\"/recruit/common_img/logo.png\" alt=\"舞浜倶楽部\">\n\t\t\t</a>\n\t\t\t<p class=\"footer--top_address\">舞浜倶楽部 本社　<br class=\"rwd_disp_xo\">〒279-0023 千葉県浦安市⾼洲1-2-1</p>\n\t\t\t<ul>\n\t\t\t\t<li class=\"tel\">TEL：<a class=\"sp_link\" href=\"tel:047-304-2400\">047-304-2400</a></li>\n\t\t\t</ul>\n\t\t</div>\n\t</div>\n\t<div class=\"footer--bottom site_wrap\">\n        <div class=\"footer--bottom_link\">\n            <p><a class=\"cp_btn arrow-tin-wh\" href=\"//www.maihamaclub.co.jp/\" target=\"_blank\">株式会社舞浜倶楽部 本サイト</a></p>\n\t\t\t<p><a href=\"/recruit/\">採用TOP</a></p>\n\t\t\t<ul>\n\n\t\t\t\t<li><a class=\"arrow-wh\" href=\"/recruit/care/\">舞浜倶楽部のケア</a></li>\n\t\t\t\t<li><a class=\"arrow-wh\" href=\"/recruit/works/\">舞浜倶楽部のお仕事</a></li>\n\t\t\t\t<li><a class=\"arrow-wh\" href=\"/recruit/career/\">研修制度/キャリアアップ</a></li>\n\t\t\t\t<li><a class=\"arrow-wh\" href=\"/recruit/benefits/\">福利厚生</a></li>\n\t\t\t\t<li><a class=\"arrow-wh\" href=\"/recruit/interview/\">先輩社員インタビュー</a></li>\n\t\t\t\t<li><a class=\"arrow-wh\" href=\"/recruit/data/\">舞浜倶楽部の数字いろいろ！</a></li>\n                <li><a class=\"arrow-wh\" href=\"/recruit/faq\">よくある質問</a></li>\n\t\t\t\t<li><a class=\"arrow-wh\" href=\"/recruit/list/\">募集要項</a></li>\n                <li><a class=\"arrow-wh\" href=\"/recruit/topics/\">TOPICS</a></li>\n                <li><a class=\"arrow-wh\" href=\"/recruit/entry/\">エントリーフォーム</a></li>\n                <li><a class=\"arrow-wh\" href=\"/recruit/entry#pp\">個人情報保護方針</a></li>\n\t\t\t</ul>\n\t\t</div>\n\t\t<!--<div class=\"footer--bottom_btn\">\n\t\t\t<a class=\"maynavi2021\" href=\"//job.mynavi.jp/21/pc/search/corp84005/outline.html\" target=\"_blank\"><img src=\"//job.mynavi.jp/conts/kigyo/2021/logo/MYNAVI_OFFICIAL_mynavi2021.jpg\" alt=\"マイナビ\" border=\"0\"></a>\n            <a class=\"maynavi\" href=\"https://job.mynavi.jp/22/pc/search/corp84005/is.html\" target=\"_blank\"><img src=\"/recruit/common_img/22logo_l.gif\"></a>\n\t\t</div>-->\n\t</div>\n</footer><!-- /#footer -->\r\n</div><!-- /#wrapper -->\r\n\r\n<!-- ▼ JavaScript\r\n################################################## -->\r\n<!-- ▽ jQuery 読み込み -->\r\n<script src=\"//ajax.googleapis.com/ajax/libs/jquery/1.11.1/jquery.min.js\"></script>\r\n<script>window.jQuery || document.write('<script src=\"../js/jquery-1.11.1.min.js\"><\\/script>');</script>   <!-- jQuery Fallback -->\r\n<!-- △ end -->\r\n<script src=\"../js/script.js\"></script>\r\n</body>\r\n</html>\r\n","finalUrl":"https://www.maihamaclub.co.jp/recruit/list/?ca=2","rendered":false,"_cachedAt":"2026-06-22T20:29:23.531Z"}