       <path class=\"line\" d=\"M0 14V13H77V14H0Z\" fill=\"#FFFFFF\"></path>\n                                <path d=\"M80 14L67 27V25L77.67 15.66C78.32 15.09 77.86 13.99 77 14V13C77.86 13.01 78.32 11.96 77.67 11.4L67 2V0L80 13V14Z\" fill=\"#FFFFFF\"></path>\n                            </svg>                               \n                        </div>\n                    </div>\n                </div>\n            </div>\n        </a>\n    </div>\n</section>\n</main>\n\n \t\t<footer class=\"footerArea js-footer-display-toggle\">\n    <div class=\"innerBlock\">\n        <a href=\"#js-laoding-init\" class=\"scrolltop js-anchor --default\">\n            <img src=\"../assets/images/common_header_arrow_icon.png\" class=\"arrow\" alt=\"\">\n        </a>\n        <a href=\"../\" class=\"logo\">\n            <img src=\"../assets/images/common_logo.png\" class=\"img\" alt=\"イチカワ株式会社\">\n        </a>\n        <ul class=\"linkList\">\n            <li class=\"item\">\n                <a href=\"../\" class=\"link\">\n                    <span class=\"title f-en\">Home</span>\n                    <span class=\"sub f-jp\">サイトTOPへ</span>\n                </a>\n            </li>\n            <li class=\"item\">\n                <a href=\"../about\" class=\"link\">\n                    <span class=\"title f-en\">About Us</span>\n                    <span class=\"sub f-jp\">イチカワとは</span>\n                </a>\n                <ul class=\"innerList\">\n                    <li class=\"innerItem\">\n                        <a href=\"../about/#sec1\" class=\"link f-jp js-anchor\">イチカワの強み</a>\n                    </li>\n                    <li class=\"innerItem\">\n                        <a href=\"../about/#sec2\" class=\"link f-jp js-anchor\">事業紹介</a>\n                    </li>\n                    <li class=\"innerItem\">\n                        <a href=\"../about/#sec3\" class=\"link f-jp js-anchor\">数字で見るイチカワ</a>\n                    </li>\n                </ul>\n            </li>\n            <li class=\"item\">\n                <a href=\"../work\" class=\"link\">\n                    <span class=\"title f-en\">Work</span>\n                    <span class=\"sub f-jp\">仕事について</span>\n                </a>\n                <ul class=\"innerList\">\n                    <li class=\"innerItem\">\n                        <a href=\"../work/#sec1\" class=\"link f-jp js-anchor\">職種紹介</a>\n                    </li>\n                    <li class=\"innerItem\">\n                        <a href=\"../work/#sec2\" class=\"link f-jp js-anchor\">社員紹介</a>\n                    </li>\n                </ul>\n            </li>\n            <li class=\"item\">\n                <a href=\"../organization\" class=\"link\">\n                    <span class=\"title f-en\">Organization</span>\n                    <span class=\"sub f-jp\">あなたを支える会社の制度</span>\n                </a>\n                <ul class=\"innerList\">\n                    <li class=\"innerItem\">\n                        <a href=\"../organization/#sec1\" class=\"link f-jp js-anchor\">人材育成</a>\n                    </li>\n                    <li class=\"innerItem\">\n                        <a href=\"../organization/#sec2\" class=\"link f-jp js-anchor\">福利厚生</a>\n                    </li>\n                </ul>\n            </li>\n            <li class=\"item\">\n                <a href=\"../infomation\" class=\"link\">\n                    <span class=\"title f-en\">Infomation</span>\n                    <span class=\"sub f-jp\">採用情報</span>\n                </a>\n                <ul class=\"innerList\">\n                    <li class=\"innerItem\">\n                        <a href=\"../infomation/#sec1\" class=\"link f-jp js-anchor\">募集要項</a>\n                    </li>\n                    <li class=\"innerItem\">\n                        <a href=\"../infomation/#sec2\" class=\"link f-jp js-anchor\">選考フロー</a>\n                    </li>\n                    <li class=\"innerItem\">\n                