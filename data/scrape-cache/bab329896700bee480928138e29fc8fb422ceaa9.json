{"url":"https://www.koaglobal.com/recruit/company_04.html","html":"<!DOCTYPE html>\r\n<html lang=\"ja\">\r\n<head>\r\n<script id=\"Cookiebot\" src=\"https://consent.cookiebot.com/uc.js\" data-cbid=\"9b6fb1f6-52f8-4ad1-af6e-c4b14938b209\" data-blockingmode=\"auto\" type=\"text/javascript\"></script>\r\n<meta charset=\"utf-8\">\r\n<meta name=\"format-detection\" content=\"telephone=no\">\r\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\r\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1, maximum-scale=1, user-scalable=0\">\r\n<title>KOAの取り組み | COMPANY |新卒採用情報 | KOA株式会社</title>\r\n<meta name=\"keywords\" content=\"新卒採用情報,新卒,インターンシップ,会社説明会,伊那谷,抵抗器,電子部品,KOA,コーア\">\r\n<meta name=\"description\" content=\"ワクワクしようよ！このコンセプトには、私たちの様々な思いが込められています。何事も楽しまないとオモシロくない！仕事も、普段の生活も、真剣に楽しく。時には悩んで凹んで、乗り越えた時に楽しさが込み上げてくる。私たちは皆さんと共にワクワクする未来を創っていきたい。そう思っています。\">\r\n\r\n<!--============ IMPORT =============-->\r\n<link href=\"share/css/import.css?260409\" rel=\"stylesheet\" type=\"text/css\" media=\"all\" />\r\n<link href=\"share/css/aos.css?260409\" rel=\"stylesheet\" type=\"text/css\" media=\"screen\" />\r\n<link href=\"share/css/print.css?260409\" rel=\"stylesheet\" type=\"text/css\" media=\"print\" />\r\n\r\n<script type=\"text/javascript\" src=\"share/js/jquery.min.js\"></script>\r\n<script type=\"text/javascript\" src=\"share/js/common.js\"></script>\r\n<script type=\"text/javascript\" src=\"share/js/aos.js\"></script>\r\n<!--=========== /IMPORT =============-->\r\n\r\n<!-- Favicons -->\r\n<link rel=\"icon\" href=\"images/favicon.ico\" type=\"image/vnd.microsoft.icon\">\r\n\r\n<!-- Google Analytics -->\r\n<script>\r\n    (function (i, s, o, g, r, a, m) {\r\n        i['GoogleAnalyticsObject'] = r; i[r] = i[r] || function () {\r\n            (i[r].q = i[r].q || []).push(arguments)\r\n        }, i[r].l = 1 * new Date(); a = s.createElement(o),\r\n        m = s.getElementsByTagName(o)[0]; a.async = 1; a.src = g; m.parentNode.insertBefore(a, m)\r\n    })(window, document, 'script', '//www.google-analytics.com/analytics.js', 'ga');\r\n\r\n    ga('create', 'UA-67261662-1', 'auto');\r\n    ga('send', 'pageview');\r\n</script>\r\n\r\n</head>\r\n\r\n<body id=\"p-2nd\">\r\n\r\n<section id=\"header\">\r\n\r\n\t<h1 id=\"title\">\r\n\t\t<a href=\"index.html\" ><img src=\"images/title.svg\" alt=\"KOA株式会社 新卒採用情報\" name=\"title\" class=\"pc_title\" /></a>\r\n\t\t<a href=\"index.html\" ><img src=\"images/sp_title.svg\" alt=\"KOA株式会社 新卒採用情報\" name=\"title\" class=\"sp_title\" /></a>\r\n\t</h1>\r\n\r\n\t<ul class=\"head_menu pc\">\r\n\r\n\t\t<li class=\"menu-head\"><a href=\"#\"><img src=\"images/bo_gnavi_01.png\" alt=\"COMPANY\" class=\"imgover\" /></a>\r\n\t\t<div class=\"menu-content\">\r\n\t\t\t<ul class=\"block_01\">\r\n\t\t\t\t<li class=\"left\"><a href=\"company_01.html\"><img src=\"images/top/bo_company_01.png\" alt=\"数字で見るKOA\" /></a></li>\r\n\t\t\t\t<li><a href=\"company_03.html\"><img src=\"images/top/bo_company_03.png\" alt=\"KOA MIND\" /></a></li>\r\n\t\t\t\t<li><a href=\"company_04.html\"><img src=\"images/top/bo_company_04.png\" alt=\"KOAの取り組み\" /></a></li>\r\n\t\t\t</ul>\r\n\t\t</div>\r\n\t\t</li>\r\n\r\n\t\t<li class=\"menu-head\"><a href=\"#\"><img src=\"images/bo_gnavi_02.png\" alt=\"WORKING PLACE\" class=\"imgover\" /></a>\r\n\t\t<div class=\"menu-content\">\r\n\t\t\t<ul class=\"block_02\">\r\n\t\t\t\t<li class=\"left\"><a href=\"working_01.html\"><img src=\"images/top/bo_place_01.png\" alt=\"KOA社員アンケート\" /></a></li>\r\n\t\t\t\t<li><a href=\"working_02.html\"><img src=\"images/top/bo_place_02.png\" alt=\"KOA流人事制度\" /></a></li>\r\n\t\t\t\t<li><a href=\"working_03.html\"><img src=\"images/top/bo_place_03.png\" alt=\"「改善」と「ものづくり」\" /></a></li>\r\n\t\t\t</ul>\r\n\t\t</div>\r\n\t\t</li>\r\n\r\n\t\t<li class=\"menu-head\"><a href=\"works_index.html\"><img src=\"images/bo_gnavi_03.png\" alt=\"WORKS\" class=\"imgover\" /></a>\r\n\t\t<div class=\"menu-content\">\r\n\t\t\t<ul class=\"block_03\">\r\n\t\t\t\t<li class=\"left\