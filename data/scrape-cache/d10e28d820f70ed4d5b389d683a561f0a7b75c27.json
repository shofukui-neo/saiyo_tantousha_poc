jax/libs/jqueryui/1.12.1/themes/base/jquery-ui.min.css\">\r\n<script src=\"https://cdnjs.cloudflare.com/ajax/libs/jqueryui/1.12.1/jquery-ui.min.js\"></script>\r\n<script src=\"https://www.gogo-jobcafe-shimane.jp/css/datepicker/datepicker-ja.js\"></script>\r\n\r\n<link href=\"https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css\" rel=\"stylesheet\" />\r\n<script src=\"https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js\"></script>\r\n<script src=\"https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/i18n/ja.js\"></script>\r\n<script src=\"https://www.gogo-jobcafe-shimane.jp/js/SelectSearch.js\"></script>\r\n\r\n<script src=\"https://www.gogo-jobcafe-shimane.jp/js/CrmMember.js\"></script>\r\n\n<!-- Google Tag Manager (noscript) -->\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-MJVJMFK\"\n        height=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n<!-- End Google Tag Manager (noscript) -->\n\n<div class=\"page_content\">\n\n    <div class=\"mainvisual\">\n        <h1 class=\"pagetitle\">しまね登録</h1>\n    </div>\n\n    <div class=\"breadcrumb contents_inner\">\n        <ol itemscope itemtype=\"https://schema.org/BreadcrumbList\">\n            <li itemprop=\"itemListElement\" itemscope itemtype=\"https://schema.org/ListItem\">\n                <a itemprop=\"item\" href=\"https://www.gogo-jobcafe-shimane.jp\">\n                    <span itemprop=\"name\">TOP</span>\n                </a>\n                <meta itemprop=\"position\" content=\"1\" />\n            </li>\n            <li itemprop=\"itemListElement\" itemscope itemtype=\"https://schema.org/ListItem\">\n                <a itemprop=\"item\">\n                    <span itemprop=\"name\">会員登録</span>\n                </a>\n                <meta itemprop=\"position\" content=\"2\" />\n            </li>\n        </ol>\n    </div>\n\n    <div class=\"contents_wrap\">\n\n        <div class=\"clear-fix\">\n                                </div>\n\n        <p class=\"explanation_txt\">\n            <a href=\"#function_contents\">以下のサービス・制度の</a>共通会員登録ページです。<br>\n            しまね登録はご登録内容に応じて、各種サービス・制度をご利用いただけます。\n        </p>\n\n        <!-- image_block -->\n        <div class=\"image_block\">\n            <p class=\"image\">\n                <img src=\"https://www.gogo-jobcafe-shimane.jp/img/jobcafe/register_bnr.png\" alt=\"ご登録はこちら\">\n            </p>\n            <p class=\"arrows\">\n                <img src=\"https://www.gogo-jobcafe-shimane.jp/img/jobcafe/register_arrow.png\" alt=\"\">\n            </p>\n        </div>\n        <!-- //image_block -->\n\n        <!-- register_select_block -->\n        <div class=\"register_select_block\">\n            <div id=\"smartwizard\" class=\"col-lg-12 sw-theme-arrows\">\n    <ul class=\"nav nav-tabs step-anchor\">\n        <li class=active><a href=\"#step-1\">STEP 1<br><small>サービスを選択</small></a></li>\n        <li ><a href=\"#step-2\">STEP 2<br><small>認証メール確認</small></a></li>\n        <li ><a href=\"#step-3\">STEP 3<br><small>入力</small></a></li>\n        <li ><a href=\"#step-4\">STEP 4<br><small>登録完了</small></a></li>\n    </ul>\n</div>\n\n\n            \n            <form method=\"POST\">\n                <input type=\"hidden\" name=\"_token\" value=\"U1K0NgGW9mHaQs5YWxaKrjDu1lTXOcrGBAZqLaSv\">                <input type=\"hidden\" name=\"via_site\" value=\"1\">\n                <input type=\"hidden\" name=\"friend_referral_cd\" value=\"\">\n                <input type=\"hidden\" name=\"stcp_cd\" value=\"\">\n\n                <div class=\"panel panel-default\" style=\"clear: both;\">\n                    <div class=\"panel-heading\">\n                        <b>サービスを選択</b><br>\n                        あなたにぴったりのサービスを提供するため、あなたの情報を教えてください。\n                    </div>\n                    <div class=\"panel-body\">\n                        <div class=\"col-lg-12\">\n    <div id=\"student_field\">\n        <div class=\"col-lg-4\">\n            <label class=\"required-label\">現在は学生ですか？<br>一般(社会人)ですか？</label>\n        </div>\n        <div class=\"col-lg-8\">\n            <label class=\"radio-inline\">\n                <input type=\"radio\" name=\"student_flg\" id=\"student\" value=\"1\" onchange=\"cmt.is_check_status_general_or_student(this.value)\">学生\n            </label>\n            <label class=\"radio-inline\">\n                <input type=\"radio\" name=\"student_flg\" id=\"general\" value=\"0\" onchange=\"cmt.is_check_status_general_or_student(this.value)\">一般(社会人)\n            </label>\n        </div>\n    </div>\n    <div class=\"clearfix\"></div>\n    <div id=\"live_field\">\n        <div class=\"col-lg-4\">\n            <label>お住まいはどこですか？</label>\n        </div>\n        <div id=\"ui_or_shimane\" class=\"col-lg-8\">\n            <label class=\"radio-inline\">\n                <input type=\"radio\" name=\"ui_want_flg\" id=\"ui\" value=\"1\" onchange=\"cmt.is_check_live_field(this.value)\">島根県外在住\n            </label>\n            <label class=\"radio-inline\">\n                <input type=\"radio\" name=\"ui_want_flg\" id=\"shimane\" value=\"0\" onchange=\"cmt.is_check_live_field(this.value)\">島根県内在住\n            </label>\n        </div>\n    </div>\n    <div class=\"clearfix\"></div>\n\n    <div id=\"already_finished_ui\">\n        <div class=\"col-lg-4\">\n            <label>島根県外から移住されて１年未満ですか？</label>\n        </div>\n        <div class=\"col-lg-8\">\n            <label class=\"radio-inline\">\n                <input type=\"radio\" name=\"ui_one_year_flg\" id=\"less_than_a_year\" value=\"1\" onchange=\"cmt.is_check_ui_history(this.value)\">はい\n            </label>\n            <label class=\"radio-inline\">\n                <input type=\"radio\" name=\"ui_one_year_flg\" id=\"more_than_a_year\" value=\"0\" onchange=\"cmt.is_check_ui_history(this.value)\">いいえ\n            </label>\n        </div>\n    </div>\n    <input type=\"hidden\" name=\"ui_done_flg\" id=\"ui_done_flg\">\n    <div class=\"clearfix\"></div>\n    <div id=\"hope_kurasimanet\" class=\"kurasimanet-register\">\n        <div class=\"col-lg-4\">\n            <label>くらしまねっとからの情報もご希望ですか？</label>\n        </div>\n        <div class=\"col-lg-8\">\n            <div class=\"checkbox\">\n                <label>\n                    <input type=\"hidden\" name=\"entry_kurashimanet\" value=\"0\">\n                    <input type=\"checkbox\" name=\"entry_kurashimanet\" id=\"hopeShareKurashimaCheckBox\" value=\"1\">希望する\n                </label>\n            </div>\n            <div> ※島根の仕事、暮らし、地域、人や移住関係イベント情報をLINE・メルマガ等でお届けします。</div>\n        </div>\n    </div>\n    <div class=\"col-lg-4\">\n    </div>\n    <div id=\"to_jobcafe_student\" class=\"col-lg-12 text-center\">\n        <p class=\"text-info\">\n            ・あなたの情報は、ジョブカフェしまね・しまね学生登録に登録されます。<br>\n            ・県内最大級の無料就活情報サイトであるジョブカフェしまねサイトの会員サービスがご利用いただけます。<br>\n            \n        </p>\n    </div>\n    <div id=\"to_jobcafe\" class=\"col-lg-12 text-center\">\n        <p class=\"text-info\">\n            ・あなたの情報は、ジョブカフェしまねに登録されます。<br>\n            ・県内最大級の無料就活情報サイトであるジョブカフェしまねサイトの会員サービスがご利用いただけます。<br>\n            \n        </p>\n    </div>\n    <div id=\"to_kurasimanet\" class=\"col-lg-12 text-center\">\n        <p class=\"text-info\">\n            ・UIターン希望者向けサービスがご利用いただけます。<br>\n            ・会員登録特典の片道交通費助成、引っ越し見積もり時割引サービス等がご利用いただけます。<br>\n            ・経験豊富なスタッフが無料職業紹介であなたの転職をサポートします。\n        </p>\n    </div>\n</div>\n                        <div id=\"next_btn_kurashimanet\"\n                            class=\"col-lg-12 centered next_btn\"\n                            style=\"display:none\">\n                            <button\n                                type=\"button\"\n                                class=\"btn btn-primary\"\n                                onclick=\"location.href='https://www.kurashimanet.jp/crm/member/register'\"><small>くらしまねっとへ</small></button>\n                            <p class=\"note\"><small>くらしまねっとのサイトへ移動してご登録ください</small></p>\n\n                        </div>\n\n                        <div id=\"next_btn_jobcafe\"\n                            class=\"col-lg-12 centered next_btn\"\n                            style=\"display: none;\">\n                            \n                            \n                            <button\n                                type=\"button\"\n                                class=\"btn btn-primary submit\"\n                                data-action=\"https://www.gogo-jobcafe-shimane.jp/crm/member/choose_auth_form\">次へ</button>\n\n                        </div>\n                    </div>\n                    <!-- //panel_body -->\n                </div>\n                <!-- //panel -->\n            </form>\n        </div>\n        <!-- //register_select_block -->\n\n        <!-- function_contents -->\n        <div id=\"function_contents\"  class=\"function_contents\">\n            <h2 class=\"heading\"><span>会員限定機能</span></h2>\n            <div class=\"function_block\">\n                <div class=\"function_box\">\n                    <p class=\"function_img\">\n                        <img src=\"https://www.gogo-jobcafe-shimane.jp/img/jobcafe/list_01.png\" alt=\"\">\n                    </p>\n                    <p class=\"function_txt\">しまねの就活に役立つ情報を<br>LINE・郵送・メール等でお届け</p>\n                </div>\n                <div class=\"function_box\">\n                    <p class=\"function_img\">\n                        <img src=\"https://www.gogo-jobcafe-shimane.jp/img/jobcafe/list_03.png\" alt=\"\">\n                    </p>\n                    <p class=\"function_txt\">合同企業説明会等の就活イベントや企業が個別で開催する会社説明会等にサイトから応募できる</p>\n                </div>\n                <div class=\"function_box\">\n                    <p class=\"function_img\">\n                        <img src=\"https://www.gogo-jobcafe-shimane.jp/img/jobcafe/list_06.png\" alt=\"\">\n                    </p>\n                    <p class=\"function_txt\">気になる求人を「お気に入りリスト(マイリスト)」に登録し、応募できる</p>\n                </div>\n                <div class=\"function_box\">\n                    <p class=\"function_img\">\n                        <img src=\"https://www.gogo-jobcafe-shimane.jp/img/jobcafe/list_05.png\" alt=\"\">\n                    </p>\n                    <p class=\"function_txt\">企業からスカウトメールが届く</p>\n                </div>\n            </div>\n        </div>\n        <!-- //function_contents -->\n\n        <!-- register_contents -->\n        <div class=\"register_contents\">\n            <div class=\"shimane_register\">\n\n                <div class=\"box2\">\n                    <h3 class=\"heading_sub\"><span>学生・若年者向け</span></h3>\n                    <div class=\"shimane_register_block\">\n                        <div class=\"site_block\">\n                            <p class=\"site_icon icon03\">\n                                <img src=\"https://www.gogo-jobcafe-shimane.jp/img/jobcafe/icon_03.png\" alt=\"ジョブカフェしまね\">\n                            </p>\n                            <p class=\"site_txt\">\n                                学生・若年者のための就活・インターンシップ情報サイト！\n                            </p>\n                        </div>\n                    </div>\n                </div>\n\n                <div class=\"box1\">\n                    <h3 class=\"heading_sub\"><span>UIターン希望者向け</span></h3>\n                    <div class=\"shimane_register_block\">\n                        <div class=\"site_block\">\n                            <p class=\"site_icon icon01\">\n                                <img src=\"https://www.gogo-jobcafe-shimane.jp/img/jobcafe/icon_01.png\" alt=\"くらしまねっと\">\n                            </p>\n                            <p class=\"site_txt\">\n                                しまねへのUターンIターンを支援！島根県最大級の求人サイト。\n                            </p>\n                        </div>\n                        <div class=\"site_block\">\n                            <p class=\"site_icon icon02\">\n                                <img src=\"https://www.gogo-jobcafe-shimane.jp/img/jobcafe/icon_02.png\" alt=\"UIターン無料職業紹介\">\n                            </p>\n                            <p class=\"site_txt\">\n                                経験豊かな職業紹介担当スタッフが、あなたの転職をサポート！\n                            </p>\n                        </div>\n                    </div>\n                </div>\n\n            </div>\n\n            <p class=\"explanation_txt\">\n                学生：しまね登録（ジョブカフェしまね/学生）会員<br>\n                UIターン希望者：しまね登録（くらしまねっと/UI）会員<br>\n                県内一般：しまね登録（ジョブカフェしまね/一般）会員\n            </p>\n\n            <p style=\"text-align: center;\"><a href=\"https://www.gogo-jobcafe-shimane.jp/line\"><img src=\"https://www.gogo-jobcafe-shimane.jp/img/jobcafe/shimane_line.png\" alt=\"しまね登録LINE連携について\"></a></p>\n\n        </div>\n        <!-- //register_contents -->\n\n    </div>\n    <!-- //contents_wrap -->\n</div>\n\n<link href=\"https://www.gogo-jobcafe-shimane.jp/css/CrmMemberRegister.css\" rel=\"stylesheet\">\n<script src=\"https://www.gogo-jobcafe-shimane.jp/js/CrmMemberRegister.js\"></script>\n","finalUrl":"https://www.gogo-jobcafe-shimane.jp/crm/member/register","rendered":false,"_cachedAt":"2026-06-23T16:08:43.879Z"}