{"url":"https://www.mic-west.co.jp/gsp/","html":"<!doctype html>\n<html class=\"no-js\" lang=\"ja\">\n<head>\n  <meta charset=\"utf-8\">\n  <title>株式会社GSP | MIC GROUP</title>\n  <meta name=\"description\" content=\"各種業務ソフトやWeb系、FA系のソフトウェアの受託開発を行う。\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n  <meta property=\"og:site_name\" content=\"MIC GROUP\">\n  <meta property=\"og:title\" content=\"MIC GROUP\">\n  <meta property=\"og:type\" content=\"website\">\n  <meta property=\"og:url\" content=\"https://www.mic-west.co.jp//\">\n  <meta property=\"og:description\" content=\"各種業務ソフトやWeb系、FA系のソフトウェアの受託開発を行う。\" />\n  <meta property=\"og:image\" content=\"../ogp.png\">\n  <link rel=\"icon\" href=\"../favicon.ico\">\n  <link rel=\"stylesheet\" href=\"../common/css/reset.css?ver51\">\n  <link rel=\"stylesheet\" href=\"../common/css/common.css?ver51\">\n  <link rel=\"stylesheet\" href=\"../common/css/corporate.css?ver51\">\n</head>\n<body>\n  <div class=\"shadow\"></div>\n  <header class=\"lower\">\n    <button id=\"spnav\" class=\"spnav\"><span class=\"spnav1\"></span><span class=\"spnav2\"></span><span class=\"spnav3\"></span></button>\n    <h2 class=\"logo\"><a href=\"../\"><img src=\"../common/img/logo.svg\" alt=\"MIC GROUP\"></a></h2>\n    <nav id=\"gnav\">\n      <ul class=\"lv_1\">\n        <li><a href=\"../\"><span class=\"ja\">トップページ</span><span class=\"en\">TOP</span></a></li>\n        <li><a href=\"../#message\"><span class=\"ja\">ごあいさつ</span><span class=\"en\">MESSAGE</span></a></li>\n        <li><a href=\"../#business\"><span class=\"ja\">事業内容</span><span class=\"en\">BUSINESS</span></a></li>\n        <li><a href=\"../#company\"><span class=\"ja\">グループ情報</span><span class=\"en\">GROUP</span></a>\n          <ul class=\"lv_2\">\n            <li><a href=\"../mic/\">株式会社経営情報センター</a></li>\n            <li><a href=\"../micc/\">株式会社エムアイシー・<br class=\"sp\">コンサルティング</a></li>\n            <li><a href=\"../gsp/\">株式会社GSP</a></li>\n            <li><a href=\"../gss/\">株式会社GSS</a></li>\n            <li><a href=\"../bi2/\">株式会社ビー・アイ・スクエア</a></li>\n          </ul>\n        </li>\n        <!-- <li><a href=\"../#contact\"><span class=\"ja\">お問い合わせ</span><span class=\"en\">CONTACT</span></a></li> -->\n        <li><a href=\"../recruit/\"><span class=\"ja\">採用情報</span><span class=\"en\">RECRUIT</span></a></li>\n      </ul>\n      <div class=\"white sp\">\n        <div class=\"left\">\n          <div class=\"instagram\"><a href=\"https://www.instagram.com/micgroup_since1979/\" target=\"_blank\"><img class=\"white\" src=\"../common/img/icon_instagram.svg\" alt=\"Instagram\"></a></div>\n          <ul>\n            <li><a href=\"../privacypolicy/\">プライバシーポリシー</a></li>\n            <li><a href=\"../sitepolicy/\">サイトポリシー</a></li>\n          </ul>\n        </div>\n        <div class=\"sdgs\"><img src=\"../common/img/sdg_h.svg\" alt=\"SUSTAINABLE DEVELOPMENT GOALS\"></div>\n      </div>\n      <div class=\"gray sp\">\n        <div class=\"inner\">\n          <small class=\"copyright\">© Management Information Center Co., Ltd. All Rights Reserved.</small>\n        </div>\n      </div>\n    </nav>\n  </header>\n  <main class=\"lower company\">\n    <nav class=\"page\">\n      <ul>\n        <li><a href=\"#business\">事業内容</a></li>\n        <li><a href=\"#profile\">会社概要</a></li>\n      </ul>\n    </nav>\n    <section id=\"title\">\n      <div class=\"inner\">\n        <div class=\"txt\">\n          <p class=\"group\">MIC Group</p>\n          <h1>株式会社GSP</h1>\n          <h2>会社情報</h2>\n          <p class=\"lead\">「情報交換・情報伝送・情報伝達をキーワードとして<br class=\"pc\">社会に貢献」することを事業方針に掲げ、<br class=\"pc\">複合的で高付加価値のトータルICTサービスを精力的に<br class=\"pc\">展開しております。</p>\n        </div>\n        <figure><img src=\"./img/logo.svg\" alt=\"\"></figure>\n      </div>\n    </section>\n    <section id=\"image\" class=\"gsp\">\n      <figure></figure>\n    </section>\n    <section id=\"business\">\n      <div class=\"inner\">\n        <h2 class=\"h_dot\">事業内容</h2>\n        <ul class=\"system\">\n          <li class=\"block\">\n            <h3>エンジニアリング事業</h3>\n            <ul>\n              <li class=\"unit\">\n                <h4>モバイルエンジニアリング</h4>\n                <ul class=\"regular\">\n                  <li>オープン基地局設計・構築</li>\n                  <li>屋内基地局設計・構築</li>\n                  <li>基地局伝送路設計・構築</li>\n                  <li>無線機調整試験</li>\n                  <li>ネットワークセンター内設備運用監視</li>\n                  <li>フィールド保守</li>\n                  <li>無線機登録点検</li>\n                </ul>\n              </li>\n              <li class=\"unit\">\n                <h4>ICTエンジニアリング</h4>\n                <ul class=\"regular\">\n                  <li>公衆無線LAN設計・構築</li>\n                  <li>データーセンター内設備設計・構築</li>\n                  <li>有線・無線LAN設計・構築</li>\n                  <li>電気設備構築</li>\n                  <li>光回線設計・保守</li>\n                </ul>\n              </li>\n            </ul>\n          </li>\n          <li class=\"block\">\n            <h3>システムインフラ事業</h3>\n            <ul>\n              <li class=\"unit\">\n                <h4>ネットワークインフラ構築</h4>\n                <ul class=\"regular\">\n                  <li>LAN・WAN環境の設計・構築・運用</li>\n                  <li>無線LAN環境の設計・構築・運用及び電波測定</li>\n                  <li>各種VPNの設計・構築・運用</li>\n                  <li>ファイアウォール・UTMの設計・構築・運用</li>\n                  <li>負荷分散装置の設計・構築・運用</li>\n                </ul>\n              </li>\n              <li class=\"unit\">\n                <h4>サーバインフラ構築</h4>\n                <ul class=\"regular\">\n                  <li>各種サーバインフラの設計・構築\n                  </li>\n                  <li>クラウド（IaaS）完了の設計・構築・運用</li>\n                  <li>ファイルサーバ、Webサーバ、Mailサーバ等の設計・構築・運用</li>\n                  <li>認証サーバ、ディレクトリサーバの設計・構築・運用</li>\n                  <li>監視システムの設計・構築・運用</li>\n                </ul>\n              </li>\n            </ul>\n          </li>\n        </ul>\n      </div>\n    </section>\n    <section id=\"profile\">\n      <div class=\"inner\">\n        <h2 class=\"h_dot\">会社概要</h2>\n        <dl>\n          <dt>名称</dt>\n          <dd>株式会社GSP<br>\n            Global Solution Power Co., Ltd.<br>\n            略称：GSP（Global Solution Power）</dd>\n          <dt>設立</dt>\n          <dd>2004年5月</dd>\n          <dt>資本金</dt>\n          <dd>グループ総資本金　1億円（GSP　2,000万円）</dd>\n          <dt>社員数</dt>\n          <dd>グループ総社員数　312名（GSP　56名）</dd>\n          <dt>売上高</dt>\n          <dd>グループ総売上高　44.7億円（GSP　6.39億円）</dd>\n          <dt>代表者</dt>\n          <dd>代表取締役会長　竹上　喜一郎</dd>\n          <dt>事業内容</dt>\n          <dd>■通信・ネットワーク関連事業<br>\n            通信インフラ事業<br>\n            ネットワークシステム事業<br>\n            通信サービス企画／開発事業<br>\n            各種データ整備／解析事業</dd>\n          <dt>取引先銀行</dt>\n          <dd>三菱UFJ銀行/三井住友銀行/みずほ銀行</dd>\n          <dt>認証・認可</dt>\n          <!--\n          <dd>電波法登録点検事業者<br>\n            建設業許可（電気通信工事業）<br>\n            ISO/IEC 27001:2013<br>\n            全省庁統一資格<br>\n            建設業許可（電気工事業）<br>\n            電気工事業者届出<br>\n            労働者派遣事業</dd>\n            -->\n            <dd>建設業許可<br>\n            （電気通信工事業/電気工事業/土木工事業/<br>\n            &ensp;\n            とび・土工工事業/鋼構造物工事業/塗装工事業）<br>\n            電波法登録点検事業者<br>\n            全省庁統一資格<br>\n            電気工事業者届出<br>\n            労働者派遣事業許可<br>\n            ISMS(ISO/IEC 27001)</dd>\n          <dt>所在地</dt>\n          <dd>■大阪本社<br>\n            〒550-0013 大阪市西区新町1-27-5 四ツ橋クリスタルビル4F（受付3F）<br>\n            TEL　06-6543-3300<br>\n            <br>\n            ■Namba EBISU ベース<br>\n            〒556-0004 大阪市浪速区日本橋西2-3-4<br>\n            TEL　06-6556-7227<br>\n            <br>\n            ■東京本社<br>\n            〒102-0074 東京都千代田区九段南1-6-5 九段会館テラス Classic Office 3F<br>\n            TEL　03-6272-4633<br>\n            <br>\n            ■Tokyo EAST ベース<br>\n            〒135-0007 東京都江東区新大橋1-8-11 大樹生命新大橋ビル\n          </dd>\n          <dt>各種窓口</dt>\n          <dd>\n            ■総合窓口<br>\n            <span class=\"email\"><img src=\"./img/email_1.svg\" alt=\"\"></span><br>\n            ■採用窓口<br>\n            <span class=\"email\"><img src=\"../common/img/email_3.svg\" alt=\"\"></span>\n          </dd>\n        </dl>\n      </div>\n    </section>\n    <nav class=\"local\">\n      <h2>MIC Group</h2>\n      <ul class=\"arrows\">\n        <li><a href=\"../mic/\">株式会社経営情報センター</a></li>\n        <li><a href=\"../micc/\">株式会社エムアイシー・コンサルティング</a></li>\n        <li class=\"current\"><a href=\"../gsp/\">株式会社GSP</a></li>\n        <li><a href=\"../gss/\">株式会社GSS</a></li>\n        <li><a href=\"../bi2/\">株式会社ビー・アイ・スクエア</a></li>\n      </ul>\n    </nav>\n  <section id=\"recruit\" class=\"switch section block6\">\n    <a href=\"../recruit/\">\n      <div class=\"inner\">\n        <div>採用サイトはこちら<span class=\"btn\"><i></i></span></div>\n      </div>\n    </a>\n  </section>\n  </main>\n  <footer id=\"footer\">\n    <div class=\"white\">\n      <div class=\"inner\">\n        <div class=\"upper\">\n          <h2 class=\"logo\"><img src=\"../common/img/logo.svg\" alt=\"\"></h2>\n          <nav class=\"sp\">\n            <ul class=\"arrows\">\n              <li class=\"ej\"><a href=\"../\"><span class=\"en\">Corporate site</span><span class=\"ja\">企業サイト</span></a></li>\n              <li class=\"ej\"><a href=\"../recruit/\"><span class=\"en\">Recruit site</span><span class=\"ja\">採用サイト</span></a></li>\n            </ul>\n          </nav>\n          <div class=\"sdgs\">\n            <h3><img src=\"../common/img/sdg_h.svg\" alt=\"SUSTAINABLE DEVELOPMENT GOALS\"></h3>\n            <ul>\n              <li><img src=\"../common/img/sdg_3.svg\" alt=\"3 すべての人に健康と福祉を\"></li>\n              <li><img src=\"../common/img/sdg_4.svg\" alt=\"4 質の高い教育をみんなに\"></li>\n              <li><img src=\"../common/img/sdg_7.svg\" alt=\"7 すべての人に健康と福祉を\"></li>\n              <li><img src=\"../common/img/sdg_8.svg\" alt=\"8 働きがいも経済成長も\"></li>\n              <li><img src=\"../common/img/sdg_9.svg\" alt=\"9 産業と技術革新の基盤を作ろう\"></li>\n              <li><img src=\"../common/img/sdg_11.svg\" alt=\"11 住み続けられるまちづくりを\"></li>\n              <li><img src=\"../common/img/sdg_16.svg\" alt=\"16 平和と公正をすべての人に\"></li>\n              <li><img src=\"../common/img/sdg_17.png\" alt=\"17 パートナーシップで目標を達成しよう\"></li>\n            </ul>\n          </div>\n        </div>\n        <nav class=\"pc\">\n          <div class=\"corporate main pc\">\n            <h3 class=\"ej\"><span class=\"en\">Corporate site</span><span class=\"ja\">企業サイト</span></h3>\n            <ul class=\"arrows\">\n              <li><a href=\"../\">TOP</a></li>\n              <li><a href=\"../mic/\">株式会社経営情報センター</a></li>\n              <li><a href=\"../micc/\">株式会社エムアイシー・コンサルティング</a></li>\n              <li><a href=\"../gsp/\">株式会社GSP</a></li>\n              <li><a href=\"../gss/\">株式会社GSS</a></li>\n              <li><a href=\"../bi2/\">株式会社ビー・アイ・スクエア</a></li>\n            </ul>\n          </div>\n          <div class=\"border bg pc\"></div>\n          <div class=\"recruit main pc\">\n            <h3 class=\"ej\"><span class=\"en\">Recruit site</span><span class=\"ja\">採用サイト</span></h3>\n            <ul class=\"arrows\">\n              <li><a href=\"../recruit/\">TOP</a></li>\n              <li><a href=\"../recruit/requirements/\">募集要項</a></li>\n              <li><a href=\"../recruit/entry/\">エントリーフォーム</a></li>\n            </ul>\n          </div>\n          <div class=\"border pc\"></div>\n          <div class=\"right\">\n            <div class=\"instagram\"><a href=\"https://www.instagram.com/micgroup_since1979/\" target=\"_blank\"><img class=\"white\" src=\"../common/img/icon_instagram.svg\" alt=\"Instagram\"><img class=\"blue\" src=\"../common/img/icon_instagram_blue.svg\" alt=\"Instagram\"></a></div>\n            <ul>\n              <li><a href=\"../privacypolicy/\">プライバシーポリシー</a></li>\n              <li><a href=\"../sitepolicy/\">サイトポリシー</a></li>\n            </ul>\n            <div class=\"pagetop sp\"><img src=\"../common/img/pagetop_gray.svg\" alt=\"PAGE TOP\"></div>\n          </div>\n        </nav>\n      </div>\n    </div>\n    <di