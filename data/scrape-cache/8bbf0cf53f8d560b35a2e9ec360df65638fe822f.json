{"url":"https://www.alco-ex.jp/contact_entry.html","html":"<!DOCTYPE html>\r\n<html dir=\"ltr\" lang=\"ja\">\r\n  <head>\r\n    <meta charset=\"UTF-8\">\r\n    <meta name=\"viewport\" content=\"width=device-width, user-scalable=yes, maximum-scale=1.0, minimum-scale=1.0\">    \r\n    <meta name=\"keywords\" content=\"介護見守りカメラ,介護施設来訪者受付システム,企業受付システム,ソフトウェア設計・開発,ＩＴソリューションの提供\">\r\n    \r\n    <title>株式会社　アルコ・イーエックス</title>\r\n\r\n    <link rel=\"stylesheet\" href=\"css/style.css\" type=\"text/css\" media=\"screen\">\r\n    <link rel=\"stylesheet\" href=\"css/style_plus.css\" type=\"text/css\" media=\"screen\">  \r\n    <link rel=\"stylesheet\" href=\"css/contact.css\" type=\"text/css\" media=\"screen\">  \r\n    <link href=\"https://fonts.googleapis.com/css?family=Noto+Sans+JP:100,300,400,500&amp;subset=japanese\" rel=\"stylesheet\">\r\n    <link href=\"../images/favicon.ico\" rel=\"Shortcut Icon\" type=\"../image/x-icon\">\r\n\r\n    <script src=\"js/html5.js\"></script>\r\n    <script src=\"js/css3-mediaqueries.js\"></script>\r\n    <script src=\"https://ajax.googleapis.com/ajax/libs/jquery/2.2.0/jquery.min.js\"></script>\r\n    <script src=\"js/script.js\"></script>  \r\n    <script type=\"text/javascript\" src=\"js/common.js\"></script>\r\n  </head>\r\n\r\n  <body>\r\n    <!-- ヘッダ -->\r\n    <header id=\"header\" role=\"banner\">\r\n      <script type=\"text/javascript\">header();</script>\r\n    </header>\r\n\r\n    <div id=\"main_content\">\r\n      <div class=\"container\">\r\n        <div style=\"text-align:center; padding-top:60px\">\r\n          <img src=\"images/ttl_contact.png\" alt=\"お問い合わせ\">\r\n        </div>\r\n\r\n        <div id=\"wrap\">\r\n          <div class=\"contents\">\r\n              <h3 style=\"color: darkcyan; font-weight: bold\">求人お問い合わせに関する個人情報の取り扱いについて</h3><br>\r\n              <p>入力前に、「個人情報保護に関して」をお読みいただき、記載されている内容に関して同意していただく必要があります。\r\n              <br> 同意していただけない場合には、当求人お問合せフォームへのリンクができません。\r\n              <br> 「個人情報保護に関して」をよくお読みいただき、同意していただける場合は下の[同意する]をチェックし[求人お問い合わせフォームへリンク]ボタンをクリックして下さい。\r\n              </p><br>\r\n              <a href=\"privacy.html\" target=\"_blank\">「個人情報保護に関して(新規ウインドウを表示)」</a>\r\n              <br><br>\r\n            </div>\r\n          </div>\r\n        </div>\r\n\r\n        <SCRIPT LANGUAGE=\"JavaScript\">\r\n          function check() {\r\n              var chk;\r\n              for (i = 0; i < formChecker.Checker.length; i++) {\r\n                  if (formChecker.Checker[i].checked) {\r\n                      // 押されている場合\r\n                      chk = formChecker.Checker[i].value;\r\n                      break;\r\n                  }\r\n              }\r\n              if (chk == \"YES\") {\r\n                  //YES\r\n                  location.href = \"https://alco-ex.jp/contact_entry.php\";\r\n              } else if (chk == \"NO\") {\r\n                  //NO\r\n              }\r\n          }\r\n        </SCRIPT><br>\r\n\r\n        <FORM NAME=\"formChecker\" style=\"text-align: center\">\r\n          <INPUT TYPE=\"radio\" NAME=\"Checker\" VALUE=\"YES\" id=\"Checker_yes\"> <label for=\"Checker_yes\">同意します</label>\r\n          <INPUT TYPE=\"radio\" NAME=\"Checker\" VALUE=\"NO\" id=\"Checker_no\" CHECKED> <label for=\"Checker_no\">同意しません</label><br><br>\r\n  \r\n          <div class=\"buttonArea\" onClick=\"check()\">\r\n            <a class=\"btn-animation-05\">\r\n              <span>求人エントリーフォームへ</span>\r\n            </a>\r\n          </div><br><br>\r\n        </FORM>\r\n      </div>\r\n    </div>\r\n    \r\n    <!-- フッタ -->\r\n    <script type=\"text/javascript\">footer();</script>\r\n    \r\n    <!-- ページの先頭へ戻るボタン -->\r\n    <p id=\"pageTop\"><a href=\"#\"><img src=\"images/page_top.png\"></a></p>\r\n    </div>\r\n  </body>\r\n</HTML>\r\n","finalUrl":"https://www.alco-ex.jp/contact_entry.html","rendered":false,"_cachedAt":"2026-06-23T20:37:44.106Z"}