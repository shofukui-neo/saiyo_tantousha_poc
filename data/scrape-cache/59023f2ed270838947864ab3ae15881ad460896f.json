c-m.co.jp/en/en-inquiry/\"><div class=\"nav_icon_box\"></div><span class=\"nav_link_span\">Contact</span></a></li>\n            <li class=\"nav_menu_list language\">\n              <ul id=\"language_switcher\"><li id=\"menu-item-131-ja\" class=\"lang-item lang-item-3 lang-item-ja lang-item-first menu-item menu-item-type-custom menu-item-object-custom menu-item-131-ja\"><a href=\"https://fc-m.co.jp/mid-career-recruit/\" lang=\"ja\" hreflang=\"ja\">日本語</a></li>\n</ul>            </li>\n            <li class=\"nav_menu_list search\">\n              <form class=\"search_box\" action=\"https://fc-m.co.jp/en/\">\n\t<button class=\"search_icon_box\" type=\"submit\"><i class=\"fas fa-search\"></i></button>\n\t<input class=\"search_text_box\" type=\"text\" placeholder=\"Search\" name=\"s\">\n</form>            </li>\n            <li class=\"nav_menu_list mobile_logo\" id=\"mobile_logo\">\n              <figure class=\"mobile_logo_figure\" id=\"mobile_logo_figure\">\n                <img class=\"mobile_logo_figure_img\" id=\"mobile_logo_figure_img\" src=\"https://fc-m.co.jp/wp-content/uploads/logo.jpg\" alt=\"FCM株式会社のロゴ\">\n              </figure>\n            </li>\n          </ul>\n        </nav>\n      </div>\n      <div id=\"nav_toggle\">\n        <span></span>\n        <span></span>\n        <span></span>\n      </div>\n    </div>\n  </header>\r\n\r\n    \r\n<div class=\"main_visual\">\r\n  <div class=\"main_visual_box\">\r\n    <figure class=\"main_visual_figure\">\r\n      <img decoding=\"async\" src=\"https://fc-m.co.jp/wp-content/uploads/mid-career-recruit01.jpg\" alt=\"\" class=\"main_visual_img\">\r\n    </figure>\r\n  </div>\r\n  <div class=\"main_visual_text\">\r\n    <h1>Mid-career<br>application guidelines</h1>\r\n  </div>\r\n</div>\r\n\r\n<article class=\"hg_main\">\r\n\r\n  <section class=\"twotone_table\" \"=\"\">\r\n      <h3 class=\" section_title\">\r\n    Admissions\r\n    </h3>\r\n    <dl class=\"twotone_table_wrapper\">\r\n      <div class=\"twotone_table_record\">\r\n        <dt class=\"twotone_table_cell title\">\r\n          Occupation\r\n        </dt>\r\n        <dd class=\"twotone_table_cell value\">\r\n          Full-time Staff\r\n        </dd>\r\n      </div>\r\n      <div class=\"twotone_table_record\">\r\n        <dt class=\"twotone_table_cell title\">\r\n          Qualifications\r\n        </dt>\r\n        <dd class=\"twotone_table_cell value\">\r\n          At least High School Graduate <br>\r\n        </dd>\r\n      </div>\r\n      <div class=\"twotone_table_record\">\r\n        <dt class=\"twotone_table_cell title\">\r\n          Work Location\r\n        </dt>\r\n        <dd class=\"twotone_table_cell value\">\r\n          Main Factory Osaka-shi Higashinari-ku Kamiji 3-8-36 <br>\r\n          Kyoto Factory Kyoto, Kamigyo-ku, Kamitoba 100 <br>\r\n          Toyama Factory Toyama-shi, Yatsuomachi Yasuuchi 2-3-6 <br>\r\n        </dd>\r\n      </div>\r\n      <div class=\"twotone_table_record\">\r\n        <dt class=\"twotone_table_cell title\">\r\n          Employment Status\r\n        </dt>\r\n        <dd class=\"twotone_table_cell value\">\r\n          Full-time employee\r\n        </dd>\r\n      </div>\r\n      <div class=\"twotone_table_record\">\r\n        <dt class=\"twotone_table_cell title\">\r\n          Salary\r\n        </dt>\r\n        <dd class=\"twotone_table_cell value\">\r\n          Averge Annual income 5,190,000 yen\r\n        </dd>\r\n      </div>\r\n      <div class=\"twotone_table_record\">\r\n        <dt class=\"twotone_table_cell title\">\r\n          Salary Bonus\r\n        </dt>\r\n        <dd class=\"twotone_table_cell value\">\r\n          Salary increase system (Annual salary increase system up to age 30) <br>\r\n          Depending on achievements, there are special bonuses <br>\r\n        </dd>\r\n      </div>\r\n      <div class=\"twotone_table_record\">\r\n        <dt class=\"twotone_table_cell title\">\r\n          Allowance\r\n        </dt>\r\n        <dd class=\"twotone_table_cell value\">\r\n          Overtime allowance, commuting allowance, various social insurance\r\n        </dd>\r\n      </div>\r\n      <div class=\"twotone_table_record\">\r\n        <dt class=\"twotone_table_cell title\">\r\n          Working Hours\r\n        </dt>\r\n        <dd class=\"twotone_table_cell value\">\r\n          8:00～17:00 <br>\r\n20:00～5:00(※2 shift system for manufacturing department)\r\n        </dd>\r\n      </div>\r\n      <div class=\"twotone_table_record\">\r\n        <dt class=\"twotone_table_cell title\">\r\n          Holiday/Vacation\r\n        </dt>\r\n        <dd class=\"twotone_table_cell value\">\r\n          【115 days a year】 <br>\r\n          Saturday, Sunday and public holidays (according to our calendar) <br>\r\n          Note: Saturday work is about once a month, and holidays that fall between weekdays are also required. <br>\r\n          【Paid vacation (up to 20 days)】 <br>\r\n          Granted immediately upon joining the company (number of days granted varies depending on when you joined the company) <br>\r\n          【Vacation system】 <br>\r\n          Golden Week Holidays, Summer Holidays, Year-end and New Year Holidays, Special Leave, Maternity Leave, Postpartum Paternity Leave, Childcare Leave, Nursing Care Leave, Happy Birthday Leave <br>\r\n        </dd>\r\n      </div>\r\n      <div class=\"twotone_table_record\">\r\n        <dt class=\"twotone_table_cell title\">\r\n          Welfare\r\n        </dt>\r\n        <dd class=\"twotone_table_cell value\">\r\n          Defined benefit pension, Defined contribution pension <br>\r\n          Employee deposit, Condolence regulations, Housing acquisition system, Retirement system <br>\r\n        </dd>\r\n      </div>\r\n      </div>\r\n      <div class=\"twotone_table_record\">\r\n        <dt class=\"twotone_table_cell title\">\r\n          Selection Method\r\n        </dt>\r\n        <dd class=\"twotone_table_cell value\">\r\n          Interview\r\n        </dd>\r\n      </div>\r\n      <div class=\"twotone_table_record\">\r\n        <dt class=\"twotone_table_cell title\">\r\n          Selection Place\r\n        </dt>\r\n        <dd class=\"twotone_table_cell value\">\r\n          Main Headquarters\r\n        </dd>\r\n      </div>\r\n    </dl>\r\n  </section>\r\n\r\n  <section class=\"recruit_flow\">\r\n    <a id=\"entry_link\"></a>\r\n    <h3 class=\"section_title\">\r\n      Recruitment flow\r\n    </h3>\r\n    <ul class=\"recruit_flow_list_wrapper numbering\">\r\n      <li class=\"recruit_flow_list numbering_list drop_shadow\">\r\n        Entry\r\n      </li>\r\n      <li class=\"recruit_flow_list numbering_list drop_shadow\">\r\n        Company Briefing\r\n      </li>\r\n      <li class=\"recruit_flow_list numbering_list drop_shadow\">\r\n        First selection\r\n      </li>\r\n      <li class=\"recruit_flow_list numbering_list drop_shadow\">\r\n        Final Selection\r\n      </li>\r\n      <li class=\"recruit_flow_list numbering_list drop_shadow\">\r\n        Informal offer\r\n      </li>\r\n    </ul>\r\n    <div class=\"enrty_link_wrapper\">\r\n      <a href=\"https://fc-m.co.jp/en/contact\" class=\"enrty_link\">They make an ENTRY</a>\r\n    </div>\r\n  </section>\r\n  <aside class=\"aside\">\r\n    <div class=\"aside_wrapper\">\r\n      <div class=\"aside_text_wrapper\">\r\n        <div class=\"aside_p_wrapper\">\r\n          <div class=\"aside_p_center\">\r\n            <p class=\"aside_title\">Careers information</p>\r\n          </div>\r\n        </div>\r\n        <figure class=\"aside_figure\"><img decoding=\"async\" src=\"https://fc-m.co.jp/wp-content/uploads/recruit01.jpg\" alt=\"\" class=\"aside_img\"></figure>\r\n        <p><a href=\"https://fc-m.co.jp/en/recruit/\" class=\"aside_content\"></a></p>\r\n      </div>\r\n      <div class=\"aside_text_wrapper\">\r\n        <div class=\"aside_p_wrapper\">\r\n          <div class=\"aside_p_center\">\r\n            <p class=\"aside_title\">Employee Interviews</p>\r\n      