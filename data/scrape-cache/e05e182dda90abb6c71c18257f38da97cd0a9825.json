c-moduleheader\"></div>\r\n<section class=\"moduleSkin moduleZero\">\r\n\t<div class=\"moduleButton\"></div>\r\n\t<div id=\"dnn_ctr821_ContentPane\"><!-- Start_Module_821 --><div id=\"dnn_ctr821_ModuleContent\">\r\n\t\r\n<header>\r\n<div class=\"corp-logo\"><a href=\"/\"><img src=\"/Portals/0/recruit2022/img/ruxy-logo.png\" alt=\"株式会社YKK APラクシー\" /></a></div>\r\n<nav class=\"gnavi pc-only\">\r\n<ul class=\"page-navi\">\r\n    <li class=\"navi-company\"><a href=\"/recruit2026/company.html\">ラクシーを知る</a></li>\r\n    <li class=\"navi-work\"><a href=\"/recruit2026/work.html\">仕事を知る</a></li>\r\n    <li class=\"navi-person\"><a href=\"/recruit2026/person.html\">働く人を知る</a></li>\r\n    <li class=\"navi-recruit\"><a href=\"/recruit2026/recruit.html\">採用情報</a></li>\r\n</ul>\r\n<ul class=\"goal-navi\">\r\n    <li><a href=\"/recruit2026/recruit.html#new_graduate\"><img alt=\"\" src=\"/Portals/0/recruit2022/img/gn_new-graduate.png?521\" /></a></li>\r\n    <li><a href=\"/recruit2026/recruit.html#career\"><img alt=\"\" src=\"/Portals/0/recruit2022/img/gn_career.png?541\" /></a></li>\r\n    <li><a href=\"https://www.ruxy.co.jp/inquiry/contact5.html\" target=\"_blank\"><img alt=\"\" src=\"/Portals/0/recruit2022/img/gn_inquiry.png?588\" /></a></li>\r\n</ul>\r\n</nav>\r\n<div class=\"humberger mobile-only\">\r\n<div>&nbsp;</div>\r\n<div>&nbsp;</div>\r\n<div>&nbsp;</div>\r\n</div>\r\n</header>\r\n<ul class=\"float-navi pc-only\">\r\n    <li><a href=\"/recruit2026/recruit.html#new_graduate\"><img alt=\"\" src=\"/Portals/0/recruit2022/img/float_new-graduate.png?1008\" /></a></li>\r\n    <li><a href=\"/recruit2026/recruit.html#career\"><img alt=\"\" src=\"/Portals/0/recruit2022/img/float_career.png?277\" /></a></li>\r\n    <li><a href=\"https://www.ruxy.co.jp/inquiry/contact5.html\" target=\"_blank\"><img alt=\"\" src=\"/Portals/0/recruit2022/img/float_inquiry.png?509\" /></a></li>\r\n</ul>\r\n<div id=\"drawer\">\r\n<ul>\r\n    <li><a href=\"/recruit2026/company.html\">ラクシーを知る</a></li>\r\n    <li><a href=\"/recruit2026/work.html\">仕事を知る</a></li>\r\n    <li><a href=\"/recruit2026/person.html\">働く人を知る</a></li>\r\n    <li><a href=\"/recruit2026/recruit.html\">採用情報</a></li>\r\n    <li><a href=\"/recruit2026/recruit.html#new_graduate\">新卒採用エントリー</a></li>\r\n    <li><a href=\"/recruit2026/recruit.html#career\">キャリア採用エントリー</a></li>\r\n    <li><a href=\"https://www.ruxy.co.jp/inquiry/contact5.html\" target=\"_blank\">お問い合わせ</a></li>\r\n</ul>\r\n</div>\r\n\r\n\r\n<!-- End_Module_821 -->\r\n</div></div>\r\n</section>\r\n\r\n\r\n<div class=\"ic-moduleheader\"></div>\r\n<section class=\"moduleSkin moduleZero\">\r\n\t<div class=\"moduleButton\"></div>\r\n\t<div id=\"dnn_ctr826_ContentPane\"><!-- Start_Module_826 --><div id=\"dnn_ctr826_ModuleContent\">\r\n\t\r\n<h1 class=\"main-visual\"><img src=\"/Portals/0/recruit2022/img/work/work-main.jpg\" alt=\"仕事を知る\" /></h1>\r\n<main class=\"page-work\">\r\n<ul class=\"page-hd-link\">\r\n    <li><a href=\"/recruit2026/work.html#our_advantage\"></a>\r\n    <div>\r\n    <p>YKK APラクシーの強み</p>\r\n    </div>\r\n    </li>\r\n    <li><a href=\"/recruit2026/work.html#our_business\"></a>\r\n    <div>\r\n    <p>事業紹介</p>\r\n    </div>\r\n    </li>\r\n</ul>\r\n<!-- #our_advantage -->\r\n<section class=\"contents-wrapper\" id=\"our_advantage\">\r\n<h2 class=\"hd ruxy-advantage\">YKK APラクシーの強み</h2>\r\n<section class=\"work-lead\">\r\n<p>「社会の大切な財産である建物を次の世代へ」<br class=\"mobile-only\" />\r\n「全てはお客様の笑顔と幸せな暮らしのために」<br />\r\nこの2つを旨ねに、「技術・実績」を積み上げ、<br class=\"pc-only\" />\r\n「安心・信頼」を一層高めるべく歩み続けます。</p>\r\n<div>\r\n<section>\r\n<h3>技術と実績</h3>\r\n<p>30年以上にわたり培ってきた独自のマンション大規模修繕工事ノウハウ</p>\r\n</section>\r\n<div>＋</div>\r\n<section>\r\n<h3>安心と信頼</h3>\r\n<p>世界的な建材大手メーカーであるYKKAPのグループ企業としての<br class=\"pc-only\" />\r\n資本力とブランド力</p>\r\n</section>\r\n</div>\r\n</section>\r\n<section class=\"our-pride\">\r\n<h3 class=\"hd-r\">私たちの誇り</h3>\r\n<h4 class=\"hd-mini\">重⼤事故30年以上0件</h4>\r\n<p>私たちの⼤規模修繕⼯事は、安全第⼀ではなく「安全別格」です。⼤規模修繕⼯事は居住者の⽅がお住まいになる中での「居ながら施⼯」。居住者の⽅や付近を通⾏する⽅、そして現場で作業をする施⼯業者の安全を最優先に考え、施⼯現場を管理しています。</p>\r\n<h4 class=\"hd-mini\">品質を厳しく確認する社内検査体制</h4>\r\n<p>⼤規模修繕⼯事期間中に、安全技術統括部や⼯事本部・役員など、さまざまな⽴場の者が豊富な経験と知識で検査や確認を⾏っています。よりよい品質と万全の安全を追求しています。</p>\r\n<h4 class=\"hd-mini\">確かな開発⼒と品質</h4>\r\n<p>「こんなのがあったら・・・」。施⼯時の安全、⾼品質な施⼯、居住者の満⾜度（CS）向上のために、独創的なアイデアとこだわりで⼤規模修繕⼯事の技術開発を⾏っています。</p>\r\n<div class=\"tech-develop\">\r\n<figure>\r\n<img src=\"/Portals/0/recruit2022/img/work/curing-sheet.jpg\" alt=\"ファスナー付養⽣シート\" />\r\n<figcaption>台⾵・強⾵時もスピーディに開閉<br />\r\nYKK製「ファスナー付養⽣シート」</figcaption>\r\n</figure>\r\n<figure>\r\n<img src=\"/Portals/0/recruit2022/img/work/raku-repo.jpg\" alt=\"ラクレポ\" />\r\n<figcaption>スマホで⼯事情報をチェック<br />\r\n「ラクレポ(ラクシーレポート)」</figcaption>\r\n</figure>\r\n<figure>\r\n<img src=\"/Portals/0/recruit2022/img/work/tablet-system.jpg\" alt=\"タブレット調査システム\" />\r\n<figcaption>現場調査と積算⼯程の<br class=\"pc-only\" />\r\nシステム化で⽣産性向上<br />\r\n「タブレット調査システム」</figcaption>\r\n</figure>\r\n<figure>\r\n<img src=\"/Portals/0/recruit2022/img/work/diagnosis-system.jpg\" alt=\"外壁タイル診断システム\" />\r\n<figcaption>外壁タイルの不良部割合を算出<br />\r\n「外壁タイル診断システム」</figcaption>\r\n</figure>\r\n</div>\r\n<div class=\"environ-measures\">\r\n<section>\r\n<h4 class=\"hd-mini\">環境対策</h4>\r\n<p>ISO14001（環境マネジメント）認証を取得し、法令順守と相違⼯夫で環境への影響を最⼩限にとどめ環境保護への取り組みを⾏っています。</p>\r\n</section>\r\n<div><img src=\"/Portals/0/recruit2022/img/work/asr-anab.png\" alt=\"ISO9001 ISO14001\" /></div>\r\n</div>\r\n</section>\r\n</section><!-- /#our_advantage -->\r\n<!-- #our_business -->\r\n<section class=\"contents-wrapper\" id=\"our_business\">\r\n<h2 class=\"hd\">事業紹介</h2>\r\n<section class=\"mansion-repair\">\r\n<h3 class=\"hd-line\">⼤規模修繕⼯事事業 (マンション)</h3>\r\n<p>マンションの外装リニューアル⼯事を担う当社の主⼒事業『⼤規模修繕⼯事』。<br />\r\n主に以下2つの⼯事を⾏います（新築⼯事ではありません）。</p>\r\n<div class=\"mansion-repair-container\">\r\n<h4>① 修繕⼯事：建物の劣化を直す (一例)</h4>\r\n<p>建物の劣化を放置すると表面だけでなく内部まで劣化が進行してしまいます。そうなる前に修繕工事で建物の寿命を延ばします。</p>\r\n<div class=\"before-after\">\r\n<dl>\r\n    <dt>外壁補修工事</dt>\r\n    <dd><img src=\"/Portals/0/recruit2022/img/work/wall-before.jpg\" alt=\"外壁補修工事前\" /><img src=\"/Portals/0/recruit2022/img/work/block-arrow.png\" alt=\"→\" /><img src=\"/Portals/0/recruit2022/img/work/wall-after.jpg\" alt=\"外壁補修工事後\" /></dd>\r\n</dl>\r\n<dl>\r\n    <dt>バルコニー防水工事</dt>\r\n    <dd><img src=\"/Portals/0/recruit2022/img/work/balcony-before.jpg\" alt=\"バルコニー防水工事前\" /><img src=\"/Portals/0/recruit2022/img/work/block-arrow.png\" alt=\"→\" /><img src=\"/Portals/0/recruit2022/img/work/balcony-after.jpg\" alt=\"バルコニー防水工事後\" /></dd>\r\n</dl>\r\n<dl>\r\n    <dt>屋上防水工事</dt>\r\n    <dd><img src=\"/Portals/0/recruit2022/img/work/rooftop-before.jpg\" alt=\"屋上防水工事前\" /><img src=\"/Portals/0/recruit2022/img/work/block-arrow.png\" alt=\"→\" /><img src=\"/Portals/0/recruit2022/img/work/rooftop-after.jpg\" alt=\"屋上防水工事後\" /></dd>\r\n</dl>\r\n</div>\r\n<h4>② 改良⼯事︓機能をグレードアップする</h4>\r\n<p>段差の解消や手すりの取り付け、玄関ドアの取り替え、滑りにくい床材への交換など、居住者様の生活に合わせた提案を行います。</p>\r\n<div class=\"gradeup-img\">\r\n<dl>\r\n    <dt>バリアフリー工事</dt>\r\n    <dd>\r\n    <div><img src=\"/Portals/0/recruit2022/img/work/barrier-free.jpg\" alt=\"バリアフリー工事\" /></div>\r\n    </dd>\r\n</dl>\r\n<dl>\r\n    <dt>玄関ドアの交換工事</dt>\r\n    <dd>\r\n    <div><img src=\"/Portals/0/recruit2022/img/work/door-before.jpg\" alt=\"玄関ドア交換工事前\" /></div>\r\n    <div><img src=\"/Portals/0/recruit2022/img/work/block-arrow.png\" alt=\"→\" /></div>\r\n    <div><img src=\"/Portals/0/recruit2022/img/work/door-after.jpg\" alt=\"玄関ドア交換工事後\" /></div>\r\n    </dd>\r\n</dl>\r\n</div>\r\n</div>\r\n</section>\r\n<section class=\"renovation\">\r\n<h3 class=\"hd-line\">リノベーション事業 (マンション)</h3>\r\n<p>YKK APラクシーでは⼤規模修繕⼯事の時にお住まいのお客様に対し、リノベーション⼯事も請け負っています。古くなった浴室・キッチン・トイレ等や、家族構成の変化に伴い間取り変更したいなど、お客様のご要望に応じたリノベーション提案をしています。</p>\r\n<figure>\r\n<figcaption>リノベーション案件ご提案書例</figcaption>\r\n<img src=\"/Portals/0/recruit2022/img/work/renovation-proposal.png\" alt=\"リノベーション案件ご提案書例\" />\r\n</figure>\r\n<section class=\"renovation-case\">\r\n<h4>リノベーション事例 (Before・After)</h4>\r\n<div class=\"before-after\">\r\n<dl>\r\n    <dt>＜エントランス＞</dt>\r\n    <dd><img alt=\"\" src=\"/Portals/0/recruit2022/img/work/entrance-before.jpg\" /><img src=\"/Portals/0/recruit2022/img/work/block-arrow.png\" alt=\"→\" /><img alt=\"\" src=\"/Portals/0/recruit2022/img/work/entrance-after.jpg\" /></dd>\r\n</dl>\r\n<dl>\r\n    <dt>＜リビング＞</dt>\r\n    <dd><img alt=\"\" src=\"/Portals/0/recruit2022/img/work/living-before.jpg\" /><img src=\"/Portals/0/recruit2022/img/work/block-arrow.png\" alt=\"→\" /><img alt=\"\" src=\"/Portals/0/recruit2022/img/work/living-after.jpg\" /></dd>\r\n</dl>\r\n<dl>\r\n    <dt>＜キッチン＞</dt>\r\n    <dd><img alt=\"\" src=\"/Portals/0/recruit2022/img/work/kitchen-before.jpg\" /><img src=\"/Portals/0/recruit2022/img/work/block-arrow.png\" alt=\"→\" /><img alt=\"\" src=\"/Portals/0/recruit2022/img/work/kitchen-after.jpg\" /></dd>\r\n</dl>\r\n</div>\r\n</section>\r\n</section>\r\n<section class=\"renewal\">\r\n<h3 class=\"hd-line\">⼤規模改修⼯事事業 (オフィスビル・商業施設)</h3>\r\n<p>マンション⼤規模修繕⼯事で培ってきた技術とノウハウを活かして、オフィスビル・倉庫・商業施設・公共施設などの⼤規模改修⼯事や耐震⼯事、内装リニューアルなどを⾏っています。</p>\r\n<div>\r\n<figure>\r\n<img src=\"/Portals/0/recruit2022/img/work/office-bldg1.jpg\" alt=\"オフィスビル\" />\r\n<figcaption>オフィスビル</figcaption>\r\n</figure>\r\n<figure>\r\n<img src=\"/Portals/0/recruit2022/img/work/office-bldg2.jpg\" alt=\"オフィスビル\" />\r\n<figcaption>オフィスビル</figcaption>\r\n</figure>\r\n<figure>\r\n<img src=\"/Portals/0/recruit2022/img/work/commercial-facility.jpg\" alt=\"商業施設\" />\r\n<figcaption>商業施設</figcaption>\r\n</figure>\r\n<figure>\r\n<img src=\"/Portals/0/recruit2022/img/work/construction.jpg\" alt=\"施工中の様子\" />\r\n<figcaption>施工中の様子</figcaption>\r\n</figure>\r\n</div>\r\n</section>\r\n</section><!-- /#our_business -->\r\n<div class=\"next-btn\"><a href=\"/recruit2026/person.html\">Next&rarr;</a></div>\r\n</main>\r\n\r\n\r\n<!-- End_Module_826 -->\r\n</div></div>\r\n</section>\r\n\r\n\r\n<div class=\"ic-moduleheader\"></div>\r\n<section class=\"moduleSkin moduleZero\">\r\n\t<div class=\"moduleButton\"></div>\r\n\t<div id=\"dnn_ctr824_ContentPane\"><!-- Start_Module_824 --><div id=\"dnn_ctr824_ModuleContent\">\r\n\t\r\n<footer>\r\n<ul class=\"footer-navi\">\r\n    <li><a href=\"/recruit2026/company.html\">ラクシーを知る</a></li>\r\n    <li><a href=\"/recruit2026/work.html\">仕事を知る</a></li>\r\n    <li><a href=\"/recruit2026/person.html\">働く人を知る</a></li>\r\n    <li><a href=\"/recruit2026/recruit.html\">採用情報</a></li>\r\n    <li><a href=\"https://www.ruxy.co.jp/inquiry/contact5.html\" target=\"_blank\">お問い合わせ</a></li>\r\n</ul>\r\n<p class=\"copyright\">Copyright &copy; YKK AP RUXY Co.,Ltd,.All Rights Reserved.</p>\r\n</footer>\r\n<script src=\"https://cdnjs.cloudflare.com/ajax/libs/image-map-resizer/1.0.10/js/imageMapResizer.min.js\"></script>\r\n<script>\r\n  imageMapResize();\r\n</script>\r\n\r\n\r\n<!-- End_Module_824 -->\r\n</div></div>\r\n</section>\r\n\r\n</div>\r\n</div>\r\n\r\n\r\n        <input name=\"ScrollTop\" type=\"hidden\" id=\"ScrollTop\" />\r\n        <input name=\"__dnnVariable\" type=\"hidden\" id=\"__dnnVariable\" />\r\n    \r\n<div class=\"aspNetHidden\">\r\n\r\n\t<input type=\"hidden\" name=\"__VIEWSTATEGENERATOR\" id=\"__VIEWSTATEGENERATOR\" value=\"CA0B0334\" />\r\n</div></form>\r\n<!-- 345646102B6E121D6EA7DB5DFE92AF20D69A0EBD9AC49BE4AF273AC623D53C89 -->\r\n</body>\r\n</html>\r\n","finalUrl":"https://www.ruxy.co.jp/recruit2026/work.html","rendered":false,"_cachedAt":"2026-06-22T19:34:20.722Z"}