https://www.k-yamasan.co.jp/recruit/info/faq/\">\n  <meta name=\"twitter:image\" content=\"https://www.k-yamasan.co.jp/recruit/inc/image/common/img_ogp.jpg\">\n  <link href=\"https://fonts.googleapis.com/css?family=Noto+Sans+JP:400,500,700&display=swap&subset=japanese\" rel=\"stylesheet\">\n  <link rel=\"stylesheet\" type=\"text/css\" href=\"/recruit/inc/css/style.css\">\n  <link rel=\"stylesheet\" type=\"text/css\" href=\"/recruit/inc/css/project/others.css\">\n</head>\n\n<body id=\"faq\">\n  <!-- Google Tag Manager (noscript) -->\n  <noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-PJDQ96SJ\" height=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n  <!-- End Google Tag Manager (noscript) -->\n  <div id=\"container\">\n    <header class=\"l-header\">\n      <div class=\"l-header__inner\">\n        <div class=\"l-header__modules\">\n          <a href=\"/recruit\" class=\"logo\">\n            <span class=\"logo-main\"><img src=\"/recruit/inc/image/common/img_logo.svg\" alt=\"株式会社山産 採用サイト\"></span>\n            <span class=\"logo-sub\"><img src=\"/recruit/inc/image/common/img_headerLogocaption.svg\" alt=\"RECRUIT SITE\"></span>\n          </a>\n        </div>\n        <nav class=\"l-header__btnArea\">\n          <button class=\"l-header__btn js-naviBtn\" data-cat=\"gnavi\">\n            <span class=\"c-toggleBtn\" id=\"toggle\">\n              <span></span>\n              <span></span>\n              <span></span>\n            </span>\n          </button>\n        </nav>\n      </div>\n      <!-- グローバルナビゲーション -->\n      <div class=\"l-navigation__wrapper\" id=\"gnavi\">\n        <nav class=\"l-navigation\">\n          <!-- 1列目 -->\n          <ul class=\"l-navigation__list\">\n            <!-- トップ -->\n            <li class=\"l-navigation__item\">\n              <a class=\"current\" href=\"/recruit\">トップ</a>\n            </li>\n            <!-- トップ -->\n            <!-- 山産を知る -->\n            <li class=\"l-navigation__item\">\n              <button class=\"js-hasDropdown l-navigation__item\">山産を知る</button>\n              <ul class=\"l-navigation__list-sub\">\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/about/message/\">採用メッセージ</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/about/business/\">山産の事業について</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/about/data/\">数字で見る山産</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/about/case/\">こんなところに山産</a></li>\n              </ul>\n            </li>\n            <!-- 山産を知る -->\n          </ul>\n          <!-- 1列目 -->\n          <!-- 2列目 -->\n          <ul class=\"l-navigation__list\">\n            <!-- 仕事を知る -->\n            <li class=\"l-navigation__item\">\n              <a href=\"/recruit/about/work/\">仕事を知る</a>\n            </li>\n            <!-- 仕事を知る -->\n            <!-- 山産の人 -->\n            <li class=\"l-navigation__item\">\n              <button class=\"js-hasDropdown l-navigation__item\">人を知る</button>\n              <ul class=\"l-navigation__list-sub\">\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/member/\" class=\"js-naviAnchor\">人を知るTOP</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/member/interview01/\" class=\"js-naviAnchor\">環境事業グループ D.F.</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/member/interview06/\" class=\"js-naviAnchor\">環境事業グループ Y.O.</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/member/interview07/\" class=\"js-naviAnchor\">産機事業グループ S.K.</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/member/interview02/\" class=\"js-naviAnchor\">産機事業グループ Y.T.</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/member/interview03/\" class=\"js-naviAnchor\">総務部 K.I.</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/member/interview04/\" class=\"js-naviAnchor\">産機事業グループ S.I.</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/member/interview05/\" class=\"js-naviAnchor\">環境事業グループ H.M.</a></li>\n              </ul>\n            </li>\n            <!-- 山産の人 -->\n          </ul>\n          <!-- 2列目 -->\n          <!-- 3列目 -->\n          <ul class=\"l-navigation__list\">\n            <!-- 環境・制度を知る -->\n            <li class=\"l-navigation__item\">\n              <button class=\"js-hasDropdown l-navigation__item\">環境・制度を知る</button>\n              <ul class=\"l-navigation__list-sub\">\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/info/culture/\">文化・社風</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/info/benefits/\">福利厚生</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/info/training/\">教育制度・キャリアステップ</a></li>\n              </ul>\n            </li>\n            <!-- 働く人を知る -->\n          </ul>\n          <!-- 3列目 -->\n          <!-- 4列目 -->\n          <ul class=\"l-navigation__list\">\n            <!-- 採用情報 -->\n            <li class=\"l-navigation__item\">\n              <button class=\"js-hasDropdown l-navigation__item\">採用情報</button>\n              <ul class=\"l-navigation__list-sub\">\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/info/guideline/\">募集要項・選考の流れ</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/info/faq/\">よくあるご質問</a></li>\n              </ul>\n            </li>\n            <!-- 採用情報 -->\n            <!-- エントリー -->\n            <li class=\"l-navigation__item\">\n              <button class=\"js-hasDropdown l-navigation__item\">エントリー</button>\n              <ul class=\"l-navigation__list-sub\">\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/new-graduate-entry/\">新卒採用エントリー</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/entry/\">経験者採用エントリー</a></li>\n              </ul>\n            </li>\n            <!-- エントリー -->\n          </ul>\n          <!-- 4列目 -->\n        </nav>\n      </div>\n      <!-- グローバルナビゲーション -->\n    </header>\n    <!-- /header -->\n    <main id=\"main\">\n      <div class=\"l-lowerCaption\">\n        <div class=\"l-lowerCaption__inner\">\n          <h1 class=\"l-lowerCaption__title\">よくあるご質問</h1>\n          <ol class=\"c-topicspath\">\n            <li><a href=\"/recruit\">ホーム</a></li>\n            <li>採用情報</li>\n            <li>よくあるご質問</li>\n          </ol>\n        </div>\n      </div>\n      <div class=\"l-lowerCaption__bottom\">\n        <img src=\"/recruit/inc/image/common/lower/img_lowerCaption-bottom.svg\" alt=\"\">\n      </div>\n      <div id=\"contents\" class=\"l-lower\">\n        <div class=\"l-section\">\n          <div class=\"l-section__inner\">\n            <ol class=\"grid\">\n              <li class=\"col-4_md-6_xs-12 p-faqButton\">\n                <a href=\"#jobDescription\" class=\"c-anchorButton\">仕事内容について</a>\n              </li>\n              <li class=\"col-4_md-6_xs-12 p-faqButton\">\n                <a href=\"#workingEnvironment\" class=\"c-anchorButton\">働く環境について</a>\n              </li>\n              <li class=\"col-4_md-6_xs-12 p-faqButton\">\n                <a href=\"#selection\" class=\"c-anchorButton\">選考について</a>\n              </li>\n            </ol>\n          </div>\n        </div>\n        <section class=\"l-section l-section--pbLarge u-border-bottom\">\n          <!-- 仕事内容について -->\n          <div id=\"jobDescription\" class=\"l-section__inner\">\n            <div class=\"l-mw l-mw--contentWidth\">\n              <h2 class=\"c-ttl-main c-ttl--center c-ttl--keycolor c-ttl--oblique\"> 仕事内容について </h2>\n              <dl class=\"c-accordion c-accordion--faq\" data-js=\"accordion\">\n                <div class=\"c-accordion__item\">\n                  <dt class=\"c-accordion__title\">勤務地や勤務場所はどこになりますか？</dt>\n                  <dd class=\"c-accordion__body\">面接時に希望部署と希望勤務地をお伺いいたします。あくまでも希望となります、最終的な配属についてはご本人の適性を見ながら決定致します。</dd>\n                </div>\n                <div class=\"c-accordion__item\">\n                  <dt class=\"c-accordion__title\">文系・理系で違いなどはありますか？</dt>\n                  <dd class=\"c-accordion__body\">みなさん入社後は、1からのスタートとなります。ただし、資格取得にあたっては電気・機械等特定の学科の方は必要な実務経験年数が短いという利点があります。</dd>\n                </div>\n                <div class=\"c-accordion__item\">\n                  <dt class=\"c-accordion__title\">短期出張をすることがありますか？</dt>\n                  <dd class=\"c-accordion__body\">部署にもよりますが数日～1週間程度出張をすることもあります。<br>また稀ですが海外に出張することもあります。</dd>\n                </div>\n                <div class=\"c-accordion__item\">\n                  <dt class=\"c-accordion__title\">転勤はありますか？</dt>\n                  <dd class=\"c-accordion__body\">状況にもよりますが、基本的にはあります。定期的な転勤ではなく、また転勤のスパンも平均で10~15年と長い方です。<br>転勤しながらスキルアップしていただき、成長していただきます。</dd>\n                </div>\n                <div class=\"c-accordion__item\">\n                  <dt class=\"c-accordion__title\">ノルマは有りますか？</dt>\n                  <dd class=\"c-accordion__body\">個人ノルマはありませんが、毎年全社で目標とする数値を達成する為、それぞれの部署でその役割を受け持ちます。</dd>\n                </div>\n              </dl>\n            </div>\n          </div>\n          <!-- 仕事内容について -->\n          <!-- 働く環境について -->\n          <div id=\"workingEnvironment\" class=\"l-section__inner\">\n            <div class=\"l-mw l-mw--contentWidth\">\n              <h2 class=\"c-ttl-main c-ttl--center c-ttl--keycolor c-ttl--oblique\"> 働く環境について </h2>\n              <dl class=\"c-accordion c-accordion--faq\" data-js=\"accordion\">\n                <div class=\"c-accordion__item\">\n                  <dt class=\"c-accordion__title\">休日出勤はありますか？</dt>\n                  <dd class=\"c-accordion__body\">業務の繁忙期や状況によっては休日出勤することも有ります。<br>その場合は、振替休日、または代休を取得していただきます。</dd>\n                </div>\n                <div class=\"c-accordion__item\">\n                  <dt class=\"c-accordion__title\">残業はありますか？</dt>\n                  <dd class=\"c-accordion__body\">あります。繁忙期にもよりますが、月の残業平均時間は20時間程度です。</dd>\n                </div>\n                <div class=\"c-accordion__item\">\n                  <dt class=\"c-accordion__title\">会社の雰囲気を教えてください。</dt>\n                  <dd class=\"c-accordion__body\">若手・中堅・ベテランのバランスが良く真面目で風通しが良い雰囲気です。<br><a href=\"/recruit/info/culture/\">詳しくはこちら</a></dd>\n                </div>\n                <div class=\"c-accordion__item\">\n                  <dt class=\"c-accordion__title\">福利厚生について教えてください</dt>\n                  <dd class=\"c-accordion__body\">社員1人1人が働きやすい環境を整えています。<br><a href=\"/recruit/info/benefits/\">詳しくはこちら</a></dd>\n                </div>\n                <div class=\"c-accordion__item\">\n                  <dt class=\"c-accordion__title\">どのような教育やフォロー体制がありますか？</dt>\n                  <dd class=\"c-accordion__body\">各自が成長できるような制度、ステップを整えています。<br><a href=\"/recruit/info/training/\">詳しくはこちら</a></dd>\n                </div>\n              </dl>\n            </div>\n          </div>\n          <!-- 働く環境について -->\n          <!-- 選考について -->\n          <div id=\"selection\" class=\"l-section__inner\">\n            <div class=\"l-mw l-mw--contentWidth\">\n              <h2 class=\"c-ttl-main c-ttl--center c-ttl--keycolor c-ttl--oblique\"> 選考について </h2>\n              <dl class=\"c-accordion c-accordion--faq\" data-js=\"accordion\">\n                <div class=\"c-accordion__item\">\n                  <dt class=\"c-accordion__title\">選考に際して、どのようなことを重視していますか？</dt>\n                  <dd class=\"c-accordion__body\">当社の選考は面接・人柄重視で行います。個人面接で1時間程度じっくり時間をかけミスマッチがないようにしています。</dd>\n                </div>\n                <div class=\"c-accordion__item\">\n                  <dt class=\"c-accordion__title\">選考から内定までに要する期間はどのくらいですか？</dt>\n                  <dd class=\"c-accordion__body\">選考開始から内定までおおよそ1か月程度です。</dd>\n                </div>\n                <div class=\"c-accordion__item\">\n                  <dt class=\"c-accordion__title\">WEBでの説明会は開催していますか？</dt>\n                  <dd class=\"c-accordion__body\">開催しております。ご希望の日時よりご参加ください。</dd>\n                </div>\n                <div class=\"c-accordion__item\">\n                  <dt class=\"c-accordion__title\">入社するまでに勉強しておいた方がいいことはありますか？</dt>\n                  <dd class=\"c-accordion__body\">特にありません。「入社したらできなくなること」をドンドン経験しておくことを推奨しています。</dd>\n                </div>\n              </dl>\n            </div>\n          </div>\n          <!-- 選考について -->\n        </section>\n        <section class=\"c-relatedContents\">\n          <div class=\"c-relatedContents__wrapper\">\n            <h2 class=\"c-ttl-main\"> 関連<span class=\"u-not-under-sm u-not-under-sm--inline\">する</span>コンテンツ </h2>\n            <ul class=\"c-cardWrapper c-cardWrapper--info\">\n              <li class=\"c-contentsCard c-contentsCard--info\">\n                <a href=\"/recruit/info/guideline/\">\n                  <div class=\"c-contentsCard__textArea\">\n                    <span class=\"c-contentsCard__text c-contentsCard__text--info\">募集要項・選考の流れ</span><span class=\"c-contentsCard__arrow\"></span>\n                  </div>\n                </a>\n              </li>\n            </ul>\n          </div>\n        </section>\n      </div>\n    </main>\n    <!-- end of #main -->\n    <div class=\"c-cvArea\">\n      <div class=\"c-cvArea__inner \">\n        <div class=\"c-cvArea__inner__textArea\">\n          <h2 class=\"c-cvArea__title\"><span>グレートを創り出す山産に</span>エントリーする</h2>\n          <p class=\"c-cvArea__text u-taC\">「グレートを創り出す」ために、<br class=\"u-only-xs\">山産で一緒に働いてみませんか？</p>\n          <div class=\"c-cvArea__buttonArea\">\n            <ul class=\"c-cvArea__buttonList\">\n              <li class=\"c-cvArea__buttonItem\">\n                <a href=\"/recruit/new-graduate-entry/\" class=\"c-cvArea__button c-cvArea__button--white\">\n                  <span class=\"c-cvArea__buttonText\">新卒採用エントリー</span>\n                </a>\n              </li>\n         