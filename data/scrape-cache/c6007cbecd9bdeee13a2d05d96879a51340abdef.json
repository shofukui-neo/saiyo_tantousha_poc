 middle\"></div>\n<div class=\"bar bottom\"></div>\n</div>\n<!-- /toggle -->\n<nav class=\"menu_sp\">\n<ul>\n<li><a href=\"../about/index.html\">NECOについて</a></li>\n<li><a href=\"../works/index.html\">私たちの仕事</a></li>\n<li><a href=\"../people/index.html\">NECOの仲間</a></li>\n<li><a href=\"../career_formation/index.html\">キャリア形成</a></li>\n<li><a href=\"../benefit/index.html\">環境と制度</a></li>\n<li><a href=\"../recruit/index.html\">採用情報</a></li>\n<li class=\"contact\"><a href=\"../contact/index.html\">お問い合わせ</a></li>\n</ul>\n</nav>\n</div>\n<!-- /menu -->\n</div>\n<!-- /global_nav_sp -->\n</header>\n\n\n<div class=\"mainvisual\">\n<div class=\"inner\">\n<ul>\n    <li>\n        <picture>\n        <img src=\"../images/entry_title/bg_title_people.jpg\" alt=\"\" width=\"1680\" height=\"750\">\n        </picture>\n    </li>\n</ul>\n</div>\n<!-- /inner -->\n<div class=\"wrap\">\n    <h1><a href=\"../about/index.html\"><span>NECOの仲間</span>PEOPLE</a></h1>\n    <img src=\"../images/entry_title/deco/people.png\" alt=\"\" width=\"361\" height=\"195\">\n</div>\n<nav class=\"bread clearfix\">\n<ol>\n    <li><a href=\"../index.html\">HOME</a></li>\n    <li>NECOの仲間</li>\n</ol>\n</nav>\n<!-- /bread -->\n</div>\n<!-- /mainvisual -->\n\n\n<main>\n<h1><span>等身大の声から見えてくる<br>私たちの仕事とこれから</span></h1>\n\n<section class=\"intro_box\">\n<div class=\"inner\">\n<h2>NECOをささえる社員を紹介します</h2>\n<div class=\"wrap flex\">\n    <div class=\"image_wrap\">\n        <img src=\"images/main.jpg\" alt=\"\" width=\"600\" height=\"450\">\n    </div>\n    <div class=\"text_wrap\">\n        <p class=\"catch\">全国の事業所で毎日いきいきと働く社員が、様々な業務、人の生活、私たちの夢をささえています。</p>\n        <p>NECOの仲間である社員の皆さんに、毎日の仕事で感じていることについて聞きました。<br>\n        社員の目から見た、NECOの良いところや仲間との関係、社会人としてこれまでに経験した嬉しいこと・大変だったことなどを紹介しています。</p>\n    </div>\n</div>\n</div>\n<!-- /inner -->\n</section>\n<!-- /adjust_group -->\n\n\n<div id=\"contents\">\n<section class=\"adjust_group\">\n<div class=\"inner\">\t\t\n<div class=\"index_menu\">\n<div class=\"half_wrap02\">\n<ul>\n\t<li>\n \t\t<a href=\"interview01/index.html\">\n \t\t    <img src=\"images/oyake.jpg\" alt=\"\" width=\"380\" height=\"380\">\n \t\t    <div class=\"text_wrap\">\n \t\t      <h3></h3>\n \t\t        <p class=\"type\">東海事業所 事業管理部 事業管理第3課所属</p>\n \t\t        <p>自分がやりたい仕事を見つけられる会社です！</p>\n \t\t        <div class=\"btn\">\n \t\t            <p>くわしく見る</p>\n \t\t        </div>\n \t\t    </div>\n \t\t</a>\n\t</li>\n\t<li>\n \t\t<a href=\"interview02/index.html\">\n \t\t    <img src=\"images/ishii.jpg\" alt=\"\" width=\"380\" height=\"380\">\n \t\t    <div class=\"text_wrap\">\n \t\t      <h3></h3>\n \t\t        <p class=\"type\">東海事業所 トリチウム研グループ所属</p>\n \t\t        <p>新エネルギーの開発をサポートする仕事です。</p>\n \t\t        <div class=\"btn\">\n                    <p>くわしく見る</p>\n                </div>\n \t\t    </div>\n \t\t</a>\n\t</li>\n    <li>\n        <a href=\"interview03/index.html\">\n            <img src=\"images/kusano.jpg\" alt=\"\" width=\"380\" height=\"380\">\n            <div class=\"text_wrap\">\n              <h3></h3>\n                <p class=\"type\">東海事業所 焼却処理グループ所属</p>\n                <p>自分の可能性を広げてくれる会社です。</p>\n                <div class=\"btn\">\n                    <p>くわしく見る</p>\n                </div>\n            </div>\n        </a>\n    </li>\n    <li>\n        <a href=\"interview04/index.html\">\n            <img src=\"images/osawa.jpg\" alt=\"\" width=\"380\" height=\"380\">\n            <div class=\"text_wrap\">\n              <h3></h3>\n                <p class=\"type\">技術営業部 営業課所属</p>\n                <p>私たちと未来に一歩踏み出しましょう！</p>\n                <div class=\"btn\">\n                    <p>くわしく見る</p>\n                </div>\n            </div>\n        </a>\n    </li>\n</ul>\n</div>\n<!-- /row3_wrap -->\n</div>\n<!-- /index_menu -->\n</div>\n<!-- /inner -->\n</section>\n<!-- /adjust_group -->\n\n</div>\n<!-- contents -->\n</main>\n\n\n<footer>\n<div class=\"inner\">\n<nav class=\"footer_area_nav sp\">\n<ul>\n<li><a href=\"../about/index.html\">NECOについて</a>