rc=\"https://code.jquery.com/jquery-1.10.1.min.js\"></script>\n<script src=\"../common/js/library.js\"></script>\n\n<!-- このページで使用するcss、プラグインのオプション設定を記述したjsなどを読み込む -->\n<script src=\"../common/js/jquery.matchHeight.js\"></script>\n<script>\n$(function(){\n　　$('.matchHeight').matchHeight();\n　　$('#menu_block ul li').matchHeight();\n　　$('#ideal dl').matchHeight();\n});\n</script>\n<script>\n\t$(function(){\n\t\t$('.accordion-menu > dt').on('click',function(){\n\t\t\t$(this).toggleClass(\"on\");\n\t\t\t$(this).next('dd').slideToggle();\n\t\t});\n\t});\n</script>\n<!-- Global site tag (gtag.js) - Google Analytics -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=UA-190657780-1\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'UA-190657780-1');\n  gtag('config', 'G-3Y0BEEZQ9C');\n</script>\n\n</head>\n\n\n<body class=\"close\">\n<!-- Google Tag Manager (noscript) -->\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-N4DKX2CP\"\n\theight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n<!-- End Google Tag Manager (noscript) -->\n\n\n<!--========== #header ==========-->\n<header id=\"header\" class=\"cbox\">\n\t<h1 class=\"logo\"><a href=\"https://www.awi.co.jp/\" target=\"_blank\"><img src=\"../common/img/logo.png\" alt=\"エア・ウォーター\"></a><a href=\"../\"><span>採用サイト</span></a></h1>\n\t<div class=\"head_list cbox\">\n\t\t<span class=\"menu_btn\"><span class=\"line\"></span></span>\n\t\t<div class=\"entry_list\">\n\t\t\t<div class=\"nav-item open-item line\">\n\t\t\t\t<div class=\"cntnr\">\n\t\t\t\t\t<span class=\"u_line\">キャリア採用</span>\n\t\t\t\t</div>\n\t\t\t\t<div class=\"open_cntnts\">\n\n\t\t\t\t\t<a href=\"../recruit/career.html\">\n\t\t\t\t\t\t<span class=\"u_line02 txt-14\">キャリア採用情報</span>\n\t\t\t\t\t</a>\n\t\t\t\t\t<a href=\"../recruit/alumni.html\">\n\t\t\t\t\t\t<span class=\"u_line02