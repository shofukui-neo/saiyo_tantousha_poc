mon/js/ajaxzip3.js\" async></script></head>\r\n\r\n<body>\r\n<!-- Google Tag Manager (noscript) -->\r\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-K2LSKFM\"\r\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\r\n<!-- End Google Tag Manager (noscript) -->\r\n<!-- header_START -->\n<header>\n\t\t\t<div class=\"logo\"><a href=\"https://www.nabeya-mfg.co.jp\"><img src=\"https://www.nabeya-mfg.co.jp/img/common/logo.png\" alt=\"株式会社 ナベヤ製作所\" width=\"219\" height=\"32\"></a></div>\n\t\t<div class=\"contact\"><a href=\"#contact\" class=\"fade\"><span class=\"pc\"><img src=\"https://www.nabeya-mfg.co.jp/img/common/icon_contact.png\" alt=\"\" width=\"24\" height=\"24\">お問い合わせ</span><span class=\"sp\"><img src=\"https://www.nabeya-mfg.co.jp/img/common/btn_contact.png\" alt=\"お問い合わせ\" width=\"61\" height=\"67\"></span></a></div>\n\t<nav id=\"menu\">\n\t\t<div class=\"btn\"><img src=\"https://www.nabeya-mfg.co.jp/img/common/btn_menu.png\" alt=\"MENU\" width=\"64\" height=\"67\"></div>\n\t\t<ul>\n\t\t\t<li><a href=\"https://www.nabeya-mfg.co.jp/company/\">会社概要</a></li>\n\t\t\t<li><a href=\"https://www.nabeya-mfg.co.jp/guideline/\">経営指針</a></li>\n\t\t\t<li><a href=\"https://www.nabeya-mfg.co.jp/manufacturing/\">品質情報</a></li>\n\t\t\t<li><a href=\"https://www.nabeya-mfg.co.jp/service/\">事業案内</a></li>\n\t\t\t<li><a href=\"https://www.nabeya-mfg.co.jp/facility/\">設備一覧</a></li>\n\t\t\t<li><a href=\"https://www.nabeya-mfg.co.jp/vr/\">工場見学</a></li>\n\t\t\t<li class=\"shop\"><a href=\"https://nabeya-mfg.shop-pro.jp/\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"fade\"><img src=\"https://www.nabeya-mfg.co.jp/img/common/icon_shop.png\" alt=\"\" width=\"24\" height=\"24\">オンラインショップ</a></li>\n\t\t\t<li class=\"recruit\"><a href=\"https://www.nabeya-mfg.co.jp/recruit/\" class=\"fade\"><img src=\"https://www.nabeya-mfg.co.jp/img/common/icon_recruit.png\" alt=\"\" width=\"24\" height=\"24\">採用情報</a></li>\n\t\t</ul>\n\t</nav>\n</header>\n<!-- header_END -->\r\n<!-- title_START -->\r\n<div id=\"title\" class=\"information\">\r\n\t<div class=\"inner\">\r\n\t\t<h1>お知らせ<span>INFORMATION</span></h1>\r\n\t</div>\r\n</div>\r\n<!-- title_END -->\r\n\r\n<!-- path_START -->\r\n<ol id=\"path\" class=\"inner\" itemscope itemtype=\"https://schema.org/BreadcrumbList\">\r\n\t<li itemprop=\"itemListElement\" itemscope itemtype=\"https://schema.org/ListItem\"><a href=\"https://www.nabeya-mfg.co.jp\" itemprop=\"item\"><span itemprop=\"name\">HOME</span></a><meta itemprop=\"position\" content=\"1\"></li>\r\n\t<li itemprop=\"itemListElement\" itemscope itemtype=\"https://schema.org/ListItem\"><a href=\"https://www.nabeya-mfg.co.jp/information/\" itemprop=\"item\"><span itemprop=\"name\">お知らせ</span></a><meta itemprop=\"position\" content=\"2\"></li>\r\n\t<li itemprop=\"itemListElement\" itemscope itemtype=\"https://schema.org/ListItem\"><span itemprop=\"name\">夏季休業のお知らせ（8/9～8/17）</span><meta itemprop=\"position\" content=\"3\"></li>\r\n</ol>\r\n<!-- path_END -->\r\n\r\n<!-- main_START -->\r\n<main id=\"information\">\r\n\t<div class=\"entry\">\r\n\t\t<div class=\"inner\">\r\n\t\t\t<h2>夏季休業のお知らせ（8/9～8/17）</h2>\r\n\t\t\t<div class=\"date\"><time datetime=\"2025-07-28\" class=\"font_Roboto\">2025.07.28</time><span>NEWS</span></div>\r\n\t\t\t<div class=\"widget_entry\">\r\n\t\t\t\t\t\t\t\t\t\t\t\t<p>平素は格別のご高配を賜り、厚く御礼申し上げます。<br>誠に勝手ながら、当社では以下の期間を夏季の休業とさせていただきます。</p>\r\n<p><strong>休業期間：2025年8月9日（土）～8月17日（日）</strong></p>\r\n<p>休業期間中にいただきましたお問い合わせにつきましては、<span style=\"color: #ff0000;\"><strong>2025年8月18日（月）</strong></span>より順次対応させていただきます。<br>皆様にはご不便をおかけいたしますが、何卒ご了承のほどお願い申し上げます。</p>\r\n<p><strong>株式会社ナベヤ製作所</strong></p>\t\t\t\t\t\t\t</div>\r\n\t\t\t<div class=\"postlink\"><a href=\"https://www.nabeya-mfg.co.jp/information/116/\" rel=\"prev\">Previous</a><a href=\"https://www.nabeya-mfg.co.jp/information/127/\" rel=\"next\">Next</a></div>\r\n\t\t</div>\r\n\t</div>\r\n<div class=\"widget_contact\">\n\t<div class=\"inner\">\n\t\t<p>ナベヤ製作所は、<br>治具製作、部品加工、大型鋳物加⼯、3次元測定など、<br>多種多様な分野でお客様をバックアップいたします。<br>ものづくりでのお悩み事は、弊社へ今すぐご相談下さい。</p>\n\t\t<div class=\"widget_btn\"><a href=\"#contact\" class=\"fade\">フォームから問い合わせる</a></div>\n\t</div>\n</div></main>\r\n<!-- main_END -->\r\n\r\n<!-- footer_START -->\n<footer>\n\t<!-- <script src=\"https://www.google.com/recaptcha/api.js?render=6LfEe8wiAAAAAMMyx-TquFyy2IbofhXq1H-9-xEa\"></script> -->\n\t<script>\n\t\t// document.addEventListener('DOMContentLoaded', function() {\n\n\t\t// \t//※サイトキーを設定\n\t\t// \tvar siteKey = '6LfEe8wiAAAAAMMyx-TquFyy2IbofhXq1H-9-xEa';\n\t\t// \t//フォーム要素を取得\n\t\t// \tvar formElem = document.querySelector('form');\n\n\t\t// \tgrecaptcha.ready(function() {\n\t\t// \t\tgrecaptcha.execute(siteKey).then(function(token) {\n\t\t// \t\t\tvar inputTokenElem = document.createElement('input');\n\t\t// \t\t\tinputTokenElem.type = 'hidden';\n\t\t// \t\t\tinputTokenElem.name = 'recaptchaResponse';\n\t\t// \t\t\tinputTokenElem.value = token;\n\t\t// \t\t\tformElem.appendChild(inputTokenElem);\n\t\t// \t\t});\n\t\t// \t});\n\t\t// });\n\t</script>\n\t<div class=\"fix\"><a href=\"#contact\"><img src=\"https://www.nabeya-mfg.co.jp/img/common/fix_contact.png\" alt=\"ナベヤ製作所に今すぐ問い合わせる\" width=\"110\" height=\"183\"></a></div>\n\t<div class=\"fix fix2\"><a href=\"/recruit/\"><img src=\"https://www.nabeya-mfg.co.jp/img/common/fix_contact2.png\" alt=\"ナベヤ製作所人材募集中\" width=\"110\" height=\"183\"></a></div>\n\t<div class=\"pagetop\"><span class=\"fade\">&uarr;</span></div>\n\t\t\t<div id=\"contact\">\n\t\t\t\t\t<h2>お問い合わせ<span>CONTACT US</span></h2>\n\t\t\t<p class=\"lead\">下記項目にご入力下さい。</p>\n\t\t\t<p>当社へのご相談、ご質問等ございましたらお気軽にお問い合わせ下さい。<br>※必要事項をご記入の上、[ 送信します ] のボタンを押して下さい。※必須項目は、必ずご記入下さい。<br>・機種依存文字を入力すると、文字化けする場合がありますので、使用しないで下さい。</p>\n\t\t\t<form method=\"post\" action=\"/form/mail_v3.php\" enctype=\"multipart/form-data\">\n\t\t\t\t<table>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<th>お名前<span>必須</span></th>\n\t\t\t\t\t\t<td><input type=\"text\" name=\"お名前\" placeholder=\"山田 太郎\" required></td>\n\t\t\t\t\t</tr>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<th>会社名<span>必須</span></th>\n\t\t\t\t\t\t<td><input type=\"text\" name=\"会社名\" placeholder=\"株式会社ナベヤ製作所\" required></td>\n\t\t\t\t\t</tr>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<th>部署名</th>\n\t\t\t\t\t\t<td><input type=\"text\" name=\"部署名\" placeholder=\"営業部\"></td>\n\t\t\t\t\t</tr>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<th>役職名</th>\n\t\t\t\t\t\t<td><input type=\"text\" name=\"役職名\" placeholder=\"課長\"></td>\n\t\t\t\t\t</tr>\n\t\t\t\t\t<tr class=\"zipcode\">\n\t\t\t\t\t\t<th>郵便番号</th>\n\t\t\t\t\t\t<td><input type=\"text\" name=\"郵便番号\" placeholder=\"5040927\">\n\t\t\t\t\t\t\t<div class=\"btn\"><button type=\"button\" class=\"ajaxzip3 fade\">住所検索</button></div>\n\t\t\t\t\t\t</td>\n\t\t\t\t\t</tr>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<th>住所</th>\n\t\t\t\t\t\t<td><input type=\"text\" name=\"住所\"></td>\n\t\t\t\t\t</tr>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<th>電話番号</th>\n\t\t\t\t\t\t<td><input type=\"tel\" name=\"電話番号\" placeholder=\"000-0000-0000\"></td>\n\t\t\t\t\t</tr>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<th>メールアドレス<span>必須</span></th>\n\t\t\t\t\t\t<td><input type=\"email\" name=\"メールアドレス\" placeholder=\"&#105;&#110;&#102;&#111;&#64;&#115;&#111;&#107;&#117;&#116;&#101;&#105;&#46;&#99;&#111;&#46;&#106;&#112;\" required></td>\n\t\t\t\t\t</tr>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<th>メールアドレス<br>（確認）<span>必須</span></th>\n\t\t\t\t\t\t<td><input type=\"email\" name=\"メールアドレス（確認）\" placeholder=\"&#105;&#110;&#102;&#111;&#64;&#115;&#111;&#107;&#117;&#116;&#101;&#105;&#46;&#99;&#111;&#46;&#106;&#112;\" required></td>\n\t\t\t\t\t</tr>\n\t\t\t\t\t<tr class=\"textarea\">\n\t\t\t\t\t\t<th>お問い合わせ内容<span>必須</span></th>\n\t\t\t\t\t\t<td><textarea name=\"お問い合わせ内容\" rows=\"5\" required></textarea></td>\n\t\t\t\t\t</tr>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<th>添付ファイル<br>（最大5MBまで）</th>\n\t\t\t\t\t\t<td><input type=\"file\" name=\"upfile[]\"></td>\n\t\t\t\t\t</tr>\n\t\t\t\t</table>\n\t\t\t\t<div class=\"btn\"><button type=\"submit\" class=\"fade\">確認画面へ</button></div>\n\t\t\t</form>\n\t\t\t</div>\n\t\t<small>&copy;2022 株式会社ナベヤ製作所</small>\n</footer>\n<!-- footer_END --></body>\r\n</html>","finalUrl":"https://www.nabeya-mfg.co.jp/information/117/","rendered":false,"_cachedAt":"2026-06-23T23:12:18.072Z"}