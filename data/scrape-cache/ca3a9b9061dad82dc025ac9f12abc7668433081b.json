i class=\"navi__list--item has-child\" data-page=\"jobs\">\n                <div class=\"list-wrap js-has-child\" data-label=\"jobs\">\n                  <p>ニチコンの仕事</p><span class=\"arrow-ico\" data-label=\"jobs\"></span>\n                </div>\n                <div class=\"child-list__wrap\" data-label=\"jobs\">\n                  <ul class=\"child-list\">\n                    <li class=\"child-list__item\"><a class=\"flex-box\" href=\"/recruit_graduates/jobs/\">\n                        <p>ニチコンの仕事TOP</p>\n                        <div class=\"c-arrow-only-ico\"></div></a></li>\n                    <li class=\"child-list__item\"><a class=\"flex-box\" href=\"/recruit_graduates/jobs/interview1.html\">\n                        <p>フィルムコンデンサ設計</p>\n                        <div class=\"c-arrow-only-ico\"></div></a></li>\n                    <li class=\"child-list__item\"><a class=\"flex-box\" href=\"/recruit_graduates/jobs/interview2.html\">\n                        <p>生産技術</p>\n                        <div class=\"c-arrow-only-ico\"></div></a></li>\n                    <li class=\"child-list__item\"><a class=\"flex-box\" href=\"/recruit_graduates/jobs/interview3.html\">\n                        <p>材料開発</p>\n                        <div class=\"c-arrow-only-ico\"></div></a></li>\n                    <li class=\"child-list__item\"><a class=\"flex-box\" href=\"/recruit_graduates/jobs/interview4.html\">\n                        <p>品質管理</p>\n                        <div class=\"c-arrow-only-ico\"></div></a></li>\n                    <li class=\"child-list__item\"><a class=\"flex-box\" href=\"/recruit_graduates/jobs/interview5.html\">\n                        <p>社内SE</p>\n                        <div class=\"c-arrow-only-ico\"></div></a></li>\n                    <li class=\"child-list__item\"><a class=\"flex-box\" href=\"/recruit_graduates/jobs/interview6.html\">\n                        <p>コンデンサ設計開発</p>\n                        <div class=\"c-arrow-only-ico\"></div></a></li>\n                    <li class=\"child-list__item\"><a class=\"flex-box\" href=\"/recruit_graduates/jobs/interview7.html\">\n                        <p>蓄電ソフト開発</p>\n                        <div class=\"c-arrow-only-ico\"></div></a></li>\n                    <li class=\"child-list__item\"><a class=\"flex-box\" href=\"/recruit_graduates/jobs/interview8.html\">\n                        <p>応用機器設計</p>\n                        <div class=\"c-arrow-only-ico\"></div></a></li>\n                    <li class=\"child-list__item\"><a class=\"flex-box\" href=\"/recruit_graduates/jobs/interview10.html\">\n                        <p>営業</p>\n                        <div class=\"c-arrow-only-ico\"></div></a></li>\n                  </ul>\n                </div>\n              </li>\n              <li class=\"navi__list--item\" data-page=\"technology\"><a href=\"/recruit_graduates/technology/\">\n                  <div class=\"list-wrap\">\n                    <p>未来をひらく技術力</p><span class=\"c-arrow-only-ico is-tab\"></span>\n                  </div></a></li>\n              <li class=\"navi__list--item\" data-page=\"internship\"><a href=\"/recruit_graduates/internship/\">\n                  <div class=\"list-wrap\">\n                    <p>インターンシップ</p><span class=\"c-arrow-only-ico is-tab\"></span>\n                  </div></a></li>\n              <li class=\"navi__list--item last-item has-child\" data-page=\"requirement\">\n                <div class=\"list-wrap js-has-child\" data-label=\"requirement\">\n                  <p>募集要項</p><span class=\"arrow-ico\" data-label=\"requirement\"></span>\n                </div>\n                <div class=\"child-list__wrap is-open\" data-label=\"requirement\">\n                  <ul class=\"child-list\">\n                    <li class=\"child-list__item\"><a class=\"flex-box\" href=\"/recruit_graduates/requirement/\">\n                        <p>募集要項TOP</p>\n                        <div class=\"c-arrow-only-ico\"></div></a></li>\n                    <li class=\"child-list__item\"><a class=\"flex-box\" href=\"/recruit_graduates/requirement/process.html\">\n                        <p>採用プロセス</p>\n                        <div class=\"c-arrow-only-ico\"></div></a></li>\n                  </ul>\n                </div>\n              </li>\n            </ul>\n          </div>\n          <div class=\"header__entry--wrap\"><a class=\"header__entry--btn -white\" href=\"https://job.axol.jp/bx/s/nichicon_27/mypage/login\" target=\"_blank\">\n              <p>My Page</p></a><a class=\"header__entry--btn\" href=\"https://job.axol.jp/bx/s/nichicon_27/entry/\" target=\"_blank\">\n              <p>Entry</p></a></div>\n          <div class=\"sp-menu__btn\" id=\"js-menu-btn\">\n            <p>Menu</p><span class=\"border-ico\"></span>\n          </div>\n        </div>\n      </div>\n    </header>\n    <div class=\"about\">\n      <section class=\"about-mv\">\n        <div class=\"about-mv__container\">\n          <div class=\"about-mv__img\">\n            <div class=\"c-container\">\n              <div class=\"c-ttl__contents\">\n                <h2 class=\"c-ttl white-txt u-textOverlay\"><span class=\"u-textOverlay__inner\">About us</span></h2>\n                <p class=\"c-sub-ttl white-txt u-textOverlay\"><span class=\"u-textOverlay__inner\">ニチコンを知る</span></p>\n              </div>\n            </div>\n          </div>\n        </div>\n      </section>\n      <section class=\"about-lead\" id=\"anc-01\">\n        <div class=\"c-container\">\n          <div class=\"about-lead__bg\">\n            <div class=\"about-lead__inner\">\n              <h3 class=\"about-lead__ttl\">ニチコンの経営理念</h3>\n              <p class=\"about-lead__txt\">\n                価値ある製品を創造し、<br class=\"is-sp\">明るい未来社会づくりに貢献します。<br>\n                より良い地球環境の実現に努め、<br class=\"is-sp\">倫理的・社会的責任を果たすとともに、<br class=\"is-sp\">顧客・株主・従業員をはじめ<br class=\"is-pc\">\n                全ての人々を<br class=\"is-sp\">大切に、企業価値の最大化を目指して、<br class=\"is-sp\">誠心誠意をもって「考働」します。\n              </p>\n            </div>\n          </div>\n        </div>\n      </section>\n      <section class=\"about-keyword js-fadeup-trigger\" id=\"anc-02\">\n        <div class=\"about-keyword__container\">\n          <div class=\"c-container\">\n            <h3 class=\"c-lower-ttl\">キーワードで見る<br class=\"is-sp\">ニチコン</h3>\n            <div class=\"about-keyword__wrap\">\n              <div class=\"about-keyword__inner\">\n                <div class=\"about-keyword__content\">\n                  <h4 class=\"c-lower-content__ttl\">2つの事業領域</h4>\n                  <p class=\"lead-txt\">創エネ・蓄エネ・省エネのコア技術を軸に「コンデンサ事業」と「NECST事業」を展開しています。</p>\n                  <div class=\"img\">\n                    <picture>\n                      <source srcset=\"/recruit_graduates/assets/images/about/about-figure-img_sp.png\" media=\"(max-width: 768px)\"><img src=\"/recruit_graduates/assets/images/about/about-figure-img_pc.png\" alt=\"\">\n                    </picture>\n                  </div>\n                </div>\n                <div class=\"about-keyword__content is-margin-top\">\n                  <h4 class=\"c-lower-content__ttl\">革新的な<br class=\"is-sp\">製品・技術開発</h4>\n                  <div class=\"product-list__box\">\n                    <div class=\"product-list\">\n                      <div class=\"product-list__item\">\n                        <div class=\"ttl\">国内No.1</div>\n                        <div class=\"txt\">家庭用蓄電池の累積販売台数</div>\n                        <div class=\"img\"><img src=\"/recruit_graduates/assets/images/about/about-technology-img01.jpg\" alt=\"\"></div>\n                      </div>\n                      <div class=\"product-list__item\">\n                        <div class=\"ttl\">オンリーワン</div>\n                        <div class=\"txt\">SLB（小形リチウムイオン二次電池）</div>\n                        <div class=\"img\"><img src=\"/recruit_graduates/assets/images/about/about-technology-img02.jpg\" alt=\"\"></div>\n                      </div>\n                      <div class=\"product-list__item\">\n                        <div class=\"ttl\">80％以上のシェア</div>\n                        <div class=\"txt\">医療用、学術用加速器電源</div>\n                        <div class=\"img\"><img src=\"/recruit_graduates/assets/images/about/about-technology-img03.jpg\" alt=\"\"></div>\n                      </div>\n                    </div>\n                    <div class=\"product-list\">\n                      <div class=\"product-list__item\">\n                        <div class=\"ttl\">世界初</div>\n                        <div class=\"txt is-txt-left\">電気自動車（EV）からの給電を可能にした<br class=\"is-only-pc\">V2H（Vehicle to Home）システム</div>\n                        <div class=\"img\"><img src=\"/recruit_graduates/assets/images/about/about-technology-img04.jpg\" alt=\"\"></div>\n                      </div>\n                      <div class=\"product-list__item\">\n                        <div class=\"ttl\">オンリーワン</div>\n                        <div class=\"txt is-txt-left\">太陽光で発電した電気を家庭やEVに<br class=\"is-sp\">活用できる蓄電システム</div>\n                        <div class=\"img\"><img src=\"/recruit_graduates/assets/images/about/about-technology-img05.jpg\" alt=\"\"></div>\n                      </div>\n                    </div>\n                  </div>\n                </div>\n              </div>\n            </div>\n            <div class=\"about-keyword__bg padding-top\" id=\"anc-03\">\n              <div class=\"about-keyword__content\">\n                <h4 class=\"c-lower-content__ttl\">創造業としての<br class=\"is-sp\">社会貢献</h4>\n                <p class=\"lead-txt\">単に良い製品をつくる製造業ではなく、お客様や社会が必要とする価値づくりや社会を変革するような<br class=\"is-pc\">コトづくりを目指しています。</p>\n                <div class=\"contribution-list__box\">\n                  <div class=\"contribution-list\">\n                    <div class=\"contribution-list__img\"><img src=\"/recruit_graduates/assets/images/about/about-contribution-img01.jpg\" alt=\"\"></div>\n                    <div class=\"contribution-list__txt\">\n                      <div class=\"ttl\">サステナブルな<br class=\"is-pc\">社会の実現へ</div>\n                      <div class=\"txt\">\n                        <p>NECST事業では、製品を通じてエネルギーの安定供給と環境保護の両立を目指しています。</p>\n                      </div>\n                    </div>\n                  </div>\n                  <div class=\"contribution-list is-reverse\">\n                    <div class=\"contribution-list__img\"><img src=\"/recruit_graduates/assets/images/about/about-contribution-img02.jpg\" alt=\"\"></div>\n                    <div class=\"contribution-list__txt\">\n                      <div class=\"ttl\">被災地への支援</div>\n                      <div class=\"txt\">\n                        <p>国内外の災害時には、外部給電器での被災地支援を行っています。</p>\n                      </div>\n                    </div>\n                  </div>\n                </div>\n              </div>\n            </div>\n            <div class=\"about-keyword__wrap padding-top\" id=\"anc-04\">\n              <div class=\"about-keyword__inner\">\n                <div class=\"about-keyword__content\">\n                  <h4 class=\"c-lower-content__ttl\">積極的な研究開発</h4>\n                  <div class=\"column-list\">\n                    <div class=\"column-list__item\">\n                      <div class=\"ttl\">積極的な設備投資</div>\n                      <div class=\"txt\">既存事業における生産能力拡大や、新規事業の成長を見据えた研究・技術開発へも積極的に投資することで、製品・技術の創出につなげています。</div>\n                      <div class=\"img\"><img src=\"/recruit_graduates/assets/images/about/about-research-img01.jpg\" alt=\"\"></div>\n                    </div>\n                    <div class=\"column-list__item\">\n                      <div class=\"ttl\">産学連携</div>\n                      <div class=\"txt\">新しい価値創造に挑戦するため、技術振興機関や異業種企業、大学とも技術開発を行っています。</div>\n                      <div class=\"img\"><img src=\"/recruit_graduates/assets/images/about/about-research-img02.jpg\" alt=\"\"></div>\n                    </div>\n                  </div>\n                </div>\n              </div>\n            </div>\n            <div class=\"about-keyword__bg\">\n              <div class=\"about-keyword__content is-left-bg\" id=\"anc-05\">\n                <div class=\"row-list\">\n                  <div class=\"row-list__txt\">\n                    <h4 class=\"ttl\">ダイバーシティ</h4>\n                    <div class=\"txt\">\n                      <p>「人」こそ最大の経営資源と考え、障がい者、高齢者、女性、外国人をはじめ多様な人材を登用し、個人の能力が最大限に発揮できるよう取り組んでいます。</p>\n                    </div>\n                  </div>\n                  <div class=\"row-list__img is-diver\"><img src=\"/recruit_graduates/assets/images/about/about-diver-img.jpg\" alt=\"\"></div>\n                </div>\n              </div>\n              <div class=\"about-keyword__content is-right-bg\" id=\"anc-06\">\n                <div class=\"row-list is-reverse\">\n                  <div class=\"row-list__txt\">\n                    <h4 class=\"ttl\">グローバルな事業展開</h4>\n                    <div class=\"txt\">\n                      <p>海外売上高比率 49.4%*<br>海外事業拠点は、中国、アメリカ、東南アジアなど、10カ国20拠点あります。</p>\n                      <p><small>*2025年3月31日現在</small></p>\n                    </div>\n                  </div>\n                  <div class=\"row-list__img is-global\"><img src=\"/recruit_graduates/assets/images/about/about-global-img.jpg\" alt=\"\"></div>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </section>\n      <section class=\"about-info\" id=\"anc-07\">\n        <div class=\"about-info__container\">\n          <div class=\"c-container\">\n            <h3 class=\"c-lower-ttl\">会社情報</h3>\n            <div class=\"about-info__wrap\">\n              <div class=\"grid-layout\">\n                <div class=\"grid-layout__item num1\">\n                  <div class=\"grid-layout__item--ttl\">設立</div>\n                  <div class=\"grid-layout__item--img\"><img src=\"/recruit_graduates/assets/images/about/about-info-icon01.svg\" alt=\"\"></div>\n                  <div class=\"grid-layout__item--value\">\n                    <p><span class=\"num\">1950</span>年<br class=\"is-tab\"><span class=\"small-txt\">（昭和25年）</span></p>\n                  </div>\n                </div>\n                <div class=\"grid-layout__item num2\">\n                  <div class=\"grid-layout__item--ttl\">資本金</div>\n                  <div class=\"grid-layout__item--img\"><img src=\"/recruit_graduates/assets/images/about/about-info-icon02.svg\" alt=\"\"></div>\n                  <div class=\"grid-layout__item--value\">\n                    <p><span class=\"num\">142.8</span>億円</p><span>2025年3月31日現在</span>\n                  </div>\n                </div>\n                <div class=\"grid-layout__item num3\">\n                  <div class=\"grid-layout__item--ttl\">社員数</div>\n                  <div class=\"grid-layout__item--img\"><img src=\"/recruit_graduates/assets/images/about/about-info-icon03.svg\" alt=\"\"></div>\n                  <div class=\"grid-layout__item--value\">\n                    <p><span class=\"num\">5,242</span>人</p><span>2025年3月31日現在</span>\n                  </div>\n                </div>\n                <div class=\"grid-layout__item num4\">\n                  <div class=\"grid-layout__item--ttl\">売上高</div>\n                  <div class=\"grid-layout__item--img\"><img src=\"/recruit_graduates/assets/images/about/about-info-icon04.svg\" alt=\"\"></div>\n                  <div class=\"grid-layout__item--value\">\n                    <p><span class=\"num\">1,757</span>億円</p><span>2025年3月31日現在</span>\n                  </div>\n                </div>\n                <div class=\"grid-layout__item num5\">\n                  <div class=\"grid-layout__item--ttl\">グループ会社</div>\n                  <div class=\"grid-layout__item--img is-wide\"><img src=\"/recruit_graduates/assets/images/about/about-info-icon05.svg\" alt=\"\"></div>\n                  <div class=\"grid-layout__item--value\">\n                    <p><span class=\"num\">28</span>社<