     <p class=\"en\">Voice</p>\r\n            <p class=\"jp\">社員の声</p>\r\n          </a>\r\n          <ul class=\"child\">\r\n            <li class=\"sp\"><a href=\"/company/recruitment/voice/\">社員の声INDEX</a></li>\r\n            <li><a href=\"/company/recruitment/voice/digital.html\">座談会：デジタルが導く変革</a></li>\r\n            <li><a href=\"/company/recruitment/voice/worklife.html\">対談：働き方・ワーク＆ライフ</a></li>\r\n            <li><a href=\"/company/recruitment/voice/global.html\">海外で活躍する社員</a></li>\r\n            <li><a href=\"/company/recruitment/voice/surprise/\"><span class=\"label new\">新卒</span>新入社員が驚いたニコン</a></li>\r\n            <li><a href=\"/company/recruitment/voice/rookie/index2.html\"><span class=\"label new\">新卒</span>新人カメラ 2024</a></li>\r\n            <li><a href=\"/company/recruitment/voice/rookie/\"><span class=\"label new\">新卒</span>新人カメラ 2022</a></li>\r\n            <li><a href=\"/company/recruitment/career/crosstalk/talk-technology.html\"><span class=\"label career\">キャリア</span>キャリア入社座談会：技術系</a></li>\r\n            <li><a href=\"/company/recruitment/career/crosstalk/talk-clerical.html\"><span class=\"label career\">キャリア</span>キャリア入社座談会：事務系</a></li>\r\n            <li><a href=\"/company/recruitment/career/pickup/\"><span class=\"label career\">キャリア</span>事業部インタビュー</a></li>\r\n          </ul>\r\n        </div>\r\n        <div class=\"sitemap_blocks\">\r\n          <div class=\"title parent\">\r\n            <p class=\"en\">Work Style</p>\r\n            <p class=\"jp\">環境・制度</p>\r\n          </div>\r\n          <ul class=\"child\">\r\n            <li><a href=\"/company/recruitment/workstyle/worklife-balance.html\">ワーク・ライフ・バランス</a></li>\r\n            <li><a href=\"/company/recruitment/workstyle/hr.html\">人事制度</a></li>\r\n            <li><a href=\"/company/recruitment/workstyle/training.html\">教育・研修制度</a></li>\r\n            <li><a href=\"/company/recruitment/workstyle/office.html\">事業所の魅力</a></li>\r\n          </ul>\r\n        </div>\r\n        <div class=\"sitemap_blocks wide col2\">\r\n          <div class=\"title parent\">\r\n            <p class=\"en\">Recruit</p>\r\n            <p class=\"jp\">採用情報</p>\r\n          </div>\r\n          <div class=\"col2\">\r\n          <ul class=\"child\">\r\n            <li><a href=\"/company/recruitment/newgraduates/message/\"><span class=\"label new\">新卒</span>求める人物像</a></li>\r\n            <li><a href=\"/company/recruitment/newgraduates/recruit/requirements_jim.html\"><span class=\"label new\">新卒</span>事務系採用募集要項</a></li>\r\n            <li><a href=\"/company/recruitment/newgraduates/recruit/requirements_tec.html\"><span class=\"label new\">新卒</span>技術系採用募集要項</a></li>\r\n            <li><a href=\"/company/recruitment/newgraduates/recruit/faq.html\"><span class=\"label new\">新卒</span>新卒FAQ</a></li>\r\n            <li><a href=\"/company/recruitment/newgraduates/internship/\"><span class=\"label new\">新卒</span>インターンシップ・イベント</a></li>\r\n          </ul>\r\n          <ul class=\"child\">\r\n            <li><a href=\"/company/recruitment/career/message/\"><span class=\"label career\">キャリア</span>キャリア採用にかける期待</a></li>\r\n            <li><a href=\"/company/recruitment/career/recruit/requirements.html\"><span class=\"label career\">キャリア</span>応募・選考について</a></li>\r\n            <li><a href=\"/company/recruitment/career/recruit/faq.html\"><span class=\"label career\">キャリア</span>キャリアFAQ</a></li>\r\n            <li><a href=\"https://job.axol.jp/qd/c/nikon/job/list\" target=\"_blank\"><span class=\"label career\">キャリア</span>募集職種一覧<span class=\"c-icon\"><img src=\"/assets/img/icon_link-ext-white.svg\" width=\"16\" height=\"16\" alt=\"別窓で遷移します\"></span></a></li>\r\n          </ul>\r\n          </div>\r\n        </div>\r\n        <div class=\"sitemap_blocks wide\">\r\n          <div class=\"title parent\">\r\n            <p class=\"en\">More Nikon</p>\r\n            <p class=\"jp\">さらに詳しくニコンを知る</p>\r\n          </div>\r\n          <ul class=\"child\">\r\n            <li><a href=\"https://www.jp.nikon.com/company/technology/\" target=\"_blank\">テクノロジー<span class=\"c-icon\"><img src=\"/assets/img/icon_link-ext-white.svg\" width=\"16\" height=\"16\" alt=\"別窓で遷移します\"></span></a></li>\r\n            <li><a href=\"https://www.jp.nikon.com/company/corporate/brand/vision2030magazine/\" target=\"_blank\">VISION 2030 magazine<span class=\"c-icon\"><img src=\"/assets/img/icon_link-ext-white.svg\" width=\"16\" height=\"16\" alt=\"別窓で遷移します\"></span></a></li>\r\n            <li><a href=\"https://www.jp.nikon.com/company/technology/stories/\" target=\"_blank\">ストーリーズ<span class=\"c-icon\"><img src=\"/assets/img/icon_link-ext-white.svg\" width=\"16\" height=\"16\" alt=\"別窓で遷移します\"></span></a></li>\r\n          </ul>\r\n\r\n        </div>\r\n        <div class=\"sitemap_blocks\"></div>\r\n        <div class=\"btns\">\r\n          <a href=\"/company/recruitment/newgraduates/\">\r\n            <span class=\"jp\">新卒採用TOP</span>\r\n            <span class=\"en\">Newgraduates</span>\r\n          </a>\r\n          <a href=\"/company/recruitment/career/\">\r\n            <span class=\"jp\">キャリア採用TOP</span>\r\n            <span class=\"en\">Career</span>\r\n          </a>\r\n          <a href=\"/company/recruitment/challenged/\" target=\"_blank\">\r\n            <span class=\"jp\">障がい者採用TOP</span>\r\n            <span class=\"en\">Challenged</span>\r\n          </a>\r\n        </div>\r\n\r\n      </div>\r\n    </div>\r\n  </div>\r\n\r\n</div>\r\n\n    <main>\n        <div id=\"pan\">\n            <ul>\n                <li><a href=\"/company/recruitment/\">採用情報</a></li>\n                <li><a href=\"/company/recruitment/newgraduates/\">新卒採用サイト</a></li>\n                <li>\n                    <p>Internship/Event</p>\n                </li>\n            </ul>\n        </div>\n\n        <div id=\"internvisual\">\n            <div class=\"in\">　\n                <h1 class=\"en\">Internship/Event<span class=\"enl\"></span></h1>\n            </div>\n            <div class=\"images pc\">\n                <img src=\"/company/recruitment/assets/img/internship/visual.jpg\" alt=\"\">\n            </div>\n            <div class=\"images sp\">\n                <img src=\"/company/recruitment/assets/img/internship/visual_sp.jpg\" alt=\"\">\n            </div>\n            <div class=\"in\">\n                <div class=\"lead inview fadeInup\">\n                    <p>\n                        ニコンってカメラの会社？…いいえ、それだけではありません。\n                    </p>\n                    <p>\n                        インターンシップやイベントでは、<br>\n                        さまざまな事業や職場の雰囲気に触れながら、<br>\n                        最前線の業務を体験いただけるプログラムを用意しています。\n                    </p>\n                    <p>\n                        ニコンの技術力やプロジェクトを肌で感じ、<br>\n                        社員からのフィードバックを通して理解を深め、<br>\n                        「ニコンと一緒に、成長する。」ことを目指しています。\n                    </p>\n                    <p>\n                        「光」の可能性に挑み、進化するニコンのインターンシップ、<br>\n                        ぜひ皆さまからのエントリーをお待ちしています。\n\n                    </p>\n                </div>\n            </div>\n        </div>\n\n        <section id=\"events\" class=\"sec-events block_contents\">\n            <div class=\"inner\">\n                <h2 class=\"slash-title\">イベントを見つける</h2>\n\n                <div class=\"filter-container\">\n                    <div class=\"filter-row\">\n                        <span class=\"filter-label-empty\"></span>\n                        <div class=\"filter-buttons\">\n                            <button class=\"filter-btn active\" data-filter=\"*\">ALL</button>\n                        </div>\n                    </div>\n\n                    <div class=\"filter-row\">\n                        <span class=\"filter-label\">形態</span>\n                        <div class=\"filter-buttons\">\n                            <button class=\"filter-btn\" data-filter=\".type-taimen\">職場体験（対面）</button>\n                            <button class=\"filter-btn\" data-filter=\".type-online\">オープンカンパニー（オンライン）</button>\n                        </div>\n                    </div>\n                    <div class=\"filter-row\">\n                        <span class=\"filter-label\">対象</span>\n                        <div class=\"filter-buttons\">\n                            <button class=\"filter-btn\" data-filter=\".target-office\">事務系</button>\n                            <button class=\"filter-btn\" data-filter=\".target-tech\">技術系</button>\n                            <button class=\"filter-btn\" data-filter=\".target-kosen\">高専本科生</button>\n                        </div>\n                    </div>\n                    <div class=\"filter-row\">\n                        <span class=\"filter-label\">時期</span>\n                        <div class=\"filter-buttons\">\n                            <button class=\"filter-btn\" data-filter=\".season-456\">4・5・6月</button>\n                            <button class=\"filter-btn\" data-filter=\".season-789\">7・8・9月</button>\n                            <button class=\"filter-btn\" data-filter=\".season-101112\">10・11・12月</button>\n                            <button class=\"filter-btn\" data-filter=\".season-123\">1・2・3月</button>\n                        </div>\n                    </div>\n                </div>\n\n                <div class=\"event-grid\">\n\n                    <div class=\"block type-taimen target-office target-tech season-789\">\n                        <span class=\"badge-yellow\">Workshop</span>\n                        <div class=\"image zoom\">\n                            <img src=\"/company/recruitment/assets/img/internship/event01.jpg\" alt=\"夏期職場体験ワークショップ\">\n                        </div>\n                        <div class=\"txt\">\n                            <div class=\"panel-tags\">\n                                <span class=\"badge-outline\">対面（職場受入）</span>\n                                <span class=\"badge-outline\">3日間コース：2026年8月26日～28日</span>\n                                <span class=\"badge-outline\">5日間コース：2026年8月31日～9月4日</span>\n                            </div>\n                            <p class=\"duration-text\">3Days/5Days</p>\n                            <div class=\"titles\">\n                                <h2>夏期 職場体験ワークショップ</h2>\n                            </div>\n                            <div class=\"exp\">\n                                <p>働くってどういうことだろう？毎日何をしているの？職場の雰囲気は？実際の職場で業務を体験すると、たくさんの新たな発見や学びがあります。</p>\n                            </div>\n                            <a href=\"summer.html\" class=\"action-wrap\">\n                                <span class=\"action-text\">詳細を見る</span>\n                                <span class=\"round-arrow-btn textlink\">＞</span>\n                            </a>\n                        </div>\n                    </div>\n\n                    <div class=\"block type-taimen target-kosen season-789\">\n                        <span class=\"badge-yellow\">Internship</span>\n                        <div class=\"image zoom\">\n                            <img src=\"/company/recruitment/assets/img/internship/event02.jpg\" alt=\"高専本科生向け職場体験インターンシップ\">\n                        </div>\n                        <div class=\"txt\">\n                            <div class=\"panel-tags\">\n                                <span class=\"badge-outline\">対面（職場受入）</span>\n                                <span class=\"badge-outline\">2026年8月31日～9月4日</span>\n                            </div>\n                            <p class=\"duration-text\">5Days</p>\n                            <div class=\"titles\">\n                                <h2>高専本科生向け<br>職場体験インターンシップ</h2>\n                            </div>\n                            <div class=\"exp\">\n                                <p>複数のコースから興味や専攻に合わせて選択していただけます。社員と一緒に技術に触れながら、自分の適性や活躍の可能性を広げてみませんか。</p>\n                            </div>\n                            <a href=\"kousen.html\" class=\"action-wrap\">\n                                <span class=\"action-text\">詳細を見る</span>\n                                <span class=\"round-arrow-btn textlink\">＞</span>\n                            </a>\n                        </div>\n                    </div>\n\n                    <div class=\"block type-online target-office target-tech season-456 season-789 season-101112\">\n                        <span class=\"badge-yellow\">Open Company</span>\n                        <div class=\"image zoom\">\n                            <img src=\"/company/recruitment/assets/img/internship/event03.jpg\"\n                                alt=\"ニコンの「光」を体験するオンラインワークショップ\">\n                        </div>\n                        <div class=\"txt\">\n                            <div class=\"panel-tags\">\n                                <span class=\"badge-outline\">オンライン</span>\n                                <span class=\"badge-outline\">2026年6月～12月頃 ※各月2～4回実施予定</span>\n                            </div>\n                            <p class=\"duration-text\">1Day 約2時間</p>\n                            <div class=\"titles\">\n                                <h2>ニコンの「光」を体験する<br>オンラインワークショップ</h2>\n                            </div>\n                            <div class=\"exp\">\n                                <p>2時間でニコンの理念や事業、社風を体感できる参加型のオンラインイベント。グループワークを通じてニコンの理解を深めることができます。</p>\n                            </div>\n                            <div class=\"action-wrap js-accordion-trigger\">\n                                <span class=\"action-text\">詳細を見る</span>\n                                <button class=\"round-arrow-btn\">＋</button>\n                            </div>\n                        </div>\n                        <div class=\"panel-accordion-body\">\n                            <div class=\"accordion-inner\">\n                                <h3>参加方法</h3>\n                                <p>詳細と予約開始はニコンマイページからご案内します。ENTRYボタンよりマイページにご登録をお願いします。</p>\n                                <hr cl