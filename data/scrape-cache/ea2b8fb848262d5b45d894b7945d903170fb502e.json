ドギーマン,DoggyMan,犬,猫,ペット,ペットフード,動物,ペットライフ,採用,新卒採用\">  <title>人事部メッセージ｜新卒採用｜ドギーマンハヤシ株式会社</title>\r\n  <meta name=\"description\" content=\"総合ペットメーカーのドギーマンハヤシの新卒採用ホームページです。社長メッセージや社員メッセージ、当社の仕事内容など、採用に関する情報をお伝えします。採用担当者より、学生の皆さまへメッセージをお伝えします。\">\r\n  <!-- OGP -->\r\n  <meta property=\"og:site_name\" content=\"新卒採用｜ドギーマンハヤシ株式会社\">\r\n  <meta property=\"og:title\" content=\"人事部メッセージ｜新卒採用｜ドギーマンハヤシ株式会社\">\r\n  <meta property=\"og:type\" content=\"article\">\r\n  <meta property=\"og:url\" content=\"https://www.doggyman.com/recruit/personnel/\">\r\n  <meta property=\"og:description\" content=\"総合ペットメーカーのドギーマンハヤシの新卒採用ホームページです。社長メッセージや社員メッセージ、当社の仕事内容など、採用に関する情報をお伝えします。採用担当者より、学生の皆さまへメッセージをお伝えします。\">\r\n  <meta property=\"og:image\" content=\"\">\r\n  <link rel=\"canonical\" href=\"https://www.doggyman.com/recruit/personnel/\">\r\n</head>\r\n\r\n\r\n\r\n<body id=\"personnel\">\r\n\r\n\r\n\r\n  <div class=\"wrapper\">\r\n\r\n\r\n\r\n    <header>\r\n  <div class=\"inner\">\r\n    <div class=\"header-menu-area\">\r\n      <figure class=\"header-logo\">\r\n        <a href=\"../\">\r\n          <img src=\"../assets/img/logo.png\" alt=\"ドギーマンハヤシ株式会社\">\r\n          <p>採用サイト</p>\r\n        </a>\r\n      </figure>\r\n      <div class=\"header-menu\">\r\n        <ul class=\"header-menu-bottom\">\r\n          <li><a href=\"../\">HOME</a></li>\r\n          <li><a href=\"../message/\">社長メッセージ</a></li>\r\n          <li class=\"drop-menu\">\r\n            <a style=\"pointer-events: none;\">ドギーマンを知る</a>\r\n            <ul class=\"drop-menu-list\">\r\n              <li class=\"drop-menu-item\"><a href=\"../pet_market/\">ペット市場の今</a></li>\r\n              <li class=\"drop-menu-item\"><a href=\"../about-doggyman/\">キーワードで知る<br>ドギーマン</a></li>\r\n            </ul>\r\n          </li>\r\n          <li class=\"drop-menu\">\r\n            <a href=\"../business/\">ドギーマンの仕事</a>\r\n            <ul class=\"drop-menu-list\">\r\n              <li class=\"drop-menu-item\"><a href=\"../business#proposal\">「提案型営業」とは</a></li>\r\n              <li class=\"drop-menu-item\"><a href=\"../business#group\">部門紹介</a></li>\r\n            </ul>\r\n          </li>\r\n          <li class=\"drop-menu\">\r\n            <a href=\"../job/\">ドギーマンの人</a>\r\n            <ul class=\"drop-menu-list\">\r\n              <li class=\"drop-menu-item\"><a href=\"../job/#interview_main\">社員メッセージ</a></li>\r\n              <li class=\"drop-menu-item\"><a href=\"../job/#top-talk-session\">トークセッション</a></li>\r\n              <li class=\"drop-menu-item\"><a href=\"../people/boss-subordinate/\">　上司×部下</a></li>\r\n              <li class=\"drop-menu-item\"><a href=\"../people/development/\">　食品開発×用品開発</a></li>\r\n              <li class=\"drop-menu-item\"><a href=\"../people/symposium\">　入社3〜4年目社員 座談会</a></li>\r\n            </ul>\r\n          </li>\r\n          <li class=\"drop-menu\">\r\n            <a style=\"pointer-events: none;\">採用情報</a>\r\n            <ul class=\"drop-menu-list\">\r\n              <li class=\"drop-menu-item\"><a href=\"../welfare/\">各種制度・福利厚生</a></li>\r\n              <li class=\"drop-menu-item\"><a href=\"../personnel/\">人事部メッセージ</a></li>\r\n              <li class=\"drop-menu-item\"><a href=\"../recruit-info/\">採用情報</a></li>\r\n              <li class=\"drop-menu-item\"><a href=\"../faq/\">よくある質問</a></li>\r\n            </ul>\r\n          </li>\r\n          <li class=\"drop-menu\">\r\n                <a style=\"pointer-events: none;\">ENTRY<br>MY PAGE</a>\r\n                <ul class=\"drop-menu-list entry\">\r\n                  <li class=\"drop-menu-item\">\r\n                  <a href=\"https://doggyman-recruit.snar.jp/index.aspx\" target=\"_blank\" rel=\"noopener noreferrer\">ENTRY</a>\r\n                  </li>\r\n                  <li class=\"drop-menu-item\">\r\n                  <a href=\"https://doggyman-recruit.snar.jp/login.aspx\" target=\"_blank\" rel=\"noopener noreferrer\">MY PAGE</a>\r\n                  </li>\r\n                </ul>\r\n              </li>\r\n\r\n\r\n\r\n        </ul>\r\n      </div>\r\n    </div>\r\n\r\n    <div class=\"menu\">\r\n      <nav>\r\n        <p class=\"navToggle\">\r\n          <span></span><span></span><span></span>\r\n        </p>\r\n        <div id=\"smt_menu_wrapper\" class=\"\">\r\n        <ul class=\"link\">\r\n            <li class=\"link-entry\">\r\n              <a href=\"https://doggyman-recruit.snar.jp/index.aspx\" target=\"_blank\" rel=\"noopener noreferrer\">新卒ENTRY</a>\r\n              <a href=\"https://doggyman-recruit.snar.jp/login.aspx\" target=\"_blank\" rel=\"noopener noreferrer\">MY PAGE</a>\r\n            </li>\r\n            <li class=\"full\">\r\n              <h3><a href=\"../\">HOME</a></h3>\r\n            </li>\r\n            <li>\r\n              <h4><a>COMPANY</a></h4>\r\n              <a href=\"../message/\">社長メッセージ</a>\r\n              <a href=\"../pet_market/\">ペット市場の今</a>\r\n              <a href=\"../about-doggyman/\">キーワードで知るドギーマン</a>\r\n              <a href=\"../business/\">「提案型営業」と部門紹介</a>\r\n              <a href=\"../#understands\">ドギーマンは分かってくれる</a>\r\n            </li>\r\n            <li>\r\n              <h4><a>PEOPLE</a></h4>\r\n              <a href=\"../job/#interview_main\">社員インタビュー</a>\r\n              <a class=\"none\" href=\"../job/#top-talk-session\">トークセッション</a>\r\n              <a class=\"under\" href=\"../people/boss-subordinate/\">上司×部下</a>\r\n              <a class=\"under\" href=\"../people/development/\">食品開発×用品開発</a>\r\n              <a class=\"under\" href=\"../people/symposium\">入社3〜4年目社員 座談会</a>\r\n            </li>\r\n            <li>\r\n              <h4><a>RECRUIT</a></h4>\r\n              <a href=\"../welfare/\">各種制度・福利厚生</a>\r\n              <a href=\"../personnel/\">人事部メッセージ</a>\r\n              <a href=\"../recruit-info/\">採用情報</a>\r\n              <a href=\"../faq/\">よくある質問</a>\r\n            </li>\r\n          </ul>\r\n        </div>\r\n      </nav>\r\n    </div>\r\n  </div>\r\n  <div class=\"to_top_btn\">\r\n    <a href=\"#\"><img src=\"../assets/img/top_allow.png\" alt=\"トップに戻る\"></a>\r\n  </div>\r\n  </header>\r\n\r\n\r\n    <main>\r\n\r\n      <div class=\"page_visual\">\r\n        <figure class=\"page_visual_bg\">\r\n          <picture>\r\n            <source media=\"(max-width:769px)\" srcset=\"../assets/img/personnel/personnel_top_sp.jpg 769w\" sizes=\"100vw\">\r\n            <img src=\"../assets/img/personnel/personnel_top.jpg\" alt=\"人事部からのメッセージ\">\r\n          </picture>\r\n        </figure>\r\n        <div class=\"page_visual_title\">\r\n          <figure class=\"title-line-data-small\">\r\n            <img src=\"../assets/img/title-line-small.png\" alt=\"トップ画像\">\r\n          </figure>\r\n          <h2>人事部からのメッセージ</h2>\r\n          <p>FROM <span>P</span>ERSONNEL <span>S</span>ECTION</p>\r\n        </div>\r\n      </div>\r\n\r\n\r\n      <section class=\"personnel_main\">\r\n        <div class=\"inner\">\r\n          <div class=\"personnel_catch\">\r\n            <h3 class=\"fade\">\r\n              <span>若手から活躍できる</span>会社で<br>\r\n              <span>新たな挑戦</span>をしてみませんか。\r\n            </h3>\r\n            <p class=\"fade\">\r\n              60年という歴史のなかで築き上げてきたお客様からの「信頼」がある会社、それがドギーマンハヤシです。ペットの衣食住すべての商品を取り扱い、その数は3,000種類超え。ペットライフに関するトータルのご提案ができるのも当社の大きな強みであり、先輩方がお客様と培ってきた信頼関係と多種多様な商品ラインナップを武器に、若手から活躍していただける土壌があります。\r\n            </p>\r\n            <p class=\"fade\">\r\n              業務における特長は、意思決定までのプロセスが短いこと。社長や上層部との距離も近いため、直接話せる機会も多く、スピード感を持って新たな挑戦をすることも可能です。また、個々のチャレンジを応援する社風も。若手だから、ベテランだからという枠組みはなく、「やってみたい」「変えたい」という強い意志があれば、「まずはやってみたら？」と背中を押してもらえます。\r\n            </p>\r\n          </div>\r\n\r\n          <div class=\"personnel_list\">\r\n            <ul>\r\n              <li class=\"fade\">\r\n                <figure class=\"leftin part1\">\r\n                  <img src=\"../assets/img/personnel/personnel_list01.jpg\" alt=\"女性社員の写真①\">\r\n                </figure>\r\n                <dl class=\"leftin part2\">\r\n                  <dt>若手社員の印象と求める人物像</dt>\r\n                  <dd>\r\n                    若手社員は素直な人が多く、「もっと知りたい」「学びたい」という意欲を持ちながら仕事に向き合っている人もたくさんいます。まさに、そんな社員が増えたらいいな、一緒に働きたいなと思いながら採用活動を進めています。<br>\r\n                    周りから言われたことをきちんと実行するだけではなく、1つひとつの物事に対して自ら考え、時には疑問を持ち、次の行動に移してみるというような「自主性」を持った方なら、当社で生き生きと働けるのではないでしょうか。\r\n                  </dd>\r\n                </dl>\r\n              </li>\r\n\r\n              <li class=\"fade\">\r\n                <figure class=\"rightin part3\">\r\n                  <img src=\"../assets/img/personnel/personnel_list02.jpg\" alt=\"女性社員の写真②\">\r\n                </figure>\r\n                <dl class=\"rightin part4\">\r\n                  <dt>ドギーマンハヤシで活躍できる人</dt>\r\n                  <dd>\r\n                    自主性や積極性を持ちながらも、その場の状況に応じて柔軟に対応できる人なら当社で活躍できるはずです。もちろん、ご自身がやってみたいこと、変えていきたいことに挑戦していただきたいですが、会社という組織では自分のやりたいことばかりできるわけではありません。時には周りに合わせながら、時には自らが先頭に立ちながら行動できる人。そんな方が当社で成長できると考えています。\r\n                  </dd>\r\n                </dl>\r\n              </li>\r\n            </ul>\r\n          </div>\r\n\r\n          <div class=\"personnel_message fade\">\r\n            <h3>採用担当者からのメッセージ</h3>\r\n            <div class=\"personnel_message_list\">\r\n              <ul>\r\n                <li>\r\n                  <figure>\r\n                    <img src=\"../assets/img/personnel/personnel_msg01.jpg\" alt=\"女性社員の写真①\">\r\n                  </figure>\r\n                  <p>就職面接では、ご自身の言葉で経験や考え、その時感じたことなどをしっかりと伝えていただきたいと思います。緊張されていても、普段のお人柄や表情などが見えると印象に残りやすいですよ。</p>\r\n                </li>\r\n                <li>\r\n                  <figure>\r\n                    <img src=\"../assets/img/personnel/personnel_msg02.jpg\" alt=\"女性社員の写真②\">\r\n                  </figure>\r\n                  <p>長い歴史や実績がありながらも、そこに奢ることなくチャレンジをし続ける会社がドギーマンハヤシです。当社で活躍してみたいと思う前向きな皆さんにお会いできるのを、とても楽しみにしております。</p>\r\n                </li>\r\n              </ul>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </section>\r\n\r\n    </main>\r\n\r\n\r\n\r\n    <footer>\r\n  <div class=\"inner\">\r\n    <dl class=\"short_btn_unit_sp\">\r\n          <dt>\r\n            <a href=\"https://doggyman-recruit.snar.jp/index.aspx\" target=\"_blank\" rel=\"noopener noreferrer\">ENTRY</a>\r\n          </dt>\r\n          <dd>\r\n            <a href=\"https://doggyman-recruit.snar.jp/login.aspx\" target=\"_blank\" rel=\"noopener noreferrer\">MY PAGE</a>\r\n          </dd>\r\n        </dl>\r\n        <dl class=\"short_btn_unit\">\r\n          <dt>\r\n            <a href=\"https://doggyman-recruit.snar.jp/index.aspx\" target=\"_blank\" rel=\"noopener noreferrer\">\r\n              <span>ENTRY</span>\r\n            </a>\r\n          </dt>\r\n          <dd>\r\n            <a href=\"https://doggyman-recruit.snar.jp/login.aspx\" target=\"_blank\" rel=\"noopener noreferrer\">\r\n              <span>MY PAGE</span>\r\n            </a>\r\n          </dd>\r\n        </dl>\r\n\r\n    <ul class=\"link\">\r\n      <li>\r\n        <h3><a href=\"../\">HOME</a></h3>\r\n      </li>\r\n      <li>\r\n        <h4><a>COMPANY</a></h4>\r\n        <a href=\"../message/\">社長メッセージ</a>\r\n        <a href=\"../pet_market/\">ペット市場の今</a>\r\n        <a href=\"../about-doggyman/\">キーワードで知るドギーマン</a>\r\n        <a href=\"../business/\">「提案型営業」と部門紹介</a>\r\n        <a href=\"../#understands\">ドギーマンは分かってくれる</a>\r\n      </li>\r\n      <li>\r\n        <h4><a>PEOPLE</a></h4>\r\n        <a href=\"../job/#interview_main\">社員インタビュー</a>\r\n        <a class=\"none\" href=\"../job/#top-talk-session\">トークセッション</a>\r\n        <a class=\"under\" href=\"../people/boss-subordinate/\">上司×部下</a>\r\n        <a class=\"under\" href=\"../people/development/\">食品開発×用品開発</a>\r\n        <a class=\"under\" href=\"../people/symposium/\">入社3〜4年目社員 座談会</a>\r\n      </li>\r\n      <li>\r\n        <h4><a>RECRUIT</a></h4>\r\n        <a href=\"../welfare/\">各種制度・福利厚生</a>\r\n        <a href=\"../personnel/\">人事部メッセージ</a>\r\n        <a href=\"../recruit-info/\">採用情報</a>\r\n        <a href=\"../faq/\">よくある質問</a>\r\n      </li>\r\n    </ul