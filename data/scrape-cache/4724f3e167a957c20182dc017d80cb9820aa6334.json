{"url":"https://www.mikuni.co.jp/corporate/brand/","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n<head prefix=\"og: http://ogp.me/ns# fb: http://ogp.me/ns/fb# article: http://ogp.me/ns/article#\">\n  <meta charset=\"UTF-8\">\n  <meta id=\"viewport\" name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n  <meta name=\"format-detection\" content=\"telephone=no\">\n  <title>ブランドメッセージ｜会社情報｜株式会社ミクニ</title>\n  <meta name=\"keywords\" content=\"MIKUNI,ミクニ,会社情報,ブランドメッセージ\">\n  <meta name=\"description\" content=\"ミクニのブランドメッセージをご紹介します。\">\n  <!--OGP-->\n  <meta property=\"og:title\" content=\"ブランドメッセージ\">\n  <meta property=\"og:type\" content=\"website\">\n  <meta property=\"og:description\" content=\"ミクニのブランドメッセージをご紹介します。\">\n  <meta property=\"og:url\" content=\"https://www.mikuni.co.jp/corporate/brand/\">\n  <meta property=\"og:image\" content=\"https://www.mikuni.co.jp/mikuni_OGP.png\">\n  <meta property=\"og:site_name\" content=\"株式会社ミクニ\">\n  <meta property=\"og:locale\" content=\"ja_JP\">\n  <!--//OGP-->\n  <link rel=\"alternate\" hreflang=\"ja\" href=\"https://www.mikuni.co.jp/corporate/brand/\">\n  <link rel=\"alternate\" hreflang=\"en\" href=\"https://www.mikuni.co.jp/en/corporate/brand/\">\n  <link rel=\"shortcut icon\" href=\"/favicon.ico\">\n  <link rel=\"apple-touch-icon\" href=\"/apple-touch-icon.png\">\n  <link rel=\"icon\" type=\"image/png\" href=\"/android-chrome-256x256.png\">\n  <script src=\"/js/brand.js\" defer></script>\n  <link rel=\"canonical\" href=\"https://www.mikuni.co.jp/corporate/brand/\">\n  <link rel=\"stylesheet\" href=\"/css/ress.css\" type=\"text/css\" media=\"all\">\n  <link rel=\"stylesheet\" href=\"/css/style.css\" type=\"text/css\" media=\"all\">\n  <link rel=\"stylesheet\" href=\"/css/corporate.css\" type=\"text/css\" media=\"all\">\n  <link href=\"https://fonts.googleapis.com/css?family=Oswald&display=swap\" rel=\"stylesheet\">\n  <!-- Global site tag (gtag.js) - Google Analytics -->\n  <script async src=\"https://www.go