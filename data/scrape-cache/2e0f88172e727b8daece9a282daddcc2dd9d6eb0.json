   \n\n    \n  </div>\n</header>\n<!-- end: l-header -->\n  <main id=\"container\" class=\"pages\">\n    <article>\n        <div class=\"c-titleblock\">\n          <div class=\"cont-wrap\">\n            <div class=\"c-cont__wrap\">\n                              <h1 class=\"c-titleblock__txt\">技術情報</h1>\n                          </div>\n          </div>\n        </div>\n\n        <div class=\"c-bread\">\n          <div class=\"cont-wrap\">\n            <div class=\"c-cont__wrap\">\n              <p id=\"breadcrumbs\"><span><span><a href=\"https://www.vitallead.co.jp/\">TOP</a></span> &gt; <span class=\"breadcrumb_last\" aria-current=\"page\">技術情報</span></span></p>            </div>\n          </div>\n        </div>\n\n\n              <div class=\"c-page\">\n          <div class=\"cont-wrap\">\n            <div class=\"c-cont__wrap u-page__wrap\">\n              <!-- 固定ページループ -->\n                              \n<p class=\"has-text-align-center fade-in fade-in-down mb48 wp-block-paragraph\">交通に関する技術力に関しては日本でもトップクラス。<br>交通計画やまちづくりにおけるバイタルリードの技術をご紹介します。</p>\n\n\n\n<h2 class=\"wp-block-heading page_title fade-in fade-in-left mb32\"><strong>技術情報</strong></h2>\n\n\n\n<h3 class=\"wp-block-heading head_wrap fade-in fade-in-down\"><strong>技術論文</strong></h3>\n\n\n\n<div class=\"wp-block-media-text is-stacked-on-mobile mb64\"><figure class=\"wp-block-media-text__media\"><picture><source  sizes='(max-width: 576px) 100vw, 576px' type=\"image/webp\" data-srcset=\"https://www.vitallead.co.jp/wp/wp-content/uploads/2024/09/technology-2-2.jpg.webp 576w, https://www.vitallead.co.jp/wp/wp-content/uploads/2024/09/technology-2-2-300x175.jpg.webp 300w\"><img fetchpriority=\"high\" decoding=\"async\" width=\"576\" height=\"336\" src=\"data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAkAAAAFQAQAAAAB/3/ydAAAAAnRSTlMAAHaTzTgAAAAuSURBVHja7cExAQAAAMKg9U/tbwagAAAAAAAAAAAAAAAAAAAAAAAAAAAAAACAN1/QAAGJBsyAAAAAAElFTkSuQmCC\" alt=\"\" class=\"wp-image-718 size-full lazyload\"   data-eio=\"p\" data-src=\"https://www.vitallead.co.jp/wp/wp-content/uploads/2024/09/technology-2-2.jpg\" data-srcset=\"https://www.vitallead.co.jp/wp/wp-content/uploads/2024/09/technology-2-2.jpg 576w, https://www.vitallead.co.jp/wp/wp-content/uploads/2024/09/technology-2-2-300x175.jpg 300w\" data-sizes=\"auto\" data-eio-rwidth=\"576\" data-eio-rheight=\"336\" /><noscript><img fetchpriority=\"high\" decoding=\"async\" width=\"576\" height=\"336\" src=\"https://www.vitallead.co.jp/wp/wp-content/uploads/2024/09/technology-2-2.jpg\" alt=\"\" class=\"wp-image-718 size-full\" srcset=\"https://www.vitallead.co.jp/wp/wp-content/uploads/2024/09/technology-2-2.jpg 576w, https://www.vitallead.co.jp/wp/wp-content/uploads/2024/09/technology-2-2-300x175.jpg 300w\" sizes=\"(max-width: 576px) 100vw, 576px\" data-eio=\"l\" /></noscript></picture></figure><div class=\"wp-block-media-text__content\">\n<p class=\"fade-in fade-in-down mb32 wp-block-paragraph\">バイタルリードでは高度な技術をお客様へ提供するにあたり、各学会、学会誌などにおいて論文等を発表しております。<br>論文等にまとめることにより、社内の知識・技術の体系化が図られ、さらに発表というアウトプットによって、知識・技術のさらなるインプットに繋がるよう図っています。</p>\n\n\n\n<div class=\"wp-block-buttons is-content-justification-center is-layout-flex wp-container-core-buttons-is-layout-fe48e5de wp-block-buttons-is-layout-flex\">\n<div class=\"wp-block-button has-custom-width wp-block-button__width-100 btn_block fade-in fade-in-up\"><a class=\"wp-block-button__link wp-element-button\" href=\"https://www.vitallead.co.jp/wp/technicalinfo/monograph/\">詳細はこちら</a></div>\n</div>\n</div></div>\n\n\n\n<h3 class=\"wp-block-heading head_wrap fade-in fade-in-down\"><strong>資格者一覧</strong></h3>\n\n\n\n<div class=\"wp-block-media-text is-stacked-on-mobile mb80\"><figure class=\"wp-block-media-text__media\"><picture><source  sizes='(max-width: 576px) 100vw, 576px' type=\"image/webp\" data-srcset=\"https://www.vitallead.co.jp/wp/wp-content/uploads/2024/09/qualification-2-2.jpg.webp 576w, https://www.vitallead.co.jp/wp/wp-content/uploads/2024/09/qualification-2-2-300x175.jpg.webp 300w\"><img decoding=\"async\" width=\"576\" height=\"336\" src=\"data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAkAAAAFQAQAAAAB/3/ydAAAAAnRSTlMAAHaTzTgAAAAuSURBVHja7cExAQAAAMKg9U/tbwagAAAAAAAAAAAAAAAAAAAAAAAAAAAAAACAN1/QAAGJBsyAAAAAAElFTkSuQmCC\" alt=\"\" class=\"wp-image-720 size-full lazyload\"   data-eio=\"p\" data-src=\"https://www.vitallead.co.jp/wp/wp-content/uploads/2024/09/qualification-2-2.jpg\" data-srcset=\"https://www.vitallead.co.jp/wp/wp-content/uploads/2024/09/qualification-2-2.jpg 576w, https://www.vitallead.co.jp/wp/wp-content/uploads/2024/09/qualification-2-2-300x175.jpg 300w\" data-sizes=\"auto\" data-eio-rwidth=\"576\" data-eio-rheight=\"336\" /><noscript><img decoding=\"async\" width=\"576\" height=\"336\" src=\"https://www.vitallead.co.jp/wp/wp-content/uploads/2024/09/qualification-2-2.jpg\" alt=\"\" class=\"wp-image-720 size-full\" srcset=\"https://www.vitallead.co.jp/wp/wp-content/uploads/2024/09/qualification-2-2.jpg 576w, https://www.vitallead.co.jp/wp/wp-content/uploads/2024/09/qualification-2-2-300x175.jpg 300w\" sizes=\"(max-width: 576px) 100vw, 576px\" data-eio=\"l\" /></noscript></picture></figure><div class=\"wp-block-media-text__content\">\n<p class=\"mb32 fade-in fade-in-down wp-block-paragraph\">高度な技術を提供していくには、技術資格者の存在は不可欠なものです。バイタルリードに在籍する資格者について一覧でご紹介いたします。<br>各種技術士はもちろんのこと、土木施工管理技士、測量士といった資格や、システム開発技術、旅行業等など、各資格の取得件数についても掲載しております。</p>\n\n\n\n<div class=\"wp-block-buttons is-content-justification-center is-layout-flex wp-container-core-buttons-is-layout-fe48e5de wp-block-buttons-is-layout-flex\">\n<div class=\"wp-block-button has-custom-width wp-block-button__width-100 btn_block fade-in fade-in-up\"><a class=\"wp-block-button__link wp-element-button\" href=\"https://www.vitallead.co.jp/wp/technicalinfo/qualified/\">詳細はこちら</a></div>\n</div>\n</div></div>\n\n\n\n<p class=\"wp-block-paragraph\"></p>\n                            <!-- 固定ページループここまで -->\n            </div>\n          </div>\n        </div>\n      \n    </article>\n  </main>\n  <!-- ▲ C