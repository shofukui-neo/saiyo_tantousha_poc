{"url":"https://site.awi.co.jp/recruit/recruit/alumni.html","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n<head>\n<!-- Google Tag Manager -->\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\n\tnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\n\tj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n\t'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n})(window,document,'script','dataLayer','GTM-N4DKX2CP');</script>\n<!-- End Google Tag Manager -->\n<meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\" />\n<meta name=\"keywords\" content=\"エア・ウォーター,airwater,新卒採用\" />\n<meta name=\"description\" content=\"エア・ウォーターの新卒（大学卒・大学院修了）採用情報です。\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1.0,minimum-scale=1.0\">\n<title>アルムナイ採用 | 採用サイト | エア・ウォーター株式会社</title>\n<!-- Google Tag Manager -->\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n})(window,document,'script','dataLayer','GTM-5WJXMST');</script>\n<!-- End Google Tag Manager -->\n<link rel=\"shortcut icon\" href=\"https://www.awi.co.jp/common/images/favicon.ico\" type=\"image/vnd.microsoft.icon\">\n<link rel=\"apple-touch-icon\" sizes=\"152x152\" href=\"https://www.awi.co.jp/common/images/apple-touch-icon.png\">\n\t\n<!-- 共通で使用するcssを読み込む -->\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../common/css/base.css\" media=\"all\" />\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../common/css/hacks.css\" media=\"all\" />\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../common/css/reset.css\" media=\"all\" />\n<link rel=\"stylesheet\" type=\"text/css\" href=\"css/alumni.css\" media=\"all\" />\n\n<!-- 共通で使用するjsを読み込む -->\n<script src=\"ht