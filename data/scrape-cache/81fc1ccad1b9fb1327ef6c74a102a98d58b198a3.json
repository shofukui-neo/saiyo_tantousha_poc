\n    <h3 class=\"title word\" v-show=\"action !== ''\">\n      <template v-if=\"!isReserve && isEvent\">開催月または</template>\n      フリーワードで探す\n    </h3>\n    <div :class=\"action === '' ? 'total-to-left' : 'total-to-right'\">\n      <template v-if=\"action === ''\">\n        <div class=\"total\">\n          <div>検索結果</div>\n          <div><span>416</span>社</div>\n        </div>\n      </template>\n      <ul class=\"list-filter\">\n        <li v-if=\"!isReserve && isEvent\" class=\"filter-em\">\n          <select name=\"em\" v-model=\"eventMonth\">\n            <option value=\"\">開催月 ▽</option>\n            <option value=\"last_month\" v-if=\"useLastMonth\">直近1ヶ月</option>\n            <option v-for=\"yearMonth in yearMonthList\" :value=\"yearMonth.value\">{{ yearMonth.label }}</option>\n          </select>\n        </li>\n        <li class=\"filter-keyword\">\n          <label>\n            <input v-model=\"keyword\" name=\"q\" placeholder=\"社名・キーワードで絞り込み\" type=\"text\"/>\n          </label>\n          <input\n            name=\"submit\"\n            placeholder=\"\"\n            type=\"submit\"\n            value=\"\"\n            :disabled=\"loading\"\n          />\n        </li>\n      </ul>\n      <template v-if=\"action !== '' && totalLabel !== ''\">\n        <div class=\"total\">{{ totalLabel }}<a :href=\"action\"><span>416</span>社</a></div>\n      </template>\n    </div>\n  </div>\n\n  <template v-if=\"useModal\">\n    <div class=\"section-conditions\">\n      <table>\n        <tbody>\n        <tr>\n          <th>現在の検索条件</th>\n          <td><span class=\"notyet\">検索条件なし</span></td>\n        </tr>\n        </tbody>\n      </table>\n      <button type=\"button\" class=\"csf-modal-open\" @click=\"handleShowModal()\"><span>＋条件で</span><span>絞り込む</span>\n      </button>\n    </div>\n  </template>\n\n  <Transition name=\"slide-fade\">\n    <div :class=\"[useModal ? 'csf-modal-contents' : 'csf-modeless-contents', isEvent ? 'event' : 'company']\" v-show=\"!useModal || showModal\">\n      <template v-if=\"useModal\">\n        <div class=\"csf-modal-header\">\n          <h3 class=\"csf-modal-title\">絞り込み条件の設定</h3>\n          <button type=\"button\" class=\"csf-modal-close\" @click=\"handleShowModal()\"></button>\n        </div>\n      </template>\n      <div :class=\"useModal ? 'csf-modal-inner' : ''\">\n        <!-- マスタ -->\n        <div class=\"section-master\">\n          <h3 class=\"title check\" v-show=\"!useModal\">各種条件から探す</h3>\n          <ul class=\"list-category\">\n            <li v-for=\"(category) in masters\"\n                :class=\"[`${category.key}`, selectedCategory === category.key ? 'select' : '']\"\n                @click=\"handleClickCategory(category.key)\">{{ category.title }}\n            </li>\n          </ul>\n          <div\n            v-for=\"(category) in masters\"\n            :class=\"['groups', area ? 'area' : '', `${category.key}`, selectedCategory === category.key ? 'select' : '']\"\n          >\n            <ul class=\"list-group\">\n              <li v-for=\"(group) in conditionMasterGroup(category)\"\n                  :class=\"[`${category.key}-${group.id}`, selectedGroup[category.key] === group.id ? 'select' : '']\"\n                  @click=\"handleClickGroup(category.key, group.id)\">{{ group.title }}\n              </li>\n            </ul>\n            <div\n              v-for=\"(group) in conditionMasterGroup(category)\"\n              :class=\"['group', `${category.key}-${group.id}`, selectedGroup[category.key] === group.id ? 'select' : '']\"\n            >\n              <!-- AND検索 -->\n              <template v-if=\"andCategory.includes(category.key)\">\n                <div class=\"and-or\">\n                  <label class=\"radio\">\n                    <input\n                      type=\"radio\"\n                      :checked=\"andChecked[category.key] === 0\"\n                      @click=\"handleRadioOr(category.key)\"\n                    >\n                    <span>選択した条件のいずれかに一致</span>\n                  </label>\n                  <label class=\"radio\">\n                    <input\n                      type=\"radio\"\n                      :checked=\"andChecked[category.key] === 1\"\n                      @click=\"handleRadioAnd(category.key)\"\n                    >\n                    <span>選択した条件のすべてに一致</span>\n                  </label>\n                </div>\n              </template>\n              <h4 class=\"title\">{{ group.title }}</h4>\n              <label class=\"checkbox all\">\n                <input\n                  type=\"checkbox\"\n                  :checked=\"~getAllSelectedGroupIndex(category.key, group.id)\"\n                  @click=\"handleSelectGroupAll(category.key, group.id)\"\n                >\n                <span>{{ group.title }}すべて</span>\n              </label>\n              <div class=\"items\">\n                <label v-for=\"(item) in group.items\" class=\"checkbox item\">\n                  <input\n                    type=\"checkbox\"\n                    v-model=\"filter[category.key]\"\n                    :name=\"`${category.key}[]`\"\n                    :value=\"item.id\"\n                    :checked=\"getSelectItemIndex(category.key, item.id)\"\n                    @click=\"handleSelectItem(category.key, group.id, item.id)\"\n                  >\n                  <span>{{ item.name }}</span>\n                </label>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"custom-search-form-footer\">\n          <!-- 満員・受付終了イベント -->\n          <div class=\"closed-event\" v-if=\"isEvent\">\n            <div class=\"closed-event-inner\">\n              <label class=\"checkbox ce\">\n                <input\n                  type=\"checkbox\"\n                  v-model=\"getClosedEventMode\"\n                  :class=\"`checkbox-${getClosedEventMode}`\"\n                  :name=\"getClosedEventMode\"\n                  :value=\"1\"\n                  :checked=\"isSelectClosedEvent()\"\n                  @click=\"handleClosedEvent()\"\n                >\n                <span>{{ `${closedEvent[getClosedEventMode].title}` }}</span>\n              </label>\n            </div>\n          </div>\n          <!-- ボタン類 -->\n          <div class=\"buttons\">\n            <div class=\"button-submit-wrapper\">\n              <button type=\"submit\" :disabled=\"loading\">検索結果を見る <span>{{ preTotal }}件</span></button>\n            </div>\n            <div class=\"button-reset-wrapper\">\n              <button type=\"reset\" :disabled=\"loading\" @click.prevent=\"handleClear\">条件をすべて<br class=\"sp\">クリア\n              </button>\n            </div>\n          </div>\n          <template v-if=\"andCategory\">\n            <input type=\"hidden\" name=\"and[]\" :value=\"filter.and\">\n          </template>\n        </div>\n      </div>\n    </div>\n  </Transition>\n\n  <Teleport to=\"body\" :disabled=\"!useModal\">\n    <template v-if=\"useModal && showModal\">\n      <div class=\"csf-modal-overlay\"></div>\n    </template>\n  </Teleport>\n</form>\n    </div>\n    <script>\n        customSearchForm('#search-company', {\n            TYPE: 'company-pre',\n            YEAR: '2028',\n            USE: ['bt', 'oc', 'fe'],\n            AND: ['fe'],\n            ACTION: 'search/list_result.html'\n        })\n    </script>\n    <script setup></script>\n</div>\n\n\n\n        \n\n\n        <!--　ページTOPタブ　-->\n<!--　▼　ページトップ　タブ　▼　-->\n<div id=\"pagetop\">\n\t<div class=\"gotop\">\n\t\t<a href=\"#\"><i class=\"fa-solid fa-circle-chevron-up\"></i></a>\n\t</div>\n</div>\n<!--　▲　ページトップ　タブ　▲　-->\n\n        <!--　▼検索ページバナー　▼　--> \n<div id=\"bottom_bannerxb2\">\n    <ul id=\"imgbanner\" v-if=\"total > 0\" :class=\"[loading && 'loading']\">\n  <li v-for=\"visual in visuals\" :class=\"[visual.type]\">\n    <a :href=\"visual.url\" :target=\"visual.target\" v-on:click=\"handleClick(visual.banner_id)\">\n      <img :src=\"visual.src\" :alt=\"vis