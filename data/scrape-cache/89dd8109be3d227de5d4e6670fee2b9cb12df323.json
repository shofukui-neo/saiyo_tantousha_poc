{"url":"https://tohoku-daiken.co.jp/recruit/entry/","html":"\n\n<!DOCTYPE html>\n<html>\n<head>\n  \n\n\n<!-- Google Tag Manager -->\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n})(window,document,'script','dataLayer','GTM-TM7DPN8');</script>\n<!-- End Google Tag Manager -->\n\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width,user-scalable=no,maximum-scale=1\" />\n<title>秋田の総合ビルメンテンナンス会社 | 株式会社秋田東北ダイケン</title>\n<meta name=\"description\" content=\"株式会社秋田東北ダイケンは、地域とともに豊かさを創造する建物の総合管理企業です。\">\n<meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\">\n<meta http-equiv=\"content-language\" content=\"ja\">\n<meta name=\"format-detection\" content=\"telephone=no\">\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\"/>\n<meta property=\"og:title\" content=\"秋田の総合ビルメンテンナンス会社 | 株式会社秋田東北ダイケン\" />\n<meta property=\"og:type\" content=\"website\" />\n<meta property=\"og:url\" content=\"https://tohoku-daiken.co.jp/\" />\n<meta property=\"og:image\" content=\"/assets/images/og/og.jpg\" />\n<meta property=\"og:site_name\" content=\"秋田の総合ビルメンテンナンス会社 | 株式会社秋田東北ダイケン\" />\n<meta property=\"og:description\" content=\"株式会社秋田東北ダイケンは、地域とともに豊かさを創造する建物の総合管理企業です。\" />\n<meta name=\"twitter:card\" content=\"summary\" />\n<meta name=\"twitter:title\" content=\"秋田の総合ビルメンテンナンス会社 | 株式会社秋田東北ダイケン\" />\n<meta name=\"twitter:description\" content=\"株式会社秋田東北ダイケンは、地域とともに豊かさを創造する建物の総合管理企業です。\" />\n<meta name=\"twitter:image\" content=\"/assets/images/og/og.jpg\" />\n<meta itemprop=\"image\" content=\"/assets/images/og/og.jpg\" />\n<link rel=\"canonical\" href=\"https://tohoku-daiken.co.jp/\">\n<link rel=\"shortcut icon\" href=\"/favicon.ico\">\n<link rel=\"apple-touch-icon-precomposed\" href=\"/assets/images/og/icon180x180.png\" />\n<link rel=\"icon\" href=\"/assets/images/og/icon192x192.png\" sizes=\"192x192\" />\n<link rel=\"stylesheet preconnect dns-prefetch\" href=\"/assets/css/style.min.css?ver101\">\n<link rel=\"preconnect dns-prefetch\" href=\"https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@100;300;400;500;700;900&family=Ubuntu:wght@300;400;500;700&display=swap\">\n  <link rel=\"stylesheet\" href=\"/assets/js/modal-video/css/modal-video.min.css\">\n</head>\n\n<body id=\"ja\">\n  \n<!-- Google Tag Manager (noscript) -->\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-TM7DPN8\"\n  height=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n  <!-- End Google Tag Manager (noscript) -->\n  \n\n<div class=\"_loaderFilm\"></div>\n\n\n<header id=\"HEADER\" class=\"class=\"_home\"\" >\n  <div class=\"_topCo\">\n    <div class=\"_inner\" id=\"HEAD-IN\">\n      <div class=\"_columnLeft\">\n        <p class=\"_logo\">\n          <a href=\"/\"><img src=\"/assets/images/common/logo_color_01.png\" alt=\"秋田東北ダイケン\" id=\"HEAD-LOGO\"></a>\n        </p>\n                  <h1 class=\"des\">総合ビルメンテナンス業なら<br />株式会社 秋田東北ダイケン</h1>\n              </div>\n\n      <div class=\"_columnRight\">\n        <p class=\"_tel\"><i><img src=\"/assets/images/common/ico_phone_black_01.svg\" alt=\"電話\"></i><span>018-832-0401</span><br />受付時間／8:30〜17:30</p>\n        <p class=\"_download\">\n          <a href=\"/download/\"><span>指定請求書様式ダウンロード</span></a>\n        </p>\n        <p class=\"_contact _cm_button\">\n          <a href=\"/contact/\"><span>お問い合わせ</span></a>\n        </p>\n      </div>\n    </div>\n\n    <div class=\"_gnav\" id=\"GNAV\">\n      <div class=\"_gnv-inner\">\n        <nav>\n\n          <ul>\n            <li><a href=\"/\"><span><img src=\"/assets/images/common/ico_home_blue_01.svg\" alt=\"HOME\" /></span><span>HOME</span></a></li>\n            <li><a href=\"/information/\"><span>お知らせ</span></a></li>\n            <li><a href=\"/elected/\"><span>選ばれる理由</span></a></li>\n            <li class=\"_menu\">\n              <a href=\"/works/\"><span>事業内容</span></a>\n              <div class=\"_megaMenu\">\n                <div class=\"_inner\">\n                  <div>\n                    <a href=\"/works/maintenance/\">\n                      <figure>\n                        <img src=\"/assets/images/common/mega_works_img_01.jpg\" alt=\"\">\n                      </figure>\n                      <p class=\"_en\">Maintenance</p>\n                      <p class=\"_jp\">ビルメンテナンス事業</p>\n                    </a>\n                  </div>\n                  <div>\n                    <a href=\"/works/engineering/\">\n                      <figure>\n                        <img src=\"/assets/images/common/mega_works_img_02.jpg\" alt=\"\">\n                      </figure>\n                      <p class=\"_en\">Engineering / Energy saving</p>\n                      <p class=\"_jp\">エンジニアリング・省エネ事業</p>\n                    </a>\n                  </div>\n                  <div>\n                    <a href=\"/works/administrator/\">\n                      <figure>\n                        <img src=\"/assets/images/common/mega_works_img_03.jpg\" alt=\"\">\n                      </figure>\n                      <p class=\"_en\">Designated Administrator</p>\n                      <p class=\"_jp\">指定管理者事業</p>\n                    </a>\n                  </div>\n                </div>\n              </div>\n            </li>\n            <li><a href=\"/aboutus/\"><span>私たちについて</span></a></li>\n\n            <!--<li><a href=\"/csr/\"><span>取り組み</span></a></li>-->\n            <li><a href=\"/group/\"><span>グループ会社</span></a></li>\n            <li><a href=\"/recruit/\"><span>採用情報</span></a></li>\n          </ul>\n        </nav>\n      </div>\n    </div>\n\n\n  </header>\n  <div id=\"NAVI-BUTTON\" class=\"navi__button\">\n  <div class=\"nbInner\">\n    <i></i>\n  </div>\n</div>\n\n<nav id=\"SP__MENU\" class=\"slide_menu\">\n\n  <div class=\"menu_inner\">\n    <div>\n      <p class=\"_tel\"><span><i><img src=\"/assets/images/common/ico_phone_black_01.svg\" /></i>018-832-0401</span><br />受付時間／9:00〜18:00</p>\n      <p class=\"_download\">\n        <a href=\"/download/\"><span>指定請求書様式ダウンロード</span></a>\n      </p>\n      <p class=\"_contact\">\n        <a href=\"/contact/\"><span>お問い合わせ</span></a>\n      </p>\n      <ul>\n        <li><a href=\"/information/\"><span>お知らせ</span></a></li>\n        <li><a href=\"/elected/\"><span>選ばれる理由</span></a></li>\n        <li><a href=\"/works/\" class=\"_accordion\">\n          <span>事業内容</span></a>\n          <div>\n            <ul>\n              <li><a href=\"/works/maintenance/\"><span>ビルメンテナンス事業</span></a></li>\n              <li><a href=\"/works/engineering/\"><span>エンジニアリング・省エネ事業</span></a></li>\n              <li><a href=\"/works/administrator/\"><span>指定管理者事業</span></a></li>\n            </ul>\n          </div>\n        </li>\n        <li><a href=\"/aboutus/\"><span>私たちについて</span></a></li>\n        <!--<li><a href=\"/csr/\"><span>取り組み</span></a></li>-->\n        <li><a href=\"/group/\"><span>グループ会社</span></a></li>\n        <li><a href=\"/recruit/\"><span>採用情報</span></a></li>\n      </ul>\n    </div>\n  </div>\n</nav>\n  <div class=\"wrappar\" id=\"HOME\">\n    <main>\n\n      <div class=\"_mv\" id=\"TOP-MV\">\n        <div class=\"_scroll\" id=\"SCROLL\">\n          <p>scroll</p>\n          <div class=\"_allow\"></div>\n        </div>\n        <div class=\"_text\">\n          <div class=\"_en\" id=\"TEXT-EN\">\n            <p><i id=\"TXT-FILM1\"></i><i id=\"TXT-FILM1-1\"></i><span id=\"MT-TXT1\">Imagine</span></p>\n            <p><i id=\"TXT-FILM2\"></i><i id=\"TXT-FILM2-1\"></i><span id=\"MT-TXT2\">Abundance</span></p>\n          </div>\n          <div class=\"_jp\" id=\"MV-TXT-JP\">\n            <h2><span>地域とともに豊かさを創造する</span></h2>\n            <h2><span>建物の総合管理企業</span></h2>\n          </div>\n        </div>\n        <div class=\"_back\">\n\n          <figure>\n            <div id=\"FILM1\"></div>\n            <i class=\"ppLazyBg\" data-bg=\"/assets/images/top/top_mv.jpg\" class=\"pc-non\" id=\"SP-BACK\"></i>\n          <video muted id=\"MV-VIDEO\" src=\"/assets/video/top_mv.mp4\" poster=\"/assets/images/top/movie_bg.png\" playsinline loop></video>\n        </figure>\n      </div>\n\n      <div class=\"_mvInfo mb-slideInBottom\">\n        <div class=\"_cm_shadow\">\n        <p><a href=\"/information\">お知らせを更新しました</a></p>\n        <!-- \n                                <p><a href=\"https://tohoku-daiken.co.jp/information/138\">福利厚生ページを公開いたしました</a></p>\n                            -->\n        </div>\n      </div>\n    </div>\n\n    <div class=\"_topConcept\" id=\"TOP-CONCEPT\">\n      <div class=\"_bg\">\n        <img src=\"/assets/images/top/top_concept_prt_01.svg\" alt=\"\">\n      </div>\n      <div class=\"_inner mb-slideInBottom\">\n        <div class=\"_image\">\n          <figure>\n            <i class=\"ppLazyBg\" data-bg=\"/assets/images/top/top_concept_img_01.jpg\"></i>\n          </figure>\n\n          <div class=\"_movie\">\n            <a href=\"#modal\">\n              <div class=\"_img\">\n                <i><img src=\"/assets/images/common/prt_play_white_01.svg\" alt=\"\"></i>\n                <figure>\n                  <img src=\"/assets/images/top/top_concept_img_02.jpg\" alt=\"\">\n                </figure>\n              </div>\n              <p><span>Concept Movie</span><i><img src=\"/assets/images/common/prt_arrow_black_01.svg\" /></i></p>\n            </a>\n\n          </div>\n        </div>\n        <div class=\"_text\">\n          <p class=\"_en\">Concept</p>\n          <h2>\n            安心・安全と確かな技術で<br />\n            大事な資産をお守りいたします\n          </h2>\n          <p class=\"_des\">\n            総合ビルメンテナンスを主の業務とし、50年以上の培った技術と多数の実績でお客様の大切な資産を守り続けてきました。\n          </p>\n        </div>\n      </div>\n\n      <div class=\"_topConceptCo mb-slideInBottom\">\n        <div>\n          <p class=\"_prt\"><img src=\"/assets/images/common/prt_num_p1_01.svg\" alt=\"01\"></p>\n          <p class=\"_en\">TECHNOLOGY</p>\n          <h3>確かな技術</h3>\n          <figure>\n            <img src=\"/assets/images/top/top_concept_img_03.jpg\" alt=\"\">\n          </figure>\n          <p class=\"_des\">50年を超え培ったノウハウと技術で、あなたの建物をまるごとサポート。</p>\n        </div>\n\n        <div class=\"\">\n          <p class=\"_prt\"><img src=\"/assets/images/common/prt_num_p1_02.svg\" alt=\"02\"></p>\n          <p class=\"_en\">ACHIEVEMENT</p>\n          <h3>多数の実績</h3>\n          <figure>\n            <img src=\"/assets/images/top/top_concept_img_04.jpg\" alt=\"\">\n          </figure>\n          <p class=\"_des\">400以上の確かな実績。多様なシーンで大切な資産を守ります。</p>\n        </div>\n\n        <div class=\"\">\n          <p class=\"_prt\"><img src=\"/assets/images/common/prt_num_p1_03.svg\" alt=\"03\"></p>\n          <p class=\"_en\">QUALITY</p>\n          <h3>トップクラスの品質</h3>\n          <figure>\n            <img src=\"/assets/images/top/top_concept_img_05.jpg\" alt=\"\">\n          </figure>\n          <p class=\"_des\">安心・安全と確かな技術で、新しいシステムのご提案が可能です。</p>\n        </div>\n      </div>\n\n      <div class=\"_topConceptAchievement\">\n        <div class=\"_in mb-slideInBottom\">\n          <div class=\"_cm_shadow\">\n            <i>※1</i>\n            <p class=\"_prt\">\n              <img src=\"/assets/images/common/ico_hospital_black.svg\" alt=\"\">\n            </p>\n            <h2><span>病院管理</span></h2>\n            <p class=\"_en\">HOSPITAL</p>\n            <p class=\"_num\"><span>20</span>件以上</p>\n          </div>\n          <div class=\"_cm_shadow\">\n            <i>※1</i>\n            <p class=\"_prt\">\n              <img src=\"/assets/images/common/ico_buil_black.svg\" alt=\"\">\n            </p>\n            <h2><span>オフィスビル<br />商業施設管理</span></h2>\n            <p class=\"_en\">BUILDING</p>\n            <p class=\"_num\"><span>55</span>件以上</p>\n          </div>\n          <div class=\"_cm_shadow\">\n            <i>※1</i>\n            <p class=\"_prt\">\n              <img src=\"/assets/images/common/ico_dril_black.svg\" alt=\"\">\n            </p>\n            <h2><span>各種工事</span></h2>\n            <p class=\"_en\">BUILDING</p>\n            <p class=\"_num\"><span>380</span>件</p>\n          </div>\n          <div class=\"_cm_shadow\">\n            <i>※2</i>\n            <p class=\"_prt\">\n              <img src=\"/assets/images/common/ico_prak_black.svg\" alt=\"\">\n            </p>\n            <h2><span>指定管理</span></h2>\n            <p class=\"_en\">ADMINISTRATOR</p>\n            <p class=\"_num\"><span>10</span>件</p>\n          </div>\n        </div>\n\n        <div class=\"_caution\">\n          <p>※1 過去5年の実績 ※2 令和4年の実績</p>\n        </div>\n\n        <div class=\"_cm_button\">\n          <a href=\"/elected/\"><span>選ばれる理由</span><i><img src=\"/assets/images/common/prt_arrow_white_01.svg\" /></i></a>\n        </div>\n\n      </div>\n    </div>\n\n    <div class=\"_topWorks\" id=\"TOP-WORKS\">\n      <div class=\"_cm_coBg ppLazyBg\" data-bg=\"/assets/images/top/top_works_bg.jpg\"></div>\n\n      <div class=\"_cm_coTitle mb-slideInBottom\">\n        <p>WORKS</p>\n        <h2>事業内容</h2>\n      </div>\n\n      <div class=\"_worksContents\">\n        <div class=\"_contents\">\n          <div class=\"_imgField\">\n            <figure>\n              <i class=\"ppLazyBg\" data-bg=\"/assets/images/top/top_works_img_01.jpg\"></i>\n            </figure>\n          </div>\n          <div class=\"_txtField\">\n            <i class=\"_prt\"><img src=\"/assets/images/common/prt_num_p2_01.svg\" /></i>\n            <p class=\"_en\">Maintenance</p>\n            <h3>ビルメンテナンス事業</h3>\n            <p class=\"_des\">\n              ビルメンテナンス事業は、建築物を長持ちさせ、財産・資産を守るだけでなく、様々な人が利用する建築物の安全と衛生的な環境を確保し、快適な空間を創り、生命・健康を守る大切な業務です。\n            </p>\n            <div class=\"_workco\">\n              <p>\n                清掃業務／警備業務／ホテル管理／設備保守管理・環境衛生管理／ビル群遠隔監視　etc…\n              </p>\n            </div>\n            <div class=\"_cm_button_type2\">\n              <a href=\"/works/maintenance\"><span class=\"_text\">詳しくはこちら</span><span class=\"_arrow\"><img src=\"/assets/images/common/prt_arrow_blue_01.svg\" /></span></a>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"_contents _reverse\">\n          <div class=\"_imgField\">\n            <figure>\n              <i class=\"ppLazyBg\" data-bg=\"/assets/images/top/top_works_img_02.jpg\"></i>\n            </figure>\n          </div>\n          <div class=\"_txtField\">\n            <i class=\"_prt\"><img src=\"/assets/images/common/prt_num_p2_02.svg\" /></i>\n            <p class=\"_en\">Engineering / Energy saving</p>\n            <h3>エンジニアリング・省エネ事業</h3>\n            <p class=\"_des\">\n              建物の維持管理に伴う各種工事や、各種法定点検の有資格者が点検業務をはじめ不具合箇所の改修まで請け負います。<br />\n              省エネと快適さを両立させるリノベーション、小さな部品交換から大規模な改修工事まで、経験豊富なスタッフがお客様のニーズにお応えします。\n            </p>\n            <div class=\"_workco\">\n              <p>\n                電気工事／空調設備設置（更新）工事／内装工事／給排水衛生設備工事／建築物及び設備機器の補修工事 etc…\n              </p>\n            </div>\n            <div class=\"_cm_button_type2\">\n              <a href=\"/works/engineering/\"><span class=\"_text\">詳しくはこちら</span><span class=\"_arrow\"><img src=\"/assets/images/common/prt_arrow_blue_01.svg\" /></span></a>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"_contents\">\n          <div class=\"_imgField\">\n            <figure>\n              <i class=\"ppLazyBg\" data-bg=\"/assets/images/top/top_works_img_03.jpg\"></i>\n            </figure>\n          </div>\n          <div class=\"_txtField\">\n            <i class=\"_prt\"><img src=\"/assets/images/common/prt_num_p2_03.svg\" /></i>\n            <p class=\"_en\">Designated Administrator</p>\n            <h3>指定管理者事業</h3>\n            <p class=\"_des\">\n              様々な運営実績から、豊富な運営ノウハウが蓄積されております。施設管理のプロフェッショナルとして、安全で快適な施設環境の提供が可能です。地域の皆様に親しまれる施設づくりを目指します。\n            </p>\n            <div class=\"_workco\">\n              <p>\n                道の駅／温泉施設／クルーズ船受入業務 etc…\n              </p>\n            </div>\n            <div class=\"_cm_button_type2\">\n              <a href=\"/works/administrator/\"><span class=\"_text\">詳しくはこちら</span><span class=\"_arrow\"><img src=\"/assets/images/common/prt_arrow_blue_01.svg\" /></span></a>\n            </div>\n          </div>\n        </div>\n\n        <!--\n        <div class=\"_cm_button\">\n        <a href=\"#\"><span>その他事業はこちら</span><i><img src=\"/assets/images/common/prt_arrow_white_01.svg\" /></i></a>\n      </div>\n    -->\n  </div>\n</div>\n\n\n<div class=\"_topAbout\" id=\"TOP-ABOUT\">\n  <div class=\"_cm_coBg ppLazyBg\" data-bg=\"/assets/images/top/top_about_bg.jpg\"></div>\n\n  <div class=\"_cm_coTitle mb-slideInBottom\">\n    <p>ABOUT US</p>\n    <h2>私たちについて</h2>\n  </div>\n\n  <div class=\"_aboutContents\">\n    <div class=\"_contents\">\n      <div class=\"_imgField\">\n        <figure>\n          <i class=\"ppLazyBg\" data-bg=\"/assets/images/top/top_about_img_01.jpg\"></i>\n        </figure>\n      </div>\n      <div class=\"_txtField\">\n        <h3>\n          地域社会の豊かさを<br />創造する企業へ\n        </h3>\n        <p class=\"_des\">\n          建物総合管理業のリーディングカンパニーとして、50年以上歩み続けてきました。ビルメンテナンス事業をはじめ、建物関連工事等、事業を広げてきました。\n        </p>\n\n        <div class=\"_cm_sdgs\">\n          <figure>\n            <img src=\"/assets/images/common/bnr_sdgs_color_01.jpg\" alt=\"\">\n          </figure>\n          <p>\n            秋田東北ダイケンは<br />\n            秋田県SDGsパートナーです\n          </p>\n        </div>\n      </div>\n    </div>\n  </div>\n  <div class=\"_aboutNav_v2\">\n    <div class=\"_cm_button\">\n      <a href=\"/aboutus/#GREETING\"><span>代表メッセージ</span><i><img src=\"/assets/images/common/prt_arrow_white_01.svg\" /></i></a>\n    </div>\n    <div class=\"_cm_button\">\n      <a href=\"/aboutus/#COMPANYINFO\"><span>企業情報</span><i><img src=\"/assets/images/common/prt_arrow_white_01.svg\" /></i></a>\n    </div>\n  </div>\n\n  <!--\n  <div class=\"_aboutNav\">\n  <div>\n  <figure>\n  <img src=\"/assets/images/top/top_about_img_02.jpg\" alt=\"\">\n</figure>\n\n<div class=\"_cm_button_type2\">\n<a href=\"/aboutus/#GREETING\"><span class=\"_text\"><b>MESSAGE</b><br />代表メッセージ</span><span class=\"_arrow\"><img src=\"/assets/images/common/prt_arrow_blue_01.svg\" /></span></a>\n</div>\n</div>\n\n<div>\n<figure>\n<img src=\"/assets/images/top/top_about_img_03.jpg\" alt=\"\">\n</figure>\n\n<div class=\"_cm_button_type2\">\n<a href=\"/aboutus/#COMPANYINFO\"><span class=\"_text\"><b>COMPANY</b><br />企業情報・沿革</span><span class=\"_arrow\"><img src=\"/assets/images/common/prt_arrow_blue_01.svg\" /></span></a>\n</div>\n</div>\n\n<div>\n<figure>\n<img src=\"/assets/images/top/top_about_img_04.jpg\" alt=\"\">\n</figure>\n\n<div class=\"_cm_button_type2\">\n<a href=\"#\"><span class=\"_text\"><b>CSR</b><br />取り組み</span><span class=\"_arrow\"><img src=\"/assets/images/common/prt_arrow_blue_01.svg\" /></span></a>\n</div>\n</div>\n</div>\n-->\n\n</div>\n\n<div class=\"_topNews\" id=\"TOP-INFO\">\n  <i>\n    <img src=\"/assets/images/top/top_info_prt_01.svg\" alt=\"\">\n  </i>\n  <div class=\"_inner\">\n    <div class=\"_title\">\n      <h3>\n        <span>INFORMATION</span><br />お知らせ\n      </h3>\n    </div>\n\n    <div class=\"_lists\">\n\n                            <a href=\"https://tohoku-daiken.co.jp/information/168\">\n          <div>\n            <p class=\"_cate _news\">お知らせ</p>\n            <p class=\"_date\">2026.03.16</p>\n          </div>\n          <p class=\"_text\">「秋田市元気な子どものまちづくり企業」として認定を受けました</p>\n        </a>\n                      <a href=\"https://tohoku-daiken.co.jp/information/161\">\n          <div>\n            <p class=\"_cate _news\">お知らせ</p>\n            <p class=\"_date\">2025.05.13</p>\n          </div>\n          <p class=\"_text\">増資のお知らせ</p>\n        </a>\n                      <a href=\"https://tohoku-daiken.co.jp/information/152\">\n          <div>\n            <p class=\"_cate _news\">お知らせ</p>\n            <p class=\"_date\">2025.03.07</p>\n          </div>\n          <p class=\"_text\">社長逝去に伴う社長交代について</p>\n        </a>\n                      <a href=\"https://tohoku-daiken.co.jp/information/138\">\n          <div>\n            <p class=\"_cate _uncategorized\">未分類</p>\n            <p class=\"_date\">2024.09.11</p>\n          </div>\n          <p class=\"_text\">福利厚生ページを公開いたしました</p>\n        </a>\n                </div>\n  </div>\n\n</div>\n\n</main>\n\n<!-- モーダルに出てくる内容 -->\n<div class=\"remodal\" data-remodal-id=\"modal\">\n  <!-- クローズボタン -->\n  <button data-remodal-action=\"close\" class=\"remodal-close\"></button>\n  <div class=\"_video\">\n    <video loop playsinline controls id=\"BRAND-VIDEO\"><source src=\"/assets/video/video_cbr2.mp4\" type=\"video/mp4\"></video>\n    </div>\n  </div>\n  \n\n<footer>\n  <div class=\"_bg\"></div>\n  <div class=\"_rowTop _footerContents\">\n    <p>\n      <img src=\"/assets/images/common/logo_color_01.png\" alt=\"秋田東北ダイケン\">\n    </p>\n    <nav>\n      <ul>\n        <li><a href=\"/information/\"><span>お知らせ</span></a></li>\n        <li><a href=\"/elected/\"><span>選ばれる理由</span></a></li>\n        <li><a href=\"/works/\"><span>事業内容</span></a></li>\n        <li><a href=\"/aboutus/\"><span>私たちについて</span></a></li>\n        <!--<li><a href=\"/csr/\"><span>取り組み</span></a></li>-->\n        <li><a href=\"/group/\"><span>グループ会社</span></a></li>\n        <li><a href=\"/recruit/\"><span>採用情報</span></a></li>\n      </ul>\n    </nav>\n  </div>\n  <div class=\"_rowBottom _footerContents\">\n    <div>\n      <h2>秋田本社</h2>\n      <div>\n        <p>\n          〒010-0001<br />\n          秋田市中通2-2-32 山二ビル\n        </p>\n        <p>\n          TEL /018-832-0401<br />\n          FAX /018-832-8699\n        </p>\n      </div>\n    </div>\n\n    <div>\n      <h2>青森営業所</h2>\n      <div>\n        <p>\n          〒030-0861<br />\n          青森市長島2-25-1 太陽生命青森ビル\n        </p>\n   