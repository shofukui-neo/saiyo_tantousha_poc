ine.html\"\n              target=\"_blank\"\n              ><img src=\"images/navi/navi_my.png\"\n            /></a>\n          </li>\n          <li style=\"margin: 0px 0px 0px 50px\">\n            <a href=\"https://works.do/R/ti/p/saiyo@nishi-tc\" target=\"_blank\"\n              ><img src=\"images/navi/QRcode.png\"\n            /></a>\n          </li>\n        </ul>\n      </div>\n      <nav class=\"global_menu\">\n        <ul>\n          <li class=\"menu\"><a href=\"index.html\">採用トップ</a></li>\n          <li class=\"menu\">\n            <a href=\"#\">メッセージ</a>\n            <ul class=\"child_menu\">\n              <p class=\"navi_komidashi\">先輩社員からのメッセージ</p>\n              <li>\n                <a href=\"./voice01.html\"\n                  ><img src=\"images/navi/navi01.png\" class=\"icon_photo\" /><span\n                    class=\"navi_txt\"\n                    >調査部 防災設計</span\n                  ></a\n                >\n              </li>\n              <li>\n                <a href=\"./voice02.html\"\n                  ><img src=\"images/navi/navi02.png\" class=\"icon_photo\" /><span\n                    class=\"navi_txt\"\n                    >設計部 道路設計</span\n                  ></a\n                >\n              </li>\n              <li>\n                <a href=\"./voice03.html\"\n                  ><img src=\"images/navi/navi03.png\" class=\"icon_photo\" /><span\n                    class=\"navi_txt\"\n                    >調査部 地質調査</span\n                  ></a\n                >\n              </li>\n              <li>\n                <a href=\"./voice05.html\"\n                  ><img src=\"images/navi/navi04.png\" class=\"icon_photo\" /><span\n                    class=\"navi_txt\"\n                    >地籍調査部</span\n                  ></a\n                >\n              </li>\n              <li>\n                <a href=\"./voice06.html\"\n                  ><img src=\"images/navi/navi05.png\" class=\"icon_photo\" /><span\n                    class=\"navi_txt\"\n                    >測量調査部<br />補償コンサルタント</span\n                  ></a\n                >\n              </li>\n              <li>\n                <a href=\"./voice04.html\"\n                  ><img src=\"images/navi/navi06.png\" class=\"icon_photo\" /><span\n                    class=\"navi_txt\"\n                    >企画管理部 営業</span\n                  ></a\n                >\n              </li>\n\n              <p class=\"navi_komidashi\">\n                上司からのメッセージ／採用担当からのメッセージ\n              </p>\n              <li>\n                <a href=\"./career01.html\"\n                  ><img src=\"images/navi/navi07.png\" class=\"icon_photo\" /><span\n                    class=\"navi_txt\"\n                    >設計部 部長</span\n                  ></a\n                >\n              </li>\n              <li>\n                <a href=\"./career02.html\"\n                  ><img src=\"images/navi/navi08.png\" class=\"icon_photo\" /><span\n                    class=\"navi_txt\"\n                    >地籍調査部 課長</span\n                  ></a\n                >\n              </li>\n              <li>\n                <a href=\"./career03.html\"\n                  ><img src=\"images/navi/navi09.png\" class=\"icon_photo\" /><span\n                    class=\"navi_txt\"\n                    >調査部 維持保全課 課長</span\n                  ></a\n                >\n              </li>\n              <li>\n                <a href=\"./career04.html\"\n                  ><img src=\"images/navi/navi10.png\" class=\"icon_photo\" /><span\n                    class=\"navi_txt\"\n                    >企画経理部 企画管理課<br />総務担当課長</span\n                  ></a\n                >\n              </li>\n              <li>\n                <a href=\"./voice07.html\"\n                  ><img src=\"images/navi/navi_mess.png\" /><span\n                    class=\"navi_txt\"\n                  ></span\n                ></a>\n              </li>\n            </ul>\n          </li>\n\n          <li class=\"menu\">\n            <a href=\"#\">インタビュー</a>\n            <ul class=\"child_menu\">\n              <li class=\"inta\">\n                <a href=\"./job.html\"><img src=\"images/navi/navi_i01.png\" /></a>\n              </li>\n              <li class=\"inta\">\n                <a href=\"./staff.html\"\n                  ><img src=\"images/navi/navi_i02.png\"\n                /></a>\n              </li>\n              <li class=\"inta\">\n                <a href=\"./staff.html#hope\"\n                  ><img src=\"images/navi/navi_i03.png\"\n                /></a>\n              </li>\n            </ul>\n          </li>\n\n          <li class=\"menu\">\n            <a href=\"#\">募集要項</a>\n            <ul class=\"child_menu\">\n              <li>\n                <a href=\"./new-job-description.html\"\n                  ><img src=\"images/navi/job_description_01.png\"\n                /></a>\n              </li>\n              <li>\n                <a href=\"./mid-job-description.html\"\n                  ><img src=\"images/navi/job_description_02.png\"\n                /></a>\n              </li>\n            </ul>\n          </li>\n\n          <li class=\"menu_i\">\n            <a href=\"./internship.html\">インターンシップ</a>\n          </li>\n\n          <li class=\"menu_i\">\n            <a href=\"./explanation.html\">会社説明会</a>\n          </li>\n          <li class=\"menu_car\">\n            <a href=\"./mid-career.html\">キャリア採用はこちら</a>\n          </li>\n        </ul>\n      </nav>\n    </header>\n    <!--ここまでヘッダー-->\n    <h1 class=\"membertitle01\">\n      <span class=\"number\"\n        ><img\n          src=\"images/member/cadastral2017.png\"\n          width=\"240\"\n          height=\"240\"\n          alt=\"\"\n      /></span>\n    </h1>\n    <!--ここからメインコンテンツ-->\n    <div id=\"content\">\n      <!--ここからメッセージ-->\n      <ul class=\"message firstChild\">\n        <li class=\"no01q1\">\n          <p>\n            入社したきっかけを<br />\n            教えてください。\n          </p>\n        </li>\n        <li class=\"answer\">\n          当初、この業界は残業が多く、きつい仕事という印象がありました。ただ、企業説明や先輩社員との交流を通し、タイムカードや勤務管理システムで、しっかりと勤務時間の管理をしているということや、職場環境向上のための取り組み（月一回の労使委員会など）を教えて頂き、安心できたのと同時に、そこから感じ取れる会社の雰囲気に惹かれたのを覚えています。そして、一番の決め手は当時の就職担当だった上司の「西谷は県内トップの技術力があります！」という言葉でした。自分もそのような環境で技術力を身につけたい！と感じ、西谷技術に入社することを決めました。\n        </li>\n\n        <li class=\"no01q1\">\n          <p>\n            現在の仕事内容を<br />\n            教えてください。\n          </p>\n        </li>\n        <li class=\"answer\">\n          現在は調査部という部署で、主に斜面の崩壊防止や落石対策を目的とした構造物設計を行っています。これらは一般的な道路や橋梁設計に比べ、日々の生活で直接利用する頻度が少ない構造物ですが、近年、多発している斜面崩壊等の災害に備える非常に重要な構造物です。また、斜面崩壊や落石といった現象は、現場の地質・地層と非常に深い関係にあります。そのため、地質調査業務も行っている現在の部署で、地質についても学び、総合的な視点で業務に取り組めるよう日々勉強しているところです。\n        </li>\n        <li class=\"photo odd\">\n          <img\n            src=\"images/member/no01photo.jpg\"\n            width=\"665\"\n            height=\"375\"\n            alt=\"\"\n            class=\"firstChild lastChild empty\"\n          />\n        </li>\n        <li class=\"q_blue\">休日の過ごし方は？</li>\n        <li class=\"a_blue\">\n          昨年、子供が生まれたこともあり、週末は自宅で家族で過ごすことが多いです。近年、動画配信サービスも充実しているので、家族で映画鑑賞したり、チーズケーキなどのお菓子を作って食べたりして、一週間の疲れをリフレッシュしています。いずれ子供が大きくなって、もっと遠出ができるようになれば、家族でドライブがてら、神戸や大阪のショッピングモールに買い物に行ったり、ＵＳＪなどの県外の遊園地にも行きたいなと思っています。\n        </li>\n        <li class=\"no01q1\">\n          <p>\n            今後の目標を<br />\n            教えてください。\n          </p>\n        </li>\n        <li class=\"answer\">\n          多くの業務に携わらせて頂き、設計の考え方であったり、問題の解決方法が少しずつわかってきたと思う反面、新たな業務に触れるほど、まだまだ自分の知らない知識や技術が見つかります。ただ、この会社には各分野の頼れる先輩・上司が多く在籍しているため、疑問や相談があれば部署の垣根を超えて、非常に丁寧に教えて下さいます。今後は、資格取得はもちろん、継承した知識と技術を次世代の後輩達へと伝えていきつつ、少しでも早く、先輩方のような会社からも発注者からも頼られる技術者になることが目標です。\n        </li>\n\n        <li class=\"no01q1\">\n          <p>\n            後輩への<br />\n            メッセージを<br />\n            お願いします。\n          </p>\n        </li>\n        <li class=\"answer\">\n          会社は、社員1人1人が仕事もプライベートも両立できるように、勤務形態や業務に取り組む体制を常に考えてくれているなと思います。もちろん、繁忙期等でやむを得ない時期はありますが、できる限り残業を減らし、休日もしっかり確保することで、皆さん、自分の趣味や家族との時間を確保できていると感じています。\n        </li>\n      </ul>\n      <!--ここまでメッセージ-->\n\n      <!--ここからスケジュール-->\n\n      <div class=\"schedule\">\n        <p class=\"oneday\">ある1日のスケジュール</p>\n        <div class=\"timebox\">\n          <div class=\"time\">7:45</div>\n          <div class=\"more\">\n            <p class=\"txt\">出社</p>\n            <p>安全運転で時間に余裕を見て家を出ています。</p>\n          </div>\n        </div>\n        <div class=\"timebox\">\n          <div class=\"time\">8:15</div>\n          <div class=\"more\">\n            <p class=\"txt\">始業</p>\n            <p>朝礼・朝ミーティングを行い、一日のスケジュールを確認します。</p>\n          </div>\n        </div>\n        <div class=\"timebox\">\n          <div class=\"time\">8:30</div>\n          <div class=\"more\">\n            <p class=\"txt\">内業開始</p>\n            <p>設計検討や、打合せに必要な資料等内業を行います。</p>\n          </div>\n        </div>\n        <div class=\"timebox\">\n          <div class=\"time\">12:00</div>\n          <div class=\"more\">\n            <p class=\"txt\">昼休憩</p>\n            <p>昼食を取ります。体調によっては仮眠をとることもあります。</p>\n          </div>\n        </div>\n        <div class=\"timebox\">\n          <div class=\"time\">13:00</div>\n          <div class=\"more\">\n            <p class=\"txt\">作業再開</p>\n            <p>設計検討を引き続き行ったり、打合せに出ることもあります。</p>\n          </div>\n        </div>\n        <div class=\"timebox\">\n          <div class=\"time\">16:00</div>\n          <div class=\"more\">\n            <p class=\"txt\">作業結果整理</p>\n            <p>\n              打合せの整理であったり、設計計画の確認を行ったりし修正を行います。\n            </p>\n          </div>\n        </div>\n\n        <div class=\"timebox\">\n          <div class=\"time\">17:15</div>\n          <div class=\"more\">\n            <p class=\"txt\">定時</p>\n            <p>業務の状況により残業をします。</p>\n          </div>\n        </div>\n        <div class=\"timebox2\">\n          <div class=\"time\">19:00</div>\n          <div class=\"more\">\n            <p class=\"txt\">退社</p>\n          </div>\n        </div>\n      </div>\n      <!--ここまでスケジュール-->\n    </div>\n    <!--ここまでメインコンテンツ-->\n\n    <!--ここからメンバーリンク-->\n    <div class=\"members\">\n      <ul class=\"member_link\">\n        <li class=\"member01on\">\n          <a href=\"voice01.html\"><em>設計部</em></a>\n        </li>\n        <li class=\"member02\">\n          <a href=\"voice02.html\"><em>設計部</em></a>\n        </li>\n        <li class=\"member03\">\n          <a href=\"voice03.html\"><em>設計部</em></a>\n        </li>\n        <li class=\"member04\">\n          <a href=\"voice05.html\"><em>地籍調査部</em></a>\n        </li>\n        <li class=\"member05\">\n          <a href=\"voice06.html\"><em>地籍調査部</em></a>\n        </li>\n        <li class=\"member06\">\n          <a href=\"voice04.html\"><em>測量調査部</em></a>\n        </li>\n        <li class=\"member08\">\n          <a href=\"career01.html\"\n            ><em>上司からのメッセージ設計本部 設計部長</em></a\n          >\n        </li>\n        <li class=\"member09\">\n          <a href=\"career02.html\"\n            ><em>上司からのメッセージ地籍調査部 一課長</em></a\n          >\n        </li>\n        <li class=\"member10\">\n          <a href=\"career03.html\"\n            ><em>上司からのメッセージ調査部 維持保全課長</em></a\n          >\n        </li>\n        <li class=\"member11\">\n          <a href=\"career04.html\"\n            ><em>上司からのメッセージ企画管理部企画管理課総務担当課長</em></a\n          >\n        </li>\n        <li class=\"un-woman\">\n          <a href=\"staff.html\"><img src=\"images/member/un-woman.png\" /></a>\n        </li>\n      </ul>\n    </div>\n    <!--ここまでメンバーリンク-->\n    <!--ここからエントリーボックス-->\n    <div class=\"entry\">\n      <ul class=\"entry_link\">\n        <li class=\"entry01\">\n          <section\n            class=\"responsive wow fadeInUp welcome__workflow-image\"\n            data-wow-delay=\"0.2s\"\n            data-wow-offset=\"0\"\n          >\n            <img\n              src=\"images/common/entry.gif\"\n              width=\"145\"\n              height=\"145\"\n              alt=\"\"\n            />\n          </section>\n        </li>\n        <li class=\"entry02\">\n          <a\n            href=\"https://job.mynavi.jp/28/pc/search/corp207090/outline.html\"\n            target=\"_blank\"\n            ><img src=\"images/common/mynavi.gif\" width=\"270\" height=\"82\" alt=\"\"\n          /></a>\n        </li>\n        <!-- <li class=\"entry03\"><a href=\"https://job.rikunabi.com/2026/company/r564710080/\" target=\"_blank\"><img src=\"images/common/ricenavi.gif\" width=\"270\" height=\"82\" alt=\"\"/></a></li> -->\n        <li class=\"entry03\" style=\"margin: 0px 0px 0px 30px\">\n          <a href=\"https://works.do/R/ti/p/saiyo@nishi-tc\" target=\"_blank\"\n            ><img\n              src=\"images/common/nishi_line.png\"\n              width=\"110\"\n              height=\"162\"\n              alt=\"\"\n          /></a>\n        </li>\n      </ul>\n    </div>\n    <!--ここまでエントリーボックス-->\n\n    <!--ここからフッター-->\n    <div id=\"footer\">\n      <div class=\"footer_box\">\n        <p class=\"foot_logo\">\n          <a href=\"../index.html\"\n            ><img\n              src=\"images/common/footerlogo.gif\"\n              width=\"425\"\n              height=\"40\"\n              alt=\"西谷技術コンサルタント株式会社\"\n          /></a>\n        </p>\n        <p class=\"add\">\n          〒682-0025鳥取県倉吉市八屋354番地1　TEL.0858-26-2411　FAX.0858-26-5537\n        </p>\n      </div>\n      <p class=\"copyright\">\n        Copyright (C) 2016 Nishitani Engineering Consultant Co.,Ltd.All rights\n        reserved\n      </p>\n    </div>\n    <!--ここまでフッター-->\n\n    <div id=\"pagetop\">\n      <a href=\"#header\" title=\"PAGE TOPへ\"><em>ページトップへ</em></a>\n    </div>\n    <!-- jquery & iScroll -->\n    <script src=\"js/iscroll.min.js\"></script>\n    <script src=\"js/drawer.min.js\"></script>\n    <script src=\"js/main.js\"></script>\n    <script>\n      (function (i, s, o, g, r, a, m) {\n        i[\"GoogleAnalyticsObject\"] = r;\n        (i[r] =\n          i[r] ||