\"shortcut icon\" href=\"assets/img/common/favicon.png\" />\n<link rel=\"apple-touch-icon\" href=\"assets/img/common/favicon.png\" />\n<meta name=\"apple-mobile-web-app-title\" content=\"平和不動産\" />\n <!--css-->\n<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\" />\n<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin />\n<link href=\"https://fonts.googleapis.com/css2?family=Outfit:wght@100;200;300;500;700&family=Zen+Kaku+Gothic+New:wght@500;700&display=swap\" rel=\"stylesheet\" />\n<link href=\"assets/css/layout/reset.min.css\" rel=\"stylesheet\" />\n<link href=\"assets/css/layout/slick-theme.css\" rel=\"stylesheet\" />\n<link href=\"assets/css/layout/slick.css\" rel=\"stylesheet\" />\n<link href=\"assets/css/layout/base.min.css\" rel=\"stylesheet\" />\n<!--/css-->\n\n\n    <link href=\"assets/css/layout/slick-theme.css\" rel=\"stylesheet\" />\n    <link href=\"assets/css/layout/slick.css\" rel=\"stylesheet\" />\n    <link href=\"assets/css/page/project-story.min.css\" rel=\"stylesheet\" />\n  </head>\n\n  <body class=\"page page-project-story sapporo\">\n    <!-- Google Tag Manager (noscript) -->\n    <noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-K4W76XMC\"\n            height=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n    <!-- End Google Tag Manager (noscript) --> <header class=\"header\">\n  <div class=\"header__toggle sp-nav\">\n    <span></span>\n    <span></span>\n    <span></span>\n  </div>\n  <div class=\"header__inner\">\n    <div class=\"header__logo\">\n      <a href=\"\">\n        <img src=\"assets/img/common/logo01.svg\" alt=\"平和不動産 RECRUIT SITE\" />\n      </a>\n    </div>\n    <nav class=\"header__gnav\">\n      <div class=\"header__gnav__logo sp-nav\">\n        <img src=\"assets/img/common/logo01_white.svg\" alt=\"平和不動産 RECRUIT SITE\" />\n      </div>\n      <ul class=\"header__navi\">\n        <li>\n          <a href=\"\" class=\"opacity no-plus\">TOP<sma