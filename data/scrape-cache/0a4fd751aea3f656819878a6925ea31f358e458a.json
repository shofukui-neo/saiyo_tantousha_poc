{"url":"https://www.sanyodenken.co.jp/recruit/entrydata/index.html","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width\">\n<meta name=\"description\" content=\"創業から受け継がれてきた技術者スピリットを守り続け、磨き続ける「山陽電研株式会社」は、新卒採用、中途採用、パート採用を募集しています。\">\n<meta name=\"keywords\" content=\"電気・電子,理系,新卒,大卒,採用,岡山,山陽電研\">\n<title>山陽電研株式会社｜採用サイト｜募集要項</title>\n<!-- Global site tag (gtag.js) - Google Analytics -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-1HGTENGETE\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'G-1HGTENGETE');\n</script>\n\n<!-- OGP -->\n<meta property=\"og:type\" content=\"article\">\n<meta property=\"og:description\" content=\"創業から受け継がれてきた技術者スピリットを守り続け、磨き続ける「山陽電研株式会社」は、新卒採用、中途採用、パート採用を募集しています。\">\n<meta property=\"og:title\" content=\"山陽電研株式会社｜採用サイト｜募集要項\">\n<meta property=\"og:url\" content=\"https://www.sanyodenken.co.jp/recruit/entrydata/\">\n<meta property=\"og:image\" content=\"https://www.sanyodenken.co.jp/recruit/entrydata/img/main_recruitment.png\">\n<meta property=\"og:site_name\" content=\"山陽電研株式会社｜採用サイト\">\n<meta property=\"og:locale\" content=\"ja_JP\">\n<!-- /OGP -->\n\n<!-- Twitter Card -->\n<!--\n<meta name=\"twitter:card\" content=\"summary\">\n<meta property=\"twitter:description\" content=\"創業から受け継がれてきた技術者スピリットを守り続け、磨き続ける「山陽電研株式会社」は、新卒採用、中途採用、パート採用を募集しています。\">\n<meta property=\"twitter:title\" content=\"山陽電研株式会社　採用サイト 仕事の魅力\">\n<meta property=\"twitter:url\" content=\"https://www.sanyodenken.co.jp/recruit/entrydata/\">\n<meta name=\"twitter:image\" content=\"https://www.sanyodenken.co.jp/recruit/entrydata/img/main_recruitment.png\">\n<meta name=\"twitter:domain\" content=\"sanyodenken.co.jp\">\n<meta name=\"twitter:creator\" content=\"@*********\">\n<meta name=\"twitter:site\" content=\"@*********\">\n-->\n<!-- StyleSheet -->\n<link rel=\"stylesheet\" href=\"../common/css/content.css\">\n<link rel=\"stylesheet\" href=\"https://maxcdn.bootstrapcdn.com/font-awesome/4.4.0/css/font-awesome.min.css\">\n<!-- Global site tag (gtag.js) - Google Analytics -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-1HGTENGETE\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'G-1HGTENGETE');\n</script>\n</head>\n\n<body>\n<header class=\"placement\">\n<h1>山陽電研株式会社｜採用サイト｜募集要項</h1>\n    <!-- スマホサイズ切替用 \n\t<img class=\"headerimgl\" src=\"img/main_recruitment.png\" alt=\"山陽電研株式会社 採用サイトヘッダ画像 L\"/>\n\t<img class=\"headerimgs\" src=\"../top_img/main.jpg\"  alt=\"山陽電研株式会社 採用サイトヘッダ画像 Sスマホ用\"/>\n    -->\n    <img src=\"img/main_recruitment.png\" alt=\"山陽電研株式会社 採用サイト 募集要項 ヘッダ画像\"/>\n\n\t<!-- ハンバーガーメニュー -->\n    <!-- ハンバーガーメニューの表示・非表示を切り替えるチェックボックス -->\n    <input type=\"checkbox\" id=\"drawer-check\" class=\"drawer-hidden\" >\n\n    <!-- ハンバーガーアイコン -->\n    <label for=\"drawer-check\" class=\"drawer-open\"><span></span></label>\n\n\t<nav class=\"drawer-content\">\n\t<ul>\n\t\t<li><a href=\"../\">ホーム</a></li>\n\t\t<li><a href=\"../job/index.html\">仕事紹介</a></li>\n\t\t<li><a href=\"../charm/index.html\">仕事の魅力</a></li>\n\t\t<li><a href=\"../senior/index.html\">先輩紹介</a></li>\n\t\t<li><a href=\"#\">募集要項</a></li>\n\t\t<li><a href=\"mailto:soumuka@sanyodenken.co.jp\">お問い合わせ</a></li>\n        <li><a href=\"https://www.sanyodenken.co.jp/\">オフィシャルサイトへ</a></li>\n\t</ul>\n\t</nav>\n</header>\n<main>\n<article class=\"placement\">\n\t<h2 style=\"display: none\">募集要項</h2>\n\n\t<section class=\"rec_category\">\n\t\t<ul>\n\t\t\t<li><a href=\"#new\"><img src=\"img/new.png\" onmouseout=\"this.src='img/new.png'\" onmouseover=\"this.src='img/on_new.png'\" class=\"iconw\" ></a></li>\n            <li><a href=\"#cyuyo\"><img src=\"img/cyutosaiyo.png\" onmouseout=\"this.src='img/cyutosaiyo.png'\" onmouseover=\"this.src='img/on_chuto.png'\" class=\"iconw\"></a></li>\n            <li><a href=\"#part\"><img src=\"img/part.png\" onmouseout=\"this.src='img/part.png'\" onmouseover=\"this.src='img/on_part.png'\" class=\"iconw\"></a></li>\n        </ul>\n    </section>\n\n    <a id=\"new\"></a>\n\t<section>\n        <p class=\"ntitle\">■新卒採用</p>\n\n\t\t<div class=\"saiyonavi\">\n\t\t\t<div class=\"saiyonavi_box\">\n\t\t\t\t<a href=\"https://job.mynavi.jp/27/pc/search/corp274087/outline.html\" target=\"_blank\">\n\t\t\t\t\t<img src=\"https://job.mynavi.jp/conts/kigyo/2027/logo/banner_entry_160_45.gif\" alt=\"マイナビ2027\" border=\"0\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t</a>\n\t\t\t\t\t<p class=\"stxtred\">\n\t\t\t\t\t\t※マイナビよりエントリーを受け付けています。待遇、制度などの詳細を掲載中。ぜひご覧下さい。 </p>\n\t\t\t</div>\n\t\t</div>\n\t\t<div class=\"saiyonavi mb2\">\n\t\t\t<div class=\"saiyonavi_box\">\n\t\t\t\t<a href=\"../video/recruit.html\" target=\"_blank\">\n\t\t\t\t\t<img src=\"../video/recruit_bana.jpg\" width=\"160\" height=\"45\" alt=\"採用ビデオメッセージ\"/>\n\t\t\t\t</a><p class=\"stxtred\">\n\t\t\t\t※採用情報ビデオをアップしました。ビデオは約7分、16MBあります。ご了承のうえご覧ください。</p>\n\t\t\t</div>\n\t\t</div>\n\t\n\t\t<table class=\"mb5\">\n\t\t\t<colgroup class=\"ntabletitle\"></colgroup>\n\t\t\t<tr>\n\t\t\t\t<th class=\"ntabletitle\">職　　種</th>\n\t\t\t\t<td>技術系職（設計・製品開発・生産技術・技術営業）<br /></td>\n\t\t\t</tr>\n\t\t\t<tr>\n\t\t\t\t<th class=\"ntabletitle\">資　　格</th>\n\t\t\t\t<td>理系全学科　　（大学）<br />\n\t\t\t\t\t電気科・機械科（高校）</td>\n\t\t\t</tr>\n\t\t\t<tr>\n\t\t\t\t<th class=\"ntabletitle\">初 任 給</th>\n\t\t\t\t<td>大学／学部卒　　250,000円<br />\n\t\t\t\t\t大学院卒　　　　260,000円<br /> \n\t\t\t\t\t高校卒　　　　　210,000円</td>\n\t\t\t</tr>\n\t\t\t<tr>\n\t\t\t\t<th class=\"ntabletitle\">勤務時間</th>\n\t\t\t\t<td>8:30～17:20</td>\n\t\t\t</tr>\n\t\t\t<tr>\n\t\t\t\t<th class=\"ntabletitle\">休日休暇</th>\n\t\t\t\t<td>完全週休2日制（土日）、祝日<br />\n\t\t\t\t\t※11月第1週土曜日は社員旅行のため出勤日となります。<br />\n\t\t\t\t\t夏季休暇<br />\n\t\t\t\t\t年末年始<br />\n\t\t\t\t\t年間休日　122日（2025年度）<br />\n\t\t\t\t\t年次有給休暇初年度　10日</td>\n\t\t\t</tr>\n\t\t\t<tr>\n\t\t\t\t<th class=\"ntabletitle\">福利厚生</th>\n\t\t\t\t<td>昇給年1回  <br />\n\t\t\t\t\t賞与年2回  <br />\n\t\t\t\t\t社会保険完備  <br />\n\t\t\t\t\t交通費 <br />\n\t\t\t\t\t残業手当 <br />\n\t\t\t\t\t資格手当 <br />\n\t\t\t\t\t家族手当 <br />\n\t\t\t\t\t特殊作業手当 <br />\n\t\t\t\t\t出張手当 <br />\n\t\t\t\t\t役職手当 <br />\n\t\t\t\t\t退職金制度 <br />\n\t\t\t\t\t財形貯蓄 <br />\n\t\t\t\t\t健康診断年1回 <br />\n\t\t\t\t\t社員旅行年1回 <br />\n\t\t\t\t\tインフルエンザ予防接種費用負担 <br />\n\t\t\t\t\t資格取得支援制度 <br />\n\t\t\t\t\t労働組合あり <br />\n\t\t\t\t\t<p>【その他】 <br />\n\t\t\t\t\t\t◎残業時の軽食支給 <br />\n\t\t\t\t\t\t◎4月に全従業員に花見弁当を支給 <br />\n\t\t\t\t\t\t\t◎転勤なし <br />\n\t\t\t\t\t\t働きやすい職場づくりのために <br />\n\t\t\t\t\t\t「小さなことでも積極的に取り組もう」と考え実践しています。\n\t\t\t\t\t</p>\n\t\t\t\t</td>\n\t\t\t</tr>\n\t\t\t<tr>\n\t\t\t\t<th class=\"ntabletitle\">応募方法</th>\n\t\t\t\t<td>マイナビの当社ページからエントリーしてください。<br />\n\t\t\t\t\t<!-- Begin mynavi Navi Link -->\n\t\t\t\t\t<a href=\"https://job.mynavi.jp/26/pc/search/corp274087/outline.html\" target=\"_blank\">\n\t\t\t\t\t\t<img src=\"https://job.mynavi.jp/conts/kigyo/2026/logo/banner_entry_160_45.gif\" alt=\"マイナビ2026\" border=\"0\">\n\t\t\t\t\t</a>\n\t\t\t\t\t<!-- End mynavi Navi Link -->\n\t\t\t\t\t<br />\n\t\t\t\t\t採用に関するお問い合わせはこちらまで。<br />\n\t\t\t\t\t総務部　TEL 086-279-0591 <br />\n\t\t\t\t</td>\n\t\t\t</tr>\n\t\t</table>\n\t</section>\n\t\n    <a id=\"cyuyo\"></a>\n\t<section>\n\t\t<p class=\"ctitle\">■中途採用</p>\n\t\t<table class=\"mb5\">\n\t\t\t<colgroup class=\"ctabletitle\"></colgroup>\n\t\t\t<tr>\n\t\t\t\t<th class=\"ctabletitle\">職　　種</th>\n\t\t\t\t<td>\n\t\t\t\t\t組立配線作業者 <br />\n\t\t\t\t</td>\n\t\t\t</tr>\n\t\t\t<tr>\n\t\t\t\t<th class=\"ctabletitle\">資　　格</th>\n\t\t\t\t<td>未経験者歓迎<br />\n\t\t\t\t\t※実務経験20年以上の方優遇<br />\n\t\t\t\t\t※配電盤組立技能士お持ちの方優遇</td>\n\t\t\t</tr>\n\t\t\t<tr>\n\t\t\t\t<th class=\"ctabletitle\">給与</th>\n\t\t\t\t<td>月給20.5万円～ ※上記経験等を考慮し優遇いたします。<br /> \n\t\t\t\t\t【年収例】<br /> \n\t\t\t\t\t470万円～530万円／35歳(入社12年・既婚・子供1人)の場合／月給27万円＋残業手当＋賞与<br /> \n\t\t\t\t\t440万円～500万円／31歳(入社8年・既婚)の場合／月給26万円＋残業手当＋賞与<br /> \n\t\t\t\t\t660万円／50歳(管理職・入社32年・既婚)の場合／月給42万円＋賞与<br />\n\t\t\t\t</td>\n\t\t\t</tr>\n\t\t\t<tr>\n\t\t\t\t<th class=\"ctabletitle\">勤務時間</th>\n\t\t\t\t<td>8:30～17:20</td>\n\t\t\t</tr>\n\t\t\t<tr>\n\t\t\t\t<th class=\"ctabletitle\">休日休暇</th>\n\t\t\t\t<td>完全週休2日制（土日）、祝日<br />\n\t\t\t\t\t※11月第1週土曜日は社員旅行のため出勤日となります。<br />\n\t\t\t\t\t夏季休暇<br />\n\t\t\t\t\t年末年始<br />\n\t\t\t\t\t年間休日　122日（2025年度）<br />\n\t\t\t\t\t年次有給休暇初年度　10日\n\t\t\t\t</td>\n\t\t\t</tr>\n\t\t\t<tr>\n\t\t\t\t<th class=\"ctabletitle\">福利厚生</th>\n\t\t\t\t<td>昇給年1回  <br />\n\t\t\t\t\t賞与年2回  <br />\n\t\t\t\t\t社会保険完備  <br />\n\t\t\t\t\t交通費 <br />\n\t\t\t\t\t残業手当 <br />\n\t\t\t\t\t資格手当 <br />\n\t\t\t\t\t家族手当 <br />\n\t\t\t\t\t特殊作業手当 <br />\n\t\t\t\t\t出張手当 <br />\n\t\t\t\t\t役職手当 <br />\n\t\t\t\t\t退職金制度 <br />\n\t\t\t\t\t財形貯蓄 <br />\n\t\t\t\t\t健康診断年1回 <br />\n\t\t\t\t\t社員旅行年1回 <br />\n\t\t\t\t\tインフルエンザ予防接種費用負担 <br />\n\t\t\t\t\t資格取得支援制度 <br />\n\t\t\t\t\t労働組合あり <br />\n\t\t\t\t\t<p>【その他】 <br />\n\t\t\t\t\t\t◎残業時の軽食支給 <br />\n\t\t\t\t\t\t◎4月に全従業員に花見弁当を支給 <br />\n\t\t\t\t\t\t\t◎転勤なし <br />\n\t\t\t\t\t\t働きやすい職場づくりのために <br />\n\t\t\t\t\t\t「小さなことでも積極的に取り組もう」と考え実践しています。\n\t\t\t\t\t</p>\n\t\t\t\t</td>\n\t\t\t</tr>\n\t\t\t<tr>\n\t\t\t\t<th class=\"ctabletitle\">応募方法</th>\n\t\t\t\t<td>中途採用に関するお問い合わせはこちらまで。<br />\n\t\t\t\t\t総務部　TEL 086-279-0591 <br /></td>\n\t\t\t</tr>\n\t\t</table>\n\t</section>\n\n    <a id=\"part\"></a>\n\t<section>\n\t\t<p class=\"ptitle\">■パート採用</p>\n\t\t<table>\n\t\t\t<colgroup class=\"ptabletitle\"></colgroup>\n\t\t\t<tr>\n\t\t\t\t<th class=\"ptabletitle\">職　　種</th>\n\t\t\t\t<td>制御盤の組立・配線補助作業です。<br /></td>\n\t\t\t</tr>\n\t\t\t<tr>\n\t\t\t\t<th class=\"ptabletitle\">資　　格</th>\n\t\t\t\t<td>年齢不問!　初心者・長期の方、大歓迎です!</td>\n\t\t\t</tr>\n\t\t\t<tr>\n\t\t\t\t<th class=\"ptabletitle\">時給</th>\n\t\t\t\t<td>まずは時給1,130円からスタート。能力に応じて昇給があります。<br />\n\t\t\t\t\t夏期・冬期・礼金あり(25,000円～50,000円)\n\t\t\t\t</td>\n\t\t\t</tr>\n\t\t\t<tr>\n\t\t\t\t<th class=\"ptabletitle\">勤務時間</th>\n\t\t\t\t<td>8:30～17:20の中で5時間、6.5時間、7.5時間のいずれかを選択できます。</td>\n\t\t\t</tr>\n\t\t\t<tr>\n\t\t\t\t<th class=\"ptabletitle\">休日休暇</th>\n\t\t\t\t<td>完全週休2日制（土日）、祝日<br />\n\t\t\t\t\t夏季休暇<br />\n\t\t\t\t\t年末年始<br />\n\t\t\t\t\t年間休日　122日（2025年度）<br />\n\t\t\t\t\t年次有給休暇初年度　10日\n\t\t\t\t</td>\n\t\t\t</tr>\n\t\t\t<tr>\n\t\t\t\t<th class=\"ptabletitle\">福利厚生</th>\n\t\t\t\t<td>日帰り旅行(年1回:会社負担)<br />\n\t\t\t\t健康診断、インフルエンザ予防接種(年1回:会社負担)<br />\n\t\t\t\t社会保険加入できます。<br />\n\t\t\t\t制服貸与</td>\n\t\t\t</tr>\n\t\t\t<tr>\n\t\t\t\t<th class=\"ptabletitle\">正社員への登用</th>\n\t\t\t\t<td>正社員への登用制度あります。<br />\n\t\t\t\t\t※配電盤組立の技能士2級合格が条件となります。<br />\n\t\t\t\t\t　高卒後3年で合格しています。<br />\n\t\t\t\t\t　勉強は会社が指導します。</td>\n\t\t\t</tr>\n\t\t\t<tr>\n\t\t\t\t<th class=\"ptabletitle\">応募方法</th>\n\t\t\t\t<td>パート採用に関するお問い合わせはこちらまで。<br />\n\t\t\t\t\t総務部　TEL 086-279-0591 <br /></td>\n\t\t\t</tr>\n\t\t</table>\n\t</section>\n</article>\n</main>\n<footer>\n<a href=\"#\" class=\"page_top_btn\"><img src=\"../common/pagetop.gif\" alt=\"ページトップアイコン\"></a>\n\t<img class=\"footerlogo\" src=\"../common/denkenwhite_logo.png\" alt=\"山陽電研ロゴマーク\" />\n\t<div class=\"container\">\n\t\t<ul style=\"display:inline-flex;  text-align: center\">\n\t\t    <li style=\"margin-left: 10px\"><a href=\"https://www.facebook.com/sanyodenken\"><img src=\"../common/icon_fecebook.png\" alt=\"Face Book\"/></a></li>\n\t\t    <li style=\"margin-left: 20px\"><a href=\"https://www.instagram.com/sanyodenken/?hl=ja\"><img src=\"../common/icon_insta.png\" alt=\"インスタグラム\"/></a></li>\n\t\t    <li style=\"margin-left: 20px\"><a href=\"https://www.youtube.com/@sanyodenken\"><img src=\"../common/icon_move.png\" alt=\"TV CM\"/></a></li>\n\t\t</ul>\n\t</div>\n\t<img class=\"footerlogo\" src=\"../common/copyligt_text.png\" alt=\"山陽電研 株式会社 コピーライト\" />\n\t<!--\n  <small>Copyright &copy; 2022 山陽電研株式会社 All Rights Reserved.</small>\n      -->\n<!--\n<address>山陽電研株式会社<br>\n〒703-8228 岡山県岡山市中区乙多見449<br>\nsoumuka＠sanyodenken.co.jp</address>\n-->\n</footer>\n</body>\n</html>\n","finalUrl":"https://www.sanyodenken.co.jp/recruit/entrydata/index.html","rendered":false,"_cachedAt":"2026-06-22T15:06:08.274Z"}