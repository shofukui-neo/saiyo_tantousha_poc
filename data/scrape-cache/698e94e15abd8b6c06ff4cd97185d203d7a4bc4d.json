/javascript\" src=\"/common/js/script.js\"></script>\n<!-- Global site tag (gtag.js) - Google Analytics -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=UA-144761729-1\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n  gtag('config', 'UA-144761729-1');\n  gtag('config', 'UA-451023-38');\n</script>\n</head>\n<body id=\"company\">\n<div id=\"base\">\n<header>\n<div id=\"head\" class=\"_type2\">\n\t<h1 class=\"site_logo\"><a href=\"/\"><img src=\"/common/image/head/logo.png\" alt=\"会社情報 | 岡山のビル管理・メンテナンス、ビル清掃 株式会社建美装社\"></a></h1>\n\t<div id=\"btn_open\"><a href=\"javascript:void(0);\"><i class=\"fa fa-bars\"></i></a></div>\n\t<nav><div class=\"main\">\n\t\t<ul>\n\t\t\t<li><a href=\"/service/\"><i class=\"fa fa-hand-holding-heart\"></i>事業・サービス</a>\n\t\t\t\t<div class=\"sub\">\n\t\t\t\t\t<div class=\"row no-gutters\">\n\t\t\t\t\t\t<div class=\"col-xs-3 col-6\"><a href=\"/service/cleaning/\">\n\t\t\t\t\t\t\t<span class=\"photo\"><img src=\"/common/image/icon/icon11.png\" alt=\"ビル清掃・ビルメンテナンス\"></span><span class=\"text\">清掃</span>\n\t\t\t\t\t\t</a></div>\n\t\t\t\t\t\t<div class=\"col-xs-3 col-6\"><a href=\"/service/facility/\">\n\t\t\t\t\t\t\t<span class=\"photo\"><img src=\"/common/image/icon/icon12.png\" alt=\"設備管理・点検\"></span><span class=\"text\">設備管理・点検</span>\n\t\t\t\t\t\t</a></div>\n\t\t\t\t\t\t<div class=\"col-xs-3 col-6\"><a href=\"/service/floor/\">\n\t\t\t\t\t\t\t<span class=\"photo\"><img src=\"/common/image/icon/icon13.png\" alt=\"フロアメンテナンス\"></span><span class=\"text\">フロアメンテナンス</span>\n\t\t\t\t\t\t</a></div>\n\t\t\t\t\t\t<div class=\"col-xs-3 col-6\"><a href=\"/service/reform/\">\n\t\t\t\t\t\t\t<span class=\"photo\"><img src=\"/common/image/icon/icon14.png\" alt=\"工事・リフォーム\"></span><span class=\"text\">工事・リフォーム</span>\n\t\t\t\t\t\t</a></div>\n\t\t\t\t\t\t<div class=\"col-xs-3 col-6\"><a href=\"/service/waste/\">\n\t\t\t\t\t\t\t<span class=\"photo\"><img src=\"/common/image/icon/icon15.png\" alt=\"廃棄物回収\"></span><span class=\"text\">廃棄物回収</span>\n\t\t\t\t\t\t</a></div>\n\t\t\t\t\t\t<div class=\"col-xs-3 col-6\"><a href=\"/service/other/\">\n\t\t\t\t\t\t\t<span class=\"photo\"><img src=\"/common/image/icon/icon18.png\" alt=\"その他のサービス\"></span><span class=\"text\">その他のサービス</span>\n\t\t\t\t\t\t</a></div>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</li>\n\t\t\t<li><a href=\"/company/\"><i class=\"fa fa-building\"></i>会社情報</a></li>\n\t\t\t<li><a href=\"/case/\"><i class=\"fa fa-images\"></i>施工事例</a></li>\n\t\t\t<li><a href=\"https://recruit-kenbisosha.com/\" target=\"_blank\" class=\"ga_link\"><i class=\"fa fa-user-tie\"></i>採用情報</a></li>\n\t\t\t<li><a href=\"/news/\"><i class=\"fa fa-comment-dots\"></i>お知らせ</a></li>\n\t\t\t<li class=\"pc_none sp_none\"><a href=\"/privacy/\">プライバシーポリシー</a></li>\n\t\t</ul>\n\t</div></nav>\n</div>\n</header>\n<main>\n<div id=\"page_title\">\n\t<h2>会社情報<span class=\"sub\">Company</span></h2>\n</div>\n<div id=\"pankuzu\" class=\"center3\">\n\t<ul>\n\t\t<li><a href=\"/\">ホーム</a></li>\n\t\t<li>会社情報</li>\n\t</ul>\n</div>\n<div id=\"body\" class=\"bg0\">\n\t<section>\n\t\t<div class=\"wrapper center2 mincho\" id=\"message\">\n\t\t\t<p class=\"mb10\">当社は「お客様に喜ばれるサービスを提供する」をモットーに、50年以上、総合ビルメンテナンス業を通じて地域社会と共に歩んでまいりました。</p>\n\t\t\t<p class=\"mb20\">創業以来の価値観を大切にしながら、お客様のニーズに寄り添った柔軟な対応、時代の変化に順応した新技術の導入など、より高いサービスの提供に日々取り組んでおります。</p>\n\t\t\t<p class=\"mb10\">今後もお客様にとって真に価値のあるパートナーであり続ける為、社員一丸となりチャレンジを続けてまいります。</p>\n\t\t\t<p class=\"mb10\">また、働きやすく成長できる環境こそがより良いサービスにつながるという信念のもと、全てのサービスの原点である「人」を大切にし、従業員一人ひとりが誇りを持ち、輝ける職場作りに力を注いでいきます。</p>\n\t\t\t<p class=\"mb20\">これからも「信頼される企業」として、変化を恐れず挑戦を重ね、お客様にとって安心と快適な空間を提供できる存在であり続ける組織を目指します。</p>\n\t\t\t<p class=\"mb30\">今後とも、皆様の変わらぬご支援ご鞭撻のほどよろしくお願いいたします。</p>\n\t\t\t<p class=\"pos_ar\">代表取締役社長　<span class=\"name\">山下 祐一郎</span></p>\n\t\t</div>\n\t</section>\n\t<section>\n\t\t<div id=\"company_info\" class=\"back_fix\">\n\t\t\t<div class=\"back_fix_in wrapper bg0\">\n\t\t\t\t<div class=\"center\">\n\t\t\t\t\t<h2 class=\"hl_1\">会社概要<span class=\"sub\">Company Info</span></h2>\n\t\t\t\t\t<table class=\"tbl_1\">\n\t\t\t\t\t\t<tbody>\n\t\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t\t<th>会社名</th>\n\t\t\t\t\t\t\t\t<td>株式会社建美装社（ケンビソウシャ）</td>\n\t\t\t\t\t\t\t</tr>\n\t\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t\t<th>所在地</th>\n\t\t\t\t\t\t\t\t<td>〒702-8005 岡山県岡山市中区江崎724-5</td>\n\t\t\t\t\t\t\t</tr>\n\t\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t\t<th>電話番号</th>\n\t\t\t\t\t\t\t\t<td>TEL：<span class=\"tel\" data-tel=\"086-277-1112\">086-277-1112</span><br>FAX：086-276-3336</td>\n\t\t\t\t\t\t\t</tr>\n\t\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t\t<th>設立</th>\n\t\t\t\t\t\t\t\t<td>昭和48年8月</td>\n\t\t\t\t\t\t\t</tr>\n\t\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t\t<th>資本金</th>\n\t\t\t\t\t\t\t\t<td>1000万円</td>\n\t\t\t\t\t\t\t</tr>\n\t\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t\t<th>代表者名</th>\n\t\t\t\t\t\t\t\t<td>山下 祐一郎</td>\n\t\t\t\t\t\t\t</tr>\n\t\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t\t<th>事業内容</th>\n\t\t\t\t\t\t\t\t<td>【総合ビルメンテナンス】<br />\r\n病院清掃、ビルメンテナンス、24時間365日緊急対応、補修工事、床コーティング、カーペット・ソファ清掃、空調設備・エアコン清掃、消防設備点検、給排水設備清掃、リフォーム、廃棄物収集、ホテル客室メイク<br />\r\n<br />\r\n【人材派遣・紹介事業】</td>\n\t\t\t\t\t\t\t</tr>\n\t\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t\t<th>許認可</th>\n\t\t\t\t\t\t\t\t<td>\n<table class=\"tbl_2 mb5\">\n\t<tbody>\n\t\t<tr>\n\t\t\t<td>一般建設業<br>\n\t\t\t　・建築工事業<br>\n\t\t\t　・屋根工事業<br>\n\t\t\t　・管工事業<br>\n\t\t\t　・内装仕上工事業<br>\n\t\t\t　・大工工事業<br>\n\t\t\t　・電気工事業<br>\n\t\t\t　・タイル・れんが・ブロック工事業</td>\n\t\t\t<td>岡山県知事許可(般-6)第24458号</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<td>一般廃棄物処理業</td>\n\t\t\t<td>岡山市許可番号 4016</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<td>産業廃棄物収集運搬業</td>\n\t\t\t<td>岡山県許可番号 第03301028457号<br>福岡県許可番号 第04000028457号</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<td>特別管理産業廃棄物収集運搬業</td>\n\t\t\t<td>岡山県許可番号 第03350028457号</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<td>労働者派遣事業許可</td>\n\t\t\t<td>許可番号 派33-300019</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<td>有料職業紹介事業許可</td>\n\t\t\t<td>許可番号 33-ユ-300060</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<td>建築物環境衛生総合管理業</td>\n\t\t\t<td>岡山県28総 第36号</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<td>建築物飲料水貯水槽清掃業</td>\n\t\t\t<td>岡山県56貯 第18号</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<td>建築物ねずみ昆虫等防除業</td>\n\t\t\t<td>岡山県21ね 第97号</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<td>消防用設備等点検済表示登録</td>\n\t\t\t<td>33-1-032号</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<td>消防用設備業</td>\n\t\t\t<td>第DEF-1097号</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<td>医療関連サービスマーク</td>\n\t\t\t<td>G(4)-2106332248</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<td>第一種フロン類充填回収業者</td>\n\t\t\t<td>岡山県登録番号 第331010002号</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<td>冷媒回収事業所</td>\n\t\t\t<td>認定番号 330070</td>\n\t\t</tr>\n\t</tbody>\n</table>\n\t\t\t\t\t\t\t\t\t<img src=\"/common/image/contents/company/image1.png\" alt=\"医療サービスマーク\">\n\t\t\t\t\t\t\t\t</td>\n\n\t\t\t\t\t\t\t</tr>\n\t\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t\t<th>加入団体</th>\n\t\t\t\t\t\t\t\t<td>（社）全国ビルメンテナンス協会、<br />\r\n（社）岡山県産業廃棄物協会、<br />\r\n（社）岡山ビルメンテナンス協会、<br />\r\n（社）岡山県消防設備協会、貯水槽管理事業協同組合</td>\n\t\t\t\t\t\t\t</tr>\n\t\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t\t<th>主要取引先<br>（50音順）</th>\n\t\t\t\t\t\t\t\t<td>朝日医療大学校、おかやまコープ、岡山文化芸術創造、岡山理科大学、慈圭病院、積水ハウス、<br />\r\n積水ハウスシャーメゾンPM中国四国、瀬戸内マリンホテル、大東建託グループ、大和リビング、<br />\r\nネッツトヨタ岡山、白十字、ファジアーノ岡山スポーツクラブ、万成病院、三宅医院、<br />\r\nヤクルト岡山販売、両備グループ</td>\n\t\t\t\t\t\t\t</tr>\n\t\t\t\t\t\t</tbody>\n\t\t\t\t\t</table>\n\t\t\t\t\t<div class=\"wrapper\">\n\t\t\t\t\t\t<iframe src=\"https://www.google.com/maps/embed?pb=!1m14!1m8!1m3!1d13133.654517945233!2d133.9674535!3d34.6189862!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0xf85efd7a5ee50b32!2z5qCq5byP5Lya56S-5bu6576O6KOF56S-!5e0!3m2!1sja!2sjp!4v1561115367644!5m2!1sja!2sjp\" width=\"1100\" height=\"450\" frameborder=\"0\" style=\"border:0\" allowfullscreen></iframe>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\t</section>\n</div>\n</main>\n<footer>\n<div id=\"foot\">\n\t<div class=\"bg1 c0\"><div class=\"center3\">\n\t\t<div class=\"row no-gutters\">\n\t\t\t<div class=\"col-sm-4\">\n\t\t\t\t<h5>株式会社建美装社</h5>\n\t\t\t\t<address>〒702-8005 岡山県岡山市中区江崎724-5<br>TEL：<span class=\"tel\" data-tel=\"086-277-1112\">086