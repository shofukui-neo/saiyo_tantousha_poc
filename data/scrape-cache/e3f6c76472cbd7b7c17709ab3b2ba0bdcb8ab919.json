{"url":"https://www.michinoku-kubota.co.jp/recruitment/index.html","html":"<!doctype html>\n<html lang=\"ja\">\n<head>\n<meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\" />\n<meta http-equiv=\"Content-Script-Type\" content=\"text/javascript\"/>\n<meta http-equiv=\"Content-Style-Type\" content=\"text/css\" />\n<meta name=\"Keywords\" content=\"トラクタ,田植機,コンバイン,岩手県,岩手,青森県、青森、農業機械,農機,農機具,耕運機,クボタ,クボタ農機\">\n<meta name=\"Description\" content=\"岩手県・青森県でクボタ農業機械の販売・整備などを行っているみちのくクボタのホームページです。中古農機も取扱。\">\n<link rel=\"shortcut icon\" href=\"https://www.michinoku-kubota.co.jp/shared_new/imgs/favicon.ico\">\n\n<!-- ▼ページアーカイブの場合 -->\n  <title>採用情報 | みちのくクボタ | 岩手県 青森県 クボタ 農業機械</title>\n\n\n\n\n\n<link rel=\"stylesheet\" href=\"https://www.michinoku-kubota.co.jp/shared_new/css/import.css\" type=\"text/css\" media=\"screen, print\">\n\n<script type=\"text/javascript\" src=\"https://www.michinoku-kubota.co.jp/shared_new/js/mjl.js\"></script><!-- ロールオーバー？？ -->\n<script type=\"text/javascript\" src=\"https://www.michinoku-kubota.co.jp/shared_new/js/run.js\"></script><!-- ロールオーバー？？ -->\n<script type=\"text/javascript\" src=\"https://www.michinoku-kubota.co.jp/shared_new/js/footer.js\"></script><!-- コピーライト -->\n\n<script type=\"text/javascript\" src=\"https://www.michinoku-kubota.co.jp/sliderpro/libs/jquery-1.11.0.min.js\"></script>\n<!--script type=\"text/javascript\" src=\"https://www.michinoku-kubota.co.jp/shared_new/js/jquery.js\"></script-->\n\n\n<!-- 新着の時のBOX色変えとスライダー -->\n<script type=\"text/javascript\">\n<!--\n$(document).ready(function() {\nvar linkboxes = $(\".ind_news\");\nfor (var i=0; i<linkboxes.length; i++){\n{\n$(\".ind_news\").click(function() {\nvar anchorTags = this.getElementsByTagName(\"a\");\nwindow.location = anchorTags[0].href;\n});\n}\n}\n$(\".ind_news\").hover(function(){\n$(this).addClass(\"box_hover\");\t\n},\nfunction(){\n$(this).removeClass(\"box_hover\");\t\n});\n});\t\n-->\n</script>\n\n<!--google-analytics-->\n<!-- Google tag (gtag.js) -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-RW6MB36Y6N\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'G-RW6MB36Y6N');\n</script>\n<!--//google-analytics-->\n\n\n<script type=\"text/javascript\" src=\"https://www.michinoku-kubota.co.jp/shared_new/js/rollover.js\"></script>\n\n<!--script type=\"text/javascript\" src=\"https://www.michinoku-kubota.co.jp/shared_new/js/jquery-1.3.2.min.js\"></script-->\n\n\n<script type=\"text/javascript\" src=\"https://www.michinoku-kubota.co.jp/shared_new/js/scrolltopcontrol.js\" charset=\"utf-8\"></script>\n\n<!--script type=\"text/javascript\" src=\"https://www.michinoku-kubota.co.jp/shared_new/js/icon.js\"></script-->\n\n\n\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1.0,minimum-scale=1.0\">\n<link rel=\"stylesheet\" href=\"https://www.michinoku-kubota.co.jp/css/style.css\">\n<link href=\"https://www.michinoku-kubota.co.jp/css/style-s.css\" rel=\"stylesheet\" type=\"text/css\" media=\"only screen and (max-width:480px)\">\n<link href=\"https://www.michinoku-kubota.co.jp/css/style-m.css\" rel=\"stylesheet\" type=\"text/css\" media=\"only screen and (min-width:481px) and (max-width:800px)\">\n<!--[if lt IE 9]>\n<script src=\"http://html5shiv.googlecode.com/svn/trunk/html5.js\"></script>\n<![endif]-->\n<!--script type=\"text/javascript\" src=\"js/openclose.js\"></script-->\n\n\n<!--script type=\"text/javascript\" src=\"shared_new/js/jquery.min.js?ver=3.8.1\"></script-->\n<!--[if lt IE 9]>\n<script src=\"http://css3-mediaqueries-js.googlecode.com/svn/trunk/css3-mediaqueries.js\"></script>\n<![endif]-->\n<script type=\"text/javascript\" src=\"https://www.michinoku-kubota.co.jp/shared_new/js/menubar_hdr.js\"></script>\n\n\n<link rel=\"stylesheet\" type=\"text/css\" href=\"https://www.michinoku-kubota.co.jp/sliderpro/dist/css/slider-pro.min.css\" media=\"screen\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"https://www.michinoku-kubota.co.jp/sliderpro/libs/fancybox/jquery.fancybox.css\" media=\"screen\"/>\n\n\n<script type=\"text/javascript\" src=\"https://www.michinoku-kubota.co.jp/sliderpro/dist/js/jquery.sliderPro.min.js\"></script>\n<script type=\"text/javascript\" src=\"https://www.michinoku-kubota.co.jp/sliderpro/libs/fancybox/jquery.fancybox.pack.js\"></script>\n\n\n<script type=\"text/javascript\">\t\n\t$( document ).ready(function( $ ) {\n\t\t$( '#wide' ).sliderPro({\n\t\t\twidth: 900,\n\t\t\theight: 300,\n    arrows: true,//左右の矢印\n    buttons: true,//ナビゲーションボタン\n    slideDistance:0,//スライド同士の距離\n\tvisibleSize: '100%',//前後のスライドを表示\n\tforceSize: 'fullWidth'\n  });\n});\n</script>\n\n<script>\n    $(function(){\n        if($(window).width() > 800) { // ウインドウサイズの幅が767ピクセルよりも大きい場合\n            $(\"#wide .sp-slide a\").each(function(){\n                $(this).addClass(\"sp-selectable\").css(\"cursor\",\"pointer\");\n            });\n        }\n    });\n</script>\n\n<script type=\"text/javascript\">\t\n\t$( document ).ready(function( $ ) {\n\t\t$( '#wide2' ).sliderPro({\n\t\t\twidth: 175,\n\t\t\theight: 60,\n    arrows: true,//左右の矢印\n    buttons: false,//ナビゲーションボタン\n    slideDistance:30,//スライド同士の距離\n\tvisibleSize: '100%',//前後のスライドを表示\n  });\n});\n</script>\n\n\n    <script type=\"text/javascript\" src=\"https://www.michinoku-kubota.co.jp/shared_new/js/jquery.rwdimagemaps.js\"></script>\n    <script>\n      $(document).ready(function(e) {\n        $('img[usemap]').rwdImageMaps();\n      });\n    </script>\n\n\n<script type=\"text/javascript\" src=\"https://www.michinoku-kubota.co.jp/shared_new/js/html5shiv.js\"></script>\n<script type=\"text/javascript\" src=\"https://www.michinoku-kubota.co.jp/shared_new/js/respond.src.js\"></script>\n\n\n</head>\n\n\n<body>\n<a name=\"pagetop\" id=\"pagetop\"></a>\n\n<div id=\"page-top\">\n<div id=\"header\" class=\"contentsWidth iconno\">\n<header>\n<h1 id=\"ci\"><a href=\"https://www.michinoku-kubota.co.jp/index.html\"><img src=\"https://www.michinoku-kubota.co.jp/shared_new/imgs/page-top/header/logo_all.gif\" alt=\"岩手県・青森県におけるクボタ農業機械販売会社　みちのくクボタ\" ></a></h1>\n\n<div class=\"utility\">\n<form name=\"search_form\" method=\"get\" action=\"https://www.google.co.jp/search\">\n<input type=\"hidden\" name=\"hl\" value=\"ja\" />\n<input type=\"hidden\" name=\"sitesearch\" value=\"www.michinoku-kubota.co.jp/\" />\n<input type=\"hidden\" name=\"ie\" value=\"UTF-8\" />\n<input type=\"hidden\" name=\"oe\" value=\"UTF-8\" />\n<fieldset id=\"site-search\">\n<legend>サイト内検索</legend>\n<p><label><img src=\"https://www.michinoku-kubota.co.jp/shared_new/imgs/page-top/header/label_site-search.gif\" class=\"ss-label\" alt=\"サイト内検索\" width=\"70\" height=\"12\"><input id=\"i_search_input\" class=\"ss-query txtmode1\" type=\"text\" name=\"q\" value=\"\"></label><input class=\"ss-button\" type=\"image\" name=\"btnG\" src=\"https://www.michinoku-kubota.co.jp/shared_new/imgs/page-top/header/btn_site-search.gif\" alt=\"検索\"></p>\n</fieldset>\n</form>\n\n<div class=\"utility-inner\">\n<ul class=\"nav\">\n<li><a href=\"http://www.kubota.co.jp/\" target=\"_blank\">クボタ・ホーム</a></li>\n</ul>\n\n<div id=\"information\" class=\"roll\"> <a href=\"https://www.michinoku-kubota.co.jp/inquiry/index.html\"><img src=\"https://www.michinoku-kubota.co.jp/shared_new/imgs/page-top/header/bg_information.gif\" alt=\"お問い合わせ\" width=\"96\" height=\"22\"></a>\n</div>\n</div><!-- /.utility-inner -->\n</div><!-- /.utility -->\n<hr>\n</header>\n<!-- ========== End Header ========== -->\n</div><!--/header-->\n\n<div class=\"contentsWidth2\">\n<nav id=\"menu\">\n<ul id=\"menubar\" class=\"clearfix\">\n<li><a href=\"https://www.michinoku-kubota.co.jp/news/index.html\" title=\"お知らせ\">お知らせ</a></li>\n<li><a href=\"https://www.michinoku-kubota.co.jp/event/index.html\" title=\"イベント情報\">イベント情報</a></li>\n<li><a href=\"https://www.michinoku-kubota.co.jp/outline/index.html\" title=\"会社案内\">会社案内</a></li>\n<li><a href=\"https://www.michinoku-kubota.co.jp/office/index.html\" title=\"営業店案内\">営業店案内</a></li>\n<li><a href=\"https://www.michinoku-kubota.co.jp/products/index.html\" title=\"製品情報\">製品情報</a></li>\n<li><a href=\"https://www.michinoku-kubota.co.jp/recruitment/index.html\" title=\"採用情報\">採用情報</a></li>\n<li><a href=\"https://www.michinoku-kubota.co.jp/blog/index.html\" title=\"社員ブログ\">社員ブログ</a></li></ul></nav>\n</div>\n</div>\n<!--$mt:Include module=\"0201サイド\"$-->\n<!--$mt:Include module=\"0301メイン_ページタイトル\"$-->\n<article>\n<div class=\"main_bg\">\n\n<!-- ********************** Begin Promotion ********************** -->\n<div id=\"maint\">\n<div class=\"contentsWidth position_r\">\n<h1 class=\"title\">採用情報</h1>\n</div>\n</div>\n<!-- ********************** End Promotion ********************** -->\n\n\n\n\n\n\n\n\n<div class=\"contentsWidth main_box clearfix\">\n\n<a name=\"index000\" id=\"index001\"></a>\n<h2>新卒採用情報・エントリーはマイナビよりお願いします。</h2>\n\n<div class=\"main_box_in\">\n<p class=\"al_c\">\n<a href=\"https://job.mynavi.jp/26/pc/search/corp222316/outline.html\" target=\"_blank\">\n<img src=\"https://job.mynavi.jp/conts/kigyo/2026/logo/banner_logo_195_60.gif\" alt=\"マイナビ2026\" border=\"0\">\n</a>\n</p>\n</div>\n\n\n<br clear=\"all\">\n\n<a name=\"index01\" id=\"index01\"></a>\n<h2>募集要項</h2>\n\n<div class=\"main_box_in\">\n\n<img src=\"imgs/ksas.png\" alt=\"\" class=\"f_r ml_20 mb_none\">\n<h5>一番大切なのは、「日本の農業を自分の力で応援したい！」 <br>\nそんな情熱を持って、じっくりと努力できる方を求めています。\n\n</h5>\n<p>充実した研修やマンツーマンの指導で、必要な専門知識は実践的に身につけて頂きます。\n\n <br>\nまた必要な資格は会社で取得サポートをしています。\n\n</p>\n\n<p><strong>意欲あふれる若い力を求めています！</strong></p>\n\n<br>\n\n<table class=\" seminar3\">\n<tr>\n<td scope=\"row\" nowrap>募集職種</td>\n<td>本社スタッフ、農業機械営業・技術スタッフ、建設設計・施工技術スタッフ</td>\n</tr>\n<tr>\n<td scope=\"row\">仕事内容</td>\n<td>各拠店担当地域の農家・販売店を訪問しクボタ農業機械の販売及び整備<br>\n又、営農情報の提供業務など</td>\n</tr>\n<tr>\n<td scope=\"row\">募集人員</td>\n<td>大学卒、短期大学卒、専門学校卒、高卒　/合計２０名</td>\n</tr>\n<tr>\n<td scope=\"row\">資　格</td>\n<td>令和７年度 卒業予定<br />\n正社員（入社より3カ月間試採用）</td>\n</tr>\n<tr>\n<td scope=\"row\">給　与</td>\n<td><!--基本給176,000円(大卒)/166,000円(短大・専門卒)<br />\n別途 通勤手当・資格手当有り-->\n【大学院・大卒】　基本給 240,000円<br />\n【短大・専門卒】　基本給 220,000円<br />\n【高卒】　　　　　基本給 200,000円<br />\n　別途 通勤手当・資格手当有り<br />\n</tr>\n<tr>\n<td scope=\"row\">昇　給</td>\n<td colspan=\"2\">年１回（４月）</td>\n</tr>\n\n<tr>\n<td scope=\"row\">賞　与</td>\n<td colspan=\"2\">年２回（7月、１２月）</td>\n</tr>\n\n<tr>\n<td scope=\"row\">勤務地</td>\n<td>青森県、岩手県、各拠店。\n\n拠店所在地につきましては、<a href=\"../office/index.html\">拠店案内</a>をご覧下さい。\n\n <br />\n2県広域につき（営業拠店多数）転勤有り。\n\n<!--br>\n応募希望の方は、事前にお問い合わせ又は、<a href=\"../entry/index.html\">エントリー</a>下さい。-->\n\n</td>\n</tr>\n\n<tr>\n<td scope=\"row\">勤務時間</td>\n<td colspan=\"2\">8：30～17：15<!--br />\n【農繁期】<br />\n4月16日～5月15日　8：30～18：00<br />\n9月16日～10月15日　8：30～18：00--></td>\n</tr>\n<tr>\n<td scope=\"row\">休　日</td>\n<td colspan=\"2\">土・日・祝日、会社指定日、／年間　115日</td>\n</tr>\n<tr>\n<td scope=\"row\">福利厚生</td>\n<td colspan=\"2\">健康保険、厚生年金、雇用保険、労災保険、企業年金、退職金制度、<br>\n  全国クボタ福祉共済日本生命福祉保険、社用車・制服貸与</td>\n</tr>\n<tr>\n<td scope=\"row\" nowrap=\"nowrap\">企業説明会</td>\n<td colspan=\"2\">随時オンライン実施予定（人事担当者に問合せ願います）<!--2022年4月より随時オンライン実施予定（人事担当者まで問合せ願います）--></td>\n</tr>\n<tr>\n<td scope=\"row\" nowrap=\"nowrap\">入社試験日</td>\n<td colspan=\"2\">追ってご連絡致します。\n\n</td>\n</tr>\n<tr>\n<td scope=\"row\" nowrap=\"nowrap\">会社案内</td>\n<td colspan=\"2\">\n\n<img src=\"../outline/imgs/outline_o.jpg\" width=\"100\" height=\"141\" alt=\"\" style=\"float:left; margin-right:10px;\" /><br clear=\"all\" class=\"pc_none\">\n    <a href=\"../outline/imgs/outline_2026_a4.pdf\" target=\"_blank\"><br />  \n  A4版（PDF：3.82 MB）</a><!--br />\n  <a href=\"../outline/imgs/outline_2025_a3.pdf\" target=\"_blank\">A3版（PDF：2.19 MB）</a--></td>\n</tr>\n</table>\n\n</div>\n\n\n<br clear=\"all\">\n<a name=\"index002\" id=\"index002\"></a>\n<h2>労働施策総合推進法に基づく中途採用比率の公表</h2>\n\n<div class=\"main_box_in\">\n\n<table class=\"seminar1 margin_top_10\">\n<tbody><tr>\n<th>　</th>\n<!--th>2019年度</th-->\n<!--th>2020年度</th-->\n<th>2022年度</th>\n<th>2023年度</th>\n<th>2024年度</th>\n</tr>\n<tr>\n<td>正規雇用労働者の中途採用比率</td>\n<!--td style=\"text-align:right;\">53%</td-->\n<!--td style=\"text-align:right;\">68%</td-->\n<td style=\"text-align:right;\">50%</td>\n<td style=\"text-align:right;\">75%</td>\n<td style=\"text-align:right;\">73%</td>\n</tr>          \n</tbody></table>\n\n<p class=\"al_r\">公表日：2025年1月6日</p>\n</div>\n\n\n<br clear=\"all\">\n<a name=\"index02\" id=\"index02\"></a>\n<h2>お問い合わせ</h2>\n\n<div class=\"main_box_in\">\n\n<table class=\"seminar3\">\n<tr>\n<td scope=\"row\" nowrap style=\"width:4em;\"> 住　所 </td>\n<td>〒025-0003 岩手県花巻市東宮野目第13地割9番地</td>\n</tr>\n<tr>\n<td scope=\"row\">電　話</td>\n<td>0198-23-5321（代表）</td>\n</tr>\n<tr>\n<td scope=\"row\">担　当</td>\n<td>株式会社　みちのくクボタ　人事チーム</td>\n</tr>\n</table>\n\n<!--p class=\"al_c btn01\"><a href=\"information.html\">2017年度採用試験案内</a></p-->\n<!--p class=\"al_c btn01\"><a href=\"../entry/index.html\">エントリー</a></p-->\n<!--p class=\"al_c btn01\"><a href=\"mailto:tk957010@kubota.co.jp\" target=\"_blank\">採用に関するお問い合わせ <img src=\"../shared_new/images/common/icon_mail.gif\" class=\"val_top\" /></a></p-->\n\n</div>\n\n\n<br clear=\"all\">\n<!--div style=\"background-color:#177E85;\">\n<a name=\"index04\" id=\"index04\"></a>\n<h2>社員とお客様と地域の発展のために</h2>\n\n<div class=\"main_box_in\">\n\n<div id=\"left\" class=\"position_r\">\n<p class=\"a_c\"><img src=\"../outline/imgs/s_01_2024.jpg\" alt=\"\"></p>\n</div>\n<div id=\"right_news\" class=\"position_r\">\n<h5 class=\"margin_top_20 tc_white\">■ セールススタッフ</h5>\n<p class=\"tc_white\">どんなに高度な最先端の機械も、使う人の役に立たなくては、良い機械であるとは言えません。当社のセールススタッフは、単に機械の販売だけでなく、展示会や実演会を通しての新機種、新技術の提供、お客様にとって何が最適機種であるかのご提案、使い方のアドバイス、さらには新しい農業経営のコンサルタントまで、多彩な活動をしています。地域の人々に信頼されるパートナーとして、日々のふれあいを大切に、お客様との心の繋がりを深めています。</p>\n</div>\n<br clear=\"all\">\n<hr class=\"dotted\">\n\n<div id=\"left\" class=\"position_r\">\n<p class=\"a_c\"><img src=\"../outline/imgs/s_02_2024.jpg\" alt=\"\"></p>\n</div>\n<div id=\"right_news\" class=\"position_r\">\n<h5 class=\"tc_white\">■ サービススタッフ</h5>\n<p class=\"tc_white\">信頼される技術とサービスでお客様や地域の発展に貢献します。これが当社の使命です。このため、機械の納品後は、機能保持のために定期的な点検や補修などを積極的に実施。万一作業中に機械が故障した場合も、作業が遅れないように万全の整備体制をとっています。これらのきめ細かなメンテナンスサービスは、お客様の信頼を高める源となっています。</p>\n</div>\n<br clear=\"all\">\n<hr class=\"dotted\">\n\n<div id=\"left\" class=\"position_r\">\n<p class=\"a_c\"><img src=\"../outline/imgs/s_03_2024.jpg\" alt=\"\"></p>\n</div>\n<div id=\"right_news\" class=\"position_r\">\n<h5 class=\"tc_white\">■ 間接スタッフ</h5>\n<p class=\"tc_white\">間接部門は、いわば会社の潤滑油。社員がそれぞれの部署でスムーズに仕事ができるように社内全体をサポートしています。管理本部は総務、経理、人事、教育を、CSR本部は安全衛生推進、CSR・ブランディング推進、監査業務を行っています。その他、営業企画部、サービス推進部、業務部があり、それぞれ幅広い仕事をしています。また、展示会や実演会などの営業活動の応援等も行っています。</p>\n</div>\n<br clear=\"all\">\n<hr class=\"dotted\">\n\n<div id=\"left\" class=\"position_r\">\n<p class=\"a_c\"><img src=\"../outline/imgs/s_04_2024.jpg\" alt=\"\"></p>\n</div>\n<div id=\"right_news\" class=\"position_r\">\n<h5 class=\"tc_white\">■ 建設事業本部スタッフ</h5>\n<p class=\"tc_white\">地域密着型の営業活動で、公共工事、大型商業施設など様々なお客様のニーズに応える建設工事を行っています。主に設備工事（ポンプ、空調）を取扱い、メンテナンス対応まで、信頼される品質の提供を心がけ、お客様との繋がりをより強固なものとしています。</p>\n</div>\n<br clear=\"all\">\n\n</div>\n\n\n<br clear=\"all\">\n</div-->\n\n<!--a name=\"index05\" id=\"index05\"></a>\n<h2>真心と技術で郷土を拓く人財（材）教育</h2>\n\n<div class=\"main_box_in\">\n<h5>● 入社3年プログラム</h5>\n<p>人こそ企業の宝であり、成長の原動力です。\n\n<br>\n当社は、社員一人一人が個性と能力を最大限に発揮できるような人材育成プログラムを積極的に採用しています。実力が芽ぶくまで、水も肥料も提供し、成長するのをあたたかく見守ります。</p>\n<br>\n<h5>● ステップアッププログラム</h5>\n<p>さらに、ステップアップを目指す社員のために、階層別研修会や営業研修会、サービス研修会、製品研修会などを積極的に実施。\n\nチャンスの場を数多く用意しています。\n\n<br>\n人間の成長という大きなフィールドに立って万全の教育環境を提供したい、これが当社の思いです。\n\n</p>\n<br>\n<p class=\"a_c\"><img src=\"../outline/imgs/education_2024.jpg\" alt=\"\"></p>\n<p class=\"a_c more\"><a href=\"../outline/imgs/education.pdf\" target=\"_blank\" class=\"icon_pdf\">教育プログラム概念図</a></p>\n</div-->\n\n\n\n\n\n</div>\n\n<!--div class=\"more\"><a href=\"javascript:history.back();\">一つ前のページへ戻る</a></div-->\n<br clear=\"all\">\n\n\n\n</div>\n\n</article>\n\n\n<!--$mt:Include module=\"parts_ページの先頭へ\"$-->\n&nbsp;\n<!--//main-->\n<!--/div-->\n\n<div class=\"contentsWidth\">\n<section>\n<ul class=\"fbtn\">\n<li><a href=\"http://www.kubota.co.jp//\" title=\"KUBOTA\" target=\"_blank\"><img src=\"https://www.michinoku-kubota.co.jp/shared_new/imgs/page-bottom/fbtn01.jpg\" alt=\"KUBOTA\" class=\"rover\" /></a></li>\n<li><a href=\"https://agriculture.kubota.co.jp/\" title=\"農業ソリューション製品サイト\" target=\"_blank\"><img src=\"https://www.michinoku-kubota.co.jp/shared_new/imgs/page-bottom/fbtn02n.jpg\" alt=\"農業ソリューション製品サイト\" class=\"rover\" /></a></li>\n<li><a href=\"http://www.kubota-spears.com/\" title=\"KUBOTA Spears\" target=\"_blank\"><img src=\"https://www.michinoku-kubota.co.jp/shared_new/imgs/page-bottom/fbtn03.jpg\" alt=\"KUBOTA Spears\" class=\"rover\" /></a></li>\n</ul>\n</section>\n</div>\n\n\n\n<br clear=\"all\">\n\n<footer>\n<!-- ********************** Begin Page Bottom ********************** -->\n<div id=\"page-bottom\" class=\"contentsWidth\">\n\n<!-- ========== Begin Footer ========== -->\n<div id=\"footer\">\n\n<div class=\"pc_none\">\n<ul id=\"footbtn\" class=\" clearfix\">\n<li class=\"line\"><a href=\"https://www.michinoku-kubota.co.jp/inquiry/index.html\">お問い合わせ</a></li>\n<li><a href=\"https://www.michinoku-kubota.co.jp/sitemap/index.html\">サイトマップ</a></li><br>\n\n<li class=\"line\"><a href=\"https://www.michinoku-kubota.co.jp/maintenance/index.html\">点検・整備</a></li>\n<li><a href=\"https://www.michinoku-kubota.co.jp/hureai-club/index.html\">ふれあいクラブ</a></li><br>\n\n<li class=\"line\"><a href=\"https://www.michinoku-kubota.co.jp/notice/index.html\">ご利用にあたって</a></li>\n<li><a href=\"https://www.michinoku-kubota.co.jp/privacypolicy/index.html\">プライバシーポリシー</a></li>\n</ul>\n</div>\n\n<br clear=\"all\">\n\n\n\n\n<ul class=\"nav mb_none\">\n<li><a href=\"https://www.michinoku-kubota.co.jp/notice/index.html\">ご利用にあたって</a></li>\n<li><a href=\"https://www.michinoku-kubota.co.jp/privacypolicy/index.html\">プライバシーポリシー</a></li>\n<li class=\"last\"><a href=\"https://www.michinoku-kubota.co.jp/sitemap/index.html\">サイトマップ</a></li>\n</ul><!-- /.nav -->\n\n<p id=\"logo\"><img src=\"https://www.michinoku-kubota.co.jp/shared_new/imgs/page-bottom/footer/logo.gif\" alt=\"株式会社 みちのくクボタ\" height=\"24\"></p>\n\n<p id=\"copyright\"><script type=\"text/javascript\">cprt();</script></p>\n</div><!-- /#footer -->\n\n<!-- ========== End Footer ========== -->\n\n</div><!-- /#page-bottom -->\n<!-- ********************** End Page Bottom ********************** -->\n</footer>\n\n\n\n\n\n\n\n\n<img src=\"https://www.michinoku-kubota.co.jp/images_new/icon_bar.png\" width=\"20\" height=\"16\" alt=\"\" id=\"menubar_hdr\" class=\"close\" />\n\n\n</body></html>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n","finalUrl":"https://www.michinoku-kubota.co.jp/recruitment/index.html","rendered":false,"_cachedAt":"2026-06-17T23:28:44.149Z"}