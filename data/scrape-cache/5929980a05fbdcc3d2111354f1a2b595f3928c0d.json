{"url":"http://www.clg.co.jp/contact/","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n<head>\n<meta charset=\"utf-8\">\n<meta http-equiv=\"Content-Script-Type\" content=\"text/javascript\" />\n<meta http-equiv=\"Content-Style-Type\" content=\"text/css\" />\n<meta name=\"keywords\" content=\"クラウン警備保障,クラウン,警備,警備会社,clg,松阪,三重,セキュリティ,ホームセキュリティ,オフィスセキュリティ,交通誘導,イベント警備,施設警備,機械警備,身辺警備,駐車場警備,警備員,防犯,防犯対策,防犯グッズ,防災\" />\n<meta name=\"description\" content=\"株式会社クラウン警備保障\" />\n<title>お問い合わせ | ひなた園</title>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"index.css\" />\n</head>\n<body>\n\n<div id=\"container\">\n\n<!-- ### headerArea Start ################################################################################################### -->\n<div id=\"headerArea\">\n<div id=\"headerUniword\"><a name=\"top\" id=\"top\"></a></div>\n\n<div id=\"headerTitle\">\n<h1>サービス付高齢者向け住宅・デイサービス・訪問介護事業所・居宅介護支援事業所  [ひなた園]  松阪市</h1>\n</div><!-- end headerTitle -->\n<div id=\"headerLogo\"><a href=\"../\"><img src=\"../images/common/header_logo.png\" width=\"304\" height=\"128\" alt=\"ひなた園\" /></a></div>\n<div id=\"headerSubMenu\">\n<a href=\"../contact/\"><img src=\"../images/common/header_contact.png\" onmouseover=\"this.src='../images/common/header_contact_over.png'\" onmouseout=\"this.src='../images/common/header_contact.png'\" width=\"128\" height=\"106\" alt=\"資料請求\" /></a>\n</div><!-- end headerSubMenu -->\n</div><!-- end headerArea -->\n\n<div id=\"headerMenu\">\n<ul class=\"clearfix\">\n<li><a href=\"../\"><img src=\"../images/common/menu01.png\" onmouseover=\"this.src='../images/common/menu01_over.png'\" onmouseout=\"this.src='../images/common/menu01.png'\" width=\"140\" height=\"50\" alt=\"ホーム\" /></a></li>\n<li><a href=\"../about/\"><img src=\"../images/common/menu02.png\" onmouseover=\"this.src='../images/common/menu02_over.png'\" onmouseout=\"this.src='../images/common/menu02.png'\" width=\"160\" height=\"50\" alt=\"ひなた園について\" /></a></li>\n<li><a href=\"../guide/\"><img src=\"../images/common/menu03.png\" onmouseover=\"this.src='../images/common/menu03_over.png'\" onmouseout=\"this.src='../images/common/menu03.png'\" width=\"160\" height=\"50\" alt=\"施設のご案内\" /></a></li>\n<li><a href=\"../service/\"><img src=\"../images/common/menu04.png\" onmouseover=\"this.src='../images/common/menu04_over.png'\" onmouseout=\"this.src='../images/common/menu04.png'\" width=\"160\" height=\"50\" alt=\"サービス内容\" /></a></li>\n<li><a href=\"../price/\"><img src=\"../images/common/menu05.png\" onmouseover=\"this.src='../images/common/menu05_over.png'\" onmouseout=\"this.src='../images/common/menu05.png'\" width=\"160\" height=\"50\" alt=\"ご利用料金\" /></a></li>\n<li><a href=\"../kids/\"><img src=\"../images/common/menu06.png\" onmouseover=\"this.src='../images/common/menu06_over.png'\" onmouseout=\"this.src='../images/common/menu06.png'\" width=\"160\" height=\"50\" alt=\"キッズクラブ\" /></a></li>\n</ul>\n</div><!-- end headerMenu -->\n\n<!-- ### Header End ####################################################################################################### -->\n\n<!-- ### bodyArea Start ##################################################################################################### -->\n<div id=\"bodyImage\">\n<img src=\"images/title.png\" width=\"940\" height=\"100\" />\n</div>\n\n<div id=\"bodyArea\">\n<div id=\"bodyConts\">\n\n<div id=\"bodyConts_Box01\">\n\n<form id=\"form1\" name=\"form1\" method=\"post\" action=\"contact_check.php\">\n<table cellpadding=\"0\" cellspacing=\"1\" border=\"0\" class=\"table_contact\">\n    <tr>\n        <th width=\"200\">お名前<span>&nbsp;（必須）</span></th>\n        <td><input type=\"text\" name=\"namae\" id=\"namae\" size=\"50\" /></td>\n    </tr>\n    <tr>\n        <th>ふりがな<span>&nbsp;（必須）</span></th>\n        <td><input type=\"text\" name=\"namaef\" id=\"namaef\" size=\"50\" /></td>\n    </tr>\n    <tr>\n        <th>会社名</th>\n        <td><input type=\"text\" name=\"company\" id=\"company\" size=\"50\" /></td>\n    </tr>\n    <tr>\n        <th>電話番号<span>&nbsp;（必須）</span></th>\n        <td><input type=\"text\" name=\"tel\" id=\"tel\" size=\"25\" /></td>\n    </tr>\n    <tr>\n        <th>FAX番号<span></span></th>\n        <td><input type=\"text\" name=\"fax\" id=\"fax\" size=\"25\" /></td>\n    </tr>\n    <tr>\n        <th>メールアドレス<span>&nbsp;（必須）</span></th>\n        <td><input type=\"text\" name=\"mail\" id=\"mail\" size=\"50\" /></td>\n    </tr>\n    <tr>\n        <th>郵便番号</th>\n        <td>〒 <input type=\"text\" name=\"zip\" id=\"zip\" size=\"20\" /></td>\n    </tr>\n    <tr>\n        <th>ご住所<span>&nbsp;（必須）</span></th>\n        <td><input type=\"text\" name=\"address\" id=\"address\" size=\"50\" /></td>\n    </tr>\n    <tr>\n        <th>内容<span>&nbsp;（必須）</span></th>\n        <td>\n        <select id=\"type\" name=\"type\">\n        <option value=\"ひなた園について\">ひなた園について</option>\n        <option value=\"入居者について\">入居者について</option>\n        <option value=\"デイサービスについて\">デイサービスについて</option>\n        <option value=\"キッズクラブひなたについて\">キッズクラブひなたについて</option>\n        <option value=\"会社について\">会社について</option>\n        <option value=\"その他\">その他</option>\n        </select>\n        </td>\n    </tr>\n    <tr>\n        <th>本文<span>&nbsp;（必須）</span></th>\n        <td><textarea name=\"naiyo\" id=\"naiyo\" rows=\"15\" cols=\"50\" /></textarea></td>\n    </tr>\n</table>\n<p>\n    <input class=\"contact_bt\" name=\"button1\" type=\"reset\" value=\"　リセット　\" />\n    　　\n    <input class=\"contact_bt\" name=\"button2\" type=\"submit\" value=\"　確　認　\"  />\n</p>\n</form>    \n\n\n</div><!-- end bodyConts_Box01 -->\n\n</div><!-- end bodyConts -->\n</div><!-- end bodyArea -->\n<!-- ### bodyArea End ####################################################################################################### -->\n\n<!-- ### footerArea Start ################################################################################################### -->\n<div id=\"footerSquare\">\n<div id=\"footerSquare_box01\">\n<a href=\"../sitemap/\">サイトマッ