{"url":"https://www.miyagi-hino.co.jp/recruit/","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=1240\">\n<meta name=\"format-detection\" content=\"telephone=no\">\n<meta name=\"description\" content=\"宮城日野自動車株式会社の採用情報をご紹介します。地域社会の一員として、トラック・バスの販売、整備、部品販売などトータルサポートを担う仕事です。\">\n<!-- OGP -->\n<meta property=\"og:type\" content=\"article\" />\n<meta property=\"og:title\" content=\"採用情報 | 宮城日野自動車株式会社\" />\n<meta property=\"og:description\" content=\"宮城日野自動車株式会社の採用情報をご紹介します。地域社会の一員として、トラック・バスの販売、整備、部品販売などトータルサポートを担う仕事です。\"/>\n<meta property=\"og:site_name\" content=\"宮城日野自動車株式会社\" />\n<meta property=\"og:url\" content=\"https://www.miyagi-hino.co.jp/\" />\n<meta property=\"og:image\" content=\"https://www.miyagi-hino.co.jp/images/og_image.png\"/>\n<!-- /OGP -->\n<title>採用情報 | 宮城日野自動車株式会社</title>\n<meta name=\"author\" content=\"宮城日野自動車株式会社\">\n<link rel=\"icon\" href=\"/images/favicon.ico\">\n<link rel=\"apple-touch-icon\" sizes=\"180x180\" href=\"/images/apple-touch-icon.png\">\n<link rel=\"stylesheet\" href=\"../css/base.css\">\n<link rel=\"stylesheet\" href=\"../css/vibit.css\">\n<link rel=\"stylesheet\" href=\"../css/pc.css\">\n<script src=\"https://webfont.fontplus.jp/accessor/script/fontplus.js?hWxdSd~4aRo%3D&box=AvrnYVleYb0%3D&aa=1&ab=2\"></script>\n<link rel=\"stylesheet\" href=\"https://kit.fontawesome.com/e2fcfcabc1.css\" crossorigin=\"anonymous\">\n<!-- Google tag (gtag.js) -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-J8L860N1V8\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n  gtag('config', 'G-J8L860N1V8');\n</script>\n</head>\n<body>\n<header class=\"frame-header hide inactive\" id=\"VcArea-Header\">\n  <div class=\"frame-header-inside\">\n    <h1 class=\"mod-header-siteid\"><a href=\"../index.html\"><img src=\"../vc-files/miyagi/common/logo.png\" width=\"347\" height=\"45\" alt=\"宮城日野自動車株式会社\" /></a></h1>\n    <div id=\"nav-main-button\">\n      <button type=\"button\" aria-controls=\"nav-main-showhide\" aria-expanded=\"false\"><span class=\"nav-main-button-icon\"><span class=\"label-menu\">メニュー</span><span class=\"label-close\">閉じる</span></span></button>\n    </div>\n    <div class=\"frame-header-nav nav-main-showhide\">\n      <nav class=\"mod-header-nav\" aria-label=\"メインメニュー\">\n                <ul class=\"nav-main-list\">\n          <li id=\"news\"><a href=\"../news/index.html\">お知らせ</a></li>\n          <li id=\"company\"><a href=\"../company/index.html\">会社案内</a></li>\n          <li id=\"branch\"><a href=\"../branch/index.html\">支店・営業所</a></li>\n          <li id=\"chuko\"><a href=\"/lease/miyagi/\">リース商品のご案内</a></li>\n          <li id=\"after-service\"><a href=\"../service/index.html\">整備料金表</a></li>\n          <li id=\"recruit\"><a href=\"../insurance/index.html\">保険案内</a></li>\n          <li id=\"recruit\"><a href=\"../recruit/index.html\">採用情報</a></li>\n          <li id=\"csr\"><a href=\"../csr/index.html\">CSR</a></li>\n        </ul>\n        <ul class=\"nav-sub-list\">\n                          \n        <li class=\"nav-sub-item icon-pdf\"><a href=\"/vc-files/miyagi/common/Calendar2025-2026.pdf\" target=\"_blank\" >営業カレンダー</a></li>\n        </ul>\n      </nav>\n    </div>\n  </div>\n</header>\n<main>\n  <section class=\"frame-pagetitle\">\n    <h1 class=\"pagetitle\"><span>採用情報</span></h1>\n  </section>\n  <div class=\"breadcrumb\">\n<a href=\"../index.html\">ホーム</a>&nbsp;採用情報&nbsp;\n  </div>\n  <div class=\"frame-main frame-2col\">\n    <article class=\"frame-2col-main mod-content frame-recruit\" id=\"VcArea-MainColum\">\n      <div class=\"frame-recruit-mainvis\">\n        <div class=\"mod-recruit-mainvis bg-border-gray\">\n          <h1 class=\"recruit-mainvis-title outline-txt-jp\"><span class=\"txt-nowrap\">地域社会<span class=\"txt-control-reduce\">の</span></span><span class=\"txt-nowrap\">一員として</span></h1>\n          <div class=\"recruit-mainvis-read\">\n            <p>私たち宮城日野自動車は、<span class=\"txt-nowrap\">トラック･バスの販売や整備にとどまらず</span><br>運転の安全講習からお客様の抱える<span class=\"txt-nowrap\">経営課題への解決提案まで、</span><br>トラック･バスのトータルサポートを<span class=\"txt-nowrap\">一手に担います。</span></p>\n            <p>私たち自身も地域社会の一員です。<br>私たちがくらすこの街が、<br>より豊かで住みよくなる未来を<span class=\"txt-nowrap\">一緒に作り上げませんか。</span></p>\n          </div>\n          <div class=\"recruit-mainvis-img recruit-mainvis-img-parts\"><img src=\"../vc-files/common/recruit-parts.svg\" width=\"176\" height=\"162\" alt=\"\" /></div>\n          <div class=\"recruit-mainvis-img recruit-mainvis-img-sales\"><img src=\"../vc-files/common/recruit-sales.svg\" width=\"176\" height=\"162\" alt=\"\" /></div>\n          <div class=\"recruit-mainvis-img recruit-mainvis-img-service\"><img src=\"../vc-files/common/recruit-service.svg\" width=\"176\" height=\"162\" alt=\"\" /></div>\n          <div class=\"recruit-mainvis-img recruit-mainvis-img-office\"><img src=\"../vc-files/common/recruit-office.svg\" width=\"176\" height=\"162\" alt=\"\" /></div>\n        </div>\n      </div>\n      <div class=\"lead\">\n        <p><strong>現在、下記の職種を募集中です</strong></p>\n        <p><strong>詳細は募集要項をご覧ください</strong></p>\n      </div>\n      <h1>新卒採用</h1>\n      <div class=\"frame-card\">\n      <div class=\"card-item \">\n        <h2>総合職（営業）</h2>\n        <div>\n          <p>車両営業職　正社員</p>\n        </div>\n        <p class=\"link-btn icon-arrow-right\"><a href=\"../recruit/guideline/index.html\" target=\"_self\" title=\"新卒採用の募集要項\">募集中</a></p>\n      </div>\n      <div class=\"card-item \">\n        <h2>総合職（部品）</h2>\n        <div>\n          <p></p>\n        </div>\n        <p class=\"link-btn icon-arrow-right\">下記総務部までお問合せ下さい</p>\n      </div>\n      <div class=\"card-item \">\n        <h2>総合職（事務）</h2>\n        <div>\n          <p></p>\n        </div>\n        <p class=\"link-btn icon-arrow-right\"><a href=\"../recruit/guideline/index.html\" target=\"_self\" title=\"新卒採用の募集要項\">募集中</a></p>\n      </div>\n      <div class=\"card-item \">\n        <h2>整備</h2>\n        <div>\n          <p>整備メカニック　正社員</p>\n        </div>\n        <p class=\"link-btn icon-arrow-right\"><a href=\"../recruit/guideline/index.html\" target=\"_self\" title=\"新卒採用の募集要項\">募集中</a></p>\n      </div>\n      </div>\n      <h1>中途採用</h1>\n      <div class=\"frame-card\">\n      <div class=\"card-item \">\n        <h2>総合職（営業）</h2>\n        <div>\n          <p>車両営業職　正社員</p>\n        </div>\n        <p class=\"link-btn icon-arrow-right\"><a href=\"../recruit/guideline/career.html\" target=\"_self\" title=\"中途採用の募集要項\">募集中</a></p>\n      </div>\n      <div class=\"card-item \">\n        <h2>総合職（部品）</h2>\n        <div>\n          <p>商品管理・部品販売</p>\n        </div>\n        <p class=\"link-btn icon-arrow-right\">下記総務部までお問合せ下さい</p>\n      </div>\n      <div class=\"card-item \">\n        <h2>整備</h2>\n        <div>\n          <p>整備メカニック　正社員</p>\n        </div>\n        <p class=\"link-btn icon-arrow-right\"><a href=\"../recruit/guideline/career.html\" target=\"_self\" title=\"中途採用の募集要項\">募集中</a></p>\n      </div>\n      </div>\n    </article>\n      <div class=\"frame-recruit-contact bg-lattice bg-beige\" id=\"VcArea-Saiyou\">\n      <div class=\"mod-recruit-contact bg-border-beige\">\n        <h1 class=\"recruit-contact-title outline-txt-jp\">採用に関するお問い合わせ</h1>\n        <ul>\n                    <li class=\"recruit-contact-tel\"><span class=\"tel\">022-235-3121</span></li>\n          <li class=\"recruit-contact-detail\">総務部総務課まで</li>\n                            </ul>\n        <div class=\"recruit-contact-img recruit-contact-img-left\"><img src=\"../images/recruit-staff-left.svg\" alt=\"\"></div>\n        <div class=\"recruit-contact-img recruit-contact-img-right\"><img src=\"../images/recruit-staff-right.svg\" alt=\"\"></div>\n      </div>\n    </div>\n    <nav class=\"frame-2col-side\" id=\"VcArea-NaviColum\">\n<!-- ▼▼▼ ラベル ▼▼▼ -->\n<ol>\n<li><strong>採用情報</strong>\n<ol>\n<li><a hre