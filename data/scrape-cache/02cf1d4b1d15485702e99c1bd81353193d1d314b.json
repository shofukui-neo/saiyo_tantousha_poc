{"url":"https://www.kurabun.co.jp/recruit/club/","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n<head>\n  \n\n<!-- Google Tag Manager -->\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n})(window,document,'script','dataLayer','GTM-KH94MQH');</script>\n<!-- End Google Tag Manager -->\n\n<!-- Original GA -->\n<script>\n  (function(i,s,o,g,r,a,m){i['GoogleAnalyticsObject']=r;i[r]=i[r]||function(){\n  (i[r].q=i[r].q||[]).push(arguments)},i[r].l=1*new Date();a=s.createElement(o),\n  m=s.getElementsByTagName(o)[0];a.async=1;a.src=g;m.parentNode.insertBefore(a,m)\n  })(window,document,'script','https://www.google-analytics.com/analytics.js','ga');\n\n  ga('create', 'UA-45171911-1', 'auto');\n  ga('send', 'pageview');\n\n</script>\n\n<!-- Google Tag Manager GOFIELD用 -->\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n})(window,document,'script','dataLayer','GTM-TBKXBLM');</script>\n<!-- End Google Tag Manager -->\n\n\n\n\n  <meta charset=\"utf-8\">\n  <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n\n  <title>同好会・部活動 | クラブン株式会社 クラブン株式会社 採用サイト</title>\n\n  <meta name=\"keywords\" content=\"ニュース,プレスリリース,最新情報\">\n  <meta name=\"description\" content=\"定期的に開催されるビジネスソリューションフェアの詳細やお得なキャンペーン情報等をご案内します。\">\n\n  <meta property=\"og:url\" content=\"https://www.kurabun.co.jp/recruit/club/\">\n<meta property=\"og:site_name\" content=\"岡山 倉敷 福山の文具 事務用品 OA機器 オフィスデザインはクラブン\">\n\n\n\n\n\n\n\n<meta property=\"og:title\" content=\"同好会・部活動 | クラブン株式会社 採用サイト 岡山 倉敷 福山の文具 事務用品 OA機器 オフィスデザインはクラブン\">\n<meta property=\"og:type\" content=\"article\">\n<meta property=\"og:image\" content=\"https://www.kurabun.co.jp//themes/recruit/images/img_ogp.jpg\">\n\n\n\n\n\n\n\n\n\n\n  <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n<link href=\"https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;700&display=swap\" rel=\"stylesheet\">\n<link href=\"https://fonts.googleapis.com/css2?family=Barlow+Semi+Condensed:wght@400;500;600;700&display=swap\" rel=\"stylesheet\">\n  <link href=\"/themes/system/css/acms.css?date=20250510022326\" rel=\"stylesheet\">\n<link href=\"/themes/system/css/acms-admin.min.css?date=20250510022326\" rel=\"stylesheet\">\n<link href=\"/recruit/css/base.css\" rel=\"stylesheet\" >\n<link href=\"/recruit/css/common.css\" rel=\"stylesheet\" >\n<link href=\"/recruit/css/layout.css\" rel=\"stylesheet\" >\n<link href=\"/recruit/css/cms.css\" rel=\"stylesheet\">\n<link href=\"https://unpkg.com/aos@2.3.1/dist/aos.css\" rel=\"stylesheet\">\n<link href=\"/recruit/css/extend.css\" rel=\"stylesheet\">\n<link rel=\"canonical\" href=\"https://www.kurabun.co.jp/recruit/club/\">\n\n\n<script type=\"text/javascript\" src=\"/acms.js?uaGroup=PC&amp;domains=www.kurabun.co.jp&amp;jsDir=js/&amp;themesDir=/themes/&amp;bid=17&amp;cid=61&amp;bcd=recruit&amp;googleApiKey=AIzaSyDOdw6NdHNXxmcNRK6N9-Y4aC5jHnMbHCs&amp;jQuery=3.6.1&amp;jQueryMigrate=migrate-3.0.1&amp;mediaClientResize=on&amp;fulltimeSSL=1&amp;v=e6fbc7fd914b6d1dc16345fcd65a80e4&amp;umfs=256M&amp;pms=256M&amp;mfu=20&amp;lgImg=width:1400&amp;jpegQuality=95&amp;mediaLibrary=on&amp;edition=standard&amp;urlPreviewExpire=48&amp;timemachinePreviewDefaultDevice=PC&amp;ccd=club&amp;scriptRoot=/\" charset=\"UTF-8\" id=\"acms-js\"></script>\n\n<script src=\"/js/library/jquery/jquery-3.6.1.min.js\"></script>\n\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1.0,munimun-scale=1.0,maximun-scale=1.0,user-scalable=no\">\n<meta name=\"format-detection\" content=\"telephone=no\">\n<link rel=\"alternate\" type=\"application/rss+xml\" title=\"RSS 2.0\" href=\"https://www.kurabun.co.jp/recruit/rss2.xml\">\n\n  \n<meta name=\"csrf-token\" content=\"41921f39dc55815e8b24e8b5e0ab8a6ba1bd9e2bde92c27e0c3ef011c819167e\"><script type=\"text/javascript\" src=\"/js/dest/vendor.js?date=20250510022324\" charset=\"UTF-8\" async defer></script>\n<script type=\"text/javascript\" src=\"/js/dest/index.js?date=20250510022324\" charset=\"UTF-8\" async defer></script>\n<meta name=\"generator\" content=\"a-blog cms\" />\n</head>\n<body>\n\n\n<!-- Google Tag Manager (noscript) -->\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-KH94MQH\"\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n<!-- End Google Tag Manager (noscript) -->\n\n<!-- Google Tag Manager (noscript) GOFIELD用 -->\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-TBKXBLM\"\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n<!-- End Google Tag Manager (noscript) -->\n\n\n\n<!-- ▼ admin ======================================================= -->\n\n\n\n<!-- ▲ admin ======================================================= -->\n\n<div class=\"body\">\n<div class=\"wrap\">\n\n  <!-- ▼ header ====================================================== -->\n  <header class=\"header\" id=\"header\">\n  \n  <h1 class=\"logo\">\n    <a href=\"https://www.kurabun.co.jp/\"><img src=\"/themes/recruit/images/logo.png\" alt=\"岡山 倉敷 福山の文具 事務用品 OA機器 オフィスデザインはクラブン\"></a><br>\n    <a href=\"https://www.kurabun.co.jp/recruit/\"><img src=\"/themes/recruit/images/logo_sub.png\" alt=\"岡山 倉敷 福山の文具 事務用品 OA機器 オフィスデザインはクラブン\"></a>\n  </h1>\n\n<div class=\"hamburger-btn toggle\" id=\"hamburger-btn\"><span></span></div>\n\n<div class=\"hamburger-menu\" id=\"hamburger-menu\">\n\n  <nav class=\"global-navigation\" id=\"global-nav\">\n    <ul>\n      <li class=\"js-link_match_location\"><a href=\"https://www.kurabun.co.jp/recruit/#anchor_greetings\">代表者メッセージ</a></li>\n      <li class=\"js-link_match_location arrow-bottom\"><input id=\"acd-check1\" class=\"acd-check\" type=\"checkbox\"><label class=\"acd-label\" for=\"acd-check1\">クラブンを知る</label>\n        <div class=\"acd-content\">\n          <div class=\"acd-inner\">\n            <div class=\"cnavi01\"><a href=\"https://www.kurabun.co.jp/recruit/data/\">数字で見るクラブン</a></div>\n            <div class=\"cnavi02\"><a href=\"https://www.kurabun.co.jp/recruit/personnelsystem/\">人事制度（教育制度）</a></div>\n            <div class=\"cnavi03\"><a href=\"https://www.kurabun.co.jp/recruit/club/\">同好会・部活動</a></div>\n            <div class=\"cnavi04\"><a href=\"https://www.kurabun.co.jp/recruit/base/\">各拠点紹介</a></div>\n            <div class=\"cnavi05\"><a href=\"https://www.kurabun.co.jp/recruit/walfare/\">福利厚生</a></div>\n            <div class=\"cnavi06\"><a href=\"https://www.kurabun.co.jp/recruit/csr/\">社会貢献活動</a></div>\n            <div class=\"cnavi07\"><a href=\"https://www.kurabun.co.jp/recruit/environmental-initiatives/\">環境への取り組み</a></div>\n          </div>\n        </div>\n      </li>\n      <li class=\"js-link_match_location arrow-bottom\">\n        <input id=\"acd-check2\" class=\"acd-check\" type=\"checkbox\">\n        <label class=\"acd-label\" for=\"acd-check2\">仕事を知る</label>\n        <div class=\"acd-content\">\n          <div class=\"acd-inner\">\n            <div class=\"cnavi08\"><a href=\"https://www.kurabun.co.jp/recruit/freshers/\">新卒採用</a></div>\n            <div class=\"cnavi09\"><a href=\"https://www.kurabun.co.jp/recruit/careers/\">中途採用</a></div>\n            <div class=\"cnavi10\"><a href=\"https://www.kurabun.co.jp/recruit/part-time/\">アルバイト・パート採用</a></div>\n          </div>\n        </div>\n      </li>\n      <li class=\"js-link_match_location arrow-bottom\">\n        <input id=\"acd-check3\" class=\"acd-check\" type=\"checkbox\">\n        <label class=\"acd-label\" for=\"acd-check3\">募集要項</label>\n        <div class=\"acd-content\">\n          <div class=\"acd-inner\">\n            <div class=\"cnavi08\"><a href=\"https://www.kurabun.co.jp/recruitment/graduate/\">新卒採用</a></div>\n            <div class=\"cnavi09\"><a href=\"https://www.kurabun.co.jp/recruitment/career/\">中途採用</a></div>\n          </div>\n        </div>\n      </li>\n      <!-- <li class=\"js-link_match_location\"><a href=\"https://www.kurabun.co.jp/recruit/requirements/\">募集要項</a></li> -->\n      <li class=\"js-link_match_location\"><a href=\"https://www.kurabun.co.jp/recruit/faq/\">よくある質問</a></li>\n      <li class=\"entry-btn -graduate\"><a href=\"https://www.kurabun.co.jp/recruitment/graduate/\">新卒<br>ENTRY</a></li>\n      <li class=\"entry-btn -career\"><a href=\"https://www.kurabun.co.jp/recruit/entry/\">中途<br>ENTRY</a></li>\n    </ul>\n    \n  <!-- /grobal-navigation--></nav>\n<!-- /hamburger-menu --></div>\n\n</header>\n  <!-- ▲ header ====================================================== -->\n\n  <!-- ▼ title =================================== -->\n  <div class=\"page-title\">\n    <h1>同好会・部活動</h1>\n  </div>\n  <!-- ▲ title =================================== -->\n\n  <!-- ▼ topicpath =============================== -->\n    \n    <div class=\"topic-path\">\n      <ol>\n        <li><a href=\"https://www.kurabun.co.jp/recruit/\">ホーム</a></li>\n        <li><a href=\"https://www.kurabun.co.jp/recruit/club/\">同好会・部活動</a></li>\n        \n      </ol>\n    </div>\n    \n  <!-- ▲ topicpath =============================== -->\n\n  <!-- ▼ container =================================================== -->\n  <div class=\"container\">\n\n  <!-- ▼ content =========================================== -->\n  <div class=\"content\">\n    <div id=\"jsChangeContents\">\n\n      <p class=\"tocHead team\">CLUB<span>部活動</span></p>\n      \n      <ul class=\"toc team\">\n        <li><a href=\"#4440\">野球部</a></li>\n        \n        <li><a href=\"#4433\">Sand&amp;Buggy</a></li>\n        \n      </ul>\n      \n\n      <p class=\"tocHead circle\">SMALL CLUB<span>同好会活動</span></p>\n      \n      <ul class=\"toc circle\">\n        <li><a href=\"#4476\">一流のものにふれる会</a></li>\n        <li><a href=\"#4475\">写真同好会</a></li>\n        <li><a href=\"#4474\">エクストリームスポーツ同好会</a></li>\n        <li><a href=\"#4473\">ちゃりんこ同好会</a></li>\n        <li><a href=\"#4472\">うどん同好会</a></li>\n        <li><a href=\"#4471\">ボウリング同好会</a></li>\n        <li><a href=\"#4470\">ラケット同好会</a></li>\n        <li><a href=\"#4469\">釣り同好会</a></li>\n        <li><a href=\"#4468\">アウトドア同好会\t</a></li>\n        <li><a href=\"#4485\">ゴルフ同好会</a></li>\n      </ul>\n      \n\n\n      \n      <div class=\"teamList\">\n        \n        \n\n        \n        \n          <h2 id=\"4433\">Sand&amp;Buggy</h2>\n        \n          <div class=\"clubBox\">\n            <div class=\"clubBoxImg\">\n              <img src=\"/archives/017/202606/mode3_w593_h350-e6844732713772ede5b7caaca4fa6ab63912d87cb745945e5114afd610aaa58c.jpg\"alt=\"\" />\n            </div>\n            <div class=\"clubBoxTxt\">\n              <div class=\"clubBoxMember\">\n                <img src=\"/archives/017/202111/19a6d74057632f23b204e2a0959bf4c1.jpg\" alt=\"\" />\n                <p>小野さん</p>\n              </div>\n              <p>「音楽を通じて成長する」をコンセプトに月に数回スタジオに入ってバンド練習を行っております。<br />\n現在管楽器メンバーを大募集中！我こそはと思うあなた。<br />\nどしどしご参加ください。一緒に音楽を奏でましょう。</p>\n            </div>\n          </div>\n          <div>\n          \n\n          \n\n          \n          \n\n        </div>\n        \n        \n\n        \n        \n          <h2 id=\"4440\">野球部</h2>\n        \n          <div class=\"clubBox\">\n            <div class=\"clubBoxImg\">\n              <img src=\"/archives/017/202111/mode3_w593_h350-dc5abd900796f03efcde2f1c324cccdf.jpg\"alt=\"\" />\n            </div>\n            <div class=\"clubBoxTxt\">\n              <div class=\"clubBoxMember\">\n                <img src=\"/archives/017/202412/bca8e668753fd702c71d22931b3e783d3b6663e0235a2701de09f685db32669b.png\" alt=\"\" />\n                <p>石井さん</p>\n              </div>\n              <p>野球部は、野球経験者を中心に25名の部員がいます。<br />\n土日に他企業のチームと親善試合をしています。（最近はあまり練習できていません、、）<br />\n野球経験者だけでなく野球が好きな方+マネージャーも募集しています！<br />\n共にいい汗をかきましょう！</p>\n            </div>\n          </div>\n          <div>\n          \n\n          \n\n          \n          \n\n        </div>\n        \n      </div>\n      \n\n\n      \n      <div class=\"circleList\">\n        \n        \n\n        \n        \n          <h2 id=\"4485\">ゴルフ同好会</h2>\n        \n        <div class=\"clubBox\">\n          <div class=\"clubBoxImg\">\n            <img src=\"/archives/017/202112/810c55ce3a46942216e5d838753a25d8.jpg\"alt=\"\" />\n          </div>\n          <div class=\"clubBoxTxt\">\n            <div class=\"clubBoxMember\">\n              <img src=\"/archives/017/202112/2353221ba18b9cc7996f677abfd3181d.jpg\" alt=\"\" />\n              <p>松嶋さん</p>\n            </div>\n            <p>ゴルフ同好会は現在24名で活動しており、年4回春夏秋冬を感じながら大自然の中でコンペを開催しています。<br />\nゴルフ歴、スコア、老若男女関係なく一打一打に一喜一憂しながらも楽しくプレイしています。<br />\nゴルフは自分との戦いです。共に成長しましょう！！！</p>\n          </div>\n        </div>\n        <div>\n          \n\n          \n\n          \n          \n\n        </div>\n        \n        \n\n        \n        \n          <h2 id=\"4468\">アウトドア同好会\t</h2>\n        \n        <div class=\"clubBox\">\n          <div class=\"clubBoxImg\">\n            <img src=\"/archives/\"alt=\"\" />\n          </div>\n          <div class=\"clubBoxTxt\">\n            <div class=\"clubBoxMember\">\n              <img src=\"/archives/017/202111/16530350f11f3a606aaa6a8f6274bf7a.jpg\" alt=\"\" />\n              <p>岩本さん</p>\n            </div>\n            <p>アウトドア同好会では主に県外の様々な<br />\n場所でキャンプを初めとしたアウトドア活動を楽しんでいます！<br />\n様々な部署の方が参加しているので、<br />\n普段は出来ない社内交流が出来るのも魅力の一つです！<br />\n自然、人との交流を楽しみましょう！！</p>\n          </div>\n        </div>\n        <div>\n          \n\n          \n\n          \n          \n\n        </div>\n        \n        \n\n        \n        \n          <h2 id=\"4469\">釣り同好会</h2>\n        \n        <div class=\"clubBox\">\n          <div class=\"clubBoxImg\">\n            <img src=\"/archives/017/202111/6f92c951433b31b178e7867229721d90.jpg\"alt=\"\" />\n          </div>\n          <div class=\"clubBoxTxt\">\n            <div class=\"clubBoxMember\">\n              <img src=\"/archives/017/202111/103da9ee9099e9442860822cee149f98.jpg\" alt=\"\" />\n              <p>小野さん</p>\n            </div>\n            <p>釣り同好会は15名で活動をしています。<br />\n県内はもちろん、県外でも釣りを楽しんでいます。<br />\n釣った魚は数知れず！？<br />\n初心者の方大歓迎！！「試しに・・・」という方でもOK！<br />\n潮風にあたりながら一緒に釣りを楽しみましょう！</p>\n          </div>\n        </div>\n        <div>\n          \n\n          \n\n          \n          \n\n        </div>\n        \n        \n\n        \n        \n          <h2 id=\"4470\">ラケット同好会</h2>\n        \n        <div class=\"clubBox\">\n          <div class=\"clubBoxImg\">\n            <img src=\"/archives/017/202112/f1f8937aaed389a3cdf385339c585703.jpg\"alt=\"\" />\n          </div>\n          <div class=\"clubBoxTxt\">\n            <div class=\"clubBoxMember\">\n              <img src=\"/archives/017/202111/b56ff22a4e6e571c79e3c28e525cd410.jpg\" alt=\"\" />\n              <p>榊原さん</p>\n            </div>\n            <p>ラケット同行会は主にテニスや卓球など、<br />\nラケット競技を軸に、皆でわいわい楽しく活動しております。<br />\nご時勢柄、今は出来ておりませんが、夜には飲み会なんかも…<br />\n日中いい汗をかいてからの、夜のみんなで宴…最高ですよ！<br />\nどなたでも大歓迎！みんなで一緒にわいわい楽しみましょう！！</p>\n          </div>\n        </div>\n        <div>\n          \n\n          \n\n          \n          \n\n        </div>\n        \n        \n\n        \n        \n          <h2 id=\"4471\">ボウリング同好会</h2>\n        \n        <div class=\"clubBox\">\n          <div class=\"clubBoxImg\">\n            <img src=\"/archives/017/202112/7823bcf8efa4bdfa4a281789bd127caf.jpg\"alt=\"\" />\n          </div>\n          <div class=\"clubBoxTxt\">\n            <div class=\"clubBoxMember\">\n              <img src=\"/archives/017/202111/45390df5973a50c6b57100f28f660614.jpg\" alt=\"\" />\n              <p>八代さん</p>\n            </div>\n            <p>ボウリング同好会は、24名の会員で年2〜3回活動をしています。<br />\n奥に佇む10本のピンめがけて一投入魂！<br />\nボウリングが上手な方も、初心者の方も大歓迎です！<br />\n豪華商品がゲットできるかも！？<br />\nぜひ私たちと一緒に遊びましょう！</p>\n          </div>\n        </div>\n        <div>\n          \n\n          \n\n          \n          \n\n        </div>\n        \n        \n\n        \n        \n          <h2 id=\"4472\">うどん同好会</h2>\n        \n        <div class=\"clubBox\">\n          <div class=\"clubBoxImg\">\n            <img src=\"/archives/017/202111/748f08725da0a8ea7d3ed979b5723e4b.jpg\"alt=\"\" />\n          </div>\n          <div class=\"clubBoxTxt\">\n            <div class=\"clubBoxMember\">\n              <img src=\"/archives/017/202111/938b06534aff95f58930478b7ea7f67c.jpg\" alt=\"\" />\n              <p>赤田さん</p>\n            </div>\n            <p>うどん大好き！なメンバーが集まって、うどんを食べたり、スイーツを味わったり、<br />\n時には香川県の観光名所を巡ったり、総勢31名で楽しく活動をしています。<br />\nうどん屋の朝は早い…ということで、早朝から集まってみんなで瀬戸大橋を渡るのは、まるで小旅行のようなわくわく感があります。<br />\n部署や世代をこえた自由なメンバー達との交流も魅力のひとつ。一度参加すれば、何度も参加したくなる同好会です。</p>\n          </div>\n        </div>\n        <div>\n          \n\n          \n\n          \n          \n\n        </div>\n        \n        \n\n        \n        \n          <h2 id=\"4473\">ちゃりんこ同好会</h2>\n        \n        <div class=\"clubBox\">\n          <div class=\"clubBoxImg\">\n            <img src=\"/archives/017/202112/ec61e2d87ddcd3a41b61ca47485fe2a0.jpg\"alt=\"\" />\n          </div>\n          <div class=\"clubBoxTxt\">\n            <div class=\"clubBoxMember\">\n              <img src=\"/archives/017/202111/51ab6983221c3fc75d49acf1815aa6cb.jpg\" alt=\"\" />\n              <p>山﨑さん</p>\n            </div>\n            <p>ちゃりんこ同好会はサイクリングロードや自然豊かな道を自転車でのんびりサイクリングする同好会です。<br />\n道中の景色を楽しむだけでなく、その地の名物を食べたりおしゃれなカフェでひと息ついたり様々な楽しみ方ができます。<br />\n日頃の運動不足解消にもなりますし、ぜひ一緒に自転車ライフを楽しみましょう！</p>\n          </div>\n        </div>\n        <div>\n          \n\n          \n\n          \n          \n\n        </div>\n        \n        \n\n        \n        \n          <h2 id=\"4474\">エクストリームスポーツ同好会</h2>\n        \n        <div class=\"clubBox\">\n          <div class=\"clubBoxImg\">\n            <img src=\"/archives/017/202111/74e93b6d914bcc09ce1fe3d69a93a090.jpg\"alt=\"\" />\n          </div>\n          <div class=\"clubBoxTxt\">\n            <div class=\"clubBoxMember\">\n              <img src=\"/archives/017/202111/806ecd67f3a38d886966c3724b58dd8c.jpg\" alt=\"\" />\n              <p>岡﨑さん</p>\n            </div>\n            <p>エクストリームスポーツ同好会は11名で活動をしています。<br />\n冬の時期、スノーボードをメインに活動することから始まりましたが、<br />\n【イグルー選手権】やら【花ござピンポン世界大会】等の大会や、<br />\n【ボルダリング】・【スラックライン】等の種目・・・<br />\n部員から出た「これやりたい、参加したい！」というものをなんでもやってみる同好会です。<br />\n新しいことに何でも触れてみたい方はぜひご参加ください！</p>\n          </div>\n        </div>\n        <div>\n          \n\n          \n\n          \n          \n\n        </div>\n        \n        \n\n        \n        \n          <h2 id=\"4475\">写真同好会</h2>\n        \n        <div class=\"clubBox\">\n          <div class=\"clubBoxImg\">\n            <img src=\"/archives/017/202111/c29fb2f209203cb01867827d434464e5.jpg\"alt=\"\" />\n          </div>\n          <div class=\"clubBoxTxt\">\n            <div class=\"clubBoxMember\">\n              <img src=\"/archives/017/202111/b3fde686fc167748a7cdfa4d7ec1066c.jpg\" alt=\"\" />\n              <p>森下さん</p>\n            </div>\n            <p>写真同好会は現在8名で活動しています。<br />\n撮ることだけにとらわれずに、写真展を観に美術館などにも足を運んでいます。<br />\n地元で開催されるコンテストなどに応募し、賞をいただいた実績もあります。<br />\n写真好きな方お待ちしております。</p>\n          </div>\n        </div>\n        <div>\n          \n\n          \n\n          \n          \n\n        </div>\n        \n        \n\n        \n        \n          <h2 id=\"4476\">一流のものにふれる会</h2>\n        \n        <div class=\"clubBox\">\n          <div class=\"clubBoxImg\">\n            <img src=\"/archives/017/202112/e42e89adf0fe78c3c2bc5c472bed50da.jpg\"alt=\"\" />\n          </div>\n          <div class=\"clubBoxTxt\">\n            <div class=\"clubBoxMember\">\n              <img src=\"/archives/017/202111/f24a4510bcc0ee7e433cf9d4566be796.jpg\" alt=\"\" />\n              <p>井上さん</p>\n            </div>\n            <p>一流のものにふれる会とは<br />\n「一流のものに触れることで自分をたかめよう！」との<br />\n趣旨で発足しました。<br />\n絵画などの展示会など鑑賞しアフターランチで<br />\n美味しいものを食しながら感想を語りあったりしています。<br />\nぜひ一緒に色々なものにふれていきましょう！</p>\n          </div>\n        </div>\n        <div>\n          \n\n          \n\n          \n          \n\n        </div>\n        \n      </div>\n      \n\n    <!-- /jsChangeContents --></div>\n  <!-- /content --></div>\n  <!-- ▲ content =========================================== -->\n\n  <!-- ▼ sidebar ==================================== -->\n  <ul class=\"recruit-lnavi\">\n  <li class=\"js-link_match_location\"><a href=\"https://www.kurabun.co.jp/recruit/data/\">数字で見るクラブン</a></li>\n  <li class=\"js-link_match_location\"><a href=\"https://www.kurabun.co.jp/recruit/personnelsystem/\">人事制度（教育制度）</a></li>\n  <li class=\"js-link_match_location\"><a href=\"https://www.kurabun.co.jp/recruit/club/\">同好会・部活動</a></li>\n  <li class=\"js-link_match_location\"><a href=\"https://www.kurabun.co.jp/recruit/base/\">各拠点紹介</a></li>\n  <li class=\"js-link_match_location\"><a href=\"https://www.kurabun.co.jp/recruit/walfare/\">福利厚生</a></li>\n  <li class=\"js-link_match_location\"><a href=\"https://www.kurabun.co.jp/recruit/csr/\">社会貢献活動</a></li>\n  <li class=\"js-link_match_location\"><a href=\"https://www.kurabun.co.jp/recruit/environmental-initiatives/\">環境への取り組み</a></li>\n</ul>\n  <!-- ▲ sidebar ==================================== -->\n\n  <!-- /container --></div>\n  <!-- ▲ container =================================================== -->\n\n\n  <!-- ▼ footer ====================================================== -->\n  \n<div class=\"instagram-btn\">\n  <a href=\"https://www.instagram.com/kurabun__saiyou/\" target=\"_blank\" rel=\"noopener\"><img src=\"/themes/recruit/images/banner_instagram.png\" alt=\"Instagram\"></a>\n  <span class=\"close\"></span>\n</div>\n