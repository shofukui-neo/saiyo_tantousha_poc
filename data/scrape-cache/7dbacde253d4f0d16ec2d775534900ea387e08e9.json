 strength -->\r\n  <section class=\"p-index_strength\">\r\n    <div class=\"l-cont_m\">\r\n      <div class=\"p-index_strength_cont\">\r\n        <h2 class=\"c-ttl_en_main blk\"><span class=\"c-ttl_en_head\">M</span>LS STRENGTH</h2>\r\n        <p class=\"c-ttl_copy blk\">マルイチ・ロジスティクス・サービス<br class=\"u-only_sp\">株式会社は、<br>総合食品卸売業 株式会社マルイチ産商の<br>ロジスティクス部門を担う、<br class=\"u-only_sp\">物流子会社です。</p>\r\n        <p class=\"c-txt_base\">マルイチ産商の物流センターの<br>運営や受発注業務を行う「物流受託事業」、<br>及び、マルイチ産商をはじめとしたエリアのお客様の冷凍品を対象として<br>営業冷蔵庫事業を行う「営業冷蔵庫事業」と、<br>共同配送や中継物流を行う「輸配送物流事業」があります。<br><br>当社は、お客様の商品を大切にお預かりし、<br>安心と鮮度を効率的にお届けするための<br class=\"u-only_sp\">機能向上に努めています。</p>\r\n        <div class=\"c-btn_gry left\">\r\n          <a href=\"./strength/\">MLSの強みについて</a>\r\n        </div>\r\n      </div>\r\n      <div class=\"p-index_strength_img\">\r\n        <img decoding=\"async\" src=\"./assets/img/index/img_strength.jpg\" alt=\"MLS STRENGTH\">\r\n      </div>\r\n    </div>\r\n  </section>\r\n  <!-- strength end -->\r\n  <!-- service -->\r\n  <section class=\"p-index_service\">\r\n    <div class=\"l-cont_m\">\r\n      <div class=\"p-index_service_head\">\r\n        <h2 class=\"c-ttl_grid\">\r\n          <span class=\"c-ttl_en_main wht\">SERVICE</span>\r\n          <span class=\"c-ttl_copy wht\">サービス内容</span>\r\n        </h2>\r\n        <p class=\"c-txt_wht\">常に「安心・安全」「高鮮度」「高効率」な物流のしくみを作り、見直し、高度化しています。\r\n          <br>物流に関するお客様の様々なニーズに、全力でお応えします。</p>\r\n      </div>\r\n      <ul class=\"p-index_service_row\">\r\n        <li>\r\n          <a href=\"./service/#bring\">\r\n            <div class=\"p-index_service_row_cont\">\r\n              <h3 class=\"p-index_service_row_ttl\">はこぶ。</h3>\r\n              <p class=\"p-index_service_row_txt\">輸配送物流事業</p>\r\n              <p class=\"p-index_service_row_more\">READ MORE</p>\r\n            </div>\r\n          </a>\r\n        </li>\r\n        <li>\r\n          <a href=\"./service/#keep\">\r\n            <div class=\"p-index_service_row_cont\">\r\n              <h3 class=\"p-index_service_row_ttl nowrap\">あずかる。</h3>\r\n              <p class=\"p-index_service_row_txt\">営業冷蔵庫事業</p>\r\n              <p class=\"p-index_service_row_more\">READ MORE</p>\r\n            </div>\r\n          </a>\r\n        </li>\r\n        <li>\r\n          <a href=\"./service/#connect\">\r\n            <div class=\"p-index_service_row_cont\">\r\n              <h3 class=\"p-index_service_row_ttl\">つなぐ。</h3>\r\n              <p class=\"p-index_service_row_txt\">物流受託事業</p>\r\n              <p class=\"p-index_service_row_more\">READ MORE</p>\r\n            </div>\r\n          </a>\r\n        </li>\r\n      </ul>\r\n    </div>\r\n  </section>\r\n  <!-- service end -->\r\n  <!-- side row -->\r\n  <section class=\"c-sideRow\">\r\n    <ul class=\"c-sideRow_box\">\r\n      <li class=\"company\">\r\n        <a href=\"./company/\">\r\n          <h2 class=\"c-ttl_row wht\">\r\n            <span class=\"c-ttl_row_en\">COMPANY INFO</span>\r\n            <span class=\"c-ttl_row_jp\">会社案内</span>\r\n          </h2>\r\n          <p class=\"c-txt_wht\">MLSは、長野県から全国へ物流事業を展開しています。企業紹介動画・経営理念・会社概要・沿革・事業所一覧をご覧ください。</p>\r\n          <div class=\"c-sideRow_arw\">\r\n            <img decoding=\"async\" src=\"./assets/img/ico_arw.svg\" alt=\"MORE\">\r\n          </div>\r\n        </a>\r\n      </li>\r\n      <li class=\"csr\">\r\n        <a href=\"./csr/\">\r\n          <h2 class=\"c-ttl_row\">\r\n            <span class=\"c-ttl_row_en\">CSR</span>\r\n            <span class=\"c-ttl_row_jp\">CSRへの取り組み</span>\r\n          </h2>\r\n          <p class=\"c-txt_wht\">社会貢献の取り組みとして、ホワイト物流推進運動への参画や自然環境にやさしい冷凍機の導入などを行っています。</p>\r\n          <div class=\"c-sideRow_arw\">\r\n            <img decoding=\"async\" src=\"./assets/img/ico_arw.svg\" alt=\"MORE\">\r\n          </div>\r\n        </a>\r\n      </li>\r\n    </ul>\r\n  </section>\r\n  <!-- side row end -->\r\n  <!-- recruit -->\r\n\r\n\r\n \r\n <section class=\"p-index_recruit\">\r\n    <div class=\"l-cont_m\">\r\n      <div class=\"p-index_recruit_cont\">\r\n        <h2 class=\"p-index_recruit_ttl\">「人」を大切にし、<br>「人」を育て、<br>「人」を活かす。</h2>\r\n        <p class=\"c-txt_opa\">MARUICHI LOGISTICS SERVICE RECRUIT SITE</p>\r\n      </div>\r\n      <div class=\"c-btn_wht right recruit\">\r\n       <a href=\"./recruit/\">マルイチ・ロジスティクス・サービス 採用情報</a>\r\n      </div>\r\n    </div>\r\n  </section>\r\n\r\n\r\n\r\n  <!-- recruit end -->\r\n  <!-- news -->\r\n  <section class=\"p-index_news\">\r\n    <div class=\"l-cont_m\">\r\n      <div class=\"p-index_news_cont\">\r\n        <h2 class=\"p-index_news_top_ttl\">\r\n          <span class=\"p-index_news_top_ttl_jp\">最新情報</span>\r\n          <span class=\"p-index_news_top_ttl_en\">NEWS</span>\r\n        </h2><ul class=\"p-index_news_list\">\n<li>\n  <a href=\"https://maruichi-logistics.com/recruitnews/%e4%bb%a4%e5%92%8c8%e5%b9%b45%e6%9c%88%e3%80%80%e6%9c%80%e6%96%b0%e3%81%ae%e6%b1%82%e4%ba%ba%e6%83%85%e5%a0%b1%e3%82%92%e3%81%8a%e7%9f%a5%e3%82%89%e3%81%9b%e3%81%97%e3%81%be%e3%81%99%e3%80%82/\" class=\"link\">\n  <h3 class=\"p-index_news_ttl\">令和8年5月　最新の求人情報をお知らせします。</h3>\n  <p class=\"p-index_news_txt\">事業拡大に伴い、マルイチ・ロジスティクス・サービス株式会社では新たな仲間を募集しています。\r\n求人情報をご確認の</p>\n  <div class=\"p-index_news_btm\">\n    <time class=\"p-index_news_update\">2026.06.01</time>\n    <span class=\"p-index_news_cat recruitnews\">採用情報</span>\n  </div>\n</a>\n</li>\n<li>\n  <a href=\"https://maruichi-logistics.com/news/%e6%9c%ac%e7%a4%be%e7%a7%bb%e8%bb%a2%e3%81%ae%e3%81%94%e6%a1%88%e5%86%85/\" class=\"link\">\n  <h3 class=\"p-index_news_ttl\">本社移転のご案内</h3>\n  <p class=\"p-index_news_txt\">このたび弊社は業務拡充に伴い、下記のとおり本社を移転し、令和8年5月1日より新所在地にて営業を開始する運びとなり</p>\n  <div class=\"p-index_news_btm\">\n    <time class=\"p-index_news_update\">2026.05.01</time>\n    <span class=\"p-index_news_cat news\">新着情報</span>\n  </div>\n</a>\n</li>\n<li>\n  <a href=\"https://maruichi-logistics.com/news/%e3%82%aa%e3%83%b3%e3%82%b5%e3%82%a4%e3%83%88ppa%e3%81%ab%e3%82%88%e3%82%8b%e5%86%8d%e7%94%9f%e5%8f%af%e8%8