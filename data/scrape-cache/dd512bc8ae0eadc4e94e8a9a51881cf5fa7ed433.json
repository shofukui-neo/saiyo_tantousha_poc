ystal.co.jp/\" class=\"hdr__logo\"><img src=\"https://www.hotel-crystal.co.jp/wp-content/themes/cp-hotel/images/common/hdr-logo.png\" alt=\"ホテルクリスタルパレス\"></a>\n    </div>\n    <div class=\"hdr-fixed\">\n\t<!-- SNSアイコン -->\n<ul class=\"sns_btn\">\n<li><a href=\"https://www.hotel-crystal.co.jp/recruit/\" class=\"recruitbtn\"><span>RECRUIT</span>-採用情報-</a></li>\n<li><a href=\"https://lin.ee/3V9u0CL\" target=\"_blank\" class=\"flowbtn fl_li\"><i class=\"fab fa-line\"></i></a></li>\n<li><a href=\"https://ja-jp.facebook.com/crystalpalace.ibaraki\" target=\"_blank\" class=\"flowbtn fl_fb\"><i class=\"fa-brands fa-square-facebook\"></i></a></li>\n<li><a href=\"https://www.instagram.com/hotel_crystalpalace/\" target=\"_blank\" class=\"flowbtn insta_btn\"><i class=\"fab fa-instagram\"></i></a></li>\n<li><a href=\"https://twitter.com/crystal_ibaraki\" target=\"_blank\" class=\"flowbtn fl_tw\"><i class=\"fa-brands fa-x-twitter\"></i></a></li>\n</ul>\n<!-- SNSアイコン -->\n      <a href=\"https://asp.hotel-story.ne.jp/ver3d/planlist.asp?hcod1=66330&hcod2=001&mode=seek&clrmode=true&reffrom=\" class=\"hdr-fixed__stay\">宿泊プランはこちら</a>\n      <span class=\"hdr-fixed__menu menu_hdr_ico\"></span>\n    </div>\n    \n    <nav class=\"gnav gnav--hdr\"><div class=\"cont__inner--wide\"><ul class=\"gnav__list gnav__list--hdr\"><li class=\"gnav__item gnav__item--hdr\"><a href=\"https://www.hotel-crystal.co.jp/\"><span class=\"gnav__ja\">トップページ</span><span class=\"gnav__en\">TOP</span></a></li><li class=\"gnav__item gnav__item--hdr\"><a href=\"https://www.hotel-crystal.co.jp/about/\"><span class=\"gnav__ja\">ホテルのご紹介</span><span class=\"gnav__en\">ABOUT</span></a></li><li class=\"gnav__item gnav__item--hdr\"><a href=\"/stay/\"><span class=\"gnav__ja\">ご宿泊</span><span class=\"gnav__en\">STAY</span></a></li><li class=\"gnav__item gnav__item--hdr\"><a href=\"/wedding/\"><span class=\"gnav__ja\">ウェディング</span><span class=\"gnav__en\">WEDDING</span></a></li><li class=\"gnav__item gnav__item--hdr\"><a href=\"/restaurant/\"><span class=\"gnav__ja\">レストランのご紹介</span><span class=\"gnav__en\">RESTAURANT</span></a></li><li class=\"gnav__item gnav__item--hdr\"><a href=\"/party/\"><span class=\"gnav__ja\">パーティ・ご宴会</span><span class=\"gnav__en\">PARTY</span></a></li><li class=\"gnav__item gnav__item--hdr\"><a href=\"https://www.hotel-crystal.co.jp/access/\"><span class=\"gnav__ja\">アクセス</span><span class=\"gnav__en\">ACCESS</span></a></li></ul><ul class=\"sns_btn\"><li><a href=\"https://www.hotel-crystal.co.jp/recruit/\" class=\"recruitbtn\"><span>RECRUIT</span>-採用情報-</a></li><li><a href=\"https://lin.ee/3V9u0CL\" target=\"_blank\" class=\"flowbtn fl_li\"><i class=\"fab fa-line\"></i></a></li><li><a href=\"https://ja-jp.facebook.com/crystalpalace.ibaraki\" target=\"_blank\" class=\"flowbtn fl_fb\"><i class=\"fab fa-facebook\"></i></a></li><li><a href=\"https://www.instagram.com/hotel_crystalpalace/\" target=\"_blank\" class=\"flowbtn insta_btn\"><i class=\"fab fa-instagram\"></i></a></li><li><a href=\"https://twitter.com/crystal_ibaraki\" target=\"_blank\" class=\"flowbtn fl_tw\"><i class=\"fab fa-twitter\"></i></a></li></ul></div></nav>  </header>\n    \n  <div class=\"page-main--white\" style=\"background:url(https://www.hotel-crystal.co.jp/wp-content/themes/cp-hotel/images/about/page-main-bg.jpg?2025) no-repeat center center / cover;\">  <div class=\"cont__inner\">\n    <p class=\"page-main__ttl\">\n      <span class=\"page-main__ttljp page-main__ttljp--white\">ホテルのご紹介</span><span class=\"page-main__ttlen page-main__ttlen--white\">ABOUT</span>    </p>\n  </div>\n</div>\n\n\n  <div class=\"breadcrumb\">\n  <div class=\"cont__inner--wide\">\n    <ul class=\"breadcrumb__list\" itemscope itemtype=\"http://schema.org/BreadcrumbList\">\n      <li class=\"breadcrumb__item\" itemprop=\"itemListElement\" itemscope itemtype=\"http://schema.org/ListItem\">\n        <a href=\"https://www.hotel-crystal.co.jp/\" itemprop=\"item\"><span itemprop=\"name\">HOME</span></a>\n        <meta itemprop=\"position\" content=\"1\"/>\n      </li>\n      <!--固定ページ-->\n            <li class=\"breadcrumb__item\" itemprop=\"itemListElement\" itemscope itemtype=\"http://schema.org/ListItem\"><span itemprop=\"name\">ホテルのご紹介</span><meta itemprop=\"position\" content=\"2\"></li>            <!--投稿ページ-->\n      \n                            </ul>\n  </div>\n</div>  <section class=\"about-first\">\n  <div class=\"cont__inner--wide\">\n    <h2 class=\"cont__sttl\">大切なやすらぎの感覚をあなたにお約束します。</h2>\n    <div class=\"cont__txt\">\n      <p>茨城の観光名所である大洗、阿字ヶ浦、ひたち海浜公園などの近接に位置し、水戸からのアクセスも容易な立地となっているホテルクリスタルパレス。<br>緑豊かな丘の上に立つシンボルの「天使の教会」をはじめ、充実した施設で、ごゆっくりおくつろぎいただけます。</p>\n      <p>また、お客様のご利用目的に合わせてゲストルームやレストラン・ホールなど、きめ細やかにおもてなしの準備をし、お迎えいたします。</p>\n    </div>\n  </div>\n</section>\n<nav class=\"about-menu\">\n  <div class=\"cont__inner--wide\">\n    <form action=\"\" name=\"about-menu\">\n      <ul class=\"about-menu__list\">\n        <li class=\"about-menu__item\"><input type=\"radio\" id=\"menu-appearance\" name=\"about-menu\" value=\"0\" checked onclick=\"entryChange();\"><label for=\"menu-appearance\">ホテルクリスタルパレスの魅力</label></li>\n        <li class=\"about-menu__item\"><input type=\"radio\" id=\"menu-company\" name=\"about-menu\" value=\"1\" onclick=\"entryChange();\"><label for=\"menu-company\">会社概要</label></li>\n      </ul>\n    </form>\n      </div>\n</nav>\n<section class=\"about-appearance\" id=\"appearance\">\n  <div class=\"cont__inner--wide\">\n    <section class=\"appearance-first\">\n      <div class=\"appearance-first__img\"><img src=\"https://www.hotel-crystal.co.jp/wp-content/themes/cp-hotel/images/about/appearance-first.jpg?2025\" alt=\"\"></div>\n      <h2 class=\"appearance-first__ttl\">Smile Experience</h2>\n      <p class=\"appearance-first__strong\">笑顔で過ごせる場所でありたい。</p>\n      <div class=\"cont__txt\">\n        <p>その日その瞬間の笑顔のために、私たちはすべての可能性を追い求めます。<br>それが私たちの存在理由だからです。</p>\n        <p>人生で、自分たちと関わる誰かが、あなたが<br>笑顔になってくれるほど嬉しいことは、私たちにはありません。</p>\n        <p>これまで、大変なこともあったと思います。</p>\n        <p>日々辛いこともあると思います。</p>\n        <p>だからこそ、最高の笑顔と幸せを。</p>\n      </div>\n    </section>\n    <section class=\"appearance-second\">\n      <div class=\"appearance-second__img\"><img src=\"https://www.hotel-crystal.co.jp/wp-content/themes/cp-hotel/images/about/appearance-second.jpg\" alt=\"\"></div>\n      <p class=\"appearance-second__strong\">\n        私たちは、お客様にとって<br>生涯お付き合いいただけるパートナーホテルを目指します。\n      </p>\n    </section>\n    <section class=\"appearance-half--re\">\n      <div class=\"section appearance-half__img\"><img src=\"https://www.hotel-crystal.co.jp/wp-content/themes/cp-hotel/images/about/appearance-bath.jpg\" alt=\"\"></div>\n      <div class=\"appearance-half__info\">\n        <h3 class=\"cont__sttl cont__sttl--left\">疲れを癒す<br>炭酸カルシウム温泉　大浴場</h3>\n        <div class=\"appearance-half__txt\">\n          快適な滞在に欠かせないのが大浴場。<br>\n          お仕事や旅の疲れを癒すには、足を延ばせる大きな浴槽でおくつろぎください。<br>\n          炭酸カルシウムを添加した人工温泉は、炭酸・硫酸イオンが血流をよくし<br class=\"pc-mode\">\n          肌の分泌物を浄化してすべすべにすることから「美肌の湯」とも言われています。\n        </div>\n        <a href=\"https://www.hotel-crystal.co.jp/stay/?id=facility\" class=\"appearance-half__btn\">施設紹介はこちら</a>\n      </div>\n    </section>\n    <section class=\"appearance-4c\">\n      <ul class=\"appearance-4c__img\">\n        <li><img src=\"https://www.hotel-crystal.co.jp/wp-content/themes/cp-hotel/images/about/appearance-restaurant01.jpg?2025\" alt=\"\"></li>\n        <li><img src=\"https://www.hotel-crystal.co.jp/wp-content/themes/cp-hotel/images/about/appearance-restaurant02.jpg?2025\" alt=\"\"></li>\n        <li><img src=\"https://www.hotel-crystal.co.jp/wp-content/themes/cp-hotel/images/about/appearance-restaurant03.jpg?2025\" alt=\"\"></li>\n        <li><img src=\"https://www.hotel-crystal.co.jp/wp-content/themes/cp-hotel/images/about/appearance-restaurant04.jpg?2025\" alt=\"\"></li>\n      </ul>\n      <div class=\"appearance-4c__info\">\n        <h3 class=\"cont__sttl\">体に優しい、おいしい料理でおもてなし</h3>\n        <p class=\"cont__txt\">\n\t\t素敵な朝のはじまりは美味しい朝食から。<br />\n\t\tホテルオリジナルカレーや大好評の「野菜ソムリエのいる栗原農園」の新鮮な野菜を使ったサラダバー、地物食材や旬の食材を使った定番のお惣菜など。<br />\n\t\t体に優しい&美味しい健康朝食をお楽しみいただけます。</p>\n        <a href=\"https://www.hotel-crystal.co.jp/restaurant/\" class=\"appearance-4c__btn\">レストランページのご紹介</a>\n      </div>\n    </section>\n    <section class=\"appearance-half\">\n      <div class=\"section appearance-half__img\"><img src=\"https://www.hotel-crystal.co.jp/wp-content/themes/cp-hotel/images/about/appearance-stay.jpg?2025\" alt=\"\"></div>\n      <div class=\"appearance-half__info\">\n        <h3 class=\"cont__sttl cont__sttl--left\">快適な空間で、<br>心地よいご滞在を</h3>\n        <div class=\"appearance-half__txt\">\n          ビジネスシーンからレジャーでの利用まで幅広いニーズにお応えする\n        </div>\n        <a href=\"https://www.hotel-crystal.co.jp/stay/\" class=\"appearance-half__btn\">宿泊についてのご紹介はこちら</a>\n      </div>\n    </section>\n    <section class=\"appearance-4c\">\n      <ul class=\"appearance-4c__img\">\n        <li><img src=\"https://www.hotel-crystal.co.jp/wp-content/themes/cp-hotel/images/about/appearance-party01.jpg\" alt=\"\"></li>\n        <li><img src=\"https://www.hotel-crystal.co.jp/wp-content/themes/cp-hotel/images/about/appearance-party02.jpg\" alt=\"\"></li>\n        <li><img src=\"https://www.hotel-crystal.co.jp/wp-content/themes/cp-hotel/images/about/appearance-party03.jpg\" alt=\"\"></li>\n        <li><img src=\"https://www.hotel-crystal.co.jp/wp-content/themes/cp-hotel/images/about/appearance-party04.jpg\" alt=\"\"></li>\n      </ul>\n      <div class=\"appearance-4c__info\">\n        <h3 class=\"cont__sttl\">大規模なイベントから少人数でのお集まりまで</h3>\n        <p class=\"cont__txt\">\n          ホテルクリスタルパレスの宴会場は、多くの方がより快適な時間をお過ごしいただけるよう<br class=\"pc-mode\">\n          大小様々なスペースをご用意しており、ご利用人数に合せた会場をご提案いたします。\n        </p>\n        <a href=\"https://www.hotel-crystal.co.jp/party/\" class=\"appearance-4c__btn\">パーティ・宴会プランのご紹介　</a>\n      </div>\n    </section>\n    <section class=\"appearance-half--re\">\n      <div class=\"section appearance-half__img\"><img src=\"https://www.hotel-crystal.co.jp/wp-content/themes/cp-hotel/images/about/appearance-wedding.jpg\" alt=\"\"></div>\n      <div class=\"appearance-half__info\">\n        <h3 class=\"cont__sttl cont__sttl--left\">とっておきの空間で<br>いつまでも心に刻まれるウエディング</h3>\n        <div class=\"appearance-half__txt\">\n          100組の結婚があれば　100通りの結婚式のカタチ。<br>さまざまな祝福のカタチで、おふたりらしい夢を叶えます。\n        </div>\n        <a href=\"https://www.hotel-crystal.co.jp/wedding/\" class=\"appearance-half__btn\">ウエディングページはこちら</a>\n      </div>\n    </section>\n    <section class=\"appearance-half\">\n      <div class=\"section appearance-half__img\"><img src=\"https://www.hotel-crystal.co.jp/wp-content/themes/cp-hotel/images/about/appearance-banquet.jpg\" alt=\"\"></div>\n      <div class=\"appearance-half__info\">\n        <h3 class=\"cont__sttl cont__sttl--left\">さまざまなご宴会、ご商談にも<br>対応いたします</h3>\n        <div class=\"appearance-half__txt\">\n          パーティや会議、そして少人数でのお集りまで、お気軽にご相談ください。\n        </div>\n        <a href=\"https://www.hotel-crystal.co.jp/banquet_hall/\" class=\"appearance-half__btn\">パーティ・宴会会場のご紹介</a>\n      </div>\n    </section>\n\t<section class=\"appearance-half--re\">\n      <div class=\"section appearance-half__img\"><img src=\"https://www.hotel-crystal.co.jp/wp-content/themes/cp-hotel/images/about/appearance-activity.jpg\" alt=\"\"></div>\n      <div class=\"appearance-half__info\">\n        <h3 class=\"cont__sttl cont__sttl--left\">環境への取り組み</h3>\n        <div class=\"appearance-half__txt\">\n          社会貢献活動として環境問題への取り組みを推進しています\n\t\t  <ul>\n\t\t  <li>● CHOJUSOオリジナルエコバッグの使用 ※一部婚礼にて</li>\n\t\t  <li>● 生分解性（PLA）ストローの使用 ※レストランサーラにて</li>\n\t\t  <li>●エコ箸の使用※レストランサーラにて </li>\n\t\t  <li>● 生ゴミの自社処理 ※肥料として活用</li>\n\t\t  </ul>\n        </div>\n      </div>\n    </section>\n\t\t\n  </div>\n</section>\n<section class=\"about-company\" id=\"company\">\n  <div class=\"cont__inner\">\n    <section class=\"company\">\n      <h2 class=\"cont__ttl\">\n        <span class=\"cont__ttljp\">会社概要</span>\n        <span class=\"cont__ttlen\">COMPANY</span>\n      </h2>\n      <table class=\"cont__tbl company__tbl\">\n        <tr>\n          <th>法人設立</th>\n          <td>昭和４２年５月１日（創業／昭和２６年１１月１日）</td>\n        </tr>\n        <tr>\n          <th>会社名</th>\n          <td>株式会社　長寿荘</td>\n        </tr>\n        <tr>\n          <th>所在地</th>\n          <td>〒312-0023　茨城県ひたちなか市大平1-22-1</td>\n        </tr>\n        <tr>\n          <th>TEL</th>\n          <td>029-273-7711（代表）</td>\n        </tr>\n        <tr>\n          <th>FAX</th>\n          <td>029-273-7742</td>\n        </tr>\n        <tr>\n          <th>資本金</th>\n          <td>3,000万円</td>\n        </tr>\n        <tr>\n          <th>代表者</th>\n          <td>代表取締役　海野　泰司</td>\n        </tr>\n        <tr>\n          <th>役員</th>\n          <td>\n            副社長　　　海野　勝人<br>\n            常務取締役　海野　良司\n          </td>\n        </tr>\n        <tr>\n          <th>従業員数</th>\n          <td>\n            約２２０人　長寿荘グループ全体<br />\n\t\t\t（令和2年１月現在　※アルバイト含む）\n          </td>\n        </tr>\n        <tr>\n          <th>事業内容</th>\n          <td>ホテル、レストラン、結婚式場の運営、ブライダルフォトスタジオ</td>\n        </tr>\n        <tr>\n          <th>決算期</th>\n          <td>８月末</td>\n        </tr>\n      </table>\n    </section>\n    <section class=\"history\">\n      <h2 class=\"cont__ttl\">\n        <span class=\"cont__ttljp\">株式会社長寿荘の歩み</span>\n        <span class=\"cont__ttlen\">HISTORY</span>\n      </h2>\n      <table class=\"cont__tbl history__tbl\">\n        <tr>\n          <th>昭和26年11月</th>\n          <td>鉱泉旅館を創業</td>\n        </tr>\n        <tr>\n          <th>昭和42年 5月</th>\n          <td>有限会社長寿荘を設立</td>\n        </tr>\n        <tr>\n          <th>昭和47年 4月</th>\n          <td>国際観光旅館連盟に加入</td>\n        </tr>\n        <tr>\n          <th>昭和57年 8月</th>\n          <td>ホテルクリスタルパレスに改名</td>\n        </tr>\n        <tr>\n          <th>昭和59年11月</th>\n          <td>勝田駅前クリスタルプラザオープン</td>\n        </tr>\n        <tr>\n          <th>昭和62年 5月</th>\n          <td>有限会社パシフィックフードオープン （モスバーガー店）</td>\n        </tr>\n        <tr>\n          <th>平成 9年 3月</th>\n          <td>水戸駅南口土地購入 （現ホテル テラス ザ ガーデン水戸）</td>\n        </tr>\n        <tr>\n          <th>平成12年 3月</th>\n          <td>有限会社長寿荘ホテルサービス設立</td>\n        </tr>\n        <tr>\n          <th>平成14年 8月</th>\n          <td>株式会社水戸クリスタルサービス設立</td>\n        </tr>\n        <tr>\n          <th>平成16年10月</th>\n          <td>ホテル テラス ザ ガーデン水戸オープン</td>\n        </tr>\n        <tr>\n          <th>平成21年 8月</th>\n          <td>ホテル日航日立購入 （現ホテル テラス ザ スクエア日立）</td>\n        </tr>\n        <tr>\n          <th>平成22年10月</th>\n          <td>ホテル テラス ザ スクエア日立オープン</td>\n        </tr>\n        <tr>\n          <th>平成24年 2月</th>\n          <td>テラスイン勝田　オープン</td>\n        </tr>\n        <tr>\n          <th>平成25年 8月</th>\n          <td>写真スタジオ「ＬＵＸＥ」オープン</td>\n        </tr>\n        <tr>\n          <th>平成28年 5月</th>\n          <td>キッチン　モアナイナオープン</td>\n        </tr>\n        <tr>\n          <th>平成28年11月</th>\n          <td>中華料理「チャイナテラス」オープン</td>\n        </tr>\n      </table>\n    </section>\n    <section class=\"group\">\n      <h2 class=\"cont__ttl\">\n        <span class=\"cont__ttljp\">グループ施設</span>\n        <span class=\"cont__ttlen\">GROUP HOTELS</span>\n      </h2>\n      <ul class=\"hotel-list\">\n        <li class=\"hotel-item\">\n          <div class=\"hotel-item__info\">\n            <h3 class=\"hotel-item__ttl cont__sttl cont__sttl--left\">ホテル テラス ザ ガーデン 水戸</h3>\n            <table class=\"cont__tbl hotel-item__tbl\">\n              <tr>\n                <th>住所</th>\n                <td>〒310-0015　水戸市宮町1-7-20</td>\n              </tr>\n              <tr>\n                <th>TEL</th>\n                <td>029-300-2500</td>\n              </tr>\n              <tr>\n                <th>FAX</th>\n                <td>029-300-2545</td>\n              </tr>\n              <tr>\n                <th>アクセス</th>\n                <td>JR常磐線水戸駅南口より徒歩０分</td>\n              </tr>\n            </table>\n          </div>\n          <div class=\"hotel-item__imgarea\">\n            <div class=\"hotel-item__img\"><img src=\"https://www.hotel-crystal.co.jp/wp-content/themes/cp-hotel/images/about/company-hotel01.jpg\" alt=\"\"></div>\n            <a href=\"http://www.hotel-terrace.com\" class=\"hotel-item__btn\" target=\"_blank\">公式サイト</a>\n          </div>\n        </li>\n        <li class=\"hotel-item\">\n          <div class=\"hotel-item__info\">\n            <h3 class=\"hotel-item__ttl cont__sttl cont__sttl--left\">ホテル テラス ザ スクエア 日立</h3>\n            <table class=\"cont__tbl hotel-item__tbl\">\n              <tr>\n                <th>住所</th>\n                <td>〒317-0073　日立市幸町1-20-3</td>\n              </tr>\n              <tr>\n                <th>TEL</th>\n                <td>0294-22-5531</td>\n              </tr>\n              <tr>\n                <th>FAX</th>\n                <td>0294-22-3139</td>\n              </tr>\n              <tr>\n                <th>アクセス</th>\n                <td>JR常磐線日立駅中央口より徒歩２分</td>\n              </tr>\n            </table>\n          </div>\n          <div class=\"hotel-item__imgarea\">\n            <div class=\"hotel-item__img\"><img src=\"https://www.hotel-crystal.co.jp/wp-content/themes/cp-hotel/images/about/company-hotel02.jpg\" alt=\"\"></div>\n            <a href=\"http://square-hitachi.jp\" class=\"hotel-item__btn\" target=\"_blank\">公式サイト</a>\n          </div>\n        </li>\n        <li class=\"hotel-item\">\n          <div class=\"hotel-item__info\">\n            <h3 class=\"hotel-item__ttl cont__sttl cont__sttl--left\">テラス イン 勝田</h3>\n            <table class=\"cont__tbl hotel-item__tbl\">\n              <tr>\n                <th>住所</th>\n                <td>〒312-0045　ひたちなか市勝田中央1-3</td>\n              </tr>\n              <tr>\n                <th>TEL</th>\n                <td>029-219-7211</td>\n              </tr>\n              <tr>\n                <th>FAX</th>\n                <td>029-219-7311</td>\n              </tr>\