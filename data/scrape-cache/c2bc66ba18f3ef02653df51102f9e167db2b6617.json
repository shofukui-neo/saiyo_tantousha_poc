">採用責任者メッセージ</a>\n                </li>\n                <li class=\"header-list__item\">\n                  <a href=\"/saiyou/r-message/\">採用担当者メッセージ</a>\n                </li>\n\t\t\t\t  <li class=\"header-list__item only-sp\">\n                  <a href=\"https://www.ags.co.jp/corporate/outline/index.html\">会社情報</a>\n                </li>\n\t\t\t\t  <li class=\"header-list__item only-sp\">\n                  <a href=\"https://ags.smktg.jp/public/application/add/123\">お問い合わせ</a>\n                </li>\n              </ul>\n              <ul class=\"header-buttons hover-outline\">\n                <li class=\"header-buttons__item\">\n                  <a href=\"/saiyou/new/\">\n                    <span>新卒採用</span>\n                  </a>\n                </li>\n                <li class=\"header-buttons__item\">\n                  <a href=\"/saiyou/career/\">\n                    <span>キャリア採用</span>\n                  </a>\n                </li>\n              </ul>\n            </div>\n          </nav>\n        </div>\n      </div>\n    </header>\n    <main class=\"layout-content\">\n<section class=\"section component-header\">\n  <div class=\"component-background\">\n  <svg viewBox=\"0 0 2423 1518\" preserveAspectRatio=\"xMidYMid slice\">\n    <defs>\n      <linearGradient id=\"gradient-stroke\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"0%\">\n        <stop offset=\"32%\" stop-color=\"#d3edf8\"></stop>\n        <stop offset=\"44%\" stop-color=\"#cef4f2\"></stop>\n        <stop offset=\"63%\" stop-color=\"#ffe7db\"></stop>\n      </linearGradient>\n    </defs>\n    <path fill=\"none\" stroke=\"url(#gradient-stroke)\" stroke-linecap=\"round\" d=\"M90.1000,385.001 C91.155,384.965 332.130,688.488 815.610,765.887 C1099.052,809.556 1468.456,754.845 1637.1000,622.1000 C1760.645,516.109 1806.136,452.090 1815.999,310.1000 C1808.923,213.713 1772.364,132.526 1685.1000,99.000 C1629.544,78.449 1548.514,95.358 1483.005,142.196 C1386.240,211.382 1295.211,366.536 1348.1000,574.1000 C1432.369,898.114 1813.031,1243.009 2287.1000,1383.000\"></path>\n  </svg>\n</div>\n\n  <div class=\"section__inner\">\n    <nav class=\"component-breadcrumb\">\n      <ul class=\"component-breadcrumb-list hover-color\">\n        <li class=\"component-breadcrumb-list__item\">\n          <a href=\"/saiyou/\">トップ</a>\n        </li>\n        <li class=\"component-breadcrumb-list__item\">採用担当者メッセージ</li>\n      </ul>\n    </nav>\n    <h1 class=\"component-header__heading\">\n      <span class=\"component-header__heading-en\">RECRUIT MESSAGE</span>\n      <span class=\"component-header__heading-ja\">採用担当者メッセージ</span>\n    </h1>\n  </div>\n</section>\n\n\n<section class=\"section message-index\">\r\n  <div class=\"section__inner\">\r\n    <ul class=\"message-index-list\">\r\n\r\n\r\n      <li class=\"message-index-list__item js-inview fadein-up\">\r\n        <figure class=\"message-index-list__image\">\r\n          <img src=\"/saiyou/assets/img/hr-message/img_index02.png\" alt=\"T.N\" loading=\"lazy\" decoding=\"async\" fetchpriority=\"auto\" width=\"540\" height=\"400\">\r\n        </figure>\r\n        <div class=\"message-index-list__content\">\r\n          <p class=\"message-index-list__data\">新卒採用担当</p>\r\n          <h3 class=\"message-index-list__subheading\">T.N.</h3>\r\n          <h2 class=\"message-index-list__heading\">あなたらしさが、私たちの求める力です</h2>\r\n          <p class=\"message-index-list__text\">「履歴書や面接で、なにをアピールしたらいいですか」と聞かれることがあります。もちろんスキルや経験も大切ですが、私たちが本当に知りたいのは、あなたがどんな時に心を動かし、どう考え、どんな風に前に進んできたかということ。自分の中で何かが変わったときの気づきや発見、そこからの小さな成長こそが、あなたらしさを映し出していると考えています。自分らしさを大切にしながら挑戦を楽しめる人と、一緒に走っていきたいと思っています。</p>\r\n        </div>\r\n      </li>\r\n\r\n      <li class=\"message-index-list__item js-inview fadein-up\">\r\n        <figure class=\"message-index-list__image\">\r\n          <img src=\"/saiyou/assets/img/hr-message/img_index01.png\" alt=\"S.R.\" loading=\"lazy\" decoding=\"async\" fetchpriority=\"auto\" width=\"540\" height=\"400\">\r\n        </figure>\r\n        <div class=\"message-index-list__content\">\r\n          <p class=\"message-index-list__data\">新卒採用担当</p>\r\n          <h3 class=\"message-index-list__subheading\">S.E.</h3>\r\n          <h2 class=\"message-index-list__heading\">支えられる側から支える側へ</h2>\r\n          <p class=\"message-index-list__text\">入社して年月が経っても、新しいことに挑戦する際には不安や心配があります。もちろん自分自身で乗り越えるべき課題もありますが、困ったときには助け合える環境や相談できる場があります。キャリア形成の過程では、ライフステージをサポートする体制も整っていて、私自身も出産や育児を経て、制度や周囲の助けに支えられました。支えられる側から支える側へと、それぞれが成長できる環境があります。一歩ずつ、一緒に成長していきましょう！</p>\r\n        </div>\r\n      </li>\r\n\r\n      <li class=\"message-index-list__item js-inview fadein-up\">\r\n        <figure class=\"message-index-list__image\">\r\n          <img src=\"/saiyou/assets/img/hr-message/img_index03.png\" alt=\"M.K\" loading=\"lazy\" decoding=\"async\" fetchpriority=\"auto\" width=\"540\" height=\"400\">\r\n        </figure>\r\n        <div class=\"message-index-list__content\">\r\n          <p class=\"message-index-list__data\">新卒採用担当</p>\r\n          <h3 class=\"message-index-list__subheading\">M.K.</h3>\r\n          <h2 class=\"message-index-list__heading\">好きな自分を見つける</h2>\r\n          <p class=\"message-index-list__text\">働く理由を問われたら、私は「働いている自分を好きでいるため」と答えます。常に目的意識を持ち、考え学ぶこと、変化し続ける事で新しい自分との出会いを創出し、自分を好きでいられる。ＡＧＳであれば、それが実現可能だと入社して６年目の今も感じています。自発的に考え行動することが出来るこの環境で、「好きな自分」を探してみませんか？</p>\r\n        </div>\r\n      </li>\r\n\r\n<!--\r\n      <li class=\"message-index-list__item js-inview fadein-up\">\r\n        <figure class=\"message-index-list__image\">\r\n          <img src=\"/saiyou/assets/img/hr-message/img_index04.png\" alt=\"S.Y\" loading=\"lazy\" decoding=\"async\" fetchpriority=\"auto\" width=\"540\" height=\"400\">\r\n        </figure>\r\n        <div class=\"message-index-list__content\">\r\n          <p class=\"message-index-list__data\">キャリア採用担当</p>\r\n          <h3 class=\"message-index-list__subheading\">S.Y.</h3>\r\n          <h2 class=\"message-index-list__heading\">“これまで”より、“これから”を見ています</h2>\r\n          <p class=\"message-index-list__text\">10年以上にわたり、数々の採用活動を通じて転職を考える皆さんと向き合ってきました。その中で多くの方から「今までの経験が活きるか」「新しい社風に馴染めるか」といった点で不安に感じているとお聞きします。私たちは皆さんのこれまでの経験に加え、「これからどのようにキャリアを描きたいか」「これからどのように成長していきたいか」という意思や意欲を大切にし、お一人おひとりの個性と新しいアイデアを尊重しています。温かな環境でお迎えしますので、安心してお越しください。</p>\r\n        </div>\r\n      </li>\r\n-->\r\n\r\n      <li class=\"message-index-list__item js-inview fadein-up\">\r\n        <figure class=\"message-index-list__image\">\r\n          <img src=\"/saiyou/assets/img/hr-message/img_index05.png\" alt=\"H.M\" loading=\"lazy\" decoding=\"async\" fetchpriority=\"auto\" width=\"540\" height=\"400\">\r\n        </figure>\r\n        <div class=\"message-index-list__content\">\r\n          <p class=\"message-index-list__data\">キャリア採用担当</p>\r\n          <h3 class=\"message-index-list__subheading\">H.M.</h3>\r\n          <h2 class=\"message-index-list__heading\">人生も、キャリアも、あきらめなくていい</h2>\r\n          <p class=\"message-index-list__text\">私はプロパー社員として入社し、現在は育児と両立しながらキャリア採用に携わっています。当社には、ライフイベントを経ても安心して働き続けられる制度と風土があります。転職は勇気のいる選択ですが、「これまで」ではなく「これから」の可能性に向き合う会社です。仕事と人生、どちらも大切にしたい——そんな想いを持つ方とお会いできるのを楽しみにしています。</p>\r\n        </div>\r\n      </li>\r\n    </ul>\r\n  </div>\r\n</section>\n\n\n<section class=\"section component-nav-top\">\n  <div class=\"section__inner\">\n    <ul class=\"component-home-index\">\n      <li class=\"component-home-index__item component-home-index__item--wide\">\n        <a href=\"/saiyou/new/\">\n          <figure class=\"component-home-index__image\">\n            <span>\n              <img src=\"/saiyou/assets/img/home/img_index01.jpg\" alt=\"NEWGRAD 新卒採用\" loading=\"lazy\" decoding=\"async\" fetchpriority=\"auto\" width=\"740\" height=\"500\"></span>\n          </figure>\n          <h3 class=\"component-home-index__heading\">\n            <span class=\"component-home-index__heading-en\">NEWGRAD</span>\n            <span class=\"component-home-index__heading-ja\">新卒採用</span>\n          </h3>\n        </a>\n      </li>\n      <li class=\"component-home-index__item component-home-index__item--wide\">\n        <a href=\"/saiyou/career/\">\n          <figure class=\"component-home-index__image\">\n            <span>\n              <img src=\"/saiyou/assets/img/home/img_index02.jpg\" alt=\"CAREER キャリア採用\" loading=\"lazy\" decoding=\"async\" fetchpriority=\"auto\" width=\"740\" height=\"500\"></span>\n          </figure>\n          <h3 class=\"component-home-index__heading\">\n            <span class=\"component-home-index__heading-en\">CAREER</span>\n            <span class=\"component-home-index__heading-ja\">キャリア採用</span>\n          </h3>\n        </a>\n      </li>\n      \n      \n        <li class=\"component-home-index__item msg\">\n          <a href=\"/saiyou/hr-message/\">\n            <figure class=\"component-home-index__image\">\n              <span>\n                <img src=\"/saiyou/assets/img/home/img_index03a-s.png\" alt=\"HR MESSAGE 人事担当者メッセージ\" loading=\"lazy\" decoding=\"async\" fetchpriority=\"auto\" width=\"478\" height=\"360\"></span>\n            </figure>\n            <h3 class=\"component-home-index__heading\">\n              <span class=\"component-home-index__heading-en\">HR MESSAGE</span>\n              <span class=\"component-home-index__heading-ja\">採用責任者メッセージ</span>\n            </h3>\n          </a>\n        </li>\n      \n      <li class=\"component-home-index__item num\">\n        <a href=\"/saiyou/numbers/\">\n          <figure class=\"component-home-index__image\">\n            <span>\n              <img src=\"/saiyou/assets/img/home/img_index04-photo.png\" alt=\"INFOGRAPHIC 数字で見るＡＧＳ\" loading=\"lazy\" decoding=\"async\" fetchpriority=\"auto\" width=\"478\" height=\"360\"></span>\n          </figure>\n          <h3 class=\"component-home-index__heading\">\n            <span class=\"component-home-index__heading-en\">INFOGRAPHIC</span>\n            <span class=\"component-home-index__heading-ja\">数字で見るＡＧＳ</span>\n          </h3>\n        </a>\n      </li>\n      <li class=\"component-home-inde