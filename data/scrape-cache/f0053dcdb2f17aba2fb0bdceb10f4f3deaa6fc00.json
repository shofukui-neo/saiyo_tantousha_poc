ttps://www.ill.co.jp/recruit/education.html\" />\r\n<meta property=\"og:image\" content=\"https://www.ill.co.jp/recruit/images/common_ogp.jpg\" />\r\n<meta property=\"og:site_name\" content=\"株式会社アイル　新卒採用サイト｜思い切りバットを振れる環境が、ここにはある。\"/>\r\n<meta name=\"twitter:card\" content=\"summary_large_image\" />\r\n<meta property=\"og:locale\" content=\"ja_JP\" />\r\n<script src=\"https://code.jquery.com/jquery-3.7.1.min.js\" integrity=\"sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo=\" crossorigin=\"anonymous\"></script>\r\n<link rel=\"SHORTCUT ICON\" href=\"https://www.ill.co.jp/assets/images/common/favicon.ico\" />\r\n<link href=\"css/reset.css\" rel=\"stylesheet\" type=\"text/css\"/>\r\n<link href=\"css/common.css\" rel=\"stylesheet\" type=\"text/css\"/>\r\n<link href=\"css/education.css\" rel=\"stylesheet\" type=\"text/css\"/>\r\n<script type=\"text/javascript\" src=\"js/smoothScroll.js\"></script> \r\n<script>\r\n  (function(i,s,o,g,r,a,m){i['GoogleAnalyticsObject']=r;i[r]=i[r]||function(){\r\n  (i[r].q=i[r].q||[]).push(arguments)},i[r].l=1*new Date();a=s.createElement(o),\r\n  m=s.getElementsByTagName(o)[0];a.async=1;a.src=g;m.parentNode.insertBefore(a,m)\r\n  })(window,document,'script','https://www.google-analytics.com/analytics.js','ga');\r\n\r\n  ga('create', 'UA-36722366-1', 'auto');\r\n  ga('send', 'pageview');\r\n\r\n</script>\r\n</head>\r\n\r\n<body>\r\n<header class=\"ill-header\">\r\n  <div class=\"ill-headerInner\">\r\n    <h1><a href=\"https://www.ill.co.jp/recruit/\" class=\"ill-logo\"><img src=\"images/airu_small.png\" alt=\"株式会社アイル採用サイト\"><span>RECRUIT</span></a></h1>\r\n    <nav class=\"ill-globalNav\">\r\n      <div class=\"ill-globalMenu\">\r\n        <ul class=\"ill-globalMenuList\">\r\n          <li><a href=\"message.html\" class=\"in-the-page\"><span class=\"h__en\">MESSAGE</span><span class=\"subtitle\">アイルの想い</span></a></li>\r\n          <li><a href=\"culture.html\" class=\"in-the-page\"><span>CULTURE</span><span class=\"subtitle\">文化を知る</span><