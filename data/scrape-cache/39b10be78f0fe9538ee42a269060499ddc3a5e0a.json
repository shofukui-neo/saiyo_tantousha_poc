.replace(/\\/+$/, '');\r\n            var parts = href.split('/').filter(function (p) { return p !== ''; });\r\n            var slug = parts.length ? parts[parts.length - 1] : '';\r\n\r\n            if (!text || !slug) return;\r\n            var li = document.createElement('li');\r\n            li.classList.add('cat');\r\n            li.classList.add('news_list_' + slug);\r\n            li.textContent = text;\r\n            targetList.appendChild(li);\r\n          });\r\n\r\n          main.dataset.categoriesInitialized = '1';\r\n          return true;\r\n        }\r\n\r\n        function tryInit() {\r\n          if (initCategories()) {\r\n            clearInterval(timer);\r\n          }\r\n        }\r\n\r\n        document.addEventListener('DOMContentLoaded', tryInit);\r\n        window.addEventListener('load', tryInit);\r\n        var timer = setInterval(tryInit, 300);\r\n      })();\r\n    </script>\r\n\r\n\r\n  </body>\n\n</html>\n","finalUrl":"https://www.tobuzoo.com/news/13124.html","rendered":false,"_cachedAt":"2026-06-22T19:31:15.734Z"}