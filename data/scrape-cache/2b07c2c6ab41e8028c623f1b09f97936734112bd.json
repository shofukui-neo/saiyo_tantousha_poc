 style=\"display:none;visibility:hidden\"></iframe></noscript>\r\n<!-- End Google Tag Manager (noscript) -->\r\n\r\n  <div id=\"header-wrapper\" class=\"fv-effect fade-drop\">\r\n    <h1 class=\"site-logo\"><a href=\"http://www.mitsui-corp.co.jp/\"><img src=\"img/common/logo_blue.svg\" alt=\"美容ディーラー商社ミツイ｜美容室サポート・専売品支援 - 美容ディーラー商社ミツイ\"></a></h1>\r\n    <nav class=\"h-nav\">\r\n      <a href=\"company/\">会社案内</a>\r\n      <a href=\"/news/\">トピックス</a>\r\n      <a href=\"support/\">ミツイのサポート</a>\r\n      <a href=\"seminar/\">セミナー情報</a>\r\n      <a href=\"manufacturer/\">取り扱いメーカー</a>\r\n      <a href=\"proshop/\">プロショップ</a>\r\n      <a href=\"/mitusi_library.pdf\" class=\"pdf\">ミツイ<br>ライブラリー</a>\r\n      <a href=\"https://recruit.mitsui-corp.co.jp/\" class=\"blank\">採用情報</a>\r\n      <a href=\"faq/\">Q&A</a>\r\n      <a href=\"contact/\" class=\"h-contact\">お問い合わせ</a>\r\n    </nav>\r\n  </div><!-- / #header-wrapper -->\r\n  \r\n  <main id=\"contents-wrapper\">\r\n    <div class=\"mv effect fade-blur\"><img src=\"content/images/sample/top.jpg\" alt=\"\" class=\"fit-img\"></div>\r\n    <article class=\"about-container\">\r\n      <h2 class=\"about-ttl effect fade-txt\">人をつなぐ、<br />\r\n　美をつなぐ</h2>\r\n      <p class=\"about-txt effect fade-blur\">この世界には、さまざまな「美しい」が存在し、時に人の心を動かします。<br />\r\n日本古来から存在し、きれいを意味するこの「美しい」という文字。<br />\r\n実は、今から１２００年前の平安時代まで、この「美しい」という文字は愛しい（うつくしい）と表わされていました。<br />\r\n<br />\r\n自分の大切な家族を愛おしく思うことを愛しい（うつくしい）と表し、やがてその意味は小さきものの可憐なさまへの愛おしさへと変化します。そして、小さきものの美そのものを愛しい（うつくしい）と表したことがきっかけで、美しいという表し方が生まれたそうです。<br />\r\n<br />\r\n時は流れ、現代。ある人が言いました。<br />\r\n<br />\r\n「女性（パートナー）が美しくなれば、この世から争い事（戦争）はなくなる」<br />\r\n<br />\r\nと。<br />\r\n<br />\r\nもしかしたらその人はこの「美しい」の文字の語源を知らなかったのかもしれません。でもきっと心の奥深く、そう、心というものが始まる出発点において気付いていたのでしょう。<br />\r\n美しいとは愛しい（うつくしい／いとしい）ということなのだと。<br />\r\n<br />\r\n今日もどこかで、誰かが誰かのことを愛おしく思う。<br />\r\nそんな些細な愛しさ（うつくしさ）の連鎖は、もう一歩だけ誰かを幸せにできる。<br />\r\n<br />\r\n美容の仕事とはきっとそういうことなのです。</p>\r\n    </article><!-- / .about-container -->\r\n    \r\n    <article class=\"topics-container\">\r\n      <h2 class=\"sec-ttl effect\"><span class=\"en\">TOPICS</span>新着情報</h2>\r\n      <ul class=\"topics-list effect\">\r\n \r\n        <li>\r\n          <a href=\"https://www.mitsui-corp.co.jp/news/%E3%80%90%E5%B2%A1%E5%B1%B1%E3%80%91%E9%AB%AA%E3%81%AB%E3%83%89%E3%83%A9%E3%83%9E%E3%82%92%E3%80%82presentation/\">\r\n<div class=\"topics-list__img\"><img width=\"1810\" height=\"2560\" src=\"https://www.mitsui-corp.co.jp/wp/wp-content/uploads/2026/06/0831-%E9%AB%AA%E3%81%AB%E3%83%89%E3%83%A9%E3%83%9E%E3%82%92-%E7%99%BA%E8%A1%A8%E4%BC%9A-balance.%E9%87%8E%E7%94%B0%E5%BA%97_%E3%82%A2%E3%83%BC%E3%83%88%E3%83%9C%E3%83%BC%E3%83%89-1-scaled.jpg\" class=\"fit-img wp-post-image\" alt=\"\" decoding=\"async\" fetchpriority=\"high\" srcset=\"https://www.mitsui-corp.co.jp/wp/wp-content/uploads/2026/06/0831-髪にドラマを-発表会-balance.野田店_アートボード-1-scaled.jpg 1810w, https://www.mitsui-corp.co.jp/wp/wp-content/uploads/2026/06/0831-髪にドラマを-発表会-balance.野田店_アートボード-1-212x300.jpg 212w, https://www.mitsui-corp.co.jp/wp/wp-content/uploads/2026/06/0831-髪にドラマを-発表会-balance.野田店_アートボード-1-724x1024.jpg 724w, https://www.mitsui-corp.co.jp/wp/wp-content/uploads/2026/06/0831-髪にドラマを-発表会-balance.野田店_アートボード-1-768x1086.jpg 768w, https://www.mitsui-corp.co.jp/wp/wp-content/uploads/2026/06/0831-髪にドラマを-発表会-balance.野田店_アートボード-1-1086x1536.jpg 1086w, https://www.mitsui-corp.co.jp/wp/wp-content/uploads/2026/06/0831-髪にドラマを-発表会-balance.野田店_アートボード-1-1448x2048.jpg 1448w\" sizes=\"(max-width: 1810px) 100vw, 1810px\"></div>\n            <div class=\"topics-list-in\">\n              <div class=\"topics-list-in__date\">2026.06.18</div>\n              <div class=\"topics-list-in__ttl\">【岡山】髪にドラマを。Presentation</div>\n            </div>\r\n          </a>\r\n        </li> \r\n        <li>\r\n          <a href=\"https://www.mitsui-corp.co.jp/news/%E3%80%90%E6%A0%84%E3%80%91mens-perm/\">\r\n<div class=\"topics-list__img\"><img width=\"1810\" height=\"2560\" src=\"https://www.mitsui-corp.co.jp/wp/wp-co