</div>\r\n              <div class=\"seminar-list__category\"><span class='category'>ヘアケア</span><span class='category'>ケミカル</span><span class='category'>トリートメント</span><span class='category'></span></div>\r\n              <div class=\"seminar-list__ttl\">【福岡】MEN’S PERM</div>\r\n              <div class=\"seminar-date \">開催日時：<br> \r\n9月7日<span class=\"time\">13:00~16:00</span></div>\r\n              <div class=\"seminar-date none\">開催日時：</div>\r\n            </a>\r\n          </li> \r\n          <li>\r\n            <a href=\"seminar/#seminar4\">\r\n              <div class=\"seminar-list__img\"><img src=\"/thumb.php?src=content/images/seminar/2026/20260611-050448.jpg&amp;w=240\" alt=\"【東京】髪にドラマを。Presentation　髪質改善ストレート\"></div>\r\n              <div class=\"seminar-list__category\"><span class='category'>カラー</span><span class='category'>ヘアケア</span><span class='category'>ケミカル</span><span class='category'>トリートメント</span><span class='category'></span></div>\r\n              <div class=\"seminar-list__ttl\">【東京】髪にドラマを。Presentation　髪質改善ストレート</div>\r\n              <div class=\"seminar-date \">開催日時：<br> \r\n2026年9月1日<span class=\"time\">13:00-17:00</span></div>\r\n              <div class=\"seminar-date none\">開催日時：</div>\r\n            </a>\r\n          </li> \r\n          <li>\r\n            <a href=\"seminar/#seminar5\">\r\n              <div class=\"seminar-list__img\"><img src=\"/thumb.php?src=content/images/seminar/2026/20260618-105208.jpg&amp;w=240\" alt=\"【岡山】髪にドラマを。Presentation\"></div>\r\n              <div class=\"seminar-list__category\"><span class='category'>カラー</span><span class='category'>ヘアケア</span><span class='category'>ケミカル</span><span class='category'>トリートメント</span><span class='category'></span></div>\r\n              <div class=\"seminar-list__ttl\">【岡山】髪にドラマを。Presentation</div>\r\n              <div class=\"seminar-date \">開催日時：<br> \r\n8月31日<span class=\"time\">13:00~17:00</span></div>\r\n              <div class=\"seminar-date none\">開催日時：</div>\r\n  