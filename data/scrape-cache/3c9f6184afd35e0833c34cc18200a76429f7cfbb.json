-function: cubic-bezier(0.1, 0.57, 0.1, 1); transition-duration: 0ms; transform: translate(0px, 0px) translateZ(0px);\">\r\n\t\t\t\t\t\t<ul>\r\n\t\t\t\t\t\t<li><a href=\"https://chopro.co.jp/recruit#message\">代表挨拶</a></li>\r\n\t\t\t\t\t\t<li><a href=\"https://chopro.co.jp/recruit#interview\">社員インタビュー</a></li>\r\n\t\t\t\t\t\t<li><a href=\"https://chopro.co.jp/recruit#devision\">職種紹介</a></li>\r\n\t\t\t\t\t\t<li><a href=\"https://chopro.co.jp/recruit#gallery\">会社の風景</a></li>\r\n\t\t\t\t\t\t<li><a href=\"https://chopro.co.jp/recruit#faq\">よくある質問</a></li>\r\n\t\t\t\t\t\t<li><a href=\"https://chopro.co.jp/recruit#about\">採用情報</a></li>\t\t\t\t\t\r\n\t\t\t\t\t\t</ul>\r\n\t\t\t\t\t\t<a href=\"https://chopro.co.jp/'\" class=\"corpo\" target=\"_blank\">\t<img src=\"https://chopro.co.jp/img/recruit/common/icon_corpo.png\" alt=\"\"><span>コーポレートサイト</span></a>\r\n\t\t\t\t\r\n\t\t\t\t\t</div><!--//drawer-menu-->\r\n\t\t\t\t</nav><!--//drawer-nav-->\r\n\r\n\t\t\t</header>\n<section id=\"image\">\n\n<figure>\n\t<div class=\"catch view-lowup\"><p><b>ポジティブで</b></p><br><p><b>明るく</b></p></div>\n\t<img src=\"https://chopro.co.jp/img/recruit/profile/02/mv.jpg\" alt=\"\" class=\"pc\">\n\t<img src=\"https://chopro.co.jp/img/recruit/profile/02/mv-sp.jpg\" alt=\"\" class=\"sp\">\n</figure>\n\n<div class=\"profile\">\n\t<div class=\"name view-lowup\">\n\t\t<dl><dt>顧客サービス部</dt>\n\t\t\t<dd><p>開野 祐樹</p><em>YUKI HIRAKINO</em></dd>\n\t\t</dl>\n\n\t\t<div class=\"career\">サービス部門</div>\n\t\t<div class=\"career\">高校・普通科（県内） 2005年入社</div>\n\t</div><!--//name-->\n\n\t<div class=\"titlebox\">\n\t<h4 style=\"color: #222; text-align: left;\"><span>SCHEDULE</span><em>1日のスケジュール</em></h4>\n\t</div>\t\n\t<div class=\"flow\">\n\t\t<figure class=\"view-lowright\"><img src=\"https://chopro.co.jp/img/recruit/profile/02/p01.jpg\" alt=\"\"></figure>\n\t\t<ul class=\"view-lowleft\">\n\t\t\t<li>\n\t\t\t\t<dl>\n\t\t\t\t\t<dt>7:00</dt>\n\t\t\t\t\t<dd><b>出社</b><span></span></dd>\n\t\t\t\t</dl>\n\t\t\t</li>\n\n\t\t\t<li>\n\t\t\t\t<dl>\n\t\t\t\t\t<dt>8:25</dt>\n\t\t\t\t\t<dd><b>会社到着</b><span></span></dd>\n\t\t\t\t</dl>\n\t\t\t</li>\n\n\t\t\t<li>\n\t\t\t\t<dl>\n\t\t\t\t\t<dt>8:30</dt>\n\t\t\t\t\t<dd><b>朝礼</b><span>本日訪問するお客様情報を確認し、担当者へ振り分け</span></dd>\n\t\t\t\t</dl>\n\t\t\t</li>\n\n\t\t\t<li>\n\t\t\t\t<dl>\n\t\t\t\t\t<dt>9:00</dt>\n\t\t\t\t\t<dd><b>部門間ミーティング</b><span>各部署と情報の共有</span></dd>\n\t\t\t\t</dl>\n\t\t\t</li>\n\n\t\t\t<li>\n\t\t\t\t<dl>\n\t\t\t\t\t<dt>10:00</dt>\n\t\t\t\t\t<dd><b>業務確認</b><span>担当者の対応に問題がないかなどチェック</span></dd>\n\t\t\t\t</dl>\n\t\t\t</li>\n\n\t\t</ul>\n\t\t<ul class=\"view-lowleft\">\n\t\t\t<li>\n\t\t\t\t<dl>\n\t\t\t\t\t<dt>13:00</dt>\n\t\t\t\t\t<dd><b>ミーティング</b><span>関連部署と課題解決のため打合せ</span></dd>\n\t\t\t\t</dl>\n\t\t\t</li>\n\n\t\t\t<li>\n\t\t\t\t<dl>\n\t\t\t\t\t<dt>15:00</dt>\n\t\t\t\t\t<dd><b>お客様対応</b><span>コンロの買替を検討されている<br class=\"br\">お客様宅へご訪問</span></dd>\n\t\t\t\t</dl>\n\t\t\t</li>\n\n\t\t\t<li>\n\t\t\t\t<dl>\n\t\t\t\t\t<dt>17:00</dt>\n\t\t\t\t\t<dd><b>業務確認</b><span>夕食時はガスの利用が増えるため、<br class=\"br\">担当スタッフの帰社は18:00過ぎることも</span></dd>\n\t\t\t\t</dl>\n\t\t\t</li>\n\n\t\t\t<li>\n\t\t\t\t<dl>\n\t\t\t\t\t<dt>18:30</dt>\n\t\t\t\t\t<dd><b>退社</b><span></span></dd>\n\t\t\t\t</dl>\n\t\t\t</li>\n\n\t\t</ul>\n\t\t\n\t</div><!--//flow-->\n</div><!--//profile-->\n</section>\n\n<section id=\"qa\">\n\t<div class=\"inner\">\n\t\t<div class=\"titlebox\">\n\t\t<h4 style=\"color: #00a0e9;\" class=\"marginb\"><span>INTERVIEW</span><em>社員インタビュー</em></h4>\n\t\t</div>\t\n\t\t\n\t\t<div class=\"qabox\">\n      <div class=\"column__flex\">\n        <article class=\"view-lowup\">\n          <div class=\"honbun\">\n            <div class=\"titlebox\">\n            <h4 style=\"color: #00a0e9;\"><span>Q.01</span></h4>\n            <div class=\"title marginb\">どんな仕事をしていますか。</div>\n            <p>一般家庭向けサービス全般を司る部署の課長を務めています。法令順守のガス点検、機器の修理、機器販売。元気な若い社員が多く、活発な議論を交わしています。単にモノを売るのではなく、お客様のお困りごとを解決し、生活を豊かにするコトを第一に考えています。</p>\n            </div>\n          </div>\n        </article>\n\n        <article class=\"view-lowup\">\n          <div class=\"honbun\">\n            <div class=\"titlebox\">\n            <h4 style=\"color: #00a0e9;\"><span>Q.02</span></h4>\n            <div class=\"title marginb\">入社したきっかけは？</div>\n            <p>災害の多い日本において、人のため自分の好きな町のために何かできる仕事に就きたいと思い、災害時も活躍するLPガスの会社を選びました。LPガス事業だけでなく、エネルギーを活用し、様々なことに挑戦する姿勢に惹かれ入社しました。</p>\n            </div>\n          </div>\n\n        </article>\t\n\t\t\t\n\t\t\t<article class=\"view-lowup w-100\">\n\t\t\t\t<div class=\"honbun\">\n\t\t\t\t\t<div class=\"titlebox\">\n\t\t\t\t\t<h4 style=\"color: #00a0e9;\"><span>Q.03</span></h4>\n\t\t\t\t\t<div class=\"title marginb\">会社の好きなところは？</div>\n\t\t\t\t\t<p>社員同士が仲が良く、和気あいあいとしているところです。会社では様々な行事があり、部署を超えた交流も盛んに行われています。スポーツ社員に対し、<br class=\"br\">社員全体の応援や支援が良い。試合や遠征、練習などで業務支障がないよう周りの社員が協力し合うのを見てきて良い会社だと思っています。<br class=\"br\">勿論、我々もスポーツ社員から元気をもらっています。<br class=\"br\">仕事面では生活に欠かせないライフラインであり、未来を創り出すエネルギー事業に携われることにやりがいを感じています。</p>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t\n\t\t\t</article>\t\n\t\t\t\n\t\t\t<article class=\"view-lowup w-100\">\n\t\t\t\t<div class=\"honbun\">\n\t\t\t\t\t<div class=\"titlebox\">\n\t\t\t\t\t<h4 style=\"color: #00a0e9;\"><span>Q.04</span></h4>\n\t\t\t\t\t<div class=\"title marginb\">印象に残っている仕事について教えて下さい。</div>\n\t\t\t\t\t<p>ガス機器の販売時、当社でリフォームを行ったお客様のことです。ご家族に足が不自由な方がおり、段差が気になることや機器を安全に使いたいとのお話がありました。私なりに精一杯考え、浴室の段差をなくし、浴槽は水位が浅いものにする。ガスコンロは消し忘れがあると自動で消えるなど、要望に合わせたご提案で成約することが出来ました。「チョープロに頼めば、ちゃんと対応してもらえるから安心ですね」と言われ、お客様の笑顔を見れたことが一番印象に残っています。お客様の気持ちに寄り添うことの大切さを学びました。</p>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t\n\t\t\t</article>\t\n\t\t\t\n\t\t\t<article class=\"view-lowup\">\n\t\t\t\t<div class=\"honbun\">\n\t\t\t\t\t<div class=\"titlebox\">\n\t\t\t\t\t<h4 style=\"color: #00a0e9;\"><span>Q.05</span></h4>\n\t\t\t\t\t<div class=\"title marginb\">県外ではなく長崎を選んだ理由は？</div>\n\t\t\t\t\t<p>坂や狭い道の多い長崎ですがそれも魅力のひとつだと思います。<br class=\"br\">そんな長崎の地形を活かし、生活を支えることができるのもLPガスの魅力です。ライフラインの会社として、高齢の方や斜面地の生活を支え、地元に貢献していきたいです。</p>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t\n\t\t\t</article>\t\n\t\t\t\n\t\t\t<article class=\"view-lowup\">\n\t\t\t\t<div class=\"honbun\">\n\t\t\t\t\t<div class=\"titlebox\">\n\t\t\t\t\t<h4 style=\"color: #00a0e9;\"><span>Q.06</span></h4>\n\t\t\t\t\t<div class=\"title marginb\">今までのキャリアとこれからの<br class=\"br\">キャリアプランについて教えて下さい。<br class=\"br\">（今後やりたいことなど）</div>\n\t\t\t\t\t<p>入社して15年が経過しました。プロパン運搬から工事・営業と経験し、現在管理職という立場になり、部下をまとめる役割を行っています。部署を一つにまとめることの難しさを日々痛感していますが、安全を第一に、保安業務遵守に務めながら営業成績を伸ばしていきたいです。</p>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t\n\t\t\t</article>\t\n\t\t\t\n\t\t\t<article class=\"view-lowup\">\n\t\t\t\t<div class=\"honbun\">\n\t\t\t\t\t<div class=\"titlebox\">\n\t\t\t\t\t<h4 style=\"color: #00a0e9;\"><span>Q.07</span></h4>\n\t\t\t\t\t<div class=\"title marginb\">学生時代の思い出は？</div>\n\t\t\t\t\t<p>高校生時代は毎日、部活のサッカー部でゴールキーパーをやっていました。高校総体での活躍を評価され、長崎県代表に選んでいただき、国体に出場したことが思い出深いです。</p>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t\n\t\t\t</article>\t\n\t\t\t\n\t\t\t<article class=\"view-lowup\">\n\t\t\t\t<div class=\"honbun\">\n\t\t\t\t\t<div class=\"titlebox\">\n\t\t\t\t\t<h4 style=\"color: #00a0e9;\"><span>Q.08</span></h4>\n\t\t\t\t\t<div class=\"title marginb\">オフの日の楽しみは？</div>\n\t\t\t\t\t<p>家族と過ごすことを大事にしています。<br class=\"br\">子どもと遊ぶ時間が何より楽しみです。</p>\n\t\t\t\t\t</div>\n\t\t\t\t\t\n\t\t\t\t</div>\n\t\t\t\n\t\t\t</article>\t\n      </div>\n\t\t</div><!--//qabox-->\n\t</div><!--//inner-->\n\n\n\t<article class=\"last view-lowup w-100\">\n\t\t<div class=\"inner\">\t\n\t<figure class=\"sp\"><img src=\"https://chopro.co.jp/img/recruit/profile/02/p02.jpg\" alt=\"\"></figure>\t\t\t\n\t<div class=\"honbun\">\n\t<div class=\"titlebox\">\n\t<div class=\"title marginb\">どんな人と一緒に働きたいですか？</div>\n\t<p>「素直」で「ポジティブ」な人。<br class=\"br\">素直に話が出来て、自分の気持ち伝え、周りのことも見て、<br class=\"br\">人に寄り添うことができる人と仕事をしたいですね。<br class=\"br\">また常にポジティブで向上心がある人が活躍できる場所だと思います。</p>\n\t</div>\n\t</div>\n\t<figure class=\"pc\"><img src=\"https://chopro.co.jp/img/recruit/profile/02/p02.jpg\" alt=\"\"></figure>\n\t\t\t</div>\t\n\t</article>\t\n\n</section>\n\n\n<section id=\"interview\" class=\"view-lowup\">\n\t<div class=\"interviewbox\">\n\t\t\n\t\t\n\t\t\t<div class=\"titlebox\">\n\t\t\t\t\n\t\t\t\t\t\t\t\t<h4 style=\"color: #00a0e9;\"><span>INTERVIEW</span></h4>\n\t\t\t\t<div class=\"title marginb2\">他の社員の<br class=\"br2\">インタビューはこちら</div>\t\n\t\t\t\t\t\t\t</div>\n\t\t\n\t\t\t<ul>\n\t\t\t\t\n\t\t\t\t\t\t\t\t\t\t\t\t\n\t\t\t\t\t\t\t\t<li>\n\t\t\t\t\t<span>02 INTERVIEW</span>\n\t\t\t\t\t<div class=\"catch\"><p><b>長崎で</b></p><br><p><b>活躍したい</b></p></div>\n\t\t\t\t\t\n\t\t\t\t\t<a href=\"https://chopro.co.jp/recruit/people03\">\n\t\t\t\t\t\t<figure class=\"scale\"><img src=\"https://chopro.co.jp/img/recruit/index/shimada.jpg\" alt=\"\">\n\t\t\t\t\t\t<img src=\"https://chopro.co.jp/img/recruit/index/shimada_h.jpg\" alt=\"\"></figure>\n\t\t\t\t\t\t\n\t\t\t\t\t\t<div class=\"profile\">\n\t\t\t\t\t\t\t<dl><dt>経理部</dt><dd><b>経理部門</b><p>2020年入社</p></dd></dl>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t\n\t\t\t\t\t</a>\n\t\t\t\t\t\n\t\t\t\t\t\n\t\t\t\t</li>\n\t\t\t\t\t\t\t\t\n\t\t\t\t\t\t\t\t<li>\n\t\t\t\t\t<span>03 INTERVIEW</span>\n\t\t\t\t\t<div class=\"catch\"><p><b>地元に</b></p><br><p><b>恩返しを</b></p></div>\n\t\t\t\t\t\n\t\t\t\t\t<a href=\"https://chopro.co.jp/recruit/people04\">\n\t\t\t\t\t\t<figure class=\"scale\"><img src=\"https://chopro.co.jp/img/recruit/index/matsuo.jpg\" alt=\"\">\n\t\t\t\t\t\t<img src=\"https://chopro.co.jp/img/recruit/index/matsuo_h.jpg\" alt=\"\">\n\t\t\t\t\t\t</figure>\n\t\t\t\t\t\t\n\t\t\t\t\t\t<div class=\"profile\">\n\t\t\t\t\t\t\t<dl><dt>営業部</dt><dd><b>営業部門</b><p>2013年入社</p></dd></dl>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</a>\n\t\t\t\t\t\n\t\t\t\t\t\n\t\t\t\t</li>\n\t\t\t\t\n\t\t\t\t\t\t\t\t\n\t\t\t\t\n\t\t\t</ul>\n\t\t</div><!--//interviewbox-->\n</section><!--//interview-->\n<footer>\n  <div id=\"pagetop\"></div>\n  <div class=\"inner\">\n    <div class=\"footerbox\">\n      <div class=\"left\">\n        <a href=\"https://chopro.co.jp/recruit\" class=\"flogo\"><img src=\"https://chopro.co.jp/