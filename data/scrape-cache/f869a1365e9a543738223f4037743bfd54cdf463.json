w.pickles.co.jp/recruit/wp-content/themes/pickles.co.jp/img/ico_company.svg\" alt=\"コーポレートサイト\">コーポレートサイト　＞</a>\n          </div>\n        </div></div>\n        <div class=\"nav-img\">\n          <img class=\"sp_only\" src=\"https://www.pickles.co.jp/recruit/wp-content/themes/pickles.co.jp/img/img_nav_01.jpg\" alt=\"PICKLES\">\n        </div>\n      </div>\n    </div>\n  </div>\n</div></header>\n<!-- /#header -->\n\n<main class=\"main\">\n<nav class=\"breadcrumbs\"><div class=\"container\"><span><span><a href=\"https://www.pickles.co.jp/recruit/\" >トップ</a> <span class=\"arrow\">＞</span> <span class=\"breadcrumb_last\">新卒採用募集要項</span></span></span></div></nav><style>\n.page-title .page-sub-title{\n  background-image: url(https://www.pickles.co.jp/recruit/wp-content/uploads/2019/02/mv-guideline-new.jpg);\n}\n@media screen and (max-width: 480px) {\n  .page-title .page-sub-title{\n    background-image: url(https://www.pickles.co.jp/recruit/wp-content/uploads/2019/02/mv-guideline-new-sp.jpg);\n  }\n}\n</style>\n<article class=\"article article-guideline\">\n<section class=\"page-title\">\n  <h2><span class=\"color-primary\">採用</span>情報</h2>\n  <div class=\"page-sub-title\">\n    <h3>新卒採用</h3>\n  </div>\n</section>\n\n<div class=\"container\">\n<h3 class=\"title-primary\">新卒採用募集要項</h3>\n\n<div class=\"guidelines\">\n  <div class=\"guideline\">\n      <h4 class=\"title\">募集企業/採用予定</h4>\n      <table class=\"table table-borderd\">\n        <tr>\n      <th><div class=\"inner\">ピックルスコーポレーション</div></th>\n      <td><div class=\"inner\">15名程度</div></td>\n    </tr>\n        <tr>\n      <th><div class=\"inner\">ピックルスコーポレーション関西 </div></th>\n      <td><div class=\"inner\">若干名</div></td>\n    </tr>\n        <tr>\n      <th><div class=\"inner\">ピックルスコーポレーション西日本</div></th>\n      <td><div class=\"inner\">若干名</div></td>\n    </tr>\n      </table>\n    </div>\n  <div class=\"guideline\">\n      <h4 class=\"title\">総合職（全国転勤型）</h4>\n      <table class=\"table table-borderd\">\n        <tr>\n      <th><div class=\"inner\">職種内容</div></th>\n      <td><div class=\"inner\">1．製造管理：生産システム・機械設備、製造工程管理などの製造に関する業務<br />\n2．営業：あさづけ・惣菜などの販売および販売促進に関する業務、商品提案業務<br />\n3．新規事業：テーマパーク事業の企画立案、運営等<br />\n4．製品開発：プライベートブランド・自社のナショナルブランドの開発<br />\n5．品質管理：製商品の検査や生産システム改善などの品質衛生管理に関する業務<br />\n6．基礎研究：野菜の鮮度保持に関する基礎研究、特許取得に関する業務<br />\n7．物流管理：商品仕入、在庫管理、得意先仕分などの受注・物流に関する業務<br />\n8．デザイン：パッケージデザインなど商品のデザインに関する業務<br />\n9．総務：人事、労務、広告・宣伝、給与事務、HP管理、関連会社管理などの総務業務<br />\n10．経理：仕訳、決算事務、税務申告、連結決算などの財務および経理関連業務<br />\n11．広報IR：広報・IR活動を通じ企業知名度、企業理解度を対外的に向上させる業務<br />\n12．システム管理：社内システムの運用、メンテナンス、各種のマスター管理など</div></td>\n    </tr>\n        <tr>\n      <th><div class=\"inner\">募集学科</div></th>\n      <td><div class=\"inner\">全学部全学科</div></td>\n    </tr>\n        <tr>\n      <th><div class=\"inner\">応募資格 </div></th>\n      <td><div class=\"inner\">2026年3月卒業見込みの方</div></td>\n    </tr>\n        <tr>\n      <th><div class=\"inner\">勤務地</div></th>\n      <td><div class=\"inner\">ピックルスコーポレーション：埼玉県等当社事業所<br />\nピックルスコーポレーション関西：京都府等当社事業所<br />\nピックルスコーポレーション西日本：佐賀県</div></td>\n    </tr>\n        <tr>\n      <th><div class=\"inner\">初任給</div></th>\n      <td><div class=\"inner\">大学院卒：229,000円(2024年実績)<br />\n大　　卒：221,000円(2024年実績)</div></td>\n    </tr>\n        <tr>\n      <th><div class=\"inner\">諸手当 </div></th>\n      <td><div class=\"inner\">時間外手当、通勤手当、資格手当　など </div></td>\n    </tr>\n        <tr>\n      <th><div class=\"inner\">昇 給・賞 与 </div></th>\n      <td><div class=\"inner\">昇給：年1回（4月）<br />\n賞与：年2回（5月・10月）</div></td>\n    </tr>\n        <tr>\n      <th><div class=\"inner\">勤務時間</div></th>\n      <td><div class=\"inner\">9:00～18:00（休憩65分）<br />\n</div></td>\n    </tr>\n        <tr>\n      <th><div class=\"inner\">休 日・休 暇</div></th>\n      <td><div class=\"inner\">休日：年間120日（当社カレンダーによる）<br />\n休暇：有給休暇、慶弔休暇、子の看護休暇　等<br />\nリフレッシュ休暇として有給休暇の連続取得を推奨</div></td>\n    </tr>\n        <tr>\n      <th><div class=\"inner\">福利厚生</div></th>\n      <td><div class=\"inner\">各種社会保険、慶弔金、従業員持株会、自己啓発支援制度、資格取得支援制度、退職金制度　など</div></td>\n    </tr>\n        <tr>\n      <th><div class=\"inner\">教育制度</div></th>\n      <td><div class=\"inner\">内定者研修（入社前）、新入社員研修（1年目）、新入社員フォローアップ研修（1年目）、OJT研修、<br />\n若手社員ステージアップ研修（3年目）、部門別研修、工場研修、マネジメント研修、教育クラウドの導入　など</div></td>\n    </tr>\n      </table>\n    </div>\n  <div class=\"guideline\">\n      <h4 class=\"title\">一般職</h4>\n      <table class=\"table table-borderd\">\n        <tr>\n      <th><div class=\"inner\">職種内容</div></th>\n      <td><div class=\"inner\">1．営業事務：販売促進資料作成など営業サポート全般業務<br />\n2．物流事務：受発注業務及び出荷に関する業務<br />\n3．経理事務：月次処理等経理関連業務<br />\n4．品質管理：各工場での品質管理業務<br />\n5．製造管理：各工場での製造管理業務<br />\n6．開発事務：製品開発に関する書類作成、アシスタント業務</div></td>\n    </tr>\n        <tr>\n      <th><div class=\"inner\">募集学科 </div></th>\n      <td><div class=\"inner\">短期大学、専門学校卒業見込みの方</div></td>\n    </tr>\n        <tr>\n      <th><div class=\"inner\">応募資格 </div></th>\n      <td><div class=\"inner\">2026年3月卒業見込みの方</div></td>\n    </tr>\n        <tr>\n      <th><div class=\"inner\">初任給 </div></th>\n      <td><div class=\"inner\">短大・専門学校卒：195,000～205,000円(2024年実績)</div></td>\n    </tr>\n      </table>\n    </div>\n  <div class=\"guideline\">\n      <h4 class=\"title\">採用人数</h4>\n      <table class=\"table table-borderd\">\n        <tr>\n      <th><div class=\"inner\">2025年4月</div></th>\n      <td><div class=\"inner\">入社予定14名(3社計)</div></td>\n    </tr>\n        <tr>\n      <th><div class=\"inner\">2024年4月</div></th>\n      <td><div class=\"inner\">入社実績11名(4社計)</div></td>\n    </tr>\n        <tr>\n      <th><div class=\"inner\">2023年4月</div></th>\n      <td><div class=\"inner\">入社実績8名(4社計)</div></td>\n    </tr>\n      </table>\n    </div>\n  <div class=\"guideline\">\n      <h4 class=\"title\">採 用 実 績（学 校）</h4>\n      <table class=\"table table-borderd\">\n        <tr>\n      <th><div class=\"inner\">大学院</div></th>\n      <td><div class=\"inner\">大阪大学、香川大学、北里大学、京都大学、近畿大学、埼玉大学、佐賀大学、静岡大学、島根大学、首都大学東京、城西大学、女子栄養大学、千葉大学、東京大学、東京農業大学、東京薬科大学、東京理科大学、法政大学、長浜バイオ大学、徳島大学、北海道大学、山梨大学、早稲田大学　ほか</div></td>\n    </tr>\n        <tr>\n      <th><div class=\"inner\">大 学</div></th>\n      <td><div class=\"inner\">秋田県立大学、麻布大学、亜細亜大学、大妻女子大学、帯広畜産大学、鹿児島大学、関西大学、関西外国語大学、関西学院大学、北里大学、学習院大学、京都産業大学、共立女子大学、近畿大学、甲子園大学、駒澤大学、埼玉大学、佐賀大学、四国大学、静岡県立大学、昭和女子大学、実践女子大学、十文字学園女子大学、城西大学、上智大学、女子栄養大学、成城大学、大正大学、白百合女子大学、静岡大学、拓殖大学、多摩美術大学、大東文化大学、玉川大学、千葉大学、中央大学、中京大学、天使大学、東海大学、東京医療保健大学、東京家政大学、東京工科大学、東京農業大学、東京農工大学、東京薬科大学、東北大学、東洋大学、同志社大学、同志社女子大学、獨協大学、日本大学、日本獣医生命科学大学、日本女子大学、広島大学、福岡女子大学、法政大学、北海道大学、北海学園大学、武庫川女子大学、武蔵大学、武蔵野美術大学、明治大学、明星大学、立教大学、山形県立米沢栄養大学、山口大学、横浜市立大学、酪農学園大学、早稲田大学、新潟食糧大学、亜細亜大学　ほか</div></td>\n    </tr>\n        <tr>\n      <th><div class=\"inner\">短 期 大 学・専 門 学 校</div></th>\n      <td><div class=\"inner\">大原簿記学校、就実短期大学、女子栄養大学短期大学部、東京家政大学短期大学部、北海道武蔵女子短期大学　ほか</div></td>\n    </tr>\n      </table>\n    </div>\n</div>\n</div>\n\n  <div class=\"btn-wrap\"><a target=\"_blank\" href=\"https://job.mynavi.jp/27/pc/search/corp62386/outline.html\" class=\"btn btn-primary-square btn-block\">今すぐエントリー</a></div>\n\n</article>\n</main>\n\n<footer id=\"footer\"><div class=\"inner\">\n  <div class=\"container\">\n    <div class=\"pagetop\"><a href=\"#\"><img src=\"https://www.pickles.co.jp/recruit/wp-content/themes/pickles.co.jp/img/btn_pagetop.svg\" alt=\"pagetop\"></a></div>\n    <div class=\"link\"><a href=\"http://pickles.co.jp/\">コーポレートサイトへ</a></div>\n    <div class=\"copy\"><p>Copyright © Pickles Corporation All Rights Reserved.</p></div>\n  </div>\n</div></footer>\n\n</div>\n<script type='text/javascript' id='contact-form-7-js-extra'>\n/* <![CDATA[ */\nvar wpcf7 = {\"apiSettings\":{\"root\":\"https:\\/\\/www.pickles.co.jp\\/recruit\\/wp-json\\/contact-form-7\\/v1\",\"namespace\":\"contact-form-7\\/v1\"}};\n/* ]]> */\n</script>\n<script type='text/javascript' src='https://www.pickles.co.jp/recruit/wp-content/plugins/contact-form-7/includes/js/scripts.js?ver=5.1.1' id='contact-form-7-js'></script>\n<script type='text/javascript' src='https://www.pickles.co.jp/recruit/wp-includes/js/jquery/jquery.form.min.js?ver=4.3.0' id='jquery-form-js'></script>\n<script type='text/javascript' src='https://www.pickles.co.jp/recruit/wp-content/plugins/contact-form-7-add-confirm/includes/js/scripts.js?ver=5.1' id='contact-form-7-confirm-js'></script>\n</body>\n</html><!-- WP Fastest Cache file was created in 0.043554067611694 seconds, on 23-06-26 6:22:11 --><!-- need to refresh to see cached version -->","finalUrl":"https://www.pickles.co.jp/recruit/guideline-new/","rendered":false,"_cachedAt":"2026-06-22T21:22:14.143Z"}