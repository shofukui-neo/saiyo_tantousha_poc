 > 0){\r\n        $('.tel-link').each(function(){\r\n            var str = $(this).text();\r\n            $(this).html($('<a>').attr('href', 'tel:' + str.replace(/-/g, '')).append(str + '</a>'));\r\n        });\r\n    }\r\n});\r\n</script>\r\n\r\n<!-- Global site tag (gtag.js) - Google Analytics -->\r\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=UA-106470999-1\"></script>\r\n<script>\r\n  window.dataLayer = window.dataLayer || [];\r\n  function gtag(){dataLayer.push(arguments);}\r\n  gtag('js', new Date());\r\n\r\n  gtag('config', 'UA-106470999-1');\r\n</script>\r\n<!-- GoogleAnalytics -->\r\n\r\n</head>\r\n\r\n<body>\r\n\r\n<div id=\"wrapper\" class=\"contact\">\r\n\r\n<header>\r\n  <div class=\"pc h_inner_top\">\r\n    <h1>カガク興商株式会社のお問い合わせ</h1>\r\n  </div>\r\n  <div id=\"fixedBox\" class=\"pc h_inner\">\r\n    <ul class=\"menu clearfix\">\r\n      <li>\r\n        <a href=\"./\">\r\n          <img src=\"img/common/h_logo.png\" width=\"287px\" height=\"33px\" alt=\"\" >\r\n        </a>\r\n      </li>\r\n      <li>\r\n        <img src=\"img/common/nav01.png\" alt=\"\" >\r\n        <ul class=\"clearfix\">\r\n          <li>\r\n            <a href=\"material.html\">\r\n              溶材部\r\n            </a>\r\n          </li>\r\n          <li>\r\n            <a href=\"oil.html\">\r\n              石油販売部\r\n            </a>\r\n          </li>\r\n          <li>\r\n            <a href=\"gas.html\">\r\n              石油ガス部\r\n            </a>\r\n          </li>           \r\n        </ul>\r\n      </li>\r\n      <li>\r\n        <a href=\"company.html\">\r\n          <img src=\"img/common/nav02.png\" alt=\"\" >\r\n        </a>\r\n      </li>      \r\n      <li>\r\n        <a href=\"recruit.html\">\r\n          <img src=\"img/common/nav03.png\" alt=\"\" >\r\n        </a>\r\n      </li>\r\n      <li>\r\n        <a href=\"sdgs.html\">\r\n          <img src=\"img/common/nav05.png\" alt=\"\" >\r\n        </a>\r\n      </li>\t\t\t\r\n      <li class=\"current\">\r\n        <a href=\"contact.html\">\r\n          <img src=\"img/common/nav04.png\" alt=\"\" >\r\n        </a>\r\n      </li>\r\n    </ul>\r\n  </div>\r\n  <div class=\"pc main01\">\r\n    <a href=\"./\">ホーム</a>　＞　お問い合わせ\r\n  </div>\r\n  \r\n  <div id=\"fixedBox\" class=\"sp h_inner\">\r\n    <div class=\"nav-wrap\">\r\n      <div class=\"menu\">\r\n        <a href=\"./\">\r\n          <img src=\"img/common/sp_h_logo.png\" width=\"250px\" height=\"44px\" alt=\"\" >\r\n        </a>\r\n        <div class=\"gnav-btn\">\r\n          <div class=\"icon-animation\">\r\n            <span class=\"top\"></span>\r\n            <span class=\"middle\"></span>\r\n            <span class=\"bottom\"></span>\r\n          </div>\r\n        </div>\r\n      </div>\r\n      <nav>\r\n        <ul class=\"gnav\">\r\n          <li><a href=\"./\">ホーム</a></li>\r\n          <li>\r\n            <p><span>業務内容　&#9661;</span></p>\r\n            <ul>\r\n              <li><a href=\"material.html\">　溶材部</a></li>\r\n              <li><a href=\"oil.html\">　石油販売部</a></li>\r\n              <li><a href=\"gas.html\">　石油ガス部</a></li>\r\n            </ul>\r\n          </li>\r\n          <li><a href=\"company.html\">会社案内</a></li>\r\n          <li><p><span>求人情報　&#9661;</span></p>\r\n            <ul>\r\n              <li><a href=\"recruit.html\">　求人情報</a></li>\r\n              <li><a href=\"voice.html\">　先輩社員の声</a></li>\r\n            </ul>\r\n          </li>\r\n          <li><a href=\"sdgs.html\">SDGsへの取り組み</a></li>\t\t\t\r\n          <li><a href=\"contact.html\">お問い合わせ</a></li>\r\n          <li><a href=\"information.html\">個人情報の取扱について</a></li>\r\n          <li><a href=\"about.html\">当サイトご利用について</a></li>\r\n        </ul>\r\n      </nav>\r\n    </div>\r\n  </div><!-- / sp -->  \r\n\r\n  <div class=\"sp h_img\">\r\n    <img src=\"img/contact/sp_contact_main.jpg\" width=\"1050px\" height=\"577px\" alt=\"\" >\r\n  </div>\r\n  \r\n</header>\r\n\r\n<div id=\"main\">\r\n  <article class=\"main02\">\r\n    <section>\r\n      <div class=\"contact_txt01\">\r\n        当サイトにご訪問いただき誠にありがとうございます。<br>\r\n        当社製品・サービス等に関するご意見・ご質問等は、 下記のメール送信フォームよりご送信願います。<br>\r\n        ■土日祝にご連絡をいただいた場合は、翌営業日以降にご連絡させて頂いております。<br>\r\n        ■個人情報の取得及び利用目的をお読みいただき、 同意された方のみご使用願います。<br>\r\n        ■項目欄の*印がついているものは必須項目です。 必ずご入力願います。\r\n      </div>\r\n    </section>\r\n  </article>\r\n  <article class=\"main_b01\">\r\n    <section>\r\n\r\n      <div class=\"ttl03\">お客様情報</div>\r\n      \r\n      <form method=\"post\" action=\"mail.php\">\r\n      <table>\r\n        <tr>\r\n          <th>お客様へのご連絡<span class=\"red\">&nbsp;&nbsp;*必須</span></th>\r\n          <td>\r\n            <input type=\"radio\" name=\"連絡方法\" value=\"電話\" /> 電話<br>\r\n            <input type=\"radio\" name=\"連絡方法\" value=\"メール\" /> メール<br>\r\n          </td>\r\n        </tr>\r\n        <tr>\r\n          <th>お名前<span class=\"red\">&nbsp;&nbsp;*必須</span></th>\r\n          <td><input type=\"text\" name=\"お名前\" class=\"input_txt01\"></td>\r\n        </tr>\r\n        <tr>\r\n          <th>フリガナ<span class=\"red\">&nbsp;&nbsp;*必須</span></th>\r\n          <td><input type=\"text\" name=\"フリガナ\" class=\"input_txt01\"></td>\r\n        </tr>\r\n        <tr>\r\n          <th>貴社名</th>\r\n          <td><input type=\"text\" name=\"貴社名\" class=\"input_txt01\"></td>\r\n        </tr>\r\n        <tr>\r\n          <th>メールアドレス</th>\r\n          <td><input type=\"text\" name=\"メールアドレス\" class=\"input_txt01\"></td>\r\n        </tr>\r\n        <tr>\r\n          <th>郵便番号</th>\r\n          <td><input type=\"text\" name=\"郵便番号\" class=\"input_txt03\"></td>\r\n        </tr>\r\n        <tr>\r\n          <th>ご住所</th>\r\n          <td><input type=\"text\" name=\"ご住所\" class=\"input_txt01\"></td>\r\n        </tr>\r\n        <tr>\r\n          <th>電話番号</th>\r\n          <td><input type=\"text\" name=\"電話番号\" class=\"input_txt03\"></td>\r\n        </tr>\r\n        <tr>\r\n          <th>ご用件</th>\r\n          <td>\r\n            <input type=\"radio\" name=\"ご用件\" value=\"各種高圧ガス、溶接・溶断関連商品等について\" /> 各種高圧ガス、溶接・溶断関連商品等について<br>\r\n            <input type=\"radio\" name=\"ご用件\" value=\"ガソリンスタンド、石油製品、灯油等について\" /> ガソリンスタンド、石油製品、灯油等について<br>\r\n            <input type=\"radio\" name=\"ご用件\" value=\"LPガス、LPガス関連商品、リフォーム等について\" /> LPガス、LPガス関連商品、リフォーム等について<br>\r\n            <input type=\"radio\" name=\"ご用件\" value=\"その他ご意見・ご質問等\" /> その他ご意見・ご質問等<br>\r\n          </td>\r\n        </tr>\r\n        <tr>\r\n          <th>お問い合わせ件名</th>\r\n          <td><input type=\"text\" name=\"お問合せ件名\" class=\"input_txt01\"></td>\r\n        </tr>\r\n        <tr>\r\n          <th>お問い合わせ内容<br>ご意見・ご感想等</th>\r\n          <td><textarea name=\"お問合せ内容\" rows=\"8\" class=\"input_txt02\"></textarea></td>\r\n        </tr>\r\n      </table>\r\n\r\n      <div class=\"contact_txt03\">\r\n        以上の内容を送信いたします。<br>\r\n        必ず内容をご確認のうえ、【送信】ボタンを押してください。<br>\r\n        <input type=\"submit\" value=\"送信\"  class=\"contact_btn01\" />\r\n      </div>\r\n      </form>\r\n    </section>\r\n  </article>\r\n</div><!--  /main -->\r\n\r\n<footer>\r\n  <div id=\"pagetop\">\r\n    <a href=\"#wrapper\">\r\n      <img src=\"img/common/sp_pagetop.png\" width=\"80px\" height=\"69px\" alt=\"pagetop\" />\r\n    </a>\r\n  </div>\r\n  <div class=\"f_inner01\">\r\n    <ul class=\"b_nav clearfix\">\r\n      <li><a href=\"./\">ホーム</a>&nbsp;&nbsp;｜&nbsp;&nbsp;</li>\r\n      <li><a href=\"material.html\">溶材部</a>&nbsp;&nbsp;｜&nbsp;&nbsp;</li>\r\n      <li><a href=\"oil.html\">石油販売部</a>&nbsp;&nbsp;｜&nbsp;&nbsp;</li>\r\n      <li><a href=\"gas.html\">石油ガス部</a>&nbsp;&nbsp;｜&nbsp;&nbsp;</li>\r\n      <li><a href=\"company.html\">会社案内</a>&nbsp;&nbsp;｜&nbsp;&nbsp;</li>\r\n      <li><a href=\"recruit.html\">求人案内</a>&nbsp;&nbsp;｜&nbsp;&nbsp;</li>\r\n      <li><a href=\"sdgs.html\">SDGsへの取り組み</a>&nbsp;&nbsp;｜&nbsp;&nbsp;</li>\t\t\r\n      <li><a href=\"contact.html\">お問い合わせ</a></li>\r\n    </ul>\r\n    <div class=\"f_inner02 clearfix\">\r\n      <div class=\"copyright\">Copyright (C) 2018 カガク興商株式会社. All Rights Res