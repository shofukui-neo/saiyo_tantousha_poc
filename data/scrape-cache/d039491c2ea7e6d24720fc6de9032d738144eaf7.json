atestPost.title.rendered; // レンダリングされたタイトル\n                var postDateStr = latestPost.date; // ISO 8601形式の日付文字列 (例: \"2025-05-14T10:00:00\")\n                // var postLink = latestPost.link; // 記事へのパーマリンク\n\n                // 日付をフォーマットする\n                var postDate = new Date(postDateStr);\n                var formattedDate = postDate.getFullYear() + '年' +\n                                   (postDate.getMonth() + 1) + '月' + // getMonth()は0から始まるため+1\n                                   postDate.getDate() + '日';\n\n                // HTML要素にタイトルと日付を表示\n                $('#latest-post-title').text(postTitle); // .text()でHTML特殊文字をエスケープ\n                $('#latest-post-date').text(formattedDate);\n\n                // リンクも表示する場合\n                // $('#latest-post-link').attr('href', postLink);\n                // $('#latest-post-title').html('<a href=\"' + postLink + '\">' + postTitle + '</a>'); // タイトル自体をリンクにする場合\n\n            } else {\n                // 記事が見つからなかった場合の処理\n                $('#latest-post-info').html('<p>新着記事はありません。</p>');\n            }\n        },\n        error: function(jqXHR, textStatus, errorThrown) {\n            // Ajaxリクエストが失敗した場合の処理\n            console.error('WordPressの新着記事取得エラー:', textStatus, errorThrown);\n            console.error('Response Text:', jqXHR.responseText); // エラーレスポンスの詳細\n            $('#latest-post-info').html('<p>記事の取得に失敗しました。サイト管理者にお問い合わせください。</p>');\n        }\n    });\n});\n  </script>\n\n  <!--AD-->\n  <script async src=\"https://s.yimg.jp/images/listing/tool/cv/ytag.js\"></script>\n  <script>\n    window.yjDataLayer = window.yjDataLayer || [];\n\n    function ytag() {\n      yjDataLayer.push(arguments);\n    }\n    ytag({\n      \"type\": \"yss_retargeting\",\n      \"config\": {\n        \"yahoo_ss_retargeting_id\": \"1000322625\",\n        \"yahoo_sstag_custom_params\": {}\n      }\n    });\n  </script>\n\n  <script async src=\"https://s.yimg.jp/images/listing/tool/cv/ytag.js\"></script>\n  <script>\n    wind