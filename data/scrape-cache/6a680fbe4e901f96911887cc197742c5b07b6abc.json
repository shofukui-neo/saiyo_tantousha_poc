r('[data-size=\"large\"]').addEventListener('click', function() {\n      changeFontSize('large');\n    });\n});\n</script> \n  <script defer type=\"text/javascript\">\n\n// .language-btn2 と .lang-close のすべての要素にイベントリスナーを追加\ndocument.querySelectorAll('.language-btn2').forEach((btn) => {\n    btn.addEventListener('click', toggleLanguageMenu);\n});\n\ndocument.querySelectorAll('.lang-close').forEach((closeBtn) => {\n    closeBtn.addEventListener('click', hideLanguageMenu);\n});\n\n// #languageSelection と #languageSelectionSP 内のすべての a タグにイベントリスナーを追加\ndocument.querySelectorAll('#languageSelection a, #languageSelectionSP a').forEach((langLink) => {\n    langLink.addEventListener('click', hideLanguageMenu);\n});\n\nfunction toggleLanguageMenu() {\n    toggleMenu('languageSelection');\n    toggleMenu('languageSelectionSP');\n}\n\nfunction hideLanguageMenu() {\n    hideMenu('languageSelection');\n    hideMenu('languageSelectionSP');\n}\n\nfunction toggleMenu(menuId) {\n    const languageMenu = document.getElementById(menuId);\n    if (!languageMenu) return;\n    const currentRight = getComputedStyle(languageMenu).right;\n    languageMenu.style.right = currentRight === '-270px' ? '0px' : '-270px';\n}\n\nfunction hideMenu(menuId) {\n    const languageMenu = document.getElementById(menuId);\n    if (!languageMenu) return;\n    languageMenu.style.right = '-270px';\n}\n\n</script> \n  <script defer type=\"text/javascript\">\n// DOMが読み込まれた後に実行される関数を設定\ndocument.addEventListener('DOMContentLoaded', function () {\n  // 全ての.toggle要素に対して関数を適用\n  document.querySelectorAll('.toggle').forEach(function(toggle) {\n    // クリックイベントリスナーを追加\n    toggle.addEventListener('click', function() {\n      // .activeクラスの付与または削除\n      toggle.classList.toggle('active');\n\n      // 関連する<ul>要素の表示を切り替え\n      var content = toggle.nextElementSibling;\n      if (content.style.display === 'block') {\n        content.style.display = 'none';\n      } else {\n        content.style.display = 'block';\n      }\n    });\n  });\n});\n</script> \n  <script defer type=\"text/javascript\">\n\n// ページが読み込まれたらgetUserLocation関数を呼び出す\ndocument.addEventListener('DOMContentLoaded', function() {\n    getUserLocation();\n});\n\nfunction getUserLocation() {\n    // APIキーをここに入力\n    const API_KEY = 'AIzaSyAF0YYZHasI5k86KevctQwAGB1SvkndHG4';\n\n    // Geolocation APIのエンドポイント\n    const GEOLOCATION_ENDPOINT = 'https://www.googleapis.com/geolocation/v1/geolocate?key=' + API_KEY;\n\n    fetch(GEOLOCATION_ENDPOINT, {\n        method: 'POST'\n    })\n    .then(response => response.json())\n    .then(data => {\n        const latitude = data.location.lat;\n        const longitude = data.location.lng;\n\n        console.log('緯度:', latitude);\n        console.log('経度:', longitude);\n    })\n    .catch(error => {\n        console.error('位置情報の取得に失敗しました:', error);\n    });\n}\n\nfunction getGeolocation() {\n    // APIキーをここに入力\n    const API_KEY = 'AIzaSyAF0YYZHasI5k86KevctQwAGB1SvkndHG4';\n\n    // Geolocation APIのエンドポイント\n    const GEOLOCATION_ENDPOINT = 'https://www.googleapis.com/geolocation/v1/geolocate?key=' + API_KEY;\n\n    fetch(GEOLOCATION_ENDPOINT, {\n        method: 'POST'\n    })\n    .then(response => response.json())\n    .then(data => {\n        const latitude = data.location.lat;\n        const longitude = data.location.lng;\n\n        console.log('緯度:', latitude);\n        console.log('経度:', longitude);\n\n        // ここで取得した緯度経度を使用して、最寄りの店舗を検索します\n        const nearestStore = findNearestStore(latitude, longitude);\n        if (nearestStore) {\n            window.location.href = nearestStore.url;\n        } else {\n            alert(\"近くの店舗が見つかりませんでした。\");\n        }\n    })\n    .catch(error => {\n        console.error('位置情報の取得に失敗しました:', error);\n    });\n}\n\nconst stores = [\n  { name: \"名古屋市場直送寿司嘉文\", lat: 35.170910105826756, lng: 136.88264312522665, url: \"https://kamon-group.com/sushi-kamon.html\" },\n\t{ name: \"魚がし料理嘉鮮(かせん)\", lat: 35.17090809532362, lng: 136.88264931173538, url: \"https://kamon-group.com/kasen.html\" },\n{ name: \"活魚料理・和食処嘉文うまいもん通り広小路口店\", lat: 35.16958329761046, lng: 136.88322092337302, url: \"https://kamon-group.com/umaimontoori.html\" },\n{ name: \"寿司酒場嘉文センチュリー豊田ビル店\", lat: 35.16917352796339, lng: 136.88658926755417, url: \"https://kamon-group.com/century-toyotabill.html\" },\n{ name: \"旬・鮮・魚・彩さ嘉なやはなれ\", lat: 35.17174553487401, lng: 136.91071772522662, url: \"https://kamon-group.com/sakanaya-hanare.html\" },\n{ name: \"鮪・活魚料理嘉文栄本店\", lat: 35.16882783970017, lng: 136.91012653871795, url: \"https://kamon-group.com/sakae-honten.html\" },\n{ name: \"和食・海鮮料理嘉文ループ金山店\", lat: 35.14345482774747, lng: 136.90140222522547, url: \"https://kamon-group.com/loop-kanayama.html\" },\n{ name: \"鮪・活魚料理嘉文金山北店\", lat: 35.143927109577874, lng: 136.9021636710018, url: \"https://kamon-group.com/kanayama-kita.html\" },\n{ name: \"活魚料理・和食処嘉文金山店\", lat: 35.142690098473615, lng: 136.90211002682074, url: \"https://kamon-group.com/kanayama.html\" },\n{ name: \"麺・丼・活魚料理嘉文神宮店\", lat: 35.126068297688036, lng: 136.91321565406105, url: \"https://kamon-group.com/zingu.html\" },\n{ name: \"海鮮・名古屋めし嘉文大曽根店\", lat: 35.189952194330964, lng: 136.94042393871868, url: \"https://kamon-group.com/ozone.html\" },\n{ name: \"魚がし料理嘉文藤が丘店\", lat: 35.18218075236893, lng: 137.02144853501156, url: \"https://kamon-group.com/huzigaoka.html\" },\n{ name: \"海鮮と天ぷら嘉文徳重店\", lat: 35.09970056806225, lng: 137.00067377809805, url: \"https://kamon-group.com/tokushige.html\" },\n];\n\n// 2つの地点の距離を計算する関数\nfunction getDistance(lat1, lon1, lat2, lon2) {\n    const R = 6371; // Earth's radius in kilometers\n    const dLat = (lat2 - lat1) * Math.PI / 180;\n    const dLon = (lon2 - lon1) * Math.PI / 180;\n\n    const a =\n        Math.sin(dLat / 2) * Math.sin(dLat / 2) +\n        Math.cos(lat1 * Math.PI / 180) * Math.cos(lat2 * Math.PI / 180) *\n        Math.sin(dLon / 2) * Math.sin(dLon / 2);\n\n    const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));\n    const distance = R * c;\n\n    return distance; // returns distance in kilometers\n}\n\n// 最も近い店舗を検索する関数\nfunction findNearestStore(lat, lng) {\n    let nearestStore = null;\n    let nearestDistance = Infinity;\n\n    for (let store of stores) {\n        const distance = getDistance(lat, lng, store.lat, store.lng);\n        if (distance < nearestDistance) {\n            nearestDistance = distance;\n            nearestStore = store;\n        }\n    }\n\n    return nearestStore;\n}\n\ndocument.addEventListener('DOMContentLoaded', function() {\n    const linkElement = document.querySelector('.findNearestStore');\n\n    if (linkElement) {\n        linkElement.addEventListener('click', function(event) {\n            event.preventDefault(); // リンクのデフォルトの動作をキャンセル\n            getGeolocation(); // 位置情報を取得し、近くの店舗を検索\n        });\n    }\n});\n\n</script> \n  <script defer type=\"text/javascript\">\nconst API_KEY = 'AIzaSyArPCow38RK0CpHD7YZEi0xTeK5mNJXFEA';\ndocument.querySelectorAll('#languageSelection a').forEach((a) => {\n    a.addEventListener('click', (e) => {\n        e.preventDefault();\n        const targetLanguage = e.currentTarget.getAttribute('data-lang');\n        translatePage(targetLanguage);\n    });\n});\n\nfunction getTextElementsWithin(element) {\n    const texts = [];\n    const elements = element.querySelectorAll(\":not(script):not(style)\");\n    elements.forEach((el) => {\n        if (el.childNodes.length === 1 && el.firstChild.nodeType === 3) {\n            texts.push(el);\n        }\n    });\n    return texts;\n}\n\nfunction chunkText(text, maxChunkSize) {\n    const chunks = [];\n    for (let i = 0; i < text.length; i += maxChunkSize) {\n        chunks.push(text.slice(i, i + maxChunkSize));\n    }\n    return chunks;\n}\n\nfunction translatePage(targetLanguage) {\n    const body = document.body;\n    const textElements = getTextElementsWithin(body);\n    const maxChunkSize = 5000;\n    let translationsReceived = 0;\n\n    const translationPromises = [];\n\n    textElements.forEach((el, index) => {\n        const textChunks = chunkText(el.textContent, maxChunkSize);\n        textChunks.forEach(chunk => {\n            const apiUrl = `https://translation.googleapis.com/language/translate/v2?key=${API_KEY}`;\n            const translationPromise = fetch(apiUrl, {\n                method: 'POST',\n                headers: {\n                    'Content-Type': 'application/json',\n                },\n                body: JSON.stringify({\n                    q: chunk,\n                    target: targetLanguage\n                }),\n            })\n            .then(response => response.json())\n            .then(data => {\n                return data.data.translations[0].translatedText;\n            });\n            translationPromises.push(translationPromise);\n        });\n    });\n\n    Promise.all(translationPromises).then(translatedChunks => {\n        let currentChunkIndex = 0;\n        textElements.forEach((el, index) => {\n            const textChunks = chunkText(el.textContent, maxChunkSize);\n            el.textContent = textChunks.map(() => translatedChunks[currentChunkIndex++]).join('');\n        });\n    }).catch(error => {\n        console.error('Error:', error);\n    });\n}\n</script> \n  <!-- custom_tags_end -->  \n </body>\n</html>","finalUrl":"http://www.kamon-group.com/recruit.html","rendered":false,"_cachedAt":"2026-06-22T17:41:29.265Z"}