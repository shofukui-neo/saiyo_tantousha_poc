-column1\"> \n             <p class=\" c-body\"></p> \n             <div class=\"c-breadcrumb\"> \n              <a href=\"./\" data-pid=\"5205773\">HOME</a> | \n              <em>採用情報</em> \n             </div> \n             <p></p> \n            </div> \n           </div> \n           <div id=\"bk80410939\" class=\"b-plain c-space_normal c-sp-space_normal cssskin-_block_main\" data-bk-id=\"bk80410939\"> \n            <div class=\" column -column1\"> \n             <h2 class=\" c-title c-center\"><span class=\" c-center\">募集要項</span></h2> \n            </div> \n           </div> \n           <div id=\"bk80411204\" class=\"b-plain cssskin-_block_main\" data-bk-id=\"bk80411204\"> \n            <div class=\" column -column1\"> \n            </div> \n           </div> \n           <div id=\"bk80411205\" class=\"b-tab c-space_normal c-sp-space_normal c-padding_normal c-sp-padding_normal cssskin-_block_main\" data-bk-id=\"bk80411205\"> \n            <div class=\" g-column\"> \n             <nav> \n              <ul class=\" b-tab_navigation\"> \n               <li><a href=\"#\">正社員</a></li> \n               <li><a href=\"#\">パート・アルバイト</a></li> \n              </ul> \n             </nav> \n             <div class=\" b-tab_contents\"> \n              <div class=\" tab-content\"> \n               <div class=\" column\"> \n                <p class=\" c-body\">&nbsp;<br>&nbsp;</p> \n                <div class=\" c-body c-center\"> \n                 <span>＜随時募集中＞株式会社嘉文は中途採用の募集を行っております。</span> \n                </div> \n                <div class=\" c-body c-center\"> \n                 <span>下記よりご連絡いただきましたら、弊社採用担当者より改めてご連絡をさせていただきます。</span> \n                </div> \n                <div class=\" c-body c-center\">\n                  &nbsp; \n                </div> \n                <div class=\" c-body c-center\">\n                  &nbsp; \n                </div> \n                <h4 class=\" c-small_headline c-left\"><span><span class=\" d-larger_font\">お電話でのお問い合わせ</span