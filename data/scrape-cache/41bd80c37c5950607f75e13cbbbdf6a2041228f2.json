r add = function() {\n\t\t\t\t$('#loading').addClass('loaded');\n\t\t\t};\n\t\t\tsetTimeout(function() {\n\t\t\t\tadd()\n\t\t\t}, 500);\n\t\t}\n\t</script>\n\t<script src=\"/common/js/background-youtube.js\" type=\"text/javascript\"></script>\n</head>\n\n<body id=\"pageTop\" class=\"home\">\n\t<div id=\"loading\"></div>\n\t    <header id=\"globalHeader\">\n        <div id=\"site-title\" class=\"relative\">\n            <a href=\"/\" title=\"高沢産業株式会社\">\n                <picture>\n                    <source media=\"(min-width: 1266px)\" srcset=\"/common/img/common/logo.svg\">\n                    <img src=\"/common/img/common/logo_sp.svg\" alt=\"高沢産業株式会社\">\n                </picture>\n            </a>\n        </div>\n        <nav id=\"globalNavi\">\n            <ul>\n                <li class=\"sm:hidden sm:text-base\"><a href=\"/\" title=\"トップ\">トップ</a></li>\n                <li id=\"naviRoad\" class=\"sm:text-base\"><a href=\"/road/\" title=\"Road to Quality of Life\">Road to Quality of Life</a></li>\n                <li id=\"naviGroup\" class=\"sm:text-base\"><a href=\"/group/\" title=\"高沢グループ\">高沢グループ</a></li>\n                <li id=\"naviService\" class=\"sm:text-base\"><a href=\"/service/\" title=\"事業内容\">事業内容</a></li>\n                <li id=\"naviCSR\" class=\"sm:text-base\"><a href=\"/sdgs/\" title=\"高沢産業のSDGs\">高沢産業のSDGs</a></li>\n                <li id=\"naviCompany\" class=\"sm:text-base\"><a href=\"/company/\" title=\"企業情報\">企業情報</a></li>\n                <li class=\"sm:text-base\"><a href=\"https://info.takasawa.co.jp/recruit\" title=\"採用情報\" target=\"_blank\">採用情報</a></li>\n                <li class=\"sm:hidden sm:text-base\"><a href=\"/inquiry/\" title=\"お問い合わせ\">お問い合わせ</a></li>\n            </ul>\n        <!-- /#globalNavi --></nav>\n        <div id=\"menu\">\n            <span class=\"bar\" id=\"bar01\"></span>\n            <span class=\"bar\" id=\"bar02\"></span>\n            <span class=\"bar\" id=\"bar03\"></span>\n        </div>\n\t<!-- /#globalHeader --></header>\n\t<div class=\"homeHero\">\n\t\t\t<div class=\"c-mv\">\n\t\t      <div id=\"youtube\" class=\"c-mv__video\"></div>\n\t\t      <div class=\"c-mv__mask\"></div>\n\t\t    </div>\t\t\n\t\t</div>\t\t\n\t\t<a href=\"#contents\" title=\"SCROLL\" class=\"btnScroll\"><img src=\"/common/img/home/img_scroll.svg\" alt=\"SCROLL\"></a>\n\t\t\t\t\t</div>\n\t<div id=\"contents\" class=\"homeCatch nonAdBlueBnr\">\t\t<div class=\"wow fadeIn\" data-wow-delay=\"0.5s\">\n\t\t    <p class=\"mainCatch\">明日をひらく</p>\n\t\t\t<p class=\"subCatch\">まずは 一人ひとりの 心をひらく<br>思いを伝え 互いを信じるために<br><br>\n\t\t\tつぎに 志をひとつにして 道をひらく<br>地域とつながり 暮らしを動かすために<br><br>\n\t\t\tそして わたしたちは 明日をひらく<br>世界を広げ 未来をはじめるために</p>\n\t\t</div>\n\t</div>\n\t<div class=\"homeBgGray\">\n\t\t<section class=\"homeRoad\">\n\t\t\t<header>\n\t\t\t\t<h2>Road to Quality of Life</h2>\n\t\t\t\t<span>― 豊かな暮らしを築く軌跡 ―</span>\n\t\t\t\t<p>Contents</p>\n\t\t\t</header>\n\t\t\t<div class=\"flex justify-between flex-col sm:flex-row\">\n\t\t\t\t<div class=\"boxColumn2 border-t border-solid border-lightgray\">\n\t\t\t\t\t<a href=\"/road/06/\" class=\"hover:opacity-75 trans cursor-pointer block flex justify-between py-5 border-b border-solid border-lightgray\">\n\t\t\t\t\t\t<figure class=\"w-4/12\">\n\t\t\t\t\t\t\t<img src=\"/common/img/road/pic_link_06.jpg\" alt=\"\" class=\"w-full\">\n\t\t\t\t\t\t</figure>\n\t\t\t\t\t\t<div class=\"w-8/12 box-border pl-3 md:pl-5\">\n\t\t\t\t\t\t\t<span class=\"block text-red text-xs md:text-base mb-1 md:mb-3 text-roboto\">Road to Quality of Life 06</span>\n\t\t\t\t\t\t\t<p class=\"text-base md:text-xl font-bold leading-normal\">総合商社の商品力と提案力で時代の先へ挑む福祉事業</p>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</a>\n\t\t\t\t\t<a href=\"/road/05/\" class=\"hover:opacity-75 trans cursor-pointer block flex justify-between py-5 border-b border-solid border-lightgray\">\n\t\t\t\t\t\t<figure class=\"w-4/12\">\n\t\t\t\t\t\t\t<img src=\"/common/img/road/pic_link_05@2x.jpg\" alt=\"\" class=\"w-full\">\n\t\t\t\t\t\t</figure>\n\t\t\t\t\t\t<div class=\"w-8/12 box-border pl-3 md:pl-5\">\n\t\t\t\t\t\t\t<span class=\"block text-red text-xs md:text-base mb-1 md:mb-3 text-roboto\">Road to Quality of Life 05</span>\n\t\t\t\t\t\t\t<p class=\"text-base md:text-xl font-bold leading-normal\">各国輸入車の正規ディーラーとしてお客様それぞれのカーライフを提案</p>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</a>\n\t\t\t\t\t<a href=\"/road/04/\" class=\"hover:opacity-75 trans cursor-pointer block flex justify-between py-5 border-b border-solid border-lightgray\">\n\t\t\t\t\t\t<figure class=\"w-4/12\">\n\t\t\t\t\t\t\t<img src=\"/common/img/road/pic_link_04@2x.jpg\" alt=\"\" class=\"w-full\">\n\t\t\t\t\t\t</figure>\n\t\t\t\t\t\t<div class=\"w-8/12 box-border pl-3 md:pl-5\">\n\t\t\t\t\t\t\t<span class=\"block text-red text-xs md:text-base mb-1 md:mb-3 text-roboto\">Road to Quality of Life 04</span>\n\t\t\t\t\t\t\t<p class=\"text-base md:text-xl font-bold leading-normal\">書店はライフライン。老舗書店「平安堂」の軌跡と未来</p>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</a>\n\t\t\t\t</div>\n\t\t\t\t<div class=\"boxColumn2 border-t border-solid border-lightgray\">\n\t\t\t\t\t<a href=\"/road/03/\" class=\"hover:opacity-75 trans cursor-pointer block flex justify-between py-5 border-b border-solid border-lightgray\">\n\t\t\t\t\t\t<figure class=\"w-4/12\">\n\t\t\t\t\t\t\t<img src=\"/common/img/home/link_road_03@2x.jpg\" alt=\"\" class=\"w-full\">\n\t\t\t\t\t\t</figure>\n\t\t\t\t\t\t<div class=\"w-8/12 box-border pl-3 md:pl-5\">\n\t\t\t\t\t\t\t<span class=\"block text-red text-xs md:text-base mb-1 md:mb-3 text-roboto\">Road to Quality of Life 03</span>\n\t\t\t\t\t\t\t<p class=\"text-base md:text-xl font-bold leading-normal\">鉄鋼原料の専門商社、一世紀。産業の礎を担う情熱を語り合う</p>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</a>\n\t\t\t\t\t<a href=\"/road/02/\" class=\"hover:opacity-75 trans cursor-pointer block flex justify-between py-5 border-b border-solid border-lightgray\">\n\t\t\t\t\t\t<figure class=\"w-4/12\">\n\t\t\t\t\t\t\t<img src=\"/common/img/home/link_road_02@2x.jpg\" alt=\"\" class=\"w-full\">\n\t\t\t\t\t\t</figure>\n\t\t\t\t\t\t<div class=\"w-8/12 box-border pl-3 md:pl-5\">\n\t\t\t\t\t\t\t<span class=\"block text-red text-xs md:text-base mb-1 md:mb-3 text-roboto\">Road to Quality of Life 02</span>\n\t\t\t\t\t\t\t<p class=\"text-base md:text-xl font-bold leading-normal\">多様な働き方を支援するOAシステム事業</p>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</a>\n\t\t\t\t\t<a href=\"/road/01/\" class=\"hover:opacity-75 trans cursor-pointer block flex justify-between py-5 border-b border-solid border-lightgray\">\n\t\t\t\t\t\t<figure class=\"w-4/12\">\n\t\t\t\t\t\t\t<img src=\"/common/img/road/pic_link_01@2x.jpg\" alt=\"\" class=\"w-full\">\n\t\t\t\t\t\t</figure>\n\t\t\t\t\t\t<div class=\"w-8/12 box-border pl-3 md:pl-5\">\n\t\t\t\t\t\t\t<span class=\"block text-red text-xs md:text-base mb-1 md:mb-3 text-roboto\">Road to Quality of Life 01</span>\n\t\t\t\t\t\t\t<p class=\"text-base md:text-xl font-bold leading-normal\">安心して暮らせるまちづくりの基盤を築く</p>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</a>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t\t<a href=\"/road/\" title=\"More\" class=\"flex items-center justify-center border border-solid btnBorder box-border block mx-auto relative hover:opacity-75 mt-8 md:mt-12 text-base md:text-xl\">More</a>\n\t\t</section>\n\t\t<section class=\"homeMission\">\n\t\t\t<img src=\"/common/img/home/pic_sdgs.jpg\" alt=\"\" class=\"homeMission__pic\">\n\t\t\t<div class=\"homeMission__box\">\n\t\t\t\t<figure><img src=\"/common/img/home/img_goal.svg\" alt=\"SUSTAINABLE DEVELOPMENT GOALS\"></figure>\n\t\t\t\t<div>\n\t\t\t\t\t<p>地域の生活、地域の環境が<br class=\"sm:hidden\">より良く循環し、<br>\n\t\t\t\t\t\t持続する未来をめざして、<br>\n\t\t\t\t\t\t「社会のために、人々のために何ができるかを考える」<br>\n\t\t\t\t\t\t企業であり続けます。</p>\n\t\t\t\t\t<a href=\"/sdgs/\" title=\"高沢産業のSDGsへ\" class=\"flex items-center justify-start sm:justify-center border border-solid btnBorder box-border block relative hover:opacity-75 mt-8 md:mt-12 text-base md:text-xl pl-5 sm:pl-0\">高沢産業のSDGsへ</a>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t\t<div class=\"homeMission__box\">\n\t\t\t\t<figure><img src=\"/common/img/home/img_adblue.png\" alt=\"AdBlue（R）\"></figure>\n\t\t\t\t<div>\n\t\t\t\t\t<p>「AdBlue（R）」はNOx・PM規制をクリアするNOｘ還元添加剤です。<br>\n\t\t\t\t\t\t高沢産業は長野県内初の製造工場を設立し、<br>\n\t\t\t\t\t\t迅速かつ安定的な供給を行い、<br>\n\t\t\t\t\t\t緑豊かな地球環境の保全に貢献します。</p>\n\t\t\t\t\t<a href=\"/service/adblue/\" title=\"AdBlue（R）の紹介ページを見る\" class=\"flex items-center justify-start sm:justify-center border border-solid btnBorder box-border block relative hover:opacity-75 mt-8 md:mt-12 text-base md:text-xl pl-5 sm:pl-0\">AdBlue（R）の紹介ページを見る</a>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</section>\n\t</div>\n\t<a href=\"/company/history/\" class=\"homeEnviron trans\">\n\t\t<section>\n\t\t\t<header class=\"titHome\">\n\t\t\t\t<h3>高沢産業の歴史</h3>\n\t\t\t\t<p>History of Takasawa</p>\n\t\t\t</header>\n\t\t\t<p class=\"homeEnviron__text\">\n\t\t\t\t地域の皆様に支えられて1世紀。<br>\n\t\t\t\tそしてこれからの時代を見据えて。<br>\n\t\t\t\t高沢産業の歴史をご紹介します。\n\t\t\t</p>\n\t\t</section>\n\t</a>\n\t<section class=\"homeGroup\">\n\t\t<header class=\"titHome titHome--group\">\n\t\t\t<h3>グループ企業</h3>\n\t\t\t<p>Group company</p>\n\t\t</header>\n\t\t<div class=\"homeGroup__slide\">\n\t\t\t<a href=\"https://www.retail-takasawa.co.jp/\" target=\"_blank\" title=\"株式会社タカサワ\"><img src=\"/common/img/home/bnr_01@2x.jpg\" alt=\"株式会社タカサワ\" class=\"w-full\"></a>\n\t\t\t<a href=\"http://www.tmaterial.jp/\" target=\"_blank\" title=\"株式会社タカサワマテリアル\"><img src=\"/common/img/home/bnr_03@2x.jpg\" alt=\"株式会社タカサワマテリアル\" class=\"w-full\"></a>\n\t\t\t<a href=\"http://takasawatsusho.co.jp/\" target=\"_blank\" title=\"タカサワ通商株式会社\"><img src=\"/common/img/home/bnr_04@2x.jpg\" alt=\"タカサワ通商株式会社\" class=\"w-full\"></a>\n\t\t\t<a href=\"https://www.heiando.co.jp/\" target=\"_blank\" title=\"平安堂\"><img src=\"/common/img/home/bnr_02@2x.jpg\" alt=\"平安堂\" class=\"w-full\"></a>\n\t\t\t<a href=\"http://www.kowa-foundry.jp/\" target=\"_blank\" title=\"高和製作所\"><img src=\"/common/img/home/bnr_05@2x.jpg\" alt=\"高和製作所\" class=\"w-full\"></a>\n\t\t\t<a href=\"http://kouwa-k.jp/\" target=\"_blank\" title=\"高和興業