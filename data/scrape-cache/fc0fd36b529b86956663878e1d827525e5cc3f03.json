s', new Date());\n  gtag('config', 'UA-2097811-1');\n  gtag('config', 'G-0BNP76Q4Q7');\n</script>\n</head>\n\n<body>\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=AW-734422123\"></script> \n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n  gtag('config', 'AW-734422123');\n</script>\n<div class=\"openbtn\"><span></span><span></span><span></span></div>\n<nav id=\"g-nav\">\n        <div id=\"g-nav-list\">\n                <ul>\n                        <li><a href=\"../index.html#01_business\" title=\"事業を知る\">事業を知る</a></li>\n                        <li><a href=\"../index.html#02_member\" title=\"職種と人を知る\">職種と人を知る</a></li>\n                        <li><a href=\"../index.html#03_workspace\" title=\"環境・待遇を知る\">環境・待遇を知る</a></li>\n                        <li><a href=\"../index.html#04_information\" title=\"新卒採用\">新卒採用</a></li>\n                        <li><a href=\"../index.html#04_information\" title=\"キャリア採用\">キャリア採用</a></li>\n                </ul>\n        </div>\n</nav>\n<nav class=\"pc\">\n        <div class=\"inner\">\n                <div class=\"logo\"><a href=\"../index.html\"><img src=\"../images/index/logo.svg\" alt=\"ソリマチ株式会社採用情報\"></a></div>\n                <div class=\"area\">\n                        <ul>\n                                <li><a href=\"service.html\" title=\"事業を知る\" class=\"select\">事業を知る</a></li>\n                                <li><a href=\"../member/movie.html\" title=\"職種と人を知る\">職種と人を知る</a></li>\n                                <li><a href=\"../workspace/office.html\" title=\"環境・待遇を知る\">環境・待遇を知る</a></li>\n                                <li><a href=\"../recruit/newgraduate.html\" title=\"新卒採用\">新卒採用</a></li>\n                                <li><a href=\"../recruit/career.html\" title=\"キャリア採用\">キャリア採用</a></li>\n                        </ul>\n                </div>\n        </div>\n</nav>\n<div id=\"contents\">\n        <div class=\"inner\">\n                <div class=\"side side--sticky\">\n                        <h1>事業を知る</h1>\n                        <ul>\n                                <li><a href=\"service.html\" title=\"01 ソリマチ製品の紹介\">01 ソリマチ製品の紹介</a></li>\n                                <li><a href=\"industry.html\" title=\"02 会計ソフト業界を知る\">02 会計ソフト業界を知る</a></li>\n                                <li><a href=\"message.html\" title=\"03 社長からメッセージ\" class=\"select\">03 社長からメッセージ</a></li>\n                                <li><a href=\"sorimachi_group.html\" title=\"04 ソリマチテックグループの紹介\">04 ソリマチテックグループの紹介</a></li>\n                                <li><a href=\"family.html\" title=\"05 ご家族の皆様へ\">05 ご家族の皆様へ</a></li>\n                        </ul>\n                </div>\n                <div class=\"area\">\n                        <h1>Message</h1>\n                        <h2><span>03</span>社長メッセージ</h2>\n                        <img src=\"../images/business/img_07.jpg\" width=\"700\"alt=\"\" class=\"img_kadoR marT30 marB30\"/>\n                        <h3 class=\"heading05\">誰かのために\n                        <br>AIテクノロジーを使い、社会課題を解決しながら日本を元気にする「最高のチーム」を目指しています。5つのTechでステークホルダーへ\n                        <br>「人生の出会い」を提供します。</h3>\n                        <p>ソリマチテックグループが会計事務所として始まった、70年前。経営者が税理士の元にわざわざ相談に来るのが慣習だった時代に、自ら1軒1軒顧問先の元を回り、小規模事業者様を支えて参りました。\n                        <br><br>「人のできないこと、人のやらないこと、世の中のためになることをやろう」\n                        <br>そのソリマチマインドは、30年ぶりの大改正と言われるインボイス制度や帳簿の電子化が義務とされる電子帳簿保存法など、時代が変わりゆく中でも変わりません。\n                        <br><br>しかし、それは会社が変わらない、ということではありません。私たちの歴史は、いつも“ファーストペンギン“で、大きな転機は、50年前でした。「コンピュータが世の中を変える」という時代、私たちの事業も大きく変わり、高度成長期を経て、その主語は「インターネット」に。そしていま再び「AIが世の中を変える」という転機が訪れ、私たちの組織は”ACCOUNTECH” ”AGRITECH” ”AREATECH” ”FINTECH” ”HUMANTECH”の5つのテーマに分類し、目的別に人材をアサインして、事業・人材の最適化と進化のスピードを上げていくことに舵を切りました。さらなる可能性を広げるため、AIを活かした新規事業や業務効率化にもグループ全体で取り組み、テーマを突き詰めて、発展を加速させています。100年続く企業を目指して、恐れずに変わり続けます。\n                        <br><br>今後も全国の中小企業・小規模事業者の皆様に喜んでいただくサービスを提供し、事業発展に貢献するとともにサスティナブルな社会の実現に向け邁進してまいります。</p>\n                        <!-- <p>「日本で唯一の会計データサイエンス企業」を目指しています。ソリマチが会計データサイエンスへ挑戦できる理由は4つ。</p>\n                        <ul class=\"msg\">\n                                <li>AI会計の特許を持ち、大量の信用情報を一瞬で取得できる仕組みを保有</li>\n                                <li>電子決済等代行業者として既に日本中の多くの銀行と提携し、銀行取引データを正式に取得できる立場</li>\n                                <li>無借金経営で自己資本比率が95%だから、長期の投資が必要なデータサイエンスに挑戦可能</li>\n                                <li>社員が未来に対する挑戦者たちで常に新しい資格や新しい技術へトライしている</li>\n                        </ul>\n                        <p>この強みと創業理念である「人のできない事、人のやらない事、世の中の為になる事をやる」を源に、社会の最前線の会計データサイエンスをベースとした産業別のファーストプラットフォーマーとなることを目指しています。</p> -->\n                        <!-- <h3 class=\"heading04\">Vision</h3>\n                        <p>これからソリマチ株式会社で働く皆様へ。社長からのメッセージ動画を紹介しています。</p>\n                        <div class=\"youtube\">\n                                <iframe width=\"560\" height=\"315\" src=\"https://www.youtube.com/embed/KLTgDncOK8g?si=72pJTDc0_x8_H0bv\" title=\"YouTube video player\" frameborder=\"0\" allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share\" allowfullscreen></iframe>\n                        </div> -->\n                        <ol class=\"pagination\">\n                                <li><a href=\"service.html\">1</a></li>\n                                <li><a href=\"industry.html\">2</a></li>\n                                <li class=\"current\"><a href=\"message.html\">3</a></li>\n                                <li><a href=\"sorimachi_group.html\">4</a></li>\n                                <li><a href=\"family.html\">5</a></li>\n                                <li class=\"next\"><a href=\"../member/movie.html\">></a></li>\n                        </ol>\n                </div>\n        </div>\n</div>\n<footer>\n        <div class=\"inner\"> &copy; Copyright Sorimachi Co.,Ltd. All rights reserved. </div>\n</footer>\n<div class=\"pagetop\"><a href=\"#\">▲</a></div>\n</body>\n</html>","finalUrl":"https://sorimachi.co.jp/about/recruit/business/message.html","rendered":false,"_cachedAt":"2026-06-23T23:07:06.721Z"}