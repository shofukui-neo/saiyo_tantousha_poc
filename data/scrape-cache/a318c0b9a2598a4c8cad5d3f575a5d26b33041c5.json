<h3 class=\"component-hero-news__heading\">NEWS</h3>\n            <ul class=\"component-hero-news-list hover-color\">\n                <li class=\"component-hero-news-list__item\">\n                    <div><date class=\"component-hero-news-list__date\">2025.09.04</date><span class=\"component-hero-news-list__text\"><p><span>採用サイトを全面リニューアルし、本日公開しました。</span></p></span></div>\n                </li>\n            </ul>\n        </div>\n        \n    </section>\n\n    <section class=\"section home-introduction text-center-pc\">\n        <div class=\"section__inner\">\n            <h2 class=\"home-introduction__heading js-inview fadein-up\">\n                これまでの経験が未来を拓く。<br>ＡＧＳで次のキャリアをともに描きましょう。\n            </h2>\n            <p class=\"home-introduction__text js-inview fadein-up\">\n                ＡＧＳは、金融・公共・法人のお客様の課題をITで解決する企業です。<br>\n社員一人ひとりの専門性と自律性を尊重し、多様なプロジェクトと柔軟な働き方で成長を後押しします。<br>\n培ってきた経験にIT技術を掛け合わせ、社会に新しい価値を届けたい—そんなあなたを歓迎します。<br>\nともに未来を創りましょう。\n            </p>\n        </div>\n    </section>\n\n    <section class=\"section home-section home-work career-about js-inview\" data-start=\"top 50%\">\n        <div class=\"component-background\">\n            <svg viewBox=\"0 0 2491 1779\" preserveAspectRatio=\"xMidYMid slice\">\n                <defs>\n                    <linearGradient id=\"gradient-stroke\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"0%\">\n                        <stop offset=\"60%\" stop-color=\"#fff2e6\"></stop>\n                        <stop offset=\"100%\" stop-color=\"#fea174\"></stop>\n                    </linearGradient>\n                </defs>\n                <path fill=\"none\" stroke=\"url(#gradient-stroke)\" stroke-linecap=\"round\" d=\"M69.999,593.999 C69.999,593.999 298.561,951.387 969.834,1076.048 C1349.225,1146.505 1806.166,1017.950 2049.070,812.382 C2266.344,606.597 2316.852,418.343 2296.857,293.851 C2282.391,203.788 2216.549,120.999 2133.444,89.105 C2050.340,57.209 1947.838,60.909 1853.363,133.783 C1758.887,206.658 1594.407,474.022 1643.491,789.205 C1695.895,1125.714 2013.850,1520.775 2385.694,1673.212\"></path>\n            </svg>\n        </div>\n\n        <div class=\"section__inner\">\n            <h2 class=\"section__heading\">\n                <span class=\"section__heading-en js-inview slide-up\">ABOUT US</span>\n                <span class=\"section__heading-ja\">ＡＧＳを知る</span>\n            </h2>\n            <p class=\"section__text\">ＡＧＳの企業理念やこれまでの実績・取り組みなどをご紹介します。</p>\n        \n        <div class=\"splide js-slider-sp\">\n<div class=\"splide__track\">\n<ul class=\"splide__list home-work-list hover-color\">\n<li class=\"splide__slide home-work-list__item\">\n<a href=\"/saiyou/career/about/philosophy/\">\n<figure class=\"home-work-list__image\">\n<img src=\"/saiyou/assets/img/career/home/img_about01.jpg\" alt=\"企業理念・事業領域\" loading=\"lazy\" decoding=\"async\" fetchpriority=\"auto\" width=\"620\" height=\"320\">\n</figure>\n<div class=\"home-work-list__content\">\n<h3 class=\"home-work-list__heading hover-color__text\">企業理念・事業領域<span class=\"component-arrow\"></span></h3>\n</div>\n</a>\n</li>\n<li class=\"splide__slide home-work-list__item\">\n<a href=\"/saiyou/career/about/contribution/\">\n<figure class=\"home-work-list__image\">\n\n<img src=\"/saiyou/assets/img/career/about/contribution/contribution_img01.png\" alt=\"地域貢献\" loading=\"lazy\" decoding=\"async\" fetchpriority=\"auto\" width=\"620\" height=\"320\">\n</figure>\n<div class=\"home-work-list__content\">\n<h3 class=\"home-work-list__heading hover-color__text\">地域貢献<span class=\"component-arrow\"></span></h3>\n<!-- <p class=\"home-work-list__text\">仕事の概要を記載します<br />仕事の概要を記載します</p> -->\n</div>\n</a>\n</li>\n<li class=\"splide__slide home-work-list__item\">\n<a href=\"/saiyou/career/numbers/\">\n<figure class=\"home-work-list__image\">\n<img src=\"/saiyou/assets/img/home/img_index04-photo.png\" alt=\"数字で見るＡＧＳ\" loading=\"lazy\" decoding=\"async\" fetchpriority=\"auto\" width=\"620\" height=\"320\">\n</figure>\n<div class=\"home-work-list__content\">\n<h3 class=\"home-work-list__heading hover-color__text\">数字で見るＡＧＳ<span class=\"component-arrow\"></span></h3>\n</div>\n</a>\n</li>\n</ul>\n</div>\n</div>    \n        \n            <p class=\"component-button component-button--more\">\n                <a href=\"/saiyou/career/about/\">More</a>\n            </p>\n        </div>\n    </section>\n\n    <section class=\"section home-section home-work\">\n        <div class=\"section__inner\">\n            <h2 class=\"section__heading\">\n                <span class=\"section__heading-en js-inview slide-up\">WORK&PERSON</span>\n                <span class=\"section__heading-ja\">事業内容・職種 </span>\n            </h2>\n            <p class=\"section__text\">ＡＧＳの事業や仕事の内容をご紹介します。</p>\n            <div class=\"splide js-slider-sp\">\n                <div class=\"splide__track\">\n                    <ul class=\"splide__list home-work-list hover-color\">\n                        <li class=\"splide__slide home-work-list__item\">\n                            <a href=\"/saiyou/career/business/infrastructure-engineer/\">\n                                <figure class=\"home-work-list__image\">\n\n                                    <img src=\"/saiyou/assets/img/career/home/img_work01-s.png\" alt=\"インフラエンジニアの仕事\" loading=\"lazy\" decoding=\"async\" fetchpriority=\"auto\" width=\"400\" height=\"260\">\n                                </figure>\n                                <div class=\"home-work-list__content\">\n                                    <h3 class=\"home-work-list__heading hover-color__text\">インフラエンジニア<span class=\"component-arrow\"></span></h3>\n                                    <!-- <p class=\"home-work-list__text\">仕事の概要を記載します<br />仕事の概要を記載します</p> -->\n                                </div>\n                            </a>\n                        </li>\n                        <li class=\"splide__slide home-work-list__item\">\n                            <a href=\"/saiyou/career/business/system-engineer/\">\n                                <figure class=\"home-work-list__image\">\n\n                                    <img src=\"/saiyou/assets/img/career/home/img_work02.png\" alt=\"システムエンジニアの仕事\" loading=\"lazy\" decoding=\"async\" fetchpriority=\"auto\" width=\"400\" height=\"260\">\n                                </figure>\n                                <div class=\"home-work-list__content\">\n                                    <h3 class=\"home-work-list__heading hover-color__text\">システムエンジニア<span class=\"component-arrow\"></span></h3>\n                                    <!-- <p class=\"home-work-list__text\">仕事の概要を記載します<br />仕事の概要を記載します</p> -->\n                                </div>\n                            </a>\n                        </li>\n                        <li class=\"splide__slide home-work-list__item\">\n                            <a href=\"/saiyou/career/business/sales/\">\n                                <figure class=\"home-work-list__image\">\n\n                                    <img src=\"/saiyou/assets/img/career/home/img_work03.png\" alt=\"営業の仕事\" loading=\"lazy\" decoding=\"async\" fetchpriority=\"auto\" width=\"400\" height=\"260\">\n                                </figure>\n                                <div class=\"home-work-list__content\">\n                                    <h3 class=\"home-work-list__heading hover-color__text\">営業<span class=\"component-arrow\"></span></h3>\n                                    <!-- <p class=\"home-work-list__text\">仕事の概要を記載します<br />仕事の概要を記載します</p> -->\n                                </div>\n                            </a>\n                        </li>\n                    </ul>\n                </div>\n            </div>\n            <p class=\"component-button component-button--more\">\n                <a href=\"/saiyou/career/business/\">More</a>\n            </p>\n        </div>\n    </section>\n\n    <section class=\"section home-section home-interview\">\n        <figure class=\"home-interview__image\">\n            <picture>\n                <source srcset=\"/saiyou/assets/img/new/home/img_interview@sp.jpg\" media=\"(max-width: 768px)\">\n\n                <img src=\"/saiyou/assets/img/new/home/img_interview.jpg\" alt=\"オフィスの風景\" loading=\"lazy\" decoding=\"async\" fetchpriority=\"auto\" width=\"1920\" height=\"500\">\n            </picture>\n        </figure>\n        <div class=\"home-interview__inner\">\n            <div class=\"section__inner\">\n                <h2 class=\"section__heading\">\n                    <span class=\"section__heading-en js-inview slide-up\">INTERVIEW</span>\n                    <span class=\"section__heading-ja\">社員インタビュー</span>\n                </h2>\n                <p class=\"section__text helper-mb-40\">ＡＧＳで働くメンバーをご紹介します。</p>\n                <div class=\"splide js-slider-sp\">\n                    <div class=\"splide__track\">\n                        <ul class=\"splide__list home-interview-list hover-color\">\n                        \n                            <li class=\"splide__slide home-interview-list__item\" data-join=\"career\">\n                                <a href=\"/saiyou/career/interview/detail01/\">\n                                    <figure class=\"home-interview-list__image\">\n                                          \n                                            <img src=\"/saiyou/assets/img/interview01_thum.png\" alt=\"\" loading=\"lazy\" decoding=\"async\" fetchpriority=\"auto\" width=\"380\" height=\"460\">\n                                          \n                                        <figcaption>インフラエンジニア</figcaption>\n                                    </figure>\n                                    <div class=\"home-interview-list__content\">\n                                        <h3 class=\"home-interview-list__heading hover-color__text\">前職の金融業務知識を活かしつつ、未経験でもインフラエンジニアとしてキャリアアップできる</h3>\n                                        <p class=\"home-interview-list__text hover-color__text\">2024年 キャリア入社</p>\n                                    </div>\n                                </a>\n                            </li>\n                          \n                        \n                            <li class=\"splide__slide home-interview-list__item\" data-join=\"career\">\n                                <a href=\"/saiyou/career/interview/detail03/\">\n                                    <figure class=\"home-interview-list__image\">\n                                          \n                                            <img src=\"/saiyou/assets/img/interview03_thum.png\" alt=\"\" loading=\"lazy\" decoding=\"async\" fetchpriority=\"auto\" width=\"380\" height=\"460\">\n                                          \n                                        <figcaption>システムエンジニア</figcaption>\n                                    </figure>\n                                    <div class=\"home-interview-list__content\">\n                                        <h3 class=\"home-interview-list__heading hover-color__text\">以前と比べ、より高度なスキルが求められるプロジェクトに携わることで大変さの中に大きなやりがいを実感</h3>\n                                        <p class=\"home-interview-list__text hover-color__text\">2025年 キャリア入社</p>\n                                    </div>\n                                </a>\n                            </li>\n                          \n                        \n                            <li class=\"splide__slide home-interview-list__item\" data-join=\"career\">\n                                <a href=\"/saiyou/career/interview/detail06/\">\n                                    <figure class=\"home-interview-list__image\">\n                                          \n                                            <img src=\"/saiyou/assets/img/interview06_thum.png\" alt=\"\" loading=\"lazy\" decoding=\"async\" fetchpriority=\"auto\" width=\"380\" height=\"460\">\n                                          \n                                        <figcaption>営業</figcaption>\n                                    </figure>\n                                    <div class=\"home-interview-list__content\">\n                                        <h3 class=\"home-interview-list__heading hover-color__text\">IT業界は“ほぼ異業種への挑戦”「これまで知らなかった世界に触れられる」ことにワクワクしています</h3>\n                                        <p class=\"home-interview-list__text hover-color__text\">2025年 キャリア入社</p>\n                                    </div>\n                                </a>\n                            </li>\n                          \n                        </ul>\n                    </div>\n                </div>\n                <p class=\"component-button component-button--more\">\n                    <a href=\"/saiyou/career/interview/\">More</a>\n                </p>\n            </div>\n        </div>\n    </section>\n\n    <section class=\"section home-section home-culture js-inview\" data-start=\"top 0%\">\n        <div class=\"component-background\">\n            <svg viewBox=\"0 0 789 1980\" preserveAspectRatio=\"xMidYMid slice\">\n                <defs>\n                    <linearGradient id=\"gradient-stroke\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"0%\">\n                        <stop offset=\"60%\" stop-color=\"#fff2e6\"></stop>\n                        <stop offset=\"100%\" stop-color=\"#fea174\"></stop>\n                    </linearGradient>\n                </defs>\n                <path fill=\"none\" stroke=\"url(#gradient-stroke)\" stroke-linecap=\"round\" d=\"M683.000,70.999 C460.172,149.241 216.318,460.731 149.1000,683.999 C55.508,1002.116 24.081,1348.564 173.1000,1576.000 C279.806,1736.515 427.313,1823.470 621.999,1874.1000\"></path>\n            </svg>\n        </div>\n\n        <div class=\"section__inner\">\n            <h2 class=\"section__heading\">\n                <span class=\"section__heading-en js-inview slide-up\">CULTURE</span>\n                <span class=\"section__heading-ja\">Ａ