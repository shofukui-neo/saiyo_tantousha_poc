{"url":"https://www.cnw.co.jp/recruit/company.html","html":"<!DOCTYPE html>\r\n<html lang=\"ja\">\r\n<head>\r\n  <meta charset=\"UTF-8\">\r\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n  <title>会社概要 | キャリアネットワーク採用サイト</title>\r\n  <link href=\"https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@300;400;500;600;700&family=Noto+Sans+JP:wght@300;400;500;700&family=Inter:wght@300;400;500;600;700&display=swap\" rel=\"stylesheet\">\r\n  <link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@fortawesome/fontawesome-free@6.4.0/css/all.min.css\">\r\n  <link rel=\"stylesheet\" href=\"css/sub.css\">\r\n  <link rel=\"stylesheet\" href=\"css/company.css\">\r\n</head>\r\n<body id=\"company_page\">\r\n<div id=\"wrapper\">\r\n<!-- ========================================\r\n     HEADER\r\n======================================== -->\r\n<header class=\"site-header\">\r\n  <div class=\"site-header__inner\">\r\n    <a href=\"index.html\" class=\"site-header__logo\">\r\n      <img src=\"images/logo.webp\" width=\"200\">\r\n      <span class=\"site-header__logo-text\">採用サイト<span>RECRUIT</span></span>\r\n    </a>\r\n    <nav class=\"site-header__nav\" id=\"headerNav\">\r\n      <ul>\r\n        <li><a href=\"company.html\" class=\"active\">会社を知る</a></li>\r\n        <li><a href=\"work.html\">仕事を知る</a></li>\r\n        <li><a href=\"people.html\">人を知る</a></li>\r\n        <li><a href=\"jobs.html\">採用情報</a></li>\r\n      </ul>\r\n    </nav>\r\n    <a href=\"jobs.html#apply\" class=\"site-header__cta\">ENTRY</a>\r\n    <button class=\"site-header__hamburger\" id=\"hamburger\" aria-label=\"メニュー\">\r\n      <span></span><span></span><span></span>\r\n    </button>\r\n  </div>\r\n</header>\r\n\r\n<div class=\"sp-menu\" id=\"spMenu\">\r\n  <ul>\r\n    <li><a href=\"company.html\" class=\"sp-menu__link active\">会社を知る</a></li>\r\n    <li><a href=\"work.html\" class=\"sp-menu__link\">仕事を知る</a></li>\r\n    <li><a href=\"people.html\" class=\"sp-menu__link\">人を知る</a></li>\r\n    <li><a href=\"jobs.html\" class=\"sp-menu__link\">採用情報</a></li>\r\n  </ul>\r\n  <a href=\"jobs.html#apply\" class=\"sp-menu__cta\">まず話を聞いてみる（無料）</a>\r\n  <a href=\"jobs.html#apply\" class=\"sp-menu__cta sp-menu__cta--sub\">30秒でENTRY →</a>\r\n</div>\r\n\r\n<!-- ========================================\r\n     PAGE HERO\r\n======================================== -->\r\n<section class=\"page-hero\">\r\n  <div class=\"container page-hero__inner\">\r\n    <nav class=\"breadcrumb\" aria-label=\"パンくずリスト\">\r\n      <a href=\"index.html\">HOME</a>\r\n      <i class=\"fa-solid fa-chevron-right\"></i>\r\n      <span>会社概要</span>\r\n    </nav>\r\n    <span class=\"page-hero__en\">COMPANY</span>\r\n    <h1 class=\"page-hero__title\">会社概要</h1>\r\n    <p class=\"page-hero__desc\">\r\n      2003年の創業以来、地域の雇用と人の可能性をつなぐ会社として、<br class=\"pc-only\">\r\n      福井を拠点に歩み続けています。\r\n    </p>\r\n  </div>\r\n</section>\r\n\r\n<!-- ========================================\r\n     SEC 01: ミッション・ビジョン・バリュー\r\n======================================== -->\r\n<section class=\"section-mvv\">\r\n  <div class=\"container\">\r\n    <div class=\"section-header\" data-fade>\r\n      <span class=\"section-header__en\">PHILOSOPHY</span>\r\n      <h2 class=\"section-header__ja\">私たちの想い</h2>\r\n      <p class=\"section-header__desc\">キャリアネットワークが大切にしている3つの価値観</p>\r\n    </div>\r\n\r\n    <div class=\"mvv-grid\">\r\n      <div class=\"mvv-card\" data-fade>\r\n        <p class=\"mvv-card__label\">MISSION</p>\r\n        <h3 class=\"mvv-card__title\">地域の雇用と人の可能性をつなぐ</h3>\r\n        <p class=\"mvv-card__body\">地元・福井で、働きたい人と採用したい企業をつなぎ、地域全体の活力を高めることが私たちの使命です。</p>\r\n      </div>\r\n      <div class=\"mvv-card\" data-fade>\r\n        <p class=\"mvv-card__label\">VISION</p>\r\n        <h3 class=\"mvv-card__title\">誰もが自分らしく働ける地域社会</h3>\r\n        <p class=\"mvv-card__body\">学歴・経験・年齢に関わらず、誰もが力を発揮できる環境を福井から実現します。</p>\r\n      </div>\r\n      <div class=\"mvv-card\" data-fade>\r\n        <p class=\"mvv-card__label\">VALUE</p>\r\n        <h3 class=\"mvv-card__title\">誠実・熱意・伴走</h3>\r\n        <p class=\"mvv-card__body\">求職者にも企業にも誠実に向き合い、熱意をもって伴走する。この姿勢がキャリアネットワークの強みです。</p>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</section>\r\n\r\n<!-- ========================================\r\n     SEC 02: 会社概要テーブル\r\n======================================== -->\r\n<section class=\"section-outline\">\r\n  <div class=\"container\">\r\n    <div class=\"section-header\" data-fade>\r\n      <span class=\"section-header__en\">COMPANY INFO</span>\r\n      <h2 class=\"section-header__ja\">会社概要</h2>\r\n    </div>\r\n\r\n    <div class=\"outline-wrap\" data-fade>\r\n      <table class=\"outline-table\">\r\n        <tbody>\r\n          <tr>\r\n            <th>会社名</th>\r\n            <td>株式会社 キャリアネットワーク</td>\r\n          </tr>\r\n          <tr>\r\n            <th>商号</th>\r\n            <td>\r\n              キャリアネットワーク（人材事業部）<br>\r\n              トラベルワールド（旅行事業部）\r\n            </td>\r\n          </tr>\r\n          <tr>\r\n            <th>所在地</th>\r\n            <td>\r\n              〒910-0067 福井県福井市新田塚1-25-18 aoiビル3F<br>\r\n              <span class=\"outline-map-link\">\r\n                <i class=\"fa-solid fa-location-dot\"></i>\r\n                <a href=\"https://maps.google.com/?q=福井市新田塚1-25-18+aoiビル\" target=\"_blank\" rel=\"noopener\">Googleマップで見る</a>\r\n              </span>\r\n            </td>\r\n          </tr>\r\n          <tr>\r\n            <th>設立</th>\r\n            <td>2003年9月1日</td>\r\n          </tr>\r\n          <tr>\r\n            <th>代表取締役社長</th>\r\n            <td>中山 喜雄</td>\r\n          </tr>\r\n          <tr>\r\n            <th>資本金</th>\r\n            <td>1,000万円</td>\r\n          </tr>\r\n          <tr>\r\n            <th>電話 / FAX</th>\r\n            <td>\r\n              TEL：<a href=\"tel:0776250864\">0776-25-0864</a><br>\r\n              FAX：0776-25-0804\r\n            </td>\r\n          </tr>\r\n          <tr>\r\n            <th>メール</th>\r\n            <td><a href=\"mailto:info@cnw.co.jp\">info@cnw.co.jp</a></td>\r\n          </tr>\r\n          <tr>\r\n            <th>許可・登録</th>\r\n            <td>\r\n              厚生労働省 一般労働者派遣事業許可 般18-300001<br>\r\n              厚生労働省 有料職業紹介事業許可 般18-ユ-300017<br>\r\n              福井県知事登録 旅行業第3種196号<br>\r\n              総合旅行業務取扱管理者 中山 喜雄\r\n            </td>\r\n          </tr>\r\n          <tr>\r\n            <th>加盟団体</th>\r\n            <td>\r\n              福井県人材派遣協会<br>\r\n              ANTA（全国旅行業協会）\r\n            </td>\r\n          </tr>\r\n          <tr>\r\n            <th>認証</th>\r\n            <td>\r\n              <span class=\"outline-badge\">ISO 9001</span>\r\n              <span class=\"outline-badge\">ISO 14001</span>\r\n              <span class=\"outline-badge\">ISO 27001</span>\r\n            </td>\r\n          </tr>\r\n        </tbody>\r\n      </table>\r\n    </div>\r\n  </div>\r\n</section>\r\n\r\n<!-- ========================================\r\n     SEC 03: 事業内容\r\n======================================== -->\r\n<section class=\"section-business\">\r\n  <div class=\"container\">\r\n    <div class=\"section-header\" data-fade>\r\n      <span class=\"section-header__en\">BUSINESS</span>\r\n      <h2 class=\"section-header__ja\">事業内容</h2>\r\n      <p class=\"section-header__desc\">人材から旅行まで、地域に根ざした多彩なサービスを展開しています。</p>\r\n    </div>\r\n\r\n    <div class=\"business-grid\">\r\n\r\n      <div class=\"business-card business-card--hr\" data-fade>\r\n        <div class=\"business-card__header\">\r\n          <div class=\"business-card__icon\"><i class=\"fa-solid fa-people-arrows\"></i></div>\r\n          <div>\r\n            <p class=\"business-card__div\">人材事業部</p>\r\n            <h3 class=\"business-card__title\">人材派遣</h3>\r\n          </div>\r\n        </div>\r\n        <p class=\"business-card__body\">\r\n          事務・営業・経理・IT・製造・サービス業など、幅広い分野で派遣スタッフの採用力を高めます。企業文化の深い理解からベストマッチングを実現。\r\n        </p>\r\n        <ul class=\"business-card__tags\">\r\n          <li>事務</li><li>営業</li><li>経理</li><li>IT</li><li>製造</li><li>サービス</li>\r\n        </ul>\r\n      </div>\r\n\r\n      <div class=\"business-card business-card--hr\" data-fade>\r\n        <div class=\"business-card__header\">\r\n          <div class=\"business-card__icon\"><i class=\"fa-solid fa-user-tie\"></i></div>\r\n          <div>\r\n            <p class=\"business-card__div\">人材事業部</p>\r\n            <h3 class=\"business-card__title\">人材紹介</h3>\r\n          </div>\r\n        </div>\r\n        <p class=\"business-card__body\">\r\n          経営管理職・専門技術職・営業幹部職・販売職など、キャリアアップを目指す方の転職を全面サポートします。\r\n        </p>\r\n        <ul class=\"business-card__tags\">\r\n          <li>経営管理職</li><li>専門技術職</li><li>営業幹部職</li><li>販売職</li>\r\n        </ul>\r\n      </div>\r\n\r\n      <div class=\"business-card business-card--hr\" data-fade>\r\n        <div class=\"business-card__header\">\r\n          <div class=\"business-card__icon\"><i class=\"fa-solid fa-chart-line\"></i></div>\r\n          <div>\r\n            <p class=\"business-card__div\">人材事業部</p>\r\n            <h3 class=\"business-card__title\">コンサルティング</h3>\r\n          </div>\r\n        </div>\r\n        <p class=\"business-card__body\">\r\n          再就職支援・人材育成など、企業の人事課題に対してきめ細かなコンサルティングサービスを提供します。\r\n        </p>\r\n        <ul class=\"business-card__tags\">\r\n          <li>再就職支援</li><li>人材育成</li>\r\n        </ul>\r\n      </div>\r\n\r\n      <div class=\"business-card business-card--hr\" data-fade>\r\n        <div class=\"business-card__header\">\r\n          <div class=\"business-card__icon\"><i class=\"fa-solid fa-graduation-cap\"></i></div>\r\n          <div>\r\n            <p class=\"business-card__div\">人材事業部</p>\r\n            <h3 class=\"business-card__title\">教育研修</h3>\r\n          </div>\r\n        </div>\r\n        <p class=\"business-card__body\">\r\n          厚生労働省・福井県委託訓練、社員教育、PC教育など、スキルアップを支援するプログラムを実施しています。\r\n        </p>\r\n        <ul class=\"business-card__tags\">\r\n          <li>委託訓練</li><li>社員教育</li><li>PC教育</li>\r\n        </ul>\r\n      </div>\r\n\r\n      <div class=\"business-card business-card--global\" data-fade>\r\n        <div class=\"business-card__header\">\r\n          <div class=\"business-card__icon\"><i class=\"fa-solid fa-globe\"></i></div>\r\n          <div>\r\n            <p class=\"business-card__div\">人材事業部</p>\r\n            <h3 class=\"business-card__title\">海外ビジネス支援</h3>\r\n          </div>\r\n        </div>\r\n        <p class=\"business-card__body\">\r\n          現地視察コーディネート・ビジネスマッチング・人材コンサルティング・海外進出支援など、グローバル展開をトータルサポート。\r\n        </p>\r\n        <ul class=\"business-card__tags\">\r\n          <li>現地視察</li><li>ビジネスマッチング</li><li>進出支援</li>\r\n        </ul>\r\n      </div>\r\n\r\n      <div class=\"business-card business-card--travel\" data-fade>\r\n        <div class=\"business-card__header\">\r\n          <div class=\"business-card__icon\"><i class=\"fa-solid fa-plane-departure\"></i></div>\r\n          <div>\r\n            <p class=\"business-card__div\">旅行事業部</p>\r\n            <h3 class=\"business-card__title\">旅行業全般</h3>\r\n          </div>\r\n        </div>\r\n        <p class=\"business-card__body\">\r\n          国内商品販売・チケット販売・ホテル予約・パッケージ販売・団体旅行はもちろん、国際航空券・海外ウェディング・留学・ホームステイなど幅広いニーズに対応。\r\n        </p>\r\n        <ul class=\"business-card__tags\">\r\n          <li>国内旅行</li><li>海外旅行</li><li>団体旅行</li><li>海外ウェディング</li><li>留学</li>\r\n        </ul>\r\n      </div>\r\n\r\n    </div>\r\n  </div>\r\n</section>\r\n\r\n<!-- ========================================\r\n     SEC 04: 数字で見るキャリアネットワーク\r\n======================================== -->\r\n<section class=\"section-numbers\">\r\n  <div class=\"container\">\r\n    <div class=\"section-header section-header--light\" data-fade>\r\n      <span class=\"section-header__en\">NUMBERS</span>\r\n      <h2 class=\"section-header__ja\">数字で見るキャリアネットワーク</h2>\r\n    </div>\r\n    <div class=\"numbers-grid\">\r\n      <div class=\"numbers-card\" data-fade>\r\n        <span class=\"numbers-card__num\" data-count=\"23\">0</span>\r\n        <span class=\"numbers-card__unit\">年</span>\r\n        <p class=\"numbers-card__label\">創業年数</p>\r\n      </div>\r\n      <div class=\"numbers-card\" data-fade>\r\n        <span class=\"numbers-card__num\" data-count=\"1500\">0</span>\r\n        <span class=\"numbers-card__unit\">社</span>\r\n        <p class=\"numbers-card__label\">取引先企業数</p>\r\n      </div>\r\n      <div class=\"numbers-card\" data-fade>\r\n        <span class=\"numbers-card__num\" data-count=\"1200\">0</span>\r\n        <span class=\"numbers-card__unit\">名</span>\r\n        <p class=\"numbers-card__label\">累計支援人数</p>\r\n      </div>\r\n      <div class=\"numbers-card\" data-fade>\r\n        <span class=\"numbers-card__num\" data-count=\"85\">0</span>\r\n        <span class=\"numbers-card__unit\">%</span>\r\n        <p class=\"numbers-card__label\">未経験入社率</p>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</section>\r\n\r\n<!-- ========================================\r\n     SEC 05: 認証・資格\r\n======================================== -->\r\n<section class=\"section-cert\">\r\n  <div class=\"container\">\r\n    <div class=\"section-header\" data-fade>\r\n      <span class=\"section-header__en\">CERTIFICATION</span>\r\n      <h2 class=\"section-header__ja\">認証・許認可</h2>\r\n      <p class=\"section-header__desc\">法令を遵守し、品質・環境・情報セキュリティの国際規格を取得しています。</p>\r\n    </div>\r\n    <div class=\"cert-grid\">\r\n      <div class=\"cert-card\" data-fade>\r\n        <div class=\"cert-card__icon\"><i class=\"fa-solid fa-certificate\"></i></div>\r\n        <h3 class=\"cert-card__title\">ISO 9001</h3>\r\n        <p class=\"cert-card__body\">品質マネジメントシステム<br>国際規格認証取得</p>\r\n      </div>\r\n      <div class=\"cert-card\" data-fade>\r\n        <div class=\"cert-card__icon\"><i class=\"fa-solid fa-leaf\"></i></div>\r\n        <h3 class=\"cert-card__title\">ISO 14001</h3>\r\n        <p class=\"cert-card__body\">環境マネジメントシステム<br>国際規格認証取得</p>\r\n      </div>\r\n      <div class=\"cert-card\" data-fade>\r\n        <div class=\"cert-card__icon\"><i class=\"fa-solid fa-shield-halved\"></i></div>\r\n        <h3 class=\"cert-card__title\">ISO 27001</h3>\r\n        <p class=\"cert-card__body\">情報セキュリティマネジメント<br>国際規格認証取得</p>\r\n      </div>\r\n      <div class=\"cert-card\" data-fade>\r\n        <div class=\"cert-card__icon\"><i class=\"fa-solid fa-id-card\"></i></div>\r\n        <h3 class=\"cert-card__title\">一般労働者派遣事業</h3>\r\n        <p class=\"cert-card__body\">厚生労働省許可<br>般18-300001</p>\r\n      </div>\r\n      <div class=\"cert-card\" data-fade>\r\n        <div class=\"cert-card__icon\"><i class=\"fa-solid fa-briefcase\"></i></div>\r\n        <h3 class=\"cert-card__title\">有料職業紹介事業</h3>\r\n        <p class=\"cert-card__body\">厚生労働省許可<br>般18-ユ-300017</p>\r\n      </div>\r\n      <div class=\"cert-card\" data-fade>\r\n        <div class=\"cert-card__icon\"><i class=\"fa-solid fa-plane\"></i></div>\r\n        <h3 class=\"cert-card__title\">旅行業第3種</h3>\r\n        <p class=\"cert-card__body\">福井県知事登録<br>第196号</p>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</section>\r\n\r\n<!-- ========================================\r\n     SEC 06: アクセス\r\n======================================== -->\r\n<section class=\"section-access\">\r\n  <div class=\"container\">\r\n    <div class=\"section-header\" data-fade>\r\n      <span class=\"section-header__en\">ACCESS</span>\r\n      <h2 class=\"section-header__ja\">アクセス</h2>\r\n    </div>\r\n    <div class=\"access-wrap\" data-fade>\r\n      <div class=\"access-info\">\r\n        <div class=\"access-info__item\">\r\n          <i class=\"fa-solid fa-building\"></i>\r\n          <div>\r\n            <p class=\"access-info__label\">会社名</p>\r\n            <p class=\"access-info__value\">株式会社 キャリアネットワーク</p>\r\n          </div>\r\n        </div>\r\n        <div class=\"access-info__item\">\r\n          <i class=\"fa-solid fa-location-dot\"></i>\r\n          <div>\r\n            <p class=\"access-info__label\">所在地</p>\r\n            <p class=\"access-info__value\">〒910-0067<br>福井県福井市新田塚1-25-18 aoiビル3F</p>\r\n          </div>\r\n        </div>\r\n        <div class=\"access-info__item\">\r\n          <i class=\"fa-solid fa-train\"></i>\r\n          <div>\r\n            <p class=\"access-info__label\">交通</p>\r\n            <p class=\"access-info__value\">えちぜん鉄道「新田塚駅」より徒歩約3分</p>\r\n          </div>\r\n        </div>\r\n        <div class=\"access-info__item\">\r\n          <i class=\"fa-solid fa-phone\"></i>\r\n          <div>\r\n            <p class=\"access-info__label\">電話番号</p>\r\n            <p class=\"access-info__value\"><a href=\"tel:0776250864\">0776-25-0864</a></p>\r\n          </div>\r\n        </div>\r\n        <div class=\"access-info__item\">\r\n          <i class=\"fa-solid fa-clock\"></i>\r\n          <div>\r\n            <p class=\"access-info__label\">営業時間</p>\r\n            <p class=\"access-info__value\">月〜金 9:00〜18:00（土日祝休）</p>\r\n          </div>\r\n        </div>\r\n      </div>\r\n      <div class=\"access-map\">\r\n\r\n        \r\n        \r\n        <iframe\r\n          src=\"https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d806.0427100307211!2d136.20800102851916!3d36.08932328201794!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x5ff8bfbd34a76147%3A0xc0c5d28285dfbfc0!2z44Kt44Oj44Oq44Ki44ON44OD44OI44Ov44O844KvIOemj-S6lei7ouiBt-aUr-aPtOOCu-ODs-OCv-ODvA!5e0!3m2!1sja!2sjp!4v1774336154147!5m2!1sja!2sjp\"\r\n          width=\"100%\"\r\n          height=\"100%\"\r\n          style=\"border:0;\"\r\n          allowfullscreen=\"\"\r\n          loading=\"lazy\"\r\n          referrerpolicy=\"no-referrer-when-downgrade\"\r\n          title=\"株式会社キャリアネットワーク アクセスマップ\">\r\n        </iframe>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</section>\r\n\r\n<!-- ========================================\r\n     FINAL CTA\r\n======================================== -->\r\n<section class=\"section-cta-final\">\r\n  <div class=\"container\">\r\n    <div class=\"cta-final-inner\" data-fade>\r\n     