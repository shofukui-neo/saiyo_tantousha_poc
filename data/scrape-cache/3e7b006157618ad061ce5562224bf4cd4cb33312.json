{"url":"https://www.yamazakipan.co.jp/recruit/universities/work/seisangijutsu/index.html","html":"<!DOCTYPE html>\r\n<html lang=\"ja\">\r\n    <head prefix=\"og: http://ogp.me/ns# fb: http://ogp.me/ns/fb# article: http://ogp.me/ns/article#\">\r\n        <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\" />\r\n        <meta charset=\"UTF-8\">\r\n        <meta name=\"viewport\" content=\"width=device-width, initial-scale=1, maximum-scale=1\">\r\n        <title>生産技術職 |山崎製パン株式会社 リクルートサイト</title>\r\n        <meta name=\"description\" content=\"山崎製パン株式会社の大学生新卒採用サイトです。「生産技術職」の仕事について、職種や仕事内容をご紹介しています。\">\r\n        <meta name=\"keywords\" content=\"ヤマザキ,山崎,山崎製パン,製パン,食品業界,リクルート,採用,大卒,就職,エントリー,ヤマザキの仕事,生産技術職\">\r\n        <meta property=\"og:title\" content=\"生産技術職 |山崎製パン株式会社 リクルートサイト\">\r\n        <meta property=\"og:type\" content=\"website\">\r\n        <meta property=\"og:url\" content=\"https://www.yamazakipan.co.jp/recruit/universities/work/seisangijutsu/index.html\">\r\n        <meta property=\"og:image\" content=\"https://www.yamazakipan.co.jp/recruit/universities/assets/images/common/img_ogp.jpg\">\r\n        <meta property=\"og:description\" content=\"山崎製パン株式会社の大学生新卒採用サイトです。「生産技術職」の仕事について、職種や仕事内容をご紹介しています。\">\r\n        <meta name=\"twitter:card\" content=\"summary_large_image\">\r\n        <meta name=\"twitter:title\" content=\"生産技術職 |山崎製パン株式会社 リクルートサイト\">\r\n        <meta name=\"twitter:image\" content=\"https://www.yamazakipan.co.jp/recruit/universities/assets/images/common/img_ogp.jpg\">\r\n        <meta name=\"twitter:description\" content=\"山崎製パン株式会社の大学生新卒採用サイトです。「生産技術職」の仕事について、職種や仕事内容をご紹介しています。\">\r\n        <meta name=\"format-detection\" content=\"telephone=no\">\r\n        <meta name=\"apple-mobile-web-app-capable\" content=\"yes\">\r\n        <meta name=\"apple-mobile-web-app-status-bar-style\" content=\"black-translucent\">\r\n        <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\r\n        <link rel=\"preconnect\" href=\"https://f