om\" crossorigin>\n<link href=\"https://fonts.googleapis.com/css2?family=Barlow:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&family=Noto+Sans+JP:wght@100..900&family=Zen+Old+Mincho:wght@400;500;600;700;900&display=swap\" rel=\"stylesheet\">\n<link rel=\"stylesheet\" href=\"../css/style.css\">\n<script src=\"../js/common.js\"></script>\n<link rel=\"stylesheet\" href=\"../css/swiper-bundle.css\">\n<link rel=\"stylesheet\" href=\"../css/aos.css\">\n<script src=\"../js/swiper-bundle.min.js\"></script>\n<script src=\"../js/aos.js\"></script>\n</head>\n<body>\n  \n<header class=\"l-header p-header\">\n  <div class=\"p-header_logo\"><a href=\"../\"><img src=\"../img/logo.png\" alt=\"「特殊アクリル酸エステル」のリーディングカンパニー 大阪有機化学工業株式会社\"></a></div>\n  <nav id=\"nav\" class=\"p-nav\">\n    <ul class=\"p-nav_list\">\n      <li class=\"p-nav_item\"><a href=\"../\">採用トップ</a></li>\n      <li class=\"p-nav_item\">\n        <a class=\"arrow\" href=\"../mind\">想いを知る</a>\n        <ul class=\"p-dropdown-content\">\n          <li><a href=\"../mind/\">コーナートップ</a></li>\n          <li><a href=\"../mind/ooc_way\">プロジェクトストーリー</a></li>\n          <li><a href=\"../mind/interview/01\">社員インタビュー</a></li>\n        </ul>\n      </li>\n      <li class=\"p-nav_item\">\n        <a class=\"arrow\" href=\"../job\">仕事を知る</a>\n        <ul class=\"p-dropdown-content\">\n          <li><a href=\"../job/\">コーナートップ</a></li>\n          <li><a href=\"../job/welfare\">福利厚生・教育制度</a></li>\n          <li><a href=\"../job/challenge\">挑戦しやすい風土</a></li>\n          <li><a href=\"../job/role_model\">キャリアロールモデル</a></li>\n        </ul>\n      </li>\n      <li class=\"p-nav_item\"><a href=\"../about\">OOCを知る</a></li>\n      <li class=\"p-nav_item\">\n        <a class=\"arrow\" href=\"../employment\">採用情報</a>\n        <ul class=\"p-dropdown-content\">\n          <li><a href=\"../employment/\">コーナートップ</a></li>\n          <li><a href=\"../employment/new/01/\">新卒採用</a></li>\n          <li><a href=\"../employment/career/01/\">キャリア採用</a></li>\n        </ul>\n      </li>\n    </ul>\n    <div class=\"p-nav_entry\"><a href=\"../entry\">ENTRY</a></div>\n    <div class=\"p-nav_sub_link\">\n      <ul>\n        <li><a href=\"/\" target=\"_blank\">コーポレートサイト</a></li>\n        <li><a href=\"/privacy\">個人情報保護方針</a></li>\n      </ul>\n    </div>\n  </nav>\n  <div class=\"p-hamburger\" id=\"hamburger\">\n    <div class=\"p-hamburger__line\"></div>\n    <div class=\"p-hamburger__line\"></div>\n    <div class=\"p-hamburger__line\"></div>\n  </div>\n</header>\n  <main class=\"hidden\">\n    <div class=\"p-second_fv --mind\">\n      <div class=\"l-container01\">\n        <div class=\"c-ttl03\" data-aos=\"fade\">\n          <h1 class=\"c-ttl03_main\">想いを知る</h1>\n          <span class=\"c-ttl03_sub\">FIND OUT ABOUT OOC MIND</span>\n        </div>\n      </div>\n    </div>\n    <div class=\"p-mind_cont\">\n      <div class=\"l-container01 --bg\">\n        <div class=\"p-row01\">\n          <div class=\"p-row01_col\" data-aos=\"fade-up\">\n            <div class=\"c-ttl02\"><h3 class=\"c-ttl02_main\">OOC Way</h3></div>\n          </div>\n          <div class=\"p-row01_col\" data-aos=\"fade-up\">\n            <div class=\"p-text01\">\n              <p>\n                OOCが手掛ける規模も内容もさまざまなプロジェクトたち。<br>\n                そのひとつひとつを成功させるべく、どのように困難を乗り越え、<br>\n                結果につなげていったのかを、メンバーの声とともに紹介します。\n              </p>\n            </div>\n          </div>\n        </div>\n        <div class=\"p-mind_cont_link\" data-aos=\"fade-up\">\n          <figure><img class=\"pc\" src=\"img/story_img.jpg\" alt=\"プロジェクトストーリーを見る\"><img class=\"sp\" src=\"img/story_img_sp.jpg\" alt=\"プロジェクトストーリーを見る\"></figure>\n          <div class=\"p-btn --center\">\n            <div class=\"c-btn01\"><a href=\"ooc_way\">プロジェクトストーリーを見る</a></div>\n          </div>\n        </div>\n      </div>\n      <div class=\"p-interview\">\n        <div class=\"l-container01\">\n          <div class=\"c-ttl02\" data-aos=\"fade-up\">\n            <span class=\"c-ttl02_main\">INTERVIEW</span>\n            <h2 class=\"c-ttl02_sub\">先輩社員の声</h2>\n          </div>\n        </div>\n        <div class=\"p-interview_slider\" data-aos=\"fade-up\">\n          <div class=\"pc\">\n            <div class=\"swiper swiper_pc\">\n              <ul class=\"swiper-wrapper p-interview_list\">\n                <li class=\"swiper-slide p-interview_item\">\n                  <a href=\"interview/08\">\n                    <div class=\"p-interview_item_img\">\n                      <img src=\"../img/interview_img08.png\" alt=\"N.T.さん\">\n                      <p>金沢工場 製造二課<br>N.T.さん</p>\n                    </div>\n                    <div class=\"p-interview_item_cont\">\n                      <h3 class=\"p-interview_item_ttl\">役に立てているという実感が、前へ前へと走らせてくれる。</h3>\n                      <div class=\"p-interview_item_detail\">\n                        <span class=\"p-interview_item_cat\">製造部門</span>\n                        <ul class=\"p-interview_item_tags\">\n                          <li>#プラントオペレーター職</li>\n                          <li>#金沢工場</li>\n                        </ul>\n                      </div>\n                    </div>\n                  </a>\n                </li>\n                <li class=\"swiper-slide p-interview_item\">\n                  <a href=\"interview/07\">\n                    <div class=\"p-interview_item_img\">\n                      <img src=\"../img/interview_img07.png\" alt=\"M.K.さん\">\n                      <p>金沢工場 製造二課<br>M.K.さん</p>\n                    </div>\n                    <div class=\"p-interview_item_cont\">\n                      <h3 class=\"p-interview_item_ttl\">ちょっとした機会にも成長の種はたくさんある。</h3>\n                      <div class=\"p-interview_item_detail\">\n                        <span class=\"p-interview_item_cat\">製造部門</span>\n                        <ul class=\"p-interview_item_tags\">\n                          <li>#プラントオペレーター職</li>\n                          <li>#金沢工場</li>\n                        </ul>\n                      </div>\n                    </div>\n                  </a>\n                </li>\n                <li class=\"swiper-slide p-interview_item\">\n                  <a href=\"interview/06\">\n                    <div class=\"p-interview_item_img\">\n                      <img src=\"../img/interview_img06.png\" alt=\"K.S.さん\">\n                      <p>金沢工場 製造五課<br>K.S.さん</p>\n                    </div>\n                    <div class=\"p-interview_item_cont\">\n                      <h3 class=\"p-interview_item_ttl\">学びって、勉強することと実践することで生まれる。</h3>\n                      <div class=\"p-interview_item_detail\">\n                        <span class=\"p-interview_item_cat\">製造部門</span>\n                        <ul class=\"p-interview_item_tags\">\n                          <li>#プラントオペレーター職</li>\n                          <li>#金沢工場</li>\n                        </ul>\n                      </div>\n                    </div>\n                  </a>\n                </li>\n                <li class=\"swiper-slide p-interview_item\">\n                  <a href=\"interview/05\">\n                    <div class=\"p-interview_item_img\">\n                      <img src=\"../img/interview_img05.png\" alt=\"I.T.さん\">\n                      <p>金沢工場 製造三課<br>I.T.さん</p>\n                    </div>\n                    <div class=\"p-interview_item_cont\">\n                      <h3 class=\"p-interview_item_ttl\">作業も考える時間も、なんでもかんでも早くするだけが、作業効率化ではない。</h3>\n                      <div class=\"p-interview_item_detail\">\n                        <span class=\"p-interview_item_cat\">製造部門</span>\n                        <ul class=\"p-interview_item_tags\">\n                          <li>#プラントオペレーター職</li>\n                          <li>#金沢工場</li>\n                        </ul>\n                      </div>\n                    </div>\n                  </a>\n                </li>\n                <li class=\"swiper-slide p-interview_item\">\n                  <a href=\"interview/04\">\n                    <div class=\"p-interview_item_img\">\n                      <img src=\"../img/interview_img04.png\" alt=\"T.Y.さん\">\n                      <p>大阪研究所 研究一課<br>T.Y.さん</p>\n                    </div>\n                    <div class=\"p-interview_item_cont\">\n                      <h3 class=\"p-interview_item_ttl\">挑戦することに、大きいも小さいも関係ない。</h3>\n                      <div class=\"p-interview_item_detail\">\n                        <span class=\"p-interview_item_cat\">研究部門</span>\n                        <ul class=\"p-interview_item_tags\">\n                          <li>#研究開発職</li>\n                          <li>#大阪研究所</li>\n                        </ul>\n                      </div>\n                    </div>\n                  </a>\n                </li>\n                <li class=\"swiper-slide p-interview_item\">\n                  <a href=\"interview/03\">\n                    <div class=\"p-interview_item_img\">\n                      <img src=\"../img/interview_img03.png\" alt=\"O.S.さん\">\n                      <p>大阪研究所 研究一課<br>O.S.さん</p>\n                    </div>\n                    <div class=\"p-interview_item_cont\">\n                      <h3 class=\"p-interview_item_ttl\">日々、向き合ってるのは、実験室の机ではなく、人です。</h3>\n                      <div class=\"p-interview_item_detail\">\n                        <span class=\"p-interview_item_cat\">研究部門</span>\n                        <ul class=\"p-interview_item_tags\">\n                          <li>#研究開発職</li>\n                          <li>#大阪研究所</li>\n                        </ul>\n                      </div>\n                    </div>\n                  </a>\n                </li>\n                <li class=\"swiper-slide p-interview_item\">\n                  <a href=\"interview/02\">\n                    <div class=\"p-interview_item_img\">\n                      <img src=\"../img/interview_img02.png\" alt=\"N.S.さんん\">\n                      <p>金沢研究所 研究二課<br>N.S.さん</p>\n                    </div>\n                    <div class=\"p-interview_item_cont\">\n                      <h3 class=\"p-interview_item_ttl\">答えはすぐ言わない。目先の早さよりも、その先の成長に期待しているから。</h3>\n                      <div class=\"p-interview_item_detail\">\n                        <span class=\"p-interview_item_cat\">研究部門</span>\n                        <ul class=\"p-interview_item_tags\">\n                          <li>#研究開発職</li>\n                          <li>#金沢研究所</li>\n                        </ul>\n                      </div>\n                    </div>\n                  </a>\n                </li>\n                <li class=\"swiper-slide p-interview_item\">\n                  <a href=\"interview/01\">\n                    <div class=\"p-interview_item_img\">\n                      <img src=\"../img/interview_img01.png\" alt=\"D.S.さん\">\n                      <p>金沢研究所 研究三課<br>D.S.さん</p>\n                    </div>\n                    <div class=\"p-interview_item_cont\">\n                      <h3 class=\"p-interview_item_ttl\">お題が難しければ難しいほど、プレッシャーがある。ワクワクもある。</h3>\n                      <div class=\"p-interview_item_detail\">\n                        <span class=\"p-interview_item_cat\">研究部門</span>\n                        <ul class=\"p-interview_item_tags\">\n                          <li>#研究開発職</li>\n                          <li>#金沢研究所</li>\n                        </ul>\n                      </div>\n                    </div>\n                  </a>\n                </li>\n              </ul>\n              <div class=\"l-container01\">\n                <div class=\"p-interview_slider_pagination\">\n                  <div class=\"swiper-button-prev\"></div>\n                  <div class=\"swiper-button-next\"></div>\n                </div>\n              </div>\n            </div>\n          </div>\n          <div class=\"sp\">\n            <div class=\"swiper swiper_sp\">\n              <ul class=\"swiper-wrapper p-interview_list\">\n                <li class=\"swiper-slide p-interview_item\">\n                  <a href=\"interview/01\">\n                    <div class=\"p-interview_item_img\">\n                      <img src=\"../img/interview_img01.png\" alt=\"D.S.さん\">\n                      <p>金沢研究所 研究三課<br>D.S.さん</p>\n                    </div>\n                    <div class=\"p-interview_item_cont\">\n                      <h3 class=\"p-interview_item_ttl\">お題が難しければ難しいほど、プレッシャーがある。ワクワクもある。</h3>\n                      <div class=\"p-interview_item_detail\">\n                        <span class=\"p-interview_item_cat\">研究部門</span>\n                        <ul class=\"p-interview_item_tags\">\n                          <li>#研究開発職</li>\n                          <li>#金沢研究所</li>\n                        </ul>\n                      </div>\n                    </div>\n                  </a>\n                </li>\n                <li class=\"swiper-slide p-interview_item\">\n                  <a href=\"interview/02\">\n                    <div class=\"p-interview_item_img\">\n                      <img src=\"../img/interview_img02.png\" alt=\"N.S.さんん\">\n                      <p>金沢研究所 研究二課<br>N.S.さん</p>\n                    </div>\n                    <div class=\"p-interview_item_cont\">\n                      <h3 class=\"p-interview_item_ttl\">答えはすぐ言わない。目先の早さよりも、その先の成長に期待しているから。</h3>\n                      <div class=\"p-interview_item_detail\">\n                        <span class=\"p-interview_item_cat\">研究部門</span>\n                        <ul class=\"p-interview_item_tags\">\n                          <li>#研究開発職</li>\n                          <li>#金沢研究所</li>\n                        </ul>\n                      </div>\n                    </div>\n                  </a>\n                </li>\n                <li class=\"swiper-slide p-interview_item\">\n                  <a href=\"interview/03\">\n                    <div class=\"p-interview_item_img\">\n                      <img src=\"../img/interview_img03.png\" alt=\"O.S.さん\">\n                      <p>大阪研究所 研究一課<br>O.S.さん</p>\n                    </div>\n                    <div class=\"p-interview_item_cont\">\n                      <h3 class=\"p-interview_item_ttl\">日々、向き合ってるのは、実験室の机ではなく、人です。</h3>\n                      <div class=\"p-interview_item_detail\">\n                        <span class=\"p-interview_item_cat\">研究部門</span>\n                        <ul class=\"p-interview_item_tags\">\n                          <li>#研究開発職</li>\n                          <li>#大阪研究所</li>\n                        </ul>\n                      </div>\n                    </div>\n                  </a>\n                </li>\n                <li class=\"swiper-slide p-interview_item\">\n                  <a href=\"interview/04\">\n                    <div class=\"p-interview_item_img\">\n                      <img src=\"../img/interview_img04.png\" alt=\"T.Y.さん\">\n                      <p>大阪研究所 研究一課<br>T.Y.さん</p>\n                    </div>\n                    <div class=\"p-interview_item_cont\">\n                      <h3 class=\"p-interview_item_ttl\">挑戦することに、大きいも小さいも関係ない。</h3>\n                      <div class=\"p-interview_item_detail\">\n                        <span class=\"p-interview_item_cat\">研究部門</span>\n                        <ul class=\"p-interview_item_tags\">\n                          <li>#研究開発職</li>\n                          <li>#大阪研究所</li>\n                        </ul>\n                      </div>\n                    </div>\n                  </a>\n                </li>\n                <li class=\"swiper-slide p-interview_item\">\n                  <a href=\"interview/05\">\n                    <div class=\"p-interview_item_img\">\n                      <img src=\"../img/interview_img05.png\" alt=\"I.T.さん\">\n                      <p>金沢工場 製造三課<br>I.T.さん</p>\n                    </div>\n                    <div class=\"p-interview_item_cont\">\n                      <h3 class=\"p-interview_item_ttl\">作業も考える時間も、なんでもかんでも早くするだけが、作業効率化ではない。</h3>\n                      <div class=\"p-interview_item_detail\">\n                        <span class=\"p-interview_item_cat\">製造部門</span>\n                        <ul class=\"p-interview_item_tags\">\n                          <li>#プラントオペレーター職</li>\n                          <li>#金沢工場</li>\n                        </ul>\n                      </div>\n                    </div>\n                  </a>\n                </li>\n                <li class=\"swiper-slide p-interview_item\">\n                  <a href=\"interview/06\">\n                    <div class=\"p-interview_item_img\">\n                      <img src=\"../img/interview_img06.png\" alt=\"K.S.さん\">\n                      <p>金沢工場 製造五課<br>K.S.さん</p>\n                    </div>\n                    <div class=\"p-interview_item_cont\">\n                      <h3 class=\"p-interview_item_ttl\">学びって、勉強することと実践することで生まれる。</h3>\n                      <div class=\"p-interview_item_detail\">\n                        <span class=\"p-interview_item_cat\">製造部門</span>\n                        <ul class=\"p-interview_item_tags\">\n                          <li>#プラントオペレーター職</li>\n                          <li>#金沢工場</li>\n                        </ul>\n                      </div>\n                    </div>\n                  </a>\n                </li>\n                <li class=\"swiper-slide p-interview_item\">\n                  <a href=\"interview/07\">\n                    <div class=\"p-interview_item_img\">\n                      <img src=\"../img/interview_img07.png\" alt=\"M.K.さん\">\n                      <p>金沢工場 製造二課<br>M.K.さん</p>\n                    </div>\n                    <div class=\"p-interview_item_cont\">\n                      <h3 class=\"p-interview_item_ttl\">ちょっとした機会にも成長の種はたくさんある。</h3>\n                      <div class=\"p-interview_item_detail\">\n                        <span class=\"p-interview_item_cat\">製造部門</span>\n                        <ul class=\"p-interview_item_tags\">\n                          <li>#プラントオペレーター職</li>\n                          <li>#金沢工場</li>\n                        </ul>\n                      </div>\n                    </div>\n                  </a>\n                </li>\n                <li class=\"swiper-slide p-interview_item\">\n                  <a href=\"interview/08\">\n                    <div class=\"p-interview_item_img\">\n                      <img src=\"../img/interview_img08.png\" alt=\"N.T.さん\">\n                      <p>金沢工場 製造二課<br>N.T.さん</p>\n                    </div>\n                    <div class=\"p-interview_item_cont\">\n                      <h3 class=\"p-interview_item_ttl\">役に立てているという実感が、前へ前へと走らせてくれる。</h3>\n                      <div class=\"p-interview_item_detail\">\n                        <span class=\"p-interview_item_cat\">製造部門</span>\n                        <ul class=\"p-interview_item_tags\">\n                          <li>#プラントオペレーター職</li>\n                          <li>#金沢工場</li>\n                        </ul>\n                      </div>\n                    </div>\n                  </a>\n                </li>\n              </ul>\n              <div class=\"l-container01\">\n                <div class=\"p-interview_slider_pagination\">\n                  <div class=\"swiper-button-prev\"></div>\n                  <div class=\"swiper-button-next\"></div>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n        <script src=\"../js/slider.js\"></script>\n      </div>\n    </div>\n    <div class=\"p-information\" data-aos=\"fade-up\">\n      <div class=\"l-container01\">\n        <div class=\"p-btn p-information_entry\">\n          <div class=\"c-btn01\"><a href=\"../entry\">エントリーはこちら</a></div>\n        </div>\n        <div class=\"p-mynavi\">\n  <a href=\"https://job.mynavi.jp/27/pc/search/corp58074/outline.html\" target=\"_blank\">\n 