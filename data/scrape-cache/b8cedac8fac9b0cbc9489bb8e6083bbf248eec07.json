{"url":"https://www.jfe-steel.co.jp/saiyou/internship/","html":"<!DOCTYPE HTML>\n<html lang=\"ja\">\n<head>\n<!-- webtru tag -->\n<script src=\"https://cmp.datasign.co/v2/42a7e0c2b9/cmp.js\" async></script>\n\n<!-- Google Tag Manager -->\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n})(window,document,'script','dataLayer','GTM-P847MB');</script>\n<!-- End Google Tag Manager -->\n\n<meta charset=\"UTF-8\">\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n<meta name=\"format-detection\" content=\"telephone=no\">\n<meta name=\"viewport\" content=\"width=device-width\">\n<title>インターンシップ｜JFEスチール 新卒採用サイト</title>\n<link href=\"https://cdn.jsdelivr.net/npm/yakuhanjp@3.4.1/dist/css/yakuhanjp-noto.min.css\" rel=\"stylesheet\">\n<link href=\"../css/default.css\" rel=\"stylesheet\">\n<link href=\"../css/common.css\" rel=\"stylesheet\">\n<link href=\"../css/common-s.css\" rel=\"stylesheet\">\n<link href=\"../css/style/internship.css\" rel=\"stylesheet\">\n<link href=\"../css/style/internship-s.css\" rel=\"stylesheet\">\n<script src=\"https://cdnjs.cloudflare.com/ajax/libs/gsap/3.8.0/gsap.min.js\"></script>\n<script src=\"https://cdnjs.cloudflare.com/ajax/libs/gsap/3.8.0/ScrollTrigger.min.js\"></script>\n<script src=\"https://ajax.googleapis.com/ajax/libs/jquery/1.12.4/jquery.min.js\"></script>\n<script src=\"https://cdnjs.cloudflare.com/ajax/libs/jquery-easing/1.4.1/jquery.easing.min.js\"></script>\n<script src=\"../script/jquery.inview.min.js\"></script>\n</head>\n<body class=\"internship-index\">\n\n<!-- Google Tag Manager (noscript) -->\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-P847MB\"\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n<!-- End Google Tag Manager (noscript) -->\n\n<!-- ヘッダー -->\n<header id=\"header\">\n  <div id=\"logo\">\n    <p><a href=\"../internship/\"><img src=\"../image/common/logo.png\" srcset=\"../image/common/logo.png 1x, ../image/common/logo@2x.png 2x\" alt=\"JFEスチール\">INTERNSHIP <br class=\"sp\">SITE</a></p>\n  </div>\n\n  <!-- ナビゲーション -->\n  <div id=\"hnavi\">\n    <p id=\"btn-menu\"><a href=\"javascript:;\"><span></span><span></span><span></span></a></p>\n    <nav>\n      <ul class=\"btn\">\n<!--\n        <li class=\"internship-entry\"><a href=\"https://job.axol.jp/qd/s/jfe-steel_26/entry/agreement\" target=\"_blank\">INTERNSHIP ENTRY</a></li>\n        <li class=\"internship-mypage\"><a href=\"https://job.axol.jp/qd/s/jfe-steel_26/mypage/login\" target=\"_blank\">INTERNSHIP MYPAGE</a></li>\n        <li class=\"internship-entry\"><span class=\"disabled\">INTERNSHIP ENTRY</span></li>\n        <li class=\"internship-mypage\"><span class=\"disabled\">INTERNSHIP MYPAGE</span></li>\n-->\n      </ul>\n      <ul class=\"textlink\">\n        <li><a href=\"../internship/\">INTERNSHIP TOP</a></li>\n        <li><a href=\"../\">リクルートサイト</a></li>\n        <li class=\"external\"><a href=\"https://www.jfe-steel.co.jp/\" target=\"_blank\"><span>コーポレートサイト</span></a></li>\n      </ul>\n    </nav>\n  </div>\n</header>\n<ul class=\"btn-internship\">\n  <li><a href=\"../\">リクルートサイト</a></li>\n  <li class=\"external\"><a href=\"https://www.jfe-steel.co.jp/\" target=\"_blank\">コーポレートサイト</a></li>\n<!--\n  <li class=\"internship-entry\"><a href=\"https://job.axol.jp/qd/s/jfe-steel_26/entry/agreement\" target=\"_blank\">INTERNSHIP ENTRY</a></li>\n  <li class=\"internship-mypage\"><a href=\"https://job.axol.jp/qd/s/jfe-steel_26/mypage/login\" target=\"_blank\">INTERNSHIP MYPAGE</a></li>\n  <li class=\"internship-entry\"><span class=\"disabled\">INTERNSHIP ENTRY</span></li>\n  <li class=\"internship-mypage\"><span class=\"disabled\">INTERNSHIP MYPAGE</span></li>\n-->\n</ul>\n<!-- /ヘッダー -->\n\n<!-- タイトル -->\n<section id=\"title\">\n  <div class=\"inner fadein\">\n    <p class=\"en\"><img src=\"../image/internship/index/title-internship.png\" alt=\"JFE STEEL Internship\" class=\"pc\"><img src=\"../image/internship/index/title-internship-sp.png\" alt=\"JFE STEEL Internship\" class=\"sp\"></p>\n    <h1>鉄の<em>可能性</em>が、<br class=\"sp\">きみの<em>可能性</em>を拓く。</h1>\n  </div>\n  <p class=\"pagination\"><a href=\"#concept\">CONCEPT</a></p>\n</section>\n<!-- /タイトル -->\n\n<!-- コンセプト -->\n<section id=\"concept\">\n  <div class=\"inner\">\n    <p class=\"en\">CONCEPT</p>\n    <h2>コンセプト</h2>\n    <div class=\"vertical fadein\">\n      <p>鉄を使い古された素材だと思っていないだろうか。<br>どこにでもある、<br>安定したビジネスと考えていないだろうか。<br>鉄には、まだまだ多くの可能性が秘められている。</p>\n      <p>この社会を根底から支える基盤として。<br>世界の経済を動かす原動力として。<br>サステナブルな未来を実現する切り札として。</p>\n      <p>JFEスチールは、こうした鉄の可能性に挑み、<br>その手で、社会を支え、世界を動かし、<br>豊かな未来を創造したいと願う、<br>きみのチャレンジに期待している。<br>ここから、鉄のイメージが、変わる。</p>\n    </div>\n  </div>\n  <p class=\"pagination\"><a href=\"#program\">PROGRAM</a></p>\n</section>\n<!-- /コンセプト -->\n\n<!-- プログラム -->\n<section id=\"program\">\n  <div class=\"inner\">\n    <p class=\"en\">PROGRAM</p>\n    <h2>プログラム</h2>\n  </div>\n  <div class=\"flex\">\n    <div class=\"item\">\n      <a href=\"../internship/office.html\">\n        <p class=\"image\"><img src=\"../image/internship/index/image-program-office.jpg\" alt=\"\" class=\"pc\"><img src=\"../image/internship/index/image-program-office-sp.jpg\" alt=\"\" class=\"sp\"></p>\n        <dl>\n          <dt>日本のものづくりを通じて<br>社会・産業・世界を変えよ！</dt>\n          <dd>｜ 「鉄鋼ビジネス体感オープン・カンパニー」 ｜</dd>\n        </dl>\n      <p class=\"btn\">事務系職種向けプログラムへ</p>\n      </a>\n    </div>\n    <div class=\"item\">\n      <a href=\"../internship/tech.html\">\n        <p class=\"image\"><img src=\"../image/internship/index/image-program-tech.jpg\" alt=\"\" class=\"pc\"><img src=\"../image/internship/index/image-program-tech-sp.jpg\" alt=\"\" class=\"sp\"></p>\n        <dl>\n          <dt>世界トップレベルの技術力で<br>全ての産業に<br class=\"sp\">イノベーションを起こせ！</dt>\n          <dd>｜ 「ものづくりエンジニア」体感インターンシップ ｜</dd>\n        </dl>\n        <p class=\"btn\">技術系職種向けプログラムへ</p>\n      </a>\n    </div>\n  </div>\n</section>\n<!-- /プログラム -->\n\n<!-- インターンシップエントリー -->\n<section id=\"entry\">\n  <a href=\"https://axol.jp/zw/s/jfe-steel_28/entry/agreement\" target=\"_blank\">\n    <p class=\"image\"><img src=\"../image/internship/index/bg-entry.jpg\" alt=\"\" class=\"pc\"><img src=\"../image/internship/index/bg-entry-sp.jpg\" alt=\"\" class=\"sp\"></p>\n    <div class=\"inner\">\n      <p class=\"en\">INTERNSHIP <br class=\"sp\">ENTRY</p>\n      <h2>インターンシップエントリーはこちら</h2>\n    </div>\n  </a>\n<!--\n  <span class=\"disabled\">\n    <p class=\"image\"><img src=\"../image/internship/index/bg-entry.jpg\" alt=\"\" class=\"pc\"><img src=\"../image/internship/index/bg-entry-sp.jpg\" alt=\"\" class=\"sp\"></p>\n    <div class=\"inner\">\n      <p class=\"en\">INTERNSHIP <br class=\"sp\">ENTRY</p>\n      <h2>インターンシップ受付は終了しました</h2>\n    </div>\n  </span>\n-->\n</section>\n<!-- /インターンシップエントリー -->\n\n<div id=\"copyright\">\n  <ul>\n    <li><a href=\"../\">リクルートサイト</a></li>\n    <li class=\"external\"><a href=\"https://www.jfe-steel.co.jp/\" target=\"_blank\">コーポレートサイト</a></li>\n  </ul>\n  <small>Copyright &copy; JFE Steel Corporation. All Rights Reserved.</small>\n</div>\n\n<!-- JavaScript -->\n<script src=\"../script/common.js\"></script>\n<!-- /JavaScript -->\n<script type=\"text/javascript\" src=\"/_Incapsula_Resource?SWJIYLWA=719d34d31c8e3a6e6fffd425f7e032f3&ns=8&cb=849780193\" async></script></body>\n</html>\n","finalUrl":"https://www.jfe-steel.co.jp/saiyou/internship/","rendered":false,"_cachedAt":"2026-06-22T21:31:13.108Z"}