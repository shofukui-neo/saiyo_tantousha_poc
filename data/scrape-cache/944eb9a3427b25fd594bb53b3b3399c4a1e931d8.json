com/ns.html?id=GTM-WRMP8TD\" height=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n    <!-- End Google Tag Manager (noscript) -->\n\n    <!--header\n///////////////////////////////////////////////-->\n    <header>\n        <div class=\"header-inner\">\n            <h1><a href=\"index.html\"><img src=\"img/logo.png\" alt=\"日本スピンドル製造株式会社\"></a></h1>\n\n            <nav>\n                <ul class=\"dropmenu\">\n                    <li><a href=\"index.html\">HOME</a></li>\n                    <li><a href=\"about.html\">日本スピンドルについて</a>\n                        <ul>\n                            <li><a href=\"about.html#ab-1\">経営理念・ビジョン</a></li>\n                            <li><a href=\"about.html#ab-2\">日本スピンドルの歴史</a></li>\n                            <li><a href=\"about.html#ab-3\">会社概要</a></li>\n                        </ul>\n                    </li>\n                    <li><a href=\"product.html\">製品情報</a>\n                        <ul>\n                            <li><a href=\"product.html#pr-1\">事業分野</a></li>\n                            <li><a href=\"product.html#pr-2\">こんなところに日本スピンドル</a></li>\n                            <li><a href=\"product.html#pr-3\">ものづくりへの想い</a></li>\n                        </ul>\n                    </li>\n                    <li><a href=\"https://www.spindle.co.jp/csr/sustainability.html\" target=\"_blank\">サステナビリティ</a>\n                    <li><a href=\"interview.html\">社員紹介</a></li>\n                    <li><a href=\"recruit.html\">採用情報</a>\n                        <ul>\n                            <li><a href=\"recruit.html#re-1\">教育制度</a></li>\n                            <li><a href=\"recruit.html#re-2\">働く環境</a></li>\n                            <li><a href=\"recruit.html#re-3\">募集要項</a></li>\n                            <li><a href=\"recruit.html#re-4\">応募フォーム</a></li>\n                        </ul>\n                    </li>\n                    <li><a href=\"https://job.mynavi.jp/28/pc/search/corp3989/outline.html\" class=\"btn-rikunav\" target=\"_blank\" rel=\"noopener noreferrer\">ENTRY</a></li>\n                </ul>\n            </nav>\n        </div>\n    </header>\n\n    <!-- ic btn -->\n    <div class=\"menu-trigger\" href=\"\">\n        <span></span>\n        <span></span>\n        <span></span>\n    </div>\n\n    <!--main\n///////////////////////////////////////////////-->\n    <!-- index mov -->\n    <section class=\"top-img about-maintitle\">\n        <h2><img src=\"img/about-maintitle.png\" alt=\"日本スピンドルについて\"></h2>\n        <p class=\"ti-p1\">オーダーメイド設計でお客様のニーズに対応し、<br>\n            製品を一から作る産業機械メーカーです。</p>\n    </section>\n\n    <!-- breadcrumb list -->\n    <section class=\"path\">\n        <ul>\n            <li><a href=\"index.html\">HOME</a>　&#8250;　</li>\n            <li>日本スピンドルについて</li>\n        </ul>\n    </section>\n\n    <main>\n\n        <!-- content\n///////////////////////////////////////////////-->\n\n        <!-- page-link -->\n        <section class=\"page-link\">\n            <ul>\n                <li><a href=\"#ab-1\">経営理念・ビジョン</a></li>\n                <li><a href=\"#ab-2\">日本スピンドルの歴史</a></li>\n                <li><a href=\"#ab-3\">会社概要</a></li>\n            </ul>\n        </section>\n\n        <!-- 経営理念 -->\n        <div class=\"ab1-back\">\n            <a id=\"ab-1\" class=\"pl-point\"></a>\n            <section class=\"about-block1 inview-point list-mv-u clearfix\">\n                <h2 class=\"chapter-title\">経営理念・ビジョン</h2>\n                <img src=\"img/about-pdfimg.png\" alt=\"\">\n                <a href=\"pdf/spindle_business-principles.pdf\" target=\"_blank\" class=\"alphaOver\"><img src=\"img/btn-pdf-rinen.png\" alt=\"経営理念・ビジョン\"></a>\n            </section>\n        </div>\n\n        <!-- 日本スピンドルの歩み -->\n        <div class=\"ab2-back\">\n            <a id=\"ab-2\" class=\"pl-point\"></a>\n            <div class=\"content-flame-ab inview-point list-mv-u\">\n                <section class=\"about-block2\">\n                    <div class=\"ab2-width\">\n                        <h2 class=\"chapter-title\">日本スピンドルの歴史</h2>\n                        <p class=\"ct-txt\">日本スピンドルは創業100年を超える産業機械メーカーです。<br>\n                            1918年(大正7年)、紡績機械の主要部品である「スピンドル」を開発・製造したことが当社の始まりです。</p>\n                    </div>\n\n                    <div class=\"ab2-mov\">\n                        <p>創業者　桑田　權平</p>\n                        <div class=\"movie-wrap\">\n                            <iframe width=\"854\" height=\"480\" src=\"https://www.youtube.com/embed/SDtOt2yP7kA?rel=0\" frameborder=\"0\" allow=\"autoplay; encrypted-media\" allowfullscreen></iframe>\n                        </div>\n                    </div>\n\n                    <div class=\"ab2-back-color\">\n                        <div class=\"ab2-history\">\n                            <h3>「次世代製品の開発へ繋がる、高い技術と柔軟な開発力」</h3>\n                            <p>日本スピンドルは、業界のニーズをいち早く把握することで次世代製品を開発してきました。</p>\n\n                            <div>\n                                <section>\n                                    <dl>\n                                        <dt>1918年　「スピンドル」国産化</dt>\n                                        <dd>\n                                            <h5><strong>(大正7年)</strong></h5>\n                                            <h6>日本で紡績産業が盛んであった当時、初の紡績機用スピンドルの国産化に成功し、 国内外で高いシェアを獲得</h6>\n                                        </dd>\n                                    </dl>\n                                    <dl>\n                                        <dt>1959年　「エアフィルター」開発</dt>\n                                        <dd>\n                                            <h5><strong></strong></h5>\n                                            <h6>紡績機用工場で課題だった空気中を舞う綿ぼこりの環境改善が目的で開発</h6>\n                                        </dd>\n                                    </dl>\n                                    <dl>\n                                        <dt>1961年　「集塵機」の納入</dt>\n                                        <dd>\n                                            <h5><strong></strong></h5>\n                                            <h6>工場のばい煙による大気汚染が深刻化し、社会問題になったことから開発。<br>\n                                                当時、米国からの輸入にたよっていた高温集塵技術の要であるガラス繊維ろ布の初の国産化に成功</h6>\n                                        </dd>\n                                    </dl>\n                                    <dl>\n                                        <dt>1968年　「スピニングマシン」が完成</dt>\n                                        <dd>\n                                            <h5><strong></strong></h5>\n                                            <h6>紡績用スピンドルで培われた技術を金属を成形する技術へ継承</h6>\n                                        </dd>\n                                    </dl>\n                                </section>\n\n                                <section class=\"pic\">\n                                    <ul>\n                                        <li><img src=\"img/about-img1.png\" alt=\"\"></li>\n                                        <li>　　　　<img src=\"img/about-img2.jpg\" alt=\"\"></li>\n                                        <li><img src=\"img/about-img3.jpg\" alt=\"\">　　　</li>\n                                    </ul>\n                                </section>\n                            </div>\n                        </div>\n\n                    </div>\n                </section>\n            </div>\n        </div>\n\n        <!-- 会社概要 -->\n        <div class=\"ab3-back\">\n            <a id=\"ab-3\" class=\"pl-point\"></a>\n            <div class=\"content-flame1 inview-point list-mv-u\">\n                <section class=\"about-block3\">\n                    <h2 class=\"chapter-title\">会社概要</h2>\n\n                    <div class=\"ab3-mov\">\n                        <p>100周年記念動画　事業紹介編</p>\n                        <div class=\"movie-wrap\">\n                            <iframe width=\"854\" height=\"480\" src=\"https://www.youtube.com/embed/Ted-nZ6qZrI?rel=0\" frameborder=\"0\" allow=\"autoplay; encrypted-media\" allowfullscreen></iframe>\n                        </div>\n                    </div>\n\n                    <div class=\"main_content\">\n\n                        <div class=\"content\" id=\"company_top\">\n\n                            <div class=\"about-in\">\n\n                                <dl class=\"dl1\">\n                                    <dt>商　　　号</dt>\n                                    <dd>日本スピンドル製造株式会社</dd>\n                                    <dt>創　　　立</dt>\n                                    <dd>1918年(大正7年)4月</dd>\n                                    <dt>資　本　金</dt>\n                                    <dd>32億7,599万円</dd>\n                                    <dt>売　上　高</dt>\n                                    <dd>連結：232.7億円（2025年度）<br>\n                                        単体：101.1億円（2025年度）</dd>\n                                    <dt>本社所在地</dt>\n                                    <dd>〒661-8510 兵庫県尼崎市潮江4丁目2番30号<br> TEL(06)6499-5551(代)</dd>\n                                    <dt>従 業 員 数</dt>\n                                    <dd>連結：803人\n                                        <!--br class=\"for-sp\" -->（2026年3月31日現在）<br>\n                                        単体：335人\n                                        <!--br class=\"for-sp\" -->（2026年3月31日現在）\n                                    </dd>\n                                    <dt>役　　　員</dt>\n                                    <dd class=\"dd2\">\n                                        <dl>\n                                            <dt>社　　　長</dt>\n                                            <dd>近藤　茂雄</dd>\n                                            <dt>常務取締役</dt>\n                                            <dd>岩本　高明</dd>\n                                            <dt>取　締　役</dt>\n                                            <dd>杉本　誠</dd>\n                                            <dt>取　締　役</dt>\n                                            <dd>笠原　正</dd>\n                                            <dt>取　締　役</dt>\n                                            <dd>笹倉　洋一</dd>\n                                            <dt>取　締　役</dt>\n                                            <dd>谷口　真一</dd>\n                                            <dt>取　締　役</dt>\n                                            <dd>山本　敬介</dd>\n                                            <dt>常勤監査役</dt>\n                                            <dd>馬塲　信介</dd>\n                                        </dl>\n                                    </dd>\n                                    <dt>株　　　主</dt>\n                                    <dd>住友重機械工業株式会社 (出資比率100%)</dd>\n                                    <dt>建設業の許可票</dt>\n                                    <dd>\n                                        <img src=\"img/about01.png\" class=\"img01\">\n                                    </dd>\n                                    <dt>古物商許可証</dt>\n                                    <dd> \n                                        <img src=\"img/about02.png\" class=\"img01\">\n                                    </dd>\n\n                                </dl>\n\n                                <p class=\"tls\">支社・支店・工場</p>\n                                <div class=\"abt02\">\n\n                                    <div class=\"abt02b\">\n                                        <div class=\"abt02c\">\n                                            <dl>\n                                                <dt>本　　　社</dt>\n                                                <dd>〒661-8510 兵庫県尼崎市潮江4-2-30<br>TEL 06(6499)5551（代）</dd>\n                                            </dl>\n                                        </div>\n                                        <div class=\"abt02c\">\n                                            <iframe src=\"https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d5842.032540566382!2d135.4239523497044