utton\" value=\"住所検索\" onclick=\"mfpc('mailform','郵便番号(必須)','ご住所(必須)');\" /></dd>\n                  </dl>\n                  <dl class=\"form-content\">\n                    <dt>ご住所<span class=\"icon-required\">必須</span></dt>\n                    <dd><input class=\"input-70\" type=\"text\" name=\"ご住所(必須)\"></dd>\n                  </dl>\n                  <dl class=\"form-content\">\n                    <dt>電話番号<span class=\"icon-required\">必須</span></dt>\n                    <dd><input class=\"input-30\" type=\"text\" name=\"電話番号(必須)\"></dd>\n                  </dl>\n                  <dl class=\"form-content\">\n                    <dt>携帯番号<span class=\"icon-required\">必須</span></dt>\n                    <dd><input class=\"input-30\" type=\"text\" name=\"携帯番号(必須)\"></dd>\n                  </dl>\n                  <dl class=\"form-content\">\n                    <dt>応募要項<span class=\"icon-required\">必須</span></dt>\n                    <dd><label><input type=\"radio\" name=\"応募要項(必須)\" value=\"新卒\"> 新卒</label>　<label><input type=\"radio\" name=\"応募要項(必須)\" value=\"中途\"> 中途</label></dd>\n                  </dl>\n                  <dl class=\"form-content\">\n                    <dt>卒業見込み</dt>\n                    <dd>\n                      ※新卒の方はご記入ください<br>\n                      <div class=\"block-select\">\n                        <select name=\"卒業年月：年\">\n                          <option value=\"\"> ----- </option>\n                          <option value=\"2026年\">2026年</option><option value=\"2027年\">2027年</option><option value=\"2028年\">2028年</option><option value=\"2029年\">2029年</option>                        </select>\n                      </div>\n                      <div class=\"block-select\">\n                        <select name=\"卒業年月：月\">\n                          <option value=\"\"> ----- </option>\n                          <option value=\"1月\">1月</option>\n                          <option value=\"2月\">2月</option>\n                          