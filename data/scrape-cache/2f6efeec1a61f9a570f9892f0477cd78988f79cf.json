{"url":"https://www.tohogas.co.jp/nw/designing-company-recruit/index.html","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n<head prefix=\"og: http://ogp.me/ns# fb: http://ogp.me/ns/fb# website: http://ogp.me/ns/website#\">\n<meta charset=\"UTF-8\">\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n<meta name=\"viewport\" content=\"width=device-width\">\n<title>東邦ガス | ゲンバの星</title>\n<meta name=\"keywords\" content=\"東邦ガス,ガス,都市ガス,ガス料金,ガス機器,ガス会社,ゲンバの星,導管工事,内管工事,ガス工事,採用,求人,監理士,工事士,設計士\">\n<meta name=\"description\" lang=\"ja\" content=\"東邦ガスのホームページです。工事会社の採用情報ページ「ゲンバの星」では、ガス工事の監理士・工事士・設計士の仕事内容、社員インタビュー、研修サポート体制、よくある質問、求人中の工事会社などをご紹介しています。\">\n<meta property=\"og:type\" content=\"website\">\n<meta property=\"og:url\" content=\"https://www.tohogas.co.jp/nw/designing-company-recruit/index.html\">\n<meta property=\"og:title\" content=\"東邦ガス | ゲンバの星\">\n<meta property=\"og:description\" content=\"東邦ガスのホームページです。工事会社の採用情報ページ「ゲンバの星」では、ガス工事の監理士・工事士・設計士の仕事内容、社員インタビュー、研修サポート体制、よくある質問、求人中の工事会社などをご紹介しています。\">\n<meta property=\"og:site_name\" content=\"ゲンバの星\">\n<meta property=\"og:image\" content=\"https://www.tohogas.co.jp/nw/designing-company-recruit/img/top_construction01.jpg\">\n<link rel=\"stylesheet\" href=\"css/reset.css\">\n<link rel=\"stylesheet\" href=\"css/style.css\">\n<link rel=\"stylesheet\" href=\"css/satellite.css\">\n<link rel=\"icon\" href=\"/nw/favicon.ico\">\n<link rel=\"apple-touch-icon\" href=\"/nw/favicon.ico\" sizes=\"180x180\">\n<link rel=\"icon\" type=\"image/png\" href=\"/nw/favicon.ico\" sizes=\"192x192\">\n<link rel=\"stylesheet\" href=\"css/swiper.min.css\">\n<link href=\"https://www.tohogas.co.jp/nw/designing-company-recruit/index.html\" rel=\"canonical\">\n<script src=\"js/swiper.min.js\"></script>\n<!--[if lt IE 9]><script src=\"/assets/js/html5shiv-printshiv.js\"></script><![endif]-->\n<script src=\"js/import.js\"></script>\n<link rel=\"alternate\" media=\"only screen and (max-width: 640px)\" href=\"https://www.tohogas.co.jp/nw/designing-company-recruit/sp/\" />\n<!-- inc_GTM_head -->\n<!-- inc_GTM_head -->\n</head>\n<body>\n<!-- Google Tag Manager (noscript)  --> \n<!-- End Google Tag Manager (noscript) --> \n\n<!-- header --> \n<script src=\"https://ajax.googleapis.com/ajax/libs/jquery/1.9.1/jquery.min.js\"></script> \n<script>\nfunction init() {\n    var px_change   = 0;\n    window.addEventListener('scroll', function(e){\n        if ( $(window).scrollTop() > px_change ) {\n            $(\"header\").addClass(\"smaller\");\n        } else if ( $(\"header\").hasClass(\"smaller\") ) {\n            $(\"header\").removeClass(\"smaller\");\n        }\n    });\n}\nwindow.onload = init();\n</script> \n<!-- header --> \n\n<!-- fade --> \n<script>\n$(function(){\n    $(window).scroll(function (){\n        $('.parallaxin,.doukan p, .constructiontop,.cooperationmore,.more').each(function(){\n            var elemPos = $(this).offset().top;\n            var scroll = $(window).scrollTop();\n            var windowHeight = $(window).height();\n            if (scroll > elemPos - windowHeight + 200){\n                $(this).addClass('scrollin');\n            }\n        });\n    });\n});\n</script> \n<!-- fade --> \n\n<!-- slide --> \n<script type=\"text/javascript\">\nwindow.addEventListener('DOMContentLoaded', function() {\n  var swiper03 = new Swiper('.topinterviewin .swiper-container', {\n    pagination: '.swiper-pagination',\n    paginationClickable: true,\n    nextButton: '.swiper-button-next',\n    prevButton: '.swiper-button-prev',\n    loop: true,\n    slidesPerView: 3,\n    loopedSlides: 9,\n\t      loopFillGroupWithBlank: true,\n    centeredSlides: true,\n    slideToClickedSlide: true,\n    spaceBetween: 170,\n\tspeed: 600,\n\teffect: 'slide',\n    direction: 'horizontal',\n\tautoplay: 8000,\n\tsimulateTouch: true,\n\tautoplayDisableOnInteraction:false,\n\n\n\n   // レスポンシブ化条件f\n    breakpoints: {\n\t\t      // 1365ピクセル幅以下になったら\n      1365: {\n        slidesPerView: 3,\n        spaceBetween:120\n      },\n    },\n  });\n}, false);\n</script> \n<!-- slide -->\n\n<div id=\"wrapper\"> \n  <!-- header -->\n  <div id=\"l-document\"></div>\n  <div id=\"header\" class=\"pc_box\">\n  <div class=\"inner\">\n    <div id=\"sitelogo\"><a href=\"/index.html\" class=\"rollover\"><img src=\"img/logo.gif\" width=\"172\" height=\"38\" alt=\"東邦ガスネットワーク\" /></a></div>\n  </div>\n \n  <!-- nav -->\n  <header>\n    <nav id=\"nav\">\n      <ul>\n        <li><a href=\"index.html\">TOP</a></li>\n        <li><a href=\"honshikan/index.html\">本支管工事</a></li>\n        <li><a href=\"naikan/index.html\">内管工事</a></li>\n        <li><a href=\"interview/index.html\">インタビュー</a></li>\n        <li><a href=\"support/index.html\">研修サポート</a></li>\n        <li><a href=\"kyujin/index.html\">求人工事会社一覧</a></li>\n        <li><a href=\"faq/index.html\">よくある質問</a></li>\n      </ul>\n    </nav>\n    </div>\n    <!-- //nav --> \n    \n  </header>\n  <!-- //header --> \n  \n  <!-- video -->\n  <video id=\"video\" muted autoplay loop>\n    <source src=\"video/thg_m001.mp4\" type=\"video/mp4\">\n  </video>\n  <p class=\"movieabsolute\"><img src=\"img/top-logo.png\" alt=\"ゲンバの星\"></p>\n  <p class=\"movieabsolute02\"><img src=\"img/scroll.png\" alt=\"scroll\"></p>\n  <!-- //video --> \n  \n  <!-- topparallax -->\n  <div id=\"topparallax\">\n    <div class=\"slide-bottom\">\n      <div class=\"parallaxin\"><img src=\"img/top01.jpg\">\n        </p>\n        <p><span><b>人が暮らし、働く場所に<br />\n          命を吹きこむ「ガス」。</b></span><br />\n          <br />\n          そのパワフルなエネルギーで <br />\n          建物は憩いの場、集いの場、ものづくりの場となり、 <br />\n          人が暮らし働く「まち」は輝きはじめます。 <br />\n          そんな「ガス」エネルギーを届けるための「ガス工事」。 <br />\n          チームで得られる充実感、ありがとうと言われる喜びなど <br />\n          大きなやりがいに「自分」も輝けるシゴトです。</p>\n      </div>\n    </div>\n  </div>\n  <!-- //topparallax --> \n  \n  <!-- doukan -->\n  <div class=\"doukan\"><img src=\"img/top_bg01.png\"　alt=\"リレーでつなぐガス工事\">\n    <p><img src=\"img/top02.jpg\"></p>\n    <p class=\"doukan02\"><span><b>見えない場所から<br />\n      ライフラインを支える、<br />\n      ｢ガス工事｣の大きな使命。</b></span><br />\n      <br />\n      製造された都市ガスは「ガス導管」を通り、必要な場所まで運ばれます。「ガス導管」を地下や建物の内部に通して、工場や商業施設、ご家庭へ安全に都市ガスをお届けする「ガス工事」は、地域のライフラインを支える大切な使命を持っています。</p>\n  </div>\n  <!-- //doukan --> \n  \n  <!-- construction -->\n  <div id=\"doukan03\">都市ガスは、都市ガス製造所からお客さまがガスを使用する&ensp;<br />\n  場所まで本支管と内管のリレーで運ばれます。<br />\n    本支管工事と内管工事、現場の内容は異なりますが、<br />\n    「都市ガスを安全に届ける」ために連携プレーで施工しています。 </div>\n  <div class=\"constructiontop\">\n    <ul>\n      <li><a href=\"honshikan/index.html\"><img src=\"img/top_construction02.jpg\">\n        <p><b>本支管工事</b> <span>&#9654;<br />\n          大動脈をこの手で通す。</span></p>\n        </a></li>\n      <li><a href=\"naikan/index.html\"><img src=\"img/top_construction03.jpg\">\n        <p><b>&emsp;&nbsp;内管工事</b> <span>&#9654;<br />\n          &emsp;&nbsp;暮らしの身近に。 </span></p>\n        </a></li>\n    </ul>\n  </div>\n  <!-- //construction --> \n  \n  <!-- interview -->\n  <div class=\"topinterview\"><img src=\"img/top_bg02.png\" alt=\"先輩に聞いてみました！！\">\n    <p><b>｢ガス工事｣の現場で働く先輩たちのホンネをご紹介。</b></p>\n  </div>\n  <div class=\"topinterviewin\">\n    <div class=\"swiper-container\">\n      <div class=\"swiper-wrapper\">\n        <div class=\"swiper-slide\"><a href=\"interview/index.html#interview01\"><img src=\"img/interview_01.jpg\"></a>\n          <p class=\"swiper-slide01\">本支管監理士<br />\n            <span><b>田中 将浩</b></span></p>\n        </div>\n        <div class=\"swiper-slide\"><a href=\"interview/index.html#interview02\"><img src=\"img/interview_02.jpg\" alt=\"樋田 泰裕\"></a>\n          <p class=\"swiper-slide01\">本支管監理士<br />\n            <span><b></b></span></p>\n        </div>\n        <div class=\"swiper-slide\"><a href=\"interview/index.html#interview03\"><img src=\"img/interview_03.jpg\"></a>\n          <p class=\"swiper-slide01\">本支管工事士<br />\n            <span><b>庄司 昌弘</b></span></p>\n        </div>\n        <div class=\"swiper-slide\"><a href=\"interview/index.html#interview04\"><img src=\"img/interview_04.jpg\"></a>\n          <p class=\"swiper-slide01\">本支管工事士<br />\n            <span><b>村川 弘信</b></span></p>\n        </div>\n        <div class=\"swiper-slide\"><a href=\"interview/index.html#interview05\"><img src=\"img/interview_05.jpg\"></a>\n          <p class=\"swiper-slide01\">本支管工事士<br />\n            <span><b>藤井 康博</b></span></p>\n        </div>\n        <div class=\"swiper-slide\"><a href=\"interview/index.html#interview06\"><img src=\"img/interview_06.jpg\"></a>\n          <p class=\"swiper-slide02\">内管監理士<br />\n            <span><b>丹羽 真里奈</b></span></p>\n        </div>\n        <div class=\"swiper-slide\"><a href=\"interview/index.html#interview07\"><img src=\"img/interview_07.jpg\"></a>\n          <p class=\"swiper-slide01\">内管工事士<br />\n            <span><b>田中 廣幸</b></span></p>\n        </div>\n        <div class=\"swiper-slide\"><a href=\"interview/index.html#interview08\"><img src=\"img/interview_08.jpg\"></a>\n          <p class=\"swiper-slide01\">内管工事士<br />\n            <span><b>谷上 友浩</b></span></p>\n        </div>\n        <div class=\"swiper-slide\"><a href=\"interview/index.html#interview09\"><img src=\"img/interview_09.jpg\"></a>\n          <p class=\"swiper-slide01\">内管設計士<br />\n            <span><b>二村 一輝</b></span></p>\n        </div>\n      </div>\n      <div class=\"swiper-pagination\"></div>\n      <div class=\"swiper-button-prev\"></div>\n      <div class=\"swiper-button-next\"></div>\n    </div>\n  </div>\n  <div class=\"interviewbutton\"><a href=\"interview/index.html\"><img src=\"img/button_interview.png\" alt=\"他の社員を見る\"></a> </div>\n  \n  <!-- //interview --> \n  \n  <!-- support -->\n  <div class=\"topsupport\">\n    <p><b>丁寧な指導と資格取得サポートでスキルアップを応援！</b></p>\n    <p class=\"more\"><a href=\"support/index.html\"><img src=\"img/button_more.png\" alt=\"詳しくみる\"></a></p>\n  </div>\n  <!-- //support --> \n  \n  <!-- kyujin -->\n  <div class=\"topcooperation\"> <img src=\"img/top_bg03.png\" alt=\"\">\n    <p class=\"cooperationfont\"><