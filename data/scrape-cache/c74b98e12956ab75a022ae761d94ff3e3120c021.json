さまには冊子もお配りしています。<br>\r\n\t\t<a href=\"https://www.yokohama-ri.co.jp/pdf/katsuyogaido.pdf\" target=\"_blank\">会員サービス活用ガイド(PDF版)</p><ul class=\"article__3col01-list row01\">\r\n    <li class=\"article__3col01-article\"> <a href=\"../seminar/seminar_list.html\">\r\n      <div class=\"article__3col01-ttl_wrap\">\r\n        <h3 class=\"article__3col01-ttl\">ビジネスセミナー</h3>\r\n      </div>\r\n      <div class=\"article__3col01_img-area\"><img src=\"../seminar/img/top_seminar_img01.jpg\" alt=\"ビジネスセミナー\"></div>\r\n      <!--<div class=\"mask\">\r\n\t\t<div class=\"caption\">It's fresh !</div>\r\n\t</div>--></a> </li>\r\n    <li class=\"article__3col01-article\"> <a href=\"../seminar/kouen_list.html\">\r\n      <div class=\"article__3col01-ttl_wrap\">\r\n        <h3 class=\"article__3col01-ttl\">講演会（会員無料）</h3>\r\n      </div>\r\n      <div class=\"article__3col01_img-area\"><img src=\"../seminar/img/top_seminar_img02.jpg\" alt=\"講演会（会員無料）\"></div>\r\n      </a> </li>\r\n    <li class=\"article__3col01-article member__designated-icn\"> <a href=\"../skillup/video_select.html\">\r\n      <div class=\"article__3col01-ttl_wrap member-icn\">\r\n        <h3 class=\"article__3col01-ttl\">DVD貸出</h3>\r\n      </div>\r\n      <div class=\"article__3col01_img-area\"><img src=\"../skillup/img/top_skillup_img01.jpg\" alt=\"DVD貸出\"></div>\r\n      </a> </li>\r\n  </ul>\r\n  <ul class=\"article__3col01-list row02\">\r\n    <li class=\"article__3col01-article\"> <a href=\"../skillup/sinnjin.html\">\r\n      <div class=\"article__3col01-ttl_wrap\">\r\n        <h3 class=\"article__3col01-ttl\">新入社員教育メニュー</h3>\r\n      </div>\r\n      <div class=\"article__3col01_img-area\"><img src=\"../skillup/img/top_skillup_img06.jpg\" alt=\"新入社員教育メニュー\"></div>\r\n      </a> </li>\r\n    <li class=\"article__3col01-article\"> <a href=\"../skillup/netseminar.html\">\r\n      <div class=\"article__3col01-ttl_wrap member-icn\">\r\n        <h3 class=\"article__3col01-ttl\">インターネットセミナー</h3>\r\n      </div>\r\n   