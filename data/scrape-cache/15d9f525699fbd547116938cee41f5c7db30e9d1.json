ass=\"listbox\">\n\t\t\t\t\t\t\t<li><a href=\"/banquet/\">ご宴会TOP</a></li>\n\t\t\t\t\t\t\t<li><a href=\"/banquet/banquetlist/\">宴会場一覧</a></li>\n\t\t\t\t\t\t</ul>\n\t\t\t\t\t</li>\n\t\t\t\t\t<li><a href=\"https://ubkinenkan.com/\" target=\"_blank\">記念館</a></li>\n\t\t\t\t\t<li><a href=\"/location/\">各種撮影依頼</a></li>\n\t\t\t\t\t<li><a href=\"/#topics\">トピックス</a></li>\n\t\t\t\t\t<li><a href=\"/hotel/access/\">アクセス</a></li>\n\t\t\t\t</ul>\n\t\t\t\t<a href=\"https://www.489pro-x.com/ja/s/gamagorich/search/\" target=\"_blank\" class=\"drawerbtn\">宿泊予約</a>\n\t\t\t\t<a href=\"https://gamagori-classic-hotel.official-wedding.jp/fair/?group_by=id\" target=\"_blank\" onClick=\"gtag('event', 'click', {'event_category': 'link','event_label': 'zexy'});\" class=\"drawerbtn\">ブライダルフェア</a>\n\t\t\t\t<a href=\"https://gamagori-classic-hotel.com/contact/\" class=\"drawerbtn\">お問い合わせ</a>\n\t\t\t\t<div class=\"drawersns\">\n\t\t\t\t\t<div class=\"drawersnspart\"><a href=\"https://www.instagram.com/gamagori_classic_hotel/\" target=\"_blank\"><img src=\"/images/icon_instagram.svg\" alt=\"インスタグラム\"></a></div>\n\t\t\t\t\t<div class=\"drawersnspart\"><a href=\"https://www.threads.net/@gamagori_classic_hotel?hl=ja\" target=\"_blank\"><img src=\"/images/icon_threads.svg\" alt=\"ホテル　スレッズ\"></a></div>\n\t\t\t\t\t<div class=\"drawersnspart\"><a href=\"https://www.facebook.com/gamagori.classic/\" target=\"_blank\"><img src=\"/images/icon_facebook.svg\" alt=\"Facebook\"></a></div>\n\t\t\t\t\t<div class=\"drawersnspart\"><a href=\"https://twitter.com/classic_hotel\" target=\"_blank\"><img src=\"/images/icon_twitter.svg\" alt=\"エックス\"></a></div>\n\t\t\t\t\t<div class=\"drawersnspart\"><a href=\"https://www.tiktok.com/@gamagori.classic.hotel\" target=\"_blank\"><img src=\"/images/icon_tiktok.svg\" alt=\"TikTok\"></a></div>\n\t\t\t\t\t<div class=\"drawersnspart\"><a href=\"https://www.youtube.com/channel/UCJkOEKM52eSgmfqpzvpgt8g\" target=\"_blank\"><img src=\"/images/icon_youtube.svg\" alt=\"ホテル　ユーチューブ\"></a></div>\n\t\t\t\t\t<div class=\"drawersnspart\"><a href=\"https://line.me/R/ti/p/@hzb6703u\" target=\"_blank\"><img src=\"/images/icon_line.svg\" alt=\"LINE\"></a></div>\n\t\t\t\t</div>\n\t\t\t</nav>\n\t\t</section>\n\t</header>\n\t\t<main>\n\t\t\t<div class=\"yss-shade\"></div>\n\t\t<section id=\"qol\">\n\t\t\t<div class=\"box\">\n\t\t\t\t<div class=\"image1\">\n\t\t\t\t\t<picture>\n\t\t\t\t\t\t<source media=\"(min-width: 568px)\" srcset=\"../images/conceptimage_01.jpg\">\n\t\t\t\t\t\t<img src=\"../images/conceptimage_sp01.jpg\" alt=\"スタッフ パティシエ\">\n\t\t\t\t\t</picture>\n\t\t\t\t</div>\n\t\t\t\t<div class=\"text\">\n\t\t\t\t\t<h1><img src=\"./images/qualityOfLife.png\" alt=\"QUALITY OF LIFE\"></h1>\n\t\t\t\t\t<p>\n\t\t\t\t\t\t感動の数だけ、人生は豊かになる\n\t\t\t\t\t</p>\n\t\t\t\t</div>\n\t\t\t\t<div class=\"image2\">\n\t\t\t\t\t<picture>\n\t\t\t\t\t\t<source media=\"(min-width: 568px)\" srcset=\"../images/conceptimage_02_2404.jpg\">\n\t\t\t\t\t\t<img src=\"../images/conceptimage_sp02_2404.jpg\" alt=\"スタッフ ベル\">\n\t\t\t\t\t</picture>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</section>\n\t\t<section id=\"description\">\n\t\t\t<p class=\"text\">\n\t\t\t\t蒲郡クラシックホテルでは、<br>\n\t\t\t\t毎日たくさんの思い出や感動が生まれています。<br>\n\t\t\t\t心が“感じて動く”ことを、感動といいます。<br>\n\t\t\t\tそこで働く人も、“感動”の当事者です。\n\t\t\t</p>\n\t\t</section>\n\t\t<section id=\"cultureConcept\">\n\t\t\t<article>\n\t\t\t\t<div class=\"image\">\n\t\t\t\t\t<h2>CONCEPT</h2>\n\t\t\t\t\t<img src=\"./images/culture_concept_260201.jpg\" alt=\"コンセプト\">\n\t\t\t\t</div>\n\t\t\t\t<p class=\"title\">\n\t\t\t\t\tクオリティ・オブ・ライフ\n\t\t\t\t</p>\n\t\t\t\t<p class=\"text\">\n\t\t\t\t\tお客様の感動・感謝を共有・共感し<br>\n\t\t\t\t\t自分自身の「人生の質」を高める。<br>\n\t\t\t\t\t<br>\n\t\t\t\t\t活力のある人は、<br>\n\t\t\t\t\tまわりに好影響を与える人。<br>\n\t\t\t\t\t正の連鎖の起点となり地域・社会に派生させる人。\n\t\t\t\t</p>\n\t\t\t</article>\n\t\t\t<article>\n\t\t\t\t<div class=\"image\">\n\t\t\t\t\t<h2>PHILOSOPHY</h2>\n\t\t\t\t\t<img src=\"./images/culture_philosophy.jpg\" alt=\"フィロソフィー\">\n\t\t\t\t</div>\n\t\t\t\t<p class=\"title\">\n\t\t\t\t\t良質なサービスは、<br>\n\t\t\t\t\t良質な人生から\n\t\t\t\t</p>\n\t\t\t\t<p class=\"text\">\n\t\t\t\t\tお客さまの人生の満足度を高めるためには、<br>\n\t\t\t\t\tまずは自身の人生の満足度を高めることから。<br>\n\t\t\t\t\t<br>\n\t\t\t\t\tビジョンを共有し、目標を明確にする<br>\n\t\t\t\t\t自分で考えて行動し、成果を創り出す<br>\n\t\t\t\t\t失敗から学び、前向きに何度でも挑戦する<br>\n\t\t\t\t\t<br>\n\t\t\t\t\tこれらが成長の鍵となり、<br>\n\t\t\t\t\t豊かな人生の歩みへとつながっていきます。\n\t\t\t\t</p>\n\t\t\t</article>\n\t\t\t<article>\n\t\t\t\t<div class=\"image\">\n\t\t\t\t\t<h2>CULTURE</h2>\n\t\t\t\t\t<img src=\"./images/culture_culture.jpg\" alt=\"カルチャー\">\n\t\t\t\t</div>\n\t\t\t\t<p class=\"title\">\n\t\t\t\t\t渡り鳥のように、全員で前に進む\n\t\t\t\t</p>\n\t\t\t\t<p class=\"text\">\n\t\t\t\t\tVの字になって空を飛ぶ渡り鳥の中に<br>\n\t\t\t\t\tリーダーがいないのをご存知でしょうか。<br>\n\t\t\t\t\t渡り鳥は、それぞれが自分の役目を持ちながら、<br>\n\t\t\t\t\tお互いが助けあい、“共創”してゴールを目指します。<br>\n\t\t\t\t\t<br>\n\t\t\t\t\t上司と部下ではなく、<br class=\"sp\">仲間としてコミュニケーションを図る。<br>\n\t\t\t\t\tスタッフ同士はもちろん、<br class=\"sp\">取引先のパートナーも大切にする。<br>\n\t\t\t\t\t呉竹荘グループに関わるすべての人が力を合わせることで、<br>\n\t\t\t\t\t私たちはより一層の高みを目指すことができるのです。\n\t\t\t\t</p>\n\t\t\t</article>\n\t\t</section>\n\t\t<section id=\"entry\">\n\t\t\t<h2><span>RECRUIT</span>採用案内</h2>\n\t\t\t<div class=\"entrytype\">\n<!--\n\t\t\t\t<a href=\"/gch/recruitnews/briefing/\" class=\"entryform\">会社説明会</a>\n-->\n\t\t\t\t<a href=\"../entry\" class=\"entryform\">新卒採用</a>\n\t\t\t\t<a href=\"../career\" class=\"entryform\">中途採用</a>\n\t\t\t\t<a href=\"../career\" class=\"entryform\">パート・<br class=\"pdpc\">アルバイト</a>\n\t\t\t</div>\n\t\t</section>\n\t</main>\n<footer>\n\t<section id=\"footlinks\">\n\t\t<div class=\"footlogo\"><img src=\"/images/mainLogo_gold.svg\" alt=\"蒲郡クラシックホテル\"></div>\n\t\t<ul class=\"footlink\">\n\t\t\t<li><a href=\"/\">トップ</a></li>\n\t\t\t<li><a href=\"/brand/\">ブランドについて</a></li>\n\t\t\t<li><a href=\"/wedding/\">ウエディング</a></li>\n\t\t\t<li><a href=\"/restaurant/\">レストラン</a></li>\n\t\t\t<li><a href=\"/hotel/\">ご宿泊</a></li>\n\t\t\t<li><a href=\"/banquet/\">ご宴会</a></li>\n\t\t\t<li><a href=\"https://ubkinenkan.com/\" target=\"_blank\">記念館</a></li>\n\t\t\t<li><a href=\"/location/\">各種撮影依頼</a></li>\n\t\t\t<li><a href=\"/#topics\">トピックス</a></li>\n\t\t\t<li><a href=\"/hotel/access/\">アクセス</a></li>\n\t\t</ul>\n\t\t<div class=\"foottel\"><span>tel</span> <a href=\"tel:0533-68-1111\">0533-68-1111</a></div>\n\t\t<ul class=\"otherlinks\">\n\t\t\t<li><a href=\"/policy/\">個人情報保護方針</a></li>\n\t\t\t<li><a href=\"/cookie-policy/\">クッキーポリシー</a></li>\n\t\t\t<li><a href=\"/recruit/\">リクルート</a></li>\n\t\t</ul>\n\t</section>\n\t<div id=\"scrltop\">\n\t\t<a href=\"#\"><img src=\"/images/arrow_totop.svg\" id=\"totop\" alt=\"ページトップへ\"><img src=\"/images/arrow_totop2.svg\" id=\"totop2\" alt=\"ページトップへ\"></a>\n\t</div>\n<div class=\"infocprt\">&copy;GAMAGORI CLASSIC HOTEL</div>\n</footer>\n\n</body>\n</html>","finalUrl":"https://gamagori-classic-hotel.com/recruit/culture/","rendered":false,"_cachedAt":"2026-06-22T18:55:39.899Z"}