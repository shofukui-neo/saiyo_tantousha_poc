;\r\n    }\r\n  });\r\n  // トップへスムーススクロール\r\n  $('#smooth_scroll a').click(function () {\r\n    $('body,html').animate({\r\n    scrollTop: 0\r\n      }, 500);\r\n      // ページのトップへ 500 のスピードでスクロールする\r\n      return false;\r\n   });\r\n});\r\n</script>\r\n<!--スムーズスクロール-->\r\n<script src=\"https://www.ydec.co.jp/wp-content/themes/yoshikawa_wp_theme3/js/lightbox.js\"></script>\r\n<script type='text/javascript' src='https://www.ydec.co.jp/wp-includes/js/wp-embed.min.js?ver=4.5.32'></script>\n</body>\r\n</html>","finalUrl":"https://www.ydec.co.jp/recruit","rendered":false,"_cachedAt":"2026-06-17T23:26:50.603Z"}