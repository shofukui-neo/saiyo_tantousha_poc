の新卒ナビ」愛知・岐阜・三重、新卒学生のための就職情報サイト。東海三県の魅力的な企業の新卒採用情報を紹介。インターン・説明会、就職フェア・イベントの情報を多数掲載中。新卒採用について情報掲載をご希望の企業様もお気軽に問い合わせください。\">\n    <meta property=\"og:title\" content=\"就活なら名大社新卒ナビ｜愛知・岐阜・三重の新卒採用就職情報サイト\">\n    <meta property=\"og:type\" content=\"website\">\n    <meta property=\"og:description\" content=\"「名大社の新卒ナビ」愛知・岐阜・三重、新卒学生のための就職情報サイト。東海三県の魅力的な企業の新卒採用情報を紹介。インターン・説明会、就職フェア・イベントの情報を多数掲載中。新卒採用について情報掲載をご希望の企業様もお気軽に問い合わせください。\">\n    <meta property=\"og:url\" content=\"https://shushoku.meidaisha.co.jp/?p=top\">\n    <meta property=\"og:image\" content=\"https://shushoku.meidaisha.co.jp/assets/images/ogp.png\">\n    <meta property=\"og:site_name\" content=\"就活なら名大社新卒ナビ｜愛知・岐阜・三重の新卒採用就職情報サイト\">\n\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n    <script type=\"module\" crossorigin src=\"./assets/main-CM10zemx.js\"></script>\n    <link rel=\"stylesheet\" crossorigin href=\"./assets/style-gr9NnlG5.css\">\n  </head>\n  <body>\n    <!-- Google Tag Manager (noscript) -->\n    <noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-K9FLBMN\" height=\"0\" width=\"0\"\n        style=\"display:none;visibility:hidden\"></iframe></noscript>\n    <!-- End Google Tag Manager (noscript) -->\n    <header id=\"main-header\" class=\"header f-main-header\"></header>\n    <div id=\"main-container\">\n    </div>\n    <footer id=\"main-footer\" class=\"f-main-footer\"></footer>\n\n\n    <!--検討リストモーダル-->\n    <div id=\"consider\" class=\"modal-overlay\">\n      <div class=\"modal _center c-checkmodal-box\">\n        <button class=\"js-modal-close c-checkmodal-close\"><img src=\"./assets/images/common/modal_close.svg\" alt=\"閉じる\"></button>\n        <p class=\"c-checkmodal-title _ico\">検討リストに<br class=\"u-only-sp\">登録しますか？</p>\n        <p class=\"c-checkmodal-txt\">登録すると、企業の最新説明会情報やフィード公開の通知、応募歓迎の通知が届きます。<br>\n          ※あなたの「大学名・学部」「居住地域」の情報が送信されます。</p>\n        <p class=\"c-checkmodal-invisible\"><label class=\"c-checkitem\"><input type=\"checkbox\" name=\"invisible-check\" value=\"1\"><span class=\"c-checkitem-child\">次回からこの確認画面を表示しない</span></label></p>\n        <div class=\"c-linkbtn-wrap\">\n          <button id=\"add-consider-list\" class=\"u-linkbtn js-modal-close c-checkmodal-btn\">登録する</button>\n        </div>\n      </div>\n    </div>\n\n    <!--キャンセルモーダル-->\n    <div id=\"cancel\" class=\"modal-overlay\">\n      <div class=\"modal _center c-checkmodal-box\">\n        <button class=\"js-modal-close c-checkmodal-close\"><img src=\"./assets/images/common/modal_close.svg\" alt=\"閉じる\"></button>\n        <p class=\"c-checkmodal-title _ico\">予約を<br class=\"u-only-sp\">キャンセルしますか？</p>\n        <div class=\"c-linkbtn-wrap\">\n          <button class=\"u-linkbtn js-modal-close c-checkmodal-btn\">はい</button>\n          <button class=\"u-linkbtn js-modal-close is-wh c-checkmodal-btn\">いいえ</button>\n        </div>\n      </div>\n    </div>\n\n    <!--オファー辞退モーダル-->\n    <div id=\"decline-offer\" class=\"modal-overlay\">\n      <div class=\"modal _center c-checkmodal-box\">\n        <button class=\"js-modal-close c-checkmodal-close\"><img src=\"./assets/images/common/modal_close.svg\" alt=\"閉じる\"></button>\n        <p class=\"c-checkmodal-title _ico\">このオファーを<br class=\"u-only-sp\">辞退しますか？</p>\n        <div class=\"c-linkbtn-wrap\">\n          <button class=\"u-linkbtn js-modal-close c-checkmodal-btn\">はい</button>\n          <button class=\"u-linkbtn js-modal-close is-wh c-checkmodal-btn\">いいえ</button>\n        </div>\n      </div>\n    </div>\n\n    <!--PR削除確認モーダル-->\n    <div id=\"delete_pr\" class=\"modal-overlay\">\n      <div class=\"modal _center c-checkmodal-box\">\n        <button class=\"js-modal-close c-checkmodal-close\"><img src=\"./assets/images/common/modal_close.svg\" alt=\"閉じる\"></button>\n        <p class=\"c-checkmodal-title _ico\">このPR情報を<br class=\"u-only-sp\">削除しますか？</p>\n        <div class=\"c-linkbtn-wrap\">\n          <button class=\"u-linkbtn js-modal-close c-checkmodal-btn\">はい</button>\n          <button class=\"u-linkbtn js-modal-close is-wh c-checkmodal-btn\">いいえ</button>\n        </div>\n      </div>\n    </div>\n\n    <!--検討リストエントリー時確認モーダル-->\n    <div id=\"consider_entry\" class=\"modal-overlay\">\n      <div class=\"modal _center c-checkmodal-box f-cannot-consider-alert\">\n        <button class=\"js-modal-close c-checkmodal-close\"><img src=\"./assets/images/common/modal_close.svg\" alt=\"閉じる\"></button>\n        <p class=\"c-checkmodal-title f-cannot-consider-alert-text\">エントリー済みのため<br class=\"u-only-sp\">検討リストに入れることはできません</p>\n      </div>\n    </div>\n\n  </body>\n</html>\n","finalUrl":"https://shushoku.meidaisha.co.jp/","rendered":false,"_cachedAt":"2026-06-22T14:39:34.278Z"}