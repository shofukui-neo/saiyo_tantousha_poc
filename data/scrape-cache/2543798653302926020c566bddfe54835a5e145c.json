{"url":"https://sanei-nt.co.jp/recruit_interview/staff1/","html":"<!DOCTYPE html>\n<html lang=\"jp\">\n<head>\n<meta charset=\"UTF-8\">\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<link rel=\"stylesheet\" href=\"/assets/css/common.css\" />\n<script src=\"https://ajax.googleapis.com/ajax/libs/jquery/1.12.4/jquery.min.js\"></script>\n<!-- Global site tag (gtag.js) - Google Analytics -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-DZ21CK4D3X\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'G-DZ21CK4D3X');\n</script>\n\n<title>株式会社 サンエイ・ニュートーキョーグループ</title>\n<link rel=\"stylesheet\" href=\"/assets/css/recruit_interview.css\" />\n</head>\n<body id=\"recruit_interview_staff1\">\n<header>\n<div>\n<p><a href=\"/\"><img src=\"/assets/images/header_logo.svg\" alt=\"株式会社サンエイ\" /></a></p>\n<input type=\"checkbox\" id=\"drawer\" />\n<label for=\"drawer\" class=\"open\"><span></span></label>\n<label for=\"drawer\" class=\"close\"></label>\n<nav class=\"menu\">\n<ul>\n<li><a href=\"/\">HOME</a></li>\n<li>\n<p>採用情報</p>\n<ul>\n<li><a href=\"/recruit_parttime/\">パート・アルバイト採用</a></li>\n<li><a href=\"/recruit_new-graduate/\">新卒採用</a></li>\n<li><a href=\"/recruit_career/\">正社員・キャリア採用</a></li>\n</ul>\n</li>\n<li><a href=\"/about/\">会社概要</a></li>\n<li><a href=\"/policy/\">企業理念</a></li>\n<li><a href=\"/shops/\">店舗情報</a></li>\n<li><a href=\"/csr/\">CSR活動</a></li>\n<li><a href=\"/funwaymaster/\">funwayマスター制度</a></li>\n<li><a href=\"/news/\">最新情報</a></li>\n<li><a href=\"/contact/\">お問い合わせ</a></li>\n<li><label for=\"drawer\">メニューを閉じる</label></li>\n</ul>\n</nav>\n</div>\n</header>\n<section class=\"recruit_interview_eyecatch\">\n\t<div>\n\t\t<h1>相澤<span>／あいざわ</span></h1>\n\t\t<p>2013年入社<br />マネージャー</p>\n\t</div>\n\t<div>\n\t\t<p><img src=\"/assets/images/recruit_interview/staff1/eyecatch/photo.jpg\" alt=\"\"><img src=\"/assets/images/recruit_interview/staff1/eyecatch/text.svg\" alt=\"\"></p>\n\t</div>\n</section>\n<!-- .recruit_interview_eyecatch -->\n<section class=\"recruit_inteview_container\">\n\t<div class=\"text\">\n\t\t<h2>成長している姿を<br />見せたい</h2>\n\t\t<p>最終面接で社長に目標を聞かれ、「社長です」と答えました。50歳までに社長になる！まだまだ前途多難ですが、応援してくれた社長、そして仲間に自分の成長している姿を見せたいと思います。</p>\n\t</div>\n</section>\n<!-- .recruit_inteview_container -->\n<section class=\"recruit_inteview_container\">\n\t<div class=\"image\">\n\t\t<p><img src=\"/assets/images/recruit_interview/staff1/image2.jpg\" alt=\"\"></p>\n\t</div>\n\t<div class=\"text\">\n\t\t<h2>入社２年目で<br />新卒担当に選任</h2>\n\t\t<p>当社にはバディー制度があります。まだまだ自分に自信が持てずにいた中で、新入社員と一緒に仕事にあたった半年間、指導を通じて自身の成長に繋がりました。新入社員が一生懸命行動してくれた時、そして結果が出た時は自分の時以上に嬉しかったです。</p>\n\t</div>\n</section>\n<!-- .recruit_inteview_container -->\n<section class=\"recruit_inteview_container\">\n\t<div class=\"image\">\n\t\t<p><img src=\"/assets/images/recruit_interview/staff1/image1.jpg\" alt=\"\"></p>\n\t</div>\n\t<div class=\"text\">\n\t\t<h2>上にあがりたい気持ちが何よりも大事</h2>\n\t\t<p>入社時から、上にあがりたい気持ちは誰よりも高かったと思います。色々なことに挑戦させてもらい、その甲斐あって新卒で初めてマネージャーに就任しました。<br />今は、営業数値の管理はもちろん、スタッフ一人ひとりがやりがいを持って成長できる環境を提供する立場です。<br />私の経験が、新卒の道しるべになるよう、これからも挑戦し続けていきます！</p>\n\t</div>\n</section>\n<!-- .recruit_inteview_container -->\n<section class=\"recruit_interview_message\">\n\t<div>\n\t\t<h2>学生へのメッセージ</h2>\n\t\t<p>職場は人生の中で長い時間を過ごす場所です。どの企業に就職するのか決めることも大切ですが、自分がそこでどう行動するかによって可能性は無限大に広がっていくと私は考えます。</p>\n\t</div>\n</section>\n<!-- .recruit_interview_message -->\n<section class=\"recruit_interview_schedlue separater\">\n\t<div>\n\t\t<h2><span>タイムスケジュール</span></h2>\n\t\t<div>\n\t\t\t<p><img src=\"/assets/images/recruit_interview/staff1/portrait.jpg\" alt=\"\"></p>\n\t\t\t<div>\n\t\t\t\t<div>\n\t\t\t\t\t<p><img src=\"/assets/images/recruit_interview/clock_08.png\" alt=\"\"></p>\n\t\t\t\t\t<p><span>15:30</span><span>出社</span></p>\n\t\t\t\t</div>\n\t\t\t\t<div>\n\t\t\t\t\t<p><img src=\"/assets/images/recruit_interview/clock_09.png\" alt=\"\"></p>\n\t\t\t\t\t<p><span>16:00</span><span>朝礼</span></p>\n\t\t\t\t</div>\n\t\t\t\t<div>\n\t\t\t\t\t<p><img src=\"/assets/images/recruit_interview/clock_10.png\" alt=\"\"></p>\n\t\t\t\t\t<p><span>16:30</span><span>ミーティング</span></p>\n\t\t\t\t</div>\n\t\t\t\t<div>\n\t\t\t\t\t<p><img src=\"/assets/images/recruit_interview/clock_13.png\" alt=\"\"></p>\n\t\t\t\t\t<p><span>18:00</span><span>事務作業、面接</span></p>\n\t\t\t\t</div>\n\t\t\t\t<div>\n\t\t\t\t\t<p><img src=\"/assets/images/recruit_interview/clock_15.png\" alt=\"\"></p>\n\t\t\t\t\t<p><span>19:00</span><span>食事</span></p>\n\t\t\t\t</div>\n\t\t\t\t<div>\n\t\t\t\t\t<p><img src=\"/assets/images/recruit_interview/clock_23.png\" alt=\"\"></p>\n\t\t\t\t\t<p><span>23:00</span><span>閉店作業</span></p>\n\t\t\t\t</div>\n\t\t\t\t<div>\n\t\t\t\t\t<p><img src=\"/assets/images/recruit_interview/clock_01.png\" alt=\"\"></p>\n\t\t\t\t\t<p><span>24:00</span><span>終礼</span></p>\n\t\t\t\t</div>\n\t\t\t\t<div>\n\t\t\t\t\t<p><img src=\"/assets/images/recruit_interview/clock_02.png\" alt=\"\"></p>\n\t\t\t\t\t<p><span>24:30</span><span>帰宅</span></p>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\t</div>\n</section>\n<!-- .recruit_interview_schedlue -->\n<section class=\"recruit_index_interview separater\" id=\"#recruit_new-graduate_interview\">\n\t<div>\n\t\t<h2><span>社員インタビュー</span></h2>\n\t\t<ul>\n<li><a href=\"/recruit_interview/staff1/\"><img src=\"/assets/images/recruit_index_interview/staff1.jpg\" alt=\"\" /><span>マネージャー</span></a></li>\n<li><a href=\"/recruit_interview/staff2/\"><img src=\"/assets/images/recruit_index_interview/staff2.jpg\" alt=\"\" /><span>キャスト</span></a></li>\n<li><a href=\"/recruit_interview/staff3/\"><img src=\"/assets/images/recruit_index_interview/staff3.jpg\" alt=\"\" /><span>営業本部 本部長</span></a></li>\n</ul>\n\n\t</div>\n</section>\n<!-- .recruit_index_interview -->\n<p><a href=\"/recruit_new-graduate_entry\">エントリーする</a></p>\n<footer>\n  <div>\n\t    <p><img src=\"/assets/images/footer_image.svg\" alt=\"株式会社 サンエイ\" /></p>\n  \t<p><a href=\"/privacy/\">個人情報保護方針</a></p>\n\t    <address>&copy;2026 Sanei. Co., Ltd All rights reserved.</address>\n  <div>\n</footer>\n\n</body>\n</html>","finalUrl":"https://sanei-nt.co.jp/recruit_interview/staff1/","rendered":false,"_cachedAt":"2026-06-22T20:47:34.782Z"}