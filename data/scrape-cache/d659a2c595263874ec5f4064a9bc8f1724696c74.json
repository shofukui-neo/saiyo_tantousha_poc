{"url":"https://www.bml-medicalworks.co.jp/recruit/","html":"<!DOCTYPE html>\r\n<html lang=\"ja\">\r\n<head>\r\n  <script src=\"https://www.baitoru.com/noscreen/adobe/fpid\" async></script>\r\n  <meta charset=\"utf-8\">\r\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1, shrink-to-fit=no\">\r\n  <title>採用情報｜（株）BMLメディカルワークス　川越</title>\r\n  <meta name=\"description\" content=\"治験用試験管キット作製のパイオニア企業、株式会社BMLメディカルワークスの採用情報です。\">\r\n  <meta name=\"keywords\" content=\"BML,メディカルワークス,川越,的場,パート,アルバイト,主婦,軽作業\">\r\n  <meta property=\"og:type\" content=\"website\" />\r\n  <meta property=\"og:site_name\" content=\"バイトル\" />\r\n  <meta property=\"og:title\" content=\"採用情報｜（株）BMLメディカルワークス　川越\" />\r\n  <meta property=\"og:description\" content=\"治験用試験管キット作製のパイオニア企業、株式会社BMLメディカルワークスの採用情報です。\" />\r\n  <meta property=\"og:image\" content=\"**************\" />\r\n  <meta property=\"og:url\" content=\"https://www.baitoru.com/op447782/\" />\r\n  <meta property=\"fb:app_id\" content=\"137840546292550\" />\r\n\r\n  <!-- 「xxxxx」の部分にコンプナンバーを入力 -->\r\n  <link rel=\"canonical\" href=\"./index.html\"/>\r\n\r\n  <!-- CSS & Java -->\r\n  <link href=\"./css/style.css\" rel=\"stylesheet\">\r\n  <link href=\"./css/style_smp.css\" rel=\"stylesheet\">\r\n  <link href=\"./css/slick.css\" rel=\"stylesheet\">\r\n  <link href=\"./css/slick-theme.css\" rel=\"stylesheet\">\r\n  <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\">\r\n  <link href=\"https://fonts.googleapis.com/css2?family=Noto%20Sans%20JP:wght@300;400;500;700&display=swap\" rel=\"stylesheet\">\r\n  <link href=\"https://fonts.googleapis.com/icon?family=Material%20Icons\" rel=\"stylesheet\">\r\n  <script src=\"https://code.jquery.com/jquery-2.1.1.min.js\"></script>\r\n  <script src=\"./js/slick.min.js\"></script>\r\n  <script src=\"./js/common.js\"></script>\r\n  <script>\r\n  $(function() {\r\n    $('.slider').slick({\r\n      autoplay: true,\r\n      autoplaySpeed: 3000,\r\n      speed: 1000,\r\n      fade: true,\r\n      pauseOnHover: false,\r\n      pauseOnFocus: false,\r\n    });\r\n  });\r\n  </script>\r\n\r\n  <!-- Adobe Dynamic Tag Manager -->\r\n  <script src=\"https://assets.adobedtm.com/launch-EN055d6810cc3a446a8e6d54d510448a5f.min.js\" async></script>\r\n  <!-- Adobe Dynamic Tag Manager // -->\r\n</head>\r\n\r\n<body>\r\n  <!-- Google Tag Manager -->\r\n  <noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-N5QJZZ\"\r\n  height=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\r\n  <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\r\n  new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\r\n  j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\r\n  '//www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\r\n  })(window,document,'script','dataLayer','GTM-N5QJZZ');</script>\r\n  <!-- End Google Tag Manager -->\r\n\r\n  <!-- コンテンツ作成開始 -->\r\n\r\n  <div id=\"contents\">\r\n    <div id=\"wrapper\">\r\n\r\n      <div class=\"cont01\">\r\n        <div class=\"cont01_top\">\r\n          <h1>株式会社BMLメディカルワークス　医療用器材等の作製・供給サービス</h1>\r\n        </div>\r\n        <!-- cont01_top -->\r\n        <div class=\"cont01_box\">\r\n          <div class=\"cont01_box_left\">\r\n            <a href=\"https://www.bml-medicalworks.co.jp/\">\r\n              <img src=\"./images/header_logo.png\" alt=\"（株）BMLメディカルワークス\">\r\n            </a>\r\n          </div>\r\n          <!-- cont01_box_left -->\r\n          <div class=\"cont01_box_right\">\r\n            <div class=\"pc_menu\">\r\n              <ul>\r\n                <li><a href=\"https://www.bml-medicalworks.co.jp/\">HOME</a></li>\r\n                <li><a href=\"https://www.bml-medicalworks.co.jp/company.html\">会社案内</a></li>\r\n                <li><a href=\"https://www.bml-medicalworks.co.jp/president.html\">代表あいさつ</a></li>\r\n                <li><a href=\"./index.html\" style=\"color:#338cd1\">採用情報</a></li>\r\n                <li><a href=\"https://www.bml-medicalworks.co.jp/contact.php\">お問い合わせ</a></li>\r\n              </ul>\r\n            </div>\r\n            <!-- pc_menu -->\r\n            <div class=\"sp_menu\">\r\n              <img src=\"./images/menu_btn.png\"alt=\"\">\r\n            </div>\r\n          </div>\r\n          <!-- cont01_box_right -->\r\n        </div>\r\n        <!-- cont01_box -->\r\n\r\n        <div class=\"menu\">\r\n          <ul>\r\n            <li><a href=\"https://www.bml-medicalworks.co.jp/\"></a>HOME</li>\r\n            <li><a href=\"https://www.bml-medicalworks.co.jp/company.html\"></a>会社案内</li>\r\n            <li><a href=\"https://www.bml-medicalworks.co.jp/president.html\"></a>代表あいさつ</li>\r\n            <li style=\"color:#338cd1\"><a href=\"./index.html\"></a>採用情報</li>\r\n            <li><a href=\"https://www.bml-medicalworks.co.jp/contact.php\"></a>お問い合わせ</li>\r\n          </ul>\r\n        </div>\r\n      </div>\r\n      <!-- cont01 -->\r\n\r\n      <div class=\"cont02\">\r\n        <div class=\"cont02_box cont_box\">\r\n          <p class=\"top_copy\">かざらず、素顔で。<br>いつもの私でいられる場所</p>\r\n          <ul class=\"slider\">\r\n            <li><img src=\"./images/slider1.png\" alt=\"\"></li>\r\n            <li><img src=\"./images/slider2.png\" alt=\"\"></li>\r\n            <li><img src=\"./images/slider3.png\" alt=\"\"></li>\r\n            <li><img src=\"./images/slider4.png\" alt=\"\"></li>\r\n          </ul>\r\n          <!-- slider -->\r\n          <p class=\"osae\">医療業界で使用される、<br class=\"sp\">治験用試験管キットの組み立てのお仕事。<br>指示書に従って、シール貼り・袋詰め<br class=\"sp\">・検品・発送手続きまで。<br class=\"sp\"><br>もくもくと自分のペースで<br class=\"sp\">進められるのがいいところ。<br>ムリせずはたらけるちょうどいい職場です。</p>\r\n        </div>\r\n        <!-- cont02_box -->\r\n      </div>\r\n      <!-- cont02 -->\r\n\r\n      <div class=\"search_btn\">\r\n        <a href=\"https://www.baitoru.com/op447782/alist/\"></a>\r\n        <p>お仕事をみる</p>\r\n      </div>\r\n      <!-- search_btn -->\r\n\r\n      <div class=\"cont03\">\r\n\r\n        <div class=\"cont03_line\">\r\n          <img src=\"./images/back_line_top1.png\" alt=\"\">\r\n        </div>\r\n        <!-- cont03_line -->\r\n\r\n        <div class=\"cont03_box\">\r\n          <div class=\"cont03_box_top\">\r\n            <div id=\"video1\">\r\n\t\t\t\t\t\t\t<div id=\"play_button1\"></div>\r\n\t\t\t\t\t\t</div>\r\n            <div class=\"video_text1\">\r\n              <p>まいにち味わえる<br>ちょっとした達成感</p>\r\n              <p>お仕事は、治験に使われる試験管キットの作製。<br>シールを貼ったり、袋詰めをしたり。<br>てきぱき、もくもくと進めます。<br>ひとつのキットが完成したときは<br>やっとできた！という喜びも。</p>\r\n            </div>\r\n            <!-- video_text1 -->\r\n          </div>\r\n          <!-- cont03_box_top -->\r\n          <div class=\"cont03_box_bottom\">\r\n            <div class=\"video_text2\">\r\n              <p>大人数だけど、<br>一人ひとりを見てくれる</p>\r\n              <p>9割が女性ということもあり<br>なんでも話しやすい雰囲気。<br>何か悩み事があっても、リーダーや社員が<br>一人ひとりの話を聞いてくれます。</p>\r\n            </div>\r\n            <div id=\"video2\">\r\n              <div id=\"play_button2\"></div>\r\n            </div>\r\n          </div>\r\n          <!-- cont03_box_bottom -->\r\n        </div>\r\n        <!-- cont03_box -->\r\n\r\n        <div class=\"cont03_line\">\r\n          <img src=\"./images/back_line_bottom1.png\" alt=\"\">\r\n        </div>\r\n        <!-- cont03_line -->\r\n\r\n      </div>\r\n      <!-- cont03 -->\r\n\r\n      <div class=\"cont04\">\r\n        <div class=\"cont_title\">\r\n          <h2>ムリなくできる理由</h2>\r\n        </div>\r\n        <!-- cont_title -->\r\n\r\n        <div class=\"cont04_box cont_box\">\r\n\r\n          <div class=\"cont04_item\">\r\n            <div class=\"cont04_item_left\">\r\n              <img src=\"./images/reason1.png\" alt=\"\">\r\n            </div>\r\n            <!-- cont04_item_left -->\r\n            <div class=\"cont04_item_right\">\r\n              <p>はじめの2ヵ月は研修期間</p>\r\n              <p>研修担当の社員がイチから流れをご説明。<br>すぐに一人前に、なんてことは言いません。<br>まずはゆっくり、正確に始めましょう。</p>\r\n            </div>\r\n            <!-- cont04_item_right -->\r\n          </div>\r\n          <!-- cont04_item -->\r\n\r\n          <div class=\"cont04_item\">\r\n            <div class=\"cont04_item_left\">\r\n              <img src=\"./images/reason2.png\" alt=\"\">\r\n            </div>\r\n            <!-- cont04_item_left -->\r\n            <div class=\"cont04_item_right\">\r\n              <p>ふだんの服装で大丈夫</p>\r\n              <p>ラクな格好で来てくださいね。<br>いい意味で気を抜いて大丈夫なんです。</p>\r\n            </div>\r\n            <!-- cont04_item_right -->\r\n          </div>\r\n          <!-- cont04_item -->\r\n\r\n          <div class=\"cont04_item\">\r\n            <div class=\"cont04_item_left\">\r\n              <img src=\"./images/reason3.png\" alt=\"\">\r\n            </div>\r\n            <!-- cont04_item_left -->\r\n            <div class=\"cont04_item_right\">\r\n              <p>座り仕事で、体にやさしい</p>\r\n              <p>自分のデスクで作業ができるから、<br>疲れを感じにくいのがいいところ。</p>\r\n            </div>\r\n            <!-- cont04_item_right -->\r\n          </div>\r\n          <!-- cont04_item -->\r\n\r\n        </div>\r\n        <!-- cont04_box -->\r\n\r\n      </div>\r\n      <!-- cont04 -->\r\n\r\n      <div class=\"cont05\">\r\n\r\n        <div class=\"cont05_line\">\r\n          <img src=\"./images/back_line_top2.png\" alt=\"\">\r\n        </div>\r\n        <!-- cont05_line -->\r\n\r\n        <div class=\"cont05_box\">\r\n\r\n          <div class=\"cont_title\">\r\n            <h2>うれしい福利厚生も</h2>\r\n          </div>\r\n          <!-- cont_title -->\r\n\r\n          <ul class=\"cont_box\">\r\n\r\n            <li>\r\n              <img src=\"./images/benefit1.png\" alt=\"\">\r\n              <p>年2回の健康診断あり</p>\r\n              <p>婦人科検診も希望で受けられます。<br>どちらも無料なんです。</p>\r\n            </li>\r\n\r\n            <li>\r\n              <img src=\"./images/benefit2.png\" alt=\"\">\r\n              <p>食堂・ラウンジあり</p>\r\n              <p>お仕事のあいまに、ほっと一息。<br>コーヒー・紅茶が飲めます。</p>\r\n            </li>\r\n\r\n            <li>\r\n              <img src=\"./images/benefit3.png\" alt=\"\">\r\n              <p>各種教室あり</p>\r\n              <p>ヨガ・フラダンス・書道など。<br>趣味も増やせるチャンスがあります。</p>\r\n            </li>\r\n\r\n          </ul>\r\n        </div>\r\n        <!-- cont05_box -->\r\n\r\n        <div class=\"cont05_line\">\r\n          <img src=\"./images/back_line_bottom2.png\" alt=\"\">\r\n        </div>\r\n        <!-- cont05_line -->\r\n\r\n      </div>\r\n      <!-- cont05 -->\r\n\r\n      <div class=\"cont06\">\r\n\r\n        <p>みんな自然体ではたらいているので、<br>あなたもふだん通りのまま<br class=\"sp\">来てくれたらうれしいです。</p>\r\n\r\n        <div class=\"search_btn\">\r\n          <a href=\"https://www.baitoru.com/op447782/alist/\"></a>\r\n          <p>お仕事をみる</p>\r\n        </div>\r\n        <!-- search_btn -->\r\n\r\n        <a href=\"https://www.bml-medicalworks.co.jp/privacy.html\">プライバシーポリシーはコチラ</a>\r\n\r\n      </div>\r\n      <!-- cont06 -->\r\n\r\n      <div class=\"cont07\">\r\n\r\n        <div class=\"cont_title\">\r\n          <h2>よくあるご質問</h2>\r\n        </div>\r\n        <!-- cont_title -->\r\n\r\n        <div class=\"cont07_box cont_box\">\r\n\r\n          <div class=\"qa_box\">\r\n            <div class=\"qa_q\">\r\n              <p>扶養内で働くことは可能でしょうか？</p>\r\n            </div>\r\n            <!-- qa_q -->\r\n            <div class=\"qa_a\">\r\n              <p>当社の勤務時間は、9：00～17：00でお願いしております。時短は認めていませんので、扶養内の勤務はできません。</p>\r\n            </div>\r\n            <!-- qa_a -->\r\n          </div>\r\n          <!-- qa_box -->\r\n\r\n          <div class=\"qa_box\">\r\n            <div class=\"qa_q\">\r\n              <p>どんな人に適性がありますか？</p>\r\n            </div>\r\n            <!-- qa_q -->\r\n            <div class=\"qa_a\">\r\n              <p>作業では一定のスピードと正確性が要求されており、また使用する指示書は細かいチェック項目があるので、こつこつとした作業が好きな方・得意な方に向いています。<br>もちろん研修がありますので最初から完ぺきに出来なくても大丈夫ですが、面接時に簡単な作業テストを行い、確認させていただきます。</p>\r\n            </div>\r\n            <!-- qa_a -->\r\n          </div>\r\n          <!-- qa_box -->\r\n\r\n          <div class=\"qa_box\">\r\n            <div class=\"qa_q\">\r\n              <p>男性も応募してもよろしいでしょうか？</p>\r\n            </div>\r\n            <!-- qa_q -->\r\n            <div class=\"qa_a\">\r\n              <p>勿論、男女問わずの応募を歓迎しております。<br>手先の器用な方、細かい作業が好きな方が活躍できます。</p>\r\n            </div>\r\n            <!-- qa_a -->\r\n          </div>\r\n          <!-- qa_box -->\r\n\r\n          <div class=\"qa_box\">\r\n            <div class=\"qa_q\">\r\n              <p>出産や育児に関する制度はありますか？</p>\r\n            </div>\r\n            <!-- qa_q -->\r\n            <div class=\"qa_a\">\r\n              <p>労働法規に従い、休暇が取得できます。</p>\r\n            </div>\r\n            <!-- qa_a -->\r\n          </div>\r\n          <!-- qa_box -->\r\n\r\n          <div class=\"qa_box\">\r\n\r\n            <div class=\"qa_q\">\r\n              <p>子供の学校行事があるときは、<br class=\"sp\">休暇がとれますか？</p>\r\n            </div>\r\n            <!-- qa_q -->\r\n            <div class=\"qa_a\">\r\n              <p>事前に、所属長の承認のうえ、休暇をとる事が可能です。</p>\r\n            </div>\r\n            <!-- qa_a -->\r\n\r\n          </div>\r\n          <!-- qa_box -->\r\n\r\n          <div class=\"qa_box\">\r\n            <div class=\"qa_q\">\r\n              <p>契約社員・正社員の登用はありますか？</p>\r\n            </div>\r\n            <!-- qa_q -->\r\n            <div class=\"qa_a\">\r\n              <p>登用制度があります。技能や総合力を判断し、契約社員、正社員の登用についても積極的に進めており、アルバイトから契約社員を経て正社員、そして管理職になった女性職員もいます。<br>これからも本人のやる気と適性を見て、今まで以上に登用していく予定です。</p>\r\n            </div>\r\n            <!-- qa_a -->\r\n          </div>\r\n          <!-- qa_box -->\r\n\r\n        </div>\r\n        <!-- cont07_box -->\r\n\r\n      </div>\r\n      <!-- cont07 -->\r\n\r\n      <div class=\"cont08\">\r\n\r\n        <div class=\"cont_title\">\r\n          <h2>MAP</h2>\r\n        </div>\r\n        <!-- cont_title -->\r\n\r\n        <div class=\"cont08_box\">\r\n          <img src=\"./images/map.png\" alt=\"\">\r\n        </div>\r\n        <!-- cont08_box -->\r\n\r\n      </div>\r\n      <!-- cont08 -->\r\n\r\n      <div class=\"cont09\">\r\n        <p>Copyright© BMLメディカルワークス,INC All Rights Reserved.</p>\r\n      </div>\r\n      <!-- cont09 -->\r\n\r\n      <div id=\"page_top\"><a href=\"#\"><img src=\"./images/ret_bttn.png\" alt=\"\"></a></div>\r\n\r\n    </div>\r\n    <!-- wrapper -->\r\n  </div>\r\n  <!-- contents -->\r\n\r\n  <!-- コンテンツ作成終了 -->\r\n\r\n  <!-- START Adobe Analytics -->\r\n  <script type=\"text/javascript\">\r\n    var analyticsData={\r\n        \"channel\" : \"静的_企業ページ(ASP)\",\r\n        \"prop5\"   : \"企業ページ(ASP)\"\r\n    };\r\n  </script>\r\n  <!-- END Adobe Analytics -->\r\n</body>\r\n</html>\r\n","finalUrl":"https://www.bml-medicalworks.co.jp/recruit/","rendered":false,"_cachedAt":"2026-06-22T20:27:15.096Z"}