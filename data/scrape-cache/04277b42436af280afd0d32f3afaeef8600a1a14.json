{"url":"https://www.nito.co.jp/saiyo/career/","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n\t<script type=\"module\" src=\"/saiyo/files/js/career.astro_astro_type_script_index_0_lang.js\"></script>\n\n\t<head>\n<!-- Google Tag Manager -->\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n})(window,document,'script','dataLayer','GTM-NQC8VNN');</script>\n<!-- End Google Tag Manager -->\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>キャリア採用 | 日東工業株式会社</title>\n  <meta name=\"description\" content=\"日東工業株式会社のキャリア採用サイトです。日東工業は人材を幅広く募集し、通常のキャリア人材募集に加えてリファラル人材・カムバック人材・障がい者人材それぞれの応募要項を掲載しております。\">\n  <meta property=\"og:title\" content=\"日東工業株式会社\">\n  <meta property=\"og:type\" content=\"website\">\n  <meta property=\"og:url\" content=\"https://www.nito.co.jp/saiyo/career/\">\n\n<meta property=\"og:image\" content=\"/saiyo/files/img/career/ogp_career.jpg\">\n  \n  <meta property=\"og:site_name\" content=\"日東工業株式会社\">\n  <meta property=\"og:description\" content=\"日東工業株式会社のキャリア採用サイトです。日東工業は人材を幅広く募集し、通常のキャリア人材募集に加えてリファラル人材・カムバック人材・障がい者人材それぞれの応募要項を掲載しております。\">\n\t<link rel=\"icon\" type=\"image/svg+xml\" href=\"/saiyo/favicon.png\">\n  <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n  <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n  <link href=\"https://fonts.googleapis.com/css2?family=Jost:ital,wght@0,100..900;1,100..900&family=Noto+Sans+JP:wght@100..900&family=Raleway:ital,wght@0,100..900;1,100..900&family=Zen+Maru+Gothic:wght@300;400;500;700;900&display=swap\" rel=\"stylesheet\">\n  <link rel=\"stylesheet\" href=\"/saiyo/files/css/reset.min.css\">\n\t<script type=\"module\" src=\"/saiyo/files/js/head.astro_astro_type_script_index_0_lang.js\"></script>\n\n<link rel=\"stylesheet\" href=\"/saiyo/files/css/global.css\">\n<link rel=\"stylesheet\" href=\"/saiyo/files/css/career.css\">\n<link rel=\"stylesheet\" href=\"/saiyo/files/css/career-1.css\"><script type=\"module\" src=\"/saiyo/files/js/page.js\"></script></head>\n\n\t<body id=\"pagetop\">\n\t\t<div id=\"bgvideo\">\n\t\t\t<video class=\"-pc\" src=\"/saiyo/files/img/common/bg.mp4\" muted loop autoplay playsinline poster=\"/saiyo/files/img/common/video-poster.png\"></video>\n      <video class=\"-sp\" src=\"/saiyo/files/img/common/bg_sp.mp4\" muted loop autoplay playsinline poster=\"/saiyo/files/img/common/video-poster.png\"></video>\n\t\t</div>\n\n\t\t<header id=\"career_header\">\n  <div class=\"container menu_overlay\">\n    <div class=\"inner\">\n    <div>\n      <div class=\"logo_group\">\n        <a href=\"/saiyo/\">\n          <img class=\"logo\" src=\"/saiyo/files/img/common/logo.svg\" width=\"129\" height=\"30\" alt=\"Nito 日東工業\">\n          中途採用サイト\n        </a>\n      </div>\n    </div>\n\n      <nav class=\"site-group\">\n         <ul class=\"list\">\n           <li class=\"item\">\n             <a class=\"sitelink\" href=\"/saiyo/newgraduate/\">\n               <span class=\"txt\">新卒採用</span>\n             </a>\n           </li>\n           <li class=\"item\">\n             <a class=\"sitelink\" href=\"/saiyo/high-school/\">\n               <span class=\"txt\">高校生採用</span>\n             </a>\n           </li>\n           <li class=\"item\">\n             <div class=\"sitelink megamenu_btn\">\n               <span class=\"txt\">キャリア採用</span>\n             </div>\n              <div class=\"megamenu -sp\">\n                <div class=\"megamenu_group\">\n                  <a class=\"megamenu_link\" href=\"/saiyo/career/\">キャリア採用</a>\n                  <a class=\"megamenu_link\" href=\"/saiyo/career/#anchor02\">社員紹介採用</a>\n                  <a class=\"megamenu_link\" href=\"/saiyo/career/#anchor03\">カムバック採用</a>\n                  <a class=\"megamenu_link\" href=\"/saiyo/career/#anchor04\">障がい者採用</a>\n                </div>\n              </div>\n           </li>\n         </ul>\n      </nav>\n\n      <div class=\"menu-btn -sp\" id=\"menu-btn\">\n        <span class=\"bar\"></span>\n        <span class=\"bar\"></span>\n        <img class=\"airplane\" src=\"/saiyo/files/img/common/menu-airplane.svg\" width=\"22\" height=\"22\" alt=\"メニューを開く\">\n      </div>\n    </div>\n    <div class=\"megamenu -pc\">\n      <div class=\"megamenu_group\">\n        <a class=\"megamenu_link\" href=\"/saiyo/career/\">キャリア採用</a>\n        <a class=\"megamenu_link\" href=\"/saiyo/career/#anchor02\">社員紹介採用</a>\n        <a class=\"megamenu_link\" href=\"/saiyo/career/#anchor03\">カムバック採用</a>\n        <a class=\"megamenu_link\" href=\"/saiyo/career/#anchor04\">障がい者採用</a>\n      </div>\n    </div>\n  </div>\n\n</header>\n\t\t<main>\n\t\t\t<section class=\"fv\">\n\t\t\t\t<div class=\"inner\">\n          <picture class=\"fv_img\">\n            <source media=\"(max-width: 768px)\" srcset=\"/saiyo/files/img/career/fv-image_sp.jpg\">\n            <img src=\"/saiyo/files/img/career/fv-image_pc.jpg\" width=\"790\" height=\"419\" alt=\"\">\n          </picture>\n          <h1 class=\"fv_copy\">\n\t\t\t\t\t\tCareer<br>\n\t\t\t\t\t\tRecruiting<br>\n\t\t\t\t\t\tInformation\n          </h1>\n        </div>\n\n\t\t\t\t<div class=\"slider_area\">\n\t\t\t\t\t<div id=\"fv_slider\" class=\"splide\">\n\t\t\t\t\t\t<div class=\"splide__track\">\n\t\t\t\t\t\t\t<ul class=\"splide__list\">\n\t\t\t\t\t\t\t\t<li class=\"splide__slide\">Career Recruiting Information</li>\n\t\t\t\t\t\t\t\t<li class=\"splide__slide\">Career Recruiting Information</li>\n\t\t\t\t\t\t\t\t<li class=\"splide__slide\">Career Recruiting Information</li>\n\t\t\t\t\t\t\t</ul>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n         </div>\n\n\t\t\t</section>\n\t\t\t<div class=\"page_container\">\n\t\t\t\t<section class=\"about -fadeUp\" id=\"anchor01\">\n          <h2 class=\"conts_ttl\"><span class=\"en\">Career Recruitment</span>キャリア採用</h2>\n\t\t\t\t\t<div class=\"conts_group\">\n\t\t\t\t\t\t<h3 class=\"heading\">応募方法</h3>\n\t\t\t\t\t\t<p class=\"text\">\n\t\t\t\t\t\t\t日東工業はキャリア採用を積極的に行っています。<br>\n\t\t\t\t\t\t\tご希望の方は 以下の応募書類（職務経歴書内）に「希望職種」を書いてENTRYよりお送りください。<br>\n\t\t\t\t\t\t\t※特に希望がない場合は、ご経歴に合った職種をこちらからご提案します\n\t\t\t\t\t\t</p>\n\t\t\t\t\t</div>\n\t\t\t\t\t<div class=\"conts_group\">\n\t\t\t\t\t\t<h3 class=\"heading\">応募書類</h3>\n\t\t\t\t\t\t<p class=\"text\">\n\t\t\t\t\t\t\t1）履歴書<br>\n\t\t\t\t\t\t\t2）職務経歴書<br>\n\t\t\t\t\t\t\t※弊社にご提出いただいた個人情報については、採用選考の目的にのみ利用いたします。<br>\n\t\t\t\t\t\t\t※応募書類は返却いたしません。あらかじめご了承ください。\n\t\t\t\t\t\t</p>\n\t\t\t\t\t</div>\n        </section>\n\t\t\t\t<section class=\"about -fadeUp\" id=\"anchor02\">\n          <h2 class=\"conts_ttl\"><span class=\"en\">Referral Recruitment</span>社員紹介採用</h2>\n\t\t\t\t\t<div class=\"conts_group\">\n\t\t\t\t\t\t<h3 class=\"heading\">社員紹介採用について</h3>\n\t\t\t\t\t\t<p class=\"text\">\n\t\t\t\t\t\t\t現在日東工業に就業している社員から紹介・推薦された方専用の採用手法です。<br>\n\t\t\t\t\t\t\t当社では親族やご友人含め既存社員からのご紹介を歓迎しております。<br>\n\t\t\t\t\t\t\t社員からの紹介により当社に興味をお持ちいただけましたら、企業情報をご確認ください。<br>\n\t\t\t\t\t\t\t応募を希望される方は、下記ENTRYから応募書類のご提出をお願いいたします。\n\t\t\t\t\t\t</p>\n\t\t\t\t\t</div>\n\t\t\t\t\t<div class=\"conts_group\">\n\t\t\t\t\t\t<h3 class=\"heading\">応募書類</h3>\n\t\t\t\t\t\t<p class=\"text\">\n\t\t\t\t\t\t\t1）履歴書<br>\n\t\t\t\t\t\t\t2）職務経歴書（必ず紹介者の氏名をご記載ください）<br>\n\t\t\t\t\t\t\t※弊社にご提出いただいた個人情報については、採用選考の目的にのみ利用いたします。<br>\n\t\t\t\t\t\t\t※応募書類は返却いたしません。あらかじめご了承ください。\n\t\t\t\t\t\t</p>\n\t\t\t\t\t</div>\n        </section>\n\t\t\t\t<section class=\"about -fadeUp\" id=\"anchor03\">\n          <h2 class=\"conts_ttl\"><span class=\"en\">Come Back Recruitment</span>カムバック採用</h2>\n\t\t\t\t\t<div class=\"conts_group\">\n\t\t\t\t\t\t<h3 class=\"heading\">募集内容</h3>\n\t\t\t\t\t\t<p class=\"text\">\n\t\t\t\t\t\t\t過去に日東工業で勤務したことがある方専用の応募方法です。<br>\n\t\t\t\t\t\t\t結婚・出産などのやむを得ない理由や、他社で身につけた経験やスキルを活かしてもう一度日東工業で正社員としてご活躍いただける方を募集しております。<br>\n\t\t\t\t\t\t\t下記応募資格をご確認の上、応募書類を下記ENTRYよりお送りください。\n\t\t\t\t\t\t</p>\n\t\t\t\t\t</div>\n\t\t\t\t\t<div class=\"conts_group\">\n\t\t\t\t\t\t<h3 class=\"heading\">応募資格</h3>\n\t\t\t\t\t\t<p class=\"text\">\n\t\t\t再び日東工業で働く意欲がある方\n\t\t\t\t\t\t</p>\n\t\t\t\t\t</div>\n\t\t\t\t\t<div class=\"conts_group\">\n\t\t\t\t\t\t<h3 class=\"heading\">応募書類</h3>\n\t\t\t\t\t\t<p class=\"text\">\n\t\t\t\t\t\t\t1）履歴書<br>\n\t\t\t\t\t\t\t2）職務経歴書（カムバック採用応募とご記載ください）<br>\n\t\t\t\t\t\t\t※弊社にご提出いただいた個人情報については、採用選考の目的にのみ利用いたします。<br>\n\t\t\t\t\t\t\t※応募書類は返却いたしません。あらかじめご了承ください。\n\t\t\t\t\t\t</p>\n\t\t\t\t\t</div>\n        </section>\n\t\t\t\t<section class=\"about -fadeUp\" id=\"anchor04\">\n          <h2 class=\"conts_ttl\"><span class=\"en\">Challenged Recruitment</span>障がい者採用</h2>\n\t\t\t\t\t<div class=\"conts_group\">\n\t\t\t\t\t\t<h3 class=\"heading\">募集内容</h3>\n\t\t\t\t\t\t<p class=\"text\">\n\t\t\t\t\t\t\t日東工業は多様性を尊重し、誰もが活躍できる職場環境づくりに取り組んでいます。<br>\n\t\t\t\t\t\t\t通年で障がい者採用も実施しておりますので、<br>\n\t\t\t\t\t\t\tご希望の方は以下応募書類をENTRYよりお送りください。\n\t\t\t\t\t\t</p>\n\t\t\t\t\t</div>\n\t\t\t\t\t<div class=\"conts_group\">\n\t\t\t\t\t\t<h3 class=\"heading\">応募書類</h3>\n\t\t\t\t\t\t<p class=\"text\">\n\t\t\t\t\t\t\t1）履歴書<br>\n\t\t\t\t\t\t\t2）職務経歴書<br>\n\t\t\t\t\t\t\t※弊社にご提出いただいた個人情報については、採用選考の目的にのみ利用いたします。<br>\n\t\t\t\t\t\t\t※応募書類は返却いたしません。あらかじめご了承ください。<br>\n\t\t\t\t\t\t\t3）障がい者手帳のコピー\n\t\t\t\t\t\t</p>\n\t\t\t\t\t</div>\n        </section>\n\n\t\t\t\t<div class=\"block -fadeUp\">\n\t\t\t\t\t<section class=\"flow -fadeUp\" id=\"anchor05\">\n          <h2 class=\"conts_ttl\"><span class=\"en\">Flow</span>採用フロー</h2>\n\t\t\t\t\t<ul class=\"list\">\n\t\t\t\t\t\t<li class=\"flow_group -fadeUp\">\n\t\t\t\t\t\t<h3 class=\"heading\">エントリー・応募書類提出</h3>\n\t\t\t\t\t\t<p class=\"text\">下記ENTRYからメールにてご応募お願いします。メールに履歴書・職務経歴書を添付してお送りください。</p>\n\t\t\t\t\t</li>\n\t\t\t\t\t<li class=\"flow_group -fadeUp\">\n\t\t\t\t\t\t<h3 class=\"heading\">書類選考</h3>\n\t\t\t\t\t\t<p class=\"text\">ご応募いただいた情報をもとに書類選考を行います。<br>\n\t\t\t\t\t\t\t結果につきましては、2週間以内にメールにてご連絡いたします。（応募者が多数の場合は選考に時間がかかることがございます。ご了承ください）</p>\n\t\t\t\t\t</li>\n\t\t\t\t\t<li class=\"flow_group -fadeUp\">\n\t\t\t\t\t\t<h3 class=\"heading\">面接・適性検査</h3>\n\t\t\t\t\t\t<p class=\"text\">職種により面接回数の増減があります。（1～2回）<br>\n\t\t\t\t\t\t\t結果につきましては、合否に関わらず2週間以内にメールにてご連絡いたします。</p>\n\t\t\t\t\t</li>\n\t\t\t\t\t<li class=\"flow_group -fadeUp\">\n\t\t\t\t\t\t<h3 class=\"heading\">内定</h3>\n\t\t\t\t\t\t<p class=\"text\">採用内定の方に、書面にて採用条件を提示いたします。</p>\n\t\t\t\t\t</li>\n\t\t\t\t\t</ul>\n\n        </section>\n\t\t\t\t<section class=\"faq -fadeUp\" id=\"anchor06\">\n          <h2 class=\"conts_ttl\"><span class=\"en\">FAQ</span>よくあるご質問</h2>\n\t\t\t\t\t<div class=\"accordion\">\n\t\t\t\t\t\t<div class=\"q_wrap\">\n\t\t\t\t\t\t\t<p class=\"heading\">Q</p>\n\t\t\t\t\t\t\t<p class=\"text\">年齢・性別・国籍の制限はありますか？</p>\n\t\t\t\t\t\t\t<span class=\"arrow\"></span>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t\t<div class=\"a_wrap\">\n\t\t\t\t\t\t\t<p class=\"text\">制限はありません。応募や選考にあたり、年齢・性別・国籍等は一切問いません。 多様な国籍の方に活躍していただいていますが、職種によりビジネスレベルの日本語能力が必要となる場合があります。また、勤務地は日本となりますので、日本での長期就業を希望される方が対象となります。</p>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t\t<div class=\"accordion\">\n\t\t\t\t\t\t<div class=\"q_wrap\">\n\t\t\t\t\t\t\t<p class=\"heading\">Q</p>\n\t\t\t\t\t\t\t<p class=\"text\">異業種から転職することは可能ですか？</p>\n\t\t\t\t\t\t\t<span class=\"arrow\"></span>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t\t<div class=\"a_wrap\">\n\t\t\t\t\t\t\t<p class=\"text\">もちろん可能です。様々な職務経歴をお持ちの方を積極的に採用しており、 異業種から転職した方も多数活躍しています。</p>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t\t<div class=\"accordion\">\n\t\t\t\t\t\t<div class=\"q_wrap\">\n\t\t\t\t\t\t\t<p class=\"heading\">Q</p>\n\t\t\t\t\t\t\t<p class=\"text\">2つ以上の職種に同時に応募できますか？</p>\n\t\t\t\t\t\t\t<span class=\"arrow\"></span>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t\t<div class=\"a_wrap\">\n\t\t\t\t\t\t\t<p class=\"text\">可能です。これまでのご経験と今後挑戦したいことへの想いを十分に考慮し、弊社のニーズと併せて検討させていただきます。ご経験や想いを伺い、より適した職種があれば弊社からご提案させていただく可能性がございます。</p>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t\t<div class=\"accordion\">\n\t\t\t\t\t\t<div class=\"q_wrap\">\n\t\t\t\t\t\t\t<p class=\"heading\">Q</p>\n\t\t\t\t\t\t\t<p class=\"text\">選考結果の連絡方法を教えてください。</p>\n\t\t\t\t\t\t\t<span class=\"arrow\"></span>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t\t<div class=\"a_wrap\">\n\t\t\t\t\t\t\t<p class=\"text\">履歴書のE-mailアドレス宛に結果のメールを送信いたします。急ぎの場合はお電話することもございますので、繋がりやすい電話番号も記載いただきますようお願いいたします。</p>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t\t<div class=\"accordion\">\n\t\t\t\t\t\t<div class=\"q_wrap\">\n\t\t\t\t\t\t\t<p class=\"heading\">Q</p>\n\t\t\t\t\t\t\t<p class=\"text\">入社後の処遇について教えてください。</p>\n\t\t\t\t\t\t\t<span class=\"arrow\"></span>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t\t<div class=\"a_wrap\">\n\t\t\t\t\t\t\t<p class=\"text\">経験・能力等を考慮のうえ、当社規定により決定いたします。</p>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n        </section>\n\t\t\t\t</div>\n\t\t\t</div>\n\n\t\t\t<div class=\"btn_box\">\n\t\t\t\t<a class=\"entry-btn\" href=\"mailto:saiyo@nito.co.jp\">\n\t\t\t    <span class=\"txt\">ENTRY</span>\n\t\t    </a>\n\t\t\t</div>\n\t\t\t\n\t\t</main>\n\n\t\t<footer>\n  <div class=\"container\">\n    <div class=\"inner\">\n      <div class=\"logo_group\">\n        <a href=\"/saiyo/\">\n              <img class=\"logo\" src=\"/saiyo/files/img/common/logo.svg\" width=\"129\" height=\"30\" alt=\"Nito 日東工業\">\n              <img class=\"site_type -default\" src=\"/saiyo/files/img/common/sitetype01.svg\" width=\"63\" height=\"10\" alt=\"Recruit Site\">\n            </a>\n      </div>\n      <div class=\"block\">\n        <div class=\"outlink_group\">\n          <a class=\"outlink\" href=\"https://www.nito.co.jp/\" target=\"_blank\" rel=\"noopener noreferrer\">コーポレートサイト</a>\n          <a class=\"outlink\" href=\"https://www.nito.co.jp/privacy/\" target=\"_blank\" rel=\"noopener noreferrer\">プライバシーポリシー</a>\n          <a class=\"outlink\" href=\"mailto:saiyo@nito.co.jp\">お問い合わせ</a>\n        </div>\n        <div class=\"sitelink-group\">\n          <a class=\"sitelink\" href=\"/saiyo/newgraduate/\">\n            <span class=\"txt\">新卒採用</span>\n          </a>\n          <a class=\"sitelink\" href=\"/saiyo/high-school/\">\n                <span class=\"txt\">高校生採用</span>\n              </a>\n          <a class=\"sitelink\" href=\"/saiyo/career/\">\n            <span class=\"txt\">キャリア採用</span>\n          </a>\n        </div>\n      </div>\n    </div>\n  </div>\n  <small class=\"copyright\">(c) NITTO KOGYO CORPORATION All Rights Reserved.</small>\n</footer>\n\t</body></html>","finalUrl":"https://www.nito.co.jp/saiyo/career/","rendered":false,"_cachedAt":"2026-06-23T17:57:39.125Z"}