il2\">\n<tr>\n<td class=\"bold\">募集職種 </td>\n<td>交通誘導警備員</td>\n</tr>\n<tr>\n<td class=\"bold\">応募資格 </td>\n<td>年齢、学歴、経験不問　未経験者歓迎<br /><br /><br />普通自動車免許証（免許の無い方も応相談）</td>\n</tr>\n<tr>\n<td class=\"bold\">勤務時間 </td>\n<td>変形１年単位<br />８：００～１７：００<br /><br /><br />休憩時間<br />６０分<br />時間外<br />あり　月１０時間位</td>\n</tr>\n<tr>\n<td class=\"bold\">給与 </td>\n<td>８，０００円～１０，０００円　　　※高齢者に関しては、別途規定あり<br /><br />手当<br />資格手当<br />子供手当<br /><br />月給２００，０００円～（経験等考慮）</td>\n</tr>\n<tr>\n<td class=\"bold\"> 休日・休暇 </td>\n<td>日　他<br />年間休日　１０５日<br />年末年始休暇あり<br /><br /><br /></td>\n</tr>\n<tr>\n<td class=\"bold\"> 福利厚生 </td>\n<td>加入保険<br />雇用　労災　健康　厚生<br /><br />定年制<br />あり　一律　６５歳<br /><br />再雇用<br />あり　７０歳まで<br /><br />独身寮あり　入居可<br />通勤手当　実費支給<br /><br />資格取得サポートあり<br />　※資格取得に必要な費用　全額当社にて負担</td>\n</tr>\n<tr>\n<td class=\"bold\"> 勤務地 </td>\n<td>群馬県内　各地<br /></td>\n</tr>\n</table>\n</td>\n</tr>\n<tr>\n<td>\n<div class=\"saiyou_l\"> 求人No.10020-11132731 <br> 掲載日 2023年07月04日</div>\n<div class=\"saiyou_r clearfix\">\n<ul class=\"btn clearfix\">\n<li>\n<form  action=\"/contact/entry/index.php\" method=\"POST\" target=\"_blank\">\n<input type=\"hidden\" name=\"jobs_name\" value=\"交通誘導員　No.10020-11132731\">\n<input type=\"image\" src=\"/common/images/recruit/btn_entry_off.png\" width=\"250\" height=\"45\" alt=\"応募する\">\n</form>\n</li>\n</ul>\t\n</div>\n</td>\n</tr>\n</table>\n<!--//採用情報詳細--> \n</div>\n<p id=\"return_index\"> <a href=\"/recruit/\"><img src=\"/common/images/btn_back_off.png\" alt=\"戻る\" width=\"160\" height=\"32\"></a> </p>\n</article>\n</div>\n<!-- //main -->\n<div id=\"side\">\n<section>\n<div id=\"pickup\">\n<h2><img src=\"/common/images/top/title_pickup.png\" alt=\"採用情報ピックアップ\" width=\"230\" height=\"40\"></h2>\n<div style=\"border-radius:0 0 10px 10px;\">\n<h3><a href=\"/recruit/000047.html\">交通誘導警備員</a></h3>\n<dl>\n<dt><img src=\"/common/images/icon_place.png\" alt=\"勤務地\" width=\"50\" height=\"18\"></dt>\n<dd>群馬県内　各地<br /></dd>\n</dl>\n\n\n<a href=\"/recruit/\"><img class=\"vam