type=\"checkbox\" name=\"資料請求内容[]\" value=\"自動料金精算システム\" /> 自動料金精算システム<br />\n                    <input type=\"checkbox\" name=\"資料請求内容[]\" value=\"個別料金精算システム\" /> 個別料金精算システム<br />\n                    <input type=\"checkbox\" name=\"資料請求内容[]\" value=\"「ニッシンパーク」\" />「ニッシンパーク」<br />\n                    <input type=\"checkbox\" name=\"資料請求内容[]\" value=\"会社経歴書\" /> 会社経歴書<br />\n                    <input type=\"checkbox\" name=\"資料請求内容[]\" value=\"その他\" /> その他\n                  </td>\n                 </tr>\n                <tr>\n                  <th>御社名<span class=\"red\">※</span></th>\n                  <td><input name=\"御社名_need\" type=\"text\" id=\"御社名\" size=\"30\" class=\"w200\" /></td>\n                </tr>\n                <tr>\n                  <th>部門名</th>\n                  <td><input name=\"部門名\" type=\"text\" id=\"部門名\" size=\"30\" class=\"w200\" /></td>\n                </tr>\n                <tr>\n                  <th>お名前<span class=\"red\">※</span></th>\n                  <td><input name=\"お名前_need\" type=\"text\" id=\"お名前\" size=\"30\" class=\"w200\" /></td>\n                </tr>\n                <tr>\n                  <th>電話番号<span class=\"red\">※</span></th>\n                  <td><input name=\"電話番号_need\" type=\"text\" id=\"電話番号\" size=\"15\" class=\"w200\" />\n                    （半角入力）</td>\n                </tr>\n                <tr>\n                  <th>住所（都道府県）<span class=\"red\">※</span></th>\n                  <td><select size=\"\" name=\"住所（都道府県）_need\"  style=\"margin:5px 5px 5px 10px;\" >\n                      <option value=\"\" selected=\"selected\">リストからお選び下さい</option>\n                      <option value=\"北海道\">北海道</option>\n                      <option value=\"青森県\">青森県</option>\n                      <option value=\"岩手県\">岩手県</option>\n                      <option value=\"宮城県\">宮城県</option>\n                      <option value=\"秋田県\">秋田県</option>\n                      <option value=\"山形県\">山形県</option>\n              