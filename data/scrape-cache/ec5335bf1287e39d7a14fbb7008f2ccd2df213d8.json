><li class=\"c-header__nav--item\"><a href=\"./cases\">導入事例</a></li><li class=\"c-header__nav--item\"><a href=\"./download\">資料</a></li><li class=\"c-header__nav--item\"><a href=\"./company\">会社情報</a></li><li class=\"c-header__nav--item\"><a href=\"./recruit\">採用</a></li><li class=\"c-header__nav--item\"><a href=\"./contact\">お問い合わせ</a></li>        </ul>\r\n      </nav>\r\n    </div>\r\n\r\n  </div>\r\n</header>\r\n<div class=\"c-header__blank\"></div>\r\n<div class=\"b-wrap\">\r\n  <ul class=\"p-breadcrumb\">\r\n  </ul>\r\n</div>\r\n\r\n\r\n<div class=\"b-wrap s-home-view\">\r\n<ul id=\"js-slider_home-view\" class=\"s-home-view__list\"><li class=\"s-home-view__item js-slider_item_0\"><img src=\"./img/home-slider/slider_01.jpg\"/></li><li class=\"s-home-view__item js-slider_item_1 _hidden\"><img src=\"./img/home-slider/slider_02.jpg\"/></li><li class=\"s-home-view__item js-slider_item_2 _hidden\"><img src=\"./img/home-slider/slider_03.jpg\"/></li><li class=\"s-home-view__item js-slider_item_3 _hidden\"><img src=\"./img/home-slider/slider_04.jpg\"/></li><li class=\"s-home-view__item js-slider_item_4 _hidden\"><img src=\"./img/home-slider/slider_05.jpg\"/></li></ul>  <div class=\"s-home-view__catch\">\r\n    <div class=\"s-home-view__msg\">\r\n      <div class=\"s-home-view__msg-main\"><img src=\"./img/home/catch-main.svg\" alt=\"ものづくり現場をもっと、スマートに。\"/></div>\r\n      <div class=\"s-home-view__msg-sub\"><img src=\"./img/home/catch-sub.svg\" alt=\"製造業を中心に、業務効率化と “見える化” を実現するシステムを開発しています\"/></div>\r\n      <div class=\"s-home-view__msg-cta btn-arrow btn-theme\"><a href=\"./contact?from=first-view\" >現場の課題を相談する</a></div>\r\n    </div>\r\n  </div>\r\n</div>\r\n<div class=\"s-home-view__footer\">\r\n  <div class=\"s-home-view__footer--item\">\r\n    <a href=\"./solution\">\r\n      <div class=\"s-home-view__footer--icon\"><img src=\"./img/icon/light.png\" loading=\"lazy\"/></div>\r\n      <div class=\"s-home-view__footer--text\">\r\n        <div class=\"s-home-view__footer--main\">ソリューション</div>\r\n        <div class=\"s-home-view__footer--sub\">事業・製品を見る</div>\r\n      </div>\r\n    </a>\r\n  </div>\r\n  <div class=\"s-home-view__footer--item\">\r\n    <a href=\"./cases\">\r\n      <div class=\"s-home-view__footer--icon\"><img src=\"./img/cta/icon_cases.png\" loading=\"lazy\"/></div>\r\n      <div class=\"s-home-view__footer--text\">\r\n        <div class=\"s-home-view__footer--main\">導入事例</div>\r\n        <div class=\"s-home-view__footer--sub\">現場の改善事例を見る</div>\r\n      </div>\r\n    </a>\r\n  </div>\r\n  <div class=\"s-home-view__footer--item\">\r\n    <a href=\"./download?from=first-view\">\r\n      <div class=\"s-home-view__footer--icon\"><img src=\"./img/cta/icon_download.png\" loading=\"lazy\"/></div>\r\n      <div class=\"s-home-view__footer--text\">\r\n        <div class=\"s-home-view__footer--main\">資料ダウンロード</div>\r\n        <div class=\"s-home-view__footer--sub\">製品資料や関連資料を見る</div>\r\n      </div>\r\n    </a>\r\n  </div>\r\n</div>\r\n\r\n<div id=\"solution\" class=\"b-wrap bg-white\">\r\n  <div class=\"b-inner b-container__top\">\r\n    <div class=\"c-headline\">\r\n      <div class=\"c-headline__label\">SOLUTION</div>\r\n      <h2 class=\"c-headline__main\">ソリューション</h2>\r\n      <p class=\"c-headline__dsc\">\r\n        1978年創立以来、工場の設備や機械を制御するソフトウェアを開発してきました。<br>\r\n        製造業のお客様を中心に、現場の課題を解決するシステムを開発・提案しています。\r\n      </p>\r\n    </div>\r\n  </div>\r\n  <div class=\"b-inner b-container__bottom\">\r\n    <div class=\"c-menu\">\r\n      <ul class=\"c-menu__list\">\r\n\r\n    <li class=\"c-menu__item\">\r\n    <a href=\"./solution/industrial\" class=\"\">\r\n        <div class=\"c-menu__thumb\"><img src=\"./solution/industrial/img/screenshot.png\" loading=\"lazy\"/></div>\r\n        <div class=\"c-menu__text\">\r\n          <div class=\"c-menu__title _center\">産業・建設機械組込</div>\r\n          <p class=\"c-menu__dsc\">高い信頼性が要求される分野に向けて、高精度な制御システムを提供します。</p>\r\n        </div>\r\n      </a>\r\n    </li>\r\n    \r\n    <li class=\"c-menu__item\">\r\n    <a href=\"./solution/testing\" class=\"\">\r\n        <div class=\"c-menu__thumb\"><img src=\"./solution/testing/img/screenshot.png\" loading=\"lazy\"/></div>\r\n        <div class=\"c-menu__text\">\r\n          <div class=\"c-menu__title _center\">自動試験・検査</div>\r\n          <p class=\"c-menu__dsc\">30年以上の実績を活かし、試験・検査業務の効率化と品質向上を支援します。</p>\r\n        </div>\r\n      </a>\r\n    </li>\r\n    \r\n    <li class=\"c-menu__item\">\r\n    <a href=\"./solution/manufacturing\" class=\"\">\r\n        <div class=\"c-menu__thumb\"><img src=\"./solution/manufacturing/img/screenshot.png\" loading=\"lazy\"/></div>\r\n        <div class=\"c-menu__text\">\r\n          <div class=\"c-menu__title _center\">設計・製造・情報</div>\r\n          <p class=\"c-menu__dsc\">ものづくり現場の“見える化”を中心に、設計から製造・検査・出荷までの全工程を支援します。</p>\r\n        </div>\r\n      </a>\r\n    </li>\r\n    \r\n    <li class=\"c-menu__item\">\r\n    <a href=\"./solution/social\" class=\"\">\r\n        <div class=\"c-menu__thumb\"><img src=\"./solution/social/img/screenshot.png\" loading=\"lazy\"/></div>\r\n        <div class=\"c-menu__text\">\r\n          <div class=\"c-menu__title _center\">社会システム</div>\r\n          <p class=\"c-menu__dsc\">映像・M2M技術で、設備・施設の遠隔監視と安全管理を支援します。</p>\r\n        </div>\r\n      </a>\r\n    </li>\r\n    \r\n    <li class=\"c-menu__item\">\r\n    <a href=\"./solution/transport\" class=\"\">\r\n        <div class=\"c-menu__thumb\"><img src=\"./solution/transport/img/screenshot.png\" loading=\"lazy\"/></div>\r\n        <div class=\"c-menu__text\">\r\n          <div class=\"c-menu__title _center\">搬送システム</div>\r\n          <p class=\"c-menu__dsc\">半導体分野向けに、高効率・高信頼な搬送制御システムを提供します。</p>\r\n        </div>\r\n      </a>\r\n    </li>\r\n          </ul>\r\n    </div>\r\n    <div class=\"top-btn-all _wrap btn-arrow\"><a href=\"./solution\">もっと詳しく見る</a></div>\r\n  </div>\r\n</div>\r\n\r\n<div id=\"product\" class=\"b-wrap bg-light\">\r\n  <div class=\"b-container\">\r\n    <div class=\"b-inner\">\r\n      <div class=\"c-headline\">\r\n        <div class=\"c-headline__label\">PRODUCT</div>\r\n        <h2 class=\"c-headline__main\">製品</h2>\r\n      </div>\r\n    </div>\r\n    <div class=\"sd-product\">\r\n      <ul id=\"js-slider_product\" class=\"sd-product__slider\">\r\n        <li class=\"sd-product__list\">\r\n          <a class=\"sd-product__list--link\" href=\"./product/wmsics\"></a>\r\n          <div class=\"sd-product__list--img\"><img src=\"./product/wmsics/img/screenshot.png\" loading=\"lazy\" alt=\"'.$value['name'].'\"/></div>\r\n          <div class=\"sd-product__list--text\">\r\n            <span class=\"sd-product__list--label\">自社製品</span>\r\n            <div class=\"sd-product__list--main\">WMSics</div>\r\n            <p class=\"sd-product__list--dsc\">ハンディターミナルを用いた<br>在庫管理システム</p>\r\n          </div>\r\n        </li>\r\n        <li class=\"sd-product__list\">\r\n          <a class=\"sd-product__list--link\" href=\"./product/pdmics\"></a>\r\n          <div class=\"sd-product__list--img\"><img src=\"./product/pdmics/img/screenshot.png\" loading=\"lazy\" alt=\"'.$value['name'].'\"/></div>\r\n          <div class=\"sd-product__list--text\">\r\n            <span class=\"sd-product__list--label\">自社製品</span>\r\n            <div class=\"sd-product__list--main\">PDMics</div>\r\n            <p class=\"sd-product__list--dsc\">一元管理を実現する<br>図面管理システム</p>\r\n          </div>\r\n        </li>\r\n        <li class=\"sd-product__list\">\r\n          <a class=\"sd-product__list--link\" href=\"./product/sagane-sf\"></a>\r\n          <div class=\"sd-product__list--img\"><img src=\"./product/sagane-sf/img/screenshot.png\" loading=\"lazy\" alt=\"'.$value['name'].'\"/></div>\r\n          <div class=\"sd-product__list--text\">\r\n            <span class=\"sd-product__list--label\">取扱製品</span>\r\n            <div class=\"sd-product__list--main\">サガネ係長のSMART FACTORY</div>\r\n            <p class=\"sd-product__list--dsc\">競争力の高い<br>スマートファクトリーを構築</p>\r\n          </div>\r\n        </li>\r\n        <li class=\"sd-product__list\">\r\n          <a class=\"sd-product__list--link\" href=\"./product/rfid\"></a>\r\n          <div class=\"sd-product__list--img\"><img src=\"./product/rfid/img/screenshot.png\" loading=\"lazy\" alt=\"'.$value['name'].'\"/></div>\r\n          <div class=\"sd-product__list--text\">\r\n            <span class=\"sd-product__list--label\">自社製品</span>\r\n            <div class=\"sd-product__list--main\">RFIDソリューション</div>\r\n            <p class=\"sd-product__list--dsc\">RFIDを活用した<br>ソリューション</p>\r\n          </div>\r\n        </li>\r\n        <li class=\"sd-product__list\">\r\n          <a class=\"sd-product__list--link\" href=\"./product/inspection\"></a>\r\n          <div class=\"sd-product__list--img\"><img src=\"./product/inspection/img/screenshot.png\" loading=\"lazy\" alt=\"'.$value['name'].'\"/></div>\r\n          <div class=\"sd-product__list--text\">\r\n            <span class=\"sd-product__list--label\">取扱製品</span>\r\n            <div class=\"sd-product__list--main\">検査表システム</div>\r\n            <p class=\"sd-product__list--dsc\">図面から検査表を自動作成</p>\r\n          </div>\r\n        </li>\r\n        <li class=\"sd-product__list\">\r\n          <a class=\"sd-product__list--link\" href=\"./product/auto-drawing\"></a>\r\n          <div class=\"sd-product__list--img\"><img src=\"./product/auto-drawing/img/screenshot.png\" loading=\"lazy\" alt=\"'.$value['name'].'\"/></div>\r\n          <div class=\"sd-product__list--text\">\r\n            <span class=\"sd-product__list--label\">自社製品</span>\r\n            <div class=\"sd-product__list--main\">CAD自動作図</div>\r\n            <p class=\"sd-product__list--dsc\">類似図面の作図を<br>自動化するツール</p>\r\n          </div>\r\n        </li>\r\n      </ul>\r\n      <!-- <div class=\"slick-dots-area\"></div> -->\r\n    </div>\r\n    <div class=\"top-btn-all _wrap btn-arrow\"><a href=\"./product\">すべての製品を見る</a></div>\r\n  </div>\r\n</div>\r\n\r\n<div id=\"cases\" class=\"b-wrap bg-white\">\r\n  <div class=\"b-inner b-container__top\">\r\n    <div class=\"c-headline\">\r\n      <div class=\"c-headline__label\">CASES</div>\r\n      <h2 class=\"c-headline__main\">導入事例</h2>\r\n    </div>\r\n  </div>\r\n  <div class=\"b-inner b-container__bottom\">\r\n    <div class=\"grid-case\">\r\n      <ul class=\"grid-case__list\">\r\n\r\n  <li class=\"grid-case__item\">\r\n    <a class=\"grid-case__link\" href=\"./cases/wms\">\r\n      <div class=\"grid-case__img\"><img src=\"./cases/wms/img/screenshot.png\" loading=\"lazy\"/></div>\r\n      <div class=\"grid-case__text\">\r\n        <div class=\"grid-case__text--main\">在庫・置場管理システム</div>\r\n        <p class=\"grid-case__text--sub\">バーコード・RFIDで在庫を可視化し、入出庫業務の効率化を実現した事例です。</p>\r\n      </div>\r\n    </a>\r\n  </li>\r\n  <li class=\"grid-case__item\">\r\n    <a class=\"grid-case__link\" href=\"./cases/missing-detection\">\r\n      <div class=\"grid-case__img\"><img src=\"./cases/missing-detection/img/screenshot.png\" loading=\"lazy\"/></div>\r\n      <div class=\"grid-case__text\">\r\n        <div class=\"grid-case__text--main\">入出庫管理誤品検知システム</div>\r\n        <p class=\"grid-case__text--sub\">入出庫時の誤品検知により、作業ミス防止と業務効率化を実現した事例です。</p>\r\n      </div>\r\n    </a>\r\n  </li>\r\n  <li class=\"grid-case__item\">\r\n    <a class=\"grid-case__link\" href=\"./cases/pdm\">\r\n      <div class=\"grid-case__img\"><img src=\"./cases/pdm/img/screenshot.png\" loading=\"lazy\"/></div>\r\n      <div class=\"grid-case__text\">\r\n        <div class=\"grid-case__text--main\">設計情報管理システム</div>\r\n        <p class=\"grid-case__text--sub\">図面・CADデータを一元管理し、設計情報の共有と検索性を向上した事例です。</p>\r\n      </div>\r\n    </a>\r\n  </li>      </ul>\r\n    </div>\r\n    <div class=\"top-btn-all _wrap btn-arrow\"><a href=\"./cases\">すべての事例を見る</a></div>\r\n  </div>\r\n</div>\r\n\r\n\r\n<div id=\"solution\" class=\"b-wrap bg-light\">\r\n  <div class=\"b-inner b-container__top\">\r\n    <div class=\"c-headline\">\r\n      <div class=\"c-headline__label\">NEWS</div>\r\n      