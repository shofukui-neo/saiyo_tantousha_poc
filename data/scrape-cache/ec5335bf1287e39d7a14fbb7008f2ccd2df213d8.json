{"url":"http://www.ise-ics.co.jp","html":"<!DOCTYPE html>\r\n<html lang=\"ja\">\r\n<head>\r\n    <meta charset=\"UTF-8\"/>\r\n    <meta property=\"og:type\" content=\"website\"/>\r\n  <meta property=\"og:title\" content=\"製造業の業務効率化・現場改善システム開発｜株式会社アイ・シー・エス\"/>\r\n  <meta property=\"og:url\" content=\"http://www.ise-ics.co.jp/\"/>\r\n  <meta property=\"og:description\" content=\"製造業の業務効率化・現場改善をシステム開発で支援するIT企業。組込み・制御技術をベースに設計・検査・搬送の自動化システムを開発。三重県伊勢市の株式会社アイ・シー・エス。\"/>\r\n  <meta property=\"og:site_name\" content=\"株式会社アイ・シー・エス\"/>\r\n  <meta property=\"og:image\" content=\"https://www.ise-ics.co.jp/img/common/screenshot.jpg\"/>\r\n  <meta property=\"og:locale\" content=\"ja_JP\">\r\n    <meta name=\"twitter:card\" content=\"summary_large_image\"/>\r\n  <meta name=\"twitter:title\" content=\"製造業の業務効率化・現場改善システム開発｜株式会社アイ・シー・エス\"/>\r\n  <meta name=\"twitter:description\" content=\"製造業の業務効率化・現場改善をシステム開発で支援するIT企業。組込み・制御技術をベースに設計・検査・搬送の自動化システムを開発。三重県伊勢市の株式会社アイ・シー・エス。\"/>\r\n  <meta name=\"twitter:image\" content=\"https://www.ise-ics.co.jp/img/common/screenshot.jpg\"/>\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1, shrink-to-fit=no\"/>\r\n  <meta name=\"format-detection\" content=\"telephone=no\">\r\n  <meta name=\"description\" content=\"製造業の業務効率化・現場改善をシステム開発で支援するIT企業。組込み・制御技術をベースに設計・検査・搬送の自動化システムを開発。三重県伊勢市の株式会社アイ・シー・エス。\"/>\r\n  <link rel=\"icon\" href=\"https://www.ise-ics.co.jp/img/favicon.ico\">\r\n  <link rel=\"canonical\" href=\"http://www.ise-ics.co.jp/\"/>\r\n  <title>製造業の業務効率化・現場改善システム開発｜株式会社アイ・シー・エス</title>\r\n\r\n    <script type=\"application/ld+json\">\r\n  {\r\n    \"@context\": \"https://schema.org\",\r\n    \"@type\": \"WebPage\",\r\n    \"name\": \"製造業の業務効率化・現場改善システム開発｜株式会社アイ・シー・エス\",\r\n    \"description\": \"製造業の業務効率化・現場改善をシステム開発で支援するIT企業。組込み・制御技術をベースに設計・検査・搬送の自動化システムを開発。三重県伊勢市の株式会社アイ・シー・エス。\",\r\n    \"url\": \"http://www.ise-ics.co.jp/\"\r\n  }\r\n  </script>\r\n  <script type=\"application/ld+json\">\r\n  {\r\n    \"@contex