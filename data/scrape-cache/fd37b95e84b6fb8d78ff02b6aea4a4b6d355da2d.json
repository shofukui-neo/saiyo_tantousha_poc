{"url":"https://www.tohogas.co.jp/nw/designing-company-recruit/interview/index.html","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n<head prefix=\"og: http://ogp.me/ns# fb: http://ogp.me/ns/fb# website: http://ogp.me/ns/website#\">\n<meta charset=\"UTF-8\">\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n<meta name=\"viewport\" content=\"width=device-width\">\n<title>東邦ガス | ゲンバの星 - インタビュー</title>\n<meta name=\"keywords\" content=\"東邦ガス,ガス,都市ガス,ガス料金,ガス機器,ガス会社,ゲンバの星,導管工事,内管工事,ガス工事,採用,求人,監理士,工事士,設計士\">\n<meta name=\"description\" lang=\"ja\" content=\"東邦ガスのホームページです。工事会社の採用情報ページ「ゲンバの星」では、ガス工事の監理士・工事士・設計士の仕事内容、社員インタビュー、研修サポート体制、よくある質問、求人中の工事会社などをご紹介しています。\">\n<meta property=\"og:type\" content=\"website\">\n<meta property=\"og:url\" content=\"https://www.tohogas.co.jp/nw/designing-company-recruit/interview/index.html\">\n<meta property=\"og:title\" content=\"東邦ガス | ゲンバの星 - インタビュー\">\n<meta property=\"og:description\" content=\"東邦ガスのホームページです。工事会社の採用情報ページ「ゲンバの星」では、ガス工事の監理士・工事士・設計士の仕事内容、社員インタビュー、研修サポート体制、よくある質問、求人中の工事会社などをご紹介しています。\">\n<meta property=\"og:site_name\" content=\"ゲンバの星\">\n<meta property=\"og:image\" content=\"https://www.tohogas.co.jp/nw/designing-company-recruit/img/top_construction01.jpg\">\n<link rel=\"stylesheet\" href=\"../css/reset.css\">\n<link rel=\"stylesheet\" href=\"../css/style.css\">\n<link rel=\"stylesheet\" href=\"../css/satellite.css\">\n<link rel=\"icon\" href=\"/nw/favicon.ico\">\n<link rel=\"apple-touch-icon\" href=\"/nw/favicon.ico\" sizes=\"180x180\">\n<link rel=\"icon\" type=\"image/png\" href=\"/nw/favicon.ico\" sizes=\"192x192\">\n<link rel=\"stylesheet\" href=\"../css/swiper.min.css\">\n<link href=\"https://www.tohogas.co.jp/nw/designing-company-recruit/interview/index.html\" rel=\"canonical\">\n<script src=\"../js/swiper.min.js\"></script>\n<!--[if lt IE 9]><script src=\"/assets/js/html5shiv-printshiv.js\"></script><![endif]-->\n<script src=\"/assets/js/import.js\"></script>\n<link rel=\"alternate\" media=\"only screen and (max-width: 640px)\" href=\"https://www.tohogas.co.jp/nw/designing-company-recruit/sp/interview/\" />\n<!-- inc_GTM_head -->\n<!-- inc_GTM_head -->\n</head>\n<body>\n<!-- Google Tag Manager (noscript)  --> \n<!-- End Google Tag Manager (noscript) --> \n\n<!-- header --> \n<script src=\"https://ajax.googleapis.com/ajax/libs/jquery/2.1.4/jquery.min.js\"></script> \n<script>\nfunction init() {\n    var px_change   = 0;\n    window.addEventListener('scroll', function(e){\n        if ( $(window).scrollTop() > px_change ) {\n            $(\"header\").addClass(\"smaller\");\n        } else if ( $(\"header\").hasClass(\"smaller\") ) {\n            $(\"header\").removeClass(\"smaller\");\n        }\n    });\n}\nwindow.onload = init();\n</script> \n<!-- header --> \n\n<!-- fade --> \n<script>\n$(function(){\n    $(window).scroll(function (){\n        $('.parallaxin,.doukan p, .constructiontop,.cooperationmore,.more,.cooperationmore02,.honshikannaikan02,.title01,.title02,.honshikannaikan03,.interviewhonshikan,.interviewnaikan').each(function(){\n            var elemPos = $(this).offset().top;\n            var scroll = $(window).scrollTop();\n            var windowHeight = $(window).height();\n            if (scroll > elemPos - windowHeight + 200){\n                $(this).addClass('scrollin');\n            }\n        });\n    });\n});\n</script> \n<!-- fade -->\n\n<div id=\"wrapper\"> \n  <!-- header -->\n  <div id=\"l-document\"></div>\n  <div id=\"header\" class=\"pc_box\">\n  <div class=\"inner\">\n    <div id=\"sitelogo\"><a href=\"/index.html\" class=\"rollover\"><img src=\"../img/logo.gif\" width=\"172\" height=\"38\" alt=\"東邦ガスネットワーク\" /></a></div>\n  </div>\n  \n  <!-- nav -->\n  <header>\n    <nav id=\"nav\">\n      <ul>\n        <li><a href=\"../index.html\">TOP</a></li>\n        <li><a href=\"../honshikan/index.html\">本支管工事</a></li>\n        <li><a href=\"../naikan/index.html\">内管工事</a></li>\n        <li><a href=\"../interview/index.html\">インタビュー</a></li>\n        <li><a href=\"../support/index.html\">研修サポート</a></li>\n        <li><a href=\"../kyujin/index.html\">求人工事会社一覧</a></li>\n        <li><a href=\"../faq/index.html\">よくある質問</a></li>\n      </ul>\n    </nav>\n    </div>\n    <!-- //nav --> \n    \n  </header>\n  <!-- //header --> \n  \n  <!-- parallax -->\n  <div id=\"sec01\">\n    <div class=\"parallax03\"> <img src=\"../img/interview_title.png\" alt=\"先輩に聞いてみました！！\"> </div>\n  </div>\n  <!-- // parallax --> \n  \n  <!-- honshikan title-->\n  \n  <div class=\"honshikanphoto\"><img src=\"../img/interview_bg01.jpg\"></div>\n  <div class=\"interviewhonshikan\">\n    <div class=\"honshikanfont\">\n      <p><b>本支管工事</b></p>\n      Interview</div>\n    <p><img src=\"../img/interview_honshikan_bg.jpg\"></p>\n  </div>\n  <!-- // honshikan title --> \n  \n  <!-- interview --> \n  <!-- 田中 将浩様 -->\n  <div id=\"interview01\">\n    <div class=\"interviewfont\">\n      <p class=\"interviewtitle\"><img src=\"../img/interview_one.jpg\" alt=\"\">&ensp;<b>本支管監理士</b></p>\n      <p class=\"interviewquestion\"><b>どんな仕事をしていますか？</b></p>\n      ガス工事が安全に予定通り進むよう、全体を見守る監督業務です。地中でも作業しやすいスペースがとれるようにするなど、工事士さんが仕事をしやすい現場づくりをしています。<br />\n      <br />\n      <p class=\"interviewquestion\"><b>仕事で驚いたことはありますか？</b></p>\n      「掘削」の大変さに驚きました！ガス工事は道路に掘った穴にガス導管を埋めるのですが、掘った場所から予想外の量の地下水が出ることもしょっちゅう。予定内に仕上げるために、事前準備も含め、日々努力しています。<br />\n      <br />\n      <p class=\"interviewquestion\"><b>入社前と後でイメージは変わりましたか？</b></p>\n      社内での業務がほとんどだと思っていたら、入社してみると社内にいるのは朝夕ぐらいで日中はずっと現場。その方が自分には向いているので良かったと思います。<br />\n      <br />\n      <p class=\"interviewquestion\"><b>心に残っている仕事を教えてください。</b></p>\n      入社1年目、先輩の担当現場に監督代行として立っていた時に工事トラブルが起きたのですが、あたふたするだけで何もできませんでした。経験を積んだ今は不測の事態にも対応できるようになりましたが、悔しくて心に残っています。<br />\n      <br />\n      <p class=\"interviewquestion\"><b>オフタイムはどのように<br />\n        過ごしていますか？</b></p>\n      平日、帰宅すると満面の笑みを浮かべて子犬のように走ってくる子どもたちが本当にかわいいです。子犬のように抱き上げてお風呂に入ったりする時間に安らぎを感じます。 </div>\n    <div class=\"interviewname\">\n      <span><b>田中 将浩</b></span><br />\n      大学 理工学部卒</div>\n    <div class=\"interview\"><img src=\"../img/interview_sozai.jpg\"></div>\n  </div>\n  <!-- //田中 将浩様 --> \n  \n  <!-- 樋田 泰裕様 -->\n  <div id=\"interview02\">\n    <div class=\"interviewfont02\">\n      <p class=\"interviewtitle\"><img src=\"../img/interview_two.jpg\" alt=\"\">&ensp;<b>本支管監理士</b></p>\n      <p class=\"interviewquestion\"><b>どんな仕事をしていますか？</b></p>\n      道路にガス導管を埋設したり撤去したりする工事を、安全・円滑に進むよう、工事全体を見渡して監督する仕事です。<br />\n      <br />\n      <p class=\"interviewquestion\"><b>仕事で気を付けていることは何ですか？</b></p>\n      ガス工事は街づくりの仕事ですが、騒音などでご迷惑をおかけすることもあるので、良いイメージを持っていただくことを大切にしています。事前のご挨拶や、可能な限り生活に配慮したスケジューリングなどで近隣の方の負担を減らし、印象が変わればいいなと思っています。 <br />\n      <br />\n      <p class=\"interviewquestion\"><b>心に残っている仕事を教えてください。 </b></p>\n      初めて打ち合わせから工事完了までトータルで関わった工事です。電気や建築など他業者さんとお互いの考えを伝え合って仕事を進めることで、コミュニケーション力を身に付けることができました。 <br />\n      <br />\n      <p class=\"interviewquestion\"><b>これからの目標を教えてください。</b></p>\n      直近の目標は、土木施工監理技術者1級資格の取得です。さらに先の目標は、頼りになる人間・父親として、会社の人・家族・友人に信頼されるようになることです。自分の子どもも社会で貢献できる人に育ってほしいです。 <br />\n      <br />\n      <p class=\"interviewquestion\"><b>オフタイムはどのように<br />\n        過ごしていますか？</b></p>\n      平日夜は家族と過ごせるよう、なるべく残業しないで仕事は朝のうちに済ますことがモットーです。ソフトボールチームに入っているのでオンシーズンは月1～2回、休日に試合を楽しんでいます。 </div>\n    <div class=\"interviewname02\">\n      <span><b></b></span><br />\n      大学 都市環境<br />\n      デザイン学科卒</div>\n    <div class=\"interview02\"><img src=\"../img/interview_sozai02.jpg\" alt=\"\"></div>\n  </div>\n  <!-- //樋田 泰裕様 --> \n  \n  <!-- 庄司 昌弘様 -->\n  <div id=\"interview03\">\n    <div class=\"interviewfont\">\n      <p class=\"interviewtitle\"><img src=\"../img/interview_three.jpg\" alt=\"\">&ensp;<b>本支管工事士</b></p>\n      <p class=\"interviewquestion\"><b>どんな仕事をしていますか？</b></p>\n      道路にガス導管を埋設したり撤去したりする工事で、溶接作業をしています。<br />\n      <br />\n      <p class=\"interviewquestion\"><b>この仕事を選んだ理由を教えてください。</b></p>\n      学校の授業がきっかけで溶接に興味を持ち、先生に薦められてこの会社を選びました。工業系の科ではなかったので溶接の知識はほぼゼロでしたが、現場や自主的な練習で技術を身に付けていきました。<br />\n      <br />\n      <p class=\"interviewquestion\"><b>仕事でうれしさを感じるのはどんな時ですか？</b></p>\n      熱で金属を溶かして管と管をつなぐのが溶接ですが、作業をすべて現場で行うのではなく、事前に準備した管を現場の管につなぐ場合もあります。その時、自分が作って準備した管が現場の管にピッタリ合った時は毎回うれしくて「よっしゃ～！」と思うと同時にホッとします。<br />\n      <br />\n      <p class=\"interviewquestion\"><b>心に残っている仕事を教えてください。</b></p>\n      幅2.5m、深さが15m以上ある穴に酸素濃度計を頼りに入る現場です。酸欠にならないよう注意しながらはしごを降りる時は足が震えました･･･。<br />\n      <br />\n      <p class=\"interviewquestion\"><b>オフタイムはどのように<br />\n        過ごしていますか？</b></p>\n      毎日帰宅すると子どもたちが「行けー！」と飛びついてきます。タックルされ、のしかかられながら「ここからが仕事だ…」と思っています（笑）。子どもが早く寝た時に妻と晩酌したりDVDを観ている時が幸せですね。 </div>\n    <div class=\"interviewname03\">\n      <span><b>庄司 昌弘</b></span><br />\n      高校 電子情報<br />\n      デザイン科卒</div>\n    <div class=\"interview03\"><img src=\"../img/interview_sozai.jpg\"></div>\n  </div>\n  <!-- //庄司 昌弘様 --> \n  \n  <!-- 村川 弘信様 -->\n  <div id=\"interview04\">\n    <div class=\"interviewfont02\">\n      <p class=\"interviewtitle\"><img src=\"../img/interview_four.jpg\" alt=\"\">&ensp;<b>本支管工事士</b></p>\n      <p class=\"interviewquestion\"><b>どんな仕事をしていますか？</b></p>\n      道路にガス導管を埋設したり撤去したりする工事を行っています。<br />\n      <br />\n      <p class=\"interviewquestion\"><b>入社前と後でイメージは変わりましたか？</b></p>\n      入社前は力仕事だと思っていましたが、実際は力も頭も使う仕事でした。ガス導管を道路に埋める時、地下に何がどんな状態で埋まっているか掘ってみないとわかりません。水道管を避けるためにガス管の通し方を変えるなど現場で考える場面が多いのは意外でした。 <br />\n      <br />\n      <p class=\"interviewquestion\"><b>心に残っている仕事を教えてください。 </b></p>\n      東日本大震災の復旧支援に参加したことです。ガス工事の仕事を通じて被災地の方々の力になれたらと思っていましたが、現場で挨拶を交わしたり、パンを差し入れしていただいたり、逆に元気をいただきました。 <br />\n      <br />\n      <p class=\"interviewquestion\"><b>これからの目標を教えてください。</b></p>\n      ガス工事のルールである「基準」の勉強をし続け、今まで以上に配管技術を上げたいです。私生活では今まで通り家族を大切にし、ずっと仲良くしていきたいです。 <br />\n      <br />\n      <p class=\"interviewquestion\"><b>オフタイムはどのように<br />\n        過ごしていますか？</b></p>\n      娘と一緒に和太鼓の教室に通っています。工事ではもう使えないガス管の端材を太鼓代わりに自宅でも叩いています。イベントで教室のみんなで演奏を披露する機会もあるので練習にも身が入ります！ </div>\n    <div class=\"interviewname04\">\n      <span><b>村川 弘信</b></span><br />\n      高校 土木科卒</div>\n    <div class=\"interview04\"><img src=\"../img/interview_sozai.jpg\" alt=\"\"></div>\n  </div>\n  <!-- //村川 弘信様 --> \n  \n  <!-- 藤井 康博様 -->\n  <div id=\"interview05\">\n    <div class=\"interviewfont\">\n      <p class=\"interviewtitle\"><img src=\"../img/interview_five.jpg\" alt=\"\">&ensp;<b>本支管工事士</b></p>\n      <p class=\"interviewquestion\"><b>どんな仕事をしていますか？</b></p>\n      道路のガス導管や、お客さまの敷地内に引き込むガス導管を埋設したり撤去したりする工事を行っています。<br />\n      <br />\n      <p class=\"interviewquestion\"><b>上司や先輩とはどのような関係ですか？</b></p>\n      仕事の相談もできるし、プライベートでも仲良くしていただいています。会社のひと回りほど年上の先輩とは旅行することもあり、最近は福岡に行きました。<br />\n      <br />\n      <p class=\"interviewquestion\"><b>大変だと思うのはどんな時ですか？</b></p>\n      ガス工事は実際に地面を掘ってみないとわからず、予定通りに進まないことも珍しくありませんが、何があっても毎日17時までには工事完了させないといけないのが大変ですね。現場では対応力が必要だと感じます。<br />\n      <br />\n      <p class=\"interviewquestion\"><b>心に残っている仕事はありますか？</b></p>\n      熊本地震の復旧支援に参加したことですね。他のガス工事会社さんたちと一緒に震災直後の熊本に入って、2週間ほどライフライン復旧に向けてガス管の修理作業などを行いました。手早い作業ももちろんですが、被災者の方々への配慮など、いつもとは違う緊張感のある現場でしたが、ガスの早期復旧の役に立つことができて良かったです。<br />\n      <br />\n      <p class=\"interviewquestion\"><b>オフタイムはどのように<br />\n        過ごしていますか？</b></p>\n      平日は家に帰って子どもの顔をみるとホッとしますね。休日は家族で公園に行ったり、買い物をしたりしています。 </div>\n    <div class=\"interviewname\">\n      <span><b>藤井 康博</b></span><br />\n      高校 機械科卒</div>\n    <div class=\"interview05\"><img src=\"../img/interview_sozai.jpg\"></div>\n  </div>\n  <!-- //藤井 康博様 --> \n  \n  <!-- naikantitle-->\n  \n  <div class=\"naikanphoto\"><img src=\"../img/interview_bg02.jpg\"></div>\n  <div class=\"interviewnaikan\">\n    <div class=\"naikanfont\">\n      <p><b>内管工事</b></p>\n      Interview</div>\n    <p><img src=\"../img/interview_naikan_bg.jpg\"></p>\n  </div>\n  <!-- // naikantitle --> \n  \n  <!-- 丹羽 真里奈様 -->\n  <div id=\"interview06\">\n    <div class=\"interviewfont\">\n      <p class=\"interviewtitle\"><img src=\"../img/interview_six.jpg\" alt=\"\">&ensp;<b>内管監理士</b></p>\n      <p class=\"interviewquestion\"><b>どんな仕事をしていますか？</b></p>\n      お客さまの敷地内や建物のガス工事で、工事全体の工程管理や調整業務を行っています。<br />\n      <br />\n      <p class=\"interviewquestion\"><b>心に残っている仕事を教えてください。</b></p>\n      初めて1人で担当した案件です。現場でわからないことが多く、｢かけ過ぎかな…｣と思うくらい1日に何度も先輩の携帯に電話をし、質問していました。そのたびに丁寧に教えてくださってなんとか無事に終えることができ、心に残る仕事になりました。<br />\n      <br />\n      <p class=\"interviewquestion\"><b>この仕事を始めて変化したことはありますか？</b></p>\n      ペーパードライバーでしたが、仕事で車移動をするようになって運転が上手になったと言われます。最初は現場に入る時も周辺をぐるっと一周して少しでも道が広くて入りやすいところを探していました（笑）。<br />\n      <br />\n      <p class=\"interviewquestion\"><b>これからの目標を教えてください。</b></p>\n      まずは今、先輩と一緒にしている仕事を1人でできるようになり、10年先は部下を持って教えられるようになりたいです。そして居心地も良くて大好きな今の会社で30年先も働いていたいです！<br />\n      <br />\n      <p class=\"interviewquestion\"><b>オフタイムはどのように<br />\n        過ごしていますか？</b></p>\n      平日の仕事後は週に1回、友達と一緒にジムに行って体を動かしています。休日は友達とショッピングや映画を楽しんでいます。旅行も好きで、今一番行きたいのは北海道です。これから10年位かけて全都道府県に行けたらいいな、と思っています。 </div>\n    <div class=\"interviewname06\">\n      <span><b>丹羽 真里奈</b></span><br />\n      大学 国際情報学部卒</div>\n    <div class=\"interview06\"><img src=\"../img/interview_sozai.jpg\"></div>\n  </div>\n  <!-- //丹羽 真里奈様 --> \n  \n  <!-- 田中 廣幸様 -->\n  <div id=\"interview07\">\n    <div class=\"interviewfont02\">\n      <p class=\"interviewtitle\"><img src=\"../img/interview_seven.jpg\" alt=\"\">&ensp;<b>内管工事士</b></p>\n      <p class=\"interviewquestion\"><b>どんな仕事をしていますか？</b></p>\n      10年の有効期限が近づいたガスメーターをお使いのお客さま宅を訪問し、取替え作業を行っています。<br />\n      <br />\n      <p class=\"interviewquestion\"><b>会社の人間関係はどのような雰囲気ですか？</b></p>\n      先輩には仕事の相談もしますが、趣味の話などもざっくばらんに話せる雰囲気ですね。後輩が悩んでいそうな時は声をかけるようにしていますが、よくジュースをおごらされています（笑）。 <br />\n      <br />\n      <p class=\"interviewquestion\"><b>仕事ではどんなことに気をつけていますか？ </b></p>\n      安全に関することには特に気を使います。ガス漏れを起こさないために作業後の安全確認はルールを守ってしっかり行います。また、車での移動中は事故を起こさないよう運転マナーを守って常に安全運転を心がけています。 <br />\n      <br />\n      <p class=\"interviewquestion\"><b>仕事でうれしさを感じるのはどんな時ですか？</b></p>\n      お客さま宅への訪問時は作業をするだけではなく、会話も大切にしています。普段あまり人と話す機会がないお年寄りの方もいらっしゃるのですが、作業の合間に会話をさせていただくととても喜んでくださり、「今日は本当にありがとう」という言葉をいただけると喜んでもらえてよかった、と思います。 <br />\n      <br />\n      <p class=\"interviewquestion\"><b>オフタイムはどのように<br />\n        過ごしていますか？</b></p>\n      平日の夜は妻と買い物に出かけ、夕食をよく一緒に作ります。最近おいしくできたのは親子丼です。2チームに所属しているサッカーは週に2~3回プレイするほか、会社の野球チームにも所属しています。 </div>\n    <div class=\"interviewname04\">\n      <span><b>田中 廣幸</b></span><br />\n      高校 体育科卒</div>\n    <div class=\"interview07\"><img src=\"../img/interview_sozai.jpg\" alt=\"\"></div>\n  </div>\n  <!-- //田中 廣幸様 --> \n  \n  <!-- 谷上 友浩様 -->\n  <div id=\"interview08\">\n    <div class=\"interviewfont\">\n      <p class=\"interviewtitle\"><img src=\"../img/interview_eight.jpg\" alt=\"\">&ensp;<b>内管工事士</b></p>\n      <p class=\"interviewquestion\"><b>どんな仕事をしていますか？</b></p>\n      お客さまの敷地内でのガス工事やガス機器の接続、プロパン（LP）ガスから都市ガスへの切替え工事などを行っています。<br />\n      <br />\n      <p class=\"interviewquestion\"><b>入社前と後でイメージは変わりましたか？</b></p>\n      入社前は人間関係や仕事がちゃんとできるかどうかなど色々不安でしたが、実際に働き始めてみると親方が親切に仕事を教えてくださり、不安もなくなりました。<br />\n      <br />\n      <p class=\"interviewquestion\"><b>心に残っている仕事を教えてください。</b></p>\n      仕事を始めて5~6年目で、自分が「親方」になって初めて1人で完了させた現場ですね。これからも安全第一で事故なく、信頼関係を大切にして仕事をしたいです。<br />\n      <br />\n      <p class=\"interviewquestion\"><b>しくじり体験を教えてください。</b></p>\n      建物にガス管を通すための穴をあける時、予定と違う場所にあけてしまった時です。まずは監督に報告して、業者さんにお願いして穴を埋めてもらったのですが、本当に反省しました。それからは前以上に図面をしっかり確認するなど慎重になりました。<br />\n      <br />\n      <p class=\"interviewquestion\"><b>オフタイムはどのように<br />\n        過ごしていますか？</b></p>\n      登山を始めました。登頂した時の達成感が気持ちいいんです。ゴールデンウィークは会社の人と御在所岳に登りました。目標は日本中の山を登ること。いつか槍ヶ岳や富士山に挑戦したいです。登山以外には自分が子どもの頃に所属していた少年野球チームで監督をしています。 </div>\n    <div class=\"interviewname\">\n      <span><b>谷上 友浩</b></span><br />\n      高校 機械科卒</div>\n    <div class=\"interview08\"><img src=\"../img/interview_sozai.jpg\"></div>\n  </div>\n  <!-- //谷上 友浩様 --> \n  \n  <!-- 二村 一輝様 -->\n  <div id=\"interview09\">\n    <div class=\"interviewfont02\">\n      <p class=\"interviewtitle\"><img src=\"../img/interview_nine.jpg\" alt=\"09\">&ensp;<b>内管設計士</b></p>\n      <p class=\"interviewquestion\"><b>どんな仕事をしていますか？</b></p>\n      設計と営業を兼務しています。戸建・アパートなどのガス導管の設計図を描いたり、工事費の計算や管理をしています。<br />\n      <br />\n      <p class=\"interviewquestion\"><b>この仕事を選んだ理由を教えてください。</b></p>\n      経営学部出身で営業職を希望していたのですが、営業だけではなく施工監理にも関わってライフラインの最前線に立つ仕事であることに魅力を感じました。 <br />\n      <br />\n      <p class=\"interviewquestion\"><b>しくじり体験を教えてください。 </b></p>\n      お客さまのニーズに応えようとするあまり、現場の視点が欠けた施工方法を提案してしまったことです。施工段階で不可能とわかって現場の方々にご迷惑をかけてしまい、それ以来、自分の設計に無理がないかを工事士さんに相談して進めるようになりました。 <br />\n      <br />\n      <p class=\"interviewquestion\"><b>オフタイムはどのように<br />\n        過ごしていますか？</b></p>\n      極力外に出て、気持ちをリフレッシュするようにしています。釣りが趣味なので、学生時代の友人や職場の先輩と鮒釣りや海釣りに出かけています。 </div>\n    <div class=\"interview09\">\n      <div class=\"interview09_02\"><img src=\"../img/interview09.png\"></div>\n      <div class=\"interview09_03\"><img src=\"../img/interview_sozai.jpg\"></div>\n      <div class=\"interviewname09\">\n        <span><b>二村 一輝</b></span><br />\n        大学 経営学部卒</div>\n    </div>\n  </div>\n  <!-- //二村 一輝様 --> \n  \n  <!-- //interview --> \n  \n  <!-- support -->\n  <div class=\"topsupport\">\n    <p><b>丁寧な指導と資格取得サポートでスキルアップを応援！</b></p>\n    <p class=\"more\"><a href=\"../support/index.html\"><img src=\"../img/button_more.png\" alt=\"\"></a></p>\n  </div>\n  <!-- //support --> \n  \n  <!-- kyujin -->\n  <div class=\"topcooperation\"> <img src=\"../img/top_bg03.png\" alt=\"\">\n    <p class=\"cooperationfont\"><b>あなたが輝く場所が、きっとあります。<br />\n      一緒に働く仲間を募集中の会社はこちら！</b></p>\n    <p class=\"cooperationmore\"><a href=\"../kyujin/index.html\"><img src=\"../img/button_more.png\" alt=\"\"></a></p>\n    <p class=\"cooperatioimage\"><img src=\"../img/woman.png\"></p>\n    <!-- topbutton -->\n    <div class=\"gotop\"><a href=\"#header\"><img src=\"../img/button02.png\" alt=\"\"></a> </div>\n    <!-- //topbutton --> \n  </div>\n  <!-- //kyujin --> \n  \n  <!-- footer -->\n  <footer id=\"footer\">\n    <ul>\n      <li><a href=\"../index.html\">TOP</a></li>\n      <li>|</li>\n      <li><a href=\"../honshikan/index.html\">本支管工事</a></li>\n      <li>|</li>\n      <li><a href=\"../naikan/index.html\">内管工事</a></li>\n      <li>|</li>\n      <li><a href=\"../interview/index.html\">インタビュー</a></li>\n      <li>|</li>\n      <li><a href=\"../support/index.html\">研修サポート</a></li>\n      <li>|</li>\n      <li><a href=\"../kyujin/index.html\">求人工事会社一覧</a></li>\n      <li>|</li>\n      <li><a href=\"../faq/index.html\">よくある質問</a></li>\n    </ul>\n  </footer>\n  <div id=\"footer02\">\n    <div class=\"inner\">\n      <div class=\"fnavi\">\n        <ul>\n          <li><a href=\"/siteinfo/site-use/\"><img src=\"../img/fnavi_site-use.gif\" height=\"19\" width=\"140\" alt=\"サイトのご利用にあたって\" /></a></li>\n          <li><a href=\"/siteinfo/privacypolicy/\"><img src=\"../img/fnavi_privacypolicy.gif\" height=\"19\" width=\"143\" alt=\"個人情報の取扱いについて\" /></a></li>\n        </ul>\n      </div>\n      <div class=\"copyright\">\n        <p><img src=\"../img/copyright.gif\" alt=\"東邦ガスネットワーク株式会社 Copyright &#169; TOHO GAS NETWORK Co., Ltd. All Rights Reserved.\" width=\"297\" height=\"39\" />\n      </div>\n\n    </div>\n  </div>\n</div>\n<!-- //footer -->\n</div>\n\n<!-- /wrap --> \n<script type=\"text/javascript\">\n\tif (location .protocol == \"https:\") {\n\tdocument.write(unescape('%3Cscript src=\"https://ssl.syncsearch.jp/common/js/suggest.js\" type=\"text/javascript\"%3E%3C/script%3E'));} else {document.write(unescape('%3Cscript src=\"http://pro.syncsearch.jp/common/js/suggest.js\" type=\"text/javascript\"%3E%3C/script%3E'));}\n</script> \n<script type=\"text/javascript\">\n\tSYNCSEARCH_SITE=\"R8JG2HJR\";\n</script> \n<!-- /wrap --> \n<!-- Parallax --> \n<script>\n if(navigator.userAgent.match(/MSIE 10/i) || navigator.userAgent.match(/Trident\\/7\\./) || navigator.userAgent.match(/Edge\\/12\\./)) {\n $('body').on(\"mousewheel\", function () {\n event.preventDefault();\n var wd = event.wheelDelta;\n var csp = window.pageYOffset;\n window.scrollTo(0, csp - wd);\n });\n }\n</script> \n<!-- Parallax --> \n\n<script src=\"https://cdnjs.cloudflare.com/ajax/libs/smooth-scroll/12.1.5/js/smooth-scroll.min.js\"></script> \n<script>\n        \tvar scroll = new SmoothScroll('a[href*=\"#\"]', {\n\t\t\t\tignore: '[data-scroll-ignore]',\n\t\t\t\theader: null,\n\t\t\t\tspeed: 500,\n\t\t\t\toffset: 0,\n\t\t\t\teasing: 'easeInOutCubic',\n\t\t\t\tbefore: function (anchor, toggle) {\n\t\t\t\t\tvar activeLink = document.querySelector('#header .nav .nav-link.active');\n\t\t\t\t\tif(activeLink){\n\t\t\t\t\t\tactiveLink.classList.remove('active');\n\t\t\t\t\t}\n\t\t\t\t\ttoggle.classList.add('active');\n\t\t\t\t}\n\t\t\t});\n\n        </script>\n</body>\n</html>","finalUrl":"https://www.tohogas.co.jp/nw/designing-company-recruit/interview/index.html","rendered":false,"_cachedAt":"2026-06-23T18:40:00.374Z"}