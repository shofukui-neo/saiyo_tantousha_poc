{"url":"https://www.pref.saitama.lg.jp/e2201/gakugei-saiyou.html","html":"<!doctype html>\r\n<html lang=\"ja\">\r\n<head>\r\n<meta charset=\"utf-8\">\r\n\r\n<title>令和8年度埼玉県学芸員採用選考について - 埼玉県</title>\r\n<meta name=\"keywords\" content=\"学芸員,採用,試験,埼玉県,博物館\" />\r\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\r\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\r\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\r\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\r\n})(window,document,'script','dataLayer','GTM-T855884');</script>\r\n\r\n<meta name=\"author\" content=\"埼玉県\">\r\n<meta property=\"og:title\" content=\"令和8年度埼玉県学芸員採用選考について\">\r\n<meta property=\"og:type\" content=\"article\">\r\n<meta property=\"og:description\" content=\"\">\r\n<meta property=\"og:url\" content=\"https://www.pref.saitama.lg.jp/e2201/gakugei-saiyou.html\">\r\n<meta property=\"og:image\" content=\"https://www.pref.saitama.lg.jp/shared/images/sns/logo.png\">\r\n<meta property=\"og:site_name\" content=\"埼玉県\">\r\n<meta property=\"og:locale\" content=\"ja_jp\">\r\n<meta name=\"dept_code_1\" content=\"140000000\">\r\n<meta name=\"dept_code_2\" content=\"140001000\">\r\n<meta name=\"dept_code_3\" content=\"140001010\">\r\n<meta name=\"cate_code_1\" content=\"005000000000\">\r\n<meta name=\"cate_code_2\" content=\"005016000000\">\r\n<meta name=\"cate_code_3\" content=\"\">\r\n<meta name=\"cate_code_4\" content=\"\">\r\n<meta name=\"publish_start\" content=\"2026-06-09 10:00:00\">\r\n<meta name=\"publish_end\" content=\"2029-06-08 00:00:00\">\r\n<meta name=\"template_id\" content=\"36\">\r\n<meta name=\"template_kind\" content=\"1\">\r\n<meta name=\"template_group\" content=\"11188\">\r\n<meta name=\"img\" content=\"\">\r\n<meta name=\"viewport\" content=\"width=device-width, maximum-scale=3.0\">\r\n<meta name=\"format-detection\" content=\"telephone=no\">\r\n<link href=\"/shared/site_rn/style/default