      <a href=\"https://www.hojoen.com/question/\" class=\"p-drawer__nav-link\">よくあるご質問</a>\n                                        </li>\n                                    </ul>\n                                </nav>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</header>\n\n<!-- チャットボット -->\n<!--\n<script>\n(function(){\nvar w=window,d=document;\nvar s=\"https://app.chatplus.jp/cp.js\";\nd[\"__cp_d\"]=\"https://app.chatplus.jp\";\nd[\"__cp_c\"]=\"0138619e_1\";\nvar a=d.createElement(\"script\"), m=d.getElementsByTagName(\"script\")[0];\na.async=true,a.src=s,m.parentNode.insertBefore(a,m);})();\n</script>\n-->\n\n<a href=\"https://app.chatplus.jp/chat/visitor/0138619e_1?t=btn\" target=\"_blank\" class=\"c-chat-bot js-chatbot\">\n    <p class=\"c-chat-bot__text\">\n        ご質問に<span class=\"u-desktop--inline\">チャットで</span><br class=\"u-desktop\">\n        回答<br class=\"u-mobile\">いたします。\n    </p>\n    <div class=\"c-chat-bot__icon\">\n        <img src=\"https://www.hojoen.com/images/icon_chat.svg\" alt=\"チャットボット\">\n    </div>\n</a>\n\n<main class=\"l-main\">\n    <!-- メインビジュアル -->\n    <div class=\"p-top-mv\">\n        <div class=\"p-top-mv__movie sp-none\">\n            <video src=\"./movie/mv250220.mp4\" autoplay loop muted playsinline></video>\n        </div>\n        <div class=\"p-top-mv__movie pc-none\">\n            <video src=\"./movie/mv250220_sp.mp4\" autoplay loop muted playsinline></video>\n        </div>\n        <div class=\"l-inner p-top-mv__inner\">\n            <div class=\"p-top-mv__wrapper\">\n                <h1 class=\"p-top-mv__logo\">\n                    <img src=\"./images/logo.svg\" alt=\"賢島宝生苑\">\n                </h1>\n                <a href=\"#news\" class=\"p-top-mv__scroll\">\n                    <span class=\"p-top-mv__scroll-text\">scroll</span>\n                    <span class=\"p-top-mv__scroll-arrow\"></span>\n                </a>\n            </div>\n        </div>\n    </div>\n\n    <!-- お知らせ -->\n    <section class=\"p-top-news\" id=\"news\">\n        <div class=\"l-inner\">\n            <div class=\"p-top-news__wrapper\">\n                <h2 class=\"p-top-news__title item1\">\n                    おしらせ\n                </h2>\n                <ul class=\"p-top-news__list item2\">\n                    <li class=\"p-top-news__item color-red\">\n                        <a href=\"topicslist/detail.php?no=20260211115405\" class=\"p-top-news__row\">\n                            <time datetime=\"2026-03-15\" class=\"p-top-news__row-date\">\n                                2026/3/15\n                            </time>\n                            <h3 class=\"p-top-news__row-title\">【ご案内】一部客室設備・改装工事のお知らせ〈2026.5/6～〉</h3>\n                        </a>\n                    </li>\n                    <li class=\"p-top-news__item\">\n                        <a href=\"topicslist/detail.php?no=20250313093846\" class=\"p-top-news__row\">\n                            <time datetime=\"2026-06-22\" class=\"p-top-news__row-date\">\n                                2026/6/22\n                            </time>\n                            <h3 class=\"p-top-news__row-title\">【ご案内】《6月・7月》入浴付きご昼食プラン ～彩(いろどり)～</h3>\n                        </a>\n                    </li>\n                    <li class=\"p-top-news__item\">\n                        <a href=\"topicslist/detail.php?no=20220126084548\" class=\"p-top-news__row\">\n                            <time datetime=\"2026-06-22\" class=\"p-top-news__row-date\">\n                                2026/6/22\n                            </time>\n                            <h3 class=\"p-top-news__row-title\">【ご案内】7月の館内施設の営業・休業について</h3>\n                        </a>\n                    </li>\n                                    </ul>\n                <div class=\"p-top-news__btn-wrap item3\">\n                    <a href=\"https://www.hojoen.com/topicslist/\" class=\"c-btn c-btn--borderless\">おしらせ一覧</a>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <!-- about -->\n    <div class=\"p-top-about js-popUp\">\n        <div class=\"l-inner p-top-about__inner\">\n            <div class=\"p-top-about__wrapper\">\n                <button class=\"p-top-about__video modal-open\" data-micromodal-trigger=\"modal-1\">\n                    <img src=\"./images/image_about-thumbnail.png\" alt=\"PVサムネイル\">\n                </button>\n                <div class=\"p-top-about__body\">\n                    <div class=\"p-top-about__body-wrapper\">\n                        <p class=\"p-top-about__text\">\n                            穏やかな波や大小の島々が織り成す\n                        </p>\n                        <p class=\"p-top-about__text\">\n                            英虞湾の壮大な眺め。\n                        </p>\n                        <p class=\"p-top-about__text\">\n                            悠然と広がる絵画のような絶景は\n                        </p>\n                        <p class=\"p-top-about__text\">\n                            朝な夕なとその表情を変えてゆく。\n                        </p>\n                        <p class=\"p-top-about__text\">\n                            くつろぎのそばに、\n                        </p>\n                        <p class=\"p-top-about__text\">\n                            美しくたおやかな海がよりそう。\n                        </p>\n                        <p class=\"p-top-about__text\">\n                            ここにしかない、こころ満ちるひとときを\n                        </p>\n                        <p class=\"p-top-about__text\">\n                            心からのおもてなしで特別な思い出に。\n                        </p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n\n    <!-- about videoのモーダル -->\n    <div class=\"p-top-video-modal\">\n        <div class=\"modal micromodal-slide\" id=\"modal-1\" aria-hidden=\"true\">\n            <!-- 背景のオーバーレイ -->\n            <div class=\"modal-overlay\" tabindex=\"-1\" data-micromodal-close>\n                <div class=\"modal-container\" role=\"dialog\" aria-modal=\"true\" aria-labelledby=\"modal-1-title\">\n                    <header class=\"modal-header\">\n                        <!-- 閉じるボタン -->\n                        <button class=\"modal-close\" aria-label=\"Close modal\" data-micromodal-close></button>\n                    </header>\n                    <!-- モーダルのコンテンツ -->\n                    <div class=\"modal-content\" id=\"modal-1-content\">\n                        <video src=\"./movie/index_movie.mp4\" controls playsinline></video>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n\n\n    <!-- お部屋 -->\n    <section class=\"p-top-room js-popUp\">\n        <div class=\"l-inner\">\n            <div class=\"p-top-room__contents\">\n                <div class=\"p-top-room__contents-body\">\n                    <div class=\"p-hgroup p-top-room__hgroup\">\n                        <h2 class=\"p-hgroup__title\">\n                            お部屋\n                        </h2>\n                        <div class=\"p-hgroup__body\">\n                            <p class=\"p-hgroup__text p-hgroup__text--narrow\">\n                                朝な夕なと変わりゆく英虞湾の景色をお楽しみいただける全室オーシャンビュー。<br>\n                                落ち着いた上質な和のしつらえが<br>\n                                窓からの景色を風情あふれる眺めに仕立て、<br class=\"u-desktop\">\n                                くつろぎの空間を演出いたします。\n                            </p>\n                            <div class=\"p-hgroup__btn-wrap\">\n                                <a href=\"https://www.hojoen.com/guestroom/\" class=\"c-btn\">くわしくはこちら</a>\n                            </div>\n                        </div>\n                    </div>\n                    <ul class=\"p-top-room__contents-image-list\">\n                        <li class=\"p-top-room__contents-image-item p-top-room__contents-image-item--video\">\n                            <img class=\"js-popUp-image\" src=\"./images/image_room1.jpg\" alt=\"お部屋写真\">\n                        </li>\n                        <li class=\"p-top-room__contents-image-item\">\n                            <img class=\"js-popUp-image\" src=\"./images/image_room2.jpg\" alt=\"お部屋写真\">\n                        </li>\n                    </ul>\n                </div>\n                <div class=\"p-top-room__contents-image\">\n                    <img class=\"js-popUp-image\" src=\"./images/image_room3.jpg\" alt=\"お部屋写真\">\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <!-- お料理 -->\n    <section class=\"p-top-food l-top-food js-popUp\">\n        <div class=\"l-inner\">\n            <div class=\"p-top-food__contents\">\n                <div class=\"p-top-food__image\">\n                    <img class=\"js-popUp-image\" src=\"./images/image_food1.jpg\" alt=\"お料理写真\">\n                </div>\n                <div class=\"p-top-food__contents-body\">\n                    <div class=\"p-hgroup p-top-food__hgroup\">\n                        <h2 class=\"p-hgroup__title\">\n                            お料理\n                        </h2>\n                        <div class=\"p-hgroup__body\">\n                            <p class=\"p-hgroup__text p-hgroup__text--narrow\">\n                                海の幸を中心に、<br>\n                                ひと皿ごとに贅を込めた会席のおもてなし。<br>\n                                丁寧に仕込んだ味わいに<br>\n                                彩りゆたかな盛り付けと<br>\n                                気持ちまで華やぐお料理が並びます。\n                            </p>\n                            <div class=\"p-hgroup__btn-wrap\">\n                                <a href=\"https://www.hojoen.com/cuisine/\" class=\"c-btn\">くわしくはこちら</a>\n                            </div>\n                        </div>\n                    </div>\n                    <ul class=\"p-top-food__contents-image-list\">\n                        <li class=\"p-top-food__contents-image-item p-top-food__contents-image-item--video\">\n                            <video class=\"js-popUp-image\" src=\"./movie/nabe_light2.mp4\" autoplay loop muted playsinline></video>\n                        </li>\n                        <li class=\"p-top-food__contents-image-item\">\n                            <img class=\"js-popUp-image\" src=\"./images/image_food3.jpg\" alt=\"お料理写真\">\n                        </li>\n                    </ul>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <div class=\"l-spring-search-wrap\">\n\n        <!-- 伊勢志摩温泉 -->\n        <section class=\"p-top-spring js-popUp\">\n            <div class=\"l-inner\">\n                <div class=\"p-top-spring__image\">\n                    <img class=\"js-popUp-image\" src=\"./images/image_spring1.jpg\" alt=\"温泉写真\">\n                </div>\n                <div class=\"p-top-spring__contents\">\n                    <div class=\"p-top-spring__contents-body\">\n                        <div class=\"p-hgroup p-top-spring__hgroup\">\n                            <h2 class=\"p-hgroup__title\">\n                                伊勢志摩温泉\n                            </h2>\n                            <div class=\"p-hgroup__body\">\n                                <p class=\"p-hgroup__text\">\n                                    空と海につづくかのような天然温泉に<br class=\"u-mobile\">身をゆだね<br class=\"u-desktop\">\n                                    美しい英虞湾を行き交う船や、<br class=\"u-mobile\">流れる雲、<br class=\"u-desktop\">\n                                    きらめく朝日や旅情を誘う夕日を眺めるひととき。<br>\n                                    贅沢な景色をゆったりと楽しむうちに<br>\n                                    とろりとなめらかな泉質が<br class=\"u-mobile\">やさしい温もりで全身を包む。<br>\n                                    何度でも入りたくなる心地よさをご堪能ください。\n                                </p>\n                                <div class=\"p-hgroup__btn-wrap\">\n                                    <a href=\"https://www.hojoen.co