/li>\n</ul>\n</li>\n<li id=\"gn-recruit\"><a href=\"http://www.kayama-sakaki.co.jp/recruit/\">採用情報</a>\n<ul class=\"drop\">\n<li><a href=\"http://www.kayama-sakaki.co.jp/recruit/\"><img class=\"arrow_mark\" src=\"../img/arrow_mark_gray.gif\" alt=\"\" width=\"9\" height=\"9\" />採用情報</a></li>\n<li><a href=\"http://www.kayama-sakaki.co.jp/recruit/selection.php\"><img class=\"arrow_mark\" src=\"../img/arrow_mark_gray.gif\" alt=\"\" width=\"9\" height=\"9\" />選考方法</a></li>\n<li><a href=\"http://www.kayama-sakaki.co.jp/recruit/guide.php\"><img class=\"arrow_mark\" src=\"../img/arrow_mark_gray.gif\" alt=\"\" width=\"9\" height=\"9\" />募集要項</a></li>\n</ul>\n</li>\n<li id=\"gn-contact\"><a href=\"https://kayama-sakaki-cojp.ssl-xserver.jp/contact/\">お問い合わせ</a></li>\n</ul>\n</div>\n</div>\n<!-- end [header] -->\n\n<!-- start [container] -->\n<div id=\"container\">\n\n<!-- start [contents] -->\n<div id=\"contents\" class=\"clearfix\">\n\n<!-- start [topicpath] -->\n<div id=\"topicpath\">\n<div id=\"topicpathInner\">\n<!--メインインデックス部分-->\n<ul>\n<li><a href=\"http://www.kayama-sakaki.co.jp/\">HOME</a> &nbsp;&gt;&nbsp;</li>\n<li>お問い合わせ &nbsp;&gt;&nbsp;お問い合わせフォーム</li>\n<!--ウェブページ部分ここから-->\n</ul>\n</div>\n</div>\n<!-- end [topicpath] -->\n\n<div id=\"main\">\n<h2 id=\"contactus\">お問い合わせ</h2>\n<p class=\"\">下記のメールフォームに必要事項をご記入の上、お問い合わせください。折り返しご連絡いたします。<br />\nお問い合わせ内容によりましては、返信までにお時間をいただく場合がございますので、あらかじめご了承ください。</p>\n<!--[ここからメールフォーム]-->\n<form id=\"mailform\" method=\"post\" action=\"mailformpro/send.cgi\" onsubmit=\"return falsesubmit(this)\" accept-charset=\"UTF-8\">\n<script type=\"text/javascript\" src=\"mailformpro/include.cgi\" charset=\"UTF-8\"></script>\n<noscript>\n<p><input type=\"hidden\" name=\"javascript_flag\" value=\"0\" /></p>\n</noscript>\n<div id=\"mailfrom_hidden_object\">\n<input type=\"submit\" value=\"submit\" />\n<input type=\"hidden\" name=\"must_id\" value=\"(必須)\" />\n<input type=\"hidden\" name=\"input_time\" value=\"0\" />\n<input type=\"hidden\" name=\"confirm_time\" id=\"confirm_time\" value=\"0\" />\n<input type=\"hidden\" name=\"sitein_referrer\" value=\"\" />\n<input type=\"hidden\" name=\"mailform_confirm_mode\" value=\"1\" />\n</div>\n<table border=\"0\" cellspacing=\"0\" cellpadding=\"0\" class=\"mailform\" summary=\"mailform main\">\n<tr class=\"mfptr\">\n<th><img src=\"images/mfp_must.gif\" width=\"30\" height=\"16\" alt=\"必須\" class=\"must\" />お名前<span>your name</span></th>\n<td><input type=\"text\" name=\"お名前(必須)\" size=\"30\" class=\"mfp\" /><div id=\"errormsg_お名前\" class=\"mfp_err\"></div></td>\n</tr>\n<tr class=\"mfptr\">\n<th>フリガナ<span>assumed name</span></th>\n<td><input type=\"text\" name=\"フリガナ\" size=\"30\" class=\"mfp\" /></td>\n</tr>\n<tr class=\"mfptr\">\n<th>会社名（法人様のみ）<span>company name</span></th>\n<td><input type=\"text\" name=\"会社名\" size=\"45\" class=\"mfp\" /></td>\n</tr>\n<tr class=\"mfptr\">\n<th>部署名（法人様のみ）<span>department name</span></th>\n<td><input type=\"text\" name=\"部署名\" size=\"45\" class=\"mfp\" /></td>\n</tr>\n<tr class=\"mfptr\">\n<th><img src=\"images/mfp_must.gif\" width=\"30\" height=\"16\" alt=\"必須\" class=\"must\" />ご連絡先電話番号<span>telephone number</span></th>\n<td><input type=\"text\" name=\"ご連絡先電話番号(必須)\" size=\"30\" class=\"mfp\" /><div id=\"errormsg_ご連絡先電話番号\" class=\"mfp_err\"></div></td>\n</tr>\n<tr class=\"mfptr\">\n<th><img src=\"images/mfp_must.gif\" width=\"30\" height=\"16\" alt=\"必須\" class=\"must\" />メールアドレス<span>mail address</span></th>\n<td><input type=\"text\" name=\"email(必須)\" size=\"45\" class=\"mfp\" /><div id=\"errormsg_email\" class=\"mfp_err\"></div></td>\n</tr>\n<tr class=\"mfptr\">\n<th>郵便番号<span>postcode</span></th>\n<td>\n<input type=\"hidden\" name=\"ご住所[unjoin]〒+郵便番号+\\n+都道府県+市区町村+丁目番地\" value=\"\" />\n<input type=\"text\" name=\"郵便番号\" size=\"20\" onblur=\"mfpc(this.form.id,this.name,'都道府県','市区町村','丁目番地');\" class=\"mfp\" /> \n&nbsp;<a href=\"http://www.post.japanpost.jp/zipcode/\" target=\"_blank\">郵便番号を調べる</a>\n<div id=\"errormsg_郵便番号\" class=\"mfp_err\"></div></td>\n</tr>\n<tr class=\"mfptr\">\n<th>ご住所<span>address</span></th>\n<td>\n<ol>\n<li>\n<span>都道府県</span>\n<select name=\"都道府県\" class=\"mfp\">\n<option value=\"\" selected=\"selected\">【選択して下さい】</option>\n<optgroup label=\"北海道・東北地方\">\n<option value=\"北海道\">北海道</option>\n<option value=\"青森県\">青森県</option>\n<option value=\"岩手県\">岩手県</option>\n<option value=\"秋田県\">秋田県</option>\n<option value=\"宮城県\">宮城県</option>\n<option value=\"山形県\">山形県</option>\n<option value=\"福島県\">福島県</option>\n</optgroup>\n<optgroup label=\"関東地方\">\n<option value=\"栃木県\">栃木県</option>\n<option value=\"群馬県\">群馬県</option>\n<option value=\"茨城県\">茨城県</option>\n<option value=\"埼玉県\">埼玉県</option>\n<option value=\"東京都\">東京都</option>\n<option value=\"千葉県\">千葉県</option>\n<option value=\"神奈川県\">神奈川県</option>\n</optgroup>\n<optgroup label=\"中部地方\">\n<option value=\"山梨県\">山梨県</option>\n<option value=\"長野県\">長野県</option>\n<option value=\"新潟県\">新潟県</option>\n<option value=\"富山県\">富山県</option>\n<option value=\"石川県\">石川県</option>\n<option value=\"福井県\">福井県</option>\n<option value=\"静岡県\">静岡県</option>\n<option value=\"岐阜県\">岐阜県</option>\n<option value=\"愛知県\">愛知県</option>\n</optgroup>\n<optgroup label=\"近畿地方\">\n<option value=\"三重県\">三重県</option>\n<option value=\"滋賀県\">滋賀県</option>\n<option value=\"京都府\">京都府</option>\n<option value=\"大阪府\">大阪府</option>\n<option value=\"兵庫県\">兵庫県</option>\n<option value=\"奈良県\">奈良県</option>\n<option value=\"和歌山県\">和歌山県</option>\n</optgroup>\n<optgroup label=\"四国地方\">\n<option value=\"徳島県\">徳島県</option>\n<option value=\"香川県\">香川県</option>\n<option value=\"愛媛県\">愛媛県</option>\n<option value=\"高知県\">高知県</option>\n</optgroup>\n<optgroup label=\"中国地方\">\n<option value=\"鳥取県\">鳥取県</option>\n<option value=\"島根県\">島根県</option>\n<option value=\"岡山県\">岡山県</option>\n<option value=\"広島県\">広島県</option>\n<option value=\"山口県\">山口県</option>\n</optgroup>\n<optgroup label=\"九州・沖縄地方\">\n<option value=\"福岡県\">福岡県</option>\n<option value=\"佐賀県\">佐賀県</option>\n<option value=\"長崎県\">長崎県</option>\n<option value=\"大分県\">大分県</option>\n<option value=\"熊本県\">熊本県</option>\n<option value=\"宮崎県\">宮崎県</option>\n<option value=\"鹿児島県\">鹿児島県</option>\n<option value=\"沖縄県\">沖縄県</option>\n</optgroup>\n</select>\n<div id=\"errormsg_都道府県\" class=\"mfp_err\"></div>\n</li>\n<li><span>市区町村</span> <input type=\"text\" name=\"市区町村\" size=\"35\" class=\"mfp\" /><div id=\"errormsg_市区町村\" class=\"mfp_err\"></div></li>\n<li><span>丁目番地</span> <input type=\"text\" name=\"丁目番地\" size=\"60\" class=\"mfp\" /><div id=\"errormsg_丁目番地\" class=\"mfp_err\"></div></li>\n</ol>\n</td>\n</tr>\n<tr class=\"mfptr\">\n<th><img src=\"images/mfp_must.gif\" width=\"30\" height=\"16\" alt=\"必須\" class=\"must\" />お問い合わせ内容\n<span>inquiry body</span></th>\n<td><textarea name=\"お問い合わせ内容(必須)\" rows=\"13\" cols=\"85\" class=\"mfp\">なるべく具体的にご記入ください。</textarea><div id=\"errormsg_お問い合わせ内容\" class=\"mfp_err\"</div></td>\n</tr>\n<tr class=\"mfptr send\">\n<th>送信<span>submit send</span></th>\n<td><ul>\n<li><input type=\"button\" value=\"確認画面へ\" onclick=\"sendMail(this.form)\" onkeypress=\"sendMail(this.form)\" /></li>\n</ul></td>\n</tr>\n</table>\n</form>\n<!--[ここまでメールフォーム]-->\n</div>\n<div id=\"sub\">\n<h5>お問い合わせメニュー</h5>\n<ul class=\"menu\">\n<li class=\"pagehere endlist\"><a href=\"http://www.kayama-sakaki.co.jp/contact/\">お問い合わせフォーム</a></li>\n</ul>\n<ul class=\"banner\">\n<li><a href=\"http://www.kayama-sakaki.co.jp/associated/esprit.php\"><img src=\"../img/sub_banner_esprit.png\" alt=\"株式会社エスプリ\" width=\"190\" height=\"53\" /></a></li>\n<li><a href=\"http://www.kayama-sakaki.co.jp/associated/ket.php\"><img src=\"../img/sub_banner_kayamaengine.png\" alt=\"kayama engineering co.,ltd\" width=\"190\" height=\"53\" /></a></li>\n<li><a href=\"http://www.kayama-sakaki.co.jp/associated/thai-akiba.php\"><img src=\"../img/sub_banner_taiakiba.png\" alt=\"tai akiba co.,ltd\" width=\"190\" height=\"53\" /></a></li>\n</ul>\n</div>\n</div>\n<!-- end [contents] -->\n\n</div>\n<!-- end [container] -->\n\n<!-- s