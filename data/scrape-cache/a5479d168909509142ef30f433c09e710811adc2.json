   </div>\n    </div>\n    </div>\n  </header>\n\n\n<main id=\"contents\">\n\n\t<section class=\"box-undertitle-01\">\n\t\t<div class=\"title-wrap recruit recruit\">\n\t\t\t<div class=\"title-inner ir-flex\">\n\t\t\t\t<h1>\n\t\t\t\t\t<span class=\"title\">жҺЎз”Ёжғ…е ұ</span>\n\t\t\t\t\t<span class=\"ruby\">RECRUIT</span>\n\t\t\t\t</h1>\n\t\t\t</div>\n\t\t</div>\n\t</section>\n\n\t<!-- recruitпјҡMV / гӮ№гғ©гӮӨгғүеҢ– -->\n\t<section class=\"under-recruit-mv\">\n\t\t<div class=\"box-slides-01\">\n\t\t\t<ul class=\"unit-slides-01\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<li><img src=\"https://www.hotta-marusho.co.jp/wordpress/wp-content/uploads/2022/12/mv_01-scaled.jpg\"></li>\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<li><img src=\"https://www.hotta-marusho.co.jp/wordpress/wp-content/uploads/2022/12/mv_02-scaled.jpg\"></li>\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<li><img src=\"https://www.hotta-marusho.co.jp/wordpress/wp-content/uploads/2022/12/mv_03-scaled.jpg\"></li>\n\t\t\t\t\t\t\t\t\t\t\t\t</ul>\n\t\t\t<div class=\"catch\"><span>дјқзөұгӮ’жҺўгӮҠж–°гҒ—гҒҚгӮ’еүөйҖ гҒҷгӮӢ</span></div>\n\t\t</div>\n\t</section>\n\n\t<!-- recruitпјҡsec01пјҡжҺЎз”ЁгғЎгғғгӮ»гғјгӮё -->\n\t<!--\n\t<section class=\"under-recruit-sec01\">\n\t\t<div class=\"wrapper\">\n\t\t\t<div class=\"wrapper-inner wrapper-inner-w800pc\">\n\t\t\t\t<h2 class=\"unit-title-04\">жҺЎз”ЁгғЎгғғгӮ»гғјгӮё</h2>\n\t\t\t\t<h3 class=\"unit-title-10\">\n\t\t\t\t\t\t\t\t\t\tжҢ‘гӮҖ!!\t\t\t\t\t\t\t\t\t</h3>\n\t\t\t\t<p>\n\t\t\t\t\t\t\t\t\t\tе Җз”°дёёжӯЈж ӘејҸдјҡзӨҫгҒ®жӯҙеҸІгҒҜгҖҒ1861е№ҙгҒ®дә¬е‘үжңҚгӮ„йӣ‘иІЁгҒ®жҢҒдёӢгӮҠе•ҶгҒ„пјҲдёҠж–№гҒ®е•Ҷе“ҒгҒЁең°ж–№гҒ®зү©з”ЈгӮ’иЎҢгҒҚжқҘгҒ—гҒӘгҒҢгӮүд»•е…ҘгӮҢиІ©еЈІгҒҷгӮӢе•ҶгҒ„пјүгҒӢгӮүе§ӢгҒҫгӮҠгҒҫгҒ—гҒҹгҖӮ<br />\r\nгҒқгҒ“гҒӢгӮү160е№ҙдҪҷгӮҠгҖҒд»Ҡж—ҘгҒ«иҮігӮӢгҒҫгҒ§гҒ®й–“гҖҒдё–гҒ®дёӯгҒҜеӨ§гҒҚгҒҸеӨүгӮҸгӮҠгҒҫгҒ—гҒҹгҖӮ<br />\r\nз§ҒгҒҹгҒЎгӮӮгҒқгҒ®еӨүеҢ–гҒ«гҒӮгӮҸгҒӣгҖҒдјқзөұгӮ’зҙЎгҒҺгҒӘгҒҢгӮүгӮӮж–°гҒҹгҒӘдәӢжҘӯй ҳеҹҹгҒёгҒЁжҢ‘жҲҰгҒ—гҖҒеӨұж•—гӮ’йҮҚгҒӯгҒӘгҒҢгӮүгӮӮгҖҒдәӢжҘӯгӮ’иӮІгҒҰгҖҒз¶ҷжүҝгҒ—гҒҰгҒҫгҒ„гӮҠгҒҫгҒ—гҒҹгҖӮ<br />\r\nзҸҫеңЁгҖҒдё–гҒ®дёӯгҒҜгҒӢгҒӨгҒҰгҒӘгҒ„зЁӢгҒ®гӮ№гғ”гғјгғүгҒ§еӨүеҢ–гҒ—гҒҰгҒ„гҒҫгҒҷгҖӮеӨүеҢ–еҜҫеҝңгҒ§гҒҚгҒӘгҒ„дјҒжҘӯгҒҜиЎ°йҖҖгҒ—гҒҰгҒ„гҒҸдёҖж–№гҖҒеӨүеҢ–гӮ’жҚүгҒҲгҖҒеӨүгҒҲгҒҰгҒҜгҒ„гҒ‘гҒӘгҒ„гҒ“гҒЁгҒЁеӨүгҒҲгӮӢгҒ№гҒҚгӮӮгҒ®гӮ’иҰӢжҘөгӮҒгҖҒжҢ‘жҲҰгҒ—з¶ҡгҒ‘гӮӢдјҒжҘӯгҒҜжҲҗй•·гҒ—гҒҰгҒ„гҒҚгҒҫгҒҷгҖӮ<br />\r\nз§ҒгҒҹгҒЎгҒ«гҒҜгҖҒгҒ“гӮҢгҒҫгҒ§зҙЎгҒ„гҒ§гҒҚгҒҹиіҮз”ЈгҒҢгҒӮгӮҠгҒҫгҒҷгҖӮеӨ§еҲҮгҒ«гҒ—гҒҰгҒҚгҒҹдјқзөұгҒҢгҒӮгӮҠгҒҫгҒҷгҖӮ<br />\r\nгҖҺжё©ж•…зҹҘж–°гҖҸж•…гҒҚгӮ’жё©гҒӯгҒҰж–°гҒ—гҒҚгӮ’зҹҘгӮӢ<br>з§ҒгҒҹгҒЎгҒ гҒӢгӮүгҒ“гҒқгҒ§гҒҚгӮӢеӨүеҢ–еҜҫеҝңгҒёгҒ®гӮўгғ—гғӯгғјгғҒгҒ§гҒҷгҖӮ\t\t\t\t\t\t\t\t\t</p>\n\t\t\t\t<h3 class=\"unit-title-11\">\n\t\t\t\t\t<span class=\"en\">OUR MISSION</span>\n\t\t\t\t\t<span class=\"ja\">\n\t\t\t\t\t\t\t\t\t\t\t\tз§ҒгҒҹгҒЎгҒ®дҪҝе‘ҪгҒҜгҖҒдјқзөұгӮ’жҺўгӮҠгҖҒж–°гҒ—гҒҚгӮ’еүөйҖ гҒ—гҖҒ<br />\r\nеҝғиұҠгҒӢгҒӘзӨҫдјҡгҒ®зҷәеұ•гҒ«иІўзҢ®гҒҷгӮӢгҒ“гҒЁгҒ§гҒҷгҖӮ\t\t\t\t\t\t\t\t\t\t\t</span>\n\t\t\t\t</h3>\n\t\t\t\t\t\t\t\t<p>гҒ“гҒ®MISSIONгӮ’йҒ”жҲҗгҒҷгӮӢгҒҹгӮҒгҖҒзҸҫеңЁгҖҒз§ҒгҒҹгҒЎгҒҜж—ўеӯҳдәӢжҘӯгҒ®еӨүйқ©гҖҒжө·еӨ–дәӢжҘӯгҒ®жӢЎеӨ§гҖҒж–°иҰҸдәӢжҘӯгӮ’йҖІгӮҒгҒҰгҒ„гҒҫгҒҷгҖӮз§ҒгҒҹгҒЎгҒЁе…ұгҒ«гҖҢжҢ‘гӮҖгҖҚж–№гӮ’жұӮгӮҒгҒҰгҒ„гҒҫгҒҷгҖӮ<br />\r\nгҒӮгҒӘгҒҹгҒ®жҢ‘жҲҰгӮ’еҝғгӮҲгӮҠгҒҠеҫ…гҒЎгҒ—гҒҰгҒҠгӮҠгҒҫгҒҷгҖӮ<br />\r\n<br />\r\nе Җз”°дёёжӯЈж ӘејҸдјҡзӨҫ<br />\r\nд»ЈиЎЁеҸ–з· еҪ№зӨҫй•·гҖҖдёҠжқү йҡјеңҹ</p>\n\t\t\t\t\t\t\t</div>\n\t\t\t<div class=\"unit-seccatch-02 w\"><span>MESSAGE</span></div>\n\t\t</div>\n\t</section>\n\t-->\n\n\t<!-- recruitпјҡsec02пјҡMISSION STATEMENT -->\n\t<!--\n  <section class=\"under-recruit-sec02 top-sec01\">\n    <a class=\"sec01-link\" href=\"https://www.hotta-marusho.co.jp/company/mission-statement/\">\n      <div class=\"wrapper\">\n        <div class=\"cont\">\n          <h2 class=\"title\">MISSION STATEMENT</h2>\n          <p class=\"lead\">Our missionпјҲз§ҒгҒҹгҒЎгҒ®дҪҝе‘ҪпјүгҒЁ<br class=\"sp-visible\">Our ValuesпјҲз§ҒгҒҹгҒЎгҒ®дҫЎеҖӨиҰіпјүгӮ’гҒ”зҙ№д»ӢгҒ—гҒҫгҒҷгҖӮ</p>\n        </div>\n      </div>\n    </a>\n  </section>\n\t-->\n\n\t<!-- recruitпјҡsec03пјҡеӢҹйӣҶиҒ·зЁ® -->\n\t<section class=\"under-recruit-sec03\">\n\t\t<div class=\"wrapper\">\n\t\t\t<div class=\"wrapper-inner\">\n\t\t\t\t<h2 class=\"unit-title-04\">еӢҹйӣҶиҒ·зЁ®</h2>\n\n\t\t\t\t\t\t\t\t\t\t\t\t\t<p class=\"t-center\">зҸҫеңЁдёӢиЁҳиҒ·зЁ®гӮ’еӢҹйӣҶгҒ—гҒҰгҒ„гҒҫгҒҷгҖӮ<br>еҗ„иҒ·зЁ®гҒ®еӢҹйӣҶиҰҒй …гҒҜдёӢиЁҳгӮҲгӮҠгҒ”зўәиӘҚгҒҸгҒ гҒ•гҒ„гҖӮ</p>\n\t\t\t\t\n\t\t\t\t<div class=\"box-530flex-01\">\n\t\t\t\t\t<div class=\"unit-entry-01 active\">\n\t\t\t\t\t\t<a href=\"#youkou01\">\n\t\t\t\t\t\t\t<span class=\"en-and-num\">\n\t\t\t\t\t\t\t\t<span class=\"en\">ENTRY</span>\n\t\t\t\t\t\t\t\t<span class=\"num\">01</span>\n\t\t\t\t\t\t\t</span>\n\t\t\t\t\t\t\t<figure class=\"img\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<img src=\"https://www.hotta-marusho.co.jp/wordpress/wp-content/uploads/2022/12/entry01.jpg\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t</figure>\n\t\t\t\t\t\t\t<h3 class=\"title\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\tе–¶жҘӯпјҲеӢҹйӣҶдёӯпјү\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t</h3>\n\t\t\t\t\t\t</a>\n\t\t\t\t\t</div>\n\t\t\t\t\t<div class=\"unit-entry-01 active\">\n\t\t\t\t\t\t<a href=\"#youkou02\">\n\t\t\t\t\t\t\t<span class=\"en-and-num\">\n\t\t\t\t\t\t\t\t<span class=\"en\">ENTRY</span>\n\t\t\t\t\t\t\t\t<span class=\"num\">02</span>\n\t\t\t\t\t\t\t</span>\n\t\t\t\t\t\t\t<figure class=\"img\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<img src=\"https://www.hotta-marusho.co.jp/wordpress/wp-content/uploads/2022/12/entry04.jpg\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t</figure>\n\t\t\t\t\t\t\t<h3 class=\"title\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\tECйҒӢз”ЁпјҲеӢҹйӣҶдёӯпјү\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t</h3>\n\t\t\t\t\t\t</a>\n\t\t\t\t\t</div>\n\t\t\t\t\t<div class=\"unit-entry-01 active\">\n\t\t\t\t\t\t<a href=\"#youkou03\">\n\t\t\t\t\t\t\t<span class=\"en-and-num\">\n\t\t\t\t\t\t\t\t<span class=\"en\">ENTRY</span>\n\t\t\t\t\t\t\t\t<span class=\"num\">03</span>\n\t\t\t\t\t\t\t</span>\n\t\t\t\t\t\t\t<figure class=\"img\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<img src=\"https://www.hotta-marusho.co.jp/wordpress/wp-content/uploads/2022/12/entry02.jpg\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t</figure>\n\t\t\t\t\t\t\t<h3 class=\"title\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\tдјҒз”»гғ»з”ҹз”Јз®ЎзҗҶпјҲеӢҹйӣҶдёӯпјү\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t</h3>\n\t\t\t\t\t\t</a>\n\t\t\t\t\t</div>\n\t\t\t\t\t<div class=\"unit-entry-01\">\n\t\t\t\t\t\t<a href=\"#youkou04\">\n\t\t\t\t\t\t\t<span class=\"en-and-num\">\n\t\t\t\t\t\t\t\t<span class=\"en\">ENTRY</span>\n\t\t\t\t\t\t\t\t<span class=\"num\">04</span>\n\t\t\t\t\t\t\t</span>\n\t\t\t\t\t\t\t<figure class=\"img\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<img src=\"https://www.hotta-marusho.co.jp/wordpress/wp-content/uploads/2022/12/entry03.jpg\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t</figure>\n\t\t\t\t\t\t\t<h3 class=\"title\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\tгҒқгҒ®д»–пјҲзҸҫеңЁеӢҹйӣҶгҒҜгҒӮгӮҠгҒҫгҒӣгӮ“пјү\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t</h3>\n\t\t\t\t\t\t</a>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t\t<div class=\"unit-seccatch-02\"><span>ENTRY</span></div>\n\t\t</div>\n\t</section>\n\n\t<!-- recruitпјҡsec04пјҡгғЎгғігғҗгғјзҙ№д»Ӣ -->\n\t<section class=\"under-recruit-sec04\">\n\t\t<div class=\"wrapper\">\n\t\t\t<div class=\"wrapper-inner wrapper-inner-w1000pc\">\n\t\t\t\t<h2 class=\"unit-title-04\">гғЎгғігғҗгғјзҙ№д»Ӣ</h2>\n\t\t\t\t<p class=\"t-center\">е–¶жҘӯгғ»дјҒз”»йғЁй–ҖгҒ§гҒҜ20д»Јдёӯе …пҪһ30д»Јдёӯе …гҒҢдёӯеҝғгҒЁгҒӘгӮҠгҖҒдәӢжҘӯгӮ’жҺЁйҖІгҒ—гҒҰгҒ„гҒҫгҒҷгҖӮ</p>\n\t\t\t\t<div class=\"box-member-01\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<div class=\"unit-member-01\">\n\t\t\t\t\t\t\t\t<figure class=\"img\"><img src=\"https://www.hotta-marusho.co.jp/wordpress/wp-content/uploads/2022/12/member03.jpg\" alt=\"еҚғзЁ®\"></figure>\n\t\t\t\t\t\t\t\t<div class=\"txt\">\n\t\t\t\t\t\t\t\t\t<div class=\"left\">\n\t\t\t\t\t\t\t\t\t\t<span class=\"year\">2007е№ҙе…ҘзӨҫ</span>\n\t\t\t\t\t\t\t\t\t\t<span class=\"name\">еҚғзЁ®</span>\n\t\t\t\t\t\t\t\t\t\t<span class=\"team\">гҒҚгӮӮгҒ®дәӢжҘӯйғЁе–¶жҘӯ</span>\n\t\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t\t<div class=\"right\">\n\t\t\t\t\t\t\t\t\t\tе…ҘзӨҫгҒ®гҒҚгҒЈгҒӢгҒ‘гҒҜгҖҒж—Ҙжң¬гҒ®дјқзөұж–ҮеҢ–гҒ«иҲҲе‘ігҒҢгҒӮгӮҠгҖҒеүөжҘӯ150дҪҷе№ҙгҒ®дјқзөұгҒӮгӮӢеҪ“зӨҫгҒёе…ҘзӨҫгӮ’жұәгӮҒгҒҫгҒ—гҒҹгҖӮ<br />\r\n<br />\r\nе…ҘзӨҫгҒ—гҒҰжңҖеҲқгҒҜгҖҗзқҖзү©еҸҚзү©гҖ‘гҒ®е·»гҒҚж–№гҒӢгӮүе§ӢгҒҫгӮҠзқҖзү©гҒ®зҹҘиӯҳгӮ’еӯҰгҒігҖҒзқҖзү©гҒ®еҘҘж·ұгҒ•гӮ’зҹҘгӮҠгҒҫгҒ—гҒҹгҖӮе–¶жҘӯйқўгҒ§гҒҜгҖҒе…Ҳиј©гҒ«еҗҢиЎҢгҒ—е°ҸеЈІеә—ж§ҳгҒӢгӮүзҷҫиІЁеә—ж§ҳгҒҫгҒ§ж§ҳгҖ…гҒӘиІ©еЈІгҒ«и§ҰгӮҢгҒҰгҒҚгҒҫгҒ—гҒҹгҖӮе•ҸеұӢгҒҜе•Ҷе“ҒгҒ®еҚёиІ©еЈІгҒ®гӮӨгғЎгғјгӮёгҒ§гҒ—гҒҹгҒҢгҖҒеҸ–еј•е…ҲгҒёгҒ®гӮўгғ—гғӯгғјгғҒгҖҒгҒқгҒ—гҒҰиҮӘгӮүе•Ҷе“ҒгҒ®иІ©еЈІгӮ’гҒ—гҒҰе®ҹйҡӣгҒ«гҒҠе®ўж§ҳгҒЁжҺҘгҒ—гҒҰгҒҚгҒҫгҒ—гҒҹгҖӮ<br />\r\n<br />\r\nе…ЁеӣҪгҒ®зҷҫиІЁеә—гӮ’жӢ…еҪ“гҒ•гҒӣгҒҰгҒ„гҒҹгҒ гҒҚгҖҒжӢ…еҪ“еә—иҲ—гҒ®йҒӢе–¶е…ЁиҲ¬гӮ’д»»гҒ•гӮҢгҒҫгҒ—гҒҹгҖӮгҒ©гҒҶгӮ„гҒЈгҒҰеЈІдёҠгӮ’дҪңгӮӢгҒ®гҒӢдёҖгҒӢгӮүиҖғгҒҲгҖҒеЈІгӮҠе ҙгҒ§гҒ®еӮ¬гҒ—гӮ’иЎҢгҒ„гҖҒгҒҠе®ўж§ҳгҒЁеҸ–еј•е…ҲгҒ«е–ңгӮ“гҒ§гӮӮгӮүгҒҶгҒ“гҒЁгӮ’иҖғгҒҲд»•дәӢгӮ’йҖІгӮҒгҒҫгҒ—гҒҹгҖӮ<br />\r\n<br />\r\nгҒ“гҒ®д»•дәӢгӮ’йҖҡгҒ—гҒҰдёҖз•ӘеҚ°иұЎгҒ«ж®ӢгҒЈгҒҹгҒ“гҒЁгҒҜгҖҒй«ҳйЎҚе•Ҷе“ҒгҒ®иІ©еЈІгҒ«жҗәгӮҸгӮӢгҒ“гҒЁгҒҢгҒӮгӮҠгҖҒгҒҠе®ўж§ҳгҒӢгӮүдҝЎй јгӮ’еҸ—гҒ‘гҒ”жіЁж–ҮгӮ’гҒ„гҒҹгҒ гҒ„гҒҹдәӢгҒ§гҒҷгҖӮе•Ҷе“ҒгӮ’жҺўгҒ—гҒ«з”Јең°гҒёзӣҙжҺҘиөҙгҒҚиҮӘеҲҶгҒ®зӣ®гҒ§е•Ҷе“ҒгӮ’йҒёгҒігҖҒгҒҠе®ўж§ҳгҒёгҒ”жҸҗжЎҲгӮ’гҒ—гҒҰе•Ҷе“ҒгҒ®йӯ…еҠӣгӮ’дјқгҒҲгҒҫгҒ—гҒҹгҖӮгҒқгҒ—гҒҰиІ©еЈІгҒ«гҒӨгҒӘгҒҢгҒЈгҒҹжҷӮгҒ®йҒ”жҲҗж„ҹгҒҜд»–гҒ®д»•дәӢгҒ§гҒҜе‘ігӮҸгҒҲгҒӘгҒ„ж„ҹеӢ•гӮ’еҫ—гӮӢгҒ“гҒЁгҒҢгҒ§гҒҚгҒҫгҒ—гҒҹгҖӮ<br />\r\n<br />\r\nжңҖеҫҢгҒ«ж—Ҙжң¬дјқзөұж–ҮеҢ–гҒёгҒ®иІўзҢ®гҒЁгҒ„гҒҲгҒ°еӨ§гҒҚгҒӘи©ұгҒ§гҒҷгҒҢгҖҒзқҖзү©гҒ«гҒөгӮҢиҰӘгҒ—гҒҝзқҖзү©гҒ®йӯ…еҠӣгӮ’дёҖдәәгҒ§гӮӮеӨҡгҒҸгҒ®ж–№гҒ«зҹҘгҒЈгҒҰгҒ„гҒҹгҒ гҒҚгҒҹгҒ„гҒЁжҖқгҒ„гҒҫгҒҷгҖӮ\t\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\n\t\t\t\t\t\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t\t<div class=\"unit-seccatch-02\"><span>MEMBER</span></div>\n\t\t</div>\n\t</section>\n\n\t<!-- recruitпјҡsec05пјҡеӢҹйӣҶиҰҒй … -->\n\t<section class=\"under-recruit-sec05\">\n\t\t<div class=\"wrapper\">\n\t\t\t<h2 class=\"unit-title-04\">еӢҹйӣҶиҰҒй …</h2>\n\n\t\t\t<div id=\"youkou01\" class=\"box-youkou-01\">\n\n\t\t\t\t<h3 class=\"unit-title-06\">\n\t\t\t\t\t\t\t\t\t\t\tе–¶жҘӯ\t\t\t\t\t\t\t\t\t</h3>\n\t\t\t\t<p>\n\t\t\t\t\t\t\t\t\t\t\tгҖҖ\t\t\t\t\t\t\t\t\t</p>\n\n\t\t\t\t\t\t\t\t\t<table class=\"unit-filetbl-01\">\n\t\t\t\t\t\t<tbody>\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t\t\t<th>иҒ·еӢҷеҶ…е®№в‘ пјҲгғ•гӮЎгғғгӮ·гғ§гғідәӢжҘӯйғЁпјү</th>\n\t\t\t\t\t\t\t\t\t<td>гғ»гғ•гӮЎгғғгӮ·гғ§гғіиЈҪе“ҒгҒ®е°Ӯй–Җеә—гғ»йҮҸиІ©еә—гҒёгҒ®еҚёе–¶жҘӯ<br />\r\nгғ»OEMгҖҒODMгҒ®е–¶жҘӯе…јз”ҹз”Јз®ЎзҗҶ</td>\n\t\t\t\t\t\t\t\t</tr>\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t\t\t<th>иҒ·еӢҷеҶ…е®№в‘ЎпјҲгҒҚгӮӮгҒ®дәӢжҘӯйғЁпјү</th>\n\t\t\t\t\t\t\t\t\t<td>е’ҢиЈ…еҸҠгҒіе’ҢиЈ…е°Ҹзү©гҒ®зҷҫиІЁеә—еҸҠгҒіе°Ӯй–Җеә—гҒёгҒ®еҚёе–¶жҘӯ</td>\n\t\t\t\t\t\t\t\t</tr>\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t\t\t<th>иҒ·еӢҷеҶ…е®№в‘ўпјҲгғһгғҶгғӘгӮўгғ«дәӢжҘӯйғЁпјү</th>\n\t\t\t\t\t\t\t\t\t<td>гғ•гӮЎгғігӮ·гғјгғӨгғјгғіпјҲзіёпјүгҒ®еҚёе–¶жҘӯ<br />\r\nпјҲгӮўгғ‘гғ¬гғ«гғ–гғ©гғігғүгҒ®гғҮгӮ¶гӮӨгғҠгғјеҸҠгҒізіёе°Ӯй–Җе•ҶзӨҫгҒёгҒ®зҙ жқҗжҸҗжЎҲжҘӯеӢҷпјү</td>\n\t\t\t\t\t\t\t\t</tr>\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t\t\t<th>иҒ·еӢҷеҶ…е®№в‘ЈпјҲгғҳгғ«гӮ№гӮұгӮўйғЁпјү</th>\n\t\t\t\t\t\t\t\t\t<td>еҜқиЈ…иЈҪе“ҒгҒ®е–¶жҘӯиЈңеҠ©жҘӯеӢҷпјҲзҙҚжңҹз®ЎзҗҶгҖҒеңЁеә«з®ЎзҗҶгҖҒеҮәиҚ·з®ЎзҗҶпјү</td>\n\t\t\t\t\t\t\t\t</tr>\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t\t\t<th>еҝңеӢҹиіҮж ј</th>\n\t\t\t\t\t\t\t\t\t<td>иҒ·еӢҷеҶ…е®№в‘ гғ•гӮЎгғғгӮ·гғ§гғій–ўдҝӮгҒ®жҘӯз•ҢзөҢйЁ“иҖ…<br />\r\nиҒ·еӢҷеҶ…е®№в‘Ўе’ҢиЈ…й–ўдҝӮгҒ®жҘӯз•ҢзөҢйЁ“иҖ…<br />\r\nиҒ·еӢҷеҶ…е®№в‘ўзөҢйЁ“дёҚе•ҸгҖҒгғ•гӮЎгғғгӮ·гғ§гғігғ»з№Ҡз¶ӯй–ўдҝӮгҒ®жҘӯз•ҢзөҢйЁ“иҖ…е„ӘйҒҮ<br />\r\nиҒ·еӢҷеҶ…е®№в‘ЈзөҢйЁ“дёҚе•Ҹ</td>\n\t\t\t\t\t\t\t\t</tr>\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t\t\t<th>еӢӨеӢҷең°</th>\n\t\t\t\t\t\t\t\t\t<td>иҒ·еӢҷеҶ…е®№в‘ жқұдә¬дәӢеӢҷжүҖгҖҒзҰҸеІЎдәӢеӢҷжүҖ<br />\r\nиҒ·еӢҷеҶ…е®№в‘Ўжң¬зӨҫгҖҒдә¬йғҪдәӢеӢҷжүҖгҖҒзҰҸеІЎдәӢеӢҷжүҖ<br />\r\nиҒ·еӢҷеҶ…е®№в‘ўжң¬зӨҫгҖҒеӨ§йҳӘдәӢеӢҷжүҖ<br />\r\nиҒ·еӢҷеҶ…е®№в‘ЈеҺҡжңЁдәӢеӢҷжүҖ</td>\n\t\t\t\t\t\t\t\