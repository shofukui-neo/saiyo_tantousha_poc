ータ\n    page = null;\n\n    lastPage = null;\n\n    initialParams = {\n      page: null,\n      category: null,\n      year: null,\n      month: null,\n    };\n\n    // 標準設定値\n    defaults = {\n      entry_id: -1,\n      encd_start: \"\",\n      encd_end: \"\",\n      jsonUrl: [],\n      limit: 3, // 1ページに表示する上限\n      listSelector: '#recommended_products'\n    }\n\n    // 設定値（標準設定値とユーザー設定値をマージしたもの。ユーザー設定値が優先）\n    settings = {};\n\n    constructor() {\n      // 標準設定値とユーザー設定値のマージ\n      if (window.recoPdListSettings) {\n        this.settings = $.extend({}, this.defaults, window.recoPdListSettings);\n        this.settings.jsonUrl = window.recoPdListSettings.jsonUrl;\n      } else {\n        this.settings = this.defaults;\n      }\n    }\n\n    // 複数ファイルのJSONをマージ\n    margeJSON(data) {\n      const result = [];\n\n      // 複数のエントリーの配列を一つにまとめる\n      data.forEach((json) => {\n        json.map((entry) => {\n          if (entry.id != this.settings.entry_id) { //対象ページと対応する記事は含めない。\n            result.push(entry);\n          }\n        });\n      });\n\n      //配列の重複要素の削除.\n      const result2nd = Array.from(\n        new Map(result.map((entry) => [entry.id, entry])).values()\n      );\n\n      // 公開日順でソート\n      result2nd.sort((a, b) => {\n        const dateA = a.date.replace(/\\./g, '');\n        const dateB = b.date.replace(/\\./g, '');\n        return dateA > dateB ? -1 : 1;\n      });\n\n      this.responseData = result2nd;\n    }\n\n    // 取得したオブジェクトから表示対象のものを抽出する。\n    filterEntry() {\n\n      const result = [];\n\n      let comp_date_start, comp_date_end;\n\n      comp_date_start = this.settings.encd_start.replace(/[^0-9]/g,'');\n      if ( this.settings.encd_end != '' ){\n        comp_date_end = this.settings.encd_end.replace(/[^0-9]/g,'');        \n      }\n      else {\n        comp_date_end = comp_date_start;\n      }\n\n      this.responseData.forEach((entry) => {\n\n        let target_date_start, target_date_end;\n\n        target_date_start = entry.encd_start.replace(/[^0-9]/g,'');\n        if ( entry.encd_end != '' ){\n          target_date_end = entry.encd_end.replace(/[^0-9]/g,'');        \n        }\n        else {\n          target_date_end = target_date_start;\n        }\n\n        if( comp_date_end >= target_date_start && target_date_end >= comp_date_start) {\n            result.push(entry);\n        }\n      });\n\n        this.data = result;\n        //console.log( `filterEntry:this.data = ${JSON.stringify(this.data)}` );\n    }\n\n    createDateLabel( date ){\n      let label__date = '';\n      label__date = date;\n      return label__date;\n    }\n\n    /*\n     * 記事リストの生成\n     */\n    createListHTML() {\n      if (!this.data.length) {\n        $(this.settings.listSelector).html('現在関連するおすすめの商品はありません。');\n        return;\n      }\n\n      const from = 0;\n      let to = this.settings.limit;\n      if ( to > this.data.length ){\n        to = this.data.length;\n      }\n      const list = [];\n\n      for (let i = 0; i < to; i++) {\n        const entry = this.data[i];\n\n        list.push(\n          `<li class=\"ArticleDetail__topicsItem\" data-id=\"4839\">\n            <a class=\"ArticleDetail__topicsLink\" href=\"${entry.permalink}\" ${entry.ext_link == true ? 'target=\"_blank\"' : ''}>\n                <p class=\"ArticleDetail__thumbnail\">\n                    <img src=\"${entry.thumb1_url}\" alt=\"\" class=\"ArticleDetail__topicsImage\">\n                </p><!-- .ArticleDetail__thumbnail -->\n              <div class=\"ArticleDetail__topicsContent\">\n                <h3 class=\"ArticleDetail__topicsTitle\">${entry.title}</h3><!-- .ArticleDetail__topicsTitle -->\n                  <p class=\"ArticleDetail__topicsText\">${entry.detail_text}</p><!-- .ArticleDetail__topicsText -->\n              </div><!-- .ArticleDetail__topicsContent -->\n            </a>\n          </li>`);\n      }\n\n      if (list.length) {\n        const html = '<ul class=\"ArticleDetail__topicsList\">' + list.join('') + '</ul>';\n        $(this.settings.listSelector).html(html);\n      }\n    }\n\n    /*\n     * ページの描画\n     */\n    render() {\n      this.filterEntry();\n      this.createListHTML()\n    }\n\n    /*\n    * アプリケーション初期化\n    */\n    init() {\n      Promise.all(\n        this.settings.jsonUrl.map((path) => {\n          return $.ajax({\n            'url': path,\n            cache: false,\n          });\n        })\n      ).then((data) => {\n        console.log( `jsonUrl = ${JSON.stringify(this.settings.jsonUrl)}` );\n        //console.log( `data = ${JSON.stringify(data)}` );\n        this.margeJSON(data);\n        this.render(true);\n\n      }).catch((error) => {\n        $(this.settings.listSelector).html(`<p>データの読み込みに失敗しました。</p>`);\n        console.error(error);\n      });\n    }\n  }\n\n  // DOMContentLoadedでアプリケーション起動\n  $(() => {\n    const recoPdList = new RecommendedProductsList();\n    recoPdList.init();\n  });\n}(jQuery));\n\n</script>\n\n\n  <script src=\"/common/js/sns.js\"></script>\n  \n<script>\n(function(i,s,o,g,r,a,m){i['GoogleAnalyticsObject']=r;i[r]=i[r]||function(){\n(i[r].q=i[r].q||[]).push(arguments)},i[r].l=1*new Date();a=s.createElement(o),\nm=s.getElementsByTagName(o)[0];a.async=1;a.src=g;m.parentNode.insertBefore(a,m)\n})(window,document,'script','https://www.google-analytics.com/analytics.js','ga');\n\n\n\nga('create', 'UA-34415336-1', 'auto');\n\n\nga(\"send\", \"pageview\");\n</script>\n\n\n\n<!-- リマーケティング タグの Google コード -->\n<script type=\"text/javascript\">\n  /* <![CDATA[ */\n  var google_conversion_id = 949569730;\n  var google_custom_params = window.google_tag_params;\n  var google_remarketing_only = true;\n  /* ]]> */\n</script>\n<span class=\"height_zero\">\n  <script type=\"text/javascript\" src=\"//www.googleadservices.com/pagead/conversion.js\"></script>\n</span>\n<noscript>\n  <div style=\"display:inline;\">\n      <img height=\"1\" width=\"1\" style=\"border-style:none;\" alt=\"\" src=\"//googleads.g.doubleclick.net/pagead/viewthroughconvers