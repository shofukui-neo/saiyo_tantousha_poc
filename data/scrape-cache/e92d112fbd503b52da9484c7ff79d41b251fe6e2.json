                         <li><a href=\"#\">働き方</a></li>\r\n                            </ul>\r\n                        </div>\r\n                    </div>\r\n                </section><!-- breadcrumb  -->\r\n            <section class=\"mv-main\">\r\n              <div class=\"mv-main__bg\">\r\n                <div class=\"mv-main__head\">\r\n                  <div class=\"text\">\r\n                    <div class=\"inner\">\r\n                      <div class=\"text-wrap\">\r\n                        <h2 class=\"subtitle\">働き方</h2>\r\n                      </div>\r\n                    </div>\r\n                  </div>\r\n                </div>\r\n               </div>\r\n            </section>\r\n    <!-- mv-main  -->\r\n                <section class=\"senior-employees\">\r\n                    <div class=\"senior-employees__bg\">\r\n                        <div class=\"inner\">\r\n                  <div class=\"content\">\r\n                      <p class=\"lead_sentence\">印刷で、想いを描く。<br>\r\n最高の「モノつくり」の現場で、たくさんの仲間が待っています。</p>\r\n                  </div>\r\n\r\n                            <div class=\"senior-employees__body\">\r\n                                   <h3 class=\"title\">エンジニア</h3>\r\n                                       <h4 class=\"item__title\">モノつくりの現場の最適化</h4>\r\n                                         <p class=\"senior-employees_lead\">生産現場への新しい技術・システムの導入、データの保守･管理を担います。モノつくりの現場に入り込んでオペレーターと密に関わりながら要望をくみ取り、作業工程の最適化、生産の効率化のための改善活動を行います。</p>\r\n\r\n\r\n                                <div class=\"items\">\r\n                                    <a class=\"item\" href=\"/recruit/person/06.html\">\r\n                                        <div class=\"thumb\"><img src=\"img/recruit_person01.jpg\" alt=\"古賀 仁 セキュア 朝霞工場\"></div>\r\n                                    </a>\r\n\r\n                                    <a class=\"item\" href=\"/recruit/person/15.html\">\r\n                                        <div class=\"thumb\"><img src=\"img/recruit_person02.jpg\" alt=\"山本 怜生 セキュア 朝霞工場\"></div>\r\n                                    </a>\r\n\r\n                                    <a class=\"item\" href=\"/recruit/person/14.html\">\r\n                                        <div class=\"thumb\"><img src=\"img/recruit_person03.jpg\" alt=\"村田 直斗 デジタル印刷 坂戸工場\"></div>\r\n                                    </a>\r\n                                </div>\t\t\t\t\t\t\t\t\t\r\n\t\t\t\t\t\t\t\t\t\r\n\r\n\r\n                                   <h3 class=\"title\">オペレーター</h3>\r\n                                       <h4 class=\"item__title\">モノつくりの最前線</h4>\r\n                                         <p class=\"senior-employees_lead\">業務を通じて、くらしに身近な製品の製造や生活に不可欠なサービスの提供に携わります。安全の確保、品質の担保を行いながら製造現場での機械の操作や委託業務に関するデータの入力･作成、進行管理など、生産オペレーションを担います。</p>\r\n\r\n                                <div class=\"items\">\r\n                                    <a class=\"item\" href=\"/recruit/person/17.html\">\r\n                                        <div class=\"thumb\"><img src=\"img/recruit_person17.jpg\" alt=\"大石 叶夢 BPO 朝霞工場\"></div>\r\n                                    </a>\r\n\t\t\t\t\t\t\t\t\t\r\n                                    <a class=\"item\" href=\"/recruit/person/18.html\">\r\n                                        <div class=\"thumb\"><img src=\"img/recruit_person18.jpg\" alt=\"髙橋 真希 セキュア 朝霞工場\"></div>\r\n                                    </a>\r\n\t\t\t\t\t\t\t\t\t\r\n                                    <a class=\"item\" href=\"/recruit/person/19.html\">\r\n                                        <div class=\"thumb\"><img src=\"img/recruit_person19.jpg\" alt=\"鞘脇 脩斗 セキュア 嵐山工場\"></div>\r\n                                    </a>\r\n\t\t\t\t\t\t\t\t\t\r\n                                    <a class=\"item\" href=\"/recruit/person/20.html\">\r\n                                        <div class=\"thumb\"><img src=\"img/recruit_person20.jpg\" alt=\"須田 駿之介 DPS 滝山工場\"></div>\r\n                                    </a>\r\n\t\t\t\t\t\t\t\t\t\r\n                                    <a class=\"item\" href=\"/recruit/person/21.html\">\r\n                                        <div class=\"thumb\"><img src=\"img/recruit_person21.jpg\" alt=\"青木 真桜 DPS 福生工場\"></div>\r\n                                    </a>\r\n\t\t\t\t\t\t\t\t\t\r\n                                    <a class=\"item\" href=\"/recruit/person/22.html\">\r\n                                        <div class=\"thumb\"><img src=\"img/recruit_person22.jpg\" alt=\"小林 裕也 DPS 城東センター\"></div>\r\n                                    </a>\r\n\r\n                                    <a class=\"item\" href=\"/recruit/person/07.html\">\r\n                                        <div class=\"thumb\"><img src=\"img/recruit_person08.jpg\" alt=\"新谷 隆英 デジタル印刷 札幌工場\"></div>\r\n                                    </a>\r\n\t\t\t\t\t\t\t\t\t\r\n                                    <a class=\"item\" href=\"/recruit/person/11.html\">\r\n                                        <div class=\"thumb\"><img src=\"img/recruit_person09.jpg\" alt=\"久保田 菖生 情報メディア 仙台工場\"></div>\r\n                                    </a>\r\n\t\t\t\t\t\t\t\t\t\r\n                                    <a class=\"item\" href=\"/recruit/person/25.html\">\r\n                                        <div class=\"thumb\"><img src=\"img/recruit_person25.jpg\" alt=\"麻生 めぐみ DPS 袋井工場\"></div>\r\n                                    </a>\r\n\t\t\t\t\t\t\t\t\t\r\n                                    <a class=\"item\" href=\"/recruit/person/16.html\">\r\n                                        <div class=\"thumb\"><img src=\"img/recruit_person10.jpg\" alt=\"加藤 文 情報メディア 名古屋工場\"></div>\r\n                                    </a>\r\n\t\t\t\t\t\t\t\t\t\r\n                                    <a class=\"item\" href=\"/recruit/person/23.html\">\r\n                                        <div class=\"thumb\"><img src=\"img/recruit_person23.jpg\" alt=\"白石 光聖 DPS 大阪工場\"></div>\r\n                    