src=https://prod-storage-tl-s3.s3.ap-northeast-1.amazonaws.com/egoh86tcvdmly2mg7vi43x7pmxju alt=\"\"/>\n    </li>\n\n    <li class=\"show \">\n      <img src=https://prod-storage-tl-s3.s3.ap-northeast-1.amazonaws.com/m6diaovdecl1xrirll3a04beor1j alt=\"\"/>\n    </li>\n</ul>\n  <div class=\"mv_text t_align_center \">\n    <div>\n      <h2 style=\"font-size: 44.4167px; word-break: break-word;\" class=\"align-center\">&nbsp;</h2>\n      <p style=\"word-break: break-word;\" class=\"static align-center\" >&nbsp;</p>\n    </div>\n  </div>\n  <div class=\"mv_nav\">\n    <div class=\"mv_scroll\"><a href=\"#main\" draggable=\"false\">SCROLL DOWN</a></div>\n    <ul class=\"mv_pointer\"></ul>\n    <ul class=\"mv_arrow\">\n      <li class=\"mv_arrow_prev\"><span>Forward</span></li>\n      <li class=\"mv_arrow_next\"><span>next</span></li>\n    </ul>\n  </div>\n</div>\n\n  </div>\n<main id=\"main\">\n        <a id=\"\"></a>\n<section class=\"width_fixed  pt60 pb60 composite_box01 align-left block_images_7 blockarea edit_outer editing block_image_text2 \"\n  style=\"background-repeat: no-repeat;background-position: center center;background-size: auto;\">\n  <div class=\"content_wrapper\">\n    \n\n    <div class=\"wrapper_item\">\n          <div class=\"inner_item\">\n    <div class=\"inner_item_container\" href=\"/d-ts/business.html\" target=\"_self\" style=\"\">\n      <a class=\"target_link\" href=\"/d-ts/business.html\" target=\"_self\"></a>\n        <div class=\"inner_item_img\" style=\"cursor: pointer;\">\n          <picture>\n            <source type=\"image/webp\" srcset=\"https://prod-storage-tl-s3.s3.ap-northeast-1.amazonaws.com/xos8ork46w3zxgrsvb57ekgpy026\">\n            <img alt=\"\" src=\"https://prod-storage-tl-s3.s3.ap-northeast-1.amazonaws.com/xos8ork46w3zxgrsvb57ekgpy026\" loading=\"lazy\" />\n          </picture>\n        </div>\n      <div class=\"inner_item_txt\" >\n          <div class=\"heading block_header_4 align-center\">\n            <h3 class=\"h\">事業内容</h3>\n            <p>business</p>\n          </div>\n        <p></p>\n      </div>\n    </div>\n</div>\n\n          <div class=\"inner_item\">\n    <div class=\"inner_item_container\" href=\"/d-ts/machine.html\" target=\"_self\" style=\"\">\n      <a class=\"target_link\" href=\"/d-ts/machine.html\" target=\"_self\"></a>\n        <div class=\"inner_item_img\" style=\"cursor: pointer;\">\n          <picture>\n            <source type=\"image/webp\" srcset=\"https://prod-storage-tl-s3.s3.ap-northeast-1.amazonaws.com/c8ly5ut83xurnxrdc5raepxr254m\">\n            <img alt=\"\" src=\"https://prod-storage-tl-s3.s3.ap-northeast-1.amazonaws.com/c8ly5ut83xurnxrdc5raepxr254m\" loading=\"lazy\" />\n          </picture>\n        </div>\n      <div class=\"inner_item_txt\" >\n          <div class=\"heading block_header_4 align-center\">\n            <h3 class=\"h\">主要機器</h3>\n            <p>machine</p>\n          </div>\n        <p></p>\n      </div>\n    </div>\n</div>\n\n    </div>\n  </div>\n</section>\n\n  \n    <a id=\"\"></a>\n<section class=\"contents_box01 block_text_1 blockarea edit_outer editing block_text   width_fixed pt60 pb30\"\n  style=\"background-color: rgba(245, 245, 245, 1);background-repeat: no-repeat;background-position: center center;background-size: auto;\">\n  <div class=\"content_wrapper\">\n    <div class=\"heading block_header_0 align-left \">\n    </div>\n    <div class=\"wrapper_item\">\n      <div class=\"inner_item_txt\">\n        <p><font face=\"Yu Gothic Medium\"><span style=\"font-size: 48px;\">Business</span></font></p>\n\n      </div>\n    </div>\n  </div>\n</section>\n\n  \n    \n<a id=\"\"></a>\n<section class=\"contents_box01 align-left block_image_text_9  w40 blockarea edit_outer editing block_image_text  width_fixed pt60 pb60\"\n  style=\"background-color: rgba(245, 245, 245, 1);background-repeat: no-repeat;background-position: center center;background-size: auto;\">\n  <div class=\"content_wrapper\">\n    \n\n    <div class=\"wrapper_item\" style=\"padding-bottom: 0\">\n      <div class=\"inner_item_img\">\n        <a href=\"https://prod-storage-tl-s3.s3.ap-northeast-1.amazonaws.com/savxv2ctdnyjr3mdfopk56933zkw\" style=\"pointer-events: none\" target=\"_self\" data-is-image=true>\n          <picture>\n            <img alt=\"\" src=\"https://prod-storage-tl-s3.s3.ap-northeast-1.amazonaws.com/savxv2ctdnyjr3mdfopk56933zkw\" loading=\"lazy\" />\n          </picture>\n        </a>\n      </div>\n\n      <div class=\"inner_item_txt align-left\">\n          <div class=\"heading block_header_2 data-target=\"1\">\n            <h3 class=\"headline-image-text-block\">最先端技術を用いた「測量」で<br>人々の暮らしの安心・安全を守るサービスです。<br></h3>\n            <p class=\"pre-wrap\">D-Cloud Insight</p>\n          </div>\n        <div class=\"\">\n          <p><span style=\"font-size:16px;\">当社では、3次元データの活用を計測サービスで総合支援する【</span>D-Cloud Insight<span style=\"font-size:16px;\">】を展開しています。<br />\n土木工事の施工現場におけるデータ活用はもちろん、危険箇所や、災害発生直後の現場調査等、小型無人航空機を活用した空撮（静止画・動画撮影）を実施。<br />\n適性に活用できる制度の高い計測サービスで、3次元データ活用を総合支援しています。</span><br />\n<br />\n<a class=\"btn01\" href=\"https://www.d-ts.jp/business/dcloudinsight.html\">詳しく見る</a></p>\n\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n  \n    \n<a id=\"\"></a>\n<section class=\"contents_box01 align-left block_image_text_10  w40 blockarea edit_outer editing block_image_text  width_fixed pt60 pb60\"\n  style=\"background-repeat: no-repeat;background-position: center center;background-size: auto;\">\n  <div class=\"content_wrapper\">\n    \n\n    <div class=\"wrapper_item\" style=\"padding-bottom: 0\">\n      <div class=\"inner_item_img\">\n        <a href=\"https://prod-storage-tl-s3.s3.ap-northeast-1.amazonaws.com/pttbbquhzrghneggx0dxd63jtit7\" style=\"pointer-events: none\" target=\"_self\" data-is-image=true>\n          <picture>\n            <img alt=\"\" src=\"https://prod-storage-tl-s3.s3.ap-northeast-1.amazonaws.com/pttbbquhzrghneggx0dxd63jtit7\" loading=\"lazy\" />\n          </picture>\n        </a>\n      </div>\n\n      <div class=\"inner_item_txt align-left\">\n          <div class=\"heading block_header_2 data-target=\"1\">\n            <h3 class=\"headline-image-text-block\">土木・建築のはじめの一歩を支える<br>高精度な地質調査をご提供します。<br></h3>\n            <p class=\"pre-wrap\">地質調査</p>\n          </div>\n        <div class=\"\">\n          <p><span style=\"font-size:16px;\">建設現場での調査のほか、災害時の地質調査も行っています。<br />\n現場の進捗や人々の安全に直結する地質調査。<br />\n当社では創業以来培ってきたノウハウと最新技術で、高精度な地質調査結果をご提供できる体制を整えています。</span><br />\n<br />\n<a class=\"btn01\" href=\"https://www.d-ts.jp/business/geologicalsurvey.html\">詳しく見る</a></p>\n\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n  \n    \n<a id=\"\"></a>\n<section class=\"contents_box01 align-left block_image_text_10  w40 blockarea edit_outer editing block_image_text  width_fixed pt60 pb60\"\n  style=\"background-repeat: no-repeat;background-position: center center;background-size: auto;\">\n  <div class=\"content_wrapper\">\n    \n\n    <div class=\"wrapper_item\" style=\"padding-bottom: 0\">\n      <div class=\"inner_item_img\">\n        <a href=\"https://prod-storage-tl-s3.s3.ap-northeast-1.amazonaws.com/s1u6rwkgj1f3cj9gv6m0rbsxugbu\" style=\"pointer-events: none\" target=\"_self\" data-is-image=true>\n          <picture>\n            <img alt=\"\" src=\"https://prod-storage-tl-s3.s3.ap-northeast-1.amazonaws.com/s1u6rwkgj1f3cj9gv6m0rbsxugbu\" loading=\"lazy\" />\n          </picture>\n        </a>\n      </div>\n\n      <div class=\"inner_item_txt align-left\">\n          <div class=\"heading block_header_2 data-target=\"1\">\n            <h3 class=\"headline-image-text-block\"></h3>\n            <p class=\"pre-wrap\">設計</p>\n          </div>\n        <div class=\"\">\n          <p><span style=\"font-size:16px;\">当社が得意とする三次元計測による地形図を用いて、道路や橋梁設計技術者が三次元CADを使った設計を行います。 地域の人々に&rdquo;よりわかりやすく&rdquo;作成することが腕の見せどころ。 またこれからのインフラの維持管理に欠かせない「点検」もドローンとAIによる先進的な取り組みを積極的に実施してます。</span><br />\n<br />\n<a class=\"btn01\" href=\"https://www.d-ts.jp/business/roaddesign.html\">詳しく見る</a></p>\n\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n  \n    <a id=\"\"></a>\n<section class=\"contents_box01 block_text_1 blockarea edit_outer editing block_text   width_fixed pt60 pb30\"\n  style=\"background-color: rgba(245, 245, 245, 1);background-repeat: no-repeat;background-position: center center;background-size: auto;\">\n  <div class=\"content_wrapper\">\n    <div class=\"heading block_header_0 align-left \">\n    </div>\n    <div class=\"wrapper_item\">\n      <div class=\"inner_item_txt\">\n        <p><span style=\"font-family:Yu Gothic Medium;\"><span style=\"font-size:48px;\">Recruit</span></span></p>\n\n      </div>\n    </div>\n  </div>\n</section>\n\n  \n    \n<a id=\"\"></a>\n<section class=\"contents_box01 align-left block_image_text_4  w40 blockarea edit_outer editing block_image_text  width_fixed pt10 pb60\"\n  style=\"background-color: rgba(245, 245, 245, 1);background-repeat: no-repeat;background-position: center center;background-size: auto;\">\n  <div class=\"content_wrapper\">\n    \n\n    <div class=\"wrapper_item\" style=\"padding-bottom: 0\">\n      <div class=\"inner_item_img\">\n        <a href=\"https://prod-storage-tl-s3.s3.ap-northeast-1.amazonaws.com/5t56xw05qavfsk6pdva8jwx70r4p\" style=\"pointer-events: none\" target=\"_self\" data-is-image=true>\n          <picture>\n            <img alt=\"\" src=\"https://prod-storage-tl-s3.s3.ap-northeast-1.amazonaws.com/5t56xw05qavfsk6pdva8jwx70r4p\" loading=\"lazy\" />\n          </picture>\n        </a>\n      </div>\n\n      <div class=\"inner_item_txt align-left\">\n          <div class=\"heading block_header_2 data-target=\"1\">\n            <h3 class=\"headline-image-text-block\">あなたも<br>「暮らしの土台を守る」一員へ。<br></h3>\n            <p class=\"pre-wrap\"></p>\n          </div>\n        <div class=\"\">\n          <p><span style=\"font-size: 16px;\">県下、東北でトップクラスの建設コンサルタントとして、創業以来着実に歩みを進めてきた当社。<br />\n官公庁をはじめ、多くの取引先から厚い信頼を得るプロフ