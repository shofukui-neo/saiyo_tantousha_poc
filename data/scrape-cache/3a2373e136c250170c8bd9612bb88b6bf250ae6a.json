            </div>\n                    <!-- /.menuSectionItem -->\n                    <div class=\"menuSectionItem\">\n                        <a href=\"https://hi-niyaku.co.jp/sdgs/\">\n                            <div class=\"menuSectionItem_title\">SDGsの取組</div>\n                        </a>\n                    </div>\n                    <!-- /.menuSectionItem -->\n\n                    <div class=\"menuSectionItem\">\n                        <a href=\"https://hi-niyaku.co.jp/contact/\">\n                            <div class=\"menuSectionItem_title\">お問い合せ</div>\n                        </a>\n                    </div>\n                    <!-- /.menuSectionItem -->\n\n                    <div class=\"menuSectionItem\">\n                        <a href=\"https://hi-niyaku.co.jp/sitemap/\">\n                            <div class=\"menuSectionItem_title\">サイトマップ</div>\n                        </a>\n                    </div>\n                    <!-- /.menuSectionItem -->\n\n                </div>\n\n            </div>\n        </div>\n        <!-- /.menuContainer -->\n\n<div class=\"commonTitle\">\n    <div class=\"container\">\n        <h1 class=\"commonTitle_title commonTitle_title-03\"><img src=\"https://hi-niyaku.co.jp/wp-content/themes/niyaku-theme/cmn/img/recruit/pic_titlte.png?v=202601260546\" alt=\"\"></h1>\n        <div class=\"commonTitle_info\">求人お問い合わせ</div>\n    </div>\n</div>\n<!-- /.commonTitle -->\n\n<div class=\"pnkz\">\n    <div class=\"container\">\n        <ul class=\"pnkz_list\">\n            <li><a href=\"https://hi-niyaku.co.jp/\">トップ</a></li>\n            <li class=\"active\">求人お問い合わせ</li>\n        </ul>\n    </div>\n</div>\n<!-- /.pnkz -->\n\n<div class=\"formContainer\">\n    <div class=\"container\">\n        <div class=\"contactHead\">\n            <div class=\"contactHead_title\">お電話での<span class=\"spBr\"></span>お問い合わせ</div>\n            <div class=\"contactHeadMain\">\n                <div class=\"contactHeadMain_item\">\n                    <span class=\"contactHeadMain_item-01\">（代）</span>\n                    <span><img src=\"https://hi-niyaku.co.jp/wp-content/themes/niyaku-theme/cmn/img/contact/pic_tel_01.png?v=202601260546\" alt=\"総務部\"></span>\n                    <span class=\"contactHeadMain_item-02\">（総務部）</span>\n                </div>\n            </div>\n            <!-- /.contactHeadMain -->\n\n            <div class=\"contactHead_title\">採用エントリー<span class=\"spBr\"></span>フォーム</div>\n\n            <div class=\"contactHead_text\">\n広島荷役株式会社に入社をご希望の方は下記のフォームからご応募ください。<br>\n万一メールが届かない場合には、お電話にてお問い合わせ下さい。<br>\n<strong>※印の項目は必ずご記入ください。</strong></div>\n        </div>\n        <!-- /.contactHead -->\n\n        <div class=\"formContainer_main\">\n                                    <div class=\"formContainer_main-inner\">\n                <div id=\"mw_wp_form_mw-wp-form-37\" class=\"mw_wp_form mw_wp_form_input  \">\n\t\t\t\t\t<form method=\"post\" action=\"\" enctype=\"multipart/form-data\"><dl class=\"formContainer_item\">\r\n<dt>希望職種<span class=\"formContainer_item-hissu\">※</span></dt>\r\n<dd class=\"formContainer_select\">\r\n<div class=\"formContainer_select-inner\">\n<select name=\"希望職種\" >\n\t\t\t<option value=\"\" selected='selected'>\n\t\t\t\t\t</option>\n\t\t\t<option value=\"営業部\" >\n\t\t\t営業部\t\t</option>\n\t\t\t<option value=\"港運部\" >\n\t\t\t港運部\t\t</option>\n\t\t\t<option value=\"総務部\" >\n\t\t\t総務部\t\t</option>\n\t\t\t<option value=\"専門・技能職チーム\" >\n\t\t\t専門・技能職チーム\t\t</option>\n\t\t\t<option value=\"大型ドライバー（要けん引）\" >\n\t\t\t大型ドライバー（要けん引）\t\t</option>\n\t</select>\n\n<input type=\"hidden\" name=\"__children[希望職種][]\" value=\"{&quot;&quot;:&quot;&quot;,&quot;\\u55b6\\u696d\\u90e8&quot;:&quot;\\u55b6\\u696d\\u90e8&quot;,&quot;\\u6e2f\\u904b\\u90e8&quot;:&quot;\\u6e2f\\u904b\\u90e8&quot;,&quot;\\u7dcf\\u52d9\\u90e8&quot;:&quot;\\u7dcf\\u52d9\\u90e8&quot;,&quot;\\u5c02\\u9580\\u30fb\\u6280\\u80fd\\u8077\\u30c1\\u30fc\\u30e0&quot;:&quot;\\u5c02\\u9580\\u30fb\\u6280\\u80fd\\u8077\\u30c1\\u30fc\\u30e0&quot;,&quot;\\u5927\\u578b\\u30c9\\u30e9\\u30a4\\u30d0\\u30fc\\uff08\\u8981\\u3051\\u3093\\u5f15\\uff09&quot;:&quot;\\u5927\\u578b\\u30c9\\u30e9\\u30a4\\u30d0\\u30fc\\uff08\\u8981\\u3051\\u3093\\u5f15\\uff09&quot;}\" />\n</div></dd>\r\n</dl>\r\n<dl class=\"formContainer_item\">\r\n<dt>お名前（漢字）<span class=\"formContainer_item-hissu\">※</span></dt>\r\n<dd class=\"formContainer_size02\">\r\n\n<input type=\"text\" name=\"お名前（漢字）\" size=\"60\" value=\"\" placeholder=\"例：山田花子\" />\n\r\n</dd>\r\n</dl>\r\n<dl class=\"formContainer_item\">\r\n<dt>お名前（フリガナ）<span class=\"formContainer_item-hissu\">※</span></dt>\r\n<dd class=\"formContainer_size02\">\r\n\n<input type=\"text\" name=\"お名前（フリガナ）\" size=\"60\" value=\"\" placeholder=\"例：ヤマダハナコ\" />\n\r\n</dd>\r\n</dl>\r\n<dl class=\"formContainer_item\">\r\n<dt>性別<span class=\"formContainer_item-hissu\">※</span></dt>\r\n<dd class=\"formContainer_radio\">\t<span class=\"mwform-radio-field horizontal-item\">\n\t\t<label >\n\t\t\t<input type=\"radio\" name=\"性別\" value=\"男性\" />\n\t\t\t<span class=\"mwform-radio-field-text\">男性</span>\n\t\t</label>\n\t</span>\n\t<span class=\"mwform-radio-field horizontal-item\">\n\t\t<label >\n\t\t\t<input type=\"radio\" name=\"性別\" value=\"女性\" />\n\t\t\t<span class=\"mwform-radio-field-text\">女性</span>\n\t\t</label>\n\t</span>\n\n<input type=\"hidden\" name=\"__children[性別][]\" value=\"{&quot;\\u7537\\u6027&quot;:&quot;\\u7537\\u6027&quot;,&quot;\\u5973\\u6027&quot;:&quot;\\u5973\\u6027&quot;}\" />\n</dd>\r\n</dl>\r\n<dl class=\"formContainer_item\">\r\n<dt>生年月日(歳)<span class=\"formContainer_item-hissu\">※</span></dt>\r\n<dd>\r\n<div class=\"formContainer_year\">\r\n<div class=\"formContainer_yearitem formContainer_yearitem-01\">西暦 \n<input type=\"text\" name=\"西暦\" size=\"60\" value=\"\" />\n 年</div>\r\n<div class=\"formContainer_yearitem formContainer_yearitem-02\">\n<input type=\"text\" name=\"月\" size=\"60\" value=\"\" />\n 月</div>\r\n<div class=\"formContainer_yearitem formContainer_yearitem-03\">\n<input type=\"text\" name=\"日\" size=\"60\" value=\"\" />\n 日</div>\r\n<div class=\"formContainer_yearitem formContainer_yearitem-04\">\n<input type=\"text\" name=\"歳\" size=\"60\" value=\"\" />\n 歳</div>\r\n</div>\r\n</dd>\r\n</dl>\r\n\r\n<dl class=\"formContainer_item\">\r\n<dt>郵便番号<span class=\"formContainer_item-hissu\">※</span></dt>\r\n<dd class=\"formContainer_size04\">\r\n\n<input type=\"text\" name=\"郵便番号\" size=\"60\" value=\"\" placeholder=\"例：734-0011\" />\n\r\n</dd>\r\n</dl>\r\n\r\n<dl class=\"formContainer_item\">\r\n<dt>市区町村<span class=\"formContainer_item-hissu\">※</span></dt>\r\n<dd class=\"formContainer_size02\">\r\n\n<input type=\"text\" name=\"市区町村\" size=\"60\" value=\"\" placeholder=\"例：広島市南区宇品海岸\" />\n\r\n</dd>\r\n</dl>\r\n\r\n<dl class=\"formContainer_item\">\r\n<dt>番地等<span class=\"formContainer_item-hissu\">※</span></dt>\r\n<dd class=\"formContainer_size02\">\r\n\n<input type=\"text\" name=\"番地等\" size=\"60\" value=\"\" placeholder=\"例：二丁目23番27号\" />\n\r\n</dd>\r\n</dl>\r\n\r\n<dl class=\"formContainer_item\">\r\n<dt>お電話番号<span class=\"formContainer_item-hissu\">※</span></dt>\r\n<dd class=\"formContainer_size04\">\r\n\n<input type=\"text\" name=\"お電話番号\" size=\"60\" value=\"\" placeholder=\"例：082-254-8889\" data-conv-half-alphanumeric=\"true\"/>\n\r\n</dd>\r\n</dl>\r\n<dl class=\"formContainer_item\">\r\n<dt>メールアドレス<span class=\"formContainer_item-hissu\">※</span></dt>\r\n<dd class=\"formContainer_size01\">\r\n\n<input type=\"text\" name=\"メールアドレス2\" size=\"60\" value=\"\" placeholder=\"例：example@example.com\" data-conv-half-alphanumeric=\"true\"/>\n\r\n</dd>\r\n</dl>\r\n<dl class=\"formContainer_item\">\r\n<dt>学歴<span class=\"formContainer_item-hissu\">※</span></dt>\r\n<dd>\r\n<div class=\"formContainer_size06\"><span>最終学歴</span>\n<input type=\"text\" name=\"最終学歴\" size=\"60\" value=\"\" />\n</div>\r\n<div class=\"formContainer_size06\"><span>卒業校</span>\n<input type=\"text\" name=\"卒業校\" size=\"60\" value=\"\" />\n</div>\r\n</dd>\r\n</dl>\r\n<dl class=\"formContainer_item\">\r\n<dt>職務経歴</dt>\r\n<dd>\r\n<div class=\"formContainer_size06\"><span>直前の勤務先</span>\n<input type=\"text\" name=\"直前の勤務先\" size=\"60\" value=\"\" />\n</div>\r\n<div class=\"formContainer_size06\"><span>在籍期間</span>\n<input type=\"text\" name=\"在籍期間\" size=\"60\" value=\"\" />\n</div>\r\n<div class=\"formContainer_size06\"><span>雇用形態</span>\n<input type=\"text\" name=\"雇用形態\" size=\"60\" value=\"\" />\n</div>\r\n<div class=\"formContainer_size06\"><span>主な職務内容</span>\n<input type=\"text\" name=\"主な職務内容\" size=\"60\" value=\"\" />\n</div>\r\n</dd>\r\n</dl>\r\n<dl class=\"formContainer_item\">\r\n<dt class=\"formContainer_item-dt\">備考</dt>\r\n<dd class=\"formContainer_textarea\">\r\n\n<textarea name=\"備考\" cols=\"50\" rows=\"5\" ></textarea>\n\r\n</dd>\r\n</dl>\r\n<div class=\"formBtnContainer\">\r\n<div class=\"formBtnContainer_inner\">\r\n<div class=\"formBtnContainer_submit formBtnContainer_submit-back\"></div>\r\n<div class=\"formBtnContainer_submit formBtnContainer_submit-next\">\n<input type=\"submit\" name=\"submitConfirm\" value=\"確認\" />\n</div>\r\n</div>\r\n</div><input type=\"hidden\" name=\"mw-wp-form-form-id\" value=\"37\" /><input type=\"hidden\" name=\"mw_wp_form_token\" value=\"f4689a557fdd9ae50d034ad2f12fcce9d6cdb673150699e23ddf19673878fa02\" /></form>\n\t\t\t\t<!-- end .mw_wp_form --></div>            </div>\n                    </div>\n\n    </div>\n\n</div>\n<!-- /.contactContainer -->\n\n\n\n<section class=\"aboutBtmNavi\">\n    <div class=\"container\">\n        <div class=\"aboutBtmNaviMain\">\n            <div class=\"aboutBtmNaviMain_item aboutBtmNaviMain_item-01\">\n                <a href=\"https://hi-niyaku.co.jp/recruit/\">\n                    <div class=\"aboutBtmNaviMain_item-inner\"><span>採用情報</span></div>\n                </a>\n            </div>\n            <div class=\"aboutBtmNaviMain_item aboutBtmNaviMain_item-02\">\n                <a href=\"https://hi-niyaku.co.jp/