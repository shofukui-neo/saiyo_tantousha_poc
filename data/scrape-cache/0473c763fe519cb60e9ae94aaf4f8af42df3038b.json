e=\"text/javascript\" src=\"/js/google_analytics.js\"></script>  <script src=\"../../common/js/jquery.backstretch.min.js\"></script>\r\n  <script>\r\n    $.backstretch(\"../bg.jpg\");\r\n  </script>\r\n  <script type=\"text/javascript\" src=\"../../../js/tab.js\"></script>\r\n<script src=\"../../../js/accordion.js\"></script>\r\n</body>\r\n\r\n</html>","finalUrl":"https://www.daiichi-kamotsu.co.jp/recruit/infomation/newgraduates/","rendered":false,"_cachedAt":"2026-06-17T23:06:50.143Z"}