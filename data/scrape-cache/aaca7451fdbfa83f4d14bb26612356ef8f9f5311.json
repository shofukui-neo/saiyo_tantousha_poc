{"url":"https://www.kohshin-grp.co.jp/recruit/outline/index.html","html":"<!doctype html>\n<html>\n<head>\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0, user-scalable=1\">\n<meta name=\"format-detection\" content=\"telephone=no\">\n<title>募集要項｜弘進ゴム株式会社</title>\n<meta name=\"description\" content=\"\">\n<meta property=\"og:description\" content=\"\">\n<meta property=\"og:title\" content=\"募集要項｜弘進ゴム株式会社\">\n<meta property=\"og:site_name\" content=\"弘進ゴム株式会社 RECRUIT SITE\">\n<meta property=\"og:url\" content=\"https://www.kohshin-grp.co.jp/\">\n<meta property=\"og:image\" content=\"https://www.kohshin-grp.co.jp/cmn/img/ogp.png\" />\n<meta property=\"og:type\" content=\"website\">\n<meta property=\"og:locale\" content=\"ja_JP\">\n<link rel=\"stylesheet\" type=\"text/css\" href=\"https://www.kohshin-grp.co.jp/recruit/cmn/css/import-recruit.css\" media=\"all\">\n</head>\n\n<body id=\"body\">\n\n<!-- header -->\n<header>\n<div class=\"header-wrapper\">\n<p id=\"logo\"><a href=\"https://www.kohshin-grp.co.jp/\"><img src=\"https://www.kohshin-grp.co.jp/recruit/cmn/img/logo-w.svg\" alt=\"弘進ゴム株式会社 RECRUIT SITE\"/></a></p>\n<ul class=\"gnavi\">\n<li><a href=\"https://www.kohshin-grp.co.jp/recruit/\">採用情報TOP</a></li>\n<li><a href=\"https://www.kohshin-grp.co.jp/recruit/outline/index.html\">募集要項</a></li>\n<li><a href=\"https://www.kohshin-grp.co.jp/recruit/interview/index.html\">社員インタビュー</a></li>\n<li><a href=\"https://www.kohshin-grp.co.jp/recruit/faq/index.html\">よくあるご質問</a></li>\n<li><a href=\"https://www.kohshin-grp.co.jp/company/history/index.html\">会社概要</a></li>\n</ul>\n<div id=\"menu\">\n<p id=\"sp_navi\"><p id=\"panel-btn\"><span id=\"panel-btn-icon\"></span></p></p>\n</div>\n</div>\n</header>\n<div class=\"header-padding\"></div>\n<!-- /header -->\n\n<!-- megamenu -->\n<nav id=\"megamenu\">\n<div class=\"inner\">\n<ul class=\"megamenu-1\">\n<li><a href=\"https://www.kohshin-grp.co.jp/recruit/\">採用情報TOP</a></li>\n<li><a href=\"https://www.kohshin-grp.co.jp/recruit/outline/index.html\">募集要項</a></li>\n<li><a href=\"https://www.kohshin-grp.co.jp/recruit/interview/index.html\">社員インタビュー</a></li>\n<li><a href=\"https://www.kohshin-grp.co.jp/recruit/faq/index.html\">よくあるご質問</a></li>\n<li><a href=\"https://www.kohshin-grp.co.jp/company/history/index.html\">会社概要</a></li>\n</ul>\n</div>\n</nav>\n<!-- /megamenu -->\n\n\n\n<!-- side-btn -->\n<div id=\"side-menu-pc\" class=\"sp_dispnone\">\n<div class=\"side-\"><a href=\"https://job.mynavi.jp/27/pc/search/corp238421/outline.html\" target=\"_blank\"><img src=\"https://job.mynavi.jp/conts/kigyo/2027/logo/banner_entry_160_45.gif\" alt=\"ENTRY\" width=\"160\" height=\"45\"></a></div>\n</div>\n<div id=\"side-menu-sp\" class=\"pc_dispnone\">\n<div class=\"side-\"><a href=\"https://job.mynavi.jp/27/pc/search/corp238421/outline.html\" target=\"_blank\"><img src=\"https://job.mynavi.jp/conts/kigyo/2027/logo/banner_entry_160_45.gif\" alt=\"ENTRY\" width=\"160\" height=\"45\"></a></div>\n</div>\n<!-- /side-btn -->\n\n<main>\n<section class=\"page-title-1 bg-recruit-outline\">\n<div class=\"sec-wrapper inner\">\n<h1 class=\"c-white-1\">募集要項</h1>\n<p class=\"catch\">OUTLINE</p>\n\n</div><!-- /sec-wrapper -->\n</section>\n\n<section class=\"page-navi-col-2\">\n<div class=\"inner\">\n<ul class=\"clearfix\">\n<li class=\"arrow-b\"><div><a href=\"#anchor-1\">募集要項</a></div></li>\n<li class=\"arrow-b\"><div><a href=\"#anchor-2\">選考プロセス</a></div></li>\n</ul>\n</div>\n</section>\n\n<section class=\"recruit-1 bg-white-1\">\n<div class=\"sec-wrapper pt50 pb50\">\n\n<h2 id=\"anchor-1\" class=\"heading-1 mb50\">2027年度新卒採用　<br class=\"pc_dispnone\">募集要項</h2>\n\n<table class=\"table-1 mb50\">\n<tbody>\n<tr>\n<th class=\"w20pc\">職種</th>\n<td class=\"w80pc\">\n\t営業・事務系／営業、営業企画、購買品管<br>\n\t技術系／化工品開発、設備技術\n</td>\n</tr>\n<tr>\n<th>雇用形態</th>\n<td>正社員（試用期間1ヵ月）</td>\n</tr>\n<tr>\n<th>給与</th>\n<td>\n修士了初任給　（月給）227,000円<br>\n学部卒初任給　（月給）215,300円<br>\n専門卒初任給　（月給）183,100円<br>\n高校卒初任給　（月給）170,900円\n</td>\n</tr>\n<tr>\n<th>諸手当</th>\n<td>家族手当、住宅手当、生活手当、地域手当、通勤手当（全額）、セールス手当など</td>\n</tr>\n<tr>\n<th>昇給</th>\n<td>年1回（4月）</td>\n</tr>\n<tr>\n<th>賞与</th>\n<td>年2回（6月、12月）</td>\n</tr>\n<tr>\n<th>勤務地</th>\n<td>本社および国内事業所所在地</td>\n</tr>\n<tr>\n<th>勤務時間</th>\n<td>\n8：45～17：30（本社・支店）<br>\n8：20～17：00（亘理工場）</td>\n</tr>\n<tr>\n<th>所定労働時間</th>\n<td>\n7.75時間（本社・支店）<br>\n7.59時間（亘理工場）\n</td>\n</tr>\n<tr>\n<th>時間外労働あり</th>\n<td>月平均2.0時間</td>\n</tr>\n<tr>\n<th>休日休暇</th>\n<td>\n年間休日116日（本社・支店）、111日（亘理工場）　※会社カレンダーに従う<br>\n（週休2日、日・祝日、夏季、年末年始、一斉年休取得日ほか）\n</td>\n</tr>\n<tr>\n<th>有給休暇</th>\n<td>\n試用期間後3日・6か月後+7日、最高で年間21日付与<br>\n（時間単位・半日取得可、年平均取得数19.0日、繰越消滅分再利用制度あり）<br>\n他、慶弔休暇、育児介護休暇、リフレッシュ休暇、バースデー休暇等あり\n</td>\n</tr>\n<tr>\n<th>保険</th>\n<td>雇用・労災・健康・厚生年金完備</td>\n</tr>\n<tr>\n<th>福利厚生</th>\n<td>借上げ社宅、財形貯蓄、保養所、仙台スポーツチーム年間シート保有、労働組合あり</td>\n</tr>\n<tr>\n<th>教育制度</th>\n<td>入社前事前研修、新入社員研修、メンター制度、階層別研修、自己啓発補助など</td>\n</tr>\n<tr>\n<th>提出書類</th>\n<td>履歴書、成績証明書、卒業（見込）証明書、修了見込証明書、WEBエントリーシート</td>\n</tr>\n</tbody>\n</table>\n\n<div class=\"box-1 mb50\">\n<div class=\"inner-25\">\n\n<div class=\"panel-col-3 clearfix\">\n\t<div class=\"cell-40\">\n\t\t<p class=\"bold xcenter f24 mt25 mb10\">問い合わせ／書類送付先</p>\n\t</div>\n\t<div class=\"cell-5\"></div>\n\t<div class=\"cell-55\">\n\t\t<p class=\"bold f18\">弘進ゴム株式会社　<br class=\"pc_dispnone\">総務部　採用担当</p>\n\t\t<p>TEL：022-214-3011（自動音声4番）</p>\n\t\t<p>FAX：022-214-6831</p>\n\t</div>\n</div>\n</div>\n</div>\n\n\n<h2 id=\"anchor-2\" class=\"heading-1 mb25\">選考プロセス</h2>\n<p>選考プロセスは以下のとおりです。</p>\n<p class=\"mb50\">※モデルケースとなりますため、面接回数など若干変更する場合もあります。</p>\n\n<p class=\"heading-step-1\"><span>01</span>\n<a href=\"https://job.mynavi.jp/27/pc/search/corp238421/outline.html\" target=\"_blank\">ナビサイト（マイナビ）</a>よりエントリー</p>\n\n<p class=\"heading-step-1\"><span>02</span>会社説明会</p>\n<p class=\"heading-step-1\"><span>03</span>書類選考</p>\n<p class=\"heading-step-1\"><span>04</span>一次面接（人事）</p>\n<p class=\"heading-step-1\"><span>05</span>適正試験</p>\n<p class=\"heading-step-1\"><span>06</span>二次面接（部門長）</p>\n<p class=\"heading-step-1\"><span>07</span>最終面接（役員）</p>\n<p class=\"heading-step-2\"><span>08</span>内定</p>\n\n</div><!-- /sec-wrapper -->\n</section>\n\n\n\n\n\n</main>\n\n<!-- footer -->\n<footer id=\"footer\">\n<div class=\"inner\">\n<h2><img src=\"https://www.kohshin-grp.co.jp/cmn/img/logo02.svg\" alt=\"弘進ゴム株式会社\"/></h2>\n<div id=\"footer_navi\">\n<div id=\"footer01\">\n<dl>\n<dt><a href=\"https://www.kohshin-grp.co.jp/shoes/index.html\">シューズ・ウェア</a></dt>\n<dd>\n<ul>\n<li><a href=\"https://www.kohshin-grp.co.jp/shoes/search/rubberboots/index.html\">製品情報</a></li>\n<li><a href=\"https://www.kohshin-grp.co.jp/shoes/feature/rubberboots/index.html\">長靴・レインブーツの特長</a></li>\n<li><a href=\"https://www.kohshin-grp.co.jp/shoes/feature/sneaker/index.html\">セーフティーシューズの特長</a></li>\n<li><a href=\"https://www.kohshin-grp.co.jp/shoes/feature/wear/index.html\">アウトドア・レインウェアの特長</a></li>\n</ul>\n</dd>\n<dt class=\"border-none\"><a href=\"https://kohshin-online.com/\" target=\"_blank\">オンラインショップ</a></dt>\n<dt class=\"border-none\"><a href=\"https://www.kohshin-grp.co.jp/catalog/index.html\">カタログ</a></dt>\n</dl>\n</div>\n<div id=\"footer02\">\n<dl>\n<dt><a href=\"https://www.kohshin-grp.co.jp/processed/index.html\">化工品</a></dt>\n<dd>\n<ul>\n<li><a href=\"https://www.kohshin-grp.co.jp/processed/search/hose/index.html\">製品情報（ホース）</a></li>\n<li><a href=\"https://www.kohshin-grp.co.jp/processed/search/sheet/index.html\">製品情報（シート）</a></li>\n<li><a href=\"https://www.kohshin-grp.co.jp/processed/kscoating/index.html\">KSコーティング</a></li>\n</ul>\n</dd>\n<dt><a href=\"https://www.kohshin-grp.co.jp/health/index.html\">健康産業</a></dt>\n<dd>\n<ul>\n<li><a href=\"https://www.kohshin-grp.co.jp/health/search/index.html\">製品情報</a></li>\n</ul>\n</dd>\n</dl>\n</div>\n<div id=\"footer03\">\n<dl>\n<dt><a href=\"https://www.kohshin-grp.co.jp/company/index.html\">会社概要</a></dt>\n<dd>\n<ul>\n<li><a href=\"https://www.