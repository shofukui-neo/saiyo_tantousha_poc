ync=!0;\n  t.src=v;s=b.getElementsByTagName(e)[0];\n  s.parentNode.insertBefore(t,s)}(window, document,'script',\n  'https://connect.facebook.net/en_US/fbevents.js');\n  fbq('init', '592318079688822');\n  fbq('track', 'PageView');\n</script>\n<noscript><img height=\"1\" width=\"1\" style=\"display:none\"\n  src=\"https://www.facebook.com/tr?id=592318079688822&ev=PageView&noscript=1\"\n/></noscript>\n<!-- End Meta Pixel Code -->\n\n<!--[if gte mso 9]><xml>\n<mso:CustomDocumentProperties>\n<mso:xd_Signature msdt:dt=\"string\"></mso:xd_Signature>\n<mso:display_urn_x003a_schemas-microsoft-com_x003a_office_x003a_office_x0023_Editor msdt:dt=\"string\">&#27700;&#27969; &#29702;&#24693;</mso:display_urn_x003a_schemas-microsoft-com_x003a_office_x003a_office_x0023_Editor>\n<mso:Order msdt:dt=\"string\">687600.000000000</mso:Order>\n<mso:xd_ProgID msdt:dt=\"string\"></mso:xd_ProgID>\n<mso:_ExtendedDescription msdt:dt=\"string\"></mso:_ExtendedDescription>\n<mso:display_urn_x003a_schemas-microsoft-com_x003a_office_x003a_office_x0023_Author msdt:dt=\"string\">&#27700;&#27969; &#29702;&#24693;</mso:display_urn_x003a_schemas-microsoft-com_x003a_office_x003a_office_x0023_Author>\n<mso:ComplianceAssetId msdt:dt=\"string\"></mso:ComplianceAssetId>\n<mso:TemplateUrl msdt:dt=\"string\"></mso:TemplateUrl>\n<mso:ContentTypeId msdt:dt=\"string\">0x0101000C9476831829A84E900CF7CF49F6C484</mso:ContentTypeId>\n<mso:TriggerFlowInfo msdt:dt=\"string\"></mso:TriggerFlowInfo>\n<mso:_SourceUrl msdt:dt=\"string\"></mso:_SourceUrl>\n<mso:_SharedFileIndex msdt:dt=\"string\"></mso:_SharedFileIndex>\n<mso:TaxCatchAll msdt:dt=\"string\"></mso:TaxCatchAll>\n<mso:MediaServiceImageTags msdt:dt=\"string\"></mso:MediaServiceImageTags>\n<mso:lcf76f155ced4ddcb4097134ff3c332f msdt:dt=\"string\"></mso:lcf76f155ced4ddcb4097134ff3c332f>\n</mso:CustomDocumentProperties>\n</xml><![endif]-->\n</head>\n\n<body>\n<div id=\"header\">\n<div id=\"header-inner\">\n<div id=\"header-logo\"><a href=\"../index.html\"><img src=\"../images/logo.png\" alt=\"パナソニック ロゴ\"></a></div>\n<div id=\"header-logo-info\">パナソニック デジタル<br>RECRUITING SITE</div>\n<div id=\"header-btns\">\n<div class=\"to-corp-btn\"><a href=\"https://digital.panasonic.co.jp/\" target=\"_blank\">企業サイトへ</a></div>\n\n<div class=\"entry-btn\"><a href=\"../entry/index.html\">ENTRY</a></div>\n</div>\n<div class=\"sp-menu-btn-box\">\n<a id=\"open-sp-menu\" href=\"#sp-menu\" class=\"fullscreen non-scroll sp-menu-btn sp-menu-btn-open\"><span></span><span></span><span></span></a>\n<div class=\"modaal-close close-sp-menu\"></div>\n</div>\n</div>\n</div>\n\n\n<div class=\"cont-wrap fade-in effect-scroll\">\n<div class=\"page-main-sec\">\n<div class=\"page-main-sec-inner\">\n<img src=\"../images/main-about04.jpg\" alt=\"イメージ\" class=\"page-main-v\">\n\n<div class=\"page-main-cat-fl\">\n<div class=\"page-main-cat-box move-to-right effect-scroll\">\n<div class=\"page-main-cat\">About Us</div>\n<img src=\"../images/top-about-jp.png\" alt=\"私たちのこと\">\n</div>\n</div>\n</div>\n</div>\n\n<h1 class=\"page-ttl-sec\">数字で知る！女性社員の活躍</h1>\n<div class=\"page-contents-wrap move-up effect-scroll\">\n<div class=\"about-wrap numbers-of-woman\">\n<div class=\"inner-1000\">\n<div class=\"about-page-lead for-num-w\">\n私たちの会社における<br class=\"over700\">女性活躍に関する強みや特徴を数字から紐解きます。\n</div>\n<p class=\"att-info-text\">2025年度 パナソニック インフォメーションシステムズとして のデータです</p>\n\n<div class=\"marked-text\"><span>女性活躍に関する数字</span></div>\n\n<div class=\"about-col2-box v-woman01\">\n<div class=\"about-col2-once move-up effect-scroll\">\n<div class=\"about-col2-once-ttl\">全従業員中の<br>女性社員の人数・比率</div>\n<img src=\"../images/about-woman-number-01.png\" alt=\"イメージ\" class=\"img100\">\n<p class=\"att-text-left\">\n※参考：2025年度 内閣府男女共同参画局によるIT技術者における女性の割合は21%</p>\n</div>\n<div class=\"about-col2-once move-up02 effect-scroll\">\n<div class=\"about-col2-once-ttl\">2026年内定者の<br>女性社員の人数・比率</div>\n<img src=\"../images/about-woman-number-02.png\" alt=\"イメージ\" class=\"img100\">\n<p class=\"att-text\">※2025年9月時点</p>\n</div>\n<div class=\"about-col2-once move-up effect-scroll\">\n<div class=\"about-col2-once-ttl\">2024年度<br>女性社員の平均勤続年数</div>\n<img src=\"../images/about-woman-number-03.png\" alt=\"イメージ\" class=\"img100\">\n<p>\n当社の女性社員の平均勤続年数は、14.0年（2024年度）。これは厚生労働省による平均値よりも高い数字です。\n</p>\n<p class=\"att-text-left\">※参考：2023年度 厚生労働省による国内女性の平均勤続年数は約9.9年</p>\n</div>\n<div class=\"about-col2-once move-up02 effect-scroll\">\n<div class=\"about-col2-once-ttl\">2024年度<br>管理職に占める女性割合</div>\n<img src=\"../images/about-woman-number-04.png\" alt=\"イメージ\" class=\"img100\">\n<p>\n当社のKPI目標は、2027年に15%、2030年に20%、2035年に25%と設定しています。\n</p>\n<p class=\"att-text-left\">※参考：2024年度 厚生労働省調査による国内平均女性管理職比率は12.4%</p>\n</div>\n</div>\n\n<div class=\"marked-text\"><span>働き方に関する数字</span></div>\n\n<div class=\"about-col2-box v-woman02\">\n<div class=\"about-col2-once move-up effect-scroll\">\n<div class=\"about-col2-once-ttl\">2024年度<br>女性育児休業取得率</div>\n<img src=\"../images/about-woman-number-05.png\" alt=\"イメージ\" class=\"img100\">\n<p>\n当社の女性育児休業取得率は100%（2024年度）です。出産予定日（産婦の場合は産後休暇後）から、子が小学校に就学した直後の4月末日までの間で、通算730日以内を上限として休業を取得できます。本人の申し出により取得期間を決めることができ、2回に分けて取得することも可能です。\n</p>\n</div>\n<div class=\"about-col2-once move-up02 effect-scroll\">\n<div class=\"about-col2-once-ttl\">2024年度<br>育児休業取得者の復職率</div>\n<img src=\"../images/about-woman-number-06.png\" alt=\"イメージ\" class=\"img100\">\n<p>\n女性育児休業取得率と同様、育児休業取得者の復職率も100%（2024年度）です。いずれの社員も、復職後も変わらず、様々なフィールドで想い描いたキャリアを歩んでいます。\n</p>\n</div>\n<div class=\"about-col2-once move-up effect-scroll\">\n<div class=\"about-col2-once-ttl\">女性管理職の中で<br>子どもを育てている人</div>\n<img src=\"../images/about-woman-number-07.png\" alt=\"イメージ\" class=\"img100\">\n<p>\n事業部長・部長・課長など、女性管理職の中には出産を経験し、育児と仕事の両立をしている方もいます。\n</p>\n</div>\n<div class=\"about-col2-once move-up02 effect-scroll\">\n<div class=\"about-col2-once-ttl\">ノンコアフレックスタイム制<br>利用率</div>\n<img src=\"../images/about-woman-number-08.png\" alt=\"イメージ\" class=\"img100\">\n<p>\n所定の期間内に総労働時間を満たせば、勤務時間・日数・始業や終業の時刻を従業員自身で自由に決めることができます。さらに、在宅勤務（利用率約60%）も選択可能であり、柔軟な働き方を実現できます。\n</p>\n</div>\n</div>\n\n<div class=\"marked-text\"><span>その他の取り組み</span></div>\n\n<div class=\"about-col2-box v-woman03\">\n<div class=\"about-col2-once move-up effect-scroll\">\n<div class=\"about-col2-once-ttl\">キャリア＆ライフデザイン<br>セミナー</div>\n<img src=\"../images/about-woman-number-09.png\" alt=\"イメージ\" class=\"img100\">\n<p>\n各年齢ごとに（4月時点、33歳・38歳・43歳・48歳・53歳の社員を対象）、自らの強みや果たすべき役割を分析し、今後の展望を描きながら具体的な行動につなげるセミナーを実施しています。\n</p>\n</div>\n<div class=\"about-col2-once move-up02 effect-scroll\">\n<div class=\"about-col2-once-ttl\">With私らしい<br>キャリアスタイルワークショップ</div>\n<img src=\"../images/about-woman-number-10.png\" alt=\"イメージ\" class=\"img100\">\n<p>\nこれからの人生のさまざまな転機に備えることを目的としたセミナーです。女性社員を対象に、他者からの刺激を受ける中で新たな気づきを得る機会を提供しています。\n</p>\n</div>\n</div>\n\n</div>\n</div>\n</div>\n</div>\n\n\n<div class=\"foot-messege-sec\">\n<div class=\"foot-messege-box\">\n<img src=\"../images/foot-message.png\" alt=\"デジタルで、幸せをつくろう。\">\n<p class=\"foot-company-name\">Panasonic Digital Co., Ltd.</p>\n<div class=\"foot-site-info\">RECRUITING SITE</div>\n</div>\n</div>\n<div class=\"footer-wrap\">\n<div class=\"inner-1000\">\n<div class=\"footer-att-box\">\n<div class=\"footer-att-ttl\">重要なお知らせ</div>\n<p>\nパナソニック社員やOB・OGを名乗り、就職活動学生に声をかける不審者にご注意ください。主要駅や就職活動イベント会場周辺において、パナソニックの社員やOB・OGを名乗り、個人情報の入手や金品の詐取などを目的に、パナソニックへの就職を優遇するなどと 声をかける不審者がいるとの情報が寄せられています。パナソニックの社員やOB・OGが就職の便宜を図る目的で声をかけることは一切ございませんので、くれぐれもご注意ください。\n</p>\n</div>\n\n<div class=\"footer-links-ttl\">\nパナソニック デジタル株式会社　RECRUITING SITE\n</div>\n<dl>\n<dt>TOP</dt>\n<dd><a href=\"../index.html\">TOPページ</a></dd>\n<dt>About Us</dt>\n<dd>\n<a href=\"../about-us/about.html\">私たちについて</a>\n<a href=\"../about-us/numbers.html\">数字で知る！私たちの強み</a>\n<a href=\"../about-us/keywords.html\">キーワードで知る！私たちの特徴</a>\n<a href=\"../about-us/numbers-of-woman.html\">数字で知る！女性社員の活躍</a>\n<a href=\"../about-us/movie.html\">動画で知る！私たち</a>\n</dd>\n<dt>Business</dt>\n<dd>\n<a href=\"../business/inside-group.html\">パナソニックグループでの