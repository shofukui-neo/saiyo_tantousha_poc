 \t\t\t\t\t\t<a href=\"https://www.mizuho.co.jp/recruit/faq/\" class=' link-gnav'>\n \t\t\t\t\t\t\t<span class=\"en\">FAQ</span>\n \t\t\t\t\t\t\t<span class=\"ja\">よくある質問</span>\n \t\t\t\t\t\t</a>\n \t\t\t\t\t</li>\n \t\t\t\t\t<li class=\"navlist\">\n            <a href=\"https://job.mynavi.jp/27/pc/search/corp227148/outline.html\" class=\"img-btn link-gnav mynavi\" target=\"_blank\">\n              <img src=\"https://job.mynavi.jp/conts/kigyo/2027/logo/banner_logo_195_60.gif\" alt=\"マイナビ2027\" border=\"0\" style=\"max-width: 190px;\">\n            </a>\n \t\t\t\t\t</li>\n \t\t\t\t\t<li class=\"navlist\">\n \t\t\t\t\t\t<a href=\"https://www.mizuho.co.jp/recruit/entry/\" class='entry link-gnav'>\n \t\t\t\t\t\t\t<span class=\"en\">ENTRY</span>\n \t\t\t\t\t\t\t<span class=\"ja\">エントリー</span>\n \t\t\t\t\t\t</a>\n \t\t\t\t\t</li>\n\n \t\t\t\t</ul>\n \t\t\t</nav>\n \t\t</div>\n \t</div>\n\n </header>\n\n\n <main role=\"main\" class=\"main \">\n<div class=\"pgttl\">\n  <div class=\"inner-pgttl\">\n    <div class=\"txt\">\n      <div class=\"wrapper-en\">\n        <p class=\"en\">Entry</p>\n      </div>\n      <div>\n        <h1 class=\"ja\">エントリー</h1>\n      </div>\n    </div>\n    <div class=\"bg photo-ofi\">\n      <img src=\"https://www.mizuho.co.jp/recruit/wp-content/themes/mizuho1.2.7/img/common/bg-pgttl-entry.jpg\" alt=\"エントリー\">\n    </div>\n  </div>\n</div>\n\n<div class=\"breadcrumbs\">\n\t<ul class=\"list-inline\" itemscope itemtype=\"http://schema.org/BreadcrumbList\"><li itemprop=\"itemListElement\" itemscope itemtype=\"http://schema.org/ListItem\"><a href=\"https://www.mizuho.co.jp/recruit/\" class=\"home\" itemprop=\"item\" ><span itemprop=\"name\">TOP</span></a><meta itemprop=\"position\" content=\"1\" /></li><li itemprop=\"itemListElement\" itemscope itemtype=\"http://schema.org/ListItem\"><span itemprop=\"name\">エントリー</span><meta itemprop=\"position\" content=\"2\" /></li></ul></div>\n\n<section class=\"section-lg\">\n  <div class=\"container-fluid container-lg\">\n    <div class=\"row\">\n      <div class=\"col-lg-offset-1 col-lg-10\">\n        <h2 class=\"txt-28 txt-main txt-mincho txt-bold ttl-bb mb-30\">エントリーフォーム</h2>\n        <p class=\"txt-16 mb-10\">\n          弊社の採用活動にご関心をお寄せ頂き、誠にありがとうございます。<br>\n          採用に関するエントリーは下記項目を入力していただき、「内容確認」ボタンを押してください。<br>\n          追ってこちらから、連絡させていただきます。\n        </p>\n        <p class=\"mb-30 txt-14\">\n          <span class=\"mark-req lg\">必須</span> のついた項目は、全て入力をお願いいたします。<br>\n          迷惑メール対策でドメイン指定をされている方は、メールが受信できるよう設定を変更頂きます様、宜しくお願いします。\n        </p>\n\n        <div class=\"mail-block txt-14 target-anker\">\n          <div role=\"form\" class=\"wpcf7\" id=\"wpcf7-f110-o1\" lang=\"ja\" dir=\"ltr\">\n<div class=\"screen-reader-response\"></div>\n<form action=\"/recruit/entry/#wpcf7-f110-o1\" method=\"post\" class=\"wpcf7-form\" enctype=\"multipart/form-data\" novalidate=\"novalidate\">\n<div style=\"display: none;\">\n<input type=\"hidden\" name=\"_wpcf7\" value=\"110\" />\n<input type=\"hidden\" name=\"_wpcf7_version\" value=\"5.0.2\" />\n<input type=\"hidden\" name=\"_wpcf7_locale\" value=\"ja\" />\n<input type=\"hidden\" name=\"_wpcf7_unit_tag\" value=\"wpcf7-f110-o1\" />\n<input type=\"hidden\" name=\"_wpcf7_container_post\" value=\"0\" />\n</div>\n<p><!--採用エントリー--></p>\n<div class=\"flow-contact mb-30\">\n<ul class=\"list-flow-contact wpcf7c-elm-step1\">\n<li class=\"step step-first current\"><span>情報入力</span></li>\n<li class=\"step\"><span>入力内容確認</span></li>\n<li class=\"step\"><span>送信完了</span></li>\n</ul>\n<ul class=\"list-flow-contact wpcf7c-elm-step2\">\n<li class=\"step step-first\"><span>情報入力</span></li>\n<li class=\"step current\"><span>入力内容確認</span></li>\n<li class=\"step\"><span>送信完了</span></li>\n</ul>\n<ul class=\"list-flow-contact wpcf7c-elm-step3\">\n<li class=\"step step-first\"><span>情報入力</span></li>\n<li class=\"step\"><span>入力内容確認</span></li>\n<li class=\"step current\"><span>送信完了</span></li>\n</ul>\n</div>\n<div id=\"mail-form\">\n<table class=\"table-form mb-30\">\n<tbody>\n<tr class=\"form-row\">\n<th class=\"form-head\"><label for=\"fm_cat\" onclick=\"\">応募区分</label><span class=\"mark-req\">必須</span></th>\n<td class=\"form-content\">\n          <span class=\"wpcf7-form-control-wrap recruit_cat\"><span class=\"wpcf7-form-control wpcf7-checkbox wpcf7-validates-as-required wpcf7-exclusive-checkbox radio-block\" id=\"fm_cat\"><span class=\"wpcf7-list-item first\"><label><input type=\"checkbox\" name=\"recruit_cat\" value=\"新卒\" /><span class=\"wpcf7-list-item-label\">新卒</span></label></span><span class=\"wpcf7-list-item last\"><label><input type=\"checkbox\" name=\"recruit_cat\" value=\"中途\" /><span class=\"wpcf7-list-item-label\">中途</span></label></span></span></span>\n        </td>\n</tr>\n<tr class=\"form-row\">\n<th class=\"form-head\"><label for=\"fm_name\" onclick=\"\">お名前</label><span class=\"min\">フルネーム</span><span class=\"mark-req\">必須</span></th>\n<td class=\"form-content\">\n          <span class=\"wpcf7-form-control-wrap recruit_name\"><input type=\"text\" name=\"recruit_name\" value=\"\" size=\"40\" class=\"wpcf7-form-control wpcf7-text wpcf7-validates-as-required form-control\" id=\"fm_name\" aria-required=\"true\" aria-invalid=\"false\" placeholder=\"例:瑞穂　太郎\" /></span>\n        </td>\n</tr>\n<tr class=\"form-row\">\n<th class=\"form-head\"><label for=\"fm_furi\" onclick=\"\">ふりがな</label><span class=\"mark-req\">必須</span></th>\n<td class=\"form-content\">\n          <span class=\"wpcf7-form-control-wrap recruit_furi\"><input type=\"text\" name=\"recruit_furi\" value=\"\" size=\"40\" class=\"wpcf7-form-control wpcf7-text wpcf7-validates-as-required form-control\" id=\"fm_furi\" aria-required=\"true\" aria-invalid=\"false\" placeholder=\"例:みずほ　たろう\" /></span>\n        </td>\n</tr>\n<tr class=\"form-row\">\n<th class=\"form-head\"><label for=\"fm_year\" onclick=\"\">生年月日</label><span class=\"mark-req\">必須</span></th>\n<td class=\"form-content\">\n          <!--日付自動制御--></p>\n<div class=\"row-fixed form-ymd\">\n<div class=\"col\" data-start=\"-10\">\n              <span class=\"wpcf7-form-control-wrap recruit_year\"><select name=\"recruit_year\" class=\"wpcf7-form-control wpcf7-select wpcf7-validates-as-required js-year\" id=\"recruit_year\" aria-required=\"true\" aria-invalid=\"false\"><option value=\"\">---</option></select></span><span class=\"txt-after\">年</span><br />\n              <span class=\"wpcf7-custom-item-error recruit_year\"></span>\n            </div>\n<div class=\"col\">\n              <span class=\"wpcf7-form-control-wrap recruit_month\"><select name=\"recruit_month\" class=\"wpcf7-form-control wpcf7-select wpcf7-validates-as-required js-month\" id=\"recruit_month\" aria-required=\"true\" aria-invalid=\"false\"><option value=\"\">---</option></select></span><span class=\"txt-after\">月</span><br />\n              <span class=\"wpcf7-custom-item-error recruit_month\"></span>\n            </div>\n<div class=\"col\">\n              <span class=\"wpcf7-form-control-wrap recruit_day\"><select name=\"recruit_day\" class=\"wpcf7-form-control wpcf7-select wpcf7-validates-as-required js-day\" id=\"recruit_day\" aria-required=\"true\" aria-invalid=\"false\"><option value=\"\">---</option></select></span><span class=\"txt-after\">日</span><br />\n              <span class=\"wpcf7-custom-item-error recruit_day\"></span>\n            </div>\n</p></div>\n</td>\n</tr>\n<tr class=\"form-row\">\n<th class=\"form-head\"><label for=\"fm_address\" onclick=\"\">住所</label><span class=\"mark-req\">必須</span></th>\n<td class=\"form-content\">\n<div class=\"mb-10\">\n            <span class=\"inline-block\"><br />\n              〒<br />\n            </span> <span class=\"inline-block\"><label for=\"fm_zip\" class=\"label-min\">郵便番号</label><br />\n              <span class=\"wpcf7-form-control-wrap recruit_zip\"><input type=\"text\" name=\"recruit_zip\" value=\"\" size=\"15\" class=\"wpcf7-form-control wpcf7-text wpcf7-validates-as-required form-control input-inline\" id=