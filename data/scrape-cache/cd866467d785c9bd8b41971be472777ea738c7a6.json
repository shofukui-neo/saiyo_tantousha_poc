"c-radio\"><label><input type=\"radio\" name=\"year\" id=\"year_rad_1\" value=\"1\" ><span class=\"c-radio__icon\"></span>4年生</label> </li>\n<li class=\"c-radio\"><label><input type=\"radio\" name=\"year\" id=\"year_rad_2\" value=\"2\" ><span class=\"c-radio__icon\"></span>既卒</label> </li>\n</ul>\n                          <div class=\"form-block__err js-errmsg\"></div>\n                                                  </div>\n                      </div>\n                      <div class=\"form-block__group\">\n                        <div class=\"form-block__label\"><span class=\"form-block__label--required\">必須</span> 電話番号</div>\n                        <div class=\"form-block__input\">\n                        <div class=\"form-block__input-row\"><input type=\"tel\" name=\"tel_number\" class=\"js-validate c-input -short\" placeholder=\"例：0664871401　※ハイフンなし\" aria-required=\"true\" required=\"\" /> \n</div>\n                        <div class=\"form-block__err js-errmsg\"></div>\n                                                </div>\n                      </div>\n                      <div class=\"form-block__group\">\n                        <div class=\"form-block__label\"><span class=\"form-block__label--required\">必須</span> メールアドレス</div>\n                        <div class=\"form-block__input\">\n                        <div class=\"form-block__input-row\"><input type=\"email\" name=\"email\" class=\"js-validate c-input\" placeholder=\"saiyou-jinji@bunguclub.co.jp\" aria-required=\"true\" required=\"\" /> \n</div>\n                        <div class=\"form-block__err js-errmsg\"></div>\n                                                </div>\n                      </div>\n                      <div class=\"form-block__group\">\n                        <div class=\"form-block__label\"><span class=\"form-block__label--required -off\">任意</span> 会社説明会参加希望日</div>\n                        <p class=\"u-mb-letter\">開催予定日は<a href=\"/recruit/meeting/\" class=\"u-text-link\" target=\"_blank\" rel=\"noopener noreferrer\" title=\"リンクを新規タブで開きます\">「会社説明会のご案内」</a>にてご確認ください。</p>\n                        <div class=\"form-block__input\">\n                          <div class=\"form-block__input-row\">\n                          <input type=\"text\" name=\"date\" class=\"c-input -short js-datepicker\" placeholder=\"年・月・日\" readonly=\"readonly\"  /> \n                          <button type=\"button\" class=\"delete js-date-reset\">削除する</button>\n                          <div class=\"form-block__err js-errmsg\"></div>\n                                                    </div>\n                        </div>\n                      </div>\n                      <div class=\"form-block__group\">\n                        <div class=\"form-block__label\"><span class=\"form-block__label--required\">必須</span> 今後の情報提供を希望する</div>\n                        <div class=\"form-block__input\">\n                        <ul class=\"c-radio__list\">\n<li class=\"c-radio\"><label><input type=\"radio\" name=\"subscribe\" id=\"subscribe_rad_3\" value=\"0\" checked ><span class=\"c-radio__icon\"></span>希望する</label> </li>\n<li class=\"c-radio\"><label><input type=\"radio\" name=\"subscribe\" id=\"subscribe_rad_4\" value=\"1\" ><span class=\"c-radio__icon\"></span>希望しない</label> </li>\n</ul>\n                        <div class=\"form-block__err js-errmsg\"></div>\n                                                </div>\n                      </div>\n                      <div class=\"form-block__group\">\n                        <div class=\"form-block__label\"><span class=\"form-block__label--required\">必須</span> エリア</div>\n                        <div class=\"form-block__input\">\n                          <div class=\"form0-block__input-row\">\n                          <ul class=\"c-chkbox__list\">\n<li class=\"c-chkbox\"><label for=\"chk_0\"><input type=\"checkbox\" name=\"area[]\" id=\"chk_0\" value=\"0\" required=\"\" /><span class=\"c-chkbox__icon\"></span>関西</label> </li>\n<li class=\"c-chkbox\"><label for=\"chk_1\"><input type=\"checkbox\" name=\"area[]\" id=\"chk_1\" value=\"1\" required=\"\" /><span class=\"c-chkbox__icon\"></span>首都圏</label> </li>\n<li class=\"c-chkbox\"><label for=\"chk_2\"><input type=\"checkbox\" name=\"area[]\" id=\"chk_2\" value=\"2\" required=\"\" /><span class=\"c-chkbox__icon\"></span>広島</label> </li>\n<li class=\"c-chkbox\"><label for=\"chk_3\"><input type=\"checkbox\" name=\"area[]\" id=\"chk_3\" value=\"3\" required=\"\" /><span class=\"c-chkbox__icon\"></span>名古屋</label> </li>\n<li class=\"c-chkbox\"><label for=\"chk_4\"><input type=\"checkbox\" name=\"area[]\" id=\"chk_4\" value=\"4\" required=\"\" /><span class=\"c-chkbox__icon\"></span>鳥取</label> </li>\n</ul>\n                          </div>\n                          <div class=\"form-block__err js-errmsg\"></div>\n                                                  </div>\n                      </div>\n                      <div class=\"form-block__group\">\n                        <div class=\"form-block__label\"><span class=\"form-block__label--required -off\">任意</span> 当社を知ったきっかけ</div>\n                        <div class=\"form-block__input\">\n                        <ul class=\"c-chkbox__list\">\n<li class=\"c-chkbox\"><label for=\"chk_5\"><input type=\"checkbox\" name=\"trigger[]\" id=\"chk_5\" value=\"0\" /><span class=\"c-chkbox__icon\"></span>学内イベント</label> </li>\n<li class=\"c-chkbox\"><label for=\"chk_6\"><input type=\"checkbox\" name=\"trigger[]\" id=\"chk_6\" value=\"1\" /><span class=\"c-chkbox__icon\"></span>就職情報サイト</label> </li>\n<li class=\"c-chkbox\"><label for=\"chk_7\"><input type=\"checkbox\" name=\"trigger[]\" id=\"chk_7\" value=\"2\" /><span class=\"c-chkbox__icon\"></span>ハローワーク</label> </li>\n<li class=\"c-chkbox\"><label for=\"chk_8\"><input type=\"checkbox\" name=\"trigger[]\" id=\"chk_8\" value=\"3\" /><span class=\"c-chkbox__icon\"></span>学校の紹介</label> </li>\n<li class=\"c-chkbox\"><label for=\"chk_9\"><input type=\"checkbox\" name=\"trigger[]\" id=\"chk_9\" value=\"4\" /><span class=\"c-chkbox__icon\"></span>知人の紹介</label> </li>\n<li class=\"c-chkbox\"><label for=\"chk_10\"><input type=\"checkbox\" name=\"trigger[]\" id=\"chk_10\" value=\"5\" /><span class=\"c-chkbox__icon\"></span>その他</label> </li>\n</ul>\n                        </div>\n                        <div class=\"form-block__err js-errmsg\"></div>\n                                              </div>\n                      <div class=\"form-block__group\">\n                        <div class=\"form-block__label\"><span class=\"form-block__label--required -off\">任意</span> その他</div>\n                        <p class=\"u-mb-letter\">ご質問やご要望がございましたらご記載ください。</p>\n                        <div class=\"form-block__input\">\n                          <div class=\"form-block__input-row\">\n                          <textarea name=\"other\" class=\"c-textarea\" rows=\"4\"></textarea> \n                          <div class=\"form-block__err js-errmsg\"></div>\n                                                    </div>\n                        </div>\n                      </div>\n                      <div class=\"form-block__group\">\n                        <div class=\"form-privacy\">\n                          <div class=\"head\">個人情報の取り扱い</div>\n                          <div class=\"txt\">\n                            <p>入力いただきました個人情報は、当社のサイトポリシーに基づいて、取り扱いをさせていただきます。サイトポリシーへの記載内容以外の目的に利用する場合は、お客様から具体的な同意を得た場合にのみ使用いたします。<br>当社の個人情報の扱いに関する詳細情報については、<a href=\"/privacy-policy/\" target=\"_blank\" class=\"u-text-link\" rel=\"noopener noreferrer\" title=\"リンクを新規タブで開きます\">個人情報保護方針</a>をご参照ください。<br>上記個人情報の取り扱いおよび当社サイトポリシーについて同意いただける場合は、「同意する」にチェックを入れ、「入力内容を確認する」ボタンをクリックしてください。</p>\n                          </div>\n                          <div class=\"form-privacy__agree\">\n                            <div class=\"c-chkbox\"><label><input class=\"js-privacy\" id=\"privacyCheck\" type=\"checkbox\" name=\"checkbox[]\" value=\"\" aria-required=\"true\" required=\"\"><span class=\"c-chkbox__icon\"></span> 同意する</label></div>\n                          </div>\n                          <div class=\"form-privacy__err form-section__err js-errmsg\"></div>\n                        </div>\n                      </div>\n                    </div>\n                  </div>\n              </div>\n              <div class=\"form-action\">\n                <div>\n                  <button type=\"submit\" class=\"c-btn-circle -large js-submit\" disabled=\"disabled\" formnovalidate=\"\">\n                    <span class=\"txt\">入力内容を確認する</span> \n                    <img class=\"arw arw-wht\" src=\"/recruit/assets/images/icons/arw_circle.svg\" alt=\"\" height=\"19\" width=\"18\" decoding=\"async\" loading=\"lazy\">\n                  </button>\n                </div>\n              </div>\n              </form>\n            </div>\n          </div>\n        </main>\n<!-- google recaptcha-->\n<script src=\"https://ajax.googleapis.com/ajax/libs/jquery/3.4.1/jquery.min.js\"></script>\n<script src=\"https://www.google.com/recaptcha/api.js?render=6Lf8V9IqAAAAANdWsyNM_2bPGTXWoTMsNM0JUBTr\"></script>\n<script>\njQuery(function($){\n  $('#Form1').submit(function(event) {\n    event.preventDefault();\n    var action_name = 'contact'; //アクション名 \n    grecaptcha.ready(function() {\n      grecaptcha.execute('6Lf8V9IqAAAAANdWsyNM_2bPGTXWoTMsNM0JUBTr', { action: action_name }).then(function(token) {\n        $('#Form1').prepend('<input type=\"hidden\" name=\"recaptchaToken\" id=\"recaptchaToken\" value=\"' + token + '\">');\n        $('#Form1').prepend('<input type=\"hidden\" name=\"action\" value=\"' + action_name + '\">');\n        $('#Form1').unbind('submit').submit();\n      });;\n    });\n  });\n})\n</script>\n\t\t\t</div>\n\t<footer class=\"l-footer\">\n  <div class=\"l-footer__main\">\n    <div class=\"l-inner\">\n      <div class=\"l-footer__cont\">\n        <div class=\"l-footer__head\">\n      