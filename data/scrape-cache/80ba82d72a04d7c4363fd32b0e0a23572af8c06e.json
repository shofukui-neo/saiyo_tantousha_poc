ly_padding ly_padding__bottom\">\n      <div class=\"ly_body\">\n        <img src=\"/dealer/dairi/assets/img/recruit/main_img.jpg\" alt=\"住み慣れた街で、ずっと暮らす。スズキで、ずっと働く。\" class=\"mv_mb\">\n        <ul class=\"menu_list\">\n          <li>\n            <a href=\"/dealer/sj-matsuyama/recruit/graduate-guideline/\" class=\"js_matchHeight\">\n              <span>\n                <i class=\"m_icon01\"></i>【新卒採用】<br>募集要項</span>\n            </a>\n          </li>\n          <li>\n            <a href=\"/dealer/sj-matsuyama/recruit/career-guideline/\" class=\"js_matchHeight\">\n              <span>\n                <i class=\"m_icon02\"></i>【中途採用】<br>募集要項</span>\n            </a>\n          </li>\n          <li>\n            <a href=\"/dealer/sj-matsuyama/recruit/workplace_information/\" class=\"js_matchHeight\">\n              <span>\n                <i class=\"m_icon08\"></i>職場情報</span>\n            </a>\n          </li>\n          <li>\n            <a href=\"/dealer/sj-matsuyama/recruit/briefing/\" class=\"js_matchHeight\">\n              <span>\n                <i class=\"m_icon03\"></i>説明会情報</span>\n            </a>\n          </li>\n          <li>\n            <a href=\"/dealer/sj-matsuyama/recruit/message/\" class=\"js_matchHeight\">\n              <span>\n                <i class=\"m_icon04\"></i>みなさんへの<br>メッセージ</span>\n            </a>\n          </li>\n          <li>\n            <a href=\"/dealer/sj-matsuyama/recruit/workplace/\" class=\"js_matchHeight\">\n              <span>\n                <i class=\"m_icon05\"></i>職場紹介</span>\n            </a>\n          </li>\n          <li>\n            <a href=\"/dealer/sj-matsuyama/recruit/shop/\" class=\"js_matchHeight\">\n              <span>\n                <i class=\"m_icon06\"></i>拠点紹介</span>\n            </a>\n          </li>\n          <li>\n            <a href=\"/dealer/sj-matsuyama/recruit/topic/\" class=\"js_matchHeight\">\n              <span>\n                <i class=\"m_icon07\"></i>採用トピックス</span>\n            </a>\n          </li>\n        </ul>\n      </div>\n\n      <div class=\"ly_body ly_body__mainContents ly_bgWhite hp_mb30 cf\">\n        <section class=\"bl_sect01\">\n          <h4 class=\"el_sectTtl el_sectTtl__lv4 bl_B08_block_title\">アクセス / お問い合わせ</h4>\n          <div class=\"ly_content_col6\">\n            <table class=\"bl_table__std\">\n              <tbody>\n                <tr>\n                  <th class=\"bl_table__std_hd__mid\">所在地</th>\n                  <td>〒791-8036　愛媛県松山市高岡町１８３－３\n                    <br />\n                     TEL：\n                    <span class=\"js_telNumber\">089-971-6112</span>                  </td>\n                </tr>\n                                                    <tr>\n                        <th class=\"bl_table__std_hd__mid\">お問い合わせ</th>\n                        <td>\n                            <span>メールでのお問い合わせはこちらから</span>\n                            <a href=\"mailto:recruit@j-matsuyama.sdr.suzuki\" class=\"el_btn el_btn__bw el_btn__c4 el_btn__arrow hp_mt10\"><span>お問い合わせ</span></a>\n                        </td>\n                    </tr>\n                              </tbody>\n            </table>\n          </div>\n          <div class=\"ly_content_col6 pc\">\n            <iframe src=\"https://www.google.com/maps?q=愛媛県松山市高岡町１８３－３&output=embed&language=jp\"\n              width=\"100%\" height=\"265\" frameborder=\"0\" style=\"border:0\" allowfullscreen></iframe>\n            <p class=\"bl_T04_right\">\n              <a href=\"https://www.google.co.jp/maps/search/?q=愛媛県松山市高岡町１８３－３\" target=\"_blank\" class=\"el_icon el_icon__blank hp_fzss hp_fwb hp_colorBlue\">大きな地図で見る</a>\n            </p>\n          </div>\n          <div class=\"sp hp_mt30\">\n            <ul class=\"bl_B03 cf\">\n              <li>\n                <a href=\"https://www.google.co.jp/maps/search/?api=1&query=愛媛県松山市高岡町１８３－３\" target=\"_blank\" class=\"el_btn el_btn__bw el_btn__l el_btn__arrow\">地図表示</a>\n              </li>\n            </ul>\n          </div>\n        </section>\n      </div>\n\n      <div class=\"ly_body ly_body__mainContents ly_bgWhite hp_mb30 cf\">\n        <section class=\"bl_sect02 bl_accessRanking bl_focalBlock\">\n          <h5 class=\"el_sectTtl el_sectTtl__lv5\">採用トピックス\n            <span class=\"more_link\">\n              <a href=\"/dealer/sj-matsuyama/recruit/topic/\" class=\"el_icon el_icon__arrow hp_fzss hp_fwb\">すべてを見る</a>\n            </span>\n          </h5>\n          <div class=\"cf\">\n            <ol class=\"bl_accessRanking_list cf\">\n                                        <li class=\"bl_focalBlock_list js_matchHeight recruit_topics hp_mr0\">\n                              <a href=\"/dealer/sj-matsuyama/recruit/topic/?id=43381\">\n                                  <figure class=\"bl_centerThumb jsArtImg\"><img src=\"/dealer/sj-admin/sharefiles/仕事体験会案内_00912a6a-429b-11f0-90d4-fa163e38a592_s.jpg\" alt=\"【11月30日】マイナビ合同説明会に出展します！\"></figure>\n                                  <div class=\"bl_focalBlock_list_info\">\n                    <p class=\"bl_focalBlock_list_meta\"><span class=\"el_label jsCatName\" style=background-color:#0099CA;>採用教育活動</span><span class=\"bl_focalBlock_list_meta_date\">2025.11.01</span></p>\n                    <p class=\"bl_focalBlock_list_shop jsRecTitle\">【11月30日】マイナビ合同説明会に出展します！</p>\n                    <p class=\"bl_focalBlock_list_title jsRecContent\"></p>\n                  </div>\n                </a>\n                <div class=\"jsTmpRecContent\" style='display:none'><p style=\"text-align: center;\">&nbsp;</p>\r\n<p style=\"text-align: center;\">こんにちは！</p>\r\n<p style=\"text-align: center;\">株式会社スズキ自販松山に興味を持って頂き、誠にありがとうございます</p>\r\n<p style=\"text-align: center;\">&nbsp;</p>\r\n<p style=\"text-align: center;\">11月30日にアイテムえひめで開催予定の</p>\r\n<p style=\"text-align: center;\"><a href=\"https://job.mynavi.jp/conts/event/2027/10078/index.html\">マイナビ　インターンシップ＆キャリア発見フェア</a>に出展します</p>\r\n<p style=\"text-align: center;\">（上記リンクからイベント詳細に飛べます）</p>\r\n<p style=\"text-align: center;\">&nbsp;</p>\r\n<p style=\"text-align: center;\">みなさまにお会いできるのを楽しみにしております！</p>\r\n<p style=\"text-align: center;\">&nbsp;</p>\r\n<p style=\"text-align: center;\">アリーナ空港店から２名の社員が同行しますのでいろんな話が聞けますよ</p>\r\n<p style=\"text-align: center;\">&nbsp;</p>\r\n<p style=\"text-align: center;\"><img src=\"/dealer/sj-admin/sharefiles/仕事体験会案内_00912a6a-429b-11f0-90d4-fa163e38a592.jpg\" alt=\"\" width=\"500\" height=\"455\" /></p>\r\n<p style=\"text-align: center;\">&nbsp;</p>\r\n<p style=\"text-align: center;\">あわせて弊社では仕事体験を受け付けております</p>\r\n<p style=\"text-align: center;\">&nbsp;</p>\r\n<p style=\"text-align: center;\">下記リンクからも仕事体験の日程が確認・予約ができます</p>\r\n<p style=\"text-align: center;\">個別の日程相談も可能ですので、お気軽にご相談ください</p>\r\n<p style=\"text-align: center;\">&nbsp;</p>\r\n<p style=\"text-align: center;\"><strong><span style=\"font-size: 14pt; color: #00ffff;\"><a style=\"color: #00ffff;\" href=\"https://job.mynavi.jp/27/pc/corpinfo/displayInternship/index?corpId=211225&amp;optNo=9lgFV\"><span style=\"color: #ff0000;\">マイナビ2027 スズキ自販松山（説明会予約）</span></a></span></strong></p>\r\n<p style=\"text-align: center;\"><strong><span style=\"font-size: 14pt; color: #3366ff;\"><a style=\"color: #3366ff;\" href=\"https://job.mynavi.jp/27/pc/corpinfo/displaySeminar/index?optNo=ylSO2C&amp;corpId=61807\">マイナビ2027 スズキ販売会社グループ（説明会予約）</a></span></strong></p>\r\n<p style=\"text-align: center;\">&nbsp;</p>\r\n<p style=\"text-align: center;\">皆さまのご応募お待ちしております</p>\r\n<p style=\"text-align: center;\">&nbsp;</p></div>\n              </li>\n                                        <li class=\"bl_focalBlock_list js_matchHeight recruit_topics hp_mr0\">\n                              <a href=\"/dealer/sj-matsuyama/recruit/topic/?id=41162\">\n                                  <figure class=\"bl_centerThumb jsArtImg\"><img src=\"/dealer/sj-admin/sharefiles/565325379960308104_709af4dc-4816-11f0-86fd-fa163e38a592_s.jpg\" alt=\"【出前授業】松山聖陵高等学校に行ってきました！\"></figure>\n                                  <div class=\"bl_focalBlock_list_info\">\n                    <p class=\"bl_focalBlock_list_meta\"><span class=\"el_label jsCatName\" style=background-color:#0099CA;>採用教育活動</span><span class=\"bl_focalBlock_list_meta_date\">2025.06.16</span></p>\n                    <p class=\"bl_focalBlock_list_shop jsRecTitle\">【出前授業】松山聖陵高等学校に行ってきました！</p>\n                    <p class=\"bl_focalBlock_list_title jsRecContent\"></p>\n                  </div>\n                </a>\n                <div class=\"jsTmpRecContent\" style='display:none'><p style=\"text-align: center;\">&nbsp;</p>\r\n<p style=\"text-align: center;\">&nbsp;</p>\r\n<p style=\"text-align: center;\">&nbsp;</p>\r\n<p style=\"text-align: center;\">こんにちは！</p>\r\n<p style=\"text-align: center;\">&nbsp;</p>\r\n<p style=\"text-align: center;\">採用教育担当の宮﨑です</p>\r\n<p style=\"text-align: center;\">&nbsp;</p>\r\n<p style=\"text-align: center;\">株式会社スズキ自販松山に興味を持って頂き、誠にありがとうございます。</p>\r\n<p style=\"text-align: center;\">&nbsp;</p>\r\n<p style=\"text-align: center;\">&nbsp;</p>\r\n<p style=\"text-align: center;\">本日は先日開催した</p>\r\n<p style=\"text-align: center;\">&nbsp;</p>\r\n<p style=\"text-align: center;\">聖陵高等学校での訪問授業の様子を</p>\r\n<p style=\"text-align: center;\">&nbsp;</p>\r\n<p style=\"text-align: center;\">お届けしたいと思います！</p>\r\n<p style=\"text-align: center;\">&nbsp;</p>\r\n<p style=\"text-align: center;\">&nbsp;</p>\r\n<p style=\"text-align: center;\">&nbsp;</p>\r\n<p style=\"text-align: center;\"><img src=\"/dealer/sj-admin/sharefiles/565325379960308104_709af4dc-4816-11f0-86fd-fa163e38a592.jpg\" alt=\"\" width=\"500\" height=\"375\" /></p>\r\n<p style=\"text-align: center;\">&nbsp;</p>\r\n<p style=\"text-align: center;\">&nbsp;</p>\r\n<p style=\"text-align: center;\"><img src=\"/dealer/sj-admin/sharefiles/565325381436702994_6c539b86-4816-11f0-a65b-fa163e38a592.jpg\" alt=\"\" width=\"400\" height=\"533\" /></p>\r\n<p style=\"text-align: center;\">&nbsp;</p>\r\n<p style=\"text-align: center;\"><img src=\"/dealer/sj-admin/sharefiles/565325380748837290_6e5a22d8-4816-11f0-9a1a-fa163e38a592.jpg\" alt=\"\" width=\"400\" height=\"300\" /></p>\r\n<p style=\"text-align: center;\">&nbsp;</p>\r\n<p style=\"text-align: center;\">&nbsp;</p>\r\n<p style=\"text-align: center;\">3班に分かれて上記を実施しました</p>\r\n<p style=\"text-align: center;\">&nbsp;</p>\r\n<p style=\"text-align: center;\">なかなか見ることできない</p>\r\n<p style=\"text-align: center;\">&nbsp;</p>\r\n<p style=\"text-align: center;\"><strong><span style=\"color: #ff0000; font-size: 14pt;\">・エアバッグ展開・発煙筒の点火・スズキコネクトの実演</span></strong></p>\r\n<p style=\"text-align: center;\">&nbsp;</p>\r\n<p style=\"text-align: center;\"><strong><span style=\"font-size: 14pt; color: #ff9900;\">・楽しみながらもチームワークを仕事に活かせるパスタタワー</span></strong></p>\r\n<p style=\"text-align: center;\">&nbsp;</p>\r\n<p style=\"text-align: center;\"><strong><span style=\"font-size: 14pt; color: #3366ff;\">・座談会形式の会社説明会</span></strong></p>\r\n<p style=\"text-align: center;\">&nbsp;</p>\r\n<p style=\"text-align: center;\">それぞれパート毎に違った盛り上がりがあり、社員も一緒に楽しんでました！</p>\r\n<p style=\"text-align: center;\">&nbsp;</p>\r\n<p style=\"text-align: center;\">会社見学会や仕事体験を開催中です</p>\r\n<p style=\"text-align: center;\">&nbsp;</p>\r\n<p style=\"text-align: center;\">個別の日程相談も可能ですので、お気軽にご相談ください</p>\r\n<p style=\"text-align: center;\">&nbsp;</p>\r\n<p style=\"text-align: center;\">下記リンクからも仕事体験の日程が確認・予約ができます</p>\r\n<p style=\"text-align: center;\">&nbsp;</p>\r\n<p style=\"text-align: center;\"><a href=\"https://job.mynavi.jp/27/pc/corpinfo/displaySeminar/index?optNo=UbJFvC&amp;corpId=211225\"><strong><span style=\"font-size: 14pt; color: #33cccc;\">マイナビ2027（説明会予約）</span></strong></a></p>\r\n<p style=\"text-align: center;\"><a href=\"https://job.mynavi.jp/27/pc/corpinfo/displaySeminar/index?optNo=hKTRoC&amp;corpId=61807\"><strong><span style=\"font-size: 14pt; color: #33cccc;\">マイナビ2027 スズキ販売会社グループ（説明会予約）</span></strong></a></p>\r\n<p style=\"text-align: center;\"><span style=\"color: #00ffff;\"><img src=\"/dealer/sj-admin/sharefiles/仕事体験会案内_00912a6a-429b-11f0-90d4-fa163e38a592.jpg\" alt=\"\" width=\"400\" height=\"364\" /></span></p>\r\n<p style=\"text-align: center;\"><img src=\"/dealer/sj-admin/sharefiles/IMG_6618_f3a43386-32c1-11ef-b187-fa163e38a592.jpg\" alt=\"\" width=\"400\" height=\"400\" /></p></div>\n              </li>\n                                        <li class=\"bl_focalBlock_list js_matchHeight recruit_topics hp_mr0\">\n                              <a href=\"/dealer/sj-matsuyama/recruit/topic/?id=41115\">\n                                  <figure class=\"bl_centerThumb jsArtImg\"><img src=\"/dealer/sj-admin/sharefiles/IMG_0736_15d1c592-44da-11f0-818a-fa163e38a592_s.jpg\" alt=\"【6/7】合同説明会に出展してきました！\"></figure>\n                                  <div class=\"bl_focalBlock_list_info\">\n                    <p class=\"bl_focalBlock_list_meta\"><span class=\"el_label jsCatName\" style=background-color:#0099CA;>採用教育活動</span><span class=\"bl_focalBlock_list_meta_date\">2025.06.10</span></p>\n                    <p class=\"bl_focalBlock_list_shop jsRecTitle\">【6/7】合同説明会に出展してきました！</p>\n                    <p class=\"bl_focalBlock_list_title jsRecContent\"></p>\n                  </div>\n                </a>\n                <div class=\"jsTmpRecContent\" style='display:none'><p style=\"text-align: center;\">&nbsp;</p>\r\n<p style=\"text-align: center;\">&nbsp;</p>\r\n<p style=\"text-align: center;\">こんにちは！</p>\r\n<p style=\"text-align: center;\">&nbsp;</p>\r\n<p style=\"text-align: center;\">採用教育担当の宮﨑です</p>\r\n<p style=\"text-align: center;\">&nbsp;</p>\r\n<p style=\"text-align: center;\">株式会社スズキ自販松山に興味を持って頂き、誠にありがとうございます</p>\r\n<p style=\"text-align: center;\">&nbsp;</p>\r\n<p style=\"text-align: center;\"><span style=\"color: #000000;\">6月7日にアイテムえひめで開催された</span></p>\r\n<p style=\"text-align: center;\"><span style=\"color: #00ccff;\"><strong><span style=\"font-size: 14pt;\"><a style=\"color: #00ccff;\" href=\"https://job.mynavi.jp/conts/event/2027/9877/index.html\">マイナビ　インターンシップ＆キャリア発見フェア</a></span></strong></span>に出展してきました。</p>\r\n<p style=\"text-align: center;\">&nbsp;</p>\r\n<p style=\"text-align: center;\"><img src=\"/dealer/sj-admin/sharefiles/IMG_0736_15d1c592-44da-11f0-818a-fa163e38a592.jpeg\" alt=\"\" width=\"500\" height=\"376\" /></p>\r\n<p style=\"text-align: center;\">&nbsp;</p>\r\n<p style=\"text-align: center;\">当日ブースに来ていただいた学生の皆様ありがとうございました！</p>\r\n<p style=\"text-align: center;\">&nbsp;</p>\r\n<p style=\"text-align: center;\">ブースで学生とお話しするのは楽しく、時間の経過がとても早く感じました</p>\r\n<p style=\"text-align: center;\">&nbsp;</p>\r\n<p style=\"text-align: center;\">あわせて会社見学・仕事体験を予約いただいた方もいらっしゃいました</p>\r\n<p style=\"text-align: center;\">&nbsp;</p>\r\n<p style=\"text-align: center;\">現在、弊社では仕事体験を受け付けております</p>\r\n<p style=\"text-align: center;\">&nbsp;</p>\r\n<p style=\"text-align: center;\">個別の日程相談も可能ですので、お気軽にご相談ください</p>\r\n<p style=\"text-align: center;\">&nbsp;</p>\r\n<p style=\"text-align: center;\">下記リンクからも仕事体験の日程が確認・予約ができます</p>\r\n<p style=\"text-align: center;\">&nbsp;</p>\r\n<p style=\"text-align: center;\"><span style=\"color: #00ccff; font-size: 14pt;\"><a style=\"color: #00ccff;\" href=\"https://job.mynavi.jp/27/pc/corpinfo/displaySeminar/index?optNo=UbJFvC&amp;corpId=211225\">マイナビ2027（説明会予約）</a></span></p>\r\n<p style=\"text-align: center;\"><span style=\"color: #00ccff; font-size: 14pt;\"><a style=\"color: #00ccff;\" href=\"https://job.mynavi.jp/27/pc/corpinfo/displaySeminar/index?optNo=hKTRoC&amp;corpId=61807\">マイナビ2027 スズキ販売会社グループ（説明会予約）</a></span></p>\r\n<p style=\"text-align: center;\">&nbsp;</p>\r\n<p style=\"text-align: center;\">皆さまのご応募お待ちしております</p>\r\n<p style=\"text-align: center;\">&nbsp;</p>\r\n<p style=\"text-align: center;\"><img src=\"/dealer/sj-admin/sharefiles/仕事体験会案内_00912a6a-429b-11f0-90d4-fa163e38a592.jpg\" alt=\"\" width=\"400\" height=\"364\" /></p>\r\n<p style=\"text-align: center;\"><img src=\"/dealer/sj-admin/sharefiles/IMG_6618_f3a43386-32c1-11ef-b187-fa163e38a592.jpg\" alt=\"\" width=\"40