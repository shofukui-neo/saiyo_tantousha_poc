\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/swiper@8/swiper-bundle.min.css\">\n<link rel=\"stylesheet\" href=\"/benesseinfo/saiyou/_assets2024/_common/css/common.css\">\n\n<!-- 固有CSS -->\n<link rel=\"stylesheet\" href=\"/benesseinfo/saiyou/_assets2024/top/css/saiyou.css\">\n\n<!-- Google tag (gtag.js) -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-Y1NDTH7WBN\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n  gtag('config', 'G-Y1NDTH7WBN');\n</script>\n\n</head>\n\n<body>\n\n<div id=\"js-header\"></div>\n\n<!-- .l-main -->\n<main class=\"l-main\">\n\n<!-- mv -->\n<div class=\"p-mv c-mv\">\n\n  <h1 class=\"p-mv-ttl\">\n    <img src=\"/benesseinfo/saiyou/_assets2024/top/img/ttl-mv.png\" width=\"600\" height=\"116\" alt=\"Bene[よく] + esse[生きる] Benesse = 「よく生きる」\" class=\"p-mv-ttl-benesse-white\">\n  </h1>\n  <figure class=\"c-mv-bg is-visible\">\n    <video class=\"c-mv-movie\" src=\"/benesseinfo/saiyou/_assets2024/top/movie/mv.mp4?202408\" playsinline autoplay loop muted></video>\n  </figure>\n\n</div>\n<!-- /mv -->\n\n<!-- recruit -->\n<div class=\"p-recruit c-box-p50-25\">\n  <div class=\"p-recruit-inner c-box-1400\">\n    <ul class=\"p-recruit-links js-mv-fade-trigger\">\n      <li>\n        <a href=\"/fr_s/\" class=\"p-recruit-link\">\n          <div class=\"p-recruit-link-img\">\n            <figure class=\"p-recruit-link-img-inr\">\n              <img src=\"/benesseinfo/saiyou/_assets2024/top/img/202408/img-recruit-new.png\" width=\"600\" height=\"480\" alt=\"\">\n              <figcaption><img src=\"/benesseinfo/saiyou/_assets2024/top/img/txt-recruit-new.png\" width=\"545\" height=\"58\" alt=\"New Graduate\"></figcaption>\n            </figure>\n          </div>\n          <p class=\"p-recruit-link-txt\">新卒採用</p>\n        </a>\n      </li>\n      <li>\n        <a href=\"/benesseinfo/saiyou/cr_s/\" class=\"p-recruit-link\">\n          <div class=\"p-recruit-link-img\">\n            <figure class=\"p-recruit-link-img-inr\">\n              <img src=\"/benesseinfo/saiyou/_assets2024/top/img/202408/img-recruit-career.png\" width=\"600\" height=\"480\" alt=\"\">\n              <figcaption><img src=\"/benesseinfo/saiyou/_assets2024/top/img/txt-recruit-career.png\" width=\"267\" height=\"58\" alt=\"Career\"></figcaption>\n            </figure>\n          </div>\n          <p class=\"p-recruit-link-txt\">中途採用</p>\n        </a>\n      </li>\n    </ul>\n  </div>\n\n</div>\n<!-- /recruit -->\n\n<!-- news -->\n<section class=\"p-news\">\n  <div class=\"p-news-head c-box-1100 c-box-p30-25 js-bg-gray-trigger\">\n    <h2 class=\"p-news-ttl\" id=\"news\"><img src=\"/benesseinfo/saiyou/_assets2024/top/img/202504/ttl-news.png\" width=\"658\" height=\"152\" alt=\"ベネッセコーポレーションの今を知る\"></h2>\n    <p class=\"p-news-lead\">各事業・サービスの事例や社員インタビューなど、<br class=\"u-pc\">ベネッセコーポレーションの最新の活動をご紹介します。</p>\n    <p class=\"p-news-links\"><a href=\"/benesseinfo/saiyou/interview/\" class=\"c-link-arrow-right\"><b>全てのインタビューを見る</b></a></p>\n  </div>\n\n  <div class=\"p-news-body\">\n\n    <div class=\"p-news-swiper-container\">\n\n      <div class=\"swiper p-news-swiper\">\n\n        <div class=\"swiper-wrapper\">\n\n          <div class=\"swiper-slide p-news-swiper-item\">\n            <a href=\"/benesseinfo/saiyou/interview/01/\" class=\"p-news-swiper-link\">\n              <div class=\"p-news-swiper-img\">\n                <figure class=\"p-news-swiper-img-inr\">\n                  <img src=\"/benesseinfo/saiyou/_assets2024/top/img/img-interview01.png\" width=\"300\" height=\"400\" alt=\"\">\n                </figure>\n              </div>\n              <div class=\"p-news-swiper-data\">\n                <p class=\"p-news-swiper-ttl\">スピード感のある環境下で自分の価値を高め続ける</p>\n                <ul class=\"p-news-swiper-tags\">\n                  <li>＃マーケター</li>\n                </ul>\n              </div>\n            </a>\n          </div>\n\n          <div class=\"swiper-slide p-news-swiper-item\">\n            <a href=\"/benesseinfo/saiyou/interview/02/\" class=\"p-news-swiper-link\">\n              <div class=\"p-news-swiper-img\">\n                <figure class=\"p-news-swiper-img-inr\">\n                  <img src=\"/benesseinfo/saiyou/_assets2024/top/img/img-interview02.png\" width=\"300\" height=\"400\" alt=\"\">\n                </figure>\n              </div>\n              <div class=\"p-news-swiper-data\">\n                <p class=\"p-news-swiper-ttl\">最先端の技術を学び、充実した学びの安定強固な基盤をつくる</p>\n                <ul class=\"p-news-swiper-tags\">\n                  <li>＃エンジニア</li>\n                </ul>\n              </div>\n            </a>\n          </div>\n\n          <div class=\"swiper-slide p-news-swiper-item\">\n            <a href=\"/benesseinfo/saiyou/interview/03/\" class=\"p-news-swiper-link\">\n              <div class=\"p-news-swiper-img\">\n                <figure class=\"p-news-swiper-img-inr\">\n                  <img src=\"/benesseinfo/saiyou/_assets2024/top/img/img-interview03.png\" width=\"300\" height=\"400\" alt=\"\">\n                </figure>\n              </div>\n              <div class=\"p-news-swiper-data\">\n                <p class=\"p-news-swiper-ttl\">現場が変革の主体者。自分から仕掛けていける醍醐味</p>\n                <ul class=\"p-news-swiper-tags\">\n                  <li>＃マーケター</li>\n                </ul>\n              </div>\n            </a>\n          </div>\n\n          <div class=\"swiper-slide p-news-swiper-item\">\n            <a href=\"/benesseinfo/saiyou/interview/04/\" class=\"p-news-swiper-link\">\n              <div class=\"p-news-swiper-img\">\n                <figure class=\"p-news-swiper-img-inr\">\n                  <img src=\"/benesseinfo/saiyou/_assets2024/top/img/img-interview04.png\" width=\"300\" height=\"400\" alt=\"\">\n                </figure>\n              </div>\n              <div class=\"p-news-swiper-data\">\n                <p class=\"p-news-swiper-ttl\">自分が手がけたサービスで学校・先生方・生徒が喜ぶ姿に触れることができる</p>\n                <ul class=\"p-news-swiper-tags\">\n                  <li>＃エンジニア</li>\n                </ul>\n              </div>\n            </a>\n          </div>\n\n          <div class=\"swiper-slide p-news-swiper-item\">\n            <a href=\"/benesseinfo/saiyou/interview/05/\" class=\"p-news-swiper-link\">\n              <div class=\"p-news-swiper-img\">\n                <figure class=\"p-news-swiper-img-inr\">\n                  <img src=\"/benesseinfo/saiyou/_assets2024/top/img/img-interview05.png\" width=\"300\" height=\"400\" alt=\"\">\n                </figure>\n              </div>\n              <div class=\"p-news-swiper-data\">\n                <p class=\"p-news-swiper-ttl\">ベンダー出身の自分が事業会社のベネッセでロールモデルに出会えた</p>\n                <ul class=\"p-news-swiper-tags\">\n                  <li>＃マーケター</li>\n                </ul>\n              </div>\n            </a>\n          </div>\n\n        </div>\n\n      </div>\n\n      <div class=\"p-news-swiper-control\">\n        <button class=\"swiper-button-prev p-news-swiper-button-prev\"></button>\n        <p class=\"p-news-swiper-index\"><span class=\"current\">1</span> / <span class=\"total\">5</span></p>\n        <button class=\"swiper-button-next p-news-swiper-button-next\"></button>\n      </div>\n\n    </div>\n\n  </div>\n\n</section>\n<!-- /news -->\n\n<!-- bnrs -->\n<section class=\"p-bnrs c-section\" id=\"bnrs\">\n  <div class=\"c-box-1100 c-box-p30-25\">\n\n    <div class=\"p-bnrs-item\">\n      <h2 class=\"p-bnrs-ttl\">取り組み・採用情報</h2>\n      <ul class=\"p-bnrs-list p-bnrs-list-col2\">\n        <li>\n          <a href=\"https://www.benesse.co.jp/digital/\" class=\"p-bnrs-link\" target=\"_blank\">\n            <div class=\"p-bnrs-link-img\"><img src=\"/benesseinfo/saiyou/_assets2024/top/img/202604/bnr-effort01.png\" alt=\"\"></div>\n            <p class=\"p-bnrs-link-txt\"><span>デジタルで、<br class=\"u-pc\">人にしかできないことを。<br>BenesseのDX戦略</span></p>\n          </a>\n        </li>\n        <li>\n          <a href=\"https://www.benesse.co.jp/lifelong-learning/recruit/\" class=\"p-bnrs-link\" target=\"_blank\">\n            <div class=\"p-bnrs-link-img\"><img src=\"/benesseinfo/saiyou/_assets2024/top/img/bnr-effort02.png\" alt=\"\"></div>\n            <p class=\"p-bnrs-link-txt\"><span>「最新学習歴」を<br>誇れる社会へ<br>Udemy</span></p>\n          </a>\n        </li>\n        <!-- <li>\n          <a href=\"https://bso.benesse.ne.jp/recruit/index.html\" class=\"p-bnrs-link\" target=\"_blank\">\n            <div class=\"p-bnrs-link-img\"><img src=\"/benesseinfo/saiyou/_assets2024/top/img/bnr-effort03.png\" alt=\"\"></div>\n            <p class=\"p-bnrs-link-txt\"><span>教育のイノベーションを<br class=\"u-pc\">牽引し、世界に誇れる<br class=\"u-pc\">公教育の実現を。<br>ミライシード</span></p>\n          </a>\n        </li> -->\n        <li>\n          <a href=\"https://www.benesse.co.jp/brand/\" class=\"p-bnrs-link\" target=\"_blank\">\n            <div class=\"p-bnrs-link-img\"><img src=\"/benesseinfo/saiyou/_assets2024/top/img/bnr-effort04.png\" alt=\"\"></div>\n            <p class=\"p-bnrs-link-txt\"><span>サステナブルな<br>社会へ</span></p>\n          </a>\n        </li>\n      </ul>\n    </div>\n\n  </div>\n</section>\n<!-- /bnrs -->\n\n</main>\n<!-- /.l-main -->\n\n<div id=\"js-footer\"></div>\n<div id=\"js-bg\"></div>\n\n<!-- 共通JS -->\n<script src=\"https://cdnjs.cloudflare.com/ajax/libs/jquery/3.4.1/jquery.min.js\" defer></script>\n<script src=\"https://cdn.jsdelivr.net/gh/studio-freight/lenis@1.0.19/bundled/lenis.min.js\" defer></script>\n<script src=\"https://cdn.jsdelivr.net/npm/swiper@8/swiper-bundle.min.js\" defer></script>\n<script src=\"/benesseinfo/saiyou/_assets2024/_common/js/common.js\" defer></script>\n\n<!-- 固有JS -->\n<script src=\"/benesseinfo/saiyou/_assets2024/top/js/saiyou.js\" defer></script>\n\n<script type=\"text/javascript\" src=\"/_Incapsula_Resource?SWJIYLWA=719d34d31c8e3a6e6fffd425f7e032f3&ns=5&cb=1098746982\" async></script></body>\n</html>","finalUrl":"https://www.benesse.