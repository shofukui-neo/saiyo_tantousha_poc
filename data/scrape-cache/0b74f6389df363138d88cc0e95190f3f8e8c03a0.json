gletagmanager.com/gtag/js?id=UA-121862001-1\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'UA-121862001-1');\n</script>\n\n<!-- Global site tag (gtag.js) - Google Ads: 773888251 -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=AW-773888251\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'AW-773888251');\n</script>\n</head>\n\n<body id=\"body\">\n\n<header role=\"banner\" class=\"header\">\n\n<div class=\"copy\">\n<p>街から街へ、人から人へ、安全・確実・迅速に、心を込めて荷物をお届けする「藤伸」</p>\n</div>\n\n<div class=\"flexbox flex-justify-between flex-align-center\">\n<h1><a href=\"https://toshin-truck.com/\"><img src=\"https://toshin-truck.com/cont/wp-content/themes/toshin_theme/img/common/logo.png\" alt=\"TOSHIN 株式会社 藤伸\"></a></h1>\n<nav id=\"gnav\" class=\"gnav collapse\" role=\"navigation\"> \n<ul class=\"flexbox flex-justify-between\">\n  <li><a href=\"https://toshin-truck.com/service/\">藤伸のサービス</a></li>\n  <li><a href=\"https://toshin-truck.com/activities/\">藤伸の取り組み</a></li>\n  <li><a href=\"https://toshin-truck.com/recruit/\">採用情報</a></li>\n  <li><a href=\"https://toshin-truck.com/company/\">会社案内</a></li>\n  <li class=\"contact\"><a href=\"https://toshin-truck.com/contact/\">お問い合わせ</a></li>\n</ul>\n</nav>\n    <button type=\"button\" id=\"toggle\" class=\"toggle\" data-toggle=\"collapse\" data-target=\"#gnav\" aria-controls=\"gnav\" aria-expanded=\"false\">\n      <span class=\"toggle__bar\"></span>\n      <span class=\"toggle__title\"></span>\n    </button>\n</div>\n</header>\n\n<main role=\"main\" class=\"main\">\n\n\n<section class=\"main-visual slider-viewport\">\n<div class=\"content-box\">\n\n<figure class=\"slide\"><img src=\"https://toshin-truck.com/cont/wp-content/themes/toshin_theme/img/top/main_visual_a.jpg\">\n</figure>\n\n<figure class=\"slide\"><img src=\"https://toshin-truck.com/cont/wp-content/themes/toshin_theme/img/top/main_visual_b.jpg\">\n</figure>\n\n<figure class=\"slide\"><img src=\"https://toshin-truck.com/cont/wp-content/themes/toshin_theme/img/top/main_visual_c.jpg\">\n</figure>\n\n<figure class=\"slide\"><img src=\"https://toshin-truck.com/cont/wp-content/themes/toshin_theme/img/top/main_visual_d.jpg\">\n</figure>\n\n<figure class=\"slide\"><img src=\"https://toshin-truck.com/cont/wp-content/themes/toshin_theme/img/top/main_visual_e.jpg\">\n</figure>\n\n</div>\n<div class=\"caption\">\n<div class=\"container\">\n<h2><img src=\"https://toshin-truck.com/cont/wp-content/themes/toshin_theme/img/top/main_copy.png\" alt=\"クルマだけでは、モノは運べない。\"></h2>\n<a href=\"https://toshin-truck.com/recruit/\" class=\"btn-a\"><!--2019 -->TOSHIN RECRUIT</a>\n</div>\n</div>\n</section>\n\n\n<!--<section class=\"top00\">\n<div class=\"container\">\n<h3>平成30年7月豪雨災害の影響について</h3>\n<p>平素は株式会社藤伸をご利用いただきまして、誠にありがとうございます。</p>\n\n<p>この度の西日本における記録的な豪雨により被災された皆さまに、謹んでお見舞い申し上げます。<br>\n亡くなられた方々のご冥福をお祈り申し上げますとともに、一日も早い復旧を心よりお祈り申し上げます。</p>\n\n\n</div>\n</section>-->\n\n\n<section class=\"top01\">\n<div class=\"container\">\n<img src=\"https://toshin-truck.com/cont/wp-content/themes/toshin_theme/img/top/map_visual.jpg\" alt=\"TOSHIN AREA MAP\">\n<div class=\"catch\">\n<h3>街から街へ、人から人へ、<br>\n｢安全｣｢確実｣｢迅速｣に<br>\n心を込めて荷物をお届け。</h3>\n<p>山陽エリアを中心に阪神･九州エリアまでお客様の大切な商品を確実にお届けできるようにネットワークを構築しています。</p>\n<a href=\"https://toshin-truck.com/service/\" class=\"btn-b\">藤伸のサービス</a>\n</div>\n</div>\n<div class=\"flexbox\">\n  <div class=\"left-contents\">\n<img src=\"https://toshin-truck.com/cont/wp-content/themes/toshin_theme/img/top/transport_visual.jpg\" class=\"visual\">\n<img src=\"https://toshin-truck.com/cont/wp-content/themes/toshin_theme/img/top/transport_ttl.png\" alt=\"TRANSPORT\" class=\"ttl\">\n  </div>\n  <div class=\"right-contents\">\n<img src=\"https://toshin-truck.com/cont/wp-content/themes/toshin_theme/img/top/warehouse_visual.jpg\" class=\"visual\">\n<img src=\"https://toshin-truck.com/cont/wp-content/themes/toshin_theme/img/top/warehouse_ttl.png\" alt=\"WAREHOUSE\" class=\"ttl\">\n  </div>\n</div>\n</section>\n\n<section class=\"top02\">\n<ul class=\"container flexbox\">\n<li class=\"safety\"><a href=\"https://toshin-truck.com/activities/safety/\">安全について</a></li>\n<li class=\"environment\"><a href=\"https://toshin-truck.com/activities/\">品質と環境について</a></li>\n</ul>\n</section>\n\n<section class=\"top03\">\n<!-- <div style=\"width: 100%; height: 500px; background-color: #ccc; \">\n</div> -->\n<div class=\"slider-list\">\n\n<div class=\"slider-a-wrap\">\n<div class=\"slider-a\">\n<div class=\"slide\"><img src=\"https://toshin-truck.com/cont/wp-content/themes/toshin_theme/img/top/slider01_a.jpg\"></div>\n<div class=\"slide\"><img src=\"https://toshin-truck.com/cont/wp-content/themes/toshin_theme/img/top/slider01_b.jpg\"></div>\n</div>\n</div>\n\n<div class=\"slider-bc-wrap\">\n<div class=\"slider-b\">\n<div class=\"slide\"><img src=\"https://toshin-truck.com/cont/wp-content/themes/toshin_theme/img/top/slider02_a.jpg\"></div>\n<div class=\"slide\"><img src=\"https://toshin-truck.com/cont/wp-content/themes/toshin_theme/img/top/slider02_b.jpg\"></div>\n</div>\n<div class=\"slider-c\">\n<div class=\"slide\"><img src=\"https://toshin-truck.com/cont/wp-content/themes/toshin_theme/img/top/slider03_a.jpg\"></div>\n<div class=\"slide\"><img src=\"https://toshin-truck.com/cont/wp-content/themes/toshin_theme/img/top/slider03_b.jpg\"></div>\n</div>\n</div>\n\n<div class=\"slider-d-wrap\">\n<div class=\"slider-d\">\n<div class=\"slide\"><img src=\"https://toshin-truck.com/cont/wp-content/themes/toshin_theme/img/top/slider04_a.jpg\"></div>\n<div class=\"slide\"><img src=\"https://toshin-truck.com/cont/wp-content/themes/toshin_theme/img/top/slider04_b.jpg\"></div>\n</div>\n</div>\n\n<div class=\"slider-ef-wrap\">\n<div class=\"slider-e\">\n<div class=\"slide\"><img src=\"https://toshin-truck.com/cont/wp-c