{"url":"https://www.hitachi-hpm.co.jp/recruit/newgraduate/info.html","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n<head>\n<!-- Google Tag Manager -->\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n})(window,document,'script','dataLayer','GTM-M9FCJQP');</script>\n<!-- End Google Tag Manager -->\n<meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0, user-scalable=no, minimum-scale=1.0, maximum-scale=1.0\">\n<meta name=\"format-detection\" content=\"telephone=no\">\n<meta name=\"author\" content=\"Hitachi Plant Mechanics Co., Ltd.\">\n<meta name=\"robots\" content=\"index, follow\">\n<meta name=\"keywords\" content=\"日立プラントメカニクス,日立グループ,採用,採用情報,クレーン,産業用クレーン\">\n<meta name=\"description\" content=\"クレーンの製作から保守・メンテナンスまで一貫したビジネスを展開する株式会社 日立プラントメカニクスの福利厚生です。\">\n<title>福利厚生：株式会社 日立プラントメカニクス</title>\n<link rel=\"index\" href=\"http://www.hitachi-hpm.co.jp/\" title=\"ホーム\">\n<link rel=\"stylesheet\" type=\"text/css\" media=\"screen,print\" href=\"/css/jp/r1/common.css\">\n<link rel=\"stylesheet\" type=\"text/css\" media=\"screen,print\" href=\"/css/jp/r1/responsive.css\">\n<link rel=\"stylesheet\" type=\"text/css\" media=\"screen,print\" href=\"/css/jp/r1/wide.css\">\n<link rel=\"stylesheet\" type=\"text/css\" media=\"screen,print\" href=\"/css/jp/r1/common2.css\">\n<link rel=\"stylesheet\" type=\"text/css\" media=\"print\" href=\"/css/jp/r1/print.css\">\n<link rel=\"stylesheet\" type=\"text/css\" media=\"screen,print\" href=\"/recruit/css/magnific-popup.css\">\n<link rel=\"stylesheet\" type=\"text/css\" media=\"screen,print\" href=\"/recruit/css/recruit.css\">\n<link rel=\"stylesheet\" type=\"text/css\" media=\"print\" href=\"/recruit/css/recruit_print.css\">\n<script type=\"text/javascript\" src=\"/js/lib/jquery.js\"></script>\n<script type=\"text/javascript\" charset=\"Shift_JIS\" src=\"/js/jp/r1/common.js\"></script>\n<script type=\"text/javascript\" charset=\"Shift_JIS\" src=\"/js/jp/r1/responsive.js\"></script>\n<script type=\"text/javascript\" charset=\"Shift_JIS\" src=\"/js/jp/r1/wide.js\"></script>\n<script type=\"text/javascript\" charset=\"Shift_JIS\" src=\"/js/jp/r1/common2.js\"></script>\n<script type=\"text/javascript\" src=\"https://module.hitachi.com/search/js/sug.js#sv=//mf2aps06.marsflag.com/hitachi__RGN_JAPAN__result_00\"></script>\n<script type=\"text/javascript\" src=\"/recruit/js/jquery.rwdImageMaps.min.js\"></script>\n<script type=\"text/javascript\" src=\"/recruit/js/jquery.matchHeight-min.js\"></script>\n<script type=\"text/javascript\" src=\"/recruit/js/recruit.js\"></script>\n<script>\n/* image click responsive\n----------------------------------------------------- */\n$(function(){\n    $('img[usemap]').rwdImageMaps();\n});\n\n/* height adjust\n----------------------------------------------------- */\n$(function() {\n    if($('.second-anchor > li > a').length){ $('.second-anchor > li > a').matchHeight(); }\n    if($('.info-box-item').length){ $('.info-box .info-box-item').matchHeight(); }\n});\n</script>\n</head>\n<body>\n<!-- Google Tag Manager (noscript) -->\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-M9FCJQP\"\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n<!-- End Google Tag Manager (noscript) -->\n\n<p id=\"top\"><a href=\"#body\">ページの本文へ</a></p>\n\n<div id=\"HeaderArea1\">\n\t<div class=\"Container Wide\">\n\n\t\t<div id=\"Statement\"><a href=\"https://www.hitachi.co.jp/\"><img src=\"/image/jp/r1/common2/corp_id.png\" alt=\"Hitachi\"></a></div>\n\n\t\t<div id=\"SupportNavi\" class=\"SupportNaviIconText\">\n\n\t\t\t<a href=\"https://www8.hitachi.co.jp/inquiry/hitachi-hpm/general/form.jsp\" target=\"_blank\"><img src=\"/image/jp/r1/common2/icon_mail.png\" alt=\"お問い合わせ\"><span>お問い合わせ</span></a>\n\n\t\t\t<button type=\"button\" id=\"SupportNaviSearch\" aria-expanded=\"false\" aria-controls=\"SearchFormArea\"><span><img src=\"/image/jp/r1/common2/icon_search.png\" alt=\"検索\"><span>検索</span></span></button>\n\t\t\t<div id=\"SearchFormArea\">\n\t\t\t\t<div>\n\t\t\t\t\t<button class=\"BtnClose\" aria-label=\"閉じる\"></button>\n\t\t\t\t\t<form action=\"https://module.hitachi.com/search/RGN_JAPAN.html\" method=\"get\" accept-charset=\"UTF-8\">\n\t\t\t\t\t\t<input type=\"hidden\" name=\"imgsize\" value=\"3\">\n\t\t\t\t\t\t<input type=\"hidden\" name=\"pagemax\" value=\"10\">\n\t\t\t\t\t\t<div class=\"SearchGroup\">\n\t\t\t\t\t\t\t<input type=\"text\" name=\"q\" size=\"20\" maxlength=\"40\" accesskey=\"s\" title=\"検索キーワード\" placeholder=\"日立グループ全体から検索\" autocomplete=\"off\" class=\"SearchPhrease\" id=\"MF_form_phrase\">\n\t\t\t\t\t\t\t<button class=\"SearchBtn\" type=\"submit\">検索</button>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</form>\n\t\t\t\t</div>\n\t\t\t</div><!--/#SearchFormArea-->\n\t\t</div><!--/#SupportNavi-->\n\n\t\t<button id=\"SpMenuBtn\" aria-label=\"メニュー\">\n\t\t\t<span></span>\n\t\t\t<span></span>\n\t\t\t<span></span>\n\t\t</button>\n\n\t</div><!--/.Container-->\n</div><!--/#HeaderArea1-->\n\n<div id=\"HeaderArea2\">\n\t<div class=\"Container Wide\">\n\t\t<div id=\"SiteID\">\n\t\t\t<a href=\"/index.html\"><span>株式会社 日立プラントメカニクス</span></a>\n\t\t\t<a href=\"/recruit/index.html\"><span>採用情報</span></a>\n\t\t</div>\n\t\t<ul id=\"GlobalNaviMenu\">\n\t\t\t<li><a href=\"/recruit/newgraduate/about.html\">会社概要</a></li>\n\t\t\t<li class=\"Current\"><a href=\"/recruit/newgraduate/info.html\" aria-crrent=\"true\"><strong>福利厚生</strong></a></li>\n\t\t\t<li><a href=\"/recruit/office.html\">事業所紹介</a></li>\n\t\t\t<li><a href=\"/recruit/newgraduate/job/index.html\">仕事風景</a></li>\n\t\t\t<li><a href=\"/recruit/newgraduate/index.html\">新卒採用</a></li>\n\t\t\t<li><a href=\"https://en-gage.net/hpm_careersaiyo/\" target=\"_blank\">経験者採用</a></li>\n\t\t\t<li><a href=\"/recruit/disability/index.html\">障がい者採用</a></li>\n\t\t</ul>\n\t</div><!--/.Container-->\n</div><!--/#HeaderArea2-->\n\n<div id=\"Contents\" class=\"sub-page\">\n\n\t<div class=\"breadcrumb-list\">\n\t\t<div class=\"GridSet\">\n\t\t\t<div class=\"Grid4\">\n\t\t\t\t<ul>\n\t\t\t\t\t<li><a href=\"/recruit/index.html\">採用情報トップページ</a></li>\n\t\t\t\t\t<li><strong>福利厚生</strong></li>\n\t\t\t\t</ul>\n\t\t\t</div>\n\t\t</div>\n\t</div><!-- /.breadcrumb-list -->\n\n\n\t<div class=\"GridSet wid100p\">\n\t\t<div class=\"Grid4\">\n\n            <div class=\"contents-width\">\n\n                <div class=\"section-recruit sub-page-layout\" id=\"section-interview-top\">\n\n                    <div class=\"recruit-title-en is-vertical info-vertical\">BENEFITS</div>\n\n                    <div class=\"message-title\">\n                        <h1>EMPLOYEE<br>BENEFITS<span>福利厚生</span></h1>\n                    </div><!-- /title-message -->\n\n                </div><!-- /#section-interview-top -->\n\n\t\t\t</div><!-- /.contents-width -->\n\n            <div class=\"contents-width\">\n                <div class=\"message-section contents-section-light\">\n                    <ul class=\"second-anchor\">\n                        <li><a href=\"#anc01\" class=\"smooth-scroll\"><span>人財育成</span></a></li>\n                        <li><a href=\"#anc02\" class=\"smooth-scroll\"><span>福利厚生</span></a></li>\n                    </ul>\n                </div><!-- /message-section -->\n\t\t\t</div><!-- /.contents-width -->\n\n\n            <div class=\"contents-width contents-section\">\n\n                <div class=\"message-section\">\n                    <h2 id=\"anc01\" class=\"title-second\">人財育成</h2>\n                    <p class=\"text-second\">キャリアステージに応じて、求められる役割の認識や能力開発をめざし、さまざまな研修制度を用意。社員一人ひとりが身につけるべき知識・スキルを習得するための能力開発プログラムや、自律的な成長の機会を提供し、個々の成長を支援しています。</p>\n                    <h3 class=\"title-second03 mt-adjust02\">人財育成体系</h3>\n\n                    <div class=\"small-section sp-scroll-box01\">\n                        <p class=\"image-second mt-adjust01\"><img src=\"/recruit/newgraduate/image-info/map_info.png\" alt=\"図：人材育成体系\" usemap=\"#Map\" class=\"img-rwd\">\n                            <map name=\"Map\">\n                                <area shape=\"rect\" coords=\"308,368,487,395\" href=\"#anc-bring01\" class=\"smooth-scroll\" alt=\"ビジネス基礎研修\">\n                                <area shape=\"rect\" coords=\"494,321,551,427\" href=\"#anc-bring02\" class=\"smooth-scroll\" alt=\"メンター制度\">\n                                <area shape=\"rect\" coords=\"308,321,487,349\" href=\"#anc-bring03\" class=\"smooth-scroll\" alt=\"研修員論文発表\">\n                                <area shape=\"rect\" coords=\"308,211,551,238\" href=\"#anc-bring04\" class=\"smooth-scroll\" alt=\"キャリア開発ワークショップ\">\n                                <area shape=\"rect\" coords=\"862,60,985,427\" href=\"#anc-bring05\" class=\"smooth-scroll\" alt=\"職能別スキル強化研修\">\n                                <area shape=\"rect\" coords=\"995,60,1116,427\" href=\"#anc-bring06\" class=\"smooth-scroll\" alt=\"全社研修（日立グループ教育制度活用）\">\n                            </map>\n                        </p>\n                    </div><!-- /small-section .sp-scroll-box600 -->\n\n                    <div class=\"info-box\">\n                        <div id=\"anc-bring01\" class=\"info-box-item\">\n                            <p class=\"info-box-num\">1</p>\n                            <dl class=\"info-box-list\">\n                                <dt>ビジネス基礎研修</dt>\n                                <dd>会社の理解や社会人としての心構え、仕事の基本と進め方、ビジネスマネーなどを学びます。安全行動に関する指導も行うほか、上司、先輩、同僚との関わり合いについても学んでいただきます。</dd>                                \n                            </dl>\n                        </div><!-- /.info-box-item -->\n\n                        <div id=\"anc-bring02\" class=\"info-box-item\">\n                            <p class=\"info-box-num\">2</p>\n                            <dl class=\"info-box-list\">\n                                <dt>メンター制度</dt>\n                                <dd>入社後3年間を上限とし、定期的に1on1を実施し、状況の確認と課題の吸い上げ並びにその課題の解決に向け、的確なアドバイスやサポートを行う等、職場の上下関係ではなく、客観的な立場で個別支援活動を実施するものです。</dd>                                \n                            </dl>\n                        </div><!-- /.info-box-item -->\n\n                        <div id=\"anc-bring03\" class=\"info-box-item\">\n                            <p class=\"info-box-num\">3</p>\n                            <dl class=\"info-box-list\">\n                                <dt>研修員論文発表</dt>\n                                <dd>入社後、2年間の研修員期間の終了にあたり、入社以降に従事してきた仕事について、自分が実施した事項を報告書に纏め、発表することで、「報告書の作成取り纏め能力」および「プレゼンテーションスキル」、「外部とのかかわりの中で技術を客観視できる能力」の習得を目的として実施しています。</dd>                                \n                            </dl>\n                        </div><!-- /.info-box-item -->\n\n                        <div id=\"anc-bring04\" class=\"info-box-item\">\n                            <p class=\"info-box-num\">4</p>\n                            <dl class=\"info-box-list\">\n                                <dt>キャリア開発ワークショップ</dt>\n                                <dd>社員一人ひとりの「働くことへの意思・意欲」を組織の成果に活かす為のキャリア開発支援を行うプログラムです。受講者が自ら、自分の内的な動機づけを自覚し、それに基づいて自ら考え、行動する、自立・自律意識の醸成を図ることを目的にしています。</dd>                                \n                            </dl>\n                        </div><!-- /.info-box-item -->\n\n                        <div id=\"anc-bring05\" class=\"info-box-item\">\n                            <p class=\"info-box-num\">5</p>\n                            <dl class=\"info-box-list\">\n                                <dt>職能別スキル強化研修</dt>\n                                <dd>それぞれの職種・職能ごとに業務内容や階層に応じ、更なるスキルアップを目的として実施しています。<br>営業や設計・開発、製造、管理補系部門ごとに様々なカリキュラムがあり、受講することで更なるステップアップが見込めます。</dd>                                \n                            </dl>\n                        </div><!-- /.info-box-item -->\n\n                        <div id=\"anc-bring06\" class=\"info-box-item\">\n                            <p class=\"info-box-num\">6</p>\n                            <dl class=\"info-box-list\">\n                                <dt>全社研修（日立グループ教育制度活用）</dt>\n                                <dd>日立グループとして実施している研修制度です。ビジネススキルをはじめとして、経営研修や語学講座など、幅広い講座があります。スキルアップはもちろんのこと、日立グループ内の横の繋がりも形成できます。</dd>                                \n                            </dl>\n                        </div><!-- /.info-box-item -->\n                    </div><!-- /.info-box -->\n                    <p class=\"smooth-page-top\"><a href=\"#top\" class=\"smooth-scroll\">ページTOPへ戻る</a></p>\n                </div><!-- /.message-section -->\n\n                <div class=\"message-section\">\n                    <div class=\"small-section\">\n                        <h2 id=\"anc02\" class=\"title-second\">福利厚生</h2>\n                        <h3 class=\"title-second03\">『必要な人に必要なサービスを提供し、さまざまなライフスタイルを支援する』</h3>\n                        <p class=\"text-second\">当社では、個々人のニーズや選択は多様であることやライフステージやイベントによってその都度変化することを踏まえ、「多様な人財の活躍を促進するための福利厚生（育児・介護、健康等への支援）」や「人生や生活の安心・安定に繋がるライフサポートのための福利厚生（資産形成支援・ライフサポート）」を充実させています。</p>\n                    </div><!--/small-section-->\n                </div><!-- /.message-section -->\n\n                <div class=\"message-section\">\n                    <h3 class=\"title-second04\"><span>&#12298;多様な働き方へのサポート&#12299;</span></h3>\n                    <p class=\"text-second\">自分らしく働き、そして成果を出せるよう、時間や場所にとらわれない柔軟な働き方が出来る環境を整えています。効率的且つ、多様な働き方の実現をめざしています。</p>\n                    <ul class=\"info-list\">\n                        <li>フレックスタイム制度</li>\n                        <li>在宅勤務制度</li>\n                    </ul>\n                </div><!-- /.message-section -->\n\n                <div class=\"message-section\">\n                    <h3 class=\"title-second04\"><span>&#12298;ワークワイフバランスへのサポート&#12299;</span></h3>\n                    <p class=\"text-second\">完全週休2日制（土・日）に加えて、年次有給休暇は24日（入社1年目は22日/年）請求することができます。年末年始、ゴールデンウィーク、お盆など、長期の連休も取りやすい環境にあります。さらに、育児休暇、介護休暇、家族看護休暇、配偶者出産休暇、リフレッシュ休暇といった制度も利用でき、仕事とプライベートとの両立がしやすい環境が整っています。</p>\n                    <ul class=\"info-list\">\n                        <li>年次有給休暇</li>\n                        <li>リフレッシュ休暇</li>\n                        <li>出産・育児休暇</li>\n                        <li>配偶者出産休暇</li>\n                        <li>介護休暇</li>\n                        <li>家族看護休暇</li>\n                        \n                    </ul>\n                </div><!-- /.message-section -->\n\n                <div class=\"message-section\">\n                    <h3 class=\"title-second04\"><span>&#12298;資産形成やライフサポート&#12299;</span></h3>\n                    <p class=\"text-second\">将来を見据えた資産形成の支援として、財形貯蓄や日立グループ社員持株会といった制度も用意しています。また、入社してから誰もが安心して生活が送れるよう、生活の基盤である住宅（寮・社宅、住宅手当、持家支援手当）についてもサポートしています。これは、異動した際にも住居の不安を払しょくする役割を果たしています。さらに、万が一の怪我や病気に備え、割安で加入できる保険も準備しております。</p>\n                    <ul class=\"info-list\">\n                        <li>財形貯蓄</li>\n                        <li>日立グループ持株会</li>\n                        <li>住宅支援制度</li>\n                        <li>団体保険</li>\n                    </ul>\n                </div><!-- /.message-section -->\n\n                <div class=\"message-section\">\n                    <h3 class=\"title-second04\"><span>&#12298;自己のキャリア形成サポート&#12299;</span></h3>\n                    <p class=\"text-second\">個人の自律的なキャリア形成を支援すべく、上長との定期的な面談を実施しています。また、自身のなりたい姿へ向け、知識やスキルを計画的に習得できるよう研修も実施しています。</p>\n                    <ul class=\"info-list\">\n                        <li>キャリア面談</li>\n                        <li>キャリア開発研修</li>\n                    </ul>\n                </div><!-- /.message-section -->\n\n                <div class=\"message-section\">\n                    <div class=\"info-declaration\">\n                        <h3 class=\"title-second05\">当社の健康経営宣言</h3>\n                        <p class=\"text-second\">当社は、「安全と健康を守ることは全てに優先する」という日立グループ安全衛生ポリシーの基本理念に基づき、従業員がいきいきと働くために、日立健康保険組合、産業医と連携し、健康保持・増進活動に努め、「安全・健康・快適で働きやすい職場づくり」を実行します。</p>\n                        <a href=\"/corporate/health.html\" class=\"recruit-top-link mt-adjust01\"><div class=\"more-general-red\">詳しくはこちら<span></span></div></a>\n                    </div><!-- /.info-declaration -->\n                    <p class=\"smooth-page-top\"><a href=\"#top\" class=\"smooth-scroll\">ページTOPへ戻る</a></p>\n                </div><!-- /.message-section -->\n\n\t\t\t</div><!-- /.contents-width -->\n\n\n<div class=\"contents-width\">\n\n<div class=\"section-recruit multiple\" id=\"section-entry\">\n<img src=\"/recruit/newgraduate/image/back_entry.jpg\" alt=\"\">\n<div class=\"entry-inner\">\n<div>\n<p>ENTRY</p>\n<p>エントリーはこちらから</p>\n</div>\n<div class=\"entry-link\">\n<p><a href=\"https://job.mynavi.jp/26/pc/search/corp113326/outline.html\" target=\"_blank\">2026卒エントリー<span class=\"entry-arrow\"></span></a></p>\n<p>2027卒エントリー（準備中）</p>\n</div>\n</div>\n</div>\n\n</div><!-- /.contents-width -->\n\n\n\t\t\t<div class=\"accessory-6\">\n\t\t\t\t<span></span>\n\t\t\t\t<span></span>\n\t\t\t\t<span></span>\n\t\t\t\t<span></span>\n\t\t\t\t<span></span>\n\t\t\t\t<span></span>\n\t\t\t\t<span></span>\n\t\t\t</div>\n\n\n\t\t</div><!--/Grid4-->\n\t</div><!--/GridSet-->\n</div><!--/Contents-->\n\n\n\n<div id=\"FooterArea\">\n\t<div class=\"Container Wide\">\n\n\t\t<a href=\"#top\" id=\"FooterPageTop\" aria-label=\"ページの先頭へ\"></a>\n\n\t\t<div id=\"Footer1\">\n\n\t\t\t<div id=\"HitachiTop\">\n\t\t\t\t<a href=\"https://www.hitachi.co.jp/\">日立グループTOP</a>\n\t\t\t</div>\n\n\t\t\t<div id=\"Footer1Menu\">\n\t\t\t\t<a href=\"/utility/termofuse/index.html\">サイトの利用条件</a>\n\t\t\t\t<a href=\"/utility/privacy/index.html\">個人情報保護に関して</a>\n\t\t\t</div>\n\n\t\t\t<div id=\"Copyright\">&copy; Hitachi Plant Mechanics Co., Ltd.<span>2007</span>. All rights reserved.</div>\n\n\t\t</div><!--/#Footer1-->\n\n\t</div><!--/.Container-->\n</div><!--/#FooterArea-->\n\n<script>\n(function (i, s, o, g, r, a, m) {(i[r] = i[r] || function () { (i[r].q = i[r].q || []).push(arguments) }),(a = s.createElement(o)), (m = s.getElementsByTagName(o)[0]);a.async = 1;a.src = g;m.parentNode.insertBefore(a, m);})(window, document, \"script\", \"//ar.mrc-s.com/web/ar.js\", \"mrc\");\nmrc(\"id\", \"mgr8af\");\nmrc(\"autolink\", [\"*.hitachi-hpm.co.jp\", \"hitachi-hpm.mrc-lp.com\"]);\nmrc(\"send\");\n</script>\n\n</body>\n</html>","finalUrl":"https://www.hitachi-hpm.co.jp/recruit/newgraduate/info.html","rendered":false,"_cachedAt":"2026-06-23T20:40:18.130Z"}