ipt src=\"https://code.createjs.com/1.0.0/createjs.min.js\"></script>\n<script src=\"https://cdnjs.cloudflare.com/ajax/libs/processing.js/1.6.2/processing.min.js\"></script>\n\n<script src=\"js/imagesloaded.pkgd.min.js\"></script>\n<script src=\"js/jquery.easing.1.3.min.js\"></script>\n<script src=\"js/jquery.inview.js\"></script>\n<script src=\"js/wave_shape.js\"></script>\n<script src=\"js/wave_fading.js\"></script>\n<script src=\"js/script.js\"></script>\n\n\t\n<script>document.createElement( \"picture\" );</script>\n<script src=\"https://cdnjs.cloudflare.com/ajax/libs/picturefill/3.0.3/picturefill.js\" async></script>\n\t\n\n<!-- @Google Tag Manager -->\n<script type=\"text/javascript\" src=\"/assets/js/ga_gtm.js\"></script>\n<!-- @Google Tag Manager END -->\n</head>\n\n<body id=\"top\">\n<!-- Google Tag Manager (noscript) -->\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-5DX4WVW\"\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n<!-- End Google Tag Manager (noscript) -->\n<noscript>JavascriptがOFFのため正しく表示されない可能性があります。</noscript>\n<a id=\"pagetop\" name=\"pagetop\"></a>\n\n<header>\n\t<div id=\"header_area\">\n\t\t<h1><a href=\"/\"><img src=\"img/p_logo.svg\" alt=\"大鵬薬品\"></a></h1>\n\t\t\n\t\t<div id=\"header_entry\">\n\t\t\t<aside class=\"bt_entry\">\n\t\t\t\t<a href=\"https://axol.jp/zw/s/taiho_28/entry/agreement\" target=\"_blank\">\n\t\t\t\t\t<div class=\"btbody\"><div><span class=\"en\">ENTRY</span></div></div>\n\t\t\t\t</a>\n\t\t\t</aside>\n\t\t</div>\n\t</div>\n</header>\n\n\n\n\n<div class=\"wrapper\">\n\n<!-- main -->\n\t\n\t<div id=\"main\" class=\"full\">\n\t\t<main>\n\t\t\t\n\t\t\t<h1>\n\t\t\t\t<article>\n\t\t\t\t\t<div><span>製薬技術研究職</span><i> </i><br class=\"only_1200\"><span style=\"padding-right: .5em;\">仕事体験</span><span>2028</span></div><br>\n\t\t\t\t</article>\n\t\t\t</h1>\n\t\t\t\n\t\t\t\n\t\t\t<ul>\n\t\t\t\t<li id=\"mainp_1\" class=\"active_on\">\n\t\t\t\t\t<figure>\n\t\t\t\t\t\t<div>\n\t\t\t\t\t\t\t<source media=\"(min-width: 769px)\" srcset=\"img/main_1.jpg\">\n\t\t\t\t\t\t\t<img src=\"img/main_1_sp.jpg\" alt=\"\">\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</figure>\n\t\t\t\t</li>\n\t\t\t\t<li id=\"mainp_2\" class=\"active_on\">\n\t\t\t\t\t<figure>\n\t\t\t\t\t\t<div>\n\t\t\t\t\t\t\t<source media=\"(min-width: 769px)\" srcset=\"img/main_2.jpg\">\n\t\t\t\t\t\t\t<img src=\"img/main_2_sp.jpg\" alt=\"\">\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</figure>\n\t\t\t\t</li>\n\t\t\t\t<li id=\"mainp_3\" class=\"active_on\">\n\t\t\t\t\t<figure>\n\t\t\t\t\t\t<div>\n\t\t\t\t\t\t\t<source media=\"(min-width: 769px)\" srcset=\"img/main_3.jpg\">\n\t\t\t\t\t\t\t<img src=\"img/main_3_sp.jpg\" alt=\"\">\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</figure>\n\t\t\t\t</li>\n\t\t\t\t<li id=\"mainp_4\" class=\"active_on\">\n\t\t\t\t\t<figure>\n\t\t\t\t\t\t<div>\n\t\t\t\t\t\t\t<source media=\"(min-width: 769px)\" srcset=\"img/main_4.jpg\">\n\t\t\t\t\t\t\t<img src=\"img/main_4_sp.jpg\" alt=\"\">\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</figure>\n\t\t\t\t</li>\n\t\t\t\t\n\t\n\t\t\t</ul>\n\t\t\t\n\t\t\t<div id=\"bg_red\"><aside></aside></div>\n\t\t\t<div id=\"bg_black\"></div>\n\t\t</main>\n\t</div>\n\t\n<!-- /main -->\n\n\t<div id=\"contents\">\n\t\t\n\t\t<aside class=\"titelnote\">CMC:Chemistry(化学), Manufacturing (製造)and Control(品質管理)</aside>\n\n\t\n\t\t<section id=\"message_area\">\n\t\t\t<div class=\"inner\">\n\t\t\t\t<article>\n\t\t\t\t\t<h1 class=\"inview_anime\"><span>製薬会社の製薬技術研究って<br>どんなもの？</span></h1>\n\t\t\t\t\t\n\t\t\t\t\t<h3 class=\"inview_anime\">「医薬品」をつくりだす要となる<br>モノづくりにかかわる研究領域を<br class=\"only_480\">学ぶ2日間</h3>\n\n\t\t\t\t\t<p>\n\t\t\t\t\t<i class=\"inview_anime\">\n\t\t\t\t\t<strong>《いつもを、いつまでも》</strong><br>\n\t\t\t\t\tあたり前のようにつづく毎日ほど、<br class=\"only_480\">かけがえのないものはない。<br>\n\t\t\t\t\t大切な「いつも」が失われた時、<br class=\"only_480\">強く取り戻す力を届けたい。<br><br>\n\t\t\t\t\t</i>\n\t\t\t\t\t<i class=\"inview_anime\">\n\t\t\t\t\t私たち大鵬薬品は、<br class=\"only_480\">がん領域・免疫関連疾患領域を中心に<br class=\"only_480\">新薬の研究開発(創薬)を行い、<br>\n\t\t\t\t\t薬を通じて世界中の患者さんと<br class=\"only_480\">ご家族にかけがえのない<br class=\"br_950\">「いつも」と「笑顔」を届けるため、<br>\n\t\t\t\t\t使命感をもって挑戦し続けています。<br><br>\n\t\t\t\t\t</i>\n\t\t\t\t\t<i class=\"inview_anime\">\n\t\t\t\t\t皆さんは、新薬の研究開発から医療現場への<br class=\"br_950\">供給までの一連の過程において、<br>\n\t\t\t\t\t創薬研究（創薬）と臨床開発(治験)、<br class=\"br_480\">そして商用生産（医療現場への供給）をつなぐ<br>\n\t\t\t\t\t<span class=\"redline p_right\">「製薬技術研究」という領域</span>があることを<br class=\"only_480\">知っていますか？<br>\n\t\t\t\t\t創薬研究で見いだした”クスリの種”を<br>\n\t\t\t\t\t臨床試験で患者さんにご使用いただく「治験薬」に<br class=\"no_480\">創りあげ、製造販売承認申請を行う。<br>その後、製造販売承認後に患者さんにご使用いただく「医薬品」を<br class=\"no_480\">安定的に製造するための製法を確立する。<br>さらに商用製造された医薬品が確かな「品質」を<br class=\"br_950_480\">備えていることを管理する―<br>\n\t\t\t\t\t<em class=\"no_600\">こうした<span class=\"redline p_side p_right\">新薬創製から医療の現場への供給の要となる研究領域</span>が<br><span class=\"redline p_side\">「製薬技術研究職」</span>です。</em>\n\t\t\t\t\t<em class=\"only_600\">こうした<span class=\"redline p_side p_right\">新薬創製から医療の現場への</span><br class=\"only_600\"><span class=\"redline p_side p_right\">供給の要となる研究領域</span>が<br><span class=\"redline p_side\">「製薬技術研究職」</span>です。</em><br><br>\n\t\t\t\t\t</i>\n\t\t\t\t\t<i class=\"inview_anime\">\n\t\t\t\t\t具体的にどんなことをするの？<br>\n\t\t\t\t\tどんなスキルが必要？<br>\n\t\t\t\t\tやりがいは？<br>\n\t\t\t\t\tどんな人たちが活躍しているの？<br><br>\n\t\t\t\t\t</i>\n\t\t\t\t\t<i class=\"inview_anime\">\t\t\t\t\t\n\t\t\t\t\tこのような疑問に向け、<br class=\"only_600\">当社の製薬技術研究を詳しく知っていただく<br>\n\t\t\t\t\t「2DAYS 仕事体験」を<br class=\"only_600\">開催いたします！\n\t\t\t\t\t</i>\n\t\t\t\t\t</p>\n\t\t\t\t</article>\n\t\t\t</div>\n\t\t</section>\n\t\t\t\n\t\t\t\n\t\t\n\t\t\n\t\t\n\t\t\n\t\t\n\t\t<div id=\"red_area\" class=\"inview_anime\">\n\t\t\t\n\t\t\t<div id=\"red_area_inner\">\n\n\t\t\t\t<section id=\"business_area\" class=\"max_1060\">\n\t\t\t\t\t<div class=\"inner\">\n\t\t\t\t\t\t<article>\n\n\t\t\t\t\t\t\t<h2 class=\"inview_anime\">\n\t\t\t\t\t\t\t\t製薬技術研究の任務は多岐にわたり、<br>\n\t\t\t\t\t\t\t\t合成化学、プロセス化学、薬剤学、粉体工学、化学工学、品質保証など<br class=\"no_768\">多様な知識・スキルを用いて下のような研究/業務を行っています。\n\t\t\t\t\t\t\t</h2>\n\n\t\t\t\t\t\t\t<dl class=\"inview_anime\">\n\t\t\t\t\t\t\t\t<dt>\n\t\t\t\t\t\t\t\t\t研究/業務内容\n\t\t\t\t\t\t\t\t</dt>\n\n\t\t\t\t\t\t\t\t<dd>\n\t\t\t\t\t\t\t\t\t<span>原薬の合成プロセス（合成法・製法）開発研究</span>\n\t\t\t\t\t\t\t\t\t<span>治験原薬の品質評価方法の開発研究</span>\n\t\t\t\t\t\t\t\t\t<span>製剤処方・製法の開発</span>\n\t\t\t\t\t\t\t\t\t<span>製剤分析法の開発</span>\n\t\t\t\t\t\t\t\t\t<span>商用生産のスケールアップ検討 医薬品の包装設計</span>\n\t\t\t\t\t\t\t\t\t<span>医薬品の品質改善</span>\n\t\t\t\t\t\t\t\t\t<span>医薬品の品質管理</span>\n\t\t\t\t\t\t\t\t\t<span>治験薬の品質・安定性評価</span>\n\t\t\t\t\t\t\t\t\t<span>治験原薬の製造・製造設備の管理</span>\n\t\t\t\t\t\t\t\t\t<span>治験申請及び新薬申請への対応</span>\n\t\t\t\t\t\t\t\t\t<sub>など</sub>\n\t\t\t\t\t\t\t\t</dd>\n\t\t\t\t\t\t\t</dl>\n\t\t\t\t\t\t</article>\n\n\t\t\t\t\t</div>\n\t\t\t\t</section>\n\n\n\n\n\n\t\t\t\t<section id=\"overview_area\" class=\"inview_anime\">\n\t\t\t\t\t\n\t\t\t\t\t<div class=\"inner inview_anime\">\n\n\t\t\t\t\t\t<h4 class=\"inview_anime\"><span>製薬技術研究職</span><br><span>2DAYS<br class=\"only_480\">仕事体験 2028</span></h4>\n\n\t\t\t\t\t\t<ul id=\"overview_list\" class=\"inview_anime\">\n\n\t\t\t\t\t\t\t<li><span>開催日程</span></li>\n\t\t\t\t\t\t\t<li>\n\t\t\t\t\t\t\t\t<div>\n\t\t\t\t\t\t\t\t\t<h5><span>DAY 1</span></h5>\n\t\t\t\t\t\t\t\t\t<div class=\"datebox\">\n\t\t\t\t\t\t\t\t\t\t<aside>第1回</aside><span>2026年10月11日（日）</span><br>\n\t\t\t\t\t\t\t\t\t\t<aside>第2回</aside><span>2026年10月13日（火）</span>\n\t\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t\t<div class=\"notebox\">\n\t\t\t\t\t\t\t\t\t\t<span class=\"note\">両日とも9:30～17:00（予定）</span>\n\t\t\t\t\t\t\t\t\t\t<span class=\"note\">2日間とも同じ内容となります。どちらかの日程にご参加いただきます。</span>\n\t\t\t\t\t\t\t\t\t\t<span class=\"note\">各職種の仕事体験参加者合同での開催になります。</span>\n\t\t\t\t\t\t\t\t\t\t<span class=\"note\">DAY2以降の各職種の仕事体験に応募する場合、DAY1も参加必須です。</span>\n\t\t\t\t\t\t\t\t\t</div>\n<br>\n\t\t\t\t\t\t\t\t\t<h5><span>DAY 2</span></h5>\n\t\t\t\t\t\t\t\t\t参加する領域により下記いずれかで実施\n\t\t\t\t\t\t\t\t\t<div class=\"datebox\">\n\t\t\t\t\t\t\t\t\t\t<aside>第1回</aside><span>2026年11月14日（土）</span><br>\n\t\t\t\t\t\t\t\t\t\t<ul class=\"listbox\">\n\t\t\t\t\t\t\t\t\t\t\t<li>開催場所：埼玉工場</li>\n\t\t\t\t\t\t\t\t\t\t\t<li>領域：原薬およびLinker-Payloadの分析法開発領域、原薬の品質管理領域</li>\n\t\t\t\t\t\t\t\t\t\t</ul>\n\t\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t\t<div class=\"datebox\">\n\t\t\t\t\t\t\t\t\t\t<aside>第2回</aside><span>2026年11月15日（日）</span><br>\n\t\t\t\t\t\t\t\t\t\t<ul class=\"listbox\">\n\t\t\t\t\t\t\t\t\t\t\t<li>開催場所：埼玉工場</li>\n\t\t\t\t\t\t\t\t\t\t\t<li>領域：原薬およびLinker-Payloadのプロセス開発領域</li>\n\t\t\t\t\t\t\t\t\t\t</ul>\n\t\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t\t<div class=\"datebox\">\n\t\t\t\t\t\t\t\t\t\t<aside>第3回</aside><span>2026年11月28日（土）</span><br>\n\t\t\t\t\t\t\t\t\t\t<ul class=\"listbox\">\n\t\t\t\t\t\t\t\t\t\t\t<li>開催場所：つくば研究所</li>\n\t\t\t\t\t\t\t\t\t\t\t<li>領域：バイオ原薬・製剤領域</li>\n\t\t\t\t\t\t\t\t\t\t</ul>\n\t\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t\t<div class=\"datebox\">\n\t\t\t\t\t\t\t\t\t\t<aside>第4回</aside><span>2026年12月5日（土）</span><br>\n\t\t\t\t\t\t\t\t\t\t<ul class=\"listbox\">\n\t\t\t\t\t\t\t\t\t\t\t<li>開催場所：徳島工場</li>\n\t\t\t\t\t\t\t\t\t\t\t<li>領域：医薬品の製剤開発領域、医薬品の分析法開発領域</li>\n\t\t\t\t\t\t\t\t\t\t</ul>\n\t\t\t\t\t\t\t\t\t</div>\n\n\t\t\t\t\t\t\t\t\t<div class=\"notebox\">\n\t\t\t\t\t\t\t\t\t\t<span class=\"note\">いずれの日程も9:00～16:30（予定）</span>\n\t\t\t\t\t\t\t\t\t\t<span class=\"note\">選択する領域により内容が異なります。</span>\n\t\t\t\t\t\t\t\t\t</div>\n\n\t\t\t\t\t\t\t\t\t<ul class=\"listbox\">\n\t\t\t\t\t\t\t\t\t\t<li>Day2対面開催時には、遠方の方に一部交通費を支給します。</li>\n\t\t\t\t\t\t\t\t\t\t<li>交通機関の都合上、宿泊が必要な方は、当社にて手配させていただきます。（宿泊費用は当社が負担します）</li>\n\t\t\t\t\t\t\t\t\t</ul>\n\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t</li>\n\n\n\t\t\t\t\t\t\t<li><span>開催場所</span></li>\n\t\t\t\t\t\t\t<li>\n\t\t\t\t\t\t\t\t<div>\n\t\t\t\t\t\t\t\t\t<h5><span>DAY 1</span></h5>\n\t\t\t\t\t\t\t\t\t<ul class=\"listbox\">\n\t\t\t\t\t\t\t\t\t\t<li>ON-LINE開催</li>\n\t\t\t\t\t\t\t\t\t</ul>\n\n\t\t\t\t\t\t\t\t\t<br>\n\t\t\t\t\t\t\t\t\t<h5><span>DAY 2</span></h5>\n\t\t\t\t\t\t\t\t\t参加する領域により下記いずれかで実施\n\t\t\t\t\t\t\t\t\t<ul class=\"listbox\">\n\t\t\t\t\t\t\t\t\t\t<li>埼玉工場：埼玉県児玉郡神川町大字元原200-22（第1回、第2回）</li>\n\t\t\t\t\t\t\t\t\t\t<li>つくば研究所：茨城県つくば市大久保3（第3回） </li>\n\t\t\t\t\t\t\t\t\t\t<li>徳島工場：徳島市川内町平石夷野224-2（第4回） </li>\n\t\t\t\t\t\t\t\t\t</ul>\n\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t</li>\n\n\n\t\t\t\t\t\t\t<li><span>プログラム概要</span></li>\n\t\t\t\t\t\t\t<li>\n\t\t\t\t\t\t\t\t<div>\n\t\t\t\t\t\t\t\t\t<div class=\"notebox\">\n\t\t\t\t\t\t\t\t\t\t<span class=\"note\">一部変更になる可能性があります</span>\n\t\t\t\t\t\t\t\t\t</div>\n\n\t\t\t\t\t\t\t\t\t<h5><span>DAY 1</span></h5>\n\t\t\t\t\t\t\t\t\t<ul class=\"listbox\">\n\t\t\t\t\t\t\t\t\t\t<li>基礎講座：製薬業界全体を俯瞰し、バリューチェーンの流れと各職種の役割を包括的に理解する</li>\n\t\t\t\t\t\t\t\t\t\t<li>創薬から育薬まで、薬の“一生”をたどりながら、大鵬薬品におけるバリューチェーンのつながりを体感できる実践型ワーク</li>\n\t\t\t\t\t\t\t\t\t\t<li>多職種が交差する学び合いの場を通じて、学びと気づきを深める振り返りセッション</li>\n\t\t\t\t\t\t\t\t\t</ul>\n\n\t\t\t\t\t\t\t\t\t<br>\n\t\t\t\t\t\t\t\t\t<h5><span>DAY 2</span></h5>\n\t\t\t\t\t\t\t\t\t<ul class=\"listbox\">\n\t\t\t\t\t\t\t\t\t\t<li>基礎レクチャー：「製薬技術研究について」</li>\n\t\t\t\t\t\t\t\t\t\t<li>グループワーク：「製薬技術研究理解・体感ワーク」</li>\n\t\t\t\t\t\t\t\t\t\t<li>施設/ラボ紹介</li>\n\t\t\t\t\t\t\t\t\t\t<li>社員との座談会</li>\n\t\t\t\t\t\t\t\t\t</ul>\n\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t</li>\n\n\n\t\t\t\t\t\t\t<li><span>参加条件</span></li>\n\t\t\t\t\t\t\t<li>\n\t\t\t\t\t\t\t\t<div>\n\t\t\t\t\t\t\t\t\t<div class=\"strong_line\">下記領域に興味を持つ理系学生</div><br>\n\t\t\t\t\t\t\t\t\t<span style=\"padding-bottom: 10px;\">2028年3月までに修士課程以上を修了予定の方</span>\n\t\t\t\t\t\t\t\t\t\n\n\t\t\t\t\t\t\t\t\t<ul class=\"listbox\" style=\"padding-bottom: 5px;\">\n\t\t\t\t\t\t\t\t\t\t<li>原薬およびLinker-Payloadのプロセス開発領域</li>\n\t\t\t\t\t\t\t\t\t\t<li>医薬品の製剤開発領域</li>\n\t\t\t\t\t\t\t\t\t\t<li>バイオ原薬・製剤領域</li>\n\t\t\t\t\t\t\t\t\t\t<li>原薬およびLinker-Payloadの分析法開発領域</li>\n\t\t\t\t\t\t\t\t\t\t<li>医薬品の分析法開発領域</li>\n\t\t\t\t\t\t\t\t\t\t<li>原薬の品質管理領域</li>\n\t\t\t\t\t\t\t\t\t</ul>\n\n\t\t\t\t\t\t\t\t\t<span class=\"note\">バイオ原薬・製剤のプロセス・分析に興味のある方は「バイオ領域」にご応募ください。</span>\n\t\t\t\t\t\t\t\t\t\n\n\t\t\t\t\t\t\t\t\t<span style=\"margin-top: 10px