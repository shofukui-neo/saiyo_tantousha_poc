cript async src=\"https://cse.google.com/cse.js?cx=d0af03f9c1c0847f1\"></script>\r\n          <div class=\"gcse-search\"></div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</header><!-- /header -->\r\n\r\n<main class=\"main\">\r\n<div class=\"js-anime js-anime-container\">\r\n<section class=\"mainimg-sec js-anime js-anime-fadein\">\r\n  <h2 class=\"mainimg-fig\">\r\n    <div style=\"position: relative; \">\r\n      <img src=\"assets/img/home/main.jpg\" alt=\"愛知県職員募集\" class=\"w100 only-pc\"><img src=\"assets/img/home/sp/main.jpg\" alt=\"愛知県職員募集\" class=\"w100 only-sp\">\r\n         <a href=\"https://www.pref.aichi.jp/press-release/r8-shikennittei.html\">\r\n\r\n           <img style=\"position: absolute; bottom: 5px; right: 5px; width: 60%; height: auto; \" src=\"assets/img/home/bn_schedule.svg\" alt=\"2026（令和8）年度愛知県職員採用試験等の日程及び主な変更点について\" class=\"only-pc\" >\r\n\r\n           <img style=\"position: absolute; bottom: 2px; left: 50%; transform: translateX(-50%); width: 95%; height: auto; \" src=\"assets/img/home/bn_schedule_sp.svg\" alt=\"2026（令和8）年度愛知県職員採用試験等の日程及び主な変更点について\" class=\"only-sp\" >\r\n\r\n         </a>\r\n       </div>\r\n     </h2>\r\n</section>\r\n\r\n<section class=\"news-sec js-anime js-anime-fadein\">\r\n  <div class=\"mainttl\">\r\n    <p class=\"mainttl-en\"><img src=\"assets/img/home/news_ttl.svg\" alt=\"News\"></p>\r\n    <div class=\"inner\">\r\n      <div class=\"mainttl-in\">\r\n        <h2 class=\"mainttl-txt\"><span>新着情報</span></h2>\r\n      </div>\r\n    </div>\r\n  </div>\r\n  <div class=\"news-con\">\r\n    <div class=\"news-in\">\r\n      <div class=\"inner\">\r\n        <ul class=\"news-list\" id=\"json_news\">\r\n\r\n\r\n        </ul>\r\n        <p class=\"news-btn\"><a href=\"news/\" class=\"c-btn\"><span>一覧へ</span></a></p>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</section>\r\n</div>\r\n\r\n<section class=\"intro-sec js-anime js-anime-fadein\">\r\n  <div class=\"mainttl\">\r\n    <p class=\"mainttl-en\"><img src=\"assets/img/home/intro_ttl.svg\" alt=\"Introduction\"></p>\r\n    <div class=\"inner\">\r\n      <div class=\"mainttl-in\">\r\n        <h2 class=\"mainttl-txt\"><span>はじめに</span></h2>\r\n      </div>\r\n    </div>\r\n  </div>\r\n  <div class=\"intro-con\">\r\n    <div class=\"inner\">\r\n      <div class=\"intro-in\">\r\n        <p class=\"intro-txt\">愛知県庁は、地域づくりの担い手として、どのような未来をつくろうとしているのか。<br>\r\n        「知事メッセージ」、「あいちビジョン2030の概要」などから見ていきます。</p>\r\n        <p class=\"intro-btn\"><a href=\"introduction/\" class=\"c-btn\"><span>詳しく見る</span></a></p>\r\n      </div>\r\n    </div>\r\n    <figure><img src=\"assets/img/home/intro_p01.jpg\" alt=\"はじめにの画像\" class=\"w100\"></figure>\r\n  </div>\r\n</section>\r\n\r\n<section class=\"work-sec js-anime js-anime-fadein\">\r\n  <div class=\"mainttl\">\r\n    <p class=\"mainttl-en\"><img src=\"assets/img/home/work_ttl.svg\" alt=\"Work & Professionals\" class=\"only-pc\"><img src=\"assets/img/home/sp/work_ttl.svg\" alt=\"Work & Professionals\" class=\"only-sp\"></p>\r\n    <div class=\"inner\">\r\n      <div class=\"mainttl-in\">\r\n        <h2 class=\"mainttl-txt\"><span>あいちの未来をつくる仕事と人</span></h2>\r\n      </div>\r\n    </div>\r\n  </div>\r\n  <div class=\"work-con\">\r\n    <div class=\"inner\">\r\n      <div class=\"work-in\">\r\n        <p class=\"work-lead\">それぞれの専門性をもとに、様々な経験を経て、幅広い視野と課題解決能力を身につけながら成長する県職員。<br>\r\n        県民の豊かな生活を実現するため、多様化・高度化する課題に対応する県職員は、まさに行政のプロフェッショナル。</p>\r\n        <div class=\"work-box\">\r\n          <div class=\"work-box-fig\">\r\n            <figure><img src=\"assets/img/home/work_p01.jpg\" alt=\"あいちの未来をつくる仕事と人の画像1\"></figure>\r\n            <figure><img src=\"assets/img/home/work_p03.jpg\" alt=\"あいちの未来をつくる仕事と人の画像2\"></figure>\r\n            <figure><img src=\"assets/img/home/work_p02.jpg\" alt=\"あいちの未来をつくる仕事と人の画像3\"></figure>\r\n          </div>\r\n          <div class=\"work-box-in\">\r\n            <div class=\"work-box-con\">\r\n              <p class=\"work-box-en\">Work <br>Interview</p>\r\n              <h3 class=\"work-box-ttl\">職種紹介<br>職員インタビュー</h3>\r\n              <p class=\"work-box-btn\"><a href=\"work/\" class=\"c-btn\"><span>詳しく見る</span></a></p>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</section>\r\n\r\n<section class=\"training-sec js-anime js-anime-fadein\">\r\n  <div class=\"mainttl\">\r\n    <p class=\"mainttl-en\"><img src=\"assets/img/home/training_ttl.svg\" alt=\"Training & Benefits\"></p>\r\n    <div class=\"inner\">\r\n      <div class=\"mainttl-in\">\r\n        <h2 class=\"mainttl-txt\"><span>ステップアップ！</span></h2>\r\n      </div>\r\n    </div>\r\n  </div>\r\n  <div class=\"training-con\">\r\n    <div class=\"inner\">\r\n      <div class=\"training-in\">\r\n        <p class=\"training-txt\">愛知県はスキルアップに最適な環境が整っています。<br>\r\n        幅広い職場を経験して視野を広げたり、一つの分野で仕事を極めたりなど、県職員としてのスキルアップを目指すことができます。<br>\r\n        気になる給与や福利厚生、勤務条件、配属や異動などに関する詳しい情報も紹介します。</p>\r\n        <p class=\"training-btn\"><a href=\"training/\" class=\"c-btn\"><span>詳しく見る</span></a></p>\r\n      </div>\r\n    </div>\r\n    <figure><img src=\"assets/img/home/training_p01.jpg\" alt=\"ステップアップ！の画像\" class=\"w100\"></figure>\r\n  </div>\r\n</section>\r\n\r\n<section class=\"pickup-sec js-anime js-anime-fadein\">\r\n  <div class=\"mainttl\">\r\n    <p class=\"mainttl-en\"><img src=\"assets/img/home/pickup_ttl.svg\" alt=\"Pick up Contents\"></p>\r\n    <div class=\"inner\">\r\n      <div class=\"mainttl-in\">\r\n        <h2 class=\"mainttl-txt\"><span>愛知県職員のことを<br class=\"only-sp\">もっと知る！</span></h2>\r\n      </div>\r\n    </div>\r\n  </div>\r\n  <div class=\"pickup-con\">\r\n    <div class=\"inner\">\r\n      <ul class=\"pickup-list\">\r\n        <li class=\"pickup-list-item\">\r\n          <figure><img src=\"assets/img/home/pickup_p01.jpg\" alt=\"特集の画像\" class=\"w100\"></figure>\r\n          <div class=\"pickup-nav\">\r\n            <p class=\"pickup-nav-p\">特集</p>\r\n            <ul class=\"pickup-nav-c\">\r\n<