s/ogp.png\">\r\n  <meta name=\"format-detection\" content=\"telephone=no\">\r\n  <link rel=\"apple-touch-icon\" sizes=\"180x180\" href=\"/assets/images/apple-touch-icon.png\">\r\n  <link rel=\"icon\" sizes=\"32x32\" href=\"/favicon.ico\">\r\n  <link rel=\"stylesheet\" href=\"/assets/css/common.css\">\r\n  <link rel=\"stylesheet\" href=\"/assets/css/components.css\">\r\n  <script src=\"/assets/js/common.js\" defer></script>\r\n\r\n  <!-- css -->\r\n  <link rel=\"stylesheet\" href=\"/assets/css/contact.css\">\r\n\r\n  <!-- js -->\r\n  <script src=\"/assets/js/contact/incliude.fetcher.js\" defer></script>\r\n  <script src=\"/assets/js/contact/jquery-1.11.3.min.js\"></script>\r\n  <script src=\"/assets/js/contact/jquery.validate.min.js\"></script>  \r\n  <script src=\"/assets/js/contact/form.js\"></script>\r\n</head>\r\n\r\n<body class=\"contact\" id=\"index\">\r\n  <!-- Google Tag Manager (noscript) -->\r\n  <noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-MJZNRR8J\"\r\n  height=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\r\n  <!-- End Google Tag Manager (noscript) -->\r\n  <!-- Google Tag Manager (noscript) -->\r\n  <noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-KHDD6M75\"\r\n  height=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\r\n  <!-- End Google Tag Manager (noscript) -->\r\n\r\n  <!---------- Header ---------->\r\n  <div id=\"include-header\"></div>\r\n  <!---------- /Header ---------->\r\n\r\n  <main class=\"l-main\">\r\n    <div class=\"c-billboard\">\r\n      <div class=\"c-billboard__inner\">\r\n        <h1 class=\"c-billboard__title\">お問い合わせ</h1>\r\n      </div>\r\n    </div>\r\n    <div class=\"l-content\">\r\n      <div class=\"l-breadcrumb\">\r\n        <div class=\"l-breadcrumb__inner\">\r\n          <ol class=\"l-breadcrumb__list\" itemscope=\"itemscope\" itemtype=\"https://schema.org/BreadcrumbList\">\r\n            <li itemprop=\"itemListElement\" itemscope=\"itemscope\" itemtype=\"https://schema.org/ListItem\">\r\n              <a href=\"/index.html\" itemprop=\"item\" class=\"c-textlink\"><span itemprop=\"name\">HOME</span></a>\r\n              <meta itemprop=\"position\" content=\"1\">\r\n            </li>\r\n            <li itemprop=\"itemListElement\" itemscope=\"itemscope\" itemtype=\"https://schema.org/ListItem\">\r\n              <a href=\"/contact/index.html\" itemprop=\"item\" class=\"c-textlink\"><span itemprop=\"name\">お問い合わせ</span></a>\r\n              <meta itemprop=\"position\" content=\"2\">\r\n            </li>\r\n          </ol>\r\n        </div>\r\n      </div>\r\n      <div class=\"l-section l-default-margin\">\r\n        <div class=\"l-section-sm l-default-margin\">\r\n          <div class=\"c-contentbox\">\r\n            <ul class=\"c-list\">\r\n              <li class=\"c-list__item\">ご入力情報は、お問い合わせへの回答のために利用させていただきます。<br>\r\n              電子メール以外の方法でご連絡する場合がありますので、情報を正しくご入力いただくようお願いいたします。</li>\r\n              <li class=\"c-list__item\">お問い合わせについては、当社営業時間内（8:00～17:00 ※当社規定の休業日除く）に対応いたします。</li>\r\n              <li class=\"c-list__item\">お問い合わせにはできる限り迅速に対応いたしますが、内容によって回答までにお時間をいただく場合や<br>\r\n              回答を差し控えさせていただく場合もございます。あらかじめご了承ください。</li>\r\n              <li class=\"c-list__item\">フォーム送信後、ご入力いただいたメールアドレス宛てに確認メールが自動配信されます。<br>\r\n              届かない場合は、お問い合わせへのご返答ができない可能性がありますのでご注意ください。</li>\r\n              <li class=\"c-list__item\">正確に送信されない場合がありますので、環境依存文字・機種依存文字の使用はお控えください。</li>\r\n              <li class=\"c-list__item\">お車の部品に関するご質問は、お買い上げいただいたディーラーまたは販売店にお問い合わせください。</li>\r\n            </ul>\r\n          </div>\r\n\r\n          <div class=\"sec-contact-note u-mt-m\">\r\n            <ul class=\"c-remarks\">\r\n              <li class=\"c-remarks__item\">お客様からお預かりした情報は、当社「個人情報保護方針」に基づき適正に管理いたします。</li>\r\n              <li class=\"c-remarks__item\">当サイトは、インターネット上の暗号化技術SSL（Secure Sockets Layer）を採用しており、ご入力いただいた情報は暗号化されて安全に送受信されます。</li>\r\n            </ul>\r\n            <div id=\"smart\">\r\n              <table width=\"135\" border=\"0\" cellpadding=\"2\" cellspacing=\"0\" title=\"このマークは、SSL/TLSで通信を保護している証です。\">\r\n              <tr>\r\n              <td width=\"135\" align=\"center\" valign=\"top\">\r\n              <!-- GeoTrust QuickSSL [tm] Smart  Icon tag. Do not edit. --> <SCRIPT LANGUAGE=\"JavaScript\"  TYPE=\"text/javascript\" SRC=\"//smarticon.geotrust.com/si.js\"></SCRIPT>\r\n              <!-- end  GeoTrust Smart Icon tag -->\r\n              </td>\r\n              </tr>\r\n              </table>\r\n            </div>\r\n          </div>\r\n\r\n          <ol class=\"contact-step\">\r\n            <li class=\"active\"><span>内容入力</span><i></i></li>\r\n            <li><span>入力内容確認</span><i></i></li>\r\n            <li><span>送信完了</span><i></i></li>\r\n          </ol>\r\n        \r\n          <section class=\"sec-input-area\">\r\n            <form name=\"frm_contact\" id=\"frm_contact\" method=\"post\" action=\"contact.php\">\r\n              <input type=\"hidden\" name=\"mode\" value=\"check\" />\r\n                \r\n              <h2 class=\"title_lv3_01\">お問い合わせ項目<span class=\"need\">必須</span></h2>\r\n              <div class=\"select-container\">\r\n                <select name=\"category\" id=\"category\">\r\n                  <option value=\"\" selected>-- 選択してください --</option>\r\n                  <option value=\"製品・技術に関するお問い合わせ\">製品・技術に関するお問い合わせ</option>\r\n                  <option value=\"部品・資材調達に関するお問い合わせ\">部品・資材調達に関するお問い合わせ</option>\r\n                  <option value=\"IRに関するお問い合わせ\">IRに関するお問い合わせ</option>\r\n                  <option value=\"新卒採用に関するお問い合わせ\">新卒採用に関するお問い合わせ</option>\r\n                  <option value=\"中途・障碍者採用に関するお問い合わせ\">中途・障碍者採用に関するお問い合わせ</option>\r\n                  <option value=\"愛三工業レーシングチーム・陸上競技部に関するお問い合わせ\">愛三工業レーシングチーム・陸上競技部に関するお問い合わせ</option>\r\n                  <option value=\"その他お問い合わせ\">その他お問い合わせ</option>\r\n                </select>\r\n              </div>\r\n              \r\n              <div class=\"select_category2\">\r\n                <h2 class=\"title_lv3_01\">お問い合わせ項目2<span class=\"need\">必須</span></h2>\r\n                <select name=\"category2\" id=\"category2\">\r\n                  <option value=\"\" selected>-- 選択してください --</option>\r\n                  <option value=\"陸上競技部向け応援メッセージ\">陸上競技部向け応援メッセージ</option>\r\n                  <option value=\"レーシング部向け応援メッセージ\">レーシング部向け応援メッセージ</option>\r\n                  <option value=\"レーシング部　サポクラ入会申し込み\">レーシング部　サポクラ入会申し込み</option>\r\n                  <option value=\"その他お問い合わせ\">その他お問い合わせ</option>\r\n                </select>\r\n              </div>\r\n              \r\n              <h2 class=\"title_lv3_01\">お客様情報</h2>\r\n              \r\n              <table class=\"tbl-common01 contact-form-item\">\r\n                <tr class=\"item_comp\">\r\n                  <th scope=\"row\">法人・個人<span class=\"need\">必須</span></th>\r\n                  <td class=\"user-type\">\r\n                    <label><input type=\"radio\" name=\"organization\" id=\"organization1\" value=\"1\">法人</label>\r\n                    <label><input type=\"radio\" name=\"organization\" id=\"organization2\" value=\"2\">個人</label>\r\n                  </td>\r\n                </tr>\r\n                <tr class=\"item_comp item_sports item_sclub item_sports_other\">\r\n                  <th scope=\"row\">氏名<span class=\"need\">必須</span></th>\r\n                  <td><input type=\"text\" name=\"name\" id=\"name\"><span class=\"example\">愛三　太郎</span></td>\r\n                </tr>\r\n                <tr class=\"item_comp item_sports item_sclub item_sports_other\">\r\n                  <th scope=\"row\">フリガナ<span class=\"need\">必須</span></th>\r\n                  <td><input type=\"text\" name=\"furigana\" id=\"furigana\"><span class=\"example\">アイサン　タロウ</span></td>\r\n                </tr>\r\n                <tr class=\"row_company item_comp\">\r\n                  <th scope=\"row\">会社名<span class=\"need\">必須</span></th>\r\n                  <td><input type=\"text\" name=\"company\" id=\"company\"><span class=\"example\">愛三工業株式会社</span></td>\r\n                </tr>\r\n                <tr class=\"row_company item_comp\">\r\n                  <th scope=\"row\">部署名</th>\r\n                  <td><input type=\"text\" name=\"section\" id=\"section\"><span class=\"example\">経営企画部</span></td>\r\n                </tr>\r\n                <tr class=\"item_comp item_sports item_sclub item_sports_other\">\r\n                  <th scope=\"row\">メールアドレス<span class=\"need\">必須</span></th>\r\n                  <td><input type=\"text\" name=\"email1\" id=\"email1\"><span class=\"example\">t.aisan＠aisan-ind.co.jp</span></td>\r\n                </tr>\r\n                <tr class=\"item_comp item_sports item_sclub item_sports_other\">\r\n                  <th scope=\"row\">メールアドレス（確認用）<span class=\"need\">必須</span></th>\r\n                  <td><input type=\"text\" name=\"email2\" id=\"email2\"><span class=\"example\">t.aisan＠aisan-ind.co.jp</span></td>\r\n                </tr>\r\n                <tr class=\"item_comp item_sports item_sclub item_sports_other\">\r\n                  <th scope=\"row\">電話番号<span class=\"need\">必須</span></th>\r\n                  <td><input type=\"text\" name=\"phone\" id=\"phone\"><span class=\"example\">0562-47-1131</span></td>\r\n                </tr>\r\n                <tr class=\"item_sports item_sclub\">\r\n                  <th scope=\"row\">郵便番号<span class=\"need\">必須</span></th>\r\n                  <td><input type=\"text\" name=\"zipcode\" id=\"zipcode\"><span class=\"example\">474-8588</span></td>\r\n                </tr>\r\n                <tr class=\"item_comp item_sports item_sports_cheer item_sclub item_sports_other\">\r\n                  <th scope=\"row\">都道府県<span class=\"need\">必須</span></th>\r\n                  <td>\r\n                    <select name=\"prefecture\" class=\"w25per\" id=\"prefecture\">\r\n                      <option value=\"\" selected>-- 都道府県 --</option>\r\n                      <option value=\"北海道\">北海道</option>\r\n                      <option value=\"青森県\">青森県</option>\r\n                      <option value=\"岩手県\">岩手県</option>\r\n                      <option value=\"宮城県\">宮城県</option>\r\n                      <option value=\"秋田県\">秋田県</option>\r\n                      <option value=\"山形県\">山形県</option>\r\n                      <option value=\"福島県\">福島県</option>\r\n                      <option value=\"茨城県\">茨城県</option>\r\n                      <option value=\"栃木県\">栃木県</option>\r\n                      <option value=\"群馬県\">群馬県</option>\r\n                      <option value=\"埼玉県\">埼玉県</option>\r\n                      <option value=\"千葉県\">千葉県</option>\r\n                      <option value=\"東京都\">東京都</option>\r\n                      <option value=\"神奈川県\">神奈川県</option>\r\n                      <option value=\"新潟県\">新潟県</option>\r\n                      <option value=\"富山県\">富山県</option>\r\n                      <option value=\"石川県\">石川県</option>\r\n                      <option value=\"福井県\">福井県</option>\r\n                      <option value=\"山梨県\">山梨県</option>\r\n                      <option value=\"長野県\">長野県</option>\r\n                      <option value=\"岐阜県\">岐阜県</option>\r\n                      <option value=\"静岡県\">静岡県</option>\r\n                      <option value=\"愛知県\">愛知県</option>\r\n                      <option value=\"三重県\">三重県</option>\r\n                      <option value=\"滋賀県\">滋賀県</option>\r\n                      <option value=\"京都府\">京都府</option>\r\n                      <option value=\"大阪府\">大阪府</option>\r\n                      <option value=\"兵庫県\">兵庫県</option>\r\n                      <option value=\"奈良県\">奈良県</option>\r\n                      <option value=\"和歌山県\">和歌山県</option>\r\n                      <option value=\"鳥取県\">鳥取県</option>\r\n                      <option value=\"島根県\">島根県</option>\r\n                      <option value=\"岡山県\">岡山県</option>\r\n                      <option value=\"広島県\">広島県</option>\r\n                      <option value=\"山口県\">山口県</option>\r\n                      <option value=\"徳島県\">徳島県</option>\r\n                      <option value=\"香川県\">香川県</option>\r\n                      <option value=\"愛媛県\">愛媛県</option>\r\n                      <option value=\"高知県\">高知県</option>\r\n                      <option value=\"福岡県\">福岡県</option>\r\n                      <option value=\"佐賀県\">佐賀県</option>\r\n                      <option value=\"長崎県\">長崎県</option>\r\n                      <option value=\"熊本県\">熊本県</option>\r\n                      <option value=\"大分県\">大分県</option>\r\n                      <option value=\"宮崎県\">宮崎県</option>\r\n                      <option value=\"鹿児島県\">鹿児島県</option>\r\n                      <option value=\"沖縄県\">沖縄県</option>\r\n                    </select>\t\t\t\t\t\t\t\t\r\n                  </td>\r\n                </tr>\r\n                <tr class=\"item_sports item_sclub\">\r\n                  <th scope=\"row\">住所<span class=\"need\">必須</span></th>\r\n                  <td><input type=\"text\" name=\"address\" id=\"address\"><span class=\"example\">大府市共和町一丁目1番地の1</span></td>\r\n                </tr>\r\n                <tr class=\"item_sports item_sclub\">\r\n                  <th scope=\"row\">建物名</th>\r\n                  <td><input type=\"text\" name=\"building\" id=\"building\"></td>\r\n                </tr>\r\n              </table>\r\n              \r\n              <div class=\"item_comp item_sports item_message\">\r\n              <h2 class=\"title_lv3_01\"><span class=\"item_message_basic\">お問い合わせ内容</span><span class=\"item_message_cheer\">応援メッセージ</span><span class=\"need\">必須</span></h2>\r\n              <textarea name=\"message\" id=\"message\" cols=\"45\" rows=\"5\"></textarea>\r\n              </div>\r\n              \r\n              \r\n              <div class=\"sec-contact-agree\">\r\n                <p>お問い合わせされる方は、必ず当社「<a href=\"/privacy.html\" target=\"_blank\" class=\"c-underline-textlink\">個人情報保護方針</a>」の内容をご確認のうえ、<br class=\"pc_only\">「同意する」にチェックを入れて、内容を送信してください。</p>\r\n                \r\n                <label><input name=\"chb_privacy\" type=\"checkbox\" value=\"\" id=\"chb_privacy\"> 同意する</label>\r\n                <div class=\"g-button-container u-mt-l\">\r\n                  <p class=\"g-button-container__item c-button\" id=\"btn-confirm\"><a href=\"javascript:void(0);\" class=\"c-button__inner\">入力内容の確認</a></p>\r\n                </div>\r\n              </div>\r\n            </form>\r\n          </section>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </main>\r\n  \r\n  <!---------- Footer ---------->\r\n  <div id=\"include-footer\"></div>\r\n  <!---------- /Footer ---------->\r\n\r\n</body>\r\n</html>\r\n","finalUrl":"https://www.aisan-ind.co.jp/contact/index.html","rendered":false,"_cachedAt":"2026-06-22T21:20:14.003Z"}