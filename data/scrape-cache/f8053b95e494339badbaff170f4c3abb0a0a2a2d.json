btn\"><a href=\"javascript:void(0)\"><span>メニューを開く</span></a></p>\n            <ul>\n                <li class=\"parent\"><a href=\"../../index.html\" class=\"pcmenu\">ホーム</a><a href=\"javascript:void(0)\" class=\"spmenu\">ホーム</a>\n                    <!-- home -->\n                    <ul class=\"submenu\">\n                        <li><a href=\"../../index.html\" class=\"spmenu\">トップページ</a></li>\n                        <li><a href=\"../../news/index.html\">新着情報</a></li>\n                        <li><a href=\"../../privacy/index.html\">プライバシーポリシー</a></li>\n                        <li><a href=\"../../sitemap/index.html\">サイトマップ</a></li>\n\t\t\t\t\t\t<li><a href=\"../../english/index.html\">English</a></li>\n                    </ul>\n                    <!-- /home -->\n                </li>\n                <li class=\"parent\"><a href=\"../../taxi/index.html\" class=\"pcmenu\">タクシーを使う</a><a href=\"javascript:void(0)\" class=\"spmenu\">タクシーを使う</a>\n                    <!-- taxi -->\n                    <ul class=\"submenu\">\n                        <li><a href=\"../../taxi/index.html\" class=\"spmenu\">タクシーを使うTOP</a></li>\n                        <li><a href=\"../../taxi/fare/index.html\">料金案内</a></li>\n                        <li><a href=\"../../taxi/lineup/index.html\">車両案内</a></li>\n\t\t\t\t\t\t<li><a href=\"../../taxi/antivirus/index.html\">新型コロナウィルス感染症対策について</a></li>\n                    </ul>\n                    <!-- /taxi -->\n                </li>\n                <li class=\"parent\"><a href=\"../../support/index.html\" class=\"pcmenu\">子育てサポート</a><a href=\"javascript:void(0)\" class=\"spmenu\">子育てサポート</a>\n                    <!-- support -->\n                    <ul class=\"submenu\">\n                        <li><a href=\"../../support/index.html\" class=\"spmenu\">子育てサポートTOP</a></li>\n                        <li><a href=\"../../support/child/index.html\">子育てタクシー</a></li>\n                        <li><a href=\"../../support/maternity/index.html\">陣痛119番</a></li>\n                    </ul>\n                    <!-- /support -->\n                </li>\n                <li class=\"parent\"><a href=\"../../tourism/index.html\" class=\"pcmenu\">観光する</a><a href=\"javascript:void(0)\" class=\"spmenu\">観光する</a>\n                    <!-- tourism -->\n                    <ul class=\"submenu\">\n                        <li><a href=\"../../tourism/index.html\" class=\"spmenu\">観光するTOP</a></li>\n                        <li><a href=\"../../tourism/yokohama/index.html\">横浜観光</a></li>\n                        <li><a href=\"../../tourism/tokyo/index.html\">東京観光</a></li>\n                        <li><a href=\"../../tourism/kamakura/index.html\">鎌倉観光</a></li>\n                        <li><a href=\"../../tourism/hakone/index.html\">富士山・箱根観光</a></li>\n                        <li><a href=\"../../tourism/special/index.html\">特別企画観光</a></li>\n\t\t\t\t\t\t<li><a href=\"../../tourism/voice/index.html\">お客様の声</a></li>\n                    </ul>\n                    <!-- /tourism -->\n                </li>\n                <li class=\"parent\"><a href=\"../../about/index.html\" class=\"pcmenu\">会社案内</a><a href=\"javascript:void(0)\" class=\"spmenu\">会社案内</a>\n                    <!-- about -->\n                    <ul class=\"submenu\">\n                        <li><a href=\"../../about/index.html\" class=\"spmenu\">会社案内TOP</a></li>\n                        <li><a href=\"../../about/profile/index.html\">会社概要</a></li>\n                        <li><a href=\"../../about/hiroba/index.html\">サンタクシーひろば</a></li>\n                    </ul>\n                    <!-- /about -->\n                </li>\n\t\t\t\t<li class=\"parent\"><a href=\"../../recruit/index.html\">ドライバーになる</a></li>\n            </ul>\n            <!-- /.Nav -->\n        </nav>\n\t\t\t<p id=\"headinsta\"><a href=\"https://www.instagram.com/yokohama_suntaxi/\" title=\"サンタクシーのインスタグラムへ\" target=\"_blank\"><img src=\"../../images/common/logo_instagram.png\" alt=\"サンタクシーのインスタグラムへ\"/></a></p>\n        </div>\n      <!-- /#header-->\n    </div>\n    <div class=\"intro midashi_trs90\">\n        <div class=\"container\">\n            <p class=\"subtit\">観光する</p>\n            <h1>お客様の声</h1>\n        </div>\n        <!-- /#intro-->\n    </div>\n    <div id=\"panlist\">\n        <div class=\"container\">\n            <p id=\"pan\"><a href=\"../../index.html\">ホーム</a><em>&gt;</em><a href=\"../index.html\">観光する</a><em>&gt;</em>お客様の声</p>\n        </div>\n        <!--  /#panlist-->\n    </div>\n    <div id=\"contents\">\n        <div class=\"area_01\">\n            <div class=\"container\">\n                <p class=\"pCtsL\">観光タクシーをご利用いただいたお客様の声をご紹介します。<br>\n                    サンタクシーではお客様から頂いた声を励みにこれからも質の高いサービスを提供し続けて参ります。</p>\n                <p class=\"caution03 bmbspc pCtsL\"><span>※</span>観光終了後にご協力いただいたアンケートから、匿名の形で抜粋。</p>\n                <div class=\"voice_box\">\n                    <dl>\n                        <dt>鎌倉・江の島観光　<br class=\"br-sp\">大阪からのお客様（60代 女性8名様）</dt>\n                        <dd>\n                            <p>良かった観光地：鎌倉大仏・長谷寺</p>\n                            <p>親切、ていねいな説明がわかりやすかったです。</p>\n                        </dd>\n                    </dl>\n                    <!-- /.voice_box -->\n                </div>\n                <div class=\"voice_box\">\n                    <dl>\n                        <dt>鎌倉・江の島観光　<br class=\"br-sp\">広島からのお客様（50代 男女4名様）</dt>\n                        <dd>\n                            <p>良かった観光地：報国寺 大仏</p>\n                            <p>色々説明していただき有難うございます。</p>\n                        </dd>\n                    </dl>\n                    <!-- /.voice_box -->\n                </div>\n                <div class=\"voice_box\">\n                    <dl>\n                        <dt>鎌倉・江の島観光　<br class=\"br-sp\">岡山からのお客様（40代 男性6名様）</dt>\n                        <dd>\n                            <p>良かった観光地：すべて</p>\n                            <p>わかりやすく丁寧ですごくよかった。穴場スポットも見れました。<br>\n                                昼に美味しいところを教えていただけました。</p>\n                      </dd>\n                    </dl>\n                    <!-- /.voice_box -->\n                </div>\n                <div class=\"voice_box\">\n                    <dl>\n                        <dt>鎌倉・江の島観光　<br class=\"br-sp\">福岡からのお客様（40代 女性3名様）</dt>\n                        <dd>\n                            <p>良かった観光地：高徳院</p>\n                            <p>とても親切にしていただきました。</p>\n                        </dd>\n                    </dl>\n                    <!-- /.voice_box -->\n                </div>\n                <div class=\"voice_box\">\n                    <dl>\n                        <dt>横浜観光　<br class=\"br-sp\">大阪からのお客様（40～80代 男性４名様）</dt>\n                        <dd>\n                            <p>良かった観光地：外交官の館、赤レンガ倉庫</p>\n                            <p>最高です。歴史的なことをわかりやすく話してくださり最高でした。<br>\n                                コース設定、料金など満足。感謝のみ、100点。またお願いしたいです。</p>\n                        </dd>\n                    </dl>\n                    <!-- /.voice_box -->\n                </div>\n                <div class=\"voice_box\">\n                    <dl>\n                        <dt>横浜観光　<br class=\"br-sp\">東京＋海外からのお客様（60代女性他）</dt>\n                        <dd>\n                            <p>良かった観光地：海の見える丘公園</p>\n                            <p>すごくフレンドリーで、プランも提案してもらって、よかったです。<br>\n                                色々なことを案内してもらいました。有難うございました。</p>\n                        </dd>\n                    </dl>\n                    <!-- /.voice_box -->\n                </div>\n                <div class=\"voice_box\">\n                    <dl>\n                        <dt>鎌倉・江の島観光<br class=\"br-sp\">（40～60代 ご家族）</dt>\n                        <dd>\n                            <p>良かった観光地：鎌倉八幡宮、大仏、長谷寺、江の島</p>\n                            <p>色々とお話しいただき、また色々対応してもらえてありがたかったです。<br>\n                                前払いなので少し不安でしたがとても満足です。<br>\n                                天気も良くなり、いろいろ楽しむことができました。</p>\n                        </dd>\n                    </dl>\n                    <!-- /.voice_box -->\n                </div>\n                <div class=\"voice_box\">\n                    <dl>\n                        <dt>鎌倉・江の島観光　<br class=\"br-sp\">長崎からのお客様（30代,50代）</dt>\n                        <dd>\n                            <p>良かった観光地：今回巡ったコースすべてよかった</p>\n                            <p>親切でお話も楽しく、とてもよかったです。<br>\n                                無理なお願いもかなえてくださり、料金は安すぎです。</p>\n                        </dd>\n                    </dl>\n                    <!-- /.voice_box -->\n                </div>\n                <div class=\"voice_box\">\n                    <dl>\n                        <dt>鎌倉・江の島観光　<br class=\"br-sp\">岩手からのお客様（50代 女性10名様）</dt>\n                        <dd>\n                            <p>良かった観光地：銭洗い弁天・大仏</p>\n                            <p>とてもスムーズに観光できました。<br>\n                                不手際な点は何もなく、満足です。</p>\n                        </dd>\n                    </dl>\n                    <!-- /.voice_box -->\n                </div>\n                <div class=\"voice_box\">\n                    <dl>\n                        <dt>横浜観光　<br class=\"br-sp\">宮崎からのお客様（60代 女性7名様）</dt>\n                        <dd>\n                            <p>良かった観光地：三渓園・外交官の家</p>\n                            <p>観光地の説明を詳しくしてくださり、一緒に廻って写真も撮っていただき、大変親切で良かったです。<br>\n                                都会の運転手の方では珍しく親切でした。有難うございました。</p>\n                        </dd>\n                    </dl>\n                    <!-- /.voice_box -->\n                </div>\n                <div class=\"voice_box\">\n                    <dl>\n                        <dt>鎌倉・江の島観光　<br class=\"br-sp\">三重からのお客様（50代 女性4名様）</dt>\n                        <dd>\n                            <p>良かった観光地：八幡宮・江の島神社</p>\n                            <p>とても詳しくてよく理解できました。<br>\n                                親切だし安全運転で安心でき、説明もわかりやすかったです。</p>\n                        </dd>\n                    </dl>\n                    <!-- /.voice_box -->\n                </div>\n                <div class=\"voice_box\">\n                    <dl>\n                        <dt>鎌倉・江の島観光　<br class=\"br-sp\">福井からのお客様（60代 女性4名様）</dt>\n                        <dd>\n                            <p>良かった観光地：江の島・大仏様</p>\n                            <p>きめ細かく優しい案内で、とてもよかったです。<br>\n                                女性ドライバーだったので安心でした。</p>\n                        </dd>\n                    </dl>\n                    <!-- /.voice_box -->\n                </div>\n                <div class=\"voice_box\">\n                    <dl>\n                        <dt>鎌倉・江の島観光　<br class=\"br-sp\">宮城からのお客様（60代 男性5名様）</dt>\n                        <dd>\n                            <p>良かった観光地：明月院</p>\n                            <p>客の気持ちを常に考えて対応してもらっています。</p>\n                        </dd>\n                    </dl>\n                    <!-- /.voice_box -->\n                </div>\n                <div class=\"voice_box\">\n                    <dl>\n                        <dt>東京観光　<br class=\"br-sp\">神奈川のお客様（60代）</dt>\n                        <dd>\n                            <p>良かった観光地：浅草・両国</p>\n                            <p>わかりやすく親切に教えていただき、楽しい時間を持てました。<br>\n                                カラーの資料をいただき、準備がよいと思いました。</p>\n                        </dd>\n                    </dl>\n                    <!-- /.voice_box -->\n                </div>\n            </div>\n        </div>\n        <p id=\"pageTop\"><a href=\"#\"><i class=\"fa fa-chevron-up\"></i></a></p>\n        <!--/#contents-->\n    </div>\n    <div id=\"fmenu\">\n        <div class=\"container\">\n            <div class=\"fnavBox\">\n                <h2><a href=\"../../index.html\">ホーム</a></h2>\n                <ul>\n                    <li><a href=\"../../news/index.html\">新着情報</a></li>\n                    <li><a href=\"../../privacy/index.html\">プライバシーポリシー</a></li>\n                    <li><a href=\"../../sitemap/index.html\">サイトマップ</a></li>\n\t\t\t\t\t<li><a href=\"../../english/index.html\">English</a></li>\n                </ul>\n            </div>\n            <div class=\"fnavBox\">\n                <h2><a href=\"../../taxi/index.html\">タクシーを使う</a></h2>\n                <ul>\n                    <li><a href=\"../../taxi/fare/index.html\">料金案内</a></li>\n\t\t\t\t\t<li><a href=\"../../taxi/lineup/index.html\">車両案内</a></li>\n\t\t\t\t\t<li><a href=\"../../taxi/antivirus/index.html\">新型コロナウィルス感染症対策について</a></li>\n                </ul>\n            </div>\n\t\t\t<div class=\"fnavBox\">\n                <h2><a href=\"../../support/index.html\">子育てサポート</a></h2>\n                <ul>\n                    <li><a href=\"../../support/child/index.html\">子育てタクシー</a></li>\n                    <li><a href=\"../../support/maternity/index.html\">陣痛119番</a></li>\n                </ul>\n            </div>\n            <div class=\"fnavBox\">\n                <h2><a href=\"../../tourism/index.html\">観光する</a></h2>\n                <ul>\n                    <li><a href=\"../../tourism/yokohama/index.html\">横浜観光</a></li>\n                    <li><a href=\"../../tourism/tokyo/index.html\">東京観光</a></li>\n                    <li><a href=\"../../tourism/kamakura/index.html\">鎌倉観光</a></li>\n                    <li><a href=\"../../tourism/hakone/index.html\">富士山・箱根観光</a></li>\n                    <li><a href=\"../../tourism/special/index.html\">特別企画観光</a></li>\n\t\t\t\t\t<li><a href=\"../../tourism/voice/index.html\">お客様の声</a></li>\n                </ul>\n            </div>\n            \n            <div class=\"fnavBox\">\n                <h2><a href=\"../../about/index.html\">会社案内</a></h2>\n                <ul>\n                    <li><a href=\"../../about/profile/index.html\">会社概要</a></li>\n                    <li><a href=\"../../about/hiroba/index.html\">サンタクシーひろば</a></li>\n                </ul>\n\t\t\t\t<h2 class=\"rec_jump\"><a href=\"../../recruit/index.html\">ドライバーになる</a></h2>\n            </div>\n        </div>\n        <!-- /#fmenu -->\n    </div>\n    <div id=\"footer\">\n        <div class=\"container\">\n            <div class=\"f_comp\">\n                <p class=\"flogo\"><a href=\"../../index.html\"><img class=\"imgMax\" src=\"../../images/common/logo.png\" alt=\"神奈川県横浜市のサンタクシー\"></a></p>\n                <p class=\"addr\">〒231-0813　<br class=\"br-sp\">神奈川県横浜市中区かもめ町20</p>\n                <dl class=\"ftel\">\n                    <dt>サンタクシー本社</dt>\n                    <dd>：tel.045-622-9923</dd>\n                </dl>\n                <dl class=\"ftel\">\n                    <dt>お車のご用命は</dt>\n                    <dd>：tel.0120-411-190</dd>\n                </dl>\n            </div>\n            <div class=\"f_msg\">\n                <p>横浜市内の観光・子育てサポートはサンタクシーへお任せください。</p>\n                <p>深夜早朝の送迎なども24時間、年中無休で承っております。</p>\n\t\t\t\t<p>お気軽にご用命ください。</p>\n              <p id=\"cpy\">&copy; Sun Taxi All Rights Reserved.</p>\n            </div>\n        </div>\n        <!-- /#footer -->\n    </div>\n\t<div id=\"ftel_area\">\n\t\t<div class=\"container\">\n\t\t\t<div class=\"ftel_taxi\">\n\t\t\t\t<p class=\"ftel_youmei\">送迎のご用命は<br class=\"br-sp\">\n\t\t\t\t  <span class=\"tel_fm\">tel.</span><span class=\"tel_no tel1\">0120-411-190</span></p>\n\t\t\t\t<p class=\"ftel_msg\">当社加盟のラジオタクシー<br class=\"br-sp\">配車センターにかかります</p>\n                </div>\n                <div class=\"ftel_tourism\">\n                    <p class=\"ftel_youmei\">観光のご用命は<br class=\"br-sp\">\n                    <span class=\"tel_fm\">tel.</span><span class=\"tel_no tel2\">0120-881-301</span></p>\n\t\t\t\t\t<p class=\"ftel_msg\">サンタクシーにかかります。<br class=\"br-sp\">「観光の問合せ」とお伝えください</p>\n                </div>\n            </div>\n            <!-- /#ftel_area-->\n        </div>\n</body>\n</html>\n","finalUrl":"https://suntaxi.com/tourism/voice/","rendered":false,"_cachedAt":"2026-06-22T19:28:16.841Z"}