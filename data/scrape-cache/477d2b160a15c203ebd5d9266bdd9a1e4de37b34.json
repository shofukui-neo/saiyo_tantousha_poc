{"url":"https://map.jp/support/contactform/info/index.php","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>総合INFO お問い合わせフォーム</title>\n<link rel=\"icon\" type=\"image/x-icon\" href=\"../favicon.ico\">\n<link rel=\"stylesheet\" href=\"../css/style.css\">\n<style>\n:root {\n    --theme-color: #847994;\n    --base-color:  #DCDAE0;\n}\n</style>\n</head>\n<body>\n\n<div class=\"page-wrapper\">\n    <div class=\"form-header\">\n        <div class=\"product-title\">その他のお問い合わせ</div>\n    </div>\n\n    <div class=\"form-container\">\n        <p class=\"form-intro\">\n            必要事項をご入力の上、送信してください。担当者よりご連絡いたします。\n        </p>\n\n        <!-- 売り込み不可注記 -->\n        <div class=\"red-notes\" style=\"margin-bottom:20px;\">\n            <p>※本サイトのフォームを利用した当社への売り込みは一切お断りしています。</p>\n        </div>\n\n        \n        <form method=\"post\" action=\"index.php\" novalidate>\n            <input type=\"hidden\" name=\"csrf_token\" value=\"0c588740395f141408be4086ec85acb2\">\n\n            <!-- 法人名 -->\n            <div class=\"form-group\">\n                <label class=\"field-label\" for=\"company_name\">法人名（個人利用の場合は入力不要）</label>\n                <input type=\"text\" id=\"company_name\" name=\"company_name\"\n                       value=\"\"\n                       maxlength=\"100\" autocomplete=\"organization\">\n            </div>\n\n            <!-- お名前 -->\n            <div class=\"form-group\">\n                <label class=\"field-label\" for=\"name\">お名前 <span class=\"required-mark\">必須</span></label>\n                <input type=\"text\" id=\"name\" name=\"name\"\n                       value=\"\"\n                       maxlength=\"100\" autocomplete=\"name\"\n                       class=\"\">\n                \n                <label class=\"field-label\" for=\"furigana\" style=\"margin-top:10px;\">ふりがな <span class=\"required-mark\">必須</span></label>\n                <input type=\"text\" id=\"furigana\" name=\"furigana\"\n                       value=\"\"\n                       maxlength=\"100\" placeholder=\"やまだ たろう\"\n                       class=\"\">\n                            </div>\n\n            <!-- 電話番号 -->\n            <div class=\"form-group\">\n                <label class=\"field-label\" for=\"phone\">電話番号 <span class=\"required-mark\">必須</span></label>\n                <p class=\"field-note\">半角でご入力ください</p>\n                <input type=\"tel\" id=\"phone\" name=\"phone\"\n                       value=\"\"\n                       placeholder=\"000-000-0000\" maxlength=\"15\" autocomplete=\"tel\"\n                       class=\"\">\n                            </div>\n\n            <!-- 返信先メール -->\n            <div class=\"form-group\">\n                <label class=\"field-label\" for=\"email\">返信先メールアドレス <span class=\"required-mark\">必須</span></label>\n                <p class=\"field-note\">半角でご入力ください</p>\n                <input type=\"email\" id=\"email\" name=\"email\"\n                       value=\"\"\n                       maxlength=\"200\" autocomplete=\"email\"\n                       class=\"\">\n                \n                <label class=\"field-label\" for=\"email_confirm\" style=\"margin-top:10px;\">返信先メールアドレス（確認） <span class=\"required-mark\">必須</span></label>\n                <input type=\"email\" id=\"email_confirm\" name=\"email_confirm\"\n                       value=\"\"\n                       maxlength=\"200\" autocomplete=\"email\" placeholder=\"もう一度入力してください\"\n                       class=\"\">\n                            </div>\n\n            <!-- お問い合わせ内容 -->\n            <div class=\"form-group\">\n                <label class=\"field-label\" for=\"inquiry_content\">お問い合わせ内容 <span class=\"required-mark\">必須</span></label>\n                <textarea id=\"inquiry_content\" name=\"inquiry_content\"\n                          placeholder=\"具体的なお問い合わせ内容を入力してください\"\n                          class=\"\"></textarea>\n                            </div>\n\n            <hr class=\"section-divider\">\n\n            <div class=\"privacy-box\">\n                <h3>お問い合わせに関する個人情報の取り扱い</h3>\n                <p>ご登録いただいた情報は、当社の<a href=\"https://map.jp/index/privacypolicy.html\" target=\"_blank\">プライバシーポリシー</a>に従い適正に管理しています。</p>\n                <p>ご登録いただいた情報は、お客様からのお問い合わせやご依頼内容に的確に対応することを目的に限定して利用します。</p>\n                <p>これ以外の目的で利用したり、第三者に提供もしくは預託することはありません。</p>\n                <label class=\"privacy-agree-label\">\n                    <input type=\"checkbox\" name=\"privacy_agree\" value=\"1\"\n                           >\n                    個人情報の取り扱いに同意する\n                    <span class=\"required-mark\">必須</span>\n                </label>\n                            </div>\n\n            <div class=\"red-notes\">\n                <p>※お問い合わせいただいたメールの返信は当社営業時間内となります。ご了承ください。</p>\n                <p>※返信メールアドレスに送信できない場合や、問い合わせの内容によってお電話させていただく場合がございます。</p>\n            </div>\n\n            <!-- ハニーポット：ボット対策（人間には見えません） -->\n            <div style=\"display:none !important; position:absolute; left:-9999px;\" aria-hidden=\"true\">\n                <input type=\"text\" name=\"website\" tabindex=\"-1\" autocomplete=\"off\">\n            </div>\n            <button type=\"submit\" class=\"btn-submit\">確認画面へ</button>\n        </form>\n    </div>\n</div>\n\n\n\n<p class=\"site-copyright\">&copy; 2026 KANKOSHA Co., Ltd.</p>\n</body>\n</html>\n","finalUrl":"https://map.jp/support/contactform/info/index.php","rendered":false,"_cachedAt":"2026-06-23T20:42:50.791Z"}