          color: #fff;\n            padding: 4px 12px;\n            border-radius: 20px;\n            font-size: 0.75rem;\n            font-weight: 500;\n            z-index: 2;\n        }\n\n        .voice-body {\n            padding: 25px;\n            display: flex;\n            flex-direction: column;\n            justify-content: space-between;\n            height: calc(100% - 66%); /* 画像以外の高さ */\n        }\n\n        .voice-catch {\n            font-size: 1.1rem;\n            font-weight: 700;\n            color: #333;\n            line-height: 1.5;\n            margin-bottom: 15px;\n        }\n\n        .voice-meta {\n            display: flex;\n            justify-content: space-between;\n            align-items: center;\n            border-top: 1px solid #eee;\n            padding-top: 15px;\n            margin-top: auto; /* 下部に固定 */\n        }\n\n        .voice-name {\n            font-size: 1rem;\n            font-weight: 700;\n            color: #333;\n        }\n\n        .voice-role {\n            font-size: 0.85rem;\n            color: #888;\n        }\n\n        /* 矢印アイコン */\n        .voice-arrow {\n            color: #77C345;\n            font-weight: bold;\n            opacity: 0;\n            transform: translateX(-10px);\n            transition: all 0.3s;\n        }\n\n        .voice-card:hover .voice-arrow {\n            opacity: 1;\n            transform: translateX(0);\n        }\n\n    </style>\n\n    <section class=\"voice-index-section\">\n        <div class=\"container clearfix\">\n\n            <!-- イントロダクション -->\n            <div class=\"voice-intro\">\n                <h3 class=\"ls1\">未来をつくる、社員たちの声。</h3>\n                <p>藤村薬品で活躍する先輩社員たちにインタビューしました。<br>\n                    仕事のやりがい、入社の決め手、職場の雰囲気など、<br class=\"d-md-none\">リアルな声をお届けします。</p>\n            </div>\n\n            <!-- 社員一覧グリッド -->\n            <div class=\"row\">\n\n                <!-- 社員 1 -->\n                <!-- ここに mb-5 を追加して行間を確保しています -->\n                <div class=