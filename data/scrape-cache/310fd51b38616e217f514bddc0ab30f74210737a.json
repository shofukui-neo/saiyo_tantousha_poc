one-expansion-unit/inc/call-to-action/package/assets/css/style.css?ver=9.109.0.1' media='all' />\n<link rel=\"https://api.w.org/\" href=\"https://www.kokudoec.co.jp/wp-json/\" /><link rel=\"alternate\" title=\"JSON\" type=\"application/json\" href=\"https://www.kokudoec.co.jp/wp-json/wp/v2/pages/2\" /><link rel=\"EditURI\" type=\"application/rsd+xml\" title=\"RSD\" href=\"https://www.kokudoec.co.jp/xmlrpc.php?rsd\" />\n<meta name=\"generator\" content=\"WordPress 7.0\" />\n<link rel=\"canonical\" href=\"https://www.kokudoec.co.jp/\" />\n<link rel='shortlink' href='https://www.kokudoec.co.jp/' />\n<!-- [ VK All in One Expansion Unit OGP ] -->\n<meta property=\"og:site_name\" content=\"株式会社国土技術コンサルタンツ\" />\n<meta property=\"og:url\" content=\"https://www.kokudoec.co.jp/\" />\n<meta property=\"og:title\" content=\"株式会社国土技術コンサルタンツ\" />\n<meta property=\"og:description\" content=\"\" />\n<meta property=\"og:type\" content=\"website\" />\n<!-- [ / VK All in One Expansion Unit OGP ] -->\n<!-- [ VK All in One Expansion Unit twitter card ] -->\n<meta name=\"twitter:card\" content=\"summary_large_image\">\n<meta name=\"twitter:description\" content=\"\">\n<meta name=\"twitter:title\" content=\"株式会社国土技術コンサルタンツ\">\n<meta name=\"twitter:url\" content=\"https://www.kokudoec.co.jp\">\n\t<meta name=\"twitter:domain\" content=\"www.kokudoec.co.jp\">\n\t<!-- [ / VK All in One Expansion Unit twitter card ] -->\n\t<link rel=\"icon\" href=\"https://www.kokudoec.co.jp/wp-content/uploads/2025/07/cropped-favicon-32x32.png\" sizes=\"32x32\" />\n<link rel=\"icon\" href=\"https://www.kokudoec.co.jp/wp-content/uploads/2025/07/cropped-favicon-192x192.png\" sizes=\"192x192\" />\n<link rel=\"apple-touch-icon\" href=\"https://www.kokudoec.co.jp/wp-content/uploads/2025/07/cropped-favicon-180x180.png\" />\n<meta name=\"msapplication-TileImage\" content=\"https://www.kokudoec.co.jp/wp-content/uploads/2025/07/cropped-favicon-270x270.png\" />\n<!-- [ VK All in One Expansion Unit WebSite Structure Data ] --><script type=\"application/ld+json\">{\"@context\":\"https://schema.org/\",\"@type\":\"WebSite\",\"name\":\"株式会社国土技術コンサルタンツ\",\"url\":\"https://www.kokudoec.co.jp\"}</script><!-- [ / VK All in One Expansion Unit WebSite Structure Data ] -->  </head>\n\n  <body class=\"home wp-singular page-template page-template-page-top page-template-page-top-php page page-id-2 wp-theme-kokudo post-name-%e4%bc%81%e6%a5%adtop%e3%83%9a%e3%83%bc%e3%82%b8 post-type-page\">\n    <header class=\"l-header\">\n<div class=\"l-header__logo\">\n  <a href=\"/\">\n    <img src=\"https://www.kokudoec.co.jp/wp-content/themes/kokudo/assets/img/common/h-logo.webp\">\n    <p>\n      <span>国土技術コンサルタンツ</span>\n      <u></u>\n      <span>Corporate</span>\n    </p>\n  </a>\n</div>\n      <div class=\"c-hamburger\">\n        <input type=\"checkbox\" id=\"menu-btn-check\">\n        <label for=\"menu-btn-check\" class=\"c-hamburger__btn\"><span></span></label>\n        <div class=\"c-hamburger__menu\">\n          <ul class=\"l-header__nav\">\n            <li>\n              <a href=\"/\">TOP</a>\n            </li>\n            <li>\n              <a href=\"/#introduction\">事業紹介</a>\n              <ul class=\"is-sp\">\n                <li><a href=\"/introduction/01\">建設コンサルタント</a></li>\n                <li><a href=\"/introduction/02\">測量</a></li>\n                <li><a href=\"/introduction/03\">補償コンサルタント</a></li>\n              </ul>\n            </li>\n            <li>\n              <a href=\"/company\">企業情報</a>\n            </li>\n            <li>\n              <a href=\"/history\">会社の歴史</a>\n            </li>\n            <li>\n              <a href=\"/achivements\">実績紹介</a>\n            </li>\n            <li>\n              <a href=\"/press\">最新情報</a>\n            </li>\n            <li>\n              <a href=\"/recruit\">採用サイト</a>\n            </li>\n            <li>\n              <a href=\"/contact\">お問い合わせ</a>\n            </li>\n          </ul>\n        </div>\n      </div>\n\n    </header>\n<main>\n    <!-- keyvisual -->\n    <section class=\"p-top-keyvisual\">\n      <div class=\"p-top-keyvisual-bg\">\n        <div class=\"p-top-keyvisual-bg__inner\">\n          <ul class=\"p-top-keyvisual-bg__Image\">\n            <li></li>\n            <li></li>\n            <li></li>\n          </ul>\n          <div class=\"p-top-keyvisual-bg__content\">\n            <h1 class=\"p-top-keyvisual__title\">選ばれる企業で<br>あり続けるために。</h1>\n            <div class=\"p-top-keyvisual__read\">\n              <p>株式会社国土技術コンサルタンツは、道路や防災施設など社会インフラの調査や\n                <br>測量、計画、設計、また公共事業に係る補償費算定を行う総合建設コンサルタントです。</p>\n            </div>\n          </div>\n        </div>\n      </div>\n      <div class=\"p-top-keyvisual__text\">\n        <sup>Thanks to You, 55 Years</sup>\n        <strong>おかげさまで創業55年</strong>\n        <p>わたしたち<br>株式会社国土技術コンサルタンツは<br>1970年に創業し、以来一貫して公共事業における<br>委託業務を社業としてまいりました。<br><br>創業以来「測量業」「建設コンサルタント業」「補償コンサルタント業」<br>などの登録を行い「総合建設コンサルタント」として<br>社業の充実に努めてまいりました。</p>\n      </div>\n    </section>\n\n    <section class=\"p-top-create bg-white\">\n      <strong>Create a Sustainable</strong>\n      <sub>〜 持続可能で活力ある地域づくりを 〜</sub>\n\n      <p>わたしたち株式会社国土技術コンサルタンツは1970年に創業<br>\n      以来、一貫して公共事業における委託業務を社業としてまいりました。<br><br>\n      \n      　この間、測量業・建設コンサルタント業・補償コンサルタント業などの登録を行い<br>\n      「総合建設コンサルタント」として社業の充実に努めてまいりました。</p>\n    </section>\n\n    <section class=\"p-top-info bg-white\">\n      <h2><b>I</b>nformation<span>事業案内</span></h2>\n    </section>\n\n    <section class=\"p-top-infra bg-white\" id=\"introduction\">\n      <div class=\"p-top-col2\">\n\n        <div class=\"p-top-col2__textarea\">\n          <div class=\"p-top-col2__image is-sp\">\n            <img src=\"https://www.kokudoec.co.jp/wp-content/themes/kokudo/assets/img/top/infra-image.webp\" alt=\"\">\n          </div>\n\n          <div class=\"p-top-col2__title\">\n            <h2>Civil Engineering<br>Consultant ＆ Design</h2>\n          </div>\n\n          <div class=\"p-top-col2__about\">\n            <sup><span></span>infrastructure</sup>\n            <strong>建設コンサルタント</strong>\n            <p>地域の発展と安全を支えるため、高品質な設計サービスを提供しています。道路・橋梁・上下水道などのインフラ設計から、都市計画や環境保全に配慮した設計まで、多様なニーズに対応。最新の技術と豊富な経験を活かし、持続可能で機能的な設計を実現します。</p>\n          </div>\n\n          <div class=\"flex\">\n            <ul class=\"p-top-col2__list\">\n              <li><img src=\"https://www.kokudoec.co.jp/wp-content/themes/kokudo/assets/img/top/infra-icon01.webp\" alt=\"\"></li>\n              <li><img src=\"https://www.kokudoec.co.jp/wp-content/themes/kokudo/assets/img/top/infra-icon02.webp\" alt=\"\"></li>\n              <li><img src=\"https://www.kokudoec.co.jp/wp-content/themes/kokudo/assets/img/top/infra-icon03.webp\" alt=\"\"></li>\n            </ul>\n            <ul class=\"p-top-col2__list\">\n              <li><img src=\"https://www.kokudoec.co.jp/wp-content/themes/kokudo/assets/img/top/infra-icon04.webp\" alt=\"\"></li>\n              <li><img src=\"https://www.kokudoec.co.jp/wp-content/themes/kokudo/assets/img/top/infra-icon05.webp\" alt=\"\"></li>\n              <li><img src=\"https://www.kokudoec.co.jp/wp-content/themes/kokudo/assets/img/top/infra-icon06.webp\" alt=\"\"></li>\n            </ul>\n          </div>\n\n          <div class=\"p-top-col2__btn\">\n            <a href=\"/introduction/01\">詳細へ</a>\n          </div>\n        </div>\n\n        <div class=\"p-top-col2__image is-pc\">\n          <img src=\"https://www.kokudoec.co.jp/wp-content/themes/kokudo/assets/img/top/infra-image.webp\" alt=\"\">\n        </div>\n      </div>\n    </section>\n\n    <section class=\"p-top-survey bg-white\">\n      <div class=\"p-top-col2\">\n\n        <div class=\"p-top-col2__textarea\">\n          <div class=\"p-top-col2__image is-sp\">\n            <img src=\"https://www.kokudoec.co.jp/wp-content/themes/kokudo/assets/img/top/survey-image.webp\" alt=\"\">\n          </div>\n          <div class=\"p-top-col2__title\">\n            <h2>Survey ＆ Geographic<br>Information</h2>\n          </div>\n          <div class=\"p-top-col2__about\">\n            <sup><span></span>SURVEYING</sup>\n            <strong>測量</strong>\n            <p>精度の高い測量技術を活かし、インフラ整備や都市開発の基盤となる測量業務を提供しています。最新の測量機器とGIS（地理情報システム）を活用し、地形測量、用地測量、工事測量など幅広いニーズに対応。正確なデータをもとに、設計や施工の効率化を支援し、安全で持続可能な社会づくりに貢献します。</p>\n          </div>\n          <ul class=\"p-top-col2__list\">\n            <li><img src=\"https://www.kokudoec.co.jp/wp-content/themes/kokudo/assets/img/top/survey-icon01.webp\" alt=\"\"></li>\n            <li><img src=\"https://www.kokudoec.co.jp/wp-content/themes/kokudo/assets/img/top/survey-icon02.webp\" alt=\"\"></li>\n            <li><img src=\"https://www.kokudoec.co.jp/wp-content/themes/kokudo/assets/img/top/survey-icon03.webp\" alt=\"\"></li>\n            <li><img src=\"https://www.kokudoec.co.jp/wp-content/themes/kokudo/assets/img/top/survey-icon04.webp\" alt=\"\"></li>\n          </ul>\n\n          <div class=\"p-top-col2__btn\">\n            <a href=\"/introduction/02\">詳細へ</a>\n          </div>\n\n        </div>\n\n        <div class=\"p-top-col2__image is-pc\">\n          <img src=\"https://www.kokudoec.co.jp/wp-content/themes/kokudo/assets/img/top/survey-image.webp\" alt=\"\">\n        </div>\n      </div>\n    </section>\n    \n    <section class=\"p-top-comp bg-white\">\n      <div class=\"p-top-col2\">\n    \n        <div class=\"p-top-col2__textarea\">\n          <div class=\"p-top-col2__image is-sp\">\n            <img src=\"https://www.kokudoec.co.jp/wp-content/themes/kokudo/assets/img/top/comp-image.webp\" alt=\"\">\n          </div>\n          <div class=\"p-top-col2__title\">\n            <h2>Compensation<br>Consultant</h2>\n          </div>\n    \n          <div class=\"p-top-col2__about\">\n            <sup><span></span>COMPENSATION</sup>\n            <strong>補償コンサルタント</strong>\n            <p>\n              公共事業や民間開発に伴う補償業務を通じて、公正かつ適正な補償を実現します。土地や建物の調査・評価から、移転補償、営業補償まで、専門的な知識と豊富な経験を活かし、権利者の方々に寄り添った対応を徹底。関係者の合意形成を円滑に進め、事業のスムーズな推進をサポートします。\n            </p>\n          </div>\n    \n    \n          <ul class=\"p-top-col2__list\">\n            <li><img src=\"https://www.kokudoec.co.jp/wp-content/themes/kokudo/assets/img/top/comp-icon01.webp\" alt=\"\"></li>\n            <li><img src=\"https://www.kokudoec.co.jp/wp-content/themes/kokudo/assets/img/top/comp-icon02.webp\" alt=\"\"></li>\n            <li><img src=\"https://www.kokudoec.co.jp/wp-content/themes/kokudo/assets/img/top/comp-icon03.webp\" alt=\"\"></li>\n            <li><img src=\"https://www.kokudoec.co.jp/wp-content/themes/kokudo/assets/img/top/comp-icon04.webp\" alt=\"\"></li>\n          </ul>\n    \n          <div class=\"p-top-col2__btn\">\n            <a href=\"/introduction/03\">詳細へ</a>\n          </div>\n        </div>\n    \n        <div class=\"p-top-col2__image is-pc\">\n          <img src=\"https://www.kokudoec.co.jp/wp-content/themes/kokudo/assets/img/top/comp-image.webp\" alt=\"\">\n        </div>\n      </div>\n    </section>\n\n    <section class=\"p-top-company\">\n      <div class=\"p-top-company-bg\">\n        <ul class=\"p-top-company-bg__image\">\n          <li>\n            <ul class=\"p-top-company-bg__slide\">\n              <li class=\"slide-top\">\n                <figure>\n                  <span><img src=\"https://www.kokudoec.co.jp/wp-content/themes/kokudo/assets/img/top/company01.jpg\" alt=\"\"></span>\n                  <span><img src=\"https://www.kokudoec.co.jp/wp-content/themes/kokudo/assets/img/top/company02.jpg\" alt=\"\"></span>\n                  <span><img src=\"https://www.kokudoec.co.jp/wp-content/themes/kokudo/assets/img/top/company03.jpg\" alt=\"\"></span>\n                  <span><img src=\"https://www.kokudoec.co.jp/wp-content/themes/kokudo/assets/img/top/company04.jpg\" alt=\"\"></span>\n                  <span><img src=\"https://www.kokudoec.co.jp/wp-content/themes/kokudo/assets/img/top/company05.jpg\" alt=\"\"></span>\n                </figure>\n              </li>\n              <li class=\"slide-top\">\n                <figure>\n                  <span><img src=\"https://www.kokudoec.co.jp/wp-content/themes/kokudo/assets/img/top/company01.jpg\" alt=\"\"></span>\n                  <span><img src=\"https://www.kokudoec.co.jp/wp-content/themes/kokudo/assets/img/top/company02.jpg\" alt=\"\"></span>\n                  <span><img src=\"https://www.kokudoec.co.jp/wp-content/themes/kokudo/assets/img/top/company03.jpg\" alt=\"\"></span>\n                  <span><img src=\"https://www.kokudoec.co.jp/wp-content/themes/kokudo/assets/img/top/company04.jpg\" alt=\"\"></span>\n                  <span><img src=\"https://www.kokudoec.co.jp/wp-content/themes/kokudo/assets/img/top/company05.jpg\" alt=\"\"></span>\n                </figure>\n              </li>\n            </ul>\n          </li>\n    \n          <li>\n            <ul class=\"p-top-company-bg__slide\">\n              <li class=\"slide-bottom\">\n                <figure>\n                  <span><img src=\"https://www.kokudoec.co.jp/wp-content/themes/kokudo/assets/img/top/company06.jpg\" alt=\"\"></span>\n                  <span><img src=\"https://www.kokudoec.co.jp/wp-content/themes/kokudo/assets/img/top/company07.jpg\" alt=\"\"></span>\n                  <span><img src=\"https://www.kokudoec.co.jp/wp-content/themes/kokudo/assets/img/top/company08.jpg\" alt=\"\"></span>\n                  <span><img src=\"https://www.kokudoec.co.jp/wp-content/themes/kokudo/assets/img/top/company09.jpg\" alt=\"\"></span>\n                  <span><img src=\"https://www.kokudoec.co.jp/wp-content/themes/kokudo/assets/img/top/company10.jpg\" alt=\"\"></span>\n                </figure>\n              </li>\n              <li class=\"slide-bottom\">\n                <figure>\n                  <span><img src=\"https://www.kokudoec.co.jp/wp-content/themes/kokudo/assets/img/top/company06.jpg\" alt=\"\"></span>\n                  <span><img src=\"https://www.kokudoec.co.jp/wp-content/themes/kokudo/assets/img/top/company07.jpg\" alt=\"\"></span>\n                  <span><img src=\"https://www.kokudoec.co.jp/wp-content/themes/kokudo/assets/img/top/company08.jpg\" alt=\"\"></span>\n                  <span><img src=\"https://www.kokudoec.co.jp/wp-content/themes/kokudo/assets/img/top/company09.jpg\" alt=\"\"></span>\n                  <span><img src=\"https://www.kokudoec.co.jp/wp-content/themes/kokudo/assets/img/top/company10.jpg\" alt=\"\"></span>\n                </figure>\n              </li>\n            </ul>\n          </li>\n        </ul>\n\n        <div class=\"p-top-company-contents\">\n          <h2>COMPANY<span>企業情報</span></h2>\n          <p>株式会社国土技術コンサルタンツは<br>\n          社会基盤の基礎となる道路や橋梁などの設計や<br>\n          公共工事に係る補償を行う<br>\n          総合建設コンサルタントです。</p>\n          <div class=\"p-top-company-contents__btn\">\n            <a href=\"/company\"><i class=\"fa-solid fa-down-long\"></i></a>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"p-top-number\">\n      <h2 class=\"p-top-number__title\">総合3000件を超える豊富な実績</h2>\n      <p class=\"p-top-number__read\">\n        私たちは、創業55年の建設コンサルタントです。<br>\n        社会基盤の調査・設計・コンサルティングを通じて、<br>\n        経済や産業、そして人々の生活といった社会と暮らしの<br>\n        課題を解決する事業に貢献しております。\n      </p>\n      <sub class=\"p-top-number__sub\">※2024年12月時点の調査・設計数を表示</sub>\n\n      <ul class=\"p-top-number__lists\">\n        <li>\n          <strong>1830<span>件</span></strong>\n          <h3><span>建設コンサルタント</span></h3>\n          <p>長年にわたり培った専門知識と技術力を活かし、多様な建設プロジェクトを支援してきました。社会インフラである道路事業や防災設計、農地計画など、幅広い分野で調査・計画・設計を担い、安全かつ持続可能な社会の実現に貢献しています。</p>\n        </li>\n        <li>\n          <strong>288<span>件</span></strong>\n          <h3><span>測量業務</span></h3>\n          <p>最新の測量技術と豊富な経験を活かし、公共測量、用地調査、新技術による3D観測など、多様なニーズに対応してきました。高精限なデータの提供を通じて、地形の視覚化や計画の最適化を実現し、地域の方々に信頼される公共事業の推進に貢献しています。</p>\n        </li>\n        <li>\n          <strong>289<span>件</span></strong>\n          <h3><span>用地補償業務</span></h3>\n          <p>専門的な法律知識と土木・建築に関する知見を活かし、土地や建物などの補填額の算定、関係者との調整など、総合的なサポートを提供してきました。公正かつ迅速な対応を徹底し、事業のスムーズな進行と地域社会との調和に貢献しています。</p>\n        </li>\n        <li>\n          <strong>810<span>件</span></strong>\n          <h3><span>市町村発注業務</span></h3>\n          <p>全国一南北に長い鹿児島県内の市町村と近隣県の一部市町村において道路整備や河川改修、農地計画など、公共事業の設計・測量・補償業務を総合的に支援し、確かな技術力と的確な提案で地域の課題解決に貢献しています。</p>\n        </li>\n        <li>\n          <strong>1616<span>件</span></strong>\n          <h3><span>鹿児島県発注業務</span></h3>\n          <p>道路・橋梁の計画や設計、河川・防災対策、公園をはじめとする公共施設の整備など、地域の発展と安全に貢献する事業に寄与しています。自然が豊富な鹿児島県において自然との共生や災害に強い郷土へ変革を図面に描き、今後も鹿児島県の持続可能なまちづくりに貢献し発展を支えてまいります。</p>\n        </li>\n        <li>\n          <strong>93<span>件</span></strong>\n          <h3><span>国機関発注業務</span></h3>\n          <p>国の機関が発注する直轄業務等において、これまで培った技術力と豊富な経験を活かし、大規模事業にも貢献してきました。道路・河川・港湾の整備、インフラの維持管理、防災・減災対策など、社会基盤の強化を進める国土強靭化計画に関する業務を担っています。<br>\n          （国土交通省、農林水産省、防衛省等）</p>\n        </li>\n      </ul>\n    </section>\n\n    <section class=\"p-top-results bg-white\">\n      <div class=\"p-top-results__title\">\n        <h2>実績<sub>挑み続け、進化し続けてきました「多彩な実績」をご紹介します。</sub></h2>\n        <strong>results</strong>\n      </div>\n\t\t\n\t\t\t\t\t\t\t\t  <ul class=\"p-top-results__lists\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<li>\n\t\t\t\t\t  <a href=\"https://www.kokudoec.co.jp/achivements/%ef%bc%93%e6%ac%a1%e5%85%83%e8%a6%b3%e6%b8%ac%ef%bc%88%e6%96%b0%e6%8a%80%e8%a1%93%ef%bc%89/\">\n\t\t\t\t\t\t  <div>\n\t\t\t\t\t\t\t  <img src=\"https://www.kokudoec.co.jp/wp-content/uploads/2025/07/実績紹介用写真.088.png\" ?>\n\t\t\t\t\t\t  </div>\n\t\t\t\t\t\t  <p>３次元観測（新技術）</p>\n\t\t\t\t\t  </a>\n\t\t\t\t  </li>\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<li>\n\t\t\t\t\t  <a href=\"https://www.kokudoec.co.jp/achivements/%e7%a5%9e%e4%b9%8b%e5%b7%9d%e6%95%b4%e5%82%99%e4%ba%8b%e6%a5%ad%ef%bc%88%e9%b9%bf%e5%85%90%e5%b3%b6%e7%9c%8c%e9%b9%bf%e5%85%90%e5%b3%b6%e5%9c%b0%e5%9f%9f%e6%8c%af%e8%88%88%e5%b1%80%ef%bc%89/\">\n\t\t\t\t\t\t  <div>\n\t\t\t\t\t\t\t  <img src=\"https://www.kokudoec.co.jp/wp-content/uploads/2025/07/実績紹介用写真.080.png\" ?>\n\t\t\t\t\t\t  </