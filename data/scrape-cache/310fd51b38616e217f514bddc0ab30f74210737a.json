{"url":"http://www.kokudoec.co.jp/","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n  <head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <script src=\"https://code.jquery.com/jquery-3.7.1.min.js\" integrity=\"sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo=\" crossorigin=\"anonymous\"></script>\n    \n<title>株式会社国土技術コンサルタンツ | </title>\n<meta name='robots' content='max-image-preview:large' />\n<link rel='dns-prefetch' href='//use.fontawesome.com' />\n<link rel='dns-prefetch' href='//fonts.googleapis.com' />\n<link rel=\"alternate\" type=\"application/rss+xml\" title=\"株式会社国土技術コンサルタンツ &raquo; 企業TOPページ のコメントのフィード\" href=\"https://www.kokudoec.co.jp/%e4%bc%81%e6%a5%adtop%e3%83%9a%e3%83%bc%e3%82%b8/feed/\" />\n<link rel=\"alternate\" title=\"oEmbed (JSON)\" type=\"application/json+oembed\" href=\"https://www.kokudoec.co.jp/wp-json/oembed/1.0/embed?url=https%3A%2F%2Fwww.kokudoec.co.jp%2F\" />\n<link rel=\"alternate\" title=\"oEmbed (XML)\" type=\"text/xml+oembed\" href=\"https://www.kokudoec.co.jp/wp-json/oembed/1.0/embed?url=https%3A%2F%2Fwww.kokudoec.co.jp%2F&#038;format=xml\" />\n<meta name=\"description\" content=\"\" /><style id=\"wp-img-auto-sizes-contain-inline-css\">\nimg:is([sizes=auto i],[sizes^=\"auto,\" i]){contain-intrinsic-size:3000px 1500px}\n/*# sourceURL=wp-img-auto-sizes-contain-inline-css */\n</style>\n<link rel='stylesheet' id='vkExUnit_common_style-css' href='https://www.kokudoec.co.jp/wp-content/plugins/vk-all-in-one-expansion-unit/assets/css/vkExUnit_style.css?ver=9.109.0.1' media='all' />\n<style id=\"vkExUnit_common_style-inline-css\">\n:root {--ver_page_top_button_url:url(https://www.kokudoec.co.jp/wp-content/plugins/vk-all-in-one-expansion-unit/assets/images/to-top-btn-icon.svg);}@font-face {font-weight: normal;font-style: normal;font-family: \"vk_sns\";src: url(\"https://www.kokudoec.co.jp/wp-content/plugins/vk-all-in-one-expansion-unit/inc/sns/icons/fonts/vk_sns.eot?-bq20cj