         <li><a href=\"../works/person.html\">社員紹介</a></li>\n                    </ul>\n\n                    <p class=\"ttl\">キャリアサポート</p>\n                    <ul class=\"flexbox col2\">\n                        <li><a href=\"../career/career.html\">キャリアとNISSO</a></li>\n                        <li><a class=\"multi-line\" href=\"../career/talk.html\">ライフイベントと<br class=\"spshow\">キャリア</a></li>\n                    </ul>\n\n                    <p class=\"ttl\">採用情報</p>\n                    <ul class=\"flexbox col2\">\n                        <li><a href=\"../recruit/bosyu.html\">募集要項</a></li>\n                        <li><a href=\"../recruit/qa.html\">採用Q&A</a></li>\n                    </ul>\n\n                    <ul class=\"flexbox col1\">\n                        <li><a href=\"https://nippon-soda.snar.jp/jobboard/detail.aspx?id=O1aKrvYGg_A\" target=\"_blank\">エントリー<span>ENTRY</span></a></li>\n                    </ul>\n                </div>\n            </nav>\n\n            <div id=\"mainbody\" class=\"sidepadding\">\n                <div class=\"insidebox\">\n                    <div id=\"h1\">\n                        <h1><img class=\"js-switchimg sp100\" src=\"../assets/img/works/workflow_h1_pc.png\" alt=\"社員と仕事 | 仕事の流れ\"></h1>\n                    </div>\n\n\n                    <div id=\"sections\">\n                        <div id=\"section01\">\n                            <div class=\"inner1040\">\n\n\n                                <div class=\"flexbox\">\n                                    <div class=\"col\">\n                                        <div class=\"float col3\">\n                                            <div class=\"left\">\n                                                <div class=\"ttl blue table-cell\">\n                                                    <div class=\"cell\">\n                                                        探索\n                                                    </div>\n                                                </div>\n                                            </div>\n                                            <div class=\"left\">\n                                                製品化の可能性のある化合物や材料を創出する<br>\n                                                <br>\n                                                <span class=\"bold\">＜活躍する職種＞</span><br>\n                                                化学合成分野：農薬探索研究、高分子材料探索、有機／無機材料探索<br>\n                                                機能性材料分野：高分子材料探索、有機／無機材料探索<br>\n                                                評価・分析分野：計算化学\n                                            </div>\n                                            <div class=\"left\">\n                                                <img src=\"../assets/img/works/workflow_p05_pc.jpg\" alt=\"イメージ\">\n                                            </div>\n                                        </div>\n\n\n                                        <div class=\"hr\"><img class=\"js-switchimg\" src=\"../assets/img/common/icon_arrow_down_pc.png\" alt=\"矢印\"></div>\n\n\n                                        <div class=\"float col3\">\n                                            <div class=\"left\">\n                                                <div class=\"ttl blue table-cell\">\n                                                    <div class=\"cell no-br\">\n                                                        評価・分析\n                                                    </div>\n                                                </div>\n                                            </div>\n                                            <div class=\"left\">\n                                                製品化の可能性のある化合物や材料の機能や効果、および安全性を多角的に分析・評価する<br>\n                                                <br>\n                                                <span class=\"bold\">＜活躍する職種＞</span><br>\n                                                ○初期活性／機能評価<br>\n                                                生物研究分野：農薬の生物活性評価<br>\n                                                機能性材料分野：物性／機能評価<br><br>\n\n                                                ○安全性評価<br>\n                                                評価・分析分野：代謝残留分析、環境安全性評価、一般化学品分析<br>\n                                                安全性研究分野：薬理・毒性評価、作用性解析<br><br>\n\n                                                ○実用性評価<br>\n                                                機能性材料分野：物性／機能評価<br>\n                                                生物研究分野：圃場評価<br>\n                                                評価・分析分野：代謝残留分析、環境安全性評価、一般化学品分析、製剤研究\n                                            </div>\n                                            <div class=\"left\">\n                                                <p class=\"wcut\"><img src=\"../assets/img/works/workflow_p01_pc.jpg\" alt=\"イメージ\"></p>\n                                                <p><img src=\"../assets/img/works/workflow_p02_pc.jpg\" alt=\"イメージ\"></p>\n                                            </div>\n                                        </div>\n                                    </div>\n                                </div>\n\n\n                                <div class=\"hr\"><img class=\"js-switchimg\" src=\"../assets/img/common/icon_arrow_down_pc.png\" alt=\"矢印\"></div>\n\n\n                                <div class=\"flexbox\">\n                                    <div class=\"col\">\n                                        <div class=\"float col3\">\n                                            <div class=\"left\">\n                                                <div class=\"ttl green table-cell\">\n                                                    <div class=\"cell\">\n                                                        生産技術・製造\n                                                    </div>\n                                                </div>\n                                            </div>\n                                            <div class=\"left\">\n                                                製品を製造するためのプロセス、装置や設備を設計する安全・安定操業のための管理を行う<br>\n                                                <br>\n                                                <span class=\"bold\">＜活躍する職種＞</span><br>\n                                                化学合成分野：プロセス開発、合理化研究<br>\n                                                機能性材料分野：プロセス開発、合理化研究<br>\n                                                評価・分析分野：一般化学品分析、品質管理<br>\n                                                製造・生産技術分野：プラント設計、保全管理（工務・計電）、薬事管理\n                                            </div>\n                                            <div class=\"left\">\n                                                <img src=\"../assets/img/works/workflow_p04_pc.jpg\" alt=\"イメージ\">\n                                            </div>\n                                        </div>\n                                    </div>\n                                </div>\n\n\n                                <div class=\"hr\"><img class=\"js-switchimg\" src=\"../assets/img/common/icon_arrow_down_pc.png\" alt=\"矢印\"></div>\n\n\n                                <div class=\"flexbox\">\n                                    <div class=\"col\">\n                                        <div class=\"float col3\">\n                                            <div class=\"left\">\n                                                <div class=\"ttl purple table-cell\">\n                                                    <div class=\"cell\">\n                                                        営業\n                                                    </div>\n                                                </div>\n                                            </div>\n                                            <div class=\"left\">\n                                                化学品と農業化学品にわかれ、国内外の顧客に製品の提供を行うと同時に、市場ニーズの汲み取りを行う<br>\n                                                <br>\n                                                <span class=\"bold\">＜活躍する職種＞</span><br>\n                                                営業部門：営業、技術営業\n                                            </div>\n                                            <div class=\"left\">\n                                                <img src=\"../assets/img/works/workflow_p06_pc.jpg\" alt=\"イメージ\">\n                                            </div>\n                                        </div>\n                                    </div>\n                                </div>\n\n\n                                <div class=\"hr none\"></div>\n\n\n                                <div class=\"flexbox\">\n                                    <div class=\"col\">\n                                        <div class=\"float col3\">\n                                            <div class=\"left\">\n                                                <div class=\"ttl pink table-cell\">\n                                                    <div class=\"cell\">\n                                                        管理\n                                                    </div>\n                                                </div>\n                                            </div>\n                                            <div class=\"left\">\n                                                事業の方向性の決定や、事業活動の直接的・間接的なサポートを行い、日本曹達の経営を支える<br>\n                                                <br>\n                                                <span class=\"bold\">＜活躍する職種＞</span><br>\n                                                管理部門：総務、法務、人事、財務・経理、購買・物流、経営企画、IT企画 など\n                                            </div>\n                                            <div class=\"left\">\n                                                <img src=\"../assets/img/works/workflow_p07_pc.png\" alt=\"イメージ\">\n                                            </div>\n                                        </div>\n                                    </div>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n\n\n            <footer class=\"sidepadding \">\n                <div class=\"insidebox\">\n                    <div id=\"pagetop\" class=\"pcshow\"><a href=\"#wrapper\"><img src=\"../assets/img/common/pagetop_pc.png\" alt=\"PAGE TOP\"></a></div>\n                    <div class=\"float\">\n                        <div class=\"left\">\n                            <ul class=\"flexbox\">\n                                <li><a href=\"http://www.nippon-soda.co.jp/privacy.html\" target=\"_blank\">プライバシーポリシー</a></li>\n                                <li><a href=\"http://www.nippon-soda.co.jp/contact/index.html\" target=\"_blank\">お問い合わせ</a></li>\n                            </ul>\n                        </div>\n                        <div class=\"right\">\n                            <div id=\"footer-logo\"><img class=\"js-switchimg\" src=\"../assets/img/common/footer_logo_pc.png\" alt=\"\"></div>\n                            <div id=\"copyright\">Copyright 2018 NIPPON SODA CO., LTD. All rights reserved</div>\n                        </div>\n                    </div>\n                </div>\n            </footer>\n\n\n\n        </div>\n    </body>\n</html>\n","finalUrl":"https://www.nippon-soda.co.jp/recruitment/saiyo/works/workflow.html","rendered":false,"_cachedAt":"2026-06-22T21:32:54.951Z"}