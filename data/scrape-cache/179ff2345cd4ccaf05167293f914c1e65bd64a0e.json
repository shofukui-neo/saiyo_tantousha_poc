{"url":"https://www.kidsfore.co.jp/recruit_voice/recruit-voice-koyama","html":"\n\n\n<!DOCTYPE html>\n<html>\n\n<head>\n    <meta charset=\"UTF-8\">\n\n    <title>キッズフォレ</title>\n\n    <link href=\"https://www.kidsfore.co.jp/wp/wp-content/themes/biz-vektor-child/recruit_style.css\" rel=\"stylesheet\" type=\"text/css\">\n\n</head>\n\n<body>\n\n    <header>\n        <div id=\"header-image\">\n            <div id=\"header-top\">\n                <div id=\"header-logo\">\n                    <a href=\"https://www.kidsfore.co.jp/recruit\"><img src=\"https://www.kidsfore.co.jp/wp/wp-content/themes/biz-vektor-child/images/header-logo.png\"></a>\n                </div>\n\t\t\t\t<!--\n                <div id=\"header-entry\">\n                    <a href=\"https://www.kidsfore.co.jp/recruit_entry\">エントリーする</a>\n                </div>\n\t\t\t\t-->\n            </div>\n                        <img src=\"https://www.kidsfore.co.jp/wp/wp-content/themes/biz-vektor-child/images/header-voice.png\">                                        \n                   </div>\n        <div id=\"header-nav\">\n            <ul>\n                <li><a href=\"https://www.kidsfore.co.jp/recruit_message\" id=\"list-message\">メッセージ</a></li>\n                <li><a href=\"https://www.kidsfore.co.jp/recruit_voice\" id=\"list-voice\">先輩スタッフの声</a></li>\n                <li><a href=\"https://www.kidsfore.co.jp/recruit_support\" id=\"list-support\">スタッフサポート</a></li>\n\t\t\t\t<li><a href=\"https://www.kidsfore.com/\" id=\"list-requirement\" target=\"_blank\" rel=\"nofollow\">募集要項</a></li>\n              <!--  <li><a href=\"https://www.kidsfore.co.jp/recruit_requirements\" id=\"list-requirement\">募集要項</a></li>\n                -->\n<!--                <li><a href=\"https://www.kidsfore.co.jp/facilities\" id=\"list-facility\">施設紹介</a></li>\n -->\n                <li><a href=\"http://www.kidsfore.co.jp/facilities/  \" id=\"list-facility\">施設紹介</a></li>\n                <li><a href=\"http://www.kidsfore.co.jp/about/outline/\" id=\"list-company\">企業情報</a></li>\n<!---     \n                <li><a href=\"https://www.kidsfore.co.jp/about\" id=\"list-company\">企業情報</a></li>\n-->     \n            </ul>\n        </div>\n    </header>\n   \n    <div id=\"voice\" class=\"container\">\n        <div class=\"contents\">\n            <div id=\"voice-top\">\n                <h1>先輩スタッフの声</h1>\n            </div>\n            <div id=\"voice-content\">\n                <div id=\"voice-left\">\n                    <img src=\"https://www.kidsfore.co.jp/wp/wp-content/themes/biz-vektor-child/images/koyama_face.png\">\n                    <img id=\"voice-aki\" class=\"back-image\" src=\"https://www.kidsfore.co.jp/wp/wp-content/themes/biz-vektor-child/images/aki.png\">\n                </div>\n                <div id=\"voice-right\">\n                    <div class=\"voice-text\">\n                        <h2>子どもたちの笑顔と、いろいろな先生のサポートでやりがいをもって働いています。\n</h2>\n  <!--                      <img src=\"https://www.kidsfore.co.jp/wp/wp-content/themes/biz-vektor-child/images/recruit_voice.png\">\n  -->\n                        <img src=\"https://www.kidsfore.co.jp/wp/wp-content/themes/biz-vektor-child/images/koyama_nn.png\">                        \n                    </div>\n                    <div class=\"voice-text\">\n                        <h3>この会社に決めた理由</h3>\n                        <p>\n                        <img src=\"https://www.kidsfore.co.jp/wp/wp-content/themes/biz-vektor-child/images/voice1.png\" align=\"left\">\n                        長崎から東京に出て働きたいと思った時に、家賃補助制度がある会社で、なおかつ英語教育を積極的に行っている保育園に勤めたいと考えて探していました。キッズフォレは、15年前から英語教育に力を入れていたという点と、家賃補助が8万円もしっかりとついていたので、どちらも自分の希望に合った場所だったので入社を決めました。\n<br clear=\"left\">\n                        </p>\n                    </div>\n                    <div class=\"voice-text\">\n                        <h3>今の仕事のやりがい</h3>\n                        <p>\n                        <img src=\"https://www.kidsfore.co.jp/wp/wp-content/themes/biz-vektor-child/images/voice2.png\" align=\"right\">\n                        子どもの小さな身体がすくすく成長していく姿を近くで見ながら、英語の絵本や手遊びを満面の笑みで一緒にやってくれた時に嬉しく感じます。また、保護者の方から自分が教えたことを家でもやっていると聞いた時、子どもにとって楽しい時間になったんだと実感できるので、一生懸命やってよかったとやりがいに繋がっています。\n\n                        <br clear=\"right\">\n                        </p>\n                    </div>\n                    <div class=\"voice-text\">\n                        <h3>みなさまへのメッセージ</h3>\n                        <p>人の命を預かるという責任ある仕事です。\n体力的にも色々と大変なこともありますが、それ以上にやりがいを感じる場面は沢山あります。何よりも子どもたちの笑顔が可愛いので、パワーをもらって頑張れます。\n小さな悩みも園長先生や色々な先生がしっかりと聞いて答えてくれるので、とても働きやすい職場だと思います。いつも明るく沢山の笑顔で溢れている場所ですよ！\n\n                        </p>\n                    </div>\n                </div>\n            </div>\n            <div id=\"voice-staff\">\n                <div class=\"staff\">\n                    <a href=\"https://www.kidsfore.co.jp/recruit_voice/recruit-voice-yamamoto\"><img src=\"https://www.kidsfore.co.jp/wp/wp-content/themes/biz-vektor-child/images/yamamoto.JPG\"></a>\n                    <h4>園長</h4>\n                    <p>山元 さおり先生</p>\n                </div>\n                <div class=\"staff\">\n                    <a href=\"https://www.kidsfore.co.jp/recruit_voice/\"><img src=\"https://www.kidsfore.co.jp/wp/wp-content/themes/biz-vektor-child/images/katou.png\">\n                    <h4>主任保育士</h4>\n                    <p>加藤 民歌先生</p>\n                </div>\n                <div class=\"staff\">\n                    <a href=\"https://www.kidsfore.co.jp/recruit_voice/recruit-voice-kawai\"><img src=\"https://www.kidsfore.co.jp/wp/wp-content/themes/biz-vektor-child/images/kawai.jpg\">\n                    <h4>指導主事</h4>\n                    <p>川井 健司先生</p>\n                </div>\n                <div class=\"staff\">\n                    <a href=\"https://www.kidsfore.co.jp/recruit_voice/recruit-voice-kasahara\"><img src=\"https://www.kidsfore.co.jp/wp/wp-content/themes/biz-vektor-child/images/sasabara.png\">\n                    <h4>管理栄養士</h4>\n                    <p>笠原 ひかる先生</p>\n                </div>\n                <div class=\"staff\">\n                    <a href=\"https://www.kidsfore.co.jp/recruit_voice/recruit-voice-koyama\"><img src=\"https://www.kidsfore.co.jp/wp/wp-content/themes/biz-vektor-child/images/koyama.JPG\">\n                    <h4>保育士</h4>\n                    <p>小山 雅美先生</p>\n                </div>\n                <div class=\"staff\">\n                    <a href=\"https://www.kidsfore.co.jp/recruit_voice/recruit-voice-urushihara\"><img src=\"https://www.kidsfore.co.jp/wp/wp-content/themes/biz-vektor-child/images/urushibara.JPG\">\n                    <h4>保育士</h4>\n                    <p>漆原 萌乃先生</p>\n                </div>\n                <img id=\"voice-bird\" class=\"back-image\" src=\"https://www.kidsfore.co.jp/wp/wp-content/themes/biz-vektor-child/images/bird.png\">\n                <img id=\"voice-plant\" class=\"back-image\" src=\"https://www.kidsfore.co.jp/wp/wp-content/themes/biz-vektor-child/images/plant.png\">\n            </div>\n        </div>\n    </div>\n    \n    <div id=\"bottom-menu\">\n        <ul>\n             <li><a href=\"https://www.kidsfore.co.jp/wp/wp-content/themes/biz-vektor-child/images/recruit_movie.mp4\"><img src=\"https://www.kidsfore.co.jp/wp/wp-content/themes/biz-vektor-child/images/kidsfore-btn.png\"></a></li>\n            <li><a href=\"https://www.kidsfore.co.jp/wp/wp-content/themes/biz-vektor-child/images/athoiku.pdf\"><img src=\"https://www.kidsfore.co.jp/wp/wp-content/themes/biz-vektor-child/images/atorie-btn.png\"></a></li>\n            <li><a href=\"https://www.kidsfore.co.jp/recruit_blog\"><img src=\"https://www.kidsfore.co.jp/wp/wp-content/themes/biz-vektor-child/images/blog-btn.png\"></a></li>\n        </ul>\n    </div>\n\n\n\n<footer>\n    <div id=\"footer-inner\">\n        <div id=\"footer-top\">\n            <div id=\"footer-left\">\n                <ul>\n                    <li><a href=\"http://www.kidsfore.co.jp/\">キッズフォレTOP</a></li>\n     