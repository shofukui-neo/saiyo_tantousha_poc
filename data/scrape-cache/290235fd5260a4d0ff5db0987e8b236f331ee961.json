lass=\" c-sp_navigation_btn\"></div> \n          </nav> \n         </div> \n        </div> \n        <div id=\"bk3227\" class=\"b-both_diff -right_large -sp-single_column c-space_narrow c-sp-space_normal c-sp-padding_normal is-sp-hide bd-webp -dress_b14006Navi cssskin-_block_header init-block_animation init-sp-block_animation\" data-bk-id=\"bk3227\" data-shared=\"true\" data-sharedname=\"_グローバルナビ2\" data-animated=\"fadeIn\" data-sp-animated=\"fadeIn\"> \n         <div class=\" g-column\"> \n          <div class=\" column -col4 -col_sub\"> \n           <h1 class=\" c-page_title\"> \n            <div class=\"c-img   \"> \n             <picture> \n              <source type=\"image/webp\" srcset=\"../_src/2239/img20150831145800040553.webp?v=1769645477911\"> \n              <img src=\"../_src/2239/img20150831145800040553.png?v=1769645477911\" width=\"380\" height=\"100\" alt=\"株式会社マルイ_2025年新卒採用情報\" id=\"imgsrc2239_1\" class=\" c-no_adjust\" loading=\"lazy\"> \n             </picture> \n            </div></h1> \n          </div> \n          <div class=\" column -col8 -col_main\"> \n           <nav> \n            <div class=\" js-motion\"> \n             <ul class=\"m-motion menu-parts -f\"> \n              <li><a href=\"../\" data-pid=\"175\">ホーム</a></li> \n              <li><a href=\"../message.html\" data-pid=\"176\">メッセージ</a></li> \n              <li><span class=\" c-unlink\">チームで取り組む</span> \n               <ul> \n                <li><a href=\"../fisheries/session1.html\" data-pid=\"180\">マルイが挑むプロジェクト</a></li> \n                <li><a href=\"../deli/session2.html\" data-pid=\"183\">新人社員の教育現場</a></li> \n                <li class=\" c-current\"><a href=\"session3.html\" data-mypid=\"189\">新人社員の研修</a></li> \n               </ul></li> \n              <li><a href=\"../characteristic.html\" data-pid=\"177\">スーパーマルイの特徴</a></li> \n              <li><a href=\"../career_plan.html\" data-pid=\"178\">キャリアプラン</a></li> \n              <li><a href=\"../entry.html\" data-pid=\"179\" class=\"entry\">エントリー</a></li> \n             </ul> \n            </div> \n           </nav> \n          </div> \n         </div> \n        </div> \n       </section> \n      </div> \n     </header> \n    </div> \n    <div id=\"a-billboard\" class=\"a-billboard    cssskin-_area_billboard\"> \n     <div class=\"site_frame\"> \n      <section> \n       <div id=\"bk3228\" class=\"b-plain cssskin-_block_billboard\" data-bk-id=\"bk3228\"> \n        <div class=\" column -column1\"> \n        </div> \n       </div> \n       <div id=\"bk3229\" class=\"b-plain c-sp-space_normal is-pc-hide bd-webp -dress_b14006Main1 cssskin-_block_billboard init-block_animation init-sp-block_animation\" data-bk-id=\"bk3229\" data-animated=\"fadeIn\" data-sp-animated=\"fadeIn\"> \n        <div class=\" g-column -col2 -sp-col1\"> \n         <div class=\" column -column1\"> \n          <p class=\"c-lead\"><span class=\" d-small_font c-left\">新人社員の研修</span></p> \n          <h2 class=\"lead c-title\"><span style=\"color:#555555;\"><span class=\" d-small_font\">同期は最初の『チーム』だ！</span></span></h2> \n          <div class=\"c-none\">\n            &nbsp; \n          </div> \n          <p class=\" c-body\">社会人の同期はライバルでもあり、良き相談相手でもあり、学生時代の友達以上の“<span class=\" d-bold\">チーム</span>”になる。<br>昨年入社の女性新人2名から、同期の連携を取材した。新人社員研修の率直な感想も紹介！</p> \n         </div> \n         <div class=\" column -column2 -column-lasts\"> \n          <div class=\"c-none c-center\"> \n           <div class=\"c-img   \"> \n            <picture> \n             <source type=\"image/webp\" srcset=\"../_src/2383/main_img.webp?v=1769645477911\"> \n             <img src=\"../_src/2383/main_img.png?v=1769645477911\" width=\"1216\" height=\"1216\" alt=\"新人社員の研修\" id=\"imgsrc2383_1\" class=\" c-no_adjust\" loading=\"lazy\"> \n            </picture> \n           </div> \n          </div> \n         </div> \n        </div> \n       </div> \n       <div id=\"bk3230\" class=\"b-plain c-sp-space_normal is-sp-hide bd-webp -dress_b14006Main1 cssskin-_block_billboard init-block_animation init-sp-block_animation\" data-bk-id=\"bk3230\" data-animated=\"fadeIn\" data-sp-animated=\"fadeIn\"> \n        <div class=\" g-column -col2 -sp-col1\"> \n         <div class=\" column -column1\"> \n          <p class=\"c-lead\"><span class=\" d-large_font\">新人社員の研修</span></p> \n          <h2 class=\" c-title\"><span style=\"color:#555555;\" class=\" d-smallest_font\">同期は最初の『チーム』だ！</span></h2> \n          <p class=\" c-body\">&nbsp;<br>社会人の同期はライバルでもあり、良き相談相手でもあり、学生時代の友達以上の“<span class=\" d-bold\">チーム</span>”になる。<br>昨年入社の女性新人2名から、同期の連携を取材した。新人社員研修の率直な感想も紹介！</p> \n         </div> \n         <div class=\" column -column2 -column-lasts\"> \n          <div class=\" c-body c-center\"> \n           <div class=\"c-img   \"> \n            <picture> \n             <source type=\"image/webp\" srcset=\"../_src/2441/main_img.webp?v=1769645477911\"> \n             <img src=\"../_src/2441/main_img.png?v=1769645477911\" width=\"1216\" height=\"1216\" alt=\"新人社員の研修\" id=\"imgsrc2441_1\" class=\" c-no_adjust\" loading=\"lazy\"> \n            </picture> \n           </div> \n          </div> \n         </div> \n        </div> \n       </div> \n      </section> \n     </div> \n    </div> \n    <main> \n     <div id=\"a-site_contents\" class=\"a-site_contents  noskin\"> \n      <article> \n       <div class=\"site_frame\"> \n        <div class=\"g-column\"> \n         <div id=\"a-main\" class=\"a-main column -col12 \"> \n          <section> \n           <div id=\"bk3231\" class=\"b-plain c-space_normal c-sp-space_normal c-sp-padding_normal bd-webp -dress_93f5ddf232da4e5eabf8affc97d8ac99 cssskin-_block_main init-block_animation init-sp-block_animation\" data-bk-id=\"bk3231\" data-animated=\"fadeInUp\" data-sp-animated=\"fadeInUp\"> \n            <div class=\" column -column1\"> \n             <h4 class=\"none c-small_headline\"><span style=\"color:#383838;\"></span><span style=\"color:#383838;\">ごはんに行ったりドライブに行ったりする仲です。</span></h4> \n             <div class=\"c-none\"> \n              <span style=\"color:#383838;\">&nbsp;</span> \n             </div> \n             <p class=\" c-body\"><span style=\"color:#787878;\"><span data-sitecolor-text=\"\" class=\" d-bold\">お互いの第一印象はどんな感じでしたか？</span></span><br>&nbsp;<br><span style=\"color:#434343;\"><span data-sitecolor-text=\"\" class=\" d-bold\">吉田</span>：絶対におとなしい子なんだろうと。でも、お互いに慣れてくるととんでもない。<span class=\" d-bold\">気づいたら仲良くなってたって感じです</span>。</span><br><br><span style=\"color:#434343;\"><span class=\" d-bold\">野崎</span>：なんとなく外見から“いい人”なんだろうなくらいで。でも話してみて、リアクションが自分の２倍の大きさで返ってくるので、びっくりでした。</span><br><span style=\"color:#434343;\">社会人になって<span class=\" d-bold\">ここまで仲良くなる人ができるとは正直思ってなかった</span>です。</span><br><br><span style=\"color:#434343;\"><span class=\" d-bold\">２人</span>：制服のサイズあわせのときに隣同士になって、話をしたのが初顔合わせでした。今では月１回は休みを合わせて、<span class=\" d-bold\">ごはんに行ったりドライブに行ったりする仲</span>です。　</span></p> \n            </div> \n           </div> \n           <div id=\"bk3272\" class=\"b-plain c-space_normal c-sp-space_normal c-sp-padding_normal bd-webp -dress_93f5ddf232da4e5eabf8affc97d8ac99 cssskin-_block_main init-block_animation init-sp-block_animation\" data-bk-id=\"bk3272\" data-animated=\"fadeInUp\" data-sp-animated=\"fadeInUp\"> \n            <div class=\" g-column -col2 -sp-col1\"> \n             <div class=\" column -column1\"> \n              <h4 data-sitecolor-text=\"#383838\" class=\" c-small_headline c-left\"><span style=\"color:#383838;\" data-sitecolor-text=\"\">本部研修について</span></h4> \n              <div class=\"c-none c-left\">\n                &nbsp; \n              </div> \n              <p class=\" c-body\"><span style=\"color:#666666;\"><span data-sitecolor-text=\"\" class=\" d-bold\">入社式に何を抱負で言ったか覚えてますか？</span></span></p> \n              <div class=\"c-none\">\n                &nbsp; \n              </div> \n              <p class=\" c-body\"><span style=\"color:#383838;\"><span data-sitecolor-text=\"\" class=\" d-bold\">吉田</span>：あまり覚えてないんですが、絵が得意なことと、コトＰＯＰを頑張りたいって言ったような・・・</span><br><br><span style=\"color:#383838;\"><span class=\" d-bold\">野崎</span>：バレーボールを頑張っていたので、体力には自信がある、くらいだったでしょうか。　</span></p> \n              <div class=\"c-none\"> \n               <span data-sitecolor-text=\"\" class=\" d-bold\">&nbsp;</span> \n              </div> \n              <p class=\" c-body\"><span style=\"color:#666666;\"><span data-sitecolor-text=\"\" class=\" d-bold\">接客訓練について教えてください。</span></span></p> \n              <div class=\"c-none\">\n                &nbsp; \n              </div> \n              <p data-sitecolor-text=\"\" class=\" c-body\"><span style=\"color:#383838;\" data-sitecolor-text=\"\">２人：接客７大用語とか、なかなか覚えられなくて（笑）。もちろん最初はやっぱり緊張しましたし、休憩時間とか家に帰ってからも、メモみたり<span class=\" d-bold\">なんとか覚えようと必死でした</span>ね。</span></p> \n             </div> \n             <div class=\" column -column2 -column-lasts\"> \n              <div class=\" c-body c-center\"> \n               <div style=\"color:#383838;\"> \n                <div class=\"c-img   \"> \n                 <picture> \n                  <source type=\"image/webp\" srcset=\"../_src/2443/img20220119140732278311.webp?v=1769645477911\"> \n                  <img src=\"../_src/2443/img20220119140732278311.jpg?v=1769645477911\" width=\"4594\" height=\"3447\" alt=\"新人研修｜本部研修\" id=\"imgsrc2443_1\" loading=\"lazy\"> \n                 </picture> \n                </div> \n               </div> \n              </div> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk3247\" class=\"b-plain c-space_normal c-sp-space_normal is-sp-hide bd-webp -dress_93f5ddf232da4e5eabf8affc97d8ac99 cssskin-_block_main init-block_animation init-sp-block_animation\" data-bk-id=\"bk3247\" data-animated=\"fadeInUp\" data-sp-animated=\"fadeInUp\"> \n            <div class=\" g-column -col2 -sp-col1\"> \n             <div class=\" column -column1\"> \n              <p class=\" c-body\"> </p> \n              <div style=\"color:#383838;\"> \n               <div class=\"c-img   \"> \n                <picture> \n                 <source type=\"image/webp\" srcset=\"../_src/2446/img20220119141112574486.webp?v=1769645477911\"> \n                 <img src=\"../_src/2446/img20220119141112574486.jpg?v=1769645477911\" width=\"1919\" height=\"1440\" alt=\"新人研修｜本部研修\" id=\"imgsrc2446_1\" loading=\"lazy\"> \n                </picture> \n               </div> \n              </div> \n              <br> \n              <span style=\"color:#383838;\"></span> \n              <p></p> \n             </div> \n             <div class=\" column -column2 -column-lasts\"> \n              <h4 class=\" c-small_headline\"><span style=\"color:#383838;\">メンバーみんなとワイワイ出来て楽しかった</span></h4> \n              <div class=\"c-none c-left\">\n                &nbsp; \n              </div> \n              <p class=\" c-body\"><span style=\"color:#787878;\"><span data-sitecolor-text=\"\" class=\" d-bold\">サンプル作成やコトＰＯＰ研修はどうでしたか？</span></span></p> \n              <div class=\"c-none\">\n                &nbsp; \n              </div> \n              <p class=\" c-body\"><span style=\"color:#434343;\" data-sitecolor-text=\"\"><span class=\" d-bold\">吉田</span>：私はコトＰＯＰを書く係で、塩引鮭のＰＯＰを鮭の栄養素の”<span class=\" d-bold\">アスタキサンチン</span>”を題材に書きました。</span><br><span style=\"color:#434343;\">でも、役員の方から「〇〇に効く」など効用を謳う内容は避けるようにと言われたことは、今でも気を付けています。</span><br><br><span style=\"color:#434343;\"><span class=\" d-bold\">野崎</span>：私はサンプルを作る係りでしたが、<span class=\" d-bold\">メンバーみんなとワイワイできて楽しかった</span>ですね。</span></p> \n              <div class=\"c-none\">\n                &nbsp; \n              </div> \n              <div class=\" c-body c-center\"> \n               <span style=\"color:#434343;\"><a href=\"../career_plan.html\" data-pid=\"178\" class=\"carrier_plan\">新人社員研修の概要はこちら &gt;&gt;</a></span> \n              </div> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk3277\" class=\"b-plain c-space_normal c-sp-space_normal is-pc-hide bd-webp -dress_93f5ddf232da4e5eabf8affc97d8ac99 cssskin-_block_main init-block_animation init-sp-block_animation\" data-bk-id=\"bk3277\" data-animated=\"fadeInUp\" data-sp-animated=\"fadeInUp\"> \n            <div class=\" g-column -col2 -sp-col1\"> \n             <div class=\" column -column1\"> \n              <h4 class=\" c-small_headline\"><span style=\"color:#383838;\">自分が感じたことをメッセージ性を持たせて書く</span></h4> \n              <div class=\"c-none c-center\">\n                &nbsp; \n              </div> \n              <p class=\" c-body\"><span style=\"color:#787878;\"><span data-sitecolor-text=\"\" class=\" d-bold\">サンプル作成やコトＰＯＰ研修はどうでしたか？</span></span></p> \n              <div class=\"c-none\">\n                &nbsp; \n              </div> \n              <p class=\" c-body\"><span style=\"color:#434343;\"><span class=\" d-bold\">吉田</span>：私はコトＰＯＰを書く係で、塩引鮭のＰＯＰを鮭の栄養素の”<span class=\" d-bold\">アスタキサンチン</span>”を題材に書きました。</span><br><span style=\"color:#434343;\">でも、役員の方から「〇〇に効く」など効用を謳う内容は避けるようにと言われたことは、今でも気を付けています。</span><br><br><span style=\"color:#434343;\"><span class=\" d-bold\">野崎</span>：私はサンプルを作る係りでしたが、<span class=\" d-bold\">メンバーみんなとワイワイできて楽しかった</span>ですね。</span></p> \n             </div> \n             <div class=\" column -column2 -column-lasts\"> \n              <div class=\"c-none c-center\"> \n               <div class=\"c-img   \"> \n                <picture> \n                 <source type=\"image/webp\" srcset=\"../_src/2448/img20220119141112574486.webp?v=1769645477911\"> \n                 <img src=\"../_src/2448/img20220119141112574486.jpg?v=1769645477911\" width=\"1919\" height=\"1440\" alt=\"新人研修｜本部研修\" id=\"imgsrc2448_1\" loading=\"lazy\"> \n                </picture> \n               </div> \n              </div> \n              <div class=\"c-none\">\n                &nbsp; \n              </div> \n              <div class=\" c-body c-center\"> \n               <span style=\"color:#383838;\"><a href=\"../career_plan.html\" data-pid=\"178\" class=\"carrier_plan\">新人社員研修の概要はこちら &gt;&gt;</a></span> \n              </div> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk3232\" class=\"b-plain c-space_normal c-sp-space_normal c-sp-padding_normal bd-webp -dress_93f5ddf232da4e5eabf8affc97d8ac99 cssskin-_block_main init-block_animation init-sp-block_animation\" data-bk-id=\"bk3232\" data-animated=\"fadeInUp\" data-sp-animated=\"fadeInUp\"> \n            <div class=\" g-column -col2 -sp-col1\"> \n             <div class=\" column -column1\"> \n              <h4 class=\"none c-small_headline\"><span data-sitecolor-text=\"#383838\" class=\" d-bold\">部門実習について</span></h4> \n              <div class=\"c-none\">\n                &nbsp; \n              </div> \n              <p class=\" c-body\"><span style=\"color:#aaaaaa;\"><span data-sitecolor-text=\"\" class=\" d-bold\">（吉田さんは）希望の青果部でのスタートでしたが？</span></span><br>&nbsp;<br><span class=\" d-bold\">吉田</span>：最初は皆さんと話しずらくて不安でした。<br>でも雰囲気にも徐々に慣れ、パートさんとも気兼ねなく会話ができて、少しずつ楽しさも自分なりに感じられるようになりました。<br>特にコトＰＯＰを書いていると、扱っている商品の旬の移り変わりに敏感になり、<span class=\" d-bold\">パズルのようにはまっていく様子は青果部ならでは</span>かなと思います。</p> \n             </div> \n             <div class=\" column -column2 -column-lasts\"> \n              <div class=\" c-body\"> \n               <div class=\"c-img   \"> \n                <picture> \n                 <source type=\"image/webp\" srcset=\"../_src/2386/img20220119153841712038.webp?v=1769645477911\"> \n                 <img src=\"../_src/2386/img20220119153841712038.jpg?v=1769645477911\" width=\"1919\" height=\"1440\" alt=\"新人研修｜部門実習\" id=\"imgsrc2386_1\" loading=\"lazy\"> \n                </picture> \n               </div> \n              </div> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk3233\" class=\"b-plain c-space_normal c-sp-space_normal c-sp-padding_normal is-sp-hide bd-webp -dress_93f5ddf232da4e5eabf8affc97d8ac99 cssskin-_block_main init-block_animation init-sp-block_animation\" data-bk-id=\"bk3233\" data-animated=\"fadeInUp\" data-sp-animated=\"fadeInUp\"> \n            <div class=\" g-column -col2 -sp-col1\"> \n             <div class=\" column -column1\"> \n              <div class=\"c-none\"> \n               <div class=\" d-bold\"> \n                <div class=\"c-img   \"> \n                 <picture> \n                  <source type=\"image/webp\" srcset=\"../_src/2389/img20220119145814682716.webp?v=1769645477911\"> \n                  <img src=\"../_src/2389/img20220119145814682716.jpg?v=1769645477911\" width=\"1919\" height=\"1440\" alt=\"新人研修｜部門実習\" id=\"imgsrc2389_1\" loading=\"lazy\"> \n                 </picture> \n                </div> \n               </div> \n              </div> \n             </div> \n             <div class=\" column -column2 -column-lasts\"> \n              <h4 class=\" c-small_headline\"><span style=\"color:#aaaaaa;\" data-sitecolor-text=\"\">チーフに言われて、<span class=\" d-bold\">ちょっと悔しさもありました</span>。</span></h4> \n              <div class=\"c-none\">\n                &nbsp; \n              </div> \n              <p class=\" c-body\"><span style=\"color:#aaaaaa;\"><span data-sitecolor-text=\"\" class=\" d-bold\">実習でまず苦戦したのはどんな点ですか？</span></span></p> \n              <div class=\"c-none\">\n                &nbsp; \n              </div> \n              <p class=\" c-body\"><span class=\" d-bold\">吉田</span>：品出しのスピードの遅さですね。<br>自分では頑張っているつもりでも、チーフに言われて、<span class=\" d-bold\">ちょっと悔しさもありました</span>。<br>そこで、他の人の手の動きや作業の進め方を見たり、自分でも最初から２倍速くらい目指すと雑になるので、１．２倍くらいというか、徐々に早くといった意識を持つようにしました。</p> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk3273\" class=\"b-plain c-space_normal c-sp-space_normal c-sp-padding_normal is-pc-hide bd-webp -dress_93f5ddf232da4e5eabf8affc97d8ac99 cssskin-_block_main init-block_animation init-sp-block_animation\" data-bk-id=\"bk3273\" data-animated=\"fadeInUp\" data-sp-animated=\"fadeInUp\"> \n            <div class=\" g-column -col2 -sp-col1\"> \n             <div class=\" column -column1\"> \n              <h4 class=\" c-small_headline\">チーフに言われて、<span class=\" d-bold\">ちょっと悔しさもありました</span>。</h4> \n              <p class=\" c-body\">&nbsp;<br><span style=\"color:#aaaaaa;\"><span data-sitecolor-text=\"\" class=\" d-bold\">実習でまず苦戦したのはどんな点ですか？</span></span><br>&nbsp;<br><span class=\" d-bold\">吉田</span>：品出しのスピードの遅さですね。<br>自分では頑張っているつもりでも、チーフに言われて、<span class=\" d-bold\">ちょっと悔しさもありました</span>。<br>そこで、他の人の手の動きや作業の進め方を見たり、自分でも最初から２倍速くらい目指すと雑になるので、１．２倍くらいというか、徐々に早くといった意識を持つようにしました。</p> \n             </div> \n             <div class=\" column -column2 -column-lasts\"> \n              <div class=\" c-body\"> \n               <div class=\"c-img   \"> \n                <picture> \n                 <source type=\"image/webp\" srcset=\"../_src/2452/img20220119145814682716.webp?v=1769645477911\"> \n                 <img src=\"../_src/2452/img20220119145814682716.jpg?v=1769645477911\" width=\"1919\" height=\"1440\" alt=\"新人研修｜部門実習\" id=\"imgsrc2452_1\" loading=\"lazy\"> \n                </picture> \n               </div> \n              </div> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk3248\" class=\"b-plain c-space_normal c-sp-space_normal c-sp-padding_normal bd-webp -dress_93f5ddf232da4e5eabf8affc97d8ac99 cssskin-_block_main init-block_animation init-sp-block_animation\" data-bk-id=\"bk3248\" data-animated=\"fadeInUp\" data-sp-animated=\"fadeInUp\"> \n            <div class=\" g-column -col2 -sp-col1\"> \n             <div class=\" column -column1\"> \n              <h4 class=\" c-small_headline\">自分が使える知識も学べました</h4> \n              <div class=\"c-none\">\n                &nbsp; \n              </div> \n              <p class=\" c-body\"><span style=\"color:#aaaaaa;\"><span data-sitecolor-text=\"\" class=\" d-bold\">野﨑さんも、まずは青果部スタートでしたが・・。</span></span><br>&nbsp;<br><span class=\" d-bold\">野﨑</span>：経験もあってＣＨ（チェッカー部）を希望していましたが、まずは商品を扱う生鮮をやってみようということで、青果スタートでした。約２か月ほどでしたが、今は良かったと思っています。<br><span class=\" d-bold\">野菜の傷みや鮮度の見極めなど、自分が使える知識も学べました</span>し、何よりメンバーの皆さんが明るい方ばかりだったので。<br>その後、希望のＣＨ部へ実習部門が変更になったのですが、その時は寂しさのほうが強かったですね。</p> \n             </div> \n             <div class=\" column -column2 -column-lasts\"> \n              <div class=\" c-body\"> \n               <div class=\"c-img   \"> \n                <picture> \n                 <source type=\"image/webp\" srcset=\"../_src/2393/img20220119144817796615.webp?v=1769645477911\"> \n                 <img src=\"../_src/2393/img20220119144817796615.jpg?v=1769645477911\" width=\"5149\" height=\"3864\" alt=\"新人研修｜部門実習\" id=\"imgsrc2393_1\" loading=\"lazy\"> \n                </picture> \n               </div> \n              </div> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk3249\" class=\"b-plain c-space_normal c-sp-space_normal c-sp-padding_normal is-sp-hide bd-webp -dress_93f5ddf232da4e5eabf8affc97d8ac99 cssskin-_block_main init-block_animation init-sp-block_animation\" data-bk-id=\"bk3249\" data-animated=\"fadeInUp\" data-sp-animated=\"fadeInUp\"> \n            <div class=\" g-column -col2 -sp-col1\"> \n             <div class=\" column -column1\"> \n              <div class=\"c-none\"> \n               <div class=\" d-bold\"> \n                <div class=\"c-img   \"> \n                 <picture> \n                  <source type=\"image/webp\" srcset=\"../_src/2396/img20220119154039271092.webp?v=1769645477911\"> \n                  <img src=\"../_src/2396/img20220119154039271092.jpg?v=1769645477911\" width=\"1919\" height=\"1440\" alt=\"新人研修｜部門実習\" id=\"imgsrc2396_1\" loading=\"lazy\"> \n                 </picture> \n                </div> \n               </div> \n              </div> \n             </div> \n             <div class=\" column -column2 -column-lasts\"> \n              <h4 class=\" c-small_headline\">しっかり覚えて臨むようにしています。</h4> \n              <div class=\"c-none\">\n                &nbsp; \n              </div> \n              <p class=\" c-body\"><span style=\"color:#aaaaaa;\"><span data-sitecolor-text=\"\" class=\" d-bold\">ＣＨの仕事に替わってどうですか?</span></span><br>&nbsp;<br><span class=\" d-bold\">野﨑</span>：レジ操作は、経験を活かせて順調かなと自分でも思います。<br>ただ、これからサービスカウンターにチーフの代わりに入る日も増えるので、不安は正直あります。それと、<span class=\" d-bold\">朝礼でのあいさつ訓練のリード役もしています</span>。<br>毎月、若干ですが内容が変更するので、メンバー全員の前に出て、つっかえることがないように、<span class=\" d-bold\">しっかり覚えて臨むようにしています</span>。</p> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk3274\" class=\"b-plain c-space_normal c-sp-space_normal c-sp-padding_normal is-pc-hide bd-webp -dress_93f5ddf232da4e5eabf8affc97d8ac99 cssskin-_block_main init-block_animation init-sp-block_animation\" data-bk-id=\"bk3274\" data-animated=\"fadeInUp\" data-sp-animated=\"fadeInUp\"> \n            <div class=\" g-column -col2 -sp-col1\"> \n             <div class=\" column -column1\"> \n              <h4 class=\" c-small_headline\">しっかり覚えて臨むようにしています。</h4> \n              <div class=\"c-none\">\n                &nbsp; \n              </div> \n              <p class=\" c-body\"><span style=\"color:#aaaaaa;\"><span data-sitecolor-text=\"\" class=\" d-bold\">ＣＨの仕事に替わってどうですか?</span></span></p> \n              <div class=\"c-none\">\n                &nbsp; \n              </div> \n              <p class=\" c-body\"><span class=\" d-bold\">野﨑</span>：レジ操作は、経験を活かせて順調かなと自分でも思います。<br>ただ、これからサービスカウンターにチーフの代わりに入る日も増えるので、不安は正直あります。それと、<span class=\" d-bold\">朝礼でのあいさつ訓練のリード役もしています</span>。<br>毎月、若干ですが内容が変更するので、メンバー全員の前に出て、つっかえることがないように、<span class=\" d-bold\">しっかり覚えて臨むようにしています</span>。</p> \n             </div> \n             <div class=\" column -column2 -column-lasts\"> \n              <div class=\" c-body\"> \n               <div class=\"c-img   \"> \n                <picture> \n                 <source type=\"image/webp\" srcset=\"../_src/2450/img20220119154039271092.webp?v=1769645477911\"> \n                 <img src=\"../_src/2450/img20220119154039271092.jpg?v=1769645477911\" width=\"1919\" height=\"1440\" alt=\"新人研修｜部門実習\" id=\"imgsrc2450_1\" loading=\"lazy\"> \n                </picture> \n               </div> \n              </div> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk3250\" class=\"b-plain c-space_normal c-sp-space_normal bd-webp -dress_93f5ddf232da4e5eabf8affc97d8ac99 cssskin-_block_main init-block_animation init-sp-block_animation\" data-bk-id=\"bk3250\" data-animated=\"fadeInUp\" data-sp-animated=\"fadeInUp\"> \n            <div class=\" column -column1\"> \n             <h4 class=\" c-small_headline\">すべてにおいて違うんじゃないかなと思います。</h4> \n             <p class=\" c-body\">&nbsp;<br><span style=\"color:#aaaaaa;\"><span data-sitecolor-text=\"\" class=\" d-bold\">４月の自分と現在の自分はどんな点が違うと思いますか？</span></span><br>&nbsp;<br><span class=\" d-bold\">吉田</span>：すべてにおいて違うんじゃないかなと思います。<br>接客も、もちろん青果部での仕事内容も。<br>　　　　<br><span class=\" d-bold\">野﨑</span>：接客面では、様々なケースでの対応で自信がついてきたと思います。<br>でも一番の違いは、声がしっかり出るようになったことですね。<br>&nbsp;<br>&nbsp;<br><span style=\"color:#aaaaaa;\"><span data-sitecolor-text=\"\" class=\" d-bold\">&nbsp;今後の抱負を聞かせてください。</span></span><br>&nbsp;<br><span class=\" d-bold\">吉田</span>：まずは、今の店舗でチーフがお休みのときに、自分１人でしっかり仕事をまわせるようにしたいです。そしていつかは、<span class=\" d-bold\">大型店舗の青果チーフを目指して頑張りたい</span>ですね。<br>&nbsp;<br><span class=\" d-bold\">野﨑</span>：まだまだＣＨは奥が深くて、覚えることはたくさんあります。まずはそのマスターと<span class=\" d-bold\">お客様にしっかり信頼されるＣＨに</span>なりたいですね。</p> \n            </div> \n           </div> \n           <div id=\"bk3234\" class=\"b-plain c-space_normal c-sp-space_normal cssskin-_block_main init-block_animation init-sp-block_animation\" data-bk-id=\"bk3234\" data-animated=\"fadeIn\" data-sp-animated=\"fadeIn\"> \n            <div class=\" column -column1\"> \n             <div class=\" c-body c-center\"> \n              <span class=\" d-larger_font\"><a href=\"../colleague/new_employees.html\" data-pid=\"190\" class=\"message\">新人同期にインタビュー</a></span> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk3235\" class=\"b-plain c-space_normal c-sp-space_normal c-sp-padding_init is-sp-hide cssskin-_block_main\" data-bk-id=\"bk3235\" data-shared=\"true\" data-sharedname=\"fwave1\"> \n            <div class=\" column -column1\"> \n             <div class=\" c-body c-center\"> \n              <div class=\"c-img   \"> \n               <picture> \n                <source type=\"image/webp\" srcset=\"../_src/2228/wave_20220112143151277.webp?v=1769645477911\"> \n                <img src=\"../_src/2228/wave_20220112143151277.png?v=1769645477911\" width=\"1920\" height=\"76\" alt=\"マルイ_リクルート求人\" id=\"imgsrc2228_1\" class=\" c-no_adjust\" loading=\"lazy\"> \n               </picture> \n              </div> \n             </div> \n            </div> \n           </div> \n           <div id=\"bk3236\" class=\"b-plain c-space_normal c-sp-space_normal c-sp-padding_init is-pc-hide cssskin-_block_main\" data-bk-id=\"bk3236\" data-shared=\"true\" data-sharedname=\"fwave2\"> \n            <div class=\" column -column1\"> \n             <div class=\" c-body c-center\"> \n              <div class=\"c-img   \"> \n               <picture> \n                <source type=\"image/webp\" srcset=\"../_src/2235/wave800.webp?v=1769645477911\"> \n                <img src=\"../_src/2235/wave800.png?v=1769645477911\" width=\"800\" height=\"102\" alt=\"マルイ_リクルート求人\" id=\"imgsrc2235_1\" class=\" c-no_adjust\" loading=\"lazy\"> \n               </picture> \n              </div> \n             </div> \n            </div> \n           </div> \n          </section> \n         </div> \n        </div> \n       </div> \n      </article> \n     </div> \n    </main> \n    <div id=\"a-footer\" data-float=\"false\" class=\"a-footer   cssskin-_area_footer\"> \n     <footer> \n      <div class=\"site_frame\"> \n       <div id=\"bk3239\" class=\"b-both_diff -left_large -sp-single_column c-space_normal c-sp-space_normal cssskin-_block_footer\" data-bk-id=\"bk3239\" data-shared=\"true\" data-sharedname=\"_フッタメニュー\"> \n        <div class=\" g-column\"> \n        