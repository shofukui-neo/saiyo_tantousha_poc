{"url":"https://kankyou-seibi.co.jp/recruit/application/","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n<head>\n<meta charset=\"UTF-8\">\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<meta name=\"format-detection\" content=\"email=no,telephone=no,address=no\">\n<title>募集要項｜博多湾環境整備株式会社 採用サイト｜港湾工事・浚渫工事・河川維持・海上清掃</title>\n\n<meta name=\"keywords\" content=\"\">\n<meta name=\"description\" content=\"博多湾環境整備では博多港長期構想の実現へ向け、港湾工事、浚渫工事、河川維持工事や海上清掃などインフラを整備する事業のほか、インバウンドやMICEに関わる事業として福岡市海浜公園の指定管理者や福岡国際センターの維持管理を行っています。また、アオサの回収や水質改善など、環境を守り育てる事業にも力を入れています。\">\n\n<link rel=\"icon\" href=\"../assets/img/common/favicon.png\">\n<link rel=\"stylesheet\" href=\"../assets/css/base.css\" rel=\"preload\" as=\"style\">\n<link rel=\"stylesheet\" href=\"../assets/css/style.css?20240531\" rel=\"preload\" as=\"style\">\n\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick.css\" rel=\"preload\" as=\"style\">\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick-theme.css\" rel=\"preload\" as=\"style\">\n<link rel=\"stylesheet\" href=\"https://use.fontawesome.com/releases/v5.6.1/css/all.css\" rel=\"preload\" as=\"style\">\n\n<!-- Global site tag (gtag.js) - Google Analytics -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=UA-171510190-1\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'UA-171510190-1');\n</script>\n</head>\n<body id=\"application\" class=\"lower\">\n\n<header id=\"header\">\n\t<div class=\"inner\">\n\t\t<h1 class=\"logo\">\n\t\t\t<a href=\"../\">\n\t\t\t\t<img src=\"..//assets/img/common/logo.svg\" width=\"320\" height=\"38\" alt=\"博多湾環境整備株式会社\">\n\t\t\t\t<span>採用サイト</span>\n\t\t\t</a>\n\t\t</h1>\n\t\t<div class=\"burger-menu\">\n\t\t\t<nav class=\"gnav\">\n\t\t\t\t<ul>\n\t\t\t\t\t<li><a href=\"../data/\"><span class=\"en\">VARIOUS OUR DATA</span><span class=\"jp\">データで見る博多湾環境整備</span></a></li>\n                    <li><a href=\"../flow/\"><span class=\"en\">DESCRIPTION & CARRIER</span><span class=\"jp\">仕事内容とキャリアイメージ</span></a></li>\n                    <li><a href=\"../intern/\"><span class=\"en\">INTERNSHIP</span><span class=\"jp\">インターンシップ</span></a></li>\n\t\t\t\t\t<li><a href=\"../application/\"><span class=\"en\">APPLICATION GUIDELINES</span><span class=\"jp\">募集要項</span></a></li>\n\t\t\t\t\t<li><a href=\"../entry/\"><span class=\"en\">ENTRY</span><span class=\"jp\">エントリー</span></a></li>\n\t\t\t\t</ul>\n\t\t\t</nav>\n\t\t</div>\n\t\t<div class=\"burger\"><span></span><span></span><span></span></div>\n\t</div>\n</header>\n\n<div id=\"pagetop\"></div>\n\n<div id=\"pagehead\">\n    <div class=\"inner\">\n    \t<h2><span class=\"en\">APPLICATION GUIDELINES</span><span class=\"jp\">募集要項</span></h2>\n        <nav class=\"breadcrumb\">\n        \t<ul itemscope=\"\" itemtype=\"http://schema.org/BreadcrumbList\">\n        \t\t<li itemprop=\"itemListElement\" itemscope=\"\" itemtype=\"http://schema.org/ListItem\">\n        \t\t\t<a itemprop=\"item\" href=\"../\"><span itemprop=\"name\">トップ</span></a>\n        \t\t\t<meta itemprop=\"position\" content=\"1\">\n        \t\t</li>\n        \t\t<li itemprop=\"itemListElement\" itemscope=\"\" itemtype=\"http://schema.org/ListItem\">\n        \t\t\t<span itemprop=\"name\">募集要項</span>\n        \t\t\t<meta itemprop=\"position\" content=\"2\">\n        \t\t</li>\n        \t</ul>\n        </nav>\n    </div>\n</div>\n\n<main id=\"main\">\n\t<article>\n\n\t\t<section class=\"sec01\">\n\t\t\t<div class=\"inner\">\n                <dl>\n                    <dt>\n                        <h3>\n                            <span class=\"label\">募集職種</span>\n                            <span class=\"name\">技術職</span>\n                            <span class=\"min\">（土木工事の施工管理等）</span>\n                        </h3>\n                    </dt>\n                    <dd>\n                        <h4>新卒採用</h4>\n                        <dl>\n                            <dt>仕事内容</dt>\n                            <dd>\n                            \t土木工事の施工管理、設計、積算等<br>\n                            \t※仕事内容は配属部署により異なりますので全てを対応することはございません。\n                            </dd>\n                            <dt>勤務地</dt>\n                            <dd>福岡県（福岡市内中心）</dd>\n                            <dt>雇用形態</dt>\n                            <dd>正社員</dd>\n                            <dt>試用期間</dt>\n                            <dd>有り（3ヶ月）</dd>\n                            <dt>勤務時間</dt>\n                            <dd>\n                                8：00～17：00<br>\n                                ※フレックス制度あり\n                            </dd>\n                            <dt>休日・休暇</dt>\n                            <dd>\n                                土日祝日　年末年始・夏季休暇　年次有給休暇<br>\n                                出産・育児・介護休暇、慶弔休暇、リフレッシュ休暇<br>\n                                年間休日125日\n                            </dd>\n                            <dt>待遇・福利厚生</dt>\n                            <dd>\n                                初任給201,000円（他諸手当有り）<br>\n                                賞与/年2回（前年度実績6カ月以上）<br>\n                                通勤手当25,000円迄<br>\n                                1人暮らし補助（37,000円～40,000円）\n                            </dd>\n                            <dt>試験内容</dt>\n                            <dd>\n                               <!-- • 筆記（一般常識）<br>-->\n\t\t\t\t\t\t\t\t• 書類選考<br>\n                                • 面接\n                            </dd>\n                            <dt>備考</dt>\n                            <dd>\n                            \t現場見学やインターンシップも可能です。<br>エントリーフォームよりお気軽にお申し込みください。\n                            </dd>\n                        </dl>\n                        <a href=\"../entry/\" class=\"btn01\"><span>エントリーする</span></a>\n                    </dd>\n                    <dd>\n                        <h4>中途採用</h4>\n                        <dl>\n                            <dt>仕事内容</dt>\n                            <dd>\n                            \t土木工事の施工管理、設計、積算等<br>\n                            \t※仕事内容は配属部署により異なりますので全てを対応することはございません。\n                        \t</dd>\n                            <dt>勤務地</dt>\n                            <dd>福岡県（福岡市内中心）</dd>\n                            <dt>雇用形態</dt>\n                            <dd>正社員</dd>\n                            <dt>試用期間</dt>\n                            <dd>有り（3ヶ月）</dd>\n                            <dt>勤務時間</dt>\n                            <dd>\n                                8：00～17：00<br>\n                                ※フレックス制度あり\n                            </dd>\n                            <dt>休日・休暇</dt>\n                            <dd>\n                                土日祝日　年末年始・夏季休暇　年次有給休暇<br>\n                                出産・育児・介護休暇、慶弔休暇、リフレッシュ休暇<br>\n                                年間休日125日\n                            </dd>\n                            <dt>待遇・福利厚生</dt>\n                            <dd>\n                            \t給与286,800円（若手）～335,800円（中堅）（他諸手当有り）<br>\n\t\t\t\t\t\t\t\t※上記には20時間分の固定残業代が含まれており、20時間を超える時間外労働は追加で支給。<br><br>\n                                賞与/年2回（前年度実績6カ月以上）<br>\n                                通勤手当25,000円迄<br>\n                                1人暮らし補助（37,000円～40,000円）（40歳以下）<br><br>\n                                \n                                ※待遇に関しては、資格・経験等を考慮して判断致します。\n                            </dd>\n                            <dt>試験内容</dt>\n                            <dd>\n                               <!-- • 筆記（一般常識）<br>-->\n\t\t\t\t\t\t\t\t• 書類選考<br>\n                                • 面接\n                            </dd>\n                            <dt>備考</dt>\n                            <dd>\n                            \t詳細はハローワーク求人をご覧ください。<br>\n                            \t現場見学も可能です。エントリーフォームよりお気軽にお申し込みください。\n                            </dd>\n                        </dl>\n                        <a href=\"../entry/\" class=\"btn01\"><span>エントリーする</span></a>\n                    </dd>\n                    <!--<dd>\n                        <h4>シニア<span>（60歳以上）</span></h4>\n                        <dl>\n                            <dt>仕事内容</dt>\n                            <dd>土木工事の施工管理、設計、積算等</dd>\n                            <dt>勤務地</dt>\n                            <dd>福岡県（福岡市内中心）</dd>\n                            <dt>雇用形態</dt>\n                            <dd>正社員</dd>\n                            <dt>試用期間</dt>\n                            <dd>有り（3ヶ月）</dd>\n                            <dt>勤務時間</dt>\n                            <dd>\n                                7：30～17；00　8：00～17：30<br>\n                                ※フレックス制度あり\n                            </dd>\n                            <dt>休日・休暇</dt>\n                            <dd>\n                                土日祝日　夏期・年末年始休暇<br>\n                                リフレッシュ休暇、有給休暇<br>\n                                年間休日125日\n                            </dd>\n                            <dt>待遇・福利厚生</dt>\n                            <dd>\n                                初任給196,000円（他諸手当有り）<br>\n                                賞与/年2回（前年度実績6カ月以上）<br>\n                                通勤手当25,000円迄<br>\n                                1人暮らし補助（37,000円～40,000円）\n                            </dd>\n                            <dt>試験内容</dt>\n                            <dd>\n                                • 筆記（一般常識）<br>\n                                • 面接\n                            </dd>\n                        </dl>\n                        <a href=\"../entry/\" class=\"btn01\"><span>エントリーする</span></a>\n                    </dd>-->\n                </dl>\n\t\t\t</div>\n\t\t</section>\n\n\t</article>\n</main>\n\n\n<footer id=\"footer\">\n\t<div class=\"inner\">\n     