{"url":"https://www.jfe-et.co.jp/recruit/","html":"<!DOCTYPE html>\r\n<html lang=\"ja\">\r\n  <head>\r\n    <title>採用情報 | JFE環境テクノロジー株式会社</title>\r\n    <meta charset=\"utf-8\">\r\n    <meta http-equiv=\"X-UA-Compatible\" content=\"IE=Edge\">\r\n    <meta name=\"format-detection\" content=\"telephone=no\">\r\n    <meta name=\"viewport\" content=\"width=device-width, user-scalable=1, initial-scale=1, viewport-fit=cover\">\r\n    <meta name=\"keywords\" content=\"this is meta keywords\">\r\n    <meta name=\"description\" content=\"私たちは、環境を通じた壮大なフィールドで、共に果敢に挑戦する仲間を求めています\">\r\n    <meta property=\"og:title\" content=\"採用情報│JFE環境テクノロジー株式会社\">\r\n    <meta property=\"og:type\" content=\"website\">\r\n    <meta property=\"og:description\" content=\"私たちは、環境を通じた壮大なフィールドで、共に果敢に挑戦する仲間を求めています\">\r\n    <meta property=\"og:url\" content=\"\">\r\n    <meta property=\"og:image\" content=\"https://jfe-et.co.jp/_assets/images/_etc/ogp.png\">\r\n    <meta property=\"fb:app_id\" content=\"XXXXXXXXXXXXXXXX\">\r\n    <meta name=\"twitter:card\" content=\"summary\">\r\n    <meta name=\"twitter:site\" content=\"@XXXXX\">\r\n    <meta name=\"twitter:creator\" content=\"@XXXXX\">\r\n    <meta name=\"twitter:image:src\" content=\"https://jfe-et.co.jp/_assets/images/_etc/ogp.png\">\r\n    <link rel=\"icon\" type=\"image/x-icon\" href=\"../_assets/images/_etc/favicon.ico\">\r\n    <link rel=\"icon\" type=\"image/png\" href=\"../_assets/images/_etc/favicon.png\">\r\n    <link rel=\"apple-touch-icon\" type=\"image/png\" href=\"../_assets/images/_etc/custom-icon.png\">\r\n    <!-- Google Tag Manager -->\r\n    <script>\r\n      (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\r\n      new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\r\n      j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\r\n      'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\r\n      })(window,document,'script','dataLayer','GTM-WR73CMD');\r\n    </script>\r\n    <!-- End Google Tag Manager -->\r\n    \r\n    <!-- Styles-->\r\n    <link rel=\"stylesheet\" media=\"print,screen\" href=\"https://cdnjs.cloudflare.com/ajax/libs/jqueryui/1.12.1/themes/base/jquery-ui.min.css\">\r\n    <link rel=\"stylesheet\" media=\"print,screen\" href=\"https://cdnjs.cloudflare.com/ajax/libs/Swiper/5.4.3/css/swiper.min.css\">\r\n    <link href=\"https://unpkg.com/aos@2.3.1/dist/aos.css\" rel=\"stylesheet\">\r\n    <link rel=\"stylesheet\" media=\"print,screen\" href=\"../_assets/css/style.css\">\r\n  </head>\r\n<style>\r\n.annotation1 {\r\n\tfont-size: 0.7em;\r\n}\r\n</style>\r\n  <body class=\"recruitPage\" id=\"recruit\">\r\n    \r\n    <!-- Google Tag Manager (noscript) -->\r\n    <noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-WR73CMD\" height=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\r\n    <!-- End Google Tag Manager (noscript) -->\r\n    <header class=\"siteHeader\">\r\n      <div class=\"siteHeader__inner\">\r\n        <div class=\"siteHeader__logoBox\"><a class=\"siteHeader__logoLink\" href=\"../\"> <img class=\"siteHeader__logo u-pcDb\" src=\"../_assets/images/common/header_logo-pc.png\" alt=\"JFE環境テクノロジー株式会社\"><img class=\"siteHeader__logo u-spDb\" src=\"../_assets/images/common/header_logo-sp.png\" alt=\"JFE環境テクノロジー株式会社\"></a></div>\r\n        <nav class=\"siteHeader__nav\" role=\"navigation\">\r\n          <ul class=\"siteHeader__list\"> \r\n            <li class=\"siteHeader__listItem\"> <a class=\"siteHeader__listItemLink\" href=\"../\">ホーム</a></li>\r\n            <li class=\"siteHeader__listItem\"><a class=\"siteHeader__listItemLink\" href=\"../business/\">事業紹介</a></li>\r\n            <li class=\"siteHeader__listItem\"> <a class=\"siteHeader__listItemLink\" href=\"../company/\">会社情報</a>\r\n              <ul class=\"siteHeader__listContentMenu js-content\">\r\n                <li class=\"siteHeader__listContentMenuItem\"><a class=\"siteHeader_