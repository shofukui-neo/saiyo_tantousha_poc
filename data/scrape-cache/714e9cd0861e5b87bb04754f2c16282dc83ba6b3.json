eadNavMain\">\r\n                    <li class=\"\"><a href=\"/recruit/\"><span class=\"NavPc\"><img src=\"/recruit/assets/images/header/nav_top.svg\" alt=\"TOP トップページ\" width=\"66\" height=\"35\"></span><span class=\"NavSp\"><img src=\"/recruit/assets/images/header/nav_top_sp.svg\" alt=\"TOP\" width=\"52\" height=\"18\"><span>トップページ</span></span></a></li>\r\n                    <li class=\"HeadNavActive\"><div>\r\n                        <span class=\"NavPc\"><img src=\"/recruit/assets/images/header/nav_com.svg\" alt=\"Company 太陽を知る\" width=\"88\" height=\"35\"></span><span class=\"NavSp\"><img src=\"/recruit/assets/images/header/nav_com_sp.svg\" alt=\"Company\" width=\"94\" height=\"18\"><span>太陽を知る</span></span>\r\n                        <ul class=\"HeadNavDown\">\r\n                            <li><a href=\"/recruit/company/message.html\">トップメッセージ</a></li>\r\n                            <li><a href=\"/recruit/company/future.html\">太陽で輝く仕事と未来</a></li>\r\n                            <li><a href=\"/recruit/company/allabout.html\">ひと目でわかる太陽</a></li>\r\n                            <li><a href=\"/recruit/company/viewing.html\">TAIYO VIEWING 〜社内風景〜</a></li>\r\n                        </ul>\r\n                    </div></li>\r\n                    <li class=\"\"><div>\r\n                        <span class=\"NavPc\"><img src=\"/recruit/assets/images/header/nav_work.svg\" alt=\"Work Style 社員・仕事を知る\" width=\"107\" height=\"35\"></span><span class=\"NavSp\"><img src=\"/recruit/assets/images/header/nav_work_sp.svg\" alt=\"Work Style\" width=\"111\" height=\"18\"><span>社員・仕事を知る</span></span>\r\n                        <ul class=\"HeadNavDown\">\r\n                            <li><a href=\"/recruit/workstyle/philosophy.html\">社員の幸せのためにできること</a></li>\r\n                            <li><a href=\"/recruit/workstyle/profession.html\">太陽で働こう -職種紹介-</a></li>\r\n                            <li><a href=\"/recruit/workstyle/interview.html\">社員インタビュー</a></li>\r\n                            <li><a href=\"/recruit/workstyle/career.html\">キャリアステップ</a></li>\r\n                            <li><a href=\"/recruit/workstyle/female.html\">女性社員が輝く職場</a></li>\r\n                        </ul>\r\n                    </div></li>\r\n                    <li class=\"\"><div>\r\n                        <span class=\"NavPc\"><img src=\"/recruit/assets/images/header/nav_rec.svg\" alt=\"Recruitment 採用情報を知る\" width=\"118\" height=\"35\"></span><span class=\"NavSp\"><img src=\"/recruit/assets/images/header/nav_rec_sp.svg\" alt=\"Recruitment\" width=\"150\" height=\"18\"><span>採用情報を知る</span></span>\r\n                        <ul class=\"HeadNavDown\">\r\n                            <li><a href=\"/recruit/recruitment/flow.html\">応募要項・選考フロー</a></li>\r\n                            <li><a href=\"/recruit/recruitment/faq.html\">採用Q&A</a></li>\r\n                        </ul>\r\n                    </div></li>\r\n                    <li class=\"HeadForm\"><a href=\"https://www.renewal-taiyo.co.jp/form/recruit/\">採用応募フォームはこちら</a></li>\r\n                </ul>\r\n            </nav>\r\n        </div>\r\n    </header>\r\n</div>\r\n<aside class=\"BreadCrumb\">\r\n    <ul>\r\n        <li><a href=\"/recruit/\"><img src=\"/recruit/assets/images/header/pan_icon_home.svg\" alt=\"TOP\" width=\"15\" height=\"14\"></a></li>\r\n        <li><span>&rsaquo;</span>太陽を知る</li>\r\n        <li><span>&rsaquo;</span>トップメッセージ</li>\r\n            </ul>\r\n</aside>\r\n\r\n\r\n<!-- Contents -->\r\n<article class=\"Container\">\r\n\t<div class=\"CommonTitleMove\">\r\n\t\t<span></span>\r\n\t\t<span></span>\r\n\t\t<span></span>\r\n\t\t<span class=\"CommonMoveTitle\"></span>\r\n\t</div>\r\n\t<h1>\r\n\t\t<img src=\"/recruit/assets/images/company/message/title.svg\" alt=\"トップメッセージ TOP MESSAGE\" width=\"394\" height=\"86\">\r\n\t</h1>\r\n    <section class=\"MessageBody\">\r\n        <div class=\"MessageTitle\">\r\n            <div class=\"MessageTitleBody\">\r\n                <img src=\"/recruit/assets/images/company/message/title_photo.jpg\" alt=\"阿部 佳介：写真\" width=\"1240\" height=\"540\" class=\"MessageTitlePc\">\r\n                <img src=\"/recruit/assets/images/company/message/title_photo_sp.jpg\" alt=\"阿部 佳介：写真\" class=\"MessageTitleSp\">\r\n                <div class=\"MessageTitleCopy\">\r\n                    <h2>今の常識を疑い、<br>未来の常識をつくっていく。</h2>\r\n                    <p>\r\n                        <span>株式会社 太陽／代表取締役社長</span>\r\n                        <span>阿部 佳介</span>\r\n                        <span>Keisuke Abe</span>\r\n                    </p>\r\n                </div>\r\n            </div>\r\n        </div>\r\n        <section class=\"MessageParagraph1\">\r\n            <h3>新しい道を切り開き、<br>中小企業の光に。</h3>\r\n            <p>\r\n                私たち太陽は世の中に役立つ事業しか行いません。<br>どんなに困難なことであっても、今起きている社会問題に本気で向き合い、<br>事業を通じて解決することで社会に貢献していきます。<br>ゼロからつくることもなく、壊すこともなく、<br>現存する技術や今あるものに新しい価値を加えることで、<br>再び輝きをもたらすことが太陽の使命です。<br>大規模修繕工事業、TAIYO SHEET事業、職人育成事業、<br>この3つの再生事業を柱にこれからも新しい道を切り開き、<br>中小企業の未来をつくっていきます。\r\n            </p>\r\n        </section>\r\n        <section class=\"MessageParagraph MessageParagraph2\">\r\n            <div class=\"MessageParagraphBody\">\r\n                <div>\r\n                    <img src=\"/recruit/assets/images/company/message/paragraph_2_ph.jpg\" alt=\"阿部 佳介：写真\" width=\"590\" height=\"340\" class=\"MoveIn\">\r\n                    <h3>3つの再生事業すべてが、<br>世の中に役立ち、成長を遂げている。</h3>\r\n                    <p>太陽の事業の要である大規模修繕工事は、老朽化した建物の資産価値を向上させる事業です。職人育成事業は、多能工職人を短期間で育成し、失われつつある職人技術を伝承します。いずれも建物の長寿命化を永続的に実現するためには必要不可欠な事業です。そして今新たに力を入れているのが、価値ある原料を再発掘し、日本の高い技術で新たな製品を開発するTAIYO SHEET事業です。発熱効果のあるTAIYO SHEETは、高速道路の融雪対策や農園の温度調整などとして幅広く使用されています。ゼロからつくるのではなく潜在的ニーズを探し、使い方や創り方を変えることで、私たちのような中小企業でも世界に通用する建材メーカーになれると考えています。</p>\r\n                </div>\r\n            </div>\r\n        </section>\r\n        <div class=\"MessageBreak1\">\r\n            <div>\r\n                <video playsinline muted autoplay loop poster=\"/recruit/assets/images/company/message/break_poster.png\">\r\n                    <source src=\"/recruit/assets/images/company/message/break_1.mp4\" type=\"video/mp4\">\r\n                </video>\r\n            </div>\r\n        </div>\r\n        <section class=\"MessageParagraph MessageParagraph3\">\r\n            <div class=\"MessageParagraphBody\">\r\n                <div>\r\n                    <img src=\"/recruit/assets/images/company/message/paragraph_3_ph.jpg\" alt=\"阿部 佳介：写真\" width=\"590\" height=\"340\" class=\"MoveIn\">\r\n                    <h3>未来の当たり前に挑み続け、<br>社員を最も幸せにする。</h3>\r\n                    <p>太陽は日本一社員のことを大切に考える企業です。私は人に大きな能力の差はなく、差がつくとしたら、誠実さや継続する気持ち、挑戦心があるかないかだと思っています。社員が前向きに働いてもらうために、太陽は公平で納得性の高い評価を大切にします。業績評価だけでなく、社員のコンピテンシー（行動特性）に比重を置き、一人ひとりの個性に合わせ、最大限の力を発揮できるような制度を整えています。また社員の家族のことも幸せにしたいという想いから親御様向けの介護保険もつくりました。さらに太陽は業界で唯一、5時間労働化を目指しています。短時間で効率よく働くことが社員も、会社も、お客様も幸せにすると考え、5時間労働化を全社一丸となって推し進めています。これからも現状を疑い、未来の当たり前を実現するために挑み続けます。</p>\r\n                </div>\r\n            </div>\r\n        </section>\r\n        <div class=\"MessageBreak2\">\r\n            <div>\r\n                <video playsinline muted autoplay loop poster=\"/recruit/assets/images/company/message/break_poster.png\">\r\n                    <source src=\"/recruit/assets/images/company/message/break_2.mp4\" type=\"video/mp4\">\r\n                </video>\r\n            </div>\r\n        </div>\r\n    </section>\r\n    <section class=\"MessageInterview\">\r\n        <div class=\"MessageInterviewBody\">\r\n            <h2><span>インタビューを動画で見る</span></h2>\r\n            <a href=\"#ModalMovie\" class=\"ModalLink\">\r\n                <img src=\"/recruit/assets/images/company/message/interview_thumb.jpg\" alt=\"動画を再生する\" width=\"927\" height=\"420\">\r\n            </a>\r\n        </div>\r\n    </section>\r\n</article>\r\n<!-- /Contents -->\r\n<aside id=\"ModalCover\">\r\n\t<div class=\"ModalOuter\"><div class=\"ModalInner\">\r\n\t\t\t<div id=\"ModalMovie\" class=\"ModalBody ModalMovie\">\r\n\t\t\t\t<div class=\"ModalMovieBody\">\r\n                    <div class=\"ModalMovieIn\">\r\n                        <iframe width=\"560\" height=\"315\" src=\"https://www.youtube.com/embed/nnxzhOq0Kgc?rel=0&showinfo=0&enablejsapi=1\" title=\"YouTube video player\" frameborder=\"0\" allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture\" allowfullscreen></iframe>\r\n                    </div>\r\n\t\t\t\t</div>\r\n\t\t\t\t<ul>\r\n\t\t\t\t\t<li class=\"ModalBtnClose\"><a href=\"javascript:void(0)\">Close</a></li>\r\n\t\t\t\t</ul>\r\n\t\t\t</div>\r\n    </div><div class=\"ModalOverlay\"></div></div>\r\n</aside>\r\n\r\n\n<footer class=\"Footer\">\n    <aside class=\"FooterPageTop\">\n        <a href=\"#PageTop\"><span>PAGE TOP</span></a>\n    </aside>\n    <div class=\"FooterLinkColumn\">\n        <div>\n            <h3>太陽を知る</h3>\n            <ul>\n                <li><a href=\"/recruit/company/message.html\">トップメッセージ</a></li>\n                <li><a href=\"/recruit/company/future.html\">太陽で輝く仕事と未来</a></li>\n                <li><a href=\"/recruit/company/allabout.html\">ひと目でわかる太陽</a></li>\n                <li><a href=\"/recruit/company/viewing.html\">TAIYO VIEWING 〜社内風景〜</a></li>\n            </ul>\n        </div>\n\n        <div>\n            <h3>社員・仕事を知る</h3>\n            <ul>\n                <li><a href=\"/recruit/workstyle/philosophy.html\">社員の幸せのためにできること</a></li>\n                <li><a href=\"/recruit/workstyle/profession.html\">太陽で働こう -職種紹介-</a></li>\n                <li><a href=\"/recruit/workstyle/interview.html\">社員インタビュー</a></li>\n                <li><a href=\"/recruit/workstyle/career.html\">キャリアステップ</a></li>\n                <li><a href=\"/recruit/workstyle/female.html\">女性社員が輝く職場</a></li>\n            </ul>\n        </div>\n\n        <div>\n            <h3>採用情報を知る</h3>\n            <ul>\n                <li><a href=\"/recruit/recruitment/flow.html\">応募要項・選考フロー</a></li>\n                <li><a href=\"/recruit/recruitment/faq.html