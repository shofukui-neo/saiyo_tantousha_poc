{"url":"https://www.hachimonjiya.co.jp/recruit/","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n<head>\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-6D5109RRHN\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'G-6D5109RRHN');\n</script>\n<meta charset=\"UTF-8\">\n<title>採用情報 | 八文字屋 | いつも新しい発見がある本屋です。</title>\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0, viewport-fit=cover\">\n<meta property=\"og:url\" content=\"https://www.hachimonjiya.co.jp/recruit/\">\n<meta property=\"og:site_name\" content=\"株式会社 八文字屋\">\n<meta property=\"og:title\" content=\"採用情報 | 八文字屋 | いつも新しい発見がある本屋です。\">\n<meta property=\"og:type\" content=\"article\">\n<meta property=\"og:description\" content=\"株式会社八文字屋の採用情報を掲載しています。\">\n<meta property=\"og:image\" content=\"https://www.hachimonjiya.co.jp/media/001/202303/ogp_hachimonjiya_b.png\">\n<meta property=\"og:image:secure_url\" content=\"https://www.hachimonjiya.co.jp/media/001/202303/ogp_hachimonjiya_b.png\" />\n<meta property=\"og:image:width\" content=\"1201\" />\n<meta property=\"og:image:height\" content=\"631\" />\n<meta name=\"description\" content=\"株式会社八文字屋の採用情報を掲載しています。\">\n<meta name=\"keywords\" content=\"本,書籍,山形,宮城,音楽,文具,雑貨,販売\">\n<meta name=\"twitter:title\" content=\"採用情報 | 八文字屋 | いつも新しい発見がある本屋です。\">\n<meta name=\"twitter:card\" content=\"summary\">\n<meta name=\"twitter:domain\" content=\"www.hachimonjiya.co.jp\">\n<meta name=\"twitter:image\" content=\"https://www.hachimonjiya.co.jp/media/001/202303/ogp_hachimonjiya_b.png\">\n<link rel=\"shortcut icon\" href=\"/themes/hachimonjiya2023/dist/images/favicon.ico\">\n<link rel=\"alternate\" type=\"application/rss+xml\" title=\"RSS 2.0\" href=\"https://www.hachimonjiya.co.jp/rss2.xml\">\n<link rel=\"stylesheet\" href=\"/themes/system/css/normalize.css?date=20250508152658\">\n<link rel=\"stylesheet\" href=\"/themes/system/css/acms.min.css?date=20250508152658\">\n<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n<link rel=\"stylesheet\" href=\"https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;700&family=Noto+Serif+JP:wght@400;600&display=swap\">\n<link rel=\"stylesheet\" href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@48,400,0,0\" />\n<link rel=\"stylesheet\" href=\"/themes/hachimonjiya2023/dist/css/style.min.css?date=20260514171342\">\n<!--[if lte IE 9]><script src=\"/js/html5shiv.min.js\"></script><script src=\"/js/respond.min.js\"></script><![endif]-->\n<script src=\"/js/library/jquery/jquery-3.6.1.min.js\"></script>\n<script src=\"/acms.js?uaGroup=PC&amp;domains=www.hachimonjiya.co.jp&amp;jsDir=js/&amp;themesDir=/themes/&amp;bid=1&amp;cid=4&amp;jQuery=3.6.1&amp;jQueryMigrate=migrate-3.0.1&amp;mediaClientResize=off&amp;fulltimeSSL=1&amp;v=9679855f1a96672a14e3dece697601d1&amp;umfs=64M&amp;pms=128M&amp;mfu=40&amp;lgImg=:1600&amp;jpegQuality=100&amp;mediaLibrary=on&amp;edition=standard&amp;urlPreviewExpire=48&amp;timemachinePreviewDefaultDevice=PC&amp;ccd=recruit&amp;scriptRoot=/\" id=\"acms-js\"></script>\n<meta name=\"csrf-token\" content=\"16d42bee272b6df2fb65b6c2c7c63b71426810c2a04ca394f604288154eb97d8\"><script type=\"text/javascript\" src=\"/js/dest/vendor.js?date=20250508152658\" charset=\"UTF-8\" async defer></script>\n<script type=\"text/javascript\" src=\"/js/dest/index.js?date=20250508152658\" charset=\"UTF-8\" async defer></script>\n<meta name=\"generator\" content=\"a-blog cms\" />\n</head>\n<body>\n<header id=\"siteHeader\">\n<div class=\"acms-container\">\n<div class=\"acms-grid\">\n<div class=\"acms-col-md-12\">\n<div class=\"siteHeader__inner\">\n<div class=\"header-logo\">\n<div>\n<p class=\"site-name\"><a href=\"https://www.hachimonjiya.co.jp/\" class=\"js-viewing-indelible\"><img src=\"/media/001/202302/site-logo3.svg\" alt=\"https://www.hachimonjiya.co.jp/\" class=\"site-logo\" width=\"280\"></a></p>\n</div>\n</div>\n<div class=\"sub-menu\">\n<div class=\"mailmag\">\n<a href=\"https://v.bmb.jp/bm/p/f/tf.php?id=hachimonjiya&task=regist\" class=\"acms-btn-flat acms-btn-flat-info\">メルマガ登録</a>\n</div>\n<form action=\"/search.html\" method=\"post\" name=\"searchForm\" class=\"search-form\" role=\"search\" aria-label=\"検索フォーム\">\n<label>\n<input type=\"search\" id=\"searchForm\" name=\"keyword\" value=\"\">\n</label>\n<button type=\"submit\" name=\"ACMS_POST_2GET\" aria-label=\"検索\">\n<input type=\"hidden\" name=\"query\" value=\"keyword\">\n<input type=\"hidden\" name=\"tpl\" value=\"/search.html\">\n<input type=\"hidden\" name=\"bid\" value=\"1\">\n<input type=\"hidden\" name=\"formUniqueToken\" value=\"ac81aa47236fe17da5d720c2312fc839630a6356bd3f319c6ad687fc6f3f3184\">\n<input type=\"hidden\" name=\"formToken\" value=\"16d42bee272b6df2fb65b6c2c7c63b71426810c2a04ca394f604288154eb97d8\">\n</form>\n</div>\n<div class=\"acms-hide-pc acms-hide-tablet acms-show-sp sp-mailmag-btn\">\n<a href=\"https://v.bmb.jp/bm/p/f/tf.php?id=hachimonjiya&task=regist\" class=\"sp-mailmag\">メルマガ登録</a>\n</div>\n</div>\n</div>\n</div>\n</div>\n<nav class=\"navbar\">\n<div class=\"acms-container\">\n<ul class=\"global-nav\">\n<li class=\"js-link_match_location\"><a href=\"https://www.hachimonjiya.co.jp/column/\" target=\"\">記事・お知らせ</a>\n</li>\n<li class=\"js-link_match_location\"><a href=\"https://www.hachimonjiya.co.jp/shops/\" target=\"\">店舗情報</a>\n</li>\n<li class=\"js-link_match_location\"><a href=\"https://www.hachimonjiya.co.jp/webstore/\" target=\"\">オンラインストア</a>\n</li>\n<li class=\"js-link_match_location\"><a href=\"https://www.hachimonjiya.co.jp/about/\" target=\"\">八文字屋について</a>\n</li>\n<li class=\"js-link_match_location\"><a href=\"https://www.hachimonjiya.co.jp/membership/\" target=\"\">メンバーシップ</a>\n</li>\n<li class=\"js-link_match_location\"><a href=\"https://www.hachimonjiya.co.jp/recruit/\" target=\"\">採用情報</a>\n</li>\n</ul>\n</div>\n</nav>\n</header>\n<main id=\"siteMain\">\n<div class=\"acms-container topicpath\">\n<ol class=\"acms-topicpath acms-margin-bottom-mini clearfix\">\n<li><a href=\"https://www.hachimonjiya.co.jp/\">HOME</a></li>\n<li class=\"js-link_match_location\"><a href=\"https://www.hachimonjiya.co.jp/recruit/\" class=\"js-viewing-indelible\">採用情報</a></li>\t</ol>\n</div>\n<div class=\"acms-container\">\n<header class=\"category-header\">\n</header>\n<section class=\"recruit-body-top\">\n<div class=\"introduction\">\n<h2 style=\"text-align: center\" id=\"52d118b1-29c3-40a7-9e0b-8babbbd4504a\">“八文字屋”で はたらく。</h2><p style=\"text-align: left\" id=\"6930ca32-be9c-4d58-a560-d2a0e0200b12\">八文字屋は、既存の店づくりや書店の常識にとらわれない新しいチャレンジを、これからも展開していきます。<br>誰しもが心躍らせ目を輝かせる、素敵な空間とサービスを私たちと一緒に作りましょう。</p><p style=\"text-align: left\" id=\"576bff02-da6e-4d3c-a98d-10935ae3e1a8\"></p>\n</div>\n<div class=\"recruit-menu\">\n<div>\n<ul class=\"recruit-banner\">\n<li>\n<a href=\"https://www.hachimonjiya.co.jp/about/\" target=\"_self\" class=\"\">\n<figure>\n<img src=\"/media/001/202303/A2.jpg\" width=\"1144\" height=\"1716\" class=\"acms-img-responsive\" alt=\"Company\" />\n<figcaption>Company</figcaption>\n</figure>\n</a>\n</li>\n<li>\n<a href=\"https://www.hachimonjiya.co.jp/recruit/top-message.html\" target=\"_self\" class=\"\">\n<figure>\n<img src=\"/media/001/202303/B.jpg\" width=\"1494\" height=\"1716\" class=\"acms-img-responsive\" alt=\"Top Message\" />\n<figcaption>Top Message</figcaption>\n</figure>\n</a>\n</li>\n<li>\n<a href=\"#interviewList\" target=\"_self\" class=\"js-fader\">\n<figure>\n<img src=\"/media/001/202303/image005.jpg\" width=\"1181\" height=\"786\" class=\"acms-img-responsive\" alt=\"Teams\" />\n<figcaption>Teams</figcaption>\n</figure>\n</a>\n</li>\n</ul>\n</div>\n<div id=\"interviewList\">\n<div class=\"built-in-module\">\n<article class=\"staff-summary\">\n<a href=\"https://www.hachimonjiya.co.jp/recruit/interview/shibuya.html\">\n<div class=\"staff-summary__inner\">\n<div class=\"rec-thumbnail\">\n<figure>\n<img alt=\"\" src=\"/media/001/202303/image001.jpg\" class=\"acms-img-responsive\">\n</figure>\n</div>\n<div class=\"rec-body\">\n<h3>「本を売ることが楽しい。その気持ちが書店員に必要な要素です」</h3>\n<p>渋谷亜香里　Shibuya Akari</p>\n</div>\n</div>\n</a>\n</article>\n<article class=\"staff-summary\">\n<a href=\"https://www.hachimonjiya.co.jp/recruit/interview/tanno.html\">\n<div class=\"staff-summary__inner\">\n<div class=\"rec-thumbnail\">\n<figure>\n<img alt=\"\" src=\"/media/001/202303/tanno_01.jpg\" class=\"acms-img-responsive\">\n</figure>\n</div>\n<div class=\"rec-body\">\n<h3>「子供にも響く書店でいたい。本好きを増やしていきたいです」</h3>\n<p>丹野孝輝　Tanno Koki</p>\n</div>\n</div>\n</a>\n</article>\n<article class=\"staff-summary\">\n<a href=\"https://www.hachimonjiya.co.jp/recruit/interview/nagaoka.html\">\n<div class=\"staff-summary__inner\">\n<div class=\"rec-thumbnail\">\n<figure>\n<img alt=\"\" src=\"/media/001/202303/nagaoka_01.jpg\" class=\"acms-img-responsive\">\n</figure>\n</div>\n<div class=\"rec-body\">\n<h3>「オンラインの可能性を拡げるべく、挑戦する日々です」</h3>\n<p>長岡信之介　Nagaoka Shinnosuke</p>\n</div>\n</div>\n</a>\n</article>\n</div>\n</div>\n</div>\n<div class=\"recruit-docs\">\n<h3>募集要項</h3>\n<ul class=\"recruit-tabs js-acms_tabs\">\n<li><a href=\"#rec1\" class=\"rec1\">新卒採用</a></li>\n<li><a href=\"#rec2\" class=\"rec2\">中途採用</a></li>\n<li><a href=\"#rec3\" class=\"rec3\">アルバイト</a></li>\n</ul>\n<div id=\"rec1\">\n<div class=\"recruit-docs__inner\">\n<div class=\"built-in-module\">\n<article class=\"article\">\n<section class=\"article-body\">\n<div class=\"acms-entry\">\n<div class=\"acms-grid-r\">\n<h3 >　　　　　　　　　　2027年卒新卒採用　一次募集は終了いたしました。<br />\n　　　　　　　　　　ご応募いただきまことにありがとうございました。<br />\n<br />\n　　　　　　　　　※一次募集で定員に達しなかった場合、二次募集を行う予定です。<br />\n　　　　　　　　　　二次募集についてはホームページで改めてお知らせいたします。</h3>\n</div>\n</div>\n<hr class=\"clearHidden\">\n</section>\n</article>\n</div>\n</div>\n</div>\n<div id=\"rec2\">\n<div class=\"recruit-docs__inner\">\n<div class=\"built-in-module\">\n<article class=\"article\">\n<section class=\"article-body\">\n<dl class=\"recruit-info\">\n<dt>募集対象</dt>\n<dd>【正社員】　販売／営業／経理・総務職　を募集します。<br />\n<br />\n※職種を限定しての採用はいたしません。<br />\n※配属は適正を鑑みて決定いたします。<br />\n※配属後、指定する職種・業務への異動があります。</dd>\n<dt>採用学部・学科</dt>\n<dd>全学部・学科</dd>\n<dt>採用予定数</dt>\n<dd>若干名（2～3名予定）</dd>\n<dt>採用職種</dt>\n<dd>\n<div class=\"flex\">\n<h4><span>販売職</span></h4>\n<p>店頭販売が主な業務です。<br />\n書籍・雑誌・文具・雑貨・ＣＤ・ゲーム・トレーディングカード・ドトールコーヒーショップ等の<br />\n商品を取り扱います。この他店舗運営にも携わっていただきます。<br />\n【主な業務】<br />\n・販売業務／問い合わせ対応など接客応対<br />\n・商品の荷受、検品、陳列、返品業務<br />\n・商品在庫管理に伴う事務作業<br />\n・商品の発注／催事計画や年間の販売計画の策定<br />\n・重点商品の企画販売の策定<br />\n・店舗管理業務<br />\n・店舗スタッフの労務管理<br />\n・マネジメント業務／店長補佐業務<br />\n<br />\n</p>\n</div>\n<div class=\"flex\">\n<h4><span>営業職</span></h4>\n<p>外商部としてルートセールスを行います。<br />\n地元の官公庁・学校・企業が主な販売先となり、地域に密着した営業部です。特に新学期は、<br />\n各学校への教材販売により年間最大の繁忙期となります。<br />\n【主な業務】<br />\n・取引先への訪問営業／受注／納品業務<br />\n・商品の荷受、発注、返品業務<br />\n・伝票処理、納品書・請求書発行、顧客管理など外商事務業務<br />\n・教材販売<br />\n・新学期の教科書・副読本販売<br />\n・小学校、中学校への無償教科書の納品<br />\n<br />\n<br />\n※経理・総務職は経理業務／人事管理・給与管理事務業務を担当します。<br />\n<br />\n<br />\n</p>\n</div>\n<div class=\"flex\">\n<h4><span>Web・IT職</span></h4>\n<p>－<br />\n</p>\n</div>\n</dd>\n<dt>必要な資格</dt>\n<dd>・普通自動車第一種免許　必須<br />\n・ＰＣスキル<br />\n　Ｏｆｆｉｃｅアプリケーション（Word、Excel）<br />\n</dd>\n<dt>応募方法</dt>\n<dd>当ホームページのエントリーフォームからの申し込み、または履歴書（写真貼付）・職務経歴書を下記住所まで<br />\n郵送してください。<br />\n<br />\n〒990-0043 山形市本町 2 丁目 4-56<br />\n株式会社八文字屋 総務部 採用係<br />\n<br />\n※履歴書送付の場合、志望動機・自己PR・職務経歴書を添付し、必ず返信用メールアドレスをご記載ください。<br />\n※エントリーフォーム、応募書類により取得した個人情報は採用および採用後の人事管理以外の目的には使用しません。<br />\n※書類は返却いたしませんのでご了承くださいますようお願いいたします。</dd>\n<dt>選考方法</dt>\n<dd>書類選考の上、面接日時をご連絡いたします。<br />\n選考は面接（個人面接）を予定しております。<br />\n選考スケジュールはその都度ご連絡いたします。</dd>\n<dt>給与</dt>\n<dd>基本給　205,000円～250,000円（時間外手当は別途支給）<br />\n※キャリア・年齢・能力等を考慮の上、当社規定に基づいて決定します。</dd>\n<dt>昇給・賞与・諸手当</dt>\n<dd>昇給：年 1 回（人事考課による）<br />\n賞与：年 2 回（業績・人事考課による）<br />\n諸手当：通勤手当（条件有り／上限 20,000 円）、家族手当、役職手当<br />\n※試用期間3ヶ月（待遇変動なし）<br />\n</dd>\n<dt>勤務地</dt>\n<dd>山形県：山形市、天童市、鶴岡市、酒田市、新庄市<br />\n宮城県：仙台市<br />\n※勤務する地域を限定せず転勤があります。<br />\n※条件により借上社宅制度が適用されます。<br />\n<br />\n</dd>\n<dt>勤務時間</dt>\n<dd>【販売】<br />\n早・遅番シフト制<br />\n（実働7 時間 40 分／昼休憩60分／昼休憩後に適宜交替により休憩20分）<br />\n※店舗の営業時間によって出勤・退勤時間が異なります。<br />\n【営業】<br />\n原則として9：00～18：00<br />\n（実働7時間40分／昼休憩60分／午前・午後に適宜交替により休憩各10分）<br />\n</dd>\n<dt>福利厚生</dt>\n<dd>健康保険／厚生年金保険／雇用保険／労災保険／定期健康診断／定年後再雇用制度<br />\n条件により借上社宅制度有り</dd>\n<dt>休日休暇</dt>\n<dd>週休 2 日（月 8 日休日） リフレッシュ休暇年 6 日 年間休日 102 日<br />\n年次有給休暇（入社6ヶ月後継続勤務後に10日付与）／慶弔休暇／産前産後休暇・育児休暇／介護休暇</dd>\n<dt>教育研修</dt>\n<dd>内定者研修 新入社員研修 出版社・取次（日本出版販売）研修<br />\n中小企業大学研修 各種講習会参加</dd>\n<dt>採用実績</dt>\n<dd>山形大、岩手大、新潟大、東北芸術工科大、東北学院大、東北福祉大、<br />\n東北文教大短大、東海大、日本大、法政大、玉川大、東洋大、国士舘大</dd>\n<dt>採用連絡先</dt>\n<dd>株式会社八文字屋 採用担当：総務部 歌丸<br />\n〒990-0043 山形市本町 2 丁目 4-56<br />\nTEL 023-642-8888（平日 9：00 ～ 18：00）<br />\ne-mail： soumu＠hachimonjiya.co.jp</dd>\n</dl>\n</section>\n</article>\n<div class=\"cf-btn cf_btn-center\">\n<a href=\"/recruit/career/\" class=\"unit-button cf_btn-blue\">中途採用に応募する</a>\n</div>\n</div>\n</div>\n</div>\n<div id=\"rec3\">\n<div class=\"recruit-docs__inner\">\n<div class=\"built-in-module\">\n<article class=\"article\">\n<section class=\"article-body\">\n<div class=\"acms-entry\">\n<div class=\"acms-grid-r\">\n<div class=\"space medium\"></div>\n<hr class=\"clearHidden\">\n<div><p style=\"text-align: center\" id=\"ec632ca2-f575-49b9-860d-e5094ce51600\">アルバイト募集については各店にお問い合わせください。</p><p style=\"text-align: left\" id=\"eee97523-084c-4c66-82f0-c5f0ca5cc6c8\"></p></div>\n</div>\n</div>\n<hr class=\"clearHidden\">\n</section>\n</article>\n</div>\n</div>\n</div>\n</div>\n</section>\n</div>\n</main>\n<footer id=\"siteFooter\">\n<div class=\"acms-container\">\n<div class=\"acms-grid\">\n<div class=\"acms-col-md-12\">\n<div class=\"bottom-menu\">\n<ul class=\"site-link\">\n<li><a href=\"https://www.hachimonjiya.co.jp/column/\" class=\"\">記事・お知らせ</a></li>\n<li><a href=\"https://www.hachimonjiya.co.jp/shops/\" class=\"\">店舗情報</a></li>\n<li><a href=\"https://www.hachimonjiya.co.jp/webstore/\" class=\"\">オンラインストア</a></li>\n<li><a href=\"https://www.hachimonjiya.co.jp/about/\" class=\"\">八文字屋について</a></li>\n<li><a href=\"https://www.hachimonjiya.co.jp/membership/\" class=\"\">メンバーシップ</a></li>\n<li><a href=\"https://www.hachimonjiya.co.jp/recruit/\" class=\"\">採用情報</a></li>\n<li><a href=\"https://www.hachimonjiya.co.jp/contact/\" class=\"\">お問い合わせ</a></li>\n<li><a href=\"https://www.hachimonjiya.co.jp/privacy/\" class=\"\">プライバシーポリシー</a></li>\n<li><a href=\"https://www.hachimonjiya.co.jp/shopinfo/\" class=\"\">特定商取引法に基づく表記</a></li>\n<li><a href=\"https://www.hachimonjiya.co.jp/partner/\" class=\"\">パートナー書店募集</a></li>\n<li><a href=\"https://www.hachimonjiya.co.jp/kanpo/\" class=\"\">官報公告・公布ご希望の方へ</a></li>\n</ul>\n</div>\n<div id=\"companyInfo\">\n<div class=\"company_logo\">\n<figure>\n<img src=\"/themes/hachimonjiya2023/dist/images/company_logo.svg\" alt=\"株式会社 八文字屋\" width=\"120\">\n</figure>\n<p>山形市本町二丁目4-11<br>\nTEL：023-622-2150</p>\n</div>\n</div>\n<p class=\"copyright\">©︎ 八文字屋, All rights reserved.</p>\n</div>\n</div>\n</div>\n</footer>\n<button id=\"menuButton\">\n<div class=\"menuButton__inner\">\n<span class=\"line l1\"></span>\n<span class=\"line l2\"></span>\n<span class=\"line l3\"></span>\n</div>\n</button>\n<div id=\"drawerMenu\">\n<div class=\"drawerMenu__inner\">\n<div class=\"wrapper--inner\">\n<div class=\"header-logo\">\n<p class=\"site-name\">\n<a href=\"https://www.hachimonjiya.co.jp/\"><img src=\"/media/001/202302/site-logo3.svg\" alt=\"https://www.hachimonjiya.co.jp/\" class=\"site-logo\" width=\"220\"></a>\n</p>\n</div>\n<div class=\"sp-menu_search\">\n<form action=\"/search.html\" method=\"post\" name=\"searchForm\" class=\"search-form\" role=\"search\" aria-label=\"検索フォーム\">\n<label>\n<input type=\"search\" id=\"searchForm\" name=\"keyword\" value=\"\">\n</label>\n<button type=\"submit\" name=\"ACMS_POST_2GET\" aria-label=\"検索\">\n<input type=\"hidden\" name=\"query\" value=\"keyword\">\n<input type=\"hidden\" name=\"tpl\" value=\"/search.html\">\n<input type=\"hidden\" name=\"bid\" value=\"1\">\n<input type=\"hidden\" name=\"formUniqueToken\" value=\"ac81aa47236fe17da5d720c2312fc839630a6356bd3f319c6ad687fc6f3f3184\">\n<input type=\"hidden\" name=\"formToken\" value=\"16d42bee272b6df2fb65b6c2c7c63b71426810c2a04ca394f604288154eb97d8\">\n</form>\n</div>\n<nav>\n<ul class=\"menu-list\">\n<li><a href=\"https://www.hachimonjiya.co.jp/column/\" class=\"\">記事・お知らせ</a></li>\n<li><a href=\"https://www.hachimonjiya.co.jp/shops/\" class=\"\">店舗情報</a></li>\n<li><a href=\"https://www.hachimonjiya.co.jp/webstore/\" class=\"\">オンラインストア</a></li>\n<li><a href=\"https://www.hachimonjiya.co.jp/about/\" class=\"\">八文字屋について</a></li>\n<li><a href=\"https://www.hachimonjiya.co.jp/membership/\" class=\"\">メンバーシップ</a></li>\n<li><a href=\"https://www.hachimonjiya.co.jp/recruit/\" class=\"\">採用情報</a></li>\n<li><a href=\"https://www.hachimonjiya.co.jp/contact/\" class=\"\">お問い合わせ</a></li>\n<li><a href=\"https://www.hachimonjiya.co.jp/privacy/\" class=\"\">プライバシーポリシー</a></li>\n<li><a href=\"https://www.hachimonjiya.co.jp/shopinfo/\" class=\"\">特定商取引法に基づく表記</a></li>\n<li><a href=\"https://www.hachimonjiya.co.jp/partner/\" class=\"\">パートナー書店募集</a></li>\n<li><a href=\"https://www.hachimonjiya.co.jp/kanpo/\" class=\"\">官報公告・公布ご希望の方へ</a></li>\n</ul>\n</nav>\n</div>\n</div>\n</div>\n<div id=\"scroll\">\n<a href=\"#\" class=\"scrollTo\">\n<img src=\"/themes/hachimonjiya2023/dist/images/scroll_up.svg\" alt=\"ページトップに戻る\" width=\"48\" height=\"48\">\n</a>\n</div>\n<script src=\"/themes/hachimonjiya2023/dist/js/main.js?date=20230420041004\" defer></script>\n</body>\n</html>","finalUrl":"https://www.hachimonjiya.co.jp/recruit/","rendered":false,"_cachedAt":"2026-06-17T23:04:36.870Z"}