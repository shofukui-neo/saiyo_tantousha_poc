e\": \"募集要項\",\r\n          \"item\": \"https://veilherz-mirai.jp/requirements\"\r\n        }\r\n        ,          {\r\n          \"@type\": \"ListItem\",\r\n          \"position\": 3,\r\n          \"name\": \"サービス管理責任者・児童発達支援管理責任者\",\r\n          \"item\": \"https://veilherz-mirai.jp/requirements/019\"\r\n        }\r\n                      ]\r\n    }\r\n  </script>\r\n\r\n\r\n  <ul class=\"rdBreadcrumbList\" itemscope itemtype=\"https://schema.org/BreadcrumbList\">\r\n            <li class=\"rdBreadcrumbItem rdBreadcrumbItemFirst\" itemprop=\"itemListElement\" itemscope\r\n      itemtype=\"https://schema.org/ListItem\">\r\n      <a class=\"rdBreadcrumbLink\" itemprop=\"item\" href=\"https://veilherz-mirai.jp/\"><span class=\"rdBreadcrumbName\"\r\n          itemprop=\"name\">トップページ</span></a>\r\n      <meta itemprop=\"position\" content=\"1\" />\r\n      <span class=\"rdBreadcrumbArrow\">\r\n        &gt;\r\n      </span>\r\n    </li>\r\n                <li class=\"rdBreadcrumbItem rdBreadcrumbItemFirst\" itemprop=\"itemListElement\" itemscope\r\n      itemtype=\"https://schema.org/ListItem\">\r\n      <a class=\"rdBreadcrumbLink\" itemprop=\"item\" href=\"https://veilherz-mirai.jp/requirements\"><span class=\"rdBreadcrumbName\"\r\n          itemprop=\"name\">募集要項</span></a>\r\n      <meta itemprop=\"position\" content=\"2\" />\r\n      <span class=\"rdBreadcrumbArrow\">\r\n        &gt;\r\n      </span>\r\n    </li>\r\n                <li class=\"rdBreadcrumbItem rdBreadcrumbItemCurrent\" itemprop=\"itemListElement\" itemscope\r\n      itemtype=\"https://schema.org/ListItem\">\r\n      <span class=\"rdBreadcrumbName\" itemprop=\"name\">サービス管理責任者・児童発達支援管理責任者</span>\r\n      <meta itemprop=\"position\" content=\"3\" />\r\n    </li>\r\n          </ul>\r\n\r\n</div></div></div>\n<div class=\" title-navi_ul\"><div class=\"  navi_li\"><div class=\" rdappended\"><p><a href=\"//veilherz-mirai.jp/recruit\">採用TOP</a></p></div></div>\n<div class=\"  navi_li\"><div class=\" rdappended\"><p><a href=\"//veilherz-mirai.jp/shinsotsu\">新卒採用</a></p></div></div>\n<div class=\"  navi_li\"><div class=\" rdappended\"><p><a href=\"//veilherz-mirai.jp/chuto\">中途採用</a></p></div></div>\n<div class=\"  navi_li\"><div class=\" rdappended\"><p><a href=\"//veilherz-mirai.jp/requirements\">募集要項</a></p></div></div>\n<div class=\"  navi_li\"><div class=\" rdappended\"><p><a href=\"//veilherz-mirai.jp/entry\">エントリーフォーム</a></p></div></div></div>\r\n</div>\r\n\r\n<div id=\"contents\" data-prc=\"\">\r\n\t<div class=\" u97e73b4eaf34433da2165460525f3684 rdplanetitle rdblock\"><h2>サービス管理責任者・児童発達支援管理責任者</h2></div>\n<div class=\" u7649c3f4bfc3450fa617eca05797b0d1 rdplanetitle rdblock\"><h3>仕事内容</h3></div>\n<div class=\" ud28129bf6afc4f2ca2107b32fab9828c rdplanetext rdblock\"><div><p>◆◆サビ管、児発管の専門業務に集中できる環境です！◆◆&nbsp;<br>◆◆施設の管理者の業務との兼務はございません！！ ◆◆&nbsp;<br>◆◆子ども達の成長を直接感じることができる職場です◆◆&nbsp;<br><br>〜仕事の内容〜&nbsp;<br>・支援計画書の作成、進捗管理、関係機関との連絡・調整&nbsp;<br><br>※専門職として個々の利用者とコミュニケーションをとりな&nbsp;<br>がら、適切な支援計画に繋げてください！&nbsp;<br>※充実した研修もありますので、放課後デイサービスでの経&nbsp;<br>験がない方でもＯＫです&nbsp;<br>※業務の変更範囲：会社の定める業務&nbsp;</p></div></div>\n<div class=\" u987e97356b2948e5b2ff63cfbeadc66e rdplanetext rdblock\"><div><p>https://veilherz-mirai.jp/</p></div></div>\n<div class=\" u22620908c8f6474d8469af5446938f1c rdplanetitle rdblock\"><h3>アピールポイント</h3></div>\n<div class=\" ue050866d22d24e1894035ac87bd8ddc4 rdplanetext rdblock\"><div><p>■■サビ管・児発管としての仕事のしやすさ♪■■&nbsp;<br>・管理者業務なし！！サビ管や児発管の仕事に集中できます！&nbsp;<br>・事業所には正社員の支援員が複数名在籍しております。&nbsp;<br>同じ立場の同僚が支援にあたってるため、現場の声を直に吸い&nbsp;<br>上げることが出来、支援の進捗状況も把握しやすい職場です！&nbsp;<br>・松戸市内に複数事業所を展開しているので、サビ管や児発管同&nbsp;<br>士で情報交換することができます。&nbsp;<br>仕事の中での「困った」を気軽に相談できる環境です！&nbsp;<br><br>■■資格取得支援充実！スペシャリストを目指せます■■&nbsp;<br>・障がい分野だけでなく、保育や介護の領域でも今後活躍したいと&nbsp;<br>考えている方にはおススメです♪&nbsp;<br>・関東信越厚生局指定養成施設「みらい福祉カレッジ」を運営&nbsp;<br>介護・福祉関係資格の講座を多数開講！！&nbsp;<br>例）保育士・介護職員初任者研修・実務者研修・介護福祉士 他&nbsp;<br><br>■当社は未就学児〜高校生まで年代別の放課後デイサービスを展開&nbsp;<br>幼い頃から支援してきた子が、高校を卒業する時の喜びは何物に&nbsp;<br>も代えられません！私達と一緒に喜びを分かちあいましょう！！&nbsp;</p></div></div>\n<div class=\" u2734c38d85a845e39f6ba39ab327571e rdplanetitle rdblock\"><h3>勤務時間・曜日</h3></div>\n<div class=\" ufcb7de33a4f542e989cb15d1e9212db2 rdplanetext rdblock\"><div><p>9:00～18:00<br>10:00～19:00<br>変形労働時間制（1ヶ月単位）</p></div></div>\n<div class=\" uc6f600b8ece143de82a8297823ae3302 rdplanetitle rdblock\"><h3>待遇・福利厚生</h3></div>\n<div class=\" ue465894d5ff5401ca020c3b14a4fad6e rdplanetext rdblock\"><div><p>マイカー通勤可（ガソリン代支給）<br>交通費支給（50,000円/月まで）<br>スマホ支給&nbsp;<br>退職金制度（勤続1年以上）<br>保養所あり<br>資格取得支援制度あり</p></div></div>\n<div class=\" u9f793724a6c64e9396ddc3e116bdd434 rdplanetitle rdblock\"><h3>資格</h3></div>\n<div class=\" u6f240baa16f748cb887710cf7514dc8e rdplanetext rdblock\"><div><p>サービス管理責任者又は児童発達支援管理責任者（いずれかの資格所持で可）<br>普通自動車運転免許　必須</p></div></div>\n<div class=\" umh45927j3bkwkxvgk0jzaqx3t27h6wo1 rdplanetitle rdblock\"><h3>雇用形態</h3></div>\n<div class=\" u1vxsnh6b2n06i6me3t9gbox1otrnb0m5 rdplanetext rdblock\"><div><p>正社員</p></div></div>\n<div class=\" u745d7f4aed874513995c95534b54c844 rdplanetitle rdblock\"><h3>給与</h3></div>\n<div class=\" u4064223019d848668d3a337887ed24bc rdplanetext rdblock\"><div><p>［月給］308,037円～361,507円</p></div></div>\n<div class=\" u818c7d6f7bb3485385bc5ecee30894b2 rdplanetext rdblock\"><div><p>基本給：185,000円〜&nbsp;231,000円<br>処遇改善手当：10,000 円&nbsp;<br>資格手当：30,000円&nbsp;<br>特別業務（運転）手当：10,000 円<br>固定残業代：43,037円～50,507円（22時間分）</p></div></div>\n<div class=\" u7e42a616546f4e2785c2d4529073bbcc rdplanetext rdblock\"><div><p>その他条件により<br>役職手当：5,000円～10,000円<br>車両手当：5,000円<br>扶養手当：5,000円等</p></div></div>\n<div class=\" u76c897fbcd0a4489923c3a7c91dd451d rdplanetitle rdblock\"><h3>勤務地</h3></div>\n<div class=\" ua846kjkmepsj4to26ohl927dp87n5pz0 rdflexarea rdblock\"><div class=\" ukfl0hxywuein5p189xqooe1ozsfr92jt rdflexareaChild rdblock\"><div class=\" uirgolua02sawibuo82iny0sxr4gs1xin rdplanemap rdblock\"><div class=\" rdiframewrapper\"><iframe src=\"https://www.google.com/maps/embed?pb=!1m14!1m8!1m3!1d1618.4201312157943!2d139.916958!3d35.7793!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x60188460bb6805d9%3A0x64da8cd1cfaf0e37!2z5qCq5byP5Lya56S-77yI5qCq77yJ44OZ44O844Or44OY44Or44OE!5e0!3m2!1sja!2sjp!4v1702366061356!5m2!1sja!2sjp\" width=\"600\" height=\"450\" style=\"border:0;\" allowfullscreen=\"\" loading=\"lazy\" referrerpolicy=\"no-referrer-when-downgrade\"></iframe></div></div></div>\n<div class=\" ut29wxj9uoog24mjhucgyzchunxwbsznd rdflexareaChild rdblock\"><div class=\" ubdxzk234wduuhqvmvwxhq6jy0q2xkh8e rdplanetext rdblock\"><div><p><span class=\"text-fontsize4\" style=\"font-size:1.2rem;\"><strong>株式会社ベールヘルツ</strong></span></p></div></div>\n<div class=\" uic61vyj3sp00zvyzpkgg0mzcs85h36tm rdplanetext rdblock\"><div><p>〒 270-2241<br>千葉県松戸市松戸新田30</p></div></div></div></div>\n<div class=\" ud29e67eea6d6477e8034277e54c0181a rdplanetitle rdblock\"><h3>本社</h3></div>\n<div class=\" ufbdf3f2020374e1a8ccef03bb0e8b8f6 rdplanetext rdblock\"><div><p><a href=\"//veilherz-mirai.jp/\">株式会社ベールヘルツ</a><br>〒270-2241<br>千葉県松戸市松戸新田３０<br>TEL：047-368-0670(代表)</p></div></div>\n<div class=\" u9cdcc54287704cfa8109dbbb83873e4b ub-to_bt link_btn\"><div><p><a href=\"//veilherz-mirai.jp/entry\">ご応募はこちら</a></p></div></div>\r\n</div>\r\n</main>\r\n\r\n\r\n<footer id=\"l_footer\" class=\"flex_inner\">\r\n\t<div class=\" flex_left\"><div class=\" logo\"><div class=\" rdappended\"><img src=\"//veilherz-mirai.jp/data/202312/img656afa27d5d24.png\" alt=\"株式会社ベールヘルツ\" width=\"284\" height=\"38\" /></div></div>\n<div class=\" address\"><div class=\" rdappended\"><p>〒270-2241<br>千葉県松戸市松戸新田30番地　</p></div></div>\n<div class=\" link_efect\"><div class=\" rdappended\"><p><a href=\"//veilherz-mirai.jp/contact\">お問い合わせ</a></p></div></div>\n<div class=\" copy\"><div class=\" rdappended\">Copyright© <a href=\"//veilherz-mirai.jp/toppage\">Veilherz Co., Ltd.</a> All rights reserved.</div></div></div>\n<div class=\" flex_right fnav\"><div class=\" fnav_dl\"><div class=\" fnav_dt\"><div class=\" rdappended\"><p><a href=\"//veil