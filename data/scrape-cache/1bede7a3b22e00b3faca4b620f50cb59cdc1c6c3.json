cation.hostname;\r\n\r\n  // 対象拡張子\r\n  const fileExtensions = [\r\n    '.pdf',\r\n    '.xls',\r\n    '.xlsx',\r\n    '.doc',\r\n    '.docx'\r\n  ];\r\n\r\n  // 全aタグ取得\r\n  const links = document.querySelectorAll('a[href]');\r\n\r\n  links.forEach((link) => {\r\n    const href = link.getAttribute('href');\r\n\r\n    // javascript:, mailto:, tel: は除外\r\n    if (\r\n      !href ||\r\n      href.startsWith('javascript:') ||\r\n      href.startsWith('mailto:') ||\r\n      href.startsWith('tel:')\r\n    ) {\r\n      return;\r\n    }\r\n\r\n    try {\r\n      // 絶対URL化\r\n      const url = new URL(href, location.origin);\r\n\r\n      const isExternal = url.hostname !== currentHost;\r\n\r\n      const pathname = url.pathname.toLowerCase();\r\n\r\n      const isFileLink = fileExtensions.some(ext =>\r\n        pathname.endsWith(ext)\r\n      );\r\n\r\n      // 条件に一致しない場合はスキップ\r\n      if (!isExternal && !isFileLink) {\r\n        return;\r\n      }\r\n\r\n      let sendUrl = url.href;\r\n\r\n      // 外部リンクの場合\r\n      if (isExternal) {\r\n        sendUrl =\r\n          '/External-link_' +\r\n          sendUrl.replace(/^https?:\\/\\//, '');\r\n      }\r\n\r\n      // すでにonclick属性がある場合は付与しない\r\n      if (link.onlick || link.onclick === '') {\r\n        return;\r\n      }\r\n\r\n      // onclick属性付与\r\n      link.setAttribute(\r\n        'onclick',\r\n        `click_send('${sendUrl}'); return true;`\r\n      );\r\n\r\n    } catch (e) {\r\n      // 不正なURLは無視\r\n      console.warn('Invalid URL:', href);\r\n    }\r\n  });\r\n});\r\n</script>\n             <script type=\"text/javascript\" class=\"optanon-category-C0002\" src=\"//rt.nc0006rtbc.nikon.com/bcx/rt_tag.js\" onload=\"bcxBeacon.send()\"></script>\n            </div>\n           </div>\n          </div>\n         </div>\n        </div>\n       </div>\n      </div>\n     </div>\n     <div class=\"container responsivegrid wrapper aem-GridColumn aem-GridColumn--default--12\">\n      <div id=\"container-c4649d090d\" class=\"cmp-container\">\n       <div class=\"aem-Grid aem-Grid--12 aem-Grid--default--12 \">\n        <div class=\"container responsivegrid aem-GridColumn aem-GridColumn--default--12\">\n         <div id=\"container-6464e14adf\" class=\"cmp-container\">\n          <div class=\"breadcrumb\">\n           <nav id=\"breadcrumb-61ce3508b2\" class=\"c-breadcrumb\" aria-label=\"パンくず\" data-cmp-data-layer=\"{&quot;breadcrumb-61ce3508b2&quot;:{&quot;@type&quot;:&quot;company/components/common/breadcrumb&quot;,&quot;repo:modifyDate&quot;:&quot;2025-10-29T07:39:45Z&quot;}}\" role=\"navigation\">\n            <ol itemscope itemtype=\"http://schema.org/BreadcrumbList\">\n             <li data-cmp-data-layer=\"{&quot;breadcrumb-61ce3508b2-item-4c063f2bd5&quot;:{&quot;@type&quot;:&quot;company/components/common/breadcrumb/item&quot;,&quot;repo:modifyDate&quot;:&quot;2026-05-31T14:12:18Z&quot;,&quot;dc:title&quot;:&quot;ホーム&quot;,&quot;xdm:linkURL&quot;:&quot;/&quot;}}\" itemprop=\"itemListElement\" itemscope itemtype=\"http://schema.org/ListItem\"><a data-cmp-clickable href=\"/\"> ホーム </a>\n              <meta itemprop=\"position\" content=\"1\"></li>\n             <li data-cmp-data-layer=\"{&quot;breadcrumb-61ce3508b2-item-d6db0f16a1&quot;:{&quot;@type&quot;:&quot;company/components/common/breadcrumb/item&quot;,&quot;repo:modifyDate&quot;:&quot;2026-05-31T19:32:08Z&quot;,&quot;dc:title&quot;:&quot;大切なお知らせ&quot;,&quot;xdm:linkURL&quot;:&quot;/content/nikoncom/jp/ja/info.html&quot;}}\" itemprop=\"itemListElement\" itemscope itemtype=\"http://schema.org/ListItem\"><a data-cmp-clickable href=\"/content/nikoncom/jp/ja/info.html\"> 大切なお知らせ </a>\n              <meta itemprop=\"position\" content=\"2\"></li>\n             <li data-cmp-data-layer=\"{&quot;breadcrumb-61ce3508b2-item-5331ce221e&quot;:{&quot;@type&quot;:&quot;company/components/common/breadcrumb/item&quot;,&quot;repo:modifyDate&quot;:&quot;2026-05-31T19:24:30Z&quot;,&quot;dc:title&quot;:&quot;製品に関する大切なお知らせ&quot;,&quot;xdm:linkURL&quot;