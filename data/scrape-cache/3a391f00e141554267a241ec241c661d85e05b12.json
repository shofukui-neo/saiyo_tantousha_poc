t=\"_blank\"><img src=\"/image/jp/r1/common2/icon_mail.png\" alt=\"お問い合わせ\"><span>お問い合わせ</span></a>\n\n\t\t\t<button type=\"button\" id=\"SupportNaviSearch\" aria-expanded=\"false\" aria-controls=\"SearchFormArea\"><span><img src=\"/image/jp/r1/common2/icon_search.png\" alt=\"検索\"><span>検索</span></span></button>\n\t\t\t<div id=\"SearchFormArea\">\n\t\t\t\t<div>\n\t\t\t\t\t<button class=\"BtnClose\" aria-label=\"閉じる\"></button>\n\t\t\t\t\t<form action=\"https://module.hitachi.com/search/RGN_JAPAN.html\" method=\"get\" accept-charset=\"UTF-8\">\n\t\t\t\t\t\t<input type=\"hidden\" name=\"imgsize\" value=\"3\">\n\t\t\t\t\t\t<input type=\"hidden\" name=\"pagemax\" value=\"10\">\n\t\t\t\t\t\t<div class=\"SearchGroup\">\n\t\t\t\t\t\t\t<input type=\"text\" name=\"q\" size=\"20\" maxlength=\"40\" accesskey=\"s\" title=\"検索キーワード\" placeholder=\"日立グループ全体から検索\" autocomplete=\"off\" class=\"SearchPhrease\" id=\"MF_form_phrase\">\n\t\t\t\t\t\t\t<button class=\"SearchBtn\" type=\"submit\">検索</button>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</form>\n\t\t\t\t</div>\n\t\t\t</div><!--/#SearchFormArea-->\n\t\t</div><!--/#SupportNavi-->\n\n\t\t<button id=\"SpMenuBtn\" aria-label=\"メニュー\">\n\t\t\t<span></span>\n\t\t\t<span></span>\n\t\t\t<span></span>\n\t\t</button>\n\n\t</div><!--/.Container-->\n</div><!--/#HeaderArea1-->\n\n<div id=\"HeaderArea2\">\n\t<div class=\"Container Wide\">\n\t\t<div id=\"SiteID\">\n\t\t\t<a href=\"/index.html\"><span>株式会社 日立プラントメカニクス</span></a>\n\t\t\t<a href=\"/recruit/index.html\"><span>採用情報</span></a>\n\t\t</div>\n\t\t<ul id=\"GlobalNaviMenu\">\n\t\t\t<li><a href=\"/recruit/newgraduate/about.html\">会社概要</a></li>\n\t\t\t<li><a href=\"/recruit/newgraduate/info.html\">福利厚生</a></li>\n\t\t\t<li><a href=\"/recruit/office.html\">事業所紹介</a></li>\n\t\t\t<li><a href=\"/recruit/newgraduate/job/index.html\">仕事風景</a></li>\n\t\t\t<li class=\"Current\"><a href=\"/recruit/newgraduate/index.html\"><em>新卒採用</em></a></li>\n\t\t\t<li><a href=\"https://en-gage.net/hpm_careersaiyo/\" target=\"_blank\">経験者採用</a></li>\n\t\t\t<li><a href=\"/recruit/disability/index.html\">障がい者採用</a></li>\n\t\t</ul>\n\t</div><!--/.Container-->\n</div><!--/#HeaderArea2-->\n\n<div id=\"Contents\" class=\"sub-page\">\n\n\t<div class=\"breadcrumb-list\">\n\t\t<div class=\"GridSet\">\n\t\t\t<div class=\"Grid4\">\n\t\t\t\t<ul>\n\t\t\t\t\t<li><a href=\"/recruit/index.html\">採用情報トップページ</a></li>\n\t\t\t\t\t<li><a href=\"/recruit/newgraduate/index.html\">新卒採用</a></li>\n\t\t\t\t\t<li><strong>募集要項</strong></li>\n\t\t\t\t</ul>\n\t\t\t</div>\n\t\t</div>\n\t</div><!-- /.breadcrumb-list -->\n\n\n\t<div class=\"GridSet wid100p\">\n\t\t<div class=\"Grid4\">\n\n            <div class=\"contents-width\">\n\n                <div class=\"section-recruit sub-page-layout\" id=\"section-interview-top\">\n\n                    <div class=\"recruit-title-en is-vertical info-vertical\">DESCRIPTION</div>\n\n                    <div class=\"message-title\">\n                        <h1>JOB<br>DESCRIPTION<span>募集要項</span></h1>\n                    </div><!-- /title-message -->\n\n                </div><!-- /#section-interview-top -->\n\n\t\t\t</div><!-- /.contents-width -->\n\n            <div class=\"contents-width\">\n                <div class=\"message-section contents-section-light\">\n                    <ul class=\"second-anchor\">\n                        <li><a href=\"#anc03\" class=\"smooth-scroll\"><span>募集要項</span></a></li>\n                        <li><a href=\"#anc04\" class=\"smooth-scroll\"><span>選考フロー</span></a></li>\n                        <li><a href=\"#anc05\" class=\"smooth-scroll\"><span>インターンシップ</span></a></li>\n                    </ul>\n                </div><!-- /message-section -->\n\t\t\t</div><!-- /.contents-width -->\n\n\n            <div class=\"contents-width contents-section\">\n\n                <div class=\"message-section\">\n                    <h2 id=\"anc03\" class=\"title-second\">募集要項</h2>\n                    <table class=\"table-second\">\n                        <colgroup>\n                            <col width=\"250\">\n                        </colgroup>\n                        <tr>\n                            <th scope=\"row\" class=\"taC\">募集対象</th>\n                            <td>高等専門学校または大学学部・修士・博士課程を2027年3月末までに卒業（修了）見込みの方<br>\n及びすでに卒業された方で新規卒業予定者と同等の枠組みでの採用を希望される方</td>\n                        </tr>\n                        <tr>\n                            <th scope=\"row\" class=\"taC\">募集人数</th>\n                            <td>\n                                <ul>\n                                    <li>技術系：10名程度</li>\n                                    <li>事務系：若干名</li>\n                                </ul>\n                            </td>\n                        </tr>\n                        <tr>\n                            <th scope=\"row\" class=\"taC\">募集職種</th>\n                             <td><ul><li>【技術系総合職（佐野工場勤務）】</li>\n                                    <li>①品質保証</li>\n                                    <li>②クレーンに関する技術開発及びシステム設計</li>\n                                    <li>③クレーンの機械設計</li>\n                                    <li>④クレーンの電気制御設計</li>\n<li>⑤クレーン全体（機械・電気制御・ソフト）の見積り及びエンジニアリング業務</li>\n<li>⑥生産技術、生産管理</li>\n                                    <br>\n                                    <li>【技術系総合職（松戸事業所勤務）】</li>\n<li>⑦クレーンの保守・メンテナンス（フィールドエンジニア）</li>\n                                    <br>\n                                    <li>【技術系総合職（尼崎事業所勤務）】</li>\n                                    <li>⑧クレーン改修・改造に関する電気制御設計及びエンジニアリング業務</li>\n<br>\n                                    <li>【技術系総合職（徳山事務所勤務）】</li>\n                                    <li>⑨ロジスティクス関連製品（ソフトウェア）のシステム設計</li>\n<br>\n                                    <li>【事務系総合職】</li>\n                                    <li>①クレーンの原価管理、業績管理（佐野工場勤務）</li>\n                                    <li>②クレーンの製作、サービスに必要な調達業務（佐野工場勤務）</li>\n<li>③クレーン製品及びアフターサービスの提案営業（勤務地未定）</li>\n                              </ul>\n                           </td>\n                        </tr>\n                        <tr>\n                            <th scope=\"row\" class=\"taC\">募集学部・学科</th>\n                            <td>\n                                <ul>\n                                    <li>技術系：機械工学、電気工学、制御工学、ロボティクス　など</li>\n                                    <li>事務系：機械工学、電気工学、情報統計、経営会計、経済法律　など</li>\n                                </ul>\n                            </td>\n                        </tr>\n                        <tr>\n                            <th scope=\"row\" class=\"taC\">本給</th>\n                            <td>\n                                2025年度初任給実績\n                                <ul>\n                                    <!--li><span class=\"dt-wid-7em\">大卒（修士）</span>：269,500円</li-->\n                                    <li><span class=\"dt-wid-7em\">大卒（学士）</span>：264,000円</li>\n                                    <li><span class=\"dt-wid-7em\">高専卒</span>：224,000円</li>\n                                    <li><span class=\"dt-wid-7em\">短大卒</span>：211,000円</li>\n                                </ul>\n                            </td>\n                        </tr>\n                        <tr>\n                            <th scope=\"row\" class=\"taC\">諸手当</th>\n                            <td>通勤手当、時間外労働手当、ワークスタイル支援手当、家族手当、住宅手当、持家支援手当　など</td>\n                        </tr>\n                        <tr>\n                            <th scope=\"row\" class=\"taC\">昇給・賞与</th>\n                            <td>\n                                <ul>\n                                    <li><span class=\"dt-wid-4em\">賃金改定</span>：年1回</li>\n                                    <li><span class=\"dt-wid-4em\">賞与</span>：年2回</li>\n                                </ul>\n                            </td>\n                        </tr>\n                        <tr>\n                            <th scope=\"row\" class=\"taC\">試用期間</th>\n                            <td>あり（入社日より3ヶ月間）</td>\n                        </tr>\n                        <tr>\n                            <th scope=\"row\" class=\"taC\">休日・休暇</th>\n                            <td>年間休日126日（2025年度、2026年度）、完全週休2日制（土・日）、年次有給休暇（24日　※初年度は22日）<br>\nリフレッシュ休暇、出産休暇、育児休暇、配偶者出産休暇、介護休暇　など</td>\n                        </tr>\n                        <tr>\n                            <th scope=\"row\" class=\"taC\">福利厚生</th>\n                            <td>各種保険（健康保険・厚生年金保険・雇用保険・労災保険・介護保険）、財形制度、日立グループ共通年金、借上げ寮・社宅制度、カフェテリアプラン制度　など</td>\n                        </tr>\n                        <tr>\n                            <th scope=\"row\" class=\"taC\">労働時間（所定）</th>\n                            <td>\n                                8:50 ～ 17:20（実働7時間45分）<br>※佐野工場は、8:30 ～ 17:00\n                          \n                                <p class=\"indent-text01 text-paragraph\">※フレックスタイム制度あり（コアタイムなし、適用にあたり社内規定あり）</p>\n                                休憩時間：45分\n                                <p class=\"indent-text01 text-paragraph\">※開始・終了時間は勤務地により異なる</p></td></tr>\n                        <tr>\n                            <th scope=\"row\" class=\"taC\">労働時間（所定）を超える<br>労働時間の有無</th>\n                            <td>業務の都合によりやむを得ない場合に、労働時間（所定）を延長（早出、残業または呼出）することがある</td>\n                        </tr>\n                        <tr>\n                            <th scope=\"row\" class=\"taC\">勤務予定地</th>\n                            <td>全社各事業所（応募職種により異なる）</td>\n                        </tr>\n                        <tr>\n                            <th scope=\"row\" class=\"taC\">就業場所における<br>屋内の受動喫煙対策</th>\n                            <td>屋内全面禁煙、もしくは空間分煙された屋内喫煙所あり（勤務地により異なる）</td>\n                        </tr>\n                        <tr>\n                            <th scope=\"row\" class=\"taC\">求める人財</th>\n                            <td>周囲とよくコミュニケーションをとり、他人の意見を尊重しながら自らの考えを持ち、明るく前向きに業務に取り組むことができるような方を歓迎します。</td>\n                        </tr>\n                    </table>\n                    <p class=\"smooth-page-top\"><a href=\"#top\" class=\"smooth-scroll\">ページTOPへ戻る</a></p>\n                </div><!-- /.message-section -->\n\n                <div class=\"message-section\">\n                    <h2 id=\"anc04\" class=\"title-second\">選考フロー</h2>\n                    <ul class=\"info-flow\">\n                        <li><span class=\"info-flow-in\">エントリー</span></li>\n                        <li><span class=\"info-flow-in\">会社説明会</span></li>\n                        <li><span class=\"info-flow-in\">書類選考<br><span class=\"info-text-small\">（エントリーシート<br class=\"only-pc\">提出）</span></span></li>\n                        <li><span class=\"info-flow-in\">面談<br class=\"only-pc\">（2～3回）<br class=\"only-pc\">・適性検査</span></li>\n                        <li><span class=\"info-flow-in\">内々定</span></li>\n                    </ul>\n                    <p class=\"smooth-page-top\"><a href=\"#top\" class=\"smooth-scroll\">ページTOPへ戻る</a></p>\n                </div><!-- /.message-section -->\n\n                <div class=\"message-section\">\n                    <h2 id=\"anc05\" class=\"title-second\">インターンシップについて</h2>\n                    <p class=\"text-second\">日立プラントメカニクスの事業や仕事の体感、工場見学、先輩社員との交流などのプログラムを用意しています。<br>詳しくは以下のエントリーリンクを押下いただき、開催中のイベントをご確認ください。</p>\n                    <p class=\"smooth-page-top\"><a href=\"#top\" class=\"smooth-scroll\">ページTOPへ戻る</a></p>\n                </div><!-- /.message-section -->\n\n\t\t\t</div><!-- /.contents-width -->\n\n            <div class=\"contents-width\">\n                <div class=\"message-section\">\n                    <div class=\"small-section\">\n                    <h2 class=\"title-second\">お問い合わせ窓口</h2>\n                    <p class=\"text-second-large\">株式会社日立プラントメカニクス 人事総務部人事教育グループ　採用担当</p>\n                    </div><!-- /.small-section -->\n\n                    <div class=\"disability-table\">\n                        <a href=\"tel:0362717140\" class=\"col01\">\n                            <p class=\"tel-style\">03-6271-7140</p>\n                        </a><!-- /.col01 -->\n                        <a href=\"mailto:gyoumu.hpm_kanribu.oo@hitachi.com\" class=\"col02\">\n                            <p class=\"mail-style\"><img src=\"/recruit/image/recruit_mail_adress.png\" alt=\"メールアドレス\"></p>\n                        </a><!-- /.col01 -->\n                    </div><!-- /.disability-table -->\n\n                </div><!-- /.message-section -->\n\t\t\t</div><!-- /.contents-width -->\n\n<div class=\"contents-width\">\n\n<div class=\"section-recruit multiple\" id=\"section-entry\">\n<img src=\"/recruit/newgraduate/image/back_entry.jpg\" alt=\"\">\n<div class=\"entry-inner\">\n<div>\n<p>ENTRY</p>\n<p>エントリーはこちらから</p>\n</div>\n<div class=\"entry-link\">\n<p><a href=\"https://job.mynavi.jp/26/pc/search/corp113326/outline.html\" target=\"_blank\">2026卒エントリー<span class=\"entry-arrow\"></span></a></p>\n<p>2027卒エントリー（準備中）</p>\n</div>\n</div>\n</div>\n\n</div><!-- /.contents-width -->\n\n\n\t\t\t<div class=\"accessory-6\">\n\t\t\t\t<span></span>\n\t\t\t\t<span></span>\n\t\t\t\t<span></span>\n\t\t\t\t<span></span>\n\t\t\t\t<span></span>\n\t\t\t\t<span></span>\n\t\t\t\t<span></span>\n\t\t\t</div>\n\n\n\n\t\t</div><!--/Grid4-->\n\t</div><!--/GridSet-->\n</div><!--/Contents-->\n\n\n\n<div id=\"FooterArea\">\n\t<div class=\"Container Wide\">\n\n\t\t<a href=\"#top\" id=\"FooterPageTop\" aria-label=\"ページの先頭へ\"></a>\n\n\t\t<div id=\"Footer1\">\n\n\t\t\t<div id=\"HitachiTop\">\n\t\t\t\t<a href=\"https://www.hitachi.co.jp/\">日立グループTOP</a>\n\t\t\t</div>\n\n\t\t\t<div id=\"Footer1Menu\">\n\t\t\t\t<a href=\"/utility/termofuse/index.html\">サイトの利用条件</a>\n\t\t\t\t<a href=\"/utility/privacy/index.html\">個人情報保護に関して</a>\n\t\t\t</div>\n\n\t\t\t<div id=\"Copyright\">&copy; Hitachi Plant Mechanics Co., Ltd.<span>2007</span>. All rights reserved.</div>\n\n\t\t</div><!--/#Footer1-->\n\n\t</div><!--/.Container-->\n</div><!--/#FooterArea-->\n\n<script>\n(function (i, s, o, g, r, a, m) {(i[r] = i[r] || function () { (i[r].q = i[r].q || []).push(arguments) }),(a = s.createElement(o)), (m = s.getElementsByTagName(o)[0]);a.async = 1;a.src = g;m.parentNode.insertBefore(a, m);})(window, document, \"script\", \"//ar.mrc-s.com/web/ar.js\", \"mrc\");\nmrc(\"id\", \"mgr8af\");\nmrc(\"autolink\", [\"*.hitachi-hpm.co.jp\", \"hitachi-hpm.mrc-lp.com\"]);\nmrc(\"send\");\n</script>\n\n</body>\n</html>","finalUrl":"https://www.hitachi-hpm.co.jp/recruit/job-description.html","rendered":false,"_cachedAt":"2026-06-23T20:40:20.223Z"}