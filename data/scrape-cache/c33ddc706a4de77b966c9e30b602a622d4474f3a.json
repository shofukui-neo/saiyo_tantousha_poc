ontIn1170\">\n      <div class=\"under-H2\">\n        <h2>採用情報</h2>\n        <span>Recruit<br /></span> </div>\n    </div>\n  </div>\n\t\t\t\t</section>\n\t\t\t\t<div>\n\t\t\t\t\t<div class=\"breadcrumb\">\n\t\t\t\t\t\t<div class=\"contIn1170 all\">\n<a href=\"../index.html\">TOP</a>&nbsp;採用情報\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t<div>\n\t\t\t\t<div class=\"contIn1170 clearfix\">\n\t\t\t\t\t<div class=\"contMainColumn_01\" id=\"VcArea-MainColum\">\n\t\t\t\t\t<!--↓ メインカラム-->\n        <div class=\"module-1st-lebel-head default1\">\n          <h3>募集要項・今後の採用日程</h3>\n        </div>\n        <div class=\"block-section default14\">\n          <div class=\"module-like-table\">\n            <dl>\n              <dt>■募集内容、仕事概要</dt>\n              <dd><strong>・雇用形態</strong><br />正社員　<br /><br /><strong>・仕事の内容</strong><br />電気設備工事の現場施工管理技術者・施工技術者・営業職<br />電気通信工事の現場施工管理技術者・施工技術者<br />情報通信工事の現場施工管理技術者・施工技術者</dd>\n            </dl>\n            <dl>\n              <dt>■勤務地</dt>\n              <dd><strong>・勤務地</strong><br />新潟市西区（本社）<br />電気設備工事の現場施工管理技術者・施工技術者・営業職<br />情報通信工事の現場施工管理技術者・施工技術者<br /><br />長岡市（長岡事業所）<br />電気通信工事の現場施工管理技術者・施工技術者<br /><br />南魚沼市（南魚沼テクニカルサービスセンター）<br />電気通信工事の現場施工管理技術者・施工技術者<br /><br />妙高市（上越事業所）<br />電気通信工事の現場施工管理技術者・施工技術者<br /><br />上越市（上越テクニカルサービスセンター）<br />電気通信工事の現場施工管理技術者・施工技術者</dd>\n            </dl>\n            <dl>\n              <dt>■給与、手当</dt>\n              <dd><strong>・賃金</strong><br />基本給：187,000円～300,000円程度<br /><br /><strong>・昇給</strong><br />年1回<br /><br /><strong>・賞与</strong><br />年2回<br />（年4～6ヶ月分）<br /><br /><strong>・手当</strong><br />役職手当<br />時間外勤務手当<br />深夜勤務手当<br />振替手当<br />現場手当<br />家族手当<br />住宅手当<br />通勤費<br />その他手当<br /><br /><strong>・給与の締め日・支払日</strong><br />毎月末日締め　27日支払い</dd>\n            </dl>\n            <dl>\n              <dt>■労働時間等</dt>\n              <dd><strong>・就業時間</strong><br />8：30～17：00<br /><br /><strong>・時間外労働時間</strong><br />月平均10時間程度<br /><br /><strong>・休憩時間</strong><br />12：00～13：00<br /><br /><strong>・有給休暇取得状況</strong><br />10日以上取得率　約70%（過去3年）<br /><br /><strong>・年間休日</strong><br />125日（各年平均）<br /><br /><strong>・休日</strong><br />土・日・祝（週休二日制）<br />夏季休暇　8/13～8/14<br />年末年始　12/29～1/3 　</dd>\n            </dl>\n            <dl>\n              <dt>■福利厚生等</dt>\n              <dd><strong>・資格取得支援</strong><br />費用負担、報奨金制度（1万～10万）制度あり<br /><br /><strong>・各種祝い金、見舞金</strong><br />結婚、銀婚、出産、小学校入学、中学校卒業<br />疾病見舞い金、弔意金<br /><br /><strong>・福利厚生施設</strong><br />温泉施設、スポーツ施設等の利用券交付</dd>\n            </dl>\n            <dl>\n              <dt>■応募条件</dt>\n              <dd><strong>・学歴</strong><br />高卒以上<br /><br /><strong>・年齢</strong><br />～59歳まで<br /><br /><strong>・必要な免許・資格等</strong><br />普通自動車運転免許　※【必須】AT限定は不可</dd>\n            </dl>\n            <dl>\n              <dt>■求人に関する<br />　特記事項</dt>\n              <dd><strong>特記事項</strong><br />2m以上の高所で作業を行う業務があります<br />ケーブルを色別する業務があるため、色覚検査を実施します</dd>\n            </dl>\n            <dl>\n              <dt>■会社情報</dt>\n              <dd><strong>連絡先</strong><br />トーシス新潟<br />経営企画部長　松野　浩<br />TEL（025）211-1600<br />（平日8：30～17：00）<br /><strong>会社所在地</strong><br />〒950-2032 新潟県新潟市西区的場流通２丁目４番地５</dd>\n            </dl>\n          </div>\n        </div>\n                    </div>\n\t\t\t\t\t<!--↑ メインカラム-->\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t\t\t<div id=\"VcArea-Footer\">\n<div class=\"footerWrap01\">\n  <div class=\"contIn1170\">\n    <div class=\"footerBlock01 clearfix accordion\">\n      <div class=\"spFooterBox\">\n        <div class=\"footerBox01\">\n          <p class=\"link01\"><a href=\"../company/index.html\" title=\"会社概要\" target=\"_self\">会社概要</a><br /><a href=\"../policy/index.html\" title=\"企業方針\" target=\"_self\">└企業方針</a><br /><a href=\"../env/index.html\" title=\"環境方針\" target=\"_self\">└環境方針</a><br /><a href=\"../notification/index.html\" title=\"決算公告・電子公告\" target=\"_self\">└決算公告・電子公告</a><br /><a href=\"../recruit/index.html\" title=\"採用情報\" target=\"_self\">└採用情報</a><br /><a href=\"../organization/index.html\" title=\"組織図\" target=\"_self\">└組織図</a></p>\n        </div>\n      </div>\n      <div class=\"spFooterBox\">\n        <div class=\"footerBox01\">\n            <p class=\"link01\"><span class=\"footerInfo\">インフォメーション</span><br /><a href=\"../privacy/index.html\" title=\"個人情報の取扱い\" target=\"_self\">└個人情報の取扱い</a><br /><a href=\"../community/index.html\" title=\"処分場の施設見学その他お問合わせについて\" target=\"_self\">└処分場の施設見学その他お問合わせについて</a><br /><a href=\"../price/index.html\" title=\"収集運搬・処分及びコンクリート砕石の料金について\" target=\"_self\">└収集運搬・処分及びコンクリート砕石の料金について</a></p>\n            </div>\n      </div>\n      <div class=\"spFooterBox\">\n        <div class=\"footerBox01\">\n            <p class=\"link01\"><a href=\"../company_guide/index.html\" title=\"事業部門\" target=\"_self\">事業部門</a><br /><a href=\"../company_guide/index.html#vcb00000463-10001-364-default1-1\" title=\"電気設備部門\" target=\"_self\">└電気設備部門</a><br /><a href=\"../company_guide/index.html#vcb00000463-10001-365-default1-1\" title=\"情報モバイル部門\" target=\"_self\">└情報モバイル部門</a><br /><a href=\"../company_guide/index.html#vcb00000463-10001-397-default1-1\" title=\"キャリア部門\" target=\"_self\">└キャリア部門</a><br /><a href=\"../company_guide/index.html#vcb00000463-10001-398-default1-1\" title=\"社会基盤事業部門\" target=\"_self\">└社会基盤事業部門</a><br /><a href=\"../company_guide/index.html#vcb00000463-10001-399-default1-1\" title=\"緑化事業部門\" target=\"_self\">└緑化事業部門</a><br /><a href=\"../company_guide/index.html#vcb00000463-10001-400-default1-1\" title=\"環境事業部門\" target=\"_self\">└環境事業部門</a><br /><a href=\"../company_guide/index.html#vcb00000463-10001-401-default1-1\" title=\"安全品質管理部\" target=\"_self\">└安全品質管理部</a></p>\n          </div>\n      </div>\n      <div class=\"spFooterBox\">\n        <div class=\"footerBox01\">\n            <p class=\"link01\"><a href=\"mailto:ts-soumu2@ts-niigata.co.jp?Subject=ご意見・ご質問等、\">お問い合わせ</a></p>\n          </div>\n      </div>\n    </div>\n  </div>\n</div>\n<div class=\"footerBottom\">\n  <div class=\"contIn1170\">\n    <di