{"url":"https://www.super-marui.com/recruit/deli/chief.html","html":"<!DOCTYPE html>\n<html lang=\"ja-JP\">\n <head> \n  <meta charset=\"UTF-8\"> \n  <meta http-equiv=\"content-type\" content=\"text/html; charset=UTF-8\"> \n  <meta name=\"robots\" content=\"index\"> \n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"> \n  <meta name=\"description\" content=\"2021年4月に入社した惣菜部所属の新人社員と、教育担当のチーフ、トレーナーそれぞれの立場から、マルイ・新人教育の“ホンネ”に迫った。\"> \n  <meta property=\"og:title\" content=\"新人社員の教育現場|チーフの“ホンネ”\"> \n  <meta property=\"og:type\" content=\"website\"> \n  <meta property=\"og:image\" content=\"https://www.super-marui.com/recruit/bdflashinfo/thumbnail-large.png\"> \n  <meta property=\"og:url\" content=\"https://www.super-marui.com/recruit/deli/chief.html\"> \n  <meta property=\"og:site_name\" content=\"リクルート採用情報サイト | 株式会社マルイ\"> \n  <meta property=\"og:description\" content=\"2021年4月に入社した惣菜部所属の新人社員と、教育担当のチーフ、トレーナーそれぞれの立場から、マルイ・新人教育の“ホンネ”に迫った。\"> \n  <meta name=\"twitter:card\" content=\"summary_large_image\"> \n  <meta name=\"twitter:image\" content=\"https://www.super-marui.com/recruit/bdflashinfo/thumbnail-large.png\"> \n  <meta name=\"note:card\" content=\"summary_large_image\"> \n  <link rel=\"canonical\" href=\"https://www.super-marui.com/recruit/deli/chief.html\"> \n  <title>新人社員の教育現場|チーフの“ホンネ”</title> \n  <link rel=\"stylesheet\" type=\"text/css\" href=\"../_module/styles/bind.css?v=17.0.6\" id=\"bind-css\"> \n  <link rel=\"stylesheet\" type=\"text/css\" href=\"../_dress/b014006/base.css?1777131017922\"> \n  <link rel=\"stylesheet\" type=\"text/css\" href=\"../_dress/b14006Navi/base.css?1777131017922\"> \n  <link rel=\"stylesheet\" type=\"text/css\" href=\"../_dress/b14006Main1/base.css?1777131017922\"> \n  <link rel=\"stylesheet\" type=\"text/css\" href=\"../_dress/93f5ddf232da4e5eabf8affc97d8ac99/base.css?1777131017922\"> \n  <link rel=\"stylesheet\" type=\"text/css\" href=\"../_dress/00bca8d34607437494a664ba54041520/base.css?1777131017922\"> \n  <link rel=\"stylesheet\" type=\"text/css\" href=\"https://fonts.googleapis.com/css?family=Noto+Sans+JP:100,200,300,regular,500,600,700,800,900&amp;display=swap\"> \n  <link rel=\"stylesheet\" type=\"text/css\" href=\"https://fonts.googleapis.com/css?family=Noto+Sans:100,200,300,regular,500,600,700,800,900,100italic,200italic,300italic,italic,500italic,600italic,700italic,800italic,900italic&amp;display=swap\"> \n  <link rel=\"stylesheet\" type=\"text/css\" href=\"https://module.bindsite.jp/type-fonts/css2-swap/mplus-1c-regular-swap.css\"> \n  <link rel=\"stylesheet\" type=\"text/css\" href=\"https://fonts.googleapis.com/css?family=Noto+Sans+JP:200&amp;display=swap\"> \n  <link rel=\"stylesheet\" type=\"text/css\" href=\"chief.css?1777131017926c0100\" id=\"page-css\">    \n  <link rel=\"stylesheet\" type=\"text/css\" href=\"../_csslinkbtn/btn-import.css?1769645477911\" id=\"linkbtn-css\"> \n  <!-- Google tag (gtag.js) --> \n  <script async src=\"https://www.googletagmanager.com/gtag/js?id=G-32DWVBZ0G4\"></script> \n  <script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'G-32DWVBZ0G4');\n</script> \n  <link rel=\"”canonical”\" href=\"”https://www.super-marui.com/recruit/”\"> \n </head> \n <body id=\"l-1\" class=\"l-1 -dress_b014006 bd-webp\" data-type=\"responsive\" data-ga-traking=\"true\" data-page-animation=\"none\"> \n  <div id=\"page\" class=\"bg-window \"> \n   <div class=\"bg-document\"> \n    <noscript> \n     <div id=\"js-off\"> \n      <img src=\"../_module/images/noscript.gif\" alt=\"Enable JavaScript in your browser. このウェブサイトはJavaScriptをオンにしてご覧下さい。\"> \n     </div> \n    </noscript> \n    <div id=\"a-header\" data-float=\"false\" class=\"a-header   cssskin-_area_header\"> \n     <header> \n      <div class=\"site_frame\"> \n       <section> \n        <div id=\"bk3102\" class=\"b-plain cssskin-_block_header\" data-bk-id=\"bk3102\"> \n         <div class=\" colu