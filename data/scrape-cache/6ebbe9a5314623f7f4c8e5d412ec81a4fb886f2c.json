li>\n            <li class=\"home-sponsoring__swiper__item swiper-slide\"> <a href=\"https://www.ajssa.or.jp/\" target=\"_blank\" class=\"home-sponsoring__swiper__link\"><img src=\"https://fuyou-g.com/contents/wp-content/themes/fuyou-child/assets/img/home/sponsoring-17.jpg\" alt=\"全国警備業協会\"></a> </li>\n            <li class=\"home-sponsoring__swiper__item swiper-slide\"> <a href=\"https://men-koubou.jp/\" target=\"_blank\" class=\"home-sponsoring__swiper__link\"><img src=\"https://fuyou-g.com/contents/wp-content/themes/fuyou-child/assets/img/home/sponsoring-19.jpg\" alt=\"麺工房ミタニ\"></a> </li>\n            <li class=\"home-sponsoring__swiper__item swiper-slide\"> <a href=\"https://www.mitohan.co.jp/\" target=\"_blank\" class=\"home-sponsoring__swiper__link\"><img src=\"https://fuyou-g.com/contents/wp-content/themes/fuyou-child/assets/img/home/sponsoring-20.jpg\" alt=\"有限会社川崎製麺所\"></a> </li>\n          </ul>\n          <div class=\"home-sponsoring__swiper__prev\"></div>\n          <div class=\"home-sponsoring__swiper__next\"></div>\n        </div>\n      </div>\n    </div>\n  </section>\n  <section class=\"home-about home-about--recruit\">\n    <div class=\"home-about__container\">\n      <h2 class=\"home-about__head\"><img src=\"https://fuyou-g.com/contents/wp-content/themes/fuyou-child/assets/img/home/recruit.svg\" alt=\"私たちと一緒に 採用情報\"></h2>\n      <div class=\"home-about__body\">\n        <div class=\"home-about__body__text\">\n          <p> 茨城の安全･安心快適を支える仕事。確かな信頼と心遣いで地域の生活をサポートしています。<br>\n            皆様のご応募をお待ちしております。 </p>\n        </div>\n        <div class=\"home-about__body__more\"> <a href=\"https://fuyou-g.com/recruit/\">View more</a> </div>\n      </div>\n      <div class=\"home-about__img\"><img src=\"https://fuyou-g.com/contents/wp-content/themes/fuyou-child/assets/img/home/recruit-illust.jpg\" alt=\"株式会社フヨウ採用情報\"></div>\n    </div>\n  </section>\n  <section class=\"home-news\">\n    <div class=\"home-news__container\">\n      <h2 class=\"home-news__head\">