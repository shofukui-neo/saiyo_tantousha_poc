li').removeClass('on');\n    \treturn false();\n    } else {\n       \t$('.header__navi > li').removeClass('on');\n        $(this).parent().addClass('on');\n    }\n  }\n  return false;\n  });\n \n//-------------------------------------------------事業紹介gnavi\n  $('.header-block .anchorcheck').click(function() {\n   $(this).parent('ul').parent('li').removeClass('on');\n  });\n  $('.header-block-sp .anchorcheck').click(function() {\n    var thisURL = $(this).children('a').attr('href');\n    $(this).parent('ul').parent('li').removeClass('on');\n    $('.gnav').fadeToggle();\n    $('.menu__line').toggleClass('active');\n    $('html').removeClass('scroll-prevent');\n  });\n\n  //-------------------------------------------------language\n  $('.hd_topnavi .language').click(function() {\n  \tif ($(this).hasClass('on')){\n   \t\t$(this).removeClass('on');\n  \t\treturn false();\n    } else {\n \t\t$(this).addClass('on');\n  \t\treturn false();\n    }\n  });\n \n //-------------------------------------------------PDF別ウィンドウ\n$(\"a[href$='pdf']\").each(function() {\n    $(this).click(function() {\n    if(!($(this).hasClass('button'))) {\n        window.open($(this).attr(\"href\"));\n        return false;\n    }\n    });\n});\n  });\n</script>\n\n\n\n\n<script>//NEWS 年別プルダウン\n$(function () { \n　　　　$(\".news-year-list_pulldown > a\").on(\"click\", function (e) {\n    \t$(this).parent().toggleClass(\"active\");\n\t\te.preventDefault();\n\n    });\n });\n</script>\n\n\t\n  </body>\n</html>\n","finalUrl":"https://www.parker.co.jp/ja/corporate/message.html","rendered":false,"_cachedAt":"2026-06-22T21:16:46.903Z"}