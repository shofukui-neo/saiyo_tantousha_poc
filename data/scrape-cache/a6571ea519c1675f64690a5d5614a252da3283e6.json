{"url":"https://www.next-1.co.jp/recruit/interview/kohyama/","html":"<!doctype html>\r\n<html><head prefix=\"og: https://ogp.me/ns#\">\r\n<meta charset=\"UTF-8\">\r\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n<meta http-equiv=\"X-UA-Compatible\" content=\"ie=edge\">\r\n<title>ネクスト・ワン株式会社 採用特設サイト - 医療用ガス、LP住宅設備機器、空調・生活関連商品、イベント・催事等のレンタル機器 -</title>\r\n<meta name=\"description\" content=\"医療用ガス、LP住宅設備機器、空調・生活関連商品、イベント・催事のレンタル機器はネクスト・ワンにお任せ下さい\" />\r\n<meta name=\"google-site-verification\" content=\"7r1WImGZILCy5zam830OzOSpFD5qQz6zFp_qzYlc8ZY\" />\r\n<meta property=\"og:url\" content=\"https://recruit.next-1.co.jp/\" />\r\n<meta property=\"og:type\" content=\"website\" />\r\n<meta property=\"og:title\" content=\"ネクスト・ワン株式会社 採用特設サイト\" />\r\n<meta property=\"og:description\" content=\"ネクスト・ワン株式会社 新卒・キャリア採用 特設サイト\" />\r\n<meta property=\"og:site_name\" content=\"ネクスト・ワン株式会社 採用特設サイト\" />\r\n<meta property=\"og:image\" content=\"\" />\r\n\r\n<!-- css -->\r\n<link rel=\"stylesheet\" href=\"../../css/reset.css\">\r\n<link rel=\"stylesheet\" href=\"../../css/common.css\">\r\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/yakuhanjp@3.4.1/dist/css/yakuhanjp.min.css\">\r\n<link href=\"https://use.fontawesome.com/releases/v5.6.1/css/all.css\" rel=\"stylesheet\">\r\n\r\n<!-- webfonts -->\r\n<link rel=\"stylesheet\" href=\"https://use.typekit.net/ddp3pmr.css\">\r\n\r\n<!--Google Fonts-->\r\n<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\r\n<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\r\n<link href=\"https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500;600;700&family=Roboto:wght@100&display=swap\" rel=\"stylesheet\"> \r\n\r\n<!-- Google Tag Manager -->\r\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\r\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\r\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\r\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\r\n})(window,document,'script','dataLayer','GTM-TLWT6JLC');</script>\r\n<!-- End Google Tag Manager --><link href=\"../../css/interview_dtl.css\" rel=\"stylesheet\" type=\"text/css\">\r\n</head>\r\n\r\n<body>\r\n<header id=\"header\">\r\n<h1 class=\"header_logo\"><a href=\"../../index.php\"><img src=\"../../img/common/head_logo.svg\" alt=\"ネクスト・ワン株式会社 採用特設サイト\"/></a></h1>\r\n\r\n<nav class=\"g_navi\">\r\n<ul>\r\n<li><a href=\"../../message/\"><span class=\"roll_txt\"><span class=\"en\">MESSAGE</span><span class=\"ja\">メッセージ</span></span></a></li>\r\n<li><a href=\"../../company/\"><span class=\"roll_txt\"><span class=\"en\">COMPANY</span><span class=\"ja\">会社を知る</span></span></a></li>\r\n<li><a href=\"../../service/\"><span class=\"roll_txt\"><span class=\"en\">SERVICE</span><span class=\"ja\">仕事を知る</span></span></a></li>\r\n<li><a href=\"../../interview/\"><span class=\"roll_txt\"><span class=\"en\">INTERVIEW</span><span class=\"ja\">人を知る</span></span></a></li>\r\n<li><a href=\"../../culture/\"><span class=\"roll_txt\"><span class=\"en\">CULTURE</span><span class=\"ja\">環境・制度</span></span></a></li>\r\n<li><a href=\"../../faq/\"><span class=\"roll_txt\"><span class=\"en\">FAQ</span><span class=\"ja\">質問</span></span></a></li>\r\n<li><a href=\"../../contact/\"><span class=\"roll_txt\"><span class=\"en\">CONTACT</span><span class=\"ja navi_contact\">お問い合わせ</span></span></a></li>\r\n</ul>\r\n\r\n<div class=\"entry_box\">\r\n<a href=\"../../entry/\">\r\n<span class=\"roll_txt\">\r\n<span class=\"en\">ENTRY</span>\r\n<span class=\"ja\">エントリー</span>\r\n</span>\r\n</a>\r\n</div>\r\n</nav>\r\n</header>\r\n\r\n\r\n<div class=\"openbtn\"><span></span><span></span><span></span></div>\r\n<nav id=\"open_navi\">\r\n<div class=\"open_navi_list\">\r\n<p class=\"ham_logo\"><img src=\"../../img/common/ham_logo.svg\" alt=\"\"/></p>\r\n<ul>\r\n<li><a href=\"../../\">TOP<span class=\"ham_menu_ja\">トップ</span></a></li> \r\n<li><a href=\"../../message/\">MESSAGE<span class=\"ham_menu_ja\">メッセージ</span></a></li>\r\n<li><a href=\"../../company/\">COMPANY<span class=\"ham_menu_ja\">会社を知る</span></a></li> \r\n<li><a href=\"../../service/\">SERVICE<span class=\"ham_menu_ja\">仕事を知る</span></a></li> \r\n<li><a href=\"../../interview/\">INTERVIEW<span class=\"ham_menu_ja\">人を知る</span></a></li>\r\n<li><a href=\"../../culture/\">CULTURE<span class=\"ham_menu_ja\">環境・制度</span></a></li> \r\n<li><a href=\"../../faq/\">FAQ<span class=\"ham_menu_ja\">よくあるご質問</span></a></li> \r\n<li><a href=\"../../contact/\">CONTACT<span class=\"ham_menu_ja\">お問い合わせ</span></a></li> \r\n<li><a href=\"../../entry/\">ENTRY<span class=\"ham_menu_ja\">エントリー</span></a></li> \r\n</ul>\r\n</div>\r\n</nav>\r\n<section class=\"interview_main\">\r\n<div class=\"image_box\">\r\n<picture>\r\n<source media=\"(max-width: 767px)\" srcset=\"../../img/interview/kohyama/main_img_sp.png\"/>\r\n<img src=\"../../img/interview/kohyama/main_img.jpg\" alt=\"\">\r\n</picture>\r\n</div>\r\n\r\n<div class=\"interview_titlebox\">\r\n<p class=\"interview_en_title\">Next One Story #02</p>\r\n\r\n<h2 class=\"interview_jp_title\">\r\n<span class=\"title_inside\"><span class=\"opc\">しっかりと安定感のある会社で</span></span><br>\r\n<span class=\"title_inside\"><span class=\"opc\">日々、経験を積んでレベルアップ。</span></span>\r\n</h2>\r\n\r\n<div class=\"interview_box_inner\">\r\n<p class=\"year color_wht\">2021年 新卒入社</p>\r\n<p class=\"interview_name color_wht\">香山 美沙希</p>\r\n<p class=\"affiliation color_wht\">本店営業本部 レンタル部</p>\r\n<!--end div.interview_box_inner -->\r\n</div>\r\n<!--end div.interview_titlebox -->\r\n</div>\r\n</section>\r\n\r\n<div class=\"profile_sec\">\r\n<div class=\"box_s\">\r\n<h3 class=\"interview_name_en\">Misaki Kouyama</h3>\r\n<p class=\"episode_tilte\">EPISODE 0</p>\r\n<p class=\"profile_title_jp\">プロフィール/入社理由</p>\r\n<p class=\"profile_txt\">ネクスト・ワンとの出会いは学校の就職説明会。豪華な社員旅行の話を聞いて利益をしっかり出している会社だと思って入社を希望。<br>\r\n実際に仕事に従事してみて会社の堅実さと安定感を実感。レンタル事業部勤務。趣味は旅行とグルメ。</p>\r\n\r\n<!--end div.profile_inner -->\r\n</div>\r\n<!--end div.profile_sec -->\r\n</div>\r\n\r\n<main>\r\n<div class=\"content page_interview_dtl\">\r\n<section class=\"interview_sec\">\r\n\r\n<div class=\"p-sec_03\">\r\n<div class=\"p-sec_03_bg\">\r\n<span class=\"p-sec_03_bg_inner\"></span>\r\n</div>\r\n\r\n<div class=\"p-sec_03_txt_left_ph\">\r\n<img src=\"../../img/interview/kohyama/img01.jpg\" alt=\"\"/>\r\n<p class=\"sec_javacom_title\">Job Rule</p>\r\n</div>\r\n\r\n<div class=\"p-sec_03_txt\">\r\n<div class=\"p-sec_03_txt_left\">\r\n\r\n<!--end div.p-sec_01_txt_left -->\r\n</div>\r\n\r\n<div class=\"p-sec_03_txt_right\">\r\n<p class=\"episode_txt\">EPISODE 01</p>\r\n<h4 class=\"p-sec_heading_copy\">発送・納品・管理・確認<br>\r\nスムーズな進行で安心と安全を確保。</h4>\r\n\r\n<h5 class=\"p-sec_heading_q\">あなたの現在の仕事内容を教えてください</h5>\r\n<p class=\"p-sec__sentence\">レンタル事業部で電話対応、配送、請求、入金管理などの業務を担当しています。中でもボリュームを占めるのは配送関連業務で、発送・納品の確認や段取りの確認を毎日行います。コロナ禍の頃はイベントの中止などで停滞感がありましたが、最近は状況も活発になり案件の数も増えてきて嬉しい思いもありますが、件数が増えても丁寧に進められるよう気を引き締めて取り組んでいます。見積り・請求などのお金に関することにも携わるので気を遣う部分もありますが、営業の方と連携しての二重にチェックを徹底して安心と安全を確保するように努めています。<br><br>\r\n\r\n業務では「良品の提供」「クレーム発生防止」の２点に気をつけ、商品の状況チェック、洗浄・動作確認、補修の要不要などの確認が速やかに行われるように各所と連携して、指示を出す場合には「わかりやすく的確な指示」が出せるように気をつけています。</p>\r\n<!--end div.p-sec_01_txt_right -->\r\n</div>\r\n<!--end div.p-sec_01_txt -->\r\n</div>\r\n<!--end div.p-sec_01 -->\r\n</div>\r\n\r\n<div class=\"p-sec_02\">\r\n<div class=\"p-sec_02_bg\">\r\n<span class=\"p-sec_02_bg_inner\"></span>\r\n</div>\r\n\r\n<div class=\"p-sec_02_txt_right_ph\">\r\n<img src=\"../../img/interview/kohyama/img02.jpg\" alt=\"\"/>\r\n<p class=\"sec_javacom_title\">Rewarding</p>\r\n</div>\r\n\r\n<div class=\"p-sec_02_txt\">\r\n<div class=\"p-sec_02_txt_left\">\r\n<p class=\"episode_txt\">EPISODE 02</p>\r\n<h4 class=\"p-sec_heading_copy\">充実感と達成感を大切に、<br>\r\n根気と強気で臨機応変に頑張ります。</h4>\r\n\r\n<h5 class=\"p-sec_heading_q\">仕事のやりがいを教えてください</h5>\r\n\r\n<p class=\"p-sec__sentence\">仕事では「充実感」と「達成感」を大切にしたいと考えていて、何事にも丁寧な姿勢で確認を怠らず真摯に臨むように心がけています。突然発生した機材トラブルや緊急の案件に対して的確に対応が行えた時は、プレッシャーも凄いですがその分大きな喜びを感じます。<br><br>\r\n\r\n年末年始などの繁忙期には需要の高い商品へのオーダーの集中や急な追加など難しい問題が発生するなど、予定通りに行かないこともたくさんありますが、倉庫や業者間の連携を密にとったり、現場での効果的な売り場づくりから考察を行ってプランニングをするなど、臨機応変な対応ができるよう根気と強気で機転を効かせて頑張っています。<br><br>\r\n\r\nお客さまが必要としていることを分析して、想定外のことも含めていろいろな方向から提案出来た時。機材の問い合わせやトラブルシューティングなどで問題を捉えて的確に応えることが出来た時。案件を締めて請求書をお送りする時。お客さまの課題を解決することが出来て感謝の言葉をいただいた時。その時、その瞬間のそれぞれに大いに達成感を感じて清々しい気持ちになります。</p>\r\n<!--end div.p-sec_02_txt_left -->\r\n</div>\r\n\r\n<div class=\"p-sec_02_txt_right\">\r\n<!--end div.p-sec_02_txt_rigfht -->\r\n</div>\r\n<!--end div.p-sec_02_txt -->\r\n</div>\r\n<!--end div.p-sec_02 -->\r\n</div>\r\n\r\n\r\n<div class=\"p-sec_03\">\r\n<div class=\"p-sec_03_bg\">\r\n<span class=\"p-sec_03_bg_inner\"></span>\r\n</div>\r\n\r\n<div class=\"p-sec_03_txt_left_ph\">\r\n<img src=\"../../img/interview/kohyama/img03.jpg\" alt=\"\"/>\r\n<p class=\"sec_javacom_title\">Future goals</p>\r\n</div>\r\n\r\n<div class=\"p-sec_03_txt\">\r\n<div class=\"p-sec_03_txt_left\">\r\n\r\n<!--end div.p-sec_01_txt_left -->\r\n</div>\r\n\r\n<div class=\"p-sec_03_txt_right\">\r\n<p class=\"episode_txt\">EPISODE 03</p>\r\n<h4 class=\"p-sec_heading_copy\">努力と時間と経験を蓄積して<br>\r\n豊かな人生にしたい。</h4>\r\n\r\n<h5 class=\"p-sec_heading_q\">これからの目標を教えてください</h5>\r\n<p class=\"p-sec__sentence\">お客さまや営業の方が求めている事を察知して、求められるよりも先に提供できるようになりたいです。主体的・客観的な様々な視点から分析してお客さまの意向を捉えたり、営業バックアップ業務として見積書を作成したりスケジュールを共有するなど、一緒に仕事を進めさせていただく方の役に立てるよう細かな気遣いが出来るように成長していきたいです。目の前の事だけではなく周囲をちゃんと見て、営業の方やお客さまの求めているよりもそれ以上の成果を出せるよう頑張りたいと考えています。<br><br>\r\n\r\nプライベートでの目標は、旅行が好きなので、ホテルステイやグルメの趣味を充実させて、綺麗な景色を見たり、雄大な自然を感じたり、美味しいご飯をいただいたり、価値の高い時間と良質な経験を自分の中に蓄積していきたいと思っています。しっかり働いて稼いで、いろいろな所にアクティブに出かけていける人間を目指しています。ネクスト・ワンは福利厚生が手厚くて「休み」もしっかり取れるので、仕事も休日もメリハリ効かせて、人生を豊かにしていきたいです。</p>\r\n<!--end div.p-sec_01_txt_right -->\r\n</div>\r\n<!--end div.p-sec_01_txt -->\r\n</div>\r\n<!--end div.p-sec_01 -->\r\n</div>\r\n\r\n<!--end interview_sec -->\r\n</section>\r\n\r\n\r\n<section class=\"schedule\">\r\n<div class=\"schedule_inner\">\r\n\r\n<div class=\"schedule_title_wrap\">\r\n<p class=\"schedule_title_jp\">ある一日のスケジュール</p>\r\n<p class=\"schedule_title_en\">DAIRY SCHEDULE</p>\r\n</div>\r\n\r\n<div class=\"sch_area_inner\">\r\n<div>\r\n<div class=\"schedule_box\">\r\n<p class=\"schedule_time\">08:15</p>\r\n<dl>\r\n<dt>出 社</dt>\r\n<dd>メールと一日の予定を確認。</dd>\r\n</dl>\r\n<!--end div.schedule_box -->\r\n</div>\r\n\r\n<div class=\"schedule_box\">\r\n<p class=\"schedule_time\">08:30</p>\r\n<dl>\r\n<dt>業務開始</dt>\r\n<dd>当日の発送の確認と変更の有無などをチェック。</dd>\r\n</dl>\r\n<!--end div.schedule_box -->\r\n</div>\r\n\r\n<div class=\"schedule_box\">\r\n<p class=\"schedule_time\">09:00</p>\r\n<dl>\r\n<dt>業 務</dt>\r\n<dd>いろいろな仕事があるので、優先順位をつけ効率よく進めます。</dd>\r\n</dl>\r\n<!--end div.schedule_box -->\r\n</div>\r\n\r\n<div class=\"schedule_box\">\r\n<p class=\"schedule_time\">12:00</p>\r\n<dl>\r\n<dt>ランチ</dt>\r\n<dd>仕事の事は一旦忘れてリフレッシュ。</dd>\r\n</dl>\r\n<!--end div.schedule_box -->\r\n</div>\r\n\r\n\r\n<div class=\"schedule_box\">\r\n<p class=\"schedule_time\">13:00</p>\r\n<dl>\r\n<dt>午後の業務開始</dt>\r\n<dd>入金確認や請求書作成、翌日の配送の管理など。</dd>\r\n</dl>\r\n<!--end div.schedule_box -->\r\n</div>\r\n\r\n<div class=\"schedule_box\">\r\n<p class=\"schedule_time\">17:15</p>\r\n<dl class=\"circle_end\">\r\n<dt>終 業 / 退 社</dt>\r\n<dd>翌日のスケジュールを確認して退社。</dd>\r\n</dl>\r\n<!--end div.schedule_box -->\r\n</div>\r\n\r\n</div>\r\n<!--end div.sch_area -->\r\n</div>\r\n<!--end div.schedule_inner -->\r\n</div>\r\n</section>\r\n\r\n<section class=\"movie_sec\">\r\n<div class=\"movie_pv_wrap\">\r\n<video class=\"movie_pvbox\" muted autoplay loop playsinline>\r\n<source src=\"../../img/interview/kohyama/interview.mp4\" type=\"video/mp4\" class=\"recruit_pv\">\r\n</video>\r\n</div>\r\n</section>\r\n\r\n<div class=\"message_box\">\r\n<p class=\"message_read\">就職活動中の皆さんへメッセージ</p>\r\n<p class=\"message_title\">チャレンジの場をたくさん与えてくれる職場で一緒に成長しましょう。</p>\r\n<p class=\"message_txt\">豪華な社員旅行に行ったり、毎年11月に開催されるトータルフェアという催しに社員皆んなで取り組んで頑張ったり、通常業務以外にもたくさんのイベントがあるので、目標をもって毎日業務にとりかかることができます。同世代の方も多く、会社の雰囲気も良くて、お給料もたくさん貰えてると思います。お休みもしっかりとあるし有給休暇も取得しやすいので、平日も休日も充実した毎日を過ごせます。趣味や家族との時間などを大切にしたい方、アクティブに色々やりたい方、ぜひ興味を持ってトライしてみてください。</p>\r\n\r\n\r\n<!--end div.message_box -->\r\n</div>\r\n<div class=\"other_sec\">\r\n<div class=\"sec_titlebox\">\r\n<h4 class=\"sec_title\">OTHER INTERVIEW</h4>\r\n<p class=\"sec_subtitle\">その他のインタビュー</p>\r\n</div>\r\n\r\n\r\n<div class=\"interview_box_wrap\">\r\n<div class=\"interview_box\">\r\n<div class=\"img_box\">\r\n<a href=\"../kamei/\"><img src=\"../../img/interview/thum01_on.jpg\" alt=\"\"/>\r\n<img src=\"../../img/interview/thum01_off.jpg\" alt=\"\"/>\r\n</a>\r\n</div>\r\n\r\n<p class=\"career\">中 途</p>\r\n<p class=\"interview_name_en\">Kentaro Kamei</p>\r\n\r\n<div class=\"interview_box_inner\">\r\n<p class=\"year\">2022年 中途入社</p>\r\n<p class=\"affiliation\">本店営業本部 ガス溶材部</p>\r\n<p class=\"interview_name\">亀井 健太郎</p>\r\n<!--end div.interview_box_inner -->\r\n</div>\r\n<!--end div.interview_box -->\r\n</div>\r\n\r\n\r\n<div class=\"interview_box\">\r\n<div class=\"img_box\">\r\n<a href=\"../haraguchi/\"><img src=\"../../img/interview/thum03_on.jpg\" alt=\"\"/>\r\n<img src=\"../../img/interview/thum03_off.jpg\" alt=\"\"/>\r\n</a>\r\n</div>\r\n\r\n<p class=\"career\">新 卒</p>\r\n<p class=\"interview_name_en\">Chiaki Haraguchi</p>\r\n\r\n<div class=\"interview_box_inner\">\r\n<p class=\"year\">2016年 新卒入社</p>\r\n<p class=\"affiliation\">管理部 一般事務</p>\r\n<p class=\"interview_name\">原口 千昌</p>\r\n<!--end div.interview_box_inner -->\r\n</div>\r\n<!--end div.interview_box -->\r\n</div>\r\n<!--end div.interview_box_wrap -->\r\n</div>\r\n<!--end div.other_sec -->\r\n</div>\r\n<!--end div.content -->\r\n</div>\r\n</main>\r\n\r\n<footer>\r\n<section class=\"sec_movie\">\r\n<div class=\"entry_pv_wrap\">\r\n<video class=\"entry_pvbox\" muted autoplay loop playsinline>\r\n<source src=\"../../img/common/entry_pv.mp4\" type=\"video/mp4\" class=\"entry_pv\">\r\n</video>\r\n\r\n<div class=\"entry_title_wrap\">\r\n<figure class=\"entry_copy\"><img src=\"../../img/common/foot_copy.svg\" alt=\"\"/></figure>\r\n<div class=\"circle_btn\"><a href=\"../../entry/\" class=\"btn-txt\">More Info</a></div>\r\n<!--end div.movie_title_wrap -->\r\n</div>\r\n\r\n<!--end div.recruit_pv_wrap -->\r\n</div>\r\n</section>\r\n\r\n<section class=\"footer_inner\">\r\n<div class=\"box_m\">\r\n<p class=\"foot_logo\"><img src=\"../../img/common/foot_logo.svg\" alt=\"\"/></p>\r\n<p class=\"foot_office_txt\">【KAKOGAWA HEAD OFFICE 】 </p>\r\n<p class=\"foot_addless\">〒 675-0039<br class=\"sp-hidden\">\r\n兵庫県加古川市加古川町粟津805-3　<br class=\"pc-hidden\">\r\nTEL：079-421-1111  FAX：079-425-8981</p>\r\n<p class=\"foot_link_txt\"><a href=\"../../privacy/\">プライバシー・ポリシー</a> /  <a class=\"blk_icon\" href=\"https://www.next-1.co.jp/\" target=\"_blank\">コーポレートサイト</a></p>\r\n<small class=\"copyright\">COPYRIGHT &copy;  NEXT ONE CO., LTD. ALL RIGHT RESERVED.</small>\r\n<!--end div.box_m -->\r\n</div>\r\n\r\n<!--end div.footer_inner -->\r\n</section>\r\n</footer>\r\n\r\n<div class=\"page_top\"><a href=\"#\"></a></div><!--jQuery-->\r\n<script src=\"https://ajax.googleapis.com/ajax/libs/jquery/3.6.1/jquery.min.js\"></script>\r\n<!-- ハンバーガーメニュー-->\r\n<script src=\"../../js/hamburgermenu.js\"></script>\r\n<!--Page top-->\r\n<script src=\"../../js/pagetop.js\"></script></body>\r\n</html>","finalUrl":"https://www.next-1.co.jp/recruit/interview/kohyama/","rendered":false,"_cachedAt":"2026-06-22T22:31:46.869Z"}