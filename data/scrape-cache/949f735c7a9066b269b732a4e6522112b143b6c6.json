{"url":"https://www.melec.co.jp/recruit/sales/","html":"<!DOCTYPE html>\n<html lang=\"ja\" prefix=\"og: http://ogp.me/ns# fb: http://ogp.me/ns/fb# website: http://ogp.me/ns/website#\">\n<head>\n<!-- Global site tag (gtag.js) - Google Analytics -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=UA-41737289-1\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'UA-41737289-1');\n</script><meta charset=\"UTF-8\">\n<title>営業部　社員インタビュー ｜ 株式会社メレック</title>\n<meta name=\"description\" content=\"営業部：株式会社メレックの社員インタビューです。\">\n<meta name=\"keyword\" content=\"太陽光発電,自動ドア修理,自動ドア施工,自動ドア保守\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0, user-scalable=no, minimum-scale=1.0, maximum-scale=1.0\">\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n<link rel=\"canonical\" href=\"https://www.melec.co.jp/recruit/sales/\">\n<meta name=\"format-detection\" content=\"telephone=no\">\n<meta property=\"og:title\" content=\"株式会社メレック - 岡山の太陽光・自動ドア\" />\n<meta property=\"og:description\" content=\"信頼と実績のメレック。三菱電気代理店、自動ドアナブコの岡山代理店。太陽光発電と自動ドアの修理・施工・保守のことならおまかせください。\"/>\n<meta property=\"og:image\" content=\"https://www.melec.co.jp/common/img/common/ogimage.jpg\" />\n<meta property=\"og:site_name\" content=\"https://www.melec.co.jp/\" />\n<meta property=\"og:url\" content=\"https://www.melec.co.jp/recruit/sales/\" />\n<meta property=\"og:type\" content=\"article\">\n<meta name=\"twitter:title\" content=\"株式会社メレック - 岡山の太陽光・自動ドア\" />\n<meta name=\"twitter:description\" content=\"信頼と実績のメレック。三菱電気代理店、自動ドアナブコの岡山代理店。太陽光発電と自動ドアの修理・施工・保守のことならおまかせください。\">\n<meta name=\"twitter:image\" content=\"https://www.melec.co.jp/common/img/common/ogimage.jpg\">\n<meta name=\"twitter:url\" content=\"https://www.melec.co.jp/recruit/sales/\" />\n<meta name=\"twitter:card\" content=\"summary\" />\n<link rel=\"apple-touch-icon-precomposed\" href=\"https://www.melec.co.jp/common/img/common/apptouch.png\">\n<link rel=\"shortcut icon\" href=\"/common/img/common/favicon.ico\">\n<link rel=\"stylesheet\" href=\"/common/css/common.css\">\n<link rel=\"stylesheet\" href=\"/common/css/base.css\"><link rel=\"stylesheet\" href=\"/common/css/recruit.css\">\n</head>\n<body>\n  <div id=\"wrapper\" class=\"profile\">\n    <header class=\"header\" id=\"header\"><!-- header -->\n      <div class=\"wrap\">\n        <div class=\"header_top\">\n          <a href=\"/\" class=\"link_logo\"><img src=\"/common/img/common/logo.png\" alt=\"ロゴ：株式会社メレックのロゴです。\"></a>\n          <ul class=\"btn_sp_wrap for_sp\">\n            <li class=\"btn_sp tel\">\n              <a href=\"tel:0862550055\"><img src=\"/common/img/common/ico_tel.gif\" alt=\"ボタン：株式会社メレックに電話をかけます\"></a>\n            </li>\n            <li class=\"btn_sp nav\" id=\"btn_nav\">\n              <a href=\"\">\n                <span class=\"line\"></span>\n                <span class=\"line\"></span>\n                <span class=\"line\"></span>\n              </a>\n            </li>\n          </ul>\n          <a href=\"/contact/\" class=\"link_contact for_pc\">お問い合わせ</a>\n        </div>\n        <nav class=\"header_nav\" id=\"nav\">\n          <ul class=\"header_nav_in\">\n            <li class=\"link_par_wrap\"><a href=\"/solution/\" class=\"link_par img solution\">導入をご検討の方</a></li>\n            <li class=\"link_par_wrap\"><a href=\"/maintenance/\" class=\"link_par img maintenance\">保守をご検討の方</a></li>\n            <li class=\"link_par_wrap\"><a href=\"/repair/\" class=\"link_par img repair\">修理をご希望の方</a></li>\n            <li class=\"link_par_wrap js_btn_par\">\n              <span class=\"btn_inner\">事業情報</span>\n              <ul class=\"box_link_chi\">\n                <li class=\"link_chi_wrap\"><a href=\"/solution/?s=area_solution\" class=\"link_chi\">事業内容</a></li>\n                <li class=\"link_chi_wrap\"><a href=\"/service/\" class=\"link_chi\">取扱製品</a></li>\n                <li class=\"link_chi_wrap\"><a href=\"/case/\" class=\"link_chi\">納入事例</a></li>\n              </ul>\n            </li>\n            <li class=\"link_par_wrap js_btn_par\">\n              <span class=\"btn_inner\">会社情報</span>\n              <ul class=\"box_link_chi\">\n                <li class=\"link_chi_wrap\"><a href=\"/info/\" class=\"link_chi\">お知らせ</a></li>\n                <li class=\"link_chi_wrap\"><a href=\"/message/\" class=\"link_chi\">メッセージ</a></li>\n                <li class=\"link_chi_wrap\"><a href=\"/profile/\" class=\"link_chi\">会社概要</a></li>\n                <li class=\"link_chi_wrap\"><a href=\"/history/\" class=\"link_chi\">沿革</a></li>\n              </ul>\n            </li>\n            <li class=\"link_par_wrap js_btn_par\">\n              <span class=\"btn_inner\">採用情報</span>\n              <ul class=\"box_link_chi\">\n                <li class=\"link_chi_wrap\"><a href=\"/recruit/\" class=\"link_chi\">採用情報トップ</a></li>\n                <li class=\"link_chi_wrap\"><a href=\"/recruit/fresh/\" class=\"link_chi\">新卒採用情報</a></li>\n                <li class=\"link_chi_wrap\"><a href=\"/recruit/career/\" class=\"link_chi\">キャリア採用情報</a></li>\n                <li class=\"link_chi_wrap\"><a href=\"/recruit/event/\" class=\"link_chi\">採用イベント情報</a></li>\n                <li class=\"link_chi_wrap\"><a href=\"/recruit/sales/\" class=\"link_chi\">営業部</a></li>\n                <li class=\"link_chi_wrap\"><a href=\"/recruit/engineer/\" class=\"link_chi\">技術部</a></li>\n                <li class=\"link_chi_wrap\"><a href=\"/recruit/service/\" class=\"link_chi\">保守サービス部</a></li>\n                <li class=\"link_chi_wrap\"><a href=\"/recruit/affairs/\" class=\"link_chi\">総務部</a></li>\n              </ul>\n            </li>\n            <li class=\"link_par_wrap for_sp\"><a href=\"/info/\" class=\"link_par\">お知らせ</a></li>\n          </ul>\n          <a href=\"/contact/\" class=\"link_contact for_sp\">お問い合わせフォーム</a>\n        </nav>\n      </div>\n      <script>(function(){\n        var w=window,d=document;\n        var s=\"https://app.chatplus.jp/cp.js\";\n        d[\"__cp_d\"]=\"https://app.chatplus.jp\";\n        d[\"__cp_c\"]=\"420a45ed_1\";\n        var a=d.createElement(\"script\"), m=d.getElementsByTagName(\"script\")[0];\n        a.async=true,a.src=s,m.parentNode.insertBefore(a,m);})();\n      </script>\n    </header><!-- header/ -->\n  <div class=\"area_pginfo\">\n    <h1 class=\"ttl_page row2\">メレックをつくる人<span class=\"sub\">部署別社員インタビュー</span></h1>\n    <ol class=\"pnkz_wrap\">\n      <li class=\"pnkz\"><a href=\"/\">TOP</a></li>\n      <li class=\"pnkz\"><a href=\"/recruit/\">採用情報</a></li>\n      <li class=\"pnkz\">メレックをつくる人</li>\n    </ol>\n  </div>\n  <div class=\"bg\">\n    <section class=\"area_interview sales\"><!-- area_interview -->\n      <h2 class=\"ttl_interview\">営業部</h2>\n      <article class=\"box_interview people01\"><!-- box_interview -->\n        <div class=\"wrap\">\n          <div class=\"box_top\">\n            <figure class=\"fig_img\"><img src=\"/common/img/recruit/sales/img_main_01.jpg\" alt=\"\"></figure>\n            <div class=\"box_intro\">\n              <img src=\"/common/img/recruit/sales/txt_01.gif\" class=\"catch\" alt=\"計画的にコツコツと\">\n              <p class=\"txt\">営業部　ドアシステム課<br>2015年入社</p>\n            </div>\n          </div>\n          <div class=\"box_col2\">\n            <div class=\"box_main\"><!-- box_main -->\n              <div class=\"box_article\">\n                <h3 class=\"ttl_article\">地域に貢献できる営業マンを目指して</h3>\n                <p class=\"txt\">私は、自動ドアを納入させていただいたお客様を中心に、より快適に、そして安心してご使用いただくために、保守点検や修理、機器の更新などの提案営業を行っています。</p>\n                <p class=\"txt\">私たちの提供する自動ドアは、高齢者やハンディキャップを持った方々は無論のこと、快適な生活を営む為にも特に必要な設備であり、人に優しい重要な社会インフラの一つです。お客様の求めている様々なニーズにお応えしていくためには、多岐に渡る商材の製品知識、各業界の情報などの取得や、実際に工事する技術員との連携などが欠かせません。</p>\n                <p class=\"txt\">大変なことも多いですが、地域の方々が快適で安全な暮らしやすい街づくりの一端に携われるこの仕事に、喜びとやりがいを感じています。</p>\n              </div>\n              <div class=\"area_bg\">\n                <div class=\"box_graph\">\n                  <h3 class=\"ttl_graph\">性格グラフ</h3>\n                  <img src=\"/common/img/recruit/sales/img_graph_01.png\" alt=\"優しさ9、冷静さ7、明るさ5、我慢強さ7、厳しさ6\">\n                </div>\n                <div class=\"box_comment\">\n                  <h3 class=\"ttl_comment\">同僚からひと言</h3>\n                  <img src=\"/common/img/recruit/sales/txt_comment_01.png\" class=\"img_comment\" alt=\"ぶれない芯を持った人\">\n                  <img src=\"/common/img/recruit/img_people.png\" class=\"img_people\" alt=\"\">\n                </div>\n              </div>\n              <div class=\"box_will for_pc\">\n                <h3 class=\"ttl_will\"><img src=\"/common/img/recruit/ttl_will_pc.png\" alt=\"わたしの志\"></h3>\n                <p class=\"txt\">誠実に<br>ひたむきに<br>考え抜く</p>\n              </div>\n            </div><!-- box_main/ -->\n            <div class=\"box_side\"><!-- box_side/ -->\n              <div class=\"box_day1\">\n                <h3 class=\"ttl_day1\">一日の流れ</h3>\n                <dl class=\"day1\">\n                  <dt class=\"time\">8:00</dt>\n                  <dd class=\"work\">\n                    <span class=\"main\">出社</span><br>メール、営業先のチェック\n                  </dd>\n                  <dt class=\"time\">8:25</dt>\n                  <dd class=\"work\">\n                    <span class=\"main\">体操・全体朝礼</span>\n                  </dd>\n                  <dt class=\"time\">8:40</dt>\n                  <dd class=\"work\">\n                    <span class=\"main\">課内朝礼</span><br>進捗状況報告・当日の営業訪問先確認\n                  </dd>\n                  <dt class=\"time\">10:00</dt>\n                  <dd class=\"work\">\n                    <span class=\"main\">保守メンテナンスの提案</span>\n                  </dd>\n                  <dt class=\"time\">12:00</dt>\n                  <dd class=\"work\">\n                    <span class=\"main\">昼食</span>\n                  </dd>\n                  <dt class=\"time\">13:00</dt>\n                  <dd class=\"work\">\n                    <span class=\"main\">機器の古くなった営業先へ<br>自動ドア更新の提案</span>\n                  </dd>\n                  <dt class=\"time\">15:00</dt>\n                  <dd class=\"work\">\n                    <span class=\"main\">新規営業先へ<br>自動ドア更新の提案</span>\n                  </dd>\n                  <dt class=\"time\">17:00</dt>\n                  <dd class=\"work\">\n                    <span class=\"main\">帰社・社内業務</span><br>見積等書類作成\n                  </dd>\n                  <dt class=\"time\">19:00</dt>\n                  <dd class=\"work\">\n                    <span class=\"main\">退社</span>\n                  </dd>\n                </dl>\n              </div>\n              <div class=\"box_fav\">\n                <h3 class=\"ttl_fav\"><span class=\"txt\">わたしのイチオシ</span></h3>\n                <img src=\"/common/img/recruit/sales/img_fav_01.jpg\" alt=\"ニコンのカメラ\">\n              </div>\n              <div class=\"box_will for_sp\">\n                <h3 class=\"ttl_will\"><img src=\"/common/img/recruit/ttl_will_sp.png\" alt=\"わたしの志\"></h3>\n                <p class=\"txt\">誠実に<br>ひたむきに<br>考え抜く</p>\n              </div>\n            </div><!-- box_side/ -->\n          </div>\n        </div>\n      </article><!-- box_interview/ -->\n\n      <article class=\"box_interview people02\"><!-- box_interview -->\n        <div class=\"wrap\">\n          <div class=\"box_top\">\n            <figure class=\"fig_img\"><img src=\"/common/img/recruit/sales/img_main_02.jpg\" alt=\"\"></figure>\n            <div class=\"box_intro\">\n              <img src=\"/common/img/recruit/sales/txt_02.gif\" class=\"catch\" alt=\"人にやさしく ここちよく\">\n              <p class=\"txt\">営業部<br>2017年入社</p>\n            </div>\n          </div>\n          <div class=\"box_col2\">\n            <div class=\"box_main\"><!-- box_main -->\n              <div class=\"box_article\">\n                <h3 class=\"ttl_article\">提案型営業の後方支援で会社を盛り上げる</h3>\n                <p class=\"txt\">私は営業部と技術部技術課において、後方支援業務を担当しています。<br>\n                まだ入社して日も浅く、知らないことも多い為、学ぶことがとても多い仕事です。<br>\n                現在は、社内書類や注文書・請求書の作成管理、案件の確認などを担当していますが、日々研鑚を重ね、自分にできることを考え工夫し、時には自ら提案しながら意欲的に取り組んでいます。</p>\n                <p class=\"txt\">また日々の仕事とは別に、社内プロジェクトへ参加する機会も与えられています。<br>\n                最近では、社用車のラッピングプロジェクトへ参加し、自分たちが考えたコンセプトとデザインが、2018年3月に実際にラッピング車となり街を走り出しました。<br>\n                こうした部署を超えた活動の中で自分の役割を持ち、会社を盛り上げていくことも<br>\n                とてもやりがいを感じられる、私たちの重要な仕事の1つです。\n                </p>\n                <p class=\"txt\">今後は、より深く仕事の流れや内容・意味を理解し、自分がすべきこと・できることを自ら先立って考え行動していけるよう、励んでまいります。</p>\n              </div>\n              <div class=\"area_bg\">\n                <div class=\"box_graph\">\n                  <h3 class=\"ttl_graph\">性格グラフ</h3>\n                  <img src=\"/common/img/recruit/sales/img_graph_02.png\" alt=\"優しさ10、冷静さ8、明るさ1、我慢強さ8、厳しさ4\">\n                </div>\n                <div class=\"box_comment\">\n                  <h3 class=\"ttl_comment\">同僚からひと言</h3>\n                  <img src=\"/common/img/recruit/sales/txt_comment_02.png\" class=\"img_comment\" alt=\"現代の大和撫子\">\n                  <img src=\"/common/img/recruit/img_people.png\" class=\"img_people\" alt=\"\">\n                </div>\n              </div>\n              <div class=\"box_will for_pc\">\n                <h3 class=\"ttl_will\"><img src=\"/common/img/recruit/ttl_will_pc.png\" alt=\"わたしの志\"></h3>\n                <p class=\"txt\">考え、<br>行動し、<br>成長し続ける。</p>\n              </div>\n            </div><!-- box_main/ -->\n            <div class=\"box_side\"><!-- box_side/ -->\n              <div class=\"box_day1\">\n                <h3 class=\"ttl_day1\">一日の流れ</h3>\n                <dl class=\"day1\">\n                  <dt class=\"time\">7:00</dt>\n                  <dd class=\"work\">\n                    <span class=\"main\">起床・準備</span>\n                  </dd>\n                  <dt class=\"time\">8:15</dt>\n                  <dd class=\"work\">\n                    <span class=\"main\">出社</span><br>社内掲示板・FAXなどの確認\n                  </dd>\n                  <dt class=\"time\">8:25</dt>\n                  <dd class=\"work\">\n                    <span class=\"main\">体操・全体朝礼</span>\n                  </dd>\n                  <dt class=\"time\">8:40</dt>\n                  <dd class=\"work\">\n                    <span class=\"main\">部内朝礼</span><br>進捗状況の確認、当日の営業先を情報共有\n                  </dd>\n                  <dt class=\"time\">9:00</dt>\n                  <dd class=\"work\">\n                    <span class=\"main\">資料作成・電話対応</span><br>社内書類や注文書・請求書の作成\n                  </dd>\n                  <dt class=\"time\">12:00</dt>\n                  <dd class=\"work\">\n                    <span class=\"main\">昼食</span>\n                  </dd>\n                  <dt class=\"time\">13:00</dt>\n                  <dd class=\"work\">\n                    <span class=\"main\">資料作成</span><br>午前中の続き、書類整理<br>営業社員から日中依頼された書類の作成\n                  </dd>\n                  <dt class=\"time\">17:00</dt>\n                  <dd class=\"work\">\n                    <span class=\"main\">報告・その他</span><br>帰社後の営業社員へ作成資料や郵便など、各書類の報告・確認\n                  </dd>\n                  <dt class=\"time\">18:00</dt>\n                  <dd class=\"work\">\n                    <span class=\"main\">退社</span>\n                  </dd>\n                  <dt class=\"time\">18:30</dt>\n                  <dd class=\"work\">\n                    <span class=\"main\">夕食の買い出しやショッピング</span>\n                  </dd>\n                  <dt class=\"time\">20:30</dt>\n                  <dd class=\"work\">\n                    <span class=\"main\">旦那さんと一緒に、ごはんを作って食べる</span>\n                  </dd>\n                  <dt class=\"time\">24:00</dt>\n                  <dd class=\"work\">\n                    <span class=\"main\">就寝</span>\n                  </dd>\n                </dl>\n              </div>\n              <div class=\"box_fav\">\n                <h3 class=\"ttl_fav\"><span class=\"txt\">わたしのイチオシ</span></h3>\n                <img src=\"/common/img/recruit/sales/img_fav_02.jpg\" alt=\"雑貨\">\n              </div>\n              <div class=\"box_will for_sp\">\n                <h3 class=\"ttl_will\"><img src=\"/common/img/recruit/ttl_will_sp.png\" alt=\"わたしの志\"></h3>\n                <p class=\"txt\">考え、<br>行動し、<br>成長し続ける。</p>\n              </div>\n            </div><!-- box_side/ -->\n          </div>\n        </div>\n      </article><!-- box_interview/ -->\n\n      <article class=\"box_interview people03\"><!-- box_interview -->\n        <div class=\"wrap\">\n          <div class=\"box_top\">\n            <figure class=\"fig_img\"><img src=\"/common/img/recruit/sales/img_main_03.jpg\" alt=\"\"></figure>\n            <div class=\"box_intro\">\n              <img src=\"/common/img/recruit/sales/txt_03.gif\" class=\"catch\" alt=\"やるときはやる\">\n              <p class=\"txt\">営業部　社会システム課<br>2010年入社</p>\n            </div>\n          </div>\n          <div class=\"box_col2\">\n            <div class=\"box_main\"><!-- box_main -->\n              <div class=\"box_article\">\n                <h3 class=\"ttl_article\">既成概念を捨て、真心をもつ</h3>\n                <p class=\"txt\">社会システム課は、地域におけるインフラ整備や防災対策、地球温暖化対策等に対して、システム提案や情報を発信する部署です。<br>\n                私たちの仕事は、ただ単に「モノを売る」ことではありません。顧客や地域が抱えている問題は何なのか、どのような改善策が最適なのか、顧客と共に問題の真因を考え、解決を図っていくことにあります。その為には商品知識や業務知識はもちろんのこと、相手の立場に立って物事を考えることができる広い視野や様々な知識・経験が必要となります。</p>\n                <p class=\"txt\">私が営業活動の中で大切にしていることは、顧客の立場に立って考え、「真心を持って取り組む事」と固定概念に捉われず「どうすれば解決出来るか」を本気で考えることです。それが出来、顧客の方との信頼関係が生まれた時、仕事の喜びと達成感を感じています。</p>\n              </div>\n              <div class=\"area_bg\">\n                <div class=\"box_graph\">\n                  <h3 class=\"ttl_graph\">性格グラフ</h3>\n                  <img src=\"/common/img/recruit/sales/img_graph_03.png\" alt=\"優しさ5、冷静さ9、明るさ3、我慢強さ3、厳しさ7\">\n                </div>\n                <div class=\"box_comment\">\n                  <h3 class=\"ttl_comment\">同僚からひと言</h3>\n                  <img src=\"/common/img/recruit/sales/txt_comment_03.png\" class=\"img_comment\" alt=\"熱く冷静沈着な人\">\n                  <img src=\"/common/img/recruit/img_people.png\" class=\"img_people\" alt=\"\">\n                </div>\n              </div>\n              <div class=\"box_will for_pc\">\n                <h3 class=\"ttl_will\"><img src=\"/common/img/recruit/ttl_will_pc.png\" alt=\"わたしの志\"></h3>\n                <p class=\"txt\">真心を持って、<br>物事に接し、<br>新しい提案を。</p>\n              </div>\n            </div><!-- box_main/ -->\n            <div class=\"box_side\"><!-- box_side/ -->\n              <div class=\"box_day1\">\n                <h3 class=\"ttl_day1\">一日の流れ</h3>\n                <dl class=\"day1\">\n                  <dt class=\"time\">8:15</dt>\n                  <dd class=\"work\">\n                    <span class=\"main\">出社・メールチェック</span>\n                  </dd>\n                  <dt class=\"time\">8:25</dt>\n                  <dd class=\"work\">\n                    <span class=\"main\">体操・全体朝礼</span>\n                  </dd>\n                  <dt class=\"time\">8:40</dt>\n                  <dd class=\"work\">\n                    <span class=\"main\">部内朝礼</span><br>進捗状況確認・営業訪問先確認\n                  </dd>\n                  <dt class=\"time\">8:50</dt>\n                  <dd class=\"work\">\n                    <span class=\"main\">社内業務　書類確認等</span>\n                  </dd>\n                  <dt class=\"time\">9:30</dt>\n                  <dd class=\"work\">\n                    <span class=\"main\">営業</span>\n                  </dd>\n                  <dt class=\"time\">12:00</dt>\n                  <dd class=\"work\">\n                    <span class=\"main\">昼食</span>\n                  </dd>\n                  <dt class=\"time\">13:00</dt>\n                  <dd class=\"work\">\n                    <span class=\"main\">営業</span>\n                  </dd>\n                  <dt class=\"time\">17:00</dt>\n                  <dd class=\"work\">\n                    <span class=\"main\">帰社・社内業務　書類作成等</span>\n                  </dd>\n                  <dt class=\"time\">19:00</dt>\n                  <dd class=\"work\">\n                    <span class=\"main\">退社</span>\n                  </dd>\n                </dl>\n              </div>\n              <div class=\"box_fav\">\n                <h3 class=\"ttl_fav\"><span class=\"txt\">わたしのイチオシ</span></h3>\n                <img src=\"/common/img/recruit/sales/img_fav_03.jpg\" alt=\"柔道着\">\n              </div>\n              <div class=\"box_will for_sp\">\n                <h3 class=\"ttl_will\"><img src=\"/common/img/recruit/ttl_will_sp.png\" alt=\"わたしの志\"></h3>\n                <p class=\"txt\">真心を持って、<br>物事に接し、<br>新しい提案を。</p>\n              </div>\n            </div><!-- box_side/ -->\n          </div>\n        </div>\n      </article><!-- box_interview/ -->\n    </section><!-- area_interview/ -->\n\n    <ul class=\"link_depertment_wrap\">\n      <li class=\"link_depertment sales\"><a href=\"/recruit/sales/\"><span class=\"txt\">営業部</span></a></li>\n      <li class=\"link_depertment engineer\"><a href=\"/recruit/engineer/\"><span class=\"txt\">技術部</span></a></li>\n      <li class=\"link_depertment service\"><a href=\"/recruit/service/\"><span class=\"txt\">保守サービス部</span></a></li>\n      <li class=\"link_depertment affairs\"><a href=\"/recruit/affairs/\"><span class=\"txt\">総務部</span></a></li>\n    </ul>\n  </div>\n    <footer class=\"footer\"><!-- footer -->\n      <div class=\"wrap\">\n        <ul class=\"footer_menu_wrap\">\n          <li class=\"footer_menu\">\n            <a href=\"/solution/\" class=\"solution\">\n              <div class=\"box_img\"><img src=\"/common/img/common/ico_solution_w.png\" alt=\"\"></div>導入をご検討の方\n            </a>\n          </li>\n          <li class=\"footer_menu\">\n            <a href=\"/maintenance/\" class=\"maintenance\">\n              <div class=\"box_img\"><img src=\"/common/img/common/ico_maintena