mage\">\r\n                    <img loading=\"lazy\" decoding=\"async\" src=\"/assets/img/company/top/index_image_history@2x.jpg\" alt=\"\" width=\"720\" height=\"480\">\r\n                  </figure>\r\n                  <p class=\"indexblock__label\">\r\n                    沿革\r\n                  </p>\r\n                </a>\r\n              </div>\r\n\r\n              <div class=\"indexblock__item\">\r\n                <a href=\"/company/executives/\">\r\n                  <figure class=\"indexblock__image\">\r\n                    <img loading=\"lazy\" decoding=\"async\" src=\"/assets/img/company/top/index_image_executives@2x.jpg\" alt=\"\" width=\"720\" height=\"480\">\r\n                  </figure>\r\n                  <p class=\"indexblock__label\">\r\n                    経営メンバー\r\n                  </p>\r\n                </a>\r\n              </div>\r\n\r\n              <div class=\"indexblock__item\">\r\n                <a href=\"https://www.simplex.inc/company/client/\" target=\"_blank\" rel=\"noopener\">\r\n                  <figure class=\"indexblock__image\">\r\n                    <img loading=\"lazy\" decoding=\"async\" src=\"/assets/img/company/top/index_image_client@2x.jpg\" alt=\"\" width=\"720\" height=\"480\">\r\n                  </figure>\r\n                  <p class=\"indexblock__label\">\r\n                    主要取引先\r\n                  </p>\r\n                </a>\r\n              </div>\r\n\r\n            </div>\r\n          </div>\r\n          <!-- /indexblock -->\r\n\r\n          <div class=\"title h2\">\r\n            <div class=\"title__label\">Business Domain</div>\r\n            <h2 class=\"title__summary\">公的機関や金融機関、各業界をリードする企業のDX推進を支援</h2>\r\n          </div>\r\n          \r\n          <!-- insight -->\r\n          <div class=\"insight js-insight\">\r\n            <div class=\"insight__lists js-insightslide\">\r\n\r\n              <div class=\"insight__list js-insightitem\">\r\n                <div class=\"insight__list__wrapper\">\r\n                  <div class=\"insight__column\">\r\n                    <figure class=\"insight__image\">\r\n                      <img decoding=\"async\" src=\"../assets/img/business/top/index_image_domain_01@2x.jpg\" alt=\"\" class=\"js-objectfit\">\r\n                    </figure>\r\n                  </div>\r\n                  <div class=\"insight__column\">\r\n                    <p class=\"insight__subject\">\r\n                      #01 銀行×Simplex\r\n                    </p>\r\n                    <p class=\"insight__summary\">\r\n                      クオンツ、トレーディング、リスク管理など高度な金融技術をコアとした、表面的なDXではない真の業務変革を支援することにより、銀行業界の価値増大に貢献しています。日本を代表する銀行の皆様も厳格な選定プロセスを経て、シンプレクスを選択しています。\r\n                    </p>\r\n                  </div>\r\n                </div>\r\n              </div>\r\n\r\n              <div class=\"insight__list js-insightitem\">\r\n                <div class=\"insight__list__wrapper\">\r\n                  <div class=\"insight__column\">\r\n                    <figure class=\"insight__image\">\r\n                      <img decoding=\"async\" src=\"../assets/img/business/top/index_image_domain_02@2x.jpg\" alt=\"\" class=\"js-objectfit\">\r\n                    </figure>\r\n                  </div>\r\n                  <div class=\"insight__column\">\r\n                    <p class=\"insight__subject\">\r\n                      #02 証券×Simplex\r\n                    </p>\r\n                    <p class=\"insight__summary\">\r\n                      テクノロジーの進展により変革期を迎えた証券業界。リテール部門やホールセール部門を主な対象として、証券業務とテクノロジーの双方のナレッジを活用することで、プロジェクトの構想から収益化まであらゆる過程を一気通貫で支援しています。\r\n                    </p>\r\n                  </div>\r\n                </div>\r\n              </div>\r\n\r\n              <div class=\"insight__list js-insightitem\">\r\n                <div class=\"insight__list__wrapper\">\r\n                  <div class=\"insight__column\">\r\n                    <figure class=\"insight__image\">\r\n                      <img decoding=\"async\" src=\"../assets/img/business/top/index_image_domain_03@2x.jpg\" alt=\"\" class=\"js-objectfit\">\r\n                    </figure>\r\n                  </div>\r\n                  <div class=\"insight__column\">\r\n                    <p class=\"insight__subject\">\r\n                      #03 保険×Simplex\r\n                    </p>\r\n                    <p class=\"insight__summary\">\r\n                      即急なデジタル変革が求められている保険業界のDXを支援しています。生命保険、損害保険における深い業務理解が評価され、近年の異業種からの保険事業参入や海外からの国内保険事業進出のビジネスパートナーとして、数多くの支援を実施しています。\r\n                    </p>\r\n                  </div>\r\n                </div>\r\n              </div>\r\n\r\n              <div class=\"insight__list js-insightitem\">\r\n                <div class=\"insight__list__wrapper\">\r\n                  <div class=\"insight__column\">\r\n                    <figure class=\"insight__image\">\r\n                      <img decoding=\"async\" src=\"../assets/img/business/top/index_image_domain_04@2x.jpg\" alt=\"\" class=\"js-objectfit\">\r\n                    </figure>\r\n                  </div>\r\n                  <div class=\"insight__column\">\r\n                    <p class=\"insight__subject\">\r\n                      #04 FX×Simplex\r\n                    </p>\r\n                    <p class=\"insight__summary\">\r\n                      FＸ業界に向けて、豊富な導入実績を誇る取引プラットフォームや、マーケットトレンドに合わせた細やかなコンサルティングサービスを提供しています。事業の迅速立ち上げからサービス拡充まで、FXビジネスの収益最大化に貢献しています。\r\n                    </p>\r\n                  </div>\r\n                </div>\r\n              </div>\r\n\r\n              <div class=\"insight__list js-insightitem\">\r\n                <div class=\"insight__list__wrapper\">\r\n                  <div class=\"insight__column\">\r\n                    <figure class=\"insight__image\">\r\n                      <img decoding=\"async\" src=\"../assets/img/business/top/index_image_domain_05@2x.jpg\" alt=\"\" class=\"js-objectfit\">\r\n                    </figure>\r\n                  </div>\r\n                  <div class=\"insight__column\">\r\n                    <p class=\"insight__subject\">\r\n                      #05 暗号資産×Simplex\r\n                    </p>\r\n                    <p class=\"insight__summary\">\r\n                      ここ数年で急速な拡大をみせる暗号資産市場。FX・暗号資産領域で長年培ったノウハウアセットの活用と、豊富な導入実績を誇る暗号資産取引ソリューションの提供を通じて、セキュアで短期間な事業の立ち上げに貢献しています。\r\n                    </p>\r\n                  </div>\r\n                </div>\r\n              </div>\r\n\r\n              <div class=\"insight__list js-insightitem\">\r\n                <div class=\"insight__list__wrapper\">\r\n                  <div class=\"insight__column\">\r\n                    <figure class=\"insight__image\">\r\n                      <img decoding=\"async\" src=\"../assets/img/business/top/index_image_domain_06@2x.jpg\" alt=\"\" class=\"js-objectfit\">\r\n                    </figure>\r\n                  </div>\r\n                  <div class=\"insight__column\">\r\n                    <p class=\"insight__subject\">\r\n                      #06 建設×Simplex\r\n                    </p>\r\n                    <p class=\"insight__summary\">\r\n                      建設業界においても、レガシーシステムからの早期脱却をテーマとしたDX推進が求められています。複雑な建設業固有業務への対応が求められるゼネコン各社の基幹業務・システムに精通したテクノロジーパートナーとして、DX推進に貢献しています。\r\n                    </p>\r\n                  </div>\r\n                </div>\r\n              </div>\r\n\r\n              <div class=\"insight__list js-insightitem\">\r\n                <div class=\"insight__list__wrapper\">\r\n                  <div class=\"insight__column\">\r\n                    <figure class=\"insight__image\">\r\n                      <img decoding=\"async\" src=\"../assets/img/business/top/index_image_domain_07@2x.jpg\" alt=\"\" class=\"js-objectfit\">\r\n                    </figure>\r\n                  </div>\r\n                  <div class=\"insight__column\">\r\n                    <p class=\"insight__subject\">\r\n                      #07 公共×Simplex\r\n                    </p>\r\n                    <p class=\"insight__summary\">\r\n                      これまで培ってきたさまざまな知見や高い技術力を活かし、政府官公庁、地方自治体、独立行政法人などのパブリックセクターにおけるDXを支援しています。各種規制を理解したうえで、ニューノーマル時代に沿った行政機関の変革に貢献しています。\r\n                    </p>\r\n                  </div>\r\n                </div>\r\n              </div>\r\n\r\n              <div class=\"insight__list js-insightitem\">\r\n                <div class=\"insight__list__wrapper\">\r\n                  <div class=\"insight__column\">\r\n                    <figure class=\"insight__image\">\r\n                      <img decoding=\"async\" src=\"../assets/img/business/top/index_image_domain_08@2x.jpg\" alt=\"\" class=\"js-objectfit\">\r\n                    </figure>\r\n                  </div>\r\n                  <div class=\"insight__column\">\r\n                    <p class=\"insight__subject\">\r\n                      #08 製造×Simplex\r\n                    </p>\r\n                    <p class=\"insight__summary\">\r\n                      サプライチェーンに対する豊富な業務知見を活かし、過去の商慣行からの脱却を目指す製造業界のDXを支援しています。製造業をよりスマートな形に洗練するべく、さらなる生産性の向上を見込んだ環境構築（インダストリー5.0）に貢献しています。\r\n                    </p>\r\n                  </div>\r\n                </div>\r\n              </div>\r\n\r\n            </div>\r\n            <div class=\"insight__meter\">\r\n              <div class=\"meter js-meter\">\r\n                <div class=\"meter__page meter__page--current js-metercurrent\">\r\n                  00\r\n                </div>\r\n                <div class=\"meter__progress\">\r\n                  <div class=\"meter__bar js-meterbar\"></div>\r\n                </div>\r\n                <div class=\"meter__page meter__page--total js-metertotal\">\r\n                  00\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n          <!-- /insight -->\r\n\r\n          <div class=\"title h2\">\r\n            <div class=\"title__label\">Simplex by Numbers</div>\r\n            <h2 class=\"title__summary\">数字で見るシンプレクス</h2>\r\n          </div>\r\n          \r\n          <!-- numerical -->\r\n          <div class=\"numerical numerical--col4 numerical__has--caption\">\r\n            <div class=\"numerical__list\">\r\n              <p class=\"numerical__label\">\r\n                創業\r\n              </p>\r\n              <figure class=\"center\">\r\n                <img decoding=\"async\" src=\"/assets/img/company/top/number_icon_established.svg\" alt=\"\" width=\"100\">\r\n              </figure>\r\n              <p class=\"numerical__number\">\r\n                1997<small>年</small>9<small>月</small>\r\n              </p>\r\n            </div>\r\n            <div class=\"numerical__list list__has--caption\">\r\n              <p class=\"numerical__label\">\r\n                連結従業員数\r\n              </p>\r\n              <figure class=\"center\">\r\n                <img decoding=\"async\" src=\"/assets/img/company/top/number_icon_employees.svg\" alt=\"\" width=\"100\">\r\n              </figure>\r\n              <p class=\"numerical__number\">\r\n                2,121<small>名</small>\r\n              </p>\r\n              <p class=\"numerical__caption\">2026年4月1日現在</p>\r\n            </div>\r\n            <div class=\"numerical__list list__has--caption\">\r\n              <p class=\"numerical__label\">\r\n                連結売上収益\r\n              </p>\r\n              <figure class=\"center\">\r\n                <img decoding=\"async\" src=\"/assets/img/company/top/number_icon_profit.svg\" alt=\"\" width=\"100\">\r\n              </figure>\r\n              <p class=\"numerical__number\">\r\n                586<small>億円</small>\r\n              </p>\r\n              <p class=\"numerical__caption\">2026年3月期</p>\r\n            </div>\r\n            <div class=\"numerical__list list__has--caption\">\r\n              <p class=\"numerical__label\">\r\n                連結営業利益\r\n              </p>\r\n              <figure class=\"center\">\r\n                <img decoding=\"async\" src=\"/assets/im