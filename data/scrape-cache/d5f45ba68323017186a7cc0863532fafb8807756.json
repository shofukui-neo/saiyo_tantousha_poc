{"url":"https://www.yaskawa.co.jp/recruit/recruit/requirement.html","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n\n<head>\n\t<meta charset=\"utf-8\">\n\t<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n\t<meta name=\"format-detection\" content=\"telephone=no\">\n\t<title>募集要項｜株式会社安川電機｜採用情報</title>\n\t<meta name=\"description\" content=\"安川電機の募集要項についてはこちらをご覧ください。安川電機は、独自の技術力と製品で、世界中のものづくりの品質と生産効率の向上に貢献しています。\">\n\t<link rel=\"stylesheet\" href=\"../assets/css/style.css\">\n\t<link rel=\"stylesheet\" href=\"../assets/css/add202112.css\">\n\t<script src=\"../assets/js/main-bundle.js\" defer></script>\n\t<script src=\"/recruit/assets/js/common.js\" defer></script>\n\t<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\">\n\t<!-- Noto Sans 400 500 900 -->\n\t<link href=\"https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&display=swap\" rel=\"stylesheet\">\n\t<!-- Roboto 500 italic -->\n\t<link href=\"https://fonts.googleapis.com/css2?family=Roboto:ital,wght@1,500&display=swap\" rel=\"stylesheet\">\n\t<!-- Roboto 400 700 -->\n\t<link href=\"https://fonts.googleapis.com/css2?family=Roboto:wght@400;700&display=swap\" rel=\"stylesheet\">\n\t<!-- Hind 400 700 -->\n\t<link href=\"https://fonts.googleapis.com/css2?family=Hind:wght@400;700&display=swap\" rel=\"stylesheet\">\n\t<!-- Google Tag Manager -->\n\t<script>\n\t\t(function(w, d, s, l, i) {\n\t\t\tw[l] = w[l] || [];\n\t\t\tw[l].push({\n\t\t\t\t'gtm.start': new Date().getTime(),\n\t\t\t\tevent: 'gtm.js'\n\t\t\t});\n\t\t\tvar f = d.getElementsByTagName(s)[0],\n\t\t\t\tj = d.createElement(s),\n\t\t\t\tdl = l != 'dataLayer' ? '&l=' + l : '';\n\t\t\tj.async = true;\n\t\t\tj.src = 'https://www.googletagmanager.com/gtm.js?id=' + i + dl;\n\t\t\tf.parentNode.insertBefore(j, f);\n\t\t})(window, document, 'script', 'dataLayer', 'GTM-KJJZWHQ');\n\n\t</script>\n\t<!-- End Google Tag Manager -->\n</head>\n\n<body>\n\t<!-- Google Tag Manager (noscript) -->\n\t<noscript><iframe src