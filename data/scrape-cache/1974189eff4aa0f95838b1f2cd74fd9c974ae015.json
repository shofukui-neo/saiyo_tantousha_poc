awer-hamburger\">\n\t\t<span class=\"sr-only\">Menu</span>\n\t\t<span class=\"drawer-hamburger-icon\"></span>\n\t</button>\n\t<!-- logo -->\n\t<h1 id=\"logo\"><a href=\"/recruit/\"><img src=\"/recruit/img/common/logo.png\" alt=\"KAGATA採用情報　RECRUIT SITE\"></a></h1>\n\t<!-- headernav_wrap -->\n\t<div id=\"headernav_wrap\" class=\"drawer-nav\">\n\t\t<div id=\"gnav\" role=\"navigation\">\n\t\t\t<nav>\n\t\t\t\t<ul class=\"drawer-menu\">\n\t\t\t\t\t<li><a href=\"/recruit/\">ホーム</a></li>\n\t\t\t\t\t<li><a href=\"/recruit/message/\">社長メッセージ</a></li>\n\t\t\t\t\t<li><a href=\"/page/recruitNew/\">新卒採用</a></li>\n\t\t\t\t\t<li class=\"select\"><a href=\"/page/recruitCareer/\">キャリア採用</a></li>\n\t\t\t\t\t<li><a href=\"/recruit/voice/\">先輩の声</a></li>\n\t\t\t\t\t<li><a href=\"/recruit/#employee\">人材育成</a></li>\n\t\t\t\t\t<li><a href=\"https://blog.kagata.co.jp/recruit/\" target=\"_blank\">人事ブログ</a></li>\n\t\t\t\t</ul>\n\t\t\t</nav>\n\t\t</div>\n\t\t<ul id=\"entrynav\">\n\t\t\t<li><a href=\"/page/recruitNew/#entry_cover\">ENTRY<span class=\"arrow\"><i class=\"fas fa-chevron-right\"></i></span></a></li>\n\t\t</ul>\n\t\t<ul id=\"othernav\">\n\t\t\t<li><a href=\"/contact/\" target=\"_blank\"><i class=\"fas fa-envelope\"></i>お問い合わせ</a></li>\n\t\t\t<li>人事直通／平日9:00～17:00<a href=\"tel:0252478188\"><i class=\"fas fa-phone fa-rotate-90\"></i><span>025-247-8188</span></a></li>\n\t\t</ul>\n\t</div><!-- /headernav_wrap -->\n</header><!-- /header -->\n\n<!-- maintitle -->\n<div id=\"maintitle\">\n\t<div class=\"maintitle_inner\">\n\t\t<h1><span class=\"en\">CAREERS</span>キャリア採用</h1>\n\t</div>\n</div><!-- /maintitle -->\n\n<!-- breadcrumb -->\n<div id=\"breadcrumb\">\n\t<ul>\n\t\t<li><a href=\"/recruit/\">ホーム</a></li>\n\t\t<li>キャリア採用</li>\n\t</ul>\n</div><!-- /breadcrumb -->\n\n<main id=\"contents\">\n\t<div class=\"container\">\n\t\t<p><span style=\"color:#009900;\"><strong><span style=\"font-size:20px;\">◆ 募集職種 ◆</span></strong></span><br />\r\n&nbsp;</p>\r\n\r\n<p><strong>加賀田組 キャリア採用ＰＲ動画</strong><br />\r\n<a href=\"https://convert.jobtv.mynavi.jp/rlink?uc=343492of4486251\" rel=\"noreferrer\" target=\"_blank\">https://convert.jobtv.mynavi.jp/rlink?uc=343492of4486251</a><br />\r\n<br />\r\n&nbsp;</p>\r\n<span style=\"font-size:14px;\">【施工管理（土木・建築・舗道）】新潟本社新潟支店・東京本社東京支店・東北支店<br />\r\n　＊建設工事における施工管理（原価・品質・工程・環境・安全等）<br />\r\n<br />\r\n【電気設備・機械設備施工管理】新潟本社新潟支店・東京本社東京支店<br />\r\n　＊建築物の電気設備・機械設備施工管理業務<br />\r\n<br />\r\n【構造設計】東京本社東京支店<br />\r\n　＊建築物の構造設計業務</span><br />\r\n<br />\r\n<span style=\"font-size:14px;\"><span style=\"font-family: メイリオ, Meiryo, &quot;ヒラギノ角ゴ Pro W3&quot;, &quot;Hiragino Kaku Gothic Pro&quot;, &quot;ＭＳ Ｐゴシック&quot;; background-color: rgb(255, 255, 255);\">【安全監理】新潟本店・新潟本社新潟支店・東京本社東京支店</span><br style=\"font-family: メイリオ, Meiryo, &quot;ヒラギノ角ゴ Pro W3&quot;, &quot;Hiragino Kaku Gothic Pro&quot;, &quot;ＭＳ Ｐゴシック&quot;; font-size: 13.3333px; background-color: rgb(255, 255, 255);\" />\r\n<span style=\"font-family: メイリオ, Meiryo, &quot;ヒラギノ角ゴ Pro W3&quot;, &quot;Hiragino Kaku Gothic Pro&quot;, &quot;ＭＳ Ｐゴシック&quot;; background-color: rgb(255, 255, 255);\">　＊建設現場での安全監理業務（安全パトロール、指導等）<br />\r\n<br />\r\n【情報システム】新潟本店<br />\r\n　＊最新デジタル技術の調査・分析<br />\r\n　＊各部署への生成ＡＩ技術活用の提案・指導等</span></span>\r\n\r\n<p><br />\r\n<br />\r\n募集要項についての詳細は、<br />\r\n<span style=\"font-size:18px;\"><strong><a href=\"https://tenshoku.mynavi.jp/company/343492/joblist/\">マイナビ転職</a></strong></span><br />\r\n<span style=\"font-size:18px;\"><strong><a href=\"https://www.hellowork.mhlw.go.jp/index.html\">ハローワーク</a></strong></span>にてご確認下さい。</p>\r\n<strong style=\"font-size: 10pt;\"><span style=\"font-size:14px;\">◆　お問い合わせ先　◆</span></strong>\r\n\r\n<div class=\"box02\">\r\n<div class=\"form_tel\">\r\n<div class=\"form_btn\"><a href=\"/contact/\" target=\"_blank\">メールフォームでのお問い合わせ</a></div>\r\n\r\n<div class=\"contact_tel\">\r\n<p><strong>管理本部人事部</strong><br />\r\n電話：025-247-8188（直通）<br class=\"br_none\" />\r\nE-mail：<a href=\"mailto:jinji@kagata.co.jp\">jinji@kagata.co.jp</a></p>\r\n</div>\r\