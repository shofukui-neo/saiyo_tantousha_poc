  <input class=\"lib-search__input\" type=\"search\" name=\"schKeyword\" placeholder=\"サイト内検索\" autocomplete=\"off\">\r\n                  <button class=\"lib-search__btn\" type=\"submit\"><span class=\"sr-only\">検索する</span></button>\r\n                </div>\r\n              </form>\r\n            </div>\r\n            <!-- [END lib-search__outer]-->\r\n            <ul class=\"lib-lang__outer js-scroll-out\">\r\n              <li><a href=\"/\" aria-current=\"page\">JP</a></li>\r\n              <li><a href=\"/en.html\">EN</a></li>\r\n              <li><a href=\"/cn.html\">CN</a></li>\r\n            </ul>\r\n            <!-- [END lib-lang__outer]-->\r\n            <div class=\"lib-utility__outer js-scroll-out\">\r\n              <ul class=\"lib-utility__list\">\r\n                <li class=\"lib-utility__item\"><a class=\"js-scroll-out\" href=\"/prototype.html\"><span class=\"txt\">試作のご相談</span></a></li>\r\n                <li class=\"lib-utility__item\"><a class=\"js-scroll-out\" href=\"/sample.html\"><span class=\"txt\">サンプル依頼</span></a></li>\r\n                <li class=\"lib-utility__item\"><a class=\"js-scroll-out\" href=\"/news.html\" target=\"\"><span class=\"txt\">お知らせ</span></a></li>\r\n              </ul>\r\n            </div>\r\n            <!-- [END lib-utility__outer]-->\r\n            <ul class=\"lib-nav__list js-child__list\" id=\"lib-header-nav\" tabindex=\"0\">\r\n              <!-- [START li.lib-nav__item]-->\r\n              <li class=\"lib-nav__item\"><a class=\"lib-nav__btn js-child__focus\" href=\"/about.html\" target=\"\"><span class=\"txt\">京都グレインシステム(株)について</span></a></li>\r\n              <!-- [END li.lib-nav__item]-->\r\n              <!-- [START .lib-nav__item]-->\r\n              <li class=\"lib-nav__item js-gnav__item\">\r\n                <button class=\"lib-nav__btn js-child__focus js-child__btn\" aria-expanded=\"false\" aria-controls=\"panel-about\"><span class=\"txt\">事業内容</span></button>\r\n                <div class=\"lib-child__panel js-child__panel\" aria-hidden=\"true\" id=\"panel-about\">\r\n                  <div class=\"lib-child__outer\">\r\n                    <div class=\"lib-child__item --headline\"><a href=\"/business.html\" target=\"\"><span class=\"txt\">事業内容 <span class=\"d-inline-block d-sm-none\">TOP</span></span></a></div>\r\n                    <!-- [END .lib-child__item-->\r\n                    <ul class=\"lib-child__list\">\r\n                      <!-- [START .lib-child__item]-->\r\n                      <li class=\"lib-child__item\"><a href=\"/business/processing.html\"><span class=\"txt\">受託加工</span></a></li>\r\n                      <!-- [START .lib-child__item]-->\r\n                      <li class=\"lib-child__item\"><a href=\"/business/sales.html\"><span class=\"txt\">製品販売</span></a></li>\r\n                      <!-- [START .lib-child__item]-->\r\n                      <li class=\"lib-child__item\"><a href=\"/business/development.html\"><span class=\"txt\">開発支援</span></a></li>\r\n                      <!-- [START .lib-child__item]-->\r\n                      <li class=\"lib-child__item\"><a href=\"/business/abroad.html\"><span class=\"txt\">海外輸出入</span></a></li>\r\n                    </ul>\r\n                  </div>\r\n                  <!-- [END .lib-child__outer]-->\r\n                </div>\r\n                <!-- [END lib-child__panel]-->\r\n              </li>\r\n              <!-- [END li.lib-nav__item]-->\r\n              <!-- [START li.lib-nav__item]-->\r\n              <li class=\"lib-nav__item\"><a class=\"lib-nav__btn js-child__focus\" href=\"/faq.html\" target=\"\"><span class=\"txt\">よくあるご質問</span></a></li>\r\n              <!-- [END li.lib-nav__item]-->\r\n              <!-- [START .lib-nav__item]-->\r\n              <li class=\"lib-nav__item js-gnav__item\">\r\n                <button class=\"lib-nav__btn js-child__focus js-child__btn\" aria-expanded=\"false\" aria-controls=\"panel-about\"><span class=\"txt\">SDGs宣言</span></button>\r\n                <div class=\"lib-child__panel js-child__panel\" aria-hidden=\"true\" id=\"panel-about\">\r\n                  <div class=\"lib-child__outer\">\r\n                    <div class=\"lib-child__item --headline\"><a href=\"/sdgs.html\" target=\"\"><span class=\"txt\">SDGs宣言<span class=\"d-inline-block d-sm-none\">TOP</span></span></a></div>\r\n                    <!-- [END .lib-child__item-->\r\n                    <ul class=\"lib-child__list\">\r\n                      <!-- [START .lib-child__item]-->\r\n                      <li class=\"lib-child__item\"><a href=\"/sdgs/envi.html\"><span class=\"txt\">環境経営</span></a></li>\r\n                      <!-- [START .lib-child__item]-->\r\n                      <li class=\"lib-child__item\"><a href=\"/sdgs/fooddesign.html\"><span class=\"txt\">食品設計</span></a></li>\r\n                      <!-- [START .lib-child__item]-->\r\n                      <li class=\"lib-child__item\"><a href=\"/sdgs/social.html\"><span class=\"txt\">社会調和</span></a></li>\r\n                    </ul>\r\n                  </div>\r\n                  <!-- [END .lib-child__outer]-->\r\n                </div>\r\n                <!-- [END lib-child__panel]-->\r\n              </li>\r\n              <!-- [END li.lib-nav__item]-->\r\n              <!-- [START li.lib-nav__item]-->\r\n              <li class=\"lib-nav__item\"><a class=\"lib-nav__btn js-child__focus\" href=\"/careers.html\" target=\"\"><span class=\"txt\">採用情報</span></a></li>\r\n              <!-- [END li.lib-nav__item]-->\r\n              <!-- [START li.lib-nav__item]-->\r\n              <li class=\"lib-nav__item\"><a class=\"lib-nav__btn js-child__focus\" href=\"/company.html\" target=\"\"><span class=\"txt\">会社概要</span></a></li>\r\n              <!-- [END li.lib-nav__item]-->\r\n            </ul>\r\n            <ul class=\"lib-induce__outer\">\r\n              <li><a class=\"lib-induce__btn --contact bg-main bg-fill\" href=\"/contact/\"><span class=\"txt\">お問い合わせ</span></a></li>\r\n              <li><a class=\"lib-induce__btn --download bg-accent bg-fill\" href=\"/download/\"><span class=\"txt\">資料ダウンロード</span></a></li>\r\n            </ul>\r\n            <!-- [END lib-induce__outer]-->\r\n          </div>\r\n          <!-- [END lib-nav__outer]-->\r\n        </div>\r\n        <!-- [END lib-nav__cover]-->\r\n      </nav>\r\n      <!-- [END lib-nav__panel]-->\r\n    </div>\r\n    <!-- [END lib-header__inner]-->\r\n  </div>\r\n  <!-- [END lib-header__outer]-->\n\n  <nav class=\"lib-breadcrumb__outer\" aria-label=\"Breadcrumbs\">\n    <div class=\"lib-breadcrumb__inside\">\n      <ol class=\"lib-breadcrumb__list\" itemscope itemtype=\"http://schema.org/BreadcrumbList\">\n      <li itemprop=\"itemListElement\" itemscope itemtype=\"http://schema.org/ListItem\"><a href=\"https://www.kyoto-grain.co.jp/index.html\" itemprop=\"item\"><span itemprop=\"name\">HOME</span></a><meta itemprop=\"position\" content=\"1\" /></li><li itemprop=\"itemListElement\" itemscope itemtype=\"http://schema.org/ListItem\"><a href=\"https://www.kyoto-grain.co.jp/careers.html\" itemprop=\"item\" aria-current=\"location\"><span itemprop=\"name\">採用情報</span></a><meta itemprop=\"position\" content=\"2\" /></li>\n      </ol>\n    </div>\n  </nav>\n  \n  <main id=\"contents\">\n    <!-- ブロック貼り付けエリア -->\n    <div id=\"dcms_layoutPageBlockPasteArea\">\n    <!-- ブロック -->\n    <div id=\"dcms_layoutPageBlock\">\n    <div class=\"lib-hero__outer js-page-main\">\n<div class=\"lib-hero__txtarea wrap\">\n<div class=\"lib-hero__inner\">\n<h1 class=\"lib-hero__title title\">採用情報</h1>\n</div>\n</div>\n</div>\n<div class=\"lib-title__outer container --typeD\">\n<h3 class=\"title\">募集の背景</h3>\n</div>\n<div class=\"container lib-txt__outer text-md-left\">\n<p>当社創業者は前職にて、お茶問屋向けに玄米茶の素を販売していました。スーパーでミネラルウォーターが売り出されたのを見て、「次はお茶のペットボトルが並ぶだろう。今度は飲料メーカーを相手に商売をしよう。」と予測したことが、独立のきっかけとなりました。予測が大当たりし、現在では大手飲料メーカー複数社に飲料原料を提供しており、スーパーやコンビニで並んでいるペットボトル飲料の多くには弊社商品が使用されています。<br /> 取引先・売上も順調に伸ばしており、他業界進出にも取り組んでいるため、生産体制強化が急務となっています。そのため、今回新たな人材を迎えることで人員体制を整えていきたいと考えています。入社いただく方には、将来的に製造部門の中核として活躍してくれることを期待し、長期的なキャリアの形成を図ります。</p>\n</div>\n<div class=\"lib-title__outer container --typeA\">\n<h4 class=\"title\">募集要項</h4>\n</div>\n<div class=\"container lib-txt__outer\">\n<table class=\"lib-table__01 w-100 bg-wht\">\n<tbody>\n<tr>\n<th class=\"tstart w-25\" scope=\"row\"><span>応募方法</span></th>\n<td><span>Indeedよりご応募ください。</span></td>\n</tr>\n<tr>\n<th class=\"tstart\" scope=\"row\"><span>雇用形態</span></th>\n<td><span>正社員</span></td>\n</tr>\n<tr>\n<th class=\"tstart\" scope=\"row\"><span>職種</span></th>\n<td><span>食品原材料の製造/構内作業</span></td>\n</tr>\n<tr>\n<th class=\"tstart\" scope=\"row\"><span>仕事内容</span></th>\n<td><span>食品原材料の加工・製造、フォークリフトを使った構内作業</span><br /><br /><span>入社後は、OJTを中心に商品の名前や形などを覚えることからスタートします。</span><br /><span>未経験からでも1～2カ月で基本的な流れを掴むことができます。</span></td>\n</tr>\n<tr>\n<th class=\"tstart\" scope=\"row\"><span>給与</span></th>\n<td><span>月給210,000円～（能力・経験による）</span><br /><span>　※試用期間：3カ月（給与同一）</span><br /><br /><span>【年収例】</span><br /><span>　550万円／主任・入社8年目・30歳（月給30万円×12ヶ月＋賞与2回＋各種手当）</span><br /><span>　400万円／入社1年目・25歳（月給21万円×12ヶ月＋賞与2回＋各種手当）</span></td>\n</tr>\n<tr>\n<th class=\"tstart\" scope=\"row\"><span>諸手当</span></th>\n<td><span>■子ども手当　※社会保険適用扶養者のみ該当</span><br /><span>■時間外手当</span><br /><span>■深夜手当（22時～5時の勤務）</span><br /><span>■代休手当</span><br /><span>■職務手当</span><br /><span>■通勤交通費支給（上限40,000円/月）</span><br /><span>■資格取得支援（全額会社負担）　　　　　　ほか</span></td>\n</tr>\n<tr>\n<th class=\"tstart\" scope=\"row\"><span>昇給・賞与</span></th>\n<td><span>■昇給：年１回</span><br /><span>　※2024年ベースアップ実績：10,000円（人事考課により一部変動あり）</span><br /><br /><span>■賞与：年2回（+ 業績により決算賞与有）</span></td>\n</tr>\n<tr>\n<th class=\"tstart\" scope=\"row\"><span>福利厚生</span></th>\n<td><span>■社会保険完備</span><br /><span>■研修制度</span><br /><span>■マイカー・バイク通勤ＯＫ</span><br /><span>■退職金制度</span></td>\n</tr>\n<tr>\n<th class=\"tstart\" scope=\"row\"><span>勤務地</span></th>\n<td><span>奈良工場（奈良県奈良市小倉町1224）</span></td>\n</tr>\n<tr>\n<th class=\"tstart\" scope=\"row\"><span>交通アクセス</span></th>\n<td><span>奈良工場：名阪国道小倉インターより車で5分程度</span></td>\n</tr>\n<tr>\n<th class=\"tstart\" scope=\"row\"><span>勤務時間・曜日</span></th>\n<td><span>完全週休二日制（土・日）、祝日<br />　※勤務シフトにより異なります。（早番・遅番有）<br />有給休暇（10～20日）、特別休暇・育児休暇ほか<br />　※年間休日：125日</span></td>\n</tr>\n<tr>\n<th class=\"tstart\" scope=\"row\"><span>資格</span></th>\n<td><span>普通自動車免許<br /><br />フォークリフト、クレーン、玉掛の有資格者歓迎（資格取得支援制度有）</span></td>\n</tr>\n<tr>\n<th class=\"tstart\" scope=\"row\"><span>学歴・年齢</span></th>\n<td><span>未経験ＯＫ、学歴不問<br />40歳までの方（若年層の長期キャリア形成を図るため）<br /></span></td>\n</tr>\n</tbody>\n</table>\n</div>\n<!--\n<div class=\"container lib-txt__outer tcenter\"><a class=\"lib-link__btn \" href=\"#\"><span class=\"txt\">新卒応募者の方はこちら</span></a></div>\n-->\n<div class=\"lib-title__outer container --typeD\">\n<h3 class=\"title\">会社・職場のご紹介</h3>\n</div>\n<div class=\"lib-title__outer container --typeA\">\n<h4 class=\"title\">事業・商品の特徴</h4>\n</div>\n<div class=\"container lib-txt__outer\">\n<p>「京都グレインシステム株式会社」という社名を初めて耳にした方がほとんどかと思います。しかし、当社の商品を一度は口にしたことがあるかと思います。当社の商品は、スーパーやコンビニに並ぶペットボトル飲料やお菓子、パンに使用されておりますが、当社の名前が表に出ることはありません。飲料メーカーや食品メーカーなどの黒子として、陰ながら皆さまの食卓を支えています。現在は飲料向けに培った技術を活かし、食品・医薬品分野への進出や、海外市場開拓も活発に行っています。</p>\n</div>\n<div class=\"container\">\n<div class=\"lib-grid__outer row row-cols-1 row-cols-md-2 row-cols-lg-3 gy-5 gx-md-3\">\n<div class=\"lib-grid__col col d-flex\">\n<div class=\"lib-card__item\">\n<div class=\"lib-card__txtarea\">\n<div class=\"lib-card__inside\">\n<div class=\"lib-card__txt\">「蒸し」「焙煎」「包装」「他加工」のラインがあり、いずれかのラインをご担当いただきます。（基本的には、複数のラインを数人で担当します。）まずはOJT形式で先輩についていただき、実際に作業すると同時にマニュアルで製品知識も覚えていただきます。</div>\n</div>\n<!-- // lib-card__inside--> <!-- // lib-card__btn--></div>\n<!-- // lib-card__txtarea--> <span class=\"lib-card__thumb\"><img src=\"/dcms_media/image/DSC_0627.JPG\" width=\"6000\" height=\"4000\" loading=\"lazy\" /></span> <!-- // lib-card__thumb--></div>\n<!-- // lib-card__item--></div>\n<!-- . col-->\n<div class=\"lib-grid__col col d-flex\">\n<div class=\"lib-card__item\">\n<div class=\"lib-card__txtarea\">\n<div class=\"lib-card__inside\">\n<div class=\"lib-card__txt\">当社の製造は同じ作業の繰り返しではなく、担当するラインがスムーズに進むように日々改善しながら、業務に取り組むことが特徴です。各プロジェクトチームメンバーに抜粋された際は、工場・会社全体の改善にも取り組んでいただきます。</div>\n</div>\n<!-- // lib-card__inside--> <!-- // lib-card__btn--></div>\n<!-- // lib-card__txtarea--> <span class=\"lib-card__thumb\"><img src=\"/dcms_media/image/DSC_0085.JPG\" width=\"6000\" height=\"4000\" loading=\"lazy\" /></span> <!-- // lib-card__thumb--></div>\n<!-- // lib-card__item--></div>\n<!-- . col-->\n<div class=\"lib-grid__col col d-flex\">\n<div class=\"lib-card__item\">\n<div class=\"lib-card__txtarea\">\n<div class=\"lib-card__inside\">\n<div class=\"lib-card__txt\">製品には大手メーカー様からのOEMだけではなく、年間200件近くの企画・開発案件もあります。基本的には営業部から企画指示がありますが、メーカー開発担当者・営業部と一緒に意見交換を行い、開発案件に携わっていただきます。現場の意見も反映される職場のため、自分が関わった商品がコンビニやスーパーに並んでいるのを見るとやる気につながります。</div>\n</div>\n<!-- // lib-card__inside--> <!-- // lib-card__btn--></div>\n<!-- // lib-card__txtarea--> <span class=\"lib-card__thumb\"><img src=\"/dcms_media/image/DSC_0070.JPG\" width=\"6000\" height=\"4000\" loading=\"lazy\" /></span> <!-- // lib-card__thumb--></div>\n<!-- // lib-card__item--></div>\n<!-- . col--></div>\n<!-- .row--></div>\n<div class=\"lib-title__outer container --typeA\">\n<h4 class=\"title\">社風・風土</h4>\n</div>\n<div class=\"container lib-cnt-010\">\n<div class=\"lib-cnt-010__outer row flex-column gy-4 gy-md-0\">\n<div class=\"lib-cnt-010__col col\">\n<div class=\"lib-cnt-010__row row row-cols-1 row-cols-md-2 flex-column-reverse flex-md-row gx-md-0\">\n<div class=\"col d-flex\">\n<div class=\"lib-card__item bg-lgry justify-content-center\">\n<div class=\"lib-card__txtarea d-block\">\n<div class=\"lib-card__txt\">経営者との距離が近く、新入社員であっても、改善・提案等について経営者に直接提案することができます。「色んなことにチャレンジしたい」「自分で考えて行動したい」という方に向いている職場です。<br /> 現在は20～30代の社員が多く、若い力が発揮できる職場です。チームワークがよく活気があり、スポーツが好きな社員も多く、休日に有志で集まり球技をするなど雰囲気が良い職場です。</div>\n</div>\n</div>\n</div>\n<!-- // col-->\n<div class=\"col d-flex\"><span class=\"thumb\"><img class=\"\" style=\"max-width: 100%; color: #000000; font-size: 14px; background-color: #f5f5f5;\" src=\"https://www.kyoto-grain.co.jp/dcms_media/image/%E3%82%BD%E3%83%95%E3%83%88%E3%83%9C%E3%83%BC%E3%83%AB%E5%A4%A7%E4%BC%9A%EF%BC%88%E7%B7%A8%E9%9B%86%E6%B8%88%E3%81%BF%EF%BC%89.jpg\" alt=\"\" width=\"1185\" height=\"612\" /></span></div>\n<!-- // col--></div>\n<!-- // lib-cnt-010__row--></div>\n<!-- // lib-cnt-010__col--></div>\n<!-- // lib-cnt-010__outer--></div>\n\n    </div><!-- // ブロック -->\n    </div><!-- // ブロック貼り付けエリア -->\n  \n  </main>\n  <div class=\"lib-column__side\">\n  \n\n  </div>\n  <div class=\"lib-cta__outer lib-cta-BS01 bg-gry --fill bg-center\" style=\"background-image: url(/dcms_media/image/cta-bg.jpg);\">\r\n        <div class=\"container\">\r\n          <div class=\"bg-wht --fill-box lib-cta-BS01__inside\">\r\n            <div class=\"lib-title__outer --def\">\r\n              <h2 class=\"title text-center text-def\">お問い合わせ</h2>\r\n            </div>\r\n            <!-- // lib-cta-title__outer-->\r\n            <div class=\"lib-txt__outer\">\r\n              <p class=\"text-sm-center\">ご不明点やご相談はお問い合わせフォームよりお気軽にご連絡ください。<br />サービス詳細は資料ダウンロードからご覧いただけます。</p>\r\n            </div>\r\n            <!-- // lib-cta-txt__outer-->\r\n            <div class=\"lib-cta-BS01__btn container --min mw-sm\">\r\n              <ul class=\"row row-cols-1 row-cols-md-2 gy-2 lib-btn__outer --grid\">\r\n                <li class=\"col\"><a class=\"lib-link__btn sizeL bg-main bg-fill ico-before-mail\" href=\"/contact/\"><span class=\"txt\">お問い合わせ</span></a></li>\r\n                <li class=\"col\"><a class=\"lib-link__btn sizeL bg-accent bg-fill ico-before-dl\" href=\"/download/\"><span class=\"txt\">資料ダウンロード</span></a></li>\r\n              </ul>\r\n            </div>\r\n            <!-- // lib-cta-BS01__btn-->\r\n            <!--<div class=\"lib-cta-BS01__phone container --mdl lib-wide__outer --fill-box bg-lgry text-md-center\">\r\n      