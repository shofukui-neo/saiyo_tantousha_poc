{"url":"http://www.nichicon.co.jp/recruit_graduates/","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n  <head>\n    <meta charset=\"UTF-8\">\n    <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1, shrink-to-fit=no\">\n    <title>新卒採用情報 | 採用情報 | 企業情報 | ニチコン株式会社 </title>\n    <meta name=\"description\" content=\"ニチコンの新卒採用情報をご紹介しています。\">\n    <link rel=\"canonical\" href=\"https://www.nichicon.co.jp/recruit_graduates/\">\n    <meta property=\"og:type\" content=\"website\">\n    <meta property=\"og:title\" content=\"新卒採用情報 | 採用情報 | 企業情報 | ニチコン株式会社 \">\n    <meta property=\"og:description\" content=\"ニチコンの新卒採用情報をご紹介しています。\">\n    <meta property=\"og:url\" content=\"https://www.nichicon.co.jp/recruit_graduates/\">\n    <meta property=\"og:image\" content=\"https://www.nichicon.co.jp/recruit_graduates/assets/images/meta-img/ogp.jpg\">\n    <link rel=\"icon\" href=\"/recruit_graduates/assets/images/meta-img/favicon.ico\">\n    <link rel=\"apple-touch-icon\" href=\"/recruit_graduates/assets/images/meta-img/touch-icon.png\">\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n    <link href=\"https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500;600;700&amp;family=Noto+Sans+JP:wght@100..900&amp;family=Work+Sans:ital,wght@0,100..900;1,100..900&amp;family=Zen+Kaku+Gothic+Antique&amp;display=swap\" rel=\"stylesheet\">\n    <link rel=\"stylesheet\" href=\"/recruit_graduates/assets/css/app.css\"><!-- Google Tag Manager -->\n      <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\n      new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\n      j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n      'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n      })(window,document,'script','dataLayer',