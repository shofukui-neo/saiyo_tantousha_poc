hild-list__item\"><a class=\"flex-box\" href=\"/recruit_graduates/jobs/interview7.html\">\n                        <p>蓄電ソフト開発</p>\n                        <div class=\"c-arrow-only-ico\"></div></a></li>\n                    <li class=\"child-list__item\"><a class=\"flex-box\" href=\"/recruit_graduates/jobs/interview8.html\">\n                        <p>応用機器設計</p>\n                        <div class=\"c-arrow-only-ico\"></div></a></li>\n                    <li class=\"child-list__item\"><a class=\"flex-box\" href=\"/recruit_graduates/jobs/interview10.html\">\n                        <p>営業</p>\n                        <div class=\"c-arrow-only-ico\"></div></a></li>\n                  </ul>\n                </div>\n              </li>\n              <li class=\"navi__list--item\" data-page=\"technology\"><a href=\"/recruit_graduates/technology/\">\n                  <div class=\"list-wrap\">\n                    <p>未来をひらく技術力</p><span class=\"c-arrow-only-ico is-tab\"></span>\n                  </div></a></li>\n              <li class=\"navi__list--item\" data-page=\"internship\"><a href=\"/recruit_graduates/internship/\">\n                  <div class=\"list-wrap\">\n                    <p>インターンシップ</p><span class=\"c-arrow-only-ico is-tab\"></span>\n                  </div></a></li>\n              <li class=\"navi__list--item last-item has-child\" data-page=\"requirement\">\n                <div class=\"list-wrap js-has-child\" data-label=\"requirement\">\n                  <p>募集要項</p><span class=\"arrow-ico\" data-label=\"requirement\"></span>\n                </div>\n                <div class=\"child-list__wrap is-open\" data-label=\"requirement\">\n                  <ul class=\"child-list\">\n                    <li class=\"child-list__item\"><a class=\"flex-box\" href=\"/recruit_graduates/requirement/\">\n                        <p>募集要項TOP</p>\n                        <div class=\"c-arrow-only-ico\"></div></a></li>\n                    <li class=\"child-list__item\"><a class=\"flex-box\" href=\"/recruit_graduates/requirement/process.html\">\n                        <p>採用プロセス</p>\n                        <div class=\"c-arrow-only-ico\"></div></a></li>\n                  </ul>\n                </div>\n              </li>\n            </ul>\n          </div>\n          <div class=\"header__entry--wrap\"><a class=\"header__entry--btn -white\" href=\"https://job.axol.jp/bx/s/nichicon_27/mypage/login\" target=\"_blank\">\n              <p>My Page</p></a><a class=\"header__entry--btn\" href=\"https://job.axol.jp/bx/s/nichicon_27/entry/\" target=\"_blank\">\n              <p>Entry</p></a></div>\n          <div class=\"sp-menu__btn\" id=\"js-menu-btn\">\n            <p>Menu</p><span class=\"border-ico\"></span>\n          </div>\n        </div>\n      </div>\n    </header>\n    <div class=\"animation\" id=\"js-animation__container\">\n      <div class=\"animation__container\">\n        <div class=\"animation__bg\">\n          <div class=\"animation__window\" id=\"js-second-animation\"></div>\n        </div>\n        <div class=\"animation__logo\" id=\"js-first-animation\"><img src=\"/recruit_graduates/assets/images/top/animation-logo.svg\" alt=\"nichicon\"></div>\n      </div>\n    </div>\n    <div class=\"top\" id=\"top\">\n      <div class=\"top-mv\">\n        <div class=\"top-mv__container\">\n          <div class=\"top-mv__bg\"><span class=\"scroll-down\"></span>\n            <h1 class=\"mv__ttl\">\n              <picture>\n                <source srcset=\"/recruit_graduates/assets/images/top/mv-ttl_sp.svg\" media=\"(max-width:768px)\"><img src=\"/recruit_graduates/assets/images/top/mv-ttl_pc.svg\" alt=\"未来は、私たちから。\">\n              </picture>\n            </h1>\n          </div>\n        </div>\n      </div>\n      <div class=\"top-lead\">\n        <div class=\"top-lead__square--bg\"></div>\n        <div class=\"top-lead__container c-container\">\n          <div class=\"top-lead__inner\">\n            <div class=\"top-lead__column\">\n              <div class=\"column-item sub-img__width\">\n                <div class=\"column-item__img\"><img src=\"/recruit_graduates/assets/images/top/lead-img01.jpg\" alt=\"\"></div>\n              </div>\n              <div class=\"column-item sp-absolute\">\n                <div class=\"column-item__txt\">\n                  <p><span class=\"u-txt-item js-fadeup\">エネルギーが切り拓く、新しい社会。<br></span><span class=\"u-txt-item js-fadeup\">可能性あふれる、新時代モビリティ。<br></span><span class=\"u-txt-item js-fadeup\">豊かな未来のカギを握るニチコンで、<br></span><span class=\"u-txt-item js-fadeup\">あなたは、どんなトビラを開けるだろう？<br></span><span class=\"u-txt-item js-fadeup\">未来は誰かのものじゃない。<br></span><span class=\"u-txt-item js-fadeup\">夢を叶える「技術」と「実現力」を武器に、<br></span><span class=\"u-txt-item js-fadeup\">たいせつな未来を、あなた自身の手で。</span></p>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n      <section class=\"top-door js-fadeup-trigger\">\n        <div class=\"top-door__container c-container\">\n          <div class=\"top-door__bg\">\n            <h2 class=\"top-door__ttl\">ニチコン<span class=\"is-f32\">と</span><span class=\"is-f40\">ひらく</span><br class=\"is-sp\">未来<span class=\"is-f40\">の</span>扉</h2><svg class=\"clip-path\" width=\"0\" height=\"0\" viewBox=\"0 0 160 240\">\n<clipPath id=\"clip-path\" clipPathUnits=\"objectBoundingBox\">\n<path transform=\"scale(0.00625, 0.004166666666666667)\" d= \"M0,20,160,0V240L0,220Z\"/>\n</clipPath>\n</svg>\n            <ul class=\"top-door__list\">\n              <li class=\"list-item js-modal-btn\" data-modal=\"num1\">\n                <div class=\"list-item__img\"><img src=\"/recruit_graduates/assets/images/top/door-img01.png\" alt=\"\"></div>\n                <p class=\"list-item__txt\">IoT</p>\n              </li>\n              <li class=\"list-item js-modal-btn\" data-modal=\"num2\">\n                <div class=\"list-item__img\"><img src=\"/recruit_graduates/assets/images/top/door-img02.png\" alt=\"\"></div>\n                <p class=\"list-item__txt\">災害支援</p>\n              </li>\n              <li class=\"list-item js-modal-btn\" data-modal=\"num3\">\n                <div class=\"list-item__img\"><img src=\"/recruit_graduates/assets/images/top/door-img03.png\" alt=\"\"></div>\n                <p class=\"list-item__txt\">医療現場</p>\n              </li>\n              <li class=\"list-item js-modal-btn\" data-modal=\"num4\">\n                <div class=\"list-item__img\"><img src=\"/recruit_graduates/assets/images/top/door-img04.png\" alt=\"\"></div>\n                <p class=\"list-item__txt\">再生可能<br class=\"is-tab\">エネルギー</p>\n              </li>\n              <li class=\"list-item js-modal-btn\" data-modal=\"num5\">\n                <div class=\"list-item__img\"><img src=\"/recruit_graduates/assets/images/top/door-img05.png\" alt=\"\"></div>\n                <p class=\"list-item__txt\">省エネ</p>\n              </li>\n              <li class=\"list-item js-modal-btn\" data-modal=\"num6\">\n                <div class=\"list-item__img\"><img src=\"/recruit_graduates/assets/images/top/door-img06.png\" alt=\"\"></div>\n                <p class=\"list-item__txt\">EV化</p>\n              </li>\n            </ul>\n            <div class=\"modal-content js-modal-content\" data-content=\"num1\">\n              <div class=\"modal-content__wrap\">\n                <div class=\"cross-ico js-modal-close\"></div>\n                <div class=\"modal-content__inner\">\n                  <div class=\"modal-content__label\">IoT</div>\n                  <div class=\"modal-content__ttl\">スマート社会を<br class=\"is-sp\">電池技術で支える</div>\n                  <div class=\"modal-content__txt\">小形リチウム二次電池「SLBシリーズ」の、身の周りの微弱なエネルギーを蓄電できる技術を活かし、IoT機器の可能性を広げます。</div>\n                  <div class=\"modal-content__img\"><img class=\"img\" src=\"/recruit_graduates/assets/images/top/modal1-img01.png\" alt=\"\"></div>\n                  <div class=\"modal-content__close js-modal-close\">\n                    <p>閉じる</p>\n                    <div class=\"cross-ico\"></div>\n                  </div>\n                </div>\n              </div>\n            </div>\n            <div class=\"modal-content js-modal-content\" data-content=\"num2\">\n              <div class=\"modal-content__wrap\">\n                <div class=\"cross-ico js-modal-close\"></div>\n                <div class=\"modal-content__inner\">\n                  <div class=\"modal-content__label\">災害支援</div>\n                  <div class=\"modal-content__ttl\">クルマの新しい可能性</div>\n                  <div class=\"modal-content__txt\">災害時の停電対策として、EV/PHVから電気を取り出せる外部給電器「パワー・ムーバー®」が活用されています。避難所などに電気を供給することで、災害時でも「人々の安心」に貢献します。</div>\n                  <div class=\"modal-content__img\"><img class=\"img\" src=\"/recruit_graduates/assets/images/top/modal2-img01.png\" alt=\"\"><img class=\"img\" src=\"/recruit_graduates/assets/images/top/modal2-img02.png\" alt=\"\"></div>\n                  <div class=\"modal-content__close js-modal-close\">\n                    <p>閉じる</p>\n                    <div class=\"cross-ico\"></div>\n                  </div>\n                </div>\n              </div>\n            </div>\n            <div class=\"modal-content js-modal-content\" data-content=\"num3\">\n              <div class=\"modal-content__wrap\">\n                <div class=\"cross-ico js-modal-close\"></div>\n                <div class=\"modal-content__inner\">\n                  <div class=\"modal-content__label\">医療現場</div>\n                  <div class=\"modal-content__ttl\">高度医療の普及拡大</div>\n                  <div class=\"modal-content__txt\">がん治療において需要が高まる粒子線治療。その装置の心臓部である医療用加速器電源を開発しており、装置全体の小型・軽量化・低コスト化に貢献します。</div>\n                  <div class=\"modal-content__img\"><img class=\"img\" src=\"/recruit_graduates/assets/images/top/modal3-img01.png\" alt=\"\"><img class=\"img\" src=\"/recruit_graduates/assets/images/top/modal3-img02.png\" alt=\"\"></div>\n                  <div class=\"modal-content__close js-modal-close\">\n                    <p>閉じる</p>\n                    <div class=\"cross-ico\"></div>\n                  </div>\n                </div>\n              </div>\n            </div>\n            <div class=\"modal-content js-modal-content\" data-content=\"num4\">\n              <div class=\"modal-content__wrap\">\n                <div class=\"cross-ico js-modal-close\"></div>\n                <div class=\"modal-content__inner\">\n                  <div class=\"modal-content__label\">再生可能エネルギー</div>\n                  <div class=\"modal-content__ttl\">電気の「家産家消」を<br class=\"is-sp\">目指す</div>\n                  <div class=\"modal-content__txt\">ニチコンが開発した蓄電システムは、昼間太陽光で発電した電気を家にもEVにもつなぐことができ、太陽光を最大限活用することが可能になります</div>\n                  <div class=\"modal-content__img\"><img class=\"img\" src=\"/recruit_graduates/assets/images/top/modal4-img01.png\" alt=\"\"><img class=\"img\" src=\"/recruit_graduates/assets/images/top/modal4-img02.png\" alt=\"\"></div>\n                  <div class=\"modal-content__close js-modal-close\">\n                    <p>閉じる</p>\n                    <div class=\"cross-ico\"></div>\n                  </div>\n                </div>\n              </div>\n            </div>\n            <div class=\"modal-content js-modal-content\" data-content=\"num5\">\n              <div class=\"modal-content__wrap\">\n                <div class=\"cross-ico js-modal-close\"></div>\n                <div class=\"modal-content__inner\">\n                  <div class=\"modal-content__label\">省エネ化</div>\n                  <div class=\"modal-content__ttl\">家電の中から省エネを</div>\n                  <div class=\"modal-content__txt\">ニチコンは創業以来培ってきたコンデンサの技術を活かし、エアコンや冷蔵庫をはじめとしたインバータ家電のさらなる省エネ化に貢献します。</div>\n                  <div class=\"modal-content__close js-modal-close\">\n                    <p>閉じる</p>\n                    <div class=\"cross-ico\"></div>\n                  </div>\n                </div>\n              </div>\n            </div>\n            <div class=\"modal-content js-modal-content\" data-content=\"num6\">\n              <div class=\"modal-content__wrap\">\n                <div class=\"cross-ico js-modal-close\"></div>\n                <div class=\"modal-content__inner\">\n                  <div class=\"modal-content__label\">xEV</div>\n                  <div class=\"modal-content__ttl\">クリーンな<br class=\"is-sp\">モビリティ社会の実現</div>\n                  <div class=\"modal-content__txt\">ニチコンはxEVに欠かせない各種コンデンサの開発や、V2Hシステムや急速充電器といった充放電インフラの拡充を通じてクリーンなモビリティ社会の実現に貢献します。</div>\n                  <div class=\"modal-content__img\"><img class=\"img\" src=\"/recruit_graduates/assets/images/top/modal6-img01.png\" alt=\"\"><img class=\"img\" src=\"/recruit_graduates/assets/images/top/modal6-img02.png\" alt=\"\"></div>\n                  <div class=\"modal-content__close js-modal-close\">\n                    <p>閉じる</p>\n                    <div class=\"cross-ico\"></div>\n                  </div>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </section>\n      <section class=\"top-column\">\n        <div class=\"top-column__container\">\n          <div class=\"top-column__column\">\n            <div class=\"column-item__img\"><img src=\"/recruit_graduates/assets/images/top/column-img.jpg\" alt=\"\">\n              <div class=\"column-item__btn is-sp\"><a class=\"c-btn\" href=\"/recruit_graduates/technology/\">\n                  <div class=\"c-btn__txt\">コラムを読む</div></a></div>\n            </div>\n            <div class=\"column-item\">\n              <div class=\"c-ttl__contents\">\n                <h2 class=\"c-ttl u-textOverlay\"><span class=\"u-textOverlay__inner\">Column</span></h2>\n                <p class=\"c-sub-ttl u-textOverlay\"><span class=\"u-textOverlay__inner\">ニチコンの未来をひらく技術力</span></p>\n              </div>\n              <div class=\"column-item__btn is-pc\"><a class=\"c-btn\" href=\"/recruit_graduates/technology/\">\n                  <div class=\"c-