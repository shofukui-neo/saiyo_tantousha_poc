         <li class=\"p-global-nav__item\">\n                <a class=\"p-global-nav__item-link\" href=\"/newgraduates/interview06/\">先輩インタビュー R.K</a>\n              </li>\n              <li class=\"p-global-nav__item\">\n                <a class=\"p-global-nav__item-link\" href=\"/newgraduates/interview07/\">先輩インタビュー R.S</a>\n              </li>\n            </ul>\n          </li>\n          <li class=\"p-global-nav__category\">\n            <h2 class=\"p-global-nav__category-title\">\n              <a class=\"p-global-nav__category-link\" href=\"/career/\">キャリア採用</a>\n            </h2>\n            <ul class=\"p-global-nav__items\">\n              <li class=\"p-global-nav__item\">\n                <a class=\"p-global-nav__item-link\" href=\"/career/requirements/\">募集要項</a>\n              </li>\n              <li class=\"p-global-nav__item\">\n                <a class=\"p-global-nav__item-link\" href=\"/career/process/\">採用の流れ</a>\n              </li>\n              <li class=\"p-global-nav__item\">\n                <a class=\"p-global-nav__item-link\" href=\"/career/entry/\">ENTRY<br><span class=\"p-global-nav__sub-text u-nowrap\">（エントリーフォーム）</span></a>\n              </li>\n              <li class=\"p-global-nav__item\">\n                <a class=\"c-link-blank p-global-nav__item-link\" href=\"/career/registration/\" target=\"_blank\">キャリア登録について</a>\n              </li>\n              <li class=\"p-global-nav__item\">\n                <a class=\"c-link-blank p-global-nav__item-link\" href=\"/career/jobreturn/\" target=\"_blank\">ジョブリターン</a>\n              </li>\n              <li class=\"p-global-nav__item\">\n                <a class=\"p-global-nav__item-link \" href=\"/career/interview/#01\">先輩インタビュー A.M</a>\n              </li>\n              <li class=\"p-global-nav__item\">\n                <a class=\"p-global-nav__item-link \" href=\"/career/interview/#02\">先輩インタビュー E.I</a>\n              </li>\n            </ul>\n          </li>\n          <li class=\"p-global-nav__category\">\n            <h2 class=\"p-global-nav__category-title\">\n              <a class=\"p-global-nav__category-link\" href=\"/highschool/\">高校生採用</a>\n            </h2>\n            <ul class=\"p-global-nav__items\">\n              <li class=\"p-global-nav__item\">\n                <a class=\"p-global-nav__item-link\" href=\"/highschool/introduction/\">事業所紹介・職場紹介</a>\n              </li>\n              <li class=\"p-global-nav__item\">\n                <a class=\"p-global-nav__item-link\" href=\"/highschool/requirements/\">募集要項</a>\n              </li>\n              <li class=\"p-global-nav__item\">\n                <a class=\"p-global-nav__item-link \" href=\"/highschool/interview/#01\">先輩インタビュー Y.W</a>\n              </li>\n              <li class=\"p-global-nav__item\">\n                <a class=\"p-global-nav__item-link \" href=\"/highschool/interview/#02\">先輩インタビュー M.Y</a>\n              </li>\n              <li class=\"p-global-nav__item\">\n                <a class=\"p-global-nav__item-link \" href=\"/highschool/interview/#03\">先輩インタビュー T.H</a>\n              </li>\n              <li class=\"p-global-nav__item\">\n                <a class=\"p-global-nav__item-link \" href=\"/highschool/interview/#04\">先輩インタビュー K.U</a>\n              </li>\n              <li class=\"p-global-nav__item\">\n                <a class=\"p-global-nav__item-link \" href=\"/highschool/interview/#05\">先輩インタビュー S.M</a>\n              </li>\n              <li class=\"p-global-nav__item\">\n                <a class=\"p-global-nav__item-link \" href=\"/highschool/interview/#06\">先輩インタビュー C.K</a>\n              </li>\n              <li class=\"p-global-nav__item\">\n                <a class=\"p-global-nav__item-link \" href=\"/highschool/interview/#07\">先輩インタビュー T.I</a>\n              </li>\n            </ul>\n          </li>\n          <li class=\"p-global-nav__category\">\n            <h3 class=\"p-global-nav__category-title p-global-nav__category-title--sub\">\n              <a class=\"p-global-nav__category-link\" href=\"/faq/\">よくある質問</a>\n            </h3>\n          </li>\n          <li class=\"p-global-nav__category\">\n            <h3 class=\"p-global-nav__category-title p-global-nav__category-title--sub\">\n              <a class=\"p-global-nav__category-link\" href=\"/contact/\">お問い合わせ</a>\n            </h3>\n          </li>\n          <li class=\"p-global-nav__category\">\n            <h3 class=\"p-global-nav__category-title p-global-nav__category-title--sub\">\n              <a class=\"p-global-nav__category-link\" href=\"/privacypolicy/\">個人情報の取り扱いについて</a>\n            </h3>\n          </li>\n        </ul>\n        <div class=\"p-footer\">\n          <ul class=\"p-footer__nav\">\n  <li class=\"p-footer__nav-item\">\n    <a class=\"c-link-blank p-footer__nav-link\" href=\"https://www.iseki.co.jp/\" target=\"_blank\">井関農機株式会社 企業サイト</a>\n  </li>\n  <li class=\"p-footer__nav-item\">\n    <a class=\"c-link-blank p-footer__nav-link\" href=\"https://www.iseki.co.jp/pp/\" target=\"_blank\">個人情報保護方針</a>\n  </li>\n  <li class=\"p-footer__nav-item\">\n    <a class=\"c-link-blank p-footer__nav-link\" href=\"https://www.iseki.co.jp/aboutsite/\" target=\"_blank\">サイトについて</a>\n  </li>\n  <li class=\"p-footer__nav-item\">\n    <a class=\"c-link-blank p-footer__nav-link\" href=\"https://www.iseki.co.jp/socialmedia-gl/\" target=\"_blank\">ソーシャルメディアガイドライン</a>\n  </li>\n</ul>        </div><!-- /.p-footer -->\n      </div><!-- /.c-inner -->\n    </div><!-- /.p-global-nav -->\n  </div>\n\n  <div class=\"p-nav__page-top\">\n    <button class=\"p-page-top js-page-top\">\n      <img src=\"/assets/images/common/pagetop.svg\" alt=\"\">\n      <img class=\"u-pc-only\" src=\"/assets/images/common/pagetop_hover.svg\" alt=\"\">\n    </button>\n  </div>\n</div><!-- /.p-nav -->    </nav><!-- /.l-nav -->\n\n    <main class=\"l-main\">\n<div class=\"p-requirements\">\n\n  <header class=\"p-page-header p-page-header--newgraduates\">\n    <a class=\"p-page-header__category\" href=\"/newgraduates/\">\n      <p class=\"p-page-header__category-ja\">新卒採用</p>\n      <p class=\"p-page-header__category-en\">New Graduates Recruitment</p>\n    </a>\n    <h2 class=\"p-page-header__title\">募集要項</h2>\n  </header><!-- /.p-page-header -->\n\n  <ul class=\"c-inner p-breadcrumb u-sp-mb40 u-pc-mb90\">\n    <li class=\"p-breadcrumb__item\">\n      <a class=\"p-breadcrumb__link\" href=\"/\">HOME</a>\n    </li>\n    <li class=\"p-breadcrumb__item\">\n      <a class=\"p-breadcrumb__link\" href=\"/newgraduates/\">新卒採用</a>\n    </li>\n    <li class=\"p-breadcrumb__item\">募集要項</li>\n  </ul><!-- /.p-breadcrumb -->\n\n  <section class=\"c-inner p-requirements__section\">\n    <h3 class=\"c-heading1 c-heading1--newgraduates p-requirements__heading\">募集概要</h3>\n    <dl class=\"c-table-1d\">\n      <dt class=\"c-table-1d__head\">職務内容</dt>\n      <dd class=\"c-table-1d__body\">\n        <div class=\"c-table-1d__box\">\n          <p class=\"c-table-1d__text\">\n            【事務系】<br>\n            国内営業、海外営業、その他管理系職種（経理、財務、総務、人事、知財など）\n          </p>\n        </div>\n        <div class=\"c-table-1d__box\">\n          <p class=\"c-table-1d__text\">\n            【技術系】<br>\n            研究開発（農業機械、エンジン、メカトロニクスなど）、デザイン、農業用施設設計、生産技術、生産管理、品質管理、サービスエンジニア、情報システムなど\n          </p>\n        </div>\n        <p class=\"c-table-1d__text\">\n          ※新入社員教育終了後、各人と面談の上、本人の希望、適性、能力と会社の要員ニーズを総合勘案し配属を決定する。\n        </p>\n      </dd>\n      <dt class=\"c-table-1d__head\">応募資格</dt>\n      <dd class=\"c-table-1d__body\">\n        <ul class=\"c-table-1d__lists\">\n          <li class=\"c-table-1d__list\">四年制大学を2027年3月卒業見込みの方。</li>\n          <li class=\"c-table-1d__list\">修士課程、博士課程を2027年3月修了見込みの方。</li>\n          <li class=\"c-table-1d__list\">高等専門学校を2027年3月卒業見込みの方。</li>\n        </ul>\n        <p class=\"c-table-1d__text\">（留学生応募可）</p>\n      </dd>\n      <dt class=\"c-table-1d__head\">勤務地</dt>\n      <dd class=\"c-table-1d__body\">\n        <p class=\"c-table-1d__text\">国内、海外の各事業所</p>\n      </dd>\n      <dt class=\"c-table-1d__head\">勤務時間</dt>\n      <dd class=\"c-table-1d__body\">\n        <p class=\"c-table-1d__text\">\n          本社、本社事務所、つくばみらい事業所 8:30～17:20<br>\n          開発製造部門 8:00～17:00<br>\n          ※職種によりフレックス制を適用\n        </p>\n      </dd>\n      <dt class=\"c-table-1d__head\">採用学科</dt>\n      <dd class=\"c-table-1d__body\">\n        <p class=\"c-table-1d__text\">全学部、全学科</p>\n      </dd>\n      <dt class=\"c-table-1d__head\">採用予定人数</dt>\n      <dd class=\"c-table-1d__body\">\n        <p class=\"c-table-1d__text\">10～20名程度</p>\n      </dd>\n      <dt class=\"c-table-1d__head\">選考方法</dt>\n      <dd class=\"c-table-1d__body\">\n        <p class=\"c-table-1d__text\">エントリーシート、適性検査、面談</p>\n      </dd>\n      <dt class=\"c-table-1d__head\">提出書類</dt>\n      <dd class=\"c-table-1d__body\">\n        <p class=\"c-table-1d__text\">エントリーシート（写真添付）、成績証明書、卒業（修了）見込証明書</p>\n      </dd>\n    </dl><!-- /.c-table-1d -->\n  </section>\n\n  <section class=\"c-inner p-requirements__section\">\n    <h3 class=\"c-heading1 c-heading1--newgraduates p-requirements__heading\">給与・福利厚生</h3>\n    <dl class=\"c-table-1d\">\n      <dt class=\"c-table-1d__head\">初任給<span class=\"c-table-1d__sub\">（2026年4月実績、総合職）</span></dt>\n      <dd class=\"c-table-1d__body\">\n        <p class=\"c-table-1d__text\">\n        博士了：286,300円・修士了：270,600円・学部卒：249,200円<br>\n          （東京地区勤務の場合は地域手当として上記の8.3%をプラス支給）\n        </p>\n      </dd>\n      <dt class=\"c-table-1d__head\">賞与</dt>\n      <dd class=\"c-table-1d__body\">\n        <p class=\"c-table-1d__text\">年2回（7月、12月）</p>\n      </dd>\n      <dt class=\"c-table-1d__head\">昇給</dt>\n      <dd class=\"c-table-1d__body\">\n        <p class=\"c-table-1d__text\">年1回（4月）</p>\n      </dd>\n      <dt class=\"c-table-1d__head\">諸手当</dt>\n      <dd class=\"c-table-1d__body\">\n        <p class=\"c-table-1d__text\">通勤手当、時間外手当、家族手当、住宅手当など</p>\n      </dd>\n      <dt class=\"c-table-1d__head\">休日休暇</dt>\n      <dd class=\"c-table-1d__body\">\n        <p class=\"c-table-1d__text\">原則週休2日制、年間休日121日、年次有給休暇、慶弔休暇、育休他</p>\n      </dd>\n      <dt class=\"c-table-1d__head\">福利厚生</dt>\n      <dd class=\"c-table-1d__body\">\n        <p class=\"c-table-1d__text\">独身寮、社宅、運動施設、各種社会保険、財形、住宅手当他</p>\n      </dd>\n      <dt class=\"c-table-1d__head\">教育制度</dt>\n      <dd class=\"c-table-1d__body\">\n        <p class=\"c-table-1d__text\">各階層別教育、職能別教育、自己啓発援助（通信教育、資格取得補助）</p>\n      </dd>\n      <dt class=\"c-table-1d__head\">受動喫煙対策</dt>\n      <dd class=\"c-table-1d__body\">\n        <p class=\"c-table-1d__text\">\n          屋内喫煙可能場所あり<br>\n          （職場敷地内の屋内に喫煙専用室の設備あり）\n        </p>\n      </dd>\n    </dl><!-- /.c-table-1d -->\n  </section>\n\n  <section class=\"c-inner p-requirements__section\">\n    <h3 class=\"c-heading1 c-heading1--newgraduates p-requirements__heading\">採用実績</h3>\n    <div class=\"c-table-2d c-table-2d--newgraduates\">\n      <header class=\"c-table-2d__header\">\n        <div class=\"c-table-2d__header-head\">入社年度</div>\n        <div class=\"c-table-2d__header-item\">技術系</div>\n        <div class=\"c-table-2d__header-item\">事務系</div>\n      </header>\n      <div class=\"c-table-2d__group\">\n        <header class=\"c-table-2d__heading\">2020年</header>\n        <div class=\"c-table-2d__item\">\n          <div class=\"c-table-2d__item-name\">技術系</div>\n          <div class=\"c-table-2d__item-body\">25名</div>\n        </div>\n        <div class=\"c-table-2d__item\">\n          <div class=\"c-table-2d__item-name\">事務系</div>\n          <div class=\"c-table-2d__item-body\">11名</div>\n        </div>\n      </div>\n      <div class=\"c-table-2d__group\">\n        <header class=\"c-table-2d__heading\">2021年</header>\n        <div class=\"c-table-2d__item\">\n          <div class=\"c-table-2d__item-name\">技術系</div>\n          <div class=\"c-table-2d__item-body\">9名</div>\n        </div>\n        <div class=\"c-table-2d__item\">\n          <div class=\"c-table-2d__item-name\">事務系</div>\n          <div class=\"c-table-2d__item-body\">3名</div>\n        </div>\n      </div>\n      <div class=\"c-table-2d__group\">\n        <header class=\"c-table-2d__heading\">2022年</header>\n        <div class=\"c-table-2d__item\">\n          <div class=\"c-table-2d__item-name\">技術系</div>\n          <div class=\"c-table-2d__item-body\">18名</div>\n        </div>\n        <div class=\"c-table-2d__item\">\n          <div class=\"c-table-2d__item-name\">事務系</div>\n          <div class=\"c-table-2d__item-body\">7名</div>\n        </div>\n      </div>\n      <div class=\"c-table-2d__group\">\n        <header class=\"c-table-2d__heading\">2023年</header>\n        <div class=\"c-table-2d__item\">\n          <div class=\"c-table-2d__item-name\">技術系</div>\n          <div class=\"c-table-2d__item-body\">14名</div>\n        </div>\n        <div class=\"c-table-2d__item\">\n          <div class=\"c-table-2d__item-name\">事務系</div>\n          <div class=\"c-table-2d__item-body\">5名</div>\n        </div>\n      </div>\n      <div class=\"c-table-2d__group\">\n        <header class=\"c-table-2d__heading\">2024年</header>\n        <div class=\"c-table-2d__item\">\n          <div class=\"c-table-2d__item-name\">技術系</div>\n          <div class=\"c-table-2d__item-body\">12名</div>\n        </div>\n        <div class=\"c-table-2d__item\">\n          <div class=\"c-table-2d__item-name\">事務系</div>\n          <div class=\"c-table-2d__item-body\">7名</div>\n        </div>\n      </div>\n      <div class=\"c-table-2d__group\">\n        <header class=\"c-table-2d__heading\">2025年</header>\n        <div class=\"c-table-2d__item\">\n          <div class=\"c-table-2d__item-name\">技術系</div>\n          <div class=\"c-table-2d__item-body\">4名</div>\n        </div>\n        <div class=\"c-table-2d__item\">\n          <div class=\"c-table-2d__item-name\">事務系</div>\n          <div class=\"c-table-2d__item-body\">5名</div>\n        </div>\n      </div>\n    </div><!-- /.c-table-2d -->\n  </section>\n\n  <ul class=\"c-squ