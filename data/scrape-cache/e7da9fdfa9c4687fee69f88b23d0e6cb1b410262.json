{"url":"https://www.mikuni.co.jp/ir/message/","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n<head prefix=\"og: http://ogp.me/ns# fb: http://ogp.me/ns/fb# article: http://ogp.me/ns/article#\">\n  <meta charset=\"UTF-8\">\n  <meta id=\"viewport\" name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n  <meta name=\"format-detection\" content=\"telephone=no\">\n  <title>株主・投資家の皆様へ｜株主・投資家情報｜株式会社ミクニ</title>\n  <meta name=\"keywords\" content=\"MIKUNI,ミクニ,株主・投資家情報,経営情報,株主・投資家の皆様へ\">\n  <meta name=\"description\" content=\"ミクニの経営情報です。株主・投資家の皆様へ。\">\n  <!--OGP-->\n  <meta property=\"og:title\" content=\"株主・投資家の皆様へ\">\n  <meta property=\"og:type\" content=\"website\">\n  <meta property=\"og:description\" content=\"ミクニの経営情報です。株主・投資家の皆様へ。\">\n  <meta property=\"og:url\" content=\"https://www.mikuni.co.jp/ir/message/\">\n  <meta property=\"og:image\" content=\"https://www.mikuni.co.jp/mikuni_OGP.png\">\n  <meta property=\"og:site_name\" content=\"株式会社ミクニ\">\n  <meta property=\"og:locale\" content=\"ja_JP\">\n  <!--//OGP-->\n  <link rel=\"alternate\" hreflang=\"ja\" href=\"https://www.mikuni.co.jp/ir/message/\">\n  <link rel=\"alternate\" hreflang=\"en\" href=\"https://www.mikuni.co.jp/en/ir/message/\">\n  <link rel=\"shortcut icon\" href=\"/favicon.ico\">\n  <link rel=\"apple-touch-icon\" href=\"/apple-touch-icon.png\">\n  <link rel=\"icon\" type=\"image/png\" href=\"/android-chrome-256x256.png\">\n  <link rel=\"canonical\" href=\"https://www.mikuni.co.jp/ir/message/\">\n  <link rel=\"stylesheet\" href=\"/css/ress.css\" type=\"text/css\" media=\"all\">\n  <link rel=\"stylesheet\" href=\"/css/style.css\" type=\"text/css\" media=\"all\">\n  <link rel=\"stylesheet\" href=\"/css/ir.css\" type=\"text/css\" media=\"all\">\n  <link href=\"https://fonts.googleapis.com/css?family=Oswald&display=swap\" rel=\"stylesheet\">\n  <!-- Global site tag (gtag.js) - Google Analytics -->\n  <script async src=\"https://www.googletagmanager.com/gtag/js?id=UA-163776801-1\"></script>\n  <s