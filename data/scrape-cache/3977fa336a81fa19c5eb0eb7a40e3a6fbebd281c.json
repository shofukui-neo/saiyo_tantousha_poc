{"url":"https://www.nds-career.co.jp/","html":"<!DOCTYPE html>\r\n<html lang=\"ja\">\r\n<head>\r\n<meta charset=\"UTF-8\">\r\n<meta name=\"viewport\" content=\"width=device-width\">\r\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\r\n<meta name=\"format-detection\" content=\"telephone=no\">\r\n<!-- favicon -->\r\n<link rel=\"apple-touch-icon\" sizes=\"180x180\" href=\"/favicon/apple-touch-icon.png\">\r\n<link rel=\"icon\" type=\"image/png\" sizes=\"32x32\" href=\"/favicon/favicon-32x32.png\">\r\n<link rel=\"icon\" type=\"image/png\" sizes=\"16x16\" href=\"/favicon/favicon-16x16.png\">\r\n<link rel=\"manifest\" href=\"/favicon/site.webmanifest\">\r\n<link rel=\"mask-icon\" href=\"/favicon/safari-pinned-tab.svg\" color=\"#005ba2\">\r\n<link rel=\"shortcut icon\" href=\"/favicon/favicon.ico\">\r\n<meta name=\"msapplication-TileColor\" content=\"#ffffff\">\r\n<meta name=\"msapplication-config\" content=\"/favicon/browserconfig.xml\">\r\n<meta name=\"theme-color\" content=\"#ffffff\">\r\n\r\n<title>NDSキャリア株式会社</title>\r\n<meta name=\"description\" content=\"NDSキャリアは“人と企業の架け橋”として全ての“はたらく”を全力で応援します。人材派遣・人材紹介・アウトソーシングを柱に、お客様に寄り添い様々な課題を解決する、そして働く人のキャリアを創造するための、人材ソリューションサービスを提供しています。\">\r\n<!-- og -->\r\n<meta property=\"og:title\" content=\"NDSキャリア株式会社\">\r\n<meta property=\"og:description\" content=\"NDSキャリアは“人と企業の架け橋”として全ての“はたらく”を全力で応援します。人材派遣・人材紹介・アウトソーシングを柱に、お客様に寄り添い様々な課題を解決する、そして働く人のキャリアを創造するための、人材ソリューションサービスを提供しています。\">\r\n<meta property=\"og:type\" content=\"website\">\r\n<meta property=\"og:url\" content=\"https://nds-career.co.jp/\">\r\n<meta property=\"og:image\" content=\"https://nds-career.co.jp/common/images/og-img.jpg\">\r\n<meta property=\"og:image:width\" content=\"1200\">\r\n<meta property=\"og:image:height\" content=\"630\">\r\n<!-- twitter card -->\r\n<meta name=\"twitter:card\" content=\"summary_large_image\">\r\n<meta name=\"twitter:title\" content=\"NDSキャリア株式会社\">\r\n<meta name=\"twitter:description\" content=\"NDSキャリアは“人と企業の架け橋”として全ての“はたらく”