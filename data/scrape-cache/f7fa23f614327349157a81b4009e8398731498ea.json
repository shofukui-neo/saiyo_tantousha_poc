gmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\r\n})(window,document,'script','dataLayer','GTM-TLWT6JLC');</script>\r\n<!-- End Google Tag Manager --><link href=\"../css/faq.css\" rel=\"stylesheet\" type=\"text/css\">\r\n</head>\r\n\r\n<body>\r\n<section class=\"bg_imgbox\">\r\n<div class=\"title_box\">\r\n<h2 class=\"page_title\">Faq</h2>\r\n<p class=\"page_sub_title\">よくあるご質問</p>\r\n</div>\r\n\r\n<div class=\"scroll_bar\">\r\n<a href=\"#\"></a>\r\n</div>\r\n<!--end bg_imgbox -->\r\n</section>\r\n\r\n<header id=\"header\">\r\n<h1 class=\"header_logo\"><a href=\"../index.php\"><img src=\"../img/common/head_logo.svg\" alt=\"ネクスト・ワン株式会社 採用特設サイト\"/></a></h1>\r\n\r\n<nav class=\"g_navi\">\r\n<ul>\r\n<li><a href=\"../message/\"><span class=\"roll_txt\"><span class=\"en\">MESSAGE</span><span class=\"ja\">メッセージ</span></span></a></li>\r\n<li><a href=\"../company/\"><span class=\"roll_txt\"><span class=\"en\">COMPANY</span><span class=\"ja\">会社を知る</span></span></a></li>\r\n<li><a href=\"../service/\"><span class=\"roll_txt\"><span class=\"en\">SERVICE</span><span class=\"ja\">仕事を知る</span></span></a></li>\r\n<li><a href=\"../interview/\"><span class=\"roll_txt\"><span class=\"en\">INTERVIEW</span><span class=\"ja\">人を知る</span></span></a></li>\r\n<li><a href=\"../culture/\"><span class=\"roll_txt\"><span class=\"en\">CULTURE</span><span class=\"ja\">環境・制度</span></span></a></li>\r\n<li><a href=\"../faq/\"><span class=\"roll_txt\"><span class=\"en\">FAQ</span><span class=\"ja\">質問</span></span></a></li>\r\n<li><a href=\"../contact/\"><span class=\"roll_txt\"><span class=\"en\">CONTACT</span><span class=\"ja navi_contact\">お問い合わせ</span></span></a></li>\r\n</ul>\r\n\r\n<div class=\"entry_box\">\r\n<a href=\"../entry/\">\r\n<span class=\"roll_txt\">\r\n<span class=\"en\">ENTRY</span>\r\n<span class=\"ja\">エントリー</span>\r\n</span>\r\n</a>\r\n</div>\r\n</nav>\r\n</header>\r\n\r\n\r\n<div class=\"openbtn\"><span></span><span></span><span></span></div>\r\n<nav id=\"open_navi\">\r\n<div class=\"open_navi_list\">\r\n<p class=\"ham_logo\"><img src=\"../img/common/ham_logo.svg\" alt=\"\"/></p>\r\n<ul>\r\n<li><a href=\"../\">TOP<span class=\"ham_menu_ja\">トップ</span></a></li> \r\n<li><a href=\"../message/\">MESSAGE<span class=\"ham_menu_ja\">メッセージ</span></a></li>\r\n<li><a href=\"../company/\">COMPANY<span class=\"ham_menu_ja\">会社を知る</span></a></li> \r\n<li><a href=\"../service/\">SERVICE<span class=\"ham_menu_ja\">仕事を知る</span></a></li> \r\n<li><a href=\"../interview/\">INTERVIEW<span class=\"ham_menu_ja\">人を知る</span></a></li>\r\n<li><a href=\"../culture/\">CULTURE<span class=\"ham_menu_ja\">環境・制度</span></a></li> \r\n<li><a href=\"../faq/\">FAQ<span class=\"ham_menu_ja\">よくあるご質問</span></a></li> \r\n<li><a href=\"../contact/\">CONTACT<span class=\"ham_menu_ja\">お問い合わせ</span></a></li> \r\n<li><a href=\"../entry/\">ENTRY<span class=\"ham_menu_ja\">エントリー</span></a></li> \r\n</ul>\r\n</div>\r\n</nav>\r\n<main>\r\n<div class=\"content page_faq\">\r\n<section class=\"box_s\">\r\n<dl class=\"nav-list\">\r\n<dt>FAQカテゴリー</dt>\r\n<dd>\r\n<ul>\r\n<li><a href=\"#tgt-q1\">応募・選考について</a></li>\r\n<li><a href=\"#tgt-q2\">働く環境について</a></li>\r\n<li><a href=\"#tgt-q3\">その他</a></li>\r\n\r\n</ul>\r\n</dd>\r\n</dl>\r\n\r\n\r\n<p class=\"faq_en\">FAQ-01</p>\r\n<h3 id=\"tgt-q1\">応募・選考について</h3>\r\n<ul class=\"list-faq\">\r\n<li>\r\n<p class=\"q-ttl\">応募年齢に制限はありますか？<span class=\"icn-faq\"><span></span><span></span></span></p>\r\n<div class=\"list-faq-inner\">\r\n<p>職種により異なりますので、詳しくは管理部までお問い合わせください。</p>\r\n</div>\r\n</li>\r\n<li>\r\n<p class=\"q-ttl\">女性だと選考において不利になりますか？<span class=\"icn-faq\"><span></span><span></span></span></p>\r\n<div class=\"list-faq-inner\">\r\n<p>採用において女性が不利になることは絶対にあり得ません。</p>\r\n</div>\r\n</li>\r\n<li>\r\n<p class=\"q-ttl\">知識や経験がなくても大丈夫ですか？<span class=\"icn-faq\"><span></span><span></span></span></p>\r\n<div class=\"list-faq-inner\">\r\n<p>資格や経験が必要な業務もありますが、資格は入社後に取得することが可能です。</p>\r\n</div>\r\n</li>\r\n<li>\r\n<p class=\"q-ttl\">面接を受けてからどのくらいで結果がでますか？<span class=\"icn-faq\"><span></span><span></span></span></p>\r\n<div class=\"list-faq-inner\">\r\n<p>出来る限り短期間で決定したいと考えています。</p>\r\n</div>\r\n</li>\r\n</ul>\r\n\r\n<p class=\"faq_en\">FAQ-02</p>\r\n<h3 id=\"tgt-q2\">働く環境について</h3>\r\n<ul class=\"list-faq\">\r\n<li>\r\n<p class=\"q-ttl\">入社後の配属先はどのように決められるのですか？<span class=\"icn-faq\"><span></span><span></span></span></p>\r\n<div class=\"list-faq-inner\">\r\n<p>希望職種・希望勤務地、通勤方法等を総合的に判断して決定します。</p>\r\n</div>\r\n</li>\r\n<li>\r\n<p class=\"q-ttl\">入社後の異動・転勤はありますか？<span class=\"icn-faq\"><span></span><span></span></span></p>\r\n<div class=\"list-faq-inner\">\r\n<p>総合職の場合は転居を伴う異動の可能性があります。<br>\r\n一般職の場合は原則として通える範囲内での異動となります。</p>\r\n</div>\r\n</li>\r\n<li>\r\n<p class=\"q-ttl\">入社後の新入社員研修を教えてください。<span class=\"icn-faq\"><span></span><span></span></span></p>\r\n<div class=\"list-faq-inner\">\r\n<p>入社式が一週間の期間で社内研修、外部研修を実施します。<br>\r\nその後は必要な外部研修を併用しながら先輩社員との同行指導で経験を積み、一日も早い独り立ちを目指します。</p>\r\n</div>\r\n</li>\r\n</ul>\r\n\r\n<p class=\"faq_en\">FAQ-03</p>\r\n<h3 id=\"tgt-q3\">その他</h3>\r\n<ul class=\"list-faq\">\r\n<li>\r\n<p class=\"q-ttl\">福利厚生制度には、どのようなものがありますか？<span class=\"icn-faq\"><span></span><span></span></span></p>\r\n<div class=\"list-faq-inner\">\r\n<p><a href=\"../culture/#sec02\">福利厚生</a>のページをご覧ください。</p>\r\n</div>\r\n</li>\r\n<li>\r\n<p class=\"q-ttl\">出産、育児に関する制度について教えて下さい。<span class=\"icn-faq\"><span></span><span></span></span></p>\r\n<div class=\"list-faq-inner\">\r\n<p><a href=\"../culture/#sec02\">福利厚生</a>のページをご覧ください。</p>\r\n</div>\r\n</li>\r\n<li>\r\n<p class=\"q-ttl\">有給休暇の取得状況を教えてください。<span class=\"icn-faq\"><span></span><span></span></span></p>\r\n<div class=\"list-faq-inner\">\r\n<p>取得に制限はありませんので、業務に支障がないよう各自の判断で効率よく取得しています。</p>\r\n</div>\r\n</li>\r\n</ul>\r\n\r\n<!--end box -->\r\n</section>\r\n\r\n\r\n</div>\r\n</main>\r\n<footer>\r\n<section class=\"sec_movie\">\r\n<div class=\"entry_pv_wrap\">\r\n<video class=\"entry_pvbox\" muted autoplay loop playsinline>\r\n<source src=\"../img/common/entr