{"url":"https://www.okinawa.ccbc.co.jp/recruite/guideline/rex.html","html":"<!doctype html>\n<html lang=\"ja\">\n<head>\n<!-- Google Tag Manager --> \n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n})(window,document,'script','dataLayer','GTM-K49Q3QS');</script> \n<!-- End Google Tag Manager -->\n<meta charset=\"UTF-8\">\n<title>REX株式会社 募集要項｜沖縄コカ･コーラボトリング採用情報</title>\n<meta name=\"description\" content=\"REX株式会社 募集要項\">\n<meta name=\"keywords\" content=\"沖縄,コカ･コーラ,リクルート,大学卒,募集要項,募集要項\">\n<meta property=\"og:title\" content=\">REX株式会社 募集要項｜沖縄コカ･コーラボトリング\">\n<meta property=\"og:type\" content=\"website\" />\n<meta property=\"og:url\" content=\"http://www.okinawa.ccbc.co.jp/recruite/guideline/\">\n<meta property=\"og:image\" content=\"http://www.okinawa.ccbc.co.jp/cmn/img/logo.gif\">\n<meta property=\"og:description\" content=\"未来へ受け継いでいこうワシタチムグクルに\">\n<meta property=\"og:site_name\" content=\"沖縄コカ･コーラボトリング採用情報\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1, maximum-scale=1\">\n<meta name=\"format-detection\" content=\"telephone=no\">\n<link rel=\"shortcut icon\" href=\"/favicon.ico\"/>\n<meta name=\"apple-mobile-web-app-title\" content=\"沖縄コカコーラ\">\n<link rel=\"apple-touch-icon\" sizes=\"192x192\" href=\"/cmn/touch-icon.png\">\n<link href=\"/recruite/css/style.css\" rel=\"stylesheet\" type=\"text/css\">\n<link href=\"style.css?200715\" rel=\"stylesheet\" type=\"text/css\">\n<script\nsrc=\"https://code.jquery.com/jquery-2.2.4.min.js\"\nintegrity=\"sha256-BbhdlvQf/xTY9gja0Dq3HiwQF8LaCRTXxZKRutelT44=\"\ncrossorigin=\"anonymous\"></script> \n<script type=\"text/javascript\" src=\"/recruite/js/script.js\"></script>\n</head>\n<body>\n<!-- Google Tag Manager (noscript) -->\n<noscript>\n<iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-K49Q3QS\"\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe>\n</noscript>\n<!-- End Google Tag Manager (noscript) --> \n<!--loding-->\n<div id=\"loader\">\n <div class=\"spinner\">\n  <div class=\"rect1\"></div>\n  <div class=\"rect2\"></div>\n  <div class=\"rect3\"></div>\n  <div class=\"rect4\"></div>\n  <div class=\"rect5\"></div>\n </div>\n</div>\n<!--/loding-->\n<div id=\"wrapper\"> \n <!--header--> \n <header>\n<div id=\"header\">\n<div class=\"sitename\">\n<h1><a href=\"/recruite/\"><img src=\"/recruite/img/logo.svg\" alt=\"沖縄コカ･コーラボトリング採用情報\" class=\"logo\"/><span class=\"siteH1\"><span class=\"corp\">沖縄コカ･コーラボトリング</span>RECRUIT SITE</span></a></h1>\n</div>\n<div class=\"contactmenu\"><a href=\"/recruite/form/\" target=\"_blank\" class=\"en\">CONTACT<span class=\"icon-forward\"></span></a></div>\n<nav>\n<ul id=\"jetmenu\" class=\"jetmenu\">\n<li><a href=\"/recruite/message/\">\n<p>社長メッセージ</p>\n</a></li>\n<li><a href=\"/recruite/vision/\">\n<p>企業ビジョン</p>\n</a></li>\n<li><a href=\"/recruite/culture/\">\n<p>企業文化</p>\n</a></li>\n<li><a href=\"/recruite/carrier_plan/\">\n<p>教育・キャリアプラン</p>\n</a></li>\n<li><a href=\"javascript:void();\">\n<p>社員インタビュー<span class=\"icon-arrow-down\"></span></p>\n</a><!--row-->\n<div class=\"megamenu full-width\">\n<div class=\"row\">\n<div class=\"memint\">\n<div class=\"title mh\">\n<h5><span class=\"en\">Interview</span>社員インタビュー</h5>\n</div>\n<ul>\n<li><a href=\"/recruite/interview/marketing.html\">\n<p><img src=\"/recruite/img/cmn/men06.jpg\" alt=\"\"/></p>\n<p class=\"text1\">トレードマーケティング部</p>\n<p class=\"text2\">新垣 凜／與久田 藍香</p>\n</a></li>\n<li><a href=\"/recruite/interview/akamine.html\">\n<p><img src=\"/recruite/img/cmn/men07.jpg\" alt=\"\"/></p>\n<p class=\"text1\">浦添工場 製造二課</p>\n<p class=\"text2\">赤嶺 孝太</p>\n</li>\n<li></li>\n</ul>\n</div>\n<a></a></div>\n</div>\n<!--/row--></li>\n<li><a href=\"/recruite/guideline/\">\n<p>募集要項</p>\n</a></li>\n</ul>\n</nav>\n</div>\n</header>\n \n <!--/header-->\n <main><!--　メイン画像　-->\n <div class=\"secondtitle\">\n      <h2><span class=\"en\">Requirements</span>募集要項</h2>\n    </div>\n  <!--　/ メイン画像　-->\n  <div class=\"site-content\"> <!---p style=\"text-align: center;\">詳細は決まり次第、ご案内いたします。</p---> \n   <!--　募集要項　-->\n   <section class=\"youkou\">\n    <h2>REX株式会社 採用</h2>\n    <p>コカ・コーラなど人気飲料を届ける！<br>\nドライバー未経験から世界的ブランドの一翼を担う</p>\n    <div class=\"shokushu\" style=\"margin-top:2em;\"> \n     <!--<p class=\"heigan\">総合職と技術職の併願が可能です</p>-->\n     <table>\n      <tbody>\n       <tr>\n        <th>募集職種</th>\n        <td><strong>自販機の補充ルート配送ドライバー</strong></td>\n       </tr>\n       <tr>\n        <th>仕事内容</th>\n        <td>主な仕事は、自動販売機へのコカ・コーラ製品の配送と補充となります。<br>\n配送先は、中南部エリアを中心にオフィス・工場・空港などさまざま。<br>\nオーナー様のニーズや売れ筋、周辺環境を把握し、商品の入れ替えやラインナップを調整しましょう。<br><br>\n＜1日の流れ＞<br>\n▼朝礼・準備<br>\n・アルコールチェック<br>\n・ルート先の確認、補充商品を積み込み<br>\n<br>\n▼自動販売機のメンテナンス<br>\n・商品補充、在庫管理、売上金回収、つり銭の補充、空き缶・ペットボトルの回収、周辺の清掃<br>\n・1日15～20件ほど対応<br>\n<br>\n▼お客様対応<br>\n・オーナー様や設置店舗の責任者の方に、新商品・売れ筋商品のご案内<br>\n※毎回ではありませんが、定期的なコミュニケーションをお願いします<br>\n<br>\n▼帰社、倉庫内作業<br>\n・商品管理、ピッキング作業、翌日の準備など<br>\n<br>\n※新しく自動販売機を導入する際は、設置作業も担います\n<br>\n＜入社後＞<br>\n先輩のトラックに同乗し、自動販売機の機械操作や補充方法・運転・ルートの組み立て方などを丁寧に指導します。<br>\n3カ月を目安に、一人で業務ができるようサポートします。<br>\n<br>\n＜トラックの運転資格が無い方＞<br>\n資格取得支援制度を利用し、免許取得を目指していただきます。\n</td>\n       </tr>\n       <tr>\n        <th>求めている人材</th>\n        <td>【必須】<br>\n＊普通自動車免許（AT限定可）<br>\n＊10キロ～15キロの補充商品の持ち運びができる方<br>\n※社内資格支援制度を利用し、必要な免許を取得していただけます<br>\n<br>\n【下記当てはまる方は歓迎いたします】<br>\n＊中型免許（8ｔ未満）または準中型免許（7.5ｔ未満）をお持ちの方<br>\n＊配送経験がある方（優遇）<br>\n<br>\n学歴に関係なく、沖縄の発展に貢献したいとお考えの方を歓迎します。<br>\n社内外問わず積極的にコミュニケーションをとり、協力しあえる方はぜひご応募ください。</td>\n       </tr>\n      </tbody>\n     </table>\n    </div>\n    <div class=\"jouken\">\n     <div class=\"left\">\n      <div class=\"jokenH\">\n       <h3>勤務条件</h3>\n      </div> <table>\n       <tbody>\n        <tr>\n         <th scope=\"row\">配属先（勤務地）</th>\n         <td>沖縄県内事業所（浦添・豊見城・中城）<br>\n※転勤あり（県内各営業所）<br>\n※初任地が浦添ではなく豊見城・中城になる可能性もございます。</td>\n        </tr>\n        <tr>\n         <th scope=\"row\">雇用形態</th>\n         <td>正社員</td>\n        </tr>\n        <tr>\n         <th scope=\"row\">採用人数</th>\n         <td>1名</td>\n        </tr>\n        <tr>\n         <th scope=\"row\">給与</th>\n         <td><p>基本給：155,000円　～　172,000円<br>\n営業手当：24,000円<br>\n＊昇格による昇給あり<br>\n＊賞与あり（年2回　前年度実績3.0ケ月分）</p></td>\n        </tr>\n        <tr>\n         <th scope=\"row\">勤務時間</th>\n         <td>月~日（土曜日を除く）　8：30～17：30（内休憩60分）<br>\n＊基本的にはルートスケジュールによってご自身で調整していただきます。<br>\n＊１日８時間勤務（休憩６０分）　休憩は自分のペースで取得OK</td>\n        </tr>\n        <tr>\n         <th scope=\"row\">休日・休暇</th>\n         <td>週休二日制（シフト制）年間休日105日<br>\n※有給休暇あり<br>\n※前月末にシフトを組むので、希望のお休みが取りやすい！！</td>\n        </tr>\n        <tr>\n         <th scope=\"row\">待遇・福利厚生</th>\n         <td><ul style=\"list-style: disc;margin-left:1.5em;\">\n           <li>雇用・労災・健康・厚生</li>\n           <li>賞与あり（業績による：23年実績　３か月）</li>\n           <li>昇給あり（昇格による）</li>\n           <li>退職金制度あり</li>\n           <li>通勤手当支給</li>\n          </ul></td>\n        </tr>\n        <tr>\n         <th scope=\"row\">会社概要</th>\n         <td>REX株式会社<br>\n          本社所在地：沖縄県浦添市伊祖5-14-1<br>\n          事業内容：清涼飲料水の配送及びオペレーションサービス業<br>\n          従業員数：67名<br>\n          事業所：うるま、中城、豊見城※25年2月まで建替え工事中</td>\n        </tr>\n        <tr>\n         <th scope=\"row\">その他</th>\n         <td>屋内禁煙（屋外喫煙所あり）</td>\n        </tr>\n       </tbody>\n      </table>\n     </div>\n     <div class=\"right\">\n      <div class=\"jokenH\">\n       <h3>応募・採用</h3>\n      </div><div class=\"oubo\"><h2>応募方法</h2><p class=\"catch\">以下応募書類を、郵送もしくはメールにてご提出ください。</p><p style=\"margin-top:1em;\"><strong>履歴書（写真添付）</strong><br>\n        ※履歴書には、必ずメールアドレスの記載をお願いいたします</p><div class=\"atesaki\">\n    <span class=\"box-title\">郵送先</span>\n    <p>〒901-2555 沖縄県浦添市伊祖5-14-1</p><p>沖縄コカ･コーラボトリング株式会社</p><p>グループ人事課　採用担当　宛</p>\n</div><div class=\"atesaki\">\n    <span class=\"box-title\">メールの場合</span>\n    <p>jinji@okinawa.ccbc.co.jp 　<span style=\"font-weight: normal;font-size:12px;\">※件名に「中途採用応募」と記載してください</span></p>\n</div><h2 style=\"margin-top:2em;\">選考内容</h2><p class=\"catch\"><strong>書類選考 → 面接・適性検査  → 内定</strong></p><ul style=\"list-style: disc;margin-left:1.5em;margin-top:1em;\">\n         <li>選考は人物重視です</li>\n         <li>興味がある方はお気軽にお問合せください</li>\n         <li>選考内容は変更となる場合はがございますのでご了承ください</li>\n         <li>「職場見学」は随時受付けています！</li>\n       </ul><h2 style=\"margin-top:2em;\">お問い合わせ</h2><p><strong>人事総務部　グループ人事課　採用担当</strong><br>\n        TEL：098-877-5257（8:30～17:30）<br>\n        Mail：jinji@okinawa.ccbc.co.jp</p></div>\n     </div>\n    </div>\n   </section>\n   <!--　/ 募集要項　--><!--　説明動画　--><!--<section class=\"oubo\"><div class=\"oubotable\"><div class=\"left\"><h2>会社説明動画</h2><p class=\"btnStyle1\"><a href=\"https://www.okinawa.ccbc.co.jp/recruite/movie/\" target=\"_blank\"><span>動画はこちらから（要認証）</span><span class=\"icon-arrow-right\"></span></a></p></div><div class=\"right\"><h2>エントリー</h2><p class=\"catch\">2021年新卒採用のエントリーは終了いたしました。たくさんのご応募ありがとうございました。</p></div></section><!--　/説明動画　--> \n  </div>\n </main>\n <!--　お問い合わせ　-->\n<aside class=\"infoLink\">\n<article class=\"contact\">\n<div class=\"basewidth\"><div class=\"all_contact\"><a href=\"tel:0988775257\" target=\"_blank\" class=\"inqtel\">\n      <p><span class=\"icon-phone\"></span><span class=\"phone\"><strong>098-877-5257</strong><i>平日9:00～17:00</i></span><span class=\"icospc\"></span></p>\n      </a><a href=\"/recruite/guideline/\"  class=\"guideline\"><p><span class=\"icon-file\"></span><span>募集要項</span><span class=\"icospc\"></span></p></a><a href=\"/recruite/form/\" target=\"_blank\"  class=\"inqmail\">\n      <p><span class=\"icon-envelope\"></span><span>採用に関するお問い合わせ</span></p>\n      </a></div>\n</div>\n</article>\n</aside>\n<!--　/ お問い合わせ　--> \n<!--footer-->\n<footer>\n<div id=\"footer\">\n<div class=\"logo\"><a href=\"/recruite/\"><img src=\"/recruite/img/logo.svg\" alt=\"沖縄コカ･コーラボトリング リクルート\"/><span class=\"siteH1\"><span class=\"corp\">沖縄コカ･コーラボトリング</span>RECRUIT SITE</span></a></div>\n<div class=\"footernav\">\n<nav>\n<dl class=\"line\">\n<dt>Contents</dt>\n<dd>\n<ul>\n<li><a href=\"/recruite/message/\">社長メッセージ</a></li>\n<li><a href=\"/recruite/vision/\">企業ビジョン</a></li>\n<li><a href=\"/recruite/culture/\">企業文化</a></li>\n<li><a href=\"/recruite/carrier_plan/\">教育・キャリアプラン</a> </li>\n<li><a href=\"/recruite/guideline/\">募集要項</a> </li>\n<li><a href=\"/recruite/form/\" target=\"_blank\">お問い合わせ</a> </li>\n</ul>\n</dd>\n</dl>\n<dl>\n<dt>Interview </dt>\n<dd>\n<ul>\n<li><a href=\"/recruite/interview/marketing.html\">新垣 凜／與久田 藍香</a></li>\n<li><a href=\"/recruite/interview/akamine.html\">赤嶺 孝太</a></li>\n</ul>\n</dd>\n</dl>\n</nav>\n</div>\n</div>\n<p class=\"copyright\">&copy; Okinawa Coca-Cola Bottling. All rigts reserved.</p>\n</footer>\n<!--/footer-->\n<p class=\"pagetop\"><a href=\"#wrapper\"><img src=\"/recruite/img/pagetop.png\" alt=\"このページのトップへ\"/></a></p>\n<!--SNSボタン-->\n<div id=\"sns\"><a href=\"https://youtube.com/channel/UChsB29BLuWGsuVKFCWQSERA?si=pPadrNdcxwR5iD5V\" target=\"_blank\"><span class=\"icon-youtube\"></span>Youtube</a><a href=\"https://www.instagram.com/okinawa_cocacola_recruit/\" target=\"_blank\"><span class=\"icon-instagram\"></span>Instagram</a></div> \n</div>\n<!--スクリプト--> \n<script>\n$('.fade-layer').animate({\n  'opacity' : '1'\n}, 5000);\n\t</script> \n<script type=\"text/javascript\" src=\"/recruite/js/jetmenu.js\"></script> \n<script type=\"text/javascript\" src=\"/recruite/js/common.js\"></script>\n</body>\n</html>\n","finalUrl":"https://www.okinawa.ccbc.co.jp/recruite/guideline/rex.html","rendered":false,"_cachedAt":"2026-06-23T22:41:29.737Z"}