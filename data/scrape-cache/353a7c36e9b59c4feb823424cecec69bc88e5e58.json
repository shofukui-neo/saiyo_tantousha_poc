<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n  <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n  <link href=\"https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;700&family=Jost:wght@400;700&family=Roboto:wght@500&display=swap\" rel=\"stylesheet\">\n  <link href=\"https://cdn.jsdelivr.net/npm/yakuhanjp@3.4.1/dist/css/yakuhanjp.min.css\" rel=\"stylesheet\">\n  <link rel=\"stylesheet\" href=\"/saiyou/assets/css/main.css?v=260415\">\n</head>\n\n<body class=\"is-top\">\n  <!-- Google Tag Manager (noscript) -->\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-TTNJQPHG\"\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n<!-- End Google Tag Manager (noscript) -->\n  <div class=\"layout-container\">\n    <header class=\"layout-header\">\n      <div class=\"layout-header__inner\">\n        <div class=\"header-logo\">\n          <a href=\"/saiyou/\">\n            <span class=\"header-logo__image\">\n              <img src=\"/saiyou/assets/img/common/logo.png\" alt=\"AGS CORPORATION\" width=\"150\" height=\"51\">\n            </span>\n            <span class=\"header-logo__text\">新卒・キャリア<br class=\"only-pc\">採用サイト</span>\n          </a>\n        </div>\n        <div class=\"header-button only-sp\">\n          <button class=\"js-click\" data-click=\"hamburger\"><span></span><span></span><span></span></button>\n        </div>\n        <div class=\"layout-header__content\">\n          <nav class=\"header-nav\">\n            <div class=\"header-nav__inner\">\n              <ul class=\"header-list hover-color\">\n                <li class=\"header-list__item\">\n                  <a href=\"/saiyou/numbers/\">数字で見るＡＧＳ</a>\n                </li>\n                <li class=\"header-list__item\">\n                  <a href=\"/saiyou/interview/\">社員インタビュー</a>\n                </li>\n                <li class=\"header-list__item\">\n                  <a href=\"/saiyou/hr-message/\">採用責任者メッセージ</a>\n                </li>\n                <li class=\"header-list__item\">\n                  <a href=\"/saiyou/r-message/\">採用担当者メッセージ</a>\n                </li>\n\t\t\t\t  <li class=\"header-list__item only-sp\">\n                  <a href=\"https://www.ags.co.jp/corporate/outline/index.html\">会社情報</a>\n                </li>\n\t\t\t\t  <li class=\"header-list__item only-sp\">\n                  <a href=\"https://ags.smktg.jp/public/application/add/123\">お問い合わせ</a>\n                </li>\n              </ul>\n              <ul class=\"header-buttons hover-outline\">\n                <li class=\"header-buttons__item\">\n                  <a href=\"/saiyou/new/\">\n                    <span>新卒採用</span>\n                  </a>\n                </li>\n                <li class=\"header-buttons__item\">\n                  <a href=\"/saiyou/career/\">\n                    <span>キャリア採用</span>\n                  </a>\n                </li>\n              </ul>\n            </div>\n          </nav>\n        </div>\n      </div>\n    </header>\n    <main class=\"layout-content\">\n<section class=\"section component-header\">\n  <div class=\"component-background\">\n  <svg viewBox=\"0 0 2423 1518\" preserveAspectRatio=\"xMidYMid slice\">\n    <defs>\n      <linearGradient id=\"gradient-stroke\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"0%\">\n        <stop offset=\"32%\" stop-color=\"#d3edf8\"></stop>\n        <stop offset=\"44%\" stop-color=\"#cef4f2\"></stop>\n        <stop offset=\"63%\" stop-color=\"#ffe7db\"></stop>\n      </linearGradient>\n    </defs>\n    <path fill=\"none\" stroke=\"url(#gradient-stroke)\" stroke-linecap=\"round\" d=\"M90.1000,385.001 C91.155,384.965 332.130,688.488 815.610,765.887 C1099.052,809.556 1468.456,754.845 1637.1000,622.1000 C1760.645,516.109 1806.136,452.090 1815.999,310.1000 C1808.923,213.713 1772.364,132.526 1685.1000,99.000 C1629.544,78.449 1548.514,95.358 1483.005,142.196 C1386.240,211.382 1295.211,366.536 1348.1000,574.1000 C1432.369,898.114 1813.031,1243.009 2287.1000,1383.000\"></path>\n  </svg>\n</div>\n\n    <div class=\"section__inner\">\n      <nav class=\"component-breadcrumb\">\n        <ul class=\"component-breadcrumb-list hover-color\">\n          <li class=\"component-breadcrumb-list__item\">\n            <a href=\"/saiyou/\">トップ</a>\n          </li>\n          <li class=\"component-breadcrumb-list__item\">採用における個人情報の取り扱い</li>\n        </ul>\n      </nav>\n      <h1 class=\"component-header__heading\">\n            <span class=\"component-header__heading-en\">PRIVACY POLICY</span>\n            <span class=\"component-header__heading-ja\">採用における個人情報の取り扱い</span>\n        </h1>\n    </div>\n</section>\n\n<section class=\"section\">\n  <div class=\"section__inner\">\n    <div class=\"policy--lead js-inview fadein-up\">\n      <p>\n                採用においてご入力頂きました個人情報につきましては、次の利用目的の範囲内で利用させて頂きます。<br>\n                利用に際しましては、個人情報保護の重要性を十分認識し、細心の注意を払って適切な取り扱いをして参ります。\n            </p>\n    </div>\n\n    <ul class=\"policy-list js-inview fadein-up\">\n      <li class=\"policy-item\">\n        <div class=\"policy-item__inner\">\n          <h2>（１）当社が取得する個人情報について</h2>\n          <ol>\n            <li>ご入力頂きました個人情報（お名前、E-mailアドレス、電話番号、ご住所等）</li>\n            <li>閲覧したWebページ等のデータ（個人情報と紐付けて取得しています）</li>\n            <li>セッション管理のためのCookie情報</li>\n          </ol>\n        </div>\n      </li>\n\n      <li class=\"policy-item\">\n        <div class=\"policy-item__inner\">\n          <h2>（２）個人情報の利用目的について</h2>\n          <ol>\n            <li>\n              ご入力頂きました個人情報につきましては、次の採用活動業務に必要な範囲に限り利用させて頂きます。\n              <ul>\n                <li>採用活動に関わる情報提供や連絡等を行うため</li>\n                <li>採用選考を行うため</li>\n              </ul>\n            </li>\n            <li>応募者が閲覧したWebページ等のデータやセッション管理のためのCookie情報は、応募者に合った、より良い情報をご提供するために利用させていただきます</li>\n            <li>当社グループの「プライオリティルート採用」にて利用するため、最終面接合格者においては利用期間を卒業後3年間とさせていただきます。</li>\n          </ol>\n        </div>\n      </li>\n\n      <li class=\"policy-item\">\n        <div class=\"policy-item__inner\">\n          <h2>（３）グループ企業間での個人情報の共同利用について</h2>\n          <p>当社は、当社グループにおいて個人情報を共同利用しております。</p>\n          <ol>\n            <li>\n              共同利用する個人情報の項目<br>\n              「（１）当社が取得する個人情報について」に記載の項目\n            </li>\n            <li>\n              共同利用する企業の範囲\n              <ul>\n                <li>ＡＧＳ株式会社</li>\n                <li>ＡＧＳビジネスコンピューター株式会社</li>\n                <li>ＡＧＳプロサービス株式会社</li>\n              </ul>\n            </li>\n            <li>\n              共同利用する目的<br>\n              「（２）個人情報の利用目的について」に記載の目的\n            </li>\n            <li>\n              共同利用する個人情報の管理について責任を有する者<br>\n              名称　ＡＧＳ株式会社<br>\n              所在地　埼玉県さいたま市浦和区針ヶ谷四丁目3番25号<br>\n              代表取締役社長　中野　真治\n            </li>\n          </ol>\n        </div>\n      </li>\n\n      <li class=\"policy-item\">\n        <div class=\"policy-item__inner\">\n          <h2>（４）個人情報の第三者提供について</h2>\n          <p>当社は、法令等による要請による場合を除き、取得した応募者の個人情報を第三者に提供することはございません。</p>\n        </div>\n      </li>\n\n      <li class=\"policy-item\">\n        <div class=\"policy-item__inner\">\n          <h2>（５）個人情報の委託について</h2>\n          <p>当社は、業務を円滑に進めるため、業務の全部または一部を委託し、この業務委託先に対して、必要な個人情報を提供することがありますが、この場合に、業務委託先との間で個人情報の取り扱いに関する契約の締結をはじめ、適切な監督を行います。</p>\n        </div>\n      </li>\n\n      <li class=\"policy-item\">\n        <div class=\"policy-item__inner\">\n          <h2>（６）個人情報提供の任意性について</h2>\n          <p>応募者が個人情報を当社へ提供いただくかどうかについては、任意です。ただし、個人情報を提供いただけない場合は、採用選考の対象とならないことがありますのでご了承ください。</p>\n        </div>\n      </li>\n\n      <li class=\"policy-item\">\n        <div class=\"policy-item__inner\">\n          <h2>（７）個人情報の開示、変更、利用停止等のご請求について</h2>\n          <p>応募者はご自身の個人情報について、当社に対して下記のご請求をすることができます。</p>\n          <ol>\n            <li>当社が保有する応募者の個人情報の開示のご請求。</li>\n            <li>当社が保有する応募者の個人情報の内容が事実でない場合には、訂正、追加または削除のご請求。</li>\n            <li>当社が保有している応募者の個人情報の利用の停止、消去のご請求。</li>\n          </ol>\n          <p>上記１．～３．のご請求をされる場合には、下記窓口にご連絡いただきますようお願いいたします。その他、ご請求の内容によってはお答えできない場合もありますので、あらかじめご了承願います。</p>\n        </div>\n      </li>\n\n      <li class=\"policy-item policy-item__footer\">\n        <div class=\"policy-item__inner\">\n          <h2>お問い合わせ窓口</h2>\n          <address>\n            ＡＧＳ株式会社<br>\n            個人情報保護管理者<br>\n            取締役兼常務執行役員　石原 清彦<br>\n            個人情報についてのお問い合わせ先：<br>\n            企画部 Tel：048-825-5975\n          </address>\n        </div>\n      </li>\n    </ul>\n  </div>\n</section>\n<section class=\"section component-cta\">\n  <ul class=\"component-cta-list hover-float\">\n    <li class=\"component-cta-list__item\">\n      <a href=\"/saiyou/new/information/entry/\">\n        <div class=\"component-cta-list__content hover-float__content\">\n          <h3 class=\"component-cta-list__heading\">NEWGRAD ENTRY</h3>\n          <p class=\"component-cta-list__text\">新卒採用エントリー</p>\n        </div>\n        <span class=\"component-arrow component-arrow--large component-arrow--outline\"></span>\n      </a>\n      <figure class=\"component-cta-list__image\">\n\n        <img src=\"/saiyou/assets/img/common/img_cta_top01.jpg\" alt=\"NEWGRAD ENTRY 新卒採用エントリー\" loading=\"lazy\" decoding=\"async\" fetchpriority=\"auto\" width=\"325\" height=\"100\">\n      </figure>\n    </li>\n    <li class=\"component-cta-list__item\">\n      <a href=\"/saiyou/career/information/entry/\">\n        <div class=\"component-cta-list__content hover-float__content\">\n          <h3 class=\"component-cta-list__heading\">CAREER ENTRY</h3>\n          <p class=\"component-cta-list__text\">キャリア採用エントリー</p>\n        </div>\n        <span class=\"component-arrow component-arrow--large component-arrow--outline\"></span>\n      </a>\n      <figure class=\"component-cta-list__image\">\n\n        <img src=\"/saiyou/assets/img/common/img_cta_top02.jpg\" alt=\"CAREER ENTRY キャリア採用エントリー\" loading=\"lazy\" decoding=\"async\" fetchpriority=\"auto\" width=\"325\" height=\"100\">\n      </figure>\n    </li>\n    <li class=\"component-cta-list__item\">\n      <a href=\"https://ags.smktg.jp/public/application/add/123\" target=\"_blank\">\n        <div class=\"component-cta-list__content hover-float__content\">\n          <h3 class=\"component-cta-list__heading\">CONTACT</h3>\n          <p class=\"component-cta-list__text\">お問い合わせはこちら</p>\n        </div>\n        <span class=\"component-arrow component-arrow--large component-arrow--outline\"></span>\n      </a>\n      <figure class=\"component-cta-list__image\">\n\n        <img src=\"/saiyou/assets/img/common/img_cta_top03.jpg\" alt=\"CONTACT お問い合わせはこちら\" loading=\"lazy\" decoding=\"async\" fetchpriority=\"auto\" width=\"325\" height=\"100\">\n      </figure>\n    </li>\n  </ul>\n</section>\n\n</main>\n<footer class=\"layout-footer\">\n  <div class=\"layout-footer__inner\">\n    <div class=\"layout-footer__content\">\n      <p class=\"footer-logo\">\n        <a href=\"/saiyou/\">\n          <span class=\"footer-logo__image\">\n            <img src=\"/saiyou/assets/img/common/logo.png\" alt=\"AGS CORPORATION\" loading=\"lazy\" decoding=\"async\" fetchpriority=\"auto\" width=\"150\" height=\"15\">\n          </span>\n          <span class=\"footer-logo__text\">\n            RECRUIT SITE\n          </span>\n        </a>\n      </p>\n      <ul class=\"footer-sns\">\n        <li class=\"footer-sns__item\">\n          <a href=\"https://x.com/ags_saiyo\" target=\"_blank\" rel=\"noopener noreferrer\">\n            <figure class=\"footer-sns__icon\">\n              <img src=\"/saiyou/assets/img/common/icn_x.svg\" alt=\"X\" loading=\"lazy\" decoding=\"async\" fetchpriority=\"auto\" width=\"23\" height=\"24\">\n            </figure>\n            <p class=\"footer-sns__text\">@ags_saiyo</p>\n          </a>\n        </li>\n        <li class=\"footer-sns__item\">\n          <a href=\"https://www.youtube.com/@AGS%E6%A0%AA%E5%BC%8F%E4%BC%9A%E7%A4%BE%E6%8E%A1%E7%94%A8%E3%83%81%E3%83%A3%E3%83%B3%E3%83%8D%E3%83%AB\" target=\"_blank\" rel=\"noopener noreferrer\">\n            <figure class=\"footer-sns__icon\">\n              <img src=\"/saiyou/assets/img/common/icn_youtube.svg\" alt=\"YouTube\" loading=\"lazy\" decoding=\"async\" fetchpriority=\"auto\" width=\"23\" height=\"16\">\n            </figure>\n            <p class=\"footer-sns__text\">ＡＧＳ株式会社 採用チャンネル</p>\n          </a>\n        </li>\n      </ul>\n    </div>\n\n    <ul class=\"footer-links\">\n      <li class=\"footer-links__item footer-links__item--recruit\">\n        <p class=\"footer-links__text footer-links__text--recruit\">\n          <a href=\"/saiyou/new/\">新卒採用</a>\n        </p>\n      </li>\n      <li class=\"footer-links__item footer-links__item--career\">\n        <p class=\"footer-links__text footer-links__text--career\">\n          <a href=\"/saiyou/career/\">キャリア採用</a>\n        </p>\n      </li>\n      <li class=\"footer-links__item footer-links__item--hr-message\">\n        <p class=\"footer-links__text footer-links__text--hr-message\">\n          <a href=\"/saiyou/hr-message/\">採用責任者メッセージ</a>\n        </p>\n      </li>\n      <li class=\"footer-links__item footer-links__item--sayo_message\">\n        <p class=\"footer-links__text footer-links__text--sayo_message\">\n          <a href=\"/saiyou/r-message/\">採用担当者メッセージ</a>\n        </p>\n      </li>\n      <li class=\"footer-links__item footer-links__item--numbers\">\n        <p class=\"footer-links__text footer-links__text--numbers\">\n          <a href=\"/saiyou/numbers/\">数字で見るＡＧＳ</a>\n        </p>\n      </li>\n      <li class=\"footer-links__item footer-links__item--interview\">\n        <p class=\"footer-links__text footer-links__text--interview\">\n          <a href=\"/saiyou/interview/\">社員インタビュー</a>\n        </p>\n      </li>\n      <li class=\"footer-links__item footer-links__item--company\">\n        <p class=\"footer-links__text footer-links__text--company\">\n          <a href=\"https://www.ags.co.jp/corporate/outline/index.html\" target=\"_blank\" rel=\"noopener noreferrer\">会社情報</a>\n        </p>\n      </li>\n      <li class=\"footer-links__item footer-links__item--contact\">\n        <p class=\"footer-links__text footer-links__text--contact\">\n          <a href=\"https://ags.smktg.jp/public/application/add/123\" target=\"_blank\" rel=\"noopener noreferrer\">お問い合わせ</a>\n        </p>\n      </li>\n    </ul>\n    <div class=\"footer-links2\">\n      <p class=\"footer-copyright\">&copy; ＡＧＳ Corporation. All Rights Reserved.</p>\n      <div class=\"footer-secondary\">\n        <ul class=\"footer-secondary__inner\">\n          <li><a href=\"https://www.ags.co.jp/privacy/index.html\" target=\"_blank\">プライバシーポリシー</a></li>\n          <li><a href=\"/saiyou/privacy-policy/\">採用における個人情報の取り扱い</a></li>\n          <li><a href=\"https://www.ags.co.jp/terms/index.html\" target=\"_blank\">利用規約</a></li>\n          <li><a href=\"https://www.ags.co.jp/corporate/approval/index.html\" target=\"_blank\">認証・認定</a></li>\n        </ul>\n      </div>\n    </div>\n  </div>\n\n</footer>\n</div>\n<script type=\"module\" src=\"/saiyou/assets/js/main.js\"></script>\n<script type=\"module\" src=\"/saiyou/assets/js/main2.js\"></script>\n</body>\n\n</html>\n","finalUrl":"https://www.ags.co.jp/saiyou/privacy-policy/","rendered":false,"_cachedAt":"2026-06-22T17:00:16.166Z"}