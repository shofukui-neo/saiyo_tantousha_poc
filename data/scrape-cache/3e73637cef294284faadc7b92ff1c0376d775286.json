{"url":"https://www.ktec-akashi.co.jp/recruit/people/interview01.html","html":"<!DOCTYPE html>\r\n<html lang=\"ja\">\r\n\r\n<head prefix=\"og: https://ogp.me/ns#\">\r\n    <meta charset=\"UTF-8\">\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n    <meta name=\"description\" content=\"カワサキモータースの関連会社、ケイテックの公式サイトです。川崎重工グループを中心に事業展開するデジタル・ソリューション・カンパニーです。\">\r\n\r\n    <title>RECRUIT | K-TEC 株式会社ケイテック</title>\r\n\r\n    <!-- ファビコン -->\r\n    <link rel=\"icon\" type=\"image/x-icon\" href=\"/recruit/assets/img/index/favicon.png\">\r\n    <link rel=\"apple-touch-icon\" href=\"/recruit/assets/img/index/icon.png\">\r\n\r\n    <!-- ogp -->\r\n    <meta property=\"og:locale\" content=\"ja_JP\">\r\n    <meta property=\"og:site_name\" content=\"RECRUIT | K-TEC 株式会社ケイテック\">\r\n    <meta property=\"og:url\" content=\"https://www.ktec-akashi.co.jp/recruit/\">\r\n    <meta property=\"og:type\" content=\"website\">\r\n    <meta property=\"og:title\" content=\"RECRUIT | K-TEC 株式会社ケイテック\">\r\n    <meta property=\"og:description\" content=\"カワサキモータースの関連会社、ケイテックの採用サイトです。川崎重工グループを中心に事業展開するデジタル・ソリューション・カンパニーです。\">\r\n    <meta property=\"og:image\" content=\"https://www.ktec-akashi.co.jp/recruit/assets/img/ogp-100.jpg\">\r\n\r\n    <!-- font -->\r\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\r\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\r\n    <link\r\n        href=\"https://fonts.googleapis.com/css2?family=Josefin+Sans:ital,wght@0,100..700;1,100..700&family=Noto+Sans+JP:wght@100..900&family=Noto+Sans:ital,wght@0,100..900;1,100..900&family=Roboto:ital,wght@0,100..900;1,100..900&display=swap\"\r\n        rel=\"stylesheet\">\r\n\r\n    <!-- css -->\r\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"../../assets/css/reset.css\">\r\n\r\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"../assets/css/slick.css\">\r\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"../assets/css/slick-theme.css\">\r\n\r\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"../assets/css/recruit.css\">\r\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"../assets/css/interview.css\">\r\n\r\n    <!-- Google tag (gtag.js) -->\r\n    <script async src=\"https://www.googletagmanager.com/gtag/js?id=G-XHJS5KLZ2J\"></script>\r\n    <script>\r\n        window.dataLayer = window.dataLayer || [];\r\n        function gtag() { dataLayer.push(arguments); }\r\n        gtag('js', new Date());\r\n\r\n        gtag('config', 'G-XHJS5KLZ2J');\r\n    </script>\r\n\r\n</head>\r\n\r\n<body>\r\n\r\n    <!-- 共通のヘッダーを使用 -->\r\n    <div id=\"recruit_header\"></div>\r\n\r\n    <main>\r\n        <!-- section01 メインイメージ -->\r\n        <section class=\"interview_sec01\">\r\n            <div class=\"interview_sec01_inn interview01_sec01_inn\">\r\n                <article class=\"interview_top_ttl\">\r\n                    <p class=\"fs16 fc-dblue\">インタビュー</p>\r\n                    <img src=\"../assets/img/interview/interview_top_ttl.png\" alt=\"INTERVIEW\">\r\n                    <div class=\"interview_top_img pc-only\">\r\n                        <img src=\"../assets/img/interview/interview_main_img01.png\" alt=\"\">\r\n                    </div>\r\n                    <!-- パンくずリスト -->\r\n                    <nav aria-label=\"Breadcrumb\" class=\"recruit_breadcrumb\">\r\n                        <ul>\r\n                            <li><a href=\"/recruit/index.html\">TOP</a></li>\r\n                            <li><a href=\"index.html\">人を知る</a></li>\r\n                            <li><span aria-current=\"page\">航空ソリューション部民間エンジン技術課</span></li>\r\n                        </ul>\r\n                    </nav>\r\n                </article>\r\n                <article class=\"interview_top_txt\">\r\n                    <div>\r\n                        <h1>世界とつながる解析の現場で、<br>\r\n                            挑戦がキャリアをつくる。</h1>\r\n                    </div>\r\n                    <div class=\"interview_top_profile_box\">\r\n                        <ul class=\"interview_name\">\r\n                            <li class=\"fs26 fc-white\">航空ソリューション部</li>\r\n                            <li class=\"fs26 fc-white\">民間エンジン技術課</li>\r\n                            <li class=\"fs58 fc-white\">R.M</li>\r\n                            <li class=\"fs20 fc-white\">2023年入社</li>\r\n                            <li class=\"fs20 fc-white\">大学卒（工学部 機械工学科）</li>\r\n                        </ul>\r\n                        <div class=\"pc-only\">\r\n                            <ul class=\"interview_hashtag\">\r\n                                <li class=\"fs15 fc-dblue\">#&emsp;キャリア入社</li>\r\n                                <li class=\"fs15 fc-dblue\">#&emsp;解析</li>\r\n                                <li class=\"fs15 fc-dblue\">#&emsp;社内副業</li>\r\n                                <li class=\"fs15 fc-dblue\">#&emsp;航空エンジン</li>\r\n                                <li class=\"fs15 fc-dblue\">#&emsp;英語</li>\r\n                            </ul>\r\n                        </div>\r\n                    </div>\r\n                </article>\r\n                <div class=\"interview_top_ink pc-only\">\r\n                    <img src=\"../assets/img/interview/interview_top_deco_red.png\">\r\n                </div>\r\n            </div>\r\n            <div class=\"sp-only\">\r\n                <ul class=\"interview_hashtag sp-only\">\r\n                    <li class=\"fs15 fc-dblue\">#&emsp;キャリア入社</li>\r\n                    <li class=\"fs15 fc-dblue\">#&emsp;解析</li>\r\n                    <li class=\"fs15 fc-dblue\">#&emsp;社内副業</li>\r\n                    <li class=\"fs15 fc-dblue\">#&emsp;航空エンジン</li>\r\n                    <li class=\"fs15 fc-dblue\">#&emsp;英語</li>\r\n                </ul>\r\n            </div>\r\n        </section>\r\n\r\n        <!-- section02 入社前 -->\r\n        <section class=\"interview_sec02 fadeUpTrigger\">\r\n            <div class=\"interview_sec02_box\">\r\n                <h1 class=\"fc-dblue border-b_red mark-red\">学生時代に学んだこと</h1>\r\n                <p class=\"fc-dblue fs16_2\">\r\n                    学生時代に、<a class=\"external_link_btn\" href=\"https://www.jsae.or.jp/formula/student-formula/about/\" target=\"_blank\" rel=\"noopener noreferrer\">学生フォーミュラチーム</a>に所属して、学生だけでレーシングカーを開発・製作するという場を経験しました。<br>\r\n                    材料選定、設計、解析、加工、溶接、組み立てなど、ものづくりの流れを実践的に一通り体験したのは大変貴重で良い経験でした。この時の経験や知識が今の職場でも活かされています。\r\n                </p>\r\n            </div>\r\n            <div class=\"interview_sec02_box\">\r\n                <h1 class=\"fc-dblue  border-b_red mark-red\">入社の決め手</h1>\r\n                <p class=\"fc-dblue fs16_2\">\r\n                    出身は北海道で、関西にゆかりはなかったのですが、業務範囲が設計に限らず、解析、組み立て、ジグ設計など多様な点が魅力で、様々な経験を積めると思いました。<br>\r\n                    入社前は実は航空機や乗り物にもそんなに興味があるわけではなかったんです。\r\n                </p>\r\n            </div>\r\n        </section>\r\n\r\n        <!-- section03 キャリアパス -->\r\n        <section class=\"interview_sec03 fadeUpTrigger\">\r\n            <h1 class=\"mark-red\">キャリアパス</h1>\r\n            <div class=\"interview_sec03_inn bgc-lred\">\r\n                <table class=\"table_red\">\r\n                    <tr>\r\n                        <th class=\"fc-red\">2023年</th>\r\n                        <td>\r\n                            ケイテック入社。現航空ソリューション部に配属となる。<br>\r\n                            唯一の解析業務立ち上げメンバーとして業務開始。<br>\r\n                            社内副業制度を利用し他部署の社員と交流、フランスの見本市へ参加。\r\n                        </td>\r\n                    </tr>\r\n                    <tr>\r\n                        <th class=\"fc-red\">2024年</th>\r\n                        <td>チーム体制がスタート。解析寿命評価対象の拡大。</td>\r\n                    </tr>\r\n                    <tr>\r\n                        <th class=\"fc-red\">2025年</th>\r\n                        <td>新入社員教育担当。業務範囲拡大に向けて日々精進中。</td>\r\n                    </tr>\r\n                </table>\r\n            </div>\r\n        </section>\r\n\r\n        <!-- section04 インタビュー -->\r\n        <section class=\"interview_sec04\">\r\n            <article class=\"interview_sec04_box interview_sec04_box01 fadeUpTrigger\">\r\n                <div class=\"interview_sec04_box_txt\">\r\n                    <h2 class=\"fs16 fc-dblue\">現在の仕事とやりがい</h2>\r\n                    <h3 class=\"fs33 fc-white bg-red\">航空エンジン部品の解析業務と<br>\r\n                        国際的な職場環境</h3>\r\n                    <p class=\"fs16_2 fc-dblue\">\r\n                       民間航空エンジン部品の寿命評価を行っています。主にAnsys（アンシス）や取引先のシステムを使った解析業務です。航空機部品は、現物部品で実験すると、何千万・何億のパーツがダメになってしまう世界なので、デジタル解析が必須となります。<br>\r\n                       前職や、学生時代の経験を買ってもらい担当となりました。<br>\r\n                       取引先が海外のため、規格資料、レポートなど全て英語記載であることに加え、川崎重工側のスタッフに外国人が多いことから会議やコミュニケーションも英語でとっています。「何千人もの命を運ぶ乗り物」の部品の解析を行う責任感を感じています。\r\n                    </p>\r\n                </div>\r\n                <div class=\"interview_sec04_box_img\">\r\n                    <img src=\"../assets/img/interview/interview01_img01.png\" alt=\"\">\r\n                </div>\r\n            </article>\r\n            <article class=\"interview_sec04_box interview_sec04_box02 fadeUpTrigger\">\r\n                <div class=\"interview_sec04_box_txt\">\r\n                    <h2 class=\"fs16 fc-dblue\">印象に残っている仕事や成長を実感した点</h2>\r\n                    <h3 class=\"fs33 fc-white bg-red\">チームで挑戦した<br>\r\n                        革製品企画と海外出展</h3>\r\n                    <p class=\"fs16_2 fc-dblue\">\r\n                        入社1年目で社内副業制度を利用し、神戸レザーさんとコラボし、企画から製作までを担当。パリの見本市出展も果たしました。<br>\r\n                        普段とは全く異なる業界、業種の方と折衝やマネジメントがあり、意思疎通がうまくいかずギャップを埋めるのに苦労しました。別部署の同世代とチームだったため、普段交流を取らない部門との交流もでき仲良くなれたのも楽しく良い思い出です。\r\n                    </p>\r\n                </div>\r\n                <div class=\"interview_sec04_box_img\">\r\n                    <img src=\"../assets/img/interview/interview01_img02.png\" alt=\"\">\r\n                </div>\r\n            </article>\r\n            <article class=\"interview_sec04_box interview_sec04_box03 fadeUpTrigger\">\r\n                <div class=\"interview_sec04_box_txt\">\r\n                    <h2 class=\"fs16 fc-dblue\">職場環境</h2>\r\n                    <h3 class=\"fs33 fc-white bg-red\">異文化交流と英語力向上、<br>\r\n                        若手中心の職場環境</h3>\r\n                    <p class=\"fs16_2 fc-dblue\">\r\n                        一日の大半を川崎重工のオフィスで過ごし川重社員や取引先とのやり取りで過ごします。川崎重工スタッフの外国人と特に仲良しで、休憩中の雑談を通した文化交流も面白いです。もともと英語が得意というわけではなかったですが、日々コミュニケーションを取るうちに英語スキルがアップしています！<br>\r\n                        ケイテックチームとのコミュニケーションは日常では短時間ですが、20代30代の若い人が多い職場のため、和気あいあいとした雰囲気です。\r\n                    </p>\r\n                </div>\r\n                <div class=\"interview_sec04_box_img\">\r\n                    <img src=\"../assets/img/interview/interview01_img03.png\" alt=\"\">\r\n                </div>\r\n            </article>\r\n        </section>\r\n\r\n        <!-- section05 タイムスケジュール -->\r\n        <section class=\"interview_sec05 fc-white fadeUpTrigger\">\r\n            <div class=\"interview_sec05_inn\">\r\n                <h1 class=\"mark-red\">ある日のスケジュール</h1>\r\n                <ul class=\"interview_sec_box fs20 red_list_mark\">\r\n                    <li class=\"interview_sec_box01\">\r\n                        <ul>\r\n                            <li><span class=\"fc-red\">07:00</span>起床</li>\r\n                            <li><span class=\"fc-red\">08:00</span>出社、川崎重工側の自席へ移動</li>\r\n                            <li><span class=\"fc-red\">12:00</span>弁当持参で動画を見ながら自席ランチ</li>\r\n                        </ul>\r\n                    </li>\r\n                    <li class=\"interview_sec_box02\">\r\n                        <ul>\r\n                            <li><span class=\"fc-red\">18:00</span>業務終了、帰宅</li>\r\n                            <li><span class=\"fc-red\">19:00</span>夕食</li>\r\n                            <li><span class=\"fc-red\">23:00</span>就寝</li>\r\n                        </ul>\r\n                    </li>\r\n                </ul>\r\n            </div>\r\n        </section>\r\n\r\n        <!-- section06 仕事のやりがい -->\r\n        <section class=\"interview_sec06 fadeUpTrigger\">\r\n\r\n            <div class=\"interview_sec06_box\">\r\n                <div class=\"interview_sec06_box_img interview_sec06_box_img-red fukidashi01\">\r\n                    <h4 class=\"fs26 fc-red sp-only\">仕事のやりがいとは？</h4>\r\n                    <img src=\"../assets/img/interview/interview01_img04.png\" alt=\"\">\r\n                </div>\r\n                <div class=\"interview_sec06_box_txt\">\r\n                    <div class=\"interview_sec06_box_txt_inn interview_sec06_box_txt_inn01\">\r\n                        <h4 class=\"fs26 fc-red\">ケイテックの好きなところ</h4>\r\n                        <p class=\"fs16_2 fc-dblue\">\r\n                            いい意味で癖の強い人が多いので飽きないです。有給休暇、長期休暇が多いためリフレッシュしやすく、スーパーフレックス制度もスケジュール調整に活用しています。<br>\r\n                            明石は住んでみると、京都や大阪へもアクセスが良く、休日も楽しんでいます。ユニバーサルスタジオの年間パスも買いました！<br>\r\n                            明石に来て初めて食べた明石焼もお気に入り。\r\n                        </p>\r\n                    </div>\r\n                    <div class=\"interview_sec06_box_txt_inn interview_sec06_box_txt_inn02\">\r\n                        <h4 class=\"fs26 fc-red\">未来の自分へ</h4>\r\n                        <p class=\"fs16_2 fc-dblue\">\r\n                            「ほどほどに そこそこに。」<br>\r\n                            良い意味で自分にも他人にも過度な期待はしないのは大切。このぐらいできたらいいだろう！のメンタルでいると、自分を追い込むことなく自分らしく仕事が出来るような気がします。いつでも自然体でいることを大切に。\r\n                        </p>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n        </section>\r\n\r\n        <!-- section07 学生さんへメッセージ -->\r\n        <section class=\"interview_sec07 bgc-lred border-red fadeUpTrigger\">\r\n            <div class=\"interview_sec07_box_txt_ttl pc-only\">\r\n                <img src=\"../assets/img/interview/message_ttl_red_pc.png\">\r\n            </div>\r\n            <div class=\"interview_sec07_box_txt_ttl sp-only \">\r\n                <img src=\"../assets/img/interview/message_ttl_red_sp.png\">\r\n            </div>\r\n            <div class=\"interview_sec07_box\">\r\n                <div class=\"interview_sec07_box_img\">\r\n                    <img src=\"../assets/img/interview/interview01_img05.png\" alt=\"\">\r\n                </div>\r\n                <div class=\"interview_sec07_box_txt\">\r\n                    <p class=\"fs16_2 fc-dblue\">\r\n                        気張らずに生きられる会社が一番です。<br>\r\n                        自分に合った会社を追い求めてください。<br>\r\n                        無理すると後々しんどくなっちゃうので。<br>\r\n                    </p>\r\n                </div>\r\n            </div>\r\n        </section>\r\n\r\n        <!-- section08 リンク -->\r\n        <section class=\"interview_sec08\">\r\n            <!-- OTHER INTERVIEW -->\r\n            <article class=\"other_interview_link_article border-b_dblue\">\r\n                <div class=\"other_interview_links_ttl\">\r\n                    <h1>OTHER INTERVIEW</h1>\r\n                </div>\r\n                <ul class=\"other_interview_links\">\r\n                    <li>\r\n                        <a href=\"interview01.html\">\r\n                            <div class=\"interview_link_btn\">\r\n                                <div class=\"pc-only\">\r\n                                    <img src=\"../assets/img/interview/interview_link_btn_img01.png\" alt=\"\">\r\n                                </div>\r\n                                <div class=\"sp-only\">\r\n                                    <img src=\"../assets/img/interview/interview_link_btn_img01_sp.png\" alt=\"\">\r\n                                </div>\r\n                                <div class=\"interview_link_btn_txt\">\r\n                                    <p class=\"fc-white fs12\">2023年入社</p>\r\n                                    <p class=\"fc-white fs14\">航空ソリューション部<br>\r\n                                        民間エンジン技術課</p>\r\n                                </div>\r\n                            </div>\r\n          