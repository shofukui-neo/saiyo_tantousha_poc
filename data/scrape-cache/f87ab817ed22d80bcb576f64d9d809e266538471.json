 \")\";\r\n\t\t\tvar tabbox = \".tab_box0\" + indexnum;\r\n\r\n\t\t\t$('.tab_box').removeClass('view');\r\n\t\t\t$('.news_nav ul li').removeClass('active');\r\n\t\t\t$(tabbox).addClass('view');\r\n\t\t\t$(tabnav).addClass('active');\r\n\t\t});\r\n\r\n\t\tif($(\"html,body\").scrollTop() < headerHeight){// ïŋ―Eïŋ―Bïŋ―ïŋ―ïŋ―hïŋ―Eïŋ―ïŋ―ïŋ―Jïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―Éwïŋ―bïŋ―_ïŋ―[ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―xïŋ―Ėïŋ―ïŋ―ïŋ―ïŋ―Åïŋ―ïŋ―ïŋ―ïŋ―\r\n\r\n\t\t\t$('html, body').animate({scrollTop: headerHeight}, \"normal\", null, init); // ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―[ïŋ―hïŋ―ïŋ―ïŋ―Éyïŋ―[ïŋ―Wïŋ―Åãïŋ―Éßïŋ―\r\n\r\n\t\t}else{\r\n\r\n\t\t\tinit();\r\n\r\n\t\t}\r\n\r\n\t});\r\n\r\n\tvar vInitFlg;\r\n\r\n\tfunction init(){\r\n\r\n\t\tif(vInitFlg){ return false; };\r\n\r\n\t\tvInitFlg = true;\r\n\r\n\t\t$(\"#mv_arr\").addClass('active');\r\n\r\n\t\t$(\".lazy\").lazyload();\r\n\r\n\t\t$(document).scroll(function(){\r\n\t\t\tif($(\".main_visual\").offset().top <= $(this).scrollTop()){ // ïŋ―Xïŋ―Nïŋ―ïŋ―ïŋ―[ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―boxïŋ―ĖĘuïŋ―ðīïŋ―ïŋ―ïŋ―ïŋ―ïŋ―A\r\n\t\t\t\t$(\".company_bar\").addClass('follow');\r\n        $(\".company_bar\").removeClass('not_follow'); // ïŋ―ufollowïŋ―vïŋ―Æïŋ―ïŋ―ïŋ―classïŋ―ïŋ―Įïŋ―ïŋ―ïŋ―ïŋ―ïŋ―\r\n\t\t\t}else{ // ïŋ―Xïŋ―Nïŋ―ïŋ―ïŋ―[ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―yïŋ―[ïŋ―Wïŋ―ïŋ―ÜÅßïŋ―ïŋ―ïŋ―ïŋ―ïŋ―A\r\n\t\t\t\t$(\".company_bar\").removeClass('follow');\r\n        $(\".company_bar\").addClass('not_follow'); // classïŋ―ïŋ―ïŋ―í\r\n\t\t\t}\r\n\t\t});\r\n\r\n\t\tvideoIntervalId = setInterval(checkVideoTag, 100);\r\n\r\n\t}\r\n\r\n\tfunction onWindowResize(){\r\n\r\n\t\t$(\".main_visual\").css(\"height\", $(window).height() + \"px\");\r\n\r\n\t\tvar w = 1920;\r\n\t\tvar h = 1080;\r\n\r\n\t\tvar ratio = Math.max($(\".main_visual .inner_box\").width() / w, $(\".main_visual .inner_box\").height() / h);\r\n\r\n\t\t$(\".main_visual .inner_box .video\").css({width:w * ratio, height:h * ratio});\r\n\r\n\t}\r\n\r\n\tvar vTag;\r\n\tvar videoIntervalId;\r\n\tvar videoTimeoutId;\r\n\r\n\tfu