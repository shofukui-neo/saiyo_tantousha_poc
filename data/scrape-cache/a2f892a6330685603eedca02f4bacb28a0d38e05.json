***************-->\n\n<!--==Container Contents Start=====================================================================-->\n<div class=\"main-container clearfix\">\n<div class=\"wrapper-area underbg clearfix\">\n\n<!--==h1 Start=============================================--> \n<div class=\"h1-area\">\n    <div class=\"h1-area-in\">\n        <h1>開発ヒストリー</h1>\n    </div>\n</div><hr><!--//h1-area-->\n<!--==//h1 End===========================================-->\n\n<!--==Wrapper Start=====================================================================-->\n<div id=\"wrapper-under\" class=\"clearfix\">\n\n<!--**[Main Area Start]**********************************************************-->\n<article>\n<div id=\"main\" class=\"clearfix\">\n\n<!--==Main Contents Start=====================================================================-->\n<div class=\"main-contents\">\n\n\n\n\n<div class=\"h2-catch-area\">\n    <div class=\"h2-catch-area-in\">\n        <h2>発明のきっかけを探る。<br>\n            トップシェアにいたるまでのひらめき</h2>\n    </div>\n</div>\n\n\n<div class=\"center-text-area\">\n    <div class=\"center-text-area-in\">\n        <p>社会、そして多くのユーザのニーズに応え、開発に取り組むチップトン。<br>\n            多様な問題解決を実現する開発ヒストリーに注目してください。</p>\n    </div>\n</div>\n\n\n\n<div class=\"invention-history-area\">\n    <div class=\"invention-history-area-in\">\n        <ul>\n            <li class=\"y1962\" data-aos=\"fade-right\" id=\"p01\">\n                <picture>\n                    <source media=\"(max-width: 767px)\" srcset=\"../../common/image/technology/t18-history-ph001-sp.png\">\n                    <img src=\"../../common/image/technology/t18-history-ph001.png\" alt=\"1962 遠心バレル研磨機を発明！\">\n                </picture>\n                <a href=\"../../technology/invention/barrel/\" class=\"btn\">開発ヒストリーを見る</a>\n            </li>\n            <li class=\"y1968\" data-aos=\"fade-right\">\n                <picture>\n                    <source media=\"(max-width: 767px)\" srcset=\"../../common/image/technology/t18-history-ph003-sp.png\">\n                    <img src=\"../../common/image/technology/t18-history-ph003.png\" alt=\"1968 微小切削研磨石を発明！\">\n                </picture>\n            </li>\n            <li class=\"y1970\" data-aos=\"fade-left\">\n                <picture>\n                    <source media=\"(max-width: 767px)\" srcset=\"../../common/image/technology/t18-history-ph004-sp.png\">\n                    <img src=\"../../common/image/technology/t18-history-ph004.png\" alt=\"1970 多重多段層振動バレル研磨機を発明！\">\n                </picture>\n            </li>\n            <li class=\"y1973\" data-aos=\"fade-right\">\n                <picture>\n                    <source media=\"(max-width: 767px)\" srcset=\"../../common/image/technology/t18-history-ph005-sp.png\">\n                    <img src=\"../../common/image/technology/t18-history-ph005.png\" alt=\"1973 無芯振動バレル研磨機を発明！\">\n                </picture>\n            </li>\n            <li class=\"y1985\" data-aos=\"fade-left\">\n                <picture>\n                    <source media=\"(max-width: 767px)\" srcset=\"../../common/image/technology/t18-history-ph006-sp.png\">\n                    <img src=\"../../common/image/technology/t18-history-ph006.png\" alt=\"1985 振動式磁気選別機を発明！\">\n                </picture>\n            </li>\n            <li class=\"y1987\" data-aos=\"fade-right\">\n                <picture>\n                    <source media=\"(max-width: 767px)\" srcset=\"../../common/image/technology/t18-history-ph007-sp.png\">\n                    <img src=\"../../common/image/technology/t18-history-ph007.png\" alt=\"1987 全自動ヘビーハイブリッドバレルを発明！\">\n                </picture>\n            </li>\n            <li class=\"y1993\" data-aos=\"fade-left\">\n                <picture>\n                    <source media=\"(max-width: 767px)\" srcset=\"../../common/image/technology/t18-history-ph008-sp.png\">\n                    <img src=\"../../common/image/technology/t18-history-ph008.png\" alt=\"1993 乾式バレル研磨機を発明！\">\n                </picture>\n            </li>\n            <li class=\"y1999\" data-aos=\"fade-right\" id=\"p02\">\n                <picture>\n                    <source media=\"(max-width: 767px)\" srcset=\"../../common/image/technology/t18-history-ph009-sp.png\">\n                    <img src=\"../../common/image/technology/t18-history-ph009.png\" alt=\"1999 食品コーティング機を発明！\">\n                </picture>\n                <a href=\"../../technology/invention/coating/\" class=\"btn\">開発ヒストリーを見る</a>\n            </li>\n            <li class=\"y2001\" data-aos=\"fade-left\">\n                <picture>\n                    <source media=\"(max-width: 767px)\" srcset=\"../../common/image/technology/t18-history-ph010-sp.png\">\n                    <img src=\"../../common/image/technology/t18-history-ph010.png\" alt=\"2001 全自動研磨システム機を発明！\">\n                </picture>\n            </li>\n            <li class=\"y2005\" data-aos=\"fade-right\">\n                <picture>\n                    <source media=\"(max-width: 767px)\" srcset=\"../../common/image/technology/t18-history-ph011-sp.png\">\n                    <img src=\"../../common/image/technology/t18-history-ph011.png\" alt=\"2005 過流バレルクリアランスゼロ機を発明！\">\n                </picture>\n            </li>\n            <li class=\"y2015\" data-aos=\"fade-left\">\n                <picture>\n                    <source media=\"(max-width: 767px)\" srcset=\"../../common/image/technology/t18-history-ph012-sp.png\">\n                    <img src=\"../../common/image/technology/t18-history-ph012.png\" alt=\"2015 高洗浄光沢用コンパウンドを発明！\">\n                </picture>\n                <a href=\"../../technology/invention/compound/\" class=\"btn\">開発ヒストリーを見る</a>\n            </li>\n            <li class=\"y2015-2\" data-aos=\"fade-right\" id=\"p03\">\n                <picture>\n                    <source media=\"(max-width: 767px)\" srcset=\"../../common/image/technology/t18-history-ph013-sp.png\">\n                    <img src=\"../../common/image/technology/t18-history-ph013.png\" alt=\"2015 重圧バレル研磨機を発明！\">\n                </picture>\n                <a href=\"../../technology/invention/mighty-mild/\" class=\"btn btn-r\">開発ヒストリーを見る</a>\n            </li>\n        </ul>\n        <div class=\"txt-box\">\n            <h3>発明が創る会社の未来！</h3>\n            <h4>とどまることない前進が<br class=\"sp-line\">新しい時代へのアプローチに</h4>\n            <p class=\"txt\">新しい発想が新しい技術を創造し、世界市場へとつなぐ確かなアプローチに。<br>\n                常にお客様の声に耳を傾け、技術・生産へとフィードバックする体制、<br class=\"pc-line\">発明へのあくなきチャレンジスピリットがチップトンの未来を築いています。</p>\n        </div>\n    </div>\n\n</div>\n\n\n\n\n</div><!--//main-contents-->\n<!--==//Main Contents End=====================================================================-->\n</div><!--//main-->\n</article>\n<!--**[//Main Area End]**********************************************************-->\n\n</div><!--//wrapper-under-->\n<!--==//Wrapper End=====================================================================-->\n\n</div><!--//wrapper-area-->\n</div><!--//main-container-->\n<!--==//Container Contents End=====================================================================-->\n\n<!--**[Container Footer Start]**********************************************************-->\n\n<alfooter>\n<div class=\"container footer-area clear clearfix\">\n        <div id=\"alfooter\">\n        <!--==Footer Entry Area Start=================================-->\n            <div class=\"alfooter-entry-area\">\n            <div class=\"alfooter-entry-area-in\">\n                <p class=\"lead\">チップトンはあなたを待っています！</p>\n                <h3>エントリーはこちらから</h3>\n                <ul>\n                    <li><a href=\"https://www.tipton.co.jp/recruit/form/entry/\" target=\"_blank\"><span>新卒採用</span></a></li>\n                    <li><a href=\"https://www.tipton.co.jp/recruit/form/entry/\" target=\"_blank\"><span>中途採用</span></a></li>\n                    <li><a href=\"https://www.tipton.co.jp/recruit/form/entry/\" target=\"_blank\"><span>アルムナイ採用</span></a></li>\n                    <li></li>\n                </ul>\n            </div>\n         </div>\n        <!--==//Footer Entry Area End=================================-->\n</div>  \n<div id=footer>\n        <!--==Footer Navi Start=================================-->\n        <div class=\"footer-navi-area clearfix\"> \n            <ul class=\"footer-navi clearfix\">\n                <li><a href=\"../../sitemap.html\">サイトマップ</a></li>\n            </ul>\n        </div><hr><!--//footer-navi-area-->\n        <!--==//Footer Navi End=================================-->\n        <div class=\"sig-area clearfix\">\n            <div class=\"sig-area-in clearfix\">\n                <p>株式会社チップトン</p>\n                <address>〒457-8566 名古屋市南区豊田三丁目19番21号<br>電話：052-691-5177（本社 総務・人事課 ）<br>メール：&#115;&#111;&#117;&#109;&#117;&#64;&#116;&#105;&#112;&#116;&#111;&#110;&#46;&#99;&#111;&#46;&#106;&#112;</address>\n                <a href=\"http://www.tipton.co.jp/\" target=\"_blank\" class=\"btn\">チップトンコーポレートサイト</a>\n            </div>\n        </div><!--//sig-area-->\n\n\n        <p class=\"copy\">Copyright © Tipton Corp. All rights reserved.</p>\n    </div><!--//footer-->\n</div>\n</alfooter>\n\n<!--**[//Container Footer End]**********************************************************-->\n\n\n</div><!--//body-in-->\n\n<script type=\"text/javascript\">\nvar gaJsHost = ((\"https:\" == document.location.protocol) ? \"https://ssl.\" : \"http://www.\");\ndocument.write(unescape(\"%3Cscript src='\" + gaJsHost + \"google-analytics.com/ga.js' type='text/javascript'%3E%3C/script%3E\"));\n</script>\n<script type=\"text/javascript\">\ntry {\nvar pageTracker = _gat._getTracker(\"UA-3069441-1\");\npageTracker._trackPageview();\n} catch(err) {}</script>\n\n<script src=\"https://cdn.rawgit.com/michalsnik/aos/2.1.1/dist/aos.js\"></script>\n<script>\n    AOS.init({\n        offset: 125,\n        duration: 500,\n        easing: 'ease-in-sine',\n        delay: 100,\n    });\n</script>\n</body>\n</html>