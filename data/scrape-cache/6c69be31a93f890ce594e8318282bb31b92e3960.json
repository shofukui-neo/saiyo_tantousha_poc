{"url":"https://www.super-marui.com/recruit/fisheries/session1.html","html":"<!DOCTYPE html>\n<html lang=\"ja-JP\">\n <head> \n  <meta charset=\"UTF-8\"> \n  <meta http-equiv=\"content-type\" content=\"text/html; charset=UTF-8\"> \n  <meta name=\"robots\" content=\"index\"> \n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"> \n  <meta name=\"description\" content=\"週末の水産トップの売り場を全店統一にする“見本売り場”の配信。このプロジェクトから、仕入れ担当のバイヤーと売り場を動かすチーフの連携を取材した。\"> \n  <meta property=\"og:title\" content=\"マルイが挑む「プロジェクト」|リクルート採用情報サイト\"> \n  <meta property=\"og:type\" content=\"website\"> \n  <meta property=\"og:image\" content=\"https://www.super-marui.com/recruit/bdflashinfo/thumbnail-large.png\"> \n  <meta property=\"og:url\" content=\"https://www.super-marui.com/recruit/fisheries/session1.html\"> \n  <meta property=\"og:site_name\" content=\"リクルート採用情報サイト | 株式会社マルイ\"> \n  <meta property=\"og:description\" content=\"週末の水産トップの売り場を全店統一にする“見本売り場”の配信。このプロジェクトから、仕入れ担当のバイヤーと売り場を動かすチーフの連携を取材した。\"> \n  <meta name=\"twitter:card\" content=\"summary_large_image\"> \n  <meta name=\"twitter:image\" content=\"https://www.super-marui.com/recruit/bdflashinfo/thumbnail-large.png\"> \n  <meta name=\"note:card\" content=\"summary_large_image\"> \n  <link rel=\"canonical\" href=\"https://www.super-marui.com/recruit/fisheries/session1.html\"> \n  <title>マルイが挑む「プロジェクト」|リクルート採用情報サイト</title> \n  <link rel=\"stylesheet\" type=\"text/css\" href=\"../_module/styles/bind.css?v=17.0.6\" id=\"bind-css\"> \n  <link rel=\"stylesheet\" type=\"text/css\" href=\"../_dress/b014006/base.css?1777131011154\"> \n  <link rel=\"stylesheet\" type=\"text/css\" href=\"../_dress/b14006Navi/base.css?1777131011154\"> \n  <link rel=\"stylesheet\" type=\"text/css\" href=\"../_dress/b14006Main1/base.css?1777131011154\"> \n  <link rel=\"stylesheet\" type=\"text/css\" href=\"../_dress/93f5ddf232da4e5eabf8affc97d8ac99/base.css?1777131011154\"> \n  <link rel=\"stylesheet\" type=\"text/css\" href=\"https://fonts.googlea