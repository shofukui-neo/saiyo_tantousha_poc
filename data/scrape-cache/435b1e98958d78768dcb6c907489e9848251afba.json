\r\n        <dt class=\"input-form_ttl\">ご相談内容</dt>\r\n        <dd class=\"input-form_txt\">\r\n\t        <dl class=\"input-form-subform\">\r\n\t\t        <dt>■ 相談希望先</dt>\r\n\t\t        <dd class=\"contact-radio\" style=\"display: inline-block\">\r\n\t\t\t        <input type=\"radio\" id=\"agent_type01\" name=\"agent_type\" value=\"弁護士\" >\r\n\t\t\t        <label for=\"agent_type01\">弁護士</label>\r\n\t\t\t        <input type=\"radio\" id=\"agent_type02\" name=\"agent_type\" value=\"税理士\" >\r\n\t\t\t        <label for=\"agent_type02\">税理士</label>\r\n\t\t\t        <input type=\"radio\" id=\"agent_type03\" name=\"agent_type\" value=\"社会保険労務士\" >\r\n\t\t\t        <label for=\"agent_type03\">社会保険労務士</label>\r\n\t\t\t        <input type=\"radio\" id=\"agent_type04\" name=\"agent_type\" value=\"当社コンサルタント\" >\r\n\t\t\t        <label for=\"agent_type04\">当社コンサルタント</label>\r\n\t\t        </dd>\r\n\t\t        <dt>■ 相談方法</dt>\r\n\t\t        <dd class=\"contact-radio\" style=\"\">\r\n\t\t\t        <input type=\"radio\" id=\"contact_way01\" name=\"contact_way\" value=\"電話\" >\r\n\t\t\t        <label for=\"contact_way01\">電話</label>\r\n\t\t\t        <input type=\"radio\" id=\"contact_way02\" name=\"contact_way\" value=\"面談\" >\r\n\t\t\t        <label for=\"contact_way02\">面談</label>\r\n\t\t        </dd>\r\n\t\t        <dt>■ 希望連絡時間</dt>\r\n\t\t        <dd>\r\n\t\t\t        <input type=\"text\" name=\"contact_time\" placeholder=\"\" >\r\n\t\t        </dd>\r\n\t\t        <dt>■ 概要</dt>\r\n\t\t        <dd>\r\n\t\t\t        <textarea id=\"\" cols=\"52\" rows=\"8\" name=\"msg_consultation\" ></textarea>\r\n\t\t\t        <p style=\"line-height: 1.4em\" class=\"input-form_txt-point\">ご相談いただいたお問い合わせ内容はメール受領後、原則お申し込みの当日または翌営業日のうちに<br>専門家・当社コンサルタントより直接ご連絡します。(土・日・祝日除く)</p>\r\n\t\t        </dd>\r\n\t        </dl>\r\n        </dd>\r\n      </dl>\r\n    </div>\r\n\t  <!-- ↑↑ -->\r\n\t  <style>\r\n\t\t  .input-form-subform {\r\n\t\t  }\r\n\t\t  .input-form-subform dt {\r\n\t\t\t  margin-bottom: .5em;\r\n\t\t\t  color: #014285;\r\n\t\t  }\r\n\t\t  .input-form-subform dd {\r\n\t\t\t  margin-bottom: 2em;\r\n\t\t  }\r\n\t\t  .input-form-subform dd label {\r\n\t\t\t  margin-right: 2em;\r\n\t\t\t  padding-left: 2em !important;\r\n\t\t\t  display: inline-block !important;\r\n\t\t  }\r\n\t\t  \r\n\t  </style>\r\n    <div class=\"form-point_txt\">「<a href=\"../../html/regulation/person.html\">個人情報保護</a>」に関する利用目的をご確認・ご同意のうえ、「確認画面へ」ボタンを押して、入力内容をご確認ください。「取り消し」ボタンを押すと、入力した内容がすべて消去されます。</div>\r\n    <div class=\"form_btn\">\r\n      <div class=\"input_btn\">\r\n        <input type=\"button\" class=\"btn-color02\" value=\"確認画面へ\" onclick=\"javascript:toi_check();\">\r\n      </div>\r\n      <div class=\"input_reset\">\r\n        <input type=\"reset\" value=\"取り消し\">\r\n      </div>\r\n    </div>\r\n  </form>\r\n</section>\r\n\t  \r\n\r\n\r\n\r\n<div class=\"page-top_btn\"> <a href=\"#page-top\">&nbsp;</a> </div>\r\n<footer>\r\n  <nav class=\"top__footer-navi\">\r\n    <ul>\r\n      <li><a href=\"/html/site_map/\">サイトマップ</a></li>\r\n      <li><a href=\"/html/regulation/index.html\">免責・利用規定</a></li>\r\n      <li><a href=\"/html/security_policy/index.html\">情報セキュリティ基本方針</a></li>\r\n      <li><a href=\"/html/regulation/person.html\">個人情報保護について</a></li>\r\n      <li><a href=\"/html/regulation/shareduse.html\">法人等のお客さまの情報の共同利用について</a></li>\r\n    </ul>\r\n  </nav>\r\n  <p class=\"footer__txt\"> 【浜銀総合研究所は、横浜銀行グループのシンクタンク・コンサルティング会社。地元神奈川、横浜、川崎、東京に密着した調査から全国規模および海外にいたるまでの専門的研究を手がけています。】<br>\r\n    このホームページに関するご意見、お問合せは、<a href=\"/html/inquiry/inquiry.html\">こちら</a>までお願いします。このホームページの内容を、許可無く転載・複製することを禁止します。 </p>\r\n  <small>Copyright 2019 (C) Hamagin Research Institute,Ltd.All rights reserved.</small> </footer>\r\n<script>\r\n\t// Fix link value (as dev)\r\n\tlet $prd_domain = 'www.yokohama-ri.co.jp';\r\n\tlet $this_domain = window.location.hostname;\r\n\tlet $env = ($this_domain === $prd_domain) ? 1 : 0;\r\n\t$(function(){\r\n\t\tif ($env === 0)\r\n\t\t{\r\n\t\t\t$('a').each(function(){\r\n\t\t\t\tlet $href = $(this).attr('href');\r\n\t\t\t\tlet $is_target = ($(this).hasClass('noRewrite')) ? 0 : 1;\r\n\t\t\t\tlet $href_fix = $href.replace($prd_domain, $this_domain);\r\n\t\t\t\tif ($is_target) $(this).attr('href', $href_fix);\r\n\t\t\t})\r\n\t\t}\r\n\t})\r\n</script><div class=\"site_login_wrap\">\r\n  <div id=\"site__close-btn\">\r\n    <div id=\"site__close-btn-inner\"> <span></span> <span></span> </div>\r\n  </div>\r\n  <div class=\"site_login_inner\">\r\n    <form autocomplete=\"off\">\r\n      <p class=\"site_login_ttl\">会員ログイン</p>\r\n        <div id=\"account_lock_message\" style=\"color:#ff0000;font-size: 14px;margin-bottom: 20px;display:none;\">10回連続ログイン失敗により、アカウントがロックされました。<br/>1時間後に解除されますが、お急ぎの場合は管理者へお問い合わせください。</div>\r\n        <div id=\"login_error_message\" style=\"color:#ff0000;font-size: 14px;margin-bottom: 20px;display:none;\">会員IDかパスワードが間違っています</div>\r\n      <p class=\"site_login_id\">\r\n        <input type=\"text\" name=\"memberid\" placeholder=\"会員ID\" >\r\n      </p>\r\n      <p class=\"site_login_id\">\r\n        <input type=\"password\"  name=\"passwd\" placeholder=\"パスワード\">\r\n      </p>\r\n      <p class=\"site_login_txt\">＊会員IDまたはパスワードをお忘れの方は<a href=\"/html/inquiry/inquiry.html?nno=3\">こちら</a></p>\r\n      <p class=\"site_loginsubmit\">\r\n        <input type=\"button\" value=\"ログイン\" id=\"site_login_button\" />\r\n      </p>\r\n      <ul class=\"site_login_list\">\r\n        <li>・新規入会の会員さまには、入会受付から2週間程度で会員ＩＤ、パスワードをご案内します。</li>\r\n        <li>・「会員ログイン」して「有料サービス」をお申込みいただいた場合、「お申込み」だけで「課金」が発生することはありませんのでご安心ください。</li>\r\n      </ul>\r\n    </form>\r\n  </div>\r\n\r\n<script>\r\n\r\n/* ログイン */\r\n$(function() {\r\n    $(\"#site_login_button\").on(\"click\", function() {\r\n        $.ajax({\r\n            url: \"/php/loginform.php?dt=1740701978\",\r\n            type:'POST',\r\n            data:{\r\n                'memberid': $('input[name=\"memberid\"]').val(),\r\n                'passwd': $('input[name=\"passwd\"]').val(),\r\n                'logintokens': \"7670a42d439fb727b1b591e7306e1381\"\r\n            }/*,\r\n            dataType:'json'*/\r\n        }).done(function(data, textStatus, jqXHR) {\r\n            if (data != null && data != \"\") {\r\n                $(\"#account_lock_message\").hide();\r\n                $(\"#login_error_message\").hide();\r\n                // 認証失敗\r\n                if (data == \"failed\") {\r\n                    //alert(\"failed\");\r\n                    $(\"#login_error_message\").show();\r\n                } else if (data == \"locked\") {\r\n                    //alert(\"locked\");\r\n                    $(\"#account_lock_message\").show();\r\n                } else {\r\n                    location.href = data;\r\n                    setTimeout(function(){\r\n                         $('.site_login_wrap').css({display: 'none'});\r\n                    },2000);\r\n                }\r\n            }\r\n        }).fail(function(jqXHR, textStatus, errorThrown) {\r\n            //alert(\"fail\");\r\n        });\r\n    });\r\n});\r\n</script>\r\n<script>\r\n\tdocument.addEventListener('DOMContentLoaded', function() {\r\n\t\t// ラジオボタンの監視対象\r\n\t\tconst radioButtons = document.querySelectorAll('input[name=\"naiyou\"]');\r\n\t\t// 表示・非表示対象\r\n\t\tconst consultationDiv = document.querySelector('.consultation');\r\n\t\tconst inquiryDiv = document.querySelector('.inquiry');\r\n\t\t\r\n\t\t// 初期状態（value=9が初期チェックなら対応。なければ適宜調整）\r\n\t\tupdateDisplay();\r\n\t\t\r\n\t\t// ラジオボタン変更時のイベント\r\n\t\tradioButtons.forEach(radio => {\r\n\t\t\tradio.addEventListener('change', updateDisplay);\r\n\t\t});\r\n\t\t\r\n\t\tfunction updateDisplay() {\r\n\t\t\t// 選択中のラジオボタンを取得\r\n\t\t\tconst selectedRadio = document.querySelector('input[name=\"naiyou\"]:checked');\r\n\t\t\tif (selectedRadio && selectedRadio.value === '9') {\r\n\t\t\t\tconsultationDiv.style.display = '';\r\n\t\t\t\tinquiryDiv.style.display = 'none';\r\n\t\t\t} else {\r\n\t\t\t\tconsultationDiv.style.display = 'none';\r\n\t\t\t\tinquiryDiv.style.display = '';\r\n\t\t\t}\r\n\t\t}\r\n\t});\r\n</script>\r\n\r\n\r\n</body>\r\n</html>","finalUrl":"https://www.yokohama-ri.co.jp/html/inquiry/inquiry.html?nno=3","rendered":false,"_cachedAt":"2026-06-22T21:47:08.952Z"}