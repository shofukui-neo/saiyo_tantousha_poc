a></li>\r\n       <li><a href=\"../../../../../contact/index.html\">お問い合わせ</a></li>\r\n     </ul>\r\n \t  </div>\r\n  </nav>\r\n<!-- ----- nav End ----- -->\r\n\r\n\r\n \t\t</div>\r\n\t\r\n\t\t</header>\r\n \r\n<!-- ----- Header End ----- --><!-- ----- Header End ----- -->\r\n\t\t\r\n\r\n<!-- InstanceBeginEditable name=\"Main\" -->\r\n\t\t\r\n<!-- ----- Main ----- -->\r\n\t\t\r\n<div id=\"page\">\r\n\t\r\n  <!-- ----- page_recruit ----- -->\r\n  <div class=\"List_bg\">\r\n    <div class=\"List List__recruit\">\r\n      <p><a href=\"../index.html\">HOME</a>　/　<a href=\"index.html\">採用情報TOP</a>　/　新卒採用情報</p>\r\n    </div>\r\n  </div>\r\n  <div class=\"page_recruit_wrp pi_rec\">\r\n    <h2><span>まるなか建設株式会社</span><br>新卒採用情報</h2>\r\n    <div class=\"rec_stit\">New Graduate</div>\r\n  </div>\r\n  <!-- ----- page_recruit End ----- -->\r\n\t\r\n\t\r\n\t\r\n\t\r\n  <!-- ----- Content ----- -->\r\n  <!-- ----- 新卒 ----- -->\r\n\t<div class=\"np_wrp\">\r\n\t\t\r\n<!--新卒採用情報へ切り替え-->\r\n\r\n\r\n<!--上記で指定した記事の件数を取得-->\r\n\r\n\t                    \r\n\t<!--アイキャッチ画像からURL取得-->\r\n\t\t\t\r\n\t<!--0詰めの日付表示用-->\r\n            \r\n    <!--現在の記事のカテゴリー情報を取得-->\r\n        \r\n\t<p>　新規卒業予定者および既卒未就職者（卒業後3年以内）の新規採用に関する募集内容は以下の通りです。</p>\r\n\r\n\r\n<!-- 忘れずにリセットする必要がある -->\r\n   \t\t<div class=\"np_inner\">\r\n\r\n\t\t<h3>募集要項</h3>\r\n\t\t<!-- ----- 募集要項の呼び出し ----- -->\r\n\t\t\r\n<!--新卒採用情報へ切り替え-->\r\n\r\n\r\n<!--上記で指定した記事の件数を取得-->\r\n\r\n\t                    \r\n\t<!--アイキャッチ画像からURL取得-->\r\n\t\t\t\r\n\t<!--0詰めの日付表示用-->\r\n            \r\n    <!--現在の記事のカテゴリー情報を取得-->\r\n    \t\r\n\t<section>\r\n  \t\t<h4>募集職種</h4>\r\n\t    <ul>\r\n\t      <li>建築技術職（施工管理、設計）</li>\r\n          <li>土木技術職（施工管理、技能）</li>\r\n          <li>事務職（経理・総務 等）</li>\r\n          <li></li>\r\n          <li></li>\r\n          <li></li>\r\n\t    </ul>\r\n  \t</section>\r\n\r\n      <section>\r\n      \t\t<h4>募集予定人数</h4>\r\n        \t<ul><li>若干名</li></ul>      </section>\r\n\r\n      <section>\r\n      \t\t<h4>必要な資格</h4>\r\n\t\t\t<p>全職種（必須）　　　　　　　　　　　普通自動車運転免許（ＡＴ限定可）<br />全職種（あれば尚可）　　　　　　　　普通自動車運転免許（ＭＴ）<br />土木施工管理技術職（あれば尚可）　　準中型自動車運転免許</p>      </section>\r\n\r\n      <section>\r\n\t  \t\t<h4>勤務条件・処遇</h4>\r\n\t\t\t<section>\r\n\t      \t\t<h5>給与</h5>\r\n      \t\t\t<p>【大学卒 手当込み支給額（基本給）】<br />技術職：231,000～237,000円（196,000円）<br />技能職：198,000～204,000円（194,000円）<br />事務職・営業職：198,000円（194,000円）</p><p>【高専・短大・専修卒 手当込み支給額（基本給）】<br />技術職：220,000～226,000円（187,000円）<br />技能職：189,000～195,000円（185,000円）<br />事務職・営業職：189,000円（185,000円）</p><p>※技術職、技能職の採用条件（事務職・営業職を除く）<br />　・職種に関連のある学科学部卒または職種に関連のある資格を保有している場合は、技術職として採用。<br />　・上記に該当しない場合は、技能職として採用。<br />※諸手当について<br />　・全職種に精勤手当 4,000円を含む。<br />　・工事現場に従事する技術職及び技能職は、現場手当を支給（300円/日）<br />※固定残業代について（技術職のみ該当）<br />　・時間外労働の有無にかかわらず、固定残業代を支給。（20時間相当）<br />　・20時間を超える時間外労働が発生した場合は、超過分を追加で支給。<br />　・大学卒： 31,000円、高専・短大・専修卒：29,000円を支給。<br />　・技術職以外の職種は、固定残業代を支給せず、実際の時間外労働時間に応じて残業代を支給。<br /><br />【大学卒技術職 給与例】<br />基本給　　　196,000円<br />精勤手当　　   4,000円<br />固定残業代　 31,000円<br />現場手当　　　6,000円（1ヶ月換算：300円×20日）<br />合計　　　　237,000円</p>\t      </section>\r\n\r\n\t\t\t<section>\r\n\t      \t\t<h5>諸手当</h5>\r\n\t        <p>現場手当、所長手当、役職手当、職位手当、資格手当、精勤手当、特殊作業手当、家族手当、通勤手当、現場宿泊手当、単身赴任手当、現場移動手当、出張旅費手当、資格取得手当</p>\t      </section>\r\n\r\n\t\t<section>\r\n\t      \t\t<h5>昇給</h5>\r\n\t        <p>年１回（４月）</p>\t      </section>\r\n\r\n\t\t<section>\r\n\t      \t\t<h5>賞与</h5>\r\n\t        <p>年２回（６月､１２月）</p>\t      </section>\r\n\r\n\t\t<section>\r\n\t      \t\t<h5>勤務地</h5>\r\n\t        <p>松江市</p>\t      </section>\r\n\r\n\t\t<section>\r\n\t      \t\t<h5>勤務時間</h5>\r\n\t        <p>8時00分～17時00分<br />※休憩12時00～13時00分</p>\t      </section>\r\n\r\n\t\t<section>\r\n\t      \t\t<h5>休日・休暇</h5>\r\n\t        <p>土日（完全週休二日制）<br />盆､年末年始（年間休日：124日）<br />有給休暇<br />特別休暇（結婚休暇、服喪休暇、裁判員休暇、ボランティア休暇、業務上傷病・通勤傷病待機休暇、産前産後休暇、生理休暇、子の看護休暇、出産補助休暇、母性健康管理休暇、傷病休暇、育児休業、介護休業）</p>\t      </section>\r\n\r\n\t\t<section>\r\n\t      \t\t<h5>定年</h5>\r\n\t        <p>60歳（65歳まで継続雇用制度あり）</p>\t      </section>\r\n\r\n\t\t<section>\r\n\t      \t\t<h5>退職金</h5>\r\n\t        <p>建設業退職金共済､中小企業退職金共済､確定拠出年金</p>\t      </section>\r\n\r\n\t\t<section>\r\n\t      \t\t<h5>研修制度</h5>\r\n\t        <p>新入社員研修､部門別研修､メンタルヘルス研修、ハラスメント研修 等</p>\t      </section>\r\n\r\n\t\t<section>\r\n\t      \t\t<h5>福利厚生</h5>\r\n\t        <p>国内外研修旅行､インフルエンザ予防接種費用負担､福利厚生倶楽部利用サービス､ノー残業デー、クラブ活動（軟式野球部･剣道部）、特別支給（クリスマスケーキ代、正月お菓子代、お年始料、お花見料）</p>\t      </section>\r\n\r\n\t\t<section>\r\n\t      \t\t<h5>働き方改革</h5>\r\n\t        <p>ノー残業デー（毎週水曜日、給料日）<br />年休取得年間計画事前申請制度<br />入社時年休５日付与</p>\t      </section>\r\n\r\n\t\t<section>\r\n\t      \t\t<h5>借上げ社宅制度</h5>\r\n\t        <p>有　　※支給条件あり</p>\t      </section>\r\n  \t</section>\r\n\r\n\r\n<!-- 忘れずにリセットする必要がある -->\r\n          \t\t\r\n    \t</div>\r\n  \t</div>\r\n\t\r\n\t\r\n\t\r\n\t\t\r\n  <!-- ----- 就職説明会 ----- -->\r\n  <div class=\"np_wrp\">\r\n   \t<div class=\"np_inner\">\r\n\r\n\t\t\t\t\t<h3>合同就職説明会のご案内</h3>\r\n      <p>以下の合同就職説明会に参加します。<br>\r\n当社ブースにお気軽にお立ち寄りください。<br>\r\nお待ちしております！</p> \r\n\t\t\t\t\t\r\n\t\t<div class=\"np_jobfair\">\r\n\t\t\t\r\n<!--新卒採用情報へ切り替え-->\r\n\r\n\r\n<!--上記で指定した記事の件数を取得-->\r\n\r\n\r\n<!-- 忘れずにリセットする必要がある -->\r\n\t\t</div>\r\n    \r\n    </div>\r\n  </div>\r\n\t\r\n  <!-- ----- 採用情報登録関連 ----- -->\r\n\t<div class=\"np_wrp\">\r\n   \t\t<div class=\"np_inner\">\r\n\t\t\t<h3>採用情報登録関連</h3>\r\n\t\t\t<div class=\"np_banner\">\r\n\t\t\t\t\r\n\r\n\r\n\r\n\r\n\t                    \r\n\r\n\t\t\t\r\n\r\n            \r\n\r\n    \t\r\n\t<p><a href=\"https://www.gogo-jobcafe-shimane.jp/job/company/657153\" target=\"_blank\"><img src=\"https://www.maru-naka.co.jp/sinsotujm/wp-content/uploads/sites/13/2023/11/ba_jobcafe_s.png\" alt=\"\"/></a></p>\r\n\t<p><a href=\"https://job.rikunabi.com/2024/company/r767520033/employ/?isc=ps342\" target=\"_blank\"><img src=\"https://www.maru-naka.co.jp/sinsotujm/wp-content/uploads/sites/13/2023/11/w160_entry3-1.gif\" alt=\"\"/></a></p>\r\n\t\r\n\r\n\t\t\t</div>\r\n    \t</div>\r\n  </div>\r\n\r\n  <!-- ----- お問い合わせ ----- -->\r\n  <div class=\"np_wrp