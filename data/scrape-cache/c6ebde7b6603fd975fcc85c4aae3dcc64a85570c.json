">\n                <ul class=\"nav_btm_itm_inr\">\n                  <li class=\"nav_btm_itm_inrItm\">\n                    <span class=\"g_menu_ttl nav_ttl_people\">イオン薬剤師を知る</span>\n                  </li>\n                  <li class=\"nav_btm_itm_inrItm mt_25 u_fz16 u_medium\">\n                    <a href=\"/saiyo/pharmacist/interview_index/?category=%E6%96%B0%E5%8D%92%E5%85%A5%E7%A4%BE\" class=\"g_link_transp\">新卒社員 一覧 </a>\n                    <a href=\"/saiyo/pharmacist/interview_index/?category=%E3%82%AD%E3%83%A3%E3%83%AA%E3%82%A2%E5%85%A5%E7%A4%BE\" class=\"g_link_transp\">キャリア社員 一覧</a>\n                  </li>\n                </ul>\n              </li>\n              <li class=\"nav_btm_itm\">\n                <ul class=\"nav_btm_itm_inr\">\n                  <li class=\"nav_btm_itm_inrItm\">\n                    <span class=\"g_menu_ttl nav_ttl_workplace\">イオン薬剤師を支える環境</span>\n                  </li>\n                  <li class=\"nav_btm_itm_inrItm mt_25 u_fz16 u_medium\">\n                    <a href=\"/saiyo/pharmacist/training/\" class=\"g_link_transp\">研修・スキルアップ支援</a>\n                    <a href=\"/saiyo/pharmacist/wellness/\" class=\"g_link_transp\">ライフスタイル支援</a>\n                  </li>\n                </ul>\n              </li>\n              <li class=\"g_pagetop u_pc\">\n                <a href=\"#top\">TOP</a>\n              </li>\n            </ul>\n          </div>\n        </div>\n      </div>\n      <div class=\"nav_copyright\">\n        <p class=\"copyright_txt l_flex l_justifyContentCenter l_alignItemsCenter g_c_wh u_bold u_fz12\">Copyright© AEON RETAIL Co.,LTD</p>\n      </div>\n    </footer>\n    <!-- /footer -->\n\n    <!-- GDPR -->\n    <!-- <div class=\"g_gdpr l_wrap\">\n<div class=\"g_gdpr_wrp l_wrap_inr\">\n\t<p class=\"g_gdpr_txt g_txt\">本サイトはユーザーエクスペリエンスの向上などを目的に、Cookieを使用しています。<br>右記のバナーで「同意する」をクリックする、または本サイトを利用することにより、<br>お客様は弊社の<a href=\"#\">Cookieポリシー</a>に同意したことになります。</p>\n\t\t<div class=\"g_gdpr_btn\">同意します</div>\n</div>\n</div> -->\n    <!-- /GDPR -->\n\n    <!-- Load JavaScript -->\n    <script src=\"/saiyo/pharmacist/js/ua.js\"></script>\n    <script src=\"/saiyo/pharmacist/js/jquery.cookie.js\"></script>\n    <script src=\"/saiyo/pharmacist/js/plugin/jquery.matchHeight.js\"></script>\n    <script src=\"/saiyo/pharmacist/js/plugin/slick.min.js\"></script>\n    <script src=\"/saiyo/pharmacist/js/common.js\"></script>\n    <!-- /Load JavaScript -->\n  </body>\n</html>\n","finalUrl":"https://www.aeonretail.jp/saiyo/pharmacist/introduction/","rendered":false,"_cachedAt":"2026-06-22T21:06:55.301Z"}