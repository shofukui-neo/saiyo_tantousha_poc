down-menu-item\"><div class=\" rdappended\"><p><a href=\"//veilherz-mirai.jp/kaigo/school\">リハ＆りふれっしゅみらいスクール</a></p></div></div></div></li>\n<li class=\" h_nav__item h-nav__item--0 drawer-dropdown\"><div class=\" h-nav__link drawer-menu-item\"><div class=\" rdappended\"><p><a href=\"//veilherz-mirai.jp/requirements\">求人募集</a></p></div></div>\n<div class=\" drawer-dropdown-menu\"><div class=\" drawer-dropdown-menu-item\"><div class=\" rdappended\"><p><a href=\"//veilherz-mirai.jp/shinsotsu\">新卒採用</a></p></div></div>\n<div class=\" drawer-dropdown-menu-item\"><div class=\" rdappended\"><p><a href=\"//veilherz-mirai.jp/chuto\">中途採用</a></p></div></div>\n<div class=\" drawer-dropdown-menu-item\"><div class=\" rdappended\"><p><a href=\"//veilherz-mirai.jp/requirements\">求人一覧</a></p></div></div>\n<div class=\" drawer-dropdown-menu-item\"><div class=\" rdappended\"><p><a href=\"//veilherz-mirai.jp/entry\">応募フォーム</a></p></div></div></div></li>\n<li class=\" h_nav__item h-nav__item--0 drawer-dropdown\"><div class=\" h-nav__link drawer-menu-item\"><div class=\" rdappended\"><p><a href=\"//veilherz-mirai.jp/college\">福祉カレッジ</a></p></div></div>\n<div class=\" drawer-dropdown-menu\"><div class=\" drawer-dropdown-menu-item\"><div class=\" rdappended\"><p><a href=\"//veilherz-mirai.jp/college/shoninsha\">初任者研修</a></p></div></div>\n<div class=\" drawer-dropdown-menu-item\"><div class=\" rdappended\"><p><a href=\"//veilherz-mirai.jp/college/jitsumusha\">実務者研修</a></p></div></div>\n<div class=\" drawer-dropdown-menu-item\"><div class=\" rdappended\"><p><a href=\"//veilherz-mirai.jp/college/request\">資料請求・受講申込</a></p></div></div></div></li>\n<li class=\" h_nav__item h_subnav\"><div class=\" contact_nav\"><div class=\" tel\"><div class=\" rdappended\"><a href=\"tel:0120-318-826\">0120-318-826</a></div></div>\n<div class=\" txt\"><div class=\" rdappended\"><p>受付｜9時～18時　定休｜日</p></div></div></div>\n<div class=\" h_subnav__li\"><div class=\" rdappended\"><p><a href=\"//veilherz-mirai.jp/contact\">お問い合わせ</a></p></div></div></li>\r\n</ul>\r\n</nav>\r\n</div>\r\n</header>\r\n\r\n<main class=\"l_main page_main forfixed\">\r\n\r\n<div id=\"section_pageHeader\" class=\"pages\" data-aos=\"fade\" data-aos-duration=\"800\">\r\n\t<div class=\" titlearea\"><div class=\" u75833000e29344cfb5bd0e898ec5ccc0 title_main jp\"><div class=\" rdappended\"><p>新卒採用</p></div></div>\n<div class=\" u83249ef924884244ac9c70ae74fb090d rdBreadcrumb rdblock\"><div><script type=\"application/ld+json\">\r\n    {\r\n      \"@context\": \"https://schema.org\",\r\n      \"@type\": \"BreadcrumbList\",\r\n      \"itemListElement\": [\r\n         {\r\n          \"@type\": \"ListItem\",\r\n          \"position\": 1,\r\n          \"name\": \"トップページ\",\r\n          \"item\": \"https://veilherz-mirai.jp/\"\r\n        }\r\n        ,          {\r\n          \"@type\": \"ListItem\",\r\n          \"position\": 2,\r\n          \"name\": \"新卒採用\",\r\n          \"item\": \"https://veilherz-mirai.jp/shinsotsu\"\r\n        }\r\n                      ]\r\n    }\r\n  </script>\r\n\r\n\r\n  <ul class=\"rdBreadcrumbList\" itemscope itemtype=\"https://schema.org/BreadcrumbList\">\r\n            <li class=\"rdBreadcrumbItem rdBreadcrumbItemFirst\" itemprop=\"itemListElement\" itemscope\r\n      itemtype=\"https://schema.org/ListItem\">\r\n      <a class=\"rdBreadcrumbLink\" itemprop=\"item\" href=\"https://veilherz-mirai.jp/\"><span class=\"rdBreadcrumbName\"\r\n          itemprop=\"name\">トップページ</span></a>\r\n      <meta itemprop=\"position\" content=\"1\" />\r\n      <span class=\"rdBreadcrumbArrow\">\r\n        &gt;\r\n      </span>\r\n    </li>\r\n                <li class=\"rdBreadcrumbItem rdBreadcrumbItemCurrent\" itemprop=\"itemListElement\" itemscope\r\n      itemtype=\"https://schema.org/ListItem\">\r\n      <span class=\"rdBreadcrumbName\" itemprop=\"name\">新卒採用</span>\r\n      <meta itemprop=\"position\" content=\"2\" />\r\n    </li>\r\n          </ul>\r\n\r\n</div></div></div>\n<div class=\" title-navi_ul\"><div class=\"  navi_li\"><div class=\" rdappended\"><p><a href=\"//veilherz-mirai.jp/recruit\">採用TOP</a></p></div></div>\n<div class=\"  navi_li\"><div class=\" rdappended\"><p><a href=\"//veilherz-mirai.jp/shinsotsu\">新卒採用</a></p></div></div>\n<div class=\"  navi_li\"><div class=\" rdappended\"><p><a href=\"//veilherz-mirai.jp/chuto\">中途採用</a></p></div></div>\n<div class=\"  navi_li\"><div class=\" rdappended\"><p><a href=\"//veilherz-mirai.jp/requirements\">募集要項</a></p></div></div>\n<div class=\"  navi_li\"><div class=\" rdappended\"><p><a href=\"//veilherz-mirai.jp/entry\">エントリーフォーム</a></p></div></div></div>\n<div class=\" rdflexareaChild rdblock\"><div class=\" udjepe25038zfatrm2jgv2j7mpib9r0af ub-to_bt link_btn\"><div><p><a href=\"//veilherz-mirai.jp/chuto\">中途採用はこちら</a></p></div></div></div>\r\n</div>\r\n\r\n<div id=\"contents\" data-prc=\"\">\r\n\t<div class=\" uggf5ueqkpkkp6bq6ar21ntkuhtn24sus rdflexarea rdblock\"><div class=\" udvjlqphqmvhh23ljwgbcnuqnz3ndi567 rdflexareaChild rdblock\"><div class=\" u8nekh0rqszi8el9gf7jhw38dk4zmn3cn rdplanetext rdblock\"><div><p>ベールヘルツでは、社内研修制度を設け、新入社員には先輩社員からの直接指導のほか、リフレクション(振り返り)の時間を取って、「一人前」になるためのサポートを行っています。</p></div></div></div>\n<div class=\" ucvmpj7zb0nz24am0ycmm0dyespfrtmz4 rdflexareaChild rdblock\"></div></div>\n<div class=\" u2elrjvozomkk6pqwqt00cl28bqeizy2i rdplanetitle rdblock\"><h3>サポート体制</h3></div>\n<div class=\" uvrao8a08d6s8w1nn50g0jc7yyn9fd8nl rdflexarea rdblock\"><div class=\" uexm1pn54c4i0xsw36fzy3edvqq0clwgx rdflexareaChild rdblock\"><div class=\" uaq3z0ndcsx49l158z36q3ck3118hpkdg rdplaneimage rdblock\"><span><img src=\"//veilherz-mirai.jp/data/202401/img659dfcdef16c3.jpg\" alt=\"月例研修\" /></span></div></div>\n<div class=\" ubrbbyrhrl1uh2fnma1nnlpwwmzhswgxx rdflexareaChild rdblock\"><div class=\" u10ceexigdm7nut4k5rxw9kypfp8hcky8 rdplanetitle rdblock\"><h5>月例研修会</h5></div>\n<div class=\" u0ja5n0qxnpmmtczyh7xs3r68hvwyuxvk rdplanetext rdblock\"><div><p>毎月部署ごとの職員が集まる学びの場です。毎回のテーマに応じた講義を行い、知識を向上させ、専門職としての質を高める機会にしています。後半では、座学だけでなく、グループワークと技術演習を行い、知識と技術の向上を目指す研修となっています。</p></div></div></div></div>\n<div class=\" unm005heeoytg15uv6i0iuxueu4p37kt1 rdflexarea rdblock\"><div class=\" uufob868jd29yj6gc3j8gnr748agmlox7 rdflexareaChild rdblock\"><div class=\" u8fi9a2m000q53k12uy29e5ggf8m8yhwx rdplaneimage rdblock\"><span><img src=\"//veilherz-mirai.jp/data/202312/img658a7dcb37573.jpg\" /></span></div></div>\n<div class=\" uvd3fp6tyrzfxpotz32cfw288hk1clu0d rdflexareaChild rdblock\"><div class=\" uqldsy197igihb7srjgk0i66qtb67u8qf rdplanetitle rdblock\"><h5>新人研修</h5></div>\n<div class=\" ud4zbjczeckonpsnjonefgidtptnikvcw rdplanetext rdblock\"><div><p>月に一度入社１年目の職員が集まり、社会人としての一般教養や、認知症・障がいについての基礎知識などを学んでいきます。電話対応・緊急時対応など、実践も取り入れつつ一から講義を行います。介護・福祉の業界で、社会で、働いていく土台作りをします。</p></div></div></div></div>\n<div class=\" uy0iia0nklgvbxn9ad02cri2b5b8wja4d rdflexarea rdblock\"><div class=\" usnqor7i0nw9biv5xf9ztuoewo5ug3j0w rdflexareaChild rdblock\"></div>\n<div class=\" ukf0gzxb9utapq1nlsh0jgqtb5i2lrck3 rdflexareaChild rdblock\"><div class=\" uaed57o7tua3qbqfu4hhj8lu7x1nxzfvz rdplanetitle rdblock\"><h5>メンター制度</h5></div>\n<div class=\" upz3mytcsxfzgxwr5gql4ughk7c2jzr60 rdplanetext rdblock\"><div><p>直属の上司以外が担当になり、定期的に面談を実施しています。利害関係にない立場で相談に乗り、課題解決に向けたサポートをします。</p></div></div></div></div>\n<div class=\" uoi62vaerz98b2kpahmb5vnd9okllkl9z rdplanetitle rdblock\"><h3>講習風景</h3></div>\n<div class=\" udw5mx0hssb5uc4cf29z99fdj1mdm1qst rdhorizontalarea rdblock\"><div class=\" u0x6q1x123z9881c4l38sw5ojsg004vrf rdflexareaChild rdblock\"><div data-direction=\"normal\" data-type=\"1\" data-gap=\"0\" data-speed=\"0.5\" data-interval=\"4\" data-easing=\"cubic-bezier(0.250, 0.100, 0.250, 1.000)\" data-width=\"100\" data-wunit=\"%\" data-height=\"\" data-hunit=\"\" data-variableheight=\"1\" class=\" rdblock rdslide\"><div class=\" rdslideInner\"><div>        <div class=rdslideItem ><img src=\"//veilherz-mirai.jp/data/202411/img674820bd0c667.png\" class=\"rdimg\" /></div>\n        <div class=rdslideItem ><img src=\"//veilherz-mirai.jp/data/202411/img672dc829cac4d.jpg\" class=\"rdimg\" /></div>\n        <div class=rdslideItem ><img src=\"//veilherz-mirai.jp/data/202411/img672dc82542044.jpg\" class=\"rdimg\" /></div>\n        <div class=rdslideItem ><img src=\"//veilherz-mirai.jp/data/202411/img672dc8202a80f.jpg\" class=\"rdimg\" /></div>\n        <div class=rdslideItem ><img src=\"//veilherz-mirai.jp/data/202411/img672dc7fe9488c.jpg\" class=\"rdimg\" /></div>\n        <div class=rdslideItem ><img src=\"//veilherz-mirai.jp/data/202411/img672dc7f784958.jpg\" class=\"rdimg\" /></div>\n        <div class=rdslideItem ><img src=\"//veilherz-mirai.jp/data/202411/img672dc7f2b7062.jpg\" class=\"rdimg\" /></div>\n        <div class=rdslideItem ><img src=\"//veilherz-mirai.jp/data/202411/img672dc7eda1c7e.jpg\" class=\"rdimg\" /></div>\n        <div class=rdslideItem ><img src=\"//veilherz-mirai.jp/data/202411/img672dc7e7e7748.jpg\" class=\"rdimg\" /></div>\n        <div class=rdslideItem ><img src=\"//veilherz-mirai.jp/data/202411/img672dc7e2b6a3a.jpg\" class=\"rdimg\" /></div>\n        <div class=rdslideItem ><img src=\"//veilherz-mirai.jp/data/202411/img672dc7de82ce7.jpg\" class=\"rdimg\" /></div>\n        <div class=rdslideItem ><img src=\"//veilherz-mirai.jp/data/202411/img672dc7b874ccf.jpg\" class=\"rdimg\" /></div>\n        <div class=rdslideItem ><img src=\"//veilherz-mirai.jp/data/202411/img672dc7b41ae35.jpg\" class=\"rdimg\" /></div>\n</div></div></div>\n<div class=\" uvlbcy04m7y0fz3v4jmh2fy2yfb166xjh rdplanetext2 rdblock\"><dl class=\" rdplanetext2_inner\"><dt></dt><dd><p>2024.11/4(木)<br>入社1年目から2年目に向けて職員を集めて介護技術研修を行いました。<br>1.まずはとにかくやってみる<br>2.正しい方法を学ぶ<br>3.再度実践<br>4.講師実演（間違いが5か所あるので探す）<br>この4ステップで行っています。<br>2時間という短い時間でしたがとても濃く、良い研修となりました！！</p></dd></dl></div></div>\n<div class=\" uesb3sfrfqw3clp8b4llld6v8yaxajxz3 rdflexareaChild rdblock\"></div>\n<div class=\" upqno47v2227dqrda0g34hiw0mjbayk85 rdflexareaChild rdblock\"></div></div>\n<div class=\" uh8nck55wfx3hi20tsnw48w9qyu5j7iea rdplanetitle rdblock\"><h3>資格取得支援</h3></div>\n<div class=\" u2u2dqwywko5sql2xpkt73xywni6pex1p rdplanetext rdblock\"><div><p>未経験で入社し、働きながら資格を取得した職員が多数在籍しています。<br>弊社では介護・福祉の学校「みらい福祉カレッジ」を併設しており、働きながらの資格取得を応援します。</p></div></div>\n<div class=\" uq2xehhgyx7ac6m3r8tezp6zpb5u0pimc rdhorizontalarea rdblock\"><div class=\" u8uk5dme1k87pljqu0xy3rdobm50x077d rdflexareaChild rdblock\"><div class=\" uemvbjlkgn38fa78xjk3379m1gd9bp6st rdplaneimage rdblock\"><span><img src=\"//veilherz-mirai.jp/data/202312/img658a4e428bb33.jpg\" /></span></div>\n<div class=\" uuddyjm5r4q3z1pu3xf87yxyhipbtvf1g rdplanetext rdblock\"><div><p style=\"text-align:center;\">通信課題で無理なく受講</p></div></div></div>\n<div class=\" u877gg7vg1bfz9aucx62mbni17rwc95m8 rdflexareaChild rdblock\"><div class=\" ubk1exz9ikdoo9e5r0yir6nnmxm5fl7nl rdplaneimage rdblock\"><span><img src=\"//veilherz-mirai.jp/data/202312/img658a8060ac0ee.jpg\" /></span></div>\n<div class=\" ut33vu3elrphhuz32a5imwrjkajjjgtio rdplanetext rdblock\"><div><p style=\"text-align:center;\">職員優待制度あり</p></div></div></div>\n<div class=\" u20ah18sfmb79kyzr2phmtlloubaairkq rdflexareaChild rdblock\"><div class=\" umqkrt2piis2cnkjmm71ncr4gno79ij08 rdplaneimage rdblock\"><span><img src=\"//veilherz-mirai.jp/data/202312/img658a80739f5cb.jpg\" /></span></div>\n<div class=\" udv3blu5s498oslokbkjjnh6b5yjy1onh rdplanetext rdblock\"><div><p style=\"text-align:center;\">通学日程も勤務日と調整しやすい</p></div></div></div></div>\n<div class=\" u0tm6gc47iqqz9yvkrsndkw6nqmq43snb rdplanetext rdblock\"><div><p>福祉カレッジにて開講以外の資格も取得支援制度があります。</p></div></div>\n<div class=\" umwnpeuz7o5f2uty7r3qh2ifih6wh0u4a rdplanetitle rdblock\"><h4>取得できる資格</h4></div>\n<div class=\" uvit1akwa3qwx0ae4gbuczmai93sfxcr3 rdplaneimage rdblock\"><span><img src=\"//veilherz-mirai.jp/data/202312/img658a82ff0b16b.jpg\" /></span></div>\n<div class=\" ue250hf6lig1hbqsvnqffppyn4antzkkd rdplanetitle rdblock\"><h3>先輩社員よりメッセージ</h3></div>\n<div class=\" u354iopq52z1icycownys7to9o7z02orm rdhorizontalarea rdblock\"><div class=\" uobwsocozrl2jkkgjxirg8ihzbnzdh9v3 rdflexareaChild rdblock\"><div class=\" u6za5ucjj6l34oik69qtt1gbx4vzxariz rdplanetext rdblock\"><div><p><span class=\"text-fontsize5\" style=\"color:rgba(3,110,184,1);font-size:1.5rem;\"><strong>イニシャル（歳）</strong></span><span style=\"color:rgba(3,110,184,1);\"><br>事業所 / 勤務形態 / 勤続年数<br>取得した資格</span></p></div></div></div></div>\n<div class=\" uvruhoj45f9yq0l6i0e1hg080oyrq0jnd rdhorizontalarea rdblock\"><div class=\" u57prxyeubenhwtrmtagngry34ndvyvav rdflexareaChild rdblock\"><h4 class=\" u0ctc4v1d94hhzzmx2gw9d8kxt3a52h64 openbox\"><div class=\" rdappended\"><span class=\"text-fontsize5\" style=\"color:rgba(3,110,184,1);font-size:1.5rem;\"><strong>E.Mさん（20）&nbsp;</strong></span><span style=\"color:rgba(3,110,184,1);\"><br>放課後等デイサービス / 常勤 / 1 年 9 ヶ月</span><br><span style=\"color:rgba(3,110,184,1);\">初任者研修修了</span></div></h4>\n<div class=\" rdflexareaChild rdblock\"><div class=\" u7yknn66pzmx6j6ond9smnhz3l106u07r rdplanetitle rdblock\"><h5>入社を決めた理由</h5></div>\n<div class=\" uubvdu168y5fpytqw0en54iz84jmvisd3 rdplanetext rdblock\"><div><p>働きながら資格がとれて、実務経験が積めること。</p></div></div>\n<div class=\" ukpydplrj8mu3ogdgh9os49cfo4e9669o rdplanetitle rdblock\"><h5>働いていて嬉しかったこと</h5></div>\n<div class=\" udfx10lm07k8f8k3v8mbqz8uq9t01lbq6 rdplanetext rdblock\"><div><p>利用者さんに名前を覚えてもらえて、お話をしたりいっしょにあそんだこと。</p></div></div>\n<div class=\" ugp8z9jaajixsgvc9n3sri2ks03xxavnf rdplanetitle rdblock\"><h5>これからの目標</h5></div>\n<div class=\" ukfk7j3q9cfd4ppf9y6yyxbewlnod7ntz rdplanetext rdblock\"><div><p>資格をとって仕事に活かしたい。</p></div></div>\n<div class=\" u187kw25xthprmyf0e3d79tws9je8tzad rdplanetitle rdblock\"><h5>後輩に伝えたいこと</h5></div>\n<div class=\" usetqqyuqjbe6fuf43lo53bwcpiwzsor4 rdplanetext rdblock\"><div><p>様々な事業所があり、それぞれ雰囲気も違うので、たくさん勉強になることがあります。</p></div></div>\n<div class=\" u3yelzz779lu7hz2tdchuywkc2ntuivsv rdplanetitle rdblock\"><h5>プライベートでの過ごし方</h5></div>\n<div class=\" uug500ay7oi87jsjcdc1kkaa8rq8ykvr9 rdplanetext rdblock\"><div><p>遊びにいく、資格の勉強</p></div></div>\n<div class=\" uc9vm92jk7co6ij08mc3ah34uqzsx7rtt rdplanetitle rdblock\"><h5>仕事で楽しかったこと</h5></div>\n<div class=\" ug9bxlag9058533qr8dbf8j174y372x0z rdplanetext rdblock\"><div><p>利用者さんと一緒に遠出をしたり、バーベキューなどの行事をしたこと。</p></div></div></div></div>\n<div class=\" u1djiwqwiy9davr0dh2n0plcfyawa4k5j rdflexareaChild rdblock\"><h4 class=\" udnwwd66k72ygpwy27nbddfovtp9z9mex openbox\"><div class=\" rdappended\"><span class=\"text-fontsize5\" style=\"color:rgba(3,110,184,1);font-size:1.5rem;\"><strong>N.Mさん（30）&nbsp;</strong></span><span style=\"color:rgba(3,110,184,1);\"><br>通所介護 / 常勤 / 5 年 9 ヶ月</span><br><span style=\"color:rgba(3,110,184,1);\">介護福祉士・保育士・キャリアコンサルタント</span></div></h4>\n<div class=\" rdflexareaChild rdblock\"><div class=\" usvo9ow4dvi1ff1xm6w13yapk7ntag5kr rdplanetitle rdblock\"><h5>入社を決めた理由</h5></div>\n<div class=\" ue2ntp67c79ay12rqon97ja5kgif6ch0x rdplanetext rdblock\"><div><p>就活中は自分が社会でやっていけるのか自信が無く、これと言ってやりたいこともありませんでした。だからどうせなら日本の社会問題に関わるような世の中に無くてはならない仕事で、人手不足の業界なら、まずはその中で働いているというだけで自分の存在意義を感じられると思いました。&nbsp;<br><br>その上で、人と自然なコミュニケーションが取れるようになりたかったので人と関わる仕事がしたいと思った時に、介護の仕事に興味を持ちました。柔らかい雰囲気が向いていると周りからも言われ、説明会を受けた際に、日本を憂えて熱く語る代表の姿と、素の自分を認めてくれる家族のように温かい社風に惹かれて、直感で「ここだ！」と思い志望しました。そして実際にアルバイトをしてみて、自分が感じたことは間違いないと思い、入社を決めました。</p></div></div>\n<div class=\" uqrfdjr7dm9znl8g50qg8tijgnvq6m4xy rdplanetitle rdblock\"><h5>働いていて嬉しかったこと・大変なこと</h5></div>\n<div class=\" u2j089t3dkktff6feyi3mm19nndzw6xvl rdplanetext rdblock\"><div><p>嬉しいのは、高齢者の利用者さんが事あるごとに褒めてくださったり、喜んでくださったり、感謝してくださることです。&nbsp;<br>お風呂での洗い方や一人一人に合わせた細かな温度調整、歌や体操、笑い方や仕草、スタイルまで、色々な面で気に入ってファンだと言ってくださる方もいて、いつも会うのを楽しみにしてくださるのがとても嬉しいです。利用者さんたちに支えられて、恵まれているなと感じます。<br><br>&nbsp;大変なのは、朝のお迎えの際やお風呂誘導の際、スムーズにいかない場合があることてす。声かけの仕方やタイミングを工夫したり、他の職員さんと協力したりして、何とか気持ちよく動いて頂くよう工夫するのが大変ですが、上手くいった時は達成感がありほっとします。</p></div></div>\n<div class=\" udkllvxbah03xpf5bgd7njm0ouzd5ljuf rdplanetitle rdblock\"><h5>これからの目標</h5></div>\n<div class=\" uzhmjx32yjl79cv9a5w0rttxccicpdf1g rdplanetext rdblock\"><div><p>求められることのレベルがいよいよ上がってきたので、上司にしっかりついていきサポートしながら、後輩や他の職員さんたちとうまく連携して、未来サポーターズ倶楽部を守り発展させていけるように頑張りたいです。</p></div></div>\n<div class=\" um3g1u89yw69fx9fnrghmnvqaoisrr9ed rdplanetitle rdblock\"><h5>後輩に伝えたいこと</h5></div>\n<div class=\" ujpkuwjsrtwlg458t66v7j1gjt0k45z7o rdplanetext rdblock\"><div><p>介護の仕事はきついイメージがあるかもしれませんが、働いてみるとそんなこともなく人間味に溢れていて楽しく、周りの職員さんも心優しい方ばかりで、有り難い仕事だなと感じます。少しでも興味を持ってもらえたら、そして良ければ是非体験してみて、介護の仕事の良さを実感してもらえたら嬉しいです！</p></div></div>\n<div class=\" uaa670jpjpd1h240olfje7fvc8a2uv725 rdplanetitle rdblock\"><h5>プライベートでの過ごし方</h5></div>\n<div class=\" udjpki4h9l1jwpsohqm8d611ujz1hj0c8 rdplanetext rdblock\"><div><p>歌が好きなので、利用者さんが好きな昭和歌謡や演歌を練習したり、大学時代から付き合いのある同世代や先輩後輩とスポーツを始めとして色々な交流をしたり、韓国ドラマを観たり資格の勉強をしたり、将来に向けてパートナーとの時間を過ごしたりしてとても充実できています。</p></div></div>\n<div class=\" ug7p6soce0szt7ekf5zqoqgggzz36oog5 rdplanetitle rdblock\"><h5>仕事で楽しかったこと</h5></div>\n<div class=\" udkdx4a1zwjoou22d8bxm3ad4e8iog333 rdplanetext rdblock\"><div><p>お茶目だったり面白い利用者さんが多く、その方たちに合わせてわざとふざけるようなことをしてみたり冗談を言ったりして、日々一緒に楽しんでいます。&nbsp;<br>また、歌好きの職員さんが増えてきて、利用者さんを交えながら時々カラオケ大会をやり、喜んで頂いているのが楽しみの一つになっています。</p></div></div></div></div></div>\n<div class=\" uviv9vq59r3uj7x7vs9225kxx1bye2bfa ub-to_bt link_btn\"><div><p><a href=\"//veilherz-mirai.jp/requirements\">募集要項一覧</a></p></div></div>\n<div class=\" uttut0u4bc1u9owxt69tqcl5jji6dvshl ub-to_bt link_btn\"><div><p><a href=\"//veilherz-mirai.jp/entry\">エントリーフォーム</a></p></div></div>\r\n</div>\r\n</main>\r\n\r\n\r\n<footer id=\"l_footer\" class=\"flex_inner\">\r\n\t<div class=\" flex_left\"><div class=\" logo\"><div class=\" rdappended\"><img src=\"//veilherz-mirai.jp/data/202312/img656afa27d5d24.png\" alt=\"株式会社ベールヘルツ\" width=\"284\" height=\"38\" /></div></div>\n<div class=\" address\"><div class=\" rdappended\"><p>〒270-2241<br>千葉県松戸市松戸新田30番地　</p></div></div>\n<div class=\" link_efect\"><div class=\" rdappended\"><p><a href=\"//veilherz-mirai.jp/contact\">お問い合わせ</a></p></div></div>\n<div class=\" copy\"><div class=\" rdappended\">Copyright© <a href=\"//veilherz-mirai.jp/toppage\">Veilherz Co., Ltd.</a> All rights reserved.</div></div></div>\n<div class=\" flex_right fnav\"><div class=\" fnav_dl\"><div class=\" fnav_dt\"><div class=\" rdappended\"><p><a href=\"//veilherz-mirai.jp/\">TOP</a></p></div></div>\n<div class=\" fnav_dt\"><div class=\" rdappended\"><p><a href=\"//veilherz-mirai.jp/news\">お知らせ</a></p></div></div>\n<div class=\" fnav_dt\"><div class=\" rdappended\"><p><a href=\"/company\">会社案内</a></p></div></div></div>\n<div class=\" fnav_dl\"><div class=\" fnav_dt\"><div class=\" rdappended\"><p><a href=\"//veilherz-mirai.jp/takino\">多機能型事業所</a></p></div></div>\n<div class=\" fnav_dd\"><div class=\" rdappended\"><p><a href=\"//veilherz-mirai.jp/takino/miraichan\">みらいちゃん</a></p></div></div>\n<div class=\" fnav_dd\"><div class=\" rdappended\"><p><a href=\"//veilherz-mirai.jp/takino/nogikuno\">みらいちゃん野菊野トライ</a></p></div></div>\n<div class=\" fnav_dd\"><div class=\" rdappended\"><p><a href=\"//veilherz-mirai.jp/takino/lifework-mirai\">ライフワークみらい</a></p></div></div>\n<div class=\" fnav_dd\"><div class=\" rdappended\"><p><a href=\"//veilherz-mirai.jp/takino/lifework-next\">ライフワークみらいネクスト</a></p></div></div></div>\n<div class=\" fnav_dl\"><div class=\" fnav_dt\"><div class=\" rdappended\"><p><a href=\"//veilherz-mirai.jp/kaigo\">在宅介護サービス</a></p></div></div>\n<div class=\" fnav_dd\"><div class=\" rdappended\"><p><a href=\"//veilherz-mirai.jp/kaigo/caremanager\">居宅支援センターみらい</a></p></div></div>\n<div class=\" fnav_dd\"><div class=\" rdappended\"><p><a href=\"//veilherz-mirai.jp/kaigo/homehelp\">ホームヘルプサービスみらい</a></p></div></div>\n<div class=\" fnav_dd\"><div class=\" rdappended\"><p><a href=\"//veilherz-mirai.jp/kaigo/dayservice\">未来サポーターズ俱楽部</a></p></div></div>\n<div class=\" fnav_dd\"><div class=\" rdappended\"><p><a href=\"//veilherz-mirai.jp/kaigo/school\">リハ&amp;りふれっしゅみらいスクール</a></p></div></div></div>\n<div class=\" fnav_dl\"><div class=\" fnav_dt\"><div class=\" rdappended\"><p><a href=\"//veilherz-mirai.jp/recruit\">求人募集</a></p></div></div>\n<div class=\" fnav_dd\"><div class=\" rdappended\"><p><a href=\"//veilherz-mirai.jp/shinsotsu\">新卒採用</a></p></div></div>\n<div class=\" fnav_dd\"><div class=\" rdappended\"><p><a href=\"//veilherz-mirai.jp/chuto\">中途採用</a></p></div></div>\n<div class=\" fnav_dd\"><div class=\" rdappended\"><p><a href=\"//veilherz-mirai.jp/requirements\">募集要項</a></p></div></div>\n<div class=\" fnav_dd\"><div class=\" rdappended\"><p><a href=\"//veilherz-mirai.jp/entry\">エントリーフォーム</a></p></div></div></div>\n<div class=\" fnav_dl\"><div class=\" fnav_dt\"><div class=\" rdappended\"><p><a href=\"//veilherz-mirai.jp/college\">福祉カレッジ</a></p></div></div>\n<div class=\" fnav_dd\"><div class=\" rdappended\"><p><a href=\"//veilherz-mirai.jp/college/shoninsha\">初任者研修</a></p></div></div>\n<div class=\" fnav_dd\"><div class=\" rdappended\"><p><a href=\"//veilherz-mirai.jp/college/jitsumusha\">実務者研修</a></p></div></div>\n<div class=\" fnav_dd\"><div class=\" rdappended\"><p><a href=\"//veilherz-mirai.jp/college/request\">資料請求・受講申込</a></p></div></div></div></div>\r\n</footer>\r\n<div id=\"pagetop-side\"><a href=\"#\"></a></div>\r\n\r\n\r\n\r\n  \r\n\r\n\r\n\r\n\r\n\r\n\r\n  \r\n<!--Navigation fix-->\r\n<!--[if lt IE 9]> \r\n<script type=\"text/javascript\" src=\"../common/js/html5shiv.js\"></script>\r\n<script src=\"https://css3-mediaqueries-js.googlecode.com/svn/trunk/css3-mediaqueries.js\"></script>\r\n<![endif]-->\r\n    \r\n\r\n\r\n\r\n\r\n\r\n<script src=\"/data/common/c1001a045901/js/iscroll.js\"></script>\r\n<script src=\"/data/common/c1001a045901/js/drawer.min.js\"></script>\r\n<script src=\"/data/common/c1001a045901/js/swiper.js\"></script>\r\n<script src=\"/data/common/c1001a045901/js/jquery.inview.min.js\"></script>\r\n<script src=\"/data/common/c1001a045901/js/modernizr.js\"></script>\r\n<script src=\"/data/common/c1001a045901/js/TweenMax.min.js\"></script>\r\n<script src=\"/data/common/c1001a045901/js/ScrollToPlugin.min.js\"></script>\r\n<script src=\"/data/common/