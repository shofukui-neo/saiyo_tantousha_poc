{"url":"https://www.kinon.co.jp/recruit/job-01.shtml","html":"<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\">\n<meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width\" />\n<meta name=\"format-detection\" content=\"telephone=no\">\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/common.css\" />\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/zone.css\" />\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/bpts.css\" />\n<!-- Basic parts -->\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/unit.css\" />\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/col.css\" />\n<!-- 本文領域レイアウタ -->\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/other.css\" />\n<!-- 職種紹介用CSS -->\n<link rel=\"stylesheet\" type=\"text/css\" href=\"css/job.css\" />\n<title>営業│職種紹介│Recruit│キノンビクス株式会社</title>\n<style>\n/* サブページのステージ */\n#zone_substage {\n\tbackground-image: url(\"image/job-01-01.jpg\");\n\tcolor: #fff;\n\tmax-width: 100%;\n}\n#zone_substage div {\n\tbackground: url(\"image/bg-triangle-01.png\")no-repeat;\n\tbackground-position: 7% 92%;\n}\n\n@media screen and (max-width : 960px) {\n#zone_substage div {\n\tbackground-position: 4% 71%!important;\n}\n}\n\n@media screen and (max-width : 768px) {\n#zone_substage div {\n\tbackground-size: 100px!important;\n}\n#zone_substage {\n\tbackground-position: center;\n}\n}\n\n@media screen and (max-width : 500px) {\n#zone_substage div {\n\tbackground: none;\n}\n}\n</style>\n<!-- スクリプトのインクルード（事前呼び出し） --> \n<meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\" />\n<link rel=\"icon\" href=\"../favicon.ico\">\n\n<!-- fontawesome -->\n<link href=\"https://use.fontawesome.com/releases/v5.6.1/css/all.css\" rel=\"stylesheet\">\n\n\n</head>\n<body>\n<div id=\"zone_sheet\"> \n  <!-- ヘッダーのインクルード --> \n  <meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\" />\n<!--\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/css/other.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/css/bpts.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/css/common.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/css/zone.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/css/unit.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/css/col.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/css/other.css\"/>\n -->\n<div class=\"header_bg\">\n<div class=\"header_logo\"><a href=\"../../\"><img src=\"../image/common/logo.svg\"></a></div>\n<nav class=\"pc_menu\">\n  <div class=\"o_mainmenu\">\n    <ul>\n      <li><a href=\"../about/\">About us</a>\n        <ul>\n          <li><a href=\"/about/index.shtml\">代表挨拶</a></li>\n          <li><a href=\"/about/overview.shtml\">会社概要</a></li>\n          <li><a href=\"/about/philosophy.shtml\">経営理念</a></li>\n          <li><a href=\"/about/promises.shtml\">7つのお約束</a></li>\n          <li><a href=\"/about/history.shtml\">沿革</a></li>\n          <li><a href=\"/about/employee.shtml\">社員保有資格一覧</a></li>\n          <li><a href=\"/about/certifications.shtml\">各種認定と宣言</a></li>\n        </ul>\n      </li>\n      <li><a href=\"../culture/\">Culture</a></li>\n      <li><a href=\"../solution/\">Solution</a>\n        <ul>\n          <li><a href=\"../solution/index.shtml#jump_01\">システムソリューション</a></li>\n          <li><a href=\"../solution/index.shtml#s_index_section02\">場所から探す</a></a></li>\n          <li><a href=\"../solution/index.shtml#s_index_section03\">納入事例</a></a></li>\n        </ul>\n      </li>\n      <li><a href=\"../recruit/\">Recruit</a>\n        <ul>\n          <li><a href=\"/recruit/\">採用情報</a></li>\n          <li><a href=\"/recruit/job.shtml\">職種紹介</a></li>\n          <li><a href=\"/recruit/interview.shtml\">社員インタビュー</a></li>\n          <li><a href=\"/recruit/requirements.shtml\">募集要項</a></li>\n        </ul>\n      </li>\n      <li><a href=\"../misc/contact.shtml\">Contact</a></li>\n    </ul>\n  </div>\n</nav>\n</div>\n<!-- レスポンシブメニュー　 -->\n<header>\n<div class=\"header-logo-menu\">\n<div id=\"nav-drawer\">\n<input id=\"nav-input\" type=\"checkbox\" class=\"nav-unshown\">\n<label id=\"nav-open\" for=\"nav-input\">\n<span></span>\n<p class=\"label_txt_menu\">MENU</p>\n</label>\n<label class=\"nav-unshown\" id=\"nav-close\" for=\"nav-input\"></label>\n<div id=\"nav-content\">\n<!--  ----------------- -->\n<div class=\"accordion\"> \n  <!-- menu1 -->\n  <div class=\"option\">\n    <input type=\"checkbox\" id=\"toggle1\" class=\"toggle\">\n    <label class=\"title item10\" for=\"toggle1\">About us</label>\n    <div class=\"content\">\n      <ul>\n        <li class=\"f_m10_10\"><a href=\"/about/index.shtml\">代表挨拶</a></li>\n        <li class=\"f_m10_20\"><a href=\"/about/overview.shtml\">会社概要</a></li>\n        <li class=\"f_m10_30\"><a href=\"/about/philosophy.shtml\">経営理念</a></li>\n        <li class=\"f_m10_40\"><a href=\"/about/promises.shtml\">7つのお約束</a></li>\n        <li class=\"f_m10_50\"><a href=\"/about/history.shtml\">沿革</a></li>\n        <li class=\"f_m10_60\"><a href=\"/about/employee.shtml\">社員保有資格一覧</a></li>\n        <li class=\"f_m10_70\"><a href=\"/about/certifications.shtml\">各種認定と宣言</a></li>\n      </ul>\n    </div>\n  </div>\n  <!-- menu2 -->\n  <div class=\"option\">\n    <div class=\"one_link\"><a href=\"../culture/\">Culture</a></div>\n  </div>\n  <!-- menu3 -->\n  <div class=\"option\">\n    <input type=\"checkbox\" id=\"toggle3\" class=\"toggle\">\n    <label class=\"title item50\" for=\"toggle3\">Solution</label>\n    <div class=\"content\">\n      <ul>\n        <li class=\"f_m30_10\"><a href=\"../solution/index.shtml#sp_jump_01\">システムソリューション</a></li>\n        <li class=\"f_m30_20\"><a href=\"../solution/index.shtml#jump_15\">場所から探す</a></a></li>\n        <li class=\"f_m30_30\"><a href=\"../solution/index.shtml#jump_02\">納入事例</a></a></li>\n      </ul>\n    </div>\n  </div>\n  <!-- menu4 -->\n  <div class=\"option\">\n    <input type=\"checkbox\" id=\"toggle4\" class=\"toggle\">\n    <label class=\"title item60\" for=\"toggle4\">Recruit</label>\n    <div class=\"content\">\n      <ul>\n        <li class=\"f_m40_10\"><a href=\"/recruit/\">採用情報</a></li>\n        <li class=\"f_m40_20\"><a href=\"/recruit/job.shtml\">職種紹介</a></li>\n        <li class=\"f_m40_30\"><a href=\"/recruit/interview.shtml\">社員インタビュー</a></li>\n        <li class=\"f_m40_40\"><a href=\"/recruit/requirements.shtml\">募集要項</a></li>\n      </ul>\n    </div>\n  </div>\n  <!-- menu5 -->\n  <div class=\"option\">\n    <div class=\"one_link\"><a href=\"../misc/contact.shtml\">Contact</a></div>\n  </div>\n<!-- menu6 -->\n  <div class=\"option\">\n    <div class=\"one_link\"><a href=\"../\">Home</a></div>\n  </div>\n</div alt=\"eod:accordion\">\n</header>\n<!-- --------------------------------------------------- --> \n\n \n  <!-- ヘッダーのインクルード 終わり　--> \n  \n  <!-- ステージ-->\n  <div id=\"zone_substage\">\n    <div>\n      <h1>営業</h1>\n      <p>「大画面のスクリーンに映し出される鮮明な映像」<br>\n        「心を震わせる迫力の音響」 <br>\n        「教育現場からビジネスの最前線まで、ICTで広がる新たな世界」<br>\n        こうしたワクワクする未来を描くのが、私たちの仕事。<br>\n        お客様の想像を超える提案の先には、多くの人の感動が待っている。<br>\n        あなたのアイデアが、お客様のビジネスを変え、社会を変える！ </p>\n    </div>\n  </div alt=\"eod:zone_substage\">\n  <!-- ステージ　終わり --> \n  <!--- パンくず -->\n  <ol class=\"zone_pankuzu\">\n    <li><a href=\"../\">HOME</a></li>\n    <li><a href=\"/recruit/\">Recruit</a></li>\n    <li><a href=\"/recruit/job.shtml\">職種紹介</a></li>\n    <li>営業</li>\n  </ol>\n  <!-- パンくず --> \n  <!-- 第2層 -->\n  <div id=\"zone_middle_floor\"> \n    <!--　ボディ領域　-->\n    <div id=\"zone_body\"> \n      <!--　メインエリア　-->\n      <div id=\"zone_mainarea_1col\">\n        <div class=\"sp_padding\"> \n          \n          <!--　▼▼▼　本文領域　▼▼▼　-->\n          <div class=\"col_textarea_full\">\n            <ul class=\"page-nav bpts_flexbox_noblock justify wrap\">\n              <li><a href=\"#job_section02\">仕事内容</a></li>\n              <li><a href=\"#job_section03\">キャリアステップ</a></li>\n              <li><a href=\"#interview_id\">INTERVIEW</a></li>\n            </ul>\n            <section id=\"job_section01\">\n              <h2>営業職の魅力</h2>\n              <ul class=\"check-list\">\n                <li>お客様の要望をカタチにする感動<br>\n                  「こんなことができるなんて！」という驚きと喜びを生む提案ができる！ </li>\n                <li>創意工夫で提案の幅が広がる<br>\n                  最新技術を活かした提案をするほど、お客様の反応が変わり、成長を実感できる！ </li>\n                <li>チームで成功をつかむ達成感<br>\n                  みんなで考えたプロジェクトが完成し、お客様に喜んでもらえた瞬間の感動は格別！ </li>\n              </ul>\n              <h3><span>＼</span>　　こんな人にピッタリ　　<span>／</span></h3>\n              <ul class=\"circle-list\">\n                <li>\n                  <p><span class=\"color\">新しい技術 </span>に触れるのが好き！</p>\n                </li>\n                <li>\n                  <p>営業を通してお客様のビジネスに <span class=\"color\">影響</span>を与えたい！</p>\n                </li>\n                <li>\n                  <p>人と<span class=\"color\">コミュニケーション</span>をとるのが得意！</p>\n                </li>\n              </ul>\n            </section>\n            <section id=\"job_section02\">\n              <div class=\"bpts_flexbox_onoff justify flexbox\">\n                <div class=\"left\">\n                  <h2>仕事内容</h2>\n                  <div> <img src=\"image/job-01-parts-01.jpg\" alt=\"\" class=\"img01\"> <img src=\"image/job-01-parts-02.jpg\" alt=\"\" class=\"img02\"> <img src=\"image/job-01-parts-03.jpg\" alt=\"\" class=\"img03\"> </div>\n                </div>\n                <div class=\"right\">\n                  <ul class=\"circle-list\">\n                    <li>\n                      <h3>お客様との打ち合わせ</h3>\n                      <p>ヒアリングを通じて、お客様の要望や困りごとを把握します。 </p>\n                    </li>\n                    <li>\n                      <h3>提案資料作成</h3>\n                      <p>お客様が理解しやすいように、わかりやすい資料や見積書を作成します。</p>\n                    </li>\n                    <li>\n                      <h3>提案・デモ</h3>\n                      <p>作成した資料を基にお客様に説明します。実際の機器を使ったデモを行うこともあります。 </p>\n                    </li>\n                    <li>\n                      <h3>納入・アフターフォロー</h3>\n                      <p>実際の納入に向けての打合せを行い、納入後はアフターフォローも行います。</p>\n                    </li>\n                  </ul>\n                  <h4 class=\"color\">こんな資格が取得可能！ </h4>\n                  <ul class=\"sub-list\">\n                    <li>\n                      <h5>電気工事士</h5>\n                      <p>技術的な提案力が身につく！ </p>\n                    </li>\n                    <li>\n                      <h5>防犯設備士</h5>\n                      <p>防犯関連の技術を理解し、より専門的な提案が可能に！ </p>\n                    </li>\n                    <li>\n                      <h5>ビジネス・キャリア検定</h5>\n                      <p>営業・マーケティングの知識を学び、営業実践に活かす！</p>\n                    </li>\n                  </ul>\n                </div>\n              </div>\n            </section>\n            <section id=\"job_section03\">\n              <h2>キャリアステップ</h2>\n              <img src=\"image/job-01-05.svg\" alt=\"\">\n              <div class=\"bpts_flexbox_onoff justify flexbox\">\n                <h3><span class=\"big color\">1</span>年目</h3>\n                <div class=\"wrap\">\n                  <div class=\"l_step_title\">基礎を学び、営業の“楽しさ”を実感！</div>\n                  <ul class=\"circle-list\">\n                    <li>\n                      <h4>先輩から営業の方法を学ぶ</h4>\n                      <p>製品知識や仕事の流れについて教わります。最初は分からないことだらけでも大丈夫。先輩が丁寧に教えてくれます！ </p>\n                    </li>\n                    <li>\n                      <h4>先輩の商談に同行する</h4>\n                      <p>先輩に同行し、実際の商談の様子を見ながら、どのように話を進めるのか学びます。<br>\n                        慣れてきたら、先輩から学んだことを活かし、自分が主体となって提案を行います。<br>\n                        まずは、営業の世界に慣れ、お客様と信頼関係を築くことが最も大切です。 </p>\n                    </li>\n                  </ul>\n                  <div class=\"txt-box\">\n                    <h5>おすすめ資格</h5>\n                    <p>ITパスポート — システムやネットワークの基礎を学び、提案の幅を広げる！ </p>\n                  </div>\n                </div>\n              </div>\n              <div class=\"bpts_flexbox_onoff justify flexbox\">\n                <h3><span class=\"big color\">2</span>年目</h3>\n                <div class=\"wrap\">\n                  <div class=\"l_step_title\">独り立ちし、自分の提案力を試す！</div>\n                  <ul class=\"circle-list\">\n                    <li>\n                      <h4>ひとりで商談にチャレンジ</h4>\n                      <p>先輩とともに商談を重ねることで、少しずつ自信ができたら、いよいよ自分ひとりで商談を行います。<br>\n                        最初は上手くいかなくても、先輩や上司がたくさんフォローしてくれます。ひとりでやり遂げることができた時の達成感は格別です！ </p>\n                    </li>\n                  </ul>\n                  <div class=\"txt-box\">\n                    <h5>おすすめ資格</h5>\n                    <p>ビジネス・キャリア検定‐営業・マーケティングの知識を学び、営業実践に活かす！ </p>\n                  </div>\n                </div>\n              </div>\n              <div class=\"bpts_flexbox_onoff justify flexbox\">\n                <h3><span class=\"big color\">3</span>年目</h3>\n                <div class=\"wrap\">\n                  <div class=\"l_step_title\">自分ならではのアイデアで、営業がもっと楽しくなる！</div>\n                  <ul class=\"circle-list\">\n                    <li>\n                      <h4>お客様の\"本当に求めているもの\"に応えられる</h4>\n                      <p>「お客様が言葉にしている要望」だけでなく、「本当に必要なものは何か？」を考えた提案ができるようになります。<br>\n                        スペック説明だけではなく、他社と差別化できるポイントや、まだ顕在化していない課題を見つけ、お客様の期待を超えられるような営業を目指します。<br>\n                        「あなたが担当者でよかった」と言われることが増え、営業の醍醐味を実感できます！</p>\n                    </li>\n                  </ul>\n                  <div class=\"txt-box\">\n                    <h5>おすすめ資格</h5>\n                    <p>防犯設備士‐防犯設備の専門知識を深めることで、技術的な提案ができる！</p>\n                  </div>\n                </div>\n              </div>\n            </section>\n            <div id=\"interview_id\" class=\"bpts_spacer_h80\"></div>\n            <section id=\"job_section04\">\n              <h2>社員INTERVIEW</h2>\n              <img src=\"image/bg-job.gif\" alt=\"\"> <a href=\"interview-01.shtml\">\n              <div class=\"box\">\n                <div>\n                  <h3>営業<br>\n                    教育ソリューションチーム<br>\n                    30代　在職歴：8年</h3>\n                  <span>Read more　　→</span></div>\n                <div class=\"ciecle_icon\"><img src=\"image/icon-job-01.jpg\"></div>\n              </div>\n              </a> </section>\n            <section id=\"job_section05\">\n              <h2>その他職種</h2>\n              <ul class=\"bpts_flexbox_onoff justify flexbox\">\n                <li><a href=\"job-02.shtml\">\n                  <h3><img src=\"image/job-02-01.jpg\" alt=\"\"><span>未来をカタチにする職人！<br>\n                    映像・音響・ICTシステムの<br>\n                    技術職とは？</span></h3>\n                  施工管理　　→</a> </li>\n                <li><a href=\"job-03.shtml\">\n                  <h3><img src=\"image/job-03-01.jpg\" alt=\"\"><span>アイデアで未来を創造する！<br>\n                    映像・音響・ICTシステムの<br>\n                    エンジニア職とは？</span></h3>\n                  システムエンジニア　　→</a> </li>\n                <li> <a href=\"job-04.shtml\">\n                  <h3><img src=\"image/job-04-01.jpg\" alt=\"\"><span>知識で未来を輝かせる！<br>\n                    映像・音響・ICTシステムの<br>\n                    サポート職！</span></h3>\n                  保守・サポート　　→</a> </li>\n              </ul>\n            </section>\n          </div alt=\"col_textarea_full\">\n          <!--　▲▲▲　本文領域　終わり　▲▲▲　--> \n        </div>\n        <!-- eod:sp_padding --> \n      </div alt=\"eod:zone_mainarea\">\n      <!--　メインエリア　終わり　--> \n    </div alt=\"eod:zone_body\">\n    <!--　ボディ領域　終わり　--> \n  </div alt=\"eod:zone_middle\">\n  <!--　第2層　終わり　--> \n  <!-- リクルート用　お問い合わせフッターのインクルード --> \n  <meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\" />\n<meta name=\"format-detection\" content=\"telephone=no\">\n<!-- \n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/common.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/zone.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/bpts.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/unit.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/col.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/other.css\"/>\n-->\n<!-- リクルートフッターここから -->\n<div class=\"bpts_footer_recruit\"> \n  <!-- ▼ 左ボックス -->\n  <div>\n    <h4>採用に関するお問い合わせ</h4>\n    <table>\n      <tr>\n        <th>担当</th>\n        <td><span>管理グループ</span><br>\n          西村 伸宏</td>\n      </tr>\n      <tr>\n        <th>TEL</th>\n        <td>077-552-1144</td>\n      </tr>\n<!--      <tr>\n        <th>Mail　</th>\n        <td><a href=\"mailto:\"></a></td>\n      </tr>-->\n    </table>\n  </div>\n  <!-- ▲ 左ボックス --> \n  <!-- ▼ 右ボックス -->\n  <div> <a href=\"requirements.shtml\">\n    <h6>募集要項</h6></a> </div>\n  <!-- ▲ 右ボックス --> \n</div>\n<!-- ▲リクルートフッターここまで --> \n\n<!-- お問い合わせfooterここから -->\n<div class=\"bpts_footer_contact_area recruit_wrap\">\n  <h6 class=\"recruit_fotter\">ご相談等ありましたら<span>お気軽にお問い合わせください</span></h6>\n  <div class=\"center\"> <a href=\"/recruit/saiyou-contact.shtml\" class=\"bpts_btn_squarered\"><span>お問い合わせフォームを開く</span></a> </div>\n</div>\n<!-- お問い合わせfooterここまで --> \n \n  <!--　第3層　-->\n  <div id=\"zone_bottom_floor\"> \n    <!--　フッター　-->\n    <div id=\"zone_footer\"> \n      <!-- フッターのインクルード --> \n      <meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\" />\n<meta name=\"format-detection\" content=\"telephone=no\">\n<!-- \n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/common.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/zone.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/bpts.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/unit.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/col.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/other.css\"/>\n -->\n<div id=\"pagetop\"><a href=\"#top\">Page Top</a></div>\n<!--　フッター　-->\n<footer id=\"footer\">\n<div class=\"bpts_footer_wrapper\"> \n  \n  <!-- -------------------- ▼　画像とロゴ --