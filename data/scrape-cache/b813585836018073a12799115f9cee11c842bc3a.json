alt=\"代表取締役　岡本知彦\" width=\"274\" height=\"32\" />\n          </p>\n        </section>\n      </div>\n    </div> -->\n\n    <div class=\"profile\">\n      <div class=\"bg_blue\">\n        <section class=\"inner\">\n          <h2>会社概要<span>COMPANY PROFILE</span></h2>\n          <section>\n            <h3>株式会社 ナベヤ製作所</h3>\n            <table>\n              <tr>\n                <th>所在地</th>\n                <td>\n                  <ul>\n                    <li>\n                      ■ 本社工場<br />\r\n〒509-0109　岐阜県各務原市テクノプラザ2丁目12番地<br />\r\nTEL：058-370-6351／ FAX：058-370-6371<br />\r\n ■上戸（じょうご）工場<br />\r\n〒504-0927　岐阜県各務原市上戸町7丁目1番地24<br />\r\nTEL：058-383-6351／ FAX：058-383-6361<br />\r\n■ 山脇工場<br />\r\n〒504-0928　岐阜県各務原市山脇町7丁目131番地<br />\r\nTEL：058-383-6831 ／ FAX：058-383-6895                    </li>\n                  </ul>\n                </td>\n              </tr>\n              <tr>\n                <th>取得認証</th>\n                <td class=\"column\">\n                                                            <figure>\n                        <figcaption>JISQ9100-2016</figcaption>\n                                                    <img src=\"https://www.nabeya-mfg.co.jp/wp/wp-content/uploads/2025/10/jisq.png\" \n                                alt=\"JISQ9100-2016\" \n                                loading=\"lazy\">\n                                              </figure>\n                                                      </td>\n              </tr>\n                                                <tr>\n                    <th>創業</th>\n                    <td>1560年（永禄3年）</td>\n                  </tr>\n                                  <tr>\n                    <th>資本金</th>\n                    <td>4,000万円</td>\n                  </tr>\n                                  <tr>\n                    <th>設立</th>\n                    <td>昭和46年11月</td>\n                  </tr>\n                                  <tr>\n                    <th>事業内容</th>\n                