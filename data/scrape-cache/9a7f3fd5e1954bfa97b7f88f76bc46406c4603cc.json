{"url":"https://www.wism-mutoh.jp/recruit_plus/work-style","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n  <head>\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>働く環境を知る | 株式会社ムトウ 採用サイト</title>\n\n<meta charset=\"UTF-8\">\n\n<link rel=\"canonical\" href=\"https://www.wism-mutoh.jp/recruit_plus/work-style.html\">\n\n<meta name=\"description\" content=\"株式会社ムトウ 採用サイトの働く環境について知るページです。入社後のキャリアアップや研修制度、福利厚生など入社前に気になる情報をまとめています。\">\n\n<meta name=\"robots\" content=\"index, follow\">\n\n<meta property=\"og:title\" content=\"働く環境を知る | 株式会社ムトウ 採用サイト\">\n<meta property=\"og:type\" content=\"website\">\n<meta property=\"og:image\" content=\"https://www.wism-mutoh.jp/recruit_plus/assets/images/ogp.jpg\">\n<meta property=\"og:url\" content=\"https://www.wism-mutoh.jp/recruit_plus/work-style/\">\n\n\n\n<meta name=\"twitter:card\" content=\"summary_large_image\">\n\n\n\n\n\n\n\n\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n    <link href=\"https://fonts.googleapis.com/css2?family=Shippori+Mincho+B1:wght@400;500;600;700&family=Zen+Kaku+Gothic+New:wght@300;400;500;700&display=swap\" rel=\"stylesheet\">\n  <link rel=\"stylesheet\" href=\"/recruit_plus/assets/css/style.css\" /><script type=\"module\" src=\"/recruit_plus/assets/js/Asd-mJ7I.js\"></script></head>\n  <body>\n    <header data-astro-cid-2my4ig3m>\n  <div id=\"js-header\" class=\"header__wrap is-active\" data-astro-cid-2my4ig3m>\n    <div class=\"header__logo\" data-astro-cid-2my4ig3m>\n      <a href=\"https://www.wism-mutoh.jp/recruit_plus/\" data-astro-cid-2my4ig3m>\n        <img src=\"/recruit_plus/assets/images/logo.svg\" alt=\"wism 株式会社ムトウ\" data-astro-cid-2my4ig3m>\n        <b data-astro-cid-2my4ig3m>RECRUIT SITE</b>\n      </a>\n    </div>\n    <a class=\"header__entry\" href=\"https://wismmutoh.snar.jp/entry.aspx?entryid=e54b569a-3f41-45e0-b9ed-d73c907a6d1b\" target=\"_blan