{"url":"https://canycom.jp/corporate/recruit1.html","html":"<!DOCTYPE html>\r\n<html lang=\"ja\">\r\n<head>\r\n    <!-- Required meta tags -->\r\n    <meta charset=\"utf-8\">\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1, shrink-to-fit=no\">\r\n\r\n    <!-- Bootstrap CSS -->\r\n    <link rel=\"stylesheet\" href=\"https://maxcdn.bootstrapcdn.com/bootstrap/4.0.0/css/bootstrap.min.css\" integrity=\"sha384-Gn5384xqQ1aoWXA+058RXPxPg6fy4IWvTNh0E263XmFcJlSAwiGgFAW/dAiS6JXm\" crossorigin=\"anonymous\">\r\n    \r\n    <title>リクルート情報│運搬車の筑水キャニコム[CANYCOM]</title>\r\n    <meta name=\"Description\" content=\"農業・林業用などの動力運搬車製造メーカー、筑水キャニコムの採用情報です。\" />\r\n    <meta name=\"Keywords\" content=\"筑水キャニコム,CYANYCOM,運搬車,林業機械,草刈機,土木建設機械,中国,韓国,デザインの森,採用情報\" />\r\n    <meta name=\"Author\" content=\"Copyright &copy; CHIKUSUI CANYCOM,INC. All rights reserved.\" />\r\n    <meta name=\"Copyright\" content=\"Copyright &copy; CHIKUSUI CANYCOM,INC. All rights reserved.\" />\r\n\r\n    \r\n    <link rel=\"stylesheet\" href=\"css/recruit-new.css\">\r\n    \r\n    <script defer src=\"https://use.fontawesome.com/releases/v5.0.6/js/all.js\"></script>\r\n</head>\r\n<body>\r\n    <header>\r\n        <nav class=\"navbar navbar-expand-lg navbar-light fixed-top col-xl-12\">\r\n            <div class=\"container\">\r\n            <a class=\"navbar-brand\" href=\"/\"><img src=\"recruit/logo.png\" alt=\"CANYCOM\" width=\"89\" height=\"53\"></a>\r\n            <button type=\"button\" class=\"navbar-toggler\" data-toggle=\"collapse\" data-target=\"#navbarText\" aria-controls=\"navbarText\" aria-expanded=\"false\" aria-label=\"ナビゲーションの切替\">\r\n                <span class=\"navbar-toggler-icon\"></span>\r\n            </button>\r\n<div class=\"collapse navbar-collapse\" id=\"navbarText\">\r\n    <ul class=\"navbar-nav ml-auto\">\r\n        <li class=\"nav-item\">\r\n            <a class=\"nav-link\" href=\"/\">ホーム</a>\r\n        </li>\r\n    </ul>\r\n</div>\r\n            </div>\r\n        </nav>\r\n        <div class=\"heading\">\r\n          <h1>リクルート情報</h1>\r\n      </div>\r\n</header>\r\n       \r\n<section id=\"yoko\" class=\"bg-blue\">\r\n        <div class=\"container-pc\"><div class=\"skew\"><h2>募集職種・募集要項</h2></div></div>\r\n  <div class=\"container-pc justify-content-center\">\r\n            <table>\r\n                <tr>\r\n                    <th>職種</th>\r\n                    <td>総合職（技術職・営業職・プロダクトデザイン職）</td>\r\n                </tr>\r\n                <tr>\r\n                    <th>応募資格</th>\r\n                    <td>営業職（国内営業、海外営業）⇒全学部・全学科<br>\r\n                    技術職（開発設計、試作実験、生産技術など） ⇒理工系学部（機械工学、電気、制御など）<br>\r\n\t\t\t\t\tプロダクトデザイン職 ⇒工業デザインを学ばれた方（学部の指定はございません）<br>\r\n                    ※普通自動車運転免許（AT可、MT尚可、入社までに取得）</td>\r\n                </tr>\r\n                <tr>\r\n                    <th>勤務地</th>\r\n                    <td>本社・博多・広島・兵庫・東京・群馬・仙台・札幌及び海外<br>\r\n                    （海外を含む転勤の可能性があります）</td>\r\n                </tr>\r\n                <tr>\r\n                    <th>勤務時間</th>\r\n                    <td>8:00～17:00（実働8時間）</td>\r\n                </tr>\r\n                <tr>\r\n                    <th>休日休暇</th>\r\n                    <td>週休2日制（土曜、日曜）、祝日（年間休日126日）<br>\r\n                    （当社カレンダーによる）</td>\r\n                </tr>\r\n                <tr>\r\n                    <th>給与</th>\r\n                    <td>【大学院卒(博士)】 　261,600円<br>\r\n                    【大学院卒(修士)】 　242,200円<br>\r\n                    【大学卒(学士)】 　　230,600円<br>\r\n                    【高専卒(学士)】 　　230,600円<br>\r\n                    【高専卒(準学士)】 　216,400円<br>\r\n                    【短大・専門卒】　　205,000円<br>\r\n                    【高校卒】　　　　　189,900円</td>\r\n                </tr>\r\n                <tr>\r\n                    <th>手当</th>\r\n                    <td>ファミリー（家族）手当・通勤手当・時間外勤務手当・営業手当</td>\r\n                </tr>\r\n                <tr>\r\n                    <th>昇給</th>\r\n                    <td>年1回（4月・・個人成果により等級格付け改訂）</td>\r\n                </tr>\r\n                <tr>\r\n                    <th>賞与</th>\r\n                    <td>夏季賞与（6月）、冬季賞与（12月）＊いずれも業績による</td>\r\n                </tr>\r\n                <tr>\r\n                    <th>福利厚生</th>\r\n                    <td>健康保険・厚生年金・雇用保険・労災保険<br>\r\n                    社宅、財形貯蓄制度、401K確定拠出年金など</td>\r\n                </tr>\r\n            </table>\r\n        </div>\r\n    </section>\r\n    \r\n    <section id=\"flow\">\r\n        <div class=\"container-pc\"><div class=\"skew\"><h2>採用までの流れ</h2></div></div>\r\n        <div class=\"container-pc\">\r\n            <table>\r\n                <thead>\r\n                    <tr>\r\n                        <th>2月</th>\r\n                        <th>3月</th>\r\n                        <th>4月</th>\r\n                    </tr>\r\n                </thead>\r\n                <tbody>\r\n                    <tr>\r\n                        <td><div>採用サイトプレオープン</div></td>\r\n                        <td><div>採用サイトオープン</div></td>\r\n                        <td><div>書類選考<span class=\"display-pc\">・</span><br class=\"display-sp\">面接</div></td>\r\n                    </tr>\r\n                    <tr>\r\n                        <td></td>\r\n                        <td><div>会社説明会</div></td>\r\n                        <td><div>面談</div></td>\r\n                    </tr>\r\n\t\t\t\t\t<tr>\r\n\t\t\t\t\t\t<td></td>\r\n\t\t\t\t\t\t<td></td>\r\n\t\t\t\t\t\t<td><div><h6>内々定</h6></div></td>\r\n\t\t\t\t\t</tr>\r\n                </tbody>\r\n            </table>\r\n            <p>&nbsp;</p>\r\n        </div>\r\n    </section>\r\n    \r\n    <section id=\"work\" class=\"bg-blue\">\r\n            <div class=\"container-pc\"><div class=\"skew\"><h2>仕事紹介</h2></div>\r\n            <div class=\"cf\">\r\n                <div id=\"kaihatsu\" class=\"work-box\">\r\n                    <div class=\"box-line\">\r\n                        <h3>技術</h3>\r\n                        <p class=\"work-box-bottom\">製品企画(構想設計、原価算出 等)や部品、材料の調達、新製品の試作・試験、品質保証業務、生産技術などの製品開発に関わる様々な業務に携わります。</p>\r\n                    </div>\r\n                </div>\r\n                <div id=\"eigyo\" class=\"work-box\">\r\n                    <div class=\"box-line\">\r\n                        <h3>営業</h3>\r\n                        <p class=\"work-box-bottom\">販売店への営業・新規販売店の拡大や実演会等でのユーザー様への製品・サービスの提案を行います。</p>\r\n                  </div>\r\n                </div>\r\n                <div id=\"parts\" class=\"work-box\">\r\n                    <div class=\"box-line\">\r\n                        <h3>パーツセンター</h3>\r\n                        <p class=\"work-box-bottom\">部品の発送、受入、管理を行っています。主に東日本のお客様には東日本パーツセンターから、そして西日本、海外のお客様には本社パーツセンターから発送しています。</p>\r\n                    </div>\r\n                </div>\r\n                <div id=\"seizo\" class=\"work-box\">\r\n                    <div class=\"box-line\">\r\n                        <h3>製造</h3>\r\n                        <div class=\"work-box-bottom\">\r\n                            <p>工場内では大きく分けて“プレス、機械加工、溶接、塗装、組立”の5つの工程を行っています。その後、品質検査に合格した製品が世界各国のお客様の元へと旅立っていきます。</p>\r\n                            <a href=\"recruit-seizo.html\"><div class=\"padding\"><div>もっと詳しく</div></div></a>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n      </div>\r\n</section>\r\n    \r\n    <section id=\"kenshu\">\r\n      <div class=\"container-pc\"><div class=\"skew\"><h2>新入社員研修</h2></div></div>\r\n        <div class=\"container-pc justify-content-center\">\r\n            <div class=\"cf\">\r\n                <div class=\"image\"><img src=\"recruit/kenshu.jpg\" alt=\"研修風景\"></div>\r\n                <div class=\"shugokenshu\">\r\n                <h3 class=\"slash\">集合研修</h3>\r\n                <p>会社知識・マナー教育・情報管理・安全・救命・製品知識・製品体験</p>\r\n                </div>\r\n            </div>\r\n            \r\n            <h3 class=\"slash\">研修・サポート制度</h3>\r\n            <table>\r\n                <tr>\r\n                    <th>入社<br class=\"display-sp\">1年目</th>\r\n                    <td>\r\n                        <dl>\r\n                            <dt>4月</dt>\r\n                            <dd>集合研修</dd>\r\n                            <dt>10月</dt>\r\n                            <dd>フォローアップ研修</dd>\r\n                        </dl>\r\n                        <div>入社後1年：メンター制によるサポート</div>\r\n                    </td>\r\n                </tr>\r\n                <tr>\r\n                    <th>入社<br class=\"display-sp\">2年目</th>\r\n                    <td>\r\n                        <dl>\r\n                            <dt>5月</dt>\r\n                            <dd>フォローアップ研修</dd>\r\n                        </dl>\r\n                    </td>\r\n                </tr>\r\n            </table>\r\n        </div>\r\n    </section>\r\n    \r\n    <section id=\"senpai\" class=\"bg-blue\">\r\n        <div class=\"container-pc\">\r\n            <div class=\"skew\"><h2>先輩社員の声</h2></div>\r\n          \r\n                <div class=\"container\">\r\n            \r\n\t<div class=\"senpai-box\">\r\n                <div id=\"kiyota\" class=\"member\">\r\n                    <h3><div>世界初商品開発line　大型グループ<br class=\"display-sp\">（技術職）<br>\r\n                    <span>清田 浩武</span>（2017年新卒入社）</div></h3>\r\n                    <dl>\r\n                        <dt>主な業務内容：</dt>\r\n                        <dd>新製品の設計、既存製品の仕様変更　等</dd>\r\n                    </dl>\r\n                </div>\r\n                <div class=\"container\">\r\n                    <h4 class=\"slash\">入社を決めた理由</h4>\r\n                    <p>　お客様の為に世界初の製品を世界中に届けるという理念に魅力を感じた事と、ネーミングや演歌の心など、独創的な社風で楽しそうな会社だと思い、入社を決めました。</p>\r\n                    <h4 class=\"slash\">仕事で印象に残っているエピソード</h4>\r\n                    <p>　開発に携わった製品（プンダ：土木建設用運搬車）がお客様のもとで実際に使用され、“使いやすい”との評価を頂いた時は嬉しく、またやりがいを感じました。</p>\r\n                    <h4 class=\"slash\">いま取り組んでいる“チャレンジ”</h4>\r\n                    <p>　既存製品への新仕様追加にチャレンジしています。これにより、さらに多くのお客様が安心・安全・快適に作業できるよう、今後もボヤキを収集しながら開発に取り組んでいきたいと考えています。</p>\r\n                </div>\r\n            </div>\t\r\n\t\t\t\t\t\r\n            <div class=\"senpai-box\">\r\n                <div id=\"yamashita\" class=\"member\">\r\n                    <h3><div>グローバルマーケティングline　DM福益　所長<br class=\"display-sp\">（営業職）<br>\r\n                    <span>山下 弘晃</span>（2012年新卒入社）</div></h3>\r\n                    <dl>\r\n                        <dt>主な業務内容：</dt>\r\n                        <dd>販売代理店、企業、ユーザーへの商品提案、CCS（※実演会 キャニコムコンサルティングサロンの略）の実施　等</dd>\r\n                    </dl>\r\n                </div>\r\n                <div class=\"container\">\r\n                    <h4 class=\"slash\">普段の営業活動で大切にしていること</h4>\r\n                    <p>　お客様が本当に欲しいものや使用現場にマッチした製品を提案することを大切にしています。また、お客様の話に耳を傾け、製品改良、新製品開発のための“ボヤキ”を集めるように努めています。</p>\r\n                    <h4 class=\"slash\">仕事を通じて成長できたこと</h4>\r\n                    <p>　仕事を通じて、自分自身のコミュニティ外の人とも接することが増え、社内外関係なく、誰とでも接するコミュニケーション能力が向上したと思います。また、自分が提案した製品を使うことで、お客様の作業がラクになっている様子を伺うと、やりがいを感じますね。育成という点では、部下が一人前に近づいていく姿を見ると、部下の成長により自分も成長できたのだと感じます。</p>\r\n                    <h4 class=\"slash\">今後の目標</h4>\r\n                    <p>　仕事に真摯に向き合いキャニコムNo.1になる。お客様に必要とされる人間になる。</p>\r\n                </div>\r\n            </div>\t\r\n\t\t\t\t\t\r\n\t\t\t\t<div class=\"senpai-box\">\r\n                <div id=\"fujiwara\" class=\"member\">\r\n                    <h3><div>価値即納line　生産管理部　副部長<br>\r\n                    <span>藤原 明子</span>（1989年新卒入社）</div></h3>\r\n                    <dl>\r\n                        <dt>主な業務内容：</dt>\r\n                        <dd>生産計画書の作成、製造への加工指示、部品の発注等</dd>\r\n                    </dl>\r\n                </div>\r\n                <div class=\"container\">\r\n                    <h4 class=\"slash\">仕事の魅力・やりがい</h4>\r\n                    <p>　この仕事をしていなかったら一生出会うことがない方と出会えることが何よりの魅力だと感じています。また、“営業と製造の架け橋”の部署に所属している為、様々な部署の人から相談を受けることもあります。その問題が解決出来た時の達成感が自分のモチベーションアップに繋がっていますね。</p>\r\n                    <h4 class=\"slash\">働いてきた中で感じたこと</h4>\r\n                    <p>　女性も活躍出来る職場だということです。“女性だから”という理由で仕事が決定することがなく、第一線で仕事をすることが出来ます。また、産前産後休暇、育児休業の取得率も高く、仕事に復帰しやすいところもキャニコムの良い所だと思います。</p>\r\n                    <h4 class=\"slash\">今後の目標</h4>\r\n                    <p>　いつも笑顔で楽しく仕事をすることです。仕事をしていると楽しいことだけでなく、悔しいことも沢山ありますが、どんな時でも笑顔を忘れずに前向きに仕事に取り組んでいきます。</p>\r\n                </div>\r\n            </div>\r\n\t\t\t\t\t\r\n        </div>\r\n    </section>\r\n    \r\n    <div class=\"container-pc\">\t\t\r\n        <a href=\"https://job.rikunabi.com/2026/company/r582210068/\" class=\"entry\"><div>エントリー/お問い合わせは<br class=\"display-sp\">こちら<span></span></div></a>\r\n    </div>\r\n    \r\n    \r\n    <footer>Copyright © CANYCOM. All Rights Reserved.</footer>\r\n    \r\n    <!-- Optional JavaScript -->\r\n    <!-- jQuery first, then Popper.js, then Bootstrap JS -->\r\n    <script src=\"https://code.jquery.com/jquery-3.2.1.slim.min.js\" integrity=\"sha384-KJ3o2DKtIkvYIK3UENzmM7KCkRr/rE9/Qpg6aAZGJwFDMVNA/GpGFF93hXpG5KkN\" crossorigin=\"anonymous\"></script>\r\n    <script src=\"https://cdnjs.cloudflare.com/ajax/libs/popper.js/1.12.9/umd/popper.min.js\" integrity=\"sha384-ApNbgh9B+Y1QKtv3Rn7W3mgPxhU9K/ScQsAP7hUibX39j7fakFPskvXusvfa0b4Q\" crossorigin=\"anonymous\"></script>\r\n    <script src=\"https://maxcdn.bootstrapcdn.com/bootstrap/4.0.0/js/bootstrap.min.js\" integrity=\"sha384-JZR6Spejh4U02d8jOt6vLEHfe/JQGiRRSQQxSfFWpi1MquVdAyjUar5+76PVCmYl\" crossorigin=\"anonymous\"></script>\r\n    \r\n\r\n<script type=\"text/javascript\" src=\"https://ajax.googleapis.com/ajax/libs/jquery/1.9.1/jquery.min.js\"></script>\r\n\r\n\r\n    <script>\r\n        $(function(){\r\n           // #で始まるアンカーをクリックした場合に処理\r\n           $('a[href^=\"#\"]').click(function() {\r\n              // スクロールの速度\r\n              var speed = 400; // ミリ秒\r\n              // アンカーの値取得\r\n              var href= $(this).attr(\"href\");\r\n              // 移動先を取得\r\n              var target = $(href == \"#\" || href == \"\" ? 'html' : href);\r\n              // 移動先を数値で取得\r\n              var position = target.offset().top;\r\n              // スムーススクロール\r\n              $('body,html').animate({scrollTop:position}, speed, 'swing');\r\n              return false;\r\n           });\r\n        });\r\n    </script>\r\n</body>\r\n</html>\r\n","finalUrl":"https://canycom.jp/corporate/recruit1.html","rendered":false,"_cachedAt":"2026-06-22T22:25:11.506Z"}