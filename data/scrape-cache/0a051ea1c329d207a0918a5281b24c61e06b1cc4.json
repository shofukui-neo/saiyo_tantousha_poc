{"url":"http://www.ab-net.co.jp/recruit/culture/health/","html":"<!DOCTYPE html>\n<html class=\"mouse lower modern\">\n<head prefix=\"og: http://ogp.me/ns# fb: http://ogp.me/ns/fb# website: http://ogp.me/ns/website#\">\n<meta charset=\"utf-8\">\n<title>健康経営の取り組み | 働く環境・制度 | Web制作会社・マーケティング | アビリブ 採用サイト</title>\n<meta name=\"keywords\" content=\"abilive,アビリブ,IT企業,ベンチャー,宿泊業,観光業,新卒採用,中途採用,リクルート,環境,制度,健康経営\">\n<meta name=\"description\" content=\"アビリブ採用サイト「健康経営の取り組み」ページです。アビリブでは、共に生きる環境づくりを目指し、従業員とその家族の心身の健康の保持増進に積極的に取り組みます。\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=0.0, user-scalable=no, minimum-scale=1.0, maximum-scale=1.0\">\n<meta name=\"format-detection\" content=\"telephone=no\">\n<link rel=\"index\" href=\"http://www.ab-net.co.jp/recruit/\">\n\n<!-- favicon -->\n<link rel=\"shortcut icon\" href=\"https://www.ab-net.co.jp/recruit/favicon.ico\">\n\n<!-- apple-touch-icon -->\n<link rel=\"apple-touch-icon\" href=\"https://www.ab-net.co.jp/recruit/apple-touch-icon.png\">\n\n<!-- Open graph tags -->\n<meta property=\"og:site_name\" content=\"Web制作会社・マーケティング | アビリブ 採用サイト\">\n<meta property=\"og:title\" content=\"健康経営の取り組み | 働く環境・制度 | Web制作会社・マーケティング | アビリブ 採用サイト\">\n<meta property=\"og:type\" content=\"website\">\n<meta property=\"og:url\" content=\"https://www.ab-net.co.jp/recruit/culture/health/\">\n<meta property=\"og:description\" content=\"アビリブ採用サイト「健康経営の取り組み」ページです。アビリブでは、共に生きる環境づくりを目指し、従業員とその家族の心身の健康の保持増進に積極的に取り組みます。\">\n<meta property=\"og:image\" content=\"https://www.ab-net.co.jp/recruit/ogp.jpg\">\n\n<!-- *** stylesheet *** -->\n<link href=\"https://www.ab-net.co.jp/recruit/css/default.css\" rel=\"stylesheet\" type=\"text/css\" media=\"all\">\n<link href=\"https://www.ab-net.co.jp/recruit/css/print.css\" rel=\"stylesheet\" type=\"text/css\" media=\"print\">\n<link href=\"https://www.ab-net.co.jp/recruit/css/common.css\" rel=\"stylesheet\" type=\"text/css\" media=\"all\">\n<link href=\"../../css/health.css\" rel=\"stylesheet\" type=\"text/css\" media=\"all\">\n\n<!-- *** javascript *** -->\n<script src=\"https://www.ab-net.co.jp/recruit/js/jquery-2.1.4.min.js\"></script>\n<script src=\"https://www.ab-net.co.jp/recruit/js/analytics.js\"></script>\n<script src=\"https://www.ab-net.co.jp/recruit/js/config.js\"></script>\n<script src=\"https://www.ab-net.co.jp/recruit/js/common.js\"></script>\n<!-- Google Tag Manager -->\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n})(window,document,'script','dataLayer','GTM-TKC4GLX');</script>\n<!-- End Google Tag Manager -->\n\n<script>\n// readyEvent\n$(function(){\n\n\t$w.on({\n\t\t//load\n\t\t'load' : function(){\n\n\t\t},\n\t\t//scroll\n\t\t'scroll' : function(){\n\n\t\t}\n\t}).superResize({\n\t\t//resize\n\t\tresizeAfter : function(){\n\n\t\t}\n\t}).firstLoad({\n\t\t//firstLoad\n\t\tpc_tab : function(){\n\n\t\t},\n\t\tsp : function(){\n\n\t\t}\n\t});\n});\n</script>\n</head>\n\n<body id=\"health\">\n<!-- Google Tag Manager (noscript) -->\r\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-TKC4GLX\"\r\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\r\n<!-- End Google Tag Manager (noscript) -->\r\n\r\n<div id=\"page\">\r\n\t<div class=\"wrapper_con\">\r\n\t\t<div id=\"header\">\r\n\t\t\t<div class=\"main_head\">\r\n\t\t\t\t<h1 class=\"header_logo\">\r\n\t\t\t\t\t<a href=\"http://www.ab-net.co.jp/recruit/\" class=\"over\">\r\n\t\t\t\t\t\t<img src=\"#\" data-img=\"https://www.ab-net.co.jp/recruit/images/logo-pc.png\" alt=\"アビリブ採用サイト\" class=\"change_img tab\">\r\n\t\t\t\t\t</a>\r\n\t\t\t\t</h1>\r\n\t\t\t\t\t\t\t\t\t<div class=\"header_common\">\r\n\t\t\t\t\t\t<div class=\"header_commontxt\">\r\n\t\t\t\t\t\t\t<div class=\"header_toptxt\">\r\n\t\t\t\t\t\t\t\t<div class=\"header_mtxtcommon\">\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<h1 class=\"header_mdesc\">健康経営の取り組み</h1>\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<p class=\"header_be\"><img src=\"https://www.ab-net.co.jp/recruit/culture/health/images/txt_health.png\" alt=\"health\"></p>\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t</div>\r\n                                                        <div class=\"header_topimg\"></div>\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t<div class=\"header_left view_pc\">\r\n\t\t\t\t\t<div class=\"box_sns\">\r\n\t\t\t\t\t\t<ul class=\"sns_list\">\r\n\t\t\t\t\t\t\t<li><a href=\"https://twitter.com/ability_c\" target=\"_blank\" class=\"over\" rel=\"noopener\"><img src=\"https://www.ab-net.co.jp/recruit/images/common/ic_twitter.svg\" alt=\"twitter\"></a></li>\r\n\t\t\t\t\t</div>\r\n\t\t\t\t\t<a class=\"header_scroll over\" href=\"#con_banner\">\r\n\t\t\t\t\t\t<span class=\"h_scroll\" >Scroll</span>\r\n\t\t\t\t\t</a>\r\n\t\t\t\t</div>\r\n\t\t\t\t<div class=\"header_gnav\" id=\"con_gnav\">\r\n\t\t\t\t\t<ul class=\"gnav1 view_pc\">\r\n\t\t\t\t\t\t<li><a href=\"http://www.ab-net.co.jp/recruit/about/\" class=\"over\">アビリブを知る</a></li>\r\n\t\t\t\t\t\t<li><a href=\"http://www.ab-net.co.jp/recruit/culture/\" class=\"over\">働く環境・制度</a></li>\r\n\t\t\t\t\t\t<li><a href=\"http://www.ab-net.co.jp/recruit/culture/health/\" class=\"over\">健康経営</a></li>\r\n\t\t\t\t\t\t<li><a href=\"http://www.ab-net.co.jp/recruit/person/\" class=\"over\">アビビト<br>(働く人)</a></li>\r\n\t\t\t\t\t\t<li class=\"ic_blank\"><a href=\"https://www.ab-net.co.jp/company/\" target=\"_blank\" class=\"over\">会社概要</a></li>\r\n\t\t\t\t\t</ul>\r\n\t\t\t\t\t<ul class=\"gnav2\">\r\n\t\t\t\t\t\t<li>\r\n\t\t\t\t\t\t\t<a href=\"http://www.ab-net.co.jp/recruit/new/\" class=\"over\">\r\n\t\t\t\t\t\t\t\t<span>新卒採用</span><br>\r\n\t\t\t\t\t\t\t\t<span class=\"txt_lg\">ENTRY</span>\r\n\t\t\t\t\t\t\t</a>\r\n\t\t\t\t\t\t</li>\r\n\t\t\t\t\t\t<li>\r\n\t\t\t\t\t\t\t<a href=\"http://www.ab-net.co.jp/recruit/career/\" class=\"over\">\r\n\t\t\t\t\t\t\t\t<span>中途採用</span><br>\r\n\t\t\t\t\t\t\t\t<span class=\"txt_lg\">ENTRY</span>\r\n\t\t\t\t\t\t\t</a>\r\n\t\t\t\t\t\t</li>\r\n\t\t\t\t\t\t<li>\r\n\t\t\t\t\t\t\t<a href=\"http://www.ab-net.co.jp/recruit/fair/\" class=\"over\">\r\n\t\t\t\t\t\t\t\t<span>新卒対象</span><br><span class=\"txt_lg\">会社説明会</span>\r\n\t\t\t\t\t\t\t</a>\r\n\t\t\t\t\t\t</li>\r\n\t\t\t\t\t\t<li>\r\n\t\t\t\t\t\t\t<a href=\"http://www.ab-net.co.jp/recruit/casual/\" class=\"over\">\r\n\t\t\t\t\t\t\t\t<span>カジュアル</span><br><span class=\"txt_lg\">面談</span>\r\n\t\t\t\t\t\t\t</a>\r\n\t\t\t\t\t\t</li>\r\n\t\t\t\t\t</ul>\r\n\t\t\t\t\t<p class=\"gnav_label view_pc\" style=\"display: none;\">\r\n\t\t\t\t\t\t<img src=\"https://www.ab-net.co.jp/recruit/images/img_label_new.png\" alt=\"新卒採用\">\r\n\t\t\t\t\t</p>\r\n\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t<div class=\"header_story\">\r\n\t\t\t\t\t<a href=\"http://www.ab-net.co.jp/recruit/engineer/\" class=\"over\"><img src=\"https://www.ab-net.co.jp/recruit/images/bnr_engineer.png\" alt=\"エンジニアの仕事\"></a>\r\n\t\t\t\t</div>\r\n\t\t\t\t<p class=\"sp_menu_btn view_tab-sp\">\r\n\t\t\t\t\t<a href=\"javascript:void(0);\">\r\n\t\t\t\t\t\t<span class=\"ic_menu\">\r\n\t\t\t\t\t\t\t<span class=\"line line01\"></span>\r\n\t\t\t\t\t\t\t<span class=\"line line02\"></span>\r\n\t\t\t\t\t\t\t<span class=\"line line03\"></span>\r\n\t\t\t\t\t\t</span>\r\n\t\t\t\t\t</a>\r\n\t\t\t\t</p>\r\n\t\t\t</div>\r\n\t\t</div>\r\n<div id=\"contents\">\n\n\t<div class=\"con_declaration\">\n\t\t<div class=\"box_dec\">\n\t\t\t<h2 class=\"st_logo\">健康経営宣言</h2>\n\t\t\t<p class=\"txt_b\">社名であるabi<span class=\"c_green\">live</span>の「<span class=\"c_green\">live</span>」は「<span class=\"c_green\">共に生きる</span>」という想いが込められています。<br>アビリブでは、共に生きる環境づくりを目指し、<br class=\"view_pc\">\n\t\t\t従業員とその家族の心身の健康の保持増進に積極的に取り組みます。</p>\n\t\t</div>\n\t</div>\n\n\t<div class=\"con_health_management\">\n\t\t<h2 class=\"st_normal\"><span class=\"c_green\">アビリブが考える</span>、健康経営</h2>\n\t\t<p class=\"txt_hm_b\">株式会社アビリブは、「健康経営優良法人（中小規模法人部門）」に、2019年より継続して認定され続けています。<br><br>\n\t\t\t弊社では「共に生きる環境づくり」を目指し、「従業員とその家族の健康」、「働きやすい職場」に力を入れています。健康経営の活動を通じ、従業員一人ひとりが心身ともに健やかに安心して働くことができる環境づくりに取り組むことで、パフォーマンスと企業価値の向上、持続的な成長に繋がると考えております。<br><br>\n\t\tなによりも、従業員が幸せを感じながら生活を送ることができるよう、今後も健康増進支援と健康意識向上を図っていきます。</p>\n\t\t<div class=\"con_hap\">\n\t\t\t<div class=\"box_img\">\n\t\t\t\t<p><img src=\"images/logo_h_2026.png\" alt=\"健康経営優良法人制度 ロゴ\"></p>\n\t\t\t</div>\n\t\t\t<div class=\"box_details\">\n\t\t\t\t<p class=\"st_b\">健康経営優良法人制度について</p>\n\t\t\t\t<p class=\"txt\">地域の健康課題に即した取り組みや日本健康会議が進める健康増進の取り組みをもとに、特に優良な健康経営を実践している企業等の法人を顕彰する制度です。<br>健康経営に取り組む優良な法人を『見える化』し、「従業員の健康管理を経営的な視点で考え、戦略的に取り組んでいる法人」として社会的に評価を受けることができる環境を整備することを目標としています。</p>\n\t\t\t</div>\n\t\t</div>\n\t</div>\n\n\t<div class=\"con_initiative\">\n\t\t<h2 class=\"st_common02\">健康経営推進の<span class=\"c_green\">取り組み</span></h2>\n\t\t<div class=\"box_ini\">\n\t\t\t<dl>\n\t\t\t\t<dt><p class=\"number\">取り組み ＃01</p>定期健康診断の実施</dt>\n\t\t\t\t<dd>全従業員を対象に、定期健康診断受診の呼び掛けを徹底しており、受診率は毎年100％。<br class=\"view_pc\">健康診断結果が「有所見」の場合、従業員へ精密検査や受診を促し、早期改善と重症化予防などのサポートを行っています。</dd>\n\t\t\t</dl>\n\t\t\t<dl>\n\t\t\t\t<dt><p class=\"number\">取り組み ＃02</p>ストレスチェックの実施</dt>\n\t\t\t\t<dd>全従業員を対象に、心の面からも豊かに仕事ができるよう、毎年ストレスチェックを実施しています。<br class=\"view_pc\">どんなことにストレスを感じているのかを分析し、従業員の健康を守るための健康経営を考える指針のひとつとして役立てています。また結果により、本人の希望で産業医面談も可能です。</dd>\n\t\t\t</dl>\n\t\t\t<dl>\n\t\t\t\t<dt><p class=\"number\">取り組み ＃03</p>適切な働き方の実現に<br class=\"view_pc\">向けた施策</dt>\n\t\t\t\t<dd><ul>\n\t\t\t\t\t<li><p class=\"txt_b\">有給休暇取得の推進</p>年間休暇の周知や、取得状況を把握して個別フォローし、積極的な有給取得を徹底しています。</li>\n\t\t\t\t\t<li><p class=\"txt_b\">ノー残業デー</p>\n\t\t\t\t\t\t毎週水曜日は「ノー残業デー」として、定時退社を促進しています。<br>適正な労働時間を管理し、長時間労働の削減にできるように努めています。\n\t\t\t\t\t</li>\n\t\t\t\t\t<li><p class=\"txt_b\">勤務間インターバル制度</p>\n\t\t\t\t\t\t勤務と勤務の間に一定時間以上の休息・睡眠時間を確保する制度です。\n\t\t\t\t\t</li>\n\t\t\t\t\t<li><p class=\"txt_b\">リフレッシュ休暇制度</p>\n\t\t\t\t\t\t勤続5年経過した節目の年に「9日間以上」の休暇を取得する制度です。<br>期間中2泊以上の旅行をした場合、補助金も支給されます。\n\t\t\t\t\t</li>\n\t\t\t\t</ul></dd>\n\t\t\t</dl>\n\t\t\t<dl class=\"dl_img\">\n\t\t\t\t<dt><p class=\"number\">取り組み ＃04</p>各種相談窓口</dt>\n\t\t\t\t<dd>\n\t\t\t\t\t<img src=\"images/img_counter.jpg\" alt=\"各種相談窓口\">\n\t\t\t\t\t<div class=\"box_r\">\n\t\t\t\t\t\t<p>従業員のための各種相談窓口を設置し、誰でも気軽に相談できる場を提供しています。<br>また、産業医と連携した外部相談窓口を用意し、会社を介さずにメールやLINEで本人から保健師等へ直接相談することができます。</p>\n\t\t\t\t\t\t<ul class=\"box_li\">\n\t\t\t\t\t\t\t<li>社外健康相談窓口</li>\n\t\t\t\t\t\t\t<li>女性専用健康相談窓口</li>\n\t\t\t\t\t\t\t<li>快適職場づくり委員会</li>\n\t\t\t\t\t\t</ul>\n\t\t\t\t\t</div>\n\t\t\t\t</dd>\n\t\t\t</dl>\n\t\t\t<dl class=\"dl_img\">\n\t\t\t\t<dt><p class=\"number\">取り組み ＃05</p>コミュニケーション促進</dt>\n\t\t\t\t<dd>\n\t\t\t\t\t<img src=\"images/img_fika.jpg\" alt=\"フィーカの様子\">\n\t\t\t\t\t<div class=\"box_r\">\n\t\t\t\t\t\tフィーカとは、友人や同僚と一緒にコーヒーを飲みながら一息つく、スウェーデンの文化的習慣です。<br>アビリブでは、従業員同士の交流の機会を増やすため、オンラインでコーヒーブレイクタイムを定期開催しています。\n\t\t\t\t\t</div>\n\t\t\t\t</dd>\n\t\t\t</dl>\n\t\t\t<dl>\n\t\t\t\t<dt><p class=\"number\">取り組み ＃06</p>健康リテラシーの向上</dt>\n\t\t\t\t<dd class=\"mt_img\">自身や家族の健康状態を意識し、もっと身近に感じてもらうため、月例で健康をテーマに情報発信しています。<br>生活に取り入れやすい内容を意識して、みなさんの健康のお手伝いをしています。</dd>\n\t\t\t</dl>\n\t\t</div>\n\n\t</div>\n    <div class=\"con_search\">\n        <div class=\"box_Joblist\">\n            <h3 class=\"st_search\">募集職種を絞り込む<span class=\"en\"><img src=\"https://www.ab-net.co.jp/recruit/images/st_search.png\" alt=\"search\"></span></h3>\n            <div class=\"box_Joblist_select\">\r\n        <form action=\"https://www.ab-net.co.jp/recruit/list/#form_search\" id=\"form_search\" method=\"get\" accept-charset=\"utf-8\">\r\n        <select name=\"status\" class=\"select_base box_s\">\r\n            <option value=\"\">採用形態</option>\r\n                        <option value=\"1\" >新卒\r\n            </option>\r\n            <option value=\"2\" >パート\r\n            </option>\r\n            <option value=\"9\" >中途\r\n            </option>\r\n        </select>\r\n        <select name=\"category\" class=\"select_base box_m\">\r\n            <option value=\"\">勤務地を選ぶ</option>\r\n        </select>\r\n        <select name=\"job\" class=\"select_base box_sl\">\r\n            <option value=\"\">カテゴリを選ぶ</option>\r\n        </select>\r\n        <select name=\"business\" class=\"select_base box_sl\">\r\n            <option value=\"\">事業を選ぶ</option>\r\n        </select>\r\n        <input type=\"submit\" name=\"\" value=\"検 索\" class=\"select_search over\"/>\r\n    </form>\r\n    <script type=\"text/javascript\">\r\n        $(document).ready(function () {\r\n            var type = $(\"select[name=status] option:selected\").val();\r\n            var category = '' ;\r\n            var job = '' ;\r\n            var business = '' ;\r\n            var alias = \"\";\r\n            getAjax(type, category, job, business, alias);\r\n\r\n            $('body').delegate('select[name=status]', 'change', function () {\r\n                category = $(\"select[name=category] option:selected\").val();\r\n                job = $(\"select[name=job] option:selected\").val();\r\n                business = $(\"select[name=business] option:selected\").val();\r\n                getAjax($(this).val(), category, job, business);\r\n            });\r\n            $('body').delegate('select[name=category]', 'change', function () {\r\n                type = $(\"select[name=status] option:selected\").val();\r\n                job = $(\"select[name=job] option:selected\").val();\r\n                business = $(\"select[name=business] option:selected\").val();\r\n                getAjax(type, $(this).val(), job, business);\r\n            });\r\n\r\n\r\n        });\r\n\r\n        function getAjax(type = 9, category = '', job = '', business = '', alias = '') {\r\n            $.ajax({\r\n                url: \"https://www.ab-net.co.jp/recruit/ajax_recruit.php\",\r\n                data: {\r\n                    type: type,\r\n                    category: category,\r\n                    job: job,\r\n                    business: business,\r\n                    alias: alias\r\n                },\r\n                type: \"GET\",\r\n                success: function (data) {\r\n                    $(\"select[name=category]\").html(data.category);\r\n                    $(\"select[name=job]\").html(data.job);\r\n                    $(\"select[name=business]\").html(data.business);\r\n                },\r\n                error: function (xhr, status) {\r\n                    alert(\"Sorry, there was a problem!\");\r\n                }\r\n            });\r\n        }\r\n    </script>\r\n</div>\r\n        </div>\n    </div>\n</div><!-- /#contents -->\n<div class=\"con_videobottom\">\n\t<div class=\"videobottom_media\">\n\t\t<div class=\"videobottom_mtop\">\n\t\t\t<div class=\"videobottom_mitemfi\">\n\t\t\t\t<h3 class=\"st_videobottom\"><span class=\"en\">ENTRY</span><span class=\"jp\">応募する</span></h3>\n\t\t\t\t<p class=\"videobottom_fdesc view_pc-tab\">お電話でのお問い合わせ</p>\n\t\t\t\t<p class=\"videobottom_tell view_pc-tab\"><a href=\"tel:0522628041\" class=\"tell\">052-228-7390</a></p>\n\t\t\t</div>\n\t\t\t<a class=\"videobottom_mitem over\" href=\"http://www.ab-net.co.jp/recruit/new/\">\n\t\t\t\t<span class=\"videobottom_desc\">新卒採用<br class=\"view_pc-tab\">ENTRY</span>\n\t\t\t</a>\n\t\t\t<a class=\"videobottom_mitem over\" href=\"http://www.ab-net.co.jp/recruit/career/\">\n\t\t\t\t<span class=\"videobottom_desc\">中途採用<br class=\"view_pc-tab\">ENTRY</span>\n\t\t\t</a>\n\t\t\t<a class=\"videobottom_mitem over\" href=\"http://www.ab-net.co.jp/recruit/fair/\">\n\t\t\t\t<span class=\"videobottom_desc\" style=\"line-height: 1.2;\">新卒対象<br>会社説明会</span>\n\t\t\t</a>\n\t\t\t<a class=\"videobottom_mitem over\" href=\"http://www.ab-net.co.jp/recruit/casual/\">\n\t\t\t\t<span class=\"videobottom_desc double\">カジュアル<br class=\"view_pc-tab\">面談</span>\n\t\t\t</a>\n\t\t</div>\n\t\t<p class=\"videobottom_pdesc view_pc