{"url":"http://www.e-kameyama.jp/contact2/","html":"<!DOCTYPE html>\r\n<html>\r\n<head>\r\n<meta charset=\"utf-8\">\r\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\r\n<meta name=\"format-detection\" content=\"telephone=no\">\r\n<title>亀山建設 採用サイト</title>\r\n<meta name=\"viewport\" content=\"width=device-width,minimum-scale=1\">\r\n<meta name=\"description\" itemprop=\"description\" content=\"\" />\r\n<meta name=\"keywords\" itemprop=\"keywords\" content=\"\" />\r\n<!--[if IE]>\r\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\r\n<![endif]-->\r\n<!--[if lt IE 9]>\r\n<script src=\"js/html5shiv-printshiv.js\"></script>\r\n<![endif]-->\r\n<link rel=\"shortcut icon\" href=\"/recruitment2/favicon.ico\">\r\n<link href=\"/recruitment2/css/style.css\" rel=\"stylesheet\" >\r\n</head>\r\n\r\n<body>\r\n<form>\r\n  <div id=\"wrapper\">\r    <!-- header -->\n    <div id=\"entry_form\">\n      <header id=\"header\" class=\"fixed\">\r\n       <div class=\"gnav_wrap\">\r\n        <div class=\"gnav\">\r\n          <h1><a href=\"/recruitment2/\"><img src=\"/recruitment2/images/logo_kameyama.png\" alt=\"亀山建設株式会社\"><span>採用サイト</span></a></h1>\r\n\t\t\t\t\t<div id=\"toggle\">\r\n\t\t\t\t\t\t<div class=\"trigger\">\r\n\t\t\t\t\t\t\t<span></span>\r\n\t\t\t\t\t\t\t<span></span>\r\n\t\t\t\t\t\t\t<span></span>\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t</div>\r\n          <nav class=\"toggle_wrap\">\r\n            <ul class=\"mainNav\">\r\n              <li><a href=\"/recruitment2/about/\" class=\"nav\">亀山建設を知る</a></li>\r\n              <li><a href=\"/recruitment2/jobcontent/\" class=\"nav\">仕事内容</a></li>\r\n              <li><a href=\"/recruitment2/internship/\" class=\"nav\">体験する</a></li>\r\n              <li><a href=\"/recruitment2/guideline/\" class=\"nav\">募集要項</a></li>\r\n              <li><a href=\"/contact2/\" class=\"nav_form\">職場体験・会社見学<br>\r\n                インターンシップ 申込み</a></li>\r\n            </ul>\r\n          </nav>\r\n        </div>\r\n       </div>\r\n      </header>\r      <main>\n      \t<article class=\"entry_form\">\n      \t\t<header class=\"head_page\"><h1>職場体験・会社見学・インターンシップ<br>\n申込みフォーム<span>ENTRY FORM</span></h1></header>\n      \t\t<div class=\"inner\">\n      \t\t\t<p class=\"intro\">下記フォームに必要事項をご記入いただき、「送信内容を確認」ボタンをクリックしてください。</p>\n      \t\t\t<div class=\"step01\">\n      \t\t\t  <ul class=\"step_flow\">\n      \t\t\t  \t<li><div><span>STEP1</span>入力</div></li>\n      \t\t\t  \t<li><div><span>STEP2</span>確認</div></li>\n      \t\t\t  \t<li><div><span>STEP3</span>完了</div></li>\n      \t\t\t  </ul>\n\t\t\t\t\t\t\t<table>\n\t\t\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t\t\t<th class=\"required\">お名前</th>\n\t\t\t\t\t\t\t\t\t<td><input type=\"text\" placeholder=\"山田 太郎\" required name=\"name\" value=\"\"></td>\n\t\t\t\t\t\t\t\t</tr>\n\t\t\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t\t\t<th class=\"required\">ふりがな</th>\n\t\t\t\t\t\t\t\t\t<td><input type=\"text\" placeholder=\"やまだ たろう\" required name=\"name_kana\" value=\"\"></td>\n\t\t\t\t\t\t\t\t</tr>\n\t\t\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t\t\t<th class=\"required\">性別</th>\n\t\t\t\t\t\t\t\t\t<td><label><input type=\"radio\" name=\"radio_sex\" value=\"male\" required >男性</label><label><input type=\"radio\" name=\"radio_sex\" value=\"female\" >女性</label></td>\n\t\t\t\t\t\t\t\t</tr>\n\t\t\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t\t\t<th class=\"required\">学校・職業</th>\n\t\t\t\t\t\t\t\t\t<td>\n\t\t\t\t\t\t\t\t\t                          <label><input type=\"radio\" name=\"radio_status\" value=\"1\" required >高校生</label>\n\t\t\t\t\t\t\t\t\t                          <label><input type=\"radio\" name=\"radio_status\" value=\"2\" required >高専生</label>\n\t\t\t\t\t\t\t\t\t                          <label><input type=\"radio\" name=\"radio_status\" value=\"3\" required >大学（院）生</label>\n\t\t\t\t\t\t\t\t\t                          <label><input type=\"radio\" name=\"radio_status\" value=\"4\" required >社会人</label>\n\t\t\t\t\t\t\t\t\t                    </td>\n\t\t\t\t\t\t\t\t</tr>\n\t\t\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t\t\t<th>学校名</th>\n\t\t\t\t\t\t\t\t\t<td><input type=\"text\" placeholder=\"××××高等専門学校\" name=\"school_name\" value=\"\"></td>\n\t\t\t\t\t\t\t\t</tr>\n\t\t\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t\t\t<th class=\"required\">参加したい体験</th>\n\t\t\t\t\t\t\t\t\t<td>\n                                            <label><input type=\"radio\" name=\"radio_experience\" value=\"1\" required >職場体験</label>\n                                            <label><input type=\"radio\" name=\"radio_experience\" value=\"2\" required >会社見学</label>\n                                            <label><input type=\"radio\" name=\"radio_experience\" value=\"3\" required >インターンシップ（7日間）</label>\n                                            <label><input type=\"radio\" name=\"radio_experience\" value=\"4\" required >インターンシップ（14日間）</label>\n                    \t\t\t\t\t\t\t\t\t<p class=\"note\">※インターンシップは、高専生・大学（院）生のみ選択できます。なお、申込期限は7/31までです。<br>※社会人の方は会社見学のみ選択できます。</p></td>\n\t\t\t\t\t\t\t\t</tr>\n\t\t\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t\t\t<th class=\"required\">電話番号</th>\n\t\t\t\t\t\t\t\t\t<td><input type=\"tel\" placeholder=\"123-4567-7890\" required name=\"tel\" value=\"\"></td>\n\t\t\t\t\t\t\t\t</tr>\n\t\t\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t\t\t<th class=\"required\">メールアドレス</th>\n\t\t\t\t\t\t\t\t\t<td><input type=\"email\" placeholder=\"xxxxxx@xxxx（半角英数）\" required name=\"email\" value=\"\"></td>\t</tr>\n\t\t\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t\t\t<th class=\"required\">メールアドレス（確認）</th>\n\t\t\t\t\t\t\t\t\t<td><input type=\"email\" placeholder=\"xxxxxx@xxxx（半角英数）\" required name=\"email_confirm\" value=\"\">\n\t\t\t\t\t\t\t\t\t<p class=\"note\">※確認のため再度入力してください。</p></td>\n\t\t\t\t\t\t\t\t</tr>\n\t\t\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t\t\t<th>備考</th>\n\t\t\t\t\t\t\t\t\t<td><textarea placeholder=\"ご意見・ご質問等ありましたらご記入ください\" name=\"opinion\"></textarea></td>\n\t\t\t\t\t\t\t\t</tr>\n\t\t\t\t\t\t\t</table>\n    \t\t\t\t\t<div class=\"blk_agreement\">\n    \t\t\t\t\t\t<label><input type=\"checkbox\" required name=\"agreement\" value=\"1\">\n    \t\t\t\t\t\t<a href=\"/profile/privacy-policy/\" target=\"_blank\">個人情報保護方針</a> <img src=\"/recruitment2/images/multitask.png\" alt=\"\">  に同意する</label>\n    \t\t\t\t\t</div>\n     \t\t\t\t\t<div class=\"form_btns\">\n\t\t\t\t\t\t\t\t<input type=\"reset\" class=\"btn_reset\"><button type=\"submit\" class=\"btn_next\" id=\"btn_next\">送信内容を確認</button>\n     \t\t\t\t\t</div>\n                    <input type=\"hidden\" name=\"cd\" value=\"\">\n\n      \t\t\t</div>\n\t\t\t\t\t</div>\n      \t</article>\n      </main>\n\n\n    </div>\n\r\n    <!-- footer -->\r\n    <footer id=\"footer\">\r\n      <div class=\"sitemap\">\r\n        <div class=\"inner\">\r\n          <ul>\r\n            <li><a href=\"/recruitment2/\">採用サイト トップ</a></li>\r\n            <li><a href=\"/recruitment2/about/\">亀山建設を知る</a>\r\n              <ul>\r\n                <li><a href=\"/recruitment2/about/?id=about01\">高レベルな建築技術</a></li>\r\n                <li><a href=\"/recruitment2/about/?id=about02\">設計・施工の一貫</a></li>\r\n                <li><a href=\"/recruitment2/about/?id=about03\">亀山建設の人材育成</a></li>\r\n              </ul>\r\n            </li>\r\n\t\t\t\t\t</ul>\r\n\t\t\t\t  <ul>\r\n            <li><a href=\"/recruitment2/jobcontent/\">仕事内容</a>\r\n              <ul>\r\n                <li><a href=\"/recruitment2/jobcontent/?id=job01\">大工（宮大工）</a></li>\r\n                <li><a href=\"/recruitment2/jobcontent/?id=job02\">施工管理士</a></li>\r\n                <li><a href=\"/recruitment2/jobcontent/?id=job03\">設計士</a></li>\r\n              </ul>\r\n            </li>\r\n\t\t\t\t\t</ul>\r\n          <ul>\r\n            <li><a href=\"/recruitment2/internship/\">体験する</a></li>\r\n            <li><a href=\"/recruitment2/guideline/\">募集要項</a></li>\r\n            <li><a href=\"/contact2/\">申し込みフォーム</a></li>\r\n\t\t\t\t\t</ul>\r\n          <ul>\r\n            <li><a href=\"/profile/privacy-policy/\">個人情報保護方針</a></li>\r\n            <li><a href=\"http://www.e-kameyama.jp/\" target=\"_blank\">亀山建設ホーム</a></li>\r\n          </ul>\r\n        </div>\r\n      </div>\r\n      <div class=\"inner\">\r\n        <p class=\"copyright\">&copy;KAMEYAMA CONSTRUCTION Co.,Ltd. All Rights Reserved.</p>\r\n      </div>\r\n    </footer>\r\n\r\n</div>\r\n</form>\r\n\r\n<!-- pagetop -->\r\n<div id=\"pageTop\"><a href=\"#wrapper\"> </a></div>\r\n\r\n<!-- jQuery -->\r\n<script src=\"http://ajax.googleapis.com/ajax/libs/jquery/1.7/jquery.min.js\"></script>\r\n<script src=\"/recruitment2/js/common.js\"></script>\r  <script type=\"text/javascript\" src=\"/common/js/contact2.js\"></script>\n  <script language='javascript'>\n  var mode = \"\";\n  var form_default = JSON.parse('{\"intern\":{\"status\":2,\"experience\":3,\"other\":\"all\"},\"corp\":{\"status\":1,\"experience\":1,\"other\":\"2\"},\"job\":{\"status\":1,\"experience\":2,\"other\":\"1\"}}');\n  var form_associate_st = JSON.parse('{\"1\":[\"corp\",\"job\"],\"2\":[\"intern\"],\"3\":[\"intern\"],\"4\":[\"corp\"]}');\n\n  function toggleEx(checkedVal, process) {\n    var toggleMode = form_associate_st[checkedVal];\n\n    if (toggleMode == undefined || toggleMode == '') {\n      return false;\n    }\n\n    if (process == undefined) {\n      $('input[name=\"radio_experience\"]').attr({'disabled' : true, 'checked' : false});\n    } else {\n      $('input[name=\"radio_experience\"]').attr({'disabled' : true});\n    }\n\n    for (var key in toggleMode) {\n      $('input[name=\"radio_experience\"]').each(function(){\n        if ($(this).val() == form_default[toggleMode[key]].experience && $('input[name=\"radio_experience\"]:checked')) {\n          if (process == undefined) {\n            $(this).attr({'checked' : true, 'disabled' : false});\n          } else {\n            $(this).attr({'disabled' : false});\n          }\n        }\n        if ($(this).val() == form_default[toggleMode[key]].other || form_default[toggleMode[key]].other == 'all') {\n          $(this).attr({'disabled' : false});\n        }\n      });\n    }\n  }\n\n  $(function(){\n    $('input[name=\"radio_status\"]').each(function(){\n      $(this).click(function(){toggleEx($(this).val());});\n    });\n\n    if ($('input[name=\"radio_status\"]:checked').val() != '') {\n      toggleEx($('input[name=\"radio_status\"]:checked').val(), mode == '' ? 'update' : undefined);\n    }\n  });\n  </script>\n</body>\n</html>","finalUrl":"http://www.e-kameyama.jp/contact2/","rendered":false,"_cachedAt":"2026-06-22T20:04:40.240Z"}