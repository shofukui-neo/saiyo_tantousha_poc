lass=\"footer__t__st__ls__bd__ls\">\r\n                      <li><a href=\"culture.html\"><span>企業文化</span></a></li>\r\n                      <li><a href=\"illword.html\"><span>アイル語</span></a></li>\r\n                    </ul>\r\n                  </div>\r\n                </li>\r\n              </ul>\r\n            </div>\r\n            <div class=\"footer__t__st\">\r\n              <ul class=\"footer__t__st__ls\">\r\n                <li>\r\n                  <div class=\"footer__t__st__ls__hd\"><a href=\"business.html\"><span class=\"c-navText\"><span class=\"__en\">BUSINESS</span><span class=\"__ja\">仕事を知る</span></span></a></div>\r\n                  <div class=\"footer__t__st__ls__bd\">\r\n                    <ul class=\"footer__t__st__ls__bd__ls\">\r\n                      <li><a href=\"business.html\"><span>ビジネスモデル</span></a></li>\r\n                      <li><a href=\"job.html\"><span>職種紹介</span></a></li>\r\n                    </ul>\r\n                  </div>\r\n                </li>\r\n              </ul>\r\n            </div>\r\n            <div class=\"footer__t__st\">\r\n              <ul class=\"footer__t__st__ls\">\r\n                <li>\r\n                  <div class=\"footer__t__st__ls__hd\"><a href=\"member.html\"><span class=\"c-navText\"><span class=\"__en\">MEMBER</span><span class=\"__ja\">人を知る</span></span></a></div>\r\n                  <div class=\"footer__t__st__ls__bd\">\r\n                    <ul class=\"footer__t__st__ls__bd__ls\">\r\n                      <li><a href=\"member.html\"><span>社員紹介</span></a></li>\r\n                      <li><a href=\"interview/index.html\"><span>若手社員の声</span></a></li>\r\n                    </ul>\r\n                  </div>\r\n                </li>\r\n              </ul>\r\n            </div>\r\n            <div class=\"footer__t__st\">\r\n              <ul class=\"footer__t__st__ls\">\r\n                <li>\r\n                  <div class=\"footer__t__st__ls__hd\"><a href=\"requirements.html\"><span class=\"c-navText\"><span class=\"__en\">RECRUIT</span><span class=\"__ja\">採用情報</span></span></a></div>\r\n                  <div class=\"footer__t__st__ls__bd\">\r\n                    <ul class=\"footer__t__st__ls__bd__ls\">\r\n                      <li><a href=\"requirements.html\"><span>募集要項</span></a></li>\r\n                      <li><a href=\"education.html\"><span>教育・評価制度</span></a></li>\r\n                      <li><a href=\"welfare.html\"><span>福利厚生</span></a></li>\r\n                      <li><a href=\"faq.html\"><span>採用FAQ</span></a></li>\r\n                    </ul>\r\n                  </div>\r\n                </li>\r\n              </ul>\r\n            </div>\r\n            <div class=\"footer__t__st\">\r\n              <ul class=\"footer__t__st__ls\">\r\n                <li>\r\n                  <div class=\"footer__t__st__ls__hd\"><a href=\"company.html\"><span class=\"c-navText\"><span class=\"__en\">COMPANY</span><span class=\"__ja\">会社概要</span></span></a></div>\r\n                </li>\r\n              </ul>\r\n            </div>\r\n            <div class=\"footer__t__st\">\r\n              <ul class=\"footer__t__st__ls\">\r\n                <li>\r\n                  <div class=\"footer__t__st__ls__hd\"><a href=\"https://www.ill.co.jp/recruit/entry_select.html\"><span class=\"c-navText\"><span class=\"__en\">ENTRY</span><span class=\"__ja\">エントリー</span></span></a></div>\r\n                </li>\r\n              </ul>\r\n            </div>\r\n          </nav>\r\n          <a href=\"https://www.ill.co.jp/\" class=\"page-link\"><img src=\"images/corporate.png\" alt=\"株式会社アイルコーポレートサイト\"></a>\r\n\t\t\t          <a href=\"https://www.ill.co.jp/recruit/internship/\" class=\"page-link\"><img src=\"images/intern.png\" alt=\"株式会社アイルインターン情報サイト\"></a>\r\n\t\t  </div>\r\n      </div>\r\n    </nav>\r\n    <div class=\"g-nav-bg\"></div>\r\n  </div>\r\n  <!--スマホヘッダー終了--> \r\n</header>\r\n<section class=\"top\">\r\n  <button class=\"entry_btn\">\r\n  <div class=\"entry_btn_in\">\r\n  <span class=\"h__en\"><a href=\"\" class=\"in-the-page\">ENTRY</a></span><span class=\"subtitle\">エントリー</span>\r\n  </div>\r\n  </button>\r\n</section>\r\n<div id=\"member_lower\">\r\n\t<section class=\"main main_top bg__w\">\r\n\t\t<div class=\"main_cont\">\r\n            <h2 class=\"title_area\">\r\n\t\t\t\t<span class=\"subtitle__en\">MEMBER</span>\r\n\t\t\t\t<span class=\"subtitle_member\">社員紹介</span>\r\n\t\t\t</h2>\r\n\t\t\t\r\n            <section class=\"member__grid\">\r\n                <div class=\"member_visual\">\r\n                    <img src=\"images/member/member01_01.jpg\" alt=\"ITソリューション営業\">\r\n                </div>\r\n                <div class=\"member_title\">\r\n                    <h3><span>「あの時に出会えて本当に良かった」</span><br><span>という声が嬉しい。</span></h3>\r\n                        <ul>\r\n                            <li>ITソリューション営業</li>\r\n                            <li>Tetsuya. B.</li>\r\n                            <li>工学部 卒業</li>\r\n                        </ul>\r\n                </div>\r\n            </section>\r\n            \r\n            <section class=\"member_work bg__b\">\r\n                <h4>私の仕事内容</h4>\r\n                <p>主にファッション業界のお客様をターゲットとした、基幹業務システムの提案営業を行う販売課のマネージャーをしています。常に相手の立場に立ち、お客様それぞれが抱える課題やニーズに応じた最適のソリューションを考えていきます。\r\n                </p>\r\n            </section>\r\n            \r\n\t\t</div>\r\n\t</section>\r\n \r\n\t<section class=\"main bg__b\">\r\n\t\t<div class=\"main_cont\">\r\n            <section class=\"member_Box\">\r\n                <h5 class=\"cont_title\"><span class=\"h__en\">WORK</span>仕事のやりがい</h5>\r\n                <p>導入後、お客様の業務効率が大幅に向上したという声を頂いた時は本当に嬉しいです。\r\n「あの時に出会えて本当に良かった」などと仰ってくださること もあります。この仕事をしていて本当に良かったと思える瞬間です。システム導入となると数百万円～数千万円単位のプロジェクトだけに、お客様にとっては大きな決断。正解の無いものに対して、期待をされて契約してくださるのですから、コスト以上の結果をお客様に提供できないといけません。\r\n現在はマネージメント側の立場なので、課員の成長を実感出来た時が一番嬉しいです。介入してしまえば早く解決に持っていける事も、勇気をもって任せる事が出来るかどうかがポイントと思って取り組んでいます。</p>\r\n            </section>\r\n            \r\n            <section class=\"member_Box\">\r\n                <h5 class=\"cont_title\"><span class=\"h__en\">DREAM</span>私の夢・キャリアプラン</h5>\r\n                <p>ファッション業界のシステム会社と言えばイコール「アイル」といった会社になりたいし、その中心人物として活躍していきたいです。一瞬で場の空気をパッと明るくするような存在感のある人間になりたいです。</p>\r\n            </section>\r\n            \r\n            <figure class=\"member_Photo\"><img src=\"images/member/member01_02.jpg\" alt=\"ITソリューション営業の仕事風景\"><img src=\"images/member/member01_03.jpg\" alt=\"ITソリューション営業の仕事風景\"></figure>\r\n            \r\n            <section class=\"member_Box\">\r\n                <h5 class=\"cont_title\"><span class=\"h__en\">REFRESH</span>プライベート</h5>\r\n                <p>息子がまだ小さいので、週末はひたすら一緒に遊んでいます。</p>\r\n            </section>\r\n            \r\n            <section class=\"member_Box mgn__top140\">\r\n                <h5 class=\"box_title\"><span class=\"yell\">応援メッセージ</span></h5>\r\n                <div class=\"member_face\"><img src=\"images/member/member01_04.png\" alt=\"ITソリューション営業からの応援メッセージ\"></div>\r\n                <p>営業職をはじめてから実感していることですが、世の中には膨大な数の会社があり、大勢の人がいます。仕事を通し、学生時代の自分の価値観がいかに視野の狭いものだったかを痛感しましたね。皆さんも、自分の価値観にとらわれて限界をつくったりせず、視野を大きく広げて就職活動に臨んでください。学部や専攻とは畑違いの分野でも、適職は数多くあると思います。いろいろな企業を見て回りながら、適職を見つけましょう。</p>\r\n            </section>\r\n            \r\n            <section class=\"member_Box\">\r\n                <h5 class=\"cont_title\"><span class=\"h__en\">SCHEDULE</span>ある１日のスケジュール</h5>\r\n                <table class=\"member_schedule_table\">\r\n                   <tbody>\r\n                        <tr>\r\n                            <th class=\"sales_color\">08:30</th>\r\n                            <td>出社</td>\r\n                        </tr>\r\n                        <tr>\r\n                            <th class=\"sales_color\">09:00</th>\r\n                            <td>朝礼、チームミーティング</td>\r\n                        </tr>\r\n                        <tr>\r\n                            <th class=\"sales_color\">10:30</th>\r\n                            <td>商談同行</td>\r\n                        </tr>\r\n                        <tr>\r\n                            <th class=\"sales_color\">11:45</th>\r\n                            <td>昼休み</td>\r\n                        </tr>\r\n                        <tr>\r\n                            <th class=\"sales_color\">13:00</th>\r\n                            <td>商談同行</td>\r\n                        </tr>\r\n                        <tr>\r\n                            <th class=\"sales_color\">15:00</th>\r\n                            <td>お客様訪問</td>\r\n                        </tr>\r\n                        <tr>\r\n                            <th class=\"sales_color\">16:30</th>\r\n                            <td>帰社・課員の商談案件相談、提案資料作成・業務処理、メールチェック</td>\r\n                        </tr>\r\n                        <tr>\r\n                            <th class=\"sales_color\">19:00</th>\r\n                            <td>退社</td>\r\n                        </tr>\r\n                    </tbody>\r\n                </table>\r\n                \r\n                \r\n            </section>\r\n            \r\n\t\t</div>\r\n\t</section>\r\n    \r\n</div>\r\n<section class=\"cv\">\r\n    <div class=\"cv_bg\">\r\n      <div class=\"cv_bg_in\">\r\n        <h3>あなたも一緒に、思い切りバットを振っていこう。</h3>\r\n        <div class=\"cv_in_box\">\r\n          <div class=\"cv_in\">\r\n            <p class=\"cv_e_p\">新卒採用</p>\r\n            <a href=\"https://ill-recruit.snar.jp/index.aspx\" class=\"cv_btn\">\r\n            <div class=\"cv_box\">\r\n              <div class=\"cv_btn_in\"> <span class=\"h__en\">ENTRY</span><span class=\"subtitle\">新卒採用</span></div>\r\n              <p>新卒採用向け<br>\r\n                エントリーはこちら</p>\r\n              <span class=\"cv_arrow\"></span> </div>\r\n            </a> </div>\r\n          <div class=\"cv_in\">\r\n            <p class=\"cv_c_p\">キャリア採用</p>\r\n            <a href=\"entry_career.html\" class=\"cv_btn btn_gr\">\r\n            <div class=\"cv_box\">\r\n              <div