{"url":"https://www.ooc.co.jp/recruit/job","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n<head>\n  <!-- Global site tag (gtag.js) - Google Analytics -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=UA-6049077-1\"></script>\n<script>\n    window.dataLayer = window.dataLayer || [];\n\n    function gtag() {\n        dataLayer.push(arguments);\n    }\n    gtag('js', new Date());\n\n    gtag('config', 'UA-6049077-1');\n</script>\n<!-- Google Analytics end -->\n<meta charset=\"UTF-8\">\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<meta name=\"format-detection\" content=\"email=no,telephone=no,address=no\">\n<link rel=\"icon\" type=\"image/png\" href=\"\">\n<link rel=\"apple-touch-icon\" href=\"\" sizes=\"180x180\">\n<link rel=\"shortcut icon\" href=\"\" type=\"image/x-icon\">\n<meta name=\"robots\" content=\"noindex,nofollow\" />\n\n  <title>仕事を知る｜採用情報｜大阪有機化学工業株式会社</title>\n  <link rel=\"shortcut icon\" href=\"/common/img/favicon.ico\" />\n  <meta name=\"description\" content=\"大阪有機化学工業株式会社は塗料・インキ・粘接着剤・電子材料部材等の樹脂原料として幅広い産業分野で使用されるアクリル酸エステルを研究開発しています。\" />\n  <meta name=\"keywords\" content=\"新卒採用,就職,求人\" />\n  <meta name=\"format-detection\" content=\"telephone=no\">\n\n  <!-- OGP -->\n  <meta property=\"og:title\" content=\"大阪有機化学工業株式会社 : アクリル酸エステルの総合メーカー\" />\n  <meta property=\"og:type\" content=\"company\" />\n  <meta property=\"og:url\" content=\"https://www.ooc.co.jp\" />\n  <meta property=\"og:image\" content=\"/common/img/thumb_fb.gif\" />\n  <meta property=\"og:site_name\" content=\"大阪有機化学工業株式会社\" />\n  <meta property=\"og:description\" content=\"大阪有機化学工業株式会社は塗料・インキ・粘接着剤・電子材料部材等の樹脂原料として幅広い産業分野で使用されるアクリル酸エステルを研究開発しています。\" />\n\n  <!-- Twitter OGP -->\n  <meta name=\"twitter:card\" content=\"summary_large_image\" />\n\n  <!-- css,js -->\n  <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n<link href=\"https://fonts.googleapis.com/css2?family=Barlow:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&family=Noto+Sans+JP:wght@100..900&family=Zen+Old+Mincho:wght@400;500;600;700;900&display=swap\" rel=\"stylesheet\">\n<link rel=\"stylesheet\" href=\"../css/style.css\">\n<script src=\"../js/common.js\"></script>\n<link rel=\"stylesheet\" href=\"../css/swiper-bundle.css\">\n<link rel=\"stylesheet\" href=\"../css/aos.css\">\n<script src=\"../js/swiper-bundle.min.js\"></script>\n<script src=\"../js/aos.js\"></script>\n</head>\n<body>\n  \n<header class=\"l-header p-header\">\n  <div class=\"p-header_logo\"><a href=\"../\"><img src=\"../img/logo.png\" alt=\"「特殊アクリル酸エステル」のリーディングカンパニー 大阪有機化学工業株式会社\"></a></div>\n  <nav id=\"nav\" class=\"p-nav\">\n    <ul class=\"p-nav_list\">\n      <li class=\"p-nav_item\"><a href=\"../\">採用トップ</a></li>\n      <li class=\"p-nav_item\">\n        <a class=\"arrow\" href=\"../mind\">想いを知る</a>\n        <ul class=\"p-dropdown-content\">\n          <li><a href=\"../mind/\">コーナートップ</a></li>\n          <li><a href=\"../mind/ooc_way\">プロジェクトストーリー</a></li>\n          <li><a href=\"../mind/interview/01\">社員インタビュー</a></li>\n        </ul>\n      </li>\n      <li class=\"p-nav_item\">\n        <a class=\"arrow\" href=\"../job\">仕事を知る</a>\n        <ul class=\"p-dropdown-content\">\n          <li><a href=\"../job/\">コーナートップ</a></li>\n          <li><a href=\"../job/welfare\">福利厚生・教育制度</a></li>\n          <li><a href=\"../job/challenge\">挑戦しやすい風土</a></li>\n          <li><a href=\"../job/role_model\">キャリアロールモデル</a></li>\n        </ul>\n      </li>\n      <li class=\"p-nav_item\"><a href=\"../about\">OOCを知る</a></li>\n      <li class=\"p-nav_item\">\n        <a class=\"arrow\" href=\"../employment\">採用情報</a>\n        <ul class=\"p-dropdown-content\">\n          <li><a href=\"../employment/\">コーナートップ</a></li>\n          <li><a href=\"../employment/new/01/\">新卒採用</a></li>\n          <li><a href=\"../employment/career/01/\">キャリア採用</a></li>\n        </ul>\n      </li>\n    </ul>\n    <div class=\"p-nav_entry\"><a href=\"../entry\">ENTRY</a></div>\n    <div class=\"p-nav_sub_link\">\n      <ul>\n        <li><a href=\"/\" target=\"_blank\">コーポレートサイト</a></li>\n        <li><a href=\"/privacy\">個人情報保護方針</a></li>\n      </ul>\n    </div>\n  </nav>\n  <div class=\"p-hamburger\" id=\"hamburger\">\n    <div class=\"p-hamburger__line\"></div>\n    <div class=\"p-hamburger__line\"></div>\n    <div class=\"p-hamburger__line\"></div>\n  </div>\n</header>\n  <main>\n    <div class=\"p-second_fv --job\">\n      <div class=\"l-container01\">\n        <div class=\"c-ttl03\" data-aos=\"fade-up\">\n          <h1 class=\"c-ttl03_main\">仕事を知る</h1>\n          <span class=\"c-ttl03_sub\">FIND OUT ABOUT OOC JOB</span>\n        </div>\n      </div>\n    </div>\n    <div class=\"l-container01\">\n      <div class=\"p-text02\" data-aos=\"fade-up\">\n        <p>OOCの魅力のひとつが前向きに仕事に取り組める環境。<br>それを支える各種制度や企業風土について詳しく紹介します。</p>\n      </div>\n    </div>\n    <div class=\"p-job_list\">\n      <div class=\"l-container01\">\n        <div class=\"p-list02\">\n          <div class=\"p-list02_item --direction\" data-aos=\"fade-up\">\n            <div class=\"p-list02_item_col\">\n              <span class=\"p-list02_item_number\">-01</span>\n              <h2 class=\"c-ttl09\">複利厚生・教育制度</h2>\n              <div class=\"p-text01\">\n                <p>休日・休暇、手当・補助、育児支援などに関する制度を充実させているほか、キャリアステージにあわせた研修を積極的に実施しています。</p>\n              </div>\n              <div class=\"p-btn\">\n                <div class=\"c-btn01\"><a href=\"welfare\">詳しく見る</a></div>\n              </div>\n            </div>\n            <div class=\"p-list02_item_col\">\n              <img src=\"img/img01.jpg\" alt=\"複利厚生・教育制度\">\n            </div>\n          </div>\n          <div class=\"p-list02_item --direction\" data-aos=\"fade-up\">\n            <div class=\"p-list02_item_col\">\n              <span class=\"p-list02_item_number\">-02</span>\n              <h2 class=\"c-ttl09\">挑戦しやすい風土</h2>\n              <div class=\"p-text01\">\n                <p>会社全体に挑戦を歓迎・応援する雰囲気があり、くわえて、人事評価や研修をはじめとした挑戦を促進する制度もあります。</p>\n              </div>\n              <div class=\"p-btn\">\n                <div class=\"c-btn01\"><a href=\"challenge\">詳しく見る</a></div>\n              </div>\n            </div>\n            <div class=\"p-list02_item_col\">\n              <img src=\"img/img02.jpg\" alt=\"挑戦しやすい風土\">\n            </div>\n          </div>\n          <div class=\"p-list02_item --direction\" data-aos=\"fade-up\">\n            <div class=\"p-list02_item_col\">\n              <span class=\"p-list02_item_number\">-03</span>\n              <h2 class=\"c-ttl09\">キャリアロールモデル</h2>\n              <div class=\"p-text01\">\n                <p>入社後から現在までのキャリアパスについて、具体的なエピソードを交えつつ先輩たちに語ってもらいました。</p>\n              </div>\n              <div class=\"p-btn\">\n                <div class=\"c-btn01\"><a href=\"role_model\">詳しく見る</a></div>\n              </div>\n            </div>\n            <div class=\"p-list02_item_col\">\n              <img src=\"img/img03.jpg\" alt=\"キャリアロールモデル\">\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n    <div class=\"p-information\">\n      <div class=\"l-container01\">\n        <div class=\"p-btn p-information_entry\">\n          <div class=\"c-btn01\"><a href=\"../entry\">エントリーはこちら</a></div>\n        </div>\n        <div class=\"p-mynavi\">\n  <a href=\"https://job.mynavi.jp/27/pc/search/corp58074/outline.html\" target=\"_blank\">\n    <img src=\"../img/mynavi_2027.svg\" alt=\"マイナビ\">\n  </a>\n</div>      </div>\n    </div>\n  </main>\n  <div class=\"p-page_top js-page_top\"><span>PAGE TOP</span></div>\n<footer class=\"p-footer\">\n  <div class=\"p-footer_row\">\n    <div class=\"p-footer_col\">\n      <p class=\"p-footer_name\">大阪有機化学工業株式会社</p>\n      <ul>\n        <li><a href=\"/\" target=\"_blank\">コーポレートサイト</a></li>\n        <li><a href=\"/privacy\">個人情報保護方針</a></li>\n      </ul>\n    </div>\n    <div class=\"p-footer_col\">\n      <p class=\"p-footer_c_right\">© OSAKA ORGANIC CHEMICAL INDUSTRY</p>\n    </div>\n  </div>\n</footer>\n<script>\n  window.onload = function () {\n      AOS.init({\n          duration: 800,\n          once: true,\n      })\n  }\n</script>\n</body>\n</html>\n","finalUrl":"https://www.ooc.co.jp/recruit/job/","rendered":false,"_cachedAt":"2026-06-22T17:26:00.971Z"}