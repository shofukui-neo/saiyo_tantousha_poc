rounded  shadow text-center\" id=\"feature\">\n<div class=\"row align-items-center\">\n<div class=\"col-lg-6 p-md-3\">\n<div id=\"carouselControls\" class=\"carousel slide\" data-bs-ride=\"carousel\">\n<div class=\"carousel-indicators\">\n<button type=\"button\" data-bs-target=\"#carouselControls\" data-bs-slide-to=\"0\" class=\"active\" aria-current=\"true\" aria-label=\"Slide 1\"></button>\n<button type=\"button\" data-bs-target=\"#carouselControls\" data-bs-slide-to=\"1\" aria-label=\"Slide 2\"></button>\n<button type=\"button\" data-bs-target=\"#carouselControls\" data-bs-slide-to=\"2\" aria-label=\"Slide 3\"></button>\n<button type=\"button\" data-bs-target=\"#carouselControls\" data-bs-slide-to=\"3\" aria-label=\"Slide 4\"></button>\n<button type=\"button\" data-bs-target=\"#carouselControls\" data-bs-slide-to=\"4\" aria-label=\"Slide 5\"></button>\n</div>\n<div class=\"carousel-inner\">\n<div class=\"carousel-item active\"><img src=\"images/p06.jpg\" class=\"img-fluid rounded\" alt=\"システム開発体験\"></div>\n<div class=\"carousel-item\"><img src=\"images/p02.jpg\" class=\"img-fluid rounded\" alt=\"プラスワン\"></div>\n<div class=\"carousel-item\"><img src=\"images/p03.jpg\" class=\"img-fluid rounded\" alt=\"職場見学\"></div>\n<div class=\"carousel-item\"><img src=\"images/p04.jpg\" class=\"img-fluid rounded\" alt=\"オンライン\"></div>\n<div class=\"carousel-item\"><img src=\"images/p18.jpg\" class=\"img-fluid rounded\" alt=\"就業体験\"></div>\n</div>\n<button class=\"carousel-control-prev\" type=\"button\" data-bs-target=\"#carouselControls\" data-bs-slide=\"prev\">\n<span class=\"carousel-control-prev-icon\" aria-hidden=\"true\"></span>\n<span class=\"visually-hidden\">Previous</span>\n</button>\n<button class=\"carousel-control-next\" type=\"button\" data-bs-target=\"#carouselControls\" data-bs-slide=\"next\">\n<span class=\"carousel-control-next-icon\" aria-hidden=\"true\"></span>\n<span class=\"visually-hidden\">Next</span>\n</button>\n</div><!-- /.carousel slide -->\n</div>\n<div class=\"col-lg-6\">\n<p class=\"mt-3\"><span class=\"display-4 fw-bold\">選べるコース</span></p>\n<p><span class=\"display-6 fw-bold\">座談会や職場見学も</span></p>\n<p class=\"lh-lg\">文理は不問です。<br>ITの知識やスキルも問いません。<br>\n履歴書、エントリーシートの提出も不要。</p>\n<p>お好きなコースに参加できます。</p>\n<a class=\"btn btn-outline-info shadow-sm\" href=\"#check\" role=\"button\"><i class=\"bi bi-arrow-right-short\"></i>自分に合ったコースを探す</a>\n</div>\n</div><!-- /.row -->\n</div><!-- /.bg -->\n</div><!-- /.container -->\n</div><!-- /#header -->\n<!-- InstanceEndEditable -->\n<!-- InstanceBeginEditable name=\"content\" -->\n<div class=\"bg-slant bg-info py-5\">\n<div class=\"display-1 text-end text-white d-none d-sm-block title\">//<span class=\"fw-bold\">Flow</span></div>\n<div class=\"container py-5 text-center\" id=\"flow\">\n<h2 class=\"mb-5 h1 text-white\">参加までの流れ</h2>\n<div class=\"row text-white\">\n<div class=\"col-lg-4 px-4\">\n<i class=\"bi bi-door-open display-1\"></i>\n<h3 class=\"fw-bold pt-3\">エントリー</h3>\n<p class=\"small\">Step1</p>\n<p class=\"text-start lh-lg\">マイナビからエントリーします。コースごとに定員がございますので、早めの申し込みがおすすめです。</p>\n</div>\n<div class=\"col-lg-4 px-4\">\n<i class=\"bi bi-card-checklist display-1\"></i>\n<h3 class=\"fw-bold pt-3\">準備</h3>\n<p class=\"small\">Step2</p>\n<p class=\"text-start lh-lg\">スケジュールや持ち物などを確認します。当日は、学校に通う時のような過ごしやすい服装でOKです。</p>\n</div>\n<div class=\"col-lg-4 px-4\">\n<i class=\"bi bi-laptop display-1\"></i>\n<h3 class=\"fw-bold pt-3\">参加</h3>\n<p class=\"small\">Step3</p>\n<p class=\"text-start lh-lg\">インターンシップを通して、KCSやIT業界・事業概要について知識を深めましょう！</p>\n</div>\n</div><!-- /.row -->\n<p class=\"pt-4\"><a class=\"btn btn-lg btn-outline-light shadow-sm\" href=\"../entry/internship.html\" target=\"_blank\" role=\"button\"><i class=\"bi bi-arrow-right-short\"></i>まずはマイナビからエントリー</a></p>\n</div><!-- /.container -->\n</div><!-- /.gb-slant -->\n\n<div class=\"display-1 text-end text-info d-none d-sm-block title\">//<span class=\"fw-bold\">Calendar</span></div>\n<div class=\"container py-5 text-center\" id=\"calendar\">\n<h2 class=\"mb-5 h1\"><span class=\"h6\">参加できる日から選ぶ</span><br>実施日カレンダー</h2>\n<p>夏季や冬季など、長期休暇中に開催しています。</p>\n<div class=\"google-cal py-3\">\n<iframe src=\"https://calendar.google.com/calendar/embed?height=600&wkst=1&bgcolor=%23ffffff&ctz=Asia%2FTokyo&showTitle=0&showTz=0&showCalendars=0&showPrint=0&src=MGxiMHU2bzcwbnJnZDM0NTl2Yzk0NDIxZjBAZ3JvdXAuY2FsZW5kYXIuZ29vZ2xlLmNvbQ&src=amEuamFwYW5lc2UjaG9saWRheUBncm91cC52LmNhbGVuZGFyLmdvb2dsZS5jb20&color=%23009688&color=%23F6BF26\" style=\"border-width:0\" width=\"950\" height=\"600\" frameborder=\"0\" scrolling=\"no\"></iframe>\n</div><!-- /.google-cal -->\n</div><!-- /.container -->\n\n<div class=\"bg-slant bg-info py-5\">\n<div class=\"display-1 text-end text-white d-none d-sm-block title\">//<span class=\"fw-bold\">Course</span></div>\n<div class=\"container pb-5 text-center\">\n<div class=\"row my-5\">\n<div class=\"col-6\"><a class=\"btn btn-outline-light shadow-sm d-grid h-100 p-3\" href=\"#1day\" role=\"button\">IT業界の仕事を知ろう<span class=\"fs-1\">1day仕事体験</span></a></div>\n<div class=\"col-6\"><a class=\"btn btn-outline-light shadow-sm d-grid h-100 p-3\" href=\"#2days\" role=\"button\">ITを学んでみる<span class=\"fs-1\">2daysインターンシップ</span></a></div>\n</div><!-- /.row -->\n<h2 class=\"mb-5 h1 text-white\">開催の様子</h2>\n<div class=\"row row-cols-1 row-cols-md-2 text-start kcs_topics photos g-4\">\n\n<div class=\"col\">\n<a href=\"../../journal/2025/09_internship_2days.html\">\n<div class=\"card h-100 shadow\">\n<img src=\"../../journal/2025/images/09_internship_2days_p28.webp\" class=\"card-img-top\" alt=\"2025年夏、2daysインターンシップ開催\n（対面・オンライン・プラスワン）\">\n<div class=\"card-body\">\n<h3 class=\"card-title h5\">2025年夏、2daysインターンシップ開催<small>（対面・オンライン・プラスワン）</small></h3>\n<p class=\"card-text link-primary\">今年は新コース「バンキングシステム開発体験」が登場！</p>\n<small class=\"text-secondary\">2025年8月～9月</small>\n</div>\n</div>\n</a>\n</div>\n\n<div class=\"col\">\n<a href=\"../../journal/2025/09_internship_1day.html\">\n<div class=\"card h-100 shadow\">\n<img src=\"../../journal/2025/images/09_internship_1day_p06.webp\" class=\"card-img-top\" alt=\"2025年夏、1day仕事体験（IT業界の仕事を知ろう）開催（オンライン・対面）\">\n<div class=\"card-body\">\n<h3 class=\"card-title h5\">2025年夏、1day仕事体験（IT業界の仕事を知ろう）開催<small>（オンライン・対面）</small></h3>\n<p class=\"card-text link-primary\">今年も8月と9月に、大学生を対象とした夏季インターンシップを開催しました。</p>\n<small class=\"text-secondary\">2025年8月～9月</small>\n</div>\n</div>\n</a>\n</div>\n\n</div><!-- /.row -->\n<div class=\"row mt-5\" id=\"check\">\n<div class=\"col-md-3\">\n<p class=\"mb-0 text-white\">\\ コース診断 /</p>\n<p><img src=\"../images/index_p02.png\" class=\"img-fluid\" alt=\"なな\"></p>\n</div>\n<div class=\"col-md-9 lh-lg\">\n<p class=\"pt-2 text-white \">迷える学生へのKCSインターンシップ診断！<br>はい/いいえを答えるだけで、あなたにピッタリのコースが分かります。</p>\n<div class=\"card py-3 mb-5\">\n<div class=\"card-body text-center\">\n<h2 class=\"text-info\">コース診断スタート</h2>\n<div id=\"question_area\" class=\"h3 mt-4\">\n<div id=\"q1\" class=\"txt_display\">プログラミング経験がありますか？</div>\n<div id=\"q2\" class=\"txt_hide\">IT企業は一日中プログラミングをしているイメージですか？</div>\n<div id=\"q3\" class=\"txt_hide\">新技術やデータ分析に興味がありますか？</div>\n<div id=\"q4\" class=\"txt_hide\">KCSのシステム開発を体験してみたいですか？</div>\n</div>\n<div id=\"result_area\" class=\"txt_hide\">\n<p class=\"mb-0\">あなたにおすすめのインターンシップコースは</p>\n<div id=\"a1\" class=\"txt_hide\">\n<h3 class=\"text-info\"><span class=\"display-4 fw-bold\">データ分析・Power BI体験</span></h3>\n<p><span class=\"mark p-1\"><a href=\"../entry/internship.html\" target=\"_blank\">エントリー</a>をお待ちしています！</span></p>\n</div>\n<div id=\"a2\" class=\"txt_hide\">\n<h3 class=\"text-info\"><span class=\"display-4 fw-bold\">Office-PRISMシステム開発体験</span></h3>\n<p><span class=\"mark p-1\"><a href=\"../entry/internship.html\" target=\"_blank\">エントリー</a>をお待ちしています！</span></p>\n</div>\n<div id=\"a3\" class=\"txt_hide\">\n<h3 class=\"text-info\"><span class=\"display-4 fw-bold\">Webアプリケーション開発体験</span></h3>\n<p><span class=\"mark p-1\"><a href=\"../entry/internship.html\" target=\"_blank\">エントリー</a>をお待ちしています！</span></p>\n</div>\n<a href=\"javaScript:OnAgainClick();\">最初に戻る</a>\n</div>\n<div id=\"btn_area\" class=\"txt_display\">\n<a href=\"javascript:OnYesClick();\" class=\"btn btn-info btn-lg me-2\" id=\"btn_yes\"><i class=\"bi bi-arrow-right-short\"></i>はい</a>\n<a href=\"javascript:OnNoClick();\" class=\"btn btn-outline-info btn-sm\" id=\"btn_no\"><i class=\"bi bi-arrow-right-short\"></i>いいえ</a>\n</div>\n</div>\n</div><!-- /.card -->\n</div>\n</div><!-- /.row -->\n</div><!-- /.container -->\n</div><!-- /.gb-slant -->\n\n<div class=\"display-1 text-end text-info d-none d-sm-block title\">//<span class=\"fw-bold\">1day</span></div>\n<div class=\"container py-5 text-center\" id=\"1day\">\n<h2 class=\"mb-5 h1\"><span class=\"h6\">IT業界の仕事を知ろう</span><br>1day仕事体験</h2>\n<ul class=\"list-inline py-3\">\n<li class=\"list-inline-item pb-2\"><span class=\"text-info small\">\\ 短期集中 /</span><div class=\"rounded-circle bg-info text-white p-3 fs-1\"><strong>1日で<br>学べる</strong></div></li>\n<li class=\"list-inline-item pb-2\"><span class=\"text-info small\">\\ 疑問点を解消 /</span><div class=\"rounded-circle bg-info text-white p-3 fs-1\"><strong>質問<br>できる</strong></div></li>\n<li class=\"list-inline-item pb-2\"><span class=\"text-info small\">\\早期選考チャンス/</span><div class=\"rounded-circle bg-info text-white p-3 fs-1\"><strong>次に<br>繋がる</strong></div></li>\n</ul>\n<ul class=\"nav nav-tabs nav-justified mt-5\" id=\"myTab\" role=\"tablist\">\n<li class=\"nav-item\" role=\"presentation\">\n<button class=\"nav-link active p-3\" id=\"home-tab\" data-bs-toggle=\"tab\" data-bs-target=\"#home\" type=\"button\" role=\"tab\" aria-controls=\"home\" aria-selected=\"true\">\nオンラインコース\n</button>\n</li>\n<li class=\"nav-item\" role=\"presentation\">\n<button class=\"nav-link p-3\" id=\"profile-tab\" data-bs-toggle=\"tab\" data-bs-target=\"#profile\" type=\"button\" role=\"tab\" aria-controls=\"profile\" aria-selected=\"false\">\n対面コース\n</button>\n</li>\n</ul>\n<div class=\"tab-content bg-white border-end border-bottom border-start pt-5 px-5 pb-2\" id=\"myTabContent\">\n<div class=\"tab-pane fade show active\" id=\"home\" role=\"tabpanel\" aria-labelledby=\"home-tab\">\n<div class=\"row\">\n<div class=\"col-md-4\"><p><img src=\"images/p05.jpg\" class=\"img-fluid rounded mb-1\" alt=\"IT業界の説明・事業概要\"><br>IT業界の説明・事業概要</p></div>\n<div class=\"col-md-4\"><p><img src=\"images/p01.jpg\" class=\"img-fluid rounded mb-1\" alt=\"先輩社員との座談会\"><br>先輩社員との座談会</p></div>\n<div class=\"col-md-4\"><p><img src=\"images/p07.jpg\" class=\"img-fluid rounded mb-1 border\" alt=\"就活の進め方\"><br>就活の進め方</p></div>\n</div><!-- /.row -->\n</div>\n<div class=\"tab-pane fade\" id=\"profile\" role=\"tabpanel\" aria-labelledby=\"profile-tab\">\n<div class=\"row\">\n<div class=\"col-md-4\"><p><img src=\"images/p08.jpg\" class=\"img-fluid rounded mb-1\" alt=\"IT業界の説明・事業概要\"><br>IT業界の説明・事業概要</p></div>\n<div class=\"col-md-4\"><p><img src=\"images/p06.jpg\" class=\"img-fluid rounded mb-1\" alt=\"システム開発体験\"><br>システム開発体験</p></div>\n<div class=\"col-md-4\"><p><img src=\"images/p03.jpg\" class=\"img-fluid rounded mb-1\" alt=\"職場見学\"><br>職場見学</p></div>\n</div><!-- /.row -->\n</div>\n</div><!-- /.tab-content -->\n<p class=\"mt-5\"><a class=\"btn btn-lg btn-outline-info shadow-sm\" href=\"../../journal/2025/09_internship_1day.html\" role=\"button\"><i class=\"bi bi-arrow-right-short\"></i>1day仕事体験を予習してみる</a></p>\n</div><!-- /.container -->\n\n<div class=\"bg-slant bg-info py-5\">\n<div class=\"display-1 text-end text-white d-none d-sm-block title\">//<span class=\"fw-bold\">Voice</span></div>\n<div class=\"container-xl py-5 text-center\" id=\"voice\">\n<h2 class=\"mb-5 h1 text-white\"><span class=\"h6\">参加者インタビュー</span><br>1day仕事体験がきっかけで入社</h2>\n<div class=\"row align-items-center text-white\">\n<div class=\"col-md-5 px-5\"><p><img src=\"images/p10.jpg\" class=\"img-fluid rounded\" alt=\"Tさん（2021年4月入社）\"></p></div>\n<div class=\"col-md-7 text-start my-5 lh-lg\">\n<figure>\n<blockquote class=\"blockquote\"><p class=\"display-3 text-start text-white pb-3\">“<span class=\"fw-bold\">スキルを活かす将来像をイメージできた</span>”</p></blockquote>\n<figcaption class=\"blockquote-footer text-white\">Tさん<small>（2021年4月入社）</small></figcaption>\n</figure>\n<div class=\"bg-white rounded p-4 text-secondary\">\n<p>私は、大学で学んだプログラミングスキルを活かした職に就きたかったので、業界は絞って参加しました。会社説明以外にグループワークなどのワークがあるか、そこで何を吸収できるかということを基準のひとつにしていました。同期の中には、興味のない分野も一通り参加してみたという強者もいましたよ！<br>\n数多くのインターンシップがありますが、どれだけ参加したらよいかに正解がなく、大事なのは参加する目的や学ぶ姿勢だと思います。</p>\n<p>インターンシップに参加してみて、先輩社員が自分の仕事に誇りと責任感を持ち、かつ楽しそうに仕事の話をしていたのが印象に残っています。そして<span class=\"mark fw-bold\">自分の身に付けたスキルを活かせられること、会社の安定性、長く働けそうな社内の雰囲気も分かりました。</span>また、人事担当者からの学生目線での就活の進め方のアドバイスがあり、自分の社会像をイメージできたのも、ほかの会社にはない珍しい内容で役立ちました。<span class=\"mark fw-bold\">基本的なビジネスマナーも学べた</span>ことも良かったです。</p>\n<p>どんな社会人になりたいのか？何を大切にこれからの人生を歩みたいのか？こんな質問を自分に問いかけながら、インターンシップに参加すると良いと思います。何から始めたらよいのかわからなかった私は、一つの企業だけをみるのではなく、<span class=\"mark fw-bold\">複数の企業同士を比較しながら、業界理解を深め、同時にそこで働く自分の将来像を作っていきました。</span>スーッと、イメージできる会社とそうでない会社がありました。その後は、実際にイメージできた会社の選考に進む、という就活をしました。</p>\n<p class=\"mb-0\">オンラインでは社内の雰囲気が分かりづらいと思いますので、社員さんと話す機会があれば、<span class=\"mark fw-bold\">気になることを一つ一つ潰していく感じで積極的に質問したほうがいい</span>と思います。KCSはどんな質問でも丁寧に対応してくれましたよ！</p>\n</div>\n</div>\n<!--\n<div class=\"col-md-5 px-5 order-md-2\"><p><img src=\"images/\" class=\"img-fluid rounded\" alt=\"\"></p></div>\n<div class=\"col-md-7 text-start my-5 lh-lg\">\n<figure>\n<blockquote class=\"blockquote\"><p class=\"display-3 text-start text-white pb-3\">“<span class=\"fw-bold\"></span>”</p></blockquote>\n<figcaption class=\"blockquote-footer text-white\"><small></small></figcaption>\n</figure>\n<div class=\"bg-white rounded p-4 text-secondary\">\n<p></p>\n</div>\n</div>\n-->\n</div><!-- /.row -->\n</div><!-- /.container -->\n</div><!-- /.gb-slant -->\n\n<div class=\"display-1 text-end text-info d-none d-sm-block title\">//<span class=\"fw-bold\">2days</span></div>\n<div class=\"container-fluid py-5 text-center\" id=\"2days\">\n<h2 class=\"mb-5 h1\"><span class=\"h6\">ITを学んでみる</span><br>2daysインターンシップ</h2>\n<ul class=\"list-inline py-3\">\n<li class=\"list-inline-item pb-2\"><span class=\"text-info small\">\\ じっくり /</span><div class=\"rounded-circle bg-info text-white p-3 fs-1\"><strong>仕事を<br>体験</strong></div></li>\n<li class=\"list-inline-item pb-2\"><span class=\"text-info small\">\\ 内部に潜入 /</span><div class=\"rounded-circle bg-info text-white p-3 fs-1\"><strong>会社を<br>知る</strong></div></li>\n<li class=\"list-inline-item pb-2\"><span class=\"text-info small\">\\早期選考チャンス/</span><div class=\"rounded-circle bg-info text-white p-3 fs-1\"><strong>次に<br>繋がる</strong></div></li>\n</ul>\n<div class=\"row row-cols-1 row-cols-sm-2 row-cols-lg-3 row-cols-xxl-5 justify-content-center text-start kcs_topics photos py-5 g-4\">\n<div class=\"col\">\n<div class=\"card h-100 shadow\">\n<img src=\"images/p11.png\" alt=\"システム開発体験\" class=\"card-img-top\">\n<div class=\"card-body pt-3\">\n<h3 class=\"h4 py-2\"><span class=\"badge rounded-pill bg-danger me-2\"><small>Aコース</small></span>システム開発体験</h3>\n<p class=\"card-text\">主力商品<a href=\"../../prism/office/index.html\">Office-PRISM</a>を使った仕事体験。身近な問題・課題を解決しよう。<br>\nプログラミング技術が無くても参加できる・仕事に必要なスキルが分かる、グループディスカッション多めのコース。<br>\n<span class=\"text-black-50 small\">#プログラマー志望</span></p>\n</div>\n</div>\n</div>\n<div class=\"col\">\n<div class=\"card h-100 shadow\">\n<img src=\"images/p12.png\" alt=\"ホームページ企画体験\" class=\"card-img-top\">\n<div class=\"card-body pt-3\">\n<h3 class=\"h4 py-2\"><span class=\"badge rounded-pill bg-success me-2\"><small>Bコース</small></span>ホームページ企画体験</h3>\n<p class=\"card-text\">デジタルマーケティングの5つのポイントをレクチャー。<br>\nプロダクトには理由がある。<br>\nターゲットに狙いを定めて、心のこもったコンテンツを企画してみるコース。<br>\n<span class=\"text-black-50 small\">#文系もウェルカム</span></p>\n</div>\n</div>\n</div>\n<div class=\"col\">\n<div class=\"card h-100 shadow\">\n<img src=\"images/p13.jpg\" alt=\"データ分析・Power BI体験\" class=\"card-img-top\">\n<div class=\"card-body pt-3\">\n<h3 class=\"h4 py-2\"><span class=\"badge rounded-pill bg-primary me-2\"><small>Cコース</small></span>データ分析・Power BI体験</h3>\n<p class=\"card-text\">ちょっと難しいけど、使えるようになると楽しい！<br>\n<a href=\"../../journal/2022/02_bi_project.html\">BIツール</a>で分析。<br>\n先輩が優しくレクチャーします。<br>\n<a href=\"../../products/index.html#new_technology\">新技術</a>についても知れちゃうおトクな2本立てのコース。<br>\n<span class=\"text-black-50 small\">#研究職向け</span></p>\n</div>\n</div>\n</div>\n<div class=\"col\">\n<div class=\"card h-100 shadow\">\n<img src=\"images/p19.png\" alt=\"Webアプリケーション開発体験\" class=\"card-img-top\">\n<div class=\"card-body pt-3\">\n<h3 class=\"h4 py-2\"><span class=\"badge rounded-pill bg-warning me-2\"><small>Dコース</small></span>Webアプリケーション開発体験</h3>\n<p class=\"card-text\">ローコードツールを使って、実際にアプリケーションを開発してみよう！<br>\n個人ワークとグループワークがあります。<br>\n使用するパソコンはこちらで用意します。<br>\n<span class=\"text-black-50 small\">#プログラミング</span></p>\n</div>\n</div>\n</div>\n<div class=\"col\">\n<div class=\"card h-100 shadow\">\n<img src=\"images/p22.webp\" alt=\"バンキングシステム開発体験\" class=\"card-img-top\">\n<div class=\"card-body pt-3\">\n<h3 class=\"h4 py-2\"><span class=\"badge rounded-pill bg-secondary me-2\"><small>Eコース</small></span>バンキングシステム開発体験</h3>\n<p class=\"card-text\">金融サービスの裏側を見てみよう！<br>\n銀行のシステムを熟知したKCSならではのコース。<br>\n銀行専用システムの操作体験やWebページ制作。<br>\n<span class=\"text-black-50 small\">#金融システム</span></p>\n</div>\n</div>\n</div>\n</div><!-- /.row -->\n<h3 class=\"h2\"><span class=\"badge rounded-pill bg-info me-2\">プラスワン2days</span></h3>\n<p>プラスワンコースの場合は、本社対面0.5日間＋オンラインもしくは対面2日間となります。</p>\n<div class=\"row pt-3\">\n<div class=\"col-md-4\">\n<p><img src=\"images/p14.jpg\" class=\"img-fluid rounded mb-1\" alt=\"IT業界の説明・事業概要\"><br><span class=\"badge rounded-pill bg-info me-2\"><small>プラスワン限定</small></span>IT業界の説明・事業概要</p>\n</div>\n<div class=\"col-md-4\">\n<p><img src=\"images/p15.jpg\" class=\"img-fluid rounded mb-1\" alt=\"先輩社員との交流\"><br><span class=\"badge rounded-pill bg-info me-2\"><small>プラスワン限定</small></span>先輩社員との交流</p>\n</div>\n<div class=\"col-md-4\">\n<p><img src=\"images/p16.jpg\" class=\"img-fluid rounded mb-1\" alt=\"職場見学\"><br><span class=\"badge rounded-pill bg-info me-2\"><small>プラスワン限定</small></span>職場見学</p>\n</div>\n</div>\n<p class=\"mt-5\"><a class=\"btn btn-lg btn-outline-info shadow-sm\" href=\"../../journal/2025/09_internship_2days.html\" role=\"button\"><i class=\"bi bi-arrow-right-short\"></i>2daysインターンシップを予習してみる</a></p>\n</div><!-- /.container -->\n\n<div class=\"bg-slant bg-info py-5\">\n<div class=\"display-1 text-end text-white d-none d-sm-block title\">//<span class=\"fw-bold\">Faq</span></div>\n<div class=\"container py-5 text-center\" id=\"faq\">\n<h2 class=\"mb-5 h1 text-white\"><span class=\"h6\">不安を解消</span><br>よくあるご質問と回答</h2>\n<div class=\"accordion\" id=\"accordionFaq\">\n<div class=\"accordion-item\">\n<h3 class=\"accordion-header\" id=\"headingOne\">\n<button class=\"accordion-button bg-light\" type=\"button\" data-bs-toggle=\"collapse\" data-bs-target=\"#collapseOne\" aria-expanded=\"true\" aria-controls=\"collapseOne\">「服装自由」ですが、本当に自由ですか？自由と言いつつ、実はスーツで参加ですか？</button>\n</h3>\n<div id=\"collapseOne\" class=\"accordion-collapse collapse show\" aria-labelledby=\"headingOne\" data-bs-parent=\"#accordionFaq\">\n<div class=\"accordion-body text-start ms-4\">\n<p>安心してください。KCSのインターンシップは本当に服装自由です！スーツでなくても大丈夫です。<br>\n私服、学校に通う時のような過ごしやすい服装でOKです。</p>\n<p>ちなみに、執務室はオフィスカジュアル！このような服装で仕事しています。 </p>\n<div class=\"row\">\n<div class=\"col\"><p><img src=\"images/p20.jpg\" class=\"img-fluid rounded\" alt=\"オフィスカジュアル\"></p></div>\n<div class=\"col\"><p><img src=\"images/p21.jpg\" class=\"img-fluid rounded\" alt=\"オフィスカジュアル\"></p></div>\n</div><!-- /.row -->\n</div>\n</div>\n</div><!-- /.accordion-item -->\n<div class=\"accordion-item\">\n<h3 class=\"accordion-header\" id=\"headingSeven\">\n<button class=\"accordion-button bg-light collapsed\" type=\"button\" data-bs-toggle=\"collapse\" data-bs-target=\"#collapseSeven\" aria-expanded=\"false\" aria-controls=\"collapseSeven\">どんな方が参加できますか？参加までの流れを教えてください。</button>\n</h3>\n<div id=\"collapseSeven\" class=\"accordion-collapse collapse\" aria-labelledby=\"headingSeven\" data-bs-parent=\"#accordionFaq\">\n<div class=\"accordion-body text-start ms-4\">\n<p class=\"mb-0\">4年生大学・大学院・短期大学・専門学校に在学中の方がご参加いただけます。</p>\n<ul class=\"list-unstyled\">\n<li class=\"list01 small\">※ITの知識やスキルは問いません。</li>\n<li class=\"list01 small\">※履歴書、エントリーシートの提出は不要です。</li>\n</ul>\n<p><a href=\"../entry/internship.html\" target=\"_blank\">マイナビからエントリーをお願いします</a>。<br>\nエントリーしてくださった方には、詳細等につきまして、マイナビ内のメールよりご連絡します。 </p>\n</div>\n</div>\n</div><!-- /.accordion-item -->\n<div class=\"accordion-item\">\n<h3 class=\"accordion-header\" id=\"headingFive\">\n<button class=\"accordion-button bg-light collapsed\" type=\"button\" data-bs-toggle=\"collapse\" data-bs-target=\"#collapseFive\" aria-expanded=\"false\" aria-controls=\"collapseFive\">オンラインでも参加できますか？</button>\n</h3>\n<div id=\"collapseFive\" class=\"accordion-collapse collapse\" aria-labelledby=\"headingFive\" data-bs-parent=\"#accordionFaq\">\n<div class=\"accordion-body text-start ms-4\">\n<p>はい。参加できます。<br>\nオンラインで実施するコースと、対面で実施するコースの両方があります。 </p>\n</div>\n</div>\n</div><!-- /.accordion-item -->\n<div class=\"accordion-item\">\n<h3 class=\"accordion-header\" id=\"headingSix\">\n<button class=\"accordion-button bg-light collapsed\" type=\"button\" data-bs-toggle=\"collapse\" data-bs-target=\"#collapseSix\" aria-expanded=\"false\" aria-controls=\"collapseSix\">文理どちらでも参加できますか？</button>\n</h3>\n<div id=\"collapseSix\" class=\"accordion-collapse collapse\" aria-labelledby=\"headingSix\" data-bs-parent=\"#accordionFaq\">\n<div class=\"accordion-body text-start ms-4\">\n<p>はい。参加できます。<br>\n「IT」と言うと理系のイメージが強いですが、文系の学部から参加される方も多いです。 </p>\n</div>\n</div>\n</div><!-- /.accordion-item -->\n<div class=\"accordion-item\">\n<h3 class=\"accordion-header\" id=\"headingTwo\">\n<button class=\"accordion-button bg-light collapsed\" type=\"button\" data-bs-toggle=\"collapse\" data-bs-target=\"#collapseTwo\" aria-expanded=\"false\" aria-controls=\"collapseTwo\">持ち物は何ですか？</button>\n</h3>\n<div id=\"collapseTwo\" class=\"accordion-collapse collapse\" aria-labelledby=\"headingTwo\" data-bs-parent=\"#accordionFaq\">\n<div class=\"accordion-body text-start ms-4\">\n<p>筆記用具、ノートをご用意ください。<br>オンラインコースの場合は、PC（カメラ・マイク）、<a href=\"https://www.zoom.com/ja/products/virtual-meetings/\" target=\"_blank\">Zoom<small>（無料）</small></a>のインストール、安定した通信環境の用意をお願いいたします。</p>\n</div>\n</div>\n</div><!-- /.accordion-item -->\n<div class=\"accordion-item\">\n<h3 class=\"accordion-header\" id=\"headingThree\">\n<button class=\"accordion-button bg-light collapsed\" type=\"button\" data-bs-toggle=\"collapse\" data-bs-target=\"#collapseThree\" aria-expanded=\"false\" aria-controls=\"collapseThree\">開催場所はどこですか？</button>\n</h3>\n<div id=\"collapseThree\" class=\"accordion-collapse collapse\" aria-labelledby=\"headingThree\" data-bs-parent=\"#accordionFaq\">\n<div class=\"accordion-body text-start ms-4\">\n<p>対面コースの場合、<a href=\"https://www.google.com/maps/place/%E5%85%B1%E7%AB%8B%E3%82%B3%E3%83%B3%E3%83%94%E3%83%A5%E3%83%BC%E3%82%BF%E3%83%BC%E3%82%B5%E3%83%BC%E3%83%93%E3%82%B9%EF%BC%88%E6%A0%AA%EF%BC%89/@35.368052,136.638932,16z/data=!4m5!3m4!1s0x0:0x1e699882f6d44caa!8m2!3d35.368067!4d136.638944?hl=ja&shorturl=1\" target=\"_blank\">共立コンピューターサービス株式会社 本社</a>にて開催します。<br>\n<small>JR大垣駅下車、名阪近鉄バス3番のりば（ソフトピアジャパン行き）より15分、ソフトピアジャパンバス停より徒歩2分、ソフトピアセンタービル北西に本社ビルがあります。</small></p>\n<p>オンラインコースの場合は、ご自宅などから参加いただけます。<br>\n<small>※オンラインコースの配信は、本社から行います。</small></p>\n</div>\n</div>\n</div><!-- /.accordion-item -->\n<div class=\"accordion-item\">\n<h3 class=\"accordion-header\" id=\"headingFour\">\n<button class=\"accordion-button bg-light collapsed\" type=\"button\" data-bs-toggle=\"collapse\" data-bs-target=\"#collapseFour\" aria-expanded=\"false\" aria-controls=\"collapseFour\">選考と関係はありますか？お礼状、お礼メールは必要ですか？</button>\n</h3>\n<div id=\"collapseFour\" class=\"accordion-collapse collapse\" aria-labelledby=\"headingFour\" data-bs-parent=\"#accordionFaq\">\n<div class=\"accordion-body text-start ms-4\">\n<p>選考基準には関係しませんが、メールアドレスを記載いただけましたら次回説明会の案内をメールでご連絡します。<br>\n例えば、昨年は就活直前対策セミナーなどのインターンシップ参加者限定イベントを開催しました。 </p>\n<p>お礼状などは必要ありません。お気持ちだけで十分です。 </p>\n</div>\n</div>\n</div><!-- /.accordion-item -->\n</div><!-- /.accordion -->\n<p class=\"pt-5 text-white\">マイナビからも、各種コースの詳細や案内をご覧いただけます。</p>\n<p><a class=\"btn btn-outline-light shadow-sm\" href=\"../entry/internship.html\" target=\"_blank\" role=\"button\"><i class=\"bi bi-arrow-right-short\"></i>マイナビへのリンクはこちら</a></p>\n</div><!-- /.container -->\n</div>\n\n<div class=\"display-1 text-end text-info d-none d-sm-block title\">//<span class=\"fw-bold\">Staff</span></div>\n<div class=\"container py-5 text-center\" id=\"staff\">\n<h2 class=\"mb-5 h1\"><span class=\"h6\">KCS人事担当より</span><br>私たちはあなたを応援しています</h2>\n<p class=\"pb-4\">業務の話だけでなく学生と社員とが繋がるイベントになるよう、毎年インターンシップを企画しています。<br>\n不安があれば何でもお答えしますので、困っていること、聞きたいことがあれば、いつでも聞いてくださいね。</p>\n<p><img src=\"images/p17.jpg\" class=\"img-fluid rounded mb-1\" alt=\"KCS人事担当\"></p>\n</div><!-- /.container -->\n\n<div id=\"contact\">\n<div class=\"container py-5 text-center \">\n<h2 class=\"text-white fw-bold\">インターンシップへの参加</h2>\n<p class=\"text-white pt-5\">都合の良い日程やコースをお選びいただけます。</p>\n<ul class=\"list-inline pt-4\">\n<li class=\"list-inline-item pb-3\"><a class=\"btn btn-info btn-lg shadow-sm\" href=\"../entry/internship.html\" role=\"button\" target=\"_blank\"><i class=\"bi bi-arrow-right-short\"></i>インターンシップの詳細を見る</a></li>\n</ul><!-- /.list-inline -->\n</div><!-- /.container -->\n</div><!-- /.contact -->\n<!-- InstanceEndEditable -->\n<footer class=\"bg-info\">\n<div id=\"footer\"></div>\n</footer>\n<script src=\"https://code.jquery.com/jquery-3.7.1.min.js\" integrity=\"sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo=\" crossorigin=\"anonymous\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js\" integrity=\"sha384-geWF76RCwLtnZ8qwWowPQNguL3RmwHVBC9FhGdlKrxdiJJigb/j/68SIy3Te4Bkz\" crossorigin=\"anonymous\"></script>\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css\">\n<script src=\"https://cdnjs.cloudflare.com/ajax/libs/protonet-jquery.inview/1.1.2/jquery.inview.min.js\" integrity=\"sha512-D68mBFX2aQwVh2wV6uCDLmabIveaSQL3uVUo2Ze7VwxIeOcAd4C1/JagkVoObb/NLkYDrdvY3JHK1KOfenHVcA==\" crossorigin=\"anonymous\" referrerpolicy=\"no-referrer\"></script>\n<!-- InstanceBeginEditable name=\"added_js\" -->\n<script src=\"../js/default.js\"></script> \n<!-- InstanceEndEditable -->\n</body>\n<!-- InstanceEnd --></html>","finalUrl":"https://www.okb-kcs.co.jp/recruit/internship/index.html","rendered":false,"_cachedAt":"2026-06-23T23:11:19.838Z"}