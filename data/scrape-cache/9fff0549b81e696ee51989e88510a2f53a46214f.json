{"url":"https://www.okinawa.ccbc.co.jp/recruite/vision/","html":"<!doctype html>\n<html lang=\"ja\">\n<head>\n<!-- Google Tag Manager --> \n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n})(window,document,'script','dataLayer','GTM-K49Q3QS');</script> \n<!-- End Google Tag Manager -->\n<meta charset=\"UTF-8\">\n<title>企業ビジョン｜沖縄コカ･コーラボトリング採用情報</title>\n<meta name=\"description\" content=\"沖縄地域のコカ･コーラ採用情報サイト　リクルート情報　新規学卒　募集要項\">\n<meta name=\"keywords\" content=\"沖縄,コカ･コーラ,リクルート,大学卒,募集要項,募集要項\">\n<meta property=\"og:title\" content=\">企業ビジョン｜沖縄コカ･コーラボトリング採用情報\">\n<meta property=\"og:type\" content=\"website\" />\n<meta property=\"og:url\" content=\"http://www.okinawa.ccbc.co.jp/recruite/vision/\">\n<meta property=\"og:image\" content=\"http://www.okinawa.ccbc.co.jp/cmn/img/logo.gif\">\n<meta property=\"og:description\" content=\"未来へ受け継いでいこうワシタチムグクルに\">\n<meta property=\"og:site_name\" content=\"沖縄コカ･コーラボトリング採用情報\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1, maximum-scale=1\">\n<meta name=\"format-detection\" content=\"telephone=no\">\n<link rel=\"shortcut icon\" href=\"/favicon.ico\"/>\n<meta name=\"apple-mobile-web-app-title\" content=\"沖縄コカコーラ\">\n<link rel=\"apple-touch-icon\" sizes=\"192x192\" href=\"/cmn/touch-icon.png\">\n<link href=\"/recruite/css/style.css\" rel=\"stylesheet\" type=\"text/css\">\n<link href=\"style.css\" rel=\"stylesheet\" type=\"text/css\">\n<script\nsrc=\"https://code.jquery.com/jquery-2.2.4.min.js\"\nintegrity=\"sha256-BbhdlvQf/xTY9gja0Dq3HiwQF8LaCRTXxZKRutelT44=\"\ncrossorigin=\"anonymous\"></script>\n<script type=\"text/javascript\" src=\"/recruite/js/script.js\"></script>\n</head>\n<body>\n<!-- Google Tag Manager (noscript) -->\n<noscript>\n<iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-K49Q3QS\"\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe>\n</noscript>\n<!-- End Google Tag Manager (noscript) --> \n<!--loding-->\n<div id=\"loader\">\n  <div class=\"spinner\">\n    <div class=\"rect1\"></div>\n    <div class=\"rect2\"></div>\n    <div class=\"rect3\"></div>\n    <div class=\"rect4\"></div>\n    <div class=\"rect5\"></div>\n  </div>\n</div>\n<!--/loding-->\n<div id=\"wrapper\"> \n\n\n  <!--header--> \n  <header>\n<div id=\"header\">\n<div class=\"sitename\">\n<h1><a href=\"/recruite/\"><img src=\"/recruite/img/logo.svg\" alt=\"沖縄コカ･コーラボトリング採用情報\" class=\"logo\"/><span class=\"siteH1\"><span class=\"corp\">沖縄コカ･コーラボトリング</span>RECRUIT SITE</span></a></h1>\n</div>\n<div class=\"contactmenu\"><a href=\"/recruite/form/\" target=\"_blank\" class=\"en\">CONTACT<span class=\"icon-forward\"></span></a></div>\n<nav>\n<ul id=\"jetmenu\" class=\"jetmenu\">\n<li><a href=\"/recruite/message/\">\n<p>社長メッセージ</p>\n</a></li>\n<li><a href=\"/recruite/vision/\">\n<p>企業ビジョン</p>\n</a></li>\n<li><a href=\"/recruite/culture/\">\n<p>企業文化</p>\n</a></li>\n<li><a href=\"/recruite/carrier_plan/\">\n<p>教育・キャリアプラン</p>\n</a></li>\n<li><a href=\"javascript:void();\">\n<p>社員インタビュー<span class=\"icon-arrow-down\"></span></p>\n</a><!--row-->\n<div class=\"megamenu full-width\">\n<div class=\"row\">\n<div class=\"memint\">\n<div class=\"title mh\">\n<h5><span class=\"en\">Interview</span>社員インタビュー</h5>\n</div>\n<ul>\n<li><a href=\"/recruite/interview/marketing.html\">\n<p><img src=\"/recruite/img/cmn/men06.jpg\" alt=\"\"/></p>\n<p class=\"text1\">トレードマーケティング部</p>\n<p class=\"text2\">新垣 凜／與久田 藍香</p>\n</a></li>\n<li><a href=\"/recruite/interview/akamine.html\">\n<p><img src=\"/recruite/img/cmn/men07.jpg\" alt=\"\"/></p>\n<p class=\"text1\">浦添工場 製造二課</p>\n<p class=\"text2\">赤嶺 孝太</p>\n</li>\n<li></li>\n</ul>\n</div>\n<a></a></div>\n</div>\n<!--/row--></li>\n<li><a href=\"/recruite/guideline/\">\n<p>募集要項</p>\n</a></li>\n</ul>\n</nav>\n</div>\n</header>\n \n  <!--/header-->\n  <main> \n    <!--　メイン画像　-->\n    <div class=\"secondtitle\">\n      <h2><span class=\"en\">Corporate Vision</span>企業ビジョン</h2>\n    </div>\n    <!--　/ メイン画像　--> \n    \n    <!--　企業ビジョン　-->\n    <section class=\"section1\">\n      <div class=\"trg\"></div>\n      <div class=\"sec1width\">\n        <div class=\"read\">\n          <p>私たちの使命は世界ブランドのコカ･コーラ製品の製造・販売を通して、沖縄県の企業として地域に根ざし、<br class=\"pcbr\">\n            地域の発展に貢献することです。その想いと方向性を明文化した経営理念「ワシタチムググル」。</p>\n          <p>社員1人ひとりが経営理念を道標に、常に自覚と誇りを持ちながら日々歩んでいます。</p>\n        </div>\n        <!--経営理念-->\n        <div class=\"sec1t\">\n          <p><img src=\"img/rinen.gif\" alt=\"ワシタ　チム　グクル\"/></p>\n          <h2>私達の経営理念</h2>\n        </div>\n        <div class=\"rinen fadein\"><img src=\"img/visionimg.gif\" alt=\"お客様に満足を・地域社会と共に歩む・働きがいのある会社に\"/></div>\n        <!--/経営理念--><!--社是-->\n        <div class=\"sec1t\">\n          <h2>社是</h2>\n        </div>\n        <div class=\"shaze fadein\">\n          <p><img src=\"img/shaze.gif\" alt=\"誠を尽くす\"/></p>\n        </div>\n        <!--社是--><!--行動規範-->\n        <div class=\"sec1t\">\n          <h2>行動規範</h2>\n        </div>\n        <div class=\"kihan fadein\">\n          <ul>\n            <li>さわやかな挨拶をしよう</li>\n            <li>円滑なコミュニケーションをしよう</li>\n            <li>自己啓発をしよう</li>\n            <li>積極的にチャレンジしよう</li>\n            <li>問題意識を持って行動しよう</li>\n            <li>変化に素早く対応しよう</li>\n            <li>感謝の心で接しよう</li>\n          </ul>\n        </div>\n        <!--行動規範--><!--OUR　VISION-->\n        <div class=\"sec1t\">\n          <h2>OUR　VISION</h2>\n        </div>\n        <div class=\"vision fadein\">\n          <p>いつまでも私たちに関わる全ての人がHappyになれる、サステナブル・カンパニーを目指します。<br>\n            コカ･コーラブランドの使命を胸に、コカ･コーラ製品を通して私たちのあらゆるステークホルダー（お客様、地域の皆様、取引先の皆様、従業員）の満足度を高め、そして企業としての社会的責任も果たしながらともに成長していく、持続可能な企業を目指していきます。</p>\n        </div>\n        <div class=\"sisa fadein\"><img src=\"img/sisa.gif\" alt=\"\"/></div>\n        <div class=\"btns\">\n          <ul>\n            <li><a href=\"https://www.okinawa.ccbc.co.jp/contribution/\" target=\"_blank\">社会貢献活動<span class=\"icon-arrow-right\"> </span></a></li>\n            <li><a href=\"https://www.okinawa.ccbc.co.jp/environment/\" target=\"_blank\">環境への取り組み<span class=\"icon-arrow-right\"> </span></a></li>\n          </ul>\n        </div>\n        <!--OUR　VISION--> \n        \n      </div>\n    </section>\n    <!--　/企業ビジョン　--> \n    <!--　システム画像　-->\n    <div class=\"systemtitle\">\n      <h2><span class=\"en\">Coca‐Cola system</span>日本のコカ･コーラシステム</h2>\n    </div>\n    <!--　/ システム画像　--> <!--　システム　-->\n    <section class=\"section2\">\n      <div class=\"sec2width\">\n        <div class=\"read\">\n          <p>コカ･コーラシステムとは、原液の供給と製品の企画開発や広告などのマーケティング活動を行う日本コカ･コーラ株式会社と、製品の製造・販売を行うボトラー社、さらにその関連会社などで構成されています。</p>\n          <p>当社を含めた全国の各ボトラー社は、それぞれの工場で厳重な品質管理体制のもと、コカ･コーラ製品を日々製造し、お取引先の店舗や自動販売機を通してお客さまへ製品をお届けしています。<br>\n            また循環型社会の構築に貢献すべく、可能な限り資源を再利用するとともに、使用後はできるだけ付加価値の高い資源として再生させていくことに努めています。</p>\n        </div>\n        <div class=\"systemimage fadein\"><img src=\"img/system_pc.gif\" alt=\"コカ･コーラシステム\" class=\"pcimg\"/><img src=\"img/system_sp.gif\" alt=\"コカ･コーラシステム\" class=\"spimg\"/></div>\n        <!--ボトラー社-->\n        <div class=\"btor fadein\">\n          <h2>日本のボトラー社</h2>\n          <p><img src=\"img/map_pc.gif\" alt=\"\" class=\"pcimg\"/><img src=\"img/map_sp.gif\" alt=\"\" class=\"spimg\"/></p>\n        </div>\n        <!--ボトラー社--> \n        \n      </div>\n    </section>\n    <!--　/システム　--><!--　数字　-->\n    <div class=\"ccbcfata\">\n      <h2>数字で見る沖縄コカ･コーラボトリング</h2>\n      <div class=\"datalist\">\n        <ul>\n          <li>\n            <p class=\"datat\">平均残業時間</p>\n            <div class=\"databody\">\n              <p>月平均<span>15</span>時間</p>\n            </div>\n            <p class=\"genzai\">（2023年実績）</p>\n          </li>\n          <li>\n            <p class=\"datat\">平均有給取得日数</p>\n            <div class=\"databody\">\n              <p><span>13.7</span>日</p>\n            </div>\n            <p class=\"genzai\">（2023年実績）</p>\n          </li>\n          <li>\n            <p class=\"datat\">年間休日</p>\n            <div class=\"databody\">\n              <p><span>121</span>日</p>\n            </div>\n            <p class=\"genzai\">（2023年実績）</p>\n          </li>\n          <li>\n            <p class=\"datat\">平均年齢</p>\n            <div class=\"databody\">\n              <p><span>44</span>歳</p>\n            </div>\n            <p class=\"genzai\">（2024年6月現在）</p>\n          </li>\n          <li>\n            <p class=\"datat\">従業員数</p>\n            <div class=\"databody\">\n              <p><span>249</span>名</p>\n            </div>\n            <p class=\"genzai\">（2024年6月現在）</p>\n          </li>\n          <li>\n            <p class=\"datat\">女性比率</p>\n            <div class=\"databody\">\n              <p><span>21</span>%</p>\n            </div>\n            <p class=\"genzai\">（2024年6月現在）</p>\n          </li>\n          <li>\n            <p class=\"datat\">取引先軒数</p>\n            <div class=\"databody\">\n              <p><span>14,100</span>軒以上</p>\n            </div>\n            <p class=\"genzai\">（2024年4月時点）</p>\n          </li>\n          <li>\n            <p class=\"datat\">Coke自販機数（本島内）</p>\n            <div class=\"databody\">\n              <p>約<span>7,800</span>台</p>\n            </div>\n            <p class=\"genzai\">（2024年4月時点）</p>\n          </li>\n        </ul>\n      </div>\n    </div>\n    <!--　/数字　--> \n    \n    <!--　/ 企業文化　--> \n  </main>\n  <!--　お問い合わせ　-->\n<aside class=\"infoLink\">\n<article class=\"contact\">\n<div class=\"basewidth\"><div class=\"all_contact\"><a href=\"tel:0988775257\" target=\"_blank\" class=\"inqtel\">\n      <p><span class=\"icon-phone\"></span><span class=\"phone\"><strong>098-877-5257</strong><i>平日9:00～17:00</i></span><span class=\"icospc\"></span></p>\n      </a><a href=\"/recruite/guideline/\"  class=\"guideline\"><p><span class=\"icon-file\"></span><span>募集要項</span><span class=\"icospc\"></span></p></a><a href=\"/recruite/form/\" target=\"_blank\"  class=\"inqmail\">\n      <p><span class=\"icon-envelope\"></span><span>採用に関するお問い合わせ</span></p>\n      </a></div>\n</div>\n</article>\n</aside>\n<!--　/ お問い合わせ　--> \n<!--footer-->\n<footer>\n<div id=\"footer\">\n<div class=\"logo\"><a href=\"/recruite/\"><img src=\"/recruite/img/logo.svg\" alt=\"沖縄コカ･コーラボトリング リクルート\"/><span class=\"siteH1\"><span class=\"corp\">沖縄コカ･コーラボトリング</span>RECRUIT SITE</span></a></div>\n<div class=\"footernav\">\n<nav>\n<dl class=\"line\">\n<dt>Contents</dt>\n<dd>\n<ul>\n<li><a href=\"/recruite/message/\">社長メッセージ</a></li>\n<li><a href=\"/recruite/vision/\">企業ビジョン</a></li>\n<li><a href=\"/recruite/culture/\">企業文化</a></li>\n<li><a href=\"/recruite/carrier_plan/\">教育・キャリアプラン</a> </li>\n<li><a href=\"/recruite/guideline/\">募集要項</a> </li>\n<li><a href=\"/recruite/form/\" target=\"_blank\">お問い合わせ</a> </li>\n</ul>\n</dd>\n</dl>\n<dl>\n<dt>Interview </dt>\n<dd>\n<ul>\n<li><a href=\"/recruite/interview/marketing.html\">新垣 凜／與久田 藍香</a></li>\n<li><a href=\"/recruite/interview/akamine.html\">赤嶺 孝太</a></li>\n</ul>\n</dd>\n</dl>\n</nav>\n</div>\n</div>\n<p class=\"copyright\">&copy; Okinawa Coca-Cola Bottling. All rigts reserved.</p>\n</footer>\n<!--/footer-->\n<p class=\"pagetop\"><a href=\"#wrapper\"><img src=\"/recruite/img/pagetop.png\" alt=\"このページのトップへ\"/></a></p>\n<!--SNSボタン-->\n<div id=\"sns\"><a href=\"https://youtube.com/channel/UChsB29BLuWGsuVKFCWQSERA?si=pPadrNdcxwR5iD5V\" target=\"_blank\"><span class=\"icon-youtube\"></span>Youtube</a><a href=\"https://www.instagram.com/okinawa_cocacola_recruit/\" target=\"_blank\"><span class=\"icon-instagram\"></span>Instagram</a></div> \n</div>\n<!--スクリプト--> \n\n<script type=\"text/javascript\" src=\"/recruite/js/jetmenu.js\"></script> \n<script type=\"text/javascript\" src=\"/recruite/js/common.js\"></script>\n</body>\n</html>\n","finalUrl":"https://www.okinawa.ccbc.co.jp/recruite/vision/","rendered":false,"_cachedAt":"2026-06-23T22:41:22.377Z"}