Editable name=\"main\" -->\n  <main>\n    <section class=\"careerMv\">\n      <div class=\"sec_ttl animate\">\n        <h2 class=\"en ant\">CAREER</h2>\n        <h3 class=\"jp\">独立資本の広告会社として､<br class=\"sp\">創業52年目を迎えました｡<br>従来の｢広告｣の枠を超えた<br class=\"sp\">さまざまな事業にも取り組んでいます｡</h3>\n      </div>\n      <div class=\"careerMv_cloud\"><img src=\"../entry/img/mv_cloud.png\" alt=\"雲\"></div>\n    </section>\n    <section class=\"career\">\n      <div class=\"career_inner\">\n        <div class=\"career_fix\">\n          <div class=\"txt_wrap\">\n            <p class=\"en ant animate animate_opacity01\">BUSINESS</p>\n            <p class=\"ja animate\">広告会社の枠を超える。</p>\n          </div>\n          <div id=\"lottie01\"></div>\n        </div>\n        <div class=\"career_block\">\n          <div class=\"career_block_cont animate\">\n            <h3 class=\"ant\">PRODUCE</h3>\n            <p class=\"sub\">ビジネスプロデュース</p>\n            <p class=\"txtArea\">\n              企業、自治体、社会、そして生活者である「あなた」。<br>\n              その点と点を結ぶ、ストーリーを作るのが我々の仕事です。<br><br>\n              新東通信のプロデュース職は、その最前線で仕事を生み出し続けます。<br class=\"pc\">\n              メディア、クリエイティブ、デジタル、あらゆるリソースを通じて<br class=\"pc\">\n              クライアントに最適なソリューションをご提案。<br>\n              それぞれの個性を、育み、考え、仕事を繋ぎ続けます。\n            </p>\n          </div>\n          <div class=\"career_block_cont animate\">\n            <h3 class=\"ant\">SOLUTION</h3>\n            <p class=\"sub\">統合ソリューション</p>\n            <p class=\"txtArea\">\n              複雑化の一途を辿る現代社会において、<br>\n              常に最新のソリューションを研究・活用しています。<br><br>\n              ことばや表現を自在に操るクリエイティブはもちろん、<br class=\"pc\">\n              多様化するメディア情報を最適化するマーケティング・ミックス・モデリングや、<br class=\"pc\">\n              インターネットやAIの発展を活用するデジタルソリューションなど、<br class=\"pc\">\n              あらゆる手段を駆使し、統合的な提案を支えます。\n            </p>\n          </div>\n          <div class=\"career_block_cont animate\">\n            <h3 class=\"ant\">DEVELOPMENT</h3>\n            <p class=\"sub\">自社事業開発</p>\n            <p class=\"txtArea\">\n              地域の社会課題から地球を脅かす環境問題まで、<br class=\"pc\">\n              山積する課題を独自の開発事業で解決していきます。<br><br>\n              サーキュラーエコノミーを起点に社会課題を解決するCircular Design Studio。<br>\n              ネイチャーポジティブを推進する生物多様性事業。<br class=\"pc\">\n              地方創生や企業のイノベーションを生み出すクラウドファンディング。<br class=\"pc\">\n              日本の基盤を作り続ける産業展示会の主催事業。<br>\n              「おもろいこと」を合言葉に、ビジネスを創造し続けます。\n            </p>\n          </div>\n          <div id=\"lottie02\"></div>\n          <div id=\"lottie03\"></div>\n        </div>\n      </div>\n      <div class=\"career_btn\">\n        <a href=\"https://job.mynavi.jp/26/pc/search/corp76272/outline.html\" target=\"_blank\"><img src=\"img/career_btn.png\" alt=\"CAREER ENTRY\"></a>\n      </div>\n    </section>\n    <div class=\"backBtn\">\n      <a href=\"../\"><img src=\"../common/images/btn_back.png\" alt=\"BACK\"></a>\n    </div>\n  </main>\n  <!-- InstanceEndEditable -->\n<section id=\"news\">\n    <div class=\"sec_ttl animate\">\n        <h2 class=\"en ant\">NEWS</h2>\n        <h3 class=\"jp\">新東の森の情報</h3>\n    </div>\n    <ul class=\"news_list\">\n    <li><a href=\"https://www.pr-today.net/a00236/opr/2838/\" target=\"_blank\"><div class=\"photo\"><img src=\"https://www.pr-today.net/a00236/wp-content/uploads/sites/90/2026/06/eye_catch_image-1-150x128.jpg\" alt=\"\" width=\"auto\" height=\"auto\"></div><div class=\"txt\"><p class=\"date\">2026.6.19</p>新東通信、公式noteを活用した新オウンドメディアを公開　〜社員の「こだわり」と独自の視点...</div></a></li><li><a href=\"https://www.pr-today.net/a00236/opr/2830/\" target=\"_blank\"><div class=\"photo\"><img src=\"https://www.pr-today.net/a00236/wp-content/uploads/sites/90/2026/06/IMG_0264-1.jpg\" alt=\"\" width=\"auto\" height=\"auto\"></div><div class=\"txt\"><p class=\"date\">2026.6.17</p>広告会社コンソーシアム「メイシス」、第26回全国大会を仙台で開催 　～メイシス賞グランプリ...</div></a></li><li><a href=\"https://www.pr-today.net/a00236/opr/2823/\" target=\"_blank\"><div class=\"photo\"><img src=\"https://www.pr-today.net/a00236/wp-content/uploads/sites/90/2026/06/bd4270