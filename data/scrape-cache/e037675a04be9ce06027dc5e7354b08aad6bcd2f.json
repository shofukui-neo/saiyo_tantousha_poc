erBlock.getBoundingClientRect();\n      const careerBlockTop = careerBlockRect.top + window.scrollY;\n      const careerBlockBottom = careerBlockRect.bottom + window.scrollY;\n      if (careerBlockTop < screenCenter && careerBlockBottom > screenCenter) {\n        careerBlock.classList.add('active');\n      } else {\n        if (careerBlockTop > screenCenter || careerBlockBottom < screenCenter - windowHeight / 2) {\n          careerBlock.classList.remove('active');\n        }\n      }\n    });\n  });\n  </script>\n  <!-- InstanceEndEditable -->\n</body>\n<!-- InstanceEnd --></html>","finalUrl":"https://www.shinto-tsushin.co.jp/recruit/career/","rendered":false,"_cachedAt":"2026-06-22T21:45:51.661Z"}