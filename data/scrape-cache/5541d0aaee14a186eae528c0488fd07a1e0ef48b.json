32.png\" sizes=\"32x32\" />\n<link rel=\"icon\" href=\"https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/01/cropped-favicon-192x192.png\" sizes=\"192x192\" />\n<link rel=\"apple-touch-icon\" href=\"https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/01/cropped-favicon-180x180.png\" />\n<meta name=\"msapplication-TileImage\" content=\"https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/01/cropped-favicon-270x270.png\" />\n</script>\r\n</head>\r\n<body>\r\n\t<header id=\"header\" class=\"p-header\">\r\n    <div class=\"p-header__wrap\">\r\n        <a href=\"https://www.pasconet.co.jp/recruit/\" class=\"p-header__logo hover\">\r\n            <span class=\"p-header__logo-img\">\r\n                <img src=\"https://www.pasconet.co.jp/recruit/wp-content/themes/pasco/assets/images/common/pasco_logo.svg\" alt=\"Pasco\">\r\n            </span>\r\n            <span class=\"p-header__logo-txt\">新卒<br class=\"sp\">採用サイト</span>\r\n        </a>\r\n        <div class=\"p-header__right\">\r\n            <h1 class=\"p-header__ttl\">敷島製パン株式会社 Pascoの大学生向けの新卒採用サイト「全国の工場を数字でつなぐ調整役として。」ページ</h1>\r\n            <div class=\"p-header__main\">\r\n                <nav class=\"p-header__nav\">\r\n                    <a href=\"https://www.pasconet.co.jp/recruit/details/\" class=\"p-header__btn btn-hover\">募集要項<span class=\"icon icon-info\"></span></a>\r\n                    <a href=\"https://job.axol.jp/bx/s/pasco_27/entry\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"p-header__btn p-header__btn--info btn-hover\">27年卒 ENTRY<span class=\"icon icon-entry\"></span></a>\r\n                    <a href=\"https://axol.jp/zw/s/pasco_28/entry/agreement\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"p-header__btn p-header__btn--info btn-hover\">28年卒 ENTRY<span class=\"icon icon-entry\"></span></a>\r\n                </nav>\r\n                <a href=\"https://www.instagram.com/pasco_saiyo/\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"p-header__ins\"><img src=\"https://www.pasconet.co.jp/recruit/wp-content/themes/pasco/assets/images/common/icn_ins.svg\" alt=\"instagram\"></a>\r\n                <div class=\"hamburger-box js-show-menu\" role=\"button\" aria-label=\"Menu\" aria-expanded=\"false\"><span class=\"hamburger-inner\"></span></div>\r\n            </div>\r\n        </div>\r\n    </div>\r\n\r\n    <div class=\"p-header__wrap p-header__wrap--fixed\">\r\n        <a href=\"https://www.pasconet.co.jp/recruit/\" class=\"p-header__logo hover\">\r\n            <span class=\"p-header__logo-img\">\r\n                <img src=\"https://www.pasconet.co.jp/recruit/wp-content/themes/pasco/assets/images/common/pasco_logo.svg\" alt=\"Pasco\">\r\n            </span>\r\n            <span class=\"p-header__logo-txt\">新卒<br>採用サイト</span>\r\n        </a>\r\n        <div class=\"p-header__right\">\r\n            <div class=\"p-header__main\">\r\n                <nav class=\"p-header__nav\">\r\n                    <a href=\"https://www.pasconet.co.jp/recruit/details/\" class=\"p-header__btn btn-hover\">募集要項<span class=\"icon icon-info\"></span></a>\r\n                    <a href=\"https://job.axol.jp/bx/s/pasco_27/entry\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"p-header__btn p-header__btn--info btn-hover\">27年卒 ENTRY<span class=\"icon icon-entry\"></span></a>\r\n                    <a href=\"https://axol.jp/zw/s/pasco_28/entry/agreement\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"p-header__btn p-header__btn--info btn-hover\">28年卒 ENTRY<span class=\"icon icon-entry\"></span></a>\r\n                </nav>\r\n                <a href=\"https://www.instagram.com/pasco_saiyo/\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"p-header__ins\"><img src=\"https://www.pasconet.co.jp/recruit/wp-content/themes/pasco/assets/images/common/icn_ins.svg\" alt=\"instagram\"></a>\r\n            </div>\r\n        </div>\r\n    </div>\r\n    <div class=\"hamburger-box hamburger-box--single js-show-menu\" role=\"button\" aria-label=\"Menu\" aria-expanded=\"false\"><span class=\"hamburger-inner\"></span></div>\r\n\r\n    <div class=\"global-nav\">\r\n    <div class=\"global-nav__wrap\">\r\n        <nav class=\"global-nav__group\">\r\n            <ul class=\"nav-list\">\r\n                <li class=\"nav-item\">\r\n                    <a href=\"https://www.pasconet.co.jp/recruit/\" class=\"nav-link\">\r\n                        <span class=\"nav-link__ttl\">Top</span>\r\n                        <span class=\"nav-link__sub\">採用ページトップ</span>\r\n                    </a>\r\n                </li>\r\n                <li class=\"nav-item\">\r\n                    <a href=\"https://www.pasconet.co.jp/recruit/news/\" class=\"nav-link\">\r\n                        <span class=\"nav-link__ttl\">News</span>\r\n                        <span class=\"nav-link__sub\">お知らせ</span>\r\n                    </a>\r\n                </li>\r\n                <li class=\"nav-item\">\r\n                    <a href=\"https://www.pasconet.co.jp/recruit/company/\" class=\"nav-link\">\r\n                        <span class=\"nav-link__ttl\">Company</span>\r\n                        <span class=\"nav-link__sub\">会社概要&<br class=\"sp\">社長メッセージ</span>\r\n                    </a>\r\n                </li>\r\n                <li class=\"nav-item\">\r\n                    <a href=\"https://www.pasconet.co.jp/recruit/data/\" class=\"nav-link\">\r\n                        <span class=\"nav-link__ttl\">Data</span>\r\n                        <span class=\"nav-link__sub\">数字で見るPasco</span>\r\n                    </a>\r\n                </li>\r\n                <li class=\"nav-item\">\r\n                    <a href=\"https://www.pasconet.co.jp/recruit/interview/\" class=\"nav-link\">\r\n                        <span class=\"nav-link__ttl\">Interview</span>\r\n                        <span class=\"nav-link__sub\">社員インタビュー</span>\r\n                    </a>\r\n                </li>\r\n            </ul>\r\n            <ul class=\"nav-list\">\r\n                <li class=\"nav-item\">\r\n                    <a href=\"https://www.pasconet.co.jp/recruit/discussion/\" class=\"nav-link\">\r\n                        <span class=\"nav-link__ttl\">Discussion</span>\r\n                        <span class=\"nav-link__sub\">社員対談</span>\r\n                    </a>\r\n                </li>\r\n                <li class=\"nav-item\">\r\n                    <a href=\"https://www.pasconet.co.jp/recruit/culture/\" class=\"nav-link\">\r\n                        <span class=\"nav-link__ttl\">Culture</span>\r\n                        <span class=\"nav-link__sub\">企業文化＆働く環境</span>\r\n                    </a>\r\n                </li>\r\n                <li class=\"nav-item\">\r\n                    <a href=\"https://www.pasconet.co.jp/recruit/career/\" class=\"nav-link\">\r\n                        <span class=\"nav-link__ttl\">Career</span>\r\n                        <span class=\"nav-link__sub\">教育・研修制度＆<br class=\"sp\">キャリアパス</span>\r\n                    </a>\r\n                </li>\r\n                <li class=\"nav-item\">\r\n                    <a href=\"https://www.pasconet.co.jp/recruit/business/\" class=\"nav-link\">\r\n                        <span class=\"nav-link__ttl\">Business</span>\r\n                        <span class=\"nav-link__sub\">事業内容</span>\r\n                    </a>\r\n                </li>\r\n                <li class=\"nav-item\">\r\n                    <a href=\"https://www.pasconet.co.jp/recruit/qa/\" class=\"nav-link\">\r\n                        <span class=\"nav-link__ttl\">Q&A</span>\r\n                        <span class=\"nav-link__sub\">よくある質問</span>\r\n                    </a>\r\n                </li>\r\n            </ul>\r\n        </nav>\r\n        <nav class=\"global-nav__other\">\r\n            <a href=\"https://www.pasconet.co.jp/recruit/details/\" class=\"btn btn-sub btn-hover\">募集要項・<br class=\"pc\">採用スケジュール<span class=\"icon icon-info\"></span></a>\r\n            <a href=\"https://job.axol.jp/bx/s/pasco_27/entry/\" class=\"btn btn-primary-reverse btn-hover\" target=\"_blank\">27年卒 ENTRY<span class=\"icon icon-entry\"></span></a>\r\n            <a href=\"https://axol.jp/zw/s/pasco_28/entry/agreement\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"btn btn-primary-reverse btn-hover\">28年卒 ENTRY<span class=\"icon icon-entry\"></span></a>\r\n        </nav>\r\n    </div>\r\n</div></header>\r\n\r\n<ul class=\"nav-fixed sp\">\r\n    <li><a href=\"https://www.pasconet.co.jp/recruit/details/\" class=\"btn btn-sub btn-hover\">募集要項<span class=\"icon icon-info\"></span></a></li>\r\n    <li><a href=\"https://job.axol.jp/bx/s/pasco_27/entry\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"btn btn-primary btn-hover\">27年卒 ENTRY<span class=\"icon icon-entry\"></span></a></li>\r\n    <li><a href=\"https://axol.jp/zw/s/pasco_28/entry/agreement\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"btn btn-primary btn-hover\">28年卒 ENTRY<span class=\"icon icon-entry\"></span></a></li>\r\n</ul><div class=\"c-mv\">\r\n    <div class=\"c-mv__wrap\">\r\n        <div class=\"c-mv__content\">\r\n            <h2 class=\"c-mv__page\">Interview</h2>\r\n            <p class=\"c-mv__sub\">社員インタビュー</p>\r\n        </div>\r\n        <div class=\"c-breadcrumb\">\r\n            <ul class=\"c-breadcrumb__list\">\r\n                <li class=\"c-breadcrumb__item hover\"><a href=\"https://www.pasconet.co.jp/recruit/\">ホーム</a></li>\r\n                <li class=\"c-breadcrumb__item hover\"><a href=\"https://www.pasconet.co.jp/recruit/interview/\">社員インタビュー</a></li>\r\n                <li class=\"c-breadcrumb__item\">全国の工場を数字でつなぐ調整役として。</li>\r\n            </ul>\r\n        </div>\r\n    </div>\r\n</div>\r\n<div class=\"inner\">\r\n    <div class=\"c-single\">\r\n        <div class=\"c-single__media\">\r\n                        <div class=\"c-single__media-img\">\r\n                                    <p class=\"c-single__media-cate\">生産</p>\r\n                                \r\n                <img width=\"1024\" height=\"761\" src=\"https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A4213-scaled-e1772094169419-1024x761.jpg\" class=\"attachment-large size-large wp-post-image\" alt=\"\" decoding=\"async\" fetchpriority=\"high\" srcset=\"https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A4213-scaled-e1772094169419-1024x761.jpg 1024w, https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A4213-scaled-e1772094169419-300x223.jpg 300w, https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A4213-scaled-e1772094169419-768x571.jpg 768w, https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A4213-scaled-e1772094169419-1536x1142.jpg 1536w, https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A4213-scaled-e1772094169419.jpg 1704w\" sizes=\"(max-width: 1024px) 100vw, 1024px\" />            </div>\r\n                        \r\n            <div class=\"c-single__media-body\">\r\n                                <p class=\"btn-basic\">2020年入社 / 生産管理</p>\r\n                \r\n                <p class=\"c-single__media-ttl\">全国の工場を数字でつなぐ調整役として。</p>\r\n                <p class=\"c-single__media-name\">坂井</p>\r\n            </div>\r\n        </div>\r\n\r\n        \r\n                \r\n        <div class=\"detail-body c-txt\"><div class=\"box\">\n<p>【略歴】</p>\n<p>2020年4月：生産職入社</p>\n<p>2022年9月：生産管理に配属</p>\n<p>&nbsp;</p>\n<p>【好きな商品】</p>\n<p>1位：超熟山型</p>\n<p>2位：国産小麦と米粉のロール</p>\n<p>3位：喫茶店風小倉バタートースト</p>\n</div>\n<h3>Q：入社の理由は？<br />\nA：食やパンへの関心と想いが入社の理由。</h3>\n<p>小学生のころからバスケットボールに打ち込み、自分の身体を構成している栄養に関して興味を持つようになったため、農学部のある大学に進学しました。大学では、バイオサイエンスや食品機能について学び、顕微鏡を用いた実験などを通して食と科学が結びつく面白さを肌で感じましたね。</p>\n<p>その背景から、食に関する企業で働きたいと考えるようになりました。食卓の中でも中心的な存在であるパン業界に従事し、多くの人の毎日に寄り添いたいという想いが強かったため、Pascoへの入社を決意しました。</p>\n<h3>Q：仕事の内容は？<br />\nA：全国の工場を数字でつなぐ調整役。</h3>\n<div>\n<div class=\"img-with-txt\">\n<div class=\"img-with-txt__content\">\n<div><img decoding=\"async\" class=\"alignnone  wp-image-238\" src=\"https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A4240-scaled.jpg\" alt=\"\" width=\"397\" height=\"264\" srcset=\"https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A4240-scaled.jpg 2560w, https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A4240-300x200.jpg 300w, https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A4240-1024x683.jpg 1024w, https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A4240-768x512.jpg 768w, https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A4240-1536x1024.jpg 1536w, https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A4240-2048x1365.jpg 2048w\" sizes=\"(max-width: 397px) 100vw, 397px\" /> <img decoding=\"async\" class=\"alignnone  wp-image-240\" src=\"https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/修正済-scaled.png\" alt=\"\" width=\"407\" height=\"272\" srcset=\"https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/修正済-scaled.png 2560w, https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/修正済-300x200.png 300w, https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/修正済-1024x684.png 1024w, https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/修正済-768x513.png 768w, https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/修正済-1536x1026.png 1536w, https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/修正済-2048x1368.png 2048w\" sizes=\"(max-width: 407px) 100vw, 407px\" /> </div>\n<div>　</div>\n<p>入社してからまずは生産職に配属され、アップルパイやうずまきデニッシュなどのパイ商品をつくっていました。その後、生産管理に異動し、現在は主に4つの仕事を担っています。</p>\n<p>&nbsp;</p>\n<p>1つ目が生産調整です。<br />\n生産工場で設備工事の予定が入ったり、トラブルが発生したりした場合には、他の工場に生産の応援を依頼します。とくに大規模な工事の際には、全国の工場における生産状況を把握し、必要数量を事前に確保することで、安定供給が続けられるように調整しています。</p>\n<p>2つ目が社内回覧文書の作成です。<br />\n生産に関わる人に対し、必要な情報を正確に共有するための文書を作成する仕事で、商品の発売・終売や包材変更の際に、パッケージや発売日、原材料名などを整理した社内回覧文書を作成します。膨大な情報の中から必要な情報を抽出し、正確かつ漏れなく共有できるように心掛けています。</p>\n<p>3つ目が原価管理です。<br />\n商品が決められた手順や分量で生産されているか管理します。例えば、生産計画が甘く原材料を余分に準備していたりすると、結果的に破棄され使い込みとなります。このような微細な積み重ねが商品原価に影響していく為、管理には気を配っています。</p>\n<p>4つ目が利益の分析と生産量の予測です。<br />\n適正な損益管理の為、各帳票および、生産に関わる数字と各ラインが取り組んでいる改善テーマなどを併せて分析し、工場運営に役立てています。また、次月はどのような生産実績になるか予測し、あらかじめ生産計画を立てています。</p>\n<p>&nbsp;</p>\n<p>生産現場にいたときは、同じラインの同僚以外と仕事をする機会がほとんどなかったのですが、生産管理に異動してからは、自工場の生産ライン、営業、開発、全国の工場の生産管理など、仕事で関わる人が大幅に増えました。さまざまな部署と連絡を取ることで知識も増えましたし、いろいろな人と一緒に仕事を進めることが楽しく感じています。</p>\n<p>&nbsp;</p>\n<p>一方で、急な生産調整が必要になったときは大変です。予測より注文数が増えたり大規模な機械故障などがあったりすると、計画どおり生産できず欠品を出してしまい、お取引先様はもちろん、なにより商品を購入してくださるお客さまからの信頼を失うことになります。そこで欠品を防ぐために他工場へ生産の応援依頼を出しますが、急な依頼だと他工場の生産能力や原材料がなかったり、商品を移動させるトラックの手配も困難なことがあります。そういったときには生産工程をさらに見直し、出荷時間に間に合う移動手段が他にないかなど、さまざまな選択肢の中から最適解を考えます。<br />\n無事すべての調整が終わった際には達成感がありますね。</p>\n<h3>Q：生産管理で大切なことは？<br />\nA：日々の管理を徹底し、数字の違和感を見逃さないこと。</h3>\n<div>\n<div class=\"img-with-txt\">\n<div class=\"img-with-txt__content\">\n<div><img decoding=\"async\" class=\"alignnone size-full wp-image-239\" src=\"https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A4296-scaled.jpg\" alt=\"\" width=\"2560\" height=\"1707\" srcset=\"https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A4296-scaled.jpg 2560w, https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A4296-300x200.jpg 300w, https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A4296-1024x683.jpg 1024w, https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A4296-768x512.jpg 768w, https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A4296-1536x1024.jpg 1536w, https://www.pasconet.co.jp/recruit/wp-content/uploads/2026/02/05A4296-2048x1365.jpg 2048w\" sizes=\"(max-width: 2560px) 100vw, 2560px\" /></div>\n<div>　</div>\n<p>生産管理としての一番大きな使命は、商品を欠品させることなくお客さまへ確実にお届けすることです。そのために日々の管理を特に大切にしています。管理システム内の生産数や生産時間などを毎日チェックし小さな数字のズレを見逃さないことが極めて重要な役割です。</p>\n<p>数字を扱う部署なので、数字を意識しながら仕事に取り組める人が向いていると感じています。入社後は生産ラインに入って生産の経験を積むのですが、その段階から原材料の使用率や不良率などを意識して働ける人は、生産全体を管理する立場になった時に力を発揮できると思います。</p>\n<p>また、生産管理は効率よく生産を進めるための提案を行う部署でもあるので、自分が働いている中で無駄だと感じる業務に気づき、より良い作業方法を生み出せる人もその能力を十分に生かせると思います。</p>\n<p>&nbsp;</p>\n<p>もともと生産管理という職種を強く志望していたわけではなかったのですが、異動してから実際に働いてみると売り上げに関わる大切な数字を扱うことが想像以上に楽しく、やりがいに感じています。</p>\n<h3>Q：どんな会社？<br />\nA：入社後、社会貢献を実際に感じた会社。</h3>\n<p>米騒動をきっかけに創業したPascoは、「金儲けは結果であり、目的ではない。食糧難の解決が開業の第一の意義であり、事業は社会に貢献するところがあればこそ発展する。」という創業の理念を大切に受け継いでおり、現在は国産小麦の小麦粉を使用した商品を多数生産することで小麦の食料自給率の向上に貢献することを目指しています。</p>\n<p>2025年には和小麦ブランドを立ち上げ、さらに国産小麦の小麦粉を使用した商品が増えたと、日々の業務を通じて感じます。こうした取り組みに携われることで、私も食料自給率向上を目指すという社会貢献の一端を確かに担っていると実感できます。</p>\n<h3>Q：今後の目標は？<br />\nA：数字から課題を見つけ出し、自分で仕事をつくり出せる人になること。</h3>\n<p>最近は、原価分析を任せてもらう機会が増えました。毎月新商品を発売していますし、パンは日配品*¹ということもあり工場の環境は日々変化しています。日頃から様々な情報にアンテナを張り、多角的な視点から総合的に分析することで課題を見つけ、利益を算出できるような人材になりたいと思います。</p>\n<p>&nbsp;</p>\n<p>また、私はこの仕事がとても面白いと感じています。今はまだ、上司に相談しながら業務を行う部分もありますが、将来的には自分で数字を見て原因を調査し、生産部門に改善提案までを行えるようになりたいですね。</p>\n<p>※1・・・消費期限が短く、毎日店舗へ配送される食品のこと</p>\n</div>\n</div>\n</div>\n</div>\n</div>\n</div>\n</div>\r\n    </div>\r\n</div>\r\n<div class=\"container\">\r\n        <nav class=\"c-back-nav\">\r\n                    <a href=\"https://www.pasconet.co.jp/recruit/production/p188/\" class=\"c-back-nav__arrow c-back-nav__arrow--prev\"></a>\r\n        \r\n        <a href=\"https://www.pasconet.co.jp/recruit/interview/\" class=\"btn btn-sub c-back-nav__button\">一覧へ戻る</a>\r\n\r\n                    <a href=\"https://www.pasconet.co.jp/recruit/sales/p200/\" class=\"c-back-nav__arrow c-back-nav__arrow--next\"></a>\r\n            </nav>\r\n\r\n        <nav class=\"c-category-filter\">\r\n        <ul class=\"c-category-filter__list\">\r\n            <li><a href=\"https://www.pasconet.co.jp/recruit/interview/\" class=\"btn-basic\">すべて</a></li>\r\n                        <li><a href=\"https://www.pasconet.co.jp/recruit/interview/engineer/\" class=\"btn-basic\">エンジニア</a></li>\r\n                        <li><a href=\"https://www.pasconet.co.jp/recruit/interview/sales/\" class=\"btn-basic\">営業</a></li>\r\n                        <li><a href=\"https://www.pasconet.co.jp/recruit/interview/production/\" class=\"btn-basic\">生産</a></li>\r\n                    </ul>\r\n    </nav>\r\n    </div>\r\n\r\n<footer class=\"p-footer\">\r\n    <div class=\"inner\">\r\n        <div class=\"footer-entry\">\r\n            <h3 class=\"footer-entry__ttl font-en\">Entry!</h3>\r\n            <p class=\"footer-entry__txt\">Pascoでは、<br class=\"sp\">一緒に働く社員を募集しています。<br>\r\n            まだ夢がはっきりしていなくても<br class=\"sp\">大丈夫。挑戦する気持ちを持つ<br class=\"sp\">皆さまからのエントリーを<br class=\"sp\">お待ちしています。</p>\r\n            <div class=\"footer-entry__nav\">\r\n                <a href=\"https://www.pasconet.co.jp/recruit/details/\" class=\"btn btn-sub btn-hover\">募集要項・<br class=\"pc\">採用スケジュール<span class=\"icon icon-info\"></span></a>\r\n                <a href=\"https://job.axol.jp/bx/s/pasco_27/entry\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"btn btn-primary btn-hover\">27年卒 ENTRY<span class=\"icon icon-entry\"></span></a>\r\n                <a href=\"https://axol.jp/zw/s/pasco_28/entry/agreement\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"btn btn-primary btn-hover\">28年卒 ENTRY<span class=\"icon icon-entry\"></span></a>\r\n            </div>\r\n            <div class=\"footer-entry__img --left\">\r\n                <picture>\r\n                    <source media=\"(min-width: 768px)\" srcset=\"https://www.pasconet.co.jp/recruit/wp-content/themes/pasco/assets/images/common/footer_entry_img01.svg\">\r\n                    <img src=\"https://www.pasconet.co.jp/recruit/wp-content/themes/pasco/assets/images/common/footer_entry_img01_sp.svg\">\r\n                </picture>\r\n            </div>\r\n            <div class=\"footer-entry__img --right\">\r\n                <picture>\r\n                    <source media=\"(min-width: 768px)\" srcset=\"https://www.pasconet.co.jp/recruit/wp-content/themes/pasco/assets/images/common/footer_entry_img02.svg\">\r\n                    <img src=\"https://www.pasconet.co.jp/recruit/wp-content/themes/pasco/assets/images/common/footer_entry_img02_sp.svg\">\r\n                </picture>\r\n            </div>\r\n        </div>\r\n    </div>\r\n\r\n    <div class=\"container\">\r\n        <div class=\"p-footer__wrap\">\r\n            <div class=\"p-footer__logo\">\r\n                <span class=\"p-footer__logo-img\"><img src=\"https://www.pasconet.co.jp/recruit/wp-content/themes/pasco/assets/images/common/pasco_logo.svg\" alt=\"Pasco\"></span>\r\n                <span class=\"p-footer__logo-txt\">新卒採用サイト</span>\r\n            </div>\r\n            <nav class=\"p-footer__nav\">\r\n                <ul>\r\n                    <li><a href=\"https://www.pasconet.co.jp/recruit/\">採用サイトトップ</a></li>\r\n                    <li><a href=\"https://www.pasconet.co.jp/recruit/news/\">お知らせ</a></li>\r\n                    <li><a href=\"https://www.pasconet.co.jp/recruit/company/\">会社概要&<br class=\"sp\">社長メッセージ</a></li>\r\n                    <li><a href=\"https://www.pasconet.co.jp/recruit/data/\">数字で見るPasco</a></li>\r\n                    <li><a href=\"https://www.pasconet.co.jp/recruit/interview/\">社員インタビュー</a></li>\r\n                    <li><a href=\"https://www.pasconet.co.jp/recruit/discussion/\">社員対談</a></li>\r\n                </ul>\r\n                <ul>\r\n                    <li><a href=\"https://www.pasconet.co.jp/recruit/culture/\">企業文化&働く環境</a></li>\r\n                    <li><a href=\"https://www.pasconet.co.jp/recruit/career/\">教育・研修制度＆<br class=\"sp\">キャリアパス</a></li>\r\n                    <li><a href=\"https://www.pasconet.co.jp/recruit/business/\">事業内容</a></li>\r\n                    <li><a href=\"https://www.pasconet.co.jp/recruit/qa/\">よくある質問</a></li>\r\n                    <li><a href=\"https://www.pasconet.co.jp/recruit/details/\">募集要項・<br>採用スケジュール</a></li>\r\n                </ul>\r\n            </nav>\r\n        </div>\r\n        <div class=\"p-footer__other\">\r\n            <nav class=\"footer-nav\">\r\n                <a href=\"https://www.pasconet.co.jp/\" target=\"_blank\" rel=\"noopener n