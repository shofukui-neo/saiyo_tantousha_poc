{"url":"https://toyota-unitedshizuoka.co.jp/recruit/se/education/","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n  <head>\n    <title>すげーエンジニアの育て方 | #すげーエンジニア探してる - トヨタユナイテッド静岡 サービスエンジニア採用サイト</title>\n    <meta name=\"description\" content=\"あなたが「すげーエンジニア」になりたいと思ったら、トヨタユナイテッド静岡は全力でバックアップします。あなたの努力が実を結ぶよう、最高のSEへの道をつないでいきます。\" />\n    <meta charset=\"utf-8\" />\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0, minimum-scale=1.0\" />\n<meta name=\"format-detection\" content=\"telephone=no\" />\n<link href=\"/recruit/se/assets/css/style.css?1729738522\" rel=\"stylesheet\">\n<link href=\"/favicon.ico\" rel=\"icon\" />\n    <link href=\"/recruit/se/assets/css/education.css\" rel=\"stylesheet\" />\n     <!-- Google Tag Manager -->\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n})(window,document,'script','dataLayer','GTM-KJK3HJG');</script>\n\n\n <script>\n   (function (w, d, s, l, i) {\n     w[l] = w[l] || [];\n     w[l].push({\n       'gtm.start': new Date().getTime(),\n       event: 'gtm.js'\n     });\n     var f = d.getElementsByTagName(s)[0],\n       j = d.createElement(s),\n       dl = l != 'dataLayer' ? '&l=' + l : '';\n     j.async = true;\n     j.src =\n       'https://www.googletagmanager.com/gtm.js?id=' + i + dl;\n     f.parentNode.insertBefore(j, f);\n   })(window, document, 'script', 'dataLayer', 'GTM-NZ5M5CC');\n </script>\n <!-- End Google Tag Manager -->  </head>\n  <body class=\"pg-EducationIndex\">\n    <!-- Google Tag Manager (noscript) -->\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-KJK3HJG\" height=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-NZ5M5CC\" height=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n<!-- End Google Tag Manager (noscript) -->\n<header class=\"st-Header\">\n  <div class=\"st-Header_Inner\">\n          <p class=\"st-Header_Logo\">\n                <a href=\"/recruit/se/\">\n          <img src=\"/recruit/se/assets/img/common/logo.png\" srcset=\"/recruit/se/assets/img/common/logo.png 1x, /recruit/se/assets/img/common/logo@2x.png 2x\" alt=\"#すげーエンジニア探してる - トヨタユナイテッド静岡 サービスエンジニア採用サイト\" />\n        </a>\n              </p>\n          <nav class=\"st-GlobalNav\">\n      <a href=\"/recruit/se/\" class=\"st-GlobalNav_Logo\">\n        <img src=\"/recruit/se/assets/img/common/logo.png\" srcset=\"/recruit/se/assets/img/common/logo.png 1x, /recruit/se/assets/img/common/logo@2x.png 2x\" alt=\"#すげーエンジニア探してる - トヨタユナイテッド静岡 サービスエンジニア採用サイト\" />\n      </a>\n      <ul class=\"st-GlobalNav_Items\">\n        <li class=\"st-GlobalNav_Item -education\">\n          <a href=\"/recruit/se/education/\">\n            <picture>\n              <source srcset=\"/recruit/se/assets/img/common/txt_nav01-mobile.png\" media=\"(max-width:767px)\" />\n              <source srcset=\"/recruit/se/assets/img/common/txt_nav01-pc.png 1x, /recruit/se/assets/img/common/txt_nav01-pc@2x.png 2x\" media=\"(min-width:768px)\" />\n              <img src=\"/recruit/se/assets/img/common/txt_nav01-pc.png\" alt=\"すげーエンジニアの育て方\" />\n            </picture>\n          </a>\n        </li>\n        <li class=\"st-GlobalNav_Item -real\">\n          <a href=\"/recruit/se/real/\">\n            <picture>\n              <source srcset=\"/recruit/se/assets/img/common/txt_nav02-mobile.png\" media=\"(max-width:767px)\" />\n              <source srcset=\"/recruit/se/assets/img/common/txt_nav02-pc.png 1x, /recruit/se/assets/img/common/txt_nav02-pc@2x.png 2x\" media=\"(min-width:768px)\" />\n              <img src=\"/recruit/se/assets/img/common/txt_nav02-pc.png\" alt=\"すげーエンジニアのリアル\" />\n            </picture>\n          </a>\n        </li>\n      </ul>\n      <ul class=\"st-GlobalNav_Links\">\n        <li class=\"st-GlobalNav_Link\">\n          <a href=\"https://toyota-unitedshizuoka.co.jp/\" target=\"_blank\">\n            <svg>\n              <use xlink:href=\"#ico_arrow_short\"></use>\n            </svg>\n            <p>コーポレートサイト</p>\n          </a>\n        </li>\n        <li class=\"st-GlobalNav_Link\">\n          <a href=\"https://toyota-unitedshizuoka.co.jp/recruit/\" target=\"_blank\">\n            <svg>\n              <use xlink:href=\"#ico_arrow_short\"></use>\n            </svg>\n            <p>リクルートサイト</p>\n          </a>\n        </li>\n      </ul>\n    </nav>\n    <button class=\"hamburgeeer js-hamburgeeer\"><span></span></button>\n  </div>\n</header>    <main class=\"st-Main\">\n      <div class=\"ei-Hero\">\n        <h1 class=\"ei-Hero_Title\">\n          <picture>\n            <source srcset=\"../assets/img/education/ttl_education-mobile.png\" media=\"(max-width:767px)\" />\n            <source srcset=\"../assets/img/education/ttl_education-pc.png 1x, ../assets/img/education/ttl_education-pc@2x.png 2x\" media=\"(min-width:768px)\" />\n            <img src=\"../assets/img/education/ttl_education-pc.png\" alt=\"すげーエンジニアの育て方\" />\n          </picture>\n        </h1>\n      </div>\n      <div class=\"ei-Catch\">\n        <div class=\"container\">\n          <p>\n            あなたが「すげーエンジニア」になりたいと思ったら、<br class=\"desktop-hidden\" />\n            トヨタユナイテッド静岡は全力でバックアップします。<br />\n            一歩ずつ着実にステップアップできるよう、<br class=\"desktop-hidden\" />\n            段階に応じた手厚い教育制度を導入。<br />\n            あなたの努力が実を結ぶよう、<br class=\"desktop-hidden\" />\n            最高のSEへの道をつないでいきます。\n          </p>\n        </div>\n      </div>\n      <section class=\"ei-Training\">\n        <div class=\"ei-Training_Header\">\n          <div class=\"container\">\n            <h2 class=\"ei-Training_Header_Title\">\n              <picture>\n                <source srcset=\"../assets/img/education/ttl_trainer-mobile.png?v=241017\" media=\"(max-width:767px)\" />\n                <source srcset=\"../assets/img/education/ttl_trainer-pc.png?v=241017 1x, ../assets/img/education/ttl_trainer-pc@2x.png?v=241017 2x\" media=\"(min-width:768px)\" />\n                <img src=\"../assets/img/education/ttl_trainer-pc.png?v=241017\" alt=\"技術トレーナーが6名在籍しています\" />\n              </picture>\n            </h2>\n            <h3 class=\"ei-Training_Header_TitleSub\">トレーナーを見て、自分の未来をイメージ！</h3>\n            <p class=\"ei-Training_Header_Text\">トヨタユナイテッド静岡（TUS）には技術教育を行うトレーナー6名。<br class=\"mobile-hidden\" />サービス技術研修のほか、新入社員向けの研修なども担当し、万全の体制を整えてあなたが来るのを待っています。</p>\n            <picture class=\"ei-Training_Header_Image\">\n              <source srcset=\"../assets/img/education/img_tus-mobile.png\" media=\"(max-width:767px)\" />\n              <source srcset=\"../assets/img/education/img_tus-pc.png 1x, ../assets/img/education/img_tus-pc@2x.png 2x\" media=\"(min-width:768px)\" />\n              <img src=\"../assets/img/education/img_tus-pc.png\" alt=\"【T】トレーナーたちが【U】上を目指すあなたを【S】サポートします（全力で）\" />\n            </picture>\n          </div>\n        </div>\n        <div class=\"ei-Training_Body\">\n          <h2 class=\"ei-Training_Body_Title\">\n            <picture>\n              <source srcset=\"../assets/img/education/ttl_system-mobile.png\" media=\"(max-width:767px)\" />\n              <source srcset=\"../assets/img/education/ttl_system-pc.png 1x, ../assets/img/education/ttl_system-pc@2x.png 2x\" media=\"(min-width:768px)\" />\n              <img src=\"../assets/img/education/ttl_system-pc.png\" alt=\"研修制度\" />\n            </picture>\n          </h2>\n          <section class=\"ei-Training_Body_Item\">\n            <h3 class=\"ei-Training_Body_ItemTitle\">新人研修</h3>\n            <p class=\"ei-Training_Body_ItemDescription\">3ヶ月［4月総合研修、5〜6月職種別研修］で、SEに求められる技術・知識の基礎を徹底的に習得。<br class=\"mobile-hidden\" />現場実習も行い、プロにふさわしい対応技術を身につけます。</p>\n            <div class=\"ei-Training_Body_Lists\">\n              <dl class=\"ei-Training_Body_List\">\n                <dt>\n                  配属前研修\n                  <picture>\n                    <source srcset=\"../assets/img/education/pic_training01-mobile.jpg?v=241017\" media=\"(max-width:767px)\" />\n                    <source srcset=\"../assets/img/education/pic_training01-pc.jpg?v=241017 1x, ../assets/img/education/pic_training01-pc@2x.jpg?v=241017 2x\" media=\"(min-width:768px)\" />\n                    <img src=\"../assets/img/education/pic_training01-pc.jpg?v=241017\" alt=\"配属前研修のイメージ\" />\n                  </picture>\n                </dt>\n                <dd>法定点検及び多頻度整備の基礎習得を目指します。また、業務システムを活用したサービス業務の基礎訓練を行い、お客様応対のコミュニケーション能力も高めます。</dd>\n              </dl>\n              <dl class=\"ei-Training_Body_List\">\n                <dt>\n                  バディプログラム\n                  <picture>\n                    <source srcset=\"../assets/img/education/pic_training02-mobile.jpg\" media=\"(max-width:767px)\" />\n                    <source srcset=\"../assets/img/education/pic_training02-pc.jpg 1x, ../assets/img/education/pic_training02-pc@2x.jpg 2x\" media=\"(min-width:768px)\" />\n                    <img src=\"../assets/img/education/pic_training02-pc.jpg\" alt=\"バディプログラムのイメージ\" />\n                  </picture>\n                </dt>\n                <dd>配属後は、店舗の先輩を教育担当者である「バディ」として任命。バディを中心に店舗全体で1年間、新入社員を計画的に育成する環境を整え、「自ら考え、行動する」社員を目指します。</dd>\n              </dl>\n              <dl class=\"ei-Training_Body_List\">\n                <dt>\n                  フォロー研修\n                  <picture>\n                    <source srcset=\"../assets/img/education/pic_training03-mobile.jpg\" media=\"(max-width:767px)\" />\n                    <source srcset=\"../assets/img/education/pic_training03-pc.jpg 1x, ../assets/img/education/pic_training03-pc@2x.jpg 2x\" media=\"(min-width:768px)\" />\n                    <img src=\"../assets/img/education/pic_training03-pc.jpg\" alt=\"フォロー研修のイメージ\" />\n                  </picture>\n                </dt>\n                <dd>配属後には、四半期に1回の集合研修を実施。研修での課題を通じて解決する力をつけ、それを行動に移すことでスキルアップできるようにトレーニングを行います。</dd>\n              </dl>\n            </div>\n          </section>\n          <section class=\"ei-Training_Body_Item\">\n            <h3 class=\"ei-Training_Body_ItemTitle\">ステップアップ753教育</h3>\n            <p class=\"ei-Training_Body_ItemDescription\">SEが、3・5・7年次に求められる目標と課題を明確に認識することで、目的意識をもってチャレンジできるようにする教育制度。</p>\n            <div class=\"ei-Training_Body_Stepup\">\n              <picture>\n                <source srcset=\"../assets/img/education/img_stepup-mobile.png\" media=\"(max-width:767px)\" />\n                <source srcset=\"../assets/img/education/img_stepup-pc.png 1x, ../assets/img/education/img_stepup-pc@2x.png 2x\" media=\"(min-width:768px)\" />\n                <img src=\"../assets/img/education/img_stepup-pc.png\" alt=\"ステップアップ753教育\" />\n              </picture>\n            </div>\n            <img src=\"../assets/img/education/img_scroll.png\" alt=\"横スクロールでご覧いただけます\" class=\"ei-Training_Body_Scroll\" />\n            <dl class=\"ei-Training_Body_List -column\">\n              <dt>成長のステップが、くっきり描きやすい！</dt>\n              <dd>積極的に教育を受けられるようにOFF-JT教育を充実させ、店舗のスタッフが成長のタイミングに合わせ知識・技術等を教えていきます。前向きな向上心がステップアップの基本となるため、年次ごとの目標を定め、つねに新しいチャレンジを続けるマインドを育成。自分が先輩になったら、後輩にも教えるという好循環があるのも特長です。また、同年代のエンジニア全員が、同じペースで成長することが出来ます。</dd>\n            </dl>\n          </section>\n        </div>\n      </section>\n      <section class=\"ei-Engineer\">\n        <div class=\"ei-Engineer_Header\">\n          <h2 class=\"ei-Engineer_Header_Title\">\n            <picture>\n              <source srcset=\"../assets/img/education/ttl_engineer-mobile.png\" media=\"(max-width:767px)\" />\n              <source srcset=\"../assets/img/education/ttl_engineer-pc.png 1x, ../assets/img/education/ttl_engineer-pc@2x.png 2x\" media=\"(min-width:768px)\" />\n              <img src=\"../assets/img/education/ttl_engineer-pc.png\" alt=\"進化するクルマには先進の技術を持ったエンジニアが必要だ。\" />\n            </picture>\n          </h2>\n          <p class=\"ei-Engineer_Header_Text\">\n            電動化、自動化など、クルマは凄い速さで<br class=\"desktop-hidden\" />進化しています。<br />\n            エンジニアの技術も、<br class=\"desktop-hidden\" />そのスピードに追いつくことが必要です。<br />\n            その成長に欠かせないのが、<br class=\"desktop-hidden\" />トヨタユナイテッド静岡の教育制度です。<br />\n            経験、技能レベル等にあわせた<br class=\"desktop-hidden\" />多角的なサポートが充実。<br />\n            未来のすげーエンジニアを支えます。\n          </p>\n        </div>\n        <div class=\"ei-Engineer_Body\">\n          <h2 class=\"ei-Engineer_Body_Title\">\n            <picture>\n              <source srcset=\"../assets/img/education/ttl_environment-mobile.png\" media=\"(max-width:767px)\" />\n              <source srcset=\"../assets/img/education/ttl_environment-pc.png 1x, ../assets/img/education/ttl_environment-pc@2x.png 2x\" media=\"(min-width:768px)\" />\n              <img src=\"../assets/img/education/ttl_environment-pc.png\" alt=\"社内環境\" />\n            </picture>\n          </h2>\n          <section class=\"ei-Engineer_Body_Item\">\n            <h3 class=\"ei-Engineer_Body_ItemTitle\">ヤリスカップ</h3>\n            <p class=\"ei-Engineer_Body_ItemDescription\">2021年、静岡県内ディーラー初のワークスチーム誕生！ さらに！2022年度は社員ドライバーも登場し、参戦決定！</p>\n            <div class=\"ei-Engineer_Body_Yariscup\">\n              <div class=\"ei-Engineer_Body_YariscupPic\">\n                <picture>\n                  <source srcset=\"../assets/img/education/pic_yariscup01-mobile.jpg?v=241021\" media=\"(max-width:767px)\" />\n                  <source srcset=\"../assets/img/education/pic_yariscup01-pc.jpg?v=241017 1x, ../assets/img/education/pic_yariscup01-pc@2x.jpg?v=241017 2x\" media=\"(min-width:768px)\" />\n                  <img src=\"../assets/img/education/pic_yariscup01-pc.jpg?v=241017\" alt=\"ヤリスのイメージ\" />\n                </picture>\n                <picture>\n                  <source srcset=\"../assets/img/education/pic_yariscup02-mobile.jpg?v=241021\" media=\"(max-width:767px)\" />\n                  <source srcset=\"../assets/img/education/pic_yariscup02-pc.jpg?v=241017 1x, ../assets/img/education/pic_yariscup02-pc@2x.jpg?v=241017 2x\" media=\"(min-width:768px)\" />\n                  <img src=\"../assets/img/education/pic_yariscup02-pc.jpg?v=241017\" alt=\"ヤリスカップのメンテナンス\" />\n                </picture>\n                <picture>\n                  <source srcset=\"../assets/img/education/pic_yariscup03-mobile.jpg?v=241021\" media=\"(max-width:767px)\" />\n                  <source srcset=\"../assets/img/education/pic_yariscup03-pc.jpg?v=241017 1x, ../assets/img/education/pic_yariscup03-pc@2x.jpg?v=241017 2x\" media=\"(min-width:768px)\" />\n                  <img src=\"../assets/img/education/pic_yariscup03-pc.jpg?v=241017\" alt=\"ヤリスカップの集合写真\" />\n                </picture>\n              </div>\n              <p class=\"ei-Engineer_Body_YariscupText\">\n                静岡県内ディーラー初のワークスチームとして、2021年よりヤリスカップに参戦。レースのサポートエンジニアは、社内のエンジニアから募集し、“イチ”からチームを結成しました。<br />\n                2023年にはグランドファイナルでワン・ツーフィニッシュを飾り念願のゼッケン1番を獲得！今シーズンも表彰台目指して爆走中です！！\n              </p>\n            </div>\n          </section>\n          <section class=\"ei-Engineer_Body_Item\">\n            <h3 class=\"ei-Engineer_Body_ItemTitle\">年間休日＆福利厚生</h3>\n            <p class=\"ei-Engineer_Body_ItemDescription -medium\">休み方を考えたら、働き方が変わりました。</p>\n            <div class=\"ei-Engineer_Body_Welfare\">\n              <div class=\"ei-Engineer_Body_WelfareItem\">\n                <dl class=\"ei-Engineer_Body_WelfareList\">\n                  <dt>\n                    <span>\n                      年間休日<br />\n                      <img src=\"../assets/img/education/img_120.png\" srcset=\"../assets/img/education/img_120.png 1x, ../assets/img/education/img_120@2x.png 2x\" alt=\"120\" />\n                      日<br /><span class=\"ei-Engineer_Body_WelfareListAttention\">※他有給休暇あり</span>\n                    </span>\n                  </dt>\n                  <dd>\n                    <dl>\n                      <dt>毎週月曜日、第1・2・3火曜日は定休日、毎月2回は連休取得可能！</dt>\n                      <dd>\n                        定休日の他に、各々が希望する日を休日にできる選択休日が月に1〜3日程度あります。当社ならプライベートも充実すること間違いなし！<br />\n                        <span>※一部店舗で変則カレンダーあり</span>\n                      </dd>\n                    </dl>\n                  </dd>\n                </dl>\n                <span class=\"ei-Engineer_Body_WelfareSupplement\">\n                  <span>\n                    土日の休みも<br />\n                    取得しやすい<br />\n                    ですよ\n                  </span>\n                </span>\n              </div>\n              <div class=\"ei-Engineer_Body_WelfareItem -welfare\">\n                <dl class=\"ei-Engineer_Body_WelfareList\">\n                  <dt>\n                    <span>福利<br />厚生</span>\n                  </dt>\n                  <dd>\n                    <dl>\n                      <dt>サービスエンジニアだけの<br class=\"desktop-hidden\" />特別手当</dt>\n                      <dd>\n                        <dl>\n                          <dt>熱中症対策手当（夏）</dt>\n                          <dd>7〜9月、毎月1万円を支給します。</dd>\n                        </dl>\n                        <dl>\n                          <dt>接客向上手当</dt>\n                          <dd>お客様と接するうえでの身だしなみを整えるために、年間5万円を支給します。</dd>\n                        </dl>\n                      </dd>\n                    </dl>\n                  </dd>\n                </dl>\n              </div>\n              <dl class=\"ei-Engineer_Body_WelfareAnother\">\n                <dt>その他にも</dt>\n                <dd>エンジニアウェア貸与（夏・冬5着ずつ）／インナーシャツ貸与（夏・冬4着ずつ）／工具一式貸与（エンジニアキャディ＋ツール）／スポーツドリンク支給（夏）／使い捨てカイロ支給（冬）</dd>\n              </dl>\n            </div>\n          </section>\n        </div>\n      </section>\n    </main>\n    <footer class=\"st-Footer\">\n  <div class=\"container\">\n    <h2 class=\"st-Footer_Header\"><img src=\"/recruit/se/assets/img/common/logo_company.png\" srcset=\"/recruit/se/assets/img/common/logo_company.png 1x, /recruit/se/assets/img/common/logo_company@2x.png 2x\" alt=\"トヨタユナイテッド静岡\" /></h2>\n    <div class=\"st-Footer_Body\">\n      <nav class=\"st-Footer_Nav\">\n        <ul class=\"st-Footer_Nav_Items\">\n          <li class=\"st-Footer_Nav_Item\">\n            <a href=\"https://toyota-unitedshizuoka.co.jp/\" target=\"_blank\">\n              <svg>\n                <use xlink:href=\"#ico_arrow_short\"></use>\n              </svg>\n              コーポレートサイト\n            </a>\n          </li>\n          <li class=\"st-Footer_Nav_Item\">\n            <a href=\"https://toyota-unitedshizuoka.co.jp/recruit/\" target=\"_blank\">\n              <svg>\n                <use xlink:href=\"#ico_arrow_short\"></use>\n              </svg>\n              リクルートサイト\n            </a>\n          </li>\n        </ul>\n      </nav>\n      <p class=\"st-Footer_Copyright\">&copy; TOYOTA UNITED SHIZUOKA</p>\n    </div>\n  </div>\n</footer>    <script src=\"/recruit/se/assets/js/bundle.js?1742880562\"></script>\n  </body>\n</html>\n","finalUrl":"https://toyota-unitedshizuoka.co.jp/recruit/se/education/","rendered":false,"_cachedAt":"2026-06-23T22:48:38.009Z"}