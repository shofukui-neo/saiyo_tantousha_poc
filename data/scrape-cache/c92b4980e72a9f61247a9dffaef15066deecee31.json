" data-src-height=\"3024\" data-src=\"https://image.jimcdn.com/app/cms/image/transf/dimension=1154x10000:format=jpg/path/s5d062c70538095d6/image/icf6d0b5a0e0e942c/version/1505091799/image.jpg\" data-image-id=\"9220971724\"/>    \n\n</figure>\n\n<div class=\"cc-clear\"></div>\n<script id=\"cc-m-reg-14648840424\">// <![CDATA[\n\n    window.regModule(\"module_imageSubtitle\", {\"data\":{\"imageExists\":true,\"hyperlink\":\"\",\"hyperlink_target\":\"\",\"hyperlinkAsString\":\"\",\"pinterest\":\"0\",\"id\":14648840424,\"widthEqualsContent\":\"0\",\"resizeWidth\":\"1154\",\"resizeHeight\":866},\"id\":14648840424});\n// ]]>\n</script></div></div>    </div>\n            <div class=\"cc-m-hgrid-separator\" data-display=\"cms-only\"><div></div></div>\n        <div class=\"cc-m-hgrid-column last\" style=\"width: 49%;\">\n        <div id=\"cc-matrix-4295525324\"><div id=\"cc-m-14648839424\" class=\"j-module n j-header \"><h3 class=\"\" id=\"cc-m-header-14648839424\">カスタマー・サポート</h3></div><div id=\"cc-m-14648839524\" class=\"j-module n j-text \"><p style=\"text-align: left;\">\n    SP（ソリューション・パートナー）と連携し、OA機器（複合機、プリンタ等）や、PC・ネットワークの保守メンテナンスにてお客さまのオフィスワークをバックアップしています。\n</p></div><div id=\"cc-m-14648839624\" class=\"j-module n j-callToAction \"><div class=\"j-calltoaction-wrapper j-calltoaction-align-2\">\n    <a class=\"j-calltoaction-link j-calltoaction-link-style-1\" data-action=\"button\" href=\"/recruit/jobintro/ce/\" data-title=\"詳しく見る\">\n        詳しく見る    </a>\n</div>\n</div></div>    </div>\n    \n<div class=\"cc-m-hgrid-overlay\" data-display=\"cms-only\"></div>\n\n<br class=\"cc-clear\"/>\n\n</div><div id=\"cc-m-14648840524\" class=\"j-module n j-hgrid \">    <div class=\"cc-m-hgrid-column\" style=\"width: 49%;\">\n        <div id=\"cc-matrix-4295525624\"><div id=\"cc-m-14648840624\" class=\"j-module n j-header \"><h3 class=\"\" id=\"cc-m-header-14648840624\">システム開発</h3></div><div id=\"cc-m-14648840724\" class=\"j-module n j-text \"><p style=\"text-align: left;\">\n    お客さま