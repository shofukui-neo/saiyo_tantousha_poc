5px, #fff -2px 1px 5px,\n    #fff 2px -1px 5px, #fff -2px -1px 5px,\n    #fff 1px 1px 5px, #fff -1px 1px 5px,\n    #fff 1px -1px 5px, #fff -1px -1px 5px;\n}\n\n.link_talent:hover {\n   color:#cc0033;\n   text-decoration:none;\n}\n\n.link_talent:visited {\n   color:#cc0033;\n   text-decoration:none;\n}\n\n.tri::before{\n\tcontent: \"\";\n    padding-left:25px;\nbackground: url(https://www.kbs-web.com/docomo/recruit/wp-content/uploads/sites/2/2017/10/img_tri_red.png\n) no-repeat 0px center;\n}\n\n#content input[type=\"submit\"]:hover {\n\tbackground-color: #ccc;\n}\n\n\n\n\n\t\t</style>\n\t\t\n</head>\n\n<body id=\"\" class=\"page-template-default page page-id-100 page-parent\">\n<div id=\"\">\n\n\n<div class=\"header_wrap\">\n<div id=\"header\">\n<div class=\"logo\">\n<a href=\"https://www.kbs-web.com/docomo/recruit/\"><img src=\"https://www.kbs-web.com/docomo/recruit/wp-content/themes/original2/contents_images/logo.png\" width=\"332px\" height=\"70px\" alt=\"KBSドコモ求人サイト｜株式会社ビジネスサービス\"/></a>\n</div>\n\n<div class=\"navi\">\n\t\t\t<div class=\"textwidget\"><p><a class=\"link_talent tri\" href=\"https://www.kbs-web.com/docomo/recruit/message/matters/\">募集要項・ご応募</a>　　<a href=\"https://www.kbs-web.com/\"><img class=\"image wp-image-41 attachment-full size-full\" style=\"max-width: 100%; height: auto;\" src=\"https://www.kbs-web.com/docomo/recruit/wp-content/uploads/sites/2/2017/09/logo_company.png\" alt=\"\" width=\"242\" height=\"38\" /></a></p>\n</div>\n\t\t</div>\n<div style=\"clear: both;\"></div>\n</div>\n</div>\n\n\n<div id=\"menu\">\n\t<div class=\"menu-main-menu-container\"><ul id=\"menu-main-menu\" class=\"menu\"><li id=\"menu-item-141\" class=\"menu-item menu-item-type-custom menu-item-object-custom current-menu-item menu-item-141\"><a href=\"https://www.kbs-web.com/docomo/recruit/message/\" aria-current=\"page\">私たちの想い</a></li>\n<li id=\"menu-item-144\" class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-144\"><a href=\"https://www.kbs-web.com/docomo/recruit/favorite/\">ココが好き！</a></li>\n<li id=\"menu-item-146\" class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-146\"><a href=\"https://www.kbs-web.com/docomo/recruit/shop/\">ショップ紹介</a></li>\n<li id=\"menu-item-150\" class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-150\"><a href=\"https://www.kbs-web.com/docomo/recruit/company/\">企業情報</a></li>\n</ul></div><div style=\"clear: both;\"></div>\n</div>\n\n<div id=\"wrap\">\n<div id=\"content\">\n\n\n<h1>メッセージ</h1>\n\n<div class=\"post\">\n\n<p><img class=\"alignnone wp-image-1061 size-full\" src=\"https://www.kbs-web.com/docomo/recruit/wp-content/uploads/sites/2/2021/08/shinmachi_staff002.png\" alt=\"\" width=\"1500\" height=\"844\" srcset=\"https://www.kbs-web.com/docomo/recruit/wp-content/uploads/sites/2/2021/08/shinmachi_staff002.png 1500w, https://www.kbs-web.com/docomo/recruit/wp-content/uploads/sites/2/2021/08/shinmachi_staff002-300x169.png 300w, https://www.kbs-web.com/docomo/recruit/wp-content/uploads/sites/2/2021/08/shinmachi_staff002-1024x576.png 1024w, https://www.kbs-web.com/docomo/recruit/wp-content/uploads/sites/2/2021/08/shinmachi_staff002-768x432.png 768w\" sizes=\"(max-width: 1500px) 100vw, 1500px\" /></p>\n</p>\n<p>携帯電話会社の中でも国内シェアが一番多いドコモ！<br />\n約半分の国内シェアで長くNo.1を維持。だからこそ永く安定したお仕事ができます。</p>\n</p>\n<p>さらに、ドコモにはスキル認定資格制度があり資格取得で頑張った分だけお給料も上がっていきます。普段のみなさんの頑張りは見逃しません。今、先輩スタッフの胸に輝いているバッジが頑張りと信頼の証です。</p>\n</p>\n<p>そして、いつまでも長く働いて頂く為の福利厚生もしっかり考えています。<br />\nだからこそ、スタッフの喜びはお店の喜び！あなたに家族が増えることは大歓迎！産休・育児休暇も充実しており実績は多数！また戻ってくるあなたの居場所を確保します。</p>\n</p>\n<p>万が一、家庭の都合で引っ越すことになっても大丈夫！ドコモショップは全国にあります。 全国共通のお仕事だから、これから磨いていくスキルは、どこのドコモショップでも通用する一生モノのスキルとなっていくでしょう。</p>\n</p>\n<p>青森県でお仕事を探されている皆さん。ぜひ地域に密着したアットホームなお店でたくさんの仲間たちと働いてみませんか？</p></p>\n\n\n</div>\n \n\t\n</div>\n\n<div id=\"column\">\n\n<!-- ▼親ページ取得▼ -->\n<div class=\"categorytitle\">\n<a href=\"https://www.kbs-web.com/docomo/recruit/message/\">メッセージ</a>\n</div>\n<!-- ▲親ページ取得▲ -->\n\n\n\n<!-- ▼子・孫ページ取得▼ -->\n<ul class=\"categorymenu\">\n<li class=\"page_item page-item-98\"><a href=\"https://www.kbs-web.com/docomo/recruit/message/talent/\">求める人材</a></li>\n<li class=\"page_item page-item-102\"><a href=\"https://www.kbs-web.com/docomo/recruit/message/matters/\">募集要項・ご応募</a></li>\n<li class=\"page_item page-item-268\"><a href=\"https://www.kbs-web.com/docomo/recruit/message/faq/\">FAQ</a></li>\n<li class=\"page_item page-item-643\"><a href=\"https://www.kbs-web.com/docomo/recruit/message/privacy/\">メールでのお問い合わせ</a></li>\n</ul>\n<!-- ▲子・孫ページ取得▲ -->\n\n\n</div><div style=\"clear: both;\"></div>\n\n</div>\n\n\n\n<div class=\"footer_banner\">\n<div class=\"wrap\">\n    \t\t\t<div class=\"block banner\">\n\t\t\t\t\t<p><a href=\"https://www.kbs-web.com/docomo/recruit/message/matters/\"></a><a href=\"https://www.kbs-web.com/docomo/recruit/message/matters/\"><img class=\"alignnone size-full wp-image-368\" src=\"https://www.kbs-web.com/docomo/recruit/wp-content/uploads/sites/2/2017/10/img_otoiawase.jpg\" alt=\"\" width=\"487\" height=\"123\" srcset=\"https://www.kbs-web.com/docomo/recruit/wp-content/uploads/sites/2/2017/10/img_otoiawase.jpg 487w, https://www.kbs-web.com/docomo/recruit/wp-content/uploads/sites/2/2017/10/img_otoiawase-300x76.jpg 300w\" sizes=\"(max-width: 487px) 100vw, 487px\" /></a><a href=\"https://www.kbs-web.com/docomo/recruit/message/faq/\"><img class=\"alignnone size-full wp-image-367\" src=\"https://www.kbs-web.com/docomo/recruit/wp-content/uploads/sites/2/2017/10/img_faq.jpg\" alt=\"\" width=\"487\" height=\"123\" srcset=\"https://www.kbs-web.com/docomo/recruit/wp-content/uploads/sites/2/2017/10/img_faq.jpg 487w, https://www.kbs-web.com/docomo/recruit/wp-content/uploads/sites/2/2017/10/img_faq-300x76.jpg 300w\" sizes=\"(max-width: 487px) 100vw, 487px\" /></a></p>\n\t\t\t\t\t\t\t\t\t</div>\n\t\t\t</div>\n</div>\n\n<div id=\"footerwrap\">\n\n<div class=\"ga_about\" ><span style=\"font-size: 80%;\"></span><span style=\"font-size: 80%;\">\nGoogle Analyticsについて<br />\n当サイトでは、Google Analytics（Google アナリティクス）を利用したアクセス解析を行っています。<br />\nGoogle Analytics は、サイトへのアクセス解析データを収集しますが、取得される情報は匿名のものであり、アクセス情報と閲覧者の個人情報を関連づけるものではありません。解析結果は、当サイトの質の向上、より良いコンテンツの提供を目的として利用するものです。<br />\n</span></div> \n    \n<div id=\"footer\">\n<a href=\"http://www.kbs-web.com/\" target=\"_blank\"><img src=\"https://www.kbs-web.com/docomo/recruit/wp-content/themes/original2/contents_images/footerlogo.png\" width=\"245\" height=\"37\" alt=\"\"/></a>\n<a class=\"link_docomo\" href=\"/docomo/\" target=\"_blank\">KBSドコモショップサイト</a>\n<span class=\"copy\">Copyright (c) 2017 Business Service Co.,LTD. All Rights Reserved. </span> </div></div>\n<a href=\"#\" id=\"page-top\"></a>\n\n<script type='text/javascript'>\n/* <![CDATA[ */\nvar SlimStatParams = {\"ajaxurl\":\"https:\\/\\/www.kbs-web.com\\/docomo\\/recruit\\/wp-admin\\/admin-ajax.php\",\"baseurl\":\"\\/docomo\\/recruit\",\"dnt\":\"noslimstat,ab-item\",\"ci\":\"YTozOntzOjEyOiJjb250ZW50X3R5cGUiO3M6NDoicGFnZSI7czoxMDoiY29udGVudF9pZCI7aToxMDA7czo2OiJhdXRob3IiO3M6OToia2Fucml1c2VyIjt9.513f9b6ea05940f8255fd1a71f71e60f\"};\n/* ]]> */\n</script>\n<script type='text/javascript' src='https://cdn.jsdelivr.net/wp/wp-slimstat/tags/4.8.8.1/wp-slimstat.min.js'></script>\n<script type='text/javascript' src='https://www.kbs-web.com/docomo/recruit/wp-includes/js/wp-embed.min.js?ver=5.4.1'></script>\n\n</div>\n</body>\n</html>","finalUrl":"https://www.kbs-web.com/docomo/recruit/message/","rendered":false,"_cachedAt":"2026-06-24T00:03:59.975Z"}