ger -->\r\n</head>\r\n\r\n<body>\r\n  <!-- Google Tag Manager (noscript) -->\r\n  <noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-P8XXC67\" height=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\r\n  <!-- End Google Tag Manager (noscript) -->\r\n\r\n  <div id=\"header\"></div>\r\n  <script>\r\n    $(function () {\r\n      $('#header').load('https://www.tepco-sa.co.jp/ssl/src/inc/header.html');\r\n    });\r\n  </script>\r\n\r\n  <div class=\"page-wrapper career-top-page\">\r\n    <div class=\"main-container bg-transparent p-0 mb-5\">\r\n      <div class=\"page-banner mx-auto mb-0 d-flex align-items-center\">\r\n        <div class=\"page-title\">採用情報</div>\r\n      </div>\r\n      <nav aria-label=\"breadcrumb\" class=\"page-breadcrumb\">\r\n        <ol class=\"breadcrumb mb-0\">\r\n          <li class=\"breadcrumb-item\"><a href=\"https://www.tepco-sa.co.jp/ssl/\">ホーム</a></li>\r\n          <li class=\"breadcrumb-item active\" aria-current=\"page\">採用情報</li>\r\n        </ol>\r\n      </nav>\r\n    </div>\r\n\r\n    <div class=\"main-container\">\r\n      <div class=\"sc-recruit\">\r\n        <div class=\"btn-group d-flex flex-column flex-md-row justify-content-center align-items-center\">\r\n          <a href=\"https://www.tepco-sa.co.jp/ssl/recruit/new_graduate/\" class=\"fs-20 btnn btnn-orange d-flex align-items-center justify-content-center\">新卒採用\r\n            <svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"currentColor\">\r\n              <path d=\"M13.1717 12.0007L8.22192 7.05093L9.63614 5.63672L16.0001 12.0007L9.63614 18.3646L8.22192 16.9504L13.1717 12.0007Z\">\r\n              </path>\r\n            </svg>\r\n          </a>\r\n          <a href=\"https://www.tepco-sa.co.jp/ssl/recruit/career/\" class=\"fs-20 btnn btnn-yellow fill-orange d-flex align-items-center justify-content-center\">キャリア採用\r\n            <svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"currentColor\">\r\n              <path d=\"M13.1717 12.0007L8.22192 7.05093L9.63614 5.63672L16.0001 12.0007L9.63614 18.3646L8.22192 16.9504L13.1717 12.0007Z\">\r\n              </path>\r\n            </svg>\r\n          </a>\r\n          <a href=\"https://www.tepco-sa.co.jp/ssl/recruit/part_time/\" class=\"fs-20 btnn btnn-blue fill-blue d-flex align-items-center justify-content-center\">契約・パート採用\r\n            <svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"currentColor\">\r\n              <path d=\"M13.1717 12.0007L8.22192 7.05093L9.63614 5.63672L16.0001 12.0007L9.63614 18.3646L8.22192 16.9504L13.1717 12.0007Z\">\r\n              </path>\r\n            </svg>\r\n          </a>\r\n        </div>\r\n      </div>\r\n      <div class=\"link-wrapper mt-5 mb-5\">\r\n        <div class=\"row\">\r\n          <div class=\"col-12 col-sm-6 col-xl-3\">\r\n            <a href=\"#link1\" class=\"d-flex justify-content-center align-items-center\">\r\n              テプコ・ソリューション・<br>アドバンスの特徴\r\n              <svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"currentColor\">\r\n                <path d=\"M13.0001 16.1716L18.3641 10.8076L19.7783 12.2218L12.0001 20L4.22192 12.2218L5.63614 10.8076L11.0001 16.1716V4H13.0001V16.1716Z\">\r\n                </path>\r\n              </svg>\r\n            </a>\r\n          </div>\r\n          <div class=\"col-12 col-sm-6 col-xl-3\">\r\n            <a href=\"#link2\" class=\"d-flex justify-content-center align-items-center\">\r\n              おしごと紹介\r\n              <svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"currentColor\">\r\n                <path d=\"M13.0001 16.1716L18.3641 10.8076L19.7783 12.2218L12.0001 20L4.22192 12.2218L5.63614 10.8076L11.0001 16.1716V4H13.0001V16.1716Z\">\r\n                </path>\r\n              </svg>\r\n            </a>\r\n          </div>\r\n          <div class=\"col-12 col-sm-6 col-xl-3\">\r\n            <a href=\"#link3\" class=\"d-flex justify-content-center align-items-center\">\r\n              人事ポリシー\r\n              <svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"currentColor\">\r\n                <path d=\"M13.0001 16.1716L18.3641 10.8076L19.7783 12.2218L12.0001 20L4.22192 12.2218L5.63614 10.8076L11.0001 16.1716V4H13.0001V16.1716Z\">\r\n                </path>\r\n              </svg>\r\n            </a>\r\n          </div>\r\n          <div class=\"col-12 col-sm-6 col-xl-3\">\r\n            <a href=\"#link4\" class=\"d-flex justify-content-center align-items-center\">\r\n              求める人財像\r\n              <svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"currentColor\">\r\n                <path d=\"M13.0001 16.1716L18.3641 10.8076L19.7783 12.2218L12.0001 20L4.22192 12.2218L5.63614 10.8076L11.0001 16.1716V4H13.0001V16.1716Z\">\r\n                </path>\r\n              </svg>\r\n            </a>\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n      <div class=\"wrapper\">\r\n        <div class=\"side-label\" id=\"link1\">テプコ・ソリューション・アドバンスの特徴</div>\r\n        <p class=\"para-text text-center mb-5\">当社の職場環境や休暇制度、取り組みなどをご紹介</p>\r\n        <div class=\"recruit-top-environment\">\r\n          <a href=\"https://www.tepco-sa.co.jp/ssl/recruit/environment_and_system/#link1\"><img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/img_service01.png\" alt=\"働く環境\"></a>\r\n          <a href=\"https://www.tepco-sa.co.jp/ssl/recruit/environment_and_system/#link2\"><img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/img_service02.png\" alt=\"カイゼンの取組\"></a>\r\n          <a href=\"https://www.tepco-sa.co.jp/ssl/recruit/environment_and_system/#link3\"><img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/img_service03.png\" alt=\"女性活躍促進\"></a>\r\n        </div>\r\n\r\n      </div>\r\n      <div class=\"wrapper\">\r\n        <div class=\"side-label\" id=\"link2\">おしごと紹介</div>\r\n        <div class=\"graduate-list\">\r\n          <a href=\"https://www.tepco-sa.co.jp/ssl/recruit/work_contents/office_work/\" class=\"graduate\">\r\n            <div class=\"graduate-image\">\r\n              <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/work_contents/img_item01.png\" alt=\"graduate-img\">\r\n            </div>\r\n            <div class=\"info-box\">\r\n              <div class=\"title fw-bold text-center\">事務職</div>\r\n            </div>\r\n          </a>\r\n          <a href=\"https://www.tepco-sa.co.jp/ssl/recruit/work_contents/technical_job/\" class=\"graduate\">\r\n            <div class=\"graduate-image\">\r\n              <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/work_contents/img_item02.png\" alt=\"graduate-img\">\r\n            </div>\r\n            <div class=\"info-box\">\r\n              <div class=\"title fw-bold text-center\">技術職</div>\r\n            </div>\r\n          </a>\r\n          <a href=\"https://www.tepco-sa.co.jp/ssl/recruit/work_contents/handicap/\" class=\"graduate\">\r\n            <div class=\"graduate-image\">\r\n              <img src=\"https://www.tepco-sa.co.jp/ssl/images/recruit/work_contents/img_item03.png\" alt=\"graduate-img\">\r\n            </div>\r\n            <div class=\"info-box\">\r\n              <div class=\"title fw-bold text-center\">障がいのある方</div>\r\n            </div>\r\n          </a>\r\n        </div>\r\n      </div>\r\n\r\n      <div class=\"wrapper\">\r\n        <div class=\"side-label\" id=\"link3\">人事ポリシー</div>\r\n        <div class=\"recruit-top-policy\">\r\n          <div>「お客さまサービスを革新し、社会から必要とされる会社」であるために</div>\r\n          <p class=\"para-text mb-0\">お客さまの信頼を得て、競争を勝ち抜いていくためにはTSAは常に変化・成長していくことが必要です。そのためには「一人ひとりが挑戦し組織として成果を出す人財集団」でなければならないと考えます。</p>\r\n        </div>\r\n        <div class=\"recruit-top-policy-list\">\r\n          <div class=\"recruit-top-policy-item\">\r\n            <div>ベンチャー魂で<br>挑戦し続けることを求めます</div>\r\n            <p class=\"para-text mb-0\">一人ひとりが変化を楽しみ、何事にも何度でも挑戦し続けることが、高い成果を出す組織に繋がると考えています。</p>\r\n          </div>\r\n          <div class=\"recruit-top-policy-item\">\r\n            <div>挑戦・成果に<br>報いていきます</div>\r\n            <p class=\"para-text mb-0\">一人ひとりの挑戦とその成果を評価し、頑張った人に報いていきます。</p>\r\n          </div>\r\n          <div class=\"recruit-top-policy-item\">\r\n            <div>活躍の場を<br>\r\n              整えていきます</div>\r\n            <p class=\"para-text mb-0\">一人ひとりが働き甲斐を感じながら成長できる仕組みや働き方の選択肢を整え、意欲ある者へ活躍の機会を提供していきます。</p>\r\n          </div>\r\n        </div>\r\n      </div>\r\n      <div class=\"wrapper\">\r\n        <div class=\"side-label\" id=\"link4\">求める人財像</div>\r\n        <div class=\"row row-cols-1 row-cols-md-3\">\r\n          <div class=\"mb-3\">\r\n            <div class=\"ini-bg\">\r\n              <div class=\"ini-title fs-20 fw-bold text-center\">お客さま目線</div>\r\n              <p class=\"para-text mb-0\">\r\n                お客さま目線で考え、行動し、お客さまの満足を自らの喜びとできる人財\r\n              </p>\r\n            </div>\r\n          </div>\r\n          <div class=\"mb-3\">\r\n            <div class=\"ini-bg\">\r\n              <div class=\"ini-title fs-20 fw-bold text-center\">自発的挑戦</div>\r\n              <p class=\"para-text mb-0\">\r\n                『出来ない』ではなく、『やるためにどうするか』という大胆な発想で挑戦し、自ら価値を創造する人財\r\n              </p>\r\n            </div>\r\n          </div>\r\n          <div class=\"mb-3\">\r\n            <div class=\"ini-bg\">\r\n              <div class=\"ini-title fs-20 fw-bold text-center\">チームワーク</div>\r\n              <p class=\"para-text mb-0\">\r\n                コミュニケーションやチームワークを重んじ、組織の目標達成に全力でコミットする人財\r\n              </p>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n  <!-- main content -->\r\n\r\n  <div id=\"footer\"></div>\r\n  <script defer>\r\n    $(function () {\r\n      $('#footer').load('https://www.tepco-sa.co.jp/ssl/src/inc/footer.html');\r\n    });\r\n  </script>\r\n  <script src=\"https://www.tepco-sa.co.jp/ssl/src/js/popper.min.js\"></script>\r\n  <script src=\"https://www.tepco-sa.co.jp/ssl/src/js/bootstrap.min.js\"></script>\r\n  <script src=\"https://www.tepco-sa.co.jp/ssl/src/js/slick.js\"></script>\r\n  <script src=\"https://www.tepco-sa.co.jp/ssl/src/js/jquery.matchHeight-min.js\"></script>\r\n  <script src=\"https://www.tepco-sa.co.jp/ssl/src/js/custom.js\"></script>\r\n</body>\r\n\r\n</html>","finalUrl":"https://www.tepco-sa.co.jp/ssl/recruit/","rendered":false,"_cachedAt":"2026-06-14T19:39:39.754Z"}