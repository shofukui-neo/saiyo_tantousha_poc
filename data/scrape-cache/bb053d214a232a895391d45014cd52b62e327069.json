pan class=\"toggler-icon\"></span>\n                                <span class=\"toggler-icon\"></span>\n                                <span class=\"toggler-icon\"></span>\n                            </button> <!-- navbar toggler -->\n                            <div class=\"collapse navbar-collapse sub-menu-bar\" id=\"navbarFive\">\n                                   <nav role=\"navigation\" aria-labelledby=\"block-careernw-front-main-menu-menu\" id=\"block-careernw-front-main-menu\">\n          \n\n        \n          <ul class=\"navbar-nav m-auto\">\n                    <li class=\"nav-item\">\n        <a class=\"page-scroll\" href=\"/\">ホーム</a>\n        \n                  </li>\n                  <li class=\"nav-item\">\n        <a class=\"page-scroll\" href=\"/job\">求人を探す</a>\n        \n                  </li>\n                  <li class=\"nav-item\">\n        <a class=\"page-scroll\" href=\"/bookmarks\">検討リスト</a>\n        \n                  </li>\n                  <li class=\"nav-item\">\n        <a class=\"page-scroll\" href=\"/works\">お仕事をお探しの方</a>\n        \n                  </li>\n                  <li class=\"nav-item\">\n        <a class=\"page-scroll\" href=\"/jinzai\">採用ご担当者様</a>\n        \n                  </li>\n                  <li class=\"nav-item\">\n        <a class=\"page-scroll\" href=\"/company/access\">アクセスマップ</a>\n        \n                  </li>\n                  <li class=\"nav-item\">\n        <a class=\"page-scroll\" href=\"/column\">コラム・お知らせ</a>\n        \n                  </li>\n      </ul>\n  \n\n\n  </nav>\n<div id=\"block-header-top-entry-btn\">\n  \n    \n      <a class=\"btn btn-register-h\" href=\"/reg-entry/1416\">お仕事紹介エントリー<span>（無料）</span></a>\n  </div>\n\n\n                              \n                            </div>\n                            <div class=\"navbar-btn d-none d-sm-inline-block\">\n                                  \n                            </div>\n                        </nav> <!-- navbar -->\n                    </div>\n                </div>\n            </div>\n        </div>\n    </header>\n\t<div class=\"breadcrumb-area\">\n\t <div class=\"container\">\n\t\t<div class=\"row\">\n\t <nav aria-label=\"breadcrumb\">    <div id=\"block-careernw-front-breadcrumbs\">\n  \n    \n      \n\n<ol class=\"breadcrumb\">\n                                                        \t\t\t\t\t\t\t<li class=\"breadcrumb-item\"><a href=\"/\"> ホーム </a> </li>\n                             \n                                                        \t\t\t\t\t\t\t<li class=\"breadcrumb-item\" aria-current=\"page\">選ばれる理由</li>\n                             \n                            </ol>\n\n\n\n  </div>\n\n</nav>\n\t\t</div>\n\t </div> \n\t</div>\n\t\t<div class=\"page-title-area\">\n\t\t<div class=\"container\">\n\t\t\t<div class=\"row\">\n\t\t\t\t<div class=\"col-lg-12\">\n\t\t\t\t\t<div class=\"page-title-content\">\n\t\t\t\t\t\t<h1 class=\"title\"><span class=\"field field--name-title field--type-string field--label-hidden\">選ばれる理由</span>\n</h1>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\t </div>\n\t\n\n\n\n\n\n\n\t\t\t<div class=\"container w900 maincontent\">\n\t\t\t<div class=\"row\">\n\n\t\t\t\t\t\t\t\t\t<div class=\"col-lg-3 content_area_left\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t    <div id=\"block-client\">\n  \n      <h2>採用ご担当者様</h2>\n    \n      <div class=\"client\">\n  <input id=\"ac_side\" name=\"ac_job_worker\" type=\"checkbox\" />\n  <label for=\"ac_side\">採用ご担当者様</label>\n<ul>\n  <li><a href=\"/jinzai\">選ばれる理由</a></li>\n  <li><a href=\"/service\">人材派遣・紹介</a></li>\n  <li><a href=\"/vietnam-engineer\">ベトナム人技術者紹介</a></li>\n  <li><a href=\"/clientsenior\">シニア人材派遣・紹介</a></li>\n  <li><a href=\"/seminar\">研修セミナー</a></li>\n\n\n</ul>\n</div>\n  </div>\n\n\n\t\t\t\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\n\n\t\t\t\t<div\n\t\t\t\t\tclass=\"col content_area_center\">\n\n\t\t\t\t\t\t\t\t\t\t\n\t\t\t\t\t\t\t\t\t\t\n\t\t\t\t\t    <div data-drupal-messages-fallback class=\"hidden\"></div><div id=\"block-careernw-front-content\" class=\"block-front-content\">\n  \n    \n      \n<section data-history-node-id=\"72\" role=\"article\" class=\"node node--type-page page-details pt-20 pb-70 page full clearfix\">\n    <div class=\"container\">\n        <div class=\"align-items-center\">\n        \n            <div class=\"clearfix text-formatted field field--name-body field--type-text-with-summary field--label-hidden field__item\"><div class=\"page-jinzai\">\n  <div class=\"point\">\n    <h2 class=\"deco-ttl\">そのお悩み<br class=\"sp\">キャリアネットワークが解決します！<span>他とはココが違う！</span>キャリアネットワークが選ばれる理由</h2>\n    \n    <div class=\"wrap\">\n      <img class=\"icon\" src=\"/themes/custom/careernw_front/custom/img/contents/jinzai/point01.svg\" alt=\"スピード紹介\">\n      <h3>スピード対応</h3>\n      <p>最短で、ご依頼いただいた日の翌日から就業できる人材をご紹介します。<br>登録スタッフ10,000人以上、各種業務の経験者が多数在籍しているので、お客様のニーズにマッチした即戦力をスピーディーにご紹介します。<br>ご提案が難しい場合には代案提示や提案の見込みを即日ご案内します。</p>\n    </div>\n\n    <div class=\"wrap\">\n      <img class=\"icon\" src=\"/themes/custom/careernw_front/custom/img/contents/jinzai/point02.svg\" alt=\"採用コンサルティング\">\n      <h3>採用コンサルティング</h3>\n      <p>経営課題の解決のため一歩進んだ採用コンサルティング提案を致します。<br>採用のノウハウがない、専任の採用担当者がいない、目標の採用人数に届かない、早期離職者が多いなどの採用に関する課題に対して、課題解決のためのさまざまなサポートを行います。</p>\n    </div>\n\n    <div class=\"wrap\">\n      <img class=\"icon\" src=\"/themes/custom/careernw_front/custom/img/contents/jinzai/point03.svg\" alt=\"求人企業満足度92%\">\n      <h3>求人企業満足度92%</h3>\n      <p>福井県内に特化し当社の人材コーディネーターは求人企業のリアルを取材します。<br>ミスマッチ解消と人材の定着のため臨機応変なスタッフフォロー体制を敷いています。<br>取引社数は福井県内の企業様を中心に1,600社以上。求人リピート率は91%です。※2023年12月<br>福井県内、求人数最多の当社は求人企業から信頼を得ている証です。<br>これからも信頼・安心できるサービスを提供いたします。</p>\n    </div>\n  </div>\n\n  <div class=\"lead\">\n    <div class=\"cta-area\">\n      <p class=\"text-left\">人材確保・人手不足にお悩みの方、短期間で大量の人材募集が必要などの、あらゆるご要望にお応えします。<br>人材派遣、人材紹介ご相談、発注、お見積りなどはこちらよりお問い合わせください。</p>\n      <a class=\"btn cta\" href=\"/form/job-contact\">求人お問い合せフォーム</a>\n    </div>\n  </div>\n\n  <div class=\"check-list-area\">\n    <h3><span>こんなことでお困りではありませんか？</span></h3>\n    <div class=\"note\">\n      <ul class=\"check\">\n        <li>急な欠員が出たので至急、補充したい</li>\n        <li>経験者・即戦力のコアな人材が欲しい</li>\n        <li>ハローワークでは理想通りの人材に会えない</li>\n        <li>良い人材の情報を随時欲しい</li>\n        <li>効率よく効果的に通年採用を行いたい</li>\n      </ul>\n    </div>\n\n    <p>上記に一つでもチェックがついたら・・・</p>\n    <div class=\"cta-area\">\n      <a class=\"btn cta\" href=\"/form/job-contact\">求人お問い合せフォーム</a>\n    </div>\n  </div>\n\n  <!-- <div class=\"cta-area\">\n    <a class=\"btn cta\" href=\"/form/job-contact\">求人お問い合せフォーム</a>\n  </div> -->\n\n  <div class=\"flow-up-to-use\">\n    <h2>ご利用までの流れ</h2>\n\n    <p>ご依頼を頂いてから、スポット派遣であれば最短翌日より就業が可能です。</p>\n\n    <div class=\"flow-list\">\n      <div class=\"flow-box\">\n        <div class=\"left\">\n          <span class=\"step\">Step01</span>\n          <p class=\"ttl\">派遣のご依頼・ご相談</p>\n        </div>\n        <div class=\"right\">\n          <p>お問い合わせフォームよりお気軽にお問い合わせください。内容を確認後担当者より迅速にご連絡差し上げます。<br>また、お急ぎの場合は直接お電話にて承ります。</p>\n        </div>\n      </div>\n      \n      <div class=\"flow-box\">\n        <div class=\"left\">\n          <span class=\"step\">Step02</span>\n          <p class=\"ttl\">ヒアリング</p>\n        </div>\n        <div class=\"right\">\n          <p>詳細な業務内容やスキル・経験などの詳細をお伺いいたします。<br>初めて派遣・ご紹介をご利用される法人様にはサービス概要のご説明もさせていただきます。</p>\n        </div>\n      </div>\n\n      <div class=\"flow-box\">\n        <div class=\"left\">\n          <span class=\"step\">Step03</span>\n          <p class=\"ttl\">手配・契約締結<br>（派遣スタッフ）</p>\n        </div>\n        <div class=\"right\">\n          <p>要件が決まりましたらご要望される人材を選出、派遣スタッフであれば最短翌日から就業可能です。<br>合わせて契約を締結いたします。</p>\n        </div>\n      </div>\n\n      <div class=\"flow-box\">\n        <div class=\"left\">\n          <span class=\"step\">Step04</span>\n          <p class=\"ttl\">マッチング<br>（紹介・紹介予定派遣）</p>\n        </div>\n        <div class=\"right\">\n          <p>当社データベースにてスクリーニング、選出を行います。<br>人材がマッチできましたら、まずはご提案いたします。</p>\n        </div>\n      </div>\n\n      <div class=\"flow-box\">\n        <div class=\"left\">\n          <span class=\"step\">Step05</span>\n          <p class=\"ttl\">契約締結<br>（紹介・紹介予定派遣）</p>\n        </div>\n        <div class=\"right\">\n          <p>当社、貴社、人材の3者による就業条件の確認、決定を行い、契約を締結いたします。</p>\n        </div>\n      </div>\n    </div>\n  </div>\n\n</div></div>\n      \n        </div>\n    </div>\n</section>\n  </div>\n\n\n\n\n\t\t\t\t\t\t\t\t\t\t\n\t\t\t\t</div>\n\n\n\t\t\t\t\n\n\t\t\t</div>\n\t\t</div>\n\t\n\n\n\t<div id=\"content_fix\" class=\"floatingBnr\">\n\t\t\t\t\t    <div id=\"block-footer-fixed\">\n  \n    \n      <div class=\"floating-bnr\">\n  <a href=\"/reg-entry/1416\" class=\"bnr btn\">\n    <p>お仕事紹介エントリー<span>（無料）</span></p>\n  </a>\n  <div class=\"btn-close\" id=\"bnr-close\">\n    <span></span>\n    <span></span>\n  </div>\n</div>\n  </div>\n\n\n\t\t\t</div>\n\n\n<!-- Main Footer -->\n<footer class=\"footer-area\">\n\t        <div class=\"container\">\n            <div class=\"row\">\n                                                                                                <div class=\"col-lg-12 col-md-12 col-sm-12\">\n                        <div class=\"views-element-container footer-area-links area-wrap accordion\" id=\"block-views-block-top-footer-taxo-links-block-2\">\n  \n      <h2>こだわり条件</h2>\n    \n      <div><div class=\"js-view-dom-id-949967a25f48eea0fedb33bb88d6b31bf3e7dc041e74405b5d6f658aca003683\">\n  \n  \n  \n\n  \n  \n  \n\n      <div class=\"views-row\"><div class=\"views-field views-field-name\"><span class=\"field-content\"><a href=\"/taxonomy/term/80\" hreflang=\"ja\">時間相談可</a></span></div></div>\n    <div class=\"views-row\"><div class=\"views-field views-field-name\"><span class=\"field-content\"><a href=\"/taxonomy/term/88\" hreflang=\"ja\">公共交通機関で通勤可</a></span></div></div>\n    <div class=\"views-row\"><div class=\"views-field views-field-name\"><span class=\"field-content\"><a href=\"/taxonomy/term/82\" hrefla