/div>\n                <div class=\"btn-arrow\"></div>\n              </div>\n            </a>\n            <!-- 05 -->\n            <a href=\"./interview/interview05.html\" class=\"people_interview-item\">\n              <img src=\"images/top/top_interview05.jpg\">\n              <div class=\"people_interview-item-name\">\n                <div class=\"nameWrap\">\n                  <p>2011年 新卒入社</p>\n                  <p>営業推進</p>\n                  <p>R.S.</p>\n                </div>\n                <div class=\"btn-arrow\"></div>\n              </div>\n            </a>\n            <!-- 06 -->\n            <a href=\"./interview/interview06.html\" class=\"people_interview-item\">\n              <img src=\"images/top/top_interview06.jpg\">\n              <div class=\"people_interview-item-name\">\n                <div class=\"nameWrap\">\n                  <p>2016年 中途入社</p>\n                  <p>システムエンジニア</p>\n                  <p>K.K.</p>\n                </div>\n                <div class=\"btn-arrow\"></div>\n              </div>\n            </a>\n          </div>\n          <div class=\"people_interview-list\">\n            <a href=\"./interview/\" class=\"people_interview-list-wrap\">\n              <p>一覧を見る</p><div class=\"btn-arrow\"></div>\n            </a>\n          </div>\n        </div>\n        <!-- project -->\n        <div class=\"people_project\">\n          <div class=\"people_project-hd\"><p>Project story<span>プロジェクトストーリー</span></p></div>\n          <div class=\"people_project-wrap\">\n            <!-- 01 -->\n            <a href=\"./project/project01.html\" class=\"people_project-item\">\n              <img src=\"images/top/top_project01.jpg\" loading=\"lazy\">\n              <div class=\"people_project-item-title\">\n                <div class=\"people_project-item-wrap\">\n                  <div class=\"people_project-item-category\">Project 01</div><br>\n                  <p>高度な技術力と部門を越えた連携が、</p>\n                  <p>業界初の革命を起こす。</p>\n       