b/offer/proship\" class=\"handicapped\" target=\"_blank\"><span>ダイバーシティ採用</span><p>募集要項</p></a>\n        </div>\n      </div>\n      <div class=\"menu_nav\">\n        <div class=\"menu_nav-item\">\n          <p>トップページ<br><span>Top</span></p>\n          <div class=\"menu_nav-link\"><a href=\"./\">トップページ</a></div>\n        </div>\n        <div class=\"menu_nav-item\">\n          <p>私たちについて<br><span>About us</span></p>\n          <div class=\"menu_nav-link\"><a href=\"./message/\">トップメッセージ</a></div>\n          <div class=\"menu_nav-link\"><a href=\"./step/\">プロシップを知る4ステップ</a></div>\n          <div class=\"menu_nav-link\"><a href=\"./keywords/\">キーワードでわかるプロシップ</a></div>\n          <div class=\"menu_nav-link\"><a href=\"./numbers/\">数字でわかるプロシップ</a></div>\n        </div>\n        <div class=\"menu_nav-item\">\n          <p>人と仕事について<br><span>People & job</span></p>\n          <div class=\"menu_nav-link hd\">職種紹介</div>\n          <div class=\"menu_nav-link sub\"><a href=\"./job-category/sales.html\">営業職</a></div>\n          <div class=\"menu_nav-link sub\"><a href=\"./job-category/development.html\">開発職</a></div>\n          <div class=\"menu_nav-link\"><a href=\"./interview/\">社員インタビュー一覧</a></div>\n          <div class=\"menu_nav-link hd\">プロジェクトストーリー</div>\n          <div class=\"menu_nav-link sub\"><a href=\"./project/project01.html\">Project 01</a></div>\n          <div class=\"menu_nav-link sub\"><a href=\"./project/project02.html\">Project 02</a></div>\n          <div class=\"menu_nav-link\"><a href=\"./crosstalk/\">社員座談会</a></div>\n        </div>\n        <div class=\"menu_nav-item\">\n          <p>働く環境について<br><span>Environment</span></p>\n          <div class=\"menu_nav-link\"><a href=\"./hr-philosophy/\">人事理念</a></div>\n          <div class=\"menu_nav-link\"><a href=\"./faq/\">よくある質問</a></div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <main class=\"toppage\">\n    <!-- mv -->\n    <section class=\"mv\">\n      <div class=\"mv_copy\" data-aos=\"fade-up\" data-aos-duration=\"1500\">\n        <p class=\"mv_copy-overlay\"><span class=\"mv_copy-en\">SET SAIL<br>FOR<br>THE FUTURE</span><br><span class=\"mv_copy-ja\">世界一になる、日本一の仲間と。</span></p>\n        <p><span class=\"mv_copy-en\">SET SAIL<br>FOR<br>THE FUTURE</span><br><span class=\"mv_copy-ja\">世界一になる、日本一の仲間と。</span></p>\n      </div>\n      <div id=\"mvEarth\"></div>\n      <div id=\"mvBg\"></div>\n    </section>\n\n    <!-- lead -->\n    <section class=\"lead\">\n      <div class=\"lead_inner inner\" data-aos=\"fade-up\" data-aos-duration=\"1400\" >\n        <div class=\"lead_hd\">- Message -</div>\n        <p>コンサルティングからスタートし、<br>\n          「固定資産管理」に特化した自社製品を開発、<br>\n          自らの手で導入までも手掛けるプロシップ。<br>\n          <br>\n          高い専門性を有し、<br class=\"sponly\">業界のトップランナーである私たちは国内シェアNo1。<br>\n          国内大手企業の2社に1社が、<br class=\"sponly\">私たちのシステムを導入しています。<br>\n          しかし、私たちは現状に満足していません。<br>\n          <br>\n          目指すのは“世界一”<br>\n          世界シェアでトップに立つこと。<br>\n          多くの人たちへ、世界中の企業へ、<br class=\"sponly\">私たちの「Speciality」を届けます。<br>\n          <br>\n          すでに、海外各国の税制に対応したシステムを開発し、<br class=\"sponly\">導入を進めています。<br>\n          “世界一”という目標を、最高の仲間たちと創る社員一人ひとりが主役の最高のチームで達成する。<br>\n          <br>\n          ITや会計に関する専門知識や技術は、入社してから学べばいい。<br>\n          大切なのは、プロフェッショナルとして、<br class=\"sponly\">共に“世界一”を目指したいかどうか。<br>\n          <br>\n          「ひとつのことを突き詰めた先に、どんな景色が見えるのか」<br>\n          プロシップで、その答えを見つけてください。</p>\n      </div>\n      <div class=\"lead_bg\"></div>\n    </section>\n\n    <!-- about us -->\n    <section class=\"about\">\n      <div class=\"about_hd section-hd\" data-aos=\"fade-left\"><h2>私たちについて</h2><br><p>About us</p></div>\n      <div class=\"about_inner inner\">\n        <div class=\"about_row row01\">\n          <a href=\"./message/\" class=\"about_item item01\">\n            <div class=\"about_item-wrap\">\n              <span>Top Message</span><p>トップメッセージ</p><div class=\"btn-arrow navy\"></div>\n            </div>\n            <img src=\"images/top/top_message.png\">\n          </a>\n          <a href=\"./numbers/\" class=\"about_item item02\">\n            <div class=\"about_item-wrap\">\n              <span>Numbers</span><p>数字でわかるプロシップ</p><div class=\"btn-arrow navy\"></div>\n            </div>\n            <img src=\"images/top/top_numbers.png\">\n          </a>\n        </div>\n        <div class=\"about_row row02\">\n          <a href=\"./step/\" class=\"about_item item03\">\n            <div class=\"about_item-wrap\">\n              <span>4Step</span><p>プロシップを知る4ステップ</p><div class=\"btn-arrow navy\"></div>\n            </div>\n            <img src=\"images/top/top_step.png\">\n          </a>\n          <a href=\"./keywords/\" class=\"about_item item04\">\n            <div class=\"about_item-wrap\">\n              <span>Keywords</span><p>キーワードでわかるプロシップ</p><div class=\"btn-arrow navy\"></div>\n            </div>\n            <img src=\"images/top/top_keywords.png\">\n          </a>\n        </div>\n      </div>\n    </section>\n\n    <!-- people & job -->\n    <section class=\"people\">\n      <div class=\"people_hd section-hd\" data-aos=\"fade-right\"><h2>人と仕事について</h2><br><p>People<span>&</span>job</p></div>\n      <div class=\"people_inner inner\">\n        <!-- occupation -->\n        <div class=\"people_occupation\">\n          <div class=\"people_occupation-hd\"><p>Job-category<span>職種紹介</span></p></div>\n          <div class=\"people_occupation-wrap\">\n            <a href=\"./job-category/sales.html\" class=\"people_occupation-item\">\n              <div class=\"itemWrap\"><span>Sales</span><p>営業職を知る</p></div>\n              <div class=\"btn-arrow white\"></div>\n            </a>\n            <a href=\"./job-category/development.html\" class=\"people_occupation-item\">\n              <div class=\"itemWrap\"><span>Development</span><p>開発職を知る</p></div>\n              <div class=\"btn-arrow white\"></div>\n            </a>\n          </div>\n        </div>\n        <!-- interview -->\n        <di