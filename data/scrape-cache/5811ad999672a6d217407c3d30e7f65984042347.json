{"url":"https://www.nishi-tc.co.jp/recruit/career01.html","html":"<!DOCTYPE html>\r\n<html lang=\"ja\">\r\n<head>\r\n<meta charset=\"utf-8\">\r\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge,chrome=1\">\r\n<meta name=\"keywords\" content=\"西谷技術,西谷技術コンサルタント,西谷技術コンサルタント,新卒採用,新卒,鳥取,設計,地質調査,測量調査\" />\r\n<meta name=\"description\" content=\"西谷技術コンサルタント株式会社 2014年入社の測量調査部の先輩の声をお届けします。仕事内容やタイムスケジュールをご覧いただけます。\" />\r\n<title>上司からのメッセージ\r\n設計本部 設計部長 2026年度新卒採用情報 西谷技術コンサルタント株式会社</title>\r\n<link href=\"css/reset.css\" rel=\"stylesheet\" type=\"text/css\" />\r\n<link href=\"css/common.css\" rel=\"stylesheet\" type=\"text/css\" />\r\n<link href=\"css/career.css\" rel=\"stylesheet\" type=\"text/css\" />\r\n<link rel=\"stylesheet\" href=\"css/drawer.min.css\">\r\n<link rel=\"stylesheet\" href=\"css/animate.css\">\r\n<script type=\"text/javascript\" src=\"https://ajax.googleapis.com/ajax/libs/jquery/1.9.1/jquery.min.js\"></script>\r\n<script type=\"text/javascript\" src=\"js/yuga.js\"></script>\r\n<script src=\"js/wow.min.js\"></script>\r\n<script type=\"text/javascript\" charset=\"utf-8\">new WOW().init();</script>\r\n<script type=\"text/javascript\" charset=\"utf-8\">$(document).ready(function() {$(\".drawer\").drawer();});</script>\r\n</head>\r\n\r\n<body class=\"drawer drawer--left\">\r\n<!--ここからヘッダー--> \r\n<header style=\"z-index: 1000;\">\r\n  <div class=\"top_navi\">\r\n    <ul>\r\n      <li><a href=\"../index.html\"><img src=\"images/navi/navi_nishitani.png\"></a></li>\r\n      <li style=\"margin:0px 100px 0px 50px\"><a href=\"./index.html\"><img src=\"images/navi/recruit_title.png\"></a></li>\r\n      <li><a href=\"https://job.mynavi.jp/28/pc/search/corp207090/outline.html\" target=\"_blank\"><img\r\n            src=\"images/navi/navi_my.png\"></a></li>\r\n      <li style=\"margin:0px 0px 0px 50px\"><a href=\"https://works.do/R/ti/p/saiyo@nishi-tc\" target=\"_blank\"><img\r\n            src=\"images/navi/QRcode.png\"></a></li>\r\n    </ul>\r\n  </div>\r\n  <nav class=\"global_menu\">\r\n    <ul>\r\n\r\n      <li class=\"menu\"><a href=\"index.html\">採用トップ</a></li>\r\n      <li class=\"menu\">\r\n        <a href=\"#\">メッセージ</a>\r\n        <ul class=\"child_menu\">\r\n\r\n          <p class=\"navi_komidashi\">先輩社員からのメッセージ</p>\r\n          <li><a href=\"./voice01.html\"><img src=\"images/navi/navi01.png\" class=\"icon_photo\"><span class=\"navi_txt\">調査部\r\n                防災設計</span></a></li>\r\n          <li><a href=\"./voice02.html\"><img src=\"images/navi/navi02.png\" class=\"icon_photo\"><span class=\"navi_txt\">設計部\r\n                道路設計</span></a></li>\r\n          <li><a href=\"./voice03.html\"><img src=\"images/navi/navi03.png\" class=\"icon_photo\"><span class=\"navi_txt\">調査部\r\n                地質調査</span></a></li>\r\n          <li><a href=\"./voice05.html\"><img src=\"images/navi/navi04.png\" class=\"icon_photo\"><span\r\n                class=\"navi_txt\">地籍調査部</span></a></li>\r\n          <li><a href=\"./voice06.html\"><img src=\"images/navi/navi05.png\" class=\"icon_photo\"><span\r\n                class=\"navi_txt\">測量調査部<br>補償コンサルタント</span></a></li>\r\n          <li><a href=\"./voice04.html\"><img src=\"images/navi/navi06.png\" class=\"icon_photo\"><span class=\"navi_txt\">企画管理部\r\n                営業</span></a></li>\r\n\r\n          <p class=\"navi_komidashi\">上司からのメッセージ／採用担当からのメッセージ</p>\r\n          <li><a href=\"./career01.html\"><img src=\"images/navi/navi07.png\" class=\"icon_photo\"><span\r\n                class=\"navi_txt\">設計部 部長</span></a></li>\r\n          <li><a href=\"./career02.html\"><img src=\"images/navi/navi08.png\" class=\"icon_photo\"><span\r\n                class=\"navi_txt\">地籍調査部 課長</span></a></li>\r\n          <li><a href=\"./career03.html\"><img src=\"images/navi/navi09.png\" class=\"icon_photo\"><span\r\n                class=\"navi_txt\">調査部 維持保全課 課長</span></a></li>\r\n          <li><a href=\"./career04.html\"><img src=\"images/navi/navi10.png\" class=\"icon_photo\"><span\r\n                class=\"navi_txt\">企画経理部 企画管理課<br>総務担当課長</span></a></li>\r\n          <li><a href=\"./voice07.html\"><img src=\"images/navi/navi_mess.png\"><span class=\"navi_txt\"></span></a></li>\r\n\r\n        </ul>\r\n      </li>\r\n\r\n      <li class=\"menu\">\r\n        <a href=\"#\">インタビュー</a>\r\n        <ul class=\"child_menu\">\r\n          <li class=\"inta\"><a href=\"./job.html\"><img src=\"images/navi/navi_i01.png\"></a></li>\r\n          <li class=\"inta\"><a href=\"./staff.html\"><img src=\"images/navi/navi_i02.png\"></a></li>\r\n          <li class=\"inta\"><a href=\"./staff.html#hope\"><img src=\"images/navi/navi_i03.png\"></a></li>\r\n        </ul>\r\n      </li>\r\n\r\n      <li class=\"menu\">\r\n        <a href=\"#\">募集要項</a>\r\n        <ul class=\"child_menu\">\r\n          <li><a href=\"./new-job-description.html\"><img src=\"images/navi/job_description_01.png\"></a></li>\r\n          <li><a href=\"./mid-job-description.html\"><img src=\"images/navi/job_description_02.png\"></a></li>\r\n        </ul>\r\n      </li>\r\n\r\n      <li class=\"menu_i\">\r\n        <a href=\"./internship.html\">インターンシップ</a>\r\n\r\n      </li>\r\n\r\n      <li class=\"menu_i\">\r\n        <a href=\"./explanation.html\">会社説明会</a>\r\n\r\n      </li>\r\n\t\t  <li class=\"menu_car\">\r\n            <a href=\"./mid-career.html\">キャリア採用はこちら</a>\r\n          </li>\r\n\r\n    </ul>\r\n  </nav>\r\n\r\n</header>\r\n<!--ここまでヘッダー--> \r\n\r\n<!--ここからメインコンテンツ-->\r\n\r\n<div id=\"career_member\">\r\n<img src=\"images/career/career01.jpg\" alt=\"\"/>\r\n<div id=\"content\"> \r\n  \r\n  <!--ここからメッセージ-->\r\n  <ul class=\"career_list\">\r\n    <!--ここから1年目-->\r\n    <li class=\"type01\">\r\n    <li class=\"year\">１年目～</li>\r\n    <ul class=\"career_back\">\r\n      <li class=\"career_title\">ＣＡＤによる設計図作成、数量計算</li>\r\n      <li>鳥取支社に配属され、道路の改良等の設計業務を担当しました。<br>\r\n大学では設計やＣＡＤ操作の講義はありませんので、入社して初めて携わったわけですが、日々の業務で先輩に丁寧に教えていただき、少しづつ仕事を覚えていきました。<br>\r\n初めて設計した重力式擁壁が完成し、その現場を見たときの感動は、今でも忘れられませんね。<br>\r\nこの場所は自分が設計したのだと、家族や親しい人と現場を見ながら話しができることは、この仕事の醍醐味だと思っています。<br>\r\n現在では、新入社員に対してＣＡＤ操作や数量計算の社内研修を行っています。<br>\r\nＯｆｆ-ＪＴの研修とＯＪＴにより、未経験でも仕事にスムーズに入っていける育成プログラムが整っていますので、安心して入社してくださいね。</li>\r\n    </ul>\r\n    </li>\r\n    <!--ここまで1年目--> \r\n    \r\n    <!--ここから5年目-->\r\n    <li class=\"type01\">\r\n    <li class=\"year\">5年目</li>\r\n    <ul class=\"career_back\">\r\n      <li class=\"career_title\">１年間の研究事業参画</li>\r\n      <li>入社して５年目に、国から鳥取大学が受託して行う、ダムの水質保全に関する研究事業に参画しました。<br>\r\n大学が行う研究のため、学術的な難しい側面もありましたが、やりがいもあり、充実した１年間を過ごしました。<br>\r\n１年後には会社に戻りましたが、研究事業の担当教授とはその後もお付き合いが続き、学会での論文発表を行ったり西オーストラリア大学とのディスカッションに参加したり、技術者としての幅が広がった貴重な経験でした。 </li>\r\n    </ul>\r\n    </li>\r\n    <!--ここまで5年目--> \r\n    \r\n    <!--ここから６年目-->\r\n    <li class=\"type02\">\r\n    <li class=\"year2\">６年目～</li>\r\n    <ul class=\"career_back2\">\r\n      <li class=\"career_title\">河川・砂防の予備設計、詳細設計</li>\r\n      <li>入社５年目に経験した水質研究のキャリアが、ステップアップにつながり、本社の河川・砂防部門におけるメイン担当者として抜擢され、管理技術者の指導のもと、予備設計や詳細設計を担当しました。<br>\r\n河川・砂防施設の設計を通じて、地域を災害から守り、安全で安心な暮らしの確保に貢献していることに誇りを感じるようになりました。<br>\r\n入社１５年目に、自身が携わる砂防堰堤測量設計業務が、国土交通省中国地方整備局長から優良業務の表彰を受賞しましたが、技術者個人を表彰する優秀技術者の受賞は逃しました。<br>\r\nこれが契機となり、技術士の資格取得に向けた勉強を本格的に開始しました。<br>\r\n入社１７年目に技術士の資格を取得し、翌年、課長職に昇格しました。<br>\r\n資格取得に必要となる受験手数料や講習受講料等の実費負担、合格祝金、合格後の手当支給等、会社として資格取得に伴う各種制度が充実しているのが魅力の一つですし、現在では、技術士の資格取得に向けた社内研修制度もあります。<br>\r\n技術士の資格を有する先輩社員が、模擬試験や論文の添削、模擬面接などを行い、資格取得に向けて丁寧に指導しておりますので、入社後は資格取得に向けて一緒に頑張りましょう！</li>\r\n    </ul>\r\n    </li>\r\n    <!--ここまで6年目--> \r\n    <!--ここから現在（19年目）-->\r\n    <li class=\"type01\">\r\n    <li class=\"year\">現在（19年目）</li>\r\n    <ul class=\"career_back\">\r\n      <li class=\"career_title\">優良業務、優秀技術者の局長表彰を受賞</li>\r\n      <li>管理技術者として携わる砂防堰堤詳細設計業務が、国土交通省中国地方整備局長から優良業務の表彰を受賞するとともに、自身も優秀技術者の局長表彰を受賞。<br>\r\n現在に至る。 </li>\r\n    </ul>\r\n    </li>\r\n    <!--ここまで現在（19年目）-->\r\n    \r\n  </ul>\r\n  <ul class=\"message_no7\">\r\n    <li class=\"no07q1\">\r\n      <p>今後の展望をお聞かせください。</p>\r\n    </li>\r\n    <li class=\"answer_no7\"> <span class=\"no7_txt\">少子高齢化社会に対応する国の施策として、土木分野でもi-Constructionや設計の３Ｄ化などのＩＣＴ化が推進されています。<br>\r\n当社でも、説明用資料を従来の紙ベースから３Ｄモデリングイメージに切り替える等して対応しており、地元の皆様からも「分かりやすい」と好評を得ております。<br>\r\n\t\t\t\t\t\tこれからも、災害に強い安全で安心な街づくりに貢献できるように、常に最新の技術に対応した地域密着型のコンサルタントでありたいと願っております。</span> <span class=\"no7_photo\"><img src=\"images/career/career01_photo.jpg\" alt=\"\" width=\"290\" height=\"290\"/></span> </li>\r\n\t\t\t\t\t\t\r\n\t\t\t\t\t\t\r\n\t\t\t\t\t\t\r\n\t\t\t\t\t\t<li class=\"no07q1\">\r\n\t\t\t\t\t\t<p>部下の指導方針をお聞かせください</p>\r\n\t\t\t\t\t\t</li>\r\n\t\t\t\t\t\t<li class=\"answer_no7\">地域のインフラ整備に貢献できるよう自己研鑽に努め、発注者から良きパートナーとして信頼されるように技術力・コミュニケーション力を高めていくことが大切だと、常に伝えています。<br>\r\n\t\t\t\t\t\tまた、主体的に判断し自ら行動する技術者になっていってほしいと思っています。<br>\r\n\t\t\t\t\t\t私を含め上司との関係性としては、自由に意見を交換でき、互いに高めあえるのが理想ですね。\r\n\t\t\t\t\t\t\r\n\t\t\t\t\t\t</li>\r\n            </ul>\r\n\t\t\t\t\t\t\r\n\t\t\t\t\t\t\r\n\r\n          <ul class=\"message-2\" style=\"margin-bottom: 80px;\">\r\n          <li class=\"qa_title\">釣りという共通の趣味を持つ、部長と入社2年目のMさんのある日のひとコマ</li>\r\n          <li style=\"text-align: right;\">【設計部　入社2年目　Mさん】</li>\r\n          \r\n          <li class=\"q01 wh50\">最近、忙しかったけど体調崩してないかな・・・？<br>この前頼んだ業務は順調かな・・・？<span class=\"fuki02\"><img src=\"images/career/fuki02.png\"></span></li>\r\n          \r\n          <li class=\"q01-1 wh50\">最近、調子はどう？<span class=\"fuki02\"><img src=\"images/career/fuki01.png\"></span></li>\r\n         \r\n          <li class=\"a01 wh50\">いいですよ～！<br>部長、これ見てくださいよ！40cm サシゴです!<span class=\"fuki03\"><img src=\"images/career/fuki03.png\"></span></li>\r\n          <li class=\"photo_nico\"><img src=\"images/career/no01photo3.jpg\" width=\"100%\" height=\"auto\" alt=\"\" /></li>\r\n          <li class=\"q01-1-1 wh50\">おお～！これはすごいなぁ～！<span class=\"fuki02-2\"><img src=\"images/career/fuki01-2.png\"></span></li>\r\n          <li class=\"a01 wh50\">いやぁ～、最高でした！ <span class=\"fuki03-2\"><img src=\"images/career/fuki03-2.png\"></span></li>\r\n          <li class=\"q01-1 wh50\">Mくん、また腕を上げたなぁ…（上司として負けちゃおれん!）<br>　・・・それはそうと、例の業務は順調なの？<span class=\"fuki02-2\"><img src=\"images/career/fuki01-2.png\"></span></li>\r\n          <li class=\"a01 wh50\">もちろん！ばっちり順調です！<br>設計計算はK先輩に教えてもらいましたし、<br>Hさんにもしっかりチェックしてもらいました！<span class=\"fuki03-2\"><img src=\"images/career/fuki03-2.png\"></span></li>\r\n          <li class=\"q01 wh50\">釣りも仕事も順調そうでよかった！<br>元気そうだし、たくましいなぁ！<span class=\"fuki02-2\"><img src=\"images/career/fuki02-2.png\"></span></li>\r\n          </ul>\r\n\r\n          <ul class=\"message-2\">\r\n            <li class=\"no07q1\">\r\n              <p>就活生のみなさまへメッセージをお願いします。</p>\r\n            </li>\r\n            <li class=\"answer_no7\">近年の異常気象に伴い、先の西日本豪雨級の災害発生が懸念される中、防災という観点から、河川・砂防施設の設計業務の重要性は今後ますます高まっていくものと考えています。<br>\r\n              安全で安心な施設を設計することは、とても困難なことですが、困難であるがゆえにやりがいもあります。<br>\r\n              私は、仕事に対するやりがいを共有でき、楽しめる人と一緒に仕事をしたいと思っています。<br>\r\n              共に成長でき、将来的にはリーダーシップをとれる人と一緒に仕事ができることを楽しみにしています。\r\n            </li>\r\n            </ul>\r\n\t\t\t\t\t\r\n  <!--ここまでメッセージ--> \r\n  \r\n</div>\r\n</div>\r\n<!--ここまでメインコンテンツ--> \r\n\r\n<!--ここからメンバーリンク-->\r\n<div class=\"members\">\r\n  <ul class=\"member_link\">\r\n    <li class=\"member01\"><a href=\"voice01.html\"><em>設計部</em></a></li>\r\n    <li class=\"member02\"><a href=\"voice02.html\"><em>設計部</em></a></li>\r\n    <li class=\"member03\"><a href=\"voice03.html\"><em>設計部</em></a></li>\r\n    <li class=\"member04\"><a href=\"voice05.html\"><em>地籍調査部</em></a></li>\r\n    <li class=\"member05\"><a href=\"voice06.html\"><em>地籍調査部</em></a></li>\r\n    <li class=\"member06\"><a href=\"voice04.html\"><em>測量調査部</em></a></li>\r\n    <li class=\"member08on\"><a href=\"career01.html\"><em>上司からのメッセージ設計本部 設計部長</em></a></li>\r\n    <li class=\"member09\"><a href=\"career02.html\"><em>上司からのメッセージ地籍調査部 一課長</em></a></li>\r\n    <li class=\"member10\"><a href=\"career03.html\"><em>上司からのメッセージ調査部 維持保全課長</em></a></li>\r\n    <li class=\"member11\"><a href=\"career04.html\"><em>上司からのメッセージ企画管理部企画管理課総務担当課長</em></a></li>\r\n    <li class=\"un-woman\"><a href=\"staff.html\"><img src=\"images/member/un-woman.png\"></a></li>\r\n  </ul>\r\n</div>\r\n<!--ここまでメンバーリンク-->\r\n<!--ここからエントリーボックス-->\r\n<div class=\"entry\">\r\n  <ul class=\"entry_link\">\r\n    <li class=\"entry01\">\r\n    <section class=\"responsive wow fadeInUp  welcome__workflow-image\" data-wow-delay=\"0.2s\" data-wow-offset=\"0\" ><img src=\"images/common/entry.gif\" width=\"145\" height=\"145\" alt=\"\"/></section></li>\r\n    <li class=\"entry02\"><a href=\"https://job.mynavi.jp/28/pc/search/corp207090/outline.html\" target=\"_blank\"><img src=\"images/common/mynavi.gif\" width=\"270\" height=\"82\" alt=\"\"/></a></li>\r\n    <!-- <li class=\"entry03\"><a href=\"https://job.rikunabi.com/2026/company/r564710080/\" target=\"_blank\"><img src=\"images/common/ricenavi.gif\" width=\"270\" height=\"82\" alt=\"\"/></a></li> -->\r\n    <li class=\"entry03\" style=\"margin: 0px 0px 0px 30px\"><a href=\"https://works.do/R/ti/p/saiyo@nishi-tc\" target=\"_blank\"><img src=\"images/common/nishi_line.png\" width=\"110\" height=\"162\" alt=\"\"/></a></li>\r\n  </ul>\r\n</div>\r\n<!--ここまでエントリーボックス--> \r\n\r\n<!--ここからフッター-->\r\n<div id=\"footer\">\r\n  <div class=\"footer_box\">\r\n    <p class=\"foot_logo\"><a href=\"../index.html\"><img src=\"images/common/footerlogo.gif\" width=\"425\" height=\"40\" alt=\"西谷技術コンサルタント株式会社\"/></a></p>\r\n    <p class=\"add\">〒682-0025鳥取県倉吉市八屋354番地1　TEL.0858-26-2411　FAX.0858-26-5537</p>\r\n  </div>\r\n  <p class=\"copyright\">Copyright (C) 2016 Nishitani Engineering Consultant Co.,Ltd.All rights reserved</p>\r\n</div>\r\n<!--ここまでフッター-->\r\n\r\n<div id=\"pagetop\"><a href=\"#header\" title=\"PAGE TOPへ\"><em>ページトップへ</em></a></div>\r\n<!-- jquery & iScroll --> \r\n<script src=\"js/iscroll.min.js\"></script> \r\n<script src=\"js/drawer.min.js\"></script> \r\n<script src=\"js/main.js\"></script> \r\n<script>\r\n  (function(i,s,o,g,r,a,m){i['GoogleAnalyticsObject']=r;i[r]=i[r]||function(){\r\n  (i[r].q=i[r].q||[]).push(arguments)},i[r].l=1*new Date();a=s.createElement(o),\r\n  m=s.getElementsByTagName(o)[0];a.async=1;a.src=g;m.parentNode.insertBefore(a,m)\r\n  })(window,document,'script','//www.google-analytics.com/analytics.js','ga');\r\n\r\n  ga('create', 'UA-64448027-1', 'auto');\r\n  ga('send', 'pageview');\r\n\r\n</script>\r\n</body>\r\n</html>\r\n","finalUrl":"https://www.nishi-tc.co.jp/recruit/career01.html","rendered":false,"_cachedAt":"2026-06-23T21:40:59.389Z"}