           <!-- .c-card16 -->\n            <div class=\"c-card16\">\n              <h3 class=\"c-card16__heading\">意思決定層における女性の割合</h3>\n              <div class=\"c-card16__columns\">\n                <div class=\"c-card16__subColumn\">\n                  <picture>\n                    <source srcset=\"https://www.aeoncompass.co.jp/cms/wp-content/themes/aeoncompass/asset/img/page/recruit/icon10.svg\" width=\"103\" height=\"48\" media=\"(max-width: 768px)\">\n                    <img src=\"https://www.aeoncompass.co.jp/cms/wp-content/themes/aeoncompass/asset/img/page/recruit/icon10.svg\" alt=\"\" width=\"103\" height=\"48\" decoding=\"async\">\n                  </picture>\n                </div>\n                <div class=\"c-card16__mainColumn\">\n                  <p class=\"c-card16__data\"><span>40.0</span>%</p>\n                  <p class=\"c-card16__year\"><span>2024年度</span></p>\n                </div>\n              </div>\n            </div>\n            <!-- /.c-card16 -->\n\n          </div>\n          <div class=\"p-recruit__column4\">\n\n            <!-- .c-card16 -->\n            <div class=\"c-card16\">\n              <h3 class=\"c-card16__heading\">新規採用者の外国籍スタッフ割合</h3>\n              <div class=\"c-card16__columns\">\n                <div class=\"c-card16__subColumn\">\n                  <picture>\n                    <source srcset=\"https://www.aeoncompass.co.jp/cms/wp-content/themes/aeoncompass/asset/img/page/recruit/icon9.svg\" width=\"70\" height=\"58\" media=\"(max-width: 768px)\">\n                    <img src=\"https://www.aeoncompass.co.jp/cms/wp-content/themes/aeoncompass/asset/img/page/recruit/icon9.svg\" alt=\"\" width=\"70\" height=\"58\" decoding=\"async\">\n                  </picture>\n                </div>\n                <div class=\"c-card16__mainColumn\">\n                  <p class=\"c-card16__data\"><span>9.5</span>%</p>\n                  <p class=\"c-card16__year\"><span>2024年度</span></p>\n                </div>\n          