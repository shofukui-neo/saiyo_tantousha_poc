t\t\t<li><a href=\"https://www.aeoncompass.co.jp/company/\">企業情報</a></li>\n\t\t\t\t\t\t\t\t\t\t\t<li><a href=\"https://www.aeoncompass.co.jp/purpose/\">パーパス</a></li>\n\t\t\t\t\t\t\t\t\t\t\t<li><a href=\"https://www.aeoncompass.co.jp/branch/\">事業所一覧</a></li>\n\t\t\t\t\t\t\t\t\t\t\t<li><a href=\"https://www.aeoncompass.co.jp/registform/\">旅行業登録票／約款条件書</a></li>\n\t\t\t\t\t\t\t\t\t\t\t<li><a href=\"https://www.aeoncompass.co.jp/health/\">健康経営の取り組み</a></li>\n\t\t\t\t\t\t\t\t\t\t</ul>\n\t\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t</li>\n\t\t\t\t\t\t\t\t<li><a href=\"https://www.aeoncompass.co.jp/recruit/\">採用情報</a></li>\n\t\t\t\t\t\t\t\t<li><a href=\"https://www.aeoncompass.co.jp/news/\">お知らせ</a></li>\n\t\t\t\t\t\t\t</ul>\n\t\t\t\t\t\t\t<ul class=\"l-globalNav__buttonList\">\n\t\t\t\t\t\t\t\t<li><a href=\"https://www.aeoncompass.co.jp/inquiry/\" class=\"l-globalNav__button\">お問い合わせ</a></li>\n\t\t\t\t\t\t\t</ul>\n\t\t\t\t\t\t\t<ul class=\"l-globalNav__helpMenu u-hidden md:u-flex\">\n\t\t\t\t\t\t\t\t<li><a href=\"https://www.aeoncompass.co.jp/privacy/\">プライバシーポリシー</a></li>\n\t\t\t\t\t\t\t\t<li><a href=\"https://www.aeoncompass.co.jp/sitemap/\">サイトマップ</a></li>\n\t\t\t\t\t\t\t</ul>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t\t<!-- /.l-globalNav -->\n\t\t\t\t</div>\n\n\t\t\t\t<button id=\"js-hamburger\" class=\"l-header__hamburger u-hidden md:u-flex\">\n\t\t\t\t\t<span>\n\t\t\t\t\t\t<span></span>\n\t\t\t\t\t\t<span></span>\n\t\t\t\t\t</span>\n\t\t\t\t</button>\n\n\t\t\t\t<div class=\"l-headerLanguage document\">\n\t\t\t\t\t<a href=\"https://www.aeoncompass.co.jp/document/\" class=\"l-headerLanguage__menu\">資料請求</a>\n\t\t\t\t</div>\n\n\t\t\t\t<div class=\"l-headerLanguage\">\n\t\t\t\t\t<button type=\"button\" class=\"js-language l-headerLanguage__menu\" aria-expanded=\"false\">\n\t\t\t\t\t\t<svg class=\"l-headerLanguage__menu__ico\" width=\"20\" height=\"20\" viewBox=\"0 0 20 20\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" aria-hidden=\"true\">\n\t\t\t\t\t\t\t<path d=\"M20 0H0V20H20V0Z\" fill=\"white\" />\n\t\t\t\t\t\t\t<path d=\"M10 19C14.9706 19 19 14.9706 19 10C19 5.02944 14.9706 1 10 1C5.02944 1 1 5.02944 1 10C1 14.9706 5.02944 19 10 19Z\" stroke=\"#D2D2D2\" stroke-width=\"1.5\" stroke-miterlimit=\"10\" />\n\t\t\t\t\t\t\t<path d=\"M10 19C12.7614 19 15 14.9706 15 10C15 5.02944 12.7614 1 10 1C7.23858 1 5 5.02944 5 10C5 14.9706 7.23858 19 10 19Z\" stroke=\"#D2D2D2\" stroke-width=\"1.5\" stroke-miterlimit=\"10\" />\n\t\t\t\t\t\t\t<path d=\"M1 10H19\" stroke=\"#D2D2D2\" stroke-width=\"1.5\" stroke-miterlimit=\"10\" />\n\t\t\t\t\t\t\t<path d=\"M10 1V19\" stroke=\"#D2D2D2\" stroke-width=\"1.5\" stroke-miterlimit=\"10\" />\n\t\t\t\t\t\t</svg>\n\t\t\t\t\t\tLanguage</button>\n\t\t\t\t\t<ul class=\"l-headerLanguage__list\" data-stt-langbar>\n\t\t\t\t\t\t<li class=\"l-headerLanguage__item\"><button class=\"l-headerLanguage__btn\" type=\"button\" data-stt-changelang=\"ja\" data-stt-ignore data-stt-active>日本語</button></li>\n\t\t\t\t\t\t<li class=\"l-headerLanguage__item\"><button class=\"l-headerLanguage__btn\" type=\"button\" data-stt-changelang=\"en\" data-stt-ignore>English</button></li>\n\t\t\t\t\t\t<li class=\"l-headerLanguage__item\"><button class=\"l-headerLanguage__btn\" type=\"button\" data-stt-changelang=\"zh-CN\" data-stt-ignore>简体中文</button></li>\n\t\t\t\t\t\t<li class=\"l-headerLanguage__item\"><button class=\"l-headerLanguage__btn\" type=\"button\" data-stt-changelang=\"zh-TW\" data-stt-ignore>繁體中文</button></li>\n\t\t\t\t\t</ul>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</header>\n<!-- .l-main -->\n<main class=\"l-main\">\n\n  <!-- .c-visualHeader -->\n  <div class=\"c-visualHeader\">\n    <div class=\"c-visualHeader__breadcrumb\">\n\n      <!-- .c-breadcrumb -->\n      <div class=\"c-breadcrumb\">\n        <div class=\"c-breadcrumb__container\">\n          <ol itemscope itemtype=\"https://schema.org/BreadcrumbList\" class=\"c-breadcrumb__itemList\">\n            <li itemprop=\"itemListElement\" itemscope itemtype=\"https://schema.org/ListItem\">\n              <a itemprop=\"item\" href=\"/\">\n                <span itemprop=\"name\">Home</span>\n              </a>\n              <meta itemprop=\"position\" content=\"1\" />\n            </li>\n            <li itemprop=\"itemListElement\" itemscope itemtype=\"https://schema.org/ListItem\" class=\"-current\">\n              <a itemprop=\"item\" href=\"/recruit/\">\n                <span itemprop=\"name\">採用情報</span>\n              </a>\n              <meta itemprop=\"position\" content=\"2\" />\n            </li>\n          </ol>\n        </div>\n      </div>\n      <!-- /.c-breadcrumb -->\n\n    </div>\n    <div class=\"c-visualHeader__img\">\n      <picture>\n        <source srcset=\"https://www.aeoncompass.co.jp/cms/wp-content/themes/aeoncompass/asset/img/page/recruit/img-sp.webp\" width=\"393\" height=\"340\" media=\"(max-width: 768px)\">\n        <img src=\"https://www.aeoncompass.co.jp/cms/wp-content/themes/aeoncompass/asset/img/page/recruit/img.webp\" alt=\"\" width=\"1400\" height=\"380\" decoding=\"async\">\n      </picture>\n    </div>\n    <div class=\"c-visualHeader__header\">\n      <h1 class=\"c-visualHeader__heading\">採用情報</h1>\n      <p class=\"c-visualHeader__englishHeading\">Recruit</p>\n    </div>\n  </div>\n  <!-- /.c-visualHeader -->\n\n  <!-- .p-recruit -->\n  <div class=\"p-recruit\">\n    <div class=\"p-recruit__section\">\n      <div class=\"c-container\">\n\n        <!-- .p-recruitMessage -->\n        <div class=\"p-recruitMessage\">\n          <div>\n            <h2 class=\"p-recruitMessage__heading\">目指す未来は、<br class=\"u-hidden md:u-block\">コンパスが知っている</h2>\n            <p class=\"p-recruitMessage__text\">まだ、見つけられていない旅の価値を創造する<br>旅の力を原点に 一緒に未来に進みませんか</p>\n          </div>\n        </div>\n        <!-- /.p-recruitMessage -->\n\n      </div>\n    </div>\n    <div class=\"p-recruit__cta\">\n      <div class=\"c-container\">\n        <ul class=\"p-recruit__buttonList\">\n          <li><a href=\"https://job.mynavi.jp/27/pc/search/corp86374/outline.html\" target=\"_blank\" class=\"c-button p-recruit__button\"><span>新卒採用</span></a></li>\n          <li><a href=\"https://en-gage.net/aeoncompass/\" target=\"_blank\" class=\"c-button p-recruit__button\"><span>キャリア採用</span></a></li>\n        </ul>\n      </div>\n    </div>\n    <div class=\"p-recruit__section -merit\">\n      <div class=\"c-container\">\n        <h2 class=\"p-recruit__heading\">イオンコンパスで働くメリット</h2>\n        <div class=\"p-recruit__columns\">\n          <div class=\"p-recruit__column\">\n\n            <!-- .c-card13 -->\n            <div class=\"c-card13\">\n              <p class=\"c-card13__number\"><span>Merit 01</span></p>\n              <h3 class=\"c-card13__heading\"><span>共創と進化 </span>で、<br class=\"u-hidden md:u-block\">次のレベルのソリューションを</h3>\n              <p class=\"c-card13__text\">イオングループの壮大なスケールと信頼性を力に幅広くビジネスを展開しています。<br>あなたの強みを発揮してください。</p>\n            </div>\n            <!-- .c-card13 -->\n\n          </div>\n          <div class=\"p-recruit__column\">\n\n            <!-- .c-card13 -->\n            <div class=\"c-card13\">\n              <p class=\"c-card13__number -right\"><span>Merit 02</span></p>\n              <h3 class=\"c-card13__heading -right\"><span>チャレンジ </span>を受け入れる<br class=\"u-hidden md:u-block\">環境と社風</h3>\n              <p class=\"c-card13__text -right\">新しい視点や価値観を柔軟に受け入れる社風は私たちの誇りです。<br>意見を出しやすい組織でともに成長していきましょう。</p>\n            </div>\n            <!-- .c-card13 -->\n\n          </div>\n          <div class=\"p-recruit__column\">\n\n            <!-- .c-card13 -->\n            <div class=\"c-card13\">\n              <p class=\"c-card13__number\"><span>Merit 03</span></p>\n              <h3 class=\"c-card13__heading\">ライフステージに沿った<span> <br class=\"u-hidden md:u-block\">キャリアパス</span></h3>\n              <p class=\"c-card13__text\">自分らしく働きやすい環境だからこそひとり一人のライフステージに沿ったキャリアパスを描けます。</p>\n            </div>\n            <!-- .c-card13 -->\n\n          </div>\n        </div>\n      </div>\n    </div>\n    <div class=\"p-recruit__section -bg\">\n      <div class=\"c-container\">\n        <h2 class=\"p-recruit__heading\">キャリアをサポートする環境</h2>\n        <div class=\"p-recruit__columns2\">\n          <div class=\"p-recruit__column2\">\n\n            <!-- .c-card14 -->\n            <div class=\"c-card14\">\n              <h3 class=\"c-card14__heading\">グループ合同<br>入社オリエンテーション</h3>\n              <p class=\"c-card14__text\">イオンピープルとしての価値観と思いを形成するために、<br>グループ全体での入社イベント・オリエンテーションに参加し、<br>イオンの基本理念・未来ビジョンを共有します。</p>\n            </div>\n            <!-- .c-card14 -->\n\n          </div>\n          <div class=\"p-recruit__column2\">\n\n            <!-- .c-card14 -->\n            <div class=\"c-card14\">\n              <h3 class=\"c-card14__heading\">メンター制度</h3>\n              <p class=\"c-card14__text\">職場環境に早く適応していただけるよう、メンター制度を導入しています。フラットなコミュニケーションを通じ、前向きな力を引き出せるようサポートしますので、メンターから成長のヒントを得て活躍の場を広げてください。</p>\n            </div>\n            <!-- .c-card14 -->\n\n          </div>\n          <div class=\"p-recruit__column2\">\n\n            <!-- .c-card14 -->\n            <div class=\"c-card14\">\n              <h3 class=\"c-card14__heading\">セルフスタディ・リスキリング</h3>\n              <p class=\"c-card14__text\">社員ひとり一人の成長意欲を尊重しています。<br>自己啓発や資格取得に向けた援助金制度、e-ラーニングの環境を<br>整え学びの場を提供いたします。</p>\n            </div>\n            <!-- .c-card14 -->\n\n          </div>\n          <div class=\"p-recruit__column2\">\n\n            <!-- .c-card14 -->\n            <div class=\"c-card14\">\n              <h3 class=\"c-card14__heading\">キャリア形成支援</h3>\n              <p class=\"c-card14__text\">思い描くキャリアパスを実現するために<br>キャリア面談を実施しています。<br>社内での活躍と成長を支えるバックアップをいたします。</p>\n            </div>\n            <!-- .c-card14 -->\n\n          </div>\n        </div>\n      </div>\n    </div>\n    <div class=\"p-recruit__section\">\n      <div class=\"c-container\">\n        <h2 class=\"p-recruit__heading\">イオンコンパスの働き方</h2>\n        <div class=\"p-recruit__columns3\">\n          <div class=\"p-recruit__column3\">\n\n            <!-- .c-card15 -->\n            <div class=\"c-card15\">\n              <div class=\"c-card15__img\"><img src=\"https://www.aeoncompass.co.jp/cms/wp-content/themes/aeoncompass/asset/img/page/recruit/icon3.svg\" alt=\"\" width=\"180\" height=\"100\" decoding=\"async\" loading=\"lazy\"></div>\n              <h3 class=\"c-card15__heading\">年間休日休暇128日（2023年実績）</h3>\n              <p class=\"c-card15__text\">年次有給休暇の他にグリーン休日や1時間ごとに取得可能なグリーン分休の制度を整備。ワークライフバランスを重視した働き方が可能です。</p>\n            </div>\n            <!-- .c-card15 -->\n\n          </div>\n          <div class=\"p-recruit__column3\">\n\n            <!-- .c-card15 -->\n            <div class=\"c-card15\">\n              <div class=\"c-card15__img\"><img src=\"https://www.aeoncompass.co.jp/cms/wp-content/themes/aeoncompass/asset/img/page/recruit/icon4.svg\" alt=\"\" width=\"180\" height=\"100\" decoding=\"async\" loading=\"lazy\"></div>\n              <h3 class=\"c-card15__heading\">充実の福利厚生</h3>\n              <p class=\"c-card15__text\">イオンほかグループ各社との相互買物割引制度があり大変便利です。</p>\n            </div>\n            <!-- .c-card15 -->\n\n          </div>\n          <div class=\"p-recruit__column3\">\n\n            <!-- .c-card15 -->\n            <div class=\"c-card15\">\n              <div class=\"c-card15__img\"><img src=\"https://www.aeoncompass.co.jp/cms/wp-content/themes/aeoncompass/asset/img/page/recruit/icon2.svg\" alt=\"\" width=\"180\" height=\"100\" decoding=\"async\" loading=\"lazy\"></div>\n              <h3 class=\"c-card15__heading\">育児休業・介護休業</h3>\n              <p class=\"c-card15__text\">育児休暇や育児勤務や介護勤務（時短勤務）<br>介護休職など育児・介護に向き合う社員をサポートしています。</p>\n            </div>\n            <!-- .c-card15 -->\n\n          </div>\n          <div class=\"p-recruit__column3\">\n\n            <!-- .c-card15 -->\n            <div class=\"c-card15\">\n              <div class=\"c-card15__img\"><img src=\"https://www.aeoncompass.co.jp/cms/wp-content/themes/aeoncompass/asset/img/page/recruit/icon11.svg\" alt=\"\" width=\"180\" height=\"100\" decoding=\"async\" loading=\"lazy\"></div>\n              <h3 class=\"c-card15__heading\">ダイバーシティ推進</h3>\n              <p class=\"c-card15__text\">誰もが働きやすく自己の可能性に挑戦できる環境を目指しています。外国籍社員も多数活躍しており積極採用を進めています。</p>\n            </div>\n            <!-- .c-card15 -->\n\n          </div>\n          <div class=\"p-recruit__column3\">\n\n            <!-- .c-card15 -->\n            <div class=\"c-card15\">\n              <div class=\"c-card15__img\"><img src=\"https://www.aeoncompass.co.jp/cms/wp-content/themes/aeoncompass/asset/img/page/recruit/icon.webp\" alt=\"\" width=\"180\" height=\"100\" decoding=\"async\" loading=\"lazy\"></div>\n              <h3 class=\"c-card15__heading\">えるぼし認定</h3>\n              <p class=\"c-card15__text\">女性活躍推進法に基づく認定基準の「えるぼし」で3つ星の認定を受けました。女性だけではなく男性も働きやすい職場づくりに励んでいます。</p>\n            </div>\n            <!-- .c-card15 -->\n\n          </div>\n          <div class=\"p-recruit__column3\">\n\n            <!-- .c-card15 -->\n            <div class=\"c-card15\">\n              <div class=\"c-card15__img\"><img src=\"https://www.aeoncompass.co.jp/cms/wp-content/themes/aeoncompass/asset/img/page/recruit/icon12.svg\" alt=\"\" width=\"180\" height=\"100\" decoding=\"async\" loading=\"lazy\"></div>\n              <h3 class=\"c-card15__heading\">健康経営の取り組み</h3>\n              <p class=\"c-card15__text\">ストレスチェックをはじめ、働きやすい職場環境の整備を通しワークエンゲイジメントの向上に繋げています。</p>\n            </div>\n            <!-- .c-card15 -->\n\n          </div>\n        </div>\n      </div>\n    </div>\n    <div class=\"p-recruit__section -bg -data\">\n      <div class=\"c-container\">\n        <h2 class=\"p-recruit__heading\">データで見るイオンコンパス</h2>\n        <div class=\"p-recruit__columns4\">\n          <div class=\"p-recruit__column4\">\n\n            <!-- .c-card16 -->\n            <div class=\"c-card16\">\n              <h3 class=\"c-card16__heading\">平均勤続勤務年数</h3>\n              <div class=\"c-card16__columns\">\n                <div class=\"c-card16__subColumn\">\n                  <picture>\n                    <source srcset=\"https://www.aeoncompass.co.jp/cms/wp-content/themes/aeoncompass/asset/img/page/recruit/icon5.svg\" width=\"60\" height=\"55\" media=\"(max-width: 768px)\">\n                    <img src=\"https://www.aeoncompass.co.jp/cms/wp-content/themes/aeoncompass/asset/img/page/recruit/icon5.svg\" alt=\"\" width=\"60\" height=\"55\" decoding=\"async\">\n                  </picture>\n                </div>\n                <div class=\"c-card16__mainColumn\">\n                  <p class=\"c-card16__data\"><span>6.3</span>年</p>\n                  <p class=\"c-card16__year\"><span>2024年度</span></p>\n                </div>\n              </div>\n            </div>\n            <!-- /.c-card16 -->\n\n          </div>\n          <div class=\"p-recruit__column4\">\n\n            <!-- .c-card16 -->\n            <div class=\"c-card16\">\n              <h3 class=\"c-card16__heading\">月平均所定外労働時間</h3>\n              <div class=\"c-card16__columns\">\n                <div class=\"c-card16__subColumn\">\n                  <picture>\n                    <source srcset=\"https://www.aeoncompass.co.jp/cms/wp-content/themes/aeoncompass/asset/img/page/recruit/icon6.svg\" width=\"62\" height=\"62\" media=\"(max-width: 768px)\">\n                    <img src=\"https://www.aeoncompass.co.jp/cms/wp-content/themes/aeoncompass/asset/img/page/recruit/icon6.svg\" alt=\"\" width=\"62\" height=\"62\" decoding=\"async\">\n                  </picture>\n                </div>\n                <div class=\"c-card16__mainColumn\">\n                  <p class=\"c-card16__data\"><span>11.2</span>時間</p>\n                  <p class=\"c-card16__year\"><span>2024年度</span></p>\n                </div>\n              </div>\n            </div>\n            <!-- /.c-card16 -->\n\n          </div>\n          <div class=\"p-recruit__column4\">\n\n            <!-- .c-card16 -->\n            <div class=\"c-card16\">\n              <h3 class=\"c-card16__heading\">平均有