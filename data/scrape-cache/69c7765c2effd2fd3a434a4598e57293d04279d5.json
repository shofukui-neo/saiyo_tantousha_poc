{"url":"https://www.tokaibsn.co.jp/recruit/interview/","html":"<!DOCTYPE html>\n<html lang=\"ja\" prefix=\"og: http://ogp.me/ns# fb: http://ogp.me/ns/fb#\">\n<head>\n<meta charset=\"UTF-8\">\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1.0\">\n<title>先輩社員紹介 | 東海物産</title>\n<meta name=\"description\" content=\"先輩社員紹介ページです。\">\n<meta property=\"og:type\" content=\"article\">\n<meta property=\"og:title\" content=\"先輩社員紹介 | 東海物産\">\n<meta property=\"og:description\" content=\"先輩社員紹介ページです。\">\n<meta property=\"og:url\" content=\"https://www.tokaibsn.co.jp/recruit/interview/\">\n<meta property=\"og:image\" content=\"https://www.tokaibsn.co.jp/recruit/img/thu_interview.jpg\">\n<meta property=\"og:site_name\" content=\"東海物産株式会社\">\n<meta property=\"og:locale\" content=\"ja_JP\">\n<!-- favicon/apple-touch-icon -->\n<link rel=\"icon\" href=\"/common/img/favicon.ico\">\n<link rel=\"stylesheet\" href=\"/common/css/normalize.css\">\n<link rel=\"stylesheet\" href=\"/common/css/iconfont.css\">\n<link rel=\"stylesheet\" href=\"/common/css/drawer.min.css\">\n<link rel=\"stylesheet\" href=\"/common/css/drawer-add.css\">\n<link rel=\"stylesheet\" href=\"/common/css/base.css\">\n<link rel=\"stylesheet\" href=\"/common/css/con_share.css\">\n<link rel=\"stylesheet\" href=\"/recruit/css/local.css\">\n<script src=\"/common/script/css_browser_selector.js\" type=\"text/javascript\"></script> <!-- Google Tag Manager -->\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n})(window,document,'script','dataLayer','GTM-KX6FJKZ');</script>\n<!-- End Google Tag Manager -->\n</head>\n<body id=\"recruit\" class=\"recruit -interview drawer drawer--top\">\n<!-- Google Tag Manager