{"url":"https://www.inaba.co.jp/recruit/gradu/about/","html":"<!doctype html>\n<html prefix=\"og: http://ogp.me/ns#\" lang=\"ja\">\n<head>\n<meta charset=\"UTF-8\">\n<!-- Global site tag (gtag.js) - Google Analytics -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-0JHXCB747W\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'G-0JHXCB747W');\n  gtag('config', 'UA-196748537-1');\n</script>\n<meta name=\"keywords\" content=\"\">\n<meta name=\"description\" content=\"\">\n<meta property=\"og:title\" content=\"\">\n<meta property=\"og:url\" content=\"\">\n<meta property=\"og:image\" content=\"\">\n<meta property=\"og:site_name\" content=\"\">\n<meta property=\"og:description\" content=\"\">\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1.0,minimum-scale=1.0\">\n<title>INABAの事業紹介 | 新卒採用サイト | 因幡電機産業株式会社</title>\n\n<!-- 共通で使用するcssを読み込む -->\n<link rel=\"stylesheet\" href=\"../common/css/base.css\">\n<link rel=\"stylesheet\" href=\"../common/css/hacks.css\">\n<link rel=\"stylesheet\" href=\"../common/css/reset.css\">\n<link rel=\"stylesheet\" href=\"../common/css/jquery.fatNav.css\">\n\n<!-- 共通で使用するjsを読み込む -->\n<script src=\"https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/viewport-extra@1.0.2/dist/viewport-extra.min.js\"></script>\n<script src=\"../common/js/jquery.fatNav.min.js\"></script>\n<script src=\"../common/js/library.js\"></script>\n\n<!-- このページで使用するcss、プラグインのオプション設定を記述したjsなどを読み込む -->\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../common/css/swiper.css\" media=\"all\" />\n<script src=\"../common/js/swiper.min.js\"></script>\n<script src=\"js/modal.js\"></script>\n<link rel=\"stylesheet\" href=\"css/style.css\">\n<script src=\"../common/js/jquery.matchHeight.js\"></script>\n<script>\n$(function(){\n　　$('.mH').matchHeight();\n});\n</scri