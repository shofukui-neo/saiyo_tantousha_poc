{"url":"https://www.ttk-g.co.jp/recruit/guideline/","html":"\n<!DOCTYPE html>\n<html lang=\"ja\">\n\n<head>\n<meta charset=\"UTF-8\">\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>募集要項 | 株式会社TTK</title>\n<meta name=\"format-detection\" content=\"telephone=no,email=no\">\n<meta name=\"keywords\" content=\"TTK,東北,NTT,通信インフラ,モバイル,きずな光,基盤,電気\">\n<meta name=\"description\" content=\"TTKの公式ウェブサイトです。TTKは東北全域を支える情報通信設備を行なっています。情報通信設備の設計・保守をはじめ、ICTソリューションサービスの提供、インフラ工事なども手掛けています。\">\n<link rel=\"icon\" href=\"/lib/favicon/icon.ico\" type=\"image/vnd.microsoft.icon\">\n<link href=\"https://maxcdn.bootstrapcdn.com/font-awesome/4.7.0/css/font-awesome.min.css\" rel=\"stylesheet\">\n<link rel=\"stylesheet\" href=\"/lib/cmn-css/common.css\" media=\"all\">\n<link rel=\"stylesheet\" href=\"/lib/cmn-css/drawer_menu.css\" media=\"all\">\n<link rel=\"stylesheet\" href=\"/lib/cmn-css/slick.css\" media=\"all\">\n</head>\n\n<body class=\"recruit recruit_pages\">\n  <div id=\"header-container\"></div>\n\n  <div class=\"mv\">\n    <h2 class=\"mv_tit\">\n      <span class=\"en\">Guideline</span><br>\n      <span class=\"jp\">募集要項</span>\n    </h2>\n\n    <ol class=\"breadcrumb\" itemscope itemtype=\"http://schema.org/BreadcrumbList\">\n      <li itemprop=\"itemListElement\" itemscope itemtype=\"http://schema.org/ListItem\">\n        <a itemprop=\"item\" href=\"../\"><span itemprop=\"name\">TOP</span></a>\n        <meta itemprop=\"position\" content=\"1\" />\n      </li>\n      <li itemprop=\"itemListElement\" itemscope itemtype=\"http://schema.org/ListItem\">\n        <span itemprop=\"name\">Guideline</span>\n        <meta itemprop=\"position\" content=\"2\" />\n      </li>\n    </ol>\n  </div>\n  <!----- mv ----->\n\n  <main class=\"guideline\">\n    <section class=\"area01 inner02\">\n      <div class=\"career\" style=\"text-align:center\">\n        <p class=\"tit\">募集要項</p>\n        <div class=\"button\" style=\"display: inline-block;width:140px;\"><a href=\"#shinsotu\">新卒採用</a></div>\n        <div class=\"button\" style=\"display: inline-block;width:140px;\"><a href=\"../../recruit/career\">中途採用</a></div>\n        <div class=\"button\" style=\"display: inline-block;width:140px;\"><a href=\"#shougai\">障がい者採用</a></div>\n        <div class=\"button\" style=\"display: inline-block;width:140px;\"><a href=\"#comeback\">カムバック採用</a></div>\n      </div>\n      \n\n      <h4 class=\"re_tit01\" id=\"shinsotu\">新卒採用 募集要項</h4>\n\n      <table class=\"type01\">\n        <tr>\n          <th>職種</th>\n          <td>総合職<br>■各種情報通信設備の設計・施工<br>■IT関連システム提案及び施工・保守<br>■土木・電気関連の設計・施工<br>■システムエンジニア<br>■一般事務職</td>\n        </tr>\n        <tr>\n          <th>勤務地</th>\n          <td>\n            ＜本社ビル＞<br>\n            宮城県仙台市若林区新寺1丁目2-23<br>\n            ・本社<br>\n            ・ネットワーク事業本部<br><br>\n\n\n            ＜中倉ビル＞<br>\n            宮城県仙台市若林区中倉2丁目2-23<br>\n            ・コミュニティ事業部<br><br>\n            \n            ＜長町ビル＞<br>\n            宮城県仙台市太白区長町5丁目3-20<br>\n            ・モバイル事業本部<br><br>\n            ＜支店＞<br>\n            宮城支店／宮城県仙台市若林区六丁の目元町12-1<br>\n            岩手支店／岩手県紫波郡矢巾町大字広宮沢第11地割501-10<br>\n            青森支店／青森県八戸市西白山台6丁目8-2<br>\n            秋田支店／秋田県秋田市御所野湯本1丁目1-7<br>\n            山形支店／山形県山形市南栄町2丁目8-2<br>\n            福島支店／福島県福島市小倉寺字中ノ内1-1<br>\n            東京支店／東京都千代田区神田東松下町27　神田MSビル2F\n          </td>\n        </tr>\n        <tr>\n          <th>勤務時間</th>\n          <td>8：30～17：00または9：00～17：30<br>\n            ※事業所によって異なる<br>※いずれも実働7.5時間（休憩60分）</td>\n        </tr>\n        <tr>\n          <th>給与</th>\n          <td>大学院修了　月給24万4,060円<br>大学卒　月給23万2,700円<br>高専・短大・専門卒　月給22万3,340円</td>\n        </tr>\n        <tr>\n          <th>諸手当</th>\n          <td>通勤手当（全額支給）、家族手当、役職手当、時間外手当　ほか</td>\n        </tr>\n        <tr>\n          <th>昇給</th>\n          <td>年1回（6月）</td>\n        </tr>\n        <tr>\n          <th>賞与</th>\n          <td>年2回（6月、12月）</td>\n        </tr>\n        <tr>\n          <th>休日休暇</th>\n          <td>完全週休2日制（土、日）、祝祭日、夏季休暇、年末年始休暇、特別有給休暇（慶弔など）、年次有給休暇（初年度15日、次年度以降20日）、積立年休制度</td>\n        </tr>\n        <tr>\n          <th>保険</th>\n          <td>各種社会保険完備</td>\n        </tr>\n        <tr>\n          <th>福利厚生</th>\n          <td>資格取得支援制度、従業員持株会、財形貯蓄、住宅・厚生資金貸付、育児・介護休業、会員型福利厚生サービス有、借上社宅制度有</td>\n        </tr>\n        <tr>\n          <th>研修期間</th>\n          <td>入社後半年間の新入社員研修（OJT）</td>\n        </tr>\n      </table>\n\n      <h4 class=\"re_tit01\" id=\"shougai\">障がい者採用 募集要項</h4>\n\n      <table class=\"type01\">\n        <tbody><tr>\n          <th>障がい者採用について</th>\n          <td>障がい者採用も積極的に行っています。<br>応募を希望される方は、採用担当までご連絡ください。<br>採用条件、業務内容、社内設備等は別途ご案内いたします。</td>\n        </tr>\n        <tr>\n          <th>エントリー方法</th>\n          <td><a href=\"../../recruit/entry/#comeback\" style=\"text-decoration:underline;\">エントリーはこちら</a></td>\n        </tr>\n        </tbody>\n      </table>\n\n      <h4 class=\"re_tit01\" id=\"comeback\">カムバック採用 募集要項</h4>\n\n      <table class=\"type01\">\n        <tbody><tr>\n          <th>カムバック採用制度とは</th>\n          <td>婚姻や育児・介護等の事情や、他社への転職などにより、定年退職を待たずに当社を退職された方が対象となります。退職の事由が解消された場合などに、過去の経験に基づく知識や技術、退職後に培った新たなスキルを活かし、再度当社で活躍していただく制度です。</td>\n        </tr>\n        <tr>\n          <th>対象となる方</th>\n          <td>以下の条件を満たす方<br>・かつて当社に正社員として在籍しており、自己都合で退職された方<br>・定年退職日(満６０歳到達日の属する年度の末日)に達していない方<br>※勤続年数・退職後に経過した期間による制限はございません。</td>\n        </tr>\n        <tr>\n          <th>再入社時の職務・職種、処遇</th>\n          <td>退職時の職務・役職・給与を基準とし、退職後のキャリアなども踏まえ、総合的に判断いたします。</td>\n        </tr>\n        <tr>\n          <th>選考方法</th>\n          <td>筆記試験及び面接</td>\n        </tr>\n        <tr>\n          <th>エントリー方法</th>\n          <td><a href=\"../../recruit/entry/#comeback\" style=\"text-decoration:underline;\">エントリーはこちら</a></td>\n        </tr>\n        </tbody>\n      </table>\n\n    </section>\n  </main>\n\n  <div class=\"page-top\"><a href=\"#\"><img src=\"../../lib/cmn-img/recruit/pagetop.png\" alt=\"\"></a></div>\n\n<div id=\"footer-container\"></div>\n\n<script src=\"/lib/cmn-js/all.js\"></script>\n<script type=\"module\" src=\"/statichtml/asset/js/recruit.js\"></script>\n<script type=\"text/javascript\">\n  $(function() {\n      $('.height').matchHeight();\n  });\n</script>\n</body>\n\n</html>\n","finalUrl":"https://www.ttk-g.co.jp/recruit/guideline/","rendered":false,"_cachedAt":"2026-06-24T00:05:26.895Z"}