{"url":"https://www.khi-saiyo.jp/entry/","html":"<!DOCTYPE html>\r\n<html lang=\"ja\">\r\n  <head prefix=\"og: http://ogp.me/ns#\">\r\n    <meta charset=\"UTF-8\">\r\n    <script type=\"text/javascript\" src=\"//nexus.ensighten.com/uw-kawasaki/dev/Bootstrap.js\"></script>\r\n    <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n    <meta name=\"format-detection\" content=\"telephone=no\">\r\n    <title>ENTRY｜川崎重工業株式会社 総合採用サイト</title>\r\n    <meta name=\"description\" content=\"新卒採用情報をお伝えします。\">\r\n    <meta name=\"keywords\" content=\"kawasaki,KAWASAKI,カワサキ,川崎重工,川崎重工業,川重,KHI,khi,採用,キャリア,中途\">\r\n    <meta property=\"og:title\" content=\"川崎重工業株式会社 総合採用サイト\">\r\n    <meta property=\"og:locale\" content=\"ja\">\r\n    <meta property=\"og:type\" content=\"website\">\r\n    <meta property=\"og:image\" content=\"https://www.khi-saiyo.jp/assets/images/common/ogp.png\">\r\n    <meta property=\"og:url\" content=\"https://www.khi-saiyo.jp/entry/\">\r\n    <meta property=\"og:description\" content=\"新卒採用情報をお伝えします。\">\r\n    <meta property=\"og:site_name\" content=\"川崎重工業株式会社 総合採用サイト\">\r\n    <script async src=\"https://www.googletagmanager.com/gtag/js?id=G-DJP17ZHGMW\"></script>\r\n    <script>window.dataLayer = window.dataLayer || [];function gtag(){dataLayer.push(arguments);}gtag('js', new Date());gtag('config', 'G-DJP17ZHGMW');</script>\r\n    <link rel=\"stylesheet\" href=\"/assets/css/main.css\">\r\n    <link rel=\"stylesheet\" href=\"/assets_entry/css/entry.css?202307\">\r\n  </head>\r\n  <body id=\"top\">\r\n    <div class=\"js-loading\" id=\"js-loading\"><span class=\"label\">LOADING</span></div>\r\n    <header class=\"head-root\" id=\"head-root\">\r\n      <div class=\"hgroup\"><a href=\"/\">\r\n          <h1 class=\"title\">Kawasaki</h1></a>\r\n        <p class=\"sub-title\"><span class=\"ja\">川崎重工業株式会社 </span><span class=\"en\">RECRUITING SITE</span></p>\r\n      </div>\r\n      <div class=\"nav-menu\"><a class=\"button mypage\" href=\"https://job.axol.jp/jn/s/khi_24/mypage/\" target=\"_blank\">\r\n          <div class=\"inner\"><span class=\"label\">MY<br> PAGE</span></div></a><a class=\"button entry\" href=\"/entry/\">\r\n          <div class=\"inner\"><span class=\"label\">ENTRY/<br>MYPAGE</span></div></a>\r\n        <button class=\"button menu-opener\" id=\"menu-opener\"><span class=\"top\"></span><span class=\"mid\"></span><span class=\"bot\"></span></button>\r\n      </div>\r\n      <div class=\"global-menu entry\" id=\"global-menu\">\r\n        <div class=\"container\">\r\n          <div class=\"menu\">\r\n            <div class=\"item n1\">\r\n              <div class=\"title\"><span class=\"num\">01</span><span class=\"ja\">川崎重工について</span><span class=\"en\">About KHI</span></div>\r\n              <div class=\"links\"><a class=\"link\" href=\"/about/value.html\"> 川崎重工の存在意義</a><a class=\"link\" href=\"/about/aboutkhi.html\">川崎重工について</a></div>\r\n            </div>\r\n            <div class=\"item n2\">\r\n              <div class=\"title\"><span class=\"num\">02</span><span class=\"ja\">事業領域</span><span class=\"en\">Work Field</span></div>\r\n              <div class=\"links\"><a class=\"link\" href=\"/field/pronoun/\"> 未来の代名詞・川崎重工</a><a class=\"link\" href=\"/field/company.html\">COMPANY COLOR</a></div>\r\n            </div>\r\n            <div class=\"item n3\">\r\n              <div class=\"title\"><span class=\"num\">03</span><span class=\"ja\">川崎重工の描く未来</span><span class=\"en\">Vision </span></div>\r\n              <div class=\"links\"> <a class=\"link\" href=\"/vision/history.html\">未来創造ヒストリー</a>\r\n                <p class=\"link\">近未来プロジェクト</p><a class=\"link c\" href=\"/vision/project_01.html\">近未来プロジェクト01</a><a class=\"link c\" href=\"/vision/project_02.html\">近未来プロジェクト02  </a>\r\n              </div>\r\n            </div>\r\n            <div class=\"item n4\">\r\n              <div class=\"title\"><span class=\"num\">04</span><span class=\"ja\">川崎重工を支える人</span><span class=\"en\">People </span></div>\r\n              <div class=\"links\"> <a class=\"link\" href=\"/people/work.html\">職種紹介</a><a class=\"link\" href=\"/people/\">社員紹介 INDEX</a><a class=\"link\" href=\"/people/career/\">キャリア入社社員の声</a><a class=\"link\" href=\"/people/crosstalk/\"> CROSS TALK <br class=\"sp\">働き方を知る座談会</a><a class=\"link\" href=\"/people/goroku/\"> 川崎語録 </a></div>\r\n            </div>\r\n            <div class=\"item n5\">\r\n              <div class=\"title\"><span class=\"num\">05</span><span class=\"ja\">働く環境</span><span class=\"en\">Environment</span></div>\r\n              <div class=\"links\"><a class=\"link\" href=\"/environment/life/\">川崎重工での暮らし</a><a class=\"link c\" href=\"/environment/life/kobe.html\">神戸編</a><a class=\"link c\" href=\"/environment/life/akashi.html\">明石編</a><a class=\"link c\" href=\"/environment/life/gifu.html\">岐阜編</a><a class=\"link\" href=\"/environment/benefitsystem.html\">人財育成と<br class=\"sp\">教育研修制度/福利厚生制度</a><a class=\"link\" href=\"/environment/diversity.html\">ダイバーシティ推進</a></div>\r\n            </div>\r\n            <div class=\"item n6\">\r\n              <div class=\"title\"><span class=\"num\">06</span><span class=\"ja\">採用情報</span><span class=\"en\">Recruit</span></div>\r\n              <div class=\"links\"><a class=\"link\" href=\"/recruit/internship.html\">インターンシップ情報</a><a class=\"link\" href=\"/recruit/newgraduate.html\">新卒採用募集要項 (川崎重工・川崎車両)</a><a class=\"link blank\" href=\"https://www.khi-saiyo.jp/kmcrecruit/recruit/info/\" target=\"_blank\">カワサキモータース採用募集要項</a><a class=\"link blank\" href=\"https://progres01.jposting.net/pgkhi/u/job.phtml\" target=\"_blank\">キャリア採用募集要項</a><a class=\"link blank\" href=\"https://app.crm.i-myrefer.jp/entry/khi/uBHs7VOnvgPwQ9GSw5Dv\" target=\"_blank\">アルムナイ・ネットワークへの登録はこちら（カムバック採用含む）</a><a class=\"link blank\" href=\"https://app.crm.i-myrefer.jp/entry/khi/RY3jtL6DwPKcSmmekUjm\" target=\"_blank\">キャリア採用に興味のある方はこちら</a><a class=\"link\" href=\"/recruit/handicapped.html\">障がい者雇用について </a><a class=\"link blank\" href=\"https://www.khi-gr.jp/\" target=\"_blank\">関係会社募集要項 </a><a class=\"button mypage\" href=\"https://job.axol.jp/jn/s/khi_24/mypage/\" target=\"_blank\">MY PAGE</a><a class=\"button entry\" href=\"/entry/\">ENTRY/MYPAGE</a></div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </header>\r\n    <main class=\"main entry\">\r\n      <section class=\"sec-second-index recruit\">\r\n        <header class=\"head-sec\">\r\n          <p class=\"label-page\"><span class=\"num\">06</span><span class=\"text\">Recruit</span></p>\r\n          <div class=\"block-title\">\r\n            <div class=\"title\">ENTRY</div>\r\n          </div>\r\n        </header>\r\n      </section>\r\n      \r\n      <section class=\"sec-entry-body\">\r\n        <div class=\"container\">\r\n          <div class=\"box\"> <p>川崎重工（川崎車両含む）、カワサキモータースでは、それぞれ新卒採用を行っています。<br>\r\nご自身が選考に進みたい会社にエントリーしてください。グループ採用についてのFAQは下記をご確認ください。</p>\r\n          </div>\r\n          <ul class=\"btn_entry\">\r\n            <li>\r\n              <div>川崎重工<span>ENTRY</span></div>\r\n              <p class=\"entry_khi\"><a href=\"https://job.axol.jp/bx/s/khi_27/entry/agreement\" target=\"_blank\"><span>2027</span>年卒<span>ENTRY</span></a></p>\r\n              <p class=\"entry_khi\"><a href=\"https://axol.jp/zw/s/khi_28/entry/\" target=\"_blank\"><span>2028</span>年卒<span>ENTRY</span></a></p>\r\n            </li>\r\n            <li>\r\n              <div>川崎重工<span>MYPAGE</span></div>\r\n              <p class=\"mypage_khi\"><a href=\"https://job.axol.jp/bx/s/khi_27/mypage/login\"\" target=\"_blank\"><span>2027</span>年卒<span>MYPAGE</span></a></p>\r\n              <p class=\"mypage_khi\"><a href=\"https://axol.jp/zw/s/khi_28/mypage/\" target=\"_blank\"><span>2028</span>年卒<span>MYPAGE</span></a></p>\r\n            </li>\r\n          </ul>\r\n          <div class=\"km_entry\">\r\n            <div class=\"km_entry_ph\"><img src=\"../assets_entry/images/pic_entry_km.jpg\" alt=\"\"></div>\r\n            <div class=\"km_entry_txt\">\r\n              <p>カワサキモータースENTRYの方はこちら</p>\r\n              <a href=\"https://job.axol.jp/qd/s/kawasaki-motors_26/entry/agreement\" target=\"_blank\"><span>2027</span>年卒</a>\r\n              <a href=\"https://axol.jp/zw/s/kawasaki-motors_28/entry_0212000008/\" target=\"_blank\"><span>2028</span>年卒</a>\r\n            </div>\r\n          </div>\r\n          <p class=\"rail\"><a href=\"#rail\">※ 川崎車両への配属を希望している方は<span style=\"text-decoration: underline;\">こちら</span>をご確認ください。</a></p>\r\n        </div>\r\n      </section>\r\n      \r\n      <section class=\"sec-block-title\">\r\n        <div class=\"inner\">\r\n          <p class=\"type\"><span class=\"text\">contents</span></p>\r\n          <h2 class=\"title\">グループ採用FAQ</h2>\r\n        </div>\r\n      </section>\r\n      <section class=\"sec-entry-qa\">\r\n        <div class=\"container\">\r\n          <dl class=\"dl\">\r\n            <dt class=\"dt\"><span class=\"q\">Q1.</span><span class=\"text\">川崎重工とカワサキモータースの併願は可能ですか？</span></dt>\r\n            <dd class=\"dd\"><span class=\"text\">川崎重工とカワサキモータースの併願は可能です。<br>プレエントリーから本エントリーまでの間に、各種イベントを予定しております。詳細はカワサキモータース/川崎重工にプレエントリー後にご確認ください。カワサキモータースのイベントに参加希望の方はカワサキモータースの<a href=\"https://job.axol.jp/jn/s/kawasaki-motors_24/mypage/login\" target=\"_blank\">マイページ</a>に登録を、そのほか川崎重工グループのイベント参加をご希望の方は川崎重工グループの<a href=\"https://job.axol.jp/jn/s/khi_24/mypage/\" target=\"_blank\">マイページ</a>にご登録ください。</span></dd>\r\n          </dl>\r\n          <dl class=\"dl\">\r\n            <dt class=\"dt\"><span class=\"q\">Q2.</span><span class=\"text\">川崎重工、カワサキモータースで待遇や福利厚生に違いはありますか？</span></dt>\r\n            <dd class=\"dd\"><span class=\"text\">現時点では、給与・福利厚生など、待遇面での違いはありません。<br>※今後分社会社独自の制度が導入される場合があります。</span></dd>\r\n          </dl>\r\n          <dl class=\"dl\">\r\n            <dt class=\"dt\"><span class=\"q\">Q3.</span><span class=\"text\">教育研修制度等はカワサキモータース独自のものでしょうか？</span></dt>\r\n            <dd class=\"dd\"><span class=\"text\">教育研修は川崎重工グループとして実施しますので、カワサキモータースも同様の教育研修制度となります。（一部、各カンパニー・分社会社独自の研修も実施します。）</span></dd>\r\n          </dl>\r\n          <dl class=\"dl\">\r\n            <dt class=\"dt\"><span class=\"q\">Q4.</span><span class=\"text\">カワサキモータースの募集職種を教えてください。</span></dt>\r\n            <dd class=\"dd\"><span class=\"text\">川崎重工グループの募集職種と同様です。詳しくは<a href=\"https://www.khi-saiyo.jp/people/work.html\">こちら</a>。</span></dd>\r\n          </dl>\r\n          <dl class=\"dl\">\r\n            <dt class=\"dt\"><span class=\"q\">Q5.</span><span class=\"text\">入社後、川崎重工・カワサキモータース間で異動はありますか？</span></dt>\r\n            <dd class=\"dd\"><span class=\"text\">分社会社も含め、カンパニーの枠を超えた人財の流動化を目指しているため、異動の可能性はあります。</span></dd>\r\n          </dl>\r\n          <dl class=\"dl\" id=\"rail\">\r\n            <dt class=\"dt\"><span class=\"q\">Q6.</span><span class=\"text\">2021年10月には、カワサキモータースだけでなく川崎車両も分社化しましたが、川崎車両の採用はどうなるのでしょうか？</span></dt>\r\n            <dd class=\"dd\"><span class=\"text\">川崎車両については、川崎重工として一括採用後に配属を決定します。川崎車両への配属をご希望の方は、川崎重工グループの<a href=\"https://axol.jp/zw/s/khi_28/mypage/login\" target=\"_blank\">マイページ</a>にご登録ください。入社後の待遇・教育研修制度等については、上記カワサキモータースについての記載と同様です。川崎車両へ配属となった方は、入社後一定期間は川崎重工からの出向として勤務し、一定期間経過後に転籍いただきます。</span></dd>\r\n          </dl>\r\n        </div>\r\n      </section>\r\n    </main>\r\n    <footer class=\"foot-root\" id=\"js-foot-root\">\r\n      <div class=\"links\"><a class=\"text blank\" href=\"https://www.khi.co.jp/\" target=\"_blank\"> 川崎重工業株式会社オフィシャルサイト</a><a class=\"banner\" data-aos=\"fade-up\" href=\"https://answers.khi.co.jp/\" target=\"_blank\"><img src=\"/assets/images/common/thm_foot_01.png\" width=\"170\" alt=\"\"></a><a class=\"link\" data-aos=\"fade-down\" href=\"https://www.youtube.com/channel/UCzfhPd8i2-rpMSE6Ey0Oeyg\" target=\"_blank\"><img src=\"/assets/images/common/thm_foot_02.png\" width=\"96\" alt=\"\"></a></div>\r\n      <div class=\"foot\">\r\n        <address class=\"cr\">Copyright &copy; Kawasaki Heavy Industries, Ltd. All rights reserved.</address>\r\n        <div class=\"misc\"><a class=\"link\" href=\"https://www.khi.co.jp/cookie_policy/\" target=\"_blank\">クッキーポリシー</a><a class=\"link\" href=\"javascript:Bootstrapper.gateway.openModal();\"> クッキー詳細設定</a></div><a class=\"totop js-smooth-scroll\" href=\"#top\"></a>\r\n      </div>\r\n    </footer>\r\n    <script src=\"/assets/js/main.js\"></script>\r\n    <script src=\"/assets_entry/js/jquery-3.6.0.min.js\"></script>\r\n    <script src=\"/assets_entry/js/entry.js\"></script>\r\n  <script type=\"text/javascript\" src=\"https://api.crm.i-myrefer.jp/track/L2wH15crfNBkkAhVWzd3ie7AYljigUSnS7tWHHDFFXdq310o6X/mt.js\"></script>\r\n</body>\r\n</html>","finalUrl":"https://www.khi-saiyo.jp/entry/","rendered":false,"_cachedAt":"2026-06-23T23:17:04.857Z"}