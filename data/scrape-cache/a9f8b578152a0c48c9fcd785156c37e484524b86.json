color-private\">\n                    <h2 class=\"d-none d-sm-block text1\">あらゆる業界に対応した<br>「付加価値」を創造する</h2>\n                    <img src=\"/common/images/top-menu-private.png\" alt=\"民間アイコン\" class=\"d-none d-sm-block\" />\n                    <div class=\"row wid100\" style=\"margin-left:0;\">\n                        <h2 class=\"col-6 col-sm-12 text2\">民間<span>販売業・製造業</span></h2>\n                        <div class=\"d-block d-sm-none col-6 col-sm-12 col-center\">\n                            <img src=\"/common/images/top-menu-private.png\" alt=\"民間アイコン\" />\n                        </div>\n                    </div>\n                </div>\n            </a>\n        </div>\n        <!-- 下 -->\n        <div class=\"col-6 col-sm-3 panel-base panel4\">\n            <a href=\"/cloud/\">\n                <div class=\"top-menu-panel color-cloud col-center\">\n                    <h2 class=\"d-none d-sm-block text1\">場所やデバイスを問わず<br>「効率」と「安心」を支援</h2>\n                    <img src=\"/common/images/top-menu-cloud.png\" alt=\"クラウドアイコン\" class=\"col-panel-img-small\" />\n                    <h2 class=\"text2\">クラウド<span>ASP・SaaS</span></h2>\n                </div>\n            </a>\n        </div>\n        <div class=\"col-6 col-sm-3 panel-base panel5\">\n            <a href=\"https://www.icc-idc.jp/\" target=\"_blank\">\n                <div class=\"top-menu-panel color-datacenter col-center\">\n                    <h2 class=\"d-none d-sm-block text1\">堅牢なデータセンターで<br>安心・安全・信頼のサービスを提供</h2>\n                    <img src=\"/common/images/top-menu-datacenter.png\" alt=\"データセンターアイコン\" class=\"col-panel-img-small\" />\n                    <h2 class=\"text2\">データセンター<span>アウトソーシング</span></h2>\n                </div>\n            </a>\n        </div>\n        <div class=\"col-6 col-sm-3 panel-base panel6\">\n            <a href=\"/security/\">\n                <div class=\"top-menu-panel color-security col-center\">\n                    <h2 class=\"d-none d-sm-block text1\">情報セキュリ