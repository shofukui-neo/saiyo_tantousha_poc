ab_selecter li').removeClass('active');\n\t\t\t\t\t\t$(this).addClass('active');\n\t\t\t\t\t})\n\t\t\t\t\t$('#selecter2').click(function(){\n\t\t\t\t\t\t$('#tab01').fadeOut('fast');\n\t\t\t\t\t\t$('#tab02').fadeIn('fast');\n\t\t\t\t\t\t$('.tab_selecter li').removeClass('active');\n\t\t\t\t\t\t$(this).addClass('active');\n\t\t\t\t\t})\n\n\t\t\t\t});\n\t\t\t</script>\n<script>\n\t\t\t\t\twindow.onpageshow = function() {\n\t\t\t\t\t\tif ($(\"#doui\").is(':checked')) {\n\t\t\t\t\t\t\t$('#submit_btn input').prop('disabled', false);\n\t\t\t\t\t\t} else {\n\t\t\t\t\t\t\t$('#submit_btn input').prop('disabled', true);\n\t\t\t\t\t\t}\n\t\t\t\t\t};\n\n</script>\n\t\t</head>\n\t\t<body class=\"page-template page-template-page-main page-template-page-main-php page page-id-10 has-header-image page-two-column colors-light\">\n\n\t\t\t<h1 id=\"logo\">\n\t\t\t\t<a href=\"https://www.systembase.co.jp/\">株式会社システムベース　オフィシャルサイトに移動</a>\n\t\t\t\t<!--<div id=\"tour_bnr\"><a href=\"https://www.systembase.co.jp/recruit/tour.html\" target=\"_blank\"><img src=\"https://www.systembase.co.jp/recruit/wp-content/uploads/2022/02/banner_tour_s.svg\" width=\"180\" height=\"60\" alt=\"\"></a></div>-->\n\t\t\t</h1>\n\t\t\t<header>\n\t\t\t\t\t\t\t\t\t<h2>『仕事を知る』</h2>\n\t\t\t\t\t\t\t</header>\n\n\t\t\t<nav id=\"gnav\">\n\t\t\t\t<div id=\"mynavi\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<!-- Begin mynavi Navi Link -->\r\n<a href=\"https://job.mynavi.jp/27/pc/search/corp55373/outline.html\" target=\"_blank\">\r\n<img src=\"https://www.systembase.co.jp/recruit/wp-content/uploads/2025/09/banner_entry2027.png\" alt=\"マイナビ2027\" border=\"0\">\r\n</a>\r\n<!-- End mynavi Navi Link -->\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t\t<ul>\n\t\t\t\t\t\t<li id=\"gnav01\"><a href=\"https://www.systembase.co.jp/recruit/recruit6/\" title=\"エントリーフォーム\">エントリーフォーム</a></li>\n\t\t\t\t\t\t<li id=\"gnav02\"><a href=\"https://www.systembase.co.jp/recruit/#section5f\" title=\"会社説明会・募集要項\">会社説明会・募集要項</a></li>\n\t\t\t\t\t\t<li id=\"gnav03\"><a href=\"https://www.systembase.co.jp/recruit/#section4f\" title=\"キャリアと制度\">キャリアと制度</a></li>\n\t\t\t\t\t\t<li id=\"gnav04\"><a href=\"https://www.systembase.co.jp/recruit/#section3f\" title=\"人を知る\">人を知る</a></li>\n\t\t\t\t\t\t<li id=\"gnav05\"><a href=\"https://www.systembase.co.jp/recruit/#section2f\" title=\"仕事を知る\">仕事を知る</a></li>\n\t\t\t\t\t\t<li id=\"gnav06\"><a href=\"https://www.systembase.co.jp/recruit/#section1f\" title=\"企業を知る\">企業を知る</a></li>\n\t\t\t\t\t</ul>\n\t\t\t\t\t\t\t</nav><main>\n\t\t\t\t\t\t\t\t\t\t\t\t\t<section id=\"section1\">\r\n<article>\r\n<h3>地域密着型のシステムインテグレーター</h3>\r\n<p>当社は、お客様の業種ごとに、ニーズ、解決課題を見極め、きめこまやかなサポートを行っています。</p>\r\n<div class=\"inner\">\r\n<dl>\r\n<dt>流通業</dt>\r\n<dd>卸売業向け総合販売管理システムなど、業種業態に即した情報の構築と活用のご提案</dd>\r\n</dl>\r\n<dl>\r\n<dt>小売業</dt>\r\n<dd>EOS・EDI業務をはじめ、店舗・顧客管理を含めたトータルシステムのご提供。</dd>\r\n</dl>\r\n<dl>\r\n<dt>製造業</dt>\r\n<dd>生産管理システム・画像検査システムなどトータルソリューションのご提案</dd>\r\n</dl>\r\n<dl>\r\n<dt>建設業</dt>\r\n<dd>工事原価管理・CAD&amp;CGによるものなど、豊富なシステムのご提供。</dd>\r\n</dl>\r\n<dl>\r\n<dt>医療</dt>\r\n<dd>岩手県内の多くの病院・医院様でのご利用実績も豊富。<br>\r\n医事業務システム・電子カルテ・給食・薬品在庫・調剤・歯科・介護。予約管理等様々なシステムのご提案。</dd>\r\n</dl>\r\n<dl>\r\n<dt>公共</dt>\r\n<dd>健康管理システム・図書館システム・消防署向け救急統計など、幅広い分野でのシステムのご提供。</dd>\r\n</dl>\r\n<dl>\r\n<dt>文教</dt>\r\n<dd>数多くの各学校教室向けパソコンシステムの納入実績を誇る。教務を支援する総合的なシステムのご提供。</dd>\r\n</dl>\r\n<dl>\r\n<dt>全業種向け</dt>\r\n<dd>一斉メール配信・安否確認・データバックアップ・ハウジング／ホスティングなどのクラウドサービス、情報開発者向け開発支援ツールのご提供</dd>\r\n</dl>\r\n<img fetchpriority=\"high\" decoding=\"async\" src=\"https://www.systembase.co.jp/recruit/wp-content/uploads/2022/02/recruit2_img1.svg\" width=\"553\" height=\"309\" alt=\"\"></div>\r\n</article>\r\n</section>\r\n<section id=\"section2\">\r\n<article>\r\n<h3>業務内容</h3>\r\n<p>コンピューターシステムは、そのシステムだけでは機能を果たすことができません。</p>\r\n<p>お客様のご要望を満たすための一つのツールがコンピューターシステムです。</p>\r\n<p>お客様とコンピューターシステムが一体となってはじめてお客様のご要望が具現化されるものと考えます。</p>\r\n<p>コンサルティングセールス活動を通して、お客様にとって効果的で価値のあるシステムのご提供を行っていきたいと考えます。</p>\r\n<div class=\"inner\">\r\n<dl>\r\n<dt>システムコンサルティング</dt>\r\n<dd>長年にわたり技術研修を重ね確かな実績を持つ当社では、経験を生かした独自のシステムをご提供しています。<br>\r\n地域への貢献を第一と考える当社だからできるシステムコンサルティングを目指し、お客様のアイディアをシステムとして生かしたい、価値あるものをより豊かに生かしたいと考えています。</dd>\r\n</dl>\r\n<dl>\r\n<dt>ソフトウェア開発</dt>\r\n<dd>当社では豊富な経験と実績を生かし、ユーザーサイドに立った経営情報システムの開発から最先端の応用技術開発にいたるまで広範囲なソフトウェア開発を行い、高い評価をいただいています。その技術はオープンシステム・ネットワークセキュリティ対策等広範囲に力を発揮しています。</dd>\r\n</dl>\r\n<dl>\r\n<dt>コンピュータ機器販売・システムの販売</dt>\r\n<dd>パソコン・サーバー・タブレット端末など、幅広い機器を取扱っています。また、各種業務パッケージの販売・導入及び、各種ビジネスセミナーを開催し、地域に密着したサービスをご提供しています。</dd>\r\n</dl>\r\n<dl>\r\n<dt>データセンターサービス</dt>\r\n<dd>長年の情報処理サービス提供実績により、企業のあらゆるニーズに応えるノウハウを確立しています。<br>\r\nセキュリティには万全を期し、ホスティング・ハウジングサービスをはじめとし、「所有」から「利用」へと変化する環境にも対応、クラウドサービスもご提供いたします。</dd>\r\n</dl>\r\n<dl>\r\n<dt>ソフト／ハードウェア保守</dt>\r\n<dd>ソフトウェアのサポートにハードウェア・ネットワークの保守業務を加えてサポート体制をご提供しています。高度情報化社会のテンポの速い技術進化にも十分に対応できる経験豊かな技術者が、お客様をサポートいたします。</dd>\r\n</dl>\r\n<dl>\r\n<dt>技術者派遣</dt>\r\n<dd>岩手県内屈指の工業都市北上市、その近郊の企業からの要望に応えて、経験豊富なコンピュータ技術者の派遣を行っています。さらに、首都圏の関連会社へ技術者出向を行い、高い評価をいただいています。</dd>\r\n</dl>\r\n</div>\r\n</article>\r\n</section>\r\n<section id=\"section3\">\r\n<article>\r\n<h3>入社後の流れ</h3>\r\n<table>\r\n<tbody>\r\n<tr>\r\n<th>10月</th>\r\n<td>内定式</td>\r\n</tr>\r\n<tr>\r\n<th>4月</th>\r\n<td>入社式、各部門説明、マナー講習等<br>\r\nプログラム研修（VB.NET、SQL、JAVA、SB社製の各種ツールの基本的技術の習得</td>\r\n</tr>\r\n<tr>\r\n<th>6月</th>\r\n<td>各部署に配属（メンター制度によるOJT研修）、電話研修</td>\r\n</tr>\r\n</tbody>\r\n</table>\r\n<p>入社後の新入社員研修、2ヵ月間のプログラム開発研修を経て配属されます。配属後は、ＯＪＴ研修のほか、各種研修でスキルアップを図っております。</p>\r\n<p>また、社員は隔月に行われる社内試験で日頃の勉強の力試をして、資格取得をめざしています。 営業はもちろん、プログラマーもシステムエンジニアも、人との関わりは大切です。『明るく積極的で、コミュニケーション能力の優れている人』を求めています。</p>\r\n</article>\r\n</section>\r\n<section id=\"section4\">\r\n<article>\r\n<h3>1日の流れ</h3>\r\n<dl>\r\n<dt>技術職（システムエンジニア）</dt>\r\n<dd><img decoding=\"async\" src=\"https://www.systembase.co.jp/recruit/wp-content/uploads/2022/02/day_flow01.svg\" width=\"765\" height=\"351\" alt=\"\"></dd>\r\n<dd class=\"photo_box\"><img decoding=\"async\" src=\"https://www.systembase.co.jp/recruit/wp-content/uploads/2025/09/recruit2_flow1.webp\" alt=\"技術職（システムエンジニア）\"></dd>\r\n</dl>\r\n<dl>\r\n<dt>技術職（プログラマ）</dt>\r\n<dd><img decoding=\"async\" src=\"https://www.systembase.co.jp/recruit/wp-content/uploads/2022/02/day_flow02.svg\" width=\"669\" height=\"354\" alt=\"\"></dd>\r\n<dd class=\"photo_box\"><img decoding=\"async\" src=\"https://www.systembase.co.jp/recruit/wp-content/uploads/2025/09/recruit2_flow2.webp\" alt=\"A Dummy Image\"></dd>\r\n</dl>\r\n<dl>\r\n<dt>営業職(社内日）</dt>\r\n<dd><img loading=\"lazy\" decoding=\"async\" src=\"https://www.systembase.co.jp/recruit/wp-content/uploads/2022/02/day_flow04.svg\" width=\"663\" height=\"364\" alt=\"\"></dd>\r\n<dd class=\"photo_box\"><img decoding=\"async\" src=\"https://www.systembase.co.jp/recruit/wp-content/uploads/2025/09/recruit2_flow3.webp\" alt=\"\"></dd>\r\n</dl>\r\n<dl>\r\n<dt>営業職(社外日）</dt>\r\n<dd><img loading=\"lazy\" decoding=\"async\" src=\"https://www.systembase.co.jp/recruit/wp-content/uploads/2022/03/day_flow03.svg\" width=\"663\" height=\"364\" alt=\"\"></dd>\r\n<dd class=\"photo_box\"><img decoding=\"async\" src=\"https://www.systembase.co.jp/recruit/wp-content/uploads/2025/09/recruit2_flow4.webp\" alt=\"\"></dd>\r\n</dl>\r\n</article>\r\n</section>\t\t\t\t\t\t\t</main>\n\n<p class=\"gotop\"><a href=\"#\">▲&nbsp;UP</a></p>\n<footer>\n\t<nav id=\"fnav\" class=\"clearfix\">\n\t\t<ul>\n\t\t\t<li><a href=\"https://www.systembase.co.jp/about/privacy/\" title=\"個人情報保護方針\">→個人情報保護方針</a></li>\n\t\t\t<li><a href=\"https://www.systembase.co.jp/about/security/\" title=\"情報セキュリティ基本方針\">→情報セキュリティ基本方針</a></li>\n\t\t</ul>\n\t</nav>\n\t<div id=\"copyright\">&copy; SystemBase all rights reserved.</div>\n</footer>\n</body>\n</html>","finalUrl":"https://www.systembase.co.jp/recruit/recruit2/","rendered":false,"_cachedAt":"2026-06-23T20:58:51.177Z"}