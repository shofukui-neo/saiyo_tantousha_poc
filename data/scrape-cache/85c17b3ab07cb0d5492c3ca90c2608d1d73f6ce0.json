</li>\n        <li class=\"parent\">\n          <a href=\"recruitment/\" class=\"current-recruitment opacity\">RECRUIT<small class=\"sp-nav\">採用情報</small></a>\n          <div class=\"header__navi__child\">\n            <div class=\"in\">\n              <p class=\"ttl\"><strong>RECRUIT</strong>採用情報</p>\n              <ul>\n                <li><a href=\"recruitment/#message\" class=\"opacity\">採用メッセージ</a></li>\n                <li><a href=\"recruitment/#recruitment\" class=\"opacity\">募集要項</a></li>\n                <li><a href=\"recruitment/#faq\" class=\"opacity\">よくある質問</a></li>\n              </ul>\n            </div>\n          </div>\n        </li>\n      </ul>\n      <div class=\"header__btn pc-nav\">\n        <a href=\"assets/pdf/opencompany_2028summer.pdf\" class=\"btn01\" target=\"_blank\"><span>OPEN COMPANY</span></a>\n        <a class=\"btn02 non-scroll\" onclick=\"modalOpen(event, 'Entry')\"><span>ENTRY / MYPAGE</span></a>\n      </div>\n      <div class=\"header__bottom sp-nav\">\n        <a class=\"c-btn02 color01 opacity\" onclick=\"modalOpen(event, 'Entry')\">\n          ENTRY/MYPAGE\n          <div class=\"c-arrow\">\n            <img src=\"assets/img/common/ico_arrow01_white.svg\" alt=\"\" />\n          </div>\n        </a>\n        <a href=\"assets/pdf/opencompany_2028summer.pdf\" class=\"c-btn02 color02 opacity\" target=\"_blank\">\n          <span>OPEN COMPANY</span>\n          <div class=\"c-arrow color02\">\n            <img src=\"assets/img/common/ico_arrow01_gradient.svg\" alt=\"\" />\n          </div>\n        </a>\n      </div>\n    </nav>\n  </div>\n</header>\n\n<div class=\"modal\" id=\"modalEntry\">\n  <div class=\"modal__overlay\" onclick=\"modalClose(event, 'Entry')\"></div>\n  <div class=\"modal__box\">\n    <div class=\"modal__inner\">\n      <p class=\"modal__ttl\">ENTRY / MYPAGE</p>\n      <div class=\"modal__btn\">\n        <!-- <a href=\"assets/pdf/opencompany_2028summer.pdf\" class=\"c-btn no-link\" target=\"_blank\">\n          