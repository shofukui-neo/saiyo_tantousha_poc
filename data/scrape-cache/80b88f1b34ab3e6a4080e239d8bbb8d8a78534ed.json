{"url":"https://gyosei.jp/recruit/rec_contact/","html":"<!DOCTYPE html>\n<html lang=\"ja\" class=\"no-js\">\n<head>\n\t<meta charset=\"UTF-8\">\n  <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n  <meta name=\"viewport\" content=\"width=device-width\">\n\n<!-- Google Tag Manager -->\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n})(window,document,'script','dataLayer','GTM-P3BQK43');</script>\n<!-- End Google Tag Manager -->\n\n\t<title>  採用に関する問い合わせ ｜ 株式会社ぎょうせい</title>\n\t<meta name=\"keywords\" content=\"\">\n\t<meta name=\"description\" content=\"\">\n\t<meta name=\"author\" content=\"株式会社ぎょうせい\">\n\n\t<link rel=\"profile\" href=\"http://gmpg.org/xfn/11\">\n\t\t<script>(function(html){html.className = html.className.replace(/\\bno-js\\b/,'js')})(document.documentElement);</script>\n<style type=\"text/css\">.recentcomments a{display:inline !important;padding:0 !important;margin:0 !important;}</style>  <link rel=\"stylesheet\" href=\"https://gyosei.jp/wp/wp-content/themes/gyosei_co/css/lightbox.min.css\" media=\"all\">\n  <link rel=\"stylesheet\" href=\"https://gyosei.jp/wp/wp-content/themes/gyosei_co/css/style.css?20260120\" media=\"all\">\n\n  <script src=\"https://gyosei.jp/wp/wp-content/themes/gyosei_co/js/vendor/jquery-1.11.3.min.js\"></script>\n  <script src=\"https://gyosei.jp/wp/wp-content/themes/gyosei_co/js/vendor/jquery.tile.min.js\"></script>\n  <script src=\"https://gyosei.jp/wp/wp-content/themes/gyosei_co/js/vendor/lightbox.min.js\"></script>\n  <script src=\"https://gyosei.jp/wp/wp-content/themes/gyosei_co/js/common.js\"></script>\n\n\t<script type=\"text/javascript\" src=\"//typesquare.com/accessor/script/typesquare.js?Z9CxUviZQW8%3D\" charset=\"utf-8\"></script>\n</head>\n\n<body class=\"page-template-default page page-id-293 page-child parent-pageid-261\">\n\n<!-- Google Tag Manager (noscript) -->\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-P3BQK43\"\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n<!-- End Google Tag Manager (noscript) -->\n\n<div id=\"container\">\n<header id=\"globalheader\">\n<div class=\"siteLogo\"><a href=\"/\" class=\"on\"><img src=\"https://gyosei.jp/wp/wp-content/themes/gyosei_co/images/global/logo_gyousei.png\" alt=\"ぎょうせい\" width=\"185\" height=\"42\"></a></div>\n</header>\n\n<nav id=\"globalnavi\">\n<div class=\"btnMenu\"><span>menu</span></div>\n<div class=\"menuBody\">\n<ul class=\"mainMenu\">\n\n<li class=\"gnHome\"><a href=\"/\">Home</a></li>\n\n<li class=\"gnCompany\">\n<a href=\"/company/\">企業情報</a>\n<div class=\"lowerMenu\">\n<dl class=\"clearfix\">\n<dt><a href=\"/company/\">企業情報</a></dt>\n<dd>\n<ul>\n<li><a href=\"/company/message/\">ごあいさつ</a></li>\n<li><a href=\"/company/outline/\">会社概要</a></li>\n<li><a href=\"/company/statement/\">ぎょうせいについて</a></li>\n<li><a href=\"/company/history/\">会社沿革</a></li>\n<li><a href=\"/mediaclip/\">メディアクリップ</a></li>\n<li><a href=\"/company/organization/\">組織体制</a></li>\n<li><a href=\"/company/group/\">グループ企業</a></li>\n<li><a href=\"/company/office/\">事業所・担当地域一覧</a></li>\n<li><a href=\"/company/compliance/\">コンプライアンス</a></li>\n<li><a href=\"/company/security/\">情報セキュリティ</a></li>\n<li><a href=\"/company/privacypolicy/\">個人情報保護基本方針</a></li>\n<li class=\"spDoubleLine pcLongLine\"><a href=\"/company/socialmedia/\">ソーシャルメディア<br class=\"only-sp\">公式アカウント一覧</a></li>\n</ul>\n</dd>\n</dl>\n<div class=\"linkList\"><a href=\"/company/\">企業情報一覧へ</a></div>\n</div>\n</li>\n\n<li class=\"gnBusiness\">\n<a href=\"/business/\">事業分野</a>\n<div class=\"lowerMenu\">\n<dl class=\"clearfix\">\n<dt><a href=\"/business/\">事業分野</a></dt>\n<dd>\n<ul>\n<li><a href=\"/business/publishing/\">総合出版</a></li>\n<li><a href=\"/business/dcs/\">デジタルコンテンツサービス</a></li>\n<li class=\"spDoubleLine\"><a href=\"/business/law/\">法令・例規・<br class=\"only-sp\">企業法務サービス</a></li>\n<li><a href=\"/business/system/\">地方公共団体情報システム</a></li>\n<li><a href=\"/business/event/\">地域創生・地域活性化</a></li>\n</ul>\n</dd>\n</dl>\n<div class=\"linkList\"><a href=\"/business/\">事業分野一覧へ</a></div>\n</div>\n</li>\n\n<li class=\"gnRecruit current\"><a href=\"/recruit/\">採用情報</a></li>\n\n<li class=\"gnInquiry\"><a href=\"/inquiry/\">お問い合わせ</a></li>\n\n<li class=\"gnInquiry\"><a href=\"/collabo_inquiry/\">協業に関するお問い合わせ</a></li>\n\n</ul>\n\n<ul class=\"subMenu\">\n<li><a href=\"/news/\">お知らせ</a></li>\n<li><a href=\"/faq/\">よくあるご質問</a></li>\n</ul>\n\n<div class=\"siteSearch\">\n<script>\n  (function() {\n  \tvar cx = '001811576467755339547:phksktl1kaw';\n  \tvar gcse = document.createElement('script');\n  \tgcse.type = 'text/javascript';\n  \tgcse.async = true;\n  \tgcse.src = 'https://cse.google.com/cse.js?cx=' + cx;\n  \tvar s = document.getElementsByTagName('script')[0];\n  \ts.parentNode.insertBefore(gcse, s);\n  })();\n</script>\n<gcse:searchbox-only></gcse:searchbox-only>\n</div>\n\n<ul class=\"socialLinks\">\n<li><a href=\"#\" class=\"on\"><img src=\"https://gyosei.jp/wp/wp-content/themes/gyosei_co/images/global/icon_facebook.png\" alt=\"facebook\"></a></li>\n<li><a href=\"#\" class=\"on\"><img src=\"https://gyosei.jp/wp/wp-content/themes/gyosei_co/images/global/icon_twitter.png\" alt=\"twitter\"></a></li>\n<li><a href=\"#\" class=\"on\"><img src=\"https://gyosei.jp/wp/wp-content/themes/gyosei_co/images/global/icon_gplus.png\" alt=\"Google +\"></a></li>\n</ul>\n\n<div class=\"linkOnlineshop\"><a href=\"http://shop.gyosei.jp/\" class=\"on\" target=\"_blank\"><span>オンラインショップ</span></a></div>\n</div>\n</nav>\n\n<div class=\"cookie\" id=\"cookie\">\n  <div class=\"cookie_block\">\n    <div class=\"cookie_box\">\n      <div class=\"cookie_text\">\n        <p>当ウェブサイトでは、お客様のサービス向上のためCookie (クッキー)を使用しています。ブラウザの設定よりCookieの機能を変更することができます。Cookieの利用に同意していただける場合は、同意ボタンをクリックしてください。</p>\n        <div class=\"cookie_text_link_container\">→ <a href=\"/about/privacy/\" class=\"cookie_text_link\">個人情報の取扱いについて</a></div>\n      </div>\n      <div class=\"cookie_button_container\">\n        <button type=\"button\" class=\"cookie_button on\" id=\"cookie_button\">同意</button>\n      </div>\n    </div>\n  </div>\n</div>\n\r\n<div id=\"topicPath\" class=\"topicPath_recruit\">\r\n<ul>\r\n<li><a href=\"https://gyosei.jp\">Home</a></li>\r\n<li><a href=\"https://gyosei.jp/recruit/\">採用情報</a></li><li>採用に関する問い合わせ</li>\r\n</ul>\r\n</div>\r\n\r\n<div id=\"mainArea\" class=\" recruitPage clearfix\">\r\n\r\n<div id=\"content\">\r\n\r\n<section id=\"mainContents\" class=\"cat-recruit page-rec_contact\">\r\n\r\n  <h1 class=\"recruitPage_ttlImg\">\r\n    <img src=\"/wp/wp-content/themes/gyosei_co/images/v/recruit/rec_contact/images/img_rec_contact_01.jpg\" alt=\"\" class=\"only-pc\">\r\n    <img src=\"/wp/wp-content/themes/gyosei_co/images/v/recruit/rec_contact/images/img_rec_contact_01-sp.jpg\" alt=\"\" class=\"only-sp\">\r\n    <div class=\"ttlInnner_txt\">採用に関するお問い合わせ</div>\r\n  </h1>\r\n<div class=\"wdt780\">\r\n<article class=\"articleBox\">\r\n<h2 class=\"rec_contactTitle1\">新卒採用お問い合わせ</h2>\r\n<p class=\"articleText\"><b>◆2028年卒業の方向け</b>\r\n<br>\r\n1DAY仕事体験の予約受付中です！<br>\r\n2時間程度で、会社概要説明＋企画業務の疑似体験の2つのプログラムをご体験いただけます。<br>\r\n<a href=\"https://job.mynavi.jp/28/pc/corpinfo/displaySeminarList/index?corpId=77259\" target=\"_blank\" rel=\"noopener\">マイナビ2028</a>・<a href=\"https://job.career-tasu.jp/corp/00012297/\" target=\"_blank\" rel=\"noopener\">キャリタス就活</a>のいずれかよりお申し込みください。\r\n</p>\r\n<p class=\"articleText\"><b>◆2027年卒業の方向け</b>\r\n<br>\r\n採用活動を実施中です。<br>\r\n<a href=\"https://job.mynavi.jp/27/pc/search/corp77259/employment.html\" target=\"_blank\" rel=\"noopener\">マイナビ2027</a>よりお申込みいただけます。<br>\r\n<br>\r\n【対象職種】<br>\r\n　総合職（全事業所に配属可能性あり）<br>\r\n【採用予定人数】<br>\r\n　20名<br>\r\n【選考参加条件】<br>\r\n　四大卒以上\r\n</p>\r\n\r\n<div class=\"grayBoxArea\">\r\n<h3 class=\"rec_contactTitle-s\">新卒採用に関するお問い合わせ先</h3>\r\n<p>株式会社ぎょうせい人事総務部人事課　新卒採用担当<br>\r\nMAIL：<a href=\"mailto:saiyo@gyosei.co.jp\">saiyo@gyosei.co.jp</a><br>\r\nTEL：<a href=\"tel:0368926014\">03-6892-6014</a></p>\r\n</div>\r\n</article>\r\n\r\n<article class=\"articleBox\">\r\n<p class=\"caution\">お問い合わせいただく際にご提供いただく個人情報の取扱いについては、<a href=\"/company/privacypolicy/\">「個人情報保護基本方針」</a><a href=\"/about/privacy/\">「個人情報の取扱いについて」</a>をご確認ください。</p>\r\n</article>\r\n\r\n<article class=\"articleBox\" id=\"anch02\">\r\n<h2 class=\"rec_contactTitle2\">中途採用お問い合わせ</h2>\r\n<p class=\"articleText\">★自治体の頼れるパートナーとして地域に貢献★<br>\r\nご経験・スキルに応じて、いずれかをお任せいたします！<br>\r\n <br>\r\n【営業】ソリューション提案営業 /全国9支社（勤務地希望可）<br>\r\n自治体の課題を当社の商品やサービスで解決する、企画提案のルート営業をお任せします。<br>\r\nまた既にご導入いただいているシステムのサポートも担当します。<br>\r\n <br>\r\n【出版企画部】書籍の企画・編集、Webコンテンツの企画制作 /本部<br>\r\n(1)法律関係の実務書、自治体や学校向けの書籍・雑誌の企画編集、Webコンテンツの企画・制作をお任せします。<br>\r\n(2)自治体史・周年記念史等の編集・制作をお任せします。<br>\r\n <br>\r\n【出版営業部】Webマーケティング /本部<br>\r\n書籍のマーケティング戦略の立案、商品開発・販売展開をサポートする部署です。<br>\r\nWebチームにて、オウンドメディアの管理・運営、ECサイトの登録・更新をお任せします。<br>\r\n<br>\r\n【法令コンテンツ事業推進部】サービス開発から運用に関わるリーダーポジション /本部<br>\r\n自治体向け書籍のデジタルコンテンツ化や検索サービス開発、開発委託先管理、当社作業進捗管理、総合テスト設計、業務運用設計などをお任せします。<br>\r\n<br>\r\n【システム事業部】企画・開発・運用 /本部<br>\r\n行政事務の効率化を目的としたパッケージソフトの企画・開発・運用や、各支社の営業支援をお任せします。<br>\r\n <br>\r\n◆応募条件<br>\r\n◎四大卒以上<br>\r\n◎社会人経験あり<br>\r\n<br>\r\n◆歓迎するスキル<br>\r\n◎無形商材の提案営業<br>\r\n◎書籍の企画・編集<br>\r\n◎Webコンテンツのサービスデザイン・販促<br>\r\n◎Webマーケティングの実務経験<br>\r\n◎システムの開発・運用・サポート<br>\r\n<br>\r\n◆求める人物<br>\r\n◎コミュニケーション力のある方<br>\r\n◎リーダーシップのある方<br>\r\n◎地域社会への貢献性に興味のある方<br>\r\n<br>\r\n◆勤務地<br>\r\n◎支社<br>\r\n　　北海道支社（札幌）、東北支社（仙台）、関東支社（東京）、東京支社（東京）、東海支社（名古屋）、<br>\r\n　　関西支社（大阪）、中国支社（広島）、四国支社（松山）、九州支社（福岡）<br>\r\n◎本部<br>\r\n　　出版企画部、出版営業部、法令コンテンツ事業推進部、システム事業部（いずれも東京）<br>\r\n<br>\r\n◆応募方法<br>\r\n◎郵便でのご応募<br>\r\n　　次の2点の応募書類を問い合わせ先にお送りください。<br>\r\n　　(1)履歴書（写真あり、学歴は高校からご記入ください）<br>\r\n　　(2)職務経歴書（新卒からご記入ください）<br>\r\n<!--<br>\r\n◎転職サイトからのご応募<br>\r\n　　<a href=\"https://tenshoku.mynavi.jp/jobinfo-216223-3-6-1/\" target=\"new\" rel=\"noopener\">マイナビ転職</a> からご応募ください。<br>\r\n　　※SE職（法令コンテンツ事業・システム事業）をご希望の方は<a href=\"https://tenshoku.mynavi.jp/jobinfo-216223-4-13-1/\" target=\"new\" rel=\"noopener\">こちら</a>のページからご応募ください。\r\n<br>--!>\r\n<br>\r\n※採用が定員に達した時点で終了いたします（予告はございません）。<br>\r\n<br>\r\n◆労働施策総合推進法に基づく中途採用比率の公表<br>\r\n　正規雇用労働者の中途採用比率（公表日：2026年5月13日）<br>\r\n<!--　【2021年度】33.3％<br>--!>\r\n<!--　【2022年度】18.2％<br>--!>\r\n　【2023年度】28.6％<br>\r\n　【2024年度】27.8％<br>\r\n　【2025年度】48.3％<br>\r\n</p>\r\n<div class=\"grayBoxArea\">\r\n<h3 class=\"rec_contactTitle-s\">中途採用に関するお問い合わせ先</h3>\r\n<p>株式会社ぎょうせい人事総務部人事課　中途採用担当<br>\r\n〒136-8575　東京都江東区新木場1-18-11<br>\r\nMAIL：<a href=\"mailto:t-saiyo@gyosei.co.jp\">t-saiyo@gyosei.co.jp</a><br>\r\nTEL：<a href=\"tel:0368926014\">03-6892-6014</a></p>\r\n</div>\r\n</article>\r\n\r\n<article class=\"articleBox\">\r\n<p class=\"caution\">お問い合わせいただく際にご提供いただく個人情報の取扱いについては、<a href=\"/company/privacypolicy/\">「個人情報保護基本方針」</a><a href=\"/about/privacy/\">「個人情報の取扱いについて」</a>をご確認ください。</p>\r\n</article>\r\n<hr>\r\n<article class=\"articleBox\">\r\n<p>株式会社ぎょうせいは、採用活動におけるセクシュアルハラスメント防止に積極的に取り組み、公正・公平な採用に努めております。<br>\r\n当社では法令を遵守するとともに、皆さまが安心して選考に参加できるよう相談窓口を設けています。\r\n<br>就職活動中にセクシュアルハラスメントと思われる行為を受けた場合は、以下の窓口までご相談ください。<br>\r\n※窓口へのご連絡が当社の選考・合否結果などに影響することは一切ございません。<br>\r\n※ご連絡いただいた方のプライバシー保護に十分に配慮いたします。<br>\r\n<br>\r\n採用活動におけるセクシュアルハラスメント相談窓口<br>\r\nMAIL：<a href=\"mailto:saiyo@gyosei.co.jp\">saiyo@gyosei.co.jp</a>\r\n</p>\r\n</article>\r\n\r\n</div>\r\n<!-- END mainContents --></section>\r\n\r\n<!-- END content --></div>\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n<nav id=\"sideNavi\" class=\"sideNavi_recruit\">\r\n<div class=\"categoryLabel only-sp\">採用情報</div>\r\n<ul>\r\n<li class=\"only-pc\"><a href=\"/recruit/president/rec_message/\"><span>社長メッセージ</span></a></li>\r\n<li class=\"only-sp\"><a href=\"/recruit/president/rec_message/\"><span>社長からのメッセージ</span></a></li>\r\n<li class=\"only-sp\"><a href=\"/recruit/president/rec_history/\"><span>沿革</span></a></li>\r\n<li class=\"only-sp\"><a href=\"/recruit/president/rec_outline/\"><span>会社概要</span></a></li>\r\n<li><a href=\"/recruit/rec_business/\"><span>お客様のニーズと当社の事業</span></a></li>\r\n<li><a href=\"/recruit/interview/\"><span>社員インタビュー</span></a></li>\r\n<li><a href=\"/recruit/more/\"><span>ぎょうせいのここが知りたい！</span></a></li>\r\n<li><a href=\"/recruit/rec_contact/\" class=\"current\"><span>採用に関するお問い合わせ</span></a></li>\r\n</ul>\r\n<div class=\"backList only-sp\"><a href=\"/recruit/\">採用情報TOPへ</a></div>\r\n</nav>\r\n\r\n\r\n\r\n<div id=\"pagetop\"><a href=\"#container\"><img src=\"https://gyosei.jp/wp/wp-content/themes/gyosei_co/images/global/btn_pagetop.png\" alt=\"pagetop\"></a></div>\r\n<!-- END mainArea --></div>\r\n\r\n\r\n<footer id=\"globalfooter\">\r\n<nav class=\"footerNavi\">\r\n<ul>\r\n<li><a href=\"/about/rules/\">利用規約・免責事項</a></li>\r\n<li><a href=\"/company/privacypolicy/\">個人情報保護基本方針</a></li>\r\n<li><a href=\"/about/privacy/\">個人情報の取扱いについて</a></li>\r\n<li><a href=\"https://shop.gyosei.jp/user_data/ad\" target=\"_blank\">広告掲載のご案内</a></li>\r\n<li class=\"socialmedia\"><a href=\"/company/socialmedia/\">ソーシャルメディア公式アカウント一覧</a></li>\r\n<li><a href=\"/sitemap/\">サイトマップ</a></li>\r\n</ul>\r\n</nav>\r\n<div class=\"copyright\">Copyright © GYOSEI CORPORATION. All Rights Reserved.</div>\r\n</footer>\r\n\r\n<!-- END container --></div>\r\n\r\n</body>\r\n</html>\r\n","finalUrl":"https://gyosei.jp/recruit/rec_contact/","rendered":false,"_cachedAt":"2026-06-22T22:43:28.484Z"}