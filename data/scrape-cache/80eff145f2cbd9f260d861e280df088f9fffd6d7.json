{"url":"https://www.okb-kcs.co.jp/journal/2025/10_recruit_contents.html","html":"<!doctype html>\n<html lang=\"ja\"><!-- InstanceBegin template=\"/Templates/default02.dwt\" codeOutsideHTMLIsLocked=\"false\" --><head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<link rel=\"icon\" sizes=\"16x16 32x32 48x48\" href=\"/favicon.ico\">\n<link rel=\"apple-touch-icon\" href=\"/apple-touch-icon.png\">\n<!-- InstanceBeginEditable name=\"doctitle\" -->\n<title>∞に広がる可能性～新入社員による学生向けコンテンツ制作～ - 共立コンピューターサービス株式会社（KCS）</title>\n<meta name=\"keywords\" content=\"新人,研修,企画\">\n<meta name=\"description\" content=\"2025年度ITソリューション本部に配属された新入社員7名による、学生向けコンテンツの制作と発表の様子を紹介します。\">\n<meta property=\"og:url\" content=\"https://www.okb-kcs.co.jp/journal/2025/10_recruit_contents.html\">\n<meta property=\"og:type\" content=\"article\">\n<meta property=\"og:title\" content=\"∞に広がる可能性～新入社員による学生向けコンテンツ制作～ - 共立コンピューターサービス株式会社（KCS）\">\n<meta property=\"og:description\" content=\"2025年度ITソリューション本部に配属された新入社員7名による、学生向けコンテンツの制作と発表の様子を紹介します。\">\n<meta property=\"og:site_name\" content=\"共立コンピューターサービス株式会社（KCS）\">\n<meta property=\"og:image\" content=\"https://www.okb-kcs.co.jp/journal/2025/images/10_recruit_contents_p01.webp\">\n<!-- InstanceEndEditable -->\n<link href=\"https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css\" rel=\"stylesheet\" integrity=\"sha384-9ndCyUaIbzAi2FUVXJi0CjmCapSmO7SnpJef0486qhLnuZ2cdeRhO02iuK6FUUVM\" crossorigin=\"anonymous\">\n<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n<link href=\"https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;700&family=Quicksand:wght@500;700&display=swap\" rel=\"stylesheet\">\n<link href=\"../../css/default02.css\" rel=\"stylesheet\">\n\n<!-- Google Tag Manager -->\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n})(window,document,'script','dataLayer','GTM-5MB5TN');</script>\n<!-- End Google Tag Manager -->\n\n<!-- InstanceBeginEditable name=\"head\" -->\n<style type=\"text/css\">\nheader{\n    background: linear-gradient(to right, rgba(255,255,255,1) 0%,rgba(255,255,255,0) 90%),url('images/10_recruit_contents_p01.webp') center;\n    background-size: cover;\n}\n\n.balloon-start .faceicon {\n    float: left;\n    margin-right: -90px;\n    width: 80px;\n}\n.balloon-start .faceicon img{\n    border: solid 3px #d7ebfe;\n    border-radius: 50%;\n}\n.balloon-start .says {\n    display: inline-block;\n    position: relative; \n    margin: 5px 0 0 105px;\n    padding: 17px 13px;\n    border-radius: 12px;\n    background: #d7ebfe;\n}\n.balloon-start .says:after {\n    content: \"\";\n    display: inline-block;\n    position: absolute;\n    top: 18px; \n    left: -24px;\n    border: 12px solid transparent;\n    border-right: 12px solid #d7ebfe;\n}\n\n.balloon-end .faceicon {\n    float: right;\n    margin-left: -90px;\n    width: 80px;\n}\n.balloon-end .faceicon img{\n    border: solid 3px #f2f2f2;\n    border-radius: 50%;\n}\n.balloon-end .says {\n    display: inline-block;\n    position: relative; \n    margin: 5px 105px 0 0;\n    padding: 17px 13px;\n    border-radius: 12px;\n    background: #f2f2f2;\n    text-align:left;\n}\n.balloon-end .says:after {\n    content: \"\";\n    display: inline-block;\n    position: absolute;\n    top: 18px; \n    right: -24px;\n    border: 12px solid transparent;\n    border-left: 12px solid #f2f2f2;\n}\n</style>\n<!-- InstanceEndEditable -->\n</head>\n\n<body>\n<!-- Google Tag Manager (noscript) -->\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-5MB5TN\"\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n<!-- End Google Tag Manager (noscript) -->\n\n<!-- InstanceBeginEditable name=\"header\" -->\n<header>\n<div id=\"header\"></div>\n<div class=\"py-5 px-sm-5 lh-lg\" id=\"jumbotron\">\n<div class=\"container-fluid\">\n<h1 class=\"display-5 fw-bold bg-white d-inline\">∞に広がる可能性～新入社員による学生向けコンテンツ制作～</h1>\n<div class=\"col-md-8 bg-white pb-1\" id=\"description\">\n<div class=\"text-secondary small\">掲載日：2025年12月5日</div>\n<p class=\"fs-5 p-4\">2025年度ITソリューション本部に配属された新入社員7名による、学生向けコンテンツの制作と発表の様子を紹介します。</p>\n<nav class=\"bg-white px-4\">\n<ul class=\"list-inline\">\n<li class=\"list-inline-item mt-2\"><a class=\"btn btn-success\" href=\"#content_1\" role=\"button\">ターゲット設定</a></li>\n<li class=\"list-inline-item mt-2\"><a class=\"btn btn-success\" href=\"#content_2\" role=\"button\">先輩インタビュー</a></li>\n<li class=\"list-inline-item mt-2\"><a class=\"btn btn-success\" href=\"#content_3\" role=\"button\">カレンダー改善</a></li>\n<li class=\"list-inline-item mt-2\"><a class=\"btn btn-success\" href=\"#content_4\" role=\"button\">発表会</a></li>\n</ul>\n</nav>\n</div>\n</div><!-- /.container-fluid -->\n</div>\n</header>\n<!-- InstanceEndEditable -->\n\n<!-- InstanceBeginEditable name=\"main\" -->\n<main class=\"lh-lg\">\n<div class=\"container-fluid\">\n<div aria-label=\"breadcrumb\">\n<ol class=\"breadcrumb\">\n<li class=\"breadcrumb-item small\"><a href=\"../../index.html\">Home</a></li>\n<li class=\"breadcrumb-item small\"><a href=\"../index.html\">Webジャーナル</a></li>\n<li class=\"breadcrumb-item small active\" aria-current=\"page\">∞に広がる可能性～新入社員による学生向けコンテンツ制作～</li>\n</ol>\n</div>\n</div><!-- /.container-fluid -->\n\n<div class=\"container text-center py-5\">\n<h2 class=\"my-5\">人気サイトの分析</h2>\n<div class=\"balloon-start text-start mb-3\">\n<div class=\"faceicon\"><img src=\"images/10_recruit_contents_p04.png\" alt=\"えん\" class=\"img-fluid rounded-circle\"></div>\n<div class=\"says\">\n<p class=\"m-0\">まずは人気の採用サイトを分析してみよう</p>\n</div>\n</div><!-- /.balloon-start -->\n</div><!-- /.container -->\n<div class=\"container-fluid text-center\">\n<div class=\"row pb-5 g-4\">\n<div class=\"col-md-4 col-6\"><p><img src=\"images/10_recruit_contents_p11.webp\" alt=\"人気サイトの分析\" class=\"img-fluid rounded\"></p></div>\n<div class=\"col-md-4 col-6\"><p><img src=\"images/10_recruit_contents_p12.webp\" alt=\"人気サイトの分析\" class=\"img-fluid rounded\"></p></div>\n<div class=\"col-md-4\"><p><img src=\"images/10_recruit_contents_p13.webp\" alt=\"人気サイトの分析\" class=\"img-fluid rounded\"></p></div>\n</div><!-- /.row -->\n</div><!-- /.container-fluid -->\n<div class=\"container text-center pb-5\">\n<div class=\"balloon-end text-end mb-3\">\n<div class=\"faceicon\"><img src=\"images/10_recruit_contents_p09.png\" alt=\"ゆう\" class=\"img-fluid rounded-circle\"></div>\n<div class=\"says\">\n<p class=\"m-0\">知りたいことがテンポよく出てくるから、見やすいし楽しい！</p>\n</div>\n</div><!-- /.balloon-end -->\n<div class=\"balloon-end text-end mb-3\">\n<div class=\"faceicon\"><img src=\"images/10_recruit_contents_p06.png\" alt=\"はし\" class=\"img-fluid rounded-circle\"></div>\n<div class=\"says\">\n<p class=\"m-0\">コーポレートカラーやアクセントカラー、ボタンの色なども参考になるね</p>\n</div>\n</div><!-- /.balloon-end -->\n<div class=\"balloon-start text-start mb-5\">\n<div class=\"faceicon\"><img src=\"images/10_recruit_contents_p04.png\" alt=\"えん\" class=\"img-fluid rounded-circle\"></div>\n<div class=\"says\">\n<p class=\"m-0\">どうしたら「見たくなるコンテンツ」が作れるのかな</p>\n</div>\n</div><!-- /.balloon-start -->\n</div><!-- /.container -->\n\n<div class=\"bg-light\">\n<div class=\"container text-center py-5\" id=\"content_1\">\n<h2 class=\"my-5\">ターゲット設定</h2>\n<div class=\"balloon-start text-start mb-3\">\n<div class=\"faceicon\"><img src=\"images/10_recruit_contents_p07.png\" alt=\"こう\" class=\"img-fluid rounded-circle\"></div>\n<div class=\"says\">\n<p class=\"m-0\">きっと裏側には、何か狙いがあると思うよ</p>\n</div>\n</div><!-- /.balloon-start -->\n<div class=\"balloon-end text-end mb-3\">\n<div class=\"faceicon\"><img src=\"images/10_recruit_contents_p08.png\" alt=\"やま\" class=\"img-fluid rounded-circle\"></div>\n<div class=\"says\">\n<p class=\"m-0\">なぜこのコンテンツができたのか、企画側の目線で考えてみよう</p>\n</div>\n</div><!-- /.balloon-end -->\n</div><!-- /.container -->\n<div class=\"container-fluid text-center\">\n<div class=\"row pb-5 g-4\">\n<div class=\"col-md-3 col-6\"><p><img src=\"images/10_recruit_contents_p19.webp\" alt=\"ターゲット設定\" class=\"img-fluid rounded\"></p></div>\n<div class=\"col-md-3 col-6\"><p><img src=\"images/10_recruit_contents_p15.webp\" alt=\"ターゲット設定\" class=\"img-fluid rounded\"></p></div>\n<div class=\"col-md-3 col-6\"><p><img src=\"images/10_recruit_contents_p16.webp\" alt=\"ターゲット設定\" class=\"img-fluid rounded\"></p></div>\n<div class=\"col-md-3 col-6\"><p><img src=\"images/10_recruit_contents_p14.webp\" alt=\"人気サイトの分析\" class=\"img-fluid rounded\"></p></div>\n</div><!-- /.row -->\n</div><!-- /.container-fluid -->\n<div class=\"container text-center pb-5\">\n<div class=\"balloon-start text-start mb-3\">\n<div class=\"faceicon\"><img src=\"images/10_recruit_contents_p03.png\" alt=\"さき\" class=\"img-fluid rounded-circle\"></div>\n<div class=\"says\">\n<p class=\"m-0\">今の話と生成AIを組み合わせて、オリジナルのターゲット像を作ったよ</p>\n</div>\n</div><!-- /.balloon-start -->\n<div class=\"balloon-end text-end mb-3\">\n<div class=\"faceicon\"><img src=\"images/10_recruit_contents_p05.png\" alt=\"なつ\" class=\"img-fluid rounded-circle\"></div>\n<div class=\"says\">\n<p class=\"m-0\">ターゲットがどんな気持ちで就活したか……企画のヒントになりそう</p>\n</div>\n</div><!-- /.balloon-end -->\n<div class=\"row py-5 g-4\">\n<div class=\"col-md-6\"><p><img src=\"images/10_recruit_contents_p02.webp\" alt=\"ペルソナ\" class=\"img-fluid rounded\"></p></div>\n<div class=\"col-md-6\"><p><img src=\"images/10_recruit_contents_p10.webp\" alt=\"カスタマージャーニーマップ\" class=\"img-fluid rounded\"></p></div>\n</div><!-- /.row -->\n</div><!-- /.container -->\n</div>\n\n<div class=\"container text-center py-5\" id=\"content_2\">\n<h2 class=\"my-5\">先輩インタビュー</h2>\n<div class=\"balloon-start text-start mb-3\">\n<div class=\"faceicon\"><img src=\"images/10_recruit_contents_p06.png\" alt=\"はし\" class=\"img-fluid rounded-circle\"></div>\n<div class=\"says\">\n<p class=\"m-0\">部署について、もう少し詳しく紹介できないかな</p>\n</div>\n</div><!-- /.balloon-start -->\n<div class=\"row py-5 g-4\">\n<div class=\"col-md-6\"><p><img src=\"images/10_recruit_contents_p17.webp\" alt=\"コンテンツ企画\" class=\"img-fluid rounded\"></p></div>\n<div class=\"col-md-6\"><p><img src=\"images/10_recruit_contents_p18.webp\" alt=\"コンテンツ企画\" class=\"img-fluid rounded\"></p></div>\n</div><!-- /.row -->\n<div class=\"balloon-end text-end mb-3\">\n<div class=\"faceicon\"><img src=\"images/10_recruit_contents_p05.png\" alt=\"なつ\" class=\"img-fluid rounded-circle\"></div>\n<div class=\"says\">\n<p class=\"m-0\">先輩に、今どんなことをしているのか聞いてみよう</p>\n</div>\n</div><!-- /.balloon-end -->\n</div><!-- /.container -->\n<div class=\"container-fluid text-center\">\n<div class=\"row pb-5 g-4\">\n<div class=\"col-md-3 col-6\"><p><img src=\"images/10_recruit_contents_p21.webp\" alt=\"先輩インタビュー\" class=\"img-fluid rounded\"></p></div>\n<div class=\"col-md-3 col-6\"><p><img src=\"images/10_recruit_contents_p23.webp\" alt=\"先輩インタビュー\" class=\"img-fluid rounded\"></p></div>\n<div class=\"col-md-3 col-6\"><p><img src=\"images/10_recruit_contents_p20.webp\" alt=\"先輩インタビュー\" class=\"img-fluid rounded\"></p></div>\n<div class=\"col-md-3 col-6\"><p><img src=\"images/10_recruit_contents_p22.webp\" alt=\"先輩インタビュー\" class=\"img-fluid rounded\"></p></div>\n</div><!-- /.row -->\n</div><!-- /.container-fluid -->\n<div class=\"container text-center pb-5\">\n<div class=\"balloon-end text-end mb-5\">\n<div class=\"faceicon\"><img src=\"images/10_recruit_contents_p06.png\" alt=\"はし\" class=\"img-fluid rounded-circle\"></div>\n<div class=\"says\">\n<p class=\"m-0\">完成したコンテンツは、<a href=\"../../recruit/work/index.html#more\">プログラミング未経験でも大丈夫かな？</a>を見てね</p>\n</div>\n</div><!-- /.balloon-end -->\n</div><!-- /.container -->\n\n<div class=\"bg-light\">\n<div class=\"container text-center py-5\" id=\"content_3\">\n<h2 class=\"my-5\">一目でわかるカレンダー</h2>\n<div class=\"balloon-start text-start mb-3\">\n<div class=\"faceicon\"><img src=\"images/10_recruit_contents_p08.png\" alt=\"やま\" class=\"img-fluid rounded-circle\"></div>\n<div class=\"says\">\n<p class=\"m-0\">場所が分かると便利だと思うなぁ</p>\n</div>\n</div><!-- /.balloon-start -->\n<div class=\"row py-5 g-4\">\n<div class=\"col-md-6\"><p><img src=\"images/10_recruit_contents_p24.webp\" alt=\"一目でわかるカレンダー\" class=\"img-fluid rounded\"></p></div>\n<div class=\"col-md-6\"><p><img src=\"images/10_recruit_contents_p25.webp\" alt=\"一目でわかるカレンダー\" class=\"img-fluid rounded\"></p></div>\n</div><!-- /.row -->\n<div class=\"balloon-end text-end mb-5\">\n<div class=\"faceicon\"><img src=\"images/10_recruit_contents_p09.png\" alt=\"ゆう\" class=\"img-fluid rounded-circle\"></div>\n<div class=\"says\">\n<p class=\"m-0\"><a href=\"../../recruit/index.html#events\">イベントカレンダー</a>を改善したよ</p>\n</div>\n</div><!-- /.balloon-end -->\n</div><!-- /.container -->\n</div>\n\n<div class=\"container text-center py-5\" id=\"content_4\">\n<h2 class=\"my-5\">発表会</h2>\n<div class=\"balloon-start text-start mb-3\">\n<div class=\"faceicon\"><img src=\"images/10_recruit_contents_p05.png\" alt=\"なつ\" class=\"img-fluid rounded-circle\"></div>\n<div class=\"says\">\n<p class=\"m-0\">この取り組みについて、全員で発表しました</p>\n</div>\n</div><!-- /.balloon-start -->\n<div class=\"balloon-end text-end mb-3\">\n<div class=\"faceicon\"><img src=\"images/10_recruit_contents_p03.png\" alt=\"さき\" class=\"img-fluid rounded-circle\"></div>\n<div class=\"says\">\n<p class=\"m-0\">参加者は25名！</p>\n</div>\n</div><!-- /.balloon-end -->\n</div><!-- /.container -->\n<div class=\"container-fluid text-center\">\n<div class=\"row pb-5 g-4\">\n<div class=\"col-md-3 col-6\"><p><img src=\"images/10_recruit_contents_p26.webp\" alt=\"発表会\" class=\"img-fluid rounded\"></p></div>\n<div class=\"col-md-3 col-6\"><p><img src=\"images/10_recruit_contents_p27.webp\" alt=\"発表会\" class=\"img-fluid rounded\"></p></div>\n<div class=\"col-md-3 col-6\"><p><img src=\"images/10_recruit_contents_p28.webp\" alt=\"発表会\" class=\"img-fluid rounded\"></p></div>\n<div class=\"col-md-3 col-6\"><p><img src=\"images/10_recruit_contents_p29.webp\" alt=\"発表会\" class=\"img-fluid rounded\"></p></div>\n</div><!-- /.row -->\n</div><!-- /.container-fluid -->\n<div class=\"container text-center py-5\">\n<div class=\"balloon-start text-start mb-3\">\n<div class=\"faceicon\"><img src=\"images/10_recruit_contents_p09.png\" alt=\"ゆう\" class=\"img-fluid rounded-circle\"></div>\n<div class=\"says\">\n<p class=\"m-0\">こんな質問や感想も出ました</p>\n</div>\n</div><!-- /.balloon-start -->\n<div class=\"row row-cols-1 row-cols-md-3 text-start photos my-5\">\n<div class=\"col\">\n<div class=\"card\">\n<div class=\"card-body bg-white rounded shadow-sm\">\n<p class=\"card-text\">データ（数値）に基づいた提案が非常分かりやすかったです。</p>\n</div>\n</div>\n</div>\n<div class=\"col\">\n<div class=\"card\">\n<div class=\"card-body bg-white rounded shadow-sm\">\n<p class=\"card-text\">話し方、伝え方共によかったです。表情がもう少し柔らかいと、笑顔だともっと良かったです。</p>\n</div>\n</div>\n</div>\n<div class=\"col\">\n<div class=\"card\">\n<div class=\"card-body bg-white rounded shadow-sm\">\n<p class=\"card-text\">SNSを利用して間口が広がるのは良いと思いますが、求める人材を集めるための方法としては何がありますか？</p>\n</div>\n</div>\n</div>\n<div class=\"col\">\n<div class=\"card\">\n<div class=\"card-body bg-white rounded shadow-sm\">\n<p class=\"card-text\">発表全体、聞きやすく内容もまとまっておりとてもよかったです。</p>\n</div>\n</div>\n</div>\n<div class=\"col\">\n<div class=\"card\">\n<div class=\"card-body bg-white rounded shadow-sm\">\n<p class=\"card-text\">HPの改善やSNSを使うことは分かったのですが、ツールを選んだ理由や改善の背景をもっと知りたかったです。</p>\n</div>\n</div>\n</div>\n</div><!-- /.row -->\n<div class=\"balloon-end text-end mb-5\">\n<div class=\"faceicon\"><img src=\"images/10_recruit_contents_p07.png\" alt=\"こう\" class=\"img-fluid rounded-circle\"></div>\n<div class=\"says\">\n<p class=\"m-0\">次に繋げていきます</p>\n</div>\n</div><!-- /.balloon-end -->\n</div><!-- /.container -->\n\n<div class=\"bg-light\">\n<div class=\"container-fluid text-center py-5\">\n<h2 class=\"my-5\">メンバー紹介</h2>\n<p>私たちの取り組みをご覧いただき、ありがとうございました。<br>\n次はインターンシップや会社説明会でお会いしましょう！</p>\n<div class=\"row py-5 g-4\">\n<div class=\"col-md-4 col-6\"><p><img src=\"images/10_recruit_contents_p30.webp\" alt=\"打ち合わせ\" class=\"img-fluid rounded\"></p></div>\n<div class=\"col-md-4 col-6\"><p><img src=\"images/10_recruit_contents_p31.webp\" alt=\"インタビュー\" class=\"img-fluid rounded\"></p></div>\n<div class=\"col-md-4\"><p><img src=\"images/10_recruit_contents_p01.webp\" alt=\"打ち合わせ\" class=\"img-fluid rounded\"></p></div>\n</div><!-- /.row -->\n</div><!-- /.container-fluid -->\n<div class=\"container text-center pb-5\">\n<div class=\"row row-cols-2 row-cols-sm-3 row-cols-md-4 justify-content-center g-4\">\n<div class=\"col\"><p>\\ 待ってます～ /<br><img src=\"images/10_recruit_contents_p03.png\" alt=\"さき\" class=\"img-fluid rounded-circle\"><br>さき<span class=\"badge rounded-pill text-bg-warning ms-1\">文系</span><br><small>ENFJ（主人公）</small></p></div>\n<div class=\"col\"><p>\\ 営業楽しい！ /<br><img src=\"images/10_recruit_contents_p05.png\" alt=\"なつ\" class=\"img-fluid rounded-circle\"><br>なつ<span class=\"badge rounded-pill text-bg-warning ms-1\">文系</span><br><small>ISFP（冒険家）</small></p></div>\n<div class=\"col\"><p>\\ 一緒に働こう！ /<br><img src=\"images/10_recruit_contents_p04.png\" alt=\"えん\" class=\"img-fluid rounded-circle\"><br>えん<span class=\"badge rounded-pill text-bg-success ms-1\">理系</span><br><small>ENFP（運動家）</small></p></div>\n<div class=\"col\"><p>\\ 一緒に成長しよ～ /<br><img src=\"images/10_recruit_contents_p06.png\" alt=\"はし\" class=\"img-fluid rounded-circle\"><br>はし<span class=\"badge rounded-pill text-bg-success ms-1\">理系</span><br><small>ESFJ（領事）</small></p></div>\n<div class=\"col\"><p>\\ 仲間になろう！ /<br><img src=\"images/10_recruit_contents_p08.png\" alt=\"やま\" class=\"img-fluid rounded-circle\"><br>やま<span class=\"badge rounded-pill text-bg-success ms-1\">理系</span><br><small>ISFJ（擁護者）</small></p></div>\n<div class=\"col\"><p>\\ 開発楽しいぞ！ /<br><img src=\"images/10_recruit_contents_p07.png\" alt=\"こう\" class=\"img-fluid rounded-circle\"><br>こう<span class=\"badge rounded-pill text-bg-success ms-1\">理系</span><br><small>INTP（論理学者）</small></p></div>\n<div class=\"col\"><p>\\ 一緒に挑戦しよう /<br><img src=\"images/10_recruit_contents_p09.png\" alt=\"ゆう\" class=\"img-fluid rounded-circle\"><br>ゆう<span class=\"badge rounded-pill text-bg-success ms-1\">理系</span><br><small>ENFJ（主人公）</small></p></div>\n</div><!-- /.row -->\n<p class=\"text-end pt-5\">記事担当：2025年度 ITソリューション本部 新入社員</p>\n</div><!-- /.container -->\n</div>\n\n<div class=\"text-center py-5\" id=\"contact\">\n<div class=\"container bg-white rounded\">\n<h2 class=\"my-5\">インターンシップのお申し込み</h2>\n<p>インターンシップの申し込みは、マイナビからできます。<br>\n詳細は、マイナビをご覧ください。</p>\n<p class=\"pb-5\"><a href=\"../../recruit/entry/internship.html\" class=\"btn btn-success btn-lg\" target=\"_blank\">マイナビへのリンクはこちら<i class=\"bi bi-chevron-double-right ms-2\" aria-hidden=\"true\"></i></a></p>\n</div><!-- /.container -->\n</div><!-- /#contact -->\n\n<div class=\"container-fluid text-center py-5\">\n<h2 class=\"my-5\">関連ページ</h2>\n\n<div class=\"row row-cols-1 row-cols-sm-2 row-cols-lg-4 text-start kcs_topics photos py-5 g-4\">\n\n<div class=\"col\">\n<a href=\"09_internship_2days.html\">\n<div class=\"card h-100 shadow\">\n<img src=\"images/09_internship_2days_p28.webp\" class=\"card-img-top\" alt=\"2025年夏、2daysインターンシップ開催\n（対面・オンライン・プラスワン）\">\n<div class=\"card-body\">\n<h3 class=\"card-title h5\">2025年夏、2daysインターンシップ開催<small>（対面・オンライン・プラスワン）</small></h3>\n<p class=\"card-text link-primary\">今年は新コース「バンキングシステム開発体験」が登場！</p>\n<small class=\"text-secondary\">2025年8月～9月</small>\n</div>\n</div>\n</a>\n</div>\n\n<div class=\"col\">\n<a href=\"09_internship_1day.html\">\n<div class=\"card h-100 shadow\">\n<img src=\"images/09_internship_1day_p06.webp\" class=\"card-img-top\" alt=\"2025年夏、1day仕事体験（IT業界の仕事を知ろう）開催（オンライン・対面）\">\n<div class=\"card-body\">\n<h3 class=\"card-title h5\">2025年夏、1day仕事体験（IT業界の仕事を知ろう）開催<small>（オンライン・対面）</small></h3>\n<p class=\"card-text link-primary\">今年も8月と9月に、大学生を対象とした夏季インターンシップを開催しました。</p>\n<small class=\"text-secondary\">2025年8月～9月</small>\n</div>\n</div>\n</a>\n</div>\n\n<div class=\"col\">\n<a href=\"../2024/10_recruit_contents.html\">\n<div class=\"card h-100 shadow\">\n<img src=\"../2024/images/10_recruit_contents_p01.webp\" class=\"card-img-top\" alt=\"まさかの、エンジニアやお！～新入社員による学生向けコンテンツ制作～\">\n<div class=\"card-body\">\n<h3 class=\"card-title h5\">まさかの、エンジニアやお！<small>～新入社員による学生向けコンテンツ制作～</small></h3>\n<p class=\"card-text link-primary\">ITソリューション本部に配属された9名による、制作活動の様子。</p>\n<small class=\"text-secondary\">2024年11月6日</small>\n</div>\n</div>\n</a>\n</div>\n\n<div class=\"col\">\n<a href=\"../../recruit/index.html\">\n<div class=\"card h-100 shadow\">\n<img src=\"../../company/images/index_p03.jpg\" class=\"card-img-top\" alt=\"採用情報\">\n<div class=\"card-body\">\n<h3 class=\"card-title h5\">採用情報</h3>\n<p class=\"card-text link-primary\">求める人材像や実際にKCSで働く先輩の生の声など、就活に役立つ情報が満載。</p>\n</div>\n</div>\n</a>\n</div>\n\n</div><!-- /.row -->\n</div><!-- /.container-fluid -->\n\n</main>\n<!-- InstanceEndEditable -->\n\n<p id=\"pagetop\"><a href=\"#header\"><i class=\"bi bi-arrow-bar-up fs-4\"></i></a></p>\n<div id=\"footer\"></div>\n<script src=\"https://code.jquery.com/jquery-3.7.1.min.js\" integrity=\"sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo=\" crossorigin=\"anonymous\"></script>\n<script src=\"../../js/default02.js\"></script> \n<script src=\"https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js\" integrity=\"sha384-geWF76RCwLtnZ8qwWowPQNguL3RmwHVBC9FhGdlKrxdiJJigb/j/68SIy3Te4Bkz\" crossorigin=\"anonymous\"></script>\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css\">\n<script src=\"https://cdnjs.cloudflare.com/ajax/libs/protonet-jquery.inview/1.1.2/jquery.inview.min.js\" integrity=\"sha512-D68mBFX2aQwVh2wV6uCDLmabIveaSQL3uVUo2Ze7VwxIeOcAd4C1/JagkVoObb/NLkYDrdvY3JHK1KOfenHVcA==\" crossorigin=\"anonymous\" referrerpolicy=\"no-referrer\"></script>\n<!-- InstanceBeginEditable name=\"added_js\" -->\n\n<!-- InstanceEndEditable -->\n</body>\n<!-- InstanceEnd --></html>","finalUrl":"https://www.okb-kcs.co.jp/journal/2025/10_recruit_contents.html","rendered":false,"_cachedAt":"2026-06-23T23:11:16.619Z"}