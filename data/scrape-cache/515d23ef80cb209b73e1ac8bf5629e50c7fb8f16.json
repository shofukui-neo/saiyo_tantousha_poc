 type=\"text/css\" href=\"/5g-info/assets/styles/reset.css\" media=\"all\">\r\n  <link rel=\"stylesheet\" type=\"text/css\" href=\"/5g-info/assets/styles/index.css\" media=\"all\">\r\n  <link rel=\"stylesheet\" type=\"text/css\" href=\"/5g-info/assets/styles/style_new.css\" media=\"all\">\r\n  <link rel=\"stylesheet\" type=\"text/css\" href=\"/5g-info/assets/styles/251224_style.css\" media=\"all\">\r\n  <link rel=\"stylesheet\" type=\"text/css\" href=\"/5g-info/assets/styles/partnership/style.css\" media=\"all\">\r\n\r\n<!-- Swiper JS -->\r\n  <script src=\"https://unpkg.com/swiper/swiper-bundle.min.js\"></script>\r\n\t<script src=\"/5g-info/assets/scripts/jquery-3.6.1.min.js\"></script>\r\n\r\n</head>\r\n<body id=\"top\">\r\n\r\n\r\n\r\n<!-- Google Tag Manager (noscript) -->\r\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-MD5J4F\" height=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\r\n<!-- End Google Tag Manager (noscript) -->\r\n<div class=\"page\">\r\n\t<header>\r\n\t\t<div class=\"header-inner\">\r\n\t\t\t<div class=\"logo\"><a href=\"/5g-info/\">\r\n\t\t\t\t<picture>\r\n\t\t\t\t\t<source srcset=\"/5g-info/assets/images/logo_sp.png\" media=\"(max-width: 767px)\">\r\n\t\t\t\t\t<img src=\"/5g-info/assets/images/logo.png\" alt=\"FUJISOFT\">\r\n\t\t\t\t</picture>\r\n\t\t\t</a></div>\r\n\t\t<a href=\"javascript:void(0);\" class=\"sp_show nav_tgl_btn\">\r\n\t\t\t<span class=\"nav_tgl_icn nav_tgl_icn--01\"></span>\r\n\t\t\t<span class=\"nav_tgl_icn nav_tgl_icn--02\"></span>\r\n\t\t</a>\r\n\t\t<nav class=\"header-nav\">\r\n\t\t\t<ul>\r\n\t\t\t\t\t<li class=\"sp_show\"><a href=\"/5g-info/\" class=\"nav_link\">TOP</a></li>\r\n\t\t\t\t\t<li><a href=\"/5g-info/incorporate/\" class=\"nav_link\">導入検討中の企業様</a></li>\r\n\t\t\t\t\t<li><a href=\"/5g-info/partnership/\" class=\"nav_link\">協業検討中の企業様</a></li>\r\n\t\t\t\t\t<li><a href=\"/5g-info/products/\" class=\"nav_link\">製品・ソリューション</a></li>\r\n\t\t\t\t\t<li><a href=\"https://sem-inq.fsi.co.jp/public/application/add/6744\" class=\"contact-btn contact-btn--01\" target=\"_blank\">無料でお問い合わせ</a></li>\r\n\t\t\t\t\t<li class=\"sp_show\"><a href=\"https://sem-inq.fsi.co.jp/public/application/add/6745\" class=\"contact-btn contact-btn--02\" target=\"_blank\">資料請求</a></li>\r\n\t\t\t</ul>\r\n\t\t</nav>\r\n\t\t</div>\r\n\t</header>\r\n\t<main>\r\n    <div id=\"main_visual\">\r\n      <div class=\"main-wrapper\">\r\n        <div class=\"main-nav\">\r\n          <p>協業検討中の企業様</p>\r\n        </div>\r\n        <div class=\"ly-container\">\r\n          <div class=\"main-logo\"><img src=\"/5g-info/assets/images/partnership/logo.png\" alt=\"\"></div>\r\n          <p class=\"main-head\">国内初</p>\r\n          <h1 class=\"main-ttl\">O-RAN準拠の5Gで、<br>新たなビジネスの<br class=\"spD\">最前線へ。</h1>\r\n          <p class=\"main-txt\">富士ソフトと拓く、<br class=\"spD\">競合優位性の高いローカル5Gパートナーシップ。</p>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\t\t<section class=\"contact contact_01\">\r\n\t\t\t<div class=\"ly-container\">\r\n\t\t\t\t<div class=\"contact-box\">\r\n\t\t\t\t\t<p class=\"contact-txt\">\r\n\t\t\t\t\t\tローカル5Gの導入・協業について<br>お気軽にご相談ください。\r\n\t\t\t\t\t</p>\r\n\t\t\t\t\t<div class=\"btn_area\">\r\n\t\t\t\t\t\t<p class=\"btn_txt\">\r\n\t\t\t\t\t\t\t＼個別相談・ラボ見学・実証実験の実施まで／\r\n\t\t\t\t\t\t</p>\r\n\t\t\t\t\t\t<div class=\"contact-btn_wrap\">\r\n\t\t\t\t\t\t\t<a href=\"https://sem-inq.fsi.co.jp/public/application/add/6744\" class=\"contact-btn contact-btn--01 contact-btn--01--talk\" target=\"_blank\">個別相談を申し込む</a>\r\n\t\t\t\t\t\t\t<a href=\"https://sem-inq.fsi.co.jp/public/application/add/6745\" class=\"contact-btn contact-btn--02\" target=\"_blank\">ローカル5G資料</a>\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t</div>\r\n\t\t\t\t</div>\r\n\t\t\t</div>\r\n\t\t</section>\r\n    <section id=\"intro\" class=\"type_bg_bl\">\r\n      <div class=\"ly-container\">\r\n        <h2 class=\"heading_line_lb\">ローカル5Gの市場規模は<br class=\"spD\">急拡大中。<br>\r\n          次のDXビジネスチャンスへ、<br class=\"spD\">今こそ参入すべきです。</h2>\r\n        <p class=\"intro_txt\">ローカル5G市場の成長率予測グラフ</p>\r\n        <div class=\"intro_img\">\r\n          <img src=\"/5g-info/assets/images/partnership/intro_figure.png\" alt=\"\">\r\n          <p class=\"intro_img_cap\">引用元：ローカル5G製品・サービスにおける市場規模の推移<br class=\"spD\">（2022～2028年度）<br class=\"spD\">（出典：デロイト トーマツ ミック経済研究所）</p>\r\n        </div>\r\n        <div>\r\n        </div>\r\n      </div>\r\n    </section>\r\n    <section id=\"solution\" class=\"type_bg_bk\">\r\n      <div class=\"ly-container\">\r\n        <h2 class=\"heading_line_wh\">競合優位性のある、PEGATRONソリューションの強み</h2>\r\n        <p class=\"solution_txt\">富士ソフトはPEGATRON Corporationと国内初の販売代理店契約を締結しています。<br>\r\n          最先端かつ高い技術力で幅広いニーズに対応できるソリューションをご提供できます。<br>\r\n          O-RANに準拠しているため、柔軟性があり将来的な拡張も見据えたシステム構築ができます。\r\n        </p>\r\n        <div class=\"solution_img\"><img src=\"/5g-info/assets/images/incorporate/supply_logo.png\" alt=\"\"></div>\r\n        <div class=\"box\">\r\n          <div class=\"box_thumb\">\r\n            <img src=\"/5g-info/assets/images/products/solution_thumb.png\" alt=\"\" class=\"pcD\">\r\n            <img src=\"/5g-info/assets/images/products/solution_thumb_sp.png\" alt=\"\" class=\"spD\">\r\n            <h3 class=\"box_ttl\">Prime Link 5G</h3>\r\n            <p class=\"box_txt\">国内初のPEGATRON Corporationの代理店である富士ソフトが提供する、<br class=\"pcD\">\r\n              パッケージ化された基地局ソリューションです。</p>\r\n          </div>\r\n          <div class=\"image-list swiper js-image-swiper\">\r\n            <div class=\"swiper-wrapper\">\r\n              <div class=\"swiper-slide\">\r\n                <div class=\"slider-img\">\r\n                  <img src=\"/5g-info/assets/images/partnership/solution_img01.png\" alt=\"MG54AX\">\r\n                </div>\r\n                <div class=\"slider-txt\">\r\n                  <p>5G対応のCPEルーターです。<br>\r\n                    ローカル5G導入に必須の機器となり、FWA（固定無線アクセス）として、中小企業やSOHO、建設現場など、幅広い顧客層に対して高速インターネット接続ソリューションとして提案ができます。</p>\r\n                </div>\r\n              </div>\r\n              <div class=\"swiper-slide\">\r\n                <div class=\"slider-img\">\r\n                  <img src=\"/5g-info/assets/images/partnership/solution_img02.png\" alt=\"Nura4K\">\r\n                </div>\r\n                <div class=\"slider-txt\">\r\n                  <p>5G対応の高解像度カメラです。<br>\r\n                    5G内蔵のため、高付加価値なワイヤレス監視や遠隔作業支援のソリューションが実現できます。<br>\r\n                    建設、インフラ点検、医療、エンターテイメント（ライブ配信）など、高精細・低遅延の映像伝送が求められる現場でも適用できます。</p>\r\n                </div>\r\n              </div>\r\n              <div class=\"swiper-slide\">\r\n                <div class=\"slider-img\">\r\n                  <img src=\"/5g-info/assets/images/partnership/solution_img03.png\" alt=\"MD100\">\r\n                </div>\r\n                <div class=\"slider-txt\">\r\n                  <p>5G対応のUSBドングルです。<br>\r\n                    産業機器、POS端末、デジタルサイネージなど、あらゆる機器の5G通信モジュールとしてご提案できます。<br>\r\n                    低コスト・低消費電力の5G RedCap規格へ対応を見据えており、顧客のIoT化ニーズに柔軟に対応できる高い汎用性もあります。</p>\r\n                </div>\r\n              </div>\r\n            </div>\r\n            <div class=\"swiper-controls\">\r\n              <div class=\"swiper-button-prev custom-arrow\"></div>\r\n              <div class=\"swiper-pagination\"></div>\r\n              <div class=\"swiper-button-next custom-arrow\"></div>\r\n            </div>\r\n          </div>\r\n          <div>\r\n            <div class=\"btn_txt\">\r\n              <p>この他にも富士ソフトがご提供する製品・ソリューションをぜひご覧になってください。</p>\r\n            </div>\r\n            <a href=\"/5g-info/products/index.html\" class=\"button_gr\">他の製品を見る</a>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </section>\r\n    <section id=\"service\" class=\"type_bg_bl\">\r\n      <div class=\"ly-container\">\r\n        <h2 class=\"heading_line_lb\">富士ソフトは<br class=\"spD\">安心と独自性のある<br class=\"spD\">サービスを提供します</h2>\r\n        <p class=\"service_txt\">富士ソフトとパートナーシップを組むことで、<br class=\"pcD\">\r\n          ローカル5Gにおける技術的な課題やビジネス効果の期待へお応えいたします。</p>\r\n        <ul class=\"circles\">\r\n          <li class=\"circle\">\r\n            <div class=\"circle__content\">\r\n              <p class=\"circle__title\">競合優位性</p>\r\n              <span class=\"circle__line\"></span>\r\n              <p class=\"circle__text\">\r\n                国内初のPEGATRON Corporationの代理店である富士ソフトであれば、競合にも負けない優位性のあるソリューションをご提供できます。\r\n              </p>\r\n            </div>\r\n          </li>\r\n          <li class=\"circle\">\r\n            <div class=\"circle__content\">\r\n              <p class=\"circle__title\">技術サポート</p>\r\n              <span class=\"circle__line\"></span>\r\n              <p class=\"circle__text\">\r\n                富士ソフトの技術者によるプリセールス支援、導入・構築サポート、ローカル5Gラボを活用した検証環境の提供まで、幅広いニーズにお応えいたします。\r\n              </p>\r\n            </div>\r\n          </li>\r\n        </ul>\r\n      </div>\r\n    </section>\r\n  <section class=\"contact contact_02\">\r\n    <div class=\"ly-container\">\r\n      <p class=\"contact-head\">ローカル5Gの未来を、<br class=\"spD\">富士ソフトと共に<br class=\"spD\">創造しませんか</p>\r\n      <div class=\"contact-box\">\r\n        <p class=\"contact-txt\">\r\n          <span>＼個別相談・ラボ見学・実証実験の実施まで／</span>\r\n          ローカル5Gの導入・協業について<br class=\"spD\">お気軽にご相談ください。\r\n        </p>\r\n        <div class=\"contact-btn_wrap\">\r\n          <a href=\"https://sem-inq.fsi.co.jp/public/application/add/6744\" class=\"contact-btn contact-btn--01 contact-btn--01--talk\" target=\"_blank\">個別相談を申し込む</a>\r\n          <a href=\"https://sem-inq.fsi.co.jp/public/application/add/6745\" class=\"contact-btn contact-btn--02\" target=\"_blank\">ローカル5G資料</a>\r\n        </div>\r\n        <p class=\"contact-tel\">こちらからのお問い合わせも<br class=\"spD\">受け付けております。</p>\r\n        <div class=\"contact-number\">\r\n          <p>ソリューションビジネスユニット<br>ソリューション事業本部　次世代通信ビジネス部</p>\r\n          <a href=\"mailto:fujisoft_5g@fsi.co.jp\">fujisoft_5g@fsi.co.jp</a>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </section>\r\n\t</main>\r\n\t<div class=\"page_t