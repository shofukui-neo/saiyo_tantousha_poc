{"url":"https://www.kawakita.co.jp/recruit/info/education/","html":"<!doctype html>\n<html lang=\"ja\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<meta http-equiv=\"X-UA-Compatible\" content=\"ie=edge\">\n  \n<!-- Google Tag Manager -->\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n})(window,document,'script','dataLayer','GTM-KCHSLKW');</script>\n<!-- End Google Tag Manager -->\n  \n<title>教育制度｜採用情報｜川北電気工業株式会社</title>\n<meta name=\"description\" content=\"川北電気工業の教育制度を紹介しています。\">\n<meta name=\"keywords\" content=\"川北電気工業,電気,電力,電設,工事,kawakita,光通信,ネットワーク,送電\">\n\n<meta property=\"og:locale\" content=\"ja_JP\">\n<meta property=\"og:type\" content=\"website\">\n<meta property=\"og:title\" content=\"教育制度｜採用情報｜川北電気工業株式会社\">\n<meta property=\"og:description\" content=\"川北電気工業の教育制度を紹介しています。\">\n<meta property=\"og:url\" content=\"https://www.kawakita.co.jp/recruit/info/education/\">\n<meta property=\"og:site_name\" content=\"川北電気工業株式会社\">\n<meta property=\"og:image\" content=\"https://www.kawakita.co.jp/images/og_recruit.png\">\n<link rel=\"canonical\" href=\"https://www.kawakita.co.jp/recruit/info/education/\">\n<link rel=\"icon\" href=\"https://www.kawakita.co.jp/favicon.ico\" type=\"image/vnd.microsoft.icon\">\n<link rel=\"shortcut icon\" href=\"https://www.kawakita.co.jp/favicon.ico\" type=\"image/vnd.microsoft.icon\">\n<link rel=\"apple-touch-icon\" sizes=\"57x57\" href=\"https://www.kawakita.co.jp/apple-touch-icon.png\">\n<link rel=\"stylesheet\" type=\"text/css\" href=\"https://www.kawakita.co.jp/css/base.css\">\n<link rel=\"stylesheet\" type=\"text/css\" href=\"https://www.kawakita.co.jp/css/common.css\">\n<link rel=\"stylesheet\" type=\"text/css\" href