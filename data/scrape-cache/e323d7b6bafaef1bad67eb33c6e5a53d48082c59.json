w.harimakb.co.jp/recruit/assets/img/about/numbers/mv_bg_sp_3x.webp?2\" type=\"image/webp\" media=\"(min-width: 481px) and (max-width: 991px)\">\n<source srcset=\"https://www.harimakb.co.jp/recruit/assets/img/about/numbers/mv_bg_sp_3x.jpg?2\" type=\"image/jpeg\" media=\"(min-width: 481px) and (max-width: 991px)\">\n<source srcset=\"https://www.harimakb.co.jp/recruit/assets/img/about/numbers/mv_bg_sp_2x.webp?2\" type=\"image/webp\" media=\"(min-width: 321px) and (max-width: 480px)\">\n<source srcset=\"https://www.harimakb.co.jp/recruit/assets/img/about/numbers/mv_bg_sp_2x.jpg?2\" type=\"image/jpeg\" media=\"(min-width: 321px) and (max-width: 480px)\">\n<source srcset=\"https://www.harimakb.co.jp/recruit/assets/img/about/numbers/mv_bg_sp.webp?2\" type=\"image/webp\" media=\"(max-width: 320px)\">\n<source srcset=\"https://www.harimakb.co.jp/recruit/assets/img/about/numbers/mv_bg_sp.jpg?2\" type=\"image/jpeg\" media=\"(max-width: 320px)\">\n<img src=\"https://www.harimakb.co.jp/recruit/assets/img/about/numbers/mv_bg.jpg?2\" alt=\"メインタイトルイメージ\" width=\"1500\" height=\"400\">\n</picture>\n<h2 class=\"page-tit\"><span class=\"page-tit__main\">数字で見るハリマ</span><span class=\"page-tit__sub\">SEE IN NUMBERS</span></h2>\n\n<!-- #breadcrumbs -->\n<div class=\"breadcrumbs\">\n<div class=\"container\">\n<span>\n<a href=\"https://www.harimakb.co.jp/recruit/\">HOME</a><span class=\"delimiter\">/</span><a href=\"../\">ハリマを知る</a><span class=\"delimiter\">/</span><span class=\"breadcrumbs_last\" aria-current=\"page\">数字で見るハリマ</span>\n</span>\n</div>\n</div>\n<!-- /#breadcrumbs -->\n<a href=\"#contents\" id=\"scroll\" class=\"hidden-phone\" title=\"SCROLL\"><span class=\"txt en\">SCROLL</span><i class=\"icon-sharp-arrow-bottom\"></i></a>\n</div>\n\n<!-- /#page-mv & breadcrumbs -->\n\n\n\n<!-- #contents -->\n<div id=\"contents\">\n\n<div class=\"container\">\n<div class=\"inner\">\n\n\n<ul class=\"list col3\">\n\n<li class=\"case-box\">\n<dl class=\"case-box__cover\">\n<dt class=\"case-box__tit\"><span>創業</span></dt>\n<dd class=\"case-box__detail\">\n<picture>\n<source srcset=\"https://www.harimakb.co.jp/recruit/assets/img/about/numbers/icon_sogyo.webp\" type=\"image/webp\">\n<img class=\"case-box__icon\" src=\"https://www.harimakb.co.jp/recruit/assets/img/about/numbers/icon_sogyo.png\" alt=\"アイコン：創業\" width=\"\" height=\"\">\n</picture>\n<p><strong class=\"en\">119</strong><span>年</span></p>\n</dd>\n</dl>\n</li>\n\n<li class=\"case-box\">\n<dl class=\"case-box__cover\">\n<dt class=\"case-box__tit\"><span>自己資本比率</span></dt>\n<dd class=\"case-box__detail\">\n<picture>\n<source srcset=\"https://www.harimakb.co.jp/recruit/assets/img/about/numbers/icon_jikoshihonritsu.webp\" type=\"image/webp\">\n<img class=\"case-box__icon\" src=\"https://www.harimakb.co.jp/recruit/assets/img/about/numbers/icon_jikoshihonritsu.png\" alt=\"アイコン：自己資本比率\" width=\"\" height=\"\">\n</picture>\n<p><strong class=\"en\">69.4</strong><span>%</span><br><small>（2026年3月期）</small></p>\n</dd>\n</dl>\n</li>\n\n<li class=\"case-box\">\n<dl class=\"case-box__cover\">\n<dt class=\"case-box__tit\"><span>社員の平均年齢</span></dt>\n<dd class=\"case-box__detail\">\n<picture>\n<source srcset=\"https://www.harimakb.co.jp/recruit/assets/img/about/numbers/icon_heikin_nenrei.webp\" type=\"image/webp\">\n<img class=\"case-box__icon\" src=\"https://www.harimakb.co.jp/recruit/assets/img/about/numbers/icon_heikin_nenrei.png\" alt=\"アイコン：社員の平均年齢\" width=\"\" height=\"\">\n</picture>\n<p><strong class=\"en\">40.6</strong><span>歳</span><br><small>（2026年3月期）</small></p>\n</dd>\n</dl>\n</li>\n\n<li class=\"case-box\">\n<dl class=\"case-box__cover\">\n<dt class=\"case-box__tit\"><span>グループ従業員数</span><br><small>※有期雇用者含む</small></dt>\n<dd class=\"case-box__detail\">\n<picture>\n<source srcset=\"https://www.harimakb.co.jp/recruit/assets/img/about/numbers/icon_jyugyoinsu.webp\" type=\"image/webp\">\n<img class=\"case-box__icon\" src=\"https://www.harimakb.co.jp/recruit/assets/img/about/numbers/icon_jyugyoinsu.png\" alt=\"アイコン：従業員数\" width=\"\" height=\"\">\n</picture>\n<p><strong class=\"en\">1,162</strong><span>人</span><br><small>（2026年3月末現在）</small></p>\n</dd>\n</dl>\n</li>\n\n<li class=\"case-box\">\n<dl class=\"case-box__cover\">\n<dt class=\"case-box__tit\"><span>年間休日数</span><br><small>※有給休暇など含む</small></dt>\n<dd class=\"case-box__detail\">\n<picture>\n<source srcset=\"https://www.harimakb.co.jp/recruit/assets/img/about/numbers/icon_nenkan_kyujitsu.webp\" type=\"image/webp\">\n<img class=\"case-box__icon\" src=\"https://www.harimakb.co.jp/recruit/assets/img/about/numbers/icon_nenkan_kyujitsu.png\" alt=\"アイコン：年間休日数\" width=\"\" height=\"\">\n</picture>\n<p><strong class=\"en\">131</strong><span>日</span><br><small>（2025年実績）</small></p>\n</dd>\n</dl>\n</li>\n\n<li class=\"case-box\">\n<dl class=\"case-box__cover\">\n<dt class=\"case-box__tit\"><span>月平均所定外<br>労働時間</span></dt>\n<dd class=\"case-box__detail\">\n<picture>\n<source srcset=\"https://www.harimakb.co.jp/recruit/assets/img/about/numbers/icon_heikin_roudojikan.webp\" type=\"image/webp\">\n<img class=\"case-box__icon\" src=\"https://www.harimakb.co.jp/recruit/assets/img/about/numbers/icon_heikin_roudojikan.png\" alt=\"アイコン：月平均所定外労働時間\" width=\"\" height=\"\">\n</picture>\n<p><strong class=\"en\">8.4</strong><span>時間</span><br><small>（2025年実績）</small></p>\n</dd>\n</dl>\n</li>\n\n<li class=\"case-box\">\n<dl class=\"case-box__cover\">\n<dt class=\"case-box__tit\"><span>新人定着率</span></dt>\n<dd class=\"case-box__detail\">\n<picture>\n<source srcset=\"https://www.harimakb.co.jp/recruit/assets/img/about/numbers/icon_shinjin_techakuritsu.webp\" type=\"image/webp\">\n<img class=\"case-box__icon\" src=\"https://www.harimakb.co.jp/recruit/assets/img/about/numbers/icon_shinjin_techakuritsu.png\" alt=\"アイコン：新人定着率（3年）\" width=\"\" height=\"\">\n</picture>\n<p><strong class=\"en\">72.4</strong><span>%</span><small>（直近3年平均）</small></span><br></p>\n</dd>\n</dl>\n</li>\n\n<li class=\"case-box\">\n<dl class=\"case-box__cover\">\n<dt clas