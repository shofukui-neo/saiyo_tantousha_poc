{"url":"https://www.doggyman.com/recruit/people/symposium","html":"<!doctype html>\r\n<html lang=\"ja\">\r\n\r\n<head>\r\n  <!-- Google Tag Manager -->\r\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\r\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\r\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\r\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\r\n})(window,document,'script','dataLayer','GTM-KPBT95R');</script>\r\n<!-- End Google Tag Manager -->\r\n<meta charset=\"UTF-8\">\r\n<meta name=\"viewport\" content=\"initial-scale=1.0\">\r\n<meta http-equiv=\"x-ua-compatible\" content=\"IE=edge\">\r\n<meta name=\"format-detection\" content=\"telephone=no\">\r\n<link rel=\"shortcut icon\" href=\"../../favicon.ico\">\r\n<link rel=\"stylesheet\" href=\"../../assets/css/style.css\" media=\"all\">\r\n<script src=\"https://code.jquery.com/jquery-3.7.1.min.js\" integrity=\"sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo=\" crossorigin=\"anonymous\"></script>\r\n<script src=\"../../assets/js/common.js\"></script>\r\n<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\r\n<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\r\n<link href=\"https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800;900&family=Noto+Sans+JP:wght@400;500;700&display=swap\" rel=\"stylesheet\">\r\n<script src=\"https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.3/gsap.min.js\" integrity=\"sha512-7Au1ULjlT8PP1Ygs6mDZh9NuQD0A5prSrAUiPHMXpU6g3UMd8qesVnhug5X4RoDr35x5upNpx0A6Sisz1LSTXA==\" crossorigin=\"anonymous\" referrerpolicy=\"no-referrer\"></script>\r\n<script src=\"https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.3/ScrollTrigger.min.js\" integrity=\"sha512-LQQDtPAueBcmGXKdOBcMkrhrtqM7xR2bVrnMtYZ8ImAZhFlIb5xrMqQ6uZviyeSB+4mYj89ta8niiCIQM1Gj0w==\" crossorigin=\"anonymous\" referrerpolicy=\"no-referrer\"></script>\r\n<meta name=\"keywords\" content=\"ドギーマン,DoggyMan,犬,猫,ペット,ペットフード,動物,ペットライフ,採用,新卒採用\">  <title>トークセッション／入社3～4年目｜新卒採用｜ドギーマンハヤシ株式会社</title>\r\n  <meta name=\"description\" content=\"総合ペットメーカーのドギーマンハヤシの新卒採用ホームページです。社長メッセージや社員メッセージ、当社の仕事内容など、採用に関する情報をお伝えします。トークセッション／入社3～4年目　社員インタビューや対談を通じて、実際に働いている社員の思いや当社の魅力をお伝えします。\">\r\n  <!-- OGP -->\r\n  <meta property=\"og:site_name\" content=\"新卒採用｜ドギーマンハヤシ株式会社\">\r\n  <meta property=\"og:title\" content=\"トークセッション／入社3～4年目｜新卒採用｜ドギーマンハヤシ株式会社\">\r\n  <meta property=\"og:type\" content=\"article\">\r\n  <meta property=\"og:url\" content=\"https://www.doggyman.com/recruit/people/symposium/\">\r\n  <meta property=\"og:description\" content=\"総合ペットメーカーのドギーマンハヤシの新卒採用ホームページです。社長メッセージや社員メッセージ、当社の仕事内容など、採用に関する情報をお伝えします。トークセッション／入社3～4年目　社員インタビューや対談を通じて、実際に働いている社員の思いや当社の魅力をお伝えします。\">\r\n  <meta property=\"og:image\" content=\"\">\r\n  <link rel=\"canonical\" href=\"https://www.doggyman.com/recruit/people/symposium/\">\r\n</head>\r\n\r\n\r\n\r\n<body id=\"talk_session\">\r\n\r\n\r\n\r\n  <div class=\"wrapper\">\r\n\r\n\r\n\r\n    <header>\r\n  <div class=\"inner\">\r\n    <div class=\"header-menu-area\">\r\n      <figure class=\"header-logo\">\r\n        <a href=\"../../\">\r\n          <img src=\"../../assets/img/logo.png\" alt=\"ドギーマンハヤシ株式会社\">\r\n          <p>採用サイト</p>\r\n        </a>\r\n      </figure>\r\n      <div class=\"header-menu\">\r\n        <ul class=\"header-menu-bottom\">\r\n          <li><a href=\"../../\">HOME</a></li>\r\n          <li><a href=\"../../message/\">社長メッセージ</a></li>\r\n          <li class=\"drop-menu\">\r\n            <a style=\"pointer-events: none;\">ドギーマンを知る</a>\r\n            <ul class=\"drop-menu-list\">\r\n              <li class=\"drop-menu-item\"><a href=\"../../pet_market/\">ペット市場の今</a></li>\r\n              <li class=\"drop-menu-item\"><a href=\"../../about-doggyman/\">キーワードで知る<br>ドギーマン</a></li>\r\n            </ul>\r\n          </li>\r\n          <li class=\"drop-menu\">\r\n            <a href=\"../../business/\">ドギーマンの仕事</a>\r\n            <ul class=\"drop-menu-list\">\r\n              <li class=\"drop-menu-item\"><a href=\"../../business#proposal\">「提案型営業」とは</a></li>\r\n              <li class=\"drop-menu-item\"><a href=\"../../business#group\">部門紹介</a></li>\r\n            </ul>\r\n          </li>\r\n          <li class=\"drop-menu\">\r\n            <a href=\"../../job/\">ドギーマンの人</a>\r\n            <ul class=\"drop-menu-list\">\r\n              <li class=\"drop-menu-item\"><a href=\"../../job/#interview_main\">社員メッセージ</a></li>\r\n              <li class=\"drop-menu-item\"><a href=\"../../job/#top-talk-session\">トークセッション</a></li>\r\n              <li class=\"drop-menu-item\"><a href=\"../../people/boss-subordinate/\">　上司×部下</a></li>\r\n              <li class=\"drop-menu-item\"><a href=\"../../people/development/\">　食品開発×用品開発</a></li>\r\n              <li class=\"drop-menu-item\"><a href=\"../../people/symposium\">　入社3〜4年目社員 座談会</a></li>\r\n            </ul>\r\n          </li>\r\n          <li class=\"drop-menu\">\r\n            <a style=\"pointer-events: none;\">採用情報</a>\r\n            <ul class=\"drop-menu-list\">\r\n              <li class=\"drop-menu-item\"><a href=\"../../welfare/\">各種制度・福利厚生</a></li>\r\n              <li class=\"drop-menu-item\"><a href=\"../../personnel/\">人事部メッセージ</a></li>\r\n              <li class=\"drop-menu-item\"><a href=\"../../recruit-info/\">採用情報</a></li>\r\n              <li class=\"drop-menu-item\"><a href=\"../../faq/\">よくある質問</a></li>\r\n            </ul>\r\n          </li>\r\n          <li class=\"drop-menu\">\r\n                <a style=\"pointer-events: none;\">ENTRY<br>MY PAGE</a>\r\n                <ul class=\"drop-menu-list entry\">\r\n                  <li class=\"drop-menu-item\">\r\n                  <a href=\"https://doggyman-recruit.snar.jp/index.aspx\" target=\"_blank\" rel=\"noopener noreferrer\">ENTRY</a>\r\n                  </li>\r\n                  <li class=\"drop-menu-item\">\r\n                  <a href=\"https://doggyman-recruit.snar.jp/login.aspx\" target=\"_blank\" rel=\"noopener noreferrer\">MY PAGE</a>\r\n                  </li>\r\n                </ul>\r\n              </li>\r\n\r\n\r\n\r\n        </ul>\r\n      </div>\r\n    </div>\r\n\r\n    <div class=\"menu\">\r\n      <nav>\r\n        <p class=\"navToggle\">\r\n          <span></span><span></span><span></span>\r\n        </p>\r\n        <div id=\"smt_menu_wrapper\" class=\"\">\r\n        <ul class=\"link\">\r\n            <li class=\"link-entry\">\r\n              <a href=\"https://doggyman-recruit.snar.jp/index.aspx\" target=\"_blank\" rel=\"noopener noreferrer\">新卒ENTRY</a>\r\n              <a href=\"https://doggyman-recruit.snar.jp/login.aspx\" target=\"_blank\" rel=\"noopener noreferrer\">MY PAGE</a>\r\n            </li>\r\n            <li class=\"full\">\r\n              <h3><a href=\"../../\">HOME</a></h3>\r\n            </li>\r\n            <li>\r\n              <h4><a>COMPANY</a></h4>\r\n              <a href=\"../../message/\">社長メッセージ</a>\r\n              <a href=\"../../pet_market/\">ペット市場の今</a>\r\n              <a href=\"../../about-doggyman/\">キーワードで知るドギーマン</a>\r\n              <a href=\"../../business/\">「提案型営業」と部門紹介</a>\r\n              <a href=\"../../#understands\">ドギーマンは分かってくれる</a>\r\n            </li>\r\n            <li>\r\n              <h4><a>PEOPLE</a></h4>\r\n              <a href=\"../../job/#interview_main\">社員インタビュー</a>\r\n              <a class=\"none\" href=\"../../job/#top-talk-session\">トークセッション</a>\r\n              <a class=\"under\" href=\"../../people/boss-subordinate/\">上司×部下</a>\r\n              <a class=\"under\" href=\"../../people/development/\">食品開発×用品開発</a>\r\n              <a class=\"under\" href=\"../../people/symposium\">入社3〜4年目社員 座談会</a>\r\n            </li>\r\n            <li>\r\n              <h4><a>RECRUIT</a></h4>\r\n              <a href=\"../../welfare/\">各種制度・福利厚生</a>\r\n              <a href=\"../../personnel/\">人事部メッセージ</a>\r\n              <a href=\"../../recruit-info/\">採用情報</a>\r\n              <a href=\"../../faq/\">よくある質問</a>\r\n            </li>\r\n          </ul>\r\n        </div>\r\n      </nav>\r\n    </div>\r\n  </div>\r\n  <div class=\"to_top_btn\">\r\n    <a href=\"#\"><img src=\"../../assets/img/top_allow.png\" alt=\"トップに戻る\"></a>\r\n  </div>\r\n  </header>\r\n\r\n\r\n    <main>\r\n\r\n\r\n\r\n      <section class=\"talk_session_main\">\r\n        <h2><span>T</span>ALK <span>S</span>ESSION</h2>\r\n        <p>トークセッション</p>\r\n        <div class=\"talk_head_title3\">\r\n          <figure class=\"talk_post center\">\r\n            <img src=\"../../assets/img/interview/talk_title_3-4.png\" alt=\"入社3～4年目\">\r\n          </figure>\r\n        </div>\r\n        <dl class=\"talk_head_profile sanyonen\">\r\n          <dt class=\"san\">\r\n            <div class=\"talk_head_profile_text\">\r\n              <h3>PROFILE</h3>\r\n              <div class=\"talk_head_profile_line\"></div>\r\n              <h4>東京営業本部<br>\r\n                東京第一営業所<br>\r\n                2020年度入社</h4>\r\n              <p>入社してからペットショップやドラッグストアの営業を担当。大学では応用生命科学を学んでいた。以前はワンちゃんを、今はネコちゃんを飼っている。趣味はアウトドアやキャンプ。</p>\r\n              <h5><span>N</span><span>さん</span></h5>\r\n            </div>\r\n          </dt>\r\n          <dd class=\"san\">\r\n            <div class=\"talk_head_profile_text\">\r\n              <h3>PROFILE</h3>\r\n              <div class=\"talk_head_profile_line\"></div>\r\n              <h4>東京営業本部<br>\r\n                東京第一営業所<br>\r\n                2020年度入社</h4>\r\n              <p>入社後よりディスカウントストアやドラッグストアの営業を担当。動物に興味があり、大学では動物に関して幅広く学んでいた。趣味は料理と言えるように日々勉強中。</p>\r\n              <h5><span>T</span><span>さん</span></h5>\r\n            </div>\r\n          </dd>\r\n          <dd class=\"san\">\r\n            <div class=\"talk_head_profile_text\">\r\n              <h3>PROFILE</h3>\r\n              <div class=\"talk_head_profile_line\"></div>\r\n              <h4>東京営業本部<br>\r\n                東京第一営業所<br>\r\n                2021年度入社</h4>\r\n              <p>Tさん・Nさんの1年後輩。ホームセンターやスーパーマーケット、ディスカウントストアなどの営業を担当。野球観戦が大好きで、横浜のチーム推し。月に1～2回は球場に足を運んでいる。\r\n              </p>\r\n              <h5><span>M</span><span>さん</span></h5>\r\n            </div>\r\n          </dd>\r\n        </dl>\r\n      </section>\r\n\r\n\r\n\r\n      <section class=\"talk_session_dis fade\">\r\n        <dl>\r\n          <dt>\r\n            <figure>\r\n              <img src=\"../../assets/img/interview/talk_sym_01.jpg\" alt=\"トークセッション\">\r\n            </figure>\r\n          </dt>\r\n          <dd>\r\n            <figure class=\"rotate\"><img src=\"../../assets/img/interview/talk_session_rotate.png\" alt=\"トークセッション\"></figure>\r\n            <h2>\r\n              <p class=\"leftin part1\"><span>温かい雰囲気</span>や</p>\r\n              <p class=\"leftin part2\"><span>商品力</span>に魅かれて入社。</p>\r\n            </h2>\r\n\r\n            <ul class=\"talk_session_dis_text\">\r\n              <li>\r\n                <figure>\r\n                  <img src=\"../../assets/img/interview/talk_face_t.jpg\" alt=\"Tさん\">\r\n                  <figcaption>T</figcaption>\r\n                </figure>\r\n                <p>私がドギーマンハヤシに興味を持ったのは、ペットフードだけでなく様々な用品に力を入れているということ。ペットの生活を幅広くサポートできそうと感じて就職を決めました。昔から動物に関わる仕事がしたいと思い、大学では動物について学んだけど、その中で犬や猫などの愛玩動物が好きということを再確認したのがきっかけかな。</p>\r\n              </li>\r\n              <li>\r\n                <figure><img src=\"../../assets/img/interview/talk_face_n.jpg\" alt=\"Nさん\">\r\n                  <figcaption>N</figcaption>\r\n                </figure>\r\n                <p>\r\n                  僕は就職活動のタイミングでペット業界について調べ始めたら「楽しそう」と思ったんだよね。CMの影響でドギーマンについて覚えていたのもあったし、面接に来てみると温かい雰囲気だったので「ここで働きたい!」と。\r\n                </p>\r\n              </li>\r\n              <li>\r\n                <figure><img src=\"../../assets/img/interview/talk_face_m.jpg\" alt=\"Mさん\">\r\n                  <figcaption>M</figcaption>\r\n                </figure>\r\n                <p>僕は、大学の時にアルバイトでペットコーナーを担当していて。その時のお客様からもワンちゃんやネコちゃんからの人気も高かったのがドギーマンハヤシの商品だったのがきっかけです。\r\n                </p>\r\n              </li>\r\n              <li>\r\n                <figure><img src=\"../../assets/img/interview/talk_face_n.jpg\" alt=\"Nさん\">\r\n                  <figcaption>N</figcaption>\r\n                </figure>\r\n                <p>\r\n                  入社してみると、人当たりの良い穏やかな人が多いなと思ったけど、いざお客様のところに行くと体育会系になる“隠れ体育会系”が多いよね(笑)。\r\n                </p>\r\n              </li>\r\n              <li>\r\n                <figure><img src=\"../../assets/img/interview/talk_face_t.jpg\" alt=\"Tさん\">\r\n                  <figcaption>T</figcaption>\r\n                </figure>\r\n                <p>\r\n                  そうそう(笑)。でも、とにかく根がとても優しい人ばかり！外交的な人も内向的な人もいるけれど、困ったときは助けてくださるし、気兼ねなく話しかけられるのも会社の魅力だと思います。\r\n                </p>\r\n              </li>\r\n            </ul>\r\n          </dd>\r\n        </dl>\r\n      </section>\r\n\r\n      <section class=\"talk_session_dis re fade\">\r\n        <dl>\r\n          <dt>\r\n            <figure>\r\n              <img src=\"../../assets/img/interview/talk_sym_02.jpg\" alt=\"トークセッション\">\r\n            </figure>\r\n          </dt>\r\n          <dd>\r\n            <figure class=\"rotate2\"><img src=\"../../assets/img/interview/talk_session_rotate.png\" alt=\"トークセッション\"></figure>\r\n            <h2>\r\n              <p class=\"leftin2 part3\">提案した商品を売り場で</p>\r\n              <p class=\"leftin2 part4\"><span>見つけた時の喜び。</span></p>\r\n            </h2>\r\n\r\n            <ul class=\"talk_session_dis_text\">\r\n              <li>\r\n                <figure><img src=\"../../assets/img/interview/talk_face_n.jpg\" alt=\"Nさん\">\r\n                  <figcaption>N</figcaption>\r\n                </figure>\r\n                <p>\r\n                  思い出に残っている仕事は、ネコの玩具をとあるホームセンター1店舗につき1週間で100個販売できたこと。展示会で「りぼんの舞(新体操で使うリボンのような猫じゃらし)」を、販促物なども使って猛アピールする棚を組んでみたら、お客様がとても興味を持ってくださって。結果、お客様の店舗でも同じように賑やかな売り場を作ることで売上に貢献できたのが嬉しかったな。\r\n                </p>\r\n              </li>\r\n              <li>\r\n                <figure><img src=\"../../assets/img/interview/talk_face_m.jpg\" alt=\"Mさん\">\r\n                  <figcaption>M</figcaption>\r\n                </figure>\r\n                <p>\r\n                  Nさんは「決める時に決める！」というタイプですもんね。僕は初めて大きい商談が成立した時はガッツポーズでしたね。売り場にズラッと並んだ商品を写真に撮って何度も見返しましたよ。僕は毎日がむしゃらに、当たって砕けろ精神で頑張っています(笑)。\r\n                </p>\r\n              </li>\r\n              <li>\r\n                <figure><img src=\"../../assets/img/interview/talk_face_t.jpg\" alt=\"Tさん\">\r\n                  <figcaption>T</figcaption>\r\n                </figure>\r\n                <p>頑張ってるよね!私は、先輩から引き継いだドラッグストアのバイヤーさんに商品を提案しても、初めは「う～ん…」と曖昧な反応をいただくことが多くて悩んでいて。でも、最近では「こういう商品が欲しかったんだよね！」と言っていただけることが増えてきました。その商品が売り場に並んで、良い実績を作れた時はやっぱり嬉しいですね。\r\n                </p>\r\n              </li>\r\n\r\n            </ul>\r\n          </dd>\r\n        </dl>\r\n      </section>\r\n\r\n\r\n      <section class=\"talk_session_dis fade\">\r\n        <dl>\r\n          <dt>\r\n            <figure>\r\n              <img src=\"../../assets/img/interview/talk_sym_03.jpg\" alt=\"トークセッション\">\r\n            </figure>\r\n          </dt>\r\n          <dd>\r\n            <figure class=\"rotate3\"><img src=\"../../assets/img/interview/talk_session_rotate.png\" alt=\"トークセッション\"></figure>\r\n            <h2>\r\n              <p class=\"leftin3 part5\">悪いことも<span>報告しやすく</span>\r\n              </p>\r\n              <p class=\"leftin3 part6\"><span>改善点を相談できる</span>環境。</p>\r\n            </h2>\r\n\r\n            <ul class=\"talk_session_dis_text\">\r\n              <li>\r\n                <figure><img src=\"../../assets/img/interview/talk_face_n.jpg\" alt=\"Nさん\">\r\n                  <figcaption>N</figcaption>\r\n                </figure>\r\n                <p>\r\n                  社内のコミュニケーションについては、M君はどう思う?僕は、良いことも悪いことも報告しやすい環境だと感じていて。良い内容だと褒めてもらえるし、良くない内容でも、そこからどう動くべきかを相談できたり、アドバイスをもらえたりするので助かってるかな。\r\n                </p>\r\n              </li>\r\n              <li>\r\n                <figure><img src=\"../../assets/img/interview/talk_face_m.jpg\" alt=\"Mさん\">\r\n                  <figcaption>M</figcaption>\r\n                </figure>\r\n                <p>\r\n                  僕もそう思います。適切な回答や助言をもらえるのが嬉しいですね。Tさんとは同じディスカウントストアを担当しているのですが、いつも気にかけてくださり、困ったことがあれば、わかりやすく説明してくださるので有難いです!\r\n                </p>\r\n              </li>\r\n              <li>\r\n                <figure><img src=\"../../assets/img/interview/talk_face_t.jpg\" alt=\"Tさん\">\r\n                  <figcaption>T</figcaption>\r\n                </figure>\r\n                <p>\r\n                  ありがとう！同じお客様を担当先しているから、お互いに仕事量を確認しながら上手く分担できているよね。上司のアドバイスはいつも的確だし、仕事以外の雑談もできるので、社員同士の距離感は近い会社かな。あと、最近は東京営業所に若手の女性社員が増えたのも良かったなと思っています。\r\n                </p>\r\n              </li>\r\n            </ul>\r\n\r\n            <div style=\"position: relative;padding-top: 100px;\">\r\n              <figure class=\"rotate4\"><img src=\"../../assets/img/interview/talk_session_rotate.png\" alt=\"トークセッション\"></figure>\r\n              <h2>\r\n                <p class=\"leftin4 part7\">わからないことを<span>素直に</span>\r\n                </p>\r\n                <p class=\"leftin4 part8\"><span>聞ける人</span>と働きたい。</p>\r\n              </h2>\r\n            </div>\r\n\r\n            <ul class=\"talk_session_dis_text\">\r\n              <li>\r\n                <figure><img src=\"../../assets/img/interview/talk_face_t.jpg\" alt=\"Tさん\">\r\n                  <figcaption>T</figcaption>\r\n                </figure>\r\n                <p>\r\n                  これからの目標は、とにかくバイヤーさんから頼られるような存在になりたい。ライバル社の棚をじわじわとドギーマン色にしたいですね。自分の努力次第で結果が大きく変わるのがこの仕事の醍醐味かな。\r\n                </p>\r\n              </li>\r\n              <li>\r\n                <figure><img src=\"../../assets/img/interview/talk_face_n.jpg\" alt=\"Nさん\">\r\n                  <figcaption>N</figcaption>\r\n                </figure>\r\n                <p>\r\n                  僕は、とにかく一歩一歩成長していきたい。そして、お客様からも社内でも頼られるような人になれたらと。売り場でお客さんから「この玩具が一番遊んでくれる」というような声をもっと聞けるために頑張ります。\r\n                </p>\r\n              </li>\r\n              <li>\r\n                <figure><img src=\"../../assets/img/interview/talk_face_m.jpg\" alt=\"Mさん\">\r\n                  <figcaption>M</figcaption>\r\n                </figure>\r\n                <p>\r\n                  僕は将来、本部長になります!!\r\n                </p>\r\n              </li>\r\n              <li>\r\n                <figure><img src=\"../../assets/img/interview/talk_face_t.jpg\" alt=\"Tさん\">\r\n                  <figcaption>T</figcaption>\r\n                </figure>\r\n                <p>\r\n                  おー、言ったね！一緒に頑張っていこう！就職を迷っている皆さんも、わからないことを聞いてくれるような素直な方だったら大丈夫。皆さんと一緒に働ける未来をとても楽しみにしています。\r\n                </p>\r\n              </li>\r\n              <li class=\"short\">\r\n                <figure><img src=\"../../assets/img/interview/talk_face_n.jpg\" alt=\"Nさん\">\r\n                  <figcaption>N</figcaption>\r\n                </figure>\r\n              </li>\r\n            </ul>\r\n          </dd>\r\n        </dl>\r\n      </section>\r\n\r\n\r\n\r\n      <figure class=\"fade last_photo\">\r\n        <picture>\r\n          <source media=\"(max-width:769px)\" srcset=\"../../assets/img/interview/talk_sym_04_sp.jpg 769w\" sizes=\"100vw\">\r\n          <img src=\"../../assets/img/interview/talk_sym_04.jpg\" alt=\"トークセッション\">\r\n        </picture>\r\n      </figure>\r\n\r\n\r\n\r\n\r\n      <section class=\"talk_session_end fade\">\r\n        <div class=\"inner\">\r\n          <figure class=\"minasama_title\"><img src=\"../../assets/img/interview/talk_minasama.png\" alt=\"就活生のみなさんへ\"></figure>\r\n          <ul class=\"minasama_pop_unit\">\r\n            <li class=\"pop part1\">\r\n              <figure><img src=\"../../assets/img/interview/talk_face_t.jpg\" alt=\"Tさん\">\r\n                <figcaption>T</figcaption>\r\n              </figure>\r\n              <div class=\"minasama\">\r\n                <p>就職活動には正解がないので、悩んだり不安になることもあるはず。睡眠時間をしっかりとり、美味しいものを食べて息抜きをしながらも自分に合った会社が見つかるよう最後まで頑張ってください！応援しています。</p>\r\n              </div>\r\n            </li>\r\n            <li class=\"pop part2\">\r\n              <figure><img src=\"../../assets/img/interview/talk_face_n.jpg\" alt=\"Nさん\">\r\n                <figcaption>N</figcaption>\r\n              </figure>\r\n              <div class=\"minasama\">\r\n                <p>自分の将来について一番じっくり考えられるのが就職活動だと思います。存分に悩むことも大切ですし、最終的には振り返って「楽しかった！」と感じられる時間にしてもらえたらと思います。\r\n                </p>\r\n              </div>\r\n            </li>\r\n            <li class=\"pop part3\">\r\n              <figure><img src=\"../../assets/img/interview/talk_face_m.jpg\" alt=\"Mさん\">\r\n                <figcaption>M</figcaption>\r\n              </figure>\r\n              <div class=\"minasama\">\r\n                <p>このホームページを見ている皆さんは、事前準備をきちんとできる人だと思いますので心配はいらないと思います。後悔を残さないよう、就職活動に精一杯打ち込んでください。もし一緒に働けることになれば、一緒に仕事を楽しみましょうね！</p>\r\n              </div>\r\n            </li>\r\n          </ul>\r\n        </div>\r\n      </section>\r\n\r\n\r\n\r\n      <a class=\"back_link\" href=\"../../job/#top-talk-session\"><span>T</span>ALK\r\n        <span>S</span>ESSION一覧に戻る<span>▶︎</span></a>\r\n\r\n\r\n\r\n    </main>\r\n\r\n\r\n\r\n    <footer>\r\n  <div class=\"inner\">\r\n    <dl class=\"short_btn_unit_sp\">\r\n          <dt>\r\n            <a href=\"https://doggyman-recruit.snar.jp/index.aspx\" target=\"_blank\" rel=\"noopener noreferrer\">ENTRY</a>\r\n          </dt>\r\n          <dd>\r\n            <a href=\"https://doggyman-recruit.snar.jp/login.aspx\" target=\"_blank\" rel=\"noopener noreferrer\">MY PAGE</a>\r\n          </dd>\r\n        </dl>\r\n        <dl class=\"short_btn_unit\">\r\n          <dt>\r\n            <a href=\"https://doggyman-recruit.snar.jp/index.aspx\" target=\"_blank\" rel=\"noopener noreferrer\">\r\n              <span>ENTRY</span>\r\n            </a>\r\n          </dt>\r\n          <dd>\r\n            <a href=\"https://doggyman-recruit.snar.jp/login.aspx\" target=\"_blank\" rel=\"noopener noreferrer\">\r\n              <span>MY PAGE</span>\r\n            </a>\r\n          </dd>\r\n        </dl>\r\n\r\n    <ul class=\"link\">\r\n      <li>\r\n        <h3><a href=\"../../\">HOME</a></h3>\r\n      </li>\r\n      <li>\r\n        <h4><a>COMPANY</a></h4>\r\n        <a href=\"../../message/\">社長メッセージ</a>\r\n        <a href=\"../../pet_market/\">ペット市場の今</a>\r\n        <a href=\"../../about-doggyman/\">キーワードで知るドギーマン</a>\r\n        <a href=\"../../business/\">「提案型営業」と部門紹介</a>\r\n        <a href=\"../../#understands\">ドギーマンは分かってくれる</a>\r\n      </li>\r\n      <li>\r\n        <h4><a>PEOPLE</a></h4>\r\n        <a href=\"../../job/#interview_main\">社員インタビュー</a>\r\n        <a class=\"none\" href=\"../../job/#top-talk-session\">トークセッション</a>\r\n        <a class=\"under\" href=\"../../people/boss-subordinate/\">上司×部下</a>\r\n        <a class=\"under\" href=\"../../people/development/\">食品開発×用品開発</a>\r\n        <a class=\"under\" href=\"../../people/symposium/\">入社3〜4年目社員 座談会</a>\r\n      </li>\r\n      <li>\r\n        <h4><a>RECRUIT</a></h4>\r\n        <a href=\"../../welfare/\">各種制度・福利厚生</a>\r\n        <a href=\"../../personnel/\">人事部メッセージ</a>\r\n        <a href=\"../../recruit-info/\">採用情報</a>\r\n        <a href=\"../../faq/\">よくある質問</a>\r\n      </li>\r\n    </ul>\r\n\r\n\r\n\r\n    <ul class=\"sns\">\r\n          <li>\r\n            <a href=\"https://page.line.me/714dlzpo?oat__id=3365953&openQrModal=true\" target=\"_blank\" rel=\"noopener noreferrer\">\r\n              <figure><img src=\"../../assets/img/sns_line.png\" alt=\"ドギーマンLINE公式\"></figure>\r\n            </a>\r\n          </li>\r\n          <li>\r\n            <a href=\"https://www.instagram.com/doggyman_pr\" target=\"_blank\" rel=\"noopener noreferrer\">\r\n              <figure><img src=\"../../assets/img/sns_instagram_doggy.png\" alt=\"ドギーマンInstagram\"></figure>\r\n            </a>\r\n          </li>\r\n          <li>\r\n            <a href=\"https://www.instagram.com/cattymancam/\" target=\"_blank\" rel=\"noopener noreferrer\">\r\n              <figure><img src=\"../../assets/img/sns_instagram_catty.png\" alt=\"キャティーマンInstagram\"></figure>\r\n            </a>\r\n          </li>\r\n          <li>\r\n            <a href=\"https://x.com/doggyman_pr/\" target=\"_blank\" rel=\"noopener noreferrer\">\r\n              <figure><img src=\"../../assets/img/sns_x_01.png\" alt=\"ドギーマンX\"></figure>\r\n            </a>\r\n          </li>\r\n          <li>\r\n            <a href=\"https://x.com/cattymancam\" target=\"_blank\" rel=\"noopener noreferrer\">\r\n              <figure><img src=\"../../assets/img/sns_x_02.png\" alt=\"キャティーマンX\"></figure>\r\n            </a>\r\n          </li>\r\n          <li>\r\n            <a href=\"https://www.youtube.com/channel/UC6OvqzIxns7JJXYC3gTuRig\" target=\"_blank\" rel=\"noopener noreferrer\">\r\n              <figure><img src=\"../../assets/img/sns_youtube.png\" alt=\"ドギーマン公式youtube\"></figure>\r\n            </a>\r\n          </li>\r\n          <li>\r\n            <a href=\"https://www.tiktok.com/@doggyman_official\" target=\"_blank\" rel=\"noopener noreferrer\">\r\n              <figure><img src=\"../../assets/img/sns_tiktok.png\" alt=\"ドギーマン公式tiktok\"></figure>\r\n            </a>\r\n          </li>\r\n        </ul>\r\n\r\n\r\n    <div class=\"footer_line\"></div>\r\n\r\n\r\n    <figure class=\"footer_logo\">\r\n      <a href=\"https://www.doggyman.com/\" target=\"_blank\">\r\n        <span>コーポレートサイト</span>\r\n      </a>\r\n    </figure>\r\n\r\n\r\n\r\n    <small>Copyright(C)DoggyMan H.A.Co.,Ltd.All rights reserved.</small>\r\n\r\n  </div>\r\n\r\n</footer>\r\n\r\n\r\n<!-- Google Tag Manager (noscript) -->\r\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-KPBT95R\" height=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\r\n<!-- End Google Tag Manager (noscript) -->\r\n\r\n\r\n<script>\r\n  const btn2a = document.querySelector(\".navToggle\");\r\n  const list = document.querySelector(\".short_btn_unit_sp\");\r\n\r\n  btn2a.addEventListener(\