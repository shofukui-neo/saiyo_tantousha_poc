{"url":"https://www.tobuzoo.com/recruit/","html":"<!doctype html>\n<html lang=\"ja\">\n\n<head>\n<meta charset=\"UTF-8\" />\n<title>スタッフ募集｜ ハイブリッド・レジャーランド東武動物公園公式Webサイト</title>\n<link rel=\"stylesheet\" href=\"/assets/cms/public.css\" media=\"all\" />\n<link rel=\"stylesheet\" href=\"/assets/jplayer.css\" media=\"all\" />\n<script src=\"/assets/cms/compat.js\"></script>\n<script src=\"/assets/cms/public.js\"></script>\n<script src=\"/assets/jplayer.js\"></script>\n<script>\n//<![CDATA[\n\n  SS.config = {\"site_url\":\"/\",\"kana_url\":\"/kana/\",\"translate_url\":\"/translate/\",\"theme\":{},\"recommend\":{}};\n\n//]]>\n</script><meta name=\"keywords\" content=\"スタッフ募集\" />\n<meta name=\"description\" content=\"東武動物公園の採用情報を掲載しています。\" />\n\r\n    <!-- Google Tag Manager -->\r\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\r\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\r\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\r\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\r\n})(window,document,'script','dataLayer','GTM-TM4GVW');</script>\r\n<!-- End Google Tag Manager -->\r\n    <script src=\"//msta.j-server.com/MSTA/LUC2TOBUZO/js/msta.js\"></script>\r\n    <meta name=\"viewport\" content=\"width=device-width,initial-scale=1.0,user-scalable=yes,minimum-scale=1.0,maximum-scale=2.0\">\r\n    <meta property=\"og:description\" content=\"東武動物公園についてご案内しています。\">\r\n    <meta name=\"twitter:description\" content=\"東武動物公園についてご案内しています。\">\r\n    <link rel=\"canonical\" href=\"https://www.tobuzoo.com/\">\r\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\r\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\r\n    <link href=\"https://fonts.googleapis.com/css2?family=M+PLUS+Rounded+1c:wght@300;400;500;700&family=Noto+Sans+JP:wght@100..900&display=swap\" rel=\"stylesheet\">\r\n    <link href=\"/development/css/splide-core.min.css\" media=\"all\" rel=\"stylesheet\" />\r\n    <link href=\"/development/css/style.css\" media=\"all\" rel=\"stylesheet\" />\r\n    <script src=\"/development/js/splide.min.js\"></script>\r\n    <script src=\"/development/js/common.js\"></script>\r\n    <link rel=\"shortcut icon\" href=\"/development/img/common/favicon.ico \">\r\n<link rel=\"apple-touch-icon\" href=\"/development/img/common/apple-touch-icon.png\">\r\n  \n\n\n\n</head>\n\n<body id=\"body--recruit-index\" class=\"body--recruit underPage_layout generic_layout\">\r\n    <!-- Google Tag Manager (noscript) -->\r\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-TM4GVW\"\r\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\r\n<!-- End Google Tag Manager (noscript) -->\r\n\r\n    <div id=\"pageContent\">\r\n      <div id=\"top\">\r\n<p class=\"skip inner\"><a href=\"#main\">このページの本文へ</a></p>\r\n</div>\r\n      <!-- Facebook JavaScript SDK -->\r\n<div id=\"fb-root\"></div>\r\n<script async defer crossorigin=\"anonymous\" src=\"https://connect.facebook.net/ja_JP/sdk.js#xfbml=1&version=v12.0\" nonce=\"ECJdN7MV\"></script>\r\n<!-- End Facebook JavaScript SDK -->\r\n      <header id=\"commonHeader\">\r\n        <div class=\"header_inner\">\r\n          <div class=\"logo\"><a href=\"/\"><img src=\"/development/img/common/logo.svg\" alt=\"ハイブリッド・レジャーランド　東武動物公園\" width=\"320\" height=\"90\" /></a></div>\r\n          <div class=\"header_right\">\r\n            <div class=\"header_tool\">\r\n              <ul>\r\n  <li class=\"guide\"><a href=\"/servicelist/\">ご利用ガイド</a></li>\r\n  <li class=\"faq\"><a href=\"/faq/\">よくあるご質問</a></li>\r\n  <li class=\"grouop\"><a href=\"/school/\">学校・団体の方へ</a></li>\r\n</ul>\r\n              <!-- PC表示 -->\r\n              <div class=\"dropdown\" id=\"langDropdown\">\r\n  <div id=\"msta_langArea\" class=\"msta-default\" lang=\"ja\">\r\n  </div>\r\n</div>\r\n\r\n<script>\r\n  (function() {\r\n    const breakpoint = 1060;\r\n    const body = document.body;\r\n\r\n    function moveLangSelector() {\r\n      const langDropdown = document.getElementById('langDropdown');\r\n      const moveTarget = document.getElementById('langMoveTarget');\r\n\r\n      if (!langDropdown || !moveTarget) {\r\n        //console.log('要素が見つかりません' );\r\n        return;\r\n      }\r\n\r\n      // 初回実行時に元の位置を保存\r\n      if (!window.langSelectorOriginal) {\r\n        window.langSelectorOriginal = {\r\n          parent: langDropdown.parentNode,\r\n          nextSibling: langDropdown.nextSibling\r\n        };\r\n      }\r\n\r\n      const isHeaderFixed = body.classList.contains('isHeaderFixed');\r\n      const isMobile = window.innerWidth <= breakpoint;\r\n\r\n      // 1060px以下 または isHeaderFixedがある場合に移動\r\n      if (isMobile || isHeaderFixed) {\r\n        // 移動先に移動\r\n        if (langDropdown.parentNode !== moveTarget) {\r\n          moveTarget.appendChild(langDropdown);\r\n          //console.log('移動しました');\r\n        }\r\n      } else {\r\n        // 元の位置に戻す\r\n        if (langDropdown.parentNode !== window.langSelectorOriginal.parent) {\r\n          window.langSelectorOriginal.parent.insertBefore(\r\n            langDropdown,\r\n            window.langSelectorOriginal.nextSibling\r\n          );\r\n          //console.log('元に戻しました');\r\n        }\r\n      }\r\n    }\r\n\r\n    // ページ読み込み完了後に実行\r\n    if (document.readyState === 'loading') {\r\n      document.addEventListener('DOMContentLoaded', function() {\r\n        moveLangSelector();\r\n      });\r\n    } else {\r\n      moveLangSelector();\r\n    }\r\n\r\n    // リサイズ時\r\n    window.addEventListener('resize', moveLangSelector);\r\n\r\n    // bodyのクラス変更をobserverで監視\r\n    const observer = new MutationObserver(function() {\r\n      //console.log('isHeaderFixedを検出');\r\n      moveLangSelector();\r\n    });\r\n\r\n    observer.observe(body, {\r\n      attributes: true,\r\n      attributeFilter: ['class']\r\n    });\r\n  })();\r\n</script>\r\n            </div>\r\n            <div class=\"header_navi\">\r\n              <nav id=\"globalNav\">\r\n                <ul>\r\n  <li class=\"zoo\">\r\n    <a href=\"/zoo/\">\r\n      <span class=\"naviIcon\" aria-hidden=\"true\"></span>\r\n      動物園\r\n    </a>\r\n  </li>\r\n  <li class=\"park\">\r\n    <a href=\"/park/\">\r\n      <span class=\"naviIcon\" aria-hidden=\"true\"></span>\r\n      遊園地\r\n    </a>\r\n  </li>\r\n  <li class=\"pool\">\r\n    <a href=\"/pool/\">\r\n      <span class=\"naviIcon\" aria-hidden=\"true\"></span>\r\n      プール\r\n    </a>\r\n  </li>\r\n  <li class=\"food-shop\">\r\n    <a href=\"/food-shop/\">\r\n      <span class=\"naviIcon\" aria-hidden=\"true\"></span>\r\n      フード＆<br>ショップ\r\n    </a>\r\n  </li>\r\n  <li class=\"ticket\">\r\n    <a href=\"/ticket/\">\r\n      <span class=\"naviIcon\" aria-hidden=\"true\"></span>\r\n      料金・<br>チケット\r\n    </a>\r\n  </li>\r\n  <li class=\"access\">\r\n    <a href=\"/access/\">\r\n      <span class=\"naviIcon\" aria-hidden=\"true\"></span>\r\n      アクセス\r\n    </a>\r\n  </li>\r\n</ul>\r\n              </nav>\r\n              <!-- SP表示 -->\r\n              <div id=\"langMoveTarget\"></div>\r\n              <div class=\"header_ticket\"><a href=\"/ticket/\"><span class=\"ticket_icon\"></span><span class=\"ticket_text\">チケット</span></a></div>\r\n              <div id=\"menuBtn\"><button aria-controls=\"menuNav\" aria-expanded=\"false\"><span class=\"hamburger\"><span></span></span><span class=\"scrText\">メニュー</span></button></div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </header>\r\n\r\n      <header id=\"pageHeader\">\r\n        <div class=\"pageHeader_inner\">\r\n          <div class=\"bread\">\r\n            <div class=\"crumbs\">\n    <div class=\"crumb\" itemscope itemtype=\"https://schema.org/BreadcrumbList\">\n      <span class=\"page\" itemprop=\"itemListElement\" itemscope itemtype=\"https://schema.org/ListItem\"><span itemprop=\"name\"><a itemprop=\"item\" href=\"/\">トップ</a></span><meta itemprop=\"position\" content=\"1\"></span><span class=\"separator\">&rsaquo;</span><span class=\"page\" itemprop=\"itemListElement\" itemscope itemtype=\"https://schema.org/ListItem\"><span itemprop=\"name\">スタッフ募集</span><meta itemprop=\"position\" content=\"2\"></span>\n    </div>\n</div>\n\r\n          </div>\r\n          <h1 class=\"pageHeader_stay\">スタッフ募集</h1>\r\n          \r\n\r\n          \r\n        </div>\r\n      </header>\r\n\r\n      <main id=\"main\">\r\n        <div class=\"mainContents_inner\">\r\n          <!-- layout_yield -->    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n      \n    <article class=\"body\">\n      <div class=\"recruit_articleabody_wrap\">\r\n<section class=\"section_wrap\">\r\n<div class=\"image marginB60\"><img alt=\"スタッフたちが働く様子\" class=\"borderRadius60\" height=\"414\" src=\"/fs/4/9/1/3/0/_/img_reqruit01.jpg\" width=\"1170\" /></div>\r\n\r\n<div class=\"box_bgLightYellow\">\r\n<h2 class=\"section_wrap__heading3\">こんな方は大歓迎！</h2>\r\n\r\n<ul class=\"yellowIconList\">\r\n\t<li>明るく人と話すことが好きな方</li>\r\n\t<li>子供を喜ばせることが好きな方</li>\r\n\t<li>笑顔、コミュニケーション力、ホスピタリティマインドの高い方</li>\r\n\t<li>大きな声で積極的にお客様へお声がけができる方・とにかくやる気だけはある</li>\r\n\t<li>勉強、サークルをしながらバイトをしたい学生の方</li>\r\n</ul>\r\n</div>\r\n</section>\r\n\r\n<section class=\"section_wrap\">\r\n<h2 class=\"section_wrap__heading3\">募集職種一覧</h2>\r\n\r\n<ul class=\"recruit_list hiring marginB20\">\r\n\t<li>\r\n\t<p class=\"title\"><span class=\"state hiring\">募集中</span><span class=\"titleMain\">ライフガード</span></p>\r\n\r\n\t<p class=\"message\">東武スーパープール内でのプール監視（プール施設管理、お客様の安全を守る）<br />\r\n\tウォータースライダーでの接客や清掃がお仕事です。<br />\r\n\t真っ黒に日焼けしてカッコよくなろう！　体力勝負なので自信のある方、大募集します。<br />\r\n\t時給 1,450円～（高校生 1,400円～）</p>\r\n\t</li>\r\n\t<li>\r\n\t<p class=\"title\"><span class=\"state hiring\">募集中</span><span class=\"titleMain\">パークキーパー</span></p>\r\n\r\n\t<p class=\"message\">東武スーパープール内でのプール場内の清掃、お客様の誘導等、場内の見回りをおこないます。<br />\r\n\t時給 1,280円～（高校生 1,230円～）</p>\r\n\t</li>\r\n\t<li>\r\n\t<p class=\"title\"><span class=\"state hiring\">募集中</span><span class=\"titleMain\">インフォメーション</span></p>\r\n\r\n\t<p class=\"message\">東武スーパープール内でのエントランス・ロッカー・チケットカウンターでの受付、ご案内、館内アナウンスをおこないます。<br />\r\n\t時給 1,230円～（高校生 1,180円～）</p>\r\n\t</li>\r\n\t<li>\r\n\t<p class=\"title\"><span class=\"state hiring\">募集中</span><span class=\"titleMain\">遊園地スタッフ</span></p>\r\n\r\n\t<p class=\"message\">遊園地の乗り物を操作する仕事。ゲームセンター・及びゲームコーナーのスタッフ。乗り物が大好きの方はぜひどうぞ！！<br />\r\n\t乗り物を動かし、お客様を楽しませるのと同時に自分も楽しんでしまいましょう。その他列の整理・誘導・案内もします。</p>\r\n\r\n\t<div class=\"text_link\"><a href=\"#recruit01\">詳しくはこちら</a></div>\r\n\t</li>\r\n\t<!--\r\n\t<li>\r\n\t<p class=\"title\"><span class=\"state hiring\">募集中</span><span class=\"titleMain\">看護師</span></p>\r\n\r\n\t<p class=\"message\">園内看護センターでの簡単な対応</p>\r\n\r\n\t<div class=\"text_link\"><a href=\"#recruit02\">詳しくはこちら</a></div>\r\n\t</li>\r\n-->\r\n\t<li>\r\n\t<p class=\"title\"><span class=\"state hiring\">募集中</span><span class=\"titleMain\">着ぐるみスタッフ</span></p>\r\n\r\n\t<p class=\"message\">着ぐるみを着て園内を巡回、東西ゲートでのお出迎えを行ないます。<br />\r\n\t着ぐるみのサイズ上、身長158cm以下の方をお待ちしています！小さなお子様の相手が得意な方には是非お薦めです。</p>\r\n\t<!-- <div class=\"text_link\"><a href=\"#recruit03\">詳しくはこちら</a></div> --></li>\r\n\t<li>\r\n\t<p class=\"title\"><span class=\"state hiring\">募集中</span><span class=\"titleMain\">動物園イベントスタッフ</span></p>\r\n\r\n\t<p class=\"message\">ふれあい動物の森にある、わとと売店での販売員と園内の動物園ゾーンでのイベントの窓口・受付を行なうお仕事です。 動物の飼育は行なえませんが、近くにはいつも動物がいる環境です。動物が好きな方、大歓迎！！</p>\r\n\t<!-- <div class=\"text_link\"><a href=\"#recruit04\">詳しくはこちら</a></div> --></li>\r\n\t<li>\r\n\t<p class=\"title\"><span class=\"state hiring\">募集中</span><span class=\"titleMain\">チケット販売スタッフ</span></p>\r\n\r\n\t<p class=\"message\">東西ゲートでチケットを発券・販売し、半券を受け取る仕事。 楽しみに来たお客様と最初に挨拶をするのも、園内で楽しんだお客様を最後にお見送りするのも私たちチケット販売スタッフです。ベビーカー・車椅子の貸し出しもします。</p>\r\n\t<!-- \r\n<div class=\"text_link\"><a href=\"#recruit05\">詳しくはこちら</a></div> --></li>\r\n\t<li>\r\n\t<p class=\"title\"><span class=\"state hiring\">募集中</span><span class=\"titleMain\">清掃スタッフ</span></p>\r\n\r\n\t<p class=\"message\">園内全域の清掃（ゴミ箱・灰皿・トイレを含む）を行ないます。お客様に気持ち良く園内を楽しんでいただけるように園内をキレイにするのが私たちの仕事です。 縁の下の力持ち！<br />\r\n\t力がなくてもキレイ好きな方にお薦めです。たくさんのお客様と接する機会が多いので、接客好きな方にはなおお勧めです。</p>\r\n\t<!-- <div class=\"text_link\"><a href=\"#recruit06\">詳しくはこちら</a></div> --></li>\r\n</ul>\r\n\r\n<ul class=\"smallNotice\">\r\n\t<li>職種の希望は受けますが、希望に添えない場合があります。</li>\r\n</ul>\r\n</section>\r\n\r\n<section class=\"section_wrap recruit_filled\">\r\n<h2 class=\"scrText\">終了した職種</h2>\r\n<button aria-controls=\"filled01\" aria-expanded=\"false\" class=\"accordion-btn\" type=\"button\"><span class=\"text\">募集終了した職種</span></button>\r\n\r\n<div class=\"accordion-content\" id=\"filled01\">\r\n<ul class=\"recruit_list filled\"><!-- <li>\r\n\t<p class=\"title\"><span class=\"state filled\">募集終了</span><span class=\"titleMain\">ライフガード</span></p>\r\n\r\n\t<p class=\"message\">東武スーパープール内でのプール監視（プール施設管理、お客様の安全を守る）<br />\r\n\tウォータースライダーでの接客や清掃がお仕事です。<br />\r\n\t真っ黒に日焼けしてカッコよくなろう！　体力勝負なので自信のある方、大募集します。<br />\r\n\t時給 1,400円～（高校生 1,350円～）</p>\r\n\t</li> --><!-- <li>\r\n\t<p class=\"title\"><span class=\"state filled\">募集終了</span><span class=\"titleMain\">パークキーパー</span></p>\r\n\r\n\t<p class=\"message\">東武スーパープール内でのプール場内の清掃、お客様の誘導等、場内の見回りをおこないます。<br />\r\n\t時給 1,250円～（高校生 1,200円～）</p>\r\n\t</li> --><!-- <li>\r\n\t<p class=\"title\"><span class=\"state filled\">募集終了</span><span class=\"titleMain\">インフォメーション</span></p>\r\n\r\n\t<p class=\"message\">東武スーパープール内でのエントランス・ロッカー・チケットカウンターでの受付、ご案内、館内アナウンスをおこないます。<br />\r\n\t時給 1,200円～（高校生 1,150円～）</p>\r\n\t</li> --><!-- <li>\r\n\t<p class=\"title\"><span class=\"state filled\">募集終了</span><span class=\"titleMain\">着ぐるみスタッフ</span></p>\r\n\r\n\t<p class=\"message\">着ぐるみを着て園内を巡回、東西ゲートでのお出迎えを行ないます。<br />\r\n\t着ぐるみのサイズ上、身長158cm以下の方をお待ちしています！小さなお子様の相手が得意な方には是非お薦めです。</p>\r\n\r\n\t<ul class=\"smallNotice\">\r\n\t\t<li>土日祝出勤できる方</li>\r\n\t</ul>\r\n\t</li> --><!-- <li>\r\n\t<p class=\"title\"><span class=\"state filled\">募集終了</span><span class=\"titleMain\">チケット販売スタッフ</span></p>\r\n\r\n\t<p class=\"message\">東西ゲートでチケットを発券・販売し、半券を受け取る仕事。 楽しみに来たお客様と最初に挨拶をするのも、園内で楽しんだお客様を最後にお見送りするのも私たちチケット販売スタッフです。ベビーカー・車椅子の貸し出しもします。</p>\r\n\t</li> -->\r\n\t<li>\r\n\t<p class=\"title\"><span class=\"state filled\">募集終了</span><span class=\"titleMain\">駐車場スタッフ</span></p>\r\n\r\n\t<p class=\"message\">料金所のスタッフ。車両の誘導スタッフ。 3,000台収容の当園直営の大型駐車場でのスタッフです。料金所での案内も、身振り・手振りを交えた交通整理も元気良くお客様と接しましょう。</p>\r\n\t</li>\r\n\t<!-- <li>\r\n\t<p class=\"title\"><span class=\"state filled\">募集終了</span><span class=\"titleMain\">清掃スタッフ</span></p>\r\n\r\n\t<p class=\"message\">園内全域の清掃（ゴミ箱・灰皿・トイレを含む）を行ないます。お客様に気持ち良く園内を楽しんでいただけるように園内をキレイにするのが私たちの仕事です。 縁の下の力持ち！<br />\r\n\t力がなくてもキレイ好きな方にお薦めです。たくさんのお客様と接する機会が多いので、接客好きな方にはなおお勧めです。</p>\r\n\r\n\t<ul class=\"smallNotice\">\r\n\t\t<li>接客のお仕事も含まれます。</li>\r\n\t</ul>\r\n\t</li> --><!-- <li>\r\n\t<p class=\"title\"><span class=\"state filled\">募集終了</span><span class=\"titleMain\">動物園イベントスタッフ</span></p>\r\n\r\n\t<p class=\"message\">ふれあい動物の森にある、わとと売店での販売員と園内の動物園ゾーンでのイベントの窓口・受付を行なうお仕事です。 動物の飼育は行なえませんが、近くにはいつも動物がいる環境です。動物が好きな方、大歓迎！！</p>\r\n\t</li> -->\r\n\t<li>\r\n\t<p class=\"title\"><span class=\"state filled\">募集終了</span><span class=\"titleMain\">イベントアシスタント</span></p>\r\n\r\n\t<p class=\"message\">東武動物公園で行なわれるイベントのアシスタント。イベントでのMCや撮影の立会い等を行ないます。 パソコンのスキル(Excel・Word等)がある方大歓迎！</p>\r\n\t</li>\r\n\t<li>\r\n\t<p class=\"title\"><span class=\"state filled\">募集終了</span><span class=\"titleMain\">団体管理スタッフ</span></p>\r\n\r\n\t<p class=\"message\">団体さんの入園情報を管理する仕事です。 パソコンのスキル(Excel・Word)は必須です。</p>\r\n\t</li>\r\n\t<li>\r\n\t<p class=\"title\"><span class=\"state filled\">募集終了</span><span class=\"titleMain\">獣医師</span></p>\r\n\r\n\t<p class=\"message\">臨床獣医医療業務、飼育業務、動物園催事補助他</p>\r\n\t</li>\r\n</ul>\r\n</div>\r\n</section>\r\n\r\n<div class=\"wide_wrap recruit_detail\">\r\n<section class=\"section_wrap inner1170\">\r\n<h2 class=\"section_wrap__heading2\">募集内容</h2>\r\n\r\n<div class=\"boxWhite marginB40\">\r\n<h3 class=\"section_wrap__heading3\" id=\"recruit01\">アルバイト</h3>\r\n\r\n<dl class=\"dl_wrap01\">\r\n\t<dt>時給</dt>\r\n\t<dd>\r\n\t<p>アルバイト　1,160円～1,190円</p>\r\n\r\n\t<ul class=\"smallNotice\">\r\n\t\t<li>研修期間は1,150円。短縮有り。</li>\r\n\t</ul>\r\n\t</dd>\r\n\t<dt>応募資格</dt>\r\n\t<dd>\r\n\t<p>18才以上(職種により高校生可)</p>\r\n\t</dd>\r\n\t<dt>勤務日</dt>\r\n\t<dd>\r\n\t<p>週1日～週4日までの間でシフトで決めていきます。<br />\r\n\t(各セクションの担当者と相談して決めることができます。土日祝だけでもOK)</p>\r\n\t</dd>\r\n\t<dt>勤務時間</dt>\r\n\t<dd>\r\n\t<p>開園40分前～閉園10-30分後の間で出勤※季節により営業時間変動します。<br />\r\n\t夜間営業ありその他、早番遅番などのシフト制です。<br />\r\n\t(各セクションの担当者と相談して決めることができます)</p>\r\n\r\n\t<ul class=\"smallNotice\">\r\n\t\t<li>週20時間未満<br />\r\n\t\t(例)営業時間9:30~17:30の場合 8:50~18:00の間で出勤できます。</li>\r\n\t</ul>\r\n\t</dd>\r\n\t<dt>待遇</dt>\r\n\t<dd>\r\n\t<p>制服一部貸与<br />\r\n\t交通費は電車・バスなどの公共機関利用で非課税限度額内での実費支給となります。<br />\r\n\t年2回の考課での時給アップあり<br />\r\n\t契約社員登用制度あり<br />\r\n\t多客時(GW、年末、年始）時給アップあり</p>\r\n\r\n\t<ul class=\"smallNotice\">\r\n\t\t<li>バイク、車通勤不可</li>\r\n\t</ul>\r\n\t</dd>\r\n\t<dt>応募</dt>\r\n\t<dd>\r\n\t<p>東武レジャー企画株式会社 (東武動物公園)<br />\r\n\t住所:埼玉県南埼玉郡宮代町須賀110<br />\r\n\t交通アクセス：東武スカイツリーライン<br />\r\n\t東武動物公園西口下車徒歩約10分<br />\r\n\t採用担当TEL：0480-93-1201<br />\r\n\tメールアドレス： <a class=\"email\" href=\"mailto:recruitment@tobuzoo.co.jp\">recruitment@tobuzoo.co.jp</a> (質問など）</p>\r\n\r\n\t<ul class=\"smallNotice\">\r\n\t\t<li>面接の予約は電話となっております。</li>\r\n\t</ul>\r\n\t</dd>\r\n</dl>\r\n</div>\r\n<!--\r\n<div class=\"boxWhite marginB40\">\r\n<h3 class=\"section_wrap__heading3\" id=\"recruit02\">看護師</h3>\r\n\r\n<dl class=\"dl_wrap01\">\r\n\t<dt>仕事内容</dt>\r\n\t<dd>\r\n\t<p>園内看護センターでの簡単な対応</p>\r\n\t</dd>\r\n\t<dt>時給</dt>\r\n\t<dd>\r\n\t<p>1,300円～</p>\r\n\r\n\t<ul class=\"smallNotice\">\r\n\t\t<li>研修期間は1,250円</li>\r\n\t</ul>\r\n\t</dd>\r\n\t<dt>応募資格</dt>\r\n\t<dd>\r\n\t<p>正看護師</p>\r\n\t</dd>\r\n\t<dt>勤務日</dt>\r\n\t<dd>\r\n\t<p>土日祝中心に週3日～週4日</p>\r\n\t</dd>\r\n\t<dt>勤務時間</dt>\r\n\t<dd>\r\n\t<p>営業時間中(夜間営業も含む)</p>\r\n\t</dd>\r\n\t<dt>待遇</dt>\r\n\t<dd>\r\n\t<p>交通費：非課税限度額内での実費支給<br />\r\n\t白衣貸与</p>\r\n\r\n\t<ul class=\"smallNotice\">\r\n\t\t<li