oter__nav-list\">\n                              \n                \n                \n                <li class=\"l-footer__nav-item\">\n                  <a href=\"https://www.hokutetsu.co.jp/recruit/event/\" class=\"item-link\"><span>イベント</span></a>\n                </li>\n                <li class=\"l-footer__nav-item\">\n                  <a href=\"https://www.hokutetsu.co.jp/news/news-category/recruit/\" class=\"item-link\"><span>お知らせ</span></a>\n                </li>\n              </ul>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n    <div class=\"l-footer__bottom\">\n      <div class=\"container\">\n        <small>Copyright HOKURIKU RAILROAD Co.,Ltd. All rights reserved.</small>\n      </div>\n    </div>\n  </div>\n</footer>  </div>\n\n</body>\n\n</html>","finalUrl":"https://www.hokutetsu.co.jp/recruit/bus-driver/job/","rendered":false,"_cachedAt":"2026-06-23T20:47:45.739Z"}