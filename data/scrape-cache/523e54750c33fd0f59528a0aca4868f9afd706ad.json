e-table-block-table>table tr td{background-color:#ffffff;}@media screen and (min-width:769px){.wp-block-flexible-table-block-table.is-scroll-on-pc{overflow-x:scroll;}.wp-block-flexible-table-block-table.is-scroll-on-pc table{max-width:none;align-self:self-start;}}@media screen and (max-width:768px){.wp-block-flexible-table-block-table.is-scroll-on-mobile{overflow-x:scroll;}.wp-block-flexible-table-block-table.is-scroll-on-mobile table{max-width:none;align-self:self-start;}.wp-block-flexible-table-block-table table.is-stacked-on-mobile th,.wp-block-flexible-table-block-table table.is-stacked-on-mobile td{width:100%!important;display:block;}}\n</style>\n<link rel='stylesheet' id='wpcf7-redirect-script-frontend-css' href='https://www.hokutetsu.co.jp/_wp/wp-content/plugins/wpcf7-redirect/build/assets/frontend-script.css?ver=a0c286e30e803dfa8dc4' type='text/css' media='all' />\n<link rel='stylesheet' id='wp-pagenavi-css' href='https://www.hokutetsu.co.jp/_wp/wp-content/plugins/wp-pagenavi/pagenavi-css.css?ver=2.70' type='text/css' media='all' />\n<link rel='stylesheet' id='cf7cf-style-css' href='https://www.hokutetsu.co.jp/_wp/wp-content/plugins/cf7-conditional-fields/style.css?ver=2.5.10' type='text/css' media='all' />\n<script type=\"text/javascript\" src=\"https://www.hokutetsu.co.jp/_wp/wp-includes/js/jquery/jquery.min.js?ver=3.7.1\" id=\"jquery-core-js\"></script>\n<script type=\"text/javascript\" src=\"https://www.hokutetsu.co.jp/_wp/wp-includes/js/jquery/jquery-migrate.min.js?ver=3.4.1\" id=\"jquery-migrate-js\"></script>\n<link rel=\"canonical\" href=\"https://www.hokutetsu.co.jp/recruit/bus-driver/job/\" />\n</head>\n<body class=\"template\">\n    <div class=\"wrapper\">\n    <header id=\"pageHeader\" class=\"l-header\">\n  <div class=\"l-header__inner\">\n    <h1 class=\"l-header__logo\">\n      <a href=\"https://www.hokutetsu.co.jp/recruit/\">\n        <img src=\"/assets/img/common/logo.png\" alt=\"北陸鉄道株式会社\">\n      </a>\n    </h1>\n\n    <nav class=\"l-header__gnav l-gnav\">\n      <div class=\"l-gnav__inner\">\n        <ul class=\"l-gnav__list\">\n          <li class=\"l-gnav__item\"><a href=\"https://www.hokutetsu.co.jp/news/news-category/recruit/\" class=\"l-gnav__link uni-btn\"><span class=\"link-text\">お知らせ</span><span class=\"arrow\"></span></a></li>\n          <li class=\"l-gnav__item\"><a href=\"https://www.hokutetsu.co.jp/recruit/bus-driver/\" class=\"l-gnav__link uni-btn\"><span class=\"link-text\">バス運転士採用</span><span class=\"arrow\"></span></a></li>\n          <li class=\"l-gnav__item\"><a href=\"https://www.hokutetsu.co.jp/recruit/general/\" class=\"l-gnav__link uni-btn\"><span class=\"link-text\">総合職採用</span><span class=\"arrow\"></span></a></li>\n          <li class=\"l-gnav__item\"><a href=\"https://www.hokutetsu.co.jp/recruit/event/\" class=\"l-gnav__link uni-btn\"><span class=\"link-text\">イベント</span><span class=\"arrow\"></span></a></li>\n        </ul>\n        <div class=\"l-gnav__btn\">\n          <a href=\"https://www.hokutetsu.co.jp\" target=\"_blank\" rel=\"noopener noreferrer\">コーポレートサイト</a>\n        </div>\n      </div>\n      <div id=\"js-focus-trap\" tabindex=\"0\"></div>\n    </nav>\n\n    <button type=\"button\" id=\"js-hamburger\" class=\"l-header__menu\" aria-controls=\"navigation\" aria-expanded=\"false\" aria-label=\"Menu\">\n      <span class=\"text\"></span>\n      <span class=\"line\"></span>\n    </button>\n  </div>\n  <div class=\"l-header__bg\"></div>\n</header>    <main id=\"pageRecruitBusDriverJob\" class=\"pageMain p-recruitJob\">\n      <section class=\"l-section p-recruit-subMainv03\">\n        <div class=\"l-container --uni-m\">\n          <div class=\"l-inner p-recruit-subMainv03__inner\">\n            <div class=\"p-recruit-subMainv03__heading\">\n              <h2 class=\"title\">募集要項</h2>\n            </div>\n            <div class=\"p-recruit-subMainv03__bg --bg01\"></div>\n          </div>\n        </div>\n      </section>\n\n      <div class=\"c-recruitTab__list --anchor\">\n        <a class=\"c-recruitTab__item\" href=\"#employee01\">正社員</a>\n        <a class=\"c-recruitTab__item\" href=\"#employee02\">契約社員</a>\n      </div>\n\n      <section id=\"employee01\" class=\"l-section l-recruitSection --white p-recruitJob-comp\">\n        <div class=\"l-container --uni-m\">\n          <div class=\"l-inner p-recruitJob-comp__inner\">\n            <div class=\"c-heading01\">\n              <h2 class=\"jp\">正社員　募集要項・応募</h2>\n            </div>\n            <div class=\"l-block wysiwyg p-recruitJob-comp__block\">\n              <table>\n                <tr>\n                  <th>\n                    <p>雇用形態</p>\n                  </th>\n                  <td>\n                    <p>正社員</p>\n                  </td>\n                </tr>\n                <tr>\n                  <th>\n                    <p>職種</p>\n                  </th>\n                  <td>\n                    <p>乗合バス運転士</p>\n                  </td>\n                </tr>\n                <tr>\n                  <th>\n                    <p>業務内容</p>\n                  </th>\n                  <td>\n                    <p>路線バス、高速乗合バス、貸切バスの運転業務</p>\n                  </td>\n                </tr>\n                <tr>\n                  <th>\n                    <p>応募資格</p>\n                  </th>\n                  <td>\n                    <ul>\n                      <li>学歴・経験不問。地域社会に貢献したいという思いをお持ちの方</li>\n                      <li>年齢：55歳くらいまでの方</li>\n                      <li>普通運転免許取得3年以上の方(AT限定可)</li>\n                      <!-- <li>過去に北陸鉄道グループバス会社の選考試験を受けていない方</li> -->\n                    </ul>\n                    <ul class=\"-asterisk\">\n                      <li>AT限定解除、大型二種免許取得費用補助制度あり（社内規定により支給）</li>\n                      <li>応募時は大型二種免許不要。大型二種免許をお持ちでない方は取得後に入社となります。</li>\n                    </ul>\n                  </td>\n                </tr>\n                <tr>\n                  <th>\n                    <p>研修制度</p>\n                  </th>\n                  <td>\n                    <p>個々の技術習熟度に合わせた研修を約2ヶ月実施。未経験の方もしっかりと学んでいただけます。</p>\n                  </td>\n                </tr>\n                <tr>\n                  <th>\n                    <p>勤務地</p>\n                  </th>\n                  <td>\n                    <ul>\n                      <li>北陸鉄道／金沢営業所(金沢市割出町)、南部支所(白山市安養寺町)、中央営業所(金沢市割出町)、北部営業所(金沢市柳橋町)<br /><br />グループ会社へのご紹介も可能です。</li>\n                      <li>北鉄白山バス／(白山市安養寺町)</li>\n                      <li>北鉄加賀バス／(小松市、加賀市)</li>\n                      <li>北鉄能登バス／(七尾市、羽咋市、志賀町、輪島市、珠洲市、能登町、穴水町)</li>\n                    </ul>\n                    <ul class=\"-asterisk\">\n                      <li>勤務地は、ご本人の居住地、営業所の欠員状況を考慮して決定します。</li>\n                    </ul>\n                  </td>\n                </tr>\n                <tr>\n                  <th>\n                    <p>給与</p>\n                  </th>\n                  <td>\n                    <p>給与会社規定による。<br>北陸鉄道 月収例269,000円～592,000円（時間外ほか各種手当含む。2025年実績）<br>固定給＋通勤手当、時間外手当、休日手当、深夜手当、精勤手当ほか</p>\n                    <ul class=\"-asterisk\">\n                      <li>詳細は採用担当者までお問い合わせください。</li>\n                    </ul>\n                  </td>\n                </tr>\n                <tr>\n                  <th>\n                    <p>就労時間</p>\n                  </th>\n                  <td>\n                    <p>シフト制　実働平均8時間以内</p>\n                  </td>\n                </tr>\n                <tr>\n                  <th>\n                    <p>休日・休暇</p>\n                  </th>\n                  <td>\n                    <p>4週8休<br>年次有給休暇（取得率90％以上、2025年実績）・結婚休暇、忌引休暇、出産休暇、育児休暇、介護休暇など（各社規定による）</p>\n                  </td>\n                </tr>\n                <tr>\n                  <th>\n                    <p>待遇</p>\n                  </th>\n                  <td>\n                    <p>社会保険完備、賞与（年2回）あり、財形貯蓄、退職金制度</p>\n                  </td>\n                </tr>\n                <tr>\n                  <th>\n                    <p>福利厚生</p>\n                  </th>\n                  <td>\n                    <p>福利厚生定期健康診断（年2回）、人間ドック、脳ドック、睡眠時無呼吸症候群スクリーニング、無事故表彰制度、社員寮、サークル活動（走友会、野球、バレーボール、フットサルなど）</p>\n                  </td>\n                </tr>\n                <tr>\n                  <th>\n                    <p>応募方法</p>\n                  </th>\n                  <td>\n                    <p>お問い合わせだけでもお気軽にご連絡ください。<br>応募の際は電話またはメールにてご連絡の上、履歴書(写真添付)を郵送またはご持参ください。</p>\n                  </td>\n                </tr>\n                <tr>\n                  <th>\n                    <p>見学会</p>\n                  </th>\n                  <td>\n                    <p>毎月行っております。詳細は<a href=\"https://www.hokutetsu.co.jp/recruit/bus-driver/opendays/\">こちら</a>をご覧ください。</p>\n                  </td>\n                </tr>\n                <tr>\n                  <th>\n                    <p>大型バス運転体験会</p>\n                  </th>\n                  <td>\n                    <p>2026年6月13日に実施いたします。<br />詳細は<a href=\"https://www.hokutetsu.co.jp/recruit/bus-driver/opendays/#tabpanel2\">こちら</a>をご覧ください。<!--次回の開催は決定次第ホームページにてお知らせいたします。--></p>\n                  </td>\n                </tr>\n                <tr>\n                  <th>\n                    <p>お問い合わせ先</p>\n                  </th>\n                  <td>\n                    <p>〒920-0031 石川県金沢市広岡3丁目1番1号 金沢パークビル1F<br>北陸鉄道株式会社<br>担当 人事部：福田、島田<br>TEL（076）204-9600（代）<br>Email：&#106;&#105;&#110;&#106;&#105;&#64;&#104;&#111;&#107;&#117;&#116;&#101;&#116;&#115;&#117;&#46;&#99;&#111;&#46;&#106;&#112;</p>\n                  </td>\n                </tr>\n                <!-- <tr>\n                  <td>\n                    <p>北陸鉄道チケットセンター</p>\n                    <p class=\"text-[14px]\">（金沢駅西口バスターミナル4番のりば近く）</p>\n                  </td>\n                  <td>\n                    <p>営業時間：7:00〜19:30</p>\n                    <p>TEL：076-263-0489</p>\n                  </td>\n                  <td>\n                    <div class=\"grid grid-cols-2 gap-3 px-9\">\n                      <div class=\"c-ticket\">おとな券</div><div class=\"c-ticket\">こども券</div>\n                    </div>\n                  </td>\n                </tr> -->\n              </table>\n            </div>\n          </div>\n        </div>\n      </section>\n\n      <section id=\"employee02\" class=\"l-section l-recruitSection --last p-recruitJob-comp\">\n        <div class=\"l-container --uni-m\">\n          <div class=\"l-inner p-recruitJob-comp__inner\">\n            <div class=\"c-heading01\">\n              <h2 class=\"jp\">契約社員　募集要項・応募</h2>\n            </div>\n            <div class=\"l-block wysiwyg p-recruitJob-comp__block\">\n              <table>\n                <tr>\n                  <th>\n                    <p>雇用形態</p>\n                  </th>\n                  <td>\n                    <p>契約社員</p>\n                  </td>\n                </tr>\n                <tr>\n                  <th>\n                    <p>職種</p>\n                  </th>\n                  <td>\n                    <p>小型コミュニティバス運転士・一般路線バス運転士</p>\n                  </td>\n                </tr>\n                <tr>\n                  <th>\n                    <p>業務内容</p>\n                  </th>\n                  <td>\n                    <p>コミュニティバス・一般路線バス運転士の運転業務</p>\n                  </td>\n                </tr>\n                <tr>\n                  <th>\n                    <p>応募資格</p>\n                  </th>\n                  <td>\n                    <ul>\n                      <li>学歴・経験不問。地域社会に貢献したいという思いをお持ちの方</li>\n                      <li>年齢：55歳くらいまでの方</li>\n                      <li>普通MT免許取得3年以上の方</li>\n                      <!-- <li>過去に北陸鉄道グループバス会社の選考試験を受けていない方</li> -->\n                    </ul>\n                    <ul class=\"-asterisk\">\n                      <li>大型二種免許取得費用補助制度あり（社内規定により支給）</li>\n                      <li>応募時は大型二種免許不要。大型二種免許をお持ちでない方は取得後に入社となります。</li>\n                    </ul>\n                  </td>\n                </tr>\n                <tr>\n                  <th>\n                    <p>研修制度</p>\n                  </th>\n                  <td>\n                    <p>接遇やルートなどについて約２週間研修をおこないます。</p>\n                  </td>\n                </tr>\n                <tr>\n                  <th>\n                    <p>勤務地</p>\n                  </th>\n                  <td>\n                    <ul>\n                      <li>北陸鉄道／　金沢営業所(金沢市割出町)、北部営業所（金沢市柳橋町）</li>\n                    </ul>\n                  </td>\n                </tr>\n                <tr>\n                  <th>\n                    <p>給与</p>\n                  </th>\n                  <td>\n                    <p>時給1,150円＋通勤手当、時間外手当、休日手当、深夜手当</p>\n                    <ul class=\"-asterisk\">\n                      <li>詳細は採用担当者までお問い合わせください。</li>\n                    </ul>\n                  </td>\n                </tr>\n                <tr>\n                  <th>\n                    <p>就労時間</p>\n                  </th>\n                  <td>\n                    <p>シフト制　実働平均8時間以内</p>\n                  </td>\n                </tr>\n                <tr>\n                  <th>\n                    <p>休日・休暇</p>\n                  </th>\n                  <td>\n                    <p>2勤2休<br>年次有給休暇（取得率90％以上、2025年実績）</p>\n                  </td>\n                </tr>\n                <tr>\n                  <th>\n                    <p>待遇</p>\n                  </th>\n                  <td>\n                    <p>社会保険完備、賞与（年2回）あり、正社員登用あり</p>\n                  </td>\n                </tr>\n                <tr>\n                  <th>\n                    <p>福利厚生</p>\n                  </th>\n                  <td>\n                    <p>福利厚生 定期健康診断（年2回）、人間ドック、脳ドック、睡眠時無呼吸症候群スクリーニング、社員寮、サークル活動（走友会、野球、バレーボール、フットサルなど）</p>\n                  </td>\n                </tr>\n                <tr>\n                  <th>\n                    <p>応募方法</p>\n                  </th>\n                  <td>\n                    <p>お問い合わせだけでもお気軽にご連絡ください。<br>応募の際は電話またはメールにてご連絡の上、履歴書(写真添付)を郵送またはご持参ください。</p>\n                  </td>\n                </tr>\n                <tr>\n                  <th>\n                    <p>見学会</p>\n                  </th>\n                  <td>\n                    <p>毎月行っております。詳細は<a href=\"https://www.hokutetsu.co.jp/recruit/bus-driver/opendays/\">こちら</a>をご覧ください。</p>\n                  </td>\n                </tr>\n                <tr>\n                  <th>\n                    <p>大型バス運転体験会</p>\n                  </th>\n                  <td>\n                    <p>詳細は<a href=\"https://www.hokutetsu.co.jp/recruit/bus-driver/opendays/#tabpanel2\">こちら</a>をご覧ください。<!--次回の開催は決定次第ホームページにてお知らせいたします。--></p>\n                  </td>\n                </tr>\n                <tr>\n                  <th>\n                    <p>お問い合わせ先</p>\n                  </th>\n                  <td>\n                    <p>〒920-0031 石川県金沢市広岡3丁目1番1号 金沢パークビル1F<br>北陸鉄道株式会社<br>TEL204-9600（代） 担当 人事部：福田、島田<br>Email：&#106;&#105;&#110;&#106;&#105;&#64;&#104;&#111;&#107;&#117;&#116;&#101;&#116;&#115;&#117;&#46;&#99;&#111;&#46;&#106;&#112;</p>\n                  </td>\n                </tr>\n              </table>\n            </div>\n          </div>\n        </div>\n      </section>\n\n      <section class=\"l-section p-recruitSection-bnr\">\n        <div class=\"l-container --uni-m\">\n          <div class=\"l-inner p-recruitSection-bnr__inner\">\n            <ul class=\"p-recruitSection-bnr__list\">\n              <!-- <li class=\"p-recruitSection-bnr__item\">\n                <div class=\"p-recruitSection-bnr__item-heading\">\n                  <div class=\"icon\">\n                    <figure><img src=\"/assets/img/common/icon_search.svg\" alt=\"\"></figure>\n                  </div>\n                  <h3 class=\"title\">お仕事を探したい方はこちら</h3>\n                </div>\n                <a href=\"https://www.hokutetsu.co.jp/recruit/bus-driver/job/\" class=\"p-recruitSection-