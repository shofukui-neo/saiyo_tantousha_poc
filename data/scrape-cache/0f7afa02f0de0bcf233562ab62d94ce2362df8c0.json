    <!-- /logo -->\n      <!-- global navi -->\n      <nav role=\"navigation\" class=\"gNav gNav-accordion drawer-nav\">\n        <ol class=\"clearfix drawer-menu\">\n          <li class=\"gNav__item gNav__item--normal gNav__item--message\">\n            <a href=\"message_index.html\" class=\"hoverNot\">\n              <span class=\"en\">MESSAGE</span>先輩メッセージ\n            </a>\n          </li>\n          <li class=\"gNav__item gNav__item--normal gNav__item--crosstalk\">\n            <a href=\"crosstalk.html\" class=\"hoverNot\">\n              <span class=\"en\">CROSSTALK</span>新人座談会\n            </a>\n          </li>\n          <li class=\"gNav__item gNav__item--normal gNav__item--work\">\n            <a href=\"work.html\" class=\"hoverNot\">\n              <span class=\"en\">WORK</span>今岡工業の仕事\n            </a>\n          </li>\n          <li class=\"gNav__item gNav__item--guide accordion close\">\n            <a href=\"guide_new_grad.html\" class=\"trigger hoverNot\">\n              <span class=\"en\">GUIDE</span>募集要項\n            </a>\n            <ul class=\"accordionMenu--mobile accordionMenu--pc\">\n              <li><a href=\"guide_new_grad.html\"><span>新卒の方</span></a></li>\n              <li><a href=\"guide_kisotsu_kentiku.html\"><span>既卒 建築技術</span></a></li>\n              <li><a href=\"guide_kisotsu_doboku.html\"><span>既卒 土木技術</span></a></li>\n              <li><a href=\"guide_kisotsu_eigyou.html\"><span>既卒 営業職</span></a></li>\n            </ul>\n          </li>\n          <li class=\"gNav__item gNav__item--normal gNav__item--faq\">\n            <a href=\"faq.html\" class=\"hoverNot\">\n              <span class=\"en\">FAQ</span>よくある質問\n            </a>\n          </li>\n          <li class=\"gNav__item gNav__item--normal gNav__item--entry\">\n            <a href=\"/recruite_form/index\" class=\"hoverNot\">\n              <span class=\"en\">ENTRY</span>エントリー\n            </a>\n          </li>\n          <li class=\"gNav__item gNav__item--close dn-pc\">\n            <a class=\"drawer-toggle\">\n              閉じる\n            </a>\n          </li>\n        </ol>\n      </nav>\n      <!-- /global navi -->\n      <!-- mobile menu -->\n      <div id=\"close\" class=\"headerArea__menuBtn dn-pc drawer-toggle\">\n        <span class=\"dn\">MENU</span>\n      </div>\n      <!-- /mobile menu -->\n    </div>\n  </header>\n  <!-- /header -->\n\n  <!-- main container -->\n  <main>\n    <div role=\"main\">\n      <!-- h1 -->\n      <h1 class=\"sub-category sub-category--massage\">\n        <span class=\"sub-category__inner\">\n          <span class=\"catNameEn\">MESSAGE</span>\n          <span class=\"catName\">先輩メッセージ</span>\n        </span>\n      </h1>\n      <!-- /h1 -->\n\n      <!-- breadcrumbs -->\n      <div class=\"sub-breadcrumbs dn-mobile\">\n        <ol class=\"l-container-sub clearfix\">\n          <li><a href=\"index.html\">トップページ</a></li>\n          <li><a href=\"message_index.html\">先輩メッセージ</a></li>\n          <li>安達 萌香</li>\n        </ol>\n      </div>\n      <!-- /breadcrumbs -->\n\n      <!-- l-container-sub -->\n      <div class=\"l-container-sub sub-container\">\n        <section>\n          <!-- h2 -->\n          <h2 class=\"mod-hl-01 mod-hl-01--catTag\">\n            <span class=\"icon-training icon\">&thinsp;</span>\n            安達 萌香\n            <span class=\"en\">Moeka Adachi</span>\n            <span class=\"small\">2020年に入社</span>\n            <span class=\"catTag\">総務</span>\n          </h2>\n          <!-- /h2 -->\n          <!-- articleBox-01 -->\n          <div class=\"column-articleBox-subLeft--w300 l-innerBox clearfix\">\n            <div class=\"mod-column-sub\">\n              <img src=\"img/massage/staff_2021_01_01.jpg?20210922\" alt=\"スタッフ写真\" class=\"imgFit\">\n            </div>\n            <div class=\"mod-column-main\">\n              <div class=\"mod-column-main__inner\">\n                <section>\n                  <h3 class=\"mod-hl-02\">\n                    <span class=\"icon\">Q</span>今岡工業に入社したきっかけは何ですか？\n                  </h3>\n                  <p>\n                    短大時代は建設業とは全く関係のない学部で学んでいましたが、いざ就職活動となった時に「本当に自分がやりたいのは何なのか」考える機会がありました。\n                    <br>\n                    そんな中で、一度幅広く企業を探してみようと足を運んだ合同企業説明会で、今岡工業と出会いました。\n                    <br>\n                    その説明会の中で今岡工業は「休日でも同僚同士で遊びにでかけたりするくらい仲がいい」と聞き、この会社の社風や福利厚生に興味を持ち、面接を受けました。\n                  </p>\n                </section>\n                <section class=\"marginTop30\">\n                  <h3 class=\"mod-hl-02\">\n                    <span class=\"icon\">Q</span>実際に入社してみていかがでしょうか？\n                  </h3>\n                  <p>\n                    社風や福利厚生は説明に聞いていたとおりで、定期的なレクリエーションなども開催されています。特に社員同士の仲がよいのは、本当に仕事がしやすいと感じています。部署を超えて社員同士の交流があり、お互いの距離感が近いので普段の仕事が円滑に進むのだと思います。\n                    <br><br>\n                    私はもともと建設業とは畑違いの学部を卒業したので、最初は自分に仕事がこなせるか心配もしましたが、先輩や上司に質問がしやすく、また丁寧に教えてくれるので安心して働くことができています。\n                    <br>\n                    入社前に不安だったビジネスマナーなども、会社が用意してくれたセミナーへ参加することで自信がつきました。\n                  </p>\n                </section>\n              </div>\n            </div>\n          </div>\n          <!-- /articleBox-01 -->\n          <!-- articleBox-02 -->\n          <div class=\"column-articleBox-subRight--w300 l-innerBox marginTop60 clearfix\">\n            <div class=\"mod-column-sub\">\n              <img src=\"img/massage/staff_2021_01_02.jpg?20210922\" alt=\"スタッフ写真\" class=\"imgFit\">\n            </div>\n            <div class=\"mod-column-main\">\n              <div class=\"mod-column-main__inner\">\n                <section>\n                  <h3 class=\"mod-hl-02\">\n                    <span class=\"icon\">Q</span>仕事のやりがいはなんですか？\n                  </h3>\n                  <p>\n                    幅広い総務の仕事ではありますが、会社や先輩の手厚い指導のおかげで、今では自分一人できることも増え、少しずつですが皆さんのお役に立てるようになってきたと思っています。\n                    <br>\n                    他の部署の方に何かを尋ねられたり資料を求められたようなときに、それを私自信が解決できるようになってきました。\n                    だんだんと自分が成長していく実感を感じることができのが、今はやりがいになっていると思います。\n                  </p>\n                </section>\n\n                <section class=\"marginTop30\">\n                  <h3 class=\"mod-hl-02\">\n                    <span class=\"icon\">Q</span>今後、目標にしていることがありますか？\n                  </h3>\n                  <p>\n                    受付や来客対応の業務を行うことが多いので、まずは皆様に名前と顔を覚えてもらえるようなスタッフになりたいと思っています。\n                    受付や来客対応の短い時間でも、責任感を大切にしてお客様に対して丁寧に仕事をこなしていきたいと思います。\n                    <br>\n                    また、いまは経理の勉強もしているので、いずれは建設業経理士の資格を取りたいと考えています。\n                    とても働きやすくて良い職場なので、早く一人前になって今以上に皆さんの役に立てるようになりたい、と思っています。\n                  </p>\n                </section>\n              </div>\n            </div>\n          </div>\n          <!-- /articleBox-02 -->\n          <!-- articleBox-03 -->\n          <!-- <div class=\"column-articleBox-subLeft--w300 l-innerBox marginTop60 clearfix\">\n            <div class=\"mod-column-sub\">\n              <img src=\"img/massage/pic_sample.jpg\" alt=\"スタッフ写真\" class=\"imgFit\">\n            </div>\n            <div class=\"mod-column-main\">\n              <div class=\"mod-column-main__inner\">\n                <section>\n                  <h3 class=\"mod-hl-02\">\n                    <span class=\"icon\">Q</span>プライベートは何をしていますか？\n                  </h3>\n                  <p>\n                    この文章はダミーです。文字の大きさ、量、字間、行間等を確認するために入れています。この文章はダミーです。文字の大きさ、量、字間、行間等を確認するために入れています。この文章はダミーです。文字の大きさ、量、字間、行間等を確認するために入れています。\n                    この文章はダミーです。文字の大きさ、量、字間、行間等を確認するために入れています。この文章はダミーです。文字の大きさ、量、字間、行間等を確認するために入れています。この文章はダミーです。文字の大きさ、量、字間、行間等を確認するために入れています。\n                  </p>\n                </section>\n              </div>\n            </div>\n          </div> -->\n          <!-- /articleBox-03 -->\n          <!-- btn -->\n          <div class=\"marginTop60 textCenter\">\n            <a href=\"message_index.html\" class=\"mod-btn-02 mod-btn-w300\">\n              <span class=\"icon-menu\">&thinsp;</span> 一覧に戻る\n            </a>\n          </div>\n          <!-- /btn -->\n        </section>\n      </div>\n      <!-- /l-container-sub -->\n    </div>\n  </main>\n  <!-- /main container -->\n\n  <!-- footer -->\n  <footer role=\"contentinfo\" class=\"mod-bg-cSub\">\n    <!-- footer -->\n    <div class=\"footer clearfix\">\n      <!-- main -->\n      <div class=\"footer__main\">\n        <a href=\"index.html\">\n          <img src=\"img/common/logo_footer_02.png\" alt=\"今岡工業株式会社\" class=\"imgFit footer__main__logo\">\n        </a>\n        <p class=\"footer__main__address\">\n          〒693-0024 島根県出雲市塩冶神前 2-8-16<br>\n          TEL <a href=\"tel:0853237778\">0853-23-7778</a> / FAX 0853-22-5959\n        </p>\n        <div class=\"footer__main__siteBtn\">\n          <a href=\"#\" class=\"hoverNot\"><span class=\"icon icon-arrow_right_02\">&thinsp;</span> 企業サイトへ</a>\n        </div>\n      </div>\n      <!-- /main -->\n      <!-- sub -->\n      <div class=\"footer__sub dn-mobile\">\n        <h6 class=\"footer__sub__hed\">MENU</h6>\n        <div class=\"clearfix footer__sub__menu\">\n          <ul>\n            <li><a href=\"index.html\" class=\"hoverNot\">トップページ</a></li>\n            <li><a href=\"message_index.html\" class=\"hoverNot\">先輩メッセージ</a></li>\n            <li><a href=\"crosstalk.html\" class=\"hoverNot\">新人座談会</a></li>\n          </ul>\n          <ul>\n            <li><a href=\"work.html\" class=\"hoverNot\">今岡工業の仕事</a></li>\n            <li><a href=\"guide_new_grad.html\" class=\"hoverNot\">募集要項</a></li>\n            <li><a href=\"faq.html\" class=\"hoverNot\">よくある質問</a></li>\n          </ul>\n          <ul>\n            <li><a href=\"/recruite_form/index\" class=\"hoverNot\">エントリーフォーム</a></li>\n          </ul>\n        </div>\n      </div>\n      <!-- /sub -->\n    </div>\n    <!-- /footer -->\n    <!-- copyright -->\n    <div class=\"mod-bg-cMain copyright\">\n      (C)Copyright 2019 imaokakogyo Corporation. All rights reserved.\n    </div>\n    <!-- /copyright -->\n  </footer>\n  <!-- /footer -->\n\n  <!-- pageTop -->\n  <div class=\"pageTop-box\">\n    <div id=\"pageTop\" class=\"pageTop\">\n      <img src=\"img/common/btn_pg_top.png\" alt=\"トップに戻る\" class=\"imgFit\">\n    </div>\n  </div>\n  <!-- /pageTop -->\n\n</body>\n\n</html>","finalUrl":"https://www.imaokakogyo.com/recruit/message_08.html","rendered":false,"_cachedAt":"2026-06-23T21:47:22.789Z"}