href=\"../recruit/\"><span>RECRUIT</span>採用情報</a> </div>\n              <ul class=\"menu_inner\">\n                <li><a href=\"../recruit/idea.html\">理念と風土</a></li>\n                <li><a href=\"../recruit/system.html\">人事制度</a></li>\n                <li><a href=\"../recruit/guidelines.html\">募集要項</a></li>\n\t\t\t\t<li><a href=\"https://www.secom.co.jp/recruit/portal/wellbeing/\" target=\"_blank\" class=\"ex\">働きやすさの推進</a></li>\n              </ul>\n            </div>\n          </div>\n        </li>\n        <li><a href=\"../corporate/\">会社案内</a>\n          <div class=\"menu\">\n            <div class=\"menu_wrap\">\n              <div class=\"menu_title\"> <a href=\".../corporate/\"><span>COMPANY</span>会社案内</a> </div>\n              <ul class=\"menu_inner\">\n                <li><a href=\"../corporate/history.html\">沿革</a></li>\n                <li><a href=\"../corporate/about.html\">会社概要</a></li>\n                <li><a href=\"../corporate/group.html\">支社・営業所</a></li>\n                <li><a href=\"../corporate/jastic.html\">セコムジャスティック山梨</a></li>\n              </ul>\n            </div>\n          </div>\n        </li>\n        <li><a href=\"../contact/\">お問い合わせ</a></li>\n      </ul>\n    </nav>\n  </div>\n</header>\r\n<div class=\"contents\">\r\n  <section id=\"main-head\" class=\"recruit\">\r\n    <div class=\"breadcrumb\">\r\n      <ul>\r\n        <li><a href=\"../\">ホーム</a></li>\r\n        <li><a href=\"./\">採用情報</a></li>\r\n        <li>エントリーフォーム</li>\r\n      </ul>\r\n    </div>\r\n    <div class=\"inner\">\r\n      <div class=\"title\"> <img src=\"./images/recruit_i.png\" alt=\"採用情報\" width=\"60\">\r\n        <p>RECRUIT</p>\r\n        <h1>採用情報</h1>\r\n      </div>\r\n    </div>\r\n  </section>\r\n  <section class=\"main-title\">\r\n    <h2>エントリーフォーム</h2>\r\n  </section>\r\n  <section id=\"main\" class=\"inner\">\r\n    <h3>エントリーしていただいた皆様には、今後の採用情報を案内させて頂きます。</h3>\r\n    <div class=\"formMes\">\r\n    <p class=\"message\">下記の入力フォームに必要事項をご記入の上、「入力内容を確認する」ボタンを押してください。</p>\r\n    <div class=\"sticker\"> \r\n      <a href=\"../sticker/sticker.html\" target=\"_blank\"><img src=\"../sticker/sticker.gif\" width=\"56\" height=\"88\" alt=\"クリックして証明書の内容をご確認ください。\"></a>\r\n    </div>\r\n    </div>\r\n    <form action=\"/cgi-bin/form-mail_recruit.cgi\" method=\"post\" id=\"form1\" class=\"h-adr\">\r\n      <span class=\"p-country-name\" style=\"display:none;\">Japan</span>\r\n      <table class=\"formTable\">\r\n        <tr class=\"mt20\">\r\n          <th><div class=\"relative\">エントリー対象<span>必須</span></div></th>\r\n          <td><select name=\"エントリー対象\" id=\"forentry\" class=\"long validate[required]\" data-prompt-position=\"bottomLeft\">\r\n\t\t\t<option value=\"\">▼選択してください</option>\r\n\t\t\t<option value=\"セコム山梨株式会社　キャリア採用\">セコム山梨株式会社　キャリア採用</option>\r\n\t\t\t<!--option value=\"セコム山梨株式会社　勤務地限定社員採用\">セコム山梨株式会社　勤務地限定社員採用</option-->\r\n\t\t\t<option value=\"セコムジャスティック山梨株式会社　キャリア採用\">セコムジャスティック山梨株式会社　キャリア採用</option>\r\n\t\t\t</select></td>\r\n        </tr>\r\n        <tr class=\"mt20\">\r\n          <th><div class=\"relative\">お名前<span>必須</span></div></th>\r\n          <td><input type=\"text\" id=\"user_name\" name=\"お名前\" class=\"validate[required]\" data-prompt-position=\"bottomLeft\">\r\n            <span>例：セコム　太郎</span></td>\r\n        </tr>\r\n        <tr class=\"mt20\">\r\n          <th><div class=\"relative\">ふりがな<span>必須</span></div></th>\r\n          <td><input type=\"text\" id=\"user_name_kana\" name=\"ふりがな\" class=\"validate[required]\" data-prompt-position=\"bottomLeft\">\r\n            <span>例：せこむ　たろう</span></td>\r\n        </tr>\r\n        <tr>\r\n          <th> 性別&nbsp;</th>\r\n          <td>&nbsp;\r\n            <input type=\"radio\" name=\"性別\" value=\"男\" id=\"man\" checked>\r\n            ：\r\n            <label for=\"man\">男</label>\r\n            &nbsp;&nbsp;&nbsp;&nbsp;\r\n            &nbsp;\r\n            <input type=\"radio\" name=\"性別\" value=\"女\" id=\"wman\">\r\n            ：\r\n            <label for=\"wman\">女</label></td>\r\n        </tr>\r\n        <tr>\r\n          <th><div class=\"relative\">メールアドレス<span>必須</span></div></th>\r\n          <td><input type=\"text\" name=\"メールアドレス\" id=\"email01\" class=\"long validate[required,custom[email]]\" data-prompt-position=\"bottomLeft\">\r\n            <span>例：aaa@aa.com</span></td>\r\n        </tr>\r\n        <tr>\r\n          <th><div class=\"relative\">生年月日<span>必須</span></div></th>\r\n          <td>\r\n          西暦\r\n        \t<input name=\"生年月日-年\" size=\"5\" maxlength=\"5\" style=\"ime-mode: disabled;\" type=\"text\" class=\"validate[required] disp-inline\" data-prompt-position=\"bottomLeft\">\r\n            年\r\n     \t <select name=\"生年月日-月\" class=\"validate[required]\" data-prompt-position=\"bottomLeft\">\r\n\t\t\t\t<OPTION value='1月'>1月<OPTION value='2月'>2月<OPTION value='3月'>3月<OPTION value='4月'>4月<OPTION value='5月'>5月<OPTION value='6月'>6月<OPTION value='7月'>7月<OPTION value='8月'>8月<OPTION value='9月'>9月<OPTION value='10月'>10月<OPTION value='11月'>11月<OPTION value='12月'>12月\r\n\t</SELECT>\r\n\t<SELECT name=\"生年月日-日\" class=\"validate[required]\" data-prompt-position=\"bottomLeft\">\r\n\t\t<OPTION value='1日'>1日<OPTION value='2日'>2日<OPTION value='3日'>3日<OPTION value='4日'>4日<OPTION value='5日'>5日<OPTION value='6日'>6日<OPTION value='7日'>7日<OPTION value='8日'>8日<OPTION value='9日'>9日<OPTION value='10日'>10日<OPTION value='11日'>11日<OPTION value='12日'>12日<OPTION value='13日'>13日<OPTION value='14日'>14日<OPTION value='15日'>15日<OPTION value='16日'>16日<OPTION value='17日'>17日<OPTION value='18日'>18日<OPTION value='19日'>19日<OPTION value='20日'>20日<OPTION value='21日'>21日<OPTION value='22日'>22日<OPTION value='23日'>23日<OPTION value='24日'>24日<OPTION value='25日'>25日<OPTION value='26日'>26日<OPTION value='27日'>27日<OPTION value='28日'>28日<OPTION value='29日'>29日<OPTION value='30日'>30日<OPTION value='31日'>31日\r\n\t</SELECT>\r\n          </td>\r\n        </tr>\r\n        <tr>\r\n          <th><div class=\"relative\">住所　<span>必須</span></div></th>\r\n