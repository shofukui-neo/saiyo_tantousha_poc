     <figure>\n                    <img src=\"assets/img/interview/01.jpg\" alt=\"\" />\n                  </figure>\n                </div>\n                <div class=\"text\">\n                  設計本部　船体設計部<br />\n                  船殻設計グループ<br />\n                </div>\n              </li>\n              <li>\n                <div class=\"image\">\n                  <figure>\n                    <img src=\"assets/img/interview/img_3.jpg\" alt=\"\" />\n                  </figure>\n                </div>\n                <div class=\"text\">\n                  総務・人事部<br />\n                  総務グループ<br />\n                </div>\n              </li>\n              <li>\n                <div class=\"image\">\n                  <figure>\n                    <img src=\"assets/img/interview/img_4.jpg\" alt=\"\" />\n                  </figure>\n                </div>\n                <div class=\"text\">\n                  営業本部　業務室<br />\n                  常石業務グループ<br />\n                </div>\n              </li>\n              <li>\n                <div class=\"image\">\n                  <figure>\n                    <img src=\"assets/img/interview/img_5_matsui.jpg\" alt=\"\" />\n                  </figure>\n                </div>\n                <div class=\"text\">\n                  調達本部　購買部<br />\n                  購買グループ<br />\n                </div>\n              </li>\n              <li>\n                <div class=\"image\">\n                  <figure>\n                    <img src=\"assets/img/interview/img_6_iruma.jpg\" alt=\"\" />\n                  </figure>\n                </div>\n                <div class=\"text\">\n                  経営管理本部<br />\n                  情報戦略室<br />\n                </div>\n              </li>\n              <li>\n                <div class=\"image\">\n                  <figure>\n                    <img\n                      src=\"assets/img/interview/img_7_sekiguchi.jpg\"\n                      alt=\"\"\n              