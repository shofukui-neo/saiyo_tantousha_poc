{"url":"https://recruit.eidaikako.co.jp/recruitment/","html":"<!DOCTYPE html>\n<html lang=\"ja\" prefix=\"og: http://ogp.me/ns# website: http://ogp.me/ns/website#\">\n<head>\n<meta charset=\"utf-8\">\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n<meta name=\"viewport\" content=\"width=device-width,user-scalable=no,initial-scale=1.0,maximum-scale=1.0\">\n\n<meta name='robots' content='index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1' />\n\n\t<!-- This site is optimized with the Yoast SEO plugin v24.3 - https://yoast.com/wordpress/plugins/seo/ -->\n\t<title>募集要項 - 永大化工の採用サイト</title>\n\t<link rel=\"canonical\" href=\"https://recruit.eidaikako.co.jp/recruitment/\" />\n\t<meta property=\"og:locale\" content=\"ja_JP\" />\n\t<meta property=\"og:type\" content=\"article\" />\n\t<meta property=\"og:title\" content=\"募集要項 - 永大化工の採用サイト\" />\n\t<meta property=\"og:url\" content=\"https://recruit.eidaikako.co.jp/recruitment/\" />\n\t<meta property=\"og:site_name\" content=\"永大化工の採用サイト\" />\n\t<meta property=\"article:modified_time\" content=\"2024-11-13T07:49:12+00:00\" />\n\t<meta property=\"og:image\" content=\"https://recruit.eidaikako.co.jp/wp/wp-content/uploads/2025/01/ogp.png\" />\n\t<meta property=\"og:image:width\" content=\"1200\" />\n\t<meta property=\"og:image:height\" content=\"630\" />\n\t<meta property=\"og:image:type\" content=\"image/png\" />\n\t<meta name=\"twitter:card\" content=\"summary_large_image\" />\n\t<script type=\"application/ld+json\" class=\"yoast-schema-graph\">{\"@context\":\"https://schema.org\",\"@graph\":[{\"@type\":\"WebPage\",\"@id\":\"https://recruit.eidaikako.co.jp/recruitment/\",\"url\":\"https://recruit.eidaikako.co.jp/recruitment/\",\"name\":\"募集要項 - 永大化工の採用サイト\",\"isPartOf\":{\"@id\":\"https://recruit.eidaikako.co.jp/#website\"},\"datePublished\":\"2024-10-03T10:03:31+00:00\",\"dateModified\":\"2024-11-13T07:49:12+00:00\",\"breadcrumb\":{\"@id\":\"https://recruit.eidaikako.co.jp/recruitment/#brea