msapplication-TileImage\" content=\"https://recruit.eidaikako.co.jp/wp/wp-content/uploads/2024/10/cropped-f81fd2e4c52864042852c112ce927ae2-270x270.jpg\" />\n\n<!-- Google tag (gtag.js) -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-L98W2C381W\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'G-L98W2C381W');\n</script>\n<!-- Google Search Console -->\n<meta name=\"google-site-verification\" content=\"06lff13z0ocRoyEktoF1WtuSYkeotbrZ82FfIFCsLpc\" />\n\n\n\n</head>\n<body>\n\t\n\t<div id=\"recruitment\" class=\"wrapper sub\">\n\t<div id=\"all-wrapper\"  >\n\t<div class=\"modal-slide\"></div>\n\t\t<header id = \"header\" >\n\t\t\t<div class=\"container\">\n\t\t\t\t<div class=\"flex flex-box\">\n\t\t\t\t\t<div class=\"left\">\n            <h1 id = \"logo\"><a href=\"https://recruit.eidaikako.co.jp/\"><img src=\"https://recruit.eidaikako.co.jp/wp/wp-content/themes/template/assets/images/common/header-logo.svg\" alt=\"コーポレートサイトロゴ\"></a></h1>\n          </div>\n          <div class=\"right\">\n            <div id=\"modalbtn\" class=\"modalbtn\"></div>\n              <nav class=\"modal\" id = \"modal\" >\n              \t\n            <ul class=\"flex\" >\n              <li class=\"nav-list\"><a href=\"https://recruit.eidaikako.co.jp/about/\">会社を知る</a></li>\n              <li class=\"nav-list\"><a href=\"https://recruit.eidaikako.co.jp/service/\">仕事を知る</a></li>\n              <li class=\"nav-list hover-nav\">\n                <a href=\"https://recruit.eidaikako.co.jp/balance/\" class=\"click\">働き方を知る</a>\n                <ul class=\"in-nav\">\n                  <li class=\"nav-list sp\"><a href=\"https://recruit.eidaikako.co.jp/balance/\">働き方を知る</a></li>\n                  <li class=\"nav-list\"><a href=\"https://recruit.eidaikako.co.jp/interview/\">インタビュー</a></li>\n                  <li class=\"nav-list\"><a href=\"https://recruit.eidaikako.co.jp/recruitment/\">募集要項</a></li>\n                </ul>\n              </li>\n              <li class=\"nav-list\"><a href=\"https://recruit.eidaikako.co.jp/news/\">お知らせ</a></li>\n              <li class=\"nav-list\"><a href=\"https://recruit.eidaikako.co.jp/entry/\">エントリー</a></li>\n              <li class=\"nav-list\"><a href=\"https://www.eidaikako.co.jp/\" target=\"_blank\">コーポレートサイト</a></li>\n            </ul>\n                        </nav>\n          </div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</header>\n\t\t<div class=\"page-wrapper\">\n\t\t\t<main>\n\n\n\n<div class=\"modal-inner-slide\"></div>\n<div class=\"title-box\">\n  <div class=\"container p-btm0\">\n    <h2 class=\"title\">\n      <div class=\"en lightblue-tx f-size40 m-btm30 light-tx\">Recruitment</div>\n      <span class=\"\">募集要項</span>\n    </h2>\n  </div>\n</div>\n\n<div class=\"contents-box\">\n  <div class=\"container\">\n    <main>\n      <div class=\"entry-content\">\n        <section id=\"sec08\" class=\"guidline-area\">\n          <div class=\"container fadeUpTrigger fadeUp\">\n            <div class=\"sectitle-box flex f_jc-between f_wrap f_ai-center\">\n              <h3 class=\"blue f-size35\">募集職種</h3>\n            </div>\n            <div class=\"post-guideline\">\n                                <div class=\"box\">\n                        <div class=\"accordion\">\n                            <dl>\n                                <dt class=\"question\">新卒採用</dt>\n                                <dd class=\"answer\">\n                                    <ul>\n                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            <li>応募方法\n                                              <p>2027年新卒採用情報<br />\r\n各ナビサイトにて、インターンシップ＆キャリアへの参加を受付中<br />\r\n<br />\r\n■マイナビ<br />\r\n<a href=\"https://job.mynavi.jp/27/pc/search/corp215054/outline.html\" target=\"_blank\">こちらをクリック</a><br />\r\n<br />\r\n■リクナビ<br />\r\n<a href=\"https://arwrk.net/recruit/eidaikako\" target=\"_blank\">こちらをクリック</a><br />\r\n<br />\r\n</p>\n                                            </li>\n                                                                            </ul>\n                                </dd>\n                            </dl>\n                        </div>\n                    </div>\n                                        <div class=\"box\">\n                        <div class=\"accordion\">\n                            <dl>\n                                <dt class=\"question\">情報システム　就業場所：大阪本社</dt>\n                                <dd class=\"answer\">\n                                    <ul>\n                                                                                    <li>仕事内容\n                                              <p>・社内パソコン設置設定、メンテナンス<br />\r\n・社内ネットワーク管理<br />\r\n・基幹システム（ＩＢＭｉ）開発メンテ外部委託管理<br />\r\n・社内ネットワーク管理　など</p>\n                                            </li>\n                                                                                                                                                                                                                                                    <li>求める人材\n                                              <p>◆必須条件<br />\r\n・60歳以下<br />\r\n・普通自動車運転免許（AT限定可）<br />\r\n</p>\n                                            </li>\n                                                                                                                            <li>給与\n                                              <p>月給　250,000円　～　340,000円<br />\r\n年収　400万円　～　550万円 <br />\r\n<br />\r\n※別途通勤手当支給（上限150,000円/月）<br />\r\n<br />\r\n◇ 賞与：年2回（直近実績4カ月）<br />\r\n◇ 昇給：年1回</p>\n                                            </li>\n                                                                                                                            <li>勤務時間\n                                              <p>08:30～17:20<br />\r\n実働時間：8時間/日（休憩50分）<br />\r\n時間外労働時間昨年平均：6時間以下</p>\n                                            </li>\n                                                                                                                            <li>勤務地\n                                              <p>大阪府大阪市平野区平野北2丁目3-9</p>\n                                            </li>\n                                                                                                                            <li>休日休暇\n                                              <p>週休2日制<br />\r\n土日は基本的にお休み、一部会社カレンダーによる<br />\r\n<br />\r\n・年間休日118日（2026年４月より、年間休日120日）<br />\r\n・有給休暇は入社日から付与（有給取得数平均15.6日）<br />\r\n・長期休暇（GW、夏期休暇、年末年始）あり<br />\r\n・その他、忌引、結婚、ヘルスケア休暇など<br />\r\n・男女産休・育休の利用実績あり</p>\n                                            </li>\n                                                                                                                            <li>待遇\n                                              <p>・社会保険完備（健康、厚生、雇用、労災）<br />\r\n・退職金制度あり（勤続１年以上）<br />\r\n・従業員持株会（奨励金あり）<br />\r\n・会員制リゾートホテル<br />\r\n・車両紹介販売助成制度<br />\r\n・家電優待販売<br />\r\n・旅行優待割引</p>\n                                            </li>\n                                                                                                                                                                                                                                                    <li>応募方法\n                                              <p>１．エントリーフォームからご連絡下さい。<br />\r\n　（こちらより３営業日以内にご連絡いたします