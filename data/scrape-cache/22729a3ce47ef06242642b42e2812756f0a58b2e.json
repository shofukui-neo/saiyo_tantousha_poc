{"url":"https://www.ichirokudo.com/company/","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n  <head>\n    <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n    <meta charset=\"utf-8\">\n    <title>会社案内 | 一六堂</title>\n    <meta name=\"description\" content=\"天地旬鮮「八吉」、「のど黒屋」など、東京、名古屋、横浜のビジネス街、ターミナル駅を中心に多様な飲食店を展開。一六堂の想い、各店舗のご紹介、採用情報など。\">\n    <meta name=\"keywords\" content=\"一六堂,ICHIROKUDO,レストラン,ダイニング,天地旬鮮八吉,のど黒屋,日本橋老舗屋,銀座酒房六角,鶏料理鳥彩,SL酒場,八吉酒場,博多もつ鍋黒・仙台牛たん荒,和食ダイニング銀の月,ナウファンテン,東京カルビ,だいにんぐばー零,otanto,東京ビアレストラン\"><!-- og -->｡\n    <meta property=\"og:locale\" content=\"ja_JP\">\n    <meta property=\"og:type\" content=\"website\">\n    <meta property=\"og:image\" content=\"https://www.ichirokudo.com/ogp.png\">\n    <meta property=\"og:title\" content=“株式会社一六堂”>\n    <meta property=\"og:url\" content=\"https://www.ichirokudo.com/\">\n    <meta property=\"og:description\" content=\"天地旬鮮「八吉」、「のど黒屋」など、東京、名古屋、横浜のビジネス街、ターミナル駅を中心に多様な飲食店を展開。一六堂の想い、各店舗のご紹介、採用情報など。\"><!-- //og -->\n    <!--[if lt IE 9]>\n    <script src=\"https://html5shiv.googlecode.com/svn/trunk/html5.js\"></script><![endif]--> \n    <link rel=\"stylesheet\" href=\"/assets/css/common.css\">\n  </head>\n  <body data-rsssl=1>\n\n  \n<div class=\"container\"><!--header-->\n      <header id=\"header\">\n        <h1 class=\"siteTitle\"><a href=\"/\"><img src=\"/assets/img/common/logo.png\" alt=\"株式会社 一六堂\"></a></h1><img src=\"/assets/img/common/ico_jpx.png\" alt=\"JPX 東証上場\" class=\"jpx\">\n        <ul class=\"headerNavi\">\n          <li><a href=\"/form\"><img src=\"/assets/img/common/btn_headerContactOff.png\" alt=\"お問い合わせ\"></a></li>\n          <li>\n            <button id=\"shopListOpen\" type=\"button\" name=\"brandlistOpen\" value=\"店舗ブランド\">店舗ブランド</button>\n          </li>\n        </ul>\n        <noscript>\n          <p>店舗リストが表示されない場合は<a href=\"#brandList\">こちら</a></p>\n        </noscript>\n        <nav>\n          <ul id=\"gNavi\" class=\"clearfix\">\n            <li id=\"gNavi00\"><a href=\"/mind\">一六堂の想い</a>\n            </li>\n            <li id=\"gNavi01\"><a href=\"/shop\">店舗情報</a>\n            </li>\n            <li id=\"gNavi02\"><a href=\"/company\" class=\"selected\">会社案内</a>\n            </li>\n            <li id=\"gNavi03\"><a href=\"/recruit\">採用情報</a>\n            </li>\n            <li id=\"gNavi04\"><a href=\"/ir/irlibrary\">株主の皆様へ</a>\n            </li>\n            <li id=\"gNavi05\"><a href=\"/news\">ニュース</a>\n            </li>\n          </ul>\n        </nav>\n      </header>\n    </div>\n    <div id=\"headerBrandList\">\n      <div class=\"inner container\">\n        <button id=\"headerClose\" type=\"button\" name=\"brandlistClose\" value=\"閉じる\"><img src=\"/assets/img/common/ico_close.png\" alt=\"閉じる\"></button>\n        <h2 class=\"leftLineTitle cosMt40\"><img src=\"/assets/img/home/ttl_brand.png\" alt=\"店舗ブランド\"></h2>\n        <ul class=\"clearfix cosMb20\">\n          <li><a href=\"/shop/yakichi\"><img src=\"/assets/img/home/img_brand01.png\" alt=\"八吉\" class=\"borderGray\"><span>天地旬鮮 八吉</span></a></li>\n          <li><a href=\"/shop/nodoguroya\"><img src=\"/assets/img/home/img_brand02.png\" alt=\"のど黒屋\" class=\"borderGray\"><span>のど黒屋</span></a></li>\n          <li><a href=\"/shop/rokkaku\"><img src=\"/assets/img/home/img_brand05.png\" alt=\"六角\" class=\"borderGray\"><span>銀座酒房 六角</span></a></li>\n          <li><a href=\"/shop/torisai\"><img src=\"/assets/img/home/img_brand07.png\" alt=\"鳥彩\" class=\"borderGray\"><span>鳥彩</span></a></li>\n          <li><a href=\"/shop/slsakaba\"><img src=\"/assets/img/home/img_brand08.png\" alt=\"SL酒場\" class=\"borderGray\"><span>SL酒場</span></a></li>\n          <li><a href=\"/shop/yakichisakaba\"><img src=\"/assets/img/home/img_brand09.png\" alt=\"八吉酒場\" class=\"borderGray\"><span>八吉酒場</span></a></li>\n          <li><a href=\"/shop/ara\"><img src=\"/assets/img/home/img_brand11.png\" alt=\"仙台 牛たん 荒\" class=\"borderGray\"><span>仙台 牛たん 荒</span></a></li>\n          <li><a href=\"/shop/ginnotsuki\"><img src=\"/assets/img/home/img_brand12.png\" alt=\"和食ダイニング 銀の月\" class=\"borderGray\"><span>和食ダイニング 銀の月</span></a></li>\n          <li><a href=\"/shop/tokyokarubi\"><img src=\"/assets/img/home/img_brand15.png\" alt=\"東京カルビ\" class=\"borderGray\"><span>東京カルビ</span></a></li>\n          <li><a href=\"/shop/zero\"><img src=\"/assets/img/home/img_brand16.png\" alt=\"だいにんぐばー 零\" class=\"borderGray\"><span>だいにんぐばー 零</span></a></li>\n          <li><a href=\"/shop/otant\"><img src=\"/assets/img/home/img_brand17.png\" alt=\"料理人・W- otanto\" class=\"borderGray\"><span>otanto</span></a></li>\n        </ul><a href=\"/shop\"><img src=\"/assets/img/common/btn_viewShopDetailOff.png\" alt=\"店舗情報を見る\" class=\"boxCenter cosMb40\"></a>\n      </div>\n      <div class=\"container textRight\">\n        <button id=\"bottomClose\" type=\"button\" name=\"brandlistClose\" value=\"閉じる\"><img src=\"/assets/img/common/btn_shopBrandClose.png\" alt=\"閉じる\"></button>\n      </div><!--/header-->\n    </div>\n\n    <div class=\"container company\">\n      <h2 class=\"cosMt30 cosMb20\"><img src=\"/assets/img/lower/company/ttl_company.jpg\" alt=\"会社案内\"></h2>\n      <div class=\"breadcrumb\"><a href=\"/\" class=\"permeable\"><img src=\"/assets/img/lower/common/ico_home.png\" alt=\"ホーム\"></a><span>会社案内</span></div><img src=\"/assets/img/lower/company/txt_main.png\" alt=\"一六堂は東京、名古屋、横浜のビジネス街、ターミナル駅を中心に18業態、全79店舗（2016年6月現在）の多様な飲食店を展開しています。 ビジネスマンのみなさんにとって、「安らぎの場」「明日への活力の場」となるようサービスを提供します。\" class=\"boxCenter cosMb40\">\n      <ul class=\"listInline textCenter cosMb60\">\n        <li><a href=\"#company__about\" class=\"permeable\"><img src=\"/assets/img/lower/company/btn_about.png\" alt=\"会社概要\"></a></li>\n        <li><a href=\"#company__greeting\" class=\"permeable\"><img src=\"/assets/img/lower/company/btn_greeting.png\" alt=\"代表挨拶\"></a></li>\n        <li><a href=\"#company__outline\" class=\"permeable\"><img src=\"/assets/img/lower/company/btn_outline.png\" alt=\"主な沿革\"></a></li>\n        <li><a href=\"/assets/img/lower/company/ichirokudo.pdf?v=2023\" class=\"permeable\"><img src=\"/assets/img/lower/company/btn_company.png\" alt=\"会社案内\"></a></li>\n\n      </ul>\n      <section id=\"company__about\" class=\"cosMb60\">\n        <h3 class=\"leftLineTitle\"><img src=\"/assets/img/lower/company/ttl_about.png\" alt=\"会社概要\"></h3>\n        <table class=\"dottedLineTable\">\n          <tr>\n            <th>会社名</th>\n            <td>株式会社 一六堂</td>\n          </tr>\n          <tr>\n            <th>代表取締役</th>\n            <td>柚原　洋一</td>\n          </tr>\n          <tr>\n            <th>本社所在地</th>\n <td>〒103-0028　東京都中央区八重洲1-6-1 TOFROM YAESU TOWER 9F<br>TEL:03(3510)6116(代）/FAX:03(3510)6117</td>\n          </tr>\n          <tr>\n            <th>設立</th>\n            <td>平成7年1月27日</td>\n          </tr>\n          <tr>\n            <th>資本金</th>\n            <td>50,000千円</td>\n          </tr>\n          <tr>\n            <th>事業内容</th>\n            <td>飲食店の経営</td>\n          </tr>\n          <tr>\n            <th>店舗展開</th>\n            <td>天地旬鮮 八吉、のど黒屋、他業態</td>\n          </tr>\n          <tr>\n            <th>決算</th>\n            <td>2月末日</td>\n          </tr>\n          <tr>\n        </table>\n      </section>\n      <section id=\"company__greeting\">\n        <h3 class=\"leftLineTitle cosMb40\"><img src=\"/assets/img/lower/company/ttl_greeting.png\" alt=\"代表挨拶\"></h3><img src=\"/assets/img/lower/company/txt_greeting.png\" alt=\"『やりあげる』『やりつづける』『あきらめない』 その精神を礎に、日々の業務に取り組み続けます。\" class=\"cosMb40\">\n        <div class=\"company__ceoGreeting cosMb40\"><img src=\"/assets/img/lower/company/img_ceo.jpg\" alt=\"代表写真\">\n          <div class=\"company__ceoGreeting__inner\">\n            <h4><img src=\"/assets/img/lower/company/txt_ceo.png\" alt=\"柚原 洋一/代表取締役 社長\"></h4>\n            <p>当社は、資源の無いこの国で唯一の資源ともいえる「勤労・勤勉」によって経済大国にした企業戦士、ビジネスマンのためにお役に立てる会社でありたいと願い、ビジネス街、ターミナル駅周辺を中心に店舗開発し「安らぎの場、明日への活力の場」を提供いたします。<br>今後も島根、山口、新潟、宮城12漁港の買参権、大田青果市場、築地市場、名古屋北部市場の売買参加権の保持により得られる食の「安全」「安心」「真実」をお客様に提供し続ける事により社会に貢献してまいります。</p>\n          </div>\n        </div>\n      </section>\n      <section id=\"company__outline\">\n        <h3 class=\"leftLineTitle\"><img src=\"/assets/img/lower/company/ttl_outline.png\" alt=\"主な沿革\"></h3>\n        <ul class=\"lineList\">\n          <li><dl><dt>平成7年1月</dt><dd>資本金1,000万円で設立。</dd></dl></li>\n          <li><dl><dt>平成13年8月</dt><dd>東京都中央区八重洲の自社ビルに移転。</dd></dl></li>\n          <li><dl><dt>平成15年11月</dt><dd>新潟県にて、２つの漁港及び１つの市場にて買参権を法人格で取得。</dd></dl></li>\n          <li><dl><dt>平成15年12月</dt><dd>新潟県糸魚川市に新潟営業所を開設。</dd></dl></li>\n          <li><dl><dt>平成16年9月</dt><dd>新潟県浦本漁港の買参権取得。</dd></dl></li>\n          <li><dl><dt>平成16年9月</dt><dd>島根県浜田漁港の準買参権を取得。</dd></dl></li>\n          <li><dl><dt>平成16年9月</dt><dd>島根県浜田市に浜田営業所を開設。</dd></dl></li>\n          <li><dl><dt>平成17年4月</dt><dd>名古屋証券取引所セントレックスに株式を上場。</dd></dl></li>\n          <li><dl><dt>平成18年4月</dt><dd>浜田漁港を含む島根県の各漁港が「漁業協同組合　JFしまね」として統合されたことに伴い、島根県の各漁港（７漁港）の買参権を新たに取得。</dd></dl></li>\n          <li><dl><dt>平成18年9月</dt><dd>株式会社エムアイフードシステム他２社を完全子会社化。都内の19店舗の立地を確保。</dd></dl></li>\n          <li><dl><dt>平成18年9月</dt><dd>株式会社柚屋を設立（当社100％完全子会社）。青果物等の一括仕入を開始。</dd></dl></li>\n          <li><dl><dt>平成18年12月</dt><dd>株式会社柚屋にて東京都中央卸売市場大田市場における売買参加権を取得。</dd></dl></li>\n          <li><dl><dt>平成20年3月</dt><dd>株式会社デイ・マックス他１社を完全子会社化。東京都内を中心に17店舗の立地を確保。</dd></dl></li>\n          <li><dl><dt>平成20年8月</dt><dd>宮城県塩釜漁港において、魚類の買い付けを開始。</dd></dl></li>\n          <li><dl><dt>平成22年4月</dt><dd>宮城県塩釜市魚市場の買参権取得。</dd></dl></li>\n          <li><dl><dt>平成23年12月</dt><dd>東京証券取引所 市場第二部に株式を上場。</dd></dl></li>\n          <li><dl><dt>平成24年12月</dt><dd>東京証券取引所　市場第一部銘柄に指定。</dd></dl></li>\n          <li><dl><dt>平成25年11月</dt><dd>山口県仙崎漁港の買参権を取得。</dd></dl></li>\n          <li><dl><dt>平成31年3月19日</dt><dd>当社代表取締役　柚原洋一が議決権を100％所有する資産管理会社である㈱八越による公開買付け（MBO）成立後の株式併合により、株式会社東京証券取引所市場一部における上場廃止。</dd></dl></li>\n        </ul>\n      </section>\n    </div>\n\n      <div id=\"pageTop\" class=\"container cosMt60\"><a href=\"#header\"><img src=\"/assets/img/common/btn_pagetop.png\" alt=\"このページの上部へ\"></a></div><!--footer-->\n    <footer id=\"footer\">\n      <div class=\"container\">\n        <nav>\n          <ul id=\"footerNavi\">\n            <li><a href=\"/privacy\">プライバシーポリシー</a></li>\n            <li><a href=\"/company\">会社案内</a></li>\n            <li><a href=\"/form\">お問い合わせ</a></li>\n          </ul>\n        </nav>\n\n<div style=\"float:right;\">\n<!-- DigiCert Seal HTML -->\n<!-- Place HTML on your site where the seal should appear -->\n<div id=\"DigiCertClickID_FrPb6Ixw\"></div>\n<!-- DigiCert Seal Code -->\n<!-- Place with DigiCert Seal HTML or with other scripts -->\n<script type=\"text/javascript\">\n\tvar __dcid = __dcid || [];\n\t__dcid.push({\"cid\":\"DigiCertClickID_FrPb6Ixw\",\"tag\":\"FrPb6Ixw\"});\n\t(function(){var cid=document.createElement(\"script\");cid.async=true;cid.src=\"//seal.digicert.com/seals/cascade/seal.min.js\";var s = document.getElementsByTagName(\"script\");var ls = s[(s.length - 1)];ls.parentNode.insertBefore(cid, ls.nextSibling);}());\n</script>\n</div>\n\n\t  <small class=\"copyright\" style=\"clear:both;\">Copyright&copy; ICHIROKUDO CO.,LTD All Rights Reserved.</small>\n      </div>\n    </footer><!--/footer-->\n    <script src=\"/assets/js/import.js\"></script>\n                    <script type=\"speculationrules\">\n{\"prefetch\":[{\"source\":\"document\",\"where\":{\"and\":[{\"href_matches\":\"\\/*\"},{\"not\":{\"href_matches\":[\"\\/wp-*.php\",\"\\/wp-admin\\/*\",\"\\/wp-content\\/uploads\\/*\",\"\\/wp-content\\/*\",\"\\/wp-content\\/plugins\\/*\",\"\\/wp-content\\/themes\\/original_pc\\/*\",\"\\/*\\\\?(.+)\"]}},{\"not\":{\"selector_matches\":\"a[rel~=\\\"nofollow\\\"]\"}},{\"not\":{\"selector_matches\":\".no-prefetch, .no-prefetch a\"}}]},\"eagerness\":\"conservative\"}]}\n</script>\n  </body>\n</html>","finalUrl":"https://www.ichirokudo.com/company","rendered":false,"_cachedAt":"2026-06-14T19:24:23.968Z"}