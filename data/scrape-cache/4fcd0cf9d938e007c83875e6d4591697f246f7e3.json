san\">生産オペレーター（印刷・仕上）</h3>\r\n                    <table class=\"career_td\">\r\n                        <tr>\r\n                            <th>募集職種</th>\r\n                            <td>生産オペレーター（印刷・仕上）</td>\r\n                        </tr>\r\n                        <tr>\r\n                            <th>仕事内容 </th>\r\n                            <td>デジタル化された最新鋭の印刷機械・加工機械を操作し、ポスター、チラシ、パンフレット、クオカード等の商業印刷物を作成します。</td>\r\n                        </tr>\r\n                        <tr>\r\n                            <th>応募資格</th>\r\n                            <td>責任感を持ち、周囲と協同しながら主体的に行動できる方</td>\r\n                        </tr>\r\n                        <tr>\r\n                            <th>勤務地</th>\r\n                            <td>\r\n                                羽田東京工場　東京都大田区昭和島1-2-1<br>\r\n                                大阪支店　大阪府大阪市中央区久太郎町1-9-2<br>\r\n                            </td>\r\n                        </tr>\r\n                        <tr>\r\n                            <th>給与</th>\r\n                            <td>年齢・経験・能力を考慮し、当社規定により優遇いたします。</td>\r\n                        </tr>\r\n                        <tr>\r\n                            <th>昇給</th>\r\n                            <td>年1回(8月)</td>\r\n                        </tr>\r\n                        <tr>\r\n                            <th>賞与</th>\r\n                            <td>年2回(7月・12月) </td>\r\n                        </tr>\r\n                        <tr>\r\n                            <th>勤務時間</th>\r\n                            <td>9:00～17:45 （実働7時間45分）<br>\r\n                                ※担当する業務により夜勤がある場合があります。<br>\r\n                            </td>\r\n                        </tr>\r\n                        <tr>\r\n                            <th>休日・休暇</th>\r\n                            <td>★週休２日<br>\r\n                                年間休日：112日　※当社休日カレンダー有り<br>\r\n                                祝日、夏季休暇、年末年始休暇、慶弔休暇、有給休暇</td>\r\n                        </tr>\r\n                        <tr>\r\n                            <th>福利厚生</th>\r\n                            <td>各種社会保険完備、財形貯蓄制度</td>\r\n                        </tr>\r\n                        <tr>\r\n                            <th>選考方法</th>\r\n                            <td>書類選考、面接（1回～2回）、適性検査</td>\r\n                        </tr>\r\n                        <tr>\r\n                            <th>エントリー</th>\r\n                            <td><a href=\"entry.html\" style=\"text-decoration: underline\">こちらのエントリーフォーム</a>からご応募をお願い致します。</td>\r\n                        </tr>\r\n                        <tr>\r\n                            <th>問い合わせ先</th>\r\n                            <td>〒104-0045<br>\r\n                                新日本印刷株式会社 東京支社<br>\r\n                                東京都中央区築地2丁目1番16号<br>\r\n                                TEL:03-3543-6000（代）<br>\r\n                                <a href=\"mailto:recruit@snp.co.jp\">recruit@snp.co.jp</a>\r\n                            </td>\r\n                        </tr>\r\n                        <!--\r\n                        <tr>\r\n                            <th>掲載日</th>\r\n                            <td>2019/4/18</td>\r\n                        </tr>\r\n                        -->\r\n                    </table>\r\n                </section>\r\n\r\n\r\n            </div>\r\n\r\n        </div>\r\n\r\n\r\n\r\n        <!--フッター-->\r\n        <footer class=\"PC Tab\">\n    <div id=\"footer-nav_gray\">\n\n        <nav id=\"footer-nav_box\">\n            <div class=\"footer-nav_box_min\">\n                <div class=\"footer-nav\">\n                    <p>SNPについて</p>\n                    <ul class=\"footer-section-list\">\n                        <li><a href=\"/company/about.html\" target=\"_top\">&#62; SNPについて</a></li>\n                        <li><a href=\"/company/profile.html\" target=\"_top\">&#62; 会社概要・沿革</a></li>\n                        <li><a href=\"/company/philosophy.html\" target=\"_top\">&#62; 企業理念</a></li>\n  