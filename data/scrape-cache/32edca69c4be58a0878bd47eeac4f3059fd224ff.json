{"url":"https://toyota-unitedshizuoka.co.jp/recruit/se/scholarship/","html":"<!doctype html>\n<html lang=\"ja\">\n<head>\n    <!-- Google Tag Manager -->\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\n    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\n    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n    })(window,document,'script','dataLayer','GTM-NZ5M5CC');</script>\n    <!-- End Google Tag Manager -->\n<meta charset=\"utf-8\">\n<meta name=\"format-detection\" content=\"telephone=no\">\n<meta name=\"description\" content=\"トヨタユナイテッド静岡は、「あなたの夢」への挑戦を応援します。企業奨学金とはエンジニア（自動車整備士）を目指す学生の学費を支援、応援させて頂く精度です。\">\n<meta name=\"keywords\" content=\"\">\n<title>未来のエンジニアを応援します。企業奨学金のご案内｜トヨタユナイテッド静岡</title>\n<meta property=\"og:image\" content=\"https://toyota-unitedshizuoka.co.jp/recruit/se/scholarship/ogp.jpg\">\n<meta property=\"og:url\" content=\"https://toyota-unitedshizuoka.co.jp/recruit/se/scholarship/\">\n<meta property=\"og:title\" content=\"未来のエンジニアを応援します。企業奨学金のご案内｜トヨタユナイテッド静岡\">\n<meta property=\"og:description\" content=\"トヨタユナイテッド静岡は、「あなたの夢」への挑戦を応援します。企業奨学金とはエンジニア（自動車整備士）を目指す学生の学費を支援、応援させて頂く精度です。\">\n<meta property=\"og:site_name\" content=\"未来のエンジニアを応援します。企業奨学金のご案内｜トヨタユナイテッド静岡\">\n<meta name=\"twitter:title\" content=\"未来のエンジニアを応援します。企業奨学金のご案内｜トヨタユナイテッド静岡\">\n<meta name=\"twitter:description\" content=\"トヨタユナイテッド静岡は、「あなたの夢」への挑戦を応援します。企業奨学金とはエンジニア（自動車整備士）を目指す学生の学費を支援、応援させて頂く精度です。\">\n<meta name=\"twitter:image\" content=\"https://toyota-unitedshizuoka.co.jp/recruit/se/scholarship/ogp.jpg\">\n<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n<link href=\"https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@100..900&display=swap\" rel=\"stylesheet\">\n<link href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css\" rel=\"stylesheet\">\n<link rel=\"stylesheet\" type=\"text/css\" href=\"css/style.css?v2.2\">\n<link rel=\"stylesheet\" type=\"text/css\" href=\"css/common.css\">\n<link rel=\"stylesheet\" type=\"text/css\" href=\"css/index.css?v2.3\">\n<script src=\"js/head.js\"></script>\n</head>\n<body>\n    <!-- Google Tag Manager (noscript) -->\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-NZ5M5CC\"\n    height=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n    <!-- End Google Tag Manager (noscript) -->\n<div id=\"container\">\n    <header id=\"gHeader\">\n        <h1><img class=\"pc\" src=\"img/index/main_img.gif\" alt=\"トヨタユナイテッド静岡\"><img class=\"sp\" src=\"img/index/main_img_sp.gif\" alt=\"トヨタユナイテッド静岡\"></h1>\n    </header>\n    <main id=\"main\">\n        <section class=\"topBox fadeLeft\">\n            <div class=\"content\">\n                <h2>トヨタユナイテッド静岡<span class=\"sml\">は、<br class=\"sp\"></span>『あなたの夢』<span class=\"sml\">への</span>挑戦<span class=\"sml\">を</span>応援します。</h2>\n            </div>\n            <div class=\"inner\">\n                <div class=\"movieBox\"><iframe width=\"560\" height=\"315\" src=\"https://www.youtube.com/embed/QE69TBJ7jLs?si=wlFOOa7nPZHc7B7A&amp;controls=0\" title=\"YouTube video player\" frameborder=\"0\" allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share\" referrerpolicy=\"strict-origin-when-cross-origin\" allowfullscreen></iframe></div>\n            </div>\n        </section>\n        <div class=\"overview comBgBox fadeRight\">\n            <div class=\"content\">\n                <div class=\"innerBox\">\n                    <h3>企業奨学金の概要</h3>\n                    <div class=\"imgBox flexB\">\n                        <div class=\"photoBox\"><img src=\"img/index/overview_photo01.jpg\" alt=\"企業奨学金の概要\"></div>\n                        <div class=\"textBox\">\n                            <p class=\"text\">企業奨学金とは、<br>エンジニア（自動車整備士）を目指す学生の<br>学費を支援・応援させていただく制度です。</p>\n                            <div class=\"img\"><img class=\"pc\" src=\"img/index/overview_img01.png\" alt=\"企業 自動車整備専門学生\"><img class=\"sp\" src=\"img/index/overview_img01_sp.png\" alt=\"企業 自動車整備専門学生\"></div>\n                        </div>\n                    </div>\n                </div>\n                <div class=\"subImg\"><img class=\"pc\" src=\"img/index/overview_img02.png\" alt=\"トヨタユナイテッド静岡より総額100万円（入学時一括）を貸与 返済420,000円(7,000円 × 60ヶ月) 勤続5年経過による残金返済免除580,000円 貸与条件 ： 高校在学時の平均評価点が2.5以上の方 その他の補助について 日本学生支援機構奨学金の返済補助制度 ・ 編入希望者に対する奨学金貸与制度がございます。\"><img class=\"sp\" src=\"img/index/overview_img02_sp.png\" alt=\"トヨタユナイテッド静岡より総額100万円（入学時一括）を貸与 返済420,000円(7,000円 × 60ヶ月) 勤続5年経過による残金返済免除580,000円 貸与条件 ： 高校在学時の平均評価点が2.5以上の方 その他の補助について 日本学生支援機構奨学金の返済補助制度 ・ 編入希望者に対する奨学金貸与制度がございます。\"></div>\n            </div>\n        </div>\n        <div class=\"flow comBgBox fadeLeft\">\n            <div class=\"content\">\n                <div class=\"innerBox\">\n                    <h3>お手続きの流れ</h3>\n                    <div class=\"photo\"><img class=\"pc\" src=\"img/index/flow_photo01.png\" alt=\"お手続きの流れ 〜7月 個別会社説明会参加 8月 応募書類提出 → 書類審査 9月 企業奨学生認定試験（面接含む） 10月 奨学金貸与の決定 10月～11月 自動車整備専門校へ願書提出 → 受験 → 合格 12月～1月　契約書類 提出 → 合格確定後 2〜3月 ご指定の口座へお振込み\"><img class=\"sp\" src=\"img/index/flow_photo01_sp.png\" alt=\"お手続きの流れ 〜7月 個別会社説明会参加 8月 応募書類提出 → 書類審査 9月 企業奨学生認定試験（面接含む） 10月 奨学金貸与の決定 10月～11月 自動車整備専門校へ願書提出 → 受験 → 合格 12月～1月　契約書類 提出 → 合格確定後 2〜3月 ご指定の口座へお振込み\"></div>\n                    <h4><span>当社奨学金提携の専門学校</span></h4>\n                    <div class=\"textBox\">\n                        <ul class=\"textList flex\">\n                            <li>静岡工科自動車大学校</li>\n                            <li>浜松工科自動車大学校</li>\n                            <li>トヨタ名古屋自動車大学校</li>\n                            <li>トヨタ東京自動車大学校</li>\n                            <li>中央メカニック自動車大学校</li>\n                            <li>東海工科自動車大学校</li>\n                            <li>愛知工科大学自動車短期大学</li>\n                            <li>高山自動車短期大学</li>\n                            <li>中日本自動車短期大学</li>\n                        </ul>\n                        <p class=\"notes\">※順不同</p>\n                    </div>\n                </div>\n            </div>\n        </div>\n        <div class=\"system comBgBox fadeRight\">\n            <div class=\"content\">\n                <div class=\"innerBox\">\n                    <p class=\"title\"><span class=\"red\">さらに<i>！</i></span><span class=\"txt\">提携の専門学校<br>成績優秀者には</span><br class=\"sp\"><span class=\"blue\">返済減額制度</span>有り</p>\n                    <div class=\"photo\"><img class=\"pc\" src=\"img/index/system_photo01.png\" alt=\"専門学校卒業時の平均評価点優秀者 4.5以上 入社より2年間返済免除  4.0以上 入社より2年間返済免除 入社より1年間返済免除\"><img class=\"sp\" src=\"img/index/system_photo01_sp.png\" alt=\"専門学校卒業時の平均評価点優秀者 4.5以上 入社より2年間返済免除  4.0以上 入社より2年間返済免除 入社より1年間返済免除\"></div>\n                    <div class=\"img\"><img class=\"pc\" src=\"img/index/system_photo02.png\" alt=\"返済イメージ　貸与金額 ： 1,000,000円 ／ 返済月額 ： 7,000円\"><img class=\"sp\" src=\"img/index/system_photo02_sp.png\" alt=\"返済イメージ　貸与金額 ： 1,000,000円 ／ 返済月額 ： 7,000円\"></div>\n                </div>\n            </div>\n        </div>\n        <div class=\"company fadeLeft\">\n            <div class=\"content\">\n                <ul class=\"companyList flex\">\n                    <li><img src=\"img/index/company_photo01.jpg\" alt=\"輝く先輩たちが、エンジニアの仕事のやりがいをご紹介！\"></li>\n                    <li><img src=\"img/index/company_photo02.jpg\" alt=\"お客様からのありがとう\"></li>\n                    <li><img src=\"img/index/company_photo03.jpg\" alt=\"仲間やお客様からの信頼\"></li>\n                    <li><img class=\"pc\" src=\"img/index/company_photo04.jpg\" alt=\"日々成長\"><img class=\"sp\" src=\"img/index/company_photo04_sp.jpg\" alt=\"日々成長\"></li>\n                    <li><img src=\"img/index/company_photo05.jpg\" alt=\"難しい故障修理の達成感/故障診断\"></li>\n                    <li><a href=\"https://toyota-unitedshizuoka.co.jp/recruit/se/real/\" target=\"_blank\"><img src=\"img/index/company_photo06.jpg\" alt=\"私のやりがいはこちらへ!\"></a></li>\n                </ul>\n            </div>\n        </div>\n        <section class=\"place fadeRight\">\n            <div class=\"content\">\n                <h3>エンジニアが『活躍する場』は<br class=\"sp\">お店だけではありません！</h3>\n                <div class=\"photo\"><img class=\"pc\" src=\"img/index/place_photo01.png\" alt=\"当社が参戦する「ヤリスカップ」のサポート エンジニアとしてレースに参加可能 凄腕の職人たちが活躍中 アナタも凄腕を目指しませんか？ 自社鈑金工場完備\"><img class=\"sp\" src=\"img/index/place_photo01_sp.png\" alt=\"当社が参戦する「ヤリスカップ」のサポート エンジニアとしてレースに参加可能 凄腕の職人たちが活躍中 アナタも凄腕を目指しませんか？ 自社鈑金工場完備\"></div>\n            </div>\n        </section>\n        <section class=\"contactBox\" id=\"contact\">\n            <h3>企業奨学金制度お問い合わせフォーム</h3>\n                        <div class=\"mailForm\">\n\t\t\t    <form method=\"post\" action=\"#contact\" id=\"bform\">\n                <p>ささいなご不明点や資料請求のみでも構いません。<br>まずはフォームよりご相談ください。ご入力情報は、企業奨学金資料の送付に利用させていただきます。</p>\n                    <input type=\"hidden\" name=\"action\" value=\"action\">\n                                        <input type='hidden' name='recaptcha-response' id='google_recaptcha'>\n                                        <table>\n                        <tr>\n                            <th>お名前</th>\n                            <td><p><input type=\"text\" name=\"parm[name]\" value=\"\" placeholder=\"お名前を入力してください\"></p><span class=\"error_msg\"></span></td>\n                        </tr>\n                        <tr>\n                            <th>お名前<br class=\"pc\">力タ力ナ</th>\n                            <td><p><input type=\"text\" name=\"parm[kana]\" value=\"\" placeholder=\"力タ力ナで入力してください\" class=\"error\"></p><span class=\"error_msg\"></span></td>\n                        </tr>\n                        <tr>\n                            <th>学年</th>\n                            <td>\n                                <p class=\"wid01\">\n                                    <select name=\"parm[year]\">\n                                        <option value=\"1年生\">1年生</option>\n                                        <option value=\"2年生\">2年生</option>\n                                        <option value=\"3年生\">3年生</option>\n                                    </select>\n                                </p>\n                            </td>\n                        </tr>\n                        <tr>\n                            <th>メ一ルアドレス</th>\n                            <td><p><input type=\"email\" name=\"parm[input_main_em]\" value=\"\" placeholder=\"半角英数字で入力してください\" class=\"halfangle\"></p><span class=\"error_msg\"></span></td>\n                        </tr>\n                        <tr>\n                            <th>郵便番号</th>\n                            <td>\n                                <div class=\"add\">\n                                    <p class=\"wid01\"><input type=\"text\" name=\"parm[zip]\" value=\"\" maxlength=\"8\" placeholder=\"0000000\" onkeyup=\"AjaxZip3.zip2addr('parm[zip]','','parm[area]','parm[address]');\" class=\"halfangle\"></p>\n                                    <span>郵便番号を入力すると<br>住所が自動で表示されます。</span>\n                                </div>\n                                <span class=\"error_msg\"></span>\n                            </td>\n                        </tr>\n                        <tr>\n                            <th>都道府県</th>\n                            <td><p><input type=\"text\" name=\"parm[area]\" value=\"\" placeholder=\"都道府県\"></p><span class=\"error_msg\"></span></td>\n                        </tr>\n                        <tr>\n                            <th>市区町村</th>\n                            <td><p><input type=\"text\" name=\"parm[address]\" value=\"\" placeholder=\"市区町村\"></p><span class=\"error_msg\"></span></td>\n                        </tr>\n                        <tr>\n                            <th>番地</th>\n                            <td><p><input type=\"text\" name=\"parm[town]\" value=\"\" placeholder=\"番地\"></p><span class=\"error_msg\"></span></td>\n                        </tr>\n                        <tr>\n                            <th>以下の住所</th>\n                            <td><p><input type=\"text\" name=\"parm[room]\" value=\"\" placeholder=\"建物名·部屋番号など\"></p><span class=\"error_msg\"></span></td>\n                        </tr>\n                        <tr>\n                            <th>お問い合わせ内容</th>\n                            <td>\n                                <p><textarea name=\"parm[content]\" placeholder=\"お問い合わせ内容\"></textarea></p>\n                                <span class=\"error_msg\"></span>\n                            </td>\n                        </tr>\n                        <tr class=\"tr02\">\n                            <th></th>\n                            <td>\n                                <ul class=\"agreeText hopeBox\">\n                                    <li>\n                                        <label><input type=\"checkbox\" name=\"parm[hope]\" value=\"資料の送付を希望します\" ><span class=\"mark\">資料の送付を希望します</span></label>\n                                        <span class=\"error_msg\"></span>\n                                    </li>\n                                </ul>\n                            </td>\n                        </tr>\n                        <tr class=\"tr01\">\n                            <th>個人情報の<br class=\"pc\">取り扱いについて</th>\n                            <td>ご入力いただいた個人情報は、お問い合わせへの対応および当社からのご連絡のために利用させていただきます。詳細は下記の「個人情報の取り扱いについて」をご確認ください。<br><a href=\"https://toyota-unitedshizuoka.co.jp/company/privacy/\" target=\"_blank\">個人情報の取り扱いについてはこちら</a></td>\n                        </tr>\n                    </table>\n                    <ul class=\"agreeText\">\n                        <li>\n                            <label><input type=\"checkbox\" name=\"parm[agree]\" value=\"agree\" ><span class=\"mark\">個人情報の取り扱いについて同意します</span></label>\n                            <span class=\"error_msg\"></span>\n                        </li>\n                    </ul>\n                    <ul class=\"submit\">\n                        <li><input type=\"submit\" name=\"__submit__\" value=\"内容を確認\"></li>\n                    </ul>\n                </form>\n            </div>\n\t\t\t        </section>\n    </main>\n    <footer id=\"gFooter\" class=\"fadeLeft\">\n        <div class=\"contact\">\n            <p class=\"title\">詳しくは個別説明会も実施いたします</p>\n            <div class=\"content\">\n                <div class=\"innerBox flexB\">\n                    <div class=\"lBox\"><img src=\"img/common/contact_img01.png\" alt=\"お問い合わせはコチラトヨタユナイテッド静岡株式会社人事部　企業奨学金制度担当まで\" class=\"pc\"><img src=\"img/common/contact_img01_sp.png\" alt=\"お問い合わせはコチラトヨタユナイテッド静岡株式会社人事部　企業奨学金制度担当まで\" class=\"sp\"></div>\n                    <div class=\"tel\"><a href=\"tel:0542618642\"><img src=\"img/common/contact_img02.png\" alt=\"TEL054-261-8642\"></a></div>\n                </div>\n                <div class=\"top\"><a href=\"https://toyota-unitedshizuoka.co.jp/recruit/se/\" target=\"_blank\">TOP</a></div>\n            </div>\n        </div>\n        <div class=\"fBox\">\n            <div class=\"content\">\n                <div class=\"logo\"><a href=\"./\"><img src=\"img/common/f_logo.png\" alt=\"トヨタユナイテッド静岡\"></a></div>\n                <div class=\"naviBox flexB\">\n                    <ul class=\"fNavi flex pc\">\n                        <li><a href=\"https://toyota-unitedshizuoka.co.jp/\" target=\"_blank\">コーポレートサイト</a></li>\n                        <li><a href=\"https://toyota-unitedshizuoka.co.jp/recruit/\" target=\"_blank\">リクルートサイト</a></li>\n                    </ul>\n                    <address>&copy; TOYOTA UNITED SHIZUOKA</address>\n                </div>\n            </div>\n        </div>\n    </footer>\n</div>\n\n\n<div class=\"fixbtn\"><span>＼説明会や個別相談も受付中！／</span><a href=\"#contact\"><span>お問い合わせ</span></a></div>\n<script src=\"js/jquery.min.js\"></script> \n<script src=\"js/common.js\"></script>\n<script src=\"https://ajaxzip3.github.io/ajaxzip3.js\" charset=\"UTF-8\"></script>\n<script>\n$(function(){\n    $(\"#edit\").click(function(){\n        $(\"#action\").val('edit');\n        $('#confirmForm').submit();\n    });\n    $(\"#submitform\").click(function(){\n        $(\"#action\").val('submit');\n        $('#confirmForm').submit();\n    });\n\n    let isinputing = false;\n    \n    $('.halfangle').on('compositionstart',function(){\n        isinputing = true;\n    });\n    $('.halfangle').on('compositionend',function(){\n        isinputing = false;\n        let text = toHalfWidth($(this).val());\n        $(this).val(text);\n    });\n\n    $('.halfangle').on('input',function(){\n        if(!isinputing){\n            let text = toHalfWidth($(this).val());\n            $(this).val(text);\n        }\n    });\n});\nfunction toHalfWidth(str) {\n    return str.replace(/[\\u3000\\uFF01-\\uFF5E]/g, function(match) {\n        if (match === \"\\u3000\") return \" \";\n        return String.fromCharCode(match.charCodeAt(0) - 0xFEE0);\n    });\n}\n</script>\n<script src=\"https://www.google.com/recaptcha/api.js?render=6Ld-64QrAAAAAGpJCYagaXuahYupmPcMlw3h2pWL\"></script>\n<script>\n$('#google_recaptcha').val('');\ngrecaptcha.ready(function() {\n    document.getElementById('bform').addEventListener(\"submit\", function(event) {\n        event.preventDefault();\n        grecaptcha.execute('6Ld-64QrAAAAAGpJCYagaXuahYupmPcMlw3h2pWL', {action: 'inquiry'}).then(function(token) {\n            document.getElementById(\"google_recaptcha\").value = token; \n            document.getElementById('bform').submit();\n        });        \n    }, false);\n});\n\n\n$(function () {\n  var $fixbtn = $('.fixbtn');\n  var $footer = $('#contact'); // footer要素（#footerなどの場合は適宜変更）\n\n  function toggleFixbtn() {\n    if (!$footer.length || !$fixbtn.length) return;\n\n    var footerTop = $footer.offset().top;\n    var scrollTop = $(window).scrollTop();\n    var winH = $(window).height();\n\n    // 画面下端がfooterの上端に到達（= footerが見え始める）したら隠す\n    if (scrollTop + winH >= footerTop) {\n      $fixbtn.addClass('hidden');\n    } else {\n      $fixbtn.removeClass('hidden');\n    }\n  }\n\n  // 初期表示 + スクロール/リサイズで判定\n  toggleFixbtn();\n  $(window).on('scroll resize', toggleFixbtn);\n});\n</script>\n</body>\n</html>","finalUrl":"https://toyota-unitedshizuoka.co.jp/recruit/se/scholarship/","rendered":false,"_cachedAt":"2026-06-23T22:48:48.072Z"}