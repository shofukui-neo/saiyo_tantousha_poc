oll.min.js\"></script>\n    <script src=\"/js/aos.js\"></script>\n    <script src=\"/js/swiper.min.js\"></script>\n    <link href=\"/css/swiper.css\" rel=\"stylesheet\">\n    <link href=\"/css/layout.css\" rel=\"stylesheet\">\n    <link href=\"/css/aos.css\" rel=\"stylesheet\">\n    <link href=\"/css/adjust.css?v=20250401\" rel=\"stylesheet\">\n\n</head>\n\n<body>\n\n    <!-- Google Tag Manager (noscript) -->\n    <noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-N9XS5L\"\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n    <!-- End Google Tag Manager (noscript) -->\n    <header id=\"header\">\n    <div class=\"sitelogo\">\n        <a href=\"/\">\n            <img src=\"/img/common/sitelogo.webp\" alt=\"エブリ株式会社\">\n        </a>\n    </div>\n    <nav class=\"mainmenu\">\n        <ul>\n            <!--li><a href=\"/corporate/progress.html\">IT業界での40年の歩み</a></li-->\n            <li><a href=\"/itsupport/\">ITサポートサービス</a></li>\n            <li><a href=\"/corporate/\">会社情報</a></li>\n            <li><a href=\"/aboutus/\">エブリについて</a></li>\n            <li><a href=\"https://www.every365.co.jp/recruit/\" target=\"_blank\">採用情報</a></li>\n\n            <li class=\"nav\">\n                <div class=\"menubar\">\n                    <div class=\"navtriger\">\n                        <span class=\"trigerbar\"></span>\n                    </div>\n                </div>\n            </li>\n        </ul>\n    </nav>\n</header>\n\n\n    <main id=\"cont\">\n\n\n\n        <article class=\"cnt ttlcol\">\n            <div class=\"wrapper\">\n\n                <h1 data-aos=\"fade-up\" class=\"ttl\">\n                    <span>message</span>\n                    <span class=\"jp\">トップメッセージ</span>\n                </h1>\n            </div>\n        </article>\n\n\n        <nav class=\"contmenu\" data-aos=\"fade-up\" data-aos-delay=\"400\">\n            <div class=\"wrapper\">\n                <ul>\n                    <li><a href=\"/corporate/\">会社概要</a></li>\n                    <li class=\"active\"><a href=\"/corporate/message.html\">トップメッセージ</a></li>\n                    <li><a href=\"/corporate/history.html\">沿革</a></li>\n                    <!--li><a href=\"/corporate/progress.html\">40年の歩み</a></li-->\n                    <li><a href=\"/corporate/group.html\">NCS&amp;Aグループ</a></li>\n                    <li><a href=\"/corporate/certification.html\">認定資格等</a></li>\n                    <li><a href=\"/corporate/variousdata.html\">社員保有資格</a></li>\n                    <li><a href=\"https://www.every365.co.jp/recruit/\" target=\"_blank\">採用情報</a></li>\n                </ul>\n            </div>\n        </nav>\n\n        <article class=\"cnt nopad\" id=\"message\" data-aos=\"fade-up\" data-aos-delay=\"200\">\n            <div class=\"wrapper\">\n                <div class=\"column\">\n\n                    <div class=\"row txtcol\">\n                    \t<!--p class=\"lead\"></p-->\n                    \t<p class=\"philosophy\">“ＩＴを通じ、変わりゆく社会に「持続可能な価値を」”<br>&nbsp;あなたの一番近いパートナーとして</p>\n                    </div>\n                    <div class=\"row imgcol\">\n                        <figure><img src=\"/img/corporate/img_president2026.webp?2026\" alt=\"\"></figure>\n                    </div>\n                </div>\n                    \n                    <div class=\"row\">\n\n\n                        <!--h2 class=\"mds hyp\"></h2-->\n\n                        <p>エブリ株式会社は、1983年の設立以来培ってきたIT関連技術をベースに、企業コンセプトである<strong>「Everytime＝いつでも」、「Everyone＝みなさまに」、「Everything＝あらゆるサポートを」</strong>に基づき、24時間365日のハード・ソフト保守・監視などのワンストップサービスをコアコンピタンスとして、システム開発・支援、インフラ設計・施工など、お客さまの様々なニーズにお応えするため、事業強化に努めてまいりました。</p>\n                        \n                        <p>社会情勢が変わっていく中、これまで変革と努力を重ねて成長し、事業を続けてこられたのは、ひとえにお客さまやパートナーの皆さまのご支援と成長し続ける社員があってこそだと思っております。あらためて心より感謝と厚く御礼を申し上げます。</p>\n                        \n                        <p><strong>企業メッセージを“Be every (エブリらしく、エブリらしさを)”とし、<br class=\"pc\">\n                        皆さまに信頼される『Nice Every！(ありがとう)』を目指します</strong></p>\n                        \n                        <p>設立以来40年以上の歩みの中で、私たちはお客さまのシステム構築・導入から運用まで、ハードとソフトの両面より幅広くサポートできる、業界でも特徴のある会社に成長しました。<br>\n                        システムやサービスが稼働してからの“アフターサポート”こそが、私たちの強みです。<br>\n                        この強みであるサポート力で、『お客さまのお困りごとに寄り添い、支え、お役に立ち、社会に貢献する』ことをミッションとして、ユーザーの皆さまが、システムを持続的に、安全かつ安心して使い続けられるための伴走者となることを目指しています。</p>\n                        \n                        <p><strong>今までも、そしてこれからもお客様と共に</strong></p>\n                        \n                        <p>今までも、そしてこれからもお客様と共に私たちエブリ株式会社は、”Teamエブリ”として、自らが考え、仕事に誠実さと責任を持って、迅速に行動し、”持続可能な社会の発展に貢献します”。</p>\n                        \n                        <p>今後とも皆さまのご愛顧とより一層のご支援を賜りますよう、宜しくお願い申し上げます。</p>\n\n                        \n                        <p class=\"sign\">エブリ株式会社<br>代表取締役社長<br><img src=\"/img/corporate/img_sign.webp?2026\" alt=\"成田 昌浩\"></p>\n                    </div>\n\n\n\n\n\n\n\n            </div>\n        </article>\n\n        <!--div class=\"btns\"><a href=\"/corporate/progress.html\" class=\"btn\">IT業界での40年の歩み</a></div-->\n\n    </main>\n\n\n\n    <aside class=\"iconlist\">\n\n    <ul data-aos=\"fade-in\" data-aos-delay=\"200\">\n        <li><a href=\"/aboutus/security.html\"><img src=\"/img/common/icon_pmark.webp?202507\" alt=\"たいせつにしますプライバシー\"></a></li>\n        <li><a href=\"https://www.aspicjapan.org/nintei/index.html\" target=\"_blank\"><img src=\"/img/common/icon_aspsaas.webp\" alt=\"ASP・SaaSの安全・信頼性に係る情報開示認定　第0249-2105号\"></a></li>\n        <li><a href=\"/aboutus/workstyle.html#health\"><img src=\"/img/common/logo_kenko2026.png\" alt=\"健康経営優良法人2026\"></a></li>\n        <li><a href=\"/aboutus/workstyle.html#lively\"><img src=\"/img/common/icon_plus.webp\" alt=\"男女いきいきPLUS＋ 大阪府男女いきいきプラス認証\"></a></li>\n        <li><a href=\"/aboutus/workstyle.html#female\"><img src=\"/img/common/icon_wrc.webp\" alt=\"女性活躍リーディングカンパニー 2020大阪市認証\"></a></li>\n        <li><a href=\"/aboutus/sdgs.html\"><img src=\"/img/common/icon_goals.webp\" alt=\"エブリ株式会社はSDGsの理念に賛同します\"></a></li>\n    </ul>\n\n</aside>\n\n\n\n<footer>\n\n    <nav class=\"cntmenu\">\n        <div class=\"menucol\" data-aos=\"fade-in\" data-aos-delay=\"600\">\n            <h2><a href=\"/itsupport/\">ITサポートサービス</a></h2>\n            <ul>\n                <li><a href=\"/itsupport/maintenance.html\">IT機器の保守・現調サービス</a></li>\n                <li><a href=\"/itsupport/software.html\">ソフトウェア開発支援サービス</a></li>\n                <li><a href=\"/itsupport/helpdesk.html\">ヘルプデスクサービス</a></li>\n                <li><a href=\"/itsupport/server.html\">サーバー構築サービス</a></li>\n                <li><a href=\"/itsupport/network.html\">ネットワーク工事サービス</a></li>\n                <li><a href=\"/itsupport/webdesign.html\">WEBデザインサービス</a></li>\n            </ul>\n        </div>\n        <div class=\"menucol\" data-aos=\"fade-in\" data-aos-delay=\"600\">\n            <h2>会社情報</h2>\n            <ul>\n                <li><a href=\"/corporate/\">会社概要</a></li>\n                <li><a href=\"/corporate/message.html\">トップメッセージ</a></li>\n                <li><a href=\"/corporate/history.html\">沿革</a></li>\n                <!--li><a href=\"/corporate/progress.html\">IT業界での40年の歩み</a></li-->\n                <li><a href=\"/corporate/group.html\">NCS&amp;Aグループ</a></li>\n                <li><a href=\"/corporate/certification.html\">認定資格等</a></li>\n                <li><a href=\"/corporate/variousdata.html\">社員保有資格</a></li>\n                <li><a href=\"https://www.every365.co.jp/recruit/\" target=\"_blank\">採用情報</a></li>\n            </ul>\n        </div>\n        <div class=\"menucol\" data-aos=\"fade-in\" data-aos-delay=\"400\">\n            <h2><a href=\"/aboutus/\">エブリについて</a></h2>\n            <ul>\n                <li><a href=\"/aboutus/itsupport.html\">ITの持続可能性を高めるサービス</a></li>\n                <li><a href=\"/aboutus/workstyle.html\">働き方の多様性</a></li>\n                <li><a href=\"/aboutus/ecp.html\">ECP（エブリ・キャリアアップ・<br>プログラム）</a></li>\n          