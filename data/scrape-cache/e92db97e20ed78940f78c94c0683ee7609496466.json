{"url":"https://www.k-yamasan.co.jp/recruit/member/interview06/","html":"<!DOCTYPE HTML>\n<html lang=\"ja\">\n\n<head>\n  <!-- Google Tag Manager -->\n  <script>\n    (function(w, d, s, l, i) {\n      w[l] = w[l] || [];\n      w[l].push({\n        'gtm.start': new Date().getTime(),\n        event: 'gtm.js'\n      });\n      var f = d.getElementsByTagName(s)[0],\n        j = d.createElement(s),\n        dl = l != 'dataLayer' ? '&l=' + l : '';\n      j.async = true;\n      j.src = 'https://www.googletagmanager.com/gtm.js?id=' + i + dl;\n      f.parentNode.insertBefore(j, f);\n    })(window, document, 'script', 'dataLayer', 'GTM-PJDQ96SJ');\n  </script>\n  <!-- End Google Tag Manager -->\n  <meta http-equiv=\"content-type\" content=\"text/html; charset=utf-8\">\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1.0,minimum-scale=1.0\">\n  <meta name=\"format-detection\" content=\"telephone=no\">\n  <title>Y.O.｜株式会社山産 採用サイト</title>\n  <script src=\"/recruit/inc/js/page/viewport-extra.min.js\"></script>\n  <script>\n    new ViewportExtra(375);\n  </script>\n  <link rel=\"icon\" href=\"/recruit/inc/image/favicon.ico\" type=\"image/x-icon\">\n  <link rel=\"apple-touch-icon\" href=\"/recruit/inc/image/apple-touch-icon.png\">\n  <link rel=\"icon\" href=\"/recruit/inc/image/android-chrome-192x192.png\" type=\"image/png\">\n  <meta name=\"description\" content=\"株式会社山産で働く先輩社員たちの、入社の動機や仕事に対する思い、みなさんへのメッセージなどをご紹介しています。\">\n  <meta property=\"og:site_name\" content=\"株式会社山産 採用サイト\">\n  <meta property=\"og:title\" content=\"Y.O.｜株式会社山産 採用サイト\">\n  <meta property=\"og:description\" content=\"株式会社山産で働く先輩社員たちの、入社の動機や仕事に対する思い、みなさんへのメッセージなどをご紹介しています。\">\n  <meta property=\"og:type\" content=\"article\">\n  <meta property=\"og:url\" content=\"https://www.k-yamasan.co.jp/recruit/member/interview06/\">\n  <meta property=\"og:image\" content=\"https://www.k-yamasan.co.jp/recruit/inc/image/common/img_ogp.jpg\">\n  <meta name=\"twitter:card\" content=\"summary_large_image\">\n  <meta name=\"twitter:site\" content=\"https://www.k-yamasan.co.jp/recruit/member/interview06/\">\n  <meta name=\"twitter:image\" content=\"https://www.k-yamasan.co.jp/recruit/inc/image/common/img_ogp.jpg\">\n  <link href=\"https://fonts.googleapis.com/css?family=Noto+Sans+JP:400,500,700&display=swap&subset=japanese\" rel=\"stylesheet\">\n  <link rel=\"stylesheet\" type=\"text/css\" href=\"/recruit/inc/css/style.css\">\n  <link rel=\"stylesheet\" type=\"text/css\" href=\"/recruit/inc/css/project/interview.css\">\n</head>\n\n<body id=\"interview06\">\n  <!-- Google Tag Manager (noscript) -->\n  <noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-PJDQ96SJ\" height=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n  <!-- End Google Tag Manager (noscript) -->\n  <div id=\"container\">\n    <header class=\"l-header\">\n      <div class=\"l-header__inner\">\n        <div class=\"l-header__modules\">\n          <a href=\"/recruit\" class=\"logo\">\n            <span class=\"logo-main\"><img src=\"/recruit/inc/image/common/img_logo.svg\" alt=\"株式会社山産 採用サイト\"></span>\n            <span class=\"logo-sub\"><img src=\"/recruit/inc/image/common/img_headerLogocaption.svg\" alt=\"RECRUIT SITE\"></span>\n          </a>\n        </div>\n        <nav class=\"l-header__btnArea\">\n          <button class=\"l-header__btn js-naviBtn\" data-cat=\"gnavi\">\n            <span class=\"c-toggleBtn\" id=\"toggle\">\n              <span></span>\n              <span></span>\n              <span></span>\n            </span>\n          </button>\n        </nav>\n      </div>\n      <!-- グローバルナビゲーション -->\n      <div class=\"l-navigation__wrapper\" id=\"gnavi\">\n        <nav class=\"l-navigation\">\n          <!-- 1列目 -->\n          <ul class=\"l-navigation__list\">\n            <!-- トップ -->\n            <li class=\"l-navigation__item\">\n              <a class=\"current\" href=\"/recruit\">トップ</a>\n            </li>\n            <!-- トップ -->\n            <!-- 山産を知る -->\n            <li class=\"l-navigation__item\">\n              <button class=\"js-hasDropdown l-navigation__item\">山産を知る</button>\n              <ul class=\"l-navigation__list-sub\">\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/about/message/\">採用メッセージ</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/about/business/\">山産の事業について</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/about/data/\">数字で見る山産</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/about/case/\">こんなところに山産</a></li>\n              </ul>\n            </li>\n            <!-- 山産を知る -->\n          </ul>\n          <!-- 1列目 -->\n          <!-- 2列目 -->\n          <ul class=\"l-navigation__list\">\n            <!-- 仕事を知る -->\n            <li class=\"l-navigation__item\">\n              <a href=\"/recruit/about/work/\">仕事を知る</a>\n            </li>\n            <!-- 仕事を知る -->\n            <!-- 山産の人 -->\n            <li class=\"l-navigation__item\">\n              <button class=\"js-hasDropdown l-navigation__item\">人を知る</button>\n              <ul class=\"l-navigation__list-sub\">\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/member/\" class=\"js-naviAnchor\">人を知るTOP</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/member/interview01/\" class=\"js-naviAnchor\">環境事業グループ D.F.</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/member/interview06/\" class=\"js-naviAnchor\">環境事業グループ Y.O.</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/member/interview07/\" class=\"js-naviAnchor\">産機事業グループ S.K.</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/member/interview02/\" class=\"js-naviAnchor\">産機事業グループ Y.T.</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/member/interview03/\" class=\"js-naviAnchor\">総務部 K.I.</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/member/interview04/\" class=\"js-naviAnchor\">産機事業グループ S.I.</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/member/interview05/\" class=\"js-naviAnchor\">環境事業グループ H.M.</a></li>\n              </ul>\n            </li>\n            <!-- 山産の人 -->\n          </ul>\n          <!-- 2列目 -->\n          <!-- 3列目 -->\n          <ul class=\"l-navigation__list\">\n            <!-- 環境・制度を知る -->\n            <li class=\"l-navigation__item\">\n              <button class=\"js-hasDropdown l-navigation__item\">環境・制度を知る</button>\n              <ul class=\"l-navigation__list-sub\">\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/info/culture/\">文化・社風</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/info/benefits/\">福利厚生</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/info/training/\">教育制度・キャリアステップ</a></li>\n              </ul>\n            </li>\n            <!-- 働く人を知る -->\n          </ul>\n          <!-- 3列目 -->\n          <!-- 4列目 -->\n          <ul class=\"l-navigation__list\">\n            <!-- 採用情報 -->\n            <li class=\"l-navigation__item\">\n              <button class=\"js-hasDropdown l-navigation__item\">採用情報</button>\n              <ul class=\"l-navigation__list-sub\">\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/info/guideline/\">募集要項・選考の流れ</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/info/faq/\">よくあるご質問</a></li>\n              </ul>\n            </li>\n            <!-- 採用情報 -->\n            <!-- エントリー -->\n            <li class=\"l-navigation__item\">\n              <button class=\"js-hasDropdown l-navigation__item\">エントリー</button>\n              <ul class=\"l-navigation__list-sub\">\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/new-graduate-entry/\">新卒採用エントリー</a></li>\n                <li class=\"l-navigation__item-sub\"><a href=\"/recruit/entry/\">経験者採用エントリー</a></li>\n              </ul>\n            </li>\n            <!-- エントリー -->\n          </ul>\n          <!-- 4列目 -->\n        </nav>\n      </div>\n      <!-- グローバルナビゲーション -->\n    </header>\n    <!-- /header -->\n    <main id=\"main\">\n      <div class=\"l-lowerCaption\">\n        <div class=\"l-lowerCaption__inner\">\n          <h1 class=\"l-lowerCaption__title\">Y.O.</h1>\n          <ol class=\"c-topicspath\">\n            <li><a href=\"/recruit\">ホーム</a></li>\n            <li><a href=\"/recruit/member/\">人を知る</a></li>\n            <li>Y.O.</li>\n          </ol>\n        </div>\n      </div>\n      <div class=\"l-lowerCaption__bottom\">\n        <img src=\"/recruit/inc/image/common/lower/img_lowerCaption-bottom.svg\" alt=\"\">\n      </div>\n      <div id=\"contents\" class=\"l-lower\">\n        <section class=\"l-section\">\n          <div class=\"l-section__inner\">\n            <div class=\"l-mw p-interviewHero\">\n              <picture class=\"p-interviewHero__image\">\n                <source srcset=\"/recruit/inc/image/member/interview06/pic_interview-main.jpg.webp 1x, /recruit/inc/image/member/interview06/pic_interview-main@2x.jpg.webp 2x\" type=\"image/webp\">\n                <img src=\"/recruit/inc/image/member/interview06/pic_interview-main.jpg\" alt=\"Y.O.\">\n              </picture>\n              <div class=\"p-interviewHero__text\">\n                <h2 class=\"p-interviewHero__title\"><span>提案から完成まで</span><span>独自のスタイルを築く</span></h2>\n                <p class=\"p-interviewHero__affiliation\"><span>2021年度入社 環境事業グループ 施工管理</span></p>\n                <p class=\"p-interviewHero__name\"><span>Y.O.</span></p>\n              </div>\n            </div>\n          </div>\n          <!-- 本文 -->\n          <div class=\"l-section__inner l-section__inner--pbSmall-sm\">\n            <div class=\"l-mw l-mw--800\">\n              <p class=\"p-interview__question\">山産で働きたいと思うようになった理由、きっかけは？</p>\n              <h3 class=\"c-ttl-small\">充実の福利厚生と安定感が決め手に</h3>\n              <p>山産に勤務している大学時代の先輩に勧めてもらったことがきっかけです。福利厚生の充実や働きやすさについて話を聞き、興味を持ち、会社説明会に参加しました。そこで知ったのが、初任給の高さと家賃補助という手厚い支援制度です。ボーナスも充実しており、これだけ待遇が整っていれば、生活の心配をせずに仕事に集中できると思いました。就職活動を進める中で、コロナ禍の影響により経営が厳しくなる企業も多く見ましたが、山産は民間と公共事業の両方に関わる企業として安心感があり、入社を決意しました。現在は地元である岩国営業所に配属され、地元のインフラを支える仕事に携われていることにやりがいを感じています。</p>\n            </div>\n          </div>\n          <div class=\"l-section__inner l-section__inner--pbSmall-sm\">\n            <div class=\"l-mw l-mw--800\">\n              <p class=\"p-interview__question\">どんな仕事をしていますか？</p>\n              <h3 class=\"c-ttl-small\">現場対応から営業まで、お客様に寄り添う仕事</h3>\n              <p>主な仕事は、山口県の東部エリア（岩国市、柳井市、平生町、田布施町）における上下水道施設のメンテナンスです。 お客様から直接ご相談をいただき、現場へヒアリングに伺います。現場で施工管理を行いながら、 同時にお客様へ営業活動を行っています。 緊急時には迅速に現場に駆けつけます。 <br>普段からお客様のところに足を運んで直接お話しする機会を大切にしており、次の引き合いのきっかけ作りに力を入れています。</p>\n            </div>\n          </div>\n          <div class=\"l-section__inner l-section__inner--pbSmall-sm\">\n            <div class=\"l-mw l-mw--800\">\n              <p class=\"p-interview__question\">山産の良い部分は？また、やりがいを教えてください。</p>\n              <h3 class=\"c-ttl-small\">提案から完成まで、自分の手でつくり上げる達成感</h3>\n              <p>山産の一番の魅力は、提案から完成まで、全て自分で携わることができる点です。自分次第で様々な提案ができ、やりたい仕事を自ら取ってくることも可能です。就職前はスーツを着た営業職を想像していましたが、実際は作業着で施工管理を行う日々です。当初はギャップを感じましたが、公共工事という大きなプロジェクトに関わることで、大きな責任と同時にやりがいを感じています。知識のない中でのスタートでしたが、工事が無事に完了し、お客様から感謝の言葉をいただいた瞬間に「この仕事をしていて良かった」と心から思います。</p>\n            </div>\n          </div>\n          <div class=\"l-section__inner l-section__inner--pbSmall-sm\">\n            <div class=\"l-mw l-mw--800\">\n              <picture class=\"c-imageWrapper\">\n                <source srcset=\"/recruit/inc/image/member/interview06/pic_interviewBody01.jpg.webp 1x, /recruit/inc/image/member/interview06/pic_interviewBody01@2x.jpg.webp 2x\" type=\"image/webp\">\n                <img src=\"/recruit/inc/image/member/interview06/pic_interviewBody01.jpg\" alt=\"業務風景\">\n              </picture>\n            </div>\n          </div>\n          <div class=\"l-section__inner l-section__inner--pbSmall-sm\">\n            <div class=\"l-mw l-mw--800\">\n              <p class=\"p-interview__question\">仕事をしていて大変なことは？どうやって乗り越えてますか？</p>\n              <h3 class=\"c-ttl-small\">知識を積み重ね、仲間と共に成長する</h3>\n              <p>新人時代に更地の状態からポンプ場を建設するプロジェクトを担当したことが、一番大変でした。建築基準が細かく、ケーブル1本にも厳密な規格が定められており、準備段階の調査から膨大な作業が必要でした。先輩や上司、職人の方々に教わりながら一つひとつ学び、時には失敗して厳しく指導を受けることもありましたが、完成した時の達成感は今でも忘れられません。<br>社内には若手会があり、同期の話を聞くことで良い刺激をもらっています。また、プライベートも大切にしており、友人と飲みに行ったり、会社の仲間とゴルフを楽しんだりしてリフレッシュしています。こうした交流が、仕事を続ける上での大きな原動力になっています。</p>\n            </div>\n          </div>\n          <div class=\"l-section__inner l-section__inner--pbSmall-sm\">\n            <div class=\"l-mw l-mw--800\">\n              <p class=\"p-interview__question\">グレートを創り出す為に心がけていることや、これから挑戦したいことがあれば教えてください</p>\n              <h3 class=\"c-ttl-small\">迅速な対応力と資格取得で信頼を築く</h3>\n              <p>お客様のお困りごとには、迅速に対応することを心がけています。また、知識を深めて自分なりの提案ができるよう、日々学び続けています。お客様からより信頼される存在になるために、資格取得にも積極的に取り組んでいます。今の目標は、施工管理技士1級の取得です。資格を取り仕事の幅をより拡げていきたいと考えています。<br>お客様から「この人が来てくれたら安心だ」と思っていただけるような存在を目指しています。そうした信頼の積み重ねが、山産の信頼とブランド力の向上につながると信じています。 </p>\n            </div>\n          </div>\n          <div class=\"l-section__inner l-section__inner--pbSmall-sm\">\n            <div class=\"l-mw l-mw--800\">\n              <picture class=\"c-imageWrapper\">\n                <source srcset=\"/recruit/inc/image/member/interview06/pic_interviewBody02.jpg.webp 1x, /recruit/inc/image/member/interview06/pic_interviewBody02@2x.jpg.webp 2x\" type=\"image/webp\">\n                <img src=\"/recruit/inc/image/member/interview06/pic_interviewBody02.jpg\" alt=\"業務風景\">\n              </picture>\n            </div>\n          </div>\n          <!-- 一日の流れ -->\n          <div class=\"l-section__inner l-section__inner--pbSmall-sm\">\n            <div class=\"l-mw l-mw--800\">\n              <h3 class=\"c-ttl-small c-ttl-middle--mbLarge\">1日の流れ</h3>\n              <div class=\"c-timeline\">\n                <ol class=\"c-timeline__list\">\n                  <li class=\"c-timeline__itemWrapper\">\n                    <dl class=\"c-timeline__item\">\n                      <dt class=\"c-timeline__time\"><span><span>6:30</span></span></dt>\n                      <dd class=\"c-timeline__content\">\n                        <h4 class=\"c-timeline__heading\">起床</h4>\n                        <p></p>\n                      </dd>\n                    </dl>\n                  </li>\n                  <li class=\"c-timeline__itemWrapper\">\n                    <dl class=\"c-timeline__item\">\n                      <dt class=\"c-timeline__time\"><span><span>7:00</span></span></dt>\n                      <dd class=\"c-timeline__content\">\n                        <h4 class=\"c-timeline__heading\">出社</h4>\n                        <p></p>\n                      </dd>\n                    </dl>\n                  </li>\n                  <li class=\"c-timeline__itemWrapper\">\n                    <dl class=\"c-timeline__item\">\n                      <dt class=\"c-timeline__time\"><span><span>7:30</span></span></dt>\n                      <dd class=\"c-timeline__content\">\n                        <h4 class=\"c-timeline__heading\">外出・現場へ向かう</h4>\n                        <p></p>\n                      </dd>\n                    </dl>\n                  </li>\n                  <li class=\"c-timeline__itemWrapper\">\n                    <dl class=\"c-timeline__item\">\n                      <dt class=\"c-timeline__time\"><span><span>8:30</span></span></dt>\n                      <dd class=\"c-timeline__content\">\n                        <h4 class=\"c-timeline__heading\">現場到着・作業開始</h4>\n                        <p></p>\n                      </dd>\n                    </dl>\n                  </li>\n                  <li class=\"c-timeline__itemWrapper\">\n                    <dl class=\"c-timeline__item\">\n                      <dt class=\"c-timeline__time\"><span><span>12:00</span></span></dt>\n                      <dd class=\"c-timeline__content\">\n                        <h4 class=\"c-timeline__heading\">昼休み</h4>\n                        <p></p>\n                      </dd>\n                    </dl>\n                  </li>\n                  <li class=\"c-timeline__itemWrapper\">\n                    <dl class=\"c-timeline__item\">\n                      <dt class=\"c-timeline__time\"><span><span>13:00</span></span></dt>\n                      <dd class=\"c-timeline__content\">\n                        <h4 class=\"c-timeline__heading\">作業再開</h4>\n                        <p></p>\n                      </dd>\n                    </dl>\n                  </li>\n                  <li class=\"c-timeline__itemWrapper\">\n                    <dl class=\"c-timeline__item\">\n                      <dt class=\"c-timeline__time\"><span><span>16:00</span></span></dt>\n                      <dd class=\"c-timeline__content\">\n                        <h4 class=\"c-timeline__heading\">作業完了</h4>\n                        <p></p>\n                      </dd>\n                    </dl>\n                  </li>\n                  <li class=\"c-timeline__itemWrapper\">\n                    <dl class=\"c-timeline__item\">\n                      <dt class=\"c-timeline__time\"><span><span>17:00</span></span></dt>\n                      <dd class=\"c-timeline__content\">\n                        <h4 class=\"c-timeline__heading\">帰社・書類整理</h4>\n                        <p></p>\n                      </dd>\n                    </dl>\n                  </li>\n                  <li class=\"c-timeline__itemWrapper\">\n                    <dl class=\"c-timeline__item\">\n                      <dt class=\"c-timeline__time\"><span><span>19:00前</span></span></dt>\n                      <dd class=\"c-timeline__content\">\n                        <h4 class=\"c-timeline__heading\">退勤</h4>\n                        <p></p>\n                      </dd>\n                    </dl>\n                  </li>\n                </ol>\n              </div>\n            </div>\n          </div>\n          <!-- 一日の流れ -->\n          <div class=\"l-section__inner l-section__inner--pbSmall-sm\">\n            <div class=\"l-mw l-mw--800\">\n              <picture class=\"c-imageWrapper\">\n                <source srcset=\"/recruit/inc/image/member/interview06/pic_interviewBody03.jpg.webp 1x, /recruit/inc/image/member/interview06/pic_interviewBody03@2x.jpg.webp 2x\" type=\"image/webp\">\n                <img src=\"/recruit/inc/image/member/interview06/pic_interviewBody03.jpg\" alt=\"業務風景\">\n              </picture>\n            </div>\n          </div>\n          <div class=\"l-section__inner l-section__inner--pbSmall-sm\">\n            <div class=\"l-mw l-mw--800\">\n              <h3 class=\"c-ttl-small\">応募を考えている人へメッセージをお願いします!!</h3>\n              <p>私自身、文系出身で専門知識がない状態からのスタートでしたが、大規模な工事に携わる中で、大きなやりがいを感じています。山産は、前向きで人と関わることが好きな方、成長意欲のある方にピッタリな会社です。やったことに対して正当に評価される制度があり、頑張った分だけ成長を実感できます。<br> 若い世代も多く、優しい先輩方が丁寧に指導してくれる働きやすい環境です。失敗することもありますが、それを糧として前向きに挑戦できる方であれば、必ず活躍できる会社だと確信しています。 </p>\n            </div>\n          </div>\n          <!-- 本文 -->\n        </section>\n        <!-- 他インタビューへのリンク-->\n        <div class=\"l-bg l-bg--bgColor\">\n          <div class=\"l-section l-section--pb2x u-border-top\">\n            <h2 class=\"c-ttl-main c-ttl-main c-ttl--center c-ttl--keycolor c-ttl--oblique\"> 他のメンバーのインタビューを見る </h2>\n            <div class=\"l-Grid--18\">\n              <!-- 他ページへのリンク -->\n              <ul class=\"grid\">\n                <li class=\"col-4_md-6_sm-12\">\n                  <a href=\"/recruit/member/interview01\" class=\"c-hasImageCard\">\n                    <picture class=\"c-hasImageCard__image\">\n                      <source srcset=\"/recruit/inc/image/member/pic_interviewCard01.jpg.webp 1x, /recruit/inc/image/member/pic_interview