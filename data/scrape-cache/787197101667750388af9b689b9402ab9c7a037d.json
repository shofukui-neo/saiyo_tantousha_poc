{"url":"https://www.dmre.daikin.co.jp/contact/index.html","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width,initial-scale=1.0\">\n    <meta name=\"description\" content=\"船舶の空調・冷凍機に関するよくあるご質問とお問い合わせ窓口のご案内。修理・交換から空調システム全体のご相談まで、グローバルネットワークでサポートします。\">\n    <title>お問い合わせ FAQ | ダイキンMRエンジニアリング株式会社</title>\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n    <link href=\"https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Noto+Sans+JP:wght@100..900&family=Roboto+Condensed:wght@100..900&display=swap\" rel=\"stylesheet\">\n    <link href=\"/common/css/common.css\" rel=\"stylesheet\">\n      <link rel=\"stylesheet\" href=\"css/index.css\">\n\n    <script src=\"//ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js\"></script>\n    <script>window.jQuery || document.write('<script src=\"/common/js/libs/jquery-3.7.1.min.js\"><\\/script>')</script>\n    <script src=\"/common/js/plugins.js\"></script>\n    <script src=\"/common/js/common.min.js\"></script>\n    \n    <meta property=\"og:type\" content=\"article\">\n    <meta property=\"og:title\" content=\"お問い合わせ FAQ | ダイキンMRエンジニアリング株式会社\">\n    <meta property=\"og:url\" content=\"https://www.dmre.daikin.co.jp/contact/\">\n    <meta property=\"og:image\" content=\"https://www.dmre.daikin.co.jp/common/img/ogp.png\">\n    <meta property=\"og:description\" content=\"船舶の空調・冷凍機に関するよくあるご質問とお問い合わせ窓口のご案内。修理・交換から空調システム全体のご相談まで、グローバルネットワークでサポートします。\">\n    <meta property=\"og:site_name\" content=\"ダイキンMRエンジニアリング株式会社\">\n    <meta property=\"og:locale\" content=\"ja_JP\">\n    <link rel=\"canonical\" href=\"https://www.dmre.daikin.co.jp/contact/\">\n    <script async=\"\" src=\"https://www.googletagmanager.com/gtag/js?id=G-M2C3PBSPC7\"></script>\n    <script>\n      window.dataLayer = window.dataLayer || [];\n      function gtag() { dataLayer.push(arguments); }\n      gtag('js', new Date());\n\n      gtag('config', 'G-M2C3PBSPC7');\n    </script>\n    <script type=\"application/ld+json\">\n  {\n\t\t\"@context\": \"http://schema.org\",\n\t\t\"@type\" : \"BreadcrumbList\",\n\t\t\"itemListElement\":[\n    \t\t                    {\n            \"@type\"   : \"ListItem\",\n            \"position\": \"1\",\n            \"item\"    : {\n                \"@id\" : \"https://www.dmre.daikin.co.jp/\",\n                \"name\": \"ダイキンMRエンジニアリング株式会社\"\n            }\n          },\n                    {\n            \"@type\"   : \"ListItem\",\n            \"position\": \"2\",\n          \"item\"    : {\n              \"@id\" : \"https://www.dmre.daikin.co.jp/contact/\",\n              \"name\": \"お問い合わせ FAQ\"\n          }\n        }\n\t\t]\n\t}\n\n</script>\n</head>\n<body>\n<div class=\"wrap\"><header class=\"header\">\n    <div class=\"header__main\">\n                    <a href=\"/\">\n                <p class=\"header__logo\"><img src=\"/common/img/logo.svg\" alt=\"ダイキンMRエンジニアリング株式会社\" width=\"307\" height=\"73\"></p>\n            </a>\n                <div class=\"header__list\">\n            <ul class=\"header__nav\">\n                <li><a href=\"/contact/\" class=\"header__contact\"><span>FAQ｜お問い合わせ</span></a></li>\n                <li>\n                    <a href=\"/recruit/\" class=\"header__recruit\">\n                        <span class=\"header__recruit-en\">RECRUIT</span>\n                        <span class=\"header__recruit-ja\">採用情報はこちら</span>\n                    </a>\n                </li>\n                <li class=\"header__lang\">\n                    <div class=\"header__lang-main\">\n                        <span class=\"header__lang-ja\">JP</span>\n                        <a href=\"/english/\" class=\"header__lang-en\">EN</a>\n                    </div>\n                </li>\n                <li>\n                    <button class=\"header__menu js-menu-show\">MENU</button>\n                </li>\n            </ul>\n        </div>\n    </div>\n</header>\n\n<div class=\"fixed-menu\">\n    <ul class=\"fixed-menu__list\">\n        <li>\n            <button class=\"fixed-menu__menu js-menu-show\">MENU</button>\n        </li>\n        <li><a href=\"/contact/\" class=\"fixed-menu__contact\"><span>FAQ｜お問い合わせ</span></a></li>\n        <li>\n            <a href=\"/recruit/\" class=\"fixed-menu__recruit\">\n                <span class=\"fixed-menu__recruit-en\">RECRUIT</span>\n                <span class=\"fixed-menu__recruit-ja\">採用情報はこちら</span>\n            </a>\n        </li>\n\n    </ul>\n</div>\n\n\n<div class=\"sp-menu\"><button class=\"js-menu-show\"><span>menu</span></button></div>\n\n\n<main class=\"main\">\n    <div class=\"main__head\">\n        <picture class=\"\">\n    <source srcset=\"img/head_img.avif\" type=\"image/avif\">\n    <img src=\"img/head_img.jpg\" alt=\"\" width=\"1400\" height=\"464\"  loading=\"lazy\">\n  </picture>\n        <hgroup class=\"main__head-group\">\n            <p class=\"main__head-sub\" lang=\"en\">FREQUENTLY ASKED QUESTIONS</p>\n            <h1 class=\"main__head-title\">よくあるご質問</h1>\n        </hgroup>\n    </div>\n    <div class=\"contents contact__head\">\n        <h2 class=\"contact__head-title\">世界の船主・造船所から<br class=\"sp-only\">選ばれる理由</h2>\n        <p class=\"contact__head-title-en\">Chosen by Shipowners and Shipyards Worldwide</p>\n        <p class=\"contact__head-lead\">グローバルネットワークを駆使して、船の空調・冷凍機に関するあらゆるご依頼・ご相談をワンストップで。</p>\n        <div class=\"contact-us__btn\"><a href=\"./inc_input.html\">お問い合わせフォーム</a></div>\n    </div>\n    <section class=\"point\">\n        <div class=\"contents\">\n            <div class=\"point__main\">\n                <p class=\"point__no\">Point <span>01</span></p>\n                <div class=\"point__block\">\n                    <div class=\"point__box\">\n                        <h3 class=\"point__title\">船の空調機で国内シェアトップクラス</h3>\n                        <p class=\"point__detail\">空調・冷凍機の設計・施工はもちろん、熱負荷検討による機器選定、気流解析、舶用ダクトの設計など、あらゆる関連業務もワンストップで承ります。設備の修理や交換から、船全体の空調システムまで、丁寧なヒアリングにより最適なご提案をします。</p>\n                    </div>\n                    <div class=\"point__img\"><picture class=\"\">\n    <source srcset=\"img/point01_img01.avif\" type=\"image/avif\">\n    <img src=\"img/point01_img01.jpg\" alt=\"\" width=\"270\" height=\"177\"  loading=\"lazy\">\n  </picture></div>\n                </div>\n            </div>\n            <div class=\"point__main\">\n                <p class=\"point__no\">Point <span>02</span></p>\n                <div class=\"point__block reverse\">\n                    <div class=\"point__box\">\n                        <h3 class=\"point__title\">サービス窓口でスピーディーに問題解決</h3>\n                        <p class=\"point__detail\">「空調の効きが悪い・冷風が出ない」、「買い換えたい」、「異音がする」などお困りのことがありましたら、お気軽に当社サービス窓口までお問い合わせください。また、取扱説明書のトラブルシューティングをご覧いただくことで、問題が解決する場合もあります。</p>\n                    </div>\n                    <div class=\"point__img\"><picture class=\"\">\n    <source srcset=\"img/point02_img01.avif\" type=\"image/avif\">\n    <img src=\"img/point02_img01.jpg\" alt=\"\" width=\"270\" height=\"177\"  loading=\"lazy\">\n  </picture></div>\n                </div>\n            </div>\n            <div class=\"point__main\">\n                <p class=\"point__no\">Point <span>03</span></p>\n                <div class=\"point__block\">\n                    <div class=\"point__box\">\n                        <h3 class=\"point__title\">海外での空調機トラブルにも安心の対応</h3>\n                        <p class=\"point__detail\">ダイキングループのグローバルサービスネットワークを活用し、海外港湾での空調・冷凍機の修理・点検にも対応しています。</p>\n                    </div>\n                    <div class=\"point__img\"><picture class=\"\">\n    <source srcset=\"img/point03_img01.avif\" type=\"image/avif\">\n    <img src=\"img/point03_img01.jpg\" alt=\"\" width=\"270\" height=\"177\"  loading=\"lazy\">\n  </picture></div>\n                </div>\n            </div>\n        </div>\n    </section>\n    <section class=\"qa\">\n        <div class=\"contents\">\n            <div class=\"qa__head\">\n                <h2 class=\"qa__title\">よくいただくご質問・ご相談</h2>\n                <p class=\"qa__title-en\">Frequently asked questions and inquiries</p>\n                <p class=\"qa__lead\">船主さま・造船所さまからの、よくあるお問い合わせをご紹介します。どのようなことでも、まずはお気軽にご相談ください。</p>\n            </div>\n            <div class=\"qa__group\">\n                <h3 class=\"qa__category\">海外におけるサービス体制について</h3>\n                <dl class=\"qa__main\">\n                    <dt>船が海外の港湾に停泊中の場合も、修理は依頼できますか？</dt>\n                    <dd>ダイキングループのグローバルサービスネットワークを活用し、海外港湾での空調・冷凍機の修理・点検にも対応しています。対応可能な地域や修理の内容につきましては、お気軽にお問い合わせください。</dd>\n                </dl>\n            </div>\n            <div class=\"qa__group\">\n                <h3 class=\"qa__category\">季節切替時の運転トラブルについて</h3>\n                <dl class=\"qa__main\">\n                    <dt>冷房／暖房の切替シーズンに、空調が動かないことがあるのですが…。</dt>\n                    <dd>シーズン切替前には、試運転の実施をおすすめしています。当社では、事前点検・試運転を含む点検サービスを提供しており、点検により思わぬトラブルを防止することができます。</dd>\n                    <dt>空調機が急に動かなくなりました。どうすればよいですか？</dt>\n                    <dd>お気軽に当社サービス窓口までお問い合わせください。取扱説明書のトラブルシューティングをご覧いただくことで、問題が解決する場合もあります。</dd>\n                </dl>\n            </div>\n            <div class=\"qa__group\">\n                <h3 class=\"qa__category\">ダクトや空気の品質について</h3>\n                <dl class=\"qa__main\">\n                    <dt>吹き出し口からほこりや鉄さびが出て困っています。</dt>\n                    <dd>舶用ダクトの清掃（ほこり・鉄さび除去）サービスを実施しています。空気環境の改善だけでなく、機器性能の維持にもつながります。</dd>\n                    <dt>ダクトの設計、製作・取り付けも依頼できますか？</dt>\n                    <dd>はい、可能です。<br>\n                        空調機のみならず、舶用ダクトの設計、製作から取り付けまでワンストップで対応します。船全体の空調システムの提案もお任せください。</dd>\n                </dl>\n            </div>\n            <div class=\"contact-us__btn\"><a href=\"./inc_input.html\">お問い合わせフォーム</a></div>\n            <div class=\"qa__group\">\n                <h3 class=\"qa__category\">空調機の冷暖房能力と増設について</h3>\n                <dl class=\"qa__main\">\n                    <dt>暑いので空調機を増設したいのですが、相談は可能ですか？</dt>\n                    <dd>はい、可能です。<br>\n                        船の規模・用途・既存設備を確認したうえで、最適な空調システムをご提案します。</dd>\n                    <dt>小型船のため、冷却水を使わない空調システムを導入したいのですが…。</dt>\n                    <dd>舶用小形空冷式空調機（キャビンパートナー）がおすすめです。運用条件に応じた最適なシステムをご提案します。</dd>\n                </dl>\n            </div>\n            <div class=\"qa__group\">\n                <h3 class=\"qa__category\">機器の更新、レトロフィットについて</h3>\n                <dl class=\"qa__main\">\n                    <dt>空調機を入れ替えたいのですが、ドアが狭く、搬入できるか心配です。</dt>\n                    <dd>ご安心ください。当社では分解搬入・現地組立サービスを行っており、搬入制限がある船舶にも空調機を設置可能です。現地を確認し、搬入プランを検討します。</dd>\n                    <dt>空調機の入れ替えから10年以上が経過しました。まだ使い続けられますか？</dt>\n                    <dd>まずは、現在の空調機の状況を点検します。そのうえで、船齢や、修理と新調のそれぞれにかかるコスト、部品入手の可否などを考慮して、最適なご提案をします。</dd>\n                    <dt>現在使用している冷媒を、今後も使い続けて大丈夫か不安です。</dt>\n                    <dd>ご利用中の冷媒が、現在もしくは今後、規制の対象となるものか、確認します。環境規制に配慮した機器への交換もご提案可能です。</dd>\n                </dl>\n            </div>\n            <div class=\"qa__group\">\n                <h3 class=\"qa__category\">メンテナンス、長期運用について</h3>\n                <dl class=\"qa__main\">\n                    <dt>空調・冷凍機のメンテナンスも依頼できますか？</dt>\n                    <dd>はい、承ります。<br>\n                        長く・安定してお使いいただくためのトータルサポートが当社の強みです。定期点検・保全まで含めたメンテナンスサービスを提供しています。</dd>\n                </dl>\n            </div>\n            <div class=\"contact-us__btn\"><a href=\"./inc_input.html\">お問い合わせフォーム</a></div>\n        </div>\n    </section>\n</main>\n<footer class=\"footer\">\n    <div class=\"footer__wrap\">\n        <div class=\"footer__contents\">\n            <div class=\"footer__main\">\n                <div class=\"footer__logo\"><a href=\"/\"><img src=\"/common/img/logo.svg\" alt=\"ダイキンMRエンジニアリング株式会社\" width=\"308\" height=\"73\"></a></div>\n                <div class=\"footer__nav\">\n                    <ul class=\"footer__nav-list\">\n                        <li><a href=\"/message/\">トップメッセージ</a></li>\n                        <li><a href=\"/outline/\">企業情報</a></li>\n                        <li><a href=\"/business/\">事業概要</a></li>\n                    </ul>\n                </div>\n                <div class=\"footer__nav\">\n                    <ul class=\"footer__nav-list\">\n                        <li><a href=\"/engineer/\">エンジニアリング力</a></li>\n                        <li><a href=\"/results/\">納入・サービス実績</a></li>\n                        <li><a href=\"/catalog/\">商品・サービス</a></li>\n                    </ul>\n                </div>\n                <div class=\"footer__other\">\n                    <ul class=\"footer-other-list\">\n                        <li><a href=\"/contact/\" class=\"footer__contact\"><span>FAQ｜お問い合わせ</span></a></li>\n                        <li>\n                            <a href=\"/recruit/\" class=\"footer__recruit\">\n                                <span class=\"footer__recruit-en\">RECRUIT</span>\n                                <span class=\"footer__recruit-ja\">採用情報はこちら</span>\n                            </a>\n                        </li>\n                    </ul>\n                    <div class=\"footer__lang\">\n                        <span class=\"footer__lang-ja\">JP</span>\n                        <a href=\"/english/\" class=\"footer__lang-en\">EN</a>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n    <div class=\"footer__bottom\">\n        <ul class=\"footer__bottom-list\">\n            <li><a href=\"/terms/\">ウェブサイトご利用条件</a></li>\n            <li><a href=\"/privacy/\">個人情報保護方針</a></li>\n        </ul>\n        <p class=\"footer__bottom-copyright\">Copyright (C) 2026 DAIKIN MR ENGINEERING,LTD. All Rights Reserved.</p>\n    </div>\n</footer>\n<div class=\"sp-footer-fix\">\n    <ul class=\"sp-footer-fix__list\">\n        <li><a href=\"/contact/\" class=\"sp-footer-fix__contact\"><span>FAQ｜お問い合わせ</span></a></li>\n        <li>\n            <a href=\"/recruit/\" class=\"sp-footer-fix__recruit\">\n                <span class=\"sp-footer-fix__recruit-en\">RECRUIT</span>\n                <span class=\"sp-footer-fix__recruit-ja\">採用情報はこちら</span>\n            </a>\n        </li>\n    </ul>\n</div>\n<div class=\"page-top\"><button class=\"js-top\"><img src=\"/common/img/page_top.svg\" alt=\"\" width=\"17\" height=\"129\"></button></div>\n\n</div>\n<div class=\"menu\">\n    <div class=\"menu__head\">\n        <a href=\"/\" class=\"menu__logo-link\">\n            <p class=\"menu__logo\"><img src=\"/common/img/logo.svg\" alt=\"ダイキンMRエンジニアリング株式会社\" width=\"307\" height=\"73\"></p>\n        </a>\n        <div class=\"menu__head-contents\">\n            <div class=\"menu__head-lang\">\n                <div class=\"menu__head-lang-main\">\n                    <span class=\"menu__head-lang-ja\">JP</span>\n                    <a href=\"/english/\" class=\"menu__head-lang-en\">EN</a>\n                </div>\n            </div>\n            <div class=\"menu__head-close\">\n                <button class=\"menu__close js-menu-close\">CLOSE</button>\n            </div>\n        </div>\n    </div>\n    <div class=\"menu__contents\">\n        <div class=\"menu__main\">\n            <p class=\"menu__title\">\n                <img src=\"/common/img/menu_title.svg\" alt=\"\">\n            </p>\n        </div>\n        <nav class=\"menu-nav\">\n            <ul class=\"menu-nav-list\">\n                <li class=\"top\"><a href=\"/\">トップページ</a></li>\n                <li><a href=\"/message/\">トップメッセージ</a></li>\n                <li><a href=\"/outline/\">企業情報</a></li>\n                <li><a href=\"/business/\">事業概要</a></li>\n                <li><a href=\"/engineer/\">エンジニアリング力</a></li>\n                <li><a href=\"/results/\">納入・サービス実績</a></li>\n                <li><a href=\"/catalog/\">商品・サービス</a></li>\n                <li><a href=\"/contact/\">FAQ／お問い合わせ</a></li>\n                <li class=\"recruit\"><a href=\"/recruit/\">RECRUIT／採用情報はこちら</a></li>\n            </ul>\n            <ul class=\"menu-nav-sub\">\n                <li><a href=\"/terms/\">ウェブサイトご利用条件</a></li>\n                <li><a href=\"/privacy/\">個人情報保護方針</a></li>\n            </ul>\n        </nav>\n    </div>\n</div>\n\n\n</body>\n</html>\n\n","finalUrl":"https://www.dmre.daikin.co.jp/contact/index.html","rendered":false,"_cachedAt":"2026-06-22T18:06:49.339Z"}