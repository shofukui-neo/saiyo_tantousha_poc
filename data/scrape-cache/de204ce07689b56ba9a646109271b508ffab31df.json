{"url":"https://www.cnw.co.jp/recruit/work.html","html":"<!DOCTYPE html>\r\n<html lang=\"ja\">\r\n<head>\r\n  <meta charset=\"UTF-8\">\r\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n  <title>仕事を知る | キャリアネットワーク採用サイト</title>\r\n  <link href=\"https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@300;400;500;600;700&family=Noto+Sans+JP:wght@300;400;500;700&family=Inter:wght@300;400;500;600;700&display=swap\" rel=\"stylesheet\">\r\n  <link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@fortawesome/fontawesome-free@6.4.0/css/all.min.css\">\r\n  <link rel=\"stylesheet\" href=\"css/sub.css\">\r\n  <link rel=\"stylesheet\" href=\"css/work.css\">\r\n</head>\r\n<body class=\"work\"><div id=\"wrapper\">\r\n\r\n<!-- ========================================\r\n     HEADER\r\n======================================== -->\r\n<header class=\"site-header\">\r\n  <div class=\"site-header__inner\"><a href=\"index.html\" class=\"site-header__logo\">\r\n      <img src=\"images/logo.webp\" width=\"200\">\r\n      <span class=\"site-header__logo-text\">採用サイト<span>RECRUIT</span></span>\r\n    </a>\r\n    <nav class=\"site-header__nav\" id=\"headerNav\">\r\n      <ul>\r\n        <li><a href=\"company.html\">会社を知る</a></li>\r\n        <li><a href=\"work.html\" class=\"active\">仕事を知る</a></li>\r\n        <li><a href=\"people.html\">人を知る</a></li>\r\n        <li><a href=\"jobs.html\">採用情報</a></li>\r\n      </ul>\r\n    </nav>\r\n    <a href=\"jobs.html#apply\" class=\"site-header__cta\">ENTRY</a>\r\n    <button class=\"site-header__hamburger\" id=\"hamburger\" aria-label=\"メニュー\">\r\n      <span></span><span></span><span></span>\r\n    </button>\r\n  </div>\r\n</header>\r\n\r\n<div class=\"sp-menu\" id=\"spMenu\">\r\n  <ul>\r\n    <li><a href=\"company.html\" class=\"sp-menu__link\">会社を知る</a></li>\r\n    <li><a href=\"work.html\" class=\"sp-menu__link active\">仕事を知る</a></li>\r\n    <li><a href=\"people.html\" class=\"sp-menu__link\">人を知る</a></li>\r\n    <li><a href=\"jobs.html\" class=\"sp-menu__link\">採用情報</a></li>\r\n  </ul>\r\n  <a href=\"jobs.html#apply\" class=\"sp-menu__cta\">まず話を聞いてみる（無料）</a>\r\n  <a href=\"jobs.html#apply\" class=\"sp-menu__cta sp-menu__cta--sub\">30秒でENTRY →</a>\r\n</div>\r\n\r\n<!-- ========================================\r\n     PAGE HERO\r\n======================================== -->\r\n<section class=\"page-hero\">\r\n  <div class=\"container page-hero__inner\">\r\n    <nav class=\"breadcrumb\" aria-label=\"パンくずリスト\">\r\n      <a href=\"index.html\">HOME</a>\r\n      <i class=\"fa-solid fa-chevron-right\"></i>\r\n      <span>仕事を知る</span>\r\n    </nav>\r\n    <span class=\"page-hero__en\">WHAT WE DO</span>\r\n    <h1 class=\"page-hero__title\">仕事を知る</h1>\r\n    <p class=\"page-hero__desc\">\r\n      人と企業をつなぐプロフェッショナルとして、<br>\r\n      私たちが日々向き合っている仕事をご紹介します。\r\n    </p>\r\n  </div>\r\n</section>\r\n\r\n<!-- ========================================\r\n     SEC 01: 仕事の全体像\r\n======================================== -->\r\n<section class=\"section-overview\">\r\n  <div class=\"container\">\r\n    <div class=\"overview-intro\" data-fade>\r\n      <div class=\"accent-line accent-line--center\"></div>\r\n      <h2 class=\"overview-intro__heading\">\r\n        「人の人生」に<br class=\"sp-only\">向き合う仕事です。\r\n      </h2>\r\n      <p class=\"overview-intro__body\">\r\n        キャリアネットワークには、大きく2つの職種があります。<br>\r\n        どちらも「未経験スタート大歓迎」。必要なのは、人への関心と誠実さです。\r\n      </p>\r\n    </div>\r\n\r\n    <!-- 職種カード（2枚） -->\r\n    <div class=\"job-type-cards\">\r\n      <div class=\"job-type-card\" data-fade>\r\n        <div class=\"job-type-card__num\">01</div>\r\n        <div class=\"job-type-card__icon\"><i class=\"fa-solid fa-building-user\"></i></div>\r\n        <h3 class=\"job-type-card__title\">派遣コーディネーター</h3>\r\n        <p class=\"job-type-card__desc\">\r\n          企業の採用課題に向き合い、最適な人材を提案。<br>\r\n          法人担当として地域の会社を支える仕事。\r\n        </p>\r\n        <div class=\"job-type-card__tags\">\r\n          <span>法人営業</span><span>コーディネート</span><span>未経験OK</span>\r\n        </div>\r\n        <a href=\"#coordinator\" class=\"text-link\">詳しく見る <i class=\"fa-solid fa-arrow-down\"></i></a>\r\n      </div>\r\n\r\n      <div class=\"job-type-card\" data-fade>\r\n        <div class=\"job-type-card__num\">02</div>\r\n        <div class=\"job-type-card__icon\"><i class=\"fa-solid fa-person-chalkboard\"></i></div>\r\n        <h3 class=\"job-type-card__title\">キャリアアドバイザー</h3>\r\n        <p class=\"job-type-card__desc\">\r\n          求職者の転職・就職を個別にサポート。<br>\r\n          一人ひとりの人生に伴走するカウンセラー職。\r\n        </p>\r\n        <div class=\"job-type-card__tags\">\r\n          <span>個人向け</span><span>キャリア支援</span><span>未経験OK</span>\r\n        </div>\r\n        <a href=\"#advisor\" class=\"text-link\">詳しく見る <i class=\"fa-solid fa-arrow-down\"></i></a>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</section>\r\n\r\n<!-- ========================================\r\n     SEC 02: 派遣コーディネーター詳細\r\n======================================== -->\r\n<section class=\"section-job-detail section-job-detail--gray\" id=\"coordinator\">\r\n  <div class=\"container\">\r\n    <div class=\"job-detail-header\" data-fade>\r\n      <div class=\"job-detail-header__num\">01</div>\r\n      <span class=\"section-header__en\">STAFFING COORDINATOR</span>\r\n      <h2 class=\"section-header__ja\">派遣コーディネーター</h2>\r\n      <p class=\"section-header__desc\">\r\n        地域企業の「人の悩み」を解決するパートナーです。\r\n      </p>\r\n    </div>\r\n\r\n    <div class=\"job-detail-body\">\r\n      <!-- 左：写真＋概要 -->\r\n      <div class=\"job-detail-visual\" data-fade>\r\n        <div class=\"job-detail-img\">\r\n          <img src=\"images/work-proposal.jpg\" alt=\"派遣コーディネーターの業務シーン\" class=\"job-detail-img__photo\">\r\n          <div class=\"job-detail-img__badge\">未経験OK</div>\r\n        </div>\r\n        <div class=\"job-detail-summary\">\r\n          <div class=\"summary-item\">\r\n            <span class=\"summary-item__label\"><i class=\"fa-solid fa-briefcase\"></i> 雇用形態</span>\r\n            <span class=\"summary-item__val\">正社員（試用期間3ヶ月）</span>\r\n          </div>\r\n          <div class=\"summary-item\">\r\n            <span class=\"summary-item__label\"><i class=\"fa-solid fa-yen-sign\"></i> 月給</span>\r\n            <span class=\"summary-item__val\">22〜28万円（経験・スキル考慮）</span>\r\n          </div>\r\n          <div class=\"summary-item\">\r\n            <span class=\"summary-item__label\"><i class=\"fa-solid fa-location-dot\"></i> 勤務地</span>\r\n            <span class=\"summary-item__val\">福井県福井市（転勤なし）</span>\r\n          </div>\r\n          <div class=\"summary-item\">\r\n            <span class=\"summary-item__label\"><i class=\"fa-regular fa-clock\"></i> 勤務時間</span>\r\n            <span class=\"summary-item__val\">9:00〜18:00（休憩1h）</span>\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n      <!-- 右：仕事内容・やりがい -->\r\n      <div class=\"job-detail-text\" data-fade>\r\n        <div class=\"job-detail-section\">\r\n          <h3 class=\"job-detail-section__title\">\r\n            <span class=\"job-detail-section__icon\"><i class=\"fa-solid fa-list-check\"></i></span>\r\n            仕事内容\r\n          </h3>\r\n          <ul class=\"job-detail-list\">\r\n            <li>担当企業への訪問・ヒアリング（月10〜20社）</li>\r\n            <li>求人票の作成・求人媒体への掲載管理</li>\r\n            <li>スタッフ（派遣社員）とのマッチング・面談調整</li>\r\n            <li>就業後のフォロー・定着支援</li>\r\n            <li>新規企業開拓（テレアポ・飛び込みなし。紹介・インバウンド中心）</li>\r\n          </ul>\r\n        </div>\r\n\r\n        <div class=\"job-detail-section\">\r\n          <h3 class=\"job-detail-section__title\">\r\n            <span class=\"job-detail-section__icon\"><i class=\"fa-solid fa-heart\"></i></span>\r\n            この仕事のやりがい\r\n          </h3>\r\n          <div class=\"appeal-cards\">\r\n            <div class=\"appeal-card\">\r\n              <i class=\"fa-solid fa-handshake\"></i>\r\n              <p>企業と求職者の両方から「ありがとう」をもらえる、二重の達成感</p>\r\n            </div>\r\n            <div class=\"appeal-card\">\r\n              <i class=\"fa-solid fa-chart-line\"></i>\r\n              <p>担当企業が成長するのを間近で見られる、長期的なパートナーシップ</p>\r\n            </div>\r\n            <div class=\"appeal-card\">\r\n              <i class=\"fa-solid fa-map-location-dot\"></i>\r\n              <p>地域に根ざした仕事で、自分が住む街を支えている実感</p>\r\n            </div>\r\n          </div>\r\n        </div>\r\n\r\n        <div class=\"job-detail-section\">\r\n          <h3 class=\"job-detail-section__title\">\r\n            <span class=\"job-detail-section__icon\"><i class=\"fa-solid fa-user-check\"></i></span>\r\n            求める人物像\r\n          </h3>\r\n          <div class=\"persona-tags\">\r\n            <span><i class=\"fa-solid fa-check\"></i> 人と話すことが好き</span>\r\n            <span><i class=\"fa-solid fa-check\"></i> 調整・段取りが得意</span>\r\n            <span><i class=\"fa-solid fa-check\"></i> 地域の役に立ちたい</span>\r\n            <span><i class=\"fa-solid fa-check\"></i> 素直に学べる</span>\r\n            <span><i class=\"fa-solid fa-check\"></i> 前職：サービス業・事務・販売など歓迎</span>\r\n          </div>\r\n        </div>\r\n\r\n        <a href=\"jobs.html#coordinator\" class=\"btn-primary\">\r\n          <i class=\"fa-solid fa-arrow-right\"></i>\r\n          求人詳細・応募はこちら\r\n        </a>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</section>\r\n\r\n<!-- ========================================\r\n     SEC 03: キャリアアドバイザー詳細\r\n======================================== -->\r\n<section class=\"section-job-detail\" id=\"advisor\">\r\n  <div class=\"container\">\r\n    <div class=\"job-detail-header\" data-fade>\r\n      <div class=\"job-detail-header__num\">02</div>\r\n      <span class=\"section-header__en\">CAREER ADVISOR</span>\r\n      <h2 class=\"section-header__ja\">キャリアアドバイザー</h2>\r\n      <p class=\"section-header__desc\">\r\n        求職者の「一歩」に伴走する、人生相談のプロです。\r\n      </p>\r\n    </div>\r\n\r\n    <div class=\"job-detail-body job-detail-body--reverse\">\r\n      <!-- 左：仕事内容・やりがい -->\r\n      <div class=\"job-detail-text\" data-fade>\r\n        <div class=\"job-detail-section\">\r\n          <h3 class=\"job-detail-section__title\">\r\n            <span class=\"job-detail-section__icon\"><i class=\"fa-solid fa-list-check\"></i></span>\r\n            仕事内容\r\n          </h3>\r\n          <ul class=\"job-detail-list\">\r\n            <li>求職者との個別キャリアカウンセリング（1日4〜8件）</li>\r\n            <li>希望・スキルに合った求人のご提案</li>\r\n            <li>履歴書・職務経歴書の添削サポート</li>\r\n            <li>面接対策・模擬面接の実施</li>\r\n            <li>内定後の入社フォロー・入社後の定着支援</li>\r\n          </ul>\r\n        </div>\r\n\r\n        <div class=\"job-detail-section\">\r\n          <h3 class=\"job-detail-section__title\">\r\n            <span class=\"job-detail-section__icon\"><i class=\"fa-solid fa-heart\"></i></span>\r\n            この仕事のやりがい\r\n          </h3>\r\n          <div class=\"appeal-cards\">\r\n            <div class=\"appeal-card\">\r\n              <i class=\"fa-solid fa-face-smile\"></i>\r\n              <p>「転職して人生が変わった」という言葉が、この仕事を続ける理由</p>\r\n            </div>\r\n            <div class=\"appeal-card\">\r\n              <i class=\"fa-solid fa-magnifying-glass-chart\"></i>\r\n              <p>人の強みを引き出す面談力が、確実に自分のスキルになっていく</p>\r\n            </div>\r\n            <div class=\"appeal-card\">\r\n              <i class=\"fa-solid fa-people-arrows\"></i>\r\n              <p>悩んでいた人が自信をもって前に進む瞬間に立ち会える感動</p>\r\n            </div>\r\n          </div>\r\n        </div>\r\n\r\n        <div class=\"job-detail-section\">\r\n          <h3 class=\"job-detail-section__title\">\r\n            <span class=\"job-detail-section__icon\"><i class=\"fa-solid fa-user-check\"></i></span>\r\n            求める人物像\r\n          </h3>\r\n          <div class=\"persona-tags\">\r\n            <span><i class=\"fa-solid fa-check\"></i> 人の話を聞くのが好き</span>\r\n            <span><i class=\"fa-solid fa-check\"></i> 共感力・傾聴力がある</span>\r\n            <span><i class=\"fa-solid fa-check\"></i> 相手の立場で考えられる</span>\r\n            <span><i class=\"fa-solid fa-check\"></i> 粘り強くサポートできる</span>\r\n            <span><i class=\"fa-solid fa-check\"></i> 前職：接客・教育・福祉など歓迎</span>\r\n          </div>\r\n        </div>\r\n\r\n        <a href=\"jobs.html#advisor\" class=\"btn-primary\">\r\n          <i class=\"fa-solid fa-arrow-right\"></i>\r\n          求人詳細・応募はこちら\r\n        </a>\r\n      </div>\r\n\r\n      <!-- 右：写真＋概要 -->\r\n      <div class=\"job-detail-visual\" data-fade>\r\n        <div class=\"job-detail-img\">\r\n          <img src=\"images/work-consultation.jpg\" alt=\"キャリアアドバイザーの業務シーン\" class=\"job-detail-img__photo\">\r\n          <div class=\"job-detail-img__badge\">第二新卒歓迎</div>\r\n        </div>\r\n        <div class=\"job-detail-summary\">\r\n          <div class=\"summary-item\">\r\n            <span class=\"summary-item__label\"><i class=\"fa-solid fa-briefcase\"></i> 雇用形態</span>\r\n            <span class=\"summary-item__val\">正社員（試用期間3ヶ月）</span>\r\n          </div>\r\n          <div class=\"summary-item\">\r\n            <span class=\"summary-item__label\"><i class=\"fa-solid fa-yen-sign\"></i> 月給</span>\r\n            <span class=\"summary-item__val\">22〜28万円（経験・スキル考慮）</span>\r\n          </div>\r\n          <div class=\"summary-item\">\r\n            <span class=\"summary-item__label\"><i class=\"fa-solid fa-location-dot\"></i> 勤務地</span>\r\n            <span class=\"summary-item__val\">福井県福井市（転勤なし）</span>\r\n          </div>\r\n          <div class=\"summary-item\">\r\n            <span class=\"summary-item__label\"><i class=\"fa-regular fa-clock\"></i> 勤務時間</span>\r\n            <span class=\"summary-item__val\">9:00〜18:00（休憩1h）</span>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</section>\r\n\r\n<!-- ========================================\r\n     SEC 04: 1日の流れ\r\n======================================== -->\r\n<section class=\"section-timeline\">\r\n  <div class=\"container\">\r\n    <div class=\"section-header section-header--center\" data-fade>\r\n      <span class=\"section-header__en\">A DAY IN THE LIFE</span>\r\n      <h2 class=\"section-header__ja\">1日の流れ</h2>\r\n      <p class=\"section-header__desc\">派遣コーディネーターの、ある1日をご紹介します。</p>\r\n    </div>\r\n\r\n    <div class=\"timeline\">\r\n      <div class=\"timeline-item\" data-fade>\r\n        <div class=\"timeline-item__time\">09:00</div>\r\n        <div class=\"timeline-item__dot\"></div>\r\n        <div class=\"timeline-item__content\">\r\n          <h4>出社・メールチェック</h4>\r\n          <p>前日の問い合わせ・スタッフからの連絡を確認。今日の訪問先と商談内容を頭に入れる。</p>\r\n        </div>\r\n      </div>\r\n      <div class=\"timeline-item\" data-fade>\r\n        <div class=\"timeline-item__time\">10:00</div>\r\n        <div class=\"timeline-item__dot\"></div>\r\n        <div class=\"timeline-item__content\">\r\n          <h4>企業訪問（午前1〜2社）</h4>\r\n          <p>担当企業を訪問し、現在の採用状況・人材ニーズをヒアリング。新しい求人につながることも。</p>\r\n        </div>\r\n      </div>\r\n      <div class=\"timeline-item\" data-fade>\r\n        <div class=\"timeline-item__time\">12:00</div>\r\n        <div class=\"timeline-item__dot\"></div>\r\n        <div class=\"timeline-item__content\">\r\n          <h4>ランチ・休憩</h4>\r\n          <p>チームでランチに出ることも。業務外の会話が多くチームの雰囲気を実感できる時間。</p>\r\n        </div>\r\n      </div>\r\n      <div class=\"timeline-item\" data-fade>\r\n        <div class=\"timeline-item__time\">13:00</div>\r\n        <div class=\"timeline-item__dot\"></div>\r\n        <div class=\"timeline-item__content\">\r\n          <h4>マッチング・提案業務</h4>\r\n          <p>午前のヒアリングをもとに、社内DBからスタッフをピックアップ。プロフィール資料を作成し企業へ提案。</p>\r\n        </div>\r\n      </div>\r\n      <div class=\"timeline-item\" data-fade>\r\n        <div class=\"timeline-item__time\">15:00</div>\r\n        <div class=\"timeline-item__dot\"></div>\r\n        <div class=\"timeline-item__content\">\r\n          <h4>スタッフ面談・フォロー</h4>\r\n          <p>就業中スタッフの状況確認面談。「仕事は慣れてきた？」など、小さな悩みを早めにキャッチ。</p>\r\n        </div>\r\n      </div>\r\n      <div class=\"timeline-item\" data-fade>\r\n        <div class=\"timeline-item__time\">17:00</div>\r\n        <div class=\"timeline-item__dot\"></div>\r\n        <div class=\"timeline-item__content\">\r\n          <h4>報告書・翌日準備</h4>\r\n          <p>訪問記録の入力、翌日の訪問スケジュール確認。基本残業は月10〜20時間程度。</p>\r\n        </div>\r\n      </div>\r\n      <div class=\"timeline-item timeline-item--end\" data-fade>\r\n        <div class=\"timeline-item__time\">18:00</div>\r\n        <div class=\"timeline-item__dot timeline-item__dot--end\"></div>\r\n        <div class=\"timeline-item__content\">\r\n          <h4>退社</h4>\r\n          <p>定時退社が基本。帰り道に明日の企業訪問でどんな提案をするか考えながら帰宅。</p>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</section>\r\n\r\n<!-- ========================================\r\n     SEC 05: 研修・成長ステップ\r\n======================================== -->\r\n<section class=\"section-growth\">\r\n  <div class=\"container\">\r\n    <div class=\"section-header\" data-fade>\r\n      <span class=\"section-header__en\">GROWTH PATH</span>\r\n      <h2 class=\"section-header__ja\">入社してからの成長ステップ</h2>\r\n      <p class=\"section-header__desc\">未経験でも、段階を踏んで確実にプロになれる環境があります。</p>\r\n    </div>\r\n\r\n    <div class=\"growth-steps\">\r\n      <div class=\"growth-step\" data-fade>\r\n        <div class=\"growth-step__phase\">入社1〜3ヶ月</div>\r\n        <div class=\"growth-step__title\">研修フェーズ</div>\r\n        <ul class=\"growth-step__items\">\r\n          <li>業界・会社の基礎知識</li>\r\n          <li>社内システムの操作研修</li>\r\n          <li>ロールプレイング（面談・営業）</li>\r\n          <li>先輩への同行訪問</li>\r\n        </ul>\r\n        <div class=\"growth-step__goal\">目標：ひとり立ちの準備完了</div>\r\n      </div>\r\n\r\n      <div class=\"growth-step__arrow\" data-fade><i class=\"fa-solid fa-chevron-right\"></i></div>\r\n\r\n      <div class=\"growth-step\" data-fade>\r\n        <div class=\"growth-step__phase\">入社4〜12ヶ月</div>\r\n        <div class=\"growth-step__title\">独り立ちフェーズ</div>\r\n        <ul class=\"growth-step__items\">\r\n          <li>担当企業・担当スタッフを持つ</li>\r\n          <li>週次の1on1でフィードバック</li>\r\n          <li>小さな成功体験を積み重ねる</li>\r\n          <li>専門知識の自己学習支援あり</li>\r\n        </ul>\r\n        <div class=\"growth-step__goal\">目標：初めての「成約」を体験</div>\r\n      </div>\r\n\r\n      <div class=\"growth-step__arrow\" data-fade><i class=\"fa-solid fa-chevron-right\"></i></div>\r\n\r\n      <div class=\"growth-step\" data-fade>\r\n        <div class=\"growth-step__phase\">入社2年目以降</div>\r\n        <div class=\"growth-step__title\">戦力フェーズ</div>\r\n        <ul class=\"growth-step__items\">\r\n          <li>担当企業・スタッフ数が増加</li>\r\n          <li>後輩のOJTを担当</li>\r\n          <li>資格取得支援（派遣検定 等）</li>\r\n          <li>チームリーダー候補へ</li>\r\n        </ul>\r\n        <div class=\"growth-step__goal\">目標：チームを引っ張る存在に</div>\r\n      </div>\r\n    </div>\r\n\r\n    <div class=\"growth-note\" data-fade>\r\n      <i class=\"fa-solid fa-circle-info\"></i>\r\n      <p>成長スピードは個人差があります。焦らず、自分のペースで進める環境です。先輩が必ずフォローします。</p>\r\n    </div>\r\n  </div>\r\n</section>\r\n\r\n<!-- ========================================\r\n     SEC 06: 先輩の声（リンク）\r\n======================================== -->\r\n<section class=\"section-voice-link\">\r\n  <div class=\"container\">\r\n    <div class=\"voice-link-inner\" data-fade>\r\n      <div class=\"voice-link-text\">\r\n        <span class=\"section-header__en\">FROM OUR TEAM</span>\r\n        <h2 class=\"voice-link-text__heading\">\r\n          実際に働く先輩の声を<br>聞いてみませんか？\r\n        </h2>\r\n        <p>未経験から入社した先輩たちが、リアルな体験を語っています。</p>\r\n        <a href=\"people.html\" class=\"btn-primary\">\r\n          <i class=\"fa-solid fa-users\"></i>\r\n          社員インタビューを見る\r\n        </a>\r\n      </div>\r\n      <div class=\"voice-link-photos pc-only\">\r\n        <div class=\"voice-link-photos__grid\">\r\n          <img src=\"images/staff-a.jpg\" alt=\"社員A\" class=\"voice-link-photo voice-link-photo--a\">\r\n          <img src=\"images/staff-b.jpg\" alt=\"社員B\" class=\"voice-link-photo voice-link-photo--b\">\r\n          <img src=\"images/staff-c.jpg\" alt=\"社員C\" class=\"voice-link-photo voice-link-photo--c\">\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</section>\r\n\r\n<!-- ========================================\r\n     BOTTOM CTA\r\n======================================== -->\r\n<section class=\"section-cta-band\">\r\n  <div class=\"container\">\r\n    <p class=\"cta-band__en\">JOIN US</p>\r\n    <h2 class=\"cta-band__heading\">まずは話を聞くだけでも大丈夫。</h2>\r\n    <p class=\"cta-band__sub\">選考なし・無料のカジュアル面談で、<br>仕事の雰囲気を直接感じてみてください。</p>\r\n    <div class=\"cta-band__btns\">\r\n      <a href=\"jobs.html#apply\" class=\"cta-band__btn--primary\">\r\n        <i class=\"fa-solid fa-calendar-check\"></i> カジュアル面談を予約（無料）\r\n      </a>\r\n      <a href=\"jobs.html#apply\" class=\"cta-band__btn--line\">\r\n        <i class=\"fa-brands fa-line\"></i> LINEで問い合わせ\r\n      </a>\r\n      <a href=\"jobs.html#apply\" class=\"cta-band__btn--casual\">\r\n        <i class=\"fa-solid fa-bolt\"></i> 30秒でENTRY\r\n      </a>\r\n    </div>\r\n  </div>\r\n</section>\r\n\r\n<!-- ========================================\r\n     FOOTER\r\n======================================== -->\r\n<footer class=\"site-footer\">\r\n  <div class=\"container\">\r\n    <div class=\"site-footer__top\">\r\n      <div class=\"site-footer__brand\">\r\n        <div class=\"site-footer__logo\">\r\n          <img src=\"images/logo.webp\" width=\"200\">\r\n          <span class=\"site-footer__logo-text\">キャリアネットワーク<span>RECRUIT</span></span>\r\n        </div>\r\n        <p class=\"site-footer__catchcopy\">学歴より、熱意。<br>未経験から、人材のプロへ。</p>\r\n        <div class=\"site-footer__sns\">\r\n          <a href=\"https://www.instagram.com/fukui_tenshoku/\" aria-label=\"Instagram\"><i class=\"fa-brands fa-instagram\"></i></a>\r\n          <a href=\"https://x.com/fukui_tenshoku\" aria-label=\"Twitter/X\"><i class=\"fa-brands fa-x\"></i></a>\r\n          <a href=\"https://page.line.me/824ylbtv?openQrModal=true\" aria-label=\"LINE\"><i class=\"fa-brands fa-line\"></i></a>\r\n        </div>\r\n      </div>\r\n      <div class=