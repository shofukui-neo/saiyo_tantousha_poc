{"url":"https://digital.panasonic.co.jp/recruit/","html":"<!DOCTYPE html>\n<html lang=\"ja\" xmlns:mso=\"urn:schemas-microsoft-com:office:office\" xmlns:msdt=\"uuid:C2F41010-65B3-11d1-A29F-00AA00C14882\">\n<head>\n<meta charset=\"UTF-8\">\n<meta http-equiv=\"content-language\" content=\"ja\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1, maximum-scale=1\">\n<title>採用情報 | パナソニック デジタル</title>\n<meta name=\"keywords\" content=\"パナソニック,Panasonic,パナソニックIS ,パナソニック デジタル 採用情報, Panasonic Information Systems,企業情報\">\n<meta name=\"description\" content=\" ,パナソニック デジタル株式会社は、約60年にわたる豊富なシステム構築経験と運用ノウハウを強みとし、システムイ ンテグレーション、アウトソーシング、ソフトウエアの開発、販売等を行っています。このサイトでは当社の採用情報をご覧いただけます。\">\n<link rel=\"stylesheet\" type=\"text/css\" href=\"css/style.css\" />\n<link rel=\"stylesheet\" type=\"text/css\" href=\"css/jquery.bxslider.css\" />\n<link rel=\"stylesheet\" type=\"text/css\" href=\"css/modaal.css\" />\n<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n<link href=\"https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;700&family=Comfortaa:wght@400;700&&display=swap\" rel=\"stylesheet\">\n<script src=\"js/jquery-3.6.1.min.js\"></script>\n<script src=\"js/jquery.bxslider.js\"></script>\n<script src=\"js/common.js\"></script>\n<!-- Google tag (gtag.js) -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-Q1W47H5ME4\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n  gtag('config', 'G-Q1W47H5ME4');\n</script>\n<!-- Meta Pixel Code -->\n<script>\n  !function(f,b,e,v,n,t,s)\n  {if(f.fbq)return;n=f.fbq=function(){n.callMethod?\n  n.callMethod.apply(n,arguments):n.queue.push(arguments)};\n  if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';\n  n.queue=[];t=b.createElement(e);t.async=!0;\n  t.src=v;s=b.getElementsByTagName(e)[0];\n  s.parentNode.insertBefore(t,s)}(window, document,'script',\n  'https://connect.facebook.net/en_US/fbevents.js');\n  fbq('init', '592318079688822');\n  fbq('track', 'PageView');\n</script>\n<noscript><img height=\"1\" width=\"1\" style=\"display:none\"\n  src=\"https://www.facebook.com/tr?id=592318079688822&ev=PageView&noscript=1\"\n/></noscript>\n<!-- End Meta Pixel Code -->\n\n<!--[if gte mso 9]><xml>\n<mso:CustomDocumentProperties>\n<mso:xd_Signature msdt:dt=\"string\"></mso:xd_Signature>\n<mso:display_urn_x003a_schemas-microsoft-com_x003a_office_x003a_office_x0023_Editor msdt:dt=\"string\">&#27700;&#27969; &#29702;&#24693;</mso:display_urn_x003a_schemas-microsoft-com_x003a_office_x003a_office_x0023_Editor>\n<mso:Order msdt:dt=\"string\">682400.000000000</mso:Order>\n<mso:xd_ProgID msdt:dt=\"string\"></mso:xd_ProgID>\n<mso:_ExtendedDescription msdt:dt=\"string\"></mso:_ExtendedDescription>\n<mso:display_urn_x003a_schemas-microsoft-com_x003a_office_x003a_office_x0023_Author msdt:dt=\"string\">&#27700;&#27969; &#29702;&#24693;</mso:display_urn_x003a_schemas-microsoft-com_x003a_office_x003a_office_x0023_Author>\n<mso:ComplianceAssetId msdt:dt=\"string\"></mso:ComplianceAssetId>\n<mso:TemplateUrl msdt:dt=\"string\"></mso:TemplateUrl>\n<mso:ContentTypeId msdt:dt=\"string\">0x0101000C9476831829A84E900CF7CF49F6C484</mso:ContentTypeId>\n<mso:TriggerFlowInfo msdt:dt=\"string\"></mso:TriggerFlowInfo>\n<mso:_SourceUrl msdt:dt=\"string\"></mso:_SourceUrl>\n<mso:_SharedFileIndex msdt:dt=\"string\"></mso:_SharedFileIndex>\n<mso:TaxCatchAll msdt:dt=\"string\"></mso:TaxCatchAll>\n<mso:MediaServiceImageTags msdt:dt=\"string\"></mso:MediaServiceImageTags>\n<mso:lcf76f155ced4ddcb4097134ff3c332f msdt:dt=\"string\"></mso:lcf76f155ced4ddcb4097134ff3c332f>\n</mso:CustomDocumentProperties>\n</xml><![endif]-->\n</head>\n\n<body class=\"front-page\">\n<div id=\"header\">\n<div id=\"header-inner\" class=\"front-head\">\n<div id=\"header-logo\"><img src=\"images/logo-white.png\" alt=\"パナソニック ロゴ\" class=\"front-page-logo\"></div>\n<div id=\"header-logo-info\">パナソニック デジタル<br>RECRUITING SITE</div>\n<div id=\"header-btns\">\n<div class=\"to-corp-btn\"><a href=\"https://digital.panasonic.co.jp/\" target=\"_blank\">企業サイトへ</a></div>\n\n<div class=\"entry-btn\"><a href=\"entry/index.html\">ENTRY</a></div>\n</div>\n<div class=\"sp-menu-btn-box\">\n<a id=\"open-sp-menu\" href=\"#sp-menu\" class=\"fullscreen non-scroll sp-menu-btn sp-menu-btn-open\"><span></span><span></span><span></span></a>\n<div class=\"modaal-close close-sp-menu close-animatedModal\"></div>\n</div>\n</div>\n</div>\n\n\n\n\n<div id=\"top-main-v\" class=\"fade-in01 effect-scroll\">\n<div class=\"top-main-half\">\n<ul>\n<li><img src=\"images/top-main01.jpg\" alt=\"イメージ\"></li>\n<li><img src=\"images/top-main02.jpg\" alt=\"イメージ\"></li>\n<li><img src=\"images/top-main03.jpg\" alt=\"イメージ\"></li>\n<li><img src=\"images/top-main04.jpg\" alt=\"イメージ\"></li>\n</ul>\n</div>\n\n<div id=\"top-main-overlay\"></div>\n<div id=\"top-main-cont\">\n<img src=\"images/top-main-catch.png\" alt=\"イメージ\">\n<p class=\"main-company-name\">Panasonic Digital Co., Ltd.</p>\n<div class=\"main-site-info\">RECRUITING SITE</div>\n</div>\n<div class=\"scrolldown\"><p>SCROLL</p></div>\n\n</div>\n\n\n<div class=\"top-message-sec\">\n<div class=\"top-message-sec-ttl fade-in effect-scroll\">Message</div>\n\n<div class=\"top-message-cont\">\n\n<div class=\"top-message01 fade-in02 effect-scroll\">\nつながる、個の知恵から架空へ<br>\n一人の知恵では届かない答えがある。<br>\nだからこそ、速く、広く、深く、共創する。<br class=\"under700\">最良の結論のために。\n</div>\n\n<div class=\"top-message02 fade-in02 effect-scroll\">\nつながる、データを新たな価値へ<br>\nデータの奥には、まだ見ぬ可能性がある。<br>\n見つけ、考え、カタチにする。<br>\n想像を超える、新たな価値へ。\n</div>\n\n<div class=\"top-message03 fade-in02 effect-scroll\">\nつながる、社会とお客さまの幸せへ<br>\nお客さまの声に耳を傾き、共に課題に向き合う。<br>\n信頼を土台に、デジタルで解決する。\n</div>\n\n<div class=\"top-message04 fade-in02 effect-scroll\">\nすべては、お客さまの<br>\n「くらし」と「しごと」のために。\n</div>\n</div>\n</div>\n\n\n\n<div class=\"front-pege-content\">\n\n\n<div class=\"front-about-sec\">\n<div class=\"front-about-cont top-move-up effect-scroll\">\n<div class=\"front-about-sec-ttl\">\n<h2 class=\"front-sec-ttl\">About Us</h2>\n<div class=\"front-sec-ttl-sub\"><img src=\"images/top-about-jp.png\" alt=\"私たちのこと\"></div>\n</div>\n<p>\nパナソニックのIT事業会社として、パナソニックが展開する全ての分野において、パナソニックと一体となって仕事を進めている私たち。ものづくりのプロセスや会社経営に関わる様々なITソリューションを提供しています。ここでは、そんな私たちの概要や強みをご紹介します。<br>\n</p>\n\n<div class=\"front-about-btn-box\">\n\n<div class=\"front-about-btn\">\n<a href=\"about-us/about.html\">\n<img src=\"images/top-about-btn01.jpg\" alt=\"イメージ\" class=\"img100\">\n<div class=\"front-about-btn-ttl\">私たちについて</div>\n</a>\n</div>\n<div class=\"front-about-btn\">\n<a href=\"about-us/movie.html\">\n<img src=\"images/top-about-btn-movie.jpg\" alt=\"イメージ\" class=\"img100\">\n<div class=\"front-about-btn-ttl\">動画で知る！私たち</div>\n</a>\n</div>\n<div class=\"front-about-btn\">\n<a href=\"about-us/numbers.html\">\n<img src=\"images/top-about-btn02.jpg\" alt=\"イメージ\" class=\"img100\">\n<div class=\"front-about-btn-ttl\">数字で知る！<br><span>私たちの強み</span></div>\n</a>\n</div>\n<div class=\"front-about-btn\">\n<a href=\"about-us/keywords.html\">\n<img src=\"images/top-about-btn03.jpg\" alt=\"イメージ\" class=\"img100\">\n<div class=\"front-about-btn-ttl\">キーワードで知る！<br><span>私たちの特徴</span></div>\n</a>\n</div>\n<div class=\"front-about-btn\">\n<a href=\"about-us/numbers-of-woman.html\">\n<img src=\"images/top-about-btn04.jpg\" alt=\"イメージ\" class=\"img100\">\n<div class=\"front-about-btn-ttl\">数字で知る！<br><span>女性社員の活躍</span></div>\n</a>\n</div>\n</div>\n</div>\n<div class=\"front-about-sec-bg\"></div>\n</div>\n\n<div class=\"front-business-sec\">\n<div class=\"front-business-sec-cont top-move-up effect-scroll\">\n<div class=\"front-business-sec-ttl\">\n<h2 class=\"front-sec-ttl\">Business</h2>\n<div class=\"front-sec-ttl-sub\"><img src=\"images/top-business-jp.png\" alt=\"事業について\"></div>\n</div>\n<p>\nパナソニックグループ内各社はもちろん、グループ外のお客様ともお取引をしている私たち。<br>\nここでは、グループ内・グループ外それぞれにおける、当社の事業をご紹介します。\n</p>\n<div class=\"front-business-sec-btn-box\">\n<div class=\"front-business-sec-btn-once\">\n<a href=\"business/inside-group.html\">\n<img src=\"images/top-business-img01.jpg\" alt=\"イメージ\" class=\"img100\">\n<div class=\"front-business-sec-btn-ttl\">パナソニックグループでのビジネス</div>\n</a>\n</div>\n<div class=\"front-business-sec-btn-once\">\n<a href=\"business/outside-group.html\">\n<img src=\"images/top-business-img02.jpg\" alt=\"イメージ\" class=\"img100\">\n<div class=\"front-business-sec-btn-ttl\">グループ外のお客様とのビジネス</div>\n</a>\n</div>\n</div>\n</div>\n<div class=\"front-business-sec-bg\"></div>\n</div>\n\n<div class=\"front-flow-sec\">\n<div class=\"front-flow-cont top-move-up effect-scroll\">\n<div class=\"front-flow-sec-ttl\">\n<h2 class=\"front-sec-ttl\">Flow</h2>\n<div class=\"front-sec-ttl-sub\"><img src=\"images/top-flow-jp.png\" alt=\"業務プロセスの流れ\"></div>\n</div>\n<p>\nIT戦略の企画段階から参画し、お客様のビジネスそのものと深く関わる当社の、業務プロセスの流れをご紹介します。\n</p>\n<a href=\"flow/process.html\">\n<img src=\"images/top-flow-img.jpg\" alt=\"イメージ\" class=\"img100\">\n</a>\n</div>\n<div class=\"front-flow-sec-bg\"></div>\n</div>\n\n<div class=\"front-people-sec\">\n<div class=\"front-people-sec-cont top-move-up effect-scroll\">\n<div class=\"front-people-sec-ttl\">\n<h2 class=\"front-sec-ttl\">Work&amp;People</h2>\n<div class=\"front-sec-ttl-sub\"><img src=\"images/top-people-jp.png\" alt=\"仕事と社員について\"></div>\n</div>\n<div class=\"front-work-btn-box\">\n<div class=\"front-work-btn\">\n<a href=\"work-people/job-category.html\">\n<img src=\"images/top-job-img.jpg\" alt=\"イメージ\" class=\"img100\">\n<div class=\"front-work-btn-ttl\">職種紹介</div>\n</a>\n</div>\n</div>\n<div class=\"front-people-btn-box\">\n<div class=\"front-people-btn-once\">\n<a href=\"work-people/inoue.html\">\n<img src=\"images/top-people01.jpg\" alt=\"イメージ\" class=\"img100\">\n<div class=\"front-people-btn-once-tag tag-type-01\">一般市場</div>\n<div class=\"front-people-btn-once-prof\">\n<div class=\"front-people-btn-once-prof-name\">井上 温子</div>\n<div class=\"front-people-btn-once-prof-dev\">\n2005年入社<br>\n理工学部　情報システム工学科卒\n</div>\n</div>\n</a>\n</div>\n<div class=\"front-people-btn-once\">\n<a href=\"work-people/minamitani.html\">\n<img src=\"images/top-people02.jpg\" alt=\"イメージ\" class=\"img100\">\n<div class=\"front-people-btn-once-tag tag-type-02\">データ分析</div>\n<div class=\"front-people-btn-once-prof\">\n<div class=\"front-people-btn-once-prof-name\">南谷 祥之</div>\n<div class=\"front-people-btn-once-prof-dev\">\n2013年入社<br>\n工学研究科　情報工学専攻卒<br>\n</div>\n</div>\n</a>\n</div>\n<div class=\"front-people-btn-once\">\n<a href=\"work-people/muro.html\">\n<img src=\"images/top-people03.jpg\" alt=\"イメージ\" class=\"img100\">\n<div class=\"front-people-btn-once-tag tag-type-03\">IoT/DX</div>\n<div class=\"front-people-btn-once-prof\">\n<div class=\"front-people-btn-once-prof-name\">室 晶彦</div>\n<div class=\"front-people-btn-once-prof-dev\">\n2009年入社<br>\n工学部 情報システム工学科卒\n</div>\n</div>\n</a>\n</div>\n<div class=\"front-people-btn-once\">\n<a href=\"work-people/nakamura.html\">\n<img src=\"images/top-people04.jpg\" alt=\"イメージ\" class=\"img100\">\n<div class=\"front-people-btn-once-tag tag-type-04\">グローバル</div>\n<div class=\"front-people-btn-once-prof\">\n<div class=\"front-people-btn-once-prof-name\">中村 亮</div>\n<div class=\"front-people-btn-once-prof-dev\">\n2010年入社<br>\n情報理工学部 メディア情報学科卒\n</div>\n</div>\n</a>\n</div>\n<div class=\"front-people-btn-once\">\n<a href=\"work-people/takahashi.html\">\n<img src=\"images/top-people05.jpg\" alt=\"イメージ\" class=\"img100\">\n<div class=\"front-people-btn-once-tag tag-type-05\">クラウド</div>\n<div class=\"front-people-btn-once-prof\">\n<div class=\"front-people-btn-once-prof-name\">高橋 僚</div>\n<div class=\"front-people-btn-once-prof-dev\">\n2014年入社<br>\nシステム理工学部 物理・応用物理学科卒\n</div>\n</div>\n</a>\n</div>\n<div class=\"front-people-btn-once\">\n<a href=\"work-people/taniguchi.html\">\n<img src=\"images/top-people06.jpg\" alt=\"イメージ\" class=\"img100\">\n<div class=\"front-people-btn-once-tag tag-type-06\">チームリーダー</div>\n<div class=\"front-people-btn-once-prof\">\n<div class=\"front-people-btn-once-prof-name\">谷口 由起</div>\n<div class=\"front-people-btn-once-prof-dev\">\n2008年入社<br>\n教育学部 教養学科卒\n</div>\n</div>\n</a>\n</div>\n<div class=\"front-people-btn-once\">\n<a href=\"work-people/hori.html\">\n<img src=\"images/top-people07.jpg\" alt=\"イメージ\" class=\"img100\">\n<div class=\"front-people-btn-once-tag tag-type-07\">ECサイト</div>\n<div class=\"front-people-btn-once-prof\">\n<div class=\"front-people-btn-once-prof-name\">堀 祐豪</div>\n<div class=\"front-people-btn-once-prof-dev\">\n2011年入社<br>\n工学部 応用理工学科卒\n</div>\n</div>\n</a>\n</div>\n<div class=\"front-people-btn-once\">\n<a href=\"work-people/makigano.html\">\n<img src=\"images/top-people08.jpg\" alt=\"イメージ\" class=\"img100\">\n<div class=\"front-people-btn-once-tag tag-type-08\">データ分析</div>\n<div class=\"front-people-btn-once-prof\">\n<div class=\"front-people-btn-once-prof-name\">牧ヶ野 衣里</div>\n<div class=\"front-people-btn-once-prof-dev\">\n2012年入社<br>\n人間発達環境学研究科 生活環境学専攻卒\n</div>\n</div>\n</a>\n</div>\n\n<div class=\"front-people-btn-once-full\">\n<a href=\"work-people/talk.html\">\n<img src=\"images/top-talk-img.jpg\" alt=\"イメージ\" class=\"img100\">\n<div class=\"front-people-btn-once-prof2\">\n<div class=\"front-people-btn-once-talk-name\">理系女子座談会</div>\n</div>\n</a>\n</div>\n\n<div class=\"front-people-btn-once-full add-nmgt\">\n<a href=\"work-people/talk-parental.html\">\n<img src=\"images/top-talk-parental.jpg\" alt=\"イメージ\" class=\"img100\">\n<div class=\"front-people-btn-once-prof2\">\n<div class=\"front-people-btn-once-talk-name\">育児休業取得者対談</div>\n</div>\n</a>\n</div>\n\n</div>\n</div>\n<div class=\"front-people-sec-bg\"></div>\n</div>\n\n\n\n<div class=\"front-special-sec-ttl\">\n<h2 class=\"front-sec-ttl\">Special Contents</h2>\n<div class=\"front-sec-ttl-sub\"><img src=\"images/top-special-jp.png\" alt=\"スペシャルコンテンツ\"></div>\n</div>\n<div class=\"front-special-sec\">\n<div class=\"front-special-sec-cont top-move-up effect-scroll\">\n<a href=\"special/challengers/index.html\">\n<img src=\"images/top-special02-img.jpg\" alt=\"イメージ\" class=\"img100\">\n<div class=\"front-special-sec-cont-btn-ttl\">CHALLENGERS 〜変革への挑戦者たち〜</div>\n</a>\n</div>\n<div class=\"front-special-sec-cont top-move-up effect-scroll\">\n<a href=\"special/transformation/index.html\">\n<img src=\"images/top-special01-img.jpg\" alt=\"イメージ\" class=\"img100\">\n<div class=\"front-special-sec-cont-btn-ttl\">TRANSFORMATION 〜未来への変革〜</div>\n</a>\n</div>\n<div class=\"front-special-sec-cont top-move-up effect-scroll\">\n<a href=\"special/womens-careers/index.html\">\n<img src=\"images/top-special03-img.jpg\" alt=\"イメージ\" class=\"img100\">\n<div class=\"front-special-sec-cont-btn-ttl\">女性社員のキャリア紹介</div>\n</a>\n</div>\n<div class=\"front-special-sec-bg\">\n</div>\n</div>\n\n\n\n\n<div class=\"front-recruit-sec\">\n\n<div class=\"front-recruit-sec-ttl\">\n<h2 class=\"front-sec-ttl\">Recruit Info</h2>\n<div class=\"front-sec-ttl-sub\"><img src=\"images/top-recruit-jp.png\" alt=\"採用情報\"></div>\n</div>\n\n<div class=\"front-recruit-sec-cont top-move-up effect-scroll\">\n<div class=\"front-recruit-sec-cont-btn-box\">\n\n<div class=\"front-recruit-sec-cont-btn-once\">\n<a href=\"recruit-info/support-system.html\">\n<img src=\"images/top-recruit-img05.jpg\" alt=\"イメージ\" class=\"img100\">\n<div class=\"front-recruit-btn-ttl\">出産・育児の<br>支援制度</div>\n</a>\n</div>\n\n<div class=\"front-recruit-sec-cont-btn-once\">\n<a href=\"recruit-info/career-step.html\">\n<img src=\"images/top-recruit-img01.jpg\" alt=\"イメージ\" class=\"img100\">\n<div class=\"front-recruit-btn-ttl\">キャリアステップ</div>\n</a>\n</div>\n\n<div class=\"front-recruit-sec-cont-btn-once\">\n<a href=\"recruit-info/education.html\">\n<img src=\"images/top-recruit-img02.jpg\" alt=\"イメージ\" class=\"img100\">\n<div class=\"front-recruit-btn-ttl\">新入社員<br>教育・研修</div>\n</a>\n</div>\n\n<div class=\"front-recruit-sec-cont-btn-once\">\n<a href=\"recruit-info/faq.ht