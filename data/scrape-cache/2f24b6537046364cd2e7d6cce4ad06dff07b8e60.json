ction\">\n\t\t\t\t\t\t\t\t<!-- <div class=\"recruit_block lastyear\">\n                  <div>\n                    <a href=\"https://aeonretail.snar.jp/login.aspx\" target=\"_blank\"><img src=\"/saiyo/newgraduate/img/common/2025mypage.png\" alt=\"MY PAGE 2025\" width=\"636\" height=\"126\" /></a>\n                  </div>\n                </div> -->\n                <div class=\"recruit_block\">\n                  <div>\n                    <a href=\"https://job.axol.jp/bx/s/aeonretail_27/mypage/login\" target=\"_blank\"><img src=\"/saiyo/newgraduate/img/common/2027mypage.png\" alt=\"MY PAGE 2027\" width=\"636\" height=\"126\" /></a>\n                  </div>\n                  <div>\n                    <a href=\"https://job.axol.jp/bx/s/aeonretail_27/entry/\" target=\"_blank\"><img src=\"/saiyo/newgraduate/img/common/2027entry.png\" alt=\"2027 ENTRY\" width=\"636\" height=\"126\"/></a>\n                  </div>\n                  <div>\n                    <a href=\"https://axol.jp/zw/s/aeonretail_28/mypage/login\" target=\"_blank\"><img src=\"/saiyo/newgraduate/img/common/2028mypage.png\" alt=\"MY PAGE 2028\" width=\"636\" height=\"126\" /></a>\n                  </div>\n                  <div>\n                    <a href=\"https://axol.jp/zw/s/aeonretail_28/entry/\" target=\"_blank\"><img src=\"/saiyo/newgraduate/img/common/2028entry.png\" alt=\"2028 ENTRY\" width=\"636\" height=\"126\"/></a>\n                  </div>\n                </div>\n                <div class=\"recruit2025\">\n                  <div>\n                    <span>RECRUIT</span>\n                    <p>\n                      <a href=\"https://job.mynavi.jp/27/pc/search/corp69194/outline.html\" target=\"_blank\">マイナビ2027<i></i></a>\n                    </p>\n                    <p>\n                      <a href=\"https://www.onecareer.jp/companies/4098\" target=\"_blank\">ONE CAREER<i></i></a>\n                    </p>\n                    <p>\n                      <a href=\"https://job.mynavi.jp/28/pc/search/corp69194/outline.html\" target=\"_blank\">マイナビ2028<i></i></a>\n                    </p>\n                  </div>\n                </div>\n                <div class=\"recruit_sns\">\n\t\t\t\t\t\t\t\t\t<a href=\"https://www.instagram.com/aeonretail_recruit/\" target=\"_blank\">\n\t\t\t\t\t\t\t\t\t<div class=\"instagram_wrap bottom\">\n\t\t\t\t\t\t\t\t\t\t<img src=\"/saiyo/newgraduate/img/common/Instagram_color.svg\" alt=\"Instagram\" width=\"44\" height=\"44\" />\n\t\t\t\t\t\t\t\t\t\t<p class=\"instagram_title\">新卒採用アカウント</p>\n\t\t\t\t\t\t\t\t\t</div></a>\n                </div>\n              </div>\n            </div>\n          </div>\n        </section>\n      </header>\n\n\n      <div class=\"main_contents\">\n        <div class=\"main_contents_inner\">\n          <section class=\"section top_kv\">\n            <h2 class=\"move_elm elm_tit js-action slideup\">未来の「お買物」はあなたがつくる。</h2>\n            <div>\n              <picture class=\"move_elm elm_basket js-action slideup\">\n                <source media=\"(max-width: 768px)\" srcset=\"/saiyo/newgraduate/img/top/sp/img-basket.png\" width=\"391\" height=\"395\" />\n                <img src=\"/saiyo/newgraduate/img/top/img-basket.png\" alt=\"\" width=\"450\" height=\"455\" loading=\"lazy\" />\n              </picture>\n              <picture class=\"move_elm elm_people_1 js-action slideup\">\n                <source media=\"(max-width: 768px)\" srcset=\"/saiyo/newgraduate/img/top/sp/img-people_1.png\" width=\"176\" height=\"195\" />\n                <img src=\"/saiyo/newgraduate/img/top/img-people_1.png\" alt=\"\" width=\"198\" height=\"220\" loading=\"lazy\" />\n              </picture>\n              <picture class=\"move_elm elm_phone js-action slideup\">\n                <source media=\"(max-width: 768px)\" srcset=\"/saiyo/newgraduate/img/top/sp/img-phone.png\" width=\"132\" height=\"236\" />\n                <img src=\"/saiyo/newgraduate/img/top/img-phone.png\" alt=\"\" width=\"150\" height=\"270\" loading=\"lazy\" />\n              </picture>\n              <picture class=\"move_elm elm_tomato js-action slideup\">\n                <source media=\"(max-width: 768px)\" srcset=\"/saiyo/newgraduate/img/top/sp/img-tomato.png\" width=\"555\" height=\"381\" />\n                <img src=\"/saiyo/newgraduate/img/top/img-tomato.png\" alt=\"\" width=\"587\" height=\"555\" loading=\"lazy\" />\n              </picture>\n              <picture class=\"move_elm elm_cake js-action slideup\">\n                <source media=\"(max-width: 768px)\" srcset=\"/saiyo/newgraduate/img/top/sp/img-cake.png\" width=\"266\" height=\"352\" />\n                <img src=\"/saiyo/newgraduate/img/top/img-cake.png\" alt=\"\" width=\"312\" height=\"417\" loading=\"lazy\" />\n              </picture>\n              <span class=\"move_elm elm_cloud_1 js-action slideup\"\n                ><img src=\"/saiyo/newgraduate/img/top/img-cloud1.png\" alt=\"\" class=\"pc_d\" width=\"1040\" height=\"417\" loading=\"lazy\" /><img\n                  src=\"/saiyo/newgraduate/img/top/sp/img-cloud_1.png\"\n                  alt=\"\"\n                  class=\"sp_d\"\n                  width=\"409\"\n                  height=\"549\"\n                  loading=\"lazy\"\n              /></span>\n              <span class=\"move_elm elm_cloud_2 js-action slideup\"\n                ><img src=\"/saiyo/newgraduate/img/top/img-cloud2.png\" alt=\"\" class=\"pc_d\" width=\"355\" height=\"163\" loading=\"lazy\" /><img\n                  src=\"/saiyo/newgraduate/img/top/sp/img-cloud2.png\"\n                  alt=\"\"\n                  class=\"sp_d\"\n                  width=\"324\"\n                  height=\"129\"\n                  loading=\"lazy\"\n              /></span>\n            </div>\n          </section>\n\n          <div class=\"top_description js-action slideup\">\n            <p>\n              イオンリテールは、<br class=\"smt\" />挑戦する人を全力で応援します。<br />\n              店舗運営から商品開発、デジタル販促まで。<br />\n              様々なフィールドで、<br class=\"smt\" />あなたの想いを支えていきたい。<br />\n              小売業のリーディングカンパニーだからこそ、<br />\n              新しいお買物体験をつくることができる。<br />\n              ワクワクするような未来のお買物は、<br class=\"smt\" />あなたの想いから生まれます。\n            </p>\n            <div class=\"btn_wrap\">\n              <a href=\"/saiyo/newgraduate/message/\" class=\"btn message\">あなたへのメッセージ</a>\n            </div>\n            <div>\n              <picture class=\"move_elm elm_people_2 js-action slideup\">\n                <source media=\"(max-width: 768px)\" srcset=\"/saiyo/newgraduate/img/top/sp/img-people_2.png\" width=\"105\" height=\"165\" />\n                <img src=\"/saiyo/newgraduate/img/top/img-people_2.png\" alt=\"\" width=\"130\" height=\"233\" loading=\"lazy\" />\n              </picture>\n              <picture class=\"move_elm elm_people_3 js-action slideup\">\n                <source media=\"(max-width: 768px)\" srcset=\"/saiyo/newgraduate/img/top/sp/img-people_3.png\" width=\"86\" height=\"167\" />\n                <img src=\"/saiyo/newgraduate/img/top/img-people_3.png\" alt=\"\" width=\"126\" height=\"164\" loading=\"lazy\" />\n              </picture>\n              <picture class=\"move_elm elm_people_4 js-action slideup\">\n                <source media=\"(max-width: 768px)\" srcset=\"/saiyo/newgraduate/img/top/sp/img-people_4.png\" width=\"70\" height=\"114\" />\n                <img src=\"/saiyo/newgraduate/img/top/img-people_4.png\" alt=\"\" width=\"78\" height=\"127\" loading=\"lazy\" />\n              </picture>\n            </div>\n          </div>\n\n          <section class=\"top_about\">\n            <div class=\"about_header\">\n              <h3><img src=\"/saiyo/newgraduate/img/top/top_about_ttl.svg\" alt=\"イオンリテールについて\" width=\"569\" height=\"136\" loading=\"lazy\" /></h3>\n              <p class=\"inner_lead\">\n                お客さまを第一に考えるイオン。<br class=\"smt\" />私たちはイオンという場所で、<br />\n                どうやって街の笑顔をふやしていくのかを<br class=\"smt\" />考える会社です。\n              </p>\n              <div>\n                <picture class=\"move_elm elm_people_5\">\n                  <source media=\"(max-width: 768px)\" srcset=\"/saiyo/newgraduate/img/top/sp/img-people_5.png\" width=\"81\" height=\"66\" />\n                  <img src=\"/saiyo/newgraduate/img/top/img-people_5.png\" alt=\"\" width=\"98\" height=\"80\" loading=\"lazy\" />\n                </picture>\n                <picture class=\"move_elm elm_people_6\">\n                  <source media=\"(max-width: 768px)\" srcset=\"/saiyo/newgraduate/img/top/sp/img-people_6.png\" width=\"84\" height=\"133\" />\n                  <img src=\"/saiyo/newgraduate/img/top/img-people_6.png\" alt=\"\" width=\"102\" height=\"163\" loading=\"lazy\" />\n                </picture>\n                <picture class=\"move_elm elm_apple\">\n                  <source media=\"(max-width: 768px)\" srcset=\"/saiyo/newgraduate/img/top/sp/img-apple.png\" width=\"175\" height=\"345\" />\n                  <img src=\"/saiyo/newgraduate/img/top/img-apple.png\" alt=\"\" width=\"370\" height=\"315\" loading=\"lazy\" />\n                </picture>\n              </div>\n            </div>\n\n            <span class=\"move_elm elm_cloud_4\"><img src=\"/saiyo/newgraduate/img/top/img-cloud4.png\" alt=\"\" width=\"379\" height=\"236\" loading=\"lazy\" /></span>\n            <span class=\"move_elm elm_cloud_3\"><img src=\"/saiyo/newgraduate/img/top/img-cloud3.png\" alt=\"\" width=\"427\" height=\"360\" loading=\"lazy\" /></span>\n\n            <ul>\n              <li class=\"about_link\">\n                <div class=\"about_link_ttl\">\n                  <h4>イオンリテールとは</h4>\n                  <p>\n                    イオンリテールってどんな会社？<br />\n                    まずは、ここで知ってください。\n                  </p>\n                  <hr />\n                  <a href=\"/saiyo/newgraduate/about/\"></a>\n                </div>\n                <picture class=\"about_link_thumb\">\n                  <source srcset=\"/saiyo/newgraduate/img/top/about_img01_sp.png\" media=\"(max-width: 768px)\" type=\"image/png\" width=\"1408\" height=\"600\" />\n                  <img src=\"/saiyo/newgraduate/img/top/about_img01.png\" alt=\"\" width=\"592\" height=\"245\" loading=\"lazy\" />\n                </picture>\n              </li>\n\n              <li class=\"about_link\">\n                <div class=\"about_link_ttl\">\n                  <h4>イオンリテールのDNA</h4>\n                  <p>\n                    イオングループに根付いている<br />\n                    大切な考え方です。<br />\n                    ぜひ、社風を感じてみてください。\n                  </p>\n                  <hr />\n                  <a href=\"/saiyo/newgraduate/dna/\"></a>\n                </div>\n                <picture class=\"about_link_thumb\">\n                  <source srcset=\"/saiyo/newgraduate/img/top/about_img02_sp.png\" media=\"(max-width: 768px)\" type=\"image/png\" width=\"1408\" height=\"600\" />\n                  <img src=\"/saiyo/newgraduate/img/top/about_img02.png\" alt=\"\" width=\"592\" height=\"245\" loading=\"lazy\" />\n                </picture>\n              </li>\n\n              <li class=\"about_link\">\n                <div class=\"about_link_ttl\">\n                  <h4>イオンリテールの挑戦</h4>\n                  <p>\n                    イオンリテールが生み出してきた、<br />\n                    新しいお買物体験はこちら。<br />\n                    いずれは、あなたの仕事も！\n                  </p>\n                  <hr />\n                  <a href=\"/saiyo/newgraduate/challenge/\"></a>\n                </div>\n                <picture class=\"about_link_thumb\">\n                  <source srcset=\"/saiyo/newgraduate/img/top/about_img03_sp.png\" media=\"(max-width: 768px)\" type=\"image/png\" width=\"1408\" height=\"600\" />\n                  <img src=\"/saiyo/newgraduate/img/top/about_img03.png\" alt=\"\" width=\"592\" height=\"245\" loading=\"lazy\" />\n                </picture>\n              </li>\n            </ul>\n          </section>\n\n          <section class=\"top_works\">\n            <div class=\"works_header\">\n              <div>\n                <h3><img src=\"/saiyo/newgraduate/img/top/top_works_ttl.svg\" alt=\"イオンリテールの仕事\" width=\"530\" height=\"136\" loading=\"lazy\" /></h3>\n                <p class=\"inner_lead\">私たちが手掛けるのは、<br class=\"smt\" />イオンの運営だけではありません。<br />幅広い事業フィールドで、<br class=\"smt\" />あなたのキャリアを拓きます。</p>\n              </div>\n\n              <div>\n                <picture class=\"move_elm elm_people_7\">\n                  <source media=\"(max-width: 768px)\" srcset=\"/saiyo/newgraduate/img/top/sp/img-people_7.png\" width=\"104\" height=\"126\" />\n                  <img src=\"/saiyo/newgraduate/img/top/img-people_7.png\" alt=\"\" width=\"116\" height=\"140\" loading=\"lazy\" />\n                </picture>\n                <picture class=\"move_elm elm_people_8\">\n                  <source media=\"(max-width: 768px)\" srcset=\"/saiyo/newgraduate/img/top/sp/img-people_8.png\" width=\"75\" height=\"115\" />\n                  <img src=\"/saiyo/newgraduate/img/top/img-people_8.png\" alt=\"\" width=\"83\" height=\"128\" loading=\"lazy\" />\n                </picture>\n                <picture class=\"move_elm elm_laptop\">\n                  <source media=\"(max-width: 768px)\" srcset=\"/saiyo/newgraduate/img/top/sp/img-laptop.png\" width=\"274\" height=\"326\" />\n                  <img src=\"/saiyo/newgraduate/img/top/img-laptop.png\" alt=\"\" width=\"419\" height=\"358\" loading=\"lazy\" />\n                </picture>\n              </div>\n\n              <span class=\"move_elm elm_cloud_5\"><img src=\"/saiyo/newgraduate/img/top/img-cloud5.png\" alt=\"\" width=\"317\" height=\"345\" loading=\"lazy\" /></span>\n              <span class=\"move_elm elm_cloud_6\"\n                ><img src=\"/saiyo/newgraduate/img/top/img-cloud6.png\" alt=\"\" class=\"pc_d\" width=\"635\" height=\"274\" loading=\"lazy\" /><img\n                  src=\"/saiyo/newgraduate/img/top/sp/img-cloud6.png\"\n                  alt=\"\"\n                  class=\"sp_d\"\n                  width=\"346\"\n                  height=\"223\"\n                  loading=\"lazy\"\n              /></span>\n              <span class=\"move_elm elm_cloud_7\"><img src=\"/saiyo/newgraduate/img/top/img-cloud7.png\" alt=\"\" width=\"435\" height=\"200\" loading=\"lazy\" /></span>\n              <span class=\"move_elm elm_cloud_71\"><img src=\"/saiyo/newgraduate/img/top/img-cloud71.png\" alt=\"\" width=\"1700\" height=\"379\" loading=\"lazy\" /></span>\n            </div>\n\n            <!--<div class=\"section_top_people\">-->\n            <section class=\"works_slide\">\n              <div>\n                <h4>社員紹介</h4>\n                <p class=\"inner_lead\">街にあるイオンは、<br class=\"smt\" />ひとり一人の社員の想いでできています。<br class=\"smt\" />その熱い想いを感じてください。</p>\n              </div>\n\n              <div class=\"slider_area\">\n                <div class=\"slider people_list_slide\">\n                  <div class=\"people1 people_item\">\n                    <a href=\"/saiyo/newgraduate/people/#people1\">\n                      <img src=\"/saiyo/newgraduate/img/people/people01_thumb.png\" alt=\"山村卓也さんの写真\" width=\"750\" height=\"555\" />\n                      <div class=\"personal-data\">\n                        <p class=\"personal-data-comment\">目指すのは、デジタル・IT技術を活用した温もりのあるお客さま応対。</p>\n                        <p class=\"personal-data-post\">\n                          2006年入社&emsp;オペレーション改革本部長<br />\n                          <strong\n                            ><ruby>山村 卓也<rt>ヤマムラ タクヤ</rt></ruby></strong\n                          >\n                        </p>\n                      </div>\n                      <hr\n                    /></a>\n                  </div>\n                  <div class=\"people2 people_item\">\n                    <a href=\"/saiyo/newgraduate/people/#people2\">\n                      <img src=\"/saiyo/newgraduate/img/people/people02_thumb.png\" alt=\"今井賢一さんの写真\" width=\"480\" height=\"360\" />\n                      <div class=\"personal-data\">\n                        <p class=\"personal-data-comment\">国内小売最大規模のデータを駆使し、お客さまに喜んでもらえる取り組みを創造する。</p>\n                        <p class=\"personal-data-post\">\n                          2011年入社&emsp;営業・デジタル担当<br />\n                          デジタル戦略部<br />データソリューションチーム&emsp;リーダー<br />\n                          <strong\n                            ><ruby>今井 賢一<rt>イマイ ケンイチ</rt></ruby></strong\n                          >\n                        </p>\n                      </div>\n                      <hr\n                    /></a>\n                  </div>\n                  <div class=\"people3 people_item\">\n                    <a href=\"/saiyo/newgraduate/people/#people3\">\n                      <img src=\"/saiyo/newgraduate/img/people/people03_thumb.png\" alt=\"松田祐子さんの写真\" width=\"480\" height=\"360\" />\n                      <div class=\"personal-data\">\n                        <p class=\"personal-data-comment\">入社時には思いもよらなかったキャリアを築けたのは、イオンリテールだからこそ。</p>\n                        <p class=\"personal-data-post\">\n                          2007年入社&emsp;北陸信越カンパニー<br />人事総務部&emsp;教育担当部長<br />\n                          <strong\n                            ><ruby>松田 祐子<rt>マツタ ユウコ</rt></ruby></strong\n                          >\n                        </p>\n                      </div>\n                      <hr\n                    /></a>\n                  </div>\n                  <div class=\"people4 people_item\">\n                    <a href=\"/saiyo/newgraduate/people/#people4\">\n                      <img src=\"/saiyo/newgraduate/img/people/people04_thumb.png\" alt=\"加藤昴さんの写真\" width=\"480\" height=\"360\" />\n                      <div class=\"personal-data\">\n                        <p class=\"personal-data-comment\">全国・世界の街づくりや地域の暮らしへ与えるインパクトの大きさが入社の決め手。</p>\n                        <p class=\"personal-data-post\">\n                          2015年入社&emsp;経営企画本部&emsp;<br />経営戦略部<br />\n                          <strong\n                            ><ruby>加藤 昴<rt>カトウ スバル</rt></ruby></strong\n                          >\n                        </p>\n                      </div>\n                      <hr\n                    /></a>\n                  </div>\n                  <div class=\"people5 people_item\">\n                    <a href=\"/saiyo/newgraduate/people/#people5\">\n                      <img src=\"/saiyo/newgraduate/img/people/people05_thumb.png\" alt=\"光石大二郎さんの写真\" width=\"480\" height=\"363\" />\n                      <div class=\"personal-data\">\n                        <p class=\"personal-data-comment\">やりがいを感じるのは、従業員一人一人が成長している実感が得られたとき。</p>\n                        <p class=\"personal-data-post\">\n                          2007年入社&emsp;イオンスタイル津南<br />店長<br />\n                          <strong\n                            ><ruby>光石 大二郎<rt>ミツイシ ダイジロウ</rt></ruby></strong\n                          >\n                        </p>\n                      </div>\n                      <hr\n                    /></a>\n                  </div>\n                  <div class=\"people6 people_item\">\n                    <a href=\"/saiyo/newgraduate/people/#people6\">\n                      <img src=\"/saiyo/newgraduate/img/people/people06_thumb.png\" alt=\"中村葵さんの写真\" width=\"480\" height=\"362\" />\n                      <div class=\"personal-data\">\n                        <p class=\"personal-data-comment\">大切にしているのは、胸を張って「お店が好きだ」と言えるファンになること。</p>\n                        <p class=\"personal-data-post\">\n                          2006年入社&emsp;イオン高砂店&emsp;店長<br />\n                          <strong\n                            ><ruby>中村 葵<rt>ナカムラ アオイ</rt></ruby></strong\n                          >\n                        </p>\n                      </div>\n                      <hr\n                    /></a>\n                  </div>\n                  <div class=\"people7 people_item\">\n                    <a href=\"/saiyo/newgraduate/people/#people7\">\n                      <img src=\"/saiyo/newgraduate/img/people/people07_thumb.png\" alt=\"木匠陽介さんの写真\" width=\"480\" height=\"362\" />\n                      <div class=\"personal-data\">\n                        <p class=\"personal-data-comment\">キャリアステップで様々な<br class=\"smt\" />フィールドに挑戦できることが一番の入社の決め手。</p>\n                        <p class=\"personal-data-post\">\n                          2016年入社&emsp;イオン堺北花田店&emsp;<br />H&amp;BC課長<br />\n                          <strong\n                            ><ruby>木匠 陽介<rt>キツイ ヨウスケ</rt></ruby></strong\n                          >\n                        </p>\n                      </div>\n                      <hr\n                    /></a>\n                  </div>\n                  <div class=\"people8 people_item\">\n                    <a href=\"/saiyo/newgraduate/people/#people8\">\n                      <img src=\"/saiyo/newgraduate/img/people/people08_thumb.png\" alt=\"中村詩鶴さんの写真\" width=\"480\" height=\"360\" />\n                      <div class=\"personal-data\">\n                        <p class=\"personal-data-comment\">商品部の仕事をする上で非常に重要なのは、地域のお客さまを“知ること”。</p>\n                        <p class=\"personal-data-post\">\n                          2013年入社&emsp;南関東カンパニー&emsp;食品部<br />\n                          デリカグループ<br />\n                          <strong\n                            ><ruby>中村 詩鶴<rt>ナカムラ シヅル</rt></ruby></strong\n                          >\n                        </p>\n                      </div>\n                      <hr\n                    /></a>\n                  </div>\n                  <div class=\"people9 people_item\">\n                    <a href=\"/saiyo/newgraduate/people/#people9\">\n                      <img src=\"/saiyo/newgraduate/img/people/people09_thumb.png\" alt=\"飯田真帆さんの写真\" width=\"480\" height=\"360\" />\n                      <div class=\"personal-data\">\n                        <p class=\"personal-data-comment\">東海エリアで立ち上げた<br class=\"smt\" />「推しコスメ」は、今までにないチャレンジ。</p>\n                        <p class=\"personal-data-post\">\n                          2013年入社&emsp;東海カンパニー&emsp;H&amp;BC部&emsp;<br />ビューティグループ<br />\n                          <strong\n                            ><ruby>飯田 真帆<rt>イイダ マホ</rt></ruby></strong\n                          >\n                        </p>\n                      </div>\n                      <hr\n                    /></a>\n                  </div>\n                  <div class=\"people10 people_item\">\n                    <a href=\"/saiyo/newgraduate/people/#people10\">\n                      <img src=\"/saiyo/newgraduate/img/people/people10_thumb.png\" alt=\"入領友美さんの写真\" width=\"480\" height=\"360\" />\n                      <div class=\"personal-data\">\n                        <p class=\"personal-data-comment\">部署異動や転勤は、新たな出会いやスキルに結びつくチャンス。</p>\n                        <p class=\"personal-data-post\">\n                          2009年入社&emsp;衣料本部<br />衣料コーディネーター部<br />\n                          <strong\n                            ><ruby>入領 友美<rt>イリョウ トモミ</rt></ruby></strong\n                          >\n                        </p>\n                      </div>\n                      <hr\n                    /></a>\n                  </div>\n                  <div class=\"people11 people_item\">\n                    <a href=\"/saiyo/newgraduate/people/#people11\">\n                      <img src=\"/saiyo/newgraduate/img/people/people11_thumb.png\" alt=\"高司愛梨さんの写真\" width=\"480\" height=\"360\" />\n                      <div class=\"personal-data\">\n                        <p class=\"personal-data-comment\">ショッピングを通して、多くの人の人生を楽しく豊かなものにしたい。</p>\n                        <p class=\"personal-data-post\">\n                          2021年入社&emsp;イオンつくば店<br />畜産マネージャー<br />\n                          <strong\n                            ><ruby>高司 愛梨<rt>タカジ アイリ</rt></ruby></strong\n                          >\n                        </p>\n                      </div>\n                      <hr\n                    /></a>\n                  </div>\n                  <div class=\"people12 people_item\">\n                    <a href=\"/saiyo/newgraduate/people/#people12\">\n                      <img src=\"/saiyo/newgraduate/img/people/people12_thumb.png\" alt=\"後藤拓真さんの写真\" width=\"480\" height=\"360\" />\n                      <div class=\"personal-data\">\n                        <p class=\"personal-data-comment\">働いていて良かったと思うのは、試行錯誤の末に成果や自身の成長を実感出来たとき。</p>\n                        <p class=\"personal-data-post\">\n                          2022年入社&emsp;イオン日吉津店<br />デリカ売場担当\n                          <strong\n                            ><ruby>後藤 拓真<rt>ゴトウ タクマ</rt></ruby></strong\n                          >\n                        </p>\n                      </div>\n                      <hr\n                    /></a>\n                  </div>\n                </div>\n              </div>\n              <div class=\"btn_wrap\">\n                <a href=\"/saiyo/newgraduate/people/\" class=\"btn message\">VIEW MORE</a>\n              </div>\n            </section>\n\n            <section class=\"works_jobtype\">\n              <div>\n                <h4>職種紹介</h4>\n                <p class=\"inner_lead\">こんなことも？と驚くかもしれません。<br class=\"smt\" />イオンリテールが手掛ける領域はけっこう広いのです。</p>\n              </div>\n\n              <figure><img src=\"/saiyo/newgraduate/img/top/top_jobtype_thumb.png\" alt=\"\" loading=\"lazy\" /></figure>\n              <div class=\"btn_wrap\">\n                <a href=\"/saiyo/newgraduate/job/\" class=\"btn message\">VIEW MORE</a>\n              </div>\n            </section>\n\n            <section class=\"works_movie\">\n              <span class=\"move_elm elm_cloud_9\"\n                ><img src=\"/saiyo/newgraduate/img/top/img-cloud9.png\" alt=\"\" class=\"pc_d\" width=\"1764\" height=\"524\" loading=\"lazy\" /><img\n                  src=\"/saiyo/newgraduate/img/top/sp/img-cloud9.png\"\n                  alt=\"\"\n                  class=\"sp_d\"\n                  width=\"768\"\n                  height=\"231\"\n                  loading=\"lazy\"\n              /></span>\n              <div>\n                <h4>スペシャルムービー</h4>\n              </div>\n              <div class=\"inner_lead movie-box\">\n                <iframe\n                  width=\"560\"\n                  height=\"315\"\n                  src=\"https://www.youtube.com/embed/Tw2jObU--4w?si=fwvJuoFG-lYaZf5p\"\n                  title=\"YouTube video player\"\n                  frameborder=\"0\"\n                  allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share\"\n                  allowfullscreen\n                ></iframe>\n              </div>\n              <div class=\"btn_wrap\">\n                <a href=\"/saiyo/newgraduate/specialmovie/\" class=\"btn message\">VIEW MORE</a>\n              </div>\n            </section>\n          </section>\n\n          <section class=\"top_recruit\">\n            <span class=\"move_elm elm_cloud_10\"><img src=\"/saiyo/newgraduate/img/top/img-cloud10.png\" alt=\"\" width=\"1522\" height=\"486\" loading=\"lazy\" /></span>\n            <div class=\"recruit_header\">\n              <div>\n                <h3><img src=\"/saiyo/newgraduate/img/recruit/ttl_recruit.svg\" alt=\"採用情報\" width=\"381\" height=\"136\" loading=\"lazy\" /></h3>\n                <p class=\"inner_lead\">\n                  イオンリテールは、<br />あなたのキャリアアップを<br class=\"smt\" />サポートするプランを用意して、<br />\n                  あなたをお待ちしています。\n                </p>\n              </div>\n\n              <div>\n                <picture class=\"move_elm elm_people_9\">\n                  <source media=\"(max-width: 768px)\" srcset=\"/saiyo/newgraduate/img/top/sp/img-people_9.png\" width=\"74\" height=\"106\" />\n                  <img src=\"/saiyo/newgraduate/img/top/img-people_9.png\" alt=\"\" width=\"82\" height=\"118\" loading=\"lazy\" />\n                </picture>\n                <picture class=\"move_elm elm_people_10\">\n                  <source media=\"(max-width: 768px)\" srcset=\"/saiyo/newgraduate/img/top/sp/img-people_10.png\" width=\"109\" height=\"130\" />\n                  <img src=\"/saiyo/newgraduate/img/top/img-people_10.png\" alt=\"\" width=\"121\" height=\"144\" loading=\"lazy\" />\n                </picture>\n                <picture class=\"move_elm elm_lemon\">\n                  <source media=\"(max-width: 768px)\" srcset=\"/saiyo/newgraduate/img/top/sp/img-lemon.png\" width=\"117\" height=\"95\" />\n                  <img src=\"/saiyo/newgraduate/img/top/img-lemon.png\" alt=\"\" width=\"219\" height=\"177\" loading=\"lazy\" />\n                </picture>\n                <picture class=\"move_elm elm_watch\">\n                  <source media=\"(max-width: 768px)\" srcset=\"/saiyo/newgraduate/img/top/sp/img-watch.png\" width=\"212\" height=\"380\" />\n                  <img src=\"/saiyo/newgraduate/img/top/img-watch.png\" alt=\"\" width=\"335\" height=\"364\" loading=\"lazy\" />\n                </picture>\n              </div>\n\n              <div>\n                <span class=\"move_elm elm_cloud_10\"></span>\n                <span class=\"move_elm elm_cloud_11\"></span>\n              </div>\n            </div>\n\n            <div class=\"top_recruit_wrap\">\n              <dl>\n                <dt>キャリア支援</dt>\n                <dd>\n                  自分でキャリアを切り拓くことのできる制度を用意しています。あなたのしたい挑戦ができるようサポートします。\n                  <hr />\n                  <a href=\"/saiyo/newgraduate/recruit/#career\"></a>\n                </dd>\n              </dl>\n              <dl>\n                <dt>ライフスタイル支援</dt>\n                <dd>\n                  ライフステージが変化しても、 あなたがずっとイオンリテールで 働けるよう、様々な働き方の プランがあります。\n                  <hr />\n                  <a href=\"/saiyo/newgraduate/recruit/#lifestyle\"></a>\n                </dd>\n              </dl>\n              <dl>\n                <dt>募集要項</dt>\n                <dd>\n                  幅広い経験をしながら、目指す キャリアアップを叶えられる ゼネラルコースを募集しています。\n                  <hr />\n                  <a href=\"/saiyo/newgraduate/recruit/#recruit-data\"></a>\n                </dd>\n              </dl>\n            </div>\n\n            <div class=\"btn_wrap\">\n              <p class=\"inner_lead entry_lead\">\n                新卒採用エントリーはこちらから\n              </p>\n              <div class=\"entry_lead_box\">\n              <a href=\"https://job.axol.jp/bx/s/aeonretail_27/entry/\" target=\"_blank\" class=\"entry-wh\">2027 ENTRY</a>\n              <a href=\"https://axol.jp/zw/s/aeonretail_28/entry/\" target=\"_blank\" class=\"entry-rd\">2028 ENTRY</a>\n            </div>\n            </div>\n          </section>\n        </div>\n      </div>\n      <ul class=\"fix_menu fix_mypage\">\n        <li class=\"mypage_under\">\n          <p>\n            <a href=\"https://job.axol.jp/bx/s/aeonretail_27/mypage/login\" target=\"_blank\"><span>27年卒</span></a>\n          </p>\n          <p>\n            <a href=\"https://axol.jp/zw/s/aeonretail_28/mypage/login\" target=\"_blank\"><span>28年卒</span></a>\n          </p>\n        </li>\n        <li class=\"mypage\"><span>MY<br />PAGE</span></li>\n      </ul>\n      <ul class=\"fix_menu fix_entry\">\n        <li class=\"entry_under\">\n          <p>\n            <a href=\"https://job.axol.jp/bx/s/aeonretail_27/entry/\" target=\"_blank\"><span>27年卒</span></a>\n          </p>\n          <p>\n            <a href=\"https://axol.jp/zw/s/aeonretail_28/entry/\" target=\"_blank\"><span>28年卒</span></a>\n          </p>\n        </li>\n        <li class=\"entry\"><span>ENTRY</span></li>\n      </ul>\n      <footer class=\"footer\">\n        <div class=\"footer_inner\">\n          <div class=\"footer_inner_text\">\n            <dl>\n              <dt class=\"footer_link1\">イオンリテールについて<span></span></dt>\n              <dd>\n                <ul class=\"link1\">\n                  <li><a href=\"/saiyo/newgraduate/\">トップページ</a></li>\n                  