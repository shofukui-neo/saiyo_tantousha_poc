{"url":"https://www.kinon.co.jp/recruit/interview-04.shtml","html":"<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\">\n<meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width\" />\n<meta name=\"format-detection\" content=\"telephone=no\">\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/common.css\" />\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/zone.css\" />\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/bpts.css\" />\n<!-- Basic parts -->\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/unit.css\" />\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/col.css\" />\n<!-- 本文領域レイアウタ -->\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/other.css\" />\n<!-- インタビュー用CSS -->\n<link rel=\"stylesheet\" type=\"text/css\" href=\"css/interview.css\" />\n<title>施工管理│社員の声│Recruit│キノンビクス株式会社</title>\n<style>\n.interview_fv {\n\tbackground-image: url(\"image/interview-04-00.jpg\");\n\tcolor: #fff;\n}\n#zone_substage h1 {\n\tfont-size: clamp(2.563rem, 0.767rem + 8.98vw, 7.5rem);\n\theight: auto;\n\tdisplay: block;\n\tpadding: 0;\n\tline-height: 1.5;\n\tfont-weight: normal;\n\tmargin: 1em 0 0 .5em;\n}\n#interview_section01 .flexbox.rev > img {\n\twidth: 30%;\n\tmargin: 0 auto;\n}\n\n@media screen and (max-width : 960px) {\n#interview_section01 .flexbox.rev > img {\n\tmargin-top: 10%;\n\tobject-fit: contain;\n\twidth: 60%;\n}\n}\n</style>\n<!-- スクリプトのインクルード（事前呼び出し） --> \n<meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\" />\n<link rel=\"icon\" href=\"../favicon.ico\">\n\n<!-- fontawesome -->\n<link href=\"https://use.fontawesome.com/releases/v5.6.1/css/all.css\" rel=\"stylesheet\">\n\n\n</head>\n<body>\n<div id=\"zone_sheet\"> \n  <!-- ヘッダーのインクルード --> \n  <meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\" />\n<!--\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/css/other.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/css/bpts.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/css/common.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/css/zone.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/css/unit.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/css/col.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/css/other.css\"/>\n -->\n<div class=\"header_bg\">\n<div class=\"header_logo\"><a href=\"../../\"><img src=\"../image/common/logo.svg\"></a></div>\n<nav class=\"pc_menu\">\n  <div class=\"o_mainmenu\">\n    <ul>\n      <li><a href=\"../about/\">About us</a>\n        <ul>\n          <li><a href=\"/about/index.shtml\">代表挨拶</a></li>\n          <li><a href=\"/about/overview.shtml\">会社概要</a></li>\n          <li><a href=\"/about/philosophy.shtml\">経営理念</a></li>\n          <li><a href=\"/about/promises.shtml\">7つのお約束</a></li>\n          <li><a href=\"/about/history.shtml\">沿革</a></li>\n          <li><a href=\"/about/employee.shtml\">社員保有資格一覧</a></li>\n          <li><a href=\"/about/certifications.shtml\">各種認定と宣言</a></li>\n        </ul>\n      </li>\n      <li><a href=\"../culture/\">Culture</a></li>\n      <li><a href=\"../solution/\">Solution</a>\n        <ul>\n          <li><a href=\"../solution/index.shtml#jump_01\">システムソリューション</a></li>\n          <li><a href=\"../solution/index.shtml#s_index_section02\">場所から探す</a></a></li>\n          <li><a href=\"../solution/index.shtml#s_index_section03\">納入事例</a></a></li>\n        </ul>\n      </li>\n      <li><a href=\"../recruit/\">Recruit</a>\n        <ul>\n          <li><a href=\"/recruit/\">採用情報</a></li>\n          <li><a href=\"/recruit/job.shtml\">職種紹介</a></li>\n          <li><a href=\"/recruit/interview.shtml\">社員インタビュー</a></li>\n          <li><a href=\"/recruit/requirements.shtml\">募集要項</a></li>\n        </ul>\n      </li>\n      <li><a href=\"../misc/contact.shtml\">Contact</a></li>\n    </ul>\n  </div>\n</nav>\n</div>\n<!-- レスポンシブメニュー　 -->\n<header>\n<div class=\"header-logo-menu\">\n<div id=\"nav-drawer\">\n<input id=\"nav-input\" type=\"checkbox\" class=\"nav-unshown\">\n<label id=\"nav-open\" for=\"nav-input\">\n<span></span>\n<p class=\"label_txt_menu\">MENU</p>\n</label>\n<label class=\"nav-unshown\" id=\"nav-close\" for=\"nav-input\"></label>\n<div id=\"nav-content\">\n<!--  ----------------- -->\n<div class=\"accordion\"> \n  <!-- menu1 -->\n  <div class=\"option\">\n    <input type=\"checkbox\" id=\"toggle1\" class=\"toggle\">\n    <label class=\"title item10\" for=\"toggle1\">About us</label>\n    <div class=\"content\">\n      <ul>\n        <li class=\"f_m10_10\"><a href=\"/about/index.shtml\">代表挨拶</a></li>\n        <li class=\"f_m10_20\"><a href=\"/about/overview.shtml\">会社概要</a></li>\n        <li class=\"f_m10_30\"><a href=\"/about/philosophy.shtml\">経営理念</a></li>\n        <li class=\"f_m10_40\"><a href=\"/about/promises.shtml\">7つのお約束</a></li>\n        <li class=\"f_m10_50\"><a href=\"/about/history.shtml\">沿革</a></li>\n        <li class=\"f_m10_60\"><a href=\"/about/employee.shtml\">社員保有資格一覧</a></li>\n        <li class=\"f_m10_70\"><a href=\"/about/certifications.shtml\">各種認定と宣言</a></li>\n      </ul>\n    </div>\n  </div>\n  <!-- menu2 -->\n  <div class=\"option\">\n    <div class=\"one_link\"><a href=\"../culture/\">Culture</a></div>\n  </div>\n  <!-- menu3 -->\n  <div class=\"option\">\n    <input type=\"checkbox\" id=\"toggle3\" class=\"toggle\">\n    <label class=\"title item50\" for=\"toggle3\">Solution</label>\n    <div class=\"content\">\n      <ul>\n        <li class=\"f_m30_10\"><a href=\"../solution/index.shtml#sp_jump_01\">システムソリューション</a></li>\n        <li class=\"f_m30_20\"><a href=\"../solution/index.shtml#jump_15\">場所から探す</a></a></li>\n        <li class=\"f_m30_30\"><a href=\"../solution/index.shtml#jump_02\">納入事例</a></a></li>\n      </ul>\n    </div>\n  </div>\n  <!-- menu4 -->\n  <div class=\"option\">\n    <input type=\"checkbox\" id=\"toggle4\" class=\"toggle\">\n    <label class=\"title item60\" for=\"toggle4\">Recruit</label>\n    <div class=\"content\">\n      <ul>\n        <li class=\"f_m40_10\"><a href=\"/recruit/\">採用情報</a></li>\n        <li class=\"f_m40_20\"><a href=\"/recruit/job.shtml\">職種紹介</a></li>\n        <li class=\"f_m40_30\"><a href=\"/recruit/interview.shtml\">社員インタビュー</a></li>\n        <li class=\"f_m40_40\"><a href=\"/recruit/requirements.shtml\">募集要項</a></li>\n      </ul>\n    </div>\n  </div>\n  <!-- menu5 -->\n  <div class=\"option\">\n    <div class=\"one_link\"><a href=\"../misc/contact.shtml\">Contact</a></div>\n  </div>\n<!-- menu6 -->\n  <div class=\"option\">\n    <div class=\"one_link\"><a href=\"../\">Home</a></div>\n  </div>\n</div alt=\"eod:accordion\">\n</header>\n<!-- --------------------------------------------------- --> \n\n \n  <!-- ヘッダーのインクルード 終わり　--> \n  \n  <!-- ステージ-->\n  <div id=\"zone_substage\">\n    <div>\n      <h1>Interview</h1>\n    </div>\n    <!--- パンくず -->\n    <ol class=\"zone_pankuzu\">\n      <li><a href=\"../\">HOME</a></li>\n      <li><a href=\"/recruit/\">Recruit</a></li>\n      <li><a href=\"/recruit/interview.shtml\">社員の声</a></li>\n      <li>施工管理</li>\n    </ol>\n    <!-- パンくず --> \n  </div alt=\"eod:zone_substage\">\n  <!-- ステージ　終わり --> \n  <!-- 第2層 -->\n  <div id=\"zone_middle_floor\"> \n    <!--　ボディ領域　-->\n    <div id=\"zone_body\"> \n      <!--　メインエリア　-->\n      <div id=\"zone_mainarea_1col\">\n        <div class=\"sp_padding\"> \n          \n          <!--　▼▼▼　本文領域　▼▼▼　-->\n          <div class=\"col_textarea_full\">\n            <div class=\"interview_fv\">\n              <div class=\"interview_fv-box\">\n                <h2>「現場ごとに違う景色が、今の自分にちょうどいい。」</h2>\n                <p>本社　施工管理<span class=\"bpts_br\"></span>（滋賀システム技術チーム）<br>\n                  30代　在職歴：1年</p>\n              </div>\n            </div>\n            <section id=\"interview_section01\">\n              <div class=\"l_overview_box\">\n                <p>この会社に来る前は、仕事で外に出ることはほとんどありませんでした。工場勤務だったため、毎日同じ場所に出勤する日々を送っていました。でも今は、「今日はこの現場、明日はあっちの現場」と県内のさまざまな場所を訪れる毎日で、そんな働き方が自分にはとても合っていると感じています。</p>\n                <p>休日に立ち寄ったスーパーで、自分が手がけたスピーカーを見て「あ、自分が付けたやつ、良い音鳴ってるな」と思ったり、初めて担当した『JRA栗東トレーニング・センター』の仕事を、競馬中継を見ながら思い出したり。そうやって、日常と仕事がつながる瞬間が面白いです。</p>\n                <p>福井県の公民館でホールの音響工事を担当したときには、音響設備をすべて入れ替える工事の仕上げに、最終チェックを兼ねて自分の好きな音楽を大音量で流すというちょっと特別な体験もできました。そんなことが出来るのも、この仕事ならではの魅力だと思います。 </p>\n              </div>\n              \n              <!-- 大見出し -->\n              <h2 class=\"col_midashi_pagetop\" data-en=\"About the Job\"> <span>業務について</span> </h2 alt=\"eod:col_midashi_pagetop\">\n              <ul>\n                <li>\n                  <h3><span><img src=\"image/no-01.svg\"></span>どのような業務を担当していますか？</h3>\n                  <p class=\"pad-left\">基本的には、ほぼ毎日協力会社の方と一緒に色々な現場に出て、音響や映像設備、ITV設備、放送設備、テレビ共聴などの施工に関わっています。現場によって異なりますが、朝は大体8時～8時半頃に朝礼が始まることが多いので、直接現場に向かう日もあれば、一旦会社に立ち寄ってから出発する日もあって、現場によってそれぞれですね。</p>\n                  <p class=\"pad-left\">業務内容は結構幅広いです。僕自身も入社前は「自分たちで施工するのかな」と思っていましたが、実際には僕たちはいわば“番頭さん”的な立ち位置で、施工は協力会社の方がすることも多いです。簡単な内容であれば自分たちで対応することもありますが、基本的には協力会社の方と連携しながら進めています。僕たちの役割は、電気工事業者の方とやり取りをしながら、「どのように施工を進めるか」「ここはこうしましょう」といった内容を調整し、協力会社に発注するまでの段取りを整えることが中心です。 \n                </li>\n                <li>\n                  <h3><span><img src=\"image/no-02.svg\"></span>入社してから成長を実感することはありますか？</h3>\n                  <div class=\"bpts_flexbox_onoff justify flexbox\">\n                    <div>\n                      <p>最近、一人で現場を任されることも少しずつ増えてきました。1年目は先輩方に同行させてもらいながら経験を積み、徐々に一人でも対応出来そうな事から任せてもらえるようになって、これから2年目、3年目と経つごとに単独で動く機会もさらに増えていくと思います。わからない事があれば持ち帰って相談できる環境は整っていますが、やっぱり少し不安はありますね（笑）。</p>\n                      <p>まだまだ初めて知る事ばかりで悩むことも多いですが、どうすればいいのかを一緒に考えて、方針を決めて、協力会社の方にしっかりと依頼して…という一連のプロセスが、結構楽しい。行き詰っても社内には相談できる人がたくさんいますし、とにかく知識を増やして仕事をして、と楽しく出勤しています。 </p>\n                    </div>\n                    <img src=\"image/interview-04-01.jpg\" alt=\"\"> </div>\n                </li>\n                <li>\n                  <h3><span><img src=\"image/no-03.svg\"></span>特に印象に残っている現場やプロジェクトはありますか？ </h3>\n                  <p class=\"pad-left\">入社して4月でちょうど1年が経ちました。さまざまな現場に行く中で、思い出に残ることはたくさんありますが、中でも特に印象に残っているのは、入社して最初に携わった『JRA栗東トレーニング・センター』です。競走馬のトレーニング施設で、新しい厩舎の建設に伴う設備工事を行うという大きな案件でした。防犯カメラを設置したり放送設備を導入したり、「キノンビクスではこんな仕事をしているんだ」と会社の仕事の全体像を実感できた現場でした。学びも多く、自分が得た経験値も大きかったです。</p>\n                </li>\n                <li>\n                  <div class=\"bpts_flexbox_onoff justify flexbox rev\">\n                    <div class=\"wrap\">\n                      <h3><span><img src=\"image/no-04.svg\"></span>やりがいを感じる瞬間や、嬉しかったことを教えてください</h3>\n                      <p>電気工事業者の方とあれこれ相談して、実際に機器が取り付けられたときはやっぱり嬉しいですね。</p>\n                      <p> 例えばプロジェクターがきれいに設置されて、映像がパッと映し出された瞬間には達成感もありますし、やり遂げたことに安心します。</p>\n                      <p>嬉しかったことといえば、どの現場でもお客様と一緒に喜びを分かち合えたときです。先輩と一緒に急遽現場に呼ばれて、すぐに問題を解決できたときがあったのですが、お客様や電気工事業者の方から「ありがとう、助かったよ」と言っていただけてとても励みになりました。</p>\n                      <p>当社には、この先輩が行けばすぐ解決！というような頼れる方がたくさんいます。質問するとすぐに返ってきたり、なんでも知っている方もいるので、自分もそんな存在になりたいと常々思っています。 </p>\n                    </div>\n                    <img src=\"image/interview-04-02.jpg\" alt=\"\"> </div>\n                </li>\n              </ul>\n              \n              <!-- 大見出し -->\n              <h2 class=\"col_midashi_pagetop\" data-en=\"About KINONVICS\"> <span>キノンビクスについて</span> </h2 alt=\"eod:col_midashi_pagetop\">\n              <ul>\n                <li>\n                  <h3><span><img src=\"image/no-01.svg\"></span>キノンビクス株式会社を知ったきっかけや、入社の決め手は何でしたか？</h3>\n                  <div class=\"bpts_flexbox_onoff justify flexbox\">\n                    <div>\n                      <p>僕は職業訓練校（ポリテクセンター滋賀）に通っていたのですが、先生から「ポリテク出身でキノンビクス株式会社に入社した人が楽しそうに働いている」と聞いたのが、当社を知ったきっかけでした。職業訓練校では電気関係の勉強をしていて、「少し違った分野の電気の仕事に関わってみたい」と思っていたタイミングだったこともあり、興味を惹かれて応募しました。</p>\n                      <p> 正直、入社前はホームページを見ても業務内容のイメージが完全にはつかめていませんでしたが、この会社でどんな事が出来るのだろう、というワクワク感が大きかったですね。実際に入社してみると、確かに音響・映像という分野ではあるのですが、対応している業務の幅が本当に幅広くて驚きました。建築現場に入ったり、町の電気屋さんに入ったり、請負の仕事もしたり、日々新しい現場で新しい学びがあります。</p>\n                    </div>\n                    <img src=\"image/interview-04-03.jpg\" alt=\"\"> </div>\n                </li>\n                <li>\n                  <h3><span><img src=\"image/no-02.svg\"></span>福利厚生・社内制度について教えてください</h3>\n                  <p class=\"pad-left\">社内外で開催される勉強会には、タイミングが合えば積極的に参加しています。僕たち技術チームはどうしても現場優先になってしまうので、工事が重なると参加できない事もありますが、その時は2回目を開催していただけることもあります。学ぶ機会に偏りが出ないよう配慮してもらえるのは、心情的にもとてもありがたいです。</p>\n                  <p class=\"pad-left\">4月末から5月初旬には慰労会があり、チームで目標を達成した際には「達成賞」として、会社の費用でチームメンバーと食事に行くこともあります。頑張りをしっかりと評価してもらえる文化があるのは、モチベーションにも繋がっています。</p>\n                  <p class=\"pad-left\">昨年6月の社員旅行では鳥取砂丘に行きました。滋賀本社と京都支店合同で、バス2台を借りて40〜50人ほどでの宿泊旅行でした。秋には日帰りの社員旅行、冬には忘年会など、季節ごとに社内イベントがあり、社員同士が顔を合わせる機会が多い会社だと思います。</p>\n                  <p class=\"pad-left\">本店と支店で拠点は離れていますが、交流も多いので自分の部署やチーム以外のメンバーとも皆フラットな関係で話しやすいです。 </p>\n                </li>\n                <li>\n                  <h3><span><img src=\"image/no-03.svg\"></span>社内の雰囲気や、周囲との関係性について教えて下さい</h3>\n                  <p class=\"pad-left\">風通しが良く、相談しやすい環境だと思います。自分の性格上、わからないことを抱えたままにするのが苦手なので、同じことでも理解できるまで何度でも聞きに行ってしまいます（笑）。正直、しつこいと思われているかもしれませんが、それでも社内の先輩方は嫌な顔せず対応してくださるので、本当にありがたいです。相談したときに冷たくあしらわれたら、次から聞きづらくなってしまうと思うのですが、そういった雰囲気もなく安心して質問できます。 </p>\n                </li>\n              </ul>\n              \n              <!-- 大見出し -->\n              <h2 class=\"col_midashi_pagetop\" data-en=\"Message\"> <span>入社・応募を考えている方へのメッセージ</span> </h2 alt=\"eod:col_midashi_pagetop\">\n              <ul>\n                <li>\n                  <div class=\"bpts_flexbox_onoff justify flexbox rev\">\n                    <div class=\"wrap\">\n                      <p>キノンビクスの僕らの世代で、電気の仕事を経験して入社している人はあまり多くないと思います。未経験で入社する人が多いですが、みんな楽しくやっていますし、わからない事があれば一緒に考えてくれます。僕の場合は職業訓練校で少し基礎を学んでいたこともあって、専門用語も比較的スムーズに頭に入ってきました。基礎知識が少しでもあると、最初の動きやすさは全然違うと思います。</p>\n                      <p>現場では「詳細まで決まっている案件」もあれば、「ざっくりとしか決まっていない案件」、「全部任される案件」など、いろんなパターンがあります。どの案件も最終的にうまく収まって、お客様から「ありがとう」と言われたときの充実感は、何にも代えがたいものがあります。その瞬間を一緒に経験しませんか。</p>\n                      <p>会社の雰囲気の良さは先程も触れましたが、僕は4月に入社して、すぐ6月に社員旅行がありました。初参加でも全然緊張せず、自然に楽しめたくらい居心地の良い会社です。ぜひ応募してみてくださいね。 </p>\n                    </div>\n                    <img src=\"image/interview-04-04.jpg\" alt=\"\"> </div>\n                </li>\n              </ul>\n            </section>\n            <section id=\"interview_section02\">\n              <h2>1日のスケジュール</h2>\n              <ul>\n                <li>\n                  <h3>8：00</h3>\n                  <div class=\"txt\">\n                    <p>業務開始<br>\n                      現場へ出るときは8時朝礼が多いため、直接現地に出勤します</p>\n                  </div>\n                </li>\n                <li>\n                  <h3>9:00</h3>\n                  <div class=\"txt\">\n                    <p>施工管理業務、打ち合わせ<br>\n                      ＊色々な現場があるため、毎日同じ作業の繰り返しではありません</p>\n                  </div>\n                </li>\n                <li>\n                  <h3>12:00</h3>\n                  <div class=\"txt\">\n                    <p>昼食</p>\n                  </div>\n                </li>\n                <li>\n                  <h3>17:00</h3>\n                  <div class=\"txt\">\n                    <p>帰社<br>\n                      片付け、明日の用意、担当案件の宿題</p>\n                  </div>\n                </li>\n                <li>\n                  <h3>17:30</h3>\n                  <div class=\"txt\">\n                    <p>退社<br>\n                      作業がひと段落付き次第退勤</p>\n                  </div>\n                </li>\n              </ul>\n            </section>\n            <section id=\"interview_section03\">\n              <h2>その他INTERVIEW</h2>\n              <ul class=\"l_grid_interview_list\">\n                <!--  -->\n                <li class=\"eigyo\"> <a href=\"interview-01.shtml\">\n                  <div>\n                    <p>京都支店　営業<span class=\"pre\">（教育ソリューションチーム）</span></p>\n                    <h5>本当に納得できる選択をしていただくために、伝えるべきことを、誠実に伝える。</h5>\n                    <span>30代 在職歴：8年</span> </div>\n                  </a> </li>\n                <!--  -->\n                <li class=\"support\"> <a href=\"interview-02.shtml\">\n                  <div>\n                    <p>京都支店　保守・サポート<span class=\"pre\">（京都サービスチーム）</span></p>\n                    <h5>“この先もずっと続けられる仕事を。”<br>\n                      夢を追いかけた先に見つけた、新しい働き方のかたち。</h5>\n                    <span> 20代　在職歴：半年</span> </div>\n                  </a> </li>\n                <!--  -->\n                <li class=\"se\"> <a href=\"interview-03.shtml\">\n                  <div>\n                    <p>本社　システムエンジニア<span class=\"pre\">（システムデザインチーム）</span></p>\n                    <h5>向いている、向いていないよりも、まずはやってみる。<em class=\"bpts_br_pc\"></em>迷いながらの一歩が自分を変えました。</h5>\n                    <span>40代　在職歴：2年半</span> </div>\n                  </a> </li>\n              </ul>\n            </section>\n          </div alt=\"col_textarea_full\">\n          <!--　▲▲▲　本文領域　終わり　▲▲▲　--> \n        </div>\n        <!-- eod:sp_padding --> \n      </div alt=\"eod:zone_mainarea\">\n      <!--　メインエリア　終わり　--> \n    </div alt=\"eod:zone_body\">\n    <!--　ボディ領域　終わり　--> \n  </div alt=\"eod:zone_middle\">\n  <!--　第2層　終わり　--> \n  <!-- リクルート用　お問い合わせフッターのインクルード --> \n  <meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\" />\n<meta name=\"format-detection\" content=\"telephone=no\">\n<!-- \n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/common.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/zone.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/bpts.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/unit.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/col.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/other.css\"/>\n-->\n<!-- リクルートフッターここから -->\n<div class=\"bpts_footer_recruit\"> \n  <!-- ▼ 左ボックス -->\n  <div>\n    <h4>採用に関するお問い合わせ</h4>\n    <table>\n      <tr>\n        <th>担当</th>\n        <td><span>管理グループ</span><br>\n          西村 伸宏</td>\n      </tr>\n      <tr>\n        <th>TEL</th>\n        <td>077-552-1144</td>\n      </tr>\n<!--      <tr>\n        <th>Mail　</th>\n        <td><a href=\"mailto:\"></a></td>\n      </tr>-->\n    </table>\n  </div>\n  <!-- ▲ 左ボックス --> \n  <!-- ▼ 右ボックス -->\n  <div> <a href=\"requirements.shtml\">\n    <h6>募集要項</h6></a> </div>\n  <!-- ▲ 右ボックス --> \n</div>\n<!-- ▲リクルートフッターここまで --> \n\n<!-- お問い合わせfooterここから -->\n<div class=\"bpts_footer_contact_area recruit_wrap\">\n  <h6 class=\"recruit_fotter\">ご相談等ありましたら<span>お気軽にお問い合わせください</span></h6>\n  <div class=\"center\"> <a href=\"/recruit/saiyou-contact.shtml\" class=\"bpts_btn_squarered\"><span>お問い合わせフォームを開く</span></a> </div>\n</div>\n<!-- お問い合わせfooterここまで --> \n \n  <!--　第3層　-->\n  <div id=\"zone_bottom_floor\"> \n    <!--　フッター　-->\n    <div id=\"zone_footer\"> \n      <!-- フッターのインクルード --> \n      <meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\" />\n<meta name=\"format-detection\" content=\"telephone=no\">\n<!-- \n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/common.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/zone.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/bpts.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/unit.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/col.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/other.css\"/>\n -->\n<div id=\"pagetop\"><a href=\"#top\">Page Top</a></div>\n<!--　フッター　-->\n<footer id=\"footer\">\n<div class=\"bpts_footer_wrapper\"> \n  \n  <!-- -------------------- ▼　画像とロゴ -------------------- -->\n  <div class=\"footer_image_logo\"><!-- <img src=\"../image/common/footer-img.jpg\" style=\"max-width: 1211px;width: 100%;\">-->\n    <h2><img src=\"../image/sitetop/logo-title-w.svg\"></h2>\n  </div>\n  <!-- -------------------- ▲　画像とロゴ -------------------- --> \n  \n  <!-- -------------------- ▼ 地図のエリア --------------