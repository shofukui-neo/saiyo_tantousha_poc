{"url":"https://shinwasyouji.co.jp/company/about/","html":"<!DOCTYPE html> \n<html lang=\"ja\">\n<head>\n  <meta charset=\"UTF-8\">\n  <!--[if IE]><meta http-equiv=\"X-UA-Compatible\" content=\"IE=Edge,chrome=1\" /><![endif]-->\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1.0\" />\n  <meta name=\"format-detection\" content=\"telephone=no\" />\n  <link rel=\"shortcut icon\" href=\"https://shinwasyouji.co.jp/wp-content/themes/shinwa/images/favicon.ico\" />\n  <link rel=\"apple-touch-icon\" href=\"https://shinwasyouji.co.jp/wp-content/themes/shinwa/images/common/apple-touch-icon.png\" />\n\n  <!-- Metadata -->\n<title>会社概要 | 大阪、京都、滋賀、三重で古紙回収・リサイクルは信和商事株式会社</title>\n    <meta name=\"robots\" content=\"index, follow\" />\n  <meta name=\"keywords\" content=\"リサイクル,古紙回収,古新聞,古雑誌,SDGs\">\n  <meta name=\"description\" content=\"信和商事の会社概要。古紙や廃棄物等を回収・収集し、リサイクル事業を展開しています。今までの歴史・沿革もご紹介。\">\n    \n  <!-- css -->\n<link rel='dns-prefetch' href='//ajax.googleapis.com' />\n<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n<link href=\"http://fonts.googleapis.com/earlyaccess/notosansjp.css\">\n<link rel='stylesheet' href='https://shinwasyouji.co.jp/wp-content/themes/shinwa/lib/css/jquery.bxslider.css' type='text/css' media='all' />\n<link rel='stylesheet' href='https://shinwasyouji.co.jp/wp-content/themes/shinwa/lib/css/style.css?250107' type='text/css' media='all' />\n<!-- scripts -->\n<script type='text/javascript' src='//ajax.googleapis.com/ajax/libs/jquery/1.12.4/jquery.min.js'></script>\n<script type='text/javascript' src='https://shinwasyouji.co.jp/wp-content/themes/shinwa/lib/js/min/jquery.matchHeight-min.js'></script>\n<script type='text/javascript' src='https://shinwasyouji.co.jp/wp-content/themes/shinwa/lib/js/jquery.bxslider.js'></script>\n<script type='text/javascript' src='https://shinwasyouji.co.jp/wp-content/themes/shinwa/lib/js/general.js'></script>\n<!-- Google tag (gtag.js) -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-XZTZHG60QN\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'G-XZTZHG60QN');\n</script>\n<script type=\"text/javascript\">\n  var _gaq = _gaq || [];\n  _gaq.push(['_setAccount', 'UA-16843285-1']);\n  _gaq.push(['_trackPageview']);\n\n  (function() {\n    var ga = document.createElement('script'); ga.type = 'text/javascript'; ga.async = true;\n    ga.src = ('https:' == document.location.protocol ? 'https://ssl' : 'http://www') + '.google-analytics.com/ga.js';\n    var s = document.getElementsByTagName('script')[0]; s.parentNode.insertBefore(ga, s);\n  })();\n</script>\n</head>\n\n<body id=\"home\" class=\"wp-singular page-template-default page page-id-16 page-child parent-pageid-5 wp-theme-shinwa\">\n\n\n\n<header>\n<h1><a href=\"/\"><img src=\"https://shinwasyouji.co.jp/wp-content/themes/shinwa/images/logo.png\" alt=\"信和商事株式会社\" /></a></h1>\n\n<nav id=\"main-nav\">\n<ul>\n<li><a href=\"/company/\"><span>会社案内</span></a></li>\n<li><a href=\"/content/\"><span>業務内容</span></a></li>\n<li><a href=\"/offices/\"><span>事業所一覧</span></a></li>\n<li><a href=\"/recruit/\" target=\"_blank\"><span>採用情報</span></a></li>\n<li><a href=\"/access/\"><span>アクセス</span></a></li>\n</ul>\n<p class=\"contact\"><a href=\"/contact/\">お問い合わせ</a></p>\n</nav>\n\n<nav id=\"humburger\" class=\"\">\n    <a id=\"menu-icon\">\n      <span></span>\n      <span></span>\n      <span></span>\n    </a>\n</nav>\n\n<div id=\"mobile-nav\">\n<div class=\"block\">\n<h1><a href=\"/\"><img class=\"icon\" src=\"https://shinwasyouji.co.jp/wp-content/themes/shinwa/images/logo_menu.png\" alt=\"信和商事株式会社\"></a></h1>\n<ul class=\"line\">\n<li class=\"box\">\n<h2><a href=\"/company/\">会社案内</a></h2>\n<ul>\n<li><a href=\"/company/philosophy/\">経営理念</a></li>\n<!-- <li><a href=\"/company/message/\">代表挨拶</a></li>\n<li><a href=\"/company/about/\">会社概要</a></li> -->\n<li><a href=\"/company/environment/\">環境・情報への取組み</a></li>\n<li><a href=\"/company/hansyakai/\">反社会的勢力への取組み</a></li>\n<li><a href=\"/company/licence/\">認証・取得資格一覧</a></li>\n<li><a href=\"/company/character/\">キャラクターについて</a></li>\n</ul>\n</li>\n\n<li class=\"box\">\n<h2><a href=\"/content/\">業務内容</a></h2>\n<ul>\n<li><a href=\"/content/area/\">業務エリア</a></li>\n<li><a href=\"/content/system/\">収集運搬車輛運行管理システム</a></li>\n<li><a href=\"/content/flow/\">リサイクルの流れ</a></li>\n<li><a href=\"/content/business/\">企業の方へ</a></li>\n<li><a href=\"/content/association/\">PTA・子ども会の方へ</a></li>\n</ul>\n</li>\n<li class=\"box\">\n<h2><a href=\"/offices/\">事業所一覧</a></h2>\n<ul>\n<li><a href=\"/offices/kyoto/\">京都本社</a></li>\n<li><a href=\"/offices/osaka/\">大阪営業所</a></li>\n<li><a href=\"/offices/shiga/\">滋賀営業所</a></li>\n<li><a href=\"/offices/mie/\">三重営業所</a></li>\n<li><a href=\"/offices/center/\">リサイクル物流センター</a></li>\n<li><a href=\"/offices/nankoh/\">南港営業所</a></li>\n<li><a href=\"https://www.junk-brothers.com/jp\" target=\"_blank\">海外の関連会社</a></li>\n<li><a href=\"/offices/associated/\">その他関連会社</a></li>\n</ul>\n</li>\n\n<li class=\"box\" style=\"border-top:2px solid #009456;\">\n<ul>\n<li><a href=\"/topics/\">トピックス</a></li>\n<li><a href=\"/faq/\">FAQ</a></li>\n<li><a href=\"/sitemap/\">サイトマップ</a></li>\n<li><a href=\"/privacy/\">個人情報保護方針</a></li>\n</ul>\n</li>\n<li class=\"box\">\n<ul>\n<li><a href=\"/aboutus/\">私たちのこと</a></li>\n<li><a href=\"/strengths/\">信和商事の強み</a></li>\n</ul>\n</li>\n</ul>\n</div>\n<div class=\"menu-btn\">\n<p><a class=\"btn\" href=\"/request/\">資料請求</a></p>\n<p><a class=\"btn\" href=\"/contact/\">お問い合わせ</a></p>\n<p><a class=\"btn\" href=\"/business_request/\">ご依頼・ご相談</a></p>\n<p><a class=\"btn\" href=\"/recruit/\" target=\"_blank\">採用情報</a></p>\n</div>\n</div>\n</header><section id=\"contents-header\">\n<div class=\"title\">\n<div class=\"zoom\"><img src=\"https://shinwasyouji.co.jp/wp-content/themes/shinwa/images/company/contents-header.jpg\" alt=\"\"></div>\n</div>\n</section>\n<section class=\"breadcrumb-nav\">\n<ol class=\"breadcrumb-nav\">\n<li class=\"home\"><a href=\"/\">HOME</a></li>\n<li><a href=\"/company/\">会社案内</a></li>\n<li class=\"current\">会社概要</li>\n</ol></section>\n\n\n<div id=\"contents\" class=\"mt30\">\n\n<section id=\"field\" class=\"fade\">\n<h1 class=\"title01 mt50\">会社概要</h1>\n</section>\n<section class=\"unit fade\">\n<table cellspacing=\"0\" summary=\"会社概要\" class=\"\">\n<colgroup>\n<col class=\"p-20\">\n<col class=\"\">\n<col class=\"\"> </colgroup>\n<tbody>\n<tr>\n<th>商号</th>\n<td colspan=\"2\">\n信和商事株式会社\n</td>\n</tr>\n\n<tr>\n<th>設立</th>\n<td colspan=\"2\">\n昭和54年9月\n</td>\n</tr>\n\n<tr>\n<th>資本金</th>\n<td colspan=\"2\">20,000,000円</td>\n</tr>\n\n<tr>\n<th>代表者</th>\n<td colspan=\"2\">代表取締役　中村貴敏</td>\n</tr>\n\n<tr>\n<th>所在地</th>\n<td colspan=\"2\">京都府八幡市八幡久保田1番地<br />\nTEL 075-981-2657（代）　FAX 075-981-7899</td>\n</tr>\n\n<tr>\n<th>事業内容</th>\n<td colspan=\"2\">\n<h6>1.古紙リサイクル事業（事業系古紙リサイクル、家庭系リサイクル）</h6>\n\n<p>・一般古紙の集荷<br />\n・機密書類のセキュリティ処理<br />\n・難再生古紙リサイクル\n</p>\n\n<h6>2.容器包装プラスチックリサイクル</h6>\n<p>・缶、ビン、ペットボトルのリサイクル<br />\n・非鉄及び金属の集荷・販売<br />\n・プラスチック再生事業</p>\n<h6>3.一般廃棄物収集運搬業</h6>\n<h6>4.産業廃棄物収集運搬及び処理業</h6>\n</td>\n</tr>\n\n<tr>\n<th>従事者</th>\n<td colspan=\"2\">\n<ul class=\"inline\">\n<li>破砕・リサイクル施設技術管理士</li>\n<li>各種産業廃棄物修了者多数</li>\n<li>古紙リサイクルアドバイザー</li>\n<li>3R検定合格者</li>\n<li>ISO内部環境監査員</li>\n<li>安全衛生推進者</li>\n<li>フォークリフト安全運転管理者</li>\n<li>ショベル安全運転管理者</li>\n</ul>\n</td>\n</tr>\n\n<tr>\n<th>営業許可</th>\n<td colspan=\"2\"><ul class=\"inline\">\n<li>一般廃棄物処理施設設置許可（京都府）</li>\n<li>一般廃棄物許可（八幡市）</li>\n<li>廃棄物再生事業者登録（京都府、滋賀県、大阪府）</li>\n<li>産業廃棄物収集運搬業許可（京都府、大阪府）</li>\n<li>大阪市産業廃棄物収集運搬業許可（積替保管含む）</li>\n<li>大阪市産業廃棄物処分業</li>\n<li>産業廃棄物収集運搬業許可（滋賀県、三重県、奈良県、兵庫県）</li>\n</ul>\n</td>\n</tr>\n<tr>\n<th>主要納入先</th>\n<td colspan=\"2\">福山製紙（株）、 レンゴー（株）、\n愛媛製紙（株）、三洋製紙（株）、 大王製紙（株）、王子マテリア（株）、九州製紙（株）、兵庫製紙（株）<br />\nその他国内有力メーカーおよび海外メーカー</td>\n</tr>\n\n<tr>\n<th>主要取引先</th>\n<td colspan=\"2\">丸紅フォレストリンクス（株）、カミ商事（株）、阪和興業（株）、日本紙パルプ商事（株）、国際紙パルプ商事（株）、\n日商岩井紙パルプ（株）、豊通マテリアル（株）\n</td>\n</tr>\n\n<tr>\n<th>主要仕入先</th>\n<td colspan=\"2\">企業全般（スーパー、百貨店、製造業等）<br/>\n行政（大阪市、堺市、東大阪市、枚方市、京都市等）<br/>\n団体（全国の自治会、子供会、福祉団体等）<br/>\n回収業者（全国の産廃、一廃の処理業者、再生資源処理業者）</td>\n</tr>\n\n<tr>\n<th>設備</th>\n<td colspan=\"2\">\n<ul class=\"disc\">\n<li>LB大型プレス機・・・10機</li>\n<li>車両・・・100台</li>\n<li>大型計量器・・・5基</li>\n<li>ショベル・・・10台</li>\n<li>リフト・・・20台</li>\n<li>飲料容器リサイクルプラント</li>\n<li>容器包装プラスチックプラント</li>\n</ul>\n</td>\n</tr>\n</tbody>\n</table>\n</section>\n\n<section class=\"unit dade\">\n<h2 class=\"title02\">沿革</h2>\n<div class=\"fig\">\n<img src=\"https://shinwasyouji.co.jp/wp-content/themes/shinwa/images/company/about/photo-main2.jpg\" alt=\"写真：旧大阪営業所\" />\n</div>\n\n<dl class=\"inline\">\n<dt>昭和48年4月</dt>\n<dd>中村博が栄和商会（個人）を設立</dd>\n<dt>昭和54年9月</dt>\n<dd>信和商事株式会社を設立　資本金10,000千円<br />\n代表取締役に中村博が就任</dd>\n<dt>昭和56年6月</dt>\n<dd>代表取締役に中村郡吉が就任</dd>\n<dt>昭和56年8月</dt>\n<dd>京都府八幡市に本社を移転</dd>\n<dt>昭和58年6月</dt>\n<dd>大阪市城東区今福南に大阪営業所を開設</dd>\n<dt>昭和59年2月</dt>\n<dd>資本金20,000千円に増資</dd>\n<dt>平成12年1月</dt>\n<dd>滋賀県湖南市岩根に滋賀営業所を開設</dd>\n<dt>平成13年3月</dt>\n<dd>中国向け古紙輸出事業を開始</dd>\n<dt>平成13年8月</dt>\n<dd>月夜田倉庫（リサイクル物流センター）を開設</dd>\n<dt>平成16年3月</dt>\n<dd>三重県伊賀市安場に三重営業所を開設</dd>\n<dt>平成16年4月</dt>\n<dd>廃プラスチックリサイクル事業開始</dd>\n<dt>平成20年10月</dt>\n<dd>本社ビル（京都府八幡市）新築</dd>\n<dt>平成21年5月</dt>\n<dd>大阪市住之江区南港東に南港営業所を開設</dd>\n<dt>平成22年6月</dt>\n<dd>ISO27001認証取得</dd>\n<dt>平成24年8月</dt>\n<dd>代表取締役に中村昌弘が就任</dd>\n<dt>平成25年4月</dt>\n<dd>大阪営業所リニューアルオープン</dd>\n<dt>平成27年2月</dt>\n<dd>三重にてエコステーションオープン</dd>\n<dt>平成29年</dt>\n<dd>京都府警本部長より優良運行管理事業所表彰を受賞<br/>京都府交通安全協会より事故防止コンクール金賞受賞</dd>\n<dt>平成26年</dt>\n<dd>宇治市からの優良褒章</dd>\n<dt>令和元年</dt>\n<dd>大阪府知事より障害者雇用促進感謝状</dd>\n<dd>大阪府産業資源循環協会より優良事業所表彰</dd>\n<dt>令和2年</dt>\n<dd>優良申告法人表敬状の授与<br/>関連会社Junk&Co設立（ベトナム）</dd>\n<dt>令和2年4月</dt>\n<dd>南港営業所　リニューアルオープン</dd>\n<dt>令和3年12月</dt>\n<dd>日本赤十字社様より表彰『金色有功章』受賞</dd>\n<dt>令和4年2月</dt>\n<dd>内閣総理大臣より紺綬褒章を受章</dd>\n<dt>令和6年11月</dt>\n<dd>代表取締役に中村貴敏が就任</dd>\n</dl>\n<!--\n<div class=\"youtube\">\n<iframe width=\"560\" height=\"315\" src=\"https://www.youtube.com/embed/oenrKAOdoew?rel=0\" title=\"YouTube video player\" frameborder=\"0\" allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture\" allowfullscreen></iframe>\n</div>-->\n</section>\n<section id=\"box02\">\n<h2 class=\"title01\"><span>お申し込みはこちら</span>CONTACTS</h2>\n<ul>\n<li><a href=\"/request/\"><img class=\"icon\" src=\"https://shinwasyouji.co.jp/wp-content/themes/shinwa/images/icon-form01.png\" alt=\"\"><h3>資料請求</h3>\n<p>お申し込み</p>\n</a></li>\n<li><a href=\"/business_request/\"><img class=\"icon\" src=\"https://shinwasyouji.co.jp/wp-content/themes/shinwa/images/icon-form02.png\" alt=\"\"><h3>ご依頼・ご相談</h3>\n<p>お申し込み</p>\n</a></li>\n<li><a href=\"/contact/\"><img class=\"icon\" src=\"https://shinwasyouji.co.jp/wp-content/themes/shinwa/images/icon-form03.png\" alt=\"\"><h3>お問い合わせ</h3>\n<p>お申し込み</p>\n</a></li>\n</ul>\n</section></div><!--/ contents -->\n<footer>\n<nav id=\"general-nav\">\n<p class=\"logo_f\"><a href=\"/\"><img src=\"https://shinwasyouji.co.jp/wp-content/themes/shinwa/images/logo_footer.png\" alt=\"\" /></a></p>\n<div class=\"line01\">\n<ul class=\"\">\n<li class=\"\"><a href=\"/topics/\">トピックス</a></li>\n<li class=\"\"><a href=\"/company/\">会社案内</a></li>\n<li class=\"\"><a href=\"/content/\">業務内容</a></li>\n<li class=\"\"><a href=\"/offices/\">事業所一覧</a></li>\n<li class=\"\"><a href=\"/contact/\">お問い合わせ</a></li>\n</ul></div>\n<div class=\"line02\">\n<ul class=\"\">\n<li class=\"\"><a href=\"/faq/\">FAQ</a></li>\n<li class=\"\"><a href=\"/access/\">アクセス</a></li>\n<li class=\"\"><a href=\"/sitemap/\">サイトマップ</a></li>\n<li class=\"\"><a href=\"/recruit/\" target=\"_blank\">採用情報</a></li>\n<li class=\"\"><a href=\"/privacy/\">個人情報保護方針</a></li>\n</ul></div>\n</nav>\n\n<div id=\"pagetop\">\n<p><a href=\"#content\"><span>このページの先頭へ</span></a></p>\n</div>\n<address><span><a href=\"tel:075-981-2657\">tel.075-981-2657</a></span><br/>\n〒614-8045 京都府八幡市八幡久保田1番地\n</address>\t\n\t<div  id=\"copyright\">\n\t<p>&copy; Copyright © SHINWASYOUJI co.,ltd All Rights Reserved.</p>\n</div>\n</footer>\n\n</body>\n</html>","finalUrl":"https://shinwasyouji.co.jp/company/about/","rendered":false,"_cachedAt":"2026-06-22T22:34:57.785Z"}