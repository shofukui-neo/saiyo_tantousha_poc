{"url":"https://www.cm-shikoku.co.jp/company/work-life-balance/","html":"<!doctype html>\n<html class=\"no-js\" lang=\"ja\">\n\n<head>\n  <meta charset=\"utf-8\">\n  <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n  <title>健康とワーク･ライフ･バランス | 会社案内 | 株式会社（株）建設マネジメント四国 | 四国の未来をつくるお手伝い。</title>\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n\n  <!-- Meta Tags -->\n  <meta name=\"title\" content=\"健康とワーク･ライフ･バランス | 会社案内 | 株式会社（株）建設マネジメント四国 | 四国の未来をつくるお手伝い。\">\n  <meta name=\"description\" content=\"安全・安心の国土強強靭化を柱とした社会資本整備の支援を通じ、四国に暮らす人々の生活がより豊かになるよう、また地域の守り手として災害等緊急時の対応や社会貢献を念頭に、地域づくりのサポートに努めてまいります。\">\n\n  <script src=\"/js/library/jquery/jquery-3.6.1.min.js\" charset=\"UTF-8\"></script> \n \n<script src=\"/acms.js?uaGroup=PC&amp;domains=www.cm-shikoku.co.jp&amp;jsDir=js/&amp;themesDir=/themes/&amp;bid=1&amp;jQuery=3.6.1&amp;jQueryMigrate=migrate-3.0.1&amp;mediaClientResize=off&amp;v=1025683fe7d2555628e58425546c7fa0&amp;umfs=32M&amp;pms=32M&amp;mfu=20&amp;lgImg=width:1400&amp;jpegQuality=85&amp;mediaLibrary=on&amp;edition=standard&amp;urlPreviewExpire=48&amp;timemachinePreviewDefaultDevice=PC&amp;scriptRoot=/\" charset=\"UTF-8\" id=\"acms-js\"></script>\n\n\n<!-- Open Graph / Facebook -->\n<meta property=\"og:type\" content=\"website\">\n<meta property=\"og:url\" content=\"https://www.cm-shikoku.co.jp/\">\n<meta property=\"og:title\" content=\"(株)建設マネジメント四国 | 四国の未来をつくるお手伝い。\">\n<meta property=\"og:description\" content=\"安全・安心の国土強強靭化を柱とした社会資本整備の支援を通じ、四国に暮らす人々の生活がより豊かになるよう、また地域の守り手として災害等緊急時の対応や社会貢献を念頭に、地域づくりのサポートに努めてまいります。\">\n<meta property=\"og:image\" content=\"https://www.cm-shikoku.co.jp/themes/cm-shikoku/images/ogp.jpg\">\n\n<!-- Twitter -->\n<meta property=\"twitter:card\" content=\"summary_large_image\">\n<meta property=\"twitter:url\" content=\"https://www.cm-shikoku.co.jp/\">\n<meta property=\"twitter:title\" content=\"(株)建設マネジメント四国 | 四国の未来をつくるお手伝い。\">\n<meta property=\"twitter:description\" content=\"安全・安心の国土強強靭化を柱とした社