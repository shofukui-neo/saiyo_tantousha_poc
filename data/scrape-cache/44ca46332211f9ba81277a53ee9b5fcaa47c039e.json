ard__category\">入社2019年</li>\n                </ul>\n                              </a>\n            </article>\n                        \n            <article class=\"card swiper-slide\">\n              <a href=\"https://www.nakaken.co.jp/recruit/archives/voice/131\">\n                <div class=\"card__img\">\n                  <img width=\"595\" height=\"397\" src=\"https://www.nakaken.co.jp/recruit/wp-content/uploads/2022/12/DSC6304　済-595x397.jpg\" class=\"attachment-voice_thumbnail size-voice_thumbnail wp-post-image\" alt=\"\" loading=\"lazy\" />                </div>\n                <p class=\"card__text\">1日乗り越えていくごとに知識やスキルが身に付き、自分自身の成長に繋がり、飽きの来ない仕事。</p>\n                                <ul class=\"card__category-wrap\">\n                  <li class=\"card__category\">建築</li>                  <li class=\"card__category\">建築施工管理職</li><li class=\"card__category\">入社2021年</li>\n                </ul>\n                              </a>\n            </article>\n                        \n            <article class=\"card swiper-slide\">\n              <a href=\"https://www.nakaken.co.jp/recruit/archives/voice/%e9%81%93%e8%b7%af%e5%bb%ba%e8%a8%ad%e5%b7%a5%e4%ba%8b%e3%81%aa%e3%81%a9%e3%80%8c%e5%9c%b0%e5%9b%b3%e3%81%ab%e6%ae%8b%e3%82%8b%e3%82%82%e3%81%ae%e3%82%92%e9%80%a0%e3%82%8a%e3%81%82%e3%81%92%e3%82%8b\">\n                <div class=\"card__img\">\n                  <img width=\"595\" height=\"397\" src=\"https://www.nakaken.co.jp/recruit/wp-content/uploads/2022/12/DSC2299-595x397.jpg\" class=\"attachment-voice_thumbnail size-voice_thumbnail wp-post-image\" alt=\"\" loading=\"lazy\" />                </div>\n                <p class=\"card__text\">道路建設工事など「地図に残るものを造りあげることができる」のが大きなやりがいに。</p>\n                                <ul class=\"card__category-wrap\">\n                  <li class=\"card__category\">土木</li>                  <li class=\"card__category\">土木施工管理職</li><li class=\"card__category\">入社2015年</li>\n                </ul>\n                              </a>\n            </article>\n                        \n            <article class=\"card swiper-slide\">\n              <a href=\"https://www.nakaken.co.jp/recruit/archives/voice/73\">\n                <div class=\"card__img\">\n                  <img width=\"595\" height=\"397\" src=\"https://www.nakaken.co.jp/recruit/wp-content/uploads/2022/12/DSC2321　済-595x397.jpg\" class=\"attachment-voice_thumbnail size-voice_thumbnail wp-post-image\" alt=\"\" loading=\"lazy\" />                </div>\n                <p class=\"card__text\">工事が完成した時の大きな喜びと、社会に必要とされ貢献できていることにやりがいを実感。</p>\n                                <ul class=\"card__category-wrap\">\n                  <li class=\"card__category\">土木</li>                  <li class=\"card__category\">土木施工管理職</li><li class=\"card__category\">入社2019年</li>\n                </ul>\n                              </a>\n            </article>\n                        \n            <article class=\"card swiper-slide\">\n              <a href=\"https://www.nakaken.co.jp/recruit/archives/voice/120\">\n                <div class=\"card__img\">\n                  <img width=\"595\" height=\"397\" src=\"https://www.nakaken.co.jp/recruit/wp-content/uploads/2022/12/DSC1697　①TOP写真-595x397.jpg\" class=\"attachment-voice_thumbnail size-voice_thumbnail wp-post-image\" alt=\"\" loading=\"lazy\" />                </div>\n                <p class=\"card__text\">土木工事は1つ1つの現場が大規模であり、業務内容も魅力的。ICTやVRを現場に活用しDX推進中。</p>\n                                <ul class=\"card__category-wrap\">\n                  <li class=\"card__category\">土木</li>                  <li class=\"card__category\">土木施工管理職</li><li class=\"card__category\">入社2012年</li>\n                </ul>\n                              </a>\n            </article>\n                        \n            <article class=\"card swiper-slide\">\n              <a href=\"https://www.nakaken.co.jp/recruit/archives/voice/%e5%a4%a7%e8%a6%8f%e6%a8%a1%e7%8f%be%e5%a0%b4%e3%81%ae%e6%89%80%e9%95%b7%e3%82%82