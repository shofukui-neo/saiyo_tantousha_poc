.has-large-font-size{font-size: var(--wp--preset--font-size--large) !important;}.has-x-large-font-size{font-size: var(--wp--preset--font-size--x-large) !important;}\n:where(.wp-block-post-template.is-layout-flex){gap: 1.25em;}:where(.wp-block-post-template.is-layout-grid){gap: 1.25em;}\n:where(.wp-block-columns.is-layout-flex){gap: 2em;}:where(.wp-block-columns.is-layout-grid){gap: 2em;}\n:root :where(.wp-block-pullquote){font-size: 1.5em;line-height: 1.6;}\n</style>\n<link rel='stylesheet' id='wp-pagenavi-css' href='https://toshin-truck.com/cont/wp-content/plugins/wp-pagenavi/pagenavi-css.css?ver=2.70' type='text/css' media='all' />\n<!--[if lt IE 9]>\n<script type=\"text/javascript\" src=\"https://toshin-truck.com/cont/wp-content/themes/toshin_theme/js/lib/html5shiv.min.js?ver=6.7.2\" id=\"html5shiv-js\"></script>\n<![endif]-->\n<!--[if lt IE 9]>\n<script type=\"text/javascript\" src=\"https://toshin-truck.com/cont/wp-content/themes/toshin_theme/js/lib/flexibility.min.js?ver=6.7.2\" id=\"flexibility-js\"></script>\n<![endif]-->\n<link rel=\"https://api.w.org/\" href=\"https://toshin-truck.com/wp-json/\" /><link rel=\"alternate\" title=\"JSON\" type=\"application/json\" href=\"https://toshin-truck.com/wp-json/wp/v2/pages/38\" /><link rel=\"EditURI\" type=\"application/rsd+xml\" title=\"RSD\" href=\"https://toshin-truck.com/cont/xmlrpc.php?rsd\" />\n<meta name=\"generator\" content=\"WordPress 6.7.2\" />\n<link rel=\"canonical\" href=\"https://toshin-truck.com/recruit/\" />\n<link rel='shortlink' href='https://toshin-truck.com/?p=38' />\n<link rel=\"alternate\" title=\"oEmbed (JSON)\" type=\"application/json+oembed\" href=\"https://toshin-truck.com/wp-json/oembed/1.0/embed?url=https%3A%2F%2Ftoshin-truck.com%2Frecruit%2F\" />\n<link rel=\"alternate\" title=\"oEmbed (XML)\" type=\"text/xml+oembed\" href=\"https://toshin-truck.com/wp-json/oembed/1.0/embed?url=https%3A%2F%2Ftoshin-truck.com%2Frecruit%2F&#038;format=xml\" />\n\n<!-- Analytics -->\n<!-- Global site tag (gtag.js) - Google Analytics -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=UA-121862001-1\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'UA-121862001-1');\n</script>\n\n<!-- Global site tag (gtag.js) - Google Ads: 773888251 -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=AW-773888251\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'AW-773888251');\n</script>\n</head>\n\n<body id=\"body\">\n\n<header role=\"banner\" class=\"header\">\n\n<div class=\"copy\">\n<p>街から街へ、人から人へ、安全・確実・迅速に、心を込めて荷物をお届けする「藤伸」</p>\n</div>\n\n<div class=\"flexbox flex-justify-between flex-align-center\">\n<h1><a href=\"https://toshin-truck.com/\"><img src=\"https://toshin-truck.com/cont/wp-content/themes/toshin_theme/img/common/logo.png\" alt=\"TOSHIN 株式会社 藤伸\"></a></h1>\n<nav id=\"gnav\" class=\"gnav collapse\" role=\"navigation\"> \n<ul class=\"flexbox flex-justify-between\">\n  <li><a href=\"https://toshin-truck.com/service/\">藤伸のサービス</a></li>\n  <li><a href=\"https://toshin-truck.com/activities/\">藤伸の取り組み</a></li>\n  <li><a href=\"https://toshin-truck.com/recruit/\">採用情報</a></li>\n  <li><a href=\"https://toshin-truck.com/company/\">会社案内</a></li>\n  <li class=\"contact\"><a href=\"https://toshin-truck.com/contact/\">お問い合わせ</a></li>\n</ul>\n</nav>\n    <button type=\"button\" id=\"toggle\" class=\"toggle\" data-toggle=\"collapse\" data-target=\"#gnav\" aria-controls=\"gnav\" aria-expanded=\"false\">\n      <span class=\"toggle__bar\"></span>\n      <span class=\"toggle__title\"></span>\n    </button>\n</div>\n</header>\n<main role=\"main\" class=\"main\">\n<section class=\"recruit01\">\n  <div class=\"recruit_ttl container\">\n        <h2><img src=\"https://toshin-truck.com/cont/wp-content/themes/toshin_theme/img/recruit/top/ttl.png\" alt=\"クルマだけでは、モノは運べない。サービス業のメーカーになろう。広島/岡山/山口/尾道\"></h2>\n        <p>クルマだけでは、モノは運べない。人が、心を込めて、お客様の立場に立って、クルマで運ぶ。<br>私たち藤伸は、「運送会社はサービス業である」ということを基本に、<br>お客様に喜んでいただけるサービスを提供できるよう、<br>全社が一丸となって積極的な取り組みを行っています。 </p>\n    </div>\n</section>\n\n<section class=\"recruit02\">\n  <div class=\"slide_wrap\">\n        <h2 class=\"slide_ttl\"><img src=\"https://toshin-truck.com/cont/wp-content/themes/toshin_theme/img/recruit/top/ttl02.png\" alt=\"藤伸では、一人ひとりが”籐伸の顔”\"></h2>\n        <ul class=\"recruit_slider\">\n            <li><img src=\"https://toshin-truck.com/cont/wp-content/themes/toshin_theme/img/recruit/top/pic01.jpg\" alt=\"社員写真\"></li>\n            <li><img src=\"https://toshin-truck.com/cont/wp-content/themes/toshin_theme/img/recruit/top/pic02.jpg\" alt=\"社員写真\"></li>\n            <!-- <li><img src=\"https://toshin-truck.com/cont/wp-content/themes/toshin_theme/img/recruit/top/pic03.jpg\" alt=\"社員写真\"></li> -->\n            <li><img src=\"https://toshin-truck.com/cont/wp-content/themes/toshin_theme/img/recruit/top/pic04.jpg\" alt=\"社員写真\"></li>\n            <li><img src=\"https://toshin-truck.com/cont/wp-content/themes/toshin_theme/img/recruit/top/pic05.jpg\" alt=\"社員写真\"></li>\n            <li><img src=\"https://toshin-truck.com/cont/wp-content/themes/toshin_theme/img/recruit/top/pic06.jpg\" alt=\"社員写真\"></li>\n            <li><img src=\"https://toshin-truck.com/cont/wp-content/themes/toshin_theme/img/recruit/top/pic07.jpg\" alt=\"社員写真\"></li>\n            <li><img src=\"https://toshin-truck.com/cont/wp-content/themes/toshin_theme/img/recruit/top/pic08.jpg\" alt=\"社員写真\"></li>\n            <li><img src=\"https://toshin-truck.com/cont/wp-content/themes/toshin_theme/img/recruit/top/pic09.jpg\" alt=\"社員写真\"></li>\n            <li><img src=\"https://toshin-truck.com/cont/wp-content/themes/toshin_theme/img/recruit/top/pic10.jpg\" alt=\"社員写真\"></li>\n        </ul>\n    </div>\n\n    <a href=\"interview\" class=\"btn-a\">社員インタビュー</a>\n\n</section>\n\n<section class=\