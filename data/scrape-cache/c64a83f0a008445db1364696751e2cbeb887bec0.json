{"url":"https://www.alae.co.jp/contact","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width\" />\n<meta name=\"format-detection\" content=\"telephone=no\" />\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\" />\n<title>お問い合わせ│株式会社エイリイ・エンジニアリング</title>\n<meta name=\"description\" content=\"エイリイ・エンジニアリングの「お問い合わせ」ページです。エイリイ・エンジニアリングは国防のための製品開発や技術を提供する「防衛産業」を行い、恒久的な空の平和を目指していきます。\" />\n<meta name=\"keywords\" content=\"エイリイ・エンジニアリング,航空機搭載機器,軌道衛星ユニット,航空,防衛,防衛産業,航空機,無線\" />\n<link rel=\"icon\" href=\"https://www.alae.co.jp/favicon.ico\" id=\"favicon\">\n<link rel=\"apple-touch-icon\" sizes=\"180x180\" href=\"/apple-touch-icon-180x180.png\">\n\n<!-- CSS -->\n<link rel=\"stylesheet\" type=\"text/css\" media=\"all\" href=\"../common/css/cmn_reset.css\" />\n<link rel=\"stylesheet\" type=\"text/css\" media=\"all\" href=\"../common/css/cmn_style.css\" />\n<link rel=\"stylesheet\" type=\"text/css\" media=\"all\" href=\"../common/css/cmn_responsive.css\" />\n<link rel=\"stylesheet\" type=\"text/css\" media=\"all\" href=\"css/form.css\" />\n\n<!-- jS -->\n<script src=\"../common/js/jquery-3.1.1.min.js\"></script>\n<script src=\"../common/js/backtop.js\"></script>\n<script src=\"../common/js/jquery.inview.js\"></script>\n<script src=\"../common/js/common.js\"></script>\n\n\n    <script type=\"text/javascript\" src=\"js/zipcode-converter.js\"></script>\n    <script type=\"text/javascript\" src=\"js/zipcode.js\"></script>\n\n\n<!-- Google Tag Manager -->\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n})(window,document,'script','dataLayer','GTM-TVS4PMP');</script>\n<!-- End Google Tag Manager -->\n</head>\n  <body>\n<!-- Google Tag Manager (noscript) -->\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-TVS4PMP\"\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n<!-- End Google Tag Manager (noscript) -->\n      <header>\n        <!-- スマホ用ヘッダー -->\n          <div class=\"cp_cont\">\n            <h1 id=\"sp_logo\">\n              <a href=\"../\"><img src=\"../common/img/hd_logo.svg\" alt=\"株式会社エイリイ・エンジニアリング\"/></a></h1>\n          </div>\t\n      </header>\n      \n      <section class=\"mv\">\n            <h2 class=\"mv_title f_min\"><span>お問い合わせ</span></h2>\n          <nav class=\"hd_inner fadein\">\n              <div class=\"nav_box\">\n                  <ul class=\"hd_nav\">\n                      <li class=\"hd_item\"><a href=\"../company\"><span class=\"bold sub_font\">About us</span><br><span>会社概要</span></a></li>\n                      <li class=\"hd_item\"><a href=\"../service\"><span class=\"bold sub_font\">Business</span><br><span>事業案内</span></a></li>\n                  </ul>\n                  <h1 class=\"hd_logo\">\n                      <a href=\"../\"><img src=\"../common/img/hd_logo.svg\" alt=\"株式会社エイリイ・エンジニアリング\" width=\"300\" height=\"79\"></a>\n                  </h1>\n                  <ul class=\"hd_nav\">\n                      <li class=\"hd_item\"><a href=\"../recruit\"><span class=\"bold sub_font\">Recruit</span><br><span>採用情報</span></a></li>\n                      <li class=\"hd_item\"><a href=\"#\"><span class=\"bold sub_font\">Contact</span><br><span>お問い合わせ</span></a></li>\n                  </ul>\n              </div>\n          </nav>\n      </section><!--mv-->\n      <div class=\"pankuzu\">\n          <ul class=\"pankuzu-list\">\n              <li><a href=\"../\">ホーム</a></li>\n              <li class=\"under_contents\">お問い合わせ</li>\n          </ul>\n      </div>\n      \n      <div class=\"main_bg\">\n      \n          <div class=\"root-container\">\n              \n              \n              \n<p class=\"cont_top\">弊社製品、採用についてのお問い合わせは、こちらで受付しております。</p>\n<div class=\"cont_block\">\n    <p class=\"cont_midashi\"><span class=\"\">電</span>話・FAXでの<span class=\"text-wrap\">お問い合わせ</span></p>\n    <div class=\"num_box\">\n        <p class=\"num_midashi\">電話・FAX</p>\n        <div class=\"num_row\">\n            <p class=\"num_post\">総務(代表)</p>\n            <p class=\"num_tel\"><a href=\"tel:0429831701\">042-983-1701</a></p>\n            <p class=\"num_fax\">042-983-1709</p>\n        </div>\n        <div class=\"num_row\">\n            <p class=\"num_post\">営業</p>\n            <p class=\"num_tel\"><a href=\"tel:0429831753\">042-983-1753</a></p>\n            <p class=\"num_fax\">042-983-1783</p>\n        </div>\n    </div>\n</div>\n\n\n<div class=\"cont_block mt90\">\n    <p class=\"cont_midashi\"><span class=\"\">お</span>問い合わせフォーム</p>\n    <div class=\"flow_img\">\n        <p class=\"pc_block\"><img src=\"img/flow01pc.png\" alt=\"情報の入力\"></p>\n        <p class=\"sp_block\"><img src=\"img/flow01sp.png\" alt=\"情報の入力\"></p>\n    </div>\n    <p class=\"cont_text mt45\">必要な情報を入力し『確認』ボタンを押してください。<br><span class=\"required\">当フォームにご記入頂いた内容は、SSL(情報暗号化通信)によって安全に送信されますのでご安心ください。</span></p>\n    <p class=\"cont_text mt30\"><span class=\"required\">※</span>は必須項目です。</p>\n\n    \n    <form name=\"contact\" action=\"/contact/\" method=\"POST\">\n      <input type=\"hidden\" name=\"op\" value=\"confirm\" />\n      <input type=\"hidden\" name=\"tk\" value=\"e2e07f90882f7203d75e77b079f8ff75a596dbd5\" />\n\n      <div class=\"form-element-container\">\n        <div class=\"form-field-input-pair\">\n          <div class=\"form-field\">お問い合わせ内容<span class=\"required\">※</span></div>\n          <div class=\"form-input\">\n              <select name=\"contents\"  required>\n<option value=\"\" >選択してください</option>\n<option value=\"1\" >製品のお問い合わせ</option>\n<option value=\"2\" >採用のお問い合わせ</option>\n<option value=\"3\" >その他のお問い合わせ</option>\n</select>\n\n            </div>\n        </div>\n        \n        <div class=\"form-field-input-pair\">\n          <div class=\"form-field\">お名前<span class=\"required\">※</span></div>\n          <div class=\"form-input\"><input type=\"text\" name=\"fullname\" value=\"\" class=\"w_full\" required />\n(全角)</div>\n        </div>\n          \n        <div class=\"form-field-input-pair\">\n          <div class=\"form-field\">ふりがな<span class=\"required\">※</span></div>\n          <div class=\"form-input\"><input type=\"text\" name=\"kana\" value=\"\" class=\"w_full\" required />\n(全角)</div>\n        </div>\n          \n        <div class=\"form-field-input-pair\">\n          <div class=\"form-field\">法人名</div>\n          <div class=\"form-input\"><input type=\"text\" name=\"corporation\" value=\"\" class=\"w_full\"  />\n(全角)</div>\n        </div>\n\n        <div class=\"form-field-input-pair\">\n          <div class=\"form-field\">Eメールアドレス<span class=\"required\">※</span></div>\n          <div class=\"form-input\"><input type=\"email\" name=\"mail\" value=\"\" class=\"w_full\" required />\n(半角)</div>\n        </div>\n\n        <div class=\"form-field-input-pair\">\n          <div class=\"form-field\">Eメールアドレス(確認用)<span class=\"required\">※</span></div>\n          <div class=\"form-input\"><input type=\"email\" name=\"mail2\" value=\"\" class=\"w_full\" required />\n(半角)</div>\n        </div>\n\n        <div class=\"form-field-input-pair\">\n          <div class=\"form-field\">電話番号<span class=\"required\">※</span></div>\n          <div class=\"form-input\"><input type=\"text\" name=\"tel\" value=\"\" class=\"w_half\" required />\n(半角数字)</div>\n        </div>\n\n        <div class=\"form-field-input-pair\">\n          <div class=\"form-field\">FAX</div>\n          <div class=\"form-input\"><input type=\"text\" name=\"fax\" value=\"\" class=\"w_half\"  />\n(半角数字)</div>\n        </div>\n\n        <div class=\"form-field-input-pair\">\n          <div class=\"form-field\">郵便番号</div>\n          <div class=\"form-input\">\n              <input type=\"text\" name=\"zipcode1\" value=\"\" size=\"3\"  />\n - <input type=\"text\" name=\"zipcode2\" value=\"\" size=\"4\"  />\n(半角英数字)\n              <p>※郵便番号を入力すると住所が自動で表示されます。</p></div>\n        </div>\n\n        <div class=\"form-field-input-pair\">\n          <div class=\"form-field\">ご住所</div>\n          <div class=\"form-input\">\n              <p>都道府県</p>\n              <select name=\"pref\"  >\n<option value=\"\" >選択してください</option>\n<option value=\"1\" >北海道</option>\n<option value=\"2\" >青森県</option>\n<option value=\"3\" >岩手県</option>\n<option value=\"4\" >宮城県</option>\n<option value=\"5\" >秋田県</option>\n<option value=\"6\" >山形県</option>\n<option value=\"7\" >福島県</option>\n<option value=\"8\" >茨城県</option>\n<option value=\"9\" >栃木県</option>\n<option value=\"10\" >群馬県</option>\n<option value=\"11\" >埼玉県</option>\n<option value=\"12\" >千葉県</option>\n<option value=\"13\" >東京都</option>\n<option value=\"14\" >神奈川県</option>\n<option value=\"15\" >新潟県</option>\n<option value=\"16\" >富山県</option>\n<option value=\"17\" >石川県</option>\n<option value=\"18\" >福井県</option>\n<option value=\"19\" >山梨県</option>\n<option value=\"20\" >長野県</option>\n<option value=\"21\" >岐阜県</option>\n<option value=\"22\" >静岡県</option>\n<option value=\"23\" >愛知県</option>\n<option value=\"24\" >三重県</option>\n<option value=\"25\" >滋賀県</option>\n<option value=\"26\" >京都府</option>\n<option value=\"27\" >大阪府</option>\n<option value=\"28\" >兵庫県</option>\n<option value=\"29\" >奈良県</option>\n<option value=\"30\" >和歌山県</option>\n<option value=\"31\" >鳥取県</option>\n<option value=\"32\" >島根県</option>\n<option value=\"33\" >岡山県</option>\n<option value=\"34\" >広島県</option>\n<option value=\"35\" >山口県</option>\n<option value=\"36\" >徳島県</option>\n<option value=\"37\" >香川県</option>\n<option value=\"38\" >愛媛県</option>\n<option value=\"39\" >高知県</option>\n<option value=\"40\" >福岡県</option>\n<option value=\"41\" >佐賀県</option>\n<option value=\"42\" >長崎県</option>\n<option value=\"43\" >熊本県</option>\n<option value=\"44\" >大分県</option>\n<option value=\"45\" >宮崎県</option>\n<option value=\"46\" >鹿児島県</option>\n<option value=\"47\" >沖縄県</option>\n</select>\n\n              <p>市区町村番地</p>\n              <input type=\"text\" name=\"address\" value=\"\" class=\"w_full\"  />\n(全角)\n            </div>\n        </div>\n        \n        <div class=\"form-field-input-pair\">\n          <div class=\"form-field\">お問い合わせ内容を<br>お書きください。<span class=\"required\">※</span></div>\n          <div class=\"form-input\"><textarea name=\"content\" class=\"w_all\" rows=\"10\" required ></textarea>\n</div>\n        </div>\n      </div>\n      <p class=\"indent mt20\">※ 個人情報保護の取扱については<a class=\"under_line\" href=\"../privacy\">プライバシーポリシー</a>をご確認ください。<br>お問い合わせはプライバシーポリシーに同意の上、送信をお願いいたします。</p>\n\n      <div class=\"btn_box\" align=\"center\">\n        <p class=\"btn_midashi bold\">入力が終わりましたら『確認』ボタンを押してください。</p>\n        <input type=\"submit\" name=\"submit\" value=\" 確　認 \">\n        <input type=\"reset\" name=\"reset\" value=\" リセット\">\n      </div>\n\n    </form>\n    \n</div>\n\n          </div>\n          \n      </div>\n      \n      <div id=\"page_top\"><a href=\"#\"></a></div>\n      <footer>\n          <div class=\"ft_inner\">\n              <div class=\"ft_left\">\n                  <p class=\"ft_logo\"><img src=\"../common/img/ft_logo.svg\" alt=\"株式会社エイリイ・エンジニアリング\"></p>\n                  <address class=\"ft_address\">〒357-0021<br>埼玉県飯能市大字双柳1054番地<br>TEL. 042-983-1701 <br>FAX. 042-983-1709</address>\n              </div>\n              <div class=\"ft_right\">\n                  <div class=\"ft_sitemap\">\n                      <ul class=\"ft_column\">\n                          <li class=\"ft_item\"><a href=\"../\">トップページ</a></li>\n                          <li class=\"ft_item\"><a href=\"../service/\">事業案内</a></li>\n                          <li class=\"ft_item\"><a href=\"../belief/\">エイリイ・エンジニアリングの理念</a></li>\n                          <li class=\"ft_item\"><a href=\"../company/\">会社概要</a></li>\n                      </ul>\n                      <ul class=\"ft_column\">\n                          <li class=\"ft_item\"><a href=\"../recruit/\">採用情報</a></li>\n                          <li class=\"ft_item\"><a href=\"../topics\">お知らせ</a></li>\n                          <li class=\"ft_item\"><a href=\"../sitemap\">サイトマップ</a></li>\n                          <li class=\"ft_item\"><a href=\"../privacy\">プライバシーポリシー</a></li>\n                          <li class=\"ft_item\"><a href=\"#\">お問い合わせ</a></li>\n                      </ul>\n                  </div>\n                  <div class=\"ft_bnr_area\">\n                      <p class=\"ft_bnr\"><a href=\"https://tohmei.com/\" target=\"_blank\" rel=\"noopener\"><img src=\"../common/img/ft_bnr_01.png\" alt=\"東明グループ\"></a></p>\n                      <p class=\"ft_bnr\"><img src=\"../common/img/ft_bnr_02.png\" alt=\"jis\"></p>\n                      <p class=\"ft_bnr\"><a href=\"https://tayou.pref.saitama.lg.jp/sd/O-001181\" target=\"_blank\"><img src=\"../common/img/ft_bnr_03.png\" alt=\"多様な働き方実践企業\"></a></p>\n                      <p class=\"ft_bnr\"><img src=\"../common/img/ft_bnr_04.png\" alt=\"守りたいを支えたい 予備自衛官等協力事務所\"></p>\n                  </div>\n              </div>\n          </div>\n          <div class=\"copyright\"><small>Copyright (C)2021  ALAE Engineering Co.,Ltd. All rights Reserved.</small><a href=\"https://www.d-berry.jp/\" target=\"_blank\" rel=\"noopener\"><img src=\"../common/img/copyright.svg\" alt=\"埼玉県のホームページ制作会社 株式会社デジタルベリー\"></a></div>\n      </footer>\n  </body>\n</html>\n","finalUrl":"https://www.alae.co.jp/contact/","rendered":false,"_cachedAt":"2026-06-22T22:36:21.020Z"}