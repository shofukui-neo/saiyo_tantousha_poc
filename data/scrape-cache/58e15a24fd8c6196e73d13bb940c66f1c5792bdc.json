_background_svg\">\r\n      </p>\r\n      <h1 class=\"h2\">お問い合わせ</h1>\r\n    </div>\r\n  </div>\r\n\r\n  <div class=\"pankuzu\">\r\n    <ul>\r\n      <li><a href=\"https://www.yashimadenko.co.jp\">ホーム</a></li>\r\n      <li>お問い合わせ</li>\r\n    </ul>\r\n  </div>\r\n\r\n\r\n  <!-- コンテンツ============================================= -->\r\n  <div id=\"contact\">\r\n    <div class=\"container\">\r\n     \r\n        <div id=\"mw_wp_form_mw-wp-form-181\" class=\"mw_wp_form mw_wp_form_input  \">\n\t\t\t\t\t<form method=\"post\" action=\"\" enctype=\"multipart/form-data\"><!-- カテゴリリンクエリア================================ -->\r\n<div class=\"category_link_area\"><!-- ボタン単体 -->\r\n<div class=\"btn_area\"><a class=\"btn_category tel\" href=\"#tel_group\">\r\n電話でのお問い合わせ\r\n</a></div>\r\n<!-- ボタン単体 -->\r\n<div class=\"btn_area\"><a class=\"btn_category fax\" href=\"#fax_group\">\r\nFAXでのお問い合わせ\r\n</a></div>\r\n<!-- ボタン単体 -->\r\n<div class=\"btn_area\"><a class=\"btn_category mail\" href=\"#form_group\">\r\nお問い合わせフォーム\r\n</a></div>\r\n</div>\r\n<!-- コンタクト手段グループ 電話============ -->\r\n<div id=\"tel_group\" class=\"contact_means_group tel\">\r\n<h2 class=\"headline_title\">電話でのお問い合わせ</h2>\r\n<p class=\"guidance_text\">※電話でのお問い合わせはお近くの支店・営業所まで直接お電話ください。</p>\r\n\r\n<div class=\"office_archive_btn_area\"><a class=\"btn office_archive_btn\" href=\"https://www.yashimadenko.co.jp/company/#salesoffice\">\r\n支店・営業所はこちら\r\n</a></div>\r\n</div>\r\n<!-- コンタクト手段グループ FAX============ -->\r\n<div id=\"fax_group\" class=\"contact_means_group fax\">\r\n<h2 class=\"headline_title\">FAXでのお問い合わせ</h2>\r\n<p class=\"content_text_area\"><span class=\"content_text\">\r\n全国共通24時間受付\r\n</span>\r\n<span class=\"fax_number\">06-6222-5013</span>\r\n<span class=\"or_text\">\r\nまたは\r\n</span>\r\n<span class=\"fax_number\">050-3548-9966</span></p>\r\n\r\n</div>\r\n<!-- コンタクト手段グループ フォーム============ -->\r\n<div id=\"form_group\" class=\"contact_means_group form\">\r\n<h2 class=\"headline_title\">お問い合わせフォーム</h2>\r\n<p cl