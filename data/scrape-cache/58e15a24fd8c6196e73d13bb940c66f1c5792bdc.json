quot;,&quot;\\u65b0\\u805e\\u30fb\\u5c02\\u9580\\u8a8c&quot;:&quot;\\u65b0\\u805e\\u30fb\\u5c02\\u9580\\u8a8c&quot;,&quot;\\u77e5\\u4eba\\u30fb\\u540c\\u50da&quot;:&quot;\\u77e5\\u4eba\\u30fb\\u540c\\u50da&quot;,&quot;\\u516b\\u5dde\\u96fb\\u5de5\\u306eSNS&quot;:&quot;\\u516b\\u5dde\\u96fb\\u5de5\\u306eSNS&quot;,&quot;\\u305d\\u306e\\u4ed6&quot;:&quot;\\u305d\\u306e\\u4ed6&quot;}\" />\n\r\n\n<input type=\"text\" name=\"chance-other\" id=\"address\" class=\"chance-other text_input\" size=\"60\" value=\"\" />\n\r\n</div>\r\n</div>\r\n<!-- 入力アイテム -->\r\n<div class=\"input_item\">\r\n<div class=\"item_area\"><label class=\"input_title\" for=\"\">\r\nご用件\r\n</label></div>\r\n<div class=\"input_area select_container\">\n<select name=\"event\" class=\"text_input single_medium select\">\n\t\t\t<option value=\"製品について\" >\n\t\t\t製品について\t\t</option>\n\t\t\t<option value=\"金属加工サービスについて\" >\n\t\t\t金属加工サービスについて\t\t</option>\n\t\t\t<option value=\"耐震計算・強度計算について\" >\n\t\t\t耐震計算・強度計算について\t\t</option>\n\t\t\t<option value=\"その他\" >\n\t\t\tその他\t\t</option>\n\t</select>\n\n<input type=\"hidden\" name=\"__children[event][]\" value=\"{&quot;\\u88fd\\u54c1\\u306b\\u3064\\u3044\\u3066&quot;:&quot;\\u88fd\\u54c1\\u306b\\u3064\\u3044\\u3066&quot;,&quot;\\u91d1\\u5c5e\\u52a0\\u5de5\\u30b5\\u30fc\\u30d3\\u30b9\\u306b\\u3064\\u3044\\u3066&quot;:&quot;\\u91d1\\u5c5e\\u52a0\\u5de5\\u30b5\\u30fc\\u30d3\\u30b9\\u306b\\u3064\\u3044\\u3066&quot;,&quot;\\u8010\\u9707\\u8a08\\u7b97\\u30fb\\u5f37\\u5ea6\\u8a08\\u7b97\\u306b\\u3064\\u3044\\u3066&quot;:&quot;\\u8010\\u9707\\u8a08\\u7b97\\u30fb\\u5f37\\u5ea6\\u8a08\\u7b97\\u306b\\u3064\\u3044\\u3066&quot;,&quot;\\u305d\\u306e\\u4ed6&quot;:&quot;\\u305d\\u306e\\u4ed6&quot;}\" />\n</div>\r\n</div>\r\n<!-- 入力アイテム -->\r\n<div class=\"input_item\">\r\n<div class=\"item_area\"><label class=\"input_title\" for=\"textarea\">\r\nお問い合わせ内容\r\n</label>\r\n<span class=\"mandatory\">必須</span></div>\r\n<div class=\"input_area textarea_input_area\">\n<textarea name=\"contents\" id=\"textarea\" class=\"text_input textarea_input\" cols=\"30\" rows=\"7\" ></textarea>\n</div>\r\n</div>\r\n<!-- 注意事項エリア -->\r\n<div class=\"contact_notes_item\">\r\n<div class=\"item_area\">\r\n<p class=\"input_title\">お問い合わせに関する注意事項</p>\r\n\r\n</div>\r\n<!-- 注意事項スクロールエリア -->\r\n<div class=\"notes_area\">\r\n<p class=\"notes_text\"><span class=\"list_flex\">\r\n<span class=\"number\">1</span>\r\n<span class=\"text\">\r\n社内担当部門にて迅速にお答えを差し上げられるよう努めますが、回答をご連絡させていただくまでにお時間をいただく場合があります。尚、お問い合わせの内容によりましては、お答えできない場合や、書面／電話／FAXなどでお答えさせていただく場合もございますので、あらかじめご了承ください。<br class=\"break\" />お急ぎの場合や価格・図面等に関してはお近くの当社営業所までお電話にてご連絡いただきますようお願いします。<br class=\"break\" />受付時間8:30～17:30（土・日・祝日を除く）\r\n</span>\r\n</span>\r\n<span class=\"list_flex\">\r\n<span class=\"number\">2</span>\r\n<span class=\"text\">\r\n土曜日、日曜日・祝日など弊社休業日にいただいたお問い合わせにつきましては、翌営業日以降の回答となりますので、ご了承ください。\r\n</span>\r\n</span>\r\n<span class=\"list_flex\">\r\n<span class=\"number\">3</span>\r\n<span class=\"text\">\r\n当社からお客様に回答いたしましたメールは、お客様個人に宛てたものです。<br class=\"break\" />メールの一部または全部を転用したり、二次利用することは、ご遠慮ください。\r\n</span>\r\n</span>\r\n<span class=\"list_flex\">\r\n<span class=\"number\">4</span>\r\n<span class=\"text\">\r\nお客様にご記入いただきました個人情報につきましては、弊社で責任をもって管理し、お客様への回答にのみ使用させていただき、第三者への開示や他の目的には使用いたしません。<br class=\"break\" />本メールフォームによってご提供いただく個人情報の取り扱いの詳細については、必ず、こちらをご確認いただき、ご同意の上、ご利用いただきますようお願いします。\r\n</span>\r\n</span></p>\r\n\r\n</div>\r\n</div>\r\n<!-- プライバシーポリシーエリア -->\r\n<div class=\"privacy_policy_area\">\r\n<p class=\"privacy_policy_text\">「 <a class=\"privacy_policy_link\" href=\"https://www.yashimadenko.co.jp/policy\" target=\"_blank\" rel=\"noopener\">プライバシーポリシー</a>」をお読みいただき、<br class=\"sp_break\" />同意していただける場合には、<br class=\"break\" />「同意する」にチェックをしてください。<br class=\"sp_break\" />チェックがない場合には情報は送信されません。</p>\r\n\r\n<div class=\"privacy_policy_checkbox_group\">\r\n\r\n\n\t<span class=\"mwform-checkbox-field horizontal-item\">\n\t\t<label for=\"checkbox6-1\">\n\t\t\t<input type=\"checkbox\" name=\"confirm[data][]\" value=\"同意します\" id=\"checkbox6-1\" class=\"checkbox privacy_policy_checkbox\" />\n\t\t\t<span class=\"mwform-checkbox-field-text\">同意します</span>\n\t\t</label>\n\t</span>\n\n<input type=\"hidden\" name=\"confirm[separator]\" value=\",\" />\n\n<input type=\"hidden\" name=\"__children[confirm][]\" value=\"{&quot;\\u540c\\u610f\\u3057\\u307e\\u3059&quot;:&quot;\\u540c\\u610f\\u3057\\u307e\\u3059&quot;}\" />\n\r\n\r\n&nbsp;\r\n\r\n</div>\r\n\r\n\r\n</div>\r\n<p class=\"confirm-txt\">\r\n以下の登録内容で受け付けさせていただきます。内容をご確認いただき、問題がなければ送信ボタンをクリックしてください。\r\n</p> \r\n<div class=\"confirm_btn_area\">\n<input type=\"submit\" name=\"submitConfirm\" value=\"確認\" class=\"confirm_btn\"/>\n\r\n\r\n\n<input type=\"hidden\" name=\"recaptcha-v3\" value=\"\" />\n\r\n\r\n</div>\r\n</div>\r\n</div>\r\n<input type=\"hidden\" id=\"mw_wp_form_token\" name=\"mw_wp_form_token\" value=\"cb87e42aae\" /><input type=\"hidden\" name=\"_wp_http_referer\" value=\"/contact/\" /><input type=\"hidden\" name=\"mw-wp-form-form-id\" value=\"181\" /><input type=\"hidden\" name=\"mw-wp-form-form-verify-token\" value=\"6d38c7acef98333b33016c6121dc31784ed3a047\" /></form>\n\t\t\t\t<!-- end .mw_wp_form --></div>\r\n      \r\n\r\n    </div>\r\n\r\n  </div>\r\n\r\n</main>\t\t\t\t<section class=\"footAddArea\">\n\t\t\t\t\t<div class=\"container\">\n\t\t\t\t\t\t\t<div class=\"contactIngfoArea\">\n\t\t\t\t\t\t\t\t<div class=\"title\">\n\t\t\t\t\t\t\t\t\t<div class=\"j\">お問い合わせ</div>\n\t\t\t\t\t\t\t\t\t<div class=\"en\">CONTACT</div>\n\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t<div class=\"message\">製品やサービスに関するご質問・不明点などお気軽にご相談ください。</div>\n\t\t\t\t\t\t\t\t<div class=\"btnArea\">\n\t\t\t\t\t\t\t\t\t<a class=\"btnBox\" href=\"https://www.yashimadenko.co.jp/contact/\">\n\t\t\t\t\t\t\t\t\t\t<div class=\"main\">お問い合わせフォーム</div>\n\t\t\t\t\t\t\t\t\t\t<div class=\"sub\">専門の担当者がご返答いたします。</div>\n\t\t\t\t\t\t\t\t\t</a>\n\t\t\t\t\t\t\t\t\t<a class=\"btnBox\" href=\"https://www.yashimadenko.co.jp/estimate/\">\n\t\t\t\t\t\t\t\t\t\t<d