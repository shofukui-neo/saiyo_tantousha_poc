span>PERSONAL</span>個人のお客さま</a> </div>\n              <ul class=\"menu_inner\">\n                <li><a href=\"../personal/goods.html\">防犯・防災商品</a></li>\n                <li><a href=\"../personal/insuarance.html\">損害保険</a></li>\n              </ul>\n            </div>\n          </div>\n        </li>\n        <li><a href=\"../business/\">法人のお客さま</a>\n          <div class=\"menu\">\n            <div class=\"menu_wrap\">\n              <div class=\"menu_title\"> <a href=\"../business/\"><span>BUSINESS</span>法人のお客さま</a> </div>\n              <ul class=\"menu_inner\">\n                <li><a href=\"../business/guard.html\">常駐警備</a></li>\n                <li><a href=\"../business/sales.html\">現金護送</a></li>\n                <li><a href=\"../business/insuarance.html\">損害保険</a></li>\n                <li><a href=\"../business/anpi.html\">安否確認サービス</a></li>\n              </ul>\n            </div>\n          </div>\n        </li>\n        <li><a href=\"../recruit/\">採用情報</a>\n          <div class=\"menu\">\n            <div class=\"menu_wrap\">\n              <div class=\"menu_title\"> <a href=\"../recruit/\"><span>RECRUIT</span>採用情報</a> </div>\n              <ul class=\"menu_inner\">\n                <li><a href=\"../recruit/idea.html\">理念と風土</a></li>\n                <li><a href=\"../recruit/system.html\">人事制度</a></li>\n                <li><a href=\"../recruit/guidelines.html\">募集要項</a></li>\n\t\t\t\t<li><a href=\"https://www.secom.co.jp/recruit/portal/wellbeing/\" target=\"_blank\" class=\"ex\">働きやすさの推進</a></li>\n              </ul>\n            </div>\n          </div>\n        </li>\n        <li><a href=\"../corporate/\">会社案内</a>\n          <div class=\"menu\">\n            <div class=\"menu_wrap\">\n              <div class=\"menu_title\"> <a href=\".../corporate/\"><span>COMPANY</span>会社案内</a> </div>\n              <ul class=\"menu_inner\">\n                <li><a href=\"../corporate/history.html\">沿革</a></li>\n                <li><a href=\"../corporate/about.html\">会社概要</a></li>\n                <li><a href=\"../corporate/group.html\">支社・営業所</a></li>\n                <li><a href=\"../corporate/jastic.html\">セコムジャスティック山梨</a></li>\n              </ul>\n            </div>\n          </div>\n        </li>\n        <li><a href=\"../contact/\">お問い合わせ</a></li>\n      </ul>\n    </nav>\n  </div>\n</header>\r\n<div class=\"contents\">\r\n  <section id=\"main-head\" class=\"recruit\">\r\n    <div class=\"breadcrumb\">\r\n      <ul>\r\n        <li><a href=\"../\">ホーム</a></li>\r\n        <li><a href=\"./\">採用情報</a></li>\r\n        <li>新卒者募集要項</li>\r\n      </ul>\r\n    </div>\r\n    <div class=\"inner\">\r\n      <div class=\"title\"> <img src=\"./images/recruit_i.png\" alt=\"採用情報\" width=\"60\">\r\n        <p>RECRUIT</p>\r\n        <h1>採用情報</h1>\r\n      </div>\r\n    </div>\r\n  </section>\r\n  <section class=\"main-title\">\r\n    <h2>新卒者募集要項</h2>\r\n  </section>\r\n  <section id=\"main\" class=\"inner\">\r\n  <h3>セコム山梨株式会社2027年３月新規卒業見込の方の募集要項</h3>\r\n    <table class=\"baseT\">\r\n   \t\t  \t<tr>\r\n   \t\t  \t\t<th>募集対象</th>\r\n   \t\t  \t\t<td>2027年3月に大学・短大・高専・専門学校を卒業、大学院を修了見込みの方</td>\r\n\t  \t\t </tr>\r\n   \t\t  \t<tr>\r\n   \t\t  \t\t<th>採用職種</th>\r\n   \t\t  \t\t<td>ビートエンジニア(BE)、事務職、営業職</td>\r\n\t  \t\t </tr>\r\n   \t\t  \t<tr>\r\n   \t\t  \t\t<th>初任給</th>\r\n   \t\t  \t\t<td>250,105円（4年制大学卒 Gコースの場合）<br>\r\n   \t\t  \t\t\t＊入社時のコース選択等により金額は異なります</td>\r\n\t  \t\t </tr>\r\n   \t\t  \t<tr>\r\n   \t\t  \t\t<th>諸手当</th>\r\n   \t\t  \t\t<td>都市、通勤、家族他</td>\r\n\t  \t\t </tr>\r\n   \t\t  \t<tr>\r\n   \t\t  \t\t<th>昇給</th>\r\n   \t\t  \t\t<td>年１回（４月）</td>\r\n\t  \t\t </tr>\r\n   \t\t  \t<tr>\r\n   \t\t  \t\t<th>賞与</th>\r\n   \t\t  \t\t<td>年２回（６月、12月）</td>\r\n\t  \t\t </tr>\r\n   \t\t  \t<tr>\r\n   \t\t  \t\t<th>勤務時間</th>\r\n   \t\t  \t\t<td>09：00～18：00　<br>\r\n\t  \t\t\t(フィールド勤務は週39時間を基準とした、１ヶ月単位の変形労働時間制)</td>\r\n\t  \t\t </tr>\r\n   \t\t  \t<tr>\r\n   \t\t  \t\t<th>休日</th>\r\n   \t\t  \t\t<td>週休２日制：原則として土・日・祝日（フィールド勤務は別途規定による）</td>\r\n\t  \t\t </tr>\r\n   \t\t  \t<tr>\r\n   \t\t  \t\t<th>休暇</th>\r\n   \t\t  \t\t<td>週休2日制・祝祭日（セキュリティ事業スタッフは別途規定による）<br>\r\n\t\t\t\t\t有給休暇（入社時9日間・半年後10日間・最大20日間、有休休暇積立制度あり）、慶弔休暇、フレックス休暇（最長10日間及び最長6日間の連続休暇）、リフレッシュ休暇（勤続年数に応じて2～3週間の連続休暇）、産前（6週間）・産後（8週間）休暇、育児休業（3年間）、介護休業（3ヶ月）など</td>\r\n\t  \t\t </tr>\r\n   \t\t  \t<tr>\r\n   \t\t  \t\t<th>福利厚生</th>\r\n   \t\t  \t\t<td>各種社会保険、企業年金制度、財形制度、社員持株制度（セコム(株)）、保養所（軽井沢・御殿場・名張）、奨学金返還支援制度、ジム法人契約</td>\r\n\t  \t\t </tr>\r\n   \t\t  \t<tr>\r\n   \t\t  \t\t<th>研修制度</th>\r\n   \t\t  \t\t<td>新入社員研修、新任マネージャー研修、通信教育助成制度</td>\r\n\t  \t\t </tr>\r\n   \t\t  \t<tr>\r\n   \t\t  \t\t<th>選考方法</th>\r\n   \t\t  \t\t<td>適性検査、面接</td>\r\n\t  \t\t </tr>\r\n   \t\t  \t<tr>\r\n   \t\t  \t\t<th>提出書類</th>\r\n   \t\t  \t\t<td>エントリーシート（写真貼付）、成績証明書、卒業見込証明書、健康診断書</td>\r\n\t  \t\t </tr>\r\n   \t\t  \t<tr>\r\n   \t\t  \t\t<th>問い合わせ先</th>\r\n \t\t  \t\t <td>管理部総務課　採用担当宛<br>\r\n   \t\t  \t\t\t〒400-0047　山梨県甲府市徳行 3-12-25　セコム山梨ビル<br>\r\n \t\t  \t\t\tTEL　055-220-7700<br>\r\n \t\t  \t\t\tFAX　055-220-7391<br><br>\r\n\t\t\t\t\t↓マイナビサイトはこちら↓<br>\r\n\t<!-- Begin mynavi Navi Link -->\r\n      <a href=\"https://job.mynavi.jp/27/pc/search/corp214228/outline.html\" target=\"_blank\">\r\n        <img src=\"https://job.mynavi.jp/conts/kigyo/2027/logo/banner_entry_130_130.gif\" alt=\"マイナビ2027\" border=\"0\">\r\n      </a>\r\n      <!-- End mynavi Navi Link -->\r\n\t\t\t\t\t ※マイナビからもお問い合わせいただけます。</td>\r\n\t  \t\t </tr>\r\n \t\t  \t</table>\r\n  </section>\r\n  <section id=\"subArea\">\r\n    <div class=\"inner\">\r\n      <h4><span>採用情報</span></h4>\n<ul>\n    <li><a class=\"fade\" href=\"./\"><i class=\"fas fa-chevron-circle-right\"></i><span class=\"ls0\">セコムの目指すもの</span></a></li>\n    <li><a class=\"fade\" href=\"./idea.html\"><i class=\"fas fa-chevron-circle-right\"></i>理念と風土</a></li>\n    <li><a class=\"fade\" href=\"./system.html\"><i class=\"fas fa-chevron-circle-right\"></i>人事制度</a></li>\n    <li><a class=\"fade\" href=\"./guidelines.html\"><i class=\"fas fa-chevron-circle-right\"><