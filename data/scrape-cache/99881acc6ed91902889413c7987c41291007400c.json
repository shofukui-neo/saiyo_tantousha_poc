iper-slide\">\n\t\t\t\t\t\t\t\t\t\t\t<img src=\"https://miraitolink.co.jp/site/wp-content/themes/miraitolink2023/images/idx_business1-2.jpg\" class=\"objf\" loading=\"lazy\">\n\t\t\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t<div class=\"txt\" data-cursor-img=\"https://miraitolink.co.jp/site/wp-content/themes/miraitolink2023/images/idx_business1-1.jpg\">\n\t\t\t\t\t\t\t\t<span>継</span>\n\t\t\t\t\t\t\t\t<h3>事業承継支援事業</h3>\n\t\t\t\t\t\t\t\t<p>昨今よく問題として取り上げられる後継者不在のために会社が存続が難しくなる事業承継問題。優れた技術や品質を維持しつつ地域の伝統を絶やすことなく存続するお手伝いをミライトリンクでは行っています。</p>\n\t\t\t\t\t\t\t\t<div class=\"_root inview blur action\">\n\t\t\t\t\t\t\t\t\t<a href=\"https://lp.miraitolink.co.jp/\" target=\"_blank\" class=\"link_text\">\n\t\t\t\t\t\t\t\t\t\t<span>さらに詳しく</span>\n\t\t\t\t\t\t\t\t\t\t<i><img src=\"https://miraitolink.co.jp/site/wp-content/themes/miraitolink2023/images/icon/arw.svg\" width=\"32\" height=\"32\" class=\"objf\" loading=\"lazy\"></i>\n\t\t\t\t\t\t\t\t\t</a>\n\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t\t<div class=\"__block showOn sticky\">\n\t\t\t\t\t\t\t<div class=\"background\">\n\t\t\t\t\t\t\t\t<div class=\"slide_wrapper first-container\">\n\t\t\t\t\t\t\t\t\t<div class=\"swiper-wrapper\">\n\t\t\t\t\t\t\t\t\t\t<div class=\"swiper-slide\">\n\t\t\t\t\t\t\t\t\t\t\t<img src=\"https://miraitolink.co.jp/site/wp-content/themes/miraitolink2023/images/idx_business2.jpg\" class=\"objf\" loading=\"lazy\">\n\t\t\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t\t\t<div class=\"swiper-slide\">\n\t\t\t\t\t\t\t\t\t\t\t<img src=\"https://miraitolink.co.jp/site/wp-content/themes/miraitolink2023/images/idx_business2-2.jpg\" class=\"objf\" loading=\"lazy\">\n\t\t\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t\t\t<div class=\"swiper-slide\">\n\t\t\t\t\t\t\t\t\t\t\t<img src=\"https://miraitolink.co.jp/site/wp-content/themes/miraitolink2023/images/idx_business2-3.jpg\" class=\"objf\" loading=\"lazy\">\n\t\t\t\t\t\t\t\t\t\t</