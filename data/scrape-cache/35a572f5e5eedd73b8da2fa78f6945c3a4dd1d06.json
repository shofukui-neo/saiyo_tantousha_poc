length=\"255\" style=\"width:100%\" class=\"Form-Item-Input text \" placeholder=\"例）2005年１月１日\"></td>\n\t\t\t\t\t</tr>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<th><span class=\"title \">大学名</span></th>\n\t\t\t\t\t\t<td><input type=\"text\" name=\"university\" id=\"university\" value=\"\" maxlength=\"255\" style=\"width:100%\" class=\"Form-Item-Input text \" placeholder=\"例）横浜食品大学\"><br><span class=\"text85\">※卒業予定の方は必ず入力してください</span></td>\n\t\t\t\t\t</tr>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<th class=\"furigana\"><span class=\"title \">学部、<br class=\"mobile_br\">学科</span></th>\n\t\t\t\t\t\t<td><input type=\"text\" name=\"faculty\" id=\"faculty\" value=\"\" maxlength=\"255\" style=\"width:100%\" class=\"Form-Item-Input text \" placeholder=\"例）横浜学部　横浜学科\"><br><span class=\"text85\">※卒業予定の方は必ず入力してください</span></td>\n\t\t\t\t\t</tr>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<th><span class=\"title required \">電話番号</span><em>必須</em></th>\n\t\t\t\t\t\t<td><input type=\"text\" name=\"tel\" id=\"tel\" value=\"\" maxlength=\"255\" style=\"width:100%\" class=\"Form-Item-Input text \" placeholder=\"例）09088887777\"></td>\n\t\t\t\t\t</tr>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<th><span class=\"title required \">メール<br class=\"mobile_br\">アドレス</span><em>必須</em></th>\n\t\t\t\t\t\t<td><input type=\"text\" name=\"email\" id=\"email\" value=\"\" maxlength=\"255\" style=\"width:100%\" class=\"Form-Item-Input text \" placeholder=\"例）yokohama@yokohamafoods.ac.jp\"></td>\n\t\t\t\t\t</tr>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<th><span class=\"title required \">会社説明会</span><em>必須</em></th>\n\t\t\t\t\t\t<td>会社説明会の日程からお選びください<br><textarea name=\"day\" id=\"day\" cols=\"40\" rows=\"3\" style=\"width:100%\" class=\"Form-Item-Inputtextarea \" placeholder=\"例）希望日：2025/00/00(水)　10:00～11:00\"></textarea></td>\n\t\t\t\t\t</tr>\n\n\n\n\n\t\t\t\t</tbody>\n\t\t\t</table>\n\t    </div> \n    </section>\n\t  \n  </div><!-- .main-contents /-->\n<div class=\"text-center\"><input type=\"submit\" value=\"確認画面へ\" class=\"submit\" /></div>\n</form>\n<!-- 入力部