{"url":"https://ftecweb.net/contact/","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n<head>\n<meta charset=\"utf-8\">\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\" >\n<meta name=\"format-detection\" content=\"telephone=no\">\n\n\n<!-- Viewport\n======================================================================-->\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1, maximum-scale=1, user-scalable=0\">\n\n\n<!-- SEO\n======================================================================-->\n<title>お問い合わせ｜FTEC株式会社</title>\n<meta name=\"description\" content=\"FTEC株式会社のお問い合わせはフォームです。プラントメンテナンス、人材派遣に関するご質問などはこちらからお問い合わせください。\">\n<meta name=\"keywords\" content=\"\">\n\n\n<!-- Facebook\n======================================================================-->\n<meta property=\"og:title\" content=\"お問い合わせ｜FTEC株式会社\">\n<meta property=\"og:type\" content=\"website\">\n<meta property=\"og:url\" content=\"https://ftecweb.net/\">\n<meta property=\"og:image\" content=\"https://ftecweb.net/images/share/OGP.png\">\n<meta property=\"og:site_name\" content=\"\">\n<meta property=\"og:description\" content=\"FTEC株式会社のお問い合わせはフォームです。プラントメンテナンス、人材派遣に関するご質問などはこちらからお問い合わせください。\" />\n<meta property=\"fb:app_id\" content=\"\">\n\n\n<!-- CSS\n======================================================================-->\n<link href=\"//fonts.googleapis.com/css?family=Fira+Sans:400,700\" rel=\"stylesheet\">\n<link rel=\"stylesheet\" href=\"//cdnjs.cloudflare.com/ajax/libs/animate.css/3.5.2/animate.min.css\">\n<link href=\"https://ftecweb.net/css/owl.carousel.css\" rel=\"stylesheet\">\n<link href=\"https://ftecweb.net/css/style.css\" rel=\"stylesheet\">\n<link href=\"https://ftecweb.net/css/custom.css\" rel=\"stylesheet\">\n\n<!-- Favicon\n======================================================================-->\n<link rel=\"icon\" href=\"https://ftecweb.net/images/favicons/favicon.ico\">\n<link rel=\"shortcut icon\" href=\"https://ftecweb.net/images/favicons/favicon.ico\">\n<link rel=\"apple-touch-icon\" href=\"https://ftecweb.net/images/favicons/apple-touch-icon.png\">\n\n\n<!-- IE Hack\n======================================================================-->\n<!--[if lt IE 9]>\n<script src=\"//cdn.jsdelivr.net/html5shiv/3.7.2/html5shiv.min.js\"></script>\n<script src=\"//cdnjs.cloudflare.com/ajax/libs/respond.js/1.4.2/respond.min.js\"></script>\n<![endif]-->\n\n\n<!-- Google Tag Manager\n======================================================================-->\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n})(window,document,'script','dataLayer','GTM-W2LXBVQ');</script>\n<!-- End Google Tag Manager -->\n\n\n<!-- WP\n======================================================================-->\n</head>\n\n<body class=\"contact\">\n\n\n\n\t<!-- Header\n\t======================================================================-->\n\t<header id=\"header\">\n  <div id=\"headerContact\">\n    <img src=\"https://ftecweb.net/images/common/logo_contact.svg\" alt=\"\" class=\"pc\" style=\"max-width:523px;\">\n    <img src=\"https://ftecweb.net/images/common/logo_contact_sp.svg\" alt=\"\" class=\"sp\" style=\"max-width:523px;padding:0 20px;\">\n  </div>\n</header>\n\n\n\n\t<!-- Wrap\n\t======================================================================-->\n\t<div id=\"wrap\">\n\n\n\n\t\t<!-- Main Content\n\t\t======================================================================-->\n\t\t<main>\n\t\t\t<div class=\"mainvisual\">\n\t\t\t\t<div class=\"titlebox\">\n\t\t\t\t\t<div class=\"title\">\n\t\t\t\t\t\t<h1>お問い<br>合わせ</h1>\n\t\t\t\t\t\t<span class=\"title-en\">CONTACT</span>\n\t\t\t\t\t</div><!-- .title -->\n\t\t\t\t</div><!-- .title -->\n\t\t\t\t<div class=\"breadcrumb\">\n\t\t\t\t\t<div class=\"breadcrumb-inner\">\n\t\t\t\t\t</div><!-- .breadcrumb-inner -->\n\t\t\t\t</div><!-- .breadcrumb -->\n\t\t\t</div><!-- .mainvisual -->\n\n\t\t\t<div id=\"main-contents\">\n\t\t\t\t<section id=\"intro\">\n\t\t\t\t\t<p>\n\t\t\t\t\t\t事業に関してのご質問・ご相談がありましたら<br class=\"pc\">\n\t\t\t\t\t\tお気軽にお問い合わせください。\n\t\t\t\t\t</p>\n\t\t\t\t</section><!-- #intro -->\n\n\n\t\t\t\t<section id=\"tel\">\n\t\t\t\t\t<div class=\"upper-decoration\"></div><!-- .upper-decoration -->\n\t\t\t\t\t<div class=\"title-with-icon\">\n\t\t\t\t\t\t<img src=\"../images/contact/icon01.svg\" alt=\"\" class=\"pc\">\n\t\t\t\t\t\t<img src=\"../images/contact/icon01-sp.svg\" alt=\"\" class=\"sp\">\n\t\t\t\t\t\t<h2>お電話でのお問い合わせ</h2>\n\t\t\t\t\t</div><!-- .title-with-icon -->\n\n\t\t\t\t\t<div class=\"tel-area\">\n\t\t\t\t\t\t<a href=\"tel:0770-39-1122\" class=\"num\">\n\t\t\t\t\t\t\t<img src=\"../images/contact/icon_tel.svg\" alt=\"\" class=\"pc\">\n\t\t\t\t\t\t\t<span class=\"icon-sp\">0770-39-1122</span>\n\t\t\t\t\t\t\t<small>受付時間<span>8:15-17:00</span></small>\n\t\t\t\t\t\t</a>\n\t\t\t\t\t</div><!-- .tel-area -->\n\n\t\t\t\t\t<div class=\"under-decoration\"></div><!-- .under-decoration -->\n\t\t\t\t</section><!-- #tel -->\n\n\t\t\t\t<section id=\"formcontent\">\n\n\t\t\t\t\t<div class=\"title-with-icon\">\n\t\t\t\t\t\t<img src=\"../images/contact/icon02.svg\" alt=\"\">\n\t\t\t\t\t\t<h2>Webでのお問い合わせ</h2>\n\t\t\t\t\t</div><!-- .title-with-icon -->\n\n\t\t\t\t\t<div class=\"stepWhole\">\n\t\t\t\t\t\t<ol class=\"stepBar step3\">\n\t\t\t\t\t\t\t<li class=\"step current\"><small>STEP1</small><span>入力</span></li>\n\t\t\t\t\t\t\t<li class=\"step\"><small>STEP2</small><span>確認</span></li>\n\t\t\t\t\t\t\t<li class=\"step\"><small>STEP3</small><span>完了</span></li>\n\t\t\t\t\t\t\t<li class=\"step\"></li>\n\t\t\t\t\t\t</ol>\n\t\t\t\t\t</div><!-- .stepWhole -->\n\n\t\t\t\t\t<p class=\"description\">\n\t\t\t\t\t\t※未入力の入力エリアはオレンジ色です。(入力すると色がグレーに変わります)\n\t\t\t\t\t</p><!-- .description -->\n\n\t\t\t\t\t<form id=\"contactForm\" action=\"https://ftecweb.net/contact/confirm.php\" method=\"post\">\n\t\t\t\t\t\t<div class=\"formTable\">\n\t\t\t\t\t\t\t<ul>\n\t\t\t\t\t\t\t\t<li><span>必須</span>お問い合わせのご用件</li>\n\t\t\t\t\t\t\t\t<li>\n\t\t\t\t\t\t\t\t\t<div class=\"selectWrap\">\n\t\t\t\t\t\t\t\t\t\t<select name=\"title\" id=\"title\" class=\"require_select\">\n\t\t\t\t\t\t\t\t\t\t\t<option value=\"\">選択してください</option>\n\t\t\t\t\t\t\t\t\t\t\t<option value=\"プラントメンテナンス事業のご依頼/ご相談\">プラントメンテナンス事業のご依頼/ご相談</option>\n\t\t\t\t\t\t\t\t\t\t\t<option value=\"人材派遣事業のご依頼/ご相談\">人材派遣事業のご依頼/ご相談</option>\n\t\t\t\t\t\t\t\t\t\t\t<option value=\"高速炉増殖炉研究開発事業のご依頼/ご相談\">高速炉増殖炉研究開発事業のご依頼/ご相談</option>\n\t\t\t\t\t\t\t\t\t\t\t<option value=\"その他お問い合わせ/ご相談\">その他お問い合わせ/ご相談</option>\n\t\t\t\t\t\t\t\t\t\t</select>\n\t\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t</li>\n\t\t\t\t\t\t\t</ul>\n\t\t\t\t\t\t\t<ul>\n\t\t\t\t\t\t\t\t<li><span>必須</span>企業名</li>\n\t\t\t\t\t\t\t\t<li>\n\t\t\t\t\t\t\t\t\t<div class=\"inputText\">\n\t\t\t\t\t\t\t\t\t\t<input type=\"text\" name=\"company\" value=\"\" placeholder=\"仮) 株式会社〇〇〇〇〇\" class=\"require_text\" />\n\t\t\t\t\t\t\t\t\t</div><!-- .inputText -->\n\t\t\t\t\t\t\t\t</li>\n\t\t\t\t\t\t\t</ul>\n\t\t\t\t\t\t\t<ul>\n\t\t\t\t\t\t\t\t<li><span>必須</span>ご担当者名</li>\n\t\t\t\t\t\t\t\t<li>\n\t\t\t\t\t\t\t\t\t<div class=\"inputText\">\n\t\t\t\t\t\t\t\t\t\t<input type=\"text\" name=\"name\" value=\"\" placeholder=\"仮) 山田太郎\" class=\"require_text\" />\n\t\t\t\t\t\t\t\t\t</div><!-- .inputText -->\n\t\t\t\t\t\t\t\t</li>\n\t\t\t\t\t\t\t</ul>\n\t\t\t\t\t\t\t<ul>\n\t\t\t\t\t\t\t\t<li><span>必須</span>メールアドレス</li>\n\t\t\t\t\t\t\t\t<li>\n\t\t\t\t\t\t\t\t\t<div class=\"inputText\">\n\t\t\t\t\t\t\t\t\t\t<input type=\"email\" name=\"email\" value=\"\" placeholder=\"仮) info@sample.co.jp\" class=\"require_text check_email\" />\n\t\t\t\t\t\t\t\t\t</div><!-- .inputText -->\n\t\t\t\t\t\t\t\t</li>\n\t\t\t\t\t\t\t</ul>\n\t\t\t\t\t\t\t<ul>\n\t\t\t\t\t\t\t\t<li><span>必須</span>電話番号</li>\n\t\t\t\t\t\t\t\t<li>\n\t\t\t\t\t\t\t\t\t<div class=\"inputText\">\n\t\t\t\t\t\t\t\t\t\t<input type=\"tel\" name=\"tel\" value=\"\" placeholder=\"仮) 01012345678\" class=\"require_text check_tel\" />\n\t\t\t\t\t\t\t\t\t</div><!-- .inputText -->\n\t\t\t\t\t\t\t\t</li>\n\t\t\t\t\t\t\t</ul>\n\t\t\t\t\t\t\t<ul>\n\t\t\t\t\t\t\t\t<li><span>必須</span>お問い合わせ内容</li>\n\t\t\t\t\t\t\t\t<li>\n\t\t\t\t\t\t\t\t\t<div class=\"inputTextarea\">\n\t\t\t\t\t\t\t\t\t\t<textarea name=\"body\" id=\"\" cols=\"30\" rows=\"10\" class=\"require_text\" ></textarea>\n\t\t\t\t\t\t\t\t\t</div><!-- .inputTextarea -->\n\t\t\t\t\t\t\t\t</li>\n\t\t\t\t\t\t\t</ul>\n\t\t\t\t\t\t</div><!-- .formTable -->\n\n\t\t\t\t\t\t<div class=\"message\">\n\t\t\t\t\t\t\t<p class=\"title\">【個人情報の取扱いについて】</p><!-- .title -->\n\t\t\t\t\t\t\t<div class=\"body\">\n\t\t\t\t\t\t\t\t<ul>\n\t\t\t\t\t\t\t\t\t<li><span>本フォームからお客様が記入・登録された個人情報は、資料送付・電子メール送信・電話連絡などの目的で利用・保管し、第三者に開示・提供することはありません。</span></li>\n\t\t\t\t\t\t\t\t\t<li><span>プライバシーポリシーについては<a href=\"https://ftecweb.net/privacypolicy/\" target=\"_blank\">こちら</a>をご覧ください。</span></li>\n\t\t\t\t\t\t\t\t</ul>\n\t\t\t\t\t\t\t</div><!-- .body -->\n\t\t\t\t\t\t</div><!-- .message -->\n\t\t\t\t\t\t<div class=\"inputCheckbox\">\n\t\t\t\t\t\t\t<label for=\"checkbox\"><input type=\"checkbox\" value=\"\" id=\"checkbox\"/>個人情報の取り扱いに同意する</label>\n\t\t\t\t\t\t</div><!-- .inputCheckbox -->\n\t\t\t\t\t\t<div class=\"inputSubmit\">\n\t\t\t\t\t\t\t<input type=\"hidden\" name=\"post_flag\" value=\"true\">\n\t\t\t\t\t\t\t<input type=\"submit\" name=\"\" value=\"入力内容を確認する\" disabled=\"disabled\" class=\"submit_btn\">\n\t\t\t\t\t\t</div><!-- .inputSubmit -->\n\t\t\t\t\t</form>\n\t\t\t\t\t<p class=\"bottom-text\">上記フォームで送信できない場合は、必要項目をご記入の上、web-toiawase@ftecnet.comまでメールをお送りください。</p>\n\t\t\t\t</section><!-- #formcontent -->\n\t\t\t</div><!-- $main-contents -->\n\t\t</main>\n\n\n\n\t\t<!-- Footer\n\t\t======================================================================-->\n\t\t<footer>\n  <div id=\"footerContact\">\n\t\t<p>(C)2009 FTEC 株式会社</p>\n  </div>\n</footer>\n\n\n\n\t</div>\n\n\n\n\t<!-- Scripts\n\t======================================================================-->\n\t<script src=\"//ajax.googleapis.com/ajax/libs/jquery/3.1.0/jquery.min.js\"></script>\n<script src=\"https://ftecweb.net/js/owl.carousel.min.js\"></script>\n<script src=\"https://ftecweb.net/js/main.js\"></script>\n<script src=\"https://ftecweb.net/js/common.js\"></script>\n\t<script type=\"text/javascript\">\n\t$(function(){\n\n\t\tvar judge_checkbox = function(checkbox_elem) {\n\t\t\tif(checkbox_elem.prop('checked')) {\n\t\t\t\tcheckbox_elem.parent().css('background','#fff');\n\t\t\t\t$('.submit_btn').prop('disabled', false);\n\t\t\t}else{\n\t\t\t\tcheckbox_elem.parent().css('background','#e8e8eb');\n\t\t\t\t$('.submit_btn').prop('disabled', true);\n\t\t\t}\n\t\t}\n\n\t\t$('#checkbox').change(function() {\n\t\t\tjudge_checkbox($(this));\n\t\t});\n\n\t\t$(window).on('load', function() {\n\t\t\tjudge_checkbox($('#checkbox'));\n\t\t});\n\t});\n\n\t</script>\n\t<script type=\"text/javascript\" src=\"../js/contact.min.js\"></script>\n</body>\n</html>\n","finalUrl":"https://ftecweb.net/contact/","rendered":false,"_cachedAt":"2026-06-23T21:21:14.940Z"}