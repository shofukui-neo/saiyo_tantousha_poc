n                                </li>\n                            \t<li>\n\t\t\t\t\t\t\t\t  <input type=\"checkbox\" value=\"гӮӯгғјгғҜгғјгғүгҒ§жӨңзҙўгҒ—гҒҹ\" id=\"knowreason03\" name=\"knowreason[]\">\n\t\t\t\t\t\t\t\t  <label for=\"knowreason03\">гӮӯгғјгғҜгғјгғүгҒ§жӨңзҙўгҒ—гҒҹ</label>\n                                </li>\n                            \t<li>\n\t\t\t\t\t\t\t\t  <input type=\"checkbox\" value=\"еұ•зӨәдјҡгғ»гӮӨгғҷгғігғҲгҒ§зҹҘгҒЈгҒҹ\" id=\"knowreason04\" name=\"knowreason[]\">\n\t\t\t\t\t\t\t\t  <label for=\"knowreason04\">еұ•зӨәдјҡгғ»гӮӨгғҷгғігғҲгҒ§зҹҘгҒЈгҒҹ</label>\n                                </li>\n                            \t<li>\n\t\t\t\t\t\t\t\t  <input type=\"checkbox\" value=\"еҒ¶з„¶иҰӢгҒӨгҒ‘гҒҹ\" id=\"knowreason05\" name=\"knowreason[]\">\n\t\t\t\t\t\t\t\t  <label for=\"knowreason05\">еҒ¶з„¶иҰӢгҒӨгҒ‘гҒҹ</label>\n                                </li>\n                            \t<li>\n\t\t\t\t\t\t\t\t  <input type=\"checkbox\" value=\"гҒқгҒ®д»–\" id=\"knowreason06\" name=\"knowreason[]\">\n\t\t\t\t\t\t\t\t  <label for=\"knowreason06\">гҒқгҒ®д»–</label>\n                                </li>\n                </ul>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t\t<div class=\"row\">\n\t\t\t\t\t\t<div class=\"cell1\">\n\t\t\t\t\t\t\t<label for=\"comment\">и©ізҙ°<strong>гҖҗеҝ…й ҲгҖ‘</strong></label>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t\t<div class=\"cell2\">\n\t\t\t\t\t\t\t<textarea rows=\"10\" cols=\"30\" name=\"comment\" id=\"comment\"></textarea>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t\t<h2 class=\"mt-35\">еҖӢдәәжғ…е ұдҝқиӯ·ж–№йҮқ</h2>\n\t\t\t\t<div id=\"form-privacy\">\n\t\t\t\t\t<p>гғҖгӮӨгғҠгғ‘гғғгӮҜж ӘејҸдјҡзӨҫ(д»ҘдёӢгҖҢеҪ“зӨҫгҖҚгҒЁиЁҖгҒ„гҒҫгҒҷ)гҒҜеҖӢдәәжғ…е ұдҝқиӯ·гҒ®йҮҚиҰҒжҖ§гӮ’еҚҒеҲҶиӘҚиӯҳгҒ—гҖҒеҖӢдәәжғ…е ұгҒ«гҒӨгҒ„гҒҰеҺіжӯЈгғ»йҒ©еҲҮгҒӘеҸ–жүұгҒ„гӮ’иЎҢгҒҶгҒ“гҒЁгӮ’е®ЈиЁҖгҒ—гҒҫгҒҷгҖӮ</p>\n\t\t\t\t\t<h3>1.жі•д»ӨзӯүгҒ®йҒөе®Ҳ</h3>\n\t\t\t\t\t<p>еҪ“зӨҫгҒҜгҖҒеҖӢдәәжғ…е ұгҒ®дҝқиӯ·гҒ«й–ўгҒҷгӮӢжі•еҫӢ(еҖӢдәәжғ…е ұдҝқиӯ·жі•)гҖҒгҒқгҒ®д»–гҒ®й–ўйҖЈжі•д»ӨгҖҒй–ўдҝӮе®ҳеәҒгҒӢгӮүгҒ®гӮ¬гӮӨгғүгғ©гӮӨгғігӮ’йҒөе®ҲгҒ—гҖҒеҖӢдәәжғ…е ұгӮ’йҒ©жӯЈгҒ«еҸ–жүұгҒҶгҒЁгҒЁгӮӮгҒ«гҖҒе®үе…Ёз®ЎзҗҶгҒ«гҒӨгҒ„гҒҰйҒ©еҲҮгҒӘжҺӘзҪ®гӮ’и¬ӣгҒҳгҒҫгҒҷгҖӮ</p>\n\t\t\t\t\t<h3>2.еҫ“жҘӯе“Ўж•ҷиӮІ</h3>\n\t\t\t\t\t<p>еҪ“зӨҫгҒҜгҖҒеҖӢдәәжғ…е ұгҒ®еҸ–жүұгҒ„гҒҢйҒ©жӯЈгҒ«иЎҢгӮҸгӮҢгӮӢгӮҲгҒҶеҖӢдәәжғ…е ұгӮ’жүұгҒҶеҪ“зӨҫеҫ“жҘӯе“ЎгҒ®ж•ҷиӮІгғ»жҢҮе°ҺгӮ’еҫ№еә•гҒ—гҒҫгҒҷгҖӮ</p>\n\t\t\t\t\t<h3>3.еҖӢдәәжғ…е ұгҒ®еҸ–еҫ—гҒҠгӮҲгҒіеҲ©з”Ёзӣ®зҡ„</h3>\n\t\t\t\t\t<p>еҪ“зӨҫгҒҜгҖҒдәӢжҘӯжҙ»еӢ•гҒ«еҝ…иҰҒгҒӘзҜ„еӣІеҶ…гҒ§гҖҒгҒӢгҒӨгҖҒйҒ©жі•гҒ§е…¬жӯЈгҒӘжүӢж®өгҒ«гӮҲгӮҠеҖӢдәәжғ…е ұгӮ’еҸ–еҫ—гҒҷгӮӢгҒЁгҒЁгӮӮгҒ«гҖҒеҸ–еҫ—жҷӮгҒ«йҖҡзҹҘгҒ—гҒҹеҲ©з”Ёзӣ®зҡ„гҒ®зҜ„еӣІеҶ…гҒ§гҒ®гҒҝеҲ©з”ЁгҒ—гҒҫгҒҷгҖӮ</p>\n\t\t\t\t\t<h3>4.еҖӢдәәжғ…е ұдҝқиӯ·гҒ«й–ўгҒҷгӮӢеҶ…йғЁиҰҸе®ҡгҒ®ж•ҙеӮҷ</h3>\n\t\t\t\t\t<p>еҖӢдәәжғ…е ұдҝқиӯ·гҒ«й–ўгҒҷгӮӢеҶ…йғЁиҰҸзЁӢгӮ’ж•ҙеӮҷгҒ—гҖҒеҖӢдәәжғ…е ұгҒ®еҸ–жүұгҒ„гҒ«гҒӨгҒ„гҒҰжҳҺзўәгҒӘж–№йҮқгӮ’зӨәгҒҷгҒЁгҒЁгӮӮгҒ«гҖҒеҖӢдәәжғ…е ұгҒ®жјҸгҒҲгҒ„зӯүгҒ«еҜҫгҒ—гҒҰгҒҜгҖҒеҺігҒ—гҒ„ж…ӢеәҰгҒ§иҮЁгӮҖгҒ“гҒЁгӮ’е‘ЁзҹҘеҫ№еә•гҒ—гҒҫгҒҷгҖӮ</p>\n\t\t\t\t\t<h3>5.еҖӢдәәжғ…е ұгҒ®е®үе…Ёз®ЎзҗҶжҺӘзҪ®</h3>\n\t\t\t\t\t<p>еҪ“зӨҫгҒҜгҖҒеҸ–жүұгҒҶеҖӢдәәжғ…е ұгҒ®жјҸгҒҲгҒ„гҖҒж»…еӨұгҖҒгҒҫгҒҹгҒҜжҜҖжҗҚгҒ®йҳІжӯўгҖҒгҒқгҒ®д»–гҒ®еҖӢдәәжғ…е ұгҒ®е®үе…Ёз®ЎзҗҶгҒ®гҒҹгӮҒгҒ«гҖҒйҒ©еҲҮгҒӘгӮ»гӮӯгғҘгғӘгғҶгӮЈеҜҫзӯ–гӮ’и¬ӣгҒҳгӮӢгҒЁгҒЁгӮӮгҒ«гҖҒеҲ©з”Ёзӣ®зҡ„гҒ®йҒ”жҲҗгҒ«еҝ…иҰҒгҒЁгҒ•гӮҢгӮӢжӯЈзўәжҖ§гғ»жңҖж–°жҖ§гӮ’зўәдҝқгҒҷгӮӢгҒҹгӮҒгҒ®йҒ©еҲҮгҒӘжҺӘзҪ®гӮ’и¬ӣгҒҳгҒҫгҒҷгҖӮ</p>\n\t\t\t\t\t<h3>6.еҖӢдәәжғ…е ұгҒ®з¬¬дёүиҖ…гҒёгҒ®жҸҗдҫӣ</h3>\n\t\t\t\t\t<p>еҪ“зӨҫгҒҜгҖҒжі•д»ӨгҒ§е®ҡгӮҒгӮүгӮҢгҒҹе ҙеҗҲгӮ’йҷӨгҒҚгҖҒдәӢеүҚгҒ«жң¬дәәгҒ®еҗҢж„ҸгҒӘгҒҸз¬¬дёүиҖ…гҒ«еҖӢдәәжғ…е ұгӮ’жҸҗдҫӣгҒ—гҒҫгҒӣгӮ“гҖӮ</p>\n\t\t\t\t\t<h3>7.еҖӢдәәжғ…е ұгҒ®й–ӢзӨәгҖҒиЁӮжӯЈгҖҒгҒҫгҒҹгҒҜеҲ©з”ЁеҒңжӯў</h3>\n\t\t\t\t\t<p>еҪ“зӨҫгҒҜгҖҒд»ҘдёӢгҒ®дәӢй …гҒ«гҒӨгҒ„гҒҰгҖҒйҒ©еҲҮгҒӢгҒӨгҖҒеҗҲзҗҶзҡ„гҒӘзҜ„еӣІгҒ§еҜҫеҝңгҒ„гҒҹгҒ—гҒҫгҒҷгҖӮ</p>\n\t\t\t\t\t<p>(1)жң¬дәәгҒӢгӮүиҮӘе·ұгҒ®еҖӢдәәжғ…е ұгҒ«гҒӨгҒ„гҒҰй–ӢзӨәгӮ’жұӮгӮҒгӮүгӮҢгҒҹе ҙеҗҲ<br>\n\t\t\t\t\t\t(2)жң¬дәәгҒӢгӮүеҪ“зӨҫгҒҢдҝқжңүгҒ—гҒҰгҒ„гӮӢеҖӢдәәжғ…е ұгҒ«гҒӨгҒҚиЁӮжӯЈгҖҒгҒҫгҒҹгҒҜеҲ©з”ЁеҒңжӯўгӮ’жұӮгӮҒгӮүгӮҢгҒҹе ҙеҗҲ</p>\n\t\t\t\t\t<h3>8.е•ҸгҒ„еҗҲгӮҸгҒӣзӘ“еҸЈ</h3>\n\t\t\t\t\t<p>жң¬д»¶гҒ«й–ўгҒ—гҖҒеҪ“зӨҫгҒ«гҒ”з…§дјҡгҒ„гҒҹгҒ гҒҸе ҙеҗҲгҒҜгҖҒз·ҸеӢҷйғЁгҒҫгҒ§гҒҠе•ҸеҗҲгӮҸгҒӣдёӢгҒ•гҒ„гҖӮгҒқгҒ®йҡӣгҒ«гҒҜгҒ”з…§дјҡиҖ…гҒҢгҒ”жң¬дәәгҒ§гҒӮгӮӢгҒ“гҒЁгӮ’зўәиӘҚгҒ•гҒӣгҒҰгҒ„гҒҹгҒ гҒ„гҒҹдёҠгҒ§еҜҫеҝңгҒ•гҒӣгҒҰгҒ„гҒҹгҒ гҒҚгҒҫгҒҷгҒ®гҒ§гҖҒдәҲгӮҒгҒ”дәҶжүҝйЎҳгҒ„гҒҫгҒҷгҖӮ</p>\n\t\t\t\t\t<p>2006е№ҙ10жңҲ21ж—Ҙ</p>\n\t\t\t\t\t<p class=\"right-position\">гғҖгӮӨгғҠгғ‘гғғгӮҜж ӘејҸдјҡзӨҫ<br>\n\t\t\t\t\t\tгҖ’460-0003<br>\n\t\t\t\t\t\tж„ӣзҹҘзңҢеҗҚеҸӨеұӢеёӮдёӯеҢәйҢҰдёүдёҒзӣ®14з•Ә15еҸ·<br>\n\t\t\t\t\t\tгӮ«гӮҙгғЎгғ“гғ«пј—йҡҺгҖҒпјҳйҡҺ(еҸ—д»ҳ)<br>\n\t\t\t\t\t\tTel:052-971-2651<br>\n\t\t\t\t\t\tFax:052-968-2395</p>\n\t\t\t\t</div>\n\t\t\t\t<div>\n\t\t\t\t\t<p class=\"link-input\">\n\t\t\t\t\t\t<input type=\"button\" value=\"еҖӢдәәжғ…е ұдҝқиӯ·ж–№йҮқгҒ«еҗҢж„ҸгҒ—гҖҒ&#13;&#10;зўәиӘҚз”»йқўгҒё\" onclick=\"sendForm();\" class=\"form-button-send\">\n\t\t\t\t\t</p>\n\t\t\t\t</div>\n\t\t\t</section>\n            \t\t</form>\n\t\t<!-- InstanceEndEditable --></div>\n</div>\n<div id=\"footer-bn-area\">\n\t<div id=\"footer-bn\">\n\t\t<ul>\n\t\t\t<li class=\"bn-1\"><a href=\"/technology/index.html\"><img src=\"/common/images/bn_pc_technology.jpg\" alt=\"ж–°еҚ°еҲ·жҠҖиЎ“гҒ®гҒ”зҙ№д»Ӣ\"></a></li>\n\t\t\t<li class=\"bn-1-sp\"><a href=\"/technology/index.html\"><img src=\"/common/images/bn_sp_technology.jpg\" alt=\"ж–°еҚ°еҲ·жҠҖиЎ“гҒ®гҒ”зҙ№д»Ӣ\"></a></li>\n\t\t\t<li class=\"bn-2\"><a href=\"/results/index.html\"><img src=\"/common/images/bn_results.png\" alt=\"е®ҹзёҫзҙ№д»Ӣ\"></a></li>\n\t\t\t<li class=\"bn-2\"><a href=\"/showroom/index.html\"><img src=\"/common/images/bn_showroom.png\" alt=\"гӮ·гғ§гғјгғ«гғјгғ гҒ®гҒ”жЎҲеҶ…\"></a></li>\n\t\t\t<li class=\"bn-2\"><a href=\"/winning/index.html\"><img src=\"/common/images/bn_winning.png\" alt=\"еҸ—иіһе®ҹзёҫ\"></a></li>\n\t\t\t<li class=\"bn-2\"><a href=\"/reboard_serice/index.html\"><img src=\"/common/images/bn_reboard.png\" alt=\"зҙҷгҒЈгҒҰгӮӢгӮ·гғӘгғјгӮә\"></a></li>\n\t\t</ul>\n\t</div>\n</div>\n<hr>\n\n<hr>\n<p class=\"bread-crumb mb-15\"> <a href=\"/\">гғӣгғјгғ </a> &gt; <!-- InstanceBeginEditable name=\"breadcrumb2\" --><!-- InstanceEndEditable -->гҒҠе•ҸеҗҲгӮҸгҒӣ</p>\n<div id=\"footer-nav-area\">\r\n\t<div id=\"footer-nav\">\r\n\t\t<ul>\r\n\t\t\t<li><a href=\"/privacy/index.html\">гғ—гғ©гӮӨгғҗгӮ·гғјгғқгғӘгӮ·гғј</a></li>\r\n\t\t\t<li><a href=\"/legalnotice/index.html\">е…ҚиІ¬дәӢй …</a></li>\r\n\t\t\t<li><a href=\"/sitemap/index.html\">гӮөгӮӨгғҲгғһгғғгғ—</a></li>\r\n\t\t\t<li id=\"nav-lang-footer\"><a href=\"/foreign_language/\">иӢұиӘһгӮөгӮӨгғҲ(English Site)</a></li>\r\n\t\t</ul>\r\n\t\t<p id=\"copyright\">Copyright &copy; Dynapac Co.,Ltd. All rights reserved.</p>\r\n\t</div>\r\n</div>\r\n\r\n<a href=\"#header\">\r\n<div id=\"totop\"></div>\r\n</a> \r\n<script src=\"https://ajax.googleapis.com/ajax/libs/jquery/1.11.1/jquery.min.js\"></script> \r\n<script src=\"/common/js/g_analytics.js\"></script>\r\n<script src=\"/common/js/script.js\"></script>\r\n<script src=\"/common/js/jquery.matchHeight.js\"></script>\n<!-- InstanceBeginEditable name=\"script\" --> \n<script type=\"text/javascript\" src=\"https://ajaxzip3.github.io/ajaxzip3.js\" ></script> \n<script type=\"text/javascript\">\n$(document).ready(function(){\n    changeItemRequired($(\".checkitem:checked\").val()); // з”»йқўиЎЁзӨәжҷӮ\n    $('.checkitem').change(function(){\n        changeItemRequired($(this).val());\n    });\n});\nfunction changeItemRequired(value) {\n\t\t$('.product-item, .recruit-item, .ir-item, .showroom-item, .compliance-item').hide();\n    if(value === 'гҒҠиҰӢз©ҚгӮҠгӮ„иЈҪе“ҒгҒ«й–ўгҒҷгӮӢгҒҠе•ҸеҗҲгӮҸгҒӣ') {\n        $('.product-item').show();\n    }\n    if(value === 'жҺЎз”ЁгҒ«й–ўгҒҷгӮӢгҒҠе•ҸгҒ„еҗҲгӮҸгҒӣ') {\n        $('.recruit-item').show();\n    }\n    if(value === 'IRгҒ«й–ўгҒҷгӮӢгҒҠе•ҸгҒ„еҗҲгӮҸгҒӣ') {\n        $('.ir-item').show();\n    }\n    if(value === 'гӮ·гғ§гғјгғ«гғјгғ гҒ«й–ўгҒҷгӮӢгҒҠе•ҸеҗҲгӮҸгҒӣ') {\n        $('.showroom-item').show();\n    }\n    if(value === 'еҪ“зӨҫгҒ®дјҒжҘӯжҙ»еӢ•пјҲгӮігғігғ—гғ©гӮӨгӮўгғігӮ№пјүгҒ«й–ўгҒҷгӮӢгҒҠе•ҸеҗҲгӮҸгҒӣ') {\n        $('.compliance-item').show();\n    }\n}\nfunction sendForm() {\n    $('#contact-form').submit();\n}\n$('.checkgroup input[type=\"checkbox\"]').on('change', function(){\n\t\t$('input[name=\"' + this.name + '\"]').not(this).prop('checked', false);\n});\n</script>\n<!-- InstanceEndEditable -->\n</body>\n<!-- InstanceEnd --></html>","finalUrl":"https://www.dynapac-gr.co.jp/contact/","rendered":false,"_cachedAt":"2026-06-22T17:07:07.624Z"}