t\t\t\t\t\t\t\t\t\t</a>\n\t\t\t\t\t\t\t\t\t</li>\n\t\t\t\t\t\t\t\t\t<li class=\"uk-parent nav_tab-sp-sub\">\n\t\t\t\t\t\t\t\t\t\t<a href=\"/recruit.html\">\n\t\t\t\t\t\t\t\t\t\t\t採用情報\n\t\t\t\t\t\t\t\t\t\t</a>\n\t\t\t\t\t\t\t\t\t\t<ul class=\"uk-nav-sub\">\n\t\t\t\t\t\t\t\t\t\t\t<li><a href=\"/recruit.html\">採用情報</a></li>\n\t\t\t\t\t\t\t\t\t\t\t<li><a href=\"/new-graduate/\">新卒募集要項</a></li>\n\t\t\t\t\t\t\t\t\t\t\t<li><a href=\"/mid-career/\">中途募集要項</a></li>\n\t\t\t\t\t\t\t\t\t\t</ul>\n\t\t\t\t\t\t\t\t\t</li>\n\t\t\t\t\t\t\t\t\t<li>\n\t\t\t\t\t\t\t\t\t\t<a href=\"/company-overview.html\">\n\t\t\t\t\t\t\t\t\t\t\t企業情報\n\t\t\t\t\t\t\t\t\t\t</a>\n\t\t\t\t\t\t\t\t\t</li>\n\t\t\t\t\t\t\t\t\t<li>\n\t\t\t\t\t\t\t\t\t\t<a href=\"/group-company.html\">\n\t\t\t\t\t\t\t\t\t\t関連会社\n\t\t\t\t\t\t\t\t\t\t</a>\n\t\t\t\t\t\t\t\t\t</li>\n\t\t\t\t\t\t\t\t\t<li>\n\t\t\t\t\t\t\t\t\t\t<a href=\"/news/\">\n\t\t\t\t\t\t\t\t\t\t\t新着情報\n\t\t\t\t\t\t\t\t\t\t</a>\n\t\t\t\t\t\t\t\t\t</li>\n\t\t\t\t\t\t\t\t\t<li>\n\t\t\t\t\t\t\t\t\t\t<a href=\"/contact.html\">\n\t\t\t\t\t\t\t\t\t\t\tお問い合わせ\n\t\t\t\t\t\t\t\t\t\t</a>\n\t\t\t\t\t\t\t\t\t</li>\n\t\t\t\t\t\t\t\t\t<li>\n\t\t\t\t\t\t\t\t\t\t<a href=\"/\">\n\t\t\t\t\t\t\t\t\t\t\tトップページ\n\t\t\t\t\t\t\t\t\t\t</a>\n\t\t\t\t\t\t\t\t\t</li>\n\t\t\t\t\t\t\t\t</ul>\n\t\t\t\t\t\t\t</nav>\n\t\t\t\t\t\t\t<!-- <div class=\"nav_tab-sp_bottom\">\n\t\t\t\t\t\t\t\t<a class=\"btn btn-bg-blue\" href=\"/\">\n\t\t\t\t\t\t\t\t\tトップページ\n\t\t\t\t\t\t\t\t</a>\n\t\t\t\t\t\t\t</div> -->\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t\t<!-- tab-sp menu -->\n\t\t\t</div>\n\t\t</div>\n\t</div>\n</header>    <!-- header -->\n    <main>\n        <!-- pagetitle -->\n        <section class=\"pagetitle\">\n            <div class=\"uk-container-expand uk-height-1-1 uk-flex uk-flex-middle uk-flex-right uk-text-right\">\n                <h2 class=\"pagetitle-box\">\n                    <div class=\"pagetitle-en\">Mid Career</div>\n                    <div class=\"pagetitle-jp\">中途採用情報</div>\n                </h2>\n            </div>\n            <ul class=\"uk-breadcrumb breadcrumb\">\n                <li><a href=\"/\">トップページ</a></li>\n                <li><a href=\"/recruit.html\">採用情報</a></li>\n                <li><span>中途採用情報</span></li>\n            </ul>\n        </section>\n        <!-- pagetitle -->\n        <section id=\"Guidelinesfield\" class=\"bg-white mainsubject\">\n            <div class=\"uk-grid-collapse uk-container-large uk-margin-auto uk-padding-large uk-padding-remove-bottom mainsubject-inner\"\n                uk-grid>\n                <div class=\"uk-width-1-4\">\n                    <h2 class=\"sectitle-area\">\n                        <div class=\"sectitle-en\">Guidelines</div>\n                        <div class=\"uk-margin-small-top sectitle-jp\">募集要項</div>\n                    </h2>\n                </div>\n                <div class=\"uk-width-3-4 uk-margin-auto-vertical cts-area\">\n                    \n<table id=\"tablepress-2\" class=\"tablepress tablepress-id-2 table-main tb-recruit guideline\">\n<tbody>\n<tr class=\"row-1\">\n\t<th class=\"column-1\">募集職種</th><td class=\"column-2\"><strong>■技術系総合職</strong><br />\n<small>（希望と適性に応じて各セクションへ配属します）</small><br />\n<hr><br />\n<b>【製品設計・開発】</b><br />\nばねや分岐器など当社製品の設計および開発を担います。お客様となるメーカーの要求を満たす製品を一から作り上げます。図面の作成には2D，3D CADを使用します。<br />\n<br />\n<b>【生産技術】</b><br />\n生産設備の設計や保全（メンテナンス）などを担います。スミハツの生産設備は既存品だけでなく、自社で設計・開発・設置をしたものも多く存在します。機械・機構・ロボットの設計に興味のある方お待ちしています。<br />\n<br />\n<b>【製造技術】</b><br />\n生産方法の管理や改善を担います。生産現場の意見を吸い上げ、時に協同して課題の解決に挑みます。熱処理や金属材料の知識を活かせる仕事です。<br />\n<br />\n<b>【品質管理】</b><br />\n製品の品質を維持・管理し、品質向上を担います。ばねも分岐器も「重要保安部品」といい、運行中の破損があった場合、人命にかかわる重要な製品です。品質不良の防止と対策を通じて、交通と産業の安心安全を守ります。<br />\n<br />\n<br />\n<strong>■事務系総合職</strong><br />\n<small>（希望と適性に応じて各セクションへ配属します）</small><br />\n<hr><br />\n<b>【生産管理】</b><br />\n工場にて製造工程の管理、原価管理、人員配置等を担います。製品の受注から納品まで、一連の流れをコントロールし、直接の売り上げにつなげる重要な仕事です。<br />\n<br />\n<b>【営業】</b><br />\nスミハツと取引のあるお客様先をまわり、営業活動をします。<br />\n<br />\n<b>【総務・人事】</b><br />\n会社の経営や工場の運営を支えるバックオフィス業務を担います。<br />\n<br />\n<b>【購買】</b><br />\n製品の製造に必要な資材・燃料の調達、価格交渉等を担います。<br />\n<br />\n<b>【経理】</b><br />\n経理知識を活かし、会社運営のサポート業務を担います。<br />\n<br />\n<b>【システム管理】</b><br />\n社内の情報インフラ（サーバー、PC端末、タブレット端末）の管理、生産管理システムの保守運営を担います。</td>\n</tr>\n<tr class=\"row-2\">\n\t<th class=\"column-1\">勤務地</th><td class=\"column-2\">本社・つくば事業所（茨城県桜川市高森1158）<br />\n営業本部（東京都千代田区神田相生町1番地 秋葉原センタープレイスビル4F）<br />\n大阪支店（大阪府大阪市淀川区宮原3-5-24）</td>\n</tr>\n<tr class=\"row-3\">\n\t<th class=\"column-1\">勤務時間</th><td class=\"column-2\">8：30〜17：15（実働8h）フレックスタイム制あり（コアタイムなし）<br />\n<small>※ノー残業Dayあり</small></td>\n</tr>\n<tr class=\"row-4\">\n\t<th class=\"column-1\">給与（基本給）</th><td class=\"column-2\">年収400万円〜　<small>※経験・能力を考慮のうえ決定</small></td>\n</tr>\n<tr class=\"row-5\">\n\t<th class=\"column-1\">各種手当</th><td class=\"column-2\">家族手当、住宅手当、残業手当、通勤手当、営業手当、役職手当</td>\n</tr>\n<tr class=\"row-6\">\n\t<th class=\"column-1\">昇給</th><td class=\"column-2\">年1回（4月）<small>※平均6千円</small></td>\n</tr>\n<tr class=\"row-7\">\n\t<th class=\"column-1\">賞与</th><td class=\"column-2\">年2回（7月・12月）<small>※平均6.0ヶ月</small></td>\n</tr>\n<tr class=\"row-8\">\n\t<th class=\"column-1\">休日・休暇</th><td class=\"column-2\">年間休日121日<br />\n完全週休2日制（土日休み）、GW休暇（9〜10日）、夏季休暇（9〜10日）、年末年始休暇（9〜10日）、有給休暇（4月入社時14日付与、最大20日　半日・時間単位使用可能）、リフレッシュ休暇、慶弔休暇</td>\n</tr>\n<tr class=\"row-9\">\n\t<th class=\"column-1\">保険</th><td class=\"column-2\">社会保険完備（健康保険、厚生年金保険、雇用保険、労災保険）、団体生命保険、団体損害保険</td>\n</tr>\n<tr class=\"row-10\">\n\t<th class=\"column-1\">福利厚生</th><td class=\"column-2\">退職金制度（確定拠出年金）、住宅資金融資、健康保険組合、資格取得支援制度、永年勤続表彰、人間ドック補助、コミュニケーション慰安費支給、住宅手当あり、社員食堂あり</td>\n</tr>\n<tr class=\"row-11\">\n\t<th class=\"column-1\">試用期間</th><td class=\"column-2\">あり（3ヶ月・同待遇）</td>\n</tr>\n<tr class=\"row-12\">\n\t<th class=\"column-1\">応募資格</th><td class=\"column-2\">40歳以下の方<br />\n<br />\n〈例外事由〉大学院・大学・高専で、電気・機械・土木を専攻していた方</td>\n</tr>\n</tbody>\n</table>\n<!-- #tablepress-2 from cache -->\n                                    </div>\n            </div>\n        </section>\n        <section id=\"Flowfield\" class=\"mainsubject bg-white\">\n            <div class=\"uk-grid-collapse uk-container-large uk-margin-auto ft-contact-inner uk-padding-large mainsubject-inner\"\n                uk-grid>\n                <div class=\"uk-width-1-4\">\n                    <h2 class=\"sectitle-area\">\n                        <div class=\"sectitle-en\">Flow\n                        </div>\n                        <div class=\"uk-margin-small-top sectitle-jp\">中途採用の流れ</div>\n                    </h2>\n                </div>\n                <div class=\"uk-width-3-4 uk-margin-auto-vertical cts-area\">\n                    <img class=\"uk-visible@s\" src=\"/resource/images/recruit-midcareer_flow.svg\" alt=\"1.お問い合わせよりエントリー 2.会社説明（書類提出）・適性検査、またはWeb説明会 3.人事面接（30分） 4.役員面接（30分） 5.内定\">\n                    <img class=\"uk-hidden@s\" src=\"/resource/images/recruit-midcareer_flow_sp.svg\" alt=\"1.お問い合わせよりエントリー 2.会社説明（書類提出）・適性検査、またはWeb説明会 3.人事面接（30分） 4.役員面接（30分） 5.内定\">\n                </div>\n            </div>\n        </section>\n        <section id=\"Entryfield\" class=\"mainsubject bg-stripe\">\n            <div class=\"uk-grid-collapse uk-container-large uk-margin-auto ft-contact-inner uk-padding-large mainsubject-inner\"\n                uk-grid>\n                <div class=\"uk-width-1-4\">\n                    <h2 class=\"sectitle-area\">\n                        <div class=\"sectitle-en\">Entry\n                        </div>\n                        <div class=\"uk-margin-small-top sectitle-jp\">エントリー</div>\n                    </h2>\n                </div>\n                <div class=\"uk-width-3-4 uk-margin-auto-vertical cts-area\">\n                    <div class=\"recruit-entry\">\n                        <p><a class=\"btn-recruit\" href=\"/contact.html\">お問い合わせフォームから応募する</a></p>\n                        <p>皆さまとの出会いを<br class=\"uk-hidden@s\">お待ちしています！</p>\n                    </div>\n                </div>\n            </div>\n        </section>\n    </main>\n    <!-- footer -->\n    <footer class=\"ft\">\n    <section class=\"ft-contact\">\n        <div class=\"uk-container uk-margin-auto ft-contact-inner\">\n            <div class=\"ctn-left\">\n                <h2 class=\"uk-padding-small sectitle-area txt-white\">\n                    <div class=\"sectitle-en\">Contact</div>\n                    <div class=\"sectitle-jp uk-margin-small-top\">お問い合わせ</div>\n                </h2>\n            </div>\n            <div class=\"ctn-right\">\n                <div class=\"cts-area\">\n                    <a class=\"ft-contact-btn\" href=\"/contact.html#Telephonefield\"><span class=\"contact-ico\" uk-icon=\"icon: receiver\"></span>電話でのお問い合わせ</a>\n                    <a class=\"ft-contact-btn\" href=\"/contact.html#Mailformfield\"><span class=\"contact-ico\" uk-icon=\"icon: mail\"></span>メールフォーム</a>\n                </div>\n            </div>\n        </div>\n    </section>\n    <!-- footer-nav-tabpc -->\n    <nav class=\"uk-visible@s uk-margin-large-top ft-nav-tabpc\">\n        <div class=\"uk-container uk-margin-auto\">\n            <ul class=\"uk-grid-large uk-child-width-1-3 uk-child-width-1-5@m uk-nav\" uk-grid>\n                <li><a href=\"/about.html\" class=\"first-directory\">スミハツについて</a></li>\n                <li>\n                    <ul>\n                        <li><a href=\"/products.html\" class=\"first-directory\">私たちの製品</a></li>\n                        <li><a href=\"/business-sleaf.html\" class=\"first-directory\">板ばね事業</a></li>\n                        <li><a href=\"/business-scoil.html\" class=\"first-directory\">巻ばね事業</a></li>\n                        <li><a href=\"/business-railway.html\" class=\"first-directory\">軌道事業</a></li>\n                    </ul>\n                </li>\n\n                <li>\n                    <ul>\n                        <li><a href=\"/company-overview.html\" class=\"first-directory\"><span>企