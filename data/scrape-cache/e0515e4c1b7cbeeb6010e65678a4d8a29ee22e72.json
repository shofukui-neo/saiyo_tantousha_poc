{"url":"https://suntaxi.com/recruit/inexperienced/index.html","html":"<!DOCTYPE html>\n<html xml:lang=\"ja\" lang=\"ja\">\n<head>\n<!-- Google tag (gtag.js) -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-8L99XZ0PR6\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'G-8L99XZ0PR6');\n</script>\n<meta charset=\"utf-8\">\n<title>未経験者 | サンタクシー【横浜】採用サイト</title>\n<meta name=\"description\" content=\"サンタクシー【横浜】のドライバー未経験者の方向けの採用情報をご紹介します。サンタクシーは自分のライフスタイルに合わせた働き方ができて、なおかつしっかりと稼ぐことができます。横浜でタクシー運転手をやろうと思っている方はぜひご覧下さい。\" />\n<meta name=\"keywords\" content=\"横浜,求人,未経験,採用,タクシー,ドライバー,運転手\" />\n<link rel=\"shortcut icon\" href=\"../images/common/favicon.ico\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1, maximum-scale=1\" />\n<link href=\"../style/base.css\" rel=\"stylesheet\" type=\"text/css\" media=\"all\" />\n<link href=\"../style/gheader.css\" rel=\"stylesheet\" type=\"text/css\" media=\"all\" />\n<link href=\"../style/common.css\" rel=\"stylesheet\" type=\"text/css\" media=\"all\" />\n<link href=\"../style/inexperienced.css\" rel=\"stylesheet\" type=\"text/css\" media=\"all\" />\n    \n<link href=\"https://use.fontawesome.com/releases/v5.5.0/css/all.css\" rel=\"stylesheet\">\n<script src=\"https://ajax.googleapis.com/ajax/libs/jquery/3.3.1/jquery.min.js\"></script>\n<script src=\"../js/common.js\"></script>\n<script src=\"../js/gnavfunc.js\"></script>\n<script src=\"../js/tpfunc.js\"></script>\n    \n</head>\n\n<body>\n    <div id=\"header\">\n        <div class=\"contaider\">\n            <div id=\"mobile-head\">\n                <div id=\"logo\"><a href=\"../index.html\" title=\"神奈川県横浜市のサンタクシー\"><img src=\"../images/common/logo.png\" alt=\"神奈川県横浜市のサンタクシー\" /><span>採用サイト</span></a></div>\n            </div>\n            <nav class=\"gNav\" role=\"navigation\" aria-label=\"メインメニュー\">\n            <p class=\"gnavbtn\"><a href=\"javascript:void(0)\"><span>メニューを開く</span></a></p>\n            <ul>\n                <li class=\"parent\"><a href=\"../index.html\" class=\"pcmenu\">ホーム</a><a href=\"javascript:void(0)\" class=\"spmenu\">ホーム</a>\n\t\t\t\t\t<!-- home -->\n\t\t\t\t\t<ul class=\"submenu\">\n\t\t\t\t\t\t<li><a href=\"../index.html\" class=\"spmenu\">トップページ</a></li>\n                        <li><a href=\"../privacy/index.html\">プライバシーポリシー</a></li>\n                    </ul>\n\t\t\t\t\t<!-- /home -->\n\t\t\t\t</li>\n                <li class=\"parent\"><a href=\"../about/index.html\" class=\"pcmenu\">会社紹介</a><a href=\"javascript:void(0)\" class=\"spmenu\">会社紹介</a>\n                    <!-- about -->\n                    <ul class=\"submenu\">\n\t\t\t\t\t\t<li><a href=\"../about/index.html\" class=\"spmenu\">会社紹介TOP</a></li>\n                        <li><a href=\"../about/appeal/index.html\">サンタクシーとは？</a></li>\n                        <li><a href=\"../about/fine/index.html\">サンタクシーの魅力</a></li>\n                        <li><a href=\"../about/voice/index.html\">現役社員の声</a></li>\n                    </ul>\n                    <!-- /about -->\n                </li>\n                <li class=\"parent\"><a href=\"../driver/index.html\" class=\"pcmenu\">働き方色々</a><a href=\"javascript:void(0)\" class=\"spmenu\">働き方色々</a>\n\t\t\t\t\t<ul class=\"submenu\">\n\t\t\t\t\t\t<li><a href=\"../driver/index.html\" class=\"spmenu\">働き方色々TOP</a></li>\n\t\t\t\t\t\t<li><a href=\"../experienced/index.html\">ドライバー経験者</a></li>\n\t\t\t\t\t\t<li><a href=\"../inexperienced/index.html\">未経験者</a></li>\n\t\t\t\t\t\t<li><a href=\"../woman/index.html\">女性ドライバー</a></li>\n\t\t\t\t\t\t<li><a href=\"../senior/index.html\">シニアドライバー</a></li>\n\t\t\t\t\t</ul>\n\t\t\t\t</li>\n                <li class=\"parent\"><a href=\"../require/index.html\">募集要項・よくある質問</a></li>\n                <li class=\"parent\"><a href=\"../entry/index.html\">エントリー</a></li>\n                <li class=\"parent\"><a href=\"../../index.html\">コーポレートサイト</a></li>\n            </ul>\n            <!-- /.Nav -->\n        </nav>\n\t\t\t<p id=\"headinsta\"><a href=\"https://www.instagram.com/yokohama_suntaxi/\" title=\"サンタクシーのインスタグラムへ\" target=\"_blank\"><img src=\"../images/common/logo_instagram.png\" alt=\"サンタクシーのインスタグラムへ\"/></a></p>\n        </div>\n      <!-- /#header-->\n    </div>\n    <div class=\"intro\">\n        <div class=\"container\">\n            <h1>未経験者</h1>\n        </div>\n        <!-- /#intro-->\n    </div>\n    <div id=\"panlist\">\n        <div class=\"container\">\n            <p id=\"pan\"><a href=\"../index.html\">ホーム</a><em>&gt;</em><a href=\"../driver/index.html\">働き方色々</a><em>&gt;</em>未経験者</p>\n        </div>\n        <!--  /#panlist-->\n    </div>\n    <div id=\"contents\">\n        <div class=\"area_01\">\n            <div class=\"container\">\n                <h2>サンタクシーのここが魅力</h2>\n                <ul class=\"apl_h3_list\">\n                    <li class=\"trnklnk\">\n                        <a href=\"#appeal01\">\n                            <p class=\"apl_h_img\"><img src=\"../images/inexperienced/img_apl_01.jpg\" class=\"imgMax\" alt=\"画像：二種免許取得費用全額会社負担\"/></p>\n                            <p class=\"apl_h_capt\">二種免許取得をサポート</p>\n                        </a>\n                    </li>\n                    <li class=\"trnklnk\">\n                        <a href=\"#appeal02\">\n                            <p class=\"apl_h_img\"><img src=\"../images/inexperienced/img_apl_02.jpg\" class=\"imgMax\" alt=\"画像：給与保証制度あり\"/></p>\n                            <p class=\"apl_h_capt\">入社祝い金・給与保証制度あり</p>\n                        </a>\n                    </li>\n                    <li class=\"trnklnk\">\n                        <a href=\"#appeal03\">\n                            <p class=\"apl_h_img\"><img src=\"../images/inexperienced/img_apl_03.jpg\" class=\"imgMax\" alt=\"画像：しっかり稼げる\"/></p>\n                            <p class=\"apl_h_capt\">1年目からしっかり稼げる</p>\n                        </a>\n                    </li>\n                </ul>\n            </div>\n        </div>\n        <div class=\"area_apl\" id=\"appeal01\">\n            <div class=\"container\">\n              <h2>二種免許取得をサポート</h2>\n                <p>タクシードライバーになるために必要な二種免許は全額当社負担で取得できます。<br>\n                さらに研修期間中は日当1万円を支給しますので安心して研修に専念できます。</p>\n              <p class=\"bmbspc\">研修では接遇・運転・地理を基礎から指導していきますので未経験者の方でもご安心ください！</p>\n              <div class=\"flow_box\">\n                  <h3>二種免許取得～ドライバーデビューまで</h3>\n                  <div class=\"step_box\">\n                      <div class=\"step_text\">\n                          <h4>自動車学校へ通学</h4>\n                          <p>原則として弊社指定の自動車学校に入校し、約2週間程度通学します。所定の学科や技能を受講し、最終的に技能検定を合格すると卒業です。</p>\n                          <p>自動車学校では、お客様をお乗せすることを想定して、安全運転に関する知識だけではなく、危険予測や適切な走行経路の設定など、質の高い運転技術を習得します。</p>\n                      </div>\n                      <div class=\"step_img\">\n                          <p><img src=\"../images/inexperienced/img_flow01.jpg\" class=\"imgMax\" alt=\"画像：自動車学校へ通学\"/></p>\n                      </div>\n                  </div>\n                  <p class=\"next_step\"><img src=\"../images/common/arrow_04.png\" class=\"imgMax\" alt=\"次のステップへ\"/></p>\n                  <div class=\"step_box\">\n                      <div class=\"step_text\">\n                          <h4>運転免許試験場で学科試験を受験</h4>\n                          <p>自動車学校を卒業後、現住所の最寄りの運転免許試験場で学科試験を受験し、合格すると普通二種免許の取得完了です。</p>\n                          <p>なお、サンタクシーでは、社有車を使用した路上演習による技能検定対策や模擬試験・添削指導といった学科試験対策を行い、全力でサポートしますので、ご安心ください。</p>\n                      </div>\n                      <div class=\"step_img\">\n                          <p><img src=\"../images/inexperienced/img_flow02.jpg\" class=\"imgMax\" alt=\"画像：運転免許試験場で学科試験を受験\"/></p>\n                      </div>\n                  </div>\n                  <p class=\"next_step\"><img src=\"../images/common/arrow_04.png\" class=\"imgMax\" alt=\"次のステップへ\"/></p>\n                  <div class=\"step_box\">\n                      <div class=\"step_text\">\n                          <h4>神奈川タクシーセンターよる乗務員登録講習を受講</h4>\n                          <p>神奈川タクシーセンターによる3日間の乗務員登録講習を受講します。受講終了後、乗務員としての登録を行い、タクシーを運行する時に常時携行が必要な乗務員証が発行されます。</p>\n                      </div>\n                      <div class=\"step_img\">\n                          <p><img src=\"../images/inexperienced/img_flow03.jpg\" class=\"imgMax\" alt=\"画像：神奈川タクシーセンターよる乗務員登録講習を受講\"/></p>\n                      </div>\n                  </div>\n                  <p class=\"next_step\"><img src=\"../images/common/arrow_04.png\" class=\"imgMax\" alt=\"次のステップへ\"/></p>\n                  <div class=\"step_box\">\n                      <div class=\"step_text\">\n                          <h4>営業所で社内ルールや運転マナーの座学</h4>\n                          <p>社内マニュアルを活用した座学により、服務規則やお客さま接遇などの基本的な知識を習得します。また、サービス業としてのおもてなしの精神を醸成するため、横浜の街の魅力を知る体験型のプログラムを取り入れています。</p>\n                      </div>\n                      <div class=\"step_img\">\n                          <p><img src=\"../images/inexperienced/img_flow04.jpg\" class=\"imgMax\" alt=\"画像：営業所で社内ルールや運転マナーの座学\"/></p>\n                      </div>\n                  </div>\n                  <p class=\"next_step\"><img src=\"../images/common/arrow_04.png\" class=\"imgMax\" alt=\"次のステップへ\"/></p>\n                  <div class=\"step_box\">\n                      <div class=\"step_text\">\n                          <h4>実地研修</h4>\n                          <p>最新の配車システムを活用した模擬配車によるお迎えや目的地までの走行演習を行います。演習後は、地図での確認・復習を繰り返し、横浜市内の地理、主要施設やお得意先を視覚的に覚えます。<br>\n                              また、走行演習時に、様々なシチュエーションを想定した対処訓練も行います。</p>\n                      </div>\n                      <div class=\"step_img\">\n                          <p><img src=\"../images/inexperienced/img_flow05.jpg\" class=\"imgMax\" alt=\"画像：実地研修\"/></p>\n                      </div>\n                  </div>\n                  <p class=\"next_step\"><img src=\"../images/common/arrow_04.png\" class=\"imgMax\" alt=\"次のステップへ\"/></p>\n                  <div class=\"step_box\">\n                      <div class=\"step_text\">\n                          <h4>ドライバーデビュー</h4>\n                          <p>社内研修で見極めを行った後、いよいよタクシードライバーとして公道でデビューします。<br>\n                              乗務開始後1ヶ月は毎週、その後2ヶ月は毎月、半年と個別目標を設定したうえで、その達成状況を確認・助言するフォロー面談を定期的に実施しています。</p>\n                      </div>\n                      <div class=\"step_img\">\n                          <p><img src=\"../images/inexperienced/img_flow06.jpg\" class=\"imgMax\" alt=\"画像：ドライバーデビュー\"/></p>\n                      </div>\n                  </div>\n                  <!-- /.flow_box -->\n                </div>\n                \n                \n            </div>\n            <!-- /.area_apl -->\n        </div>\n        <div class=\"area_apl\" id=\"appeal02\">\n            <div class=\"container\">\n                <h2>入社祝い金・給与保障制度あり</h2>\n                <div class=\"hos_box\">\n                    <div class=\"hos_text\">\n                        <p class=\"bmspc\">未経験の方へは、入社祝い金15万円を支給させていただきます（紹介会社経由の方は対象外になります）。<br>\n                          また入社後、12ヶ月間は月額30万円の給与保障制度があるので、手堅く稼ぎながら仕事を覚えることが可能です。<br>\n                            「慣れていないから稼げない」なんて心配はいりません。</p>\n                      <p>給与保障期間が終わっても、通常のタクシー業務の他、子育てタクシー、観光タクシー等、たくさんの仕事があるので継続して稼ぐことができます。<br>\n                          中には、1年目から年間600万円近く稼ぐドライバーもいるほどです。</p>\n                    </div>\n                    <div class=\"hos_img\">\n                        <p><img src=\"../images/inexperienced/img_hos01.jpg\" class=\"imgMax\" alt=\"画像：給与保証\"/></p>\n                    </div>\n                </div>\n            </div>\n            <!-- /.area_apl -->\n        </div>\n        <div class=\"area_apl\" id=\"appeal03\">\n            <div class=\"container\">\n                <h2>1年目からしっかり稼げる</h2>\n                <p class=\"bmbspc\">サンタクシーでは観光タクシーや子育てタクシー等、多くの配車依頼があり、1年目からしっかりと稼ぐことができます。<br>\n                  62%という高歩率も魅力です。\n                </p>\n                <div class=\"kinkei_box\">\n                    <h3>未経験者 入社後の給与<sup>(※)</sup></h3>\n\t\t\t\t\t<p class=\"sm_words_m pCsL\">（＊）2019年実績</p>\n                    <ul class=\"sala_list\">\n                        <li>\n                            <div class=\"sala_face\">\n                                <p><img src=\"../images/inexperienced/img_emp01.png\" class=\"imgMax\" alt=\"画像：未経験者1\"/></p>\n                            </div>\n                            <div class=\"sala_text\">\n\t\t\t\t\t\t\t\t<p class=\"sala_nenrei\">入社2年　47歳</p>\n                                <p>昼勤務</p>\n\t\t\t\t\t\t\t\t<p>前職：輸入業</p>\n                                <p class=\"sala_nensyu\">年収<span class=\"fonWarn\"><span>410</span>万円</span></p>\n                                \n                            </div>\n                        </li>\n                        <li>\n                            <div class=\"sala_face\">\n                                <p><img src=\"../images/inexperienced/img_emp02.png\" class=\"imgMax\" alt=\"画像：未経験者2\"/></p>\n                            </div>\n                            <div class=\"sala_text\">\n\t\t\t\t\t\t\t\t<p>入社3年　39歳</p>\n                                <p>夜日勤</p>\n\t\t\t\t\t\t\t\t<p>前職：廃棄物リサイクル業</p>\n\t\t\t\t\t\t\t\t<p class=\"sala_nensyu\">年収<span class=\"fonWarn\"><span>580</span>万円</span></p>\n                            </div>\n                        </li>\n\t\t\t\t\t\t<li>\n                            <div class=\"sala_face\">\n                                <p><img src=\"../images/inexperienced/img_emp03.png\" class=\"imgMax\" alt=\"画像：未経験者3\"/></p>\n                            </div>\n                            <div class=\"sala_text\">\n\t\t\t\t\t\t\t\t<p>入社2年　67歳</p>\n                                <p>隔日勤務　<br class=\"br-sp\">子育てタクシーも担当</p>\n\t\t\t\t\t\t\t\t<p>前職：自営業・花屋</p>\n\t\t\t\t\t\t\t\t<p class=\"sala_nensyu\">年収<span class=\"fonWarn\"><span>333</span>万円</span></p>\n                            </div>\n                