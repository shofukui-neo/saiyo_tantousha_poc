{"url":"https://www.ktec-akashi.co.jp/recruit/company/top_message.html","html":"<!DOCTYPE html>\r\n<html lang=\"ja\">\r\n\r\n<head prefix=\"og: https://ogp.me/ns#\">\r\n    <meta charset=\"UTF-8\">\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n    <meta name=\"description\" content=\"カワサキモータースの関連会社、ケイテックの公式サイトです。川崎重工グループを中心に事業展開するデジタル・ソリューション・カンパニーです。\">\r\n\r\n    <title>RECRUIT | K-TEC 株式会社ケイテック</title>\r\n\r\n    <!-- ファビコン -->\r\n    <link rel=\"icon\" type=\"image/x-icon\" href=\"/recruit/assets/img/index/favicon.png\">\r\n    <link rel=\"apple-touch-icon\" href=\"/recruit/assets/img/index/icon.png\">\r\n\r\n    <!-- ogp -->\r\n    <meta property=\"og:locale\" content=\"ja_JP\">\r\n    <meta property=\"og:site_name\" content=\"RECRUIT | K-TEC 株式会社ケイテック\">\r\n    <meta property=\"og:url\" content=\"https://www.ktec-akashi.co.jp/recruit/\">\r\n    <meta property=\"og:type\" content=\"website\">\r\n    <meta property=\"og:title\" content=\"RECRUIT | K-TEC 株式会社ケイテック\">\r\n    <meta property=\"og:description\" content=\"カワサキモータースの関連会社、ケイテックの採用サイトです。川崎重工グループを中心に事業展開するデジタル・ソリューション・カンパニーです。\">\r\n    <meta property=\"og:image\" content=\"https://www.ktec-akashi.co.jp/recruit/assets/img/ogp-100.jpg\">\r\n\r\n    <!-- font -->\r\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\r\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\r\n    <link\r\n        href=\"https://fonts.googleapis.com/css2?family=Josefin+Sans:ital,wght@0,100..700;1,100..700&family=Noto+Sans+JP:wght@100..900&family=Noto+Sans:ital,wght@0,100..900;1,100..900&family=Roboto:ital,wght@0,100..900;1,100..900&display=swap\"\r\n        rel=\"stylesheet\">\r\n\r\n    <!-- css -->\r\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"../../assets/css/reset.css\">\r\n\r\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"../assets/css/slick.css\">\r\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"../assets/css/slick-theme.css\">\r\n\r\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"../assets/css/recruit.css\">\r\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"../assets/css/topmessage.css\">\r\n\r\n    <!-- Google tag (gtag.js) -->\r\n    <script async src=\"https://www.googletagmanager.com/gtag/js?id=G-XHJS5KLZ2J\"></script>\r\n    <script>\r\n        window.dataLayer = window.dataLayer || [];\r\n        function gtag() { dataLayer.push(arguments); }\r\n        gtag('js', new Date());\r\n\r\n        gtag('config', 'G-XHJS5KLZ2J');\r\n    </script>\r\n\r\n</head>\r\n\r\n<body>\r\n\r\n    <!-- 共通のヘッダーを使用 -->\r\n    <div id=\"recruit_header\"></div>\r\n\r\n    <main>\r\n        <!-- section01 メインイメージ -->\r\n        <section class=\"topmessage_sec01\">\r\n            <div class=\"topmessage_sec01_inn\">\r\n                <article class=\"topmessage_top_ttl\">\r\n                    <p class=\"fs16 fc-purple\">トップメッセージ</p>\r\n                    <img src=\"../assets/img/topmessage/topmessage_top_ttl.png\" alt=\"TOP MESSAGE\">\r\n                    <!-- パンくずリスト -->\r\n                    <nav aria-label=\"Breadcrumb\" class=\"recruit_breadcrumb\">\r\n                        <ul>\r\n                            <li><a href=\"/recruit/index.html\">TOP</a></li>\r\n                            <li><span aria-current=\"page\">トップメッセージ</span></li>\r\n                        </ul>\r\n                    </nav>\r\n                </article>\r\n                <article class=\"topmessage_top_txt\">\r\n                    <div class=\"topmessage_top_txt_message\">\r\n                        <p class=\"fs18 topmessage_top_txt_message01\">このページを見られているということは、<br class=\"pc-only\">\r\n                            当社に関心を持っていただいているということで、<br class=\"pc-only\">\r\n                            社長として非常に嬉しく思います。<br>\r\n                            ありがとうございます！\r\n                        </p>\r\n                        <p class=\"fs18 topmessage_top_txt_message02\">私たちケイテックは、<br>\r\n                            以下の価値観（経営理念）を持った会社です。<br>\r\n                            これを機に、より関心を深めていただけると幸いです。\r\n                        </p>\r\n                    </div>\r\n                    <div class=\"topmessage_top_txt_name\">\r\n                        <p class=\"fs20\">代表取締役社長</p>\r\n                        <p class=\"fs36\">北野 正巳</p>\r\n                    </div>\r\n                </article>\r\n                <article class=\"topmessage_top_photo pc-only\">\r\n                    <img src=\"../assets/img/topmessage/topmessage_main_img_pc.png\">\r\n                </article>\r\n                <article class=\"topmessage_top_ink pc-only\">\r\n                    <img src=\"../assets/img/topmessage/topmessage_top_ink02.png\">\r\n                </article>\r\n            </div>\r\n            <article class=\"topmessage_top_photo sp-only\">\r\n                <img src=\"../assets/img/topmessage/topmessage_main_img_sp.png\">\r\n            </article>\r\n        </section>\r\n        <section class=\"topmessage_sec02\">\r\n            <div class=\"topmessage_link_btn_box fadeUpTrigger\">\r\n                <div class=\"topmessage_link_btn topmessage_link_btn01\">\r\n                    <a href=\"#topmessage_box01\">\r\n                        <div class=\"topmessage_link_btn_no\">\r\n                            <p class=\"josefin-sans fc-red fs70_2\">01</p>\r\n                        </div>\r\n                        <div class=\"topmessage_link_btn_txt\">\r\n                            <p class=\"bg-red fc-white fs25\">顧客志向に徹し、<br>\r\n                                顧客の信頼を得る</p>\r\n                        </div>\r\n                    </a>\r\n                </div>\r\n                <div class=\"topmessage_link_btn topmessage_link_btn02\">\r\n                    <a href=\"#topmessage_box02\">\r\n                        <div class=\"topmessage_link_btn_no\">\r\n                            <p class=\"josefin-sans fc-green fs70_2\">02</p>\r\n                        </div>\r\n                        <div class=\"topmessage_link_btn_txt\">\r\n                            <p class=\"bg-green fc-white fs25\">情熱、独創性、<br>\r\n                                チャレンジ精神を持つ</p>\r\n                        </div>\r\n                    </a>\r\n                </div>\r\n                <div class=\"topmessage_link_btn topmessage_link_btn03\">\r\n                    <a href=\"#topmessage_box03\">\r\n                        <div class=\"topmessage_link_btn_no\">\r\n                            <p class=\"josefin-sans fc-lblue fs70_2\">03</p>\r\n                        </div>\r\n                        <div class=\"topmessage_link_btn_txt\">\r\n                            <p class=\"bg-lblue fc-white fs25\">個性を尊重し、<br>\r\n                                感動を共有する</p>\r\n                        </div>\r\n                    </a>\r\n                </div>\r\n                <div class=\"topmessage_link_btn topmessage_link_btn04\">\r\n                    <a href=\"#topmessage_box04\">\r\n                        <div class=\"topmessage_link_btn_no\">\r\n                            <p class=\"josefin-sans fc-yellow fs70_2\">04</p>\r\n                        </div>\r\n                        <div class=\"topmessage_link_btn_txt\">\r\n                            <p class=\"bg-yellow fc-white fs25\">グローバル思考で、<br>\r\n                                変化に即応し得る</p>\r\n                        </div>\r\n                    </a>\r\n                </div>\r\n            </div>\r\n            <div class=\"topmessage_link_btn_arrow fadeUpTrigger\">\r\n                <img src=\"../assets/img/topmessage/topmessage_sec02_arrow.png\">\r\n            </div>\r\n            <div id=\"topmessage_box01\" class=\"anchor\">\r\n                <article class=\"topmessage_box topmessage_box01 fadeUpTrigger\">\r\n                    <div class=\"topmessage_box_txt\">\r\n                        <div class=\"topmessage_box_txt_no\">\r\n                            <p class=\"josefin-sans fc-red fs70_2\">01</p>\r\n                        </div>\r\n                        <div class=\"topmessage_box_txt_ttl\">\r\n                            <p class=\"bg-red fc-white fs50\">顧客志向</p>\r\n                        </div>\r\n                        <div class=\"topmessage_box_txt_inn\">\r\n                            <p class=\"fd-dblue fs16\">\r\n                                私たちは、ユニークな芸術家思考をもったデジタル・ソリューションの技術者集団ですが、独善的であってはならないと考えています。独善的に働くことで自己満足は得られるかもしれませんが、その働きが必ずしも周りに評価されるとは限りません。私たちは、自分の思いは大切にしつつ、顧客に寄り添って考えます。まさにWin-Winの関係を模索しながら働いています。\r\n                            </p>\r\n                        </div>\r\n                    </div>\r\n                    <div class=\"topmessage_box_img pc-only\">\r\n                        <img src=\"../assets/img/topmessage/topmessage01_img.png\">\r\n                    </div>\r\n                    <div class=\"topmessage_box_img sp-only\">\r\n                        <img src=\"../assets/img/topmessage/topmessage01_img_sp.png\">\r\n                    </div>\r\n                </article>\r\n            </div>\r\n            <div id=\"topmessage_box02\" class=\"anchor\">\r\n                <article class=\"topmessage_box topmessage_box02 fadeUpTrigger\">\r\n                    <div class=\"topmessage_box_txt\">\r\n                        <div class=\"topmessage_box_txt_no\">\r\n                            <p class=\"josefin-sans fc-green fs70_2\">02</p>\r\n                        </div>\r\n                        <div class=\"topmessage_box_txt_ttl\">\r\n                            <p class=\"bg-green fc-white fs50\">チャレンジ精神</p>\r\n                        </div>\r\n                        <div class=\"topmessage_box_txt_inn\">\r\n                            <p class=\"fd-dblue fs16\">\r\n                                私たちは、チャレンジ精神を持ってビジネスに変革をもたらします。受け身な気持ちでは何も変わりません。一歩踏み出すのは勇気がいるものです、熱意を持って主体的に動き、1mmでも前に進むよう心がけています。その1mmが積み重なって、最終的には偉大な成果につながると信じています。\r\n                            </p>\r\n                        </div>\r\n                    </div>\r\n                    <div class=\"topmessage_box_img pc-only\">\r\n                        <img src=\"../assets/img/topmessage/topmessage02_img.png\">\r\n                    </div>\r\n                    <div class=\"topmessage_box_img sp-only\">\r\n                        <img src=\"../assets/img/topmessage/topmessage02_img_sp.png\">\r\n                    </div>\r\n                </article>\r\n            </div>\r\n            <div id=\"topmessage_box03\" class=\"anchor\">\r\n                <article class=\"topmessage_box topmessage_box03 fadeUpTrigger\">\r\n                    <div class=\"topmessage_box_txt\">\r\n                        <div class=\"topmessage_box_txt_no\">\r\n                            <p class=\"josefin-sans fc-lblue fs70_2\">03</p>\r\n                        </div>\r\n                        <div class=\"topmessage_box_txt_ttl\">\r\n                            <p class=\"bg-lblue fc-white fs50\">感動の共有</p>\r\n                        </div>\r\n                        <div class=\"topmessage_box_txt_inn\">\r\n                            <p class=\"fd-dblue fs16\">\r\n                                会社で働く価値って考えたことあるでしょうか。一人で出来ることって意外と多くありません。一人で出来ることには限界があるのです。仲間と協力しながら一つのことをやり遂げることで、苦しいことも乗り越えられますし、喜びも多くなるのだと思います。ワクワク働き、その結果感動を共有できる、そんな素晴らしい場を提供します。\r\n                            </p>\r\n                        </div>\r\n                    </div>\r\n                    <div class=\"topmessage_box_img pc-only\">\r\n                        <img src=\"../assets/img/topmessage/topmessage03_img.png\">\r\n                    </div>\r\n                    <div class=\"topmessage_box_img sp-only\">\r\n                        <img src=\"../assets/img/topmessage/topmessage03_img_sp.png\">\r\n                    </div>\r\n                </article>\r\n            </div>\r\n            <div id=\"topmessage_box04\" class=\"anchor\">\r\n                <article class=\"topmessage_box topmessage_box04 fadeUpTrigger\">\r\n                    <div class=\"topmessage_box_txt\">\r\n                        <div class=\"topmessage_box_txt_no\">\r\n                            <p class=\"josefin-sans fc-yellow fs70_2\">04</p>\r\n                        </div>\r\n                        <div class=\"topmessage_box_txt_ttl\">\r\n                            <p class=\"bg-yellow fc-white fs50\">グローバル思考</p>\r\n                        </div>\r\n                        <div class=\"topmessage_box_txt_inn\">\r\n                            <p class=\"fd-dblue fs16\">\r\n                                “グローバル思考”って難しいですよね。何ができたらグローバル思考なのか…。私たちは、日本的な常識にとらわれず、視野を広く物事を考えることとしてとらえています。視野が狭いと、いろいろ行き詰ってしまいますよね。そんなとき別の視点があって気づきが得られたりすると、一気に突破できたりします。そのためには、他の価値観を毛嫌いせず受け入れる。こころの垣根を下げてコミュニケーションできるそんな技術者集団を目指しています。\r\n                            </p>\r\n                        </div>\r\n                    </div>\r\n                    <div class=\"topmessage_box_img pc-only\">\r\n                        <img src=\"../assets/img/topmessage/topmessage04_img.png\">\r\n                    </div>\r\n                    <div class=\"topmessage_box_img sp-only\">\r\n                        <img src=\"../assets/img/topmessage/topmessage04_img_sp.png\">\r\n                    </div>\r\n                </article>\r\n            </div>\r\n        </section>\r\n        <section class=\"topmessage_sec03 fadeUpTrigger\">\r\n            <div class=\"philosophy_ink01 pc-only\">\r\n                <img src=\"../assets/img/topmessage/philosophy_back_img01.png\">\r\n            </div>\r\n            <div class=\"philosophy_ink02 pc-only\">\r\n                <img src=\"../assets/img/topmessage/philosophy_back_img02.png\">\r\n            </div>\r\n            <div class=\"topmessage_philosophy_box\">\r\n                <div class=\"topmessage_philosophy_box_img pc-only\">\r\n                    <img src=\"../assets/img/topmessage/philosophy_photo_img.png\">\r\n                </div>\r\n                <div class=\"topmessage_philosophy_box_img sp-only\">\r\n                    <img src=\"../assets/img/topmessage/philosophy_photo_img_sp.png\">\r\n                </div>\r\n                <div class=\"topmessage_philosophy_box_txt\">\r\n                    <div class=\"topmessage_philosophy_box_txt_ttl\">\r\n                        <img src=\"../assets/img/topmessage/philosophy_txt_img.png\">\r\n                    </div>\r\n                    <div class=\"topmessage_philosophy_box_txt_inn\">\r\n                        <p class=\"fc-white fs18\">私たちケイテックの社是は、<br>\r\n                            <span class=\"bg-purple\">『夢と革新　愛と歓び』</span> です。<br>\r\n                            夢だけでなく“革新”、愛だけでなく“歓び”、<br class=\"sp-only\">\r\n                            やさしさと強さを併せ持った社風の会社です。<br>\r\n                            こんな価値観に共感していただける皆さんと<br class=\"sp-only\">\r\n                            一緒に仕事できることを楽しみにしています！\r\n                        </p>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n        </section>\r\n\r\n        <!-- <section class=\"topmessage_sec04\">\r\n            <a href=\"/company/index.html\">\r\n                <div class=\"topmessage_sec04_inn\">\r\n                    <p class=\"recruit_sec_subttl fs16 fc-yellow josefin-sans\">Contact</p>\r\n                    <p class=\"recruit_sec_ttl fs70 fc-white\">お問い合わせ</p>\r\n                    <p class=\"recruit_sec_txt fs16 fc-white\">ケイテックに興味をもった方は、こちらからお気軽にお問い合わせください。\r\n                    </p>\r\n                    <div class=\"recruit_sec_inn_btn\">\r\n                        <svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 72.5 72.5\" fill=\"none\">\r\n                            <defs>\r\n                                <style>\r\n                                    .cls-3 {\r\n                                        fill: none;\r\n                                        stroke-miterlimit: 10;\r\n                                    }\r\n\r\n                                    .cls-3,\r\n                                    .cls-4 {\r\n                                        stroke: #fff;\r\n                                        stroke-width: 1.5px;\r\n                                    }\r\n\r\n                                    .cls-4 {\r\n                                        fill: none;\r\n                                        stroke-linecap: round;\r\n                                        stroke-linejoin: round;\r\n                                    }\r\n                                </style>\r\n                            </defs>\r\n                            <g id=\"data\">\r\n                                <g>\r\n                                    <circle class=\"cls-3\" cx=\"35.75\" cy=\"35.75\" r=\"35\" />\r\n                                    <polyline class=\"cls-4\" points=\"33.24 43.98 41.13 35.75 33.24 27.52\" />\r\n                                </g>\r\n                            </g>\r\n                        </svg>\r\n                    </div>\r\n                </div>\r\n            </a>\r\n        </section> -->\r\n        <section class=\"topmessage_sec05\">\r\n            <a href=\"../company/index.html\">\r\n                <div class=\"topmessage_sec05_inn\">\r\n                    <p class=\"recruit_sec_subttl fs16 fc-purple josefin-sans\">K-TEC by the Numbers</p>\r\n                    <p class=\"recruit_sec_ttl fs70 fc-dblue\">データでみるケイテック</p>\r\n                    <p class=\"recruit_sec_txt fs16 fc-dblue\">社員の就業状況からライフワークバランスまで、<br class=\"pc-only\">\r\n                        「ケイテックで働く」を、数字でわかりやすくご紹介します。\r\n                    </p>\r\n                    <div class=\"recruit_sec_inn_btn\">\r\n                        <svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 72.5 72.5\">\r\n                            <defs>\r\n                                <style>\r\n                                    .cls-1 {\r\n                                        fill: none;\r\n                                        stroke-linecap: round;\r\n                                        stroke-linejoin: round;\r\n                                    }\r\n\r\n                                    .cls-1,\r\n                                    .cls-2 {\r\n                                        stroke: #262e40;\r\n                                        stroke-width: 1.5px;\r\n                                    }\r\n\r\n                                    .cls-2 {\r\n                                        fill: #fff;\r\n                                        stroke-miterlimit: 10;\r\n                                    }\r\n                                </style>\r\n                            </defs>\r\n                            <g id=\"data\">\r\n                                <g>\r\n                                    <circle class=\"cls-2\" cx=\"35.75\" cy=\"35.75\" r=\"35\" />\r\n                                    <polyline class=\"cls-1\" points=\"33.24 43.98 41.13 35.75 33.24 27.52\" />\r\n                                </g>\r\n                            </g>\r\n                        </svg>\r\n                    </div>\r\n                </div>\r\n            </a>\r\n        </section>\r\n    </main>\r\n\r\n    <!-- 共通のフッターを使用 -->\r\n    <div id=\"recruit_footer\"></div>\r\n\r\n    <!-- js -->\r\n    <script src=\"https://code.jquery.com/jquery-3.7.1.min.js\"\r\n        integrity=\"sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo=\" crossorigin=\"anonymous\"></script>\r\n    <script src=\"../assets/js/slick.min.js\"></script>\r\n    <script src=\"../assets/js/recruit.js\"></script>\r\n\r\n    <!-- 共通のヘッダーフッターを使用 -->\r\n    <script>\r\n        $(function () {\r\n            $(\"#recruit_header\").load(\"../include/recruit_header.html\");\r\n            $(\"#recruit_footer\").load(\"../include/recruit_footer.html\");\r\n        });\r\n    </script>\r\n\r\n</body>\r\n\r\n</html>","finalUrl":"https://www.ktec-akashi.co.jp/recruit/company/top_message.html",