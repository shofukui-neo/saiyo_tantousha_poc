{"url":"https://www.tbts.co.jp/members/wp-login.php?action=lostpassword","html":"<!DOCTYPE html>\n\t<html lang=\"ja\">\n\t<head>\n\t<meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\" />\n\t<title>パスワード紛失 &lsaquo; サポートサイト | 東京貿易テクノシステム &#8212; WordPress</title>\n\t  <style type=\"text/css\">\n    body {\n      background: linear-gradient(to left, #263a9f, #1d81f9)!important;\n      color: #fff;\n    }\n\n    .login h1 a {\n      margin-bottom: 64px!important;\n      width: 100px!important;\n      height: 70px!important;\n      background-image: url(./wp-content/themes/members/assets/images/login/logo_login.svg)!important;\n      background-size: 100px 70px!important;\n    }\n\n\n    .footer {\n      position: fixed;\n      bottom: 20px;\n      left: 50%;\n      transform: translateX(-50%);\n    }\n\n    #login {\n      position: relative;\n    }\n\n    .login #backtoblog a, .login #nav a {\n      color: #fff!important;\n    }\n\n    #backtoblog {\n      display: none;\n    }\n\n    .footer__copy {\n      color: #fff;\n    }\n\n    .footer__list {\n      display: flex;\n      justify-content: center;\n      margin-bottom: 16px;\n    }\n\n    .footer__item {\n      list-style-type: none;\n    }\n\n    .footer__item + .footer__item {\n      margin-left: 20px;\n    }\n\n    .footer__link {\n      color: #fff;\n      text-decoration: none;\n    }\n\n    .footer__link:hover{\n      text-decoration: underline;\n    }\n\n    .footer__link:hover{\n      text-decoration: underline;\n    }\n  </style>\n<meta name='robots' content='max-image-preview:large, noindex, noarchive' />\n<link rel='stylesheet' id='dashicons-css' href='https://www.tbts.co.jp/members/wp-includes/css/dashicons.min.css?ver=6.8.1' type='text/css' media='all' />\n<link rel='stylesheet' id='buttons-css' href='https://www.tbts.co.jp/members/wp-includes/css/buttons.min.css?ver=6.8.1' type='text/css' media='all' />\n<link rel='stylesheet' id='forms-css' href='https://www.tbts.co.jp/members/wp-