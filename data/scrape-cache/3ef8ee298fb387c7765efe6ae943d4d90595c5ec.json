{"url":"https://www.shinnihon-c.co.jp/recruit/qa.php","html":"<!DOCTYPE html>\r\n<html lang=\"ja\">\r\n<head>\r\n    <script>\r\n        (function(w, d, s, l, i) {\r\n            w[l] = w[l] || [];\r\n            w[l].push({\r\n                'gtm.start': new Date().getTime(),\r\n                event: 'gtm.js'\r\n            });\r\n            var f = d.getElementsByTagName(s)[0],\r\n                j = d.createElement(s),\r\n                dl = l != 'dataLayer' ? '&l=' + l : '';\r\n            j.async = true;\r\n            j.src =\r\n                'https://www.googletagmanager.com/gtm.js?id=' + i + dl;\r\n            f.parentNode.insertBefore(j, f);\r\n        })(window, document, 'script', 'dataLayer', 'GTM-P4FJ3WL');\r\n    </script>\r\n    <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\" />\r\n    <meta name=\"viewport\" content=\"width=device-width\">\r\n    <meta http-equiv=\"Content-Type\" content=\"text/html; charset=utf-8\">\r\n    <meta http-equiv=\"Content-Style-Type\" content=\"text/css\">\r\n    <meta http-equiv=\"Content-Script-Type\" content=\"text/javascript\">\r\n    <meta name=\"robots\" content=\"index,follow\">\r\n    <title>Q&amp;A｜新日本建設株式会社 採用サイト</title>\r\n    <meta name=\"Description\" content=\"Q&amp;A｜新日本建設株式会社 採用サイト\" />\r\n    <meta name=\"Keywords\" content=\"新日本建設株式会社,採用,新卒採用,中途採用,ゼネコン,建設事業,建築,開発,PC工法,土地の有効利用,分譲マンション,新日本建設\" />\r\n    <link rel=\"shortcut icon\" href=\"../../favicon.ico\" />\r\n    <link rel=\"stylesheet\" rev=\"stylesheet\" href=\"./css/common.css?ver=0117\" type=\"text/css\" media=\"screen,print\" />\r\n    <link rel=\"stylesheet\" rev=\"stylesheet\" href=\"./css/pc.css?ver=0221\" type=\"text/css\" media=\"screen,print\" />\r\n    <link rel=\"stylesheet\" rev=\"stylesheet\" href=\"./css/tab.css?ver=0217\" type=\"text/css\" media=\"screen and (max-width: 1100px)\" />\r\n    <link rel=\"stylesheet\" rev=\"stylesheet\" href=\"./css/sp.css?ver=0217\" type=\"text/css\" media=\"screen and (max-width: 767px)\" />\r\n    <link href=\"https://fonts.googleapis.com/icon?family=Material+Icons\" rel=\"stylesheet\">\r\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\">\r\n    <link href=\"https://fonts.googleapis.com/css2?family=Noto+Serif:ital,wght@0,400;0,700;1,400;1,700&display=swap\" rel=\"stylesheet\">\r\n    <link href=\"https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@200;300;400;500;600;700;900&display=swap\" rel=\"stylesheet\">\r\n    <script type=\"text/javascript\" src=\"https://code.jquery.com/jquery-2.2.3.min.js\"></script>\r\n    <script src=\"https://cdnjs.cloudflare.com/ajax/libs/moment.js/2.8.2/moment.min.js\"></script>\r\n    <script src=\"./js/cont.js?ver=0117\" type=\"text/javascript\"></script>\r\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"./lightbox/lightbox.min.css\">\r\n</head></head>\r\n<body class=\"qa\">\r\n    <!-- Google Tag Manager (noscript) 20210406reci-->\r\n    <noscript>\r\n        <iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-P4FJ3WL\" height=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe>\r\n    </noscript>\r\n    <!-- End Google Tag Manager (noscript) --><div class=\"conw\">\r\n    <header class=\"hdPc\">\n    <div class=\"logo\"> \n        <a href=\"./\" class=\"eng\">\n            <img src=\"../common/img/common/logo.jpg\" alt=\"新日本建設株式会社\" /><br>\n            RECRUITING SITE\n        </a> \n    </div>\n    <div class=\"hd cf\">\n        <ul class=\"hdnav cf\">\n            <li class=\"ttl\">\n                募集要項<br>エントリー\n            </li>\n            <li class=\"btnEntry\">\n                <a href=\"https://job.axol.jp/bx/s/shinnihon-c_27/entry/\" target=\"_blank\">\n                    新卒採用（2027卒）<br>エントリーはこちら\n                </a>\n            </li>\n            <li class=\"btnEntry\">\n                <a href=\"https://axol.jp/zw/s/shinnihon-c_28/entry/\" target=\"_blank\">\n                    新卒採用（2028卒）<br>インターンシップは<br>こちら\n                </a>\n            </li>\n            <!-- <li class=\"btnMynavi\">\n                <a href=\"https://job.mynavi.jp/26/pc/search/corp54735/outline.html\" target=\"_blank\">\n                <img src=\"https://job.mynavi.jp/conts/kigyo/2026/logo/banner_logo_195_60.gif\" alt=\"マイナビ2026\" border=\"0\">\n                </a>\n            </li> --> \n            <li class=\"btnCareer\">\n                <a href=\"./career.php\">\n                    キャリア採用\n                </a>\n            </li>               \n        </ul>\n        <nav>\n            <ul class=\"gn cf\">\r\n    <li class=\"\">\r\n        <a href=\"./about.php\">\r\n            会社を知る\r\n        </a>\r\n    </li> \r\n    <li class=\"\">\r\n        <a href=\"./work.php\">\r\n            仕事を知る\r\n        </a>\r\n    </li>\r\n    <li class=\"\">\r\n        <a href=\"./staff.php\">\r\n            社員を知る\r\n        </a>\r\n    </li>\r\n    <li class=\"on\">\r\n        <a href=\"./qa.php\">\r\n            Q&A\r\n        </a>\r\n    </li>\r\n</ul>        </nav>\n    </div>\n</header>\n\n<header class=\"hdSp\">\n    <div class=\"logo cf\"> \n        <a href=\"./\" class=\"eng\">\n            <img src=\"../common/img/common/logo.jpg\" alt=\"新日本建設株式会社\" />\n            RECRUITING SITE\n        </a> \n    </div>\n    <div class=\"btnMenu\"> \n        <span></span> \n        <span></span> \n        <span></span> \n    </div>\n    <nav class=\"navCommon\">\n        <!--<p class=\"\">\n    <a href=\"./\">トップページ</a>\n</p>-->\n<div class=\"btn_entry\">\n    <a href=\"https://job.axol.jp/bx/s/shinnihon-c_27/entry/\" target=\"_blank\">\n        新卒採用（2027卒）<br>エントリーはこちら\n    </a>\n    <a href=\"https://axol.jp/zw/s/shinnihon-c_28/entry/\" target=\"_blank\">\n        新卒採用（2028卒）<br>インターンシップはこちら\n    </a>\n    <a href=\"https://job.mynavi.jp/27/pc/search/corp54735/outline.html\" class=\"bnr\" target=\"_blank\">\n    <img src=\"https://job.mynavi.jp/conts/kigyo/2027/logo/banner_logo_195_60.gif?\" alt=\"マイナビ2027\" border=\"0\">\n    </a>\n\t<a href=\"./career.php\">キャリア採用</a>\n</div>\n<ul class=\"cf\">\n    <li class=\"\">\n        <dl>\n            <dt class=\"\">\n                <a href=\"./about.php\">\n                    会社を知る\n                </a>\n            </dt>\n        </dl>\n    </li>\n\n    <li class=\"\">\n        <dl>\n            <dt class=\"\">\n                <a href=\"./work.php\">\n                    仕事を知る\n                </a>\n            </dt>\n        </dl>\n    </li>\n    <li class=\"\">\n        <dl>\n            <dt class=\"\">\n                <a href=\"./staff.php\">\n                    社員を知る\n                </a>\n            </dt>\n        </dl>\n    </li>\n    <li class=\"on\">\n        <dl>\n            <dt class=\"\">\n                <a href=\"./qa.php\">\n                    Q&A\n                </a>\n            </dt>\n        </dl>\n    </li>\n</ul>    </nav>\n</header>    <div class=\"secTitle\">\r\n        <div class=\"title mincho\">\r\n            <h1>\r\n                Q&amp;A<br>\r\n                <small>学生からの質問に先輩社員たちが答えました</small>\r\n            </h1>\r\n        </div>\r\n        <div class=\"bgTitle bgTitleqa\"></div>\r\n    </div>\r\n    <div class=\"con block mincho\">\r\n\r\n        <ul class=\"sNav\">\r\n            <li>\r\n                <a href=\"#seko\" class=\"on\">\r\n                    施工管理職\r\n                </a>\r\n            </li>\r\n            <li>\r\n                <a href=\"#sekkei\">\r\n                    設計職\r\n                </a>\r\n            </li>\r\n            <li>\r\n                <a href=\"#kensetsu\">\r\n                    建設営業職\r\n                </a>\r\n            </li>\r\n            <li>\r\n                <a href=\"#mansion\">\r\n                    マンション販売職\r\n                </a>\r\n            </li>\r\n            <li>\r\n                <a href=\"#jinji\">\r\n                    採用担当者\r\n                </a>\r\n            </li>\r\n        </ul>\r\n        <section class=\"secQa\" id=\"seko\">\r\n            <h2 class=\"ttl\">施工管理</h2>\r\n            <div class=\"lstQa\">\r\n                <dl>\r\n                    <dt>\r\n                        業務の中で一番重要だと思うことは何ですか\r\n                    </dt>\r\n                    <dd>\r\n                        最優先は「安全」です。そして「品質」です。<br>\r\n                        安全は取り戻せませんし、品質は技術者としての「責任とプライド」です。\r\n                    </dd>\r\n                </dl>\r\n                <dl>\r\n                    <dt>\r\n                        現場の状況整理で工夫していることや意識していることはありますか\r\n                    </dt>\r\n                    <dd>\r\n                        常に先の工程を意識して仕事を進め準備に不備を起こさないようにします。確認の確認が大事な仕事です。<br>\r\n                        またコミュニケーションをしっかりとることでミスがないようにしています。\r\n                    </dd>\r\n                </dl>\r\n                <dl>\r\n                    <dt>\r\n                        1つの現場に何名の施工管理が配属されていますか\r\n                    </dt>\r\n                    <dd>\r\n                        現場の大きさ、難易度により異なりますが3名～6名位が多いです。<br>\r\n                        所長、次席、中堅、若手のようなチームです。\r\n                    </dd>\r\n                </dl>\r\n                <dl>\r\n                    <dt>\r\n                        職人さんとのコミュニケーションで気を付けていることはありますか\r\n                    </dt>\r\n                    <dd>\r\n                        職人さんは年上も多くプロの技術者ですので、言葉使いに注意し、意見を尊重するようにしています。<br>\r\n                        意見が違う時は一緒に解決方法を見つける意識が大切です。\r\n                    </dd>\r\n                </dl>\r\n                <dl>\r\n                    <dt>\r\n                        会社を決める際に一番大切にしたことは何ですか\r\n                    </dt>\r\n                    <dd>\r\n                        将来性とやりたい事ができるかです。せっかく働くなら駒ではなく、自分で建物を造りたかったので新日本建設を選びました。<br>\r\n                        当社の施工管理は最初から最後まで現場を管理できるので「自分が造った」と自信を持って言えます。\r\n                    </dd>\r\n                </dl>\r\n                <dl>\r\n                    <dt>\r\n                        入社してから一番良かった出来事は何ですか\r\n                    </dt>\r\n                    <dd>\r\n                        自分が建てた（関わった）建物が出来上がり、たくさんの人たちが暮らしている姿を目の当たりにした時です。<br>\r\n                        その時は泣けるくらい感動しました。\r\n                    </dd>\r\n                </dl>\r\n            </div>\r\n\r\n        </section>\r\n\r\n        <ul class=\"sNav\">\r\n            <li>\r\n                <a href=\"#seko\">\r\n                    施工管理職\r\n                </a>\r\n            </li>\r\n            <li>\r\n                <a href=\"#sekkei\" class=\"on\">\r\n                    設計職\r\n                </a>\r\n            </li>\r\n            <li>\r\n                <a href=\"#kensetsu\">\r\n                    建設営業職\r\n                </a>\r\n            </li>\r\n            <li>\r\n                <a href=\"#mansion\">\r\n                    マンション販売職\r\n                </a>\r\n            </li>\r\n            <li>\r\n                <a href=\"#jinji\">\r\n                    採用担当者\r\n                </a>\r\n            </li>\r\n        </ul>\r\n        <section class=\"secQa\" id=\"sekkei\">\r\n            <h2 class=\"ttl\">設計</h2>\r\n            <div class=\"lstQa\">\r\n                <dl>\r\n                    <dt>\r\n                        大学の課題と実際に働いて設計することの違いは何ですか\r\n                    </dt>\r\n                    <dd>\r\n                        企業設計はデザイン性の他にもコストと施工しやすさと施工期間などを緻密に考えています。<br>\r\n                        特にコストが厳しい時などは設備設計や構造設計とも協議して解決策を導きます。\r\n                    </dd>\r\n                </dl>\r\n                <dl>\r\n                    <dt>\r\n                        DX推進の中でBIMが注目されていますが、御社での状況はどうですか。<br>\r\n                        またBIMならではの利点、恩恵はありますか\r\n                    </dt>\r\n                    <dd>\r\n                        三次元CAD（BIM)の導入も行っています。<br>\r\n                        平面図から立体図に変換できるのでクライアントが建築未経験者でも説明がしやすいですし、平面・立面・断面図の整合性が取れるのが業務効率化に大きく役立っています。\r\n                    </dd>\r\n                </dl>\r\n                <dl>\r\n                    <dt>\r\n                        設計1年目の仕事は主にどのようなことをしますか\r\n                    </dt>\r\n                    <dd>\r\n                        多い業務は条例や建築基準に適合しているかの行政との打合せです。他にも部分的な外構図の作成、緑化計画図の作成など少しずつ担当が任されます。<br>\r\n                        先輩・上司がサポートしてくれますので安心して業務を行えます。\r\n                    </dd>\r\n                </dl>\r\n                <dl>\r\n                    <dt>\r\n                        一つのプロジェクトを成し遂げる中で最も大切なことは何ですか\r\n                    </dt>\r\n                    <dd>\r\n                        相談・確認・他部署との連携を繰り返しますが、どれも重要になります。確認は絶対に何度も行います。\r\n                    </dd>\r\n                </dl>\r\n                <dl>\r\n                    <dt>\r\n                        入社前のビジョンと入社後の現実について、異なる部分はありますか\r\n                    </dt>\r\n                    <dd>\r\n                        入社前は「素敵なデザインを描く」ことを想像していましたが、実際は「コストの問題、工事の問題、クライアントの要望」など多くの制限の中で自分らしさを表現しなければならない現実を知りました。だからこそ「やってやろう」と熱意が湧きます。\r\n                    </dd>\r\n                </dl>\r\n                <dl>\r\n                    <dt>\r\n                        建築的なことで学生時代にやっておくべきことはありますか\r\n                    </dt>\r\n                    <dd>\r\n                        日々多くの建物を見て設計者の意図を読み解くことや、建築雑誌に目を通すことです。また学業では設計課題に真剣に取り組むことが大切です。\r\n                    </dd>\r\n                </dl>\r\n            </div>\r\n\r\n        </section>\r\n\r\n        <ul class=\"sNav\">\r\n            <li>\r\n                <a href=\"#seko\">\r\n                    施工管理職\r\n                </a>\r\n            </li>\r\n            <li>\r\n                <a href=\"#sekkei\">\r\n                    設計職\r\n                </a>\r\n            </li>\r\n            <li>\r\n                <a href=\"#kensetsu\" class=\"on\">\r\n                    建設営業職\r\n                </a>\r\n            </li>\r\n            <li>\r\n                <a href=\"#mansion\">\r\n                    マンション販売職\r\n                </a>\r\n            </li>\r\n            <li>\r\n                <a href=\"#jinji\">\r\n                    採用担当者\r\n                </a>\r\n            </li>\r\n        </ul>\r\n        <section class=\"secQa\" id=\"kensetsu\">\r\n            <h2 class=\"ttl\">建設営業</h2>\r\n            <div class=\"lstQa\">\r\n                <dl>\r\n                    <dt>\r\n                        営業をする時、どのような組み立てでお客様と話をしていますか\r\n                    </dt>\r\n                    <dd>\r\n                        まずはお客様のニーズの深堀です。何を求めているのか？を真剣に聞いて考えます。<br>\r\n                        その上でお客様の為に何ができるかを誠心誠意考え抜きご提案内容を作り上げます。\r\n                    </dd>\r\n                </dl>\r\n                <dl>\r\n                    <dt>\r\n                        他社に勝つための工夫していることや、軸にしていること、大切にしていることは何ですか\r\n                    </dt>\r\n                    <dd>\r\n                        まずはスピードです。ここで他社より一番を心がけます。早い対応は信頼を勝ち得ます。<br>\r\n                        さらにお客様の為に何が一番良いのかを真剣に考え抜くことも大切です。\r\n                    </dd>\r\n                </dl>\r\n                <dl>\r\n                    <dt>\r\n                        新日本建設で働いて良かったと思うことは何ですか\r\n                    </dt>\r\n                    <dd>\r\n                        先輩社員たちの面倒見の良さです。当然、最初の頃は先輩の資料作成などをサポートしながら仕事を学んでいく事になりますが、一人立ちした後も仕事の進捗確認や苦労していることがあれば相談に乗ってくださり解決の方法を示してくれます。<br>\r\n                        また一人で太刀打ちできないようなお客様は先輩に同席してもらったりしています。\r\n                    </dd>\r\n                </dl>\r\n                <dl>\r\n                    <dt>\r\n                        自社製販一貫体制で良かった点は何ですか\r\n\r\n                    </dt>\r\n                    <dd>\r\n                        プラン作成もデザインもコスト計算も社内で行う為、スピードが早く相談しやすい点です。\r\n                    </dd>\r\n                </dl>\r\n                <dl>\r\n                    <dt>\r\n                        建設営業職で必要な資格やスキルはありますか\r\n                    </dt>\r\n                    <dd>\r\n                        資格は宅地建物取引士を推奨しており、毎年、試験前には勉強会が開かれています。<br>\r\n                        また日々の営業で一番必要なスキルは「人間力」です。お客様との信頼関係を作る事が受注するための基本になると思います。\r\n                    </dd>\r\n                </dl>\r\n            </div>\r\n\r\n        </section>\r\n\r\n        <ul class=\"sNav\">\r\n            <li>\r\n                <a href=\"#seko\">\r\n                    施工管理職\r\n                </a>\r\n            </li>\r\n            <li>\r\n                <a href=\"#sekkei\">\r\n                    設計職\r\n                </a>\r\n            </li>\r\n            <li>\r\n                <a href=\"#kensetsu\">\r\n                    建設営業職\r\n                </a>\r\n            </li>\r\n            <li>\r\n                <a href=\"#mansion\" class=\"on\">\r\n                    マンション販売職\r\n                </a>\r\n            </li>\r\n            <li>\r\n                <a href=\"#jinji\">\r\n                    採用担当者\r\n                </a>\r\n            </li>\r\n        </ul>\r\n        <section class=\"secQa\" id=\"mansion\">\r\n            <h2 class=\"ttl\">マンション販売</h2>\r\n            <div class=\"lstQa\">\r\n                <dl>\r\n                    <dt>\r\n                        お客様のご希望通りのお部屋だと予算的に厳しい場合、どのような提案をしていますか\r\n                    </dt>\r\n                    <dd>\r\n                        予算に合わない時は、別プランのご提案になります。広さを変えたり、階数を変更して予算に合うお部屋を提案しますし、住宅ローンの組み方を変えて購入しやすいプランを提案します。\r\n                    </dd>\r\n                </dl>\r\n                <dl>\r\n                    <dt>\r\n                        お客様から信頼を得るためにやっていること、努力していることはありますか\r\n                    </dt>\r\n                    <dd>\r\n                        約束は必ず守ることです。当たり前ですが「うっかりミス」はNGです。<br>\r\n                        何時にお電話する、いつまでに資料を送るなどは基本です。私は多くのお客様を担当しますが、お客様からすれば担当は私一人になります。\r\n                    </dd>\r\n                </dl>\r\n                <dl>\r\n                    <dt>\r\n                        マンション販売の仕事で「意外とこんなことをする」というものはありますか\r\n                    </dt>\r\n                    <dd>\r\n                        周辺の散策（調査）です。<br>\r\n                        公園の雰囲気や、美味しいお店を探してお客様へ紹介したりもします。また、マンション情報誌の打合せなども行います。もちろんゲストサロンの清掃も欠かせません。\r\n                    </dd>\r\n                </dl>\r\n                <dl>\r\n                    <dt>\r\n                        マンション販売職の新入社員研修はどのように行われますか\r\n                    </dt>\r\n                    <dd>\r\n                        新入社員はそれぞれゲストサロンに分かれて配属します。そこでOJT形式で仕事を覚えていきます。<br>\r\n                        また毎週月曜に全体ミーティングがありますが入社まもない頃はミーティング終了後に接客マナーや住宅ローンなどの研修が行われます。\r\n                    </dd>\r\n                </dl>\r\n                <dl>\r\n                    <dt>\r\n                        マンション販売で必須の資格、知っておいた方が良い知識や勉強するべきことはありますか\r\n                    </dt>\r\n                    <dd>\r\n                        宅地建物取引士は必須資格です。また家具のサイズや家電についての知識、その他、子育てに関することや教育に必要な資金などライフプランについても知っておくと良いと思います。\r\n                    </dd>\r\n                </dl>\r\n            </div>\r\n\r\n        </section>\r\n\r\n        <ul class=\"sNav\">\r\n            <li>\r\n                <a href=\"#seko\">\r\n                    施工管理職\r\n                </a>\r\n            </li>\r\n            <li>\r\n                <a href=\"#sekkei\">\r\n                    設計職\r\n                </a>\r\n            </li>\r\n            <li>\r\n                <a href=\"#kensetsu\">\r\n                    建設営業職\r\n                </a>\r\n            </li>\r\n            <li>\r\n                <a href=\"#mansion\">\r\n                    マンション販売職\r\n                </a>\r\n            </li>\r\n            <li>\r\n                <a href=\"#jinji\" class=\"on\">\r\n                    採用担当者\r\n                </a>\r\n            </li>\r\n        </ul>\r\n        <section class=\"secQa\" id=\"jinji\">\r\n            <h2 class=\"ttl\">採用担当者</h2>\r\n            <div class=\"lstQa\">\r\n                <dl>\r\n                    <dt>\r\n                        希望する職種で働くことができますか\r\n                    </dt>\r\n                    <dd>\r\n                        当社は職種別の採用になります。建設営業、施工管理、意匠設計、設備設計、構造設計、マンション販売、総合事務、一般事務と職種別に選考をおこないますので、希望の職種にて就業できます。\r\n                    </dd>\r\n                </dl>\r\n                <dl>\r\n                    <dt>\r\n                        大学での成績は採用でどのくらい影響がありますか\r\n                    </dt>\r\n                    <dd>\r\n                        成績は学生の本分である学業に対して真剣に取り組んだか、目的を持って大学を選び学んだかの証明になりますので確認をします。<br>\r\n                        もし成績が自慢できるもので無くても、その代わりに何に取組み何を学んだかも大切です。\r\n                    </dd>\r\n                </dl>\r\n                <dl>\r\n                    <dt>\r\n                        採用する際に目を引く学生はどんな人ですか\r\n                    </dt>\r\n                    <dd>\r\n                        目的意識が定まっている学生です。芯があり一貫性がある学生には魅力を感じます。\r\n                    </dd>\r\n                </dl>\r\n                <dl>\r\n                    <dt>\r\n                        会社としてどのような新入社員が欲しいと考えていますか\r\n                    </dt>\r\n                    <dd>\r\n                        主体性がある人材です。自ら学び、動き、失敗し、また学びのサイクルができると成長は段違いです。\r\n                    </dd>\r\n                </dl>\r\n                <!--<dl>\r\n                    <dt>\r\n                        面接時の雰囲気はどうですか\r\n                    </dt>\r\n                    <dd>\r\n                        当社の面接官は柔らかい感じです。ただし設計のポートフォリオへの質問はプロ目線になります。\r\n                    </dd>\r\n                </dl>-->\r\n                <dl>\r\n                    <dt>\r\n                        採用の時点で設計職から施工管理職への変更はありますか\r\n                    </dt>\r\n                    <dd>\r\n                        職種別に採用するので、変更はありません。設計で不採用になり、他の職種にて適性がありそうな学生にはこちらから職種変更の声をかける場合があります。<br>\r\n                        （昨年は設計から施工管理に再度選考に進む方がいました。）\r\n                    </dd>\r\n                </dl>\r\n                <dl>\r\n                    <dt>\r\n                        新日本建設の強みは何ですか\r\n                    </dt>\r\n                    <dd>\r\n                        ベテランと中堅と若手の融合だと思います。教える時はしっかり教え、任せる時は責任を持って任せ、苦しい時はみんなで乗り切ることができます。\r\n                    </dd>\r\n                </dl>\r\n            </div>\r\n\r\n        </section>\r\n<!--        <section class=\"secQa\">\r\n            <ul class=\"sNav\">\r\n                <li>\r\n                    <a href=\"#seko\">\r\n                        <img src=\"./images/qa/icoSeko.png\">\r\n                        「施工管理職」への質問\r\n                    </a>\r\n                </li>\r\n                <li>\r\n                    <a href=\"#sekkei\">\r\n                        <img src=\"./images/qa/icoSekkei.png\">\r\n                        「設計職」への質問\r\n                    </a>\r\n                </li>\r\n                <li>\r\n                    <a href=\"#kensetsu\">\r\n                        <img src=\"./images/qa/icoKensetsu.png\">\r\n                        「建設営業職」への質問\r\n                    </a>\r\n                </li>\r\n                <li>\r\n                    <a href=\"#mansion\">\r\n                        <img src=\"./images/qa/icoMansion.png\">\r\n                        「マンション販売職」への質問\r\n                    </a>\r\n                </li>\r\n               <li>\r\n                    <a href=\"#desk\">\r\n                        <img src=\"./images/qa/icoDesk.png\">\r\n                        「事務系職」への質問\r\n                    </a>\r\n                </li>\r\n                <li>\r\n                    <a href=\"#jinji\">\r\n                        <img src=\"./images/qa/icoJinji.png\">\r\n                        「人事部」への質問\r\n                    </a>\r\n                </li>\r\n            </ul>\r\n            <h2 class=\"ttl\" id=\"seko\">人事部</h2>\r\n            <div class=\"\">\r\n                <dl>\r\n                    <dt>\r\n                        ●●●\r\n                    </dt>\r\n                    <dd>\r\n                        ●●●\r\n                    </dd>\r\n                </dl>\r\n            </div>\r\n\r\n        </section>-->\r\n\r\n    </div>\r\n\r\n</div>\r\n<footer>\n    <div class=\"ftBtm block\">       \n        <div class=\"ftLink\">\n            <div class=\"logo cf\"> \n                <a href=\"../\" target=\"_blank\" class=\"eng\">\n                    <img src=\"../common/img/common/logo.jpg\" alt=\"新日本建設株式会社\" />\n                </a> \n            </div>\n            <ul class=\"cf\">\n                <li>\n                    <a href=\"../privacypolicy/\" target=\"_blank\">個人情報の取り扱いについて</a>\n                </li>\n                <li>\n                    <a href=\"../contact/\" target=\"_blank\">お問い合わせ</a>\n                </li>\n                <li>\n                    <a href=\"../sitemap/\" target=\"_blank\">サイトマップ</a>\n                </li>\n            </ul>\n        </div>\n        <p class=\"copy\">\n            <small>COPYRIGHT &copy; SHINNIHON CORPORATION. All Rights Reserved.</small>\n        </p> \n\n    </div>\n</footer>\n\n<div class=\"page_top\">\n    PAGE<br class=\"spOnly\"> TOP\n    <i class=\"material-icons\">keyboard_arrow_up</i>\n</div>\n\n<div class=\"btn_entry_fix spOnly\">\n\t<div class=\"box\">\n\t\t<a href=\"https://job.axol.jp/bx/s/shinnihon-c_27/entry/\" target=\"_blank\">\n        新卒採用（2027卒）<br>エントリーはこちら\n\t\t</a>\n        <a href=\"https://axol.jp/zw/s/shinnihon-c_28/entry/\" target=\"_blank\">\n            新卒採用（2028卒）<br>インターンシップは<br>こちら\n        </a>\n        <!-- <a href=\"https://job.mynavi.jp/26/pc/search/corp54735/outline.html\" class=\"bnr\" target=\"_blank\">\n        <img src=\"https://job.mynavi.jp/conts/kigyo/2026/logo/banner_logo_195_60.gif\" alt=\"マイナビ2026\" border=\"0\">\n        </a> -->\n\t\t<a href=\"./career.php\">キャリア採用</a>\n\t</div>\n</div>\n\n</body>\n</html>","finalUrl":"https://www.shinnihon-c.co.jp/recruit/qa.php","rendered":false,"_cachedAt":"2026-06-22T22:38:35.111Z"}