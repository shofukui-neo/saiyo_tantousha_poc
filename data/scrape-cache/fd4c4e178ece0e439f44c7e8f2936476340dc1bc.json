{"url":"https://www.stertec.co.jp/~kunimori/contact/policy.html","html":"<!DOCTYPE html>\n<html lang=\"ja\" class=\"no-js\">\n<head prefix=\"og: http://ogp.me/ns# fb: http://ogp.me/ns/fb# article: http://ogp.me/ns/article#\">\n\n<!-- Google tag (gtag.js) -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-KHYN9M9KJB\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'G-KHYN9M9KJB');\n</script>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width\">\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n<title>プライバシーポリシー | 株式会社国盛化学</title>\n<meta name=\"description\" content=\"株式会社国盛化学は、自動車部品をはじめ情報通信・家電製品などさまざまな分野の製品を受注生産、国内外のネットワークを駆使し、機構設計の受注から金型作製・製品出荷まで一貫対応しております。\">\n<meta property=\"og:site_name\" content=\"株式会社国盛化学\">\n<meta property=\"og:type\" content=\"article\">\n<meta property=\"og:url\" content=\"http://www.stertec.co.jp/~kunimori/contact/\">\n<meta property=\"og:title\" content=\"お問い合わせ | 株式会社国盛化学\">\n<meta property=\"og:description\" content=\"株式会社国盛化学は、自動車部品をはじめ情報通信・家電製品などさまざまな分野の製品を受注生産、国内外のネットワークを駆使し、機構設計の受注から金型作製・製品出荷まで一貫対応しております。\">\n<meta property=\"og:image\" content=\"//www.stertec.co.jp/~kunimori/common/setting/ogimage.jpg\">\n<meta name=\"msapplication-config\" content=\"../common/setting/windows.xml\">\n<link rel=\"icon\" href=\"../common/setting/favicon.ico\">\n<link rel=\"apple-touch-icon\" sizes=\"192x192\" href=\"../common/setting/iphone.png\">\n<link rel=\"mask-icon\" href=\"../common/setting/safari.svg\" color=\"#0d6fb8\">\n<link rel=\"manifest\" href=\"../common/setting/android.manifest\">\n<link rel=\"stylesheet\" href=\"../common/css/style.css\">\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=UA-637674-23\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n  gtag('config', 'UA-637674-23');\n</script>\n</head>\n<body>\n\n\n\n<!--ヘッダーメニュー-->\n\t<header class=\"header\">\n\t<div class=\"header-logo\"><a href=\"../index.html\"><img src=\"../common/img/header_logo.svg\" alt=\"株式会社国盛化学\"></a></div>\n\t<nav class=\"header-menu\">\n\t\t<div class=\"gnav\">\n\t\t\t<div class=\"gnav-item\">\n\t\t\t\t<div class=\"gnav-main\"><a href=\"../company/index.html\">国盛化学について</a></div>\n\t\t\t\t<div class=\"gnav-subs\">\n\t\t\t\t\t<div class=\"gnav-subs-item\">\n\t\t\t\t\t\t<div class=\"gnav-subs-image\"><img src=\"../common/img/gnav_company_subs01.jpg\" alt=\"会社概要\"></div>\n\t\t\t\t\t\t<div class=\"gnav-subs-body\">\n\t\t\t\t\t\t\t<div class=\"gnav-subs-title\"><a href=\"../company/index.html\">会社概要</a></div>\n\t\t\t\t\t\t\t<div class=\"gnav-subs-lists\">\n\t\t\t\t\t\t\t\t<ul class=\"gnav-subs-list\">\n\t\t\t\t\t\t\t\t\t<li><a href=\"../company/index.html#section01\">代表者挨拶</a></li>\n\t\t\t\t\t\t\t\t\t<li><a href=\"../company/index.html#section02\">会社概要</a></li>\n\t\t\t\t\t\t\t\t\t<li><a href=\"../company/index.html#section03\">組織図</a></li>\n\t\t\t\t\t\t\t\t</ul>\n\t\t\t\t\t\t\t\t<ul class=\"gnav-subs-list\">\n\t\t\t\t\t\t\t\t\t<li><a href=\"../company/index.html#section04\">沿革</a></li>\n\t\t\t\t\t\t\t\t\t<li><a href=\"../company/index.html#section05\">品質・環境方針</a></li>\n\t\t\t\t\t\t\t\t</ul>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t\t<div class=\"gnav-subs-item\">\n\t\t\t\t\t\t<div class=\"gnav-subs-image\"><img src=\"../common/img/gnav_company_subs02.jpg\" alt=\"関連企業\"></div>\n\t\t\t\t\t\t<div class=\"gnav-subs-body\">\n\t\t\t\t\t\t\t<div class=\"gnav-subs-title\"><a href=\"../company/network.html\">関連企業</a></div>\n\t\t\t\t\t\t\t<div class=\"gnav-subs-title\"><a href=\"../group/index.html\">海外拠点</a></div>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\n\t\t\t<div class=\"gnav-item\">\n\t\t\t\t<div class=\"gnav-main\"><a href=\"../technology/index.html\">技術紹介</a></div>\n\t\t\t\t<div class=\"gnav