{"url":"https://suntaxi.com/recruit/require/index.html","html":"<!DOCTYPE html>\n<html xml:lang=\"ja\" lang=\"ja\">\n<head>\n<!-- Google tag (gtag.js) -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-8L99XZ0PR6\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'G-8L99XZ0PR6');\n</script>\n<meta charset=\"utf-8\">\n<title>募集要項・よくある質問 | サンタクシー【横浜】採用サイト</title>\n<meta name=\"description\" content=\"サンタクシー【横浜】のタクシードライバー募集要項や採用についてのよくある質問をご紹介します。横浜でタクシー運転手をやろうと思っている方はぜひご覧下さい。\" />\n<meta name=\"keywords\" content=\"横浜,求人,募集要項,よくある質問,FAQ,採用,タクシー,ドライバー,運転手\" />\n<link rel=\"shortcut icon\" href=\"../images/common/favicon.ico\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1, maximum-scale=1\" />\n<link href=\"../style/base.css\" rel=\"stylesheet\" type=\"text/css\" media=\"all\" />\n<link href=\"../style/gheader.css\" rel=\"stylesheet\" type=\"text/css\" media=\"all\" />\n<link href=\"../style/common.css\" rel=\"stylesheet\" type=\"text/css\" media=\"all\" />\n<link href=\"../style/require.css\" rel=\"stylesheet\" type=\"text/css\" media=\"all\" />\n    \n<link href=\"https://use.fontawesome.com/releases/v5.5.0/css/all.css\" rel=\"stylesheet\">\n<script src=\"https://ajax.googleapis.com/ajax/libs/jquery/3.3.1/jquery.min.js\"></script>\n<script src=\"../js/common.js\"></script>\n<script src=\"../js/gnavfunc.js\"></script>\n<script src=\"../js/tpfunc.js\"></script>\n    \n</head>\n\n<body>\n    <div id=\"header\">\n        <div class=\"contaider\">\n            <div id=\"mobile-head\">\n                <div id=\"logo\"><a href=\"../index.html\" title=\"神奈川県横浜市のサンタクシー\"><img src=\"../images/common/logo.png\" alt=\"神奈川県横浜市のサンタクシー\" /><span>採用サイト</span></a></div>\n            </div>\n            <nav class=\"gNav\" role=\"navigation\" aria-label=\"メインメニュー\">\n            <p class=\"gnavbtn\"><a href=\"javascript:void(0)\"><span>メニューを開く</span></a></p>\n            <ul>\n                <li class=\"parent\"><a href=\"../index.html\" class=\"pcmenu\">ホーム</a><a href=\"javascript:void(0)\" class=\"spmenu\">ホーム</a>\n\t\t\t\t\t<!-- home -->\n\t\t\t\t\t<ul class=\"submenu\">\n\t\t\t\t\t\t<li><a href=\"../index.html\" class=\"spmenu\">トップページ</a></li>\n                        <li><a href=\"../privacy/index.html\">プライバシーポリシー</a></li>\n                    </ul>\n\t\t\t\t\t<!-- /home -->\n\t\t\t\t</li>\n                <li class=\"parent\"><a href=\"../about/index.html\" class=\"pcmenu\">会社紹介</a><a href=\"javascript:void(0)\" class=\"spmenu\">会社紹介</a>\n                    <!-- about -->\n                    <ul class=\"submenu\">\n\t\t\t\t\t\t<li><a href=\"../about/index.html\" class=\"spmenu\">会社紹介TOP</a></li>\n                        <li><a href=\"../about/appeal/index.html\">サンタクシーとは？</a></li>\n                        <li><a href=\"../about/fine/index.html\">サンタクシーの魅力</a></li>\n                        <li><a href=\"../about/voice/index.html\">現役社員の声</a></li>\n                    </ul>\n                    <!-- /about -->\n                </li>\n                <li class=\"parent\"><a href=\"../driver/index.html\" class=\"pcmenu\">働き方色々</a><a href=\"javascript:void(0)\" class=\"spmenu\">働き方色々</a>\n\t\t\t\t\t<ul class=\"submenu\">\n\t\t\t\t\t\t<li><a href=\"../driver/index.html\" class=\"spmenu\">働き方色々TOP</a></li>\n\t\t\t\t\t\t<li><a href=\"../experienced/index.html\">ドライバー経験者</a></li>\n\t\t\t\t\t\t<li><a href=\"../inexperienced/index.html\">未経験者</a></li>\n\t\t\t\t\t\t<li><a href=\"../woman/index.html\">女性ドライバー</a></li>\n\t\t\t\t\t\t<li><a href=\"../senior/index.html\">シニアドライバー</a></li>\n\t\t\t\t\t</ul>\n\t\t\t\t</li>\n                <li class=\"parent\"><a href=\"../require/index.html\">募集要項・よくある質問</a></li>\n                <li class=\"parent\"><a href=\"../entry/index.html\">エントリー</a></li>\n                <li class=\"parent\"><a href=\"../../index.html\">コーポレートサイト</a></li>\n            </ul>\n            <!-- /.Nav -->\n        </nav>\n\t\t\t<p id=\"headinsta\"><a href=\"https://www.instagram.com/yokohama_suntaxi/\" title=\"サンタクシーのインスタグラムへ\" target=\"_blank\"><img src=\"../images/common/logo_instagram.png\" alt=\"サンタクシーのインスタグラムへ\"/></a></p>\n        </div>\n      <!-- /#header-->\n    </div>\n    <div class=\"intro\">\n        <div class=\"container\">\n            <h1>募集要項・よくある質問</h1>\n        </div>\n        <!-- /#intro-->\n    </div>\n    <div id=\"panlist\">\n        <div class=\"container\">\n            <p id=\"pan\"><a href=\"../index.html\">ホーム</a><em>&gt;</em>募集要項・よくある質問</p>\n        </div>\n        <!--  /#panlist-->\n    </div>\n    <div id=\"contents\">\n\t\t<div class=\"area_101\">\n\t\t\t<ul class=\"plan_list\">\n\t\t\t\t<li><a href=\"#type_require\">募集要項</a></li>\n                <li><a href=\"#type_faq\">よくある質問</a></li>\n\t\t\t</ul>\n\t\t</div>\n        <div class=\"area_01\" id=\"type_require\">\n            <div class=\"container\">\n                <h2>募集要項</h2>\n                <table class=\"require\" summary=\"タクシードライバー募集要項\">\n                    <tr>\n                        <th scope=\"row\">募集職種</th>\n       \t\t\t\t  <td>タクシードライバー</td>\n                    </tr>\n                    <tr>\n          \t\t\t\t<th scope=\"row\">雇用形態</th>\n          \t\t\t\t<td>\n                            <p>正社員</p>\n                            <p>嘱託</p>\n                            <p>パート</p>\n                        </td>\n                    </tr>\n                    <tr>\n                        <th scope=\"row\">募集対象</th>\n          \t\t\t\t<td>\n                            <p>学歴不問</p>\n                            <p>年齢：19歳以上</p>\n                            <p>普通自動車運転免許の取得後1年以上経過している方。（AT限定も可）</p>\n       \t\t\t\t\t    <p class=\"bmspc\">または普通自動車二種免許を取得している方</p>\n                            <p>未経験者や女性の方も大歓迎！</p>\n                        </td>\n                    </tr>\n                    <tr>\n                        <th scope=\"row\">勤務地</th>\n                        <td>\n                            <dl class=\"locate bmspc\">\n                                <dt>本社</dt>\n                                <dd>神奈川県横浜市中区かもめ町20</dd>\n                            </dl>\n                            <dl class=\"locate\">\n                                <dt>小机営業所</dt>\n                                <dd>神奈川県横浜市港北区新羽町3844-1</dd>\n                            </dl>\n                        </td>\n                    </tr>\n                    <tr>\n                        <th scope=\"row\">勤務時間</th>\n                        <td>\n                            <dl class=\"kintm\">\n                                <dt>隔日勤務</dt>\n                                <dd>月間12～13乗務</dd>\n                                <dd>8:00～翌1:00（休憩3時間）</dd>\n                            </dl>\n                            <dl class=\"kintm\">\n                                <dt>昼日勤</dt>\n                                <dd>月間22～24乗務</dd>\n                                <dd>8:00～16:30（休憩1時間）</dd>\n                            </dl>\n                            <dl class=\"kintm\">\n                              <dt>夜日勤</dt>\n                                <dd>月間22～24乗務</dd>\n                                <dd>17:00～翌3:00（休憩1時間）</dd>\n                            </dl>\n                            <dl class=\"kintm\">\n                                <dt>所定労働時間</dt>\n                                <dd>1ヶ月単位の変形労働時間制（週40時間以内）</dd>\n                                <dd>嘱託・パートの方の勤務日数・勤務時間は相談に応じます</dd>\n                            </dl>\n                        </td>\n                    </tr>\n                    <tr>\n                        <th scope=\"row\">給与</th>\n                        <td>\n                            <p>月収28万円～50万円以上可<br>\n                                （勤務日数・売上により異なります）</p>\n                        </td>\n                    </tr>\n                    <tr>\n                        <th scope=\"row\">休日・休暇</th>\n                        <td>\n                            <p>月間の公休日はシフトにより6～7日</p>\n                            <p>有給休暇・育児休暇・介護休暇</p>\n                        </td>\n                    </tr>\n                    <tr>\n                        <th scope=\"row\">待遇</th>\n                        <td>\n                            <ul class=\"taigu_list\">\n                                <li>経験者の方は入社祝い金25万円、未経験の方でも入社祝い金15万円（紹介会社経由の方は対象外になります）</li>\n                                <li>12ヶ月間30万円の給与保障あり（未経験者でフルタイム勤務の場合）</li>\n                                <li>賞与あり（年2回）</li>\n                                <li>マイカー通勤可</li>\n                                <li>タクシー車両は自動日報機搭載（機械任せで日報記入の手間が省けます）</li>\n                                <li>ドライブレコーダー、車内カメラ搭載</li>\n                                <li>GOアプリ配車機能搭載</li>\n                                <li>ナビ、ETC、決済端末搭載</li>\n                                <li>各種研修、検定資格取得支援あり</li>\n                                <li>各種社会保険完備（雇用・労災・健康保険、厚生年金）</li>\n                                <li>月額1万円の一時預かり金補助あり（保育園・幼稚園児限定）</li>\n                                <li>年2回の集団健康診断</li>\n                                <li>ご希望の方には完全個室の社宅をご用意（単身・ファミリーも可。入居初期費用も最大30万円まで支援）</li>\n\t\t\t\t\t\t\t\t<li>クレジットカード手数料や各種割引手数料等のドライバー負担は一切ありません。</li>\n                            </ul>\n                        </td>\n                    </tr>\n                </table>\n            </div>\n        </div>\n        <div class=\"area_02\" id=\"type_faq\">\n            <div class=\"container\">\n                <h2>よくある質問</h2>\n                <dl class=\"driver_faq\">\n                    <dt>二種免許がないので、教習所に通っての取得になると思いますが、給与は出ますか？</dt>\n                    <dd>教習所へ通学中は日給1万円を支給いたします。<br>\n                        さらに教習費用・受験料(3回まで)は当社が負担いたします。</dd>\n                </dl>\n                <dl class=\"driver_faq\">\n                    <dt>二種免許取得は、どれ位かかりますか？</dt>\n                    <dd>教習所で約10日間です。</dd>\n                </dl>\n                <dl class=\"driver_faq\">\n                    <dt>座学などの業界研修中の給与は出ますか？</dt>\n                    <dd>研修期間は約10日間、日給1万円支給いたします。</dd>\n                </dl>\n                <dl class=\"driver_faq\">\n                  <dt>地理を覚えられるか、とても不安で･･･。</dt>\n                    <dd>配属先での先輩との添乗研修で地理を勉強していただきます。<br>\n                        サンタクシーのドライバーは、未経験からスタートした方が多いので、きちんと覚えられるよう、丁寧にしっかりサポートするので安心して下さい！！</dd>\n                </dl>\n                <dl class=\"driver_faq\">\n                    <dt>子供が小さいのですが、勤務時間の短縮は？</dt>\n                    <dd>それぞれのご家庭で事情はあると思いますので、お子様の年齢やご家庭の状況に合わせた勤務時間を検討していきたいと思っております。(保育園の送迎・参観日・懇談会等)</dd>\n                </dl>\n                <dl class=\"driver_faq\">\n                    <dt>お正月やお盆などは休めますか？</dt>\n                    <dd>あらかじめ勤務を確認します。<br>\n                        事前申請して頂ければ、お休みも取れます。</dd>\n                </dl>\n                <dl class=\"driver_faq\">\n                    <dt>本当に稼げるのでしょうか？</dt>\n                    <dd>しっかり稼ぎたい方は、18:00～翌4:00などの夜勤勤務がオススメです！\n                        月24日勤務で深夜手当が支給されるので、ガッチリ稼いでいるドライバーも多数います。<br>\n                        運転が好きな方には天職かもしれません。</dd>\n                </dl>\n            </div>\n        </div>\n        <div class=\"area_01\" id=\"area_entry\">\n            <h2>エントリー</h2>\n            <div class=\"container_naw\">\n                <ul class=\"list_outline\">\n                    <li><a href=\"../privacy/index.html\">プライバシーポリシー</a></li>\n                </ul>\n                <div class=\"entry_box\">\n                    <h3>採用についてのご応募・お問い合わせ</h3>\n                    <div class=\"entry_box_tel\">\n                        <p>お電話の場合はこちらから</p>\n                        <p class=\"entry_telno\"><span class=\"tel1\">045-622-9923</span></p>\n                    </div>\n                    <div class=\"entry_box_mail\">\n                        <p class=\"entry_mail\"><a href=\"../entry/index.html\"><span>応募フォームはこちらから</span></a></p>\n                    </div>\n                    <!-- /.entry_box -->\n                </div>\n\t\t\t\t<div class=\"ext_box2\">\n\t\t\t\t\t<h3>下記転職サイトにも、求人情報掲載中！</h3>\n\t\t\t\t  <dl>\n\t\t\t\t\t<dt>Indeed</dt>\n\t\t\t\t\t  <dd><a href=\"https://jp.indeed.com/求人?q=サンタクシー株式会社&l=神奈川県+横浜市+中区&redirected=1&vjk=081a7bf6b6359b0c\" target=\"_blank\" class=\"extsite\">サンタクシー株式会社の求人 - 神奈川県 横浜市 中区</a></dd>\n\t\t\t\t\t</dl>\n\t\t\t\t  <dl>\n\t\t\t\t\t<dt>Indeed</dt>\n\t\t\t\t\t  <dd>サンタクシー株式会社の<a href=\"https://jp.indeed.com/cmp/%E3%82%B5%E3%83%B3%E3%82%BF%E3%82%AF%E3%82%B7%E3%83%BC%E6%A0%AA%E5%BC%8F%E4%BC%9A%E7%A4%BE\" target=\"_blank\" class=\"extsite\">キャリア・企業情報</a></dd>\n\t\t\t\t\t</dl>\n\t\t\t\t\t<dl>\n\t\t\t\t\t  <dt>Indeed</dt>\n\t\t\t\t\t\t<dd>サンタクシー株式会社の<a href=\"https://jp.indeed.com/cmp/サンタクシー株式会社/about\" target=\"_blank\" class=\"extsite\">企業理念・福利厚生</a></dd>\n\t\t\t\t\t</dl>\n\t\t\t\t  <dl>\n\t\t\t\t\t<dt>転職道</dt>\n\t\t\t\t\t  <dd><a href=\"https://www.tenshokudou.com/detail/5108\" target=\"_blank\" class=\"extsite\">サンタクシー株式会社のタクシー求人情報</a></dd>\n\t\t\t\t\t</dl>\n\t\t\t\t\t<dl>\n\t\t\t\t\t  <dt>転職道</dt>\n\t\t\t\t\t\t<dd>サンタクシー株式会社の<a href=\"https://www.tenshokudou.com/detail/about/5108\" target=\"_blank\" class=\"extsite\">特徴</a>／<a href=\"https://www.tenshokudou.com/detail/profile/5108\" target=\"_blank\" class=\"extsite\">会社概要</a>／<a href=\"https://www.tenshokudou.com/detail/movie/5108\" target=\"_blank\" class=\"extsite\">動画</a>／<a href=\"https://www.tenshokudou.com/blog/company/5108\" target=\"_blank\" class=\"extsite\">ブログ</a></dd>\n\t\t\t\t\t</dl>\n\t\t\t\t\t<!-- /.ext_box -->\n\t\t\t\t</div>\n            </div>\n            <!-- /#area_news-->\n        </div>\n        \n        <p id=\"pageTop\"><a href=\"#\"><i class=\"fa fa-chevron-up\"></i></a></p>\n        <!--/#contents-->\n    </div>\n    <div id=\"fmenu\">\n        <div class=\"container\">\n\t\t\t<div class=\"fnavBox\">\n\t\t\t\t<h2><a href=\"../index.html\">ホーム</a></h2>\n\t\t\t\t<ul>\n\t\t\t\t\t<li><a href=\"../privacy/index.html\">プライバシーポリシー</a></li>\n\t\t\t\t</ul>\n\t\t\t</div>\n\t\