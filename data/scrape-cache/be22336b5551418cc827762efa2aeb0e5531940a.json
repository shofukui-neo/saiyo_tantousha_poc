{"url":"http://www.alsok-chiso.co.jp/recruit.html","html":"<!DOCTYPE HTML>\n<html lang=\"ja\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"initial-scale=1.0,width=device-width, user-scalable=yes\"/>\n<title>ALSOK千葉株式会社｜採用情報</title>\n<meta name=\"keywords\" content=\"ALSOK千葉株式会社,ALSOK,アルソック,警備会社,セキュリティシステム,ホームセキュリティ,放置車両確認機関,採用情報\" />\n<meta name=\"description\" content=\"24時間・365日、訓練された「安全のプロ」と「集中管理システム」のALSOK千葉株式会社の採用情報を掲載致します。\" />\n<meta name=\"format-detection\" content=\"telephone=no\"> \n\n<!-- 共用JavaScript -->\n<script type=\"text/javascript\" src=\"js/jquery.js\"></script>\n<script type=\"text/javascript\" src=\"js/option.js\"></script>\n\n<!-- PC・スマホ 読込CSS振分JavaScript -->\n<script type=\"text/javascript\" src=\"js/css-divide.js\"></script>\n\n<!-- スマホ 電話リンク -->\n<script type=\"text/javascript\" src=\"js/sp_tel.js\"></script>\n\n<!-- 共用CSS -->\n<link href=\"css/common.css\" rel=\"stylesheet\" type=\"text/css\" />\n<link href=\"css/print.css\" rel=\"stylesheet\" type=\"text/css\" media=\"print\">\n\n<!-- スマホ ドロップダウンメニュー用 JavaScript -->\n<script type=\"text/javascript\" src=\"js/dropdown_list.js\"></script> \n\n\n<!-- アナリティクス トラッキングコード -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=UA-169180497-1\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n  gtag('config', 'UA-169180497-1');\n</script>\n\n\n</head>\n\n<body>\n\n\n\n\t<!-- h1 -->\n\t<div class=\"h1_wrap\"><h1>ALSOK千葉株式会社｜常駐警備、空港保安検査業務、施設綜合管理、警備・防犯・安全対策のお手伝いで社会に貢献いたします。</h1></div>\n\n\n\n\t<!-- コンテンツ start -->\n\t<div class=\"cnt\">\n\n\n\n\t\t<!-- ロゴ（キャリア切替　【PC用】通常版・【スマホ用】簡易版） -->\n\t\t<div class=\"hd cmn_sp_hidden\"><a class=\"cmn_lnk_alpha\" href=\"index.html\"><img src=\"images/header/hd_logo.jpg\" width=\"420\" alt=\"ALSOK千葉株式会社\"></a></div>\n\t\t<div class=\"hd cmn_pc_hidden\"><a class=\"cmn_lnk_alpha\" href=\"index.html\"><img src=\"images/header/hd_logo_sp.jpg\" width=\"420\" alt=\"ALSOK千葉株式会社\"></a></div>\n\n\n\n\t\t<!-- 【PC用】グローバルメニュー -->\n\t\t<div class=\"gl\">\n\t\t\t<a class=\"lnk_gl01_wrap\" href=\"index.html\"><div class=\"lnk_gl01\">HOME</div></a>\n\t\t\t<a class=\"lnk_gl02_wrap\" href=\"service.html\"><div class=\"lnk_gl02\">業務の<br class=\"cmn_pc_hidden\">ご案内</div></a>\n\t\t\t<a class=\"lnk_gl03_wrap\" href=\"profile.html\"><div class=\"lnk_gl03\">企業<br class=\"cmn_pc_hidden\">情報</div></a>\n\t\t\t<a class=\"lnk_gl04_wrap\" href=\"recruit.html\"><div class=\"lnk_gl04\">採用<br class=\"cmn_pc_hidden\">情報</div></a>\n\t\t\t<a class=\"lnk_gl05_wrap\" href=\"news.html\"><div class=\"lnk_gl05\">新着<br class=\"cmn_pc_hidden\">情報</div></a>\n\t\t\t<br class=\"cmn_clearfix\">\n\t\t</div>\n\n\t\t<!-- 【スマホ用】プルダウン・スマホのみフロート解除 -->\n\t\t<div class=\"hd_gl_sp\"><script type=\"text/javascript\" src=\"js/spmenu_write.js\"></script></div>\n\t\t<br class=\"cmn_clearfix cmn_pc_hidden\">\n\n\n\n\n\t\t<!-- メイン画像 -->\n\t\t<div class=\"main_img\">\n\t\t\t<img src=\"images/recruit/recruit_main.jpg\" width=\"1000\" height=\"220\" alt=\"採用情報\">\n\t\t</div>\n\n\n\n\t\t<!-- パンくずリンク -->\n\t\t<div class=\"root\">\n\t\t\t<a href=\"index.html\">HOME</a>　＞　採用情報\n\t\t</div>\n\n\n\n\n\n\t\t<!-- 採用情報 PDFリンク -->\n\t\t<div class=\"cmn_mgn_b40\">\n\n\n\t\t\t<!-- リンクボックス -->\n\t\t\t<div class=\"recruit_pdfbox\">\n\t\t\t\t<div class=\"recruit_pdfbox_img\">\n\t\t\t\t\t<a class=\"cmn_lnk_alpha\" href=\"images/recruit/pdf/recruit01.pdf\" target=\"_blank\"><img src=\"images/recruit/pdf/recruit01.jpg\" width=\"210\"></a>\n\t\t\t\t</div>\n\t\t\t\t<div class=\"recruit_pdfbox_txt\">コーポレートガイド<br class=\"cmn_pc_hidden\">コミック<br>ALSOK×TCA</div>\n\t\t\t</div>\n\n\n\t\t\t<!-- リンクボックス -->\n\t\t\t<div class=\"recruit_pdfbox\">\n\t\t\t\t<div class=\"recruit_pdfbox_img\">\n\t\t\t\t\t<a class=\"cmn_lnk_alpha\" href=\"images/recruit/pdf/recruit02.pdf\" target=\"_blank\"><img src=\"images/recruit/pdf/recruit02.jpg\" width=\"210\"></a>\n\t\t\t\t</div>\n\t\t\t\t<div class=\"recruit_pdfbox_txt\">常駐警備<br>リクルートガイド</div>\n\t\t\t</div>\n\n\n\n\t\t\t<!-- スマホの時のみ、ここでフロート解除 -->\n\t\t\t<br class=\"cmn_clearfix cmn_pc_hidden\">\n\n\n\n\t\t\t<!-- リンクボックス -->\n\t\t\t<div class=\"recruit_pdfbox\">\n\t\t\t\t<div class=\"recruit_pdfbox_img\">\n\t\t\t\t\t<a class=\"cmn_lnk_alpha\" href=\"images/recruit/pdf/recruit03.pdf\" target=\"_blank\"><img src=\"images/recruit/pdf/recruit03.jpg\" width=\"210\"></a>\n\t\t\t\t</div>\n\t\t\t\t<div class=\"recruit_pdfbox_txt\">空港保安検査業務<br>リクルートガイド</div>\n\t\t\t</div>\n\n\n\t\t\t<!-- リンクボックス -->\n\t\t\t<div class=\"recruit_pdfbox\">\n\t\t\t\t<div class=\"recruit_pdfbox_img\">\n\t\t\t\t\t<a class=\"cmn_lnk_alpha\" href=\"images/recruit/pdf/recruit04.pdf\" target=\"_blank\"><img src=\"images/recruit/pdf/recruit04.jpg\" width=\"210\"></a>\n\t\t\t\t</div>\n\t\t\t\t<div class=\"recruit_pdfbox_txt\">千葉テレビ<br>「ビジネストレンドスペシャル」</div>\n\t\t\t</div>\n\n\n\n\t\t\t<!-- スマホの時のみ、ここでフロート解除 -->\n\t\t\t<br class=\"cmn_clearfix cmn_pc_hidden\">\n\n\n\n\t\t\t<!-- リンクボックス -->\n\t\t\t<div class=\"recruit_pdfbox\">\n\t\t\t\t<div class=\"recruit_pdfbox_img\">\n\t\t\t\t\t<a class=\"cmn_lnk_alpha\" href=\"images/recruit/pdf/recruit05.pdf\" target=\"_blank\"><img src=\"images/recruit/pdf/recruit05.jpg\" width=\"210\"></a>\n\t\t\t\t</div>\n\t\t\t\t<div class=\"recruit_pdfbox_txt\">社員寮制度</div>\n\t\t\t</div>\n\n\n\t\t\t<!-- リンクボックス -->\n\t\t\t<div class=\"recruit_pdfbox\">\n\t\t\t\t<div class=\"recruit_pdfbox_img\">\n\t\t\t\t\t<a class=\"cmn_lnk_alpha\" href=\"images/recruit/pdf/recruit06.pdf\" target=\"_blank\"><img src=\"images/recruit/pdf/recruit06.jpg\" width=\"210\"></a>\n\t\t\t\t</div>\n\t\t\t\t<div class=\"recruit_pdfbox_txt\">奨学金返還制度</div>\n\t\t\t</div>\n\n\n\n\t\t\t<!-- スマホの時のみ、ここでフロート解除 -->\n\t\t\t<br class=\"cmn_clearfix cmn_pc_hidden\">\n\n\n\n\t\t\t<!-- リンクボックス -->\n\t\t\t<div class=\"recruit_pdfbox\">\n\t\t\t\t<div class=\"recruit_pdfbox_img\">\n\t\t\t\t\t<a class=\"cmn_lnk_alpha\" href=\"images/recruit/pdf/recruit07.pdf\" target=\"_blank\"><img src=\"images/recruit/pdf/recruit07.jpg\" width=\"210\"></a>\n\t\t\t\t</div>\n\t\t\t\t<div class=\"recruit_pdfbox_txt\">警備業の魅力紹介</div>\n\t\t\t</div>\n\n\n\n\t\t\t<!-- フロート解除 -->\n\t\t\t<br class=\"cmn_clearfix\">\n\n\n\t\t</div>\n\n\n\n\n\n\t\t<!-- リンクタブ -->\n\t\t<div class=\"cmn_mgn_b40\">\n\n\n\t\t\t<!-- 左 -->\n\t\t\t<span class=\"tab_left_active\">採用情報</span>\n\n\t\t\t<!-- 右 -->\n\t\t\t<a class=\"tab_right\" href=\"recruit_info.html\">募集要項</a>\n\n\t\t\t<!-- フロート解除 -->\n\t\t\t<br class=\"cmn_clearfix\">\n\n\t\t</div>\n\n\n\n\n\t\t<!-- テキスト -->\n\t\t<div class=\"cmn_mgn_b50\">\n一人ひとりが専門的知識・技術を持ち、チームワークでプロとしての質の高い警備サービスをご提供しています。<br class=\"cmn_sp_hidden\">\n研修・教育システムについても、業界随一を自負しており、また、最新の設備が整った新しい研修所が2016年4月にオープン。<br class=\"cmn_sp_hidden\">\n安全安心な地域社会の実現をめざして、一緒に頑張りませんか？\n\t\t</div>\n\n\n\n\n\t\t<!-- コンテンツ 背景付 タイトル -->\n\t\t<div class=\"cnt_back_ttl cmn_mgn_b30\" id=\"message\">採用担当者からのメッセージ</div>\n\n\n\t\t<!-- ボックス start -->\n\t\t<div class=\"cmn_mgn_b30\">\n\n\t\t\t<!-- ボックスタイトル -->\n\t\t\t<div class=\"recruit_box_ttl\">人材こそが財産。<br class=\"cmn_sp_hidden\">当社で新しいチャレンジをしてみませんか。</div>\n\n\t\t\t<!-- テキスト -->\n\t\t\t<div class=\"cmn_mgn_b30\">\n当社は警備業界のリーディングカンパニーである<br>\nALSOKのグループ会社として<br>\n昭和50年2月10日に千葉県に誕生して以来、常に質の高い警備サービスを提供しています。<br>\n施設警備をはじめ各種イベント警備、放置車両確認事務（駐車監視業務）等の業務を展開しつつ、<br>\nまた、社会のニーズに応えるべく新たな業務にも取り組んでいます。<br>\n安全安心を守る警備業にあっては人材こそ財産であることから<br>\nALSOKグループ全体として教育訓練に力を入れており、<br>\n豊富な研修プログラムや最新の研修設備を完備し<br>\n必要な知識、技能が習得できるシステムが構築されています。<br>\nまた、階級昇任制度や社員持株制度、グループ保険、ALSOK提携保養施設の利用など<br>\n福利厚生面も充実。社員間の交流の場として社員懇親会による社内旅行や様々な懇親会行事なども実施。<br>\nお客様の安全安心の確保を通じて社会に貢献できるやり甲斐のある仕事です。<br>\n当社で新しいチャレンジをしてみませんか。\n\t\t\t</div>\n\n\n\t\t</div>\n\t\t<!-- ボックス end -->\n\n\n\n\n\n\n\n\t\t<!-- コンテンツ 背景付 タイトル -->\n\t\t<div class=\"cnt_back_ttl cmn_mgn_b30\" id=\"ikusei\">人材教育</div>\n\n\n\t\t<!-- 左右ボックス start -->\n\t\t<div class=\"cmn_mgn_b0\">\n\n\t\t\t<!-- 左 -->\n\t\t\t<div class=\"recruit_box_left\">\n\n\t\t\t\t<!-- ボックスタイトル -->\n\t\t\t\t<div class=\"recruit_box_ttl\">企業活動の最も重要な源泉は<br class=\"cmn_sp_hidden\">「人材」であると考え、<br class=\"cmn_sp_hidden\">人材育成に努めています。</div>\n\n\t\t\t\t<!-- テキスト -->\n\t\t\t\t<div class=\"cmn_mgn_b30\">\n\t\t\t\t\t<div class=\"cmn_clr_blue01 cmn_wgt_bld\">ALSOK千葉の人材教育</div>\n\t\t\t\t\t<div class=\"cmn_mgn_b0\">\n当社では、企業活動の最も重要な源泉は「人材」であるとの基本的な考え方に基づき、企業人にふさわしい優れた人材、競争力のある人材を育成するための教育に力を入れています。当社は、社員一人ひとりが人として守り行うべき道を守ることで企業としての倫理感を高め、社徳の高い会社として他の追随を許さない真のリーディングカンパニーになるべく、日々努力を続けています。\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\n\n\t\t\t\t<!-- テキスト -->\n\t\t\t\t<div class=\"cmn_mgn_b30\">\n\t\t\t\t\t<div class=\"cmn_clr_blue01 cmn_wgt_bld\">次世代育成支援対策</div>\n\t\t\t\t\t<div class=\"cmn_mgn_b0\">\nALSOK千葉株式会社は、次の世代を担う子どもたちが健やかに生まれ育つ環境の整備を推進するために、次の行動計画に取り組んでまいります。\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\n\n\t\t\t\t<!-- テキスト -->\n\t\t\t\t<div class=\"cmn_mgn_b30\">\n\t\t\t\t\t<div class=\"cmn_clr_blue01 cmn_wgt_bld\">次世代育成支援対策推進法に基づく行動計画（7回目）</div>\n\n\t\t\t\t\t<div class=\"cmn_mgn_b30\">\n社員が仕事と子育てを両立させることができ、社員全員が働きやすい環境を作ることによって、すべての社員がその能力を十分に発揮できるようにするため、次のように行動計画を策定する。\n\t\t\t\t\t</div>\n\n\t\t\t\t\t<div class=\"cmn_mgn_b30 cmn_li7\">１．計画期間　令和５年6月1日～令和８年5月31日までの3年間</div>\n\t\t\t\t\t<div class=\"cmn_mgn_b30 cmn_li2\">２．内容</div>\n\n\t\t\t\t\t<div class=\"cmn_mgn_b30\">\n\t\t\t\t\t\t<ul class=\"cmn_ul2\">\n\t\t\t\t\t\t\t<li class=\"cmn_li4\">目標１：子どもの出生時における育児休業や短時間勤務等の取得促進を図り、取得率向上をめざす。</li>\n\t\t\t\t\t\t</ul>\n\t\t\t\t\t\t<ul class=\"cmn_ul2\">\n\t\t\t\t\t\t\t<li class=\"cmn_li0\">＜対策＞</li>\n\t\t\t\t\t\t</ul>\n\t\t\t\t\t\t<ul class=\"cmn_ul3\">\n\t\t\t\t\t\t\t<li class=\"cmn_li10\">・令和５年　６月～　男性の育児休業取得促進を図るために、対象者へ取得奨励の案内を実施する</li>\n\t\t\t\t\t\t\t<li class=\"cmn_li10\">・令和５年　８月～　各配置先における育児短時間勤務の体制づくりを検討する</li>\n\t\t\t\t\t\t  <li class=\"cmn_li10\">・令和５年１０月～　管理職向けに取得者の体験等を周知する機会を検討する</li>\n\t\t\t\t\t\t</ul>\n\t\t\t\t\t</div>\n\n\n\t\t\t\t\t<div class=\"cmn_mgn_b30\">\n\t\t\t\t\t\t<ul class=\"cmn_ul2\">\n\t\t\t\t\t\t\t<li class=\"cmn_li4\">目標２：年次有給休暇の取得促進を図り、年間の平均取得日数を１日以上増加させる。</li>\n\t\t\t\t\t\t</ul>\n\t\t\t\t\t\t<ul class=\"cmn_ul2\">\n\t\t\t\t\t\t\t<li class=\"cmn_li0\">＜対策＞</li>\n\t\t\t\t\t\t</ul>\n\t\t\t\t\t\t<ul class=\"cmn_ul3\">\n\t\t\t\t\t\t\t<li class=\"cmn_li10\">・令和５年　６月～　取得日数の少ない社員に対する取得推奨の案内を継続して実施する</li>\n\t\t\t\t\t\t\t<li class=\"cmn_li10\">・令和５年　８月～　現状把握のために、職場風土等に関するアンケート（意識調査）を実施する</li>\n\t\t\t\t\t\t\t<li class=\"cmn_li10\">・令和６年　３月～　取得奨励を図るために、毎年度有給休暇取得率を集計し開示する</li>\n\t\t\t\t\t\t</ul>\n\t\t\t\t\t</div>\n\n\n\t\t\t\t\t<div class=\"cmn_mgn_b30 cmn_aln_r\">\n\t\t\t\t\t\t以上\n\t\t\t\t\t</div>\n\n\t\t\t\t\t<div class=\"cmn_mgn_b0 cmn_li1\">※次世代育成支援対策推進法とは、次の世代を担う子どもたちが健やかに生まれ育つ環境をつくるために、企業等による仕事と子育ての両立支援の取り組みを促進することを目的とした法律です。</div>\n\t\t\t\t</div>\n\n\n\t\t\t\t<!-- テキスト -->\n\t\t\t\t<div class=\"cmn_mgn_b30\">\n\t\t\t\t\t<div class=\"cmn_clr_blue01 cmn_wgt_bld\">資格</div>\n\t\t\t\t\t<div class=\"cmn_mgn_b0 cmn_li0\">様々な分野で有資格者が活躍しています。</div>\n\t\t\t\t\t<div class=\"cmn_mgn_b0 cmn_li1\">○警備員指導教育責任者</div>\n\t\t\t\t\t<div class=\"cmn_mgn_b0 cmn_li1\">○施設警備業務１・２級</div>\n\t\t\t\t\t<div class=\"cmn_mgn_b0 cmn_li1\">○交通誘導警備業務１・２級</div>\n\t\t\t\t\t<div class=\"cmn_mgn_b0 cmn_li1\">○雑踏警備業務１・２級</div>\n\t\t\t\t\t<div class=\"cmn_mgn_b0 cmn_li1\">○貴重品運搬警備業務１・２級</div>\n\t\t\t\t\t<div class=\"cmn_mgn_b0 cmn_li1\">○防災センター要員</div>\n\t\t\t\t\t<div class=\"cmn_mgn_b0 cmn_li1\">○防火管理者</div>\n\t\t\t\t\t<div class=\"cmn_mgn_b0 cmn_li1\">○上級・普通救命講習</div>\n\t\t\t\t\t<div class=\"cmn_mgn_b0 cmn_li1\">○応急手当普及員</div>\n\t\t\t\t\t<div class=\"cmn_mgn_b0 cmn_li1\">○セキュリティ・プランナー　他</div>\n\t\t\t\t</div>\n\n\t\t\t</div>\n\n\n\n\t\t\t<!-- 右 -->\n\t\t\t<div class=\"recruit_box_rignt\">\n\n\t\t\t\t<!-- テキスト -->\n\t\t\t\t<div class=\"cmn_mgn_b30\">\n\t\t\t\t\t<div class=\"cmn_clr_blue01 cmn_wgt_bld\">教育プログラム</div>\n\t\t\t\t\t<div class=\"cmn_mgn_b0\">\n警備業法で定められた法定教育に加え、より高度な警備提供と企業人としてふさわしい人材の育成を目指し、新入社員教育から部門別、階級別、管理者向けなどの多岐にわたる教育を実施しています。いずれの教育においても、創業以来の基本的な精神の理解・浸透を図り、実践されるよう教育体系を構築しています。\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\n\n\t\t\t\t<!-- 画像 -->\n\t\t\t\t<div class=\"cmn_mgn_b30\"><img src=\"images/recruit/recruit_kyouiku_program.jpg\" width=\"480\" height=\"329\" alt=\"教育プログラム\"></div>\n\n\n\t\t\t\t<!-- テキスト -->\n\t\t\t\t<div class=\"cmn_mgn_b30\">\n\t\t\t\t\t<div class=\"cmn_clr_blue01 cmn_wgt_bld\">昇任・資格制度</div>\n\t\t\t\t\t<div class=\"cmn_mgn_b0\">昇任審査には公平を重視して昇任試験制度を導入しています。</div>\n\t\t\t\t</div>\n\n\n\t\t\t\t<!-- 画像 -->\n\t\t\t\t<div class=\"cmn_mgn_b30\"><img src=\"images/recruit/recruit_shikaku_seido.jpg\" width=\"480\" height=\"307\" alt=\"昇任・資格制度\"></div>\n\t\t\t\t<div class=\"cmn_mgn_b30\"><img src=\"images/recruit/recruit_kyouiku_fuukei01.jpg\" width=\"480\" height=\"320\" alt=\"人材教育\"></div>\n\t\t\t\t<div class=\"cmn_mgn_b50\"><img src=\"images/recruit/recruit_kyouiku_fuukei02.jpg\" width=\"480\" height=\"320\" alt=\"人材教育\"></div>\n\n\n\t\t\t</div>\n\n\n\n\t\t\t<!-- フロート解除 -->\n\t\t\t<br class=\"cmn_clearfix\">\n\n\t\t</div>\n\t\t<!-- 左右ボックス end -->\n\n\n\n\n\n\n\n\n\n\n\t\t<!-- コンテンツ 背景付 タイトル -->\n\t\t<div class=\"cnt_back_ttl cmn_mgn_b0\" id=\"senpai\">先輩の声</div>\n\n\n\t\t<!-- 採用情報ボックス 本体 start -->\n\t\t<div class=\"recruit_voice_box_body\">\n\n\t\t\t<!-- ボックスセット start -->\n\t\t\t<div class=\"recruit_voice_box\">\n\t\t\t\n\t\t\t\t<!-- 右 -->\n\t\t\t\t<div class=\"recruit_voice_box_right\"><img src=\"images/recruit/recruit_senpai_voice_ss.jpg\" width=\"260\" height=\"200\" alt=\"大型商業施設勤務　K.A\"></div>\n\n\t\t\t\t<!-- 左 -->\n\t\t\t\t<div class=\"recruit_voice_box_left\">\n\t\t\t\t\t<div class=\"recruit_box_left_ttl\">大型商業施設勤務　S.S</div>\n\t\t\t\t\t<div class=\"recruit_box_left_txt\">\nあっという間の１年でした。この１年で私の一挙手一投足が、お客様は元より、警備隊をはじめ会社全体に影響するということを学びました。責任ある仕事を任せられているというプレッシャーと日々戦いながら、やりがいのある仕事に就くことができたことを今は嬉しく思っています。これからも笑顔を絶やさず、立派な警備を提供していきます。\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\n\t\t\t\t<!-- フロート解除 -->\n\t\t\t\t<br class=\"cmn_clearfix\">\n\t\t\t</div>\n\t\t\t<!-- ボックスセット end -->\n\n\n\n\t\t\t<!-- ボックスセット start -->\n\t\t\t<div class=\"recruit_voice_box\">\n\n\t\t\t\t<!-- 右 -->\n\t\t\t\t<div class=\"recruit_voice_box_right\"><img src=\"images/recruit/recruit_senpai_voice_kr.jpg\" width=\"260\" height=\"200\" alt=\"大型商業施設勤務　F.D\"></div>\n\n\t\t\t\t<!-- 左 -->\n\t\t\t\t<div class=\"recruit_voice_box_left\">\n\t\t\t\t\t<div class=\"recruit_box_left_ttl\">大型商業施設勤務　K.R</div>\n\t\t\t\t\t<div class=\"recruit_box_left_txt\">\n私がこの１年間で一番感じた事は、学生の時に想像していた警備という仕事が、全然違ったことです。私自身、警備とは交通誘導をするようなイメージしかありませんでした。しかし、業務に就いてみると、受付では電話や来客者の応対などを行い、また、警備室ではモニターの監視など、想像していた警備の内容とは違いました。そのような事もあり、最初は覚える事がたくさんあり、苦労もありましたが、先輩方の支えもあり、一歩一歩ですが成長しています。今年は今迄とは違い、入社してくる後輩に仕事を教えなければならない立場になります。より一層、謙虚な気持ちで取り組んでいこうと思います。\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\n\t\t\t\t<!-- フロート解除 -->\n\t\t\t\t<br class=\"cmn_clearfix\">\n\t\t\t</div>\n\t\t\t<!-- ボックスセット end -->\n\n\n\t\t\t<!-- ボックスセット start -->\n\t\t\t<div class=\"recruit_voice_box\">\n\n\t\t\t\t<!-- 右 -->\n\t\t\t\t<div class=\"recruit_voice_box_right\"><img src=\"images/recruit/recruit_senpai_voice_kt.jpg\" width=\"260\" height=\"200\" alt=\"複合オフィスビル勤務　H.F\"></div>\n\n\t\t\t\t<!-- 左 -->\n\t\t\t\t<div class=\"recruit_voice_box_left\">\n\t\t\t\t\t<div class=\"recruit_box_left_ttl\">本社総務部　K.T</div>\n\t\t\t\t\t<div class=\"recruit_box_left_txt\">\n私は現在本社総務部で給与管理を担当しています。入社当初は常駐警備隊に配属されていました。配属先では業務に関することだけでなく、社会人として必要なビジネスマナーや、何事にも前向きに取り組むことの大切さを学びました。これからも仕事にプライベートに常に前向きに取り組み、まわりの方々に成長した姿を見せられるよう頑張ります。\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\n\t\t\t\t<!-- フロート解除 -->\n\t\t\t\t<br class=\"cmn_clearfix\">\n\t\t\t</div>\n\t\t\t<!-- ボックスセット end -->\n\n\t\t</div>\n\t\t<!-- 採用情報ボックス 本体 end -->\n\n\n\n\n\n\n\n\t\t<!-- 下 破線ボーダ ボックス -->\n\t\t<div class=\"cmn_bdr_btm_dsh30 cmn_mgn_b0\">\n\n\t\t\t<!-- 募集要項 リンク -->\n\t\t\t<div class=\"cmn_aln_c sp_scale50\">\n\t\t\t\t<a class=\"cmn_lnk_alpha\" href=\"recruit_info.html\"><img src=\"images/recruit/btn_recruit_datail.jpg\" width=\"364\" height=\"80\" alt=\"募集要項はこちら\"></a>\n\t\t\t</div>\n\n\t\t</div>\n\n\n\n\t\t<!-- お問い合わせ情報 -->\n\t\t<!-- 電話情報ボックス start -->\n\t\t<div class=\"tel_info print_pagebreak\">\n\n\t\t\t<!-- 電話情報ボックス 1段目 -->\n\t\t\t<div class=\"tel_info01\">\n\t\t\t\t<img src=\"images/footer/tel_mark.png\" width=\"66\" height=\"66\" alt=\"お問い合わせ\"/>\n\t\t\t\t<span class=\"tel_info01_name cmn_clr_blue01\">&nbsp;お問い合わせ</span>\n\t\t\t</div>\n\n\t\t\t<!-- 電話情報ボックス 2段目 -->\n\t\t\t<div class=\"tel_info02\">\n\t\t\t  <span class=\"tel_info02_name cmn_clr_blue01\">代表（営業部）／採用（総務部採用課）</span>\n\t\t\t</div>\n\n\t\t\t<!-- 電話情報ボックス 3段目 -->\n\t\t  <div class=\"tel_info03\">\n\t\t\t\t<span class=\"tel_info03_name cmn_clr_blue01\">TEL. </span>\n\t\t\t\t<span class=\"tel_info03_tel cmn_clr_blue01\">043-275-7575</span>\n\t\t  </div>\n\n\t\t\t<!-- 電話情報ボックス 4段目 -->\n\t\t\t<div class=\"tel_info04\">\n\t\t\t  <span class=\"tel_info04_name cmn_clr_red01\">お問い合わせの対応品質向上のため、<br class=\"cmn_pc_hidden\">通話を録音させていただきます</span>\n\t\t\t</div>\n\n\t\t\t<!-- 電話情報ボックス 5段目 -->\n\t\t\t<div class=\"tel_info05\">\n\t\t\t  <span class=\"tel_info05_name cmn_clr_blue01\">受付時間／月〜金曜日（祝祭日以外）<br class=\"cmn_pc_hidden\">9：00−17：00</span>\n\t\t\t</div>\n\n\t\t\t<br class=\"cmn_clearfix\">\n\t\t</div>\n\t\t<!-- 電話情報ボックス end -->\n\t\t\n\t\n\t\t\n\n\n\t\t\n\t</div>\n\t<!-- コンテンツ end -->\n\n\n\n\n\n\n\t<!-- フッタメニュー 外殻 start -->\n\t<div class=\"ft_menu_wrap\">\n\n\t\t<!-- フッタメニュー 本体 start -->\n\t\t<div class=\"ft_menu\">\n\n\t\t\t<!-- 1列目 -->\n\t\t\t<div class=\"ft_menu_01\">\n\t\t\t\t<a class=\"ft_menu_main\" href=\"index.html\">HOME</a>\n\t\t\t\t<a class=\"ft_menu_sub\" href=\"news.html\">新着情報</a>\n\t\t\t</div>\n\n\n\t\t\t<!-- 2列目 -->\n\t\t\t<div class=\"ft_menu_02\">\n\t\t\t\t<a class=\"ft_menu_main\" href=\"service.html\">業務のご案内</a>\n\t\t\t\t<a class=\"ft_menu_sub\" href=\"service01.html\">常駐警備</a>\n\t\t\t\t<a class=\"ft_menu_sub\" href=\"service06.html\">空港保安検査業務</a>\n\t\t\t\t<a class=\"ft_menu_sub\" href=\"service02.html#event\">イベント警備</a>\n\t\t\t\t<a class=\"ft_menu_sub\" href=\"service02.html#vip\">VIP身辺警備</a>\n\t\t\t\t<a class=\"ft_menu_sub\" href=\"service03.html#kanri\">綜合管理</a>\n\t\t\t\t<a class=\"ft_menu_sub\" href=\"service03.html#goods\">防犯・防災商品</a>\n\t\t\t\t<