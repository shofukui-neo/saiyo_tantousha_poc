terview/ob01/\">総務部</a></li>\r\n\t\t\n\t\t\t\t\t\t<li class=\"\"><a href=\"https://gunseisya.co.jp/recruit/interview/ob02/\">イノベーション事業部</a></li>\r\n\t\t\t\t\t</ul>\n\t\t\t\t</li>\r\n\t\t\n\t\t\t\t<li class=\"\"><a href=\"https://gunseisya.co.jp/recruit/ecology/\">数字でみる群成舎</a>\t\t\t\t</li>\r\n\t\t\n\t\t\t\t<li class=\"\"><a href=\"#\">新卒採用</a>\n\t\t\t\t\t<ul class=\"sub-menu\">\n\t\t\t\t\t\t<li class=\"\"><a href=\"https://gunseisya.co.jp/recruit/support/\">福利厚生</a></li>\r\n\t\t\n\t\t\t\t\t\t<li class=\"\"><a href=\"https://gunseisya.co.jp/recruit/education/\">教育体制/キャリア</a></li>\r\n\t\t\n\t\t\t\t\t\t<li class=\"\"><a href=\"https://gunseisya.co.jp/recruit/environment/\">働く環境</a></li>\r\n\t\t\n\t\t\t\t\t\t<li class=\"\"><a href=\"https://gunseisya.co.jp/recruit/message/\">採用メッセージ</a></li>\r\n\t\t\n\t\t\t\t\t\t<li class=\"\"><a href=\"https://gunseisya.co.jp/recruit/requirements/\">募集要項</a></li>\r\n\t\t\n\t\t\t\t\t\t<li class=\"\"><a href=\"https://gunseisya.co.jp/recruit/entry/\">応募フォーム</a></li>\r\n\t\t\t\t\t</ul>\n\t\t\t\t</li>\r\n\t\t\n\t\t\t\t<li class=\"\"><a href=\"#\">キャリア採用</a>\n\t\t\t\t\t<ul class=\"sub-menu\">\n\t\t\t\t\t\t<li class=\"\"><a href=\"https://gunseisya.co.jp/recruit/career/\">キャリアボイス</a></li>\r\n\t\t\n\t\t\t\t\t\t<li class=\"\"><a href=\"https://gunseisya.co.jp/recruit/support/\">福利厚生</a></li>\r\n\t\t\n\t\t\t\t\t\t<li class=\"\"><a href=\"https://gunseisya.co.jp/recruit/education/\">教育研修/キャリア</a></li>\r\n\t\t\n\t\t\t\t\t\t<li class=\"\"><a href=\"https://gunseisya.co.jp/recruit/environment/\">働く環境</a></li>\r\n\t\t\n\t\t\t\t\t\t<li class=\"\"><a href=\"https://gunseisya.co.jp/recruit/message/\">採用メッセージ</a></li>\r\n\t\t\n\t\t\t\t\t\t<li class=\"\"><a href=\"https://gunseisya.co.jp/recruit/requirements/\">募集要項</a></li>\r\n\t\t\n\t\t\t\t\t\t<li class=\"\"><a href=\"https://gunseisya.co.jp/recruit/entry/\">応募フォーム</a></li>\r\n\t\t\t\t\t</ul>\n\t\t\t\t</li>\r\n\t\t</ul>\t</nav>\r\n\t<a id=\"nav-switch\" href=\"#\" class=\"l-header__btn1 sp\"><div class=\"inbox\"><span class=\"nav-switch-line01\"></span><span class=\"nav-switch-line02\"></span><span class=\"nav-switch-line03\"></span></div></a>\r\n</header>\r\n\r\n<main id=\"main\" class=\"l-main\">\t\r\n\r\n<div class=\"home-main\">\r\n<div class=\"home-main_item\"></div>\r\n<a href=\"field/\" class=\"btn01 pc\"><span>私たちのフィールド</span></a>\r\n<div class=\"textbox\">\r\n\r\n<img src=\"img/img-home_main01.png\" alt=\"KEEP NATURE NATURE\" />\r\n<p>街の環境をデザインする会社</p>\r\n\r\n<section class=\"home-main_news\">\r\n<h2 class=\"title en\">&#8211; NEWS &#8211;</h2>\r\n<ul><li><a href=\"https://gunseisya.co.jp/recruit/news/473/\"><time datetime=\"2025-03-04 16:27:38\">2025.03.04</time><h3>【2026年卒】採用会社説明会開催のお知らせ</h3></a></li><li><a href=\"https://gunseisya.co.jp/recruit/news/249/\"><time datetime=\"2019-12-25 10:40:26\">2019.12.25</time><h3>採用Webサイトオープン！</h3></a></li></ul>\r\n</section></div>\r\n</div>\r\n<section class=\"home-about\">\r\n<div class=\"inner01\">\r\n<div class=\"imgbox\"><img src=\"/recruit/uploads/2024/02/img-home_about01_1.png\" srcset=\"/recruit/uploads/2024/02/img-home_about01_1.png 1x,/recruit/uploads/2024/02/img-home_about01_1-2x.png 2x\" alt=\"\" /></div>\r\n<div class=\"textbox\">\r\n<div class=\"home-title n1\">\r\n\r\n<img src=\"img/h-home01.png\" srcset=\"img/h-home01.png 1x,img/h-home01@2x.png 2x\" alt=\"\" />\r\n<h2>私たちについて</h2>\r\n</div>\r\n<p class=\"catch\"><span class=\"grad1\">街の環境をデザインする会社</span><span class=\"grad1\">“自然をまもり”笑顔をつなぐ</span></p>\r\n美しい地球で、すべての人が安心して暮らし、笑顔の絶えない持続可能な社会を創る。そのために、未来の世代に誇れる街の環境をデザインする。「“自然をまもり”笑顔をつなぐ」それが群成舎の使命です。\r\n<ul class=\"l-row30 sp-colbox0\">\r\n \t<li class=\"w40\"><a href=\"about/\" class=\"btn01 max100\"><span>群成舎について</span></a></li>\r\n \t<li class=\"w40\"><a href=\"about/strength/\" class=\"btn01 max100\"><span>群成舎の強み</span></a></li>\r\n</ul>\r\n</div>\r\n</div>\r\n</section><section class=\"home-interview\">\r\n<div class=\"inner02\">\r\n<div class=\"home-title n2 w40 sp-w80\">\r\n\r\n<img src=\"img/h-home02.png\" srcset=\"img/h-home02.png 1x,img/h-home02@2x.png 2x\" alt=\"\" />\r\n<h2>社員インタビュー</h2>\r\n</div>\r\n<div class=\"interview/ob01/\">\r\n<ul class=\"home-interview_list pc-contC\">\r\n \t<li><a href=\"interview/ob01/\">\r\n<img src=\"uploads/2024/02/img-home_interview01.png\" alt=\"\" />\r\n<div class=\"textbox\">\r\n<div>\r\n<h3 class=\"name\"><span class=\"marker01\">黛 汰夢</span></h3>\r\n<p class=\"disc\">総務部<br>\r\n2022年入社<br>\r\n経営学部</p>\r\n\r\n</div>\r\n</div></a></li>\r\n \t<li><a href=\"interview/ob02/\">\r\n<img src=\"uploads/2024/02/img-home_interview02.png\" alt=\"\" />\r\n<div class=\"textbox\">\r\n<div>\r\n<h3 class=\"name\"><span class=\"marker01\">塚本 早稀</span></h3>\r\n<p class=\"disc\">イノベーション事業部<br>\r\n2023年入社<br>\r\n地域政策学部 地域づくり学科</p>\r\n\r\n</div>\r\n</div></a></li>\r\n</ul>\r\n</div>\r\n</div>\r\n<div class=\"home-accent img1\"><img src=\"img/img-home_accent1.png\" alt=\"\" /></div>\r\n<div class=\"home-accent img2\"><img src=\"img/img-home_accent2.png\" alt=\"\" /></div>\r\n<div class=\"home-accent img3\"><img src=\"img/img-home_accent3.png\" alt=\"\" /></div>\r\n<div class=\"home-accent img4\"><img src=\"img/img-home_accent4.png\" alt=\"\" /></div>\r\n<div class=\"home-accent img6\"><img src=\"img/img-home_accent6.png\" alt=\"\" /></div>\r\n<div class=\"home-accent img7\"><img src=\"img/img-home_accent7.png\" alt=\"\" /></div>\r\n</section>\r\n<section class=\"home-career cf\">\r\n<div class=\"inner02\">\r\n<div class=\"home-career_textbox\">\r\n<div class=\"home-title relativeBox\">\r\n<img src=\"img/h-home_career01.png\" srcset=\"img/h-home_career01.png 1x,img/h-home_career01@2x.png 2x\" alt=\"\">\r\n<h2>キャリア採用</h2>\r\n</div>\r\n<p class=\"home-career_catch\"><span class=\"grad2\">あなたが大切にしたいものが、</span><br><span class=\"grad2\">群成舎にあるかもしれません </span></p>\r\n</div>\r\n<ul class=\"home-career_list\">\r\n<li>\r\n<a href=\"career/ob01/\">\r\n<img src=\"img/img-home_career01.jpg\" alt=\"\">\r\n<div class=\"textbox\">\r\n<div>\r\n<h3 class=\"name\"><span class=\"marker01\">石田 環</span></h3>\r\n<p class=\"disc\">イノベーション事業部<br>2019年8月入社<br></p>\r\n</div>\r\n</div>\r\n</a>\r\n</li>\r\n<li>\r\n<a href=\"career/ob02/\">\r\n<img src=\"uploads/2024/02/img-home_career02.jpg\" alt=\"\">\r\n<div class=\"textbox\">\r\n<div>\r\n<h3 class=\"name\"><span class=\"marker01\">細野 辰徳</span></h3>\r\n<p class=\"disc\">環境整備部<br>2015年4月入社<br></p>\r\n</div>\r\n</div>\r\n</a>\r\n</li>\r\n</ul>\r\n<a href=\"career/\" class=\"btn01 max100 pc-fR \"><span>キャリア採用メッセージを見る</span></a>\r\n</div>\r\n<div class=\"home-accent img5\"><img src=\"img/img-home_accent5.png\" alt=\"\"></div>\r\n<div class=\"home-accent img8\"><img src=\"img/img-home_accent17.png\" alt=\"\"></div>\r\n</section>\r\n<section class=\"home-special\">\r\n<div class=\"inner01\">\r\n<div class=\"home-title n3 tC\">\r\n\r\n<img src=\"img/h-home03.png\" srcset=\"img/h-home03.png 1x,img/h-home03@2x.png 2x\" alt=\"\" />\r\n<h2>データと働く環境について</h2>\r\n</div>\r\n<ul class=\"l-row50 sp-colbox4\">\r\n \t<li class=\"w50\"><a href=\"ecology/\">\r\n<div class=\"card01\">\r\n<div class=\"imgbox\"><img src=\"img/img-home_special01.jpg\" srcset=\"img/img-home_special01.jpg 1x,img/img-home_special01@2x.jpg 2x\" alt=\"\" /></div>\r\n<h3 class=\"title\">数字で学ぶ群成舎</h3>\r\n</div>\r\n<p class=\"mt1\">環境を守るエコな企業である群成舎。\r\n弊社の特徴的なエコ数値をご覧ください。</p>\r\n</a></li>\r\n \t<li class=\"w50\"><a href=\"environment/\">\r\n<div class=\"card01\">\r\n<div class=\"imgbox\"><img src=\"uploads/2024/02/img-home_special02.jpg\" srcset=\"uploads/2024/02/img-home_special02.jpg 1x,uploads/2024/02/img-home_special02-2x.jpg 2x\" alt=\"\" /></div>\r\n<h3 class=\"title\">会社環境</h3>\r\n</div>\r\n<p class=\"mt1\">ワンフロアに全員が集結。部署を超えた情報共有と連携により「チーム群成舎」がさらにパワーアップ。</p>\r\n</a></li>\r\n</ul>\r\n</div>\r\n</section><section class=\"home-working\">\r\n<div class=\"inner01\">\r\n<div class=\"home-title n5 tC\">\r\n\r\n<img src=\"img/h-home05.png\" srcset=\"img/h-home05.png 1x,img/h-home05@2x.png 2x\" alt=\"\" />\r\n<h2>採用情報</h2>\r\n</div>\r\n<div class=\"home-univ\">\r\n<p class=\"univ-title\">近年採用実績校</p>\r\n<p class=\"mt1\">高崎経済大学、高崎商科大学、上武大学、群馬県立女子大学、獨協大学、城西大学、日本大学、白鴎大学、立正大学、大東文化大学、立教大学、同志社大学、早稲田大学、東京農業大学</p>\r\n</div>\r\n<ul class=\"l-row20 sp-row2box3\">\r\n \t<li class=\"w25\"><a href=\"support/\" class=\"card01 is-small\"><div class=\"imgbox\"><img src=\"img/img-home_working01.jpg\" srcset=\"img/img-home_working01.jpg 1x,img/img-home_working01@2x.jpg 2x\" alt=\"\" /></div><h3 class=\"title\">福利厚生</h3></a></li>\r\n \t<li class=\"w25\"><a href=\"education/\" class=\"card01 is-small\"><div class=\"imgbox\"><img src=\"img/img-home_working02.jpg\" srcset=\"img/img-home_working02.jpg 1x,img/img-home_working02@2x.jpg 2x\" alt=\"\" /></div><h3 class=\"title\">教育研修・キャリアフロー</h3></a></li>\r\n \t<li class=\"w25\"><a href=\"environment/\" class=\"card01 is-small\"><div class=\"imgbox\"><img src=\"img/img-home_working03.jpg\" srcset=\"img/img-home_working03.jpg 1x,img/img-home_working03@2x.jpg 2x\" alt=\"\" /></div><h3 class=\"title\">働きやすい環境</h3></a></li>\r\n \t<li class=\"w25\"><a href=\"entry/\" class=\"card01 is-small\"><div class=\"imgbox\"><img src=\"img/img-home_working04.jpg\" srcset=\"img/img-home_working04.jpg 1x,img/img-home_working04@2x.jpg 2x\" alt=\"\" /></div><h3 class=\"title\">応募フォーム</h3></a></li>\r\n</ul>\r\n</div>\r\n<div class=\"home-accent img1\"><img src=\"img/img-home_accent9.png\" alt=\"\" /></div>\r\n<div class=\"home-accent img2\"><img src=\"img/img-home_accent9.png\" alt=\"\" /></div>\r\n<div class=\"home-accent img3\"><img src=\"img/img-home_accent10.png\" alt=\"\" /></div>\r\n<div class=\"home-accent img4\"><img src=\"img/img-home_accent17.png\" alt=\"\" /></div>\r\n<div class=\"home-accent img5\"><img src=\"img/img-home_accent17.png\" alt=\"\" /></div>\r\n<div class=\"home-accent img6\"><img src=\"img/img-home_accent11.png\" alt=\"\" /></div>\r\n<div class=\"home-accent img7\"><img src=\"img/img-home_accent17.png\" alt=\"\" /></div>\r\n</section><section class=\"home-msg\">\r