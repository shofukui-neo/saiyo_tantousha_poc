contact.html\">\r\n          <img src=\"img/common/nav04.png\" alt=\"\" >\r\n        </a>\r\n      </li>\r\n    </ul>\r\n  </div>\r\n  <div class=\"pc main01\">\r\n    <a href=\"./\">ホーム</a>　＞　<a href=\"recruit.html\">求人情報</a>　＞　先輩社員の声\r\n  </div>\r\n  \r\n  <div id=\"fixedBox\" class=\"sp h_inner\">\r\n    <div class=\"nav-wrap\">\r\n      <div class=\"menu\">\r\n        <a href=\"./\">\r\n          <img src=\"img/common/sp_h_logo.png\" width=\"250px\" height=\"44px\" alt=\"\" >\r\n        </a>\r\n        <div class=\"gnav-btn\">\r\n          <div class=\"icon-animation\">\r\n            <span class=\"top\"></span>\r\n            <span class=\"middle\"></span>\r\n            <span class=\"bottom\"></span>\r\n          </div>\r\n        </div>\r\n      </div>\r\n      <nav>\r\n        <ul class=\"gnav\">\r\n          <li><a href=\"./\">ホーム</a></li>\r\n          <li>\r\n            <p><span>業務内容　&#9661;</span></p>\r\n            <ul>\r\n              <li><a href=\"material.html\">　溶材部</a></li>\r\n              <li><a href=\"oil.html\">　石油販売部</a></li>\r\n              <li><a href=\"gas.html\">　石油ガス部</a></li>\r\n            </ul>\r\n          </li>\r\n          <li><a href=\"company.html\">会社案内</a></li>\r\n          <li><p><span>求人情報　&#9661;</span></p>\r\n            <ul>\r\n              <li><a href=\"recruit.html\">　求人情報</a></li>\r\n              <li><a href=\"voice.html\">　先輩社員の声</a></li>\r\n            </ul>\r\n          </li>\r\n          <li><a href=\"sdgs.html\">SDGsへの取り組み</a></li>\t\t\t\r\n          <li><a href=\"contact.html\">お問い合わせ</a></li>\r\n          <li><a href=\"information.html\">個人情報の取扱について</a></li>\r\n          <li><a href=\"about.html\">当サイトご利用について</a></li>\r\n        </ul>\r\n      </nav>\r\n    </div>\r\n  </div><!-- / sp -->  \r\n\r\n  <div class=\"sp h_img\">\r\n    <img src=\"img/recruit/sp_voice01_main.jpg\" width=\"1050px\" height=\"577px\" alt=\"\" >\r\n  </div>\r\n\r\n</header>\r\n\r\n<div id=\"main\">\r\n\t\r\n  <a id=\"voice_01\" class=\"voice_link\"></a>\t\r\n  <article class=\"main pdtop50\">\r\n    <section>\r\n\t\t<div class=\"voice_inner\">\r\n\t\t\t<img src=\"img/recruit/voice_01_img01.jpg\" alt=\"\" >\r\n\t\t\t<div class=\"voice_txtbox\">\r\n\t\t\t\t<div class=\"item\">\r\n\t\t\t\t\t<div class=\"ttl\">カガク興商を選んだ理由</div>\r\n\t\t\t\t\t<div class=\"txt\">地元の企業に貢献したいと思ったからです。</div>\r\n\t\t\t\t</div>\r\n\t\t\t\t<div class=\"item\">\r\n\t\t\t\t\t<div class=\"ttl\">現在の仕事内容</div>\r\n\t\t\t\t\t<div class=\"txt\">高圧ガスボンベや溶材商材など、トラックにて配送しています。</div>\r\n\t\t\t\t</div>\r\n\t\t\t\t<div class=\"item\">\r\n\t\t\t\t\t<div class=\"ttl\">カガク興商はどんな会社？</div>\r\n\t\t\t\t\t<div class=\"txt\">明るく元気な職場です。</div>\r\n\t\t\t\t</div>\r\n\t\t\t\t<div class=\"item\">\r\n\t\t\t\t\t<div class=\"ttl\">入社希望者へのメッセージ</div>\r\n\t\t\t\t\t<div class=\"txt\">まずは挨拶はしっかりとするところからはじめましょう！<br>\r\n\t\t\t\t\tご応募お待ちしております。</div>\r\n\t\t\t\t</div>\r\n\t\t\t\t<div class=\"item\"><img src=\"img/recruit/voice_01_img02.jpg\" alt=\"\" ></div>\r\n\t\t\t\t<div class=\"item\"><img src=\"img/recruit/voice_01_img03.jpg\" alt=\"\" ></div>\r\n\r\n\t\t\t</div>\r\n\r\n\t\t</div>\r\n\t\t\r\n    </section>\r\n  </article>\r\n  <a id=\"voice_02\" class=\"voice_link\"></a>\t\r\n  <article class=\"main02b\">\r\n    <section>\r\n\t\t<div class=\"voice_inner\">\r\n\t\t\t<img src=\"img/recruit/voice_02_img01.jpg\" alt=\"\" >\r\n\t\t\t<div class=\"voice_txtbox\">\r\n\t\t\t\t<div class=\"item\">\r\n\t\t\t\t\t<div class=\"ttl\">カガク興商を選んだ理由</div>\r\n\t\t\t\t\t<div class=\"txt\">学生の頃にしていたコンビニのアルバイトが、セルフのガソリンスタンドも経営している所だったので元々興味を持っていたのと、接客業を続けたかったからです。</div>\r\n\t\t\t\t</div>\r\n\t\t\t\t<div class=\"item\">\r\n\t\t\t\t\t<div class=\"ttl\">現在の仕事内容</div>\r\n\t\t\t\t\t<div class=\"txt\">給油の許可出しや、お客様が安全かつ快適にお車を走行できるように様々な商品を提案しています。時間が空いたときは掃除など事務作業をしています。全てが同じお客様ではないので、一つ一つ対応を変えていかなければいけないことが大変ですが、何事も元気と笑顔を常に意識しています。</div>\r\n\t\t\t\t</div>\r\n\t\t\t\t<div class=\"item\">\r\n\t\t\t\t\t<div class=\"ttl\">カガク興商はどんな会社？</div>\r\n\t\t\t\t\t<div class=\"txt\">先輩方が仕事に対してメリハリをつけ、やる時はしっかりと仕事に集中し、余裕があるときはコミュニケーションをとってくれるので仕事がしやすい会社です。</div>\r\n\t\t\t\t</div>\r\n\t\t\t\t<div class=\"item\">\r\n\t\t\t\t\t<div class=\"ttl\">入社希望者へのメッセージ</div>\r\n\t\t\t\t\t<div class=\"txt\">人と話すことが好きな方、接客業をしてみたい方におすすめです。<br>\r\n\t\t\t\t\tみんな明るくて優しい先輩が多く、すごく活気のある会社です。<br>それと、福利厚生がとてもしっかりしていて働きやすい環境です。</div>\r\n\t\t\t\t</div>\r\n\t\t\t\t<div class=\"item\"><img src=\"img/recruit/voice_02_img02.jpg\" alt=\"\" ></div>\r\n\t\t\t\t<div class=\"item\"><img src=\"img/recruit/voice_02_img03.jpg\" alt=\"\" ></div>\r\n\r\n\t\t\t</div>\r\n\r\n\t\t</div>\r\n\t\t\r\n    </section>\r\n  </article>\r\n\t\r\n  <a id=\"voice_03\" class=\"voice_link\"></a>\t\r\n  <article class=\"main\">\r\n    <section>\r\n\t\t<div class=\"voice_inner\">\r\n\t\t\t<img src=\"img/recruit/voice_04_img01b.jpg\" alt=\"\" >\r\n\t\t\t<div class=\"voice_txtbox\">\r\n\t\t\t\t<div class=\"item\">\r\n\t\t\t\t\t<div class=\"ttl\">カガク興商を選んだ理由</div>\r\n\t\t\t\t\t<div class=\"txt\">車に携わる仕事に就きたかったためです。</div>\r\n\t\t\t\t</div>\r\n\t\t\t\t<div class=\"item\">\r\n\t\t\t\t\t<div class=\"ttl\">現在の仕事内容</div>\r\n\t\t\t\t\t<div class=\"txt\">お客様が安心・安全に車に乗れるよう、点検などを行いサポートする仕事です。<br>\r\n\t\t\t\t\t\t屋外での作業が多いため、夏は暑く冬は寒いです。<br>接客業であるため、人と人とのコミュニケーションが大切だと思います。</div>\r\n\t\t\t\t</div>\r\n\t\t\t\t<div class=\"item\">\r\n\t\t\t\t\t<div class=\"ttl\">カガク興商はどんな会社？</div>\r\n\t\t\t\t\t<div class=\"txt\">スタッフみんな個性豊かで明るい会社だと思います。</div>\r\n\t\t\t\t</div>\r\n\t\t\t\t<div class=\"item\">\r\n\t\t\t\t\t<div class=\"ttl\">入社希望者へのメッセージ</div>\r\n\t\t\t\t\t<div class=\"txt\">車に関する基本的な知識が学べるので、車好きの方や人と関わり話すのが好きな方、是非来てください。</div>\r\n\t\t\t\t</div>\r\n\t\t\t\t<div class=\"item\"><img src=\"img/recruit/voice_04_img02.jpg\" alt=\"\" ></div>\r\n\t\t\t\t<div class=\"item\"><img src=\"img/recruit/voice_04_img03.jpg\" alt=\"\" ></div>\r\n\r\n\t\t\t</div>\r\n\r\n\t\t</div>\r\n\t\t\r\n    </section>\r\n  </article>\r\n\r\n  <a id=\"voice_04\" class=\"voice_link\"></a>\t\r\n  <article class=\"main02b pdtop50\">\r\n    <section>\r\n\t\t<div class=\"voice_inner\">\r\n\t\t\t<img src=\"img/recruit/voice_05_img01b.jpg\" alt=\"\" >\r\n\t\t\t<div class=\"voice_txtbox\">\r\n\t\t\t\t<div class=\"item\">\r\n\t\t\t\t\t<div class=\"ttl\">カガク興商を選んだ理由</div>\r\n\t\t\t\t\t<div class=\"txt\">自営でガスの仕事をしており、少しでも知識をつけたくて入社しました。</div>\r\n\t\t\t\t</div>\r\n\t\t\t\t<div class=\"item\">\r\n\t\t\t\t\t<div class=\"ttl\">現在の仕事内容</div>\r\n\t\t\t\t\t<div class=\"txt\">ＬＰガスボンベの充填や、タンクローリーの受入・回収作業など。</div>\r\n\t\t\t\t</div>\r\n\t\t\t\t<div class=\"item\">\r\n\t\t\t\t\t<div class=\"ttl\">カガク興商はどんな会社？</div>\r\n\t\t\t\t\t<div class=\"txt\">優しい方々が多く、親しみやすい会社だと思いました。<br>一人一人が仕事に対して熱量が素晴らしいです。</div>\r\n\t\t\t\t</div>\r\n\t\t\t\t<div class=\"item\">\r\n\t\t\t\t\t<div class=\"ttl\">入社希望者へのメッセージ</div>\r\n\t\t\t\t\t<div class=\"txt\">ガス系の仕事に興味のある人はぜひ！！</div>\r\n\t\t\t\t</div>\r\n\t\t\t\t<div class=\"item\"><img src=\"img/recruit/voice_05_img02.jpg\" alt=\"\" ></div>\r\n\t\t\t\t<div class=\"item\"><img src=\"img/recruit/voice_05_img03.jpg\" alt=\"\" ></div>\r\n\r\n\t\t\t</div>\r\n\r\n\t\t</div>\r\n\t\t\r\n    </section>\r\n  </article>\t\r\n\r\n  <a id=\"voice_05\" class=\"voice_link\"></a>\t\r\n  <article class=\"main main02\">\r\n    <section>\r\n\t\t<div class=\"voice_inner\">\r\n\t\t\t<img src=\"img/recruit/voice_06_img01b.jpg\" alt=\"\" >\r\n\t\t\t<div class=\"voice_txtbox\">\r\n\t\t\t\t<div class=\"item\">\r\n\t\t\t\t\t<div class=\"ttl\">カガク興商を選んだ理由</div>\r\n\t\t\t\t\t<div class=\"txt\">トラックを運転したいのと、石巻に貢献したいと思って入社しました。</div>\r\n\t\t\t\t</div>\r\n\t\t\t\t<div class=\"item\">\r\n\t\t\t\t\t<div class=\"ttl\">現在の仕事内容</div>\r\n\t\t\t\t\t<div class=\"txt\">私は主にオイル配達をしています。いろんな会社・現場に行き、オイルを納品しています。<br>たくさんの会社でオイルは使われており、機械にオイルを入れたり色んな場面で使われています。<br>ドラム缶を転がす作業では、倒したりしないように気をつけています。</div>\r\n\t\t\t\t</div>\r\n\t\t\t\t<div class=\"item\">\r\n\t\t\t\t\t<div class=\"ttl\">カガク興商はどんな会社？</div>\r\n\t\t\t\t\t<div class=\"txt\">トラックで物を運ぶだけだと思ってましたが、他にもたくさんやることがあり、入社してから勉強することは多いですが、自分のためになるので毎日が充実しています。</div>\r\n\t\t\t\t</div>\r\n\t\t\t\t<div class=\"item\">\r\n\t\t\t\t\t<div class=\"ttl\">入社希望者へのメッセージ</div>\r\n\t\t\t\t\t<div class=\"txt\">私は入社する前は人見知りでしたが、入社してたくさんの会社に配達するようになってからたくさんお客様と話し、徐々に人見知りがなくなりました。たくさんの人としゃべるのが好き、またはしゃべってみたい方はとても向いていると思います。</div>\r\n\t\t\t\t</div>\r\n\t\t\t\t<div class=\"item\"><img src=\"img/recruit/voice_06_img02.jpg\" alt=\"\" ></div>\r\n\t\t\t\t<div class=\"item\"><img src=\"img/recruit/voice_06_img03.jpg\" alt=\"\" ></div>\r\n\r\n\t\t\t</div>\r\n\r\n\t\t</div>\r\n\t\t\r\n    </section>\t  \r\n\t  \r\n\t  \r\n  </article>\t\r\n\t\r\n\t\r\n</div><!--  /main -->\r\n\r\n<footer>\r\n  <div id=\"pagetop\">\r\n    <a href=\"#wrapper\">\r\n      <img src=\"img/common/sp_pagetop.png\" width=\"80px\" height=\"69px\" alt=\"pagetop\" />\r\n    </a>\r\n  </div>\r\n  <div class=\"f_inner01\">\r\n    <ul class=\"b_nav clearfix\">\r\n      <li><a href=\"./\">ホーム</a>&nbsp;&nbsp;｜&nbsp;&nbsp;</li>\r\n      <li><a href=\"material.html\">溶材部</a>&nbsp;&nbsp;｜&nbsp;&nbsp;</li>\r\n      <li><a href=\"oil.html\">石油販売部</a>&nbsp;&nbsp;｜&nbsp;&nbsp;</li>\r\n      <li><a href=\"gas.html\">石油ガス部</a>&nbsp;&nbsp;｜&nbsp;&nbsp;</li>\r\n      <li><a href=\"company.html\">会社案内</a>&nbsp;&nbsp;｜&nbsp;&nbsp;</li>\r\n      <li><a href=\"recruit.html\">求人案内</a>&nbsp;&nbsp;｜&nbsp;&nbsp;</li>\r\n      <li><a href=\"sdgs.html\">SDGsへの取り組み</a>&nbsp;&nbsp;｜&nbsp;&nbsp;</li>\t\t\r\n      <li><a href=\"contact.html\">お問い合わせ</a></li>\r\n    </ul>\r\n    <div class=\"f_inner02 clearfix\">\r\n      <div class=\"copyright\">Copyright (C) 2018 カガク興商株式会社. All Rights Reserved.</div>\r\n      <div class=\"link\">\r\n        <img src=\"img/common/f_sign.png\" width=\"17px\" height=\"15px\" alt=\"\" >\r\n        <a href=\"information.html\">個人情報の取扱について</a>　\r\n        <img src=\"img/common/f_sign.png\" width=\"17px\" height=\"15px\" alt=\"\" >\r\n        <a href=\"about.html\">当サイトご利用について</a>\r\n      </div>\r\n    </div>\r\n  </div>\r\n  <div class=\"f_inner03\">\r\n    <div class=\"f_inner04 clearfix\">\r\n      <div class=\"logo\">\r\n        <a href=