-list\">\n              <li class=\"nav-list__item\"><a class=\"nav-list__link\" href=\"../../job/\">仕事紹介</a></li>\n              <li class=\"nav-list__item\"><a class=\"nav-list__link\" href=\"../../analysis/\">解析・分析・MIYAZAKI</a></li>\n              <li class=\"nav-list__item\"><a class=\"nav-list__link\" href=\"../../welfare\">福利厚生・<br class=\"dn-w\">キャリアアップ</a></li>\n              <li class=\"nav-list__item\"><a class=\"nav-list__link\" href=\"../../guideline/\">募集要項</a></li>\n            </ul>\n            <ul class=\"nav-list\">\n              <li class=\"nav-list__item\"><a class=\"nav-list__link\" href=\"../../voice01/\">先輩社員の声 営業 A.I</a></li>\n              <li class=\"nav-list__item\"><a class=\"nav-list__link\" href=\"../../voice02/\">先輩社員の声 営業 M.Y</a></li>\n              <li class=\"nav-list__item\"><a class=\"nav-list__link\" href=\"../../voice04/\">先輩社員の声 営業 M.T</a></li>\n              <li class=\"nav-list__item\"><a class=\"nav-list__link\" href=\"../../voice05/\">先輩社員の声 営業 T.M</a></li>\n              <li class=\"nav-list__item nav-list__item--wide\"><a class=\"nav-list__link\" href=\"../../voice03/\">先輩社員の声 ドライバー K.K</a></li>\n            </ul>\n            <ul class=\"nav-list\">\n              <li class=\"nav-list__item\"><a class=\"nav-list__link\" href=\"../../entry/\" target=\"_blank\">エントリーフォーム</a></li>\n              <li class=\"nav-list__item\"><a class=\"nav-list__link\" href=\"../../driver/\">中途募集専用ページ<br>（ドライバー）</a></li>\n            </ul>\n            <a href=\"https://www.miyazaki-recycle.com\" target=\"_blank\" class=\"nav__bnr effect-fade-hover\"><img src=\"../../common/img/nav/img_corporation.jpg?220901\" alt=\"株式会社宮崎 コーポレートサイト\" width=\"636\" height=\"182\"></a>\n          </div><!-- /.nav__main -->\n        </div><!-- /.nav__in -->\n      </nav><!-- .nav -->\n    </div><!-- /.header__main -->\n\n  </div><!-- .header__in -->\n</header><!-- #header -->\n\n    <main id=\"main\">\n      <div class=\"cnt-head\">\n        <div class=\"ttl02\">\n          <p class=\"ttl02__en\">GUIDELINE</p>\n          <h1 class=\"ttl02__jp\">募集要項</h1>\n        </div><!-- /.ttl02 -->\n      </div><!-- /.cnt-head -->\n\n      <section class=\"lcl-main\">\n                    <div class=\"lcl-main__block\">\n              <h2 class=\"lcl-main__ttl\">職種</h2>\n              <div class=\"lcl-main__cnt\">回収ドライバー</div>\n            </div><!-- /.lcl-main__block -->\n                    <div class=\"lcl-main__block\">\n              <h2 class=\"lcl-main__ttl\">仕事内容</h2>\n              <div class=\"lcl-main__cnt\">パッカー車・平ボディ車等での古紙回収<br />\r\n※リサイクル用の段ボールや新聞紙等がメインとなります<br />\r\n※勤務時間は拠点やルートにより異なります。<br />\r\n　7:00～16:00、8:00～17:00、6:30～15:30など</div>\n            </div><!-- /.lcl-main__block -->\n                    <div class=\"lcl-main__block\">\n              <h2 class=\"lcl-main__ttl\">応募資格</h2>\n              <div class=\"lcl-main__cnt\">【中部地区・関東地区】<br />\r\n・準中型免許以上<br />\r\n・トラック業務経験のある方<br />\r\n※当社の「資格取得支援制度」を用いて、中型免許を取得することができます（条件あり）<br />\r\n<br />\r\n【九州地区】<br />\r\n・35歳未満の方（例外事由3号のイ：長期キャリア形成のため）<br />\r\n・準中型免許以上<br />\r\n・トラック業務未経験可<br />\r\n※当社の「資格取得支援制度」を用いて、中型免許を取得することができます（条件あり）</div>\n            </div><!-- /.lcl-main__block -->\n                    <div class=\"lcl-main__block\">\n              <h2 class=\"lcl-main__ttl\">給与</h2>\n              <div class=\"lcl-main__cnt\">月給27.9～28.9万円(地域により異なる)＋各種手当＋交通費<br />\r\n（研修期間中の賃金は異なります。）<br />\r\n<br />\r\n＜月収例＞<br />\r\n関東勤務 30歳（1年目）、子２人の場合<br />\r\n38.9万円（基本給＋残業30ｈ＋家族手当）<br />\r\n※残業30ｈの内訳（休日出勤１回8ｈ＋1日1ｈ程度の残業）<br />\r\n</div>\n            </div><!-- /.lcl-main__block -->\n                    <div class=\"lcl-main__block\">\n              <h2 class=\"lcl-main__ttl\">諸手当・待遇等</h2>\n              <div class=\"lcl-main__cnt\">賞与年2回、通勤手当（当社規定）、<br />\r\n家族手当毎月（子ども 1人につき 毎月20,000円 22歳まで）<br />\r\n ※就学している扶養内のお子さんが対象となります。<br />\r\n<br />\r\nリフト・中型免許取得支援有、制服貸与、社会保険完備、結婚・出産祝金<br />\r\n ※研修期間2か月は時給[九州]1,460円 [中部]1,560円 [関東]1,660円、雇用・労災保険／延長有<br />\r\n・自動車学校での安全運転講習<br />\r\n・夏場には熱中症予防対策として飲料水手当<br />\r\n・インフルエンザ予防接種補助金<br />\r\n・永年勤続表彰として10・20・30年目に旅行、または記念品贈呈</div>\n            </div><!-- /.lcl-main__block -->\n                    <div class=\"lcl-main__block\">\n              <h2 class=\"lcl-main__ttl\">休日休暇</h2>\n              <div class=\"lcl-main__cnt\">完全週休2日制／シフト制／年間休日120日以上<br />\r\n ※シフト制の為、土日祝と同じ日数分が休日となります。<br />\r\n 慶弔休暇、年次有給休暇</div>\n            </div><!-- /.lcl-main__block -->\n                    <div class=\"lcl-main__block\">\n              <h2 class=\"lcl-main__ttl\">勤務地</h2>\n              <div class=\"lcl-main__cnt\">ドライバー職 受付中の営業所　2026.6.19現在<br />\r\n【中部地区】<br />\r\n・刈　谷 リサイクルセンター　愛知県刈谷市小垣江町御茶屋下8-1<br />\r\n・名　港 リサイクルセンター　愛知県名古屋市港区十一屋2-100<br />\r\n・　関　 リサイクルセンター　岐阜県関市尾太町66<br />\r\n・四日市 リサイクルセンター　三重県四日市市八田3-6-35<br />\r\n<br />\r\n【関東地区】<br />\r\n・新木場 リサイクルセンター　東京都江東区新木場2丁目7-1<br />\r\n・横　浜 リサイクルセンター　神奈川県横浜市都筑区池辺町3905-3<br />\r\n・西多摩 営業所　　　　　　　東京都西多摩郡瑞穂町長岡3-11-4　<br />\r\n・厚木北 営業所　　　　　　　神奈川県愛甲郡愛川町角田357-1　<br />\r\n・成　田 リサイクルセンター　千葉県印旛郡栄町矢口神明4-9-1　<br />\r\n<br />\r\n【九州地区】<br />\r\n・みやま リサイクルセンター　福岡県みやま市高田町江浦294</div>\n            </div><!-- /.lcl-main__block -->\n                    <div class=\"lcl-main__block\">\n              <h2 class=\"lcl-main__ttl\">ご応募方法</h2>\n              <div class=\"lcl-main__cnt\">①フォームから応募<br />\r\n　画面下「エントリー」からご応募してください。<br />\r\n　<br />\r\n②電話から応募<br />\r\n　0120-173-839 (フリーダイヤル)からご応募下さい。<br />\r\n　応対可能日時　平日(祝日を除く)　9時～17時</div>\n            </div><!-- /.lcl-main__block -->\n                <a href=\"../../entry/?about=career&job=driver\" target=\"_blank\" class=\"lcl-main__btn btn01\">エントリー<svg class=\"ico_svg ico_right\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n  <path class=\"svg-path svg-path01\" d=\"M10.4297 3.13599L11.4703 2.09536C11.9109 1.65474 12.6234 1.65474 13.0594 2.09536L22.1719 11.2032C22.6125 11.6438 22.6125 12.3563 22.1719 12.7922L13.0594 21.9047C12.6187 22.3454 11.9062 22.3454 11.4703 21.9047L10.4297 20.8641C9.98437 20.4188 9.99375 19.6922 10.4484 19.2563L16.0969 13.875H2.625C2.00156 13.875 1.5 13.3735 1.5 12.75V11.25C1.5 10.6266 2.00156 10.125 2.625 10.125H16.0969L10.4484 4.7438C9.98906 4.30786 9.97969 3.5813 10.4297 3.13599Z\" fill=\"black\" />\n</svg></a>\n        <a href=\"../../guideline/\" class=\"lcl-main__prev\">一覧に戻る</a>\n      </section><!-- /.lcl-main -->\n    </main><!-- #main -->\n\n    \n<div class=\"recruit-bnr js-load\">\n  <button class=\"recruit-bnr__close\" aria-label=\"閉じる\"></button>\n  <a href=\"../../driver/\" class=\"recruit-bnr__link\">\n    <figure class=\"recruit-bnr__img\"><img src=\"../../common/img/recruit-nav/img_bnr.jpg?250512\" alt=\"\"></figure>\n    <div class=\"recruit-bnr__main\">\n      <p class=\"recruit-bnr__txt\">ドライバー採用はこちら</p>\n    </div><!-- /.recruit-bnr__main -->\n  </a>\n</div><!-- /.recruit-bnr -->\n\n<footer id=\"footer\" class=\"footer\">\n  <div class=\"footer-nav\">\n    <div class=\"footer-nav-head\">\n      <a href=\"../../\" class=\"footer-nav-head__link effect-fade-hover\">\n        <figure class=\"footer-nav-head__fig\">\n          <img src=\"../../common/img/logo.png?260529\" alt=\"\" loading=\"lazy\" width=\"370\" height=\"70\">\n        </figure>\n        <p class=\"footer-nav-head__recruit\">RECRUIT<span class=\"dn-w\"> </span><br class=\"dn-n\">SITE</p>\n      </a>\n    </div><!-- /.footer-nav-head -->\n    <div class=\"footer-nav__main\">\n      <ul class=\"footer-nav-list\">\n        <li class=\"footer-nav-list__item\"><a class=\"footer-nav-list__link\" href=\"../../job/\">仕事紹介</a></li>\n        <li class=\"footer-nav-list__item\"><a class=\"footer-nav-list__link\" href=\"../../analysis/\">解析・分析・MIYAZAKI</a></li>\n        <li class=\"footer-nav-list__item\"><a class=\"footer-nav-list__link\" href=\"../../welfare\">福利厚生・<br class=\"dn-w\">キャリアアップ</a></li>\n        <li class=\"footer-nav-list__item\"><a class=\"footer-nav-list__link\" href=\"../../guideline/\">募集要項</a></li>\n      </ul>\n      <ul class=\"footer-nav-list\">\n        <li class=\"footer-nav-list__item\"><a class=\"footer-nav-list__link\" href=\"../../voice01/\">先輩社員の声 営業 A.I</a></li>\n        <li class=\"footer-nav-list__item\"><a class=\"footer-nav-list__link\" href=\"../../voice02/\">先輩社員の声 営業 M.Y</a></li>\n        <li class=\"footer-nav-list__item\"><a class=\"footer-nav-list__link\" href=\"../../voice04/\">先輩社員の声 営業 M.T</a></li>\n        <li class=\"footer-nav-list__item\"><a class=\"footer-nav-list__link\" href=\"../../voice05/\">先輩社員の声 営業 T.M</a></li>\n        <li class=\"footer-nav-list__item footer-nav-list__item--wide\"><a class=\"footer-nav-list__link\" href=\"../../voice03/\">先輩社員の声 ドライバー K.K</a></li>\n      </ul>\n      <ul class=\"footer-nav-list\">\n        <li class=\"footer-nav-list__item\"><a class=\"footer-nav-list__link\" href=\"../../entry/\" target=\"_blank\">エントリーフォーム</a></li>\n        <li class=\"footer-nav-list__item\"><a class=\"footer-nav-list__link\" href=\"../../driver/\">中途募集専用ページ<br>（ドライバー）</a></li>\n      </ul>\n      <a href=\"https://www.miyazaki-recycle.com\" target=\"_blank\" class=\"footer-nav__bnr effect-fade-hover\"><img src=\"../../common/img/nav/img_corporation.jpg?220901\" alt=\"株式会社宮崎 コーポレートサイト\" width=\"636\" height=\"182\"></a>\n    </div><!-- /.footer-nav__main -->\n  </div><!-- /.footer-nav -->\n  <p class=\"footer__copy\"><small>&copy; MIYAZAKI All rights reserved.</small></p>\n</footer><!-- #footer -->\n  </div><!-- #wrapper -->\n\n  <script type=\"speculationrules\">\n{\"prefetch\":[{\"source\":\"document\",\"where\":{\"and\":[{\"href_matches\":\"/*\"},{\"not\":{\"href_matches\":[\"/app/wp-*.php\",\"/app/wp-admin/*\",\"/app/wp-content/uploads/*\",\"/app/wp-content/*\",\"/app/wp-content/plugins/*\",\"/app/wp-content/themes/main/*\",\"/*\\\\?(.+)\"]}},{\"not\":{\"selector_matches\":\"a[rel~=\\\"nofollow\\\"]\"}},{\"not\":{\"selector_matches\":\".no-prefetch, .no-prefetch a\"}}]},\"eagerness\":\"conservative\"}]}\n</script>\n<script id=\"wp-emoji-setting