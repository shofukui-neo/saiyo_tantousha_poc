{"url":"https://www.suzuki.co.jp/corporate/message/mission.html","html":"<!DOCTYPE HTML>\r\n<html lang=\"ja\">\r\n<head>\r\n<title>社是・行動理念・コーポレートスローガン｜スズキ</title>\r\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\r\n<!-- Google Tag Manager ver.2023.05.10 -->\r\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\r\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\r\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\r\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\r\n})(window,document,'script','dataLayer','GTM-TK9KRGP');</script>\r\n<!-- End Google Tag Manager -->\r\n<meta charset=\"utf-8\">\r\n<meta name=\"format-detection\" content=\"telephone=no\">\r\n<meta name=\"keywords\" content=\"SUZUKI,スズキ,鈴木,すずき,環境技術,CSR,社会貢献,企業情報,会社概要,生産拠点,浜松,株式会社,コーポレートサイト\">\n<meta name=\"description\" content=\"スズキ株式会社の会社概要や概況、生産拠点、次世代環境技術、環境や社会貢献への取り組みなどの情報をご覧いただけます。\">\n<meta property=\"og:description\" content=\"スズキ株式会社の会社概要や概況、生産拠点、次世代環境技術、環境や社会貢献への取り組みなどの情報をご覧いただけます。\">\n<meta property=\"og:type\" content=\"website\">\r\n<meta property=\"og:title\" content=\"社是・行動理念・コーポレートスローガン｜スズキ\">\r\n<meta property=\"og:site_name\" content=\"社是・行動理念・コーポレートスローガン｜スズキ\">\r\n<meta property=\"og:url\" content=\"https://www.suzuki.co.jp/corporate/message/mission.html\">\r\n<meta property=\"og:image\" content=\"https://www.suzuki.co.jp/commons/v1/img/facebook_icon.gif\">\r\n<link rel=\"shortcut icon\" href=\"/commons/v1/icon/favicon.ico\">\n<link rel=\"apple-touch-icon-precomposed apple-touch-icon\" href=\"/commons/v1/icon/apple-touch-icon.png\">\r\n<link rel=\"stylesheet\" href=\"/commons/v1/css/common.css\">\r\n<link rel=\"stylesheet\" href=\"/corporate/commons/css/corporate_pc.css\">\r\n<link rel=\"stylesheet\" href=\"/corporate/commons/css/corporate_sp.css\">\r\n<link rel=\"stylesheet\" href=\"/corporate/message/css/mission.css\">\r\n</head>\r\n<body>\r\n<!-- Google Tag Manager (noscript) v