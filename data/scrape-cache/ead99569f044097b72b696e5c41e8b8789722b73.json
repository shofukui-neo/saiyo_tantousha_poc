"l-contW investorInfo\">\n\n        <div class=\"investorInfo_box\">\n          <dl class=\"investorInfo_boxList\">\n            <dt class=\"investorInfo_boxListTitle investorInfo_boxListTitle-top\">募集職種</dt>\n            <dd class=\"investorInfo_boxListItem\">\n            ・設計開発<br>\n            ・セールスエンジニア（技術営業）<br>\n            ・サービスエンジニア<br>\n            ※その他要相談<br>\n            変更範囲（有無）：有　　変更の範囲：当社業務全般<br>\n            </dd>\n          </dl>\n<!--                ただいま募集はありません。\n-->\n\n          <dl class=\"investorInfo_boxList\">\n            <dt class=\"investorInfo_boxListTitle\">採用人数</dt>\n            <dd class=\"investorInfo_boxListItem\">若干名</dd>\n          </dl>\n          <dl class=\"investorInfo_boxList\">\n            <dt class=\"investorInfo_boxListTitle\">給与</dt>\n            <dd class=\"investorInfo_boxListItem\">※要相談、詳細は面談の時にお伝えします</dd>\n          </dl>\n          <dl class=\"investorInfo_boxList\">\n            <dt class=\"investorInfo_boxListTitle\">諸手当</dt>\n            <dd class=\"investorInfo_boxListItem\">残業手当、家族手当、役職手当、通勤手当（実費）</dd>\n          </dl>\n          <dl class=\"investorInfo_boxList\">\n            <dt class=\"investorInfo_boxListTitle\">昇給</dt>\n            <dd class=\"investorInfo_boxListItem\">年1回（4月）18,500円（2025年度組合員平均実績）</dd>\n          </dl>\n          <dl class=\"investorInfo_boxList\">\n            <dt class=\"investorInfo_boxListTitle\">賞与</dt>\n            <dd class=\"investorInfo_boxListItem\">年2回（6月・12月）年間実績171万円＋利益配分（業績による / 2024年度組合員平均実績）</dd>\n          </dl>\n\t\t  <dl class=\"investorInfo_boxList\">\n            <dt class=\"investorInfo_boxListTitle\">契約期間</dt>\n            <dd class=\"investorInfo_boxListItem\">募集案件ごとに設定</dd>\n          </dl>\n\t\t  <dl class=\"investorInfo_boxList\">\n            <dt class=\"investorInfo_boxListTitle\">試用期間</dt>\n            <dd class=\"investorInfo_boxListItem\">入社3ヶ月経過後の21日付</dd>\n          </dl>\n          <dl class=\"investorInfo_boxList\">\n            <dt class=\"investorInfo_boxListTitle\">勤務時間 </dt>\n            <dd class=\"investorInfo_boxListItem\">8:30〜17:00（東京支店・北海道営業所・さいたま営業所・千葉営業所　9:00～17:30）</dd>\n          </dl>\n          <dl class=\"investorInfo_boxList\">\n            <dt class=\"investorInfo_boxListTitle investorInfo_boxListTitle-top\">勤務地</dt>\n            <dd class=\"investorInfo_boxListItem\">\n              本社（大阪府大阪市北区曾根崎2-12-7 清和梅田ビル20F）<br>\n              <a href=\"/company_info/access.html#homeLink\" target=\"_blank\" class=\"investorInfo_boxListItemMail\">≫地図を見る</a><br>\n              鴻池事業所（大阪府東大阪市東鴻池町2-1-48）<br>\n              <a href=\"/company_info/access.html#konoikeLink\" target=\"_blank\" class=\"investorInfo_boxListItemMail\">≫地図を見る</a><br>\n              生駒事業所（奈良県生駒市高山町8916-10）<br>\n              <a href=\"/company_info/access.html#ikomaLink\" target=\"_blank\" class=\"investorInfo_boxListItemMail\">≫地図を見る</a><br>\n              <br>\n              変更の範囲（有無）：有　　変更の範囲：国内外の全拠点\n            </dd>\n          </dl>\n          <dl class=\"investorInfo_boxList\">\n            <dt class=\"investorInfo_boxListTitle investorInfo_boxListTitle-top\">休日休暇</dt>\n            <dd class=\"investorInfo_boxListItem\">完全週休2日制、年間休日124日(2025年度)、年次有給休暇(入社日に応じて付与、初年度最大12日)、<br>\n\t\t\t\t慶弔特別休暇、連続休暇(夏季/年末年始/ゴールデンウイーク)、リフレッシュ休暇、看護・介護休暇</dd>\n          </dl>\n\t\t  <dl class=\"investorInfo_boxList\">\n            <dt class=\"investorInfo_boxListTitle\">時間外労働</dt>\n            <dd class=\"investorInfo_boxListItem\">あり（月平均20時間）</dd>\n          </dl>\n          <dl class=\"investorInfo_boxList\">\n            <dt class=\"investorInfo_boxListTitle investorInfo_boxListTitle-top\">福利厚生・各種制度</dt>\n            <dd class=\"investorInfo_boxListItem\">各種社会保険、財形貯蓄、持株会、住宅ローン利息補助、年金基金、福祉会、OB会、<br class=\"pc\">テレワーク制度（週2回、月8回まで取得可能）、クラブ活動、レクリエーション（補助）、他</dd>\n          </dl>\n          <dl class=\"investorInfo_boxList\">\n            <dt class=\"investorInfo_boxListTitle\">教育制度</dt>\n            <dd class=\"investorInfo_boxListItem\">職能別専門教育、OJT、ビジネス基礎力研修、自己研修、通信教育、外部研修</dd>\n          </dl>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"l-mt60 l-mb80\">\n      <div class=\"l-contW investorInfo\">\n        <h4 class=\"investorInfo_notoTitle\">お問い合わせ先</h4>\n\n        <div class=\"investorInfo_box\">\n          <dl class=\"investorInfo_boxList\">\n            <dt class=\"investorInfo_boxListTitle\">電話番号</dt>\n            <dd class=\"investorInfo_boxListItem\">06-6363-0006（代表）</dd>\n          </dl>\n          <dl class=\"investorInfo_boxList\">\n            <dt class=\"investorInfo_boxListTitle\">メールアドレス</dt>\n            <dd class=\"investorInfo_boxListItem\">\n              <a href=\"mailto:career-saiyo@hisaka.co.jp\" class=\"investorInfo_boxListItemMail\">career-saiyo@hisaka.co.jp</a>\n            </dd>\n          </dl>\n          <dl class=\"investorInfo_boxList\">\n            <dt class=\"investorInfo_boxListTitle\">採用担当者</dt>\n            <dd class=\"investorInfo_boxListItem\">九保</dd>\n          </dl>\n        </div>\n      </div>\n    </section>\n  </div>\n</div>\n<!-- / contents -->\n\n<footer>\n  <div class=\"l-contWFull l-footerPos footer\">\n    <div class=\"l-contW footer_cont\">\n      <p class=\"footer_contLogo\">\n        <img src=\"/img/common_new/footer_logo.png\" alt=\"株式会社 日阪製作所\" class=\"footer_contLogoImg\">\n      </p>\n\n      <span class=\"header_navContact contactBtn\">\n        <a href=\"/inquiry/\" class=\"contactBtn_link\">お問い合わせ</a>\n      </span>\n\n      <ul class=\"footer_contBox\">\n        <li class=\"footer_contBoxList\">\n          <a href=\"/company_info/\" class=\"footer_contBoxListLink footer_contBoxListLink-index\">企業情報</a>\n          <a href=\"/company_info/message.html\" class=\"footer_contBoxListLink\">トップメッセージ</a>\n          <a href=\"/company_info/philosophy.html\" class=\"footer_contBoxListLink\">経営理念『HISAKA MIND』</a>\n          <a href=\"/company_info/outline.html\" class=\"footer_contBoxListLink\">会社概要</a>\n          <a href=\"/company_info/p