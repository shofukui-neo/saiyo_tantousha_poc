     </span>\r\n                                            </h2>\r\n                                            <div class=\"submenufr\">\r\n                                                <div class=\"submenuouter\">\r\n                                                    <div class=\"submenu\">\r\n                                                        <div class=\"submenuulfr\">\r\n                                                            <ul class=\"submenuul\">\r\n                                                                <li>\r\n                                                                    <h3 class=\"submenuultitlefr\">\r\n                                                                        <a class=\"submenuultitle\" href=\"/recruit/recruit_info/person/\">求める人物像</a>\r\n                                                                    </h3>\r\n                                                                </li>\r\n                                                            </ul>\r\n                                                            <ul class=\"submenuul\">\r\n                                                                <li>\r\n                                                                    <h3 class=\"submenuultitlefr\">\r\n                                                                        <a class=\"submenuultitle\" href=\"/recruit/recruit_info/career/\">教育研修制度・支援</a>\r\n                                                                    </h3>\r\n                                                                </li>\r\n                                                            </ul>\r\n                                                            <ul class=\"submenuul\">\r\n                                                                <li>\r\n                                                                    <h3 class=\"submenuultitlefr\">\r\n                                                                        <a class=\"submenuultitle\" href=\"/recruit/recruit_info/welfare/\">福利厚生</a>\r\n                                                                    </h3>\r\n                                                                </li>\r\n                                                            </ul>\r\n                                                            <ul class=\"submenuul\">\r\n                                                                <li>\r\n                                                                    <h3 class=\"submenuultitlefr\">\r\n                                                                        <a class=\"submenuultitle\" href=\"/recruit/recruit_info/requirements_freshman/\">募集要項（新卒・既卒）</a>\r\n                                                                    </h3>\r\n                                                                </li>\r\n                                                            </ul>\r\n                                                            <ul class=\"submenuul\">\r\n                                                                <li>\r\n                                                                    <h3 class=\"submenuultitlefr\">\r\n                                                                        <a class=\"submenuultitle\" href=\"/recruit/recruit_info/requirements_career/\">募集要項（キャリア）</a>\r\n                                                                    </h3>\r\n                                                                </li>\r\n                                                            </ul>\r\n                                                            <ul class=\"submenuul\">\r\n                                                                <li>\r\n                                                                    <h3 class=\"submenuultitlefr\">\r\n                                                                        <a class=\"submenuultitle\" href=\"/recruit/recruit_info/internship/\">インターンシップ</a>\r\n                                                                    </h3>\r\n                                                                </li>\r\n                                                            </ul>\r\n                                                            <ul class=\"submenuul\">\r\n                                                                <li>\r\n                                                                    <h3 class=\"submenuultitlefr\">\r\n                                                                        <a class=\"submenuultitle\" href=\"/recruit/recruit_info/faq/\">FAQ</a>\r\n                                                                    </h3>\r\n                                                                </li>\r\n                                                            </ul>\r\n                                                        </div>\r\n                                                    </div>\r\n                                                </div>\r\n                                            </div>\r\n                                        </li>\r\n                                        <li class=\"only-sp\">\r\n                                            <div class=\"btn-entry-wrap\">\r\n                                                <a class=\"btn-entry font-ls\" href=\"https://www.suwa.sansha.co.jp/entry/\" target=\"_blank\">entry</a>\r\n                                            </div>\r\n                                        </li>\r\n                                    </ul>\r\n                                </div>\r\n                            </div>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n            </nav>\r\n        </header>\r\n\t\t<main>\r\n            <span id=\"top\" valoffsety=\"0\"></span>\r\n            <div class=\"main-wrap main-wrap1\">\r\n                <div class=\"content-wrap\">\r\n                    <div class=\"content\">\r\n                        <div class=\"inner-wrap\">\r\n                            <div class=\"inner\">\r\n                                <h3 class=\"font-ls\">Welfare Program</h3>\r\n                                <span>福利厚生</span>\r\n                            </div>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n            <div class=\"main-wrap main-wrap2\">\r\n                <div class=\"content-wrap\">\r\n                    <div class=\"content\">\r\n                        <ul class=\"breadcrumbfr clearfix\">\r\n                            <li class=\"breadcrumb\"><a class=\"breadcrumblnk\" href=\"/recruit/\">Top</a><span class=\"breadcrumbborder\">／</span>\r\n                            </li>\r\n                            <li class=\"breadcrumb\"><a class=\"breadcrumblnk\" href=\"/recruit/recruit_info/\">採用情報</a><span class=\"breadcrumbborder\">／</span>\r\n                            </li>\r\n                            <li class=\"breadcrumb\"><span class=\"breadcrumblnk\">福利厚生</span>\r\n                            </li>\r\n                        </ul>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n            <div class=\"main-wrap main-wrap3\">\r\n                <div class=\"content-wrap\">\r\n                    <div class=\"content\">\r\n                        <div class=\"inner-wrap\">\r\n                            <div class=\"inner\">\r\n                                <ul>\r\n                                    <li>\r\n                                        <span class=\"list-left\">年間休日</span>\r\n                                        <span class=\"list-right\">\r\n\t\t\t\t\t\t\t\t\t\t\t年間休日数は121日です。年末年始、GW、お盆に連休があります。\r\n\t\t\t\t\t\t\t\t\t\t</span>\r\n                                    </li>\r\n                                    <li>\r\n                                        <span class=\"list-left\">社員食堂完備</span>\r\n                                        <span class=\"list-right\">\r\n\t\t\t\t\t\t\t\t\t\t\t1食350円で定食、丼、カレー、麺などが食べられます。緑茶はいつでも無料。\r\n\t\t\t\t\t\t\t\t\t\t</span>\r\n                                    </li>\r\n                                    <li>\r\n                                        <span class=\"list-left\">有給休暇</span>\r\n                                        <span class=\"list-right\">\r\n\t\t\t\t\t\t\t\t\t\t\t入社2週間後に付与します。10日間（4～9月入社）または5日間（10～3月入社）<br>\r\n\t\t\t\t\t\t\t\t\t\t\t会社指定の有給消化日が年3日、個人の計画有給消化日を年4日設けています。\r\n\t\t\t\t\t\t\t\t\t\t</span>\r\n                                    </li>\r\n                                    <li>\r\n                                        <span class=\"list-left\">半日・時間有給</span>\r\n                                        <span class=\"list-right\">\r\n\t\t\t\t\t\t\t\t\t\t\t1日単位だけではなく、半日や1時間単位で有給取得ができます。\r\n\t\t\t\t\t\t\t\t\t\t</span>\r\n                                    </li>\r\n                                    <li>\r\n                                        <span class=\"list-left\">社宅制度</span>\r\n                                        <span class=\"list-right\">\r\n\t\t\t\t\t\t\t\t\t\t\t借上げ社宅の本人負担が10年間15％です。通勤距離が40km以遠の方が対象です。\r\n\t\t\t\t\t\t\t\t\t\t</span>\r\n                                    </li>\r\n                                    <li>\r\n                                        <span class=\"list-left\">奨学金支援制度</span>\r\n                                        <span class=\"list-right\">\r\n\t\t\t\t\t\t\t\t\t\t\t奨学金返済月額最大1万円を支援します。入社から最大5年間。（新卒のみ）\r\n\t\t\t\t\t\t\t\t\t\t</span>\r\n                                    </li>\r\n                                    <li>\r\n                                        <span class=\"list-left\">語学教室<br>（英語・中国語）</span>\r\n                                        <span class=\"list-right\">\r\n\t\t\t\t\t\t\t\t\t\t\tネイティブの講師が週に1回レッスンを実施しています。（無料）\r\n\t\t\t\t\t\t\t\t\t\t</span>\r\n                                    </li>\r\n                                    <li>\r\n                                        <span class=\"list-left\">NO残業デー</span>\r\n                                        <span class=\"list-right\">\r\n\t\t\t\t\t\t\t\t\t\t\t月に3日残業を禁止する日を設定しています。\r\n\t\t\t\t\t\t\t\t\t\t</span>\r\n                                    </li>\r\n                                    <li>\r\n                                        <span class=\"list-left\">育児短時間勤務</span>\r\n                                        <span class=\"list-right\">\r\n\t\t\t\t\t\t\t\t\t\t\tお子さんが小学校を卒業するまで勤務時間を6時間までに短縮できます。\r\n\t\t\t\t\t\t\t\t\t\t</span>\r\n                                    </li>\r\n                                    <li>\r\n                                        <span class=\"list-left\">子の看護等休暇</span>\r\n                                        <span class=\"list-right\">\r\n\t\t\t\t\t\t\t\t\t\t\t中学入学前までのお子さんの病気・けが等で看護が必要な場合に取得できます。（無給）<br>\r\n\t\t\t\t\t\t\t\t\t\t\t子1人で年5日、2人以上で年10日まで。1日、半日、1時間単位での取得が可能です。\r\n\t\t\t\t\t\t\t\t\t\t</span>\r\n                                    </li>\r\n                                    <li>\r\n                                        <span class=\"list-left\">介護休暇</span>\r\n                                        <span class=\"list-right\">\r\n\t\t\t\t\t\t\t\t\t\t\tご家族の介護が必要な場合に取得できます。（無給）<br>\r\n\t\t\t\t\t\t\t\t\t\t\tご家族1人で年5日、2人以上で年10日まで。1日、半日、1時間単位での取得が可能です。\r\n\t\t\t\t\t\t\t\t\t\t</span>\r\n                                    </li>\r\n                                    <li>\r\n                                        <span class=\"list-left\">慶弔休暇</span>\r\n                                        <span class=\"list-right\">\r\n\t\t\t\t\t\t\t\t\t\t\tお祝い事、お悔やみ事のための休暇制度です。<br>\r\n\t\t\t\t\t\t\t\t\t\t\t例えば、結婚休暇は連続して10日間のお休み（有給）、結婚祝い金が7万円支給されます。\r\n\t\t\t\t\t\t\t\t\t\t</span>\r\n                                    </li>\r\n                                    <li>\r\n                                        <span class=\"list-left\">生理休暇</span>\r\n                                        <span class=\"list-right\">\r\n\t\t\t\t\t\t\t\t\t\t\t就業が難しい場合、月に1日（有給）取得できます。半日単位での取得も可能です。\r\n\t\t\t\t\t\t\t\t\t\t</span>\r\n                                    </li>\r\n                                </ul>\r\n                            </div>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n\t\t</main>\r\n\t\t\t\t<footer>\r\n\t\t\t<span id=\"footer\" class=\"\">\r\n\t\t\t\t<div class=\"footer-wrap\">\r\n\t\t\t        <div class=\"footergototop\">\r\n                        <div class=\"btn-entry-wrap\">\r\n                            <a class=\"btn-entry font-ls\" href=\"#top\">TO TOP</a>\r\n                        </div>\r\n                    </div>\r\n\t\t\t\t\t<div class=\"footer-in\">\r\n                        <div class=\"footer-in-inner\">\r\n                            <div class=\"footer-in-left\">\r\n                                <a href=\"/recruit/\"><img src=\"/recruit/common/images/footer_logo_01.png\" alt=\"logo\"></a>\r\n                            </div>\r\n                            <div class=\"footer-in-right\">\r\n                                <ul>\r\n                                    <li>\r\n                                        <a href=\"/recruit/company/\"><span>会社を知る</span></a>\r\n                                        <ul>\r\n                                            <li>\r\n                                                <a href=\"/recruit/company/profile/\"><span>会社概要</span></a>\r\n                                            </li>\r\n                                            <li>\r\n                                                <a href=\"/recruit/company/philosophy/\"><span>経営理念・パーパス</span></a>\r\n                                            </li>\r\n                                            <li>\r\n                                                <a href=\"/recruit/company/data/\"><span>数字でわかる</span></a>\r\n                                           