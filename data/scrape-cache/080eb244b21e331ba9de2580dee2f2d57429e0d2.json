avascript\" src=\"js/script.js\"></script>\n</head>\n<body>\n<!-- Google Tag Manager (noscript) -->\n<noscript>\n<iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-K49Q3QS\"\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe>\n</noscript>\n<!-- End Google Tag Manager (noscript) --> \n<!--loding-->\n<div id=\"loader\">\n<div class=\"spinner\">\n<div class=\"rect1\"></div>\n<div class=\"rect2\"></div>\n<div class=\"rect3\"></div>\n<div class=\"rect4\"></div>\n<div class=\"rect5\"></div>\n</div>\n</div>\n<!--/loding-->\n<div id=\"wrapper\"> \n<!--header--> \n<header>\n<div id=\"header\">\n<div class=\"sitename\">\n<h1><a href=\"/recruite/\"><img src=\"/recruite/img/logo.svg\" alt=\"沖縄コカ･コーラボトリング採用情報\" class=\"logo\"/><span class=\"siteH1\"><span class=\"corp\">沖縄コカ･コーラボトリング</span>RECRUIT SITE</span></a></h1>\n</div>\n<div class=\"contactmenu\"><a href=\"/recruite/form/\" target=\"_blank\" class=\"en\">CONTACT<span class=\"icon-forward\"></span></a></div>\n<nav>\n<ul id=\"jetmenu\" class=\"jetmenu\">\n<li><a href=\"/recruite/message/\">\n<p>社長メッセージ</p>\n</a></li>\n<li><a href=\"/recruite/vision/\">\n<p>企業ビジョン</p>\n</a></li>\n<li><a href=\"/recruite/culture/\">\n<p>企業文化</p>\n</a></li>\n<li><a href=\"/recruite/carrier_plan/\">\n<p>教育・キャリアプラン</p>\n</a></li>\n<li><a href=\"javascript:void();\">\n<p>社員インタビュー<span class=\"icon-arrow-down\"></span></p>\n</a><!--row-->\n<div class=\"megamenu full-width\">\n<div class=\"row\">\n<div class=\"memint\">\n<div class=\"title mh\">\n<h5><span class=\"en\">Interview</span>社員インタビュー</h5>\n</div>\n<ul>\n<li><a href=\"/recruite/interview/marketing.html\">\n<p><img src=\"/recruite/img/cmn/men06.jpg\" alt=\"\"/></p>\n<p class=\"text1\">トレードマーケティング部</p>\n<p class=\"text2\">新垣 凜／與久田 藍香</p>\n</a></li>\n<li><a href=\"/recruite/interview/akamine.html\">\n<p><img src=\"/recruite/img/cmn/men07.jpg\" alt=\"\"/></p>\n<p class=\"text1\">浦添工場 製造二課</p>\n<p class=\"text2\">赤嶺 孝太</p>\n</li>\n<li></li>\n</ul>\n</div>\n<a></a></div>\n</div>\n<!--/row--></li>\n<li><a href=\"/recruite/guideline/\">\n<p>募集要項</p>\n</a></li>\n</ul>\n</nav>\n</div>\n</header>\n \n<!--/header-->\n<main> \n<!--　メイン画像　-->\n<div class=\"mainimage\">\n<div class=\"swiper-wrapper\"> \n<!-- Slides -->\n<div class=\"swiper-slide slide1\"> </div>\n<div class=\"swiper-slide slide2\"> </div>\n<div class=\"swiper-slide slide3\"> </div>\n<div class=\"swiper-slide slide4\"> </div>\n<!--<div class=\"swiper-slide slide5\"> </div>-->\n</div>\n<div class=\"conseptin\">\n<h3>がむしゃらに、<br>\nそして爽やかに</h3>\n<p class=\"pccatch\">コカ･コーラブランドの使命は「世界中にさわやかさをお届けすること」、「前向きでハッピーな気持ちを味わえるひとときをもたらすこと」、そして「価値を生み出し前向きな変化をもたらすこと」。沖縄コカ･コーラボトリングは、1968年から50年間ここ沖縄で世界共通の高品質で安全・安心なコカ･コーラ製品を届けてきました。<br>\nしかし、ブランドを守り続けることは容易ではありません。私達はこれからも環境の変化に対応しながら、お客様のことを常に考え、日々努力し続けていきます。<br>\n私たちと一緒にブランドを守り、「沖縄を爽やかな気分で満たし、Happyな瞬間を届けたい」という志の高い仲間との出会いを待っています。</p>\n</div>\n</div>\n<div class=\"spcatch\">\n<p>コカ･コーラブランドの使命は「世界中にさわやかさをお届けすること」、「前向きでハッピーな気持ちを味わえるひとときをもたらすこと」、そして「価値を生み出し前向きな変化をもたらすこと」。沖縄コカ･コーラボトリングは、1968年から50年間ここ沖縄で世界共通の高品質で安全・安心なコカ･コーラ製品を届けてきました。<br>\nしかし、ブランドを守り続けることは容易ではありません。私達はこれからも環境の変化に対応しながら、お客様のことを常に考え、日々努力し続けていきます。<br>\n私たちと一緒にブランドを守り、「沖縄を爽やかな気分で満たし、Happyな瞬間を届けたい」という志の高い仲間との出会いを待っています。</p>\n</div>\n<!--　/ メイン画像　--> \n<!--　カラム　-->\n<div class=\"second\">\n<div class=\"box1\" style=\"background: none;\"><!--　お知らせ　-->\n<section class=\"news\">\n<div class=\"contitle\">\n<h2><span class=\"en\">Information</span>お知らせ</h2>\n</div>\n<div class=\"newslist\">\n<ul> <li class=\"news1\">\n<dl>\n<dt>2025.10.1</dt>\n<dd><h3>LGBTQ＋SOGI（性的指向・性自認または表現）に関する多様性を尊重するための方針について。</h3>\n<p><a href=\"/lgbtq/\"><span class=\"icon-forward\"></span> 詳しくはこちら</a></p>\n\n</dd>\n</dl>\n</li>\n <li class=\"news2\">\n<dl>\n<dt>2024.8.21</dt>\n<dd>\n<h3>社員インタビューを公開いたしました。</h3>\n\n <p><a href=\"/recruite/interview/marketing.html\"><span class=\"icon-forward\"></span> 社員インタビューはこちら</a></p>\n</dd>\n</dl>\n</li>\n<li class=\"news3\">\n<dl>\n<dt>2024.7.30</dt>\n<dd>\n<h3>新卒採用募集要項を公開いたしました。</h3>\n\n <p><a href=\"/recruite/guideline/ccbc.html\"><span class=\"icon-forward\"></span> 募集要項はこちら</a></p>\n</dd>\n</dl>\n</li>\n<li class=\"news4\">\n<dl>\n<dt>2024.2.27</dt>\n<dd>\n<h3>募集要項を更新いたしました。</h3>\n\n <p><a href=\"/recruite/guideline/\"><span class=\"icon-forward\"></span> 募集要項はこちら</a></p>\n</dd>\n</dl>\n</li>\n</ul>\n</div>\n</section>\n<!--　/ お知らせ　--> \n<!--<section class=\"president\">\n<div class=\"trg\"></div>\n<h2><span class=\"en\">Message</span>社長メッセージ</h2>\n<div class=\"presidentbody\">\n<p><strong>\n<ruby>未来\n<rp>（</rp>\n<rt>みらい</rt>\n<rp>）</rp>\n</ruby>\nへ受け継いでいこう、<br>\nワシタチムグクル</strong>これからの未来を支え、自らの意思で変化し、覚悟を持って果敢にチャレンジしていける。そういう高い志を持った仲間との出会いを期待しています。</p>\n<div class=\"btn\"><a href=\"/recruite/message/\">社長メッセージはこちら<span class=\"icon-forward\"></span></a></div>\n</div>\n</section>-->\n</div>\n<div class=\"box2\"> \n\n<!--　コンセプト　-->\n<section class=\"consept\">\n<div class=\"bw\">\n<div class=\"conmenu\">\n<div class=\"contitle\">\n<h2><span class=\"en\">About us</span>沖縄コカ･コーラボトリングについて</h2>\n</div>\n<ul>\n<li class=\"fadein\"><a href=\"/recruite/vision/\">\n<div class=\"conmenuimg img3\"></div>\n<div class=\"conmenutext\">\n<h4>企業ビジョン</h4>\n<p>当社の経営理念、社是の他、全国のコカ･コーラシステムについて紹介いたします</p>\n<span class=\"icon-forward\"></span></div>\n</a></li>\n<li class=\"fadein\"><a href=\"/recruite/culture/\">\n<div class=\"conmenuimg img1\"></div>\n<div class=\"conmenutext\">\n<h4>企業文化</h4>\n<p>会社および一人一人の成長のため共通認識として掲げる目標を紹介いたします</p>\n<span class=\"icon-forward\"></span></div>\n</a></li>\n<li class=\"fadein\"><a href=\"/recruite/carrier_plan/\">\n<div class=\"conmenuimg img2\"></div>\n<div class=\"conmenutext\">\n<h4>教育・キャリアプラン</h4>\n<p>入社後のキャリアプランおよび多様な教育・研修制度について紹介いたします</p>\n<span class=\"icon-forward\"></span></div>\n</a></li>\n</ul>\n</div>\n</div>\n</section>\n<!--　/ コンセプト　--></div>\n</div>\n<!--　/カラム　--> \n<!--　社員紹介　-->\n<section class=\"member\">\n<div class=\"memberwidth\">\n<div class=\"int\">\n<div class=\"inttitle\">\n<h2><span class=\"en\">Interview</span>社員インタビュー</h2>\n</div>\n<div class=\"intlist\">\n<ul>\n<li class=\"menber6\"><a href=\"/recruite/interview/marketing.html\">\n<div class=\"memberdata\" style=\"width:360px;max-width:100%;\"><span class=\"icon-forward\"></span>\n<p class=\"text1\">トレードマーケティング部</p>\n<p class=\"text2\">新垣 凜／與久田 藍香</p>\n</div>\n</a></li>\n<li class=\"menber7\"><a href=\"/recruite/interview/akamine.html\">\n<div class=\"memberdata\"><span class=\"icon-forward\"></span>\n<p class=\"text1\">浦添工場 製造二課</p>\n<p class=\"text2\">赤嶺 孝太</p>\n</div>\n</a></li>\n\n</ul>\n</div>\n</div>\n</div>\n</section>\n<!--　/ 社員紹介　--> \n</main>\n<!--　お問い合わせ　-->\n<aside class=\"infoLink\">\n<article class=\"contact\">\n<div class=\"basewidth\"><div class=\"all_contact\"><a href=\"tel:0988775257\" target=\"_blank\" class=\"inqtel\">\n      <p><span class=\"icon-phone\"></span><span class=\"phone\"><strong>098-877-5257</strong><i>平日9:00～17:00</i></span><span class=\"icospc\"></span></p>\n      </a><a href=\"/recruite/guideline/\"  class=\"guideline\"><p><span class=\"icon-file\"></span><span>募集要項</span><span class=\"icospc\"></span></p></a><a href=\"/recruite/form/\" target=\"_blank\"  class=\"inqmail\">\n      <p><span class=\"icon-envelope\"></span><span>採用に関するお問い合わせ</span></p>\n      </a></div>\n</div>\n</article>\n</aside>\n<!--　/ お問い合わせ　--> \n<!--footer-->\n<footer>\n<div id=\"footer\">\n<div class=\"logo\"><a href=\"/recruite/\"><img src=\"/recruite/img/logo.svg\" alt=\"沖縄コカ･コーラボトリング リクルート\"/><span class=\"siteH1\"><span class=\"corp\">沖縄コカ･コーラボトリング</span>RECRUIT SITE</span></a></div>\n<div class=\"footernav\">\n<nav>\n<dl class=\"line\">\n<dt>Contents</dt>\n<dd>\n<ul>\n<li><a href=\"/recruite/message/\">社長メッセージ</a></li>\n<li><a href=\"/recruite/vision/\">企業ビジョン</a></li>\n<li><a href=\"/recruite/culture/\">企業文化</a></li>\n<li><a href=\"/recruite/carrier_plan/\">教育・キャリアプラン</a> </li>\n<li><a href=\"/recruite/guideline/\">募集要項</a> </li>\n<li><a href=\"/recruite/form/\" target=\"_blank\">お問い合わせ</a> </li>\n</ul>\n</dd>\n</dl>\n<dl>\n<dt>Interview </dt>\n<dd>\n<ul>\n<li><a href=\"/recruite/interview/marketing.html\">新垣 凜／與久田 藍香</a></li>\n<li><a href=\"/recruite/interview/akamine.html\">赤嶺 孝太</a></li>\n</ul>\n</dd>\n</dl>\n</nav>\n</div>\n</div>\n<p class=\"copyright\">&copy; Okinawa Coca-Cola Bottling. All rigts reserved.</p>\n</footer>\n<!--/footer-->\n<p class=\"pagetop\"><a href=\"#wrapper\"><img src=\"/recruite/img/pagetop.png\" alt=\"このページのトップへ\"/></a></p>\n<!--SNSボタン-->\n<div id=\"sns\"><a href=\"https://youtube.com/channel/UChsB29BLuWGsuVKFCWQSERA?si=pPadrNdcxwR5iD5V\" target=\"_blank\"><span class=\"icon-youtube\"></span>Youtube</a><a href=\"https://www.instagram.com/okinawa_cocacola_recruit/\" target=\"_blank\"><span class=\"icon-instagram\"></span>Instagram</a></div> \n</div>\n<!--スクリプト--> \n<script src=\"https://cdnjs.cloudflare.com/ajax/libs/Swiper/4.4.1/js/swiper.min.js\"></script> \n<script>\n\n//Initialize Swiper for mainimage\n    var swiper = new Swiper('.mainimage', {\n\t    effect: 'fade',\n     speed: 3000,\n     autoplay: {\n      delay: 4000,\n    },\n    });\n  </script> \n<script type=\"text/javascript\" src=\"/recruite/js/jetmenu.js\"></script> \n<script type=\"text/javascript\" src=\"/recruite/js/common.js\"></script>\n</body>\n</html>\n","finalUrl":"https://www.okinawa.ccbc.co.jp/recruite/","rendered":false,"_cachedAt":"2026-06-17T23:16:43.650Z"}