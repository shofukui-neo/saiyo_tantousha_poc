{"url":"https://corp.jac-recruitment.jp/recruit/workplace/workenvironment/","html":"<!doctype html>\r\n<html lang=\"ja\">\r\n<head>\r\n<meta charset=\"utf-8\">\r\n  <meta name=\"robots\" content=\"noindex\" />\r\n  <script>\r\n    location.replace(\"https://recruit.jacgroup.com/workplace/workenvironment/\");\r\n  </script>\r\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\r\n<title>制度・環境｜採用情報｜転職・人材紹介のJAC Recruitment</title>\r\n<meta name=\"description\" content=\"JAC Recruitmentの採用情報、各種制度・環境を紹介しています。\">\r\n<analyticsOUT></analyticsOUT>\r\n\r\n<link rel=\"shortcut icon\" href=\"/recruit/common/images/favicon.ico\" />\r\n\r\n<link rel=\"stylesheet\" href=\"/recruit/common/css/master.css\">\r\n<script src=\"/recruit/common/js/init.js\"></script>\r\n\t\r\n</head>\r\n\r\n<body>\r\n<!-- Google Tag Manager (noscript) -->\r\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-NMMNH8P3\"\r\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\r\n<!-- End Google Tag Manager (noscript) -->\r\n<header-underlayerOUT></header-underlayerOUT>\r\n\r\n<hr>\r\n\r\n<div class=\"site-heading\">\r\n<div class=\"outer\">\r\n<nav class=\"nav-breadcrumb\" aria-label=\"Breadcrumb\">\r\n<ul>\r\n<li><a href=\"/recruit/\">採用トップ</a></li>\r\n<li><a href=\"/recruit/workplace/\">制度・環境</a></li>\r\n<li><a aria-current=\"true\">制度・環境</a></li>\r\n</ul>\r\n</nav>\r\n\r\n<h1 class=\"heading-01\">制度・環境</h1>\r\n</div><!-- /.str-outer -->\r\n</div><!-- /.site-heading -->\r\n\r\n\r\n<!--main-content-->\r\n<main>\r\n\r\n\r\n\r\n<div class=\"str-outer\">\r\n<div class=\"str-inner\">\r\n\r\n<div class=\"mod-text-lead\">\r\n<p class=\"text\">ジェイ エイ シー リクルートメントでは社員1人ひとりが働きやすい環境づくりに取り組んでいます。</p>\r\n</div><!-- /.mod-text-lead -->\r\n\r\n<div class=\"mod-link-page\">\r\n<ul>\r\n<li><a href=\"#anchor-03\">健康経営</a></li>\r\n<li><a href=\"#anchor-02\">育児支援</a></li>\r\n<li><a href=\"#anchor-01\">福利厚生</a></li>\r\n<li><a href=\"#anchor-04\">表彰制度</a></li>\r\n</ul>\r\n</div><!-- /.mod-link-page -->\r\n\r\n</div><!-- /.str-inner -->\r\n</div><!-- /.str-outer -->\r\n\r\n\r\n<section>\r\n<div class=\"str-outer\">\r\n<div class=\"str-inner\">\r\n\r\n<div class=\"mod-heading-img of-type-img-03\" id=\"anchor-03\">\r\n<h2 class=\"title\">健康経営の取り組み</h2>\r\n</div><!-- /.mod-heading-img -->\r\n\r\n<div class=\"mod-heading-04\">\r\n<h3 class=\"title\">働き方・勤務制度支援</h3>\r\n</div>\r\n\t\r\n<div class=\"mod-box-text of-col3\">\r\n<div class=\"box\">\r\n<h4 class=\"head\">7時間労働制</h4>\r\n<div class=\"content\">\r\n<p class=\"text\">基本就業時間、9:30〜17:30の7時間労働制です。社員の健康と生産性を考慮した勤務体系を採用しています。</p>\r\n</div><!-- /.content -->\r\n</div><!-- /.box -->\r\n\r\n<div class=\"box\">\r\n<h4 class=\"head\">フレックスタイム制度</h4>\r\n<div class=\"content\">\r\n<p class=\"text\">11:00〜16:00をコアタイムとし、月の所定労働時間を満たす範囲で、日々の勤務時間を柔軟に調整できます。</p>\r\n</div><!-- /.content -->\r\n</div><!-- /.box -->\r\n\t\r\n<div class=\"box\">\r\n<h3 class=\"head\">22時退勤ルール</h3>\r\n<div class=\"content\">\r\n<p class=\"text\">社員の健康を守るため、22時〜翌営業日7時まで、PCが自動的にロックされる仕組みを導入しています。</p>\r\n</div><!-- /.content -->\r\n</div><!-- /.box -->\r\n\r\n</div><!-- /.mod-box-text col3 -->\r\n\r\n\t\r\n<div class=\"mod-heading-04\">\r\n<h3 class=\"title\">健康促進・ウェルビーイング支援</h3>\r\n</div>\r\n\t\r\n<div class=\"mod-box-text of-col3\">\r\n\t\r\n<div class=\"box\">\r\n<h4 class=\"head\">社員喫煙率0％への取り組み</h4>\r\n<div class=\"content\">\r\n<p class=\"text\">非喫煙者の採用を基本方針としており、就業時間中の喫煙も禁止しています。喫煙社員には禁煙治療補助も行っています。</p>\r\n</div><!-- /.content -->\r\n</div><!-- /.box -->\t\r\n\r\n<div class=\"box\">\r\n<h4 class=\"head\">運動施設の利用補助</h4>\r\n<div class=\"content\">\r\n<p class=\"text\">スポーツクラブなどの運動施設利用に対して、月最大4,000円までの補助をしています。</p>\r\n</div><!-- /.content -->\r\n</div><!-- /.box -->\r\n\t\r\n<div class=\"box\">\r\n<h4 class=\"head\">ヘルシーチャレンジ</h4>\r\n<div class=\"content\">\r\n<p class=\"text\">運動量に応じてポイントが付与され、月間で一定のポイントを達成すると、最大1,500円の支給がされます。</p>\r\n</div><!-- /.content -->\r\n</div><!-- /.box -->\r\n\r\n<div class=\"box\">\r\n<h4 class=\"head\">高機能オフィスチェア</h4>\r\n<div class=\"content\">\r\n<p class=\"text\">長時間のデスクワークでも負担が少ない高機能オフィスチェアを全社員に提供しています。</p>\r\n</div><!-- /.content -->\r\n</div><!-- /.box -->\r\n\t\r\n<div class=\"box\">\r\n<h4 class=\"head\">オフィス内休養室</h4>\r\n<div class=\"content\">\r\n<p class=\"text\">体調がすぐれないときに、横になれる休養室を男女別々に設置しています。(※一部拠点)</p>\r\n</div><!-- /.content -->\r\n</div><!-- /.box -->\r\n\r\n<div class=\"box\">\r\n<h4 class=\"head\">Powernap Room</h4>\r\n<div class=\"content\">\r\n<p class=\"text\">短時間の昼寝が可能な、昼寝専用部屋を男女別々に設置しています。(※東京本社)</p>\r\n</div><!-- /.content -->\r\n</div><!-- /.box -->\r\n\r\n</div><!-- /.mod-box-text col3 -->\r\n\r\n</div><!-- /.str-inner -->\r\n</div><!-- /.str-outer -->\r\n\r\n\r\n<div class=\"str-outer\">\r\n<div class=\"str-inner\">\r\n\r\n<div class=\"mod-link-page\">\r\n<ul>\r\n<li><a href=\"#anchor-03\">健康経営</a></li>\r\n<li><a href=\"#anchor-02\">育児支援</a></li>\r\n<li><a href=\"#anchor-01\">福利厚生</a></li>\r\n<li><a href=\"#anchor-04\">表彰制度</a></li>\r\n</ul>\r\n</div><!-- /.mod-link-page -->\r\n\r\n<div class=\"mod-heading-img of-type-img-02\" id=\"anchor-02\">\r\n<h2 class=\"title\">育児支援制度</h2>\r\n</div><!-- /.mod-heading-img -->\r\n\r\n<div class=\"mod-heading-04\">\r\n<h3 class=\"title\">育児と仕事の両立支援</h3>\r\n</div>\r\n\t\r\n<div class=\"mod-box-text of-col3\">\t\r\n<div class=\"box\">\r\n<h4 class=\"head\">育児休業制度</h4>\r\n<div class=\"content\">\r\n<p class=\"text\">1歳6ヶ月未満の子どもを育てている社員は、会社の規定に基づいて育児休業を取得できます。</p>\r\n</div><!-- /.content -->\r\n</div><!-- /.box -->\r\n\t\t\r\n<div class=\"box\">\r\n<h4 class=\"head\">時短勤務制度</h4>\r\n<div class=\"content\">\r\n<p class=\"text\">育児中の社員は、1日5時間以上の短時間勤務を選択できます。家庭と仕事の両立を支援する制度です。</p>\r\n</div><!-- /.content -->\r\n</div><!-- /.box -->\r\n\r\n<div class=\"box\">\r\n<h4 class=\"head\">在宅勤務制度</h4>\r\n<div class=\"content\">\r\n<p class=\"text\">業務内容や社員の状況に応じて、在宅勤務が可能です。育児中の柔軟な働き方を支援します。</p>\r\n</div><!-- /.content -->\r\n</div><!-- /.box -->\t\r\n\r\n<div class=\"box\">\r\n<h4 class=\"head\">子の看護等休暇制度</h4>\r\n<div class=\"content\">\r\n<p class=\"text\">小学6年生までの子どもの、看病や入学式/卒業式（入園式/卒園式）などに、年5日まで有給休暇を取得できます。</p>\r\n</div><!-- /.content -->\r\n</div><!-- /.box -->\t\r\n\t\r\n<div class=\"box\">\r\n<h4 class=\"head\">目標軽減制度</h4>\r\n<div class=\"content\">\r\n<p class=\"text\">育児休業から復職した社員は、2回の評価期間にわたり、自身の希望に応じて業務目標やグレードを調整できます。</p>\r\n</div><!-- /.content -->\r\n</div><!-- /.box -->\r\n\r\n</div><!-- /.mod-box-text col3 -->\t\r\n\r\n\t\r\n<div class=\"mod-heading-04\">\r\n<h3 class=\"title\">出産・育児の経済支援</h3>\r\n</div>\r\n<div class=\"mod-box-text of-col3\">\t\r\n\t\r\n<div class=\"box\">\r\n<h4 class=\"head\">出産休暇 + お祝い金</h4>\r\n<div class=\"content\">\r\n<p class=\"text\">子どもが生まれた際に、休暇の取得とお祝い金の支給があります。</p>\r\n</div><!-- /.content -->\r\n</div><!-- /.box -->\r\n\t\r\n<div class=\"box\">\r\n<h4 class=\"head\">出産手当金</h4>\r\n<div class=\"content\">\r\n<p class=\"text\">出産のために休職し給与が支払われない場合、健康保険組合から給与の約67％相当の手当金が支給されます。</p>\r\n</div><!-- /.content -->\r\n</div><!-- /.box -->\r\n\r\n<div class=\"box\">\r\n<h4 class=\"head\">出産育児一時金</h4>\r\n<div class=\"content\">\r\n<p class=\"text\">出産した際に、健康保険組合から50万円と付加給付3万5千円が支給されます。</p>\r\n</div><!-- /.content -->\r\n</div><!-- /.box -->\t\r\n\r\n<div class=\"box\">\r\n<h4 class=\"head\">出生後休業支援給付金</h4>\r\n<div class=\"content\">\r\n<p class=\"text\">子どもの出生後、夫婦ともに通算14日以上の育児休業を取得した場合、雇用保険から給与の約13％が支給されます。</p>\r\n</div><!-- /.content -->\r\n</div><!-- /.box -->\t\r\n\r\n<div class=\"box\">\r\n<h4 class=\"head\">育児手当金</h4>\r\n<div class=\"content\">\r\n<p class=\"text\">子育て中の社員に対して、仕事と育児の両立を支援するため、月額3万円〜10万円の範囲で育児手当金が支給されます。</p>\r\n</div><!-- /.content -->\r\n</div><!-- /.box -->\r\n\r\n<div class=\"box\">\r\n<h4 class=\"head\">育児休業給付金</h4>\r\n<div class=\"content\">\r\n<p class=\"text\">育児のために休職し給与が支払われない場合、雇用保険から最初の6ヶ月間は給与の約67％、それ以降は約50％が支給されます。</p>\r\n</div><!-- /.content -->\r\n</div><!-- /.box -->\t\r\n\t\r\n</div><!-- /.mod-box-text col3 -->\r\n\r\n\r\n<div class=\"mod-heading-04\">\r\n<h3 class=\"title\">育児社員へのサポート</h3>\r\n</div>\r\n\r\n<div class=\"mod-box-text of-col3\">\t\r\n<div class=\"box\">\r\n<h4 class=\"head\">Working Parents Community</h4>\r\n<div class=\"content\">\r\n<p class=\"text\">育児中の社員が自主的に集まり、情報交換や悩みの共有を行うコミュニティがあります。</p>\r\n</div><!-- /.content -->\r\n</div><!-- /.box -->\t\t\r\n\r\n<div class=\"box\">\r\n<h4 class=\"head\">Working Parents 管理職研修</h4>\r\n<div class=\"content\">\r\n<p class=\"text\">管理職向けに、育児中の部下を支援するためのマネジメント研修を実施しています。</p>\r\n</div><!-- /.content -->\r\n</div><!-- /.box -->\t\t\r\n\r\n<div class=\"box\">\r\n<h4 class=\"head\">子女へのクリスマスプレゼント</h4>\r\n<div class=\"content\">\r\n<p class=\"text\">希望する社員の小学生以下の子どもに、プレゼントとして、Uncle Taz（創業者：田崎 忠良）より図書券が贈られます。</p>\r\n</div><!-- /.content -->\r\n</div><!-- /.box -->\t\r\n\t\r\n</div><!-- /.mod-box-text col3 -->\r\n\r\n\r\n</div><!-- /.str-inner -->\r\n</div><!-- /.str-outer -->\r\n\r\n\t\t\r\n<div class=\"str-outer\">\r\n<div class=\"str-inner\">\r\n\r\n<div class=\"mod-link-page\">\r\n<ul>\r\n<li><a href=\"#anchor-03\">健康経営</a></li>\r\n<li><a href=\"#anchor-02\">育児支援</a></li>\r\n<li><a href=\"#anchor-01\">福利厚生</a></li>\r\n<li><a href=\"#anchor-04\">表彰制度</a></li>\r\n</ul>\r\n</div><!-- /.mod-link-page -->\r\n\t\r\n<div class=\"mod-heading-img\" id=\"anchor-01\">\r\n<h2 class=\"title\">福利厚生制度</h2>\r\n</div><!-- /.mod-heading-img -->\r\n\r\n<div class=\"mod-heading-04\">\r\n<h3 class=\"title\">資産形成・将来設計サポート</h3>\r\n</div>\r\n\r\n<div class=\"mod-box-text of-col3\">\r\n<div class=\"box\">\r\n<h3 class=\"head\">企業型確定拠出年金(企業型DC)</h3>\r\n<div class=\"content\">\r\n<p class=\"text\">会社が毎月積み立てる資金をもとに、社員自身が投資商品を選び、将来に向けて運用する制度です。</p>\r\n</div><!-- /.content -->\r\n</div><!-- /.box -->\r\n\r\n<div class=\"box\">\r\n<h3 class=\"head\">社員持株会制度</h3>\r\n<div class=\"content\">\r\n<p class=\"text\">社員が自社の株式を定期的に購入できる制度です。中長期的な資産形成を支援します。</p>\r\n</div><!-- /.content -->\r\n</div><!-- /.box -->\r\n\t\r\n<div class=\"box\">\r\n<h3 class=\"head\">財産形成貯蓄制度</h3>\r\n<div class=\"content\">\r\n<p class=\"text\">毎月の給与から一定額を自動的に貯金する制度です。将来に向けて計画的に資産を形成したい方に適しています。</p>\r\n</div><!-- /.content -->\r\n</div><!-- /.box -->\r\n\r\n<div class=\"box\">\r\n<h3 class=\"head\">譲渡制限株式交付(RS)制度</h3>\r\n<div class=\"content\">\r\n<p class=\"text\">一定の条件を満たした社員に、譲渡制限付きの自社株式が付与される制度です。（※対象条件あり）</p>\r\n</div><!-- /.content -->\r\n</div><!-- /.box -->\t\r\n</div><!-- /.mod-box-text col3 -->\r\n\r\n\t\r\n\t\r\n<div class=\"mod-heading-04\">\r\n<h3 class=\"title\">職場環境・交流・多様性支援</h3>\r\n</div>\r\n\r\n<div class=\"mod-box-text of-col3\">\r\n<div class=\"box\">\r\n<h3 class=\"head\">食事補助制度</h3>\r\n<div class=\"content\">\r\n<p class=\"text\">月3,500円の自己負担で、7,000円分の食事代を受け取れる制度です。希望者のみ利用可能です。</p>\r\n</div><!-- /.content -->\r\n</div><!-- /.box -->\r\n\t\r\n<div class=\"box\">\r\n<h3 class=\"head\">社内懇親費バウチャー</h3>\r\n<div class=\"content\">\r\n<p class=\"text\">社員同士の懇親会(飲食)に利用できる費用として、四半期ごとに1人あたり5,000円の予算が支給されます。</p>\r\n</div><!-- /.content -->\r\n</div><!-- /.box -->\t\r\n\r\n<div class=\"box\">\r\n<h3 class=\"head\">保養所(健康保険組合）</h3>\r\n<div class=\"content\">\r\n<p class=\"text\">東京実業健康保険組合が所有する保養所を、心身のリフレッシュを目的としてご利用いただけます。</p>\r\n</div><!-- /.content -->\r\n</div><!-- /.box -->\t\r\n\r\n<div class=\"box\">\r\n<h3 class=\"head\">ウォーターサーバー</h3>\r\n<div class=\"content\">\r\n<p class=\"text\">すべてのフロアにウォーターサーバーを設置しており、自由に利用できます。</p>\r\n</div><!-- /.content -->\r\n</div><!-- /.box -->\r\n\t\r\n<div class=\"box\">\r\n<h4 class=\"head\">設置型社食</h4>\r\n<div class=\"content\">\r\n<p class=\"text\">オフィス内で、健康的なお惣菜やサラダなどを100円で購入できるサービスです。（※一部拠点）</p>\r\n</div><!-- /.content -->\r\n</div><!-- /.box -->\r\n\t\r\n<div class=\"box\">\r\n<h3 class=\"head\">オフィス置き菓子</h3>\r\n<div class=\"content\">\r\n<p class=\"text\">オフィス内で気分転換としてお菓子を購入できるサービスです。</p>\r\n</div><!-- /.content -->\r\n</div><!-- /.box -->\t\r\n\t\r\n<div class=\"box\">\r\n<h3 class=\"head\">わくはぴ野菜販売(障がい者就労)</h3>\r\n<div class=\"content\">\r\n<p class=\"text\">障がい者支援の一環として、オフィスでわくはぴ農園で育てた野菜を1つ50円で購入できます。（※不定期）</p>\r\n</div><!-- /.content -->\r\n</div><!-- /.box -->\t\r\n\t\r\n<div class=\"box\">\r\n<h4 class=\"head\">社内クラブ(JACOC)活動支援</h4>\r\n<div class=\"content\">\r\n<p class=\"text\">部署や役職を超えて交流できる社内クラブ活動を支援しています。仲間づくりや社内コミュニケーションの活性化を目的としています。</p>\r\n</div><!-- /.content -->\r\n</div><!-- /.box -->\t\r\n\t\r\n<div class=\"box\">\r\n<h3 class=\"head\">同性婚、内縁婚</h3>\r\n<div class=\"content\">\r\n<p class=\"text\">DE&I（多様性・公平性・包括性）の取り組みの一環として、同性婚・内縁関係・法律婚のいずれも、同じ社内サービスの対象となります。</p>\r\n</div><!-- /.content -->\r\n</div><!-- /.box -->\r\n</div><!-- /.mod-box-text col3 -->\r\n\r\n\t\r\n<div class=\"mod-heading-04\">\r\n<h3 class=\"title\">ライフイベント・休暇支援</h3>\r\n</div>\r\n\t\r\n<div class=\"mod-box-text of-col3\">\r\n\r\n<div class=\"box\">\r\n<h3 class=\"head\">介護休業制度</h3>\r\n<div class=\"content\">\r\n<p class=\"text\">要介護状態の家族を介護する必要がある場合、一定の条件のもとで休業が可能な制度です。</p>\r\n</div><!-- /.content -->\r\n</div><!-- /.box -->\r\n\r\n<div class=\"box\">\r\n<h3 class=\"head\">積立有給休暇制度</h3>\r\n<div class=\"content\">\r\n<p class=\"text\">有給休暇を積み立てておき、長期の病気や家族の介護など、急な長期休職が必要な際に利用できる制度です。</p>\r\n</div><!-- /.content -->\r\n</div><!-- /.box -->\r\n\r\n<div class=\"box\">\r\n<h3 class=\"head\">不妊治療休暇制度</h3>\r\n<div class=\"content\">\r\n<p class=\"text\">不妊治療と仕事の両立を支援するために、不妊治療に取り組む社員が安心して治療に専念できる休暇制度です。</p>\r\n</div><!-- /.content -->\r\n</div><!-- /.box -->\t\r\n\t\r\n<div class=\"box\">\r\n<h3 class=\"head\">慶事祝い金、休暇</h3>\r\n<div class=\"content\">\r\n<p class=\"text\">社員本人や家族の結婚・出産などのお祝い事に際して、休暇の取得やお祝い金の支給があります。</p>\r\n</div><!-- /.content -->\r\n</div><!-- /.box -->\t\t\t\r\n\r\n<div class=\"box\">\r\n<h3 class=\"head\">弔事お香典、休暇</h3>\r\n<div class=\"content\">\r\n<p class=\"text\">社員本人または家族の弔事に際して、休暇の取得やお香典の支給を受けられる制度です。</p>\r\n</div><!-- /.content -->\r\n</div><!-- /.box -->\r\n\r\n<div class=\"box\">\r\n<h3 class=\"head\">語学留学休職制度</h3>\r\n<div class=\"content\">\r\n<p class=\"text\">英語力向上を目的とした語学留学のために、一定期間の休職が可能な制度です。（※利用条件あり）</p>\r\n</div><!-- /.content -->\r\n</div><!-- /.box -->\t\r\n\t\r\n</div><!-- /.mod-box-text col3 -->\r\n\r\n\r\n<div class=\"mod-heading-04\">\r\n<h3 class=\"title\">医療・生命保険支援</h3>\r\n</div>\r\n\t\r\n<div class=\"mod-box-text of-col3\">\r\n<div class=\"box\">\r\n<h4 class=\"head\">健康診断/人間ドック受診促進<br>及び費用補助</h4>\r\n<div class=\"content\">\r\n<p class=\"text\">社員の健康維持を目的として、定期的な健康診断や人間ドックの受診を推奨しており、費用の一部を会社が補助します。</p>\r\n</div><!-- /.content -->\r\n</div><!-- /.box -->\r\n\r\n<div class=\"box\">\r\n<h4 class=\"head\">インフルエンザ予防接種の実施<br>及び費用補助</h4>\r\n<div class=\"content\">\r\n<p class=\"text\">社員の健康管理の一環として、インフルエンザ予防接種の費用を会社が補助しております。</p>\r\n</div><!-- /.content -->\r\n</div><!-- /.box -->\r\n\r\n<div class=\"box\">\r\n<h3 class=\"head\">総合福祉団体<br>定期保険</h3>\r\n<div class=\"content\">\r\n<p class=\"text\">社員が万が一亡くなった場合に備えた保険制度です。保険料はすべて会社が負担します。</p>\r\n</div><!-- /.content -->\r\n</div><!-- /.box -->\r\n\r\n<div class=\"box\">\r\n<h4 class=\"head\">無料歯科検診の実施</h4>\r\n<div class=\"content\">\r\n<p class=\"text\">社員のデンタルケア支援の一環として、年に1回、オフィス内で無料の歯科検診を実施しています。（※一部拠点）</p>\r\n</div><!-- /.content -->\r\n</div><!-- /.box -->\r\n\r\n\r\n<div class=\"box\">\r\n<h4 class=\"head\">常備薬、救急セットの設置</h4>\r\n<div class=\"content\">\r\n<p class=\"text\">社員の急な体調不良に備え、オフィス内に常備薬や救急セットを設置しております。</p>\r\n</div><!-- /.content -->\r\n</div><!-- /.box -->\r\n</div><!-- /.mod-box-text col3 -->\r\n\r\n\r\n</div><!-- /.str-inner -->\r\n</div><!-- /.str-outer -->\r\n\r\n\r\n\r\n<div class=\"str-outer\">\r\n<div class=\"str-inner\">\r\n\r\n<div class=\"mod-link-page\">\r\n<ul>\r\n<li><a href=\"#anchor-03\">健康経営</a></li>\r\n<li><a href=\"#anchor-02\">育児支援</a></li>\r\n<li><a href=\"#anchor-01\">福利厚生</a></li>\r\n<li><a href=\"#anchor-04\">表彰制度</a></li>\r\n</ul>\r\n</div><!-- /.mod-link-page -->\r\n\r\n<div class=\"mod-heading-img of-type-img-04\" id=\"anchor-04\">\r\n<h2 class=\"title\">表彰制度</h2>\r\n</div><!-- /.mod-heading-img -->\r\n\r\n<div class=\"mod-heading-04\">\r\n<h3 class=\"title\">新人・若手社員の活躍表彰</h3>\r\n</div>\r\n\t\r\n<div class=\"mod-box-text of-col3\">\r\n<div class=\"box\">\r\n<h3 class=\"head\">新人賞</h3>\r\n<div class=\"content\">\r\n<p class=\"text\">前年12月31日から当年12月31日までに中途入社した社員の中で、特に優れた成果を上げた方を表彰します。</p>\r\n</div><!-- /.content -->\r\n</div><!-- /.box -->\r\n\r\n<div class=\"box\">\r\n<h3 class=\"head\">ルーキー賞</h3>\r\n<div class=\"content\">\r\n<p class=\"text\">当年度に新卒入社した社員の中で、最も活躍した方を表彰する制度です。</p>\r\n</div><!-- /.content -->\r\n</div><!-- /.box -->\r\n\r\n</div><!-- /.mod-box-text col3 -->\r\n\t\r\n<div class=\"mod-heading-04\">\r\n<h3 class=\"title\">業績・貢献に対する表彰</h3>\r\n</div>\r\n\t\r\n<div class=\"mod-box-text of-col3\">\r\n<div class=\"box\">\r\n<h3 class=\"head\">月間MVP/年間MVP</h3>\r\n<div class=\"content\">\r\n<p class=\"text\">毎月・毎年の売上が最も高かったコンサルタントを表彰。成果を正当に評価し、モチベーション向上につなげます。</p>\r\n</div><!-- /.content -->\r\n</div><!-- /.box -->\r\n\r\n<div class=\"box\">\r\n<h3 class=\"head\">ベストチーム賞</h3>\r\n<div class=\"content\">\r\n<p class=\"text\">月間・年間の業績が最も優秀だったチームを表彰します。</p>\r\n</div><!-- /.content -->\r\n</div><!-- /.box -->\r\n\r\n<div class=\"box\">\r\n<h3 class=\"head\">永年勤続表彰制度</h3>\r\n<div class=\"content\">\r\n<p class=\"text\">長年、会社に在籍し、継続的に貢献している社員を表彰。勤続5年・10年・20年の節目にカードと旅行券が贈られます。</p>\r\n</div><!-- /.content -->\r\n</div><!-- /.box -->\r\n</div><!-- /.mod-box-text col3 -->\r\n\r\n<div class=\"mod-link-page\">\r\n<ul>\r\n<li><a href=\"#anchor-03\">健康経営</a></li>\r\n<li><a href=\"#anchor-02\">育児支援</a></li>\r\n<li><a href=\"#anchor-01\">福利厚生</a></li>\r\n<li><a href=\"#anchor-04\">表彰制度</a></li>\r\n</ul>\r\n</div><!-- /.mod-link-page -->\r\n\r\n</div><!-- /.str-inner -->\r\n</div><!-- /.str-outer -->\r\n\r\n</section>\r\n\r\n</main>\r\n<!--/.main-content-->\r\n\r\n\r\n\r\n<section class=\"sct-recruit of-mt\">\r\n<div class=\"site-recruit\">\r\n<div class=\"outer\">\r\n<div class=\"inner\">\r\n\r\n\r\n<h2 class=\"title\"><font size=\"7\">JAC Group 採用情報</font></h2>\r\n<ul class=\"mod-index-box\">\r\n<li><font size=\"6\">新卒採用</font><a href=\"/recruit/entry/new-graduate.html\">詳しく見る</a></li>\r\n<li><font size=\"6\">キャリア/中途採用</font><a href=\"/recruit/entry/career.html\">詳しく見る</a></li>\r\n<li><font size=\"6\">海外採用</font><a href=\"/recruit/entry/overseas1.html\">詳しく見る</a></li>\r\n</ul>\r\n\r\n\r\n</div><!-- /.inner -->\r\n</div><!-- /.outer -->\r\n</div><!-- /.site-recruit -->\r\n</section>\r\n\r\n\r\n\r\n<footerOUT></footerOUT>\r\n\r\n\r\n\r\n<script src=\"/recruit/common/js/jquery.js\"></script>\r\n<script src=\"/recruit/common/js/run.js\"></script>\r\n\r\n<script>\r\n    $(function(){\r\n        $.ajaxSetup({cache:false});\r\n        $(\"analyticsOUT\").load(\"/recruit/common/inc/analytics.html\");\r\n    }); \r\n    </script>\r\n    <script>\r\n    $(function(){\r\n        $.ajaxSetup({cache:false});\r\n        $(\"headerOUT\").load(\"/recruit/common/inc/header.html\");\r\n    }); \r\n    </script>\r\n<script>\r\n    $(function(){\r\n        $.ajaxSetup({cache:false});\r\n        $(\"header-underlayerOUT\").load(\"/recruit/common/inc/header-underlayer.html\");\r\n    }); \r\n    </script>\r\n    <script>\r\n    $(function(){\r\n        $.ajaxSetup({cache:false});\r\n        $(\"footerOUT\").load(\"/recruit/common/inc/footer.html\");\r\n    }); \r\n    </script>\r\n\t\r\n\t\r\n</body>\r\n</html>\r\n","finalUrl":"https://corp.jac-recruitment.jp/recruit/workplace/workenvironment/","rendered":false,"_cachedAt":"2026-06-22T21:37:30.186Z"}