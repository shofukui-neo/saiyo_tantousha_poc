{"url":"http://www.k-futaba.co.jp/cont.html","html":"<!DOCTYPE HTML>\n<html lang=\"ja\"><!-- InstanceBegin template=\"/Templates/index.dwt\" codeOutsideHTMLIsLocked=\"false\" -->\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width\">\n<meta http-equiv=\"CONTENT-TYPE\" content=\"IE=9\" >\n<meta name=\"Keywords\" content=\"鉄鋼製品,亜鉛めっき,めっき,鉄骨\" />\n<meta name=\"Description\" content=\"双葉工業社は鉄鋼製品の加工、亜鉛めっきによる防食加工など品質・機能・納期・価格でお客様にご満足いただける製品をお届けいたします。道内屈指の大型めっき槽による優れた生産性、機動力を発揮した各種鉄塔・鉄柱・鉄構製造、設計・加工・組立までお客様のニーズに合わせた技術をご提供いたします。\" />\n<!-- InstanceBeginEditable name=\"doctitle\" -->\n<title>お問い合わせ｜株式会社双葉工業社 鉄鋼製品の加工・亜鉛めっきによる防食加工のことならお任せください。</title>\n<script src=\"js/jquery-3.2.1.min.js\"></script>\n<link rel=\"stylesheet\" href=\"mailform/mailform.css\" type=\"text/css\">\n<script type=\"text/javascript\" src=\"mailform/mailform.js\" charset=\"utf-8\"></script>\n<script type=\"text/javascript\" src=\"mailform/postcodes/get.cgi?js\" charset=\"utf-8\"></script>\n<!-- InstanceEndEditable -->\n<link href=\"css/main.css\" rel=\"stylesheet\" type=\"text/css\"/>\n<link href=\"css/page.css\" rel=\"stylesheet\" type=\"text/css\"/>\n<link href=\"css/moji.css\" rel=\"stylesheet\" type=\"text/css\"/>\n<link href=\"css/menu.css\" rel=\"stylesheet\" type=\"text/css\"/>\n<link href=\"css/auto.css\" rel=\"stylesheet\" type=\"text/css\" />\n<link href=\"css/font.css\" rel=\"stylesheet\" type=\"text/css\"/>\n<script src=\"http://ajax.googleapis.com/ajax/libs/jquery/1.11.3/jquery.min.js\"></script>\n<script src=\"js/script.js\"></script>\n<script src=\"js/analytics.js\"></script>\n<!--[if lt IE 9]>\n<script src=\"js/html5.js\"></script>\n<script src=\"js/css3-mediaqueries.js\"></script>\n<![endif]-->\n\n<!-- InstanceBeginEditable name=\"head\" -->\n<!-- InstanceEndEditable -->\n</head>\n<body>\n\n<!-- ヘッダー ここから -->\n<header>\n  <div class=\"head-main\">\n    <h1 class=\"logo spmini1\"><a href=\"index.html\" title=\"株式会社双葉工業社HOMEへ\"><img src=\"img/logo.png\" alt=\"鉄鋼製品の加工・亜鉛めっきによる防食加工 株式会社双葉工業社\"></a></h1>\n    <div class=\"button3 sphide\"> <a href=\"cont.html\"><span class=\"mail-solid icon\"></span>お問い合わせ</a> </div>\n    \n    <!-- nav sp ここから -->\n    <nav class=\"spdisp\">\n      <div class=\"button-toggle\"><img src=\"img/menu.png\" alt=\"メニュー\"></div>\n      <div class=\"menu\">\n        <ul>\n        <li><a href=\"index.html\">HOMEへ</a></li>\n        <li><a href=\"index.html#cont1_youtube\">ビデオ</a></li>\n        <li><a href=\"info.html\">会社概要</a></li>\n        <li><a href=\"busi.html\">業務内容</a></li>\n        <li><a href=\"achieve.html\">施工実績</a></li>\n        <li><a href=\"fact.html\">工場案内</a></li>\n        <li><a href=\"recu.html\">採用情報</a></li>\n        <li><a href=\"cont.html\">お問い合わせ</a></li>\n      </ul>\n      </div>\n    </nav>\n    <!-- nav sp ここまで --> \n    \n    <!-- nav pc ここから -->\n    <nav>\n      <div class=\"nav-box1 sphide\">\n        <ul>\n          <li class=\"button4 g-font3 thick1\"><a href=\"index.html\" title=\"ホーム\">ホーム<br>\n  <span class=\"mini-p3\">HOME</span></a></li>\n\t\t<li class=\"button4 g-font3 thick1\"><a href=\"index.html#cont1_youtube\" title=\"ビデオ\">ビデオ<br>\n<span class=\"mini-p3\">VIDEO</span></a></li>\n\t\t<li class=\"button4 g-font3 thick1\"><a href=\"info.html\" title=\"会社概要\">会社概要<br>\n<span class=\"mini-p3\">COMPANY</span></a></li>\n\t\t<li class=\"button4 g-font3 thick1\"><a href=\"busi.html\" title=\"業務内容\">業務内容<br>\n<span class=\"mini-p3\">BUSINESS</span></a></li>\n\t\t<li class=\"button4 g-font3 thick1\"><a href=\"achieve.html\" title=\"施工実績\">施工実績<br>\n<span class=\"mini-p3\">ACHIEVEMENT</span></a></li>\n\t\t<li class=\"button4 g-font3 thick1\"><a href=\"fact.html\" title=\"工場案内\">工場案内<br>\n<span class=\"mini-p3\">FACTORY</span></a></li>\n\t\t<li class=\"button4 g-font3 thick1\"><a href=\"recu.html\" title=\"採用情報\">採用情報<br>\n<span class=\"mini-p3\">RECRUIT</span></a></li>\n        </ul>\n      </div>\n    </nav>\n    <!-- nav pc ここまで --> \n  </div>\n</header>\n<!-- ヘッダー ここまで --> \n\n<!-- メイン画像ー ここから --><!-- InstanceBeginEditable name=\"EditRegion1\" -->\n  <div class=\"backpic1\">\n    <h2 class=\"caption4 g-font3\">お問い合わせ</h2>\n    <span class=\"mini-p\">CONTACT</span></div>\n  <!-- InstanceEndEditable --> \n<!-- メイン画像ー ここまで --> \n\n<!-- パンクズ ここから --><!-- InstanceBeginEditable name=\"EditRegion5\" -->\n<div class=\"pankuzu\">\n  <div class=\"topicpath\">\n    <ul class=\"bread_list\">\n      <li><a href=\"index.html\">ホーム</a></li>\n      <li>お問い合わせ</li>\n    </ul>\n  </div>\n</div>\n<!-- InstanceEndEditable --> \n\n<!-- パンクズ ここまで --> \n\n<!-- コンテンツ ここから --> \n\n<!-- InstanceBeginEditable name=\"EditRegion2\" -->\n  <section>\n    <div class=\"layout-3-box1\">\n    <h2 class=\"g-font3 t-4\"><span class=\"sen-1\">メールでのお問い合わせ</span></h2>\n      <p class=\"p-4\">株式会社双葉工業社へのお問い合わせは、以下のフォームよりお問い合わせ下さい。<br>\n        折り返し担当者より返信させていただきます。<br>\n        当社のプライバシーポリシーとして、ここで得た個人情報を他の目的について使用することはございません。 </p>\n      <form id=\"mailform\" method=\"post\" action=\"mailform/send.cgi\" onsubmit=\"return sendmail(this);\">\n        <table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" class=\"mailform\" summary=\"mailform main\">\n          <tr class=\"mfptr\">\n            <th>お問い合わせ内容</th>\n            <td><p>\n                <input type=\"checkbox\" name=\"お問い合わせ内容\" id=\"お問い合わせ内容2\" value=\"取り扱い製品について\" class=\"mfp\" />\n                取り扱い製品について</p>\n                <p class=\"ma-td2\">\n                <input type=\"checkbox\" name=\"お問い合わせ内容\" id=\"お問い合わせ内容2\" value=\"新規採用について\" class=\"mfp\" />\n                新規採用について</p>\n              <p class=\"ma-td2\">\n                <input type=\"checkbox\" name=\"お問い合わせ内容\" id=\"お問い合わせ内容2\" value=\"その他お問合わせ\" class=\"mfp\" />\n                その他お問合わせ</p>\n              <p></td>\n          </tr>\n          <tr class=\"mfptr\">\n            <th><img src=\"mailform/images/item4.png\" width=\"84\" alt=\"必須\" class=\"must\" />メールアドレス</th>\n            <td><input type=\"text\" name=\"email(必須)\" size=\"50\" maxlength=\"50\" class=\"mf\" />\n              <p class=\"from-p2\">受信拒否設定の解除もしくは弊社ドメイン「&#107;&#45;&#102;&#117;&#116;&#97;&#98;&#97;&#46;&#99;&#111;&#46;&#106;&#112;」からのメールが迷惑メールとして認識されないよう設定をお願いいたします。</p></td>\n          </tr>\n          <tr class=\"mfptr\">\n            <th><img src=\"mailform/images/item4.png\" width=\"84\" alt=\"必須\" class=\"must\" />会社名</th>\n            <td><input name=\"会社名(必須)\" type=\"text\" id=\"name3\" size=\"30\"  /></td>\n          </tr>\n          <tr class=\"mfptr\">\n            <th><img src=\"mailform/images/item4.png\" width=\"84\" alt=\"必須\" class=\"must\" />お名前</th>\n            <td><input name=\"お名前(必須)\" type=\"text\" id=\"name3\" size=\"30\"  /></td>\n          </tr>\n          <tr class=\"mfptr\">\n            <th>フリガナ</th>\n            <td><input name=\"フリガナ\" type=\"text\" id=\"tel4\" size=\"30\" /></td>\n          </tr>\n          <tr class=\"mfptr\">\n            <th><img src=\"mailform/images/item4.png\" width=\"84\" alt=\"必須\" class=\"must\" />電話番号</th>\n            <td><input name=\"電話番号(必須)\" type=\"text\" id=\"tel\" size=\"30\" /></td>\n          </tr>\n          <tr class=\"mfptr\">\n            <th>ご住所</th>\n            <td><input name=\"ご住所\" type=\"text\" id=\"tel4\" size=\"30\" /></td>\n          </tr>\n          <tr class=\"mfptr\">\n            <th><img src=\"mailform/images/item4.png\" width=\"84\" alt=\"必須\" class=\"must\" />ご用件内容</th>\n            <td><textarea name=\"ご用件内容(必須)\" rows=\"8\" cols=\"40\" id=\"detail\" placeholder=\"ご質問やご用件などご記入ください。\" class=\"add\"></textarea>\n              <div id=\"errormsg_お問い合わせ\" class=\"mfp_err\"></div></td>\n          </tr>\n          <tr class=\"mfptr\">\n            <th>送信 </th>\n            <td><input type=\"submit\" name\"submit\" value=\"送信する\" class=\"send-bo\" /></td>\n          </tr>\n        </table>\n      </form>\n    </div>\n  </section>\n  <!-- InstanceEndEditable --> \n\n<!-- コンテンツ ここまで --> \n\n<!-- フッター ここから -->\n<footer>\n  <div class=\"footmain\">\n  <!-- \n    <div class=\"foot2\">\n      <iframe src=\"https://www.google.com/maps/embed?pb=!1m14!1m8!1m3!1d11655.10884118754!2d141.34935!3d43.088179!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x1f0ae71458e33ef4!2z77yI5qCq77yJ5Y-M6JGJ5bel5qWt56S-!5e0!3m2!1sja!2sjp!4v1518278705607\" width=\"100%\" height=\"100%\" frameborder=\"0\" style=\"border:0\" allowfullscreen></iframe>\n    </div>\n     -->\n    <div class=\"foot1\">\n      <div class=\"foot1-box1\">\n        <h5 class=\"logo2\"><img src=\"img/logo2.png\" alt=\"株式会社 双葉工業社\"></h5>\n        <p class=\"foot-p\">〒065-0022<br>\n          札幌市東区北22条東1丁目1番50号<br>\n          TEL:011-721-6391 FAX:011-721-6395</p>\n      </div>\n        <ul class=\"foot1-box2\">\n        　<li class=\"button6 nav-td1\"><a href=\"index.html\">HOME</a></li>\n          <li class=\"button6 nav-td1\"><a href=\"index.html#cont1_youtube\">ビデオ</a></li>\n          <li class=\"button6 nav-td1\"><a href=\"info.html\">会社概要</a></li>\n          <li class=\"button6 nav-td1\"><a href=\"busi.html\">業務内容</a></li>\n          <li class=\"button6 nav-td1\"><a href=\"achieve.html\">施工実績</a></li>\n          <li class=\"button6 nav-td1\"><a href=\"fact.html\">工場案内</a></li>\n          <li class=\"button6 nav-td1\"><a href=\"recu.html\">採用情報</a></li>\n          <li class=\"button6 nav-td1\"><a href=\"cont.html\">お問い合わせ</a></li>\n        </ul>\n    </div>\n  </div>\n  <p class=\"copy-p\">Copyright © 株式会社双葉工業社. All rights reserved.</p>\n  <p class=\"pagetop\"><a href=\"header\">▲</a></p>\n</footer>\n<!-- フッター ここまで -->\n\n</body>\n<!-- InstanceEnd --></html>\n","finalUrl":"http://www.k-futaba.co.jp/cont.html","rendered":false,"_cachedAt":"2026-06-22T16:04:04.552Z"}