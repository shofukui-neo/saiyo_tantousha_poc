youtube.com/watch?v=lb4TjtOCngc\" target=\"_blank\">\r\n\t\t\t\t\t<div class=\"pht img-over\">\r\n\t\t\t\t\t\t<img src=\"/recruit/fresh/image/common/movie_pht.svg\" alt=\"会社説明動画を公開中！\">\r\n\t\t\t\t\t</div><!--- //pht --->\r\n\t\t\t\t\t<p class=\"link\">会社説明動画を公開中！</p>\r\n\t\t\t\t</a><!--- //linkbox --->\r\n\t\t\t</div><!--- //box --->\r\n\t\t</nav><!--- //localnav --->\r\n\t\t\r\n\t</nav><!--- //menunav --->\r\n</div><!--- //menubox --->\r\n\r\n\t\r\n\t\r\n\t\r\n\t\r\n<main id=\"main\">\r\n\t\r\n\t\r\n\t<div id=\"pagetitle\" class=\"atfirst01\">\r\n\t\t<div class=\"bg bg-gr-transparent\">\r\n\t\t\t<section class=\"inner\" data-aos=\"fade-up\" data-aos-duration=\"1500\" data-aos-once=\"true\">\r\n\r\n\t\t\t\t<div class=\"head c-white\">\r\n\t\t\t\t\t<p class=\"jp\">日本ハムについて</p>\r\n\t\t\t\t\t<p class=\"en\">[ ABOUT US ]</p>\r\n\t\t\t\t</div><!--- /head--->\r\n\r\n\t\t\t\t<h1 class=\"c-white\">はじめに知る日本ハム<br class=\"sp\"> - 前編</h1>\r\n\r\n\t\t\t\t<div class=\"breadcrumbs flex c-white\">\r\n\t\t\t\t\t⚫︎　<a href=\"/recruit/fresh/\">ホーム</a>　 /　<span>はじめに知る日本ハム - 前編</span>\r\n\t\t\t\t</div><!--- /breadcrumbs--->\r\n\r\n\t\t\t</section><!--- /inner--->\r\n\t\t</div><!--- /bg-gr-transparent --->\r\n\t</div><!--- /pagetitle --->\r\n\t\r\n\t<div id=\"atfirst01\" class=\"\">\r\n\t\t<section class=\"inner\">\r\n\t\t\t<div class=\"theme\">\r\n\t\t\t\t<div class=\"flex\" data-aos=\"fade-up\" data-aos-duration=\"1500\" data-aos-once=\"true\">\r\n\t\t\t\t\t<div class=\"txt\">\r\n\t\t\t\t\t\t<!-- <p class=\"en\">[THEME]</p> -->\r\n\t\t\t\t\t\t<p class=\"\">私たちは、<span>「食べる喜び」</span>を基本テーマに掲げ、<br>人々の楽しく健やかな暮らしに貢献しています。</p>\r\n\t\t\t\t\t</div>\r\n\t\t\t\t\t<div class=\"pht\">\r\n\t\t\t\t\t\t<img src=\"image/atfirst01/theme01.png\" alt=\"\">\r\n\t\t\t\t\t</div>\r\n\t\t\t\t</div>\r\n\t\t\t\t<div class=\"cntnr\" data-aos=\"fade-up\" data-aos-duration=\"1500\" data-aos-once=\"true\">\r\n\t\t\t\t\t<h2 class=\"\">企業理念</h2>\r\n\t\t\t\t\t<div class=\"cntnt\">\r\n\t\t\t\t\t\t<div class=\"box\">\r\n\t\t\t\t\t\t\t<p class=\" en\">01</p>\r\n\t\t\t\t\t\t\t<p class=\"\">わが社は、「食べる喜び」を基本のテーマとし、時代を画する文化を創造し、社会に貢献する。</p>\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t<div class=\"box\">\r\n\t\t\t\t\t\t\t<p class=\" en\">02</p>\r\n\t\t\t\t\t\t\t<p class=\"\">わが社は、従業員が真の幸せと生き甲斐を求める場として存在する。</p>\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t</div>\r\n\t\t\t\t</div>\r\n\t\t\t</div>\r\n\t\t</section>\r\n\t\t<section class=\"bg\">\r\n\t\t\t<div class=\"business\">\r\n\t\t\t\t<div class=\"ttl\" data-aos=\"fade-up\" data-aos-duration=\"1500\" data-aos-once=\"true\">\r\n\t\t\t\t\t<p class=\"en \">[CHAPTER01]</p>\r\n\t\t\t\t\t<h2 class=\"\">創業以来世界の食を支え続け、<br>従業員3万人、売上高1兆円の<br class=\"sp\">グループに成長。</h2>\r\n\t\t\t\t</div>\r\n\t\t\t\t<div class=\"inner\">\r\n\t\t\t\t\t<div class=\"cntnt\" data-aos=\"fade-up\" data-aos-duration=\"1500\" data-aos-once=\"true\">\r\n\t\t\t\t\t\t<div class=\"box line\">\r\n\t\t\t\t\t\t\t<div class=\"l-box\">\r\n\t\t\t\t\t\t\t\t<div class=\"year\">\r\n\t\t\t\t\t\t\t\t\t<h3 class=\"\">創業当時</h3>\r\n\t\t\t\t\t\t\t\t\t<img src=\"image/atfirst01/1942.svg\" alt=\"\">\r\n\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t<p class=\"\"><span>わずか7名</span>の食肉加工場からスタート</p>\r\n\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t<div class=\"seven r-box\">\r\n\t\t\t\t\t\t\t\t<img src=\"image/atfirst01/seven.png\" alt=\"\">\r\n\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t<div class=\"box\">\r\n\t\t\t\t\t\t\t<div class=\"l-box\">\r\n\t\t\t\t\t\t\t\t<h3 class=\"\">現在</h3>\r\n\t\t\t\t\t\t\t\t<p class=\"\"><span>約3万人の従業員</span>が支える<br>巨大バリューチェーンに</p>\r\n\t\t\t\t\t\t\t\t<div class=\"pht\">\r\n\t\t\t\t\t\t\t\t\t<img src=\"image/atfirst01/three.png\" alt=\"\">\r\n\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t<div class=\"round r-box\">\r\n\t\t\t\t\t\t\t\t<img src=\"image/atfirst01/b-round.svg\" alt=\"\">\r\n\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t</div>\r\n\t\t\t\t\t<div class=\"rank\" data-aos=\"fade-up\" data-aos-duration=\"1500\" data-aos-once=\"true\">\r\n\t\t\t\t\t\t<div class=\"box rank01\">\r\n\t\t\t\t\t\t\t<div class=\"txt\">\r\n\t\t\t\t\t\t\t\t<h3>国内の<br>食肉加工業界</h3>\r\n\t\t\t\t\t\t\t\t<div class=\"num\">\r\n\t\t\t\t\t\t\t\t\t<p>売上</p>\r\n\t\t\t\t\t\t\t\t\t<p class=\"en\">No.<span>1</span></p>\r\n\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t<div class=\"pht\">\r\n\t\t\t\t\t\t\t\t<img src=\"image/atfirst01/graph01.svg\" alt=\"\">\r\n\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t<p class=\"kome\"><span>2024年 3月期</span></p>\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t<div class=\"r-box\">\r\n\t\t\t\t\t\t\t<div class=\"box rank02\">\r\n\t\t\t\t\t\t\t\t<h3>国内の食品業界<br>売上ランキング</h3>\r\n\t\t\t\t\t\t\t\t<div class=\"pht\">\r\n\t\t\t\t\t\t\t\t\t<img src=\"image/atfirst01/rank02.png\" alt=\"\">\r\n\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t<p class=\"num\"><span class=\"en\">2</span>位</p>\r\n\t\t\t\t\t\t\t\t<p class=\"abs\"><span>（出所）SPEEDA（飲料・タバコは除く）</span></p>\r\n\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t<div class=\"box rank03\">\r\n\t\t\t\t\t\t\t\t<h3>海外の食肉業界<br>売上ランキング</h3>\r\n\t\t\t\t\t\t\t\t<div class=\"pht\">\r\n\t\t\t\t\t\t\t\t\t<img src=\"image/atfirst01/rank03.png\" alt=\"\">\r\n\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t<p class=\"num\"><span class=\"en\">11</span>位</p>\r\n\t\t\t\t\t\t\t\t<p class=\"abs\"><span>（出所）SPEEDA</span></p>\r\n\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t</div>\r\n\t\t\t\t</div>\r\n\t\t\t</div>\r\n\t\t\t<div class=\"question\">\r\n\t\t\t\t<div class=\"ttl\" data-aos=\"fade-up\" data-aos-duration=\"1500\" data-aos-once=\"true\">\r\n\t\t\t\t\t<p class=\"en \">[CHAPTER02]</p>\r\n\t\t\t\t\t<h2 class=\"\">実は様々な「食」のシーンにいる<br>ニッポンハムグループの商品。</h2>\r\n\t\t\t\t</div>\r\n\t\t\t\t<div class=\"inner\">\r\n\t\t\t\t\t<div class=\"cntnr\">\r\n\t\t\t\t\t\t<div class=\"cntnt\" data-aos=\"fade-up\" data-aos-duration=\"1500\" data-aos-once=\"true\">\r\n\t\t\t\t\t\t\t<div class=\"pht\">\r\n\t\t\t\t\t\t\t\t<img src=\"image/atfirst01/woman.png\" alt=\"\">\r\n\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t<div class=\"txt\">\r\n\t\t\t\t\t\t\t\t<p>日本ハムって<br>ハムやソーセージだけを<br>つくっている会社ですよね？</p>\r\n\t\t\t\t\t\t\t\t<div class=\"icon\">\r\n\t\t\t\t\t\t\t\t\t<img src=\"image/atfirst01/food01.png\" alt=\"\">\r\n\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t<div class=\"tri-left\"></div>\r\n\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t<div class=\"cntnt\" data-aos=\"fade-up\" data-aos-duration=\"1500\" data-aos-once=\"true\">\r\n\t\t\t\t\t\t\t<img src=\"image/atfirst01/no.svg\" alt=\"\">\r\n\t\t\t\t\t\t\t<p>いいえ！<br>ハム・ソーセージは<br><span>私たちの一面でしかありません！</span></p>\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t<div class=\"cntnt\" data-aos=\"fade-up\" data-aos-duration=\"1500\" data-aos-once=\"true\">\r\n\t\t\t\t\t\t\t<h3>こんなにもたくさんの<br class=\"sp\"><span>「食」</span>を手掛けています。</h3>\r\n\t\t\t\t\t\t\t<div class=\"flex\">\r\n\t\t\t\t\t\t\t\t<div class=\"item\">\r\n\t\t\t\t\t\t\t\t\t<img src=\"image/atfirst01/food02.png\" alt=\"\">\r\n\t\t\t\t\t\t\t\t\t<p>食肉</p>\r\n\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t<div class=\"item\">\r\n\t\t\t\t\t\t\t\t\t<img src=\"image/atfirst01/food03.png\" alt=\"\">\r\n\t\t\t\t\t\t\t\t\t<p>ハム・<br class=\"sp\">ソーセージ</p>\r\n\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t<div class=\"item\">\r\n\t\t\t\t\t\t\t\t\t<img src=\"image/atfirst01/food05.png\" alt=\"\">\r\n\t\t\t\t\t\t\t\t\t<p>水産物</p>\r\n\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t<div class=\"item\">\r\n\t\t\t\t\t\t\t\t\t<img src=\"image/atfirst01/food06.png\" alt=\"\">\r\n\t\t\t\t\t\t\t\t\t<p>チーズ</p>\r\n\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t<div class=\"item\">\r\n\t\t\t\t\t\t\t\t\t<img src=\"image/atfirst01/food07.png\" alt=\"\">\r\n\t\t\t\t\t\t\t\t\t<p>はっ酵乳・<br>乳酸菌飲料</p>\r\n\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t<div class=\"item\">\r\n\t\t\t\t\t\t\t\t\t<img src=\"image/atfirst01/food04.png\" alt=\"\">\r\n\t\t\t\t\t\t\t\t\t<p>加工食品</p>\r\n\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t<div class=\"item\">\r\n\t\t\t\t\t\t\t\t\t<img src=\"image/atfirst01/food08.png\" alt=\"\">\r\n\t\t\t\t\t\t\t\t\t<p>食物アレルギー<br>対応食品</p>\r\n\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t<div class=\"item\">\r\n\t\t\t\t\t\t\t\t\t<img src=\"image/atfirst01/food11.png\" alt=\"\">\r\n\t\t\t\t\t\t\t\t\t<p>エキス調味料</p>\r\n\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t<div class=\"item\">\r\n\t\t\t\t\t\t\t\t\t<img src=\"image/atfirst01/food09.png\" alt=\"\">\r\n\t\t\t\t\t\t\t\t\t<p>冷凍食品</p>\r\n\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t<div class=\"item\">\r\n\t\t\t\t\t\t\t\t\t<img src=\"image/atfirst01/food10.png\" alt=\"\">\r\n\t\t\t\t\t\t\t\t\t<p>フリーズドライ</p>\r\n\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t<div class=\"item\">\r\n\t\t\t\t\t\t\t\t\t<img src=\"image/atfirst01/food13.png\" alt=\"\">\r\n\t\t\t\t\t\t\t\t\t<p>食品検査</p>\r\n\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t<div class=\"item\">\r\n\t\t\t\t\t\t\t\t\t<img src=\"image/atfirst01/food12.png\" alt=\"\">\r\n\t\t\t\t\t\t\t\t\t<p>健康食品</p>\r\n\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t<div class=\"item\">\r\n\t\t\t\t\t\t\t\t\t<img src=\"image/atfirst01/food14.png\" alt=\"\">\r\n\t\t\t\t\t\t\t\t\t<p>コンビニ<br class=\"sp\">エンスストア<br>向け食品</p>\r\n\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t<div class=\"item\">\r\n\t\t\t\t\t\t\t\t\t<p>(注)当社取り扱い重量データおよび外部データをもとに当社にて推計</p>\r\n\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t</div>\r\n\t\t\t\t\t<div class=\"cntnr\">\r\n\t\t\t\t\t\t<div class=\"cntnt\" data-aos=\"fade-up\" data-aos-duration=\"1500\" data-aos-once=\"true\">\r\n\t\t\t\t\t\t\t<div class=\"pht\">\r\n\t\t\t\t\t\t\t\t<img src=\"image/atfirst01/man.png\" alt=\"\">\r\n\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t<div class=\"txt\">\r\n\t\t\t\t\t\t\t\t<p>とはいえ、<br>ハム・ソーセージが主力<br>のフィールドなんですよね？</p>\r\n\t\t\t\t\t\t\t\t<div class=\"icon\">\r\n\t\t\t\t\t\t\t\t\t<img src=\"image/atfirst01/food01.png\" alt=\"\">\r\n\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t<div class=\"tri-left\"></div>\r\n\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t<div class=\"cntnt\" data-aos=\"fade-up\" data-aos-duration=\"1500\" data-aos-once=\"true\">\r\n\t\t\t\t\t\t\t<img src=\"image/atfirst01/no.svg\" alt=\"\">\r\n\t\t\t\t\t\t\t<p>いいえ！<br>実は最も多く売上高を占めるのは<br class=\"pc\"><span>「食肉事業」</span>です。</p>\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t<div class=\"cntnt\" data-aos=\"fade-up\" data-aos-duration=\"1500\" data-aos-once=\"true\">\r\n\t\t\t\t\t\t\t<div class=\"flex\">\r\n\t\t\t\t\t\t\t\t<div class=\"pht\">\r\n\t\t\t\t\t\t\t\t\t<img src=\"image/atfirst01/graph02.svg\" alt=\"\">\r\n\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t<div class=\"txt\">\r\n\t\t\t\t\t\t\t\t\t<div class=\"center\">\r\n\t\t\t\t\t\t\t\t\t\t<img src=\"image/atfirst01/food15.png\" alt=\"\">\r\n\t\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t\t<!-- <p>牛肉・豚肉・鶏肉</p> -->\r\n\t\t\t\t\t\t\t\t\t<p><span>国内の食肉販売量のシェア約20％。</span><br>日本の食卓の5回に1回は<br>私たちがお肉を提供していることに！</p>\r\n\t\t\t\t\t\t\t\t\t<p class=\"kome\">※ 2025年3月期　当社算定</p>\r\n\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t</div>\r\n\t\t\t\t</div><!--- /inner--->\r\n\t\t\t</div>\r\n\t\t\t<div class=\"goods\">\r\n\t\t\t\t<div class=\"ttl\" data-aos=\"fade-up\" data-aos-duration=\"1500\" data-aos-once=\"true\">\r\n\t\t\t\t\t<p class=\"en \">[CHAPTER03]</p>\r\n\t\t\t\t\t<h2 class=\"\">実は様々な「食」のシーンにいる<br>ニッポンハムグループの商品。</h2>\r\n\t\t\t\t</div>\r\n\t\t\t\t<div class=\"inner\" data-aos=\"fade-up\" data-aos-duration=\"1500\" data-aos-once=\"true\">\r\n\t\t\t\t\t<p>思い浮かべやすいのは…</p>\r\n\t\t\t\t\t<img src=\"image/atfirst01/goods01.png\" alt=\"\">\r\n\t\t\t\t\t<p>スーパーなどで売っている<br>ニッポンハムグループブランドの商品<br><span>（肉やハム、ピザなど…）</span></p>\r\n\t\t\t\t\t<p>だけじゃない</p>\r\n\t\t\t\t\t<div class=\"cntnr\">\r\n\t\t\t\t\t\t<div class=\"flex\">\r\n\t\t\t\t\t\t\t<div class=\"item\">\r\n\t\t\t\t\t\t\t\t<img src=\"image/atfirst01/goods02.png\" alt=\"\">\r\n\t\t\t\t\t\t\t\t<p>居酒屋のメニューに</p>\r\n\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t<div class=\"item\">\r\n\t\t\t\t\t\t\t\t<img src=\"image/atfirst01/goods03.png\" alt=\"\">\r\n\t\t\t\t\t\t\t\t<p>学校給食に</p>\r\n\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t<div class=\"item\">\r\n\t\t\t\t\t\t\t\t<img src=\"image/atfirst01/goods04.png\" alt=\"\">\r\n\t\t\t\t\t\t\t\t<p>コンビニ弁当に</p>\r\n\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t<p>ニッポンハムグループと気付かない所でも<br><span>皆さんの食に広く携わっています。</span></p>\r\n\t\t\t\t\t</div>\r\n\t\t\t\t\t<p>ニッポンハムグループの業界への影響力や<br class=\"sp\">ビジネス展開について、<br class=\"pc\">理解できましたか？</p>\r\n\t\t\t\t\t<p>後編では<span>「強み」「未来へのビジョン」</span>を<br class=\"sp\">ご紹介します！</p>\r\n\t\t\t\t\t<div class=\"btn\">\r\n\t\t\t\t\t\t<a href=\"/recruit/fresh/about/at-first02.html\">\r\n\t\t\t\t\t\t\t<h3>はじめに知る日本ハム<br class=\"sp\"> - 後編 へ</h3>\r\n\t\t\t\t\t\t</a>\r\n\t\t\t\t\t</div>\r\n\t\t\t\t</div>\r\n\t\t\t</div>\r\n\t\t</section>\r\n\t</div><!--- /systems --->\r\n\t\r\n\t\r\n</main><!--- /main --->\r\n\r\n\t\r\n\t\r\n\t\r\n\r\n\r\n<footer id=\"footer\"> \r\n\t<div class=\"sitemap inner flex\">\r\n\t\t<div class=\"box\">\r\n\t\t\t<p class=\"head en\">ABOUT US</p>\r\n\t\t\t<ul class=\"s-list\">\r\n\t\t\t\t<li><a href=\"/recruit/fresh/about/\">トップメッセージ</a></li>\r\n\t\t\t\t<li><a href=\"/recruit/fresh/about/at-first01.html\">はじめに知る日本ハム<br>前編（これまでの歩みと基本情報）</a></li>\r\n\t\t\t\t<li><a href=\"/recruit/fresh/about/at-first02.html\">はじめに知る日本ハム<br>後編（強みと目指すもの）</a></li>\r\n\t\t\t</ul><!--- /s-list --->\r\n\t\t</div><!--- /box --->\r\n\t\t\r\n\t\t<div class=\"box\">\r\n\t\t\t<p class=\"head en\">JOB</p>\r\n\t\t\t<ul class=\"s-list\">\r\n\t\t\t\t<li><a href=\"/recruit/fresh/job/jobflow.html\">日本ハムの仕事の流れ</a></li>\r\n\t\t\t\t<li><a href=\"/recruit/fresh/job/\">職種紹介</a></li>\r\n\t\t\t\t<li><a href=\"/recruit/fresh/job/episode01.html\">挑戦エピソード01〈事業企画〉<br>バイオ炭で挑む循環型畜産イノベーション</a></li>\r\n\t\t\t\t<li><a href=\"/recruit/fresh/job/episode02.html\">挑戦エピソード02〈商品開発〉<br>『中華名菜 酢豚』リニューアルの裏側</a></li>\r\n\t\t\t</ul><!--- /s-list --->\r\n\t\t</div><!--- /box --->\r\n\t\t\r\n\t\t<div class=\"box\">\r\n\t\t\t<p class=\"head en\">PEOPLE</p>\r\n\t\t\t<ul class=\"s-list\">\r\n\t\t\t\t<li><a href=\"/recruit/fresh/people/\">社員インタビュー</a></li>\r\n\t\t\t\t<li><a href=\"/recruit/fresh/people/variou