ript>\n<script id=\"bootstrap-js\" src=\"https://www.maruwa-wk.co.jp/_wp2025/wp-content/themes/maruwa2025/assets/bootstrap/dist/js/bootstrap.bundle.min.js?ver=7.0\"></script>\n<link rel=\"https://api.w.org/\" href=\"https://www.maruwa-wk.co.jp/wp-json/\" /><link rel=\"alternate\" title=\"JSON\" type=\"application/json\" href=\"https://www.maruwa-wk.co.jp/wp-json/wp/v2/pages/14\" /><link rel=\"EditURI\" type=\"application/rsd+xml\" title=\"RSD\" href=\"https://www.maruwa-wk.co.jp/_wp2025/xmlrpc.php?rsd\" />\n<meta name=\"generator\" content=\"WordPress 7.0\" />\n<link rel=\"canonical\" href=\"https://www.maruwa-wk.co.jp/company\" />\n<link rel='shortlink' href='https://www.maruwa-wk.co.jp/?p=14' />\n<link rel=\"icon\" href=\"https://www.maruwa-wk.co.jp/_wp2025/wp-content/uploads/2025/07/cropped-logo-32x32.png\" sizes=\"32x32\" />\n<link rel=\"icon\" href=\"https://www.maruwa-wk.co.jp/_wp2025/wp-content/uploads/2025/07/cropped-logo-192x192.png\" sizes=\"192x192\" />\n<link rel=\"apple-touch-icon\" href=\"https://www.maruwa-wk.co.jp/_wp2025/wp-content/uploads/2025/07/cropped-logo-180x180.png\" />\n<meta name=\"msapplication-TileImage\" content=\"https://www.maruwa-wk.co.jp/_wp2025/wp-content/uploads/2025/07/cropped-logo-270x270.png\" />\n</head>\n\n<body class=\"wp-singular page-template-default page page-id-14 wp-embed-responsive wp-theme-maruwa2025 no-js singular no-widgets\">\n    \n    \n<header class=\"site-header fixed-top\">\n    <div class=\"container-fluid\" style=\"max-width: calc(1160px + var(--bs-gutter-x));\">\n        <nav class=\"navbar navbar-expand-lg bg-transparent py-2 py-md-4\" data-bs-theme=\"dark\">\n            <a class=\"navbar-brand\" href=\"https://www.maruwa-wk.co.jp/\">\n                <img src=\"https://www.maruwa-wk.co.jp/_wp2025/wp-content/themes/maruwa2025/assets/images/logo.svg\" alt=\"MARUWA CO., LTD.\">\n            </a>\n\n            <button class=\"navbar-toggler\" type=\"button\" data-bs-toggle=\"offcanvas\" data-bs-target=\"#offcanvasNavbar\" aria-controls=\"offcanvasNavbar\" aria-label=\"ナビゲーションの切替\">\n                <svg xmlns=\"http://www.w3.org/2000/svg\" class=\"navbar-toggler-icon\" viewbox=\"0 0 50 50\" style=\"--bs-navbar-toggler-icon-bg: none;\">\n                    <g>\n                        <circle cx=\"25\" cy=\"25\" r=\"25\" />\n                        <path d=\"M11.76 20.91h26.48\" />\n                        <path d=\"M11.76 29.09h26.48\" />\n                    </g>\n                </svg>\n            </button>\n\n            <div class=\"offcanvas offcanvas-lg offcanvas-end\" data-bs-scroll=\"true\" data-bs-backdrop=\"false\" tabindex=\"-1\" id=\"offcanvasNavbar\" aria-labelledby=\"offcanvasNavbarLabel\" style=\"--bs-offcanvas-bg: var(--bs-primary); --bs-offcanvas-width: 50%;\">\n                <div class=\"offcanvas-header\">\n                    <h5 class=\"offcanvas-title visually-hidden\" id=\"offcanvasNavbarLabel\">ヘッダーナビゲーション</h5>\n                    <!--<button type=\"button\" class=\"btn-close\" data-bs-dismiss=\"offcanvas\" aria-label=\"閉じる\"></button>-->\n                </div>\n                <div class=\"offcanvas-body ms-lg-auto\">\n                    <ul class=\"navbar-nav\">\n                        <li id=\"menu-item-21\" class=\"menu-item menu-item-type-custom menu-item-object-custom menu-item-21 nav-item fs-13px\"><a href=\"https://maruwa-wk.co.jp/\" class=\"nav-link py-2 lh-200\">ホーム</a></li>\n<li id=\"menu-item-25\" class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-25 nav-item fs-13px\"><a href=\"https://www.maruwa-wk.co.jp/services\" class=\"nav-link py-2 lh-200\">本社事業</a></li>\n<li id=\"menu-item-24\" class=\"menu-item menu-item-type-post_type menu-item-object-page current-menu-item page_item page-item-14 current_page_item menu-item-24 nav-item fs-13px\"><a href=\"https://www.maruwa-wk.co.jp/company\" aria-current=\"page\" class=\"nav-link py-2 lh-200\">会社概要</a></li>\n<li id=\"menu-item-22\" class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-22 nav-item fs-13px\"><a href=\"https://www.maruwa-wk.co.jp/others\" class=\"nav-link py-2 lh-200\">その他事業</a></li>\n<li id=\"menu-item-26\" class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-26 nav-item fs-13px\"><a href=\"https://www.maruwa-wk.co.jp/interview\" class=\"nav-link py-2 lh-200\">社員インタビュー</a></li>\n<li id=\"menu-item-29\" class=\"menu-item menu-item-type-taxonomy menu-item-object-category menu-item-29 nav-item fs-13px\"><a href=\"https://www.maruwa-wk.co.jp/./information\" class=\"nav-link py-2 lh-200\">お知らせ</a></li>\n<li id=\"menu-item-23\" class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-23 nav-item fs-13px\"><a href=\"https://www.maruwa-wk.co.jp/contact\" class=\"nav-link py-2 lh-200\">リクルート / お問い合わせ</a></li>\n                    </ul>\n                </div>\n            </div>\n        </nav>\n    </div>\n</header>    \n    <main>\n\n<article id=\"post-14\" class=\"post-14 page type-page status-publish hentry entry\">\n\t\n<header class=\"page-header mb-80px mb-lg-160px\">\n\t<div class=\"page-header-img\">\n\t\t<picture>\n\t\t\t<source media=\"(min-width: 992px)\" srcset=\"https://www.maruwa-wk.co.jp/_wp2025/wp-content/themes/maruwa2025/assets/images/company/img_company_hero_lg.jpg\" />\n\t\t\t<img class=\"d-block w-100\" src=\"https://www.maruwa-wk.co.jp/_wp2025/wp-content/themes/maruwa2025/assets/images/company/img_company_hero.jpg\" alt=\"\">\n\t\t</picture>\n\t</div>\n\t<h1 class=\"page-header-title container\">\n\t\t<span class=\"d-block fw-black fs-48px fs-md-120px font-latin ls-40 lh-100\">COMPANY</span>\n\t\t<span class=\"d-block fs-16px fs-md-22px ls-200\">会社概要</span>\n\t</h1>\n</header><!-- /.page-header -->\n\t\n\n<!-- 社長メッセージ -->\n<section id=\"top\" class=\"bg-white\">\n    <div class=\"container pb-50px pb-lg-100px\">\n        <div class=\"section-top\">\n            <div class=\"section-top-head\">\n                <h2 class=\"heading-circle fw-bold fs-12px fs-lg-16px mb-30px mb-lg-60px ps-40px ps-lg-45px\">\n                    <span class=\"fw-black fs-22px fs-lg-28px font-latin\">Top interview</span>\n                    <span class=\"ls-80 ms-lg-25px\">社長メッセージ</span>\n                </h2>\n                <h3 class=\"fw-bold fs-20px fs-lg-24px lh-200 ls-40 ls-lg-0 text-center text-lg-start mb-0\">\n                    <span class=\"d-inline-block text-decoration-underline mb-20px mb-lg-0\" style=\"text-decoration-color: var(--bs-warning) !important; text-underline-offset: .375em; text-decoration-thickness: 3px !important;\">お客様の繁栄<br class=\"d-lg-none\"><span class=\"d-none d-lg-inline align-text-top\">&emsp;</span>社員の幸福<br class=\"d-lg-none\"><span class=\"d-none d-lg-inline align-text-top\">&emsp;</span>福祉への還元</span>\n                    <span class=\"d-inline-block lh-160 ls-160 text-decoration-lg-underline\" style=\"text-decoration-color: var(--bs-warning) !important; text-underline-offset: .375em; text-decoration-thickness: 3px !important;\">この3つを目標に<br class=\"d-lg-none\">丸和は頑張り続けます</span>\n                </h3>\n            </div>\n            <div class=\"section-top-img\">\n                <img class=\"d-block img-fluid mx-auto\" src=\"https://www.maruwa-wk.co.jp/_wp2025/wp-content/themes/maruwa2025/assets/images/company/img_company_top_president_02.jpg\" alt=\"\">\n            </div>\n            <div class=\"section-top-body\">\n                <p class=\"fs-14px lh-190 lh-lg-200 text-indent mb-0\">株式会社丸和は2025年6月に創業65年を迎えました。これもひとえに、長きにわたり多くの皆さまよりご支援とご協力を賜り、支えていただいた賜物であり、心より御礼申し上げます。</p>\n                <p class=\"fs-14px lh-190 lh-lg-200 text-indent mb-0\">弊社は2006年7月、本社を創業以来長年事業展開していた和歌山市坂田より、現在の紀の川市桃山町へ移転いたしました。それ以来、病院・施設リネン、ホテルリネン、寝具の各事業を主力として、経営基盤をより強固なものとし、「思いは人へ、環境へ」の理念のもと、人と地球にやさしい高品質な製品を皆さまにお届けすることを第一に、商品開発および品質向上に努めてまいりました。</p>\n                <p class=\"fs-14px lh-190 lh-lg-200 text-indent\">お客さまのことを第一に考え、そのニーズに応えるべく、社員教育と人材育成を通じて新たな知恵を創造し、変化の激しい時代においても、お客さまの期待に応えられる柔軟性と力強さを備えた企業を目指してまいります。</p>\n                <p class=\"fs-14px lh-190 lh-lg-200 text-indent\">今後とも、社員一丸となって努めてまいりますので、ご指導ご鞭撻のほどよろしくお願い申し上げます。</p>\n                <p class=\"fs-14 text-end mb-0\">代表取締役&emsp;丸山&emsp;昌三</p>\n            </div>\n        </div>\n    </div>\n</section><!-- /#top -->\n\n<!-- 基本情報 -->\n<section id=\"information\" class=\"bg-secondary\">\n    <div class=\"container pt-50px pt-lg-75px pb-60px pb-lg-90px\">\n        <h2 class=\"heading-circle fw-bold fs-12px fs-lg-16px ls-80 mb-30px mb-lg-60px ps-40px ps-lg-45px\">\n            <span class=\"fw-black fs-22px fs-lg-28px font-latin\">Information</span>\n            <span class=\"ms-lg-25px\">基本情報</span>\n        </h2>\n        <div class=\"mx-auto\" style=\"max-width: 640px;\">\n            <dl class=\"listing row fs-16px\">\n                <dt class=\"col-lg-3 ls-160\">会社名</dt>\n                <dd class=\"col-lg-9\">株式会社&emsp;丸和</dd>\n                                <dt class=\"col-lg-3 ls-160\">本社所在地</dt>\n                <dd class=\"col-lg-9\">〒649-6112 <br class=\"d-lg-none\">和歌山県紀の川市桃山町調月1758-6<a class=\"btn btn-primary btn-sm mt-2 mt-lg-0 ms-3\" target=\"_target\" href=\"https://maps.app.goo.gl/u6Eu11yt7n7uS5rp9\">Google Maps <i class=\"ri-external-link-line\"></i></a></dd>\n                <dt class=\"col-lg-3 ls-160\">創業</dt>\n                <dd class=\"col-lg-9\">昭和35年</dd>\n                <dt class=\"col-lg-3 ls-160\">設立年月日</dt>\n                <dd class=\"col-lg-9\">平成2年8月8日</dd>\n                <dt class=\"col-lg-3 ls-160\">代表取締役</dt>\n                <dd class=\"col-lg-9\">丸山 昌三</dd>\n                <dt class=\"col-lg-3 ls-160\">決算期</dt>\n                <dd class=\"col-lg-9\">7月</dd>\n                <dt class=\"col-lg-3 ls-160\">資本金</dt>\n                <dd class=\"col-lg-9\">1,000万円</dd>\n                <dt class=\"col-lg-3 ls-160\">従業員</dt>\n                <dd class=\"col-lg-9\">200人</dd>\n                <dt class=\"col-lg-3 ls-160\">電話</dt>\n                <dd class=\"col-lg-9\">0736-66-1148</dd>\n                <dt class=\"col-lg-3 ls-160\">ファックス</dt>\n                <dd class=\"col-lg-9\">0736-66-2700</dd>\n            </dl>\n        </div>\n    </div>\n</section><!-- /#information -->\n\n<!-- 会社の歴史 -->\n<section id=\"history\" class=\"bg-white\">\n    <div class=\"container pt-50px pt-lg-75px pb-60px pb-lg-90px\">\n        <h2 class=\"heading-circle fw-bold fs-12px fs-lg-16px ls-80 mb-30px mb-lg-60px ps-40px ps-lg-45px\">\n            <span class=\"fw-black fs-22px fs-lg-28px font-latin\">Company history</span>\n            <span class=\"ms-lg-25px\">会社の歴史</span>\n        </h2>\n        <div class=\"mx-auto\" style=\"max-width: 900px;\">\n            <dl class=\"listing row gx-0 fs-16px\">\n                <dt class=\"col-lg-3 ls-160\">1960年6月</dt>\n                <dd class=\"col-lg-9\">和歌山市和田626番地にて、製綿業工場創業</dd>\n                <dt class=\"col-lg-3 ls-160\">1964年8月</dt>\n                <dd class=\"col-lg-9\">有限会社丸和寝具法人設立　資本金300万円</dd>\n                <dt class=\"col-lg-3 ls-160\">1967年10月</dt>\n                <dd class=\"col-lg-9\">有限会社丸和寝具の資本金を500万円に増資</dd>\n                <dt class=\"col-lg-3 ls-160\">1968年8月</dt>\n                <dd class=\"col-lg-9\">有限会社丸和寝具を有限会社丸和に名称変更</dd>\n                <dt class=\"col-lg-3 ls-160\">1972年4月</dt>\n                <dd class=\"col-lg-9\">有限会社丸和の本社を和歌山市坂田348番地に移転。同時に製綿工場・倉庫増設</dd>\n                <dt class=\"col-lg-3 ls-160\">1974年7月</dt>\n                <dd class=\"col-lg-9\">有限会社 丸和の資本金を750万円に増資</dd>\n                <dt class=\"col-lg-3 ls-160\">1980年9月</dt>\n                <dd class=\"col-lg-9\">有限会社 丸和の資本金を1000万円に増資</dd>\n                <dt class=\"col-lg-3 ls-160\">1986年4月</dt>\n                <dd class=\"col-lg-9\">東牟婁郡那智勝浦町市屋1057 財団法人グリーンピア南紀内に<br>有限会社 丸和　勝浦出張所　開設</dd>\n                <dt class=\"col-lg-3 ls-160\">1987年2月</dt>\n                <dd class=\"col-lg-9\">有限会社　丸和　本社社屋新築・製綿機械増強並びに工場新築</dd>\n                <dt class=\"col-lg-3 ls-160\">1988年3月</dt>\n                <dd class=\"col-lg-9\">電気製品他関連商品の販売・リース部門を分離独立<br>株式会社　丸和リース法人設立　資本金500万円</dd>\n                <dt class=\"col-lg-3 ls-160\">1990年8月</dt>\n                <dd class=\"col-lg-9\">有限会社　丸和を有限会社　昌和に名称変更<br>丸和グループの不動産管理会社とする<br>新たに寝具製造・販売・リース・リネンサプライ部門を営業する<br>株式会社　丸和法人設立　資本金1000万円</dd>\n                <dt class=\"col-lg-3 ls-160\">1992年9月</dt>\n                <dd class=\"col-lg-9\">有病院専用寝具製造部門として、有限会社 アリオ 法人設立 資本金300万円</dd>\n                <dt class=\"col-lg-3 ls-160\">1993年7月</dt>\n                <dd class=\"col-lg-9\">和歌山県海南市日方237番地に、株式会社 丸和、株式会社 丸和リースの支店開設</dd>\n                <dt class=\"col-lg-3 ls-160\">1994年7月</dt>\n                <dd class=\"col-lg-9\">和歌山県紀の川市桃山町調月1758番地の18に知的障害者福祉工場、<br>社会福祉法人　桃の木会を設立　リネン類洗濯業務を開始</dd>\n                <dt class=\"col-lg-3 ls-160\">1995年5月</dt>\n                <dd class=\"col-lg-9\">株式会社　丸和リースの資本金を1000万円に増資</dd>\n                <dt class=\"col-lg-3 ls-160\">1998年12月</dt>\n                <dd class=\"col-lg-9\">ホテル事業部として和歌山県民交流プラザ(和歌山ビッグ愛10F11F)<br>ホテルランドマーク和歌山開業有限会社丸和寝具の資本金を500万円に増資</dd>\n                <dt class=\"col-lg-3 ls-160\">2005年3月</dt>\n                <dd class=\"col-lg-9\">売店事業部として和歌山市塩屋6丁目2番70号の和歌浦中央病院内に病院内売店の営業開始</dd>\n                <dt class=\"col-lg-3 ls-160\">2005年8月</dt>\n                <dd class=\"col-lg-9\">レストラン事業部として和歌山県民交流プラザ(和歌山ビッグ愛12F)<br>にガストロ “オテル ド ヨシノ” 及び“カフェステラマリス” 開業</dd>\n                <dt class=\"col-lg-3 ls-160\">2006年7月</dt>\n                <dd class=\"col-lg-9\">株式会社丸和新本社社屋並びに工場を和歌山県紀の川市桃山町調月1758-6（現在地）に移転<img class=\"img-fluid mw-lg-max mt-3 me-10px\" src=\"https://www.maruwa-wk.co.jp/_wp2025/wp-content/themes/maruwa2025/assets/images/company/img_company_history_0607_01.jpg\" alt=\"\" style=\"--bs-mw-max-max-width: 256px;\"></dd>\n                <dt class=\"col-lg-3 ls-160\">2010年3月</dt>\n                <dd class=\"col-lg-9\">株式会社丸和リースを吸収合併、テレビリース事業部を設立</dd>\n                <dt class=\"col-lg-3 ls-160\">2013年7月</dt>\n                <dd class=\"col-lg-9\">有限会社 昌和　一般建設業許可を取得</dd>\n                <dt class=\"col-lg-3 ls-160\">2020年7月</dt>\n                <dd class=\"col-lg-9\">有限会社アリオを吸収合併、集配事業部を設立</dd>\n                <dt class=\"col-lg-3 ls-160\">2024年４月</dt>\n                <dd class=\"col-lg-9\">和歌山県紀の川市桃山町調月1758-14（本社と同じ桃山第２工業団地内）に新社屋を竣工<div class=\"d-flex flex-column flex-lg-row\">\n                        <div><img class=\"img-fluid mw-lg-max mt-3 me-lg-10px\" src=\"https://www.maruwa-wk.co.jp/_wp2025/wp-content/themes/maruwa2025/assets/images/company/img_company_history_2404_01.jpg\" alt=\"\" style=\"--bs-mw-max-max-width: 256px;\"></div>\n                        <div><img class=\"img-fluid mw-lg-max mt-3 me-lg-10px\" src=\"https://www.maruwa-wk.co.jp/_wp2025/wp-content/themes/maruwa2025/assets/images/company/img_company_history_2404_02.jpg\" alt=\"\" style=\"--bs-mw-max-max-width: 256px;\"></div>\n                    </div>\n                </dd>\n                <dt class=\"col-lg-3 ls-160\">2024年5月</dt>\n                <dd class=\"col-lg-9\">保育園事業を新規開始（和歌山県紀の川市桃山町調月1758-14で「つたのは保育園」を開園）</dd>\n            </dl>\n        </div>\n    </div>\n</section><!-- /#history -->\n\n<!-- グループ会社 -->\n<section id=\"group\" class=\"bg-secondary\">\n    <div class=\"container pt-50px pt-lg-75px pb-60px pb-lg-90px\">\n        <h2 class=\"heading-circle fw-bold fs-12px fs-lg-16px ls-80 mb-30px mb-lg-60px ps-40px ps-lg-45px\">\n            <span class=\"fw-black fs-22px fs-lg-28px font-latin\">Group companies</span>\n            <span class=\"ms-lg-25px\">グループ会社</span>\n        </h2>\n        <div class=\"mx-20px ms-lg-50px me-lg-0\">\n            <div class=\"row gy-20px gx-lg-3\">\n                <div class=\"col-lg\">\n                    <a class=\"d-block position-relative btn btn-light fw-bold fs-14px py-4\" role=\"button\" target=\"_blank\" href=\"https://momonokikai.or.jp/\">社会福祉法人桃の木会<i class=\"ri-external-link-line ri-sm\" style=\"position: absolute; right: .5rem; bottom: .5rem; color: var(--bs-primary);\"></i></a>\n                </div>\n                <div class=\"col-lg\">\n                    <a class=\"d-block btn btn-light fw-bold fs-14px py-4 disabled\" role=\"button\" href=\"#\" style=\"--bs-btn-disabled-opacity: 1;\">有限会社昌和</a>\n                </div>\n                <div class=\"col-lg\">\n                    <a class=\"d-block position-relative btn btn-light fw-bold fs-14px py-4\" role=\"button\" target=\"_blank\" href=\"https://kishiyasu-wk.co.jp/\">株式会社貴志安商店<i class=\"ri-external-link-line ri-sm\" style=\"position: absolute; right: .5rem; bottom: .5rem; color: var(--bs-primary);\"></i></a>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>\n\t<div class=\"entry-content\">\n\t\t\t</div><!-- .entry-content -->\n\n\t</article><!-- #post-14 -->\n\t\n</main>\n\n<footer class=\"site-footer text-bg-primary py-3\">\n    <div class=\"container-fluid\" style=\"max-width: calc(1160px + var(--bs-gutter-x));\">\n        <div class=\"d-md-flex justify-content-md-between align-items-md-center\">\n            <p class=\"fs-12px fs-md-14px ls-120 text-center mb-0\">株式会社 丸和</p>\n            <p class=\"fs-10px text-center mb-0\">Copyright &copy; 2025 MARUWA CO., LTD. All Rights Reserved</p>\n        </div>\n    </div>\n</footer>\n\n<script src=\"https://www.maruwa-wk.co.jp/_wp2025/wp-content/themes/maruwa2025/assets/libs/slick.js\"></script>\n<script>\n    $(function(){\n\n        // トピックス\n        $('#interviewSlider').slick({\n            autoplay: true,\n            speed: 5000,\n            autoplaySpeed: 0,\n            cssEase: 'linear',\n            centerMode: true,\n            slidesToShow: 1,\n            centerPadding: '40%',\n            arrows: false,\n            pauseOnHover: false,\n            responsive: [\n                {\n                    breakpoint: 992,\n                    settings: {\n                        centerPadding: '15.9985%',\n                    }\n                }\n            ]\n        });\n    });\n<