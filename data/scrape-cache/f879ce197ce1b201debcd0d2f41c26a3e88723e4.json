{"url":"https://www.jr-takashimaya.co.jp/mypage_info/","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n<head>\n<meta charset=\"UTF-8\">\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n\n\n<!-- Google Tag Manager -->\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n})(window,document,'script','dataLayer','GTM-KHNW9NP');</script>\n<!-- End Google Tag Manager -->\n\n\n\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<script src=\"/common/js/viewport.js\"></script>\n\n<meta name=\"format-detection\" content=\"telephone=no,address=no,email=no\">\n<meta name=\"description\" content=\"ジェイアール名古屋タカシマヤのマイページをご案内します。マイページに登録すると、最新情報や、ポイント照会サービス、その他、さまざまな特典がいっぱい！\">\n<meta name=\"keywords\" content=\"JR,名古屋,高島屋,タカシマヤ,takashimaya,名古屋駅,名駅,メイエキ\">\n\n<!-- OGTag start -->\n<!-- meta property=\"og:type\" content=\"website\" -->\n<meta property=\"og:type\" content=\"article\">\n<meta property=\"og:title\" content=\"マイページのご案内 | ジェイアール名古屋タカシマヤ\">\n<meta property=\"og:url\" content=\"\">\n<meta property=\"og:image\" content=\"https://www.jr-takashimaya.co.jp/common/img/thumb_fb.png\">\n<meta property=\"og:description\" content=\"ジェイアール名古屋タカシマヤのマイページをご案内します。マイページに登録すると、最新情報や、ポイント照会サービス、その他、さまざまな特典がいっぱい！\">\n<meta property=\"og:site_name\" content=\"ジェイアール名古屋タカシマヤ\">\n<!-- OGTag end -->\n\n\n\n<link rel=\"icon\" href=\"/common/img/favicon.ico\">\n<link rel=\"apple-touch-icon\" href=\"/common/img/icon.png\">\n<link href=\"https://fonts.googleapis.com/css?family=Noto+Sans+JP:100,300,400,700,900\" rel=\"stylesheet\">\n<link rel=\"stylesheet\" href=\"/common/css/style.css?v=1.4\">\n<title>マイページのご案内 | ジェイアール名古屋タカシマヤ</title>\n\n</head>\n<body>\n<!-- Google Tag Manager (noscript) -->\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-KHNW9NP\" height=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n<!-- End Google Tag Manager (noscript) -->\n\n\n\n<div id=\"Wrapper\" class=\"Wrapper\">\n\n<!-- ////////////////////////////////////////////////// Header start -->\n<header class=\"Header\" id=\"Header\">\n\n  <div class=\"Header__inner\">\n\n    <div class=\"Header__menu\">\n\n      <div class=\"Header__menuInner1\">\n\n      \n        <h1 class=\"Header__logo\"><a href=\"/\"><img src=\"/common/svg/head_logo.svg\" alt=\"ジェイアール名古屋タカシマヤ\"></a></h1><!-- .Header__logo -->\n      \n\n      </div><!-- .Header__menuInner -->\n\n      <div class=\"Header__menuInner2\">\n\n        <ul class=\"Header__utility\">\n        <!-- crosslanguage:delete -->\n          <li class=\"Header__utilityItem\">\n            <a href=\"/mypage/\" class=\"HeaderUtility__link\">\n              <span class=\"HeaderUtility__icon\"><img src=\"/common/svg/icon_mypage.svg\" alt=\"\" class=\"IconSvg\"></span>\n              <span class=\"HeaderUtility__text\">マイページ</span>\n            </a>\n          </li>\n        <!-- /crosslanguage:delete -->\n          <li class=\"Header__utilityItem\">\n            <a href=\"/today/\" class=\"HeaderUtility__link\">\n              <span class=\"HeaderUtility__icon -date\"><img src=\"/common/svg/icon_calendar.svg\" alt=\"\" class=\"IconSvg\"><span class=\"HeaderUtility__iconDate\">23</span></span>\n              <span class=\"HeaderUtility__text\">今日のタカシマヤ</span>\n            </a>\n          </li>\n          <li class=\"Header__utilityItem -language\">\n            <a href=\"#\" class=\"HeaderUtility__link\" id=\"HeaderlanguageButton\">\n              <span class=\"HeaderUtility__icon\"><img src=\"/common/svg/icon_global.svg\" alt=\"\" class=\"IconSvg\"></span>\n              <span class=\"HeaderUtility__text\">LANGUAGE</span>\n            </a>\n            <div class=\"LanguageNavigation cl-notranslate\">\n              <div class=\"LanguageNavigation__inner\">\n              <div class=\"LanguageNavigation__item\"><a href=\"/\" class=\"LanguageNavigation__link cl-norewrite\">日本語</a></div>\n              <div class=\"LanguageNavigation__item\"><a href=\"/en/\" class=\"LanguageNavigation__link cl-norewrite\">ENGLISH</a></div>\n              <div class=\"LanguageNavigation__item\"><a href=\"/cn/\" class=\"LanguageNavigation__link cl-norewrite\">简体中文</a></div>\n              <div class=\"LanguageNavigation__item\"><a href=\"/tw/\" class=\"LanguageNavigation__link cl-norewrite\">繁体中文</a></div>\n              <div class=\"LanguageNavigation__item\"><a href=\"/ko/\" class=\"LanguageNavigation__link cl-norewrite\">한국어</a></div>\n              </div><!-- .LanguageNavigation__inner -->\n            </div><!-- .LanguageNavigation -->\n          </li>\n        </ul>\n\n        <p class=\"Header__navigationButton\">\n          <a href=\"#\" id=\"NavigationButton\" class=\"Header__navigationButtonInner\">\n            <span class=\"Header__navigationIcon\"></span>\n            <span class=\"Header__navigationIcon\"></span>\n            <span class=\"Header__navigationIcon\"></span>\n          </a>\n        </p><!-- .Header__navigationButton -->\n\n      </div><!-- .Header__menuInner -->\n\n    </div><!-- .Header__menu -->\n\n    <p class=\"Header__gateTowerMall\">\n      <a href=\"https://www.jr-tgm.com/\" class=\"Header__gateTowerMallLink\" target=\"_blank\"><img src=\"/common/svg/icon_gatetowermall.svg\" alt=\"タカシマヤ ゲートタワーモール\"></a>\n    </p><!-- .Header__gateTowerMall -->\n\n  </div><!-- .Header__inner -->\n</header>\n<!-- ////////////////////////////////////////////////// Header end -->\n\n\n<main>\n\n\n\n  \n  \t\n  \t\n  \t\t<div class=\"ImportantNotices\">\n        <div class=\"ImportantNotices__inner\">\n          <h2 class=\"ImportantNotices__title\">\n            <span class=\"ImportantNotices__titleIcon\">\n              <img src=\"/common/svg/icon_attention.svg\" alt=\"\"></span>\n              <span class=\"ImportantNotices__titleText\">重要なお知らせ</span>\n            </h2>\n            <ul class=\"ImportantNotices__list\">\n    \n\n    \n    \n    \n    \n    \n    \n      \n    <li class=\"ImportantNotices__listItem\">\n      <a class=\"ImportantNotices__link\" href=\"/info/post-282.html\" target=\"_blank\">\n        ＜ロクシタン＞粗品「メゾンブレモンド クレモンティーヌ＆オレンジコンフィチュール」異物混入の可能性についてのお詫びとお知らせ\n      </a>\n    </li>\n\n    \n  \n    \n\n    \n    \n    \n    \n    \n    \n      \n    <li class=\"ImportantNotices__listItem\">\n      <a class=\"ImportantNotices__link\" href=\"/info/post-278.html\" target=\"_blank\">\n        タカシマヤ ゲートタワーモール営業時間変更のお知らせ\n      </a>\n    </li>\n\n    \n  \n    \n\n    \n    \n    \n    \n    \n    \n      \n    <li class=\"ImportantNotices__listItem\">\n      <a class=\"ImportantNotices__link\" href=\"/info/post-265.html\" target=\"_blank\">\n        ＜ティファール＞「電気ケトルの電源プレート」無償交換のお知らせ\n      </a>\n    </li>\n\n    \n          </ul>\n        </div>\n      </div><!-- .ImportantNotices -->\n    \n  \n\n  \t\n  \n\n\n\n\n\n  <div class=\"PageTitle\">\n  <h2 class=\"@Title\">\n    <span class=\"@Title__english\">\n      <span>MY PAGE</span>\n    </span>\n    <span class=\"@Title__japanese\">\n      <span>マイページ</span>\n    </span>\n  </h2>\n</div>\n<!-- .PageTitle -->\n\n<section class=\"MypageContents -pcWidthSmall\">\n  <div class=\"MypageContents__inner\">\n    <div class=\"SectionDescription\">\n      <div class=\"SectionDescription__title -red -textCenter\">\n        <span class=\"SectionDescription__titleCaption\">ジェイアール名古屋タカシマヤのカード会員様限定</span>便利なインターネットサービス\n        <br>マイページ\n      </div>\n      <!-- .SectionDescription__title -->\n      <p class=\"SectionDescription__text\">マイページに登録すると、ジェイアール名古屋タカシマヤの最新情報をお届けするほか、ポイント照会、オンライン販売、リモショピ(スマホ決済)、イベント予約など、特典がいっぱい!</p>\n    </div>\n  </div>\n  <!-- .MypageContents__inner -->\n  <div class=\"BackgroundContents\">\n    <h3 class=\"BackgroundContents__title\">\n      <span class=\"BackgroundContents__titleIcon\">\n        <img src=\"/common/svg/icon_mypage.svg\" alt=\"\" class=\"IconSvg\">\n      </span >\n      <!-- .BackgroundContents__titleIcon -->サービスのご利用にはマイページの登録が必要です \n    </h3>\n    <!-- .BackgroundContents__title -->\n    <div class=\"BackgroundContents__button\">\n      <a href=\"#guide\" class=\"@ButtonB -arrowFrontBottom -smoothLink\">\n        <span class=\"@ButtonB__adjust\">マイページの新規ご登録方法はこちら</span>\n      </a>\n    </div>\n    <ul class=\"@ListNote -marginNone\">\n      <li class=\"@ListNote__item -black\">ジェイアール名古屋タカシマヤのクレジットカード・ポイントカードをお持ちでない方は\n        <a href=\"/card/\">こちら</a>\n      </li>\n    </ul>\n    <div class=\"BackgroundContents__button\">\n      <a href=\"/login/\" class=\"@ButtonB -formButton\">\n        <span class=\"@ButtonB__adjust\">ログインはこちら\n          <span class=\"@ButtonB__caption\">（マイページにご登録済みの方）</span>\n        </span>\n      </a>\n    </div>\n    <ul class=\"@ListNote -marginNone\">\n      <li class=\"@ListNote__item -black\">お使いの機種・端末により正常に登録できない場合や正常に機能しない・閲覧できない場合がございます。</li>\n      <li class=\"@ListNote__item -black\">情報登録に伴う通信料はお客さまのご負担となります。</li>\n      <li class=\"@ListNote__item -black\">マイページでの各種プレゼントポイントは、翌月7日または21日頃に付与されます。1月のみ8日または21日頃の付与となります。（一部、例外がございます）</li>\n    </ul>\n  </div>\n  <!-- .BackgroundContents -->\n  <div class=\"MypageContents__inner\">\n    <div class=\"MypageContents__pointImage\">\n      <img src=\"../img_point_2x_231017.png\" alt=\"新規ご登録でもれなく！タカシマヤのカードポイント100ポイントプレゼント！\" width=\"692\" height=\"192.5\">\n    </div>\n    <!-- .MypageContents__pointImage -->\n  </div>\n\n  <div class=\"MypageContents__inner -wrapTitleLine\">\n    <h3 class=\"@TitleLine\">\n      <span>マイページのうれしいサービス</span>\n    </h3>\n  </div>\n  <!-- .MypageContents__inner -->\n  <h4 class=\"@TitleIcon\">\n    <span class=\"@TitleIcon__icon\">\n      <img src=\"/common/svg/icon_bird.svg\" alt=\"\" class=\"IconSvg\">\n    </span>\n    <span class=\"@TitleIcon__text\">メールでタカシマヤの最新情報をお届け</span>\n  </h4>\n  <div class=\"MypageContents__inner\">\n    <p class=\"MypageContents__text\">メールマガジン「タカシマヤ通信」にてイベントや催し、カードキャンペーンの情報など、定期的に配信します。</p>\n    <!-- .MypageContents__text -->\n  </div>\n  <!-- .MypageContents__inner -->\n  <h4 class=\"@TitleIcon\">\n    <span class=\"@TitleIcon__icon\">\n      <img src=\"/common/svg/icon_point.svg\" alt=\"\" class=\"IconSvg\">\n    </span>\n    <span class=\"@TitleIcon__text\">ポイント照会サービスやポイントカードの会員情報の変更もスムーズ</span>\n  </h4>\n  <div class=\"MypageContents__inner\">\n    <p class=\"MypageContents__text\">ご登録のカードのポイント数や、基本ポイントご利用期間などをご確認いただけます。さらにポイントカードの各種ご登録内容・パスワードの変更ができます。</p>\n    <!-- .MypageContents__text -->\n  </div>\n  <!-- .MypageContents__inner -->\n  <h4 class=\"@TitleIcon\">\n    <span class=\"@TitleIcon__icon\">\n      <img src=\"/common/svg/icon_baby.svg\" alt=\"\" class=\"IconSvg\">\n    </span>\n    <span class=\"@TitleIcon__text\">ベビー＆キッズ ハッピークラブの特典</span>\n  </h4>\n  <div class=\"MypageContents__inner\">\n    <p class=\"MypageContents__text\">0～12歳(小学生以下)のおこさま・お孫さまの親御様またはご祖父母様、もしくはご出産予定の方がご登録いただくと、おこさま・お孫さまのご成⾧に合わせたプレゼントなど、さまざまな特典を受けられます。詳しい内容につきましては、下記の「ベビー&キッズハッピークラブのご案内」ページよりご確認ください。</p>\n    <!-- .MypageContents__text -->\n    <div class=\"BoderContents\">\n      <h4 class=\"BoderContents__headLine\">ご入会いただくと楽しい特典が！</h4>\n      <!-- .BoderContents__headLine -->\n      <h5 class=\"BoderContents__title\">特典1：新規ご入会で200ポイントプレゼント!</h5>\n      <!-- .BoderContents__title -->\n      <h5 class=\"BoderContents__title\">特典2：おこさま・お孫さま誕生月のお買物で300ポイントプレゼント(お買上げ条件があります)</h5>\n      <!-- .BoderContents__title -->\n      <h5 class=\"BoderContents__title\">特典3：新生児衣料・用品、マタニティーウェア売場でのお買物で粗品プレゼント</h5>\n      <!-- .BoderContents__title -->\n      <h5 class=\"BoderContents__title\">特典4：七五三、お宮参り用品売場(11階 きものサロン)でのお買物で粗品プレゼント</h5>\n      <!-- .BoderContents__title -->\n    </div>\n    <div class=\"MypageContents__button\">\n      <a href=\"/babykids_info/\" class=\"@ButtonB\">\n        <span class=\"@ButtonB__adjust\">ベビー＆キッズ \n          <br class=\"-spItem\">ハッピークラブのご案内\n        </span>\n      </a>\n    </div>\n    <!-- .MypageContents__button -->\n  </div>\n  <!-- .MypageContents__inner -->\n  <h4 class=\"@TitleIcon\">\n    <span class=\"@TitleIcon__icon\">\n      <img src=\"/common/svg/icon_cosme.svg\" alt=\"\" class=\"IconSvg\">\n    </span>\n    <span class=\"@TitleIcon__text\">コスメティックカウンター\n      <br>「カウンセリングサービス」の予約受付\n    </span>\n  </h4>\n  <div class=\"MypageContents__inner\">\n    <div class=\"MypageContents__pointImage\">\n      <img src=\"img/img_cosme@2x.jpg\" alt=\"\" width=\"666\" height=\"222\">\n    </div>\n    <!-- .MypageContents__pointImage -->\n    <p class=\"MypageContents__text\">3階 「コスメティックカウンター」での「カウンセリングサービス」がご予約いただけます。</p>\n    <!-- .MypageContents__text -->\n    <ul class=\"@ListNote -marginNone\" style=\"margin-bottom: 10px;\">\n      <li class=\"@ListNote__item -black\">サービスの特性上、女性向けのカウンセリングとなります。</li>\n    </ul>\n    <!-- .MypageContents__pointImage -->\n    <p class=\"MypageContents__text\"><strong style=\"color: #BC1601\">※こちらのサービスは2026年3月度よりジェイアール名古屋タカシマヤ アプリのランク特典として［ブロンズランク以上のお客さま限定］とさせていただきました。</strong></p>\n    <!-- .MypageContents__text -->\n    <div class=\"MypageContents__button\">\n      <a href=\"/cosmetic_info/\" class=\"@ButtonB\">\n        <span class=\"@ButtonB__adjust\">アプリランク特典「カウンセリングサービス」の詳細はこちら</span>\n      </a>\n    </div>\n    <!-- .MypageContents__button -->\n  </div>\n  <!-- .MypageContents__inner -->\n  <h4 class=\"@TitleIcon\">\n    <span class=\"@TitleIcon__icon\">\n      <img src=\"/common/svg/icon_lingerie.svg\" alt=\"\" class=\"IconSvg\">\n    </span>\n    <span class=\"@TitleIcon__text\">ランジェリーコンサルティングの予約受付</span>\n  </h4>\n  <div class=\"MypageContents__inner\">\n    <p class=\"MypageContents__text\">4階 ランジェリー ＆ リラクシング売場での「ランジェリーコンサルティング」がご予約いただけます。</p>\n    <!-- .MypageContents__text -->\n    <ul class=\"@ListNote -marginNone\">\n      <li class=\"@ListNote__item -black\">サービスの特性上、女性向けのカウンセリングとなります。</li>\n    </ul>\n    <div class=\"BoderContents\">\n      <h4 class=\"BoderContents__headLine\">「ランジェリーコンサルティング」メニューについて\n        <br>(要予約・無料)\n      </h4>\n      <!-- .BoderContents__headLine -->\n      <p class=\"BoderContents__text2\">事前にお悩みをお伺いし、人気ブランドのアドバイザーやジェイアール名古屋タカシマヤのランジェリーアドバイザーによる、完全予約制のコンサルティングをお試しいただけます。\n        <br>採寸、フィッティングをとおして、最適なランジェリーのご提案をします。\n      </p>\n       <h5 class=\"BoderContents__title\">１. ｢ジェイアール名古屋タカシマヤのランジェリーアドバイザー｣（約30～60分）</h5>\n        <dt class=\"BoderContents__definitionTerm\">ランジェリーアドバイザー</dt>\n        <dd class=\"BoderContents__definitionDescription\">ジェイアール名古屋タカシマヤのランジェリーアドバイザーなら、ブランドを問わずトータルにご相談いただけます。</dd>\n        <h5 class=\"BoderContents__title\">２. ｢各ブランドのアドバイザー｣（約30〜60分）</h5>\n        <p class=\"BoderContents__text2\">お客さまのご要望に寄り添ったランジェリー選びのお手伝いをいたします。</p>\n        <h6 class=\"BoderContents__title2\">対象ブランド</h6>\n         <dl class=\"BoderContents__definitionList\">\n          <div class=\"BoderContents__definitionList\">\n          <div class=\"BoderContents__definitionTerm\">ブラデリスニューヨーク</div>\n          <div class=\"BoderContents__definitionTerm\">トリンプ</div>\n          <div class=\"BoderContents__definitionTerm\">インポートブランド（リズ&nbsp;シャルメル）</div>\n          </div>\n         <ul class=\"@ListNote -marginNone\"><li class=\"@ListNote__item -black\">対象ブランドは変更になる場合がございます。</li></ul>\n        </dl>\n    </div>\n    <div class=\"MypageContents__button\">\n      <a href=\"/lingerie_info/\" class=\"@ButtonB\">\n        <span class=\"@ButtonB__adjust\">ランジェリーコンサルティング\n          <br class=\"-spItem\">のご案内\n        </span>\n      </a>\n    </div>\n    <!-- .MypageContents__button -->\n  </div>\n  <!-- .MypageContents__inner -->\n  <h4 class=\"@TitleIcon\">\n    <span class=\"@TitleIcon__icon\">\n      <img src=\"/common/svg/icon_apply.svg\" alt=\"\" class=\"IconSvg\">\n    </span>\n    <span class=\"@TitleIcon__text\">イベント・お申し込み履歴</span>\n  </h4>\n  <div class=\"MypageContents__inner\">\n    <p class=\"MypageContents__text\">各種イベントのお申し込み履歴を確認いただけます。</p>\n    <!-- .MypageContents__text -->\n  </div>\n\n  <!-- .MypageContents__inner -->\n  <h4 class=\"@TitleIcon\">\n    <span class=\"@TitleIcon__icon\">\n      <img src=\"/common/svg/icon_cart.svg\" alt=\"\" class=\"IconSvg\">\n    </span>\n    <span class=\"@TitleIcon__text\">オンライン販売</span>\n  </h4>\n  <div class=\"MypageContents__inner\">\n    <p class=\"MypageContents__text\">インターネットショッピングをお楽しみいただけます。</p>\n    <!-- .MypageContents__text -->\n  </div>\n\n  <!-- .MypageContents__inner -->\n        <h4 class=\"@TitleIcon\">\n          <span class=\"@TitleIcon__icon\"><img src=\"img2/icon_smartphone.svg\" alt=\"\" class=\"IconSvg\"></span>\n          <span class=\"@TitleIcon__text\">「リモショピ」</span>\n        </h4>\n        <div class=\"MypageContents__inner\">\n\n          <div class=\"MypageContents__pointImage\"><img src=\"img2/img_remoshoppi@2x.png\" alt=\"\" width=\"680\" height=\"227\"></div><!-- .MypageContents__pointImage -->\n\n          <p class=\"MypageContents__text\"><strong style=\"color: #BC1601\">ジェイアール名古屋タカシマヤの各種カードのご利用で通常ポイントが付きます！</strong><br>\n          ジェイアール名古屋タカシマヤで取り扱いのある商品を、来店することなくスマートフォンでご注文・ご決済いただけるリモートショッピングサービスです。</p><!-- .MypageContents__text -->\n          <ul class=\"@ListNote\">\n            <li class=\"@ListNote__item -black\">一部対象外の売場・商品がございます。</li>\n            <li class=\"@ListNote__item -black\">ポイントの使用はできません。</li>\n          </ul>\n          \n          <div class=\"MypageContents__button\">\n            <a href=\"/cp/remoteshopping/\" target=\"_blank\" class=\"@ButtonB\"><span class=\"@ButtonB__adjust\">「リモショピ」ご利用方法のご案内</span></a>\n          </div><!-- .MypageContents__button -->\n\n        </div><!-- .MypageContents__inner -->\n\n  <!-- .MypageContents__inner -->\n  <div class=\"MypageContents__inner -marginTopL\" id=\"guide\">\n    <h3 class=\"@TitleLine\">\n      <span>マイページの新規ご登録</span>\n    </h3>\n    <p class=\"MypageContents__text2\">マイページ登録にはジェイアール名古屋タカシマヤの各種カードが必要です。</p>\n    <!-- .MypageContents__text -->\n    <div class=\"BoderContents\">\n      <h5 class=\"BoderContents__title\">STEP１</h5>\n      <!-- .BoderContents__title -->\n      <p class=\"BoderContents__text2\">マイページログイン画面「新規会員登録」にて登録用メールアドレスを入力し、送信してください。</p>\n      <!-- .BoderContents__text2 -->\n       <p class=\"MypageContents__text\">\n         <picture>\n           <source media=\"(min-width: 768px)\" srcset=\"../../mypage_step1_pc.jpg\">\n           <source media=\"(max-width: 767.9px)\" srcset=\"../../mypage_step1_sp.jpg\">\n           <img src=\"../../mypage_step1_pc.jpg\" alt=\"ステップ1イメージ画像\">\n         </picture>\n       </p>\n      <h5 class=\"BoderContents__title\">STEP２</h5>\n      <!-- .BoderContents__title -->\n      <p class=\"BoderContents__text2\">メールアドレス送信後、jrnt-info@jr-takashimaya.co.jpより返信メールで認証番号が届きます。<br>返信メール本文に記載の認証番号を入力してください。</p>\n       <p class=\"MypageContents__text\">\n         <picture>\n           <source media=\"(min-width: 768px)\" srcset=\"../../mypage_step2_pc.jpg\">\n           <source media=\"(max-width: 767.9px)\" srcset=\"../../mypage_step2_sp.jpg\">\n           <img src=\"../../mypage_step2_pc.jpg\" alt=\"ステップ2イメージ画像\">\n         </picture>\n       </p>\n      <!-- .BoderContents__text2 -->\n      <h5 class=\"BoderContents__title2\">ご登録の前にご確認ください</h5>\n      <!-- .BoderContents__title -->\n      <p class=\"BoderContents__text2\">【ドメイン指定受信の確認】ドメイン指定受信（迷惑メール対策）をされている方は、お手数ではございますが[@jr-takashimaya.co.jp]を許可するドメインに追加登録してください。ドメイン許可されないとメールが届かない場合がございます。</p>\n      <!-- .BoderContents__text2 -->\n      <ul class=\"@ListNote -marginNone\">\n        <li class=\"@ListNote__item -black\">ご登録には スマートフォン・パソコンを推奨しております。</li>\n      </ul>\n    </div>\n  </div>\n  <!-- .MypageContents__inner -->\n  <div class=\"MypageContents__inner -marginTopL\">\n    <h3 class=\"@TitleLine\">\n      <span>マイページご登録に関するお問い合わせ</span>\n    </h3>\n    <p class=\"MypageContents__text\">マイページご登録に関するお問い合わせは以下よりお願いいたします。</p>\n    <!-- .MypageContents__text -->\n    <div class=\"MypageContents__tel\">\n      <h4 class=\"MypageContents__telTitle\">フリーダイヤル</h4>\n      <!-- .MypageContents__telTitle -->\n      <p class=\"MypageContents__telNumber\">0120-45-1101</p>\n      <!-- .MypageContents__telNumber -->\n      <p class=\"MypageContents__telCaption\">(受付時間:午前10時～午後6時／年末年始休み)</p>\n      <!-- .MypageContents__telCaption -->\n    </div>\n    <!-- .MypageContents__tel -->\n  </div>\n  <!-- .MypageContents__inner -->\n</section>\n<!-- .MypageContents -->\n\n\n\n\n</main>\n<div class=\"SnsBtn\">\n    <div class=\"SnsBtn__item -facebook\">\n      <a class=\"icon\" href=\"//www.facebook.com/sharer.php?src=bm&u=https://www.jr-takashimaya.co.jp/&t=【ジェイアール名古屋タカシマヤ】\" title=\"Facebookでシェア\" onclick=\"javascript:window.open(this.href, '_blank', 'menubar=no,toolbar=no,resizable=yes,scrollbars=yes,height=800,width=600');return false;\"><span><img src=\"/common/svg/icon_facebook.svg\" alt=\"\"></span></a>\n    </div>\n    <div class=\"SnsBtn__item -twitter\">\n      <a class=\"icon\" href=\"//twitter.com/share?text=【ジェイアール名古屋タカシマヤ】&url=https://www.jr-takashimaya.co.jp/\" title=\"Twitterでシェア\" onclick=\"javascript:window.open(this.href, '_blank', 'menubar=no,toolbar=no,resizable=yes,scrollbars=yes,height=400,width=600');return false;\"><span><img src=\"/common/svg/icon_twitter.svg\" alt=\"\"></span></a>\n    </div>\n    <div class=\"SnsBtn__item -line\">\n      <a class=\"icon\" href=\"//line.me/R/msg/text/?【ジェイアール名古屋タカシマヤ】%0Ahttps://www.jr-takashimaya.co.jp/\" target=\"_blank\" title=\"LINEに送る\"><span><img src=\"/common/svg/icon_line.svg\" alt=\"\"></span></a>\n    </div>\n  </div><!-- .SnsBtn -->\n  \n\n\n\n\n<div id=\"PageTop\" class=\"PageTop\"><a href=\"#\"><span class=\"PageTop__icon\"></span></a></div>\n\n<!-- ////////////////////////////////////////////////// Footer start -->\n<footer class=\"Footer\">\n<div class=\"Footer__inner\">\n\n  <div class=\"Footer__utility\">\n\n    <ul class=\"Footer__utilityList\">\n<!-- crosslanguage:delete -->\n      <li class=\"Footer__utilityListItem\"><a href=\"/floor/\">フロアガイド</a></l