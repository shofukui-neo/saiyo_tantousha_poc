k arw_ani\">\n\t\t\t\t\t\t\t<a href=\"/benesseinfo/sustainability/evaluation/index.html\"><span>外部評価・受賞実績</span></a>\n\t\t\t\t\t  </div>\n\t\t\t\t\t</li>\n\t\t\t\t</ul>\n\t\t\t</nav>\n\t\t</div>\n\n\t\t<div class=\"su-contents\">\n\t\t\t<h2 class=\"sustaina_title\"><span>動画で見る</span><span>ベネッセのサステナビリティ</span></h2>\n\t\t\t<nav id=\"sustaina_channel_movie\" class=\"sustaina_top_grid\">\n\t\t\t\t<a href=\"https://api01-platform.stream.co.jp/apiservice/plt3/MTc0Mw%3d%3d%23MTM5NA%3d%3d%23280%23168%230%2333E6A0D86400%23MDoyOjc6YTpmOzEwOzEwOzEw%23\" rel=\"noopener\" target=\"_blank\" class=\"sustaina_index_imgover\">\n\t\t\t\t\t<span class=\"sustaina_pic\"><img src=\"/benesseinfo/sustainability/images/channel-202604-1.jpg\" alt=\"\"></span>\n\t\t\t\t\t<span class=\"sustaina_txt su-fs\"><span>企業理念とベネッセアートサイト直島での活動</span></span>\n\t\t\t\t</a>\n\t\t\t\t<a href=\"https://api01-platform.stream.co.jp/apiservice/plt3/MTc0Mw%3d%3d%23MTI2Mw%3d%3d%23280%23168%230%2333E6A0D86400%23MDoyOjc6YTpmOzEwOzEwOzEw%23\" rel=\"noopener\" target=\"_blank\" class=\"sustaina_index_imgover\">\n\t\t\t\t\t<span class=\"sustaina_pic\"><img src=\"/benesseinfo/sustainability/images/channel-202503-2.jpg\" alt=\"\"></span>\n\t\t\t\t\t<span class=\"sustaina_txt su-fs\"><span>サステナビリティMovie特別編</span> <span><span>ベネッセアートサイト直島</span><span>特別インタビュー①</span></span></span>\n\t\t\t\t</a>\n\t\t\t\t<a href=\"https://api01-platform.stream.co.jp/apiservice/plt3/MTc0Mw%3d%3d%23MTI2Mg%3d%3d%23280%23168%230%2333E6A0D86400%23MDoyOjc6YTpmOzEwOzEwOzEw%23\" rel=\"noopener\" target=\"_blank\" class=\"sustaina_index_imgover\">\n\t\t\t\t\t<span class=\"sustaina_pic\"><img src=\"/benesseinfo/sustainability/images/channel-202503-3.jpg\" alt=\"\"></span>\n\t\t\t\t\t<span class=\"sustaina_txt su-fs\"><span>サステナビリティMovie特別編</span><span><span>ベネッセアートサイト直島</span><span>特別インタビュー②</span></span></span>\n\t\t\t\t</a>\n\t\t\t</nav>\n\t\t</div>\n\n\t\t<div class=\"su-contents_bg\">\n\t\t\t<nav class=\"su-contents\">\n\t\t\t\t<h2 class=\"sustaina_title\"><span>関連サイト・コンテンツ</span></h2>\n\t\t\t\t<ul id=\"sustaina_top_related\" class=\"sustaina_top_grid\">\n\t\t\t\t\t<li class=\"sustaina_top_related\">\n\t\t\t\t\t\t<a href=\"https://www.benesse.co.jp/brand/\" rel=\"noopener\" target=\"_blank\" class=\"sustaina_index_imgover\">\n\t\t\t\t\t\t\t<span class=\"sustaina_pic\"><img class=\"su-full\" src=\"/benesseinfo/sustainability/images/banner-brand.webp\" alt=\"\"></span>\n\t\t\t\t\t\t\t<span class=\"sustaina_txt\">\n\t\t\t\t\t\t\t\t<strong>サステナブルな社会へ from Benesse</strong>\n\t\t\t\t\t\t\t\t<span class=\"su-fs\">一人ひとりの「Benesse（よく生きる）」のために。持続可能な社会に向けた、ベネッセの“今”を発信しています。</span>\n\t\t\t\t\t\t\t</span>\n\t\t\t\t\t\t</a>\n\t\t\t\t\t</li>\n\t\t\t\t\t<li class=\"sustaina_top_related\">\n\t\t\t\t\t\t<a href=\"https://www.benesse.co.jp/well-being/about/\" rel=\"noopener\" target=\"_blank\" class=\"sustaina_index_imgover\">\n\t\t\t\t\t\t\t<span class=\"sustaina_pic\"><img class=\"su-full\" src=\"/benesseinfo/sustainability/images/banner-wb.webp\" alt=\"\"></span>\n\t\t\t\t\t\t\t<span class=\"sustaina_txt\">\n\t\t\t\t\t\t\t\t<strong>ウェルビーイングってなんだろう</strong>\n\t\t\t\t\t\t\t\t<span class=\"su-fs\">人生100年時代を生きる私たちや、これからの先の社会のキーワードとされる「ウェルビーイング」について、わかりやすく解説しています。</span>\n\t\t\t\t\t\t\t</span>\n\t\t\t\t\t\t</a>\n\t\t\t\t\t</li>\n\t\t\t\t</ul>\n\t\t\t</nav>\n\t\t</div>\n \t\t<script>\n\t\t(function(){\n\t\t\tconst count = 6000;\n\t\t\tconst $visual = document.querySelector('#vis');\n\t\t\tconst $vis = $visual.querySelectorAll('li');\n\t\t\tconst len = $vis.length;\n\t\t\tconst imgList = Array.from($vis).map(li => li.querySelector('img').src);\n\t\t\tlet current = 0;\n\t\t\tlet timer;\n\t\t\tPromise.all(imgList.map(src => {\n\t\t\t  const img = new Image();\n\t\t\t  img.src = src;\n\t\t\t  return img.decode().catch(() => {});\n\t\t\t}))\n\t\t\t.then(() => new Promise(resolve => setTimeout(resolve, count)))\n\t\t\t.then(() => {\n\t\t\t  visualFade();\n\t\t\t\tconst observer = new IntersectionObserver((entries) => {\n\t\t\t\t\tif(entries[0].isIntersecting) {\n\t\t\t\t\t\tclearTimeout(timer);\n\t\t\t\t\t\tsetTimeout(visualFade, count)\n\t\t\t\t\t}else{\n\t\t\t\t\t\tclearTimeout(timer);\n\t\t\t\t\t}\n\t\t\t\t},{ rootMargin: '-100px 0px 0px 0px'});\n\t\t\t\tobserver.observe($visual);\n\t\t\t});\n\t\t\tfunction visualFade() {\n\t\t\t  const next = (current >= len - 1) ? 0 : current + 1;\n\t\t\t  $vis[current].classList.remove('active');\n\t\t\t  $vis[next].classList.add('active');\n\t\t\t  $visual.className = 'active-' + next;\n\t\t\t  current = next;\n\t\t\t  timer = setTimeout(visualFade, count);\n\t\t\t}\n\t\t})();\n\t\t</script>\n\n\t\t<div class=\"LastUpDate\">最終更新日：2026年04月24日</div>\n\n\t</main>\n\t<!-- / l-main-->\n\n\t<div class=\"c-breadcrumb lower_type02\">\n\t\t<ul class=\"c-breadcrumb__items\">\n\t\t\t<li class=\"c-breadcrumb__item\"><a href=\"/\"><span>ベネッセトップ</span></a></li>\n\t\t\t<li class=\"c-breadcrumb__item\">企業情報</li>\n\t\t\t<li class=\"c-breadcrumb__item\">サステナビリティ</li>\n\t\t</ul>\n\t</div><!--/.c-breadcrumb-->\n\n\t<footer id=\"l-footer\" aria-label=\"Website Footer\">\r\n\t<div class=\"l-pagetop\"><p>ページトップへ</p></div>\r\n\t<div class=\"l-footer__inner\">\r\n\t\t<div class=\"l-footer-upperGroup\">\r\n\t\t\t<div class=\"l-footer-menuGroup\">\r\n\t\t\t\t<div class=\"l-primary-menu__items\">\r\n\t\t\t\t\t<div class=\"l-primary-menu__item\"><p class=\"l-primary-menu__name\">ベネッセコーポレーション企業情報</p></div>\r\n\t\t\t\t\t<ul class=\"l-primary-menu-child__items\">\r\n\t\t\t\t\t\t<li class=\"l-primary-menu-child__item\"><a href=\"/benesseinfo/data.html\">会社概要</a></li>\r\n\t\t\t\t\t\t<li class=\"l-primary-menu-child__item\"><a href=\"/benesseinfo/executive_member.html\">役員一覧</a></li>\r\n\t\t\t\t\t\t<li class=\"l-primary-menu-child__item\"><a href=\"/ism/\">企業哲学</a></li>\r\n\t\t\t\t\t\t<li class=\"l-primary-menu-child__item\"><a href=\"/purpose/\">パーパス</a></li>\r\n\t\t\t\t\t\t<li class=\"l-primary-menu-child__item\"><a href=\"/benesseinfo/group.html\">グループ会社</a></li>\r\n\t\t\t\t\t\t<li clas