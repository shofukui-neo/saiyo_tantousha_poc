    // アコーディオンが開いているときはheightをautoに設定\n            if (isOpen) {\n                next.addEventListener('transitionend', function() {\n                    next.style.height = 'auto';\n                }, { once: true });\n            }\n        };\n    });\n}\n\n// ウィンドウのリサイズ時にアコーディオンメニューを再計算\nwindow.addEventListener('resize', function() {\n    document.querySelectorAll('.accordion-btn').forEach(function(el) {\n        const next = el.nextElementSibling;\n        const nextH = next.scrollHeight + 'px';\n        next.style.height = el.classList.contains(\"open\") ? nextH : 0;\n    });\n});\n\n// ページロード時に初期化\nwindow.addEventListener('load', initializeAccordion);\n\t</script>\n</body>\n</html>\n","finalUrl":"https://www.magara.co.jp/recruit/shinsotsu-info/","rendered":false,"_cachedAt":"2026-06-23T23:49:16.701Z"}