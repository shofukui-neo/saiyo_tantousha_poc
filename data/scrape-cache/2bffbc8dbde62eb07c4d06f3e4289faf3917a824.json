 <li>\r\n          <a href=\"./index.html\"><img src=\"./assets/images/menu_00.png\" alt=\"TOP\"></a>\r\n      </li>\r\n      <li>\r\n          <a href=\"./number/\"><img src=\"./assets/images/menu_01.png\" alt=\"数字で見るヤマザキ\"></a>\r\n      </li>\r\n      <li>\r\n        <a href=\"./work/\"><img src=\"./assets/images/menu_04.png\" alt=\"どんな仕事？\"></a>\r\n      </li>\r\n      <li>\r\n          <a href=\"./interview/\"><img src=\"./assets/images/menu_02.png\" alt=\"先輩たちにインタビュー\"></a>\r\n      </li>\r\n      <li>\r\n        <a href=\"./exp/\"><img src=\"./assets/images/menu_10.png\" alt=\"先輩たちの座談会\"></a>\r\n      </li>\r\n      <li>\r\n          <a href=\"./lifestyle/\"><img src=\"./assets/images/menu_03.png\" alt=\"ヤマザキでの生活\"></a>\r\n      </li>\r\n      <li>\r\n        <a href=\"./factory/\"><img src=\"./assets/images/menu_08.png\" alt=\"応募前職場見学\"></a>\r\n      </li>\r\n      <li>\r\n        <a href=\"./parents/\"><img src=\"./assets/images/menu_06.png\" alt=\"保護者・先生の方へ\"></a>\r\n      </li>\r\n      <li>\r\n        <a href=\"./location/\"><img src=\"./assets/images/menu_07.png\" alt=\"事業所一覧\"></a>\r\n      </li>\r\n      <!-- <li> -->\r\n          <!-- <a href=\"./job/\"><img src=\"./assets/images/menu_05.png\" alt=\"職種診断\"></a> -->\r\n      <!-- </li> -->\r\n    </ul>\r\n\r\n    <a href=\"https://www.yamazakipan.co.jp\" target=\"_blank\" class=\"menu-bottom-btn\"><img src=\"./assets/images/menu_09.png\" alt=\"山崎製パン企業サイト\"></a>\r\n  </div>\r\n</nav>\r\n\r\n<main>\r\n  <section class=\"top-section-01\">\r\n    <h2 class=\"heading-text\">たくさんの誰かを、幸せにする仕事</h2>\r\n    <div class=\"text-01\">\r\n      \r\n      <p>「幸せな暮らし」そこには<br>\r\n        「朝の朝食に漂うトーストの香り」と<br>\r\n        笑顔があります。</p>\r\n      <p>パンには、人を幸せにする力がある。</p>\r\n      <p>その力を信じ、数えきれないほどのパンを私たちは日々作り出しています。<br>\r\n        つくった数だけ、食卓に幸せが届いて家族の笑顔が生まれるなら、<br>\r\n        それって、とても素敵なことだと思いませんか。<br>\r\n        自分のつくったパンが、誰かを幸せにしている・・・<br>\r\n        と幸せな気分になっている自分がいる。<br>\r\n        私たちの仕事は、突きつめるとそんな仕事です。</p>\r\n      <p>あなたと一緒に働けたなら、私も幸せ。</p>\r\n    </div>\r\n  </section>\r\n  <section class=\"top-section-02\">\r\n    \r\n    <ul class=\"list-block\">\r\n      <li class=\"list-block-item\">\r\n        <a href=\"./number/\">\r\n          <h2 class=\"heading heading-01\">数字で見るヤマザキ</h2>\r\n          <p class=\"text text-01\">いろんなデータを数字でご紹介</p>\r\n          <figure class=\"image image-01\"><img src=\"./assets/images/top_list_image_01.png\" alt=\"男女比はどのくらい？ 平均年齢は何歳？\"></figure>\r\n          <span class=\"btn-link more\">もっと詳しく</span>\r\n        </a>\r\n      </li>\r\n      <li class=\"list-block-item\">\r\n        <a href=\"./work/\">\r\n          <h2 class=\"heading heading-04\">どんな仕事？</h2>\r\n          <p class=\"text text-04\">お客様の手に渡るまでのパンの流れ、私達の仕事を紹介します。</p>\r\n          <figure class=\"image image-04\"><img src=\"./assets/images/top_list_image_04.png\" alt=\"どんな仕事\"></figure>\r\n          <span class=\"btn-link more\">もっと詳しく</span>\r\n        </a>\r\n      </li>\r\n      <li class=\"list-block-item\">\r\n        <a href=\"./interview/\">\r\n          <h2 class=\"heading heading-02\">先輩たちにインタビュー</h2>\r\n          <p class=\"text text-02\">不安がいっぱいな社会人。先輩の生の声を聞いてみましょう。</p>\r\n          <figure class=\"image image-02\"><img src=\"./assets/images/top_list_image_02.png\" alt=\"先輩たち\"></figure>\r\n          <span class=\"btn-link interview\">インタビューを読む</span>\r\n        </a>\r\n      </li>\r\n      <li class=\"list-block-item\">\r\n        <a href=\"./exp/\">\r\n          <h2 class=\"heading heading-09\">先輩たちの座談会</h2>\r\n          <p class=\"text text-09\">普段の仕事やプライベートのことなど、先輩たちの\"いつも\"を聞いてみました。</p>\r\n          <figure class=\"image image-09\"><img src=\"./assets/images/top_list_image_09.png\" alt=\"先輩たちの座談会\"></figure>\r\n          <span class=\"btn-link more\">もっと詳しく</span>\r\n        </a>\r\n      </li>\r\n      <li class=\"list-block-item\">\r\n        <a href=\"./lifestyle/\">\r\n          <h2 class=\"heading heading-03\">ヤマザキでの生活</h2>\r\n          <p class=\"text text-03\">何もかもが新しい社会人生活。先輩たちの生活をご紹介します！</p>\r\n          <figure class=\"image image-03\"><img src=\"./assets/images/top_list_image_03.png\" alt=\"日々の写真\"></figure>\r\n          <span class=\"btn-link more\">もっと詳しく</span>\r\n        </a>\r\n      </li>\r\n      <li class=\"list-block-item\">\r\n        <a href=\"./factory/\">\r\n          <h2 class=\"heading heading-08\">応募前職場見学</h2>\r\n          <p class=\"text text-08\">応募前にヤマザキパンの工場を見学してみよう</p>\r\n          <figure class=\"image image-08\"><img src=\"./assets/images/top_list_image_08.png\" alt=\"応募前職場見学\"></figure>\r\n          <span class=\"btn-link more\">もっと詳しく</span>\r\n        </a>\r\n      </li>\r\n      <!-- <li class=\"list-block-item\">\r\n        <a href=\"./job/\">\r\n          <h2 class=\"heading heading-05\">あなたにぴったりの職種、探してみませんか?</h2>\r\n          <figure class=\"image image-05\"><img src=\"./assets/images/top_list_image_05.png\" alt=\"職種診断\"></figure>\r\n          <span class=\"btn-link diag\">診断してみる</span>\r\n        </a>\r\n      </li> -->\r\n      <li class=\"list-block-item\">\r\n        <a href=\"./parents/\">\r\n          <h2 class=\"heading heading-06\">保護者の方へ -お問い合わせ-</h2>\r\n          <figure class=\"image image-06\"><img src=\"./assets/images/top_list_image_06.png\" alt=\"保護者の方へ\"></figure>\r\n          <span class=\"btn-link more\">もっと詳しく</span>\r\n        </a>\r\n      </li>\r\n      <li class=\"list-block-item\">\r\n        <a href=\"./location/\">\r\n          <h2 class=\"heading heading-07\">事務所を探す</h2>\r\n          <figure class=\"image image-07\"><img src=\"./assets/images/top_list_image_07.png\" alt=\"日本地図\"></figure>\r\n          <span class=\"btn-link more\">もっと詳しく</span>\r\n        </a>\r\n      </li>\r\n    </ul>\r\n\r\n    <div class=\"bottom-block\">\r\n      <a href=\"https://www.yamazakipan.co.jp/\" target=\"_blank\">\r\n        <h2 class=\"heading-text\">山崎製パンのことをもっと知る</h2>\r\n        <span class=\"btn-link\">山崎製パン企業サイト</span>\r\n      </a>\r\n    </div>\r\n  </section>\r\n</main>\r\n\r\n<