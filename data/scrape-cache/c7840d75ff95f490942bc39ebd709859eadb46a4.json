       <li><a href=\"/support/\">お客さまサポートトップ</a></li>\r\n              <li><a href=\"/support/faq/\">よくあるご質問</a></li>\r\n              <li>\r\n                <div>お問い合わせ・資料請求</div>\r\n                <ul class=\"c-header-nav-sp-list03\">\r\n                  <li><a href=\"https://qmnb.f.msgs.jp/webapp/form/26692_qmnb_1/index.do\" target=\"_blank\" rel=\"noopener\">ソリューション・製品に関するお問い合わせ</a></li>\r\n                  <li><a href=\"https://yagb.f.msgs.jp/webapp/form/21656_yagb_1/index.do\" target=\"_blank\" rel=\"noopener\">e-コレクト&reg;をご利用中の方のお問い合わせ</a></li>\r\n                  <li><a href=\"https://qmnb.f.msgs.jp/webapp/form/26692_qmnb_2/index.do\" target=\"_blank\" rel=\"noopener\">当社サービス以外のお問い合わせ</a></li>\r\n                  <li><a href=\"https://qmnb.f.msgs.jp/webapp/form/26692_qmnb_3/index.do\" target=\"_blank\" rel=\"noopener\">資料請求</a></li>\r\n                </ul>\r\n              </li>\r\n            </ul>\r\n          </li>\r\n          <li><a href=\"/strength/\">SGシステムの強み</a></li>\r\n          <li>\r\n            <button class=\"js-header-sp-item\" type=\"button\">採用情報</button>\r\n            <ul class=\"c-header-nav-sp-list02 js-header-sp-item__contents\">\r\n              <li><a href=\"/recruit/\">採用情報トップ</a></li>\r\n              <li><a href=\"/recruit/job/\">仕事を知る</a></li>\r\n              <li><a href=\"/recruit/people/\">人を知る</a></li>\r\n              <li><a href=\"/recruit/corporate/\">会社を知る</a></li>\r\n              <li><a href=\"/recruit/corporate/3min/\">数字で分かるSGシステム</a></li>\r\n              <li><a href=\"/recruit/guideline/\">募集要項</a></li>\r\n            </ul>\r\n          </li>\r\n          <li>\r\n            <button class=\"js-header-sp-item\" type=\"button\">企業情報</button>\r\n            <ul class=\"c-header-nav-sp-list02 js-header-sp-item__contents\">\r\n              <li><a href=\"/company/\">企業情報トップ</a></li>\r\n              <li><a href=\"/company/message/\">ごあいさつ</a></li>\r\n              <li><a href=\"/company/outline/\">会社概要</a></li>\r\n              <li><a href=\"/company/history/\">沿革</a></li>\r\n              <li><a href=\"/company/branch/\">事業所一覧</a></li>\r\n              <li><a href=\"/company/internal/\">内部統制基本方針</a></li>\r\n              <!--<li><a href=\"/company/faq/\">よくあるご質問</a></li>-->\r\n              <li><a href=\"https://www.sg-hldgs.co.jp/company/philosophy/\" target=\"_blank\" rel=\"noopener\">企業理念・行動憲章</a></li>\r\n            </ul>\r\n          </li>\r\n        </ul>\r\n      </div>\r\n      <div class=\"c-header-nav-sp__sub\">\r\n        <ul>\r\n          <li><a href=\"/service/e-collect/guide/\">e-コレクト&reg;のお申込</a></li>\r\n          <li><a href=\"https://www.e-service.sagawa-exp.co.jp/portal/do/login/show\" target=\"_blank\" rel=\"noopener\">スマートクラブログイン</a></li>\r\n        </ul>\r\n      </div>\r\n      <div class=\"c-header-nav-sp__contact\">\r\n        <a href=\"/support/#inquiry\">お問い合わせ</a>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</header>\r\n<div class=\"l-header__overlay\"></div>\n    <main class=\"l-main\">\n      <div class=\"recruit-header\">\r\n  <div class=\"recruit-header__inner\">\r\n    <div class=\"recruit-header__heading\">\r\n      <span>RECRUIT</span><span>SGシステムの採用情報</span>\r\n    </div>\r\n    <button class=\"recruit-header__menu\" type=\"button\"></button>\r\n    <div class=\"recruit-header__nav\">\r\n      <div>\r\n        <ul class=\"recruit-header__links\">\r\n          <li><a href=\"/recruit/\" class=\"recruit-header__item\" data-url=\"\"><span>トップ</span></a></li>\r\n          <li><a href=\"/recruit/corporate/\" class=\"recruit-header__item\" data-url=\"corporate\"><span>会社を知る</span></a></li>\r\n          <li><a href=\"/recruit/job/\" class=\"recruit-header__item\" data-url=\"job\"><span>仕事を知る</span></a></li>\r\n          <li><a href=\"/recruit/people/\" class=\"recruit-header__item\" data-url=\"people\"><span>人を知る</span></a></li>\r\n          <li><a href=\"/recruit/faq/\" class=\"recruit-header__item\" data-url=\"faq\"><span>よくあるご質問</span></a></li>\r\n        </ul>\r\n        <ul class=\"recruit-header__cta\">\r\n          <li><a href=\"https://job.mynavi.jp/27/pc/search/corp88148/outline.html\" target=\"_blank\" class=\"recruit-header__btn\"><span>新卒採用（マイナビ）</span></a></li>\r\n          <li><a href=\"https://jsd.jposting.net/sg-systems/\" target=\"_blank\" rel=\"noopener\" class=\"recruit-header__btn -career\"><span>中途採用</span></a></li>\r\n        </ul>\r\n      </div>\r\n    </div>\r\n  </div>\r\n  <div class=\"recruit-header__overlay\"></div>\r\n</div>\n            <div class=\"l-title -simple\">\r\n        <div class=\"l-title__inner\">\r\n          <h1 class=\"l-title__heading\">募集要項</h1>\r\n        </div>\r\n      </div>\r\n      <div class=\"recruit-block\">\r\n        <div class=\"recruit-block__inner u-pt-80 u-sp-pt-40\">\r\n          <section class=\"l-section\">\r\n            <h2 class=\"c-heading -large -mark u-mb-24 u-sp-mb-16\">新卒採用</h2>\r\n            <dl class=\"c-table-list\">\r\n              <div class=\"c-table-list__item\">\r\n                <dt>募集対象者</dt>\r\n                <dd>\r\n                  <p>2027年3月に大学院、大学、短期大学、高専、専門学校を卒業見込みの方</p>\r\n                  <ul class=\"c-list -note\">\r\n                    <li>既卒の方：3年まで対象</li>\r\n                    <li>高専の方：5年制から対象</li>\r\n                    <li>募集学科：全学部全学科対象</li>\r\n                    <li>留学生　：採用実績あり</li>\r\n                  </ul>\r\n                </dd>\r\n              </div>\r\n              <div class=\"c-table-list__item\">\r\n                <dt>募集職種</dt>\r\n                <dd>\r\n                  <p>総合職（ITエンジニア分野・営業分野・事務分野）<br>\r\n                    詳細につきましては「<a href=\"/recruit/job/\" class=\"c-link\">仕事を知る</a>」をご覧ください。</p>\r\n                  <ul class=\"c-list -note\">\r\n                    <li>配属に関しましては、選考時と研修時にヒアリング実施し、希望と適性に応じて決定しています。</li>\r\n                    <li>職種によっては全国転勤あり</li>\r\n                  </ul>\r\n                </dd>\r\n              </div>\r\n              <div class=\"c-table-list__item\">\r\n                <dt>勤務予定地</dt>\r\n                <dd>\r\n                  <p>東京、京都、大阪の事業所</p>\r\n                  <ul class=\"c-list -note\">\r\n                    <li>希望につきましては選考時お伺いし、配属先の決定方法同様、希望と適性にて決定いたします。</li>\r\n                  </ul>\r\n                </dd>\r\n              </div>\r\n              <div class=\"c-table-list__item\">\r\n                <dt>給与<br class=\"sp:view\">（月給）</dt>\r\n                <dd>\r\n                  <p class=\"u-font-bold\">大学院修了</p>\r\n                  <p>東京：258,000円〜　京都：248,000円〜</p>\r\n                  <hr class=\"c-line\">\r\n                  <p class=\"u-font-bold\">大学卒業</p>\r\n                  <p>東京：254,000円〜　京都：244,000円〜</p>\r\n                  <hr class=\"c-line\">\r\n                  <p class=\"u-font-bold\">短期大学卒業・専門学校卒業（2年制）・高専卒業（5年制）</p>\r\n                  <p>東京：234,000円〜　京都：224,000円〜</p>\r\n                  <hr class=\"c-line\">\r\n                  <ul class=\"c-list -note\">\r\n                    <li>2027年3月21日時点の満年齢により基本月額が変更となる場合がございます。</li>\r\n                    <li>既卒の場合は年齢に応じた金額となりますが、各学卒ともに上記金額を下回ることはございません。</li>\r\n                    <li>専門学校ご卒業で「高度専門士」の資格を取得されている場合は大学卒業同様となります。</li>\r\n                    <li>高等専門学校ご卒業で「学士」の学位を取得されている場合は大学卒業同様となります。</li>\r\n                    <li>勤務地手当を含んだ金額になります。東京勤務の場合は80,000円、京都勤務の場合は70,000円です。</li>\r\n                    <li>時間外勤務手当、通勤手当、住宅補助等の手当を含まない金額となります。</li>\r\n                  </ul>\r\n                </dd>\r\n              </div>\r\n              <div class=\"c-table-list__item\">\r\n                <dt>諸手当</dt>\r\n                <dd>\r\n                  <p>時間外勤務手当<br>\r\n                    通勤手当（1カ月150,000円まで（非課税限度額）、公共交通機関に限る）<br>\r\n                    赴任手当<br>\r\n                    単身赴任手当<br>\r\n                    休日勤務手当<br>\r\n                    深夜勤務手当<br>\r\n                    役職手当</p>\r\n                </dd>\r\n              </div>\r\n              <div class=\"c-table-list__item\">\r\n                <dt>昇給</dt>\r\n                <dd>年2回（5月度・11月度）</dd>\r\n              </div>\r\n              <div class=\"c-table-list__item\">\r\n                <dt>賞与</dt>\r\n                <dd>年2回（7月度・12月度）</dd>\r\n              </div>\r\n              <div class=\"c-table-list__item\">\r\n                <dt>勤務時間</dt>\r\n                <dd>\r\n                  <p>9：00～18：00（1時間休憩、8時間勤務）</p>\r\n                  <ul class=\"c-list -note\">\r\n                    <li>事業所や業務により若干の変動あり</li>\r\n                  </ul>\r\n                </dd>\r\n              </div>\r\n              <div class=\"c-table-list__item\">\r\n                <dt>休日休暇</dt>\r\n                <dd>\r\n                  <ul class=\"c-list -dot u-mb-16\">\r\n                    <li>年間休日121日（土日祝休み※）2026年度</li>\r\n                    <li>有給休暇（初年度10日間）</li>\r\n                  </ul>\r\n                  <ul class=\"c-list -note\">\r\n                    <li>事業所や業務により若干の変動あり</li>\r\n                  </ul>\r\n                </dd>\r\n              </div>\r\n              <div class=\"c-table-list__item\">\r\n                <dt>保険</dt>\r\n                <dd>雇用・労災・健康（グループ内健康保険組合）・厚生年金完備</dd>\r\n              </div>\r\n              <div class=\"c-table-list__item\">\r\n                <dt>福利厚生</dt>\r\n                <dd>詳細につきましては「<a href=\"/recruit/corporate/#a4\" class=\"c-link\">福利厚生</a>」をご覧ください。</dd>\r\n              </div>\r\n              <div class=\"c-table-list__item\">\r\n                <dt>採用人数</dt>\r\n                <dd>\r\n                  <p class=\"u-mb-0\">2027年度採用予定：40名程度</p>\r\n                  <ul class=\"c-list -note u-mb-8\">\r\n                    <li>あくまでも予定ですので、この限りではありません。</li>\r\n                  </ul>\r\n                  <p>2026年度実績：全国合計47名採用<br>\r\n                  2025年度実績：全国合計38名採用<br>\r\n                  2024年度実績：全国合計46名採用<br></p>\r\n                </dd>\r\n              </div>\r\n              <div class=\"c-table-list__item\">\r\n                <dt>採用実績（学校）</dt>\r\n                <dd>\r\n                  <p class=\"u-font-bold\">大学院</p>\r\n                  <p>大阪電気通信大学大学院・大妻女子大学大学院・岡山理科大学・関西大学大学院・九州大学大学院・京都工芸繊維大学大学・京都産業大学大学院・京都大学大学院・駒沢大学大学院・佐賀大学大学院・静岡大学大学院・東海大学大学院・東京大学大学院・同志社大学大学院・日本大学大学院・広島市立大学大学院・広島大学大学院・明治学院大学大学院・立命館大学大学院・山口大学大学院・早稲田大学大学院<br>\r\n                    etc…</p>\r\n                  <hr class=\"c-line\">\r\n                  <p class=\"u-font-bold\">大学</p>\r\n                  <p>青山学院大学・跡見学園女子大学・愛媛大学・桜美林大学・大阪経済大学・大阪工業大学・大阪大学・大谷大学・大妻女子大学・大阪電気通信大学・岡山理科大学・学習院大学・神奈川大学・金沢工業大学・金沢大学・関西学院大学・関西大学・関東学院大学・京都外国語大学・京都工芸繊維大学・京都産業大学・京都女子大学・京都先端科学大学・京都大学・京都府立大学・共立女子大学・近畿大学・群馬県立女子大学・慶應義塾大学・工学院大学・高知工科大学・高知大学・甲南大学・神戸市外国語大学・神戸大学・國學院大學・国際武道大学・駒沢女子大学・駒澤大学・埼玉大学・佐賀大学・首都大学東京・滋賀県立大学・滋賀大学・静岡大学・芝浦工業大学・城西大学・上智大学・成蹊大学・摂南大学・専修大学・拓殖大学・玉川大学・千葉工業大学・千葉大学・中央大学・中京大学・筑波大学・帝京大学・東海大学・東京外国語大学・東京経済大学・東京工科大学・東京都市大学・東京海洋大学・東京女子体育大学・東京電機大学・東京農業大学・東京理科大学・同志社女子大学・同志社大学・東洋大学・東邦大学・獨協大学・鳥取大学・名古屋大学・奈良女子大学・日本大学・日本女子大学・阪南大学・福岡大学・佛教大学・文教大学・法政大学・北海道情報大学・北海道大学・武庫川女子大学・武蔵大学・明治学院大学・明治大学・目白大学・立正大学・立教大学・立命館アジア太平洋大学・立命館大学・龍谷大学・流通科学大学・流通経済大学・早稲田大学<br>\r\n                    etc…</p>\r\n                  <hr class=\"c-line\">\r\n                  <p class=\"u-font-bold\">短期大学</p>\r\n                  <p>大阪国際女子短期大学・関西外国語大学短期大学部・京都外国語短期大学・京都女子大学短期大学部・京都聖母女学院短期大学・京都文教短期大学・岐阜市立女子短期大学・近畿大学短期大学・神戸女子短期大学・目白大学短期大学・拓殖短期大学<br>\r\n                    etc…</p>\r\n                  <hr class=\"c-line\">\r\n                  <p class=\"u-font-bold\">専門学校</p>\r\n                  <p>アクト情報ビジネス専門学校・麻生情報ビジネス専門学校・ECCコンピュータ専門学校・大阪情報コンピュータ専門学校・大阪電子専門学校・大原学園・金沢科学技術専門学校・京都コンピュータ学院・神戸電子専門学校・コンピュータ教育学院・東京工業専門学校・東京スクールオブビジネス・東京電子専門学校・トライデントコンピュータ専門学校・新潟コンピュータ専門学校・日本工学院・日本電子専門学校・HAL大阪・HAL東京・広島コンピュータ専門学校<br>\r\n                    etc…</p>\r\n                  <hr class=\"c-line\">\r\n                </dd>\r\n              </div>\r\n            </dl>\r\n          </section>\r\n          <section class=\"l-section\">\r\n            <h2 class=\"c-heading -large -mark u-mb-24 u-sp-mb-16\">選考プロセス</h2>\r\n            <h3 class=\"c-heading -small u-mb-16\">1． エントリー</h3>\r\n            <p class=\"u-mb-40\">就職情報サイト「<a href=\"https://job.mynavi.jp/27/pc/search/corp88148/outline.html\" target=\"_blank\" rel=\"noopener\" class=\"c-link\">マイナビ</a>」からエントリーが可能です。</p>\r\n            <h3 class=\"c-heading -small u-mb-16\">2． 会社説明会</h3>\r\n            <p class=\"u-mb-40\">就職情報サイトの弊社のページ、またはエントリー後、別途ご案内するマイページよりご予約が可能です。</p>\r\n            <h3 class=\"c-heading -small u-mb-16\">3． エントリーシート提出</h3>\r\n            <p class=\"u-mb-40\">マイページよりエントリーシートをご提出頂きます。</p>\r\n            <h3 class=\"c-heading -small u-mb-16\">4． 1次選考（グループディスカッション）</h3>\r\n            <p class=\"u-mb-40\">3名～6名のグループを組み、課題へ取り組んで頂きます。</p>\r\n            <h3 class=\"c-heading -small u-mb-16\">5． 最終選考（個別面接）</h3>\r\n            <p class=\"u-mb-40\">個別面接（部長相当）を行います。</p>\r\n          </section>\r\n        </div>\r\n      </div>\r\n      <div class=\"recruit-entry\">\r\n  <div class=\"recruit-entry__block\">\r\n    <h2 class=\"recruit-entry__heading\">ENTRY</h2>\r\n    <p class=\"recruit-entry__lead\">SGシステムで一緒に<br class=\"sp-tb:view\">未来を作りませんか</p>\r\n    <p class=\"recruit-entry__txt\">私たちとこれからの物流を変える一歩を<br class=\"sp:view\">踏み出しませんか？<br>\r\n      エントリーはこちらからお願いします。</p>\r\n    <div class=\"recruit-entry__btn\">\r\n      <a href=\"https://job.mynavi.jp/27/pc/search/corp88148/outline.html\" target=\"_blank\" rel=\"noopener\" class=\"recruit-btn\"><span>新卒採用（マイナビ）</span></a>\r\n      <a href=\"https://jsd.jposting.net/sg-systems/\" target=\"_blank\" rel=\"noopener\" class=\"recruit-btn\"><span>中途採用</span></a>\r\n    </div>\r\n    <a href=\"https://qmnb.f.msgs.jp/webapp/form/26692_qmnb_2/index.do\" target=\"_blank\" rel=\"noopener\" class=\"recruit-entry__link01\">\r\n      <div>採用に関するお問い合わせ</div>\r\n    </a>\r\n    <a href=\"https://www.sg-hldgs.co.jp/recruit/group-recruit/\" target=\"_blank\" rel=\"noopener\" class=\"recruit-entry__link02\">\r\n      <div>SGホールディングスグループ合同採用募集</div>\r\n    </a>\r\n  </div>\r\n</div>\r\n<div class=\"l-block\">\r\n  <div class=\"l-block__inner\">\r\n    <h3 class=\"recruit-heading -medium u-mb-40 u-sp-mb-32\">関連リンク</h3>\r\n    <div class=\"c-btn-wrap\">\r\n      <a href=\"/strength/\" class=\"recruit-btn\"><span>SGシステムの強み</span></a>\r\n    </div>\r\n  </div>\r\n</div>\r\n<div class=\"recruit-bottom\">\r\n  <button class=\"recruit-bottom__open\" type=\"button\">応募する</button>\r\n  <div class=\"recruit-bottom__modal\">\r\n    <div class=\"recruit-bottom__heading\">応募する</div>\r\n    <p class=\"recruit-bottom__txt\">物流×ITのリーディングカンパニーを目指し、<br>\r\n      活躍していただける人材を募集しています。</p>\r\n    <div class=\"recruit-bottom__cta\">\r\n      <a href=\"https://job.mynavi.jp/27/pc/search/corp88148/outline.html\" target=\"_blank\" rel=\"noopener\" class=\"recruit-bottom__btn\"><span>新卒採用（マイナビ）</span></a>\r\n      <!--<a href=\"\" target=\"_blank\" rel=\"noopener\" class=\"recruit-bottom__btn\"><span>新卒採用（リクナビ）</span></a>-->\r\n      <a href=\"https://jsd.jposting.net/sg-systems/\" target=\"_blank\" rel=\"noopener\" class=\"recruit-bottom__btn\"><span>中途採用</span></a>\r\n      <a href=\"https://qmnb.f.msgs.jp/webapp/form/26692_qmnb_2/index.do\" target=\"_blank\" rel=\"noopener\" class=\"recruit-bottom__btn -contact\"><span>お問い合わせ</span></a>\r\n    </div>\r\n    <button class=\"recruit-bottom__close\"></button>\r\n  </div>\r\n</div>\r\n      <div class=\"l-breadcrumb\">\r\n        <div class=\"l-breadcrumb__inner\">\r\n          <ol class=\"l-breadcrumb__list\">\r\n            <li class=\"l-breadcrumb__item\"><a href=\"/\">ホーム</a></li>\r\n            <li class=\"l-breadcrumb__item\"><a href=\"/recruit/\">採用情報</a></li>\r\n            <li class=\"l-breadcrumb__item\"><a href=\"/recruit/guideline/\">募集要項</a></li>\r\n          </ol>\r\n        </div>\r\n      </div>\n    </main>\n    ﻿<footer class=\"l-footer\">\r\n  <div class=\"l-footer__pagetop\">\r\n    <a href=\"#\"></a>\r\n  </div>\r\n  <div class=\"l-footer__head\">\r\n    <div class=\"l-footer__logo\">\r\n      <div>\r\n        <