/wp-content/plugins/easy-fancybox/css/jquery.fancybox.min.css?ver=1.3.24' type='text/css' media='screen' />\n<script type='text/javascript' src='https://koei-e.jp/wp/wp-includes/js/jquery/jquery.js?ver=1.12.4-wp'></script>\n<script type='text/javascript' src='https://koei-e.jp/wp/wp-includes/js/jquery/jquery-migrate.min.js?ver=1.4.1'></script>\n<link rel='https://api.w.org/' href='https://koei-e.jp/wp-json/' />\n<link rel=\"canonical\" href=\"https://koei-e.jp/recruit/\" />\n<link rel='shortlink' href='https://koei-e.jp/?p=26' />\n<link rel=\"alternate\" type=\"application/json+oembed\" href=\"https://koei-e.jp/wp-json/oembed/1.0/embed?url=https%3A%2F%2Fkoei-e.jp%2Frecruit%2F\" />\n<link rel=\"alternate\" type=\"text/xml+oembed\" href=\"https://koei-e.jp/wp-json/oembed/1.0/embed?url=https%3A%2F%2Fkoei-e.jp%2Frecruit%2F&#038;format=xml\" />\n<meta name=\"cdp-version\" content=\"1.1.7\" />\t\t<style type=\"text/css\" id=\"wp-custom-css\">\n\t\t\t#copyright_inner {\n\twidth: 100% !important;\n}\nul.lst-ftbana {\n\tjustify-content: center;\n}\n\n.ss-fig h5 {\n\tline-height: 2;\n\tmargin: 0;\n\tfont-size: 1em;\n\ttext-align: center;\n\tbackground: #967613;\n\tcolor: #fff;\n}\n.ss-fig img {\n\twidth: 100%;\n}\n\n.carlife-portal {\n\tborder: 2px solid #967613;\n\tbackground: #fff;\n\tpadding: clamp(14px, calc(1.5909 * 1vw + 8.9091px), 28px);\n\tborder-radius: 8px;\n}\n#main_col .carlife-portal h3 {\n\tcolor: #967613;\n\tline-height: 1.3;\n\ttext-align: center\n}\n#main_col .carlife-portal a {\n\tposition: relative;\n\tdisplay: block;\n\tbackground: #967613;\n\tcolor: #fff;\n\tfont-size: 3.8vw;\n\tfont-weight: bold;\n\ttext-decoration: none;\n\ttext-align: center;\n\tpadding: 16px 0;\n\tborder-radius: 4px;\n\tline-height: 1.3\n}\n#main_col .carlife-portal a::after {\n\tcontent: '';\n\tposition: absolute;\n\tright: 15px;\n\ttop: calc(50% - 8px);\n\tdisplay: block;\n\theight: 16px;\n\twidth: 16px;\n\tbackground-image: url(https://koei-e.jp/wp/wp-content/themes/precious_tcd019