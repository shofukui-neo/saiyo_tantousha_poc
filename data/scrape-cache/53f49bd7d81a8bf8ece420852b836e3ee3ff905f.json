pt>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'UA-140934017-39');\n</script>\n<!-- Global site tag (gtag.js) - Google Analytics -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-SZ9B8RBVZ7\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'G-SZ9B8RBVZ7');\n</script>\n</head>\n<body class=\"page-template page-template-page-noside page-template-page-noside-php page page-id-26\">\n\n <div id=\"header_wrap\">\n  <div id=\"header\" class=\"clearfix\">\n\n   <!-- logo -->\n   <h1 id=\"logo_image\" style=\"top:18px; left:14px;\"><a href=\" https://koei-e.jp/\" title=\"興栄燃料株式会社\"><img src=\"https://koei-e.jp/wp/wp-content/uploads/tcd-w/logo.png?1782165887\" alt=\"興栄燃料株式会社\" title=\"興栄燃料株式会社\" /></a></h1>\n\n   <!-- global menu -->\n   <a href=\"#\" class=\"menu_button\"></a>\n   <div id=\"global_menu\" class=\"clearfix\">\n    <ul id=\"menu-%e3%83%a1%e3%83%8b%e3%83%a5%e3%83%bc\" class=\"menu\"><li id=\"menu-item-426\" class=\"menu-item menu-item-type-custom menu-item-object-custom menu-item-home menu-item-426\"><a href=\"https://koei-e.jp/\">HOME</a></li>\n<li id=\"menu-item-736\" class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-736\"><a href=\"https://koei-e.jp/ss/\">サービスステーション事業</a></li>\n<li id=\"menu-item-552\" class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-552\"><a href=\"https://koei-e.jp/carlife/\">カーライフ事業</a></li>\n<li id=\"menu-item-564\" class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-564\"><a href=\"https://koei-e.jp/homelife/\">ホームライフ事業</a></li>\n<li id=\"menu-item-609\" class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-609\"><a href=\"https://koei-e.jp/oil/\">産業エネルギー事業</a></li>\n<li id=\"menu-item-422\" class=\"menu-item menu-item-type-post_type menu-item-object-page current-menu-item page_item page-item-26 current_page_item menu-item-422\"><a href=\"https://koei-e.jp/recruit/\" aria-current=\"page\">リクルート情報</a></li>\n<li id=\"menu-item-425\" class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-425\"><a href=\"https://koei-e.jp/company/\">会社概要</a></li>\n</ul>   </div>\n\n   <!-- submenu -->\n   <ul class=\"header__sub\">\n     <li><a href=\"https://koei-e.jp/privacy/\">個人情報保護方針</a></li>\n     <li><a href=\"https://koei-e.jp/contact/\">お問い合わせ</a></li>\n   </ul>\n\n  </div><!-- END #header -->\n </div><!-- END #header_wrap -->\n\n \n<!-- header image -->\n<section class=\"headerimg\">\n    <div class=\"fig-headerimg\"><img src=\"https://koei-e.jp/wp/wp-content/uploads/2020/07/recruit_header.jpg\" alt=\"リクルート情報\" /></div>\n  <div class=\"tx-headerimg\">\n    <h2 class=\"ttl-headerimg\">リクルート情報</h2>\n    <p class=\"catch-headerimg\">RECRUIT</p>\n  </div>\n</section>\n<!-- /header image -->\n\n\n <div id=\"main_contents_wrap\">\n  <div id=\"main_contents\" class=\"clearfix\">\n    \n        \n<ul id=\"bread_crumb\" class=\"clearfix\">\n <li itemscope=\"itemscope\" itemtype=\"http://data-vocabulary.org/Breadcrumb\" class=\"home\"><a itemprop=\"url\" href=\"https://koei-e.jp/\"><span itemprop=\"title\">Home</span></a></li>\n\n\n <li class=\"last\">リクルート情報</li>\n\n </ul>\n    \n\n<div id=\"main_col\" class=\"recruit\">\n\n \n\n\n <h1 class=\"headline1\"><span>リクルート情報</span></h1>\n\n <div class=\"post clearfix\">\n     </div><!-- END .post -->\n\n \n <section class=\"blc-cnts recblock\">\n\t<h2><span>興栄燃料とは・・・</span></h2>\n\t\t<h3 class=\"big\">興栄燃料は、地域密着型カーライフ・ホームライフの安心をお届けする総合エネルギー企業です。</h3>\n\t<p>薪炭の卸売業として1947年に創業し、70余年。<br />\r\n <br />\r\n千葉市中心に11拠点ネットワークするガソリンスタンド運営を中心に、地域エネルギーの安定供給とご来店いただくお車への安心をご提供するカーライフ事業を展開してまいりました。<br />\r\nまた、一方ではご家庭になくてはならないLPガスの安定供給を主軸に、太陽光発電、住宅設備機器、エネファームのご提供等々、地域の皆様のカーライフ・ホームライフの安心をお届けする事業基盤を作り上げている地域密型の総合エネルギー企業として確かな事業基盤を築いております。<br />\r\n <br />\r\nしかしながら、これら事業基盤の根幹にある逞しさや安心感の源泉とは、「人の力」＝「人の大切さ」であった事は、これまでの長い歴史と実績が物語っています。  <br />\r\nこれらは、会社の成長と共に人の成長を意識し、職場環境においても資格取得支援制度や福利厚生充実の推進、頑張った人がきちんと評価を得ることができる環境を整えるなど、社員の成長を強く推進した結果であると確信しております。<br />\r\n<br />\r\n地域のお客様に安心をお届けする総合エネルギー企業、興栄燃料で共に飛躍し共に成長しませんか？</p>\n\t</section>\n\n<section class=\"blc-cnts recblock\">\n\t<h2><span>こんな仕事を任せたい　～仕事内容～</span></h2>\n\t<h3 class=\"big\">【正社員募集】</h3>\n\t<p class=\"subttl\">■職種：サービスステーションスタッフ・マネージャー候補　<br />\r\n　業務内容：サービスステーション店舗運営</h3>\n\t<!--<div class=\"box-message member\">\n\t\t<figure><img src=\"https://koei-e.jp/wp/wp-content/uploads/2026/06/staff_ss-1.jpg\" alt=\"\"></figure>\n\t\t<div class=\"tx\">\n\t\t\t<p>サービスステーションスタッフとして、店舗運営全般に関わる業務をお任せする事になりますが、その後、徐々に業務レベルの階段を上がり成果が伴えば、店舗をマネジメントする立場となっていきます。<br />\r\nサービスステーションは、サービス業としてお客様が何を求めているのかを見極め、品質向上や業務改善・効率化を考え実践し、店舗マネジメント者として、結果が素早く手に入れる事ができる大変遣り甲斐のある環境です。<br />\r\n段階的にさまざまな業務を経験しマネージャーを目指すキャリアアッププランとなりますが、他事業へのキャリアチェンジも可能なので、自身の可能性を最大限に発揮して次のチャンスも掴めるポジションでもあります。 </p>\n\t\t</div>\n\t</div>-->\n\n\t\t<ul class=\"box-figs-def bet\">\n\t\t\t\t<li><img src=\"https://koei-e.jp/wp/wp-content/uploads/2026/06/staff_ss-1.jpg\" alt=\"\"></li>\n\t\t\t</ul>\n\t\t\t<p class=\"mb\">サービスステーションスタッフとして、店舗運営全般に関わる業務をお任せする事になりますが、その後、徐々に業務レベルの階段を上がり成果が伴えば、店舗をマネジメントする立場となっていきます。<br />\r\nサービスステーションは、サービス業としてお客様が何を求めているのかを見極め、品質向上や業務改善・効率化を考え実践し、店舗マネジメント者として、結果が素早く手に入れる事ができる大変遣り甲斐のある環境です。<br />\r\n段階的にさまざまな業務を経験しマネージャーを目指すキャリアアッププランとなりますが、他事業へのキャリアチェンジも可能なので、自身の可能性を最大限に発揮して次のチャンスも掴めるポジションでもあります。 </p>\n\t\t\t\n\t<p class=\"subttl\">■職種：検査員・整備士<br />\r\n　業務内容：車検整備・車検検査・一般整備</h3>\n\t<!--<div class=\"box-message member\">\n\t\t<figure><img src=\"https://koei-e.jp/wp/wp-content/uploads/2020/07/整備士-1.jpg\" alt=\"\"></figure>\n\t\t<div class=\"tx\">\n\t\t\t<p>当社の「KOEI車検センター」は国交省の厳しい基準をクリアした指定民間車検工場です。これまでに50,000台以上の車検を実施し、多くの車検実績を誇るまでに成長して参りました。<br />\r\n車検・整備というのは、お客様からの信頼を勝ち取るためのスキルが必要ですが、当社では未経験であっても、実際の業務に就きながら、さまざまな知識を習得し、資格取得制度も確立しています。<br />\r\n指定民間車検工場のメリットを活かした、専門性の高い幅広い業務に就きながら、整備士だけでなく、その先の検査員の資格習得のチャンスもあります。経験者の方で、さらにキャリアアップを挑みたい方にお勧めな環境です。<br />\r\n  <br />\r\nまずは、サービスステーションの受付業務からスタートしていただきますが、そこでは地域のお客様と直接接し、業務知識やお客様対応と共に業務の流れを習得していただく事になります。<br />\r\nその後、資格取得制度を利用しキャリアアップにつなげるなど、プロフェッショナル集団の一員になり、さまざまなチャンスを掴んでいただく事になります。</p>\n\t\t</div>\n\t</div>-->\n\n\t\t<ul class=\"box-figs-def bet\">\n\t\t\t\t<li><img src=\"https://koei-e.jp/wp/wp-content/uploads/2020/07/整備士-1.jpg\" alt=\"\"></li>\n\t\t\t</ul>\n\t\t\t<p class=\"mb\">当社の「KOEI車検センター」は国交省の厳しい基準をクリアした指定民間車検工場です。これまでに50,000台以上の車検を実施し、多くの車検実績を誇るまでに成長して参りました。<br />\r\n車検・整備というのは、お客様からの信頼を勝ち取るためのスキルが必要ですが、当社では未経験であっても、実際の業務に就きながら、さまざまな知識を習得し、資格取得制度も確立しています。<br />\r\n指定民間車検工場のメリットを活かした、専門性の高い幅広い業務に就きながら、整備士だけでなく、その先の検査員の資格習得のチャンスもあります。経験者の方で、さらにキャリアアップを挑みたい方にお勧めな環境です。<br />\r\n  <br />\r\nまずは、サービスステーションの受付業務からスタートしていただきますが、そこでは地域のお客様と直接接し、業務知識やお客様対応と共に業務の流れを習得していただく事になります。<br />\r\nその後、資格取得制度を利用しキャリアアップにつなげるなど、プロフェッショナル集団の一員になり、さまざまなチャンスを掴んでいただく事になります。</p>\n\t\t\t\n\t<p class=\"subttl\">■職種：営業〔リテール〕<br />\r\n　業務内容：LPガス・住宅機器販売</h3>\n\t<!--<div class=\"box-message member\">\n\t\t<figure><img src=\"https://koei-e.jp/wp/wp-content/uploads/2021/05/recruit_gas.jpg\" alt=\"\"></figure>\n\t\t<div class=\"tx\">\n\t\t\t<p>LPガスや機器の提案、大切な生活空間のリフォームなどお客様のホームライフをサポートするやりがいある仕事です。<br />\r\n地域の一般家庭へのLPガス販売・保安サービス事業をおこなっています。\u000b環境にやさしいクリーンエネルギー、LPガスは一般家庭の暮らしになくてはならないホームエネルギーなので、安定供給はもちろん事ながら、安全にご利用いただくため、365日24時間体制で集中監視し、緊急時の対応にも万全を期すなど、ホームエネルギーの安定供給を担う大変遣り甲斐のある仕事です。<br />\r\nまた、専門知識を習得して快適な生活の提案や、省燃費ガス機器の提案・販売を通じて、環境への貢献などお客様の身近なパートナーとしてキャリアアップの階段を上がる事も可能です。<br />\r\n先輩達からのＯＪＴ研修、資格取得制度により、自分の成長に繋げて下さい。</p>\n\t\t</div>\n\t</div>-->\n\n\t\t<ul class=\"box-figs-def bet\">\n\t\t\t\t<li><img src=\"https://koei-e.jp/wp/wp-content/uploads/2021/05/recruit_gas.jpg\" alt=\"\"></li>\n\t\t\t</ul>\n\t\t\t<p class=\"mb\">LPガスや機器の提案、大切な生活空間のリフォームなどお客様のホームライフをサポートするやりがいある仕事です。<br />\r\n地域の一般家庭へのLPガス販売・保安サービス事業をおこなっています。\u000b環境にやさしいクリーンエネルギー、LPガスは一般家庭の暮らしになくてはならないホームエネルギーなので、安定供給はもちろん事ながら、安全にご利用いただくため、365日24時間体制で集中監視し、緊急時の対応にも万全を期すなど、ホームエネルギーの安定供給を担う大変遣り甲斐のある仕事です。<br />\r\nまた、専門知識を習得して快適な生活の提案や、省燃費ガス機器の提案・販売を通じて、環境への貢献などお客様の身近なパートナーとしてキャリアアップの階段を上がる事も可能です。<br />\r\n先輩達からのＯＪＴ研修、資格取得制度により、自分の成長に繋げて下さい。</p>\n\t\t\t\n\t<p class=\"subttl\">■職種：営業〔リテール・法人〕<br />\r\n　業務内容：太陽光発電販売</h3>\n\t<!--<div class=\"box-message member\">\n\t\t<figure><img src=\"https://koei-e.jp/wp/wp-content/uploads/2020/06/太陽光発電.jpg\" alt=\"\"></figure>\n\t\t<div class=\"tx\">\n\t\t\t<p>環境にやさしいエネルギーと快適な生活をお届けすることを使命として、太陽光発電システムの普及に取り組む仕事です。<br />\r\n太陽光発電で得た電力の販売や発電機導入など、お客様にご満足いただけるよう「販売・施工・アフターメンテナンス」の知識を身に付け、お客様に寄り添う充実した仕事を得る事ができます。</p>\n\t\t</div>\n\t</div>-->\n\n\t\t<ul class=\"box-figs-def bet\">\n\t\t\t\t<li><img src=\"https://koei-e.jp/wp/wp-content/uploads/2020/06/太陽光発電.jpg\" alt=\"\"></li>\n\t\t\t</ul>\n\t\t\t<p class=\"mb\">環境にやさしいエネルギーと快適な生活をお届けすることを使命として、太陽光発電システムの普及に取り組む仕事です。<br />\r\n太陽光発電で得た電力の販売や発電機導入など、お客様にご満足いただけるよう「販売・施工・アフターメンテナンス」の知識を身に付け、お客様に寄り添う充実した仕事を得る事ができます。</p>\n\t\t<div class=\"fig-business\"><a href=\"https://koei-energy.jbplt.jp/\" target=\"_blank\"><img src=\"https://koei-e.jp/wp/wp-content/uploads/2021/06/airwork_logo.png\" alt=\"\"></a></div>\n\t\t\t\n\t<p class=\"subttl\">■職種：ドライバー等<br />\r\n　業務内容：LPガス配送ドライバー及び充填作業</h3>\n\t<!--<div class=\"box-message member\">\n\t\t<figure><img src=\"https://koei-e.jp/wp/wp-content/uploads/2021/05/recruit_driver.jpg\" alt=\"\"></figure>\n\t\t<div class=\"tx\">\n\t\t\t<p>地元企業様への産業エネルギーである、ガソリン、灯油、軽油、重油、潤滑油の安定供給を担う仕事です。地域経済を支える産業エネルギーの供給は大変遣り甲斐のある仕事でもあり、知識と経験が必要です。<br />\r\n省燃費や環境対策が企業の社会的責任として求められているので、多様なニーズに応えるための知識習得は必須ですが、社内には資格取得支援制度やビジネスマナー研修など万全の教育制度があるので、自身の成長から成果につなげることができます。</p>\n\t\t</div>\n\t</div>-->\n\n\t\t<ul class=\"box-figs-def bet\">\n\t\t\t\t<li><img src=\"https://koei-e.jp/wp/wp-content/uploads/2021/05/recruit_driver.jpg\" alt=\"\"></li>\n\t\t\t</ul>\n\t\t\t<p class=\"mb\">地元企業様への産業エネルギーである、ガソリン、灯油、軽油、重油、潤滑油の安定供給を担う仕事です。地域経済を支える産業エネルギーの供給は大変遣り甲斐のある仕事でもあり、知識と経験が必要です。<br />\r\n省燃費や環境対策が企業の社会的責任として求められているので、多様なニーズに応えるための知識習得は必須ですが、社内には資格取得支援制度やビジネスマナー研修など万全の教育制度があるので、自身の成長から成果につなげることができます。</p>\n\t\t\t<h3 class=\"big\"><br>【パートアルバイト募集】<br />\r\n</h3>\n\t<p class=\"subttl\">■職種：サービスステーションスタッフ<br />\r\n　業務内容：各種受付・作業・サービス</h3>\n\t<!--<div class=\"box-message member\">\n\t\t<figure><img src=\"https://koei-e.jp/wp/wp-content/uploads/2026/06/staff_eneos-1.jpg\" alt=\"\"></figure>\n\t\t<div class=\"tx\">\n\t\t\t<p>ENEOSサービスステーションを千葉県下に11店舗運営しているため、出来る限り自宅近くのお店が選択できます。<br />\r\n高速道路の酒々井パーキングエリアSSを除く全てのサービスステーションでセルフ化しているため、給油接客作業は有りませんが、各種サービスの提供・車検・洗車整備等の受付・作業のおこなっていただきます。<br />\r\nさまざまな業務知識を習得していただく必要がありますが、先輩たちによるOJTや研修もしっかりしているので安心して就業できます。<br />\r\n仕事の楽しさから、多くのスキルを身に付け正社員になり、マネージャーになった方もいますよ。</p>\n\t\t</div>\n\t</div>-->\n\n\t\t<ul class=\"box-figs-def bet\">\n\t\t\t\t<li><img src=\"https://koei-e.jp/wp/wp-content/uploads/2026/06/staff_eneos-1.jpg\" alt=\"\"></li>\n\t\t\t</ul>\n\t\t\t<p class=\"mb\">ENEOSサービスステーションを千葉県下に11店舗運営しているため、出来る限り自宅近くのお店が選択できます。<br />\r\n高速道路の酒々井パーキングエリアSSを除く全てのサービスステーションでセルフ化しているため、給油接客作業は有りませんが、各種サービスの提供・車検・洗車整備等の受付・作業のおこなっていただきます。<br />\r\nさまざまな業務知識を習得していただく必要がありますが、先輩たちによるOJTや研修もしっかりしているので安心して就業できます。<br />\r\n仕事の楽しさから、多くのスキルを身に付け正社員になり、マネージャーになった方もいますよ。</p>\n\t\t\n<!--\t<p><strong></strong></p>\n\t<p></p>\n\t\t<p><strong></strong></p>\n\t<p></p>\n\t-->\n</section>\n\n<!--\n<section class=\"blc-cnts\">\n\t<h2><span></span></h2>\n\t<h3></h3>\n\t<p></p>\n\t\t<div class=\"box-lfig\"><img src=\"\" alt=\"\"></div>\n\t<p></p>\n\t</section>\n-->\n\n<section class=\"blc-cnts box-pres recblock\">\n\t<h2><span>将来入社する貴方へ　～サービスステーション先輩社員からのメッセージ～</span></h2>\n\t\t<div class=\"box-message\">\n\t\t\t\t<figure><img src=\"https://koei-e.jp/wp/wp-content/uploads/2020/04/pic_top_02.png\" alt=\"将来入社する貴方へ　～サービスステーション先輩社員からのメッセージ～\"></figure>\n\t\t\t\t<div class=\"tx\">\n\t\t\t<h3></h3>\n\t\t\t<p>当社社員は、継続年数が長い社員が多く、多くの経験を有した仲間に囲まれているので安心して働ける環境だと思います。<br />\r\nカーライフ・ホームライフを通じて、新たな事業へチャレンジする企業風土もある一方、福利厚生、資格取得制度等、社員の成長を後押しする<br />\r\n歴史に裏打ちされた社員育成へのプロセスも感じる事ができます。<br />\r\n現在、私も大変遣り甲斐を感じて充実した日々の毎日ですが、新入社員の入社となれば100％サポートさせていただきますので安心して下さい。<br />\r\n会社の成長と共に私達個人も成長を感じ取れる会社で、是非一緒に働きましょう！お待ちしています。</p>\n\t\t</div>\n\t</div>\n\t<p></p>\n</section>\n\n<section class=\"blc-cnts recblock\">\n\t\t<h2><span>実際働いている社員へインタビュー</span></h2>\n\t<h3>興栄燃料はこんな会社です！</h3>\n\t\t\t\t<img src=\"https://koei-e.jp/wp/wp-content/uploads/2020/06/cs1.jpg\" alt=\"実際働いている社員へインタビュー\" align=\"left\" class=\"allft\">\n\t\t\t\t<div class=\"tx\">\n\t\t\t<p>前職から自動車業界にいたのですが、思い立って転職を決断し、興栄燃料に入社しました。<br />\r\n<br />\r\n今、私が働いているのは国交省関東運輸局指定の民間車検工場で、施設・設備が充実しており、技術や対応力も前職とは比べものにならい位、良い環境にあると感じています。<br />\r\nまた、先輩達も気さくな人達ばかりで、毎日楽しく働く事ができています。<br />\r\n<br />\r\n①入社時について<br />\r\n<br />\r\nまずはサービスステーションに配属され、多くのお客様が訪れる現場を経験しました。<br />\r\n整備士ともなると、ほとんどが車と向き合う時間が多く、実際にお客様の表情や依頼内容を掘り下げて聞く事ができないものですが、この経験を経て、お客様がどんな思いでお車を預けていただけるのか知る事ができました。<br />\r\n結果、自ずと自覚と責任感が芽生えて、整備士として成長を促す意味でも非常に有意義な時間となりました。<br />\r\nまた、会社の主軸事業を知り、多くのお客様からご愛顧をいただいている事が知れた事にも大きな財産となっています。<br />\r\n <br />\r\n②業務未経験から、安定と厚遇を手に！<br />\r\n <br />\r\n業界経験者として入社しましたが、社内には未経験入社の先輩も多い事に驚きました。<br />\r\n専門学校で整備士資格取得をしたけど車関係の仕事がしていなかった方、整備士として長年ブランク状態にあり未経験と同等だった方など、当初の不安も恵まれた環境の中ですぐに解消されたそうです。<br />\r\n <br />\r\n興栄燃料は、きちんと評価していただける給与体制、充実した福利厚生、2級整備士や検査員資格取得を含む支援制度等、充実した環境が整っており、自分自身の成長が安定と厚遇を手にできる大きなチャンスが用意されていると思います。<br />\r\n新たなキャリアをスタートさせるには非常に恵まれた環境にある会社です。</p>\n\t\t</div>\n\t<!--<figure class=\"box-lfig half\">\n\t\t<img src=\"https://koei-e.jp/wp/wp-content/uploads/2020/06/cs1.jpg\" alt=\"実際働いている社員へインタビュー\">\n\t</figure>\n\t<h3>興栄燃料はこんな会社です！</h3>\n\t<p>前職から自動車業界にいたのですが、思い立って転職を決断し、興栄燃料に入社しました。<br />\r\n<br />\r\n今、私が働いているのは国交省関東運輸局指定の民間車検工場で、施設・設備が充実しており、技術や対応力も前職とは比べものにならい位、良い環境にあると感じています。<br />\r\nまた、先輩達も気さくな人達ばかりで、毎日楽しく働く事ができています。<br />\r\n<br />\r\n①入社時について<br />\r\n<br />\r\nまずはサービスステーションに配属され、多くのお客様が訪れる現場を経験しました。<br />\r\n整備士ともなると、ほとんどが車と向き合う時間が多く、実際にお客様の表情や依頼内容を掘り下げて聞く事ができないものですが、この経験を経て、お客様がどんな思いでお車を預けていただけるのか知る事ができました。<br />\r\n結果、自ずと自覚と責任感が芽生えて、整備士として成長を促す意味でも非常に有意義な時間となりました。<br />\r\nまた、会社の主軸事業を知り、多くのお客様からご愛顧をいただいている事が知れた事にも大きな財産となっています。<br />\r\n <br />\r\n②業務未経験から、安定と厚遇を手に！<br />\r\n <br />\r\n業界経験者として入社しましたが、社内には未経験入社の先輩も多い事に驚きました。<br />\r\n専門学校で整備士資格取得をしたけど車関係の仕事がしていなかった方、整備士として長年ブランク状態にあり未経験と同等だった方など、当初の不安も恵まれた環境の中ですぐに解消されたそうです。<br />\r\n <br />\r\n興栄燃料は、きちんと評価していただける給与体制、充実した福利厚生、2級整備士や検査員資格取得を含む支援制度等、充実した環境が整っており、自分自身の成長が安定と厚遇を手にできる大きなチャンスが用意されていると思います。<br />\r\n新たなキャリアをスタートさせるには非常に恵まれた環境にある会社です。</p>\n\t<h3 class=\"mt\"></h3>\n\t<div class=\"box-message reverse\">\n\t\t\t\t<div class=\"tx\">\n\t\t\t<p></p>\n\t\t</div>\n\t</div>-->\n</section>\n\n<!-- 募集要項変更html版 -->\n<section class=\"blc-cnts recblock\">\n\t<h2><span>募集要項</span></h2>\n\t<!--<h3><span>採用データ</span></h3>-->\n\t<table class=\"rec__shokushu\">\n\t\t<tr>\n\t\t\t<th>職種</th>\n\t\t\t<td>セルフガソリンスタンドでの仕事全般</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<th>仕事内容</th>\n　　　　　　<td>・接客応対<br>・車検・鈑金等のカーケア商品販売及び自動車の軽整備<br>・販売プラン、スタッフ管理<br>・その他、付随する業務<br>※ユニフォーム貸与\n　　　　　　</td>\n\t\t<tr>\n\t\t\t<th>就業場所</th>\n\t\t\t<td>千葉県千葉市（中央区、美浜区）佐倉市（ユーカリが丘、中志津）、習志野市秋津、八千代市村上　のいずれか</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<th>必要な資格</th>\n\t\t\t<td>普通自動車免許（ＡＴ限定可）</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<th>学歴</th>\n\t\t\t<td>高卒以上</td>\n\t\t</tr>\n\t</table>\n\n\n\t<table class=\"rec__shokushu\">\n\t\t<tr>\n\t\t\t<th>職種</th>\n\t\t\t<td>自動車整備士</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<th>仕事内容</th>\n\t\t\t<td>・自動車の車検業務をメインに、一般修理などの業務を担当していただきます。<br>・整備車両の回送業務<br>・その他、付随する関連業務</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<th>就業場所</th>\n\t\t\t<td>千葉県市原市八幡浦１一１３</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<th>必要な資格</th>\n\t\t\t<td>国家自動車３級整備士以上（２級整備士、自動車検査員の資格保有者であれば尚可。<br>普通自動車免許（ＡＴ限定不可）</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<th>学歴</th>\n\t\t\t<td>専門学校卒以上</td>\n\t\t</tr>\n\t</table>\n\n\n\t<table class=\"rec__shokushu\">\n\t\t<tr>\n\t\t\t<th>職種</th>\n\t\t\t<td>ＬＰガスのルート営業</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<th>仕事内容</th>\n\t\t\t<td>・定期的な保安点検、ガスの開閉栓、ガス代金の管理<br>・ガス機器や住宅設備機器の提案など</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<th>就業場所</th>\n\t\t\t<td>千葉県千葉市中央区新宿２－５－１０</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<th>必要な資格</th>\n\t\t\t<td>普通自動車免許（ＡＴ限定可）</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<th>学歴</th>\n\t\t\t<td>専門学校卒以上</td>\n\t\t</tr>\n\t</table>\n\n\n\t<table class=\"rec__shokushu\">\n\t\t<tr>\n\t\t\t<th>職種</th>\n\t\t\t<td>ＬＰガスの配送ドライバー及び充填作業</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<th>仕事内容</th>\n\t\t\t<td>・プロパンガスの容器の配送及び交換<br>・プロパンガス充填作業</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<th>就業場所</th>\n\t\t\t<td>千葉県市原市八幡浦１一１３　</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<th>必要な資格</th>\n\t\t\t<td>準中型自動車免許以上</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<th>学歴</th>\n\t\t\t<td>高卒以上</td>\n\t\t</tr>\n\t</table>\n\t\n\t<h3><span>給与・福利厚生（待遇）</span></h3>\n\t<table class=\"rec__taigu\">\n\t\t<tr>\n\t\t\t<th>給与</th>\n\t\t\t<td>181,800～255,040円</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<th>諸手当</th>\n\t\t\t<td>■通勤手当（上限26,000円）<br>■時間外手当<br>■資格手当（職務に必須の資格のみ）<br>■家族手当</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<th>昇給</th>\n\t\t\t<td>年１回（４月）</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<th>賞与</th>\n\t\t\t<td>年２回（７月・１２月）</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<th>休日休暇</th>\n\t\t\t<td>年１０５日（月７～１０日）<br>■有給休暇<br>■慶弔休暇</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<th>福利厚生</th>\n\t\t\t<td>■社会保険完備（厚生年金・健康保険等）<br>■制服貸与<br>■社員割引（ガソリン・整備代・LPG他）<br>■退職金あり<br>■国家資格取得支援制度あり（全額会社負担）</td>\n\t\t</tr>\n\t\t\t\t<tr>\n\t\t\t<th>試用期間</th>\n\t\t\t<td>3か月間　※試用期間中も採用条件変わらず</td>\n\t\t</tr>\n\t</table>\n</section>\n<!-- /募集要項変更html版 -->\n\n<!-- 募集要項変更時非表示用php版 -->\n<!--<section class=\"blc-cnts recblock\">\n\t<h2><span>募集要項</span></h2>\n\t<table>\n\t\t\t\t<tr>\n\t\t\t<th>業務内容</th>\n\t\t\t<td> 給油監視業務、接客、各種作業、受付、商談、清掃、配達など</td>\n\t\t</tr>\n\t\t\t\t<tr>\n\t\t\t<th>応募資格</th>\n\t\t\t<td>学歴・経験・年齢不問</td>\n\t\t</tr>\n\t\t\t\t<tr>\n\t\t\t<th>雇用形態</th>\n\t\t\t<td>正社員　アルバイト・パート　</td>\n\t\t</tr>\n\t\t\t\t<tr>\n\t\t\t<th>試用期間</th>\n\t\t\t<td>試用期間あり（3か月間）</td>\n\t\t</tr>\n\t\t\t\t<tr>\n\t\t\t<th>勤務地</th>\n\t\t\t<td>当社運営店舗のうち希望勤務地を考慮　＞店舗一覧</td>\n\t\t</tr>\n\t\t\t\t<tr>\n\t\t\t<th>勤務時間</th>\n\t\t\t<td>シフト制　正社員は残業あり（約20時間／月）</td>\n\t\t</tr>\n\t\t\t\t<tr>\n\t\t\t<th>給与</th>\n\t\t\t<td>正社員23万円以上　アルバイト・パート　時給1100円以上</td>\n\t\t</tr>\n\t\t\t\t<tr>\n\t\t\t<th>待遇、福利厚生</th>\n\t\t\t<td>正社員　社会保険完備</td>\n\t\t</tr>\n\t\t\t\t<tr>\n\t\t\t<th>休日および休暇</th>\n\t\t\t<td>正社員　年間休日105日　※月7～9日のシフト制＋有給休暇、慶弔休暇、特別休暇</td>\n\t\t</tr>\n\t\t\t\t<tr>\n\t\t\t<th>資格取得制度</th>\n\t\t\t<td>危険物取扱者、国家資格整備士、損害保険募集人資格、カーコーティング技術資格 他</td>\n\t\t</tr>\n\t\t\t</table>\n</section>-->\n<!-- 募集要項変更時非表示用php版 -->\n\n<section class=\"blc-cnts recblock\">\n\t<h2><span>リクルート エントリーフォーム</span></h2>\n\t<p>下記エントリーフォームに必要事項をご記入の上、送信をお願いします。</p>\n\t<div class=\"box-form\">\n\t\t<div id=\"mw_wp_form_mw-wp-form-220\" class=\"mw_wp_form mw_wp_form_input  \">\n\t\t\t\t\t<form method=\"post\" action=\"\" enctype=\"multipart/form-data\"><dl>\n<dt>お名前＊</dt>\n<dd>\n<input type=\"text\" name=\"お名前\" class=\"required\" size=\"60\" value=\"\" placeholder=\"お名前をご入力ください。\" />\n</dd>\n<dt>お名前フリガナ＊</dt>\n<dd>\n<input type=\"text\" name=\"お名前フリガナ\" class=\"required\" size=\"60\" value=\"\" placeholder=\"お名前のフリガナをご入力ください。\" />\n</dd>\n<dt>お電話番号＊</dt>\n<dd>\n<input type=\"text\" name=\"お電話番号\" class=\"email required\" size=\"60\" value=\"\" placeholder=\"お電話番号をご入力ください。\" />\n</dd>\n<dt>メールアドレス＊</dt>\n<dd>\n<input type=\"text\" name=\"メールアドレス\" class=\"email required\" size=\"60\" value=\"\" placeholder=\"メールアドレスをご入力ください。\" />\n</dd>\n<dt>件名＊</dt>\n<dd>\n<input type=\"text\" name=\"件名\" size=\"60\" value=\"\" placeholder=\"件名をご入力ください。\" />\n</dd>\n<dt>お問い合わせ内容＊</dt>\n<dd>\n<textarea name=\"お問い合わせ内容\" cols=\"50\" rows=\"5\" ></textarea>\n</dd>\n</dl>\n<p class=\"tx-pre\"><a href=\"/privacy/\" target=\"_blank\" rel=\"noopener noreferrer\">プライバシーポリシー</a>をお読みいただき同意をいただいた場合は「個人情報の取り扱いについて、同意する」にチェックの上、<br />\n下記【送信する】ボタンを押してください。</p>\n<p class=\"tx-pre\">\t<span class=\"mwform-radio-field horizontal-item\">\n\t\t<label >\n\t\t\t<input type=\"radio\" name=\"個人情報の取り扱いについて、同意する\" value=\"個人情報の取り扱いについて、同意する\" />\n\t\t\t<span class=\"mwform-radio-field-text\">個人情報の取り扱いについて、同意する</span>\n\t\t</label>\n\t</span>\n\n<input type=\"hidden\" name=\"__children[個人情報の取り扱いについて、同意する][]\" value=\"{&quot;\