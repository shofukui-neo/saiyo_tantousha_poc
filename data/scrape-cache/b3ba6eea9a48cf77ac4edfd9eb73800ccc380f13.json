{"url":"https://www.inahara.co.jp/recruit/entry/","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n\n<head>\n\n<!-- Google tag (gtag.js) -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-1HPD70193M\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'G-1HPD70193M');\n</script>\n\n  <meta http-equiv=\"X-UA-Compatible\" content=\"IE=Edge\">\n  <meta charset=\"utf-8\">\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n  <meta name=\"format-detection\" content=\"telephone=no\">\n  <!-- SEO対策 -->\n  <meta name=\"description\" content=\"お客様にとって最適な職場環境を創造するため、コピー機や複合機などのオフィス機器のご提案からビジネスインフラ、オフィス空間デザイン、保守・管理サポートまで、ビジネスシーンのあらゆる問題解決にご一緒に取り組みます。\">\n  <title>株式会社イナハラ｜地域密着の強みを活かし、働きやすいオフィス空間を創造するソリューションをご提供します。</title>\n  <!-- FontAwesome -->\n  <link href=\"https://use.fontawesome.com/releases/v5.6.1/css/all.css\" rel=\"stylesheet\">\n  <!-- スタイルシート -->\n  <link rel=\"stylesheet\" href=\"assets/css/swiper.css\">\n  <link rel=\"stylesheet\" href=\"assets/css/style.css\" media=\"all\">\n</head>\n\n<body>\n  <div id=\"wrapper\">\n    <header role=\"banner\" class=\"l-flex-wrap l-flex-jc-sb l-flex-ai-center p30\">\n      <h1 class=\"header-logo\">\n        <a href=\"index.html\">\n          <img src=\"assets/img/common/logo.svg\" alt=\"株式会社イナハラ\">\n        </a>\n      </h1>\n      <div class=\"nav-btn\">\n        <span></span>\n        <span></span>\n        <span></span>\n      </div>\n      <nav role=\"navigation\">\n        <!-- 中身はtemplate.js -->\n      </nav>\n    </header>\n\n\n    <main role=\"main\">\n      <div class=\"index-mainvisual\">\n        <div class=\"swiper-container swiper-index\">\n          <div class=\"swiper-wrapper\">\n            <div class=\"swiper-slide slide03\"></div>\n            <div class=\"swiper-slide slide01\"></div>\n            <div class=\"swiper-slide slide02\"></div>\n          </div>\n          <!-- Add Pagination -->\n          <div class=\"swiper-pagination\"></div>\n        </div>\n        <!-- swiper-container -->\n          <h2 class=\"slide-title\">\n            私たちは、働きやすい\n            <br>\n            オフィス空間を創造します\n            <span>\n              <img src=\"assets/img/index/top-catch.png\" alt=\"future creation of office\">\n            </span>\n          </h2>\n        <!-- /.slide-title -->\n      </div>\n      <!-- /.mainvisual -->\n\n      <!-- ↓↓イベントのバナーはここに貼る↓↓ -->\n\n     <!--<section class=\"l-container-lg l-section-lg pb0\">\n        <div class=\"box-fm\">\n          <a class=\"none\" href=\"https://www.inahara.co.jp/cgi-bin/news/index.cgi?mode=detail&file=info&select=1749780028\" target=\"_blank\">\n            <img class=\"pc-only\" src=\"assets/img/index/20250715.png\" alt=\"セキュリティセミナー\">\n            <img class=\"sp-only\" src=\"assets/img/index/20250715-sp.png\" alt=\"セキュリティセミナー\">\n          </a>\n        </div>\n      </section>-->\n\n      <!-- ↑↑イベントのバナーはここに貼る↑↑ -->\n\n      <section class=\"l-section-mid\">\n        <div class=\"l-container-lg\">\n          <h3 class=\"title-index mb20\">\n            SOLUTION\n            <span>\n              お客様の課題を解決するための、<br class=\"sp-only\">6つの事業ソリューション。\n            </span>\n          </h3>\n          <p class=\"mb50\">\n            オフィス全体のノウハウを網羅するソリューションであり、ビジネスの環境変化から\n            <br>\n            生じるさまざまな課題を解決。お客様にとって最適な運用をご提案します。\n          </p>\n          <ul class=\"l-flex-wrap l-flex-jc-center list-sol mb40\">\n            <li class=\"l-flex-col-3 mb0\">\n              <a href=\"/solution.html#sol01\">\n                <img src=\"assets/img/solution/sol01.png\" alt=\"ドキュメントソリューション\">\n                <h4>\n                  ドキュメントソリューション\n                </h4>\n                <p class=\"fz14\">\n                  <!-- 情報共有・出力抑止／出力効率化／環境対策・省電力推進 -->\n                  複合機・プリンタ・スキャナなどを活用した<br>\n                  書類の発生・活用・保管における<br>\n                  運用改善と事務効率化\n                </p>\n              </a>\n            </li>\n\n            <li class=\"l-flex-col-3 mb0\">\n              <a href=\"/solution.html#sol02\">\n                <img src=\"assets/img/solution/sol02.png\" alt=\"システムソリューション\">\n                <h4>\n                  システムソリューション\n                </h4>\n                <p class=\"fz14\">\n                  <!-- 基幹業務／顧客接点強化／情報共有・業務効率化／管理負担軽減／教育・研修 -->\n                  サーバー・PC・周辺機器の提供<br>\n                  基幹業務ソフトとクラウドの提供<br>\n                  セキュリティ対策とデータバックアップ\n                </p>\n              </a>\n            </li>\n\n            <li class=\"l-flex-col-3 mb0\">\n              <a href=\"/solution.html#sol03\">\n                <img src=\"assets/img/solution/sol03.png\" alt=\"オフィスデザイン\">\n                <h4>\n                  オフィスデザイン\n                </h4>\n                <p class=\"fz14\">\n                  <!-- 生産性向上型オフィス／顧客接点強化型オフィス -->\n                  オフィスの移転・リニューアルを<br>\n                  プランニング<br>\n                  オフィス家具のCAD配置図面作成<br>\n                  職場・会議室・応接室・工場などをデザイン\n                </p>\n              </a>\n            </li>\n\n            <li class=\"l-flex-col-3 mb0\">\n              <a href=\"/solution.html#sol04\">\n                <img src=\"assets/img/solution/sol04.png\" alt=\"通信・コミュニケーション\">\n                <h4>\n                  通信・コミュニケーション\n                </h4>\n                <p class=\"fz14\">\n                  <!-- コミュニケーション強化／コスト削減 -->\n                  ビジネスフォン・法人向けスマートフォンの提供<br>\n                  TV会議・Web会議システムの構築<br>\n                  プロジェクタの提供・各種配線工事\n                </p>\n              </a>\n            </li>\n\n            <li class=\"l-flex-col-3 mb0\">\n              <a href=\"/solution.html#sol05\">\n                <img src=\"assets/img/solution/sol05.png\" alt=\"オフィスサプライ\">\n                <h4>\n                  オフィスサプライ\n                </h4>\n                <p class=\"fz14\">\n                  トナーカートリッジ・インク・用紙など<br>\n                  オフィスにまつわる事務用品を一元的に提供<br>\n                  アスクル正規取扱店\n                </p>\n              </a>\n            </li>\n\n            <li class=\"l-flex-col-3 mb0\">\n              <a href=\"/solution.html#sol06\">\n                <img src=\"assets/img/solution/sol06.png\" alt=\"サービス＆サポート\">\n                <h4>\n                  サービス＆サポート\n                </h4>\n                <p class=\"fz14\">\n                  <!-- 定期点検・修理・年間保守 -->\n                  メーカー認定資格保有のサービスマンによる<br>\n                  設置・設定と修理・点検・保守\n                </p>\n              </a>\n            </li>\n\n          </ul>\n          <p class=\"btn-red01\">\n            <a href=\"/solution.html\">\n              詳しく見る\n            </a>\n          </p>\n        </div>\n      </section>\n\n      <section class=\"l-container-lg l-section-mid\">\n        <h3 class=\"title-index mb20\">\n          STRENGTHS\n          <span>\n            お客様にとことん寄り添うイナハラ。<br class=\"sp-only\">お役立ちの力がここに。\n          </span>\n        </h3>\n        <p class=\"mb50\">\n          1927年の創業から今日まで、イナハラの変わらない使命はお客様のお役に立つこと。\n          <br>\n          現在のお困り事の解決から、未来の可能性を踏まえたソリューションのご提供まで、\n          <br>\n          これまでの実績やノウハウから生み出したイナハラならではの力で、\n          <br>\n          お客様のその先のお客様までを見据えながら、最適なオフィス環境をご提案しています。\n        </p>\n        <!-- PC版 -->\n        <div class=\"animation mb60 pc-only print-on\">\n          <ul class=\"hexa-box01 animation\">\n            <li class=\"l-flex-wrap l-flex-jc-center\">\n              <a href=\"/strengths.html#str01\" class=\"hexa hexa01 l-flex-col-2\">\n                <img src=\"assets/img/index/str01.png\" alt=\"拠点も心もお客様との距離の近さ\">\n                <img class=\"txt-hexa01\" src=\"assets/img/index/str01txt.png\" alt=\"拠点も心もお客様との距離の近さ\">\n              </a>\n              <a href=\"/strengths.html#str03\" class=\"hexa l-flex-col-2\">\n                <img src=\"assets/img/index/str02.png\" alt=\"徹底したコンサルティング\">\n                <img class=\"txt-hexa02\" src=\"assets/img/index/str02txt.png\" alt=\"徹底したコンサルティング\">\n              </a>\n            </li>\n          </ul>\n          <ul class=\"hexa-box02\">\n            <li class=\"l-flex-wrap\">\n              <a href=\"/strengths.html#str02\" class=\"hexa hexa01 l-flex-col-2\">\n                <img src=\"assets/img/index/str03.png\" alt=\"ワンストップの総合力\">\n                <img class=\"txt-hexa03\" src=\"assets/img/index/str03txt.png\" alt=\"ワンストップの総合力\">\n              </a>\n              <a href=\"/strengths.html#str04\" class=\"hexa l-flex-col-2\">\n                <img src=\"assets/img/index/str04.png\" alt=\"メーカー100社以上の正規一次販売店\">\n                <img class=\"txt-hexa01 txt-hexa04\" src=\"assets/img/index/str04txt.png\" alt=\"メーカー100社以上の正規一次販売店\">\n              </a>\n            </li>\n          </ul>\n        </div>\n        <!-- /.animation -->\n        <!-- PC版 -->\n\n        <!-- スマホ版 -->\n        <div class=\"mb60 sp-only print-none\">\n          <ul class=\"hexa-box01 animation\">\n            <li class=\"l-flex-wrap l-flex-jc-sa mb40\">\n              <a href=\"/strengths.html#str01\" class=\"hexa hexa01 l-flex-col-2\">\n                <img src=\"assets/img/index/str01.png\" alt=\"お客様に寄り添う地域密着企業\">\n                <img class=\"txt-hexa01\" src=\"assets/img/index/str01txt.png\" alt=\"お客様に寄り添う地域密着企業\">\n              </a>\n              <a href=\"/strengths.html#str03\" class=\"hexa hexa01 l-flex-col-2\">\n                <img src=\"assets/img/index/str02.png\" alt=\"課題解決へ徹底したヒアリング\">\n                <img class=\"txt-hexa02\" src=\"assets/img/index/str03txt_sp.png\" alt=\"課題解決へ徹底したヒアリング\">\n              </a>\n            </li>\n          </ul>\n          <ul class=\"hexa-box02\">\n            <li class=\"l-flex-wrap l-flex-jc-sa\">\n              <a href=\"/strengths.html#str02\" class=\"hexa l-flex-col-2\">\n                <img src=\"assets/img/index/str03.png\" alt=\"導入後も継続する万全の運用支援\">\n                <img class=\"txt-hexa03\" src=\"assets/img/index/str02txt_sp.png\" alt=\"導入後も継続する万全の運用支援\">\n              </a>\n              <a href=\"/strengths.html#str04\" class=\"hexa l-flex-col-2\">\n                <img src=\"assets/img/index/str04.png\" alt=\"仕入先100社以上の正規一時販売店\">\n                <img class=\"txt-hexa01 txt-hexa04\" src=\"assets/img/index/str04txt_sp.png\" alt=\"仕入先100社以上の正規一時販売店\">\n              </a>\n            </li>\n          </ul>\n        </div>\n        <!-- /.animation -->\n        <!-- スマホ版 -->\n\n        <p class=\"btn-red01\">\n          <a href=\"/strengths.html\">\n            詳しく見る\n          </a>\n        </p>\n      </section>\n\n      <!-- <section class=\"l-container-lg l-section-mid\">\n        <h3 class=\"title-index mb40 title-index-border\">\n          CASE STUDY\n          <span>\n            事例紹介\n          </span>\n        </h3>\n        <div class=\"slide_box\">\n          <div id=\"slide_area\">\n            <div id=\"slider_parent\">\n              <div class=\"slider_child sc0\" id=\"sd0\"></div>\n              <div class=\"slider_child sc1\" id=\"sd1\"></div>\n              <div class=\"slider_child sc2\" id=\"sd2\"></div>\n              <div class=\"slider_child sc3\" id=\"sd3\"></div>\n            </div>\n            <div id=\"kaisetsu\">\n              <a id=\"readme\" href=\"\" target=\"_blank\">Read More</a>\n            </div>\n          </div>\n          <div id=\"changebox\">\n            <a id=\"before_btn\">＜</a>\n            <a id=\"next_btn\">＞</a>\n          </div>\n        </div>\n      </section> -->\n\n      <section class=\"l-container-lg l-section-min\">\n        <div class=\"index-news\">\n          <div class=\"l-wrap-30p\">\n            <h3 class=\"title-index mb20\">\n              NEWS\n              <span>\n                お知らせ\n              </span>\n            </h3>\n            <p class=\"btn-red03 pc-only\">\n              <a href=\"cgi-bin/news/index.cgi?mode=list&file=info&genre=1\">\n                詳しく見る\n              </a>\n            </p>\n          </div>\n          <dl class=\"l-wrap