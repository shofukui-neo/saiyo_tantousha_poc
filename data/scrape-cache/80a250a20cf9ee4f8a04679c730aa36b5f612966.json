{"url":"https://www.chugai-af.co.jp/about/","html":"<!DOCTYPE html>\n<html lang=\"ja\" prefix=\"og: http://ogp.me/ns#\">\n<head>\n<!-- Google Tag Manager -->\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start': new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n})(window,document,'script','dataLayer','GTM-WK85SH6');</script>\n<!-- End Google Tag Manager -->\n<!-- Yahoo Tag -->\n<script async src=\"https://s.yimg.jp/images/listing/tool/cv/ytag.js\"></script>\n<script>\nwindow.yjDataLayer = window.yjDataLayer || [];\nfunction ytag() { yjDataLayer.push(arguments); }\nytag({\"type\":\"ycl_cookie\"});\nytag({\"type\":\"ycl_cookie_extended\"});\n</script>\n<!-- End Yahoo Tag -->\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1, shrink-to-fit=no\">\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n<meta name=\"format-detection\" content=\"telephone=no\">\n<meta name=\"skype_toolbar\" content=\"skype_toolbar_parser_compatible\">\n<title>社長メッセージ | 会社概要 | 中外商工株式会社</title>\n<meta name=\"description\" content=\"メーカー責任施工により、大規模修繕などの現場に新しい価値をご提案する中外商工株式会社の企業理念、事業ルーツ、会社概要をご紹介します。\">\n<meta name=\"keywords\" content=\"中外商工,マンション大規模修繕,大規模改修,修繕,資産価値,メーカー責任施工,事業ルーツ,研究開発,施工技術,事業エリア,取扱製品,塗り床,会社概要,社長メッセージ\">\n<link rel=\"shortcut icon\" type=\"image/x-icon\" href=\"/img/common/favicon.ico\">\n<link rel=\"apple-touch-icon-precomposed\" sizes=\"192x192\" href=\"/img/common/touch-icon.png\">\n<!-- search setting START -->\n<meta name=\"robots\" content=\"index,follow\"><!-- すべての検索エンジン用 -->\n<meta name=\"googlebot\" content=\"index,follow\"><!-- Google用 -->\n<!-- search setting END -->\n<!-- style START -->\n<link rel=\"stylesheet\" href=\"/css/common/base.css\">\n<link rel=\"stylesheet\" href=\"/css/about/style.css\">\n<link href=\"https://fonts.googleapis.com/earlyaccess/notosansjapanese.css\" rel=\"stylesheet\">\n<!-- style END -->\n</head>\n<body id=\"anc_pagetop\">\n  <!-- Google Tag Manager (noscript) -->\n  <noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-WK85SH6\" height=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n  <!-- End Google Tag Manager (noscript) -->\n  <!-- wrapper START -->\n  <div class=\"wrapper\">\n    <header class=\"header\" role=\"banner\">\n  <div class=\"header__in\">\n    <h1 class=\"header-logo\"><a href=\"/\" class=\"inner\"><img src=\"/img/common/logo2.svg\" alt=\"中外商工株式会社\"></a></h1>\n    <div class=\"header-contact\">\n      <div class=\"header-contact__in\">\n        <div class=\"header-contact__item\">\n          <div class=\"header-contact-tel\">\n            <a href=\"tel:0120957096\" class=\"header-contact-tel__in\"　onclick=\"ga('send','event','button','click','tel_header');\">\n              <p class=\"header-contact-tel__title\">お電話で<br class=\"spbr\">お問い合わせ<span class=\"pctext\">・見積相談</span></p>\n              <p class=\"header-contact-tel__number\"><img src=\"/img/common/img_tel_number_01.svg\" alt=\"0120-957-096\"></p>\n            </a>\n            <p class=\"header-contact-tel__description\">受付時間／月曜日から金曜日の 8：30〜17：30（休日を除く）</p>\n          </div>\n        </div>\n        <div class=\"header-contact__item\">\n          <a href=\"/contact/\" target=\"_blank\" class=\"header-contact-mail\"　onclick=\"ga('send','event','link','click','contact_fixed');\">\n            <div class=\"header-contact-mail__in\">\n              <p class=\"header-contact-mail__title\">メールで<br>お問い合わせ<span class=\"pctext\">・<br>見積相談</span></p>\n            </div>\n          </a>\n        </div>\n        <button id=\"js-menuTrigger\" class=\"header-menu-button\" type=\"button\" aria-label=\"メニューボタン\">\n          <span class=\"header-menu-button__bar\" aria-hidden=\"true\"></span>\n          <span class=\"header-menu-button__text\">MENU</s