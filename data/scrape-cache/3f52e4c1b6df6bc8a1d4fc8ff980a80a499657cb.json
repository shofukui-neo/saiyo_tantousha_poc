:new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src='//www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);})(window,document,'script','dataLayer','GTM-NTTVHP');</script><!-- End Google Tag Manager -->\n<header class=\"rs-header rs-drawer-target\">\n  <div class=\"rs-header__container\">\n    <div class=\"rs-header__heading rs-header__column rs-header__column--01\"><a class=\"rs-header-logo\" href=\"/recruit/inhouse/\"><img class=\"rs-header-logo__img\" src=\"/recruit/img_f/logo.svg\" alt=\"randstad\"></a>\n      <p class=\"rs-header-title\">インハウス事業<br>採用特設サイト</p>\n    </div>\n    <div class=\"rs-header__column rs-header__column--02\">\n      <nav class=\"rs-nav\">\n        <ul class=\"rs-nav__list\">\n          <li class=\"rs-nav__item\"><a class=\"rs-nav__link rs-nav-link\" href=\"/recruit/inhouse/about/\">インハウス事業について</a></li>\n          <li class=\"rs-nav__item\"><a class=\"rs-nav__link rs-nav-link\" href=\"/recruit/inhouse/personality/\">求める人材・面接</a></li>\n          <li class=\"rs-nav__item\"><a class=\"rs-nav__link rs-nav-link\" href=\"/recruit/inhouse/jobs/\">職種紹介</a></li>\n          <li class=\"rs-nav__item\"><a class=\"rs-nav__link rs-nav-link\" href=\"/recruit/about/\" target=\"_blank\">会社を知る<i class=\"rs-icon rs-icon--external rs-nav-link__icon\"></i></a></li>\n          <li class=\"rs-nav__item\"><a class=\"rs-nav__link rs-nav-link\" href=\"/recruit/talent/\" target=\"_blank\">仲間を知る<i class=\"rs-icon rs-icon--external rs-nav-link__icon\"></i></a></li>\n          <li class=\"rs-nav__item\"><a class=\"rs-nav__link rs-nav-link\" href=\"/recruit/workstyle/\" target=\"_blank\">働き方の制度<i class=\"rs-icon rs-icon--external rs-nav-link__icon\"></i></a></li>\n          <li class=\"rs-nav__item\"><a class=\"rs-nav__link rs-nav-link\" href=\"/recruit/benefit/\" target=\"_blank\">評価・研修制度／ 福利厚生<i class=\"rs-icon rs-icon--external rs-nav-link__icon\"></i></a></li>\n        </ul>\n      </nav><a class=\"rs-header-entry-button rs-header-entry-button--inhouse rs-none rs-md:block\" href=\"https://randstad-jp.my.site.com/randstadtenshoku/s/job-list?c__filter=In-house%20%2F%20Outsourcing&language=ja#\" target=\"_blank\">エントリー</a>\n    </div>\n  </div>\n  <div class=\"rs-header__button-wrap\"><a class=\"rs-header-entry-link rs-header-entry-link--inhouse\" href=\"https://randstad-jp.my.site.com/randstadtenshoku/s/job-list?c__filter=In-house%20%2F%20Outsourcing&language=ja#\" target=\"_blank\"><i class=\"rs-icon rs-icon--login rs-header-entry-link__icon\"></i><span>エントリー</span></a>\n    <button class=\"rs-header-menu-button rs-drawer-toggle\" type=\"button\"><i class=\"rs-icon rs-icon--menu rs-header-menu-button__icon\"></i><span>メニュー</span></button>\n  </div>\n</header>\n<nav class=\"rs-drawer-menu\">\n  <ul class=\"rs-drawer-menu__list\">\n    <li class=\"rs-drawer-menu__item\"><a class=\"rs-drawer-menu__link\" href=\"/recruit/inhouse/\">HOME</a></li>\n    <li class=\"rs-drawer-menu__item\"><a class=\"rs-drawer-menu__link rs-drawer-menu-link\" href=\"/recruit/inhouse/about/\">インハウス事業について</a></li>\n    <li class=\"rs-drawer-menu__item\"><a class=\"rs-drawer-menu__link rs-drawer-menu-link\" href=\"/recruit/inhouse/personality/\">求める人材・面接</a></li>\n    <li class=\"rs-drawer-menu__item\"><a class=\"rs-drawer-menu__link rs-drawer-menu-link\" href=\"/recruit/inhouse/jobs/\">職種紹介</a></li>\n    <li class=\"rs-drawer-menu__item\"><a class=\"rs-drawer-menu__link rs-drawer-menu-link\" href=\"/recruit/about/\" target=\"_blank\">会社を知る<i class=\"rs-icon rs-icon--external rs-drawer-menu-link__icon\"></i></a></li>\n    <li class=\"rs-drawer-menu__item\"><a class=\"rs-drawer-menu__link rs-drawer-menu-link\" href=\"/recruit/talent/\" target=\"_blank\">仲間を知る<i class=\"rs-icon rs-icon--external rs-drawer-menu-link__icon\"></i></a></li>\n    <li class=\"rs-drawer-menu__item\"><a class=\"rs-drawer-menu__link rs-drawer-menu-link\" href=\"/recruit/workstyle/\" target=\"_blank\">働き方の制度<i class=\"rs-icon rs-icon--external rs-drawer-menu-link__icon\"></i></a></li>\n    <li class=\"rs-drawer-menu__item\"><a class=\"rs-drawer-menu__link rs-drawer-menu-link\" href=\"/recruit/benefit/\" target=\"_blank\">評価・研修制度／ 福利厚生<i class=\"rs-icon rs-icon--external rs-drawer-menu-link__icon\"></i></a></li>\n  </ul><a class=\"rs-header-entry-button\" href=\"https://randstad-jp.my.site.com/randstadtenshoku/s/job-list?c__filter=In-house%20%2F%20Outsourcing&language=ja#\" target=\"_blank\">エントリー</a>\n</nav>\n    <main class=\"rs-drawer-target\">\n      <div class=\"rs-main-title-layout rs-main-title-layout--top rs-main-title-layout--inhouse\">\n        <div class=\"rs-base-layout\">\n          <h1 class=\"rs-heading rs-heading--level-1 rs-text-color-white\">everything for one client<br>全てを1社のお客様のために</h1>\n          <p class=\"rs-main-title-layout__lead rs-text-color-white\">私たちは、1社のお客様のためだけのテーラーメイドサービスを提供し、<br class=\"rs-none rs-md:block\">クライアントと派遣スタッフの満足を追求し続けます。</p>\n          <div class=\"rs-main-title-layout__button\"><a class=\"rs-button rs-button--light-green rs-button--round\" href=\"https://randstad-jp.my.site.com/randstadtenshoku/s/job-list?c__filter=In-house%20%2F%20Outsourcing&language=ja#\" target=\"_blank\">エントリーはこちらから</a></div>\n        </div>\n      </div>\n      <section class=\"rs-section-layout rs-strip rs-strip--beige\">\n        <div class=\"rs-base-layout\">\n          <p class=\"rs-heading rs-heading--level-4 rs-mb-0\">インハウス事業本部では、人材派遣事業を中心に、1社専属のチームを編成し、派遣スタッフの「採用から定着まで」一気通貫でサービスを提供します。</p>\n        </div>\n        <div class=\"rs-mt-30-50\">\n<div class=\"rs-strip rs-strip--beige\">\n  <div class=\"rs-base-layout\">\n    <div class=\"rs-icon-column-layout rs-md:icon-column-layout-width-1-3\">\n      <div><a class=\"rs-icon-column\" href=\"/recruit/inhouse/about/\"><span class=\"rs-icon-column__title\">インハウス事業について</span>\n          <div class=\"rs-icon-column__icon\"><img src=\"/recruit/img_f/icon-about.svg\" alt=\"\"></div></a></div>\n      <div><a class=\"rs-icon-column\" href=\"/recruit/inhouse/personality/\"><span class=\"rs-icon-column__title\">求める人材</span>\n          <div class=\"rs-icon-column__icon\"><img src=\"/recruit/img_f/icon-personality.svg\" alt=\"\"></div></a></div>\n      <div><a class=\"rs-icon-column\" href=\"/recruit/inhouse/jobs/\"><span class=\"rs-icon-column__title\">職種紹介</span>\n          <div class=\"rs-icon-column__icon\"><img src=\"/recruit/img_f/icon-jobs.svg\" alt=\"\"></div></a></div>\n    </div>\n  </div>\n</div>\n        </div>\n      </section>\n      <section class=\"rs-section-layout\">\n        <div class=\"rs-base-layout\">\n          <h2 class=\"rs-heading rs-heading--level-2\">ランスタッドで働く社員のライフストーリーをご紹介。</h2>\n<div class=\"rs-overflow-hidden\">\n  <div class=\"swiper rs-slider\">\n    <div class=\"swiper-wrapper\">\n      <div class=\"swiper-slide rs-slide\"><a class=\"rs-card\" href=\"/recruit/talent/interview/KatsuhiroKoyama/\">\n          <div class=\"rs-card__img\"><img class=\"rs-radius\" src=\"/recruit/talent/682daa70a29499641e89de3605018e5f.png\" alt=\"\"></div>\n          <div class=\"rs-card__title\">事務系と製造系の壁を越えて。自分たちで「最適な働き方」を創り上げる、オンサイト管理者の醍醐味</div>\n          <div class=\"rs-card__labels\">\n            <div class=\"rs-label-layout\"><span class=\"rs-label rs-label--muted\">オンサイト(顧客常駐)社員</span><span class=\"rs-label rs-label--muted\">働くママ</span><span class=\"rs-label rs-label--muted\">自分らしさ</span><span class=\"rs-label rs-label--muted\">関東</span></div>\n          </div></a></div>\n      <div class=\"swiper-slide rs-slide\"><a class=\"rs-card\" href=\"/recruit/talent/interview/YukoSaito/\">\n          <div class=\"rs-card__img\"><img class=\"rs-radius\" src=\"/recruit/talent/unnamed_8.png\" alt=\"\"></div>\n          <div class=\"rs-card__title\">「育休3回」それでも歩みを止めなかった。支えられた経験が誰かを支える力になる</div>\n          <div class=\"rs-card__labels\">\n            <div class=\"rs-label-layout\"><span class=\"rs-label rs-label--muted\">タレントセンター</span><span class=\"rs-label rs-label--muted\">働くママ</span><span class=\"rs-label rs-label--muted\">女性のキャリア</span><span class=\"rs-label rs-label--muted\">完全在宅</span><span class=\"rs-label rs-label--muted\">自分らしさ</span></div>\n          </div></a></div>\n      <div class=\"swiper-slide rs-slide\"><a class=\"rs-card\" href=\"/recruit/talent/interview/YunaSuda/\">\n          <div class=\"rs-card__img\"><img class=\"rs-radius\" src=\"/recruit/talent/d9ef0d5cfbb88526359b74d91119bca4.png\" alt=\"\"></div>\n          <div class=\"rs-card__title\">「人を一番大切にする会社で働きたい」対話から人の可能性を引き出すコーディネーターの挑戦</div>\n          <div class=\"rs-card__labels\">\n            <div class=\"rs-label-layout\"><span class=\"rs-label rs-label--muted\">タレントセンター</span><span class=\"rs-label rs-label--muted\">女性のキャリア</span><span class=\"rs-label rs-label--muted\">完全在宅</span><span class=\"rs-label rs-label--muted\">未経験からの転職</span><span class=\"rs-label rs-label--muted\">自分らしさ</span></div>\n          </div></a></div>\n      <div class=\"swiper-slide rs-slide\"><a class=\"rs-card\" href=\"/recruit/talent/interview/MihoSugahara/\">\n          <div class=\"rs-card__img\"><img class=\"rs-radius\" src=\"/recruit/talent/1.png\" alt=\"\"></div>\n          <div class=\"rs-card__title\">たった30文字で、誰かの人生が動き出す。言葉とデータで出会いを生み出す「派遣の入口」担当者の挑戦</div>\n          <div class=\"rs-card__labels\">\n            <div class=\"rs-label-layout\"><span class=\"rs-label rs-label--muted\">タレントセンター</span><span class=\"rs-label rs-label--muted\">リファーラル</span><span class=\"rs-label rs-label--muted\">自分らしさ</span><span class=\"rs-label rs-label--muted\">関東</span></div>\n          </div></a></div>\n      <div class=\"swiper-slide rs-slide\"><a class=\"rs-card\" href=\"/recruit/talent/conversation/ChengScarlett/\">\n          <div class=\"rs-card__img\"><img class=\"rs-radius\" src=\"/recruit/talent/cffed515245d4ceff8c9f8941f8172cd.png\" alt=\"\"></div>\n          <div class=\"rs-card__title\">「現場を知るからこそできる支援がある」製造業出身の二人が挑む、製造業領域人材紹介のキャリア支援</div>\n          <div class=\"rs-card__labels\">\n            <div class=\"rs-label-layout\"><span class=\"rs-label rs-label--muted\">人材紹介（プロフェッショナル）</span><span class=\"rs-label rs-label--muted\">未経験からの転職</span><span class=\"rs-label rs-label--muted\">自分らしさ</span><span class=\"rs-label rs-label--muted\">関東</span></div>\n          </div></a></div>\n      <div class=\"swiper-slide rs-slide\"><a class=\"rs-card\" href=\"/recruit/talent/interview/CareerOwnership/\">\n          <div class=\"rs-card__img\"><img class=\"rs-radius\" src=\"/recruit/talent/2adc8267199315a47f2b21ecc647b4a7.png\" alt=\"\"></div>\n          <div class=\"rs-card__title\">なぜ、今の会社では『5年後の自分』が描けないのか？ 「会社都合の異動」をなくし、キャリアの決定権を個人の手に。これからのタレント戦略</div>\n          <div class=\"rs-card__labels\">\n            <div class=\"rs-label-layout\"><span class=\"rs-label rs-label--muted\">制度</span></div>\n          </div></a></div>\n    </div>\n    <div class=\"swiper-pagination rs-slider-pagination rs-slider-pagination--transparent\"></div>\n  </div>\n</div>\n<div class=\"rs-flex rs-flex--center rs-mt-30-50\"><a href=\"/recruit/talent/\" target=\"_blank\"><img src=\"/recruit/img_f/banner-story.png\" alt=\"ランスタッドで働く社員の声や、インタビューを見る\" width=\"600\" height=\"100\"></a></div>\n        </div>\n      </section>\n    </main>\n<div class=\"rs-section-layout rs-strip rs-strip--beige rs-drawer-target\">\n  <div class=\"rs-base-layout rs-sns-wrap\">\n    <dl class=\"rs-sns-lists-layout\">\n      <dt class=\"rs-heading rs-heading--level-4 rs-intersection-target\">SNS公式アカウント</dt>\n      <dd class=\"rs-sns-lists\"><a class=\"rs-sns-lists__item\" href=\"https://www.facebook.com/RandstadJapan\" target=\"_blank\"><svg class=\"rs-filter rs-filter--primary rs-text-bottom\" width=\"40\" height=\"40\">\n            <use xlink:href=\"/dist/assets/image/icons.svg#facebook-filled-30\"></use>\n          </svg></a><a class=\"rs-sns-lists__item\" href=\"https://twitter.com/randstadjapan\" target=\"_blank\"><svg class=\"rs-filter rs-filter--primary rs-text-bottom\" width=\"40\" height=\"40\">\n            <use xlink:href=\"/dist/assets/image/icons.svg#twitter-filled-30\"></use>\n          </svg></a><a class=\"rs-sns-lists__item\" href=\"http://www.linkedin.com/company/randstad-japan\" target=\"_blank\"><svg class=\"rs-filter rs-filter--primary rs-text-bottom\" width=\"40\" height=\"40\">\n            <use xlink:href=\"/dist/assets/image/icons.svg#linkedin-filled-30\"></use>\n          </svg></a><a class=\"rs-sns-lists__item\" href=\"https://www.youtube.com/user/RandstadJapan\" target=\"_blank\"><svg class=\"rs-filter rs-filter--primary rs-text-bottom\" width=\"40\" height=\"40\">\n            <use xlink:href=\"/dist/assets/image/icons.svg#youtube-filled-30\"></use>\n          </svg></a><a class=\"rs-sns-lists__item\" href=\"https://www.instagram.com/randstad_japan/\" target=\"_blank\"><svg class=\"rs-filter rs-filter--primary rs-text-bottom\" width=\"40\" height=\"40\">\n            <use xlink:href=\"/dist/assets/image/icons.svg#instagram-filled-30\"></use>\n          </svg></a><a class=\"rs-sns-lists__item\" href=\"https://www.tiktok.com/@randstadjapan\" target=\"_blank\"><img class=\"rs-svg-icon-color rs-svg-icon-color--primary rs-text-bottom\" src=\"/recruit/img_f/icon-tiktok.svg\" alt=\"tiktok\" width=\"50\" height=\"50\"></a>\n      </dd>\n    </dl>\n    <dl class=\"rs-sns-lists-layout\">\n      <dt class=\"rs-heading rs-heading--level-4\">他事業部の採用はこちら</dt>\n      <dd><a class=\"rs-button rs-button--border\" href=\"/recruit/\" target=\"_blank\"><i class=\"rs-icon rs-icon--external\"></i>&nbsp;ランスタッド 採用情報</a></dd>\n    </dl>\n  </div>\n</div>\n    <div class=\"rs-notification rs-notification-target\">\n      <div class=\"rs-notification__inner\"><a class=\"rs-notification-logo\" href=\"/\"><img class=\"rs-notification-logo__img\" src=\"/recruit/img_f/logo.svg\" alt=\"randstad\"></a>\n        <button class=\"rs-notification__close rs-notification-close\" type=\"button\"><i class=\"rs-icon rs-icon--clear rs