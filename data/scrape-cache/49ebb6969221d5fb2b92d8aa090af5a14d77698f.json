\">キャリアステップ</a></li>\r\n                            <li><a href=\"/recruit/workstyle/female.html\">女性社員が輝く職場</a></li>\r\n                        </ul>\r\n                    </div></li>\r\n                    <li class=\"\"><div>\r\n                        <span class=\"NavPc\"><img src=\"/recruit/assets/images/header/nav_rec.svg\" alt=\"Recruitment 採用情報を知る\" width=\"118\" height=\"35\"></span><span class=\"NavSp\"><img src=\"/recruit/assets/images/header/nav_rec_sp.svg\" alt=\"Recruitment\" width=\"150\" height=\"18\"><span>採用情報を知る</span></span>\r\n                        <ul class=\"HeadNavDown\">\r\n                            <li><a href=\"/recruit/recruitment/flow.html\">応募要項・選考フロー</a></li>\r\n                            <li><a href=\"/recruit/recruitment/faq.html\">採用Q&A</a></li>\r\n                        </ul>\r\n                    </div></li>\r\n                    <li class=\"HeadForm\"><a href=\"https://www.renewal-taiyo.co.jp/form/recruit/\">採用応募フォームはこちら</a></li>\r\n                </ul>\r\n            </nav>\r\n        </div>\r\n    </header>\r\n</div>\r\n<aside class=\"BreadCrumb\">\r\n    <ul>\r\n        <li><a href=\"/recruit/\"><img src=\"/recruit/assets/images/header/pan_icon_home.svg\" alt=\"TOP\" width=\"15\" height=\"14\"></a></li>\r\n        <li><span>&rsaquo;</span></li>\r\n            </ul>\r\n</aside>\r\n\r\n\r\n<!-- Contents -->\r\n<article class=\"Container\">\r\n\t<div class=\"CommonTitleMove\">\r\n\t\t<span></span>\r\n\t\t<span class=\"CommonMoveTitle\"></span>\r\n\t\t<span class=\"CommonMoveTitle\"></span>\r\n\t\t<span class=\"CommonMoveTitle\"></span>\r\n\t</div>\r\n\t<h1>\r\n\t\t<img src=\"/recruit/assets/images/top/title.svg\" alt=\"日本一社員のことを考える企業であること TAIYO RECRUITING SITE\" width=\"529\" height=\"263\">\r\n\t</h1>\r\n\r\n    <aside class=\"RecTopNav\">\r\n        <nav>\r\n            <ul>\r\n                <li><a href=\"#RecTopCompany\"><span>太陽を知る</span></a></li>\r\n                <li><a href=\"#RecTopWorkstyle\"><span>社員・仕事を知る</span></a></li>\r\n                <li><a href=\"#RecTopRecruitment\"><span>採用情報を知る</span></a></li>\r\n            </ul>\r\n        </nav>\r\n        <div class=\"RecTopNavPeople1\"></div>\r\n        <div class=\"RecTopNavPeople2\"></div>\r\n    </aside>\r\n\r\n    <section class=\"RecTopNews\">\r\n        <div>\r\n            <h2><img src=\"/recruit/assets/images/top/news_title.png\" alt=\"NEWS\" width=\"86\" height=\"22\"></h2>\r\n            <dl>\r\n                <dt>2021.06.09</dt><dd>採用サイトをリニューアルしました！</dd>\r\n            </dl>\r\n        </div>\r\n    </section>\r\n\r\n    <div class=\"RecTopBody\">\r\n\r\n        <section class=\"RecSection MoveIn\" id=\"RecTopVision\">\r\n            <h2><img src=\"/recruit/assets/images/top/vison_title.svg\" alt=\"Vision\" width=\"167\" height=\"39\"></h2>\r\n            <div class=\"RecSectionTxt\">\r\n                <h3>社員を最も幸せにすることで、<br>会社の価値を高め続ける。</h3>\r\n                <p>企業の成長には社員一人ひとりの<br>発想力、行動力、挑戦心が必要不可欠です。<br>やりがいとやる気をもって働けるように、<br>太陽は、ビジネスで得た福利を社員に還元。<br>質の高いサービスを提供することで、<br>永続的な成長を果たしていきます。</p>\r\n            </div>\r\n            <div class=\"RecSectionPic\"><img src=\"/recruit/assets/images/top/vision_pic1.png\" alt=\"社員への還元 福利厚生の充実 質の高い仕事 画期的なサービス 企業価値の向上 永続的な成長\" width=\"394\" height=\"354\"></div>\r\n            <div class=\"RecSectionPeople\"></div>\r\n        </section>\r\n\r\n        <section class=\"RecSection MoveIn\" id=\"RecTopCompany\">\r\n            <h2><img src=\"/recruit/assets/images/top/com_title.svg\" alt=\"Company\" width=\"245\" height=\"47\"></h2>\r\n\r\n            <div class=\"RecSectionTxt\">\r\n                <h3>太陽を知る</h3>\r\n                <p>太陽は「100年間」必要とされる企業を目指し、<br>今日も社員一丸となって挑戦を続けています。</p>\r\n            </div>\r\n            <nav>\r\n                <ul>\r\n                    <li><a href=\"/recruit/company/message.html\"><span><span>トップメッセージ</span></span></a></li>\r\n                    <li><a href=\"/recruit/company/future.html\"><span><span>太陽で輝く仕事と未来</span></span></a></li>\r\n                    <li><a href=\"/recruit/company/allabout.html\"><span><span>ひと目でわかる太陽</span></span></a></li>\r\n                    <li><a href=\"/recruit/company/viewing.html\"><span><span>TAIYO VIEWING<span>～社内風景～</span></span></span></a></li>\r\n                </ul>\r\n            </nav>\r\n            <div class=\"RecSectionPeople\"></div>\r\n        </section>\r\n\r\n        <section class=\"RecSection MoveIn\" id=\"RecTopWorkstyle\">\r\n            <h2><img src=\"/recruit/assets/images/top/work_title.svg\" alt=\"Work Style\" width=\"297\" height=\"48\"></h2>\r\n            <div class=\"RecSectionTxt\">\r\n                <h3>社員・仕事を知る</h3>\r\n                <p>革新的な「5時間労働化」や多様な働き方を推し進め、<br>社員一人ひとりが幸せを感じて働ける環境づくりに努めています。</p>\r\n            </div>\r\n            <nav>\r\n                <ul>\r\n                    <li><a href=\"/recruit/workstyle/philosophy.html\"><span>社員の幸せのために<br>できること</span></a></li>\r\n                    <li><a href=\"/recruit/workstyle/profession.html\"><div><span>太陽で働こう<br>-職種紹介-</span></div></a></li>\r\n                    <li><a href=\"/recruit/workstyle/interview.html\"><div><span>社員インタビュー</span></div></a></li>\r\n                    <li><a href=\"/recruit/workstyle/career.html\"><div><span>キャリアステップ</span></div></a></li>\r\n                    <li><a href=\"/recruit/workstyle/female.html\"><div><span>女性社員が輝く職場</span></div></a></li>\r\n                </ul>\r\n            </nav>\r\n            <div class=\"RecSectionPeople\"></div>\r\n        </section>\r\n\r\n        <section class=\"RecSection MoveIn\" id=\"RecTopRecruitment\">\r\n            <h2><img src=\"/recruit/assets/images/top/rec_title.svg\" alt=\"Recruitment\" width=\"330\" height=\"39\"></h2>\r\n            <div class=\"RecSectionTxt\">\r\n                <h3>採用情報を知る</h3>\r\n                <p>採用についての詳しい情報や<br>よくある質問を紹介します。</p>\r\n            </div>\r\n            <nav>\r\n                <ul>\r\n                    <li><a href=\"/recruit/recruitment/flow.html\"><span>応募要項・選考フロー</span></a></li>\r\n                    <li><a href=\"/recruit/recruitment/faq.html\"><span>採用Q&A</span></a></li>\r\n                </ul>\r\n            </nav>\r\n            <div class=\"RecSectionPeople\"></div>\r\n        </section>\r\n    </div>\r\n\r\n    <div class=\"RecTopEntry\" id=\"RecTopEntry\">\r\n        <nav class=\"MoveIn\">\r\n            <a href=\"https://www.renewal-taiyo.co.jp/form/recruit/\"><img src=\"/recruit/assets/images/top/entry_entry.png\" alt=\"採用応募フォームはこちら\" width=\"364px\" height=\"141\"></a>\r\n            <div class=\"RecSectionPeople\">\r\n                <img src=\"/recruit/assets/images/top/entry_people-1.png\" alt=\"社員：イラスト\">\r\n                <img src=\"/recruit/assets/images/top/entry_people-2.png\" alt=\"社員：イラスト\">\r\n                <img src=\"/recruit/assets/images/top/entry_people-3.png\" alt=\"社員：イラスト\">\r\n                <img src=\"/recruit/assets/images/top/entry_people-4.png\" alt=\"社員：イラスト\">\r\n                <img src=\"/recruit/assets/images/top/entry_people-5.png\" alt=\"社員：イラスト\">\r\n            </div>\r\n        </nav>\r\n        <div class=\"RecSectionPic1\"></div>\r\n        <div class=\"RecSectionPic2\"></div>\r\n    </div>\r\n\r\n</article>\r\n<!-- /Contents -->\r\n\r\n\n<footer class=\"Footer\">\n    <aside class=\"FooterPageTop\">\n        <a href=\"#PageTop\"><span>PAGE TOP</span></a>\n    </aside>\n    <div class=\"FooterLinkColumn\">\n        <div>\n            <h3>太陽を知る</h3>\n            <ul>\n                <li><a href=\"/recruit/company/message.html\">トップメッセージ</a></li>\n                <li><a href=\"/recruit/company/future.html\">太陽で輝く仕事と未来</a></li>\n                <li><a href=\"/recruit/company/allabout.html\">ひと目でわかる太陽</a></li>\n                <li><a href=\"/recruit/company/viewing.html\">TAIYO VIEWING 〜社内風景〜</a></li>\n            </ul>\n        </div>\n\n        <div>\n            <h3>社員・仕事を知る</h3>\n            <ul>\n                <li><a href=\"/recruit/workstyle/philosoph