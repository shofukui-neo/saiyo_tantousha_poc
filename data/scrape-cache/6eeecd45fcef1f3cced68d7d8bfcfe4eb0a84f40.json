/cdn.jsdelivr.net/npm/@splidejs/splide@4.1.4/dist/css/splide.min.css\" rel=\"stylesheet\">\r\n<script>\r\nconst target = '.splide.headermv';\r\nconst target_options = {\r\ntype: 'fade',\r\nrewind: true,\r\narrows: false,\r\nautoplay: true,\r\ninterval: 5000,\r\nspeed: 2000,\r\ndrag:false,\r\npagination:false,\r\npauseOnHover: false,\r\npauseOnFocus: false,\r\nlazyLoad:'nearby',\r\n};\r\nconst mySplide = new Splide(target, target_options);\r\nmySplide.mount();\r\nmySplide.on('inactive', function (Slide) {if(mySplide.root.parentNode.className.match(new RegExp(/\\bautoscroll-\\S+/, 'g'))) Slide.slide.getElementsByClassName('slide-title')[0].firstElementChild.classList.remove('is-show'); let removeTarget = mySplide.root.getElementsByClassName('is-previous')[0];if(removeTarget) removeTarget.classList.remove('is-previous');Slide.slide.classList.add('is-previous');});\r\nmySplide.on('active', function (Slide) {Slide.slide.classList.remove('is-active');window.requestAnimationFrame(function(time) {window.requestAnimationFrame(function(time) {Slide.slide.classList.add('is-active');});});});\r\nconst fade=new IntersectionObserver(function(e){e.forEach(e=>{e.isIntersecting&&e.target.classList.add('is-show')})},{root:document.querySelector('#header-mv'),threshold:.95}),elements=document.querySelectorAll('.slide-title');elements.forEach(e=>{fade.observe(e.firstElementChild)});\r\n</script>\r\n<style>\r\n#header-mv.splider-container,#header-mv .headermv .slide-media,#header-mv .splide__slide{height: clamp(500px, calc(20rem + ((1vw - 4.8px) * 40)), 680px) !important;}\r\n#header-mv .slide-title,#header-mv h2.slide-title,\r\n#header-mv .slide-title,#header-mv h2.slide-title a{\r\ncolor:#F9E8EC;\r\n}\r\n#header-mv .slide-title,#header-mv h2.slide-title{\r\nfont-size:min(max(18px, calc(0.75rem + ((1vw - 4.8px) * 6.5))), 36px);\r\nmin-height: 0vw;\r\ntext-shadow:1px 1px 2px #666666;\r\n}\r\n#header-mv.autoscroll-left [aria-hidden=\"true\"] .slide-title,#header-mv.autoscroll-right [aria-hidden=\"true\"] .slide-title{opacity:initial;}\r\n</style>\r\n</div>\r\n<main id=\"main\">\r\n<section id=\"text1-section\">\r\n<div id=\"text1\" class=\"txt-body\">\r\n<div class=\"img-layout layout-04\">\r\n<div class=\"grid grid-clRD\" data-grid-column=\"col1\" data-grid-sp-column=\"col1\">\r\n<div class=\"grid-item\">\r\n<figure class=\"figure\" data-figure-horizontal=\"true\" data-figure-reverse=\"\" data-figure-responsive=\"true\" style=\"background-color:#F2E9B8;\">\r\n<span class=\"img-lb\"><a href=\"./tenpo.html\" class=\"figure-link\"><img class=\"lazyload\" data-src=\"./img/希望.jpg\" width=\"3200\" height=\"2400\" alt=\"\" style=\"border-radius:50%;\" /><noscript><img src=\"./img/希望.jpg\" alt=\"\" style=\"border-radius:50%;\" /></noscript></a></span>\r\n<figcaption class=\"figcaption\">\r\n<div class=\"figcaption-title\" style=\"font-size:clamp(18px, calc(1rem + ((1vw - 4.8px) * 7.5)), 20px)\"><span><a href=\"./tenpo.html\">ようこそ！いでしたへ！！</a></span></div>\r\n<p>『いつまでも、元気で明るく健康に』をモットーに運動を通して、体力低下の防止や寝たきり防止のための介護予防サポートを行っております！</p>\r\n<p>太陽のように明るい笑顔でおで迎えいたします！！</p>\r\n</figcaption>\r\n</figure>\r\n</div>\r\n<div class=\"grid-item\">\r\n<figure class=\"figure\" data-figure-horizontal=\"true\" data-figure-reverse=\"true\" data-figure-responsive=\"true\" style=\"background-color:#E6EEC7;\">\r\n<span class=\"img-lb\"><a href=\"./entry25.html\" class=\"figure-link\"><img class=\"lazyload\" data-src=\"./img/img_7286 copy.jpg\" width=\"2048\" height=\"1536\" alt=\"\" style=\"border-radius:50%;\" /><noscript><img src=\"./img/img_7286 copy.jpg\" alt=\"\" style=\"border-radius:50%;\" /></noscript></a></span>\r\n<figcaption class=\"figcaption\">\r\n<div class=\"figcaption-title\" style=\"font-size:clamp(18px, calc(1rem + ((1vw - 4.8px) * 7.5)), 20px)\"><span><a href=\"./entry25.html\">いでしたの盛りだくさんサービス！！</a></span></div>\r\n<p>全事業所10種類以上の運動機器を導入しております！様々なお身体のお悩みを解消するお手伝いができます。</p>\r\n<p>また他ではなかなか体験することの出来ない「足湯」「ウォーターベット」なども完備しております。</p>\r\n<p>娯楽も本物さながらの夏祭り！ギネスに挑戦⁉恵方巻作りなど楽しい娯楽が沢山です。</p>\r\n<p>いでしたでは「運動」「リラクゼーション」「娯楽」多種多様なサービスを楽しむことができます。</p>\r\n</figcaption>\r\n</figure>\r\n</div>\r\n<div class=\"grid-item\">\r\n<figure class=\"figure\" data-figure-horizontal=\"true\" data-figure-reverse=\"\" data-figure-responsive=\"true\" style=\"background-color:#F2E9B8;\">\r\n<span class=\"img-lb\"><a href=\"./saiyou.html\" class=\"figure-link\"><img class=\"lazyload\" data-src=\"./img/リクルート.jpg\" width=\"611\" height=\"425\" alt=\"\" style=\"border-radius:50%;\" /><noscript><img src=\"./img/リクルート.jpg\" alt=\"\" style=\"border-radius:50%;\" /></noscript></a></span>\r\n<figcaption class=\"figcaption\">\r\n<div class=\"figcaption-title\" style=\"font-size:clamp(18px, calc(1rem + ((1vw - 4.8px) * 7.5)), 20px)\"><span><a href=\"./saiyou.html\">一緒に働く仲間を募集中！！</a></span></div>\r\n<p>笑顔いっぱいの職場で、私たちと一緒に働きませんか？</p>\r\n<p>高齢者の方々の生活をサポートしながら、日々の小さな喜びや成長を感じられるやりがいのあるお仕事です。</p>\r\n<p>介護が未経験の方やブランクのある方も、丁寧な教育とサポート体制があるのでご安心ください。</p>\r\n<p><span class=\"mky_yellow_a\"><span class=\"mky_red_a\">◆2026.3.1求人情報更新◆</span></span></p>\r\n</figcaption>\r\n</figure>\r\n</div>\r\n<div class=\"grid-item\">\r\n<figure class=\"figure\" data-figure-horizontal=\"true\" data-figure-reverse=\"true\" data-figure-responsive=\"true\" style=\"background-color:#E6EEC7;\">\r\n</figure>\r\n</div>\r\n</div>\r\n</div>\r\n</div>\r\n</section>\r\n</main>\r\n<div id=\"main-footer\">\r\n<div id=\"whatsnew\">\r\n<div class=\"title\"><span>NEW<i>いでしたの最新情報</i></span></div>\r\n<div class=\"scroll-table hidden\" data-scroll-direction=\"vertical\">\r\n<div class=\"scroll-area\">\r\n<ul class=\"whatsnew_ul\">\r\n<li>\r\n<div class=\"whatsnew-time\"><time class=\"date\" datetime=\"2025-07-08\">2025/07/08</time></div>\r\n<div class=\"whatsnew-txt\"><a href=\"./entry25.html\">いでしたのサービス紹介を更新</a></div>\r\n</li>\r\n<li>\r\n<div class=\"whatsnew-time\"><time class=\"date\" datetime=\"2025-01-30\">2025/01/30</time></div>\r\n<div class=\"whatsnew-txt\"><a href=\"./entry23.html\">いでしたでのスケジュールを更新</a></div>\r