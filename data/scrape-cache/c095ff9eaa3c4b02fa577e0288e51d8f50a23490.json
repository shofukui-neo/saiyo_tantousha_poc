 type=\"text\" name=\"zip[data][1]\" class=\"p-postal-code\" size=\"5\" maxlength=\"4\" value=\"\" data-conv-half-alphanumeric=\"true\" />\n</span>\n\n<input type=\"hidden\" name=\"zip[separator]\" value=\"-\" />\n</dd>\n</p></div>\n</dl>\n<dl>\n<div class=\"dl-box\">\n<dt>ご住所<span class=\"req\">必須</span></dt>\n<dd>\n<input type=\"text\" name=\"address\" class=\"p-region p-locality p-street-address p-extended-address contact-add\" size=\"60\" value=\"\" placeholder=\"（例）和歌山県和歌山市友田町2丁目145番地 KEG教育センタービル2F\" />\n</dd>\n</p></div>\n</dl>\n<dl>\n<div class=\"dl-box\">\n<dt>法人・企業・団体の名称<span class=\"req\">必須</span></dt>\n<dd>\n<input type=\"text\" name=\"company\" class=\"contact-comp\" size=\"60\" value=\"\" />\n</dd>\n</p></div>\n</dl>\n<dl>\n<div class=\"dl-box\">\n<dt>電話番号<span class=\"req\">必須</span></dt>\n<dd>\n<input type=\"text\" name=\"tel\" class=\"contact-text\" size=\"60\" value=\"\" data-conv-half-alphanumeric=\"true\"/>\n</dd>\n</p></div>\n</dl>\n<dl>\n<div class=\"dl-box\">\n<dt>メールアドレス<span class=\"req\">必須</span></dt>\n<dd>\n<input type=\"text\" name=\"mail1\" class=\"contact-mail\" size=\"60\" value=\"\" placeholder=\"（例）sample@sample.com\" />\n</dd>\n</p></div>\n</dl>\n<dl>\n<div class=\"dl-box\">\n<dt>メールアドレス（確認用）<span class=\"req\">必須</span></dt>\n<dd>\n<input type=\"text\" name=\"mail2\" class=\"contact-mail\" size=\"60\" value=\"\" />\n</dd>\n</p></div>\n</dl>\n<p>\n<input type=\"submit\" name=\"submitConfirm\" value=\"確認画面へ\" class=\"contact-btn\"/>\n\n</p></div>\n<input type=\"hidden\" name=\"mw-wp-form-form-id\" value=\"88\" /><input type=\"hidden\" name=\"mw_wp_form_token\" value=\"6c54f53e98bd82bea462b5f0e55382344eaed574dda4f9a1177435a0e5183a6b\" /></form>\n\t\t\t\t<!-- end .mw_wp_form --></div>\n\t</section>\n\t<section class=\"related-wrap fadein-bottom\">\n\t<h2>関連コンテンツ</h2>\n\t<div class=\"related-box\">\n\t\t<div class=\"item\">\n\t\t\t\t\t\t\t<div class=\"img\">\n\t\t\t\t\t<img src=\"https://k-e-g.co.jp/wp-content/themes/keg-theme/assets/i