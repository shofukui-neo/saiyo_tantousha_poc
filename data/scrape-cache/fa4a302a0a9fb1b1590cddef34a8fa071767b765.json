{"url":"https://www.miyagi-hino.co.jp/recruit/guideline/index.html","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=1240\">\n<meta name=\"format-detection\" content=\"telephone=no\">\n<meta name=\"description\" content=\"宮城日野自動車株式会社の募集要項をご紹介します。募集職種、学科、初任給、勤務時間などの情報をしています。\">\n<!-- OGP -->\n<meta property=\"og:type\" content=\"article\" />\n<meta property=\"og:title\" content=\"新卒採用の募集要項 | 宮城日野自動車株式会社\" />\n<meta property=\"og:description\" content=\"宮城日野自動車株式会社の募集要項をご紹介します。募集職種、学科、初任給、勤務時間などの情報をしています。\"/>\n<meta property=\"og:site_name\" content=\"宮城日野自動車株式会社\" />\n<meta property=\"og:url\" content=\"https://www.miyagi-hino.co.jp/\" />\n<meta property=\"og:image\" content=\"https://www.miyagi-hino.co.jp/images/og_image.png\"/>\n<!-- /OGP -->\n<title>新卒採用の募集要項 | 宮城日野自動車株式会社</title>\n<meta name=\"author\" content=\"宮城日野自動車株式会社\">\n<link rel=\"icon\" href=\"/images/favicon.ico\">\n<link rel=\"apple-touch-icon\" sizes=\"180x180\" href=\"/images/apple-touch-icon.png\">\n<link rel=\"stylesheet\" href=\"../../css/base.css\">\n<link rel=\"stylesheet\" href=\"../../css/vibit.css\">\n<link rel=\"stylesheet\" href=\"../../css/pc.css\">\n<script src=\"https://webfont.fontplus.jp/accessor/script/fontplus.js?hWxdSd~4aRo%3D&box=AvrnYVleYb0%3D&aa=1&ab=2\"></script>\n<link rel=\"stylesheet\" href=\"https://kit.fontawesome.com/e2fcfcabc1.css\" crossorigin=\"anonymous\">\n<!-- Google tag (gtag.js) -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-J8L860N1V8\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n  gtag('config', 'G-J8L860N1V8');\n</script>\n</head>\n<body>\n<header class=\"frame-header hide inactive\" id=\"VcArea-Header\">\n  <div class=\"frame-header-inside\">\n    <h1 class=\"mod-header-siteid\"><a href=\"../../index.html\"><img src=\"../../vc-files/miyagi/common/logo.png\" width=\"347\" height=\"45\" alt=\"宮城日野自動車株式会社\" /></a></h1>\n    <div id=\"nav-main-button\">\n      <button type=\"button\" aria-controls=\"nav-main-showhide\" aria-expanded=\"false\"><span class=\"nav-main-button-icon\"><span class=\"label-menu\">メニュー</span><span class=\"label-close\">閉じる</span></span></button>\n    </div>\n    <div class=\"frame-header-nav nav-main-showhide\">\n      <nav class=\"mod-header-nav\" aria-label=\"メインメニュー\">\n                <ul class=\"nav-main-list\">\n          <li id=\"news\"><a href=\"../../news/index.html\">お知らせ</a></li>\n          <li id=\"company\"><a href=\"../../company/index.html\">会社案内</a></li>\n          <li id=\"branch\"><a href=\"../../branch/index.html\">支店・営業所</a></li>\n          <li id=\"chuko\"><a href=\"/lease/miyagi/\">リース商品のご案内</a></li>\n          <li id=\"after-service\"><a href=\"../../service/index.html\">整備料金表</a></li>\n          <li id=\"recruit\"><a href=\"../../insurance/index.html\">保険案内</a></li>\n          <li id=\"recruit\"><a href=\"../../recruit/index.html\">採用情報</a></li>\n          <li id=\"csr\"><a href=\"../../csr/index.html\">CSR</a></li>\n        </ul>\n        <ul class=\"nav-sub-list\">\n                          \n        <li class=\"nav-sub-item icon-pdf\"><a href=\"/vc-files/miyagi/common/Calendar2025-2026.pdf\" target=\"_blank\" >営業カレンダー</a></li>\n        </ul>\n      </nav>\n    </div>\n  </div>\n</header>\n<main>\n  <section class=\"frame-pagetitle\">\n    <h1 class=\"pagetitle\"><span>新卒採用の募集要項</span></h1>\n  </section>\n  <div class=\"breadcrumb\">\n<a href=\"../../index.html\">ホーム</a>&nbsp;<a href=\"../index.html\">採用情報</a>&nbsp;新卒採用の募集要項&nbsp;\n  </div>\n  <div class=\"frame-main frame-2col\">\n    <article class=\"frame-2col-main mod-content frame-recruit\" id=\"VcArea-MainColum\">\n      <div class=\"table table-type01\">\n        <dl>\n          <dt class=\"valign \">募集職種</dt>\n          <dd class=\"valign \">整備　／　総合職（営業・事務）</dd>\n        </dl>\n        <dl>\n          <dt class=\"valign \">募集学科</dt>\n          <dd class=\"valign \">総合職　：　学部不問<br />整備　　：　整備学科</dd>\n        </dl>\n        <dl>\n          <dt class=\"valign \">初任給</dt>\n          <dd class=\"valign \">大学（４年制）：194,000円<br />専門（整備）：184,000円～194,000円</dd>\n        </dl>\n        <dl>\n          <dt class=\"valign \">諸手当</dt>\n          <dd class=\"valign \">営業手当、整備士資格手当、現場手当、家族手当、通勤手当、時間外勤務手当　他</dd>\n        </dl>\n        <dl>\n          <dt class=\"valign \">昇給</dt>\n          <dd class=\"valign \">年1回（4月）</dd>\n        </dl>\n        <dl>\n          <dt class=\"valign \">賞与</dt>\n          <dd class=\"valign \">年2回（7月、12月）</dd>\n        </dl>\n        <dl>\n          <dt class=\"valign \">休日休暇</dt>\n          <dd class=\"valign \">日曜、祝日、土曜日（第2・第4土曜日＋1回／月）<br />年間休日115日（ＧＷ、夏季、年末年始休暇他）※2026年度より<br />年次有給休暇最大20日、特別休暇他</dd>\n        </dl>\n        <dl>\n          <dt class=\"valign \">福利厚生</dt>\n          <dd class=\"valign \">各種社会保険加入（健康、厚生年金、雇用）、財形貯蓄・ＤＣ（任意）、住宅補助（社内規定による）</dd>\n        </dl>\n        <dl>\n          <dt class=\"valign \">勤務地</dt>\n          <dd class=\"valign \">本社：仙台市宮城野区扇町<br />石巻営業所：東松島市赤井<br />古川営業所：大崎市古川沢田<br />大河原営業所：柴田郡大河原町</dd>\n        </dl>\n        <dl>\n          <dt class=\"valign \">勤務時間</dt>\n          <dd class=\"valign \">8：50 ～ 17：30　（12：00 ～ 13：00　休憩時間）<br />※事務職はフレックスタイム制あり<br />　　　　　コアタイム　10：00 ～ 15：00</dd>\n        </dl>\n        <dl>\n          <dt class=\"valign \">教育制度</dt>\n          <dd class=\"valign \">新入社員研修、整備研修、日野自動車集合研修・社内研修（階層別研修、スキルアップ研修）　等</dd>\n        </dl>\n        <dl>\n          <dt class=\"valign \">提出書類</dt>\n          <dd class=\"valign \">履歴書、卒業見込証明書、成績証明書、健康診断書</dd>\n        </dl>\n        <dl>\n          <dt class=\"valign \">選考方法</dt>\n          <dd class=\"valign \">書類選考を通った方について筆記試験、面接を行ないます</dd>\n        </dl>\n      </div>\n    </article>\n      <div class=\"frame-recruit-contact bg-lattice bg-beige\" id=\"VcArea-Saiyou\">\n      <div class=\"mod-recruit-contact bg-border-beige\">\n        <h1 class=\"recruit-contact-title outline-txt-jp\">採用に関するお問い合わせ</h1>\n        <ul>\n                    <li class=\"recruit-contact-tel\"><span class=\"tel\">022-235-3121</span></li>\n          <li class=\"recruit-contact-detail\">総務部総務課まで</li>\n                            </ul>\n        <div class=\"recruit-contact-img recruit-contact-img-left\"><img src=\"../../images/recruit-staff-left.svg\" alt=\"\"></div>\n        <div class=\"recruit-contact-img recruit-contact-img-right\"><img src=\"../../images/recruit-staff-right.svg\" alt=\"\"></div>\n      </div>\n    </div>\n    <nav class=\"frame-2col-side\" id=\"VcArea-NaviColum\">\n<!-- ▼▼▼ ラベル ▼▼▼ -->\n<ol>\n<li><a href=\"../index.html\">採用情報</a>\n<ol>\n<li><strong>新卒採用の募集要項</strong></li>\n<li><a href=\"career.html\">中途採用の募集要項</a></li>\n</ol>\n</li>\n</ol>\n<!-- ▲▲▲ ラベル ▲▲▲ -->\n    </nav>\n  </div>\n</main>\n<footer id=\"VcArea-Footer\">\n  <div class=\"frame-footer\">\n    <div class=\"mod-footer-nav\">\n            <ul class=\"footer-nav-list\">\n        <li class=\"footer-nav-item\"><a href=\"../../privacy/index.html\">プライバシーポリシー</a></li>\n        <li class=\"footer-nav-item\"><a href=\"../../insurance/detail/solicitationpolicy.html\">勧誘方針</a></li>\n        <li class=\"footer-nav-item\"><a href=\"../../insurance/detail/FiduciaryDuty.html\">お客様本位の業務運営に関する方針【FD宣言】</a></li>\n        <li class=\"footer-nav-item\"><a href=\"https://www.hino.co.jp/\" target=\"_blank\" rel=\"noopener noreferrer\">日野自動車公式サイト</a></li>\n      </ul>\n    </div>\n      \n    <ul class=\"mod-footer-banner\">\n          <li class=\"footer-banner-item\"><a href=\"https://www.hino.co.jp/profia/index.html\" target=\"_blank\" ><img src=\"/vc-files/common/banner_profia.jpg\" width=\"170\" height=\"60\" alt=\"日野プロフィア（大型トラック）商品サイトに移動する\" /></a></li>\n          <li class=\"footer-banner-item\"><a href=\"https://www.hino.co.jp/ranger/index.html\" target=\"_blank\" ><img src=\"/vc-files/common/banner_ranger.jpg\" width=\"170\" height=\"60\" alt=\"日野レンジャー（中型トラック）商品サイトに移動する\" /></a></li>\n   