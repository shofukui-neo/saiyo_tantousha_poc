r\"><div>\r\n\t\t<div class=\"renew2020-layout-wrapper__left\">\r\n\r\n<div class=\"section-block bg-color-4\"><div><div>\r\n\r\n\n\n\n\t\n\n\t\t\t<div class=\"elem-heading-lv1\"><div><div class=\"title_flex\">\n\t\t\t\t\n\t\t\t\t\n\t\t\t\t<h1><span itemprop=\"headline\">お問い合わせ</span></h1>\n\t\t\t\t\n\t\t\t\t\n\t\t\t\t\n\t\t\t\t\n\t\t\t\t\n\t\t\t<!-- /elem-heading-lv1 --></div></div></div>\n\n\n\n\n\r\n\r\n<div class=\"contents-wrapper\"><div><div>\r\n\r\n\n\n\n\t\n\n\t<style>\n.btn-faqlink_area {\nwidth:40%;\nmargin:10px auto;\n}\n.btn-faqlink {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  line-height: 1;\n  text-decoration: none;\n  color: #000;\n  font-size: 14px;\n  border-radius: 5px;\n  width: 100%;\n  height: 66px;\n  border: 2px solid #585858;\n  transition: 0.3s;\n  box-shadow: 0 2px #6e6e6e;\n  background-color: #fafafa;\n}\n\n.btn-faqlink:hover {\n text-decoration: none;\n  opacity: .7;\n}\n.anchor_area{\ncolor: #5a5a5a;\nwidth: 60%;\nmargin: 10px auto;\n}\n.flex_list{\ndisplay: flex;\nflex-direction: row;\njustify-content: space-between;\n}\n.flex_list li a{\n  color: #5a5a5a;\n  text-decoration: underline;\n  position: relative;\n  display: inline-block;\n  padding-left: 12px;\n}\n.flex_list li a:hover{\n  color: #5a5a5a;\n}\n.flex_list li a:before {\n  content: '';\n  width: 0;\n  height: 0;\n  border-style: solid;\n  border-width: 8px 6px 0px 6px;\n  border-color: #5a5a5a transparent transparent transparent;\n  position: absolute;\n  top: 0;\n  left: 0;\n  bottom: 0;\n  margin: auto;\n}\n</style>\n\n\n\n\n\n\t\n\n\t\n\t\t\n\t\t\t\n\t\t\t\t<div class=\"elem-paragraph\">\n\t\t\t\t\t<p class=\"left\">\n\t\t\t\t\t\tお問い合わせは、パソナにご登録済みかお済みでないかにより、下記いずれかのボタンからお願いします。<br />また、お問い合わせが多い項目につきましては「よくある質問」に掲載していますので、お問い合わせいただく前に、まずはご確認ください。\n\t\t\t\t\t\t\n\t\t\t\t\t</p>\n\t\t\t\t<!-- /elem-paragraph --></div>\n\n\t\t\n\t\t\n\t\t\t\n\n<div class=\"btn-faqlink_area\">\n<a href=\"/faq/index.html\" class=\"btn-faqlink\">よくある質問ページを見る</a>\n</div>\n\n\n\t\t\n\t\t\n\t\t\t\n\n\t\t\n\t\t\n\t\t\t\n\t\t\n\t\t\t\n\t\t\t\n\t\t\t\t<div class=\"elem-heading-lv3\" id=\"contact01\"><div class=\"elem-heading-lv3-pad\"><div class=\"elem-heading-lv3-pad\">\n\t\t\t\t\t<h3>ご登録がお済みでない方</h3>\n\t\t\t\t\t\n\t\t\t\t<!-- /elem-heading-lv3 --></div></div></div>\n\t\t\t\t\n\t\t\t\n\t\t\t\n\t\t\t\n\t\t\n\n\t\t\n\t\t\n\t\t\t\n\t\t\t\t<div class=\"elem-paragraph\">\n\t\t\t\t\t<p class=\"left\">\n\t\t\t\t\t\t「よくある質問」に該当がなく解決しない場合は、下記ボタンより必要項目をご入力のうえ、お問い合わせください。<br />基本的には1営業日以内に担当より回答を差し上げますが、お問い合わせ内容や営業時間などにより、回答にお時間をいただく場合もございますので、ご了承ください。\n\t\t\t\t\t\t\n\t\t\t\t\t</p>\n\t\t\t\t<!-- /elem-paragraph --></div>\n\n\t\t\n\t\t\n\t\t\t\n\t<div style=\"margin-bottom: 30px;\" class=\"txt-center\">\n\t\t<a class=\"btn large bg-color-1\" shape=\"rect\" href=\"https://pasonaelpis.my.site.com/MPS_ExternalInquiry\" target=\"_blank\"><div>お問い合わせをする</div></a>\n\t</div>\n\n\t\t\n\t\t\n\t\t\t\n\t\t\n\t\t\t\n\t\t\t\n\t\t\t\t<div class=\"elem-heading-lv3\" id=\"contact02\"><div class=\"elem-heading-lv3-pad\"><div class=\"elem-heading-lv3-pad\">\n\t\t\t\t\t<h3>ご登録済みの方</h3>\n\t\t\t\t\t\n\t\t\t\t<!-- /elem-heading-lv3 --></div></div></div>\n\t\t\t\t\n\t\t\t\n\t\t\t\n\t\t\t\n\t\t\n\n\t\t\n\t\t\n\t\t\t\n\t\t\t\t<div class=\"elem-paragraph\">\n\t\t\t\t\t<p class=\"left\">\n\t\t\t\t\t\tご登録済みの方には、MYPAGEに専用のお問い合わせ窓口をご用意しております。<br />MYPAGEにログインしていただき、「お問い合わせ・ヘルプ」メニューから「よくあるお問い合わせ」をご確認ください。<br />該当のFAQがない、あるいはお急ぎの場合には、AIチャットボットもご利用いただけます。\n\t\t\t\t\t\t\n\t\t\t\t\t</p>\n\t\t\t\t<!-- /elem-paragraph --></div>\n\n\t\t\n\t\t\n\t\t\t\n\t<div style=\"margin-bottom: 30px;\" class=\"txt-center\">\n\t\t<a class=\"btn large bg-color-3\" shape=\"rect\" href=\"https://pasonaelpis.my.site.com/MPS_CommunitiesLogin\" target=\"_blank\"><div>MYPAGEにログインする</div></a>\n\t</div>\n\n\t\t\n\t\t\n\t\t\t\n\t\t\n\t\t\t\n\t\t\t\n\t\t\t\t<div class=\"elem-heading-lv3\"><div class=\"elem-heading-lv3-pad\"><div class=\"elem-heading-lv3-pad\">\n\t\t\t\t\t<h3>法人のお客様</h3>\n\t\t\t\t\t\n\t\t\t\t<!-- /elem-heading-lv3 --></div></div></div>\n\t\t\t\t\n\t\t\t\n\t\t\t\n\t\t\t\n\t\t\n\n\t\t\n\t\t\n\t\t\t\n\t\t\t\t<div class=\"elem-paragraph\">\n\t\t\t\t\t<p class=\"left\">\n\t\t\t\t\t\tエキスパートサービス（人材派遣）、BPO・アウトソーシングサービス（委託・請負）、キャリアソリューション（人材紹介、再就職支援）、ITソリューション（DX導入支援、ITアウトソーシング）、健康経営支援サービスなどの事業を展開しております。サービスの詳細や料金などお気軽にお問合せくださいませ。\n\t\t\t\t\t\t\n\t\t\t\t\t</p>\n\t\t\t\t<!-- /elem-paragraph --></div>\n\n\t\t\n\t\t\n\t\t\t\n\t<div style=\"margin-bottom: 30px;\" class=\"txt-center\">\n\t\t<a class=\"btn large bg-color-1\" shape=\"rect\" href=\"https://info.pasona.co.jp/input/index.html\" target=\"_blank\"><div>お問い合わせをする</div></a>\n\t</div>\n\n\t\t\n\t\n\n\n\n\n\n\t\n\n\t\n\n\n\n\n\r\n\r\n\r\n\r\n<!-- /contents-wrapper --></div></div></div>\r\n<!-- /section-block --></div></div></div>\r\n\r\n\n\n\n\t\n\t\n\n\n\n\n\t\n\t\t\n\n\n\n\r\n\r\n\r\n\t\t</div><!-- /renew2020-layout-wrapper__left -->\r\n\r\n\t\t<div class=\"renew2020-layout-wrapper__right\">\r\n<div class=\"renew2020-color-box renew2020-pasona-register\">\r\n\t<h3 class=\"renew2020-pasona-register-heading\">\r\n\t\tパソナへのご登録は<br>お済みですか？\r\n\t</h3><!-- /renew2020-pasona-register-heading -->\r\n\r\n\t<a href=\"https://www.pasona.co.jp/register/basic-info\" class=\"renew2020-btn\">\r\n\t\t<i aria-hidden=\"true\" class=\"renew2020-note\"><svg><use xlink:href=\"#renew2020-note\"></use></svg></i>\r\n\t\t<span>パソナへ登録</span>\r\n\t</a><!-- /renew2020-btn -->\r\n\r\n\t<div class=\"elem-text-list\">\r\n\t\t<ul>\r\n\t\t\t<li class=\"nav\"><a href=\"/about/\">パソナがはじめての方へ</a></li>\r\n\t\t\t<li class=\"nav\"><a href=\"/regist/flow.html\">お仕事を開始するまでの流れ</a></li>\r\n\t\t\t<li class=\"nav\"><a href=\"/faq/index.html\">よくある質問</a></li>\r\n\t\t</ul>\r\n\t</div>\r\n<!-- /renew2020-color-box --></div>\r\n\r\n<div class=\"renew2020-column-list\" data-style=\"2\">\r\n\r\n<div class=\"renew2020-column-item\">\r\n<div class=\"renew2020-right-pic-container\">\r\n<a href=\"/campaign/\">\r\n<img src=\"/image/sidebar/bnr_tcp260501.png\" al