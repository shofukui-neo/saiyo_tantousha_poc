\n<!-- /under-line-anime-wrap -->\n\n    <div class=\"text-wrap\">\n        <h1 class=\"title\">トップメッセージ</h1>\n\n        <ul class=\"breadcrumbs\">\n        <li><a href=\"/\">Home</a></li>\n        <li><a href=\"index.html\">企業・グループ情報</a></li>\n        <li>トップメッセージ</li>\n        </ul>\n\n    </div>\n    <!-- /text-wrap -->\n\n<div class=\"under-line-anime-narrowwrap pos-rightbottom_narrow\">\n<div class=\"under-line-narrow\"></div>\n</div>\n<!-- /under-line-anime-wrap -->\n\n<div class=\"under-line-anime-fatwrap pos-rightbottom_fat\">\n<div class=\"under-line-fat\"></div>\n</div>\n<!-- /under-line-anime-wrap -->\n\n</div>\n<!-- /undercon-category-wrap-inner -->\n</div>\n<!-- /undercon-category-wrap -->\n\n\n<div class=\"section-wrap__under\">\n<div class=\"section\">\n\n<div class=\"title-wrap\">\n<h2 class=\"under-title\">トップメッセージ</h2>\n</div>\n<!-- /title-wrap -->\n\n<div class=\"message-wrap\">\n    <div class=\"message-wrap__inner\">\n        <div class=\"message-wrap__img\">\n            <img src=\"images/message/img_president.jpg?202509\" alt=\"トップメッセージ\">\n        </div>\n        <!-- /message-wrap__img -->\n        <div class=\"message-wrap__txt\">\n            <p class=\"message-wrap__txt--title\">TOP MESSAGE</p>\n            <p class=\"message-wrap__txt--subtitle\">トップメッセージ</p>\n            <p class=\"message-wrap__txt--desc\">\n                価値のある企業に成長し続けることを<br>目指します\n            </p>\n        </div>\n        <!-- /message-wrap__txt -->\n    </div>\n    <!-- /message-wrap_inner -->\n</div>\n<!-- /message-wrap -->\n\n<h3 class=\"under-title\">ご挨拶</h3>\n<p class=\"parag\">\n平素は格別のご支援を賜り、誠にありがとうございます。<br>\n<br>\n当社は、中古車輸出業界のパイオニアとして全世界のお客様とのお取引を1件1件大切にすることで、お客様のニーズを的確に把握し、敏感に対応することで常に業界の先頭を走ってまいりました。近年、当社は中古車輸出事業者からグローバルカーディーラーとなるべく、多様な販売ネットワークを確立してまいりました。<br>\n<br>\n市場環境が著しく変化する中、当社は今までのインターネットを通じた販売スタイルにとらわれず 『CLOSER TO YOU』というコンセプトのもと、それぞれのマーケットに根付いた戦略を世界規模で展開してまいります。今後も、押し寄せる業界変革の波とマーケットの成熟に対応し、常に未来を見据え一歩先ゆく一手を打っていくことにより、お取引先様、地域社会の皆様にとって価値のある企業に成長し続けることを目指してまいります。<br>\n<br>\n今後とも、何卒ご支援を賜わりますようお願い申し上げます。\n</p>\n<div class=\"sign\">\n株式会社トラスト<br>\n代表取締役社長<br>\n伊藤　和繁\n</div>\n\n\n</div>\n<!-- /section -->\n</div>\n<!-- /section-wrap -->\n\n\n</div>\n<!-- / id wrapper -->\n\n\n\n\n<footer id=\"footer\">\n\n<div class=\"footer-inner\">\n\n<div class=\"footer-menu-wrap\">\n\n<ul class=\"footer-menu-col1\">\n<li><p class=\"footer-menu--title\"><a href=\"https://www.trust-ltd.co.jp/about/index.html\">企業・グループ情報</a></p>\n\t<ul class=\"level1\">\n\t\t<li><a href=\"https://www.trust-ltd.co.jp/about/message.html\">トップメッセージ</a></li>\n\t\t<li><a href=\"https://www.trust-ltd.co.jp/about/philosophy.html\">企業理念</a></li>\n\t\t<li><a href=\"https://www.trust-ltd.co.jp/about/bussiness/index.html\">事業案内</a>\n\t\t\t<ul class=\"level2\">\n\t\t\t<li><a href=\"https://www.trust-ltd.co.jp/about/bussiness/usedcar-export.html\">中古車輸出事業</a></li>\n\t\t\t<li><a href=\"https://www.trust-ltd.co.jp/about/bussiness/overseas-cardealer.html\">海外自動車ディーラー事業</a></li>\n\t\t\t</ul>\n\t\t</li>\n\t\t<li><a href=\"https://www.trust-ltd.co.jp/about/organization.html\">会社概要・組織図</a></li>\n\t\t<li><a href=\"https://www.trust-ltd.co.jp/about/history.html\">沿革</a></li>\n\t\t<li><a href=\"https://www.trust-ltd.co.jp/about/group.html\">グループ会社</a></li>\n\t\t<li><a href=\"https://www.trust-ltd.co.jp/about/faq.html\">よくあるご質問・お問い合わせ</a></li>\n\t</ul>\n</li>\n<li><p class=\"footer-menu--title\"><a href=\"https://www.trust-ltd.co.jp/topics/\">トピックス</a></p></li>\n</ul>\n\n<ul class=\"footer-menu-col1\">\n\t<li><p class=\"footer-menu--title\"><a href=\"https://www.trust-ltd.co.jp/ir/index.html\">公開情報</a></p>\n\t\t<div class=\"footer-menu-col2__inner\">\n\t\t<ul class=\"level1\">\n\t\t\t<li><a href=\"https://www.trust-ltd.co.jp/ir/library/index.html\">財務・業績情報</a>\n\t\t\t\t<ul class=\"level2\">\n\t\t\t\t<li><a href=\"https://www.trust-ltd.co.jp/ir/library/result.html\">決算短信</a></li>\n\t\t\t\t<li><a href=\"https://www.trust-ltd.co.jp/ir/library/securities.html\">有価証券報告書</a><