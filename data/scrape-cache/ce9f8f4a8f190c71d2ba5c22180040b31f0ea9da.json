069\\u518d\\u5b9f\\u884c\\u3057\\u3066\\u304f\\u3060\\u3055\\u3044\\u3002\"},\"form\":{\"badRequest\":\"\\u30a8\\u30e9\\u30fc\\u304c\\u767a\\u751f\\u3057\\u307e\\u3057\\u305f\\u3002\\u5f8c\\u307b\\u3069\\u6539\\u3081\\u3066\\u304a\\u8a66\\u3057\\u304f\\u3060\\u3055\\u3044\\u3002\"}},\"jQuery\":\"jimdoGen002\",\"isJimdoMobileApp\":false,\"bgConfig\":null,\"bgFullscreen\":null,\"responsiveBreakpointLandscape\":767,\"responsiveBreakpointPortrait\":480,\"copyableHeadlineLinks\":false,\"tocGeneration\":false,\"googlemapsConsoleKey\":false,\"loggingForAnalytics\":false,\"loggingForPredefinedPages\":false,\"isFacebookPixelIdEnabled\":false,\"userAccountId\":\"19640ab5-1fa5-4ec4-a15a-ec269c50c686\",\"dmp\":{\"typesquareFontApiKey\":\"4L6CCYWjET8%3D\",\"typesquareFontApiScriptUrl\":\"\\/\\/code.typesquare.com\\/static\\/4L6CCYWjET8%253D\\/ts105.js\",\"typesquareFontsAvailable\":true}};\n    // ]]>\n</script>\n\n     <script> (function(window) { 'use strict'; var regBuff = window.__regModuleBuffer = []; var regModuleBuffer = function() { var args = [].slice.call(arguments); regBuff.push(args); }; if (!window.regModule) { window.regModule = regModuleBuffer; } })(window); </script>\n    <script src=\"https://assets.jimstatic.com/web.js.c1d9079888a6ad3e83ae.js\" async=\"true\"></script>\n    <script src=\"https://assets.jimstatic.com/at.js.619d00f8aa071522cb43.js\"></script>\n<meta name=\"google-site-verification\" content=\"xf9ohjnS4ifhkThGo480poIwVgZ7x_VZEUBEf_74FUw\"/>\n    \n\n</head>\n\n<body class=\"body cc-page cc-page-index cc-indexpage cc-pagemode-default cc-content-parent\" id=\"page-979407174\">\n\n<div id=\"cc-inner\" class=\"cc-content-parent\"><div id=\"gj-container-wrap\" class=\"cc-content-parent\">\n    <div id=\"gj-container\" class=\"cc-content-parent\">\n        <div id=\"gj-header\">\n            <div id=\"gj-visual\">\n                \n<div id=\"emotion-header\" data-action=\"emoHeader\" style=\"background: #FFFFFF;width: 900px; height: 272px;\">\n            <a href=\"https://www.mtk.jp/\" style=\"border: 0; text-decoration: none; cursor: pointer;\">\n    \n    <img src=\"https://u.jimcdn.com/cms/o/s6fee64c18e400669/emotion/crop/header.jpg?t=1585905460\" id=\"emotion-header-img\" alt=\"\"/>\n\n\n\n        <img id=\"emotion-header-logo\" src=\"https://image.jimcdn.com/app/cms/image/transf/dimension=184x38:format=jpg/path/s6fee64c18e400669/logo/version/1585905037/image.jpg\" alt=\"\" style=\"left: 78%; top: 83%;                 border: none;                  padding: 0px;                  background: #FFF;              \"/>\n    \n\n\n    <strong id=\"emotion-header-title\" style=\"             left: 26%;             top: 6%;             font: normal normal 29px/120% 'ヒラギノ角ゴ Pro W3', 'Hiragino Kaku Gothic Pro','メイリオ','Mayryo','ＭＳ Ｐゴシック','MS PGothic',sans-serif;             color: #1626DD;                         \">異形引抜シャフトのトップメーカー\n\n\n\n\n\nＴＥＬ 058-271-6541</strong>\n            </a>\n        </div>\n\n\n            </div>\n        </div>\n        <div id=\"gj-contents\" class=\"cc-content-parent\">\n            <div id=\"gj-main_contents\" class=\"cc-content-parent\"> \n                <div id=\"content_area\" data-container=\"content\"><div id=\"content_start\"></div>\n        \n        <div id=\"cc-matrix-1216149174\"><div id=\"cc-m-5532143774\" class=\"j-module n j-header \"><h1 class=\"\" id=\"cc-m-header-5532143774\">ようこそ　異形シャフトのMTKへ</h1></div><div id=\"cc-m-5532140574\" class=\"j-module n j-text \"><p>\n    鉄を創造し、新しい時代を拓く。\n</p>\n\n<p>\n    MTK株式会社は、鉄と共に生きる異形引抜シャフト（磨棒鋼）の専門メーカーです！\n</p></div><div id=\"cc-m-5586701374\" class=\"j-module n j-header \"><h2 class=\"\" id=\"cc-m-header-5586701374\">MTK　６つの強み</h2></div><div id=\"cc-m-5586093974\" class=\"j-module n j-text \"><p>\n    1.豊富な形状を製造（オリジナル形状/六角/四角/平鋼）\n</p>\n\n<p>\n    2.豊富な取り扱い鋼種（SUM２２/SGD３/S４５C/SUS等）\n</p>\n\n<p>\n    3.プリンターシャフト国内シェア№１\n</p>\n\n<p>\n    4.自社製品在庫（丸棒/<span style=\"line-height: 22.3999996185303px;\">六角/四角/平鋼</span><span style=\"line-height: 22.3999996185303px;\">）の翌日配送</span>\n</p>\n\n<p>\n    5.切削レス/歩留まり向上によるコストダウンの提案\n</p>\n\n<p>\n    6.究極の高品質・高精度　（5.0シャフト）\n</p></div><div id=\"cc-m-5586093774\" class=\"j-module n j-hr \">    <div class=\"hr\"></div>\n</div><div id=\"cc-m-10329483074\" class=\"j-module n j-video \"><div class=\"cc-m-video-gutter cc-m-video-align-left cc-m-video-ratio-2\" style=\"width: 608px;\">\n    <div class=\"cc-m-video-wrapper\">\n<iframe id=\"cc-m-video-youtu-container-10329483074\" class=\"cc-m-video-youtu-container cc-m-video-container\" frameborder=\"0\" allowfullscreen=\"true\" style=\"border: 0;\" src=\"https://www.youtube-nocookie.com/embed/wRtJTVfcoqA?wmode=transparent&amp;vq=hd1080\">\n</iframe>\n        <div class=\"cc-m-video-overlay\"></div>\n    </div>\n\n</div>\n\n<div class=\"cc-clear\"></div>\n\n<script id=\"cc-m-reg-10329483074\">// <![CDATA[\n\n    window.regModule(\"module_video\", {\"variant\":\"default\",\"id\":10329483074,\"maxwidth\":1920,\"maxheight\":1200,\"minwidth\":100,\"minheight\":100,\"useContentSize\":0,\"isVideoValid\":true,\"align\":\"left\",\"height\":\"344\",\"width\":\"608\",\"ratioIndex\":2});\n// ]]>\n</script></div><div id=\"cc-m-5532142874\" class=\"j-module n j-header \"><h2 class=\"\" id=\"cc-m-header-5532142874\">会社概要</h2></div><div id=\"cc-m-5532140974\" class=\"j-module n j-textWithImage \"><figure class=\"cc-imagewrapper cc-m-image-align-2\">\n<a href=\"javascript:;\" rel=\"lightbox\" data-href=\"https://image.jimcdn.com/app/cms/image/transf/dimension=origxorig:format=jpg/path/s6fee64c18e400669/image/i415ad8f1498bfa18/version/1750029642/mtk-%E6%9C%AC%E7%A4%BE-%E3%82%A8%E3%83%A0%E3%83%86%E3%82%A3%E3%82%B1%E3%83%BC.jpg\" data-title=\"MTK全景\"><img srcset=\"https://image.jimcdn.com/app/cms/image/transf/dimension=251x1024:format=jpg/path/s6fee64c18e400669/image/i415ad8f1498bfa18/version/1750029642/mtk-%E6%9C%AC%E7%A4%BE-%E3%82%A8%E3%83%A0%E3%83%86%E3%82%A3%E3%82%B1%E3%83%BC.jpg 251w, https://image.jimcdn.com/app/cms/image/transf/dimension=320x1024:format=jpg/path/s6fee64c18e400669/image/i415ad8f1498bfa18/version/1750029642/mtk-%E6%9C%AC%E7%A4%BE-%E3%82%A8%E3%83%A0%E3%83%86%E3%82%A3%E3%82%B1%E3%83%BC.jpg 320w, https://image.jimcdn.com/app/cms/image/transf/dimension=502x1024:format=jpg/path/s6fee64c18e400669/image/i415ad8f1498bfa18/version/1750029642/mtk-%E6%9C%AC%E7%A4%BE-%E3%82%A8%E3%83%A0%E3%83%86%E3%82%A3%E3%82%B1%E3%83%BC.jpg 502w\" sizes=\"(min-width: 251px) 251px, 100vw\" id=\"cc-m-textwithimage-image-5532140974\" src=\"https://image.jimcdn.com/app/cms/image/transf/dimension=251x1024:format=jpg/path/s6fee64c18e400669/image/i415ad8f1498bfa18/version/1750029642/mtk-%E6%9C%AC%E7%A4%BE-%E3%82%A8%E3%83%A0%E3%83%86%E3%82%A3%E3%82%B1%E3%83%BC.jpg\" alt=\"MTK　本社　エムティケー\" class=\"\" data-src-width=\"1024\" data-src-height=\"768\" data-src=\"https://image.jimcdn.com/app/cms/image/transf/dimension=251x1024:format=jpg/path/s6fee64c18e400669/image/i415ad8f1498bfa18/version/1750029642/mtk-%E6%9C%AC%E7%A4%BE-%E3%82%A8%E3%83%A0%E3%83%86%E3%82%A3%E3%82%B1%E3%83%BC.jpg\" data-image-id=\"4001887174\"/></a><figcaption style=\"width: 251px\">MTK全景</figcaption>    \n\n</figure>\n<div>\n    <div id=\"cc-m-textwithimage-5532140974\" data-name=\"text\" data-action=\"text\" class=\"cc-m-textwithimage-inline-rte\">\n        <p>\n    <strong>会社名称:</strong>　エム・ティ・ケー株式会社\n</p>\n\n<p>\n     \n</p>\n\n<p>\n    <strong>本社所在地:</strong>　岐阜県岐阜市六条江東1－16－5\n</p>\n\n<p>\n     \n</p>\n\n<p>\n    <strong>代表者:</strong>　代表取締役 松原　健\n</p>\n\n<p>\n     \n</p>\n\n<p>\n    <strong>創立:</strong>　1939年2月11日\n</p>\n\n<p>\n    <strong> </strong>\n</p>\n\n<p>\n    <strong>資本金:</strong>　7500万円\n</p>\n\n<p>\n     \n</p>\n\n<p>\n    <strong>売上高:</strong>　112億円（2024年度実績）\n</p>\n\n<p>\n     \n</p>\n\n<p>\n    <strong>従業員数:</strong>　220人\n</p>\n\n<p>\n     \n</p>\n\n<p>\n    <strong>事業内容:</strong>　磨棒鋼、 センターレス研磨、 切削加工部品、 天井吊りボルト、\n</p>\n\n<p>\n    　　　　　 建築用鋼製下地材（天井・壁）、 コンクリートセパレーター等の製造\n</p>    </div>\n</div>\n\n<div class=\"cc-clear\"></div>\n<script id=\"cc-m-reg-5532140974\">// <![CDATA[\n\n    window.regModule(\"module_textWithImage\", {\"data\":{\"imageExists\":true,\"hyperlink\":\"\",\"hyperlink_target\":\"\",\"hyperlinkAsString\":\"\",\"pinterest\":\"0\",\"id\":5532140974,\"widthEqualsContent\":\"0\",\"resizeWidth\":\"251\",\"resizeHeight\":189},\"variant\":\"default\",\"selector\":\"#cc-m-5532140974\",\"id\":5532140974});\n// ]]>\n</script></div><div id=\"cc-m-5586093174\" class=\"j-module n j-header \"><h2 class=\"\" id=\"cc-m-header-5586093174\">企業理念</h2></div><div id=\"cc-m-5535048674\" class=\"j-module n j-text \"><div class=\"line-h13\">\n    <span style=\"color: #000000;\">私達は絶えず創意工夫をして技術の向上に取り組み、顧客から期待される高品質な製品を適正価格で安定供給することに生きがいを見い出し、製品を通じて社会に貢献できる価値ある企業づくりを目指しております。</span>\n</div></div><div id=\"cc-m-10330802474\" class=\"j-module n j-hr \">    <div class=\"hr\"></div>\n</div><div id=\"cc-m-5535760574\" class=\"j-module n j-header \"><h2 class=\"\" id=\"cc-m-header-5535760574\">社是</h2></div><div id=\"cc-m-5535766974\" class=\"j-module n j-text \"><p>\n    <strong>鍵 ＝ 商人 ＝ <span style=\"color: #339966;\">「才覚」</span> 採算をくずさず</strong>\n</p>\n\n<p>\n    <strong>剣 ＝ 武士 ＝ <span style=\"color: #3366ff;\">「清廉」</span> 浮利に走らず</strong>\n</p>\n\n<p>\n    <strong>鎌 ＝ 農民 ＝ <span style=\"color: #ff0000;\">「忍耐」</span> 日々努力する</strong>\n</p></div><div id=\"cc-m-5535814074\" class=\"j-module n j-header \"><h3 class=\"\" id=\"cc-m-header-5535814074\">農鍛冶の心意気を受け継ぐ、「才覚、清廉、忍耐」の社是額</h3></div><div id=\"cc-m-5535777974\" class=\"j-module n j-hgrid \">    <div class=\"cc-m-hgrid-column\" style=\"width: 29.65%;\">\n        <div id=\"cc-matrix-1217129374\"><div id=\"cc-m-5535778174\" class=\"j-module n j-imageSubtitle \"><figure class=\"cc-imagewrapper cc-m-image-align-1\">\n<img srcset=\"https://image.jimcdn.com/app/cms/image/transf/none/path/s6fee64c18e400669/image/i356facda4de5b56c/version/1427347572/mtk-%E7%A4%BE%E6%98%AF.jpg 155w\" sizes=\"(min-width: 155px) 155px, 100vw\" id=\"cc-m-imagesubtitle-image-5535778174\" sr