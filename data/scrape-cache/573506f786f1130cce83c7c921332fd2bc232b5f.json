portant;}.has-light-green-cyan-to-vivid-green-cyan-gradient-background{background: var(--wp--preset--gradient--light-green-cyan-to-vivid-green-cyan) !important;}.has-luminous-vivid-amber-to-luminous-vivid-orange-gradient-background{background: var(--wp--preset--gradient--luminous-vivid-amber-to-luminous-vivid-orange) !important;}.has-luminous-vivid-orange-to-vivid-red-gradient-background{background: var(--wp--preset--gradient--luminous-vivid-orange-to-vivid-red) !important;}.has-very-light-gray-to-cyan-bluish-gray-gradient-background{background: var(--wp--preset--gradient--very-light-gray-to-cyan-bluish-gray) !important;}.has-cool-to-warm-spectrum-gradient-background{background: var(--wp--preset--gradient--cool-to-warm-spectrum) !important;}.has-blush-light-purple-gradient-background{background: var(--wp--preset--gradient--blush-light-purple) !important;}.has-blush-bordeaux-gradient-background{background: var(--wp--preset--gradient--blush-bordeaux) !important;}.has-luminous-dusk-gradient-background{background: var(--wp--preset--gradient--luminous-dusk) !important;}.has-pale-ocean-gradient-background{background: var(--wp--preset--gradient--pale-ocean) !important;}.has-electric-grass-gradient-background{background: var(--wp--preset--gradient--electric-grass) !important;}.has-midnight-gradient-background{background: var(--wp--preset--gradient--midnight) !important;}.has-small-font-size{font-size: var(--wp--preset--font-size--small) !important;}.has-medium-font-size{font-size: var(--wp--preset--font-size--medium) !important;}.has-large-font-size{font-size: var(--wp--preset--font-size--large) !important;}.has-x-large-font-size{font-size: var(--wp--preset--font-size--x-large) !important;}\n/*# sourceURL=global-styles-inline-css */\n</style>\n\n<link rel='stylesheet' id='contact-form-7-css' href='https://fic.co.jp/cms/wp-content/plugins/contact-form-7/includes/css/styles.css?ver=6.1.6' media='all' />\n<link rel='stylesheet' id='contact-form-7-confirm-css' href='https://fic.co.jp/cms/wp-content/plugins/contact-form-7-add-confirm/includes/css/styles.css?ver=5.1-20210630' media='all' />\n<script id=\"jquery-core-js\" src=\"https://fic.co.jp/cms/wp-includes/js/jquery/jquery.min.js?ver=3.7.1\"></script>\n<script id=\"jquery-migrate-js\" src=\"https://fic.co.jp/cms/wp-includes/js/jquery/jquery-migrate.min.js?ver=3.4.1\"></script>\n</head>\n\n \n<body id=\"p-rec\" class=\"page-about\">\r\n<header id=\"top\">\r\n<p id=\"sp-name\"><a href=\"https://fic.co.jp/\"><img decoding=\"async\" src=\"https://fic.co.jp/cms/wp-content/themes/fic/images/img-common/logo_color.svg\" alt=\"株式会社福島情報処理センター\"></a></p>\n<div class=\"menu-container\">\n  <nav class=\"menu sp\">\n    <ul class=\"cl-effect-3\">\n      <li id=\"name-box\">\n        <h1><img decoding=\"async\" src=\"https://fic.co.jp/cms/wp-content/themes/fic/images/img-common/logo_color.svg\" alt=\"株式会社福島情報処理センター\"></h1>\n        <p><a href=\"https://fic.co.jp/\"><img decoding=\"async\" src=\"https://fic.co.jp/cms/wp-content/themes/fic/images/img-common/logo_color.svg\" alt=\"株式会社福島情報処理センター\"></a></p>\n      </li>\n      <li id=\"nav-rechome\"><a href=\"https://fic.co.jp/recruitment/\">Home</a></li>\n      <li id=\"nav-about\"><a href=\"https://fic.co.jp/recruitment/about/\">About</a></li>\n      <li id=\"nav-workstyle\"><a href=\"https://fic.co.jp/recruitment/workstyle/\">Work style</a></li>\n      <li id=\"nav-interview\"><a href=\"https://fic.co.jp/recruitment/interview/\">Interview</a></li>\n      <li id=\"nav-yoko\"><a href=\"https://fic.co.jp/recruitment/newface/\">募集要項</a></li>\n      <li id=\"nav-contact\"><a href=\"https://fic.co.jp/contact/\">お問い合わせ</a></li>\n    </ul>\n  </nav>\n</div>\r\n<div id=\"head-vis\" data-aos=\"slide-down\" data-aos-offset=\"300\">\r\n  <h2>[会社理念・概要など]</h2>\r\n  <p>About</p>\r\n</div>\r\n</header>\r\n\r\n<main>\r\n\r\n<section id=\"msg-wrap\">\r\n<h3 class=\"t-type2\">トップメッセージ</h3>\r\n<div class=\"sprits\">\r\n<div class=\"ph-pre\"><img decoding=\"async\" src=\"https://fic.co.jp/cms/wp-content/themes/fic/images/about/ph-pres.jpg\" alt=\"FIC代表取締役社長 小暮　憲一\">\r\n<p>代表取締役社長<span>小暮　憲一</span></p>\r\n</div>\r\n<p><span>「ふくしま」で注目されるICT企業へ。</span>　情報サービス産業は、変化のスピードが速く最先端を走っており、時代の流れも敏感に感じることができますし、新しいことにチャレンジすることができる環境にあります。ですから当社としては物事をプラス思考で捉え、積極的にチャレンジできる人材を求めています。本人のやる気次第ですが、ICT関係の資格も勤めながら取得することもできます。すでに色々な資格を取得している社員も多いので、サポート面も充実しています。<br>\r\nまた当社の魅力はその９割近くが地元「ふくしま」出身者で、「地元愛」が強い会社であり、スポーツをはじめとした同好会活動も活発です。仕事以外での趣味も共有できると思います。<br>\r\nICT関係は現在注目される業種であり、どうしても中央（首都圏）を希望される学生さんが多いと思いますが、ICT関連業種であるからこそ、ここ「ふくしま」でもできる企業があることをわかってほしいとの思いがあります。<br>\r\n地元福島で、福島のために働きたい方を待っております。</p>\r\n</div>\r\n</section>\r\n\r\n<section id=\"keiei-wrap\">\r\n<h3 class=\"t-type2\">経営ビジョン</h3>\r\n<div class=\"sprits\">\r\n<dl>\r\n<dt>お客様満足度の向上</dt>\r\n<dd>FICはベストICTパートナーとして、お客様のニーズを高品質かつスピーディに実現する『オンリーワン企業』を目指します。</dd>\r\n</dl>\r\n<dl>\r\n<dt>社員満足度の向上</dt>\r\n<dd>FICは社員一人ひとりを尊重し、自ら考え自ら行動する社員とともに「やりがい」を実感できる職場を作ります。</dd>\r\n</dl>\r\n<dl>\r\n<dt>収益力の強化</dt>\r\n<dd>FICは事業環境変化に順応できる態勢を整備し、強固な収益基盤を構築することで、地域になくてはならない長寿企業を目指します。</dd>\r\n</dl>\r\n</div>\r\n</section>\r\n\r\n<div id=\"rec\" class=\"sprits\">\r\n<section id=\"rinen-wrap\">\r\n<h3 class=\"t-type2\">企業理念</h3>\r\n<div class=\"sprits\">\r\n<dl>\r\n<dt>社会的使命</dt>\r\n<dd><p>「地域情報化へ貢献する企業」</p>社会的ニーズを的確に捉え、情報サービス業を以て地域の発展に寄与する企業</dd>\r\n</dl>\r\n<dl>\r\n<dt>行動規範</dt>\r\n<dd><p>「未来を思考する企業」</p>常に最新技術を意識したソリューションを提供できる企業</dd>\r\n</dl>\r\n<dl>\r\n<dt>経営姿勢</dt>\r\n<dd><p>「お客様の満足を第一とする企業」</p>常に満足いただけるシステム作りに徹しお客様から信頼される企業</dd>\r\n</dl>\r\n<dl>\r\n<dt>品質方針</dt>\r\n<dd><p>顧客要求事項を的確に捉え、お客様に満足していただける品質の良い製品を開発し提供するため、継続的な改善を行う。品質マネジメントシステムの効率的な運用により顧客満足度を高め、生産性の向上を目指す。</p></dd>\r\n</dl>\r\n</div>\r\n</section>\r\n\r\n<section id=\"jigyo-wrap\">\r\n<h3 class=\"t-type2\">事業内容</h3>\r\n<p>「ネットワーク」「リアルタイム」「コラボレーション」 常に千変万化するビジネス環境にあって、最適なソリューションをご提案する上で求められるものは、最先端の技術、広範囲な業務知識とノウハウ、安全な情報管理、安定したシステム運用。 私たちＦＩＣが常に携わり、追い求めてきたそれらすべてを、ワンストップで提供します。</p>\r\n<div class=\"fig-jigyo\" data-aos=\"slide-top\" data-aos-offset=\"300\"><img decoding=\"async\" src=\"https://fic.co.jp/cms/wp-content/themes/fic/images/about/fig_jigyo.svg\" alt=\"事業内容の図\"></div>\r\n<figure><img decoding=\"async\" src=\"https://fic.co.jp/cms/wp-content/themes/fic/images/recruitment/ph-gaikan.jpg\" alt=\"FIC外観\"></figure>\r\n</section>\r\n</div>\r\n\r\n<dl id=\"all-about\">\r\n<dt>創業50余年が過ぎて、今も地域の情報システムを牽引しています。</dt>\r\n<dd>\r\n<ul>\r\n  <li><a href=\"https://fic.co.jp/about/gaiyo/\">会社概要</a></li>\r\n  <li><a href=\"https://fic.co.jp/about/gaiyo/?id=enkaku-wrap\">沿　革</a></li>\r\n  <li><a href=\"https://fic.co.jp/products/\">製品情報</a></li>\r\n  <li><a href=\"https://fic.co.jp/datacenter/\">データセンター</a></li>\r\n  </ul>\r\n</dd>\r\n</dl>\r\n\r\n<section id=\"access-wrap\">\r\n<h3 class=\"t-type2\">アクセス</h3>\r\n<dl>\r\n<dt class=\"access-name\">本　社</dt>\r\n<dd>\r\n<div class=\"iframe-wrap\">\r\n<iframe src=\"https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d25355.56402374855!2d140.33250680338782!3d37.4029312296505!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x60206cd1ff0cd567%3A0xc8714621d4dc1cb7!2z44CSOTYzLTgwMjUg56aP5bO255yM6YOh5bGx5biC5qGR6YeO77yT5LiB55uu77yR77yY4oiS77yS77yU!5e0!3m2!1sja!2sjp!4v1603329619029!5m2!1sja!2sjp\" frameborder=\"0\" style=\"border:0;\" allowfullscreen=\"\" aria-hidden=\"false\" tabindex=\"0\"></iframe>\r\n</div>\r\n</dd>\r\n</dl>\r\n<div id=\"add-link\">\r\n<p>〒963-8025<br>\r\n福島県郡山市桑野三丁目18-24<br>\r\nTEL.024-923-2116 FAX.024-938-6762</p>\r\n<a href=\"https://fic.co.jp/about/gaiyo/?id=kotsu\">交通案内はこちらをご覧ください</a>\r\n</div>\r\n</section>\r\n\r\n<div id=\"inter-bk\"></div>\n<dl id=\"inter-wrap\">\n  <dt>[スタッフインタビュー]<p>学歴や学部はいろいろ。多彩な個性が光ってる。</p><div class=\"zabuton\"><a href=\"https://fic.co.jp/recruitment/interview/?id=zadankai\" data-aos=\"fade-down\" data-aos-offset=\"300\"><img decoding=\"async\" src=\"https://fic.co.jp/cms/wp-content/themes/fic/images/recruitment/btn-interview.svg\" alt=\"グループインタビューこちら\"></a></div></dt>\n  <dd>\n  <a href=\"https://fic.co.jp/recruitment/interview-staff01/\"><div class=\"inter01\"><img decoding=\"async\" src=\"https://fic.co.jp/cms/wp-content/themes/fic/images/recruitment/ph-inter01-murakami.jpg\" alt=\"村上　俊政\"><div><span>開発・保守</span>村上　俊政</div></div></a>\n  <a href=\"https://fic.co.jp/recruitment/interview-staff02/\"><div class=\"inter02\"><img decoding=\"async\" src=\"https://fic.co.jp/cms/wp-content/themes/fic/images/recruitment/ph-inter02-aitai.jpg\" alt=\"會田　純平\"><div><span>運用・保守</span>會田　純平</div></div></a> \n  <a href=\"https://fic.co.jp/recruitment/interview-staff03/\"><div class=\"inter03\"><img decoding=\"async\" src=\"https://fic.co.jp/cms/wp-content/themes/fic/images/recruitment/ph-inter03-inaba.jpg\" alt=\"稲葉　友美香\"><div><span>営　業</span>稲葉　友美香</div></div></a>\n  <a href=\"https://fic.co.jp/recruitment/interview-staff04/\"><div class=\"inter04\"><img decoding=\"async\" src=\"https://fic.co.jp/cms/wp-content/themes/fic/images/recruitment/ph-inter04-endo.jpg\" alt=\"遠藤　卓哉\"><div><span>設計構築</span>遠藤　卓哉</div></div></a>\n  <a href=\"https://fic.co.jp/recruitment/interview-staff05/\"><div class=\"inter05\"><img decoding=\"async\" src=\"https://fic.co.jp/cms/wp-content/themes/fic/images/recruitment/ph-inter05-wakabayashi.jpg\" alt=\"若林　柊太\"><div><span>電算運用</span>若林　柊太</div></div></a>\n  </dd>\n</dl>\r\n<dl id=\"group-wrap\">\n  <dt>GROUP INTERVIEW</dt>\n  <dd>\n  <a href=\"https://fic.co.jp/recruitment/zadankai-flesh/\"><div class=\"gr01\"><img decoding=\"async\" src=\"https://fic.co.jp/cms/wp-content/themes/fic/images/recruitment/ph-zadankai01.jpg\" alt=\"座談会：新入社員\"><p>興味・関心・向上心を持ち続けること。</p><p>座談会：新入社員</p></div></a>\n  <a href=\"https://fic.co.jp/recruitment/zadankai-sankyu/\"><div class=\"gr02\"><img decoding=\"async\" src=\"https://fic.co.jp/cms/wp-content/themes/fic/images/recruitment/ph-zadankai02.jpg\" alt=\"座談会：産休・育休\"><p>FICの環境は子育てに優しい会社。</p><p>座談会：産休・育休</p></div></a>\n  <a href=\"https://fic.co.jp/recruitment/zadankai-josei/\"><div class=\"gr03\"><img decoding=\"async\" src=\"https://fic.co.jp/cms/wp-content/themes/fic/images/recruitment/ph-zadankai03.jpg\" alt=\"座談会：新入社員\"><p>皆が存分に頑張れる会社。</p><p>座談会：女性社員</p></div></a>\n  </dd>\n</dl>\r\n<hr>\r\n<div id=\"cont-bana\" class=\"sprits\">\n  <dl>\n    <dt>[会社理念・概要など]</dt>\n    <dd>\n    <p>About</p>\n    <a href=\"https://fic.co.jp/recruitment/about/\"><div><img decoding=\"async\" src=\"https://fic.co.jp/cms/wp-content/themes/fic/images/recruitment/ph-about-thum.jpg\" alt=\"会社理念・概要など\"></div></a>\n    </dd>\n  </dl>\n  <dl>\n    <dt>[仕事環境]</dt>\n    <dd>\n    <p>Work style</p>\n    <a href=\"https://fic.co.jp/recruitment/workstyle/\"><div><img decoding=\"async\" src=\"https://fic.co.jp/cms/wp-content/themes/fic/images/recruitment/ph-work-thum.jpg\" alt=\"仕事環境\"></div></a>\n    </dd>\n  </dl>\n</div>\r\n\r\n<div id=\"QAWebChat\"></div> \r\n</main>\n<footer>\n<ul id=\"footer-top\">\n  <!-- <li>\n    <a href=\"http://www.abnet.or.jp/abnet/\" target=\"_blank\" rel=\"noopener noreferrer\">\n    <p>インターネットプロバイダー</p>\n    <p>あぶくまネットワークス</p>\n    </a>\n    <p class=\"child\"></p>\n  </li> -->\n  <li>\n    <a href=\"https://ff-project.com/\" target=\"_blank\" rel=\"noopener noreferrer\">\n    <p>FICとFCSの2社共創プロジェクト</p>\n    <p>FF Project</p>\n    </a>\n    <p class=\"child\"></p>\n  </li>\n</ul>\n<div class=\"footer-3box\">\n  <div id=\"fname-box\">\n    <img src=\"https://fic.co.jp/cms/wp-content/themes/fic/images/img-common/logo_color.svg\" alt=\"株式会社福島情報処理センター\">\n    <p>〒963-8025<br>\n    福島県郡山市桑野三丁目18-24<br>\n    <span><a href=\"tel:0249232116\">TEL.024-923-2116</a> FAX.024-938-6762</span></p>\n    <a href=\"https://fic.co.jp/about/gaiyo/?id=access-wrap\">アクセス</a>\n  </div>\n\n  <div id=\"nav-box-wrap\">\n    <div id=\"nav-box\">\n      <ul>\n        <li><a href=\"https://fic.co.jp/info/\">新着情報</a></li>\n        <li><a href=\"https://fic.co.jp/products/\">製品情報</a></li>\n        <li><a href=\"https://fic.co.jp/recruitment/\">採用情報</a></li>\n      </ul>\n      <ul>\n        <li><a href=\"https://fic.co.jp/about/\">会社情報</a><