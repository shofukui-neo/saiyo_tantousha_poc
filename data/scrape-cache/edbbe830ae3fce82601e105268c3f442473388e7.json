/common/variable.css\">\n  <link rel=\"stylesheet\" href=\"/assets/css/common/reset.css\">\n  <link rel=\"stylesheet\" href=\"/assets/css/common/layout.css\">\n  <link rel=\"stylesheet\" href=\"/assets/css/common/utility.css\">\n  <!-- /COMMON SET -->\n\n  <!-- COMPONENT -->\n  <link rel=\"stylesheet\" href=\"/assets/css/component/component.css\">\n  <link rel=\"stylesheet\" href=\"/assets/css/component/form.css\">\n  <link rel=\"stylesheet\" href=\"/assets/css/page/form/common.css\">\n  <link rel=\"stylesheet\" href=\"/assets/css/page/form/search.css\">\n  <link rel=\"stylesheet\" href=\"/assets/css/page/gx-common.css\"/>\n  <link rel=\"stylesheet\" href=\"/assets/css/page/gx-entry.css\">\n  <link rel=\"stylesheet\" href=\"/assets/css/component/include_global_t.css\">\n\t<link rel=\"stylesheet\" href=\"/assets/css/component/include_local.css\">\n  <link rel=\"stylesheet\" href=\"/assets/css/lib/scroll-hint.css\"/>\n  <!-- /COMPONENT -->\n\n\t<!-- PAGE -->\n\t<!-- /PAGE -->\n\n  <!-- COMMON JS -->\n  <script src=\"/assets/js/lib/swiper-bundle.min.js\"></script>\n  <script src=\"/assets/js/common/common.js\" defer></script>\n  <script src=\"/assets/js/common/utils.js\"></script>\n  <script src=\"/assets/js/common/include_global.js\"></script>\n  <script src=\"/assets/js/common/include_local.js\"></script>\n  <!-- /COMMON JS -->\n\n  <!-- COMPONENT JS -->\n  <script src=\"/assets/js/lib/scroll-hint.min.js\"></script>\n  <!-- /COMPONENT JS -->\n</head>\n<body data-step=\"1\">\n  <!-- Google Tag Manager (noscript) -->\n  <noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-K9LJ3D22\"\n  height=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n  <!-- End Google Tag Manager (noscript) -->\n\n  <!-- SIDENAVI -->\n  <div class=\"sidenavi\" id=\"sidenavi\">\n  </div>\n  <script>window.GRPT_GLOBAL && window.GRPT_GLOBAL.createGlobalSideNavi();</script>\n  <!-- /SIDENAVI -->\n\n  <div class=\"l-frame-wrap\">\n    <!-- SIDEBAR -->\n    <div class=\"l-gsidebar\" id=\"sidebar\">\n    </div>\n    <script>window.GRPT_GLOBAL && window.GRPT_GLOBAL.createGlobalSideBar();</script>\n    <!-- /SIDEBAR -->\n    <div class=\"l-frame-main\">\n      <!-- HEADER -->\n      <header class=\"l-header\" id=\"header\">\n      </header>\n      <script>window.GRPT_GLOBAL && window.GRPT_GLOBAL.createGlobalHeader();</script>\n      <!-- /HEADER -->\n      <!-- CONTENTS -->\n      <main>\n        <div class=\"l-hero\">\n          <div class=\"l-hero__inner\">\n           <div class=\"l-hero__body\">\n              <div class=\"l-hero__block\">\n                <div class=\"c-hero-heading-sub\">\n                  <div class=\"c-hero-heading-sub__inner\">\n                    <div class=\"c-hero-heading-sub__label\">\n                      <img src=\"/assets/img/common/hero_label.png\" alt=\"\">\n                    </div>\n                  </div>\n                </div>\n                <h1 class=\"c-hero-heading\">\n                  <span class=\"c-hero-heading__head-category u-text--s u-hide-sp\">GXアカウント</span>\n                  <div class=\"c-hero-heading-text\">\n                    <span class=\"c-hero-heading-text__label\">GXへの協力表明 専用アカウント<br class=\"u-hide-tab-pc\">（GXアカウント）発行依頼</span>\n                  </div>\n                </h1>\n                <div class=\"c-hero-heading-add\">\n                  <div class=\"c-hero-heading-add-ico u-hide-tab-pc\">\n                    <p class=\"c-hero-heading-add-ico__text\">GX建築事業者<br class=\"u-hide-tab-pc\">アカウント</p>\n                  </div>\n                  <div class=\"c-hero-heading-add-ico --gx\">\n                    <p class=\"c-hero-heading-add-ico__text\">GX志向型<br class=\"u-hide-tab-pc\">住宅</p>\n                  </div>\n                </div>\n              </div>\n           </div>\n          </div>\n        </div>\n        <div class=\"l-container\">\n          <div class=\"l-container__body\">\n\n            <section class=\"l-section\" id=\"\">\n              <div class=\"l-section__body\">\n                <div class=\"l-block\">\n                  <div class=\"l-block__body\">\n\n                    <!-- accordion-->\n                    <dl class=\"js-accordion-group entry__container\" role=\"tablist\">\n                      <dt class=\"tab__term js-accordion-item\" role=\"tab\" aria-expanded=\"true\">\n                        <span class=\"tab__term__label entry__container-heading\"><p class=\"entry__container-heading-title\">\n                          <span class=\"entry__container-heading-title__label u-main-color u-text-bold u-text--l\">GXアカウントについて</span>\n                        </p>\n                        <div class=\"js-accordion-toggle entry__container-heading-toggle\"><span class=\"entry__container-heading__icon\"></span></div></span>\n                      </dt>\n                      <dd class=\"tab__defin js-accordion-panel-item\" aria-hidden=\"true\" role=\"tabpanel\">\n                        <div class=\"tab__defin__inner\">\n                          <div class=\"tab__defin-container\">\n                            <div class=\"tab__defin-content\">\n                              <div class=\"tab__txt\">\n                                <div class=\"entry__block js-accordion-body\">\n                                  <p class=\"c-text u-mb-1_5\">\n                                    <span class=\"u-text--s\">GX建築事業者のうち、建築した分譲住宅を自ら販売しない事業者（ゼネコンや下請業者等）が、GXへの協力表明を行うためのアカウント。</span>\n                                  </p>\n                                  <p class=\"c-text\">\n                                    <span class=\"u-text--s u-text-bold u-accent-color\">本社の管理部門等の担当者が取得、利用してください。（１事業者１アカウントのみ）</span>\n                                  </p>\n                                  <div class=\"entry_caution\">\n                                    <div class=\"entry_caution__body\">\n                                      <div class=\"entry_caution-heading\">ご注意ください</div>\n                                      <div class=\"entry_caution__block\">\n                                        <ul class=\"c-list --list-desc --list-size-xs u-attention-color-1000\">\n                                          <li><span class=\"c-list__ico\"></span><span class=\"c-list__text\">住宅省エネ支援事業者として登録する場合、当該事業者の登録過程でGXへの協力表明を行うため、本アカウントを取得する必要はありません。\n                                          </span></li>\n                                          <li><span class=\"c-list__ico\"></span><span class=\"c-list__text\">GXへの協力表明を行った事業者は、本キャンペーンのホームページ上で公表されます。</span></li>\n                                        </ul>\n                                      </div>\n                                    </div>\n                                  </div>\n\n                                  <div class=\"c-btn-list --2col --s --justify-content-center\">\n                                    <div class=\"c-btn --download --download-sp --circle-icon --color-jigyo01\">\n                                      <a href=\"https://jutaku-shoene2026.mlit.go.jp/assets/doc/about_account.pdf\" target=\"_blank\" class=\"c-btn__link\">\n                                        <div class=\"c-btn__inner\">\n                                          <div class=\"c-btn__body\">\n                                            <div class=\"c-btn__img\"><svg>\n                                                <use xmlns:xlink=\"http://www.w3.org/2000/svg\" xlink:href=\"/assets/img/common/sprite.svg#ico_pdf\">\n                                                </use>\n                                              </svg></div>\n                                            <p class=\"c-btn__text\"><span class=\"c-btn__text__label\">アカウントについて</span></p>\n                                            <div class=\"c-btn__arrow\">\n                                              <div class=\"c-btn__arrow__icon\">\n                                                <svg>\n                                                  <use xmlns:xlink=\"http://www.w3.org/2000/svg\" xlink:href=\"/assets/img/common/sprite.svg#ico_cursor\"></use>\n                                                </svg>\n                                              </div>\n                                            </div>\n                                          </div>\n                                        </div>\n                                      </a>\n                                    </div>\n                                    <div class=\"c-btn\">\n                                      <a href=\"/gx-participation/\" class=\"c-btn__link\">\n                                        <div class=\"c-btn__inner\">\n                                          <div class=\"c-btn__body\">\n                                            <p class=\"c-btn__text\"><span class=\"c-btn__text__label\">GXへの協力に係る<br>意思表明について\n                                            </span></p>\n                                            <div class=\"c-btn__arrow\">\n                                              <div class=\"c-btn__arrow__icon\">\n                                                <svg>\n                                                  <use xmlns:xlink=\"http://www.w3.org/2000/svg\" xlink:href=\"/assets/img/common/sprite.svg#ico_cursor\"></use>\n                                                </svg>\n                                              </div>\n                                            </div>\n                                          </div>\n                                        </div>\n                                      </a>\n                                    </div>\n                                  </div>\n\n                                </div>\n                              </div>\n                            </div>\n                          </div>\n                        </div>\n                      </dd>\n                    </dl>\n                    <!-- /accordion -->\n\n                    <!-- accordion-->\n                    <dl class=\"js-accordion-group entry__container\" role=\"tablist\" id=\"environment\">\n                      <dt class=\"tab__term js-accordion-item\" role=\"tab\" aria-expanded=\"false\">\n                        <span class=\"tab__term__label entry__container-heading\"><p class=\"entry__container-heading-title\">\n                          <span class=\"entry__container-heading-title__label u-main-color u-text-bold u-text--l\">住宅省エネポータルの<br class=\"u-hide-tab-pc\">ご利用にあたり</span>\n                        </p>\n                        <div class=\"js-accordion-toggle entry__container-heading-toggle\"><span class=\"entry__container-heading__icon\"></span></div></span>\n                      </dt>\n                      <dd class=\"tab__defin js-accordion-panel-item\" aria-hidden=\"true\" role=\"tabpanel\">\n                        <div class=\"tab__defin__inner\">\n                          <div class=\"tab__defin-container\">\n                            <div class=\"tab__defin-content\">\n                              <div class=\"tab__txt\">\n                                <div class=\"entry__block js-accordion-body\">\n                                  <ul class=\"c-list --list-desc --list-size-s environment-list u-mb-1\">\n                                    <li><span class=\"c-list__ico\"></span><span class=\"c-list__text\">本キャンペーンの手続きはすべてWEBシステム（住宅省エネポータル）で行います。（インターネット環境が必要です）</span></li>\n                                    <li><span class=\"c-list__ico\"></span><span class=\"c-list__text\">多くの添付書類をアップロードする必要があるため、スマートフォンによる操作は想定しておりません。<br>(スマートフォンでは、一部レイアウトが崩れる場合があります。)</span></li>\n                                  </ul>\n\n                                  <ul class=\"c-list --list-desc --list-size-s\">\n                                    <li><span class=\"c-list__ico\"></span><span class=\"c-list__text\">ポータルの利用、申請手続きは以下のウェブブラウザでご利用頂くことを推奨しています。</span></li>\n                                  </ul>\n                                  <ul class=\"c-list --list-size-s browser-list\">\n                                    <li><span class=\"c-list__text\">Google Chrome™の最新の安定バージョン</span></li>\n                                    <li><span class=\"c-list__text\">Microsoft® Edge®の最新の安定バージョン</span></li>\n                                    <li><span class=\"c-list__text\">Mozilla®Firefox®の最新の安定バージョン</span></li>\n                                    <li><span class=\"c-list__text\">Apple® Safari®の最新の安定バージョン</span></li>\n                                  </ul>\n                                </div>\n                              </div>\n                            </div>\n                          </div>\n                        </div>\n                      </dd>\n                    </dl>\n                    <!-- /accordion -->\n\n                    <!-- /.l-block__body -->\n                  </div>\n                  <!-- /.l-block -->\n                </div>\n                <!-- /.l-section__body -->\n              </div>\n            </section>\n\n            <form action=\"https://mirai-eco2026.mlit.go.jp/gx-entry/step2\" name=\"frm\" id=\"frm\" method=\"post\">\n              <input type=\"hidden\" name=\"_token\" value=\"9FsFAsWv44KdcEjBtaXSC1xgW3UqJJtTjQ9Gn8fJ\" autocomplete=\"off\">              <section class=\"l-section\" id=\"\">\n                <div class=\"l-section__body\">\n                  <div class=\"step-heading\">\n                    <div class=\"step-heading__inner\">\n                      <h2 class=\"step-heading__body\">\n                        <span class=\"step-heading__label\">情報の入力</span>\n                      </h2>\n                      <div class=\"step-heading__progress\">\n                        <div class=\"step-heading-form__progress\" data-step=\"1\">\n                          <ol class=\"step-heading-form__progress_list\">\n                            <li class=\"step-heading-form__progresslist_items\">\n                              <div class=\"step-heading-form__progress_container\">\n                                <p class=\"step-heading-form__progress_head\">STEP1</p>\n                                <dl class=\"step-heading-form__progress_desc\">\n                                  <dt class=\"step-heading-form__progress_desc__term\">\n                                    <div class=\"step-heading-form__progress_desc__term__label__inner\">\n                                      <span class=\"step-heading-form__progress_desc__term__label\"></span>\n                                    </div>\n                                  </dt>\n                                  <dd class=\"step-heading-form__progress_desc__defin\">情報の入力</dd>\n                                </dl>\n                              </div>\n                            </li>\n                            <li class=\"step-heading-form__progresslist_items\">\n                              <div class=\"step-heading-form__progress_container\">\n                                <p class=\"step-heading-form__progress_head\">STEP2</p>\n                                <dl class=\"step-heading-form__progress_desc\">\n                                  <dt class=\"step-heading-form__progress_desc__term\">\n                                    <div class=\"step-heading-form__progress_desc__term__label__inner\">\n                                    <span class=\"step-heading-form__progress_desc__term__label\"></span>\n                                  </div>\n                                  </dt>\n                                  <dd class=\"step-heading-form__progress_desc__defin\">入力内容の<br class=\"u-hide-tab-pc\">確認</dd>\n                                </dl>\n                              </div>\n                            </li>\n                            <li class=\"step-heading-form__progresslist_items\">\n                              <div class=\"step-heading-form__progress_container\">\n                                <p class=\"step-heading-form__progress_head\">STEP3</p>\n                                <dl class=\"step-heading-form__progress_desc\">\n                                  <dt class=\"step-heading-form__progress_desc__term\">\n                                    <div class=\"step-heading-form__progress_desc__term__label__inner\">\n                                      <span class=\"step-heading-form__progress_desc__term__label\"></span>\n                                    </div>\n                                  </dt>\n                                  <dd class=\"step-heading-form__progress_desc__defin\">メール認証<br class=\"u-hide-tab-pc\">確認</dd>\n                                </dl>\n                              </div>\n                            </li>\n                            <li class=\"step-heading-form__progresslist_items\">\n                              <div class=\"step-heading-form__progress_container\">\n                                <p class=\"step-heading-form__progress_head\">STEP4</p>\n                                <dl class=\"step-heading-form__progress_desc\">\n                                  <dt class=\"step-heading-form__progress_desc__term\">\n                                    <div class=\"step-heading-form__progress_desc__term__label__inner\">\n                                      <span class=\"step-heading-form__progress_desc__term__label\"></span>\n                                    </div>\n                                  </dt>\n                                  <dd class=\"step-heading-form__progress_desc__defin\">発行依頼<br class=\"u-hide-tab-pc\">完了</dd>\n                                </dl>\n                              </div>\n                            </li>\n                          </ol>\n                        </div>\n                      </div>\n                      <p class=\"c-text u-text-align-center\">\n                        <span class=\"u-text--s\">以下のすべての項目を入力してください。</span>\n                      </p>\n                    </div>\n                  </div>\n                  <div class=\"l-block\">\n                    <div class=\"l-block__body\">\n                      <div class=\"c-form\">\n                        <div class=\"c-form__row\">\n                          <div class=\"c-form__row__inner \">\n                            <div class=\"c-form__row__title\">\n                              <div class=\"c-form__row__title__inner\">\n                                <span class=\"c-form__row__title__label\">あなたの氏名</span>\n                                <span class=\"c-form__row__title__label-icon --required\">必須</span>\n                              </div>\n                            </div>\n                            <div class=\"c-form__row__cell --2col\">\n                              <div class=\"c-form__row__cell__inner\">\n                                <div class=\"c-form-component__outer --two-column\">\n                                  <div class=\"c-form-component__outer__inner\">\n                                    <p class=\"c-text u-text-bold c-form-text-unit\">\n                                      <span class=\"u-text--s\">姓</span>\n                                    </p>\n                                    <div class=\"c-form-component --size-s\">\n                                      <input type=\"text\" name=\"last_name\" id=\"last_name\" value=\"\" placeholder=\"田中\" class=\"--gray\">\n                                    </div>\n                                  </div>\n                                                                  </div>\n                                <div class=\"c-form-component__outer --two-column\">\n                                  <div class=\"c-form-component__outer__inner\">\n                                    <p class=\"c-text u-text-bold c-form-text-unit\">\n                                      <span class=\"u-text--s\">名</span>\n                                    </p>\n                                    <div class=\"c-form-component --size-s\">\n                                      <input type=\"text\" name=\"first_name\" id=\"first_name\" value=\"\" placeholder=\"太郎\" class=\"--gray\">\n                                    </div>\n                                  </div>\n                                                                  </div>\n                              </div>\n                            </div>\n                            <!-- /.c-form__row__inner -->\n                          </div>\n                          <div class=\"c-form__row__inner --mail \">\n                            <div class=\"c-form__row__title\">\n                              <div class=\"c-form__row__title__inner\">\n                                <span class=\"c-form__row__title__label\">メールアドレス</span>\n                                <span class=\"c-form__row__title__label-icon --required\">必須</span>\n                              </div>\n                            </div>\n                            <div class=\"c-form__row__cell\">\n                              <div class=\"c-form__row__cell__inner\">\n                                <div class=\"c-form-component --size-l\">\n                                  <input type=\"text\" name=\"email\" id=\"email\" value=\"\"  placeholder=\"メールアドレスを入力してください\" class=\"--gray\">\n                                </div>\n                              </div>\n                                                            <p class=\"c-text mail-text\">\n                                <span class=\"u-text--m\">事務局からのメールが、迷惑メールとして取り扱われる事象が報告されています。<br>除外リストに以下のドメインを追加頂けますよう、お願い致します。</span>\n                              </p>\n                              <ul class=\"c-list --list-desc --list-size-s mail-list u-mb-1\">\n                                <li><span class=\"c-list__ico\"></span><span class=\"c-list__text\">●●@jutaku-shoene2026.jp</span></li>\n                                <li><span class=\"c-list__ico\"></span><span class=\"c-list__text\">●●@mirai-eco2026.jp</span></li>\n                              </ul>\n                              <ul class=\"c-list --list-annotation --list-size-m u-attention-color-1000 u-text-bold\">\n                                <li class=\"\"><span class=\"c-list__ico\">※</span><span class=\"c-list__text\">GXアカウントが発行されると、今後、事務局のメールアドレスより通知が届きます。</span></li>\n                                <li class=\"\"><span class=\"c-list__ico\">※</span><span class=\"c-list__text\">事務局からのメールの到着に、一定の時間を要する場合があります。</span></li>\n                              </ul>\n                            </div>\n                            <!-- /.c-form__row__inner -->\n                          </div>\n                          <!-- /.c-form__row__inner -->\n                        </div>\n                          <!-- /.c-form__row -->\n                      </div>\n                      <!-- /.c-form -->\n                    </div>\n                  </div>\n                </div>\n              </section>\n              <section class=\"l-section\" id=\"\">\n                <div class=\"l-section__body\">\n                  <h3 class=\"c-section-heading\">\n                    <div class=\"c-section-heading__body\">\n                      <span class=\"c-section-heading__label\">住宅省エネポータル利用規約およびプライバシーポリシー各種への同意</span>\n                    </div>\n                  </h3>\n                  <div class=\"l-block\">\n                    <div class=\"l-block__body\">\n                      <p class=\"c-text playvacy-text\">\n                        <span>「住宅省エネ2026キャンペーン 住宅省エネポータル利用規約」および「プライバシーポリシー」各種をすべて読み、同意する必要があります。</span>\n                      </p>\n                      <p class=\"c-text playvacy-text\">\n                        <span>すべてを読み、同意事項に同意した上で、確認画面へ進んでください。</span>\n                      </p>\n                      <ul class=\"c-list --list-annotation --list-size-xs playvacy-list --bold-600\">\n                        <li><span class=\"c-list__ico\">※</span><sp