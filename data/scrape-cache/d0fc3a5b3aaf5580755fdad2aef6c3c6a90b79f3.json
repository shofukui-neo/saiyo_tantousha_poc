le\">\n\n<article>\n<header class=\"ly_main_head\">\n<div class=\"bl_lower_mv\">\n<h1 class=\"bl_lower_mv_ttl\">お客様の声</h1>\n</div>\n\n<div class=\"bl_breadcrumbs\">\n<ol class=\"ly_cont_inner\">\n<li class=\"home\"><a href=\"https://chicken-golf.com/\"><img src=\"https://chicken-golf.com/wp-content/themes/asobi_lab/images/common/icon_home__gold.svg\" alt=\"HOME\"></a></li>\n<li><a href=\"https://chicken-golf.com/voices\">お客様の声</a></li><li><span class=\"pc\">小原様</span><span class=\"sp\">小原様</span></li></ol>\n</div>\n</header>\n\n<section id=\"voices\">\n<div class=\"ly_cont_inner\">\n\n<div class=\"ly_cont ly_cont__col\">\n<div class=\"ly_cont_main\">\n\n<div class=\"bl_postVoices\">\n<h1 class=\"bl_postVoices_ttl\">小原&nbsp;様</h1>\n\n<div class=\"bl_postVoices_info\">\n<figure class=\"bl_postVoices_imgWrapper\">\n<img src=\"https://chicken-golf.com/wp-content/uploads/2023/07/golf_obara_5.png\" alt=\"小原様\">\n</figure>\n\n<dl class=\"bl_postVoices_salon\">\n<div>\n<dt>【ご利用店舗】</dt>\n<dd>札幌店</dd>\n</div>\n<div>\n<dt>【通い始めて】</dt>\n<dd>5ヵ月目</dd>\n</div>\n<div>\n<dt>【スコア】</dt>\n<dd>105→97</dd>\n</div>\n\n</dl>\n</div><!-- /.bl_postVoices_info -->\n\n<div class=\"bl_postVoices_impressions\">\n<h2 class=\"bl_postVoices_lv2Heading\">お客様の感想</h2>\n\n<p>通い始めて5ヵ月目、スコア105→97！<br />\nゴルフを始めて約3年、100切りの壁を感じているとき、SNSでチキンゴルフの広告をみて、まず入ってみようという軽い気持ちで店舗へ足を運びました。<br />\n試しに1級打つと自分の悪い癖を見事に言い当てられ、どうして悪いのかもその場で教えて頂き、入会する決め手にもなりました。<br />\nレッスンでは基礎的なグリップ・スイング軌道を教わり、どんどん上手になるのが実感できました。<br />\n初めて100を切った日はバーディ2回連続、パーも4回出せたのには、本当に自分でもびっくりしましたし、チキンゴルフでの練習の成果が出たラウンドだったのでとても嬉しかったです。<br />\nこれからも上手くなるように精進します。</p>\n</div><!-- /.bl_postVoices_impressions -->\n\n</div><!-- /.bl_postVoices -->\n\n<div class=\"bl_pager\">\n<ul class=\"bl_pager_inner\">\n<li class=\"bl_pager_link bl_pager_prev\"><a href=\"https://chicken-golf.com/voices/customer44/\" rel=\"prev\">前の記事へ</a></li>\n<li class=\"bl_pager_link bl_pager_next\"><a href=\"https://chicken-golf.com/voices/customer46/\" rel=\"next\">次の記事へ</a></li>\n</ul>\n</div><!-- /.bl_pager -->\n</div><!-- /.ly_cont_main -->\n\n<aside class=\"ly_cont_side\">\n\n<div class=\"bl_aside_item recentPosts\">\n<p class=\"bl_mainTtl\">最新の声</p>\n<ol class=\"bl_aside_recentPosts_list\">\n<li><a href=\"https://chicken-golf.com/voices/customer46/\">大平&nbsp;様</a></li>\n<li><a href=\"https://chicken-golf.com/voices/customer45/\">小原&nbsp;様</a></li>\n<li><a href=\"https://chicken-golf.com/voices/customer44/\">中村&nbsp;様</a></li>\n<li><a href=\"https://chicken-golf.com/voices/customer43/\">谷内&nbsp;様</a></li>\n<li><a href=\"https://chicken-golf.com/voices/customer42/\">阪口&nbsp;様</a></li>\n</ol>\n<a class=\"el_btn el_moreBtn\" href=\"https://chicken-golf.com/voices/\">一覧へ</a>\n\n</div><!-- /.bl_aside_recentPosts -->\n\n</aside>\n\n</div><!-- /.ly_cont -->\n\n</div><!-- /.ly_cont_inner -->\n</section>\n</article>\n\n</main>\n<footer class=\"ly_foot\">\n<div class=\"ly_foot_inner\">\n\n<div class=\"bl_foot__left\">\n<h1 class=\"bl_foot_logo\"><a href=\"https://chicken-golf.com/\" class=\"hp_opacity1\"><img src=\"https://chicken-golf.com/wp-content/themes/asobi_lab/images/common/footer_logo.svg\" alt=\"Chicken Golf\"></a></h1>\n<a href=\"https://aura-mico.jp/qr-codes/7a11f930c288367027c4399b92f87b6e/preview \" target=\"_blank\" class=\"bl_foot__line\"><img src=\"https://chicken-golf.com/wp-content/themes/asobi_lab/images/common/footer_bnr_line.png\" alt=\"LINE予約！\"></a>\n</div>\n<!-- /.bl_foot__left -->\n\n<div class=\"bl_foot__right\">\n<nav class=\"bl_foot_gloNav\">\n<ul class=\"bl_foot_gloNav_inner\">\n<li class=\"top\"><a href=\"https://chicken-golf.com/\">HOME</a></li>\n<li class=\"about\"><a href=\"https://chicken-golf.com/about/\">チキンゴルフの魅力</a></li>\n<li class=\"lesson\"><a href=\"https://chicken-golf.com/lesson/\">レッスン内容</a></li>\n<li class=\"price\"><a href=\"https://chicken-golf.com/price/\">料金</a></li>\n<li class=\"schools\"><a href=\"https://chicken-golf.com/schools/\">店舗一覧</a></li>\n<li class=\"voices\"><a href=\"https://chicken-golf.c