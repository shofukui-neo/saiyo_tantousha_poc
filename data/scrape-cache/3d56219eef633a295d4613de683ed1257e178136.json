{"url":"https://persol-hrpartners.co.jp/recruit/mywayv/","html":"<!DOCTYPE html>\r\n<html lang=\"ja\">\r\n<head>\r\n<!-- Google Tag Manager --> \r\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\r\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\r\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\r\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\r\n})(window,document,'script','dataLayer','GTM-NTKXXD3');</script> \r\n<!-- End Google Tag Manager -->\r\n<meta charset=\"UTF-8\"/>\r\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"/>\r\n<title>パーソルエクセルHRパートナーズ｜プロジェクト選択型エンジニア</title>\r\n<meta name=\"description\" content=\"パーソルエクセルHRパートナーズ\"/>\r\n<meta name=\"keywords\" content=\"パーソルエクセルHRパートナーズ、ICTec、エンジニア、無期雇用、派遣、転職、技術、IT\"/>\r\n<meta name=\"format-detection\" content=\"telephone=no\"/>\r\n<meta property=\"og:type\" content=\"article\"/>\r\n<meta property=\"og:title\" content=\"パーソルエクセルHRパートナーズ｜プロジェクト選択型エンジニア\"/>\r\n<meta property=\"og:description\" content=\"\"/>\r\n<meta property=\"og:url\" content=\"https://persol-hrpartners.co.jp/tech/lp/ictec/\"/>\r\n<meta property=\"og:image\" content=\"\"/>\r\n<meta property=\"og:image:alt\" content=\"\"/>\r\n<meta property=\"og:locale\" content=\"ja_JP\"/>\r\n<meta name=\"twitter:card\" content=\"summary\"/>\r\n<script type=\"application/ld+json\">{\r\n\t\"@context\": \"https://schema.org\",\r\n\t\"@type\": \"BreadcrumbList\",\r\n\t\"itemListElement\": [{\r\n\t\t\"@type\": \"ListItem\",\r\n\t\t\"position\": 1,\r\n\t\t\"name\": \"HOME\",\r\n\t\t\"item\": \"https://example.com/\"\r\n\t\t}]\r\n\t}\r\n    </script>\r\n<meta name=\"theme-color\" content=\"#ffffff\"/>\r\n\r\n<!-- css -->\r\n<link href=\"assets/css/common.css\" rel=\"stylesheet\"/>\r\n<link href=\"assets/css/index.css\" rel=\"stylesheet\"/>\r\n<link href=\"assets/css/accodion.css\" rel=\"stylesheet\"/>\r\n\r\n<!-- font -->\r\n<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\"/>\r\n<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin/>\r\n</head>\r\n<body class=\"preload\">\r\n<!-- Google Tag Manager (noscript) -->\r\n<noscript>\r\n<iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-NTKXXD3\"\r\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe>\r\n</noscript>\r\n<!-- End Google Tag Manager (noscript) -->\r\n\r\n<div id=\"app\">\r\n  <div class=\"lContainer\">\r\n    <header class=\"lHeader\">\r\n      <div class=\"lHeader__inner\" aria-hidden=\"true\" data-header-top>\r\n        <h1 class=\"lHeader__logo\"><a href=\"https://persol-hrpartners.co.jp/\" target=\"_blank\" rel=\"noopener noreferrer\">\r\n          <picture>\r\n            <source type=\"image/svg+xml\" srcset=\"assets/img/header-logo-pc.svg\" media=\"(min-width: 768px)\"/>\r\n            <source type=\"image/svg+xml\" srcset=\"assets/img/header-logo.svg\"/>\r\n            <img src=\"assets/img/header-logo-pc.svg\" width=\"280\" height=\"27\" alt=\"パーソルエクセルHRパートナーズ\" decoding=\"async\"/> </picture>\r\n          </a> </h1>\r\n      </div>\r\n      <button class=\"lHeader__open js-menu-open\" type=\"button\" aria-label=\"メニューを開く\" data-menu-open><span class=\"icon\"><span class=\"line\"></span> <span class=\"line\"></span></span></button>\r\n    </header>\r\n    <main class=\"lMain\">\r\n      <div class=\"pFv\">\r\n        <div class=\"pFv__maincopy\">\r\n          <picture>\r\n            <source media=\"(min-width: 768px)\" srcset=\"assets/img/fv-maincopy-pc.png, assets/img/fv-maincopy-pc@2x.png 2x\"/>\r\n            <img src=\"assets/img/fv-maincopy.png\" srcset=\"assets/img/fv-maincopy@2x.png 2x\" width=\"275\" height=\"91\" alt=\"最先端の仕事をして、最先端を日常にする\" decoding=\"async\"/></picture>\r\n        </div>\r\n        <div class=\"pFv__subcopy\">\r\n          <p>プロジェクト選択型エンジニア<br class=\"br--sp\"/>\r\n            募集サイト</p>\r\n        </div>\r\n      </div>\r\n      <section id=\"overview\">\r\n        <div class=\"pMessage\">\r\n          <div class=\"pMessage__inner\">\r\n            <div class=\"pMessageHeadline\"><span class=\"en\">Overview</span>\r\n              <h2 class=\"ja\">エンジニアファースト</h2>\r\n            </div>\r\n            <div class=\"pMessage__text\">\r\n              <div class=\"pMessage__box js-scroll-target\">\r\n                <div class=\"pMessage__box_text\">当社は「エンジニアファースト」を<br>\r\n                  選択した未来で<br class=\"br--sp\"/>\r\n                  市場価値を高める事と定義</div>\r\n              </div>\r\n              <div class=\"pMessage__box js-scroll-target\">\r\n                <div class=\"pMessage__box_text\">1,000を超えるプロジェクトから<br class=\"br--sp\"/>\r\n                  配属先を選び<br>\r\n                  未来を期待するキャリアパスを<br class=\"br--sp\"/>\r\n                  選べるからこそ<br>\r\n                  あなたが望む市場価値を高められます</div>\r\n              </div>\r\n              <div class=\"pMessage__box js-scroll-target\">\r\n                <div class=\"pMessage__box_text\">一流企業で最先端技術と共に、<br class=\"br--sp\"/>\r\n                  さらなる高みを目指しませんか？</div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </section>\r\n      <div class=\"pSpace\"> </div>\r\n      <div class=\"pRealize\">\r\n        <div class=\"pRealize__inner\">\r\n          <h2 class=\"pRealizeHeadline\">当社で<br class=\"br--sp\">\r\n            実現できること</h2>\r\n        </div>\r\n        <div class=\"pRealize__container\">\r\n          <div class=\"pRealize__item01\">\r\n            <div class=\"pRealize__imagecontainer\"></div>\r\n            <div class=\"pRealize__textcontainer_01\">\r\n              <div class=\"pRealize__textbox\">\r\n                <p class=\"pRealize__text_title\">自分の仕事を自分で選ぶ</p>\r\n                <p class=\"pRealize__text\">パナソニックグループや大手システム開発会社、注目のベンチャー企業など1,000件以上の選択肢から、あなたが目指すキャリアに最適なプロジェクトを選んで働くことができます。</p>\r\n              </div>\r\n            </div>\r\n          </div>\r\n          <div class=\"pRealize__item02\">\r\n            <div class=\"pRealize__imagecontainer\"></div>\r\n            <div class=\"pRealize__textcontainer_02\">\r\n              <div class=\"pRealize__textbox\">\r\n                <p class=\"pRealize__text_title\">転居を伴う転勤なし</p>\r\n                <p class=\"pRealize__text\">充実したエンジニアライフを実現するには、生活基盤が安定していることが大切です。</p>\r\n              </div>\r\n            </div>\r\n          </div>\r\n          <div class=\"pRealize__item03\">\r\n            <div class=\"pRealize__imagecontainer\"></div>\r\n            <div class=\"pRealize__textcontainer_03\">\r\n              <div class=\"pRealize__textbox\">\r\n                <p class=\"pRealize__text_title\">最先端技術に携わる</p>\r\n                <p class=\"pRealize__text\">AIやクラウド・研究開発といった多数の技術分野で、企画・管理職から技術のスペシャリストまで幅広いポジションをご用意。</p>\r\n                <p class=\"pRealize__text\">ひとつの技術を突き詰めることも、トレンドを渡り歩くこともあなた次第です。</p>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n      <section id=\"about\">\r\n        <div class=\"pAbout\">\r\n          <div class=\"pAboutHeadline\"><span class=\"en\">About</span>\r\n            <h2 class=\"ja\">プロジェクト選択型<br/>\r\n              エンジニアとは</h2>\r\n          </div>\r\n          <div class=\"pAbout__wrap\">\r\n            <div class=\"pAbout__inner js-scroll-target\">\r\n              <div class=\"pAbout__container\">\r\n                <p class=\"pAbout__text\">一人ひとりの市場価値を高めるプロジェクト選択型エンジニアという、新しい技術職の働き方。</p>\r\n                <ul class=\"pAbout__list\">\r\n                  <li class=\"pAbout__item\">\r\n                    <div class=\"checkbox\"></div>\r\n                    未来を創る千を超える、<br class=\"br--tab\"/>\r\n                    選べるプロジェクト</li>\r\n                  <li class=\"pAbout__item\">\r\n                    <div class=\"checkbox\"></div>\r\n                    はたらく理想を叶える、<br class=\"br--tab\"/>\r\n                    選べるキャリアパス</li>\r\n                  <li class=\"pAbout__item\">\r\n                    <div class=\"checkbox\"></div>\r\n                    仕事を好きでいられる<br class=\"br--tab\"/>\r\n                    ワークライフバランス</li>\r\n                  <li class=\"pAbout__item\">\r\n                    <div class=\"checkbox\"></div>\r\n                    15年連続業績UPを実現した<br class=\"br--tab\"/>\r\n                    盤石な経営基盤</li>\r\n                </ul>\r\n              </div>\r\n              <div class=\"pExample\">\r\n                <ul class=\"pExample__list\">\r\n                  <li class=\"pExample__item\">\r\n                    <div class=\"pCard\">\r\n                      <div class=\"en\">Selectable<br class=\"br--pc\"/>\r\n                        Projects</div>\r\n                      <h4 class=\"ja\">選べる<br class=\"br--pc\"/>\r\n                        プロジェクト</h4>\r\n                      <p class=\"pCard__text__check\">最先端・プライム・リモート・上流工程</p>\r\n                      <p class=\"pCard__text__check\">全国で1,000を超える選べるプロジェクト</p>\r\n                      <p class=\"pCard__text__check\">一流企業の技術者たちと働ける環境(FB有)</p>\r\n                      <p class=\"pCard__text__check\">就業後は当社の社員2名のフルサポート体制</p>\r\n                    </div>\r\n                  </li>\r\n                  <li class=\"pExample__item\">\r\n                    <div class=\"pCard\">\r\n                      <div class=\"en\">1Selectable<br class=\"br--pc\"/>\r\n                        Carriers</div>\r\n                      <h4 class=\"ja\">選べる<br class=\"br--pc\"/>\r\n                        キャリアパス</h4>\r\n                      <p class=\"pCard__text__check\">1つの勤務先でワークライフバランスを重視</p>\r\n                      <p class=\"pCard__text__check\">プロジェクトを渡り歩きモダンな技術を習得</p>\r\n                      <p class=\"pCard__text__check\">尖った技術を現場で更に磨いてレベルアップ</p>\r\n                      <p class=\"pCard__text__check\">上流工程／マネジメントなどステップアップ</p>\r\n                    </div>\r\n                  </li>\r\n                  <li class=\"pExample__item\">\r\n                    <div class=\"pCard\">\r\n                      <div class=\"en\">Work Life<br class=\"br--pc\"/>\r\n                        Balance</div>\r\n                      <h4 class=\"ja\">ワークライフ<br class=\"br--pc\"/>\r\n                        バランス</h4>\r\n                      <p class=\"pCard__text__check\">残業月20時間以下でリモート併用も可能</p>\r\n                      <p class=\"pCard__text__check\">業界屈指の福利厚生パナソニック健康保険</p>\r\n                      <p class=\"pCard__text__check\">年間休日125日で完全週休2日制（土日祝）</p>\r\n                    </div>\r\n                  </li>\r\n                  <li class=\"pExample__item\">\r\n                    <div class=\"pCard\">\r\n                      <div class=\"en\">Solid<br class=\"br--pc\"/>\r\n                        Foundation</div>\r\n                      <h4 class=\"ja\">盤石な<br class=\"br--pc\"/>\r\n                        経営基盤</h4>\r\n                      <p class=\"pCard__text__check\">20-30代の入社時年収100%アップ実績</p>\r\n                      <p class=\"pCard__text__check\">パナソニックグループとの資本関係あり</p>\r\n                      <p class=\"pCard__text__check\">15年連続で業績UPを実現してきた実績</p>\r\n                    </div>\r\n                  </li>\r\n                </ul>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </section>\r\n      <section id=\"project\">\r\n        <div id=\"faq\" class=\"pProject js-scroll-target\">\r\n          <div class=\"pProject__inner\">\r\n            <div class=\"pProjectHeadline\"><span class=\"en\">Projects &amp; Clients</span>\r\n              <h2 class=\"ja\">プロジェクト例</h2>\r\n            </div>\r\n            <ul class=\"pProject__entry_list\">\r\n              <li class=\"pProject__entry_item\">\r\n                <div class=\"pProject__entry_item_image\">\r\n                  <picture>\r\n                    <source media=\"(min-width: 768px)\" srcset=\"assets/img/support-menu01-pc.png\"/>\r\n                    <img src=\"assets/img/support-menu01.png\" width=\"84\" height=\"63\" alt=\"\" decoding=\"async\" loading=\"lazy\"/></picture>\r\n                </div>\r\n                <span class=\"pProject__entry_item_menu\">最先端技術</span></li>\r\n              <li class=\"pProject__entry_item\">\r\n                <div class=\"pProject__entry_item_image\">\r\n                  <picture>\r\n                    <source media=\"(min-width: 768px)\" srcset=\"assets/img/support-menu02-pc.png\"/>\r\n                    <img src=\"assets/img/support-menu02.png\" width=\"84\" height=\"63\" alt=\"\" decoding=\"async\" loading=\"lazy\"/></picture>\r\n                </div>\r\n                <span class=\"pProject__entry_item_menu\">スペシャリスト&nbsp;</span></li>\r\n              <li class=\"pProject__entry_item\">\r\n                <div class=\"pProject__entry_item_image\">\r\n                  <picture>\r\n                    <source media=\"(min-width: 768px)\" srcset=\"assets/img/support-menu03-pc.png\"/>\r\n                    <img src=\"assets/img/support-menu03.png\" width=\"84\" height=\"63\" alt=\"\" decoding=\"async\" loading=\"lazy\"/></picture>\r\n                </div>\r\n                <span class=\"pProject__entry_item_menu\">上流工程</span></li>\r\n              <li class=\"pProject__entry_item\">\r\n                <div class=\"pProject__entry_item_image\">\r\n                  <picture>\r\n                    <source media=\"(min-width: 768px)\" srcset=\"assets/img/support-menu04-pc.png\"/>\r\n                    <img src=\"assets/img/support-menu04.png\" width=\"84\" height=\"63\" alt=\"\" decoding=\"async\" loading=\"lazy\"/></picture>\r\n                </div>\r\n                <span class=\"pProject__entry_item_menu\">マネジメント</span></li>\r\n            </ul>\r\n          </div>\r\n          <div id=\"support\" class=\"pProject js-scroll-target\">\r\n            <div class=\"pProject__inner\">\r\n              <div class=\"pProject__employment\"><span class=\"pProject__employment_title\">配属先例</span>\r\n                <div class=\"pProject__employment_text\">大手企業・最先端を中心とした<span>1,000以上の配属先</span>からあなたが選択。<br/>\r\n                  入社後も<span>あなたのキャリアプラン</span>に併せて柔軟に<span>配属先を変更</span>することも可能です。</div>\r\n                <ul class=\"pProject__employment_summary_list\">\r\n                  <li class=\"pProject__employment_summary_item_title\">プログラマー・システムエンジニア</li>\r\n                  <li class=\"pProject__employment_summary_item\">パナソニックホールディングス各社・株式会社ラクス・Sky株式会社・株式会社日立ソリューションズ・NSW株式会社・応用技術株式会社・クリエイト株式会社・ネットワンシステムズ株式会社・TIS株式会社・サイバーコム株式会社・ほか（順不同）</li>\r\n                </ul>\r\n                <ul class=\"pProject__employment_summary_list\">\r\n                  <li class=\"pProject__employment_summary_item_title\">サーバー・ネットワークエンジニア</li>\r\n                  <li class=\"pProject__employment_summary_item\">伊藤忠テクノソリューションズ株式会社・楽天グループ各社・LINE株式会社・GMOフィナンシャルグループ各社・ネットワンシステムズ株式会社・株式会社インターネットイニシアティブ・株式会社ＤＴＳ・ＫＤＤＩ株式会社・株式会社NTTデータ関西・三菱電機インフォメーションネットワーク株式会社・西日本高速道路株式会社・SCSK株式会社・ほか（順不同）</li>\r\n                </ul>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </section>\r\n      <section id=\"carrier\">\r\n        <div id=\"faq2\" class=\"pCarrier js-scroll-target\">\r\n          <div class=\"pCarrier__inner\">\r\n            <div class=\"pCarrierHeadline\"><span class=\"en\">Carrier</span>\r\n              <h2 class=\"ja\">キャリアアップ事例</h2>\r\n            </div>\r\n            <div class=\"pCarrier__accordion js-accordion\">\r\n              <button class=\"pCarrier__question js-accordion-trigger\" type=\"button\"><span class=\"title\"><span class=\"text\">ステップを積んでシステム設計者へ</span> </span><span class=\"BTN_CARRIER_openPG arrow\"><span class=\"arrow__answer--pc\">OPEN</span></span></button>\r\n              <div class=\"pCarrier__answer js-accordion-target\">\r\n                <div class=\"contents\">\r\n                  <div class=\"textbox\">\r\n                    <h3 class=\"se\">System Engnieer</h3>\r\n                    <h4>基幹システム運用・改修経験1.5年</h4>\r\n                    <picture>\r\n                      <source media=\"(min-width: 768px)\" srcset=\"assets/img/car_se-pc.jpg, assets/img/car_se-pc.jpg\"/>\r\n                      <img src=\"assets/img/car_se.jpg\" srcset=\"assets/img/car_se.jpg\" width=\"375\" height=\"180\" alt=\"\" decoding=\"async\" loading=\"lazy\"/></picture>\r\n                    <p class=\"ques se\">転職の動機</p>\r\n                    <p class=\"answ\">設備メーカーで基幹系システムの機能追加や障害対応をしていました。自分が開発している機能以外は何もわからないことも多かったので、システム全体を考えながら開発できる環境に憧れていました。</p>\r\n                    <div class=\"line-between\"></div>\r\n                    <p class=\"ques se\">プロジェクト選択型エンジニアを選んだ理由</p>\r\n                    <p class=\"answ\">まずは開発、次は設計…とステップを細かく刻みながら成長できる点です。ゴールは設計ができるエンジニアという思いはありましたが、まずは1年間でTypeScriptの開発案件でトレンドを学ぶというプランも選択できたことが決め手でした。</p>\r\n                    <div class=\"line-between\"></div>\r\n                    <p class=\"ques se\">今後の目標</p>\r\n                    <p class=\"answ\">大手SIerでSE補佐業務として要件定義同席やベンダーコントロールを経験したことでエンジニアとしてのキャリアが明確になりました。今後は新規開発での要件定義や業務分析にも対応できるように、経験したことのない業界や開発現場を選び、知識の幅やスキルを高めたいと思っています。</p>\r\n                  </div>\r\n                  <button class=\"closeButton js-accordion-trigger\">Close</button>\r\n                </div>\r\n              </div>\r\n            </div>\r\n            <div class=\"pCarrier__accordion js-accordion\">\r\n              <button class=\"pCarrier__question js-accordion-trigger\" type=\"button\"><span class=\"title\"><span class=\"text\">テスト環境構築からクラウドエンジニアへ</span> </span><span class=\"BTN_CARRIER_openNW arrow\"><span class=\"arrow__answer--pc\">OPEN</span></span></button>\r\n              <div class=\"pCarrier__answer js-accordion-target\">\r\n                <div class=\"contents\">\r\n                  <div class=\"textbox\">\r\n                    <h3 class=\"nw\">Server Engnieer</h3>\r\n                    <h4>金融系Windowsサーバ保守経験2年</h4>\r\n                    <picture>\r\n                      <source media=\"(min-width: 768px)\" srcset=\"assets/img/car_nw-pc.jpg, assets/img/car_nw-pc.jpg\"/>\r\n                      <img src=\"assets/img/car_nw.jpg\" srcset=\"assets/img/car_nw.jpg\" width=\"375\" height=\"180\" alt=\"\" decoding=\"async\" loading=\"lazy\"/></picture>\r\n                    <p class=\"ques nw\">転職の動機</p>\r\n                    <p class=\"answ\">大手SIerからの受託で銀行のサーバ保守業務を担当していました。システム更改時期に小規模なサーバ構築を行ったことがきっかけで、構築にキャリアチェンジしたいと思ったことがきっかけです</p>\r\n                    <div class=\"line-between\"></div>\r\n                    <p class=\"ques nw\">プロジェクト選択型エンジニアを選んだ理由</p>\r\n                    <p class=\"answ\">第一歩に相応しいプロジェクトや環境を自分で選べた点です。最初に選んだのは、学習用の検証ルームに様々なメーカーの機材やソフトが準備されており自由に使うことができるという配属先でした。就業環境も事前にわかりるので満足のいく選択ができると思います。</p>\r\n                    <div class=\"line-between\"></div>\r\n                    <p class=\"ques nw\">今後の目標</p>\r\n                    <p class=\"answ\">いろいろなチャレンジができる環境を活かして、将来はAWSやAzuru等の最新のクラウド環境で設計から構築までできるエンジニアになりたいです。</p>\r\n                  </div>\r\n                  <button class=\"closeButton\">Close</button>\r\n                </div>\r\n              </div>\r\n            </div>\r\n            <div class=\"pCarrier__accordion--line\"></div>\r\n          </div>\r\n        </div>\r\n      </section>\r\n      <section id=\"job\">\r\n        <div id=\"job-description\" class=\"pJob js-scroll-target\">\r\n          <div class=\"pJob__inner\">\r\n            <div class=\"pJobHeadline\"><span class=\"en\">Job description</span>\r\n              <h2 class=\"ja\">募集要項</h2>\r\n            </div>\r\n            <div class=\"l-inner_sm\">\r\n              <div class=\"pRecruit__body\">\r\n                <table>\r\n                  <tbody>\r\n                    <tr>\r\n                      <th>雇用形態</th>\r\n                      <td>正社員<br class=\"br--sp\">\r\n                        ※プロジェクト選択型エンジニア</td>\r\n                    </tr>\r\n                    <tr>\r\n                      <th>給与</th>\r\n                      <td>年収400万円～700万円<br class=\"br--sp\">\r\n                        （月給＋賞与年２回＋諸手当）</td>\r\n                    </tr>\r\n                    <tr>\r\n                      <th>休日休暇</th>\r\n                      <td>年間休日125日<br>\r\n                        ※完全週休2日制（土日祝）<br>\r\n                        ※就業先によって異なる</td>\r\n                    </tr>\r\n                    <tr>\r\n                      <th>勤務地</th>\r\n                      <td>関東・関西・中部・九州<br>\r\n                        ※原則、転居を伴う転勤なし<br>\r\n                        ※在宅併用勤務可<br></td>\r\n                    </tr>\r\n                    <tr>\r\n                      <th>対象となる方</th>\r\n                      <td>言語問わずシステム開発経験をお持ちの方<br>\r\n                        サーバーまたはネットワーク構築経験をお持ちの方</td>\r\n                    </tr>\r\n                  </tbody>\r\n                </table>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </section>\r\n      <section id=\"flow\">\r\n        <div class=\"pFlow\">\r\n          <div class=\"pFlowHeadline\"><span class=\"en\">Flow</span>\r\n            <h2 class=\"ja\">就業開始までの流れ</h2>\r\n          </div>\r\n          <div class=\"pFlow__wrap\">\r\n            <div class=\"pFlow__inner js-scroll-target\">\r\n              <div class=\"pFlow__list\">\r\n                <div class=\"pFlow__item pFlow__item01\">\r\n                  <div class=\"pFlow__numberBox\"><span class=\"step\">Step</span> <span class=\"number\">01</span></div>\r\n                  <div class=\"pFlow__item_text\"><span class=\"pFlow__item_title\">応募</span> <span class=\"pFlow__item_subtitle\">（書類選考）</span></div>\r\n                  <div class=\"pFlow__item_image\">\r\n                    <picture>\r\n                      <source media=\"(min-width: 768px)\" srcset=\"assets/img/flow-step-01-pc.png, assets/img/flow-step-01-pc@2x.png 2x\"/>\r\n                      <img src=\"assets/img/flow-step-01.png\" srcset=\"assets/img/flow-step-01@2x.png 2x\" width=\"50\" height=\"50\" alt=\"\" decoding=\"async\" loading=\"lazy\"/></picture>\r\n                  </div>\r\n                </div>\r\n                <div class=\"line--sp\">\r\n                  <picture>\r\n                    <source media=\"(min-width: 768px)\" srcset=\"assets/img/flow-line-pc.png, assets/img/flow-line-pc@2x.png 2x\"/>\r\n                    <img src=\"assets/img/flow-line.png\" srcset=\"assets/img/flow-line@2x.png 2x\" width=\"5\" height=\"18\" alt=\"\" decoding=\"async\" loading=\"lazy\"/></picture>\r\n                </div>\r\n                <div class=\"pFlow__item pFlow__item02\">\r\n                  <div class=\"pFlow__numberBox\"><span class=\"step\">Step</span> <span class=\"number\">02</span></div>\r\n                  <div class=\"pFlow__item_text\"><span class=\"pFlow__item_title\">面接・適性検査</span> <span class=\"pFlow__item_subtitle\">（Web面接 ※原則1回）</span></div>\r\n                  <div class=\"pFlow__item_image\">\r\n                    <picture>\r\n                      <source media=\"(min-width: 768px)\" srcset=\"assets/img/flow-step-02-pc.png, assets/img/flow-step-02-pc@2x.png 2x\"/>\r\n                      <img src=\"assets/img/flow-step-02.png\" srcset=\"assets/img/flow-step-02@2x.png 2x\" width=\"50\" height=\"50\" alt=\"\" decoding=\"async\" loading=\"lazy\"/></picture>\r\n                  </div>\r\n                </div>\r\n                <div class=\"line--sp\">\r\n                  <picture>\r\n                    <source media=\"(min-width: 768px)\" srcset=\"assets/img/flow-line-pc.png, assets/img/flow-line-pc@2x.png 2x\"/>\r\n                    <img src=\"assets/img/flow-line.png\" srcset=\"assets/img/flow-line@2x.png 2x\" width=\"5\" height=\"18\" alt=\"\" decoding=\"async\" loading=\"lazy\"/></picture>\r\n                </div>\r\n                <div class=\"pFlow__item pFlow__item03\">\r\n                  <div class=\"pFlow__numberBox\"><span class=\"step\">Step</span> <span class=\"number\">03</span></div>\r\n                  <div class=\"pFlow__item_text\"><span class=\"pFlow__item_title\">内定</span></div>\r\n                  <div class=\"pFlow__item_image\">\r\n                    <picture>\r\n                      <source media=\"(min-width: 768px)\" srcset=\"assets/img/flow-step-03-pc.png, assets/img/flow-step-03-pc@2x.png 2x\"/>\r\n                      <img src=\"assets/img/flow-step-03.png\" srcset=\"assets/img/flow-step-03@2x.png 2x\" width=\"65\" height=\"44\" alt=\"\" decoding=\"async\" loading=\"lazy\"/></picture>\r\n                  </div>\r\n                </div>\r\n                <div class=\"line--sp\">\r\n                  <picture>\r\n                    <source media=\"(min-width: 768px)\" srcset=\"assets/img/flow-line-pc.png, assets/img/flow-line-pc@2x.png 2x\"/>\r\n                    <img src=\"assets/img/flow-line.png\" srcset=\"assets/img/flow-line@2x.png 2x\" width=\"5\" height=\"18\" alt=\"\" decoding=\"async\" loading=\"lazy\"/></picture>\r\n                </div>\r\n                <div class=\"pFlow__item pFlow__item04\">\r\n                  <div class=\"pFlow__numberBox\"><span class=\"step\">Step</span> <span class=\"number\">04</span></div>\r\n                  <div class=\"pFlow__item_text\"><span class=\"pFlow__item_title\">プロジェクト配属<br/>\r\n                    就業開始</span></div>\r\n                  <div class=\"pFlow__item_image\">\r\n                    <picture>\r\n                      <source media=\"(min-width: 768px)\" srcset=\"assets/img/flow-step-04-pc.png, assets/img/flow-step-04-pc@2x.png 2x\"/>\r\n                      <img src=\"assets/img/flow-step-04.png\" srcset=\"assets/img/flow-step-04@2x.png 2x\" width=\"50\" height=\"50\" alt=\"\" decoding=\"async\" loading=\"lazy\"/></picture>\r\n                  </div>\r\n                </div>\r\n              </div>\r\n            </div>\r\n            <div class=\"pFlow__entry_text\">※面接日時、入社日はご相談に応じます<br/>\r\n              ※カジュアル面談があります。お気軽に不明点やキャリア展望をご相談ください</div>\r\n          </div>\r\n        </div>\r\n      </section>\r\n      <section id=\"contents\" class=\"contents\">\r\n        <div class=\"pContents\