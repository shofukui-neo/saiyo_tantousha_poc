        </li>\r\n                <li class=\"pContents__entry_item\">\r\n                  <div class=\"pContents__entry_item_image btn-content\"> <a href=\"https://www.tiktok.com/@persol_excel_hr2\" class=\"BTN_CONTENTS_ARUARU\" target=\"_blank\">\r\n                    <picture>\r\n                      <source srcset=\"assets/img/contents/bg_03.png\" media=\"(min-width: 768px)\" type=\"image/png\">\r\n                      <img src=\"assets/img/contents/bg_03-sp.png\" alt=\"エンジニアあるある\"> </picture>\r\n                    </a> </div>\r\n                </li>\r\n              </ul>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </section>\r\n      <div class=\"lFooterbottun\">\r\n        <div class=\"row\">\r\n          <div class=\"column\"> <a href=\"https://persol-hrpartners.co.jp/\" target=\"_blank\" class=\"BTN_COMPANY_BOTTOM\">\r\n            <div class=\"box\">\r\n              <div class=\"lFooterbottun__title\">\r\n                <div class=\"lFooterbottun__title_en\">Company</div>\r\n                <div class=\"lFooterbottun__title_ja\">パーソルエクセルHRパートナーズ トップ</div>\r\n              </div>\r\n            </div>\r\n            </a> </div>\r\n          <div class=\"column order-1\"> <a href=\"https://group.tempstaff.co.jp/wcform/pub/pphr_ex/1061802322292dc1202t\" target=\"_blank\" class=\"BTN_ENTRY_BOTTOM\">\r\n            <div class=\"box\">\r\n              <div class=\"lFooterbottun__title\">\r\n                <div class=\"lFooterbottun__title_en\">Entry</div>\r\n                <div class=\"lFooterbottun__title_ja\">プロジェクト選択型エンジニア<br class=\"only-sp\">\r\n                  エントリーフォーム</div>\r\n              </div>\r\n            </div>\r\n            </a> </div>\r\n        </div>\r\n      </div>\r\n      <section id=\"security\">\r\n        <div class=\"pSecurity\">\r\n          <div class=\"pSecurity_row\"> <a href=\"https://persol-hrpartners.co.jp/info/policy.html\" class=\"pSecurity_col\" target=\"_blank\">サイトのご利用にあたって</a> <a href=