{"url":"https://www.shinnihon-c.co.jp/recruit/work.php","html":"<!DOCTYPE html>\r\n<html lang=\"ja\">\r\n<head>\r\n    <script>\r\n        (function(w, d, s, l, i) {\r\n            w[l] = w[l] || [];\r\n            w[l].push({\r\n                'gtm.start': new Date().getTime(),\r\n                event: 'gtm.js'\r\n            });\r\n            var f = d.getElementsByTagName(s)[0],\r\n                j = d.createElement(s),\r\n                dl = l != 'dataLayer' ? '&l=' + l : '';\r\n            j.async = true;\r\n            j.src =\r\n                'https://www.googletagmanager.com/gtm.js?id=' + i + dl;\r\n            f.parentNode.insertBefore(j, f);\r\n        })(window, document, 'script', 'dataLayer', 'GTM-P4FJ3WL');\r\n    </script>\r\n    <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\" />\r\n    <meta name=\"viewport\" content=\"width=device-width\">\r\n    <meta http-equiv=\"Content-Type\" content=\"text/html; charset=utf-8\">\r\n    <meta http-equiv=\"Content-Style-Type\" content=\"text/css\">\r\n    <meta http-equiv=\"Content-Script-Type\" content=\"text/javascript\">\r\n    <meta name=\"robots\" content=\"index,follow\">\r\n    <title>仕事を知る｜新日本建設株式会社 採用サイト</title>\r\n    <meta name=\"Description\" content=\"仕事を知る｜新日本建設株式会社 採用サイト\" />\r\n    <meta name=\"Keywords\" content=\"新日本建設株式会社,採用,新卒採用,中途採用,ゼネコン,建設事業,建築,開発,PC工法,土地の有効利用,分譲マンション,新日本建設\" />\r\n    <link rel=\"shortcut icon\" href=\"../../favicon.ico\" />\r\n    <link rel=\"stylesheet\" rev=\"stylesheet\" href=\"./css/common.css?ver=0117\" type=\"text/css\" media=\"screen,print\" />\r\n    <link rel=\"stylesheet\" rev=\"stylesheet\" href=\"./css/pc.css?ver=0221\" type=\"text/css\" media=\"screen,print\" />\r\n    <link rel=\"stylesheet\" rev=\"stylesheet\" href=\"./css/tab.css?ver=0217\" type=\"text/css\" media=\"screen and (max-width: 1100px)\" />\r\n    <link rel=\"stylesheet\" rev=\"stylesheet\" href=\"./css/sp.css?ver=0217\" type=\"text/css\" media=\"screen and (max-width: 767px)\" />\r\n    <link href=\"https://fonts.googleapis.com/icon?family=Material+Icons\" rel=\"stylesheet\">\r\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\">\r\n    <link href=\"https://fonts.googleapis.com/css2?family=Noto+Serif:ital,wght@0,400;0,700;1,400;1,700&display=swap\" rel=\"stylesheet\">\r\n    <link href=\"https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@200;300;400;500;600;700;900&display=swap\" rel=\"stylesheet\">\r\n    <script type=\"text/javascript\" src=\"https://code.jquery.com/jquery-2.2.3.min.js\"></script>\r\n    <script src=\"https://cdnjs.cloudflare.com/ajax/libs/moment.js/2.8.2/moment.min.js\"></script>\r\n    <script src=\"./js/cont.js?ver=0117\" type=\"text/javascript\"></script>\r\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"./lightbox/lightbox.min.css\">\r\n</head></head>\r\n<body class=\"work\">\r\n    <!-- Google Tag Manager (noscript) 20210406reci-->\r\n    <noscript>\r\n        <iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-P4FJ3WL\" height=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe>\r\n    </noscript>\r\n    <!-- End Google Tag Manager (noscript) --><div class=\"conw\">\r\n    <header class=\"hdPc\">\n    <div class=\"logo\"> \n        <a href=\"./\" class=\"eng\">\n            <img src=\"../common/img/common/logo.jpg\" alt=\"新日本建設株式会社\" /><br>\n            RECRUITING SITE\n        </a> \n    </div>\n    <div class=\"hd cf\">\n        <ul class=\"hdnav cf\">\n            <li class=\"ttl\">\n                募集要項<br>エントリー\n            </li>\n            <li class=\"btnEntry\">\n                <a href=\"https://job.axol.jp/bx/s/shinnihon-c_27/entry/\" target=\"_blank\">\n                    新卒採用（2027卒）<br>エントリーはこちら\n                </a>\n            </li>\n            <li class=\"btnEntry\">\n                <a href=\"https://axol.jp/zw/s/shinnihon-c_28/entry/\" target=\"_blank\">\n                    新卒採用（2028卒）<br>インターンシップは<br>こちら\n                </a>\n            </li>\n            <!-- <li class=\"btnMynavi\">\n                <a href=\"https://job.mynavi.jp/26/pc/search/corp54735/outline.html\" target=\"_blank\">\n                <img src=\"https://job.mynavi.jp/conts/kigyo/2026/logo/banner_logo_195_60.gif\" alt=\"マイナビ2026\" border=\"0\">\n                </a>\n            </li> --> \n            <li class=\"btnCareer\">\n                <a href=\"./career.php\">\n                    キャリア採用\n                </a>\n            </li>               \n        </ul>\n        <nav>\n            <ul class=\"gn cf\">\r\n    <li class=\"\">\r\n        <a href=\"./about.php\">\r\n            会社を知る\r\n        </a>\r\n    </li> \r\n    <li class=\"on\">\r\n        <a href=\"./work.php\">\r\n            仕事を知る\r\n        </a>\r\n    </li>\r\n    <li class=\"\">\r\n        <a href=\"./staff.php\">\r\n            社員を知る\r\n        </a>\r\n    </li>\r\n    <li class=\"\">\r\n        <a href=\"./qa.php\">\r\n            Q&A\r\n        </a>\r\n    </li>\r\n</ul>        </nav>\n    </div>\n</header>\n\n<header class=\"hdSp\">\n    <div class=\"logo cf\"> \n        <a href=\"./\" class=\"eng\">\n            <img src=\"../common/img/common/logo.jpg\" alt=\"新日本建設株式会社\" />\n            RECRUITING SITE\n        </a> \n    </div>\n    <div class=\"btnMenu\"> \n        <span></span> \n        <span></span> \n        <span></span> \n    </div>\n    <nav class=\"navCommon\">\n        <!--<p class=\"\">\n    <a href=\"./\">トップページ</a>\n</p>-->\n<div class=\"btn_entry\">\n    <a href=\"https://job.axol.jp/bx/s/shinnihon-c_27/entry/\" target=\"_blank\">\n        新卒採用（2027卒）<br>エントリーはこちら\n    </a>\n    <a href=\"https://axol.jp/zw/s/shinnihon-c_28/entry/\" target=\"_blank\">\n        新卒採用（2028卒）<br>インターンシップはこちら\n    </a>\n    <a href=\"https://job.mynavi.jp/27/pc/search/corp54735/outline.html\" class=\"bnr\" target=\"_blank\">\n    <img src=\"https://job.mynavi.jp/conts/kigyo/2027/logo/banner_logo_195_60.gif?\" alt=\"マイナビ2027\" border=\"0\">\n    </a>\n\t<a href=\"./career.php\">キャリア採用</a>\n</div>\n<ul class=\"cf\">\n    <li class=\"\">\n        <dl>\n            <dt class=\"\">\n                <a href=\"./about.php\">\n                    会社を知る\n                </a>\n            </dt>\n        </dl>\n    </li>\n\n    <li class=\"on\">\n        <dl>\n            <dt class=\"\">\n                <a href=\"./work.php\">\n                    仕事を知る\n                </a>\n            </dt>\n        </dl>\n    </li>\n    <li class=\"\">\n        <dl>\n            <dt class=\"\">\n                <a href=\"./staff.php\">\n                    社員を知る\n                </a>\n            </dt>\n        </dl>\n    </li>\n    <li class=\"\">\n        <dl>\n            <dt class=\"\">\n                <a href=\"./qa.php\">\n                    Q&A\n                </a>\n            </dt>\n        </dl>\n    </li>\n</ul>    </nav>\n</header>    <div class=\"secTitle\">\r\n        <div class=\"title mincho\">\r\n            <h1>\r\n                仕事を知る<br>\r\n                <small>「信頼」と「想い」の襷をつなぐ自社製販一貫体制</small>\r\n            </h1>\r\n        </div>\r\n        <div class=\"bgTitle bgTitlework\"></div>\r\n    </div>\r\n    <div class=\"con block mincho\">\r\n\r\n        <section class=\"sec01\">\r\n            <h2 class=\"ttl\">「信頼」と「想い」の襷をつなぐ自社製販一貫体制</h2>\r\n            <div class=\"boxWork step01\">\r\n                <div class=\"ttlWork\">\r\n                    <div class=\"ico\">\r\n                        <img src=\"./images/work/ico01.png\">\r\n                        <span>STEP.<strong>1</strong></span>\r\n                    </div>\r\n                    <p>建設営業・不動産開発営業（営業職）</p>\r\n                    \t<span class=\"btnOpen\"><span>\r\n                </div>\r\n                <article>\r\n\t\t\t\t\t<div class=\"detail\">\r\n                    <p class=\"img\">\r\n                        <img src=\"./images/work/img01.jpg\">\r\n                    </p>\r\n                    <div class=\"\">\r\n                        <p class=\"txt\">\r\n                            営業職が工事受注、用地仕入、土地活用の提案を行いプロジェクトが始まります。\r\n                        </p>\r\n                        <h4 class=\"ttl\">\r\n                            工事受注\r\n                        </h4>\r\n                        <p class=\"txt\">\r\n                            各クライアント企業様を訪問し、工事受注の営業活動を行います。大型商業施設やホテル・オフィスビル・工場・病院・大型物流倉庫など受注プロジェクトは多岐にわたります。\r\n                        </p>\r\n                        <h4 class=\"ttl\">\r\n                            用地仕入\r\n                        </h4>\r\n                        <p class=\"txt\">\r\n                            土地所有者を訪問し、土地購入の商談、土地の有効活用の提案などを行います。<br>\r\n                            土地の有効活用の提案では設計部や積算部、工事部など多くの部署と協力し合いながら、お客様の事を深く理解し、お客様が何を望んでいるのかを考え抜いた提案書を作成します。\r\n                        </p>\r\n                        <h4 class=\"ttl\">\r\n                            プロジェクト推進\r\n                        </h4>\r\n                        <p class=\"txt\">\r\n                            工事の受注後もお客様の事業を成功に導くため営業社員がリーダーシップを発揮し、社内・社外を動かしながら完成まで責任をもって活動していきます。\r\n                        </p>\r\n                    </div>\r\n\t\t\t\t\t</div>\r\n                </article>\r\n                <div class=\"schedule\">\r\n                    <h3>一日のスケジュール</h3>\r\n                    <p class=\"img\">\r\n                        <img src=\"./images/work/sche01.jpg\">\r\n                    </p>\r\n                </div>\r\n            </div>\r\n\r\n\r\n            <div class=\"boxWork step02\">\r\n                <div class=\"ttlWork\">\r\n                    <div class=\"ico\">\r\n                        <img src=\"./images/work/ico02.png\">\r\n                        <span>STEP.<strong>2</strong></span>\r\n                    </div>\r\n                    <p>商品企画</p>\r\n                    \t<span class=\"btnOpen\"><span>\r\n                </div>\r\n                <article>\r\n\t\t\t\t\t<div class=\"detail\">\r\n                    <p class=\"img\">\r\n                        <img src=\"./images/work/img02.jpg\">\r\n                    </p>\r\n                    <div class=\"\">\r\n                        <p class=\"txt\">\r\n                            商品企画職のミッションは「お客様に選ばれ、末永く安心・安全・快適な建物」をつくることです。どこにでもあるマンションを企画するのではなく、一棟ごとにコンセプトやデザインなどを練り上げていきます。\r\n                        </p>\r\n                        <h4 class=\"ttl\">\r\n                            市場調査・事業計画\r\n                        </h4>\r\n                        <p class=\"txt\">\r\n                            建設地の周辺環境から、ここに暮らす人達は何を求めているか、どんな家族構成か、また価格相場などを調査します。また、自社内にいる営業担当や設計者と打合せを繰り返し、建物の面積や階数・戸数などを決めていきます。\r\n                        </p>\r\n                        <h4 class=\"ttl\">\r\n                            商品企画\r\n                        </h4>\r\n                        <p class=\"txt\">\r\n                            市場調査や事業計画に基づきマンションの顔となるエントランスのデザインや設備の仕様などを企画します。打合せを重ね、より付加価値が高く、お客様を感動させるような企画につくり上げていきます。\r\n                        </p>\r\n                        <h4 class=\"ttl\">\r\n                            販売企画\r\n                        </h4>\r\n                        <p class=\"txt\">\r\n                            マンション販売部と協議しながらお客様に魅力を十分に伝えるためのプロモーションの策定、モデルルームのインテリアコーディネート、販売促進ツールの作成などを行い、マンション販売部に引き継ぎます。\r\n                        </p>\r\n                    </div>\r\n\t\t\t\t\t</div>\r\n                </article>\r\n                <div class=\"schedule\">\r\n                    <h3>一日のスケジュール</h3>\r\n                    <p class=\"img\">\r\n                        <img src=\"./images/work/sche02.jpg\">\r\n                    </p>\r\n                </div>\r\n            </div>\r\n\r\n\r\n\r\n\r\n            <div class=\"boxWork step03\">\r\n                <div class=\"ttlWork\">\r\n                    <div class=\"ico\">\r\n                        <img src=\"./images/work/ico03.png\">\r\n                        <span>STEP.<strong>3</strong></span>\r\n                    </div>\r\n                    <p>設計（意匠・構造・設備）</p>\r\n                    \t<span class=\"btnOpen\"><span>\r\n                </div>\r\n                <article>\r\n\t\t\t\t\t<div class=\"detail\">\r\n                    <p class=\"img\">\r\n                        <img src=\"./images/work/img03.jpg\">\r\n                    </p>\r\n                    <div class=\"\">\r\n                        <p class=\"txt\">\r\n                            設計は大きく分けて意匠設計、構造設計、設備設計の3つに分かれます。\r\n                        </p>\r\n                        <h4 class=\"ttl\">\r\n                            意匠設計\r\n                        </h4>\r\n                        <p class=\"txt\">\r\n                            基本設計は、施主からヒアリングした要望を図面に反映させます。施主の想いが反映できているか、建築基準法に適合しているか、予算内で収まっているかなど確認します。<br>\r\n                            次に詳細設計では、建築の納まりなどを考慮しながら、コンセントの位置や、スイッチの高さなど施工する全てのものについて決定した図面に仕上げます。また設計監理では、現場の進捗に合わせ図面通りに建物が造られているかの監理を行います。\r\n                        </p>\r\n                        <h4 class=\"ttl\">\r\n                            構造設計\r\n                        </h4>\r\n                        <p class=\"txt\">\r\n                            意匠設計、設備設計と情報を共有し、建物の安全性を確保できるように梁や柱などの配置、断面などを計画します。専用ソフトで構造計算を行い正確な図面に仕上げていきます。\r\n                        </p>\r\n                        <h4 class=\"ttl\">\r\n                            設備設計\r\n                        </h4>\r\n                        <p class=\"txt\">\r\n                            建物のインフラを設計します。電気設備・空調設備・衛生設備まで様々な分野の設備を計画し、意匠設計・構造設計と密な打合せをしながら図面を仕上げていきます。\r\n                        </p>\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t</div>\r\n                </article>\r\n                <div class=\"schedule\">\r\n                    <h3>一日のスケジュール（意匠設計）</h3>\r\n                    <p class=\"img\">\r\n                        <img src=\"./images/work/sche03.jpg\">\r\n                    </p>\r\n                </div>\r\n            </div>\r\n\r\n            <div class=\"boxWork step04\">\r\n                <div class=\"ttlWork\">\r\n                    <div class=\"ico\">\r\n                        <img src=\"./images/work/ico04.png\">\r\n                        <span>STEP.<strong>4</strong></span>\r\n                    </div>\r\n                    <p>施工管理</p>\r\n                    \t<span class=\"btnOpen\"><span>\r\n                </div>\r\n                <article>\r\n\t\t\t\t\t<div class=\"detail\">\r\n                    <p class=\"img\">\r\n                        <img src=\"./images/work/img04.jpg\">\r\n                    </p>\r\n                    <div class=\"\">\r\n                        <p class=\"txt\">\r\n                            施工管理は安全管理・品質管理・工程管理・予算管理を行います。多くの企業と協力して安心・安全な建物を造り上げていきます。\r\n                        </p>\r\n                        <h4 class=\"ttl\">\r\n                            安全管理\r\n                        </h4>\r\n                        <p class=\"txt\">\r\n                            工事現場では危険な場所での作業もある為、設備の整備・点検や安全教育、健康管理や安全パトロールなどを行いながら安全確保に努めています。\r\n                        </p>\r\n                        <h4 class=\"ttl\">\r\n                            品質管理\r\n                        </h4>\r\n                        <p class=\"txt\">\r\n                            建物が設計図・仕様書どおりの品質を満たすように管理します。材料の寸法や強度、デザインなどが既定された品質であることを試験・工事写真の撮影・分析等を行うことで確認します。\r\n                        </p>\r\n                        <h4 class=\"ttl\">\r\n                            工程管理\r\n                        </h4>\r\n                        <p class=\"txt\">\r\n                            予定通りに建物を完成させるためのスケジュール管理を行います。設計図に基づいた建設が工期内で安全に施工できるように工法を計画し、作業員の配置や重機手配などの予定を立て管理します。\r\n                        </p>\r\n                        <h4 class=\"ttl\">\r\n                            予算管理\r\n                        </h4>\r\n                        <p class=\"txt\">\r\n                            労務費や材料費という工事にかかる原価を計算し、予算内に収まるように管理します。常に進捗状況を把握し、問題が生じた場合は計画や工程を見直し軌道修正しながら予算を超過しないようにします。\r\n                        </p>\r\n                    </div>\r\n\t\t\t\t\t</div>\r\n                </article>\r\n                <div class=\"schedule\">\r\n                    <h3>一日のスケジュール</h3>\r\n                    <p class=\"img\">\r\n                        <img src=\"./images/work/sche04.jpg\">\r\n                    </p>\r\n                </div>\r\n            </div>\r\n\r\n            <div class=\"boxWork step05\">\r\n                <div class=\"ttlWork\">\r\n                    <div class=\"ico\">\r\n                        <img src=\"./images/work/ico05.png\">\r\n                        <span>STEP.<strong>5</strong></span>\r\n                    </div>\r\n                    <p>マンション販売</p>\r\n                    \t<span class=\"btnOpen\"><span>\r\n                </div>\r\n                <article>\r\n\t\t\t\t\t<div class=\"detail\">\r\n                    <p class=\"img\">\r\n                        <img src=\"./images/work/img05.jpg\">\r\n                    </p>\r\n                    <div class=\"\">\r\n                        <p class=\"txt\">\r\n                            土地の仕入れ、企画、設計、施工と多くの社員が「信頼」と「想い」を込めてつくり上げてきた建物を自信と誇りを持ってお客様へ販売します。\r\n                        </p>\r\n                        <h4 class=\"ttl\">\r\n                            ヒアリング・ニーズの把握\r\n                        </h4>\r\n                        <p class=\"txt\">\r\n                            ご来場されたお客様にアンケートやヒアリングを行い、お客様の予算や家族構成など様々な要望を把握することで、お客様に最適な物件をご提案します。\r\n                        </p>\r\n                        <h4 class=\"ttl\">\r\n                            物件説明\r\n                        </h4>\r\n                        <p class=\"txt\">\r\n                            保育園・小中学校や医療機関、スーパーなど生活に欠かせない現地周辺施設のご紹介やお部屋の設備仕様の説明を行います。モデルルームの部屋を一つひとつ案内し備え付けられる家具や家電製品のサイズなども一緒に考えていきます。\r\n                        </p>\r\n                        <h4 class=\"ttl\">\r\n                            ライフプランの相談\r\n                        </h4>\r\n                        <p class=\"txt\">\r\n                            お客様のご年齢やお子様達の成長に合わせた住宅ローンの相談なども親身に行うことで、安心して購入頂けるように努めます。ファイナンシャルプランナーに同席をしてもらうこともあります。\r\n                        </p>\r\n                        <h4 class=\"ttl\">\r\n                            契約・引渡\r\n                        </h4>\r\n                        <p class=\"txt\">\r\n                            お客様にご納得していただき契約を締結します。内覧会などを通じ、引き渡しまでお客様に寄り添います。\r\n                        </p>\r\n                    </div>\r\n\t\t\t\t\t</div>\r\n                </article>\r\n                <div class=\"schedule\">\r\n                    <h3>一日のスケジュール</h3>\r\n                    <p class=\"img\">\r\n                        <img src=\"./images/work/sche05.jpg\">\r\n                    </p>\r\n                </div>\r\n            </div>\r\n\r\n            <div class=\"boxWork step06\">\r\n                <div class=\"ttlWork\">\r\n                    <div class=\"ico\">\r\n                        <img src=\"./images/work/ico06.png\">\r\n                        <span>STEP.<strong>6</strong></span>\r\n                    </div>\r\n                    <p>アフター管理</p>\r\n                    \t<span class=\"btnOpen\"><span>\r\n                </div>\r\n                <article>\r\n\t\t\t\t\t<div class=\"detail\">\r\n                    <p class=\"img\">\r\n                        <img src=\"./images/work/img06.jpg\">\r\n                    </p>\r\n                    <div class=\"\">\r\n                        <p class=\"txt\">\r\n                            建物が出来上がり、お客様へ引き渡した後も社員の想いが永く続くように定期点検やメンテナンスを行っています。\r\n                        </p>\r\n                        <h4 class=\"ttl\">\r\n                            定期点検・メンテナンス\r\n                        </h4>\r\n                        <p class=\"txt\">\r\n                            定期点検では外観全般、建具、水まわり、床下、共用部分の点検などを行い、建物に不具合が生じていないかを確認します。また、お客様からの問い合わせ等にもスピーディーに対応します。社内で対応可能な場合はそのまま作業に移りますが、専門業者の対応が必要な時は工事の手配や現場管理なども行います。\r\n                        </p>\r\n                        <h4 class=\"ttl\">\r\n                            品質カイゼン\r\n                        </h4>\r\n                        <p class=\"txt\">\r\n                            建物に不具合が発生した際にはその原因まで調べます。同じような事象を繰り返さないように社内で共有し建物の品質向上の役割も担っています。\r\n                        </p>\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t</div>\r\n                </article>\r\n                <div class=\"schedule\">\r\n                    <h3>一日のスケジュール</h3>\r\n                    <p class=\"img\">\r\n                        <img src=\"./images/work/sche06.jpg\">\r\n                    </p>\r\n                </div>\r\n            </div>\r\n    </div>\r\n</section>\r\n\r\n\r\n</div>\r\n\r\n</div>\r\n<footer>\n    <div class=\"ftBtm block\">       \n        <div class=\"ftLink\">\n            <div class=\"logo cf\"> \n                <a href=\"../\" target=\"_blank\" class=\"eng\">\n                    <img src=\"../common/img/common/logo.jpg\" alt=\"新日本建設株式会社\" />\n                </a> \n            </div>\n            <ul class=\"cf\">\n                <li>\n                    <a href=\"../privacypolicy/\" target=\"_blank\">個人情報の取り扱いについて</a>\n                </li>\n                <li>\n                    <a href=\"../contact/\" target=\"_blank\">お問い合わせ</a>\n                </li>\n                <li>\n                    <a href=\"../sitemap/\" target=\"_blank\">サイトマップ</a>\n                </li>\n            </ul>\n        </div>\n        <p class=\"copy\">\n            <small>COPYRIGHT &copy; SHINNIHON CORPORATION. All Rights Reserved.</small>\n        </p> \n\n    </div>\n</footer>\n\n<div class=\"page_top\">\n    PAGE<br class=\"spOnly\"> TOP\n    <i class=\"material-icons\">keyboard_arrow_up</i>\n</div>\n\n<div class=\"btn_entry_fix spOnly\">\n\t<div class=\"box\">\n\t\t<a href=\"https://job.axol.jp/bx/s/shinnihon-c_27/entry/\" target=\"_blank\">\n        新卒採用（2027卒）<br>エントリーはこちら\n\t\t</a>\n        <a href=\"https://axol.jp/zw/s/shinnihon-c_28/entry/\" target=\"_blank\">\n            新卒採用（2028卒）<br>インターンシップは<br>こちら\n        </a>\n        <!-- <a href=\"https://job.mynavi.jp/26/pc/search/corp54735/outline.html\" class=\"bnr\" target=\"_blank\">\n        <img src=\"https://job.mynavi.jp/conts/kigyo/2026/logo/banner_logo_195_60.gif\" alt=\"マイナビ2026\" border=\"0\">\n        </a> -->\n\t\t<a href=\"./career.php\">キャリア採用</a>\n\t</div>\n</div>\n\n</body>\n</html>","finalUrl":"https://www.shinnihon-c.co.jp/recruit/work.php","rendered":false,"_cachedAt":"2026-06-22T22:38:32.979Z"}