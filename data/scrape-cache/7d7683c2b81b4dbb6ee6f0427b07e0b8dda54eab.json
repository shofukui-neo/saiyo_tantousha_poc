x\"\r\n           alt=\"長野県交通警備株式会社 ホームページ\">\r\n      </a>\r\n    </figure>\r\n    <div id=\"sp-nav\">\r\n      <i></i>\r\n    </div>\r\n    <nav id=\"nav\">\r\n      <ul>\r\n        <li><a href=\"/outline/\">会社案内</a></li>\r\n        <li><a href=\"/office/\">営業所案内</a></li>\r\n        <li><a href=\"/business/\">業務案内</a></li>\r\n        <li><a href=\"/recruit/\">求人情報</a></li>\r\n      </ul>\r\n      <div class=\"nav-inquiry\">\r\n        <a href=\"/inquiry/\">お問い合わせ</a>\r\n        <a href=\"/ask\" class=\"op-ask\">警備業務のご依頼</a>\r\n      </div>\r\n    </nav>\r\n  </div>\r\n</header>\r\n<!-- { ./ HEADER START } -->\r\n\r\n<!-- { CATEGORY TITLE START } -->\r\n<section id=\"category-header\" class=\"outer category-header-information\">\r\n  <div class=\"wrap\">\r\n    <div class=\"category-title\">\r\n      <h2>お知らせ</h2>\r\n      <p class=\"en\">INFORMATION</p>\r\n    </div>\r\n    <div class=\"bread-crumbs\">\r\n      <a href=\"/\">TOP</a> / <a href=\"/information/\">お知らせ</a> / 新年のご挨拶    </div>\r\n  </div>\r\n</section>\r\n<!-- { ./ CATEGORY TITLE START } -->\r\n\r\n<!-- { MAIN START } -->\r\n<main id=\"main\">\r\n  <article class=\"main-body\">\r\n\r\n    <!-- { 投稿ヘッダー } -->\r\n    <section id=\"information-post-header\" class=\"outer\">\r\n      <div class=\"wrap\">\r\n        <h3 class=\"title-h3\">新年のご挨拶</h3>\r\n        <div class=\"entry-header\">\r\n          <div class=\"entry-date\">\r\n            2026.01.05          </div>\r\n          <ul class=\"entry-category\">\r\n                                  </ul>\r\n        </div>\r\n      </div>\r\n    </section>\r\n    <!-- { ./ 投稿ヘッダー } -->\r\n\r\n    <!-- { 投稿本文 } -->\r\n    <section id=\"information-post-body\" class=\"entry-post outer\">\r\n      <div class=\"wrap\">\r\n        \r\n<section id=\"entry-segment-id-1\" class=\"entry-segment entry-segment-wysiwyg entry-segment-wysiwyg\">\r\n<div class=\"entry-body\">\r\n<p>お客様　各位</p>\n<p>&nbsp;</p>\n<p>新年、明けましておめでとうございます。</p>\n<p>本年も、長野県交通警備㈱をどうぞ、よろしく</p>\n<p>お願い申し上げます。</p>\n<p>当社は、これまで以上に社員を守り、</p>\n<p>社員の家族を守り、その上で全社員一丸</p>\n<p>となって、お客様の生命・身体・財産を</p>\n<p>全力でお守りしてまいりますので、</p>\n<p>旧年来同様、ご愛顧賜りますようお願い</p>\n<p>申し上げます。</p>\n<p>&nbsp;</p>\n<p>令和8年１月５日</p>\n<p>代表取締役社長　竹花　長雅</p>\n<p>長野県交通警備㈱　社員一同</p>\n\r\n</div>\r\n</section>\r\n\r\n        <div class=\"button-group position-center\">\r\n          <a class=\"button button-type-gray\" href=\"/information/\">お知らせトップに戻る</a>\r\n        </div>\r\n      </div>\r\n    </section>\r\n    <!-- { ./ 投稿本文 } -->\r\n  </article>\r\n</main>\r\n<!-- { ./ MAIN END } -->\r\n\r\n\n<!-- { FOOTER START } -->\n<div id=\"common-data-group\">\n  \n  <!-- { Sales Offiece } -->\n  <section id=\"sales-office\">\n    <div class=\"wrap\">\n      <div class=\"title\">\n        <h2>営業所一覧</h2>\n        <p class=\"en\">SALES OFFICE</p>\n      </div>\n\n      <ul class=\"sales-office-list\"><li><h3><a href=\"/office/#office-id-1\">東信支社</a></h3><ul><li class=\"telorfax\"><p class=\"office-name\">東信支社</p><span class=\"tel\">TEL</span>0267-31-6501<span class=\"fax\">FAX</span>0267-31-6509</li><li class=\"email\" data-email_user=\"toushin\" data-email_host=\"nk-keibi.co.jp\"></li></ul><ul></ul></li><li><h3><a href=\"/office/#office-id-2\">長野支社</a></h3><ul><li class=\"telorfax\"><p class=\"office-name\">長野支社</p><span class=\"tel\">TEL</span>026-251-1988<span class=\"fax\">FAX</span>026-251-1990</li><li class=\"email\" data-email_user=\"info\" data-email_host=\"nk-keibi.co.jp\"></li></ul><ul><li class=\"telorfax\"><p class=\"office-name\">管制センター</p><span class=\"tel\">TEL</span>026-251-1977<span class=\"fax\">FAX</span>026-251-1978</li></ul><ul></ul></li><li><h3><a href=\"/office/#office-id-3\">上田営業所</a></h3><ul><li class=\"telorfax\"><span class=\"tel\">TEL</span>0268-26-8585<span class=\"fax\">FAX</span>0268-26-8790</li><li class=\"email\" data-email_user=\"ueda\" data-email_host=\"nk-keibi.co.jp\"></li></ul><ul></ul></li><li><h3><a href=\"/office/#office-id-4\">松本営業所</a></h3><ul><li class=\"telorfax\"><span class=\"tel\">TEL</span>0263-48-5212<span class=\"fax\">FAX</span>0263-48-5213</li><li class=\"email\" data-email_user=\"matsumoto\" data-email_host=\"nk-keibi.co.jp\"></li></ul><ul></ul></li><li><h3><a href=\"/office/#office-id-5\">伊那営業所</a></h3><ul><li class=\"telorfax\"><span class=\"tel\">TEL</span>0265-73-7302<span class=\"fax\">FAX</span>0265-98-8303</li><li class=\"email\" data-email_user=\"ina\" data-email_host=\"nk-keibi.co.jp\"></li></ul><ul></ul></li><li><h3><a href=\"/office/#office-id-6\">高崎営業所</a></h3><ul><li class=\"telorfax\"><span class=\"tel\">TEL</span>090-9668-7737</li></ul><ul></ul></li></ul>    </div>\n  </section>\n  <!-- { ./ Sales Offiece } -->\n\n  <footer id=\"footer\">\n\n    <!-- { Inquiry & Recruit } -->\n    <section id=\"common-links\">\n      <div class=\"wrap\">\n        <div class=\"common-link common-link-ask\">\n          <p class=\"common-link-description\">\n            警備のご依頼・ご相談など、<br>\n            お申込みはこちら\n          </p>\n          <div class=\"common-link-btn-group\">\n            <a href=\"/ask\" class=\"common-link-btn\">警備業務のご依頼</a>\n            <p class=\"common-link-en\">ASK FOR PROTECTION</p>\n          </div>\n        </div>\n        <div class=\"common-link common-link-inquiry\">\n          <p class=\"common-link-description\">\n            警備のご依頼・ご相談など、<br>\n            お気軽にお問い合わせください。\n          </p>\n          <div class=\"common-link-btn-group\">\n            <a href=\"/inquiry/\" class=\"common-link-btn\">お問い合わせ</a>\n            <p class=\"common-link-en\">INQUIRY</p>\n          </div>\n        </div>\n        <div class=\"common-link common-link-recruit\">\n          <p class=\"common-link-description\">\n            警備スタッフ大募集！<br>\n            各営業所の求人情報についてのご案内\n          </p>\n          <div class=\"common-link-btn-group\">\n            <a href=\"/recruit/\" class=\"common-link-btn\">求人情報</a>\n            <p class=\"common-link-en\">JOB INFORMATION</p>\n          </div>\n        </div>\n      </div>\n    </section>\n 