{"url":"https://www.pref.saitama.lg.jp/f2210/r8kyouinsaiyou/r8top.html","html":"<!doctype html>\r\n<html lang=\"ja\">\r\n<head>\r\n<meta charset=\"utf-8\">\r\n\r\n<title>令和8年度埼玉県公立学校教員採用選考試験(令和7年度実施) - 埼玉県</title>\r\n<meta name=\"keywords\" content=\"教員採用,採用試験,教員,採用\" />\r\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\r\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\r\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\r\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\r\n})(window,document,'script','dataLayer','GTM-T855884');</script>\r\n\r\n<meta name=\"author\" content=\"埼玉県\">\r\n<meta property=\"og:title\" content=\"令和8年度埼玉県公立学校教員採用選考試験(令和7年度実施)\">\r\n<meta property=\"og:type\" content=\"article\">\r\n<meta property=\"og:description\" content=\"\">\r\n<meta property=\"og:url\" content=\"https://www.pref.saitama.lg.jp/f2210/r8kyouinsaiyou/r8top.html\">\r\n<meta property=\"og:image\" content=\"https://www.pref.saitama.lg.jp/shared/images/sns/logo.png\">\r\n<meta property=\"og:site_name\" content=\"埼玉県\">\r\n<meta property=\"og:locale\" content=\"ja_jp\">\r\n<meta name=\"dept_code_1\" content=\"140000000\">\r\n<meta name=\"dept_code_2\" content=\"140026000\">\r\n<meta name=\"dept_code_3\" content=\"140026010\">\r\n<meta name=\"cate_code_1\" content=\"005000000000\">\r\n<meta name=\"cate_code_2\" content=\"005016000000\">\r\n<meta name=\"cate_code_3\" content=\"\">\r\n<meta name=\"cate_code_4\" content=\"\">\r\n<meta name=\"publish_start\" content=\"2025-10-20 18:00:00\">\r\n<meta name=\"publish_end\" content=\"2028-10-20 00:00:00\">\r\n<meta name=\"template_id\" content=\"36\">\r\n<meta name=\"template_kind\" content=\"1\">\r\n<meta name=\"template_group\" content=\"259404\">\r\n<meta name=\"img\" content=\"\">\r\n<meta name=\"viewport\" content=\"width=device-width, maximum-scale=3.0\">\r\n<meta name=\"format-detection\" content=\"telephone=no\">\r\n<link href=\"/shared/site_rn/style/default.css\" rel=\"stylesheet\" media=\"all\">\r\n<link href=\"/shared/site_rn/style/shared.css\" rel=\"stylesheet\" media=\"all\">\r\n<link href=\"/shared/templates/free_rn/style/edit.css\" rel=\"stylesheet\" media=\"all\">\r\n<link href=\"/shared/site_rn/style/smartphone.css\" rel=\"stylesheet\" media=\"only screen and (max-width : 640px)\" class=\"mc_css\">\r\n<link href=\"/shared/site_rn/images/favicon/favicon.ico\" rel=\"shortcut icon\" type=\"image/vnd.microsoft.icon\">\r\n<link href=\"/shared/site_rn/images/favicon/apple-touch-icon-precomposed.png\" rel=\"apple-touch-icon-precomposed\">\r\n<script src=\"/shared/site_rn/js/jquery.js\"></script>\r\n<script src=\"/shared/site_rn/js/setting.js\"></script>\r\n<script src=\"/shared/system/js/furigana/ysruby.js\"></script>\r\n<script>\r\nwindow.rsDocReaderConf = {lang: 'ja_jp'};\r\n</script>\r\n<script src=\"//f1-as.readspeaker.com/script/5686/webReader/webReader.js?pids=wr&amp;forceAdapter=ioshtml5&amp;disable=translation,lookup&amp;dload=DocReader.AutoAdd\"></script>\r\n\r\n\r\n\r\n\r\n\r\n</head>\r\n<body class=\"format_free no_javascript\">\r\n\r\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-T855884\" height=\"0\" width=\"0\" style=\"display:none;visibility:hidden\" title=\"Google Tag Manager\"></iframe></noscript>\r\n\r\n<script src=\"/shared/site_rn/js/init.js\"></script>\r\n<div id=\"tmp_wrapper\">\r\n<div id=\"tmp_wrapper2\">\r\n<noscript>\r\n<p>このサイトではJavaScriptを使用したコンテンツ・機能を提供しています。JavaScriptを有効にするとご利用いただけます。</p>\r\n</noscript>\r\n<p><a href=\"#tmp_honbun\" class=\"skip\">本文へスキップします。</a></p>\r\n\r\n<div id=\"tmp_header\">\r\n<div class=\"container\">\r\n<div id=\"top\">\r\n<div id=\"tmp_hlogo\">\r\n<p><a href=\"/index.html\"><span>彩の国 埼玉県</span></a></p>\r\n</div>\r\n<div id=\"tmp_means\">\r\n<ul id=\"tmp_hnavi\">\r\n\t<li class=\"hnavi_lang\"><a href=\"/foreignlanguage/index.html\" lang=\"en\" xml:lang=\"en\">Foreign Language</a></li>\r\n\t<li class=\"hna