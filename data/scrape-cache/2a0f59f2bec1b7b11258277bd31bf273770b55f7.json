{"url":"https://www.aeonretail.jp/saiyo/challenged/message/","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n\n<head>\n  <!-- Google Tag Manager -->\n  <script>\n    (function (w, d, s, l, i) {\n      w[l] = w[l] || [];\n      w[l].push({\n        'gtm.start': new Date().getTime(),\n        event: 'gtm.js'\n      });\n      var f = d.getElementsByTagName(s)[0],\n        j = d.createElement(s),\n        dl = l != 'dataLayer' ? '&l=' + l : '';\n      j.async = true;\n      j.src =\n        'https://www.googletagmanager.com/gtm.js?id=' + i + dl;\n      f.parentNode.insertBefore(j, f);\n    })(window, document, 'script', 'dataLayer', 'GTM-M38PPC');\n  </script>\n  <!-- End Google Tag Manager -->\n  <meta charset=\"utf-8\">\n  <meta name=\"format-detection\" content=\"telephone=no\">\n  <meta name=\"viewport\" content=\"width=device-width\">\n  <link rel=\"shortcut icon\" href=\"/saiyo/challenged/img/common/apple-touch-icon.ico\">\n  <link rel=\"apple-touch-icon\" href=\"/saiyo/challenged/img/common/aeon_appletouchicon.png.webp\">\n\n  <title>私たちの想い｜障がい者採用サイト｜イオンリテール株式会社</title>\n  <meta name=\"keywords\" content=\"\">\n  <meta name=\"description\" content=\"一人ひとりが自分らしく輝ける職場を目指す、イオンリテールの障がい者採用についての取り組みをご紹介します。\">\n\n  <meta property=\"og:title\" content=\"私たちの想い｜障がい者採用サイト｜イオンリテール株式会社\">\n  <meta property=\"og:description\" content=\"一人ひとりが自分らしく輝ける職場を目指す、イオンリテールの障がい者採用についての取り組みをご紹介します。\">\n  <meta property=\"og:url\" content=\"https://www.aeonretail.jp/saiyo/challenged/message/\">\n  <meta property=\"og:type\" content=\"website\">\n  <meta property=\"og:locale\" content=\"ja_JP\">\n  <meta property=\"og:image\" content=\"/saiyo/challenged/img/common/og-image.jpg.webp\">\n  <meta property=\"og:site_name\" content=\"障がい者採用サイト｜イオンリテール株式会社\">\n\n  <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n  <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n  <link href=\"https://fonts.googleapis.com/css2?family=Quicksand:wght@500;700&family=Zen+Maru+Gothic:wght@500;700&display=swap\" rel=\"stylesheet\">\n\n  <link rel=\"stylesheet\" type=\"text/css\" href=\"/saiyo/challenged/css/lib/splide-core.min.css\">\n  <link rel=\"stylesheet\" type=\"text/css\" href=\"/saiyo/challenged/css/style.css\">\n\n\n  <script src=\"/saiyo/challenged/js/lib/b_browser_switcher.js\"></script>\n  <script src=\"/saiyo/challenged/js/lib/jquery-3.6.3.min.js\"></script>\n</head>\n\n\n<body>\n  <!-- Google Tag Manager (noscript) -->\n  <noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-M38PPC\" height=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n  <!-- End Google Tag Manager (noscript) -->\n  <div class=\"\" id=\"loading\">\n    <div class=\"fade-content\">\n      <div class=\"logo-area\">\n        <img src=\"/saiyo/challenged/img/common/aeon_logo.svg\" alt=\"AEON\">\n        <span class=\"txt\">障がい者採用サイト</span>\n      </div>\n    </div>\n  </div>\n  <div id=\"wrapper\">\n\n    <header></header>\n    <script>\n      $('header').load('/saiyo/challenged/inc/c-header.html');\n    </script>\n\n    <main class=\"message c-main-bg-pink\" id=\"main\" tabindex=\"-1\">\n      <section class=\"c-kv-section\">\n        <div class=\"white-bg\">\n          <div class=\"inner-block anim\">\n            <nav  aria-label=\"パンくずリスト\">\n              <ol class=\"crumb\">\n                <li><a href=\"/saiyo/challenged/\">ホーム</a></li>\n                <li class=\"current\" aria-current=\"location\">私たちの想い</li>\n              </ol>\n            </nav>\n            <h1 class=\"c-ttl01 yellow\">\n              <span class=\"ja\">私たちの想い</span>\n              <span class=\"en\">Message</span>\n            </h1>\n            <div class=\"desc-area has-img\">\n              <p class=\"desc\">\n                イオンリテールでは、一人ひとりの個性を尊重し、誰もが自分らしく活躍できる職場づくりを推進しています。障がいの有無にかかわらず、安心して挑戦できる環境をご用意しています。\n              </p>\n              <img src=\"/saiyo/challenged/img/message/kv-img.jpg.webp\" alt=\"\">\n            </div>\n          </div>\n        </div>\n\n      </section>\n\n      <section class=\"message-section\" aria-labelledby=\"message-section-title\">\n        <div class=\"inner-block\">\n          <h2 id=\"message-section-title\" class=\"section-ttl anim\">一人ひとりの個性が光る、<br class=\"pc\">誰もが自分らしく働ける場所へ。</h2>\n\n          <p class=\"section-txt anim\">\n            イオンでは<br class=\"pc\">「一人ひとりの笑顔が咲く未来のくらしを創造する」を<br class=\"pc\">ビジョンに掲げています。<br>それはイオンリテールで働く一人ひとりが<br class=\"pc\">「心豊かにくらし、笑顔が広がる」未来を描いていくことです。<br>そのためにも「すべての人が自分らしく活躍できる環境」が不可欠です。\n          </p>\n\n          <p class=\"section-txt anim\">\n            全国で2,000人を超える障がい者の方々を含め、<br class=\"pc\">11万人以上の従業員が働くイオンリテールでは、<br class=\"pc\">全ての従業員が、それぞれの個性を認め合いながら活躍しています。<br>一人ひとりが今以上に輝ける場をさらに広げていきたい。<br>それが私たちの心からの想いです。\n          </p>\n\n          <p class=\"section-txt anim\">\n            全国に360以上ある店舗には、さまざまなお仕事があふれています。<br>障がいのある方々が自分に合った役割を見つけ、<br class=\"pc\">自分らしくチャレンジを続けていけるよう、<br class=\"pc\">いろいろな働き方を用意し、就業環境を整えています。\n          </p>\n\n          <p class=\"section-txt anim\">\n            あなたが「ぴったり」と感じられる場所と、<br class=\"sp\">あなたが笑顔になれるお仕事を、<br>私たちと一緒に見つけましょう。\n          </p>\n        </div>\n\n        <span class=\"flow-img img01\">\n          <img src=\"/saiyo/challenged/img/message/message-img01.png.webp\" alt=\"\">\n        </span>\n        <span class=\"flow-img img02 pc\">\n          <img src=\"/saiyo/challenged/img/message/message-img02.png.webp\" alt=\"\">\n        </span>\n        <span class=\"flow-img img03 pc\">\n          <img src=\"/saiyo/challenged/img/message/message-img03.png.webp\" alt=\"\">\n        </span>\n        <span class=\"flow-img img04\">\n          <img src=\"/saiyo/challenged/img/message/message-img04.png.webp\" alt=\"\">\n        </span>\n        <span class=\"flow-deco deco01 blue\"></span>\n        <span class=\"flow-deco deco02 primary\"></span>\n        <span class=\"flow-deco deco03 l-blue\"></span>\n        <span class=\"flow-deco deco04 orange pc\"></span>\n        <span class=\"flow-deco deco05 yellow pc\"></span>\n        <span class=\"flow-deco deco06 green pc\"></span>\n        <span class=\"flow-deco deco07 green pc\"></span>\n        <span class=\"flow-deco deco08 primary pc\"></span>\n        <span class=\"flow-deco deco09 l-blue pc\"></span>\n        <span class=\"flow-deco deco10 yellow pc\"></span>\n        <span class=\"flow-deco deco11 orange pc\"></span>\n        <span class=\"flow-deco deco12 primary pc\"></span>\n        <span class=\"flow-deco deco13 green\"></span>\n        <span class=\"flow-deco deco14 orange\"></span>\n        <span class=\"flow-deco deco15 blue\"></span>\n        <span class=\"flow-deco deco16 l-blue\"></span>\n      </section>\n\n      <section class=\"initiative-section c-bg-white\" aria-labelledby=\"initiative-section-title\">\n        <div class=\"inner-block\">\n          <h2 id=\"initiative-section-title\" class=\"c-ttl02 anim\">障がい者雇用に対する取り組み</h2>\n          <div class=\"cont\">\n            <p class=\"section-txt anim\">障がいのある方々が安心してお仕事ができる環境整備を進めています。</p>\n            <ul class=\"initiative-list\">\n              <li class=\"anim\">\n                <h3 class=\"ttl\">イオンの“ダイ満足”</h3>\n                <div class=\"img\">\n                  <img src=\"/saiyo/challenged/img/message/initiative-img01.jpg.webp\" alt=\"イオンのダイ満足ロゴ\">\n                </div>\n                <p class=\"txt\">\n                  多様な人材がともに働くために、グループ全体でさまざまな取り組みを実施しています。従業員とその家族、お客さま、会社の満足を“ダイ満足”と名付け、イオングループ共通のビジョンとしています。\n                </p>\n              </li>\n              <li class=\"anim\">\n                <h3 class=\"ttl\">バリアフリー施設の環境整備</h3>\n                <div class=\"img\">\n                  <img src=\"/saiyo/challenged/img/message/initiative-img02.jpg.webp\" alt=\"\">\n                </div>\n                <p class=\"txt\">\n                  障がいのあるお客さまはもちろん、従業員にとっても心地よい店舗であるための環境を整備。館内サインや、段差のない入り口などさまざまな設備を整え、760以上の施設でバリアフリー新法の認定を取得しています。\n                </p>\n              </li>\n              <li class=\"anim\">\n                <h3 class=\"ttl\">入社前の職場体験実習</h3>\n                <div class=\"img\">\n                  <img src=\"/saiyo/challenged/img/message/initiative-img03.jpg.webp\" alt=\"\">\n                </div>\n                <p class=\"txt\">\n                  入社前の職場体験実習を推奨しています。実際の業務を体験することで働く姿をイメージできると同時に、職場の雰囲気を体感できます。入社後の職場への適応もスムーズになり、長期的な就労にも繋がります。\n                </p>\n              </li>\n              <li class=\"anim\">\n                <h3 class=\"ttl\">細やかなサポート面談</h3>\n                <div class=\"img\">\n                  <img src=\"/saiyo/challenged/img/message/initiative-img05.jpg.webp\" alt=\"\">\n                </div>\n                <p class=\"txt\">\n                  すべての従業員を対象に定期面談を行っています。障がいのある方は職場体験実習と入社後の働きやすい環境づくりのため、合理的配慮を確認する面談も実施。また、必要に応じてご家族や支援者も交えての面談も行います。\n                </p>\n              </li>\n              <li class=\"anim\">\n                <h3 class=\"ttl\">多様性を認め合う組織づくりのための研修</h3>\n                <div class=\"img\">\n                  <img src=\"/saiyo/challenged/img/message/initiative-img06.jpg.webp\" alt=\"\">\n                </div>\n                <p class=\"txt\">\n                  全従業員が多様性を尊重し、働きやすい職場環境や組織づくりをするための研修を毎年受講しています。会社として大切にする価値観や人権に関する新しい知識を学ぶ機会です。\n                </p>\n              </li>\n              <li class=\"anim\">\n                <h3 class=\"ttl\">人事担当者向け研修の開催</h3>\n                <div class=\"img\">\n                  <img src=\"/saiyo/challenged/img/message/initiative-img04.jpg.webp\" alt=\"\">\n                </div>\n                <p class=\"txt\">\n                  イオンの特例子会社『アビリティーズジャスコ』の講師によるオンライン研修が毎月開催され、店舗の人事担当者が参加し、障がいのある従業員が働きやすい職場環境を整えるための知識や手法を学んでいます。\n                </p>\n              </li>\n            </ul>\n          </div>\n          <div class=\"audience-message-wrap anim\">\n            <h2 class=\"c-ttl02 anim\">求職者のご家族、就労支援に携わる方へ</h2>\n            <div class=\"inn\">\n              <p class=\"section-txt anim\">創業以来、人権を尊重し、国籍・人権・性別・学歴・宗教・心身の障がいのあることなどを理由とした差別を行わず、多様な人材が活躍できる企業を目指しています。従業員一人ひとりが自分らしく働ける職場づくりに取り組んでおり、現在では2,000人以上の障がいのある方が、それぞれの個性を発揮して活躍しています。私たちには、これまで長年続けてきたダイバーシティ経営の実績と、それを支える豊富な制度が揃っています。</p>\n              <ul class=\"data-list\">\n                <li class=\"anim\">\n                  <h3 class=\"ttl\">障がい者在籍数</h3>\n                  <div class=\"img\">\n                    <img src=\"/saiyo/challenged/img/message/data-img01.svg\" alt=\"\">\n                  </div>\n                  <p class=\"txt\">\n                    <span class=\"num\">2,000</span>人以上\n                  </p>\n                </li>\n                <li class=\"anim\">\n                  <h3 class=\"ttl\">障がい種別</h3>\n                  <div class=\"img\">\n                    <picture>\n                      <source media=\"(min-width: 768px)\" srcset=\"/saiyo/challenged/img/message/data-img02.svg\">\n                      <img src=\"/saiyo/challenged/img/message/data-img02-sp.svg\" loading=\"lazy\" alt=\"\">\n                    </picture>\n                  </div>\n                  <div class=\"txt-wrap\">\n                    <div class=\"txt-inn\">\n                      <p class=\"top txt\">知的</p>\n                      <p class=\"num\">\n                        43<span class=\"small\">%</span>\n                      </p>\n                    </div>\n                    <div class=\"txt-inn\">\n                      <p class=\"top txt\">身体</p>\n                      <p class=\"num\">\n                        34<span class=\"small\">%</span>\n                      </p>\n                    </div>\n                    <div class=\"txt-inn\">\n                      <p class=\"top txt\">精神・発達</p>\n                      <p class=\"num\">\n                        23<span class=\"small\">%</span>\n                      </p>\n                    </div>\n                  </div>\n                </li>\n                <li class=\"anim\">\n                  <h3 class=\"ttl\">年代別構成比</h3>\n                  <ul class=\"composition-table\">\n                    <li>\n                      <h4><span class=\"num\">70</span><span class=\"ja\">代</span></h4>\n                      <picture>\n                        <source media=\"(min-width: 768px)\" srcset=\"/saiyo/challenged/img/message/composition-img01.svg\">\n                        <img src=\"/saiyo/challenged/img/message/composition-img01-sp.svg\" loading=\"lazy\" alt=\"\">\n                      </picture>\n                      <p class=\"num-txt\"><span class=\"num\">2</span><span class=\"symbol\">%</span></p>\n                    </li>\n                    <li>\n                      <h4><span class=\"num\">60</span><span class=\"ja\">代</span></h4>\n                      <picture>\n                      <source media=\"(min-width: 768px)\" srcset=\"/saiyo/challenged/img/message/composition-img02.svg\">\n                      <img src=\"/saiyo/challenged/img/message/composition-img02-sp.svg\" loading=\"lazy\" alt=\"\">\n                      </picture>\n                      <p class=\"num-txt\"><span class=\"num\">15</span><span class=\"symbol\">%</span></p>\n                    </li>\n                    <li>\n                      <h4><span class=\"num\">50</span><span class=\"ja\">代</span></h4>\n                      <picture>\n                      <source media=\"(min-width: 768px)\" srcset=\"/saiyo/challenged/img/message/composition-img03.svg\">\n                      <img src=\"/saiyo/challenged/img/message/composition-img03-sp.svg\" loading=\"lazy\" alt=\"\">\n                      </picture>\n                      <p class=\"num-txt\"><span class=\"num\">19.8</span><span class=\"symbol\">%</span></p>\n                    </li>\n                    <li>\n                      <h4><span class=\"num\">40</span><span class=\"ja\">代</span></h4>\n                      <picture>\n                      <source media=\"(min-width: 768px)\" srcset=\"/saiyo/challenged/img/message/composition-img04.svg\">\n                      <img src=\"/saiyo/challenged/img/message/composition-img04-sp.svg\" loading=\"lazy\" alt=\"\">\n                      </picture>\n                      <p class=\"num-txt\"><span class=\"num\">16.8</span><span class=\"symbol\">%</span></p>\n                    </li>\n                    <li>\n                      <h4><span class=\"num\">30</span><span class=\"ja\">代</span></h4>\n                      <picture>\n                      <source media=\"(min-width: 768px)\" srcset=\"/saiyo/challenged/img/message/composition-img05.svg\">\n                      <img src=\"/saiyo/challenged/img/message/composition-img05-sp.svg\" loading=\"lazy\" alt=\"\">\n                      </picture>\n                      <p class=\"num-txt\"><span class=\"num\">22.2</span><span class=\"symbol\">%</span></p>\n                    </li>\n                    <li>\n                      <h4><span class=\"num\">20</span><span class=\"ja\">代</span></h4>\n                      <picture>\n                      <source media=\"(min-width: 768px)\" srcset=\"/saiyo/challenged/img/message/composition-img06.svg\">\n                      <img src=\"/saiyo/challenged/img/message/composition-img06-sp.svg\" loading=\"lazy\" alt=\"\">\n                      </picture>\n                      <p class=\"num-txt\"><span class=\"num\">21.6</span><span class=\"symbol\">%</span></p>\n                    </li>\n                    <li>\n                      <h4><span class=\"num\">10</span><span class=\"ja\">代</span></h4>\n                      <picture>\n                      <source media=\"(min-width: 768px)\" srcset=\"/saiyo/challenged/img/message/composition-img07.svg\">\n                      <img src=\"/saiyo/challenged/img/message/composition-img07-sp.svg\" loading=\"lazy\" alt=\"\">\n                      </picture>\n                      <p class=\"num-txt\"><span class=\"num\">2.6</span><span class=\"symbol\">%</span></p>\n                    </li>\n                  </ul>\n                </li>\n                <li class=\"anim\">\n                  <h3 class=\"ttl\">平均勤続年数</h3>\n                  <div class=\"txt-wrap\">\n                    <div class=\"inn\">\n                      <p class=\"txt\">正社員</p>\n                      <div class=\"img\">\n                        <img src=\"/saiyo/challenged/img/message/data-img04.svg\" alt=\"\">\n                      </div>\n                    </div>\n                    <p class=\"txt\"><span class=\"num\">28.8</span>年</p>\n                  </div>\n                  <div class=\"txt-wrap\">\n                    <div class=\"inn\">\n                      <p class=\"txt\">パート<br>タイマー</p>\n                      <div class=\"img\">\n                        <img src=\"/saiyo/challenged/img/message/data-img05.svg\" alt=\"\">\n                      </div>\n                    </div>\n                    <p class=\"txt\"><span class=\"num\">10.6</span>年</p>\n                  </div>\n                  <p class=\"txt\">パートタイマーで<span class=\"num\">46</span>年<br>働いている方もいらっしゃいます</p>\n                </li>\n              </ul>\n              <p class=\"note anim\"><span class=\"inn\">※</span><span class=\"inn\">2025年5月時点</span></p>\n              <p class=\"note anim\"><span class=\"inn\">※</span><span class=\"inn\">パートタイマー、正社員を合わせた数で計算</span></p>\n            </div>\n          </div>\n        </div>\n      </section>\n    </main>\n\n    <footer></footer>\n    <script>\n      $('footer').load('/saiyo/challenged/inc/c-footer.html');\n    </script>\n\n  </div><!-- /wrapper -->\n\n  <script src=\"/saiyo/challenged/js/lib/splide.min.js\"></script>\n\n  <script src=\"/saiyo/challenged/js/lib/jquery.matchHeight-min.js\"></script>\n  <script src=\"/saiyo/challenged/js/common.js\"></script>\n</body>\n\n</html>","finalUrl":"https://www.aeonretail.jp/saiyo/challenged/message/","rendered":false,"_cachedAt":"2026-06-22T21:06:57.646Z"}