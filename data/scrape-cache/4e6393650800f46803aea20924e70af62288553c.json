{"url":"https://www.sc-aero.co.jp/recruit/message/","html":"\n<!DOCTYPE html>\n<html lang=\"ja\">\n    <head>\n        <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n        <meta charset=\"utf-8\">\n        <meta name=\"description\" content=\"住商エアロシステム株式会社 新卒採用情報の「社長メッセージ」ページです。\">\n        <meta name=\"keywords\" content=\"住商エアロシステム,防衛航空宇宙,社長メッセージ\">\n        <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n        <meta name=\"format-detection\" content=\"telephone=no\">\n\n        <title>社長メッセージ｜住商エアロシステム株式会社 新卒採用情報</title>\n\n        <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n        <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n        <link rel=\"stylesheet\" href=\"https://fonts.googleapis.com/css2?family=Zen+Old+Mincho:wght@400;700&display=swap\">\n        <link rel=\"stylesheet\" href=\"https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&display=swap\">\n        \n        <link rel=\"stylesheet\" href=\"../assets/css/style.css\" media=\"all\">\n\n        <script src=\"../assets/js/vendor/script.js\"></script>\n        <script src=\"../assets/js/plugins.js\"></script>\n        \n        <script src=\"../assets/js/app.js\"></script>\n\n        <!-- Global site tag (gtag.js) - Google Analytics -->\n        <script async src=\"https://www.googletagmanager.com/gtag/js?id=G-K76JDYQNZS\"></script> <script>\n            window.dataLayer = window.dataLayer || []; function gtag(){dataLayer.push(arguments);} gtag('js', new Date());\n            gtag('config', 'G-K76JDYQNZS');\n            gtag('config', 'UA-226519009-1');\n        </script>\n    </head>\n    <body class=\"child message top\" data-key=\"00-01-00\" data-dir=\"1\">\n        <div id=\"wrapper\">\n            <header>\n                <div id=\"header\">\n                    <div class=\"float\">\n                        <div class=\"left\">\n                            <ul class=\"flex\">\n                                <li><a class=\"logo\" href=\"../\"><img src=\"../assets/img/common/header_logo.png\" alt=\"住商エアロシステム株式会社\"></a></li>\n                                <li><p>新卒採用サイト</p></li>\n                            </ul>\n                        </div>\n                        <div class=\"right\">\n                            <ul class=\"flex\">\n                                <li><a id=\"menu-entry\" href=\"../info/requirements.html#entry\"><p>ENTRY</p></a></li>\n                                <li><button id=\"menu-btn\"><span class=\"icon\"></span></button></li>\n                            </ul>\n                        </div>\n                    </div>\n                </div>\n            </header>\n\n\n\n            <div id=\"menu\">\n                <div id=\"menu-overlay\"></div>\n                <div id=\"menu-list\">\n                    <div class=\"inner900\">\n                        <div class=\"flex\">\n                            <div class=\"col\">\n                                <div class=\"box\">\n                                    <div class=\"parent\"><a href=\"../\"><p class=\"font--serif\">TOP</p></a></div>\n                                </div>\n\n                                <div class=\"box\">\n                                    <div class=\"parent\"><a href=\"../message/\"><p class=\"font--serif\">社長メッセージ</p></a></div>\n                                </div>\n\n                                <div class=\"box\">\n                                    <div class=\"parent\"><a class=\"accordion-btn--sp\"><p class=\"font--serif\">会社を知る</p></a></div>\n                                    <ul class=\" accordion-body--sp\">\n                                        <li class=\"child\"><a href=\"../company/\"><p>企業概要</p></a></li>\n                                        <li class=\"child\"><a href=\"../company/info.html\"><p>住商エアロシステムの機能</p></a></li>\n                                        <li class=\"child\"><a href=\"../company/movie.html\"><p>動画ギャラリー</p></a></li>\n                                    </ul>\n                                </div>\n\n                                <div class=\"box\">\n                                    <div class=\"parent\"><a class=\"accordion-btn--sp\"><p class=\"font--serif\">ビジネスを知る</p></a></div>\n                                    <ul class=\" accordion-body--sp\">\n                                        <li class=\"child\"><a href=\"../business/#business-pro\"><p>防衛・航空宇宙の専門商社</p></a></li>\n                                        <li class=\"child\"><a href=\"../business/#business-sas\"><p>SAS Business</p></a></li>\n                                    </ul>\n                                </div>\n                            </div>\n                            <div class=\"col\">\n                                <div class=\"box\">\n                                    <div class=\"parent\"><a class=\"accordion-btn--sp\"><p class=\"font--serif\">社員を知る</p></a></div>\n                                    <ul class=\" accordion-body--sp\">\n                                        <li class=\"child\"><a href=\"../staff/member04.html\"><p>総合職</p></a></li>\n                                        <li class=\"child\"><a href=\"../staff/member02.html\"><p>総合職</p></a></li>\n                                        <li class=\"child\"><a href=\"../staff/member03.html\"><p>管理職</p></a></li>\n                                    </ul>\n                                </div>\n                                <div class=\"box\">\n                                    <div class=\"parent\"><a class=\"accordion-btn--sp\"><p class=\"font--serif\">採用情報</p></a></div>\n                                    <ul class=\" accordion-body--sp\">\n                                        <li class=\"child\"><a href=\"../info/requirements.html\"><p>募集要項</p></a></li>\n                                        <li class=\"child\"><a href=\"../info/personality.html\"><p>求める人材像</p></a></li>\n                                        <li class=\"child\"><a href=\"../info/event.html\"><p>イベント情報</p></a></li>\n                                    </ul>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n\n            <div id=\"mv\" class=\"size--message\">\n                <div class=\"bg\"></div>\n\n                <div class=\"inside\">\n                    <div class=\"inner1000\">\n                        <h1>社長メッセージ</h1>\n                        <div class=\"txt\">\n                            <p>\n                                社会に貢献し続ける会社として、<br>\n                                意欲の高い人材とともに<br class=\"spshow\">成長してゆきたい。\n                            </p>\n                        </div>\n                    </div>\n                </div>\n            </div>\n\n\n\n            <main>\n                <article>\n                    <section id=\"message-top-name\">\n                    </section>\n\n\n                    <section id=\"message-top-body\">\n                        <div class=\"blocks inner1000\">\n                            <div class=\"block\">\n                                <div class=\"h2\">\n                                    <h2>\n                                        住友商事グループの総合力を用いて、<br class=\"pcshow\">国の安全と平和に貢献する安全保障の分野で活躍\n                                    </h2>\n                                </div>\n                                <div class=\"txt\">\n                                    <p>\n                                        当社は、1982年に住友商事の航空宇宙・防衛事業の一翼を担う、安全保障に精通した専門家集団として設立されました。以来、住友商事グループの一員として、役割を充実させて成長してきました。営業力の強化と並んで健全な事業活動に不可欠な管理部門の機能の高度化を進め、バランスの取れた経営を実現しています。<br>\n                                        コアコンピタンスは、国の安全と平和に貢献する安全保障の分野において、住友商事グループの総合力を用いて、多岐にわたる機能を提供している点です。情報収集・分析機能、市場開拓機能、マーケティング技術、リスクマネジメント機能、物流技術、金融技術、オーガナイザー機能、プロジェクトマネジメントなどが代表例です。\n                                    </p>\n                                </div>\n                            </div>\n\n\n                            <div class=\"block\">\n                                <div class=\"h2\">\n                                    <h2>\n                                        多岐にわたる分野での事業展開を図り、成長を続ける\n                                    </h2>\n                                </div>\n                                <div class=\"txt\">\n                                    <p>\n                                        安全保障をキーワードに、国の安全と平和に貢献することが弊社のミッションであることは今後も変わりません。国内外パートナーの代理店として、既存分野で必要とされる技術や商材を提供するだけでなく、新領域分野にも進出してきています。またゲームチェンジャーとなり得る先端技術を自ら探索して、ベンチャー企業とともに未開拓の領域の研究開発も行っています。事業化が必要なケースにおいては住友商事グループの強みを生かして、目的に沿った投資の実現を図っています。さらには、顧客に密着したビジネス展開により、製造や運用の仕組みに精通している当社の強みを生かし、開発・製造から運用までの一貫したバリューチェーンのなかで、サプライチェーンマネージメントを請け負うサービス事業の展開も図っています。<br>\n                                        事業戦略において様々な“軸”がありますが、多岐にわたる分野での事業展開を実現するため、ポートフォリオ戦略、パートナー戦略、バリュープロポジション戦略、オペレーション戦略などを推進しています。\n                                    </p>\n                                </div>\n                            </div>\n\n\n                            <div class=\"block\">\n                                <div class=\"h2\">\n                                    <h2>\n                                        忍耐強さと誠実さ、<br class=\"pcshow\">チャレンジ精神、コミュニケーション能力が必要\n                                    </h2>\n                                </div>\n                                <div class=\"txt\">\n                                    <p>\n                                        当社が目指すことを実現するために、様々な戦略を立てていますが、最も大事な戦略は人財戦略と考えています。当社が担う役割を理解して共感できる人財とともに成長してゆきたいと考えています。当社のビジネスは、多岐にわたりそれぞれに関わる社内外の関係者が多く、かつ取組み開始から案件として成就するまで時間のかかるものが多くあります。どの案件も蓋然性があり大事な案件であるなかで、成就させるには知識のみならず、創意工夫や大きなエネルギーを必要とします。それらをやり遂げる人財には、様々な要素が求められますが、例えば、粘り強さを持つ、コミュニケーション力がある、チャレンジすることに旺盛である、目的を見失わない、いつも誠実である、などがそれにあたります。また、事業活動の根幹である規則や決まりを守るコンプライアンス意識が必須となります。<br>\n                                        当社は、健全な事業活動を通じて、ステークホルダーの皆様の経済的、精神的な豊かさと夢を実現することを経営のミッションとしています。「住友の事業精神」の真髄である「信用を重んじ確実を旨とする」ことを貫き、主体性と創造性を発揮し、改革と革新を不断に生み出して、社会に貢献する企業を目指しています。<br>\n                                        <br>\n                                        当社に興味を持ってくださる方には是非とも連絡先にコンタクトいただき、双方の意思疎通のための機会を持たせていただきたいと思っています。\n                                    </p>\n                                </div>\n\n                                <div class=\"name\">\n                                    <div class=\"align--right\"><p>代表取締役社長　<span>上野 智規</span></p></div>\n                                </div>\n                            </div>\n                        </div>\n                    </section>\n                </article>\n            </main>\n\n            <div id=\"footer-message\">\n                <div class=\"inside\">\n                    <div class=\"ph\"><img src=\"../assets/img/common/footer_copy.png\" alt=\"あたりまえを衞り続ける\"></div>\n                </div>\n            </div>\n            <footer class=\"child message top\">\n                <div class=\"upper\">\n                    <div class=\"inner1000\">\n                        <ul class=\"flex\">\n                            <li>\n                                <ol>\n                                    <li class=\"parent\"><a href=\"../\"><p>TOP</p></a></li>\n                                    <li class=\"child\"><a href=\"../info/requirements.html#entry\"><p>エントリー</p></a></li>\n                                    <li class=\"child\"><a class=\"blank\" href=\"https://www.sc-aero.co.jp/index.html\" target=\"_blank\"><p>コーポレートサイト</p></a></li>\n                                </ol>\n                            </li>\n                            <li>\n                                <ol>\n                                    <li class=\"parent\"><a href=\"../message/\"><p>社長メッセージ</p></a></li>\n                                </ol>\n                            </li>\n                            <li>\n                                <ol>\n                                    <li class=\"parent\"><a class=\"none\"><p>会社を知る</p></a></li>\n                                    <li class=\"child\"><a href=\"../company/\"><p>企業概要</p></a></li>\n                                    <li class=\"child\"><a href=\"../company/info.html\"><p>住商エアロシステムの機能</p></a></li>\n                                    <li class=\"child\"><a href=\"../company/movie.html\"><p>動画ギャラリー</p></a></li>\n                                </ol>\n                            </li>\n                            <li>\n                                <ol>\n                                    <li class=\"parent\"><a class=\"none\"><p>ビジネスを知る</p></a></li>\n                                    <li class=\"child\"><a href=\"../business/#business-pro\"><p>防衛・航空宇宙の専門商社</p></a></li>\n                                    <li class=\"child\"><a href=\"../business/#business-sas\"><p>SAS Business</p></a></li>\n                                </ol>\n                            </li>\n                            <li>\n                                <ol>\n                                    <li class=\"parent\"><a class=\"none\"><p>社員を知る</p></a></li>\n                                    <li class=\"child\"><a href=\"../staff/member04.html\"><p>総合職</p></a></li>\n                                    <li class=\"child\"><a href=\"../staff/member02.html\"><p>総合職</p></a></li>\n                                    <li class=\"child\"><a href=\"../staff/member03.html\"><p>管理職</p></a></li>\n                                </ol>\n                            </li>\n                            <li>\n                                <ol>\n                                    <li class=\"parent\"><a class=\"none\"><p>採用情報</p></a></li>\n                                    <li class=\"child\"><a href=\"../info/requirements.html\"><p>募集要項</p></a></li>\n                                    <li class=\"child\"><a href=\"../info/personality.html\"><p>求める人材像</p></a></li>\n                                    <li class=\"child\"><a href=\"../info/event.html\"><p>イベント情報</p></a></li>\n                                </ol>\n                            </li>\n                        </ul>\n                    </div>\n                </div>\n\n\n                <div class=\"lower\">\n                    <div class=\"copyright\"><p>&copy; Sumisho Aero Systems Corporation</p></div>\n                </div>\n            </footer>\n        </div>\n    </body>\n</html>","finalUrl":"https://www.sc-aero.co.jp/recruit/message/","rendered":false,"_cachedAt":"2026-06-22T15:49:23.743Z"}