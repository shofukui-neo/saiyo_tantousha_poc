{"url":"https://www.takizumi.com/recruit/crosstalk/","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n<head prefix=\"og: http://ogp.me/ns#\">\n\t<!-- Google tag (gtag.js) -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-23HKB9BP8V\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'G-23HKB9BP8V');\n</script>\t<meta charset=\"UTF-8\">\n\t<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n\t<title>社員クロストーク｜タキズミ採用サイト</title>\n  <meta name=\"description\" content=\"タキズミに2017年に入社した同期4人によるクロストークです。入社のきっかけ、仕事への想い、タキズミのいいところなどNGワードなしの本音で話してもらいました。\">\n  <meta name=\"keywords\" content=\"\">\n\n  <meta property=\"fb:app_id\" content=\"\">\n  <meta property=\"og:title\" content=\"社員クロストーク｜タキズミ採用サイト\">\n  <meta property=\"og:description\" content=\"タキズミに2017年に入社した同期4人によるクロストークです。入社のきっかけ、仕事への想い、タキズミのいいところなどNGワードなしの本音で話してもらいました。\">\n  <meta property=\"og:type\" content=\"website\">\n  <meta property=\"og:image\" content=\"https://www.takizumi.com/recruit/images/ogp.jpg\">\n  <meta property=\"og:url\" content=\"https://www.takizumi.com/recruit/crosstalk/\">\n  <meta property=\"og:site_name\" content=\"株式会社タキズミ\">\n  <meta property=\"og:locale\" content=\"ja_JP\">\n  <meta name=\"twitter:title\" content=\"社員クロストーク｜タキズミ採用サイト\">\n  <meta name=\"twitter:description\" content=\"タキズミに2017年に入社した同期4人によるクロストークです。入社のきっかけ、仕事への想い、タキズミのいいところなどNGワードなしの本音で話してもらいました。\">\n  <meta name=\"twitter:image\" content=\"https://www.takizumi.com/recruit/images/ogp.jpg\">\n  <meta name=\"twitter:url\" content=\"https://www.takizumi.com/recruit/crosstalk/\">\n  <meta name=\"twitter:card\" content=\"summary_large_image\">\n\t<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<link rel=\"icon\" href=\"/recruit/images/apple-touch-icon.png\">\n<link rel=\"shortcut icon\" href=\"/recruit/images/apple-touch-icon.png\">\n<link rel=\"shortcut icon\" type=\"image/x-icon\" href=\"/recruit/favicon.ico\">\n<link rel=\"apple-touch-icon\" href=\"/recruit/images/apple-touch-icon.png\">\n<link rel=\"apple-touch-icon-precomposed\" href=\"/recruit/images/apple-touch-icon-precomposed.png\">\n\n\t<link rel=\"stylesheet\" href=\"../css/reset.css\">\n  <link rel=\"stylesheet\" href=\"../css/style.css\">\n</head>\n<body>\n\t\n  <div id=\"wrapper\" class=\"crosstalk\">\n    <div id=\"Loader\"><span class=\"base\"></span><span class=\"progress\"></span></div>\n\t\t<div id=\"page\">\n\t\t\t<header id=\"header\" class=\"header\">\n  <div class=\"header_logo_area\"><a href=\"/recruit/\">\n    <p class=\"header_logo\"><img src=\"/recruit/images/all_logo.jpg\" alt=\"株式会社タキズミ\"></p>\n    <p class=\"header_logo_recruit\">RECRUIT SITE</p>\n  </a></div>\n\t<div class=\"header_menubtn\">\n\t\t<div class=\"header_menubtn_lines\">\n\t\t\t<span></span>\n\t\t\t<span></span>\n\t\t</div>\n\t</div>\n\t<div class=\"header_wrap\">\n\t\t<div class=\"header_wrap_inner\">\n\t\t\t<nav class=\"header_gnav\">\n\t\t\t\t<ul class=\"header_gnav_nav\">\n\t\t\t\t\t<li class=\"header_gnav_item header_gnav_item_01 header_gnav_item_solo\"><a href=\"/recruit/business/\">事業紹介</a></li>\n\t\t\t\t\t<li class=\"header_gnav_item header_gnav_item_02 header_gnav_item_mega\"><span>仕事を知る</span>\n\t\t\t\t\t\t<div class=\"header_gnav_mega\">\n\t\t\t\t\t\t\t<ul class=\"header_megamenu\">\n\t\t\t\t\t\t\t\t<li class=\"header_megamenu_item\"><a href=\"/recruit/crosstalk/\">社員クロストーク</a></li>\n\t\t\t\t\t\t\t\t<li class=\"header_megamenu_item\"><a href=\"/recruit/workflow/\">1日の仕事の流れ</a></li>\n\t\t\t\t\t\t\t</ul>\n\t\t\t\t\t\t</div>\n          </li>\n\t\t\t\t\t<li class=\"header_gnav_item header_gnav_item_03 header_gnav_item_mega\"><span>働く環境を知る</span>\n\t\t\t\t\t\t<div class=\"header_gnav_mega\">\n\t\t\t\t\t\t\t<ul class=\"header_megamenu\">\n\t\t\t\t\t\t\t\t<li class=\"header_megamenu_item\"><a href=\"/recruit/training/\">キャリア・研修制度</a></li>\n\t\t\t\t\t\t\t\t<li class=\"header_megamenu_item\"><a href=\"/recruit/welfare/\">福利厚生</a></li>\n\t\t\t\t\t\t\t</ul>\n\t\t\t\t\t\t</div>\n          </li>\n\t\t\t\t\t<li class=\"header_gnav_item header_gnav_item_04 header_gnav_item_mega\"><span>人を知る</span>\n\t\t\t\t\t\t<div class=\"header_gnav_mega\">\n\t\t\t\t\t\t\t<ul class=\"header_megamenu\">\n\t\t\t\t\t\t\t\t<li class=\"header_megamenu_item\"><a href=\"/recruit/Interview01/\">社員インタビュー01</a></li>\n\t\t\t\t\t\t\t\t<li class=\"header_megamenu_item\"><a href=\"/recruit/Interview02/\">社員インタビュー02</a></li>\n\t\t\t\t\t\t\t\t<!-- <li class=\"header_megamenu_item\"><a href=\"/recruit/Interview03/\">社員インタビュー03</a></li>  -->\n\t\t\t\t\t\t\t\t<!-- <li class=\"header_megamenu_item\"><a href=\"/recruit/Interview04/\">社員インタビュー04</a></li> -->\n\t\t\t\t\t\t\t</ul>\n\t\t\t\t\t\t</div>\n          </li>\n\t\t\t\t\t<li class=\"header_gnav_item header_gnav_item_05 header_gnav_item_solo\"><a href=\"/recruit/detail/\">募集要項</a></li>\n\t\t\t\t</ul>\n\t\t\t</nav>\n      <p class=\"header_corporate\"><a href=\"http://www.takizumi.com/\" target=\"_blank\">コーポレートサイトはこちら</a></p>\n\t\t\t<div class=\"header_entry\">\n\t\t\t\t<p class=\"header_entry_btn\"><a href=\"/recruit/detail/#message\">エントリー</a></p>\n\t\t\t</div>\n      <p class=\"header_copy\">&copy; 2022 TAKIZUMI All Right Reserved.</p>\n\t\t</div><!-- /.header_wrap_inner -->\n\t</div><!-- /.header_wrap -->\n</header>\n\n\t\t\t<main id=\"main\">\n\t\t\t\t<div class=\"all_m_mv\"><div class=\"all_m_mv_wrap\">\n          <div class=\"all_m_mv_title\">\n\t\t\t\t\t\t<h1 class=\"all_m_mv_title_text\">社員クロストーク</h1>\n            <span class=\"all_m_mv_title_obj\"><img src=\"../images/crosstalk_txt_obj.svg\" alt=\"Cross talk\"></span>\n\t\t\t\t\t</div>\n          <figure class=\"all_m_mv_img\"><img src=\"../images/crosstalk_img_mv.jpg\" width=\"2800\" height=\"1400\" alt=\"社員クロストーク\"></figure>\n          <div class=\"all_m_mv_scroll\">\n            <p class=\"all_m_mv_scroll_img\"><img src=\"../images/all_img_mv_scroll.svg\" alt=\"SCROLL\"></p>\n          </div>\n\t\t\t\t</div></div><!-- /.all_m_mv -->\n\n        <div class=\"all_m_intro\">\n          <div class=\"all_l_wrap\">\n            <h2 class=\"all_m_intro_title all_c_title_en\" data-anim=\"fadeup\">・Introduction</h2>\n            <p class=\"all_m_intro_catch\" data-anim=\"fadeup\">お客様に、仕事に、<br class=\"all_mi_sp\">そして自分自身に。<br>向き合ったからこそ<br class=\"all_mi_sp\">成長できたと思います。</p>\n            <p class=\"all_m_intro_text\" data-anim=\"fadeup\">タキズミに2017年に入社した同期の仲良し4人によるクロストーク。入社のきっかけ、仕事への想い、タキズミのいいところなどNGワードなしの本音で話してもらいました。会社としてはちょっとハラハラもするのですが、当社への入社を検討されている方には、きっとお役に立つと思います。職種ごとのエピソードも全開！ぜひ最後までお読みください。</p>\n          </div>\n        </div><!-- /.all_m_intro -->\n\n        <div class=\"crosstalk_member\">\n          <div class=\"all_l_wrap\">\n            <h2 class=\"crosstalk_member_title all_c_title_en\" data-anim=\"fadeup\">・Member</h2>\n            <ul class=\"crosstalk_member_panel_list\">\n              <li class=\"crosstalk_member_panel\" data-anim=\"fadeup\">\n                <figure class=\"crosstalk_member_img\">\n                  <img src=\"../images/crosstalk_img_member01.jpg\" width=\"360\" height=\"274\" alt=\"画像\">\n                </figure>\n                <div class=\"crosstalk_member_label\">\n                  <p class=\"crosstalk_member_name\">H.S.</p>\n                  <p class=\"crosstalk_member_job\"><span>業務部</span></p>\n                </div>\n                <p class=\"crosstalk_member_text\">経理、人事、総務、情報セキュリティーなどバックオフィス全般を担当。</p>\n              </li>\n              <li class=\"crosstalk_member_panel\" data-anim=\"fadeup\">\n                <figure class=\"crosstalk_member_img\">\n                  <img src=\"../images/crosstalk_img_member02.jpg\" width=\"360\" height=\"274\" alt=\"画像\">\n                </figure>\n                <div class=\"crosstalk_member_label\">\n                  <p class=\"crosstalk_member_name\">K.U.</p>\n                  <p class=\"crosstalk_member_job\"><span>PMソリューション部施工管理グループ</span></p>\n                </div>\n                <p class=\"crosstalk_member_text\">オフィスビル、商業ビルなどの改修工事についてデザイン面、施工面、安全面などを管理。</p>\n              </li>\n              <li class=\"crosstalk_member_panel\" data-anim=\"fadeup\">\n                <figure class=\"crosstalk_member_img\">\n                  <img src=\"../images/crosstalk_img_member03.jpg\" width=\"360\" height=\"274\" alt=\"画像\">\n                </figure>\n                <div class=\"crosstalk_member_label\">\n                  <p class=\"crosstalk_member_name\">R.M.</p>\n                  <p class=\"crosstalk_member_job\"><span>管理ソリューション部</span></p>\n                </div>\n                <p class=\"crosstalk_member_text\">賃貸マンションの退去時における原状回復、リノベーション工事の管理などを担当。</p>\n              </li>\n              <li class=\"crosstalk_member_panel\" data-anim=\"fadeup\">\n                <figure class=\"crosstalk_member_img\">\n                  <img src=\"../images/crosstalk_img_member04.jpg\" width=\"360\" height=\"274\" alt=\"画像\">\n                </figure>\n                <div class=\"crosstalk_member_label\">\n                  <p class=\"crosstalk_member_name\">K.T.</p>\n                  <p class=\"crosstalk_member_job\"><span>PMソリューション部デザイン課</span></p>\n                </div>\n                <p class=\"crosstalk_member_text\">マンション、オフィスビルなどの改修においてデザインにおけるバリューアップを提案。</p>\n              </li>\n            </ul>\n          </div>\n        </div><!-- /.crosstalk_member -->\n\n        <div class=\"crosstalk_main\">\n          <div class=\"crosstalk_main_wrapper js-target-crosstalkFixed\">\n            <div class=\"crosstalk_main_menu\">\n              <div class=\"crosstalk_main_menu_inner\">\n                <p class=\"crosstalk_main_menu_title\">Page Index</p>\n                <ul class=\"crosstalk_main_menu_list\">\n                  <li class=\"crosstalk_main_menu_item\"><a href=\"#a-theme01\" data-no=\"1\" class=\"js-scroller is-current\">タキズミに入社したきっかけ・理由は？</a></li>\n                  <li class=\"crosstalk_main_menu_item\"><a href=\"#a-theme02\" data-no=\"2\" class=\"js-scroller\">職場の雰囲気はいかがですか？</a></li>\n                  <li class=\"crosstalk_main_menu_item\"><a href=\"#a-theme03\" data-no=\"3\" class=\"js-scroller\">タキズミのいいところは？</a></li>\n                  <li class=\"crosstalk_main_menu_item\"><a href=\"#a-theme04\" data-no=\"4\" class=\"js-scroller\">向き合って、強くなれたと感じたことは？</a></li>\n                  <li class=\"crosstalk_main_menu_item\"><a href=\"#a-theme05\" data-no=\"5\" class=\"js-scroller\">仕事をする上で大切にしていることは？</a></li>\n                  <li class=\"crosstalk_main_menu_item\"><a href=\"#a-theme06\" data-no=\"6\" class=\"js-scroller\">ランチはどうしていますか？</a></li>\n                  <li class=\"crosstalk_main_menu_item\"><a href=\"#a-theme07\" data-no=\"7\" class=\"js-scroller\">どんな仕事を担当したいですか？</a></li>\n                  <li class=\"crosstalk_main_menu_item\"><a href=\"#a-theme08\" data-no=\"8\" class=\"js-scroller\">タキズミへの入社を検討している方にメッセージを</a></li>\n                </ul>\n              </div>\n            </div>\n            <div class=\"crosstalk_main_body\">\n              <div class=\"all_l_wrap\">\n                <div id=\"a-theme01\" data-no=\"1\" class=\"crosstalk_main_section\">\n                  <h3 class=\"crosstalk_main_header\" data-anim=\"custom\">\n                    <span class=\"crosstalk_main_header_en all_c_title_en\">・Theme 01</span>\n                    <span class=\"crosstalk_main_header_text\">タキズミに入社したきっかけ・理由は？</span>\n                  </h3>\n                  <span class=\"crosstalk_main_header_obj\"><img src=\"../images/crosstalk_txt_num01.svg\" width=\"155\" height=\"166\" alt=\"01\"></span>\n                  <div class=\"crosstalk_main_voice\" data-anim=\"custom\">\n                    <div class=\"crosstalk_main_voice_icon\">\n                      <figure class=\"crosstalk_main_voice_icon_img\"><img src=\"../images/crosstalk_icon_member03.jpg\" width=\"160\" height=\"160\" alt=\"人物画像\"><figcaption>R.M.</figcaption></figure>\n                    </div>\n                    <div class=\"crosstalk_main_voice_box\">\n                      <p class=\"crosstalk_main_voice_text\">就活の時期に合同説明会がありまして。どこかいい会社ないかなと思いながら立ち寄ったブースの一つがタキズミでした。社長と色々とお話をしていると、「とりあえず面接に来ませんか？」となりまして。後日、会社を訪問して改めてお話しする機会をいただきました。事業の内容や社風の説明があって、その日の午後には内定をいただきました。もちろんご縁ということもありますけど、自分のキャラクターにあまりにも合っていたので、トントン拍子に話が進んでも、全く違和感がなかったんです。</p>\n                    </div>\n                  </div>\n                  <div class=\"crosstalk_main_voice _reverse\" data-anim=\"custom\">\n                    <div class=\"crosstalk_main_voice_icon\">\n                      <figure class=\"crosstalk_main_voice_icon_img\"><img src=\"../images/crosstalk_icon_member01.jpg\" width=\"160\" height=\"160\" alt=\"人物画像\"><figcaption>H.S.</figcaption></figure>\n                    </div>\n                    <div class=\"crosstalk_main_voice_box\">\n                      <p class=\"crosstalk_main_voice_text\">就職活動の中で唯一大事にしていたことは、「風通しのいい会社」で働きたいってことでした。そんな希望を理解してくれていたエージェントさんから連絡があって、お勧めの会社がありますということで面接を受けに行ったのがタキズミでした。いきなり社長面接で。でも、とてもフランクに接していただきました。それが午前中のことで、いい会社だなと思っていたらお昼過ぎにはエージェントさんから「おめでとうございます、内定です」と連絡がありました。私も「ぜひ、お願いします！」となりました。</p>\n                    </div>\n                  </div>\n                  <div class=\"crosstalk_main_voice\" data-anim=\"custom\">\n                    <div class=\"crosstalk_main_voice_icon\">\n                      <figure class=\"crosstalk_main_voice_icon_img\"><img src=\"../images/crosstalk_icon_member02.jpg\" width=\"160\" height=\"160\" alt=\"人物画像\"><figcaption>K.U.</figcaption></figure>\n                    </div>\n                    <div class=\"crosstalk_main_voice_box\">\n                      <p class=\"crosstalk_main_voice_text\">就職サイトに登録して、最初に紹介していただいたのがタキズミでした。私もH.S.さんと一緒で、いきなり社長面接。その後に専務をはじめ他の社員の方とも次々にお話しする機会があったんですが、皆さん本当に話しやすくて、面白くて、あたたかくて。この会社だったら自分も「素のまま」でやれるなと思ったんです。</p>\n                    </div>\n                  </div>\n                  <div class=\"crosstalk_main_voice _reverse\" data-anim=\"custom\">\n                    <div class=\"crosstalk_main_voice_icon\">\n                      <figure class=\"crosstalk_main_voice_icon_img\"><img src=\"../images/crosstalk_icon_member04.jpg\" width=\"160\" height=\"160\" alt=\"人物画像\"><figcaption>K.T.</figcaption></figure>\n                    </div>\n                    <div class=\"crosstalk_main_voice_box\">\n                      <p class=\"crosstalk_main_voice_text\">私は4年制の大学で文系の学部を卒業したんですが、子どもの頃からお部屋をどうコーディネートするかとか、インテリアに興味があって、その道に進みたいという夢が捨てられなかったんです。それで2年ほどインテリアの勉強をするために専門学校に通っていたところ、就職活動の時期にタキズミの社長が学校を訪問されて、運命が動いたという感じです。「ちょっと面接に来ませんか？」というお話で、面接後は即決となりました。だから、実はみんなと同じで、私もタキズミ1社しか受けていないんです。</p>\n                    </div>\n                  </div>\n                </div><!-- /#a-theme01 -->\n                <div id=\"a-theme02\" data-no=\"2\" class=\"crosstalk_main_section\">\n                  <h3 class=\"crosstalk_main_header\" data-anim=\"custom\">\n                    <span class=\"crosstalk_main_header_en all_c_title_en\">・Theme 02</span>\n                    <span class=\"crosstalk_main_header_text\">職場の雰囲気はいかがですか？</span>\n                  </h3>\n                  <span class=\"crosstalk_main_header_obj\"><img src=\"../images/crosstalk_txt_num02.svg\" width=\"196\" height=\"168\" alt=\"02\"></span>\n                  <div class=\"crosstalk_main_voice\" data-anim=\"custom\">\n                    <div class=\"crosstalk_main_voice_icon\">\n                      <figure class=\"crosstalk_main_voice_icon_img\"><img src=\"../images/crosstalk_icon_member01.jpg\" width=\"160\" height=\"160\" alt=\"人物画像\"><figcaption>H.S.</figcaption></figure>\n                    </div>\n                    <div class=\"crosstalk_main_voice_box\">\n                      <p class=\"crosstalk_main_voice_text\">多分、皆さん共通だと思うんですけど、明るい会社の一言に尽きますね。一般の従業員と同じスペースで社長も専務も働いていて、距離が近いですし、それこそ社員と経営層が話している時でも笑い声が聞こえることがあります。同期の仲もいいですし、先輩・後輩で普通に食事に行ったり、飲みに行ったりという関係ができています。若い社員が多くて、6割が20代というのも社内が明るく感じる理由かもしれないですね。</p>\n                    </div>\n                  </div>\n                  <div class=\"crosstalk_main_voice _reverse\" data-anim=\"custom\">\n                    <div class=\"crosstalk_main_voice_icon\">\n                      <figure class=\"crosstalk_main_voice_icon_img\"><img src=\"../images/crosstalk_icon_member04.jpg\" width=\"160\" height=\"160\" alt=\"人物画像\"><figcaption>K.T.</figcaption></figure>\n                    </div>\n                    <div class=\"crosstalk_main_voice_box\">\n                      <p class=\"crosstalk_main_voice_text\">私たちの職種は、部署や年齢の垣根を越えて仕事をすることが結構あるんですけど、そんなときも本当にみんなフランクでコミュニケーションがとりやすいんです。先輩社員が通りすがりに話しかけてくださったり、でも仕事の時はしっかり緊張感もあって。タキズミの成長の秘訣って、こんなところにもあるのかもしれませんね。</p>\n                    </div>\n                  </div>\n                  <div class=\"crosstalk_main_voice\" data-anim=\"custom\">\n                    <div class=\"crosstalk_main_voice_icon\">\n                      <figure class=\"crosstalk_main_voice_icon_img\"><img src=\"../images/crosstalk_icon_member02.jpg\" width=\"160\" height=\"160\" alt=\"人物画像\"><figcaption>K.U.</figcaption></figure>\n                    </div>\n                    <div class=\"crosstalk_main_voice_box\">\n                      <p class=\"crosstalk_main_voice_text\">右に同じです。これに関してはこれ以上言うことがないくらい。</p>\n                    </div>\n                  </div>\n                  <div class=\"crosstalk_main_voice _reverse\" data-anim=\"custom\">\n                    <div class=\"crosstalk_main_voice_icon\">\n                      <figure class=\"crosstalk_main_voice_icon_img\"><img src=\"../images/crosstalk_icon_member03.jpg\" width=\"160\" height=\"160\" alt=\"人物画像\"><figcaption>R.M.</figcaption></figure>\n                    </div>\n                    <div class=\"crosstalk_main_voice_box\">\n                      <p class=\"crosstalk_main_voice_text\">私も明るい会社だと思いますね。社長はむしろ冗談を言うと喜んでくださいますし。それだけ、私たちが意見や提案をしやすい環境を、普段から作ってくれているのだと感じます。</p>\n                    </div>\n                  </div>\n                </div><!-- /#a-theme02 -->\n              </div><!-- /.all_l_wrap -->\n              <div class=\"crosstalk_main_slide\" data-anim=\"fadein\">\n                <div class=\"crosstalk_main_slide_img\">\n                  <img src=\"../images/crosstalk_img_slide01.jpg\" width=\"1950\" height=\"450\" alt=\"社員クロストーク画像\">\n                  <img src=\"../images/crosstalk_img_slide01.jpg\" width=\"1950\" height=\"450\" alt=\"社員クロストーク画像\">\n                </div>\n              </div>\n              <div class=\"all_l_wrap\">\n                <div id=\"a-theme03\" data-no=\"3\" class=\"crosstalk_main_section\">\n                  <h3 class=\"crosstalk_main_header\" data-anim=\"custom\">\n                    <span class=\"crosstalk_main_header_en all_c_title_en\">・Theme 03</span>\n                    <span class=\"crosstalk_main_header_text\">タキズミのいいところは？</span>\n                  </h3>\n                  <span class=\"crosstalk_main_header_obj\"><img src=\"../images/crosstalk_txt_num03.svg\" width=\"197\" height=\"177\" alt=\"03\"></span>\n                  <div class=\"crosstalk_main_voice\" data-anim=\"custom\">\n                    <div class=\"crosstalk_main_voice_icon\">\n                      <figure class=\"crosstalk_main_voice_icon_img\"><img src=\"../images/crosstalk_icon_member02.jpg\" width=\"160\" height=\"160\" alt=\"人物画像\"><figcaption>K.U.</figcaption></figure>\n                    </div>\n                    <div class=\"crosstalk_main_voice_box\">\n                      <p class=\"crosstalk_main_voice_text\">私は以前、管理ソリューション部に所属していたので、PMソリューション部の施工管理グループに異動してきてまだ1年も経っていないんです。それで改めて実感したんですけど、タキズミって会社として幅広い工種を扱っているんですよね。だから所属部署や担当が変わると、それぞれの専門分野の知識やスキルが身に付くんです。それは社員にとっては成長につながるし、会社としても幅広い知識を持ったスタッフが多いということは強みにもなりますよね。</p>\n                    </div>\n                  </div>\n                  <div class=\"crosstalk_main_voice _reverse\" data-anim=\"custom\">\n                    <div class=\"crosstalk_main_voice_icon\">\n                      <figure class=\"crosstalk_main_voice_icon_img\"><img src=\"../images/crosstalk_icon_member01.jpg\" width=\"160\" height=\"160\" alt=\"人物画像\"><figcaption>H.S.</figcaption></figure>\n                    </div>\n                    <div class=\"crosstalk_main_voice_box\">\n                      <p class=\"crosstalk_main_voice_text\">いいところは、若い世代にも、どんどん責任ある仕事を任せてもらえるところですね。ここにいるメンバーはみんな入社5年目ですけど、最前線で活躍していますし。それは、プレッシャーでもあり、大変なことでもあるんですけど、やはり乗り越えたときの達成感の大きさは常日頃から感じていますね。</p>\n                    </div>\n                  </div>\n                  <div class=\"crosstalk_main_voice\" data-anim=\"custom\">\n                    <div class=\"crosstalk_main_voice_icon\">\n                      <figure class=\"crosstalk_main_voice_icon_img\"><img src=\"../images/crosstalk_icon_member04.jpg\" width=\"160\" height=\"160\" alt=\"人物画像\"><figcaption>K.T.</figcaption></figure>\n                    </div>\n                    <div class=\"crosstalk_main_voice_box\">\n                      <p class=\"crosstalk_main_voice_text\">本当に入社してすぐに大きな案件を任せてもらえるんです。これって他社ではなかなかないと思います。もちろん先輩社員がしっかりフォローしてくれます。自分の考えたこと、イメージしたものが形になるっていう、私の職種の醍醐味が早くから味わえて、やりがいも感じるし、お客様からの反応を直接いただけるのもいいですね。</p>\n                    </div>\n                  </div>\n                  <div class=\"crosstalk_main_voice _reverse\" data-anim=\"custom\">\n                    <div class=\"crosstalk_main_voice_icon\">\n                      <figure class=\"crosstalk_main_voice_icon_img\"><img src=\"../images/crosstalk_icon_member03.jpg\" width=\"160\" height=\"160\" alt=\"人物画像\"><figcaption>R.M.</figcaption></figure>\n                    </div>\n                    <div class=\"crosstalk_main_voice_box\">\n                      <p class=\"crosstalk_main_voice_text\">いいところは、社長や専務など経営層との距離が近いところ。それから、みんなも言ってましたけど、自分で担当を持つまでが早いんですよね。そこには当然、責任が発生するわけで、今日はこれをしよう、これは自分で決めようというように、早くから仕事を自分事としてとらえるようになることも、いいですよね。</p>\n                    </div>\n                  </div>\n                </div><!-- /#a-theme03 -->\n                <div id=\"a-theme04\" data-no=\"4\" class=\"crosstalk_main_section\">\n                  <h3 class=\"crosstalk_main_header\" data-anim=\"custom\">\n                    <span class=\"crosstalk_main_header_en all_c_title_en\">・Theme 04</span>\n                    <span class=\"crosstalk_main_header_text\">向き合って、強くなれたと感じたことは？</span>\n                  </h3>\n                  <span class=\"crosstalk_main_header_obj\"><img src=\"../images/crosstalk_txt_num04.svg\" width=\"193\" height=\"183\" alt=\"04\"></span>\n                  <div class=\"crosstalk_main_voice\" data-anim=\"custom\">\n                    <div class=\"crosstalk_main_voice_icon\">\n                      <figure class=\"crosstalk_main_voice_icon_img\"><img src=\"../images/crosstalk_icon_member04.jpg\" width=\"160\" height=\"160\" alt=\"人物画像\"><figcaption>K.T.</figcaption></figure>\n                    </div>\n                    <div class=\"crosstalk_main_voice_box\">\n                      <p class=\"crosstalk_main_voice_text\">入社して間もない頃は、お客様であるビルのオーナーの方や管理会社の方の方が施工のデザインについて知識があるんですよね。そこに専門職として対応しなければならない。やりがいがあると同時にプレッシャーで、心が折れかけたときもありました。でも、例えばお客様の方から、「この現場をベースに成長してね」と声を掛けてくださる方もいらっしゃって。恐らく、タキズミの過去の実績から、信頼があるからこそ、言ってくださると思うんです。頑張らなきゃと、必死になりました。そういう言葉が、今も励みになっていますね。</p>\n                    </div>\n                  </div>\n                  <div class=\"crosstalk_main_voice _reverse\" data-anim=\"custom\">\n                    <div class=\"crosstalk_main_voice_icon\">\n                      <figure class=\"crosstalk_main_voice_icon_img\"><img src=\"../images/crosstalk_icon_member03.jpg\" width=\"160\" height=\"160\" alt=\"人物画像\"><figcaption>R.M.</figcaption></figure>\n                    </div>\n                    <div class=\"crosstalk_main_voice_box\">\n                      <p class=\"crosstalk_main_voice_text\">私たちの仕事って、どうしても間に入ることが多いんです。お客様から発注いただいて、職人さんに作業してもらう。その間に入って、調整したり管理したりするのが役割です。ここ1、2年はコロナの影響もあって、お願いしていた職人の方が体調不良で来られなくなるとか、材料が入ってこないとかトラブルが多かったんです。私たちの仕事は、そんな予期しない事態にも対応することです。どんな時でも、冷静に向き合って、臨機応変に最善の判断をする知識と度胸が身に付いてきたと思います。</p>\n                    </div>\n                  </div>\n                  <div class=\"crosstalk_main_voice\" data-anim=\"custom\">\n                    <div class=\"crosstalk_main_voice_icon\">\n                      <figure class=\"crosstalk_main_voice_icon_img\"><img src=\"../images/crosstalk_icon_member02.jpg\" width=\"160\" height=\"160\" alt=\"人物画像\"><figcaption>K.U.</figcaption></figure>\n                    </div>\n                    <div class=\"crosstalk_main_voice_box\">\n                      <p class=\"crosstalk_main_voice_text\">数年前に担当した工事で規模の大きな現場がありまして。どんな手順で進めていけばいいのか想像がつかなくて、それでも自分なりに資料を見て手順を考えて、上司に相談したら「それじゃ、ちょっと厳しいんじゃないかな」と言われたんです。落ち込んでなんかいられないので、そこで頭を切り替えて、一から考え直すことに。わからないことは先輩に教えていただき、自分でも勉強して準備し直して、ようやく職人さんに作業してもらうところまでたどり着きました。後日、通行人の方が「ここ、きれいになったよね」と言いながら通り過ぎるのを見た時はうれしかったし、自分が力の足りない部分に向き合えたことで、一つ成長できたんだなと思いました。</p>\n                    </div>\n                  </div>\n                  <div class=\"crosstalk_main_voice _reverse\" data-anim=\"custom\">\n                    <div class=\"crosstalk_main_voice_icon\">\n                      <figure class=\"crosstalk_main_voice_icon_img\"><img src=\"../images/crosstalk_icon_member01.jpg\" width=\"160\" height=\"160\" alt=\"人物画像\"><figcaption>H.S.</figcaption></figure>\n                    </div>\n                    <div class=\"crosstalk_main_voice_box\">\n                      <p class=\"crosstalk_main_voice_text\">タキズミが担当する改修工事の中で、国や自治体から助成金が出る仕事があるんです。私は入社2年目に総務に異動してきて、社長に言われたのが「助成金大臣だからね」と。そこで、最初に担当したのが、数千万円単位の空調工事でした。辞書のような厚さの積算単価表をはじめ膨大な資料を前に最初は呆然として…。でも、ベテラン社員の方に読み方・見方を教えていただいたり、自分で勉強したり、とにかく必死で取り組みました。その時の自分、本当によく頑張ったなと思います。あの仕事を乗り越えてきたんだから、大抵のことは大丈夫。そんな自信にもつながりましたね。</p>\n                    </div>\n                  </div>\n                </div><!-- /#a-theme04 -->\n              </div><!-- /.all_l_wrap -->\n              <div class=\"crosstalk_main_slide\" data-anim=\"fadein\">\n                <div class=\"crosstalk_main_slide_img\">\n                  <img src=\"../images/crosstalk_img_slide02.jpg\" width=\"1950\" height=\"450\" alt=\"社員クロストーク画像\">\n                  <img src=\"../images/crosstalk_img_slide02.jpg\" width=\"1950\" height=\"450\" alt=\"社員クロストーク画像\">\n                </div>\n              </div>\n              <div class=\"all_l_wrap\">\n                <div id=\"a-theme05\" data-no=\"5\" class=\"crosstalk_main_section\">\n                  <h3 class=\"crosstalk_main_header\" data-anim=\"custom\">\n                    <span class=\"crosstalk_main_header_en all_c_title_en\">・Theme 05</span>\n                    <span class=\"crosstalk_main_header_text\">仕事をする上で大切にしていることは？</span>\n                  </h3>\n                  <span class=\"crosstalk_main_header_obj\"><img src=\"../images/crosstalk_txt_num05.svg\" width=\"186\" height=\"185\" alt=\"05\"></span>\n                  <div class=\"crosstalk_main_voice\" data-anim=\"custom\">\n                    <div class=\"crosstalk_main_voice_icon\">\n                      <figure class=\"crosstalk_main_voice_icon_img\"><img src=\"../images/crosstalk_icon_member01.jpg\" width=\"160\" height=\"160\" alt=\"人物画像\"><figcaption>H.S.</figcaption></figure>\n                    </div>\n                    <div class=\"crosstalk_main_voice_box\">\n                      <p class=\"crosstalk_main_voice_text\">三つあります。まず、どんな業務でも積極的にチャレンジすること。社内で依頼される仕事は未経験のことも多いですけど、それは社内の誰かに聞けば必ずわかるので、また一つできる仕事が増えたと、前向きに捉えます。二つ目はチームワークを大切にして、どんな社員の発言もしっかり聞くこと。先輩社員はもちろん、後輩の意見にも積極的に耳を傾けるようにしています。三つ目はどんな時も平常心を忘れないこと。ストレスがたまるようなことがあっても常に冷静さを心がける。その方がみんなに話しかけてもらいやすいし、意見や情報が集まってくるんです。</p>\n                    </div>\n                  </div>\n                  <div class=\"crosstalk_main_voice _reverse\" data-anim=\"custom\">\n                    <div class=\"crosstalk_main_voice_icon\">\n                      <figure class=\"crosstalk_main_voice_icon_img\"><img src=\"../images/crosstalk_icon_member02.jpg\" width=\"160\" height=\"160\" alt=\"人物画像\"><figcaption>K.U.</figcaption></figure>\n                    </div>\n                    <div class=\"crosstalk_main_voice_box\">\n                      <p class=\"crosstalk_main_voice_text\">私も三つあります。一つ目は専門知識がないと務まらない仕事なので、スキルを向上させること。自分の価値を上げるためでもありますよね。二つ目は今自分がやっていることが、お客様に喜んでもらえることかどうか常に考えること。自分がこうしたいからとか、こういうデザインが好きだからとかではなくて、お客様にとってメリットになるか考え続けます。そのことがお客様のためにも、結局自分のためにもなるんです。そして三番目は、自分がどう動いたら、会社の利益になるかを意識すること。これは、会社員としては当然なんですが、忘れがちな視点なので大切にしています。</p>\n                    </div>\n                  </div>\n                  <div class=\"crosstalk_main_voice\" data-anim=\"custom\">\n                    <div class=\"crosstalk_main_voice_icon\">\n                      <figure class=\"crosstalk_main_voice_icon_img\"><img src=\"../images/crosstalk_icon_member04.jpg\" width=\"160\" height=\"160\" alt=\"人物画像\"><figcaption>K.T.</figcaption></figure>\n                    </div>\n                    <div class=\"crosstalk_main_voice_box\">\n                      <p class=\"crosstalk_main_voice_text\">お客さまの要望をいかに深く汲み取るか、そしてプラスαの価値を提供できるのか、を大切にしています。デザイン業務なので、正解はないのですが、できるだけ皆さんに「いいね」「キレイになったね」「カッコよくなったね」と思っていただきたいですね。</p>\n                    </div>\n                  </div>\n                  <div class=\"crosstalk_main_voice _reverse\" data-anim=\"custom\">\n                    <div class=\"crosstalk_main_voice_icon\">\n                      <figure class=\"crosstalk_main_voice_icon_img\"><img src=\"../images/crosstalk_icon_member03.jpg\" width=\"160\" height=\"160\" alt=\"人物画像\"><figcaption>R.M.</figcaption></figure>\n                    </div>\n                    <div class=\"crosstalk_main_voice_box\">\n                      <p class=\"crosstalk_main_voice_text\">私は二つあります。私の担当している原状回復の仕事の中でも、中には特殊な工事の依頼があるんです。そんなときに、タキズミに、その中でもＲ.M.にお願いしたいって言っていただけるように実績と知識を増やすこと。それから、この仕事ってキツイ部分もあるので、なるべく楽しく仕事をするということ。業務の中に、自分なりの楽しさを見つけたいし、工事をしてキレイになることや、お客様に「ありがとう」と感謝されるのも楽しみですよね。私の対応の仕方一つで、自分だけではなくて周りの人も気分よく仕事ができるので、気を付けています。</p>\n                    </div>\n                  </div>\n                </div><!-- /#a-theme05 -->\n                <div id=\"a-theme06\" data-no=\"6\" class=\"crosstalk_main_section\">\n                  <h3 class=\"crosstalk_main_header\" data-anim=\"custom\">\n                    <span class=\"crosstalk_main_header_en all_c_title_en\">・Theme 06</span>\n                    <span class=\"crosstalk_main_header_text\">ランチはどうしていますか？</span>\n                  </h3>\n                  <span class=\"crosstalk_main_header_obj\"><img src=\"../images/crosstalk_txt_num05.svg\" width=\"186\" height=\"185\" alt=\"05\"></span>\n                  <div class=\"crosstalk_main_voice\" data-anim=\"custom\">\n                    <div class=\"crosstalk_main_voice_icon\">\n                      <figure class=\"crosstalk_main_voice_icon_img\"><img src=\"../images/crosstalk_icon_member01.jpg\" width=\"160\" height=\"160\" alt=\"人物画像\"><figcaption>H.S.</figcaption></figure>\n                    </div>\n                    <div class=\"crosstalk_main_voice_box\">\n                      <p class=\"crosstalk_main_voice_text\">社内にいることが多いので、隣のコンビニでお弁当やお惣菜を買うことが多いです。ちょっと歩くとラーメン屋、中華料理屋もあるので。実は今日は、R.M.さんとランチに行きました。</p>\n                    </div>\n                  </div>\n                  <div class=\"crosstalk_main_voice _reverse\" data-anim=\"custom\">\n                    <div class=\"crosstalk_main_voice_icon\">\n                      <figure class=\"crosstalk_main_voice_icon_img\"><img src=\"../images/crosstalk_icon_member04.jpg\" width=\"160\" height=\"160\" alt=\"人物画像\"><figcaption>K.T.</figcaption></figure>\n                    </div>\n                    <div class=\"crosstalk_main_voice_box\">\n                      <p class=\"crosstalk_main_voice_text\">内勤のときはコンビニが多いですね。外勤のときは都内を中心に色々な地域に行くので、現場の近くに美味しいレストランやカフェはないかなって、自分で調べたり、後輩社員が調べてくれたりします。毎日の楽しみの一つですね。</p>\n                    </div>\n                  </div>\n                  <div class=\"crosstalk_main_voice\" data-anim=\"custom\">\n                    <div class=\"crosstalk_main_voice_icon\">\n                      <figure class=\"crosstalk_main_voice_icon_img\"><img src=\"../images/crosstalk_icon_member02.jpg\" width=\"160\" height=\"160\" alt=\"人物画像\"><figcaption>K.U.</figcaption></figure>\n                    </div>\n                    <div class=\"crosstalk_main_voice_box\">\n                      <p class=\"crosstalk_main_voice_text\">私の場合は、昼の時間は現場にいることが多くて。コンビニでお弁当を買って、職人さんの車で一緒に食べています。こういうコミュニケーション、すごく大事にしています。食事をとって、コーヒーを飲んで、雑談する。一番心が打ち解けやすい時間でもあるので。</p>\n                    </div>\n                  </div>\n                  <div class=\"crosstalk_main_voice _reverse\" data-anim=\"custom\">\n                    <div class=\"crosstalk_main_voice_icon\">\n                      <figure class=\"crosstalk_main_voice_icon_img\"><img src=\"../images/crosstalk_icon_member03.jpg\" width=\"160\" height=\"160\" alt=\"人物画像\"><figcaption>R.M.</figcaption></figure>\n                    </div>\n                    <div class=\"crosstalk_main_voice_box\">\n                      <p class=\"crosstalk_main_voice_text\">私は、ほぼ外勤なので、都内の色々なところで食べています。ほとんどラーメンがベースになっていますね。(笑)　恵比寿だったら、この店とか、地域ごとにお目当ての店があります。「家系」のガッツリしたラーメンが好きですね。</p>\n                    </div>\n                  </div>\n                </div><!-- /#a-theme06 -->\n                <div id=\"a-theme07\" data-no=\"7\" class=\"crosstalk_main_section\">\n                  <h3 class=\"crosstalk_main_header\" data-anim=\"custom\">\n                    <span class=\"crosstalk_main_header_en all_c_title_en\">・Theme 07</span>\n                    <span class=\"crosstalk_main_header_text\">どんな仕事を担当したいですか？</span>\n                  </h3>\n                  <span class=\"crosstalk_main_header_obj\"><img src=\"../images/crosstalk_txt_num05.svg\" width=\"186\" height=\"185\" alt=\"05\"></span>\n                  <div class=\"crosstalk_main_voice\" data-anim=\"custom\">\n                    <div class=\"crosstalk_main_voice_icon\">\n                      <figure class=\"crosstalk_main_voice_icon_img\"><img src=\"../images/crosstalk_icon_member02.jpg\" width=\"160\" height=\"160\" alt=\"人物画像\"><figcaption>K.U.</figcaption></figure>\n                    </div>\n                    <div class=\"crosstalk_main_voice_box\">\n                      <p class=\"crosstalk_main_voice_text\">規模の大きな案件を担当したいですよね。仕事が大規模になると、色々な知識が必要になるし、調整も必要になるし、その分自分のスキルアップになって、会社にも貢献できると思うんです。</p>\n                    </div>\n                  </div>\n                  <div class=\"crosstalk_main_voice _reverse\" data-anim=\"custom\">\n                    <div class=\"crosstalk_main_voice_icon\">\n                      <figure class=\"crosstalk_main_voice_icon_img\"><img src=\"../images/crosstalk_icon_member01.jpg\" width=\"160\" height=\"160\" alt=\"人物画像\"><figcaption>H.S.</figcaption></figure>\n                    </div>\n                    <div class=\"crosstalk_main_voice_box\">\n                      <p class=\"crosstalk_main_voice_text\">将来的には経営のサポートができるようになりたいですね。経営層が会社の方向性を決めるときに、私がいま幅広く担当している業務の中から相応しい判断材料を提供するのが、自分の役割かなと考えています。</p>\n                    </div>\n                  </div>\n                  <div class=\"crosstalk_main_voice\" data-anim=\"custom\">\n                    <div class=\"crosstalk_main_voice_icon\">\n                      <figure class=\"crosstalk_main_voice_icon_img\"><img src=\"../images/crosstalk_icon_member04.jpg\" width=\"160\" height=\"160\" alt=\"人物画像\"><figcaption>K.T.</figcaption></figure>\n                    </div>\n                    <div class=\"crosstalk_main_voice_box\">\n                      <p class=\"crosstalk_main_voice_text\">入社して5年が経って小規模な案件を後輩に任せて、自分は大きなコンペ案件を担当するようになっています。会社として成長するには、こういう案件を取っていくことが必要なんです。私の担当しているデザインの力で引っ張ってきて、実績につなげるようにしたいですね。</p>\n                    </div>\n                  </div>\n                  <div class=\"crosstalk_main_voice _reverse\" data-anim=\"custom\">\n                    <div class=\"crosstalk_main_voice_icon\">\n                      <figure class=\"crosstalk_main_voice_icon_img\"><img src=\"../images/crosstalk_icon_member03.jpg\" width=\"160\" height=\"160\" alt=\"人物画像\"><figcaption>R.M.</figcaption></figure>\n                    </div>\n                    <div class=\"crosstalk_main_voice_box\">\n                      <p class=\"crosstalk_main_voice_text\">私は管理ソリューション部に所属しているんですが、マンションだけではなくて、オフィスビルや商業施設のお仕事を担当することも多くなっています。マンション以外の仕事を手がけることで、どんどん仕事の幅を広げてスキルアップしたいですね。</p>\n                    </div>\n                  </div>\n                </div><!-- /#a-theme07 -->\n                <div id=\"a-theme08\" data-no=\"8\" class=\"crosstalk_main_section\">\n                  <h3 class=\"crosstalk_main_header\" data-anim=\"custom\">\n                    <span class=\"crosstalk_main_header_en all_c_title_en\">・Theme 08</span>\n                    <span class=\"crosstalk_main_header_text\">タキズミへの入社を検討している方にメッセージを</span>\n                  </h3>\n                  <span class=\"crosstalk_main_header_obj\"><img src=\"../images/crosstalk_txt_num05.svg\" width=\"186\" height=\"185\" alt=\"05\"></span>\n                  <div class=\"crosstalk_main_voice\" data-anim=\"custom\">\n                    <div class=\"crosstalk_main_voice_icon\">\n                      <figure class=\"crosstalk_main_voice_icon_img\"><img src=\"../images/crosstalk_icon_member01.jpg\" width=\"160\" height=\"160\" alt=\"人物画像\"><figcaption>H.S.</figcaption></figure>\n                    </div>\n                    <div class=\"crosstalk_main_voice_box\">\n                      <p class=\"crosstalk_main_voice_text\">タキズミって30年以上の歴史があるんですけど、ベンチャー精神を持ち続けているんですよね。だから若い世代でも、どんどん責任ある仕事を任せてもらえるし、最前線で活躍できる環境が整っています。デザイン以外の部門では、未経験の方でも安心して働けます。チャレンジ精神があって、明るく前向きな方は、ぜひ私たちと一緒に働きましょう。</p>\n                    </div>\n                  </div>\n                  <div class=\"crosstalk_main_voice _reverse\" data-anim=\"custom\">\n                    <div class=\"crosstalk_main_voice_icon\">\n                      <figure class=\"crosstalk_main_voice_icon_img\"><img src=\"../images/crosstalk_icon_member02.jpg\" width=\"160\" height=\"160\" alt=\"人物画像\"><figcaption>K.U.</figcaption></figure>\n                    </div>\n                    <div class=\"crosstalk_main_voice_box\">\n                      <p class=\"crosstalk_main_voice_text\">今までずっと話してきましたけど、社内の雰囲気が本当によくて。未経験の方でも優しくフォローしてくれる人が多いので、安心して入ってきてください。明るい人なら大丈夫です。もしよければ、近くの居酒屋に一緒に飲みにいきましょう。</p>\n                    </div>\n                  </div>\n                  <div class=\"crosstalk_main_voice\" data-anim=\"custom\">\n                    <div class=\"crosstalk_main_voice_icon\">\n                      <figure class=\"crosstalk_main_voice_icon_img\"><img src=\"../images/crosstalk_icon_member04.jpg\" width=\"160\" height=\"160\" alt=\"人物画像\"><figcaption>K.T.</figcaption></figure>\n                    </div>\n                    <div class=\"crosstalk_main_voice_box\">\n                      <p class=\"crosstalk_main_voice_text\">正直言って、決してラクではないんですけれど、すごくやりがいを感じられる仕事なので、デザインの好きな方、自分のアイデアを発揮する場が欲しいと思っている方は、一緒に働くことができたら嬉しいです。</p>\n                    </div>\n                  </div>\n                  <div class=\"crosstalk_main_voice _reverse\" data-anim=\"custom\">\n                    <div class=\"crosstalk_main_voice_icon\">\n                      <figure class=\"crosstalk_main_voice_icon_img\"><img src=\"../images/crosstalk_icon_member03.jpg\" width=\"160\" height=\"160\" alt=\"人物画像\"><figcaption>R.M.</figcaption></figure>\n                    </div>\n                    <div class=\"crosstalk_main_voice_box\">\n                      <p class=\"crosstalk_main_voice_text\">とにかく面接に来てください。その時に社風が伝わると思います。この業界の知識がない方でも、明るければ何とかなります。入社の際は、ぜひＲ.M.をご指名ください。一緒に働きましょう。色んなことを経験していただけると思います。</p>\n                    </div>\n                  </div>\n                </div><!-- /#a-theme08 -->\n              </div><!-- /.all_l_wrap -->\n            </div><!-- /.crosstalk_main_body -->\n          </div><!-- /.crosstalk_main_wrapper -->\n          <figure class=\"crosstalk_main_visual\"><img src=\"../images/crosstalk_img_end.jpg\" width=\"1400\" height=\"600\" alt=\"画像\"></figure>\n        </div><!-- /.crosstalk_main -->\n\n        <div class=\"all_m_breadcrumb\">\n          <div class=\"all_l_wrap\">\n            <ul class=\"all_m_breadcrumb_list\">\n              <li class=\"all_m_breadcrumb_item\"><a href=\"../\">トップ</a></li>\n              <li class=\"all_m_breadcrumb_item _current\">社員クロストーク</li>\n            </ul>\n          </div>\n        </div><!-- /.all_m_breadcrumb -->\n\t\t\t</main><!-- /#main -->\n\n\t\t\t<div class=\"all_m_entry\">\n  <div class=\"all_m_entry_boxes\">\n    <div class=\"all_m_entry_box all_m_entry_recruitment\"><a href=\"/recruit/detail/\">\n      <span class=\"all_m_entry_box_filter\"></span>\n      <div class=\"all_m_entry_box_inner\">\n        <div class=\"all_m_entry_box_title_area\">\n          <p class=\"all_m_entry_box_title\">募集要項</p>\n        </div>\n        <div class=\"all_m_entry_box_btn\">\n          <span class=\"all_m_entry_box_btn_mark\"></span>\n        </div>\n      </div>\n      <span class=\"all_m_entry_box_obj\"><img src=\"/recruit/images/all_footer_txt_recruitment.svg\" alt=\"recruitment\"></span>\n    </a></div>\n    <div class=\"all_m_entry_box all_m_entry_entry\"><a href=\"/recruit/detail/#message\">\n      <span class=\"all_m_entry_box_filter\"></span>\n      <div class=\"all_m_entry_box_inner\">\n        <div class=\"all_m_entry_box_title_area\">\n          <p class=\"all_m_entry_box_title\">エントリー</p>\n        </div>\n        <div class=\"all_m_entry_box_btn\">\n          <span class=\"all_m_entry_box_btn_mark\"></span>\n        </div>\n      </div>\n      <span class=\"all_m_entry_box_obj\"><img src=\"/recruit/images/all_footer_txt_entry.svg\" alt=\"Entry\"></span>\n    </a></div>\n  </div><!-- /.all_m_entry_boxes -->\n</div><!-- /.all_m_entry -->\n\t\t\t<footer id=\"footer\" class=\"footer\">\n  <div class=\"footer_inner all_l_wrap\">\n    <div class=\"footer_content\">\n      <div class=\"footer_logo_area\">\n        <p class=\"footer_logo\"><a href=\"/recruit/\"><img src=\"/recruit/images/all_logo.jpg\" alt=\"株式会社タキズミ\"></a></p>\n        <p class=\"footer_logo_recruit\">RECRUIT SITE</p>\n      </div>\n      <div class=\"footer_nav\">\n        <ul class=\"footer_nav_list\">\n          <li class=\"footer_nav_item all_mi_pc\"><a href=\"/recruit/\">トップ</a></li>\n          <li class=\"footer_nav_item\"><a href=\"/recruit/business/\">事業紹介</a></li>\n          <li class=\"footer_nav_item\"><span>仕事を知る</span>\n            <div class=\"footer_nav_mega\">\n              <ul class=\"footer_megamenu\">\n                <li class=\"footer_megamenu_item\"><a href=\"/recruit/crosstalk/\">社員クロストーク</a></li>\n                <li class=\"footer_megamenu_item\"><a href=\"/recruit/workflow/\">1日の仕事の流れ</a></li>\n              </ul>\n            </div>\n          </li>\n          <li class=\"footer_nav_item\"><span>働く環境を知る</span>\n            <div class=\"footer_nav_mega\">\n              <ul class=\"footer_megamenu\">\n                <li class=\"footer_megamenu_item\"><a href=\"/recruit/training/\">キャリア・研修制度</a></li>\n                <li class=\"footer_megamenu_item\"><a href=\"/recruit/welfare/\">福利厚生</a></li>\n              </ul>\n            </div>\n          </li>\n        </ul>\n        <ul class=\"footer_nav_list\">\n          <li class=\"footer_nav_item\"><span>人を知る</span>\n            <div class=\"footer_nav_mega\">\n              <ul class=\"footer_megamenu\">\n                <li class=\"footer_megamenu_item\"><a href=\"/recruit/Interview01/\">社員インタビュー01</a></li>\n                <li class=\"footer_megamenu_item\"><a href=\"/recruit/Interview02/\">社員インタビュー02</a></li>\n                <!-- <li class=\"footer_megamenu_item\"><a href=\"/recruit/Interview03/\">社員インタビュー03</a></li>\n                <li class=\"footer_megamenu_item\"><a href=\"/recruit/Interview04/\">社員インタビュー04</a></li> -->\n              </ul>\n            </div>\n          </li>\n          <li class=\"footer_nav_item\"><a href=\"/recruit/detail/\">募集要項</a></li>\n        </ul>\n      </div><!-- /.footer_nav -->\n    </div><!-- /.footer_content -->\n    <div class=\"footer_bottom\">\n      <p class=\"footer_corporate\"><a href=\"http://www.takizumi.com/\" target=\"_blank\">コーポレートサイトはこちら</a></p>\n      <p class=\"footer_copy\">&copy; 2022 TAKIZUMI All Right Reserved.</p>\n    </div>\n  </div><!-- /.footer_inner -->\n</footer>\n\t\t</div><!-- /#page -->\n\t</div><!-- /#wrapper -->\n\n\t<script src=\"/recruit/js/jquery-3.4.1.min.js\"></script>\n<script src=\"/recruit/js/swiper/js/swiper.min.js\"></script>\n<script src=\"/recruit/js/velocity/1.5.2/velocity.js\"></script>\n<script src=\"/recruit/js/match-height/jquery.matchHeight.js\"></script>\n<script src=\"/recruit/js/perfect-scrollbar/perfect-scrollbar.js\"></script>\n<script src=\"/recruit/js/sticky-sidebar/jquery.sticky-sidebar.min.js\"></script>\n<script src=\"/recruit/js/common.js\"></script></body>\n</html>\n","finalUrl":"https://www.takizumi.com/recruit/crosstalk/","rendered":false,"_cachedAt":"2026-06-22T19:23:18.366Z"}