src=\"https://www.fujihensokuki.co.jp/wp-includes/js/jquery/jquery-migrate.min.js?ver=3.4.1\" defer></script><script src=\"https://www.fujihensokuki.co.jp/wp-content/themes/theme/js/scripts.js?ver=6.9.4\" defer></script><script src=\"https://www.fujihensokuki.co.jp/wp-content/themes/theme/js/imageMapResizer.min.js?ver=6.9.4\" defer></script><script src=\"https://www.fujihensokuki.co.jp/wp-content/themes/theme/js/gearmotor-search.js?ver=6.9.4\" defer></script><link rel=\"https://api.w.org/\" href=\"https://www.fujihensokuki.co.jp/wp-json/\" /><link rel=\"alternate\" title=\"JSON\" type=\"application/json\" href=\"https://www.fujihensokuki.co.jp/wp-json/wp/v2/pages/52\" /><link rel=\"canonical\" href=\"https://www.fujihensokuki.co.jp/recruit/career/\" />\n<link rel=\"alternate\" type=\"application/rss+xml\" title=\"富士変速機株式会社\" href=\"https://www.fujihensokuki.co.jp/feed/\">\n</head>\n\n<body>\n  <div class=\"wrap\">\n    <header class=\"header\">\n      <h1 class=\"header--logo\">\n        <a href=\"https://www.fujihensokuki.co.jp\">\n          <img src=\"https://www.fujihensokuki.co.jp/wp-content/themes/theme/img/common/logo.svg\" alt=\"タチカワブラインドグループ 富士変速機株式会社\">\n        </a>\n      </h1>\n      <button id=\"js-gnav_btn\" class=\"gnav_btn\">\n        <span class=\"gnav_btn--line\"></span>\n        <span class=\"gnav_btn--line\"></span>\n        <span class=\"gnav_btn--line\"></span>\n      </button>\n      <nav id=\"js-gnav\" class=\"gnav\">\n        <div class=\"container\">\n          <ul class=\"gnav--list\">\n            <li class=\"gnav--item js-gnav--item\">\n              <a href=\"/gearmotor/\">\n                ギヤード<br class=\"is-hidden_sp\">モータ\n              </a>\n              <ul>\n                <li><a href=\"/gearmotor/#gearmotor-search\">製品検索</a></li>\n                <li><a href=\"/gearmotor/select/\">機種選定依頼</a></li>\n                <li class=\"is-hidden_pc\"><a href=\"/contact-gearmotor/\">お問い合わせ</a></li>\n                <li class=\"is-hidden_pc\"><a href=\"/gearmotor/catalog/\">カタログダウンロード</a></li>\n              </ul>\n            </li>\n            <li class=\"gnav--item js-gnav--item\">\n              <a href=\"/parking/\">\n                パーキング<br class=\"is-hidden_sp\">システム\n              </a>\n              <ul>\n                <li><a href=\"/parking/tower/\">タワー式</a></li>\n                <li><a href=\"/parking/underground/\">地下式</a></li>\n                <li><a href=\"/parking/double/\">2段式</a></li>\n                <li><a href=\"/parking/network/\">サービスネットワーク</a></li>\n                <li class=\"is-hidden_pc\"><a href=\"/contact-parking/\">お問い合わせ</a></li>\n                <li class=\"is-hidden_pc\"><a href=\"/parking/download/\">カタログ・図面ダウンロード</a></li>\n              </ul>\n            </li>\n            <li class=\"gnav--item js-gnav--item\">\n              <a href=\"/about/\">\n                会社情報\n              </a>\n              <ul>\n                <li><a href=\"/about/history/\">沿革</a></li>\n                <li><a href=\"/about/office/\">事業所一覧</a></li>\n                <li><a href=\"/about/associated/\">関連会社</a></li>\n              </ul>\n            </li>\n            <!-- <li class=\"gnav--item js-gnav--item\">\n              <a href=\"/ir/\">\n                IR情報\n              </a>\n              <ul>\n                <li><a href=\"/ir/highlight/\">財務ハイライト</a></li>\n                <li><a href=\"/ir/library/\">IRライブラリー</a></li>\n                <li><a href=\"/ir/stock/\">株式情報</a></li>\n              </ul>\n            </li> -->\n            <li class=\"gnav--item js-gnav--item\">\n              <a href=\"/recruit/\">\n                リクルート\n              </a>\n              <ul>\n                <li><a href=\"/recruit/contents/\">会社紹介</a></li>\n                <li><a href=\"/recruit/new-graduate/\">新卒採用</a></li>\n                <li><a href=\"/recruit/career/\">中途採用</a></li>\n              </ul>\n            </li>\n            <li class=\"gnav--item js-gnav--item\">\n              <a href=\"/contact/\">\n                お問い合わせ\n              </a>\n              <ul>\n                <li><a href=\"/contact-gearmotor/\">ギヤードモータに関するお問い合わせ</a></li>\n                <li><a href=\"/contact-parking/\">パーキングシステムに関するお問い合わせ</a></li>\n                <li><a href=\"/contact/\">一般に関するお問い合わせ</a></li>\n                <li><a href=\"/contact-material/\">資材調達に関するお問い合わせ</a></li>\n              </ul>\n            </li>\n            <li class=\"gnav--item js-gnav--item\">\n              <a>\n                English\n              </a>\n              <ul>\n                <li><a href=\"https://www.fujihensokuki.co.jp/wp-content/themes/theme/pdf/english/pdf_corporate.pdf\" target=\"_blank\" rel=\"noopenner norefferer\">Corporate Profile</a></li>\n                <li><a href=\"/contact/\">Contact Us</a></li>\n              </ul>\n            </li>\n          </ul>\n        </div>\n      </nav>\n    </header>\n<main class=\"career_page\">\n      \n<div class=\"eyecatch -recruit\">\n  <div class=\"container\">\n    <div class=\"eyecatch--ttl\">\n      <h1>採用情報</h1>\n      <p>Recruit</p>\n    </div>\n  </div>\n</div>\n\n\n\n<nav class=\"nav_recruit u-mb80\">\n  <ul>\n    <a href=\"/recruit/contents/\">\n      <li>会社紹介</li>\n    </a>\n    <a href=\"/recruit/new-graduate/\">\n      <li>新卒採用</li>\n    </a>\n    <a>\n      <li>中途採用</li>\n    </a>\n  </ul>\n</nav>\n\n\n\n<div class=\"wp-block-custom-div recruit_info\">\n<div class=\"container_recruit\">\n    <h2 class=\"ttl_section -recruit\">中途情報</h2>\n\n\n\n    <table class=\"table_responsive\">\n        <tbody>\n            <tr>\n                <th>募集職種</th>\n                <td>\n                    ①営業職（減速機営業、パーキング営業、メンテナンス営業）<br>\n                    ②施工管理職<br>\n                    ③一級建築士事務所<br>\n                    ④加工・組立職<br>\n                    <br>\n                    <p class=\"u-mb20\">\n                        <span>①営業職</span><br>\n                        ・減速機営業［岐阜県岐阜市／東京都新宿区］<br>\n                        　技術・製造・品質保証部門と連携しながら、販売代理店やセットメーカへ<br>\n                        　減速機の製品説明・提案・手配を担当。<br>\n                        <br>\n                        ・メンテナンス営業［岐阜県岐阜市］<br>\n                        　ホテルやマンションなどに併設されている当社の機械式立体駐車場の<br>\n                        　メンテナンス契約の締結や改修工事の提案、客先窓口対応などを担当。<br>\n                        <br>\n                        ・パーキング営業［東京都新宿区］<br>\n                        　技術部門などと協力して、設計事務所やゼネコン、デベロッパーへ、<br>\n                        　機械式立体駐車場の製品説明・提案・受注を担当。<br>\n                    </p>\n                    <p class=\"u-mb20\">\n                        <span>②施工管理職［岐阜県岐阜市］</span><br>\n                        　機械式立体駐車場の施工監督として、工事全体の安全・品質・工程等を管理。\n                    </p>\n                    <p class=\"u-mb20\">\n                        <span>③一級建築士事務所［岐阜県岐阜市］</span><br>\n                        　機械式立体駐車場の新設工事に伴う、建築確認申請図・設備図などの作成<br>\n                        　および設計事務所との打ち合わせを担当。<br>\n                    </p>\n                    <p class=\"u-mb20\">\n                        <span>④加工・組立職［岐阜県美濃市］</span><br>\n                        ・加工職<br>\n                        　マシニングセンタ、NC旋盤、ボブ盤などを操作し、減速機の部材加工を担当。<br>\n                        <br>\n                        ・組立職<br>\n                        　電動ドライバなどを用いて減速機を組立てるほか、検品・梱包作業を担当。\n                    </p>\n                </td>\n            </tr>\n            <!--<tr>\n                <th>ハローワーク<br>事業所番号</th>\n                <td>2101-1778-5</td>\n            </tr>-->\n        </tbody>\n    </table>\n\n    <table class=\"table_responsive\">\n        <caption class=\"recruit_info--deco\">募集要項</caption>\n        <tbody>\n            <tr>\n                <th>雇用形態</th>\n                <td>\n                    正社員：営業、施工管理、一級建築士事業所<br>\n                    正社員およびパート：加工・組立<br>\n                </td>\n            </tr>\n            <tr>\n                <th>勤務時間</th>\n                <td>\n                    岐阜県岐阜市　8：30～17：30<br>\n                    東京都新宿区　9：00～18：00<br>\n                    岐阜県美濃市　8：00～17：00※<br>\n                    ※パートは8：00～17：00の間で5～6時間以上勤務できる方。<br>\n                    　時間帯などは応相談。\n                </td>\n            </tr>\n            <tr>\n                <th>募集事業所</th>\n                <td>\n                    本社（岐阜県岐阜市）：営業（減速機、メンテナンス）、施工管理、一級建築士事務所<br>\n                    東京支店（新宿区）：営業（減速機、パーキング）<br>\n                    美濃工場（岐阜県美濃市）：加工・組立\n                </td>\n            </tr>\n            <tr>\n                <th>給与</th>\n                <td>\n                    ［正社員］月額195,800円～435,600円　［パート］時給1,065円～<br>\n                    ※年齢・経験を考慮の上、当社規定により決定<br>\n                    ※残業代別途支給<br>\n                    ※試用期間3ヵ月あり（給与、待遇条件は同じ）<br>\n                </td>\n            </tr>\n            <tr>\n                <th>諸手当</th>\n                <td>\n                    営業外交手当、世帯主手当、時間外勤務手当、特技手当、地域手当　等<br>\n                    通勤費50,000円まで実費支給<br>\n                </td>\n            </tr>\n            <tr>\n                <th>昇給</th>\n                <td>\n                    年1回（4月）<br>\n                </td>\n            </tr>\n            <tr>\n                <th>賞与</th>\n                <td>\n                    年2回（6月、12月）　※支給額は業績・勤務成績により変動\n                </td>\n            </tr>\n            <tr>\n                <th>休日休暇</th>\n                <td>\n                    休日：完全週休二日制（土・日）、祝祭日、年末年始（年間休日124日）<br>\n                    休暇：有給休暇、慶弔時特別休暇、産前産後休暇、リフレッシュ休暇制度<br>\n                    &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;\n                    ストック休暇、介護休暇、子の看護休暇　等<br>\n                    休業：育児休業、介護休業、私傷病給食　等\n                </td>\n            </tr>\n            <tr>\n                <th>教育制度</th>\n                <td>\n                    階層別研修、通信教育制度　等<br>\n                </td>\n            </tr>\n            <tr>\n                <th>福利厚生</th>\n                <td>\n                    ［保険］雇用保険、健康保険、厚生年金、労災<br>\n                    ［制度］持株会、財形貯蓄、退職金制度、長期所得補償制度(LTD) 等<br>\n                    ［施設］借上社宅、全国の保養所（立川ブラインドグループ・提携施設）\n                </td>\n            </tr>\n        </tbody>\n    </table>\n\n    <table class=\"table_responsive\">\n        <caption class=\"recruit_info--deco\">募集要項</caption>\n        <tbody>\n            <tr>\n                <th>採用条件</th>\n                <td>\n                    高卒以上、普通自動車免許をお持ちの方　　※経験者なお可<br>\n                </td>\n            </tr>\n            <tr>\n                <th>選考方法</th>\n                <td>\n                    個人面接、適性検査（SPI） ※面接重視<br>\n                </td>\n            </tr>\n            <tr>\n                <th>提出書類</th>\n                <td>\n                    履歴書、職務経歴書<br>\n                </td>\n            </tr>\n            <tr>\n                <th>応募方法</th>\n                <td>\n                    メールまたは郵送にて、総務経理課宛てに書類をご提出ください。<br>\n                    ※希望職種を明記<br>\n                    E-mail：jinji@fujihensokuki.co.jp<br>\n                    住　所：〒500-8448　岐阜県岐阜市中洲町18番地　総務経理課宛<br>\n                    電　話：058-271-6521<br>\n                    ※頂いた個人情報は、選考及び付随するご案内、ご連絡にのみ使用させていただきます。\n                </td>\n            </tr>\n        </tbody>\n    </table>\n</div>\n</div>\n\n\n\n<nav id=\"js-sidenav\" class=\"sidenav -recruit\">\r\n  <ul class=\"sidenav--list\">\r\n    <li><a href=\"/contact/\" class=\"sidenav--item -contact\">お問い合わせ</a></li>\r\n    <li><button class=\"js-totop sidenav--totop\"><img decoding=\"async\" src=\"/wp-content/themes/theme/img/common/icon_triangle.svg\" alt=\"ページトップに戻る\"></button></li>\r\n  </ul>\r\n</nav>\n  </main>\n\n<footer class=\"footer\">\n  <img src=\"https://www.fujihensokuki.co.jp/wp-content/themes/theme/img/common/totop.svg\" alt=\"ページトップへ\" class=\"js-totop footer_totop\">\n  <div class=\"container\">\n    <ul class=\"sitemap\">\n      <li class=\"sitemap--item\">\n        <a href=\"/gearmotor/\">ギヤードモータ</a>\n        <ul>\n          <li><a href=\"/gearmotor/#gearmotor-search\">製品検索</a></li>\n          <li><a href=\"/gearmotor/select/\">機種選定依頼</a></li>\n        </ul>\n      </li>\n      <li class=\"sitemap--item\">\n        <a href=\"/parking/\">パーキングシステム</a>\n        <ul>\n          <li><a href=\"/parking/tower/\">タワー式</a></li>\n          <li><a href=\"/parking/underground/\">地下式</a></li>\n          <li><a href=\"/parking/double/\">2段式</a></li>\n          <li><a href=\"/parking/network/\">サービスネットワーク</a></li>\n        </ul>\n      </li>\n      <li class=\"sitemap--item\">\n        <a href=\"/about/\">会社情報</a>\n        <ul>\n          <li><a href=\"/about/history/\">沿革</a></li>\n          <li><a href=\"/about/office/\">事業所一覧</a></li>\n          <li><a href=\"/about/associated/\">関連会社</a></li>\n        </ul>\n      </li>\n       <!-- <li class=\"sitemap--item\">\n        <a href=\"/ir/\">IR情報</a>\n        <ul>\n          <li><a href=\"/ir/highlight/\">財務ハイライト</a></li>\n          <li><a href=\"/ir/library/\">IRライブラリー</a></li>\n          <li><a href=\"/ir/stock/\">株式情報</a></li>\n        </ul>\n      </li> -->\n      <li class=\"sitemap--item\">\n        <a href=\"/recruit/\">リクルート</a>\n        <ul>\n          <li><a href=\"/recruit/new-graduate/\">募集要項</a></li>\n        </ul>\n      </li>\n      <li class=\"sitemap--item is-hidden_sp\">\n        <a href=\"/contact/\">お問い合わせ</a>\n        <ul>\n          <li><a href=\"/contact-gearmotor/\">ギヤードモータに関するお問い合わせ</a></li>\n          <li><a href=\"/contact-parking/\">パーキングシステムに関するお問い合わせ</a></li>\n          <li><a href=\"/contact/\">一般に関するお問い合わせ</a></li>\n          <li><a href=\"/contact-material/\">資材調達に関するお問い合わせ</a></li>\n        </ul>\n      </li>\n      <li class=\"sitemap--item is-hidden_sp\">\n        その他\n        <ul>\n          <li><a href=\"/privacy-policy/\">プライバシーポリシー</a></li>\n          <li><a href=\"/specific-privacy-policy/\">特定個人情報保護方針</a></li>\n          <li><a href=\"/tos/\">ご利用規約</a></li>\n        </ul>\n      </li>\n\n      <li class=\"sitemap--item is-hidden_pc\">\n        <a href=\"/contact-gearmotor/\">ギヤードモータに関するお問い合わせ</a>\n      </li>\n      <li class=\"sitem