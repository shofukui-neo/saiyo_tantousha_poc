max-width: 767px) {\n                body .l-header .btn-contact a span::before {\n                    width: 22px;\n                    height: 13px;\n                }\n\n            }\n\n        </style> -->\n    </header>\n<!-- InstanceBeginEditable name=\"Edit headingarea\" -->\n<div id=\"headingarea\" class=\"headingarea service temporary-staffing\">\n\t<div class=\"headingarea__tit\">\n\t\t<div class=\"headingarea__tit-inner\">\n\t\t\t<h1>人材サービス</h1>\n\t\t\t<p><p>人材サービスは、グループ会社の株式会社アイ・エス・エスより提供します。</p><br><div class=\"block-btn\"><div class=\"col-set\"><div class=\"col1-2\"><div class=\"btn w-auto icon-window\"><a href=\"https://haken.issjp.com/b2b\" rel=\"noopener\" target=\"_blank\">アイ・エス・エスはこちら</a></div></div> </div><!-- /col-set --></div></p>\n\t\t</div>\n\t</div>\n\t<div class=\"headingarea__img\"></div>\n\t<div class=\"scroll-bar\"></div>\n</div>\n<div class=\"content\">\n<main class=\"main\">\n<div class=\"row\">\n<div class=\"breadcrumb\">\n\t<ul>\n\t\t<li><a href=\"/\">翻訳センタートップ</a></li>\n\t\t<li><a href=\"/service/\">サービス</a></li>\n\t\t<li class=\"current\">人材サービス</li>\n\t</ul>\n</div>\n</div>\n<div class=\"row txt-box\">\r\n\t<h2>通訳、翻訳など語学に特化した人材派遣・人材紹介サービス</h2>\r\n\t<!--<p>通訳、翻訳、バイリンガル秘書など、語学に特化した人材派遣、紹介予定派遣、人材紹介サービスを提供しています。</p>-->\r\n</div><!-- /.row -->\r\n\t<div id=\"service-temporary-staffing01\" class=\"service-panel-covered txt-bg\">\r\n\t\t<div class=\"row\">\r\n\t\t\t<div class=\"txt-area\">\r\n\t\t\t\t<p class=\"sub_title\">人事ご担当者さま</p>\r\n\t\t\t\t<p style=\"margin-bottom:40px;\">多様化・専門化したお客さまのニーズにお応えするため、当社独自の厳正な選定プログラムにより、優れた語学力、ヒューマン・スキルを備えた質の高いスタッフを多数揃えています。<br>また、（株）アイ・エス・エスの通訳者・翻訳者養成スクールと連携し、高度な語学スキルを備えた人材の養成にも力を注いでいます。</p>\r\n                                <p class=\"sub_title\">お仕事をお探しの方</p>\r\n\t\t\t\t<p>（株）アイ・エス・エスは、60年におよぶ信頼と実績を誇る、通訳・翻訳の専門エージェントです。<br>すでにプロとして活躍されている方はもちろん、これからキャリアアップを目指されている方も、私たちにお任せください。</p>\r\n\t\t\t</div>\r\n\t\t</div><!-- /.row -->\r\n\t</div>\r\n<!-- 20190626追加 -->\r\n<div class=\"row txt-box\">\r\n  <div class=\"regist-job-list\">\r\n   <h3>株式会社アイ・エス・エス<br class=\"show-sp\">&ensp;人材サービス事業部のお仕事情報</h3>\r\n         <ul class=\"news\">\r\n<!--             <li><a href=\"https://haken.issjp.com/jobs/detail/1019\" rel=\"noopener\" target=\"_blank\"><div class=\"meta-data\" style=\"width:25%;\"><span class=\"label-icon\">急募</span><span class=\"job-num\">お仕事番号:005-02711</span></div>\r\n              <p>＊同時通訳経験者歓迎＊NYに本社がある外資系広告代理店で通訳・翻訳のお仕事　東京都港区</p>\r\n            </a></li>\r\n            <li><a href=\"https://haken.issjp.com/jobs/detail/540\" rel=\"noopener\" target=\"_blank\"><div class=\"meta-data\" style=\"width:25%;\"><span class=\"label-icon\">急募</span><span class=\"job-num\">お仕事番号:019-02597</span></div>\r\n              <p>【高時給！4000円〜】外資系テーマパークでの英語通訳翻訳（通訳メイン/同時通訳） 大阪市</p>\r\n            </a></li>\r\n            <li><a href=\"https://haken.issjp.com/jobs/detail/897\" target=\"_blank\"><div class=\"meta-data\" style=\"width:25%;\"><span class=\"label-icon\">急募</span><span class=\"job-num\">お仕事番号:015-02374</span></div>\r\n              <p>英語　通訳　外資系ITコンサルティング会社にてプール制通訳・翻訳のお仕事　港区</p>\r\n            </a></li> -->\r\n        </ul> \r\n        <div class=\"btn\"><a href=\"https://haken.issjp.com/jobs\" rel=\"noopener\" target=\"_blank\">仕事情報一覧を見る</a></div>\r\n  </div>\r\n</div>\r\n<!-- 20190626追加 -->\r\n<div class=\"row\">\r\n\t<div class=\"box-a\">\r\n\t\t<div class=\"col-set service-box-set\">\r\n\t\t\t<div class=\"col1-2\">\r\n\t\t\t<h4 class=\"mb10\">サービス形態</h4>\r\n\t\t\t\t<ul class=\"line-adjust0\">\r\n\t\t\t\t\t<li>人材派遣</li>\r\n\t\t\t\t\t<li>紹介予定派遣</li>\r\n\t\t\t\t\t<li>人材紹介</li>\r\n\t\t\t\t\t<li>アウトソーシング・BPO</li>\r\n\t\t\t\t</ul>\r\n\t\t\t<h4 class=\"mb10\">対応職種</h4>\r\n\t\t\t\t<ul class=\"line-adjust0\">\r\n\t\t\t\t\t<li>通訳</li>\r\n\t\t\t\t\t<li>翻訳</li>\r\n\t\t\t\t\t<li>コーディネーター</li>\r\n\t\t\t\t\t<li>セクレタリー</li>\r\n\t\t\t\t\t<li>アシスタント</li>\r\n\t\t\t\t\t<li>英文事務</li>\r\n\t\t\t\t\t<li>その他</li>\r\n\t\t\t\t</ul>\r\n\t\t\t</div>\r\n\t\t\t<div class=\"col1-2\">\r\n\t\t