/2026/02/20260401_2-768x576.jpg 768w, https://www.nttdata-ncb.co.jp/manager/wp-content/uploads/2026/02/20260401_2-1536x1152.jpg 1536w, https://www.nttdata-ncb.co.jp/manager/wp-content/uploads/2026/02/20260401_2-2048x1536.jpg 2048w\" sizes=\"(max-width: 245px) 100vw, 245px\" />　<img decoding=\"async\" class=\"alignnone wp-image-1297\" src=\"https://www.nttdata-ncb.co.jp/manager/wp-content/uploads/2026/02/20260401_1-300x225.jpg\" alt=\"\" width=\"245\" height=\"184\" srcset=\"https://www.nttdata-ncb.co.jp/manager/wp-content/uploads/2026/02/20260401_1-300x225.jpg 300w, https://www.nttdata-ncb.co.jp/manager/wp-content/uploads/2026/02/20260401_1-1024x768.jpg 1024w, https://www.nttdata-ncb.co.jp/manager/wp-content/uploads/2026/02/20260401_1-768x576.jpg 768w, https://www.nttdata-ncb.co.jp/manager/wp-content/uploads/2026/02/20260401_1-1536x1152.jpg 1536w, https://www.nttdata-ncb.co.jp/manager/wp-content/uploads/2026/02/20260401_1-2048x1536.jpg 2048w\" sizes=\"(max-width: 245px) 100vw, 245px\" /></p>\n    </div>\n\n  </div>\n</div>\n\n            </main><!-- l-main -->\n        </div><!-- /l-contents-detail -->\n      </div><!-- /l-contents -->\n\n      <footer class=\"l-footer\">\n  <p class=\"l-footer-title\">株式会社NTTデータNCB</p>\n  <ul class=\"l-footer-links__ul\">\n    <li class=\"l-footer-links__li\">\n      <a href=\"/message/\" class=\"l-footer-links__inner\">\n        <span>トップメッセージ</span>\n      </a>\n    </li>\n    <li class=\"l-footer-links__li\">\n      <a href=\"/business/\" class=\"l-footer-links__inner\">\n        <span>事業紹介</span>\n      </a>\n    </li>\n    <li class=\"l-footer-links__li\">\n      <a href=\"/company/\" class=\"l-footer-links__inner\">\n        <span>企業情報</span>\n      </a>\n    </li>\n    <li class=\"l-footer-links__li\">\n      <a href=\"/csr/\" class=\"l-footer-links__inner\">\n        <span>私たちの取り組み</span>\n      </a>\n    </li>\n    <li class=\"l-footer-links__li\">\n      <a href=\"/recruit/\" class=\"l-footer-links__inner\">\n        <spa