{"url":"https://www.kinon.co.jp/recruit/requirements.shtml","html":"<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\">\n<meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width\" />\n<meta name=\"format-detection\" content=\"telephone=no\">\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/common.css\" />\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/zone.css\" />\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/bpts.css\" />\n<!-- Basic parts -->\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/unit.css\" />\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/col.css\" />\n<!-- 本文領域レイアウタ -->\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/other.css\" />\n<link rel=\"stylesheet\" type=\"text/css\" href=\"css/local.css\" />\n<title>募集要項│Recruit│キノンビクス株式会社</title>\n<style>\n.bpts_footer_recruit {\n    display: none;\n}\n</style>\n<!-- スクリプトのインクルード（事前呼び出し） --> \n<meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\" />\n<link rel=\"icon\" href=\"../favicon.ico\">\n\n<!-- fontawesome -->\n<link href=\"https://use.fontawesome.com/releases/v5.6.1/css/all.css\" rel=\"stylesheet\">\n\n\n</head>\n<body>\n<div id=\"zone_sheet\"> \n  <!-- ヘッダーのインクルード --> \n  <meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\" />\n<!--\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/css/other.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/css/bpts.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/css/common.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/css/zone.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/css/unit.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/css/col.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/css/other.css\"/>\n -->\n<div class=\"header_bg\">\n<div class=\"header_logo\"><a href=\"../../\"><img src=\"../image/common/logo.svg\"></a></div>\n<nav class=\"pc_menu\">\n  <div class=\"o_mainmenu\">\n    <ul>\n      <li><a href=\"../about/\">About us</a>\n        <ul>\n          <li><a href=\"/about/index.shtml\">代表挨拶</a></li>\n          <li><a href=\"/about/overview.shtml\">会社概要</a></li>\n          <li><a href=\"/about/philosophy.shtml\">経営理念</a></li>\n          <li><a href=\"/about/promises.shtml\">7つのお約束</a></li>\n          <li><a href=\"/about/history.shtml\">沿革</a></li>\n          <li><a href=\"/about/employee.shtml\">社員保有資格一覧</a></li>\n          <li><a href=\"/about/certifications.shtml\">各種認定と宣言</a></li>\n        </ul>\n      </li>\n      <li><a href=\"../culture/\">Culture</a></li>\n      <li><a href=\"../solution/\">Solution</a>\n        <ul>\n          <li><a href=\"../solution/index.shtml#jump_01\">システムソリューション</a></li>\n          <li><a href=\"../solution/index.shtml#s_index_section02\">場所から探す</a></a></li>\n          <li><a href=\"../solution/index.shtml#s_index_section03\">納入事例</a></a></li>\n        </ul>\n      </li>\n      <li><a href=\"../recruit/\">Recruit</a>\n        <ul>\n          <li><a href=\"/recruit/\">採用情報</a></li>\n          <li><a href=\"/recruit/job.shtml\">職種紹介</a></li>\n          <li><a href=\"/recruit/interview.shtml\">社員インタビュー</a></li>\n          <li><a href=\"/recruit/requirements.shtml\">募集要項</a></li>\n        </ul>\n      </li>\n      <li><a href=\"../misc/contact.shtml\">Contact</a></li>\n    </ul>\n  </div>\n</nav>\n</div>\n<!-- レスポンシブメニュー　 -->\n<header>\n<div class=\"header-logo-menu\">\n<div id=\"nav-drawer\">\n<input id=\"nav-input\" type=\"checkbox\" class=\"nav-unshown\">\n<label id=\"nav-open\" for=\"nav-input\">\n<span></span>\n<p class=\"label_txt_menu\">MENU</p>\n</label>\n<label class=\"nav-unshown\" id=\"nav-close\" for=\"nav-input\"></label>\n<div id=\"nav-content\">\n<!--  ----------------- -->\n<div class=\"accordion\"> \n  <!-- menu1 -->\n  <div class=\"option\">\n    <input type=\"checkbox\" id=\"toggle1\" class=\"toggle\">\n    <label class=\"title item10\" for=\"toggle1\">About us</label>\n    <div class=\"content\">\n      <ul>\n        <li class=\"f_m10_10\"><a href=\"/about/index.shtml\">代表挨拶</a></li>\n        <li class=\"f_m10_20\"><a href=\"/about/overview.shtml\">会社概要</a></li>\n        <li class=\"f_m10_30\"><a href=\"/about/philosophy.shtml\">経営理念</a></li>\n        <li class=\"f_m10_40\"><a href=\"/about/promises.shtml\">7つのお約束</a></li>\n        <li class=\"f_m10_50\"><a href=\"/about/history.shtml\">沿革</a></li>\n        <li class=\"f_m10_60\"><a href=\"/about/employee.shtml\">社員保有資格一覧</a></li>\n        <li class=\"f_m10_70\"><a href=\"/about/certifications.shtml\">各種認定と宣言</a></li>\n      </ul>\n    </div>\n  </div>\n  <!-- menu2 -->\n  <div class=\"option\">\n    <div class=\"one_link\"><a href=\"../culture/\">Culture</a></div>\n  </div>\n  <!-- menu3 -->\n  <div class=\"option\">\n    <input type=\"checkbox\" id=\"toggle3\" class=\"toggle\">\n    <label class=\"title item50\" for=\"toggle3\">Solution</label>\n    <div class=\"content\">\n      <ul>\n        <li class=\"f_m30_10\"><a href=\"../solution/index.shtml#sp_jump_01\">システムソリューション</a></li>\n        <li class=\"f_m30_20\"><a href=\"../solution/index.shtml#jump_15\">場所から探す</a></a></li>\n        <li class=\"f_m30_30\"><a href=\"../solution/index.shtml#jump_02\">納入事例</a></a></li>\n      </ul>\n    </div>\n  </div>\n  <!-- menu4 -->\n  <div class=\"option\">\n    <input type=\"checkbox\" id=\"toggle4\" class=\"toggle\">\n    <label class=\"title item60\" for=\"toggle4\">Recruit</label>\n    <div class=\"content\">\n      <ul>\n        <li class=\"f_m40_10\"><a href=\"/recruit/\">採用情報</a></li>\n        <li class=\"f_m40_20\"><a href=\"/recruit/job.shtml\">職種紹介</a></li>\n        <li class=\"f_m40_30\"><a href=\"/recruit/interview.shtml\">社員インタビュー</a></li>\n        <li class=\"f_m40_40\"><a href=\"/recruit/requirements.shtml\">募集要項</a></li>\n      </ul>\n    </div>\n  </div>\n  <!-- menu5 -->\n  <div class=\"option\">\n    <div class=\"one_link\"><a href=\"../misc/contact.shtml\">Contact</a></div>\n  </div>\n<!-- menu6 -->\n  <div class=\"option\">\n    <div class=\"one_link\"><a href=\"../\">Home</a></div>\n  </div>\n</div alt=\"eod:accordion\">\n</header>\n<!-- --------------------------------------------------- --> \n\n \n  <!-- ヘッダーのインクルード 終わり　--> \n  \n  <!-- ステージ-->\n  <div id=\"zone_substage\">\n    <div>\n      <h1>募集要項</h1>\n    </div>\n    <!--- パンくず -->\n    <ol class=\"zone_pankuzu\">\n      <li><a href=\"../\">HOME</a></li>\n      <li><a href=\"/recruit/\">Recruit</a></li>\n      <li>募集要項</li>\n    </ol>\n    <!-- パンくず --> \n  </div alt=\"eod:zone_substage\">\n  <!-- ステージ　終わり --> \n  <!-- 第2層 -->\n  <div id=\"zone_middle_floor\"> \n    <!--　ボディ領域　-->\n    <div id=\"zone_body\"> \n      <!--　メインエリア　-->\n      <div id=\"zone_mainarea_1col\">\n        <div class=\"sp_padding\"> \n          \n          <!--　▼▼▼　本文領域　▼▼▼　-->\n          <div class=\"col_textarea_full\">\n            <section id=\"req-section\"> \n              \n              <!-- 大見出し -->\n              <h2 class=\"col_midashi_pagetop\" data-en=\"Open Positions\"> <span>募集職種</span> </h2 alt=\"eod:col_midashi_pagetop\">\n              <div class=\"center\">\n                <p class=\"center\">現在募集中の職種の詳細は<span class=\"bpts_br\"></span>採用特設ページにてご確認ください。</p>\n                <a href=\"https://en-gage.net/kinon_saiyo/?banner=1\" class=\"bpts_btn_border red\" target=\"_blank\" rel=\"noopener norefe\"><span class=\"link_targetblank\">採用特設ページ</span></a></div>\n              <div class=\"bpts_spacer_h40\"></div>\n            </section>\n            <section id=\"section_req_table\"> \n              \n              <!-- 大見出し -->\n              <h2 class=\"col_midashi_pagetop\" data-en=\"Job Details\"> <span>募集要項</span> </h2 alt=\"eod:col_midashi_pagetop\">\n              \n              <!--　▼▼▼　１件分　▼▼▼　-->\n              <div class=\"unit_table_side\">\n                <table>\n                  <tbody>\n                    <tr>\n                      <th>応募資格</th>\n                      <td> 高卒以上～35才位まで　学部不問<br>\n                        <h5>必須の経験・スキル</h5>\n                        <ul class=\"col_mark_circle\">\n                          <li>要普通免許</li>\n                        </ul>\n                        <h5>歓迎する経験・スキル</h5>\n                        <ul class=\"col_mark_circle\">\n                          <li>オーディオビジュアル・放送機器・コンピュータネットワークなどに興味があり、AVシステム設計、ネットワーク設計などの経験のある方</li>\n                          <li>電気工事士、電話工事担任者、ネットワーク技術者など、有資格者・工事経験者</li>\n                          <li>IT系スキル、資格があれば尚可</li>\n                        </ul></td>\n                    </tr>\n                    <tr>\n                      <th>勤務地</th>\n                      <td><dl>\n                          <dt>本社</dt>\n                          <dd>〒520-3045　滋賀県栗東市高野577番地1</dd>\n                          <dt>京都支店</dt>\n                          <dd>〒601-8036　京都市南区東九条松田町138番地2（西洞院通り札の辻角）</dd>\n                        </dl></td>\n                    </tr>\n                    <tr>\n                      <th>給与</th>\n                      <td>経験・能力による　※試用期間 3カ月（給与同じ）<br>\n                        昇給／あり 年1回（7月）　賞与／あり 年2回（6月、12月）<br>\n                        手当／あり　営業または外勤・家族・時間外・役職・通勤など </td>\n                    </tr>\n                    <tr>\n                      <th>勤務時間</th>\n                      <td>8時30分～17時30分  うち労働時間：8時間00分 休憩時間：60分<br>\n                        ※所定時間外労働あり　　平均10時間／月 </td>\n                    </tr>\n                    <tr>\n                      <th>休日・休暇</th>\n                      <td> 年間休日123日\n                        <ul class=\"col_mark_circle\">\n                        <li>週休二日制（土曜日は年に4日程度出勤あり）</li>\n                        <li>祝日、夏季・年末年始休暇、年次有給休暇、創立記念休暇（8/8）</li>\n                        <li>リフレッシュ休暇制度あり</li>\n                        10年勤続ごとに《連休＋金一封》を贈呈<br>\n                        10年勤続／5日間・5万円　20年勤続／10日間・10万円　30年勤続／10日間・10万円</td>\n                    </tr>\n                    <tr>\n                      <th>福利厚生</th>\n                      <td><h5>保険制度</h5>\n                        健康保険、厚生年金、雇用保険、労災保険\n                        <h5>そのほか福利厚生など</h5>\n                        <ul class=\"col_mark_circle\">\n                          <li>退職金制度</li>\n                          <li>社内旅行、食事会</li>\n                          <li>勤労者互助会会員</li>\n                          <li>資格取得バックアップ制度（資格取得報奨金あり）</li>\n                          <li>援助システム（社内勉強会、教育専門機関への参加による研修など全費用会社負担、研修出席時出勤扱い）</li>\n                          <li>マイカー通勤可（本社のみ）</li>\n                        </ul>\n                        <h5>働き方改革への取り組み</h5>\n                        滋賀県ワークライフバランス推進企業認定、京都モデルワークライフバランス推進企業認定、滋賀県イクボス宣言企業登録、くるみん認定に向けた一般事業主行動計画の公表と実践\n                        <h5>受動喫煙体制</h5>\n                        屋内全面禁煙（屋外喫煙指定場所あり） </td>\n                    </tr>\n                    <tr>\n                      <th>選考フロー</th>\n                      <td><ul class=\"col_mark_number\">\n                          <li>\n                            <h5>書類選考</h5>\n                            <p>電話又はメール連絡の上、履歴書（写真貼付）・技術（職務）経歴書をメール又は郵送して下さい。<br>\n                              ※選考の結果にかかわらず、書類の返却はいたしません。</p>\n                          </li>\n                          <li>\n                            <h5>一次面接</h5>\n                            <p>原則WEB面接</p>\n                          </li>\n                          <li>\n                            <h5>SPI適性検査</h5>\n                          </li>\n                          <li>\n                            <h5>二次面接</h5>\n                          </li>\n                          <li>\n                            <h5>内定</h5>\n                          </li>\n                        </ul>\n                        <p>※会社見学も受け付けています</p></td>\n                    </tr>\n                    <tr>\n                      <th>採用実績</th>\n                      <td>56期　17名<br>\n                        55期　12名<br>\n                        54期　13名 </td>\n                    </tr>\n                  </tbody>\n                </table>\n              </div>\n              <!--　▲▲▲　１件分　▲▲▲　-->\n              <div class=\"bpts_spacer_h40\"></div>\n              \n              <!-- 中見出し -->\n              <h3 class=\"col_internal_chuumidashi\"> <span>インターンシップ </span> </h3 alt=\"eod:col_internal_chuumidashi\">\n              <p>弊社の業務がより理解できる映像、音響等機器を見ていただけます。また、施行実績なども映像でご確認いただけます。</p>\n              \n              <!--　▼▼▼　１件分　▼▼▼　-->\n              <div class=\"unit_table_side\">\n                <table>\n                  <tbody>\n                    <tr>\n                      <th>期間</th>\n                      <td><ul class=\"col_mark_circle\">\n                          <li>申込期間　通年</li>\n                          <li>受入期間　3月、8月を除く通年</li>\n                        </ul></td>\n                    </tr>\n                    <tr>\n                      <th>実習日程</th>\n                      <td><ul class=\"col_mark_circle\">\n                          <li>1days </li>\n                          <li>午前、午後の約2時間程度</li>\n                        </ul></td>\n                    </tr>\n                    <tr>\n                      <th>開催場所</th>\n                      <td>キノンビクス株式会社　京都支店（京都市南区東九条松田町138－2）</td>\n                    </tr>\n                    <tr>\n                      <th>募集人数</th>\n                      <td>1～5名</td>\n                    </tr>\n                    <tr>\n                      <th>対象者</th>\n                      <td>対象学年／全学年<br>\n                        理系大学院生、理系学部生、文系大学院生、文系学部生<br>\n                        短大生、高専生、専門学校生、留学生 </td>\n                    </tr>\n                    <tr>\n                      <th>給与</th>\n                      <td>なし</td>\n                    </tr>\n                    <tr>\n                      <th>実施概要</th>\n                      <td><ul class=\"col_mark_circle\">\n                          <li>対面形式</li>\n                          <li>職場見学、先輩社員との座談会ほか</li>\n                        </ul></td>\n                    </tr>\n                  </tbody>\n                </table>\n              </div>\n              <!--　▲▲▲　１件分　▲▲▲　-->\n              \n              <div class=\"bpts_spacer_h40\"></div>\n              <div class=\"col_txtsheet center\" style=\"max-width: 700px;width: 90%;\">\n                <h5>採用・インターンシップに関する<span class=\"bpts_br\"></span>問い合わせ先</h5>\n                <!--　▼▼▼　１件分　▼▼▼　-->\n                <div class=\"unit_table_side\" style=\"max-width: 500px;width: 90%;\">\n                  <table>\n                    <tbody>\n                      <tr>\n                        <th>担当</th>\n                        <td>管理グループ　西村　伸宏</td>\n                      </tr>\n                      <tr>\n                        <th>TEL</th>\n                        <td>077-552-1144</td>\n                      </tr>\n                      <tr>\n                        <th>FAX</th>\n                        <td>077-552-1179</td>\n                      </tr>\n                      <!--<tr>\n                        <th>E-mail</th>\n                        <td><a href=\"mailto:\"></a></td>\n                      </tr>-->\n                    </tbody>\n                  </table>\n                </div>\n                <!--　▲▲▲　１件分　▲▲▲　--> \n              </div>\n            </section>\n          </div alt=\"col_textarea_full\">\n          <!--　▲▲▲　本文領域　終わり　▲▲▲　--> \n        </div>\n        <!-- eod:sp_padding --> \n      </div alt=\"eod:zone_mainarea\">\n      <!--　メインエリア　終わり　--> \n    </div alt=\"eod:zone_body\">\n    <!--　ボディ領域　終わり　--> \n  </div alt=\"eod:zone_middle\">\n  <!--　第2層　終わり　--> \n  <!-- リクルート用　お問い合わせフッターのインクルード --> \n  <meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\" />\n<meta name=\"format-detection\" content=\"telephone=no\">\n<!-- \n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/common.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/zone.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/bpts.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/unit.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/col.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/other.css\"/>\n-->\n<!-- リクルートフッターここから -->\n<div class=\"bpts_footer_recruit\"> \n  <!-- ▼ 左ボックス -->\n  <div>\n    <h4>採用に関するお問い合わせ</h4>\n    <table>\n      <tr>\n        <th>担当</th>\n        <td><span>管理グループ</span><br>\n          西村 伸宏</td>\n      </tr>\n      <tr>\n        <th>TEL</th>\n        <td>077-552-1144</td>\n      </tr>\n<!--      <tr>\n        <th>Mail　</th>\n        <td><a href=\"mailto:\"></a></td>\n      </tr>-->\n    </table>\n  </div>\n  <!-- ▲ 左ボックス --> \n  <!-- ▼ 右ボックス -->\n  <div> <a href=\"requirements.shtml\">\n    <h6>募集要項</h6></a> </div>\n  <!-- ▲ 右ボックス --> \n</div>\n<!-- ▲リクルートフッターここまで --> \n\n<!-- お問い合わせfooterここから -->\n<div class=\"bpts_footer_contact_area recruit_wrap\">\n  <h6 class=\"recruit_fotter\">ご相談等ありましたら<span>お気軽にお問い合わせください</span></h6>\n  <div class=\"center\"> <a href=\"/recruit/saiyou-contact.shtml\" class=\"bpts_btn_squarered\"><span>お問い合わせフォームを開く</span></a> </div>\n</div>\n<!-- お問い合わせfooterここまで --> \n \n  <!--　第3層　-->\n  <div id=\"zone_bottom_floor\"> \n    <!--　フッター　-->\n    <div id=\"zone_footer\"> \n      <!-- フッターのインクルード --> \n      <meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\" />\n<meta name=\"format-detection\" content=\"telephone=no\">\n<!-- \n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/common.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/zone.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/bpts.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/unit.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/col.css\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/other.css\"/>\n -->\n<div id=\"pagetop\"><a href=\"#top\">Page Top</a></div>\n<!--　フッター　-->\n<footer id=\"footer\">\n<