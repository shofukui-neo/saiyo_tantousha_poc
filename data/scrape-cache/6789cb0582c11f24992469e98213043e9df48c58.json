n            </li>\r\n\r\n            <li class=\"header-nav-list-item--pulldown sp\">\r\n              <div class=\"header-nav-list-item__link accordion_close_sp\">採用情報</div>\r\n              <div class=\"header-nav--pulldown\">\r\n                <div class=\"header-nav--pulldown-wrapper\">\r\n                  <p class=\"header-nav--pulldown-title\">会社情報<span>Company</span></p>\r\n                  <div class=\"header-nav--pulldown-items\">\r\n                    <div class=\"header-nav--pulldown-item\">\r\n                      <p class=\"header-nav--pulldown-item-title\"><a href=\"index.html\">人事部からのメッセージ</a></p>\r\n                    </div>\r\n                    <div class=\"header-nav--pulldown-item\">\r\n                      <p class=\"header-nav--pulldown-item-title\"><a href=\"inquiry.html\">採用お問い合わせ</a></p>\r\n                    </div>\r\n                  </div>\r\n                </div>\r\n              </div>\r\n            </li>\r\n          </ul>\r\n        </nav>\r\n        \r\n        <div class=\"header-menu2-sec2 sp\">\r\n          <ul class=\"header-menu2-sec2--items\">\r\n            <li class=\"header-menu2-sec2--item recruit-btn\">\r\n              <a href=\"https://arisawa-saiyo.com/\" target=\"_blank\" class=\"header-menu2-sec2--item__link\">採用情報<span><img src=\"../../img/icon_link1.svg\" width=\"14\" height=\"14\" /></span></a>\r\n            </li>\r\n            <li class=\"header-menu2-sec2--item contact-btn\">\r\n              <a href=\"../inquiry/index.html\" class=\"header-menu2-sec2--item__link\">お問い合わせ</a>\r\n            </li>\r\n          </ul>\r\n        </div>\r\n        \r\n        <div class=\"header-menu-search sp\">\r\n          <form action=\"https://www.google.com/search\" target=\"_blank\">\r\n            <input type=\"hidden\" name=\"hl\" value=\"ja\">\r\n            <input type=\"hidden\" value=\"arisawa.co.jp\" name=\"as_sitesearch\">\r\n            <p class=\"sitenai\">\r\n              <input type=\"text\" name=\"q\" size=\"15\" maxlength=\"256\" value=\"\" placeholder=\"キーワードを入力してください\">\r\n              <button><img src=\"../../img/icon_search.svg\" alt=\"検索\" widht=\"18\" height=\"18\" /></button>\r\n            </p>\r\n          </form>\r\n        </div>\r\n        \r\n        <div class=\"header-menu-eng sp\"><a href=\"../../en/index.html\"><span><img src=\"../../img/icon_eng.svg\" width=\"18\" height=\"18\" /></span>English</a></div>\r\n      </div>\r\n      \r\n      <div class=\"header-menu2 pc\">\r\n        <div class=\"header-menu2-sec1\">\r\n          <p class=\"header-menu2-sec1-eng\"><a href=\"../../en/index.html\"><span><img src=\"../../img/icon_eng.svg\" width=\"18\" height=\"18\" /></span>English</a></p>\r\n          <div id=\"js-header-search-btn\" class=\"header-menu2-sec1-search\"><img src=\"../../img/icon_search.svg\" alt=\"検索\" widht=\"18\" height=\"18\" /></div>\r\n        </div>\r\n        \r\n        <div class=\"header-menu2-sec2\">\r\n          <ul class=\"header-menu2-sec2--items\">\r\n            <li class=\"header-menu2-sec2--item recruit-btn\">\r\n              <a href=\"https://arisawa-saiyo.com/\" target=\"_blank\" class=\"header-menu2-sec2--item__link\">採用情報<span><img src=\"../../img/icon_link1.svg\" width=\"14\" height=\"14\" /></span></a>\r\n            </li>\r\n            <li class=\"header-menu2-sec2--item contact-btn\">\r\n              <a href=\"../inquiry/index.html\" class=\"header-menu2-sec2--item__link\">お問い合わせ</a>\r\n            </li>\r\n          </ul>\r\n        </div>\r\n      </div>\r\n    </div>\r\n    \r\n    <div id=\"js-header-search-menu\" class=\"header-search\">\r\n      <form action=\"https://www.google.com/search\" target=\"_blank\">\r\n        <input type=\"hidden\" name=\"hl\" value=\"ja\">\r\n        <input type=\"hidden\" value=\"arisawa.co.jp\" name=\"as_sitesearch\">\r\n        <p class=\"sitenai\">\r\n          <input type=\"text\" name=\"q\" size=\"15\" maxlength=\"256\" value=\"\" placeholder=\"キーワードを入力してください\">\r\n          <button><img src=\"../../img/icon_search.svg\" alt=\"検索\" widht=\"18\" height=\"18\" /></button>\r\n        </p>\r\n      </form>\r\n    </div>\r\n  </div>\r\n</header>\r\n<!--ヘッダーここまで-->\r\n\r\n\r\n<div id=\"contents_main_bg\">\r\n<div id=\"main\">\r\n<div id=\"left\">\r\n<p class=\"left-title\" data-title-en=\"Recruit\">採用情報</p>\r\n<div class=\"sub_menu\">\r\n<a href=\"index.html\">人事部からのメッセージ</a>\r\n</div>\r\n<div class=\"sub_menu\">\r\n<a href=\"https://arisawa-saiyo.com/\" target=\"_brank\">採用サイト</a>\r\n</div>\r\n<div class=\"sub_menu\">\r\n<a href=\"inquiry.html\">採用お問い合わせ</a>\r\n</div>\r\n</div>\r\n\r\n<div id=\"right\">\r\n\r\n<h1 class=\"pt2\" data-title-en=\"Message from human resources department\">人事部からのメッセージ</h1>\r\n<p>有沢製作所の採用ページにアクセス頂きありがとうございます。<br>\n<br>\n人が夢を描くから次々と新しいテーマが生まれ技術は進歩します。<br>\nバテンレースという編み物製造で創業し、百年余りにわたる歴史を持つ有沢製作所は、ここ十数年で情報通信機器の素材分野で世界有数のメーカーへと成長を遂げました。<br>\n常に技術革新に挑戦し、その実現を目指す当社にとって、技術進化への歩みは一時たりとも止まることを許されません。<br>\n<br>\nその歩みを支えているのは、当社に集う社員ひとりひとりの技術の可能性を追求する真摯な態度であり、それは創業以来今日まで、そしてこれからも、決して変わることはありません。<br>\n当社の基本理念であるCIC（創造・革新・挑戦）の下で、グローバルに活躍できる人材を育成し、その人材の力を最大限に引き出すことによって、『Dreams to Reality!（夢を現実に...！）』を実現していきます。</p>\r\n<p class=\"mB40\"><span class=\"blue3-b size6\">人の力こそ、有沢製作所の技術力であり、企業力！<br />\r\n</span></p>\r\n\r\n<h2>会社紹介</h2>\r\n<div class=\"mB30\">\r\n<p>当社は、<p/>\r\n<div id=\"recruit\">\r\n<ul>\r\n\r\n<li class=\"size4\">『創造・革新・挑戦』を基軸にした経営方針です。 </li>\r\n\r\n<li class=\"size4\">目指すは世界市場での継続的な“勝ち組”です。</li>\r\n\r\n<li class=\"size4\">化学の力で『できない』を『できる』にする仕事です。</li>\r\n\r\n<li class=\"size4\">アリサワグループ各社の総合力で、現在も発展し続けています。あなたの周りにも当社製品はきっと届いています。</li>\r\n\r\n</ul>\r\n</div>\r\n</div>\r\n\r\n<h2>当社が求める人材</h2>\r\n<div class=\"mB30\">\r\n<div id=\"recruit\">\r\n<ul>\r\n\r\n<li class=\"size4\">自分の信念</li>\r\n\r\n<li class=\"size4\">真意を見極める力</li>\r\n\r\n<li class=\"size4\">現状に満足しない挑戦性</li>\r\n\r\n<li class=\"size4\">発想や行動の柔軟さ、</li>\r\n\r\n</ul>\r\n</div>\r\n<br />\r\n<p>を持つ人材を必要としています。</p>\r\n</div>\r\n\r\n<h2>採用サイト</h2>\r\n<p>\r\n<a href=\"https://arisawa-saiyo.com/\" target=\"blank\"><img src=\"img/recruit_banner3.png\" border=\"0\" /></a>\r\n</p>\r\n\r\n</div>\r\n\r\n<div id=\"main_bottom\"></div>\r\n</div>\r\n</div>\r\n\r\n<!--フッターここから-->\r\n<div id=\"js-pagetop-btn\" class=\"footer__pagetop\">\r\n  <div class=\"footer__pagetop-btn\">&nbsp;</div>\r\n</div>\r\n<footer class=\"footer\">\r\n  <div class=\"footer-wrapper\">\r\n    <div class=\"footer-logo\">\r\n      <a href=\"../../index.html\">\r\n        <picture>\r\n          <source media=\"(max-width:767px)\" srcset=\"../../img/logo.png\" width=\"220\" height=\"40\">\r\n          <img src=\"../../img/logo.png\" alt=\"有沢製作所\" width=\"220\" height=\"40\">\r\n        </picture>\r\n      </a>\r\n    </div>\r\n    \r\n    <div class=\"footer-inner\">\r\n      <div class=\"footer-titlelink top\"><a href=\"../../index.html\">トップページ</a></div>\r\n      <div class=\"footer-inner-main\">\r\n        <div class=\"footer--sec\">\r\n          <div class=\"footer-sec--item\">\r\n            <div class=\"footer-titlelink pc\"><a href=\"../products/index.html\">技術・製品情報</a></div>\r\n            <div class=\"footer-titlelink js-accordion--sp sp\"><span>技術・製品情報</span></div>\r\n            <ul class=\"footer-nav-list\">\r\n              <li class=\"footer-nav-list--item\">\r\n                <div class=\"footer-nav-list--item-wrapper\"><a href=\"../products/fpc.html\" class=\"footer-nav-list--item__link\">FPC材料</a></div>\r\n                <div class=\"footer-nav-list--item-nav\">\r\n                  <p><a href=\"../products/fpc01.html\">カバーレイフィルム</a></p>\r\n                  <p><a href=\"../products/fpc02.html\">銅張り積層板</a></p>\r\n                  <p><a href=\"../products/fpc03.html\">層間接着シート</a></p>\r\n                  <p><a href=\"../products/fpc04.html\">その他</a></p>\r\n                </div>\r\n              </li>\r\n              <li class=\"footer-nav-list--item\">\r\n                <div class=\"footer-nav-list--item-wrapper\"><a href=\".