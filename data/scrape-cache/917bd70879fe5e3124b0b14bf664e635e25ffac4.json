{"url":"https://www.kurabun.co.jp/info/entry-5532.html","html":"<!DOCTYPE html>\n<html lang=\"ja\"><!-- InstanceBegin template=\"/Templates/common.dwt\" codeOutsideHTMLIsLocked=\"false\" -->\n<head>\n\n\n<!-- Google Tag Manager -->\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n})(window,document,'script','dataLayer','GTM-KH94MQH');</script>\n<!-- End Google Tag Manager -->\n\n\n<!-- Google Tag Manager GOFIELD用 -->\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n})(window,document,'script','dataLayer','GTM-TBKXBLM');</script>\n<!-- End Google Tag Manager -->\n\n\n<meta charset=\"utf-8\">\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n<!-- InstanceBeginEditable name=\"doctitle\" -->\n\n\n<title>【プレスリリース】うさぎや開店30周年記念イベント 大型文具専門店うさぎや30th あいちゃんのバースデーフェア ～文具で地元の魅力再発見～ | 岡山 倉敷 福山の文具 事務用品 OA機器 オフィスデザインはクラブン</title>\n\n\n<meta property=\"og:url\" content=\"https://www.kurabun.co.jp/info/entry-5532.html\">\n<meta property=\"og:site_name\" content=\"岡山 倉敷 福山の文具 事務用品 OA機器 オフィスデザインはクラブン\">\n\n\n\n\n\n\n\n\n\n\n<meta property=\"og:title\" content=\"【プレスリリース】うさぎや開店30周年記念イベント 大型文具専門店うさぎや30th あいちゃんのバースデーフェア ～文具で地元の魅力再発見～ | 新着情報\">\n<meta property=\"og:type\" content=\"article\">\n\n\n\n\n\n<meta property=\"og:image\" content=\"https://www.kurabun.co.jp/archives/002/202510/ce1fa1d3e8e575b9.jpg\">\n\n\n<meta property=\"og:description\" content=\"クラブン株式会社（本社：岡山県倉敷市）が運営する大型文具専門店うさぎやは、2025年11月1日(土)に開店...\">\n<meta name=\"description\" content=\"クラブン株式会社（本社：岡山県倉敷市）が運営する大型文具専門店うさぎやは、2025年11月1日(土)に開店...\">\n<meta name=\"keywords\" content=\"【プレスリリース】うさぎや開店30周年記念イベント 大型文具専門店うさぎや30th あいちゃんのバースデーフェア ～文具で地元の魅力再発見～,ニュース,プレスリリース,最新情報\">\n\n\n\n\n\n<link href=\"/themes/system/css/acms.css?date=20250510022326\" rel=\"stylesheet\">\n<link href=\"/themes/system/css/acms-admin.min.css?date=20250510022326\" rel=\"stylesheet\">\n<link href=\"/themes/main/css/base.css?date=20230607104604\" rel=\"stylesheet\" >\n<link href=\"/themes/main/css/common.css?date=20240109090005\" rel=\"stylesheet\" >\n<link href=\"/themes/main/css/layout.css?date=20250402125534\" rel=\"stylesheet\" >\n<link rel=\"canonical\" href=\"https://www.kurabun.co.jp/info/entry-5532.html\">\n<script src=\"/js/library/jquery/jquery-3.4.1.min.js\"></script> \n\n\n<script src=\"/acms.js?uaGroup=PC&amp;domains=www.kurabun.co.jp&amp;jsDir=js/&amp;themesDir=/themes/&amp;bid=2&amp;eid=5532&amp;bcd=info&amp;googleApiKey=AIzaSyDOdw6NdHNXxmcNRK6N9-Y4aC5jHnMbHCs&amp;jQuery=3.6.1&amp;jQueryMigrate=migrate-3.0.1&amp;mediaClientResize=on&amp;fulltimeSSL=1&amp;v=e6fbc7fd914b6d1dc16345fcd65a80e4&amp;umfs=256M&amp;pms=256M&amp;mfu=20&amp;lgImg=width:1400&amp;jpegQuality=95&amp;mediaLibrary=on&amp;edition=standard&amp;urlPreviewExpire=48&amp;timemachinePreviewDefaultDevice=PC&amp;ecd=entry-5532.html&amp;scriptRoot=/\"  id=\"acms-js\"></script>\n\n\n<script type=\"text/javascript\" src=\"/themes/main/js/common.js?date=20260126080149\"></script>\n<script type=\"text/javascript\" src=\"/themes/main/js/jquery.flatheights.js?date=20230607104604\"></script>\n<!--[if lte IE 9]><script src=\"/themes/main/js/html5shiv-printshiv.js?date=20230607104604\"></script><![endif]-->\n<!--[if IE 8]><meta http-equiv=\"X-UA-Compatible\" content=\"IE=8\"><![endif]-->\n\n\n\n<!-- Original GA -->\n<script>\n  (function(i,s,o,g,r,a,m){i['GoogleAnalyticsObject']=r;i[r]=i[r]||function(){\n  (i[r].q=i[r].q||[]).push(arguments)},i[r].l=1*new Date();a=s.createElement(o),\n  m=s.getElementsByTagName(o)[0];a.async=1;a.src=g;m.parentNode.insertBefore(a,m)\n  })(window,document,'script','https://www.google-analytics.com/analytics.js','ga');\n\n  ga('create', 'UA-45171911-1', 'auto');\n  ga('send', 'pageview');\n\n</script>\n\n\n\n<link href=\"https://fonts.googleapis.com/css?family=Kanit:700,700i\" rel=\"stylesheet\">\n<link href=\"/themes/main/css/cms.css?date=20230607104604\" rel=\"stylesheet\" >\n<!-- InstanceEndEditable -->\n\n<meta name=\"csrf-token\" content=\"3314e78b7d531bbe9f06585605bd5fba4bc525ac196eea0b058cf8c548ee42d3\"><script type=\"text/javascript\" src=\"/js/dest/vendor.js?date=20250510022324\" charset=\"UTF-8\" async defer></script>\n<script type=\"text/javascript\" src=\"/js/dest/index.js?date=20250510022324\" charset=\"UTF-8\" async defer></script>\n<meta name=\"generator\" content=\"a-blog cms\" />\n</head>\n<body>\n\n\n<!-- Google Tag Manager (noscript) -->\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-KH94MQH\"\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n<!-- End Google Tag Manager (noscript) -->\n\n<!-- Google Tag Manager (noscript) GOFIELD用 -->\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-TBKXBLM\"\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n<!-- End Google Tag Manager (noscript) -->\n\n\n\n<!-- ▼ 管理用パーツ ================================================ -->\n\n<!-- ▲ 管理用パーツ ================================================ -->\n\n<div class=\"body\">\n<div class=\"wrap\">\n\n<!-- ▼ header ====================================================== -->\n<header class=\"header\">\n\n<nav class=\"global-navigation\" id=\"global-nav\">\n<ul>\n<li class=\"logo one\"><a href=\"https://www.kurabun.co.jp/\"><img src=\"/themes/main/images/logo.png\" alt=\"クラブン株式会社\"></a></li>\n<li class=\"js-link_match_location two\" id=\"two\"><a href=\"https://www.kurabun.co.jp/office/\">文具・事務用品</a></li>\n<li class=\"js-link_match_location three\" id=\"three\"><a href