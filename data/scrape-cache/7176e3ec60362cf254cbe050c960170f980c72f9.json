{"url":"http://www.r-ehm.co.jp/recruit/training/","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n\n<head>\n  <meta charset=\"utf-8\">\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n  <title>研修制度-トヨタレンタリース西四国</title>\n  <meta name=\"description\" content=\"よいクルマ、よいサービス。愛媛県と高知県のレンタカー予約はトヨタレンタリース西四国へ！\">\n  <meta name=\"title\" content=\"研修制度-トヨタレンタリース西四国\">\n  <meta content=\"IE=edge\" http-equiv=\"X-UA-Compatible\">\n  <meta name=\"format-detection\" content=\"telephone=no,address=no,email=no\">\n  <!-- seo -->\n  <meta property=\"og:title\" content=\"研修制度-トヨタレンタリース西四国\" />\n  <meta property=\"og:type\" content=\"website\" />\n  <meta property=\"og:url\" content=\"https://www.r-ehm.co.jp/recruit/training/\" />\n  <meta property=\"og:image\" content=\"https://www.r-ehm.co.jp/assets/img/ogp.jpg\" />\n  <meta property=\"og:site_name\" content=\"研修制度-トヨタレンタリース西四国\" />\n  <meta property=\"og:description\" content=\"よいクルマ、よいサービス。愛媛県と高知県のレンタカー予約はトヨタレンタリース西四国へ！\" />\n  <meta name=\"twitter:card\" content=\"summary\" />\n  <meta name=\"twitter:title\" content=\"研修制度-トヨタレンタリース西四国\" />\n  <meta name=\"twitter:description\" content=\"よいクルマ、よいサービス。愛媛県と高知県のレンタカー予約はトヨタレンタリース西四国へ！\" />\n  <meta name=\"twitter:image\" content=\"https://www.r-ehm.co.jp/assets/img/ogp.jpg\" />\n\n  <!-- faviconの指定 -->\n  <link rel=\"icon\" type=\"img/x-icon\" href=\"/assets/img/favicon.ico\">\n  <link rel=\"icon\" href=\"/assets/img/favicon.ico\">\n  <link rel=\"shortcut icon\" type=\"img/vnd.microsoft.icon\" href=\"/assets/img/favicon.ico\">\n  <link rel=\"icon\" type=\"img/vnd.microsoft.icon\" href=\"/assets/img/favicon.ico\">\n  <link rel=\"apple-touch-icon\" href=\"/apple-touch-icon.png\" sizes=\"180x180\">\n  <link rel=\"apple-touch-icon-precomposed\" href=\"/apple-touch-icon.png\" sizes=\"180x180\">\n  <link rel=\"stylesheet\" href=\"https://unpkg.com/swiper/swiper-bundle.min.css\">\n  <link rel=\"stylesheet\" href=\"/assets/css/scss/pages/common.css\">\n  <link rel=\"stylesheet\" href=\"/assets/css/scss/pages/training.css\">\n</head>\n\n<body>\n  <div class=\"wrap\">\n    <div class=\"l-content\">\n      <!-- l-header -->\n      <header class=\"l-header js-header\">\n        <div class=\"l-header-logo\">\n          <h1 class=\"l-header-logo__ttl\">\n            <a class=\"-link\" href=\"/\">\n              <img src=\"/assets/img/common/logo.svg\" alt=\"TOYOTA Rent a Car\">\n            </a>\n          </h1>\n        </div>\n        <div id=\"js-drawermenu\" class=\"l-header-area\">\n          <ul class=\"l-header-area__list\">\n            <li class=\"l-header-area__list-item\"><a class=\"-link\" href=\"/\">ホーム</a></li>\n            <li class=\"l-header-area__list-item\"><a class=\"-link\" href=\"/company/\">会社概要</a></li>\n            <div class=\"l-header-area__list-item l-header-area__list-item--linkaccd\">\n              <a class=\"-link\" href=\"/recruit/\">採用情報</a>\n              <span class=\"l-header-area__list-item--linkaccd-btn js-accd\"></span>\n              <ul class=\"l-header-area__list-ul\" style=\"display:none;\">\n                <li class=\"l-header-area__list-section l-header-area__list-section--mt\"><a href=\"/recruit/interview/\">-\n                    社員インタビュー</a></li>\n                <li class=\"l-header-area__list-section\"><a href=\"/recruit/data/\">- 数字で見る</a></li>\n                <li class=\"l-header-area__list-section\"><a href=\"/recruit/training/\">- 研修制度</a></li>\n                <li class=\"l-header-area__list-section\"><a href=\"/recruit/faq/\">- よくあるご質問</a></li>\n                <li class=\"l-header-area__list-section\"><a href=\"/recruit/description/\">- 募集要項</a></li>\n              </ul>\n            </div>\n          </ul>\n          <div class=\"l-header-area__targetbox\">\n            <div class=\"l-header-area__shop\">\n              <a href=\"/shop/\"><span class=\"-icon\">店舗を探す</span></a>\n            </div>\n            <div class=\"l-header-area__info\">\n              <a href=\"https://rent.toyota.co.jp/static/guide/\" target=\"_blank\"><span class=\"-icon\">ご利用案内</span></a>\n            </div>\n            <div class=\"l-header-area__reservation\">\n              <a href=\"https://rent.toyota.co.jp/\" target=\"_blank\"><span class=\"-icon\">インターネット予約</span></a>\n            </div>\n          </div>\n        </div>\n        <div id=\"js-btnTrigger\" class=\"js-navbtn l-header-humbtn\">\n          <span class=\"l-header-humbtn__line\">\n            <!--btn-->\n          </span>\n          <span class=\"l-header-humbtn__line\">\n            <!--btn-->\n          </span>\n        </div>\n      </header>\n      <!-- l-snsbox -->\n      <div class=\"l-snsbox\">\n        <div class=\"l-snsbox-block l-snsbox-block--01\">\n          <a href=\"/recruit/\">\n            <p class=\"-txt\">採用情報</p>\n          </a>\n        </div>\n        <div class=\"l-snsbox-block l-snsbox-block--02\">\n          <a href=\"https://www.instagram.com/toyota_nishishikoku/\" target=\"_blank\">\n            <p class=\"-txt\">インスタグラム</p>\n          </a>\n        </div>\n      </div>\n      <div class=\"l-content-main\">\n        <section class=\"c-submv\">\n          <div class=\"c-submv-bg\"></div>\n          <div class=\"inner c-submv--inner\">\n            <div class=\"c-submv-img c-submv-img--training\"></div>\n            <div class=\"c-submv-area flex is-between\">\n              <h1 class=\"-ttl\">研修制度<br class=\"sp\">トヨタレンタリース西四国</h1>\n              <div class=\"-breadcrumbs\">\n                <ul class=\"flex\">\n                  <li><a href=\"/\">トップ</a></li>\n                  <li><a href=\"/recruit/\">採用情報</a></li>\n                  <li>研修制度</li>\n                </ul>\n              </div>\n            </div>\n          </div>\n        </section>\n\n        <!-- p-training-top -->\n        <section class=\"p-training-top\">\n          <div class=\"inner p-training-top--inner\">\n            <div class=\"p-training-top__area flex\">\n              <div class=\"p-training-top__area-txtbox\">\n                <div class=\"c-ttl02box p-training-top__area-txtbox--ttlbox\">\n                  <h2 class=\"c-ttl02 js-anime\">training<span class=\"-jp\">研修制度</span></h2>\n                </div>\n                <p class=\"-subttl\">まずは楽しんでもらえる<br>環境づくりから。<br><span class=\"-color\">一人一人にちゃんと向き合う</span><br>そんな研修です。</p>\n                <p class=\"-txt\">新しい環境では、まず“楽しむこと”が大切だと私たちは考えています。<br>\n                  研修では、業務の流れを学ぶだけでなく、先輩スタッフとの交流や現場体験を通じて、安心して一歩を踏み出せるようサポートしています。<br>\n                  最初は分からないことばかりでも大丈夫。周りがしっかりフォローしながら、少しずつ仕事の楽しさを感じてもらえるよう工夫しています。<br>\n                  一人ひとりのペースや性格に合わせて寄り添うことで、「ここなら自分らしく成長できる」と思えるような時間を大切にしています。<br>\n                  学ぶだけでなく、人とのつながりやチームの温かさを感じながら成長していける。そんな研修を目指しています。</p>\n              </div>\n              <div class=\"p-training-top__area-img\">\n                <picture>\n                  <source srcset=\"/assets/img/training/training01-sp.jpg\" media=\"(max-width: 768px)\">\n                  <img src=\"/assets/img/training/training01-pc.jpg\">\n                </picture>\n              </div>\n            </div>\n          </div>\n        </section>\n\n        <!-- p-training-design -->\n        <section class=\"p-training-design\">\n          <div class=\"inner\">\n            <div class=\"p-training-design__area\">\n              <div class=\"-txtbox\">\n                <p class=\"-en\">Goal Design</p>\n                <p class=\"-ttl\">自身で目的を決めて、実行していく。<br><span class=\"-color\">試行錯誤の先に見えるもの</span>が生まれるような目標設計を。</p>\n                <p class=\"-txt\">仕事を通して自分の“目的”を見つけ、形にしていく。<br\n                    class=\"pc\">最初から完璧でなくても、試行錯誤を重ねることで、自分らしい成長の形が見えてきます。<br>ここでは、入社後に歩んでいく具体的なステップを図でご紹介します。</p>\n              </div>\n              <div class=\"-imgbox\">\n                <div class=\"-img\">\n                  <img src=\"/assets/img/training/training02.png\">\n                </div>\n              </div>\n            </div>\n          </div>\n        </section>\n\n        <!-- p-training-case -->\n        <section class=\"p-training-case\">\n          <div class=\"inner\">\n            <div class=\"c-ttl02box p-training-case__ttl\">\n              <h2 class=\"c-ttl02 js-anime\">case<span class=\"-jp\">研修の実施例</span></h2>\n            </div>\n            <p class=\"p-training-case__txt\">実際にどんな研修が行われているのか、気になる方も多いのではないでしょうか。<br>\n              今回は、研修に参加したスタッフと、担当者にお話を伺いました。<br>\n              それぞれの視点から見た“学び”や“気づき”を通して、研修の雰囲気を感じていただければと思います。</p>\n          </div>\n        </section>\n\n        <!-- p-training-mv -->\n        <div class=\"p-training-mv\">\n          <div class=\"p-training-mv__bg p-training-mv__bg--01\"></div>\n          <p class=\"p-training-mv__ttl\">staff<br>voices</p>\n          <p class=\"p-training-mv__num\">case<br>#01</p>\n          <div class=\"p-training-mv__img p-training-mv__img--01 js-anime\">\n            <img src=\"/assets/img/training/case01.png\">\n          </div>\n          <div class=\"p-training-mv__txtbox\">\n            <p class=\"-name\">\n              <span class=\"-bg\">\n                <span class=\"-jp\">松平 春佳</span>\n                <span class=\"-en\">HARUKA MATSUHIRA</span>\n              </span>\n            </p>\n            <p class=\"-txt -txt--01\"><span class=\"-txtin\">不安から無敵モードに、</span></p>\n            <p class=\"-txt -txt--02\"><span class=\"-txtin\">何でもできるようになった気が</span></p>\n            <p class=\"-txt -txt--03\"><span class=\"-txtin\">しました。</span></p>\n          </div>\n          <div class=\"p-training-mv__profile\">\n            <p class=\"-name\">\n              <span class=\"-en\">\n                profile\n              </span>\n            </p>\n            <p class=\"-txt -txt--01\"><span class=\"-txtin\">入社年月日：2025年 入社</span></p>\n            <p class=\"-txt -txt--02\"><span class=\"-txtin\">所属部署：レンタル部 スタッフ</span></p>\n          </div>\n        </div>\n\n        <div class=\"p-training-bgcolor\">\n          <!-- p-training-block -->\n          <section class=\"p-training-block js-anime\">\n            <p class=\"p-training-block__bgttl\">question 01</p>\n            <div class=\"inner p-training-block--inner\">\n              <div class=\"p-training-block__outer flex is-between\">\n                <div class=\"-img\">\n                  <picture>\n                    <source srcset=\"/assets/img/training/case02-sp.jpg\" media=\"(max-width: 768px)\">\n                    <img src=\"/assets/img/training/case02-pc.jpg\">\n                  </picture>\n                </div>\n                <div class=\"-txtbox\">\n                  <div class=\"-group\">\n                    <p class=\"-group-en\">Q1-Training Impressions</p>\n                    <h3 class=\"-group-question\">研修に参加した感想を教えてください</h3>\n                    <p class=\"-group-answer\">学びと挑戦で自分を育てる研修</p>\n                  </div>\n                  <p class=\"-txt\">\n                    研修を受けて感じたのは、この会社が「人としての在り方」をとても大切にしているということです。入社して最初の1か月の研修では、謙虚さや素直さといった姿勢を学ぶ授業があって、そういう人間性を重視する会社なんだと改めて実感しました。自分もそうなりたいという気持ちが強くなりましたね。もう一つ印象的だったのは、自分の考えややりたいことを発表できる「取り組み」の機会があること。これまでの職場では言われたことをこなすだけでしたが、ここでは「自分から提案していいんだ」と思える環境があって、とても楽しいです。次は何に挑戦しようかなとワクワクします。\n                  </p>\n                </div>\n              </div>\n            </div>\n          </section>\n\n          <!-- p-training-block -->\n          <section class=\"p-training-block p-training-block--02 js-anime\">\n            <p class=\"p-training-block__bgttl\">question 02</p>\n            <div class=\"inner p-training-block--inner\">\n              <div class=\"p-training-block__outer flex is-between\">\n                <div class=\"-img\">\n                  <picture>\n                    <source srcset=\"/assets/img/training/case03-sp.jpg\" media=\"(max-width: 768px)\">\n                    <img src=\"/assets/img/training/case03-pc.jpg\">\n                  </picture>\n                </div>\n                <div class=\"-txtbox\">\n                  <div class=\"-group\">\n                    <p class=\"-group-en\">Q2-Training Activities</p>\n                    <h3 class=\"-group-question\">研修の中で具体的にどんな取り組みを行いましたか？ </h3>\n                    <p class=\"-group-answer\">お客様のために自分にできることはないか</p>\n                  </div>\n                  <p class=\"-txt\">\n                    最初の取り組みでは、「お客様に迷惑をかけないように、業務をすべて覚える」という目標を立てました。そのために、自分だけのノートを作って、教わったことをすぐに書き留め、いつでも見返せるようにしたんです。そうすることで、同じことを何度も聞かずに済むし、お客様をお待たせする時間も減らせる。小さな工夫かもしれませんが、自分の成長にもつながったと思います。このノートは今でも見返すことが多く、自分の努力の証にもなっています。\n                  </p>\n                </div>\n              </div>\n            </div>\n          </section>\n\n          <!-- p-training-feature -->\n          <section class=\"p-training-feature inner p-training-feature--inner\">\n            <div class=\"-txtbox\">\n              <p class=\"-ttl\">私の「好き」なもの<br class=\"sp\"><span class=\"-en\">My Favorites</span></p>\n              <h3 class=\"-catch\">私は、「ME:Iと歌」が大好きです！</h3>\n              <p class=\"-txt\">\n                私は「ME:I」というガールズグループが大好きなんです！メンバーの歌声がすごく魅力的で、聴いていると自然と元気をもらえます。もともと私自身も歌うことが好きで、実は研修の中で、皆さんの前で歌を披露したこともあるんですよ。緊張したけど、みんなが温かく聴いてくれて、それもすごくいい思い出になりました！\n              </p>\n            </div>\n            <div class=\"-img\">\n              <picture>\n                <source srcset=\"/assets/img/training/case04-sp.png\" media=\"(max-width: 768px)\">\n                <img src=\"/assets/img/training/case04-pc.png\">\n              </picture>\n            </div>\n          </section>\n        </div>\n\n\n\n        <!-- p-training-midimg -->\n        <div class=\"p-training-midimg\"></div>\n\n        <!-- p-training-mv -->\n        <div class=\"p-training-mv\">\n          <div class=\"p-training-mv__bg p-training-mv__bg--02\"></div>\n          <p class=\"p-training-mv__ttl\">staff<br>voices</p>\n          <p class=\"p-training-mv__num\">case<br>#02</p>\n          <div class=\"p-training-mv__img p-training-mv__img--02 js-anime\">\n            <img src=\"/assets/img/training/case06.png\">\n          </div>\n          <div class=\"p-training-mv__txtbox p-training-mv__txtbox--02\">\n            <p class=\"-name\">\n              <span class=\"-bg\">\n                <span class=\"-jp\">岡田 麻梨菜</span>\n                <span class=\"-en\">MARINA OKADA</span>\n              </span>\n            </p>\n            <p class=\"-txt -txt--01\"><span class=\"-txtin\">「私でも大丈夫」という</span></p>\n            <p class=\"-txt -txt--02\"><span class=\"-txtin\">強い自信が持てました。</span></p>\n          </div>\n          <div class=\"p-training-mv__profile p-training-mv__profile--02\">\n            <p class=\"-name\">\n              <span class=\"-en\">\n                profile\n              </span>\n            </p>\n            <p class=\"-txt -txt--01\"><span class=\"-txtin\">入社年月日：2018年 入社</span></p>\n            <p class=\"-txt -txt--02\"><span class=\"-txtin\">所属部署：レンタル部 スタッフ</span></p>\n          </div>\n        </div>\n\n        <div class=\"p-training-bgcolor\">\n          <!-- p-training-block -->\n          <section class=\"p-training-block js-anime\">\n            <p class=\"p-training-block__bgttl\">question 01</p>\n            <div class=\"inner p-training-block--inner\">\n              <div class=\"p-training-block__outer flex is-between\">\n                <div class=\"-img\">\n                  <picture>\n                    <source srcset=\"/assets/img/training/case07-sp.jpg\" media=\"(max-width: 768px)\">\n                    <img src=\"/assets/img/training/case07-pc.jpg\">\n                  </picture>\n                </div>\n                <div class=\"-txtbox\">\n                  <div class=\"-group\">\n                    <p class=\"-group-en\">Q1-Training Impressions</p>\n                    <h3 class=\"-group-question\">研修に参加した感想を教えてください</h3>\n                    <p class=\"-group-answer\">挑戦と成長で“無敵モード”に</p>\n                  </div>\n                  <p class=\"-txt\">\n                    最初は4年間も研修期間があるなんて長いなと思っていたんですけど、実際に重ねていくうちにすごく楽しく感じるようになりました。研修が終わる頃には、なんだか無敵モードに入った気分で、何でもできるんじゃないかと思えるようになったんです。周りがいろんなことを肯定してくれるし、教えてくれるので、実際にやって考えてまとめて提出する、という経験を通して「社会人としてやっていける」という自信がつきました。その後も実践でフォローしてくれるので、挑戦するのが楽しくなる研修です。\n                  </p>\n                </div>\n              </div>\n            </div>\n          </section>\n\n          <!-- p-training-block -->\n          <section class=\"p-training-block p-training-block--02 js-anime\">\n            <p class=\"p-training-block__bgttl\">question 02</p>\n            <div class=\"inner p-training-block--inner\">\n              <div class=\"p-training-block__outer flex is-between\">\n                <div class=\"-img\">\n                  <picture>\n                    <source srcset=\"/assets/img/training/case08-sp.jpg\" media=\"(max-width: 768px)\">\n                    <img src=\"/assets/img/training/case08-pc.jpg\">\n                  </picture>\n                </div>\n                <div class=\"-txtbox\">\n                  <div class=\"-group\">\n                    <p class=\"-group-en\">Q2-Training Activities</p>\n                    <h3 class=\"-group-question\">研修の中で具体的にどんな取り組みを行いましたか？ </h3>\n                    <p class=\"-group-answer\">同期と共に意見を交わし成長する</p>\n                  </div>\n                  <p class=\"-txt\">\n                    研修はテーマごとに進められていて、同期と一緒にディスカッションする機会が多かったです。同期だからこそ話しやすいし、アドバイスも指摘もしやすい、意見を出しやすい環境があったのが良かったですね。こういう環境で何度も発言していると、自分の考えや想いを言葉にするのが自然になって、どんどん自信がつきました。互いに学び合える雰囲気があるので、単なる研修以上に成長を実感できる取り組みでした。\n                  </p>\n                </div>\n              </div>\n            </div>\n          </section>\n\n          <!-- p-training-feature -->\n          <section class=\"p-training-feature inner p-training-feature--inner\">\n            <div class=\"-txtbox\">\n              <p class=\"-ttl\">私の「好き」なもの<br class=\"sp\"><span class=\"-en\">My Favorites</span></p>\n              <h3 class=\"-catch\">私は、「食べること」が大好きです！</h3>\n              <p class=\"-txt\">\n                私は食べることが大好きです！ジャンクなものも好きですけど、野菜もすごく好きで、中でもなすは家族みんなのお気に入りです。お浸しにしても、お肉と合わせてもおいしいし、料理のバリエーションも豊富なので、できるなら無限に食べたいくらい！食べることは私の元気の源で、毎日の楽しみの一つになっています。\n              </p>\n            </div>\n            <div class=\"-img -img02\">\n              <picture>\n                <source srcset=\"/assets/img/training/case09-sp.png\" media=\"(max-width: 768px)\">\n                <img src=\"/assets/img/training/case09-pc.png\">\n              </picture>\n            </div>\n          </section>\n        </div>\n\n        <!-- p-training-planning -->\n        <section class=\"p-training-planning\">\n          <div class=\"c-ttl02box p-training-planning--ttl\">\n            <h2 class=\"c-ttl02 js-anime\">planning<span class=\"-jp\">研修担当者の想い</span></h2>\n          </div>\n          <!-- p-training-feature -->\n          <section class=\"p-training-feature inner p-training-feature--inner p-training-feature--02\">\n            <div class=\"-txtbox\">\n              <div class=\"-txtbox-in flex\">\n                <p class=\"-ttl\">研修担当者</p>\n                <h3 class=\"-catch\">和氣 徳子<span class=\"-en\">NORIko Wake</span></h3>\n              </div>\n              <p class=\"-txt\">\n                研修はただの学びの場ではなく、皆さんが戻ってくる場所でもあります。日々の業務で忙しくなると、大事にしていることを忘れがちですが、研修を通じて改めて会社の価値観や基本を思い出してもらえればと思っています。スタッフ一人ひとりの成長やアイデアに触れるたび、私自身も刺激を受け、学びがあります。皆さんが楽しみながら成長できる研修を、これからも一緒に作っていきたいです。\n              </p>\n            </div>\n            <div class=\"-img -img03\">\n              <picture>\n                <source srcset=\"/assets/img/training/planning01-sp.png\" media=\"(max-width: 768px)\">\n                <img src=\"/assets/img/training/planning01-pc.png\">\n              </picture>\n            </div>\n          </section>\n\n          <!-- p-training-block -->\n          <section class=\"p-training-block p-training-block--mt js-anime\">\n            <p class=\"p-training-block__bgttl\">question 01</p>\n            <div class=\"inner p-training-block--inner\">\n              <div class=\"p-training-block__outer flex is-between p-training-block__outer--02\">\n                <div class=\"-img\">\n                  <picture>\n                    <source srcset=\"/assets/img/training/planning02-sp.jpg\" media=\"(max-width: 768px)\">\n                    <img src=\"/assets/img/training/planning02-pc.jpg\">\n                  </picture>\n                </div>\n                <div class=\"-txtbox\">\n                  <div class=\"-group\">\n                    <p class=\"-group-en\">Q1-Training Approach</p>\n                    <h3 class=\"-group-question\">研修担当者としての想いや、<br class=\"pc\">工夫していることはありますか？</h3>\n                    <p class=\"-group-answer\">一人ひとりに合わせた“オーダーメイド研修”</p>\n                  </div>\n                  <p class=\"-txt\">\n                    研修は毎回同じ内容ではなく、参加される皆さんに合った内容を考えることから始めています。名前や特徴をメモして「この人たちにはこういう内容がいいかな」とイメージして組み立てるのが私の楽しみです。事前に業務内容や取り組みもリサーチして、より実践的で楽しい研修になるよう工夫しています。講師として進行する立場ではありますが、実際には参加者から学ぶことも多く、互いに成長を感じながら進められるのが魅力です。\n                  </p>\n                </div>\n              </div>\n            </div>\n          </section>\n\n          <!-- p-training-block -->\n          <section class=\"p-training-block p-training-block--02 js-anime\">\n            <p class=\"p-training-block__bgttl\">question 02</p>\n            <div class=\"inner p-training-block--inner\">\n              <div class=\"p-training-block__outer flex is-between p-training-block__outer--02\">\n                <div class=\"-img\">\n                  <picture>\n                    <source srcset=\"/assets/img/training/planning03-sp.jpg\" media=\"(max-width: 768px)\">\n                    <img src=\"/assets/img/training/planning03-pc.jpg\">\n                  </picture>\n                </div>\n                <div class=\"-txtbox\">\n                  <div class=\"-group\">\n                    <p class=\"-group-en\">Q2-What I Observe</p>\n                    <h3 class=\"-group-question\">研修を通して感じることはありますか？</h3>\n                    <p class=\"-group-answer\">成長を共に喜ぶ場づくり</p>\n                  </div>\n                  <p class=\"-txt\">\n                    研修を通じて、参加者の成長や変化を感じられることが何よりの喜びです。人によって成長スピードやテーマの吸収の仕方が違うので、前年と比べて「こう変わったな」と実感できる瞬間があります。また、研修は離れて勤務するスタッフが集まる貴重な機会でもあり、会えること自体が嬉しいですね。過去には外で料理を作る研修などもあり、一方的に教えるのではなく、共に学び合う場を作ることで、より深い学びや気づきが生まれています。\n                  </p>\n                </div>\n              </div>\n            </div>\n          </section>\n        </section>\n\n\n\n\n\n        <!-- c-recruit-layout -->\n        <section class=\"c-recruit-layout\">\n          <div class=\"inner c-recruit-layout--inner\">\n            <div class=\"c-recruit-layout__area flex\">\n              <div class=\"c-recruit-layout__area-left\">\n                <div class=\"c-ttl02box c-recruit-layout__area-left--ttl\">\n                  <h2 class=\"c-ttl02 js-anime\">recruit<span class=\"-jp\">採用情報</span></h2>\n                </div>\n                <p class=\"-catch\">地域と共に、人も育つ。<br>トヨタレンタリース西四国の<br><span class=\"-color\">未来</sapn>を一緒に。</p>\n                <p class=\"c-recruit-layout-txt\">\n                  愛媛・高知のあたたかさそのままに、職場も明るく居心地の良い環境が自慢です。役職や年齢に関係なく、意見を出し合い、助け合える関係性が根づいています。<br>地域の方々に寄り添いながら、自分らしくのびのびと働ける職場で、一緒に成長していきませんか？\n                </p>\n                <div class=\"c-btn01 c-recruit-layout--btn\">\n                  <a href=\"/recruit/\">\n                    <p class=\"-txt\">採用情報を見る</p>\n                  </a>\n                </div>\n              </div>\n              <div class=\"c-recruit-layout__area-right\">\n                <div class=\"-bgicon\">\n                  <img src=\"/assets/img/top/recruit-bg.png\">\n                </div>\n                <div class=\"-imgbox01 js-anime\">\n                  <div class=\"-in js-pararax\">\n                    <img src=\"/assets/img/top/recruit-img01.jpg\">\n                  </div>\n                </div>\n                <div class=\"-imgbox02 js-anime\">\n                  <div class=\"-in js-pararax\">\n                    <img src=\"/assets/img/top/recruit-img02.jpg\">\n                  </div>\n                </div>\n                <div class=\"-imgbox03 js-anime\">\n                  <div class=\"-in js-pararax\">\n                    <img src=\"/assets/img/top/recruit-img03.jpg\">\n                  </div>\n                </div>\n              </div>\n            </div>\n          </div>\n          <p class=\"c-recruit-layout__icon js-anime\">\n            <img src=\"/assets/img/top/recruitsec-icon.png\">\n          </p>\n        </section>\n        <div class=\"c-link-area\">\n          <div class=\"inner c-link-area--inner\">\n            <div class=\"c-link-area__block flex\">\n              <!-- c-link-area__block-item -->\n              <div class=\"c-link-area__block-item\">\n                <a class=\"-link\" href=\"/company/\">\n                  <div class=\"-img -img01\"></div>\n                  <div class=\"-txtbox\">\n                    <h3 class=\"-ttl\"><span class=\"-en\">Company</span>会社概要</h3>\n                  </div>\n                  <div class=\"-arrow\"></div>\n                </a>\n              </div>\n              <!-- c-link-area__block-item -->\n              <div class=\"c-link-area__block-item\">\n                <a class=\"-link\" href=\"/recruit/\">\n                  <div class=\"-img -img02\"></div>\n                  <div class=\"-txtbox\">\n                    <h3 class=\"-ttl\"><span class=\"-en\">Recruit</span>採用情報</h3>\n                  </div>\n                  <div class=\"-arrow\"></div>\n                </a>\n              </div>\n              <!-- c-link-area__block-item -->\n              <div class=\"c-link-area__block-item\">\n                <a class=\"-link\" href=\"/recruit/data/\">\n                  <div class=\"-img -img03\"></div>\n                  <div class=\"-txtbox\">\n                    <h3 class=\"-ttl\"><span class=\"-en\">Date</span>数字で見る</h3>\n                  </div>\n                  <div class=\"-arrow\"></div>\n                </a>\n              </div>\n              <!-- c-link-area__block-item -->\n              <div class=\"c-link-area__block-item\">\n                <a class=\"-link\" href=\"/recruit/interview/\">\n                  <div class=\"-img -img04\"></div>\n                  <div class=\"-txtbox\">\n                    <h3 class=\"-ttl\"><span class=\"-en\">Interview</span>社員インタビュー一覧</h3>\n                  </div>\n                  <div class=\"-arrow\"></div>\n                </a>\n              </div>\n              <!-- c-link-area__block-item -->\n              <div class=\"c-link-area__block-item\">\n                <a class=\"-link\" href=\"/recruit/training/\">\n                  <div class=\"-img -img05\"></div>\n                  <div class=\"-txtbox\">\n                    <h3 class=\"-ttl\"><span class=\"-en\">Training</span>研修制度</h3>\n                  </div>\n                  <div class=\"-arrow\"></div>\n                </a>\n              </div>\n\n            </div>\n          </div>\n        </div>\n        <!-- l-footer -->\n        <footer class=\"l-footer\">\n          <div class=\"l-footer-area\">\n            <div class=\"l-footer-area__pagetop\">\n              <a href=\"#\">\n                <p class=\"l-footer-area__pagetop-txt\">page top</p>\n              </a>\n            </div>\n            <div class=\"l-footer-area__block inner\">\n              <div class=\"l-footer-area__block-top flex is-between\">\n                <div class=\"-left flex\">\n                  <div class=\"-logo\">\n                    <a href=\"/\">\n                      <img src=\"/assets/img/common/f-logo.svg\">\n                    </a>\n                  </div>\n                  <p class=\"-access\">株式会社トヨタレンタリース西四国<br>〒791-8042 松山市南吉田町2750-12</p>\n                </div>\n                <div class=\"-insta\">\n                  <a href=\"https://www.instagram.com/toyota_nishishikoku/\" target=\"_blank\"><img\n                      src=\"/assets/img/common/insta-icon-wh.svg\"></a>\n                </div>\n              </div>\n  