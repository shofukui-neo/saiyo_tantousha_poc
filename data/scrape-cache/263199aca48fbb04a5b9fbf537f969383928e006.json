\">\r\n      <!-- article -->\r\n      <article class=\"article article--full\">\r\n\r\n      <div class=\"sustopSection_copy-box\">\r\n        <p class=\"sustopSection_copy\">\r\n          シンプレクスグループは、ビジネスを通じて社会にポジティブなインパクトをもたらすとともに、持続可能な社会の実現に向けて、イノベーション創出企業としての責任を果たしていきます。\r\n        </p>\r\n      </div>\r\n\r\n      <div class=\"h2 title\">\r\n        <div class=\"title__label\">Message from the CEO</div>\r\n        <h2 class=\"title__summary\">トップメッセージ</h2>\r\n      </div>\r\n\r\n      <!-- pc tablet -->\r\n      <div class=\"sustop__companyinfo\">\r\n        <div class=\"sustop__companyinfo__lists\">\r\n          <div class=\"sustop__companyinfo__list\">\r\n              <figure class=\"sustop__companyinfo__image\">\r\n                <img decoding=\"async\" src=\"/assets/img/company/message/message_image_pc.jpg\" alt=\"\" width=\"720\" height=\"960\" class=\"js-srcswap\">\r\n                <a href=\"/company/message/\">\r\n                  <div class=\"sustop__message__nameplate\">\r\n                    <p class=\"sustop__message__position\">\r\n                      シンプレクス・ホールディングス株式会社<br>\r\n                      代表取締役社長\r\n                    </p>\r\n                    <p class=\"sustop__message__name\">\r\n                      金子 英樹\r\n                    </p>\r\n                    <div class=\"sustop__companyinfo__button\">\r\n                      <span class=\"morebutton\">\r\n                        <span class=\"morebutton__label\"> View More </span>\r\n                      </span>\r\n                    </div>\r\n                  </div>\r\n                </a>\r\n              </figure>\r\n\r\n          </div>\r\n        </div>\r\n      </div>\r\n      <!-- /pc tablet -->\r\n      <!-- sp only -->\r\n      <div class=\"sustop__message__indexblock\">\r\n        <div class=\"indexblock__items\">\r\n          <div class=\"indexblock__item\">\r\n            <a href=\"/ir/management/message/\">\r\n              <figure class=\"indexblock__image\">\r\n                  <img decoding=\"async\" loading=\"lazy\" src=\"/assets/img/company/top/index_image_message@2x.jpg\" alt=\"\" width=\"720\" height=\"480\" />\r\n              </figure>\r\n              <p class=\"indexblock__label\">トップメッセージ</p>\r\n            </a>\r\n          </div>\r\n        </div>\r\n      </div>\r\n      <!-- /sp only -->\r\n\r\n\r\n      <div class=\"h2 title\">\r\n        <div class=\"title__label\">Sustainability Management</div>\r\n        <h2 class=\"title__summary\">サステナビリティマネジメント</h2>\r\n      </div>\r\n      \r\n      <div class=\"infobox__lists\">\r\n        <div class=\"infobox__list\">\r\n          <a href=\"/sustainability/management/#management_headline_01\">\r\n            <span class=\"infobox__label\"> サステナビリティ方針 </span>\r\n          </a>\r\n          <span class=\"infobox__base\">\r\n            <img decoding=\"async\" src=\"/assets/img/common/infobox_base.png\" alt=\"\" width=\"270\" height=\"270\" />\r\n          </span>\r\n        </div>\r\n        <div class=\"infobox__list\">\r\n          <a href=\"/sustainability/management/#management_headline_02\">\r\n            <span class=\"infobox__label\"> 推進体制 </span>\r\n          </a>\r\n          <span class=\"infobox__base\">\r\n            <img decoding=\"async\" src=\"/assets/img/common/infobox_base.png\" alt=\"\" width=\"270\" height=\"270\" />\r\n          </span>\r\n        </div>\r\n        <div class=\"infobox__list\">\r\n          <a href=\"/sustainability/management/#management_headline_03\">\r\n            <span class=\"infobox__label\"> マテリアリティの特定 </span>\r\n          </a>\r\n          <span class=\"infobox__base\">\r\n            <img decoding=\"async\" src=\"/assets/img/common/infobox_base.png\" alt=\"\" width=\"270\" height=\"270\" />\r\n          </span>\r\n        </div>\r\n        <div class=\"infobox__list\">\r\n          <a href=\"/sustainability/management/#management_headline_04\" rel=\"noopener\">\r\n            <span class=\"infobox__label\"> マテリアリ