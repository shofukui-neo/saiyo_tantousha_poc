"application/json+oembed\" href=\"https://field.ne.jp/wp-json/oembed/1.0/embed?url=https%3A%2F%2Ffield.ne.jp%2Fcontact_send\" />\n<link rel=\"alternate\" type=\"text/xml+oembed\" href=\"https://field.ne.jp/wp-json/oembed/1.0/embed?url=https%3A%2F%2Ffield.ne.jp%2Fcontact_send&#038;format=xml\" />\n<style type=\"text/css\">.recentcomments a{display:inline !important;padding:0 !important;margin:0 !important;}</style></head>\n<body class=\"top cms\">\n\t<div class=\"content-wrap\">\n\t\t<header>\n    <div class=\"l-header\">\n        <div class=\"l-title\"><a href=\"https://field.ne.jp/index.php\"><h1><img src=\"https://field.ne.jp/images/main-logo.png\" alt=\"株式会社IGER\"></h1></a>\n        </div>\n\n        <div class=\"l-menu-trigger__box mb-object\">\n            <div class=\"l-menu-trigger\">\n                <p class=\"menu-trigger\">\n                    <span></span>\n                    <span></span>\n                    <span></span>\n                </p>\n            </div>\n        </div>\n        <div class=\"l-menu\">\n            <ul class=\"category-list\">\n                <li><a href=\"https://field.ne.jp/index.php#who_we_are\">WHO WE ARE</a></li>\n                <li><a href=\"https://field.ne.jp/index.php#our_works\">OUR WORKS</a></li>\n                <li><a href=\"https://field.ne.jp/index.php#offices\">OFFICES</a></li>\n                <li><a href=\"https://field.ne.jp/index.php#recruit\">RECRUIT</a></li>\n                <li><a href=\"https://field.ne.jp/index.php#news\">NEWS</a></li>\n                <li><a href=\"https://field.ne.jp/index.php#ir\">IR</a></li>\n                <li><a href=\"https://field.ne.jp/index.php#contact\">CONTACT</a></li>\n            </ul>\n        </div>\n    </div>\n</header>\n<div class=\"video-wrap\">\n    <video playsinline autoplay loop muted preload class=\"video-fix\">\n        <source src=\"https://field.ne.jp/movie/top.mp4\" type=\"video/mp4\">\n    </video>\n</div>\n\n\t\t<!-- <div class=\"test_num\">\n\t\t\t<p class=\"test_scroll\"></p>\n\t\t\t<p class=\"test_width\"></p>\n\t\t\t<p class=\"test_window\"></p>\n\t\t</div>\t -->\t\t<div class=\"top-section header-anchor contact\" id=\"contact\">\n\t<div class=\"section-inner\">\n\t\t\t\t<div id=\"mw_wp_form_mw-wp-form-19\" class=\"mw_wp_form mw_wp_form_input  \">\n\t\t\t\t\t<script type=\"text/javascript\" charset=\"UTF-8\" src=\"https://zipaddr.github.io/zipaddrx.js?v=1.27\"></script><script type=\"text/javascript\" charset=\"UTF-8\">function zipaddr_ownb(){D.dli='-';D.wp='1';D.uver='6.0.12';D.sysid='MWWPForm';}</script><form method=\"post\" action=\"\" enctype=\"multipart/form-data\"><div class=\"contact-inner\">\n<div class=\"contact-text\">\n    下記の入力フォームに必要事項をご記入ください。<br />\n    「<span class=\"required\">＊</span>」は、ご記入必須項目です。必ずご記入してくださいますようお願い申し上げます。\n</div>\n<div class=\"contact-list\">\n<div class=\"contact-item\">\n<div class=\"title\">お問い合わせ区分<span class=\"required\">＊</span></div>\n<div class=\"content\">\n<p>\n<select name=\"type\" >\n\t\t\t<option value=\"企業\" >\n\t\t\t企業\t\t</option>\n\t\t\t<option value=\"大学\" >\n\t\t\t大学\t\t</option>\n\t\t\t<option value=\"高校\" >\n\t\t\t高校\t\t</option>\n\t\t\t<option value=\"その他\" >\n\t\t\tその他\t\t</option>\n\t</select>\n\n<input type=\"hidden\" name=\"__children[type][]\" value=\"{&quot;\\u4f01\\u696d&quot;:&quot;\\u4f01\\u696d&quot;,&quot;\\u5927\\u5b66&quot;:&quot;\\u5927\\u5b66&quot;,&quot;\\u9ad8\\u6821&quot;:&quot;\\u9ad8\\u6821&quot;,&quot;\\u305d\\u306e\\u4ed6&quot;:&quot;\\u305d\\u306e\\u4ed6&quot;}\" />\n</p>\n</div></div>\n<div class=\"contact-item\">\n<div class=\"title\">企業名/学校名<span class=\"required\">＊</span></div>\n<div class=\"content\">\n<p>\n<input type=\"text\" name=\"company\" size=\"34\" value=\"\" />\n</p>\n</div></div>\n<div class=\"contact-item\">\n<div class=\"title\">氏名（ご担当者名）<span class=\"required\">＊</span></div>\n<div class=\"content\">\n<p>\n<input type=\"text\" name=\"name01\" size=\"15\" value=\"\" placeholder=\"姓\" />\n　\n<input type=\"text\" name=\"name02\" size=\"15\" value=\"\" placeholder=\"名\" />\n</p>\n</div></div>\n<div class=\"contact-item\">\n<div class=\"title\">フリガナ<span class=\"required\">＊</span></div>\n<div class=\"content\">\n<p>\n<input type=\"text\" name=\"name03\" size=\"15\" value=\"\" placeholder=\"セイ\" />\n　\n<input type=\"text\" name=\"name04\" size=\"15\" value=\"\" placeholder=\"メイ\" />\n</p>\n</div></div>\n<div class=\"contact-item\">\n<div class=\"title\">メールアドレス<span class=\"required\">＊</span></div>\n<div class=\"content\">\n<p>\n<input type=\"text\" name=\"mail\" size=\"34\" value=\"\" />\n</p>\n</div></div>\n<div class=\"contact-item\">\n<div class=\"title\">メールアドレス(確認用)<span class=\"required\">＊</span></div>\n<div class=\"content\">\n<p>\n<input type=\"text\" name=\"mail_confirm\" size=\"34\" value=\"\" />\n</p>\n</div></div>\n<div class=\"contact-item\">\n<div class=\"title\">電話番号<span class=\"required\">＊</span></div>\n<div class=\"content\">\n<p>\n<input type=\"text\" name=\"tel\" size=\"34\" value=\"\" />\n</p>\n</div></div>\n<div class=\"contact-item\">\n<div class=\"title\">ご住所<span class=\"required\">＊</span></div>\n<div class=\"content\">\n<p>〒 \n<input type=\"text\" name=\"zip\" id=\"zip\" size=\"12\" value=\"\" placeholder=\"郵便番号\" />\n</p>\n<p>\n<input type=\"text\" name=\"add01\" id=\"pref\" size=\"15\" value=\"\" placeholder=\"都道府県\" />\n\n<input type=\"text\" name=\"add02\" id=\"city\" size=\"15\" value=\"\" placeholder=\"市区町村\" />\n<br />\n<input type=\"text\" name=\"add03\" id=\"addr\" size=\"25\" value=\"\" placeholder=\"町名・番地・建物名\" />\n</p>\n</div></div>\n<div class=\"contact-item\">\n<div class=\"title\">お問い合せ項目<br />（複数解答可）</div>\n<div class=\"content\">\n<p>\n\t<span class=\"mwform-checkbox-field horizontal-item\">\n\t\t<label >\n\t\t\t<input type=\"checkbox\" name=\"contact[data][]\" value=\"グラフィックデザイン\" />\n\t\t\t<span class=\"mwform-checkbox-field-text\">グラフィックデザイン</span>\n\t\t</label>\n\t</span>\n\t<span class=\"mwform-checkbox-field horizontal-item\">\n\t\t<label >\n\t\t\t<input type=\"checkbox\" name=\"contact[data][]\" value=\"Webデザイン\" />\n\t\t\t<span class=\"mwform-checkbox-field-text\">Webデザイン</span>\n\t\t</label>\n\t</span>\n\t<span class=\"mwform-checkbox-field horizontal-item\">\n\t\t<label >\n\t\t\t<input type=\"checkbox\" name=\"contact[data][]\" value=\"番組制作・ムービー\" />\n\t\t\t<span class=\"mwform-checkbox-field-text\">番組制作・ムービー</span>\n\t\t</label>\n\t</span>\n\t<span class=\"mwform-checkbox-field horizontal-item\">\n\t\t<label >\n\t\t\t<input type=\"checkbox\" name=\"contact[data][]\" value=\"卒業アルバム\" />\n\t\t\t<span class=\"mwform-checkbox-field-text\">卒業アルバム</span>\n\t\t</label>\n\t</span>\n\t<span class=\"mwform-checkbox-field horizontal-item\">\n\t\t<label >\n\t\t\t<input type=\"checkbox\" name=\"contact[data][]\" value=\"リクルートについて\" />\n\t\t\t<span class=\"mwform-checkbox-field-text\">リクルートについて</span>\n\t\t</label>\n\t</span>\n\t<span class=\"mwform-checkbox-field horizontal-item\">\n\t\t<label >\n\t\t\t<input type=\"checkbox\" name=\"contact[data][]\" value=\"イベント・謝恩会について\" />\n\t\t\t<span class=\"mwform-checkbox-field-text\">イベント・謝恩会について</span>\n\t\t</label>\n\t</span>\n\t<span class=\"mwform-checkbox-field horizontal-item\">\n\t\t<label >\n\t\t\t<input type=\"checkbox\" name=\"contact[data][]\" value=\"その他\" />\n\t\t\t<span class=\"mwform-checkbox-field-text\">その他</span>\n\t\t</label>\n\t</span>\n\n<input type=\"hidden\" name=\"contact[separator]\" value=\",\" />\n\n<input type=\"hidden\" name=\"__children[contact][]\" value=\"{&quot;\\u30b0\\u30e9\\u30d5\\u30a3\\u30c3\\u30af\\u30c7\\u30b6\\u30a4\\u30f3&quot;:&quot;\\u30b0\\u30e9\\u30d5\\u30a3\\u30c3\\u30af\\u30c7\\u30b6\\u30a4\\u30f3&quot;,&quot;Web\\u30c7\\u30b6\\u30a4\\u30f3&quot;:&quot;Web\\u30c7\\u30b6\\u30a4\\u30f3&quot;,&quot;\\u756a\\u7d44\\u5236\\u4f5c\\u30fb\\u30e0\\u30fc\\u30d3\\u30fc&quot;:&quot;\\u756a\\u7d44\\u5236\\u4f5c\\u30fb\\u30e0\\u30fc\\u30d3\\u30fc&quot;,&quot;\\u5352\\u696d\\u30a2\\u30eb\\u30d0\\u30e0&quot;:&quot;\\u5352\\u696d\\u30a2\\u30eb\\u30d0\\u30e0&quot;,&quot;\\u30ea\\u30af\\u30eb\\u30fc\\u30c8\\u306b\\u3064\\u3044\\u3066&quot;:&quot;\\u30ea\\u30af\\u30eb\\u30fc\\u30c8\\u306b\\u3064\\u3044\\u3066&quot;,&quot;\\u30a4\\u30d9\\u30f3\\u30c8\\u30fb\\u8b1d\\u6069\\u4f1a\\u306b\\u3064\\u3044\\u3066&quot;:&quot;\\u30a4\\u30d9\\u30f3\\u30c8\\u30fb\\u8b1d\\u6069\\u4f1a\\u306b\\u3064\\u3044\\u3066&quot;,&quot;\\u305d\\u306e\\u4ed6&quot;:&quot;\\u305d\\u306e\\u4ed6&quot;}\" />\n</p>\n</div></div>\n<div class=\"contact-item\">\n<div class=\"title\">お問い合わせ内容</div>\n<div class=\"content\">\n<p>\n<textarea name=\"message\" cols=\"60\" rows=\"5\" ></textarea>\n</p>\n</div></div>\n</div>\n<div class=\"contact-privacy\">\n<h4 class=\"privacy-title\">お問い合わせにおける個人情報の取扱いについて</h4>\n<div class=\"privacy-box\">\n        <iframe src=\"https://field.ne.jp/iframe-privacy.html\"></iframe>\n    </div>\n<div class=\"privacy-btn\">\n\t<span class=\"mwform-checkbox-field vertical-item\">\n\t\t<label for=\"agree-1\">\n\t\t\t<input type=\"checkbox\" name=\"agree[data][]\" value=\"同意する\" id=\"agree-1\" />\n\t\t\t<span class=\"mwform-checkbox-field-text\">同意する</span>\n\t\t</label>\n\t</span>\n\n<input type=\"hidden\" name=\"agree[separator]\" value=\",\" />\n\n<input type=\"hidden\" name=\"__children[agree][]\" value=\"{&quot;\\u540c\\u610f\\u3059\\u308b&quot;:&quot;\\u540c\\u610f\\u3059\\u308b&quot;}\" />\n</div>\n</div>\n<div class=\"send-btn\">\n<input type=\"submit\" name=\"submitConfirm\" value=\"確認画面に進む\" />\n</div>\n</div>\n<input type=\"hidden\" name=\"mw-wp-form-form-id\" value=\"19\" /><input type=\"hidden\" name=\"mw_wp_form_token\" value=\"58c7b1bfd07c1e83929e7a8d518985389f537587c483d9e0326113064631354f\" /></form>\n\t\t\t\t<!-- end .mw_wp_form --></div>\n\t\t\t</div>\n</div> \n</div>\n<script type='text/javascript' src='https://field.ne.jp/iger-info/wp-content/plugins/mw-wp-form/js/form.js?ver=6.0.12' id='mw-wp-form-js'></script>\n</body>\n</html>","finalUrl":"https://field.ne.jp/contact_send",