-globalLink-child -->\r\n\r\n</li>\r\n\r\n</ul>\r\n</div><!-- header-links-bottom -->\r\n<div class=\"header-links-close\">\r\n<button class=\"header-links-close-buttton\">閉じる<span></span></button>\r\n</div>\r\n</div><!-- header-links -->\r\n</div><!-- toggle-menu -->\r\n</div><!-- header-main -->\r\n</div><!-- header-inner -->\r\n<span id=\"header-bg\"></span>\r\n</header>\r\n  <section class=\"section template-area breadcrumb-section\">\r\n    <div class=\"section-inner\">\r\n\r\n<ol class=\"breadcrumb-list\">\r\n\r\n<li><a href=\"/jp/\">HOME</a></li>\r\n\r\n<li>採用情報</li>\r\n\r\n</ol>\r\n\r\n    </div>\r\n  </section>\r\n  <section class=\"section template-area\">\r\n    <div class=\"page-heading-block \">\r\n\r\n<div class=\"image\">\r\n<picture>\r\n<source media=\"(max-width: 767px)\" srcset=\"/jp/recruit/uoavdk00000004ku-img/uoavdk00000004ld.jpg\">\r\n<img src=\"/jp/recruit/uoavdk00000004ku-img/uoavdk00000004lc.jpg\" alt=\"採用情報\">\r\n</picture>\r\n\r\n</div>\r\n\r\n\r\n      <div class=\"heading\">\r\n        \r\n        <h1>\r\n          採用情報\r\n        </h1>\r\n\r\n     </div>\r\n\r\n    </div>\r\n  </section>\r\n  <div id=\"contents\">\r\n    <main id=\"main\" role=\"main\">\r\n      <section class=\"section component-area\">\r\n        <div class=\"section-inner\">\r\n            <ul class=\"link-list list-left mb-middle\">\r\n\r\n<li>\r\n\r\n<p><a href=\"#section-h2-2\" target=\"_top\">採用に関するお問い合わせ</a></p>\r\n\r\n</li>\r\n\r\n<li>\r\n\r\n<p><a href=\"#section-h2-3\" target=\"_top\">一般事業主行動計画</a></p>\r\n\r\n</li>\r\n\r\n</ul>\r\n<hr>\r\n<h2 class=\"align-center mb-middle\">採用情報</h2>\r\n<div class=\"column-box-wrapper\">\r\n<div class=\"column-box col2 \">\r\n\r\n<div>\r\n\r\n<div class=\"media-box mb-middle\">\r\n<div>\r\n<div class=\"media\"><a href=\"https://www.ydktechs.co.jp/jp/ydk-saiyo/\" target=\"_blank\"><img src=\"/jp/recruit/uoavdk00000004ku-img/uoavdk0000000a9f.jpg\" alt=\"新卒採用情報\"></a></div>\r\n\r\n</div>\r\n</div>\r\n<h3 class=\"align-center mb-middle\"><a href=\"https://www.ydktechs.co.jp/jp/ydk-saiyo/\" target=\"_blank\">新卒採用情報</a></h3>\r\n\r\n<p class=\"  mb-middle\">新卒者向けの採用情報のご案内です。</p>\r\n\r\n\r\n</div>\r\n\r\n<div>\r\n\r\n<div class=\"media-box mb-middle\">\r\n<div>\r\n<div class=\"media\"><a href=\"https://ydk.snar.jp/index.aspx\" target=\"_blank\"><img src=\"/jp/recruit/uoavdk00000004ku-img/uoavdk0000000dx6.jpg\" alt=\"キャリア採用情報\"></a></div>\r\n\r\n</div>\r\n</div>\r\n<h3 class=\"align-center mb-middle\"><a href=\"https://ydk.snar.jp/index.aspx\" target=\"_blank\">キャリア採用情報</a></h3>\r\n\r\n<p class=\"  mb-middle\">事務経験のあるキャリア向け採用募集のご案内です。</p>\r\n\r\n\r\n</div>\r\n\r\n</div><!-- colBox -->\r\n</div>\r\n<hr class=\"margin-utility\">\r\n<hr>\r\n<h2 class=\" mb-middle\">採用に関するお問い合わせ</h2>\r\n<h3 class=\" mb-middle\">フォームによるお問い合わせ</h3>\r\n<p class=\" mb-middle\"><a href=\"/jp/contact/recruit/index.php\" target=\"_top\" class=\"link-button \"><span>お問い合わせ</span></a></p>\r\n\r\n<p class=\"  mb-middle\">※お問い合わせの内容によっては、回答にお時間がかかる場合もございますので、予めご了承いただきますようお願い致します。<br>\n※お急ぎの場合は恐れ入りますがお電話にてお問い合わせいただけると幸いです。</p>\r\n\r\n<h3 class=\" mb-middle\">お電話によるお問い合わせ</h3>\r\n\r\n<p class=\"  mb-small\">宛先：人事労務課　採用担当<br>\n電話：0463-84-8751（直通）</p>\r\n\r\n\r\n<p class=\"  mb-large\">＊お電話によるお問い合わせ時間に関して<br>\n月曜日～金曜日　9:30～12:00 13:00～17:00<br>\n但し、土・日・祝祭日・弊社が定める休業日及び年末年始は除きます。 お電話のおかけ間違えのないようお願いいたします。</p>\r\n\r\n<hr>\r\n<h3 class=\"align-center mb-middle\">中途採用比率（２０２３年度～２０２５年度）</h3>\r\n\r\n<p class=\" align-center mb-middle\">労働施策総合推進法に基づく中途採用比率の公表</p>\r\n\r\n<div class=\"scroll-table-box mb-small\">\r\n<table>\r\n<colgroup>\r\n<col style=\"width:30%\">\r\n</colgroup>\r\n\r\n\r\n<thead>\r\n<tr>\r\n\r\n<th>\r\n</th>\r\n\r\n<th>\r\n<p class=\" align-center mb-middle\">2023年度</p>\r\n\r\n</th>\r\n\r\n<th>\r\n<p class=\" align-center mb-middle\">2024年度</p>\r\n\r\n</th>\r\n\r\n<th>\r\n<p class=\" align-center mb-middle\">2025年度</p>\r\n\r\n</th>\r\n\r\n</tr>\r\n</thead>\r\n<tbody>\r\n\r\n\r\n<tr>\r\n\r\n<th>\r\n<p class=\" align-center mb-middle\">正規雇用労働者の中途採用比率</p>\r\n\r\n</th>\r\n\r\n<td>\r\n<p class=\" align-center mb-small\">66％</p>\r\n\r\n</td>\r\n\r\n<td>\r\n<p class=\" align-center mb-small\">71％</p>\r\n\r\n</td>\r\n\r\n<td>\r\n<p class=\" align-center mb-middle\">71％</p>\r\n\r\n</td>\r\n\r\n</tr>\r\n\r\n\r\n</tbody>\r\n</table>\r\n</div>\r\n\r\n<p class=\" align-right mb-middle\">公表日:2026年3月1日</p>\r\n\r\n<hr>\r\n<h2 class=\"align-center mb-middle\">一般事業主行動計画</h2>\r\n\r\n<p class=\"lede align-center mb-middle\">次世代育成支援対策推進法・女性活躍推進法に基づき、従業員の仕事と家庭の両立を目的に策定しました。<br>\n「一般事業主行動計画」及び女性の活躍に関する弊社の情報を公開します。</p>\r\n\r\n<div class=\"scroll-table-box mb-small\">\r\n<table>\r\n<colgroup>\r\n<col style=\"width:20%\">\r\n</colgroup>\r\n\r\n\r\n<tbody>\r\n\r\n\r\n<tr>\r\n\r\n<th>\r\n<p class=\"  mb-middle\">1.計画期間</p>\r\n\r\n</th>\r\n\r\n<td>\r\n<p class=\" align-left mb-middle\">2026年4月1日～2028年3月31日までの2年間</p>\r\n\r\n</td>\r\n\r\n</tr>\r\n\r\n\r\n\r\n<tr>\r\n\r\n<th>\r\n<p class=\"  mb-middle\">2.数値目標・取り組み内容</p>\r\n\r\n</th>\r\n\r\n<td>\r\n<p class=\" align-left mb-zero\">(1)女性管理職候補者の育成強化のための研修を、期間内に1回以上実施する。&nbsp;</p>\r\n\r\n\r\n<p class=\"  mb-small\">＜取組内容＞<br>\n将来の女性管理職候補者が、リーダーとして力を発揮できる基盤を築けるよう、学習機会を用意します。<br>\n自身の強みを伸ばしながら、マネジメントに必要な知識・スキルを習得できるよう、研修プログラムを通じて成長を支援します。</p>\r\n\r\n\r\n<p class=\"  mb-zero\">(2)女性社員の育児休職率100％を維持しつつ、男性社員の育休取得率55％以上を目指す。&nbsp;</p>\r\n\r\n\r\n<p class=\"  mb-small\">＜取組内容＞<br>\n従来どおり対象となる従業員には個別面談を実施し、育児休職に関する制度や手続きについて丁寧に案内します。<br>\n従業員一人ひとりの状況や要望を踏まえたきめ細かなサポートを行い、男女問わず育児休職を取得しやすい環境づくりを推進します。</p>\r\n\r\n\r\n<p class=\"  mb-zero\">(3)時間外労働を月平均20時間以内とする。&nbsp;</p>\r\n\r\n\r\n<p class=\"  mb-small\">＜取組内容＞<br>\n時間外労働が多い従業員については、個別に状況を確認し、業務量の調整や休暇取得の促進を行うことで、健康的で持続可能な働き方を支援します。</p>\r\n\r\n</td>\r\n\r\n</tr>\r\n\r\n\r\n\r\n<tr>\r\n\r\n<th>\r\n<p class=\"  mb-middle\">4.実施時期</p>\r\n\r\n</th>\r\n\r\n<td>\r\n<p class=\" align-left mb-middle\">計画期間内で適宜実施</p>\r\n\r\n</td>\r\n\r\n</tr>\r\n\r\n\r\n</tbody>\r\n</table>\r\n</div>\r\n<div class=\"column-box-wrapper\">\r\n<div class=\"column-box col2-ratio2to1 \">\r\n\r\n<div>\r\n\r\n\r\n</div>\r\n\r\n<div>\r\n\r\n<p class=\"  mb-zero\"><sup>「かながわ子育て応援団」の認証を受けています 。</sup></p>\r\n\r\n\r\n<div class=\"media-box mb-middle\">\r\n<div>\r\n<div class=\"media\"><img src=\"/jp/recruit/uoavdk00000004ku-img/sfr1l10000000380.jpg\" alt=\"\"></a></div>\r\n\r\n</div>\r\n</div>\r\n\r\n</div>\r\n\r\n</div><!-- colBox -->\r\n</div>\r\n<hr class=\"margin-utility\">\r\n\r\n        </div>\r\n      </section>\r\n    </main>\r\n  </div>\r\n<footer id=\"footer\">\r\n<a href=\"#\" id=\"pageTop\"><span>ページトップへ</span></a>\r\n<div class=\"footer-sitemap\">\r\n<div class=\"inner\">\r\n<ul class=\"footer-list\">\r\n\r\n<li>\r\n<a href=\"/jp/business/index.html\" target=\"_top\"> 事業紹介</a>\r\n\r\n<ul class=\"footer-subList\">\r\n\r\n<li>\r\n<a href=\"/jp/business/environment/index.html\" target=\"_top\">環境計測事業</a>\r\n</li>          \r\n\r\n<li>\r\n<a href=\"/jp/business/marine/index.html\" target=\"_top\">航海事業</a>\r\n</li>          \r\n\r\n<li>\r\n<a href=\"/jp/business/aerospace_combustion/index.html\" target=\"_top\">航空・燃焼事業</a>\r\n</li>          \r\n\r\n<li>\r\n<a href=\"/jp/business/index.html#section-h2-6\" target=\"_top\">防衛事業</a>\r\n</li>          \r\n\r\n</ul>\r\n \r\n</li>\r\n\r\n<li>\r\n<a href=\"/jp/product/index.html\" target=\"_top\">製品紹介</a>\r\n\r\n<ul class=\"footer-subList\">\r\n\r\n<li>\r\n<a href=\"/jp/product/meteorology/index.html\" target=\"_top\">気象観測機器</a>\r\n</li>          \r\n\r\n<li>\r\n<a href=\"/jp/product/hydrology/index.html\" target=\"_top\">水文観測機器</a>\r\n</li>          \r\n\r\n<li>\r\n<a href=\"/jp/product/transmission/index.html\" target=\"_top\">情報伝送機器・テンションメータ</a>\r\n</li>          \r\n\r\n<li>\r\n<a href=\"/jp/product/marine/index.html\" target=\"_top\">航海機器</a>\r\n</li>          \r\n\r\n<li>\r\n<a href=\"/jp/product/aerospace/index.html\" target=\"_top\">航空宇宙関連機器</a>\r\n</li>          \r\n\r\n<li>\r\n<a href=\"/jp/product/combustion/index.html\" target=\"_top\">燃焼関連機器</a>\r\n</li>         