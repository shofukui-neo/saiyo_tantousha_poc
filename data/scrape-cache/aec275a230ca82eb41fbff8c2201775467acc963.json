      src=\"../../../../recruit_assets/images/special/logo_iitokoro-red.svg\" alt=\"\">\n        </div>\n        <div class=\"specialKvSec__titleWrap\">\n          <h1 class=\"specialKvSec__title\">\n            SPECIAL</h1>\n          <p class=\"specialKvSec__subTitle\">スペシャルコンテンツ</p>\n        </div>\n      </div>\n    </section>\n    <div class=\"specialTab\">\n      <ul class=\"specialTab__list\">\n        <li class=\"specialTab__listItem is-current\"><a class=\"specialTab__itemLink\" href=\"#\">\n            <div class=\"specialTab__cont\">\n              <div class=\"specialTab__itemTtlWrap\">\n                <div class=\"specialTab__ttlSub\">男性社員に聞いた</div>\n                <div class=\"specialTab__logo\">\n                  <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"185.029\" height=\"33.6\" viewBox=\"0 0 185.029 33.6\">\n                    <g id=\"logo_イイトコロ\" transform=\"translate(0.5 1.1)\">\n                      <path id=\"イイトコロ\"\n                        d=\"M7757.006,5086v-19.538h6.271v13.267h14.639v-14.74h-20.909v-6.271h27.179V5086Zm-64.8,0v-17.682H7713.4v6.271h-14.921V5086Zm-26.316,0v-12.242l5.361-3.067V5086Zm-33.515,0v-12.242l5.362-3.067V5086Zm108.022-.47h-18.043v-6.39H7740.4v-12.912h6.39v19.3Zm-85.743-13.015,26.577-15.2v6.262l-26.577,15.2Zm-33.513,0,26.576-15.2v6.262l-26.576,15.2Zm71.064-5.5v-9.4h6.27v9.4Zm30.148-2.286v-6.39h24.433v6.39Zm70.2-10.728h3.094v5.524l-3.094,2.7Zm-4.382,0h3.094v5.524l-3.094,2.7ZM7616,5062.225V5056.7l3.093-2.7v8.225Zm-4.383,0V5056.7l3.094-2.7v8.225Z\"\n                        transform=\"translate(-7611.616 -5054)\" fill=\"#e60000\" stroke=\"rgba(0,0,0,0)\" stroke-width=\"1\">\n                      </path>\n                    </g>\n                  </svg>\n                </div>\n              </div>\n            </div>\n            <figure class=\"specialTab__fig\"><img class=\"specialTab__figImg u-pcDb\"\n                src=\"../../../../recruit_assets/images/special/specialTab_male.png\" alt=\"男性社員に聞いた\"><img\n                class=\"specialTab__figImg u-spDb\" src=\"../../../../recruit_assets/images/special/specialTab_male-sp.png\"\n                alt=\"男性社員に聞いた\"></figure>\n          </a></li>\n        <li class=\"specialTab__listItem\"><a class=\"specialTab__itemLink\"\n            href=\"../../../../recruit/special/goodmuf/woman/\">\n            <div class=\"specialTab__cont\">\n              <div class=\"specialTab__itemTtlWrap\">\n                <div class=\"specialTab__ttlSub\">女性社員に聞いた</div>\n                <div class=\"specialTab__logo\">\n                  <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"185.029\" height=\"33.6\" viewBox=\"0 0 185.029 33.6\">\n                    <g id=\"logo_イイトコロ\" transform=\"translate(0.5 1.1)\">\n                      <path id=\"イイトコロ\"\n                        d=\"M7757.006,5086v-19.538h6.271v13.267h14.639v-14.74h-20.909v-6.271h27.179V5086Zm-64.8,0v-17.682H7713.4v6.271h-14.921V5086Zm-26.316,0v-12.242l5.361-3.067V5086Zm-33.515,0v-12.242l5.362-3.067V5086Zm108.022-.47h-18.043v-6.39H7740.4v-12.912h6.39v19.3Zm-85.743-13.015,26.577-15.2v6.262l-26.577,15.2Zm-33.513,0,26.576-15.2v6.262l-26.576,15.2Zm71.064-5.5v-9.4h6.27v9.4Zm30.148-2.286v-6.39h24.433v6.39Zm70.2-10.728h3.094v5.524l-3.094,2.7Zm-4.382,0h3.094v5.524l-3.094,2.7ZM7616,5062.225V5056.7l3.093-2.7v8.225Zm-4.383,0V5056.7l3.094-2.7v8.225Z\"\n                        transform=\"translate(-7611.616 -5054)\" fill=\"#e60000\" stroke=\"rgba(0,0,0,0)\" stroke-width=\"1\">\n                      </path>\n                    </g>\n                  </svg>\n                </div>\n              </div>\n            </div>\n            <figure class=\"specialTab__fig\"><img class=\"specialTab__figImg u-pcDb\"\n                src=\"../../../../recruit_assets/images/special/specialTab_female.png\" alt=\"男性社員に聞いた\"><img\n                class=\"specialTab__figImg u-spDb\"\n                src=\"../../../../recruit_assets/images/special/specialTab_female-sp.png\" alt=\"男性社員に聞いた\"></figure>\n          </a></li>\n      </ul>\n    </div>\n    <div class=\"specialTtl\">\n      <div class=\"specialTtl__inner\">\n        <div class=\"specialTtl__lbl\">\n          <div class=\"specialTtl__lblWrap\"><span class=\"specialTtl__lblTxt\">社員に聞いた</span><img\n              class=\"specialTtl__lblLogo\" src=\"../../../../recruit_assets/images/special/logo_iitokoro.svg\" alt=\"イイトコロ\">\n          </div>\n        </div>\n        <h2 class=\"specialTtl__txt\">成長を応援してくれる会社。<br>若いうちから様々な経験を積める。</h2>\n      </div>\n    </div>\n    <div class=\"specialPosSec\">\n      <div class=\"specialPosSec__inner\">\n        <div class=\"specialPosSec__cont\">\n          <figure class=\"specialPosSec__fig\"><img class=\"specialPosSec__img\"\n              src=\"../../../../recruit_assets/images/special/img_specialPosition.png\" alt=\"#\"></figure>\n          <div class=\"specialPosSec__txtCont\">\n            <div class=\"specialPosSec__txtWrap\">\n              <p class=\"specialPosSec__txt\">東京ファクタリング営業第一部（総合職）</p><span class=\"specialPosSec__txtYear\">2009年入社</span>\n            </div>\n            <div class=\"specialPosSec__txtWrap\">\n              <p class=\"specialPosSec__txt\">東京ファクタリング営業第一部（総合職）</p><span class=\"specialPosSec__txtYear\">2015年入社</span>\n            </div>\n          </div>\n        </div>\n        <p class=\"specialPosSec__btmTxt\">※所属およびインタビュー内容は取材当時のものです。</p>\n      </div>\n    </div>\n    <div class=\"specialQuestionSec\">\n      <div class=\"specialQuestionSec__inner\">\n        <div class=\"specialQuestionSec__block\">\n          <div class=\"specialQuestionSec__blockQTtlWrap\"><span class=\"specialQuestionSec__blockQLbl\">Q1</span>\n            <div class=\"specialQuestionSec__blockQTtl\">三菱UFJファクター（MUF）で働く<br class=\"u-spDb\">魅力とは？</div>\n          </div>\n          <h2 class=\"specialQuestionSec__blockTtl\">MUFGグループならではの<br class=\"u-spDb\">ノウハウを活かし、<br class=\"u-pcDb\">付加価値を生む。\n          </h2>\n          <hr class=\"specialQuestionSec__hr\">\n          <div class=\"specialQuestionSec__blockInner\">\n            <div class=\"specialQuestionSec__blockTxtCont\">\n              <div class=\"specialQuestionSec__blockTxtWrap\"><img class=\"specialQuestionSec__blockImgSm\"\n                  src=\"../../../../recruit_assets/images/special/profile_man_sm-01.png\" alt=\"#\">\n                <p class=\"specialQuestionSec__blockTxt\">\n                  私はファクタリングの営業担当ですが、営業の仕事は契約がゴールではありません。ファクタリングを利用されるお客さまの多くは、定期的に契約を見直されます。当社を長く選び続けていただくために、他社との価値の違いを際立たせるのが営業の役目です。MUFGグループならではの知見を活かした提案で、長くお付き合いさせていただいているお客さまがたくさんいます。<br>お客さま自身も把握していないような潜在的な課題を見つけ、適切な形の商品を提案することによって、お客さまに満足していただき、末永くお付き合いをさせていただくことが最大のモチベーションですね。\n                </p>\n              </div>\n              <div class=\"specialQuestionSec__blockTxtWrap\"><img class=\"specialQuestionSec__blockImgSm\"\n                  src=\"../../../../recruit_assets/images/special/profile_man_sm-02.png\" alt=\"#\">\n                <p class=\"specialQuestionSec__blockTxt\">\n                  私は学生時代に経営学や会計学を専攻しており、関連分野である金融関係の会社に就職することを希望していました。他にも内定をいただいた会社はありましたが、銀行の最前線で仕事をしてきた方々のノウハウを身近で学べること・若手を登用していく意向があることの2点が入社の決め手でした。入社前は金融機関特有の厳格なイメージが頭を占めていましたが、実際には話しやすい方ばかりです。入社直後から今現在も定期的な研修によるフォローもあるので、安心して業務に取り組むことができています。\n                </p>\n              </div>\n            </div>\n          </div>\n        </div>\n        <div class=\"specialQuestionSec__block\">\n          <div class=\"specialQuestionSec__blockQTtlWrap\"><span class=\"specialQuestionSec__blockQLbl\">Q2</span>\n            <div class=\"specialQuestionSec__blockQTtl\">どんな経験・成長ができる？</div>\n          </div>\n          <h2 class=\"specialQuestionSec__blockTtl\">若手のうちから幅広い経験ができ、<br class=\"u-spDb\">視野が拡大。</h2>\n          <hr class=\"specialQuestionSec__hr\">\n          <div class=\"specialQuestionSec__blockInner\">\n            <figure class=\"specialQuestionSec__blockFig\"><img class=\"specialQuestionSec__blockImg\"\n                src=\"../../../../recruit_assets/images/special/profile_man_lg-01.png\" alt=\"#\"></figure>\n            <div class=\"specialQuestionSec__blockTxtCont\">\n              <div class=\"specialQuestionSec__blockTxtWrap\"><img class=\"specialQuestionSec__blockImgSm\"\n                  src=\"../../../../recruit_assets/images/special/profile_man_sm-01.png\" alt=\"#\">\n                <p class=\"specialQuestionSec__blockTxt\">\n                  現在は営業職ですが、本部計数管理に始まり商品開発や新拠点の立上げなど、様々な業務を経験してきました。入社4年目で新拠点の立上げに参画することになった時はとても驚きましたが、一営業担当としてだけでなく上位役職者の業務も経験することができ、視野が拡大しました。今後のキャリアパスに活きる大きな糧になりましたね。\n                </p>\n              </div>\n              <div class=\"specialQuestionSec__blockTxtWrap\"><img class=\"specialQuestionSec__blockImgSm\"\n                  src=\"../../../../recruit_assets/images/special/profile_man_sm-02.png\" alt=\"#\">\n                <p class=\"specialQuestionSec__blockTxt\">\n                  周りの方からのサポートにより、１つずつできることを増やして、階段を上るように着実にスキルを身につけることができていると思います。学生時代から指摘されていた「諦めの早さ」を改善するよう意識して粘り強く業務に取り組むことで成果も得られるようになり、それが自信と成長につながっていると感じています。\n                </p>\n              </div>\n            </div>\n          </div>\n        </div>\n        <div class=\"specialQuestionSec__block\">\n          <div class=\"specialQuestionSec__blockQTtlWrap\"><span class=\"specialQuestionSec__blockQLbl\">Q3</span>\n            <div class=\"specialQuestionSec__blockQTtl\">先輩・後輩の関係は？</div>\n          </div>\n          <h2 class=\"specialQuestionSec__blockTtl\">\n            手厚いサポートで<br>安心して日々の業務に取り組める。</h2>\n          <hr class=\"specialQuestionSec__hr\">\n          <div class=\"specialQuestionSec__blockInner blockReverse\">\n            <figure class=\"specialQuestionSec__blockFig\"><img class=\"specialQuestionSec__blockImg\"\n                src=\"../../../../recruit_assets/images/special/profile_man_lg-02.png\" alt=\"#\"></figure>\n            <div class=\"specialQuestionSec__blockTxtCont\">\n              <div class=\"specialQuestionSec__blockTxtWrap\"><img class=\"specialQuestionSec__blockImgSm\"\n                  src=\"../../../../recruit_assets/images/special/profile_man_sm-01.png\" alt=\"#\">\n                <p class=\"specialQuestionSec__blockTxt\">\n                  後輩の育成にあたり、大切にしていることは「良さ」を伸ばすことです。人それぞれ、得意も不得意もあるし向き不向きもあります。「絶対にやってはいけないこと」「絶対にやったほうがいいこと」ははっきりと伝えますが、全体としては自分の価値観を押し付けないよう心掛けています。勢いが良くて、それを大切にしてあげたいと考えながら接してきましたが、逆に私の方が学ばせてもらうこともありました（笑）。後輩の若手社員達がそれぞれの持ち場で活躍している様子を見ることは、モチベーションにもなりますね。\n                </p>\n              </div>\n              <div class=\"specialQuestionSec__blockTxtWrap\"><img class=\"specialQuestionSec__blockImgSm\"\n                  src=\"../../../../recruit_assets/images/special/profile_man_sm-02.png\" alt=\"#\">\n                <p class=\"specialQuestionSec__blockTxt\">\n                  フォロー体制がとてもしっかりしていますし、周りの方々が本当によく見ていてくれています。私は1～2年目にOJTの先輩と一緒に営業活動を行い、マンツーマンで手厚くサポートしてもらったので、安心して日々の業務に取り組むことができました。特に話し方に関しては、丁寧にアドバイスしてもらいました。日々接するのは一回りも二回りも年齢が上の方ばかりですので、失礼がないよう、かつしっかりと自分の考えを伝えるためにはどう話すべきか、受けたアドバイスは今でも大切にしています。\n                </p>\n              </div>\n            </div>\n          </div>\n        </div>\n        <div class=\"specialQuestionSec__block\">\n          <div class=\"specialQuestionSec__blockQTtlWrap\"><span class=\"specialQuestionSec__blockQLbl\">Q4</span>\n            <div class=\"specialQuestionSec__blockQTtl\">将来のビジョンや、<br class=\"u-spDb\">チャレンジしたいことは？</div>\n          </div>\n          <h2 class=\"specialQuestionSec__blockTtl\">\n            様々な経験を積んで希少な「人財」に。<br>リーディングカンパニーとして<br class=\"u-spDb\">新しい取り組みに挑戦。</h2>\n          <hr class=\"specialQuestionSec__hr\">\n          <div class=\"specialQuestionSec__blockInner flexColumn\">\n            <div class=\"specialQuestionSec__blockTxtCont\">\n              <div class=\"specialQuestionSec__blockTxtWrap\"><img class=\"specialQuestionSec__blockImgSm\"\n                  src=\"../../../../recruit_assets/images/special/profile_man_sm-01.png\" alt=\"#\">\n                <p class=\"specialQuestionSec__blockTxt\">\n                  「お客さまとの信頼関係の強さ」という当社の強みを残しつつ、フィンテックやAI分析等の最先端技術を取り入れた商品の開発など、業界のリーディングカンパニーであり続けるための新しい取組みに深く関わっていきたいですね。<br>これまでのキャリアでも貴重な経験をたくさん積ませてもらいましたが、今後も他の人が経験していないことをたくさん経験し、希少性のある「人財」になることが目標です。\n                </p>\n              </div>\n              <div class=\"specialQuestionSec__blockTxtWrap\"><img class=\"specialQuestionSec__blockImgSm\"\n                  src=\"../../../../recruit_assets/images/special/profile_man_sm-02.png\" alt=\"#\">\n                <p class=\"specialQuestionSec__blockTxt\">\n                  他部署や他本部で全く違う分野の仕事を経験し、様々な見識を得た上で自分のキャリアパスを築いていきたいです。<br>まだまだ長い道のりですが、身近にお手本となる方がいるので、少しでも近づけるよう学ばせてもらいたいです。そして、私が後進を育成する立場になった時に、私を見て「自分も頑張ろう」と思ってもらえるような先輩になっていたいです。\n                </p>\n              </div>\n            </div>\n            <figure class=\"specialQuestionSec__blockFig fullwidth u-pcDb\"><img class=\"specialQuestionSec__blockImg\"\n                src=\"../../../../recruit_assets/images/special/profile_man_fullwidth.png\" alt=\"#\"></figure>\n          </div>\n        </div>\n      </div>\n    </div>\n    <div class=\"specialTab\">\n      <ul class=\"specialTab__list\">\n        <li class=\"specialTab__listItem is-current\"><a class=\"specialTab__itemLink\" href=\"#\">\n            <div class=\"specialTab__cont\">\n              <div class=\"specialTab__itemTtlWrap\">\n                <div class=\"specialTab__ttlSub\">男性社員に聞いた</div>\n                <div class=\"specialTab__logo\">\n                  <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"185.029\" height=\"33.6\" viewBox=\"0 0 185.029 33.6\">\n                    <g id=\"logo_イイトコロ\" transform=\"translate(0.5 1.1)\">\n                      <path id=\"イイトコロ\"\n                        d=\"M7757.006,5086v-19.538h6.271v13.267h14.639v-14.74h-20.909v-6.271h27.179V5086Zm-64.8,0v-17.682H7713.4v6.271h-14.921V5086Zm-26.316,0v-12.242l5.361-3.067V5086Zm-33.515,0v-12.242l5.362-3.067V5086Zm108.022-.47h-18.043v-6.39H7740.4v-12.912h6.39v19.3Zm-85.743-13.015,26.577-15.2v6.262l-26.577,15.2Zm-33.513,0,26.576-15.2v6.262l-26.5