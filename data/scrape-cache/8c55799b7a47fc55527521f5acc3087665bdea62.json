\"\r\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\r\n<!-- End Google Tag Manager (noscript) -->\r\n<div id=\"header-area\">\r\n <header id=\"header\">\r\n  <p class=\"header-logo\"><a href=\"/careers/\"><img src=\"/careers/common/images/logo_header.webp\" alt=\"ダイナパック株式会社\" width=\"224\" height=\"34\"></a></p>\r\n  <div id=\"toggle-nav\" class=\"toggle-menu\"><span></span></div>\r\n  <div class=\"gnav-wrap\">\r\n   <nav class=\"gnav\">\r\n    <ul class=\"gnav-lv1\">\r\n     <li class=\"nav-home\"><a href=\"/careers/\">ホーム</a></li>\r\n     <li><a href=\"/careers/about/\"><span>ダイナパックを知る</span></a></li>\r\n     <li><a href=\"/careers/interview/\"><span>ダイナパックで働く人</span></a></li>\r\n     <li><a href=\"/careers/internship/\"><span>1day仕事体験</span></a></li>\r\n     <li><a href=\"/careers/description/\"><span>募集要項</span></a></li>\r\n     <li class=\"gnav-contact\"><a href=\"https://www.dynapac-gr.co.jp/contact/\" target=\"_blank\" class=\"icon-arrow\">資料請求・お問い合わせ</a></li>\r\n    </ul>\r\n    <div class=\"sub-nav\">\r\n     <ul>\r\n      <li class=\"pc-none\"><a href=\"/careers/highschool/\">高校生新卒採用</a></li>\r\n      <li><a href=\"/careers/recruit_policy/\">採用ポリシー</a></li>\r\n      <li><a href=\"https://www.dynapac-gr.co.jp/privacy/index.html\" target=\"_blank\">プライバシーポリシー<i class=\"ai-out\"></i></a></li>\r\n      <li><a href=\"https://www.dynapac-gr.co.jp/\" target=\"_blank\">ダイナパック企業サイト<i class=\"ai-out\"></i></a></li>\r\n      <li><a href=\"/careers/sitemap/\">サイトマップ</a></li>\r\n     </ul>\r\n    </div>\r\n   </nav>\r\n   <!--/#gnav-->\r\n  </div>\r\n </header>\r\n <!--/#header-area-->\r\n <div id=\"drawer\"></div>\r\n <!--/#drawer-->\r\n</div>\r\n\r\n<div id=\"home-logo-wrap\">\r\n  <div class=\"header-logo\"><a href=\"/careers/\"><img alt=\"ダイナパック株式会社\" width=\"224\" height=\"34\" src=\"/careers/common/images/logo_header_home.webp\"></a></div>\r\n</div>\r\n<div id=\"home-h1-area\">\r\n  <div class=\"home-h1-bg\">\r\n\t\t<figure><img class=\"sp-none\" src=\"images/main01_pc.webp\" alt=\"\"><img class=\"pc-none\" src=\"images/main01_sp.webp\" alt=\"\"></figure>\r\n\t\t<figure><img class=\"sp-none\" src=\"images/main02_pc.webp\" alt=\"\"><img class=\"pc-none\" src=\"images/main02_sp.webp\" alt=\"\"></figure>\r\n\t</div>\r\n  <h1>「包む」を深化し、<br>「包む」を拡げる<span>人の想いを大切に包み、<span class=\"inline-block\">届け、</span><br>人と人をつなぎ、<span class=\"inline-block\">心や未来をひらいていく。</span></span></h1>\r\n  <div class=\"home-highschool\">\r\n    <a href=\"highschool/\"><img class=\"sp-none\" src=\"images/bnr_highschool_pc.webp\" alt=\"高校生 新卒採用\" width=\"410\" height=\"220\"><img class=\"pc-none\" src=\"images/bnr_highschool_sp.webp\" alt=\"高校生 新卒採用\" width=\"270\" height=\"160\"></a>\r\n  </div>\r\n</div>\r\n<div class=\"home-banner\">\r\n  <div class=\"col\">\r\n    <a href=\"about/numbers/\">\r\n      <img class=\"sp-none\" src=\"images/bnr_numbers_pc.webp\" alt=\"\" width=\"842\" height=\"285\"><img class=\"pc-none\" src=\"images/bnr_numbers_sp.webp\" alt=\"\" width=\"340\" height=\"102\">\r\n      <div class=\"bnr-ttl\"><i class=\"circle-arrow\"></i>数字で見る<span>ダイナパック</span></div>\r\n    </a>\r\n  </div>\r\n  <div class=\"col\">\r\n    <a href=\"about/society/\">\r\n      <img class=\"sp-none\" src=\"images/bnr_society_pc.webp\" alt=\"\" width=\"842\" height=\"322\"><img class=\"pc-none\" src=\"images/bnr_society_sp.webp\" alt=\"\" width=\"340\" height=\"106\">\r\n      <div class=\"bnr-ttl\"><i class=\"circle-arrow\"></i>社会の中の<span>ダイナパック</span></div>\r\n    </a>\r\n  </div>\r\n</div>\r\n<div id=\"content-area\">\r\n  <div id=\"main-content\">\r\n    <div class=\"home-content-wrap\">\r\n      <section class=\"home-sec fadein\">\r\n        <div class=\"home-pattern\">\r\n          <div class=\"col\">\r\n           <h2 class=\"home-h2\">ダイナパックからのメッセージ<span class=\"en\">OUR MESSAGE</span></h2>\r\n          </div>\r\n           <div class=\"img-col\">\r\n           <p class=\"head\">ダイナパックの魅力が詰まった　たくさんの「箱」<br>\r\n            本サイトはページを「箱」に見立てて作っています。</p>\r\n            <p>働くイメージや職場環境などたくさんの情報を包み、<br class=\"sp-none\">キャリアに関する情報収集をされているすべての方へ届け、<br class=\"sp-none\">「箱」をひらくときに、ワクワクするような情報をお届けします。</p>\r\n          </div>\r\n        </div>\r\n      </section>\r\n    \r\n      <section class=\"home-sec fadein\">\r\n        <div class=\"home-pattern\">\r\n          <div class=\"img-col\">\r\n            <figure><img src=\"images/image_about.webp\" alt=\"\" width=\"720\" height=\"540\"></figure>\r\n          </div>\r\n          <div class=\"col\">\r\n           <h2 class=\"home-h2\">ダイナパックを知る<span class=\"en\">ABOUT US</span></h2>\r\n            <p>私たちはトータルパッケージング・ソリューション・プロバイダー<br class=\"sp-none\">として人・モノ・地球にやさしい製品およびサービスを<br class=\"sp-none\">提供しています。<br>\r\n           当社の事業や、取り組みを分かりやすくお伝えします。</p>\r\n            <div class=\"link-btn\">\r\n              <a href=\"about/\">READ MORE<i class=\"circle-arrow\"></i></a>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </section>\r\n    \r\n      <section class=\"home-sec home-interview fadein\">\r\n       <h2 class=\"home-h2 center-position\">ダイナパックで働く人<span class=\"en\">EMPLOYEE INTERVIEWS</span></h2>\r\n        <p class=\"center-position mb-0\">様々な部署のスタッフに、ダイナパックの仕事を語ってもらいました。</p>\r\n        <div class=\"interview-slide\">\r\n          <div class=\"slider\">\r\n  <!--この分岐はダイナパックのお仕事の下層ページ下部のリンクと共通です /careers/about/job/XXX/-->\r\n     <div class=\"col sales sales01\"> <a href=\"/careers/interview/01/\">\r\n        <figure><img src=\"/careers/interview/images/index_01.webp\" alt=\"\"></figure>\r\n       <div class=\"category\">営業<span>職</span></div>\r\n        <div class=\"head\">脱プラ案件の経験が<br class=\"sp-none\">大きな自信に。<i class=\"circle-arrow\"></i></div>\r\n       <p class=\"name\">A.H.さん（2021年入社）</p>\r\n       </a> </div>\r\n     <div class=\"col sales sales02\"> <a href=\"/careers/interview/02/\">\r\n      <figure><img src=\"/careers/interview/images/index_02.webp\" alt=\"\"></figure>\r\n      <div class=\"category\">営業<span>職</span></div>\r\n      <div class=\"head\">多彩な業界で、<br class=\"sp-none\">女性が輝ける環境。<i class=\"circle-arrow\"></i></div>\r\n      <p class=\"name\">M.Y.さん（2021年入社）</p>\r\n     </a></div>\r\n     <div class=\"col design design01\"> <a href=\"/careers/interview/03/\">\r\n      <figure><img src=\"/careers/interview/images/index_03.webp\" alt=\"\"></figure>\r\n      <div class=\"category\">設計デザイン<span>職</span></div>\r\n      <div class=\"head\">自分の名を冠した特許は<br class=\"sp-none\">設計者の誇り！<i class=\"circle-arrow\"></i></div>\r\n      <p class=\"name\">H.S.さん（2019年入社）</p>\r\n     </a></div>\r\n     <div class=\"col design design02\"> <a href=\"/careers/interview/04/\">\r\n      <figure><img src=\"/careers/interview/images/index_04.webp\" alt=\"\"></figure>\r\n      <div class=\"category\">設計デザイン<span>職</span></div>\r\n      <div class=\"head\">設計の仕事は達成感がスゴイ！<i class=\"circle-arrow\"></i></div>\r\n      <p class=\"name\">J.H.さん（2024年入社）</p>\r\n     </a></div>\r\n     <div class=\"col production-manage production-manage01\"> <a href=\"/careers/interview/05/\">\r\n      <figure><img src=\"/careers/interview/images/index_05.webp\" alt=\"\"></figure>\r\n      <div class=\"category\">生産管理<span>職</span></div>\r\n      <div class=\"head\">購買と生産計画で、<br class=\"sp-none\">効率と成果を追求。<i class=\"circle-arrow\"></i></div>\r\n      <p class=\"name\">T.N.さん（2016年入社）</p>\r\n     </a></div>\r\n     <div class=\"col production-manage production-manage02\"> <a href=\"/careers/interview/06/\">\r\n      <figure><img src=\"/careers/interview/images/index_06.webp\" alt=\"\"></figure>\r\n      <div class=\"category\">生産管理<span>職</span></div>\r\n      <div class=\"head\">ミスが許されない部門として<br class=\"sp-none\">自覚が重要<i class=\"circle-arrow\"></i></div>\r\n      <p class=\"name\">F.T.さん（2023年入社）</p>\r\n     </a></div>\r\n     <div class=\"col quality-manage quality-manage01\"> <a href=\"/careers/interview/07/\">\r\n      <figure><img src=\"/careers/interview/images/index_07.webp\" alt=\"\"></figure>\r\n      <div class=\"category\">品質管理<span>職</span></div>\r\n      <div class=\"head\">厳しい品質チェックで、<br class=\"sp-none\">確かな製品を。<i class=\"circle-arrow\"></i></div>\r\n      <p class=\"name\">S.N.さん（2015年入社）</p>\r\n     </a></div>\r\n      <div class=\"col quality-manage quality-manage02\"> <a href=\"/careers/interview/08/\">\r\n      <figure><img src=\"/careers/interview/images/index_08.webp\" alt=\"\"></figure>\r\n      <div class=\"category\">品質管理<span>職</span></div>\r\n      <div class=\"head\">学生時代の化学や物理が<br class=\"sp-none\">活きる仕事。<i class=\"circle-arrow\"></i></div>\r\n      <p class=\"name\">M.M.さん（2016年入社）</p>\r\n     </a></div>\r\n     <div class=\"col production1 production1-01\"> <a href=\"/careers/interview/09/\">\r\n      <figure><img src=\"/careers/interview/images/index_09.webp\" alt=\"\"></figure>\r\n      <div class=\"category\">生産<span>職【段ボールシート製造】</span></div>\r\n      <div class=\"head\">毎日8万メートルの<br class=\"sp-none\">シートを作る。<i class=\"circle-arrow\"></i></div>\r\n      <p class=\"name\">T.K.さん（2021年入社）</p>\r\n     </a></div>\r\n     <div class=\"col production1 production1-02\"> <a href=\"/careers/interview/10/\">\r\n       <figure><img src=\"/careers/interview/images/index_10.webp\" alt=\"\"></figure>\r\n       <div class=\"category\">生産<span>職【段ボールシート製造】</span></div>\r\n       <div class=\"head\">大量の段ボールを<br class=\"sp-none\">チームで製造。<i class=\"circle-arrow\"></i></div>\r\n       <p class=\"name\">S.T.さん（2023年入社）</p>\r\n      </a></div>\r\n      <div class=\"col production2 production2-01\"> <a href=\"/careers/interview/11/\">\r\n       <figure><img src=\"/careers/interview/images/index_11.webp\" alt=\"\"></figure>\r\n       <div class=\"category\">生産<span>職【段ボール箱製造】</span></div>\r\n       <div class=\"head\">当社の最終段階の工程。<br class=\"sp-none\">重要な役割。<i class=\"circle-arrow\"></i></div>\r\n       <p class=\"name\">M.G.さん（2019年入社）</p>\r\n      </a></div>\r\n       <div class=\"col production2 production2-02\"> <a href=\"/careers/interview/12/\">\r\n       <figure><img src=\"/careers/interview/images/index_12.webp\" alt=\"\"></figure>\r\n       <div class=\"category\">生産<span>職【段ボール箱製造】</span></div>\r\n       <div class=\"head\">機械の様子を気にしながら<br class=\"sp-none\">自分の役割も全うする。<i class=\"circle-arrow\"></i></div>\r\n       <p class=\"name\">R.K.さん（2019年入社）</p>\r\n      </a></div>\r\n          </div>\r\n        </div>\r\n      </section>\r\n    \r\n      <section class=\"home-sec mb-0 fadein\">\r\n        <div class=\"home-work\">\r\n          <div class=\"img-col\">\r\n            <figure><img src=\"images/image_work.webp\" alt=\"\" width=\"1050\" height=\"580\"></figure>\r\n          </div>\r\n          <div class=\"col\">\r\n           <h2 class=\"home-h2\">1day 仕事体験<span class=\"en\">WORK EXPERIENCE</span></h2>\r\n            <p>「パッケージメーカーは一体どんなことをしているのだろうか？」そんな疑問にお応えする1day仕事体験。<br>\r\n            プログラムは「提案営業」「設計デザイン」「生産管理」「生産技術」「品質管理」とパッケージメーカーの一連業務を擬似体験できるグループワークとなっています。</p>\r\n            <div class=\"link-btn\">\r\n              <a href=\"internship/\">READ MORE<i class=\"circle-arrow\"></i></a>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </section>\r\n    </div>\r\n\r\n    <div class=\"inner\">\r\n<section id=\"footer-entry-area\" class=\"bg-full\">\r\n <h2 class=\"h2-footer-entry\">エントリー<span class=\"en\">ENTRY</span></h2>\r\n <div class=\"footer-entry\">\r\n  <div class=\"wrap\">\r\n   <div class=\"col\">\r\n    <h3>新卒者</h3>\r\n    <p>新卒採用に応募される方は、こちらをご覧ください。</p>\r\n    <div class=\"entry-btn-area\">\r\n     <div class=\"link-btn\"> <a href=\"/careers/description/new/\">募集要項<i class=\"circle-arrow\"></i></a> </div>\r\n     <div class=\"link-btn mynavi\"><a href=\"https://job.mynavi.jp/27/pc/search/corp276378/outline.html\" target=\"_blank\"><img src=\"/careers/common/images/logo_mynavi.svg\" alt=\"マイナビ\" class=\"img-mynavi\"><i class=\"arrow-out\"></i></a></div>\r\n    </div>\r\n   </div>\r\n   <div class=\"col\">\r\n    <h3>経験者</h3>\r\n    <p>経験者採用・中途採用をご希望の方は、こちらをご覧ください。</p>\r\n    <div class=\"entry-btn-area\">\r\n     <div class=\"link-btn\"> <a href=\"/careers/description/career/\">募集要項<i class=\"circle-arrow\"></i></a></div>\r\n     <div class=\"link-btn\"><a href=\"https://www.dynapac-gr.co.jp/recruit/entry/\" target=\"_blank\">エントリー<i class=\"circle-arrow\"></i></a></div>\r\n    </div>\r\n   </div>\r\n  </div>\r\n  <div class=\"recruit-contact\">\r\n   <h3>採用に関するお問い合わせ</h3>\r\n   <p>疑問点・不明点の確認や質問など、採用に関することでしたらこちらからお問い合わせください。</p>\r\n   <div class=\"link-btn\"> <a href=\"https://www.dynapac-gr.co.jp/contact/\" target=\"_blank\">お問い合わせはこちら<i class=\"circle-arrow\"></i></a> </div>\r\n  </div>\r\n </div>\r\n<div id=\"footer-bnr-area\">\r\n <ul id=\"footer-bnr\">\r\n  <li><a href=\"https://www.dynapac-gr.co.jp/video/\" target=\"_blank\"><img src=\"/careers/common/images/footer_bnr_video.webp\" alt=\"ダイナパックが3分でわかる　ダイナパック早わかり\"></a></li>\r\n  <li><a href=\"https://www.dynapac-gr.co.jp/results/\" target=\"_blank\"><img src=\"/careers/common/images/footer_bnr_results.webp\" alt=\"ダイナパック実績紹介\"></a></li>\r\n  <li><a href=\"https://www.dynapac-gr.co.jp/winning/\" target=\"_blank\"><img src=\"/careers/common/images/footer_bnr_awards.webp\" alt=\"ダイナパック受賞実績\"></a></li>\r\n </ul>\r\n</div>\r\n\r\n</section>\r\n\r\n    </div>\r\n  </div>\r\n  <!--/#main-content-->\r\n</div>\r\n<div id=\"to-top\"><a href=\"#header-area\"></a></div>\r\n<div id=\"footer-area\">\r\n  <footer id=\"footer\">\r\n   <div class=\"fnav-wrap\">\r\n      <div class=\"left-col\">\r\n        <p class=\"footer-logo\"><a href=\"/careers/\"><img src=\"/careers/common/images/logo_footer.webp\" alt=\"ダイナパック株式会社\" width=\"222\" height=\"34\"></a><span>採用事務局</span></p>\r\n        <div class=\"footer-adress\">\r\n          <adress>〒460-0003<br>\r\n           愛知県名古屋市中区錦三丁目14番15号　<br>\r\n           カゴメビル7階・8階（受付）<br>\r\n          電話番号：<span class=\"tel-link\">052-971-2651</span>（代表）</adress>\r\n        </div>\r\n        <div class=\"sub-nav\">\r\n     <ul>\r\n      <li><a href=\"/careers/