://www.abbey2007.com/wp/wp-content/themes/2019abbey/images/logo-salon-abbey5.svg\" alt=\"ABBEY 5\"></a></div>\n              <div class=\"reservation-btn\"><a href=\"https://49fe5f.b-merit.jp/w4md37/web/login\" target=\"_blank\"><img src=\"https://www.abbey2007.com/wp/wp-content/themes/2019abbey/images/logo-salon-abbey-kamakura.svg\" alt=\"ABBEY 鎌倉\"></a></div>\n            </div>\n            <p class=\"close\"><a href=\"/\" class=\"reservation-modal-close\"><img src=\"https://www.abbey2007.com/wp/wp-content/themes/2019abbey/images/icon-close.svg\" alt=\"×\"></a></p>\n          </div>\n        </div>\n      </div>\n    </header>  <main id=\"content\">\n  \t<h3 class=\"zigzag\">RECRUIT<span>新入社員募集要項</span></h3>\n  \t<div class=\"recruit-wrap\">\n\t  \t<p class=\"free\"></p>\n\t  \t<h4>■ 令和6年度　中途アシスタント・フロント募集要項</h4>\n\t  \t<dl>\n\t  \t\t\t\t\t\t<dt>募集職種</dt>\n\t\t\t\t<dd>アシスタント</dd>\n\t\t\t\t\t\t\t\t<dt>募集形態</dt>\n\t\t\t\t<dd>正社員</dd>\n\t\t\t\t\t\t\t\t<dt>募集期日</dt>\n\t\t\t\t<dd>随時</dd>\n\t\t\t\t\t\t\t\t<dt>提出書類</dt>\n\t\t\t\t<dd>履歴書／健康診断書／全身写真／instagramアカウント<br />\r\n</dd>\n\t\t\t\t\t\t\t\t<dt>応募方法</dt>\n\t\t\t\t<dd>下記住所に郵送いただくか直接お持ちください。<br />\r\n<br />\r\n〒107-0062<br />\r\n東京都港区南青山5-7-23始弘ビル2F<br />\r\n人事担当 矢賀部 宛て</dd>\n\t\t\t\t\t\t\t\t<dt>入社試験予定日</dt>\n\t\t\t\t<dd>履歴書が届き次第、ご連絡させていただきます。<br />\r\n</dd>\n\t\t\t\t\t\t\t\t<dt> 選考方法</dt>\n\t\t\t\t<dd>１次審査：<br />\r\n書類選考<br />\r\n<br />\r\n2次審査：<br />\r\n面接、技術（ワインディング）、その他</dd>\n\t\t\t\t\t\t\t\t<dt>問い合わせ先</dt>\n\t\t\t\t<dd>03-5774-5774</dd>\n\t\t\t\t\t\t\t\t<dt>サロン見学</dt>\n\t\t\t\t<dd>平日のみ受け付けています。</dd>\n\t\t\t\t\t\t\t\t<dt>・・・・・・・・・・・・・・・・・・・・</dt>\n\t\t\t\t<dd>・・・・・・・・・・・・・・・・・・・・・・・</dd>\n\t\t\t\t\t\t\t\t<dt>募集職種</dt>\n\t\t\t\t<dd>フロント</dd>\n\t\t\t\t\t\t\t\t<dt>募集形態</dt>\n\t\t\t\t<dd>正社員</dd>\n\t\t\t\t\t\t\t\t<dt>募集期日</dt>\n\t\t\t\t<dd>随時</dd>\n\t\t\t\t\t\t\t\t<dt>提出書類</dt>\n\t\t\t\t<dd>履歴書</dd>\n\t\t\t\t\t\t\t\t<dt>応募方法</dt>\n\t\t\t\t<dd>下記住所に郵送いただくか直接お持ちください<br />\r\n<br />\r\n〒107-0062<br />\r\n東京都港区南青山4-21-26RUELLE青山A-3F<br />\r\nABBEY2 扇 宛て</dd>\n\t\t\t\t\t\t\t\t<dt>選考方法</dt>\n\t\t\t\t<dd>・面接<br />\r\n<br />\r\n履歴書が届き次第日程のご連絡をさせていただきます</dd>\n\t\t\t\t\t\t\t\t<dt>お問い合わせ先</dt>\n\t\t\t\t<dd>03-3405-6655（ABBEY2）<br />\r\n<br />\r\nフロントの場合、サロン見学も随時受け付けております。</dd>\n\t\t\t\t\t  \t</dl>\n\t  \t<p class=\"free bottom\"></p>\n\t  </div>\n  </main>\n    <footer>\n      <div class=\"inner\">\n        <section id=\"schedule\">\n          <h3>SCHEDULE</h3>\n          <div class=\"calender-wrap\"><aside id=\"bizcalendar-4\" class=\"widget widget_bizcalendar\"><h3 class=\"widget-title\">New title</h3><div id='biz_calendar'></div></aside></div>\n        </section>\n        <section id=\"open\">\n          <h3>OPENING HOURS</h3>\n          <p>平日 11:00〜20:00<br>土、日、祝日 10:00〜18:00<br>\n            定休日 毎週月曜、火曜日<br>\n          第3水曜日</p>\n        </section>\n        <!--<section id=\"staff-schedule\">\n          <h3>STAFF SCHEDULE</h3>\n          <p>スタイリストの出勤スケジュールをご確認いただけます。</p>\n          <p class=\"link\"><a href=\"https://www.abbey2007.com/schedule\">今月のスタッフスケジュール</a></p>\n        </section>-->\n        <nav class=\"footer_nav\">\n          <ul>\n            <li><a href=\"https://www.abbey2007.com/company\">COMPANY</a></li>\n            <li>\n              <script type=\"text/javascript\">\n                <!--\n                function converter(M){\n                var str=\"\", str_as=\"\";\n                for(var i=0;i<M.length;i++){\n                str_as = M.charCodeAt(i);\n                str += String.fromCharCode(str_as + 1);\n                }\n                return str;\n                }\n                function mail_to(k_1,k_2)\n                {eval(String.fromCharCode(108,111,99,97,116,105,111,110,46,104,114,101,102,32,\n                61,32,39,109,97,105,108,116,111,58) \n                + escape(k_1) + \n                converter(String.fromCharCode(104,109,101,110,63,96,97,97,100,120,49,47,47,54,45,98,110,108,\n                62,114,116,97,105,100,98,115,60)) \n      