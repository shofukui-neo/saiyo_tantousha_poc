his.src='/wp-content/uploads/business_bnr.png'\" alt=\"BUSINESS\"></a></li>\r\n\r\n<li><a href=\"/product\"><img src=\"/wp-content/uploads/product_bnr.png\" onmouseover=\"this.src='/wp-content/uploads/product_on.png'\" onmouseout=\"this.src='/wp-content/uploads/product_bnr.png'\" alt=\"PRODUCT\"></a></li>\r\n\r\n<li><a href=\"/real-estate\"><img src=\"/wp-content/uploads/real-estate_bnr.png\" onmouseover=\"this.src='/wp-content/uploads/real-estate_on.png'\" onmouseout=\"this.src='/wp-content/uploads/real-estate_bnr.png'\" alt=\"REAL ESTATE\"></a></li>\r\n\r\n<li><a href=\"/csr/\"><img src=\"/wp-content/uploads/csr_bnr.png\" onmouseover=\"this.src='/wp-content/uploads/csr_on.png'\" onmouseout=\"this.src='/wp-content/uploads/csr_bnr.png'\" alt=\"CSR\"></a></li>\r\n\r\n<li><a href=\"/recruit/\"><img src=\"/wp-content/uploads/recruit_bnr.png\" onmouseover=\"this.src='/wp-content/uploads/recruit_on.png'\" onmouseout=\"this.src='/wp-content/uploads/recruit_bnr.png'\" alt=\"RECRUIT\"></a></li>\r\n\r\n</ul>\r\n</div>\r\n</div>\r\n<div>\r\n\r\n<div class=\"contents_img\"><img class=\"aligncenter wp-image-1488 size-full\" src=\"https://www.kondobo.co.jp/wp-content/uploads/cow_top_001.png\" alt=\"\" width=\"1280\" height=\"240\" srcset=\"https://www.kondobo.co.jp/wp-content/uploads/cow_top_001.png 1280w, https://www.kondobo.co.jp/wp-content/uploads/cow_top_001-300x56.png 300w, https://www.kondobo.co.jp/wp-content/uploads/cow_top_001-768x144.png 768w, https://www.kondobo.co.jp/wp-content/uploads/cow_top_001-1024x192.png 1024w\" sizes=\"(max-width: 1280px) 100vw, 1280px\" /></div>\n<div class=\"contents_copy\"></div>\n<div class=\"contents\">\n<div class=\"contents_main\">\n<div class=\"contents_list\">\n<h1 class=\"bk\">2026年 新卒者募集要項</h1>\n<p>&nbsp;</p>\n<table style=\"width: 500px;\">\n<tbody>\n<tr>\n<th style=\"width: 62.7px;\"><span style=\"font-family: arial,helvetica,sans-serif; font-size: 12px;\">職　 　種</span></th>\n<td style=\"width: 435.3px;\"><span style=\"font-size: 12px;\">●<span style=\"font-family: arial,helvetica,sans-serif;\">総合職（繊維部門）</span></span><br />\n<span style=\"font-size: 12px;\"> 　<span style=\"font-family: arial, helvetica, sans-serif;\">機械メンテナンス</span><span style=\"font-family: arial,helvetica,sans-serif;\">、生産管理、素材開発、技術営業　等<br />\n●総合職（不動産部門）<br />\n管理、営業、企画開発　等</span></span><br />\n<span style=\"font-size: 12px;\">●<span style=\"font-family: arial,helvetica,sans-serif;\">総合職（事務部門）</span></span><br />\n<span style=\"font-size: 12px;\"> 　<span style=\"font-family: arial,helvetica,sans-serif;\">財務経理、人事労務、人財育成　等</span></span></td>\n</tr>\n<tr>\n<th style=\"width: 62.7px;\"><span style=\"font-family: arial,helvetica,sans-serif; font-size: 12px;\">初  任  給</span></th>\n<td style=\"width: 435.3px;\"><span style=\"font-size: 12px;\">●<span style=\"font-family: arial,helvetica,sans-serif;\">大学卒（総合職）：252,400円</span></span><br />\n<span style=\"font-size: 12px;\"> ●<span style=\"font-family: arial,helvetica,sans-serif;\">修士了（総合職）：280,400円</span></span></td>\n</tr>\n<tr>\n<th style=\"width: 62.7px;\"><span style=\"font-family: arial,helvetica,sans-serif; font-size: 12px;\">諸  手  当</span></th>\n<td style=\"width: 435.3px;\"><span style=\"font-family: arial,helvetica,sans-serif; font-size: 12px;\">子供手当、住宅手当、通勤手当、単身赴任手当　等</span></td>\n</tr>\n<tr>\n<th style=\"width: 62.7px;\"><span style=\"font-family: arial,helvetica,sans-serif; font-size: 12px;\">昇　 　給</span></th>\n<td style=\"width: 435.3px;\"><span style=\"font-family: arial,helvetica,sans-serif; font-size: 12px;\">年1回（4月）</span></td>\n</tr>\n<tr>\n<th style=\"width: 62.7px;\"><span style=\"font-family: arial,helvetica,sans-serif; font-size: 12px;\">賞　 　与</span></th>\n<td style=\"width: 435.3px;\"><span style=\"font-family: arial,helvetica,sans-serif; font-size: 12px;\">年2回（6月・12月）</span></td>\n</tr>\n<tr>\n<th style=\"width: 62.7px;\"><span style=\"font-family: arial,helvetica,sans-serif; font-size: 12px;\">勤  務  地</span></th>\n<td style=\"width: 435.3px;\"><span style=\"font-size: 12px;\">●<span style=\"font-family: arial,helvetica,sans-serif;\">本社（名古屋）</span></span><br />\n<span style=\"font-size: 12px;\"> ●<span style=\"font-family: arial,helvetica,sans-serif;\">工場（長野県大町市、徳島県板野郡）</span></span><br />\n<span style=\"font-size: 12px;\"> ●<span style=\"font-family: arial,helvetica,sans-serif;\">支店・営業所（東京、大阪）</span></span><br />\n<span style=\"font-size: 12px;\"> ●<span style=\"font-family: arial,helvetica,sans-serif;\">海外（中国、インドネシア、ベトナム）</span></span></td>\n</tr>\n<tr>\n<th style=\"width: 62.7px;\"><span style=\"font-size: 12px;\">勤務時間</span></th>\n<td style=\"width: 435.3px;\"><span style=\"font-size: 12px;\">●<span style=\"font-family: arial,helvetica,sans-serif;\">本社　8：30~17：30</span></span><br />\n<span style=\"font-size: 12px;\"> ●<span style=\"font-family: arial,helvetica,sans-serif;\">工場　8：20~16：55</span></span><br />\n<span style=\"font-size: 12px;\"> ●<span style=\"font-family: arial,helvetica,sans-serif;\">支店・営業所（事業所によって異なる）</span></span></td>\n</tr>\n<tr>\n<th style=\"width: 62.7px;\"><span style=\"font-size: 12px;\">休日休暇</span></th>\n<td style=\"width: 435.3px;\"><span style=\"font-size: 12px;\">●<span style=\"font-family: arial,helvetica,sans-serif;\">本社　123日</span></span><br />\n<span style=\"font-family: arial,helvetica,sans-serif; font-size: 12px;\"> （土日祝日、夏季休暇、年末年始休暇）</span><br />\n<span style=\"font-size: 12px;\"> ●<span style=\"font-family: arial,helvetica,sans-serif;\">工場　115日</span></span><br />\n<span style=\"font-family: arial,helvetica,sans-serif; font-size: 12px;\"> （工場設定の休日による）</span><br />\n<span style=\"font-size: 12px;\"> ●<span style=\"font-family: arial,helvetica,sans-serif;\">支店・営業所</span></span><br />\n<span style=\"font-family: arial,helvetica,sans-serif; font-size: 12px;\"> （事業所によって異なる）</span><br />\n<span style=\"font-family: arial,helvetica,sans-serif; font-size: 12px;\"> 年次有給休暇、慶弔休暇、育児休暇、介護休暇　等</span></td>\n</tr>\n<tr>\n<th style=\"width: 62.7px;\"><span style=\"font-family: arial,helvetica,sans-