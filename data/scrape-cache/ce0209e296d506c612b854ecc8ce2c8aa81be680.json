nstanceBeginEditable name=\"css\" -->\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/contact.css\" media=\"all\">\n<!-- InstanceEndEditable -->\n\n\n<script type=\"text/javascript\" src=\"../common/jvs/2013/analytics.js\"></script>\n<script type=\"text/javascript\" src=\"../common/jvs/2011b/mjl.js\"></script>\n<script type=\"text/javascript\" src=\"../jvs/jquery-3.6.0.min.js\"></script>\n<script type=\"text/javascript\" src=\"../common/jvs/2013/linkoff.js\"></script>\n<script type=\"text/javascript\" src=\"../common/jvs/2013/run.js\"></script>\n<!-- InstanceBeginEditable name=\"script\" -->\n<!-- InstanceEndEditable -->\n<!-- InstanceBeginEditable name=\"scriptforIE\" --><!--[if lt IE 9]> \n<script src=\"../jvs/html5shiv.js\"></script>\n<![endif]--><!-- InstanceEndEditable -->\n<!-- InstanceParam name=\"withLmenu\" type=\"boolean\" value=\"false\" -->\n<!-- InstanceParam name=\"pageTop\" type=\"boolean\" value=\"true\" -->\n<!-- InstanceParam name=\"rd\" type=\"boolean\" value=\"false\" -->\n<!-- InstanceParam name=\"keyword\" type=\"text\" value=\"東芝電材マーケティング,電材,電設資材,照明器具,LED,蓄電池,太陽光発電,お問い合わせ\" -->\n<!-- InstanceParam name=\"description\" type=\"text\" value=\"東芝電材マーケティング株式会社のお問い合わせのページです。東芝電材マーケティングは、太陽光発電からLED照明、高圧受変電設備などの電気設備をはじめ、住宅設備や通信情報設備などを幅広く販売する総合電設資材商社です。\" -->\n<!-- InstanceParam name=\"gnavCategory\" type=\"number\" value=\"0\" -->\n<!-- InstanceParam name=\"snavCategory\" type=\"number\" value=\"1\" -->\n<!-- InstanceParam name=\"subCategory\" type=\"number\" value=\"1\" -->\n<!-- InstanceParam name=\"footerNavi\" type=\"boolean\" value=\"true\" -->\n<!-- InstanceParam name=\"topKv\" type=\"boolean\" value=\"false\" -->\n</head>\n<body>\n<!-- Google Tag Manager (noscript) -->\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-WTJD8K3\"\nheight=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe></noscript>\n<!-- End Google Tag Manager (noscript) -->\n<header id=\"gHeader\">\n\t<section id=\"tos_line\" class=\"header__inner\">\n  \t<div id=\"logo\" class=\"headerLeft\">\n\t\t<p><a href=\"https://www.global.toshiba/jp/top.html\" title=\"東芝トップページ\"><img src=\"../common/img/head/logo_l.gif\" alt=\"Toshiba\" width=\"161\" height=\"64\" id=\"totop\"></a></p><a href=\"#mainContents\" class=\"jumpContents\">本文へジャンプ</a>\n\t\t\n\t\t<p id=\"identifier\"><a href=\"../index_j.htm\"><img src=\"../common/img/head/identifier.png\" alt=\"東芝電材マーケティング株式会社\" width=\"218\" height=\"16\"></a></p>\n\t\t\n\t\t<p id=\"switch_menu\"><a href=\"#\"><img src=\"../images/common/icon-spmenu.png\" alt=\"ナビ\" /></a></p>\n\t</div>\n    <div id=\"gHeaderRightBlock\" class=\"headerRight\">\n            <div class=\"mf_finder_container\">\n                <mf-search-box lang=\"ja\" submit-text=\"\" ajax-url=\"https://mf2aps07.marsflag.com/corp__jpja__jpja/x_search.x\" serp-url=\"https://www.global.toshiba/jp/search/search-results.html\" placeholder=\"検索\" doctype-csv=\"html,pdf\" category-csv=\"corp__jpja__jpja\" doctype-hidden\n                category-hidden options-hidden input-title=\"検索\" imgsize-default=\"2\"></mf-search-box>\n            </div>\n    \n            <ul class=\"headerNav_pc\">\n                <li class=\"sitemap\"><a href=\"../sitemap.htm\">サイトマップ</a></li>\n                <li class=\"contact\"><a href=\"index_j.htm\">お問い合わせ</a></li>\n            </ul>\n        </div>\n    </section>\n\t<nav id=\"mainNav\">\n\t\t<ul id=\"globalNav\">\n\t\t\t<li id=\"g_home\"><a href=\"../index_j.htm\">トップページ</a></li>\n\t\t\t<li id=\"g_guide\"><a href=\"../guide/index_j.htm\">事業内容</a></li>\n            <li id=\"g_products\"><a href=\"../products/index_j.htm\">取扱商品</a></li>\n            <li id=\"g_company\"><a href=\"../company/index_j.htm\">企業情報</a></li>\n            <li id=\"g_office\"><a href=\"../company/office.htm\">事業所</a></li>\n            <li id=\"g_closeup\"><a href=\"../customer/index_j.htm\">得意先向け情報</a></li>\n\t    </ul>\n\n        <ul id=\"headerSubNav\" class=\"doAct sp_only\">\n            <li class=\"sitemap\"><a href=\"../sitemap.htm\">サイトマップ</a></li>\n            <li class=\"contact\"><a href=\"index_j.htm\">お問い合わせ</a></li>\n            <li class=\"closemenu\"><a href=\"#\">閉じる</a></li>\n        </ul>\n\t</nav>\n</header>\n\n<section id=\"mainContents\">\n\n<div class=\"container clear\">\n\t<div id=\"stepNav\"><span id=\"stephome\"><a href=\"../index_j.htm\">東芝電材マーケティングトップページ</a></span> &gt; <!-- InstanceBeginEditable name=\"stepNav\" -->お問い合わせ<!-- InstanceEndEditable --></div>\n</div>\n<div class=\"container clear\"><!-- InstanceBeginEditable name=\"titleImage-noside\" -->\n  <h1 class=\"tit_lv1\">お問い合わせ</h1>\n<!-- InstanceEndEditable --><!-- InstanceBeginEditable name=\"no-side-contents\" -->\n    <p class=\"indent-lv1\">お問い合わせ窓口のご案内です。以下の項目にご同意のうえ、お問い合わせください。</p>\n    \n    <div id=\"contact\">\n    <div class=\"noticeBox pb30\">\n    <p class=\"title\">お問い合わせいただく前の注意</p>\n    <div class=\"honbun\">\n      <ol>\n        <li>お客様からいただく個人情報は、お問い合わせへの回答のために使用させていただきます。<br />\n        利用目的の範囲内で、お客様の個人情報を東芝グループ会社等より対応させていただくことが適切と判断される場合に、お客様の住所・お名前・電話番号等を提供することがあります。<br />\n        この場合、お客様はお問い合わせ窓口に対し個人情報提供の停止を請求することができます。<br />\n        </li>\n        <li>お客様は、お客様ご本人の個人情報について、開示・訂正・削除をご請求いただけます。<br />\n          その際は、このページのお問い合わせ先までご連絡ください。<br />\n        </li>\n        <li>お問い合わせ窓口の個人情報の取扱全般に関する考え方をご覧になりたい方は、各々のお問い合わせ先の会社の個人情報保護方針をご覧ください。</li>\n        <li>１６歳未満のお客様は、保護者の同意を得たうえでお問い合わせください。</li>\n        <li>土曜日・日曜日・祝日・年末年始等、会社休業日にいただくお問い合わせについては、翌営業日以降の回答となります。</li>\n        <li>お客様のお申し出を聞き漏らすことがないように、通話内容を録音させていただくことがあります。</li>\n      </ol><br />\n    </div>\n  </div>\n  </div>\n    \n    <h2 class=\"tit_lv2\">営業拠点（営業所所在地）のご案内</h2>\n\t<p class=\"indent-lv2\">東芝電材マーケティング株式会社の営業拠点（営業所所在地）をご紹介しています。各拠点の詳細は事業所ページにてご確認ください。</p>\n    <p class=\"tc pb20\"><span class=\"normalbtn\"><a href=\"../company/office.htm\">事業所ページはこちらから</a></span></p>\n    \n    <h2 class=\"tit_lv2\">主要取扱メーカーのご案内</h2>\n\t<p class=\"indent-lv2\">東芝電材マーケティング株式会社で取り扱う商品のメーカー一覧をご案内しています。詳細は東芝グループ一覧、または、取扱メーカー一覧ページよりご確認ください。</p>\n    \n    <p class=\"tc pb15\"><span class=\"normalbtn\"><a href=\"../products/toshiba/group.htm\">東芝グループ一覧ページはこちらから</a></span></p>\n    <p class=\"tc pb20\"><span class=\"normalbtn\"><a href=\"../products/electoric/manufacturer.htm\">取扱メーカー一覧ページはこちらから</a></span></p>\n    \n     <h2 class=\"tit_lv2\">よくあるご質問Q＆Aのご案内</h2>\n\t<p class=\"indent-lv2\">お客様からいただくよくある質問と回答をご案内しています。詳細はQ＆Aページにてご確認ください。</p>\n    <p class=\"tc pb20\"><span class=\"normalbtn\"><a href=\"../q_and_a.htm\">Q＆Aページはこちらから</a></span></p>\n    \n     <h2 class=\"tit_lv2\">お問い合わせフォームのご案内</h2>\n\t<p class=\"indent-lv2\">入力フォームからの送信も受付いたしております。下記お問い合わせフォームのページよりお願いいたします。</p>\n    <p class=\"tc pb10\"><span class=\"normalbtn\"><a href=\"../webapp/ssl/contact/index_j.htm\">お問い合わせフォームのページはこちらから</a></span></p>\n    \n    <h3 class=\"tit_lv3\">その他電話でのお問い合わせ</h3>\n    <p class=\"indent-lv3 pb20\">TEL：044-578-8213（代表）<br>\n※受付時間　平日8：45～17：30　土・日曜日、祝日および当社休業日は除きます。</p>\n\n\n\t<h2 class=\"tit_lv2\" id=\"dealings\">お取引希望のお客様</h2>\n\t<p class=\"indent-lv2\">入力フォームから受付いたしております。お取引を希望されるお客様は、下記お問い合わせフォームのページよりお願いいたします。</p>\n    <p class=\"tc pb10\"><span class=\"normalbtn\"><a href=\"../dealings/index_j.htm\">お取引希望のお客様はこちらから</a></span></p>\n    \n    \n    <h2 class=\"tit_lv2\">その他サポート情報のご案内</h2>\n\t<p class=\"indent-lv2 pb20\">※以下のサイトにある個人情報保護方針と弊社の個人情報保護方針は異なります。 </p>\n    \n    <p class=\"indent-lv2 tit_lv5_2\">東芝ライテック株式会社の製品お問い合わせ先は以下となります。（旧 東芝電材（株）製品）</p>\n\n\t<p class=\"tc pb25\"><span class=\"normalbtn\"><a href=\"https://www.tlt.co.jp/tlt/contact/contact.htm\" target=\"_blank\">東芝ライテック製品のお問い合わせ先はこちらから<img src=\"../images/common/icon_newwin.gif\" width=\"17\" height=\"13\" alt=\"別ウィンドウで開きます\" class=\"icon_external\" /></a></span></p>\n    \n    <p class=\"indent-lv2 tit_lv5_2\">東芝ライテック株式会社のアスベスト（石綿）に関する状況は以下よりご確認ください。（旧 東芝電材（株）製品）</p>\n\n\t<p class=\"tc pb25\"><span class=\"normalbtn\"><a href=\"https://www.tlt.co.jp/tlt/contact/asbestos/asbestos.htm\" target=\"_blank\">アスベスト（石綿）に関する状況はこちらから<img src=\"../images/common/icon_newwin.gif\" width=\"17\" height=\"13\" alt=\"別ウィンドウで開きます\" class=\"icon_external\" /></a></span></p>\n    \n    <p class=\"indent-lv2 tit_lv5_2\">東芝ライテック株式会社のPCB使用器具の取り扱いについては、以下よりご確認ください。（旧 東芝電材（株）製品）</p>\n\n\t<p class=\"tc pb25\"><span class=\"normalbtn\"><a href=\"https://www.tlt.co.jp/tlt/contact/pcb/pcb.htm\" target=\"_blank\">PCB使用器具の取り扱いについてはこちらから<img src=\"../images/common/icon_newwin.gif\" width=\"17\" height=\"13\" alt=\"別ウィンドウで開きます\" class=\"icon_external\" /></a></span></p>\n    \n    <p class=\"indent-lv2 tit_lv5_2\">東芝ライテック株式会社の照明Q＆Aは以下となります。</p>\n\n\t<p class=\"tc pb25\"><span class=\"normalbtn\"><a href=\"https://www.tlt.co.jp/tlt/support/faq/faq.htm\" target=\"_blank\">照明Q＆Aはこちらから<img src=\"../images/common/icon_newwin.gif\" width=\"17\" height=\"13\" alt=\"別ウィンドウで開きます\" class=\"icon_external\" /></a></span></p>\n    \n    <p class=\"indent-lv2 tit_lv5_2\">東芝製品の消費生活用品安全法の基づく事故報告に関しては、以下よりご確認ください。</p>\n\n\t<p class=\"tc pb25\"><span class=\"normalbtn\"><a href=\"https://www.global.toshiba/jp/info/corporate/safety.html\" target=\"_blank\">消費生活用製品安全法に基づく事故報告はこちらから<img src=\"../images/common/icon_newwin.gif\" width=\"17\" height=\"13\" alt=\"別ウィンドウで開きます\" class=\"icon_external\" /></a></span></p>\n    \n    \n    <p class=\"note_newwin\"><img src=\"../images/common/icon_newwin.gif\" alt=\"別ウィンドウが開きます\" width=\"17\" height=\"13\" class=\"icon_external\" />…このマークのついているリンクは別ウインドウで開きます。</p>\n\n<!-- InstanceEndEditable --></div>\n\n\n\n\n<p class=\"pagetop\"><a href=\"#topagetop\"><img src=\"../images/common/btn_topagetop.png\" width=\"44\" height=\"38\" alt=\"to PageTop\"/></a></p>\n\n\n\n</section>\n\n\n\n\n\n<div id=\"footerNav\">\n  <div id=\"footerNavInner\" class=\"clearfix\">\n    <div class=\"fnBox\">\n      <ul class=\"doAct\">\n        <li><a href=\"../index_j.htm\" class=\"cat1\">トップページ</a></li>\n        <li><a href=\"../guide/index_j.htm\" class=\"cat1\">事業内容</a></li>\n        