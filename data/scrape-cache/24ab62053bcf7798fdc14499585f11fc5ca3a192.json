mg.wp-smiley,img.emoji{display:inline !important;border:none !important;box-shadow:none !important;height:1em !important;width:1em !important;margin:0 .07em !important;vertical-align:-.1em !important;background:0 0 !important;padding:0 !important}</style><link rel='stylesheet' id='wp-block-library-css'  href='https://www.kakuhan.com/wordpress/wp-includes/css/dist/block-library/style.min.css?ver=5.6.17' type='text/css' media='all' /><link rel=\"https://api.w.org/\" href=\"https://www.kakuhan.com/wp-json/\" /><link rel=\"alternate\" type=\"application/json\" href=\"https://www.kakuhan.com/wp-json/wp/v2/interview/139\" /><link rel=\"EditURI\" type=\"application/rsd+xml\" title=\"RSD\" href=\"https://www.kakuhan.com/wordpress/xmlrpc.php?rsd\" /><link rel=\"wlwmanifest\" type=\"application/wlwmanifest+xml\" href=\"https://www.kakuhan.com/wordpress/wp-includes/wlwmanifest.xml\" /><meta name=\"generator\" content=\"WordPress 5.6.17\" /><link rel='shortlink' href='https://www.kakuhan.com/?p=139' /><link rel=\"alternate\" type=\"application/json+oembed\" href=\"https://www.kakuhan.com/wp-json/oembed/1.0/embed?url=https%3A%2F%2Fwww.kakuhan.com%2Frecruit%2Finterview%2Ftaguchi-2%2F\" /><link rel=\"alternate\" type=\"text/xml+oembed\" href=\"https://www.kakuhan.com/wp-json/oembed/1.0/embed?url=https%3A%2F%2Fwww.kakuhan.com%2Frecruit%2Finterview%2Ftaguchi-2%2F&#038;format=xml\" /><link rel=\"icon\" href=\"https://www.kakuhan.com/wordpress/wp-content/uploads/2020/09/favicon.png\" sizes=\"32x32\" /><link rel=\"icon\" href=\"https://www.kakuhan.com/wordpress/wp-content/uploads/2020/09/favicon.png\" sizes=\"192x192\" /><link rel=\"apple-touch-icon\" href=\"https://www.kakuhan.com/wordpress/wp-content/uploads/2020/09/favicon.png\" /><meta name=\"msapplication-TileImage\" content=\"https://www.kakuhan.com/wordpress/wp-content/uploads/2020/09/favicon.png\" /></head><body class=\"page--interview\"><header class=\"global-header\"><div class=\"uk-container uk-container-expand\"><nav class=\"uk-navbar-container uk-navbar-transparent\" uk-navbar><div class=\"uk-flex uk-width-expand uk-hidden@l\"><div class=\"uk-navbar-center\"><a class=\"uk-logo\" href=\"https://www.kakuhan.com\"><img src=\"https://www.kakuhan.com/wordpress/wp-content/themes/kakuhan/images/common/logo.png\" alt=\"株式会社角繁のロゴ\"></a></div><div class=\"uk-navbar-right\"><a class=\"offcanvas-btn\" id=\"offcanvas-btn\" href=\"#offcanvas\" uk-toggle><span></span><span></span><span></span></a></div></div><div class=\"uk-flex uk-width-expand uk-visible@l\"><div class=\"uk-navbar-left\"><a class=\"uk-logo\" href=\"https://www.kakuhan.com\"><img src=\"https://www.kakuhan.com/wordpress/wp-content/themes/kakuhan/images/common/logo.png\" alt=\"\"></a></div><div class=\"uk-navbar-right\"><ul class=\"uk-navbar-nav gnav\"><li class=\"gnav-list\"><a href=\"https://www.kakuhan.com/works/\">WORKS</a></li><li class=\"gnav-list\"><a href=\"https://www.kakuhan.com/about/\">ABOUT</a></li><li class=\"gnav-list\"><a href=\"https://www.kakuhan.com/map/\">MAP</a></li><li class=\"gnav-list\"><a href=\"https://www.kakuhan.com/recruit/\">RECRUIT</a></li><li class=\"gnav-list\"><a href=\"https://www.kakuhan.com/news/\">NEWS</a></li><li class=\"gnav-list\"><a href=\"https://www.kakuhan.com/gallery/\">GALLERY</a></li><li class=\"gnav-list\"><a href=\"https://www.kakuhan.com/group/\">GROUP</a></li></ul></div></div></nav></div></header><main><div class=\"sub-page-mv uk-background-cover uk-position-relative recruit-interview-mv\" style=\"background-image: url(https://www.kakuhan.com/wordpress/wp-content/themes/kakuhan/images/mv/recruit_mv_4.jpg);\"><div class=\"uk-container\"><div class=\"sub-page-mv__inner\"><div class=\"component-header recruit-interview-mv\"><h2 class=\"title\">RECRUIT<span class=\"slug\">採用情報</span></h2></div></div></div></div><div class=\"uk-section-xsmall breadcrumb uk-padding-remove-bottom\"><div class=\"uk-container\"><ul class=\"uk-breadcrumb\"><li><a class=\"uk-icon-link\" href=\"https://www.kakuhan.com\" uk-icon=\"home\"></a></li><li><a href=\"https://www.kakuhan.com/recruit/\">採用情報</a></li><li><span>社員インタビュー(総務部 部長　田口さん)</span></li></ul></div></div><section class=\"interview-component component uk-margin-remove-bottom\"><div class=\"uk-container\"><div class=\"interview-component__thumnailgrid\"><div class=\"block uk-cover-container\"><canvas width=\"1200\" height=\"900\"></canvas><img src=\"https://www.kakuhan.com/wordpress/wp-content/uploads/2020/04/リクルート田口ＴＯＰ.jpg\" alt=\"\" uk-cover loading=\"lazy\"></div><div class=\"block\"><div class=\"component-header\"><div class=\"inner-contents\"><h2 class=\"title\">会社全体のことを考えて<br /> 行動しなければいけないため、<br /> 常に公平なスタンスで<br /> 仕事に取り組んでいます。</h2><div class=\"data-block\"><p class=\"text\"><span>2000年</span><span>入社</span></p></div><div class=\"postname\"><p class=\"post\">総務部 部長</p><p class=\"name\">田口さん</p></div></div></div></div></div><div class=\"interview-component__works interview-contents\"><h3 class=\"interview-contents__title\">総務部ってどんな仕事？</h3><p><strong>総務·経理·人事·広報·財務など、幅広いジャンルの仕事を行っています。</strong><br /> 私は総務・経理をメインに担当しています。仕事は多岐に渡るため、他のメンバーにも業務を割り振って、協力して行っています。<br /> 現在総務部は7名で頑張っています。</p></div><div class=\"uk-margin-large interview-component__history interview-contents\"><h2>角繁に採用〜入社まで</h2><div class=\"uk-margin-large\"><h3 class=\"interview-contents__title\">まず、角繁を知ったきっかけはなんですか？</h3><p>学生時代の就職活動中に掲示されていた求人情報を見て知りました。<br /> 役員面接後、内定の連絡がすぐにあり、自分を必要としていただいているという気持ちを感じ、とても嬉しかったです。<br /> また、入社試験では、筆記試験の会場から面接会場まで距離が離れていたのですが、社員に丁寧に誘導してもらい優しく声かけをしてもらったのが印象的でした。こういう親切な人が多い会社で働けたら幸せだなと思いました。</p></div><div class=\"uk-margin-large\"><h3 class=\"interview-contents__title\">学生時代に専門的な知識を身につけたのですか？</h3><p>いえ、私はほとんど知識がない状態で入社しました。必要なスキルや知識（たとえば経理や保険関係など）は入社してから覚えました。</p></div></div><div class=\"uk-margin-large interview-component__images interview-contents\"><figure><img src=\"https://www.kakuhan.com/wordpress/wp-content/uploads/2020/04/田口リクルート.jpg\"></figure></div><div class=\"uk-margin-large interview-component__career interview-contents\"><h2>業務内容・キャリアアップについて</h2><h3 class=\"interview-contents__title\">現在の田口さんの仕事内容を詳しく教えてください。</h3><p>・総務·経理関連の書類チェックや部門の管理<br /> ・会議などの資料作成、給与支払業務、社内外への情報発信等の会社全般に関係する仕事<br /> ・経営陣が意思決定するために必要とする情報の収集や提供<br /> ・部門間の調整も含め、会社全体に関すること<br /> などが主な業務です<br /> <br /> その他、多いのは社内外からの問い合わせ対応です。</p><h3 class=\"interview-contents__title\">多岐にわたる仕事内容ですね。1日中1人でデスクワークなのでしょうか？</h3><p>人事・広報・総務の仕事に関しては外出する事が多いです。私が思っていた総務の仕事は、一人で集中してあまり会話をせずに淡々と仕事をこなして一日が終わるイメージだったので、予想外でした。<br /> <br /> 人と話すことが多くコミュニケーションをとって仕事を進めていくので、少しずつ仕事が完成に向かう過程が楽しいです。（時間がないときはすごいプレッシャーですが...）<br /> さらに、総務は自分一人で完結できる仕事はほとんどなく、社内·社外どちらも複数の人と協力して進めることが多いです。<br /> 難しい仕事をうまく達成できたときに喜びを共有できるところは、この仕事のやりがいを感じる部分です。</p><h3 class=\"interview-contents__title\">総務という、会社のまとめ役のような部署にいるからこそ苦労する事などはありますか？</h3><p>人とのやり取りが多い分、様々な点に神経を使うことはありますね。<br /> 会社全体のことを考えて行動しなければいけないため、常に公平なスタンスを保つことに気をつけています。<br /> 相談を受けることも多い部門ですが、片方に感情移入するばかりに他部署へのひずみが出たりしないかを冷静に判断し、<br /> その上で役員への報告や社内への発信をしなければいけない点は難しいです。<br /> フラットな目線で判断をすることを常に心がけています。</p><h3 class=\"interview-contents__title\">公平なスタンスで仕事を行うのは管理職として、とても大事なことですね。</h3><p>極端な感情移入はしないよう心がけているので、相談に対して「個人」ではなく「会社」として最適解が出せるように心がけています。<br /> また、公平でいながら、相談や提案には真剣・親身に対応することも大事だと思っています。</p><h3 class=\"interview-contents__title\">総務部の部長として、部下とのコミュニケーションで気をつけていたり心がけていることはありますか？</h3><p>3つ心がけている点があります。<br /> <br /> ・部署の特性でもありますが皆とても気が利いて、親切にしてくれる部署です。<br /> それが当然とならないように意識的に感謝の気持ちを言葉にして伝えるようにしています。<br /> <br /> ・できるだけ部下の話を聞くようにしています。話しかけられたときや相談をもちかけられたときは、忙しくても普段と変わらず対応するよう心がけています。部下のケアは第一優先としています。<br /> <br /> ・部下の変化を見るようにしています。（外見についてはハラスメントもあるので慎重になりますが、）仕事上で何か悩みがないか、<br /> 作業がうまくいかずに煩雑になっていないか、体調が悪いけど無理していないか・・・などを注視して声かけするようにしています。</p><h3 class=\"interview-contents__title\">現在は管理職に就いていますが、今後のキャリア展望はありますか？</h3><p>これまで経験してきた仕事を通じて、経営企画などより会社全体を俯瞰して見ることができる業務に取り組んでみたいです。<br /> また、今はプレイヤーの色が強いのですがマネジメントについても更に知識を増やして今後の業務に活かしていきたいと思います。</p></div><div class=\"uk-margin-large interview-component__images interview-contents\"><figure><img src=\"https://www.kakuhan.com/wordpress/wp-content/uploads/2020/04/田口リクルート２.jpg\"></figure></div><div class=\"uk-margin-large interview-component__other interview-contents\"><h2>プライベート・その他について</h2><h3 class=\"interview-contents__title\">残業量は正直なところ多いですか？プライベートとの両立はうまくいくでしょうか。</h3><p>残業が多くて大変・・という感じではないのですが、毎日定時で帰れるように努力しています。<br /> 事務的処理が大量に発生する時期、例えば年末や期末は忙しいです。<br /> 帰宅後や休日は家でリラックスしていることが多いですが、たまに趣味の旅行に行くのが楽しみです。</p><h3 class=\"interview-contents__title\">角繁に入社を検討している学生は、何か勉強しておいたほうがよいでしょうか？</h3><p>ビジネスマナーなどは入社前に勉強していると、業務のことのみ覚えることができるので負担が減るかもしれません。<br /> 学生時代にしかできないことや、時間があるからこそ学べること、そして、友達や家族との思い出づくりに励んでもらって短い期間の学生生活を充実したものにしてほしいと思います！</p></div><div class=\"uk-margin-large interview-component__images interview-contents\"><figure><img src=\"https://www.kakuhan.com/wordpress/wp-content/uploads/2020/04/田口リクルート３.jpg\"></figure></div><div class=\"uk-margin-large interview-component__oneday interview-contents\"><h2>総務部　田口さんの1日</h2><table class=\"uk-table\"><tbody><tr><td>07:30～08:00</td><td>出社！コーヒーを飲みながら新聞を読む</td></tr><tr><td>08:00〜09:00</td><td>スケジュールチェック・メール返信・問い合わせ対応</td></tr><tr><td>09:00〜12:00</td><td>書類チェック・会議資料作成</td></tr><tr><td>12:00〜13:00</td><td>昼休憩</td></tr><tr><td>13:00〜14:00</td><td>メール返信・問い合わせ対応</td></tr><tr><td>14:00〜16:00</td><td>社内外との打合せ・来客対応</td></tr><tr><td>16:00〜17:00</td><td>打合せ議事録作成・社内インフォメーション作成</td></tr><tr><td>17:00～17:30</td><td>メール返信</td></tr><tr><td>17:30～18:30</td><td>稟議書、日報確認</td></tr><tr><td>18:30～</td><td>書類を片付けて退社！今日もお疲れさまでした。</td></tr></tbody></table></div></div><section class=\"interview-component__contact uk-background-norepeat uk-background-fixed uk-background-cover uk-position-relative uk-background-center-center\" style=\"background-image: url(https://www.kakuhan.com/wordpress/wp-content/themes/kakuhan/images/top/contact_bg.jpg);\"><div class=\"contact-grid\"><div class=\"block\"><h2>採用に関する<br>お問い合わせはこちらから</h2><p class=\"contact-tel\"><span uk-icon=\"receiver\"></span><a class=\"tel-text\" href=\"tel:0188339461\">018-833-9461</a><span class=\"ex\">平日 8:00〜17:00</span><span uk-icon=\"print\"></span>018-833-9464</p><a class=\"btn\" href=\"mailto:info@kakuhan.com\"><span uk-icon=\"mail\"></span>info@kakuhan.com</a></div><div class=\"block\"><p>募集要項を見る</p><div class=\"btn-block\"><a href=\"https://www.kakuhan.com/recruit/guideline/#career\">中途採用<svg class=\"arrow\" xmlns=\"http://www.w3.org/2000/svg\" width=\"86.679\" height=\"57.786\" viewBox=\"0 0 86.679 57.786\"><path id=\"パス_95\" data-name=\"パス 95\" d=\"M74.732,193.263l21.883-20.21H22.329v-7.318H96.615L74.732,145.523l4.587-5.023,29.689,28.677v.432L79.319,198.286Z\" transform=\"translate(-22.329 -140.5)\" fill=\"#fff\"></path></svg></a><a href=\"https://www.kakuhan.com/recruit/guideline/#new\">新卒採用<svg class=\"arrow\" xmlns=\"http://www.w3.org/2000/svg\" width=\"86.679\" height=\"57.786\" viewBox=\"0 0 86.679 57.786\"><path id=\"パス_95\" data-name=\"パス 95\" d=\"M74.732,193.263l21.883-20.21H22.329v-7.318H96.615L74.732,145.523l4.587-5.023,29.689,28.677v.432L79.319,198.286Z\" transform=\"translate(-22.329 -140.5)\" fill=\"#fff\"></path></svg></a></div></div></div></section></section></main><div id=\"offset\"><div class=\"totop\" id=\"totop\"><a href=\"#top\" uk-scroll><img src=\"https://www.kakuhan.com/wordpress/wp-content/themes/kakuhan/images/common/totop.png\" alt=\"\"></a></div></div><footer class=\"global-footer\" id=\"global-footer\"><div class=\"uk-container\"><div class=\"uk-child-width-1-4 uk-visible@l\" uk-grid><div><div class=\"f_nav__content\"><a class=\"f_nav\" href=\"https://www.kakuhan.com\">TOPページ</a></div><div class=\"f_nav__content\"><a class=\"f_nav\" href=\"https://www.kakuhan.com/about/\">会社案内</a></div><div class=\"f_nav__content\"><ul class=\"uk-nav uk-nav-default\"><li class=\"uk-parent\"><a class=\"parent-link\" href=\"https://www.kakuhan.com/works/\">業務内容</a><ul class=\"uk-nav-sub line\"><li><a class=\"sub_link\" href=\"https://www.kakuhan.com/works/wood\">木材</a></li><li><a class=\"sub_link\" href=\"https://www.kakuhan.com/works/materials\">建材・住宅設備機器</a></l