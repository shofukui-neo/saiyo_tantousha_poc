{"url":"https://digital.panasonic.co.jp/recruit/about-us/about.html","html":"<!DOCTYPE html>\n<html lang=\"ja\" xmlns:mso=\"urn:schemas-microsoft-com:office:office\" xmlns:msdt=\"uuid:C2F41010-65B3-11d1-A29F-00AA00C14882\">\n<head>\n<meta charset=\"UTF-8\">\n<meta http-equiv=\"content-language\" content=\"ja\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1, maximum-scale=1\">\n<title>私たちについて | About Us | 採用情報 | パナソニック デジタル</title>\n<meta name=\"keywords\" content=\"パナソニック,Panasonic,パナソニックIS ,パナソニック デジタル 採用情報, Panasonic Information Systems,企業情報\">\n<meta name=\"description\" content=\" ,パナソニック デジタル株式会社は、約60年にわたる豊富なシステム構築経験と運用ノウハウを強みとし、システムイ ンテグレーション、アウトソーシング、ソフトウエアの開発、販売等を行っています。このサイトでは当社の採用情報をご覧いただけます。\">\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/style.css\" />\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/jquery.bxslider.css\" />\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../css/modaal.css\" />\n<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n<link href=\"https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;700&family=Comfortaa:wght@400;700&&display=swap\" rel=\"stylesheet\">\n<script src=\"../js/jquery-3.6.1.min.js\"></script>\n<script src=\"../js/jquery.bxslider.js\"></script>\n<script src=\"../js/common.js\"></script>\n<!-- Google tag (gtag.js) -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-Q1W47H5ME4\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n  gtag('config', 'G-Q1W47H5ME4');\n</script>\n<!-- Meta Pixel Code -->\n<script>\n  !function(f,b,e,v,n,t,s)\n  {if(f.fbq)return;n=f.fbq=function(){n.callMethod?\n  n.callMethod.apply(n,arguments):n.queue.push(arguments)};\n  if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';\n  n.queue=[];t=b.createElement(e);t.async=!0;\n  t.src=v;s=b.getElementsByTagName(e)[0];\n  s.parentNode.insertBefore(t,s)}(window, document,'script',\n  'https://connect.facebook.net/en_US/fbevents.js');\n  fbq('init', '592318079688822');\n  fbq('track', 'PageView');\n</script>\n<noscript><img height=\"1\" width=\"1\" style=\"display:none\"\n  src=\"https://www.facebook.com/tr?id=592318079688822&ev=PageView&noscript=1\"\n/></noscript>\n<!-- End Meta Pixel Code -->\n\n<!--[if gte mso 9]><xml>\n<mso:CustomDocumentProperties>\n<mso:xd_Signature msdt:dt=\"string\"></mso:xd_Signature>\n<mso:display_urn_x003a_schemas-microsoft-com_x003a_office_x003a_office_x0023_Editor msdt:dt=\"string\">&#27700;&#27969; &#29702;&#24693;</mso:display_urn_x003a_schemas-microsoft-com_x003a_office_x003a_office_x0023_Editor>\n<mso:Order msdt:dt=\"string\">687300.000000000</mso:Order>\n<mso:xd_ProgID msdt:dt=\"string\"></mso:xd_ProgID>\n<mso:_ExtendedDescription msdt:dt=\"string\"></mso:_ExtendedDescription>\n<mso:display_urn_x003a_schemas-microsoft-com_x003a_office_x003a_office_x0023_Author msdt:dt=\"string\">&#27700;&#27969; &#29702;&#24693;</mso:display_urn_x003a_schemas-microsoft-com_x003a_office_x003a_office_x0023_Author>\n<mso:ComplianceAssetId msdt:dt=\"string\"></mso:ComplianceAssetId>\n<mso:TemplateUrl msdt:dt=\"string\"></mso:TemplateUrl>\n<mso:ContentTypeId msdt:dt=\"string\">0x0101000C9476831829A84E900CF7CF49F6C484</mso:ContentTypeId>\n<mso:TriggerFlowInfo msdt:dt=\"string\"></mso:TriggerFlowInfo>\n<mso:_SourceUrl msdt:dt=\"string\"></mso:_SourceUrl>\n<mso:_SharedFileIndex msdt:dt=\"string\"></mso:_SharedFileIndex>\n<mso:TaxCatchAll msdt:dt=\"string\"></mso:TaxCatchAll>\n<mso:MediaServiceImageTags msdt:dt=\"string\"></mso:MediaServiceImageTags>\n<mso:lcf76f155ced4ddcb4097134ff3c332f msdt:dt=\"string\"></mso:lcf76f155ced4ddcb4097134ff3c332f>\n</mso:CustomDocumentProperties>\n</xml><![endif]-->\n</head>\n\n<body>\n<div id=\"header\">\n<div id=\"header-inner\">\n<div id=\"header-logo\"><a href=\"../index.html\"><img src=\"../images/logo.png\" alt=\"パナソニック ロゴ\"></a></div>\n<div id=\"header-logo-info\">パナソニック デジタル<br>RECRUITING SITE</div>\n<div id=\"header-btns\">\n<div class=\"to-corp-btn\"><a href=\"https://digital.panasonic.co.jp/\" target=\"_blank\">企業サイトへ</a></div>\n\n<div class=\"entry-btn\"><a href=\"../entry/index.html\">ENTRY</a></div>\n</div>\n<div class=\"sp-menu-btn-box\">\n<a id=\"open-sp-menu\" href=\"#sp-menu\" class=\"fullscreen non-scroll sp-menu-btn sp-menu-btn-open\"><span></span><span></span><span></span></a>\n<div class=\"modaal-close close-sp-menu\"></div>\n</div>\n</div>\n</div>\n\n<div class=\"cont-wrap fade-in effect-scroll\">\n<div class=\"page-main-sec\">\n<div class=\"page-main-sec-inner\">\n<img src=\"../images/main-about01.jpg\" alt=\"イメージ\" class=\"page-main-v\">\n<div class=\"page-main-cat-fl\">\n<div class=\"page-main-cat-box move-to-right effect-scroll\">\n<div class=\"page-main-cat\">About Us</div>\n<img src=\"../images/top-about-jp.png\" alt=\"私たちのこと\">\n</div>\n</div>\n</div>\n</div>\n\n<h1 class=\"page-ttl-sec\">私たちについて</h1>\n<div class=\"page-contents-wrap\">\n<div class=\"aboutus-wrap\">\n\n<div class=\"about-num-sec move-up effect-scroll\">\n<div class=\"about-num\">01</div>\n<div class=\"inner-1000\">\n<div class=\"marked-text\">\n<span>One Panasonic IT</span>\n</div>\n<div class=\"about-std-text\">\nパナソニックグループのシナジー創出を促すためのキャッチコピー「One Panasonic」。ここにITの2文字を加えた「One Panasonic IT」は、“デジタルと人の力で「くらし」と「しごと」を幸せにするために、お客様、お取引先様、従業員に、ITによる本質的な価値を提供し、経営に直接貢献する”という私たちの意志を込めたフレーズです。\n</div>\n\n<div class=\"about-pick01-sec fade-in effect-scroll\">\n<div class=\"about-pick01-ttl\">\nPX<br>\n<span>(Panasonic Transformation)</span>\n</div>\n<div class=\"about-std-text\">\n「One Panasonic IT」が掲げる“デジタルと人の力で「くらし」と「しごと」を幸せにする”こと。その要となるのが、「PX（Panasonic Transformation）」です。「ITとデジタルを通じてパナソニックを良い方向に変革する」ことを目的にしたこの全社活動において、当社はその強みと実行力を発揮し中心となって推進しています。\n</div>\n<div class=\"about-pick01-video-box\">\n<div class=\"youtube\">\n<iframe loading=\"lazy\" width=\"560\" height=\"315\" src=\"https://www.youtube.com/embed/5q3dSebHxOg?loop=1&playlist=5q3dSebHxOg\" title=\"YouTube video player\" frameborder=\"0\" allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share\" allowfullscreen></iframe>\n</div>\n</div>\n</div>\n\n<div class=\"about-pick-block-ttl\">MISSION</div>\n<div class=\"page-accent-mark\"></div>\n<div class=\"about-mission-sec fade-in effect-scroll\">\n<div class=\"about-mission-ttl\">\nお客様、お取引先様、従業員に、ITによる本質的な価値を提供、経営に直接貢献。\n</div>\n<div class=\"about-mission-cont\">\n<div class=\"about-mission-cont-once\"><span>お客様</span>の<br>便利と嬉しいへ</div>\n<div class=\"about-mission-cont-once\"><span>お取引先様</span>との<br>シナジーへ</div>\n<div class=\"about-mission-cont-once\"><span>従業員</span>の<br>キャリア形成と<br>成長へ</div>\n<div class=\"about-mission-cont-tag\">ITを創る喜びを</div>\n</div>\n</div>\n<div class=\"about-pick-block-ttl\">VISION</div>\n<div class=\"page-accent-mark\"></div>\n<div class=\"about-vision-cont-box fade-in effect-scroll\">\n<div class=\"about-vision-cont-once\">\n<div class=\"atc-text\">\n私たちはビジネスに寄り添う、<br><span>Co-Creator</span><br>です。\n</div>\n<p>\nお客様の「くらし」と「しごと」を<br class=\"over900\">共に考え、共に創ります。\n</p>\n</div>\n<div class=\"about-vision-cont-once\">\n<div class=\"atc-text\">\n私たちは<br><span>Innovator</span><br>です。\n</div>\n<p>\n新しい技術、働き方で、スピーディに、<br class=\"over900\">想像の先を実現します。</p>\n</div>\n<div class=\"about-vision-cont-once\">\n<div class=\"atc-text\">\n私たちは<br><span>One Panasonic IT</span><br>です。\n</div>\n<p>\n認め合い、学び合い、高め合って、<br class=\"over900\">皆で成長し続けます。</p>\n</div>\n</div>\n\n<div class=\"about-pick-block-ttl\">VALUE</div>\n<div class=\"page-accent-mark\"></div>\n<div class=\"about-value-cont-box fade-in effect-scroll\">\n<div class=\"about-value-cont-once\">\n<div class=\"about-value-cont-once-ttl\">想像、その先を創造</div>\n<div class=\"about-value-cont\">\n<p>\nお客様の夢をかなえるために<br>\nITの匠集団として、<br>\n想像の先を創造する\n</p>\n</div>\n</div>\n<div class=\"about-value-cont-once\">\n<div class=\"about-value-cont-once-ttl\">多様性、信頼、成長</div>\n<div class=\"about-value-cont\">\n<p>\n多様性を認め合い、<br>\n時にぶつかり、高め合う\n</p>\n</div>\n</div>\n<div class=\"about-value-cont-once\">\n<div class=\"about-value-cont-once-ttl\">速く、広く、深く、つなぐ</div>\n<div class=\"about-value-cont\">\n<p>\nつなぐ価値を最大化<br>\nビジネスとIT、人や組織、<br>\n人のこころをつなぐ\n</p>\n</div>\n</div>\n<div class=\"about-value-cont-once\">\n<div class=\"about-value-cont-once-ttl\">データが語る、語らせる</div>\n<div class=\"about-value-cont\">\n<p>\n答えのヒントはデータにある。<br>\nデータに語らせる\n</p>\n</div>\n</div>\n<div class=\"about-value-cont-once\">\n<div class=\"about-value-cont-once-ttl\">衆知・自律化集団</div>\n<div class=\"about-value-cont\">\n<p>\n全員参加で衆知を集め、<br>\n変革を常態化\n</p>\n</div>\n</div>\n<div class=\"about-value-cont-once\">\n<div class=\"about-value-cont-once-ttl\">主役は、「わたし」</div>\n<div class=\"about-value-cont\">\n<p>\n変革の主役は「わたし」\n</p>\n</div>\n</div>\n</div>\n\n\n\n</div>\n</div>\n\n<div class=\"about-num-sec move-up effect-scroll\">\n<div class=\"about-num\">02</div>\n<div class=\"inner-1000\">\n<div class=\"marked-text\">\n<span>パナソニックグループにおける役割</span>\n</div>\n<div class=\"about-std-text\">\nパナソニック デジタルが携わる事業分野は、パナソニックホールディングスの各事業会社の事業領域の全て。家電や自動車、航空や公共などパナソニックが展開する様々な事業分野において、グループ企業会社に勤める現場の方々と一体となり、生産性の向上や商品の品質向上など様々な課題解決に取り組んでいます。<br>\n“ITとデジタルを通じてパナソニックを良い方向に変革する”という使命を果たすべく、グループを横断した全社活動に取り組んでいます。\n</div>\n<div class=\"about-full-img\">\n<img class=\"img800\" src=\"../images/business-img01.png\" alt=\"業務のイメージ図\">\n</div>\n<div class=\"about-with-img-btn\">\n<a href=\"../business/inside-group.html\">\n<img class=\"img100\" src=\"../images/about-img-btn01.jpg\" alt=\"イメージ\">\n<div class=\"about-with-img-btn-ttl\">パナソニックグループ内での<br class=\"under700\">ビジネスを詳しく知る</div>\n</a>\n</div>\n</div>\n</div>\n\n<div class=\"about-num-sec move-up effect-scroll\">\n<div class=\"about-num\">03</div>\n<div class=\"inner-1000\">\n<div class=\"marked-text\">\n<span>パナソニックグループ外のお客様との関わり</span>\n</div>\n<div class=\"about-std-text\">\nパナソニック デジタルが携わる事業分野は、グループ内に留まりません。パナソニックグループの国内外の多様な事業をITで支援すると共に、そこで培った経験・ノウハウを活かし、パナソニックグループ外のお客様とも様々なお取引があります。<br>\nその領域は幅広く、製造や販売に関わる基幹業務はもちろん、製造現場の支援や施設空間など、暮らしの様々な場所に関わっています。あなたがいつも行くあの場所にも、私たちの技術が活かされているかもしれませんよ。\n</div>\n<div class=\"about-full-img\">\n<img class=\"img900\" src=\"../images/about-img03.png\" alt=\"業務のイメージ図\">\n</div>\n<div class=\"about-with-img-btn\">\n<a href=\"../business/outside-group.html\">\n<img class=\"img100\" src=\"../images/about-img-btn02.jpg\" alt=\"イメージ\">\n<div class=\"about-with-img-btn-ttl\">パナソニックグループ外での<br class=\"under700\">ビジネスを詳しく知る</div>\n</a>\n</div>\n</div>\n</div>\n\n</div>\n</div>\n</div>\n\n<div class=\"foot-messege-sec\">\n<div class=\"foot-messege-box\">\n<img src=\"../images/foot-message.png\" alt=\"デジタルで、幸せをつくろう。\">\n<p class=\"foot-company-name\">Panasonic Digital Co., Ltd.</p>\n<div class=\"foot-site-info\">RECRUITING SITE</div>\n</div>\n</div>\n<div class=\"footer-wrap\">\n<div class=\"inner-1000\">\n<div class=\"footer-att-box\">\n<div class=\"footer-att-ttl\">重要なお知らせ</div>\n<p>\nパナソニック社員やOB・OGを名乗り、就職活動学生に声をかける不審者にご注意ください。主要駅や就職活動イベント会場周辺において、パナソニックの社員やOB・OGを名乗り、個人情報の入手や金品の詐取などを目的に、パナソニックへの就職を優遇するなどと 声をかける不審者がいるとの情報が寄せられています。パナソニックの社員やOB・OGが就職の便宜を図る目的で声をかけることは一切ございませんので、くれぐれもご注意ください。\n</p>\n</div>\n\n<div class=\"footer-links-ttl\">\nパナソニック デジタル株式会社　RECRUITING SITE\n</div>\n<dl>\n<dt>TOP</dt>\n<dd><a href=\"../index.html\">TOPページ</a></dd>\n<dt>About Us</dt>\n<dd>\n<a href=\"../about-us/about.html\">私たちについて</a>\n<a href=\"../about-us/numbers.html\">数字で知る！私たちの強み</a>\n<a href=\"../about-us/keywords.html\">キーワードで知る！私たちの特徴</a>\n<a href=\"../about-us/numbers-of-woman.html\">数字で知る！女性社員の活躍</a>\n<a href=\"../about-us/movie.html\">動画で知る！私たち</a>\n</dd>\n<dt>Business</dt>\n<dd>\n<a href=\"../business/inside-group.html\">パナソニックグループでのビジネス</a>\n<a href=\"../business/outside-group.html\">グループ外のお客様とのビジネス</a>\n</dd>\n<dt>Flow</dt>\n<dd>\n<a href=\"../flow/process.html\">業務プロセスの流れ</a>\n</dd>\n<dt>Work&amp;People</dt>\n<dd>\n<a href=\"../work-people/job-category.html\">職種紹介</a>\n<a href=\"../work-people/inoue.html\">井上 温子</a>\n<a href=\"../work-people/minamitani.html\">南谷 祥之</a>\n<a href=\"../work-people/muro.html\">室 晶彦</a>\n<a href=\"../work-people/nakamura.html\">中村 亮</a>\n<a href=\"../work-people/takahashi.html\">高橋 僚</a>\n<a href=\"../work-people/taniguchi.html\">谷口 由起</a>\n<a href=\"../work-people/hori.html\">堀 祐豪</a>\n<a href=\"../work-people/makigano.html\">牧ヶ野 衣里</a>\n<a href=\"../work-people/talk.html\">理系女子座談会</a>\n<a href=\"../work-people/talk-parental.html\">育児休業取得者対談</a>\n</dd>\n<dt>Special Contents</dt>\n<dd>\n<a href=\"../special/challengers/index.html\">CHALLENGERS 〜変革への挑戦者たち〜</a>\n<a href=\"../special/transformation/index.html\">TRANSFORMATION 〜未来への変革〜</a>\n<a href=\"../special/womens-careers/index.html\">Women's Careers　女性社員のキャリア紹介</a>\n</dd>\n<dt>Recruit Info</dt>\n<dd>\n<a href=\"../recruit-info/support-system.html\">出産・育児の支援制度</a>\n<a href=\"../recruit-info/career-step.html\">キャリアステップ</a>\n<a href=\"../recruit-info/education.html\">新入社員教育・研修</a>\n<a href=\"../recruit-info/faq.html\">FAQ</a>\n<a href=\"../recruit-info/essential.html\">新卒採用募集要項</a></dd>\n</dl>\n\n<div class=\"copyright\">&copy; Panasonic Digital Co., Ltd.</div>\n</div>\n</div>\n\n<!--=======OVERLAY MENU==========-->\n<div id=\"sp-menu\" class=\"hidden\">\n<div class=\"sp-menu-inner\">\n<dl>\n<dt>Top</dt>\n<dd>\n<a href=\"../index.html\">TOPページ</a>\n</dd>\n<dt>About Us</dt>\n<dd>\n<a href=\"../about-us/about.html\">私たちについて</a>\n<a href=\"../about-us/numbers.html\">数字で知る！私たちの強み</a>\n<a href=\"../about-us/keywords.html\">キーワードで知る！私たちの特徴</a>\n<a href=\"../about-us/numbers-of-woman.html\">数字で知る！女性社員の活躍</a>\n<a href=\"../about-us/movie.html\">動画で知る！私たち</a>\n</dd>\n<dt>Business</dt>\n<dd>\n<a href=\"../business/inside-group.html\">パナソニックグループでのビジネス</a>\n<a href=\"../business/outside-group.html\">グループ外のお客様とのビジネス</a>\n</dd>\n<dt>Flow</dt>\n<dd>\n<a href=\"../flow/process.html\">業務プロセスの流れ</a>\n</dd>\n<dt>Work&amp;People</dt>\n<dd>\n<a href=\"../work-people/job-category.html\">職種紹介</a>\n<a href=\"../work-people/inoue.html\">井上 温子</a>\n<a href=\"../work-people/minamitani.html\">南谷 祥之</a>\n<a href=\"../work-people/muro.html\">室 晶彦</a>\n<a href=\"../work-people/nakamura.html\">中村 亮</a>\n<a href=\"../work-people/takahashi.html\">高橋 僚</a>\n<a href=\"../work-people/taniguchi.html\">谷口 由起</a>\n<a href=\"../work-people/hori.html\">堀 祐豪</a>\n<a href=\"../work-people/makigano.html\">牧ヶ野 衣里</a>\n<a href=\"../work-people/talk.html\">理系女子座談会</a>\n<a href=\"../work-people/talk-parental.html\">育児休業取得者対談</a>\n</dd>\n<dt>Special Contents</dt>\n<dd>\n<a href=\"../special/challengers/index.html\">CHALLENGERS 〜変革への挑戦者たち〜</a>\n<a href=\"../special/transformation/index.html\">TRANSFORMATION 〜未来への変革〜</a>\n<a href=\"../special/womens-careers/index.html\">Women's Careers　女性社員のキャリア紹介</a>\n</dd>\n<dt>Recruit Info</dt>\n<dd>\n<a href=\"../recruit-info/support-system.html\">出産・育児の支援制度</a>\n<a href=\"../recruit-info/career-step.html\">キャリアステップ</a>\n<a href=\"../recruit-info/education.html\">新入社員教育・研修</a>\n<a href=\"../recruit-info/faq.html\">FAQ</a>\n<a href=\"../recruit-info/essential.html\">新卒採用募集要項</a>\n</dd>\n</dl>\n</div>\n</div>\n\n<script src=\"../js/modaal.js\"></script>\n<script>\n$('.fullscreen').modaal({\nfullscreen: true,\nhide_close:true\n});\n</script>\n</body>\n</html>","finalUrl":"https://digital.panasonic.co.jp/recruit/about-us/about.html","rendered":false,"_cachedAt":"2026-06-22T22:49:19.255Z"}