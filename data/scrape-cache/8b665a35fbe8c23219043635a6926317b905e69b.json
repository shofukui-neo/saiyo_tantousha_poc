{"url":"https://www.suzuki.co.jp/dealer/sj-gunma/recruit/graduate-guideline/","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n  <title>【新卒採用】募集要項｜採用情報｜株式会社スズキ自販群馬</title>\n  <link rel=\"icon\" href=\"/dealer/assets/img/common/favicon.ico\">\n  <link rel=\"stylesheet\" href=\"/dealer/assets/css/style.css\">\n  <link rel=\"stylesheet\" href=\"https://maxcdn.bootstrapcdn.com/font-awesome/4.7.0/css/font-awesome.min.css\">\n\n  <style>\n      .ly_bgGray {\n      background-image: url('/dealer/sj-admin/sharefiles/水玉_81480b88-a0c9-11eb-a603-fa163e794ba5.jpg');\n      background-repeat: repeat;\n      background-size: 100% auto;\n    }\n  </style>\n\n    <meta name=\"description\" content=\"株式会社スズキ自販群馬の【新卒採用】募集要項ページです。\">\n  <meta name=\"keywords\" content=\"\">\n  <meta property=\"og:title\" content=\"【新卒採用】募集要項｜採用情報｜株式会社スズキ自販群馬\">\n  <meta property=\"og:type\" content=\"website\">\n  <meta property=\"og:description\" content=\"株式会社スズキ自販群馬の【新卒採用】募集要項ページです。\">\n  <meta property=\"og:url\" content=\"https://www.suzuki.co.jp/dealer/sj-gunma/recruit/graduate-guideline/\">\n  <meta property=\"og:image\" content=\"https://www.suzuki.co.jp/dealer/assets/img/common/ogp.gif\" />\n  <meta property=\"og:site_name\" content=\"株式会社スズキ自販群馬\" />\n  <meta property=\"og:locale\" content=\"ja_JP\" />\n<!-- Google Tag Manager -->\n<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\nnew Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\nj=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\n'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\n})(window,document,'script','dataLayer','GTM-T3HPBJF');</script>\n<!-- End Google Tag Manager -->\n\n\n</head>\n<body class=\"dealer\" >\n<!-- Google Tag Manager (noscript) -->\n<noscript><iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-T3HPBJF\"\nheigh