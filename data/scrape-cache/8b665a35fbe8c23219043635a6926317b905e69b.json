 </ul>\n      </nav>\n      <!-- /.bl_headerNav_gnav -->\n      <div class=\"bl_headerNav_utilityNav\">\n        <div class=\"bl_utilityNav cf\">\n                                    <div class=\"bl_utilityNav_wrapp cf\">\n            <div class=\"bl_utilityNav_child bl_utilityNav_child__recall\"><a href=\"https://www.suzuki.co.jp/recall/\" target=\"_blank\"><span class=\"bl_utilityNav_child_inner\">リコール等情報</span></a></div>\n          </div>\n        </div>\n        <div class=\"bl_utilityNav cf\">\n          <div class=\"bl_utilityNav_wrapp cf\">\n                                  </div>\n          <div class=\"bl_utilityNav_wrapp cf\">\n                                  </div>\n        </div>\n      </div>\n      <!-- /.bl_headerNav_gnav -->\n    </div>\n    <!-- /.bl_headerNav -->\n  </div>\n  <!-- /.ly_header_inner -->\n</header>\n      <!-- YTM -->\n  <!-- End YTM-->\n\n  <!--#include virtual=\"/dealer/dairi/_inc/_header.html\" -->\n\n\n  <div class=\"ly_bgWhite\">\n    <div class=\"ly_body\">\n      <ol class=\"bl_breadcrumbs cf\">\n        <li><a href=\"/dealer/sj-gunma/\">ホーム</a></li>\n        <li><a href=\"/dealer/sj-gunma/recruit/\">採用情報</a></li>\n        <li>【新卒採用】募集要項</li>\n      </ol>\n    </div>\n    <!-- /.ly_body -->\n  </div>\n  <!-- /.ly_bgWhite -->\n\n  <div class=\"ly_bgBlue bl_M01 bl_M01__col1\">\n    <div class=\"ly_body\">\n      <div class=\"bl_M01_txt\">\n        <h1 class=\"el_pageTtl\">【新卒採用】募集要項</h1>\n      </div>\n    </div>\n    <!-- /.bl_M01 -->\n  </div>\n  <!--#include virtual=\"/dealer/dairi/_inc/_localNav_recruit.html\" -->\n  <div class=\"bl_N01 recruit-menu\">\n  <div class=\"ly_body\">\n    <ul class=\"bl_N01_list js_matchHeightChildren\">\n      <li class=\"bl_N01_list_child\"><div class=\"bl_N01_list_child_inner\"><span><a href=\"/dealer/sj-gunma/recruit/\">採用情報</a></span></div></li>\n      <li class=\"bl_N01_list_child graduate-guideline\"><div class=\"bl_N01_list_child_inner\"><span><a href=\"/dealer/sj-gunma/recruit/graduate-guideline/\">【新卒採用】<br>募集要項</a></span></div></li>\n      <li class=\"bl_N01_list_child career-guideline\"><div class=\"bl_N01_list_child_inner\"><span><a href=\"/dealer/sj-gunma/recruit/career-guideline/\">【中途採用】<br>募集要項</a></span></div></li>\n      <li class=\"bl_N01_list_child workplace_information\"><div class=\"bl_N01_list_child_inner\"><span><a href=\"/dealer/sj-gunma/recruit/workplace_information/\">職場情報</a></span></div></li>\n      <li class=\"bl_N01_list_child briefing\"><div class=\"bl_N01_list_child_inner\"><span><a href=\"/dealer/sj-gunma/recruit/briefing/\">説明会情報</a></span></div></li>\n      <li class=\"bl_N01_list_child message\"><div class=\"bl_N01_list_child_inner\"><span><a href=\"/dealer/sj-gunma/recruit/message/\">みなさんへの<br />メッセージ</a></span></div></li>\n      <li class=\"bl_N01_list_child workplace\"><div class=\"bl_N01_list_child_inner\"><span><a href=\"/dealer/sj-gunma/recruit/workplace/\">職場紹介</a></span></div></li>\n      <li class=\"bl_N01_list_child shop\"><div class=\"bl_N01_list_child_inner\"><span><a href=\"/dealer/sj-gunma/recruit/shop/\">拠点紹介</a></span></div></li>\n      <li class=\"bl_N01_list_child topic\"><div class=\"bl_N01_list_child_inner\"><span><a href=\"/dealer/sj-gunma/recruit/topic/\">採用トピックス</a></span></div></li>\n    </ul>\n  </div>\n</div>\n<!-- /.bl_N01 -->\n\n\n  <div id=\"graduate-guideline\">\n    <div class=\"ly_bgGray ly_padding ly_padding__bottom\">\n          <div class=\"ly_body ly_body__mainContents ly_bgWhite\">\n              <section class=\"bl_sect01 hp_mb45\">\n          <h3 class=\"el_sectTtl__lv3\"><span class=\"el_sectTtl__lv3_inner\">募集職種：営業職(2027年卒対象）</span></h3>\n          <table class=\"bl_table__std\">\n            <tbody>\n                          <tr>\n                <th class=\"bl_table__std_hd__mid\">給与</th>\n                <td>\n                  基本給<br />\r\n【四年制大学卒】２２８，０００円　<br />\r\n【短大・専門卒】２０８，０００円　<br />\r\n<br />\r\n※通勤手当や時間外手当（残業代）などは別途支給します。\n                </td>\n              </tr>\n                                      <tr>\n                <th class=\"bl_table__std_hd__mid\">手当</th>\n                <td>奨励金、時間外手当、子育て支援手当、住宅手当、役職手当、通勤手当</td>\n              </tr>\n                                      <tr>\n                <th class=\"bl_table__std_hd__mid\">試用期間</th>\n                <td>４月～９月の６ヶ月間</td>\n              </tr>\n                                      <tr>\n                <th class=\"bl_table__std_hd__mid\">昇給</th>\n                <td>年１回（４月）</td>\n              </tr>\n                                      <tr>\n                <th class=\"bl_table__std_hd__mid\">賞与</th>\n                <td>年２回（７月、１２月）、勤続２年目以降　６．２ヶ月（２０２５年度実績）</td>\n              </tr>\n                                      <tr>\n                <th class=\"bl_table__std_hd__mid\">勤務地</th>\n                <td>群馬県内１１ヶ所の各営業所（高崎、前橋、伊勢崎、太田、みどり市、館林、藤岡、渋川）※県外への異動・転勤はありません）</td>\n              </tr>\n                                      <tr>\n                <th class=\"bl_table__std_hd__mid\">勤務時間</th>\n                <td>【業販営業】８：４０～１７：４０／【直販営業】９：３０～１８：３０</td>\n              </tr>\n                                      <tr>\n                <th class=\"bl_table__std_hd__mid\">休日</th>\n                <td>【年間休日】会社カレンダーによる１１５日（年末年始、夏季、GW含む)<br />\r\n※別途、計画有給７日取得を必須としています。（実質の年間休日は１２２日です。）<br />\r\n<br />\r\n【業販営業】日曜日・祝日、土曜日は会社指定日<br />\r\n【直販営業】毎週火曜日、第２・３水曜日　（定休日以外にもシフト制の休みがあります。）</td>\n              </tr>\n                                      <tr>\n                <th class=\"bl_table__std_hd__mid\">休暇</th>\n                <td>有給休暇、結婚休暇、産前産後休暇、出生時育児休暇、忌引休暇、法要休暇、傷病介護休暇ほか</td>\n              </tr>\n                                      <tr>\n                <th class=\"bl_table__std_hd__mid\">保険</th>\n                <td>健康保険、厚生年金、雇用保険、労災保険</td>\n              </tr>\n                                      <tr>\n                <th class=\"bl_table__std_hd__mid\">福利厚生</th>\n                <td>通信教育受講補助、車両購入援助制度、退職金、財形貯蓄、持株制度、慶弔金、借上げ寮制度　</td>\n              </tr>\n                                      <tr>\n                <th class=\"bl_table__std_hd__mid\">採用実績校</th>\n                <td>高崎経済大学、高崎商科大学、共愛学園前橋国際大学、関東学園大学、上武大学、埼玉工業大学、桐生大学、城西大学、高崎健康福祉大学、東京農業大学、大東文化大学、群馬県立女子大学、東京福祉大学、神奈川大学、東海大学、東北学院大学、育英大学、育英短期大学、高崎商科大学短期大学部、新島学園短期大学、日本大学、日本外国語専門学校、群馬県立農林大学校、目白大学、白鴎大学、西武文理大学、茨城大学、　ほか　　<br />\r\n <br />\r\n</td>\n              </tr>\n                        </tbody>\n          </table>\n        </section>\n                <section class=\"bl_sect01 hp_mb45\">\n          <h3 class=\"el_sectTtl__lv3\"><span class=\"el_sectTtl__lv3_inner\">募集職種：整備職(2027年卒対象)</span></h3>\n          <table class=\"bl_table__std\">\n            <tbody>\n                          <tr>\n                <th class=\"bl_table__std_hd__mid\">給与</th>\n                <td>\n                  基本給<br />\r\n【１級課程卒】２２８，０００円　<br />\r\n【車体課程卒】２１３，０００円<br />\r\n【２級課程卒】２０８，０００円　<br />\r\n【３級課程卒】１９８，０００円<br />\r\n<br />\r\n※通勤手当や時間外手当（残業代）などは別途支給します。\n                </td>\n              </tr>\n                                      <tr>\n                <th class=\"bl_table__std_hd__mid\">手当</th>\n                <td>奨励金、時間外手当、子育て支援手当、住宅手当、役職手当、通勤手当</td>\n              </tr>\n                                      <tr>\n                <th class=\"bl_table__std_hd__mid\">試用期間</th>\n                <td>４月～９月の６ヶ月間</td>\n              </tr>\n                                      <tr>\n                <th class=\"bl_table__std_hd__mid\">昇給</th>\n                <td>年１回（４月）</td>\n              </tr>\n                                      <tr>\n                <th class=\"bl_table__std_hd__mid\">賞与</th>\n                <td>年２回（７月、１２月）、勤続２年目以降　６．２ヶ月（２０２５年度実績）</td>\n              </tr>\n                                      <tr>\n                <th class=\"bl_table__std_hd__mid\">勤務地</th>\n                <td>群馬県内１１ヶ所の各営業所（高崎、前橋、伊勢崎、太田、みどり市、館林、藤岡、渋川）※県外への異動・転勤はありません）</td>\n              </tr>\n                                      <tr>\n                <th class=\"bl_table__std_hd__mid\">勤務時間</th>\n                <td>９：３０～１８：３０</td>\n              </tr>\n                                      <tr>\n                <th class=\"bl_table__std_hd__mid\">休日</th>\n                <td>【年間休日】会社カレンダーによる１１５日（年末年始、夏季、GW含む)<br />\r\n※別途、計画有給７日取得を必須としています。（実質の年間休日は１２２日です。）<br />\r\n<br />\r\n【定休日】毎週火曜日、第２・３水曜日　<br />\r\n（定休日以外にもシフト制の休みがあります。）</td>\n              </tr>\n                                      <tr>\n                <th class=\"bl_table__std_hd__mid\">休暇</th>\n                <td>有給休暇、結婚休暇、産前産後休暇、出生時育児休暇、忌引休暇、法要休暇、傷病介護休暇ほか</td>\n              </tr>\n                                      <tr>\n                <th class=\"bl_table__std_hd__mid\">保険</th>\n                <td>健康保険、厚生年金、雇用保険、労災保険</td>\n              </tr>\n                                      <tr>\n                <th class=\"bl_table__std_hd__mid\">福利厚生</th>\n                <td>通信教育受講補助、車両購入援助制度、退職金、財形貯蓄、持株制度、慶弔金、借上げ寮制度　</td>\n              </tr>\n                                      <tr>\n                <th class=\"bl_table__std_hd__mid\">採用実績校</th>\n                <td>群馬自動車大学校、太田自動車大学校、高崎自動車整備大学校、太田産業技術専門校、埼玉自動車大学校、関東工業自動車大学校、高崎産業技術専門校　　</td>\n              </tr>\n                        </tbody>\n          </table>\n        </section>\n              </div>\n          </div>\n  </div>\n  </div>\n  <!--#include virtual=\"/dealer/dairi/_inc/_contactBlock.html\" -->\n  <!-- /.bl_contactBlock -->\n\n  <!--#include virtual=\"/dealer/dairi/_inc/_footer.html\" -->\n\n  <!-- YTM -->\n  <!-- End YTM -->\n  <section class=\"bl_contactBlock ly_bgLightBlue\" id=\"contact\">\n  <div class=\"ly_body\">\n    <h2 class=\"bl_contactBlock_title\">お問い合わせ</h2>\n    <ul class=\"bl_contactBlock_list cf\">\n                  <li><a href=\"https://form.suzuki.co.jp/contact/buycar/30316\" target=\"_blank\"><span class=\"bl_contactBlock_list_inner\"><i class=\"el_icon02 el_icon02__soudan\"></i><span class=\"bl_contactBlock_txt el_icon el_icon__blank\">購入相談</span></span></a></li>\n                