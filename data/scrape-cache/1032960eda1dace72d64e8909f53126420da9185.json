>\n                      <input\n                        type=\"text\"\n                        name=\"comname_r\"\n                        id=\"comname_r\"\n                        value=\"\"\n                        placeholder=\"○○株式会社\"\n                        class=\"required\"\n                      />\n                      <label\n                        id=\"comname_r-error\"\n                        for=\"comname_r\"\n                        class=\"error red\"\n                      ></label>\n                    </td>\n                  </tr>\n                  <tr>\n                    <th><label for=\"comname2\">部署名</label></th>\n                    <td>\n                      <input\n                        type=\"text\"\n                        name=\"comname2\"\n                        id=\"comname2\"\n                        value=\"\"\n                        placeholder=\"○○部署\"\n                      />\n                      <label\n                        id=\"comname-error\"\n                        for=\"comname2\"\n                        class=\"error red\"\n                      ></label>\n                    </td>\n                  </tr>\n                  <tr>\n                    <th>\n                      <label for=\"name1_r\">お名前</label>\n                      <span class=\"red\">※</span>\n                    </th>\n                    <td>\n                      <input\n                        type=\"text\"\n                        name=\"name1_r\"\n                        id=\"name1_r\"\n                        value=\"\"\n                        placeholder=\"山田 太郎\"\n                        class=\"required\"\n                      />\n                    </td>\n                  </tr>\n                  <tr>\n                    <th>\n                      <label for=\"tel\">電話番号</label>\n                      <span class=\"red\">※</span>\n                    </th>\n                    <td>\n                      <input\n   