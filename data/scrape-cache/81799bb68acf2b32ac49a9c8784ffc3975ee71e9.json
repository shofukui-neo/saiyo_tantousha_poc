>\n\t\t\t岩手県\t\t</option>\n\t\t\t<option value=\"宮城県\" >\n\t\t\t宮城県\t\t</option>\n\t\t\t<option value=\"秋田県\" >\n\t\t\t秋田県\t\t</option>\n\t\t\t<option value=\"山形県\" >\n\t\t\t山形県\t\t</option>\n\t\t\t<option value=\"福島県\" >\n\t\t\t福島県\t\t</option>\n\t\t\t<option value=\"茨城県\" >\n\t\t\t茨城県\t\t</option>\n\t\t\t<option value=\"栃木県\" >\n\t\t\t栃木県\t\t</option>\n\t\t\t<option value=\"群馬県\" >\n\t\t\t群馬県\t\t</option>\n\t\t\t<option value=\"埼玉県\" >\n\t\t\t埼玉県\t\t</option>\n\t\t\t<option value=\"千葉県\" >\n\t\t\t千葉県\t\t</option>\n\t\t\t<option value=\"東京都\" >\n\t\t\t東京都\t\t</option>\n\t\t\t<option value=\"神奈川県\" >\n\t\t\t神奈川県\t\t</option>\n\t\t\t<option value=\"新潟県\" >\n\t\t\t新潟県\t\t</option>\n\t\t\t<option value=\"富山県\" >\n\t\t\t富山県\t\t</option>\n\t\t\t<option value=\"石川県\" >\n\t\t\t石川県\t\t</option>\n\t\t\t<option value=\"福井県\" >\n\t\t\t福井県\t\t</option>\n\t\t\t<option value=\"山梨県\" >\n\t\t\t山梨県\t\t</option>\n\t\t\t<option value=\"長野県\" >\n\t\t\t長野県\t\t</option>\n\t\t\t<option value=\"岐阜県\" >\n\t\t\t岐阜県\t\t</option>\n\t\t\t<option value=\"静岡県\" >\n\t\t\t静岡県\t\t</option>\n\t\t\t<option value=\"愛知県\" >\n\t\t\t愛知県\t\t</option>\n\t\t\t<option value=\"三重県\" >\n\t\t\t三重県\t\t</option>\n\t\t\t<option value=\"滋賀県\" >\n\t\t\t滋賀県\t\t</option>\n\t\t\t<option value=\"京都府\" >\n\t\t\t京都府\t\t</option>\n\t\t\t<option value=\"大阪府\" >\n\t\t\t大阪府\t\t</option>\n\t\t\t<option value=\"兵庫県\" >\n\t\t\t兵庫県\t\t</option>\n\t\t\t<option value=\"奈良県\" >\n\t\t\t奈良県\t\t</option>\n\t\t\t<option value=\"和歌山県\" >\n\t\t\t和歌山県\t\t</option>\n\t\t\t<option value=\"鳥取県\" >\n\t\t\t鳥取県\t\t</option>\n\t\t\t<option value=\"島根県\" >\n\t\t\t島根県\t\t</option>\n\t\t\t<option value=\"岡山県\" >\n\t\t\t岡山県\t\t</option>\n\t\t\t<option value=\"広島県\" >\n\t\t\t広島県\t\t</option>\n\t\t\t<option value=\"山口県\" >\n\t\t\t山口県\t\t</option>\n\t\t\t<option value=\"徳島県\" >\n\t\t\t徳島県\t\t</option>\n\t\t\t<option value=\"香川県\" >\n\t\t\t香川県\t\t</option>\n\t\t\t<option value=\"愛媛県\" >\n\t\t\t愛媛県\t\t</option>\n\t\t\t<option value=\"高知県\" >\n\t\t\t高知県\t\t</option>\n\t\t\t<option value=\"福岡県\" >\n\t\t\t福岡県\t\t</option>\n\t\t\t<option value=\"佐賀県\" >\n\t\t\t佐賀県\t\t</option>\n\t\t\t<option value=\"長崎県\" >\n\t\t\t長崎県\t\t</option>\n\t\t\t<option value=\"熊本県\" >\n\t\t\t熊本県\t\t</option>\n\t\t\t<option value=\"大分県\" >\n\t\t\t大分県\t\t</option>\n\t\t\t<option value=\"宮崎県\" >\n\t\t\t宮崎県\t\t</option>\n\t\t\t<option value=\"鹿児島県\" >\n\t\t\t鹿児島県\t\t</option>\n\t\t\t<option value=\"沖縄県\" >\n\t\t\t沖縄県\t\t</option>\n\t</select>\n</div>\r\n<div class=\"errordiv\"></div></dd>\r\n</dl>\r\n<dl>\r\n \t<dt>市区町村・番地</dt>\r\n \t<dd>\r\n<div class=\"inputArea\">\n<input type=\"text\" name=\"addr\" id=\"addr\" class=\"chkrequired\" size=\"60\" value=\"\" placeholder=\"岡山市北区本町6-36\" />\n</div>\r\n<div class=\"errordiv\"></div></dd>\r\n</dl>\r\n<dl>\r\n \t<dt>建物名・部屋番号</dt>\r\n \t<dd>\r\n<div class=\"inputArea\">\n<input type=\"text\" name=\"contactAddress3\" id=\"contactAddress3\" size=\"60\" value=\"\" placeholder=\"第一セントラルビル1F\" />\n</div>\r\n<div class=\"errordiv\"></div></dd>\r\n</dl>\r\n</div>\r\n<!--//innerTable--></dd>\r\n</dl>\r\n<dl class=\"required\">\r\n \t<dt>電話番号</dt>\r\n \t<dd>\r\n<div class=\"inputArea\">\r\n\r\n\n<span class=\"mwform-tel-field\">\n\t<input type=\"text\" name=\"contactTel[data][0]\" size=\"6\" maxlength=\"5\" value=\"\" data-conv-half-alphanumeric=\"true\" />\n\t-\t<input type=\"text\" name=\"contactTel[data][1]\" size=\"5\" maxlength=\"4\" value=\"\" data-conv-half-alphanumeric=\"true\" />\n\t-\t<input type=\"text\" name=\"contactTel[data][2]\" size=\"5\" maxlength=\"4\" value=\"\" data-conv-half-alphanumeric=\"true\" />\n</span>\n\n<input type=\"hidden\" name=\"contactTel[separator]\" value=\"-\" />\n\r\n<p class=\"note\">※半角数字のみ</p>\r\n\r\n</div>\r\n<div class=\"errordiv\"></div></dd>\r\n</dl>\r\n<dl class=\"required\">\r\n \t<dt>メールアドレス</dt>\r\n \t<dd>\r\n<div class=\"inputArea\">\n<input type=\"email\" name=\"contactMail1\" id=\"contactMail1\" size=\"60\" value=\"\" placeholder=\"info@capla.co.jp\" data-conv-half-alphanumeric=\"true\"/>\n</div>\r\n<p class=\"note\">※「@capla.co.jp」からのメールを受信できるよう、あらかじめドメイン設定を解除していただくか、\r\nまたは弊社ドメイン「capla.co.jp」を 受信リストへの追加をお願いいたします。</p>\r\n\r\n<div class=\"errordiv\"></div></dd>\r\n</dl>\r\n<dl class=\"chkRq required\">\r\n \t<dt>最終学歴</dt>\r\n \t<dd>\r\n<div class=\"inputArea finalEducationInput\">\r\n<ul>\r\n \t<li class=\"select\">\n<select name=\"finalEducation1\" id=\"finalEducation1\" >\n\t\t\t<option value=\"\" selected='selected'>\n\t\t\t選択してください\t\t</option>\n\t\t\t<option value=\"大学院（MBA含む）\" >\n\t\t\t大学院（MBA含む）\t\t</option>\n\t\t\t<option value=\"大学\" >\n\t\t\t大学\t\t</option>\n\t\t\t<option value=\"短期大学\" >\n\t\t\t短期大学\t\t</option>\n\t\t\t<option value=\"専門学校\" >\n\t\t\t専門学校\t\t</option>\n\t\t\t<option value=\"高等専門学校\" >\n\t\t\t高等専門学校\t\t</option>\n\t\t\t<option value=\"高等学校\" >\n\t\t\t高等学校\t\t</option>\n\t\t\t<option value=\"中学校\" >\n\t\t\t中学校\t\t</option>\n\t\t\t<option value=\"その他\" >\n\t\t\tその他\t\t</option>\n\t</select>\n</li>\r\n \t<li class=\"kubun\">最終学歴区分\r\n\n<select name=\"finalEducation2\" id=\"finalEducation2\" >\n\t\t\t<option value=\"\" selected='selected'>\n\t\t\t選択してください\t\t</option>\n\t\t\t<option value=\"卒業\" >\n\t\t\t卒業\t\t</option>\n\t\t\t<option value=\"中退\" >\n\t\t\t中退\t\t</option>\n\t</select>\n</li>\r\n</ul>\r\n</div>\r\n<div class=\"errordiv\"></div></dd>\r\n</dl>\r\n</div>\r\n<!--//formTable-->\r\n\r\n</section><!--//formSection-->\r\n\r\n<section id=\"jobHistoryInputArea\" class=\"formSection\">\r\n<h3 class=\"h3TTL chkRq\">職歴情報</h3>\r\n<div class=\"formTable\">\r\n<dl class=\"chkRq required\">\r\n \t<dt>就業状況</dt>\r\n \t<dd>\r\n<div class=\"inputArea radioList\">\t<span class=\"mwform-radio-field horizontal-item\">\n\t\t<label for=\"employmentStatusInput-1\">\n\t\t\t<input type=\"radio\" name=\"employmentStatusInput\" value=\"現職中\" id=\"employmentStatusInput-1\" />\n\t\t\t<span class=\"mwform-radio-field-text\">現職中</span>\n\t\t</label>\n\t</span>\n\t<span class=\"mwform-radio-field horizontal-item\">\n\t\t<label for=\"employmentStatusInput-2\">\n\t\t\t<input type=\"radio\" name=\"employmentStatusInput\" value=\"離職中\" id=\"employmentStatusInput-2\" />\n\t\t\t<span class=\"mwform-radio-field-text\">離職中</span>\n\t\t</label>\n\t</span>\n\n<input type=\"hidden\" name=\"__children[employmentStatusInput][]\" value=\"{&quot;\\u73fe\\u8077\\u4e2d&quot;:&quot;\\u73fe\\u8077\\u4e2d&quot;,&quot;\\u96e2\\u8077\\u4e2d&quot;:&quot;\\u96e2\\u8077\\u4e2d&quot;}\" />\n</div>\r\n<div class=\"errordiv\"></div></dd>\r\n</dl>\r\n<dl class=\"chkRq required\">\r\n \t<dt>現職または直近の会社名</dt>\r\n \t<dd>\r\n<div class=\"inputArea\">\n<input type=\"text\" name=\"latestCompany\" id=\"latestCompany\" size=\"60\" value=\"\" placeholder=\"株式会社キャリアプランニング\" />\n</div>\r\n<div class=\"errordiv\"></div></dd>\r\n</dl>\r\n<dl class=\"chkRq required\">\r\n \t<dt>現職または直近の職務内容</dt>\r\n \t<dd>\r\n<div class=\"inputArea\">\n<textarea name=\"latestDuties\" id=\"latestDuties\" cols=\"50\" rows=\"5\" placeholder=\"法人営業職として、15社を担当。 顧客対応、見積書作成などを行う。\"></textarea>\n</div>\r\n<div class=\"errordiv\"></div></dd>\r\n</dl>\r\n<dl class=\"chkRq required\">\r\n \t<dt>現職または直近の雇用形態</dt>\r\n \t<dd>\r\n<div class=\"inputArea\">\n<select name=\"employmentStatusSelect\" id=\"employmentStatusSelect\" >\n\t\t\t<option value=\"\" selected='selected'>\n\t\t\t選択してください\t\t</option>\n\t\t\t<option value=\"正社員\" >\n\t\t\t正社員\t\t</option>\n\t\t\t<option value=\"契約社員\" >\n\t\t\t契約社員\t\t</option>\n\t\t\t<option value=\"派遣社員\" >\n\t\t\t派遣社員\t\t</option>\n\t\t\t<option value=\"その他\" >\n\t\t\tその他\t\t</option>\n\t</select>\n</div>\r\n<div class=\"errordiv\"></div></dd>\r\n</dl>\r\n<dl class=\"chkRq required\">\r\n \t<dt>現職または直近の勤務年数</dt>\r\n \t<dd>\r\n<div class=\"inputArea\">\n<input type=\"text\" name=\"yearsWorked\" id=\"yearsWorked\" class=\"yearInput\" size=\"60\" value=\"\" placeholder=\"4\" data-conv-half-alphanumeric=\"true\"/>\n年</div>\r\n<div class=\"errordiv\"></div></dd>\r\n</dl>\r\n<dl class=\"chkRq required\">\r\n \t<dt>上記以外の職歴</dt>\r\n \t<dd>\r\n<p class=\"note\">職歴が1社の方は、なしと入力してください。</p>\r\n\r\n<div class=\"inputArea\">\n<textarea name=\"otherDuties\" id=\"otherDuties\" cols=\"50\" rows=\"5\" placeholder=\"20××年×月～20××年×月まで、株式会社キャプラにて営業職として勤務。\"></textarea>\n</div>\r\n<div class=\"errordiv\"></div></dd>\r\n</dl>\r\n</div>\r\n<!--//formTable-->\r\n\r\n</section><!--//formSection-->\r\n\r\n<section class=\"formSection\">\r\n<h3 class=\"h3TTL\">ご質問・ご要望など</h3>\r\n<div class=\"formTable\">\r\n<dl>\r\n \t<dt>ご質問・ご要望</dt>\r\n \t<dd>\r\n<p class=\"note\">正式な応募前に「会社説明・業務内容説明」をご希望の場合は、その旨と希望日時があれば、希望日時を入力してください。</p>\r\n\r\n<div class=\"inputArea\">\n<textarea name=\"otherComment\" id=\"otherComment\" cols=\"50\" rows=\"5\" placeholder=\"・応募前に会社説明希望 ・メール連絡希望 ・●月以降、入社可能\"></textarea>\n</div>\r\n<div class=\"errordiv\"></div></dd>\r\n</dl>\r\n</div>\r\n<!--//formTable-->\r\n\r\n</section><!--//formSection-->\r\n<div class=\"agreePrivacyBox\">\r\n<dl>\r\n \t<dt>個人情報の取り扱いについて</dt>\r\n \t<dd class=\"privacyPolicy\">\r\n<div class=\"inner\">\r\n\r\n個人情報の取り扱い等に関しまして下記事項をご確認ください。同意いただける場合、「同意する」ボタンをチェックしてください。ご同意いただけない場合はエントリーいただくことが出来ませんのでご了承ください。\r\n<div class=\"termsSection\">\r\n<div class=\"privacySection\">\r\n<div class=\"usePrivacyGuide\">\r\n<dl>\r\n \t<dt>【個人情報の利用目的について】</dt>\r\n \t<dd>当社は、採用及びそれに関連・付随する業務遂行の為に個人情報を収集し、以下の目的達成に必要な範囲内で利用いたします。\r\n<ul class=\"circleList\">\r\n \t<li>1.当社の採用活動に関する、各種情報（セミナー・イベントやホームページの案内等）の提供や連絡</li>\r\n \t<li>2.当社の採用選考に関する業務</li>\r\n \t<li>3.法令等に定める手続きの実施、その他会社の業務遂行に必要な範囲での利用</li>\r\n</ul>\r\n</dd>\r\n</dl>\r\n<dl>\r\n \t<dt>【個人情報の第三者提供について】</dt>\r\n \t<dd>当社は、ご本人の同意がある場合を除いて、個人情報を第三者へ提供いたしません。ただし、以下に該当する場合を除きます。\r\n<ul class=\"circleList\">\r\n \t<li>1.法令に基づく場合</li>\r\n \t<li>2.人の生命、身体または財産の保護の為に必要である場合であって、本人の同意を得ることが困難な場合</li>\r\n \t<li>3.公衆衛生の向上又は児童の健全な育成の推進のために特に必要がある場合であって、本人の同意を得ることが困難である場合</li>\r\n \t<li>4.国の機関若しくは地方公共団体又はその委託を受けた者が法令の定める事務を遂行することに対して協力する必要がある場合であって、ご本人の同意を得ることにより当該事務の遂行に支障を及ぼすおそれがある場合</li>\r\n \t<li>5.収集・利用目的の達成に必要な範囲で、個人情報の取り扱いを委託する場合</li>\r\n \t<li>6.合併その他の事由による事業の承継にともない、個人情報を提供する場合</li>\r\n</ul>\r\n</dd>\r\n</dl>\r\n<dl>\r\n \t<dt>【個人情報の共同利用について】</dt>\r\n \t<dd>当社は、下記2の目的達成のために必要な場合に限り、特例子会社である株式会社キャプラ・ウィッシュと共同で個人情報を利用する場合があります。\r\n<ul class=\"circleList\">\r\n \t<li>1.利用する情報\r\n履歴書・職務経歴書・キャリア採用エントリーフォームに記載された情報</li>\r\n \t<li>2.個人情報の利用目的\r\n株式会社キャプラ・ウィッシュの採用選考に関する業務</li>\r\n \t<li>3.個人情報の管理責任者\r\n株式会社キャプラ・ウィッシュ（岡山市北区東古松3丁目12-2 両備グレースマンション医大西1階）</li>\r\n \t<li>　代表取締役社長　槙野 博通</li>\r\n</ul>\r\n</dd>\r\n</dl>\r\n<dl>\r\n \t<dt>【個人情報の委託について】</dt>\r\n \t<dd>当社は、情報処理やメンテナンス等、業務上の必要性により、個人情報を外部に委託する場合があります。委託先については、個人情報取扱いの安全性確認、秘密保持契約の締結等、適切な管理を行っています。</dd>\r\n</dl>\r\n<dl>\r\n \t<dt>【本人が容易に知覚できない方法によって個人情報を取得する場合について】</dt>\r\n \t<dd>当社のサイトでは利便性の向上、広告の配信、および統計データの取得のため、閲覧されたウェブページ等のデータ（以下、“閲覧履歴”といいます）を、クッキー（Cookie）等の技術を利用して取得しています。\r\n個人が特定されるような情報は含んでおりませんが、当社が保有する情報との照合により個人を特定した場合には、上記１に定める利用目的の範囲で利用する場合があります。当社におけるクッキーの取扱いの詳細は<a href=\"https://www.capla.co.jp/privacypolicy/#Cookie\">こちら</a>をご参照ください。</dd>\r\n\r\n</dl>\r\n<dl>\r\n \t<dt>【その他】</dt>\r\n \t<dd>\r\n<ul class=\"circleList\">\r\n \t<li>1.個人情報のうち、人事、評価項目については、利用目的の通知、開示、内容の訂正、追加又は削除、利用の停止、消去及び第三者への提供の停止並びに第三者提供記録の開示（以下、“開示等”という）の対象にはなりません</li>\r\n \t<li>2.個人情報の提出においてお預かりしました媒体は返却いたしません。予めご了承ください</li>\r\n \t<li>3.個人情報に関する開示等については、下記問合せ窓口までお申し出ください</li>\r\n \t<li>4.個人情報のご提出はあくまで任意ですが、情報を提出頂けない場合、採用選考に支障を来たす場合があります</li>\r\n</ul>\r\n</dd>\r\n</dl>\r\n</div>\r\n<!--//usePrivacyGuide-->\r\n\r\n</div>\r\n<section class=\"privacySection\">\r\n<div class=\"grayBgBox madoguchi\">\r\n<h4 class=\"h4TTL\">【問い合わせ窓口】</h4>\r\n住　　所：〒700-0901　 岡山市北区本町6番36号　 第一セントラルビル1階<br>\r\n\r\n宛　　先：株式会社キャリアプランニング　個人情報保護管理者　総務部長　宛<br>\r\n\r\n電話番号：086-235-9800<br>\r\n\r\nE-MAIL：privacy@capla.co.jp\r\n\r\n</div>\r\n</section></div>\r\n<!--//termsSection-->\r\n\r\n</div></dd>\r\n \t<dd class=\"agreeCheck\"><label>\n\t<span class=\"mwform-checkbox-field horizontal-item\">\n\t\t<label for=\"privacyAgreeCheck-1\">\n\t\t\t<input type=\"checkbox\" name=\"privacyAgreeCheck[data][]\" value=\"個人情報の取扱いについて同意する\" id=\"privacyAgreeCheck-1\" />\n\t\t\t<span class=\"mwform-checkbox-field-text\">個人情報の取扱いについて同意する</span>\n\t\t</label>\n\t</span>\n\n<input type=\"hidden\" name=\"privacyAgreeCheck[separator]\" value=\",\" />\n\n<input type=\"hidden\" name=\"__children[privacyAgreeCheck][]\" value=\"{&quot;\\u500b\\u4eba\\u60c5\\u5831\\u306e\\u53d6\\u6271\\u3044\\u306b\\u3064\\u3044\\u3066\\u540c\\u610f\\u3059\\u308b&quot;:&quot;\\u500b\\u4eba\\u60c5\\u5831\\u306e\\u53d6\\u6271\\u3044\\u306b\\u3064\\u3044\\u3066\\u540c\\u610f\\u3059\\u308b&quot;}\" />\n<em>必須</em></label>\r\n<div class=\"errordiv\"></div></dd>\r\n</dl>\r\n</div>\r\n<!--//agreePrivacyBox-->\r\n<div class=\"bottomBtnArea\">\r\n<ul>\r\n \t<li class=\"btnEntryRed\">\n<button type=\"submit\" name=\"submitConfirm\" value=\"confirm\" >入力内容の確認へ進む</button>\n</li>\r\n \t<li class=\"btnBack\"></li>\r\n</ul>\r\n</div><input type=\"hidden\" id=\"mw_wp_form_token\" name=\"mw_wp_form_token\" value=\"6f29d5f23f\" /><input type=\"hidden\" name=\"_wp_http_referer\" value=\"/recruit/contact/\" /><input type=\"hidden\" name=\"mw-wp-form-form-id\" value=\"317\" /><input type=\"hidden\" name=\"mw-wp-form-form-verify-token\" value=\"bafd648a96eba63498c52d061d52fd4b59f45a82\" /></form>\n\t\t\t\t<!-- end .mw_wp_form --></div>\n            \r\n        \r\n\t\t<!--//#formContents-->\r\n\t\t\r\n\t\t\t\t\r\n    </section>\r\n\r\n\t\t\t\r\n</main>\r\n<!--//main-->\r\n<footer id=\"footer\">\n\t\t<div class=\"contactFoot\">\n        <img src=\"https://www.capla.co.jp/wp-content/themes/capla/img/common/logo_capla_column.svg\" alt=\"CAREER PLANNING\">\n    </div>\n\t<div class=\"footUnder\">\n        <ul>\n            <li><a href=\"https://www.capla.co.jp/forcompany/yuryo_haken/\">優良派遣事業者行動指針</a></li>\n            <li><a href=\"https://www.capla.co.jp/forcompany/yuryo_syokai/\">職業紹介優良事業者行動指針</a></li>\n            <li><a href=\"https://www.capla.co.jp/disclosure/\">労働者派遣法に基づく情報公開</a></li>\n            <li><a href=\"https://www.capla.co.jp/privacypolicy/\">プライバシーポリシー</a></li>\n        </ul>\n        <div class=\"certificationMarks\">\n            <ul>\n            </ul>\n        </div>\n\t</div>\n\n\t\n    <div class=\"footCopy\">\n        <p>Copyright &copy; CAREER PLANNING Co., Ltd.</p>\n    </div>\n</footer>\n\n<script src='https://www.capla.co.jp/wp-content/plugins/mw-wp-form/js/form.js?ver=5.5.14' id='mw-wp-form-js'></script>\n<script src='https://www.capla.co.jp/wp-content/themes/capla/js/navigation.js?ver=1.0.0' id='capla-navigation-js'></script>\n<script src='https://www.capla.co.jp/wp-includes/js/wp-embed.min.js?ver=5.5.14' id='wp-embed-js'></script>\n<script src=\"https://www.capla.co.jp/wp-content/themes/capla/js/jquery_2.0.3.js\"></script>\n<script src=\"https://www.capla.co.jp/wp-content/themes/capla/js/swiper.min.js\"></script>\n<script src=\"https://www.capla.co.jp/wp-content/themes/capla/js/init.js\"></script>\n<script src=\"https://www.capla.co.jp/wp-content/themes/capla/js/recruit_init.js\"></script>\n<script>\n\t$(window).bind(\"pageshow\", function() {\n\t\tvar chk = $('input[name=historyInputType]:checked').val();\n\t\tchked(chk);\n\t});\n\t$(document).ready(function(){\n\t\tvar chk = $('input[name=historyInputType]:checked').val();\n\t\tchked(chk);\n\n\t});\n\t$('input[name=historyInputType]').on('change', function () {\n\t\tvar chk = $('input[name=historyInputType]:checked').val();\n\t\tchked(chk);\n\t});\n\tfunction chked(chk){\n\t\tif(chk === '経歴をフォームに入力'){\n\t\t\t$('.chkRq').removeClass('hidden');\n\t\t\t$('.chkRq').addClass('required');\n\t\t\t$('.chkRq2').addClass('hidden');\n\t\t\t$('.chkRq2').removeClass('required');\n\t\t}\n\t\tif(chk === '履歴書・職務経歴書を添付'){\n\t\t\t$('.chkRq').addClass('hidden');\n\t\t\t$('.chkRq').removeClass('required');\n\t\t\t$('.chkRq2').removeClass('hidden');\n\t\t\t$('.chkRq2').addClass('required');\n\t\t}\n\t}\n\t$('#historyDocument1').on('change', function () {\n\t\t$('#historyDocument1Fake').val($(this).val());\n\t});\n\t$('#historyDocument2').on('change', function () {\n\t\t$('#historyDocument2Fake').val($(this).val());\n\t});\n\t$(document).ready(function(){\n\t\tvar y = $('[name=birthYear]').val();\n\t\tvar m = $('[name=birthMonth]').val();\n\t\tvar d = $('[name=birthDay]').val();\n\t\tif(y !== '' && m !== '' && d !== ''){\n\t\t\tif(ValidDate(y,m,d)){\n\t\t\t\t$('.birthError').hide();\n\t\t\t\t$('[name=\"submitConfirm\"]').prop(\"disabled\", false);\n\t\t\t}else{\n\t\t\t\t$('.birthError').show();\n\t\t\t\t$('[name=\"submitConfirm\"]').prop(\"disabled\", true);\n\t\t\t}\n\t\t}\n\t});\n\t$('.birth').on('change', function () {\n\t\tvar y = $('[name=birthYear]').val();\n\t\tvar m = $('[name=birthMonth]').val();\n\t\tvar d = $('[name=birthDay]').val();\n\t\tif(y !== '' && m !== '' && d !== ''){\n\t\t\tif(ValidDate(y,m,d)){\n\t\t\t\t$('.birthError').hide();\n\t\t\t\t$('[name=\"submitConfirm\"]').prop(\"disabled\", false);\n\t\t\t}else{\n\t\t\t\t$('.birthError').show();\n\t\t\t\t$('[name=\"submitConfirm\"]').prop(\"disabled\", true);\n\t\t\t}\n\t\t}\n\t});\n\tfunction ValidDate(y,m,d) {\n\t\tdt=new Date(y,m-1,d);\n\t\treturn(dt.getFullYear()==y && dt.getMonth()==m-1 && dt.getDate()==d);\n\t}\n</script>\n<script>\n\t $(\"input\"). keydown(function(e) {\n\t\tif ((e.which && e.which === 13) || (e.keyCode && e.keyCode === 13)) {\n\t\t\treturn false;\n\t\t} else {\n\t\t\treturn true;\n\t\t}\n\t});\n</script>\n<!-- Yahoo Tag Manager -->\n<script type=\"text/javascript\">\n  (function () {\n    var tagjs = document.createElement(\"script\");\n    var s = document.getElementsByTagName(\"script\")[0];\n    tagjs.async = true;\n    tagjs.src = \"//s.yjtag.jp/tag.js#site=srRQDoP\";\n    s.parentNode.insertBefore(tagjs, s);\n  }());\n</script>\n<noscript>\n  <iframe src=\"//b.yjtag.jp/iframe?c=srRQDoP\" width=\"1\" height=\"1\" frameborder=\"0\" scrolling=\"no\" marginheight=\"0\" marginwidth=\"0\"></iframe>\n</noscript>\n<!-- End Yahoo Tag Manager -->\n</body>\n</html>\n","finalUrl":"https://www.capla.co.jp/recruit/contact/","rendered":false,"_cachedAt":"2026-06-23T23:20:23.767Z"}