html\">新卒採用募集要項<i class=\"fa fa-angle-right\" aria-hidden=\"true\"></i></a></li>\n\t\t\t\t\t\t<li><a href=\"career.html\">キャリア採用募集要項<i class=\"fa fa-angle-right\" aria-hidden=\"true\"></i></a></li>\n\t\t\t\t\t\t<li><a href=\"recruit/relation.html\">関連会社員募集要項<i class=\"fa fa-angle-right\" aria-hidden=\"true\"></i></a></li>\n\t\t\t\t\t</ul>\n\t\t\t\t</li>\n\t\t\t\t<li class=\"sp_only\"><a class=\"drawer-menu-item\" href=\"https://www.mnm.co.jp/\">コーポレイトサイト<i class=\"fa fa-angle-right\" aria-hidden=\"true\"></i></a></li>\n\t\t\t</ul>\n\t\t</nav>\n\t</header>\n\t<div id=\"next_main\" role=\"main\">\n\n\t<h2>募集要項</h2>\n\t\t<div id=\"recruit\">\n\t\t\t<!--<p id=\"visual\"><img src=\"recruit/images/image02.jpg\" alt=\"メインビジュアル\"></p>-->\n\t\t\t<div id=\"recruit_bg\">\n\t\t<div class=\"container\">\n\t\t\t<ul class=\"tabmenu\">\n\t\t\t\t<li><a href=\"recruit/index.html\">人事担当からのメッセージ</a></li>\n\t\t\t\t<li class=\"active second\"><a href=\"shinsotsu.html\">新卒採用募集要項</a></li>\n\t\t\t\t<li><a href=\"career.html\">キャリア採用募集要項</a></li>\n\t\t\t\t<li class=\"second\"><a href=\"recruit/relation.html\">関連会社募集要項</a></li>\n\t\t\t</ul>\n\t\t\t<div id=\"back_bg\">\n\n\t\t\t\t<dl class=\"first\">\n\t\t\t\t\t<dt>募集職種<br class=\"desc\"><span></span>職務内容</dt>\n\t\t\t\t\t<dd>技術系 ⇒　機械設計・開発\n\t\t\t\t\t<br>\n\t\t\t\t\t&emsp;&emsp;&emsp; ⇒　制御設計・プログラム設計<br>\n                    &emsp;&emsp;&emsp; ⇒　生産技術<br>\n\t\t\t\t\t&emsp;&emsp;&emsp; ⇒　生産管理<br>\n                    &emsp;&emsp;&emsp; ⇒　品質管理<br>\n                    事務系 ⇒　総務\n\t\t\t\t\t<br>\n\t\t\t\t\t&emsp;&emsp;&emsp; ⇒　経理<br>\n                    &emsp;&emsp;&emsp; ⇒　営業<br>\n                    &emsp;&emsp;&emsp; ⇒　購買<br>\n\t\t\t\t\t</dd>\n                    \n\t\t\t\t</dl>\n                \n\t\t\t\t<dl>\n\t\t\t\t\t<dt>募集学科</dt>\n\t\t\t\t\t<dd><span class=\"left_m\">〔技術系〕</span><br>\n\t\t\t\t\t機械・電気・電子・金属材料・情報系の学科、または類似の学科を専攻されている方<br>\n                    <span class=\"left_m\">〔事務系〕</span><br>\n\t\t\t\t\t特になし<br>\n                    </dd>\n                    \n\t\t\t\t</dl>\n\t\t\t\t<dl>\n\t\t\t\t\t<dt>応募資格</dt>\n\t\t\t\t\t<dd>リクナビよりエントリーをお願いします。<br>\n\t\t\t\t\t※画面下部のリンクをクリック。</dd>\n\t\t\t\t</dl>\n\t\t\t\t<dl>\n\t\t\t\t\t<dt>給&emsp;&emsp;与</dt>\n\t\t\t\t\t<dd>院卒 ： 月給&emsp;267,000円～<br>\n\t\t\t\t\t\t大卒 ： 月給&emsp;252,000円～</dd>\n\t\t\t\t</dl>\n\t\t\t\t<dl>\n\t\t\t\t\t<dt>諸 手 当</dt>\n\t\t\t\t\t<dd>残業、休日、通勤、住宅、役職、営業職、食事 等</dd>\n\t\t\t\t</dl>\n\t\t\t\t<dl>\n\t\t\t\t\t<dt>昇<span class=\"space2\"></span>給<br class=\"desc\"><br class=\"desc\"><span></span>賞<span class=\"space2\"></span>与</dt>\n\t\t\t\t\t<dd>年1回（4月）<br><br class=\"desc\">\n\t\t\t\t\t年2回（7月、12月）</dd>\n\t\t\t\t</dl>\n\t\t\t\t<dl>\n\t\t\t\t\t<dt>勤　務　地</dt>\n\t\t\t\t\t<dd>本社（長崎）又は東京・大阪・千葉　　※長崎地区はマイカー通勤可</dd>\n\t\t\t\t</dl>\n\t\t\t\t<dl>\n\t\t\t\t\t<dt>勤務時間</dt>\n\t\t\t\t\t<dd>8：30～17：30&nbsp;（8時間/日）<br>\n\t\t\t\t\t\t</dd>\n\t\t\t\t</dl>\n\t\t\t\t<dl>\n\t\t\t\t\t<dt>休日・休暇</dt>\n\t\t\t\t\t<dd>年間休日日数124日（土・日・祭日・GW・夏季・年末年始等）<br>\n\t\t\t\t\t年次有給休暇、結婚休暇、出産休暇、忌引休暇、介護休暇　永年勤続リフレッシュ休暇 等</dd>\n\t\t\t\t</dl>\n\t\t\t\t<dl>\n\t\t\t\t\t<dt>保&emsp;&emsp;険</dt>\n\t\t\t\t\t<dd>健康保険、厚生年金保険、雇用保険、労災保険</dd>\n\t\t\t\t</dl>\n\t\t\t\t<dl>\n\t\t\t\t\t<dt>福利厚生</dt>\n\t\t\t\t\t<dd>資格取得費用負担、書籍購入補助、食堂、寮・社宅、作業服・制服貸与、<br>\n\t\t\t\t\t部活動（ソフト部・テニス部）、個人選択福利厚生（リソルライフサポート）、<br class=\"desc\">\n\t\t\t\t\t三菱自動車購入時の割引、冠婚葬祭施設の割引 等</dd>\n\t\t\t\t</dl>\n\t\t\t\t<dl>\n\t\t\t\t\t<dt>選考方法</dt>\n\t\t\t\t\t<dd>面接、適性検査</dd>\n\t\t\t\t</dl>\n\t\t\t\t<dl class=\"last\">\n\t\t\t\t\t<dt>応募に関する<br class=\"desc\">お問い合わせ</dt>\n\t\t\t\t\t<dd>〒851-0301　長崎市深堀町1-2-1<br>\n\t\t\t\t\t総務部総務課　採用担当<br>\n\t\t\t\t\t（TEL）　　095-871-6101</dd>\n\t\t\t\t</dl>\n\t\t\t<h3 class=\"recruit_title\">選考スケジュール（2027年3月卒）</h3>\n\t\t\t<p style=\"margin-top: 20px;\"><img src=\"recruit/images/selection.jpg\" alt=\"選考スケジュール\"></p>\n<br>\n\t\t\t\n\t\t\t<h3 class=\"recruit_title\">会社説明をご希望の方は</h3>\n\t\t\t\t<p id=\"rikunabi\"><a href=\"https://job.rikunabi.com/n/company_jobs/1321692614/?mode=intern\" target=\"_blank\">三菱長崎機工株式会社　インターン＆キャリア</a></p>\n\t\t\t\t<h3 class=\"recruit_title\">選考へのご応募は</h3>\n\t\t\t<p id=\"rikunabi\"><a href=\"https://job.rikunabi.com/n/company_jobs/1321692614/?mode=selection&vos=oforhpcp0864\" target=\"_blank\">三菱長崎機工株式会社　新卒採用</a></p>\n\n\t\t</div><!-- #back_bg_end -->\n\t\t</div><!-- .container_end -->\n\t\t</div><!-- #recruit_bg_end -->\n\t\t</div><!-- #recruit_end -->\n\n\t</div><!-- #next_main_end -->\n\n\t\t<footer id=\"footer\">\n\t\t\t<div class=\"container\">\n\t\t\t\t<div id=\"footer_menu\">\n\t\t\t\t\t<div class=\"section\">\n\t\t\t\t\t\t<dl class=\"desc\">\n\t\t\t\t\t\t\t<dt><a href=\"corporate/index.html\">会社紹介</a></dt>\n\t\t\t\t\t\t\t<dd>\n\t\t\t\t\t\t\t<a href=\"corporate/index.html\">・製品内容</a>\n\t\t\t\t\t\t\t<a href=\"corporate/overview.html\">・会社概要</a>\n\t\t\t\t\t\t\t<a href=\"https://www.mnm.co.jp/news/index.html\">・ニュース</a>\n\t\t\t\t\t\t\t<a href=\"corporate/access.html\">・アクセス</a>\n\t\t\t\t\t\t\t</dd>\n\t\t\t\t\t\t</dl>\n\t\t\t\t\t</div>\n\n\t\t\t\t\t<div class=\"section\">\n\t\t\t\t\t\t<dl id=\"tit\" class=\"desc\">\n\t\t\t\t\t\t\t<dt><a href=\"education/index.html\">社員教育</a></dt>\n\t\t\t\t\t\t\t<dt><a href=\"member/index.html\">社員紹介</a></dt>\n\t\t\t\t\t\t</dl>\n\t\t\t\t\t</div>\n\n\t\t\t\t\t<div class=\"section\">\n\t\t\t\t\t\t<dl class=\"desc\">\n\t\t\t\t\t\t\t<dt><a href=\"recruit/index.html\">募集要項</a></dt>\n\t\t\t\t\t\t\t<dd>\n\t\t\t\t\t\t\t<a href=\"recruit/index.html\">・人事担当メッセージ</a>\n\t\t\t\t\t\t\t<a href=\"shinsotsu.html\">・新卒採用募集要項</a>\n\t\t\t\t\t\t\t<a href=\"career.html\">・キャリア募集要項</a>\n\t\t\t\t\t\t\t<a href=\"recruit/relation.html\">・関連会社募集要項</a>\n\t\t\t\t\t\t\t</dd>\n\t\t\t\t\t\t</dl>\n\t\t\t\t\t</div>\n\n\t\t\t\t\t<div class=\"section\" id=\"last\">\n\t\t\t\t\t\t<dl id=\"tit\">\n\t\t\t\t\t\t\t<dt><a href=\"index.html\">採用情報ホーム</a></dt>\n\t\t\t\t\t\t\t<dd><a href=\"rule/index.html\">ご利用規約</a></dd>\n\t\t\t\t\t\t\t<dd><a href=\"privacy/index.html\">個人情報保護方針</a></dd>\n\t\t\t\t\t\t\t<dd><a href=\"https://www.mnm.co.jp/\">コーポレイトサイト</a></dd>\n\