{"url":"https://jsg-system.com/contact/","html":"<!DOCTYPE html>\n<html lang=\"ja\" prefix=\"og: http://ogp.me/ns#\">\n<head>\n<!-- Google tag (gtag.js) -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-JKY286QSC5\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'G-JKY286QSC5');\n</script>\n\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width\">\n<meta name=\"format-detection\" content=\"telephone=no\">\n\n<link rel=\"icon\" href=\"https://jsg-system.com/wordpress/wp-content/themes/nkh/common/images/favicon.ico\" />\n<link rel=\"apple-touch-icon\" href=\"webclip.png\" />\n\n<title>お問い合せ｜日本海警備保障株式会社</title>\n<meta name=\"description\" content=\"日本海警備保障のお問い合せフォームです。警備に関するご相談やお見積もり依頼などお気軽にお問い合わせください。\" />\n    \n<!-- OGP -->\n<meta property=\"og:url\" content=\"https://jsg-system.com/contact/\" />\n<meta property=\"og:type\" content=\"article\" />\n<meta property=\"og:title\" content=\"お問い合せ｜日本海警備保障株式会社\" />\n<meta property=\"og:description\" content=\"日本海警備保障のお問い合せフォームです。警備に関するご相談やお見積もり依頼などお気軽にお問い合わせください。\" />\n<meta property=\"og:site_name\" content=\"日本海警備保障株式会社\" />\n<meta property=\"og:image\" content=\"https://jsg-system.com/wordpress/wp-content/themes/nkh/common/images/ogp.png\" />\n\n<link rel=\"stylesheet\" href=\"https://jsg-system.com/wordpress/wp-content/themes/nkh/common/css/reset.css\">\n<link rel=\"stylesheet\" href=\"https://jsg-system.com/wordpress/wp-content/themes/nkh/common/css/design.css\">\n<link rel=\"stylesheet\" href=\"https://jsg-system.com/wordpress/wp-content/themes/nkh/common/css/sub.css\">\n    \n<script src=\"https://ajax.googleapis.com/ajax/libs/jquery/3.1.1/jquery.min.js\"></script>\n<script type=\"text/javascript\" src=\"https://jsg-system.com/wordpress/wp-content/themes/nkh/common/js/common.js\" defer></script>\n\n<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n<link href=\"https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700&family=Noto+Serif+JP:wght@400;500;600;700;900&display=swap\" rel=\"stylesheet\">\n    \n<link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/animate.css/3.6.2/animate.min.css\" />\n<script src=\"https://cdnjs.cloudflare.com/ajax/libs/wow/1.1.2/wow.min.js\"></script>\n    \n<!--[if lt IE 9]>\n<script src=\"common/js/html5shiv.js\"></script>\n<![endif]-->\n\n</head>\n<body class=\"subpage page_contact\">\n\n<header class=\"header\">\n    <h1 class=\"logo\"><a href=\"/\"><img src=\"/wordpress/wp-content/themes/nkh/common/images/logo.svg\" alt=\"日本海警備保障\"></a></h1>\n    <div class=\"header_rightbox\">\n        <nav class=\"header_nav\">\n            <ul>\n                <li class=\"page_index\"><a href=\"/\">HOME</a></li>\n                <li class=\"page_company\"><a href=\"/company/\">企業情報</a></li>\n                <li class=\"header_nav_parent page_service\"><a href=\"javascript: void(0)\">サービス紹介<span></span></a>\n                    <ul class=\"header_nav_child\">\n                        <li><a href=\"/institution/\">施設警備</a></li>\n                        <li><a href=\"/machine/\">機械警備</a></li>\n                        <li><a href=\"/traffic_guidance/\">交通誘導警備</a></li>\n                    </ul>\n                </li>\n                <li class=\"page_info\"><a href=\"/info/\">お知らせ</a></li>\n            </ul>\n        </nav>\n        <a class=\"btn_rock\" href=\"https://jsg-system.com/works/\"><span></span>社員用</a>\n        <a class=\"btn_contact\" href=\"/contact/\"><span></span>お問い合わせ</a>\n        <div class=\"sp_x\"><div class=\"x_box\"><span></span><span></span><span></span></div></div>\n    </div>\n</header>\n<div class=\"sp_nav\">\n    <nav>\n        <ul>\n            <li><a href=\"/\">HOME</a></li>\n            <li><a href=\"/company/\">企業情報</a></li>\n            <li><a href=\"javascript: void(0)\" class=\"sp_nav_parent\">サービス紹介</a>\n                <div class=\"sp_nav_child\"><a href=\"/institution/\">施設警備</a></div>\n                <div class=\"sp_nav_child\"><a href=\"/machine/\">機械警備</a></div>\n                <div class=\"sp_nav_child mgb10\"><a href=\"/traffic_guidance/\">交通誘導警備</a></div>\n            </li>\n            <li><a href=\"/info/\">お知らせ</a></li>\n        </ul>\n        <div class=\"sp_otherbtn\">\n            <a href=\"/contact/\" class=\"sp_nav_contact\"><span>お問い合わせ</span></a>\n            <a href=\"https://jsg-system.com/works/\" class=\"sp_nav_rock\"><span>社員用</span></a>\n        </div>\n    </nav>\n</div>\n    \n<div class=\"sub_header\">\n    <div class=\"inner\">\n        <h1>CONTACT<span>お問い合せ</span></h1>\n    </div>\n    <img src=\"/wordpress/wp-content/uploads/2023/09/subh_contact.png\" alt=\"\">\n</div>\n<div class=\"subpage_wrap\">\n    <section>\n        <div class=\"sub_inner contact_form\">\n            \n<div class=\"wpcf7 no-js\" id=\"wpcf7-f146-o1\" lang=\"ja\" dir=\"ltr\" data-wpcf7-id=\"146\">\n<div class=\"screen-reader-response\"><p role=\"status\" aria-live=\"polite\" aria-atomic=\"true\"></p> <ul></ul></div>\n<form action=\"/contact/#wpcf7-f146-o1\" method=\"post\" class=\"wpcf7-form init\" aria-label=\"コンタクトフォーム\" novalidate=\"novalidate\" data-status=\"init\">\n<fieldset class=\"hidden-fields-container\"><input type=\"hidden\" name=\"_wpcf7\" value=\"146\" /><input type=\"hidden\" name=\"_wpcf7_version\" value=\"6.1.6\" /><input type=\"hidden\" name=\"_wpcf7_locale\" value=\"ja\" /><input type=\"hidden\" name=\"_wpcf7_unit_tag\" value=\"wpcf7-f146-o1\" /><input type=\"hidden\" name=\"_wpcf7_container_post\" value=\"0\" /><input type=\"hidden\" name=\"_wpcf7_posted_data_hash\" value=\"\" />\n</fieldset>\n<p class=\"contact_lead\">お気軽に下記の「お問い合わせフォーム」からご連絡ください。</p>\n\n<dl class=\"input_wrap\">\n    <dt>問合わせ項目<div class=\"hissu\">必須</div></dt>\n    <dd>\n        </label><span class=\"wpcf7-form-control-wrap\" data-name=\"checkbox-508\"><span class=\"wpcf7-form-control wpcf7-checkbox wpcf7-validates-as-required\"><span class=\"wpcf7-list-item first\"><label><input type=\"checkbox\" name=\"checkbox-508[]\" value=\"警備に関するご相談\" /><span class=\"wpcf7-list-item-label\">警備に関するご相談</span></label></span><span class=\"wpcf7-list-item\"><label><input type=\"checkbox\" name=\"checkbox-508[]\" value=\"お見積もりに関するご相談\" /><span class=\"wpcf7-list-item-label\">お見積もりに関するご相談</span></label></span><span class=\"wpcf7-list-item\"><label><input type=\"checkbox\" name=\"checkbox-508[]\" value=\"採用に関するご相談\" /><span class=\"wpcf7-list-item-label\">採用に関するご相談</span></label></span><span class=\"wpcf7-list-item last\"><label><input type=\"checkbox\" name=\"checkbox-508[]\" value=\"その他・当サイトに関するご相談\" /><span class=\"wpcf7-list-item-label\">その他・当サイトに関するご相談</span></label></span></span></span>\n    </dd>\n\n    <dt>会社名</dt>\n    <dd><span class=\"wpcf7-form-control-wrap\" data-name=\"text-158\"><input size=\"40\" maxlength=\"400\" class=\"wpcf7-form-control wpcf7-text\" aria-invalid=\"false\" value=\"\" type=\"text\" name=\"text-158\" /></span></dd>\n\n    <dt>お名前<div class=\"hissu\">必須</div></dt>\n    <dd><span class=\"wpcf7-form-control-wrap\" data-name=\"text-159\"><input size=\"40\" maxlength=\"400\" class=\"wpcf7-form-control wpcf7-text wpcf7-validates-as-required\" aria-required=\"true\" aria-invalid=\"false\" value=\"\" type=\"text\" name=\"text-159\" /></span></dd>\n\n    <dt>メールアドレス<div class=\"hissu\">必須</div></dt>\n    <dd><span class=\"wpcf7-form-control-wrap\" data-name=\"email-387\"><input size=\"40\" maxlength=\"400\" class=\"wpcf7-form-control wpcf7-email wpcf7-validates-as-required wpcf7-text wpcf7-validates-as-email\" aria-required=\"true\" aria-invalid=\"false\" value=\"\" type=\"email\" name=\"email-387\" /></span></dd>\n\n    <dt>メールアドレス<span>（確認用）</span><div class=\"hissu\">必須</div></dt>\n    <dd><span class=\"wpcf7-form-control-wrap\" data-name=\"email-388\"><input size=\"40\" maxlength=\"400\" class=\"wpcf7-form-control wpcf7-email wpcf7-validates-as-required wpcf7-text wpcf7-validates-as-email\" aria-required=\"true\" aria-invalid=\"false\" value=\"\" type=\"email\" name=\"email-388\" /></span></dd>\n\n    <dt>電話番号</dt>\n    <dd><span class=\"wpcf7-form-control-wrap\" data-name=\"tel-519\"><input size=\"40\" maxlength=\"400\" class=\"wpcf7-form-control wpcf7-tel wpcf7-text wpcf7-validates-as-tel\" aria-invalid=\"false\" value=\"\" type=\"tel\" name=\"tel-519\" /></span></dd>\n\n    <dt>問合わせ内容<div class=\"hissu\">必須</div></dt>\n    <dd><span class=\"wpcf7-form-control-wrap\" data-name=\"textarea-544\"><textarea cols=\"40\" rows=\"10\" maxlength=\"2000\" class=\"wpcf7-form-control wpcf7-textarea wpcf7-validates-as-required\" aria-required=\"true\" aria-invalid=\"false\" name=\"textarea-544\"></textarea></span></dd>\n</dl>  \n\n<div class=\"privacy\">\n    <div class=\"privacy_ttl\">個人情報保護方針</div>\n    <div class=\"privacy_wrap\">\n<div class=\"h_pp\">プライバシーポリシー</div>\n日本海警備保障株式会社（以下「当社」といいます）は、お客様に関する情報の取得、保有、利用について、適切な取扱いを行うことが社会的責務と認識し下記の通り実践致します。\n\n<div class=\"h_pp\">「利用目的」</div>\n　当社はお客様情報の取扱いに関し利用目的を特定し、公表又はご本人へ通知します。取得したお客様情報は、原則としてあらかじめ特定された目的以外には利用致しません。\n\n<div class=\"h_pp\">「委託・第三者提供」</div>\n　前項の利用目的を達成する上で必要な範囲において、個人情報を含んだ業務を、外部の業務委託会社に委託することがあります。<br>\n　但し、委託先の会社は弊社との間で、正式な個人情報の取扱いに関する契約を締結した会社とします。<br>\n　また、第三者への提供は一切行ないません。\n\n<div class=\"h_pp\">「安全管理」</div>\n　個人情報は、漏洩・盗難・紛失・不正アクセス等のリスクから保護するため、社内規定の整備等、十分なセキュリティ対策を講じるとともに、正確性、最新性を確保するために、必要かつ適切な措置を講じます。\n\n<div class=\"h_pp\">「開示」</div>\n　弊社は情報提供者の了解なく、第三者に提供、開示等を一切いたしません。<br>\n　また、情報提供者は弊社が保有している御本人の個人情報の開示を要求することができます。<br>\n　お問い合わせフォームよりお問い合わせ下さい。\n\n<div class=\"h_pp\">「削除・訂正」</div>\n　個人情報の確認、訂正及び削除等を希望された場合、合理的な期間、妥当な範囲内でこれに応じます。\n\n<div class=\"h_pp\">「苦情・相談」</div>\n　個人情報の取扱いに関する苦情・相談等は下記まで御連絡下さい。\n        \n<p style=\"text-align: right; margin-top: 30px;\">以上</p>\n    </div>\n\n    <div class=\"privacy_check\">\n        <span class=\"wpcf7-form-control-wrap\" data-name=\"checkbox-509\"><span class=\"wpcf7-form-control wpcf7-checkbox wpcf7-validates-as-required\"><span class=\"wpcf7-list-item first last\"><label><input type=\"checkbox\" name=\"checkbox-509[]\" value=\"個人情報保護方針に同意します\" /><span class=\"wpcf7-list-item-label\">個人情報保護方針に同意します</span></label></span></span></span>\n    </div>\n\n<label> 表示されている文字を入力してください→ <input type=\"hidden\" name=\"_wpcf7_captcha_challenge_captcha-301\" value=\"2913709746\" /><img decoding=\"async\" class=\"wpcf7-form-control wpcf7-captchac wpcf7-captcha-captcha-301\" width=\"72\" height=\"24\" alt=\"captcha\" src=\"https://jsg-system.com/wordpress/wp-content/uploads/wpcf7_captcha/2913709746.png\" />\n<span class=\"wpcf7-form-control-wrap\" data-name=\"captcha-301\"><input size=\"40\" class=\"wpcf7-form-control wpcf7-captchar\" autocomplete=\"off\" aria-invalid=\"false\" placeholder=\"英数字4文字\" value=\"\" type=\"text\" name=\"captcha-301\" /></span> </label>\n\n</div>\n\n\n<div class=\"contact_submit mar_t10\">\n    <input class=\"wpcf7-form-control wpcf7-submit has-spinner\" type=\"submit\" value=\"送信する\" />\n</div><p style=\"display: none !important;\" class=\"akismet-fields-container\" data-prefix=\"_wpcf7_ak_\"><label>&#916;<textarea name=\"_wpcf7_ak_hp_textarea\" cols=\"45\" rows=\"8\" maxlength=\"100\"></textarea></label><input type=\"hidden\" id=\"ak_js_1\" name=\"_wpcf7_ak_js\" value=\"151\"/><script type=\"text/javascript\">\n/* <![CDATA[ */\ndocument.getElementById( \"ak_js_1\" ).setAttribute( \"value\", ( new Date() ).getTime() );\n/* ]]&gt; */\n</script>\n</p><div class=\"wpcf7-response-output\" aria-hidden=\"true\"></div>\n</form>\n</div>\n\n        </div>\n    </section>\n</div>\n<div class=\"bread\">\n    <div class=\"inner\">\n        <ul>\n            <li><a href=\"/\">HOME</a></li>\n            <li>お問い合わせ</li>\n        </ul>\n    </div>\n</div>\n        \n\n<footer>\n    <div class=\"footer_contact\">\n        <div class=\"inner\">\n            <a href=\"/contact/\"><span>お問い合わせ</span></a>\n        </div>\n    </div>\n    <div class=\"footer_info\">\n        <div class=\"inner\">\n            <div class=\"footer_info_box\">\n                <div class=\"footer_signiture\">\n                    <div class=\"footer_tit\"><img src=\"/wordpress/wp-content/themes/nkh/common/images/logo.svg\" alt=\"日本海警備保障\"></div>\n                    <div class=\"footer_address\">\n                        〒920-0376<br>\n                        石川県金沢市福増町北1377番地2<br>\n                        電話番号：076-255-7711<br>\n                        FAX番号：076-255-7195\n                    </div>\n\t\t\t\t<!--\n                    <div class=\"footer_sns\">\n                        <a href=\"\" target=\"_blank\"><img src=\"https://jsg-system.com/wordpress/wp-content/themes/nkh/common/images/sns_tw.svg\" alt=\"\"></a>\n                        <a href=\"\" target=\"_blank\"><img src=\"https://jsg-system.com/wordpress/wp-content/themes/nkh/common/images/sns_fb.svg\" alt=\"\"></a>\n                    </div>\n-->\n                </div>\n                <div class=\"footer_link\">\n                    <div class=\"footer_nav\">\n                        <nav>\n                            <ul>\n                                <li><a href=\"/\">HOME</a></li>\n                            </ul>\n                            <ul>\n                                <li><a href=\"/company/\">企業情報</a></li>\n                            </ul>\n                            <ul>\n                                <li><a href=\"javascript: void(0)\" class=\"nolink\">サービス紹介</a></li>\n                                <li class=\"footernav_child\"><a href=\"/institution/\">施設警備</a></li>\n                                <li class=\"footernav_child\"><a href=\"/machine/\">機械警備</a></li>\n                                <li class=\"footernav_child\"><a href=\"/traffic_guidance/\">交通誘導警備</a></li>\n                            </ul>\n                            <ul>\n                                <li><a href=\"/info/\">お知らせ</a></li>\n                            </ul>\n                        </nav>\n                    </div>\n                    <div class=\"footer_key\">\n                        <a href=\"https://jsg-system.com/works/\"><span>社員用</span></a>\n                    </div>\n                </div>\n            </div>\n            <div class=\"signiture\">&copy; 日本海警備保障株式会社</div>\n        </div>\n    </div>\n</footer>\n\n<div class=\"pagetop\"><img src=\"https://jsg-system.com/wordpress/wp-content/themes/nkh/common/images/pagetop.svg\" alt=\"\"></div>\n\n<script>\nnew WOW().init();\n</script>\n\n</body>\n</html>","finalUrl":"https://jsg-system.com/contact/","rendered":false,"_cachedAt":"2026-06-23T23:51:33.840Z"}