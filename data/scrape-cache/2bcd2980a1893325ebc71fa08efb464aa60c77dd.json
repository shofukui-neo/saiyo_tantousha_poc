{"url":"https://e-marumiya.jp/newgraduate/","html":"<!DOCTYPE html>\n<html lang=\"ja\">\n<head>\n    <meta charset=\"utf-8\"/>    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0, maximum-scale=1.0\">\n    <meta name=\"description\" content=\"経験者の方はもちろん、新卒の方、業界業種が未経験の方、Iターン・Uターン就職、転職も大歓迎。\" />\n    <meta name=\"robots\" content=\"noimageindex\">\n\n    <meta property=\"og:locale\" content=\"ja_JP\" />\n    <meta property=\"og:type\" content=\"website\" />\n    <meta property=\"og:title\" content=\"丸宮建設株式会社｜採用情報｜宮崎県都城市\" />\n    <meta property=\"og:description\" content=\"経験者の方はもちろん、新卒の方、業界業種が未経験の方、Iターン・Uターン就職、転職も大歓迎。\" />\n    <meta property=\"og:url\" content=\"https://e-marumiya.jp/newgraduate/\" />\n    <meta property=\"og:image\" content=\"https://e-marumiya.jp/img/og.png\" />\n    <meta property=\"og:site_name\" content=\"丸宮建設株式会社\" />\n\n    <title>丸宮建設株式会社｜採用情報｜宮崎県都城市</title>\n    <link href=\"/favicon.ico\" type=\"image/x-icon\" rel=\"icon\"/><link href=\"/favicon.ico\" type=\"image/x-icon\" rel=\"shortcut icon\"/>\n    \n\t<link rel=\"stylesheet\" href=\"https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&amp;display=swap\"/>\n\t<link rel=\"stylesheet\" href=\"/css/reset.css\"/>\n\t<link rel=\"stylesheet\" href=\"/css/default.css?v=1\"/>\n    \n\t<script src=\"https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js\" defer=\"defer\"></script>\n\t<script src=\"https://cdnjs.cloudflare.com/ajax/libs/waypoints/4.0.1/jquery.waypoints.min.js\" defer=\"defer\"></script>\n\t<script src=\"/js/default.js\" defer=\"defer\"></script>\n\n        \n\t<link rel=\"stylesheet\" href=\"/css/common.css\"/>\n\t<link rel=\"stylesheet\" href=\"/css/requirement.css\"/>\n    \n\t<script src=\"/js/requirement.js\" defer=\"defer\"></script>\n\n    <!-- Google Tag Manager -->\n    <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\n    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\n   