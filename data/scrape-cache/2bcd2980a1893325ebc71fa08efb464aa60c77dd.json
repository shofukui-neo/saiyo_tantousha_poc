        </li>\n                                        </ul>\n                                        <div class=\"header_menu_recruit_btn_wrap\">\n                                            <div class=\"header_menu_recruit_btn\">\n                                                <span class=\"header_menu_recruit_btn_txt\">RECRUIT</span>\n                                                <span class=\"header_menu_recruit_btn_message\">積極採用中！</span>\n                                            </div>\n                                            <div class=\"header_menu_recruit_bottom\">\n                                                <ul class=\"header_menu_recruit_bottom_list\">\n                                                <li >\n                                                        <a href=\"/recruit/\" class=\"header_menu_recruit_bottom_link\">採用トップ</a>\n                                                    </li>\n                                                    <li class=\"is_current_page\">\n                                                        <a href=\"/newgraduate/\" class=\"header_menu_recruit_bottom_link\">募集要項（新卒）</a>\n                                                    </li>\n                                                    <li >\n                                                        <a href=\"/midcareer/\" class=\"header_menu_recruit_bottom_link\">募集要項（キャリア）</a>\n                                                    </li>\n                                                    <li >\n                                                        <a href=\"/entry/\" class=\"header_menu_recruit_bottom_link\">エントリー</a>\n                                                    </li>\n                                                </ul>\n                                            </div>\n                                        </div>\n                                    </div>\n                                </div>\n                            </div>\n                        </nav>\n                        <div class=\"header_recruit_btn_wrap\">\n                            <a href=\"/recruit/\" class=\"header_recruit_btn\">\n                                <span class=\"header_recruit_btn_txt\">\n                                    <span class=\"header_recruit_btn_txt_inner\">\n                                        <span class=\"header_recruit_btn_txt_en\">RECRUIT</span>\n                                    </span>\n                                </span>\n                                <span class=\"header_recruit_btn_txt_sekkyoku\">積極採用中！</span>\n                            </a>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </header>\n        <div class=\"menu_btn_sp_wrap sp_only\">\n            <button id=\"menu_btn_sp\" class=\"menu_btn_sp\">\n                <div class=\"menu_btn_line menu_btn_line_1\"></div>\n                <div class=\"menu_btn_line menu_btn_line_2\"></div>\n            </button>\n        </div>\n        <main class=\"main\">\n            <section class=\"recruit_page_ttl\">\n    <h1 class=\"content_ttl js_waypoint\">\n        <span class=\"content_ttl_ureshii\">\n            <span class=\"content_ttl_ureshii_1\">うれしい</span><span class=\"content_ttl_ureshii_2\">！</span>\n            <svg class=\"content_ttl_ureshii_3\" xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 1631.64 239.4\">\n                <style type=\"text/css\">\n                    .st1{fill:none;stroke:#008a67;stroke-width:17.0079;stroke-linecap:round;stroke-linejoin:round;stroke-miterlimit:10;}\n                </style>\n                <path class=\"st1 feature_ttl_path\" d=\"M8.5,230.4c0,0,198.2-146.3,706.3-214.2c168.5-22.5,224,8.5,203.5,34.6C892,84.4,772,114.7,772,114.7\n                s377.8-118.4,854.5-94.5\"/>\n            </svg>\n        </span>\n        <span class=\"content_ttl_1\">を</span>\n        <span class=\"content_ttl_2\">つくり、まもる<br class=\"sp_only\">仲間を</span>\n        <span class=\"content_ttl_3\">探しています。</span>\n    </h1>\n</section>\n\n<!-- 要項 -->\n<div class=\"requirement_wrap\" id=\"requirement\">\n    <div class=\"inner requirement_btn_wrap\" id=\"requirement_btn_wrap\">\n        <div class=\"requirement_btn\">新卒採用募集要項</div>\n        <a class=\"requirement_btn anim_hover_fade\" href=\"/midcareer/#requirement\">キャリア採用募集要項</a>\n    </div>\n    <div class=\"inner tab_area js_tab_area\">\n        <div class=\"tab_area_side\">\n            <div class=\"tab_btn_wrap tab_btn_wrap_newgraduate\" role=\"tablist\">\n                <button class=\"btn_tab js_link\" role=\"tab\" aria-selected=\"true\" aria-controls=\"panelA\" id=\"tabA\" tabindex=\"0\">建築施工管理</button>\n                <button class=\"btn_tab js_link\" role=\"tab\" aria-selected=\"false\" aria-controls=\"panelB\" id=\"tabB\" tabindex=\"-1\">土木施工管理</button>\n            </div>\n            <div class=\"tab_btn_entry_wrap tab_btn_entry_wrap_pc\">\n                <a href=\"/entry/\" class=\"tab_btn_entry js_link fw700\">\n                    <p>\n                        <span class=\"tab_btn_entry_en\">ENTRY</span>\n                        <span class=\"tab_btn_entry_jp\">エントリーする</span>\n                    </p>\n                    <span class=\"tab_btn_entry_icon\"></span>\n                </a>\n            </div>\n        </div>\n        <div class=\"tab_area_cont\">\n            <div id=\"panelA\" role=\"tabpanel\" aria-labelledby=\"tabA\" tabindex=\"0\">\n                <h2 class=\"tab_area_cont_ttl\">建築施工管理</h2>\n                <picture>\n                    <source media=\"(max-width: 750px)\" srcset=\"/img/newgraduate/img_requirement_architecture_sp.png\" width=\"622\" height=\"629\">\n                    <img class=\"tab_area_cont_img\" src=\"/img/newgraduate/img_requirement_architecture.png\" alt=\"\" width=\"888\" height=\"291\">\n                </picture>\n                <table class=\"requirement_tb\">\n                    <tr>\n                        <th>業務内容</th>\n                        <td>\n                            <p>公共・民間ともに建築工事における施工管理業務全般</p>\n                            <p class=\"requirement_tb_small\">※初めは先輩社員の補助として業務を学び、経験を積みながら、施工管理技士などの資格取得を目指していただきます。希望や適性により配属部署の変更も可能です。</p>\n                        </td>\n                    </tr>\n                    <tr>\n                        <th>応募要件</th>\n                        <td>\n                            <ul>\n                                <li>・自動車運転免許(AT限定可) ※卒業までに取得予定であれば可</li>\n                                <li>・モノづくりに興味のある方</li>\n                            </ul>\n                        </td>\n                    </tr>\n                    <tr>\n                        <th>歓迎要件</th>\n                        <td>\n                            <ul>\n                                <li>・建築関連学科卒の方</li>\n                            </ul>\n                        </td>\n                    </tr>\n                    <tr>\n                        <th>勤務地</th>\n                        <td>\n                            <p>都城本社：宮崎県都城市庄内町8031番地2</p>\n                            <p class=\"requirement_tb_small\">\n                            ※現場担当時は県内の現場事務所(一部鹿児島県も有り)\n                            </p>\n                        </td>\n                    </tr>\n                    <tr>\n                        <th>給与</th>\n                        <td>\n                            <ul>\n                                <li>・高卒：180,000円</li>\n                                <li>・高専卒：200,000円</li>\n                                <li>・大卒：230,000円</li>\n                                <li>・大学院卒：250,000円</li>\n                                <li>※既卒者、第二新卒の方も検討可</li>\n                            </ul>\n                        </td>\n                    </tr>\n                    <tr>\n                        <th>昇給・賞与</th>\n                        <td>\n                            <ul>\n                                <li>・昇給年1回、賞与年2回</li>\n                            </ul>\n                        </td>\n                    </tr>\n                    <tr>\n                        <th>勤務・休暇</th>\n                        <td>\n                            <ul>\n                                <li>・8:00-17:00（休憩90分）</li>\n                                <li>・完全週休2日制（土日祝休）</li>\n                                <li>・年間休日120日以上</li>\n                                <li>・GW、年末年始休暇、有給休暇、産休、育休、介護休暇、特別休暇 他</li>\n                            </ul>\n                        </td>\n                    </tr>\n                    <tr>\n                        <th>保険</th>\n                        <td>\n                            <ul>\n                                <li>・社会保険完備</li>\n                            </ul>\n                        </td>\n                    </tr>\n                    <tr>\n                        <th>諸手当</th>\n                        <td>\n                            <ul>\n                                <li>・通勤手当</li>\n                                <li>・資格手当</li>\n                                <li>・子女手当</li>\n                                <li>・残業手当</li>\n                                <li>・遠隔地手当</li>\n                                <li>・宿泊手当　他</li>\n                            </ul>\n                        </td>\n                    </tr>\n                    <tr>\n                        <th>福利厚生</th>\n                        <td>\n                            <ul>\n                                <li>・業務に必要な各種資格受験費用全額補助</li>\n                                <li>・資格取得お祝い金</li>\n                                <li>・退職金制度</li>\n                                <li>・健康診断（年１回）</li>\n                                <li>・部活動制度</li>\n                                <li>・家族を含めた懇親会（年２回程度）</li>\n                                <li>・社員貯金</li>\n                                <li>・特別休暇（結婚、出産、忌引他）</li>\n                                <li>・従業員専用駐車場</li>\n                                <li>・制服貸与</li>\n                            </ul>\n                        </td>\n                    </tr>\n                </table>\n            </div>\n            <div class=\"is-hidden\" id=\"panelB\" role=\"tabpanel\" aria-labelledby=\"tabB\" tabindex=\"0\">\n                <h2 class=\"tab_area_cont_ttl\">土木施工管理</h2>\n                <picture>\n                    <source media=\"(max-width: 750px)\" srcset=\"/img/newgraduate/img_requirement_civil_sp.png\" width=\"622\" height=\"629\">\n                    <img class=\"tab_area_cont_img\" src=\"/img/newgraduate/img_requirement_civil.png\" alt=\"\" width=\"888\" height=\"291\">\n                </picture>\n                <table class=\"requirement_tb\">\n                    <tr>\n                        <th>業務内容</th>\n                        <td>\n                            <p>宮崎県の土木公共工事における施工管理業務全般</p>\n                            <p class=\"requirement_tb_small\">※初めは先輩社員の補助として業務を学び、経験を積みながら、施工管理技士などの資格取得を目指していただきます。希望や適性により配属部署の変更も可能です。</p>\n                        </td>\n                    </tr>\n                    <tr>\n                        <th>応募要件</th>\n                        <td>\n                            <ul>\n                                <li>・自動車運転免許(AT限定可) ※卒業までに取得予定であれば可</li>\n                                <li>・モノづくりに興味のある方</li>\n                            </ul>\n                        </td>\n                    </tr>\n                    <tr>\n                        <th>歓迎要件</th>\n                        <td>\n                            <ul>\n                                <li>・土木関連学科卒の方</li>\n                            </ul>\n                        </td>\n                    </tr>\n                    <tr>\n                        <th>勤務地</th>\n                        <td>\n                            <p>都城本社：宮崎県都城市庄内町8031番地2</p>\n                            <p class=\"requirement_tb_small\">\n                                ※現場担当時は現場事務所(宮崎県内)\n                            </p>\n                        </td>\n                    </tr>\n                    <tr>\n                        <th>給与</th>\n                        <td>\n                            <ul>\n                                <li>・高卒：180,000円</li>\n                                <li>・高専卒：200,000円</li>\n                                <li>・大卒：230,000円</li>\n                                <li>・大学院卒：250,000円</li>\n                                <li>※既卒者、第二新卒の方も検討可</li>\n                            </ul>\n                        </td>\n                    </tr>\n                    <tr>\n                        <th>昇給・賞与</th>\n                        <td>\n                            <ul>\n                                <li>・昇給年1回、賞与年2回</li>\n                            </ul>\n                        </td>\n                    </tr>\n                    <tr>\n                        <th>勤務・休暇</th>\n                        <td>\n                            <ul>\n                                <li>・8:00-17:00（休憩90分）</li>\n                                <li>・完全週休2日制（土日祝休）</li>\n                                <li>・年間休日120日以上</li>\n                                <li>・GW、年末年始休暇、有給休暇、産休、育休、介護休暇、特別休暇 他</li>\n                            </ul>\n                        </td>\n                    </tr>\n                    <tr>\n                        <th>保険</th>\n                        <td>\n                            <ul>\n                                <li>・社会保険完備</li>\n                            </ul>\n                        </td>\n                    </tr>\n                    <tr>\n                        <th>諸手当</th>\n                        <td>\n                            <ul>\n                                <li>・通勤手当</li>\n                                <li>・資格手当</li>\n                                <li>・子女手当</li>\n                                <li>・残業手当</li>\n                                <li>・遠隔地手当</li>\n                                <li>・宿泊手当　他</li>\n                            </ul>\n                        </td>\n                    </tr>\n                    <tr>\n                        <th>福利厚生</th>\n                        <td>\n                            <ul>\n                                <li>・業務に必要な各種資格受験費用全額補助</li>\n                                <li>・資格取得お祝い金</li>\n                                <li>・退職金制度</li>\n                                <li>・健康診断（年１回）</li>\n                                <li>・部活動制度</li>\n                                <li>・家族を含めた懇親会（年２回程度）</li>\n                                <li>・社員貯金</li>\n                                <li>・特別休暇（結婚、出産、忌引他）</li>\n                                <li>・従業員専用駐車場</li>\n                                <li>・制服貸与</li>\n                            </ul>\n                        </td>\n                    </tr>\n                </table>\n            </div>\n        </div>\n        <div class=\"tab_btn_entry_wrap tab_btn_entry_wrap_sp\" id=\"tab_btn_entry_wrap_sp\">\n            <a href=\"/entry/\" class=\"tab_btn_entry fw700\">\n                <p>\n                    <span class=\"tab_btn_entry_en\">ENTRY</span>\n                    <span class=\"tab_btn_entry_jp\">エントリーする</span>\n                </p>\n                <span class=\"tab_btn_entry_icon\"></span>\n            </a>\n        </div>\n    </div>\n</div>\n\n<section class=\"requirement_flow\">\n    <div class=\"inner \">\n        <div class=\"content_en_ttl_wrap animate_en_txt js_waypoint\">\n            <p class=\"content_en_ttl fw900\">selection</p>\n        </div>\n        <div class=\"js_waypoint requirement_flow_box\">\n            <h2 class=\"fw900 requirement_flow_ttl\">選考フロー</h2>\n            <ol class=\"requirement_flow_list \">\n                <li class=\"requirement_flow_listitem\">\n                    <dl>\n                        <dt class=\"requirement_flow_list_ttl\">エントリー</dt>\n                        <dd class=\"requirement_flow_list_txt\">エントリーフォームより<br class