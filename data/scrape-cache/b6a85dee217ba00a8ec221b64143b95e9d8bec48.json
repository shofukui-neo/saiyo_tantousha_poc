 cubic-bezier(0.1, 0.57, 0.1, 1); transition-duration: 0ms; transform: translate(0px, 0px) translateZ(0px);\">\r\n\t\t\t\t\t\t<ul>\r\n\t\t\t\t\t\t<li><a href=\"https://chopro.co.jp/recruit#message\">代表挨拶</a></li>\r\n\t\t\t\t\t\t<li><a href=\"https://chopro.co.jp/recruit#interview\">社員インタビュー</a></li>\r\n\t\t\t\t\t\t<li><a href=\"https://chopro.co.jp/recruit#devision\">職種紹介</a></li>\r\n\t\t\t\t\t\t<li><a href=\"https://chopro.co.jp/recruit#gallery\">会社の風景</a></li>\r\n\t\t\t\t\t\t<li><a href=\"https://chopro.co.jp/recruit#faq\">よくある質問</a></li>\r\n\t\t\t\t\t\t<li><a href=\"https://chopro.co.jp/recruit#about\">採用情報</a></li>\t\t\t\t\t\r\n\t\t\t\t\t\t</ul>\r\n\t\t\t\t\t\t<a href=\"https://chopro.co.jp/'\" class=\"corpo\" target=\"_blank\">\t<img src=\"https://chopro.co.jp/img/recruit/common/icon_corpo.png\" alt=\"\"><span>コーポレートサイト</span></a>\r\n\t\t\t\t\r\n\t\t\t\t\t</div><!--//drawer-menu-->\r\n\t\t\t\t</nav><!--//drawer-nav-->\r\n\r\n\t\t\t</header>\n<section id=\"image\">\n\n<figure>\n\t<div class=\"catch view-lowup\"><p><b>長崎で</b></p><br><p><b>活躍したい</b></p></div>\n\t<img src=\"https://chopro.co.jp/img/recruit/profile/03/mv.jpg\" alt=\"\" class=\"pc\">\n\t<img src=\"https://chopro.co.jp/img/recruit/profile/03/mv-sp.jpg\" alt=\"\" class=\"sp\">\n</figure>\n\n<div class=\"profile\">\n\t<div class=\"name view-lowup\">\n\t\t<dl><dt>経理部</dt>\n\t\t\t<dd><p>島田 紗絵</p><em>SAE SHIMADA</em></dd>\n\t\t</dl>\n\n\t\t<div class=\"career\">経理部門</div>\n\t\t<div class=\"career\">県外私立大 教育学部 2020年入社</div>\n\t</div><!--//name-->\n\n\t<div class=\"titlebox\">\n\t<h4 style=\"color: #222; text-align: left;\"><span>SCHEDULE</span><em>1日のスケジュール</em></h4>\n\t</div>\t\n\t<div class=\"flow\">\n\t\t\t<figure class=\"view-lowright\"><img src=\"https://chopro.co.jp/img/recruit/profile/03/p01.jpg\" alt=\"\"></figure>\n\t\t<ul class=\"view-lowleft\">\n\t\t\t<li>\n\t\t\t\t<dl>\n\t\t\t\t\t<dt>6:30</dt>\n\t\t\t\t\t<dd><b>起床</b><span></span></dd>\n\t\t\t\t</dl>\n\t\t\t</li>\n      <li>\n\t\t\t\t<dl>\n\t\t\t\t\t<dt>7:40</dt>\n\t\t\t\t\t<dd><b>出発</b><span></span></dd>\n\t\t\t\t</dl>\n\t\t\t</li>\n      <li>\n\t\t\t\t<dl>\n\t\t\t\t\t<dt>8:10</dt>\n\t\t\t\t\t<dd><b>会社到着</b><span></span></dd>\n\t\t\t\t</dl>\n\t\t\t</li>\n\n\t\t\t<li>\n\t\t\t\t<dl>\n\t\t\t\t\t<dt>8:15</dt>\n\t\t\t\t\t<dd><b>業務開始</b><span>メールチェック、業務の進捗確認、<br>スケジュールの確認</span></dd>\n\t\t\t\t</dl>\n\t\t\t</li>\n      <li>\n\t\t\t\t<dl>\n\t\t\t\t\t<dt>8:30</dt>\n\t\t\t\t\t<dd><b>朝礼</b><span>共有事項確認</span></dd>\n\t\t\t\t</dl>\n\t\t\t</li>\n\n\t\t\t<li>\n\t\t\t\t<dl>\n\t\t\t\t\t<dt>9:00</dt>\n\t\t\t\t\t<dd><b>会議資料準備</b></dd>\n\t\t\t\t</dl>\n\t\t\t</li>\n\n\t\t</ul>\n\t\t<ul class=\"view-lowleft\">\n\t\t\t\t\t\t<li>\n\t\t\t\t<dl>\n\t\t\t\t\t<dt>10:00</dt>\n\t\t\t\t\t<dd><b>請求書の確認・処理</b><span>内容の照合、会計システムへの入力</span></dd>\n\t\t\t\t</dl>\n\t\t\t</li>\n\t\t\t<li>\n\t\t\t\t<dl>\n\t\t\t\t\t<dt>12:00</dt>\n          <dd><b>昼食・休憩</b></dd>\n\t\t\t\t</dl>\n\t\t\t</li>\n      \n      <li>\n\t\t\t\t<dl>\n\t\t\t\t\t<dt>13:00</dt>\n          <dd><b>会議</b><span>業務課題解決のための会議</span></dd>\n\t\t\t\t</dl>\n\t\t\t</li>\n      \n      <li>\n\t\t\t\t<dl>\n\t\t\t\t\t<dt>15:30</dt>\n          <dd><b>退社</b></dd>\n\t\t\t\t</dl>\n\t\t\t</li>\n      \n      <li>\n\t\t\t\t<dl>\n\t\t\t\t\t<dt>16:30</dt>\n          <dd><b>トレーニング開始</b></dd>\n\t\t\t\t</dl>\n\t\t\t</li>\n\t\t\t\n\t\t\t<li>\n\t\t\t\t<dl>\n\t\t\t\t\t<dt>19:00</dt>\n\t\t\t\t\t<dd><b>トレーニング終了</b></dd>\n\t\t\t\t</dl>\n\t\t\t</li>\n      <li>\n\t\t\t\t<dl>\n\t\t\t\t\t<dt>19:30</dt>\n\t\t\t\t\t<dd><b>帰宅</b></dd>\n\t\t\t\t</dl>\n\t\t\t</li>\n\t\t</ul>\n\t\n\t</div><!--//flow-->\n</div><!--//profile-->\n</section>\n\n<section id=\"qa\">\n\t<div class=\"inner\">\n\t\t<div class=\"titlebox\">\n\t\t<h4 style=\"color: #00a0e9;\" class=\"marginb\"><span>INTERVIEW</span><em>社員インタビュー</em></h4>\n\t\t</div>\t\n\t\t\n\t\t<div class=\"qabox\">\n      <div class=\"column__flex\">\n\t\t\t<article class=\"view-lowup\">\n\t\t\t\t<div class=\"honbun\">\n\t\t\t\t\t<div class=\"titlebox\">\n\t\t\t\t\t<h4 style=\"color: #00a0e9;\"><span>Q.01</span></h4>\n\t\t\t\t\t<div class=\"title marginb\">どんな仕事をしていますか。</div>\n\t\t\t\t\t<p>経理部門に在籍しています。日常の業務では、主に請求書の処理や管理を行っています。<br class=\"br\">会社の経営や資産管理にも関わってくる、責任感のある業務です。<br class=\"br\">\nまた、スポーツと仕事を両立する社員として陸上競技にも取り組んでいます。</p>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</article>\n\t\t\t\t\n\t\t\t<article class=\"view-lowup\">\n\t\t\t\t<div class=\"honbun\">\n\t\t\t\t\t<div class=\"titlebox\">\n\t\t\t\t\t<h4 style=\"color: #00a0e9;\"><span>Q.02</span></h4>\n\t\t\t\t\t<div class=\"title marginb\">入社したきっかけは？</div>\n\t\t\t\t\t<p>県外の企業に就職していたのですが、県内での就職を念頭に競技と両立できる環境はないか探している時に、「チョープロは社員のスポーツ活動に力を入れているよ」と紹介してもらったのがきっかけです。<br class=\"br\">長崎にもそういう企業があるんだ！と嬉しかったのを覚えています。<br class=\"br\">\n私自身、長崎に恩返しがしたいという想いがあったので、「この街のエネルギーになりたい」という会社スローガンを掲げているところにも、とても魅力を感じました。</p>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t\n\t\t\t</article>\t\n\t\t\t\n\t\t\t<article class=\"view-lowup\">\n\t\t\t\t<div class=\"honbun\">\n\t\t\t\t\t<div class=\"titlebox\">\n\t\t\t\t\t<h4 style=\"color: #00a0e9;\"><span>Q.03</span></h4>\n\t\t\t\t\t<div class=\"title marginb\">会社の好きなところは？</div>\n\t\t\t\t\t<p>スポーツに取り組む社員に理解があるところです。<br class=\"br\">時短勤務や試合での休暇取得など、活動環境をサポートしてくれています。<br class=\"br\">「調子はどう？」「頑張ってね」などの声がけをいただくことも多く、いつも力をもらっています。<br class=\"br\">早く結果を出して恩返しがしたいです！</p>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t\n\t\t\t</article>\t\n\t\t\t\n\t\t\t<article class=\"view-lowup\">\n\t\t\t\t<div class=\"honbun\">\n\t\t\t\t\t<div class=\"titlebox\">\n\t\t\t\t\t<h4 style=\"color: #00a0e9;\"><span>Q.04</span></h4>\n\t\t\t\t\t<div class=\"title marginb\">印象に残っている仕事について<br class=\"br\">教えて下さい。</div>\n\t\t\t\t\t<p>現行しているものですが、経理業務をより良くしていくための改善プロジェクトに携わっていることです。<br class=\"br\">まだまだ知識不足なので話についていくのがやっとという感じですが、会社全体のことを考えなければいけないのでとても勉強になり、社員としての責任を感じています。</p>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\n\t\t\t\n\t\t\t</article>\t\n\t\t\t\n\t\t\t<article class=\"w-100 view-lowup\">\n\t\t\t\t<div class=\"honbun\">\n\t\t\t\t\t<div class=\"titlebox\">\n\t\t\t\t\t<h4 style=\"color: #00a0e9;\"><span>Q.05</span></h4>\n\t\t\t\t\t<div class=\"title marginb\">県外ではなく長崎を選んだ理由は？</div>\n\t\t\t\t\t<p>「より地元に根付いたアスリートとして恩返しがしたい」「競技だけではなく、仕事でも長崎に貢献できないか」と思うようになったからです。</p>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</article>\t\n\t\t\t\n\t\t\t<article class=\"w-100 view-lowup\">\n\t\t\t\t<div class=\"honbun\">\n\t\t\t\t\t<div class=\"titlebox\">\n\t\t\t\t\t<h4 style=\"color: #00a0e9;\"><span>Q.06</span></h4>\n\t\t\t\t\t<div class=\"title marginb\">今までのキャリアとこれからの<br class=\"br\">キャリアプランについて教えて下さい。（今後やりたいことなど）</div>\n\t\t\t\t\t<p>入社して約半年は総務として、受付や備品管理、広報などの業務を行っていました。<br class=\"br\">今の経理部門に移動してから約1年間は現預金の管理に携わり、その後は請求書処理関係の業務を行っています。<br class=\"br\">まだまだ学ぶべきことも多く、日々勉強です。資格取得など、今後はさらに知識を深めていきたいです。</p>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t\t\t<figure><img src=\"https://chopro.co.jp/img/recruit/profile/03/p03.jpg\" alt=\"\"></figure>\t\t\n\t\t\t\n\t\t\t</article>\t\n\t\t\t\n\t\t\t<article class=\"view-lowup\">\n\t\t\t\t<div class=\"honbun\">\n\t\t\t\t\t<div class=\"titlebox\">\n\t\t\t\t\t<h4 style=\"color: #00a0e9;\"><span>Q.07</span></h4>\n\t\t\t\t\t<div class=\"title marginb\">学生時代の思い出は？</div>\n\t\t\t\t\t<p>部活動に没頭したことです。仲間と一緒にたくさん笑い、たくさん泣き、結果が出なくて苦しい時期も諦めず乗り越えてきました。<br class=\"br\">\nその結果、大学時には100m日本選手権入賞、創部以来初となる4×100mリレー関東インカレ・全日本インカレ優勝を達成することができました。<br class=\"br\">\nこの時の諦めない経験が今でも活きていると感じます。</p>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t\n\t\t\t</article>\t\n\t\t\t\n\t\t\t<article class=\"view-lowup\">\n\t\t\t\t<div class=\"honbun\">\n\t\t\t\t\t<div class=\"titlebox\">\n\t\t\t\t\t<h4 style=\"color: #00a0e9;\"><span>Q.08</span></h4>\n\t\t\t\t\t<div class=\"title marginb\">オフの日の楽しみは？(コロナが終息したらやりたいことは？)</div>\n\t\t\t\t\t<p>休日は練習や試合に出ていることが多いです。オフの時間は、家でゆっくりしたり愛犬と遊んだりするのが楽しみです！</p>\n\t\t\t\t\t</div>\n\t\t\t\t\t\n\t\t\t\t</div>\n\t\t\t\n\t\t\t</article>\n\n      </div>\n\t\t</div><!--//qabox-->\n\t</div><!--//inner-->\n\n\n\t<article class=\"last view-lowup w-100\">\n\t<figure class=\"sp\"><img src=\"https://chopro.co.jp/img/recruit/profile/03/p02.jpg\" alt=\"\"></figure>\t\t\n\t\t<div class=\"inner\">\t\n\t<div class=\"honbun\">\n\t<div class=\"titlebox\">\n\t<div class=\"title marginb\">どんな人と一緒に働きたいですか？</div>\n\t<p>「思いやりのある人」、「一生懸命に取り組む人」と一緒に働きたいです。<br class=\"br\">\nお客様や社員同士など、どんな仕事にも人との関わりがあります。信頼関係を築けるか、連携が取れた仕事をできるかは、どれだけ相手の立場に立って考えられるかが大切になると思います。そして何事にも一生懸命に取り組めば、最初は失敗してしまったとしても、後に大きい成果が得られるはずです。</p>\n\t</div>\n\t</div>\n\t<figure class=\"pc\"><img src=\"https://chopro.co.jp/img/recruit/profile/03/p02.jpg\" alt=\"\"></figure>\n\t\t\t</div>\t\n\t</article>\t\n\n</section>\n\n\n<section id=\"interview\" class=\"view-lowup\">\n\t<div class=\"interviewbox\">\n\t\t\n\t\t\n\t\t\t<div class=\"titlebox\">\n\t\t\t\t\n\t\t\t\t\t\t\t\t<h4 style=\"color: #00a0e9;\"><span>INTERVIEW</span></h4>\n\t\t\t\t<div class=\"title marginb2\">他の社員の<br class=\"br2\">インタビューはこちら</div>\t\n\t\t\t\t\t\t\t</div>\n\t\t\n\t\t\t<ul>\n\t\t\t\t\n\t\t\t\t\t\t\t\t<li>\n\t\t\t\t\t<span>01 INTERVIEW</span>\n\t\t\t\t\t<div class=\"catch\"><p><b>ポジティブで</b></p><br><p><b>明るく</b></p></div>\n\t\t\t\t\t<a href=\"https://chopro.co.jp/recruit/people02\">\n\t\t\t\t\t\t<figure class=\"scale\">\n\t\t\t\t\t\t\t<img src=\"https://chopro.co.jp/img/recruit/index/hirakino.jpg\" alt=\"\">\n\t\t\t\t\t\t\t<img src=\"https://chopro.co.jp/img/recruit/index/hirakino02_h.jpg\" alt=\"\">\n\t\t\t\t\t\t</figure>\n\t\t\t\t\t\t\n\t\t\t\t\t\t<div class=\"profile\">\n\t\t\t\t\t\t\t<dl><dt>顧客サービス部</dt><dd><b>サービス部門</b><p>2005年入社</p></dd></dl>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t\n\t\t\t\t\t</a>\n\t\t\t\t</li>\n\t\t\t\t\n\t\t\t\t\t\t\t\t\n\t\t\t\t\t\t\t\t\t\t\t\t\n\t\t\t\t\t\t\t\t<li>\n\t\t\t\t\t<span>03 INTERVIEW</span>\n\t\t\t\t\t<div class=\"catch\"><p><b>地元に</b></p><br><p><b>恩返しを</b></p></div>\n\t\t\t\t\t\n\t\t\t\t\t<a href=\"https://chopro.co.jp/recruit/people04\">\n\t\t\t\t\t\t<figure class=\"scale\"><img src=\"https://chopro.co.jp/img/recruit/index/matsuo.jpg\" alt=\"\">\n\t\t\t\t\t\t<img src=\"https://chopro.co.jp/img/recruit/index/matsuo_h.jpg\" alt=\"\">\n\t\t\t\t\t\t</figure>\n\t\