/javascript'; fjs.async = true; fjs.id = \"fjssync\"; var timestamp = new Date;fjs.src = ('https:' == document.location.protocol ? 'https' : 'http') + '://hm.mieru-ca.com/service/js/mieruca-hm.js?v='+ timestamp.getTime(); var x = document.getElementsByTagName('script')[0]; x.parentNode.insertBefore(fjs, x); };\nsetTimeout(mieruca, 500); document.readyState != \"complete\" ? (window.attachEvent ? window.attachEvent(\"onload\", mieruca) : window.addEventListener(\"load\", mieruca, false)) : mieruca();\n})();\n</script>\n<!-- End Mieruca Embed Code -->\n</head>\r\n\r\n<body id=\"PageSeek\">\r\n<!-- skip_nav -->\r\n<div id=\"page_top\">\r\n  <p class=\"skip\">ページの先頭です。</p>\r\n  <p class=\"skip\"><a href=\"#skip_menu\">メインメニューへ移動します。</a></p>\r\n  <p class=\"skip\"><a href=\"#skip_honbun\">本文へ移動します。</a></p>\r\n  <p class=\"skip\"><a href=\"#skip_footer\">フッターへ移動します。</a></p>\r\n</div>\r\n<!-- /skip_nav --> \r\n\r\n<!-- // Header START // -->\r\n<header>\r\n<div id=\"HeadSubMenu\">\r\n<ul class=\"clearfix\">\r\n  <li><a href=\"/inquiry/\">お問い合わせ</a></li>\r\n  <li><a href=\"/profile/office.html\">アクセス</a></li>\r\n  <li><a href=\"/\">ウインコーポレートサイト</a></li>\r\n</ul>\r\n</div><!-- /#HeadSubMenu -->\r\n\r\n<p id=\"skip_menu\" class=\"skip\">メインメニューです。</p>\r\n<div id=\"HeadEntryMenu\" class=\"clearfix\">\r\n  <div class=\"innerBlock\">\r\n    <p><a href=\"/recruit/\"><img src=\"/recruit/common/images/logo.png\" width=\"388\" height=\"34\" alt=\"株式会社ウイン 採用情報\"/></a></p>\r\n    <ul class=\"clearfix button\">\r\n      <li><a href=\"/recruit/entry/#section01\">新卒採用</a></li>\r\n      <li><a href=\"/recruit/entry/#section02\">キャリア採用</a></li>\r\n    </ul>\r\n  </div>\r\n</div><!-- /#HeadEntryMenu --><div id=\"HeadGlobalMenu\">\r\n  <ul class=\"clearfix button\">\r\n    <li><a href=\"/recruit/vision/\">ビジョン</a></li>\r\n    <li><a href=\"/recruit/seek/\">求める人材</a></li>\r\n    <li><a href=\"/profile/approach.html\">ウインの取組み</a></li>\r\n    <li><a href=\"/recruit/department/\">部署紹介</a></li>\r\n    <li><a href=\"/recruit/jobcategory/\">募集職種</a></li>\r\n    <li><a href=\"/recruit/flow/\">採用の流れ</a></li>\r\n  </ul>\r\n</div><!-- /#HeadGlobalMenu --></header>\r\n<!-- // Header END // -->\r\n\r\n\r\n<!-- // Contents START // -->\r\n\r\n<!-- topicPath -->\r\n<div id=\"topicPath\">\r\n  <ul class=\"clearfix\">\r\n    <li><a href=\"./\">求める人物像</a></li>\r\n    <li><a href=\"message.html\">採用担当者から</a></li>\r\n  </ul>\r\n</div>\r\n<!-- /topicPath -->\r\n\r\n<p id=\"skip_honbun\" class=\"skip\">本文です。</p>\r\n\r\n<h1>求める人物像<span>Human resources to find</span></h1>\r\n\r\n\r\n<section id=\"section01\">\r\n\t<div>\r\n\t<h2>当社の仕事のスタンス</h2>\r\n  <p>私たちは、お客様のご要望に対して、ただ問題解決の提案をするだけではありません。<br>どの方法が最適なのかということはもちろん、その先の展開までを見通し、<br>\r\n    さらにはお客様の業務が円滑に回るようさまざまな方向から検証し、ご提案を行っています。<br>必ずフェーズ分けを行い、第一フェーズ完了後、推移を分析し、第二フェーズでさらに成功へ導く施策を行います。</p>\r\n  </div>\r\n</section>\r\n\r\n<section id=\"section02\">\r\n\t<div>\r\n\t<h2>当社のスタンスを実行するためには</h2>\r\n  <p>当社では、営業とプロデューサー・ディレクターが一緒にお客様のご要望をヒアリングし、<br>技術者も加わった三者会議で方向性を決めていきます。<br>当社だけで営業からプロデュース、構築を行うことが主なため、<br>個々の能力と団結力が必要になりますが、実現は一人だけの力ではできません。<br>同じ目的を共有し、一緒に成長していける仲間が必要です。</p>\r\n  </div>\r\n</section>\r\n\r\n<section id=\"section03\">\r\n\t<div>\r\n\t<h2>当社ではこんな方を求めています</h2>\r\n  <ul>\r\n  \t<li><img src=\"../common/images/icon_no01.png\" width=\"36\" height=\"36\" alt=\"\"/>より自分たちの価値を高める努力ができる人</li>\r\n    <li><img src=\"../common/images/icon_no02.png\" width=\"36\" height=\"36\" alt=\"\"/>仲間の能力にあわせながら、夢を共有し、一緒に成長していける人</li>\r\n    <li><img src=\"../common/images/icon_no03.png\" width=\"36\" height=\"36\" alt=\"\"/>部の雰囲気を良くし、仕事を面白くしてくれる人</li>\r\n    <li><img src=\"../common/images/icon_no04.png\" width=\"36\" height=\"36\" alt=\"\"/>働きがいや働きやすさを、自分たちで作っていける人</li>\r\n  </ul>\r\n  <p>そんな積極性にあふれる方のご応募を、お待ちしております。</p>\r\n\t<p class=\"button\"><a class=\"btn\" href=\"message.html\">採用担当者からのメッセージ</a></p>\r\n  </div>\r\n</section>\r\n\r\n<!-- // Contents END // -->\r\n\r\n\r\n<!-- // Footer START // -->\r\n<footer>\r\n<div id=\"FooterNavi\" class=\"button\">\r\n<ul class=\"col2 clearfix\">\r\n  <li><a href=\"/recruit/entry/#section01\">新卒採用</a></li>\r\n  <li><a href=\"/recruit/entry/#section02\">キャリア採用</a></li>\r\n</ul>\r\n<ul class=\"col3 clearfix\">\r\n  <li><a href=\"/recruit/department/\">部署紹介</a></li>\r\n  <li><a href=\"/recruit/jobcategory/\">募集職種</a></li>\r\n  <li><a href=\"/recruit/flow/\">採用の流れ</a></li>\r\n</ul>\r\n</div><!-- /#FooterNavi -->\r\n<div id=\"gotop\"><a href=\"#page_top\"><img class=\"imgover\" src=\"/recruit/common/images/btn_pagetop.png\" width=\"70\" height=\"70\" alt=\"このページの一番上へ\" /></a></div> \r\n<p id=\"skip_footer\" class=\"skip\">フッターです。</p>\r\n</footer>\r\n<!-- // Footer END // -->\r\n\r\n\r\n</body>\r\n</html>\r\n","finalUrl":"https://www.pro-win.co.jp/recruit/seek/","rendered":false,"_cachedAt":"2026-06-22T16:02:09.912Z"}