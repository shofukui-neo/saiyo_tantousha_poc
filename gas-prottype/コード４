// ---------- L1: 商材 → ICP ----------
function buildIcp_(productDesc, existing){
  if(!productDesc){ return null; }
  var prompt =
    'あなたはB2B SaaSのRevOpsアナリストです。次の自社商材から理想顧客プロファイル(ICP)を日本語でJSON出力してください。\n' +
    '商材説明:\n' + productDesc + '\n' +
    (existing ? '既存受注（参考・類似性を学習）:\n' + existing + '\n' : '') +
    '出力キー: primary_value_prop(string), target_industries(string[]), ' +
    'company_size{employees_min:int, employees_max:int}, geography(string[]都道府県), ' +
    'buying_signals(string[]), pain_points(string[]), ' +
    'buyer_persona{titles:string[], departments:string[]}, exclusion(string[])';
  return geminiJson_(prompt, { maxTokens: 1200 });
}

// ---------- L2-a: 国税庁 法人番号 Web-API v4（商号→法人番号） ----------
function ntaFindByName_(name){
  var appId = cfg_('NTA_APP_ID');
  if(!appId){ log_('WARN', 'ntaFindByName_', 'NTA_APP_ID未設定'); return null; }
  // type=12: XML / mode=2: 部分一致 / close=0: 登記閉鎖を除く
  var url = CONFIG.NTA_BASE + '/name'
    + '?id=' + encodeURIComponent(appId)
    + '&name=' + encodeURIComponent(name)
    + '&type=12&mode=2&close=0';
  var res = fetchWithRetry_(url, {}, 3);
  if(!res || res.getResponseCode() >= 400){ log_('WARN', 'ntaFindByName_', 'HTTP ' + (res && res.getResponseCode())); return null; }
  try{
    var root = XmlService.parse(res.getContentText()).getRootElement();
    var corp = findFirstChild_(root, 'corporation');
    if(!corp) return null;
    return {
      corporateNumber: childText_(corp, 'corporateNumber'),
      name: childText_(corp, 'name'),
      prefecture: childText_(corp, 'prefectureName'),
      city: childText_(corp, 'cityName')
    };
  }catch(e){ log_('WARN', 'ntaFindByName_', e); return null; }
}

function findFirstChild_(el, tag){
  var kids = el.getChildren();
  for(var i = 0; i < kids.length; i++){
    if(kids[i].getName() === tag) return kids[i];
    var deep = findFirstChild_(kids[i], tag);
    if(deep) return deep;
  }
  return null;
}
function childText_(el, tag){ var c = findFirstChild_(el, tag); return c ? c.getText() : ''; }



// ---------- L2-c: gBizINFO 条件検索（業種×地域 → 候補） ----------
function gbizSearch_(params){
  var token = cfg_('GBIZ_TOKEN');
  if(!token){ return []; }
  var q = [];
  if(params.name)         q.push('name=' + encodeURIComponent(params.name));
  if(params.prefecture)   q.push('prefecture=' + encodeURIComponent(params.prefecture));
  if(params.businessItem) q.push('business_item=' + encodeURIComponent(params.businessItem));
  q.push('page=1');
  var url = CONFIG.GBIZ_BASE + '?' + q.join('&');
  var res = fetchWithRetry_(url, { headers: { 'X-hojinInfo-api-token': token, 'Accept': 'application/json' } }, 3);
  if(!res || res.getResponseCode() >= 400){ return []; }
  try{
    var arr = (JSON.parse(res.getContentText())['hojin-infos']) || [];
    return arr.map(function(info){
      return {
        corporateNumber: info.corporate_number || info.corporateNumber || '',
        name: info.name || '',
        representativeName: info.representative_name || '',
        websiteUrl: info.company_url || '',
        prefecture: info.location || ''
      };
    });
  }catch(e){ log_('WARN', 'gbizSearch_', e); return []; }
}


